#** #####################################################################################
#*
#* Function:   GETTYPEOFFIELD
#*
#* Purpose:    Returns the X3 data type for a given pair of table name and field name.
#*             Defaults to "A" (alphanumeric field).
#*
#*
#* Parameters:
#*
#* @param TABLENAME          local char()   Table name
#* @param FIELDNAME          local char()   Field name
#*
#*! #####################################################################################

Funprog GETTYPEOFFIELD( TABLENAME, FIELDNAME )
Value Char TABLENAME
Value Char FIELDNAME

    Local Char FIELDTYPE(255) : FIELDTYPE= "A"
    Local Integer I

    # Cut field name dimension.
    For I= 1 To len( FIELDNAME )
        If mid$( FIELDNAME, I, 1 ) = '('
            FIELDNAME= left$( FIELDNAME, I - 1 )
            Break
        Endif
    Next

    Read [ATZ]CODZONE = TABLENAME; FIELDNAME
    If !fstat
        FIELDTYPE= [F:ATZ]CODTYP
    Endif
End FIELDTYPE



#** #####################################################################################
#*
#* Function:   GETDIRSEPARATOR
#*
#* Purpose:    Returns the directory separator of the current X3 installation.
#*
#*
#* Parameters: None
#*
#*! #####################################################################################

Funprog GETDIRSEPARATOR()
    Local Char DIRSEP(1)
    Local Char OS(255)
    Local Char MACHINE(255)
    Local Char APPPATH(255) : APPPATH = filpath( "", "", "" ) : # Folder path on the server
    Local Integer POS : POS = instr(1, APPPATH , "@")

    If POS
        MACHINE = left$( APPPATH, POS - 1 )
    Else
        MACHINE = ""
    Endif

    Call GET_OS( MACHINE, OS ) From ORDSYS
    If OS = "unix"
        DIRSEP = "/"
    Else
        DIRSEP = "\"
    Endif
End DIRSEP



#** #####################################################################################
#*
#* Procedure:  READTEXTFILETOACLOB
#*
#* Purpose:    Reads a text file and writes it into the CLOB field in the ACLOB table.
#*
#*
#* Parameters:
#*
#* @param ID                 local char()   The identifier (e. g. "GDPDU")
#* @param NAMBLB             local char()   The name of the file to store in the table.
#* @param NAMEOFFILE         local char()   The path and the filename of the text file.
#*
#*! #####################################################################################

Subprog READTEXTFILETOACLOB( ID, NAMBLB, NAMEOFFILE )
Value Char ID
Value Char NAMBLB
Value Char NAMEOFFILE

    # Open ACLOB table.
    If !clalev([F:ACBX]) : Local File ACLOB [ACBX] : Endif

    # Open the text file using one huge block (no field and no row separator) for reading.
    Openi NAMEOFFILE Using [TT]
    adxifs = ""
    adxirs = ""

    # Begin transaction
    Trbegin [ACBX]

    # Delete eventually already existing records.
    Delete [ACBX] Where CODBLB = ID

    # Clean the record.
    Raz [ACBX]

    # Read data into the CLOB.
    Rdseq [F:ACBX]CLOB Using [TT]

    # Close text file.
    Openi Using [TT]

    # Add meta data.
    [F:ACBX]CODBLB = ID
    [F:ACBX]NAMBLB = NAMBLB
    [F:ACBX]TYPDOC = "TXT"
    [F:ACBX]CREUSR = GUSER
    [F:ACBX]CREDAT = date$
    [F:ACBX]CRETIM = time
    Write [ACBX]

    If !fstat
        # Commit transaction.
        Commit
    Else
        # Error handling
        Rollback
        Call ECR_TRACE( mess(12,141,1) - NAMEOFFILE, 1 ) From GESECRAN # 'Importing not possible on file'
    Endif

    # Close ACLOB table.
    If clalev([F:ACBX]) : Close Local File [ACBX] : Endif
End



#** #####################################################################################
#*
#* Procedure:  WRITETEXTFILEFROMACLOB
#*
#* Purpose:    Writes a text file from a clob in ACLOB table.
#*
#*
#* Parameters:
#*
#* @param ID           Value Char()     The identifier (e. g. "GDPDU")
#* @param EXPORTDIR    Variable Char()  The export path for the text file.
#*
#*! #####################################################################################

Subprog WRITETEXTFILEFROMACLOB( ID, EXPORTDIR )
Value Char ID
Variable Char EXPORTDIR

    # Open ACLOB table.
    If !clalev([F:ACBX]) : Local File ACLOB [ACBX] : Endif

    # Try getting the text file from table ACLOB in the current folder.
    Read [ACBX] = ID
    If fstat
        # NOT FOUND: Try in the parent folder.
        If clalev([F:ACBX]) : Close Local File [ACBX] : Endif
        If !clalev([F:ACBX]) : Local File =GDOSX3+".ACLOB"[ACBX] : Endif

        Read [ACBX] = ID
        If fstat
            Call ECR_TRACE( mess(13,141,1), 1 ) From GESECRAN #  'Exporting not possible on file'
            Goto WTFACEXIT
        Endif
    Endif

    # Open the text file using one huge block (no field and no row separator) for writing.
    EXPORTDIR += [F:ACBX]NAMBLB
    Openo EXPORTDIR, 0 Using [TT]
    adxifs = ""
    adxirs = ""

    # Write clob to text file.
    Wrseq [F:ACBX]CLOB Using [TT]

    # Close text file.
    Openo Using [TT]

$WTFACEXIT
    # Close ACLOB table.
    If clalev([F:ACBX]) : Close Local File [ACBX] : Endif
End



# 2017-04-13 DNE INSERT BEGIN (X3-31121 / X3-33368)
#** #####################################################################################
#*
#* Procedure:  EXPORTDTD
#*
#* Purpose:    Writes the file "gdpdu-01-08-2002.dtd" to disk.
#*
#*
#* Parameters:
#*
#* @param FILNAM           Value Char()     The filename of the DTD file
#*                                          (gdpdu-01-08-2002.dtd)
#*
#*! #####################################################################################

Subprog EXPORTDTD(FILNAM)
Value Char FILNAM
    Local Clbfile DTD

    DTD = '<?xml version="1.0" encoding="UTF-8"?>' + chr$(13) + chr$(10)
& + '<!--Versions available:' + chr$(13) + chr$(10)
& + '1.1 (August-01-2002)' + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Start Simple Types -->' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Supplementary Vocabulary -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Version (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT Location (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT Comment (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT Length (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT References (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT From (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT To (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Specifying a maximum length for a VariableLength column can' + chr$(13) + chr$(10)
& + "     reduce a VariableLength tables' import time. If MaxLength" + chr$(13) + chr$(10)
& + '     is not specified then we parse URL to determine the MaxLength' + chr$(13) + chr$(10)
& + '     for each column.' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + '     * Only applies to VariableLength tables. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT MaxLength (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Specifies which character (if any) encapsulates a' + chr$(13) + chr$(10)
& + '     VariableLength AlphaNumeric column.' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + '     Doublequote is the default TextEncapsulator "' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + '     * Only applies to VariableLength tables. (Optional) -->' + chr$(13) + chr$(10)
& + '<!ELEMENT TextEncapsulator (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Specifies how many digits appear to the right of the decimal symbol.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     CAUTION: Results are undefined when importing numeric data with' + chr$(13) + chr$(10)
& + '              greater Accuracy than the Accuracy defined in index.xml' + chr$(13) + chr$(10)
& + '        ' + chr$(13) + chr$(10)
& + '          For example trying to import the value 1000,25 with an' + chr$(13) + chr$(10)
& + '          accuracy of 0 might result in 1000 or an error. This' + chr$(13) + chr$(10)
& + '          behavior is specific to the implementation.' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + "     Zero is the default Accuracy '0' (Optional)" + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '<!ELEMENT Accuracy (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- The decimal place is not always stored with numbers. If each number' + chr$(13) + chr$(10)
& + '     is supposed to have decimal places use ImpliedAccuracy -->' + chr$(13) + chr$(10)
& + '<!ELEMENT ImpliedAccuracy (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Enables you to change how GDPdU displays dates.' + chr$(13) + chr$(10)
& + '     DD.MM.YYYY is the default Format -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Format (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Specifies the symbol that indicates decimal values.' + chr$(13) + chr$(10)
& + "     Comma is the default DecimalSymbol. ','" + chr$(13) + chr$(10)
& + '     Specified once per Table. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT DecimalSymbol (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Specifies the symbol that groups the digits in large numbers.' + chr$(13) + chr$(10)
& + "     Dot is the default DigitGroupingSymbol or ThousandsSeperator. '.'" + chr$(13) + chr$(10)
& + '     Specified once per Table -->' + chr$(13) + chr$(10)
& + '<!ELEMENT DigitGroupingSymbol (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Command(s) are executed in the following manner' + chr$(13) + chr$(10)
& + '      * before the import process' + chr$(13) + chr$(10)
& + '      * after the import process' + chr$(13) + chr$(10)
& + '      * before a Media is imported' + chr$(13) + chr$(10)
& + '      * after a Media is imported' + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '<!ELEMENT Command (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Only the file protocol is supported at this time.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     * The standard uses relative URLs.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     Absolute URLs are not allowed. The following are all invalid:' + chr$(13) + chr$(10)
& + '     * http://www.somewhere.com/data/Accounts.dat' + chr$(13) + chr$(10)
& + '     * ftp://ftp.somewhere.com/data/Accounts.dat' + chr$(13) + chr$(10)
& + '     * file://localhost/Accounts.dat' + chr$(13) + chr$(10)
& + '     * file:///Accounts.dat' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + '     The following are valid examples' + chr$(13) + chr$(10)
& + '      * Accounts.dat' + chr$(13) + chr$(10)
& + '      * data/Accounts.dat' + chr$(13) + chr$(10)
& + '      * data/january/Accounts.dat' + chr$(13) + chr$(10)
& + '      * ../Accounts.dat' + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '<!ELEMENT URL (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Textual description of specified element (Optional) -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Description (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- The logical name of specified element.' + chr$(13) + chr$(10)
& + '     Sometimes referred to business name.' + chr$(13) + chr$(10)
& + ' ' + chr$(13) + chr$(10)
& + '     If missing, URL will be used in place of Name. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Name (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Y2K Window Any year before Epoch is 2000+' + chr$(13) + chr$(10)
& + '     Default value 30.  -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Epoch (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Element(s) that separate columns or records.' + chr$(13) + chr$(10)
& + "     Semicolon is the default ColumnDelimiter. ';'" + chr$(13) + chr$(10)
& + '     CRLF or &#13;&#10; is the default RecordDelimiter. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT ColumnDelimiter (#PCDATA)>' + chr$(13) + chr$(10)
& + '<!ELEMENT RecordDelimiter (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- The number of bytes skipped before reading of URL commences.' + chr$(13) + chr$(10)
& + "     Zero is the default when not specified. '0'" + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '<!ELEMENT SkipNumBytes (#PCDATA)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- End Simple Types -->' + chr$(13) + chr$(10)
& + '<!-- Start Complex Types -->' + chr$(13) + chr$(10)
& + '<!-- Self-explanatory -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Range (From, (To | Length)?)>' + chr$(13) + chr$(10)
& + '<!ELEMENT FixedRange (From, (To | Length))>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- The document element -->' + chr$(13) + chr$(10)
& + '<!ELEMENT DataSet (Version, DataSupplier?, Command*, Media+, Command*)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Supported datatypes (mandatory) -->' + chr$(13) + chr$(10)
& + '<!ELEMENT AlphaNumeric EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT Date (Format?)>' + chr$(13) + chr$(10)
& + '<!ELEMENT Numeric ((ImpliedAccuracy | Accuracy)?)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Supported codepages:' + chr$(13) + chr$(10)
& + '     Be careful to explicitly define RecordDelimiter when using' + chr$(13) + chr$(10)
& + '     a non-default codepage.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     ANSI is the default codepage when not specified -->' + chr$(13) + chr$(10)
& + '<!ELEMENT ANSI EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT Macintosh EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT OEM EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT UTF16 EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT UTF7 EMPTY>' + chr$(13) + chr$(10)
& + '<!ELEMENT UTF8 EMPTY>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Supported file formats:' + chr$(13) + chr$(10)
& + '     FixedLength' + chr$(13) + chr$(10)
& + '  VariableLength -->' + chr$(13) + chr$(10)
& + '<!ELEMENT FixedLength ((Length | RecordDelimiter)?, ((FixedPrimaryKey+, FixedColumn*) | (FixedColumn+)), ForeignKey*)>' + chr$(13) + chr$(10)
& + '<!ELEMENT FixedColumn (Name, Description?, (Numeric | AlphaNumeric | Date), Map*, FixedRange)>' + chr$(13) + chr$(10)
& + '<!ELEMENT FixedPrimaryKey (Name, Description?, (Numeric | AlphaNumeric | Date), Map*, FixedRange)>' + chr$(13) + chr$(10)
& + '<!ELEMENT VariableLength (ColumnDelimiter?, RecordDelimiter?, TextEncapsulator?, ((VariablePrimaryKey+, VariableColumn*) | (VariableColumn+)), ForeignKey*)>' + chr$(13) + chr$(10)
& + '<!ELEMENT VariableColumn (Name, Description?, (Numeric | (AlphaNumeric, MaxLength?) | Date), Map*)>' + chr$(13) + chr$(10)
& + '<!ELEMENT VariablePrimaryKey (Name, Description?, (Numeric | (AlphaNumeric, MaxLength?) | Date), Map*)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Description of the entity supplying the data. (Optional) -->' + chr$(13) + chr$(10)
& + '<!ELEMENT DataSupplier (Name, Location, Comment)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- The first Media will contain index.xml. Importing will process each media listed -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Media (Name, Command*, Table+, Command*)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Elements common to FixedLength & VariableLength are propagated to Table. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Table (URL, Name?, Description?, Validity?, (ANSI | Macintosh | OEM | UTF16 | UTF7 | UTF8)?, (DecimalSymbol, DigitGroupingSymbol)?, SkipNumBytes?, Range?, Epoch?, (VariableLength | Fix'
&  + 'edLength))>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- ForeignKeys denote joins or relationships between tables.' + chr$(13) + chr$(10)
& + '     To successfully join two tables make sure both the PrimaryKey' + chr$(13) + chr$(10)
& + '     and the referenced column (foreignkey) are of the same datatype.' + chr$(13) + chr$(10)
& + '     Results are undefined when joining two tables with different' + chr$(13) + chr$(10)
& + '     key datatypes. Most likely an error will occur. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT ForeignKey (Name+, References)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + "<!-- Maps AlphaNumeric columns from 'From' to 'To'" + chr$(13) + chr$(10)
& + '     ie. From         To' + chr$(13) + chr$(10)
& + '         ============ =============' + chr$(13) + chr$(10)
& + '         True         1' + chr$(13) + chr$(10)
& + '         True         -1' + chr$(13) + chr$(10)
& + '         False        0' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     Basically, a map is an associative container.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     The standard implementation only supports' + chr$(13) + chr$(10)
& + '     AlphaNumeric datatypes. The following' + chr$(13) + chr$(10)
& + '     conversions are NOT supported.' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '     Numeric      -> AlphaNumeric' + chr$(13) + chr$(10)
& + '     Date         -> AlphaNumeric' + chr$(13) + chr$(10)
& + '     AplhaNumeric -> Date' + chr$(13) + chr$(10)
& + '     AlphaNumeric -> Numeric' + chr$(13) + chr$(10)
& + '-->' + chr$(13) + chr$(10)
& + '<!ELEMENT Map (Description?, From, To)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- Documentation for table validity. -->' + chr$(13) + chr$(10)
& + '<!ELEMENT Validity (Range, Format?)>' + chr$(13) + chr$(10)
& + '' + chr$(13) + chr$(10)
& + '<!-- End Complex Types -->' + chr$(13) + chr$(10)

    Openo FILNAM, 0 Using [TT]
    adxifs = ""
    adxirs = ""

    # Write clob to text file.
    Wrseq DTD Using [TT]

    # Close text file.
    Openo Using [TT]
End
# 2017-04-13 DNE INSERT END




#** #####################################################################################
#*
#* Sub chunk:  INIT
#*
#* Purpose:    - Opens a log/trace file.
#*             - Opens needed tables.
#*             - Opens needed Masks.
#*             - Initialize  variables.
#*
#*! #####################################################################################

$INIT
    # Open X3 log file.
    If !GSERVEUR : Call OUVRE_TRACE( "GDPDU" ) From LECFIC : Endif

    # Open company/facility/addres etc. tables.
    If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
    If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
    If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
    If !clalev([F:LED])  : Local File GLED       [LED]  : Endif
    If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif

    # Open export template tables.
    If !clalev([F:AOE])  : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])  : Local File AOBJEXTD   [AOD]  : Endif

    # Open dictinary tables.
    If !clalev([F:ATB])  : Local File ATABLE     [ATB]  : Endif
    If !clalev([F:ATZ])  : Local File ATABZON    [ATZ]  : Endif

    # Additional tables.
    If !clalev([F:ATY])  : Local File ATYPE      [ATY]  : Endif
    If !clalev([F:APX])  : Local File APARIMPEXP [APX]  : Endif
    If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
    If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
    If !clalev([F:AOB])  : Local File AOBJET     [AOB]  : Endif
    If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
    If !clalev([F:AMP])  : Local File AMSKPAR    [AMP]  : Endif
    If !clalev([F:TVT])  : Local File TABVAT     [TVT]  : Endif
    If !clalev([F:TRA])  : Local File TABRATVAT  [TRA]  : Endif
    If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
# 2017-06-26 DNE INSERT BEGIN (X3-40515)
    If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif
    If !clalev([F:PIH])  : Local File PINVOICE   [PIH]  : Endif
    If !clalev([F:GDPDUD]) : Local File GDPDUDUD [GDPDUD] : Endif
# 2017-06-26 DNE INSERT END
# 2017-06-26 DNE INSERT BEGIN (X3-31174)
    If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
    If !clalev([F:BPD])  : Local File BPDLVCUST  [BPD]  : Endif
    If !clalev([F:SIV])  : Local File SINVOICEV  [SIV]  : Endif
    If !clalev([F:PIH])  : Local File PINVOICE   [PIH]  : Endif
# 2017-09-06 DNE INSERT END

    # Additional masks.
    If !clalev([M:EXP1]) : Local Mask EXPOBJ     [EXP1] : Endif
    If !clalev([M:EXP2]) : Local Mask EXPOBJ2    [EXP2] : Endif
    If !clalev([M:AOE0]) : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1]) : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2]) : Local Mask AOE2       [AOE2] : Endif

    # XML tag stack.
    Gosub INITXMLSTACK

# 2017-06-26 DNE INSERT BEGIN
    # User ID for temporary tables.
    Local Char    EXPORTUSERID(20)       : EXPORTUSERID = GUSER + num$( adxuid(2) )
# 2017-06-26 DNE INSERT END

    # Directory separator.
    Local Char    DIRSEP(1)              : DIRSEP     = func GETDIRSEPARATOR()

    # Parameter variables.
    Local Char    X3EXPORTTEMPLATE(255)  : X3EXPORTTEMPLATE = ""
    Local Char    TABLEURL(255)          : TABLEURL   = ""
    Local Char    TABLENAME(255)         : TABLENAME  = ""
    Local Char    TABLEDESC(255)         : TABLEDESC  = ""
    Local Integer TABLENOPK              : TABLENOPK  = 0 # Number of primary key elements

    # Screen data: Export directory, company, site etc.
    Local Char    EXPORTCPY(GLONCPY)     : EXPORTCPY  = GDEFSOC
    Local Char    EXPORTLED(GLONLED)     : EXPORTLED  = ""
    Local Char    EXPORTCOA(GLONCOA)     : EXPORTCOA  = ""
    Local Char    EXPORTLEG(GLONADI)     : EXPORTLEG  = ""
    Local Date    EXPDATSTR              : EXPDATSTR  = gdat$(  1,  1, 2012 )
    Local Date    EXPDATEND              : EXPDATEND  = gdat$( 31, 12, 2012 )
    Local Char    EXPORTDIR(255)         : EXPORTDIR  = "" # func ASYRSTO.GETFULLPATH( "TMP", "" )
    Local Char    DTDNAME(255)           : DTDNAME    = "gdpdu-01-08-2002.dtd"
    Local Integer FLGFINANCE             : FLGFINANCE = 1
    Local Integer FLGHISTDAT             : FLGHISTDAT = 1
    Local Integer FLGFA                  : FLGFA      = 1
    Local Integer FLGANACC               : FLGANACC   = 1
    Local Integer TYPEXP                 : TYPEXP     = 2

# 2017-06-26 DNE INSERT BEGIN (X3-46897)
    # Flag that indicates that temporary data was found calling
    Local Integer FLGTMPDAT              : FLGTMPDAT  = 0
# 2017-06-26 DNE INSERT END
Return



#** #####################################################################################
#*
#* Sub chunk:  CLEANUP
#*
#* Purpose:    - Closes a log/trace file and shows it on the screen.
#*             - Closes opened tables.
#*             - Closes opened Masks.
#*
#*! #####################################################################################

$CLEANUP
    # Close tables.
    If clalev([F:CPY])  : Close Local File [CPY]  : Endif
    If clalev([F:FCY])  : Close Local File [FCY]  : Endif
    If clalev([F:GCM])  : Close Local File [GCM]  : Endif
    If clalev([F:LED])  : Close Local File [LED]  : Endif
    If clalev([F:BPA])  : Close Local File [BPA]  : Endif
    If clalev([F:AOE])  : Close Local File [AOE]  : Endif
    If clalev([F:AOD])  : Close Local File [AOD]  : Endif
    If clalev([F:ATZ])  : Close Local File [ATZ]  : Endif
    If clalev([F:ATY])  : Close Local File [ATY]  : Endif
    If clalev([F:APX])  : Close Local File [APX]  : Endif
    If clalev([F:ATB])  : Close Local File [ATB]  : Endif
    If clalev([F:HAE])  : Close Local File [HAE]  : Endif
    If clalev([F:DAE])  : Close Local File [DAE]  : Endif
    If clalev([F:AOB])  : Close Local File [AOB]  : Endif
    If clalev([F:GAC])  : Close Local File [GAC]  : Endif
    If clalev([F:AMK])  : Close Local File [AMK]  : Endif
    If clalev([F:TVT])  : Close Local File [TVT]  : Endif
    If clalev([F:DUD])  : Close Local File [DUD]  : Endif
# 2017-06-26 DNE INSERT BEGIN (X3-40515)
    If clalev([F:GDPDUD]) : Close Local File [GDPDUD] : Endif
# 2017-06-26 DNE INSERT END

    # Close masks.
    If clalev([M:AOE0]) : Close Local Mask [AOE0] : Endif
    If clalev([M:AOE1]) : Close Local Mask [AOE1] : Endif
    If clalev([M:AOE2]) : Close Local Mask [AOE2] : Endif
    If clalev([M:EXP1]) : Close Local Mask [EXP1] : Endif
    If clalev([M:EXP2]) : Close Local Mask [EXP2] : Endif

    # Close X3 log/trace file and show it on screen.
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Return

