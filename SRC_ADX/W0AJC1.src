#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone AJCCOD
mkstat = 0
zoncou = "AJCCOD"
indice = 0
WCHAR = [M]AJCCOD
If varmode([M]AJCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AJCCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]AJCCOD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "AJCCOD" : GZNUM = 42109 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]AJCCOD or IMPMOD
   SAVACT = GACTION : GACTION = "CONTOBJ"
   Call C_CLE("AJC") From GOBJET
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "AJCCOD" : GZNUM = 42109 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone AJCDESZ
mkstat = 0
zoncou = "AJCDESZ"
indice = 0
If varmode([M]AJCDESZ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AJCDESZ" : Gosub ACTION From =IMPTRT
  IMPMOD = 0 : IMPZON = "AJCDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
WCHAR = [M]CODACT
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CODACT([M]CODACT) From SUBAJC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CODACT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_CODACT([M]CODACT) From SUBAJC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone MODULE
mkstat = 0
zoncou = "MODULE"
indice = 0
IMPENT = [M]MODULE
If varinit([M]MODULE,indice)=0
 IMPENT = 1
Endif
If varmode([M]MODULE,indice)=0
 [M]MODULE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MODULE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MODULE(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MODULE" : GZNUM = 943 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]MODULE = IMPENT

## Zone AJCDEVMOD
mkstat = 0
zoncou = "AJCDEVMOD"
indice = 0
IMPENT = [M]AJCDEVMOD
If varinit([M]AJCDEVMOD,indice)=0
 IMPENT = 1
Endif
If varmode([M]AJCDEVMOD,indice)=0
 [M]AJCDEVMOD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AJCDEVMOD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AJCDEVMOD(indice)
 Endif
Endif
[M]AJCDEVMOD = IMPENT

## Zone AJCHTPVER
mkstat = 0
zoncou = "AJCHTPVER"
indice = 0
If varinit([M]AJCHTPVER,indice)=0
 [M]AJCHTPVER = 1
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone AJCXSD
mkstat = 0
zoncou = "AJCXSD"
indice = 0
WCLOB = [M]AJCXSD
If varmode([M]AJCXSD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AJCXSD" : Gosub ACTION From =IMPTRT
 Endif
 If len([M]AJCXSD)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "AJCXSD" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCLOB<>[M]AJCXSD or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_AJCXSD([M]AJCXSD) From SUBAJC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "AJCXSD" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "AJC1"
Return

