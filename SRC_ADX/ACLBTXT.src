#<AdxTL>@(#)0.0.0.0 $Revision$

Raz GPILOBJ,GNBMASKOUV
Local Char    VALEUR(30), PARAM(250)(1..20)
GABREV = "AUS"
PARAM(1) = GABREV
PARAM(2) = "MB"
PARAM(4) = "M"
Call SAISIE_CHAR(VALEUR,PARAM,"AOBJTXT","GOBJTXT","XWGOBJTXT") From GSAISIE
End

#-------------------------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
 When Default
Endcase
Return

$INIT_DIA
Local Integer OK
Call LEC_ACB(PARAM(1),PARAM(2),PARAM(3),[M]TEXT,OK) From GOBJTXT
#SAM 120819
[M:AOXC]PARAM6= PARAM(6)
Affzo [M:AOXC]TEXT
Return

$EXEC
#SAM 120819
If [M:AOXC]PARAM6= "0"
  Return
Endif

Call MAJ_ACB(PARAM(1),PARAM(2),PARAM(3),[M:AOXC]TEXT,PARAM(4),OK) From GOBJTXT
[M:AOX]TEXTE = [M:AOXC]TEXT
PARAM(5) = "1"
Return

#SAM 120819
Subprog AS_TEXT(VALEUR)
Variable Clbfile VALEUR
If [M:AOXC]PARAM6= "0"
  Grizo [M:AOXC]TEXT
  Affzo [M:AOXC]TEXT
Endif
End


######################################################################################

