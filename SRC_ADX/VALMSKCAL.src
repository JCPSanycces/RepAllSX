#<AdxTL>@(#)7.0.0.0 $Revision$
#################################################################################
## VALMSKCAL Calcul des positions écran
#################################################################################

################################################################################
## Pilotage du calcul
################################################################################
$PILCAL

# On lance le calcul de positionnement en haute résolution puis en basse résolution
# sauf si l'application est définie uniquement en haute résolution

# Lecture des paramètres

Local Integer RESOL

Call PARAM("","ECRRESOL",PARAM) From ADOVAL
RESOL = val(PARAM)
Call RESOLUTION(RESOL,LGECRAN,HTECRAN,LGBROWS) From GLOBVAR

#  On est obligatoirement en haute résolution en 150
TET_LIG = [F:AMK]NBRLIG
TET_COL = [F:AMK]NBRCOL


$CALCBR
Gosub CALCUL  From VALMSKCAL
If !OK : Return : Endif

#  On duplique les résultats de calcul si on n'a fait qu'une seule passe  (à supprimer)
  For indice=1 To MAXBLOC
    BLC_NCO1(indice)=BLC_NCO(indice)
    BLC_NLI1(indice)=BLC_NLI(indice)
    BLC_X1(indice)=BLC_X(indice)
    BLC_Y1(indice)=BLC_Y(indice)
    BLC_NCO2(indice)=BLC_NCO(indice)
    BLC_NLI2(indice)=BLC_NLI(indice)
    BLC_X2(indice)=BLC_X(indice)
    BLC_Y2(indice)=BLC_Y(indice)
  Next indice
Return


$CALCUL

################################################################################
## Préliminaires
################################################################################

LG1 = 1.1
For B=1 To BLC_NBR
 If BLC_TYP(B)<>5 & BLC_TYP(B)<>10
  BLC_PDS(B) = min(COLMAX,max(1,BLC_PDS(B)))
  BLC_PDH(B) = min(COLMAX,max(1,BLC_PDH(B)))
  If BLC_NUM(B)<1 or BLC_NUM(B)>COLMAX
   BLC_NUM(B) = LG1
   LG1 += 1
  Endif
  If BLC_NUM(B)=int(BLC_NUM(B)) : BLC_NUM(B) += 0.1 : Endif
  While find(BLC_NUM(B),BLC_NUM(1..B-1))
   BLC_NUM(B) += 0.1
   If BLC_NUM(B)=int(BLC_NUM(B)) : BLC_NUM(B) += 0.1 : Endif
  Wend
  BLC_NOL(B) = int(BLC_NUM(B))
  BLC_NOC(B) = 10*(BLC_NUM(B)-BLC_NOL(B))
  For L=1 To LIG_NBR(B)
   If LIG_NUM(B,L)<1 or (LIG_NUM(B,L)>LIGMAX & LIG_SAI(B,L)<3 & BLC_TYP(B)=2)
    If L=1
     LIG_NUM(B,L) = 1.1
    Else
     LIG_NUM(B,L) = LIG_NUM(B,L-1)+0.1
    Endif
   Endif
  Next L
 Endif
Next B

## Pour gérer les tableaux invisibles ??

For B=1 To BLC_NBR
 If BLC_TYP(B)=1
  For L=1 To LIG_NBR(B)
   If LIG_ZON(B,L)=BLC_BAS(B)
    If LIG_SAI(B,L)>=3
     BLC_PDS(B) = 0
     BLC_PDH(B) = 0
     BLC_OPT(B) = ""
     #59847 : we musn't take into account HTBLOC and LGBLOC in this case
     BLC_MINLIG(B) = 0
     BLC_MINCOL(B) = 0
     #end 59847
    Endif
    Break
   Endif
  Next L
 Endif
Next B

# Contraintes pour les blocs graphiques

For B=1 To BLC_NBR
 #59847 added  & BLC_PDS(B)>0 & BLC_PDH(B)>0 (not to do if invisible table)
 If BLC_TYP(B)=1 & BLC_PDS(B)>0 & BLC_PDH(B)>0
  Case BLC_TYPT(B)
   When 2 : # Graphique
    BLC_MINLIG(B) = max(8,BLC_MINLIG(B))    : # 8 lignes mini
    BLC_MINCOL(B) = max(36,BLC_MINCOL(B))   : # 36 colonnes mini
   When 3 : # Dual
    Case BLC_POSG(B)
     When 1,2 : # Droite/gauche
      BLC_MINLIG(B) = max(8,BLC_MINLIG(B))                : # 8 lignes mini
      BLC_MINCOL(B) = max(TET_COL,BLC_MINCOL(B))          : # Le max de colonnes
     When 3,4 : # Dessus/dessous
      BLC_MINLIG(B) = max(min(16,TET_LIG),BLC_MINLIG(B))  : # 16 lignes mini
      BLC_MINCOL(B) = max(36,BLC_MINCOL(B))               : # 36 colonnes mini
    Endcase
  Endcase
 Endif
Next B

################################################################################
## A) Détermination du nb de colonnes logique max de chaque bloc (BLC_COL)
##    Calcul du nb de colonnes de chaque champ                   (LIG_COL)
################################################################################

For B=1 To BLC_NBR
 BLC_COL(B) = BLC_PDS(B)
 Case BLC_TYP(B)
  When 2
   For LIGCUR=1 To LIGMAX
    COLONNE = 0
    For L=1 To LIG_NBR(B)
     If LIG_SAI(B,L)<3
      If int(LIG_NUM(B,L))=LIGCUR
       LIBEL  = (LIG_TIT(B,L)<>0 or LIG_EVL(B,L)<>"")*(find(LIG_GRA(B,L),1,10))
       NBRCOL = LIG_PDS(B,L)+(LIG_LIE(B,L)>1)
       If find(LIG_GRA(B,L),5,6) : # Boutons horizontaux
        # Pas bien d'utiliser un mess qui n'est pas forcément correct dans X3
        # faudrait utiliser un func
        NBRCOL += len(mess(0,LIG_LIB(B,L),1))-1
       Endif
       # Un champ de poids nul et sans libellé se colle au précédent
       If LIG_PDS(B,L)=0 & !LIBEL & COLONNE>0
        L2 = 0
        For L1=L To 1 Step -1
         If LIG_SAI(B,L1)<3 & LIG_PDS(B,L1)<>0
          If int(LIG_NUM(B,L1))=LIGCUR & find(LIG_GRA(B,L1),1,10) & LIG_DIM(B,L1)=LIG_DIM(B,L)
           L2 = L1
           Break
          Endif
         Endif
        Next L1
        If L2
         LIG_COL(B,L)   = 0
         LIG_SUI(B,L)   = L2
         LIG_COL(B,L2) += NBRCOL
         COLONNE       += NBRCOL
         # On ne rajoute 1 colonne que si la longueur totale est >10
         LG1 = LIG_FLN(B,L2)
         For L3=1 To LIG_NBR(B)
          If LIG_SUI(B,L3) = L2 : LG1 += LIG_FLN(B,L3) : Endif
         Next L3
         If LG1>10
          LIG_COL(B,L2) += 1
          COLONNE       += 1
         Endif
        Else
         LIG_COL(B,L) = NBRCOL+1
         COLONNE     += LIG_COL(B,L)
        Endif
       Else
        If NBRCOL<1 : NBRCOL = 1 : Endif
        LIG_COL(B,L) = NBRCOL
        COLONNE     += NBRCOL+LIBEL
       Endif
      Elsif int(LIG_NUM(B,L))<LIGCUR & int(LIG_NUM(B,L))+LIG_FLI(B,L)*LIG_DIM(B,L)-1>=LIGCUR
       COLONNE += LIG_COL(B,L)
      Endif
     Endif
    Next L
    BLC_COL(B) = max(BLC_COL(B),COLONNE)
   Next LIGCUR
 Endcase
Next B

################################################################################
# Réaffectation du nb max de colonnes au dernier champ de chaque ligne
################################################################################

For B=1 To BLC_NBR
 If BLC_TYP(B)=2
  For LIGCUR=1 To LIGMAX
   L1 = 0
   COLONNE = 0
   For L=1 To LIG_NBR(B)
    If LIG_SAI(B,L)<3
     If int(LIG_NUM(B,L))<=LIGCUR and int(LIG_NUM(B,L))+LIG_DIM(B,L)-1>=LIGCUR
      LIBEL  = (LIG_TIT(B,L)<>0 or LIG_EVL(B,L)<>"")*(find(LIG_GRA(B,L),1,10))
      COLONNE += LIG_COL(B,L)+LIBEL
      If LIG_SUI(B,L)=0 : L1 = L : Endif
     Endif
    Endif
   Next L
   If L1 & int(LIG_NUM(B,L1))=LIGCUR & LIG_FLI(B,L1)=1 & LIG_DIM(B,L1)=1
    If COLONNE<BLC_COL(B)
     If LIG_SUI(B,L1) : L1 = LIG_SUI(B,L1) : Endif
     LIG_COL(B,L1) += BLC_COL(B)-COLONNE
    Endif
   Endif
  Next LIGCUR
 Endif
Next B

If TEST
 Call ECR_TRACE("Affectation colonnes (A)",0) From GESECRAN
 For B=1 To BLC_NBR
  If BLC_TYP(B)=2
   Call ECR_TRACE("Bloc"-num$(B)-num$(BLC_COL(B))-"colonnes",0) From GESECRAN
   For L=1 To LIG_NBR(B)
    Call ECR_TRACE("----"-LIG_ZON(B,L)-"Poids"-num$(LIG_COL(B,L)),0) From GESECRAN
   Next L
  Endif
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

################################################################################
## B ) Affectation de chaque champ à une colonne  (LIG_POS)
##     Calcul de la largeur de chaque bloc liste  (BLC_CAR)
##     Calcul du nb de lignes mini de chaque bloc (BLC_NLI)
################################################################################

## 1ère passe, on ne s'occupe que des champs de poids 1

For B=1 To BLC_NBR
 LIGCUR = 0
 Case BLC_TYP(B)

  When 1 : # Tableau : Un nb de ligne mini

   BLC_NLI(B) = HTDEF

  When 4 : # Texte : Le nb de champ (un champ par ligne)

   BLC_COL(B)   = 1
   BLC_CAR(B,1) = -int(-COEF1*BLC_LNG(B))
   BLC_NLI(B)   = LIG_NBR(B)

  When 6,7,8,9,11 : # Bloc Flash, bureautique, browser,BO
   BLC_NLI(B)   = max(HTFLASH,LIG_FLI(B,1))
   BLC_CAR(B,1) = max(LGFLASH,LIG_FLN(B,1))

  When 2 : # Liste

   LIGCUR = 0
   COLCUR = 1
   Raz MAP
#  Affectation de lig_pos
   For L=1 To LIG_NBR(B)
    If int(LIG_NUM(B,L))<>LIGCUR
     LIGCUR = int(LIG_NUM(B,L))
     COLCUR = 1
    Endif
    If LIG_SAI(B,L)<3
     If LIG_SUI(B,L)
      LIG_POS(B,L) = LIG_POS(B,LIG_SUI(B,L))
     Else
      LIBEL   = (LIG_TIT(B,L)<>0 or LIG_EVL(B,L)<>"")*(find(LIG_GRA(B,L),1,10,13))
      COLONNE = LIG_COL(B,L)+LIBEL
      #112218
      If (COLCUR+COLONNE-1) > COLMAX
       OK=0
      Endif
      While OK & sigma(1,COLONNE,MAP(LIGCUR,COLCUR+indcum-1))<>0
       COLCUR += 1
       If (COLCUR+indcum-1) > COLMAX
        OK=0
        Break
       Endif
      Wend
      If OK = 0 : Break 2 : Endif

      If LIBEL
       If LIG_DIM(B,L)+LIGCUR-1>LIGMAX : OK = 0 : Break 2 : Endif
       For I=1 To LIG_DIM(B,L)
        MAP(LIGCUR+I-1,COLCUR) = 1
       Next I
       COLCUR += 1
      Endif
      If LIG_DIM(B,L)+LIGCUR-1>LIGMAX | LIG_COL(B,L)+COLCUR-1>COLMAX : OK = 0 : Break 2 : Endif
      For I=1 To LIG_FLI(B,L)*LIG_DIM(B,L)
       For J=1 To LIG_COL(B,L)
        MAP(LIGCUR+I-1,COLCUR+J-1) = 1
       Next J
      Next I
      LIG_POS(B,L) = COLCUR
      COLCUR += LIG_COL(B,L)
     Endif
    Endif
   Next L

# Calcul place pour les champs de poids 1

   LIGCUR = 0
   For L=1 To LIG_NBR(B)
    If int(LIG_NUM(B,L))<>LIGCUR
     LIGCUR = int(LIG_NUM(B,L))
    Endif
    If LIG_SAI(B,L)<3
     If LIG_SUI(B,L)=0
      LIBEL   = (LIG_TIT(B,L)<>0 or LIG_EVL(B,L)<>"")*(find(LIG_GRA(B,L),1,10,13))
      COLCUR  = LIG_POS(B,L)
      If LIBEL
       BLC_CAR(B,COLCUR-1) = max(BLC_CAR(B,COLCUR-1),-int(-COEF1*BLC_LNG(B)))
      Endif
      BLC_NLI(B) = max(BLC_NLI(B),LIGCUR+LIG_FLI(B,L)*LIG_DIM(B,L)-1)
      If LIG_COL(B,L)=1
       Gosub LONGCHAMP
       BLC_CAR(B,COLCUR) = max(BLC_CAR(B,COLCUR),LONGCHAMP)
      Endif
     Endif
    Endif
   Next L
 Endcase
Next B

If !OK
 Call ECR_TRACE(ECRAN-":"-mess(55,9014,1)-"("-mess(17,115,1)-LIG_ZON(B,L)-")",1) From GESECRAN
# Trop de dimension/zone
 Return
Endif

## 2ème passe, pour les champs de poids>1

For B=1 To BLC_NBR
 Case BLC_TYP(B)
  When 2
   For L=1 To LIG_NBR(B)
    If LIG_SAI(B,L)<3
     If LIG_COL(B,L)>1
      LIGCUR = int(LIG_NUM(B,L))
      COLCUR = LIG_POS(B,L)
      Gosub LONGCHAMP
      LONGBLOC = sigma(1,LIG_COL(B,L),BLC_CAR(B,COLCUR+indcum-1))+(LIG_COL(B,L)-1)
      If LONGCHAMP>LONGBLOC
       RESIDU = LONGCHAMP-LONGBLOC
       While RESIDU>0
# On met tout sur la dernière colonne ?
        BLC_CAR(B,COLCUR+LIG_COL(B,L)-1) += RESIDU
        RESIDU = 0
# Ou on saupoudre régulièrement ?
#       For L1=COLCUR To COLCUR+LIG_COL(B,L)-1
#        BLC_CAR(B,L1) += 1
#        RESIDU        -= 1
#        If RESIDU<=0 : Break : Endif
#       Next L1
       Wend
      Endif
     Endif
    Endif
   Next L
 Endcase
Next B

If TEST
 Call ECR_TRACE("Affectation colonnes (B1)",0) From GESECRAN
 For B=1 To BLC_NBR
  If find(BLC_TYP(B),2,4,6,7,8)
   Call ECR_TRACE("Bloc"-num$(B)-num$(BLC_COL(B))-"colonnes",0) From GESECRAN
   For L=1 To BLC_COL(B)
    Call ECR_TRACE("-----"-num$(L)-":"-num$(BLC_CAR(B,L))-"caractères",0) From GESECRAN
   Next L
   For L=1 To LIG_NBR(B)
    Call ECR_TRACE("----"-LIG_ZON(B,L)-"Position"-num$(LIG_POS(B,L))-"Poids"-num$(LIG_COL(B,L)),0) From GESECRAN
   Next L
  Endif
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

################################################################################
## Détermination de la position de chaque champ en positions relatives (LIG_X LIG_Y)
## (Le premier champ est en (2,2))
################################################################################

For B=1 To BLC_NBR
 Case BLC_TYP(B)

  When 2 : # Liste

   For L=1 To LIG_NBR(B)
    If LIG_SAI(B,L)<3 & LIG_SUI(B,L)=0 : # Le premier champ
     LIG_Y(B,L) = 1+int(LIG_NUM(B,L))  : # Une ligne pour le cadre
     LIG_X(B,L) = 2+sigma(1,LIG_POS(B,L)-1,BLC_CAR(B,indcum))+(LIG_POS(B,L)-1)
     COLCUR = LIG_X(B,L)+LIG_FLN(B,L)+1+LIG_LLI(B,L)+(LIG_LLI(B,L)<>0)
     For L1=L+1 To LIG_NBR(B) : # Les champs suivants
      If LIG_SUI(B,L1)=L
       LIG_Y(B,L1) = LIG_Y(B,L)
       LIG_X(B,L1) = COLCUR
       COLCUR += LIG_FLN(B,L1)+1+LIG_LLI(B,L1)+(LIG_LLI(B,L1)<>0)
      Endif
     Next L1
    Endif
   Next L

  When 4 : # Texte

   For L=1 To LIG_NBR(B)
    LIG_POS(B,L) = 1
    LIG_COL(B,L) = 1
    LIG_Y(B,L)   = L+1
    LIG_X(B,L)   = 2
   Next L

 Endcase
Next B

If TEST
 Call ECR_TRACE("Position des champs (B2)",0) From GESECRAN
 For B=1 To BLC_NBR
  If find(BLC_TYP(B),2,4)
   For L=1 To LIG_NBR(B)
    Call ECR_TRACE(LIG_ZON(B,L)-num$(LIG_Y(B,L))-num$(LIG_X(B,L)),0) From GESECRAN
   Next L
  Endif
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

################################################################################
## Détermination de la taille des blocs liste et texte en nb de caractères
################################################################################

For B=1 To BLC_NBR
 If find(BLC_TYP(B),2,4,6,7)
  BLC_NLI(B) += 1 : # Pour le cadre
  BLC_NCO(B)  = 2  : # Pour le cadre
  For COLCUR=1 To BLC_COL(B)
   BLC_NCO(B) += (BLC_CAR(B,COLCUR)+(BLC_CAR(B,COLCUR)<>0)) : # 1 caractère de séparation
  Next COLCUR
 Endif
# Si le dernier champ du bloc est DCB, alors 1 ou 2 caractère de moins ????
 XM = 0
 BB = 1
 For L=1 To LIG_NBR(B)
  If LIG_SAI(B,L)<3
   XM = max(XM,LIG_X(B,L))
  Endif
 Next L
 For L=1 To LIG_NBR(B)
  If LIG_SAI(B,L)<3 & LIG_X(B,L)=XM & LIG_TYI(B,L)<>4
   BB = 0 : Break
  Endif
 Next L
 If BB
  BLC_NCO(B) -= 2 : #If GUSER="BY" : Infbox "2"-num$(B) : Endif
 Endif
Next B

If TEST
 Call ECR_TRACE("Taille des blocs (B3)",0) From GESECRAN
 For B=1 To BLC_NBR
  If find(BLC_TYP(B),2,4)
   Call ECR_TRACE(num$(B)-":"-num$(BLC_NLI(B))-num$(BLC_NCO(B)),0) From GESECRAN
  Endif
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

################################################################################
## Calcul ou affectation des maximum
################################################################################

Case TET_TAI
 When 1,2,5 : # Libre ou centré ou en-tête
  LARGMAX = TET_COL
  HAUTMAX = TET_LIG
 When 4   : # Avec browser
  LARGMAX = LGBROWS
  HAUTMAX = HTECRAN
 When 3   : # Plein écran
  LARGMAX = LGECRAN
  HAUTMAX = HTECRAN
Endcase
If LARGMAX<1 : LARGMAX = 64 : Endif
If HAUTMAX<1 : HAUTMAX = 16 : Endif
TET_LIG = HAUTMAX
TET_COL = LARGMAX


########################################################################
# C) Calcul de la hauteur de chaque "ligne"   BLC_NLI => HAUT()
########################################################################
HAUTEUR = 0
Raz HAUT

## Nb de blocs en hauteur

NBHAUT = 0
For B=1 To BLC_NBR
 If BLC_TYP(B)<>5 & BLC_TYP(B)<>10
  NBHAUT = max(NBHAUT,BLC_NOL(B)+BLC_PDH(B)-1)
 Endif
Next B

## 1) Blocs liste de poids 1

Raz FLIMP
For LIGCUR=1 To NBHAUT
 HAUT(LIGCUR) = 0
 For B=1 To BLC_NBR
  If find(BLC_TYP(B),2,4,6,7,8,9,11)
   If BLC_NOL(B)=LIGCUR & BLC_PDH(B)=1
    HAUT(LIGCUR)  = max(HAUT(LIGCUR),BLC_NLI(B))
    FLIMP(LIGCUR) = 1
   Endif
  Endif
 Next B
Next LIGCUR

## 2) Blocs liste de poids n

Raz LIGTAB
For LIGCUR=1 To NBHAUT
 For B=1 To BLC_NBR
  If BLC_TYP(B)=1 & LIGCUR>=BLC_NOL(B) & LIGCUR<=BLC_NOL(B)+BLC_PDH(B)-1
   NBTAB += 1
   LIGTAB(LIGCUR) = 1
   Break
  Endif
 Next B
Next LIGCUR
For B=1 To BLC_NBR
 If find(BLC_TYP(B),2,4,6,7,8,9,11)
  RESIDU = BLC_NLI(B)-sum(HAUT(BLC_NOL(B)..BLC_NOL(B)+BLC_PDH(B)-1))
  ## On agrandit d'abord les lignes non traitées en passe 1
  BB = 0
  For L=BLC_NOL(B) To BLC_NOL(B)+BLC_PDH(B)-1
   If FLIMP(L)=0
    BB += 1
   Endif
  Next L
  If BB>0 & RESIDU>0
   BB1 = 0
   DELTA = int(RESIDU/BB)
   For L=BLC_NOL(B) To BLC_NOL(B)+BLC_PDH(B)-1
    If FLIMP(L)=0
     BB1 += 1
     If BB1=BB
      HAUT(L) += RESIDU
      RESIDU   = 0
     Else
      HAUT(L)  += DELTA
      RESIDU   -= DELTA
     Endif
    Endif
   Next L
  Endif
  ## Sinon on donne priorité aux lignes ayant des tableaux
  While RESIDU>0
   For L=BLC_NOL(B) To BLC_NOL(B)+BLC_PDH(B)-1
    If LIGTAB(L) or sum(LIGTAB(BLC_NOL(B)..BLC_NOL(B)+BLC_PDH(B)-1))=0
     HAUT(L) += 1
     RESIDU  -= 1
     If RESIDU<=0 : Break : Endif
    Endif
   Next L
  Wend
 Endif
Next B

## 2bis) Traitement du mini des blocs tableaux

For B=1 To BLC_NBR
 If BLC_TYP(B)=1
  L = BLC_NOL(B)
  While BLC_MINLIG(B)>sum(HAUT(BLC_NOL(B)..BLC_NOL(B)+BLC_PDH(B)-1))
   HAUT(L) += 1
   L += 1
   If L>BLC_NOL(B)+BLC_PDH(B)-1
    L = BLC_NOL(B)
   Endif
  Wend
 Endif
Next B

## 3) Affectation du reste aux blocs tableaux

RESIDU = HAUTMAX-sum(HAUT(1..NBHAUT))
NBTAB = 0
Raz LIGTAB , HAUTEUR
For LIGCUR=1 To NBHAUT
 For B=1 To BLC_NBR
  If BLC_TYP(B)=1 & LIGCUR>=BLC_NOL(B) & LIGCUR<=BLC_NOL(B)+BLC_PDH(B)-1
&  & BLC_PDH(B)<NBHAUT
   NBTAB += 1
   LIGTAB(LIGCUR) += BLC_PDH(B) : # 1
   HAUTEUR += HAUT(LIGCUR)
   Break
  Endif
 Next B
Next LIGCUR

# Si tous les tableaux d'une ligne sont aussi présents sur un autre ligne
# alors cette ligne n'est pas prioritaire

For LIGCUR=1 To NBHAUT
 If LIGTAB(LIGCUR)
  OKL = 0
  For L=1 To NBHAUT
   If L<>LIGCUR & LIGTAB(L)
    OKL = 1
    For B=1 To BLC_NBR
     If BLC_TYP(B)=1 & LIGCUR>=BLC_NOL(B) & LIGCUR<=BLC_NOL(B)+BLC_PDH(B)-1
      If !(L>=BLC_NOL(B) & L<=BLC_NOL(B)+BLC_PDH(B)-1)
       OKL = 0 : Break
      Endif
     Endif
    Next B
    If OKL : Break : Endif
   Endif
  Next L
  If OKL & NBTAB>1
   LIGTAB(LIGCUR) = 0
   HAUTEUR -= HAUT(LIGCUR)
   NBTAB -= 1
  Endif
 Endif
Next LIGCUR

If NBTAB
 MH = 0
 DH = int((HAUTEUR+RESIDU)/sum(LIGTAB))
 For LIGCUR=1 To NBHAUT
  If LIGTAB(LIGCUR)
   If LIGTAB(LIGCUR)>MH
    IH = LIGCUR
    MH = LIGTAB(LIGCUR)
   Endif
   If HAUT(LIGCUR)<DH*LIGTAB(LIGCUR)
    DELTA = min(RESIDU,DH*LIGTAB(LIGCUR)-HAUT(LIGCUR))
    HAUT(LIGCUR) += DELTA
    RESIDU       -= DELTA
   Endif
  Endif
 Next LIGCUR

 RESIDU = HAUTMAX-sum(HAUT(1..NBHAUT))
 If RESIDU>0 & MH>0
  HAUT(IH) += RESIDU
  RESIDU    = 0
 Endif
 If RESIDU>0
  For LIGCUR=1 To NBHAUT
   If LIGTAB(LIGCUR)
    HAUT(LIGCUR) += int(RESIDU/NBTAB)
   Endif
  Next LIGCUR
  RESIDU -= NBTAB*int(RESIDU/NBTAB)
 Endif
 If RESIDU>0
  For LIGCUR=1 To NBHAUT
   If LIGTAB(LIGCUR)
    HAUT(LIGCUR) += RESIDU
    RESIDU = 0
    Break
   Endif
  Next LIGCUR
 Endif
Endif

## 4) Le reste sur le dernier bloc ?

If NBHAUT & RESIDU>0
 HAUT(NBHAUT) += RESIDU
 RESIDU = 0
## ou... Affectation du reste au hasard
 While RESIDU>0
  For LIGCUR=1 To NBHAUT
   HAUT(LIGCUR) += 1
   RESIDU       -= 1
   If RESIDU<=0 : Break : Endif
  Next LIGCUR
 Wend
Endif

## 5) Recalcul taille des blocs

For B=1 To BLC_NBR
 If BLC_TYP(B)<>5 & BLC_TYP(B)<>10
  BLC_NLI(B) = sum(HAUT(BLC_NOL(B)..BLC_NOL(B)+BLC_PDH(B)-1))
 Endif
Next B

HAUTEUR = sum(HAUT(1..NBHAUT))
If HAUTEUR>HAUTMAX and GFUSION=0      : #  CC 15/02/2013 pour ne pas afficher ce message en fusion
# Call ECR_TRACE(ECRAN-":"-mess(75,133,1)-"("+num$(HAUTEUR)+"/"+num$(HAUTMAX)+")",0) From GESECRAN
# Pas assez de place en hauteur
Endif

If TEST
 Call ECR_TRACE("Taille des blocs (C)",0) From GESECRAN
 Call ECR_TRACE("Hauteur max"-num$(HAUTMAX),0) From GESECRAN
 For L=1 To NBHAUT
  Call ECR_TRACE("Ligne"-num$(L)-":"-num$(HAUT(L)),0) From GESECRAN
 Next L
 For B=1 To BLC_NBR
  Call ECR_TRACE("Bloc"-num$(B)-":"-num$(BLC_NLI(B))-num$(BLC_NCO(B)),0) From GESECRAN
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

###########################################################################
# D) Calcul de la largeur de chaque "ligne"   BLC_NCO => LARGE()
###########################################################################
LARGEUR = 0
Raz LARGE

## Nb de blocs en hauteur

NBLARGE = 0
For B=1 To BLC_NBR
 If BLC_TYP(B)<>5  & BLC_TYP(B)<>10
  NBLARGE = max(NBLARGE,BLC_NOC(B)+BLC_PDS(B)-1)
 Endif
Next B

## 1) Blocs liste de poids 1

Raz FLIMP
For LIGCUR=1 To NBLARGE
 LARGE(LIGCUR) = 0
 For B=1 To BLC_NBR
  If find(BLC_TYP(B),2,4,6,7,8,9,11)
   If BLC_NOC(B)=LIGCUR & BLC_PDS(B)=1
    LARGE(LIGCUR) = max(LARGE(LIGCUR),BLC_NCO(B))
    FLIMP(LIGCUR) = 1
   Endif
  Endif
 Next B
Next LIGCUR

## 2) Blocs liste de poids n

Raz LIGTAB
For L=1 To NBLARGE
 For B1=1 To BLC_NBR
  If BLC_TYP(B1)=1 & L>=BLC_NOC(B1) & L<=BLC_NOC(B1)+BLC_PDS(B1)-1
   LIGTAB(L) = 1 : Break
  Endif
 Next B1
Next L
For B=1 To BLC_NBR
 If find(BLC_TYP(B),2,4,6,7,8,9,11)
  RESIDU = BLC_NCO(B)-sum(LARGE(BLC_NOC(B)..BLC_NOC(B)+BLC_PDS(B)-1))
  # On donne priorité aux colonnes non traitées en passe 1
  BB = 0
  For L=BLC_NOC(B) To BLC_NOC(B)+BLC_PDS(B)-1
   If FLIMP(L)=0
    BB += 1
   Endif
  Next L
  If BB>0 & RESIDU>0
   BB1 = 0
   DELTA = int(RESIDU/BB)
   For L=BLC_NOC(B) To BLC_NOC(B)+BLC_PDS(B)-1
    If FLIMP(L)=0
     BB1 += 1
     If BB1=BB
      LARGE(L) += RESIDU
      RESIDU    = 0
     Else
      LARGE(L) += DELTA
      RESIDU   -= DELTA
     Endif
    Endif
   Next L
  Endif
  ## Sinon on privilégie les colonnes ayant des tableaux
  While RESIDU>0
   For L=BLC_NOC(B) To BLC_NOC(B)+BLC_PDS(B)-1
    If LIGTAB(L) or sum(LIGTAB(BLC_NOC(B)..BLC_NOC(B)+BLC_PDS(B)-1))=0
     LARGE(L) += 1
     RESIDU   -= 1
     If RESIDU<=0 : Break : Endif
    Endif
   Next L
  Wend
 Endif
Next B

## 2bis) Traitement du mini des blocs tableaux

For B=1 To BLC_NBR
 If BLC_TYP(B)=1
  L = BLC_NOC(B)
  While BLC_MINCOL(B)>sum(LARGE(BLC_NOC(B)..BLC_NOC(B)+BLC_PDS(B)-1))
   LARGE(L) += 1
   L += 1
   If L>BLC_NOC(B)+BLC_PDS(B)-1
    L = BLC_NOC(B)
   Endif
  Wend
 Endif
Next B

## 3) Affectation du reste aux blocs tableaux

RESIDU = LARGMAX-sum(LARGE(1..NBLARGE))
NBTAB = 0
LARGEUR = 0
Raz LIGTAB
For LIGCUR=1 To NBLARGE
 For B=1 To BLC_NBR
  If BLC_TYP(B)=1 & LIGCUR>=BLC_NOC(B) & LIGCUR<=BLC_NOC(B)+BLC_PDS(B)-1
&  & BLC_PDS(B)<NBLARGE
   NBTAB += 1
   LIGTAB(LIGCUR) += BLC_PDS(B) : # 1
   LARGEUR += LARGE(LIGCUR)
   Break
  Endif
 Next B
Next LIGCUR

# Si tous les tableaux d'une colonne sont aussi présents sur une autre colonne
# alors cette colonne n'est pas prioritaire

For LIGCUR=1 To NBLARGE
 If LIGTAB(LIGCUR)
  OKL = 0
  For L=1 To NBLARGE
   If L<>LIGCUR & LIGTAB(L)
    OKL = 1
    For B=1 To BLC_NBR
     If BLC_TYP(B)=1 & LIGCUR>=BLC_NOC(B) & LIGCUR<=BLC_NOC(B)+BLC_PDS(B)-1
      If !(L>=BLC_NOC(B) & L<=BLC_NOC(B)+BLC_PDS(B)-1)
       OKL = 0 : Break
      Endif
     Endif
    Next B
    If OKL : Break : Endif
   Endif
  Next L
  If OKL & NBTAB>1
   LIGTAB(LIGCUR) = 0
   LARGEUR -= LARGE(LIGCUR)
   NBTAB -= 1
  Endif
 Endif
Next LIGCUR

If NBTAB & RESIDU>0
 DH = int((LARGEUR+RESIDU)/sum(LIGTAB))
 For LIGCUR=1 To NBLARGE
  If LIGTAB(LIGCUR)
   If LARGE(LIGCUR)<DH*LIGTAB(LIGCUR)
    DELTA = min(RESIDU,DH*LIGTAB(LIGCUR)-LARGE(LIGCUR))
    LARGE(LIGCUR) += DELTA : # int(RESIDU/NBTAB)
    RESIDU -= DELTA
   Endif
  Endif
 Next LIGCUR
 RESIDU = LARGMAX-sum(LARGE(1..NBLARGE))
 If RESIDU>0
  For LIGCUR=1 To NBLARGE
   If LIGTAB(LIGCUR)
    LARGE(LIGCUR) += int(RESIDU/NBTAB)
   Endif
  Next LIGCUR
  RESIDU -= NBTAB*int(RESIDU/NBTAB)
 Endif
Endif

## 4) Affectation du reste au hasard

If NBLARGE
 While RESIDU>0
  For LIGCUR=1 To NBLARGE
   LARGE(LIGCUR) += 1
   RESIDU        -= 1
   If RESIDU<=0 : Break : Endif
  Next LIGCUR
 Wend
Endif

## 5) Recalcul taille des blocs

For B=1 To BLC_NBR
 If BLC_TYP(B)<>5 &  BLC_TYP(B)<>10
  BLC_NCO(B) = sum(LARGE(BLC_NOC(B)..BLC_NOC(B)+BLC_PDS(B)-1))
 Endif
Next B

LARGEUR = sum(LARGE(1..NBLARGE))
#  Test modifié pour ne pas sortir en erreur sur écrans Abel :  CC 14/01/2009 Bug 49661
If RESOL=3 and TET_TAI=4
  Local Integer H1,H2
  Call RESOLUTION(2,H1,H2,LARGMAX) From GLOBVAR
Endif
If LARGEUR>LARGMAX and GFUSION=0   : #  CC 15/02/2013 pour ne pas afficher ce message en fusion
# Call ECR_TRACE(ECRAN-":"-mess(76,133,1)-"("+num$(LARGEUR)+"/"+num$(LARGMAX)+")",0) From GESECRAN
# Pas assez de place en largeur
Endif



If TEST
 Call ECR_TRACE("Taille des blocs (D)",0) From GESECRAN
 Call ECR_TRACE("Largeur max"-num$(LARGMAX),0) From GESECRAN
 For L=1 To NBLARGE
  Call ECR_TRACE("Ligne"-num$(L)-":"-num$(LARGE(L)),0) From GESECRAN
 Next L
 For B=1 To BLC_NBR
  Call ECR_TRACE("Bloc"-num$(B)-":"-num$(BLC_NLI(B))-num$(BLC_NCO(B)),0) From GESECRAN
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

###########################################################
# E) Calculs finaux
#    Affectation des coordonnées
###########################################################

#{SAM 121133
For B=1 To BLC_NBR
 BLC_X(B) = min(255,1+sum(LARGE(1..BLC_NOC(B)-1)))
 BLC_Y(B) = 1+sum(HAUT(1..BLC_NOL(B)-1))
Next B
#SAM 121133}


################################################################################
# Centrage
################################################################################
If TET_TAI=2
 # Taille réelle de l'écran
 MAXX = 1
 MAXY = 1
 MINX = LGECRAN
 MINY = HTECRAN
 For B=1 To BLC_NBR
  If BLC_TYP(B)<>5  & BLC_TYP(B)<>10
   MINX = min(MINX,BLC_X(B))
   MAXX = max(MAXX,BLC_X(B)+BLC_NCO(B)-1)
   MINY = min(MINY,BLC_Y(B))
   MAXY = max(MAXY,BLC_Y(B)+BLC_NLI(B)-1)
  Endif
 Next B
 LARGEUR = MAXX-MINX+1
 HAUTEUR = MAXY-MINY+1
 # Calcul du décalage
 DX = max(0,(LGECRAN-LARGEUR)/2)
 DY = max(0,(HTECRAN-HAUTEUR)/2)
 # Affectation
 For B=1 To BLC_NBR
  BLC_X(B) += DX
  BLC_Y(B) += DY
 Next I
Endif

If TEST
 Call ECR_TRACE("Coordonnées des blocs (E)",0) From GESECRAN
 For B=1 To BLC_NBR
  Call ECR_TRACE("Bloc"-num$(B)-":"-num$(BLC_Y(B))-num$(BLC_X(B)),0) From GESECRAN
 Next B
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif

Return

########################################################
## Sous-prog
########################################################
$LONGCHAMP
LONGCHAMP = 0
For L1=1 To LIG_NBR(B)
 If int(LIG_NUM(B,L1))=LIGCUR & LIG_POS(B,L1)=COLCUR
  LONGCHAMP += 2*(LONGCHAMP<>0)+LIG_FLN(B,L1)+(LIG_LLI(B,L1)>0)+LIG_LLI(B,L1) : # 1 caractère de séparation
 Endif
Next L1
Return

