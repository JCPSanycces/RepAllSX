#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:25"
A_USER  = "DOC"
A_STAMP = "20181109230425"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "DTANBR"
  If [M]DTANBR=0
  Endif
 When "FLTNBR"
  If [M]FLTNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENHREXT1 [HREXE1]
Gosub HORODAT
Local Inpbox "GENHREXT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE1] As [SIM_]
Grizo [HREXE1]5
Grizo [HREXE1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXE1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=74 : Y1(1)=14 : Y2(1)=25
Return

$ON_DTALVL
Onevent INIT_AREA Call D_DTALVL(zc) From W1GENHREXT1
Onevent BEFORE_INPUT Call AS_DTALVL(zc) From W1GENHREXT1
Return

Subprog D_DTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]DTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DTALVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DTATBL
Onevent CONTROL Call C_DTATBL(zc) From W1GENHREXT1
Onevent BEFORE_INPUT Call AS_DTATBL(zc) From W1GENHREXT1
Return

Subprog AS_DTATBL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DTATBL(zc) From W1GENHREXT1
Onkey   2 Titled GBOUTS Call S_DTATBL(zc) From W1GENHREXT1
Onkey 144 Titled GBOUTP Call P_DTATBL(zc) From W1GENHREXT1
Onkey 146 Titled GBOUTA Call SA_DTATBL(zc) From W1GENHREXT1
Gosub _AFF
End

Subprog C_DTATBL(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ATB","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "DTATBL" : GZNUM = 1176 : Endif
Gosub _AFF
End

Subprog S_DTATBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATB"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_DTATBL(VALEUR)
Variable Char    VALEUR()
Call OBJET("ATB",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_DTATBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATB"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DTATBL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DTALNKCLC
Onevent BEFORE_INPUT Call AS_DTALNKCLC(zc) From W1GENHREXT1
Onevent CONTROL Call C_DTALNKCLC(zc) From W1GENHREXT1
Return

Subprog AS_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(988,GBOUT1) From OBJDIV
Call TEXTE(988,GBOUT2) From OBJDIV
Call TEXTE(988,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action LNKINIT
 Call AS_LNK(VALEUR) From LNKSUB
 If mkstat=2
  [M]DTALNKCLC(INDIC) = VALEUR
  Affzo DTALNKCLC(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_DTALNKCLC(zc) From W1GENHREXT1
Onkey 130 Titled GBOUT2 Call B2_DTALNKCLC(zc) From W1GENHREXT1
Onkey 131 Titled GBOUT3 Call B3_DTALNKCLC(zc) From W1GENHREXT1
Gosub _AFF
End

Subprog C_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action LNKCONT
 Call C_LNK(VALEUR) From LNKSUB
 If mkstat : GERR = 1 : GZONE = "DTALNKCLC" : GZNUM = 988 : Endif
Endif
Gosub _AFF
End

Subprog B1_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action LNKB1
 Call B1_LNK(VALEUR,nolign,[M]DTATBL) From LNKSUB
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action LNKB2
 Call B2_LNK(VALEUR) From LNKSUB
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action LNKB3
 Call B3_LNK(VALEUR,nolign,[M]DTATBL) From LNKSUB
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

