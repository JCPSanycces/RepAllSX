If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"","","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
