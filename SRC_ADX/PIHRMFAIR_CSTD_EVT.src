#<AdxTL>@(#)0.0.0.0 $Revision$
#Class PIHRMFAIR

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                : Gosub AINIT

    Endcase
Endcase
Return

$AINIT
#Create a unique code for a new integration
Local File PIHRMFAIR [PIFA2]
If this.INTUID = 0
  this.INTUID  = uniqid([PIFA2])
Endif
LogicClose File [PIFA2]
Return

$ADELETE_AFTER
Local Integer TRANSACTION_PENDING,DEL_OK

DEL_OK = [V]CST_AOK


Local File EMPLOCTRSTG  [HRCSG1]
Local File EMPUKISTG    [IDUSG1]
Local File EMPCTRUKISTG [CTRUSG1]
Local File EMPLORIBSTG  [RIBSG1]


#Detele all records from the table - EMPLOCTRSTG
  Delete [HRCSG1] Where [F:HRCSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPUKISTG
  Delete [IDUSG1] Where [F:IDUSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPCTRUKISTG
  Delete [CTRUSG1] Where [F:CTRUSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPLORIBSTG
  Delete [RIBSG1] Where [F:RIBSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

LogicClose File     [HRCSG1]
LogicClose File     [IDUSG1]
LogicClose File     [CTRUSG1]
LogicClose File     [RIBSG1]
Return

