#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque ACTIVLNK
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,"ACTIVLNK","ACTIVLNK",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return

$INIT
If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
TMP = 1
Return

$EXEC
Local Char CRITERE(250)
If [M:DIA]TOUUSR<>2
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'USRCOD="'+[M:DIA]USRCOD+'"'
Endif
If [M:DIA]TOUOBJ<>2
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= '(SRCOBJ="'+[M:DIA]OBJ+'" | DSTOBJ="'+[M:DIA]OBJ+'")'
Endif
If [M:DIA]TOULIA<>2
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'LNK="'+[M:DIA]LIA+'"'
Endif
If [M:DIA]AUTFLG<>2
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'AUTFLG<>2'
Elsif [M:DIA]MANFLG<>2
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'AUTFLG=2'
Endif
If [M:DIA]DATDEB<>[0/0/0]
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'CREDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN<>[0/0/0]
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'CREDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
Endif
If [M:DIA]FNC=1
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'ENAFLG<>2'
Else
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= 'ENAFLG=2'
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ALI]
 Case [M:DIA]FNC
  When 1 : Update [ALI] Where evalue(CRITERE) With ENAFLG=2
  When 2 : Update [ALI] Where evalue(CRITERE) With ENAFLG=1
 Endcase
Commit
Return

#####################################################
Subprog AS_USRCOD(VALEUR)
Variable Char    VALEUR()
If [M]TOUUSR=2 : mkstat = 2 : End : Endif
End

Subprog AS_OBJ(VALEUR)
Variable Char    VALEUR()
If [M]TOUOBJ=2 : mkstat = 2 : End : Endif
End

Subprog AS_LIA(VALEUR)
Variable Char    VALEUR()
If [M]TOULIA=2 : mkstat = 2 : End : Endif
End

