$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 186: RES='Codes activité'
   When 4: RES='Code activité'
  Endcase
 When "ENG":
  Case _ID
   When 186: RES='Activity codes'
   When 4: RES='Activity code'
  Endcase
 When "ITA":
  Case _ID
   When 186: RES='Codici attività'
   When 4: RES='Codice attività'
  Endcase
 When "POR":
  Case _ID
   When 186: RES='Códs. actividade'
   When 4: RES='Cód. activ.'
  Endcase
 When "SPA":
  Case _ID
   When 186: RES='Códigos actividad'
   When 4: RES='Código actividad'
  Endcase
 When "BRI":
  Case _ID
   When 186: RES='Activity codes'
   When 4: RES='Activity code'
  Endcase
 When "GER":
  Case _ID
   When 186: RES='Aktivitätscode'
   When 4: RES='Aktivitätscode'
  Endcase
 When "POL":
  Case _ID
   When 186: RES='Kody działań'
   When 4: RES='Kod działań'
  Endcase
 When "CHI":
  Case _ID
   When 186: RES='业务代码'
   When 4: RES='业务代码'
  Endcase
 When "ARB":
  Case _ID
   When 186: RES='رموز النشاط'
   When 4: RES='رمز النشاط'
  Endcase
Endcase
Return
