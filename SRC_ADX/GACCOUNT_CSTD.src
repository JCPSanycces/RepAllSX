#<AdxTL>@(#)12.0.0.0 $Revision$
# Classe GACCOUNT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
        When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

##########################################################################################################
$AREAD_AFTER
# BP authorizations
Local Integer I, NUMCUR, ITRANS, ITRANS2
If this.SAC=2
 # Delete the collection
 For I=0 To dim([F:GAC]AUZBPR)-1
  If [F:GAC]AUZBPR(I)<>0
   NUMCUR +=1
   this.AUZ1(NUMCUR).AUZDES = I+1
  Endif
 Next
Endif

Local File GCOA [COA]
Call LEC_COA(this.COA) From CPTLEC
If !fstat
 this.LEGCLS = [F:COA]LEGCLS
Endif

# Load adress
Local File BPADDRESS [BPA]
Filter [BPA] Where BPATYP=5 & BPANUM=this.COA+this.ACC
For [BPA]
 NUMCUR = fmet this.ADDLINE("BPA",[V]CST_ALASTPOS)
 this.BPA(NUMCUR).BPAADD     = [F:BPA]BPAADD
 this.BPA(NUMCUR).BPADES     = [F:BPA]BPADES
 this.BPA(NUMCUR).CRY        = [F:BPA]CRY
 this.BPA(NUMCUR).BPAADDLIG1 = [F:BPA]BPAADDLIG(0)
 this.BPA(NUMCUR).BPAADDLIG2 = [F:BPA]BPAADDLIG(1)
 this.BPA(NUMCUR).BPAADDLIG3 = [F:BPA]BPAADDLIG(2)
 this.BPA(NUMCUR).POSCOD     = [F:BPA]POSCOD
 this.BPA(NUMCUR).CTY        = [F:BPA]CTY
 this.BPA(NUMCUR).SAT        = [F:BPA]SAT
 this.BPA(NUMCUR).FCYWEB     = [F:BPA]FCYWEB
 this.BPA(NUMCUR).EXTNUM     = [F:BPA]EXTNUM
 this.BPA(NUMCUR).BPAADDFLG  = [F:BPA]BPAADDFLG
 For ITRANS=1 To 5
   ITRANS2 = fmet this.BPA(NUMCUR).ADDLINE("COLTEL",[V]CST_ALASTPOS)
   this.BPA(NUMCUR).COLTEL(ITRANS2).TELNUM = [F:BPA]TEL(ITRANS-1)
   this.BPA(NUMCUR).COLTEL(ITRANS2).TELTYP = ITRANS
 Next
 For ITRANS=1 To 5
   ITRANS2 = fmet this.BPA(NUMCUR).ADDLINE("COLWEB",[V]CST_ALASTPOS)
   this.BPA(NUMCUR).COLWEB(ITRANS2).WEBADR = [F:BPA]WEB(ITRANS-1)
   this.BPA(NUMCUR).COLWEB(ITRANS2).WEBTYP = ITRANS
 Next
Next
Filter [BPA]

# Load bid
Local File BID [BID]
Filter [BID] Where BPATYP=5 & BPANUM=this.COA+this.ACC
For [BID]
 NUMCUR = fmet this.ADDLINE("BID1",[V]CST_ALASTPOS)
 this.BID1(NUMCUR).CRY       = [F:BID]CRY
 this.BID1(NUMCUR).IBAN      = [F:BID]IBAN
 this.BID1(NUMCUR).BIDNUM    = [F:BID]BIDNUM
 this.BID1(NUMCUR).BIDNUMFLG = [F:BID]BIDNUMFLG
 this.BID1(NUMCUR).BPAADD    = [F:BID]BPAADD
 this.BID1(NUMCUR).CUR       = [F:BID]CUR
 this.BID1(NUMCUR).PAB1      = [F:BID]PAB1
 this.BID1(NUMCUR).PAB2      = [F:BID]PAB2
 this.BID1(NUMCUR).PAB3      = [F:BID]PAB3
 this.BID1(NUMCUR).PAB4      = [F:BID]PAB4
 this.BID1(NUMCUR).BNF       = [F:BID]BNF
 this.BID1(NUMCUR).BICCOD    = [F:BID]BICCOD
 this.BID1(NUMCUR).MIDPAB1   = [F:BID]MIDPAB1
 this.BID1(NUMCUR).MIDPAB2   = [F:BID]MIDPAB2
 this.BID1(NUMCUR).MIDPAB3   = [F:BID]MIDPAB3
 this.BID1(NUMCUR).MIDPAB4   = [F:BID]MIDPAB4
 this.BID1(NUMCUR).MIDBICCOD = [F:BID]MIDBICCOD
 this.BID1(NUMCUR).MIDCRY    = [F:BID]MIDCRY
Next
Filter [BID]

this.COAACC = this.COA+this.ACC

# Conversion Type
If this.DIF=2 or this.DIF=3
 For I=1 To 10 # Issue 105932
   this.CNV(I).CNVDES = mess(4+I, 2649, 1)
   this.CNV(I).CNVACC = evalue("[F:GAC]CNVACC"+num$(I))
 Next
Endif
Return

