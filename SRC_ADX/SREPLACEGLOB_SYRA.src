#--------------------------------------------------------------------------------------------------
#--En remplacement de GDECPRI
Funprog GET_GDECPRI()

Local Decimal DECPRI

#--Pour remplacement GDECPRI chargé par superviseur dans le ttt GLOBX3
# Lecture nombre décimales prix (max des types de donnée MD5/MD6/MD8)
Local File ATYPE [ATYY]

Read [ATYY]CODTYP='MD5'
If fstat = 0
 [L]DECPRI = mod([F:ATYY]LNGTYP,1)*10
Else
 [L]DECPRI = 4
Endif
Read [ATYY]CODTYP='MD6'
If fstat = 0
 If mod([F:ATYY]LNGTYP,1)*10 > [L]DECPRI
  [L]DECPRI = mod([F:ATYY]LNGTYP,1)*10
 Endif
Endif
Read [ATYY]CODTYP='MD8'
If fstat = 0
 If mod([F:ATYY]LNGTYP,1)*10 > [L]DECPRI
  [L]DECPRI = mod([F:ATYY]LNGTYP,1)*10
 Endif
Endif
#--
End [L]DECPRI
#--------------------------------------------------------------------------------------------------
#--En remplacement de GLOCALDEV
Funprog GET_GLOCALDEV(PFCY,PCPY)
Value Char PFCY()
Value Char PCPY()

Local Char LOCALDEV(GLONCUR) : 	[L]LOCALDEV = ""

If PFCY="" and PCPY="" : End 	[L]LOCALDEV : Endif

Local File COMPANY  [CPY]
Local File FACILITY [FCY]

If PCPY<>""
	 Read [F:CPY]CPY0=PCPY
	 If fstat Raz [F:CPY] Endif
Else
   Read [F:FCY]FCY0=PFCY
   If fstat Raz [F:FCY] Endif
   Read [F:FCPY]CPY0=[F:FCY]LEGCPY
   If fstat Raz [F:CPY] Endif
Endif

[L]LOCALDEV = [F:CPY]ACCCUR

End [L]LOCALDEV

#########################################################################################
# GET_ATEXTRA : S/P de récupération d'un texte traduit à partir de la table ATEXTRA     #
# ------------------------------------------------------------------------------------- #
# Paramètres E : TABLE  = Nom de la table contenant le texte                            #
#                ZONE   = Nom du champ contenant le texte                               #
#                LANGUE = Code langue                                                   #
#            S : TEXTE  = Contient le texte récupéré de ATEXTRA                         #
#                                                                                       #
# Prérequis    : La buffer de "TABLE" doit être ouvert et chargé !                      #
# ------------------------------------------------------------------------------------- #
# TABLES         ZONES possibles                                                        #
# ------------   ---------------                                                        #
# ATABDIV        LNGDES      SHODES                                                     #
# ATABTAB        LNGDES      SHODES      ALPDES1      ALPDES2     NUMDES1     NUMDES2   #
# CFGQST         SALTXT                                                                 #
# CRMTRS         DESAXX                                                                 #
# HDKTRS         DESAXX                                                                 #
# IMTMASTER      DES1AXX     DES2AXX     DES3AXX                                        #
# PFOOTINV       DESAXX      SHOAXX                                                     #
# PPRICCONF      DESAXX                                                                 #
# PPREASON       DESAXX                                                                 #
# PRICSTRUCT     DESAXX(0-8) SHOAXX(0-8)                                                #
# PURTRS         DESAXX                                                                 #
# SALTRS         DESAXX                                                                 #
# MFGTRS         DESAXX                                                                 #
# BENCHTRS       DESAXX                                                                 #
# SFOOTINV       DESAXX      SHOAXX                                                     #
# SPRICCONF      DESAXX                                                                 #
# SPREASON       DESAXX                                                                 #
# SPPRTCONF      DESAXX                                                                 #
# STKTRS         DESAXX                                                                 #
# TABCOEFF       COEAX2      COEAX1                                                     #
# TABCATBPS      DESAXX      SHOAXX                                                     #
# TABMODELIV     DESAXX      SHOAXX                                                     #
# TABDEPAGIO     DESAXX      SHOAXX                                                     #
# TABPACKAGE     DESAXX      SHOAXX                                                     #
# TABPAYTERM     DESAXX      SHOAXX                                                     #
# TABPIVTYP      DESAXX      SHOAXX                                                     #
# TABSIVTYP      DESAXX      SHOAXX                                                     #
# TABSOHTYP      DESAXX      SHOAXX                                                     #
# TABUNAVAIL     DESAXX      SHOAXX                                                     #
# TABUNIT        DES         DESSHO                                                     #
# TABCOUNTRY     CRYDES      ETANAM      ETANAM2                                        #
# TABVAT         DESAXX      SHOAXX                                                     #
# TABVATSEL      DESAXX      SHOAXX                                                     #
# BPCCATEG       DESAXX      SHOAXX                                                     #
# BPSCATEG       DESAXX      SHOAXX                                                     #
#                                                                                       #
#########################################################################################
Subprog GET_ATEXTRA(CTX, TABLE,ZONE,LANGUE,IDENT1,IDENT2,TEXTE)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    TABLE
Value    Char    ZONE
Value    Char    LANGUE
Value    Char    IDENT1
Value    Char    IDENT2
Variable Char    TEXTE()

#-----
Local File ATEXTRA [AXX]
#-----
If CTX=null : CTX = GACTX : Endif

Local Char CTX_LANDEF(10) : CTX_LANDEF = CTX.LAN

If LANGUE=""  LANGUE=CTX_LANDEF : Endif

Raz TEXTE#, [L]IDENT1, [L]IDENT2

If [L]IDENT1="" & [L]IDENT2=""  End : Endif

Read [AXX] AXX0=TABLE;ZONE;LANGUE;IDENT1;IDENT2
If fstat
  Read [AXX] AXX0=TABLE;ZONE;CTX_LANDEF;IDENT1;IDENT2
  If fstat
    Raz [F:AXX]
  Else
    TEXTE=[F:AXX]TEXTE
  Endif
Else
  TEXTE=[F:AXX]TEXTE
Endif
End
