#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SPRICESEAM
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AINIT"            :  Gosub AINIT
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "PRICESEARCHM"     :  Gosub FINDPRICE_FOR_MOBILE
    When "PRICELISTM"       :  Gosub PRICELIST_MET_MOBILE
    When "GETDEFAULT"       :  Gosub GET_DEFAULT
    When "LOAD_TECPJT"      :  Gosub LOAD_TECPJT           # Issue X3-49098 - 2017-07-25 by CPO : Search price mobile applications don't display the result
  Endcase
Return
#--------------------------------------
#--------------------------------------------------------------------------
$PROPERTIES

Case [L]CURPRO
  When "BPCORD_REP"   : Gosub BPCORD_REP
  When "ITMREF_REP"   : Gosub ITMREF_REP
  When "CURREF_REP"   : Gosub CURREF_REP
  When "SAUREF_REP"   : Gosub SAUREF_REP
  When "BPAADD_REP"   : Gosub BPAADD_REP
  When "VACBPR_REP"   : Gosub VACBPR_REP
  When "EECICT_REP"   : Gosub EECICT_REP
  When "PTE_REP"      : Gosub PTE_REP
  When "MDL_REP"      : Gosub MDL_REP
  When "PJT_REP"      : Gosub PJT_REP
Endcase

Return
#--------------------------------------------------------------------------
$AINIT

  this.BPCORD_REP = "" : this.ITMREF_REP = ""
  #--Set _isdef to "false"
  this.BPCORD_GETDF = [V]CST_AFALSE
  this.ITMREF_GETDF = [V]CST_AFALSE
  this.CURREF_ISDEF = [V]CST_AFALSE
  this.SAUREF_ISDEF = [V]CST_AFALSE
  this.BPAADD_ISDEF = [V]CST_AFALSE
  this.VACBPR_ISDEF = [V]CST_AFALSE
  this.EECICT_ISDEF = [V]CST_AFALSE
  this.PTE_ISDEF    = [V]CST_AFALSE
  this.MDL_ISDEF    = [V]CST_AFALSE
  this.PJT_ISDEF    = [V]CST_AFALSE

#  Local Char WATTRIBUT_CRIT(10)
#  Local Char WATTRIBUT_ADDCRIT(10)
#  Local Char WATTRIBUT_PRICERESULT(10)
#  Local Char WATTRIBUT_PRICELIST(10)
#
#  WATTRIBUT_CRIT        = "true"
#  WATTRIBUT_ADDCRIT     = "true"
#  WATTRIBUT_PRICERESULT = "true"
#  WATTRIBUT_PRICELIST   = "true"
#
#  Gosub MODIFY_ATTRIBUTS_ALL

  #Gosub INST_R_PRICE #Gb/CPO Tests

Return
#--------------------------------------------------------------------------
$BPCORD_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_BPCORD_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_BPCORD_REP

  If this.SPRISEA.BPCORD<>this.BPCORD_REP

     #Gosub SET_FROM_BPCORD_TOKEEP

     this.SPRISEA.BPCORD = this.BPCORD_REP :#--It triggers the propagate

     this.BPCORD_GETDF = [V]CST_ATRUE
  Else
     this.BPCORD_GETDF = [V]CST_AFALSE
  Endif
Return
#--------------------------------------------------------------------------
$ITMREF_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_ITMREF_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_ITMREF_REP

  If this.SPRISEA.ITMREF<>this.ITMREF_REP

    #Gosub SET_FROM_ITMREF_TOKEEP

    this.SPRISEA.ITMREF = this.ITMREF_REP :#--It triggers the propagate

    this.ITMREF_GETDF = [V]CST_ATRUE
  Else
    this.ITMREF_GETDF = [V]CST_AFALSE
  Endif
Return
#--------------------------------------------------------------------------
$CURREF_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_CURREF_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_CURREF_REP

  If (this.CURREF_ISDEF = [V]CST_ATRUE and this.CURREF_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.CURREF = this.CURREF_REP
  Endif

Return
#--------------------------------------------------------------------------
$SAUREF_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_SAUREF_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_SAUREF_REP

  If (this.SAUREF_ISDEF = [V]CST_ATRUE and this.SAUREF_REP <>"") | this.ITMREF_GETDF=[V]CST_AFALSE
    this.SPRISEA.SAUREF = this.SAUREF_REP
  Endif

Return

#--------------------------------------------------------------------------
$BPAADD_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_BPAADD_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_BPAADD_REP

  If (this.BPAADD_ISDEF = [V]CST_ATRUE and this.BPAADD_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.BPAADD = this.BPAADD_REP
  Endif

Return
#--------------------------------------------------------------------------
$VACBPR_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_VACBPR_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_VACBPR_REP

  If (this.VACBPR_ISDEF = [V]CST_ATRUE and this.VACBPR_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.VACBPR = this.VACBPR_REP
  Endif

Return
#--------------------------------------------------------------------------
$EECICT_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_EECICT_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_EECICT_REP

  If (this.EECICT_ISDEF = [V]CST_ATRUE and this.EECICT_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.EECICT = this.EECICT_REP
  Endif

Return
#--------------------------------------------------------------------------
$PTE_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_PTE_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_PTE_REP

  If (this.PTE_ISDEF = [V]CST_ATRUE and this.PTE_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.PTE = this.PTE_REP
  Endif

Return
#--------------------------------------------------------------------------
$MDL_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_MDL_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_MDL_REP

  If (this.MDL_ISDEF = [V]CST_ATRUE and this.MDL_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.MDL = this.MDL_REP
  Endif

Return
#--------------------------------------------------------------------------
$PJT_REP
Case [L]ARULE
   When "PROPAGATE" :  Gosub PROPAGATE_PJT_REP
   When Default     :  Return
Endcase
Return
#--------------------------------------------------------------------------
$PROPAGATE_PJT_REP

  If (this.PJT_ISDEF = [V]CST_ATRUE and this.PJT_REP <>"") | this.BPCORD_GETDF=[V]CST_AFALSE
    this.SPRISEA.PJT = this.PJT_REP
  Endif

Return
#--------------------------------------------------------------------------
$SET_FROM_BPCORD_TOKEEP

  this.CURREF_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.CURREF=""
    this.CURREF_ISDEF = [V]CST_ATRUE
  Endif

  this.BPAADD_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.BPAADD=""
    this.BPAADD_ISDEF = [V]CST_ATRUE
  Endif

  this.VACBPR_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.VACBPR=""
    this.CURREF_ISDEF = [V]CST_ATRUE
  Endif

  this.EECICT_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.EECICT=""
    this.EECICT_ISDEF = [V]CST_ATRUE
  Endif

  this.PTE_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.PTE=""
    this.PTE_ISDEF = [V]CST_ATRUE
  Endif

  this.MDL_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.MDL=""
    this.MDL_ISDEF = [V]CST_ATRUE
  Endif

  this.PJT_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.PJT=""
    this.PJT_ISDEF = [V]CST_ATRUE
  Endif

Return
#--------------------------------------------------------------------------
$SET_FROM_ITMREF_TOKEEP

  this.SAUREF_ISDEF = [V]CST_AFALSE
  If this.SPRISEA.SAUREF=""
    this.SAUREF_ISDEF = [V]CST_ATRUE
  Endif

Return
#--------------------------------------------------------------------------
$GET_DEFAULT

  # Issue 112865 - 2016-02-02 by CPO : Default values action in price search
  this.CURREF_REP = AVOID.ACHAR
  this.SAUREF_REP = AVOID.ACHAR
  this.BPAADD_REP = AVOID.ACHAR
  this.VACBPR_REP = AVOID.ACHAR
  this.EECICT_REP = AVOID.ACHAR
  this.PRITYP_REP = 1
  this.PTE_REP    = AVOID.ACHAR
  this.MDL_REP    = AVOID.ACHAR
  this.PJT_REP    = AVOID.ACHAR

  this.SPRISEA.BPCORD = AVOID.ACHAR #--Done this because as both SPRISEA.ITMREF and ITMREF_REP can be equal, the propagate might not be executed
  this.SPRISEA.BPCORD = this.BPCORD_REP :#--It triggers the propagate
  this.BPCORD_GETDF = [V]CST_ATRUE
  this.SPRISEA.ITMREF = AVOID.ACHAR #--Done this because as both SPRISEA.ITMREF and ITMREF_REP can be equal, the propagate might not be executed
  this.SPRISEA.ITMREF = this.ITMREF_REP :#--It triggers the propagate
  this.ITMREF_GETDF = [V]CST_ATRUE
  # End issue 112865

  #--Default values
  Gosub SET_PROPERTIES
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif # Issue X3-49098 - 2017-07-25 by CPO : Search price mobile applications don't display the result

  Gosub LOAD_R_PRICE
  [L]ARET_VALUE = [L]ASTATUS
#  Local Char WATTRIBUT_CRIT(10)
#  Local Char WATTRIBUT_ADDCRIT(10)
#
#  WATTRIBUT_CRIT        = "false"
#  Gosub MODIFY_ATTRIBUTS_CRITERIA
#
#  WATTRIBUT_ADDCRIT     = "false"
#  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA

Return
#--------------------------------------------------------------------------
#--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
$CONTROL_PROP

  Local Integer VRET
  Local Char    VMESSA(250)

  #--Because we are still on Edit mode, the global _ACONTROL of the class is not executed
  #--It meens that controls such as mandatory fields are not done (tha _aformat and _aothers control actions are executed, but not _amandatory)
  #--All those have to be done manually

  If this.CURREF_REP=""
    [L]ASTATUS = fmet this.ASETERROR("CURREF_REP",mess(10,123,1),[V]CST_AERROR)
    #Return # Issue 112865 - 2016-02-02 by CPO : Default values action in price search
  Endif

  If this.SAUREF_REP=""
    [L]ASTATUS = fmet this.ASETERROR("SAUREF_REP",mess(10,123,1),[V]CST_AERROR)
    #Return # Issue 112865 - 2016-02-02 by CPO : Default values action in price search
  Endif

  # Issue 110914 - 2015-09-30 by CPO : Add PRITYP_REP to this control
  If this.PRITYP_REP=0
    [L]ASTATUS = fmet this.ASETERROR("PRITYP_REP",mess(10,123,1),[V]CST_AERROR)
    #Return # Issue 112865 - 2016-02-02 by CPO : Default values action in price search
  Endif
  # End issue 110914

Return
#--------------------------------------------------------------------------
$SET_PROPERTIES
  #--A way to recover the properties in the sended json
  #--We don't want accessors triggered
  this.SPRISEA.setAccessorEnabled = [V]CST_AFALSE

  this.SPRISEA.SALFCY     = this.SPRISEA.SALFCY
  this.SPRISEA.STOFCY     = this.SPRISEA.STOFCY
  this.SPRISEA.CPY        = this.SPRISEA.CPY
  this.SPRISEA.LEG        = this.SPRISEA.LEG
  this.SPRISEA.PLISTC     = this.SPRISEA.PLISTC
  this.SPRISEA.BPCORD     = this.SPRISEA.BPCORD
  this.SPRISEA.ITMREF     = this.SPRISEA.ITMREF
  this.SPRISEA.DATEREF    = this.SPRISEA.DATEREF

  #--Dafault values if customer changed
  #--else (same customer), we keep the filled values
  If this.BPCORD_GETDF = [V]CST_ATRUE
    this.setAccessorEnabled = [V]CST_AFALSE
    this.CURREF_REP         = this.SPRISEA.CURREF
    this.PRITYP_REP         = this.SPRISEA.PRITYP
    this.BPAADD_REP         = this.SPRISEA.BPAADD
    this.VACBPR_REP         = this.SPRISEA.VACBPR
    this.SPRISEA.VACBPR_LEG = this.SPRISEA.VACBPR_LEG
    this.PTE_REP            = this.SPRISEA.PTE
    this.SPRISEA.PTE_LEG    = this.SPRISEA.PTE_LEG
    this.MDL_REP            = this.SPRISEA.MDL
    this.EECICT_REP         = this.SPRISEA.EECICT
    this.PJT_REP            = this.SPRISEA.PJT
    this.setAccessorEnabled = [V]CST_ATRUE
  Else
    this.SPRISEA.CURREF     = this.CURREF_REP
    this.SPRISEA.PRITYP     = this.PRITYP_REP
    this.SPRISEA.BPAADD     = this.BPAADD_REP
    this.SPRISEA.VACBPR     = this.VACBPR_REP
    this.SPRISEA.VACBPR_LEG = this.SPRISEA.VACBPR_LEG
    this.SPRISEA.PTE        = this.PTE_REP
    this.SPRISEA.PTE_LEG    = this.SPRISEA.PTE_LEG
    this.SPRISEA.MDL        = this.MDL_REP
    this.SPRISEA.EECICT     = this.EECICT_REP
    this.SPRISEA.PJT        = this.PJT_REP
  Endif

  #--Dafault values if item changed
  #--else (same item), we keep the filled values
  If this.ITMREF_GETDF = [V]CST_ATRUE
    this.setAccessorEnabled = [V]CST_AFALSE
    this.SAUREF_REP     = this.SPRISEA.SAUREF
    this.setAccessorEnabled = [V]CST_ATRUE
  Else
    this.SPRISEA.SAUREF = this.SAUREF_REP
  Endif

  this.SPRISEA.setAccessorEnabled = [V]CST_ATRUE
  #--/

Return
#--------------------------------------------------------------------------
$SET_PROPERTIES_REP
  #--A way to recover the properties in the sended json
  #--We don't want accessors triggered
  #this.SPRISEA.setAccessorEnabled = [V]CST_AFALSE

  this.SPRISEA.SALFCY     = this.SPRISEA.SALFCY
  this.SPRISEA.STOFCY     = this.SPRISEA.STOFCY
  this.SPRISEA.CPY        = this.SPRISEA.CPY
  this.SPRISEA.LEG        = this.SPRISEA.LEG
  this.SPRISEA.PLISTC     = this.SPRISEA.PLISTC
  this.SPRISEA.BPCORD     = this.SPRISEA.BPCORD
  this.SPRISEA.ITMREF     = this.SPRISEA.ITMREF
  this.SPRISEA.DATEREF    = this.SPRISEA.DATEREF
  this.SPRISEA.CURREF     = this.CURREF_REP
  this.SPRISEA.PRITYP     = this.PRITYP_REP
  this.SPRISEA.BPAADD     = this.BPAADD_REP
  this.SPRISEA.VACBPR     = this.VACBPR_REP
  #this.SPRISEA.VACBPR_LEG = this.SPRISEA.VACBPR_LEG
  this.SPRISEA.PTE        = this.PTE_REP
  #this.SPRISEA.PTE_LEG    = this.SPRISEA.PTE_LEG
  this.SPRISEA.MDL        = this.MDL_REP
  this.SPRISEA.EECICT     = this.EECICT_REP
  this.SPRISEA.PJT        = this.PJT_REP
  this.SPRISEA.SAUREF     = this.SAUREF_REP

#  this.SPRISEA.setAccessorEnabled = [V]CST_ATRUE
  #--/

Return
#--------------------------------------------------------------------------
$FINDPRICE_FOR_MOBILE
  Local Char WPROP(30)

  #--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
  Gosub CONTROL_PROP
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif
  #--/

  #--A way to recover the properties in the sended json
  #--As oposite to the Get_default, we do not change the filled values
  #--Accessors must be triggered
  Gosub SET_PROPERTIES_REP
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif # Issue X3-49098 - 2017-07-25 by CPO : Search price mobile applications don't display the result
  #--/

  [L]ASTATUS = fmet this.SPRISEA.PRICESEARCH_MET()
  If [L]ASTATUS>= [V]CST_AERROR
    WPROP = this.SPRISEA.AERROR.PRO # Issue 110915 - 2015-09-09 by CPO : The error is displayed but no explanation message
    # Issue 111108 - 2016-02-05 by CPO : Recherche tarifs en mobilité erreurs sur prop classe de base
    #--Mapping class properties => mobile reprensentation properties
    Case WPROP
      When "BPCORD" : WPROP = "BPCORD_REP"
      When "ITMREF" : WPROP = "ITMREF_REP"
      When "CURREF" : WPROP = "CURREF_REP"
      When "PRITYP" : WPROP = "PRITYP_REP"
      When "SAUREF" : WPROP = "SAUREF_REP"
      When "BPAADD" : WPROP = "BPAADD_REP"
      When "VACBPR" : WPROP = "VACBPR_REP"
      When "PTE"    : WPROP = "PTE_REP"
      When "MDL"    : WPROP = "MDL_REP"
      When "EECICT" : WPROP = "EECICT_REP"
      When "PJT"    : WPROP = "PJT_REP"
    Endcase
    # End issue 111108
    If fmet this.SPRISEA.AGETMAXERROR("")=[V]CST_AWARNING
      #WPROP = this.SPRISEA.AERROR.PRO # Issue 110915 - 2015-09-09 by CPO : The error is displayed but no explanation message
      #--The message for forbidden product is a warning => changed to error #--new
      If this.SPRISEA.AERROR.PRO="ITMREF"
        WPROP = "ITMREF_REP"
      Endif
      [L]ASTATUS = fmet this.ASETERROR (WPROP, this.SPRISEA.AERROR.MES, [V]CST_AERROR)
    Else
      # Issue 110915 - 2015-09-09 by CPO : The error is displayed but no explanation message
      #[L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"PRICESEARCHM_MET"-this.SPRISEA.AERROR.MES, [L]ASTATUS)
      [L]ASTATUS = fmet this.ASETERROR (WPROP, mess(68,123,1)-":"-this.SPRISEA.AERROR.MES, [L]ASTATUS)
      # End issue 110915
    Endif
    [L]ARET_VALUE = [L]ASTATUS
  Endif

  Gosub LOAD_R_PRICE

#  Local Char WATTRIBUT_PRICERESULT(10)
#  Local Char WATTRIBUT_PRICELIST(10)
#
#  WATTRIBUT_PRICERESULT = "false"
#  WATTRIBUT_PRICELIST   = "false"
#
#  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
#  Gosub MODIFY_ATTRIBUTS_PRICE_LIST


Return
#--------------------------------------------------------------------------
$LOAD_R_PRICE
Local Integer INBRPRICE

  If this.SPRISEA.C_PRICE(1)=null and this.SPRISEA.C_PRICE(2)=null
    Return
  Endif

  Gosub INST_R_PRICE

  INBRPRICE = 1
#  While this.SPRISEA.R_PRICE(INBRPRICE)<>null and find(this.SPRISEA.R_PRICE(INBRPRICE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
#    INBRPRICE += 1
#  Wend

  If this.SPRISEA.C_PRICE(1)<>null

    If INBRPRICE<=maxtab(this.SPRISEA.R_PRICE)-3
      this.SPRISEA.R_PRICE(INBRPRICE).LIBPRIX_REP   = mess(294,197,1) #"Prix brut"
      this.SPRISEA.R_PRICE(INBRPRICE).VALUE_REP     = this.SPRISEA.C_PRICE(1).GROPRI
      this.SPRISEA.R_PRICE(INBRPRICE+1).LIBPRIX_REP = mess(295,197,1) #"Prix net"
      this.SPRISEA.R_PRICE(INBRPRICE+1).VALUE_REP   = this.SPRISEA.C_PRICE(1).NETPRI
      this.SPRISEA.R_PRICE(INBRPRICE+2).LIBPRIX_REP = mess(167,123,1) #"Divers"
      this.SPRISEA.R_PRICE(INBRPRICE+2).VALUE_REP   = this.SPRISEA.C_PRICE(1).AUTRE
      this.SPRISEA.R_PRICE(INBRPRICE+3).LIBPRIX_REP = mess(155,121,1) #"Total"
      this.SPRISEA.R_PRICE(INBRPRICE+3).VALUE_REP   = this.SPRISEA.C_PRICE(1).TOTAL
    Endif
  Else

  Endif

  If this.SPRISEA.C_PRICE(2)<>null
    If INBRPRICE<=maxtab(this.SPRISEA.R_PRICE)-3
      this.SPRISEA.R_PRICE(INBRPRICE).AMOUNT_REP     = this.SPRISEA.C_PRICE(2).GROPRI
      this.SPRISEA.R_PRICE(INBRPRICE+1).AMOUNT_REP   = this.SPRISEA.C_PRICE(2).NETPRI
      this.SPRISEA.R_PRICE(INBRPRICE+2).AMOUNT_REP   = this.SPRISEA.C_PRICE(2).AUTRE
      this.SPRISEA.R_PRICE(INBRPRICE+3).AMOUNT_REP   = this.SPRISEA.C_PRICE(2).TOTAL
    Endif
  Else

  Endif

Return


$INST_R_PRICE
  #--Fill the presentation
  Local Integer I,WRET

  For I=1 To 4
    If this.SPRISEA.R_PRICE(I)=null
      WRET = fmet this.SPRISEA.ADDLINE("R_PRICE",I)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"R_PRICE","SPRICESEARCH"), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next I
Return

#--------------------------------------------------------------------------
$PRICELIST_MET_MOBILE
  Local Char WPROP(30) # Issue 111108 - 2016-02-05 by CPO : Recherche tarifs en mobilité erreurs sur prop classe de base

  #--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
  Gosub CONTROL_PROP
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif
  #--/

  [L]ASTATUS = fmet this.SPRISEA.PRICELIST_MET()
  If [L]ASTATUS>=[V]CST_AERROR
    # Issue 111108 - 2016-02-05 by CPO : Recherche tarifs en mobilité erreurs sur prop classe de base
    #[L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"PRICELIST_MET()", [L]ASTATUS)
    WPROP = this.SPRISEA.AERROR.PRO # Issue 110915 - 2015-09-09 by CPO : The error is displayed but no explanation message
    #--Mapping class properties => mobile reprensentation properties
    Case WPROP
      When "BPCORD" : WPROP = "BPCORD_REP"
      When "ITMREF" : WPROP = "ITMREF_REP"
      When "CURREF" : WPROP = "CURREF_REP"
      When "PRITYP" : WPROP = "PRITYP_REP"
      When "SAUREF" : WPROP = "SAUREF_REP"
      When "BPAADD" : WPROP = "BPAADD_REP"
      When "VACBPR" : WPROP = "VACBPR_REP"
      When "PTE"    : WPROP = "PTE_REP"
      When "MDL"    : WPROP = "MDL_REP"
      When "EECICT" : WPROP = "EECICT_REP"
      When "PJT"    : WPROP = "PJT_REP"
    Endcase
    [L]ASTATUS = fmet this.ASETERROR (WPROP, mess(68,123,1)-":"-mess(1,7845,1)-"PRICELIST_MET()", [L]ASTATUS)
    # End issue 111108
    [L]ARET_VALUE = [L]ASTATUS
  Endif

  Gosub LOAD_R_PRICE

Return
#--------------------------------------------------------------------------
$MODIFY_ATTRIBUTS_ALL

  Gosub MODIFY_ATTRIBUTS_CRITERIA
  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA
  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
  Gosub MODIFY_ATTRIBUTS_PRICE_LIST

Return
