#<AdxTL>@(#)0.0.0.0 $Revision$
# Class BSIFILFMTD


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
 Case [L]CURPRO
        When "SCT"    : Gosub PROPERTY_SCT
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$PROPERTY_SCT
   Case [L]ARULE
        When "PROPAGATE"
            #angre
            #If this.APARENT.FILTYP = 2
              Gosub SET_CSV_LINE_ATTRIBUTES
            #Endif
    Endcase
Return

$SET_CSV_LINE_ATTRIBUTES
  If this.APARENT.FILTYP = 2
    ASTATUS = fmet this.ASETATTRIBUTE("SCTSTR", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("SCTEND", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("TABTYP", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("SEGOBY", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("DBACT", "$isDisabled", "true")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE("SCTSTR", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("SCTEND", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("TABTYP", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("SEGOBY", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("DBACT", "$isDisabled", "false")
  Endif

Return

