#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque TPSVAR
GACTION = "MAJCUM1"
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,GACTION,"MAJCUM","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRE
 When "FIN"         : Gosub FIN
Endcase
Return

$OUVRE
If clalev([F:CUM])=0 : Local File CUMUL    [CUM] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
Local Integer FLMOD , OKCUM , PLEIN
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$DEBUT
If dim([M]LEG)<0
  GCURLEG = GDOSLEG
  Gosub CHARGE
Elsif GLEGFIL<>""
  GCURLEG = GLEGFIL
  Gosub CHARGE
Else
 Raz [M]LEG
Endif
Return

$CHARGE
Raz [M]
nolign = 0
PLEIN = 0
For [CUM]CUM0 Where LEG=GCURLEG
 Gosub TEST
 If OKCUM
  If nolign>=dim([M]CUMCOD)
   PLEIN = 1 : Break
  Endif
  nolign += 1
  [M] = [F:CUM]
  Gosub LIRE
 Endif
Next
[M]NBLIG = nolign
Affzo
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif
Return

$APRES_MODIF
FLMOD = 1
Return

$SETBOUT
If FLMOD
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
Return

$ABANDON
Gosub CHARGE
FLMOD = 0
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
FLMOD = 0
Return

###########################################################################
$TEST
Case GACTION
 When "MAJCUM1"
  OKCUM = find(2,[F:CUM]PRNFLG(0..1))
 When "MAJCUM2"
  OKCUM = ([F:CUM]CUMNUMADI<>"")
Endcase
Return

$RAZE
Case GACTION
 When "MAJCUM1"
  [F:CUM]PRNFLG(0) = 1
  [F:CUM]PRNFLG(1) = 1
 When "MAJCUM2"
  [F:CUM]CUMNUMADI = ""
Endcase
Return

$LIRE
Case GACTION
 When "MAJCUM1"
  [M]PRNFLG1(nolign-1)  = min(max([F:CUM]PRNFLG(0),1),2)
  [M]PRNFLG2(nolign-1)  = min(max([F:CUM]PRNFLG(1),1),2)
Endcase
Return

$ECRIRE
Case GACTION
 When "MAJCUM1"
  [F:CUM]PRNFLG(0) = [M]PRNFLG1(nolign-1)
  [F:CUM]PRNFLG(1) = [M]PRNFLG2(nolign-1)
Endcase
Return

###########################################################################

$TR1
GOK = 1
Trbegin [CUM]
 For nolign=1 To [M]NBLIG
  Readlock [CUM]CUM0 = GCURLEG;[M]CUMCOD(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$CUMUL"-[M]CUMCOD(nolign-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("CUM",[M]CUMCOD(nolign-1)) From GLOCK : Break
  Endif
  [F:CUM] = [M]
  Gosub ECRIRE
  Rewrite [CUM]
  If fstat
   GOK = 0 : Call FSTA("CUM") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [CUM]CUM0 Where LEG=GCURLEG
  Gosub TEST
  If OKCUM
   If !find([F:CUM]CUMCOD,[M]CUMCOD(0..[M]NBLIG-1))
    Readlock [CUM]CUM0 Curr
    If fstat=1
     GOK = -1 : GLOCK = "$CUMUL"-[F:CUM]CUMCOD : Break
    Elsif fstat
     GOK = 0 : Call RSTA("CUM",[F:CUM]CUMCOD) From GLOCK : Break
    Endif
    Gosub RAZE
    Rewrite [CUM]
    If fstat
     GOK = 0 : Call FSTA("CUM") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR1 : Endif
Return

########################################
## Ecran MAJCUMi
########################################
Subprog C_CUMCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CUMCOD(0..[M]NBLIG-1)) From OBJDIV
# JOJAC - 2016-02-24 - Req 114309 US 37 - START
If mkstat : End : Endif
# JOJAC - 2016-02-24 - Req 114309 US 37 - END
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MAJCUM1) 30/08/2012 11:31:38 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
Gosub CHARGE
If NBLIG=0
  [M]LEG=GCURLEG
  Affzo [M]LEG
Endif
End

