#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLSAL02   Contrôle Pre-migration Commandes normales   Module Vente  #
#                                                                          #
# Toutes versions :                                                        #
# ---------------                                                          #
# SORDER  without SORDERP                                                  #
# SORDERP without SORDER                                                   #
# SORDER  without SORDERQ                                                  #
# SORDERQ without SORDER                                                   #
# SORDERP with SALFCY different from SORDER                                #
# SORDERP with SOHCAT different from SORDER                                #
# SORDERQ with SALFCY different from SORDER                                #
# SORDERQ with SOHCAT different from SORDER                                #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLSAL02") From LECFIC
  Endif

  Call MAJ_UUMGCTLSAL02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLSAL02(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(4)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLSAL02 Sales Orders Process : SORDER-P") From DOSSUB
Call ECR_TRACE("UUMGCTLSAL02 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1 : # SORDER  without SORDERP
Gosub CTL2 : # SORDERP without SORDER
Gosub CTL3 : # SORDER  without SORDERQ
Gosub CTL4 : # SORDERq without SORDER
Gosub CTL5 : # SORDERP with SALFCY different from SORDER
Gosub CTL6 : # SORDERP with SOHCAT different from SORDER
Gosub CTL7 : # SORDERQ with SALFCY different from SORDER
Gosub CTL8 : # SORDERQ with SOHCAT different from SORDER

$FIN
Call ECR_TIME("UUMGCTLSAL02 : Sales Orders Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
# SORDER without SORDERP
###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SORDER")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SORDERP") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SOH.SOHNUM_0 FROM "-DOSSIER+".SORDER SOH "
REQSQL(1)="WHERE SOHCAT_0<4 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SORDERP SOP WHERE SOH.SOHNUM_0=SOP.SOHNUM_0) "
REQSQL(2)="ORDER BY SOH.SOHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SORDER without SORDERP",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSOHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SOHNUM="-[BXX]VSOHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################
###################################################################################
# SORDERP without SORDER
###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SORDER")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SORDERP") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT DISTINCT SOP.SOHNUM_0,SOP.SOPLIN_0 FROM "-DOSSIER+".SORDERP SOP "
REQSQL(1)="WHERE SOHCAT_0<4 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SOP.SOHNUM_0) "
REQSQL(2)="ORDER BY SOP.SOHNUM_0,SOP.SOPLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SORDERP without SORDER",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSOHNUM(50),Integer VSOPLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SOHNUM/SOPLIN="-[BXX]VSOHNUM+'/'+num$([BXX]VSOPLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
