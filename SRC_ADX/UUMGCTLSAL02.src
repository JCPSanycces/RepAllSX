REQSQL(0)="SELECT SOP.SOHNUM_0,SOP.SOPLIN_0,SOP.SOPSEQ_0 FROM "-DOSSIER+".SORDERP SOP "
REQSQL(1)="WHERE SOP.SALFCY_0<>(SELECT SOH.SALFCY_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SOP.SOHNUM_0) "
