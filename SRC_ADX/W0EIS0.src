#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EIS0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CATTYP
mkstat = 0
zoncou = "CATTYP"
indice = 0
IMPENT = [M]CATTYP
If varinit([M]CATTYP,indice)=0
 IMPENT = 1
Endif
[M]CATTYP = IMPENT

## Zone PARCOD
mkstat = 0
zoncou = "PARCOD"
indice = 0
If varmode([M]PARCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PARCOD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 52054 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EPR","",[M]PARCOD,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 52054 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CATACT
mkstat = 0
zoncou = "CATACT"
indice = 0
IMPENT = [M]CATACT
If varinit([M]CATACT,indice)=0
 IMPENT = 1
Endif
[M]CATACT = IMPENT

## Zone CATOPE
mkstat = 0
zoncou = "CATOPE"
indice = 0
IMPENT = [M]CATOPE
If varinit([M]CATOPE,indice)=0
 IMPENT = 1
Endif
[M]CATOPE = IMPENT

## Zone TESTFLG
mkstat = 0
zoncou = "TESTFLG"
indice = 0
IMPENT = [M]TESTFLG
If varinit([M]TESTFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]TESTFLG,indice)=0
 [M]TESTFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TESTFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TESTFLG(indice)
 Endif
Endif
[M]TESTFLG = IMPENT

## Zone DUPLICATEFLG
mkstat = 0
zoncou = "DUPLICATEFLG"
indice = 0
IMPENT = [M]DUPLICATEFLG
If varinit([M]DUPLICATEFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]DUPLICATEFLG,indice)=0
 [M]DUPLICATEFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DUPLICATEFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DUPLICATEFLG(indice)
 Endif
Endif
[M]DUPLICATEFLG = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EIS0"
Return

