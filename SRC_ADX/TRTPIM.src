####################################################################################################
# Button tunnels on PIM Data type
# Issue X3-7425/119804 - 2016-11-16 by FGR : comment
####################################################################################################
####################################################################################################
Subprog PIM_INIT_BUTTON(AZC)
Variable Char    AZC()

  #  GBOUT1 : PIM - Tunnel dynamique
  #  GBOUT2 : PIM - Tunnel objet PJM
  #  GBOUT3 : PIM - Tunnel objet CRM
  # -------------------------
  Local File PIMPL [PIM]
  # -------------------------
  Read [PIM]PIM0=AZC
  If !fstat Then
    Case [F:PIM]PIMTYP
      When 1
        # CRM Project
        Raz GBOUT2
        Raz GBOUT3
      When 2
        # PJM Project
        Raz GBOUT2
        Raz GBOUT3
      When 3
        # Mixed Project
        Raz GBOUT3
      When 4
        # Budget
        Raz GBOUT3
      When 5, 6, 7
        # Task
        Raz GBOUT3
      When Default
        Raz GBOUT1
        Raz GBOUT2
        Raz GBOUT3
    Endcase
  Else
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
  Endif
  # -------------------------
End

####################################################################################################
Subprog PIM_BUTTON1(AZC)
Variable Char    AZC()

  # GBOUT1 : PIM - Tunnel dynamique
  # -------------------------
  Local File PIMPL [PIM]
  # -------------------------
  Read [PIM]PIM0=AZC
  # -------------------------
  Case [F:PIM]PIMTYP
    When 1
      # CRM Project
      Call TUNCRM(AZC) From PJMSELECT
    When 2, 3
      # PJM Project or mixed
      Call TUNPJM(AZC) From PJMSELECT
    When 4
      # Budget
      Call TUNPJMBUD(AZC, [F:PIM]OPPNUM) From PJMSELECT
    When 5, 6, 7
      # Task
      Call TUNPJMTSK(AZC, [F:PIM]OPPNUM) From PJMSELECT
  Endcase
  # -------------------------
End

####################################################################################################
Subprog PIM_BUTTON2(AZC)
Variable Char    AZC()

  # GBOUT2 : PIM - Tunnel objet PJM
  # ------------------------- PJM_KEY_SPLIT_OPPNUM(ACTX, INPKEY)
  Call TUNCRM(func PJM_KEY_SPLIT_OPPNUM(GACTX, AZC)) From PJMSELECT
  # -------------------------
End

####################################################################################################
Subprog PIM_BUTTON3(AZC)
Variable Char    AZC()

  # GBOUT3 : PIM - Tunnel objet CRM
  # -------------------------
  Call TUNCRM(func PJM_KEY_SPLIT_OPPNUM(GACTX, AZC)) From PJMSELECT
  # -------------------------
End

