#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer    ERROR : ERROR = [V]CST_AOK
Local Integer    COUNT

Local Char       PROPATH(250),PROINS(250),PRONAME(250)
Local Integer   LANCOUNT : LANCOUNT=0
Local Char       LANCODE(10)(1..)
Local Char       LANTITLE(50)(1..)
Local Char       LANISO(50)(1..)
Local Char       LANLOC(250)(1..)
Local Integer   AL
Local Integer   ASTATUS,STAT

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 ERROR = func ASYRWRKPRO.GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,[L]PROPATH,[L]PROINS,[L]PRONAME)
 If ERROR = [V]CST_AOK

  Local File ADOSSIER [ADS]
  #107271 Read [ADS]DOSSIER=nomap
  STAT=func DOSSUB.FILL_ADS(nomap)
  Local Instance LANGUAGE Using C_TABLAN
  LANGUAGE = NewInstance C_TABLAN AllocGroup null

  # For each language supported by the folder :
  For AL=1 To [F:ADS]NBRLAN
   [L]ASTATUS = fmet LANGUAGE.AREAD( [F:ADS]LAN(AL-1))
   If [L]ASTATUS = [V]CST_AOK
    [L]LANCOUNT += 1
    [L]LANCODE(LANCOUNT) = LANGUAGE.LAN
    [L]LANTITLE(LANCOUNT) = LANGUAGE.INTDES
    [L]LANISO(LANCOUNT)    = LANGUAGE.LANISO
    [L]LANLOC(LANCOUNT)   = evalue([L]PROPATH)
    [L]LANLOC(LANCOUNT)   = evalue('fmet '+[L]PROINS+'.AGETTEXTRALAN("'+[L]PRONAME+'","'+LANGUAGE.LAN+'")')
   Endif
  Next AL

  FreeGroup LANGUAGE
  Close Local File [ADS]
 Endif
 ERROR = func BUILD_ANSWER(ACTX,ASWK(COUNT),ARCV,PSYR,ASND,LANCOUNT,LANCODE,LANTITLE,LANISO,LANLOC)
Endif

End ERROR

#**
#* Funprog HANDLER_PUT()
#*!
Funprog HANDLER_PUT(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Integer   COUNT
Local Char       PROPATH(250),PROINS(250),PRONAME(250)
Local Integer   LANCOUNT : LANCOUNT=0
Local Char       LANCODE(10)(1..)
Local Char       LANTITLE(50)(1..)
Local Char       LANISO(50)(1..)
Local Char       LANLOC(250)(1..)
Local Clbfile   CNT

Local Instance  NODE         Using C_ASYRJSO  : NODE=null
Local Instance  VALUES    Using C_ASYRJSO  : VALUES=null
Local Instance  LOCALE    Using C_ASYRJSO  : LOCALE=null

Local Instance UPD(1..) Using C_ADELTA
Local Instance ULN(1..) Using C_ADELTALIN : # Uncommitted lines of collection by the serveur

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 # Load the representation's description :
 ASWK(COUNT).DATCLA.setAccessorEnabled = 1
 Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,1) From ASYRDELSYS

 ERROR = func ASYRWRKPRO.GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,[L]PROPATH,[L]PROINS,[L]PRONAME)
 If ERROR = [V]CST_AOK
  NODE = JSON

  While NODE <> null
   If NODE.PRO="$values"
    VALUES = NODE.SUB
    While VALUES <> null
     LOCALE = VALUES.SUB
     LANCOUNT += 1
     While LOCALE <> null
      If LOCALE.TYP = 5
       CNT =""
      Elsif left$( fmet LOCALE.AGETCNT,1) = '"'
       CNT = seg$(fmet LOCALE.AGETCNT,2,len(fmet LOCALE.AGETCNT)-1)
      Endif
      Case LOCALE.PRO
       When "$code": LANCODE(LANCOUNT) = CNT
       When "$title": LANTITLE(LANCOUNT) = CNT
       When "$locale": LANISO(LANCOUNT) = CNT
       When "$value": LANLOC(LANCOUNT) =CNT
      Endcase
      LOCALE = LOCALE.NEX
     Wend
     If len(LANCODE(LANCOUNT))
      If LANCODE(LANCOUNT) = ACTX.LAN
        Assign [L]PROPATH With LANLOC(LANCOUNT)
      Else
       ERROR = evalue('fmet '+[L]PROINS+'.ASETTEXTRALAN("'+[L]PRONAME+'","'+LANLOC(LANCOUNT)+'","'+LANCODE(LANCOUNT)+'")')
      Endif
     Endif
     VALUES = VALUES.NEX
    Wend
    Break
   Endif
   NODE = NODE.NEX
  Wend
  Call LOAD_DELTA(ASWK(COUNT).DATCLA,ASWK(COUNT).METCLA,UPD,ULN) From ASYRDELSRV
  Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,0) From ASYRDELSYS
  ASWK(COUNT).DATCLA.setAccessorEnabled = 0
  #Generate the answer to be sent to the client :
  ASWK(COUNT).NUMWRK += 1
  Call DETAIL_JSON(ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,ASWK(COUNT),PSYR,UPD,ASND.DATA) From ASYRDATDEL
 Endif
Endif
End ERROR



#**
#* BUILD_ANSWER
#*
#* @param ACTX
#* @param ASWK
#* @param ARCV
#* @param PSYR
#* @param ASND
#* @param JSON
#*!
Funprog BUILD_ANSWER(ACTX,ASWK,ARCV,PSYR,ASND,LANCOUNT,LANCODE,LANTITLE,LANISO,LANLOC)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Value Integer LANCOUNT

Variable Char LANCODE()(1..)
Variable Char LANTITLE()(1..)
Variable Char LANISO()(1..)
Variable Char LANLOC()(1..)

Local Integer    ERROR : ERROR = [V]CST_AOK
Local Char        PROPERTY(250)
Local Char        URL(250)

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  NODE          Using C_ASYRJSO  : NODE=null
Local Instance  VALUES      Using C_ASYRJSO  : VALUES=null
Local Instance  LOCALE      Using C_ASYRJSO  : LOCALE=null
Local Instance  LINKS          Using C_ASYRJSO  : LINKS=null

Local Integer AE,AL

[L]URL      = baseUrl+'/'+PSYR.URLUPD+"('"+num$(ASWK.TRCKID)+"')"
For AE = 2 To maxtab(ARCV.ENTITIES)
 [L]URL += '/' + ARCV.ENTITIES(AE)
Next AE

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'$url',[L]URL)  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'$type',func ASYRJSO.TYP('localization'))  From ASYRJSO
If LANCOUNT
 Call JSON_ADDARRAY(NODES,ROOT,"$values",VALUES)  From ASYRJSO
 For AL=1 To LANCOUNT
  Call JSON_ADDOBJECT(NODES,VALUES,"",LOCALE)  From ASYRJSO
  Call JSON_ADDSTRING(NODES,LOCALE,'$code'    ,LANCODE(AL))  From ASYRJSO
  Call JSON_ADDSTRING(NODES,LOCALE,'$title'    ,LANTITLE(AL))  From ASYRJSO
  Call JSON_ADDSTRING(NODES,LOCALE,'$locale' ,LANISO(AL))  From ASYRJSO
  If len(LANLOC(AL))
   Call JSON_ADDSTRING(NODES,LOCALE,'$value',LANLOC(AL))  From ASYRJSO
  Else
   Call JSON_ADDNULL(NODES,LOCALE,'$value')  From ASYRJSO
  Endif
 Next AL

 Call JSON_ADDOBJECT(NODES,ROOT,"$links",LINKS)  From ASYRJSO
 Call JSON_ADDOBJECT(NODES,LINKS,"$save",NODE)  From ASYRJSO
 Call JSON_ADDSTRING(NODES,NODE,'$title',mess(17,7971,1))  From ASYRJSO
 Call JSON_ADDSTRING(NODES,NODE,"$method","PUT")  From ASYRJSO
 Call JSON_ADDSTRING(NODES,NODE,'$url',[L]URL)  From ASYRJSO
Endif
Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

End ERROR

