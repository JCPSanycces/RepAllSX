#<AdxTL>@(#)5.0.0.0 $Revision$
Call OBJET("HRTRL",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Gestion des demandes de formation
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "INICRE"      : Gosub INICRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub SAUVE_LIGNES
 When "MODIF"       : Gosub SAUVE_LIGNES
 When "VERIF_MOD"   : Gosub VERIF
 When "VERIF_CRE"   : Gosub VERIF
 When "RAZCRE"      : [M]FLGTRE=1 : Affzo [M]FLGTRE
 When "FERME"     : Gosub FERME
Endcase
Return

###################################
$OUVRE
If clalev([F:TRH])=0    : Local File TIKRESHEA [TRH]    : Endif
If clalev([F:TRL])=0    : Local File TIKRESLIG [TRL]    : Endif
If clalev([F:CPY])=0    : Local File COMPANY   [CPY]    : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
If clalev([F:TCA])=0    : Local File TABCOUAFF [TCA]    : Endif
If clalev([F:SRV])=0    : Local File SERVICE   [SRV]    : Endif
Local Integer STAT, I
Local Char    COMPTEUR(GLONANM)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
Return

###################################
$FERME
If dim(SAV_GCURLEG)>=0 : GCURLEG = SAV_GCURLEG : Kill SAV_GCURLEG : Endif
Return

###################################
$SETBOUT
Call VIREBOUT(CHAINE,"HD") From GOBJET
If GREP<>"" | !VERROU | [M]FLGTRE=2
 Call VIREBOUT (CHAINE,"AG") From GOBJET    :#Bouton génération & supprimer
Endif
Return

########################################
$EXEBOUT
Case BOUT
 When "G"
  Gosub RELIT From GOBJSUB
 Endcase
Return

###################################
$INICRE
## Affectation du no de demande
If [F:TRH]NUMTRE=""
 If [F:TRH]CPY <> ""
   Call LECTURE("CPY",[F:TRH]CPY,"") From CONTOBJ
   GSOCIETE=[F:CPY]CPY
   If GNBLEG = 1
    GCURLEG = GDOSLEG
   Else
    If dim([F:CPY]LEG)>0
     GCURLEG =[F:CPY]LEG
    Endif
   Endif
 Endif

 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(81,134,1)
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(5)
 Endif

 Call NUMERO(COMPTEUR,"",datesyst,"",[F:TRH]NUMTRE,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_VCR([F:TRH]NUMTRE,COMPTEUR)
 If GOK=0 : Return : Endif
 [M]NUMTRE = [F:TRH]NUMTRE
 Affzo [M]NUMTRE
Endif
## Affectation de l'identifiant = SAGE01
If [F:TRH]REF=""
 [F:TRH]REF="SAGE01"
 [M]REF = [F:TRH]REF
 Affzo [M]REF
Endif
Return

###################################
Subprog VERIF_VCR(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:TRHZ])=0 : Local File TIKRESHEA [TRHZ] : Endif
Read [TRHZ]TRH0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",datesyst,"",NUM,STAT) From SUBANM
 Read [TRHZ]TRH0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

###################################
$LIENS
If GREP="" & [M]FLGTRE=2
 Grizo [M]CPY,DATTRE
Else
 Actzo [M]CPY,DATTRE
Endif
Gosub CHARGE_LIGNES
# Grizage de cellule contrat après chargement (sinon ça marche pas...)
For nolign=1 To [M]NBRLIG
 Read [F:ID]ID0=[M]REFNUM(nolign-1)
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Next
Affzo [M]
Return

###################################
$CHARGE_LIGNES
Raz [M]TOTTRE
nolign = 1
For [TRL]TRL0 Where NUMTRE=[F:TRH]NUMTRE
 [M] = [F:TRL]
 #Pour contrôler les doublons sur le couple Matricule+contrat
 [M]REFCTR(nolign-1)=[F:TRL]REFNUM+"|"+[F:TRL]CTRNUM+"|"+[F:TRL]CTRDAT :##**82073
 [M]TOTTRE+=[F:TRL]NBRTRE
 nolign +=1
Next
[M]NBRLIG = nolign-1
Affzo [M]
Return

###################################
$SAUVE_LIGNES
Delete [TRL] Where NUMTRE=[M]NUMTRE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("TRL",[F:TRL]NUMTRE-num$([F:TRL]LIG)) From GLOCK : Return
Else
 For nolign=1 To [M]NBRLIG
  [F:TRL]       = [M]
  [F:TRL]NUMTRE = [M]NUMTRE
  [F:TRL]DATTRE = [M]DATTRE
  [F:TRL]TRECPY = [M]TRECPY
  [F:TRL]REF = [M]REF
  [F:TRL]LIG = nolign
##**82073
  Read [F:HRCTR]CTR0 = [F:TRL]REFNUM;[F:TRL]CTRNUM;[F:TRL]CTRDAT
  If !fstat
   [F:TRL]FCY=[F:HRCTR]ETRFCY
  Endif
  #Affect matricule trafiqué pour l'envoyer sur 10 caractères !
  If len([F:TRL]REFNUM)<=10
   [F:TRL]EMP=[F:TRL]REFNUM
  Else
   [F:TRL]EMP=left$([F:TRL]REFNUM,5)+right$([F:TRL]REFNUM,len([F:TRL]REFNUM)-4)
  Endif
  Write [TRL]
  If fstat
   GOK=0 : Call FSTA("TRL") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

###################################
$VERIF
If [M]NBRLIG=0
 #Le tableau doit contenir au moins une ligne
 GMESSAGE = mess(205,199,1)
 OK=0 : Return
Endif
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran TRH0) 21/02/2008 12:36:10 (DBA)
######################################################################################

###########################
Subprog AS_DATTRE(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR=eomonth(GMOIPAY)
Endif
End

###########################
Subprog AM_DATTRE(VALEUR)
Variable Date    VALEUR
[M]NBRLIG=0
Effzo [M]15
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Read[F:CPY]CPY0=VALEUR
If fstat |[F:CPY]TRECPY=""
 #Code client non renseigné pour la société
 GMESSAGE = mess(1,10719,1)-VALEUR
 mkstat=2 : End
Else
 [M]TRECPY=[F:CPY]TRECPY
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer TROUVE
##**82073 It's optimized to begin by the control
#Verif si salarié a bien un contrat sur la société en entête de commande !
TROUVE=0
Filter [F:HRCTR] Where REFNUM=VALEUR & CTRDAT<=[M]DATTRE & (XITDAT=[0/0/0] | XITDAT>=[M]DATTRE) Order By Key CTR0 Desc
For [F:HRCTR]
 Read[F:FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat & [M]CPY=[F:FCY]LEGCPY
  TROUVE=1 : Break
 Endif
Next
Filter [F:HRCTR]
If !TROUVE
 # Salarié non présent dans la société
 GMESSAGE = mess(5,10719,1)-[M]CPY
 mkstat=2 : End
Endif

Read[F:ID]ID0=VALEUR
If !fstat
 [M]NAMSRN(nolign-1)=[F:ID]NAM-left$([F:ID]SRN,40-len([F:ID]NAM))
Else
 [M]NAMSRN(nolign-1)=""
Endif
##**82073
Call CHERCHE_CTR(VALEUR,[M:TRL0]DATTRE,[M]CTRNUM(nolign-1)) From DIVPAYE
Call GRISE_CTRNUM([F:ID]FLGMULCTR)

If [F:FCY]TREFCY=""
 #Code livraison non renseigné pour le site
 GMESSAGE = mess(2,10719,1)-[F:FCY]FCY
 mkstat=2 : End
Endif
[M]TREFCY(nolign-1)=[F:FCY]TREFCY
#87491
Read[F:SRV]SRV0=[F:HRCTR]ETRSRV
If !fstat : [M]TRESRV2(nolign-1)=[F:SRV]TRESRV2 : Endif
End

Subprog C_NBRLIG
## Bloque la saisie dans le tableau si commandé
If [M]FLGTRE=2 & !adxgtb
 mkstat=2 : End
Endif
End

Subprog APRES_NBRLIG
Raz [M]TOTTRE
For I=0 To [M]NBRLIG
 [M]TOTTRE+=[M]NBRTRE(I)
Next
Affzo [M]TOTTRE
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:TRL0]CTRNUM(nolign-1)
Else
 Diszo [M:TRL0]CTRNUM(nolign-1)
Endif
Affzo [M:TRL0]CTRNUM(nolign-1)
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Call SELCTR([M:TRL0]REFNUM(nolign-1),[M:TRL0]DATTRE,[M:TRL0]DATTRE,VALEUR) From DIVPAYE : Endif
End

# Contrôle déclenché que si salarié en multi-ctr
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer TROUVE
##**82073
#Verif si contrat choisi est bien sur la société en entête de commande !
TROUVE=0
Filter [F:HRCTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=VALEUR & CTRDAT<=[M]DATTRE Order By Key CTR0 Desc
For [F:HRCTR]
 Read[F:FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat & [M]CPY=[F:FCY]LEGCPY
  TROUVE=1 : Break
 Endif
Next
Filter [F:HRCTR]
If !TROUVE
 # Salarié non présent dans la société
 GMESSAGE = mess(5,10719,1)-[M]CPY
 mkstat=2 : End
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRL0) 16/04/2013 17:04:51 (DBA)
######################################################################################
##**82073
Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT<=[M]DATTRE & (XITDAT=[0/0/0] | XITDAT>=[M]DATTRE | (XITDAT<[M]DATTRE & XITFNL<2))
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 VALEUR=[F:HRCTR]CTRDAT
Endif
End

##**82073
Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
#unicity control
[M]REFCTR(nolign-1)=[M]REFNUM(nolign-1)+"|"+[M]CTRNUM(nolign-1)+"|"+VALEUR
Call UNICITE([M]REFCTR(nolign-1),[M]REFCTR(0..[M]NBRLIG-1)) From OBJDIV
If mkstat=2 : End : Endif

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Read [F:HRCTR]CTR0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1);VALEUR
If fstat
 GMESSAGE=mess(26,10701,1) #: Contrat inexistant
 mkstat=2 : End
Elsif ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<[M]DATTRE & [F:HRCTR]XITFNL=2)
 # Salarié non présent dans la société
 GMESSAGE = mess(5,10719,1)-[M]CPY
 mkstat=2 : End
Endif
End

##**82073
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
[M]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT
End

######################################################################################
