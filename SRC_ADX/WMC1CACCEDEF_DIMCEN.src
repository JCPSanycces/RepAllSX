#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## ACLA-CLASSE ## CACCEDEF_DIMCEN
# 2018-11-06 07:04:04 418


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : DIE Dimension codes ( Field DIE 3)
####################################################################

$SET_DIE
If [L]_AOLDVAL<>this.DIE
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_DIE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.DIE
 Gosub PROPAGATE_DIE
Endif
Return

$INIT_DIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DIE"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_DIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DIE"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_DIE                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_DIE                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_DIE
[L]CURPRO = "DIE"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.DIE,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_DIE
[L]CURPRO = "DIE"
If vireblc(this.DIE,2)<>vireblc(format$("K:3c",this.DIE),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_DIE
[L]CURPRO = "DIE"
If vireblc(this.DIE,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPDIE.ACTRLREF(this,"DIE",this.DIE,this.DIE,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.DIE<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_DIE
[L]CURPRO = "DIE"
Return

$PROPAGATE_DIE
this.isReadonly = 0
[L]CURPRO = "DIE"
Gosub _LNKPRO_DIE
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_DIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DIE"
$_LNKPRO_DIE
If vireblc(this.DIE,2)<>""
 # Link GDIE
 Local File GDIE [WDIE]
 Read [F:WDIE]DIE0 = this.DIE
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="GDIE" & ZONE="SHOTRA" & IDENT1=[F:WDIE]DIE & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("DIE","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="GDIE" & ZONE="DESTRA" & IDENT1=[F:WDIE]DIE & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("DIE","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WDIE]
Endif
Return


####################################################################
# 2 : DESDIE Description ( Field AX3)
####################################################################

$GET_DESDIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DESDIE"
this.DESDIE = fmet this.AGETTEXTRA(CURPRO)
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return

$SET_DESDIE
If [L]_AOLDVAL<>this.DESDIE
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_DESDIE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.DESDIE
 Gosub PROPAGATE_DESDIE
Endif
Return

$INIT_DESDIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DESDIE"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_DESDIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DESDIE"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_DESDIE                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_DESDIE                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_DESDIE
[L]CURPRO = "DESDIE"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.DESDIE,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_DESDIE
[L]CURPRO = "DESDIE"
If vireblc(fmet this.AGETTEXTRA("DESDIE"),2)<>vireblc(format$("K:30X",fmet this.AGETTEXTRA("DESDIE")),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_DESDIE
[L]CURPRO = "DESDIE"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_DESDIE
[L]CURPRO = "DESDIE"
Return

$PROPAGATE_DESDIE
this.isReadonly = 0
[L]CURPRO = "DESDIE"
[L]ASTATUS = fmet this.ASETTEXTRA(CURPRO,this.DESDIE)
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_DESDIE
Gosub DECLARE_VAR From WMC0CACCEDEF_DIMCEN
[L]CURPRO = "DESDIE"
$_LNKPRO_DESDIE
Return




