#<AdxTL>@(#)6.0.0.0 $Revision$
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
#Call AS_ALLCPY(VALEUR) From CPTTRT
# bug 12539 (CP:22/01/02)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    mkstat = 1 : End 
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char  VALEUR
Call AS_CPY(VALEUR) From CPTTRT
End

########################################
Subprog AS_NBLIG
If [M]ALLCPY = 2 
 Effzo CPY,ZCPY
 [M]NBLIG=0
 mkstat = 1
 End
Endif
End

########################################
Subprog C_SENFCY(VALEUR)
Variable Char    VALEUR()
Read[FCY]FCY0=VALEUR
If !find([F:FCY]LEGCPY,[M]CPY(0..[M]NBLIG-1)) & [M]ALLCPY<>2
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
 mkstat = 2
Endif
End

########################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CPY(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If clalev([F:DCP])=0 : Local File DADCPY [DCP] : Endif
Read[DCP]DCP0=VALEUR
If fstat
 GMESSAGE = mess(24,122,1) : # Société non répertoriée DAS2
 mkstat = 2
Endif
End

########################################
Subprog D_YEA(VALEUR)
Variable Decimal VALEUR
VALEUR = year(date$)-1
End

