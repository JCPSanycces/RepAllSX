#<AdxTL>@(#)7.0.0.0 $Revision$
# ------------------------------------------------------------
# SUBAPSSTA
# Version 0007
#    Serveur de statistiques
#
#    E45835 - Geode tunnel
#    E52357 - Prevision debordement
#    E52337 - AccÃĻs aux tables statistiques par UPDCOD de PARSTA2
#    E52733 - Manque des lignes si pas de rÃĐsultat sur la pÃĐriode 1
#
# ------------------------------------------------------------
# Extraction des donnÃĐes liÃĐes Ã  des statistiques
# Si la stat est dÃĐfinie sur N niveaux, on peut aller jusqu'au niveau N+1
# (dans ce cas, on ne reprend qu'une ligne de dÃĐtail)
# Exemple d'utilisation avec une stat VTE1, dÃĐfinie sur le dÃĐclencheur SID, avec les critÃĻres suivants :
# ITMMASTER / TSICOD(2)
# SINVOICED / ITMREF
# BPCUSTOMER / TSCCOD(1)
# SINVOICEV / BPCINV
# au niveau 1, on verra toutes les lignes pour chaque famille statistique article
# au niveau 2, on verra les lignes pour une famille statistique article donnÃĐe, avec le dÃĐtail par articles
# au niveau 3, on verra, pour un couple famille stat, code article donnÃĐ, le dÃĐtail par codes stat clients
# au niveau 4, on verra, pour le triplet (famstat art, code art, famstat cli), le dÃĐtail par clients
# au niveau 5, on restreindra le niveau 4 au code client donnÃĐ

# AmÃĐliorations par rapport au premier essai :
# - ÃĐvaluation des formules (page "avancÃĐe")
# - accÃĻs aux prÃĐvisions et aux pÃĐriodes prÃĐcÃĐdentes

# Limitations Ã  connaÃŪtre :
# - le nombre de lignes extraites est limitÃĐ (variable GDIMSTAT)
# - il n'y a pas d'arrondi fait comme le rÃĐalise le traitement stat (Ã  faire ultÃĐrieurement)
# Lorsqu'un zoom est envisageable, un tag <ZOOM> a ÃĐtÃĐ ajoutÃĐ, qui donne les paramÃĻtres d'appel du zoom
# Sous-programme de gÃĐnÃĐration (pour le moment sur un fichier fixe)
# On attend :
# - le code, la sociÃĐtÃĐ, le site, les bornes de date dÃĐbut/fin des deux pÃĐriodes (si un comparatif est fait)
# - le niveau d'interrogation (1=niveau le plus haut, 2 = 1er zoom, etc...)
# - les valeurs fixÃĐes compte tenu du niveau de zoom sont donnÃĐes par le tableau VALCRIT
# - on ne redescend pas au niveau de dÃĐtail le plus fin (interrogation sur la table trop longue)
# 

# ------------------------------------------------------------
$S_GENEINIT

Global Integer GDIMSTAT
GDIMSTAT=100
Local Char VALCRIT(20)(1..8)    # modif 4 en 8 suite demande DB de 8 crit en saisie
Local Integer OK , OKTRT
Local Char CODE, CPY, FCY
Local Date DATDEB,DATFIN,DDATDEB,DDATFIN
Local Integer LEVEL
Local Integer S_LEVELMIN

# Code 
CODE=S_STACOD
GFONCTION="CONSSTA" : Call AUTORIS From EXEFNC    # Gestion autorisation std
If GNBAUZ=0
    U_MESCODE="X3FNCNOTAUTHORIZE" : U_MESP1=GFONCTION : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
Endif
CODE = [PS2]UPDCOD  # 52337

# Lecture des paramÃĻtres sources de donnÃĐes
LEVELMIN=1    # Level mini autorisÃĐ de la stat: levelmin=1 -> pas de critÃĻre, =2 -> 1 crit ....
SW_CTXFOR=mess(40,137,1)-[F:APV]APVCOD-mess(45,137,1)-[F:APV]SRCCODTYP(SW_I)    # contexte
For SW_I=0 To [F:APV]SRCPARNBR-1
    SW_PARCOD=[F:APV]SRCPARCOD(SW_I)
    #U_CTXFOR=SW_CTXFOR-mess(41,137,1)-SW_PARCOD    # contexte
    #U_EVAFOR=[F:APV]SRCPARFOR(SW_I) : Gosub U_EVAFOR From SUBAPSUTI
    #If U_ERR=UC_ERRG : Return : Endif    # erreur 
    #U_TRAMES=U_CTXFOR-mess(41,137,1)-U_PARCODE-":"-U_RESFOR : Gosub U_TRAPUT From SUBAPSUTI
    U_PARCODE=SW_PARCOD : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR=UC_ERRG : Break : Endif
    
    Case SW_PARCOD
    When SC_CPY             # SociÃĐtÃĐ
        CPY=U_PARVAL
    When SC_FCY             # Site
        FCY=U_PARVAL
        If FCY<>"" & GUSRFCY(1)<>"\" & !find(FCY,GUSRFCY(1..GNBAUZ)) # autorisation site      # JPJ E25552
             U_MESCODE="X3STAFCYNOTAUTHO" : U_MESP1=FCY : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Break
        Endif     # JPJ E25552
    When SC_DATDEB1
        DATDEB=U_PARVALDAT
        #Gosub $SETDATE : If U_ERR=UC_ERRG : Break : Endif    # erreur
        #DATDEB=SW_DATE    
    When SC_DATFIN1
        DATFIN=U_PARVALDAT
        #Gosub $SETDATE : If U_ERR=UC_ERRG : Break : Endif    # erreur
        #DATFIN=SW_DATE    
    When SC_DATDEB2
        DDATDEB=U_PARVALDAT
        #Gosub $SETDATE : If U_ERR=UC_ERRG : Break : Endif    # erreur
        #DDATDEB=SW_DATE    
    When SC_DATFIN2
        DDATFIN=U_PARVALDAT
        #Gosub $SETDATE : If U_ERR=UC_ERRG : Break : Endif    # erreur
        #DDATFIN=SW_DATE    
    When Default
        SW_J=find(SW_PARCOD,SC_CRIT)
        If SW_J and vireblc(U_PARVAL,4)<>""    # niveau min sur critÃĻre non vide
            If SW_J+1 > LEVELMIN : LEVELMIN=SW_J+1: Endif
            VALCRIT(SW_J)=U_PARVAL        # Valeur du paramÃĻtre
        Endif
    Endcase
Next
If U_ERR=UC_ERRG : Return : Endif


LEVEL=LEVELMIN                # niveau Ã  traiter
If ( M_ACTION = SQ_ACTLOAD or M_ACTION = SQ_ACTTITLE)
    U_QSCODE=SQ_NIVEAU : Gosub U_QSREAD From SUBAPSUTI     
    If U_QSEXIST
        SW_I=val(U_QSVAL)
        If SW_I = 0
            U_MESCODE="X3STALEVELNOTNUMERIC" : U_MESP1=U_QSVAL : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
        Endif
        If ( SW_I <1 and SW_I > 9 )
            U_MESCODE="X3STALEVELINVALID" : U_MESP1=U_QSCODE : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
        Endif
        If ( SW_I < LEVEL)
            U_MESCODE="X3STALEVELNOTAUTHO" : U_MESP1=U_QSVAL : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
        Endif
        LEVEL=SW_I
    Endif
Endif

For SW_I=1 To LEVELMIN-1                           # VÃĐrifications critÃĻres
    If M_ACTION = SQ_ACTLOAD                          # avertissements si remise en cause des critÃĻres fixes
        U_QSCODE=SQ_CRIT + num$(SW_I) : Gosub U_QSREAD From SUBAPSUTI
        If U_QSEXIST
            If  U_QSVAL <> VALCRIT(SW_I)
                U_MESCODE="X3STACRIFIXED" : U_MESP1=U_QSCODE : U_MESP2=VALCRIT(SW_I) : U_ERR=UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
            Endif 
        Endif
    Endif
Next
If M_ACTION = SQ_ACTLOAD                               # CritÃĻres zoom 
    For SW_I=LEVELMIN To 8                                # Dernier non voulu (9) car risque de trop d'enreg.
        U_QSCODE=SQ_CRIT + num$(SW_I) : Gosub U_QSREAD From SUBAPSUTI
        If U_QSEXIST : VALCRIT(SW_I)=U_QSVAL : Endif
    Next
Endif

#VALCRIT(1)="FR"
#VALCRIT(2)="AN006"
#VALCRIT(3)="DIS"
#VALCRIT(4)="DIS001"

 Local Char CRITVAL(250),CRITFCY(250),CRITRUPT(255),CRITRUPT1(255)
 Local Integer II,NLI,RUPT,FLGPREC,FLGPREV,JJ, NBLINES

 Local Char CLE(30)(1..GDIMSTAT), LIBCLE(50)(1..GDIMSTAT),CLEINS(30),LIBINS(50)
 Local Decimal MONTANTS(10,1..GDIMSTAT), MONTPREVPREC(10,1..GDIMSTAT),
&              MONTPREV(10,1..GDIMSTAT), MONTPREC(10,1..GDIMSTAT),
&              MONTANT, COLONNE(1..GDIMSTAT)

Local Integer GRP , NBSITE , NBSOC
Local Char    TSITE(GLONFCY)(1..max(1,GNBSITE)) , TSOC(GLONCPY)(1..max(1,GNBSITE))

# Ouverture fichiers complÃĐmentaires statistiques
Local File [PS2], STAT [SAT], STAT [SAT1], STATPRV [SAP], STATPRV [SAP1]  # nota [PS2] ouvert par SUBAPSSTA

# Init groupe de site/sociÃĐtÃĐ
Call GRPSITSOC([L]CPY,[F:PS2]UPDLEV,GRP,NBSITE,TSITE,NBSOC,TSOC) From CNSSTASTD

# Verif niveau
If LEVEL > [F:PS2]NBRFLD + 1
    U_MESCODE="X3STALEVELTOOHIGHT" : U_MESP1=num$(LEVEL) : U_MESP2=num$([F:PS2]NBRFLD+1) : U_ERR=UC_ERRW : Gosub U_MESPUT From SUBAPSUTI
    LEVEL=[F:PS2]NBRFLD + 1
Endif
# Synthese niveaux
U_TECMES=' <MinLevel>' + num$(LEVELMIN) + '</MinLevel>' : Gosub U_TECPUT From SUBAPSUTI
U_TECMES=' <CurrentLevel>' + num$(LEVEL) + '</CurrentLevel>' : Gosub U_TECPUT From SUBAPSUTI
U_TECMES=' <MaxLevel>' + num$([F:PS2]NBRFLD + 1) + '</MaxLevel>' : Gosub U_TECPUT From SUBAPSUTI
If LEVELMIN < LEVEL     # Info sur niveau prÃĐcÃĐdent
    # U_HEXTOTXT=[F:PS2]FLDaDES(LEVEL-2) 
    Call LECTEXTRA(U_HEXTOTXT,"PARSTA2","FLDINTIT",[PS2]COD,num$(LEVEL-1)) From ATEXTRA
    Gosub U_TXTTOHEX From SUBAPSUTI
    U_TECMES=' <PrevDetailTitle>' + U_TXTTOHEX + '</PrevDetailTitle>' : Gosub U_TECPUT From SUBAPSUTI
Endif 
If LEVEL < [F:PS2]NBRFLD      # Info sur zoom suivant
    # U_HEXTOTXT=[F:PS2]FLDaDES(LEVEL) 
    Call LECTEXTRA(U_HEXTOTXT,"PARSTA2","FLDINTIT",[PS2]COD,num$(LEVEL+1)) From ATEXTRA
    Gosub U_TXTTOHEX From SUBAPSUTI
    U_TECMES=' <NextDetailTitle>' + U_TXTTOHEX + '</NextDetailTitle>' : Gosub U_TECPUT From SUBAPSUTI
Endif 

# CritÃĻres utilisÃĐs
U_TECMES=' <Criteria>' : Gosub U_TECPUT From SUBAPSUTI
For SW_I=1 To LEVEL-1
    U_HEXTOTXT=VALCRIT(SW_I) : Gosub U_TXTTOHEX From SUBAPSUTI
    U_TECMES='   <Criterion' + num$(SW_I) +'>' + U_TXTTOHEX + '</Criterion' + num$(SW_I) +'>' : Gosub U_TECPUT From SUBAPSUTI
Next
U_TECMES=' </Criteria>' : Gosub U_TECPUT From SUBAPSUTI

# Montants pour cumuls
 Local Decimal MONTCUM(0..[F:PS2]NBRFRM-1), TOTCUM(0..[F:PS2]NBRFRM-1)

# CritÃĻre de sÃĐlection liÃĐ au niveau de stat recherchÃĐ (aux valeurs connues) et au niveau maximum de la stat
 For II=1 To [F:PS2]NBRFLD
     CRITVAL+=string$(CRITVAL<>""," &")-"CRI"+num$(II)
&         +string$(II=LEVEL,"<>'")+string$(II<>LEVEL,"='")
&         +string$(II<LEVEL,VALCRIT(II))+string$(II>=LEVEL,'$$$')+"'"
 Next II

# CritÃĻre sociÃĐtÃĐ/site
 #If CPY<>"" & [PS2]UPDLEV>1
 #    CRITFCY="CPY='"+CPY+"'"
 #Endif
 #If FCY<>"" & [PS2]UPDLEV>2
 #    CRITFCY+=string$(CRITFCY<>""," & ")+" FCY='"+FCY+"'"
 #Endif
 #CRITFCY+=string$(CRITFCY="","1=1")

 CRITFCY = "1=1"
 If [L]CPY<>"" & !GRP
  CRITFCY -= '& CPY="'+[L]CPY+'"'
 Endif
 If [L]FCY<>""
  CRITFCY -= '& FCY="'+[L]FCY+'"'
 Elsif GRP
  If NBSITE>0
   CRITFCY -= '& find(FCY,TSITE(1..NBSITE))'
  Else
   CRITFCY -= '& find(CPY,TSOC(1..NBSOC))'
  Endif
 Endif
 If GUSRFCY(1)<>"\" & ([L]FCY<>"" or (GRP & !NBSOC)) & GNBAUZ<>GNBSITE
  CRITFCY -= '& find(FCY,GUSRFCY(1..GNBAUZ))'
 Endif

# Flags mis Ã  1 si la pÃĐriode prÃĐcÃĐdente est impactÃĐe et si les prÃĐvisions le sont aussi
 FLGPREC=0
 FLGPREV=0
 For II=1 To [PS2]NBRFRM
     If sigma(1,10,pat(format$("KTv2:255X",AMTFRM(II-1)),"*CC"+num$(indcum)+"*"))
         FLGPREC=1
         Break (FLGPREV=1)
     Endif
     If sigma(1,10,pat(format$("KTv2:255X",AMTFRM(II-1)),"*P"+num$(indcum)+"*"))
         FLGPREV=1
         Break (FLGPREC=1)
     Endif
     If sigma(1,10,pat(format$("KTv2:255X",AMTFRM(II-1)),"*PP"+num$(indcum)+"*"))
         FLGPREC=1
         FLGPREV=1
         Break
     Endif
 Next II

# DÃĐclarations pour les cumuls si nÃĐcessaire
 If max([F:PS2]CUMFRM)>2
     Local Decimal COLCUM(0..[F:PS2]NBRFRM-1,1..GDIMSTAT)
 Endif

# OpÃĐrations prÃĐliminaires 
 Raz MONTANTS

 RUPT=min(LEVEL+1,9)
 CRITRUPT=sigma(1,RUPT,string$(indcum>1," & ")+"CRI"+num$(indcum)+"=[SAT]CRI"+num$(indcum))
 CRITRUPT1=sigma(1,RUPT,string$(indcum>1," & ")+"CRI"+num$(indcum)+"=[SAT1]CRI"+num$(indcum))

# Objet lien sur les critÃĐres le cas ÃĐchÃĐant
If clalev([F:ATZ])=0  : Local File ATABZON  [ATZ]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE    [ATY]  : Endif
#If clalev([F:AOB])=0  : Local File AOBJET   [AOB]  : Endif

For S_NBCOL=0 To [PS2]NBRFLD-1
    S_COLLINK(II)=""
    Read [ATZ]CODZONE = [F:PS2]TBL(S_NBCOL);[F:PS2]FLDNAM(S_NBCOL)
    If fstat=0
        Read [ATY]CODTYP = [F:ATZ]CODTYP
        If fstat=0 & [F:ATY]OBJLIEN<>""
#          Read [AOB]ABREV = [F:ATY]OBJLIEN
#          If fstat=0
#              S_COLLINK(S_NBCOL)= [F:AOB]ABREV
#          Endif
          # Recherches infos sur la clÃĐ de la table principale de l'objet
          Call EXISTE_ADX("","","WO"+[F:ATY]OBJLIEN,OKTRT) From ORDSYS
          If OKTRT>0  # trt objet existe
                Gosub SETCLE From ="WO"+[F:ATY]OBJLIEN        # en retour: CLEPRIM, CLESEC() et CLESUP()
                # Seule les clÃĐs Ã  une seule composante sont gÃĐrÃĐes
#  Bug 45787 : ajout d'un test d'existence de CLESUP
                If ((GPRODUIT<>1 and CLESEC(0)="") or (GPRODUIT=1 and (dim(CLESUP)<0 or CLESUP(0)="")))    # Geode E45787 (voir ex WOITC)
                        S_COLLINK(S_NBCOL)= [F:ATY]OBJLIEN
                Endif
          Endif
        Endif
    Endif
Next

Return 

# ------------------------------------------------------------
$S_GENETIT
# Trace
U_TRAMES="--> $S_GENETIT (initialisation)" : Gosub U_TRAPUT From SUBAPSUTI 

# En-tÃŠte dÃĐcrivant les colonnes
U_SEQPUT='<Titles>' : Gosub S_SEQPUTDEC
# U_SEQPUT=' <Title>' + [PS2]DEaS + '</Title>' : Gosub S_SEQPUTDEC
# Codage des caractÃĻres spÃĐciaux --   Bug 47832     CC  21/08/2008
Local Char VALLM(200)
#U_SEQPUT=' <Title>'+func AFNC.TEXTRA("PARSTA2","INTIT",[F:PS2]COD,"")+'</Title>' 
VALLM=func AFNC.TEXTRA("PARSTA2","INTIT",[F:PS2]COD,"") : Gosub MVALC From INTRUTILA
U_SEQPUT=' <Title>'+VALLM+'</Title>' 

 Gosub S_SEQPUTDEC

# U_HEXTOTXT=[F:PS2]FLDaDES(LEVEL-1) 
Call LECTEXTRA(U_HEXTOTXT,"PARSTA2","FLDINTIT",[PS2]COD,num$(LEVEL)) From ATEXTRA
Gosub U_TXTTOHEX From SUBAPSUTI
U_SEQPUT=' <ColTitle Num="1" X3Type="7" >' + U_TXTTOHEX + '</ColTitle>' : Gosub S_SEQPUTDEC     # JPJ E28697
Call TEXTE(8,U_HEXTOTXT) From OBJDIV : Gosub U_TXTTOHEX From SUBAPSUTI    # 8: intitulÃĐ
U_SEQPUT=' <ColTitle Num="2" X3Type="7" >' + U_TXTTOHEX + '</ColTitle>' : Gosub S_SEQPUTDEC     # JPJ E28697
For II=0 To [PS2]NBRFRM-1
    U_HEXTOTXT=func AFNC.TEXTRA("PARSTA2","INTITFRM",[F:PS2]COD,num$(II+1)) 
    Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT=' <ColTitle Num="' + num$(II +3) + '" X3Type="4">' + U_TXTTOHEX + '</ColTitle>' : Gosub S_SEQPUTDEC     # JPJ E28697
Next II
U_SEQPUT='</Titles>' : Gosub S_SEQPUTDEC
Return

# ------------------------------------------------------------
$S_GENE
# Trace
U_TRAMES="--> $S_GENE (gÃĐnÃĐration donnÃĐes) " : Gosub U_TRAPUT From SUBAPSUTI 

# Premier parcours des lignes de stats principales
SW_STR1="COD=CODE"
If DATDEB<>[00/00/00] : SW_STR1+=" & DAT>=DATDEB" : Endif
If DATFIN<>[00/00/00] : SW_STR1+=" & DAT<=DATFIN" : Endif
If dim([SAP]CRI8)>0
    Filter [SAT] Where evalue(SW_STR1) & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7;CRI8
Elsif dim([SAP]CRI7)>0
    Filter [SAT] Where evalue(SW_STR1) & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7
Elsif dim([SAP]CRI6)>0
    Filter [SAT] Where evalue(SW_STR1) & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6
Elsif dim([SAP]CRI5)>0
    Filter [SAT] Where evalue(SW_STR1) & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5
Else
    Filter [SAT] Where evalue(SW_STR1) & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4
Endif

Filter [SAP] Where evalue(SW_STR1)

# Calcul des N montants par agrÃĐgation des lignes de stats sur la pÃĐriode et les sociÃĐtÃĐs/sites concernÃĐs
        # Nota [PS2]NBRAMT n'existe plus en 140
        Local Integer S_DIMSTA
        If clalev([F:ACV]) = 0 : Local File ACTIV [ACV] : Endif
        Read [ACV]CODACT="STA"
        If fstat = 0
          S_DIMSTA = [F:ACV]DIME
        Else 
          S_DIMSTA = 10
        Endif

 JJ=1
 For [SAT]CLE(RUPT)
    For [SAT]CLE
       For II=0 To S_DIMSTA-1
           MONTANTS(II,JJ)+=[SAT]AMT(II)
       Next II
    Next
    If FLGPREV
       For [SAP] Where evalue(CRITRUPT)
           For II=0 To S_DIMSTA-1
               MONTPREV(II,JJ)+=[SAP]AMT(II)
           Next
       Next
    Endif

    Gosub CLE_STAT : CLE(JJ)=CLEINS
    Gosub LIB_STAT : LIBCLE(JJ)=LIBINS

    JJ+=1 : If JJ>GDIMSTAT : Break : Endif
 Next
 NBLINES=JJ-1

# Calcul des N montants de la pÃĐriode prÃĐcÃĐdente s'ils existent
 If FLGPREC
    If dim([SAT]CRI8)>0 
        Filter [SAT1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN & evalue(CRITVAL) & evalue(CRITFCY)
&                     Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7;CRI8
    Elsif dim([SAT]CRI7)>0
        Filter [SAT1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN & evalue(CRITVAL) & evalue(CRITFCY)
&                     Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7
    Elsif dim([SAT]CRI6)>0
        Filter [SAT1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN & evalue(CRITVAL) & evalue(CRITFCY)
&                     Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5;CRI6
    Elsif dim([SAT]CRI5)>0
        Filter [SAT1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN & evalue(CRITVAL) & evalue(CRITFCY)
&                     Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4;CRI5
    Else
        Filter [SAT1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN & evalue(CRITVAL) & evalue(CRITFCY)
&                Order By Key CLE=COD;CRI1;CRI2;CRI3;CRI4
 Endif

    Filter [SAP1] Where COD=CODE & DAT>=DDATDEB & DAT<=DDATFIN 
    JJ=1
    For [SAT1]CLE(RUPT)
        #Gosub CLE_STAT
        Gosub CLE_STAT1 : # 14.1.8
        If NBLINES=0                # E52733 - Pas de rÃĐsultat sur la pÃĐriode 1
            NBLINES+=1
            CLE(JJ)=CLEINS
            #Gosub LIB_STAT
            Gosub LIB_STAT1 : # 14.1.8
            LIBCLE(JJ)=LIBINS
        Elsif CLEINS>CLE(JJ)        # Recherche index insertion
            Repeat
                JJ+=1
            Until JJ>NBLINES or CLEINS<=CLE(JJ)
            If JJ>NBLINES
                Break (NBLINES>=GDIMSTAT)
                NBLINES+=1
                CLE(JJ)=CLEINS
                #Gosub LIB_STAT
                Gosub LIB_STAT1 : # 14.1.8
                LIBCLE(JJ)=LIBINS
            Endif
        Endif
        If CLEINS<CLE(JJ)
            NBLINES=min(GDIMSTAT,NBLINES+1)
            Gosub DEC_JJ
            CLE(JJ)=CLEINS
            #Gosub LIB_STAT
            Gosub LIB_STAT1 : # 14.1.8
            LIBCLE(JJ)=LIBINS
            Gosub RAZ_JJ
        Endif
        For [SAT1]CLE
            For II=0 To dim([SAT1]AMT)-1
                MONTPREC(II,JJ)+=[SAT1]AMT(II)
            Next II
        Next
        If FLGPREV
            For [SAP1] Where evalue(CRITRUPT1)
                For II=0 To dim([SAT1]AMT)-1
                    MONTPREVPREC(II,JJ)+=[SAP1]AMT(II)
                Next
            Next
        Endif
    Next
 Endif

# Ecriture des lignes
 U_SEQPUT='<Lines>' : Gosub S_SEQPUTDEC
 If max([F:PS2]CUMFRM)<=2
    Gosub STATS1
 Else
    Gosub STATS2
 Endif
U_SEQPUT='</Lines>' : Gosub S_SEQPUTDEC

Return

# Recherche des critÃĻre plus rapide qu'un evalue, et adaptÃĐ au fait que CRI8 Ã  CRI5 peuvent ne pas exister
$CLE_STAT
    Case LEVEL
        When 8
            CLEINS=[SAT]CRI8
        When 7
            CLEINS=[SAT]CRI7
        When 6
            CLEINS=[SAT]CRI6
        When 5
            CLEINS=[SAT]CRI5
        When Default
            CLEINS=string$(LEVEL=1,[SAT]CRI1)+string$(LEVEL=2,[SAT]CRI2)+string$(LEVEL=3,[SAT]CRI3)
&                 +string$(LEVEL=4,[SAT]CRI4)
    Endcase
Return

$LIB_STAT
    Case LEVEL
        When 8
            LIBINS=ctrans([SAT]DES8,"<>","  ")
        When 7
            LIBINS=ctrans([SAT]DES7,"<>","  ")
        When 6
            LIBINS=ctrans([SAT]DES6,"<>","  ")
        When 5
            LIBINS=ctrans([SAT]DES5,"<>","  ")
        When Default
            LIBINS=ctrans(string$(LEVEL=1,[SAT]DES1)+string$(LEVEL=2,[SAT]DES2)
&                 +string$(LEVEL=3,[SAT]DES3)+string$(LEVEL=4,[SAT]DES4),"<>","  ")
    Endcase
Return

