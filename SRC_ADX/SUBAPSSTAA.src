# ------------------------------------------------------------
# Ecriture des lignes de stat (cas simple sans total prÃĐliminaire Ã  calculer)
$STATS1
 # Trace
 U_TRAMES="--> $STATS1 (Ecriture des lignes de stat - cas simple) " : Gosub U_TRAPUT From SUBAPSUTI 

 For JJ=1 To NBLINES
     Gosub S_DEBLINE

     For II=0 To [PS2]NBRFRM-1
         Call FORMU([PS2]AMTFRM(II),MONTANT,
&                    MONTANTS(0,JJ),MONTANTS(1,JJ),MONTANTS(2,JJ),MONTANTS(3,JJ),MONTANTS(4,JJ),
&                    MONTANTS(5,JJ),MONTANTS(6,JJ),MONTANTS(7,JJ),MONTANTS(8,JJ),MONTANTS(9,JJ),
&                    MONTPREV(0,JJ),MONTPREV(1,JJ),MONTPREV(2,JJ),MONTPREV(3,JJ),MONTPREV(4,JJ),
&                    MONTPREV(5,JJ),MONTPREV(6,JJ),MONTPREV(7,JJ),MONTPREV(8,JJ),MONTPREV(9,JJ),
&                    MONTPREC(0,JJ),MONTPREC(1,JJ),MONTPREC(2,JJ),MONTPREC(3,JJ),MONTPREC(4,JJ),
&                    MONTPREC(5,JJ),MONTPREC(6,JJ),MONTPREC(7,JJ),MONTPREC(8,JJ),MONTPREC(9,JJ),
&                    MONTPREVPREC(0,JJ),MONTPREVPREC(1,JJ),MONTPREVPREC(2,JJ),MONTPREVPREC(3,JJ),
&                    MONTPREVPREC(4,JJ),MONTPREVPREC(5,JJ),MONTPREVPREC(6,JJ),MONTPREVPREC(7,JJ),
&                    MONTPREVPREC(8,JJ),MONTPREVPREC(9,JJ)
& )
         Case [F:PS2]CUMFRM(II)
            When 1 
                 SW_STRINTVAL=num$(MONTANT)
                 SW_STRVAL=format$("NzZ3:" + GFM92,MONTANT)
            When 2 
                 MONTCUM(II)+=MONTANT
                 SW_STRINTVAL=num$(MONTCUM(II))
                 SW_STRVAL=format$("NzZ3:" + GFM92,MONTCUM(II))
         Endcase
         #  debut
         U_SEQPUT='  <Col Num="'+num$(II+3)+'" X3Type="4">' : Gosub S_SEQPUTDEC       # type decimal     # JPJ E28697
         #  valeurs
         U_SEQPUT='     <X3IntVal>' + SW_STRINTVAL + '</X3IntVal>' : Gosub S_SEQPUTDEC
         U_SEQPUT='     <X3Value>' + SW_STRVAL + '</X3Value>' : Gosub S_SEQPUTDEC    # valeur avec conversion
         #  fin colonne
         U_SEQPUT="    </Col>": Gosub S_SEQPUTDEC

     Next II
     Gosub ECRIZOOM
     U_SEQPUT='</Line>' : Gosub S_SEQPUTDEC
        
     # E52357 - Prevision debordement
     If U_OUTFLGMAX : Break : Endif

 Next JJ
Return

# ------------------------------------------------------------
# Ecriture des lignes de stat (cas oÃđ total prÃĐliminaire doit ÃŠtre calculÃĐ)
$STATS2
 # Trace
 U_TRAMES="--> $STATS2 (Ecriture des lignes de stat - cas complexe) " : Gosub U_TRAPUT From SUBAPSUTI 

 For JJ=1 To NBLINES
     For II=0 To [PS2]NBRFRM-1
         Call FORMU([PS2]AMTFRM(II),COLCUM(II,JJ),
&                    MONTANTS(0,JJ),MONTANTS(1,JJ),MONTANTS(2,JJ),MONTANTS(3,JJ),MONTANTS(4,JJ),
&                    MONTANTS(5,JJ),MONTANTS(6,JJ),MONTANTS(7,JJ),MONTANTS(8,JJ),MONTANTS(9,JJ),
&                    MONTPREV(0,JJ),MONTPREV(1,JJ),MONTPREV(2,JJ),MONTPREV(3,JJ),MONTPREV(4,JJ),
&                    MONTPREV(5,JJ),MONTPREV(6,JJ),MONTPREV(7,JJ),MONTPREV(8,JJ),MONTPREV(9,JJ),
&                    MONTPREC(0,JJ),MONTPREC(1,JJ),MONTPREC(2,JJ),MONTPREC(3,JJ),MONTPREC(4,JJ),
&                    MONTPREC(5,JJ),MONTPREC(6,JJ),MONTPREC(7,JJ),MONTPREC(8,JJ),MONTPREC(9,JJ),
&                    MONTPREVPREC(0,JJ),MONTPREVPREC(1,JJ),MONTPREVPREC(2,JJ),MONTPREVPREC(3,JJ),
&                    MONTPREVPREC(4,JJ),MONTPREVPREC(5,JJ),MONTPREVPREC(6,JJ),MONTPREVPREC(7,JJ),
&                    MONTPREVPREC(8,JJ),MONTPREVPREC(9,JJ)
& )
        TOTCUM(II)+=COLCUM(II,JJ)
     Next II
 Next JJ
 
 # Ecriture lignes
 For JJ=1 To NBLINES
     Gosub S_DEBLINE

     For II=0 To [PS2]NBRFRM-1
         Case [F:PS2]CUMFRM(II)
            When 1 
                 SW_STRINTVAL=num$(COLCUM(II,JJ))
                 SW_STRVAL=format$("NzZ3:" + GFM92,COLCUM(II,JJ))
            When 2 
                 MONTCUM(II)+=COLCUM(II,JJ)
                 SW_STRINTVAL=num$(MONTCUM(II))
                 SW_STRVAL=format$("NzZ3:" + GFM92,MONTCUM(II))
            When 3
                 SW_DEC1=100*COLCUM(II,JJ)/(TOTCUM(II)+(TOTCUM(II)=0))
                 SW_STRINTVAL=num$(SW_DEC1)
                 SW_STRVAL=format$("NzZ3:" + GFM92,SW_DEC1)
            When 4
                 MONTCUM(II)+=COLCUM(II,JJ)
                 SW_DEC1=100*MONTCUM(II)/(TOTCUM(II)+(TOTCUM(II)=0))
                 SW_STRINTVAL=num$(SW_DEC1)
                 SW_STRVAL=format$("NzZ3:" + GFM92,SW_DEC1)
         Endcase
         # debut
         U_SEQPUT='  <Col Num="'+num$(II+3)+'" X3Type="4">' : Gosub S_SEQPUTDEC       # type decimal     # JPJ E28697
         #  valeurs
         U_SEQPUT='     <X3IntVal>' + SW_STRINTVAL + '</X3IntVal>' : Gosub S_SEQPUTDEC
         U_SEQPUT='     <X3Value>' + SW_STRVAL + '</X3Value>' : Gosub S_SEQPUTDEC    # valeur avec conversion
         #  fin 
         U_SEQPUT="    </Col>": Gosub S_SEQPUTDEC

     Next II

     Gosub ECRIZOOM
     U_SEQPUT='</Line>' : Gosub S_SEQPUTDEC

     # E52357 - Prevision debordement
     If U_OUTFLGMAX : Break : Endif

 Next JJ
Return

# ------------------------------------------------------------
$S_DEBLINE
    U_SEQPUT=' <Line Num="'+num$(JJ)+'" >' : Gosub S_SEQPUTDEC

    U_SEQPUT='  <Col Num="1" X3Type="7" '      # JPJ E28697
    # Objet liÃĐ en fonction du niveau
    If S_COLLINK(LEVEL-1)<>""    #   lien
         Call GETURLCLEPRIM(S_COLLINK(LEVEL-1), CLE(JJ), M_MODE, SW_URL) From SUBAPSOBJ
         If SW_URL<>""
             U_HEXTOTXT=SW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
             U_SEQPUT+=' X3Link="' + U_TXTTOHEX + '" '
         Endif
    Endif
    U_SEQPUT +=  ' >': Gosub S_SEQPUTDEC

    U_HEXTOTXT=CLE(JJ) : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT='     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub S_SEQPUTDEC

    U_SEQPUT='     <X3Value>' + CLE(JJ) + '</X3Value>' : Gosub S_SEQPUTDEC
    U_SEQPUT="  </Col>": Gosub S_SEQPUTDEC
    
    U_HEXTOTXT=LIBCLE(JJ) : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT='  <Col Num="2" X3Type="7">' : Gosub S_SEQPUTDEC     # JPJ E28697
    U_SEQPUT='     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub S_SEQPUTDEC
    U_SEQPUT='     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub S_SEQPUTDEC  
    U_SEQPUT="  </Col>": Gosub S_SEQPUTDEC
Return

# ------------------------------------------------------------
Subprog FORMU(EXPR,RESULT
& ,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10
& ,P1,P2,P3,P4,P5,P6,P7,P8,P9,P10
& ,CC1,CC2,CC3,CC4,CC5,CC6,CC7,CC8,CC9,CC10
& ,PP1,PP2,PP3,PP4,PP5,PP6,PP7,PP8,PP9,PP10)
Value    Char    EXPR
Variable Decimal RESULT
Value    Decimal C1, C2, C3, C4, C5, C6, C7, C8, C9, C10 
Value    Decimal P1, P2, P3, P4, P5, P6, P7, P8, P9, P10
Value    Decimal CC1, CC2, CC3, CC4, CC5, CC6, CC7, CC8, CC9, CC10
Value    Decimal PP1, PP2, PP3, PP4, PP5, PP6, PP7, PP8, PP9, PP10
Onerrgo RIEN
RESULT = evalue(EXPR)
Onerrgo
End

$RIEN
Resume

# Effacement (un peu optimisÃĐ en fonction des champs retenus) de la ligne jj
# Dommage que Raz ne fonctionne pas sur des parties de tableaux !
$RAZ_JJ
 If FLGPREV<>0 & FLGPREC<>0
     For II=0 To dim([SAT1]AMT)-1
         MONTANTS(II,JJ)=0
         MONTPREV(II,JJ)=0
         MONTPREC(II,JJ)=0
         MONTPREVPREC(II,JJ)=0
     Next II
 Elsif FLGPREV
     For II=0 To dim([SAT1]AMT)-1
         MONTANTS(II,JJ)=0
         MONTPREV(II,JJ)=0
     Next II
 Elsif FLGPREC
     For II=0 To dim([SAT1]AMT)-1
         MONTANTS(II,JJ)=0
         MONTPREC(II,JJ)=0
     Next II
 Else
     For II=0 To dim([SAT1]AMT)-1
         MONTANTS(II,JJ)=0
     Next II
 Endif
Return

# DÃĐcalage(un peu optimisÃĐ en fonction des champs retenus) Ã  partir de la ligne JJ
# Dommage que Insa ne fonctionne pas sur des parties de tableaux !
$DEC_JJ
 If FLGPREV<>0 & FLGPREC<>0 : # Optimisons les tests dans les boucles
     For KK=NBLINES To JJ+1 Step -1
         CLE(KK)=CLE(KK-1)
         LIBCLE(KK)=LIBCLE(KK-1)
         For II=0 To dim([SAT1]AMT)-1
             MONTANTS(II,KK)=MONTANTS(II,KK-1)
             MONTPREV(II,KK)=MONTPREV(II,KK-1)
             MONTPREC(II,KK)=MONTPREC(II,KK-1)
             MONTPREVPREC(II,KK)=MONTPREVPREC(II,KK-1)
         Next II
     Next KK
 Elsif FLGPREC
     For KK=NBLINES To JJ+1 Step -1
         CLE(KK)=CLE(KK-1)
         LIBCLE(KK)=LIBCLE(KK-1)
         For II=0 To dim([SAT1]AMT)-1
             MONTANTS(II,KK)=MONTANTS(II,KK-1)
             MONTPREC(II,KK)=MONTPREC(II,KK-1)
         Next II
     Next KK
 Elsif FLGPREV
     For KK=NBLINES To JJ+1 Step -1
         CLE(KK)=CLE(KK-1)
         LIBCLE(KK)=LIBCLE(KK-1)
         For II=0 To dim([SAT1]AMT)-1
             MONTANTS(II,KK)=MONTANTS(II,KK-1)
             MONTPREV(II,KK)=MONTPREV(II,KK-1)
         Next II
     Next KK
 Else
     For KK=NBLINES To JJ+1 Step -1
         CLE(KK)=CLE(KK-1)
         LIBCLE(KK)=LIBCLE(KK-1)
         For II=0 To dim([SAT1]AMT)-1
             MONTANTS(II,KK)=MONTANTS(II,KK-1)
         Next II
     Next KK
 Endif
Return


# ------------------------------------------------------------
$SETDATE
# Positionne la date SW_DATE Ã  partir de U_RESFOR
If U_PARVAL <> ""
    Onerrgo SETDATE_ERR 
    SW_DATE=U_PARVAL        # l'assignation marche si ordre de la chaine YYYYMMDD
    Onerrgo
Else
    SW_DATE=[00/00/00]    # date nulle
Endif
Return

$SETDATE_ERR    # U_EVAFOR contient la formule Ã  ÃĐvaluer
U_MESCODE="X3DATEVAERR" : U_MESP1=U_EVAFOR : U_MESP2=errm-errmes$(errn) : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI 
Resume
Return

# ------------------------------------------------------------
$ECRIZOOM
# Ecriture des infos de zoom au niveau infÃĐrieur
 If LEVEL<[F:PS2]NBRFLD

     U_SEQPUT = "<Zoom>": Gosub S_SEQPUTDEC
     #    infos issues de la fiche statistique portail
     # Wrseq 'STAT="'+CODE+'" ';
     # Wrseq 'CPY="'+CPY+'" ';
     # Wrseq 'FCY="'+FCY+'" ';
     # Wrseq 'DATDEB="'+format$("D:DD[-]MM[-]YYYY",DATDEB)+'" ';
     # Wrseq 'DATFIN="'+format$("D:DD[-]MM[-]YYYY",DATFIN)+'" ';
     # Wrseq 'DDATDEB="'+format$("D:DD[-]MM[-]YYYY",DDATDEB)+'" ';
     # Wrseq 'DDATFIN="'+format$("D:DD[-]MM[-]YYYY",DDATFIN)+'" ';


     U_SEQPUT = "  <Level>" +num$(LEVEL+1)+ "</Level>": Gosub S_SEQPUTDEC
     U_SEQPUT = "  <Criteria>" : Gosub S_SEQPUTDEC
         For II=0 To LEVEL-1
             SW_STR1=string$(II<LEVEL-1,VALCRIT(II+1)) + string$(II=LEVEL-1,CLE(JJ))
             U_HEXTOTXT=SW_STR1 : Gosub U_TXTTOHEX From SUBAPSUTI
             U_SEQPUT = "  <Criterion"+num$(II+1) + ">" + U_TXTTOHEX + "</Criterion"+num$(II+1) + ">"
             Gosub S_SEQPUTDEC
         Next II
     U_SEQPUT = "  </Criteria>" : Gosub S_SEQPUTDEC
     U_SEQPUT = "</Zoom>": Gosub S_SEQPUTDEC
 Endif
Return



