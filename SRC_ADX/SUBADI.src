# Exigence 53267
Subprog L_AS_A(VALEUR, IND)
Variable Char VALEUR()
Value Integer IND
Local Char L_AA
L_AA = evalue("[M]AA"+num$(IND))
If L_AA="" : mkstat = 1 : End : Endif
End

# Exigence 53267
Subprog L_AS_N(VALEUR, IND)
Variable Char VALEUR()
Value Integer IND
Local Char L_NN
L_NN = evalue("[M]NN"+num$(IND))
If L_NN="" : mkstat = 1 : End : Endif
End

# Exigence 53267
Subprog L_C_A(VALEUR, IND)
Variable Char VALEUR()
Value Integer IND
Local Char    CODTYP(GLONATY) , SUPP(10)
Local Integer  DIMCAR
DIMCAR = evalue("max(20,type([M:ADI1]A"+num$(IND)+")-10)")
Local Char VALSUP(DIMCAR)
CODTYP = evalue("[M]CODTYP"+num$(IND))
VALSUP = evalue("[M]AV"+num$(IND)+"(nolign-1)")
SUPP = evalue("[M]SUP"+num$(IND))
Gosub CONTSUP
End

# Exigence 53267
Subprog L_C_N(VALEUR, IND)
Variable Char VALEUR()
Value Integer IND
Local Char    CODTYP(GLONATY) , SUPP(10)
Local Integer  DIMCAR
DIMCAR = evalue("max(20,type([M:ADI1]N"+num$(IND)+")-10)")
Local Char VALSUP(DIMCAR)
CODTYP = evalue("[M]CODTYPN"+num$(IND))
VALSUP = evalue("[M]NV"+num$(IND)+"(nolign-1)")
SUPP = evalue("[M]SUPN"+num$(IND))
Gosub CONTSUP
End

$CONTSUP
If CODTYP<>"A"
 Call LECTURE("ATY",CODTYP,"") From CONTOBJ
 If [F:ATY]OBJLIEN<>""
  Call CONTROLE([F:ATY]OBJLIEN,"!",VALSUP,SUPP,mkstat) From CONTOBJ
 Endif
 If mkstat : Return : Endif
Endif
Local Char ACTION(10)
ACTION = "CONTSUP" : Gosub ACTION
Return

# Exigence 53267
Subprog C_DEPCOD(VALEUR)
Variable Char    VALEUR()
Local Char    CODTYP(GLONATY) , SUPP(10)
Local Integer DIMCAR
DIMCAR = max(20,type([M:ADI1]DEPCOD)-10)
Local Char VALSUP(DIMCAR)
CODTYP = "ADI"
VALSUP = VALEUR
SUPP = num$([M]DEPNUM)
Gosub CONTSUP
End

Subprog IB_NBLIG
End

Subprog B1_NBLIG
End

Subprog B2_NBLIG
End

Subprog INILEG(VALEUR,NUMTAB,DEPCOD)
Variable Char  VALEUR()
Value    Char  NUMTAB()
Value    Char  DEPCOD()
If val(NUMTAB)=0 : End : Endif
# DBA
If val(NUMTAB)=909 : VALEUR=GLEGFIL : Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & dim([F:ADV]OBLLEG)>0
 Call LECTURE("ADV",num$([M]NUMTAB),"") From CONTOBJ
 If [F:ADV]OBLLEG=2
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 1 : End
 Endif
Endif
End

