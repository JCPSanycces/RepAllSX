#<AdxTL>@(#)0.0.0.0 $Revision$ Tables diverses
Raz GBIDC1, GBIDC2 , GPILOBJ , GNBMASKOUV
Call OBJET("ADI",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBADIB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "OUVRE"        : Gosub OUVRE
 When "FILTRE"       : Gosub FILTRE
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "AVANT_VERROU" : Gosub AVANT_VERROU
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"       : Gosub CHANGE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "GRISE"        : Gosub GRISE
 When "DEGRISE"      : Gosub DEGRISE
 When "DROIT"        : Gosub DROIT
 When "LIENS0"       : Gosub LIENS0
 When "LIENS"        : Gosub LIENS
 When "LIENS2"       : Gosub LIENS2
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "CHX_TABLE"    : Gosub CHX_TABLE
Endcase
If PSUBB
 Gosub ACTION From SUBADIB
Endif
Return

#-------------------------------------#
$MODIF
Delete [AXX] Where CODFIC="ATABDIV" & LANGUE=GLANGUE & IDENT1=num$([M]NUMTAB)
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",num$([M]NUMTAB)) From GLOCK : Return
Endif
For nolign=1 To [M]NBLIG
 Call MAJTEXTRA([M]LNGDES(nolign-1),"ATABDIV","LNGDES",num$([M]NUMTAB),[M]CODE(nolign-1)) From ATEXTRA
 If GOK<1 : Break : Endif
 Call MAJTEXTRA([M]SHODES(nolign-1),"ATABDIV","SHODES",num$([M]NUMTAB),[M]CODE(nolign-1)) From ATEXTRA
 If GOK<1 : Break : Endif
Next nolign
Return

#-------------------------------------#
# Exigence 53267
$VERIF_MAJ
Local Char    WINTDES(80) , WINTNAM(GLONAVA) , WVAL(50) ,WVALNEW(50)
Local Integer WMODIF(0..dim([M]CODE))

For I=0 To [M]NBLIG-1
 Read [ADI]CODE=[M]NUMTAB;[M]CODE(I)
 If fstat
  WMODIF(I) = 2
 Else
  WMODIF(I) = 0
  # check update 1
  For WINTNAM="LNGDES","SHODES"
   Call LECTEXTRA(WINTDES,"ATABDIV",WINTNAM,num$([M]NUMTAB),[M]CODE(I)) From ATEXTRA
   If WINTDES<>evalue("[M]"+WINTNAM+"("+num$(I)+")") : WMODIF(I) = 1 : Break : Endif
  Next WINTNAM

  # check update 2
  If [F:ADI]DEFVAL=2 & [M]VALDEF<>[M]CODE(I)
   WMODIF(I) = 1
  # check update 3
  Elsif [F:ADI]DEFVAL=1 & [M]VALDEF=[M]CODE(I)
   WMODIF(I) = 1
  # check update 4
  Elsif [F:ADI]SOC<>[M]SOC(I)
   WMODIF(I) = 1
  # check update 5
  Elsif [F:ADI]LEG<>[M]LEG(I)
   WMODIF(I) = 1
  # check update 6
  Elsif [F:ADV]DEPNUM<>0
   If [F:ADI]DEPCOD <> [M]DEPCOD(I)
    WMODIF(I) = 1
   Endif
  Endif
  # check update 7
  If !WMODIF(I)
   # check each alphabetic columns
   For J = 1 To dim([F:ADV]COLALPTYP)
    If L_TITA(J)<>""
     WVAL = evalue("[F:ADI]A"+num$(J))
     WVALNEW = evalue("[M]AV"+num$(J))
     If WVAL <> WVALNEW
      WMODIF(I) = 1
      Break
     Endif
    Endif
   Next J
   If !WMODIF(I)
    # check each numeric columns
    For J = 1 To dim([F:ADV]COLNUMTYP)
     If L_TITN(J)<>""
      WVAL = num$(evalue("[F:ADI]N"+num$(J)))
      WVALNEW = evalue("[M]NV"+num$(J))
      If WVAL <> WVALNEW
       WMODIF(I) = 1
       Break
      Endif
     Endif
    Next J
   Endif
  Endif
  # check update end
 Endif

Next I

Return

$VERFCOL
Case J
 When 1 : If WVAL<>[M]AV1(I) : K = 0 : Endif
 When 2 : If WVAL<>[M]AV2(I) : K = 0 : Endif
 When 3 : If WVAL<>[M]AV3(I) : K = 0 : Endif
 When 4 : If WVAL<>[M]AV4(I) : K = 0 : Endif
 When 5 : If WVAL<>[M]AV5(I) : K = 0 : Endif
Endcase
Return

#-------------------------------------#
$MARQUE_MAJ
If GADONIX<>2 : Return : Endif
For I=0 To [M]NBLIG-1
 If WMODIF(I)=2
  Call TRACE_COR("ADI",[M]CODE(I),num$([M]NUMTAB),"c") From GOBJET
 Elsif WMODIF(I)=1
  Call TRACE_COR("ADI",[M]CODE(I),num$([M]NUMTAB),"m") From GOBJET
 Endif
Next I
Return

#-------------------------------------#
$FILTRE
If dim(FILTADI)>0 & FILTADI<>""
 FILTRE = FILTADI
Endif
Return

#-------------------------------------#
$DROIT
If [F:ADI]NUMTAB<>0
 Read [ADV]CODE = [F:ADI]NUMTAB
 If !fstat & [F:ADV]ACS<>""
  Read [ACC]CODACC = GUSER;[F:ADV]ACS
  If fstat or ([F:ACC]CONSUL<>2 & [F:ACC]MODIF<>2)
   CLECUR = 0
  Endif
 Endif
Endif
Return

#-------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ATABDIV" & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]CODE) From GLOCK : Return
Endif
Return

#-------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="ATABDIV" & IDENT1=[L]SUPP & IDENT2=[L]OCODE With IDENT2=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ATABDIV"-[L]SUPP-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]OCODE) From GLOCK : Return
Endif
Return

#-------------------------------------#
$OUVRE

Local Char    T_TIT(GLONDES) , T_TYP(GLONATY) , T_VAL(50) , T_SUP(10) , T_CODTYP(GLONATY) , T_AVNV(40)
Local Integer T_LIB
Local Decimal T_LNG
Local Integer T_TYPFLG # 1 for alphabetic, 2 for numeric
Local Integer T_IND # index of column
Local Integer FLMODIF , NOTAB , DIMCAR
Local Char    FLACCES(GLONACS) , FILTADI(250) , CHAINE(250) , CLEADI(10)
If clalev([F:ADV])=0  : Local File ATABTAB [ADV]  : Endif
If clalev([F:ADVD])=0 : Local File ATABTAB [ADVD] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA [AXX]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE   [ATY]  : Endif
If clalev([F:AGF])=0  : Local File AGRPFCY [AGF]  : Endif
# Exigence 53267
Local Char    L_TITA(GLONDES)(1..dim([F:ADV]COLALPTYP)), L_TYPA(GLONATY)(1..dim([F:ADV]COLALPTYP)) , L_SUPA(10)(1..dim([F:ADV]COLALPTYP))
Local Char    L_TITN(GLONDES)(1..dim([F:ADV]COLNUMTYP)), L_TYPN(GLONATY)(1..dim([F:ADV]COLNUMTYP)), L_SUPN(10)(1..dim([F:ADV]COLNUMTYP))

Gosub SETCLE2
If SAVCLE2<>""
 Read [ADV]CODE = val(SAVCLE2)
 If !fstat & [F:ADV]DEPNUM
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
 Endif
Endif
Return

#------------------------------------------------------------------------------------#
# Dans la fonction GESADI, GBIDC1 peut valoir par exemple "20-25,30"
# Dans ce cas, on génère le filtre FILTADI = (NUMTAB>=20&NUMTAB<=25)|NUMTAB=30
#------------------------------------------------------------------------------------#

$SETCLE2
If CLE2=""
 CLE2 = "1"
Else
 FILTADI = ""
 I = instr(1,CLE2,"-")
 J = instr(1,CLE2,",")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  CLEADI = left$(CLE2,I-1)
  CLE2 = vireblc(CLE2,4)
  While J
   CHAINE = left$(CLE2,J-1)
   CLE2 = right$(CLE2,J+1)
   Gosub FILTADI
   J = instr(1,CLE2,",")
  Wend
  CHAINE = CLE2
  Gosub FILTADI
  CLE2 = ""
 Elsif !TUNNEL & SAVCLE2<>""
  CLEADI = CLE2
  CHAINE = CLE2
  Gosub FILTADI
  CLE2 = ""
 Endif
 If FILTADI<>""
  FILTADI += ")"
  If GLECOBJ=2 & GNBDERNIER>0
   Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
   For [ALS]ALS0
    I = instr(1,[F:ALS]CLES,"~")
    If I
     J = instr(I+1,[F:ALS]CLES,"~")
     If I & J
      CLE2 = seg$([F:ALS]CLES,I+1,J-1)
     Endif
    Endif
    Look [ADV]CODE=val(CLE2)
    If fstat or !evalue(FILTADI) : CLE2 = "" : Endif
    Break
   Next
   Filter [ALS]
  Endif
 Endif
 If CLE2="" : CLE2 = CLEADI : Endif
 SAVCLE2 = CLE2
Endif
Return

$FILTADI
If CHAINE="" : Return : Endif
If FILTADI=""
 FILTADI = "("
Else
 FILTADI += "|"
Endif
I = instr(1,CHAINE,"-")
If I
 FILTADI += "(NUMTAB>="+left$(CHAINE,I-1)
 FILTADI += "&NUMTAB<="+right$(CHAINE,I+1)+")"
Else
 FILTADI += "NUMTAB="+CHAINE
Endif
Return

#-------------------------------------#
$FILGAUCHE
FILGAUSUP = '([F:ACC]CODACC="" or [F:ACC]MODIF=2 or [F:ACC]CONSUL=2)'
If TUNNEL
 FILGAUSUP -= "& NUMTAB="+CLECUR2
Endif
If FILTADI<>""
 FILGAUSUP -= "&"-FILTADI
Endif
Return

#-------------------------------------#
$AP_FILGAUCHE
# Pour le Setlbox
Read [ADV]CODE = [M]NUMTAB
Return

#-------------------------------------#
$SETBOUT
If !TUNNEL
 CHAINE += "><09"
Else
 Gosub GRISE
Endif
If FILTADI<>""
 Gosub GRISE
Endif
If [M]NBLIG=0 : # mb 3.5.2 bug 14192
 Call VIREBOUT(CHAINE,"A") From GOBJET
Else
 CHAINE += "@" : # Propriétés
Endif
If CLECUR=0 or REP="M" or (!VERROU & (dim([L]MLOCK)<=0 or ![L]MLOCK))
 Call VIREBOUT(CHAINE,"H2") From GOBJET
Endif
If FLMODIF<>2
 Call VIREBOUT(CHAINE,"AMH2") From GOBJET
Elsif FLACCES<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;FLACCES
 If fstat or [F:ACC]MODIF<>2
  Call VIREBOUT(CHAINE,"AMH2") From GOBJET
 Endif
Endif
If [M]NUMTAB=909
 Call VIREBOUT(CHAINE,"H") From GOBJET
Endif
Return

#-------------------------------------#
$APRES_CHOI
Case REPONSE
 When GSTALFT : Gosub GAUCHE    : REPONSE = 0
 When GSTASUI : Gosub SUIVANT   : REPONSE = 0
 When GSTAPRE : Gosub PRECEDENT : REPONSE = 0
 When GSTAFIR : Gosub PREMIER   : REPONSE = 0
 When GSTALAS : Gosub DERNIER   : REPONSE = 0
Endcase
Return

$GRISE
Grizo NUMTAB
Return

$DEGRISE
Actzo NUMTAB
Return

#-------------------------------------#
$LIENS
If [F:ADI]DEFVAL=2
 [M:ADI1]VALDEF = [F:ADI]CODE
Endif

# initialise
# Exigence 53267
For K = 1 To dim([F:ADV]COLALPTYP)
 Assign("[M]A"+num$(1)+"(nolign-1)") With ""
Next
For K = 1 To dim([F:ADV]COLNUMTYP)
 Assign("[M]N"+num$(1)+"(nolign-1)") With ""
Next

[M]SOC(nolign-1) = ""
[M]LEG(nolign-1) = ""

# Exigence 53267
For I=1 To dim([F:ADV]COLALPTYP)
 If L_TITA(I)<>""
  T_VAL = evalue("[F:ADI]A"+num$(I))
  T_CODTYP = evalue("[M]CODTYP"+num$(I))
  T_LIB = evalue("[M]LIB"+num$(I))
  T_LNG = evalue("[M]LNG"+num$(I))
  T_AVNV = evalue("[M]AV"+num$(I)+"(nolign-1)")
  Call CHARGE(T_VAL,T_CODTYP,T_LIB,T_LNG,T_AVNV) From FMTVAR
  Assign("[M]A"+num$(I)+"(nolign-1)") With T_VAL
  Assign("[M]AV"+num$(I)+"(nolign-1)") With T_AVNV
 Endif
Next

For I = 1 To dim([F:ADV]COLNUMTYP)
 If L_TITN(I)<>""
  T_VAL = num$(evalue("[F:ADI]N"+num$(I)))
  T_CODTYP = evalue("[M]CODTYPN"+num$(I))
  T_LIB = evalue("[M]LIBN"+num$(I))
  T_LNG = evalue("[M]LNGN"+num$(I))
  T_AVNV = num$(evalue("[M]NV"+num$(I)+"(nolign-1)"))
  Call CHARGE(T_VAL,T_CODTYP,T_LIB,T_LNG,T_AVNV) From FMTVAR
  Assign("[M]N"+num$(I)+"(nolign-1)") With T_VAL
  Assign("[M]NV"+num$(I)+"(nolign-1)") With T_AVNV
 Endif
Next

If [F:ADI]LEG <> ""
 [M]LEG(nolign-1) = [F:ADI]LEG
 Call LECTEXTRA([M]INTLEG(nolign-1),"ATABDIV","SHODES","909",[M]LEG(nolign-1)) From ATEXTRA
Endif
If [F:ADI]SOC <> ""
 [M]SOC(nolign-1) =[F:ADI]SOC
 Read [AGF]AGF0 = [M]SOC(nolign-1)
 If !fstat
  [M]INTSOC(nolign-1)  = [F:AGF]SHO
 Endif
Endif

Return

#-------------------------------------#
$LIENS0
[M]NUMTAB = val(CLECUR2)

# Exigence 53267
# initialise
Raz L_TITA
Raz L_TYPA
Raz L_SUPA
Raz L_TITN
Raz L_TYPN
Raz L_SUPN

Call LECTEXTRA([M]ZINTIT,"ATABTAB","LNGDES",num$([M]NUMTAB),"") From ATEXTRA

Read [ADV]CODE = [M]NUMTAB
If !fstat
 # Exigence 53267
 # get the title of each column from ATABTAB
 For I = 1 To dim([F:ADV]COLALPTYP)
  Call LECTEXTRA(L_TITA(I),"ATABTAB","COLALPDES",num$([M]NUMTAB),num$(I-1)) From ATEXTRA
  If L_TITA(I)<>""
   L_TYPA(I) = [F:ADV]COLALPTYP(I-1)
   L_SUPA(I) = [F:ADV]COLALPSUP(I-1)
  Endif
Next
 For I = 1 To dim([F:ADV]COLNUMTYP)
  Call LECTEXTRA(L_TITN(I),"ATABTAB","COLNUMDES",num$([M]NUMTAB),num$(I-1)) From ATEXTRA
  If L_TITN(I)<>""
   L_TYPN(I) = [F:ADV]COLNUMTYP(I-1)
   L_SUPN(I) = [F:ADV]COLNUMSUP(I-1)
  Endif
 Next

 Gosub SETBOX From =WINPROG
 NOTAB = [M]NUMTAB

 If PSUBB
  ACTION = "LIENS1"
  Gosub ACTSUB From GOBJSUB
  ACTION = "LIENS0"
 Endif
 K = 0

 # Exigence 53267
 For I = 1 To dim(L_TITA) :# dim([F:ADV]COLALPTYP)
  If L_TITA(I)<>""
   T_IND = I
   T_TYPFLG = 1
   T_TYP = L_TYPA(I)
   T_SUP = L_SUPA(I)
   If T_TYP="" : T_TYP = "A" : Endif
   T_TIT = L_TITA(I)
  Gosub L_COLSUP
  Endif
 Next
 For I = 1 To dim(L_TITN) : # dim([F:ADV]COLNUMTYP)
  If  L_TITN(I)<>""
   T_IND = I
   T_TYPFLG = 2
   T_TYP = L_TYPN(I)
   T_SUP = L_SUPN(I)
   If T_TYP="" : T_TYP = "L" : Endif
   T_TIT = L_TITN(I)
   Gosub L_COLSUP
  Endif
 Next

 # Exigence 53267
 If [F:ADV]DEPNUM<>0
  [M]DEPNUM  = [F:ADV]DEPNUM
  Read [ADV]CODE = [M]DEPNUM
  [M]DEPLNG = [F:ADV]LNG
  Read [ADV]CODE = [M]NUMTAB
 Endif

 [M]LNG     = [F:ADV]LNG
 If [F:ADV]FLGSOC = 2
  [M]ASOC = mess(237,133,1) : # SOCIETE
  [M]AINTSOC = mess(30,109,1) : # Intitulé
 Else
  Raz [M]ASOC
  Raz [M]AINTSOC
 Endif
 If [F:ADV]FLGLEG = 2
  [M]ALEG = mess(238,133,1) : # "Legislation"
  [M]AINTLEG = mess(30,109,1) : # Intitulé
 Else
  Raz [M]ALEG
  Raz [M]AINTLEG
 Endif
 If [F:ADV]FLGENA=2
  [M]AENAFLG = mess(2,8,1)+" " : # Actif
 Else
  Raz [M]ENAFLG
 Endif
Endif
FLMODIF = [F:ADV]UPDFLG
FLACCES = [F:ADV]ACS
Return

#-------------------------------------#
$LIENS2

# Exigence 53267
For I = 1 To dim([F:ADV]COLALPTYP)
 DIMCAR = evalue("max(20,type([M:ADI1]A"+num$(I)+")-10)")
 If L_TITA(I) <> ""
  Case I
   When 1 : Chgfmt [M]A1 With "K:"+num$(DIMCAR)+"X"
   When 2 : Chgfmt [M]A2 With "K:"+num$(DIMCAR)+"X"
   When 3 : Chgfmt [M]A3 With "K:"+num$(DIMCAR)+"X"
   When 4 : Chgfmt [M]A4 With "K:"+num$(DIMCAR)+"X"
   When 5 : Chgfmt [M]A5 With "K:"+num$(DIMCAR)+"X"
   When 6 : Chgfmt [M]A6 With "K:"+num$(DIMCAR)+"X"
   When 7 : Chgfmt [M]A7 With "K:"+num$(DIMCAR)+"X"
   When 8 : Chgfmt [M]A8 With "K:"+num$(DIMCAR)+"X"
   When 9 : Chgfmt [M]A9 With "K:"+num$(DIMCAR)+"X"
   When 10 : Chgfmt [M]A10 With "K:"+num$(DIMCAR)+"X"
   When 11 : Chgfmt [M]A11 With "K:"+num$(DIMCAR)+"X"
   When 12 : Chgfmt [M]A12 With "K:"+num$(DIMCAR)+"X"
   When 13 : Chgfmt [M]A13 With "K:"+num$(DIMCAR)+"X"
   When 14 : Chgfmt [M]A14 With "K:"+num$(DIMCAR)+"X"
   When 15 : Chgfmt [M]A15 With "K:"+num$(DIMCAR)+"X"
  Endcase
 Else
  Case I
   When 1 : Chgfmt [M]A1 With "-K:"+num$(DIMCAR)+"X"
   When 2 : Chgfmt [M]A2 With "-K:"+num$(DIMCAR)+"X"
   When 3 : Chgfmt [M]A3 With "-K:"+num$(DIMCAR)+"X"
   When 4 : Chgfmt [M]A4 With "-K:"+num$(DIMCAR)+"X"
   When 5 : Chgfmt [M]A5 With "-K:"+num$(DIMCAR)+"X"
   When 6 : Chgfmt [M]A6 With "-K:"+num$(DIMCAR)+"X"
   When 7 : Chgfmt [M]A7 With "-K:"+num$(DIMCAR)+"X"
   When 8 : Chgfmt [M]A8 With "-K:"+num$(DIMCAR)+"X"
   When 9 : Chgfmt [M]A9 With "-K:"+num$(DIMCAR)+"X"
   When 10 : Chgfmt [M]A10 With "-K:"+num$(DIMCAR)+"X"
   When 11 : Chgfmt [M]A11 With "-K:"+num$(DIMCAR)+"X"
   When 12 : Chgfmt [M]A12 With "-K:"+num$(DIMCAR)+"X"
   When 13 : Chgfmt [M]A13 With "-K:"+num$(DIMCAR)+"X"
   When 14 : Chgfmt [M]A14 With "-K:"+num$(DIMCAR)+"X"
   When 15 : Chgfmt [M]A15 With "-K:"+num$(DIMCAR)+"X"
  Endcase
 Endif
Next I
For I = 1 To dim([F:ADV]COLNUMTYP)
 DIMCAR = evalue("max(20,type([M:ADI1]N"+num$(I)+")-10)")
 If L_TITN(I) <> ""
  Case I
   When 1 : Chgfmt [M]N1 With "K:"+num$(DIMCAR)+"X"
   When 2 : Chgfmt [M]N2 With "K:"+num$(DIMCAR)+"X"
   When 3 : Chgfmt [M]N3 With "K:"+num$(DIMCAR)+"X"
   When 4 : Chgfmt [M]N4 With "K:"+num$(DIMCAR)+"X"
   When 5 : Chgfmt [M]N5 With "K:"+num$(DIMCAR)+"X"
   When 6 : Chgfmt [M]N6 With "K:"+num$(DIMCAR)+"X"
   When 7 : Chgfmt [M]N7 With "K:"+num$(DIMCAR)+"X"
   When 8 : Chgfmt [M]N8 With "K:"+num$(DIMCAR)+"X"
   When 9 : Chgfmt [M]N9 With "K:"+num$(DIMCAR)+"X"
   When 10 : Chgfmt [M]N10 With "K:"+num$(DIMCAR)+"X"
   When 11 : Chgfmt [M]N11 With "K:"+num$(DIMCAR)+"X"
   When 12 : Chgfmt [M]N12 With "K:"+num$(DIMCAR)+"X"
   When 13 : Chgfmt [M]N13 With "K:"+num$(DIMCAR)+"X"
   When 14 : Chgfmt [M]N14 With "K:"+num$(DIMCAR)+"X"
   When 15 : Chgfmt [M]N15 With "K:"+num$(DIMCAR)+"X"
  Endcase
 Else
  Case I
   When 1 : Chgfmt [M]N1 With "-K:"+num$(DIMCAR)+"X"
   When 2 : Chgfmt [M]N2 With "-K:"+num$(DIMCAR)+"X"
   When 3 : Chgfmt [M]N3 With "-K:"+num$(DIMCAR)+"X"
   When 4 : Chgfmt [M]N4 With "-K:"+num$(DIMCAR)+"X"
   When 5 : Chgfmt [M]N5 With "-K:"+num$(DIMCAR)+"X"
   When 6 : Chgfmt [M]N6 With "-K:"+num$(DIMCAR)+"X"
   When 7 : Chgfmt [M]N7 With "-K:"+num$(DIMCAR)+"X"
   When 8 : Chgfmt [M]N8 With "-K:"+num$(DIMCAR)+"X"
   When 9 : Chgfmt [M]N9 With "-K:"+num$(DIMCAR)+"X"
   When 10 : Chgfmt [M]N10 With "-K:"+num$(DIMCAR)+"X"
   When 11 : Chgfmt [M]N11 With "-K:"+num$(DIMCAR)+"X"
   When 12 : Chgfmt [M]N12 With "-K:"+num$(DIMCAR)+"X"
   When 13 : Chgfmt [M]N13 With "-K:"+num$(DIMCAR)+"X"
   When 14 : Chgfmt [M]N14 With "-K:"+num$(DIMCAR)+"X"
   When 15 : Chgfmt [M]N15 With "-K:"+num$(DIMCAR)+"X"
  Endcase
 Endif
Next I

If [M]ALEG <> "" & func AFNC.ACTIV("LEG")=1
 Chgfmt [M]LEG  With "K:"+num$(GLONADI)+"B"
 Chgfmt [M]INTLEG  With "KP:"+num$(GLONAX1)+"B"
Else
 Chgfmt [M]LEG  With "-K:"+num$(GLONADI)+"B"
 Chgfmt [M]INTLEG  With "-KP:"+num$(GLONAX1)+"B"
Endif
If [M]ASOC<> ""
 Chgfmt [M]SOC With "K:"+num$(GLONAGF)+"B"
 Chgfmt [M]INTSOC With "KP:"+num$(GLONSHO)+"B"
Else
 Chgfmt [M]SOC With "-K:"+num$(GLONAGF)+"B"
 Chgfmt [M]INTSOC With "-KP:"+num$(GLONSHO)+"B"
Endif
If [M]AENAFLG<> ""
 Chgfmt [M]ENAFLG With "K:"+num$("20")+"B"
Else
 Chgfmt [M]ENAFLG With "-K:"+num$("20")+"B"
Endif

# Exigence 53267
If [M]DEPNUM<> 0
 #Chgfmt [M]DEPCOD With "K:"+num$(GLONAGF)+"B"
 Read [ADVD]CODE=[M]DEPNUM
 If !fstat & [F:ADVD]LNG>0
  Chgfmt [M]DEPCOD With "K:"+num$([F:ADVD]LNG)+"B"
 Else
  Chgfmt [M]DEPCOD With "K:"+num$(GLONADI)+"B"
 Endif
Else
 #Chgfmt [M]DEPCOD With "-K:"+num$(GLONAGF)+"B"
 Chgfmt [M]DEPCOD With "-K:1X"
Endif
Return

$L_COLSUP
Read [ATY]CODTYP = T_TYP
# Exigence 53267
Case T_TYPFLG
 When 1
  Assign "[M]AA"+num$(T_IND) With T_TIT
  Assign "[M]CODTYP"+num$(T_IND) With T_TYP
  If [F:ATY]NOLIB<>0
   Assign "[M]LIB"+num$(T_IND) With [F:ATY]NOLIB
  Else
   Assign "[M]LIB"+num$(T_IND) With val(T_SUP)
  Endif
  Assign "[M]LNG"+num$(T_IND) With [F:ATY]LNGTYP
  If [F:ATY]LNGTYP = 0
   Case [F:ATY]TYPTYP
    When 2 : Assign "[M]LNG"+num$(T_IND) With 4
    When 3 : Assign "[M]LNG"+num$(T_IND) With 8
    When 4 : Assign "[M]LNG"+num$(T_IND) With 11.2
   Endcase
  Endif
  If [F:ATY]CODTYP="ADI"
   Assign "[M]SUP"+num$(T_IND) With ""
  Else
   Assign "[M]SUP"+num$(T_IND) With T_SUP
  Endif

 When 2
  Assign "[M]NN"+num$(T_IND) With T_TIT
  Assign "[M]CODTYPN"+num$(T_IND) With T_TYP
  If [F:ATY]NOLIB<>0
   Assign "[M]LIBN"+num$(T_IND) With [F:ATY]NOLIB
  Else
   Assign "[M]LIBN"+num$(T_IND) With val(T_SUP)
  Endif
  Assign "[M]LNGN"+num$(T_IND) With [F:ATY]LNGTYP
  If [F:ATY]LNGTYP = 0
   Case [F:ATY]TYPTYP
    When 2 : Assign "[M]LNGN"+num$(T_IND) With 4
    When 3 : Assign "[M]LNGN"+num$(T_IND) With 8
    When 4 : Assign "[M]LNGN"+num$(T_IND) With 11.2
   Endcase
  Endif
  If [F:ATY]CODTYP="ADI"
   Assign "[M]SUPN"+num$(T_IND) With ""
  Else
   Assign "[M]SUPN"+num$(T_IND) With T_SUP
  Endif
Endcase
Return

#-------------------------------------#
$VERIF_MOD
Gosub VERIF_LEG
If !OK : Return : Endif
Call LECTURE("ADV",num$([M]NUMTAB),"") From CONTOBJ
#117111
#If !fstat & func AFNC.ACTIV("LEG")<>2 & [F:ADV]FLGLEG=2
If !fstat & func AFNC.ACTIV("LEG")=0 & [F:ADV]FLGLEG=2
 For I=0 To [M]NBLIG-1
  Read [F:ADI]CODE = [M]NUMTAB;[M]CODE(I)
  If fstat
   [M]LEG(I) = GDOSLEG(1)
  Endif
 Next I
Endif
Gosub VERIF_MAJ
Return

#-------------------------------------#
$VERIF_CRE
Gosub VERIF_LEG
If !OK : Return : Endif
For I=0 To [M]NBLIG-1
 WMODIF(I) = 2
Next I
Return

#------------------------------------#
$VERIF_LEG
If dim([F:ADV]OBLLEG)>0
 Call LECTURE("ADV",num$([M]NUMTAB),"") From CONTOBJ
 If [F:ADV]OBLLEG=2
  For I=0 To [M]NBLIG-1
   If [M]LEG(I)=""
    GMESSAGE = mess(61,100,1)-num$(I+1)-":"-mess(232,143,1) : # Ligne no $1$ : Législation obligatoire
    OK = 0 : Break
   Endif
  Next I
  If !OK : Return : Endif
 Endif
Endif
Return

#-------------------------------------#
$INICRE

# save data from additional columns
# Exigence 53267
For I = 1 To dim([F:ADV]COLALPTYP)
 If L_TITA(I)<>""
  Assign("[F:ADI]A"+num$(I)) With evalue("[M]AV"+num$(I)+"(nolign-1)")
 Else
  Assign("[F:ADI]A"+num$(I)) With ""
 Endif
Next
For I = 1 To dim([F:ADV]COLNUMTYP)
 If L_TITN(I)<>""
  Assign("[F:ADI]N"+num$(I)) With val(evalue("[M]NV"+num$(I)+"(nolign-1)"))
 Else
  Assign("[F:ADI]N"+num$(I)) With 0
 Endif
Next

If [F:ADI]CODE=[M:ADI1]VALDEF
 [F:ADI]DEFVAL = 2
Else
 [F:ADI]DEFVAL = 1
Endif

Case WMODIF(nolign-1)
 When 1 : # Modif
  If dim([F:ADI]UPDUSR)>0 : [F:ADI]UPDUSR = GUSER   : Endif
  If dim([F:ADI]UPDDAT)>0 : [F:ADI]UPDDAT = date$   : Endif
  If dim([F:ADI]UPDTIM)>0 : [F:ADI]UPDTIM = time    : Endif
  If dim([F:ADI]CREUSR)>0 & dim([M]CREUSR)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ADI]CREDAT)>0 & dim([M]CREDAT)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:ADI]CRETIM)>0 & dim([M]CRETIM)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CRETIM = [M]CRETIM(nolign-1) : Endif
 When 2 : # Création
  If dim([F:ADI]CREUSR)>0 : [F:ADI]CREUSR = GUSER   : Endif
  If dim([F:ADI]CREDAT)>0 : [F:ADI]CREDAT = date$   : Endif
  If dim([F:ADI]CRETIM)>0 : [F:ADI]CRETIM = time    : Endif
  If dim([F:ADI]UPDUSR)>0 : [F:ADI]UPDUSR = ""      : Endif
  If dim([F:ADI]UPDDAT)>0 : [F:ADI]UPDDAT = [0/0/0] : Endif
  If dim([F:ADI]UPDTIM)>0 : [F:ADI]UPDTIM = 0       : Endif
 When 0
  If dim([F:ADI]CREUSR)>0 & dim([M]CREUSR)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ADI]CREDAT)>0 & dim([M]CREDAT)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:ADI]CRETIM)>0 & dim([M]CRETIM)>0 & [M]CREUSR(nolign-1)<>'' : [F:ADI]CRETIM = [M]CRETIM(nolign-1) : Endif
  If dim([F:ADI]UPDUSR)>0 & dim([M]UPDUSR)>0 & [M]UPDUSR(nolign-1)<>'' : [F:ADI]UPDUSR = [M]UPDUSR(nolign-1) : Endif
  If dim([F:ADI]UPDDAT)>0 & dim([M]UPDDAT)>0 & [M]UPDUSR(nolign-1)<>'' : [F:ADI]UPDDAT = [M]UPDDAT(nolign-1) : Endif
  If dim([F:ADI]UPDTIM)>0 & dim([M]UPDTIM)>0 & [M]UPDUSR(nolign-1)<>'' : [F:ADI]UPDTIM = [M]UPDTIM(nolign-1) : Endif
Endcase
#Mettre a jour ecran
[M]=[F]
Return

#-------------------------------------#
$APRES_MOD
If [M]NUMTAB=61
 Call INILNK From GLOBSUP
Endif
Gosub MARQUE_MAJ
Return

$LINKE
Link [ADV] With [ACC]CODACC=GUSER;[ADV]ACS
&             , [AXX]AXX0="ATABTAB";"LNGDES";GLANGUE;[F:ADV]NUMCAR;""
&  As [LADV]
&  Where ([ACC]MODIF=2 or [ACC]CONSUL=2) & (FILTADI="" | evalue(FILTADI))
Return

#-------------------------------------#
$GAUCHE
If VERROU : Gosub DEVERROU From GOBJET : Endif : # GH 27/02/02 bug 8146
Gosub LINKE
Read [LADV]CODE = [F:ADV]NUMTAB
Goto SUIVPREC

#-------------------------------------#
$SUIVANT
If VERROU : Gosub DEVERROU From GOBJET : Endif : # GH 27/02/02 bug 8146
Gosub LINKE
Read [LADV]CODE > [M]NUMTAB
Goto SUIVPREC

#-------------------------------------#
$PRECEDENT
If VERROU : Gosub DEVERROU From GOBJET : Endif : # GH 27/02/02 bug 8146
Gosub LINKE
Read [LADV]CODE < [M]NUMTAB
Goto SUIVPREC

#-------------------------------------#
$PREMIER
If VERROU : Gosub DEVERROU From GOBJET : Endif : # GH 27/02/02 bug 8146
Gosub LINKE
Read [LADV]CODE First
Goto SUIVPREC

#-------------------------------------#
$DERNIER
If VERROU : Gosub DEVERROU From GOBJET : Endif : # GH 27/02/02 bug 8146
Gosub LINKE
Read [LADV]CODE Last
Goto SUIVPREC

#-------------------------------------#
$SUIVPREC
If fstat>2
 GMESSAGE = mess(11,100,1) : GERR = 1 : Return
Else
 [M]NUMTAB = [F:ADV]NUMTAB
 CLE2 = num$([M]NUMTAB)
 Gosub SETBOX From =WINPROG
 Gosub RELIT From GOBJSUB
 REP = "" : GREP = ""
 CRITERE = "1=1"
Endif
Return

#-------------------------------------#
$APRES_MODIF
If COUZON="NUMTAB"
 Local Integer OLDTAB , NEWTAB
 OLDTAB = [M]NUMTAB
 NEWTAB = val(CZ)
 If OLDTAB<>NEWTAB
  Gosub LINKE
  Read [LADV]CODE = NEWTAB
  If fstat
   GMESSAGE = mess(124,124,1) : # Table inexistante
   mkstat = 2
  Else
   If VERROU : Gosub DEVERROU From GOBJET : Endif
   CLE2 = num$(NEWTAB)
   [M]NUMTAB = NEWTAB
   Gosub SETBOX From =WINPROG
   Gosub RELIT From GOBJSUB
  Endif
  OK = -1
  SUIZON = "NBLIG(0)"
 Endif
 Gosub SETBOUT From GOBJSUB
Endif
Return

#------------------------------#
$AVANT_VERROU
If SYMBOLE="ATABDIV\0"
 SYMBOLE = "ATABDIV\"+CLE2 : # mb 26.3.8 bug 46364
Endif
Return

#-----------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELADI"    : Gosub SELADI    : # Sélection dépendances
 When "SELADII"   : Gosub SELADII   : # Sélection tables diverses
 When "SELFCYCPY" : Gosub SELFCYCPY : # Sélection Société /  site
 When "ASELLEG"   : Gosub SELLEG    : # Sélection légisaltion
Endcase
Return

#---------------------------------#
$CHX_TABLE
Case TABLE
 When "SELADI"  : Gosub CHXADI
Endcase
Return

#---------------------------------#
$SELADI
Local Char NUMTAB(10), DEPCOD(GLONADI)
If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
[L]NUMTAB = PARAM(1) : # table diverse
[L]DEPCOD = PARAM(2) : # code dépendance
If [L]NUMTAB<>""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'NUMTAB = '+[L]NUMTAB,"&") From GOBJSUB
Endif

#DBA
# cg avril 2013 : la selection sur la table 909 est aussi possible dans GESADLV
# ajout du code fct GESADLV
#If val(NUMTAB)=909 & GFONCTION<>"GESADS"
If val(NUMTAB)=909 & GFONCTION<>"GESADS" & GFONCTION<>"GESADLV"
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:ADI]CODE,GDOSLEG(1..GNBLEG))>0',"&") From GOBJSUB
Endif


START   = "[F:ADI]CODE"
OBJET   = "ADI"
If maskcou<>"" & zoncou<>"" : # Pour récupérer les éventuelles options de sélection d'un écran
 Read [AMZ]CODE=maskcou;zoncou
 If !fstat & [F:AMZ]OPTOBJ<>""
  Gosub OPTIONS From ="WO"+OBJET
  For I=1 To NBCOND
   If instr(1,[F:AMZ]OPTOBJ,OPT(I))
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
 Endif
Endif
Default File [ADI]
Read [ADV]CODE = val([L]NUMTAB)
If fstat
 OK = 0
Else
 #112574
 If dim([F:ADV]FLGENA)>0 & dim([F:ADI]ENAFLG)>0 & [F:ADV]FLGENA=2
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]ENAFLG=2)',"&") From GOBJSUB
 Endif
 #
 If [L]DEPCOD<>""& [F:ADV]DEPNUM<>0
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'((DEPCOD = "'+[L]DEPCOD+'") or DEPCOD ="")',"&") From GOBJSUB
 Endif
 If [F:ADV]FLGSOC=2 or [F:ADV]FLGLEG=2
  OBJET = ""
  ORDRE = START
  DEFPAG = 1
  Gosub OUVFIC_LISTE From ="WOADI" # walkaround for Bug 85118 , a complete fix is needed.
  Gosub NOMFIC From ="WOADI"
  # Filtre sur la législation préférée de l'utilisateur
  # 119235 - Selection on legislation from company - Use company legislation
  If dim([M:CPY1]LEG)>0 & dim(GLEGFIL)>0 & GNBLEG>1
   J = evalue("dim([F:"+ABFIC+"]"+FLDLEG+")")
   If J
    # 120024 - allow 'blank' legislations to be selected
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]'+FLDLEG+'="'+[M:CPY1]LEG+ '" | [F:ADI]'+FLDLEG+'=""'+')',"&") From GOBJSUB
   Endif
  #  If dim([L]FLDLEG)>0 & [L]FLDLEG<>"" & dim(GLEGFIL)>0 & GLEGFIL<>"" & GNBLEG>1
  Elsif dim([L]FLDLEG)>0 & [L]FLDLEG<>"" & dim(GLEGFIL)>0 & GLEGFIL<>"" & GNBLEG>1
  # 119235 - end of change
   J = evalue("dim([F:"+ABFIC+"]"+FLDLEG+")")
   If J
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]'+FLDLEG+'="" | [F:ADI]'+FLDLEG+'="'+GLEGFIL+'")',"&") From GOBJSUB
   Endif
  Endif
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif       # SAM 120269-add company table open
  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
  # mb 25.3.13 rajout du num$ - bug 88543
  Link [ADI] With
& [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$([F:ADI]NUMTAB);[F:ADI]CODE
& As [LNK]
  Call  TRANSCOL("ADI",NBCOL,COL,TIT,FMTCOL) From OBJDIV
  If [F:ADV]FLGLEG=2 & func AFNC.ACTIV("LEG")
   If GSOCIETE<>""
    If dim([M:CPY1]LEG)>0 # 119235 - Do not use GSOCIETE when in tunnel from company
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]LEG="'+[M:CPY1]LEG+'" or [F:ADI]LEG="")',"&") From GOBJSUB
    Else
      Read [CPY]CPY0 = GSOCIETE
      If !fstat
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]LEG="'+[F:CPY]LEG+'" or [F:ADI]LEG="")',"&") From GOBJSUB
      Endif
    Endif
   Elsif dim([V]GCURLEG)>0 & GCURLEG<>""
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]LEG="'+GCURLEG+'" or [F:ADI]LEG="")',"&") From GOBJSUB
   Endif
   # Ajout des colonnes Legislation
   NBCOL += 1 : COL(NBCOL) = "[F:ADI]LEG"    : COLTYP(NBCOL) =  type([F:ADI]LEG)    : TIT(NBCOL) = mess(238,133,1)
   COL(NBCOL) = "string$([F:ADI]LEG<>'',[F:ADI]LEG)+string$([F:ADI]LEG='',mess(236,143,1))"
  Endif
  If [F:ADV]FLGSOC=2
   If GSOCIETE<>""
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    # mb 25.3.13 rajout du num$ - bug 88543
    Link [ADI] With
&   [AGC]AGC0=[F:ADI]SOC,
&   [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$([F:ADI]NUMTAB);[F:ADI]CODE
&   As [LNK]
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY=GSOCIETE  or [F:ADI]SOC="")',"&") From GOBJSUB
   Endif
   # Ajout des colonnes Société
   NBCOL += 1 : COL(NBCOL) = "[F:ADI]SOC"    : COLTYP(NBCOL) =  type([F:ADI]SOC)    : TIT(NBCOL) = mess(237,133,1)
  Endif
  Default File [LNK]
 Endif
Endif
Return

#---------------------------------#
$CHXADI
Call LECTEXTRA(TIT,"ATABTAB","LNGDES",num$([L]NUMTAB),"") From ATEXTRA
Return

#---------------------------------#
$SELLEG
OBJET="ADI"
CRITERE = "find([F:ADI]CODE,GDOSLEG(1..GNBLEG))>0 & [F:ADI]NUMTAB=909"
Return

#---------------------------------#
$SELFCYCPY
Local Char    WOBJ(50)(1..500),WINTITULE(50)(1..500),WTYP(80)(1..500)
Local Integer I,J
Local File   (Char OBJ(50) ,  Char INTITULE(50) , Char TYP(50) )
&             From Variable WOBJ, WINTITULE, WTYP  As [A__]
&             Order By OBJ;  TYP ; INTITULE
Gosub CHARGE_SOC
Default File [A__]
NBCOL = 3
COL(1) = "[F:A__]OBJ"       : COLTYP(1) =  type([F:A__]OBJ)      :  TIT(1) = mess(37,100,1) : # Code
COL(2) = "[F:A__]INTITULE"  : COLTYP(2) =  type([F:A__]INTITULE) :  TIT(2) = mess(82,123,1) : # Intitulé
COL(3) = "[F:A__]TYP"       : COLTYP(3) =  type([F:A__]TYP)      :  TIT(3) = mess(59,100,1) : # type
TIT = mess(237,133,1) : # "Société/site"
CRITERE ='OBJ <> ""  '
FILTRE = '1=1  '
START = "OBJ"
ORDRE = ""
adxmxl = 500
Return

#---------------------------------#
$CHARGE_SOC
If !clalev([F:AGF]) : Local File AGRPFCY [AGF] : Endif
I=1
For [AGF]
 WOBJ(I)      = [F:AGF]GRP
 WINTITULE(I) = [F:AGF]DES
 WTYP(I)      = mess(239,133,1)-"-"-mess(2,45,1)  : #  GROUPE de site - société
 I+=1
Next
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
For [FCY]
 WOBJ(I)      = [F:FCY]FCY
 WINTITULE(I) = [F:FCY]FCYNAM
 WTYP(I)      = mess(3,45,1) : #  Site
 I+=1
Next
Return

#---------------------------------#
$SELADII
Link [ADV] With [ACC]CODACC=GUSER;[ADV]ACS
&             , [AXX]AXX0="ATABTAB";"LNGDES";GLANGUE;[F:ADV]NUMCAR;""
& As [LADV]
& Where [F:ACC]MODIF=2 or [F:ACC]CONSUL=2 or [F:ADV]ACS=""
Default File [LADV]
NBCOL = 2
COL(1) = "[F:ADV]NUMTAB"    : TIT(1) = mess(56,123,1) : # Table
COL(2) = "[F:AXX]TEXTE"     : TIT(2) = mess(82,123,1) : # Intitulé
TIT = mess(75,125,1) : # Tables diverses
Return

#-----------------------------------------------------------------#
Subprog CONTADI(VALEUR,NUMTAB,DEPCOD)
Variable Char  VALEUR()
Value    Char  NUMTAB()
Value    Char  DEPCOD()
If VALEUR="" or val(NUMTAB)=0 : End : Endif
If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Local Integer TROUVE
Read [ADV]CODE = val([L]NUMTAB)
If fstat : End : Endif
Read [ADI]CODE=val([L]NUMTAB);VALEUR
#If fstat : End : Endif
# mb 8.9.14 bug 94010
If fstat
 # 120945-Selection of ATABDIV doesn't take into account dependencies - add filter on DEPCOD when GAUTOSEL set to yes
 If [L]DEPCOD<>""
  Filter [F:ADI] Where ([F:ADI]DEPCOD=[L]DEPCOD | [F:ADI]DEPCOD="") & (dim(GAUTOSEL)>0 and GAUTOSEL=2)
 Endif
 Call CONTSEL("ADI","!",VALEUR,NUMTAB,mkstat) From CONTOBJ
 Filter [F:ADI]                   # 120945-clear filter
Else
 TROUVE=1
Endif
If [L]DEPCOD<>"" & [F:ADV]DEPNUM<>0 & [F:ADI]DEPCOD<>"" & [F:ADI]DEPCOD<>[L]DEPCOD
 GMESSAGE = VALEUR -mess(99,133,1)- [L]DEPCOD : # ne dépend pas de
 mkstat = 2 : End
Endif
If [F:ADV]FLGLEG=2 & func AFNC.ACTIV("LEG")
 If [F:ADI]LEG<>"" & GSOCIETE<>""
  If dim([M:CPY1]LEG)>0 & [M:CPY1]LEG<>""
    If [F:ADI]LEG<>[M:CPY1]LEG                      # # 119235
       GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
       mkstat = 2 : End
    Endif
  Else
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    Read [CPY]CPY0 = GSOCIETE
    If !fstat & [F:ADI]LEG<>[F:CPY]LEG
     GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
     mkstat = 2 : End
    Endif
  Endif
 Endif
Endif
If [F:ADV]FLGSOC=2
 If [F:ADI]SOC<>"" & GSOCIETE<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:ADI]SOC;GSOCIETE
  If fstat
   GMESSAGE = VALEUR-":"-mess(63,127,1)-":"-[F:ADI]SOC : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
 Endif
Endif
# DBA
# cg dec 2014 ajout de la fct gesadlv en plus de gesads
#If val(NUMTAB)=909 &  GFONCTION<>"GESADS"  : Call CONTLEG(VALEUR) : Endif
If val(NUMTAB)=909 &  GFONCTION<>"GESADS" and GFONCTION<>"GESADLV" : Call CONTLEG(VALEUR) : Endif
#112574
If TROUVE & dim([F:ADV]FLGENA)>0 & dim([F:ADI]ENAFLG)>0 & [F:ADV]FLGENA=2 & [F:ADI]ENAFLG<>2
  GMESSAGE = VALEUR-":"-mess(2,126,1) : # Fiche inactive
  mkstat = 2 : End
Endif
 #
End

#-----------------------------------------------------------------#
Subprog CONTLEG(VALEUR)
Variable Char  VALEUR()
If !find(VALEUR,GDOSLEG(1..GNBLEG)) & VALEUR<>""
 GMESSAGE = VALEUR-":"-mess(67,127,1)-nomap : # Législation non gérée par le dossier
 mkstat = 2
Endif
End

#-----------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ATABTAB  [ADV1]
 Local File ATABDIV  [ADI1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".ATABTAB"  [ADV1]
 Local File =[M]DOSORG+".ATABDIV"  [ADI1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ATABTAB  [ADV2]
 Local File ATABDIV  [ADI2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".ATABTAB"  [ADV2]
 Local File =[M]DOSDES+".ATABDIV"  [ADI2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Local Integer I , J , K , L , OK
Gosub SET_MONOLEG
Gosub SET_DOSDESLEG
OK = 1
If !GSERVEUR & GTRACE=""
 If TABLE2<>""
  # Voulez-vous copier uniquement le code "#"
  OK = 1 : Call OUINON(func AFNC.MES(mess(215,115,1),TABLE2),OK) From GESECRAN
  If OK<>2 : TABLE2 = "" : Endif
 Endif
 Read [ADV1]CODE(1)=val(TABLE)
 If [F:ADV1]FLGLEG=2
  If OK=1
   OK = 0
   For [ADI1]CODE Where NUMTAB=val(TABLE)
    If [F:ADI1]LEG="" or find([F:ADI1]LEG,DOSDESLEG(1..NBDESLEG))
     OK = 1 : Break
    Endif
   Next ADI1
   If !OK
    # Aucune législation correspondant au dossier
    Call ERREUR(mess(141,127,1)-[M]DOSDES) From GESECRAN
   Else
    Read [ADI1]CODE(1)=val(TABLE)
    If !fstat
     OK = 1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
     If OK<>2 : OK = 0 : Endif
    Endif
   Endif
  Elsif OK=2
   Read [ADI1]CODE=val(TABLE);TABLE2
   If [F:ADI1]LEG<>"" & !find([F:ADI1]LEG,DOSDESLEG(1..NBDESLEG))
    OK = 0 : Call ERREUR([F:ADI1]LEG-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   Else
    Read [ADI2]CODE=val(TABLE);TABLE2
    If !fstat
     OK=1 : Call AVERTIR([M]DOSDES-TABLE-TABLE2-mess(22,100,1),OK) From GESECRAN
     If OK<>2 : OK = 0 : Endif
    Endif
   Endif
  Endif
 Else
  If OK=1
   Read [ADI1]CODE(1)=val(TABLE)
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Else
   Read [ADI2]CODE=val(TABLE);TABLE2
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-TABLE2-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ADV1], [ADI1], [AXX1], [ADV2], [ADI2], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$SET_DOSDESLEG
Local Char DOSDESLEG(GLONADI)(1..dim(GDOSLEG)) , DOSORGLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer NBDESLEG , NBORGLEG
Call SETLEG([M]DOSDES,DOSDESLEG,NBDESLEG) From DOSCONT
Call SETLEG([M]DOSORG,DOSORGLEG,NBORGLEG) From DOSCONT
Return

$SET_MONOLEG
Local Integer MONOLEG
MONOLEG = !func AFNC.ACTIVDOS([M]DOSDES,"LEG")
Return

$TR_COP
If dim(MONOLEG)<0 : Gosub SET_MONOLEG : Endif
If dim(DOSDESLEG)<0 : Gosub SET_DOSDESLEG : Endif
GOK = 1
Trbegin [ADV2] , [ADI2]
 If TABLE2=""
  For [ADI2]CODE Where NUMTAB=val(TABLE)
   If [F:ADI2]LEG="" or find([F:ADI2]LEG,DOSORGLEG(1..NBORGLEG))
    Read [ADI1]CODE=[F:ADI2]NUMTAB;[F:ADI2]CODE
    If fstat
     Delete [AXX2] Where CODFIC="ATABDIV" & IDENT1=TABLE & IDENT2=[F:ADI2]CODE
     If fstat=1
      GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Break
     Elsif fstat>5
      GOK = 0 : Call RSTA("AXX2","") From GLOCK : Break
     Endif
    Endif
    Delete [ADI2] Curr
    If fstat=1
     GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABDIV" : Break
    Elsif fstat>5
     GOK = 0 : Call RSTA("ADI2","") From GLOCK : Break
    Endif
   Endif
  Next ADI2
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
 For [ADI1]CODE Where NUMTAB=val(TABLE) & (TABLE2="" or TABLE2=CODE)
  Read [ADV2]CODE=val(TABLE)
  If [F:ADI1]LEG="" or find([F:ADI1]LEG,DOSDESLEG(1..NBDESLEG))
   Readlock [ADI2]CODE=[F:ADI1]NUMTAB;[F:ADI1]CODE
   If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Break
   Elsif fstat
    [F:ADI2] = [F:ADI1]
    Call COPTEXTRA("ATABDIV","LNGDES",TABLE,[F:ADI1]CODE) From ATEXTRA
    Call COPTEXTRA("ATABDIV","SHODES",TABLE,[F:ADI1]CODE) From ATEXTRA
    If dim([F:ADI2]UPDUSR)>0 : [F:ADI2]UPDUSR = GUSER : Endif
    If dim([F:ADI2]UPDDAT)>0 : [F:ADI2]UPDDAT = date$ : Endif
    If dim([F:ADI2]UPDTIM)>0 : [F:ADI2]UPDTIM = time  : Endif
    If MONOLEG & [F:ADI2]LEG="" & [F:ADV2]FLGLEG=2
     [F:ADI2]LEG = DOSDESLEG(1)
    Endif
    Write [ADI2]
    If fstat
     GOK=0 : Call FSTA("ADI2") From GLOCK : Break
    Endif
   Else
    [F:ADI2] = [F:ADI1]
    Call COPTEXTRA("ATABDIV","LNGDES",TABLE,[F:ADI1]CODE) From ATEXTRA
    Call COPTEXTRA("ATABDIV","SHODES",TABLE,[F:ADI1]CODE) From ATEXTRA
    If dim([F:ADI2]UPDUSR)>0 : [F:ADI2]UPDUSR = GUSER : Endif
    If dim([F:ADI2]UPDDAT)>0 : [F:ADI2]UPDDAT = date$ : Endif
    If dim([F:ADI2]UPDTIM)>0 : [F:ADI2]UPDTIM = time  : Endif
    If MONOLEG & [F:ADI2]LEG="" & [F:ADV2]FLGLEG=2
     [F:ADI2]LEG = DOSDESLEG(1)
    Endif
    Rewrite [ADI2]
    If fstat
     GOK=0 : Call FSTA("ADI2") From GLOCK : Break
    Endif
   Endif
  Endif
 Next ADI1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 Delete [ADV2] Where NUMTAB=val(TABLE)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABTAB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ADV1]CODE Where NUMTAB=val(TABLE)
  [F:ADV2] = [F:ADV1]
  Call COPTEXTRA("ATABTAB","LNGDES",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","SHODES",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","ALPDES1",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","ALPDES2",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","NUMDES1",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","NUMDES2",TABLE,"") From ATEXTRA
  If dim([F:ADV2]UPDUSR)>0 : [F:ADV2]UPDUSR = GUSER : Endif
  If dim([F:ADV2]UPDDAT)>0 : [F:ADV2]UPDDAT = date$ : Endif
  If dim([F:ADV2]UPDTIM)>0 : [F:ADV2]UPDTIM = time  : Endif
  Write [ADV2]
  If fstat
   GOK=0 : Call FSTA("ADV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-----------------------------------------------------------------#
Subprog C_NUMTAB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ADV",num$(VALEUR),"") From CONTOBJ
If [F:ADV]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ADV]ACS
 If fstat or ([F:ACC]MODIF<>2 & [F:ACC]CONSUL<>2)
  GMESSAGE = mess(94,133,1) : # Table non accessible
  mkstat = 2
 Endif
Endif
End

Subprog IB_CODE
GBOUTS = ""
GBOUTA = ""
GBOUTP = ""
End

Subprog AS_CODE(VALEUR)
Variable Char    VALEUR()
Look [ADI]CODE = [M]NUMTAB;VALEUR
If fstat=0 : mkstat=2 : End : Endif
End

Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODE) From OBJDIV
End

Subprog IB_VALDEF
GBOUTS = ""
GBOUTA = ""
GBOUTP = ""
End

Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & !find(VALEUR,[M]CODE(0..[M]NBLIG-1))
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog IB_TEST
End

Subprog AM_SOC(VALEUR)
Variable Char    VALEUR()
Read [AGF]AGF0 = VALEUR
If !fstat
 [M]INTSOC(nolign-1)  = [F:AGF]SHO
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]INTLEG(nolign-1),"ATABDIV","SHODES","909",VALEUR) From ATEXTRA
End

