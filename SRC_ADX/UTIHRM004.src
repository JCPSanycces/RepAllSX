#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM004 - Delete Representation(ASW) ESSTEST      #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Delete Representation(ASW) ESSTEST") From LECFIC

  Call MAJ_UTIHRM004(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIHRM004(DOSSIER)
Value Char DOSSIER
Local Char CODREPDEL (GLONASW)

If clalev([F:ASW])=0    : Local File =DOSSIER+".ASHW"           [ASW]     : Endif
If clalev([F:ASWB])=0   : Local File =DOSSIER+".ASHWBLC"        [ASWB]    : Endif
If clalev([F:ASWC])=0   : Local File =DOSSIER+".ASHWCOL"        [ASWC]    : Endif
If clalev([F:ASWR])=0   : Local File =DOSSIER+".ASHWEXPPRO"     [ASWR]    : Endif
If clalev([F:ASWF])=0   : Local File =DOSSIER+".ASHWFLD"        [ASWF]    : Endif
If clalev([F:ASWK])=0   : Local File =DOSSIER+".ASHWLNK"        [ASWK]    : Endif
If clalev([F:ASWMN])=0  : Local File =DOSSIER+".ASHWMENU"       [ASWMN]   : Endif
If clalev([F:ASWM])=0   : Local File =DOSSIER+".ASHWMET"        [ASWM]    : Endif
If clalev([F:ASWO])=0   : Local File =DOSSIER+".ASHWOPT"        [ASWO]    : Endif
If clalev([F:ASWP])=0   : Local File =DOSSIER+".ASHWPAR"        [ASWP]    : Endif
If clalev([F:ASWMP])=0  : Local File =DOSSIER+".ASHWPARMET"     [ASWMP]   : Endif
If clalev([F:ASWS])=0   : Local File =DOSSIER+".ASHWSEC"        [ASWS]    : Endif


Call ECR_TRACE("UTIHRM004 : Delete Representation(ASW) ESSTEST : "+DOSSIER,0) From GESECRAN

Call DEBTRANS From GLOCK

Trbegin [ASW]

[L]CODREPDEL="ESSTEST"
Gosub DEL_ASW_ESSTEST

If !GOK
  Rollback
Else
  Commit
Endif

Call ECR_TRACE("UTIHRM004: Process completed on : "+DOSSIER,0) From GESECRAN

Close Local File [ASW]
Close Local File [ASWB]
Close Local File [ASWC]
Close Local File [ASWR]
Close Local File [ASWF]
Close Local File [ASWK]
Close Local File [ASWMN]
Close Local File [ASWM]
Close Local File [ASWO]
Close Local File [ASWP]
Close Local File [ASWMP]
Close Local File [ASWS]

End

##############################
$DEL_ASW_ESSTEST

Delete [ASW] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASW") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASW  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWB] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWB") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWB  : "+DOSSIER,0) From GESECRAN
Endif


Delete [ASWC] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWC") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWC  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWR] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWR") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWR  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWF] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWF") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWF  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWK] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWK") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWK  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWMN] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWMN") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWMN  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWM] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWM") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWM  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWO] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWO") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWO  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWP] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWP") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWP  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWMP] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWMP") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWMP  : "+DOSSIER,0) From GESECRAN
Endif

Delete [ASWS] Where CODREP = CODREPDEL
If fstat
 GOK = 0 : Call FSTA("ASWS") From GLOCK
 Return
Else
  Call ECR_TRACE("UTIHRM004 : Deleted Representation ESSTEST from ASWS  : "+DOSSIER,0) From GESECRAN
Endif


Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func CHECKFILINFO(APPLI)>0 : End : Endif
Call MAJ_UTIHRM004(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func CHECKFILINFO(APPLI)>0 : End : Endif
Call MAJ_UTIHRM004(APPLI)

End

Funprog CHECKFILINFO(APPLI)
Value Char APPLI
Local Integer STAT
Local Integer STAT_ERR
[L]STAT_ERR = 1

If filinfo(filpath("FIL","ASHW","fde",APPLI),0)<=0          : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWBLC","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWCOL","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWEXPPRO","fde",APPLI),0)<=0    : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWFLD","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWLNK","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWMENU","fde",APPLI),0)<=0      : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWMET","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWOPT","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWPAR","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWPARMET","fde",APPLI),0)<=0    : End [L]STAT_ERR : Endif
If filinfo(filpath("FIL","ASHWSEC","fde",APPLI),0)<=0       : End [L]STAT_ERR : Endif

End STAT

