#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# UTIMAJTVC  Utilitaire de mise à jour de la table TABVAC                   #
#            L'espression contenue dans EXP1 n'est plus contenue dans EXPTST#
#############################################################################

Call MAJ_UTIMAJTVC
End


Subprog MAJ_UTIMAJTVC
Local Char WDOSSIER(30)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTITMAJTVC - Modif table TABVAC") From SAIDOS
If WDOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITMAJTVC : Utilitaire de mise à jour de la table TABVAC") From LECFIC
  Call EXE_UTIMAJTVC(WDOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIMAJTVC(WDOSSIER)
Value Char    WDOSSIER
#----- Variables locales -----#
Local Char    WMSG(100)
Local Integer WNBR
Local Char EXPRESSION(250)
#-----
Call ECR_TIME("UTIMAJTVC : Début traitement du dossier "+WDOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture de la table -----#
Local File  ADOSSIER            [ADS]
Local File =WDOSSIER+".TABVAC" [TVC]
#----- Début du traitement -----#
Raz WNBR
Read [ADS] DOSSIER=WDOSSIER
If fstat  Goto FIN_UTIMAJTVC : Endif
Call ECR_TRACE("Mise à jour TABVAC",0) From GESECRAN
#-----

Trbegin [TVC] 
  For [TVC] Where [F:TVC]EXP1 <> ""
  If len([F:TVC]EXPTST) < 250
    If [F:TVC]FLD(0)="" EXPRESSION = " & (  ("+[F:TVC]EXP1 + ") )"
    Else EXPRESSION = " & ("+[F:TVC]EXP1 + ")" : Endif
      I=instr(1,[F:TVC]EXPTST,EXPRESSION)
      If I>0  
        [F:TVC]EXPTST = left$([F:TVC]EXPTST,I) 
        If [F:TVC]FLD(0)<>"" [F:TVC]EXPTST += ")" : Endif
        Rewrite[TVC]
        If fstat
          WMSG=mess(40,9014,1)+" TABVAC"
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Else
          WNBR+=1
       Endif
      Endif
 Else
    WMSG =[F:TVC]COD+' '+ mess(570,199,1)
    Call ECR_TRACE(WMSG,0) From GESECRAN
    WMSG =mess(571,199,1) 
    Call ECR_TRACE(WMSG,0) From GESECRAN
 Endif 
 Next
Commit
#----- Fin du traitement -----#
$FIN_UTIMAJTVC
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIMAJTVC : Nbre d'enregistrements corrigés :"-num$(WNBR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [TVC]
End


