##################################################
## SUBSTADEC : Statistiques par dûˋcades
##################################################
## Subprog BORNES(DAT1,DAT2,LIBCLE)
## Subprog CADRE(DAT1)
## Subprog DATFIN(DAT1,DAT2)
## Subprog DECAL(DAT1,DAT3,DECAL)
## Subprog RECAL(DAT1,DAT2,DECAL)
##################################################

##################################################
## Bornes de dates d'une pûˋriode + libellûˋ
##################################################
Subprog BORNES(DAT1,DAT2,LIBCLE)
Value    Date    DAT1
Variable Date    DAT2
Variable Char    LIBCLE
If day(DAT1)>20
 DAT2 = eomonth(DAT1)
Elsif day(DAT1)>10
 DAT2 = gdat$(20,month(DAT1),year(DAT1))
Else
 DAT2 = gdat$(10,month(DAT1),year(DAT1))
Endif
LIBCLE = format$("D:"+GFMDAT4,DAT1)+"  -  " + format$("D:"+GFMDAT4,DAT2)
End

##########################################################################################
# Recadrage de la date de dûˋbut sur le dûˋbut d'une pûˋriode
##########################################################################################
Subprog CADRE(DAT1)
Variable Date    DAT1
If day(DAT1)>20
 DAT1 = gdat$(21,month(DAT1),year(DAT1))
Elsif day(DAT1)>10
 DAT1 = gdat$(11,month(DAT1),year(DAT1))
Else
 DAT1 = gdat$(01,month(DAT1),year(DAT1))
Endif
End

##########################################################################################
# Renvoie la date de fin de pûˋriode en fonction du dûˋbut
##########################################################################################
Subprog DATFIN(DAT1,DAT2)
Value    Date    DAT1
Variable Date    DAT2
Local Date DAT3
DAT3 = DAT1
Repeat
 If day(DAT3)>20
  DAT3 = eomonth(DAT3)+1
 Elsif day(DAT3)>10
  DAT3 = gdat$(21,month(DAT3),year(DAT3))
 Else
  DAT3 = gdat$(11,month(DAT3),year(DAT3))
 Endif
Until DAT3>DAT2
DAT2 = DAT3-1
End

##########################################################################################
# Renvoie le nombre de pûˋriodes qui sûˋparent 2 dates de dûˋbut (+ ou -)
##########################################################################################
Subprog DECAL(DAT1,DAT2,DECAL)
Value    Date    DAT1
Value    Date    DAT2
Variable Integer DECAL
DECAL = 36*(year(DAT1)-year(DAT2))+3*(month(DAT1)-month(DAT2))
DECAL += min(2,int((day(DAT1)-1)/10))-min(2,int((day(DAT2)-1)/10))
End

##########################################################################################
# Ajoute un nombre de pûˋriode û  une date de fin (+ ou -)
##########################################################################################
Subprog RECAL(DAT1,DAT2,DECAL)
Value    Date    DAT1
Variable Date    DAT2
Value    Integer DECAL
DAT2 = addmonth(DAT1,fix(DECAL/3))
Case mod(DECAL,3)
 When 0
 When 1
  Case day(DAT2)
   When 10      : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))
   When 20      : DAT2 = eomonth(DAT2)
   When Default : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))
  Endcase
 When -1
  Case day(DAT2)
   When 10      : DAT2 = eomonth(addmonth(DAT2,-1))
   When 20      : DAT2 = gdat$(10,month(DAT2),year(DAT2))
   When Default : DAT2 = gdat$(20,month(DAT2),year(DAT2))
  Endcase
 When 2
  Case day(DAT2)
   When 10      : DAT2 = eomonth(DAT2)
   When 20      : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))
   When Default : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))
  Endcase
 When -2
  Case day(DAT2)
   When 10      : DAT2 = gdat$(20,month(DAT2)-1,year(DAT2))
   When 20      : DAT2 = eomonth(addmonth(DAT2,-1))
   When Default : DAT2 = gdat$(10,month(DAT2),year(DAT2))
  Endcase
Endcase
End

