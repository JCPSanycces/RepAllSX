Gosub IB_DSP
End

Subprog IB_DSP6
Gosub IB_DSP
End

Subprog IB_DSP7
Gosub IB_DSP
End

$IB_DSP
Local Integer AXE
Local Integer OK
For AXE=1 To [M]NBRDIE
 If AXE>GOPTCANA : Break : Endif
 Call CPY_AXE (AXE, [M]FCY, OK) From TPSDIV
 If OK : Break : Endif :# A partir du moment où un axe correspond, on peut afficher la fenêtre de répartition
Next
If !OK
 Raz GBOUT2
 Raz GBOUT3
Endif
Return

