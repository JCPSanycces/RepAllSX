# FQ92876 - 26/09/14 - Réinitialisation des axes même si que affichés
$AM_DSP
Local Integer AXE,COLCCE,SAU_MKSTAT
Local Char    VALCCE(20)

  Assign "[M]DSP"+num$(COL) With ""
  SAU_MKSTAT=mkstat
  For COLCCE=1 To 7
    For AXE=1 To 9
      If evalue("dim([M]CCE"+num$(AXE)+num$(COLCCE)+")")>0 Then
        VALCCE=""
        Call ="AS_CCE"+num$(AXE)+num$(COLCCE) With VALCCE From TPSJOU0
        If VALCCE<>"" Then
          Assign "[M]CCE"+num$(AXE)+num$(COLCCE) With VALCCE
        Endif
      Endif
    Next
  Next
  mkstat=SAU_MKSTAT
  Assign "[M]DSP"+num$(COL) With ""
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 10-01-2017 - X3-18688 - START
GCURLEG = VALUER
#LIPET - 10-01-2017 - X3-18688 - END
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
#LIPET - 10-02-2017 - X3-25203 - START
Filter [HRCTR] Where REFNUM = VALEUR
#Read [HRCTR] First
If rowcount([HRCTR])= 0
  GMESSAGE = mess(150,10702,1)
  mkstat=2
Endif
#LIPET - 10-02-2017 - X3-25203 - END
End

Subprog AS_YEA(VALEUR)
Variable Decimal VALEUR
#LIPET - 10-01-2017 - X3-18688 - START
#If dim(GCURLEG)= 0:GCURLEG =[M:TPSJ]LEG :Endif
#LIPET - 10-01-2017 - X3-18688 - END
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
#LIPET - 10-01-2017 - X3-18688 - START
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

If VALEUR<>""
   Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
   Filter [HRCTR]
   If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:TPSJ]LEG = GCURLEG
    Affzo [M:TPSJ]LEG
   Endif
Endif
#LIPET - 10-01-2017 - X3-18688 - END
End


