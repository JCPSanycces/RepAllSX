## Entête
######################################################################################

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Gosub AM_REFNUM From TPSJOU1
#LIPET - 10-01-2017 - X3-18688 - START
If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
   Filter  [HRCTR] Where REFNUM=VALEUR
   If rowcount([HRCTR]) = 1
     Read [HRCTR] First
     Filter [HRCTR]
     [M:TPSJ]CTRNUM = [F:HRCTR]CTRNUM
     Grizo [M:TPSJ]CTRNUM
     Affzo [M:TPSJ]CTRNUM
     Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
     If !fstat
       GCURLEG = [F:FCY2]LEG
       [M:TPSJ]LEG = GCURLEG
       Affzo [M:TPSJ]LEG
     Endif
    Else
    Actzo CTRNUM
    Affzo CTRNUM
Endif
Effzo [M:TPSJ]NUMWEK
#LIPET - 10-01-2017 - X3-18688 - END
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub AS_CTRNUM From TPSJOU1
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub AM_CTRNUM From TPSJOU1
End

Subprog C_NUMWEK(VALEUR)
Variable Decimal VALEUR
#LIPET - 10-01-2017 - X3-18688 - START
#If clalev([F:PEO])=0 : Local File PERIOD [PEO] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
#LIPET - 10-01-2017 - X3-18688 - END
Local Integer OK, I
Local Char    LESITE(GLONFCY) : #59323

LESITE = [M]FCY
#Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#LIPET - 10-01-2017 - X3-18688 - START
#Filter [PEO] Where (FCY=LESITE | FCY="") & find([M]YEA,YEAWEK)<>0  & find(VALEUR,NUMWEK)<>0 Order By FCY Desc
#For [PEO]
# I = find(VALEUR,[F:PEO]NUMWEK)
# If [F:PEO]YEAWEK(I-1)=[M]YEA
#  OK = 1 : Break
# Endif
#Next
#Filter [PEO]
Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
Filter [HRPEOD] Where (PERCOD=[F:HRCTR]PERCOD) & find([M]YEA,YEAWEK)<>0  & find(VALEUR,NUMWEK)<>0 Order By PERCOD
For [HRPEOD]
 I = find(VALEUR,[F:HRPEOD]NUMWEK)
 If [F:HRPEOD]YEAWEK(I-1)=[M]YEA
  OK = 1 : Break
 Endif
Next
Filter [HRPEOD]
#LIPET - 10-01-2017 - X3-18688 - END
If !OK
 #LIPET - 10-01-2017 - X3-18688 - START
 # Aucune période n'est définie sur cette semaine
 #GMESSAGE = mess(120,709,1)
 GMESSAGE = mess(120,10709,1)
 #LIPET - 10-01-2017 - X3-18688 - END
 mkstat = 2 : End
Endif
End

Subprog AM_NUMWEK(VALEUR)
Variable Decimal VALEUR
Local Integer STAT
If [M]REFNUM<>"" & [M]YEA<>0
 If [F:ID]FLGMULCTR<>2
  #LIPET - 10-01-2017 - X3-18688 - START
  # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#  Filter [CTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=aweek(VALEUR,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek(VALEUR,[M]YEA)))
#  Read [CTR]CTR1 Last
#  Filter [CTR]
#  If !fstat
#   [M]FCY    = [F:CTR]ETRFCY
#   [M]SRV    = [F:CTR]ETRSRV
#   [M]CTRNUM = [F:CTR]CTRNUM
#   Affzo [M]FCY,CTRNUM,SRV

  Filter [HRCTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=aweek(VALEUR,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek(VALEUR,[M]YEA)))
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
   Affzo [M]FCY,CTRNUM,SRV
   #LIPET - 10-01-2017 - X3-18688 - END
  Endif
 Endif
 Call CADRE_SEM(VALEUR,[M]YEA,[M]FCY,STAT) From TPSJOU1
 If STAT=0 : mkstat=2 : End : Endif
 [M]NUMWEK = VALEUR
 Gosub CHARGE From TPSJOU
Endif
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
Local Char    LESITE(GLONFCY)

LESITE = [M]FCY

#LIPET - 10-01-2017 - X3-18688 - START
#If clalev([F:PEO])=0 : Local File PERIOD [PEO] : Endif
#
#Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#Filter [PEO] Where (FCY=LESITE | FCY="") & find(VALEUR,YEAWEK)<>0
#
#Read [PEO]PEO0 Last
#Filter [PEO]
#If fstat
# # Aucune période n'est définie sur cette année
# GMESSAGE = mess(121,709,1)
# mkstat = 2 : End
#Endif

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO
Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & find(VALEUR,YEAWEK)<>0
#Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD
Read [HRPEOD]HRPEOD0 Last
Filter [HRPEOD]
If fstat
 # Aucune période n'est définie sur cette année
 GMESSAGE = mess(121,10709,1)
 mkstat = 2 : End
Endif
#LIPET - 10-01-2017 - X3-18688 - END
End

Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
Local Integer STAT
If [M]REFNUM<>"" & [M]NUMWEK<>0

 If [F:ID]FLGMULCTR<>2
 #LIPET - 10-01-2017 - X3-18688 - START
  # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#  Filter [CTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,VALEUR)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,VALEUR)))
#  Read [CTR]CTR1 Last
#  Filter [CTR]
#  If !fstat
#   [M]FCY    = [F:CTR]ETRFCY
#   [M]SRV    = [F:CTR]ETRSRV
#   [M]CTRNUM = [F:CTR]CTRNUM
#   Affzo [M]FCY,CTRNUM,SRV
  Filter [HRCTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,VALEUR)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,VALEUR)))
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
   Affzo [M]FCY,CTRNUM,SRV
 #LIPET - 10-01-2017 - X3-18688 - END
  Endif
 Endif
 Call CADRE_SEM([M]NUMWEK,VALEUR,[M]FCY,STAT) From TPSJOU1
 If STAT=0 : mkstat=2 : End : Endif
 [M]YEA = VALEUR
 Gosub CHARGE From TPSJOU
Endif
End

