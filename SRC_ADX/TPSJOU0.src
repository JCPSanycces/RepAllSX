Subprog CL_PREWEK(VALEUR)
Variable Char    VALEUR()
Local Integer DEFILE
If [M]DAT(0)<>[0/0/0]
  DEFILE = 3
  Gosub PRE From TPSJOU : mkstat=4 : # Pour appeler apres_modif et faire setbout
Endif
End

Subprog CL_SUIWEK(VALEUR)
Variable Char    VALEUR()
Local Integer DEFILE
DEFILE = 3
Gosub SUI From TPSJOU : mkstat=4 : # Pour appeler apres_modif et faire setbout
End

# FQ82073 - MABON 11/12/12 - Ajout nouveaux champs CTRDATx
Subprog AS_CTRDAT1(VALEUR)
Variable Date    VALEUR()

  If VALEUR<>[0/0/0] | [M]TIM1="" : End : Endif
  VALEUR=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,[M]DAT(6),[M]PYRDAT(0),[M]DAT(0),2)
End

Subprog C_CTRDAT1(VALEUR)
Variable Date    VALEUR
Local    Date    XITDAT

  If VALEUR=[0/0/0] Then
    If [M]TIM1<>"" Then
      mkstat = 1 : GMESSAGE = mess(10,123,1) : # Zone obligatoire
    Endif
    End
  Endif
  Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,VALEUR,[M]DAT(0),[M]PYRDAT(0),1,[L]XITDAT) From TPSSTD
  If !mkstat Then
    If dim([M]SCTRDAT1)>0 Then
      [M]SCTRDAT1=[L]XITDAT : Affzo [M]SCTRDAT1
    Endif
    #LIPET - 10-01-2017 - X3-18688 - START
#    If dim([M]FCYT1)>0 Then
#      [M]FCYT1=[F:CTR]ETRFCY : Affzo [M]FCYT1
#    Endif
#    If dim([M]SRVT1)>0 Then
#      [M]SRVT1=[F:CTR]ETRSRV : Affzo [M]SRVT1
#    Endif
    If dim([M]FCYT1)>0 Then
      [M]FCYT1=[F:HRCTR]ETRFCY : Affzo [M]FCYT1
    Endif
    If dim([M]SRVT1)>0 Then
      [M]SRVT1=[F:HRCTR]ETRSRV : Affzo [M]SRVT1
    Endif
    #LIPET - 10-01-2017 - X3-18688 - END
  Endif
End

