#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMPH
###################################################################################################
# METHODS                                                                                         #
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-62154 - 2017-11-06 by TEJAC
  SLEVEL = func AFNC.MES1(mess(994,2260,1), this.CLB)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

#######################################################################################
$TIMENT_GET_INDEX
#Value Integer PTESEQ
#Local Integer ARET_VALUE

Local Integer NI

  For NI = 1 To maxtab(this.TIMENT)
    If this.TIMENT(NI) <> null and find(this.TIMENT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TIMENT(NI).PTESEQ = PTESEQ Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$PTE_RESET_ERRORS
#Local Integer ARET_VALUE

Local Integer NI

  # ---------------------------------
  # Mandatory to do that from here. It's not possible to use AREAD_AFTER at each level because AREAD_AFTER
  # if going from the lower level to the upper lever. And in this case, the need is the opposite.
  # Maybe there is another way to do that, but I don't know it. :-(
  # ---------------------------------
  [L]ARET_VALUE = fmet this.ADELETERRORALL()
  For NI = 1 To maxtab(this.TIMENT)
    If this.TIMENT(NI) <> null and find(this.TIMENT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.TIMENT(NI).ADELETERRORALL()
    Endif
  Next NI
Return

#######################################################################################
$_TIMENT_VALIDATION
#Variable Instance TECPTESTA Using C_TECPTESTA : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer IPTELINE
Local Instance ZPJMTIMEMP Using C_PJMTIMEMP      # Issue X3-94962 - 2018-06-20 by FGR
Local Integer IRET                               # Issue X3-94962 - 2018-06-20 by FGR

  # Issue X3-66487 - 2018-04-08 by SINGC
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If this.TCHACTION <> "TIMENTVAL" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # ------------------------------------
  For NI = 1 To maxtab(TECPTESTA.TIMENT)
    If TECPTESTA.TIMENT(NI) <> null and find(TECPTESTA.TIMENT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      IPTELINE = fmet this.TIMENT_GET_INDEX(TECPTESTA.TIMENT(NI).PTESEQ)
      If IPTELINE > 0 Then   # Issue X3-94962 - 2018-06-20 by FGR : When status is over than "Validated" line is not in the collection
        If this.TIMENT(IPTELINE).PTESTA <> TECPTESTA.TIMENT(NI).PTESTA Then
          this.TIMENT(IPTELINE).TCHACTION = "TIMENTVAL"
          this.TIMENT(IPTELINE).PTESTA = TECPTESTA.TIMENT(NI).PTESTA
        Endif
      Else
        # Issue X3-94962 - 2018-06-20 by FGR : When status is over than "Validated" line is not in the collection
        ZPJMTIMEMP = NewInstance C_PJMTIMEMP AllocGroup null
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet ZPJMTIMEMP.AREAD(this.CLB, TECPTESTA.TIMENT(NI).PTESEQ))
        If ZPJMTIMEMP.PTESTA <> TECPTESTA.TIMENT(NI).PTESTA Then
          ZPJMTIMEMP.TCHACTION = "TIMENTVAL"
          ZPJMTIMEMP.PTESTA = TECPTESTA.TIMENT(NI).PTESTA
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet ZPJMTIMEMP.AUPDATE())
        Endif
        If [L]ARET_VALUE > [V]CST_AOK Then
          IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZPJMTIMEMP, this)
        Endif
        FreeGroup ZPJMTIMEMP
      Endif
    Endif
  Next NI
Return
