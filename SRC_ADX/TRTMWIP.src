#<AdxTL>@(#)0.0.0.0 $Revision$
# Traitement TRTMWIP            TB Juin 2003 Intégration Wipcost
#
# Affichage des fenêtres détails à partir de la consultation des encours d'OF
# (fonction GESMWI) -  Actions sur tableau

$ACTION
Case ACTION
 When "DEBUT"
  Case GACTION
    When "VISUWIPPDT" Gosub LOAD_SCREEN_P
    When "VISUWIPEO"  Gosub LOAD_SCREEN_P
    When "VISUWIPMAT" Gosub LOAD_SCREEN_M
    When "VISUWIPEOM" Gosub LOAD_SCREEN_M
    When "VISUWIPLAB" Gosub LOAD_SCREEN_L
    When "VISUWIPMAC" Gosub LOAD_SCREEN_O
    When "VISUWIPSCO" Gosub LOAD_SCREEN_S
    When "VISUWIPSRV" Gosub LOAD_SCREEN_S
  Endcase
 When Default
Endcase
Return

# LIGNES REPRISES du TRT spec  >>>> (enlever les affzo)
#####################################################################
#  XFUNXWP - Product Cost detail Inquiry
#            Called from WIP Cost / Products Screen - MWI3
#####################################################################
$LOAD_SCREEN_P

Local Integer I, J, K, L


Raz [M:MWP0], [M:MWMP], [M:MWOH], [M:MWP3]

If PARAM(2) <> ""
    [M:MWP0]VCRTYP = val(PARAM(1))
    [M:MWP0]VCRNUM = PARAM(2)
    [M:MWP0]VCRLIN = val(PARAM(3))
    [M:MWP0]STU    = PARAM(4)
    [M:MWP0]ITMREF = PARAM(5)      # (suivi sans OF)
    Raz [M:MWP0]TOTNOTPST, [M:MWP0]TOTPOSTED, [M:MWP0]TOTAMT, [M:MWP0]TOTQTY
Endif

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER   [ITM] : Endif

If [M:MWP0]VCRTYP=10 
    If !clalev([F:MFI]) : Local File MFGITM      [MFI] : Endif
Endif
If [M:MWP0]VCRTYP=36 
    If !clalev([F:SCI]) : Local File SCOITM      [MFI] : Endif
Endif

# Load Header Screen
If [M:MWP0]VCRTYP=10 & [M:MWI0]TRKTYP = 1 # ou relire MWH (pour réutilisabilité)
  Read [MFI]MFI0 = [M:MWP0]VCRNUM;[M:MWP0]VCRLIN
  If !fstat 
    [M:MWP0]=[F:MFI]
  Endif
Elsif [M:MWP0]VCRTYP=36
  Read [SCI]SCI0 = [M:MWP0]VCRNUM;[M:MWP0]VCRLIN
  If !fstat 
    [M:MWP0]=[F:SCI]
  Endif
Endif

# Load Products Detail
I = 0
J = 0
L = 0
For  [MWI]MWI2 Where VCRTYP = [M:MWP0]VCRTYP & VCRNUM=[M:MWP0]VCRNUM & VCRLIN=[M:MWP0]VCRLIN & 
&    ITMREF=[M:MWP0]ITMREF & STU=[M:MWP0]STU & (TXNTYP=14 | (TXNTYP=5 & MATOVETYP = 1) | TXNTYP=17)
    If [F:MWI]TXNTYP = 14
        [M:MWMP]VCRNUM(I)    = [F:MWI]VCRNUM
        [M:MWMP]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWMP]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWMP]QTY(I)       = [F:MWI]QTY
        [M:MWMP]STU(I)       = [F:MWI]STU
        [M:MWMP]UNTCST(I)    = [F:MWI]UNTCST
        [M:MWMP]PRINAT(I)    = [F:MWI]PRINAT
        [M:MWMP]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWMP]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWMP]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWMP]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWMP]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWMP]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWP0]TOTQTY += [F:MWI]QTY
        [M:MWP0]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWP0]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWP0]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 1) # FG de type entrée (produit)
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        ##For K = 0 To 5
        ##   Assign "[M:MWOH]OVENAT"+num$(K)+"("+num$(J)+")" With [F:MWI]OVENAT(K)
        ##    Assign "[M:MWOH]OVENATAMT"+num$(K)+"("+num$(J)+")" With [F:MWI]OVENATAMT(K)
        ##Next # >> 1 nature par enregistrement !  remplacé par
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT

        [M:MWOH]WST(J)       = [F:MWI]WST
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Elsif [F:MWI]TXNTYP = 17
        [M:MWP3]TXNDAT(L)    = [F:MWI]TXNDAT ## si on indice par nolign on peut faire M=F !!mais 3 écrans
        [M:MWP3]TXNACT(L)    = [F:MWI]TXNACT
        [M:MWP3]QTY(L)       = [F:MWI]QTY
        [M:MWP3]REJQTY(L)    = [F:MWI]REJQTY
        [M:MWP3]STU(L)       = [F:MWI]STU
        [M:MWP3]PRINAT(L)    = [F:MWI]PRINAT
        [M:MWP3]AMOUNT(L)    = [F:MWI]AMOUNT
        [M:MWP3]CSTELM2(L)   = [F:MWI]CSTELM(2)
        [M:MWP3]CSTELM3(L)   = [F:MWI]CSTELM(3)
        [M:MWP3]GLPSTA(L)    = [F:MWI]GLPSTA
        [M:MWP3]JOUTYP(L)    = [F:MWI]JOUTYP
        [M:MWP3]JOUNUM(L)    = [F:MWI]JOUNUM
        [M:MWP3]MFGFCY(L)    = [F:MWI]MFGFCY

        L += 1
    Endif
Next
[M:MWMP]NBLIG = I
[M:MWOH]NBLIG = J
[M:MWP3]NBLIG = L

#Affzo [M:MWP0]    # pas nécesaire !?
Affzo [M:MWMP]
Affzo [M:MWOH]
Affzo [M:MWP3]

Return

#####################################################################
#  XFUNXWM - Material Cost detail Inquiry
#            Called from WIP Cost / Materials Screen - MWI4
#####################################################################
$LOAD_SCREEN_M

# Define and Initialize variables
Local Integer I, J

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif

Raz [M:MWM0], [M:MWMP], [M:MWOH]

# (séq et MFGLIN peuvent être 0 si mat rajoutée...)
If PARAM(2) <> "" & PARAM(5) <> "" & PARAM(6) <> ""
    [M:MWM0]VCRTYP = val(PARAM(1))
    [M:MWM0]VCRNUM = PARAM(2)
    [M:MWM0]VCRLIN = val(PARAM(3))
    [M:MWM0]BOMSEQ = val(PARAM(4))
    [M:MWM0]ITMREF = PARAM(5)
    [M:MWM0]STU    = PARAM(6)
Endif

If [M:MWM0]VCRTYP=10 
    If !clalev([F:MFM]) : Local File MFGMAT      [MFM] : Endif
    If !clalev([F:MFI]) : Local File MFGITM      [MFI] : Endif
Endif
If [M:MWM0]VCRTYP=36 
    If !clalev([F:SCI]) : Local File SCOITM      [MFI] : Endif
    If !clalev([F:SCM]) : Local File SCOMAT      [SCM] : Endif
Endif

# ecran entete
If [M:MWM0]VCRTYP=10 & [M:MWI0]TRKTYP = 1 # ou relire MWH (pour réutilisabilité)
  Read [MFM]MFM0 = [M:MWM0]VCRNUM;[M:MWM0]VCRLIN;[M:MWM0]BOMSEQ;[M:MWM0]ITMREF
  If !fstat 
    [M:MWM0]=[F:MFM]
  Endif

  Read [MFI]MFI0=[M:MWM0]VCRNUM;[M:MWM0]VCRLIN
  If !fstat 
    [M:MWM0]PITMREF=[F:MFI]ITMREF
  Endif
Elsif [M:MWM0]VCRTYP=36
  Read [SCM]SCM0 = [M:MWM0]VCRNUM;[M:MWM0]VCRLIN;[M:MWM0]BOMSEQ
  If !fstat 
    [M:MWM0]=[F:SCM]
    [M:MWM0]ITMREF=[F:SCM]CPNITMREF
  Endif

  Read [SCI]SCI0=[M:MWM0]VCRNUM;[M:MWM0]VCRLIN
  If !fstat 
    [M:MWM0]PITMREF=[F:SCI]ITMREF
  Endif
Else
  [M:MWM0]PITMREF = [F:MWH]ITMREF   # (suivi sans OF)
Endif


# Load Materials Detail
I = 0
J = 0
For  [MWI]MWI4 Where VCRTYP = [M:MWM0]VCRTYP & VCRNUM=[M:MWM0]VCRNUM & VCRLIN=[M:MWM0]VCRLIN & 
&    BOMSEQ=[M:MWM0]BOMSEQ & ITMREF=[M:MWM0]ITMREF &
&    STU=[M:MWM0]STU & (TXNTYP=1 | (TXNTYP=5 & MATOVETYP = 2)) 
    If [F:MWI]TXNTYP = 1
        [M:MWMP]VCRNUM(I)    = [F:MWI]VCRNUM
        [M:MWMP]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWMP]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWMP]QTY(I)       = [F:MWI]QTYACT    # CCC (08/11/04) Bug 26297
        [M:MWMP]STU(I)       = [F:MWI]STU
# CCC (08/11/04) Bug 26297
#        [M:MWMP]UNTCST(I)    = [F:MWI]UNTCST
        If [F:MWI]QTYACT<>0
            [M:MWMP]UNTCST(I)    = abs([F:MWI]AMOUNT/[F:MWI]QTYACT)
        Endif
        [M:MWMP]PRINAT(I)    = [F:MWI]PRINAT
        [M:MWMP]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWMP]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWMP]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWMP]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWMP]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWMP]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWM0]TOTQTY += [F:MWI]QTYACT    # CCC (08/11/04) Bug 26297
        [M:MWM0]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWM0]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWM0]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 2) # FG de type sortie (matière)
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT
        [M:MWOH]WST(J)       = [F:MWI]WST
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Endif
Next
[M:MWMP]NBLIG = I
[M:MWOH]NBLIG = J

Affzo [M:MWM0]
Affzo [M:MWMP]
Affzo [M:MWOH]

Return

#####################################################################
#  XFUNXWL - Labor Cost detail Inquiry
#            Called from WIP Cost / Labor Screen - MWI5
#####################################################################
$LOAD_SCREEN_L
Local Integer I, J

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif
If !clalev([F:MFO]) : Local File MFGOPE      [MFO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO  [MWS] : Endif

Raz [M:MWIL], [M:MWIO], [M:MWOH]

##If PARAM(1) <> "" & val(PARAM(2)) > 0 & val(PARAM(3)) >= 0 & PARAM(4) <> ""
    [M:MWIL]VCRTYP     = val(PARAM(1))
    [M:MWIL]VCRNUM     = PARAM(2)
    [M:MWIL]OPENUM     = val(PARAM(3))
    [M:MWIL]OPESPLNUM  = val(PARAM(4))
    [M:MWIL]OPEUOM     = PARAM(5)
##Endif

# Load Header Screen
Read [MFO]MFO0 = [M:MWIL]VCRNUM;[M:MWIL]OPENUM;[M:MWIL]OPESPLNUM
If !fstat 
    [M:MWIL]=[F:MFO]
Endif
    ## > lire la gamme pour un suivi sur gamme (?)
Read [MWS]WST0=[M:MWIL]EXTWST;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYP=[F:MWS]WSTTYP
Endif

Read [MWS]WST0=[M:MWIL]EXTLAB;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYPL=[F:MWS]WSTTYP
Endif
# reprendre tps prévu ...EXT car MWIL n'a que les zones "STDSETTIM" et "STDOPETIM"
If [M:MWIL]STDSETTIM = 0 & [M:MWIL]STDOPETIM = 0
   [M:MWIL]STDSETTIM = [F:MFO]EXTSETTIM
   [M:MWIL]STDOPETIM = [F:MFO]EXTOPETIM
Endif

# Load Labor Detail
I = 0
J = 0
For  [MWI]MWI3 Where VCRTYP = [M:MWIL]VCRTYP & VCRNUM=[M:MWIL]VCRNUM & OPENUM=[M:MWIL]OPENUM & 
&    OPESPLNUM=[M:MWIL]OPESPLNUM &
&    STU=[M:MWIL]OPEUOM & (TXNTYP=2 | TXNTYP=6)  ##PAS d'UNITE en SUIVI DIVERS !!
    If [F:MWI]TXNTYP = 2
        [M:MWIO]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWIO]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWIO]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWIO]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWIO]WST(I)       = [F:MWI]WST
        [M:MWIO]CSTTYP(I)    = [F:MWI]CSTTYP
        [M:MWIO]CPLSETTIM(I) = [F:MWI]CPLSETTIM
        [M:MWIO]SETRAT(I)    = [F:MWI]SETRAT
        [M:MWIO]CSTELM0(I)   = [F:MWI]CSTELM(0)
        [M:MWIO]CPLOPETIM(I) = [F:MWI]CPLOPETIM
        [M:MWIO]OPERAT(I)    = [F:MWI]OPERAT
        [M:MWIO]CSTELM1(I)   = [F:MWI]CSTELM(1)
        [M:MWIO]QTY(I)       = [F:MWI]QTY
        [M:MWIO]REJQTY(I)    = [F:MWI]REJQTY
        [M:MWIO]STU(I)       = [F:MWI]STU
        [M:MWIO]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWIO]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWIO]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWIO]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWIO]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWIL]TOTSETTIM += [F:MWI]CPLSETTIM
        [M:MWIL]TOTOPETIM += [F:MWI]CPLOPETIM
        [M:MWIL]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWIL]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWIL]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif [F:MWI]TXNTYP = 6
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT
        [M:MWOH]WST(J)       = [F:MWI]WST
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Endif
Next
[M:MWIO]NBLIG = I
[M:MWOH]NBLIG = J

Affzo [M:MWIL]
Affzo [M:MWIO]
Affzo [M:MWOH]

Return

#####################################################################
#  XFUNXWO - Machine Cost detail Inquiry
#            Called from WIP Cost / Machine Screen - MWI6
#####################################################################
$LOAD_SCREEN_O
Local Integer I, J

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif
If !clalev([F:MFO]) : Local File MFGOPE      [MFO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO  [MWS] : Endif

Raz [M:MWIL], [M:MWIO], [M:MWOH]

##If PARAM(1) <> "" & val(PARAM(2)) > 0 & val(PARAM(3)) >= 0 ## & PARAM(4) <> ""
    [M:MWIL]VCRTYP     = val(PARAM(1))
    [M:MWIL]VCRNUM     = PARAM(2)
    [M:MWIL]OPENUM     = val(PARAM(3))
    [M:MWIL]OPESPLNUM  = val(PARAM(4))
    [M:MWIL]OPEUOM     = PARAM(5)
##Endif  # les suivis divers n'ont pas de n° d'opérations !

# Load Header Screen
Read [MFO]MFO0 = [M:MWIL]VCRNUM;[M:MWIL]OPENUM;[M:MWIL]OPESPLNUM
If !fstat 
    [M:MWIL]=[F:MFO]
Endif

Read [MWS]WST0=[M:MWIL]EXTWST;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYP=[F:MWS]WSTTYP
Endif

Read [MWS]WST0=[M:MWIL]EXTLAB;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYPL=[F:MWS]WSTTYP
Endif
# reprendre tps prévu ...EXT car MWIL n'a que les zones "STDSETTIM" et "STDOPETIM"
If [M:MWIL]STDSETTIM = 0 & [M:MWIL]STDOPETIM = 0
   [M:MWIL]STDSETTIM = [F:MFO]EXTSETTIM
   [M:MWIL]STDOPETIM = [F:MFO]EXTOPETIM
Endif

# Load Machine Detail
I = 0
J = 0
For  [MWI]MWI3 Where VCRTYP=[M:MWIL]VCRTYP & VCRNUM=[M:MWIL]VCRNUM & OPENUM=[M:MWIL]OPENUM & 
&    OPESPLNUM=[M:MWIL]OPESPLNUM &
&    STU=[M:MWIL]OPEUOM & (TXNTYP=3 | TXNTYP=7)  ## PAS D'UNITE en SUIVI DIVERS !
    If [F:MWI]TXNTYP = 3
        [M:MWIO]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWIO]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWIO]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWIO]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWIO]WST(I)       = [F:MWI]WST
        [M:MWIO]CSTTYP(I)    = [F:MWI]CSTTYP
        [M:MWIO]CPLSETTIM(I) = [F:MWI]CPLSETTIM
        [M:MWIO]SETRAT(I)    = [F:MWI]SETRAT
        [M:MWIO]CSTELM0(I)   = [F:MWI]CSTELM(0)
        [M:MWIO]CPLOPETIM(I) = [F:MWI]CPLOPETIM
        [M:MWIO]OPERAT(I)    = [F:MWI]OPERAT
        [M:MWIO]CSTELM1(I)   = [F:MWI]CSTELM(1)
        [M:MWIO]QTY(I)       = [F:MWI]QTY
        [M:MWIO]REJQTY(I)    = [F:MWI]REJQTY
        [M:MWIO]STU(I)       = [F:MWI]STU
        [M:MWIO]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWIO]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWIO]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWIO]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWIO]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWIL]TOTSETTIM += [F:MWI]CPLSETTIM
        [M:MWIL]TOTOPETIM += [F:MWI]CPLOPETIM
        [M:MWIL]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWIL]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWIL]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif [F:MWI]TXNTYP = 7
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT
        [M:MWOH]WST(J)       = [F:MWI]WST
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Endif
Next
[M:MWIO]NBLIG = I
[M:MWOH]NBLIG = J

Affzo [M:MWIL]
Affzo [M:MWIO]
Affzo [M:MWOH]

Return

#####################################################################
#  XFUNXWS - Subcontracting Cost detail Inquiry
#            Called from WIP Cost / Subcontracting Screen - MWI7
#####################################################################
$LOAD_SCREEN_S
Local Integer I, J

Case PARAM(1)
    When "10" : Gosub ORI_MFG
    When "36" : Gosub ORI_SCO
Endcase
Return

$ORI_MFG
Raz [M:MWIL], [M:MWSC], [M:MWOH]

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif
If !clalev([F:MFO]) : Local File MFGOPE      [MFO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO  [MWS] : Endif

If val(PARAM(3)) > 0 & val(PARAM(4)) >= 0 & PARAM(5) <> ""
    [M:MWIL]VCRTYP     = val(PARAM(1))
    [M:MWIL]VCRNUM     = PARAM(2)
    [M:MWIL]OPENUM     = val(PARAM(3))
    [M:MWIL]OPESPLNUM  = val(PARAM(4))
    [M:MWIL]OPEUOM     = PARAM(5)
Endif

# Load Header Screen
Read [MFO]MFO0 = [M:MWIL]VCRNUM;[M:MWIL]OPENUM;[M:MWIL]OPESPLNUM
If !fstat 
    [M:MWIL]=[F:MFO]
Endif

Read [MWS]WST0=[M:MWIL]EXTWST;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYP=[F:MWS]WSTTYP
Endif

Read [MWS]WST0=[M:MWIL]EXTLAB;[F:MFO]MFGFCY
If !fstat 
  [M:MWIL]WSTTYPL=[F:MWS]WSTTYP
Endif

# reprendre tps prévu ...EXT car MWIL n'a que les zones "STDSETTIM" et "STDOPETIM"
If [M:MWIL]STDSETTIM = 0 & [M:MWIL]STDOPETIM = 0
   [M:MWIL]STDSETTIM = [F:MFO]EXTSETTIM
   [M:MWIL]STDOPETIM = [F:MFO]EXTOPETIM
Endif

# Load Subcontracting Detail
I = 0
J = 0
For  [MWI]MWI3 Where VCRTYP=[M:MWIL]VCRTYP & VCRNUM=[M:MWIL]VCRNUM & OPENUM=[M:MWIL]OPENUM & 
&    OPESPLNUM=[M:MWIL]OPESPLNUM &
&    STU=[M:MWIL]OPEUOM & (TXNTYP=4 | TXNTYP=8)
    If [F:MWI]TXNTYP = 4
        [M:MWSC]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWSC]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWSC]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWSC]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWSC]WST(I)       = [F:MWI]WST
        [M:MWSC]CSTELM3(I)   = [F:MWI]CSTELM(3)
        [M:MWSC]CSTTYP(I)    = [F:MWI]CSTTYP
        [M:MWSC]CPLSETTIM(I) = [F:MWI]CPLSETTIM
        [M:MWSC]SETRAT(I)    = [F:MWI]SETRAT
        [M:MWSC]CSTELM0(I)   = [F:MWI]CSTELM(0)
        [M:MWSC]CPLOPETIM(I) = [F:MWI]CPLOPETIM
        [M:MWSC]OPERAT(I)    = [F:MWI]OPERAT
        [M:MWSC]CSTELM1(I)   = [F:MWI]CSTELM(1)
        [M:MWSC]QTY(I)       = [F:MWI]QTY
        [M:MWSC]REJQTY(I)    = [F:MWI]REJQTY
        [M:MWSC]STU(I)       = [F:MWI]STU
        [M:MWSC]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWSC]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWSC]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWSC]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWSC]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWIL]TOTSETTIM += [F:MWI]CPLSETTIM
        [M:MWIL]TOTOPETIM += [F:MWI]CPLOPETIM
        [M:MWIL]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWIL]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWIL]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif [F:MWI]TXNTYP = 8
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT
        [M:MWOH]WST(J)       = [F:MWI]WST
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Endif
Next
[M:MWSC]NBLIG = I
[M:MWOH]NBLIG = J

Affzo [M:MWIL]
Affzo [M:MWSC]
Affzo [M:MWOH]

Return

$ORI_SCO
Raz [M:MWIS], [M:MWSV], [M:MWOH]

# Open tables if need to
If !clalev([F:MWI]) : Local File WIPCOST     [MWI] : Endif
If !clalev([F:SCS]) : Local File SCOSRV      [SCS] : Endif

If val(PARAM(3)) > 0 & val(PARAM(4)) >= 0
    [M:MWIS]VCRTYP     = val(PARAM(1))
    [M:MWIS]VCRNUM     = PARAM(2)
    [M:MWIS]SCILIN     = val(PARAM(3))
    [M:MWIS]SCSLIN     = val(PARAM(4))
Endif

# Load Header Screen
Read [SCS]SCS0=[M:MWIS]VCRNUM;[M:MWIS]SCILIN;[M:MWIS]SCSLIN
[M:MWIS] = [F:SCS]


# Load Subcontracting Detail
I = 0
J = 0
For  [MWI]MWI3 Where VCRTYP=[M:MWIS]VCRTYP & VCRNUM=[M:MWIS]VCRNUM & VCRLIN=[M:MWIS]SCILIN
&                  & BOMSEQ=[F:SCS]BOMSEQ & (TXNTYP=4 | TXNTYP=8)
    If [F:MWI]TXNTYP = 4
        [M:MWSV]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWSV]TXNDAT(I)    = [F:MWI]TXNDAT
        [M:MWSV]TXNACT(I)    = [F:MWI]TXNACT
        [M:MWSV]AMOUNT(I)    = [F:MWI]AMOUNT
        [M:MWSV]QTY(I)       = [F:MWI]QTY
        [M:MWSV]REJQTY(I)    = [F:MWI]REJQTY
        [M:MWSV]STU(I)       = [F:MWI]STU
        [M:MWSV]MFGTRKNUM(I) = [F:MWI]MFGTRKNUM
        [M:MWSV]GLPSTA(I)    = [F:MWI]GLPSTA
        [M:MWSV]JOUTYP(I)    = [F:MWI]JOUTYP
        [M:MWSV]JOUNUM(I)    = [F:MWI]JOUNUM
        [M:MWSV]MFGFCY(I)    = [F:MWI]MFGFCY

        [M:MWIS]TOTAMT += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:MWIS]TOTPOSTED += [F:MWI]AMOUNT
        Else
            [M:MWIS]TOTNOTPST += [F:MWI]AMOUNT
        Endif
        I += 1
    Elsif [F:MWI]TXNTYP = 8
        [M:MWOH]VCRNUM(J)    = [F:MWI]VCRNUM
        [M:MWOH]TXNDAT(J)    = [F:MWI]TXNDAT
        [M:MWOH]TXNACT(J)    = [F:MWI]TXNACT
        [M:MWOH]AMOUNT(J)    = [F:MWI]AMOUNT
        [M:MWOH]OVENAT(J)    = [F:MWI]OVENAT
        [M:MWOH]MFGTRKNUM(J) = [F:MWI]MFGTRKNUM
        [M:MWOH]GLPSTA(J)    = [F:MWI]GLPSTA
        [M:MWOH]JOUTYP(J)    = [F:MWI]JOUTYP
        [M:MWOH]JOUNUM(J)    = [F:MWI]JOUNUM
        [M:MWOH]MFGFCY(J)    = [F:MWI]MFGFCY
        
        J += 1
    Endif
Next
[M:MWSV]NBLIG = I
[M:MWOH]NBLIG = J

Affzo [M:MWIS]
Affzo [M:MWSV]
Affzo [M:MWOH]

Return

##########################################################################
## Etiquette ajoutée par le superviseur 23/06/2003 10:21:59 (TB)
##########################################################################
Subprog AS_NBLIG
# remplace XFUNGASB
# sert pour les tableaux des différents écrans
If [M]JOUNUM(nolign-1) = ""
    Raz GBOUT2
    #GBOUT2 = mess(22,2361,1)
Endif
End

##########################################################################

