# Endif
 [M:EMP6]ICO = "21"
 Actzo [EMP6]ICO
 Affzo [EMP6]ICO
Endif
If REP<>"" | !VERROU
 Call VIREBOUT (CHAINE,"1") From GOBJET
 Effzo [EMP6]ICO
 Grizo [EMP6]ICO
 Affzo [EMP6]ICO
Endif


#MIPEA - 2016-10-21 - X3PEOP-907 - START
Call LIST_LEG_EML([F:ID]REFNUM, [M:EMP0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG # Get list of legislation per contract
If LISTLEG <> "" #Display legislation of each contract
  For COUNTER=1 To dim([L]LISTLEG)
    If ([L]LISTLEG(COUNTER)) = "ZAF"
      ZAFCHECK = 1
    Endif
  Next
Else
  ZAFCHECK=0
Endif

If ZAFCHECK <> 1
  Call VIREBOUT (CHAINE,"3") From GOBJET
Endif
#ADNGO - 2017-06-09 - X3-33781 - START
