#**
#* SYMEU V6.1 Module Formation - Formateur interne
#* Si le salariÚ est inactif, mise Ó jour du flag inactif pour tous les contrats du salariÚ
#* dans la table des formateurs internes
#*!
$MAJ_TRAINER_INACTIF
If clalev([F:TRN])=0 : Local File TRAINER [TRN] : Endif
Filter [F:TRN] Where REFNUM=[F:ID]REFNUM and ENAFLG=2
For [TRN]TRN1
  [F:TRN]ENAFLG=1
  Rewrite [TRN] Curr
  If fstat
   GOK = 0 : Call FSTA("TRN") From GLOCK : Break
  Endif
Next
Filter [TRN]
Return

#**
#* SYMEU V6.1 Module Formation - Formateur interne - Fiche 70023
#* Si le salariÚ est actif, mise Ó jour du flag actif pour tous les contrats du salariÚ
#* dans la table des formateurs internes, si l'utilisateur le souhaite
#*!
$MAJ_TRAINER_ACTIF
Local Integer L_OK
If clalev([F:TRN])=0 : Local File TRAINER [TRN] : Endif

Filter [F:TRN] Where REFNUM=[F:ID]REFNUM and ENAFLG=1
L_OK = 1
If rowcount([F:TRN]) > 0 Then
  # Ce salariÚ est aussi un formateur interne : voulez-vous rendre actif le formateur interne ?
  Call OUINON(mess(188,10717,1),L_OK) From GESECRAN
Endif

If L_OK = 2
  For [TRN]TRN1
    [F:TRN]ENAFLG=2
    Rewrite [TRN] Curr
    If fstat
     GOK = 0 : Call FSTA("TRN") From GLOCK : Break
    Endif
  Next
Endif
Filter [TRN]
Return

#**
#* SYMEU V6.1 Module Formation - Formateur interne
#* VÚrification que le salariÚ n'est pas renseignÚ en tant que formateur
#* dans les stages ou les sessions
#*!
$VERIF_STG_SES
  If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  Filter [F:STG] Where [F:STG]TCHEMP = [M:EMP0]REFNUM
  If rowcount([F:STG]) > 0 Then
    GOK = 0
  Endif
  Filter [F:STG]
  If GOK<1 Then Return Endif

  Filter [F:HRSES] Where [F:HRSES]TCHEMP = [M:EMP0]REFNUM
  If rowcount([F:HRSES]) > 0 Then
    GOK = 0
  Endif
  Filter [F:HRSES]

Return
############################################
############################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnÚs EMPSBD (ESB)
#-----------------------------------------------------------
$MAJ_ESB
Local  Integer L_K
If clalev([F:ESB]) =0 : Local File EMPSBD        [ESB]  : Endif
If clalev([F:CTR1])=0 : Local File EMPLOCTR    [CTR1] : Endif
If clalev([F:WAD]) =0 : Local File EMPLOAD     [WAD]  : Endif
#     SEGAY - 03/04/12 - FQ81387 - GÚnÚration subordonnÚs sans contrat
If ACTION="ANNULE"
  Delete [ESB] Where [F:ESB]REFNUM=[F:ID]REFNUM
  If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[F:ID]REFNUM -[F:ESB]CTRNUM-[F:ESB]CTRDAT-num$(2)-num$([F:ESB]RANG)
   Return
  Endif
  Return
Endif
#END - FQ81387 - GÚnÚration subordonnÚs sans contrat

Delete [ESB] Where [F:ESB]REFNUM=[F:ID]REFNUM & [F:ESB]NIVEAU=2
If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[F:CTR1]REFNUM-[F:ESB]CTRNUM-[F:ESB]CTRDAT-num$(2)-num$([F:ESB]RANG)
Endif

If !GOK  Then Return Endif
Read [F:WAD] AD0=[F:ID]REFNUM
If !fstat
  Filter [F:CTR1] Where REFNUM=[F:ID]REFNUM
  If rowcount([F:CTR1]) > 0 Then
    For [F:CTR1]CTR1
      For L_K=0 To len(mess(0,50,1))
          If [F:WAD]CHEF(L_K)<> ""
              Raz [F:ESB]
              [F:ESB]CTRNUM=[F:CTR1]CTRNUM
              [F:ESB]CTRDAT=[F:CTR1]CTRDAT
              [F:ESB]CHEF=[F:WAD]CHEF(L_K)
              [F:ESB]NIVEAU=2
              [F:ESB]RANG=L_K+1
              Gosub WRITE_ESB
              If !GOK : Break 2 : Endif
          Endif
      Next L_K
    Next
  Else
    For L_K=0 To len(mess(0,50,1))
        If [F:WAD]CHEF(L_K)<> ""
            Raz [F:ESB]
            [F:ESB]CHEF=[F:WAD]CHEF(L_K)
            [F:ESB]NIVEAU=2
            [F:ESB]RANG=L_K+1
            Gosub WRITE_ESB
            If !GOK : Break 2 : Endif
        Endif
    Next L_K
  Endif
Endif

Return

#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnÚs EMPSBD (ESB)
#-----------------------------------------------------------
$WRITE_ESB
  [F:ESB]REFNUM=[F:ID]REFNUM
  If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
  If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
  If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
  Write [F:ESB]
  If fstat
      GOK = 0 : Call FSTA("ESB") From GLOCK : Return
  Endif
Return
#END SEGAY 01/07/11 DEM 71093


# FQ81085 US525 - SEGAY 05/07/12
$MAJ_CIVCTR
# Updated Civility of Employee. The Civility is changed in the contracts
  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  Filter [F:ILEG] Where REFNUM=[F:ID]REFNUM & [F:ILEG]LEGID = [M:EMP0]LEGORI
&  & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)
#&  & [F:ILEG]CTRDAT<=date$ & ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=date$)

  For [F:ILEG] Where REFNUM=[F:ID]REFNUM
    Read [HRCTR]CTR0 = [F:ILEG]REFNUM;[F:ILEG]CTRNUM;[F:ILEG]CTRDAT
    If !fstat
        [F:HRCTR]CIVCTR=[F:ID]CIV
        Rewrite [HRCTR]
        If fstat
         GOK = 0 : Call FSTA("HRCTR") From GLOCK : Break
        Endif
    Endif
  Next
  Filter [F:ILEG]
Return

# FQ81085 US1554 - 13/05/13
$MAJ_NUMSSC
Local Char IDCRYFCY(GLONFCY)

  IDCRYFCY=func TRTDIV.LECPAYSIT([F:ID]FCYORI)
  # If the NUMSSC is changed in GESEML, it must be changed in the contracts which are in the same country
  For [F:HRCTR] Where REFNUM=[F:ID]REFNUM
    CRYFCY=func TRTDIV.LECPAYSIT([F:HRCTR]ETRFCY)
    If IDCRYFCY=CRYFCY Then
      [F:HRCTR]NUMSSCCTR  = [F:ID]NUMSSC
      [F:HRCTR]NUMSSCCTR2 = [F:ID]NUMSSC2
      Rewrite [F:HRCTR]
      If fstat
        GOK = 0 : Call FSTA("HRCTR") From GLOCK : Break
      Endif
    Endif
  Next
Return

#**
#* Affichage BULDEM
#*
#* @param Matricule
#* @param Contrat
#* @param DAT
#* valeur retour :
#*    0 : non accessible
#*    1 : au moins 1 contrat non actif autorisant le bulletin dÚmatÚrialisÚ
#*    2 : au moins 1 contrat actif autorisant le bulletin dÚmatÚrialisÚ
#* #SBA : FQ88174-US2217
#*!
Funprog DISP_BULDEM(MATRICULE,CONTRAT,CTRDATE)
Value Char MATRICULE()
Value Char CONTRAT()
Value Date CTRDATE

Local Integer RES
Local Char WRES(2)
Local Char WFILTER(250)
If [L]MATRICULE<>""
  [L]WFILTER="REFNUM=[L]MATRICULE"
  If [L]CONTRAT<>""
    [L]WFILTER-="& CTRNUM=[L]CONTRAT"
    If([L]CTRDATE<>[0/0/0])
      [L]WFILTER-="& CTRDAT=[L]CTRDATE"
    Endif
  Endif
  If clalev([F:CTRW])=0 : Local File EMPLOCTR [CTRW] : Endif

  Filter [CTRW]  Where evalue([L]WFILTER)
  For [CTRW]CTR0
    Call PARAM([F:CTRW]ETRFCY,"BULDEM",[L]WRES) From ADOVAL
    If(WRES="2")
      If([F:CTRW]XITDAT=[0/0/0] or [F:CTRW]XITDAT>=date$)
        [L]RES=2
        Break
      Else
        [L]RES=1
      Endif
    Endif
  Next
Endif

End RES

#**
#* Affichage BULDEM
#* Shortcut use in workflow BULDEMREL
#* @param Matricule
#* valeur retour :
#*    0 : non accessible
#*    1 : au moins 1 contrat non actif autorisant le bulletin dÚmatÚrialisÚ
#*    2 : au moins 1 contrat actif autorisant le bulletin dÚmatÚrialisÚ
#* #SBA : FQ88174-US2217
#*!
Funprog SEND_BULDEM(MATRICULE)
Value Char MATRICULE()
Local Integer RES
RES=func DISP_BULDEM(MATRICULE,"",[0/0/0])
End RES


#-----------------------------------------------------------

#**
#* valeur champ BULDEM
#*
#* @param Matricule
#*
#* #SBA : FQ88174-US2217
#*!
Funprog GETVAL_BULDEM(MATRICULE)
Value Char MATRICULE()

Local Integer RES :RES=1

If [L]MATRICULE<>""

  If clalev([F:IDW])=0 : Local File EMPLOID [IDW] : Endif
  Read [IDW]ID0=[L]MATRICULE
  If(!fstat)
     RES=[F:IDW]FLGBULDEM
  Endif

Endif

End RES

#-----------------------------------------------------------
$REINI_FLGBULDEM

ZONE = "FLGBULDEM" : Gosub SET_ZONE From SUBEML2
If MA Then
    [M]FLGBULDEM=1
    Grizo [M]FLGBULDEM
    Affzo [M]FLGBULDEM
Endif

Return

$FIN_MOD
Local Char    GRPDEB(GLONVCR)

   If dim(GOLDBULDEM)>0 Then
      If GOLDBULDEM<>[F:ID]FLGBULDEM Then
        Call WORKPLUS(1,"DIV","","","BULDEM",0,0,0,GRPDEB) From AWRK
      Endif
    Kill GOLDBULDEM
  Endif
Return

Funprog IS_LEG(LEG)
Value    Char LEG
Local Integer RES
Local Char  LISTLEG(1)(1..99)
Local Integer COUNTER
Local Char    WCRIT(250)
Local Integer WNBLEG
Local Integer COUNTER
Local Integer WNBLEG
WFLDLEG=GCURLEG
RES=0

Call LIST_LEG_EML([F:ID]REFNUM, [M:EMP0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG # Get list of legislation per contract

If LISTLEG <> ""
  For COUNTER=1 To dim([L]LISTLEG)
    If ([L]LISTLEG(COUNTER)) <> ""
        If [L]LISTLEG(COUNTER) = LEG
           RES= 1
        Endif
    Endif
  Next
Endif

If GCURLEG = LEG
  RES= 1
Endif

End RES


Subprog GET_LEG_CONTRACT(LISTLEG)

Variable Char LISTLEG()(1..99)

Local Char    WCRIT(250)
Local Integer WNBLEG
Local Integer COUNTER

Call LIST_LEG_EML([F:ID]REFNUM, [M:EMP0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG # Get list of legislation per contract

End

$WRITE_EMPLOIDESS

If clalev([F:IDES])=0  : Local File EMPLOIDESS     [IDES]  : Endif

Read [IDES]IDES0 = [M:EMP0]REFNUM
If fstat
  Raz [IDES]
  [F:IDES]REFNUM  = [M:EMP0]REFNUM
  [F:IDES]NAM     = [M:EMP0]NAM
  [F:IDES]SRN     = [M:EMP0]SRN
  [F:IDES]PSD     = [M:EMP0]PSD
  [F:IDES]DATBRN  = [M:EMP2]DATBRN
  [F:IDES]ENAFLG  = [M:EMP0]ENAFLG
  Write [F:IDES]
Else
  [F:IDES]REFNUM  = [M:EMP0]REFNUM
  [F:IDES]NAM     = [M:EMP0]NAM
  [F:IDES]SRN     = [M:EMP0]SRN
  [F:IDES]PSD     = [M:EMP0]PSD
  [F:IDES]DATBRN  = [M:EMP2]DATBRN
  [F:IDES]ENAFLG  = [M:EMP0]ENAFLG
  Rewrite [F:IDES]
  If fstat
    GOK = 0 : Call FSTA("IDES") From GLOCK : Return
  Endif
Endif

Return

