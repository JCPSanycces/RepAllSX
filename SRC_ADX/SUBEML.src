Return

# FQ80379 - MABON 12/06/12 - Gestion des utilisateurs pour obtenir liste des users dont REFNUM=<matricule>
$AVANTBOUT


  If BOUT="6" Then
    Local Char VALBOUT(250) , PARBOUT(250)(1..20)
    PARBOUT(2) = "AUS"
    FLGEXE = 1
    GACTION = "GOBJET"
#    If GUSER='MABON' Dbgaff Endif
    If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
    Filter [F:ADU] Where PARAM='REFNUM' & VALEUR=[M:EMP0]REFNUM Order By CODUSR
    If rowcount([F:ADU])>0 Then
      Read [F:ADU] First
      Filter [F:ADU]
      PARBOUT(1) = [F:ADU]CODUSR
      Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),"") From GOBJET
    Else
      # FQ90355 - 18/06/13 - On propose d'en crÚer un s'il n'y en a pas
#      Infbox mess(215,10703,1) : # Aucun utilisateur n'a ÚtÚ dÚfini pour ce matricule
      Local Integer OK
      Filter [F:HRCTR] Where REFNUM=[M:EMP0]REFNUM
      If rowcount([F:HRCTR])>0 Then
        # Aucun utilisateur n'a ÚtÚ dÚfini pour ce matricule
        # Voulez-vous en crÚer un ?
        Call OUINON(mess(215,10703,1)+chr$(10)+mess(218,10703,1), OK) From GESECRAN
        If OK=2 Then
          Filter [F:ADU]
          GACTION = "CREUSR"
          Call TRAITE_CHAR(VALBOUT,PARBOUT,"CREUSR2","CREUSR","CREUSR",4,"XYCREUSR") From GTRAITE
        Endif
      Else
        Infbox mess(215,10703,1) : # Aucun utilisateur n'a ÚtÚ dÚfini pour ce matricule
      Endif
      Filter [F:HRCTR]
      # Fin FQ90355
    Endif
    Filter [F:ADU]
    Gosub LIENS
  Endif
Return
# Fin MABON


