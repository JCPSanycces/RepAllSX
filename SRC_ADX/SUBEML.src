$APRES_MODIF
Case COUZON
 When "EMPPIC"
  #Gestion de la photo du salariÚ par un blob
  If !VERROU & REP<>"C"
   [M]EMPPIC = [M]SAVEMPPIC
  Else
   [M]SAVEMPPIC = [M]EMPPIC
   PHOTO = 1
  Endif
 When "ICO"
 # Ic¶ne pour visualiser les contrats
 Gosub RELIT_CTR
  For I=1 To NBTBL
  If evalue("dim([M:EMP"+MSKTAB(I)+"]NBRPOP)")>0
    MA = find("EMP"+MSKTAB(I),ABMSK(1..NBMASK))
    Gosub SETMASK From =WINPROG
    Raz [M]NBRPOP, POP, ZPOP
    #88588
    Gosub FILL_POP
    Affzo [M]NBRPOP,POP,ZPOP
  Endif
 Next

 Gosub LECTURE From GOBJSUB
 OK=-1 : SUIZON="ICO" : # Pour ne pas passer en Modif et dÚgriser Enregistrer/Abandon


 When "FLGBULDEM" : # SBA  2216-88174
  ZONE = "FLGBULDEM" : Gosub SET_ZONE From SUBEML2
  If MA Then
    If dim(GOLDBULDEM)<0 Then Global Integer GOLDBULDEM : Endif
    GOLDBULDEM=[M]FLGBULDEM
  Endif
Endcase

Return

$FILL_POP
nolign = 1
Filter [HRPOA] Where REFNUM=[F:ID]REFNUM & TYP=0 & COD<>""
For [HRPOA]POA1
 If nolign>[L]POPMAX : Break : Endif
 [M]POP(nolign-1) = [F:HRPOA]COD
 nolign += 1
Next
If rowcount([HRPOA])>[L]POPMAX & !MESPOPMAX
 GMESSAGE= mess(216,703,1)
 MESPOPMAX=1
Endif
Filter [HRPOA]
[M]NBRPOP = nolign-1
Return

$RELIT_CTR
OK = 0
For nolign=1 To [M]NBRCTR
 If [M]CTRNUM(nolign-1)=[F:HRCTR]CTRNUM & [M]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT
  OK = 1 : Break
 Endif
Next
Look [HRCTR]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
If fstat | OK=0
 # Le contrat a ÚtÚ supprimÚ ou crÚe
 Raz [M]
 Filter [HRCTR] Where REFNUM=[M]REFNUM
 nolign = 0
 For [HRCTR]CTR1
  nolign += 1
  [M] = [F:HRCTR]
 Next
 Filter [HRCTR]
 [M]NBRCTR = nolign
 TABLE = "EMPLOCTR"
 ACT = "AFFICHE" : Gosub ACT
Else
 # On rÚaffiche les donnÚes du contrat car il peut avoir ÚtÚ modifiÚ
 [M] = [F:HRCTR]
 If [F:HRCTR]XITDAT=[0/0/0]
  Chgstl [M]CTRNUM(nolign-1),CTRDAT(nolign-1) With "CONTRAT"
 Else
  Chgstl [M]CTRNUM(nolign-1),CTRDAT(nolign-1) With ""
 Endif
 Affzo [M]CTRNUM(nolign-1),CTRDAT(nolign-1)
 Affzo [M]
Endif
Return

