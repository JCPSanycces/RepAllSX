$AFF_MATRI
## Affectation du no de matricule
If [F:ID]REFNUM=""
  TYP_CPT=1               : #counter associate to refnum =1
  W_SIT=[M:EMP0]FCYORI
  W_CRITCOMP=""
  W_DATCPT=datesyst
  If [M:EMP0]FCYORI=""
    # Keep the same process than V6 I'm not sure we can have FCYORI empty
    Call SAVE_CTX From TOOLSHRTCA
    Gosub CONVERT_TO_SAL From TOOLSHRTCA
    Call GET_PARCPT(W_MODULE, W_SIT, W_POS, W_CPTNAME, W_CPTMAN,W_STAT)From TOOLSHRTCA
    Call RESTORE_CTX From TOOLSHRTCA
    If W_STAT
      # Compteur composÚ de la sociÚtÚ ou du site
      If find (6,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1)) | find (7,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
        #Zone site initial obligatoire pour l'affectation automatique d'un matricule
        GMESSAGE = mess(88,10701,1)
        SUIZON="[M:EMP0]FCYORI"
        GOK = 0 : Return
      Endif
    Endif : # else will be in the next part of code
  Endif

  Gosub GET_COUNTER_SAL From TOOLSHRTCA
  If !GOK : Return : Endif
  [F:ID]REFNUM=W_VALUECPT

 #  COMPTEUR= [F:TCA]CODNUM(2)

  [M:EMP0]REFNUM = [F:ID]REFNUM
 Affzo [EMP0]REFNUM
Endif
Return

