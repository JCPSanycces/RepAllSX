    Local Integer BROWMAT, BROWMAT2, BROWMAT3
    Local Char    BOXMAT(10), BOXMAT2(10), BOXMAT3(10)
    Local Char    OBJLIS(GLONAOB)(0..10)
    Local Char    ETIQ(10)
    Local Integer PHOTO
    Local Integer AUTO
    Local Integer DEBUT
    Local Char    CRITCTR(250) # FQ81085 US524 - SEGAY 05/07/12
    Local Char  CRITERE(250)(1..6)
    #88588
    Local Integer POPMAX :#Maximum of population allowed for an employee.
    Local Integer MESPOPMAX :#Message about number maximum of population for an employee displayed.
    #91274
    #POPMAX=50
    POPMAX=func AFNC.ACTIV('NBPOP')
    MESPOPMAX=0

    # SBA US4302_111201 common code with SUBHRENT
    Gosub SET_VAR_COUNTER_SAL From TOOLSHRTCA

    DEBUT=1

    Gosub OUVRE From WPDEFTABLE
    Gosub OUVRE_POPUL # MABOS-25/02/13-FQ 81085-US1335-synchronize the populations
    If clalev([F:TCY])=0   : Local File TABCOUNTRY [TCY]         : Endif
    If clalev([F:HRPOP])=0 : Local File POPUL    [HRPOP]         : Endif
    If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA]         : Endif
    If clalev([F:POB])=0 : Local File POPULB   [POB]         : Endif
    If clalev([F:FCY])=0 : Local File FACILITY [FCY]         : Endif
    If clalev([F:CPY])=0 : Local File COMPANY  [CPY]         : Endif
    If clalev([F:CCE])=0 : Local File =GTABCPT+"CACCE" [CCE] : Endif
    If clalev([F:DSP])=0 : Local File =GTABCPT+"CADSP" [DSP] : Endif
    If clalev([F:ADI])=0 : Local File ATABDIV  [ADI]         : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX]         : Endif
    #** V7 : Waiting several modules **#
    #**If clalev([F:PLN])=0 : Local File PLANTYP  [PLN]         : Endif
    #**
    If clalev([F:ACV])=0 : Local File ACTIV    [ACV]         : Endif
    If GPAYE
     If clalev([F:VRA])=0 : Local File VARIA    [VRA]        : Endif
     If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB]        : Endif
    Endif

    If clalev([F:BBB])=0  : Local File BBLOB     [BBB]  : Endif

    ###66085
    If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif
    If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif

    If clalev([F:HRMDP])=0  : Local File HRMEDAPT [HRMDP]  : Endif
    If clalev([F:HRMDT])=0  : Local File HRMEDTYP [HRMDT]  : Endif

    # MABON 21/09/12 - Ouverture de la table des codes comptables, obligatoire pour contr¶le du code
    If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif

    # FQ81085 US524 - SEGAY 05/07/12 LEG
    If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

    PROGOBJ = "WOEML"
    PROGSTD = "SUBEML2"

    #47941
    #WINPROG = "WGOEML"
    If WINPROG="" : WINPROG = "WGOEML" : Endif
    #
    PROGSPE = "SPEEML2"
    #50328
    PROGSPV = "SPVEML2"

    #43742
    #BROWMAT = find("EM2",OBJLIS(1..dim(OBJLIS)-1))
    #BOXMAT  = "GAU_CHE"+num$(BROWMAT)
    #
    Gosub DEFPOP From SUBPOP

    Call EXISTE_ADX("","","SPEEML2",FLSPE) From ORDSYS
    #50328
    Call EXISTE_ADX("","","SPVEML2",FLSPV) From ORDSYS

    ##################################################################################
    ## Description des tables utilisÚes
    ##################################################################################
    ## TYPTABLE = 1  => 1 ligne par salariÚ,  clÚ unique REFNUM
    ## TYPTABLE = 2  => n lignes par salariÚ, clÚ unique REFNUM+NUMLIG
    ## TYPTABLE = 0  => cas particulier gÚrÚ Ó part
    ##################################################################################
    NBTBL = 0
    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOAD"   : TYPTABLE(NBTBL) = 1
    # FRRIC - 44459 - Gestion historisÚe de l'handicap
    MSKTAB(NBTBL) = "3" : BASTAB(NBTBL) = "NBHDC"
    #END 44459

    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOCPT"  : TYPTABLE(NBTBL) = 1
    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOCHD"  : TYPTABLE(NBTBL) = 2
    MSKTAB(NBTBL) = "2" : BASTAB(NBTBL) = "NBRCHD" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"

    # V7 : Waiting Update Accounting **#
    #JOJAC - 2017-01-23 - START
    Read [ACV]CODACT="NOF"
    If !fstat & [F:ACV]FLACT=2
    #JOJAC - 2017-01-23 - START
     NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOEXN"  : TYPTABLE(NBTBL) = 2
     MSKTAB(NBTBL) = "E" : BASTAB(NBTBL) = "NBREXN" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"
    #JOJAC - 2017-01-23 - START
    Endif
    #JOJAC - 2017-01-23 - END

    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOHAB"  : TYPTABLE(NBTBL) = 2
    #MABOS-FQ74502-US1642-10/06/13
#  MSKTAB(NBTBL) = "3" : BASTAB(NBTBL) = "NBRHAB" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"
   MSKTAB(NBTBL) = "4" : BASTAB(NBTBL) = "NBRHAB" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"

    If GPAYE=1
     NBTBL += 1 : TBTABLE(NBTBL) = "EMPLORIB"  : TYPTABLE(NBTBL) = 2
     MSKTAB(NBTBL) = "7" : BASTAB(NBTBL) = "NBRRIB" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"
    Endif
    #72680
    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOMED"  : TYPTABLE(NBTBL) = 2
    MSKTAB(NBTBL) = "A" : BASTAB(NBTBL) = "NBRVIS" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"

    Read [ACV]CODACT="PAR"
    If !fstat & [F:ACV]FLACT=2
     NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOPAR"  : TYPTABLE(NBTBL) = 2
     MSKTAB(NBTBL) = "C" : BASTAB(NBTBL) = "NBRPAR" : ADDFLG(NBTBL) = "FLGADD" : MODFLG(NBTBL) = "FLGMOD"
    Endif

    NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOCTR"   : TYPTABLE(NBTBL) = 0
    MSKTAB(NBTBL) = "6" : BASTAB(NBTBL) = "NBRCTR"

    Read [ACV]CODACT="NCA"
    If !fstat & [F:ACV]FLACT=2
     NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOEXM"  : TYPTABLE(NBTBL) = 2
     MSKTAB(NBTBL) = "9" : BASTAB(NBTBL) = "NBREXM" : ADDFLG(NBTBL) = "FLGADD1" : MODFLG(NBTBL) = "FLGMOD1"
     NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOTRY"  : TYPTABLE(NBTBL) = 2
     MSKTAB(NBTBL) = "9" : BASTAB(NBTBL) = "NBRTRY" : ADDFLG(NBTBL) = "FLGADD2" : MODFLG(NBTBL) = "FLGMOD2"
    Endif
    For I=1 To NBTBL
     If TBABREV(I)=""
      TBABREV(I) = right$(TBTABLE(I),6)
     Endif
    Next I

    #FQ 81085-US 917- - remove population block  in HRMAT10
    #Cas particulier Population
    NBTBL += 1 : TBTABLE(NBTBL) = "POPUL"  : TYPTABLE(NBTBL) = 0
    MSKTAB(NBTBL) = "A" : BASTAB(NBTBL) = "NBRPOP"
    # END - MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10

      # Flip - 28/10/13
