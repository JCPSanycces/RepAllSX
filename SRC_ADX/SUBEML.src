   Assign "[M]FDSPAR"+num$(J-1) +"("+num$(nolign-1)+")" With [F]FDSPAR(J-1)
   Assign "[M]FDSPARPRC"+num$(J-1) +"("+num$(nolign-1)+")" With [F]FDSPARPRC(J-1)
  Next
  For J=1 To [F]NBRFDSITS
   Assign "[M]FDSITS"+num$(J-1) +"("+num$(nolign-1)+")" With [F]FDSITS(J-1)
