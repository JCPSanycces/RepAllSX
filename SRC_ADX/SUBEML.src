 Case TBTABLE(I)
  When "EMPLOSAL", "EMPLOEXN", "EMPLOCTR"
  #79255 : When "EMPLORIB","EMPLOSAL","EMPLOMED", "EMPLOEXN", "EMPLOCTR"
   MA =  find("EMP"+MSKTAB(I),ABMSK(0..NBMASK))-1
   Gosub RAZMASK From =WINPROG
   Gosub SETMASK From =WINPROG
   Affzo
 Endcase
Next I

