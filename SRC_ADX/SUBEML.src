[L]CHMEN=""
If REP="" & VERROU
 # FQ80379 - MABON 12/06/12 - Ajout 6 pour menu Utilisateur
 #ADNGO - 2017-06-09 - X3-33781 - START
 #[L]CHMEN+="2456"
 [L]CHMEN+="256"
