$CHG_BBB
GOK = 1
Trbegin [BBB],[BBB2]
 For [BBB]BBB0 Where CODBLB = "EMPPIC" & IDENT1 = OCODE With Stability
  Raz [BBB2]
  [F:BBB2]=[F:BBB]
  [F:BBB2]IDENT1=NCODE
  Write [BBB2]
  If fstat
   GOK = 0 : Call FSTA("BBB2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_BBB : Endif
 Delete [BBB] Where CODBLB = "EMPPIC" & IDENT1 = OCODE
Commit
Return

$AB_BBB
Rollback
Return

$CHG_BCB
GOK = 1
Trbegin [BCB],[BCB2]
 For [BCB]BCB0 Where IDENT2 = OCODE & find(CODBLB,"VEPTXT","VARTXT")<>0 With Stability
  Raz [F:BCB2]
  [F:BCB2]=[F:BCB]
  [F:BCB2]IDENT2=NCODE
  Write [BCB2]
  If fstat
   GOK = 0 : Call FSTA("BCB2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_BCB : Endif
 Delete [BCB] Where IDENT2 = OCODE & find(CODBLB,"VEPTXT","VARTXT")<>0
Commit
Return

$AB_BCB
Rollback
Return

