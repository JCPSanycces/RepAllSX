$MODIF



Gosub MOD_CRE From SUBEMLKSA

For I=1 To NBTBL
 TABLE =  TBTABLE(I)

 Gosub DEFAUT From WPDEFTABLE
 Case TYPTABLE(I)
  When 1
   Filter [F] Where REFNUM=[F:ID]REFNUM
   Readlock [F] First
   Filter [F]
   If fstat=1
    GOK = -1 : GLOCK = "$"+TABLE-[F:ID]REFNUM : Break
   Elsif fstat
    nolign = 1
    Gosub DECHARGE
    Gosub CREUSR
    Write
   Else
    nolign = 1
    Gosub DECHARGE
    Gosub MODUSR
    Rewrite
   Endif
   If fstat
    GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break
   Endif
  When 2
    MA = find("EMP"+MSKTAB(I),ABMSK(1..NBMASK))
      Gosub SETMASK From =WINPROG
      If evalue("[M]"+ADDFLG(I))
         Delete [F] Where REFNUM=[F:ID]REFNUM
         If fstat=1
            GOK = -1 : GLOCK = "$"+TABLE-[F:ID]REFNUM : Break
         Endif
         Gosub CREFIC
      Else
         For nolign=evalue("[M]"+BASTAB(I)) To 1 Step -1
            If evalue("[M]"+MODFLG(I)+"(nolign-1)")
               If [G]nbind=1 : # pour CHD, RIB et HAB
                  Filter [F] Where REFNUM=[F:ID]REFNUM and NUMLIG=nolign
               Elsif [L]TABLE="EMPLOEXN"
                  Filter [F] Where REFNUM=[F:ID]REFNUM and NUMLIG=nolign
               Elsif [L]TABLE="EMPLOCHD"    : # 69092
                  Filter [F] Where REFNUM=[F:ID]REFNUM and NUMLIG=nolign
               Else
                  Filter [F] Where REFNUM=[F:ID]REFNUM and NUMLIG=evalue("[M]"+BASTAB(I))-(nolign-1)
               Endif
               Readlock [F] First
               If fstat=1
                  GOK = -1 : GLOCK = "$"+TABLE-[F:ID]REFNUM-num$(nolign) : Break 2
               Elsif fstat
                  GOK = 0 : Call RSTA(TBABREV(I),[F:ID]REFNUM-num$(nolign)) From GLOCK : Break 2
               Endif
               Filter [F]
               [F] = [M]
               Gosub ECRPAR
               Gosub MODUSR
               Rewrite
               If fstat
                  GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break 2
               Endif
            Endif
         Next nolign
      Endif
 Endcase
Next I



If GOK<1 : Return : Endif
#Gosub POPUL removal of population from screen
If GOK<1 : Return : Endif
If PHOTO
