# END FQ81085 US524 - SEGAY 05/07/12 - Find the good local menu for the title, depending on the site
For I=0 To NBMASK
 If evalue ("dim([M:"+ABMSK(I)+"]EMPPIC)")>0
 # fin 43514
  Read [BBB]BBB0 = "EMPPIC";[F:ID]REFNUM;"";""
