$OUVRE


    Local Integer NBTBL , TYPTABLE(1..50)
    Local Char    MSKTAB(1)(1..50), MSKSUP(1)(1..50)
    Local Char    TBTABLE(GLONATB)(1..50) , TBABREV(5)(1..50) , BASTAB(20)(1..50) , TABLE(GLONATB)
    Local Char    ADDFLG(10)(1..50) , MODFLG(10)(1..50)
    Local Char    PROGOBJ(GLONADC) , PROGSTD(GLONADC) , PROGSPE(GLONADC) , ACT(20), PROGSPV(GLONADC)
    Local Integer FLSPE, FLSPV
#    MABOS-25/02/13-FQ 81085-US1335-synchronize the populations
#    Local Integer NBPOP         : # Nb Tableau des Pop supprimÚes
#    Local Char    TBLPOP(GLONPOP)(1..50) : # Tableau des Pop supprimÚes
#    #MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
