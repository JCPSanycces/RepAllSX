###########################################################################################
# Modifications :
#     SYMEU - 21/07/10 - EXI 66191 LOT 2
#              - Le formateur interne est dans la table TRAINER et plus dans les salariÚs
#     SEGAY-FRRIC - 07/02/12 - EXI 44459
#              - Rajout du tableau pour Handicap (Flag,Taux de handicap et Date dÚbut et de fin)
#     SEGAY - 03/04/12 - FQ81387 - GÚnÚration subordonnÚs sans contrat
#     MABOS - 15/10/12 - FQ82362 - Hide or not the social numbers
#     MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
#     MABOS - 25/02/13 - FQ81085-US1335 - synchronize the populations from GENEMP, UPDEMP
#     MABOS - 10/06/13 - FQ74502-US1642 - add new tab "Specialities" before "Specific"
#     SEGAY US 1749 90546 11/07/13 test du maxi des tableaux Úcran
#     SEGAY - 12/12/13 - FQ94474 US2231 : Rate of handicap not mandatory
#     SBA - 20/12/13 - FQ88174 - 2216
###########################################################################################

$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "LIENS"        : Gosub LIENS
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "FILTRE"       : Gosub FILTRE
 When "APRES_CHOI"   : Gosub APRES_CHOI : # FQ81085 US524 - SEGAY 05/07/12 Multi_leg & multi_sociÚtÚ
 When "DROIT"        : Gosub DROIT
 When "RAZDUP"       : Gosub RAZDUP
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "RAZCRE"       : Gosub RAZCRE
 When "VERF_ANU"     : Gosub VERF_ANU # SYMEU V6.1 Module Formation - Formateur interne
 When "ANNULE"       : Gosub ANNULE
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT : # 80379
 When "AVANT_CHOI"   : Gosub AVANT_CHOI
 When "FIN_ACTION"   : Gosub FIN_ACTION
 When "FERME"        : Gosub FERME : # FQ81085 US524 - SEGAY 05/07/12 Multi_leg & multi_sociÚtÚ
 When "ABANDON"      : Gosub ABANDON : # FQ81085 US524 - SEGAY 05/07/12 Multi_leg & multi_sociÚtÚ
 When "STYLE"        : Gosub STYLE :# SEGAY 16/04/2012 - 81084
 When "FIN_MOD"      : Gosub FIN_MOD : # FQ88174
 When "SEL_LISTE"    : Gosub SEL_LISTE
Endcase


If func AFNC.ACTIV("KPOAO")>0  Then
    Gosub ACTION From SUBEMLKPO
Endif


If func AFNC.ACTIV("KAFR")>0
    Gosub ACTION From SUBEMLKAQ
Endif

If func AFNC.ACTIV("KMIEA")>0
    Gosub ACTION From SUBEMLMID
Endif


If func AFNC.ACTIV("KAUS")>0
    Gosub ACTION From SUBEMLKAU
Endif


Return

