$CREFIC
TABLE = TBTABLE(I)
Gosub DEFAUT From WPDEFTABLE
Case TYPTABLE(I)
 When 1
  nolign = 1
  Gosub DECHARGE
  Gosub CREUSR
  Write
  If fstat
   GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Return
  Endif
 When 2
  MA = find("EMP"+MSKTAB(I),ABMSK(1..NBMASK))
  Gosub SETMASK From =WINPROG
  Assign "[M]"+ADDFLG(I) With 0
  If find(BASTAB(I),"NBRHAB","NBRCHD","NBRRIB")
   For nolign=1 To evalue("[M]"+BASTAB(I))
    [F] = [M]
    [F]REFNUM = [F:ID]REFNUM
    [F]NUMLIG = nolign
    Gosub ECRPAR
    Gosub CREUSR
    Write
    If fstat
     GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break
    Endif
   Next
  Else
   For nolign=evalue("[M]"+BASTAB(I)) To 1 Step -1
    [F] = [M]
    [F]REFNUM = [F:ID]REFNUM
    [F]NUMLIG = evalue("[M]"+BASTAB(I))-(nolign-1)
    Gosub ECRPAR
    Gosub CREUSR
    Write
    If fstat
     GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break
    Endif
   Next nolign
  Endif
Endcase
Return

