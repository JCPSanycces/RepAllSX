If [M:EMP2]NTT <> '' #and [M:EMP2]NTTNAM = ''
  Call LECTEXTRA([M:EMP2]NTTNAM,"TABCOUNTRY","CRYDES",[M:EMP2]NTT,'') From ATEXTRA
Endif
#HEGES - 2017-04-07 - X3-47309 - END
 If [F:ID]FCYORI = ""
     [F:ID]FCYORI=[F:ID]FCY
     [M:EMP0]FCYORI=[F:ID]FCY
     Affzo [M:EMP0]FCYORI
 Endif
# FQ81085 US524 - SEGAY 05/07/12 - Find the good local menu for the title, depending on the site

For I=1 To NBTBL
 TABLE = TBTABLE(I)
 Gosub DEFAUT From WPDEFTABLE
 Case TYPTABLE(I)
  When 1
   nolign = 1
   Read = [F:ID]REFNUM
   If !fstat
    Gosub CHARGE
   Endif
  When 2
   Filter [F] Where REFNUM=[F:ID]REFNUM
   nolign = 0
   For [F]
   # SEGAY US 1749 90546 11/07/13 test du maxi des tableaux Úcran
    If nolign>=evalue("dim([M:EMP"+MSKTAB(I)+"]"+MODFLG(I)+")")
       Call ERREUR(TABLE-mess(26,100,1)) From GESECRAN   # Tableau plein
       Break
    Endif
    nolign += 1
    Gosub CHARGE
    Assign "[M:EMP"+MSKTAB(I)+"]"+MODFLG(I)+"("+num$(nolign-1)+")" With 0
   Next
   Filter [F]
   Assign "[M:EMP"+MSKTAB(I)+"]"+BASTAB(I) With nolign
   Assign "[M:EMP"+MSKTAB(I)+"]"+ADDFLG(I) With 0
 Endcase
 If TABLE="EMPLOCTR"
  Filter [F] Where REFNUM=[F:ID]REFNUM
  nolign = 0
  For [F]CTR1
   nolign += 1
   Gosub CHARGE
  Next
  Filter [F]
  Assign "[M:EMP"+MSKTAB(I)+"]"+BASTAB(I) With nolign
 Endif

