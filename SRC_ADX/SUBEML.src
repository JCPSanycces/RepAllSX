$ENREG_PHOTO
# 43514
#For I=1 To NBTBL
# If evalue("dim("+ABMSK(I)+"EMPPIC)")>0
For MA=0 To NBMASK
 If evalue("dim([M:"+ABMSK(MA)+"]EMPPIC)")>0
  # fin 43514
  Gosub SETMASK From =WINPROG
  Raz [F:BBB]
  [F:BBB]BLOB   = [M]EMPPIC
  [F:BBB]CODBLB = "EMPPIC"
  [F:BBB]TYPBLB = 3
  [F:BBB]IDENT1 = [F:ID]REFNUM
  [F:BBB]IDENT2 = ""
  [F:BBB]IDENT3 = ""
  If dim([F:BBB]CREUSR)>0 : [F:BBB]CREUSR = GUSER : Endif
  If dim([F:BBB]CREDAT)>0 : [F:BBB]CREDAT = date$ : Endif
  If dim([F:BBB]CRETIM)>0 : [F:BBB]CRETIM = time  : Endif
  Write [BBB]
  If fstat
   GOK = 0 : Call FSTA("BBB") From GLOCK : Return
  Endif
  Break
 Endif
Next
Return

$MAJ_INTMT
# On a changÚ le flag intermittent du salariÚ. Il faut maj fiche contrat
If clalev([F:PSN])=0 : Local File PRESTATION [PSN] : Endif
Filter [HRCTR] Where REFNUM=[F:ID]REFNUM
For [HRCTR]CTR0
 If [F:ID]FLGINT=2 : # Intermittent
  ## Si le contrat est validÚ et qu'il n'y a pas de prestation, mettre le contrat Ó Saisi
  If [F:HRCTR]STACTR=2 : # ValidÚ
   Read [PSN]PSN0=[F:HRCTR]CTRNUM;1
   If fstat
    [F:HRCTR]STACTR = 1
    Rewrite [HRCTR] Curr
    If fstat
     GOK = 0 : Call FSTA("HRCTR") From GLOCK : Break
    Endif
   Endif
  Endif
 Else : # Permanent
  ## Si le contrat n'Útait pas validÚ, le mettre Ó Valider et effacer les prestations
  If [F:HRCTR]STACTR<>2 | [F:HRCTR]CALPAY<>1
   [F:HRCTR]STACTR = 2 : # ValidÚ
   [F:HRCTR]CALPAY = 1
   Rewrite [HRCTR] Curr
   If fstat
    GOK = 0 : Call FSTA("HRCTR") From GLOCK : Break
   Endif
   Delete [PSN] Where CTRNUM=[F:HRCTR]CTRNUM
   If fstat=1
    GOK = -1 : Call FSTA("PSN") From GLOCK : Break
   Endif
  Endif
 Endif
Next
Filter [HRCTR]
Return

$OUVRE_POPUL
#MABOS-25/02/13-FQ 81085-US1335-synchronize the populations
    Local Integer NBPOP         : # Nb Tableau des Pop supprimÚes
    Local Char    TBLPOP(GLONPOP)(1..50) : # Tableau des Pop supprimÚes
    #MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
    Local Integer L_NB_POPUL    : # Nb Tableau des Pop du salariÚ
    #Local Char   L_POPUL(GLONPOP)(0..)
    Local Char    L_POPUL(GLONPOP)(0..50)  : # Tableau des Codes Pop du salariÚ
    Local Integer L_POPMAJTYP(0..50) : # Tableau des Types(Manuelle/Auto) Pop du salariÚ
    Local Integer L_POPMOD      : # Indicateur de modif
    Local Integer L_MAJTYP(0..) : # Types(Manuelle/Auto) de pop en cours de Trt
    Local Char    WLEG          : # Leg du contrat en cours de trt
    Local Integer WOK,WDISP     : # var
    # END - MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10


    If clalev([F:HRPOP])=0 : Local File POPUL    [HRPOP]         : Endif
    If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA]         : Endif
    If clalev([F:POB])=0 : Local File POPULB   [POB]         : Endif
Return
#MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
$POPUL
Raz AUTO
Raz TBLPOP

# FQ91981 - 27/08/13 - Recherche sur l'ensemble des contrats du salariÚ
If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
Local Date DATMAT,DATDIA :# 96877
DATDIA=date$ :# 96877
Local Char MATRI(GLONMAT) : MATRI=[F:ID]REFNUM
Local Char CTR(GLONCTR)
Local Integer OKENR

# Fin FQ91981
For I=1 To NBTBL
 MA = find("EMP"+MSKTAB(I),ABMSK(1..NBMASK))
 If evalue("dim([M:EMP"+MSKTAB(I)+"]NBRPOP)")>0
  Gosub SETMASK From =WINPROG
  AUTO = [M]NBRPOP
  ## Affectation des populations en fonction du critÞre d'appartenance en crÚation
  If ACTION="CREATION"
   DATMAT=DATDIA : # 96877
   CTR = "" : # 96877
   Gosub LECEMP From WPDEFTABLE : # 96877
   Filter [HRPOP] Where CRI<>""
   For [HRPOP]
    If evalue([F:HRPOP]CRI)=1 & !find([F:HRPOP]COD,[M]POP(0..[M]NBRPOP-1))
     [M]POP([M]NBRPOP) = [F:HRPOP]COD
     [M]NBRPOP +=1
     [M]POPMOD = 1
    Endif
   Next
   Filter[HRPOP]
   Affzo POP, ZPOP, NBRPOP
  Endif
  For J=[M]NBRPOP-1 To 0 Step -1
   Read [F:HRPOP]POP0=[M]POP(J)
  # FQ91981 - 27/08/13 - Recherche sur l'ensemble des contrats du salariÚ
#   If !fstat & [F:POP]CRI<>"" & !evalue([F:POP]CRI) Then

   If !fstat & [F:HRPOP]CRI<>"" Then
    OKENR=1
    Filter [CTR2] Where REFNUM=MATRI & CTRDAT<=DATDIA
    If rowcount([CTR2])<1 : # 96877 si on n'a pas encore de contrat
      DATMAT=DATDIA
      CTR = ""
      Gosub LECEMP From WPDEFTABLE : # 96877
      If evalue([F:HRPOP]CRI)=1 Then OKENR=2 :Endif
    Else
#    For [CTR2]CTR0(2) Where REFNUM=MATRI & CTRDAT<=DATMAT & (XITDAT=[0/0/0] | XITDAT>DATMAT)
      For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA # 96877 Update populations of inactive contract
        DATMAT=[F:CTR2]CTRDAT : # 96877
        CTR = [F:CTR2]CTRNUM
        Gosub LECEMP From WPDEFTABLE
        If evalue([F:HRPOP]CRI)=1 Then OKENR=2 : Break : Endif
      Next
    Endif
    Filter [CTR2]
    If OKENR=1 Then
    # Fin FQ91981
     Read [F:HRPOA]POA0=[M]POP(J);[F:ID]REFNUM
     If !fstat & [F:HRPOA]MAJTYP=1 Then
       Delete [HRPOA] Curr
       If fstat=1
         GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM : Break 2
       Endif
       NBPOP += 1
       TBLPOP(NBPOP) = [F:HRPOA]COD
       Dela J,1 [M]NBRPOP
       [M]NBRPOP -= 1
     Endif
    Endif
   Endif
  Next
  Sorta [M]NBRPOP [M]NBRPOP Order By [M]POP([S]indice)
  Affzo [M]NBRPOP, POP

  If [M]POPMOD
   NBPOP = 0
   For [HRPOA]POA1 Where REFNUM=[F:ID]REFNUM & TYP=0 & COD<>""
    If !find([F:HRPOA]COD,[M]POP(0..[M]NBRPOP-1))
     NBPOP += 1
     TBLPOP(NBPOP) = [F:HRPOA]COD
     Delete [HRPOA] Curr
     If fstat=1
      GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM : Break 2
     Endif
    Endif
   Next
   ## On efface de POPULA toutes les fiches du salariÚ associÚes Ó des sous-populations de la population
   ## stockÚe dans CODPOP
   For J=1 To NBPOP
    CODPOP = TBLPOP(J)
    Gosub GENPOP From SUBPOP
   Next J
  Endif
  If ACTION="MODIF"
   Filter [HRPOP] Where CRI<>""
   For [HRPOP]
    # FQ91981 - 27/08/13 - Recherche sur l'ensemble des contrats du salariÚ
#     If evalue([F:POP]CRI)=1 & !find([F:POP]COD,[M]POP(0..[M]NBRPOP-1)) & !find([F:POP]COD,TBLPOP)
     OKENR=1
#     For [CTR2]CTR0(2) Where REFNUM=MATRI & CTRDAT<=DATMAT & (XITDAT=[0/0/0] | XITDAT>DATMAT)
     Filter [CTR2] Where REFNUM=MATRI & CTRDAT<=DATDIA
     If rowcount([CTR2])<1 : # 96877 si on n'a pas encore de contrat
       DATMAT=DATDIA
       CTR = ""
       Gosub LECEMP From WPDEFTABLE : # 96877
       If evalue([F:HRPOP]CRI)=1 Then OKENR=2 :Endif
     Else
       For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA # 96877 Update populations of inactive contract
        CTR = [F:CTR2]CTRNUM
        DATMAT=[F:CTR2]CTRDAT # 96877
        Gosub LECEMP From WPDEFTABLE
        If evalue([F:HRPOP]CRI)=1 Then OKENR=2 : Break : Endif
       Next
     Endif
     Filter [CTR2]
     If OKENR=2 & !find([F:HRPOP]COD,[M]POP(0..[M]NBRPOP-1)) & !find([F:HRPOP]COD,TBLPOP)
     # Fin FQ91981
       [M]POP([M]NBRPOP) = [F:HRPOP]COD
       [M]NBRPOP +=1
       [M]POPMOD = 1
     Endif
   Next
   Filter[HRPOP]
   Affzo POP, ZPOP, NBRPOP
  Endif
  If [M]POPMOD
   For nolign=1 To [M]NBRPOP
    Read [F:HRPOP]POP0=[M]POP(nolign-1)
    Read [HRPOA]POA1 = [F:ID]REFNUM;[M]POP(nolign-1)
    If fstat
     [F:HRPOA]COD    = [M]POP(nolign-1)
     [F:HRPOA]TYP    = 0
     [F:HRPOA]REFNUM = [F:ID]REFNUM
 #    If [F:POP]CRI<>"" & evalue([F:POP]CRI)>0 Then
     # 96877 on teste les contrats du salariÚ pour mettre auto ou manuelle
     OKENR=1
     If [F:HRPOP]CRI<>""
       If [F:ID]NBRCTR>0
         For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA
          CTR = [F:CTR2]CTRNUM
          DATMAT=[F:CTR2]CTRDAT : # 96877
          Gosub LECEMP From WPDEFTABLE
          If evalue([F:HRPOP]CRI)=1 Then OKENR=2 : Break : Endif
         Next
       Else
        If evalue([F:HRPOP]CRI)=1 Then OKENR=2 Endif
       Endif
     Endif
     If [F:HRPOP]CRI<>"" & OKENR=2 Then
     # END 96877
      [F:HRPOA]MAJTYP = 1 : # Auto
     Else
      [F:HRPOA]MAJTYP = 2 : # Manuelle
     Endif
     If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
     If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
     If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
     Write [HRPOA]
     If fstat
      GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break 2
     Endif
     CODPOP = [M]POP(nolign-1)
     Gosub AJOUTLIS
    Endif
   Next nolign
  Endif
  Break
 Endif
Next I
If GOK<1 : Return : Endif
# Population vide
Read [HRPOA]POA0 = "";[F:ID]REFNUM
If fstat
 Raz [F:HRPOA]
 [F:HRPOA]REFNUM = [F:ID]REFNUM
 [F:HRPOA]MAJTYP = 2 : # Manuelle
 If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
 If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
 If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
 Write [HRPOA]
 If fstat
  GOK = 0 : Call FSTA("HRPOA") From GLOCK : Return
 Endif
Endif
Return

#    For nolign=1 To [M]NBRCTR
#       If !([M]CTRNUM(nolign-1)=[F:HRCTR]CTRNUM & [M]CTRDAT(nolign-1)=[F:HRCTR]CTRDAT)
#          # FQ85451 US904 - MABON 05/11/12 - Synchronisation of populations, lecture du bon contrat/date
##          Read [HRCTR]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#          Read [HRCTR]CTR0=[F:HRCTR]REFNUM;[M]CTRNUM(nolign-1);[M]CTRDAT(nolign-1)
#          # Fin MABON
#       Endif
#      # MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
#      Gosub POPUL_CTR
#      If GOK<1 : Break : Endif:# exit the loops in 2 steps (2nd step)
#
#    Next
#Return

$POPUL_CTR
# MABOS-25/02/13-FQ 81085-US1335-synchronize the populations
      # recherche la leg du contrat / Site
       NBPOP = 0
       Raz TBLPOP
       Call  GET_LEGFCY([F:HRCTR]ETRFCY,WOK,WLEG,WDISP) From TOOLSHRLEG
       Call  CHARGE_POPUL([F:HRCTR]REFNUM,L_POPUL,L_NB_POPUL,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,L_POPMAJTYP) From SUBCTR

      ## MAJ du tableau des populations en fonction du critÞre d'appartenance en crÚation, modif
#     If (ACTION="CREATION" | ACTION="MODIF" )
         Filter [HRPOP] Where CRI<>""
         For [HRPOP]
            # Úvaluation des critÞres -> affectation nouvelle population
            If evalue([F:HRPOP]CRI)=1 & !find([F:HRPOP]COD,L_POPUL(0..L_NB_POPUL-1))
&              & ([F:HRPOP]LEG="" |[F:HRPOP]LEG= WLEG)
#              # Ajout dans le tableau
               L_POPUL(L_NB_POPUL) = [F:HRPOP]COD
               L_POPMAJTYP(L_NB_POPUL) = 1 : # automatique
               L_NB_POPUL +=1
               L_POPMOD = 1
            Endif
         Next
         Filter[HRPOP]
#     Endif
      # Lecture du tableau : supprimer l'affectation si critÞres non ok

      For J=L_NB_POPUL-1 To 0 Step -1
         Read [F:HRPOP]POP0=L_POPUL(J)
         # Úvaluation des critÞres -> si pas OK - supprimer affectation population
         If !fstat & [F:HRPOP]CRI<>"" & !evalue([F:HRPOP]CRI) Then
             Read [F:HRPOA]POA0=L_POPUL(J);[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
             If !fstat & [F:HRPOA]MAJTYP=1 Then
                 # stockÚ dans tableau des supprimÚs
                 NBPOP += 1
                 TBLPOP(NBPOP) = [F:HRPOA]COD
                 # suppression de l'enregistrement dans fichier
                 Delete [F:HRPOA] Curr
                 If fstat=1
                   GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM-[F:HRPOA]CTRNUM-[F:HRPOA]CTRDAT
                   #MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
                    Break : # Break 2:# exit the loops in 2 steps (1st step)
                 Endif
                 # suppression de la ligne dans tableau
                 Dela J L_POPUL, L_POPMAJTYP
                 L_NB_POPUL -= 1
                 L_POPMOD = 1
             Endif
         Endif
      Next
      #MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
      If GOK<1 : Return : Endif:# exit the loops in 2 steps (1st step)
      Sorta L_NB_POPUL L_POPUL, L_POPMAJTYP Order By L_POPUL([S]indice), L_POPMAJTYP([S]indice)

      If L_POPMOD
  #      NBPOP = 0
         For [HRPOA]POA1 Where REFNUM=[F:HRCTR]REFNUM
&                      & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
&                      & TYP=0 & COD<>""
#           si il n'exsite pas le tableau des pop
            If !find([F:HRPOA]COD,L_POPUL(0..L_NB_POPUL-1))
#             On le met dans le tableau des supprimÚs si pas dÚjÓ
              If !find([F:HRPOA]COD,TBLPOP(1..NBPOP))
                 NBPOP += 1
                 TBLPOP(NBPOP) = [F:HRPOA]COD
              Endif
              # suppression de l'enregistrement dans fichier
              Delete [HRPOA] Curr
              If fstat=1
                GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM-[F:HRPOA]CTRNUM-[F:HRPOA]CTRDAT
                #MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
                Break : # Break 2:# exit the loops in 2 steps (1st step)
              Endif

            Endif
         Next
         #MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
         If GOK<1 : Return : Endif :# exit the loop in 2 steps (1st step)
         ## On efface de POPULA toutes les fiches du salariÚ associÚes Ó des sous-populations de la population
         ## stockÚe dans CODPOP
         # FQ85451 US904 - MABON 08/11/12 - Manage only the employee concerned by the update, if it is the case
         Local Char CRITERE_REF
         CRITERE_REF="REFNUM='"+[F:HRPOA]REFNUM+"'"
         # End MABON
         For J=1 To NBPOP
            CODPOP = TBLPOP(J)
            Gosub GENPOP From SUBPOP
         Next J
         For J=1 To L_NB_POPUL
            Read [HRPOA]POA1 = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;L_POPUL(J-1)
            If fstat
               [F:HRPOA]COD    = L_POPUL(J-1)
               [F:HRPOA]TYP    = 0
               [F:HRPOA]REFNUM = [F:HRCTR]REFNUM
               [F:HRPOA]CTRNUM = [F:HRCTR]CTRNUM
               [F:HRPOA]CTRDAT = [F:HRCTR]CTRDAT
               If L_POPMAJTYP(J-1)=0
                 L_POPMAJTYP(J-1)=2: # Manuelle
               Endif
               [F:HRPOA]MAJTYP = L_POPMAJTYP(J-1)
               If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
               If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
               If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
               Write [HRPOA]
               If fstat
                  GOK = 0 : Call FSTA("HRPOA") From GLOCK :
                  #MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
                  Break : # Break 2 : # exit the loops in 2 steps (1st step)
               Endif
               CODPOP = L_POPUL(J-1)
               L_MAJTYP =  L_POPMAJTYP(J-1)
               Gosub AJOUTLIS
            Endif
         Next J
       Endif
       If GOK<1 : Return : Endif
          # Population vide
       Read [HRPOA]POA0 = "";[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
       If fstat
           Raz [F:HRPOA]
           [F:HRPOA]REFNUM = [F:HRCTR]REFNUM
           [F:HRPOA]CTRNUM = [F:HRCTR]CTRNUM
           [F:HRPOA]CTRDAT = [F:HRCTR]CTRDAT
           [F:HRPOA]MAJTYP = 2 : # Manuelle
           If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
           If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
           If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
           Write [HRPOA]
           If fstat
              GOK = 0 : Call FSTA("HRPOA") From GLOCK : Return
           Endif
       Endif


#   Next # MABOS-25/02/13-FQ 81085-US1335-synchronize the populations from GENEMP, UPDEMP
Return

$AJOUTLIS
  NIV2 = 1
  POPUL2(NIV2) = CODPOP
  Gosub AJOUT
Return

$AJOUT
  If GOK<1 : Return : Endif
  If ERR or NIV2>=MAXNIV
    ERR = 1
    Return
  Endif
  NB2(NIV2) = 0
  For [F:POB]POB1 Where POP=POPUL2(NIV2)
    NB2(NIV2) += 1
    TBPOP2(NIV2,NB2(NIV2)) = [F:POB]COD
  Next
  PT2(NIV2) = 1
  While PT2(NIV2)<=NB2(NIV2)
    [F:HRPOA]COD    = TBPOP2(NIV2,PT2(NIV2))
    [F:HRPOA]TYP    = NIV2
    [F:HRPOA]REFNUM = [F:HRCTR]REFNUM
    [F:HRPOA]CTRNUM = [F:HRCTR]CTRNUM
    [F:HRPOA]CTRDAT = [F:HRCTR]CTRDAT
    # MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
    [F:HRPOA]MAJTYP = L_MAJTYP
#    If nolign>AUTO
#      [F:HRPOA]MAJTYP = 1 : # Auto
#    Else
#      [F:HRPOA]MAJTYP = 2 : # Manuelle
#    Endif
#   end - MABOS - 02/11/12 - FQ81085-US917 - remove population block  in HRMAT10
    If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
    If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
    If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
    Write [HRPOA]
    If fstat=3
      # on s'en fout
    Elsif fstat
      GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break
    Endif
    POPUL2(NIV2+1) = TBPOP2(NIV2,PT2(NIV2))
    NIV2 += 1
    Gosub AJOUT
    If GOK<1 : Break : Endif
    NIV2 -= 1
    PT2(NIV2) += 1
  Wend
Return


$CREUSR
If dim([F]CREDAT)>0 : [F]CREDAT = date$     : Endif
If dim([F]CRETIM)>0 : [F]CRETIM = time      : Endif
If dim([F]CREUSR)>0 : [F]CREUSR = GUSER     : Endif
If dim([F]EXPNUM)>0 : [F]EXPNUM = [C]EXPORT : Endif
Return

$MODUSR
If dim([F]UPDDAT)>0 : [F]UPDDAT = date$     : Endif
If dim([F]UPDTIM)>0 : [F]UPDTIM = time      : Endif
If dim([F]UPDUSR)>0 : [F]UPDUSR = GUSER     : Endif
If dim([F]EXPNUM)>0 : [F]EXPNUM = [C]EXPORT : Endif
Return

$FILGAUCHE
FILGAUSUP = "[F:ID]FLGNEWSAL<>2"

Call FILTREROLE("EML",FILGAUSUP)

Case currbox

 When BOXMAT, BOXMAT2
  If GUSRACS<>2
   FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
   FILGAUSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
  Endif
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
   FILGAUSUP -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
  Endif
  If FILTRE<>""
   FILGAUSUP -= '&'+FILTRE
  Endif
# FQ81085 US524 - SEGAY 05/07/12 -  Filter left list based on legislation
#  FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
  FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
  FILGAUCHE -= " | ([F:CPY]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CPY]LEG='') | GLEGFIL='')"

# FQ74282 - 10/09/13 - FILGAUSUP trop long, donc on passe par CRITERE
#  If FILGAUSUP <> '' FILGAUSUP -= '&' Endif
##  FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
#  FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
#  FILGAUSUP -= " | ([F:CPY]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CPY]LEG='') | GLEGFIL='')"
Local Char W_CRIT(250)

# If CRITERE <> '' :  CRITERE -= '&' :  Endif
#  CRITERE -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
#  CRITERE -= " | ([F:CPY]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CPY]LEG='') | GLEGFIL='')"
  W_CRIT = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0))"
  W_CRIT -= "| ([F:CPY]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CPY]LEG='') | GLEGFIL='')"
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",W_CRIT,"&")From GOBJSUB
#If GLEGFIL<>""
# If CRITERE <> '' :  CRITERE -= '&' :  Endif
#  # SBA US 2135 : 92896 : pb liÚ au superviseur. Chaine trop longue.
#  # [F:CPY]LEG toujours renseignÚ.
##CRITERE -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
##  CRITERE -= " | ([F:CPY]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CPY]LEG='') | GLEGFIL='')"
#
#  Local Char A(5)
#  CRITERE -= "(([F:FCY]LEG<>'' & [F:FCY]LEG=GLEGFIL) "
#  CRITERE -= " | ([F:FCY]LEG='' & [F:CPY]LEG=GLEGFIL))"
#  # FQ74282
#Endif
 When BOXMAT3
  If GUSRACS<>2
   FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  Endif
  FILGAUSUP -= '& [F:ID]NBRCTR=0'
  If FILTRE<>""
   FILGAUSUP -= '&'+FILTRE
  Endif
# FQ81085 US524 - SEGAY 05/07/12 -  Filter left list based on legislation
#  FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:ID]FCYORI='' | [F:FCY]LEG='' | GLEGFIL='' )"
  FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
  FILGAUCHE -= " | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CP3]LEG='') | [F:ID]FCYORI='' | GLEGFIL='')"

#  If FILGAUSUP <> '' FILGAUSUP -= '&' Endif
##  FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:ID]FCYORI='' | [F:FCY]LEG='' | GLEGFIL='')"
#  FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0))"
#  FILGAUSUP -= " | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CP3]LEG='') | [F:ID]FCYORI='' | GLEGFIL='')"
# FQ74282 - 10/09/13 - FILGAUSUP trop long, donc on passe par CRITERE

  If CRITERE <> '' :  CRITERE -= '&' :  Endif
  # SBA US 2135 : 92896 : pb liÚ au superviseur. Chaine trop longue.
  # [F:CPY]LEG toujours renseignÚ.
#  CRITERE -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0))"
#  CRITERE -= " | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CP3]LEG='') | [F:ID]FCYORI='' | GLEGFIL='')"
  CRITERE -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0))"
  CRITERE -= " | ([F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) |  [F:ID]FCYORI='' | GLEGFIL='')"

#FRLAA 2017-06-13 - US X3-39981 START
 When "GAU_CHE4"
  If GUSRACS<>2
   FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  Endif
  FILGAUSUP -= '& [F:ID]INTFLG=2'

  If FILTRE<>""
   FILGAUSUP -= '&'+FILTRE
  Endif

  FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
  FILGAUCHE -= " | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) | ([F:FCY]LEG='' & [F:CP3]LEG='') | [F:ID]FCYORI='' | GLEGFIL='')"

  If CRITERE <> '' :  CRITERE -= '&' :  Endif
  CRITERE -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0))"
  CRITERE -= " | ([F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0)) |  [F:ID]FCYORI='' | GLEGFIL='')"
Endcase
#FRLAA 2017-06-13 - US X3-39981 END
Return

# FQ81085 US524 - SEGAY 05/07/12 - Navigate in the records, taking into account GLEGFIL
$FILDEM
  CRITCTR="1=1"
#  If GLEGFIL<>""
    If CRITCTR<>"" Then CRITCTR-="&" : Endif
    CRITCTR -= " [F:ID]FLGNEWSAL<>2"

    Call FILTREROLE("EML",CRITCTR) From SUBEML

    Case currbox
     When BOXMAT, BOXMAT2
      If GUSRACS<>2
       CRITCTR -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
       CRITCTR -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
      Endif
      If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
       CRITCTR -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
      Endif
      If FILTRE<>""
       CRITCTR -= '&'+FILTRE
      Endif
      If GLEGFIL<>""
#         CRITCTR -= " & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  CRITCTR -= " & (([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
  CRITCTR -= " | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CP3]LEG,'"+GLEGFIL+"','')>0))) "


      Endif

      If currbox = BOXMAT2
        Filter [EC2] Where evalue(CRITCTR)
      Endif
      If currbox = BOXMAT
       Filter [ECT_] Where evalue(CRITCTR)
      Endif
     When BOXMAT3
      If GUSRACS<>2
       CRITCTR -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
      Endif
      CRITCTR -= '& [F:ID]NBRCTR=0'
      If FILTRE<>""
       CRITCTR -= '&'+FILTRE
      Endif
#      CRITCTR -= " & (([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:ID]FCYORI='' | [F:FCY]LEG='' | GLEGFIL='')"
      CRITCTR -= " & (([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) "
      CRITCTR -= " | [F:ID]FCYORI='' | ([F:FCY]LEG='' & [F:CP3]LEG='') | GLEGFIL='' | ([F:CP3]LEG<>'' & [F:FCY]LEG='' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0))) "

      Filter [ID_] Where evalue(CRITCTR)
    Endcase
#  Endif
Return

$APRES_CHOI

  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILDEM
      Case currbox
       When BOXMAT
        If REPONSE=GSTASUI Then Read [ECT_]ECT0(1) > [M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAPRE Then Read [ECT_]ECT0(1) < [M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAFIR Then Read [ECT_]ECT0 First                : Endif
        If REPONSE=GSTALAS Then Read [ECT_]ECT0 Last                 : Endif
        Filter [ECT_]
       When BOXMAT2
        If REPONSE=GSTASUI Then Read [EC2]ECT2 > [EC2]FCY;[EC2]SRV;[M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAPRE Then Read [EC2]ECT2 < [EC2]FCY;[EC2]SRV;[M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAFIR Then Read [EC2]ECT2 First                : Endif
        If REPONSE=GSTALAS Then Read [EC2]ECT2 Last                 : Endif
        Filter [EC2]
       When BOXMAT3
        If REPONSE=GSTASUI Then Read [ID_]ID0 > [M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAPRE Then Read [ID_]ID0 < [M:EMP0]REFNUM  : Endif
        If REPONSE=GSTAFIR Then Read [ID_]ID0 First             : Endif
        If REPONSE=GSTALAS Then Read [ID_]ID0 Last              : Endif
        Filter [ID_]
      Endcase
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End FQ81085 US524 - SEGAY


$RAZDUP
Raz [M:EMP0]FCY,CPY
For I=1 To NBTBL
# Impossible pour "EMPLOCUM" car on ne connait pas le n? du mask
