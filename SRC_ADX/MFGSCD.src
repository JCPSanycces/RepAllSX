#<AdxTL>@(#)6.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Actions liées au  jalonnement OF                                          #
# - SAIMFGSCD    Gestion jalonnement OF                                     #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE":         Case GACTION
                              When "SAIMFGSCD" : Gosub OUVRE_MFGSCD
                          Endcase
    When "DEBUT":         Case GACTION
                              When "SAIMFGSCD" : Gosub DEBUT_MFGSCD
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAIMFGSCD" : Gosub SETBOUT_MFGSCD
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAIMFGSCD" : Gosub BOUTON_MFGSCD
                          Endcase
    When "OK":            Case GACTION
                              When "SAIMFGSCD":  Gosub OK_MFGSCD
                          Endcase
    When "FIN":           Case GACTION
                              When "SAIMFGSCD":  Gosub FIN_MFGSCD
                          Endcase
    When "FINSAI":        Case GACTION
                              When "SAIMFGSCD":  Gosub FINSAI_MFGSCD
                          Endcase
Endcase
Return

#---------------------------------------------------------------------------#
# Action SAIMFGSCD                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_MFGSCD
Local Char       WMFGFCY(GLONFCY) : WMFGFCY = PARAM(1)
Local Char       WMFGNUM(GLONVCR) : WMFGNUM = PARAM(2)

Local Integer    I, L, WREP, WRET, OK, J
Local Integer    WTRS : WTRS = 1
Local Integer    WLK  : WLK = 0
Local Integer    WDLK : WDLK = 0
Local Date       WENDDAT

If dim(OJAL) < 0     : Global Integer OJAL     : Endif
If dim(GCONSLCT) < 0 : Global Integer GCONSLCT : Endif
If OJAL <> 2 : OJAL   = 0 : Endif

If clalev ([F:MFG]) <= 0 Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFO]) <= 0 Local File MFGOPE     [MFO] : Endif
If clalev ([F:SCH]) <= 0 Local File SCHEDULING [SCH] : Endif
If clalev ([F:PJA]) <= 0 Local File PARJAL     [PJA] : Endif
If clalev ([F:MWS]) <= 0 Local File WORKSTATIO [MWS] : Endif

If clalev ([M:JALK])<= 0 Local Mask JALK       [JALK] : Endif

Return

###########################################################################
$DEBUT_MFGSCD
Local Integer WOK : WOK=0

# lock OF
# GH 27/02/2014 bug 97066
#WLK = 0
#SYMBOLE = "MFG"+WMFGNUM
#Lock = SYMBOLE With lockwait = 0
#If fstat
#    WLK = 1
#Endif
If WDLK<>1
  WLK =  func TRTX3FNC.CHECK_LOCK("MFG",WMFGNUM,1,WDLK)
Endif

If [F:MFG]MFGNUM <> WMFGNUM
    Read [MFG]MFG0=WMFGNUM
    If fstat : Return : Endif
Endif

# chargement du tableau jalonnements
[M:MFOS]MFGFCY = [F:MFG]MFGFCY
[M:MFOS]MFGNUM = [F:MFG]MFGNUM
[M:MFOS]ROUALT = [F:MFG]ROUALT
[M:MFOS]ROUNUM = [F:MFG]ROUNUM
[M:MFOS]EXTQTY = [F:MFG]EXTQTY
[M:MFOS]SCDMOD = [F:MFG]SCDMOD
[M:MFOS]SCDFLG = [F:MFG]SCDFLG
[M:MFOS]CFMFLG = [F:MFG]CFMFLG
[M:MFOS]OBJDAT = [F:MFG]OBJDAT
[M:MFOS]STRDAT = [F:MFG]STRDAT
[M:MFOS]ENDDAT = [F:MFG]ENDDAT
If [M:MFOS]OBJDAT = [0/0/0] : [M:MFOS]OBJDAT = [F:MFG]ENDDAT : Endif    # (pour migration)
[M:MFOS]ELFLG  = [M:MFOS]OBJDAT - [F:MFG]ENDDAT

J=0
Link [MFO] With [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&          As   [MFOX]
&          Where MFGNUM=WMFGNUM
&          Order By Key MFO0

For [MFOX]
    If [F:MFO]OPESTA <> 6
        [M:MFOS]OPENUM(J)     = [F:MFO]OPENUM
        [M:MFOS]OPESPLNUM(J)  = [F:MFO]OPESPLNUM
        [M:MFOS]WST(J)        = [F:MFO]EXTWST
        Read [MWS]WST0=[M:MFOS]WST(J);[F:MFG]MFGFCY
        If fstat : WOK=1: Break : Endif    # FQ 69909 Ctrl des sources avant Return
        [M:MFOS]WCR(J)        = [F:MWS]WCR
        [M:MFOS]WSTTYP(J)     = [F:MWS]WSTTYP
        [M:MFOS]EXTWSTNBR(J)  = [F:MFO]EXTWSTNBR
        [M:MFOS]NEXOPENUM(J)  = [F:SCH]NEXOPENUM
        [M:MFOS]SCDCOD(J)     = [F:SCH]SCDCOD
        [M:MFOS]SCDTIM(J)     = [F:SCH]SCDTIM
        [M:MFOS]SCDQTY(J)     = [F:SCH]SCDQTY
        [M:MFOS]SCDLOT(J)     = [F:SCH]SCDLOT
        [M:MFOS]LOTQTY(J)     = [F:SCH]LOTQTY
        [M:MFOS]DACMST(J)     = [F:SCH]DACMST
        [M:MFOS]MFGMST(J)     = [F:SCH]MFGMST
        [M:MFOS]OPEUOM(J)     = [F:MFO]OPEUOM
        Case [M:MFOS]SCDFLG
            When 1,2,3:         [M:MFOS]INFCAPSTR(J)  = [F:SCH]INFCAPSTR
                                [M:MFOS]INFCAPEND(J)  = [F:SCH]INFCAPEND
            When 4:             [M:MFOS]INFCAPSTR(J)  = [F:SCH]FITCAPSTR
                                [M:MFOS]INFCAPEND(J)  = [F:SCH]FITCAPEND
        Endcase
        [M:MFOS]OPESTRDAT(J)  = [F:SCH]OPESTRDAT
        [M:MFOS]OPEENDDAT(J)  = [F:SCH]OPEENDDAT
        [M:MFOS]CLCPRPDUR(J)  = [F:SCH]CLCPRPDUR
        [M:MFOS]CLCSETDUR(J)  = [F:SCH]CLCSETDUR
        [M:MFOS]CLCOPEDUR(J)  = [F:SCH]CLCOPEDUR
        [M:MFOS]CLCPSTDUR(J)  = [F:SCH]CLCPSTDUR
        [M:MFOS]CLCWAIDUR(J)  = [F:SCH]CLCWAIDUR
        [M:MFOS]FRCSTRDAT(J)  = [F:MFO]FRCSTRDAT
        J += 1
    Endif
Next I
If WOK Return Endif  # FQ 69909 Ctrl des sources : Erreur à traiter ?

[M:MFOS]NBLIG = J
If [M:MFOS]NBLIG = 0 : [M:MFOS]CFMFLG = 1 : Endif

Affzo  [MFOS]
Return

###########################################################################
$SETBOUT_MFGSCD
ETABOU(GVALI)=1
If [M:MFOS]NBLIG = 0
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 0
    ETABOU(GSPE4) = 0
    ETABOU(GSPE5) = 0
Else
    Case [M:MFOS]SCDFLG
        When 1:   ETABOU(GSPE1) = 0
                  If [M:MFOS]CFMFLG = 2
                      ETABOU(GSPE2)=1
                  Else
                      ETABOU(GSPE2)=0
                  Endif
                  ETABOU(GSPE3) = 0
                  ETABOU(GSPE4)=0
        When 2,4: ETABOU(GSPE1) = 1
                  ETABOU(GSPE2)=0
                  ETABOU(GSPE3)=1
                  ETABOU(GSPE4)=1
        When 3:   ETABOU(GSPE1) = 1
                  If [M:MFOS]CFMFLG = 2
                      ETABOU(GSPE2)=1
                  Else
                      ETABOU(GSPE2)=0
                  Endif
                  ETABOU(GSPE3)=0
                  ETABOU(GSPE4)=1
    Endcase
    # Issue X3-25678 - 2017-02-21 by ALSHE : Disable buttons if WO is beeing optimized
    If [F:MFG]MFGNUM <> WMFGNUM
        Read [MFG]MFG0=WMFGNUM
        If fstat : Return : Endif
    Endif
    If ([F:MFG]OPTFLG=2 | [F:MFG]SCDFLG=4 )
        ETABOU(GSPE2)=0
        ETABOU(GSPE3)=0
        ETABOU(GSPE4)=0
    Endif
    # End issue X3-25678
    ETABOU(GSPE5)=1
Endif

If GCONSLCT = 1 | WLK
    ETABOU(GSPE2)=0
    ETABOU(GSPE3)=0
    ETABOU(GSPE4)=0
    Diszo [M:MFOS]
Endif

# FQ 58503 GA 09/2009 ne plus griser ce bouton en Web pour la V5
# #If GBROWS : ETABOU(GSPE1) = 0 : ETABOU(GSPE5) = 0 : Endif
# If GBROWS :  ETABOU(GSPE5) = 0 : Endif
Return

###########################################################################
$BOUTON_MFGSCD
Case BOUT
    When "1"       :    # graphique
#                        Gosub VISU_GRAPH
    When "2"       :    # jalonner
                        Gosub JALONNER
    When "3"       :    # a rejalonner
                        If [M:MFOS]NBLIG <> 0
                            GOK=1
                            Call DEBTRANS From GLOCK
												    # STWIL X3-24327 - If Production Scheduler in use - no change of SCDFLG
                            Read [MFG]MFG0 = WMFGNUM
                            If fstat = CST_AOK & [F:MFG]OPTFLG <> 2 & [F:MFG]SCDFLG <> 4
                                Trbegin ADOVAL
                                Update [MFG] Where MFGNUM = WMFGNUM
&                                           With  SCDFLG = 3
                                Commit
                                [M:MFOS]SCDFLG = 3
                                OJAL = 9
                            Else
                                Call ERREUR (mess(122,193,1)) From GESECRAN
                            Endif
                        Endif
    When "4"       :    # déjalonner
                        Gosub DEJALONNER
Endcase
FIN=0

Return

###########################################################################
$OK_MFGSCD
If [M:MFOS]NBLIG <> 0
    If (OJAL <> 0 | [M:MFOS]CFMFLG <> 2)
        Call CONTJAL(WRET) From MFGSCD
        If WRET <> 0
            OK=1
            Call OUINON(mess(29,190,1),OK) From GESECRAN
            If OK=2
                Gosub DEBUT_MFGSCD
                Return
            Endif
        Endif
        Call UPD_SCH(WMFGNUM,WRET) From MFGSCD
        If WRET <> 1 : Gosub DEBUT_MFGSCD : Return : Endif
        GVCR   = [M:MFOS]MFGNUM
        GLIN   = 1000
        GSEQ   = 0
        Case GFONCTION
            When "FUNGBENCH" : If clalev ([M:MGD])=0
                                   [M:MGB]REACT = 2
                                   GLRET = 2
                                   Gosub FABRICATION From FUNGBENCH
                               Else
                                   [M:MGD]REACT = 2
                                   GDLRET = 2
                                   Gosub FABRICATION From FUNDBENCH
                               Endif
            When "FUNDBENCH" : If clalev ([M:MGB])=0
                                   [M:MGD]REACT = 2
                                   GDLRET = 2
                                   Gosub FABRICATION From FUNDBENCH
                               Else
                                   [M:MGB]REACT = 2
                                   GLRET = 2
                                   Gosub FABRICATION From FUNGBENCH
                               Endif
           When "FUNBENPLT"  : If dim([M:MBP]REACT)
                                   Gosub PILOTAGE From FUNBENPLT
                                   GDLRET = 2
                               Endif
        Endcase
        If OJAL = 9 : OJAL = 99 : Endif
    Endif
Endif
Return

###########################################################################
$FIN_MFGSCD
If OJAL = 9 : Gosub OK_MFGSCD  : Endif

# GH 27/02/2014 bug 97066 : # on delocke ssi on a locké en debut de ce traitement
If WDLK=1
   Unlock = "MFG"+WMFGNUM
   WDLK=0
Endif
Return

###########################################################################
$FINSAI_MFGSCD
If OJAL = 99 : OJAL = 9 : Endif
Return

#--------------------------------------------------------------------------
# jalonnement
$JALONNER
If [M:MFOS]NBLIG <> 0
    Call CONTJAL(WRET) From MFGSCD
    If WRET <> 0 : FIN = 0 : Return : Endif

    # un petit message pour patienter ...
    Call TEMPON(mess(98,195,1)) From GESECRAN
    Call UPD_SCH(WMFGNUM,WRET) From MFGSCD
    If WRET <> 1 : FIN = 0 : Return : Endif

    If [F:MFG]MFGNUM <> WMFGNUM
        Read [MFG]MFG0=WMFGNUM
        If fstat : Return : Endif
    Endif

    WENDDAT        = [F:MFG]ENDDAT
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 1
    [M:JALK]MFGFCY = [F:MFG]MFGFCY
    [M:JALK]MFGNUM = [F:MFG]MFGNUM
    [M:JALK]MFGSTA = [F:MFG]MFGSTA
    If [F:PJA]MFGFCY <> [F:MFG]MFGFCY
        Read [PJA]PJA0=[F:MFG]MFGFCY
        If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
    Endif
    Call JALONNE From JALLIB

    If [M:JALK]CODRET = 0
        [M:MFOS]SCDFLG = 2
        # relecture jalonnements pour réaffichage dates
        For [SCH]SCH0 Where MFGNUM=WMFGNUM
            For I = 0 To [M:MFOS]NBLIG - 1
                If [M:MFOS]OPENUM(I) = [F:SCH]OPENUM & [M:MFOS]OPESPLNUM(I) = [F:SCH]OPESPLNUM
                    [M:MFOS]INFCAPSTR(I)  = [F:SCH]INFCAPSTR
                    [M:MFOS]INFCAPEND(I)  = [F:SCH]INFCAPEND
                    [M:MFOS]OPESTRDAT(I)  = [F:SCH]OPESTRDAT
                    [M:MFOS]OPEENDDAT(I)  = [F:SCH]OPEENDDAT
                    [M:MFOS]CLCPRPDUR(I)  = [F:SCH]CLCPRPDUR
                    [M:MFOS]CLCSETDUR(I)  = [F:SCH]CLCSETDUR
                    [M:MFOS]CLCOPEDUR(I)  = [F:SCH]CLCOPEDUR
                    [M:MFOS]CLCPSTDUR(I)  = [F:SCH]CLCPSTDUR
                    [M:MFOS]CLCWAIDUR(I)  = [F:SCH]CLCWAIDUR
                Endif
            Next I
        Next
        Affzo [MFOS]
        # si jalonnement amont et date fin changée, warning
        If [M:MFOS]SCDMOD = 1
            Read [MFG]MFG0=WMFGNUM
            If !fstat & [F:MFG]ENDDAT <> WENDDAT
                Call MESSAGE(mess(76,190,1)+"\"+format$(GFMD,WENDDAT)-"-->"-format$(GFMD,[F:MFG]ENDDAT)) From GESECRAN
            Endif
        Endif
        OJAL = 9
    Elsif [M:JALK]CODRET = 2
        OJAL = 2
# Issue 111414 - 2016-01-25 by CCC : Errors are managed in JALLIB
#    Else
#        Call ERREUR(mess(78,193,1)) From GESECRAN
    Endif
    ETABOU(GABAN)=0
    Call TEMPOFF From GESECRAN
Endif
Return

#--------------------------------------------------------------------------
# déjalonnement
$DEJALONNER
If [M:MFOS]NBLIG <> 0
    Call UPD_SCH(WMFGNUM,WRET) From MFGSCD
    If WRET <> 1 : FIN = 0 : Return  : Endif

    If [F:MFG]MFGNUM <> WMFGNUM
        Read [MFG]MFG0=WMFGNUM
        If fstat : Return : Endif
    Endif

    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 1
    [M:JALK]MFGFCY = [F:MFG]MFGFCY
    [M:JALK]MFGNUM = [F:MFG]MFGNUM
    [M:JALK]MFGSTA = [F:MFG]MFGSTA
    Call DEJALONNE From JALLIBA
    If [M:JALK]CODRET = 0
        [M:MFOS]SCDFLG = 1
        # relecture jalonnements pour réaffichage dates
        I = 0
        For [SCH]SCH0 Where MFGNUM=WMFGNUM
            For I = 0 To [M:MFOS]NBLIG - 1
                If [M:MFOS]OPENUM(I) = [F:SCH]OPENUM
                    [M:MFOS]INFCAPSTR(I)  = [F:SCH]INFCAPSTR
                    [M:MFOS]INFCAPEND(I)  = [F:SCH]INFCAPEND
                    [M:MFOS]OPESTRDAT(I)  = [F:SCH]OPESTRDAT
                    [M:MFOS]OPEENDDAT(I)  = [F:SCH]OPEENDDAT
                    [M:MFOS]CLCPRPDUR(I)  = [F:SCH]CLCPRPDUR
                    [M:MFOS]CLCSETDUR(I)  = [F:SCH]CLCSETDUR
                    [M:MFOS]CLCOPEDUR(I)  = [F:SCH]CLCOPEDUR
                    [M:MFOS]CLCPSTDUR(I)  = [F:SCH]CLCPSTDUR
                    [M:MFOS]CLCWAIDUR(I)  = [F:SCH]CLCWAIDUR
                Endif
            Next I
        Next
        OJAL = 9
        Affzo [MFOS]
    # STWIL X3-24327 - If Production Scheduler in use DEJALONNE outputs the message
    Elsif func AFNC.ACTIV("POPS") = 0
        Call ERREUR(mess(79,193,1)) From GESECRAN
    Endif
    ETABOU(GABAN)=0
Endif
Return

#########################################################################
# Mise à jour des données jalonnement                                   #
#########################################################################
Subprog UPD_SCH(LMFGNUM, LRET)
Value    Char    LMFGNUM
Variable Integer LRET
Local Integer I
Local Char    WCLE, WCLE2

# début de la transaction de jalonnement bidon
WCLE  = LMFGNUM
Call DEBTRANS From GLOCK
$TR_SCH
LRET = 1
Trbegin ADOVAL
    Readlock [MFG]MFG0=LMFGNUM
    If    fstat=1 : LRET=-1: GOK =-1 : GLOCK="$MFGHEAD"-WCLE             : Goto ROLL_SCH
    Elsif fstat   : LRET=0 : GOK = 0 : Call RSTA("MFG", WCLE) From GLOCK : Goto AB_SCH : Endif
    I = 0
# mise à jour des données jalonnement
    For  I = 0 To [M:MFOS]NBLIG-1
        WCLE2 = LMFGNUM-num$([M:MFOS]OPENUM(I))-num$([M:MFOS]OPESPLNUM(I))
        Readlock [SCH]SCH0=LMFGNUM;[M:MFOS]OPENUM(I);[M:MFOS]OPESPLNUM(I)
        If    fstat=1 : LRET=-1: GOK =-1 : GLOCK="$SCHEDULING"-WCLE2          : Goto ROLL_SCH
        Elsif fstat   : LRET=0 : GOK = 0 : Call RSTA("SCH", WCLE2) From GLOCK : Goto AB_SCH   : Endif
        [F:SCH]SCDCOD = [M:MFOS]SCDCOD(I)
        [F:SCH]SCDTIM = [M:MFOS]SCDTIM(I)
        [F:SCH]SCDQTY = [M:MFOS]SCDQTY(I)
        [F:SCH]SCDLOT = [M:MFOS]SCDLOT(I)
        [F:SCH]DACMST = [M:MFOS]DACMST(I)
        [F:SCH]MFGMST = [M:MFOS]MFGMST(I)
        Rewrite [SCH]
        If    fstat=1 : LRET=-1: GOK =-1 : GLOCK="$SCHEDULING"-WCLE2          : Goto ROLL_SCH
        Elsif fstat   : LRET=0 : GOK = 0 : Call RSTA("SCH", WCLE2) From GLOCK : Goto AB_SCH   : Endif
    Next I

# mise à jour entête OF
    [F:MFG]CFMFLG = [M:MFOS]CFMFLG
    [F:MFG]OBJDAT = [M:MFOS]OBJDAT
    Rewrite [MFG]
    If    fstat=1 : LRET=-1: GOK =-1 : GLOCK="$MFGHEAD"-WCLE             : Goto ROLL_SCH
    Elsif fstat   : LRET=0 : GOK = 0 : Call RSTA("MFG", WCLE) From GLOCK : Goto AB_SCH : Endif
Commit
End

#--------------------------------
$ROLL_SCH
Rollback  : Call ROLL From GLOCK
If !GROLL : Goto TR_SCH : Endif
Return

#--------------------------------
$AB_SCH
Rollback
Return

#########################################################################
# Contrôle de validité du jalonnement
Subprog CONTJAL(WRET)
Variable Integer WRET
Local    Integer I, J, JMAX
Local    Integer OPEOK
Local    Integer MFGOK, JALOK
# matrice contenant une image des opérations sans les fractions supplémentaires (synchro STR)
Local    Integer XOPE(0..[M:MFOS]NBLIG-1,2)

OPEOK = 0
MFGOK = 0
WRET  = 0

# il faut une et une seule opération qui n'ait pas d'opération suivante
# et il faut au moins une opération productive
For I=0 To [M:MFOS]NBLIG-1
    If ([M:MFOS]NEXOPENUM(I) = 0) & ([M:MFOS]SCDCOD(I) <> 8) : OPEOK += 1 : Endif
    If ([M:MFOS]MFGMST(I)    = 2) & ([M:MFOS]SCDCOD(I) <> 8) : MFGOK += 1 : Endif
Next I

# si pas de dernière opération trouvée précédemment (sous-traitance exclue),
# on vérifie à présent les opérations de sous-traitance
If OPEOK = 0
    For I=0 To [M:MFOS]NBLIG-1
        If ([M:MFOS]NEXOPENUM(I) = 0) & ([M:MFOS]SCDCOD(I) = 8) : OPEOK += 1 : Break : Endif
    Next I
Endif

If MFGOK = 0
    For I=0 To [M:MFOS]NBLIG-1
        If ([M:MFOS]MFGMST(I) = 2) & ([M:MFOS]SCDCOD(I) = 8) : MFGOK += 1 : Break : Endif
    Next I
Endif

# il faut au moins une opé productive!
If MFGOK = 0
    [M:MFOS]CFMFLG = 1
    Affzo [M:MFOS]CFMFLG
    Call MESSAGE(mess(31,193,1)) From GESECRAN
    WRET = 1
    Goto FIN_CONTROLE
Endif

# il faut une dernière opération !
If OPEOK = 0
    [M:MFOS]CFMFLG = 1
    Affzo [MFOS]CFMFLG
    Call MESSAGE(mess(20,193,1)) From GESECRAN
    WRET = 1
    Goto FIN_CONTROLE
Endif

# il faut une et une seule dernière opération !
If OPEOK > 1
    [M:MFOS]CFMFLG = 1
    Affzo [MFOS]CFMFLG
    Call MESSAGE(mess(21,193,1)) From GESECRAN
    WRET = 1
    Goto FIN_CONTROLE
Endif

# chargement du tableau des opération
# llc 11.03 19214
J=0
For I = 0 To [M:MFOS]NBLIG - 1
    If [M:MFOS]SCDCOD(I) <> 8
        XOPE(J,0) = [M:MFOS]OPENUM(I)
        XOPE(J,1) = [M:MFOS]NEXOPENUM(I)
        J += 1
    Else
        If I > 0
            If [M:MFOS]OPENUM(I-1) <> [M:MFOS]OPENUM(I)
                XOPE(J,0) = [M:MFOS]OPENUM(I)
                XOPE(J,1) = [M:MFOS]NEXOPENUM(I)
                J += 1
            Endif
        Endif
    Endif
Next I

JMAX  = J
JALOK = 0
For I = 0 To JMAX - 2
    If XOPE(I+1,0) <> XOPE(I,1) : JALOK = 9 : Endif
Next I

If JALOK <> 0
   [M:MFOS]CFMFLG = 1
   Affzo [MFOS]CFMFLG
   Call MESSAGE(mess(22,193,1)) From GESECRAN
   WRET = 1
Endif
#
$FIN_CONTROLE
If (MFGOK <> 0) & (OPEOK = 1) & (JALOK <> 0)
   [M:MFOS]CFMFLG = 2
   Affzo [MFOS]CFMFLG
Endif
#
End

#########################################################################
# reséquencement des opérations (mode séquence automatique)             #
# application d'une séquence linéaire en tenant compte des exclusions   #
#########################################################################
Subprog RESEQ_JAL
Local Integer I,J

For I=0 To [M:MFG3]NBLIG - 1
    If I = [M:MFG3]NBLIG-1 : [M:MFG3]NEXOPENUM(I) = 0 : Break : Endif
    For J=I+1 To [M:MFG3]NBLIG - 1
        If [M:MFG3]OPESTA(J) <> 6 & [M:MFG3]OPENUM(J) <> [M:MFG3]OPENUM(I)
            [M:MFG3]NEXOPENUM(I) = [M:MFG3]OPENUM(J)
            Break
        Endif
    Next J
Next I
End

#########################################################################
# Jalonnement suggéré en cas d'ajout ou d'exclusion d'opération         #
# LCOD = 1, ajout/réactivation                                          #
# LCOD = 2, exclusion                                                   #
# LOPE = numéro d'opération ajoutée ou exclue                           #
#########################################################################
Subprog CAL_JAL_SUG(LCOD, LOPE)
Value Integer LCOD
Value Integer LOPE
Local Integer I,J
Local Integer WOPE
Local Integer WOK
Local Integer WL
Local Integer WPOS
Local Integer TOPE([M:MFG3]NBLIG)

# recherche nombre lignes actives
WL = 0
For  I = 0 To [M:MFG3]NBLIG - 1
    If [M:MFG3]OPESTA(I) <> 6 : TOPE(WL) = I : WL += 1 : Endif
Next I
# recherche position
WPOS = 0
For  I = 0 To WL - 1
    If [M:MFG3]OPENUM(TOPE(I)) = LOPE : WPOS = I : Break : Endif
Next I

Case LCOD
    When 1:     If WL = 1
                    [M:MFG3]NEXOPENUM(TOPE(WPOS)) = 0
                    [M:MFG3]SCDCOD(TOPE(WPOS))    = 1
                    [M:MFG3]DACMST(TOPE(WPOS))    = 2
                    [M:MFG3]MFGMST(TOPE(WPOS))    = 1
                Else
                    If WPOS = 0    # première position
                        [M:MFG3]NEXOPENUM(TOPE(WPOS)) = [M:MFG3]OPENUM(TOPE(WPOS+1))
                        [M:MFG3]SCDCOD(TOPE(WPOS))    = 1
                        [M:MFG3]DACMST(TOPE(WPOS))    = 2
                        [M:MFG3]MFGMST(TOPE(WPOS))    = 1
                    Endif
                    If WPOS = WL - 1    # dernière position
                        [M:MFG3]NEXOPENUM(TOPE(WPOS-1)) = LOPE
                        [M:MFG3]NEXOPENUM(TOPE(WPOS))   = 0
                        [M:MFG3]SCDCOD(TOPE(WPOS))      = 1
                        [M:MFG3]DACMST(TOPE(WPOS))      = 2
                        [M:MFG3]MFGMST(TOPE(WPOS))      = 1
                    Endif
                    If (WPOS > 0) & (WPOS < WL - 1)
                        [M:MFG3]NEXOPENUM(TOPE(WPOS-1)) = LOPE
                        [M:MFG3]SCDCOD(TOPE(WPOS))      = 1
                        [M:MFG3]NEXOPENUM(TOPE(WPOS))   = [M:MFG3]OPENUM(TOPE(WPOS+1))
                        [M:MFG3]DACMST(TOPE(WPOS))      = 2
                        [M:MFG3]MFGMST(TOPE(WPOS))      = 1
                    Endif
                Endif
    When 2:     If [M:MFG3]NBLIG > 1 & WL > 0
                    For  I = 0 To [M:MFG3]NBLIG - 1
                        If [M:MFG3]OPENUM(I) = LOPE : Break : Endif
                    Next I
                    If I = [M:MFG3]NBLIG - 1    # dernière position
                            [M:MFG3]NEXOPENUM(TOPE(WL-1)) = 0
                    Endif
                    If (I > 0) & (I < [M:MFG3]NBLIG-1)
                        If WL > 1
                            For  J = 1 To WL - 1 # Issue 105341 - 2015-03-06 by JUSYN : WL need to be reduced by one not to exceed array
                                If [M:MFG3]OPENUM(TOPE(J)) > LOPE
                                    [M:MFG3]NEXOPENUM(TOPE(J-1)) = [M:MFG3]OPENUM(TOPE(J))
                                    Break
                                Endif
                            Next J
                        Else
                            [M:MFG3]NEXOPENUM(TOPE(0)) = 0
                        Endif
                    Endif
                Endif
Endcase
# vérif si opération de production existe
WOK = 0
If WL > 0
    For  I = 0 To WL - 1
        If [M:MFG3]MFGMST(TOPE(I)) = 2 : WOK = 1 : Break : Endif
    Next I
    If WOK = 0
        J = WL - 1
        [M:MFG3]MFGMST(TOPE(J)) = 2
        If [M:MFG3]DACMST(TOPE(J)) = 1 : [M:MFG3]DACMST(TOPE(J)) = 2 : Endif
    Endif
Endif
End

#############################################################
$VISU_GRAPH
Local    Integer  LALT : LALT = [F:MFG]ROUALT
Local    Date     LDAT
Local    Char     LTIT
Local    Mask JALK [JALK]
If clalev ([ATZ])=0 : Local File ATABZON [ATZ] : Endif
Raz [M:JALK]
I = 0
For [SCH]SCH0 Where MFGNUM=[F:MFG]MFGNUM
    If [F:SCH]OPESTRDAT = [0/0/0] : Goto NEXT_SCH : Endif
    [M:JALK]OPENUM(I)    = [F:SCH]OPENUM
    [M:JALK]OPESPLNUM(I) = [F:SCH]OPESPLNUM
    [M:JALK]OPESTRDAT(I) = [F:SCH]OPESTRDAT
    [M:JALK]OPEENDDAT(I) = [F:SCH]OPEENDDAT
    Case [M:MFOS]SCDFLG
        When 1,2,3: [M:JALK]INFCAPSTR(I) = [F:SCH]INFCAPSTR
                    [M:JALK]INFCAPSTF(I) = [F:SCH]INFCAPSTF
                    [M:JALK]INFCAPEND(I) = [F:SCH]INFCAPEND
                    [M:JALK]INFCAPENF(I) = [F:SCH]INFCAPENF
                    [M:JALK]OPESTRFRD(I) = [F:SCH]OPESTRFRD
                    [M:JALK]OPEENDFRD(I) = [F:SCH]OPEENDFRD
                    [M:JALK]CLCPRPDUR(I) = [F:SCH]CLCPRPDUR
                    [M:JALK]CLCWORDUR(I) = [F:SCH]CLCWORDUR
                    If [F:SCH]CLCPSTDUR > [F:SCH]CLCWAIDUR
                       [M:JALK]CLCAFTDUR(I) = [F:SCH]CLCPSTDUR
                    Else
                       [M:JALK]CLCAFTDUR(I) = [F:SCH]CLCWAIDUR
                    Endif
        When 4:     [M:JALK]INFCAPSTR(I) = [F:SCH]FITCAPSTR
                    [M:JALK]INFCAPSTF(I) = [F:SCH]FITCAPSTF
                    [M:JALK]INFCAPEND(I) = [F:SCH]FITCAPEND
                    [M:JALK]INFCAPENF(I) = [F:SCH]FITCAPENF
                    [M:JALK]OPESTRFRD(I) = [F:SCH]OPEFITSTF
                    [M:JALK]OPEENDFRD(I) = [F:SCH]FITOPEENF
                    [M:JALK]CLCPRPDUR(I) = [F:SCH]FITPRPDUR
                    [M:JALK]CLCWORDUR(I) = [F:SCH]FITWORDUR
                    [M:JALK]CLCAFTDUR(I) = [F:SCH]FITPSTDUR
    Endcase
    I += 1
$NEXT_SCH
Next
# Calcul nombre d'opérations
Local Integer WROW
WROW = 0
While [M:JALK]OPENUM(WROW) <> 0
  WROW += 1
Wend
If WROW = 0
    Return
Endif
# Calcul Gant.t
Local Char    WNAM      : WNAM = "Chart_horiz_1"
Local Decimal WSETD(WROW)
Local Decimal WSETF(WROW)
Local Decimal WRUND(WROW)
Local Decimal WRUNF(WROW)
Local Decimal WWAID(WROW)
Local Decimal WWAIF(WROW)
Local Char    WABS(8)(WROW)
Local Char    WORD(20)(6)
Local Char    WTIT(80)
Local Char    WFOO(80)
Local Char    WTXTQ(20)
Local Integer I, J
#
# Constitution table dates début et fin temps prep et fab et labels abscisses
LDAT = [M:JALK]OPESTRDAT(0)
For I = 0 To WROW-1
  WABS(I)  = num$([M:JALK]OPENUM(I))
  WSETD(I) = ([M:JALK]OPESTRDAT(I)-LDAT)+[M:JALK]OPESTRFRD(I)
  WSETF(I) = WSETD(I) + [M:JALK]CLCPRPDUR(I)
  WRUND(I) = WSETF(I)
  WRUNF(I) = WSETF(I) + [M:JALK]CLCWORDUR(I)
  WWAID(I) = WRUNF(I)
  WWAIF(I) = WRUNF(I) + [M:JALK]CLCAFTDUR(I)
Next I
# Constitution table labels ordonnées
Call TEXTFIC("ROUOPE","PRPTIM",2,WORD(0)) From OBJDIV
WORD(1) = " "
Call TEXTFIC("ROUOPE","OPETIM",2,WORD(2)) From OBJDIV
WORD(3) = " "
Call TEXTFIC("ROUOPE","WAITIM",2,WORD(4)) From OBJDIV
WORD(5) = " "
Call TEXTFIC("MFGHEAD","EXTQTY",2,WTXTQ) From OBJDIV
# Composition titre et bas page
If LTIT = ""
  WTIT = mess(155,195,1)-"/"-mess([M:MFOS]SCDMOD,334,1)
Else
  WTIT = LTIT
Endif
WFOO = [F:MFG]MFGNUM-"/"-[F:MFG]ROUNUM-"/"-num$(LALT)-WTXTQ+" : "+num$([F:MFG]EXTQTY)
# Ouverture graphe
Call OPEN_CHART(WNAM,0,0,340,200,6,1,WROW,1,WTIT,WFOO,0) From ATRTX3
# Chargement des données
Call DATA_CHART(1,1,WSETD,0,0) From ATRTX3
Call DATA_CHART(2,1,WSETF,0,0) From ATRTX3
Call DATA_CHART(3,1,WRUND,0,0) From ATRTX3
Call DATA_CHART(4,1,WRUNF,0,0) From ATRTX3
Call DATA_CHART(5,1,WWAID,0,0) From ATRTX3
Call DATA_CHART(6,1,WWAIF,0,0) From ATRTX3
# Chargement titres
Call LABELX_CHART(1,1,WABS,0) From ATRTX3
Call LABELC_CHART(1,1,WORD,0) From ATRTX3
# Affichage
Call DISPLAY_CHART(1,1,1,0,0,0) From ATRTX3
Return

