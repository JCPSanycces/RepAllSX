########################################
Subprog D_NBRCCE

  [M]NBRCCE=[M:FPC]NBDIE                 : # Gestion des Sections analytiques : gestion du tableau en création

  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
    [M]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
  Next I_DIE

  Affzo DIE

End

################################################################################
##
##
##
##   GESTION DES ZONES SITE/BATIMENT/ETAGE/PIECE
##
##   Types de données : BLS, BLB, BLE, BLP
##
################################################################################
########################################
Subprog CONT_LOC_SUP(PLVL, PCOD, PSUP, PRET)
# Contrôle que le code d'une zone de niveau (x) dépend du code de la zone (x-1)
# PRET=0 si c'est le cas.
Value    Integer PLVL            : # Niveau à contrôler
Value    Char    PCOD            : # Code à contrôler dans la zone PLVL
Value    Char    PSUP            : # Code précédent dans la zone PLVL-1
Variable Integer PRET            : # Code retour
                                 : #  0=Ok
                                 : #  1=Niveau invalide (plutôt bug)
                                 : # 11=Table ou code inexistant
                                 : # 21=Parent du code, différent du parent passé

Local Integer NUMTAB

  If clalev([F:WADI])=0 : Local File ATABDIV  [WADI] : Endif
  PRET = 0
  Case PLVL
    When 2       : NUMTAB = GTD_BATIMENT
    When 3       : NUMTAB = GTD_ETAGE
    When 4       : NUMTAB = GTD_PIECE
    When Default : PRET   = 1
  Endcase
  If PRET = 0 Then
    Read [WADI]CODE=NUMTAB;PCOD
    If fstat Then
      PRET = 11
    Endif
    If !PRET Then
      If PLVL <= 2 Then
        If [F:WADI]A1 <> PSUP Then
          PRET = 21
        Endif
      Else
        If [F:WADI]DEPCOD <> PSUP Then
          PRET = 21
        Endif
      Endif
    Endif
  Endif
End

################################################################################
# PARTIE SUR LES LISTES DE SELECTION
################################################################################
$ACTION
  Case ACTION
    When  "SEL_LISTE"      : Gosub SEL_LISTE
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_LISTE
  Case LISTE
    When "SELCPYFCY"       : Gosub SET_CPYFCY : # Sociétés juridiques autorisées
  Endcase
Return

#-------------------------------------------------------------------------------
$SET_CPYFCY
# ******  Liste sociétés juridiques autorisée  *************
  NBTEX = 0
  Call TITOBJ("CPY","!",TIT(0)) From CONTOBJ
  TIT(0)  = mess(12,123,1)-TIT(0) : # Choix

  If clalev([F:WCPY])=0 : Local File COMPANY [WCPY] : Endif

  Local Integer MAXCPY
  [L]MAXCPY=rowcount([F:WCPY])
  Local Char TEX(50)(0..MAXCPY) , TEXTE(80)(1..MAXCPY,1..2)

  TIT(1) = mess(143,7773,1) : # Société
  TIT(2) = mess(15,7771,1)  : # Désignation

  For [F:WCPY] Where CPYLEGFLG=2
    mkstat = 0
    Call CONTCPY([F:WCPY]CPY) From SUPCPT
    If !mkstat
      NBTEX         += 1
      TEX(NBTEX)     = [F:WCPY]CPY
      TEXTE(NBTEX,1) = [F:WCPY]CPY
      TEXTE(NBTEX,2) = [F:WCPY]CPYNAM
    Else
      # Pour ne pas provoquer de message d'erreur lorsque la société n'est pas autorisée
      OK=0 : mkstat=0 : GMESSAGE=""
    Endif
  Next
Return
