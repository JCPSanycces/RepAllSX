#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################
#    GESTION DE TYPES DE DONNEES RELATIF A LA SOCIETE-CPY ET ETABLISSEMENT-FCY
#
#    Création le : 20/02/2003
#    Modification V5
#       MDJ - 09.02.2015  FQ100398   Suppression site géographique
#       MWA - 10.09.2014  FQ95754_4  Classement pour vente uniquement s'il existe au moins un plan normé IAS/IFRS
#       CBO - 13/10/2014 - FQ79743 - Paramètres CREDIRLOF et CREDIRFAS paramétrables au niveau SOC ou LEG
#       GLE - 06/12/2013 - FQ95063 - Alimentation des globales GFASLEDSOC et GFASLEDIAS fausse si le ref Compta n'est pas le premier
#                                    du modèle ou si le ref IAS n'est pas le troisième du modèle
#       GLE - 10/07/2013 - FQ90794 - Vérification que la société passée en paramètre de LOAD_FASPARCPY est bien alimentée
#       MWA - 2012.05.21 - FQ67621 - Initialisation de GCURLEG
#       CBO - 2012.03.08 - FQ80212 - find d'1 tableau trop grand dans un filter
#       GBO - 10.03.2011 - FQ72245 - Problème alimentation du taux de TVA facturée en création de bien
#       GBO - 15/11/2010 - Fq65071 - Chargement des intitulés court et long des axes analytiques
#       GBO - 23/09/2010 - FQ67467 - Pas de raz du tableau des axes analytiques dans FASPARCPY
#       GLE - 26/08/2010 - FQ66890 - Champs IFRS affichés à tort lorsque le code activité IAS est à Non
#       GLE - 08/07/2010 - FQ65632 - Mauvaise détermination du référentiel IAS
#       GLE - 23/06/2010 - FQ65623 - Certification NF NC28 : Création des dépenses en direct
#       GLE - 10/03/2010 - FQ63185 - Ajout de la devise société et des devises du référentiel
#       MWA - 11/02/2010 - FQ54343 - Gestion des concessions
#       GLE - 05/02/2010 - FQ56093 - Possibilité de gérer le site d'inventaire au niveau société
#       GLE - 12/01/2010 - FQ61531 - Suite 59480 : si on "tasse" le tableau des référentiel dans FPC, l'indice [FPC]IASLEDTYP ne pointe
#                                    plus sur la bonne ligne. Il faut laisser un trou dans le tableau.
#       GLE - 21/12/2009 - FQ61091 - Modification du chargement des axes analytique dans le masque FPC
#       GLE - 03/11/2009 - FQ59480 - Pb chargement masque FPC lorsqu'un type de référentiel n'a pas de référentiel
#       GLE - 07/10/2009 - FQ58514 - correction erreur GLEDTYPGEN(0) ou signe débordement adressage en import
#       GBO - 25/09/2009 - FQ58081 - Erreur sur ventilations analytiques
#     MABON - 04/05/09   - FQ55586 - Confidentialité sur le site
#       MDJ   13/08/2007 (mdj*V5)  - Adaptations pour V5
################################################################################

################################################################################
Subprog INIT_FCY
  Local Char BIDSOC (GLONCPY), BIDFCY(GLONFCY)

  If GCOUSIT <> ""
    BIDFCY = GCOUSIT     : # On charge l'environnement correspondant au dernier site lu (REMAFCY à OUI)
  Elsif GFCYDEF(14) <> ""
    BIDFCY = GFCYDEF(14) : # On charge l'environnement correspondant au site par défaut du module Immobilisation
  Else
    BIDFCY = GFINSITE(1) : # On charge l'environnement correspondant au premier site financier
  Endif
  Call ACTION_FCY (BIDFCY, BIDSOC)
End

################################################################################
Subprog ACTION_FCY (PFCY, RCPY)
Value    Char PFCY
Variable Char RCPY

  If PFCY = "" Then
    End : # Pas de site : On quitte
  Endif
  If PFCY = GCOUSIT Then
    RCPY = GCOUSOC
    End  : # Environnement déjà chargé : On quitte
  Endif

  If GREMAFCY <> G_NON : GCOUSIT = PFCY : Endif

  Call GET_DEV(PFCY)

  GCOUSOC = GSOCIETE
  RCPY    = GSOCIETE
  GCOUDEV = GLOCALDEV

  Call CHARGE_ENVIRONNEMENT ()
  Call AFFICHE_STATUS ()
End

################################################################################
Subprog ACTION_CPY (PCPY)
Value Char PCPY

Local Integer LSITE

  If PCPY = GCOUSOC and GCOUSOC <> "" : End : Endif   : # Environnement déjà chargé : On quitte
  If PCPY = "" Then
    # Pas de société on quitte, sur les objets de paramétrage la société n'est pas tj obligatoire !
    Raz GCOUSOC
    Raz GCOUSIT
    Raz GCOUDEV
    Call RAZ_ENVIRONNEMENT()
    End
  Endif
  LSITE = find(PCPY,GSOCSITE(1..GNBSITE))
  If LSITE <> 0 Then
    If GREMAFCY <> G_NON : GCOUSIT = GFINSITE(LSITE) : Endif
    Call GET_DEV(GCOUSIT)
    GCOUSOC = GSOCIETE
    GCOUDEV = GLOCALDEV

    Call CHARGE_ENVIRONNEMENT ()
    If !GSERVEUR
      Call AFFICHE_STATUS ()
    Endif
  Endif
End

################################################################################
Subprog GET_DEV (SITE)
Value Char SITE
  Call GET_SOC(SITE)
  GISOC = find(GSOCIETE,GSOC(1..GNBSOC))
  If GISOC
    GLOCALDEV = GDEVSOC(GISOC)
  Else
    GLOCALDEV = "EUR" : # Devise par défaut en cas de pb
  Endif
  If clalev([F:TCU])>0
    Call LECTURE("TCU",GLOCALDEV,"") From CONTOBJ
  Endif
End

################################################################################
#*! Syracused in cashed class AFCY
#*!  Local char LCPY(GLONCPY)
#*!  LCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR("site","LEGCPY")
Subprog GET_SOC(SITE)
Value    Char SITE
Local Integer ISITE
  ISITE = find(SITE,GSITE(1..GNBSITE))
  If ISITE
    GSOCIETE = GSOCSITE(ISITE)
    GFINRSP  = GFINSITE(ISITE)
  Else
    GSOCIETE = GDEFSOC
    GFINRSP  = GDEFFIN
  Endif
End

################################################################################
Funprog GET_SOC_PAYS(PCPY)
Value    Char PCPY
Local Char RCRY
 If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
 Read [CPY]CPY0=PCPY
 If fstat
  RCRY = ""
 Else
  RCRY = [F:CPY]CRY
 Endif
End RCRY

################################################################################
Funprog GET_SOC_LEG(PCPY)
Value    Char PCPY

Local Char RLEG
 RLEG = GLEGSOC(find(PCPY,GSOC))
End RLEG

#@dev-Remplacer l'affectation en dur par l'accès à la table des correspondances
#     entre société et référentiels
################################################################################
Funprog GET_SOC_LED(PCPY,PTYPLED)
Value Char  PCPY
Value Char  PTYPLED

Local Char RLED

Case PTYPLED
 When "SOC"
  RLED="SOC"
 When "IAS"
  RLED="IAS"
Endcase

End RLED

################################################################################
# Sous programme de chargement du paramétrage d'une société dans le masque
# de travail FASPARCPY :
#
#    - Modèle comptable
#    - Liste des référentiel
#    - Liste des axes analytiques
#
#  Codes retour
#
#    1 - Masque non ouvert
#
################################################################################
Subprog LOAD_FASPARCPY(PCPY,PABR,PFORCELOAD,RERROR)
Value    Char    PCPY
Value    Char    PABR
Value    Integer PFORCELOAD : # FQ58514
Variable Integer RERROR

Local Char LABR

# FQ90794
If PCPY=""
  RERROR=2
  End
Endif

If LABR=""
 LABR="FPC"
Endif

If evalue("dim([M:"+LABR+"]CPY)<0")
 RERROR=1
 End
Endif

If PFORCELOAD<>G_OUI & PCPY=evalue("[M:"+LABR+"]CPY")
 End
Endif

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:LED]) : Local File GLED    [LED] : Endif
If !clalev([F:GCM]) : Local File GACM    [GCM] : Endif
If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
Local Char LNOMCHAMP(150)
Global Integer GTYPLED(1..10)   : #FQ-67625  Types référentiels redéclarée car killée dans SUBBICS (Tiers)
#> Initialisations
# FQ67467
Local Integer I_DIE
For I_DIE=1 To evalue ("[M:"+LABR+"]NBDIE")
 LNOMCHAMP="[M:"+LABR+"]DIE("+num$(I_DIE)+"-1)"        : Assign LNOMCHAMP With ""
 LNOMCHAMP="[M:"+LABR+"]DIECOA("+num$(I_DIE)+"-1)"     : Assign LNOMCHAMP With ""
 LNOMCHAMP="[M:"+LABR+"]OBYDIE("+num$(I_DIE)+"-1)"     : Assign LNOMCHAMP With G_NON
Next I_DIE
LNOMCHAMP="[M:"+LABR+"]NBDIE"                          : Assign LNOMCHAMP With 0


#> Société / Modèle comptable
LNOMCHAMP="[M:"+LABR+"]CPY"    : Assign LNOMCHAMP With PCPY
Call LECTURE("CPY",PCPY,"") From CONTOBJ
LNOMCHAMP="[M:"+LABR+"]ISOC"   : Assign LNOMCHAMP With find(PCPY,GSOC)
LNOMCHAMP="[M:"+LABR+"]LEG"    : Assign LNOMCHAMP With GLEGSOC(find(PCPY,GSOC))
GCURLEG = GLEGSOC(find(PCPY,GSOC)) : # FQ67621
LNOMCHAMP="[M:"+LABR+"]GCM"    : Assign LNOMCHAMP With evalue("GGCMSOC("+num$(find(PCPY,GSOC))+")")
Call LECTURE("GCM",evalue("[M:"+LABR+"]GCM"),"") From CONTOBJ
If G_ACTIAS<>G_OUI : # FQ66890
  LNOMCHAMP="[M:"+LABR+"]FLGIAS" : Assign LNOMCHAMP With G_NON
Else
  LNOMCHAMP="[M:"+LABR+"]FLGIAS" : Assign LNOMCHAMP With [F:GCM]FLGIAS
Endif
LNOMCHAMP="[M:"+LABR+"]IGCM"   : Assign LNOMCHAMP With find(evalue("[M:"+LABR+"]GCM"),GGCM)
LNOMCHAMP="[M:"+LABR+"]GENLEDTYP"
Assign LNOMCHAMP With evalue("GLEDTYPGEN("+num$(evalue("[M:"+LABR+"]IGCM"))+")")
LNOMCHAMP="[M:"+LABR+"]ANALEDTYP"
Assign LNOMCHAMP With evalue("GLEDTYPANA("+num$(evalue("[M:"+LABR+"]IGCM"))+")")
LNOMCHAMP="[M:"+LABR+"]CURCPY"
Assign LNOMCHAMP With GDEVSOC(find(PCPY,GSOC)) : # FQ63185
If [F:GCM]FLGIAS=G_OUI
 LNOMCHAMP="[M:"+LABR+"]IASLEDTYP"
 # FQ65632
 #Assign LNOMCHAMP With 3
 Assign LNOMCHAMP With [F:GCM]IASLEDTYP
Else
 LNOMCHAMP="[M:"+LABR+"]IASLEDTYP"
 #Effzo =LNOMCHAMP
 #Grizo =LNOMCHAMP
 Assign LNOMCHAMP With 0 : # FQ58514
Endif

#> Tableau des référentiels

Local Integer I_LED
Local Integer LLEDTYP
Local Char    LLED,LCOA
Local Integer I_DIE, IDX_DIE

GFASLEDSOC = "" : # FQ95063
GFASLEDIAS = "" : # FQ95063

For I_LED=1 To 10
 #If evalue("GLED"+num$(I_LED)+"("+num$(evalue("[M:"+LABR+"]IGCM"))+")" )="" : Break : Endif : # FQ59480
 LNOMCHAMP="[M:"+LABR+"]LEDTYP("+num$(I_LED-1)+")" : Assign LNOMCHAMP With I_LED : # FQ61531
 If evalue("GLED"+num$(I_LED)+"("+num$(evalue("[M:"+LABR+"]IGCM"))+")" )<>""
  LLED=evalue("GLED"+num$(I_LED)+"("+num$(evalue("[M:"+LABR+"]IGCM"))+")" )
  Call LECTURE("LED",LLED,"") From CONTOBJ
  LNOMCHAMP="[M:"+LABR+"]LED("+num$(I_LED-1)+")"    : Assign LNOMCHAMP With LLED
  LNOMCHAMP="[M:"+LABR+"]ILED("+num$(I_LED-1)+")"   : Assign LNOMCHAMP With find(evalue("GLED"+num$(I_LED)),GLED)
  LCOA=[F:LED]COA
  LNOMCHAMP="[M:"+LABR+"]COA("+num$(I_LED-1)+")"  : Assign LNOMCHAMP With LCOA
  LNOMCHAMP="[M:"+LABR+"]ANA("+num$(I_LED-1)+")"  : Assign LNOMCHAMP With [F:LED]ANA          #Fq58081.
  LNOMCHAMP="[M:"+LABR+"]CUR("+num$(I_LED-1)+")"  : Assign LNOMCHAMP With [F:GCM]CUR(I_LED-1) #FQ63185.
  If [F:LED]ANA=G_OUI
   Gosub LOAD_DIE
  Endif

  # DEBUT FQ95063
  If evalue("[M:"+LABR+"]GENLEDTYP") = I_LED
   # Référentiel général principal
   LNOMCHAMP="[M:"+LABR+"]COASOC": Assign LNOMCHAMP With evalue("[M:"+LABR+"]COA("+num$(I_LED-1)+")")
   GFASLEDSOC = evalue("[M:"+LABR+"]COASOC")
  Endif
  If ([F:GCM]FLGIAS=G_OUI) and (evalue("[M:"+LABR+"]IASLEDTYP") = I_LED)
   # Référentiel IAS principal
   GFASLEDIAS = evalue("[M:"+LABR+"]COA("+num$(I_LED-1)+")")
  Endif
  # FIN FQ95063
 Endif
Next I_LED

GNBDIE=evalue("[M:"+LABR+"]NBDIE" )

#> Chargement de OBYDIE à partir de la société

If evalue("[M:"+LABR+"]NBDIE<>0")
 For I_DIE=1 To evalue("[M:"+LABR+"]NBDIE")
  IDX_DIE=find(evalue("[M:"+LABR+"]DIE("+num$(I_DIE-1)+")"),[F:CPY]DIE)
  LNOMCHAMP="[M:"+LABR+"]OBYDIE(I_DIE-1)"
  If IDX_DIE<>0
   Assign LNOMCHAMP With max(G_NON,[F:CPY]OBYDIE(IDX_DIE-1))
  Else
   Assign LNOMCHAMP With G_NON
  Endif
 Next I_DIE
Endif
LNOMCHAMP="[M:"+LABR+"]NBLED" : Assign LNOMCHAMP With I_LED-1
#LNOMCHAMP="[M:"+LABR+"]COASOC": Assign LNOMCHAMP With evalue("[M:"+LABR+"]COA(0)")  : # FQ95063 remonté plus haut
Call SETPLAN2(evalue("[M:"+LABR+"]GCM"),GNBCOA,GCOA,GTYPLED,GNBDIE,GDIE,GOBLDIE) From CPTDIV

#> Tableau des plans à utiliser pour récupérer les infos analytiques dans les événements

LNOMCHAMP="[M:"+LABR+"]NBPLN"                     : Assign LNOMCHAMP With 0
LNOMCHAMP="[M:"+LABR+"]DPRPLN([M:"+LABR+"]NBPLN)" : Assign LNOMCHAMP With G301CPT
LNOMCHAMP="[M:"+LABR+"]NBPLN"                     : Assign LNOMCHAMP With evalue("[M:"+LABR+"]NBPLN")+1
If evalue("[M:"+LABR+"]ANALEDTYP>0")
 Local Integer I_LEDANA
 I_LEDANA=evalue("find([M:"+LABR+"]ANALEDTYP,[M:"+LABR+"]LEDTYP)")
 If I_LEDANA
  For I_DIE=1 To 9
   LNOMCHAMP="[M:"+LABR+"]DPRPLNDIE"+num$(I_DIE)+"(0)" : Assign LNOMCHAMP With evalue("[M:"+LABR+"]CCE"+num$(I_DIE)+"("+num$(I_LEDANA-1)+")")
  Next
 Endif
Else
Endif
If [F:GCM]FLGIAS=G_OUI
 LNOMCHAMP="[M:"+LABR+"]DPRPLN([M:"+LABR+"]NBPLN)" : Assign LNOMCHAMP With G301IAS
 LNOMCHAMP="[M:"+LABR+"]NBPLN"                     : Assign LNOMCHAMP With evalue("[M:"+LABR+"]NBPLN")+1
 Local Integer I_LEDANA
 I_LEDANA=evalue("find([M:"+LABR+"]IASLEDTYP,[M:"+LABR+"]LEDTYP)")
 If I_LEDANA
  If evalue("[M:"+LABR+"]ANA("+num$(I_LEDANA-1)+")")
   For I_DIE=1 To 9
    LNOMCHAMP="[M:"+LABR+"]DPRPLNDIE"+num$(I_DIE)+"(1)" : Assign LNOMCHAMP With evalue("[M:"+LABR+"]CCE"+num$(I_DIE)+"("+num$(I_LEDANA-1)+")")
   Next
  Endif
 Endif
Endif

#> Tableau de correspondance plans contexte / plans référentiel

Local Integer I_PLN
LNOMCHAMP="[M:"+LABR+"]NBPLNCNX"                          : Assign LNOMCHAMP With 0
For [CNX] Where CPY=PCPY
 For I_PLN=1 To [F:CNX]NBPLC
  LNOMCHAMP="[M:"+LABR+"]DPRPLNCNX([M:"+LABR+"]NBPLNCNX)" : Assign LNOMCHAMP With [F:CNX]PLNCAA(I_PLN-1)
  # FQ95754_4
  LNOMCHAMP="[M:"+LABR+"]PLNSTD([M:"+LABR+"]NBPLNCNX)"    :  Assign LNOMCHAMP With [F:CNX]PLNSTD(I_PLN-1)
  LNOMCHAMP="[M:"+LABR+"]DPRPLNLED([M:"+LABR+"]NBPLNCNX)"
  Case [F:CNX]ORIBASDPR(I_PLN-1)
   When GVML_OBPCG : Assign LNOMCHAMP With G301CPT
   When GVML_OBSUB : Assign LNOMCHAMP With G301CPT
   When GVML_OBIAS : Assign LNOMCHAMP With G301IAS
   When Default    : Assign LNOMCHAMP With G301CPT
  Endcase
  LNOMCHAMP="[M:"+LABR+"]NBPLNCNX"                        : Assign LNOMCHAMP With evalue("[M:"+LABR+"]NBPLNCNX+1")
 Next I_PLN
Next

#> FQ65623 Chargement des paramètres de création directe autorisée pour les biens et les dépenses
#> pour la legislation française
#FQ79743 GÉNÉRALISATION
#If evalue("[M:"+LABR+"]LEG") = "FRA"
#  Local Char LPARM
#  Call PARAM("","CREDIRLOF",LPARM) From ADOVAL
#  LNOMCHAMP="[M:"+LABR+"]CREDIRLOF" : Assign LNOMCHAMP With val(LPARM)
#  Call PARAM("","CREDIRFAS",LPARM) From ADOVAL
#  LNOMCHAMP="[M:"+LABR+"]CREDIRFAS" : Assign LNOMCHAMP With val(LPARM)
#Else
#  LNOMCHAMP="[M:"+LABR+"]CREDIRLOF" : Assign LNOMCHAMP With G_OUI
#  LNOMCHAMP="[M:"+LABR+"]CREDIRFAS" : Assign LNOMCHAMP With G_OUI
#Endif
  Local Char LPARM(10)
  Call PARAM(PCPY, "CREDIRLOF", LPARM) From ADOVAL
  LNOMCHAMP = "[M:" + LABR + "]CREDIRLOF"
  Assign LNOMCHAMP With val(LPARM)
  If evalue(LNOMCHAMP) <> G_NON
    Assign LNOMCHAMP With G_OUI
  Endif
  Call PARAM(PCPY, "CREDIRFAS", LPARM) From ADOVAL
  LNOMCHAMP = "[M:" + LABR + "]CREDIRFAS"
  Assign LNOMCHAMP With val(LPARM)
  If evalue(LNOMCHAMP) <> G_NON
    Assign LNOMCHAMP With G_OUI
  Endif

##> Alimentation des globales contenant les plans de compte SOC et IAS
#
#GFASLEDSOC = evalue("[M:"+LABR+"]COASOC") : # FQ95063  remonté plus haut
#GFASLEDIAS = evalue("[M:"+LABR+"]COA(2)") : # FQ95063  remonté plus haut

End

#> Tableau des axes analytiques

$LOAD_DIE
 Local Integer I_DIELED, IDX_DIE

 #For I_DIELED=1 To 9 : # FQ61091
 Local Char LDES(80) #Fq65071
 For I_DIELED=1 To [F:LED]DIENBR
  If [F:LED]DIE(I_DIELED-1)<>""
   LNOMCHAMP="[M:"+LABR+"]CCE"+num$(I_DIELED)+"("+num$(I_LED-1)+")"
   Assign LNOMCHAMP With [F:LED]DIE(I_DIELED-1)
   IDX_DIE=evalue("find([F:LED]DIE(I_DIELED-1),[M:"+LABR+"]DIE)")
   If !IDX_DIE
    LNOMCHAMP="[M:"+LABR+"]DIE([M:"+LABR+"]NBDIE)"    : Assign LNOMCHAMP With [F:LED]DIE(I_DIELED-1)
    LNOMCHAMP="[M:"+LABR+"]DIECOA([M:"+LABR+"]NBDIE)" : Assign LNOMCHAMP With mess((evalue("[M:"+LABR+"]LEDTYP("+num$(I_LED-1)+")")),2644,1)
    #Fq65071-Ajout intitulés court et long des axes
    Call LECTEXTRA(LDES,"GDIE","DESTRA",evalue("[M:"+LABR+"]DIE([M:"+LABR+"]NBDIE)"),"") From ATEXTRA
    LNOMCHAMP="[M:"+LABR+"]DIEDES([M:"+LABR+"]NBDIE)" : Assign LNOMCHAMP With LDES
    Call LECTEXTRA(LDES,"GDIE","SHOTRA",evalue("[M:"+LABR+"]DIE([M:"+LABR+"]NBDIE)"),"") From ATEXTRA
    LNOMCHAMP="[M:"+LABR+"]DIEDESSHO([M:"+LABR+"]NBDIE)" : Assign LNOMCHAMP With LDES
    #Fq65071-Fin
    LNOMCHAMP="[M:"+LABR+"]NBDIE"                     : Assign LNOMCHAMP With evalue("[M:"+LABR+"]NBDIE")+1
    GDIE(evalue("[M:"+LABR+"]NBDIE"))=evalue("[M:"+LABR+"]DIE([M:"+LABR+"]NBDIE-1)")
   Else
   LNOMCHAMP="[M:"+LABR+"]DIECOA("+num$(IDX_DIE-1)+")" : Assign LNOMCHAMP With
&                                                        evalue("[M:"+LABR+"]DIECOA("+num$(IDX_DIE-1)+")")+";"+mess((evalue("[M:"+LABR+"]LEDTYP("+num$(I_LED-1)+")")),2644,1)
   Endif
  Endif
 Next I_DIELED

Return


######################################################################################
## Ecran FASPARCPY
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
 Local Integer ERROR
 #Effzo [M:FPC]
 Raz [M:FPC]
 Call LOAD_FASPARCPY(VALEUR,"FPC",G_NON,ERROR)
 Affzo [M:FPC]
End



################################################################################
Subprog AFFICHE_STATUS ()

Local Char MSG

  # 30 caractères maximum
  MSG = mess(109,7773,1)-format$("DD2",GDEBEXECPF)-'-'-format$("DD2",GFINEXECPF)-mess(110,7773,1)-GCNXCURCPF
  Inftxt MSG At 2
End

################################################################################
Subprog RAZ_ENVIRONNEMENT ()

  # Initialisation IAS
  GCNXPROIAS = G_NON
  GCNXIAS    = 0
  GCNXCURIAS = ""
  GDEBEXEIAS = [0/0/0]
  GFINEXEIAS = [0/0/0]

  # Initialisation comptable/fiscal
  GCNXPROCPF = G_NON
  GCNXCURCPF = ""
  GDEBEXECPF = [0/0/0]
  GFINEXECPF = [0/0/0]
  GFINPE1CPF = [0/0/0]
  GFINPERCPF = [0/0/0]
  GDEBEXSCPF = [0/0/0]
  GFINEXSCPF = [0/0/0]
  GFINPESCPF = [0/0/0]
  Raz GCNXDEV

  Raz GCNXUO
  GDEBEXEUO  = [0/0/0]

  # Initialisation des globales des paramètres de niveau site ou société
  Local Integer EXISTE_ADX
  If clalev([F:ADI])  = 0 : Local File ATABDIV     [ADI]  : Endif : # Tables diverses
  For [ADI]CODE Where NUMTAB=901
    Call EXISTE_ADX("","","WWGLOB"+[F:ADI]CODE,EXISTE_ADX) From ORDSYS
    If EXISTE_ADX Then
      Call GLOBVAR("") From ="WWGLOB"+[F:ADI]CODE
    Endif
  Next

  #Effzo [M:FPC]
  Raz [M:FPC]

End

################################################################################
Subprog CHARGE_ENVIRONNEMENT ()
  Local Char LPARAM

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
  If clalev([F:FIS])  = 0 : Local File FISCYEAR    [FIS]  : Endif : # Exercices
  If clalev([F:ADI])  = 0 : Local File ATABDIV     [ADI]  : Endif : # Tables diverses

  Raz GCNXDEV

  # Initialisation GCNXUO
  Raz GCNXUO
  Filter [CNX] Where CPY=GSOCIETE  and FLGCNXUO=G_OUI
  Read [CNX] First
  Filter [CNX]
  If !(fstat) Then
    GCNXUO    = [F:CNX]CNX
    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 Last
    Filter [FIS]
    GDEBEXEUO = [F:FIS]DATSTRFIY
  Endif

  # Initialisation IAS
  GCNXPROIAS = G_NON
  GCNXIAS    = 0
  GCNXCURIAS = ""
  GDEBEXEIAS = [0/0/0]
  GFINEXEIAS = [0/0/0]
   For [CNX] Where CPY=GSOCIETE
     I= find(G301IAS,[F:CNX]PLNCAA(0..14))
     If ( I > 0 ) Then
       GCNXPROIAS = G_OUI
       GCNXIAS    = [F:CNX]CNX
       GCNXCURIAS = [F:CNX]CUR
       #-----------------------
       Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
       Read [FIS]FIY0 Last
       Filter [FIS]
       #-----------------------
       GDEBEXEIAS       = [F:FIS]DATSTRFIY
       GFINEXEIAS       = [F:FIS]DATENDFIY
       GCNXDEV(G300IAS) = [F:CNX]CUR
       Break
     Endif
    # ------------------------------
    # Suite de la boucle
  Next

  # Initialisation comptable/fiscal
  GCNXPROCPF = G_NON
  GCNXCURCPF = ""
  GDEBEXECPF = [0/0/0]
  GFINEXECPF = [0/0/0]
  GFINPE1CPF = [0/0/0]
  GFINPERCPF = [0/0/0]
  GDEBEXSCPF = [0/0/0]
  GFINEXSCPF = [0/0/0]
  GFINPESCPF = [0/0/0]
  For [CNX] Where CPY=GSOCIETE and CNX=G300CPFI
    GCNXPROCPF = G_OUI
    GCNXCURCPF = [F:CNX]CUR
    #-----------------------
    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 Last
    Filter [FIS]
    #-----------------------
    GDEBEXECPF = [F:FIS]DATSTRFIY
    GFINEXECPF = [F:FIS]DATENDFIY
    GFINPE1CPF = [F:FIS]DATENDPER(0)
    If ( [F:FIS]INDCURPER > 0 ) Then
       GFINPERCPF = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Else
      GFINPERCPF = [F:FIS]DATENDPER(0)
    Endif
    #-----------------------
    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV
    Read [FIS]FIY0 Last
    Filter [FIS]
    #-----------------------
    GDEBEXSCPF        = [F:FIS]DATSTRFIY
    GFINEXSCPF        = [F:FIS]DATENDFIY
    GCNXDEV(G300CPFI) = [F:CNX]CUR
    GCNXDEV(0)        = [F:CNX]CPY
    #-----------------------
    If ( [F:FIS]INDCURPER > 0 ) Then
       GFINPESCPF = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Else
      GFINPESCPF = [F:FIS]DATENDPER(0)
    Endif

    # FQ54343
    If ( G_ACTCCN= G_OUI ) Then
      G_CCNFLG    = [F:CNX]CCNFLG
      If ( [F:CNX]CCNMOD = GVML_GCRNW ) Then
        G_CCNRPR    = G_OUI
        G_CCNPLNIND = [F:CNX]CCNINDPLN
        G_CCNPLNCAD = [F:CNX]CCNCADPLN
        G_CCNPLNSUB = 0
        If ([F:CNX]CCNGRTFLG= G_OUI ) Then
         G_CCNSUB   = G_OUI
         G_CCNPLNSUB= [F:CNX]CCNGRTPLN
        Endif
      Else
        G_CCNRPR    = G_NON
        G_CCNSUB    = G_NON
        G_CCNPLNIND = 0
        G_CCNPLNCAD = 0
        G_CCNPLNSUB = 0
      Endif
    Endif

  Next

  # Initialisation des globales des paramètres de niveau site ou société
  Local Integer EXISTE_ADX
  For [ADI]CODE Where NUMTAB=901
    Call EXISTE_ADX("","","WWGLOB"+[F:ADI]CODE,EXISTE_ADX) From ORDSYS
    If EXISTE_ADX Then
      Call GLOBVAR(GCOUSOC) From ="WWGLOB"+[F:ADI]CODE #Fq72245-On remplace GCOUSIT pas toujours alimenté (REMAFCY=NON) par GCOUSOC
    Endif
  Next

  # Détermination des référentiels PCG et IAS pour la société
  #@dev - A brancher sur la table à venir faisant le lien entre X3 et ABX3.

 #GFASLEDSOC="FRA"#func GLOFCYCPY.GET_SOC_LED(GSOCIETE,"SOC")
 #GFASLEDIAS="IAS"#func GLOFCYCPY.GET_SOC_LED(GSOCIETE,"IAS")

  Raz [M:FPC]
  Local Integer ERROR
  Call LOAD_FASPARCPY(GSOCIETE,"",G_NON,ERROR) From GLOFCYCPY
  If ERROR
  Endif

End

################################################################################
Funprog GET_DEVISE_CNX (PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX

Local Char    LDEVISE(GLONCUR)

  If GCNXDEV(0) = "" Then
    Raz GCNXDEV
    GCNXDEV(0) = PCPY
  Endif
  If GCNXDEV(0) <> PCPY Then
    Raz GCNXDEV
    GCNXDEV(0) = PCPY
  Endif

  If GCNXDEV(PCNX) <> "" Then
    LDEVISE = GCNXDEV(PCNX)
  Else
    Local File CONTEXT [CZZ] : # Contextes
    Read [CZZ]CNX0=GCNXDEV(0);PCNX
    If fstat Then
      LDEVISE     = ""
    Else
      LDEVISE     = [F:CZZ]CUR
    Endif
    GCNXDEV(PCNX) = LDEVISE
  Endif
End LDEVISE

################################################################################
Funprog GET_DEVISE_PLN (PCPY, PPLN)
Value Char    PCPY
Value Integer PPLN

Local Char    LDEVISE(GLONCUR)
Local Integer LCNX

  Call GET_CNX_FROM_PLAN (PCPY, PPLN, LCNX) From GLOBIENS
  If LCNX > 0 Then
    LDEVISE = func GLOFCYCPY.GET_DEVISE_CNX (PCPY, LCNX)
  Else
    LDEVISE = ""
  Endif
End LDEVISE

################################################################################
#
Subprog GET_CPY_CUR(PCPY,RCUR,RCURLIB)
#
# Sous-programme permettant de récupérer le code et le libellé de la devise
# de gestion de la société passée en paramètre
################################################################################
Value    Char PCPY     # Société
Variable Char RCUR     # Devise de la société
Variable Char RCURLIB  # Libellé de la devise

 If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
 If !clalev([F:TCU]) : Local File TABCUR  [TCU] : Endif

 Read [CPY]CPY0=PCPY
 If !fstat
  Read [TCU]TCU0=[F:CPY]ACCCUR
  If !fstat
   RCUR    = [F:TCU]CUR
   RCURLIB = [F:TCU]CURDES
  Endif
 Endif

End

################################################################################
Funprog IS_CPYFCY_OK (PCPY,PFCY)
#
# Sous-programme permettant de contrôler que le société et le site passés en
# paramètres correspondent bien (le site doit être rattaché à la société)
################################################################################
Value Char PCPY()
Value Char PFCY()

  Local Integer ISITE, OK

  # Recherche de la société du site
  ISITE = find(PFCY,GSITE(1..GNBSITE))
  If !ISITE | PCPY <> GSOCSITE(ISITE)
    GMESSAGE = mess(58,7772,1) : # Site financier et société incompatibles
    OK = 0
  Else
    OK = 1
  Endif

End OK

