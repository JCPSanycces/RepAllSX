#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
#  PJMSIH : Simulation and test of creation of invoice from a project  #
##########################################################################
# DAHOF 08/07/16                                                         #
##########################################################################
Subprog EXEC(HDOCNUM)
Variable Char HDOCNUM

  Gosub PJM_CONTEXT
  Call OUVRE_TRACE("PJMSIH : "+PJM_MES(1)) From LECFIC

  Onerrgo TRT_ERR
      Call ECR_TIME("PJMSIH : "+mess(213,124,1)+" SINVOICE / SINVOICED / SINVOICEV") From DOSSUB
      Call PJM_SINVOICE(HDOCNUM)

  Onerrgo

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC

  # Issue X3-7539/119856 - 2016-11-22 By TEJAC/FGR : BEGIN
  If HDOCNUM = AVOID.ACHAR Then
    GMESSAGE = mess(459,2260,1)
    GERR = 1
    GOK = 0
  Endif
  # Issue X3-7539/119856 - 2016-11-22 By TEJAC/FGR : END
End

#########################################################################
Subprog PJM_SINVOICE(HDOCNUM)
  Variable Char HDOCNUM
#  Local Integer ZFSTAT # Issue X3-3418/119268 - 2016-10-19 by TEJAC

  Local Integer LCOD      : LCOD=1                : # 1=Création complète / 2=Garnissage uniquement des classes [M]
  Local Char    LMAJ(1)   : LMAJ="C"              : # C=Création
  Local Integer LECH      : LECH=1                : # LECH=Création des echeances (1=Non / 2=Oui)
  Local Integer LTEST     : LTEST=2               : # 1=Pas ecriture du fichier trace / 2=Ecriture de la trace
  Local Char    LTRT(8)   : LTRT="PJMSIH"       : # Traitement contenant les actions appelees par TRTVENCDEG
  Local Char    LORINUM(GLONVCR)                  : # No du document origine ( utilisation facultative )
  Local Char    LSIVNUM(GLONVCR)                  : # No de INVOICE creee
  Local Integer LERR           : LERR=0           : # Code retour erreur
  Local Integer LNBSIH, LNBERR : LNBSIH=0 : LNBERR=0
  Local Char PSONUM(GLONVCR)
  Global Integer PSO_SEQNUM(0..)

  # Issue X3-95109 - 2018-06-25 by FGR : BEGIN
  If fmet GACTX.APARAM.AGETUSERVALNUM("PJMLOGFIL") = [V]CST_AYES Then
    LTEST = 2
  Else
    LTEST = 1
  Endif
  # Issue X3-95109 - 2018-06-25 by FGR : END
  #  ------------------------------------------------
  # build list of keys
#  Gosub BUILD_DETAIL_KEYS           # Issue X3-6201/119572 - 2016-11-04 by TEJAC
  #  ------------------------------------------------
  #--- Ouverture standard documents ventes
  Gosub OPEN_STD

  #--- Ouverture des tables PJM
  Gosub OPEN_PJM

  If dim([M:PSO0]PSONUM) > 0 and [M:PSO0]PSONUM <> ""
    PSONUM = [M:PSO0]PSONUM
  Endif

  Read [F:PSOH]PSOH0 = PSONUM
#  ZFSTAT = fstat                     # Issue X3-3418/119268 - 2016-10-19 by TEJAC :

  If !fstat
    #build list of keys
    Gosub BUILD_DETAIL_KEYS
    #  --------------------------
    If NI > 0 #detail lines found
      Read [OPP]OPP0 = [F:PSOH]OPPNUM
      If !fstat
        Call LEC_BPC([F:OPP]OPPMCN) From CPTLEC
        Call GENSIH (LCOD,LMAJ,LECH, LTEST,LTRT,LORINUM,LSIVNUM,LERR) From TRTVENFACG
        If LSIVNUM <> ""
          HDOCNUM = LSIVNUM
        Endif
      Endif
    Endif
    #  --------------------------
  Endif

  #  ------------------------------------------------
  # Issue X3-3418/119268 - 2016-10-19 by TEJAC : comment
  If dim(PSO_SEQNUM) >= 0
    Kill PSO_SEQNUM
  Endif
  #  ------------------------------------------------

End
#########################################################################
$BUILD_DETAIL_KEYS
  Local  Integer NI

  Filter [F:PSOD] Where PSONUM = [L]PSONUM Order By SEQNUM

  For [F:PSOD]
    PSO_SEQNUM(NI) = [F:PSOD]SEQNUM
    NI += 1
  Next

  Filter [F:PSOD]
Return
#########################################################################
#    Pour GENSIH composant calcul facture
#    chargement masques SOH0 SOH1 SOH2 SOH3 SOH4
#    Actions appelées dans le TRTVENCDEG
#########################################################################
$ACTION_GS
  Case GWACTION_GS
    When "MSK_ENTETE"      Gosub MSK_ENTETE
    When "READ_DETAIL"     Gosub READ_DETAIL
    When "MSK_DETAIL"      Gosub MSK_DETAIL
    When "AP_READ_DETAIL"  Gosub AP_READ_DETAIL
    When "RAZCRE"          Gosub RAZCRE
    When "ERREUR"          Gosub ERREUR
  Endcase
Return
#########################################################################
$AP_READ_DETAIL
  LINTYP(nolign-1) = 1
Return
#########################################################################
$MSK_DETAIL
Local Char WSAU(GLONUOM)
Local Char WPIMNUM(GLONPIM) # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR

  # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR : BEGIN
  # Read [PIM] = [F:OPP]OPPNUM
#  If [F:PSOD]TASCOD <> AVOID.ACHAR Then
#    WPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:PSOD]OPPNUM, [F:PSOD]TASCOD)
#  Elsif [F:PSOD]PBUCOD <> AVOID.ACHAR Then
#    WPIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSOD]OPPNUM, [F:PSOD]PBUCOD)
#  Else
#    WPIMNUM = [F:PSOD]OPPNUM
#  Endif
#  Read [PIM]=WPIMNUM
  # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR : END

  Case IMPZON
    When "ITMREF" : [M]ITMREF(nolign-1) = [F:PSOD]ITMREF
                    # Issue X3-8078/120078 - 2016-11-29 by FGR : BEGIN
                    [M]SIDPSONUM(nolign-1)   = [F:PSOD]PSONUM
                    [M]SIDSEQNUM(nolign-1)   = [F:PSOD]SEQNUM
                    # Issue X3-8078/120078 - 2016-11-29 by FGR : END
    When "ITMDES" : [M]ITMDES(nolign-1) = [F:PSOD]ITMDES
    When "SAU"    : [M]SAU(nolign-1)    = [F:PSOD]SAU
    When "QTY"    : [M]QTY(nolign-1)    = [F:PSOD]QTY
    When "GROPRI" : [M]GROPRI(nolign-1) = [F:PSOD]BASPRI
    When "PJT"    : [M]PJT(nolign-1)    = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM,[F:PSOD]SEQNUM)      #OPPNUM                 # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR
    When "DPJT"   : [M]DPJT(nolign-1)   = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM,[F:PSOD]SEQNUM)      #WPIMNUM
    When Default
  Endcase

#    When "DPJT"   : [M]DPJT(nolign-1)   = [F:PSOD]OPPNUM
  GCLE=mess(3,40,1)-num$(nolign)-mess(18,7,1)-[M]ITMREF(nolign-1)
Return
#########################################################################
$READ_DETAIL
  nolign = 0 : LIG_DETAIL = "C"

  Read [F:PSOD]PSOD0 = [F:PSOH]PSONUM;PSO_SEQNUM([M]NBLIG)
  If fstat = 0
    LEC_DETAIL = 1
  Else
    LEC_DETAIL = 2
  Endif
Return
#########################################################################
$MSK_ENTETE
  Local Integer WINDVAC
  Local Char    WBPCPYR(GLONBPC)

  Case IMPZON
    When "SALFCY"     :  [M]SALFCY    = [F:PSOH]SALFCY
    When "SIVTYP"     :  [M]SIVTYP    = [F:PSOH]SIVTYP
    When "INVREF"     :  [M]INVREF    = [F:PSOH]DOCREF
    When "INVDAT"     :  [M]INVDAT    = [F:PSOH]DOCDAT
    When "BPCINV"     :  [M]BPCINV    = [F:PSOH]BPCORD
   #When "PJT"        :  [M]PJT       = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM, [F:PSOH]SEQNUM)  # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR # [F:PSOH]OPPNUM
    When "PJT"        :  [M]PJT       = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM, [F:PSOD]SEQNUM)  # Issue X3-8078/120078 - 2016-11-29 by FGR
   #When "DPJT"       :  [M]DPJT      = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM, [F:PSOH]SEQNUM)  # Issue X3-6244/119791 - 2016-11-16 by TEJAC/FGR [F:PSOH]OPPNUM
    When "DPJT"       :  [M]DPJT      = func PJMSQH.LOAD_PJT_HEADER(PJM_DOSSIER, [F:PSOH]PSONUM, [F:PSOD]SEQNUM)  # Issue X3-8078/120078 - 2016-11-29 by FGR
    When "REP"        :  [M]REP       = [F:OPP]OPPREP
    When "CUR"        :  [M]CUR       = [F:PSOH]CUR
    When "CURTYP"     :  [M]CURTYP    = [F:PSOH]CURTYP        # Issue X3-36115/122811 - 2017-05-09 by TEJAC
    When "STRDUDDAT"  :  [M]STRDUDDAT = [F:PSOH]STRDUDDAT     # Issue X3-36115/122811 - 2017-05-09 by TEJAC
    When Default
  Endcase
Return
#########################################################################
$TRT_ERR
  Call ECR_TRACE(errp-"line"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Return
#########################################################################
$PJM_CONTEXT
  Global Char    PJM_MES(250)(300)
  # Issue X3-5085/118901 - 2016-10-06 by FGR : BEGIN length is wrong
  #Global Char    PJM_DOSSIER(6) : PJM_DOSSIER = nomap
  Global Char    PJM_DOSSIER(GLONADS) : PJM_DOSSIER = nomap
  # Issue X3-5085/118901 - 2016-10-06 by FGR : END
  Global Integer GTYPLED         (1..10)  : # Types de référentiel
Return
#########################################################################
$PJM_MES
  PJM_MES(1) = "Creation of a invoice"
Return
#########################################################################
$OPEN_PJM
  If !clalev([F:OPP])    : Local File =PJM_DOSSIER+".OPPOR"      [OPP]    : Endif  : # Project
  If !clalev([F:OPPPJM]) : Local File =PJM_DOSSIER+".OPPORPJM"   [OPPPJM] : Endif  : # PJM Project
  If !clalev([F:PJBU])   : Local File =PJM_DOSSIER+".PJMBUD"     [PJBU]   : Endif  : # Project budget
  If !clalev([F:PSPLD])  : Local File =PJM_DOSSIER+".PJMSALITMD" [PSPLD]  : Endif  : # Saleable products list
  If !clalev([F:PSOH])   : Local File =PJM_DOSSIER+".PJMSOLITMH" [PSOH]   : Endif  : # Sold products list - header
  If !clalev([F:PSOD])   : Local File =PJM_DOSSIER+".PJMSOLITMD" [PSOD]   : Endif  : # Sold products list - detail

  If !clalev([F:PIMPL])   : Local File =PJM_DOSSIER+".PIMPL"      [PIM]     : Endif  : # Pimple project link
Return
#########################################################################
$OPEN_STD
  If !clalev([F:FCY])  : Local File =PJM_DOSSIER+".FACILITY"   [FCY] : Endif  : # Sites
  If !clalev([F:TCA])  : Local File =PJM_DOSSIER+".TABCOUAFF"  [TCA] : Endif  : # Affectation compteurs
  If !clalev([F:AVN])  : Local File =PJM_DOSSIER+".AVALNUM"    [AVN] : Endif  : # Valeur des compteurs
  If !clalev([F:ANM])  : Local File =PJM_DOSSIER+".ACODNUM"    [ANM] : Endif  : # Compteurs documents
  If !clalev([F:ACV])  : Local File =PJM_DOSSIER+".ACTIV"      [ACV]   Endif  : # Codes activites
  If !clalev([F:TCC])  : Local File =PJM_DOSSIER+".TEXCPT"     [TCC] : Endif  : # compteur des textes par table
  If !clalev([F:TXC])  : Local File =PJM_DOSSIER+".TEXCLOB"    [TXC] : Endif  : # Textes clob
  If !clalev([F:AXX])  : Local File =PJM_DOSSIER+".ATEXTRA"    [AXX] : Endif  : # Textes traduisibles

  If !clalev([F:TVC])  : Local File =PJM_DOSSIER+".TABVAC"     [TVC] : Endif  : # Determination des taxes
  If !clalev([F:TCU])  : Local File =PJM_DOSSIER+".TABCUR"     [TCU] : Endif  : # Devises
  If !clalev([F:TVT])  : Local File =PJM_DOSSIER+".TABVAT"     [TVT] : Endif  : # Taxes
  If !clalev([F:TUN])  : Local File =PJM_DOSSIER+".TABUNIT"    [TUN] : Endif  : # Unites
  If !clalev([F:TMD])  : Local File =PJM_DOSSIER+".TABMODELIV" [TMD] : Endif  : # Modes de livraison
  If !clalev([F:TCY])  : Local File =PJM_DOSSIER+".TABCOUNTRY" [TCY] : Endif  : # Pays

  If !clalev([F:BPR])  : Local File =PJM_DOSSIER+".BPARTNER"   [BPR] : Endif  : # Tiers
  If !clalev([F:BPC])  : Local File =PJM_DOSSIER+".BPCUSTOMER" [BPC] : Endif  : # Clients
  If !clalev([F:MVC])  : Local File =PJM_DOSSIER+".BPCUSTMVT"  [MVC] : Endif  : # Mouvements clients
  If !clalev([F:LCM])  : Local File =PJM_DOSSIER+".LASTCUSMVT" [LCM] : Endif  : # Derniers mouvements clients
  If !clalev([F:BPD])  : Local File =PJM_DOSSIER+".BPDLVCUST"  [BPD] : Endif  : # Clients livres
  If !clalev([F:BPA])  : Local File =PJM_DOSSIER+".BPADDRESS"  [BPA] : Endif  : # Adresses
  If !clalev([F:REP])  : Local File =PJM_DOSSIER+".SALESREP"   [REP] : Endif  : # Representants

  If !clalev([F:ITM])  : Local File =PJM_DOSSIER+".ITMMASTER"  [ITM] : Endif  : # Articles
  If !clalev([F:ITS])  : Local File =PJM_DOSSIER+".ITMSALES"   [ITS] : Endif  : # Articles ventes
  If !clalev([F:ITU])  : Local File =PJM_DOSSIER+".ITMBPC"     [ITU] : Endif  : # Articles clients
  If !clalev([F:ITF])  : Local File =PJM_DOSSIER+".ITMFACILIT" [ITF] : Endif  : # Articles sites
  If !clalev([F:ITV])  : Local File =PJM_DOSSIER+".ITMMVT"     [ITV] : Endif  : # Cumuls articles sites
  If !clalev([F:ITG])  : Local File =PJM_DOSSIER+".ITMCATEG"   [ITG] : Endif  : # Categrories articles
  If !clalev([F:BOH])  : Local File =PJM_DOSSIER+".BOM"        [BOH] : Endif  : # Nomenclature entete
  If !clalev([F:BOD])  : Local File =PJM_DOSSIER+".BOMD"       [BOD] : Endif  : # Nomenclature detail

  If !clalev([F:SFI])  : Local File =PJM_DOSSIER+".SFOOTINV"   [SFI] : Endif  : # Elements facturation vente
  If !clalev([F:PRS])  : Local File =PJM_DOSSIER+".PRICSTRUCT" [PRS] : Endif  : # Structure tarifs
  If !clalev([F:SPK])  : Local File =PJM_DOSSIER+".SPRICLINK"  [SPK] : Endif  : # Buffer recherche tarifs vente
  If !clalev([F:SPL])  : Local File =PJM_DOSSIER+".SPRICLIST"  [SPL] : Endif  : # Buffer recherche tarifs vente
  If !clalev([F:PPL])  : Local File =PJM_DOSSIER+".PPRICLIST"  [PPL] : Endif  : # Buffer recherche tarifs vente
  If !clalev([F:SPR])  : Local File =PJM_DOSSIER+".SPREASON"   [SPR] : Endif  : # Motifs tarifs vente
  If !clalev([F:SLT])  : Local File =PJM_DOSSIER+".SALTRS"     [SLT] : Endif  : # Transactions de saisie vente
  If !clalev([F:SVV])  : Local File =PJM_DOSSIER+".SVCRVAT"    [SVV] : Endif  : # Documents vente taxe
  If !clalev([F:SVF])  : Local File =PJM_DOSSIER+".SVCRFOOT"   [SVF] : Endif  : # Documents vente éléments
  If !clalev([F:CAL])  : Local File =PJM_DOSSIER+".CPTANALIN"  [CAL] : Endif  : # Lignes comptables analytiques

  If !clalev([M:ADB1]) : Local Mask =PJM_DOSSIER+".ADRBPC"     [ADB1] : Endif : # Fenetres adresse
  If !clalev([M:ADB2]) : Local Mask =PJM_DOSSIER+".ADRBPC"     [ADB2] : Endif : # -- idem
  If !clalev([M:ADB3]) : Local Mask =PJM_DOSSIER+".ADRBPC"     [ADB3] : Endif : # -- idem
  If !clalev([M:ADI4]) : Local Mask =PJM_DOSSIER+".ADRBPC"     [ADI4] : Endif : # -- idem
  # Issue JIRA 3462 - SAM 119148 - 2016-10-14 by TEJAC : comment
#  If !clalev([M:SIW0]) : Local Mask =PJM_DOSSIER+".SIWRKEPV"   [SIW0] : Endif : # Fenetre stockage donnees entête
  # End issue JIRA 3462
  If !clalev([M:ACL])  : Local Mask =PJM_DOSSIER+".ACLOB"      [ACL]  : Endif : # Gestion des textes clob

  If !clalev([F:GTE])  : Local File =PJM_DOSSIER+".GTYPACCENT" [GTE] : Endif
  If !clalev([F:CAC])  : Local File =PJM_DOSSIER+".GACCCODE"   [CAC] : Endif
  If !clalev([F:GAC])  : Local File =PJM_DOSSIER+".GACCOUNT"   [GAC] : Endif
  If !clalev([F:CON])  : Local File =PJM_DOSSIER+".CONTSERV"   [CON] : Endif
  If !clalev([F:CCE])  : Local File =PJM_DOSSIER+".CACCE"      [CCE] : Endif
Return
#########################################################################
$RAZCRE
  [M]ALLTYP=[F:PSOH]ALLTYP : # On alloue toujours en global
Return
#########################################################################
$ERREUR
  If LERR=4
     GBIDC3=GBIDC3-mess(532,197,1)-[F:SGD]VCRNUM+"   "+mess(18,7,1)-[M:SOH4]ITMREF(nolign-1)
  Endif
Return
#########################################################################
$SHIP_TO_CUSTOMER
  Read [BPD]BPD0 =[F:PSOH]BPCORD;[F:BPC]BPDADD
Return

