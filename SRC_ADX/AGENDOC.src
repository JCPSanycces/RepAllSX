#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################
# AGENDOC
###################################################################
# Génération automatique du squelette de l'aide
# dans la table ADOCUMENT, à partir du dictionnaire étendu de l'objet
#
# AGENDOC splitté en 2 AGENDOC et AGENDOCA à partir v7 car limite atteinte
###################################################################
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("AFC",GBIDC1,GBIDC2) From  GOBJET
End

###################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT     From AGENDOCA
 When "CONTROLE"   : Gosub CONTROLE From AGENDOCA
 When "EXEC"       : Gosub EXEC     From AGENDOCA
 When "FIN"        : Gosub EXEC     From AGENDOCA
 When "FERME"      : Gosub FERME    From AGENDOCA
Endcase
Return

###################################################################
# ETIQUETTES ECRANS
###################################################################
Subprog C_GENDOC(VALEUR)
Variable Integer VALEUR
  #JPGA 12/12/2011 BUG-78621 : Affinage du controle de Génération ADOCUMENT sur une plage de DOC.
  Call CONTROLE_TOUTES_DOC (VALEUR, [M:DIA]ALLTYP, [M:DIA]TYPEDOC, [M:DIA]FUNDEB, [M:DIA]FUNFIN) From AGENLIBA
End

Subprog C_GENFIN(VALEUR)
Variable Integer VALEUR
  #JPGA 09/01/2012 BUG-79154 : Si toutes langues sélectionné : contrôle présence du caractère % dans DIRDOC.
  Call CONTROLE_TOUTES_LAN (VALEUR, [M:DIA]ALLLAN, [M:DIA]REPERT) From AGENLIBA
End


Subprog AS_FUNFIN(VALEUR)
Variable Char VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]FUNDEB
   If VALEUR=""
        If [M]TYPEDOC="AML"
           VALEUR="99999"
        Else
           VALEUR="X"
        Endif
   Endif
Endif
End

Subprog AS_TYPEDOC(VALEUR)
Variable Char VALEUR()
 If VALEUR=""
   VALEUR="AFC"
 Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 Effzo TYPEDOC : Grizo TYPEDOC
 Effzo FUNDEB , FUNFIN : Grizo FUNDEB , FUNFIN
Else
 Actzo TYPEDOC , FUNDEB , FUNFIN
Endif
End

Subprog C_ALLLAN(VALEUR)
Variable Integer  VALEUR
  If VALEUR=2
    Effzo LAN : Grizo LAN
    #JPGA 09/01/2012 BUG-79154 : Si toutes langues sélectionné : contrôle présence du caractère % dans DIRDOC.
    Call CONTROLE_TOUTES_LAN ([M:DIA]GENFIN, VALEUR, [M:DIA]REPERT) From AGENLIBA
  Else
    Actzo LAN
  Endif
End

Subprog AV_ALLLAN(VALEUR)
Variable Integer VALEUR
  #JPGA 21/12/2011 BUG-78568 : Affinage de l'affichage/Grisage des zones si génération HTML à NON.
   Call GRISE_GENFIN([M:DIA]GENFIN) From AGENDOCA
End

Subprog C_HLPFLD(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 Actzo HLPDEB, HLPFIN
Else
 Effzo HLPDEB, HLPFIN : Grizo HLPDEB,HLPFIN
Endif
End

Subprog AP_GENFIN(VALEUR)
Variable Integer VALEUR
   # Grisage des Blocs selon que la Génération du document Final HTML aait été sélectionnée ou non
   Call GRISE_GENFIN(VALEUR) From AGENDOCA
End

Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M:DIA]ALLCREGRP") From AGENLIBA
End
######################################################################################
$VERDOC
#VPO 12/12/08 50994 test version superviseur
If dim(IF_DOCV5)<0
    Global Integer IF_DOCV5
    #cg le 8 janvier 2009
    #IF_DOCV5=pat(func AFNC.PARAM('VERSUP',''),"05v.*")
    #il ne faut pas tester le param VERSUP n a pas cette valeur 05v.***
    # prendre plutot GVERSION qui contient 1.5.* ou 1.6.*
    # valeur = 0 on est en v6 valeur 1 on est en V5
    IF_DOCV5=pat(GVERSION,"1.5.*")
Endif
# JPGA-Bug 54028-31/03/2009 : IF_DOCV6 <> 0 : on est en V6
If dim(IF_DOCV6)<0
    Global Integer IF_DOCV6
    IF_DOCV6=pat(GVERSION,"1.6.*")
Endif
# JPGA-Bug 70497-31/12/2010 : IF_DOCV7 <> 0 : on est en V7
If dim(IF_DOCV7)<0
    Global Integer IF_DOCV7
    IF_DOCV7=pat(GVERSION,"1.7.*")
Endif
# TCH-Maj pour AKIRA : IF_DOCV8 <> 0 : on est en V8
If dim(IF_DOCV8)<0
    Global Integer IF_DOCV8
    IF_DOCV8=pat(GVERSION,"1.8.*")
Endif
# TCH-Maj pour AMBAS : IF_DOCV9 <> 0 : on est en V9
If dim(IF_DOCV9)<0
    Global Integer IF_DOCV9
    IF_DOCV9=pat(GVERSION,"1.9.*")
Endif
# TCH-Maj pour AVENG : IF_DOCV0 <> 0 : on est en V10
If dim(IF_DOCV0)<0
    Global Integer IF_DOCV0
    IF_DOCV0=pat(GVERSION,"1.9.*")
    IF_DOCV9=0
Endif
#JPGA 20/12/2013 EXI-95405-1 : Positionnement de VERMAJ en amont afin de pouvoir utiliser les Sous-programmes par d'autres dossiers
If dim([L]VERMAJ)<=0
  Local Integer VERMAJ
  [L]VERMAJ=val(mid$(GVERSION,3,1))+1
Endif
Return

