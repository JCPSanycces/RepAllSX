#<AdxTL>@(#)5.0.0.0 $Revision$
################################################################################################################
# Routage Recherche Destinataire ou Tiers Destinataire                    Module CRM          01 décembre 2000 #
################################################################################################################

$ACTION
Case ACTION
 When "CONTROLE"     : BOITE = GSZWNDADD
 When "OUVRE"        : Gosub OUVRE From =GSZPROGADD
 When "DEFBOUT"      : Gosub DEFBOUT From =GSZPROGADD
 When "SETBOUT"      : Gosub SETBOUT From =GSZPROGADD
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE From =GSZPROGADD
 When "DEBUT"        : Gosub DEBUT From =GSZPROGADD
 When "AV_CHOIX"     : Gosub AV_CHOIX From =GSZPROGADD
 When "AP_CHOIX"     : Gosub AP_CHOIX From =GSZPROGADD
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON From =GSZPROGADD
 When "FINSAI"       : Gosub FINSAI From =GSZPROGADD
 When "FIN"          : Gosub FIN From =GSZPROGADD
 When "ABANDON"      : Gosub ABANDON From =GSZPROGADD
 When "APRES_MODIF"  : Gosub APRES_MODIF From =GSZPROGADD
 When "BOUTON"       : Gosub BOUTON From =GSZPROGADD
 When "MEN"          : Gosub ONMENU From =GSZPROGADD
 When "OK"           : Gosub ONOK From =GSZPROGADD
 When Default
Endcase
Return


