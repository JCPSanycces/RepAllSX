GBIDC1="" : GBIDC2="" : GFLAG="LIN"
Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
End


########################################################################################################################
## Gestion des cours référentiels
##  Action : SAIRATCUR 
##  Masque : SAICURLED [SCL]
##
##  Paramètres
##   CUR    : Devise de transaction (Zone Courante)
##   CPY    : Société (recherche du modèle comptable)
##   TYPRAT : Type de cours 
##   DAT    : Date de cours 
##   RATMLT : Zone dimensionnée de 0 à Nbr Référentiels => Stock le cours multiplicateur 
##   RATDIV : Zone dimensionnée de 0 à Nbr Référentiels => Stock le cours diviseur
########################################################################################################################
Local Char PARAM(30)(1..4)
Local Char VALEUR
PARAM(1) = "USD"
PARAM(2) = "MPDC1"
PARAM(3) = "1"
PARAM(4) = date$ 
Call SAISIE_CHAR(VALEUR,PARAM,"DSAICUR","SUBSCL","SPESCL") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE
 When "DEBUT"  : Gosub DEBUT
 When "OK"     : Gosub OK
 When "FINSAI" : Gosub FINSAI
 When Default
Endcase
Return


$OUVRE
Local Char    CUR(GLONCUR)     # Devise de pièce (=Zone courante)

Local Integer I, J, K, STAT, INDLED
Local Integer NOLI
Local Char    LED(GLONLED)
Local Char    XRATDIV(20), XRATMLT(20)

Local Date    DATCUR

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
Return


$DEBUT
Raz [M:SCL]

If PARAM(4)="" : PARAM(4) = "00000000" : Endif
DATCUR = PARAM(4)

Call INIT(PARAM(1),PARAM(2),val(PARAM(3)),DATCUR,1)
Gosub CHARG_ZONES_DEV
Gosub INIT_COURS
Affzo [M:SCL]
Return

Subprog INIT(CUR,CPY,TYP,DAT,FLG)
Value Char    CUR()
Value Char    CPY()
Value Integer TYP
Value Date    DAT
Value Integer FLG

# Initialiation des variables
[M:SCL]CURENT  = CUR
[M:SCL]CPY     = CPY
[M:SCL]TYPRAT  = TYP
[M:SCL]DAT     = DAT
[M:SCL]INI     = FLG

# Initialisation des tables 
Call LEC_CPY([M:SCL]CPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC

#Call LECTURE("CPY",[M:SCL]CPY,"") From CONTOBJ
#Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
End


#--------------------------------------------------#
# Affichage des cours devises                      #
#--------------------------------------------------#
#--------------------------------------------------#
# [M]RATDIV  : Cours Diviseur                      #
# [M]CUR     : Devise de transaction/pièce         #
# [M]RATMLT  : Cours multiplicateur                #
# [M]CURLED  : Devise de référentiel               #
#--------------------------------------------------# 
$CHARG_ZONES_DEV 
Local Integer I,J,K,INDCUR, INDRAT

# Afficher une gestion de cours pour chaque référentiel si         
#
#      - Type de cours pièces est à NON et devise de transaction est différente de la devise de référentiel
#       (2 référentiels gérés dans la même devise => cours différent)
#  Devise de transaction            : USD
#  Devise du référentiel Sociale    : EUR  + Type de cours OUI
#  Devise du référentiel Analytique : EUR  + Type de cours OUI
#  Devise du référentiel Reporting  : EUR  + Type de cours NON
#        Cours référentiel '*' (=Sociale&Analytique)  seront saisissables et identique (ex : 1 USD=1.2 EUR)
#        Cours référentiel Reporting pourra être différent donc saisissable            (ex : 1 USD=1.3 EUR)
#
#   OU    
#      - Type de cours pièces est à OUI
#      ET Devise de transaction est différente de la devise de référentiel
#      ET Devise de référentiel n'est pas déjà gérée sous un autre référentiel
#
#
# Chargement des champs relatifs à la conversion devise
# Cours diviseur...
#    Standard (1) : le cours saisi est par rapport à la devise de pièce
#    Cas particulier (2) : Devise de pièce est IN et différent de EURO avec une devise de référentiels OUT 
#                       => saisi des cours par rapport à l'euro
# Cours multiplicateur...
#    Standard (3) : le cours saisi est par rapport à la devise de réfentiels
#    Cas particulier (4) : Devise de référentiels est IN et différent de EURO avec une devise de pièce OUT 
#                       => saisi des cours par rapport à l'euro
#
# Position des devises par rapport à l'Euro
Call SETFLGDEV([M:SCL]CURENT,[M:SCL]CPY,[M:SCL]DAT) From CPTDIV

# Gestion de tous les cours-référentiel du modèle comptable (GNBSTR=0)
#             ou uniquement des cours saisi sous Variable Globale GSTRTYP
#If dim(GNBSTR)>0 & !GNBSTR
# For J=1 To len(mess(0,2644,1))
#  GNBSTR+=1
#  GSTRTYP(GNBSTR) = J
# Next
#Endif

#Gosub RAT_OLD

# Affichage des cours

Case GFONCTION
 When "GESCMM"
  INDCUR=1
  For I=1 To len(mess(0,2644,1))
   J=find(I,GENGTYPLED(1..GENGNBTYPLED))
   If J
    If [F:GCM]LED(GENGTYPLED(J)-1)<>"" & [F:GCM]CUR(GENGTYPLED(J)-1)<>[M:SCL]CURENT
     [M:SCL]CURLED(INDCUR-1)=[F:GCM]CUR(GENGTYPLED(J)-1)                                                                #(3)
     If GCURFLG=1 & [F:GCM]CUR(GENGTYPLED(J)-1)<>GEURO & GLEDFLG(GENGTYPLED(J))=2 : [M:SCL]CURLED(INDCUR-1)=GEURO : Endif         #(4)
     Raz K 
     If (GENGTYPLED(1)-1) & [F:GCM]FLGVCRRAT(GENGTYPLED(J)-1)<>1
      For INDRAT=0 To INDCUR-2
        If [M:SCL]CURLED(INDCUR-1)=[M:SCL]CURLED(INDRAT) & [F:GCM]FLGVCRRAT([M:SCL]LEDTYP(INDRAT)-1)=2
         K=INDRAT+1 : Break
        Endif
      Next
     Endif
     If !K
      [M:SCL]IDT(INDCUR-1)=mess(GENGTYPLED(J),2644,1)
      [M:SCL]LEDTYP(INDCUR-1)=GENGTYPLED(J)
      [M:SCL]CUR(INDCUR-1)=[M:SCL]CURENT                                                                   #(1)
      If GCURFLG=2 & [M:SCL]CURENT<>GEURO & GLEDFLG(GENGTYPLED(J))=1 : [M:SCL]CUR(INDCUR-1)=GEURO : Endif            #(2)
       # Existence de cours passé sous les paramètres de l'action SAIRATCUR => Pré-chargement.
      If [M:SCL]INI      
       [M:SCL]RATMLT(INDCUR-1) = evalue(PARAM(5)+"("+num$(I-1)+")")
       [M:SCL]RATDIV(INDCUR-1) = evalue(PARAM(6)+"("+num$(I-1)+")")
      Endif
      # Information pour effectuer le lien cours et le référentiel (un cours pour x référentiel)
      [M:SCL]LIGLED(I-1)=INDCUR+1
      INDCUR+=1
     Else
       [M:SCL]IDT(K-1) = "*"
       [M:SCL]LIGLED(J-1)= K
     Endif
    Endif
   Endif
  Next
  [M:SCL]NBRC = INDCUR-1
 When Default
  INDCUR=0
  For J=0 To len(mess(0,2644,1))-1
   If [F:GCM]LED(J)<>"" & [F:GCM]CUR(J)<>[M:SCL]CURENT
    [M:SCL]CURLED(INDCUR)=[F:GCM]CUR(J)                                                                #(3)
    If GCURFLG=1 & [F:GCM]CUR(J)<>GEURO & GLEDFLG(J+1)=2 : [M:SCL]CURLED(INDCUR)=GEURO : Endif         #(4)
  
    # Ce cours est il déjà géré sous un autre référentiel ?
    #  Un cours saisi doit être un cours :
    #        - n'ayant pas encore sa devise représentée 
    #      ou
    #        - ayant un Type de référentiel paramétré avec 'Type de cours pièce' à NON

    # Cours indépendant 
    #   - Premier cours du modèle comptable
    #   - Type de référentiel avec un type cours à NON
    #   - Type de référentiel avec un type cours à OUI avec devise non encore présente.
  
    Raz K 
    If J & [F:GCM]FLGVCRRAT(J)<>1
     For INDRAT=0 To INDCUR-1
      If [M:SCL]CURLED(INDCUR)=[M:SCL]CURLED(INDRAT) & [F:GCM]FLGVCRRAT([M:SCL]LEDTYP(INDRAT)-1)=2 : K=INDRAT+1 : Break : Endif
     Next
    Endif
    If !K
     [M:SCL]IDT(INDCUR)=mess(J+1,2644,1)
     [M:SCL]LEDTYP(INDCUR)=J+1
     [M:SCL]CUR(INDCUR)=[M:SCL]CURENT                                                                   #(1)
     If GCURFLG=2 & [M:SCL]CURENT<>GEURO & GLEDFLG(J+1)=1 : [M:SCL]CUR(INDCUR)=GEURO : Endif            #(2)
     # Existence de cours passé sous les paramètres de l'action SAIRATCUR => Pré-chargement.
     If [M:SCL]INI
      If instr(1,PARAM(5),"#")
       XRATMLT = PARAM(5)
       XRATDIV = PARAM(6)
       Call SUBST(XRATMLT,"#",num$(J+1))
       Call SUBST(XRATDIV,"#",num$(J+1))
       NOLI = val(PARAM(7))
       [M:SCL]RATMLT(INDCUR) = evalue(XRATMLT+"("+num$(NOLI)+")")
       [M:SCL]RATDIV(INDCUR) = evalue(XRATDIV+"("+num$(NOLI)+")")
      Else
       [M:SCL]RATMLT(INDCUR) = evalue(PARAM(5)+"("+num$(J)+")")
       [M:SCL]RATDIV(INDCUR) = evalue(PARAM(6)+"("+num$(J)+")")
      Endif
     Endif
     # Information pour effectuer le lien cours et le référentiel (un cours pour x référentiel)
     [M:SCL]LIGLED(J)=INDCUR+1
     INDCUR+=1
    Else
     [M:SCL]IDT(K-1) = "*"
     [M:SCL]LIGLED(J)= K
    Endif
   Endif
  Next
  [M:SCL]NBRC = INDCUR
Endcase
Return

$OK
Case GFONCTION
 When "GESCMM"
  For I=0 To [M:SCL]NBRC-1
   For J=1 To len(mess(0,2644,1))
    K=find(J,GENGTYPLED(1..GENGNBTYPLED))
    If K
     If GENGCURLED(K)=[M:SCL]CURLED(I)
      # Devise de pièce = Devise de référentiel (au cas où)
      If [F:GCM]CUR(GENGTYPLED(K)-1)=[M:SCL]CURENT
       Assign PARAM(5)+"("+num$(J-1)+")" With 1
       Assign PARAM(6)+"("+num$(J-1)+")" With 1
      Else
       Assign PARAM(5)+"("+num$(J-1)+")" With [M:SCL]RATMLT(I)
       Assign PARAM(6)+"("+num$(J-1)+")" With [M:SCL]RATDIV(I)
      Endif     
     Endif
    Endif
   Next
  Next
  # LIGLED dimentionné à 10 permet de stocker pour les 10 référentiels, la ligne des cours saisis dans la fenêtre DSAICUR
#  For I=1 To len(mess(0,2644,1))
#   K=find(I,GENGTYPLED(1..GENGNBTYPLED))
#   If K
#    If [F:GCM]LED(GENGTYPLED(K)-1)<>""
#     # Devise de pièce = Devise de référentiel (au cas où)
#     If [F:GCM]CUR(GENGTYPLED(K)-1)=[M:SCL]CURENT
#      Assign PARAM(5)+"("+num$(I-1)+")" With 1
#      Assign PARAM(6)+"("+num$(I-1)+")" With 1
#     Else
#      Assign PARAM(5)+"("+num$(I-1)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I-1)-2)
#      Assign PARAM(6)+"("+num$(I-1)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I-1)-2)
#     Endif     
#    Endif
#   Endif
#  Next
 When Default
  # LIGLED dimentionné à 10 permet de stocker pour les 10 référentiels, la ligne des cours saisis dans la fenêtre DSAICUR
  For I=0 To len(mess(0,2644,1))-1
   If [F:GCM]LED(I)<>""
    # Devise de pièce = Devise de référentiel (au cas où)
    If instr(1,PARAM(5),"#")
     Local Integer NOLI
     XRATMLT = PARAM(5)
     XRATDIV = PARAM(6)
     Call SUBST(XRATMLT,"#",num$(I+1))
     Call SUBST(XRATDIV,"#",num$(I+1))
     NOLI = val(PARAM(7))
     If [F:GCM]CUR(I)=[M:SCL]CURENT
      Assign "[M:"+PARAM(8)+"]RATMLT"+num$(I+1)+"("+num$(NOLI)+")" With 1
      Assign "[M:"+PARAM(8)+"]RATDIV"+num$(I+1)+"("+num$(NOLI)+")" With 1
     Else
      Assign "[M:"+PARAM(8)+"]RATMLT"+num$(I+1)+"("+num$(NOLI)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
      Assign "[M:"+PARAM(8)+"]RATDIV"+num$(I+1)+"("+num$(NOLI)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
     Endif     
    Else
     If [F:GCM]CUR(I)=[M:SCL]CURENT
      Assign PARAM(5)+"("+num$(I)+")" With 1
      Assign PARAM(6)+"("+num$(I)+")" With 1
  #   Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
     Else
      Assign PARAM(5)+"("+num$(I)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
      Assign PARAM(6)+"("+num$(I)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
     Endif     
    Endif
   Endif
  Next
 Endcase
Return


Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
Local Integer K
Repeat
 K = instr(1,CHAINE,AB1)
 If K
  CHAINE = left$(CHAINE,K-1)+AB2+right$(CHAINE,K-1+len(AB1)+1)
 Endif
Until K=0
End


#--------------------------------------------------#
# Sugg V140 : Stocker les cours devises            #
#--------------------------------------------------#
#--------------------------------------------------#
# Initialisation des cours saisis                  # 
#------------------------------------------------- #
# [M]RATDIV : Cours devise pièce                   #
# [M]RATMLT : Cours devise référentiel             #
#--------------------------------------------------#
$INIT_COURS
Local Decimal COURMUL , COURDIV, TYPCOURS
Local Decimal COURS
For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
 If [F:GCM]FLGVCRRAT([M:SCL]LEDTYP(J)-1)=2
  TYPCOURS = [M:SCL]TYPRAT
 Else
  TYPCOURS = [F:GCM]TYPRAT([M:SCL]LEDTYP(J)-1)
 Endif
 Local Integer STAT
 Call INI_COURS2([M:SCL]CUR(J),[M:SCL]CURLED(J),TYPCOURS,[M:SCL]DAT,COURDIV,COURMUL,STAT)
 If STAT
  Case [F:GCM]DACRAT([M:SCL]LEDTYP(J)-1)
   When 1 : # Multiplicateur
    [M:SCL]RATDIV1(J) = 1
    [M:SCL]RATMLT1(J) = 0
   When 2 : # Diviseur
    [M:SCL]RATDIV1(J) = 0
    [M:SCL]RATMLT1(J) = 1
   When 3 : # Les 2
    [M:SCL]RATMLT1(J) = 0
    [M:SCL]RATDIV1(J) = 0
  Endcase
 Else
  Case [F:GCM]DACRAT([M:SCL]LEDTYP(J)-1)
   When 1 : # Multiplicateur
    [M:SCL]RATDIV1(J) = 1
    [M:SCL]RATMLT1(J) = arr(COURMUL/COURDIV,10^-GDECRCU)
   When 2 : # Diviseur
    [M:SCL]RATDIV1(J) = arr(COURDIV/COURMUL,10^-GDECRCU)
    [M:SCL]RATMLT1(J) = 1
   When 3 : # Les 2
    [M:SCL]RATMLT1(J) = COURMUL
    [M:SCL]RATDIV1(J) = COURDIV
  Endcase
 Endif
 If ![M:SCL]INI
   [M:SCL]RATMLT(J) = [M:SCL]RATMLT1(J)
   [M:SCL]RATDIV(J) = [M:SCL]RATDIV1(J)
 Endif
Next
Return

Subprog INI_COURS2(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Integer TYPCOURS
Value    Date    DATCOURS
Variable Decimal COURMUL
Variable Decimal COURDIV
Variable Integer STAT
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
Local Integer INORG , INDES
Local Decimal EURORG , EURDES
STAT=0
Call LEC_TCU(DEVORG) From AINICOURS
INORG  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURORG = [F:TCU]EURRAT
Call LEC_TCU(DEVDES) From AINICOURS
INDES  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURDES = [F:TCU]EURRAT
If DEVORG=DEVDES    : # Cas trivial
 COURMUL = 1
 COURDIV = 1
Elsif DEVORG=GEURO  
 If INDES           : # In => Euro
  COURMUL = 1
  COURDIV = EURDES
 Else               : # xx => Euro
  Call COURS(GEURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT) From AINICOURS
 Endif
Elsif DEVDES=GEURO
 If INORG           : # Euro => In
  COURMUL = EURORG
  COURDIV = 1
 Else               : # Euro => yy
  Call COURS(DEVORG,GEURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT) From AINICOURS
 Endif
Elsif INDES & INORG : # In => In
 COURMUL = EURORG
 COURDIV = EURDES
Elsif INORG         : # In => Out
 Call COURS(GEURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT) From AINICOURS
 COURMUL /= EURORG
Elsif INDES         : # Out => In
 Call COURS(DEVORG,GEURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT) From AINICOURS
 COURMUL *= EURDES
Else                : # xx => yy
 Call COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT) From AINICOURS
Endif
End

######################################################
$INIT_COURS_OLD
Local Integer STAT

# Remplissage du masque 
For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
 Case [F:GCM]DACRAT([M:SCL]LEDTYP(J)-1)
  When 1,3 : 
   # Multiplicateur   
   [M:SCL]RATDIV1(J) = 1
   If ![M:SCL]INI :    [M:SCL]RATDIV(J) = 1 : Endif
   Call CONVERT([M:SCL]CUR(J),[M:SCL]CURLED(J),[F:CPY]ACCCUR,[M:SCL]TYPRAT,[M:SCL]DAT,10^GDECRCU,[M:SCL]RATMLT1(J),STAT) From TRTDEV
   If !STAT
    [M:SCL]RATMLT1(J)  = arr([M:SCL]RATMLT1(J)/10^GDECRCU, 10^-GDECRCU)
    If ![M:SCL]INI : [M:SCL]RATMLT(J) = [M:SCL]RATMLT1(J) : Endif
   Endif
  When 2 : 
   # Diviseur
   [M:SCL]RATMLT1(J) = 1
   If ![M:SCL]INI :    [M:SCL]RATMLT(J) = 1 : Endif
   Call CONVERT([M:SCL]CURLED(J),[M:SCL]CUR(J),[F:CPY]ACCCUR,[M:SCL]TYPRAT,[M:SCL]DAT,10^GDECRCU,[M:SCL]RATDIV1(J),STAT) From TRTDEV
   If !STAT 
    [M:SCL]RATDIV1(J)  = arr([M:SCL]RATDIV1(J)/10^GDECRCU, 10^-GDECRCU) 
    If ![M:SCL]INI : [M:SCL]RATDIV(J) = [M:SCL]RATDIV1(J) : Endif
   Endif
 Endcase   
Next
Return
#################################


$FINSAI
Case GFONCTION
 When "GESPIH"
  [M:PIH1]RAT1  = evalue(PARAM(6)+"("+num$(GTYPGEN-1)+")")
  [M:PIH1]RAT2  = evalue(PARAM(5)+"("+num$(GTYPGEN-1)+")")
  Affzo [PIH1]RAT1, RAT2
 When "GESSIH"
  [M:SIH2]RAT1  = evalue(PARAM(6)+"("+num$(GTYPGEN-1)+")")
  [M:SIH2]RAT2  = evalue(PARAM(5)+"("+num$(GTYPGEN-1)+")")
  Affzo [SIH2]RAT1, RAT2
 When "GESBIC"
  [M:BIC1]RAT1  = evalue(PARAM(6)+"("+num$(GTYPGEN-1)+")")
  [M:BIC1]RAT2  = evalue(PARAM(5)+"("+num$(GTYPGEN-1)+")")
  Affzo [M:BIC1]RAT1 : Affzo [M:BIC1]RAT2
 When "GESBIS"
  [M:BIS1]RAT1  = evalue(PARAM(6)+"("+num$(GTYPGEN-1)+")")
  [M:BIS1]RAT2  = evalue(PARAM(5)+"("+num$(GTYPGEN-1)+")")
  Affzo [M:BIS1]RAT1 : Affzo [M:BIS1]RAT2
 When "GESGAS"
  For I=0 To dim([M]RAT1)-1
   [M]RAT1(I)  = [M:SCL]RATDIV(I)
   [M]RAT2(I)  = [M:SCL]RATMLT(I)
  Next
   #CHECK IGNORE_BEGIN
  For I=0 To 2
   If evalue("dim([M:HAE"+num$(I)+"]RAT1)>0")
    Case I
     When 1 :   Affzo [M:HAE1]RAT1 : Affzo [M:HAE1]RAT2
     When 2 :   Affzo [M:HAE2]RAT1 : Affzo [M:HAE2]RAT2
    Endcase
    Break
   Endif
  Next I
   #CHECK IGNORE_END
 When "GESCMM"
  [M:CMM1]RAT1  = evalue(PARAM(6)+"("+num$(GENGNUMLEDAFF-1)+")")
  [M:CMM1]RAT2  = evalue(PARAM(5)+"("+num$(GENGNUMLEDAFF-1)+")")
  Affzo [M:CMM1]RAT1 : Affzo [M:CMM1]RAT2
Endcase
Return

######################################################################################
Subprog AS_RATDIV(VALEUR)
Variable Decimal VALEUR
ZON = "RATDIV" : Goto AS_RAT
Subprog AS_RATMLT(VALEUR)
Variable Decimal VALEUR
ZON = "RATMLT" : Goto AS_RAT

$AS_RAT
Gosub SETNOL
Case GFONCTION
 When "GESPIH"
 When "GESSIH"
 When "GESBIC"
  If [M]AMTMIN<>0 | [M]STA=3 : mkstat=2 : End : Endif
 When "GESBIS"
  If [M]AMTMIN<>0 | [M]STA=3 : mkstat=2 : End : Endif
 When "GESGAS"
  If [M]STA>1 & (GREP="M" | GREP="") & func AFNC.PARAM("FRADGI",[M]CPY)="2" : mkstat = 2 : End : Endif : # Définitif
  If [M]ORIMOD<>2 : mkstat=2 : End : Endif
Endcase


Case [F:GCM]DACRAT([M:SCL]LEDTYP(NOL)-1)
 When 1 : 
  # Multiplicateur   
  If ZON="RATDIV" : VALEUR = 1  : mkstat=2 : End : Endif
 When 2 : 
  # Diviseur
  If ZON="RATMLT" : VALEUR = 1  : mkstat=2 : End : Endif
Endcase
 
# Devise IN 
If GCURFLG=2 and GLEDFLG([M:SCL]LEDTYP(NOL))=2
  mkstat=2 : End
Endif

End


######################################################################################

Subprog AM_RATDIV(VALEUR)
ZON = "RATDIV" : Goto AM_RAT
Subprog AM_RATMLT(VALEUR)
Variable Decimal VALEUR
ZON = "RATMLT" : Goto AM_RAT

$AM_RAT
If VALEUR=0 : VALEUR=evalue("[M:SCL]"+ZON+"1("+num$(indice)+")") : Endif
If GIMPORT : End : Endif

Assign "[M:SCL]"+ZON+"("+num$(indice)+")" With VALEUR
#Affzo ="[M:SCL]"+ZON+"("+num$(indice)+")"
End

######################################################################################

$SETNOL
Local Integer NOL
NOL = nolign-1
Return


$RAT_OLD
# Affichage des cours
INDCUR=0
For J=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(J)<>"" & [F:GCM]CUR(J)<>[M:SCL]CURENT
 
  [M:SCL]CURLED(INDCUR)=[F:GCM]CUR(J)                                                                #(3)
  If GCURFLG=1 & [F:GCM]CUR(J)<>GEURO & GLEDFLG(J+1)=2 : [M:SCL]CURLED(INDCUR)=GEURO : Endif         #(4)
 
  # Devise est elle déjà gérée sous un autre référentiel ?
  K = find([M:SCL]CURLED(INDCUR),[M:SCL]CURLED(0..INDCUR-1)) 

  If !J or [F:GCM]FLGVCRRAT(J)=1 or ([F:GCM]FLGVCRRAT(J)=2 & !K) 
   [M:SCL]IDT(INDCUR)=mess(J+1,2644,1)
   [M:SCL]LEDTYP(INDCUR)=J+1
   [M:SCL]CUR(INDCUR)=[M:SCL]CURENT                                                                   #(1)
   If GCURFLG=2 & [M:SCL]CURENT<>GEURO & GLEDFLG(J+1)=1 : [M:SCL]CUR(INDCUR)=GEURO : Endif            #(2)

   # Existence de cours passé sous les paramètres de l'action SAIRATCUR => Pré-chargement.
   If [M:SCL]INI
    [M:SCL]RATMLT(INDCUR) = evalue(PARAM(5)+"("+num$(J)+")")
    [M:SCL]RATDIV(INDCUR) = evalue(PARAM(6)+"("+num$(J)+")")
   Endif

   # Information pour effectuer le lien cours et le référentiel (un cours pour x référentiel)
   #[M:SCL]LIG(INDCUR)=INDCUR+1
   [M:SCL]LIGLED(J)=INDCUR+1
   INDCUR+=1
   
  Else

   # Devise déjà gérée & "Type cours Pièce" à Oui...
   If K & [F:GCM]FLGVCRRAT(J)=2
    [M:SCL]IDT(K-1) = "*"
    #[M:SCL]LIG(J)=[M:SCL]LIG(K-1)
    #[M:SCL]LIGLED(J)=[M:SCL]LIGLED(K-1) #24/07/06
    [M:SCL]LIGLED(J)=[M:SCL]LIGLED(K-1) #03/08/06
    [M:SCL]LIGLED(J)=K
   Endif
  Endif
 Endif
Next
Return

