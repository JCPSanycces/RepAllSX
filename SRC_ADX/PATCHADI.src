#<AdxTL>@(#)0.0.0.0 $Revision$ Intûˋgration de patch
###################################################
## Intûˋgration d'une table diverse
###################################################
$TABDIV
FICHIER = "ATABDIV" : ABR = "ADI"
#
Local Integer SAV_ADVLNG
SAV_ADVLNG = 0
#for SCM deletion (typenr=-2 only in scm at the moment)
Read [ADV]CODE = val(NOMOBJ)
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ADI
      Gosub FIN_OBJ From PATCH
  Else
      If dim([F:ADV]CODACT)>0 & [F:ADV]CODACT>="X" & !find([F:ADV]CODACT,ACTIV(1..NBACT))
            # specific Objet
            Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
            OKSPE = 1
            Gosub FIN_OBJ From PATCH
      Else
            NEWOBJ = 0
            SAV_ADVLNG =  [F:ADV]LNG
            Gosub TR_ADI
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:ADV]
      Gosub TR_ADI
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return


#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_ADI
Call DEBTRANS From GLOCK
Trbegin [ADI]
    Delete [AXX] Where CODFIC="ATABDIV" & IDENT2=[L]NOMOBJ
    Delete [ADI] Where NUMTAB=val(NOMOBJ)
    If fstat
          GOK = 0 : ER = 99 : ERFIC = "ATABDIV"-NOMOBJ : Rollback :  Return
    Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADI",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMû
Return


$TR_ADI
Call DEBTRANS From GLOCK
Local Integer ADV : ADV=0
Local Integer ADI : ADI=0
Trbegin [ADI] , [ADV]
Repeat
  Gosub LIRE From PATCH
  Case TYPENR
       When 7 : # Fin normale
                Break
       When 3 : # Le fichier
                IDENT = CHAMP(2)
                Case CHAMP(1)
                        When "ADI"   : ADI=1 : Gosub ADI1
                        When "ADV"   : ADV=1 : Gosub ADI2
                        When Default : ER = 31
                Endcase
      When Default :  ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If ADV & [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADV",num$([F:ADV]NUMTAB),"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
If ADI & [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADI",[F:ADI]CODE,num$([F:ADI]NUMTAB),string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$ADI1
#jira 82799
Local Integer WENAFLG
WENAFLG = 0
#

FICHIER = "ATABDIV" : ABR = "ADI"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  #jira 82799
  # le newobj correspond en fait û  la cle sur atabtab et pas sur atabdiv
  # donc ici aucun interet de faire ce test
  # on laisse le patch faire car test plus bas sur flag (svg et restaure)
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   #If find(VARIA,"ENAFLG")
   # OK = 0
   #Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# read atabtab for leg and module
Read [F:ADV]CODE = [F:ADI]NUMTAB
If !fstat & [F:ADV]FLGLEG=2 & [F:ADI]LEG<>"" & !find([F:ADI]LEG,LEGREF(1..NBLEGREF))
    # Lûˋgislation non gûˋrûˋe dans le dossier
    Return
Endif
# module test only if not root folder
If DOSSIER(D) <> GDOSX3
    MODOBJ = max(1,[F:ADV]MODULE)
    If [F:ADS]MODULE(MODOBJ-1)<>2
         Return
    Endif
Endif
## activity code to be tested also like in valdos
ACVOBJ = [F:ADV]CODACT
If ACVOBJ<>"" & DOSSIER(D)<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
    OKOBJ = 0 : Return
 Endif
Endif
#
[F:ADI2]=[F:ADI]
Read [F:ADI]CODE =
If fstat
 [F:ADI]=[F:ADI2]
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
      If dim([F:ADI]CREDAT)>0 : [F:ADI]CREDAT = date$ : Endif
      If dim([F:ADI]CREUSR)>0 : [F:ADI]CREUSR = GUSER : Endif
      If dim([F:ADI]CRETIM)>0 : [F:ADI]CRETIM = time  : Endif
      If dim([F:ADI]UPDDAT)>0 : [F:ADI]UPDDAT = date$ : Endif
      If dim([F:ADI]UPDUSR)>0 : [F:ADI]UPDUSR = GUSER : Endif
      If dim([F:ADI]UPDTIM)>0 : [F:ADI]UPDTIM = time  : Endif
 Endif
 Write [ADI]
Else
 If [F:ADV]FLGLEG=2 & [F:ADI]LEG<>"" & [F:ADI2]LEG <> [F:ADI]LEG
      Call ECR_TRACE("---"-func AFNC.MES3(mess(78,127,1),mess(56,123,1)-num$([F:ADI]NUMTAB)
&       -"("+[F:ADI2]CODE+")","'"+[F:ADI2]LEG+"'","'"+[F:ADI]LEG+"'"),-1) From GESECRAN
  Return
 Endif
 #jira 82799
 # do not overwrite the flag in update mode
 If [F:ADV]FLGENA=2
        WENAFLG =[F:ADI]ENAFLG
 Endif
 [F:ADI]=[F:ADI2]
 #jira 82799
 # do not overwrite the flag in update mode
 If [F:ADV]FLGENA=2
        [F:ADI]ENAFLG = WENAFLG
 Endif
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
      If dim([F:ADI]UPDDAT)>0 : [F:ADI]UPDDAT = date$ : Endif
      If dim([F:ADI]UPDUSR)>0 : [F:ADI]UPDUSR = GUSER : Endif
      If dim([F:ADI]UPDTIM)>0 : [F:ADI]UPDTIM = time  : Endif
 Endif
 Rewrite [ADI]
Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATABDIV"-NOMOBJ : Return
Endif
#ici aussi pour marquage
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADI",[F:ADI]CODE,num$([F:ADI]NUMTAB),string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$ADI2
FICHIER = "ATABTAB" : ABR = "ADV"
Read [ADV]CODE=val(NOMOBJ)
If fstat
    NEWOBJ = 1
Else
    NEWOBJ = 0
Endif
# common with ADV and ADI (no reason to be different)
Goto ADV1
Return

$ABORT
Rollback
Return

###################################################
## Intûˋgration d'un paramû´tre de table diverse
###################################################
$PARAM_DIV
FICHIER = "ATABTAB" : ABR = "ADV"
#
Local Integer SAV_ADVLNG
SAV_ADVLNG = 0
#

Read [ADV]CODE = val(NOMOBJ)
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ADV
      Gosub FIN_OBJ From PATCH
  Else
      If dim([F:ADV]CODACT)>0 & [F:ADV]CODACT>="X" & !find([F:ADV]CODACT,ACTIV(1..NBACT))
            # specific Objet
            Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
            OKSPE = 1
            Gosub FIN_OBJ From PATCH
      Else
            NEWOBJ = 0
            SAV_ADVLNG =  [F:ADV]LNG
            Gosub TR_ADV
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Gosub TR_ADV
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

$DEL_ADV
#-------------------#
# deletion at the moment only for scm
#-------------------#
Call DEBTRANS From GLOCK
Trbegin [ADV]
  # strange we don't take care of ADI .. only definition is cancelled????
  Delete [AXX] Where CODFIC="ATABTAB" & ZONE='LNGDES' & IDENT1=[L]NOMOBJ
  Delete [ADV] Where NUMTAB=val(NOMOBJ)
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "ATABTAB"-NOMOBJ : Rollback : Return
  Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADV",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMû
Return


$TR_ADV
Call DEBTRANS From GLOCK

Trbegin [ADV]
Repeat
    Gosub LIRE From PATCH
    Case TYPENR
        When 7 :  # Fin normale
                  Break
        When 3 :  # Le fichier
                  IDENT = CHAMP(2)
                  Case CHAMP(1)
                      When "ADV"   : Gosub ADV1
                      When Default : ER = 31
                  Endcase
        When Default :     ER = 32
    Endcase
    If ER or !OKOBJ : Break : Endif
Until 1=0
If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADV",num$([F:ADV]NUMTAB),"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return


$ADV1
Repeat
  Gosub LIRE_ZONE From PATCH
  If ER : Break : Endif
  If DIME>0 & IND+1<=DIME
        OK = 1
        # Patch not for scm - ISFULLMOD = 2 when SCM
        If !NEWOBJ and find(VARIA,"ACS","DEPNUM","LNGDES","SHODES")  and [L]ISFULLMOD<>2
             OK = 0
        Endif
        If OK
              Gosub AFF_ZONE From PATCH
              If GOK<1 : ER = 99 : Break : Endif
        Endif
  Endif
Until TYPENR=6
If ER : Return : Endif
# module test only if not root folder
If [F:ADS]DOSSIER <> GDOSX3
    MODOBJ = max(1,[F:ADV]MODULE)
    If [F:ADS]MODULE(MODOBJ-1)<>2
        OKOBJ = 0 : Return
    Endif
Endif
## activity code to be tested also like in valdos
ACVOBJ = [F:ADV]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
  Read [ACV]CODACT = ACVOBJ
  If fstat or [F:ACV]FLACT<>2
      OKOBJ = 0 : Return
  Endif
Endif
#
If NEWOBJ
    If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
           Call FLDCRE("ADV") From OBJDIV
    Endif
    Write [ADV]
    If fstat
            Call LOG_ERROR_DETAILS(1, "ADV",num$([F:ADV]NUMTAB),"") From GLOCK
    Endif
Else
    If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
            Call FLDUPD("ADV") From OBJDIV
    Endif
    # caution with LNG only if LNGFLG <> 2 we overwrite
    If [F:ADV]LNGFLG = 2
        # if LNGFLG = 2 we don't orverwrite the LNG so put the SVGLNG
        # if savlng = 0 put the lng of patch
        If SAV_ADVLNG <> 0
            [F:ADV]LNG = SAV_ADVLNG
        Endif
    Endif
    Rewrite [ADV]
    If fstat
            Call LOG_ERROR_DETAILS(2, "ADV",num$([F:ADV]NUMTAB),"") From GLOCK
    Endif

Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATABTAB"-NOMOBJ : Return
Endif
Return

