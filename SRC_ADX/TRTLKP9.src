#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
#   Envoi d'un objet CRM par E-Mail                                        Module CRM        10 Mars 2004
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If PARAM(1) = "" Then
    #Aucun code objet n'a été communiqué. Accès refusé.
    GMESSAGE = mess(83,177,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  If PARAM(2) = "" Then
    #Aucun numéro de pièce n'a été communiqué. Accès refusé.
    GMESSAGE = mess(830,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  Case PARAM(1)
    When "ITN"
      FIN = 0
    When "SRE"
      FIN = 0
    When "SOL"
      FIN = 0
    When "TSK"
      FIN = 0
    When "CLL"
      FIN = 0
    When "OPP"
      FIN = 0
    When "BAP"
      FIN = 0
    When "BPR"
      FIN = 0
    When Default
      #L'envoi par E-Mail n'est pas disponible pour l'objet demandé.
      GMESSAGE = mess(80,177,1)
      GERR = 2
      FIN = 1
  Endcase
  If FIN Then
    Return
  Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
Return

##########################################################################################################
$SETBOUT
  ETAMEN(1) = 1
Return

##########################################################################################################
$DEBUT
  [M:LKP9]AOB = PARAM(1)
  [M:LKP9]VCRNUM = PARAM(2)
  [M:LKP9]HTMCXT = PARAM(3)
  #Envoi par message électronique d'une intervention.
  #Envoi par message électronique d'une demande de service.
  #Envoi par message électronique d'une solution.
  #Envoi par message électronique d'une tâche.
  #Envoi par message électronique d'un appel.
  #Envoi par message électronique d'une affaire.
  #Envoi par message électronique d'un rendez-vous.
  #Envoi par message électronique d'un tiers.
  Case [M:LKP9]AOB
    When "ITN"
      [M:LKP9]TTR = mess(84,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "SRE"
      [M:LKP9]TTR = mess(85,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "SOL"
      [M:LKP9]TTR = mess(86,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "TSK"
      [M:LKP9]TTR = mess(87,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "CLL"
      [M:LKP9]TTR = mess(88,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "OPP"
      [M:LKP9]TTR = mess(89,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "BAP"
      [M:LKP9]TTR = mess(90,177,1) - "(" + [M:LKP9]VCRNUM + ")"
    When "BPR"
      [M:LKP9]TTR = mess(92,177,1) - "(" + [M:LKP9]VCRNUM + ")"
  Endcase
  [M:LKP9]TYP = 4
  [M:LKP9]TYPCLA = "AUS"
  [M:LKP9]CRI = ""
  [M:LKP9]DSYTYP = 1
  Gosub LOADLKP9
  # -----------------------------------------------------------
  Case [M:LKP9]AOB
    When "SRE"
      # Demandes de services
      # --------------------
      Gosub PRECHARGE_SRE_MAIL
    When "ITN"
      # Intervention
      # --------------------
      Gosub PRECHARGE_ITN_MAIL
    When Default
  Endcase
  # -----------------------------------------------------------
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:LKP9]
Return

##########################################################################################################
$ONOK
  If [M:LKP9]WEBADD = "" Then
    GMESSAGE = mess(91,177,1)
    GERR = 2
    FIN = 0
    Return
  Endif
  Gosub GENEMAIL
Return

##########################################################################################################
Funprog GET_SCREENTYPE_FROM_DSYTYP(IDSYTYP)
Value Integer IDSYTYP

Local Char SARENDRE(10)

  Case IDSYTYP
    When 1
      SARENDRE = "PC"
    When 2
      SARENDRE = "PALM"
    When Default
      SARENDRE = "PC"
  Endcase
End SARENDRE

##########################################################################################################
$LOADLKP9
Local Char SZPATEVAL(250)

  Call TEMPON("L") From GESECRAN
  SZPATEVAL = '*' + toupper([M:LKP9]CRI) + '*'
  Raz [M:LKP9]NBLIG
  Raz [M:LKP9]ADECOD
  Raz [M:LKP9]ADENAM
  Raz [M:LKP9]ADEADD
  Raz [M:LKP9]ADEWEB
  Case [M:LKP9]TYP
    When 1
      If [M:LKP9]CRI = "" Then
        Filter [AUS] Where [F:AUS]ADDEML <> "" Order By [F:AUS]USR Asc
      Else
        Filter [AUS] Where [F:AUS]ADDEML <> "" and pat(toupper([F:AUS]NOMUSR), SZPATEVAL) <> 0 Order By [F:AUS]USR Asc
      Endif
      For [AUS]
        If [M:LKP9]NBLIG >= dim([M:LKP9]ADECOD)-1 Then
          Break
        Endif
        [M:LKP9]ADECOD([M:LKP9]NBLIG) = [F:AUS]USR
        [M:LKP9]ADENAM([M:LKP9]NBLIG) = [F:AUS]NOMUSR
        [M:LKP9]ADEADD([M:LKP9]NBLIG) = ""
        [M:LKP9]ADEWEB([M:LKP9]NBLIG) = [F:AUS]ADDEML
        [M:LKP9]NBLIG += 1
      Next
      Filter [AUS]
    When 2
      If [M:LKP9]CRI = "" Then
        Filter [BPR] Where [F:BPR]BPRNUM <> "" Order By [F:BPR]BPRNUM Asc
      Else
        Filter [BPR] Where pat(toupper([F:BPR]BPRNAM), SZPATEVAL) <> 0 Order By [F:BPR]BPRNUM Asc
      Endif
      For [BPR]
        If [M:LKP9]NBLIG >= dim([M:LKP9]ADECOD)-1 Then
          Break
        Endif
        Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPR]BPRNUM and [F:BPA]WEB(0) <> ""   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        For [BPA]
          If [M:LKP9]NBLIG >= dim([M:LKP9]ADECOD)-1 Then
            Break
          Endif
          [M:LKP9]ADECOD([M:LKP9]NBLIG) = [F:BPR]BPRNUM
          [M:LKP9]ADENAM([M:LKP9]NBLIG) = [F:BPR]BPRNAM
          If [F:BPA]BPADES = "" Then
            [M:LKP9]ADEADD([M:LKP9]NBLIG) = [F:BPA]BPAADD
          Else
            [M:LKP9]ADEADD([M:LKP9]NBLIG) = [F:BPA]BPADES
          Endif
          [M:LKP9]ADEWEB([M:LKP9]NBLIG) = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
          [M:LKP9]NBLIG += 1
        Next
        Filter [BPA]
      Next
      Filter [BPR]
    When 3
      If [M:LKP9]CRI = "" Then
        Filter [AIN] Where [F:AIN]CNTEMA <> "" Order By [F:AIN]CNTLNA Asc
      Else
        Filter [AIN] Where [F:AIN]CNTEMA <> "" and pat(toupper([F:AIN]CNTLNA), SZPATEVAL) <> 0 Order By [F:AIN]CNTLNA Asc
      Endif
      For [AIN]
        If [M:LKP9]NBLIG >= dim([M:LKP9]ADECOD)-1 Then
          Break
        Endif
        [M:LKP9]ADECOD([M:LKP9]NBLIG) = [F:AIN]CNTNUM
        Call BUILDFULNAM("AIN", [M:LKP9]ADENAM([M:LKP9]NBLIG)) From CRMUTIL140
        [M:LKP9]ADEADD([M:LKP9]NBLIG) = ""
        [M:LKP9]ADEWEB([M:LKP9]NBLIG) = [F:AIN]CNTEMA
        [M:LKP9]NBLIG += 1
      Next
      Filter [AIN]
    When 4
  Endcase
  Call TEMPOFF From GESECRAN
  Affzo [M:LKP9]1-99
Return

##########################################################################################################
$GENEMAIL
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Char SZHTMLPAGE(250)
Local Char SZEMAILSUBJECT(250)
Local Char SZPREFIXSUBJECT(100)
Local Integer IERR
Local Integer ICHAPTER
Local Char SZTYPEDISPLAY(GLONDES)

  If [M:LKP9]DSYTYP = 2 Then
    SZTYPEDISPLAY = "PALM"
  Else
    SZTYPEDISPLAY = "PC"
  Endif
  IERR = 0
  ICHAPTER = 0
  Case [M:LKP9]AOB
    When "ITN"
      Call TEXTE(14563, SZPREFIXSUBJECT) From OBJDIV      #Intervention
    When "SRE"
      Call TEXTE(14603, SZPREFIXSUBJECT) From OBJDIV      #Demande de service
    When "SOL"
      Call TEXTE(14610, SZPREFIXSUBJECT) From OBJDIV      #Solution
    When "TSK"
      Call TEXTE(1195, SZPREFIXSUBJECT) From OBJDIV       #Tâche
    When "CLL"
      Call TEXTE(13606, SZPREFIXSUBJECT) From OBJDIV      #Appel
    When "OPP"
      Call TEXTE(18260, SZPREFIXSUBJECT) From OBJDIV      #Affaire
    When "BAP"
      Call TEXTE(14423, SZPREFIXSUBJECT) From OBJDIV      #Rendez-vous
    When "BPR"
      Call TEXTE(19569, SZPREFIXSUBJECT) From OBJDIV      #Tiers
  Endcase
  Gosub SEND_EMAIL
Return

##########################################################################################################
$SEND_EMAIL
Local Integer IRECU
Local Integer NI
Local Integer NE
Local Char SMESSAGE(250)
Local Char STOEMAIL(250)(1..)

  Case [M:LKP9]AOB
    When "SRE"
      # Demandes de services
      # --------------------
      Gosub SEND_SRE_MAIL
    When "ITN"
      # Interventions
      # --------------------
      Gosub SEND_ITN_MAIL
    When Default
      # Tous les autres cas
      # -------------------
      Call AOBINHTML([M:LKP9]AOB, [M:LKP9]VCRNUM, 1, SZTYPEDISPLAY, [M:LKP9]HTMCXT, SZFULLFILENAME, SZFILENAME, ICHAPTER, IERR) From SUBAOBHTML
      If IERR Then
        GMESSAGE = mess(IERR,ICHAPTER,1)
        GERR = 2
        FIN = 0
      Endif
  Endcase
Return

##########################################################################################################
$PRECHARGE_ATTACHMENT
  # Attachment
  [M:LKP9]PCEJOI = S_ATTACHMENTS(1)
Return

##########################################################################################################
$PRECHARGE_SRE_MAIL
Local Integer IRECU
Local Integer NI
Local Integer NE
Local Char SMESSAGE(250)
Local Char STOEMAIL(250)(1..)

Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)

  IRECU = func SUBSREHTML.PREPARE_EMAIL(GACTX, [M:LKP9]VCRNUM, [M:LKP9]DSYTYP, GUSER, STOEMAIL, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IRECU = [V]CST_ANO Then
    GMESSAGE = SMESSAGE
    GERR = 2
    FIN = 0
  Else
    # From
    [M:LKP9]MELORI = SA_FROM
    # To(s)
    [M:LKP9]NBWEBADD = 0
    For NI = 1 To maxtab(SA_USER)
      If SA_USER(NI) <> "" Then
        [M:LKP9]WEBADD([M:LKP9]NBWEBADD) = SA_USER(NI)
        [M:LKP9]NBWEBADD += 1
      Endif
    Next NI
    # Copy(s)
    [M:LKP9]NBCOPY = 0
    For NI = 1 To maxtab(SCC_USER)
      If SCC_USER(NI) <> "" Then
        [M:LKP9]COPY([M:LKP9]NBCOPY) = SCC_USER(NI)
        [M:LKP9]NBCOPY += 1
      Endif
    Next NI
    # Subject
    [M:LKP9]OBC = SZEMAILSUBJECT
    # Body
    [M:LKP9]MSG = BODY
    Gosub PRECHARGE_ATTACHMENT
  Endif
  Affzo [M:LKP9]1-99
Return

##########################################################################################################
$PRECHARGE_ITN_MAIL
Local Integer IRECU
Local Integer NI
Local Integer NE
Local Char SMESSAGE(250)
Local Char STOEMAIL(250)(1..)

Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)

  IRECU = func SUBITNHTML.PREPARE_EMAIL(GACTX, [M:LKP9]VCRNUM, [M:LKP9]DSYTYP, GUSER, [V]CST_AYES, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IRECU = [V]CST_ANO Then
    GMESSAGE = SMESSAGE
    GERR = 2
    FIN = 0
  Else
    # From
    [M:LKP9]MELORI = SA_FROM
    # To(s)
    [M:LKP9]NBWEBADD = 0
    For NI = 1 To maxtab(SA_USER)
      If SA_USER(NI) <> "" Then
        [M:LKP9]WEBADD([M:LKP9]NBWEBADD) = SA_USER(NI)
        [M:LKP9]NBWEBADD += 1
      Endif
    Next NI
    # Copy(s)
    [M:LKP9]NBCOPY = 0
    For NI = 1 To maxtab(SCC_USER)
      If SCC_USER(NI) <> "" Then
        [M:LKP9]COPY([M:LKP9]NBCOPY) = SCC_USER(NI)
        [M:LKP9]NBCOPY += 1
      Endif
    Next NI
    # Subject
    [M:LKP9]OBC = SZEMAILSUBJECT
    # Body
    [M:LKP9]MSG = BODY
    # Attachment
    Gosub PRECHARGE_ATTACHMENT
  Endif
  Affzo [M:LKP9]1-99
Return

##########################################################################################################
$LOAD_VARIABLE_SEND_MAIL
Local Integer NI
Local Integer NE
Local Integer IRECU
Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)

  SA_FROM = [M:LKP9]MELORI
  Raz SA_USER
  NE = 0
  For NI = 0 To [M:LKP9]NBWEBADD-1
    If [M:LKP9]WEBADD(NI) <> "" Then
      NE += 1
      SA_USER(NE) = [M:LKP9]WEBADD(NI)
    Endif
  Next NI
  Raz SCC_USER
  NE = 0
  For NI = 0 To [M:LKP9]NBCOPY-1
    If [M:LKP9]COPY(NI) <> "" Then
      NE += 1
      SCC_USER(NE) = [M:LKP9]COPY(NI)
    Endif
  Next NI
  SZEMAILSUBJECT = [M:LKP9]OBC
  BODY = [M:LKP9]MSG
  Raz S_ATTACHMENTS
  S_ATTACHMENTS(1) = [M:LKP9]PCEJOI
Return

##########################################################################################################
$SEND_SRE_MAIL
  Gosub LOAD_VARIABLE_SEND_MAIL
  IRECU = func SUBSREHTML.SEND_EMAIL(GACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IRECU = [V]CST_ANO Then
    GMESSAGE = mess(IERR,ICHAPTER,1)
    GERR = 2
    FIN = 0
  Endif
Return

##########################################################################################################
$SEND_ITN_MAIL
  Gosub LOAD_VARIABLE_SEND_MAIL
  IRECU = func SUBITNHTML.SEND_EMAIL(GACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IRECU = [V]CST_ANO Then
    GMESSAGE = mess(IERR,ICHAPTER,1)
    GERR = 2
    FIN = 0
  Endif
Return

