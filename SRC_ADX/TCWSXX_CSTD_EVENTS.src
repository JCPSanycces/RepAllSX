# This script is used by the following classes :
# ***
# TCWSQH_CSTD
# ***
# TCWSOH_CSTD
# ***
# TCWSOC_CSTD
# ***
# TCWSXX_CSTD
# ***


###############################################################################

$AREAD_AFTER
  Local File AWRKHISSUI [AWS]
  Read [AWS]AWS2 = this.DEST;this.CHRONO
  If !fstat
    Gosub READ_DATA_AWS #get workflow info
    Case WCODOBJ
      When "SQH" : Gosub READ_DATA_SQH  #get Purchase req. info
      When "SOH" : Gosub READ_DATA_SOH  #get Order info
      When "SOC" : Gosub READ_DATA_SOC  #get Open order info
      When "SXX" : #nothing to do
    Endcase
  Endif
  LogicClose File [AWS]
Return

###############################################################################

$READ_DATA_AWS
  Local Integer I
  I = instr(1,[AWS]CLEDEC,"~")
  If I > 0
    this.KEYNUM = left$([AWS]CLEDEC, I-1)
    this.KEYLIN = val(right$([AWS]CLEDEC, I+1))
  Else
    this.KEYNUM = [AWS]CLEDEC
    this.KEYLIN = 0
  Endif

  SetInstance this With [F:AWS]
  this.MAIENV   = func GET_EMAIL([AWS]EMETTEUR, [AWS]MAIENV)
  this.EMAIL    = func GET_EMAIL([AWS]DEST, [AWS]EMAIL)
Return

###############################################################################

$READ_DATA_SQH
  #get SQUOTE (header)
  Local File SQUOTE [SQH]
  Read [SQH]SQH0 = this.KEYNUM
  If !fstat
    SetInstance this.SQH With [F:SQH]

    #get Representant
    WPOS = fmet this.SQH.ADDLINE("C_REP",[V]CST_ALASTPOS)
    this.SQH.C_REP(WPOS).REP = [F:SQH]REP(0)
    WPOS = fmet this.SQH.ADDLINE("C_REP",[V]CST_ALASTPOS)
    this.SQH.C_REP(WPOS).REP = [F:SQH]REP(1)
  Endif
  LogicClose File [SQH]

  #get SQUOTED (lines)
  Local Integer WPOS, WPOS1
  Local File SQUOTED [SQD]

  If this.KEYLIN = 0
    Filter [SQD] Where SQHNUM = this.KEYNUM Order By SQDLIN Asc
  Else
    Filter [SQD] Where SQHNUM = this.KEYNUM and SQDLIN = this.KEYLIN
  Endif
  For [SQD]
    WPOS = fmet this.SQH.ADDLINE("SQD",[V]CST_ALASTPOS)
    If WPOS >= 0
      SetInstance this.SQH.SQD(WPOS) With [F:SQD]

      #get Analytique
      Local File CPTANALIN [CAL]
      Read [CAL]CAL0 = "SQD";0;[F:SQD]SQHNUM;[F:SQD]SQDLIN;0;"";1
      If !fstat
        WPOS1 = fmet this.SQH.SQD(WPOS).ADDLINE("SQDCAL",[V]CST_ALASTPOS)
        If WPOS1 >= 0
          SetInstance this.SQH.SQD(WPOS).SQDCAL(WPOS1) With [F:CAL]
          For J = 1 To func GET_OPTCANA() #GOPTCANA
            this.SQH.SQD(WPOS).SQDCAL(WPOS1).C_DIE(J).DIE = [F:CAL]DIE(J-1)
            this.SQH.SQD(WPOS).SQDCAL(WPOS1).C_DIE(J).CCE = [F:CAL]CCE(J-1)
          Next J
        Endif
      Endif
      LogicClose File [CAL]
    Endif
  Next
  Filter [SQD]
  LogicClose File [SQD]
Return

###############################################################################

$READ_DATA_SOH
  #get SORDER (header)

  Local Integer WPOS
  Local File SORDER [SOH]
  Read [SOH]SOH0 = this.KEYNUM
  If !fstat
    SetInstance this.SOH With [F:SOH]

    #get Representant
    WPOS = fmet this.SOH.ADDLINE("C_REP",[V]CST_ALASTPOS)
    this.SOH.C_REP(WPOS).REP = [F:SOH]REP(0)
    WPOS = fmet this.SOH.ADDLINE("C_REP",[V]CST_ALASTPOS)
    this.SOH.C_REP(WPOS).REP = [F:SOH]REP(1)
  Endif
  LogicClose File [SOH]

  #get SORDERP (lines)
  Local Integer WPOS0, WPOS1, WPOS2
  Local File SORDERP [SOP]

  If this.KEYLIN = 0
    Filter [SOP] Where SOHNUM = this.KEYNUM Order By SOPLIN Asc
  Else
    Filter [SOP] Where SOHNUM = this.KEYNUM and SOPLIN = this.KEYLIN
  Endif
  For [SOP]
    WPOS0 = fmet this.SOH.ADDLINE("SOP",[V]CST_ALASTPOS)
    If WPOS0 >= 0
      SetInstance this.SOH.SOP(WPOS0) With [F:SOP]

      #get PORDERQ (lines)
      Local File SORDERQ [SOQ]
      Read [SOQ]SOQ0 = [F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
      If !fstat
        WPOS1 = fmet this.SOH.SOP(WPOS0).ADDLINE("SOPSOQ",[V]CST_ALASTPOS)
        If WPOS1 >= 0
          SetInstance this.SOH.SOP(WPOS0).SOPSOQ(WPOS1) With [F:SOQ]
        Endif
      Endif
      LogicClose File [SOQ]

      #get Analytique
      Local File CPTANALIN [CAL]
      Read [CAL]CAL0 = "SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
      If !fstat
        WPOS2 = fmet this.SOH.SOP(WPOS0).ADDLINE("SOPCAL",[V]CST_ALASTPOS)
        If WPOS2 >= 0
          SetInstance this.SOH.SOP(WPOS0).SOPCAL(WPOS2) With [F:CAL]
          For J = 1 To func GET_OPTCANA() #GOPTCANA
            this.SOH.SOP(WPOS0).SOPCAL(WPOS2).C_DIE(J).DIE = [F:CAL]DIE(J-1)
            this.SOH.SOP(WPOS0).SOPCAL(WPOS2).C_DIE(J).CCE = [F:CAL]CCE(J-1)
          Next J
        Endif
      Endif
      LogicClose File [CAL]
    Endif
  Next
  Filter [SOP]
  LogicClose File [SOP]
Return

###############################################################################

$READ_DATA_SOC
  #get SORDER (header)

  Local Integer WPOS
  Local File SORDER [SOH]
  Read [SOH]SOH0 = this.KEYNUM
  If !fstat
    SetInstance this.SOH With [F:SOH]
  Endif
  LogicClose File [SOH]

  #get SORDERC (line)
  Local Integer WPOS, WPOS1, WPOS2
  Local File SORDERC [SOC]

  If this.KEYLIN = 0
    Filter [SOC] Where SOHNUM = this.KEYNUM Order By SOPLIN Asc
  Else
    Filter [SOC] Where SOHNUM = this.KEYNUM and SOPLIN = this.KEYLIN
  Endif
  For [SOC]
    WPOS = fmet this.SOH.ADDLINE("SOC",[V]CST_ALASTPOS)
    If WPOS >= 0
      SetInstance this.SOH.SOC(WPOS) With [F:SOC] #only one unique line to read
    Endif
  Next
  Filter [SOC]
  LogicClose File [SOC]
Return

###############################################################################

Funprog GET_EMAIL(USER, EMAIL)
Value Char USER
Value Char EMAIL
  Local Char WEMAIL(250) : WEMAIL = ""
  If EMAIL = ""
    Local File AUTILIS [AUS]
    Read [AUS]CODUSR = USER
    If !fstat
      WEMAIL = [AUS]ADDEML
    Endif
    LogicClose File [AUS]
  Else
    WEMAIL = EMAIL
  Endif
End WEMAIL

###############################################################################

Funprog GET_OPTCANA()
  #get WOPTCANA
  Local Integer WOPTCANA
  Local File ACTIV [ACV]
  Read [ACV]CODACT = "ANA"
  If !fstat and [ACV]FLACT = [V]CST_AYES
    WOPTCANA = [ACV]DIMMAX  #GOPTCANA
  Else
    WOPTCANA  = 0
  Endif
  LogicClose File [ACV]
End WOPTCANA

