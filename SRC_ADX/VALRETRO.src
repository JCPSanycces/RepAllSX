#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
# 85082 : Tâche batch de validation des fiches de rétroactivité de type extourne
#################################################################################

$ACTION

  Case ACTION
    When "INIT"         : Gosub OUVRE
    When "EXEC"         : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
  Endcase
Return

#######################################################
$OUVRE
  If clalev([F:WRET])=0 : Local File RETRO     [WRET] : Endif
Return

#######################################################
$EXEC
Local Char TIT(50)

  TIT= mess(225,10703,1)-'"'+mess(3,10644,1)+'"'
  If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
  Endif

  Call VALID_RETRO

  If !GSERVEUR
    Call FERME_TRACE From LECFIC
  Endif
Return

###############################################################
$TERMINE
  If !GSERVEUR
    TRA = 1
  Else
    TRA = 0
  Endif
Return


Subprog VALID_RETRO
  Local Mask TRTRETVAL [DIA]

  #Déclaration des variables et des tables qui seront utilisées dans TR1 de TRTRETVAL
  Gosub OUVRE From TRTRETVAL

  Filter [WRET] Where RETTYP=3 and STATUT=2

  For [WRET]RET0
    [M:DIA]DATEXT=[F:WRET]DATMININT-5
    [M:DIA]DATPAY=[F:WRET]DATMININT-3
    [M:DIA]RETNUM=[F:WRET]RETNUM
    [M:DIA]FLGIMP=1
    Gosub TRAITEMENT From TRTRETVAL
    If GOK
      Call ECR_TRACE(mess(2,10725,1)-[WRET]RETNUM-mess(3,10645,1), 0) From GESECRAN
    Endif
  Next
End

