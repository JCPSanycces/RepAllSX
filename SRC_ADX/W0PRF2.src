#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone TBL
mkstat = 0
zoncou = "TBL"
indice = 0
status = 1
zoncou = "TBL"
If varmode([M]TBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TBL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]TBL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]TBL = nolign
   status = 75
   Call SAI_TBL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_TBL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone TBL
mkstat = 0
zoncou = "TBL"

## Zone CODE
mkstat = 0
zoncou = "CODE"
If varmode([M]CODE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODE" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODE(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTRUB"
  Call CONTRUB([M]CODE(indice)) From SUBRUB
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CODE(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CODE(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CODE([M]CODE(indice)) From SUBPRF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CODE" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone TYPRUB
mkstat = 0
zoncou = "TYPRUB"
IMPENT = [M]TYPRUB(indice)
If varinit([M]TYPRUB,indice)=0
 IMPENT = 1
Endif
[M]TYPRUB(indice) = IMPENT

## Zone CALCUL
mkstat = 0
zoncou = "CALCUL"
IMPENT = [M]CALCUL(indice)
If varinit([M]CALCUL,indice)=0
 IMPENT = 1
Endif
If varmode([M]CALCUL,indice)=0
 [M]CALCUL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CALCUL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CALCUL(indice)
 Endif
Endif
[M]CALCUL(indice) = IMPENT

## Zone TBL
mkstat = 0
zoncou = "TBL"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PRF2"
Return

