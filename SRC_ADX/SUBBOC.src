#<AdxTL>@(#)10.0.0.0 $Revision$
# Sélection pour Copie nomenclature        TB 12/02/98  -- Web 13/12/00
# premier niveau et multi niveau
# Pour l'instant copie sur article UNIQUE
#######################################################################
# La saisie initiale est une saisie de FENETRE sous "forme" de dialogue
# pour éviter les confusion de mask DIA avec les traitements de btn de [BOD1]NBLIG
#######################################################################
# Fenêtre principale :
# Affichage / modif / Validation des nouvelles nomenclatures
# Tous les écrans liens sont sous la même abrév pour utiliser les mêmes subprog
# Les écrans BOCx(1,2,3,4) ont la zone Niveau en plus et sont affichés seulement
# GA 11/2005 ajout BOMS
# GA 03/2006 les lignes BOMS sont remises dans BOMD avec CPNTYP=7

$ACTION
Case ACTION
 When "INIT"     Gosub INIT
 When "CONTROLE" Gosub CONTROLE
 When "EXEC"     Gosub EXEC
 When "TERMINE"  Gosub TERMINE
 When "SORTIE"   Gosub SORTIE

 # pour GSAISIE de la fenêtre principale
 When "DEBUT":    If BOITE <> "DBOMCOP" : Gosub DEBUTCOP : Else : Gosub DEBUT : Endif
 When "SETBOUT"  Gosub SETBOUT
 When "CRE"
       If [M:BOC0]TRT = 1
           Gosub VALID   # correspond au btn Créer de la fenêtre OBOD
       Else
           Gosub VALMULT
       Endif
       FIN = 1

 When "END"  If BOITE="DBOMCOP" PARAM(1) = "END" Endif
 When "FIN"  Raz GFONC1  # 18/01/02

Endcase
Return

$INIT
Local    Integer TOK , OK
Local    Char TEX(15)(30), ERR_TRA(132)
Global   Integer GNIV, GBOHLLC
If clalev([F:ACC]) = 0 : Local File ACCES      [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif

Local Mask BOMCOP0 [BOC0] # pour la conserver pendant le traitement !
Raz GDATEREF   # pour sélection composé (FILTRE de SUBBODA)
Return

$CONTROLE
# paramètre en retour de la fenêtre initiale
If PARAM(1) = "END"
  FIN = 1
  Return
Endif

# affectation de la bonne fenêtre selon le type de trt et le type d'alternative
If clalev([M:BOH0])=0 : Local Mask BOH0 [BOH0] Endif : # mêmes écrans que gestion
If [M:BOC0]ALTTYP = 2
   GFONBOD = "BOMP"
   If [M:BOC0]TRT = 3  # multi niveau
      Local Mask BOC1 [BOD1]
      BOITE = "FBOC1"
   Else
      Local Mask BOD1 [BOD1]
      BOITE = "FBOCP"  # Premier niveau = Gestion nomenclature
   Endif  #    ## probleme erreur PSUB  v 140 : NOUVELLES FENETRES type Divers

Elsif [M:BOC0]ALTTYP = 1
   GFONBOD = "BOMC"
   If [M:BOC0]TRT = 3
      Local Mask BOC2 [BOD1]
      BOITE = "FBOC2"
   Else
      Local Mask BOD2 [BOD1] : # MÊME ABREV pour les subprog de zones
      BOITE = "FBOC"  # v 140
   Endif

Elsif [M:BOC0]ALTTYP = 3
# GA 11/2005 copie nomenclature sous-traitance
   GFONBOD = "BOMS"
   If [M:BOC0]TRT = 3  # multi niveau
      Local Mask BOC3 [BOD1]
      Local Mask BOC4 [BODS] : # Préparation Liste des services
      BOITE = "FBOC3"
   Else
      Local Mask BOD3 [BOD1]
      Local Mask BOS2 [BODS] : # Préparation Liste des services
      BOITE = "FBOCS"  # Premier niveau = Gestion nomenclature
   Endif
Endif

If [M:BOC0]TRT = 1
# 1er niveau
     OK = 1
     Call FILTCOP(OK)
     # "Erreur d'accès sur fichier (Entête ?) de nomenclature ..."
     If OK = 0
       GERR = 1
       GMESSAGE=mess(12,100,1)-"BOH:"-[F:ITM]ITMREF-num$([M:BOC0]ALTORG) # 02/07/01
     Endif

Else
# multi-niveaux
     OK = 0
     Read [BOH]BOH0=[M:BOC0]ITMSEL;[M:BOC0]ALTORG;[M:BOC0]ALTTYP
     If !fstat
        [M:BOH0] = [F:BOH]
        [M:BOH0]BOMALT = [M:BOC0]ALTDST
      # GH 31/12/12 bug 85668
        Call LECTEXTRA([M:BOH0]BOMDESAXX,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA

        OK = 1 : GNIV = 0
        nolign = 0
        Call COPMULT([M:BOC0]ITMSEL,[M:BOC0]ALTORG,OK)
        # à laisser ici à cause de la récursivité ?
        [M:BOD1]NBLIG = nolign

      # GA 11/2005 copie nomenclature sous-traitance: liste des services
        If [M:BOC0]ALTTYP = 3
           nolign = 0
           Call COPMULT_BOMS([M:BOC0]ITMSEL,[M:BOC0]ALTORG,OK)
           [M:BODS]NBLIG = nolign
        Endif

     Else
       GERR = 1
       GMESSAGE=mess(12,100,1)-"BOH:"-[M:BOC0]ITMSEL-num$([M:BOC0]ALTORG) # 02/07/01
     Endif
Endif
If GERR = 0  TMP = 1  Endif
Return

#######################################################################
$DEBUT
Affzo [M:BOC0]
Return

$DEBUTCOP
Affzo [BOH0]

# entête grisé pour interdire la modif en multi-niv; BOC1/2 : affichés seulement
If [M:BOC0]TRT = 3
# Multi niveau: fenêtre FBOC1,FBOC2,FBOC3
# Diszo [BOH0]5, BOMDES , BOMSTU , QTYCOD, BASQTY , BOHSTRDAT, BOHENDDAT    # 17991 05.03 MM
# Diszo [BOH0]5, BOMDESAXX, BOMSTU , QTYCOD, BASQTY , BOHSTRDAT, BOHENDDAT   # FGR 01/10/2009 : X3SUIVI57935
 Diszo [BOH0]5, BOMSTU , QTYCOD, BASQTY , BOHSTRDAT, BOHENDDAT              # GH 31/12/12 bug 85668

 [M:BOH0]USESTA=1                                                           # 17991 05.03 MM
 # BOCx étaient ouverts sous abv BOD1 pour le chargement ; il faut
 # copier l'autre masque car GSAISIE les ouvre avec l'abv du dico
 If [M:BOC0]ALTTYP = 1
   # Issue X3-36381 [M:BOC2] = [M:BOD1]
   Raz [M:BOC2]
   Transmask [M:BOD1] To [M:BOC2]
   Affzo [BOC2]
 Elsif [M:BOC0]ALTTYP = 2
   # Issue X3-36381 [M:BOC1] = [M:BOD1]
   Raz [M:BOC1]
   Transmask [M:BOD1] To [M:BOC1]
   Affzo [BOC1]
 Elsif [M:BOC0]ALTTYP = 3
   # Issue X3-36381 [M:BOC3] = [M:BOD1]
   # Issue X3-36381 [M:BOC4] = [M:BODS]
   Raz [M:BOC3], [M:BOC4]
   Transmask [M:BOD1] To [M:BOC3]
   Transmask [M:BODS] To [M:BOC4]
   Affzo [BOC3] : Affzo [BOC4]
 Endif
Else
# 1er niveau: fenêtre  FBOC,FBOCP,FBOCS(2 onglets)
   Affzo [BOD1]
   If [M:BOC0]ALTTYP = 3
      # Issue X3-36381 [M:BOS2] = [M:BODS]
      Raz [M:BOS2]
      Transmask [M:BODS] To [M:BOS2]
      Affzo [BOS2]
   Endif
   Diszo [BOH0]ITMREF, BOMALT, DATREF
   Default File [BOH] # pour être dans le même contexte que l'objet BOD (18/01/02)
   GFONC1 = "GESBOD"  #
Endif
Return

$SETBOUT
ETABOU(GCREE) = 1 # on est en situation de création de nomenclature
ETABOU(GSUPP) = 0
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0 # désactiver Btn multiniv (17/01/02)
Return

$EXEC
Return

$TERMINE
#Close Local Mask [BOH0], [BOD1]
If clalev([M:BOH0]) > 0 : Close Local Mask [BOH0] : Endif
If clalev([M:BOD1]) > 0 : Close Local Mask [BOD1] : Endif
If clalev([M:BODS]) > 0 : Close Local Mask [BODS] : Endif
# correction bug 15584 : laisser les alternatives 14/05/03
Default Mask [M:BOC0]
Raz [M:BOC0]ITMSEL,[M:BOC0]FILART,[M:BOC0]TRT
TRA = 1
SAI = 1
Return

$SORTIE
Raz GFONBOD
Raz [M:BOC0]  # effacer tout en sortant    14/05/03
Return

# Ce sous-pro extrait les nomencl. et les charge dans les masques
#################################################################
Subprog FILTCOP(OK)
Variable Integer OK

Local File ITMMASTER [ITM2]

##If [M:BOC0]ITMSEL = toupper(mess(20,197,1))
##   [M:BOC0]FILART = "1=1"
##Elsif [M:BOC0]ITMSEL <> toupper(mess(36,198,1))
   [M:BOC0]FILART = 'ITMREF ="'+[M:BOC0]ITMSEL + '"' :# pour un article défini
##Endif : # POUR L'INSTANT MODE DIRECT: UN SEUL ARTICLE

nolign = 0
For [ITM] Where evalue([M:BOC0]FILART) :# si filtre sur ITM passer par F.travail
#  + distinguer les types d'alternatives
   Read [BOH]BOH0=[F:ITM]ITMREF;[M:BOC0]ALTORG;[M:BOC0]ALTTYP
   If fstat  OK = 0 : Break : Endif
   [M:BOH0] = [F:BOH]
   [M:BOH0]BOMALT = [M:BOC0]ALTDST
 ## GH 31/12/12 bug 85668
   Call LECTEXTRA([M:BOH0]BOMDESAXX,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
 ## GA 03/2006
 # copie nomenclature(production/commerciale/sous-traitance): liste des composants
 ##For [BOD] Where ITMREF=[F:ITM]ITMREF & BOMALT=[M:BOC0]ALTORG With Lock
   For [BOD] Where ITMREF=[F:ITM]ITMREF & BOMALT=[M:BOC0]ALTORG & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP<7 With Lock
     nolign += 1
     [M:BOD1] = [F:BOD]
     If [F:BOD]CPNTYP <> 5
         Read [ITM2]ITM0=[F:BOD]CPNITMREF
#     03.07 Demande 40156
#     [M:BOD1]ITMDES1(nolign-1) = [F:ITM2]ITMDES1
         [M:BOD1]STU(nolign-1)     = [F:ITM2]STU
     Endif
     # process 03.03 MM
     If dim([M:BOD1]BOMUOM(nolign-1))>0
        If [M:BOD1]BOMUOM(nolign-1)=""
           [M:BOD1]BOMUOM(nolign-1)=[M:BOD1]STU(nolign-1)
           [M:BOD1]BOMSTUCOE(nolign-1)=1
           [M:BOD1]BOMQTY(nolign-1)=[M:BOD1]LIKQTY(nolign-1)
        Endif
     Endif
     # Fin process 03.03 MM
   Next
   [M:BOD1]NBLIG = nolign

 # GA 11/2005 cela sera à revoir si multi-articles ...
 # copie nomenclature sous-traitance: liste des services
   If [M:BOC0]ALTTYP = 3
       nolign = 0
    ## GA 03/2006 remplacement table BOMS par BOMD Where CPNTYP=7
       For [BOD] Where ITMREF=[F:ITM]ITMREF & BOMALT=[M:BOC0]ALTORG & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP=7 With Lock
         nolign += 1
         [M:BODS] = [F:BOD]
         Read [ITM2]ITM0=[F:BOD]CPNITMREF
#  03.07 Demande 40156
#  [M:BOD1]ITMDES1(nolign-1) = [F:ITM]ITMDES1
       Next
       [M:BODS]NBLIG = nolign
   Endif
Next
End

# Ce sous-pro extrait l'arborescence de la nomencl. à copier
#################################################################
Subprog COPMULT(ART,ALT,OK)
Value    Char ART
Value Integer ALT
Variable Integer OK

Local Integer WLLCTYP

Local Integer J  # au cas où un composé n'a plus de cpn !(TB 09/00)
Local File BOMD [BOD] Where ITMREF = ART & BOMALT = ALT & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP<7
Read [BOD] First
If !fstat : J = 1 : GNIV += 1 : Endif
While !fstat
# chargement des ecrans
  nolign += 1
# Trop de liens d'alternative de production/commerciale. Le tableau sera incomplet
  If nolign > dim([M:BOD1]BOMSEQ)
     nolign -= 1
     If [M:BOC0]ALTTYP = 2
        GMESSAGE = mess(187,199,1) : GERR = 2
     Elsif [M:BOC0]ALTTYP = 1
        GMESSAGE = mess(188,199,1) : GERR = 2
     Elsif [M:BOC0]ALTTYP = 3
        GMESSAGE = "BOMD:"-mess(512,199,1) : GERR = 2
     Endif
     OK = 0
     Break
  Endif
  [M:BOD1] = [F:BOD]
  If [F:BOD]CPNTYP <> 5
      Read [ITM]ITM0=[F:BOD]CPNITMREF
#      [M:BOD1]ITMDES1(nolign-1) = [F:ITM]ITMDES1
      [M:BOD1]STU(nolign-1)     = [F:ITM]STU
  Endif
  [M:BOD1]NIVBOM(nolign-1)  = GNIV
  # process 03.03 MM
     If dim([M:BOD1]BOMUOM(nolign-1))>0
        If [M:BOD1]BOMUOM(nolign-1)=""
         [M:BOD1]BOMUOM(nolign-1)=[M:BOD1]STU(nolign-1)
         [M:BOD1]BOMSTUCOE(nolign-1)=1
         [M:BOD1]BOMQTY(nolign-1)=[M:BOD1]LIKQTY(nolign-1)
        Endif
     Endif
  # Fin process 03.03 MM
# Descente de la nomenclature
  WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
  Read [F:ITB]ITB0=[F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
  If !fstat & [F:ITB]BOMEXIFLG = 2
     Call COPMULT([F:BOD]CPNITMREF,[F:BOD]BOMALT,OK)
     If OK = 0 : Break : Endif
  Endif
  Read [BOD] Next
Wend
If J = 1 GNIV -= 1 Endif
Close Local File         # 25/01/02 pour vider de la mémoire (!!)
End



# Ce sous-pro extrait l'arborescence de la nomencl. à copier
#################################################################
Subprog COPMULT_BOMS(ART,ALT,OK)
Value    Char ART
Value Integer ALT
Variable Integer OK

Local Integer J  # au cas où un composé n'a plus de cpn !(TB 09/00)
#GA 03/2006 remplacement de BOMS par BOMD Where CPNTYP=7
Local File BOMD [BOD] Where ITMREF = ART & BOMALT = ALT & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP=7
Read [BOD] First
If !fstat : J = 1 : GNIV += 1 : Endif
While !fstat
# chargement de l'ecran (pas de recursivite ici)
  nolign += 1
  If nolign > dim([M:BODS]BOMSEQ)
     nolign -= 1
   # Trop de liens d'alternative de sous-traitance. Le tableau sera incomplet
     GMESSAGE = "BOMS:"-mess(512,199,1) : GERR = 2
     OK = 0
     Break
  Endif
  [M:BODS] = [F:BOD]
  If dim([M:BODS]NIVBOM(nolign-1))>0  : # si on est en multi-niveau dans BOC4
         [M:BODS]NIVBOM(nolign-1)  = GNIV
  Endif
  Read [ITM]ITM0=[F:BOD]CPNITMREF
#  [M:BODS]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  Read [BOD] Next
Wend
If J = 1 GNIV -= 1 Endif
Close Local File         # 25/01/02 pour vider de la mémoire (!!)
End


# Ce sous-pro recopie l'arborescence de la nomencl. et màj le LLC
#################################################################
# Issue 118021 GH 07/09/2016 - if there is an issue for ITMBOM updates, it doesn't stop the transaction
#                              in this case, we ask to execute the resynchronization of LLC
#Subprog WRI_MUL(ART,ALT)
#Value Char    ART
#Value Integer ALT
Subprog WRI_MUL(ART,SYNCLLC)
Value Char       ART
Variable Integer SYNCLLC

Local Char    ERR_TRA(132) : # redéfini pour sortie trace, vide à l'entrée
Local Integer J, EXI_DST, TROUVE : # BOMEXIORG
Local Integer WRETOUR  # (12/12/00)
Local Integer WLLCTYP
WLLCTYP = func LLCLIB.LLCTYP([M:BOC0]ALTTYP)

Onerrgo ERREUR From CONTROLE
# Issue 118021 GH 07/09/2016 - ITMBOM records should be generated for components used as a service
#Local File BOMD [BOD] Where ITMREF = ART & BOMALT = ALT & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP<7 :# enreg origine
Local File BOMD [BOD] Where ITMREF = ART & BOMALT = [M:BOC0]ALTORG & BOMALTTYP=[M:BOC0]ALTTYP : # enreg origine
Onerrgo
If GERREUR : End : Endif

# Lecture des liens origine
Read [BOD] First
If !fstat : GNIV += 1 : TROUVE = 1 : Endif

While !fstat
# écrire BOMD
  [F:BODW] = [F:BOD]
  [F:BODW]BOMALT = [M:BOC0]ALTDST
  ABLIG= "BODW" : Gosub INICRE_LIG From TABLEAUX
  #----------------------------------------------------#
  # duplication des textes des liens                   #
  #----------------------------------------------------#
  If [F:BOD]BOMTEXNUM <> ""
        [F:BODW]BOMTEXNUM = [F:BOD]BOMTEXNUM
        Call DUP_CLOB("BOD",[F:BODW]BOMTEXNUM,GOK) From TRTX3TEX
  Endif
  Write [BODW] : # ne pas faire de look : cela changerait l'enreg Curr
  If fstat = 3 : # le lien existe déjà
     ERR_TRA = mess(22,100,1)-"BOD:" -[F:BODW]ITMREF-num$([F:BODW]BOMALT)
     ERR_TRA -= num$([F:BOD]BOMSEQ) - [F:BOD]CPNITMREF
     Call ECR_TRACE(ERR_TRA,1) From GESECRAN
     ERR_TRA = ""
  Endif
# même si le lien existait il faut continuer car les sous-niveaux
# n'existent peut-être pas ...

# Issue 118021 GH 07/09/2016 - the standard routine is now used
## lire l'enreg ITB origine et conserver son flag BOMEXIFLG
#  WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
#  Read [F:ITB]ITB0=[F:BOD]CPNITMREF;[M:BOC0]ALTORG;WLLCTYP
#  If !fstat
#     BOMEXIORG = [F:ITB]BOMEXIFLG
#  Endif
## (ré)écrire l'enreg ITMBOM composant (dans ts les cas forcer BOMEXIFLG)
#  Readlock [F:ITB]ITB0=[F:BODW]CPNITMREF;[M:BOC0]ALTDST;WLLCTYP
#  If fstat = 5
#     Raz [F:ITB]
#     If BOMEXIORG = 2 : [F:ITB]BOMEXIFLG = 2 : Endif
#     [F:ITB]ITMREF = [F:BODW]CPNITMREF
#     [F:ITB]BOMALT = [F:BODW]BOMALT
#     [F:ITB]LLCTYP = WLLCTYP
#     [F:ITB]WUSEXIFLG = 2
#     [F:ITB]LLC    = GSAVLLC + GNIV
#     [F:ITB]BOHITM = [F:BOD]ITMREF
#     [F:ITB]CREDAT = date$
#     [F:ITB]CREUSR = GUSER
#     Write [ITB]
#     If fstat GOK = 0 : Break : Endif : # err d'écriture ! Déphasage
#  Elsif fstat = 1  : # enreg déjà locké : rollback
#     GOK = -1 : GLOCK = "$ITMBOM"-[F:ITB]ITMREF-num$([F:ITB]BOMALT)-num$([F:ITB]LLCTYP) : Break
#  Elsif !fstat & [F:ITB]LLC < (GSAVLLC + GNIV) :# ITB existait avec un LLC<
#     [F:ITB]WUSEXIFLG = 2
#     If BOMEXIORG = 2 : [F:ITB]BOMEXIFLG = 2 : Endif
#     [F:ITB]LLC       = GSAVLLC + GNIV
#     [F:ITB]BOHITM    = [F:BOD]ITMREF
#     Rewrite [ITB]
#     If fstat GOK = 0 : Break : Endif : # err d'écriture ! Déphasage
#     GBOHLLC = GSAVLLC
#     Call CALCLLC([F:BODW]CPNITMREF,[F:BODW]BOMALT,[F:BOD]BOMALTTYP,"+") From LLCLIB
#     If GOK =-1 : Break : Endif : # cas d'enreg lockés
#  Elsif !fstat & [F:ITB]LLC = (GSAVLLC + GNIV)
#     [F:ITB]BOHITM = "" : # plusieurs composés aux même niveau
#     If BOMEXIORG = 2 : [F:ITB]BOMEXIFLG = 2 : Endif
#     Rewrite [ITB]
#     If fstat GOK = 0 : Break : Endif : # err d'écriture ! Déphasage
#  Endif
  J=GOK : GOK=1
  Call UPDLLC([F:BODW]BOMALTTYP, [F:BODW]BOMALT, [F:BODW]ITMREF, [F:BODW]CPNITMREF, [F:BODW]CPNTYP, +1) From SUBBODB
  If GOK<1 : SYNCLLC=1 : Endif
  GOK=J

  If [F:BODW]CPNITMREF<>"" & [F:BODW]CPNTYP<>7  : # If BOMEXIORG = 2
# Le composant a lui-même une nomencl : on créé alors l'entête
     Read [BOH]BOH0=[F:BOD]CPNITMREF;[M:BOC0]ALTORG;[M:BOC0]ALTTYP
     If !fstat
       [F:BOH]BOMALT = [M:BOC0]ALTDST
       [F:BOH]USESTA = [M:BOH0]USESTA              # 17991 05.03 MM
       ABLIG= "BOH" : Gosub INICRE_LIG From TABLEAUX
      #----------------------------------------------------#
      # duplication du texte de l'entête                   #
      #----------------------------------------------------#
       If [F:BOH]HEATEX <> ""
          #--- dupli texte entete ---  attribution d'un nouveau numéro
          Call DUP_CLOB("BOH",[F:BOH]HEATEX,GOK) From TRTX3TEX
       Endif

       # GH 31/12/12 bug 85668
       [F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
       Call LECTEXTRA([M:BOH0]BOMDESAXX,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([M:BOC0]ALTORG),num$([F:BOH]BOMALTTYP)) From ATEXTRA
       Call MAJTEXTRA([M:BOH0]BOMDESAXX, "BOM", "BOMDESAXX", [F:BOH]IDENT1,num$([F:BOH]BOMALTTYP)) From ATEXTRA

       Write [BOH]
       If fstat = 3 : # s'il existe déjà
          EXI_DST = 1
          ERR_TRA = mess(22,100,1)-"BOH:"-[F:BOH]ITMREF -num$([F:BOH]BOMALT)
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
          ERR_TRA = ""
       Elsif !fstat
  #       Trace de Création avec clé de l'enreg
          ERR_TRA = mess(51,197,1)-"BOH:"-[F:BOH]ITMREF -num$([F:BOH]BOMALT)
          Call ECR_TRACE(ERR_TRA,0) From GESECRAN
          ERR_TRA = ""
       Endif

  # Descente de la nomenclature (RECURSIVITE) à moins que le composé existe
       If EXI_DST = 0
          # Issue 118021 GH 07/09/2016 - This ITMBOM record should already exist because of the component
          #                              but we should indicate it is also a coupound
          J=GOK : GOK=1
          Readlock [ITB]ITB0=[F:BOH]ITMREF;[F:BOH]BOMALT;WLLCTYP
          If fstat = 1
             GOK = -1
             GLOCK = "$ITMBOM"-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$(WLLCTYP)
          Elsif fstat
             GOK=0
          Elsif [F:ITB]BOMEXIFLG<>2
             [F:ITB]BOMEXIFLG = 2
             Rewrite [ITB]
             If fstat : GOK=0 : Endif
          Endif
          If GOK<1 : SYNCLLC=1 : Endif
          GOK=J

          Call WRI_MUL([F:BOH]ITMREF,SYNCLLC)
          If GOK < 1 : Break : Endif
       Endif

       EXI_DST = 0
     Endif
  Endif
  Read [BOD] Next
Wend

If TROUVE : GNIV -= 1 : Endif : # sécurité supplémentaire avant décrementation

If GOK = -1 : # cas d'enregistrements verrouillés
   ERR_TRA = mess(60,100,1) - GLOCK
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   ERR_TRA = ""
Endif
# Close Local File    # 25/01/02 pour vider de la mémoire - GA 24/11/2005 dans VALMULT
End

# Issue 118021 GH 07/09/2016 - not used anymore - included in WRI_MUL_BOMS to manage ITMBOM records for services
###################################################################
# Ce sous-pro recopie les services de la nomencl. de sous-traitance
###################################################################
Subprog WRI_MUL_BOMS(ART,ALT)
Value Char    ART
Value Integer ALT

Local Char    ERR_TRA(132) : # redéfini pour sortie trace, vide à l'entrée
Local Integer BOMEXIORG, EXI_DST, TROUVE
Local Integer WRETOUR  # (12/12/00)

Onerrgo ERREUR From CONTROLE
#GA 03/2006 remplacement de BOMS par BOMD Where CPNTYP=7
Local File BOMD [BOD] Where ITMREF = ART & BOMALT = ALT & BOMALTTYP=[M:BOC0]ALTTYP & CPNTYP=7
Onerrgo
If GERREUR : End : Endif

# Lecture des liens origine
Read [BOD] First
If !fstat : GNIV += 1 : TROUVE = 1 : Endif

While !fstat
# écrire BOMS
  [F:BOSW] = [F:BOD]
  [F:BOSW]BOMALT = [M:BOC0]ALTDST
  ABLIG= "BOSW" : Gosub INICRE_LIG From TABLEAUX
  #----------------------------------------------------#
  # duplication des textes des liens                   #
  #----------------------------------------------------#
  If [F:BOD]BOMTEXNUM <> ""
     [F:BOSW]BOMTEXNUM = [F:BOD]BOMTEXNUM
     Call DUP_CLOB("BOD",[F:BOSW]BOMTEXNUM,GOK) From TRTX3TEX
  Endif
  Write [BOSW] : # ne pas faire de look : cela changerait l'enreg Curr
  If fstat = 3 : # le lien existe déjà
     ERR_TRA = mess(22,100,1)-"BOMS:" -[F:BOSW]ITMREF-num$([F:BOSW]BOMALT)
     ERR_TRA -= num$([F:BOD]BOMSEQ) - [F:BOD]CPNITMREF
     Call ECR_TRACE(ERR_TRA,1) From GESECRAN
     ERR_TRA = ""
  Endif
  Read [BOD] Next
Wend

If TROUVE : GNIV -= 1 : Endif : # sécurité supplémentaire avant décrementation

If GOK = -1 : # cas d'enregistrements verrouillés
   ERR_TRA = "BOMS:"-mess(60,100,1) - GLOCK
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   ERR_TRA = ""
Endif
End


$VALID
Global Integer GOK
Local Char    ABLIG(4)
Local Integer SAVLLC, SIGN
Local Integer WRETOUR
Local Char    WNUMTEX (12)

# Fichier TRACE "Copie nomenclature 1er niveau" Sélections et erreurs
Call OUVRE_TRACE(mess(118,199,1)) From LECFIC
ERR_TRA = mess(34,197,1) - [M:BOC0]ITMSEL
Call ECR_TRACE(ERR_TRA,0) From GESECRAN
ERR_TRA = mess(36,197,1) - mess(40,197,1)- ":" - num$([M:BOC0]ALTORG)
ERR_TRA -= mess(41,197,1)- ":" - num$([M:BOC0]ALTDST)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

GOK = 1
Trbegin [BOD]
Raz [F:BOH]  # rajouté le 12/12/00
[F:BOH] = [M:BOH0]
ABLIG = "BOH" : # pour zones standard
Gosub INICRE_LIG From TABLEAUX

#----------------------------------------------------#
# duplication des textes si pas accès a ces derniers #
#----------------------------------------------------#
If [M:BOH0]HEATEX <> ""
   [F:BOH]HEATEX = [M:BOH0]HEATEX
   Call DUP_CLOB("BOH",[F:BOH]HEATEX,GOK) From TRTX3TEX
Endif

Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
[F:BOH]ACSCOD = [F:TBO]ACSCOD  # bug 6336  Code accès en Redondance 12/01/01

[F:BOH]IDENT1 = [M:BOH0]ITMREF + "~" + num$([M:BOH0]BOMALT) : # GH 31/12/12 bug 85668

Write [BOH]

GREP = "D"          :# simulation de Duplication !
Default Mask [BOD1] :# indispensables pour que l'étiquette CREATION marche
Gosub CREATION From SUBBODA : # même traitement que gestion nomenclature
#
#
If GOK < 1
   Call ECR_TRACE(mess(20,100,1) - GLOCK,1) From GESECRAN
   Rollback
Else
   Commit
Endif
Call FERME_TRACE From LECFIC
Return

$VALMULT
Global Integer GOK
Local Char     ABLIG(4)
Local Integer  WLLCTYP, SYNCLLC
Local Integer  J

#Global Integer GSAVLLC : # global pour être utilisée par WRI_MUL
Local File BOMD [BODW] : # nouvelle classe pour le write
Local File BOMD [BOSW] : # nouvelle classe pour le write (avant BOMS)

# Fichier TRACE "Copie nomenclature multi niveau" Sélections et erreurs
Call OUVRE_TRACE(mess(119,199,1)) From LECFIC
ERR_TRA = mess(34,197,1) - [M:BOC0]ITMSEL
Call ECR_TRACE(ERR_TRA,0) From GESECRAN
ERR_TRA = mess(36,197,1) - mess(40,197,1)- ":" - num$([M:BOC0]ALTORG)
ERR_TRA -= mess(41,197,1)- ":" - num$([M:BOC0]ALTDST)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

GOK = 1
Trbegin [BOD]
Raz [F:BOH]
[F:BOH] = [M:BOH0] : # entete destination
ABLIG = "BOH" : # pour zones standard
Gosub INICRE_LIG From TABLEAUX

Read [TBO]TBO0=[M:BOH0]BOMALTTYP;[M:BOH0]BOMALT
[F:BOH]ACSCOD = [F:TBO]ACSCOD  # bug 6336  Code accès en Redondance 12/01/01

# GH 31/12/12 bug 85668
[F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
Call MAJTEXTRA([M:BOH0]BOMDESAXX, "BOM", "BOMDESAXX", [F:BOH]IDENT1,num$([F:BOH]BOMALTTYP)) From ATEXTRA

Write [BOH]
ERR_TRA = mess(51,197,1)-"BOH:"-[F:BOH]ITMREF -num$([F:BOH]BOMALT)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

WLLCTYP = func LLCLIB.LLCTYP([F:BOH]BOMALTTYP)
J=GOK : GOK=1
Readlock [ITB]ITB0=[F:BOH]ITMREF;[F:BOH]BOMALT;WLLCTYP
If fstat = 1  : # enreg déjà locké : rollback
   GOK = -1
   GLOCK = "$ITMBOM"-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$(WLLCTYP)
   # Goto ERR_ROLL
Elsif fstat
   Raz [F:ITB]
   [F:ITB]ITMREF = [F:BOH]ITMREF
   [F:ITB]BOMALT = [F:BOH]BOMALT
   [F:ITB]LLCTYP = WLLCTYP
   [F:ITB]BOMEXIFLG = 2
   [F:ITB]LLC    = 0
   [F:ITB]CREDAT = date$
   [F:ITB]CREUSR = GUSER
   Write [ITB]
   If fstat : GOK=0 : Endif
Elsif [F:ITB]BOMEXIFLG<>2
   [F:ITB]BOMEXIFLG = 2
   Rewrite [ITB]
   If fstat : GOK=0 : Endif
Endif
If GOK<1 : SYNCLLC=1 : Endif
GOK=J

#GSAVLLC = [F:ITB]LLC
Call WRI_MUL([F:BOH]ITMREF,SYNCLLC) : # récursivité arborescence
# Issue 118021 GH 07/09/2016 - WRI_MUL_BOMS now included in WRI_MUL to manage ITMBM records for services
#If [M:BOC0]ALTTYP = 3
#   Call WRI_MUL_BOMS([F:BOH]ITMREF,[M:BOC0]ALTORG) : # sans récursivité ici
#Endif

#$ERR_ROLL
If GOK<0
   Call ECR_TRACE(mess(20,100,1) - GLOCK,1) From GESECRAN
   Rollback
Elsif GOK = 0
   Call ECR_TRACE(mess(13,100,1) - "ITMBOM",1) From GESECRAN
   Rollback
Else
   Commit
   If SYNCLLC
     #Il est préférable de lancer une resynchronisation des codes de plus bas niveau !
     Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
     SYNCLLC=0
   Endif
Endif
Call FERME_TRACE From LECFIC
Close Local File [BODW] :  # GA 24/11/2005
Close Local File [BOSW] :  # GA 24/11/2005
Return


################################
# Etiquettes-sous-pro de zones #
################################
Subprog C_ITMSEL(VALEUR)
Variable Char     VALEUR
If  VALEUR <> ""
   Look [BOH]BOH0 = VALEUR;[M:BOC0]ALTORG;[M:BOC0]ALTTYP
   If fstat : mkstat=2 : GMESSAGE=mess(95,193,1) : End : Endif : # Nomenclature inexistante !

   Look [BOH]BOH0 = VALEUR;[M:BOC0]ALTDST;[M:BOC0]ALTTYP
   If !fstat : mkstat=2 : GMESSAGE=mess(125,199,1) : End : Endif # La nomenclature destination existe déjà

Endif
End

Subprog B3_ITMSEL(VALEUR)
Variable Char     VALEUR
#Local    Integer  OK
#Call SELECT("ITMMASTER",[M]FILART,OK) From ASELECT
# mettre le radio btn à "sélection"
End

########################################
Subprog AS_ITMSEL(VALEUR)
Variable Char    VALEUR()
# GBOUT2 = mess(20,197,1)
# GBOUT3 = mess(36,198,1) : # pour plus tard (mode différé)
End


Subprog C_ALTORG(VALEUR)
Variable Decimal  VALEUR
If VALEUR = [M]ALTDST : mkstat=2 : End : Endif
# "Les alternatives doivent être de même type"
If  [F:TBO]BOMALTTYP <> [M]ALTTYP
   mkstat=2 : GMESSAGE = mess(124,199,1) : End
Endif
End

Subprog C_ALTDST(VALEUR)
Variable Decimal VALEUR
#  "Pas d'autorisation de modif sur cette alternative"
Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD
If !fstat & [F:ACC]MODIF = 1
    mkstat=2 : GMESSAGE = mess(144,199,1)
Endif
End

Subprog AS_TRT(VALEUR)
Variable Integer  VALEUR
GMENLOC(2) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
# valeur sans signification dans ce contexte (03/04/03)
End

########################################
Subprog C_TRT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 | VALEUR = 4
  mkstat=1
Endif  # GMENLOC inefficace sur radio btn en web (12494)
End

Subprog AS_ALTORG(VALEUR)
Variable Decimal  VALEUR
# GA 23/11/2005 formule trop longue pour affecter le paramètre OPTIONA1
[M]OPTIONA1 = string$([M]ALTTYP=1,"A")+string$([M]ALTTYP=2,"B")+string$([M]ALTTYP=3,"D")
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BOMCOP0) 27/03/2006 15:33:08 (SR)
######################################################################################
Subprog S_ALTDST(VALEUR)
Variable Decimal VALEUR
If status = 7 : End : Endif
Read [F:TBO]TBO0 Curr
If !fstat [M]ALTTYP = [F:TBO]BOMALTTYP : Affzo [M]ALTTYP : Endif
End

