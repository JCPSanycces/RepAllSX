#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH9        Utilitaire de récupération du bug 17806    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Resynchroniser les dates comptables entêtes et lignes facture achat  #
#   [F:PID]ACCDAT = [F:PIH]ACCDAT                                        #
##########################################################################

Call MAJ_UTIACH9
End

Subprog MAJ_UTIACH9
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH9") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH9 : Utilitaire de màj dates comptables factures achat") From LECFIC
If DOSSIER<>"" Call EXE_UTIACH9(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog EXE_UTIACH9(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WMSG2(90), WNUM(GLONPIH), CLE1(GLONPIH), CRITERE(50)
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR,   WLIN,    WSEQ
#-----
Call ECR_TRACE("UTIACH9 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:PIH]) =0  Local File =DOSSIER+".PINVOICE"   [PIH] : Endif
If clalev([F:PID]) =0  Local File =DOSSIER+".PINVOICED"  [PID] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, NBENR, NBCOR
#-----
$BOUCLE_PIH
STOP=0
CRITERE='NUM>"'+CLE1+'"'
Raz COMPTEUR
Trbegin [PIH]
  For [PIH] Where evalue(CRITERE)
    WNUM=[F:PIH]NUM
    If COMPTEUR=0
      Call ECR_TRACE("----- Début de transaction ("+WNUM+")",0) From GESECRAN
    Endif
    COMPTEUR+=1
    NBENR+=1
    For [PID] PID0 Where NUM=[F:PIH]NUM
      WLIN=[F:PID]PIDLIN
      If [F:PID]ACCDAT<>[F:PIH]ACCDAT
        Update [PID] Where NUM=[F:PIH]NUM & PIDLIN=WLIN
&                    With ACCDAT=[F:PIH]ACCDAT
        If fstat  GOK=0 : Call FSTA("PID") From GLOCK : Break 2 : Endif
        WMSG ="Facture"-WNUM-num$(WLIN)
        WMSG-="Correction date comptable"
        WMSG-=num$([F:PID]ACCDAT)-"-->"-num$([F:PIH]ACCDAT)
        Call ECR_TRACE(WMSG,0) From GESECRAN
        NBCOR+=1 
      Endif
    Next
    If GOK=1
      If COMPTEUR>GMAXUPDTRS : CLE1=[F:PIH]NUM : STOP=1 : Break : Endif
    Else
      Break
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM+")",1) From GESECRAN
    Goto FIN_UTIACH9
  Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM+")",0) From GESECRAN
Endif
If STOP  Goto BOUCLE_PIH : Endif
#----- Fin du traitement -----#
$FIN_UTIACH9
WMSG ="UTIACH9 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [PIH]
Close Local File [PID]
End
