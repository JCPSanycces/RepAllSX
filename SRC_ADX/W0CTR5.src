# Gestion du masque CTR5 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone RPTBUL
mkstat = 0
zoncou = "RPTBUL"
indice = 0
If varmode([M]RPTBUL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RPTBUL([M]RPTBUL) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]RPTBUL : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "RPTBUL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("ARP","!",[M]RPTBUL,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "RPTBUL" : GZNUM = 45790 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_RPTBUL([M]RPTBUL) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "RPTBUL" : GZNUM = 45790 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FLGCREBUL
