zoncou = "NBRSAL"
indice = 0
status = 1
zoncou = "NBRSAL"
If varmode([M]NBRSAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRSAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRSAL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRSAL = nolign
   status = 75
   Call SAI_NBRSAL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

