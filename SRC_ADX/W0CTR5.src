zoncou = "FLGCREBUL"
indice = 0
IMPENT = [M]FLGCREBUL
WNUM = IMPENT
If varinit([M]FLGCREBUL,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCREBUL,indice)=0
 [M]FLGCREBUL(indice) = IMPENT
