 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGCREBUL" : GZNUM = 54943 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_FLGCREBUL(IMPENT) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FLGCREBUL" : GZNUM = 54943 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
