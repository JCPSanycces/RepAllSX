#<AdxTL>@(#)8.0.0.0 $Revision$

####################################################################################
# SUBMTKC                                                                          #
#Gosub's pour la mise à jour des fichiers liés à un suivi                          #
#                                                   sr Novembre 1998               #
#Gosub principaux :                                                                #
#                MAJOPE      : Maj des opérations en suivi opération               #
#                  Appelant  : LEC_PREC                                            #
#                              MAJ_SUIVANTE                                        #
#                              MAJ_TECCRD                                          #
#                MAJITM      : Maj articles lancés en déclaration de fabrication   #
#                              TRT_WIP                                             #
#                              TRT_MVT                                             #
#                              Subprog MAJ_ALLOCATION                              #
#               MAJMAT       : Maj matière en suivi matière                        #
#                  Appelant  :                                                     #
#                              SUPALL_OF                                           #
#                ANNULE_SUIV : Maj liées à la suppression d'un suivi               #
#                  Appelant  : ANNULE_SUIVOPE                                      #
#                              ANNULE_SUIVITM                                      #
#                              ANNULE_SUIVMAT                                      #
#                              MAJ_SUIVANTE                                        #
#                              CREALL_OF                                           #
#                              MAJMFGHEAD                                          #
#           TRT_MAJ_DOCUMENT : En modification des entrées                         #
# Call         MAJMFGHEAD    : Maj entête OF en création/Annulation de suivi       #
####################################################################################
#---------------------Maj liées au suivi d'opérations -----------------------------#
$MAJOPE
Local Decimal WCPLHOU
Local Integer WSOLDE,WI
Local Char    WACTION
Local Char    WPJT
If clalev([F:OPS])<=0 : Local File OPERATIONS [OPS] : Endif

For nolign = 1 To [M:MTK1]NBOPE
    #si l'opération a été suivie
     If [M:MTK1]MODIFLG(nolign-1) = 0 &
&       ([M:MTK1]CPLQTY(nolign-1) <> 0 | [M:MTK1]CPLOPETIM(nolign-1) <> 0 | [M:MTK1]CPLSETTIM(nolign-1) <> 0 |
&        ([M:MTK1]CLEFLG(nolign-1) <> [M:MTK1]WCLEFLG(nolign-1)))
    #Création enregistrement suivi opé
    # V 150 lecture opération et encours de charge pour récupérer l'affaire
      Raz WPJT
      If [M:MTK1]ROUOPENUM(nolign-1) <> 0
         Read [F:MFO]MFO0 = [M:MTK0]MFGNUM;[M:MTK1]OPENUM(nolign-1)
         If fstat : Raz  [F:MFO] : Endif
         Read [F:OPS]OPS1=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
         If fstat : Raz [F:OPS] : Endif
         WPJT = [F:OPS]PJT
      Endif

      # Issue 85671 GA 09/2014 3=Prohibited
      If [F:MTS]MATRICULE = 3 & [M:MTK1]EMPNUM(nolign-1)<>0
         [M:MTK1]EMPNUM(nolign-1)=0
      Endif

      Raz [F:MKO]
      [F:MKO]          = [M:MTK0]
      [F:MKO]          = [M:MTK1]
      For WI = 1 To 15
        [F:MKO]SCANUM(WI-1)    = evalue("[M:MTK1]SCANUM"+num$(WI)+"(nolign-1)")
        [F:MKO]TABREJQTY(WI-1) = evalue("[M:MTK1]TAREJQTY"+num$(WI)+"(nolign-1)")
      Next
      If [F:MKO]REJCPLQTY <> 0 & [F:MKO]TABREJQTY(0) = 0
         [F:MKO]TABREJQTY(0)  =  [F:MKO]REJCPLQTY
      Endif
      [F:MKO]PJT       = WPJT
      [F:MKO]IPTDAT    = [M:MTK0]MFGTRKDAT
      [F:MKO]DACDAT    = date$
      [F:MKO]DACHOU    = left$(time$,2)+mid$(time$,4,2)
      [F:MKO]CREDAT    = date$
      [F:MKO]CREUSR    = GUSER
      [F:MKO]EXPNUM    = [C]EXPORT
      If [M:MTK1]MKOTEX(nolign-1) <> ""
         [F:MKO]MKOTEX = [M:MTK1]MKOTEX(nolign-1)
         If left$([F:MKO]MKOTEX,3)="MKO"
              Call CRE_CLOB([F:MKO]MKOTEX,GOK) From TRTX3TEX
              If GOK<1 Return Endif
           Elsif !find(left$([F:MKO]MKOTEX,3),"ROT","ROO")
              Call DUP_CLOB("MKO",[F:MKO]MKOTEX,GOK) From TRTX3TEX
              If GOK<1 Return Endif
           Endif
       Endif
      WACTION = "C"
      GPOINT = "MKOMAJ"
      Gosub  ENTREE From EXEFNC
      Write [F:MKO]
      If fstat
            GOK = 0 : Call FSTA("MKO") From GLOCK : Break
      Endif


     #----- Ecriture des sections de la ligne operation -----#
     Gosub MAJMKO_CPTANALIN
     If GOK<1
         Break
     Endif

    #Maj Opération
     If [M:MTK1]ROUOPENUM(nolign-1) <> 0
    #----- MISE à jour statistiques ligne suivi opé -----#
         Call VALSTA("MKO",1) From SUBPS2
         If GOK < 1 : Break : Endif
         Readlock [F:MFO]MFO0 = [M:MTK0]MFGNUM;[M:MTK1]OPENUM(nolign-1)
         If fstat=1  GOK=-1 : GLOCK="$MFGOPE"-num$([M:MTK1]OPENUM(nolign-1)) : Break
         Elsif fstat GOK=0  : Call RSTA("MFO",num$([M:MTK1]OPENUM(nolign-1))) From GLOCK : Break
         Endif
    # llc 03.01 multi-exemplaire
    #     If [F:MFO]CPLWST <> [M:MTK1]CPLWST(nolign-1) :  [F:MFO]CPLWSTNBR += 1 : Endif
         [F:MFO]CPLWSTNBR = [F:MFO]EXTWSTNBR
         If [F:MFO]CPLWST = "" : [F:MFO]CPLWST = [M:MTK1]CPLWST(nolign-1) : Endif
         If [F:MFO]CPLLAB = "" : [F:MFO]CPLLAB = [M:MTK1]CPLLAB(nolign-1) : Endif
         [F:MFO]CPLQTY    += [M:MTK1]CPLQTY(nolign-1)    * [F:MKO]OPEWORCOE
         [F:MFO]REJCPLQTY += [M:MTK1]REJCPLQTY(nolign-1) * [F:MKO]OPEWORCOE
         [F:MFO]CPLSETTIM += [M:MTK1]CPLSETTIM(nolign-1)
         [F:MFO]CPLOPETIM += [M:MTK1]CPLOPETIM(nolign-1)
         If   [F:MFO]CPLUNTTIM = 0 : [F:MFO]CPLUNTTIM = [M:MTK1]CPLUNTTIM(nolign-1) / [M:MTK1]OPEWORCOE(nolign-1)
         Else [F:MFO]CPLUNTTIM  = avg([M:MTK1]CPLUNTTIM(nolign-1)/[M:MTK1]OPEWORCOE(nolign-1),[F:MFO]CPLUNTTIM)
         Endif
    # 11.06 demande 38402
    [F:MFO]CPLUNTTIM = func TRTX3.ARRTYP("","","TIH",[F:MFO]CPLUNTTIM)
         # CCC (10/01/08) DM 44021
         #If [F:MFO]TRKFIRST = "00/00/00" : [F:MFO]TRKFIRST = [F:MTK]MFGTRKDAT : Endif
         If [F:MFO]TRKLAST<[F:MTK]MFGTRKDAT
           [F:MFO]TRKLAST   = [F:MTK]MFGTRKDAT
         Endif
         If [F:MFO]TRKLASTC<date$
           [F:MFO]TRKLASTC  = date$
         Endif
         If [F:MFO]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFO]TRKFIRST = "00/00/00"
            [F:MFO]TRKFIRST = [F:MTK]MFGTRKDAT
         Endif
         If [F:MFO]TRKFIRSTC>date$ | [F:MFO]TRKFIRSTC = "00/00/00"
            [F:MFO]TRKFIRSTC = date$
         Endif
         Raz WSOLDE
    # mise à jour du flag solde selon différents cas
         If     [M:MTK1]CLEFLG(nolign-1) = 2 & [F:MFO]MFOTRKFLG < 5:#on solde une ligne
                # CCC (10/01/08) DM 44021
                #[F:MFO]TRKLAST = [F:MTK]MFGTRKDAT
                [F:MFO]OPESTA = 5
                [F:MFO]MFOTRKFLG = 5
                WOPECLENBR += 1
                WSOLDE = 1
         Elsif [M:MTK1]CLEFLG(nolign-1) = 1 & [F:MFO]MFOTRKFLG = 5 :#on désolde une ligne
                [F:MFO]OPESTA = 4
                # CCC (10/01/08) DM 44021
                #Raz [F:MFO]TRKLAST
                [F:MFO]MFOTRKFLG = 4
                WOPECLENBR -= 1
         Elsif [M:MTK1]CLEFLG(nolign-1) = 1 & [F:MFO]MFOTRKFLG < 4 :#une ligne passe à "encours"
                [F:MFO]OPESTA    = 4
                [F:MFO]MFOTRKFLG = 4
         Endif
         Gosub MAJ_SUIVANTE
         If GOK < 1 : Break : Endif
         Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
         Read [F:MFI]MFI0 First
         If !fstat
             Call UPDATE_OWX("SM",[F:MFI]PJT) From MFGLIBO
         Endif
         Filter [MFI]
         Rewrite [F:MFO]
         If fstat
            GOK = 0 : Call FSTA("MFO") From GLOCK : Break
         Endif
         #----- Mise à jour statistiques ligne opé -----#
         Call VALSTA("MFO",1) From SUBPS2  : If GOK<1  : Break  : Endif
      Endif
    #Maj éventuelle du fichier réponses fiche technique
         If [M:MTK1]TECCRD(nolign-1) <> ""
             Gosub MAJ_TECCRD
             If GOK = 0 : Break : Endif
         Endif
    #Maj du fichier WORKSTATIO
         Readlock [F:MWS]WST0 = [M:MTK1]CPLWST(nolign-1);[M:MTK0]MFGFCY
         If !fstat
             WCPLHOU = [M:MTK1]CPLOPETIM(nolign-1)
             If [M:MTK1]TIMUOMCOD(nolign-1) = 2 : WCPLHOU = WCPLHOU / 60 : Endif
             [F:MWS]CPLHOUTIM += func TRTX3.ARRTYP("","","TIH",WCPLHOU)
             Rewrite [F:MWS]
             If fstat
                 GOK = 0 : Call FSTA("MWS") From GLOCK : Break
             Endif
         Endif

    #------------------------------------------------------------------------------------------------------------------
    # point d'entrée WIP costing 14548
             If dim(WRET) < 0     : Local Integer WRET       : Endif
             If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
             GWIPCOST = "OPETRK_NEW"
             WRET = 0
             GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
             If WRET > 0 : GOK = 0 : Break : Endif
    #------------------------------------------------------------------------------------------------------------------
         Call OPETRK_NEW(WRET) From MWIPLIB   # (TB) Intégration WIP
         If WRET > 0 : GOK = 0 : Break : Endif

      Endif
Next
Return

################
#---------------------------------------------------------#
# Ecriture des sections de la ligne operation             #
#---------------------------------------------------------#
$MAJMKO_CPTANALIN

Call ENREG_ACCCCE(nolign-1,"","","[M:MTK1]CCE","MKO",0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLWST,"C") From TRTX3CPT
#
If [F:MKO]CPLLAB = "" : Return : Endif
Call ENREG_ACCCCE(nolign-1,"","","[M:MTK1]LABCCE","MKO",0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLLAB,"C") From TRTX3CPT

Return

################
$LEC_PREC
#Recup du statut de l'opération précédente
Local Integer J
If clalev([F:MFO1])<=0 : Local File MFGOPE [MFO1] : Endif
If clalev([F:SCH1])<=0 : Local File SCHEDULING [SCH1] : Endif
Filter [F:SCH1] Where MFGNUM = [F:MTK]MFGNUM & NEXOPENUM = [F:MFO]OPENUM
Read [F:SCH1]SCH0  First
If !fstat
    Read  [F:MFO1]MFO0=[F:MTK]MFGNUM;[F:SCH1]OPENUM
    If !fstat
       Case [F:MFO1]OPESTA
            When 4 :       [F:MFO]OPESTA  = 2
            When 5 :       [F:MFO]OPESTA  = 3
            When Default : [F:MFO]OPESTA  = 1
       Endcase
    Endif
Endif
Filter [F:SCH1]
Return

################
$MAJ_SUIVANTE
#maj du statut de l'opération suivante
Local Integer J
If clalev([F:MFO1])<=0 : Local File MFGOPE [MFO1] : Endif
If clalev([F:SCH1])<=0 : Local File SCHEDULING [SCH1] : Endif
If clalev([F:OPS1])<=0 : Local File OPERATIONS [OPS1] : Endif        :# 12/00 dem 7291
Filter [F:SCH1]
Filter [F:MFO1]
Filter [F:OPS1]

Read [F:SCH1]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If !fstat & [F:SCH1]NEXOPENUM <> 0
    Readlock  [F:MFO1]MFO0=[F:SCH1]MFGNUM;[F:SCH1]NEXOPENUM
    If !fstat
       If [F:MFO1]OPESTA < 4 & [F:MFO1]OPESTA <> 7
          Case [F:MFO]OPESTA
            When 4   :       [F:MFO1]OPESTA  = 2
            When 5   :       [F:MFO1]OPESTA  = 3
            When Default   : [F:MFO1]OPESTA  = 1
          Endcase
          Rewrite [F:MFO1]
          If fstat
             GOK = 0 : Call FSTA("MFO") From GLOCK : Return
          Endif
       Endif
       # mise à jour du statut dans l'encours de charge demande 7291
       Readlock [F:OPS1]OPS1=[F:MFO1]MFGNUM;[F:MFO1]OPENUM;[F:MFO1]OPESPLNUM :# 12/00
       If !fstat
           [F:OPS1]OPESTA = [F:MFO1]OPESTA
           Rewrite [F:OPS1]
           If fstat
              GOK = 0 : Call FSTA("OPS") From GLOCK : Return
           Endif
       Endif
    Endif
Endif
Return

################
$MAJ_TECCRD
#Enregistrement des réponses pour la fiche technique associée à l'opération
If clalev([F:MTA])<= 0 : Local File MTKCRDASW [MTA] : Endif
If clalev([F:QLW])<= 0 : Local File QLYWRK [QLW] : Endif
Filter [F:QLW] Where PRONUM = adxuid(1) & LINNUM = [M:MTK1]OPETRKLIN(nolign-1) & VCRTYP = 12
Look [F:QLW]QLW0 First
If fstat
# 10.06 demande 28860
#          If GCTLFICTEC < 3 : Return
#          Else : GOK = 0
#                 Filter [F:QLW]
#                 Call ERREUR(mess(23,190,1)-num$([M:MTK1]OPENUM(nolign-1))) From GESECRAN
#                 Return
#          Endif
   Return
Endif
For [F:QLW]
    Raz [F:MTA]
        [F:MTA]= [F:QLW]
        [F:MTA]MFGTRKNUM = [M:MTK0]MFGTRKNUM
        [F:MTA]OPETRKLIN = [M:MTK1]OPETRKLIN(nolign-1)
        [F:MTA]OPENUM    = [M:MTK1]OPENUM(nolign-1)
        [F:MTA]MFGNUM    = [M:MTK0]MFGNUM
        [F:MTA]EXPNUM    = [C]EXPORT
        Write [F:MTA]
        If fstat
           GOK = 0 : Call FSTA("MTA") From GLOCK : Break
        Endif
Next
Filter [F:QLW]
Delete [F:QLW] Where PRONUM = adxuid(1) & LINNUM = [M:MTK1]OPETRKLIN(nolign-1)
If GOK = 0 : GLOCK = "$"+"QLYWRK" : Endif

Return

#---------------------Maj liées à la déclaration de  production ---------------------------#
######################################################
$MAJITM
Local Integer WRETOUR, WSOLDE
Local Decimal WALLREJQTY
Local Integer WRET
Local Decimal LQTA, LSHT, PRI
Local Integer LNBR, LNBJ
Local Char    WLOT(GLONLOT), WACTION

For nolign = 1 To [M:MTK2]NBITM
#si l'article a été suivi
    If [M:MTK2]UOMCPLQTY(nolign-1) <> 0 & [M:MTK2]WSTOFLG(nolign-1) = 1
#Lecture éventuelle de article et article-site OF et article lancé
       If [F:ITM]ITMREF <> [M:MTK2]ITMREF(nolign-1)
          Read [F:ITM]ITM0 = [M:MTK2]ITMREF(nolign-1)
          If fstat GOK=0  : Call RSTA("ITM",[M:MTK2]ITMREF(nolign-1)) From GLOCK : Break : Endif
       Endif
       If [F:ITF]ITMREF <> [M:MTK2]ITMREF(nolign-1) | [F:ITF]STOFCY <> [M:MTK0]MFGFCY
          Read [F:ITF]ITF0 = [M:MTK2]ITMREF(nolign-1);[M:MTK0]MFGFCY
          If fstat GOK=0  : Call RSTA("ITF",[M:MTK2]ITMREF(nolign-1)+[M:MTK0]MFGFCY) From GLOCK : Break : Endif
       Endif
       If [F:MFI]MFGNUM <> [M:MTK0]MFGNUM | [F:MFI]MFGLIN <> [M:MTK2]MFGLIN(nolign-1)
           Read [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK2]MFGLIN(nolign-1)
           If fstat : Raz [F:MFI] : Endif
       Endif
       If [F:MFG]MFGNUM <> [M:MTK0]MFGNUM
           Read [F:MFG]MFG0 = [M:MTK0]MFGNUM
           If fstat : Raz [F:MFG] : Endif
       Endif

#Création enregistrement suivi decl prod
       Raz [F:MKI]
       [F:MKI] = [M:MTK0]
       [F:MKI] = [M:MTK2]
       [F:MKI]IPTDAT = [M:MTK0]MFGTRKDAT
       [F:MKI]CREDAT = date$
       [F:MKI]CREUSR = GUSER
       [F:MKI]EXPNUM = [C]EXPORT

       # Alimentation dépôt ligne si renseigné
       If dim([M:MTK2]WRH)>0 & [M:MTK2]WRH(nolign-1)<>""
        [F:MKI]WRH = [M:MTK2]WRH(nolign-1)
       Else
        [F:MKI]WRH = ""
       Endif

       #point d'entrée  pour mise à jour  spécifique   09.04 demande 25251
       WACTION = "C"
       GPOINT = "MKIMAJ" : Gosub ENTREE From EXEFNC
       #
       Write [F:MKI]
       If fstat
             GOK = 0 : Call FSTA("MKI") From GLOCK : Break
       Endif
 #----- Mise à jour statistiques ligne suivi article lancé -----#
       Call VALSTA("MKI",1) From SUBPS2
       If GOK < 1 : Break : Endif

 #----- Ecriture des sections de la ligne article lancé -----#
      Gosub MAJMKI_CPTANALIN
      If GOK<1
          Break
      Endif
#
#Maj Stock
      Raz [M:STW]
      [M:STW]STOFCY    = [F:MKI]MFGFCY
      [M:STW]TRSTYP    = 5
      [M:STW]VCRTYP    = 15
      [M:STW]VCRNUM    = [F:MKI]MFGTRKNUM
      [M:STW]VCRLIN    = [F:MKI]ITMTRKLIN
      [M:STW]ITMREF    = [F:MKI]ITMREF # Article
      [M:STW]MVTDES    = [M:MTK2]MVTDES(nolign-1)
      [M:STW]PJT       = [F:MFI]PJT
      [M:STW]TRSFAM    = [F:MTS]TRSFAM
      [M:STW]TRSCOD    = [F:MTS]TRSCOD
      [M:STW]IPTDAT    = [F:MKI]IPTDAT
    # 11.06 demande 38306
    [M:STW]ENTCOD = [F:MTS]ENTCOD
      [M:STW]CCECOD    = "STKEOF"
      [M:STW]VCRTYPORI = 10
      [M:STW]VCRNUMORI = [F:MKI]MFGNUM
      [M:STW]VCRLINORI = [F:MKI]MFGLIN
      [M:STW]CUR = GLOCALDEV
      [M:STW]BPRNUM = ""


      [M:STW]TRAFLG   = 2                        : # Trace normal

      PRI = func STKVAL.DEFPRIMKI([M:MTK2]WSTOSEQ(nolign-1))
      [M:STW]PRIORDH  = PRI
      Call ALISTOWORK(2,[M:MTK2]WSTOSEQ(nolign-1),LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT
      If WRET <> 0 : GOK = 0 : Break : Endif
# SI premier suivi et lot à réserver au premier suivi le récupérer là
      WLOT = [M:STW]LOT
      Call MAJ_STOCK From STKMAJ
      If GOK < 1 : Break : Endif
      If GOK
         If GREP <> "A"
            Local Integer WQUA
            WQUA  = [F:MKI]QUAFLG
            Call STKFREQCQ("MTK2",[F:MKI]MFGFCY ,nolign-1,[F:MKI]ITMREF ,"","V",WQUA,0) From STKACT   # hcb V6CQ (freq)
         Endif
      Endif
      If GOK<1  Break : Endif
                                                                          # hcb V6CQ (freq)
      If [M:MTK2]ITMTYP(nolign-1) <> 2
           WCPLQTY += [F:MKI]CPLQTY
           WREJQTY += [M:STW]RRRQTY
           WQUAQTY += [M:STW]QQQQTY
       Endif
#Maj Article lancé
       Readlock [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK2]MFGLIN(nolign-1)
       If fstat=1  GOK=-1 : GLOCK="$MFGITM"-[M:MTK2]ITMREF(nolign-1) : Break
       Elsif fstat GOK=0  : Call RSTA("MFI",[M:MTK2]ITMREF(nolign-1)) From GLOCK : Break
       Endif
       WSOLDE = [F:MFI]MFITRKFLG
       [F:MFI]CPLQTY += [M:MTK2]CPLQTY(nolign-1)
       Call QTEARR([F:MFI]CPLQTY,[F:MFI]STU) From TRTDIV
       [F:MFI]REJCPLQTY += [M:STW]RRRQTY
       Call QTEARR([F:MFI]REJCPLQTY,[F:MFI]STU) From TRTDIV
       [F:MFI]QUACPLQTY += [M:STW]QQQQTY
       Call QTEARR([F:MFI]QUACPLQTY,[F:MFI]STU) From TRTDIV
       [F:MFI]RMNEXTQTY = [F:MFI]EXTQTY - [F:MFI]CPLQTY
       If [F:MFI]RMNEXTQTY < 0 : [F:MFI]RMNEXTQTY = 0 : Endif
       Call QTEARR([F:MFI]RMNEXTQTY,[F:MFI]STU) From TRTDIV
# mise à jour du flag solde selon différents cas
        If    [M:MTK2]CLEFLG(nolign-1) = 2 & [F:MFI]MFITRKFLG < 5:#on solde une ligne
              # CCC (10/01/08) DM 44021
              #[F:MFI]TRKLAST = [F:MTK]MFGTRKDAT
              [F:MFI]MFITRKFLG = 5
              WITMCLENBR += 1
        Elsif [M:MTK2]CLEFLG(nolign-1) = 1 & [F:MFI]MFITRKFLG = 5 :#on désolde une ligne
              # CCC (10/01/08) DM 44021
              #Raz [F:MFI]TRKLAST
              [F:MFI]MFITRKFLG = 4
              WITMCLENBR -= 1
        Elsif [M:MTK2]CLEFLG(nolign-1) = 1 & [F:MFI]MFITRKFLG < 4 :#une ligne passe à "encours"
              [F:MFI]MFITRKFLG = 4
       Endif
       If    [F:MFI]MFITRKFLG = 4 : [F:MFI]ITMSTA    = 2
       Elsif [F:MFI]MFITRKFLG = 5 : [F:MFI]ITMSTA    = 3
                                    [F:MFI]RMNEXTQTY = 0
       Endif
       # CCC (10/01/08) DM 44021
       If [F:MFI]TRKFIRST = "00/00/00"
          #[F:MFI]TRKFIRST = [M:MTK0]MFGTRKDAT
          # selon paramètre général, on récupère le LOT au premier suivi
          If [F:ITM]LOTMGTCOD > 1 & [F:MFI]LOT = "" & GLOTMGT = 4 & WLOT <> ""
             [F:MFI]LOT = WLOT
          Endif
       Endif
       If [F:MFI]TRKLAST<[M:MTK0]MFGTRKDAT
           [F:MFI]TRKLAST   = [M:MTK0]MFGTRKDAT
       Endif
       If [F:MFI]TRKLASTC<date$
           [F:MFI]TRKLASTC  = date$
       Endif
       If [F:MFI]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFI]TRKFIRST = "00/00/00"
            [F:MFI]TRKFIRST = [M:MTK0]MFGTRKDAT
       Endif
       If [F:MFI]TRKFIRSTC>date$ | [F:MFI]TRKFIRSTC = "00/00/00"
            [F:MFI]TRKFIRSTC = date$
       Endif
       Rewrite [F:MFI]
       If fstat
          GOK = 0 : Call FSTA("MFI") From GLOCK : Break
       Endif
#Maj encours et mvts article
#Si la ligne était soldée et le reste on ne met pas à jour l'encours ni  l'en commande
       If WSOLDE <> 5 | [F:MFI]MFITRKFLG <> 5

           # affectations v6
           Call MAJ_MTO("C", [F:MKI]CPLQTY)   From MTKMTOLIB
           If GOK<1 : Break : Endif : # GH 05/09/12 bug 84291
           If [F:MFG]MFGSTA   = 4 | [F:MFI]MFITRKFLG = 5 : Gosub SUP_MTO_MFI From MFGMTOLIB : Endif

           Gosub TRT_WIP
           If GOK < 1 : Break : Endif
#Si la ligne était soldée et qu'on la désolde il faut d'abord réajuster l'en commande
           If WSOLDE = 5 & [F:MFI]MFITRKFLG < 5
              Local Integer STA : STA = 0
              Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
              If GOK <> 1 | STA > 1 : Break : Endif
              Update [ITV] Where ITMREF = [F:MFI]ITMREF & STOFCY = [F:MFI]MFGFCY
&                  With ORDSTO += ([F:MFI]EXTQTY - [F:MFI]CPLQTY)+[F:MKI]CPLQTY
           Endif
           Gosub TRT_MVT
           If GOK < 1 : Break : Endif
        Endif
# ----------------- TEST LLC 150 Gestion a la commande
#Si production pour une commande allocation automatique pour celle-ci
#       If [F:MFI]FMI = 5 & [F:MFI]VCRTYPORI = 2 : Call MAJ_ALLOCATION("C",[F:MKI]CPLQTY,
#&                                                      [F:MKI]ITMTRKLIN)
#            If GOK < 1 : Break : Endif
#       Endif

#----- Mise à jour statistiques ligne article lancé -----#
       Call VALSTA("MFI",1) From SUBPS2
       If GOK < 1 : Break : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
         If dim(WRET) < 0     : Local Integer WRET       : Endif
         If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
         GWIPCOST = "ITMTRK_NEW"
         WRET = 0
         GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
         If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------

    Endif
Next
Return

##############################################
#---------------------------------------------------------#
# Ecriture des sections de la ligne article lancé         #
#---------------------------------------------------------#
$MAJMKI_CPTANALIN

Call ENREG_ACCCCE(nolign-1,"","","[M:MTK2]CCE","MKI",0,[F:MKI]MFGTRKNUM,[F:MKI]ITMTRKLIN,0,"","C") From TRTX3CPT

Return
##############################################
$TRT_WIP
#Maj de l'encours lié à l'article lancé
[M:ORDK]MAJCOD     = "M"
# llc 05.00 (sous-produits)
Case [F:MFI]ITMTYP
    When 2:       [M:ORDK]WIPTYP     = 9
    When Default: [M:ORDK]WIPTYP     = 5
Endcase
[M:ORDK]WIPSTA     = [F:MFI]MFGSTA
[M:ORDK]WIPNUM     = [F:MFI]WIPNUM
[M:ORDK]ITMREF     = [F:MFI]ITMREF
[M:ORDK]ORIFCY     = [F:MFI]PLNFCY
[M:ORDK]STOFCY     = [F:MFI]MFGFCY
[M:ORDK]PJT        = [F:MFI]PJT
[M:ORDK]BPRNUM     = [F:MFI]BPCNUM
[M:ORDK]STRDAT     = [F:MFG]STRDAT
[M:ORDK]ENDDAT     = [F:MFG]ENDDAT
[M:ORDK]VCRTYP     = 10
[M:ORDK]VCRNUM     = [F:MFI]MFGNUM
[M:ORDK]VCRLIN     = [F:MFI]MFGLIN
[M:ORDK]VCRSEQ     = 0
[M:ORDK]EXTQTY     = [F:MFI]EXTQTY
[M:ORDK]CPLQTY     = [F:MFI]CPLQTY
[M:ORDK]ALLQTY     = 0
[M:ORDK]SHTQTY     = 0
[M:ORDK]FMI        = [F:MFI]FMI
[M:ORDK]MRPMES     = 1
[M:ORDK]VCRTYPORI  = [F:MFI]VCRTYPORI
[M:ORDK]VCRNUMORI  = [F:MFI]VCRNUMORI
[M:ORDK]VCRLINORI  = [F:MFI]VCRLINORI
[M:ORDK]VCRSEQORI  = [F:MFI]VCRSEQORI
[M:ORDK]ITMREFORI  = [F:MFI]ITMREF
[M:ORDK]BOMALT     = [F:MFI]BOMALT
[M:ORDK]BOMALTTYP  = 2                 # V6 Nomenclature de Production
[M:ORDK]ORI        = 4
[M:ORDK]ABBFIL     = "MFI"
[M:ORDK]PIO        = [F:MFG]MFGPIO
#Si ordre clos ou ligne article lancé est soldée, on supprime l'encours
If [F:MFG]MFGSTA   = 4 | [F:MFI]MFITRKFLG = 5  : [M:ORDK]MAJCOD = "A" : Endif
Call WIP From TRTWIP
Return

##########################################
$TRT_MVT
#Maj des mouvements article en déclaration de production pour la qté en commande
#les autres qtés sont mise à jour par le moteur de stock
Local Integer STA : STA=0

Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
If GOK <> 1 | STA > 1 : Return : Endif
#
# attention, on ne doit mettre à jour le stock en commande que par rapport à la
# quantité prévue ...
If find(GREP,"C","M") | !find(GFONC1,"GESMTK","GESPTH") :
   # si la quantité prévue était déjà dépassée, on sort (pas de mise à jour)
   If ([F:MFI]CPLQTY - [F:MKI]CPLQTY) >= [F:MFI]EXTQTY : Return : Endif

   If [F:MFI]CPLQTY <= [F:MFI]EXTQTY & [F:MFI]MFITRKFLG < 5
      # Issue 65503 - 2010-06-18 by CCC : Déduction du delta de quantité
      If GREP="M" & dim(WCPLQTY)>0
          [F:ITV]ORDSTO -= WCPLQTY
      Else
          [F:ITV]ORDSTO -= [F:MKI]CPLQTY
      Endif
   Else
      [F:ITV]ORDSTO -= [F:MKI]CPLQTY + ([F:MFI]EXTQTY - [F:MFI]CPLQTY)
   Endif
Elsif GREP = "A"
   # si la quantité prévue est toujours dépassée, on sort (pas de mise à jour)
   If   [F:MFI]CPLQTY  >= [F:MFI]EXTQTY : Return
   Elsif[F:MFI]CPLQTY + [F:MKI]CPLQTY > [F:MFI]EXTQTY | WSOLDE = 5
        [F:ITV]ORDSTO += [F:MFI]EXTQTY - [F:MFI]CPLQTY
   Else
        [F:ITV]ORDSTO += [F:MKI]CPLQTY
   Endif
Else
   If WCPLQTY > 0
      #On arrive ici lorsque l'on vient de TRT15. WCPLQTY contient le delta
      # si la quantité prévue était déjà dépassée, on sort (pas de mise à jour)
      If ([F:MFI]CPLQTY - WCPLQTY) >= [F:MFI]EXTQTY : Return : Endif

      If [F:MFI]CPLQTY <= [F:MFI]EXTQTY & [F:MFI]MFITRKFLG < 5
         [F:ITV]ORDSTO -= WCPLQTY
      Else
         [F:ITV]ORDSTO -= [F:MFI]EXTQTY - ([F:MFI]CPLQTY - WCPLQTY)
      Endif
   Else
      # si la quantité est toujours déjà dépassée, on sort (pas de mise à jour)
      # si l'ancienne qté réalisée (nouvelle qté réalisée + delta) était
      # supérieure à la qté prévue on ne met à jour l'en commande que pour
      # la réelle qté restante
      # sinon on met à jour l'en commande pour le delta !!!!!
      If   [F:MFI]CPLQTY >= [F:MFI]EXTQTY : Return
      Elsif[F:MFI]CPLQTY - WCPLQTY > [F:MFI]EXTQTY | WSOLDE = 5
           [F:ITV]ORDSTO += [F:MFI]EXTQTY - [F:MFI]CPLQTY
      Else
           [F:ITV]ORDSTO -= WCPLQTY
      Endif
   Endif
Endif
Rewrite [ITV] : If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Endif
#
Return

###########################################
Subprog MAJ_ALLOCATION (TRTLIG,LQTY,L)
#Si pec d'une commande en création de l'of, allocation automatique de la qté fabriquée
# en 1.4.0 on alloue toute la quantité réalisée sans tenir compte du statut (cf TS)
Value Char    TRTLIG
Value Decimal LQTY
Value Integer L

Local Decimal WQTY
Local Decimal WQTYACT
Local Integer WRETOUR
Local Decimal SAV_WALLQTY, WQTE, WQTE1,WSTOCOU
Local Char    WDEFLOC(GLONLOC)
Local Char    WDEFLOCTYP(GLONTLO)

WRETOUR = 0
#-----------------------------------------------------------------#
# lecture detail cde vente pour récuperer  qté restant  à allouer #
#-----------------------------------------------------------------#
If clalev ([F:SOQ]) = 0  : Local File SORDERQ [SOQ]  : Endif
If clalev ([F:SOP]) = 0  : Local File SORDERP [SOP]  : Endif
If clalev ([F:SOH]) = 0  : Local File SORDER  [SOH]  : Endif
If clalev ([F:STA]) = 0  : Local File STOALL  [STA]  : Endif
If clalev ([F:STJ]) = 0  : Local File STOJOU  [STJ]  : Endif

Read [SOQ]SOQ0 = [F:MFI]VCRNUMORI ;[F:MFI]VCRLINORI;[F:MFI]VCRSEQORI
If fstat             : End : Endif
# 07.04 Si la ligne de vente n'est plus porteuse du n° d'OF, il ne faut rien faire demande 23417
If [F:SOQ]SOQSTA = 3 | [F:SOQ]FMINUM <> [F:MFI]MFGNUM : End : Endif
Read [SOH]SOH0 = [F:MFI]VCRNUMORI
If fstat   Raz [F:SOH]        : End : Endif
Read [SOP]SOP0 = [F:MFI]VCRNUMORI ;[F:MFI]VCRLINORI;[F:MFI]VCRSEQORI
If fstat : Raz [F:SOP] : Endif
If TRTLIG = "A"
   # 01.03 demande 17110
   GPE = 1
   GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
   If GOK < 1 : End : Endif
   If GPE
     # 04.02 Problèmes de Perf
     If clalev([F:STO1])=0  Local File STOCK  [STO1] : Endif
     #-------------------------------#
     # suppression des allocations   #
     #-------------------------------#
      For [STJ]STJ1   Where STOFCY = [F:MKI]MFGFCY
&                     & VCRTYP = 15
&                     & VCRNUM = [F:MKI]MFGTRKNUM
&                     & VCRLIN = [F:MKI]ITMTRKLIN
&                     & REGFLG <> 2
          Raz WSTOCOU
          #--- Issue X3-53322 : ajout LPN
          Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                     [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                     [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                     [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
          For [F:STA]STA1 Where STOFCY = [F:STJ]STOFCY &
&                               VCRTYP = 2 & STOCOU = WSTOCOU &
&                               VCRNUM = [F:MFI]VCRNUMORI & VCRLIN = [F:MFI]VCRLINORI &
&                               VCRSEQ = [F:MFI]VCRSEQORI
                           Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,WRETOUR) From STKALL
                           If WRETOUR<>0 : GOK=0 : Break
                           Else          : SAV_WALLQTY -= [F:STA]QTYSTU
                           Endif
          Next
          If GOK<1 : Break : Endif
      Next
      If GOK<1 : End : Endif
   Endif
Else
     Local Decimal WALLQTY
     #----------------------------------------------------------------------------------------#
     # qté restant a allouer :                                                                #
     # cde facturation directe : qté cde  - qté alloué - qté livré - qté facturé              #
     # autre cde                 qté cde  - qté alloué - qté livré - qté encours de livraison #
     #----------------------------------------------------------------------------------------#
     If [F:SOH]SOHCAT = 3
         WALLQTY = [F:SOQ]QTYSTU  - [F:SOQ]ALLQTYSTU - [F:SOQ]INVQTYSTU
     Else
         WALLQTY = [F:SOQ]QTYSTU  - [F:SOQ]ALLQTYSTU - [F:SOQ]DLVQTYSTU - [F:SOQ]ODLQTYSTU
     Endif
     If WALLQTY <= 0  : End : Endif

     # 05.02 Point d'entrée permettant de modifier la quantité à allouer
     #         il suffit de mettre WALLQTY = LQTY (quantité déclarée)
     # derrière, on enlève la quantité déclarée en "R"
     GPOINT = "CALWALLQTY"
     Gosub  ENTREE From EXEFNC

     If WALLQTY >    LQTY
        WALLQTY =    LQTY
     Endif
     If WALLQTY  <= 0  : End  : Endif
     SAV_WALLQTY = WALLQTY
#
     # 01.03 demande 17110
     GPE = 1
     GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
     If GOK < 1 : End : Endif
     If GPE
         # Recherche de l'emp (type) de consommation (de livraison) si exclusif
         Raz WDEFLOC, WDEFLOCTYP
         Call RECH_PICLOC(2,[F:SOQ]STOFCY,[F:SOQ]ITMREF,"","",1,1,"O",WDEFLOC,WDEFLOCTYP)
&             From STKALL
         #--------------------------#
         # boucle du fichier STOJOU #
         #--------------------------#
         # 04.02 Problèmes Perf
         For [STJ]STJ1 Where STOFCY = [F:MKI]MFGFCY
&                        & VCRTYP = 15
&                        & VCRNUM = [F:MKI]MFGTRKNUM
&                        & VCRLIN = [F:MKI]ITMTRKLIN
&                        & REGFLG <> 2
             If WALLQTY  <= 0 : Break : Endif
             WALLQTY -= [F:STJ]QTYSTU
             If WALLQTY >=0
                     WQTY    = [F:STJ]QTYSTU
             Else    WQTY    = WALLQTY + [F:STJ]QTYSTU
             Endif
             If [F:STJ]POT <> 0
                  WQTYACT = WQTY * ([F:STJ]POT/100)
             Else WQTYACT = WQTY
             Endif
             WQTE=[F:SOQ]ALLQTYSTU : # Quantité déjà allouée
             #-- Calcul de la quantité allouée en unité active
             If [F:STJ]POT <> 0
                   GBIDD2 = WQTE * ([F:STJ]POT/100)
             Else
#                   GBIDD1 = WQTE
                   GBIDD2 = WQTE
             Endif
             Raz GBIDC1

             Raz WSTOCOU
             #--- Issue X3-53322 : ajout LPN
             Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                        [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                        [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                        [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
#             Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:MTK]MFGTRKDAT,[F:STJ]QTYSTU,
#&               GBIDD1,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,GBIDC1,[F:SOQ]SHIDAT,
#&               "","","","","",WQTE,GBIDD2,
#&               WRETOUR) From STKALL
             #--- TS 106217 ajout paramètre LECC (avant dernier)
             Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:MTK]MFGTRKDAT,WQTY,
&               WQTYACT,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,GBIDC1,[F:SOQ]SHIDAT,
&               "","","","","","",WQTE,GBIDD2,WDEFLOC,WDEFLOCTYP,"","",1,"",WRETOUR) From STKALL

             If WRETOUR<>0 : GOK=0 : Break : Endif
         Next
         If GOK<1 : End : Endif
     Endif
Endif
If WRETOUR <> 0     : End : Endif
If SAV_WALLQTY = 0  : End : Endif
#--------------------------------------#
# mise à jour detail commande de vente #
#--------------------------------------#

Readlock [SOH]SOH0 = [F:MFI]VCRNUMORI
If fstat= 1
       GOK=-1 : GLOCK="$SORDER"-[F:MFI]VCRNUMORI
       Call ROLL From GLOCK
       End
Elsif fstat
       GOK=0  : Call RSTA("SOH",[F:MFI]VCRNUMORI) From GLOCK
       End
Endif

Readlock [SOQ]SOQ0 = [F:MFI]VCRNUMORI ;[F:MFI]VCRLINORI ;[F:MFI]VCRSEQORI
If fstat= 1
       GOK=-1 : GLOCK="$SORDERQ"-[F:MFI]VCRNUMORI-num$([F:MFI]VCRLINORI)-num$([F:MFI]VCRSEQORI)
       Call ROLL From GLOCK
       End
Elsif fstat
       GOK=0  : Call RSTA("SOQ",[F:MFI]VCRNUMORI-num$([F:MFI]VCRLINORI)) From GLOCK     # llc 05.02 cohérence
       End
Endif

If [F:SOH]SOHCAT = 3
    WQTE1= [F:SOQ]INVQTYSTU
Else
    WQTE1= [F:SOQ]DLVQTYSTU
Endif

If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU + WQTE1 >= [F:SOQ]QTYSTU
&       &  [F:SOQ]SHTQTYSTU = 0 & ([F:SOQ]STOMGTCOD <> 1  | find([F:SOP]LINTYP,2,10))
# --- La ligne etait allouée
    GBIDI1 = 2
Else
# --- La ligne n'etait pas allouée
    GBIDI1 = 1
Endif

#---------------------------------------------------#
# sav_wallqty est negatif dans le cas trtlig = "A"  #
#---------------------------------------------------#
[F:SOQ]ALLQTYSTU += SAV_WALLQTY
If [F:SOQ]ALLQTYSTU < 0 : [F:SOQ]ALLQTYSTU = 0 : Endif
#-------- lecture SORDERP pour recuperer UV ----#
Read [SOP]SOP0 = [F:MFI]VCRNUMORI ;[F:MFI]VCRLINORI;[F:MFI]VCRSEQORI
If fstat : Raz [F:SOP] : Endif
If [F:SOP]SAU = [F:SOP]STU
    [F:SOQ]ALLQTY += SAV_WALLQTY
Else
    GBIDD1=SAV_WALLQTY*(1/[F:SOP]SAUSTUCOE)
    Call QTEARR(GBIDD1, [F:SOP]SAU) From TRTDIV
    [F:SOQ]ALLQTY += GBIDD1
Endif
If [F:SOQ]ALLQTY < 0 : [F:SOQ]ALLQTY = 0 : Endif

# 01.03 demande 17110
If GPE
    [F:SOQ]ALLTYP = 2
Else
    [F:SOQ]ALLTYP = 1
Endif

Rewrite [SOQ]
If fstat
      GOK = 0 : Call FSTA ("SOQ") From GLOCK
      End
Endif

# La ligne est passée du statut non alloué au statut alloué
If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU >= [F:SOQ]QTYSTU
&       &  [F:SOQ]SHTQTYSTU = 0 & ([F:SOQ]STOMGTCOD <> 1 | find([F:SOP]LINTYP,2,10))
&       &  GBIDI1 = 1
    GBIDI2=-1
# La ligne a passé du statut alloué au statut non alloué
Elsif ([F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU < [F:SOQ]QTYSTU
&       | [F:SOQ]SHTQTYSTU <> 0) & ([F:SOQ]STOMGTCOD <> 1  | find([F:SOP]LINTYP,2,10))
&       &  GBIDI1 = 2
    GBIDI2=1
Else
# La ligne n'a pas changé d'état
    GBIDI2=0
Endif
#-----------------------------------------#
# mise à jour entete de commande de vente #
#-----------------------------------------#
If GBIDI2<>0 : # la ligne a changé d'état
  [F:SOH]ALLLINNBR+=GBIDI2
Endif

If [F:SOH]ALLLINNBR <= 0
   [F:SOH]ALLLINNBR = 0
   [F:SOH]ALLSTA = 3
Elsif [F:SOH]ALLLINNBR < [F:SOH]LINNBR | [F:SOQ]ALLQTY <> 0
   [F:SOH]ALLSTA = 2
Else
   [F:SOH]ALLSTA = 1
Endif

Rewrite [SOH]
If fstat
      GOK = 0 : Call FSTA ("SOH") From GLOCK
      End
Endif
#----------------------------------------------------------------------------------#
# Bug 27897 : Si l'article est un composé de kit, il faut allouer des composants   #
#----------------------------------------------------------------------------------#
#   Si Composé de kit/sous-traité, il faut allouer les composants
If find([F:SOP]LINTYP,2,10) & SAV_WALLQTY<> 0
    Local Char WSOQ_TRTLIG : Local Decimal WSOQ_ALLSTU
    If SAV_WALLQTY<0
        # --- C'est une diminution/annulation de l'allocation
        WSOQ_TRTLIG="D" : WSOQ_ALLSTU=abs(SAV_WALLQTY)
    Elsif SAV_WALLQTY>0
        # --- C'est une augmentation de l'allocation
        If [F:SOQ]ALLQTYSTU-SAV_WALLQTY=0 WSOQ_TRTLIG="C"  Else  WSOQ_TRTLIG="M"  Endif
        WSOQ_ALLSTU=[F:SOQ]ALLQTYSTU
    Endif
    # Récupération du paramètre vente : USERERBPC : Consommation réservations clients
    Local Char WSOQ_PARAM(10) : Call PARAM([F:SOH]SALFCY,"USERERBPC",WSOQ_PARAM) From ADOVAL
    Call GENALLKIT ([F:SOH]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, WSOQ_TRTLIG, val(WSOQ_PARAM), 2, 0, 1, 0,
&                   WSOQ_ALLSTU, WRETOUR) From TRTVENALL
    If WRETOUR<>0 GOK=0 : End : Endif
Endif
# Bug 27897
#------------------------------------#
# mise a jour de l encours SOF(vente)#
#------------------------------------#
If [F:SOQ]DEMNUM <>""
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = 1
    [M:ORDK]WIPSTA    = [F:SOQ]DEMSTA
    [M:ORDK]WIPNUM    = [F:SOQ]DEMNUM
    [M:ORDK]ITMREF    = [F:SOQ]ITMREF
    [M:ORDK]ORIFCY    = [F:SOH]SALFCY
    [M:ORDK]STOFCY    = [F:SOQ]STOFCY
    [M:ORDK]PJT       = [F:SOH]PJT
    [M:ORDK]BPRNUM    = [F:SOH]BPCORD
    [M:ORDK]STRDAT    = [F:SOQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:SOQ]SHIDAT
    [M:ORDK]VCRTYP    = 2
    [M:ORDK]VCRNUM    = [F:SOQ]SOHNUM
    [M:ORDK]VCRLIN    = [F:SOQ]SOPLIN
    [M:ORDK]VCRSEQ    = [F:SOQ]SOQSEQ
    [M:ORDK]EXTQTY    = [F:SOQ]QTYSTU
    If [F:SOH]SOHCAT = 3
      [M:ORDK]CPLQTY = [F:SOQ]INVQTYSTU
    Else
      [M:ORDK]CPLQTY = [F:SOQ]DLVQTYSTU
    Endif
    [M:ORDK]ALLQTY    = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
    [M:ORDK]SHTQTY    = [F:SOQ]SHTQTYSTU
    [M:ORDK]MRPMES    = 1
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
    [M:ORDK]BOMALT    = 0
    [M:ORDK]BOMALTTYP = 2                 # V6 Nomenclature de Production
    [M:ORDK]ORI       = 2
    If [F:SOH]SOHCAT = 4
       [M:ORDK]ABBFIL  = "SOC"
       [M:ORDK]FMI     = 1
    Else
       [M:ORDK]ABBFIL  = "SOQ"
       [M:ORDK]FMI     = [F:SOQ]FMI
    Endif
    Call WIP From TRTWIP
    If GOK <1 : GMESSAGE=mess(013,100,1)-"ORDERS:"-[F:SOQ]DEMNUM : Endif
Endif
End

#---------------------Maj liées au suivi matière  ----------------------------------#
#######################################################
$MAJMAT
Local Integer WNBSER,WFICFLG
Local Decimal WCOEFF,WALLQTY,WSHTQTY,WWQTY,WREPART, WSTOQTY, WSAV_USEQTY
Local Decimal LQTA, LSHT
Local Integer LNBR, LNBJ, LRET
Local Decimal WWALLQTY,WWSHTQTY
Local Char    WORI : WORI = "MTK3"
Local Char    WACTION
# 10.05 demande 32472
Local Integer WCUMMATSUI
# CCC (18/03/08) Bug 46398
If !clalev([M:SOWS]) : Local Mask STOSORW [SOWS] : Endif

For nolign = 1 To [M:MTK3]NBMAT
    #si la matière a été suivie ou soldée
    If [M:MTK3]MODIFLG(nolign-1) = 0 &
&      ([M:MTK3]USEQTY(nolign-1) <> 0 | ([M:MTK3]CLEFLG(nolign-1) <> [M:MTK3]WCLEFLG(nolign-1)))
        If [M:MTK3]USEQTY(nolign-1) <> 0 | [M:MTK3]WEXCMAT(nolign-1) <> 2
    #Lecture éventuelle de article et article-site
           If [F:ITM]ITMREF <> [M:MTK3]MATITMREF(nolign-1)
              Read [F:ITM]ITM0 = [M:MTK3]MATITMREF(nolign-1)
              If fstat GOK=0  : Call RSTA("ITM",[M:MTK3]MATITMREF(nolign-1)) From GLOCK : Break : Endif
           Endif
           If [F:ITF]ITMREF <> [M:MTK3]MATITMREF(nolign-1) | [F:ITF]STOFCY <> [M:MTK0]MFGFCY
              Read [F:ITF]ITF0 = [M:MTK3]MATITMREF(nolign-1);[M:MTK0]MFGFCY
              If fstat GOK=0  : Call RSTA("ITF",[M:MTK3]MATITMREF(nolign-1)+[M:MTK0]MFGFCY) From GLOCK : Break : Endif
           Endif
    #Lecture eventuelle matière OF
           If [M:MTK3]MFMITMREF(nolign-1) <> ""
               If [M:MTK3]CUMMATSUI(nolign-1) = 1
                   Filter [F:MFM] Where MFGNUM = [M:MTK0]MFGNUM & ITMREF = [M:MTK3]MFMITMREF(nolign-1)&
&                             BOMOPE = [M:MTK3]OPENUM(nolign-1) & MATSTA < 4
                   Read [F:MFM]MFM3 First            # 10.02 Performances
               Else
                   Read [F:MFM]MFM0 = [M:MTK0]MFGNUM;[M:MTK3]MFGLIN(nolign-1);[M:MTK3]BOMSEQ(nolign-1);
&                                 [M:MTK3]MFMITMREF(nolign-1)
               Endif
               Filter [F:MFM]
               If fstat : GOK = 0 : Call RSTA("MFM",[M:MTK0]MFGNUM+num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : Break : Endif
           Endif
           If [M:MTK3]MFGLIN(nolign-1) <> 0
               Read [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK3]MFGLIN(nolign-1)
               # llc 05.02 cohérence
               If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : Break  : Endif
           Else
               Filter [F:MFI] Where MFGNUM = [M:MTK0]MFGNUM
               Read [F:MFI]MFI0 First
               Filter [F:MFI]
               # llc 05.02 cohérence
               If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : Break  : Endif
           Endif
    #Création enregistrement suivi mat
           Raz [F:MKM]
           [F:MKM] = [M:MTK0]
           [F:MKM] = [M:MTK3]
           [F:MKM]PJT    = [F:MFI]PJT
           [F:MKM]ITMREF = [M:MTK3]MATITMREF(nolign-1)
           [F:MKM]IPTDAT = [M:MTK0]MFGTRKDAT
           [F:MKM]CREDAT = date$
           [F:MKM]CREUSR = GUSER
           [F:MKM]EXPNUM = [C]EXPORT

           # Alimentation dépôt ligne si renseigné
           If dim([M:MTK3]WRH)>0 & [M:MTK3]WRH(nolign-1)<>""
            [F:MKM]WRH = [M:MTK3]WRH(nolign-1)
           Else
            [F:MKM]WRH = ""
           Endif

           If [M:MTK3]MKMTEX(nolign-1) <> ""
              [F:MKM]MKMTEX = [M:MTK3]MKMTEX(nolign-1)
              If left$([F:MKM]MKMTEX,3)="MKM"
                  Call CRE_CLOB([F:MKM]MKMTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
              Elsif left$([F:MKM]MKMTEX,3) <> "BOD"
                  Call DUP_CLOB("MKM",[F:MKM]MKMTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
               Endif
           Endif
           #point d'entrée  pour mise à jour  spécifique   09.04 demande 25251
           WACTION = "C"
           GPOINT = "MKMMAJ" : Gosub ENTREE From EXEFNC
           #
           Write [F:MKM]
           If fstat
                 GOK = 0 : Call FSTA("MKM") From GLOCK : Break
           Endif
         #----- Ecriture des sections de la ligne matiere -----#
         Gosub MAJMKM_CPTANALIN
         If GOK<1
             Break
         Endif

    Endif
    #
    #Maj Matière et stock
    If [M:MTK3]MFMITMREF(nolign-1) <> ""
        #----- Mise à jour statistiques ligne suivi matière -----#
        Call VALSTA("MKM",1) From SUBPS2
        If GOK < 1 : Break : Endif
        Raz WWQTY,WREPART
        If [M:MTK3]CUMMATSUI(nolign-1) = 1
           Raz WSTOQTY
            # CCC (18/03/08) Bug 46398 : Sauvegarde de [M:SOW] car il est effacé dans LOAD_SOW_SORTIE
            Raz [M:SOWS]
            Transmask [M:SOW] To [M:SOWS]  # Issue X3-36381 [M:SOWS] = [M:SOW]
           # 07.05 Trier les lignes à traiter dans l'ordre ascendant des qtés prévues
           Filter [MFM]   Where MFGNUM = [M:MTK0]MFGNUM
&                             & ITMREF = [M:MTK3]MFMITMREF(nolign-1)
&                             & BOMOPE = [M:MTK3]OPENUM(nolign-1)
&                             & MATSTA < 4
&          Order By Key MFM9=MFGNUM;BOMOPE;ITMREF;RETQTY
           For [MFM]MFM9
                Readlock [F:MFM]Curr
                If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[M:MTK3]MFMITMREF(nolign-1) : Break 2
                Elsif fstat GOK=0  : Call RSTA("MFM",[M:MTK3]MFMITMREF(nolign-1)) From GLOCK : Break 2
                Endif

                WCOEFF = ([F:MFM]RETQTY/[M:MTK3]MFMEXTQTY(nolign-1))
               # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
               # Ce sont les quantités qui sont arrondies
               ## 01.02 demande 12597
               #WCOEFF = arr(WCOEFF,0.00000001)
               # 07.05 demande 29720
               # Pour les matières avec quantité infime, si le calcul donne 0 mais qu'il reste quelque chose
               # à consommer, on consomme tout ce qu'il reste
               If WCOEFF = 0
                  WWQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
               Else
                   WWQTY   = [M:MTK3]USEQTY(nolign-1) * WCOEFF
               Endif
               #Attention à ne pas répartir plus que la qté consommée totale (à cause des arrondis)
               If (WREPART + WWQTY) > [M:MTK3]USEQTY(nolign-1)
                   WWQTY  = [M:MTK3]USEQTY(nolign-1) - WREPART
               Endif
               Call QTEARR (WWQTY,[F:MFM]STU) From TRTDIV
               #si il ne reste plus rien à répartir
               If WWQTY = 0 : Break : Endif
               [F:MFM]USEQTY += WWQTY
               Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
               WREPART += WWQTY
               WSAV_USEQTY   = [F:MKM]USEQTY
               [F:MKM]USEQTY = WWQTY
               Gosub LOAD_MTMK         From MTKAUTLIB
               Gosub LOAD_SOW_SORTIE   From MTKAUTLIB
               # Issue 83888 - 2012-08-20 by CCC : récupération du WSTOSEQ généré
               [M:MTK3]WSTOSEQ(nolign-1) = max([M:SOW]WSTOSEQ)
               Gosub LOAD_STW          From MTKAUTLIB
               Gosub LOAD_ALP          From MTKAUTLIB
               Raz LQTA,LSHT,LNBR,LNBJ,LRET
               If [F:MFM]ALLSTA > 1  & [F:MFM]MFMTRKFLG < 5
                   Call MAJALLORI([F:MKM]MATTRKLIN,LRET) From STKALL
                   If LRET : GOK = 0 : Endif
                   WWALLQTY = [M:ALP]DESQTY
                   WWSHTQTY = [M:ALP]DESQTYSHT
               Endif
               Raz LQTA,LSHT,LNBR,LNBJ,LRET
               # Issue 83888 - 2012-08-20 by CCC : récupération du WSTOSEQ généré
               ## Issue 74190 - 2011-06-06 by CCC : STW est à charger à partir de SOW, les alloc techniques n'existent plus
               ##Call ALISTOWORK(1,0,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
               #Call ALISTOWORK(3,1,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
               Call ALISTOWORK(3,[M:MTK3]WSTOSEQ(nolign-1),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
               If LRET : GOK = 0 : Break 2 : Endif
               WWALLQTY = LQTA
               WWSHTQTY = LSHT
               Call MAJ_STOCK() From STKMAJ
               [F:MKM]USEQTY = WSAV_USEQTY
               If GOK < 1 : Break 2  : Endif
               # mise à jour du flag solde selon différents cas
               If     [M:MTK3]CLEFLG(nolign-1) = 2 & [F:MFM]MFMTRKFLG < 5:#on solde une ligne
                      [F:MFM]MFMTRKFLG = 5
                      # CCC (10/01/08) DM 44021
                      #[F:MFM]TRKLAST = [F:MTK]MFGTRKDAT
                      If [F:MFM]ALLQTY <> 0 | [F:MFM]SHTQTY <> 0
                         Gosub SUPALL_OF
                         If GOK < 1 : Break 2: Endif
                         Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                      Endif
                      WMATCLENBR += 1
               Elsif [M:MTK3]CLEFLG(nolign-1) = 1 & [F:MFM]MFMTRKFLG = 5 :#on désolde une ligne
                     [F:MFM]MFMTRKFLG = 4
                     # CCC (10/01/08) DM 44021
                     #Raz [F:MFM]TRKLAST
                     # On réalloue si besoin
                     If [F:MFM]RETQTY > [F:MFM]USEQTY & [F:MFM]ALLSTA > 1
                        Gosub CREALL_OF
                        If GOK < 1 : Break 2 : Endif
                     Endif
                     # mise à jour des qtés allouée et en rupture
                     If [F:MFM]ALLSTA > 1
                        [F:MFM]ALLQTY += WWALLQTY
                        [F:MFM]SHTQTY += WWSHTQTY
                     Endif
                     WMATCLENBR -= 1
               Elsif [M:MTK3]CLEFLG(nolign-1) = 1
                     If  [F:MFM]MFMTRKFLG < 4         :#une ligne passe à "encours"
                         [F:MFM]MFMTRKFLG = 4
                     Endif
                     If [F:MFM]ALLSTA > 1
                        [F:MFM]ALLQTY -= WWALLQTY
                        [F:MFM]SHTQTY -= WWSHTQTY
                     Endif
               Endif
               If    [F:MFM]MFMTRKFLG = 4 : [F:MFM]MATSTA = 2
               Elsif [F:MFM]MFMTRKFLG = 5 : [F:MFM]MATSTA = 3
               Endif
                # CCC (10/01/08) DM 44021
                #If [F:MFM]TRKFIRST = "00/00/00" : [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT : Endif
                #If [F:MFM]MFMTRKFLG = 5 : [F:MFM]TRKLAST = [M:MTK0]MFGTRKDAT : Endif
                If [F:MFM]TRKLAST<[M:MTK0]MFGTRKDAT
                   [F:MFM]TRKLAST   = [M:MTK0]MFGTRKDAT
                Endif
                If [F:MFM]TRKLASTC<date$
                   [F:MFM]TRKLASTC  = date$
                Endif
                If [F:MFM]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFM]TRKFIRST = "00/00/00"
                    [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT
                Endif
                If [F:MFM]TRKFIRSTC>date$ | [F:MFM]TRKFIRSTC = "00/00/00"
                    [F:MFM]TRKFIRSTC = date$
                Endif
              Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
              # 10.05 demande 32472
              WCUMMATSUI =   [M:MTK3]CUMMATSUI(nolign-1)
              WACTION = "C"

             #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
             If [F:MFI]ITMSTA = 3
                # mm 11.10
                If dim([F:MFM]WGGSTAAVS) > 0
                  [F:MFM]WGGSTAAVS= [F:MFM]WGGSTA   :# Sauvegarder la situation de pesée avant le solde d'OF
                  [F:MFM]WGGSTA   = 8
                Endif
             Endif
             #=========================================================================#

              Gosub BEFORE_REWRITE_MFM
              Rewrite [F:MFM]
              If fstat
                 GOK = 0 : Call FSTA("MFM") From GLOCK : Break 2
              Endif
              #----- Mise à jour statistiques ligne matière -----#
              Call VALSTA("MFM",1) From SUBPS2
              If GOK < 1 : Break 2 : Endif
           Next
           Filter [F:MFM]
            # CCC (18/03/08) Bug 46398 : Restauration de [M:SOW]
            Raz [M:SOW]
            Transmask [M:SOWS] To [M:SOW]  # Issue X3-36381 [M:SOW] = [M:SOWS]
        Else
              Readlock [F:MFM]MFM0 = [M:MTK0]MFGNUM;[M:MTK3]MFGLIN(nolign-1);[M:MTK3]BOMSEQ(nolign-1);[M:MTK3]MATITMREF(nolign-1)
              If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[M:MTK3]MFMITMREF(nolign-1) : Break
              Elsif fstat GOK=0  : Call RSTA("MFM",[M:MTK3]MFMITMREF(nolign-1)) From GLOCK : Break
              Endif
              If [M:MTK3]WEXCMAT(nolign-1) = 2
                  # exclusion de la matière sur l'OF
                  [F:MFM]MATSTA = 4
                  # normalement il n'y a pas d'allocation sur cette matière
                  Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                  Update [F:MFG] Where MFGNUM = [F:MFM]MFGNUM With MATLINNBR -= 1
                  If fstat : GOK = 0 : Break : Endif
              Else
                  If  [M:MTK3]USEQTY(nolign-1) <> 0
                      [F:MFM]USEQTY += [M:MTK3]USEQTY(nolign-1)

                      Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
                      Gosub LOAD_STW    From MTKAUTLIB
                      Gosub LOAD_ALP    From MTKAUTLIB
                      Raz LQTA,LSHT,LNBR,LNBJ,LRET
                      #  03.06  demande 35048
                      If [F:MFM]ALLSTA > 1
                          Call MAJALLORI([M:MTK3]WSTOSEQ(nolign-1),LRET) From STKALL
                          If LRET : GOK = 0 : Break : Endif
                          WWALLQTY = [M:ALP]DESQTY
                          WWSHTQTY = [M:ALP]DESQTYSHT
                      Endif
                      Call ALISTOWORK(3,[M:MTK3]WSTOSEQ(nolign-1),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
# 03.06 fin de remplacement
                      If LRET : GOK = 0 : Break : Endif
                      Call MAJ_STOCK() From STKMAJ
                      If GOK < 1 : Break  : Endif
                  Endif
                  #mise à jour du flag solde selon différents cas
                  If     [M:MTK3]CLEFLG(nolign-1) = 2 & [F:MFM]MFMTRKFLG < 5:#on solde une ligne
                         [F:MFM]MFMTRKFLG = 5
                         # CCC (10/01/08) DM 44021
                         #[F:MFM]TRKLAST = [F:MTK]MFGTRKDAT
                         If [F:MFM]ALLQTY <> 0 | [F:MFM]SHTQTY <> 0
                             Gosub SUPALL_OF
                             If GOK < 1 : Break : Endif
                             Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                         Endif
                         WMATCLENBR += 1
                  Elsif [M:MTK3]CLEFLG(nolign-1) = 1 & [F:MFM]MFMTRKFLG = 5 :#on désolde une ligne
                        [F:MFM]MFMTRKFLG = 4
                        # CCC (10/01/08) DM 44021
                        #Raz [F:MFM]TRKLAST
                        #On réalloue si besoin
                        If [F:MFM]RETQTY > [F:MFM]USEQTY & [F:MFM]ALLSTA > 1
                           Gosub CREALL_OF
                           If GOK < 1 : Break  : Endif
                        Endif
                        #mise à jour des qtés allouée et en rupture
                        If [F:MFM]ALLSTA > 1
                           [F:MFM]ALLQTY += WWALLQTY
                           [F:MFM]SHTQTY += WWSHTQTY
                        Endif
                        WMATCLENBR -= 1
                  Elsif [M:MTK3]CLEFLG(nolign-1) = 1
                        If [F:MFM]MFMTRKFLG < 4 :#une ligne passe à "encours"
                           [F:MFM]MFMTRKFLG = 4
                        Endif
                        If [F:MFM]ALLSTA > 1
                           [F:MFM]ALLQTY -= WWALLQTY
                           [F:MFM]SHTQTY -= WWSHTQTY
                        Endif
                  Endif
                  If    [F:MFM]MFMTRKFLG = 4 : [F:MFM]MATSTA = 2
                  Elsif [F:MFM]MFMTRKFLG = 5 : [F:MFM]MATSTA = 3
                  Endif
                  # CCC (10/01/08) DM 44021
                  #If [F:MFM]TRKFIRST = "00/00/00" : [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT : Endif
                  #If [F:MFM]MFMTRKFLG = 5 : [F:MFM]TRKLAST = [M:MTK0]MFGTRKDAT : Endif
                  If [F:MFM]TRKLAST<[M:MTK0]MFGTRKDAT
                     [F:MFM]TRKLAST   = [M:MTK0]MFGTRKDAT
                  Endif
                  If [F:MFM]TRKLASTC<date$
                     [F:MFM]TRKLASTC  = date$
                  Endif
                  If [F:MFM]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFM]TRKFIRST = "00/00/00"
                      [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT
                  Endif
                  If [F:MFM]TRKFIRSTC>date$ | [F:MFM]TRKFIRSTC = "00/00/00"
                      [F:MFM]TRKFIRSTC = date$
                  Endif
             Endif

             # affectations V6
             If [F:MFG]MFGSTA   = 4 | [F:MFM]MFMTRKFLG = 5 : Gosub SUP_MTO_MFM From MFGMTOLIB : Endif

             Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM

             # affectations
             Gosub MAJ_MTO_MFM From MFGMTOLIB

                 # 10.05 demande 32472
             WCUMMATSUI =   [M:MTK3]CUMMATSUI(nolign-1)
             WACTION = "C"

             #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
             If [F:MFI]ITMSTA = 3
                # mm 11.10
                If dim([F:MFM]WGGSTAAVS) > 0
                  [F:MFM]WGGSTAAVS= [F:MFM]WGGSTA   :# Sauvegarder la situation de pesée avant le solde d'OF
                  [F:MFM]WGGSTA   = 8
                Endif
             Endif
             #=========================================================================#

             Gosub BEFORE_REWRITE_MFM

             Rewrite [F:MFM]
             If fstat
                GOK = 0 : Call FSTA("MFM") From GLOCK : Break
             Endif
            #----- Mise à jour statistiques ligne matière  -----#
            Call VALSTA("MFM",1) From SUBPS2
            If GOK < 1 : Break : Endif
        Endif
     Else
        Gosub LOAD_STW   From MTKAUTLIB
        Raz LQTA,LSHT,LNBR,LNBJ,LRET
        Call ALISTOWORK(3,[M:MTK3]WSTOSEQ(nolign-1),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
        Call MAJ_STOCK() From STKMAJ
        If GOK < 1 : Break  : Endif
     Endif
    #------------------------------------------------------------------------------------------------------------------
    # point d'entrée WIP costing 14548
           If dim(WRET) < 0     : Local Integer WRET       : Endif
           If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
           GWIPCOST = "MATTRK_NEW"
           WRET = 0
           GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
           If WRET > 0 : GOK = 0 : Break : Endif

    #------------------------------------------------------------------------------------------------------------------
    Endif
Next
Filter [F:MFM]
Return

###############################################
$MAJMKM_CPTANALIN

Call ENREG_ACCCCE(nolign-1,"","","[M:MTK3]CCE","MKM",0,[F:MKM]MFGTRKNUM,[F:MKM]MATTRKLIN,0,"","C") From TRTX3CPT

Return
###############################################
#Suppression des allocations restantes pour la ligne matière si solde
#en création de suivi matière
$SUPALL_OF
Local Decimal WALLQTY
Local Decimal WSHTQTY
Local Integer WRET

Call DELALL(12,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF,0,WALLQTY,WSHTQTY,WRET) From STKALL
If WRET <> 0 : GOK = 0 : Endif
Return


###############################################
Subprog MAJMFGHEAD(LVCR,LOPECLENBR,LITMCLENBR,LMATCLENBR,LCPLQTY,LREJQTY,LQUAQTY,LPRN)
Value     Char     LVCR
Value     Integer  LOPECLENBR
Value     Integer  LITMCLENBR
Value     Integer  LMATCLENBR
Value     Decimal  LCPLQTY
Value     Decimal  LREJQTY  # FGR 14/01/2010 : X3SUIVI60986
Value     Decimal  LQUAQTY  # FGR 14/01/2010 : X3SUIVI60986
Value     Integer  LPRN
Local     Integer  WPRN : WPRN = LPRN

If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
#Maj de l'entête OF en création/Modification/Suppression de suivi
Readlock [F:MFG]MFG0 = LVCR
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MTK]MFGNUM : End
Elsif fstat GOK=0  : Call RSTA("MFG",[F:MTK]MFGNUM) From GLOCK : End
Endif
[F:MFG]OPECLENBR += LOPECLENBR
[F:MFG]MATCLENBR += LMATCLENBR
[F:MFG]ITMCLENBR += LITMCLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    # CCC (10/01/08) DM 44021
    #[F:MFG]TRKLAST = [F:MTK]MFGTRKDAT
    [F:MFG]MFGTRKFLG = 5
Else
    [F:MFG]MFGTRKFLG = 4
    # CCC (10/01/08) DM 44021
    #Raz [F:MFG]TRKLAST
Endif

If find(GREP,"C","M")
      # CCC (10/01/08) DM 44021
      #If [F:MFG]TRKFIRST = "00/00/00" : [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT : Endif
      If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
          [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
      Endif
      If [F:MFG]TRKLASTC<date$
          [F:MFG]TRKLASTC  = date$
      Endif
      If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
          [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
      Endif
      If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
          [F:MFG]TRKFIRSTC = date$
      Endif
Elsif GREP = "A" : Gosub MAJSTATUT
Endif
If find(GREP,"M","A")
#----- MISE à jour statistiques entête d'OF -----#
     Call VALSTA("MFG",-1) From SUBPS2
     If GOK < 1 : End : Endif
Endif
#Si Déclaration de production alors maj des qtés réalisées...
If  [F:MTK]ITMTRKFLG = 2
    [F:MFG]CPLQTY    += LCPLQTY
    [F:MFG]REJCPLQTY += LREJQTY
    [F:MFG]QUACPLQTY += LQUAQTY
    If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
        [F:MFG]RMNEXTQTY = 0
    Else
        [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
    Endif
    Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
    If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
    If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
    If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
Endif
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : End
Endif
If find(GREP,"C","M")
#----- MISE à jour statistiques Entête d'OF -----#
     Call VALSTA("MFG",1) From SUBPS2
     If GOK < 1 : End : Endif
Endif
#----- MISE à jour Entête de Wipcost -----#
Readlock [MWH]MWH0=10;[F:MFG]MFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGWIP"-[F:MFG]MFGNUM : End
#Elsif fstat GOK=0  : Call RSTA("MWH",[F:MFG]MFGNUM) From GLOCK : End # pas grave !
Elsif !fstat
 [F:MWH]MFGTRKFLG = [F:MFG]MFGTRKFLG
 [F:MWH]TRKLAST   = [F:MFG]TRKLAST
 Rewrite [MWH]
 If fstat
   GOK = 0 : Call FSTA("MWH") From GLOCK : End
 Endif
Endif
End

########################################################
#Recalcul des statuts de l'entête d'OF
$MAJSTATUT
Local Integer WIPOPE, WIPITM,WIPMAT,XTOT
# 03.05 demande 28958
If clalev([F:MFO1])<=0 : Local File MFGOPE [MFO1] : Endif
If clalev([F:MFI1])<=0 : Local File MFGITM [MFI1] : Endif
If clalev([F:MFM1])<=0 : Local File MFGMAT [MFM1] : Endif
If clalev([F:MTK1])<=0 : Local File MFGHEADTRK [MTK1] : Endif
Filter [F:MFO1]
Filter [F:MFI1]
Filter [F:MFM1]
Filter [F:MTK1]
Raz [F:MFG]DETALLNBR
Raz [F:MFG]SHTMATNBR

For [F:MFO1] Where MFGNUM = [F:MFG]MFGNUM
    If find([F:MFO1]OPESTA,4,5,7) : WIPOPE += 1 : Endif
Next
For [F:MFI1] Where MFGNUM = [F:MFG]MFGNUM
    If find([F:MFI1]ITMSTA,2,3) : WIPITM += 1 : Endif
Next
For [F:MFM1] Where MFGNUM = [F:MFG]MFGNUM
    If find([F:MFM1]MATSTA,2,3) : WIPMAT += 1 : Endif
    Case [F:MFM1]ALLSTA    # évaluation nouveaux totaux en fonction de l'évolution du statut
            When 4:  [F:MFG]DETALLNBR += 1
                     [F:MFG]SHTMATNBR += 1
            When 5:  [F:MFG]DETALLNBR += 1
    Endcase
Next
For [F:MTK1]MTK1 Where MFGNUM = [F:MFG]MFGNUM & MFGTRKNUM <> [F:MTK]MFGTRKNUM
    WIPMAT += 1
Next

# si des ruptures existent, statut allocation + 2
#If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif

If WIPOPE = 0 &
&  WIPITM = 0 &
&  WIPMAT = 0
   If WPRN = 2 : [F:MFG]MFGTRKFLG = 3
   Else        : [F:MFG]MFGTRKFLG = 1
   Endif
   Raz [F:MFG]TRKFIRST
   Raz [F:MFG]TRKLAST
   Raz [F:MFG]TRKFIRSTC
   Raz [F:MFG]TRKLASTC
Endif
# 03.05 demande 28958
#Close Local File [MFO1]
#Close Local File [MFI1]
#Close Local File [MFM1]
#Close Local File [MTK1]            # llc 07.04 23880
Return

################################################################################
# Chargement pour modification mouvements de stock de déclaration de production#
################################################################################
$MODMVTSTOE
Global Decimal GTOTQTY, GQQQQTY, GRRRQTY
# --> Ctrl autorisation modification
GBIDC2="M": GFCY=[M]MFGFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2
   GZNUM=0 : GERR=1 : GMESSAGE=mess(2,104,1)
   FIN=1 : Return
Endif
NOL = nolign-1
LTYP = 15
SITE = [M:MTK0]MFGFCY
LITM = [M:MTK2]ITMREF(NOL)
LNUM = [M:MTK0]MFGTRKNUM
LLIN = [M:MTK2]ITMTRKLIN(NOL)
If [M:MTK2]PRODTYP(NOL) = 1
   LTYPORI = 10
   LNUMORI = [M:MTK2]MFGNUMIT(NOL)
   LLINORI = [M:MTK2]MFGLIN(NOL)
Endif
LECR = NOL

Return

#############################################################
$ANNULE_SUIV

#Annulation d'un suivi
Local Integer LRET,WNBR,WPRN
Local Char WTRSNUM
# 04.02 demande 14124
If [F:MTK]MFGNUM <> ""
    Local File MFGPRN [MFP]
    WPRN = 1
    Read [F:MFP]MFP0 = [F:MTK]MFGNUM
    If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
    Close Local File [F:MFP]
Endif
#------------------------------- Annulation suivi opérations ------------------------------#
If clalev([F:XKO])<=0 : Local File MFGOPETRK [XKO] : Endif
If [F:MTK]OPETRKFLG = 2
    Filter [F:MKO] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
    For [MKO]
        Gosub ANNULE_SUIVOPE
        If GOK < 1 : Break : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
        If dim(WRET) < 0     : Local Integer WRET       : Endif
        If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
        GWIPCOST = "OPETRK_DEL"
        WRET = 0
        GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
        If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------
       Call OPETRK_DEL(WRET) From MWIPLIB  # intégration WIP 140 (TB)
       If WRET > 0 : GOK = 0 : Break : Endif

    Next
    If GOK = 0 : Return : Endif
    Delete [F:MKO] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
    If GOK = 0 : GLOCK = "$"+"MFGOPETRK" : Endif
    Filter [F:MKO]
    Close Local File [F:XKO]
Endif
#
#----------------------------- Annulation déclaration production -------------------------#
If [F:MTK]ITMTRKFLG = 2
    Gosub DECL_VAR
    Local Decimal WCPLQTY,WREJQTY,WQUAQTY
    Raz WCPLQTY,WREJQTY,WQUAQTY
    Filter [F:MKI] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
    For [MKI]
       Gosub ANNULE_SUIVITM
       If GOK < 1 : Break : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
        If dim(WRET) < 0     : Local Integer WRET       : Endif
        If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
        GWIPCOST = "ITMTRK_DEL"
        WRET = 0
        GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
        If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------

    Next
    If GOK < 1 : Return : Endif
    Delete [F:MKI] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
    If GOK = 0 : GLOCK = "$"+"MFGITMTRK" : Endif
    Filter [F:MKI]
Endif
#
#-------------------------- Annulation suivi matières ------------------------------------#
If [F:MTK]MATTRKFLG = 2
    Gosub DECL_VAR
    WFCY = [F:MTK]MFGFCY
    If !clalev([SOM]) : Local Mask STOSORM [SOM] : Endif
    Filter [F:MKM] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
    For [MKM]
        Gosub ANNULE_SUIVMAT
        If GOK < 1 : Break : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
        If dim(WRET) < 0     : Local Integer WRET       : Endif
        If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
        GWIPCOST = "MATTRK_DEL"
        WRET = 0
        GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
        If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------

    Next
#suppression des lignes suivi matière
  If GOK < 1 : Return : Endif
  Delete [F:MKM] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
  If GOK = 0 : GLOCK = "$"+"MFGMATTRK" : Endif
  Filter [F:MKM]
Endif
If clalev ([F:MFO]) <= 0 : Local File MFGOPE [MFO] : Endif
If [F:MTK]MFGNUM <> ""
   Call MAJMFGHEAD([F:MTK]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN)
    Raz GPE
    GPOINT="UPDSCD"
    Gosub ENTREE From EXEFNC
    If !GPE
       # 08.02 si besoin maj de WORKLOAD demande 15029
       If [F:MTK]OPETRKFLG = 2
           Read [F:MFG]MFG0 = [F:MTK]MFGNUM
           If !fstat & find([F:MFG]SCDFLG,2,4)
               [M:JALK]CODORI = 1
               [M:JALK]CODMAJ = 0
               [M:JALK]CODTRS = 0                    # llc 11.02 16716
               [M:JALK]MFGFCY = [F:MFG]MFGFCY
               [M:JALK]MFGNUM = [F:MFG]MFGNUM
               [M:JALK]MFGSTA = [F:MFG]MFGSTA
               # llc 12.02 16779
               If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
               If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                   Read [PJA]PJA0=[M:JALK]MFGFCY
                   If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
               Endif
               # Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WO when it is being optimized
               If (func AFNC.ACTIV("POPS") = 0 | ([F:MFG]OPTFLG <> 2 & [F:MFG]SCDFLG <> 4))
                   Call DEJALONNE From JALLIBA
                   If [M:JALK]CODRET = 0
                       Call JALONNE From JALLIB
                   Endif
               Endif
           Endif
        Endif
    Endif
    If GOK < 1 : Return : Endif
Endif

If GOK >0
  Call TRACKING_DELETED([F:MTK]MFGTRKNUM) From SFTLIB #SAM 96961
Endif

Return

##########################################
$ANNULE_SUIVOPE
#------------------------------------#
# supression des textes associées    #
#------------------------------------#
Local Integer WRET,WSOLDE
Local Decimal WCPLHOU

If [F:MKO]MKOTEX  <> "" & left$([F:MKO]MKOTEX,3) = "MKO"
   Call SUP_CLOB([F:MKO]MKOTEX,WRET) From TRTX3TEX
Endif

# 75509
If [F:MKO]TIMTYP = 1 & [F:MKO]ROUOPENUM  = 0
    Read [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
    If fstat : Goto NXT_ASO : Endif
Endif

If [F:MKO]TIMTYP = 1
    Readlock [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
    If fstat=1  GOK=-1 : GLOCK="$MFGOPE"-num$([F:MKO]OPENUM) : Return
    Elsif fstat GOK=0  : Call RSTA("MFO",num$([F:MKO]OPENUM)) From GLOCK : Return
    Endif

    #----- MISE à jour statistiques ligne opé -----#
    Call VALSTA("MFO",-1) From SUBPS2
    If GOK < 1 : Return : Endif

    Read [F:MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
#--------------------------------------------#
#MAJ poste réalisé et nbr de postes réalisés #
#--------------------------------------------#
#On filtre le fichier suivi opé sur le même OF, même opé
    Filter [F:XKO] Where MFGNUM = [F:MKO]MFGNUM & OPENUM = [F:MKO]OPENUM &
&                        OPESPLNUM = [F:MKO]OPESPLNUM & MFGTRKNUM <> [F:MKO]MFGTRKNUM
    Read [F:XKO]MKO1 First            # 10.02 Performances
#Si pas d'autre suivi sur cette opé on 'raz' le poste réalisé,le nbre de postes
#et le poste main d'oeuvre réalisé
    If fstat
       Raz [F:MFO]CPLWST, [F:MFO]CPLWSTNBR,[F:MFO]CPLLAB
    Else
#On récupère le poste main d'oeuvre
       [F:MFO]CPLLAB = [F:XKO]CPLLAB
#si le prochain suivi portait sur un autre poste on récupère le poste
       If [F:MFO]CPLWST <> [F:XKO]CPLWST
          [F:MFO]CPLWST = [F:XKO]CPLWST
# llc 03.01 multi-exemplaire
#Y a-t-il un suivi avec le même poste réalisé ?
#           Filter [F:XKO] Where MFGNUM = [F:MKO]MFGNUM &
#&                               OPENUM = [F:MFO]OPENUM & CPLWST = [F:MKO]CPLWST
#           Read First
#si pas d'autre suivi sur ce poste on décrémente le nbre de postes réalisés
#           If fstat
#                [F:MFO]CPLWSTNBR -= 1
#           Endif
       Endif
    Endif
    Filter [F:XKO]

    #---------
    # 02.07 39933
    # PE pour inhiber la mise à jour de MFO
    GPOINT = "DEL_CPLMFO"
    Gosub  ENTREE From EXEFNC
    #---------

    If !GPE
        [F:MFO]CPLQTY    -= [F:MKO]CPLQTY     * [F:MKO]OPEWORCOE
        [F:MFO]REJCPLQTY -= [F:MKO]REJCPLQTY  * [F:MKO]OPEWORCOE
        [F:MFO]CPLSETTIM -= [F:MKO]CPLSETTIM
        [F:MFO]CPLOPETIM -= [F:MKO]CPLOPETIM
        If [F:MFO]CPLQTY <> 0
             [F:MFO]CPLUNTTIM  = [F:MFO]CPLOPETIM/[F:MFO]CPLQTY
            # 11.06 demande 38402
            [F:MFO]CPLUNTTIM = func TRTX3.ARRTYP("","","TIH",[F:MFO]CPLUNTTIM)
        Else Raz [F:MFO]CPLUNTTIM,[F:MFO]TRKFIRST,[F:MFO]TRKFIRSTC,[F:MFO]TRKLAST,[F:MFO]TRKLASTC
        Endif
    Endif
#L'opération est-elle soldée quand même
    Raz LRET,WSOLDE
    Call CONT_SOLDE_OPE([F:MFO]MFGFCY,[F:MFO]CPLWST,[F:MFO]CPLQTY,[F:MFO]EXTQTY,LRET) From MFGLIBO
#L'opération est soldée
    If LRET = 1
       If   [F:MFO]OPESTA <> 5
            [F:MFO]OPESTA = 5
            If [F:MWS]WSTTYP<> 3 : WOPECLENBR += 1
            Else WSOLDE = 2
            Endif
       Endif
#L'opération n'est pas soldée
    Else
#Si elle l'était auparavant
       If  [F:MFO]OPESTA = 5
           If [F:MFO]CPLQTY <> 0 : [F:MFO]OPESTA = 4
           Else
              If [F:MFO]POHNUM = "": [F:MFO]OPESTA = 1
              Else                 : [F:MFO]OPESTA = 7
              Endif
           Endif
           If [F:MWS]WSTTYP <> 3 : WOPECLENBR -= 1
           Else WSOLDE = 1
           Endif
#Si elle n'était déjà pas soldée
       Else
#Si la qté réalisée devient = à 0 , l'ope revient en attente ou cdée sinon elle reste en cours
          If [F:MFO]CPLQTY = 0
              If [F:MFO]POHNUM = ""   : [F:MFO]OPESTA = 1
              Else                    : [F:MFO]OPESTA = 7
              Endif
          Endif
        Endif
    Endif
    If [F:MFO]OPESTA < 4
        If WPRN = 2 : [F:MFO]MFOTRKFLG = 3
        Else        : [F:MFO]MFOTRKFLG = 1
        Endif
    Else
        If [F:MFO]OPESTA = 7 : [F:MFO]MFOTRKFLG = 4
        Else                 : [F:MFO]MFOTRKFLG = [F:MFO]OPESTA
        Endif
    Endif
    # CCC (14/01/08) DM 44021
    #If [F:MFO]MFOTRKFLG <> 5 : Raz [F:MFO]TRKLAST : Endif
    Gosub MAJ_SUIVANTE
    If !find([F:MFO]OPESTA,4,5,7) : Gosub LEC_PREC : Endif
    If GOK = 0 : Return : Endif
    Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
    Read [F:MFI]MFI0 First
    If !fstat
        Call UPDATE_OWX("SM",[F:MFI]PJT) From MFGLIBO
        If GOK = 0 : Call ERREUR(mess(99,193,1)) From GESECRAN : Endif
    Endif
    Filter [MFI]
    Rewrite [F:MFO]
    If fstat
       GOK = 0 : Call FSTA("MFO") From GLOCK : Return
    Endif

#On a soldé une fraction d'opé de STT. Faut-il incrémenter le nbre d'opé soldées?
    If [F:MWS]WSTTYP = 3 & WSOLDE = 2
        Local Integer WPREC : WPREC = [F:MFO]OPENUM
        Gosub  CTR_SOLDE From FUNMFGS
    Endif
#On a désoldé une fraction d'opé de STT. Faut-il décrémenter le nbre d'opé soldées?
    If [F:MWS]WSTTYP = 3 & WSOLDE = 1
        Local Integer WPREC : WPREC = [F:MFO]OPENUM
        Gosub CTR_DESOLDE From FUNMFGS
    Endif
   #MAJ entête d'OF ici si suivi multi-OF
    If [F:MTK]MFGNUM = ""
       Readlock [F:MFG]MFG0 = [F:MKO]MFGNUM
       If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MKO]MFGNUM : Return
       Elsif fstat GOK=0  : Call RSTA("MFG",[F:MKO]MFGNUM) From GLOCK : Return
       Endif
       # 04.02 demande 14124
       Local File MFGPRN [MFP]
       WPRN = 1
       Read [F:MFP]MFP0 = [F:MFG]MFGNUM
       If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
       Close Local File [F:MFP]
       [F:MFG]OPECLENBR += WOPECLENBR
       If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&         [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&         [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
                             # CCC (14/01/08) DM 44021
                             #[F:MFG]TRKLAST = [F:MTK]MFGTRKDAT
                             [F:MFG]MFGTRKFLG = 5
       Else                  [F:MFG]MFGTRKFLG = 4
                             #Raz [F:MFG]TRKLAST
                             Gosub MAJSTATUT
       Endif
       # CCC (14/01/08) DM 44021
       If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
           [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKLASTC<date$
           [F:MFG]TRKLASTC  = date$
       Endif
       If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
           [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
           [F:MFG]TRKFIRSTC = date$
       Endif

       Rewrite [F:MFG]
       If fstat
         GOK = 0 : Call FSTA("MFG") From GLOCK : Return
       Endif

       #----- MISE à jour statistiques entête OF -----#
       Call VALSTA("MFG",-1) From SUBPS2
       If GOK < 1 : Return : Endif
       Raz WOPECLENBR
       # 08.02 si besoin maj de WORKLOAD demande 15029
       If find([F:MFG]SCDFLG,2,4)
           [M:JALK]CODORI = 1
           [M:JALK]CODMAJ = 0
           [M:JALK]CODTRS = 0                        # llc 11.02 16716
           [M:JALK]MFGFCY = [F:MFG]MFGFCY
           [M:JALK]MFGNUM = [F:MFG]MFGNUM
           [M:JALK]MFGSTA = [F:MFG]MFGSTA
           # llc 12.02 16779
           If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
           If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
               Read [PJA]PJA0=[M:JALK]MFGFCY
               If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
           Endif
           # Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WO when it is being optimized
           If (func AFNC.ACTIV("POPS") = 0 | ([F:MFG]OPTFLG <> 2 & [F:MFG]SCDFLG <> 4))
              Call DEJALONNE From JALLIBA
              If [M:JALK]CODRET = 0
                  Call JALONNE From JALLIB
              Endif
           Endif
           If GOK < 1 : Return : Endif
       Endif

       #----- MISE à jour Entête de Wipcost -----#
       If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
       Readlock [MWH]MWH0=10;[F:MFG]MFGNUM
       If fstat=1  GOK=-1 : GLOCK="$MFGWIP 10;"+[F:MFG]MFGNUM : Return
       #Elsif fstat GOK=0  : Call RSTA("MWH",[F:MFG]MFGNUM) From GLOCK : return
       Elsif !fstat
         [F:MWH]MFGTRKFLG = [F:MFG]MFGTRKFLG
         [F:MWH]TRKLAST   = [F:MFG]TRKLAST
         [F:MWH]TRKFIRST  = [F:MFG]TRKFIRST
         Rewrite [MWH]
         If fstat
           GOK = 0 : Call FSTA("MWH") From GLOCK : Return
         Endif
       Endif
    Endif
    #----- MISE à jour statistiques ligne suivi opé -----#
    Call VALSTA("MKO",-1) From SUBPS2
    If GOK < 1 : Return : Endif
Endif
# 75509
$NXT_ASO
#Sup éventuelle du fichier réponses fiche technique
If [F:MFO]TECCRD <> ""
        If clalev([F:MTA])<= 0 : Local File MTKCRDASW [MTA] : Endif
        Delete [F:MTA] Where MFGTRKNUM = [F:MTK]MFGTRKNUM & OPETRKLIN = [F:MKO]OPETRKLIN
        If GOK = 0 : Return : Endif
        Close Local File [F:MTA]
Endif
#Maj du fichier WORKSTATIO
Readlock [F:MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
If !fstat
    WCPLHOU = [F:MKO]CPLOPETIM
    If [F:MKO]TIMUOMCOD = 2 : WCPLHOU = WCPLHOU / 60 : Endif
    [F:MWS]CPLHOUTIM -= func TRTX3.ARRTYP("","","TIH",WCPLHOU)
    Rewrite [F:MWS]
    If fstat
       GOK = 0 : Call FSTA("MWS") From GLOCK : Return
    Endif
Endif

# Issue 74988 - 2011-09-01 by CCC : Suppression des sections analytiques liées au suivi
Delete [F:CAL] Where ABRFIC="MKO"
&                  & VCRNUM=[F:MKO]MFGTRKNUM
&                  & VCRLIN=[F:MKO]OPETRKLIN
&                  & CPLCLE=[F:MKO]CPLWST
If [F:MKO]CPLLAB<>""
    Delete [F:CAL] Where ABRFIC="MKO"
&                      & VCRNUM=[F:MKO]MFGTRKNUM
&                      & VCRLIN=[F:MKO]OPETRKLIN
&                      & CPLCLE=[F:MKO]CPLLAB
Endif

Return

###################################
$ANNULE_SUIVITM
Local Integer WSOLDE, I, SAVNOLIGN
Local Decimal WALLREJQTY,WQTE1, WQTE2
Local Decimal WRRRQTY, WQQQQTY
Local Char    WPJT
Local Integer WRETOUR, WOK

If [F:MKI]PRODTYP = 1
    Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
    If fstat : GOK = 0 : Call RSTA("MFI",[F:MKI]ITMREF) From GLOCK : Return : Endif

    # 68911
    # affectations v6
    Call MAJ_MTO("A", [F:MKI]CPLQTY)   From MTKMTOLIB
    If GOK<1 : Return : Endif : # GH 05/09/12 bug 84291

#    #Si production pour une commande
#    If [F:MFI]FMI = 5 & [F:MFI]VCRTYPORI = 2 : Call MAJ_ALLOCATION("A",[F:MKI]CPLQTY,
#&                                                   [F:MKI]ITMTRKLIN)
#       If GOK < 1 : Return : Endif
#    Endif
    WPJT = [F:MFI]PJT
Endif
Read [F:ITM]ITM0 = [F:MKI]ITMREF
# si on est en suppression ligne via le moteur de modif (GREP = ""), la MAJ du stock est faite
# par les stock. De même la maj de l'entête d'OF est faite par TRT_MAJ_DOCUMENT
If GREP = "A"
    Raz [M:STW]
    [M:STW]MAJCOD   = "A"
    [M:STW]STOFCY   = [F:MKI]MFGFCY            : # Site
    [M:STW]TRSTYP   = 5                        : # Type mouvement (M.704)
    [M:STW]VCRTYP   = 15                       : # Type pièce (M.701)
    [M:STW]VCRNUM   = [F:MKI]MFGTRKNUM         : # Numéro pièce
    [M:STW]VCRLIN   = [F:MKI]ITMTRKLIN         : # Numero ligne pièce
    [M:STW]ITMREF   = [F:MKI]ITMREF            : # Article
    [M:STW]BPRNUM   = ""                       : # Tiers
    [M:STW]PJT      = WPJT                     : # Affaire
    If mid$(GFONCTION1,1,6)="GESPTH"              :
      [M:STW]TRSCOD   = [F:PTH]TRSCOD             :
      [M:STW]TRSFAM   = [F:PTD]TRSFAM             :
    Else
      [M:STW]TRSFAM   = [F:MTS]TRSFAM
      [M:STW]TRSCOD   = [F:MTS]TRSCOD
    Endif
    [M:STW]IPTDAT   = [F:MKI]IPTDAT            : # Date imputation
    [M:STW]PRIORDH  = 0                        : # Prix de l'ordre
    [M:STW]TRAFLG   = 2                        : # Trace normal
    [M:STW]CCECOD   = "STKEOF"
    [M:STW]TRAFLG   = 2                        : # Trace normal
    [M:STW]CUR = GLOCALDEV
    [M:STW]BPRNUM = ""

    If !WRETOUR
        If !clalev([M:ENM])  Local Mask STOENTM [ENM]  : Endif
        Raz [M:ENM]
        Call ALISTOWORK (4,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRETOUR) From STKINT
        If !WRETOUR
            #----- Appel du sous-programme de mise à jour des stocks -----#
            Call MAJ_STOCK From STKMAJ
            If GOK<1 : Return : Endif
        # Issue 73670 - 2011-05-18 by CCC : déplacées pour faire le calcul dans tous les cas
        #    # attention le quantités renvoyées dans ce cas sont négatives !!!
        #    WRRRQTY = [M:STW]RRRQTY
        #    WQQQQTY = [M:STW]QQQQTY

            # CCC(04/10/06) DM 37826
            Call FUNSTKACC([F:MKI]MFGFCY,[F:MKI]ITMREF,15, [F:MKI]MFGTRKNUM, [F:MKI]ITMTRKLIN) From STKLIB
            If GOK < 1
              WRETOUR = 1
            Endif
        Endif
    Endif

Endif
# Issue 73670 - 2011-05-18 by CCC : déplacées pour faire le calcul dans tous les cas
#    # attention le quantités renvoyées dans ce cas sont négatives !!!
WRRRQTY = [M:STW]RRRQTY
WQQQQTY = [M:STW]QQQQTY
#
If [F:MKI]PRODTYP = 1
    #Mise à jour de la ligne article de l'OF
    Readlock [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
    If fstat : GOK = 0 : Call RSTA("MFM",[F:MKI]ITMREF) From GLOCK : Return : Endif
    WSOLDE = [F:MFI]MFITRKFLG
    [F:MFI]CPLQTY -= [F:MKI]CPLQTY
    Call QTEARR([F:MFI]CPLQTY,[F:MFI]STU) From TRTDIV
    If [F:MFI]ITMTYP <> 2 : WCPLQTY        += [F:MKI]CPLQTY * -1 : Endif
    [F:MFI]REJCPLQTY += WRRRQTY
    Call QTEARR([F:MFI]REJCPLQTY,[F:MFI]STU) From TRTDIV
    If [F:MFI]ITMTYP <> 2 : WREJQTY           += WRRRQTY  : Endif
    [F:MFI]QUACPLQTY += WQQQQTY
    Call QTEARR([F:MFI]QUACPLQTY,[F:MFI]STU) From TRTDIV
    If [F:MFI]ITMTYP <> 2 : WQUAQTY           += WQQQQTY : Endif
    [F:MFI]RMNEXTQTY = [F:MFI]EXTQTY - [F:MFI]CPLQTY
    Call QTEARR([F:MFI]RMNEXTQTY,[F:MFI]STU) From TRTDIV
    If [F:MFI]CPLQTY >= [F:MFI]EXTQTY : Raz [F:MFI]RMNEXTQTY : Endif
    If [F:MFI]RMNEXTQTY > [F:MFI]EXTQTY : [F:MFI]RMNEXTQTY = [F:MFI]EXTQTY : Endif
    If [F:MFI]MFITRKFLG = 5 & [F:MFI]CPLQTY < [F:MFI]EXTQTY
                              WITMCLENBR -= 1
                              [F:MFI]MFITRKFLG = 4
    Endif
    If [F:MFI]CPLQTY = 0
       If WPRN = 2 : [F:MFI]MFITRKFLG = 3
       Else        : [F:MFI]MFITRKFLG = 1 :
       Endif
       Raz [F:MFI]TRKFIRST, [F:MFI]TRKLAST
       Raz [F:MFI]TRKFIRSTC, [F:MFI]TRKLASTC
       # selon paramètre général, remettre "" dans [F:MFI]LOT
       If [F:ITM]LOTMGTCOD > 1 &  GLOTMGT = 4
          Raz [F:MFI]LOT
       Endif
    Endif
    Case [F:MFI]MFITRKFLG
         When 1,3 : [F:MFI]ITMSTA = 1
         When 4   : [F:MFI]ITMSTA = 2
         When 5   : [F:MFI]ITMSTA = 3
         When Default :
    Endcase
    Rewrite [F:MFI]
    If fstat
       GOK = 0 : Call FSTA("MFI") From GLOCK : Return
    Endif
    #----- MISE à jour statistiques ligne article lancé -----#
    Call VALSTA("MFI",-1) From SUBPS2
    If GOK < 1 : Return : Endif
    #Maj encours et mvts article
    Gosub TRT_WIP
    If GOK < 1 : Return : Endif

    # mm 07.11 - commenter le gosub MAJ_MTO_MFI pour la livraison FLOWLINE
    # mise à jour des affectations
    Gosub MAJ_MTO_MFI From MFGMTOLIB        # 05.2011
    If GOK < 1 : Return : Endif

    Gosub TRT_MVT
    If GOK < 1 : Return : Endif
   #MAJ entête d'OF ici si suivi multi-OF
  # 09.06 demande37802 si modif des mvts de stock la maj de l'of se fait ailleurs
    If [F:MTK]MFGNUM = "" & GREP = "A"
       Readlock [F:MFG]MFG0 = [F:MKI]MFGNUM
       If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MKI]MFGNUM : Return
       Elsif fstat GOK=0  : Call RSTA("MFG",[F:MKI]MFGNUM) From GLOCK : Return
       Endif
       # 04.02 demande 14124
       Local File MFGPRN [MFP]
       WPRN = 1
       Read [F:MFP]MFP0 = [F:MFG]MFGNUM
       If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
       Close Local File [F:MFP]
       [F:MFG]ITMCLENBR += WITMCLENBR
       If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&         [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&         [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
                             # CCC (14/01/08) DM 44021
                             #[F:MFG]TRKLAST = [F:MTK]MFGTRKDAT
                             [F:MFG]MFGTRKFLG = 5
       Else                  [F:MFG]MFGTRKFLG = 4
                             #Raz [F:MFG]TRKLAST
                             Gosub MAJSTATUT
       Endif
       # CCC (14/01/08) DM 44021
       If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
           [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKLASTC<date$
           [F:MFG]TRKLASTC  = date$
       Endif
       If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
           [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
           [F:MFG]TRKFIRSTC = date$
       Endif

       [F:MFG]CPLQTY    -= ([F:MFI]ITMTYP<>2) * [F:MKI]CPLQTY
       [F:MFG]REJCPLQTY += ([F:MFI]ITMTYP<>2) * WRRRQTY
       [F:MFG]QUACPLQTY += ([F:MFI]ITMTYP<>2) * WQQQQTY
       If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
          [F:MFG]RMNEXTQTY = 0
       Else
          [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
       Endif
       Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
       If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
       If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
       If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
       Rewrite [F:MFG]
       If fstat
         GOK = 0 : Call FSTA("MFG") From GLOCK : Return
       Endif

       #----- MISE à jour statistiques entête OF -----#
       Call VALSTA("MFG",-1) From SUBPS2
       If GOK < 1 : Return : Endif
       Raz WITMCLENBR
    Endif

    #----- MISE à jour statistiques ligne suivi article lancé -----#
    Call VALSTA("MKI",-1) From SUBPS2
    If GOK < 1 : Return : Endif


Endif

# Issue 74988 - 2011-09-01 by CCC : Suppression des sections analytiques liées au suivi
Delete [F:CAL] Where ABRFIC="MKI"
&                  & VCRNUM=[F:MKO]MFGTRKNUM
&                  & VCRLIN=[F:MKO]OPETRKLIN
Return

###############################
$ANNULE_SUIVMAT
Local Decimal WCOEFF,WQTY,WREPART
Local Integer SAVNOLIGN
Local Integer STA,I : STA=0
Local Decimal WWALLQTY,WWSHTQTY
Local Decimal WQTE1, WQTE2
Local Integer WRET
# 10.05 demande 32472
Local Char    WACTION
Local Integer WCUMMATSUI

Filter [F:MFM]


If [F:MKM]MKMTEX  <> "" & left$([F:MKM]MKMTEX,3) = "MKM"
   Call SUP_CLOB([F:MKM]MKMTEX,WRET) From TRTX3TEX
Endif

#
If [F:MKM]MATTYP = 1 & [F:MKM]MFMITMREF <> ""
   If [F:MKM]CUMMATSUI = 0
       Read [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
       If fstat : GOK = 0 : Call RSTA("MFM",[F:MKM]ITMREF) From GLOCK : Return : Endif
   Else
       Filter [MFM]   Where MFGNUM = [F:MKM]MFGNUM
&                         & ITMREF = [F:MKM]MFMITMREF
&                         & BOMOPE = [F:MKM]OPENUM
&                         & MATSTA < 4
&              Order By Key MFM9=MFGNUM;BOMOPE;ITMREF;RETQTY  # 96761 mm 05.2014 + 103216
       Read [F:MFM]MFM9 First                    # 10.02 Performances
   Endif
Endif
# si on est en suppression de pièce (GREP = "A") on doit metttre à jour le stock
# sinon, on est en suppression de ligne, c'est le moteur de modif qui a déjà mis à jour les stocks!!!
# et c'est APRES_STOSOM qui met à jour l'entête d'OF
If GREP = "A" & [F:MKM]USEQTY <> 0
    #maj du stock
    Read [F:ITM]ITM0 = [F:MKM]ITMREF
    Case [F:MKM]MATTYP
        When 1,2 :
                        Raz [M:STW]
                        [M:STW]MAJCOD   = "A"
                        [M:STW]STOFCY   = [F:MKM]MFGFCY            : # Site
                        [M:STW]TRSTYP   = 6                        : # Type mouvement (M.704)
                        [M:STW]VCRTYP   = 12                       : # Type pièce (M.701)
                        [M:STW]VCRNUM   = [F:MKM]MFGTRKNUM         : # Numéro pièce
                        [M:STW]VCRLIN   = [F:MKM]MATTRKLIN         : # Numero ligne pièce
                        [M:STW]ITMREF   = [F:MKM]ITMREF            : # Article
                        [M:STW]BPRNUM   = ""                       : # Tiers
                        [M:STW]PJT      = ""                       : # Affaire
                        [M:STW]TRSFAM   = [F:MTS]TRSFAMS
                        [M:STW]TRSCOD   = [F:MTS]TRSCODS
                        [M:STW]IPTDAT   = [F:MKM]IPTDAT            : # Date imputation
                        [M:STW]PRIORDH  = 0                        : # Prix de l'ordre
                        [M:STW]TRAFLG   = 2                        : # Trace normal
                        [M:STW]CUR = GLOCALDEV
                        [M:STW]BPRNUM = ""

                        If !clalev([M:SOM])  Local Mask STOSORM [SOM]  : Endif
                        Raz [M:SOM]
                        Call ALISTOWORK (5,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT

                        #----- Appel du sous-programme de mise à jour des stocks -----#
                        Call MAJ_STOCK From STKMAJ
                        If GOK<1 : Return : Endif

        When Default :
                        Raz [M:STW]
                        [M:STW]MAJCOD   = "A"
                        [M:STW]STOFCY   = [F:MKM]MFGFCY            : # Site
                        [M:STW]TRSTYP   = 19                        : # Type mouvement (M.704)
                        [M:STW]VCRTYP   = 12                       : # Type pièce (M.701)
                        [M:STW]VCRNUM   = [F:MKM]MFGTRKNUM         : # Numéro pièce
                        [M:STW]VCRLIN   = [F:MKM]MATTRKLIN         : # Numero ligne pièce
                        [M:STW]ITMREF   = [F:MKM]ITMREF            : # Article
                        [M:STW]BPRNUM   = ""                       : # Tiers
                        [M:STW]PJT      = ""                       : # Affaire
                        [M:STW]TRSFAM   = [F:MTS]TRSFAMS
                        [M:STW]TRSCOD   = [F:MTS]TRSCODS
                        [M:STW]IPTDAT   = [F:MKM]IPTDAT            : # Date imputation
                        [M:STW]PRIORDH  = 0                        : # Prix de l'ordre
                        [M:STW]TRAFLG   = 2                        : # Trace normal
                        [M:STW]CCECOD   = "STKEOF"
                        [M:STW]TRAFLG   = 2                        : # Trace normal
                        [M:STW]CUR = GLOCALDEV
                        [M:STW]BPRNUM = ""

                        # CCC(04/10/06) DM 37826
                        Call FUNSTKACC([M:STW]STOFCY,[M:STW]ITMREF,[M:STW]VCRTYP, [M:STW]VCRNUM, [M:STW]VCRLIN) From STKLIB
                        If GOK < 1
                          WRETOUR = 1
                        Endif

                        If !clalev([M:ENM])  Local Mask STOENTM [ENM]  : Endif
                        Raz [M:ENM]
                        Call ALISTOWORK (4,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT
                        #----- Appel du sous-programme de mise à jour des stocks -----#
                        Call MAJ_STOCK From STKMAJ
                        If GOK<1 : Return : Endif
                        # attention le quantités renvoyées dans ce cas sont négatives !!!
                        WRRRQTY = [M:STW]RRRQTY
                        WQQQQTY = [M:STW]QQQQTY
    Endcase

    # CCC(04/10/06) DM 37826
    Call FUNSTKACC([F:MKM]MFGFCY,[F:MKM]ITMREF,12, [F:MKM]MFGTRKNUM, [F:MKM]MATTRKLIN) From STKLIB
    If GOK < 1
      Return
    Endif

Endif
If find([F:MKM]MATTYP,1,3) & [F:MKM]MFMITMREF <> ""
  If [F:MKM]CUMMATSUI = 0
   Raz WWALLQTY
   Raz WWSHTQTY
#Mise à jour de la matière, de l'encours
   Readlock [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
   If fstat : GOK = 0 : Call RSTA("MFM",[F:MKM]ITMREF) From GLOCK : Return : Endif
   If [F:MKM]MATTYP = 1
        [F:MFM]USEQTY -= [F:MKM]USEQTY
   Else
        [F:MFM]USEQTY += [F:MKM]USEQTY
   Endif
   If [F:MFM]USEQTY < 0 : [F:MFM]USEQTY = 0 : Endif
   Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
   If [F:MFM]MFMTRKFLG = 5 & [F:MFM]USEQTY < [F:MFM]RETQTY
                             WMATCLENBR -= 1
                            [F:MFM]MFMTRKFLG = 4
   Endif
   If [F:MFM]USEQTY = 0
      If WPRN = 2 : [F:MFM]MFMTRKFLG = 3
      Else        : [F:MFM]MFMTRKFLG = 1
      Endif
      Raz [F:MFM]TRKFIRST, [F:MFM]TRKLAST
      Raz [F:MFM]TRKFIRSTC, [F:MFM]TRKLASTC
   Endif
   Case [F:MFM]MFMTRKFLG
        When 1,3 : [F:MFM]MATSTA = 1
        When 4   : [F:MFM]MATSTA = 2
        When 5   : [F:MFM]MATSTA = 3
   Endcase
#Mise à jour des allocs sur l'OF si qté prévue reste supérieure à la qté consommée en supp d'une consomation matière
   If [F:MKM]MATTYP = 1 & [F:MFM]RETQTY > [F:MFM]USEQTY & [F:MFM]ALLSTA > 1
      WQTY = [F:MKM]USEQTY
      Gosub CREALL_OF
      If GOK < 1 : Return : Endif
 #Mise à jour des allocs sur l'OF en supp d'une réintégration matière
  Elsif [F:MKM]MATTYP = 3 & [F:MFM]ALLSTA > 1
         Gosub DIMALL_OF
  Endif
#mise à jour des qtés allouée et en rupture !!!!!
   If [F:MFM]ALLSTA > 1
       [F:MFM]ALLQTY += WWALLQTY
       [F:MFM]SHTQTY += WWSHTQTY
   Endif
#Mise à jour de l'encours
   If [F:MFM]MFGLIN <> 0
      Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
      If fstat : Raz [F:MFI] : Endif
   Else
      Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
      Read [F:MFI]MFI0 First
      If fstat : Raz [F:MFI] : Endif
      Filter [F:MFI]
   Endif
   Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
   If GOK < 1 : Return : Endif

   # affectations
   Gosub MAJ_MTO_MFM From MFGMTOLIB
#
   # 10.05 demande 32472
   WCUMMATSUI =   [F:MKM]CUMMATSUI
   WACTION = "A"

   #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
   If [F:MFI]ITMSTA < 3 &  [F:MFM]WGGSTA = 8
       If [F:MFM]WGGSTAAVS<>0
           [F:MFM]WGGSTA   = [F:MFM]WGGSTAAVS
       Else
           [F:MFM]WGGSTA   = 1
       Endif
   Elsif [F:MFI]ITMSTA = 3 & [F:MFM]WGGSTA <> 8
       [F:MFM]WGGSTAAVS = [F:MFM]WGGSTA
       [F:MFM]WGGSTA    = 8
   Endif
   #=========================================================================#

   Gosub BEFORE_REWRITE_MFM
   Rewrite [F:MFM]
   If fstat
      GOK = 0 : Call FSTA("MFM") From GLOCK : Return
   Endif
   #----- MISE à jour statistiques ligne matière -----#
    Call VALSTA("MFM",-1) From SUBPS2
    If GOK < 1 : Return : Endif
#MAJ entête d'OF ici si suivi multi-OF
# 09.06 demande37802 si modif des mvts de stock la maj de l'of se fait ailleurs
   If [F:MTK]MFGNUM = "" & GREP = "A"
       Readlock [F:MFG]MFG0 = [F:MKM]MFGNUM
       If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MKM]MFGNUM : Return
       Elsif fstat GOK=0  : Call RSTA("MFG",[F:MKM]MFGNUM) From GLOCK : Return
       Endif
       # 04.02 demande 14124
       Local File MFGPRN [MFP]
       WPRN = 1
       Read [F:MFP]MFP0 = [F:MFG]MFGNUM
       If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
       Close Local File [F:MFP]

       [F:MFG]MATCLENBR += WMATCLENBR
       If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&         [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&         [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
                             # CCC (14/01/08) DM 44021
                             #[F:MFG]TRKLAST = [F:MTK]MFGTRKDAT
                             [F:MFG]MFGTRKFLG = 5
       Else                  [F:MFG]MFGTRKFLG = 4
                             #Raz [F:MFG]TRKLAST
                             Gosub MAJSTATUT
       Endif
       # CCC (14/01/08) DM 44021
       If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
           [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKLASTC<date$
           [F:MFG]TRKLASTC  = date$
       Endif
       If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
           [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
       Endif
       If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
           [F:MFG]TRKFIRSTC = date$
       Endif

       Rewrite [F:MFG]
       If fstat
         GOK = 0 : Call FSTA("MFG") From GLOCK : Return
       Endif
       Raz WMATCLENBR
       #----- MISE à jour statistiques entête OF -----#
       Call VALSTA("MFG",-1) From SUBPS2
       If GOK < 1 : Return : Endif
   Endif
  Else
   Raz WQTY,WREPART
   # 07.05 Trier les lignes à traiter dans l'ordre ascendant des qtés prévues
   For [MFM]MFM9
       Raz WWALLQTY
       Raz WWSHTQTY
#Mise à jour de la matière, de l'encours
       Readlock [F:MFM] Curr              # 10.02 Performances
       If fstat : GOK = 0 : Call RSTA("MFM",[F:MKM]ITMREF) From GLOCK : Break : Endif
       WCOEFF = ([F:MFM]RETQTY/[F:MKM]MFMEXTQTY)
       # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
       # Ce sont les quantités qui sont arrondies
       ## 01.02 demande 12597
       #WCOEFF = arr(WCOEFF,0.00000001)
       If WCOEFF = 0
          WQTY = [F:MFM]USEQTY
       Else
           WQTY   = ([F:MKM]USEQTY * WCOEFF)
       Endif
       If WREPART + WQTY > [F:MKM]USEQTY
          WQTY    = [F:MKM]USEQTY - WREPART
       Endif
       Call QTEARR(WQTY,[F:MFM]STU) From TRTDIV
       If WQTY = 0 : Break : Endif
       [F:MFM]USEQTY -= WQTY
       Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
       If [F:MFM]USEQTY < 0 : Raz [F:MFM]USEQTY : Endif
       WREPART += WQTY
       If [F:MFM]MFMTRKFLG = 5 & [F:MFM]USEQTY < [F:MFM]RETQTY
                                 WMATCLENBR -= 1
                                [F:MFM]MFMTRKFLG = 4
       Endif
       If [F:MFM]USEQTY = 0
          If WPRN = 2 : [F:MFM]MFMTRKFLG = 3
          Else        : [F:MFM]MFMTRKFLG = 1
          Endif
          Raz [F:MFM]TRKFIRST, [F:MFM]TRKLAST
          Raz [F:MFM]TRKFIRSTC, [F:MFM]TRKLASTC
       Endif
       Case [F:MFM]MFMTRKFLG
            When 1,3 : [F:MFM]MATSTA = 1
            When 4   : [F:MFM]MATSTA = 2
            When 5   : [F:MFM]MATSTA = 3
       Endcase
#Mise à jour des allocs sur l'OF si qté prévue reste supérieure à la qté consommée
       If [F:MFM]RETQTY > [F:MFM]USEQTY & [F:MFM]ALLSTA > 1
          Gosub CREALL_OF
          If GOK < 1 : Break : Endif
       Endif
#mise à jour des qtés allouée et en rupture !!!!!
       If [F:MFM]ALLSTA > 1
           [F:MFM]ALLQTY += WWALLQTY
           [F:MFM]SHTQTY += WWSHTQTY
       Endif
#Mise à jour de l'encours
       If [F:MFM]MFGLIN <> 0
          Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
          If fstat : Raz [F:MFI] : Endif
       Else
          Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
          Read [F:MFI]MFI0 First
          If fstat : Raz [F:MFI] : Endif
          Filter [F:MFI]
       Endif
       Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
       If GOK < 1 : Break : Endif
#
       # 10.05 demande 32472
       WCUMMATSUI =   [F:MKM]CUMMATSUI
       WACTION = "A"

       #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
       If [F:MFI]ITMSTA < 3 &  [F:MFM]WGGSTA = 8
          If [F:MFM]WGGSTAAVS<>0
              [F:MFM]WGGSTA   = [F:MFM]WGGSTAAVS
          Else
              [F:MFM]WGGSTA   = 1
          Endif
       Elsif [F:MFI]ITMSTA = 3 & [F:MFM]WGGSTA <> 8
             [F:MFM]WGGSTAAVS = [F:MFM]WGGSTA
             [F:MFM]WGGSTA    = 8
       Endif
       #=========================================================================#

       Gosub BEFORE_REWRITE_MFM
       Rewrite [F:MFM]
       If fstat
          GOK = 0 : Call FSTA("MFM") From GLOCK : Break
       Endif
       #----- MISE à jour statistiques ligne matière -----#
       Call VALSTA("MFM",-1) From SUBPS2
       If GOK < 1 : Break : Endif
#MAJ entête d'OF ici si suivi multi-OF
# 09.06 demande37802 si modif des mvts de stock la maj de l'of se fait ailleurs
       If [F:MTK]MFGNUM = "" & GREP = "A"
            Readlock [F:MFG]MFG0 = [F:MKM]MFGNUM
            If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MKM]MFGNUM : Break
            Elsif fstat GOK=0  : Call RSTA("MFG",[F:MKM]MFGNUM) From GLOCK : Break
            Endif
            # 04.02 demande 14124
            Local File MFGPRN [MFP]
            WPRN = 1
            Read [F:MFP]MFP0 = [F:MFG]MFGNUM
            If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
            Close Local File [F:MFP]
            [F:MFG]MATCLENBR += WMATCLENBR
            If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&              [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&              [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
                                  # CCC (14/01/08) DM 44021
                                  #[F:MFG]TRKLAST = [F:MTK]MFGTRKDAT
                                  [F:MFG]MFGTRKFLG = 5
            Else                  [F:MFG]MFGTRKFLG = 4
                                   #Raz [F:MFG]TRKLAST
                                  Gosub MAJSTATUT
            Endif
            # CCC (14/01/08) DM 44021
            If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
                [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
            Endif
            If [F:MFG]TRKLASTC<date$
                [F:MFG]TRKLASTC  = date$
            Endif
            If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
                [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
            Endif
            If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
                [F:MFG]TRKFIRSTC = date$
            Endif
            Rewrite [F:MFG]
            If fstat
              GOK = 0 : Call FSTA("MFG") From GLOCK : Break
            Endif
            #----- MISE à jour statistiques entête OF -----#
            Call VALSTA("MFG",-1) From SUBPS2
            If GOK < 1 : Break : Endif
       Endif
    Next
    Filter [F:MFM]
    If GOK < 1 : Return : Endif
  Endif
  #----- MISE à jour statistiques ligne suivi matière -----#
  Call VALSTA("MKM",-1) From SUBPS2
  If GOK < 1 : Return : Endif
Endif

# Issue 74988 - 2011-09-01 by CCC : Suppression des sections analytiques liées au suivi
Delete [F:CAL] Where ABRFIC="MKM"
&                  & VCRNUM=[F:MKM]MFGTRKNUM
&                  & VCRLIN=[F:MKM]MATTRKLIN
Return


###############################################
#création de l'allocation de l'OF en suppression de suivi matière
#ou en création de suivi si dé-solde d'une matière et qté consommée < qté prévue
#ou en réintégration
$CREALL_OF
Local Decimal WALLQTY, WALLTYP, WSHTQTY
Local Integer LRET

Case [F:MFM]ALLSTA
    When 1:      WALLTYP = 1
    When 2,3:    WALLTYP = 1    # allocation globale
    When 4,5:    WALLTYP = 2    # allocation détaillée
Endcase

#si on alloue en création de suivi, cela veut dire qu'on vient de dé-solder une matière
#et qu'il reste de la qté à consommer. Donc on alloue pour la qté totale restant à consommer
#si on alloue en supp de suivi ou réintégration on alloue pour la qté du suivi annulé sauf si les allocs sont à 0
#Dans ce cas  on alloue pour la qté totale restant à consommer
If GREP = "C" | ([F:MFM]ALLQTY + [F:MFM]SHTQTY = 0)
    WALLQTY     = [F:MFM]RETQTY - [F:MFM]USEQTY
    Call QTEARR(WALLQTY,[F:MFM]STU) From TRTDIV
Else
    WALLQTY     =  WQTY
Endif
If WALLQTY<0 : WALLQTY=0 : Endif : # GH 31/03/2016 bug 115537 not to generate negative allocation
Call ALLOCATION("C",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
#If WRET <> 0 : GOK = 0 : Return :  Endif : # GH 16/10/12 bug 85239
If LRET <> 0 : GOK = 0 : Return :  Endif
WWALLQTY += WALLQTY
WWSHTQTY += WSHTQTY
# ajustement du statut allocation de la matière  03.05
Case [F:MFM]ALLSTA
    When 2,4 : If WWSHTQTY =  0 : [F:MFM]ALLSTA += 1 : Endif
    When 3,5 : If WWSHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
Endcase

# v6 affectations
Gosub MAJ_MTO_MFM From MFGMTOLIB

Return

###############################################
#Diminution de l'allocation en suppression de réintégration
$DIMALL_OF
Local Decimal WALLQTY, WALLTYP, WSHTQTY
Local Integer LRET

Case [F:MFM]ALLSTA
    When 1:      WALLTYP = 1
    When 2,3:    WALLTYP = 1    # allocation globale
    When 4,5:    WALLTYP = 2    # allocation détaillée
Endcase

WALLQTY     =  [F:MKM]USEQTY
If WALLQTY <> 0
    Call ALLOCATION("D",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
    #If WRET <> 0 : GOK = 0 : Return :  Endif : # GH 16/10/12 bug 85239
    If LRET <> 0 : GOK = 0 : Return :  Endif
Endif
WWALLQTY += WALLQTY
WWSHTQTY += WSHTQTY
Return


############################
$DECL_VAR
#déclaration des variables utiles en  création et en annulation de suivi matière
Local Integer WRET,WALL,WTYP,WWIN
Local Decimal WCLE,WQTYP,WQTY,WCHR,WSEQ,WSTOCOU,WLIN,WQTYSTU,WQTYRUP,WQTYRUPP
Local Char WFCY(GLONFCY),WNUM(GLONVCR),WITM(GLONITM),WPRE, WLOC(GLONLOC)
Local Date WDAT,WDTE
Local Decimal WWALLQTY,WWSHTQTY
Return


################################################################################
# ancien TRT15
$TRT_MAJ_DOCUMENT
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR,WNBITM,WSOLDE
Local Decimal WCPLQTY,WREJQTY,WQUAQTY,WMFIQTY
Local Decimal WQTE
Local Char    WTRSNUM(GLONTRS)
Local Integer WPRN
Local Char    WACTION
Local Integer ERROR
If dim(NOL)<0 :  Local Shortint NOL: Endif
If dim(TRTLIG)<0 Local Char    TRTLIG(1) : Endif
WREJQTY = [M:STW]RRRQTY
WQUAQTY = [M:STW]QQQQTY

NOL=LLIGDOC
nolign=NOL+1
Case LTYP
    When 15 :
        WPRN = 1
        If [M:MTK2]PRODTYP(NOL) = 1
            Local File MFGPRN [MFP]
            Read [F:MFP]MFP0 = [M:MTK2]MFGNUMIT(NOL)
            If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
            Close Local File [F:MFP]
        Endif

        WCPLQTY       =  LQTYSTU - [M:MTK2]CPLQTY(NOL)
        #Issue X3-52493 03/10/2017 by GEBIL : Problem in deletion of manufacturing line using WO tunnel
        # mise à jour de la ligne écran
        #Gosub MAJ_LIG_MTK From MTKLIB
        GFONC1 = "GESMTK"

        # mise à jour de la ligne écran
        Gosub MAJ_LIG_MTK From MTKLIB

        GFONC1 = SAVFONC1

        # mise à jour des fichiers
        #si demande de suppression de la ligne
        If [M:MTK2]UOMCPLQTY(NOL) = 0
            WNBITM = [F:MTK]NBRITM - 1
            # GH 07/02/2014 bug 94071
            #If [F:MTK]NBROPE = 0 & WNBITM = 0 & [F:MTK]NBRMAT = 0
            #    Call ERREUR(mess(87,193,1)) From GESECRAN
            #    GOK = 0
            #    Return
            #Endif
            Readlock [F:MKI]MKI0 = [M:MTK0]MFGTRKNUM;[M:MTK2]ITMTRKLIN(NOL)
            If fstat=1  GOK=-1 : GLOCK="$MFGITMTRK"-[M:MTK2]ITMREF(NOL) :  Return
            Elsif fstat GOK=0  : Call RSTA("MKI",[M:MTK2]ITMREF(NOL)) From GLOCK :  Return
            Endif
            # CCC (2010-01-25) Bug 61055 : ces variables sont calculées par cumul dans ANNULE_SUIVITM dans le cas de la suppression totale du suivi
            # => il faut faire un RAZ ici
            Raz WCPLQTY,WREJQTY,WQUAQTY
            Gosub ANNULE_SUIVITM
            If GOK < 1 :  Return : Endif
            Delete [F:MKI]
            If fstat : GOK = 0 :  Return : Endif
            Readlock [F:MTK]MTK0 = [M:MTK0]MFGTRKNUM
            If fstat=1  GOK=-1 : GLOCK="$MFGHEADTRK"-[M:MTK0]MFGTRKNUM :  Return
            Elsif fstat GOK=0  : Call RSTA("MTK",[M:MTK0]MFGTRKNUM) From GLOCK :  Return
            Endif
            [F:MTK]NBRITM -= 1
            Rewrite [F:MTK]
            If fstat
               GOK = 0 : Call FSTA("MTK") From GLOCK :  Return
            Endif
            # X3-80367 - STWIL - If we have deleted the production tracking delete this document in any non-conformances
            If func AFNC.ACTIV ("NCS")
                [L]ERROR = func NCSDOCHDR_CSTD.DELETE_NON_CONFORMANCE_DOCUMENTS (3, [M:MTK0]MFGTRKNUM, [M:MTK2]ITMTRKLIN(NOL))
                If [L]ERROR
                    GMESSAGE = mess(47,3702,1)
                    OK = 0
                    GOK = 0
                    Return
                Endif
            Endif
        Else
        #modification enregistrement suivi decl prod
            Readlock [F:MKI]MKI0 = [M:MTK0]MFGTRKNUM;[M:MTK2]ITMTRKLIN(NOL)
            If fstat=1  GOK=-1 : GLOCK="$MFGITMTRK"-[M:MTK2]ITMREF(NOL) :  Return
            Elsif fstat GOK=0  : Call RSTA("MKI",[M:MTK2]ITMREF(NOL)) From GLOCK :  Return
            Endif
                # Désallocation de la commande de vente associée
            If [F:MKI]PRODTYP = 1
                #----- Mise à jour statistiques ligne suivi article lancé -----#
                If [M:MTK2]PRODTYP(NOL) = 1
                      Call VALSTA("MKI",-1) From SUBPS2
                      If GOK < 1 :  Return : Endif
                Endif
            Endif
            If [F:MKI]UOMSTUCOE = 0 : [F:MKI]UOMSTUCOE = 1 : Endif
            [F:MKI]UOMCPLQTY = [M:MTK2]CPLQTY(NOL) / [F:MKI]UOMSTUCOE
            Call QTEARR([F:MKI]UOMCPLQTY,[F:MKI]UOM) From TRTDIV
            [F:MKI]CPLQTY     = [M:MTK2]CPLQTY(NOL)
            [F:MKI]UPDDAT = date$
            [F:MKI]UPDUSR = GUSER
            [F:MKI]EXPNUM = [C]EXPORT
            #point d'entrée  pour mise à jour  spécifique   09.04 demande 25251
            WACTION = "M"
            GPOINT = "MKIMAJ" : Gosub ENTREE From EXEFNC
            #
            Rewrite [F:MKI]
            If fstat
               GOK = 0 : Call FSTA("MKI") From GLOCK :  Return
            Endif

             If [M:MTK2]PRODTYP(NOL) = 1
            #----- Mise à jour statistiques ligne suivi article lancé -----#
               Call VALSTA("MKI",1) From SUBPS2
               If GOK < 1 :  Return : Endif
            #maj article lancé
                Readlock [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
                If fstat=1  GOK=-1 : GLOCK="$MFGITM"-[F:MKI]ITMREF :  Return
                Elsif fstat GOK=0  : Call RSTA("MFI",[F:MKI]ITMREF) From GLOCK :  Return
                Endif
                # 09.01 demande 10365
                WMFIQTY = [F:MFI]CPLQTY
            #----- Mise à jour statistiques ligne article lancé -----#
                Call VALSTA("MFI",-1) From SUBPS2
                If GOK < 1 :  Return : Endif
                WSOLDE            = [F:MFI]MFITRKFLG
                [F:MFI]CPLQTY    += WCPLQTY
                Call QTEARR([F:MFI]CPLQTY,[F:MFI]STU) From TRTDIV
                # attention dans ce cas les quantités représentent le delta entre ancienne et nouvelle qté.
                # ce delta est signé (il peut être négatif si on a diminué les qtés)
                [F:MFI]REJCPLQTY += WREJQTY
                Call QTEARR([F:MFI]REJCPLQTY,[F:MFI]STU) From TRTDIV
                [F:MFI]QUACPLQTY += WQUAQTY
                Call QTEARR([F:MFI]QUACPLQTY,[F:MFI]STU) From TRTDIV

                [F:MFI]RMNEXTQTY = [F:MFI]EXTQTY - [F:MFI]CPLQTY
                If [F:MFI]RMNEXTQTY < 0 : [F:MFI]RMNEXTQTY = 0 : Endif
                If [F:MFI]CPLQTY >= [F:MFI]EXTQTY & [F:MFI]MFITRKFLG <> 5
                                                    [F:MFI]MFITRKFLG = 5
                                                    # 12.02 demande 16844
                                                    GPOINT = "MFICLEMAJ"
                                                    Gosub  ENTREE From EXEFNC
                                                    If [F:MFI]MFITRKFLG = 5
                                                        # CCC (14/01/08) DM 44021
                                                        #[F:MFI]TRKLAST = [M:MTK0]MFGTRKDAT
                                                        WITMCLENBR+=1
                                                    Endif
                Elsif [F:MFI]CPLQTY < [F:MFI]EXTQTY & [F:MFI]MFITRKFLG = 5
                                                   [F:MFI]MFITRKFLG = 4
                                                   # sr 12.02 demande 16844
                                                   GPOINT = "MFICLEMAJ"
                                                   Gosub  ENTREE From EXEFNC
                                                   If [F:MFI]MFITRKFLG = 4
                                                       # CCC (14/01/08) DM 44021
                                                       #Raz [F:MFI]TRKLAST
                                                       WITMCLENBR -= 1
                                                   Endif
                Endif
                # CCC (14/01/08) DM 44021
                If [F:MFG]TRKLAST<[F:MTK]MFGTRKDAT
                    [F:MFG]TRKLAST   = [F:MTK]MFGTRKDAT
                Endif
                If [F:MFG]TRKLASTC<date$
                    [F:MFG]TRKLASTC  = date$
                Endif
                If [F:MFG]TRKFIRST>[F:MTK]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
                    [F:MFG]TRKFIRST = [F:MTK]MFGTRKDAT
                Endif
                If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
                    [F:MFG]TRKFIRSTC = date$
                Endif

                If    [F:MFI]MFITRKFLG = 4 : [F:MFI]ITMSTA = 2
                Elsif [F:MFI]MFITRKFLG = 5 : [F:MFI]ITMSTA = 3
                Endif
                Rewrite [F:MFI]
                If fstat
                   GOK = 0 : Call FSTA("MFI") From GLOCK :  Return
                Endif
            #Maj encours et mvts article

            #Si la ligne était soldée et qu'elle le reste on ne touche à rien
                If WSOLDE <> 5 | [F:MFI]MFITRKFLG <> 5
                    # mise à jour des affectations si augmentation
                    If WCPLQTY > 0
                       Call MAJ_MTO("C", WCPLQTY)   From MTKMTOLIB
                       If GOK<1 : Return : Endif : # GH 05/09/12 bug 84291
                    Endif

                    Gosub TRT_WIP
                    If GOK < 1 :  Return : Endif
            #Si la ligne était soldée et qu'on la désolde il faut d'abord réajuster l'en commande
                    If WSOLDE = 5 & [F:MFI]MFITRKFLG < 5
                          Local Integer STA : STA = 0
                          Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
                          If GOK <> 1 | STA > 1 : Return : Endif
                # 09.01 demande 10365
                          Update [ITV] Where ITMREF = [F:MFI]ITMREF & STOFCY = [F:MFI]MFGFCY
&                              With ORDSTO += ([F:MFI]EXTQTY - WMFIQTY)
                    Endif
                    If WCPLQTY <> 0
                       Gosub TRT_MVT
                       If GOK < 1 :  Return : Endif
                       # mise à jour des affectations si diminution
                       If WCPLQTY < 0 : Gosub MAJ_MTO_MFI From MFGMTOLIB : Endif
                    Endif
                Endif
            #----- Mise à jour statistiques ligne article lancé -----#
                 Call VALSTA("MFI",1) From SUBPS2
                 If GOK < 1 :   Return : Endif
            Endif
        Endif
        If [M:MTK2]PRODTYP(NOL) = 1
            #gestion sous-produits  05 00
            If [F:MFI]ITMTYP = 2
               Raz WCPLQTY
               Raz WREJQTY
               Raz WQUAQTY
            Endif
            If GOK = 1
            Call MAJMFGHEAD([F:MKI]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN)
            Endif
            If GOK < 1 :  Return : Endif
        Endif
    When 12 :
Endcase

# GH 07/02/2014 bug 94071
If GOK=1 & [F:MTK]NBROPE=0 & [F:MTK]NBRITM=0 & [F:MTK]NBRMAT=0
   Local Char PARAM2(10)(1), SAVREP(1)
   SAVREP=GREP : GREP="A" : : # GH 28/10/2014 bug 101284
   [L]OK=-9 : Raz [L]PARAM2 : # pour ne pas demander de confirmation
   Call ANUCOD("-MTK",[F:MTK]MFGTRKNUM,[L]PARAM2,[L]OK) From GOBJACT : # pas de boite [VLC]
   GREP=SAVREP
Endif

#
#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITMTK = 1
Endif

Return

###############################################
# ancien TRT12
$APRES_STOSOM
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - etc ...
#
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOM]PECQTY    contient la quantité US sortie
#   [M:SOM]PECQTYACT contient la quantité en UA sortie
#   [M:SOM]SHTQTY    contient la quantité manquante
#-----------------------------------------------------------------------#
###############################################
Local Integer    WNBMAT
Local Integer    WOPECLENBR, WITMCLENBR, WMATCLENBR,WALLTYP
Local Decimal    LQTYSTU
Local Decimal    WCPLQTY,WREJQTY,WQUAQTY,WUSEQTY,WALLQTY,WSHTQTY,WCOEFF,WQTY,WREPART
Gosub DECL_VAR
Local Char       WTRSNUM
Local Integer    WPRN
Local Char       WACTION
# 10.05 demande 32472
Local Integer WCUMMATSUI

# On n'a pas enregistré
If WGENR<>1 Return Endif

WPRN = 1
# 04.02 demande 14124
If [M:MTK3]MATTYP(LNOL) = 1
    Local File MFGPRN [MFP]
    Read [F:MFP]MFP0 = [M:MTK3]MFGNUMMA(LNOL)
    If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
    Close Local File [F:MFP]
Endif

# Quantité traitée
LQTYSTU = [M:SOM]PECQTYACT + [M:SOM]SHTQTY

#si demande de suppression de la ligne
If LQTYSTU = 0
    Local Integer WNBR
    WNBMAT = [F:MTK]NBRMAT - 1
    # GH 07/02/2014 bug 94071
    #If [F:MTK]NBROPE = 0 & WNBMAT = 0 & [F:MTK]NBRITM = 0
    #    Call ERREUR(mess(87,193,1)) From GESECRAN
    #    GOK = 0 : LRET = 1
    #    Return
    #Endif
    Readlock [F:MKM]MKM0 = [M:MTK0]MFGTRKNUM;[M:MTK3]MATTRKLIN(LNOL)
    If fstat=1  GOK=-1 : GLOCK="$MFGMATTRK"-[M:MTK3]MATITMREF(LNOL) : LRET = 1 : Return
    Elsif fstat GOK=0  : Call RSTA("MKM",[M:MTK3]MATITMREF(LNOL)) From GLOCK : LRET = 1 : Return
    Endif
    Gosub ANNULE_SUIVMAT
    If GOK < 1 : LRET = 1 : Return : Endif
    Delete [F:MKM]
    If fstat : GOK = 0 : LRET = 1 : Return : Endif
    Readlock [F:MTK]MTK0 = [M:MTK0]MFGTRKNUM
    If fstat=1  GOK=-1 : GLOCK="$MFGHEADTRK"-[M:MTK0]MFGTRKNUM : LRET = 1 : Return
    Elsif fstat GOK=0  : Call RSTA("MTK",[M:MTK0]MFGTRKNUM) From GLOCK : LRET = 1 : Return
    Endif
    [F:MTK]NBRMAT -= 1
    Rewrite [F:MTK]
    If fstat
       GOK = 0 : Call FSTA("MTK") From GLOCK : LRET = 1 : Return
    Endif
Else
#modification enregistrement suivi matière
    Readlock [F:MKM]MKM0 = [M:MTK0]MFGTRKNUM;[M:MTK3]MATTRKLIN(LNOL)
    If fstat=1  GOK=-1 : GLOCK="$MFGMATTRK"-[M:MTK3]MATITMREF(LNOL) : LRET = 1 : Return
    Elsif fstat GOK=0  : Call RSTA("MKM",[M:MTK3]MATITMREF(LNOL)) From GLOCK : LRET = 1 : Return
    Endif
    If [F:MKM]MATTYP = 1
#----- MISE à jour statistiques ligne suivi matière -----#
         Call VALSTA("MKM",-1) From SUBPS2
         If GOK < 1 : LRET = 1 : Return : Endif
    Endif
    WUSEQTY       = LQTYSTU - [F:MKM]USEQTY
    [F:MKM]USEQTY = LQTYSTU
    [F:MKM]UPDDAT = date$
    [F:MKM]UPDUSR = GUSER
    [F:MKM]EXPNUM = [C]EXPORT
    #point d'entrée  pour mise à jour  spécifique   09.04 demande 25251
    WACTION = "M"
    GPOINT = "MKMMAJ" : Gosub ENTREE From EXEFNC
    #
    Rewrite [F:MKM]
    If fstat
       GOK = 0 : Call FSTA("MKM") From GLOCK : LRET = 1 : Return
    Endif
    If [F:MKM]MATTYP = 1 & [F:MKM]MFMITMREF <> ""
    #----- MISE à jour statistiques ligne suivi matière -----#
        Call VALSTA("MKM",1) From SUBPS2
        If GOK < 1 : LRET = 1 : Return : Endif
        If [F:MKM]CUMMATSUI = 1
           Raz WQTY,WREPART
           # 10.02 Performances
           For [MFM]MFM3 Where MFGNUM = [F:MKM]MFGNUM & ITMREF = [F:MKM]MFMITMREF &
&                                    BOMOPE = [F:MKM]OPENUM & MATSTA < 4
                   Readlock [F:MFM]Curr
                   If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MKM]MFMITMREF : Break
                   Elsif fstat GOK=0  : Call RSTA("MFM",[F:MKM]MFMITMREF) From GLOCK : Break
                   Endif
                   #----- MISE à jour statistiques ligne matière -----#
                   Call VALSTA("MFM",-1) From SUBPS2
                   If GOK < 1 : LRET = 1 : Break : Endif
                   WCOEFF = ([F:MFM]RETQTY/[F:MKM]MFMEXTQTY)
                   # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                   # Ce sont les quantités qui sont arrondies
                   ## 01.02 demande 12597
                   #WCOEFF = arr(WCOEFF,0.00000001)
                   WQTY   = WUSEQTY * WCOEFF
                   If WREPART + WQTY > WUSEQTY
                      WQTY  = WUSEQTY - WREPART
                   Endif
                   Call QTEARR (WQTY,[F:MFM]STU) From TRTDIV
                   If WQTY = 0 : Break : Endif
                   [F:MFM]USEQTY += WQTY
                   WREPART += WQTY
                   Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
                   Case [F:MFM]ALLSTA
                        When 1:      WALLTYP = 0    # pas d'allocation
                        When 2,3:    WALLTYP = 1    # allocation globale
                        When 4,5:    WALLTYP = 2    # allocation détaillée
                   Endcase
                   If WALLTYP <> 0
                       #si qté supérieure à qté prévue, on supprime toutes les allocs restantes
                       If WUSEQTY >= [F:MFM]RETQTY
                            Call ALLOCATION("A",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                            If LRET <> 0 : GOK = 0 : Break : Endif
                        #si qté consommée supérieure à ancienne qté consommée, on diminue les allocs
                       Elsif WUSEQTY > 0
                           WALLQTY = USEQTY
                           WSHTQTY = 0
                           Call ALLOCATION("D",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                           If LRET <> 0 : GOK = 0 : Break : Endif
                           [F:MFM]ALLQTY -= WALLQTY
                           [F:MFM]SHTQTY -= WSHTQTY
                #si qté consommée inférieure à ancienne qté consommée, on augmente les allocs
                       Else
                           WALLQTY = abs(WUSEQTY)
                           # 11.02 demande 16655
                           If WALLQTY > [F:MFM]RETQTY - [F:MFM]USEQTY - ([F:MFM]ALLQTY + [F:MFM]SHTQTY)
                              WALLQTY = [F:MFM]RETQTY - [F:MFM]USEQTY - ([F:MFM]ALLQTY + [F:MFM]SHTQTY)
                           Endif
                           WSHTQTY = 0
                           If WALLQTY > 0
                               Call ALLOCATION("C",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                               If LRET <> 0 : GOK = 0 : Break : Endif
                               [F:MFM]ALLQTY += WALLQTY
                               [F:MFM]SHTQTY += WSHTQTY
                           Endif
                       Endif
                   Endif
                   If [F:MFM]USEQTY >= [F:MFM]RETQTY & [F:MFM]MFMTRKFLG <> 5
                                           [F:MFM]MFMTRKFLG = 5
                                           Gosub SUPALL_OF
                                           If GOK < 1 : LRET = 1 : Break : Endif
                                           Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                                           WMATCLENBR+=1
                   Elsif [F:MFM]USEQTY < [F:MFM]RETQTY & [F:MFM]MFMTRKFLG = 5
                                           [F:MFM]MFMTRKFLG = 4
                                           WMATCLENBR    -= 1
                   Endif
                   If    [F:MFM]MFMTRKFLG = 4 : [F:MFM]MATSTA = 2
                   Elsif [F:MFM]MFMTRKFLG = 5 : [F:MFM]MATSTA = 3
                   Endif
                   # CCC (14/01/08) DM 44021
                   #If [F:MFM]TRKFIRST = "00/00/00" : [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT : Endif
                   #[F:MFM]TRKLAST = [M:MTK0]MFGTRKDAT
                   If [F:MFG]TRKLAST<[M:MTK0]MFGTRKDAT
                       [F:MFG]TRKLAST   = [M:MTK0]MFGTRKDAT
                   Endif
                   If [F:MFG]TRKLASTC<date$
                       [F:MFG]TRKLASTC  = date$
                   Endif
                   If [F:MFG]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
                       [F:MFG]TRKFIRST = [M:MTK0]MFGTRKDAT
                   Endif
                   If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
                       [F:MFG]TRKFIRSTC = date$
                   Endif

                   If [F:MFM]MFGLIN <> 0
                      Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
                      # llc 05.02 cohérence
                      If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : LRET = 1 : Break : Endif
                   Else
                       Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
                       Read [F:MFI]MFI0 First
                       Filter [F:MFI]
                       # llc 05.02 cohérence
                       If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : LRET = 1 : Break : Endif
                   Endif
                   Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
                   # 10.05 demande 32472
                   WCUMMATSUI =   [F:MKM]CUMMATSUI
                   WACTION = "M"
                   Gosub BEFORE_REWRITE_MFM
                   Rewrite [F:MFM]
                   If fstat
                       GOK = 0 : Call FSTA("MFM") From GLOCK : LRET = 1 : Break
                   Endif
                   #----- MISE à jour statistiques ligne matière -----#
                   Call VALSTA("MFM",1) From SUBPS2
                   If GOK < 1 : Break : Endif
            Next
         Else
            Readlock [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]MFMITMREF
            If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MKM]MFMITMREF : LRET = 1 : Return
            Elsif fstat GOK=0  : Call RSTA("MFM",[F:MKM]MFMITMREF) From GLOCK : LRET = 1 : Return
            Endif
            #----- MISE à jour statistiques ligne matière -----#
            Call VALSTA("MFM",-1) From SUBPS2
            If GOK < 1 : LRET = 1 : Return : Endif
            [F:MFM]USEQTY += WUSEQTY
            Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
            Case [F:MFM]ALLSTA
                When 1:      WALLTYP = 0    # pas d'allocation
                When 2,3:    WALLTYP = 1    # allocation globale
                When 4,5:    WALLTYP = 2    # allocation détaillée
            Endcase
            If WALLTYP <> 0
                #si qté supérieure à qté prévue, on supprime toutes les allocs restantes
                If WUSEQTY >= [F:MFM]RETQTY
                    Call ALLOCATION("A",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                    If LRET <> 0 : GOK = 0 : Return : Endif
                #si qté consommée supérieure à ancienne qté consommée, on diminue les allocs
                Elsif WUSEQTY > 0
                    WALLQTY = USEQTY
                    WSHTQTY = 0
                    Call ALLOCATION("D",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                    If LRET <> 0 : GOK = 0 : Return : Endif
                    [F:MFM]ALLQTY -= WALLQTY
                    [F:MFM]SHTQTY -= WSHTQTY
                #si qté consommée inférieure à ancienne qté consommée, on augmente les allocs
                Else
                    WALLQTY = abs(WUSEQTY)
                    # 11.02 demande 16655
                    If WALLQTY > [F:MFM]RETQTY - [F:MFM]USEQTY - ([F:MFM]ALLQTY + [F:MFM]SHTQTY)
                       WALLQTY = [F:MFM]RETQTY - [F:MFM]USEQTY - ([F:MFM]ALLQTY + [F:MFM]SHTQTY)
                    Endif
                    WSHTQTY = 0
                    If WALLQTY > 0
                        Call ALLOCATION("C",WALLTYP,WALLQTY,WSHTQTY,LRET) From MFGALL
                        If LRET <> 0 : GOK = 0 : Return : Endif
                        [F:MFM]ALLQTY += WALLQTY
                        [F:MFM]SHTQTY += WSHTQTY
                    Endif
                Endif
            Endif
            If [F:MFM]USEQTY >= [F:MFM]RETQTY & [F:MFM]MFMTRKFLG <> 5
                                                [F:MFM]MFMTRKFLG = 5
                                                Gosub SUPALL_OF
                                                If GOK < 1 : LRET = 1 : Return : Endif
                                                Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                                                WMATCLENBR+=1
            Elsif [F:MFM]USEQTY < [F:MFM]RETQTY & [F:MFM]MFMTRKFLG = 5
                                                  [F:MFM]MFMTRKFLG = 4
                                                  WMATCLENBR    -= 1
            Endif
            If    [F:MFM]MFMTRKFLG = 4 : [F:MFM]MATSTA = 2
            Elsif [F:MFM]MFMTRKFLG = 5 : [F:MFM]MATSTA = 3
            Endif
            # CCC (14/01/08) DM 44021
            #If [F:MFM]TRKFIRST = "00/00/00" : [F:MFM]TRKFIRST = [M:MTK0]MFGTRKDAT : Endif
            #If [F:MFM]MFMTRKFLG = 5 : [F:MFM]TRKLAST = [M:MTK0]MFGTRKDAT : Endif
            If [F:MFG]TRKLAST<[M:MTK0]MFGTRKDAT
                [F:MFG]TRKLAST   = [M:MTK0]MFGTRKDAT
            Endif
            If [F:MFG]TRKLASTC<date$
                [F:MFG]TRKLASTC  = date$
            Endif
            If [F:MFG]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
                [F:MFG]TRKFIRST = [M:MTK0]MFGTRKDAT
            Endif
            If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
                [F:MFG]TRKFIRSTC = date$
            Endif

            If [F:MFM]MFGLIN <> 0
               Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
               # llc 05.02 cohérence
               If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : LRET = 1 : Return : Endif
            Else
               Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
               Read [F:MFI]MFI0 First
               Filter [F:MFI]
               # llc 05.02 cohérence
               If fstat : GOK=0: Call RSTA("MFI",num$([M:MTK3]MFGLIN(nolign-1))) From GLOCK : LRET = 1 : Return : Endif
            Endif
            Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM

            # affectations
            Gosub MAJ_MTO_MFM From MFGMTOLIB

            # 10.05 demande 32472
            WCUMMATSUI =   [F:MKM]CUMMATSUI
            WACTION = "M"
            Gosub BEFORE_REWRITE_MFM
            Rewrite [F:MFM]
            If fstat
               GOK = 0 : Call FSTA("MFM") From GLOCK : LRET = 1 : Return
            Endif
            #----- MISE à jour statistiques ligne matière -----#
            Call VALSTA("MFM",1) From SUBPS2
            If GOK < 1 : LRET = 1 : Return : Endif
        Endif
    Endif
Endif
If GOK < 1 : LRET = 1 : Return : Endif
If [F:MKM]MATTYP = 1 & [F:MKM]MFMITMREF <> ""
    Call MAJMFGHEAD([F:MKM]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN)
    If GOK < 1 : LRET = 1 : Return : Endif
Endif

# GH 20/02/2014 bug 94071 # si la transaction est OK, un RELIT est effectué, sinon ne pas toucher à l'écran des matières
# Maj des zones écran pour réaffichage
#If LQTYSTU=0
#   Dela LNOL,1,[M:MTK3]NBMAT-1 [M:MTK3]NBMAT
#   [M:MTK3]NBMAT -= 1
#Else
#   [M:MTK3]USEQTY(LNOL) = [F:MKM]USEQTY
#Endif

# GH 07/02/2014 bug 94071
If GOK=1 & [F:MTK]NBROPE=0 & [F:MTK]NBRITM=0 & [F:MTK]NBRMAT=0
   Local Char PARAM2(10)(1), SAVREP(1)
   SAVREP=GREP : GREP="A" : : # GH 28/10/2014 bug 101284
   [L]OK=-9 : Raz [L]PARAM2 : # pour ne pas demander de confirmation
   Call ANUCOD("-MTK",[F:MTK]MFGTRKNUM,[L]PARAM2,[L]OK) From GOBJACT : # pas de boite [VLC]
   GREP=SAVREP
Endif

#
#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITMTK = 1
Endif
Return

############################
# 10.05 demande 32472
$BEFORE_REWRITE_MFM
GPOINT = "BEFREWMFM" : Gosub ENTREE From EXEFNC
Return

