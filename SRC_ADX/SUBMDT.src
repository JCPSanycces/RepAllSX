#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################################################
# Updates:
# 2018-08-20 DNE X3-102365
#

Raz GPILOBJ
Call OBJET("MDT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "RAZDUP"       : Gosub RAZDUP
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "MODIF"        : Gosub MODIF
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "EXEBOUT"      : Gosub EXEBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "ABANDON"      : Gosub ABANDON
 When "SEL_LISTE"    : If COUZON="IBACOD" : Gosub SELIBACOD : Endif
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "AB2_NBLIG"    : Gosub AB2_NBLIG
 When "BB2_NBLIG"    : Gosub BB2_NBLIG
Endcase
Return

$OUVRE
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY]  : Endif
If !clalev([F:TCA]) : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:BID]) : Local File BID        [BID]  : Endif
If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY]  : Endif
If !clalev([F:HMDT]): Local File HISTOMDT   [HMDT] : Endif
If !clalev([F:ADI]) : Local File ATABDIV    [ADI]  : Endif
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH]  : Endif

Local Char    MESSA(100)
Local Integer STAT
Local Char    TMPTXT(34) : # IBACOD reconstructed from the BID record
Local Integer VALOK      : # Answer of the yes/no question
Local Char    VALPAR(10) : # Value of the OPTBICSTR parameter
Local Date    DATBICSTR  : # Stores OPTBICSTR in a date variable
Local Integer OPTBICSTR  : # Indicates if the BICCOD is optional(=1) or not
Return

$LIENS
Call PARAML([M:MDT0]CPY, "OPTBICSTR", VALPAR) From ADOVAL
DATBICSTR = VALPAR
If date$>=DATBICSTR & DATBICSTR<>[0/0/0]
 OPTBICSTR = 1
Else
 OPTBICSTR = 0
Endif

# Load read-only fields with information stored in other tables
Call LEC_CPY([M:MDT0]CPY) From CPTLEC
[M:MDT1]SCINUM = [F:CPY]SCINUM
Affzo [M:MDT1]SCINUM

If [M:MDT1]CPYADD<>""
 Read [F:BPA]BPA0 = 2;[M:MDT0]CPY;[M:MDT1]CPYADD
 If !fstat : [M:MDT1]CPYADDDES = [F:BPA]BPADES : Affzo [M:MDT1]CPYADDDES : Endif
Endif
If [M:MDT1]BPCADD<>""
 Read [F:BPA]BPA0 = 1;[M:MDT1]BPCNUM;[M:MDT1]BPCADD
 If !fstat : [M:MDT1]BPCADDDES = [F:BPA]BPADES : Affzo [M:MDT1]BPCADDDES : Endif
Endif

# Enable/disable fields
If find([M:MDT1]STA, 1, 2, 3)
 Actzo [M:MDT0]DES
 Actzo [M:MDT1]ACS, CPYADD, BPCADD, BICCOD, IBACOD, FNLDBT, UDLCON
 If [M:MDT1]PAYTYP=1 : Actzo [M:MDT1]FNLFLG : Else Grizo [M:MDT1]FNLFLG : Endif
 If [M:MDT1]FNLFLG=2 : Actzo [M:MDT1]PAYNBR : Elsif [M:MDT1]FNLFLG=1 or [M:MDT1]PAYTYP=2 : Grizo [M:MDT1]PAYNBR : Endif

 If [M:MDT1]STA=1
  Actzo [M:MDT0]CPY
  Actzo [M:MDT1]SIGDAT, TYP, PAYTYP, SIGCTY, SITNAM, SITFNC, BPCNUM
  If [M:MDT1]TYP=2 : Grizo [M:MDT1]MIGFLG Else Actzo [M:MDT1]MIGFLG : Endif
 Endif
Else
 Grizo [M:MDT0]DES
 Grizo [M:MDT1]ACS, CPYADD, BPCADD, BICCOD, IBACOD, FNLDBT, UDLCON, PAYNBR, FNLFLG
Endif

If [M:MDT1]STA=3 or find([M:MDT1]STA,1,2) and [M:MDT1]MAIMDTFLG=2 or [M:MDT1]STA>=4
 Grizo [M:MDT1]MAIMDTFLG
Else
 Actzo [M:MDT1]MAIMDTFLG
Endif

If [M:MDT1]STA<>1
 Grizo [M:MDT1]SIGDAT, TYP, PAYTYP, SIGCTY, SITNAM, SITFNC, BPCNUM, WIOFIRSEQ, MIGFLG, NTLMIGIDT
Else
 If [M:MDT1]PAYTYP=1
  Actzo [M:MDT1]WIOFIRSEQ
 Else
  Grizo [M:MDT1]WIOFIRSEQ
 Endif
Endif

If [M:MDT1]MIGFLG=2 and [M:MDT1]STA<>2 : Actzo [M:MDT1]NTLMIGIDT : Else Grizo [M:MDT1]NTLMIGIDT : Endif

# Load [MDT2] values
nolign = 1
For [HMDT] Where CPY=[M:MDT0]CPY and UMRNUM=[M:MDT0]UMRNUM
 [M:MDT2] = [F:HMDT]
 Call LEC_ADI("330",[F:HMDT]SEQTYP) From CPTLEC
 If !fstat
 [M:MDT2]CODSEQTYP(nolign-1) = [F:ADI]A1
  Call LECTEXTRA([M:MDT2]LIBSEQTYP(nolign-1),"ATABDIV","LNGDES","330",[F:ADI]CODE) From ATEXTRA
 Endif
 nolign += 1
 If nolign>dim([M:MDT2]AMT)
  Call MESSAGE(mess(26,100,1)) From GESECRAN
  Break
 Endif
Next
[M:MDT2]NBLIG = nolign-1
Return

$RAZDUP
GSOCIETE = [M:MDT0]CPY
Call LECTCA(3, OK) From SUBTCA
If [F:TCA]MANCOU(13)<>2
 Grizo [M:MDT0]UMRNUM
 Raz [M:MDT0]UMRNUM : Affzo [M:MDT0]UMRNUM
Endif
[M:MDT1]STA=1
Actzo [M:MDT0]DES
Actzo [M:MDT1]
If [M:MDT1]FNLFLG<>2 : Grizo [M:MDT1]PAYNBR : Endif
If [M:MDT1]TYP=2 : Grizo [M:MDT1]MIGFLG : Endif
If [M:MDT1]MIGFLG<>2 : Grizo [M:MDT1]NTLMIGIDT : Endif
If [M:MDT1]PAYTYP<>1 : Grizo [M:MDT1]FNLFLG, WIOFIRSEQ : Endif
Raz [M:MDT2]
Raz [M:MDT1]ENDDAT
# The BICCOD was changed in the BID of the customer.
# The mandate is not updated but it is duplicated without the right value of BICCOD.
For [BID] Where BPATYP=1 and BPANUM=[M]BPCNUM and BPAADD=[M]BPCADD
# 2018-08-20 DNE X3-102365
 Call CRE_IBAN( TMPTXT, func GET_ISO_3166_1_ALPHA2( [F:BID]CRY ), [F:BID]BICCOD,[F:BID]BIDNUM ) From SUBBID
# Call CRE_IBAN(TMPTXT, [F:BID]CRY, [F:BID]BICCOD,[F:BID]BIDNUM) From SUBBID
 If [M:MDT1]IBACOD=TMPTXT
  If [M:MDT1]BICCOD<>[F:BID]BICCOD : [M:MDT1]BICCOD = [F:BID]BICCOD : Endif
  Break
 Endif
Next
Affzo [M:MDT1]
Affzo [M:MDT2]
Return

$INICRE
GSOCIETE = [M:MDT0]CPY
Call LECTCA(3, OK) From SUBTCA
If [F:TCA]CODNUM(13)="" & [F:TCA]MANCOU(13)<>2
 GMESSAGE = mess(12,114,1)
 GOK=0 : Return
Elsif [F:TCA]CODNUM(13)<>""
 Call LEC_CPY([M:MDT0]CPY) From CPTLEC
 If [F:TCA]MANCOU(13)=1 or [M:MDT0]UMRNUM=""
  Call NUMERO([F:TCA]CODNUM(13), [F:CPY]MAIFCY, date$, [M:MDT1]BPCNUM, [F:MDT]UMRNUM, STAT) From SUBANM
  [M:MDT0]UMRNUM = [F:MDT]UMRNUM
  If GOK<0
   Return
  Elsif GOK<1 | STAT
   GOK=0
   If STAT
    # Problème lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    GMESSAGE=mess(104,117,1)-"("+[F:TCA]CODNUM(13)+") : "+MESSA
   Endif
   Return
  Endif
 Endif
Endif
Return

$CREATION
If [M:MDT1]MAIMDTFLG=2
 Update [MDT] Where CPY=[M]CPY and BPCNUM=[M:MDT1]BPCNUM and UMRNUM<>[M:MDT0]UMRNUM With MAIMDTFLG=1
 If fstat
  GOK=0 : Call RSTA("MDT", [M]CPY-[M]UMRNUM) From GLOCK
 Endif
Endif

## SDD : Amendment of the NNE : Update the HISTOAMD table
Local Char    V_FLDCOD(GLONAVA)(1..2)
Local Char    V_OLDFLD(50)(1..2)
Local Char    V_NEWFLD(50)(1..2)
Local Integer WRK1,WRK2 : # not useful for this amendement

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Raz V_FLDCOD, WRK1, WRK2

If [F:MDT]STA=1 and [F:MDT]MIGFLG=2 # Initial
 Call LEC_CPY([F:MDT]CPY) From CPTLEC
 If !fstat & mid$([F:CPY]SCINUM,8,6)<>[F:MDT]NTLMIGIDT
  V_FLDCOD(1) = "SCINUM"
  V_OLDFLD(1) = [F:MDT]NTLMIGIDT
  V_NEWFLD(1) = [F:CPY]SCINUM
  WRK2 = 9 :# Indicates that this amendment concerns NNE
  GOK = func AMENDEMENT([F:MDT]CPY,[F:MDT]UMRNUM,V_FLDCOD,V_OLDFLD,V_NEWFLD,0,WRK1,WRK2)
  If GOK<1 : Return : Endif
 Endif
Endif
Return

$VERIF_CRE
Filter [MDT] Where CPY=[M:MDT0]CPY and BPCNUM=[M:MDT1]BPCNUM and MAIMDTFLG=2
If rowcount([MDT])=0 : [M:MDT1]MAIMDTFLG=2 : Else [M:MDT1]MAIMDTFLG=1 : Endif
Affzo [M:MDT1]MAIMDTFLG
Filter [MDT]
Return


$VERIF_MOD
If [M:MDT1]STA=2
 If [M:MDT1]CPYADD="" or [M:MDT1]BPCADD="" or [M:MDT1]IBACOD="" : OK=0 : Return : Endif
Endif

Filter [MDT] Where UMRNUM<>[M:MDT0]UMRNUM and CPY=[M:MDT0]CPY and BPCNUM=[M:MDT1]BPCNUM and MAIMDTFLG=2
If rowcount([MDT])=0 & [M:MDT1]STA<>3 : [M:MDT1]MAIMDTFLG=2 : Affzo [M:MDT1]MAIMDTFLG : Endif
Filter [MDT]
Return


$AVANT_MODFIC
## SDD : Amendment : Update the HISTOAMD table
# BANUPD = 2 if the user answer yes it is a bank change
# BANUPD = 1 if the user answer no it is not a bank change

# Message 2 in PRD
# The user answers it is a bank change but the BICCOD was not changed.
# In AVANT_MODFIC to run this test even if it is an import.
If OPTBICSTR=1 & [F:MDT]BICCOD=[M:MDT1]BICCOD & [F:MDT]BICCOD<>"" & [M:MDT1]BICCOD<>""
&              & [M:MDT1]BANUPD=2 & ([M:MDT1]STA=2 | [M:MDT1]STA=3)
 GMESSAGE = mess(333,117,1)
 GOK = 0 : Return
Endif
# Message 5 in PRD
# The user answers it is not a bank change but the BICCOD was changed.
If OPTBICSTR=1 & [F:MDT]BICCOD<>[M:MDT1]BICCOD & [F:MDT]BICCOD<>"" & [M:MDT1]BICCOD<>""
&              & [M:MDT1]BANUPD=1 & ([M:MDT1]STA=2 | [M:MDT1]STA=3)
 GMESSAGE = mess(337,117,1)
 GOK = 0 : Return
Endif

Local Char    V_FLDCOD(GLONAVA)(1..2)
Local Char    V_OLDFLD(50)(1..2)
Local Char    V_NEWFLD(50)(1..2)
Local Integer WRK1,WRK2 : # not useful for this amendement
Local Integer BICONLY   : # BICCOD was changed but not the IBACOD. Update BICCOD amendement only

If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:HAM]) : Local File HISTOAMD [HAM] : Endif

Raz V_FLDCOD, WRK1, WRK2, BICONLY

Case [M:MDT1]STA
  When 1 # Initial
   Call LEC_CPY([M:MDT0]CPY) From CPTLEC
   If [M:MDT1]MIGFLG=2 # Migration ticked
    If [M:MDT1]NTLMIGIDT<>[F:MDT]NTLMIGIDT : # NNE modified
     # The NNE entered is not encapsulated in [F:CPY]SCINUM
     If mid$([F:CPY]SCINUM,8,6)<>[M:MDT1]NTLMIGIDT
      V_FLDCOD(1) = "SCINUM"
      V_OLDFLD(1) = [M:MDT1]NTLMIGIDT
      V_NEWFLD(1) = [F:CPY]SCINUM
      WRK2 = 9 :# Indicates that this amendment concerns NNE
      GOK = func AMENDEMENT([M:MDT0]CPY,[M:MDT0]UMRNUM,V_FLDCOD,V_OLDFLD,V_NEWFLD,0,WRK1,WRK2)
      If GOK<1 : Return : Endif
     # NNE is encapsulated but the previous NNE wasn't encapsulated in [F:CPY]SCINUM. A recording exists for this previous NNE
     # This record must be deleted
     Elsif mid$([F:CPY]SCINUM,8,6)<>[F:MDT]NTLMIGIDT
      Delete [HAM]HAM0=[M:MDT0]CPY;[M:MDT0]UMRNUM;"SCINUM";""
      If fstat=1 : GOK=-1 : Return : Endif
     Endif
    Endif
   Elsif [M:MDT1]MIGFLG<>2 & [F:MDT]MIGFLG=2 & mid$([F:CPY]SCINUM,8,6)<>[F:MDT]NTLMIGIDT:# Migration unticked
    Delete [HAM]HAM0=[M:MDT0]CPY;[M:MDT0]UMRNUM;"SCINUM";""
    If fstat=1 : GOK=-1 : Return : Endif
   Endif
  When 2,3 # Adjourned,validated
   If [M:MDT1]IBACOD<>[F:MDT]IBACOD
    V_FLDCOD(1) = "IBACOD"
    V_OLDFLD(1) = evalue("[F:MDT]"+V_FLDCOD(1))
    V_NEWFLD(1) = evalue("[M:MDT1]"+V_FLDCOD(1))
   Endif
   If !OPTBICSTR
    If [M:MDT1]BICCOD<>[F:MDT]BICCOD
     Read [HAM]HAM0=[M:MDT0]CPY;[M:MDT0]UMRNUM;"IBACOD";""
     If !fstat | [M:MDT1]IBACOD<>[F:MDT]IBACOD
      V_FLDCOD(2) = "BICCOD"
      V_OLDFLD(2) = evalue("[F:MDT]"+V_FLDCOD(2))
      V_NEWFLD(2) = evalue("[M:MDT1]"+V_FLDCOD(2))
     Endif
    Endif
   Elsif OPTBICSTR=1 & V_FLDCOD(1)="IBACOD" &
&       ([M:MDT1]BANUPD=2 | ([M:MDT1]BANUPD=1 & func EXIST_AMENDEMENT([M:MDT0]CPY,[M:MDT0]UMRNUM,"BICCOD")))
    V_FLDCOD(2) = "BICCOD"
    V_OLDFLD(2) = evalue("[F:MDT]"+V_FLDCOD(2))
    V_NEWFLD(2) = evalue("[M:MDT1]"+V_FLDCOD(2))
   Elsif OPTBICSTR=1 & V_FLDCOD(1)="" & func EXIST_AMENDEMENT([M:MDT0]CPY,[M:MDT0]UMRNUM,"IBACOD")
    # BICCOD was changed in the BID but IBACOD was not changed in the mandate
    # Do BICCOD amendments already exist in HISTOAMD ?
    BICONLY = 1
    Filter [HAM] Where CPY=[M:MDT0]CPY & UMRNUM=[M:MDT0]UMRNUM & FLDCOD="BICCOD"
    Read [HAM]HAM0 First
    Filter [HAM]
    If !fstat & [F:HAM]PAYNUM<>""
     Link [HAM] With [PYH]PYH0=[F:HAM]PAYNUM As [LNK]
&    Where [F:HAM]CPY=[M:MDT0]CPY & [F:HAM]UMRNUM=[M:MDT0]UMRNUM & [F:HAM]FLDCOD="BICCOD" & [F:PYH]STA<8
     Read [LNK]HAM0 First
     If fstat : BICONLY = 0 : Endif
    Elsif fstat & [M:MDT1]BANUPD=1
     BICONLY = 0
    Endif
    If BICONLY=1
     V_FLDCOD(2) = "BICCOD"
     V_OLDFLD(2) = evalue("[F:MDT]"+V_FLDCOD(2))
     V_NEWFLD(2) = evalue("[M:MDT1]"+V_FLDCOD(2))
    Endif
   Endif
   # No amended field updated
   If V_FLDCOD(1)="" & V_FLDCOD(2)="" : Return : Endif
   GOK = func AMENDEMENT([M:MDT0]CPY,[M:MDT0]UMRNUM,V_FLDCOD,V_OLDFLD,V_NEWFLD,OPTBICSTR,WRK1,WRK2)
   If GOK<1 : Return : Endif
Endcase
Return

# Do a FLDCOD amendment exist in HISTOAMD ?
Funprog EXIST_AMENDEMENT(CPY,RUM,FLDCOD)
Value    Char    CPY
Value    Char    RUM
Value    Char    FLDCOD
Local Integer OK

If !clalev([F:HAM]) : Local File HISTOAMD [HAM] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif

OK = 0

Filter [HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD=[L]FLDCOD
Read [HAM]HAM0 First
Filter [HAM]
If !fstat & [F:HAM]PAYNUM<>""
 Link [HAM] With [PYH]PYH0=[F:HAM]PAYNUM As [LNK]
& Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]RUM & [F:HAM]FLDCOD=[L]FLDCOD & [F:PYH]STA<8
 Read [LNK]HAM0 First
 If !fstat : OK = 1 : Endif
Elsif !fstat & [F:HAM]PAYNUM=""
 OK = 1
Endif
End OK


Funprog AMENDEMENT(CPY,RUM,FLDCOD,OLD_VAL,NEW_VAL,OPTBICSTR,WRK1,WRK2)
Value    Char CPY
Value    Char RUM
Value    Char FLDCOD()(1..2)
Value    Char OLD_VAL()(1..2)
Value    Char NEW_VAL()(1..2)
Value    Integer OPTBICSTR
Variable Integer WRK1
Variable Integer WRK2

Local Integer OK, I, OKCRE
Local Char    CURPAYNUM(GLONVCR)
Local Integer SAME_IBAN   : # If the new IBAN amendment is the same as the older
Local Char    IBANOLD(50) : # keep the old value of the amendment
Local Char    IBANNEW(50) : # keep the new value of the amendment

Raz SAME_IBAN, IBANOLD, IBANNEW

OK = 1
If !clalev([F:HAM]) : Local File HISTOAMD [HAM] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif

# Loop if some approved or adjorned mandates exist with this creditor (company)
For I=1 To 2
 If FLDCOD(I)<>""
  # A workflow is sent only if the name ou the ICS of the creditor is changed
  If I=1 : WRK1 = 1 : Endif
  If I=2 : WRK2 = 1 : Endif

  Filter [HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD=[L]FLDCOD(I)
  # The first recording read has an empty receipt entry number (<=>[F:HAM]PAYNUM="") if this recording exists
  Read [HAM]HAM0 First
  Filter [HAM]
  # Create the recording (okcre=1):
  # - if no record for this amended field exists in HISTOAMD
  # - or if a record for this amended field exists in HISTOAMD with a receipt entry number<>empty and [F:PYH]STA>=8
  Raz OKCRE, [L]CURPAYNUM
  If fstat
   OKCRE = 1
  Elsif !fstat & [F:HAM]PAYNUM<>""
   Link [HAM] With [PYH]PYH0=[F:HAM]PAYNUM As [LNK]
&  Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]RUM & [F:HAM]FLDCOD=[L]FLDCOD(I) & [F:PYH]STA<8
   Read [LNK]HAM0 First
   If fstat
    OKCRE = 1
   Else
    [L]CURPAYNUM = [F:HAM]PAYNUM
   Endif
  Endif

  If OKCRE
   If OPTBICSTR & FLDCOD(I)="BICCOD" & SAME_IBAN=1
    GMESSAGE =func AFNC.MESNC(mess(334,117,1),IBANOLD+"~"+IBANNEW)
    OK = 0 : Break
   Endif
   Raz [F:HAM]
   [F:HAM]CPY    = CPY
   [F:HAM]UMRNUM = RUM
   [F:HAM]FLDCOD = FLDCOD(I)
   [F:HAM]OPEDAT = date$
   [F:HAM]OLDVAL = OLD_VAL(I)
   [F:HAM]NEWVAL = NEW_VAL(I)
   Write [F:HAM]
   If fstat : OK = 0 : Break : Endif
  Else
   If OPTBICSTR & FLDCOD(I)="BICCOD" & SAME_IBAN=1
    If [M:MDT1]BANUPD=2 : # SMNDA
     Delete [F:HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD=[L]FLDCOD(I) & PAYNUM=[L]CURPAYNUM
     If fstat : OK=0 : Endif
     Break
    Elsif [M:MDT1]BANUPD=1
     ## Message 4
     GMESSAGE = func AFNC.MESNC(mess(335,117,1),IBANOLD+"~"+IBANNEW)
     OK = 0 : Break
    Endif
   Endif
   If [F:HAM]OLDVAL=NEW_VAL(I)
       If OPTBICSTR & FLDCOD(I)="IBACOD" & FLDCOD(2)="BICCOD" # SMNDA
     SAME_IBAN    = 1
     IBANOLD = [F:HAM]OLDVAL
     IBANNEW = [F:HAM]NEWVAL
    Endif
    ## Message 4
    If OPTBICSTR & FLDCOD(I)="IBACOD" & FLDCOD(2)="" :# No SMNDA
     IBANOLD = [F:HAM]OLDVAL
     IBANNEW = [F:HAM]NEWVAL
     Filter [HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD="BICCOD"
     Read [HAM]HAM0 First
     Filter [HAM]
     If !fstat
      If [F:HAM]PAYNUM<>""
       Link [HAM] With [PYH]PYH0=[F:HAM]PAYNUM As [LNK]
&      Where [F:HAM]CPY=[L]CPY & [F:HAM]UMRNUM=[L]RUM & [F:HAM]FLDCOD=[L]FLDCOD(I) & [F:PYH]STA<8
       Read [LNK]HAM0 First
      Endif
      If !fstat
       GMESSAGE = func AFNC.MESNC(mess(335,117,1),IBANOLD+"~"+IBANNEW)
       OK = 0 : Break
      Endif
     Endif
    Endif
    # Case 10 : Only BICCOD changes. A SMNDA already exists. Old_BICCOD=New_BICCOD=""
    If OPTBICSTR & FLDCOD(1)="" & FLDCOD(I)="BICCOD" & NEW_VAL(I)="" & [M:MDT1]BANUPD=2
     Readlock [HAM]HAM0=[L]CPY;[L]RUM;[L]FLDCOD(I);[L]CURPAYNUM
     If !fstat
      [F:HAM]OPEDAT = date$
      [F:HAM]NEWVAL = NEW_VAL(I)
      Rewrite [F:HAM]
      If fstat : OK = 0 : Endif
     Endif
     Break
    Endif
    Delete [F:HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD=[L]FLDCOD(I) & PAYNUM=[L]CURPAYNUM
    If fstat : OK=0 : Break : Endif
   Else
    If OPTBICSTR & FLDCOD(I)="BICCOD" & [M:MDT1]BANUPD=1
     Delete [F:HAM] Where CPY=[L]CPY & UMRNUM=[L]RUM & FLDCOD=[L]FLDCOD(I) & PAYNUM=[L]CURPAYNUM
     If fstat : OK=0 : Break : Endif
    Else
     Readlock [HAM]HAM0=[L]CPY;[L]RUM;[L]FLDCOD(I);[L]CURPAYNUM
     If fstat=1
      OK = -1 : Break
     Elsif fstat
      OK = 0 : Break
     Endif
     [F:HAM]OPEDAT = date$
     [F:HAM]NEWVAL = NEW_VAL(I)
     If WRK2=9 :#If a recording is already created for this NNE amendment, change also the old value with the new NTLMIGIDT
      [F:HAM]OLDVAL = OLD_VAL(I)
     Endif
     Rewrite [F:HAM]
     If fstat : OK = 0 : Break : Endif
    Endif
   Endif
  Endif
 Endif
Next
End OK

$MODIF
If [M:MDT1]MAIMDTFLG=2
 Update [MDT] Where CPY=[M:MDT0]CPY and BPCNUM=[M:MDT1]BPCNUM and UMRNUM<>[M:MDT0]UMRNUM With MAIMDTFLG=1
Endif
If fstat
 GOK=0 : Call RSTA("MDT", [M]CPY-[M]UMRNUM) From GLOCK
Endif
Return

$APRES_MODIF
If COUZON="CPY"
 If GREP="C"
  GSOCIETE = [M:MDT0]CPY
  Call LECTCA(3, OK) From SUBTCA
  If [F:TCA]MANCOU(13)=2
   Actzo [M:MDT0]UMRNUM
   Affzo [M:MDT0]UMRNUM
  Else
   Grizo [M:MDT0]UMRNUM
  Endif
 Endif
Endif
# Message 1
If OPTBICSTR=1 & ([M:MDT1]STA=2 | [M:MDT1]STA=3)
 If (COUZON="BPCADD" & [M]IBACOD<>[F:MDT]IBACOD) | (COUZON="IBACOD" & zc<>[F:MDT]IBACOD)
  VALOK = 1 # Non
  Call OUINON(mess(336,117,1),VALOK) From GESECRAN
  [M:MDT1]BANUPD = VALOK
 Elsif (COUZON="BPCADD" & [M]IBACOD=[F:MDT]IBACOD) | (COUZON="IBACOD" & zc=[F:MDT]IBACOD)
  If [F:MDT]BICCOD = [M:MDT1]BICCOD
   Raz [M:MDT1]BANUPD
  Else
   VALOK = 1 # Non
   Call OUINON(mess(338,117,1),VALOK) From GESECRAN
   [M:MDT1]BANUPD = VALOK
  Endif
 Endif
Endif
Return

$APRES_CRE
Actzo [M:MDT0]UMRNUM
[M:MDT0]UMRNUM = [F:MDT]UMRNUM
If !GIMPORT : Affzo [M:MDT0]UMRNUM : Endif
Return

$APRES_MOD
If !GIMPORT Gosub RELIT From GOBJSUB : Endif
Return

$ABANDON
Actzo [M:MDT0]UMRNUM
Return

$SETBOUT
If find(GREP,"C", "D", "M")=0
 If [M]SIGCTY="" or [M]SIGDAT=[0/0/0] or [M]CPYADD="" or [M]BPCADD="" or [M]IBACOD="" or ([M]BICCOD="" and OPTBICSTR=0)
  Call VIREBOUT(CHAINE, "V") From GOBJET # Validation
 Endif
 If find([M:MDT1]STA, 1, 3)=0 # Initial, Adjourned
  Call VIREBOUT(CHAINE, "V") From GOBJET # Validation
 Endif
 If [M:MDT1]STA<>2 # Validated
  Call VIREBOUT(CHAINE, "OU") From GOBJET # Adjournment and Revocation
 Endif
Else
 Call VIREBOUT(CHAINE, "AOUV") From GOBJET
Endif
If [M:MDT1]STA<>1 & [M:MDT1]STA<>6 & [M:MDT1]STA<>2
 Call VIREBOUT(CHAINE, "A") From GOBJET
Endif
Return

$EXEBOUT
Local Integer OK
OK=1
If find(BOUT, "V", "O", "U")
 If BOUT="V"
  MESSA =func AFNC.MES1(mess(276,117,1), [M:MDT0]UMRNUM)
  OK=2 : Call OUINON(MESSA,OK) From GESECRAN
  If OK=2
   [M:MDT1]STA=2
   Gosub EXE
  Else
   Return
  Endif
 Elsif BOUT="O"
  [M:MDT1]STA=3
  Gosub EXE
 Elsif BOUT="U"
  MESSA =func AFNC.MES1(mess(277,117,1), [M:MDT0]UMRNUM)
  OK=2 : Call OUINON(MESSA,OK) From GESECRAN
  If OK=2
   Local Char PARAM(30)(1..2)
   Local Date ENDDAT
   Call SAISIE_DAT(ENDDAT, PARAM, "FMDTDAT", "MDTDAT", "") From GSAISIE
   If ENDDAT<>[0/0/0]
    [M:MDT1]STA=4
    Grizo [M:MDT1]
    Gosub EXE
   Endif
  Else
   Return
  Endif
 Endif
Endif
Return

$EXE
If BOUT="O"
 Update [MDT] Where CPY=[M:MDT0]CPY and UMRNUM=[M:MDT0]UMRNUM With STA=[M:MDT1]STA, MAIMDTFLG=1
Elsif BOUT="U"
 Update [MDT] Where CPY=[M:MDT0]CPY and UMRNUM=[M:MDT0]UMRNUM With STA=[M:MDT1]STA, MAIMDTFLG=1, ENDDAT=[L]ENDDAT
Else
 Update [MDT] Where CPY=[M:MDT0]CPY and UMRNUM=[M:MDT0]UMRNUM With STA=[M:MDT1]STA
Endif
If fstat
 GOK=0 : Call RSTA("MDT", [M:MDT0]CPY-[M:MDT0]UMRNUM) From GLOCK
Else
 AFFICHE=1 : Gosub RELIT From GOBJSUB
Endif
Return

$SELIBACOD
Local Char TEX(34)(1..20)
Local Char TEXTE(34)(1..20, 1..2)
Local Char TMPTXT(34)

TIT(0) = mess(18,100,1)-mess(315,107,1)
TIT(1) = mess(315,107,1)
NBTEX = 0
For [BID] Where BPATYP=1 and BPANUM=[M]BPCNUM and BPAADD=[M]BPCADD
 NBTEX += 1
# 2018-08-20 DNE X3-102365
 Call CRE_IBAN( TMPTXT, func GET_ISO_3166_1_ALPHA2( [F:BID]CRY ), [F:BID]BICCOD,[F:BID]BIDNUM ) From SUBBID
# Call CRE_IBAN(TMPTXT, [F:BID]CRY, [F:BID]BICCOD,[F:BID]BIDNUM) From SUBBID
 TEX(NBTEX) = [L]TMPTXT
 TEXTE(NBTEX, 1) = TEX(NBTEX)
 TEXTE(NBTEX, 2) = [F:BID]BICCOD
Next
Return

$AB2_NBLIG
Local Char SAV_GBIDC1(250)
SAV_GBIDC1 = GBIDC1
Raz GBIDC1
Return

$BB2_NBLIG
GBIDC1 = SAV_GBIDC1
Raz SAV_GBIDC1
Return

Subprog UPDBID(BPCNUM)
Value Char BPCNUM()
Local Char DEFMSK(255)

DEFMSK = dbgstr(1)
Case GFONCTION
 When "GESBPC" : Default Mask [BIDC]
 When "GESBPR" : Default Mask [BIDB]
 When "GESBPS" : Default Mask [BIDS]
 When Default : End
Endcase

If clalev([F:MDT])=0 : Local File MANDATE [MDT] : Endif

For nolign=1 To [M]NBRIB
 If  [M]BIDBPAADD(nolign-1)<>[M]OBIDBPAADD(nolign-1)
& or [M]BIDNUM(nolign-1)<>[M]OBIDNUM(nolign-1)
& or [M]BICCOD(nolign-1)<>[M]OBICCOD(nolign-1)
  Filter [MDT] Where BPCNUM=[L]BPCNUM and STA<=3
&   and BPCADD=[M]OBIDBPAADD(nolign-1) and BIDNUM=[M]OBIDNUM(nolign-1) and BICCOD=[M]OBICCOD(nolign-1)
  If rowcount([MDT])>0
   Call MESSAGE(mess(309,117,1)) From GESECRAN
   Break
  Endif
 Endif
Next
Filter [MDT]
Default Mask DEFMSK
End

Subprog DELBID(BPCNUM)
Value Char BPCNUM()
Local Char DEFMSK(255)

DEFMSK = dbgstr(1)
Case GFONCTION
 When "GESBPC" : Default Mask [BIDC]
 When "GESBPR" : Default Mask [BIDB]
 When "GESBPS" : Default Mask [BIDS]
 When Default : End
Endcase

Local Integer OK
If clalev([F:MDT])=0 : Local File MANDATE [MDT] : Endif
If clalev([F:BID])=0 : Local File BID [BID] : Endif

For [BID] Where BPATYP=1 and BPANUM=[L]BPCNUM
 OK=0
 For nolign=1 To [M]NBRIB
  If [F:BID]BIDNUM=[M]OBIDNUM(nolign-1) and [F:BID]BPAADD=[M]OBIDBPAADD(nolign-1) and [F:BID]BICCOD=[M]OBICCOD(nolign-1)
   OK=1 : Break
  Endif
 Next
 If OK=0
  Filter [MDT] Where BPCNUM=[L]BPCNUM and STA<=3
&   and BPCADD=[F:BID]BPAADD and BIDNUM=[F:BID]BIDNUM and BICCOD=[F:BID]BICCOD
  If rowcount([MDT])>0
   Call MESSAGE(mess(309,117,1)) From GESECRAN
   Break
  Endif
 Endif
Next
Filter [MDT]
Default Mask DEFMSK
End

$FILGAUCHE
If FILTRE<>""
 Call ADDCRIT(FILGAUSUP,IFILGAUSUP,"FILGAUSUP","("+FILTRE+")","&") From GOBJSUB
Endif
Return

# 2018-08-20 DNE X3-102365
########################################################################################################################
# Get the ISO 3166-1 2-letter code #####################################################################################

Funprog GET_ISO_3166_1_ALPHA2(VCRY)
  Value Char VCRY
  Local File TABCOUNTRY [TCY]
  Read [F:TCY]TCY0 = VCRY
  If fstat <> 0 Then
    End ""
  Endif
End [F:TCY]ISO

####################################################################################################################
# Mask controls for MDT0
####################################################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer ACCFCY
Local Char    AUZFCY(15)

Call LEC_CPY(VALEUR) From CPTLEC

[M:MDT1]SCINUM = [F:CPY]SCINUM
Affzo [M:MDT1]SCINUM
Raz [M:MDT1]CPYADD
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [F:CPY]SCINUM=""
 GMESSAGE = mess(268,117,1) : mkstat=2 : End
Endif
End

####################################################################################################################
# Mask controls for MDT1
####################################################################################################################

Subprog AM_FNLFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:MDT1]PAYNBR
Else
 Raz [M:MDT1]PAYNBR : Grizo [M:MDT1]PAYNBR
Endif
End

Subprog AM_PAYTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:MDT1]FNLFLG, WIOFIRSEQ
Else
 Raz [M:MDT1]FNLFLG, PAYNBR, WIOFIRSEQ : Grizo [M:MDT1]FNLFLG, PAYNBR, WIOFIRSEQ
Endif
End

Subprog AS_CPYADD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If [F:CPY]CPY<>[M:MDT0]CPY : Call LEC_CPY([M:MDT0]CPY) From CPTLEC : Endif
 VALEUR = [F:CPY]BPAADD
Endif
End

Subprog C_CPYADD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [F:BPA]BPA0 = 2;[M:MDT0]CPY;VALEUR
 If fstat
  GMESSAGE = mess(16,199,1)
  mkstat = 2 : End
 Else
  [M:MDT1]CPYADDDES = [F:BPA]BPADES
 Endif
Endif
End

Subprog AS_BPCADD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If [F:BPC]BPCNUM<>[M:MDT1]BPCNUM : Call LEC_BPC([M:MDT1]BPCNUM) From CPTLEC : Endif
 VALEUR = [F:BPC]BPAADD
Endif
End

Subprog C_BPCADD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [F:BPA]BPA0 = 1;[M:MDT1]BPCNUM;VALEUR
 If fstat
  GMESSAGE = mess(16,199,1)
  mkstat = 2 : End
 Else
  [M:MDT1]BPCADDDES = [F:BPA]BPADES
 Endif
Endif
End

Subprog AM_MIGFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:MDT1]NTLMIGIDT
Else
 Raz [M:MDT1]NTLMIGIDT : Grizo [M:MDT1]NTLMIGIDT
Endif
End

Subprog AM_BPCADD(VALEUR)
Variable Char    VALEUR()
Filter [BID] Where BPATYP=1 and BPANUM=[M:MDT1]BPCNUM and BPAADD=VALEUR and BIDNUMFLG=2
Read [BID] First
If fstat
 Raz [M:MDT1]IBACOD, BIDCRY, IBAN, BIDNUM, BICCOD
Else
 [M:MDT1]BIDCRY = [F:BID]CRY
 [M:MDT1]IBAN   = [F:BID]IBAN
 [M:MDT1]BIDNUM = [F:BID]BIDNUM
 [M:MDT1]BICCOD = [F:BID]BICCOD
# 2018-08-20 DNE X3-102365
 Call CRE_IBAN( [M:MDT1]IBACOD, func GET_ISO_3166_1_ALPHA2( [F:BID]CRY ), [F:BID]BICCOD, [F:BID]BIDNUM ) From SUBBID
# Call CRE_IBAN([M:MDT1]IBACOD, [F:BID]CRY, [F:BID]BICCOD, [F:BID]BIDNUM) From SUBBID
 Affzo [M:MDT1]IBACOD, BICCOD
Endif
Filter [BID]
End

Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
Raz [M:MDT1]BPCADD
End

Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz [M:MDT1]MIGFLG, NTLMIGIDT : Grizo [M:MDT1]MIGFLG, NTLMIGIDT : Affzo [M:MDT1]MIGFLG, NTLMIGIDT
Else
 Actzo [M:MDT1]MIGFLG
Endif
End

Subprog AM_IBACOD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Raz [M:MDT1]BIDCRY, IBAN, BIDNUM, BICCOD
Endif
End

Subprog C_IBACOD(VALEUR)
Variable Char    VALEUR()
Local Char    VALPAR(10): # Value of the OPTBICSTR parameter
Local Date    DATBICSTR : # Stores OPTBICSTR in a date variable
Local Integer OPTBICSTR : # Indicates if the BICCOD is optional(=1) or not

Call PARAML([M:MDT0]CPY, "OPTBICSTR", VALPAR) From ADOVAL
DATBICSTR = VALPAR
If date$>=DATBICSTR & DATBICSTR<>[0/0/0]
 OPTBICSTR = 1
Else
 OPTBICSTR = 0
Endif

If [M:MDT1]STA=2
 If VALEUR="" : Call ERRTIT(mess(10,123,1), mess(32,126,1)-'"'+mess(315,107,1)+'"') From GESECRAN : mkstat=2 : End : Endif
 If OPTBICSTR=0 and [M:MDT1]BICCOD="" : Call ERRTIT(mess(10,123,1), mess(32,126,1)-'"'+mess(316,107,1)+'"') From GESECRAN : mkstat=2 : End : Endif
Endif
If VALEUR<>""
 Local Char TMPTXT(34)
 Local Integer OK
 Raz OK
 For [BID] Where BPATYP=1 and BPANUM=[M]BPCNUM and BPAADD=[M]BPCADD
# 2018-08-20 DNE X3-102365
  Call CRE_IBAN( TMPTXT, func GET_ISO_3166_1_ALPHA2( [F:BID]CRY ), [F:BID]BICCOD,[F:BID]BIDNUM ) From SUBBID
#  Call CRE_IBAN(TMPTXT, [F:BID]CRY, [F:BID]BICCOD,[F:BID]BIDNUM) From SUBBID
  If VALEUR=TMPTXT : OK=1 : Break : Endif
 Next
 If OK=0
  GMESSAGE = mess(83,123,1): mkstat=2 : End
 Else
  OK=0
  If [M:MDT1]BIDCRY<>[F:BID]CRY
   [M:MDT1]BIDCRY = [F:BID]CRY : OK=1
  Endif
  If [M:MDT1]IBAN<>[F:BID]IBAN
   [M:MDT1]IBAN   = [F:BID]IBAN : OK=1
  Endif
  If [M:MDT1]BIDNUM<>[F:BID]BIDNUM
   [M:MDT1]BIDNUM = [F:BID]BIDNUM : OK=1
  Endif
  If [M:MDT1]BICCOD<>[F:BID]BICCOD
   [M:MDT1]BICCOD = [F:BID]BICCOD : OK=1
  Endif
  If OK
   Affzo [M:MDT1]IBACOD, BICCOD
   If !GIMPORT : mkstat=4 : Endif
  Endif
 Endif
 If [F:TCY]CRY<>[M]BIDCRY : Read [TCY]TCY0=[M]BIDCRY : Endif
 If !fstat & [F:TCY]FLGSEPA<>2 : GMESSAGE=mess(267,117,1) : mkstat = 2 : End : Endif
Endif
End

Subprog C_PAYNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0 : GMESSAGE = mess(21,131,1) : mkstat = 2 : End : Endif
If !find(GREP,"C","D")
 If VALEUR<=[F:MDT]NBRSDDPAY : GMESSAGE = mess(6,199,1)-":"-num$(VALEUR)-mess(52,147,1)-num$([F:MDT]NBRSDDPAY) : mkstat=2 : End : Endif
Endif
End

Subprog IB_NBLIG
If [M:MDT2]FRMNUM(nolign-1)="" : Raz [V]GBOUT2 : Endif
End

