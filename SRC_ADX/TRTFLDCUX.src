#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################################################
#   Gestion du paramétrage d'un champs Tiers divers                 Module CRM         20 juillet 2000
######################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "STATUT"       : Gosub STATUT
 When Default
Endcase
Return


$OUVRE
# PARAM(1) : Code du champs à paramétrer
# PARAM(2) : Type de paramétrage à réaliser
Local Char SZTTRFLD
SZTTRFLD = ""
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Gosub LOADLIB
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Return

$FIN
If [M:CUS2]TTRFLD <> "" : Gosub SAVELIB : Endif
Raz [M:CUS2]
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$STATUT
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################################################
#Gère les libellés en ouverture de fenêtre
$LOADLIB
Local Integer A1
A1 = 0

If !clalev([F:BPG]) : Local File BPMISCCGF [BPG] : Endif

Filter [BPG] Where [F:BPG]BPRTYP = "LIBDOO" and [F:BPG]LAN = GLANGUE and [F:BPG]TTRINT(0) = PARAM(1)
&            Order By [F:BPG]TTRALH(0)

For [BPG]
    [M:CUS2]TTRLIB(A1) = [F:BPG]TTRALH(0)
    A1 += 1
Next

[M:CUS2]NBLIB = A1
Filter [BPG]
Affzo [M:CUS2]
Return

########################################################################################
#Gère les libellés en fermeture de fenêtre
$SAVELIB
Local Integer A2
A2 = 0
If !clalev([F:BPG]) : Local File BPMISCCGF [BPG] : Endif

#Vérifie si un libellé identique n'a pas déjà été saisi
Filter [BPG] Where [F:BPG]BPRTYP = "LIBDOO"
&              and [F:BPG]LAN = GLANGUE
&              and [F:BPG]TTRINT(0) = PARAM(1)
&              and [F:BPG]TTRALH(0) = [M:CUS2]TTRFLD Order By [F:BPG]TTRALH(0)
For [BPG]
    A2 += 1
Next
If A2
    GMESSAGE = mess(235, 196, 2) #Ce libellé existe déjà. Abandon de la création.
    GERR = 2
    Filter [BPG]
    Return
Endif
Filter [BPG]

Raz [F:BPG]

Call DEBTRANS From GLOCK
Trbegin [BPG]

[F:BPG]BPRTYP = "LIBDOO"
[F:BPG]LAN = GLANGUE
[F:BPG]TTRINT(0) = PARAM(1)
[F:BPG]TTRALH(0) = [M:CUS2]TTRFLD
Write [BPG]
If fstat
     Rollback
     GMESSAGE = mess(227, 196, 2) #Erreur lors de l'enregistrement. Transaction abandonnée.
     GERR = 1
Else
     Commit
Endif
Return

