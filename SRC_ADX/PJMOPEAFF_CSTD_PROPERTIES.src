#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMOPEAFF
###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
    When Default     : Return
  Endcase
Return

###################################################################################################
$KEYCONCAT_GET
  #this.KEYCONCAT = this.OPPNUM + "~" + this.TASCOD + "~" + num$(this.OPENUM) + "~" + num$(this.OPESPLNUM) + "~" + num$(this.POANUM)
  this.KEYCONCAT = func PJMOPEAFF_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(this.OPPNUM, this.TASCOD, this.OPENUM, this.OPESPLNUM, this.POANUM)
Return

###################################################################################################
$POACLB
  # Issue X3-5414/119279 - 2016-11-02 by TEJAC : Begin
  Case [L]ARULE
    When "CONTROL"         : Gosub POACLB_CONTROL
  Endcase
Return

$POACLB_CONTROL
  If this.POACLB <> AVOID.ACHAR Then
    # -----------------------------
    Local File PJMAUS [PAUS]
    # -----------------------------
    Read [F:PAUS]PAUS = this.POACLB
    If fstat
      [L]ASTATUS = fmet this.SETERROR("POACLB", func AFNC.MES1(mess(443,2260,1), this.POACLB), [V]CST_AERROR)
    Else
      If [F:PAUS]ENAFLG <> [V]CST_AYES Then
        [L]ASTATUS = fmet this.SETERROR("POACLB", func AFNC.MES1(mess(443,2260,1), this.POACLB), [V]CST_AERROR)
      Endif
    Endif
    # -----------------------------
  Endif
  # Issue X3-5414/119279 - 2016-11-02 by TEJAC : End
Return

###################################################################################################
$POASTDQTY
  Case [L]ARULE
    When "CONTROL"         : Gosub POASTDQTY_CONTROL
    When "PROPAGATE"       : Gosub POASTDQTY_PROPAGATE         # Issue X3-17075/120484 - 2016-12-19 by FGR
  Endcase
Return

$POASTDQTY_CONTROL
  If this.POASTDQTY < 0 Then
    [L]ASTATUS = fmet this.SETERROR("POASTDQTY", mess(232,2260,1), [V]CST_AERROR)
  Endif
Return

$POASTDQTY_PROPAGATE
  # Issue X3-17075/120484 - 2016-12-19 by FGR : BEGIN
  If this.POACSMQTY = 0 Then
    this.POARMNQTY = this.POASTDQTY
  Else
    # ---------------------------------------
    If this.POASTDQTY < this.POACSMQTY Then
      this.POARMNQTY = 0
    Else
      this.POARMNQTY = this.POASTDQTY - this.POACSMQTY
    Endif
    # ---------------------------------------
  Endif
  # Issue X3-17075/120484 - 2016-12-19 by FGR : END
Return

###################################################################################################
$POACSMQTY
  # Issue X3-6415/119493 - 2016-10-31 by SINGC
  Case [L]ARULE
    When "CONTROL"         : Gosub POACSMQTY_CONTROL
  Endcase
Return

$POACSMQTY_CONTROL
  # Issue X3-6415/119493 - 2016-10-31 by SINGC
  If this.POACSMQTY < 0 Then
    [L]ASTATUS = fmet this.SETERROR("POACSMQTY", mess(232,2260,1), [V]CST_AERROR)
  Endif
Return

###################################################################################################
$POARMNQTY
  Case [L]ARULE
    When "CONTROL"         : Gosub POARMNQTY_CONTROL
  Endcase
Return

$POARMNQTY_CONTROL
# TEJAC TODO : ADD CONDITION
# IF THE TOTAL OF EMPLOYEES REMAINING LOAD IS NOT > REMAINING LOAD
  If this.POARMNQTY < 0 Then
    [L]ASTATUS = fmet this.SETERROR("POARMNQTY", mess(232,2260,1), [V]CST_AERROR)
  Endif
  # Issue X3-17075/120484 - 2016-12-19 by FGR : BEGIN
  If this.TCHOPESTA = 5 Then
    If this.POARMNQTY <> 0 Then
      [L]ASTATUS = fmet this.SETERROR("POARMNQTY", mess(475,2260,1), [V]CST_AERROR)
    Endif
  Endif
  # Issue X3-17075/120484 - 2016-12-19 by FGR : END
Return

