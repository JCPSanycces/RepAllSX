#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'un Rendez-vous                                                   Version 140
#   Module CRM                             
#   
###############################################################################################################

Subprog BAPINHTML(SZRECNUM, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub HTMLPART1 From CRMXML140

Call TEXTE(14423, SZHTMLTITLE) From OBJDIV      #Rendez-vous
SZSUBPROG = "BAPINHTML"
SZAOBABREV = "BAP"

############################################
#Variables particulières pour les réservations de ressources
Local Integer ITERRRS
ITERRRS = 0
###########################################

Gosub HTMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREHTML

Gosub HTMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML

Gosub SETBAPEXCEPT From CRMEXCEPT
Gosub SETBPREXCEPT From CRMEXCEPT
Gosub SETBPCEXCEPT From CRMEXCEPT
Gosub SETBPAEXCEPT From CRMEXCEPT
Gosub SETREPEXCEPT From CRMEXCEPT
Gosub SETAINEXCEPT From CRMEXCEPT
Gosub SETRRSEXCEPT From CRMEXCEPT

#On extrait
Filter [BAP] Where [F:BAP]APTNUM = SZRECNUM

For [BAP]
    Gosub HTMLBAP From CRMEXCEPT

    #Interlocuteurs
    Gosub ADDAIN

    #Représentants
    Gosub ADDREP

    #Réservations de ressources
    If IDISPLAYRRS
        Gosub ADDRRS
    Endif

    #Tiers
    If IDISPLAYBPR
        Gosub ADDBPR
    Endif

    #Client
    If IDISPLAYBPC
        Gosub ADDBPC
    Endif

    #Adresse
    If IDISPLAYBPA
        Gosub ADDBPA
    Endif
Next

Filter [BAP]

Return

##########################################################
# Tiers
##########################################################
$ADDBPR

Filter [BPR] Where [F:BPR]BPRNUM = [F:BAP]APTCMP

For [BPR]
    Gosub HTMLBPR From CRMEXCEPT
Next

Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC

Filter [BPC] Where [F:BPC]BPCNUM = [F:BAP]APTCMP

For [BPC]
    Gosub HTMLBPC From CRMEXCEPT
Next

Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA

Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BAP]APTCMP

For [BPA]
    Gosub HTMLBPA From CRMEXCEPT
Next

Filter [BPA]
Return

##########################################################
# Contact
##########################################################
$ADDAIN

Local Integer ITERCCNNUM
ITERCCNNUM = 0

For ITERCCNNUM = 0 To dim([F:BAP]APTCCNNUM) - 1
    If [F:BAP]APTCCNNUM(ITERCCNNUM) <> ""
        Read [AIN] AIN0 = [F:BAP]APTCCNNUM(ITERCCNNUM)
        If !fstat
            Gosub HTMLAIN From CRMEXCEPT
        Endif
    Endif
Next
Return

##########################################################
# Représentant
##########################################################
$ADDREP

Local Integer ITERREPNUM
ITERREPNUM = 0

For ITERREPNUM = 0 To dim([F:BAP]APTREPNUM) - 1
    If [F:BAP]APTREPNUM(ITERREPNUM) <> ""
        Read [REP] REP0 = [F:BAP]APTREPNUM(ITERREPNUM)
        If !fstat
            Gosub HTMLREP From CRMEXCEPT
        Endif
    Endif
Next
Return

##########################################################
# Réservations de ressources
##########################################################
$ADDRRS

ITERRRS = 0
For ITERRRS = 0 To dim([F:BAP]APTRER) - 1
    If [F:BAP]APTRER(ITERRRS) <> ""
        Read [RRS] RRS0 = [F:BAP]APTRER(ITERRRS)
        If !fstat
            Gosub HTMLRRS From CRMEXCEPT
        Endif
    Endif
Next
Return



