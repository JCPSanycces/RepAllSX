#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:38"
A_USER  = "DOC"
A_STAMP = "20181109230438"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT0 [EMP0]
Gosub HORODAT
Local Inpbox "HRMAT0" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP0] As [SIM_]
Grizo [EMP0]6
Grizo [EMP0]11
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=26 : Y1(0)=1 : Y2(0)=4
X1(1)=27 : X2(1)=74 : Y1(1)=1 : Y2(1)=4
Return

$ON_REFNUM
Onevent CONTROL Call C_REFNUM(zc) From W1HRMAT0
Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1HRMAT0
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1HRMAT0
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action CONTEMP
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTEMP"
PARMSK(1) = ""
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = ""
PARMSK(5) = ""
PARMSK(6) = GLEGFIL
Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !mkstat
 ## Action STD
 Call C_REFNUM(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
Endif
Gosub _AFF
End

Subprog S_REFNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_REFNUM" : PROGSUB = "SUBEML2" : PROGSPE = "SPEEML2" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GLEGFIL
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_REFNUM" : PROGSUB = "SUBEML2" : PROGSPE = "SPEEML2" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_FCY
Return

$ON_FCYORI
Onevent CONTROL Call C_FCYORI(zc) From W1HRMAT0
Onevent BEFORE_INPUT Call AS_FCYORI(zc) From W1HRMAT0
Onevent AFTER_AREA Call AP_FCYORI(zc) From W1HRMAT0
Onevent AFTER_CHANGE Gosub AMM_FCYORI From W1HRMAT0
Return

Subprog AS_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1427,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_FCYORI(VALEUR) From SUBEML2
If mkstat=2
 [M]FCYORI(INDIC) = VALEUR
 Affzo FCYORI(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_FCYORI(zc) From W1HRMAT0
Onkey   2 Titled GBOUTS Call S_FCYORI(zc) From W1HRMAT0
Onkey 144 Titled GBOUTP Call P_FCYORI(zc) From W1HRMAT0
Onkey 146 Titled GBOUTA Call SA_FCYORI(zc) From W1HRMAT0
Gosub _AFF
End

Subprog C_FCYORI(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
  If !mkstat
   ## Action STD
   Call C_FCYORI(VALEUR) From SUBEML2
   If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog AP_FCYORI(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_FCYORI(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
Gosub _AFF
End

$AMM_FCYORI
Call AM_FCYORI(zc)
If !mkstat & GOBJET
 zoncou = "FCYORI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FCYORI(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_FCYORI(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZFCYORI)")>indice
 [M]FCYORI(indice) = VALEUR
 Affzo ZFCYORI(indice)
Endif
Gosub _AFF
End

Subprog S_FCYORI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELFCYLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFCYLEG"
 PARMSK(1) = GLEGFIL
 Call S_TAB_CHAR(VALEUR,PARMSK,"","TRTX3","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_FCYORI(VALEUR)
Variable Char    VALEUR()
Call OBJET("FCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZFCYORI
Onevent BEFORE_AREA Gosub AV_ZFCYORI From W1HRMAT0
Return

$AV_ZFCYORI
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]FCYORI(indice)),"") From CONTOBJ
zc = [F:FCY]FCYSHO
Gosub _AFF
Return

$ON_CPY
Return

$ON_CPYORI
Return

$ON_ZCPYORI
Onevent BEFORE_AREA Gosub AV_ZCPYORI From W1HRMAT0
Return

$AV_ZCPYORI
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPYORI(indice)),"") From CONTOBJ
zc = [F:CPY]CPYSHO
Gosub _AFF
Return

$ON_CIVA
Onevent BEFORE_INPUT Call AS_CIVA(zc) From W1HRMAT0
Onevent CONTROL Call C_CIVA(zc) From W1HRMAT0
Onevent AFTER_CHANGE Gosub AMM_CIVA From W1HRMAT0
Return

Subprog IB_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]NOLIB,"") From FMTVAR
Endif
## Action STD
Call IB_CIVA From SUBEML2
Gosub _AFF
End

Subprog AS_CIVA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CIVA(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]CIVA(INDIC) = VALEUR
 Affzo CIVA(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CIVA(zc) From W1HRMAT0
Onkey   2 Titled GBOUTS Call S_CIVA(zc) From W1HRMAT0
Gosub _AFF
End

Subprog C_CIVA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
If !mkstat
 ## Action AFMTCONT
 Call CONTROLE(VALEUR,"M",[M]NOLIB,15,[M]VALINT) From FMTVAR
 If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
 If !mkstat
  ## Action ACONTACL
  Call CONTACL([M]VALINT,"M","","") From SUBACL
  If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CIVA
Call AM_CIVA(zc)
If !mkstat & GOBJET
 zoncou = "CIVA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CIVA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CIVA(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
Gosub _AFF
End

Subprog S_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINT
 PARMSK(5) = [M]VALPAR
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINT = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CIVA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B1_CIVA(VALEUR) From SUBEML2
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

