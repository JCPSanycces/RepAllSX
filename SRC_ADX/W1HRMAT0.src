$ON_ENAFLG
Onevent AFTER_CHANGE Gosub AMM_ENAFLG From W1HRMAT0
Onevent INIT_AREA Call D_ENAFLG(zc) From W1HRMAT0
Onevent BEFORE_INPUT Call AS_ENAFLG(zc) From W1HRMAT0
Return

Subprog D_ENAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_ENAFLG
Call AM_ENAFLG(zc)
