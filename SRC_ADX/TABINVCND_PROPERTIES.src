#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------- PROPERTIES
$INIT_LEG

  this.LEG = fmet this.ACTX.APARAM.AGETUSERVALCHAR("LEGFIL") # Issue 107888 - 2016-08-05 by CPO : Scheduled invoices object management US85

Return
#---------------------------------------------------------------
$CONTROL_GRP
  #--At least one of the facilities within this group, must have it's company from LEG value
  If this.LEG=AVOID.ACHAR : Return : Endif

  Local Char VMESSA(255)
  [L]ASTATUS = func TRTVENCTL_SYRA.CTLGFYLEG(this.ACTX, this.GRP, this.LEG, VMESSA)
  If [L]ASTATUS>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR(CURPRO,VMESSA,[V]CST_AERROR)
    Return
  Endif

Return
#---------------------------------------------------------------
$CONTROL_INVCNDTYP
  #--It is forbidden to delete/change the value of the INVCNDTYP
  #--if INVCND+LEG entry already used in a DOCINVCND record
  If find(this.ASTALIN, [V]CST_ANEW, [V]CST_ANEWDEL)=0 # Issue X3-38345 - 2017-06-09 by CPO : [120063] GESINVCND issue in duplication / wrong message
    If this.snapshot<>null and this.snapshot.INVCNDTYP<>AVOID.AINT and this.snapshot.INVCNDTYP<>this.INVCNDTYP
      #--Should I be doing this in the ACONTROL global control event ?
      #--Especially because there is no snapshot on the interface type class
      Local File SVCRINVCND [SVIC]

      Filter [SVIC] Where INVCND=this.INVCND and LEG=this.LEG
      Read [SVIC] First
      If fstat=[V]CST_AOK
        [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(437,192,1)+"."-mess(438,192,1),[V]CST_AERROR)
      Endif
      Filter [SVIC]
    Endif
  Endif
  #--/
Return
#---------------------------------------------------------------
$PROPAGATE_INVCNDTYP
Local Integer IL
Local Char    WTRUEFALSE : WTRUEFALSE=AVOID.ACHAR

  #--First, according to the type, activate/deactivate fields
  #--The mandatory flag has to be set, also
  Case this.INVCNDTYP
    When 1 :
            #--Normal
            WTRUEFALSE = "false"
            Gosub SET_MANDATORY_PERIODICITY_ITEMS
    When 2 :
            #--Fixed percentage
            WTRUEFALSE = "false"
            Gosub SET_MANDATORY_PERIODICITY_ITEMS
            WTRUEFALSE=AVOID.ACHAR
    When 3 :
            #--Periodicity
            WTRUEFALSE = "true"
            Gosub SET_MANDATORY_PERIODICITY_ITEMS
            WTRUEFALSE=AVOID.ACHAR
  Endcase
  #--
  If this.snapshot<>null and this.snapshot.INVCNDTYP<>this.INVCNDTYP
    #--Deleting existing collection line or emptying header properties associated to 'Periodicity' type
    Case this.snapshot.INVCNDTYP
      When 2 #--Previous : 'Fixed percentage'
      When 3 #--Previous : 'Periodicity'
        this.FREQINV= 0
        this.PERINV = 0
        this.INVMETH= 0
        this.INVDAY = 0
    Endcase
    For IL= maxtab(this.INVCNDLIN) To 1 Step -1
      If this.INVCNDLIN(IL)<>null
        [L]ASTATUS = fmet this.ADELLINE("INVCNDLIN",IL)
        Break ([L]ASTATUS>=[V]CST_AERROR)
      Endif
    Next IL
    If this.snapshot.INVCNDTYP=0 and this.INVCNDTYP=3

    Endif
  Endif

Return
#-----------------------
$SET_MANDATORY_PERIODICITY_ITEMS
  #--List of properties that depends of the Periodicity invoice term type
  #--Some of the properties are located in the header (common to all invoice term lines)
  #--FREQINV, PERINV, INVMETH
  If WTRUEFALSE<>AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETATTRIBUTE("FREQINV"  ,"$isMandatory",WTRUEFALSE)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("PERINV"   ,"$isMandatory",WTRUEFALSE)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("INVMETH"  ,"$isMandatory",WTRUEFALSE)
  Endif
  #--
  #--Other properties are present at line level
  #--Changing the mandatory attribute is done at line level

  #--
Return
#---------------------------------------------------------------

