#<AdxTL>@(#)1.0.0.0 $Revision$
##################################################################################
# UUAFFCCCN                                                                      #
# Affectation du compteur CCCN à l'objet CCN                                     #
##################################################################################
 Call OUVRE_TRACE("Test moulinette UUAFFCCCN") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE From LECFIC
End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","TABCOUAFF","fde",PAPPLI),0)<=0
      End
Else
   Call EXE_UUAFFCCCN(PAPPLI)
Endif

End
##################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","TABCOUAFF","fde",APPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif 
  Call EXE_UUAFFCCCN(APPLI)
End

End

##################################################################################
Subprog EXE_UUAFFCCCN(LDOSSIER)
Value Char LDOSSIER

 If LDOSSIER=GDOSX3 : End : Endif

 Local Char     WMSG(80)
 Local Integer OK
 
 If !clalev([F:ZTCA]) : Local File =LDOSSIER+".TABCOUAFF" [ZTCA] : Endif
 
 GOK =1

 Call ECR_TRACE("UUAFFCCCN: Sequence number CCCN assignment / CCN object (Folder"-LDOSSIER+")",0) From GESECRAN
 If dim(G_ACTCCN)>0 & G_ACTCCN<>G_OUI
  WMSG="Activity code CCN disabled in this folder"
  Call ECR_TRACE(WMSG,-1) From GESECRAN
  Goto FIN2
 Endif

 Trbegin [ZTCA]
 Update [ZTCA] Where MODULE=14 With CODNUM(7)="CCCN"
 If !fstat
  WMSG=num$(adxuprec)-"records updated in TABCOUAFF table"
  Call ECR_TRACE(WMSG,-1) From GESECRAN
 Else
  GOK=0
  WMSG="I/O error while updating TABCOUAFF table fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
 Endif
 
 $FIN
  If GOK=1
   Commit
  Else
   Rollback
  Endif
 $FIN2
 WMSG ="UUAFFCCN: end of process"
 Call ECR_TRACE(WMSG,0) From GESECRAN

End
