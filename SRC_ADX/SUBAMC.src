#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ,GBIDC1,GBIDC2,GNBMASKOUV,GTEST
Call OBJET("AMC",GBIDC1,GBIDC2) From GOBJET
End

# Gestion du masque AMC1

######################################################################################
$ACTION
#If GUSER='VPO' : Dbgaff : Endif
#Infbox "action="+ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "ANNULE"      : Gosub ANNULE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When Default
Endcase
Return

$OUVRE
If !clalev([F:AMC2])    Local File AMOTCLE  [AMC2]  : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS]  : Endif
If clalev([F:ADZ])=0  : Local File ADOCFLD  [ADZ]  : Endif
Local Char DOSX3(GLONADS)
Read [ADS]DOSSIER = nomap
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If DOSX3<>""
 Local File =DOSX3+".ADOCFLD" [AD7]
Endif
Return

#----------------------------------------------------------#
$OUVRE_BOITE
Local Char    AMCBOX1(10) , AMCBOX2(10) , AMCBOX3(10) , AMCBOX4(10)
AMCBOX1 = "GAU_CHE"+num$(find("AMC1",OBJLIS(1..dim(OBJLIS)-1)))
AMCBOX2 = "GAU_CHE"+num$(find("AMC2",OBJLIS(1..dim(OBJLIS)-1)))
AMCBOX3 = "GAU_CHE"+num$(find("AMC3",OBJLIS(1..dim(OBJLIS)-1)))
AMCBOX4 = "GAU_CHE"+num$(find("AMC4",OBJLIS(1..dim(OBJLIS)-1)))
Return

#----------------------------------------------------------------------------#
$SETBOUT
If CLECUR & REP<>"M" & VERROU
 CHAINE += "A" : # Suppression
Endif
If CLECUR & REP="" & VERROU
       CHMEN += "1"   : # Epuration
Else
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

#----------------------------------------------------------------------------#
$ANNULE
$APRES_CRE
$APRES_MOD
If [M:AMC1]TYPZON=2
  Local Char NAMF(250)
  NAMF=filpath("ECR",[M:AMC1]IDENT1,"msk",nomap)
  # Issue 87267 - 2013-01-21 by VPO : invalidation ecran s'il n'existe pas
  #If filinfo(NAMF,7)>0
  Openo NAMF,0 Using [DIFM]
  Openo Using [DIFM]
  #Endif
Endif
Return

#----------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "AMOTCLEL1" : Gosub AMOTCLEL1
Endcase
Return

$LIENS
Case [M:AMC1]TYPZON
  When 1 : Read [ATZ]CODZONE=[M:AMC1]IDENT1;[M:AMC1]IDENT2(nolign-1)
           Call TEXTE([F:ATZ]NOCOURT,[M:AMC1]DESIDENT2(nolign-1)) From OBJDIV
  When 2 : Read [AMZ]CODE=[M:AMC1]IDENT1;[M:AMC1]IDENT2(nolign-1)
           Call TEXTE([F:AMZ]INTIT,[M:AMC1]DESIDENT2(nolign-1)) From OBJDIV
  When 3 : Read [ACLAF]ACLAF0=[M:AMC1]IDENT1;[M:AMC1]IDENT2(nolign-1)
           Call TEXTE([F:ACLAF]INTFLD,[M:AMC1]DESIDENT2(nolign-1)) From OBJDIV
  When 4 : Read [ASWR]ASWR0=[M:AMC1]IDENT1;[M:AMC1]IDENT2(nolign-1)
           Call TEXTE([F:ASWR]INTPRO,[M:AMC1]DESIDENT2(nolign-1)) From OBJDIV
Endcase
[M:AMC1]EXI([M:AMC1]NBZONE)=1
Return

$LIENS2
Case [M:AMC1]TYPZON
  When 1 : Read [ATB]CODFIC=[M:AMC1]IDENT1
           Call TEXTE([F:ATB]INTITFIC,[M:AMC1]DESIDENT1) From OBJDIV
  When 2 : Read [AMK]CODMSK=[M:AMC1]IDENT1
           Call TEXTE([F:AMK]INTMSK,[M:AMC1]DESIDENT1) From OBJDIV
  When 3 : Read [ACLA]ACLA0=[M:AMC1]IDENT1
           Call TEXTE([F:ACLA]INTCLA,[M:AMC1]DESIDENT1) From OBJDIV
  When 4 : Read [ASW]ASW0=[M:AMC1]IDENT1
           Call TEXTE([F:ASW]INTREP,[M:AMC1]DESIDENT1) From OBJDIV
Endcase
Case [M:AMC1]TYPZON
  When 1 : Gosub COMPL_ATB
  When 2 : Gosub COMPL_AMK
  When 3 : Gosub COMPL_ACLA
  When 4 : Gosub COMPL_ASW
Endcase
Local Integer JL
Sorta [M:AMC1]NBZONE [M:AMC1]NBZONE Order By EXI([S]indice),NUM1([S]indice), NUM2([S]indice)
JL=find(2,[M:AMC1]EXI(0..[M:AMC1]NBZONE))
If JL>1
  Dela 0,JL-1 [M:AMC1]NBZONE : [M:AMC1]NBZONE -= (JL-1)
Endif
Return

#------------------------------------#
$COMPL_ATB
Local Integer IZON
For [ATZ] Where CODFIC=[M:AMC1]IDENT1
  IZON=find([F:ATZ]CODZONE,[M:AMC1]IDENT2(0..[M:AMC1]NBZONE-1))
  If IZON=0
     [M:AMC1]IDENT2([M:AMC1]NBZONE)=[F:ATZ]CODZONE
     Call TEXTE([F:ATZ]NOCOURT,[M:AMC1]DESIDENT2([M:AMC1]NBZONE)) From OBJDIV
     [M:AMC1]EXI([M:AMC1]NBZONE)=2
     [M:AMC1]NUM1([M:AMC1]NBZONE)=[F:ATZ]NUMLIG
     [M:AMC1]NUM2([M:AMC1]NBZONE)=0
     [M:AMC1]NBZONE+=1
  Else
     [M:AMC1]EXI(IZON-1)=2
     [M:AMC1]NUM1(IZON-1)=[F:ATZ]NUMLIG
     [M:AMC1]NUM2(IZON-1)=0
  Endif
Next ATZ
Return

#------------------------------------#
$COMPL_AMK
Local Integer IZON
For [AMZ]CODZON Where CODMSK=[M:AMC1]IDENT1 & SAIAFF<=2 & CODTYP<>"ABS"
  IZON=find([F:AMZ]CODZON,[M:AMC1]IDENT2(0..[M:AMC1]NBZONE-1))
  If IZON=0
     [M:AMC1]IDENT2([M:AMC1]NBZONE)=[F:AMZ]CODZON
     Call TEXTE([F:AMZ]INTIT,[M:AMC1]DESIDENT2([M:AMC1]NBZONE)) From OBJDIV
     [M:AMC1]EXI([M:AMC1]NBZONE)=2
     [M:AMC1]NUM1([M:AMC1]NBZONE)=[F:AMZ]NUMBLOC
     [M:AMC1]NUM2([M:AMC1]NBZONE)=[F:AMZ]NOZONE
     [M:AMC1]NBZONE+=1
  Else
     [M:AMC1]EXI(IZON-1)=2
     [M:AMC1]NUM1(IZON-1)=[F:AMZ]NUMBLOC
     [M:AMC1]NUM2(IZON-1)=[F:AMZ]NOZONE
  Endif
Next ATZ
Return

#------------------------------------#
$COMPL_ACLA
Local Integer IZON
For [ACLAF] Where CODCLA=[M:AMC1]IDENT1
  IZON=find([F:ACLAF]FLDCLA,[M:AMC1]IDENT2(0..[M:AMC1]NBZONE-1))
  If IZON=0
     [M:AMC1]IDENT2([M:AMC1]NBZONE)=[F:ACLAF]FLDCLA
     Call TEXTE([F:ACLAF]INTFLD,[M:AMC1]DESIDENT2([M:AMC1]NBZONE)) From OBJDIV
     [M:AMC1]EXI([M:AMC1]NBZONE)=2
     [M:AMC1]NUM1([M:AMC1]NBZONE)=[F:ACLAF]NUMFLD
     [M:AMC1]NUM2([M:AMC1]NBZONE)=[F:ACLAF]NUMLIG
     [M:AMC1]NBZONE+=1
  Else
     [M:AMC1]EXI(IZON-1)=2
     [M:AMC1]NUM1(IZON-1)=[F:ACLAF]NUMFLD
     [M:AMC1]NUM2(IZON-1)=[F:ACLAF]NUMLIG
  Endif
Next ATZ
Return

#------------------------------------#
$COMPL_ASW
Local Integer IZON
For [ASWR]ASWR0 Where CODREP=[M:AMC1]IDENT1
  IZON=find([F:ASWR]ALIAS,[M:AMC1]IDENT2(0..[M:AMC1]NBZONE-1))
  If IZON=0
     [M:AMC1]IDENT2([M:AMC1]NBZONE)=[F:ASWR]ALIAS
     Call TEXTE([F:ASWR]INTPRO,[M:AMC1]DESIDENT2([M:AMC1]NBZONE)) From OBJDIV
     [M:AMC1]EXI([M:AMC1]NBZONE)=2
     [M:AMC1]NUM1([M:AMC1]NBZONE)=[F:ASWR]ORDPRO
     [M:AMC1]NUM2([M:AMC1]NBZONE)=[F:ASWR]NUMPRO
     [M:AMC1]NBZONE+=1
  Else
     [M:AMC1]EXI(IZON-1)=2
     [M:AMC1]NUM1(IZON-1)=[F:ASWR]ORDPRO
     [M:AMC1]NUM2(IZON-1)=[F:ASWR]NUMPRO
  Endif
Next ATZ
Return

##################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AMOTCLE  [AMC1]
Else
 # Issue 84754 - 2012-10-01 by VPO : verif si table AMOTCLE existe
 If filinfo(filpath("FIL","AMOTCLE","fde",[M]DOSORG),0) < 0
    GOK=0 : GMESSAGE=mess(112,125,1)-[M]DOSORG+"\AMOTCLE"-mess(124,124,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Return
 Endif
 Local File =[M]DOSORG+".AMOTCLE"  [AMC1]
Endif
If [M]DOSDES=nomap
 Local File AMOTCLE  [AMC2]
Else
 # Issue 84754 - 2012-10-01 by VPO : verif si table AMOTCLE existe
 If filinfo(filpath("FIL","AMOTCLE","fde",[M]DOSDES),0) < 0
    GOK=0 : GMESSAGE=mess(112,125,1)-[M]DOSDES+"\AMOTCLE"-mess(124,124,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Close Local File [AMC1]
    Return
 Endif
 Local File =[M]DOSDES+".AMOTCLE"  [AMC2]
Endif
Local Integer I
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AMC1],[AMC2]
Return

$TR_COP
GOK = 1
Trbegin [AMC2]
 Delete [AMC2] Where TYPZON=val(TABLE) & IDENT1=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMOTCLE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AMC1]AMC0 Where TYPZON=val(TABLE) & IDENT1=TABLE2
  [F:AMC2] = [F:AMC1]
  Write [AMC2]
  If fstat
   GOK=0 : Call FSTA("AMC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#######################################################
$FILGAUCHE
Case currbox
 When AMCBOX1
  FILGAUSUP = 'TYPZON=1'
 When AMCBOX2
  FILGAUSUP = 'TYPZON=2'
 When AMCBOX3
  FILGAUSUP = 'TYPZON=3'
 When AMCBOX4
  FILGAUSUP = 'TYPZON=4'
 When Default
  FILGAUSUP = "1=1"
Endcase
Return

#------------------------------------#
# Sélection IDENT1
#------------------------------------#

$AMOTCLEL1
Local Char WOTRT(30)
WOTRT=""
Case [M:AMC1]TYPZON
  When 1 : WOTRT="WOATB"
  When 2 : WOTRT="WOAMK"
  When 3 : WOTRT="WOACLA"
  When 4 : WOTRT="WOASW"
Endcase
Call TIT_AMOTCLEL1(WOTRT,TIT(0))
Gosub OUVFIC From =WOTRT
Gosub OUVRE_LISTE From =WOTRT
For I=1 To NBSEL
 J = I+NBCOL
 If SELEXP(I)<>""
  COL(J) = SELEXP(I)
 Else
  COL(J) = SELZON(I)
 Endif
 TIT(J) = SELLIB(I)
 If dim(SELFOR)>0
  FMTCOL(J) = SELFOR(I)
 Endif
Next I
NBCOL += NBSEL
OBJET = ""
START = SELZON(1)
ORDRE = SELZON(1)
Gosub DEFAUT_LISTE From =WOTRT
Return

Subprog TIT_AMOTCLEL1(TRT,VALEUR)
Value Char TRT
Variable Char    VALEUR()
Gosub TIT From =TRT
VALEUR=TIT
End

######################################################################################
Subprog C_IDENT1(VALEUR)
Variable Char    VALEUR()
Local Char WOBJ
WOBJ=""
Case [M:AMC1]TYPZON
  When 1 : WOBJ="ATB"
  When 2 : WOBJ="AMK"
  When 3 : WOBJ="ACLA"
  When 4 : WOBJ="ASW"
Endcase
Call CONTROLE(WOBJ,"",VALEUR,"",mkstat) From CONTOBJ
End

Subprog AM_IDENT1(VALEUR)
Variable Char    VALEUR()
Read [AMC2]AMC0=[M:AMC1]TYPZON;VALEUR
If fstat=5
  Local Integer WTYPZON : WTYPZON=[M:AMC1]TYPZON
  Local Char WIDENT1 : WIDENT1=VALEUR
  Raz [M:AMC1]
  [M:AMC1]TYPZON=WTYPZON
  [M:AMC1]IDENT1=WIDENT1
  Gosub LIENS2
  Affzo [M:AMC1]
Endif
Case [M:AMC1]TYPZON
  When 1 : Call TEXTE([F:ATB]INTITFIC,[M:AMC1]DESIDENT1) From OBJDIV
  When 2 : Call TEXTE([F:AMK]INTMSK,[M:AMC1]DESIDENT1) From OBJDIV
  When 3 : Call TEXTE([F:ACLA]INTCLA,[M:AMC1]DESIDENT1) From OBJDIV
  When 4 : Call TEXTE([F:ASW]INTREP,[M:AMC1]DESIDENT1) From OBJDIV
Endcase
Affzo [M:AMC1]DESIDENT1
End


######################################################################################
Subprog AS_MOTCLE(VALEUR)
Variable Char    VALEUR()
End

Subprog C_MOTCLE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Read [ADZ]ADZ0=GLANGUE;VALEUR
    If !fstat : End : Endif
    If clalev([F:AD7])>0
     Read [AD7]ADZ0=GLANGUE;VALEUR
     If !fstat : End : Endif
    Endif
    GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
    mkstat = 2
Endif
End

######################################################################################
Subprog AS_INFBUL(VALEUR)
Variable Char    VALEUR()
End

Subprog C_INFBUL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Read [ADZ]ADZ0=GLANGUE;VALEUR
    If !fstat : End : Endif
    If clalev([F:AD7])>0
     Read [AD7]ADZ0=GLANGUE;VALEUR
     If !fstat : End : Endif
    Endif
    GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
    mkstat = 2
Endif
End

######################################################################################
