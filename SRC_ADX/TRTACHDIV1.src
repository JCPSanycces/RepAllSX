  Rollback
Endif
End

#---------------------------------------------------------#
# Traitement de la màj indicateur signature entête DA à 1 #
#---------------------------------------------------------#
$PSHAPP1
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
