#--------------------------------------------------------------#
# Traitement de la màj indicateur signature de la commande à 1 #
#--------------------------------------------------------------#
$POHAPP1
#----- Variables locales -----#
Local    Char    WMSG(100)
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
