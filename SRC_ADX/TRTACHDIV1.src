################################################################################
# TRTPSHCLE : Solde complet d'une DA avec pour chaque ligne       MBT 07/11/05 #
#             mise à jour du pré-engagement si nécessaire,                     #
#             annulation suivi et suppression de l'encours                     #
# ---------------------------------------------------------------------------- #
# Subprog TRTPSHCLE (WPSHNUM,WMSGFLG,WRET)                                     #
#   Sous-programme appelé dans les traitements du module achats.               #
#   Il y a toujours une transaction en cours.                                  #
# ---------------------------------------------------------------------------- #
#   WPSHNUM : Numéro de la demande d'achat                                     #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                       11-19 = Erreur avec GOK=0 si bloquant)                 #
################################################################################
Subprog TRTPSHCLE(WPSHNUM,WMSGFLG,WRET)
Value    Char    WPSHNUM
Value    Integer WMSGFLG
Variable Integer WRET
#-----
Local    Libelle WORIFLG : WORIFLG=1 : # Appel hors Workflow (annulation suivi)
#-----
If !clalev([F:PSD])  Local File PREQUISD  [PSD] : Endif
#-----
Gosub PSHCLE
End

################################################################################
# DIVPSHCLE : Solde complet d'une DA avec pour chaque ligne       MBT 07/11/05 #
#             mise à jour du pré-engagement si nécessaire                      #
#             et suppression de l'encours                                      #
# ---------------------------------------------------------------------------- #
# Subprog DIVPSHCLE (WPSHNUM,WMSGFLG)                                          #
#   Sous-programme appelé par l'action DIVPSHCLE.                              #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WPSHNUM : Numéro de la demande d'achat                                     #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVPSHCLE(WPSHNUM,WMSGFLG)
Value    Char    WPSHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
Local    Libelle WORIFLG : WORIFLG=0 : # Appel depuis le Workflow
#-----
Local File PREQUISD  [PSD] : # Il faut réouvrir à cause du "Link" workflow
#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_PSHCLE
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub PSHCLE
If GOK=-1  Goto ROLL_PSHCLE : Endif
If GOK=0   Goto AB_PSHCLE   : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End
#-----
$ROLL_PSHCLE
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  End  Else  Goto TR_PSHCLE : Endif
Else
  End
Endif
#-----
$AB_PSHCLE
If [L]WADXLOG=0
  Rollback
Endif
End

#---------------------------------------------------#
# Traitement du solde complet d'une demande d'achat #
#---------------------------------------------------#
$PSHCLE
#----- Variables locales -----#
Local    Char    WFCY(GLONFCY), WPARAME(10), WMSG(100)
Local    Integer WPSDLIN, WLINCLEFLG, WCLELINNBR, WCLEFLG, WFLAG
Local    Integer SAV_GAPPPSH  : [L]SAV_GAPPPSH=GAPPPSH
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
#-----
If [L]WPSHNUM=""  [L]WRET=11 : Gosub TRT_ERR_PSHCLE : Return : Endif
#----- Contrôle lock logique -----#
Call JELOCKE("PSH"+[L]WPSHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="PSH"+[L]WPSHNUM
  If fstat        [L]WRET=12 : Gosub TRT_ERR_PSHCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#-----
If !clalev([F:PSH])  Local File PREQUIS   [PSH] : Endif
If !clalev([F:GAC])  Local File GACCOUNT  [GAC] : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO] : Endif
If !clalev([F:ORD])  Local File ORDERS    [ORD] : Endif
If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
#----- Lecture entête demande d'achat -----#
Read [PSH] PSH0=[L]WPSHNUM
If fstat
  GOK=0 : [L]WRET=14 : Gosub TRT_ERR_PSHCLE : Goto FIN_PSHCLE
Endif
[L]WCLELINNBR=[F:PSH]CLELINNBR
[L]WCLEFLG   =[F:PSH]CLEFLG
#-----
[L]WFCY=[F:PSH]PSHFCY
Call PARAML([L]WFCY,"APPPSH",[L]WPARAME) From ADOVAL
GAPPPSH=val([L]WPARAME)
Call PARAML([L]WFCY,"PSHAPPHEA",[L]WPARAME) From ADOVAL
GPSHAPPHEA=val([L]WPARAME)
#----- Mise à jour indicateur solde sur toutes les lignes de la DA -----#
For [PSD] PSD0 Where PSHNUM=[L]WPSHNUM & LINCLEFLG<>2
  [L]WPSDLIN   =[F:PSD]PSDLIN
  [L]WLINCLEFLG=[F:PSD]LINCLEFLG
  Readlock [PSD] Curr
  If fstat=1
    GOK=-1  : GLOCK="$PREQUISD"-[L]WPSHNUM-num$([L]WPSDLIN)
    [L]WRET=16 : Gosub TRT_ERR_PSHCLE : Break
  Elsif fstat
    GOK=0   : Call RSTA("PSD",[L]WPSHNUM-num$([L]WPSDLIN)) From GLOCK
    [L]WRET=17 : Gosub TRT_ERR_PSHCLE : Break
  Endif
  #-----
  Gosub MAJ_PSDCLE : If GOK<1  Break : Endif
  #-----
  Rewrite [PSD]
  If fstat
    GOK=0   : Call FSTA("PSD") From GLOCK
    [L]WRET=18 : Gosub TRT_ERR_PSHCLE : Break
  Endif
Next
If GOK<1  Goto FIN_PSHCLE : Endif
#----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPSH>1 & [L]WORIFLG=1 & [F:PSH]APPFLG<3 & GPSHAPPHEA=2
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  Call ANNULE_SUIVI("PSH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  If GOK<1  Goto FIN_PSHCLE  Else  Raz [L]WRET : Endif
Endif
#----- Mise à jour indicateur solde sur l'entête de la DA -----#
Raz [L]WFLAG
If [F:PSH]CLELINNBR<>[F:PSH]LINNBR | [F:PSH]CLEFLG<>2
  [L]WCLELINNBR=[F:PSH]LINNBR : [L]WCLEFLG=2 : [L]WFLAG=1
Endif
If [L]WFLAG=1
  Update [PSH] Where PSHNUM=[L]WPSHNUM With CLELINNBR=[L]WCLELINNBR, CLEFLG=[L]WCLEFLG
  If fstat
    GOK=0   : Call FSTA("PSH") From GLOCK
    [L]WRET=15 : Gosub TRT_ERR_PSHCLE : Goto FIN_PSHCLE
  Endif
Endif
#-----
$FIN_PSHCLE
If [L]WLOCK  Unlock="PSH"+[L]WPSHNUM : Endif
GAPPPSH=[L]SAV_GAPPPSH
#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK & dim([L]SAV_GOK)>0
    GOK=[L]SAV_GOK
Endif
Return
#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
# 11 = WPSHNUM Paramètre non renseigné                            #
# 12 = $PREQUIS xxxxxxxx Modification en cours sur un autre poste #
# 13 = Erreur d'accès sur le fichier PREQUIS xxxxxxxx             #
# 14 = xxxxxxxxxx Demande d'achat introuvable !                   #
# 15 = Erreur d'écriture sur le fichier PREQUIS xxxxxxxx          #
# 16 = Erreur d'accès sur le fichier PREQUISD xxxxxxxx            #
# 17 = xxxxxxxxxx 9999 Demande d'achat introuvable !              #
# 18 = Erreur d'écriture sur le fichier PREQUISD xxxxxxxx         #
# 19 = xxxxxxxxxx Problème de mise à jour des encours             #
#-----------------------------------------------------------------#
$TRT_ERR_PSHCLE
Case [L]WRET
  When 11 : [L]WMSG="WPSHNUM"-mess(136,199,1)               : GOK=0
  When 12 : [L]WMSG="$PREQUIS"-[L]WPSHNUM-mess(10,100,1)    : GOK=0
  When 13 : [L]WMSG=mess(12,100,1)-"PREQUIS"-[L]WPSHNUM
  When 14 : [L]WMSG=[L]WPSHNUM-mess(220,197,1)
  When 15 : [L]WMSG=mess(13,100,1)-"PREQUIS"-[L]WPSHNUM
  When 16 : [L]WMSG=mess(12,100,1)-"PREQUISD"-[L]WPSHNUM
  When 17 : [L]WMSG=[L]WPSHNUM-num$([L]WPSDLIN)-mess(220,197,1)
  When 18 : [L]WMSG=mess(13,100,1)-"PREQUISD"-[L]WPSHNUM
  When 19 : [L]WMSG=[F:PSD]ITMREF-mess(92,197,1)
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


################################################################################
# TRTPOHCLE : Solde complet d'une commande avec pour chaque ligne MBT 27/12/05 #
#             mise à jour de l'engagement si nécessaire,                       #
#             annulation suivi et suppression de l'encours                     #
# ---------------------------------------------------------------------------- #
# Subprog TRTPOHCLE (WPOHNUM,WMSGFLG,WRET)                                     #
#   Sous-programme appelé dans les traitements du module achats.               #
#   Il y a toujours une transaction en cours.                                  #
# ---------------------------------------------------------------------------- #
#   WPOHNUM : Numéro de la commande d'achat                                    #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                       11-19 = Erreur avec GOK=0 si bloquant)                 #
################################################################################
Subprog TRTPOHCLE(WPOHNUM,WMSGFLG,WRET)
Value    Char    WPOHNUM
Value    Integer WMSGFLG
Variable Integer WRET
#-----
Local    Libelle WORIFLG : WORIFLG=1 : # Appel hors Workflow (annulation suivi)
#-----
If !clalev([F:POQ])  Local File PORDERQ  [POQ] : Endif
# Issue 106506 - 2015-05-05 by SR : Landed Cost
If !clalev([F:SHD])  Local File SHIPMENTD  [SHD] : Endif
#-----
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
If !GSERVEUR
# Ouverture de la trace "solde du document"
    Call OUVRE_TRACE(mess(654,197,1)) From LECFIC
Endif
Call DEBTRANS From GLOCK
#-----
$TR_TRTPOHCLE
GOK=1
Trbegin ADOVAL
Gosub POHCLE
If GOK=-1  Goto ROLL_TRTPOHCLE : Endif
If GOK=0   Goto AB_TRTPOHCLE   : Endif
Commit
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
If !GSERVEUR
    Call FERME_TRACE From LECFIC
Endif
End
#-----
$ROLL_TRTPOHCLE
Rollback : Call ROLL From GLOCK
If GROLL  End  Else  Goto TR_TRTPOHCLE : Endif
#-----
$AB_TRTPOHCLE
Rollback
End


################################################################################
# DIVPOHCLE : Solde complet d'une commande avec pour chaque ligne MBT 27/12/05 #
#             mise à jour del'engagement si nécessaire                         #
#             et suppression de l'encours                                      #
# ---------------------------------------------------------------------------- #
# Subprog DIVPOHCLE (WPOHNUM,WMSGFLG)                                          #
#   Sous-programme appelé par l'action DIVPOHCLE.                              #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WPOHNUM : Numéro de la commande d'achat                                    #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVPOHCLE(WPOHNUM,WMSGFLG)
Value    Char    WPOHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
Local    Libelle WORIFLG : WORIFLG=0 : # Appel depuis le Workflow
#-----
Local File PORDERQ  [POQ] : # Il faut réouvrir à cause du "Link" workflow
#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_POHCLE
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub POHCLE
If GOK=-1  Goto ROLL_POHCLE : Endif
If GOK=0   Goto AB_POHCLE   : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End
#-----
$ROLL_POHCLE
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  End  Else  Goto TR_POHCLE : Endif
Else
  End
Endif
#-----
$AB_POHCLE
If [L]WADXLOG=0
  Rollback
Endif
End

#----------------------------------------------------#
# Traitement du solde complet d'une commande d'achat #
#----------------------------------------------------#
$POHCLE
#----- Variables locales -----#
Local Char    WFCY(GLONFCY), WPARAME(10), WMSG(100)
Local Integer WPOPLIN, WLINCLEFLG, WCLELINNBR, WCLEFLG, WFLAG
Local Decimal WORDNOT, WORDATI
Local Libelle WTRAIT
Local Integer SAV_GOK                : [L]SAV_GOK      =GOK
Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE =GSOCIETE
Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV=GLOCALDEV
Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP  =GFINRSP
Local Integer SAV_GAPPPOH            : [L]SAV_GAPPPOH  =GAPPPOH
Local Libelle WLOCK
Local Integer SIGN
#-----
GOK=1 : Raz [L]WRET
If [L]WPOHNUM=""  [L]WRET=11 : Gosub TRT_ERR_POHCLE : Return : Endif
#----- Contrôle lock logique -----#
Call JELOCKE("POH"+[L]WPOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="POH"+[L]WPOHNUM
  If fstat        [L]WRET=12 : Gosub TRT_ERR_POHCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#-----
If !clalev([F:POH])  Local File PORDER    [POH]  : Endif
If !clalev([F:POP])  Local File PORDERP   [POP]  : Endif
If !clalev([F:ITM])  Local File ITMMASTER [ITM]  : Endif
If !clalev([F:MVS])  Local File BPSUPPMVT [MVS]  : Endif
If !clalev([F:GAC])  Local File GACCOUNT  [GAC]  : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO]  : Endif
If !clalev([F:ORD])  Local File ORDERS    [ORD]  : Endif
# Issue 113200 - 2015-12-17 by SR
If !clalev([F:ITV])   Local File ITMMVT   [ITV]  :  Endif
If !clalev([F:SHD])   Local File SHIPMENTD [SHD] :  Endif
# End issue 113200

If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
If !clalev([M:SBCK]) Local Mask SBCK     [SBCK] : Endif
#----- Lecture entête commande d'achat -----#
Read [POH] POH0=[L]WPOHNUM
If fstat
  GOK=0 : [L]WRET=14 : Gosub TRT_ERR_POHCLE : Goto FIN_POHCLE
Endif
[L]WCLELINNBR=[F:POH]CLELINNBR
[L]WCLEFLG   =[F:POH]CLEFLG
#-----
[L]WFCY=[F:POH]POHFCY
Call GETDEV([L]WFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[L]WFCY : Endif
Call PARAML([L]WFCY,"APPPOH",[L]WPARAME) From ADOVAL
GAPPPOH=val([L]WPARAME)
#----- Mise à jour indicateur solde sur toutes les lignes de la commande -----#
Raz [L]WORDNOT, [L]WORDATI
For [POQ] POQ0 Where POHNUM=[L]WPOHNUM & LINCLEFLG<>2
  [L]WPOPLIN   =[F:POQ]POPLIN
  [L]WLINCLEFLG=[F:POQ]LINCLEFLG
  Readlock [POQ] Curr
  If fstat=1
    GOK=-1  : GLOCK="$PORDERQ"-[L]WPOHNUM-num$([L]WPOPLIN)
    [L]WRET=16 : Gosub TRT_ERR_POHCLE : Break
  Elsif fstat
    GOK=0   : Call RSTA("POQ",[L]WPOHNUM-num$([L]WPOPLIN)) From GLOCK
    [L]WRET=17 : Gosub TRT_ERR_POHCLE : Break
  Endif
  #-----
  # Issue 83217 - 2012-07-02 by SR : Ne sert plus à rien
  # Issue 80684 - 2012-03-14 by MUARN : ne pas solder commande si commande vente en cours de livraison
#  If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif
#  Read [SOH] SOH0=[F:POH]OCNNUM
#  If [F:SOH]LASDLVNUM <> ""
#    GOK=0
#    [L]WRET=23 : Gosub TRT_ERR_POHCLE : Goto FIN_POHCLE
#  Endif

  Gosub MAJ_POQCLE : If GOK<1  Break : Endif
  #-----
  Rewrite [POQ]
  If fstat
    GOK=0   : Call FSTA("POQ") From GLOCK
    [L]WRET=18 : Gosub TRT_ERR_POHCLE : Break
  Endif
  # Issue 82703 - 2013-03-28 by SR : Régul valo stock
  If [F:POQ]RCPQTYSTU <> 0
      Call REGPRIX_FCC(2,"",0) From TRTACHFAC1
      If GOK<1 : Break : Endif
  Endif
Next
If GOK<1  Goto FIN_POHCLE : Endif
#----- Màj nbre lignes soldées et indicateur solde sur l'entête de la commande -----#
[L]WCLEFLG=[F:POH]CLEFLG
Raz [L]WFLAG
If [F:POH]CLELINNBR<>[F:POH]LINNBR | [F:POH]CLEFLG<>2
  [L]WCLELINNBR=[F:POH]LINNBR : [L]WCLEFLG=2 : [L]WFLAG=1
Endif
If [L]WFLAG=1
  # Issue 101281 - 2014-08-26 by MUARN : mise à jour champs UPDDAT
#  Update [POH] Where POHNUM=[L]WPOHNUM
#&              With  CLELINNBR=[L]WCLELINNBR, CLEFLG=[L]WCLEFLG, EXPNUM=[C]EXPORT
  Update [POH] Where POHNUM=[L]WPOHNUM
&              With  CLELINNBR=[L]WCLELINNBR, CLEFLG=[L]WCLEFLG, EXPNUM=[C]EXPORT,UPDDAT=date$
  If fstat
    GOK=0   : Call FSTA("POH") From GLOCK
    [L]WRET=15 : Gosub TRT_ERR_POHCLE : Goto FIN_POHCLE
  Endif
  [F:POH]CLEFLG=[L]WCLEFLG
Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOH>1 & [L]WORIFLG=1 & [F:POH]CLEFLG=2 & [F:POH]APPFLG<3
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  If [F:POH]POHTYP=1
    Call ANNULE_SUIVI("POH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Else
    Call ANNULE_SUIVI("POC",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Endif
  If GOK<1  Goto FIN_POHCLE : Endif
Endif
#----- Mise à jour en commande dans mvts fournisseurs -----#
Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POH]POHNUM,[L]WORDNOT,[L]WORDATI,[F:POH]TTVORD) From TRTBPMVT
If GOK<1  Goto FIN_POHCLE : Endif
#----- Solde de la commande de vente inter-sites si nécessaire -----#
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif
  Read [SOH] SOH0=[F:POH]OCNNUM
  #----- Ne pas solder la commande de vente si déjà soldée -----#
  If !fstat & [F:SOH]ORDSTA<>2
    Call GENSOH("S",1,[L]WRET) From TRTVENISOC
    If GOK<1
      [L]WRET=22 : Gosub TRT_ERR_POHCLE : Goto FIN_POHCLE
    Endif
  Endif
Endif
#-----
$FIN_POHCLE
If [L]WLOCK  Unlock="POH"+[L]WPOHNUM : Endif
#----- Rétablissement des globales -----#
GSOCIETE =[L]SAV_GSOCIETE
GLOCALDEV=[L]SAV_GLOCALDEV
GFINRSP  =[L]SAV_GFINRSP
GAPPPOH  =[L]SAV_GAPPPOH
#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK & dim([L]SAV_GOK)>0
    GOK=[L]SAV_GOK
Endif
Return
#------------------------------------------------------------------------------#
#                           Traitement des erreurs                             #
# -----------------------------------------------------------------------------#
# 11 = WPOHNUM Paramètre non renseigné                                         #
# 12 = $PORDER xxxxxxxx Modification en cours sur un autre poste               #
# 13 = Erreur d'accès sur le fichier PORDER xxxxxxxx                           #
# 14 = xxxxxxxxxx Commande introuvable !                                       #
# 15 = Erreur d'écriture sur le fichier PORDER xxxxxxxx                        #
# 16 = Erreur d'accès sur le fichier PORDERQ xxxxxxxx                          #
# 17 = xxxxxxxxxx 9999 Commande introuvable !                                  #
# 18 = Erreur d'écriture sur le fichier PORDERQ xxxxxxxx                       #
# 19 = xxxxxxxxxx Problème de mise à jour des encours                          #
# 22 = xxxxxxxxxx Inter-sites : La commande de vente n'existe pas              #
# 23 = xxxxxxxxxx Inter-sites : La commande de vente est en cours de livraison #
#------------------------------------------------------------------------------#
$TRT_ERR_POHCLE
Case [L]WRET
  When 11 : [L]WMSG="WPOHNUM"-mess(136,199,1)              : GOK=0
  When 12 : [L]WMSG="$PORDER"-[L]WPOHNUM-mess(10,100,1)    : GOK=0
  When 13 : [L]WMSG=mess(12,100,1)-"PORDER"-[L]WPOHNUM
  When 14 : [L]WMSG=[L]WPOHNUM-mess(359,197,1)
  When 15 : [L]WMSG=mess(13,100,1)-"PORDER"-[L]WPOHNUM
  When 16 : [L]WMSG=mess(12,100,1)-"PORDERQ"-[L]WPOHNUM
  When 17 : [L]WMSG=[L]WPOHNUM-num$([L]WPOPLIN)-mess(359,197,1)
  When 18 : [L]WMSG=mess(13,100,1)-"PORDERQ"-[L]WPOHNUM
  When 19 : [L]WMSG=[F:POQ]ITMREF-mess(92,197,1) # Issue 110325/125 - 2016-05-23 by SR : erreur de classe [F]
  When 22 : [L]WMSG=[F:POH]OCNNUM-mess(274,194,1)
  When 23 : [L]WMSG=[F:POH]OCNNUM-mess(427,194,1) # Issue 80684 - 2012-03-14 by MUARN : inter-site commande vente livrée
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


################################################################################
# TRTPSDCLE : Solde d'une ligne de DA avec désengagement si       MBT 08/11/05 #
#             besoin, annulation suivi et suppression de l'encours             #
# ---------------------------------------------------------------------------- #
# Subprog TRTPSDCLE (WPSHNUM,WPSDLIN,WMSGFLG,WRET)                             #
#   Sous-programme appelé dans les traitements du module achats.               #
#   Il y a toujourd une transaction en cours.                                  #
# ---------------------------------------------------------------------------- #
#   WPSHNUM : Numéro de la demande d'achat                                     #
#   WPSDLIN : Numéro de la ligne                                               #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                       11-19 = Erreur avec GOK=0 si bloquant)                 #
################################################################################
Subprog TRTPSDCLE(WPSHNUM,WPSDLIN,WMSGFLG,WRET)
Value    Char    WPSHNUM
Value    Integer WPSDLIN
Value    Integer WMSGFLG
Variable Integer WRET
#-----
Local    Libelle WORIFLG : WORIFLG=1 : # Appel hors Workflow (annulation suivi)
#-----
Gosub PSDCLE
End

################################################################################
# DIVPSDCLE : Solde d'une ligne de DA avec désengagement si       MBT 08/11/05 #
#             besoin et suppression de l'encours                               #
# ---------------------------------------------------------------------------- #
# Subprog DIVPSDCLE (WPSHNUM,WPSDLIN,WMSGFLG)                                  #
#   Sous-programme appelé par l'action DIVPSDCLE.                              #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WPSHNUM : Numéro de la demande d'achat                                     #
#   WPSDLIN : Numéro de la ligne                                               #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVPSDCLE(WPSHNUM,WPSDLIN,WMSGFLG)
Value    Char    WPSHNUM
Value    Integer WPSDLIN
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET
Local    Libelle WADXLOG
Local    Libelle WORIFLG : WORIFLG=0 : # Appel depuis le Workflow
#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_PSDCLE
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub PSDCLE
If GOK=-1  Goto ROLL_PSDCLE : Endif
If GOK=0   Goto AB_PSDCLE   : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End
#-----
$ROLL_PSDCLE
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  End  Else  Goto TR_PSDCLE : Endif
Else
  End
Endif
#-----
$AB_PSDCLE
If [L]WADXLOG=0
  Rollback
Endif
End

#---------------------------------------#
# Traitement du solde d'une ligne de DA #
#---------------------------------------#
$PSDCLE
#----- Variables locales -----#
Local    Char    WFCY(GLONFCY), WPARAME(10), WMSG(100)
Local    Integer WLINCLEFLG, WCLELINNBR, WCLEFLG
Local    Integer SAV_GAPPPSH  : [L]SAV_GAPPPSH=GAPPPSH
Local    Integer SAV_GOK      : [L]SAV_GOK=GOK : GOK=1 : Raz [L]WRET
Local    Libelle WLOCK
#-----
If [L]WPSHNUM=""  [L]WRET=11 : Gosub TRT_ERR_PSDCLE : Return : Endif
If [L]WPSDLIN=0   [L]WRET=11 : Gosub TRT_ERR_PSDCLE : Return : Endif
#----- Contrôle lock logique -----#
Call JELOCKE("PSH"+[L]WPSHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="PSH"+[L]WPSHNUM
  If fstat        [L]WRET=12 : Gosub TRT_ERR_PSDCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#-----
If !clalev([F:PSH])  Local File PREQUIS   [PSH] : Endif
If !clalev([F:PSD])  Local File PREQUISD  [PSD] : Endif
If !clalev([F:GAC])  Local File GACCOUNT  [GAC] : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO] : Endif
If !clalev([F:ORD])  Local File ORDERS    [ORD] : Endif
If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
#----- Lecture entête demande d'achat -----#
Read [PSH] PSH0=[L]WPSHNUM
If fstat
  GOK=0 : [L]WRET=14 : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Endif
[L]WCLELINNBR=[F:PSH]CLELINNBR
[L]WCLEFLG   =[F:PSH]CLEFLG
#-----
[L]WFCY=[F:PSH]PSHFCY
Call PARAML([L]WFCY,"APPPSH",[L]WPARAME) From ADOVAL
GAPPPSH=val([L]WPARAME)
Call PARAML([L]WFCY,"PSHAPPHEA",[L]WPARAME) From ADOVAL
GPSHAPPHEA=val([L]WPARAME)
#----- Mise à jour indicateur solde sur la ligne de la DA -----#
Readlock [PSD] PSD0=[L]WPSHNUM;[L]WPSDLIN
If fstat=1
  GOK=-1  : GLOCK="$PREQUISD"-[L]WPSHNUM-num$([L]WPSDLIN)
  [L]WRET=16 : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Elsif fstat
  GOK=0   : Call RSTA("PSD",[L]WPSHNUM-num$([L]WPSDLIN)) From GLOCK
  [L]WRET=17 : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Endif
If [F:PSD]LINCLEFLG=2
  [L]WRET=20 : Unlock [PSD] : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Endif
#-----
Gosub MAJ_PSDCLE : If GOK<1  Goto FIN_PSDCLE : Endif
#-----
Rewrite [PSD]
If fstat
  GOK=0   : Call FSTA("PSD") From GLOCK
  [L]WRET=18 : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Endif
#----- Mise à jour indicateur solde sur l'entête de la DA -----#
[L]WCLELINNBR=min([F:PSH]CLELINNBR+1,[F:PSH]LINNBR)
If [L]WCLELINNBR<[F:PSH]LINNBR  [L]WCLEFLG=1  Else  [L]WCLEFLG=2 : Endif
Update [PSH] Where PSHNUM=[L]WPSHNUM With CLELINNBR=[L]WCLELINNBR, CLEFLG=[L]WCLEFLG
If fstat
  GOK=0   : Call FSTA("PSH") From GLOCK
  [L]WRET=15 : Gosub TRT_ERR_PSDCLE : Goto FIN_PSDCLE
Endif
#-----
$FIN_PSDCLE
If [L]WLOCK  Unlock="PSH"+[L]WPSHNUM : Endif
GAPPPSH=[L]SAV_GAPPPSH
#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK & dim([L]SAV_GOK)>0
    GOK=[L]SAV_GOK
Endif
Return
#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
# 11 = WPSHNUM Paramètre non renseigné                            #
# 12 = $PREQUIS xxxxxxxx Modification en cours sur un autre poste #
# 13 = Erreur d'accès sur le fichier PREQUIS xxxxxxxx             #
# 14 = xxxxxxxxxx Demande d'achat introuvable !                   #
# 15 = Erreur d'écriture sur le fichier PREQUIS xxxxxxxx          #
# 16 = Erreur d'accès sur le fichier PREQUISD xxxxxxxx            #
# 17 = xxxxxxxxxx 9999 Demande d'achat introuvable !              #
# 18 = Erreur d'écriture sur le fichier PREQUISD xxxxxxxx         #
# 19 = xxxxxxxxxx Problème de mise à jour des encours             #
# 20 = xxxxxxxxxx 9999 Ligne déjà soldée, solde impossible !      #
#-----------------------------------------------------------------#
$TRT_ERR_PSDCLE
Case [L]WRET
  When 11 : [L]WMSG="WPSHNUM-WPSDLIN"-mess(136,199,1)           : GOK=0
  When 12 : [L]WMSG="$PREQUIS"-[L]WPSHNUM-mess(10,100,1)        : GOK=0
  When 13 : [L]WMSG=mess(12,100,1)-"PREQUIS"-[L]WPSHNUM
  When 14 : [L]WMSG=[L]WPSHNUM-mess(220,197,1)
  When 15 : [L]WMSG=mess(13,100,1)-"PREQUIS"-[L]WPSHNUM
  When 16 : [L]WMSG=mess(12,100,1)-"PREQUISD"-[L]WPSHNUM
  When 17 : [L]WMSG=[L]WPSHNUM-num$([L]WPSDLIN)-mess(220,197,1)
  When 18 : [L]WMSG=mess(13,100,1)-"PREQUISD"-[L]WPSHNUM
  When 19 : [L]WMSG=[F:PSD]ITMREF-mess(92,197,1)
  When 20 : [L]WMSG=[L]WPSHNUM-num$([L]WPSDLIN)-mess(168,194,1) : GOK=0
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


#--------------------------------------------------------#
#  Mises à jour dans le cas du solde d'une ligne de DA   #
# ------------------------------------------------------ #
# - Màj pré-engagement                                   #
# - Annulation du workflow                               #
# - Suppression de l'encours                             #
# - Positionnement du flag solde et date/opérateur modif #
#--------------------------------------------------------#
$MAJ_PSDCLE
#----- Mise à jour pré-engagement -----#
If GAPPPSH<2 | [F:PSD]CMMPRPFLG=1
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD2",3,[L]WRET) From TRTACHDIV1
  If GOK<1  Return  Else  Raz [L]WRET : Endif
  [F:PSD]CMMPRPFLG=0
Endif
#----- Postionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPSH>1 & [L]WORIFLG=1 & [F:PSD]LINAPPFLG<3 & GPSHAPPHEA<2
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  Call ANNULE_SUIVI("PSD",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  If GOK<1  Return  Else  Raz [L]WRET : Endif
Endif
#----- Suppression de l'encours -----#
If [F:PSD]WIPNUM<>""
  [M:ORDK]MAJCOD="A"
  [M:ORDK]WIPTYP=2
  [M:ORDK]WIPNUM=[F:PSD]WIPNUM
  [M:ORDK]ITMREF=[F:PSD]ITMREF
  Call WIP From TRTWIP
  If GOK<1  [L]WRET=19 : Gosub TRT_ERR_PSHCLE : Return : Endif
Endif
#-----
[F:PSD]LINCLEFLG=2
[F:PSD]UPDDAT   =date$
[F:PSD]UPDUSR   =GUSER
Return


#-----------------------------------------------------------#
# Mises à jour dans le cas du solde d'une ligne de commande #
# --------------------------------------------------------- #
# - Màj qté commandée de l'article-site                     #
# - Màj engagement                                          #
# - Annulation du workflow                                  #
# - Suppression de l'encours                                #
# - Màj opération de sous-traitance                         #
# - Positionnement du flag solde et date/opérateur modif    #
#-----------------------------------------------------------#
$MAJ_POQCLE
If [F:POQ]RCPQTYPUU<[F:POQ]QTYPUU
  #----- Cumuls des montants restant en commande -----#
  Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
  If fstat  Raz [F:POP] : Endif
  [L]SIGN=-1 : Gosub CAL_MVS From SUBPOHA
  #----- Mise à jour de la quantité commandée dans l'article-site -----#
  If [F:POQ]WIPNUM<>""
    Call LECITV([F:POQ]PRHFCY,[F:POQ]ITMREF,"",[L]WRET) From STKLIB
    If GOK<1  [L]WRET=0 : Return : Endif
    If [L]WRET=0
      Update [ITV] Where ITMREF=[F:POQ]ITMREF & STOFCY=[F:POQ]PRHFCY
&                  With ORDSTO-=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
      If fstat  GOK=0 : Call FSTA("ITV") From GLOCK : Return : Endif
    Endif
  Endif
Endif
#----- Mise à jour engagement -----#
[F:POQ]LINCLEFLG=2
Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ2",[L]WMSGFLG,[L]WRET) From TRTACHDIV1
If GOK<1  Return  Else  Raz [L]WRET : Endif
#----- Mise à jour opération de sous-traitance -----#
If find([F:POQ]VCRTYPORI,10,36) : # Si achat sous-traitance
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
  Endif
  If [F:POQ]RCPQTYSTU=0
    [M:SBCK]MAJCOD="A"
  Else
    [M:SBCK]MAJCOD="M"
  Endif
  [M:SBCK]VCRNUM=[F:POQ]POHNUM
  [M:SBCK]VCRLIN=[F:POQ]POPLIN
  [M:SBCK]VCRSEQ=[F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]BPAADD=[F:POQ]SCOADD
  [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU : # ligne cde soldée donc qté commandée = qté réceptionnée
  [M:SBCK]ORDDAT=[F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT=[F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,[L]WRET) From TRTDEV
  [M:SBCK]EXTPRI=arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  [M:SBCK]OFS   =[F:POQ]OFS
  [M:SBCK]MSGFLG=1
  [M:SBCK]CLEFLG=[F:POQ]LINCLEFLG
  [M:SBCK]ITMREFORI=[F:POQ]ITMREFORI # Issue 109433 by GA 09/2015 idem SUBPOHA
  [M:SBCK]VCRTYPORI=[F:POQ]VCRTYPORI # Issue 109433 by GA 09/2015 idem SUBPOHA
  [M:SBCK]VCRNUMORI=[F:POQ]VCRNUMORI # Issue 92866 GA 09/2013
  [M:SBCK]VCRLINORI=[F:POQ]VCRLINORI # Issue 92866 GA 09/2013
  [M:SBCK]VCRSEQORI=[F:POQ]VCRSEQORI # Issue 92866 GA 09/2013
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    # Issue 109433 by GA 09/2015 idem SUBPOHA
    #GMESSAGE=mess(96,193,1) : GERR=1 : GOK=0 : Return
      If [M:SBCK]VCRTYPORI=10
        GMESSAGE=mess(96,193,1)-":"-GMESSAGE
      Elsif [M:SBCK]VCRTYPORI=36
        GMESSAGE=mess(913,196,1)-":"-GMESSAGE
      Endif
      GERR=1 : GOK=0 : Return
  Endif
Endif

# solde = suppression affectations
If [F:POQ]LINCLEFLG = 2 : Gosub SUP_MTO_POQ From PURMTOLIB : Endif

#----- Suppression de l'encours -----#
If [F:POQ]WIPNUM<>""
  [M:ORDK]MAJCOD="A"
  [M:ORDK]WIPTYP=[F:POQ]WIPTYP
  [M:ORDK]WIPNUM=[F:POQ]WIPNUM
  [M:ORDK]ITMREF=[F:POQ]ITMREF
  Call WIP From TRTWIP
  If GOK<1  [L]WRET=19 : Gosub TRT_ERR_POHCLE : Return : Endif
Endif

# Issue 106506 - 2015-05-05 by SR : Landed Cost
Gosub MAJ_SHD
# End issue 106506
#-----
[F:POQ]RCPCLEFLG=1
[F:POQ]UPDDAT   =date$
[F:POQ]UPDUSR   =GUSER
[F:POQ]EXPNUM   =[C]EXPORT
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
[L]WTRAIT=1 : [L]WCLEFLG=1
Gosub POINT_POHCLE From TRTACHCDE1
#-----
Return

# Issue 106506 - 2015-05-05 by SR : Landed Cost
$MAJ_SHD
If [F:POQ]LINCLEFLG = 2
   # Solde
   # Issue 110948 - 2015-09-10 by SR : Seulement les non encore soldées
   Update [SHD] Where POHNUM = [F:POQ]POHNUM & POPLIN = [F:POQ]POPLIN & POQSEQ = [F:POQ]POQSEQ
&                   & CLEFLG <> 2  With CLEFLG=2
Else
   Update [SHD] Where POHNUM = [F:POQ]POHNUM & POPLIN = [F:POQ]POPLIN & POQSEQ = [F:POQ]POQSEQ
&                   & (SHIQTYPUU - RCPQTYPUU > 0)  With CLEFLG=1
Endif
# End issue 110948
Return
# End issue 106506

################################################################################
# ANNULE_SUIVI : S/P Positionnement indicateur "Annulé"           MBT 20/12/05 #
#                sur les lignes de suivi de workflow                           #
# ---------------------------------------------------------------------------- #
# Subprog ANNULE_SUIVI(WOBJET,WMOTIF,WMSGFLG,WRET)                             #
# ---------------------------------------------------------------------------- #
#   WOBJET  : Code l'objet ("PSH","PSD","POH","POC")                           #
#   WMOTIF  : Motif de l'annulation                                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = message dans une trace)         #
#   WRET    : Code retour ( 0 = Ok avec GOK=1,                                 #
#                           1 = Erreur avec GOK=0 si bloquant)                 #
################################################################################
Subprog ANNULE_SUIVI(WOBJET,WMOTIF,WMSGFLG,WRET)
Value    Char    WOBJET
Value    Char    WMOTIF
Value    Integer WMSGFLG
Variable Integer WRET
#----- Variables locales -----#
Local    Integer WTYPEVT,     WTYPEVT2
Local    Char    WCODEVT(10), WCODEVT2(10)
#-----
Raz [L]WRET
Case [L]WOBJET
  When "PSH" : [L]WTYPEVT=2 : [L]WCODEVT="PSH" : [L]WTYPEVT2=9 : [L]WCODEVT2="PSHSIG"
  When "PSD" : [L]WTYPEVT=2 : [L]WCODEVT="PSH" : [L]WTYPEVT2=9 : [L]WCODEVT2="PSDSIG"
  When "POH" : [L]WTYPEVT=2 : [L]WCODEVT="POH" : [L]WTYPEVT2=9 : [L]WCODEVT2="POHSIG"
  When "POC" : [L]WTYPEVT=2 : [L]WCODEVT="POC" : [L]WTYPEVT2=9 : [L]WCODEVT2="POCSIG"
Endcase
#-----
Call ANNULE_SUIVI([L]WTYPEVT,[L]WCODEVT,0,[L]WRET,[L]WMOTIF,0) From AWRKDEL
If GOK<1  Gosub ERR_ANNULE_SUIVI : End : Endif
End
$ERR_ANNULE_SUIVI
If [L]WMSGFLG=1
  Case [L]WOBJET
    When "PSH", "PSD" : If GPURTRACE=1  GPURTRACE=2  Else  GPURTRACE=1 : Endif
    When "POH"        : If GPURTRACE=1  GPURTRACE=2 : Endif
    When "POC"
  Endcase
Endif
Return


#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 22/09/09 #
#                     de la ligne d'un document achat                   #
# --------------------------------------------------------------------- #
# Subprog MAJ_CALTAX_LIG(ABREV,NOL)                                     #
#   ABREV  : Abréviation de l'écran ou de la table ("PSD","PSH1"...etc) #
#   NOL    : indice de la ligne (nolign-1) si ABREV = Abréviation écran #
#########################################################################
Subprog MAJ_CALTAX_LIG(ABREV,NOL)
Value  Char     ABREV
Value  Shortint NOL

#----- Si c'est le composé (produit fini), pas de chiffrage -----#
# Issue 102669 - 2014-10-03 by MUARN : point d'entrée non documenté pour un spé
GPE = 1
#CHECK IGNORE BEGIN
[V]GPOINT="CUSTAXE" : Gosub ENTREE From EXEFNC
#CHECK IGNORE END
If GPE =1
  If ABREV="POH2" & [M:POH2]LINTYP(NOL)=2  End : Endif
  If ABREV="PTH1" & [M:PTH1]LINTYP(NOL)=2  End : Endif
Endif

#----- Variables locales -----#
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#Local  Libelle  X : X=3+4*func AFNC.ACTIV("PTX")
Local  Libelle  X : X=3+4*func TRTX3.ACTIV_PTX
Local  Shortint I
Local  Integer  TYPREG, STAT
Local  Decimal  BASE, MONTANT(1..X), MONTDED(1..X)
Local  Char     TAXE(GLONVAT)(1..X)
Local  Decimal  WRND
#-----
Local  Char     WCLASSE(8)
Local  Char     WNOMIND(5)
Local  Char     WCUR(GLONCUR)
Local  Char     WITMREF(GLONITM)
Local  Char     WBPSNUM(GLONBPS)
Local  Char     WVAT1(GLONVAT)
Local  Shortint WNOL
Local  Date     WDOCDAT
Local  Char     WVACBPR(GLONTVB)
Local  Libelle  WVACTYP
Local  Decimal  WQTYPUU
Local  Decimal  WLINAMT, WLINATIAMT
Local  Decimal  WCLCAMT(1..X)
Local  Decimal  WBASTAXLIN1, WDISBASLIN1
Local  Decimal  WAMTTAXLIN1, WAMTTAXLIN2, WAMTTAXLIN3
Local  Decimal  WAMTTAXRCP,  WAMTTAXISS,  WAMTTAXOTH1, WAMTTAXOTH2
Local  Decimal  WDEDTAXLIN1, WDEDTAXLIN2, WDEDTAXLIN3
Local  Decimal  WDEDTAXRCP,  WDEDTAXISS,  WDEDTAXOTH1, WDEDTAXOTH2
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
Case ABREV
  When "PSD"
    WCLASSE="[F:PSD]"
    WNOMIND=""
    WCUR   =[F:PSD]CUR
    WITMREF=[F:PSD]ITMREF
    WBPSNUM=[F:PSD]BPSNUM
    WVAT1  =[F:PSD]VAT(0)
    WQTYPUU=[F:PSD]QTYPUU
    WNOL   =-1
    WDOCDAT=[F:PSH]PRQDAT
    WVACBPR=[F:PSD]VACBPR
    WVACTYP=[F:PSD]VACTYP
    WLINAMT=[F:PSD]LINAMT
  When "PSH1"
    WCLASSE="[M:PSH1]"
    WNOMIND="(NOL)"
    WCUR   =[M:PSH1]CUR(NOL)
    WITMREF=[M:PSH1]ITMREF(NOL)
    WBPSNUM=[M:PSH1]BPSNUM(NOL)
    WVAT1  =[M:PSH1]VAT1(NOL)
    WQTYPUU=[M:PSH1]QTYPUU(NOL)
    WNOL   =NOL
    WDOCDAT=[M:PSH0]PRQDAT
    WVACBPR=[M:PSH1]VACBPR(NOL)
    WVACTYP=[M:PSH1]VACTYP(NOL)
    WLINAMT=[M:PSH1]LINAMT(NOL)
  When "POH2"
    WCLASSE="[M:POH2]"
    WNOMIND="(NOL)"
    WCUR   =[M:POH1]CUR
    WITMREF=[M:POH2]ITMREF(NOL)
    WBPSNUM=[M:POH0]BPSNUM
    WVAT1  =[M:POH2]VAT1(NOL)
    WQTYPUU=[M:POH2]QTYUOM(NOL)
    WNOL   =NOL
    WDOCDAT=[M:POH0]ORDDAT
    WVACBPR=[M:POH1]VACBPR
    WVACTYP=[M:POH1]VACTYP
    WLINAMT=[M:POH2]LINAMT(NOL)
  When "PTH1"
    WCLASSE="[M:PTH1]"
    WNOMIND="(NOL)"
    WCUR   =[M:PTH0]CUR
    WITMREF=[M:PTH1]ITMREF(NOL)
    WBPSNUM=[M:PTH0]BPSNUM
    WVAT1  =[M:PTH1]VAT1(NOL)
    WQTYPUU=[M:PTH1]QTYUOM(NOL)
    WNOL   =NOL
    WDOCDAT=[M:PTH0]RCPDAT
    WVACBPR=[M:PTH0]VACBPR
    WVACTYP=[M:PTH0]VACTYP
    WLINAMT=[M:PTH1]LINAMT(NOL)
  When "PND"
    WCLASSE="[F:PND]"
    WNOMIND=""
    WCUR   =[F:PND]NETCUR
    WITMREF=[F:PND]ITMREF
    WBPSNUM=[F:PND]BPSNUM
    WVAT1  =[F:PND]VAT(0)
    WQTYPUU=[F:PND]QTYUOM
    WNOL   =-1
    WDOCDAT=[F:PND]RTNDAT
    WVACBPR=[F:PNH]VACBPR
    WVACTYP=[F:PNH]VACTYP
    WLINAMT=[F:PND]LINAMT
  When "PNH1"
    WCLASSE="[M:PNH1]"
    WNOMIND="(NOL)"
    WCUR   =[M:PNH1]NETCUR(NOL)
    WITMREF=[M:PNH1]ITMREF(NOL)
    WBPSNUM=[M:PNH1]BPSNUM
    WVAT1  =[M:PNH1]VAT1(NOL)
    WQTYPUU=[M:PNH1]QTYUOM(NOL)
    WNOL   =NOL
    WDOCDAT=[M:PNH1]RTNDAT
    WVACBPR=[M:PNH1]VACBPR
    WVACTYP=[M:PNH1]VACTYP
    WLINAMT=[M:PNH1]LINAMT(NOL)
  When Default
    End
Endcase
#----- Calcul des taxes du montant ligne (marchandise) -----#
Call ALICLCAMT2(WITMREF,WQTYPUU,WNOL,ABREV,WCLCAMT) From TRTX3
#-----
For I=1 To X
  If left$(WCLASSE,3)="[F:"
    Case I
      When 1 : TAXE(1)=evalue(WCLASSE+"VAT(0)")
      When 2 : TAXE(2)=evalue(WCLASSE+"VAT(1)")
      When 3 : TAXE(3)=evalue(WCLASSE+"VAT(2)")
      When 4 : TAXE(4)=evalue(WCLASSE+"TAXRCP")
      When 5 : TAXE(5)=evalue(WCLASSE+"TAXISS")
      When 6 : TAXE(6)=evalue(WCLASSE+"TAXOTH1")
      When 7 : TAXE(7)=evalue(WCLASSE+"TAXOTH2")
    Endcase
  Else
    Case I
      When 1 : TAXE(1)=evalue(WCLASSE+"VAT1(NOL)")
      When 2 : TAXE(2)=evalue(WCLASSE+"VAT2(NOL)")
      When 3 : TAXE(3)=evalue(WCLASSE+"VAT3(NOL)")
      When 4 : TAXE(4)=evalue(WCLASSE+"TAXRCP(NOL)")
      When 5 : TAXE(5)=evalue(WCLASSE+"TAXISS(NOL)")
      When 6 : TAXE(6)=evalue(WCLASSE+"TAXOTH1(NOL)")
      When 7 : TAXE(7)=evalue(WCLASSE+"TAXOTH2(NOL)")
    Endcase
  Endif
Next I
#-----
Call CALTAXE2(GSOCIETE,WDOCDAT,WVACBPR,WCUR,X,TAXE,1,WLINAMT,
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To X
  Case I
    When 1
      Raz WDISBASLIN1
      WBASTAXLIN1=WLINAMT
      WAMTTAXLIN1=MONTANT(1)
      WDEDTAXLIN1=MONTDED(1)
    When 2
      If TAXE(2)=""
        Raz WAMTTAXLIN2, WDEDTAXLIN2
      Else
        WAMTTAXLIN2=MONTANT(2)
        WDEDTAXLIN2=MONTDED(2)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(2),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(2) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXLIN2 : Endif
      Endif
    When 3
      If TAXE(3)=""
        Raz WAMTTAXLIN3, WDEDTAXLIN3
      Else
        WAMTTAXLIN3=MONTANT(3)
        WDEDTAXLIN3=MONTDED(3)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(3),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(3) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXLIN3 : Endif
      Endif
    When 4
      If TAXE(4)=""
        Raz WAMTTAXRCP, WDEDTAXRCP
      Else
        WAMTTAXRCP=MONTANT(4)
        WDEDTAXRCP=MONTDED(4)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(4),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(4) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXRCP : Endif
      Endif
    When 5
      If TAXE(5)=""
        Raz WAMTTAXISS, WDEDTAXISS
      Else
        WAMTTAXISS=MONTANT(5)
        WDEDTAXISS=MONTDED(5)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(5),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(5) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXISS : Endif
      Endif
    When 6
      If TAXE(6)=""
        Raz WAMTTAXOTH1, WDEDTAXOTH1
      Else
        WAMTTAXOTH1=MONTANT(6)
        WDEDTAXOTH1=MONTDED(6)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(6),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(6) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXOTH1 : Endif
      Endif
    When 7
      If TAXE(7)=""
        Raz WAMTTAXOTH2, WDEDTAXOTH2
      Else
        WAMTTAXOTH2=MONTANT(7)
        WDEDTAXOTH2=MONTDED(7)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,TAXE(7),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=TAXE(7) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2  WBASTAXLIN1+=WAMTTAXOTH2 : Endif
      Endif
  Endcase
Next I
If WVACTYP<>4
  WLINATIAMT=WLINAMT
  For I=1 To X
    Case I
      When 1 : WLINATIAMT+=WAMTTAXLIN1
      When 2 : WLINATIAMT+=WAMTTAXLIN2
      When 3 : WLINATIAMT+=WAMTTAXLIN3
      When 4 : WLINATIAMT+=WAMTTAXRCP
      When 5 : WLINATIAMT+=WAMTTAXISS
      When 6 : WLINATIAMT+=WAMTTAXOTH1
      When 7 : WLINATIAMT+=WAMTTAXOTH2
    Endcase
  Next I
Else
  WLINATIAMT=WLINAMT
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
If [F:BPS]BPSNUM<>WBPSNUM
  Read [BPS] BPS0=WBPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Chargement arrondi devise commande -----#
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#-----
Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
For I=1 To 9
  If evalue("dim("+WCLASSE+"DISCRGVAL"+num$(I)+WNOMIND+")")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat  Raz [F:PFI] : Endif
      If [F:PFI]VATRUL=1
        Raz TAXE : TAXE(1)=WVAT1
        #----- C'est un montant -----#
        If GDISCRGTYP(I-1)=1
          If GCLCRUL(I-1)=1 : # Par unité
            BASE=arr(evalue(WCLASSE+"DISCRGVAL"+num$(I)+WNOMIND)*WQTYPUU,WRND)
          Else              : # Par ligne
            BASE=evalue(WCLASSE+"DISCRGVAL"+num$(I)+WNOMIND)
          Endif
        #----- C'est un pourcentage -----#
        Else
          BASE=arr(WLINAMT*evalue(WCLASSE+"DISCRGVAL"+num$(I)+WNOMIND)/100,WRND)
        Endif
        #----- Inversion de la base si minoration -----#
        If GINCDCR(I-1)=2  BASE=-BASE : Endif
        #-----
        If BASE<>0
          Call CALTAXE(GSOCIETE,WDOCDAT,WVACBPR,WCUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          WBASTAXLIN1+=BASE
          WAMTTAXLIN1+=MONTANT(1)
          WDEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
    Endif
  Endif
Next I
#-----
If ABREV="POH2" | ABREV="PTH1"
  #----- Calcul de la taxe des montants remises/frais de pied répartis -----#
  For I=1 To 9
    If evalue(WCLASSE+"INVDTALIN2(I-1)")<>0 & evalue(WCLASSE+"INVDTAVAT2(I-1)")=""
      Raz TAXE : TAXE(1)=WVAT1
      BASE=evalue(WCLASSE+"DISCRGAMT"+num$(I)+"(NOL)")
      If BASE<>0
        Call CALTAXE(GSOCIETE,WDOCDAT,WVACBPR,WCUR,1,TAXE,1,
&                    BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
        WBASTAXLIN1+=BASE
        WAMTTAXLIN1+=MONTANT(1)
        WDEDTAXLIN1+=MONTDED(1)
        # Issue 70985 - 2012-05-11 by MUARN : landed cost taxe ajouté au montant TTC
        WLINATIAMT+=MONTANT(1)
      Endif
    Endif
  Next I
  #----- Positionnement de l'indicateur de calcul en sortie de tableau -----#
  Assign WCLASSE+"CLCFLG" With 2
Endif
#-----
If ABREV="POH2"  [M:POH2]LINATI(NOL)=WLINATIAMT : Endif
If evalue("dim("+WCLASSE+"DISBASLIN1)")>0  Assign WCLASSE+"DISBASLIN1"+WNOMIND With 0 : Endif
#-----
Assign WCLASSE+"CLCAMT1"   +WNOMIND With WCLCAMT(1)
Assign WCLASSE+"CLCAMT2"   +WNOMIND With WCLCAMT(2)
Assign WCLASSE+"CLCAMT3"   +WNOMIND With WCLCAMT(3)
Assign WCLASSE+"LINATIAMT" +WNOMIND With WLINATIAMT
Assign WCLASSE+"BASTAXLIN1"+WNOMIND With WBASTAXLIN1
Assign WCLASSE+"AMTTAXLIN1"+WNOMIND With WAMTTAXLIN1
Assign WCLASSE+"AMTTAXLIN2"+WNOMIND With WAMTTAXLIN2
Assign WCLASSE+"AMTTAXLIN3"+WNOMIND With WAMTTAXLIN3
Assign WCLASSE+"DEDTAXLIN1"+WNOMIND With WDEDTAXLIN1
Assign WCLASSE+"DEDTAXLIN2"+WNOMIND With WDEDTAXLIN2
Assign WCLASSE+"DEDTAXLIN3"+WNOMIND With WDEDTAXLIN3
If X=7
  Assign WCLASSE+"CLCAMT4"   +WNOMIND With WCLCAMT(4)
  Assign WCLASSE+"CLCAMT5"   +WNOMIND With WCLCAMT(5)
  Assign WCLASSE+"CLCAMT6"   +WNOMIND With WCLCAMT(6)
  Assign WCLASSE+"CLCAMT7"   +WNOMIND With WCLCAMT(7)
  Assign WCLASSE+"AMTTAXRCP" +WNOMIND With WAMTTAXRCP
  Assign WCLASSE+"AMTTAXISS" +WNOMIND With WAMTTAXISS
  Assign WCLASSE+"AMTTAXOTH1"+WNOMIND With WAMTTAXOTH1
  Assign WCLASSE+"AMTTAXOTH2"+WNOMIND With WAMTTAXOTH2
  Assign WCLASSE+"DEDTAXRCP" +WNOMIND With WDEDTAXRCP
  Assign WCLASSE+"DEDTAXISS" +WNOMIND With WDEDTAXISS
  Assign WCLASSE+"DEDTAXOTH1"+WNOMIND With WDEDTAXOTH1
  Assign WCLASSE+"DEDTAXOTH2"+WNOMIND With WDEDTAXOTH2
Endif
End

# Issue 110325/125 - 2016-05-23 by SR : Solde/désolde POQ
################################################################################
# DIVPOQCLE : Solde/désolde d'une ligne de cde avec Engagement/désengagement   #
# si besoin et suppression/création de l'encours                               #
# ---------------------------------------------------------------------------- #
# Subprog DIVPOQCLE (WPOHNUM,WPOPLIN,WPOQSEQ,WSENS,WMSGFLG)                     #
# Il n'y a pas forcément de transaction en cours.                              #
# ---------------------------------------------------------------------------- #
#   WPOHNUM : Numéro de la commande                                            #
#   WPOPLIN : Numéro de la ligne                                               #
#   WPOQSEQ : Numéro de la séquence                                            #
#   WSENS    : Sens l'appel : 1 = Solde 2 = Désolde                            #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVPOQCLE(WPOHNUM,WPOPLIN,WPOQSEQ,WSENS,WMSGFLG)
Value    Char    WPOHNUM
Value    Integer WPOPLIN
Value    Integer WPOQSEQ
Value    Integer WSENS
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WORIFLG
Local    Integer WADXLOG
Local    Decimal WORDNOT, WORDATI
Local    Char    WFCY(GLONFCY), WPARAME(10), WMSG(100)
Local    Char   WGRPDEB(GLONVCR) : #Annule suivi de signatures

Local    Integer SAV_GAPPPOH            : [L]SAV_GAPPPOH=GAPPPOH
Local    Integer SAV_GOK                : [L]SAV_GOK=GOK
Local    Char    SAV_FCY(GLONFCY)       : [L]SAV_FCY = GFCY
Local    Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE  =GSOCIETE
Local    Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV =GLOCALDEV
Local    Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP   =GFINRSP
Local    Integer WLOCK, WLINSOLD, STA, SIGN, WRET
#----- Variables pour le point d'entrée POHCLE -----#
Local   Integer  WCLEFLG, WTRAIT
#-----
WORIFLG=1 : # Appel hors Workflow (annulation suivi)
GOK=1
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_POQCLE
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub POQCLE
If GOK=-1  Goto ROLL_POQCLE : Endif
If GOK=0   Goto AB_POQCLE   : Endif
#-----
If [L]WADXLOG=0
  Commit
  #----- Envoi des messages groupe workflow signature -----#
  If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
Endif
End
#-----
$ROLL_POQCLE
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  End  Else  Goto TR_POQCLE : Endif
Else
  End
Endif
#-----
$AB_POQCLE
If [L]WADXLOG=0
  Rollback
  #----- Suppression des message groupe workflow signature -----#
  If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : WGRPDEB="" : Endif
Endif
End

#------------------------------------------------#
# Traitement du solde/désolde d'une ligne de CDE #
#------------------------------------------------#
$POQCLE
Raz [L]WRET
#-----
If [L]WPOHNUM=""  [L]WRET=11 : Gosub TRT_ERR_POHCLE : Return : Endif
If [L]WPOPLIN=0   [L]WRET=11 : Gosub TRT_ERR_POHCLE : Return : Endif
If [L]WPOQSEQ=0   [L]WRET=11 : Gosub TRT_ERR_POHCLE : Return : Endif
#-----
If !clalev([F:POH])  Local File PORDER    [POH]   : Endif
If !clalev([F:POP])  Local File PORDERP   [POP]   : Endif
If !clalev([F:POQ])  Local File PORDERQ   [POQ]   : Endif
If !clalev([F:POC])  Local File PORDERC   [POC]   : Endif
If !clalev([F:ITM])  Local File ITMMASTER [ITM]   : Endif
If !clalev([F:MVS])  Local File BPSUPPMVT [MVS]   : Endif
If !clalev([F:GAC])  Local File GACCOUNT  [GAC]   : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO]   : Endif
If !clalev([F:TCU])  Local File TABCUR    [TCU]   : Endif
If !clalev([F:ORD])  Local File ORDERS    [ORD]   : Endif
If !clalev([F:ITV])   Local File ITMMVT    [ITV]  : Endif
If !clalev([F:TCA])   Local File TABCOUAFF [TCA]  : Endif
If GMODU(2)=2
  If !clalev([F:BUP]) Local File BUDPAR    [BUP]  : Endif : # Si module compta présent
Endif
If GMODU(5)=2 : # Module Vente présent
 If !clalev([F:SOQ])  Local File SORDERQ  [SOQ]   : Endif
Endif

If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
If !clalev([M:SBCK]) Local Mask SBCK     [SBCK] : Endif
#----- Lecture entête commande -----#
Read [POH] POH0=[L]WPOHNUM
If fstat
  GOK=0 : [L]WRET=14 : Gosub TRT_ERR_POHCLE : Goto FIN_POQCLE
Endif
#---------------------------------------------------------#
# On ne fait rien si :                                    #
# le code traitement est à SOLDE et ligne déjà soldée     #
# le code traitement est à annulation et ligne non soldée #
#---------------------------------------------------------#
Read [POQ]POQ0 = [L]WPOHNUM;[L]WPOPLIN;[L]WPOQSEQ
If fstat : WRET= 16 : Gosub TRT_ERR_POHCLE : Return : Endif
If WSENS=1 & [F:POQ]LINCLEFLG=2 : Return : Endif
If WSENS=2 & [F:POQ]LINCLEFLG=1 : Return : Endif
# ne pas annuler un solde sur un article non réceptionnable (jamais possible en expédition)
If [F:ITM]ITMREF<>[F:POQ]ITMREF
   Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]RCPFLG=1 & WSENS=2 : Return : Endif

# On ne peut pas annuler le solde d'une ligne de sous-traitance
If [F:POQ]VCRTYPORI = 10 | [F:POQ]VCRTYPORI = 36 : Return : Endif

# Si besoin, Pourra-t-on solder/Désolder la ligne de commande de vente ?
If [F:POH]BETFCY=2 & [F:POQ]LINOCNNUM<>""
  Raz GBIDI1
  # On ne fait le controle que si demande de solde et ligne de commande de vente non soldée
  # ou demande de désolde et commande de vente soldée
  Read [SOQ]SOQ0=[F:POQ]LINOCNNUM;[F:POQ]OCNLIN;[F:POQ]OCNLIN
  If !fstat & ((WSENS=1 & [F:SOQ]SOQSTA <> 3) |(WSENS=2 & [F:SOQ]SOQSTA = 3))
      Call CTLMAJSOP("S",[F:POQ]LINOCNNUM,[F:POQ]OCNLIN,[F:POQ]OCNLIN,
&                   GBIDI1) From TRTVENISOC
  Endif
  If GBIDI1<>0 : [L]WRET = 23 : Gosub TRT_ERR_POHCLE : Return : Endif
Endif
#----- Contrôle lock logique -----#
Call JELOCKE("POH"+[L]WPOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="POH"+[L]WPOHNUM
  If fstat        [L]WRET=12 : Gosub TRT_ERR_POHCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif

#-----
[L]WFCY=[F:POH]POHFCY
Call GETDEV([L]WFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[L]WFCY : Endif
Call PARAML([L]WFCY,"APPPOH",[L]WPARAME) From ADOVAL
GAPPPOH=val([L]WPARAME)
#----- Mise à jour indicateur solde sur la ligne commande -----#
Raz [L]WORDNOT, [L]WORDATI
Readlock [POQ]POQ0 = [L]WPOHNUM;[L]WPOPLIN;[L]WPOQSEQ
If fstat=1
   GOK=-1  : GLOCK="$PORDERQ"-[L]WPOHNUM-num$([L]WPOPLIN)
   [L]WRET=16 : Gosub TRT_ERR_POHCLE : Goto FIN_POQCLE
  Elsif fstat
    GOK=0   : Call RSTA("POQ",[L]WPOHNUM-num$([L]WPOPLIN)) From GLOCK
    [L]WRET=17 : Gosub TRT_ERR_POHCLE : Goto FIN_POQCLE
Endif
#-----

#----- Relire les paramètres budgets -----#
If [F:POQ]POHFCY<>GFCY
   GFCY=[F:POQ]POHFCY
   Call DEFRCPFCY(GFCY)    From TRTACHDEF1
   Call DEFSITE(GFCY)      From TRTACHDEF1
   Call DEFBUD("POH",GFCY) From TRTACHDEF1
   GCNTBUD=GCTLBUD
Endif
#
Gosub SOLDE_LIG : If GOK<1  Goto FIN_POQCLE : Endif
#
#-----
$FIN_POQCLE
If [L]WLOCK  Unlock="POH"+[L]WPOHNUM : Endif
#----- Rétablissement des globales -----#
GSOCIETE =[L]SAV_GSOCIETE
GLOCALDEV=[L]SAV_GLOCALDEV
GFINRSP  =[L]SAV_GFINRSP
GAPPPOH  =[L]SAV_GAPPPOH
GFCY     =[L]SAV_FCY
Return
#-----

############################################
# Solde ou désolde de la ligne de commande #
# ---------------------------------------- #
# WSENS = 1 --> Solde                      #
#       = 2 --> Annulation de solde        #
############################################
$SOLDE_LIG
Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
If fstat
  Raz [F:POP]
  Read [POC] POC0=[F:POQ]POHNUM;[F:POQ]POPLIN
  If fstat
    Raz [F:POC]
  Else
    [F:POP]ITMREF=[F:POC]ITMREF
    [F:POP]PRHFCY=[F:POC]PRHFCY
  Endif
Endif
If WSENS=1        : # Solde
  SIGN=-1 : Gosub CAL_MVS From SUBPOHA : # Calcul mts en commande HT et TTC
Else             : # Désolde
  SIGN=+1 : Gosub CAL_MVS From SUBPOHA : # Calcul mts en commande HT et TTC
Endif
#----- Maj qté en commande dans article-site -----#
If [F:POP]ITMREF<>"" & ([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)>0
  STA=0
  Call LECITV([F:POP]PRHFCY,[F:POP]ITMREF,"",STA) From STKLIB
  If STA>2
    Infbox("Erreur : Le site ou l'article ne sont pas alimenté")
    GOK=0
  Endif
  If GOK<>1
    #----- On continue quand même sans mettre à jour ITV -----#
    GOK=1
  Else
    If WSENS=1 : # Solde
      If STA=0
        Update [ITV] Where ITMREF=[F:POP]ITMREF & STOFCY=[F:POP]PRHFCY
&                    With ORDSTO-=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
      Endif
    Else      : # Désolde
      Update [ITV] Where ITMREF=[F:POP]ITMREF & STOFCY=[F:POP]PRHFCY
&                  With ORDSTO+=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
    Endif
    If fstat  GOK=0 : Call FSTA ("ITV") From GLOCK : Return : Endif
  Endif
Endif
#----- Maj du budget et de la ligne commande PORDERQ -----#
Read [POH] POH0=[F:POQ]POHNUM
If WSENS=1
  SIGN=-1 :           : # Solde
  [F:POQ]LINCLEFLG=2
Else
  SIGN=+1 :           : # Désolde
  [F:POQ]LINCLEFLG=1
Endif
[F:POQ]RCPCLEFLG=1
If [F:POQ]LINTYP<>2
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,"POQ2",0,GBIDI1) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
#----- Relecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
Call GETDEV([F:POQ]POHFCY) From DEVSUB
#----- Mise à jour opération de sous-traitance -----#
# Issue 109433 by GA 09/2015 Subcontrated operation (WO) or Subcontracted product (EO)
If find([F:POQ]VCRTYPORI,10,36) & [F:POQ]LINTYP<=2 : # Si achat sous-traitance
  [M:SBCK]MAJCOD = "M"
  [M:SBCK]VCRNUM = [F:POQ]POHNUM
  [M:SBCK]VCRLIN = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ = [F:POQ]POQSEQ
  [M:SBCK]ITMREF = [F:POQ]ITMREF                                 # Issue 109433 by GA 09/2015
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # Issue 109433 by GA 09/2015
  If [F:POQ]LINCLEFLG<>2
    [M:SBCK]ORDQTY=[F:POQ]QTYSTU
  Elsif [F:POQ]RCPQTYSTU<>0
    [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU
  Else
    [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD="A"
  Endif
  [M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,STA) From TRTDEV
  If [F:POQ]QTYSTU = 0
    [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI,10^-GDECPRI)
  Else
    [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  Endif
  [M:SBCK]OFS    = [F:POQ]OFS
  [M:SBCK]MSGFLG = 1                        # llc 03.01 (inutile après tout)
  [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG         # 03.02 13517
  #-----
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
     If [F:POQ]VCRTYPORI=10
        GMESSAGE=mess(96,193,1)-":"-GMESSAGE
      Elsif [F:POQ]VCRTYPORI=36
        GMESSAGE=mess(913,196,1)-":"-GMESSAGE
      Endif
      GERR=1 : GOK=0 : Return
  Endif
Endif
#----- Maj de l'encours ORDERS -----#
If [F:POQ]WIPNUM<>""
  #-----
   Call LECTCA(7,GBIDI3) From SUBTCA
  If fstat | !GBIDI3
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : GOK=0 : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #-----
  If WSENS=1          : # Solde
    # affectations
    Gosub SUP_MTO_POQ From PURMTOLIB

    [M:ORDK]MAJCOD    = "A"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF

  Else               : # Désolde
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]ORIFCY    = [F:POQ]POHFCY
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = [F:POP]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = [F:POQ]RCPQTYSTU
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    If [F:POH]POHTYP=2 [M:ORDK]ABBFIL="POC" Else [M:ORDK]ABBFIL="POQ" : Endif
  Endif
  Call WIP From TRTWIP : If GOK<1 Return : Endif

  # affectations si désolde
  If WSENS <> 1
    # affectations
    Gosub MAJ_MTO_POQ From PURMTOLIB
  Endif
Endif
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
WTRAIT=2
If WSENS=1  WCLEFLG=1  Else  WCLEFLG=2 : Endif
Gosub POINT_POHCLE From TRTACHCDE1
#-----
Rewrite [POQ]
If fstat GOK = 0 : Call FSTA("POQ") From GLOCK
 [L]WRET=18 : Gosub TRT_ERR_POHCLE : Return
Endif
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
# Pour chaque réception existante, il faudra faire ou défaire la PEC des FCC
If [F:POQ]RCPQTYSTU <> 0
   If [F:POQ]LINCLEFLG = 2
    Call REGPRIX_FCC(2,"",0) From TRTACHFAC1
   Else
    Call REGPRIX_FCC(3,"",0) From TRTACHFAC1
   Endif
Endif

If WSENS=1
  WLINSOLD+=1      : # Solde
Else
  WLINSOLD-=1      : # Désolde
Endif
#Maj du flag solde de la ligne de commande de vente si besoin
If [F:POH]BETFCY=2 & [F:POQ]LINOCNNUM<>""
  #--- Solde de ligne d'une commande de vente
  Call DIVCLESOQ([F:POQ]LINOCNNUM, [F:POQ]OCNLIN, [F:POQ]OCNSEQ, GBIDC1) From TRTVENCDE
  If GOK<1
      [L]WRET=22 : Gosub TRT_ERR_POHCLE : Return
  Endif
Endif
If GOK < 1: Return : Endif
#
#-----  Maj de l'entête cde PORDER -----#
Readlock [POH] POH0=[L]WPOHNUM
If fstat=1
  GOK=-1 : GLOCK = "$PORDER" :
  [L]WRET=12 : Gosub TRT_ERR_POHCLE : Return
Elsif fstat
  GOK= 0 : Call RSTA("POH",[L]WPOHNUM) From GLOCK
 [L]WRET=13 : Gosub TRT_ERR_POHCLE : Return
Endif
[F:POH]CLELINNBR+=WLINSOLD
If [F:POH]CLELINNBR<0  [F:POH]CLELINNBR=0 : Endif
If [F:POH]CLELINNBR>[F:POH]LINNBR  [F:POH]CLELINNBR=[F:POH]LINNBR : Endif
If [F:POH]CLELINNBR=[F:POH]LINNBR
  [F:POH]CLEFLG=2
Else
  [F:POH]CLEFLG=1
Endif
Rewrite [POH]
If fstat  GOK=0 : Call FSTA("POH") From GLOCK
 [L]WRET=15 : Gosub TRT_ERR_POHCLE : Return
Endif
#
#----- Maj en commande dans mouvements fournisseur -----#
Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
If GOK<1  Return : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
#----- Uniquement si appel hors évènement de Workflow ! -----#
If WSENS = 1 & [L]WORIFLG=1 &  GAPPPOH>1 & [F:POH]CLEFLG=2 & [F:POH]APPFLG<3
   If [F:POH]POHTYP=1
    Call ANNULE_SUIVI("POH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Else
    Call ANNULE_SUIVI("POC",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Endif
  If GOK<1  Return : Endif
#----- Réactivation de la ligne de suivi de workflow -----#
#----- Uniquement si appel hors évènement de Workflow ! -----#
Elsif WSENS = 2 & [L]WORIFLG=1 & GAPPPOH > 1 & [F:POH]CLEFLG <> 2 & [F:POH]APPFLG<3
  If [F:POH]POHTYP=1
    Call REACTIV_SUIVI("POH",[F:POH]POHNUM) From TRTACHDIV1
  Else
    Call REACTIV_SUIVI("POC",[F:POH]POHNUM) From TRTACHDIV1
  Endif
  If GOK<1  Return : Endif
Endif
Return


# Issue 116808 - 2016-05-26 by SR : Reactivation du suivi des signatures
# Appelé par exemple par FUNCLEAR/ DICPOQCLE de TRTACHDIV1
################################################################################
# REACTIV_SUIVI : S/P Positionnement indicateur "A signer"                     #
#                sur la ligne  de suivi de workflow                            #
# ---------------------------------------------------------------------------- #
# Subprog REACTIV_SUIVI(LABROBJ,LCLEOBJ)                                       #
# ---------------------------------------------------------------------------- #
#   LABROBJ  : Code l'objet ("PSH","PSD","POH","POC")                          #
#   LCLEOBJ  : Clé de l'objet                                                  #
#               Exemple : N° de commande                                       #
################################################################################
Subprog REACTIV_SUIVI(LABROBJ,LCLEOBJ)
Value    Char    LABROBJ : # Abréviation de l'objet : exemple "POH"
Value    Char    LCLEOBJ : # Clé de l'objet

If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS] : Endif
# Ne réactiver que la dernière annulée (une autre a pû être annulée
# suite à l'annulation manuelle de la signature précédente)
Filter [F:AWS] Where ABROBJ = LABROBJ & CLEDEC=LCLEOBJ & FLGSIG = 1
Readlock [F:AWS]AWS0 Last
If ! fstat
  [F:AWS]FLGSIG = 3
  Raz [F:AWS]REASON
  Rewrite [F:AWS]
Endif
Filter [F:AWS]
If fstat
    GOK=0   : Call FSTA("AWS") From GLOCK
    End
Endif
End
# End issue 116808

