#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK & dim([L]SAV_GOK)>0
    GOK=[L]SAV_GOK
Endif
Return
#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
# 11 = WPSHNUM Paramètre non renseigné                            #
# 12 = $PREQUIS xxxxxxxx Modification en cours sur un autre poste #
# 18 = Erreur d'écriture sur le fichier PREQUIS xxxxxxxx          #
#-----------------------------------------------------------------#
$TRT_ERR_PSHAPP1
Case [L]WRET
  When 11 : [L]WMSG="WPSHNUM"-mess(136,199,1)              : GOK=0
  When 12 : [L]WMSG="$PREQUIS"-[L]WPSHNUM-mess(10,100,1)   : GOK=0
  When 18 : [L]WMSG=mess(13,100,1)-"PREQUIS"-[L]WPSHNUM
