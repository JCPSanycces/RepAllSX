#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------------------------
#--The "black box" method for the price search  # TRTACHTAR_SYRA   12/6/2013
Funprog SEARCHPRICE(MYPARAM,PLINEDOC, MYRESULT,WMESS)
Variable Instance MYPARAM  Using C_PFINDPRICE
Value    Integer  PLINEDOC
Variable Instance MYRESULT Using C_RESULTPRICE
Variable Char WMESS

    If MYPARAM.C_LINE(PLINEDOC) = null : End [V]CST_AERROR : Endif

Gosub OUVRE

    Local Integer WRET

    Local Decimal WTEMPDEC, WRATRPT, WCOEFDEVISE, GROPRI #
    Local Integer WTEMPINT
    Local Char    WVAT(GLONVAT)(1..),WVAT_LEG(GLONADI)(1..)
    Local  Char   LBPCORD    (GLONBPC)   : # client cde vente

    Local Integer CTX_UPDPRIPUR

    CTX_UPDPRIPUR = fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"UPDPRIPUR")

    If MYPARAM.PLITYP = 0 : MYPARAM.PLITYP = 1 : Endif # Normal

    If MYPARAM.GTYPGEN>0 and MYPARAM.C_LED(MYPARAM.GTYPGEN)<>null and MYPARAM.C_LED(MYPARAM.GTYPGEN).RATDIV<>0
      If MYPARAM.C_LED(MYPARAM.GTYPGEN).RATMLT<>0
        MYPARAM.MLTDIVCOE=arr((1/(MYPARAM.C_LED(MYPARAM.GTYPGEN).RATMLT/MYPARAM.C_LED(MYPARAM.GTYPGEN).RATDIV)), 10^-MYPARAM.GDECRCU)
      Endif
    Endif
    If maxtab(MYPARAM.C_LED)>0
      WI=find(MYPARAM.GSYSCUR,MYPARAM.C_LED(1..maxtab(MYPARAM.C_LED)).CURLED)
      If WI and MYPARAM.C_LED(WI)<>null and  MYPARAM.C_LED(WI).RATDIV<>0
        If MYPARAM.C_LED(WI).RATMLT<>0
          WRATRPT=arr((1/(MYPARAM.C_LED(WI).RATMLT/MYPARAM.C_LED(WI).RATDIV)), 10^-MYPARAM.GDECRCU)
        Endif
      Endif
    Endif

#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>MYPARAM.BPSNUM
  Read [BPR] BPR0=MYPARAM.BPSNUM : If fstat Raz [F:BPR] : Endif
Endif

If [F:ITS]ITMREF<> MYPARAM.C_LINE(PLINEDOC).ITMREF #[M:POH2]ITMREF(NOL) ##################
  Read [ITS] ITS0= MYPARAM.C_LINE(PLINEDOC).ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>MYPARAM.C_LINE(PLINEDOC).ITMREF | [F:ITP]BPSNUM<>MYPARAM.BPSNUM
  Read [ITP] ITP0=MYPARAM.C_LINE(PLINEDOC).ITMREF;MYPARAM.BPSNUM : If fstat Raz [F:ITP] : Endif
Endif

#Local File ITMSALES   [ITS]  ### testusar27_sy
    #--Syracusation of the TRTPRICE.TARIFRECH subroutine
    Call TARIFRECH(MYPARAM,PLINEDOC, MYRESULT, WMESS,[L]WRET) From TRTPRICE_SYRA
    If WRET>[V]CST_AINFO : End [L]WRET : Endif

    #====================================================================================
    #-------------------------------------------------------------------------------#
    # Prix brut à 0 : Application du prix de base sf pour composants                #
    #                                             sf pour les articles non vendus   #
    #                                             sf pour les articles sous-traités #
    #                 --> Conversion prix de base dans unité  cde                   #
    #                 --> Conversion prix de base dans devise cde                   #
    #-------------------------------------------------------------------------------#


    Read [F:ITM]ITM0 = MYPARAM.C_LINE(PLINEDOC).ITMREF
    If fstat : Raz [F:ITM] : Endif

    Read [F:ITS]ITS0 = MYPARAM.C_LINE(PLINEDOC).ITMREF
    If fstat : Raz [F:ITS] : Endif


    If MYRESULT.C_PRICE(1).MONTANT = 0 & MYRESULT.C_PRICE(1).MOTIF = 0 & MYPARAM.TYPRECH = 1 #& [F:ITM]SALFLG=2 #& !find(MYPARAM.C_LINE(PLINEDOC).C_PPKD(1).LINTYP, 10)

                Gosub TARIF_ABSENT  # 98721.n
                WPRIREN = CTX_UPDPRIPUR

                MYRESULT.C_PRICE(1).MONTANT = GROPRI
                MYRESULT.C_PRICE(1).MOTIF   = WPRIREN
# 98721.so
#       If MYPARAM.C_LINE(PLINEDOC).PUU <> [F:ITM]PUU
#
#          WTEMPDEC= MYPARAM.C_LINE(PLINEDOC).PUUSTUCOE #val(MYPARAM_T(0)) : # indice 0 = coef. conversion UV --> US
#
#          If WTEMPDEC=0
#              Call SREC_COE(MYPARAM.C_LINE(PLINEDOC).ITMREF,MYPARAM.BPCNUM,[F:ITM]PUU, MYPARAM.C_LINE(PLINEDOC).PUU,WTEMPDEC) From TRTACHQTE1_SYRA
#          Else
#              # calcul coef. conversion UV cde --> UV article  car le prix de base est exprimé ds l'UV article
#              # coef. conversion UV --> US / coef. conversion UV --> US de la fiche article
#              WTEMPDEC = WTEMPDEC/[F:ITM]PUUSTUCOE
#              WTEMPDEC = arr(WTEMPDEC,0.000001)
#              If WTEMPDEC=0 : WTEMPDEC = 1 : Endif
#          Endif
#
#          If WTEMPDEC <> 0
#            If MYPARAM.C_PPKH.BETFCY=[V]CST_AYES # 2
#              GROPRI = [F:ITS]BASPRI * WTEMPDEC
#            Else
#              GROPRI = [F:ITM]PURBASPRI * WTEMPDEC
#            Endif
#          Else
#             GROPRI = 0
#          Endif
#
#       Else
#          If MYPARAM.C_PPKH.BETFCY=[V]CST_AYES # 2
#            GROPRI = [F:ITS]BASPRI
#          Else
#            GROPRI = [F:ITM]PURBASPRI
#          Endif
#       Endif
#
#       If MYPARAM.CUR <> MYPARAM.GSYSCUR & GROPRI <> 0
#
#           If WRATRPT<>0
#               WCOEFDEVISE=WRATRPT
#           Else
#               Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR,MYPARAM.CUR,MYPARAM.GLOCALDEV,MYPARAM.CHGTYP,MYPARAM.DOCDAT,1000000000000.00,WCOEFDEVISE,WTEMPINT) From TRTDEV_SYRA
#               If WTEMPINT=0 & WCOEFDEVISE<>0 WCOEFDEVISE=WCOEFDEVISE/1000000000000.00 Else WCOEFDEVISE=1 Endif
#           Endif
#           GROPRI = GROPRI*WCOEFDEVISE
#
#       Endif
#
#       # Si document avec type prix en TTC, il faut passer le prix de base (HT) en TTC
#       If MYPARAM.PRITYP=2
#          # Bug 84596 : Date pour conversion prix HT/TTC
#          Local Date WDATCONVPRI
#
#          If MYPARAM.VATCLCDAT<>[0/0/0] WDATCONVPRI=MYPARAM.VATCLCDAT Else WDATCONVPRI=MYPARAM.DOCDAT Endif
#
#          Call CLCTAXEPRIV(MYPARAM.ACTX, GROPRI,WVAT,WVAT_LEG,
#&            1,MYPARAM.CPY,WDATCONVPRI,MYPARAM.C_LINE(PLINEDOC).QTY,MYPARAM.VACBPR, MYPARAM.VACBPR_LEG ,MYPARAM.C_LINE(PLINEDOC).CLCAMT1,MYPARAM.C_LINE(PLINEDOC).CLCAMT2,WTEMPDEC) From TRTX3_SYRA
#
#          GROPRI = WTEMPDEC
#       Endif
#
#       GROPRI  = arr(GROPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
#
#       WPRIREN = CTX_UPDPRIPUR
#
#       MYRESULT.C_PRICE(1).MONTANT = GROPRI
#       MYRESULT.C_PRICE(1).MOTIF   = WPRIREN # 98721.eo

    Endif


    Gosub PE_RECHTARIF1 From TRTACHTAR_SYRA : #

    #----------------------------------------------------------------#
    # Gestion des gratuits                                           #
    #----------------------------------------------------------------#


    If MYRESULT.C_FOC(1)<>null and MYRESULT.C_FOC(1).FOCQTY <> 0 & MYRESULT.C_FOC(1).FOCITMREF = ""
      If MYPARAM.C_LINE(PLINEDOC)<>null
        MYRESULT.C_FOC(1).FOCITMREF = MYPARAM.C_LINE(PLINEDOC).ITMREF
        MYRESULT.C_FOC(1).FOCUOM    = MYPARAM.C_LINE(PLINEDOC).SAU
      Endif
    Endif

End [L]WRET
#--------------------------------------------------------------------------------------------------
$RECHGROUP1

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHGROUP1" : Gosub ENTREE From EXEFNC

Return
#--------------------------------------------------------------------------------------------------
$PE_RECHTARIF1

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHTARIF1" : Gosub ENTREE From EXEFNC

Return
#----------------------------------------------------------------#
$OUVRE


Local File  ITMMASTER [ITM]
Local File  ITMSALES  [ITS]
Local File  ITMCOST   [ITC]
Local File  ITMBPS    [ITP]
Local File  BPARTNER  [BPR]
Local File  BPSUPPLIER [BPS]

Local File BPSUPPMVT  [MVS]
Local File BPADDRESS  [BPA]
Local File ITMMVT     [ITV]
Local File ITMFACILIT [ITF]
Local File FACILITY   [FCY]
Local File TABCUR     [TCU]
Local File TABVAT     [TVT]
Local File TABRATVAT  [TRA]
Local File PRICSTRUCT [PRS]
Local File PPRICCONF  [PPC]
Local File PPRICFICH  [PPF]
Local File PFOOTINV   [PFI]
Local File ATEXTRA    [AXX]
Local File PORDER     [POH]
Local File PPREASON   [PPR]

If GACTX.AFOLD.AMODULE(5)<2 # Sales
#If GMODU(5)=2            : # si presence module vente
   Local File BPCUSTOMER [BPC]
   Local File BPDLVCUST  [BPD]
   Local File BPCUSTMVT  [MVC]
   Local File ITMSALES   [ITS]
Endif
Return
#---------------------------------------------------------------------------------
$TARIF_ABSENT  # 98721.n
#----- Variables locales -----#
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN, VCRTYP, VCRLIN, VCRSEQ, WGPURPRICE
Local Integer STAT
Local Char     CUR(GLONCUR), UOM(GLONUOM), VCRNUM(GLONVCR), PRHFCY(GLONFCY), WGLOCALDEV(8)
Local Decimal  WBASE, WQTE, WGCOEUOM, WGBIDD1, NETPRI # Issue 10401 - 2012-02-24 by MUARN : prix base
Local Date WGBIDA1

Local  Char     LITMREF    (GLONITM)   : # article

LITMREF=MYPARAM.C_LINE(PLINEDOC).ITMREF

#-----
 Raz [L]NETPRI, [L]GROPRI, [L]PRIREN, [L]VCRTYP, [L]VCRNUM, [L]VCRLIN, [L]VCRSEQ
#Case TRAIT
#  When "POH"
    WGBIDA1    = MYPARAM.DOCDAT
    [L]BETFCY  = MYPARAM.C_PPKH.BETFCY
    [L]CUR     = MYPARAM.CUR
    [L]CHGTYP  = MYPARAM.CHGTYP
    [L]UOM     = MYPARAM.C_LINE.PUU
    [L]PRHFCY  = MYPARAM.FCY
    [L]VCRTYP  = 14
    [L]VCRNUM  = ""
    [L]VCRLIN  = 0
    [L]VCRSEQ  = 0
    WGPURPRICE= 2 # fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,this.ACTX.ACPY,"PURPRICE")

#-------------------------------------------------------------#
# Si inter-sites, on prend le prix de base de l'article-vente #
#-------------------------------------------------------------#

WGLOCALDEV=func SREPLACEGLOB_SYRA.GET_GLOCALDEV(MYPARAM.FCY,MYPARAM.CPY)

If [L]BETFCY=2 & GACTX.AFOLD.AMODULE(5)=2 & [F:ITS]ITMREF<>""
  If [L]UOM<>[F:ITM]SAU
    Call SREC_COE([F:ITM]ITMREF,LBPCORD,[F:ITM]SAU,[L]UOM,WGBIDD1) From TRTVENQTE_SYRA
    If WGBIDD1<>0 [L]NETPRI=[F:ITS]BASPRI*WGBIDD1 Else Raz [L]NETPRI : Endif
  Else
    [L]NETPRI=[F:ITS]BASPRI
  Endif
  If [L]NETPRI<>0 & [L]CUR<>MYPARAM.GSYSCUR
    [L]GROPRI=[L]NETPRI
    Call CONVERT2(MYPARAM.ACTX,MYPARAM.GSYSCUR,[L]CUR,WGLOCALDEV,[L]CHGTYP,WGBIDA1,
&                 [L]GROPRI,[L]NETPRI,[L]STAT) From TRTDEV_SYRA
  Endif
  #----- Chargement prix net et motif du prix -----#
  [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
  [L]PRIREN=CTX_UPDPRIPUR
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & WGPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article de sous-traitance, module GP actif et no OF renseigné    #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG=2 & GACTX.AFOLD.AMODULE(8)=2 & [L]VCRNUM<>"" & [L]VCRTYP=10
  Local File MFGOPE [MFO]
# Issue 87203 - 2013-01-14 by CCC
#  Read [MFO]MFO0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:MFO]MFGNUM<>[L]VCRNUM | [F:MFO]OPENUM<>[L]VCRLIN | [F:MFO]OPESPLNUM<>[L]VCRSEQ
    Read [MFO]MFO0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:MFO] Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:MFO]REFPRI<>0
  If [F:MFO]REFPRI<>0
    [L]NETPRI=[F:MFO]REFPRI : # Récupération du prix de référence
    #----- Conversion prix si devise différente -----#
    If WGLOCALDEV<>[L]CUR
      Call CONVERT2(MYPARAM.ACTX,WGLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:MFO]REFPRI,[L]NETPRI,[L]STAT) From TRTDEV_SYRA
    Endif
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:MFO]OPEUOM
      Call PCAL_QTY(WGBIDD1,[F:MFO]OPEUOM,WGBIDD1,[L]UOM,
&                   [F:ITM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1_SYRA
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
    [L]PRIREN=CTX_UPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & WGPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article de sous-traitance et ref EO renseignée                   #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG=2 & [L]VCRNUM<>"" & [L]VCRTYP=36
  Local File SCOSRV [SCS]
# Issue 87203 - 2013-01-14 by CCC
#  Read [SCS] SCS0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:SCS]SCONUM<>[L]VCRNUM | [F:SCS]SCILIN<>[L]VCRLIN | [F:SCS]SCSLIN<>[L]VCRSEQ
    Read [SCS]SCS0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:SCS] Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:SCS]NETPRI<>0
  If [F:SCS]NETPRI<>0
    [L]NETPRI=[F:SCS]NETPRI : # Récupération du prix saisi
    #----- Conversion prix si devise différente -----#
    If WGLOCALDEV<>[L]CUR
       Call CONVERT2(MYPARAM.ACTX,WGLOCALDEV,[L]CUR,WGLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:MFO]REFPRI,[L]NETPRI,[L]STAT) From TRTDEV_SYRA
    Endif
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:SCS]SCOPUU
      Call PCAL_QTY(WGBIDD1,[F:SCS]SCOPUU,WGBIDD1,[L]UOM,
&                   [F:SCS]SRVITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1_SYRA
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
    [L]PRIREN=CTX_UPDPRIPUR # GUPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & WGPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article matière fournie et ref EO renseignée                     #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG<>2 & [F:ITM]SCPFLG<>2 & [L]VCRNUM<>"" & [L]VCRTYP=36
  Local File SCOMAT [SCM]
# Issue 87203 - 2013-01-14 by CCC
#  Read [SCM] SCM0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:SCM]SCONUM<>[L]VCRNUM | [F:SCM]SCILIN<>[L]VCRLIN | [F:SCM]SCMLIN<>[L]VCRSEQ
    Read [SCM]SCM0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:SCM] Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:SCM]GROPRI<>0
  If [F:SCM]GROPRI<>0
    [L]NETPRI=[F:SCM]GROPRI : # Récupération du prix saisi
    #----- Conversion prix si devise différente -----#
    If GLOCALDEV<>[L]CUR
      Call CONVERT2(MYPARAM.ACTX,WGLOCALDEV,[L]CUR,WGLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:SCM]GROPRI,[L]NETPRI,[L]STAT) From TRTDEV_SYRA
    Endif
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:SCM]STU
      Call PCAL_QTY(WGBIDD1,[F:SCM]STU,WGBIDD1,[L]UOM,
&                   [F:SCM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1_SYRA
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
    [L]PRIREN=CTX_UPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & WGPURPRICE=2
    Gosub COUT_STD
  Endif
Endif
#-------------#
# Fin commune #
#-------------#
# Issue 10401 - 2011-12-01 by MUARN : prix de base
If [L]NETPRI = 0
  Read [ITM]ITM0=LITMREF
  [L]NETPRI = [F:ITM]PURBASPRI
Endif
If [L]NETPRI = 0 & WGPURPRICE=2
  Gosub COUT_STD
Endif
# fin Issue 10401 - 2011-12-01 by MUARN : prix de base

[L]GROPRI=[L]NETPRI
#Case TRAIT
#  When "POH"
    # Issue 10401 - 2012-03-29 by MUARN : prix base conversion devise
    If [L]PRIREN <> CTX_UPDPRIPUR #GUPDPRIPUR
      If MYPARAM.GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
Call CONVERT2(MYPARAM.ACTX,MYPARAM.GSYSCUR, [L]CUR, WGLOCALDEV, [L]CHGTYP, MYPARAM.DOCDAT,
&                     WBASE, [L]NETPRI,STAT) From TRTDEV_SYRA
#Endif
        [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2012-03-29 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>MYPARAM.C_LINE(PLINEDOC).ITMREF
        Read [ITM] ITM0=MYPARAM.C_LINE(PLINEDOC).ITMREF : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> MYPARAM.C_LINE.PUU
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,MYPARAM.C_LINE.PUU,
&             MYPARAM.C_LINE(PLINEDOC).ITMREF,MYPARAM.BPSNUM,1,WGCOEUOM) From TRTACHQTE1_SYRA
        [L]NETPRI = [L]NETPRI/WGCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2012-03-29 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = CTX_UPDPRIPUR #GUPDPRIPUR
    Endif

Return
#---------------------------------------------------------------------------------
$COUT_STD # 98721.n

#Local File ITMCOST [ITC]
Call GETPRI([F:ITM]ITMREF,"","",[L]PRHFCY,WGBIDA1,1,"","",1,[L]NETPRI,STAT) From STKVAL_SYRA
If !STAT & [F:ITC]VLTTOT<>0
  [L]NETPRI=[F:ITC]VLTTOT
  #----- Conversion prix si devise différente -----#
  If WGLOCALDEV<>[L]CUR
    Call CONVERT2(MYPARAM.ACTX,WGLOCALDEV,[L]CUR,WGLOCALDEV,[L]CHGTYP,datesyst,
&                 [F:ITC]VLTTOT,[L]NETPRI,[L]STAT) From TRTDEV_SYRA
  Endif
  #----- Conversion prix si unité différente -----#
  If [L]UOM<>[F:ITM]STU
    Call PCAL_QTY(WGBIDD1,[F:ITM]STU,WGBIDD1,[L]UOM,
&                 [F:ITM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1_SYRA
  If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
    [L]NETPRI=[L]NETPRI*[L]COEFUNITE
  Endif
  #----- Chargement prix net, prix brut et motif du prix -----#
  [L]NETPRI=arr([L]NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
  [L]PRIREN=GUPDPRIPUR
Endif
Return

