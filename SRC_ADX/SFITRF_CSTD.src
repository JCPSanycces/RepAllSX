#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
       When "AINIT"
       When "AREAD"
       When "AUPDATE"
       When "AINSERT"
       When "ADELETE"
       When "AINSERT_CONTROL_AFTER"
       When "AUPDATE_CONTROL_AFTER"
       When "AINSERT_BEFORE"
       When "AUPDATE_BEFORE"
       When Default
    Endcase
Endcase
Return
#######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case CURPTH
   When ""
     Case [L]AMETHOD
       When "INIT_SFIT"                    : Gosub INIT_SFIT              : # Class method
       When "NEW_SFIT"										 : Gosub NEW_SFIT
       When "UPD_NBFAC"										 : Gosub UPD_NBFAC
       When Default
     Endcase
   When Default
Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#--It's a technical class : no events on properties
Case CURPRO
  When Default
Endcase
Return
#######
$INIT_SFIT
Local Integer IJ0, IJ1
Local Char 		SFI_CRITERE (30)
Local Char 		SFI_TST     (15)

Local Integer WRET

Local Instance W_CPY Using C_COMPANY

W_CPY = NewInstance =this.AllocGrp, C_COMPANY
WRET = fmet W_CPY.AREAD(PCOMPANY)
If WRET>0
	#--gestion de l'erreur
Endif

#------?-----#If GREP<>"C" & GREP<>"" : Return: Endif
#If this.APARENT.??? <> [V]???

#--Ici nous allons déclarer et instancier la classe SFOOTINV
Gosub OPEN_SFI From TRTX3CPY

  Local File ATEXTRA  [AXX]

#------?-----#Raz this.

If find(POBJECT,"SQH","SOH","SDH","SRH", "SRL", "SIH","SOR")
   this.S_OBJ=POBJECT
  Else
   If find(PCLASS,"SQUOTE") 	 :    this.S_OBJ="SQH" : Endif
   If find(PCLASS,"SORDER") 	 :    this.S_OBJ="SOH" : Endif
   If find(PCLASS,"SDELIVERY") :  	this.S_OBJ="SDH" : Endif
   If find(PCLASS,"SRETURN") 	 :    this.S_OBJ="SRH" : Endif
   #------?-----#If find(PCLASS,"GESSRL") 	 :    this.S_OBJ="SRL" : Endif
   If find(PCLASS,"SINVOICE")  :    this.S_OBJ="SIH" : Endif
Endif

# --- constitution du critere de lecture de SFI : suivant les elements saisis dans le document
Case this.S_OBJ
     When "SQH","SOH","SOR"  : SFI_CRITERE="DACORD<>0" : # dans les devis et commandes
     When "SDH","SRH","SRL"  : SFI_CRITERE="DACDLV<>0" : # dans les livraisons retours
     When "SIH"              : SFI_CRITERE="DACINV<>0" : # dans les factures
Endcase
# --- Si Paramètre société Remise sur taxe à non, exclure les élts Remise sur taxe
#------?-----#If GDEPMGTMOD>1 : SFI_CRITERE-="& MISRULSTD<>2" : Endif

#Local Integer EXNOLIGN: EXNOLIGN=nolign
#Raz nolign

# --- chargement dans tableau NBSFI des elements saisis dans le document
Local Integer L_NBSFI
Local Integer L_NBSFIT
Local Integer L_NBTRF
For [SFI] Where evalue(SFI_CRITERE)
    [L]L_NBSFI +=1

		If this.C_NBSFI([L]L_NBSFI)=null
			[L]L_NBSFI= fmet this.ADDLINE("C_NBSFI",[V]CST_ALASTPOS)
		Endif
		this.NBSFI=[L]L_NBSFI

    SetInstance this.C_NBSFI(L_NBSFI) With [F:SFI]

    Case this.S_OBJ
         When "SQH","SOH","SOR"  : this.C_NBSFI([L]L_NBSFI).SFIORD=[F:SFI]DACORD
         When "SDH","SRH","SRL"  : this.C_NBSFI([L]L_NBSFI).SFIORD=[F:SFI]DACDLV
         When "SIH"              : this.C_NBSFI([L]L_NBSFI).SFIORD=[F:SFI]DACINV
    Endcase
    #------?-----#If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
        Call GET_ATEXTRA("SFOOTINV","DESAXX",this.ACTX.LAN,this.C_NBSFI([L]L_NBSFI).SFIDES) From TRTX3TEX
        Call GET_ATEXTRA("SFOOTINV","SHOAXX",this.ACTX.LAN,this.C_NBSFI([L]L_NBSFI).SFISHO) From TRTX3TEX
    #-----------#Endif                        : # Dde 81811 : Optimisation
    this.C_NBSFI([L]L_NBSFI).SFICUR=[F:SFI]CUR

    #------?-----## 85879 : Valeur par défaut non convertie car devise non alimentée dans SFOOTINV
    #------?-----#If this.SFICUR(nolign-1)="" this.SFICUR(nolign-1)=GSYSCUR Endif

#   --- chargement dans tableau NBSFIT de particularites de transfert (ex : commande --> livraison)
#       nota : pas de selection suivant document recepteur (faire eventuellement)

    For IJ0=0 To dim([F:SFI]ORIVCR)-1
        If [F:SFI]ORIVCR(IJ0)=0 : Break : Endif
        SFI_TST    = num$([F:SFI]SFINUM)+"~"
        SFI_TST   += num$([F:SFI]ORIVCR(IJ0))+"~"
        SFI_TST   += num$([F:SFI]DESVCR(IJ0))

				L_NBSFIT = IJ0+1
				If this.C_NBSFIT([L]L_NBSFIT)=null
					[L]L_NBSFIT = fmet this.ADDLINE("C_NBSFIT",[V]CST_ALASTPOS)
				Endif

				this.NBSFIT =[L]L_NBSFIT

        this.C_NBSFIT([L]L_NBSFIT).T_TST_RUL=SFI_TST
        this.C_NBSFIT([L]L_NBSFIT).T_ORIVCR=[F:SFI]ORIVCR(IJ0)
        this.C_NBSFIT([L]L_NBSFIT).T_DESVCR=[F:SFI]DESVCR(IJ0)
        this.C_NBSFIT([L]L_NBSFIT).T_BRDRUL=[F:SFI]BRDRUL(IJ0)
        this.C_NBSFIT([L]L_NBSFIT).T_GRUFLG=[F:SFI]GRUFLG(IJ0)
        this.C_NBSFIT([L]L_NBSFIT).T_GRURUL=[F:SFI]GRURUL(IJ0)
    Next
Next

Local Integer SAVIND : SAVIND=indice

#------?-----#Sorta this.NBSFI this.NBSFI Order By this.SFIORD(indice)

indice=SAVIND

this.S_SOC=PCOMPANY
#------?-----#
#------?-----#this.S_CUR=GLOCALDEV    : # devise de la societe
this.S_CUR=W_CPY.ACCCUR

#nolign=EXNOLIGN

FreeInstance W_CPY : W_CPY=null

Return

#-----------------------------------------------------------------------------------------------
######################################################################################
# Chargement des données affichées et invisibles du tableau des elements facture     #
# CUR Devise du document                                                             #
######################################################################################
#FMethod NEW_SFIT (CLASSE,ABREV,CUR,BPCINV,BPCORD,RATDAT)
#Variable Instance CLASSE Using OBJECT
#Value Char    ABREV
#Value Char    CUR             : # Devise du document
#Value Char    BPCINV          : # Client facture
#Value Char    BPCORD          : # Client commande
#Value Date    RATDAT          : # Date pour le cours (date du doc)
$NEW_SFIT

#--Globales à remplacer :
#GREP
#--/Globales

#If GREP<>"C" & GREP<>"" : return : Endif

Local Integer IJ0, IJ1, IJ2
Local Integer WRET

# --- Init des codes clients
this.S_BPCINV=PBPCINV
this.S_BPCORD=PBPCORD

# --- Init dans bloc NBSFI
For IJ=1 To maxtab(this.C_NBSFI)
	If this.C_NBSFI(IJ)<>null
	  If this.C_NBSFI(IJ).SFINUM=0 : Break : Endif
	  this.C_NBSFI(IJ).DTAAMT = 0
	Endif
Next

# --- Raz du bloc NBTRF
For IJ=1 To maxtab(this.C_NBTRF)
	#If this.C_NBTRF(IJ) <> null
		WRET= fmet this.ADELLINE("C_NBTRF",IJ)
	#Endif
Next

# --- Maj de valeurs par défaut
Gosub FROM_DEFAULT

# --- Maj des éléments issus du client ( facture ou commande )
If this.S_BPCORD<>"" or this.S_BPCINV<>""
    Gosub FROM_BPC
Endif

If this.APARENT <> null
	WRET=fmet this.UPD_NBFAC
Endif

Return

######################################################################################
# Chargement des lignes dans tableau des transferts
######################################################################################
#-------------------------------------------------------------------------------------
# Lignes issues des valeurs par défaut
#-------------------------------------------------------------------------------------
$FROM_DEFAULT
#--Globales à remplacer :
#GLOCALDEV
#--/Globales
Local Integer PORI, PDTA
Local Decimal PDTAAMT

For IJ0=1 To maxtab(this.C_NBSFI)
 If this.C_NBSFI(IJ0) <> null and find(this.C_NBSFI(IJ0).ASTALIN,[V]CSCST_AEL,[V]CST_ANEWDEL)<1
   If this.C_NBSFI(IJ0).SFIORD=0 : Break : Endif
   If this.C_NBSFI(IJ0).DEFVAL<>0                      : # Présence d'une valeur par défaut
      PDTA=this.C_NBSFI(IJ0).SFINUM                    : # No. element (critère de tri du tableau NBTRF)
      If this.C_NBSFI(IJ0).AMTCOD=2                    : # C'est un montant
         If this.C_NBSFI(IJ0).SFICUR<>PCUR              : # Convertir dans la devise du document
            Local Integer STAT
            Local Integer CHGTYP
            If dim(this.APARENT.CHGTYP)>0
                [L]CHGTYP=this.APARENT.CHGTYP
            Else
                [L]CHGTYP=1
            Endif
            #Call CONVERT(this.C_NBSFI(IJ0).SFICUR,PCUR,GLOCALDEV,[L]CHGTYP,PRATDAT,this.C_NBSFI(IJ0).DEFVAL,PDTAAMT,STAT) From TRTDEV
            Call CONVERT(this.C_NBSFI(IJ0).SFICUR,PCUR,"",[L]CHGTYP,PRATDAT,this.C_NBSFI(IJ0).DEFVAL,PDTAAMT,STAT) From TRTDEV
            If STAT<>0
                PDTAAMT=this.C_NBSFI(IJ0).DEFVAL
            Endif
         Else
            PDTAAMT = this.C_NBSFI(IJ0).DEFVAL
         Endif
      Else
         PDTAAMT = this.C_NBSFI(IJ0).DEFVAL
      Endif
      PORI = 9
      Call ADD_NBTRF(this,PORI, PDTA, PDTAAMT)
   Endif
 Endif
Next IJ0
Return

#-------------------------------------------------------------------------------------
# Lignes issues des clients ( facture ou commande )
#-------------------------------------------------------------------------------------
$FROM_BPC
#--Globales à remplacer :
#GLOCALDEV
#--/Globales
Local Integer PORI, PDTA
Local Decimal PDTAAMT

  Local File BPCUSTOMER [BPC]

For IJ0=1 To maxtab(this.C_NBSFI)
 If this.C_NBSFI(IJ0) <> null and find(this.C_NBSFI(IJ0).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
   If this.C_NBSFI(IJ0).SFIORD=0 : Break : Endif

   If this.C_NBSFI(IJ0).BPCORI=1                       : # Origine client facture
      If [F:BPC]BPCNUM<>this.S_BPCINV
         Read [BPC]BPC0=this.S_BPCINV
         If fstat : Raz [F:BPC] : Endif
      Endif
   Endif

   If this.C_NBSFI(IJ0).BPCORI=2                       : # Origine client commande
      If [F:BPC]BPCNUM<>this.S_BPCORD
         Read [BPC]BPC0=this.S_BPCORD
         If fstat : Raz [F:BPC] : Endif
      Endif
   Endif

   IJ2=find (this.C_NBSFI(IJ0).SFINUM,[F:BPC]INVDTA)
   If IJ2
      PDTA=this.C_NBSFI(IJ0).SFINUM                      : # No. element (critère de tri du tableau NBTRF)
      Raz PDTAAMT
      If this.C_NBSFI(IJ0).AMTCOD=2                      : # C'est un montant
         If [F:BPC]CUR<>PCUR       : # Convertir dans la devise du document
            Local Integer STAT
            Local Integer CHGTYP
            If dim(this.APARENT.CHGTYP)>0
                [L]CHGTYP=this.APARENT.CHGTYP
            Else
                [L]CHGTYP=1
            Endif
            #Call CONVERT([F:BPC]CUR,PCUR,GLOCALDEV,[L]CHGTYP,PRATDAT,[F:BPC]INVDTAAMT(IJ2-1),PDTAAMT,STAT) From TRTDEV
            Call CONVERT([F:BPC]CUR,PCUR,"",[L]CHGTYP,PRATDAT,[F:BPC]INVDTAAMT(IJ2-1),PDTAAMT,STAT) From TRTDEV
            If STAT<>0
                PDTAAMT=this.C_NBSFI(IJ0).DEFVAL
            Endif
         Else
            PDTAAMT=[F:BPC]INVDTAAMT(IJ2-1)
         Endif
      Else
         PDTAAMT=[F:BPC]INVDTAAMT(IJ2-1)
      Endif
      PORI=5
      Call ADD_NBTRF(this,PORI, PDTA, PDTAAMT)
   Endif
 Endif
Next IJ0

Return
#----------------------------------------------------------------------------------
Subprog ADD_NBTRF(PSFITRF,PORI, PDTA, PDTAAMT)
Variable Instance PSFITRF Using C_SFITRF
Value Integer PORI
Value Integer PDTA
Value Decimal PDTAAMT

If PSFITRF=null : End : Endif

Local Integer IJ0, IJ1

# find manuel, car sur plusieurs critères : DTA et ORI
IJ1=-1
For IJ0 = 1 To maxtab(PSFITRF.C_NBTRF)
 If PSFITRF.C_NBTRF(IJ0) <> null
  If  PSFITRF.C_NBTRF(IJ0).DTA = PDTA and PSFITRF.C_NBTRF(IJ0).ORI = PORI
    IJ1=IJ0
    Break
  Endif
 Endif
Next


If IJ1=-1 : # Si nouveau
	PSFITRF.NBTRF = fmet PSFITRF.ADDLINE("C_NBTRF",[V]CST_ALASTPOS) :#-- IJ1=-1 donc la ligne sera ajoutée à la fin
	IJ1=PSFITRF.NBTRF
Endif

PSFITRF.C_NBTRF(IJ1).ORI      =PORI
PSFITRF.C_NBTRF(IJ1).DTA      =PDTA
PSFITRF.C_NBTRF(IJ1).DTAAMTORI=PDTAAMT
PSFITRF.C_NBTRF(IJ1).DTAAMTCLC=PDTAAMT

End
#------------------------------------------------------------------------------------
######################################################################################
# Calcul des éléments :                                                              #
#  - Eclatement dans SFITRF                                                          #
#  - Regroupement de SFITRF -> SFI                                                   #
# Appelé par $FIN_PICK, par l'intermédiaire d'un Subprog XXX_YYY_CALCUL()            #
#  ou par $INIT_SFIT                                                                 #
######################################################################################
#Subprog UPD_NBFAC(PSFITRF)
#Variable Instance PSFITRF Using C_SFITRF
#Variable Instance PDOCUMENT Using OBJECT
#Value Char PTYPE_CLS
$UPD_NBFAC
#--Globales à remplacer :
#GREP
#--/Globales

If this=null : End : Endif

#--Nous allons mettre à jour la classe parente de SFITRF ...
If this.APARENT = null : End : Endif

Local Char TST_RUL

#--A remplacer--If GREP<>"C" : End : Endif

#--NA--Gosub SAVE_DEFS

Local Integer SAVIND : SAVIND=indice

Local Integer WERR
Local Integer WRET

# Regen du TST_RUL
If this.C_ORIVCR<>this.C_DESVCR
    TST_RUL="~" + num$(this.C_ORIVCR) + "~" + num$(this.C_DESVCR)
Else
    TST_RUL=""
Endif
Local Integer IJ0, IJ1, IJSFI
Local Integer IJW
Local Integer TOATTRIB : # Pour Eclatement de type "1ere"
Local Decimal TMTGOAL : # Prorata % : Mt à obtenir

# Eclatement
Local Integer BRDRUL

For IJ0=1 To maxtab(this.C_NBTRF)
	If this.C_NBTRF(IJ0) <> null and find(this.C_NBTRF(IJ0).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
    If this.C_NBTRF(IJ0).DTA=0     : Break : Endif :#--?-- je pense qu'il n'y a plus besoin dans le cas de collections de classes...

		IJ1=find(num$(this.C_NBTRF(IJ0).DTA) + TST_RUL, this.C_NBSFIT(1..maxtab(this.C_NBSFIT)).T_TST_RUL)

		IJSFI=find(this.C_NBTRF(IJ0).DTA , this.C_NBSFI(1..maxtab(this.C_NBSFI)).SFINUM)

    If IJSFI>0 and IJSFI<=maxtab(this.C_NBSFI) and IJ1<>0 and this.C_NBTRF(IJ0).ORI<5 and this.C_NBTRF(IJ0).ORI<>0 : # Lié au document
        #Recup règle d'éclatement
        [L]BRDRUL = this.C_NBSFIT(IJ1).T_BRDRUL
        If    [L]BRDRUL =  9 : # Prorata Montants
            If this.C_NBTRF(IJ0).TOTAMTPRO<>0
                If this.C_NBSFI(IJSFI-1).AMTCOD=1 # If TAUX
                    # Pas utilisé, laissé au cas où ("ceinture et bretelles")
                    this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
                Else # Montant
                    this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGAMTPRO / this.C_NBTRF(IJ0).TOTAMTPRO
                Endif
            Else
                this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
            Endif
        Elsif [L]BRDRUL = 10 : # Prorata Quantités
            If this.C_NBTRF(IJ0).TOTQTYPRO<>0 and this.C_NBTRF(IJ0).LIGAMTPRO<>0
                If this.C_NBSFI(IJSFI-1).AMTCOD=1 : # If TAUX
                    [L]TMTGOAL=this.C_NBTRF(IJ0).TOTAMTPRO * this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGQTYPRO / this.C_NBTRF(IJ0).TOTQTYPRO
                    this.C_NBTRF(IJ0).DTAAMTCLC = [L]TMTGOAL / this.C_NBTRF(IJ0).LIGAMTPRO
                Else  : # Montant
                    this.C_NBTRF(IJ0).DTAAMTCLC = this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGQTYPRO / this.C_NBTRF(IJ0).TOTQTYPRO
                Endif
            Elsif this.C_NBTRF(IJ0).LIGAMTPRO=0
                this.C_NBTRF(IJ0).DTAAMTCLC=0
            Else this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
            Endif
        Elsif [L]BRDRUL = 11 : # Prorata Poids
            If this.C_NBTRF(IJ0).TOTWEIPRO<>0 and this.C_NBTRF(IJ0).LIGAMTPRO<>0
                If this.C_NBSFI(IJSFI-1).AMTCOD=1 : # If TAUX
                    [L]TMTGOAL=this.C_NBTRF(IJ0).TOTAMTPRO * this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGWEIPRO / this.C_NBTRF(IJ0).TOTWEIPRO
                    this.C_NBTRF(IJ0).DTAAMTCLC = [L]TMTGOAL / this.C_NBTRF(IJ0).LIGAMTPRO
                Else  : # Montant
                    this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGWEIPRO / this.C_NBTRF(IJ0).TOTWEIPRO
                Endif
            Elsif this.C_NBTRF(IJ0).LIGAMTPRO=0
                this.C_NBTRF(IJ0).DTAAMTCLC=0
            Else this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
            Endif
        Elsif [L]BRDRUL = 12 : # Prorata Volumes
            If this.C_NBTRF(IJ0).TOTVOLPRO<>0 and this.C_NBTRF(IJ0).LIGAMTPRO<>0
                If this.C_NBSFI(IJSFI-1).AMTCOD=1 : # If TAUX
                    [L]TMTGOAL=this.C_NBTRF(IJ0).TOTAMTPRO * this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGVOLPRO / this.C_NBTRF(IJ0).TOTVOLPRO
                    this.C_NBTRF(IJ0).DTAAMTCLC = [L]TMTGOAL / this.C_NBTRF(IJ0).LIGAMTPRO
                Else  : # Montant
                    this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI * this.C_NBTRF(IJ0).LIGVOLPRO / this.C_NBTRF(IJ0).TOTVOLPRO
                Endif
            Elsif this.C_NBTRF(IJ0).LIGAMTPRO=0
                this.C_NBTRF(IJ0).DTAAMTCLC=0
            Else this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
            Endif
        Elsif find([L]BRDRUL,1,2,3,4)<>0 : # 1ere
            TOATTRIB=0
            Case this.C_ORIVCR
                When 10, 12 : # SOH
                		#--On passe par la classe C_SORDER
                  	If 1=1
                      #If clalev([F:SOH1])=0
                          Local File SORDER [SOH1]
                          #--NA--
                          #If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                      #Endif
                      If [F:SOH1]SOHNUM<>this.VCRENT(IJ0)
                          Read [F:SOH1]SOH0=this.VCRENT(IJ0)
                      Endif
                      If  (this.C_DESVCR=2  and [F:SOH1]DLVSTA=1)
&	                     or (this.C_DESVCR=18 and [F:SOH1]INVSTA=1)
&	                      or [F:SOH1]SOHCAT=4 # Commande ouverte
                          TOATTRIB=1
                      Endif
										 Else
										 	 If this.C_NBTRF(IJ0).VCRENT<>""
  										 	 Local Instance WSORDER Using C_SORDER
  										 	 WSORDER = NewInstance =this.AllocGrp, C_SORDER
  											 WERR=WSORDER.AREAD(this.C_NBTRF(IJ0).VCRENT)
  											 #If WERR....
                          If  (this.C_DESVCR=2  and WSORDER.DLVSTA=1)
&	                    		 or (this.C_DESVCR=18 and WSORDER.INVSTA=1)
&	                    		 or  WSORDER.SOHCAT=4 # Commande ouverte
                              TOATTRIB=1
                          Endif
  										 Endif
										 Endif
                When 2 : # SDH
                    # 1 livraison est forcément éclatée sur 1 seule facture
                    #If [F:SDH]SDHNUM<>this.VCRENT(IJ0)
                    #    Read [F:SDH]SDH0=this.VCRENT(IJ0)
                    #Endif
                    #If [F:SDH]SIHNUM=""
                    TOATTRIB=1
                    #Endif
                When 1 : # SQH
                		#--On passe par la classe C_SQUOTE
                		If 1=1
                      #If clalev([F:SQH1])=0
                          Local File SQUOTE [SQH1]
                          #--NA--
                          #If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                      #Endif
                      If [F:SQH1]SQHNUM<>this.VCRENT(IJ0)
                          Read [F:SQH1]SQH0=this.VCRENT(IJ0)
                      Endif
                      If [F:SQH1]QUOSTA=1
                          TOATTRIB=1
                      Endif
                    Else
										 	 If this.C_NBTRF(IJ0).VCRENT<>""
  										 	 Local Instance WSQUOTE Using C_SQUOTE
  										 	 WSQUOTE = NewInstance =this.AllocGrp, C_SQUOTE
  											 WERR=WSORDER.AREAD(this.C_NBTRF(IJ0).VCRENT)
  											 #If WERR...
                          If  WSQUOTE.QUOSTA=1
                              TOATTRIB=1
                          Endif
  										 Endif
										Endif
                When 4 : # SIH
                		#--On passe par la classe C_SINVOICE
                		If 1=1
                      #If clalev([F:SIV1])=0
                          Local File SINVOICEV [SIV1]
                          #--NA--
                          #If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif
                      #Endif
                      If [F:SIV1]NUM<>this.VCRENT(IJ0)
                          Read [F:SIV1]SIV0=this.VCRENT(IJ0)
                      Endif
                      If [F:SIV1]INVCNOSTA=1 : # Si Pas d'avoir
                          TOATTRIB=1
                      Endif
                    Else
										 	If this.C_NBTRF(IJ0).VCRENT<>""
  										 	Local Instance WSINVOICE Using C_SINVOICE
  										 	WSINVOICE = NewInstance =this.AllocGrp, C_SINVOICE
  											WERR=WSINVOICE.AREAD(this.C_NBTRF(IJ0).VCRENT)
                      	If WSINVOICE.INVCNOSTA=1 : # Si Pas d'avoir
                          TOATTRIB=1
                      	Endif
                      Endif
										Endif
            Endcase
            If TOATTRIB=1 & this.C_NBTRF(IJ0).LIGQTYPRO<>0 # Si suppression, on met 0 (51731)
                this.C_NBTRF(IJ0).DTAAMTCLC = this.C_NBTRF(IJ0).DTAAMTORI
            Else
                this.C_NBTRF(IJ0).DTAAMTCLC = 0
            Endif
        Elsif find([L]BRDRUL,5,6,7,8)<>0 : # Toutes
            this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
        Endif
    Else
        # Non lié au document (saisi, client ou defaut -> pas d'éclatement)
        this.C_NBTRF(IJ0).DTAAMTCLC=this.C_NBTRF(IJ0).DTAAMTORI
    Endif
	Endif
Next IJ0

For I=1 To maxtab(this.APARENT.C_INVDTAAMT)
	If this.APARENT.C_INVDTAAMT(I) <> null
		this.APARENT.C_INVDTAAMT(I).INVDTAAMT = 0
	Endif
Next

#--A Remplacer--
#If this.ACTX.USER="CPOx"
#	#Local Integer NBELTS : NBELTS = maxtab(this.C_NBTRF)
#	#Sorta NBELTS this.C_NBTRF(1..maxtab(this.C_NBTRF)).DTA Order By this.C_NBTRF([S]indice).ORI, this.C_NBTRF([S]indice).DAC, this.C_NBTRF([S]indice).DTA    : # Dde 81811 : Optimisation
#	WRET = fmet this.SORT3("C_NBTRF","DTA","ORI","DAC")
#Endif

# Regroupement
Local Integer GRURUL, DESTDOC
Local Integer IELT
Local Decimal NEWDTAAMT, OLDDTAAMT
Local Integer IJ2
Local Integer DTAFLG(0..maxtab(this.C_NBSFI))

#If max(this.C_NBTRF(1..maxtab(this.C_NBTRF)).DAC)>0 and dim(this.C_NBSFI.SFINUM)>0
    Local Decimal DTAMOYTAB (0..maxtab(this.C_NBSFI)) : # Tableau utilisé pour les moyennes : Moyenne
    Local Integer DTAMOYIND (0..maxtab(this.C_NBSFI)) : # Tableau utilisé pour les moyennes : Nb de valeurs
#Endif

For IJ0=1 To maxtab(this.C_NBSFI)
	If this.C_NBSFI(IJ0) <> null
    [L]DTAFLG(IJ0-1)=10
  Endif
Next IJ0

#If clalev([F:TCU])=0
    Local File TABCUR [TCU]  :
    #If dim(DEF_TAB)>0 & DEF_TAB<>"" Default File DEF_TAB Else Default File SAV_DEF_TAB Endif :#--Remplacé-- plus besoin..?
#Endif
If [F:TCU]CUR<>this.S_CUR            : # Dde 81811 : Optimisation
  Read [TCU]TCU0=this.S_CUR
Endif                                   : # Dde 81811 : Optimisation

For IJ0=1 To maxtab(this.C_NBTRF)
	If this.C_NBTRF(IJ0) <> null and find(this.C_NBTRF(IJ0).ASTALIN,[V]CST_ADEL,[V]CST_NEWDEL)<1
    If this.C_NBTRF(IJ0).DTA<>0
        # Indice de l'element dans la liste des élements (1e tableau)
        IJ2 = find(this.C_NBTRF(IJ0).DTA, this.C_NBSFI(1..maxtab(this.C_NBSFI)).SFINUM)

        # Retrouver la regle associée (2e tableau)
        IJ1=find(num$(this.C_NBTRF(IJ0).DTA) + TST_RUL, this.C_NBSFIT(1..maxtab(this.C_NBSFIT)).T_TST_RUL)

        IELT = find( this.C_NBTRF(IJ0).DTA,this.APARENT.C_INVDTAAMT(1..maxtab(this.APARENT.C_INVDTAAMT)).INVDTA)

        If IELT<>0 and IJ2<>0
        	If this.APARENT.C_INVDTAAMT(IELT) <> null
						[L]OLDDTAAMT = this.APARENT.C_INVDTAAMT(IELT).INVDTAAMT

            # On passe si on a trouvé  la règle, ou si l'origine n'est pas le document,
            # ou si on est dans le cas :
            #   Devis -> Proforma : 1-1, pas de paramétrage fait
            If ( IJ1<>0 or this.C_NBTRF(IJ0).ORI>=5 or this.C_NBTRF(IJ0).ORI=0
&                    or TST_RUL="~1~12" )
&                and [L]DTAFLG(IJ2-1)>=this.C_NBTRF(IJ0).ORI
                If this.C_NBTRF(IJ0).ORI>=5 or this.C_NBTRF(IJ0).ORI=0 or TST_RUL="~1~12"
                    [L]NEWDTAAMT = this.C_NBTRF(IJ0).DTAAMTCLC
                    [L]DTAFLG(IJ2-1)=this.C_NBTRF(IJ0).ORI
                Else
                    [L]DTAFLG(IJ2-1)=this.C_NBTRF(IJ0).ORI
                    #Recup règle de regroupement
                    [L]GRURUL = this.C_NBSFIT(IJ1-1).T_GRURUL
                    #--CPO 84215 Cas des élts en taux avec regroupement "Non si différent"
                    #--Dans ce cas la règle est vide, il faut l'alimenter
                    If [L]GRURUL=0
                      #--  this.C_ORIVCR ou this.C_NBSFIT(IJ1-1).T_ORIVCR?
                      Case this.C_NBSFIT(IJ1-1).T_ORIVCR
                          When 1  : [L]GRURUL=1 :# SQH
                          When 10 : [L]GRURUL=2 :# SOH Cde normale
                          When 12 : [L]GRURUL=2 :# SOH Cde à fact. directe
                          When 2  : [L]GRURUL=3 :# SDH
                          When 4  : [L]GRURUL=4 :# SIH
                      Endcase
                    Endif
                    #--/
                    # Retrouver le doc de destination
                    [L]DESTDOC=this.C_NBSFIT(IJ1-1).T_DESVCR
                    # Valeur actuelle de l'élément du document de destination
                    If find([L]GRURUL,1,2,3,4)<>0
                        # 1ere
                        If this.C_NBTRF(IJ0).DAC = func MINNOTZERO (this.C_NBTRF(1..maxtab(this.C_NBTRF)).DAC)
                            [L]NEWDTAAMT = this.C_NBTRF(IJ0).DTAAMTCLC
                        Else
                            [L]NEWDTAAMT = [L]OLDDTAAMT
                        Endif
                    Elsif    find([L]GRURUL,5,6,7,8)<>0
                        # Somme des montants devis, commandes, livraisons ou factures
                        [L]NEWDTAAMT=[L]OLDDTAAMT + this.C_NBTRF(IJ0).DTAAMTCLC
                    Elsif [L]GRURUL = 10 or [L]GRURUL=12
                        # Montant maxi ou % maxi
                        If this.C_NBTRF(IJ0).DAC = func MINNOTZERO (this.C_NBTRF(1..maxtab(this.C_NBTRF)).DAC)
                            [L]NEWDTAAMT = this.C_NBTRF(IJ0).DTAAMTCLC
                        Else
                            [L]NEWDTAAMT = max ([L]OLDDTAAMT , this.C_NBTRF(IJ0).DTAAMTCLC )
                        Endif
                    Elsif [L]GRURUL = 9 or [L]GRURUL=11
                        # Montant mini ou % mini
                        If this.C_NBTRF(IJ0).DAC = func MINNOTZERO (this.C_NBTRF(1..maxtab(this.C_NBTRF)).DAC)
                            [L]NEWDTAAMT = this.C_NBTRF(IJ0).DTAAMTCLC
                        Else
                            [L]NEWDTAAMT = min ([L]OLDDTAAMT , this.C_NBTRF(IJ0).DTAAMTCLC )
                        Endif
                    Elsif [L]GRURUL = 13
                        # % Moyen
                        [L]DTAMOYTAB(IJ2-1) = (([L]DTAMOYTAB(IJ2-1) * [L]DTAMOYIND(IJ2-1) ) + this.C_NBTRF(IJ0).DTAAMTCLC)/([L]DTAMOYIND(IJ2-1)+1)
                        [L]DTAMOYIND(IJ2-1)+=1
                        [L]NEWDTAAMT = [L]DTAMOYTAB(IJ2-1)
                    Elsif [L]GRURUL = 14
                        # TODO % Mt Mini
                    Elsif [L]GRURUL = 15
                        # TODO % Mt Max
                    Endif
                Endif
                # Impacter sur le doc de destination
                this.APARENT.C_INVDTAAMT(IELT).INVDTAAMT = [L]NEWDTAAMT
            Endif
          Endif
        Endif
    Endif
  Endif
Next IJ0


:#--A remplacer--
# Restauration du tri "naturel", indispensable pour MAJ_SFIT
#Sorta this.NBTRF this.NBTRF Order By this.ORI([S]indice) * -1, this.DAC([S]indice)*-1, this.DTA([S]indice)*-1

indice=SAVIND

Return
######################################################################################
# ACA - Renvoi le plus petit nombre d'un tableau, sauf 0
# Utilisé dans UPD_NBFAC
Funprog MINNOTZERO(TAB)
Value Integer TAB(1..)

Local Integer I
Local Integer RESULT
RESULT=1000

	#--CPO 83405 Bench GESSOH => sous-pro 2ème consommateur de proc après UPD_NBFAC !
	#--Voir d'autres algos de tri : par tas, par insertion etc...
  #  For I=0 To dim (TAB)-1
  #      If TAB(I)<RESULT & TAB(I)<>0
  #          RESULT=TAB(I)
  #      Endif
  #  Next I
	I=maxtab(TAB)
	If I>1
  	Sorta TAB  I
  	I=0
  	While I<dim(TAB) and TAB(I)=0
  	 I=I+1
  	Wend
  Endif
	If I>0 and I<dim(TAB) & TAB(I)<>0 : RESULT = TAB(I) Endif
	#--/CPO

End RESULT

