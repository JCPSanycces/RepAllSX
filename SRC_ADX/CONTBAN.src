#<AdxTL>@(#)37.0.0.0 $Revision$
Subprog CONTBAN(COD)
Variable Char COD()
Call CONTTYP(COD,1)
End

Subprog CONTCAI(COD)
Variable Char COD()
Call CONTTYP(COD,2)
End


Subprog CONTTYP(COD,TYP)
Variable Char    COD()
Value    Integer TYP

If COD="" : End : Endif # CP (02/05/03) : Suite au nouveau superviseur
If TYP<>0
 If clalev([F:BAN])=0
  Local File BANK
 Endif

 Read [F:BAN]BAN0=[L]COD

 # Contrôle du type banque ou caisse
 If fstat=0 & [F:BAN]BANCSH<>[L]TYP
  Case TYP
   When 1 : GMESSAGE = mess(126,121,1)
   When 2 : GMESSAGE = mess(125,121,1)
  Endcase
  mkstat = 2 : End
 Endif

 # Contrôle code d'accès
 If dim([F:BAN]ACS)>0
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif

Endif
End

