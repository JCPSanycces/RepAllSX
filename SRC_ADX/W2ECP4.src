#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_WEVAJOBGRP
Onevent INIT_AREA Call D_WEVAJOBGRP(zc) From W2ECP4
Onevent CONTROL Call C_WEVAJOBGRP(zc) From W2ECP4
Onevent BEFORE_INPUT Call AS_WEVAJOBGRP(zc) From W2ECP4
Return

Subprog D_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
If varinit([M]WEVAJOBGRP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10460","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10460") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WEVAJOBGRP(zc) From W2ECP4
Onkey   2 Titled GBOUTS Call S_WEVAJOBGRP(zc) From W2ECP4
Onkey 144 Titled GBOUTP Call P_WEVAJOBGRP(zc) From W2ECP4
Onkey 146 Titled GBOUTA Call SA_WEVAJOBGRP(zc) From W2ECP4
Gosub _AFF
End

Subprog C_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10460","") From SUBADI
If mkstat : GERR = 1 : GZONE = "WEVAJOBGRP" : GZNUM = 11105 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10460",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WEVAJOBGRP" : GZNUM = 11105 : Endif
Endif
Gosub _AFF
End

Subprog S_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10460"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10460") From GOBJET
Gosub _AFF
End

Subprog SA_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10460"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEVAJOBGRP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10460"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_WEVAJOBGRPDA
Onevent BEFORE_AREA Gosub AV_WEVAJOBGRPDA From W2ECP4
Return

$AV_WEVAJOBGRPDA
Chgfmt [M]WEVAJOBGRPDA(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_WFLGMOB
Onevent AFTER_CHANGE Gosub AMM_WFLGMOB From W2ECP4
Onevent INIT_AREA Call D_WFLGMOB(zc) From W2ECP4
Onevent BEFORE_INPUT Call AS_WFLGMOB(zc) From W2ECP4
Return

Subprog D_WFLGMOB(VALEUR)
Variable Integer VALEUR
If varinit([M]WFLGMOB,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WFLGMOB(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_WFLGMOB
Call AM_WFLGMOB(zc)
If !mkstat & GOBJET
 zoncou = "WFLGMOB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WFLGMOB(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_WFLGMOB(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WFLGMOB" : GZNUM = 47503 : Endif
Gosub _AFF
End

$ON_WEVAFCY
Onevent CONTROL Call C_WEVAFCY(zc) From W2ECP4
Onevent BEFORE_INPUT Call AS_WEVAFCY(zc) From W2ECP4
Return

Subprog AS_WEVAFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1427,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WEVAFCY(zc) From W2ECP4
Onkey   2 Titled GBOUTS Call S_WEVAFCY(zc) From W2ECP4
Onkey 144 Titled GBOUTP Call P_WEVAFCY(zc) From W2ECP4
Onkey 146 Titled GBOUTA Call SA_WEVAFCY(zc) From W2ECP4
Gosub _AFF
End

Subprog C_WEVAFCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "WEVAFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WEVAFCY" : GZNUM = 1344 : Endif
Endif
Gosub _AFF
End

Subprog S_WEVAFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_WEVAFCY(VALEUR)
Variable Char    VALEUR()
Call OBJET("FCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WEVAFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEVAFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

