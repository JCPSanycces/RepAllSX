Next I
If I1<nolign             : # on a trouve un précédent différent
  For I=I1 To 0 Step -1  : # on remonte maintenant pour trouver le même
    I2=nolign
    If [M]CRIT3(I)=[M]CRIT3(NOL-1) : I2=I+1 : Break : Endif
  Next I
  If I2<nolign
    [M]CRIT3(NOL)=[M]CRIT3(I2)
    If !GIMPORT : Affzo [M]CRIT3(NOL) : Endif
#    zonsui=GXPLBOUZS(3)+"("+num$(nolign-1)+")" : mkstat=99 : # positionnement ne marche pas
  Endif
Endif
Return


