#------------------------------------------#
# Contrôle supplémentaire sur les critères #
#------------------------------------------#
$CONTROLE_CRIT
Case [F:PPC]FLDTYP(I)
  When "BPS" : Gosub CONTROLE_BPS
  When "ITM" : Gosub CONTROLE_ITM
Endcase
Return

#-----------------------------------------------------#
# Contrôle sur fournisseur : même structure tarifaire #
#-----------------------------------------------------#
$CONTROLE_BPS
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
Read [BPS] BPS0=VALEUR
If !fstat
  If [F:BPS]PLISTC<>[F:PPC]PLISTC
    GMESSAGE=mess(141,199,1) : GERR=1 : mkstat=1
  Endif
Else
  mkstat=1
Endif
Return

#----------------------------------------#
# Contrôle sur article : actif et acheté #
#----------------------------------------#
$CONTROLE_ITM
# Issue 77307 - 2011-10-21 by SR : Permettre les tarifs sur les articles inactifs
#Call CONTROLE("ITM","AB",VALEUR,"",mkstat) From CONTOBJ : #CHECK IGNORE_LINE
#--- Issue 103686
#Filter [F:ITM]
#Call CONTROLE("ITM","B",VALEUR,"",mkstat) From CONTOBJ : #CHECK IGNORE_LINE
#---
Return

