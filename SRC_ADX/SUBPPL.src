#CHECK IGNORE_END

######################################## Code devise ####################
Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
#----- Si devise déjà chargée pas d'init
If VALEUR<>""  End : Endif
If [F:PPC]CUR<>""
  #----- Si devise dans paramétrage, prendre devise du paramétrage et pas de saisie
  VALEUR=[F:PPC]CUR : mkstat=2
Elsif [F:PPC]CRIBPSNUM<>0
  #----- Si fournisseur dans les critères, prendre devise du fournisseur en init.
  Call LECTURE("BPS",evalue("[M]CRIT"+num$([F:PPC]CRIBPSNUM)+"(nolign-1)"),"") From CONTOBJ
  If !fstat  VALEUR=[F:BPS]CUR : Endif
Else
  #----- Sinon devise du site financier actif en init.
  VALEUR=GLOCALDEV
Endif
End

######################################## Code unité #####################
Subprog AS_UOM(VALEUR)
Variable Char    VALEUR()
#  si unité déjà chargée pas d'init
If VALEUR<>"" : End : Endif
#  article dans les critères : =unité de achat en init.
If [F:PPC]CRIITMNUM<>0
 Call LECTURE("ITM",evalue("[M]CRIT"+num$([F:PPC]CRIITMNUM)+"(nolign-1)"),"") From CONTOBJ
 If !fstat : VALEUR=[F:ITM]PUU : Endif
Endif
End
#---------------------------------------
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
# Controle uniquement si absence joker *
If VALEUR="*" : End : Endif
Call CONTROLE("TUN","",VALEUR,"",mkstat) From CONTOBJ
End
#---------------------------------------
Subprog S_UOM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TUN"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub AFF From GSAISIE
End

######################################## Quantité maxi ##################
Subprog AS_MAXQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If clalev([F:TUN])<=0 : Local File TABUNIT[TUN] : Endif
Read [TUN]TUN0=[M]UOM(nolign-1)
If !fstat
  If [F:TUN]UOMDEC=0 : VALEUR=99999999999     : Endif
  If [F:TUN]UOMDEC=1 : VALEUR=9999999999.9    : Endif
  If [F:TUN]UOMDEC=2 : VALEUR=999999999.99    : Endif
  If [F:TUN]UOMDEC=3 : VALEUR=99999999.999    : Endif
  If [F:TUN]UOMDEC=4 : VALEUR=9999999.9999    : Endif
  If [F:TUN]UOMDEC=5 : VALEUR=999999.99999    : Endif
  If [F:TUN]UOMDEC=6 : VALEUR=99999.999999    : Endif
Endif
End

#########################################################################
#########################################################################
#########################################################################

#------------------------------------------------------------------------
# --- Visu du libellé dans cadre du bas
#------------------------------------------------------------------------
$VISU_LIB
Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT>0
  GPPLTYP=[F:PPC]FLDTYP(ICRIT-1)
Endif

# Issue 71069 - 2016-01-29 by SR : PJT
If ICRIT > 0
  If [F:PPC]FLD(ICRIT-1) = "PJT" and GMODU(13) = 2
    #GSPLTYP = "OPP" #TEST MUARN S/P
    GPPLTYP = "OPP"
  Endif
Endif
# End issue 71069

Case GPPLTYP
  When "ITM", "BPS", "OPP": If CLEVISU="" Return Endif # Issue 71069 - 2016-01-29 by SR : PJT
  When Default Return
Endcase
[M]AFFLIB=""
If GPPLTYP= "ITM"
  If clalev([F:ITM])<=0 : Local File ITMMASTER [ITM] : Endif
  Call LECTURE("ITM",CLEVISU,"") From CONTOBJ
  #If !fstat : [M]AFFLIB=[F:ITM]ITMDES1 : Endif
  If !fstat
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]AFFLIB, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  Endif
Endif
If GPPLTYP= "BPS"
  If clalev([F:BPR])<=0 : Local File BPARTNER [BPR] : Endif
  Call LECTURE("BPR",CLEVISU,"") From CONTOBJ
  If !fstat : [M]AFFLIB=[F:BPR]BPRNAM : Endif
Endif
# Issue 71069 - 2016-01-29 by SR : PJT
If GPPLTYP = "OPP" and GMODU(13) = 2
  #Affaire
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  Read [OPP]OPP0=CLEVISU
  If fstat : Raz [F:OPP] : Endif
Endif
# End issue 71069
If !GIMPORT GERR=4 : GMESSAGE=[M]AFFLIB  : Endif
Return


#------------------------------------------------------------------------
# --- Chargement de cur et uom si dans critères
#------------------------------------------------------------------------
$VAL_DEFAUT
Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT<>0 & ICRIT=[F:PPC]CRICURNUM : [M]CUR(nolign-1)=VALEUR : Endif
If ICRIT<>0 & ICRIT=[F:PPC]CRIUOMNUM : [M]UOM(nolign-1)=VALEUR : Endif
# Issue 71069 - 2016-01-29 by SR : PJT
If ICRIT > 0 Then
  If [F:PPC]FLD(ICRIT-1) = "PJT" and GMODU(13) = 2
    Local Char SZMESSAGE(250)
    Local Char SZVALEUR(GLONVCR)
    Local Integer IBRETOUR
    Local Char SZCONTROL(50)

    If GMODU(13) = 2 Then
      If GCTLOPPCOD = 2 Then
        If VALEUR <> "" Then
           SZCONTROL = "***" # Pas de controle du site
          Call VERIFOBJCODE("OPP", SZCONTROL, SZVALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
          If IBRETOUR = 0 Then
            GMESSAGE = SZMESSAGE
            mkstat = 1
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
Return


#------------------------------------------------------------------------
# --- Init Qté mini et montant mini si changement critères
#------------------------------------------------------------------------
$INI_QTYAMT
If [M]MINQTY(nolign-1)<>0 and [M]MINQTY(nolign-1)>[M]MAXQTY(nolign-1)
  [M]MINQTY(nolign-1)=0 : [M]MAXQTY(nolign-1)=0
  If !GIMPORT : Affzo [M]MINQTY(nolign-1), MAXQTY(nolign-1) : Endif
Endif
If [M]MINAMT(nolign-1)<>0 and [M]MINAMT(nolign-1)>[M]MAXAMT(nolign-1)
  [M]MINAMT(nolign-1)=0 : [M]MAXAMT(nolign-1)=0
  If !GIMPORT : Affzo [M]MINAMT(nolign-1), MAXAMT(nolign-1) : Endif
Endif
Return


#------------------------------------------------------------------------
# --- Chargement de cur et uom si tiers et article des critères sont modifiés
#------------------------------------------------------------------------
$SI_BPRBPSITM
Local Integer ICRIT    : # no de critère
If len(GSPLZON)=5 & mid$(GSPLZON,1,4)="CRIT"
   ICRIT=val(mid$(GSPLZON,5,1))
 Else ICRIT=0
Endif
If ICRIT>0
  If find([F:PPC]FLDTYP(ICRIT-1),"BPR","BPS")
    Call LECTURE("BPS",VALEUR,"") From CONTOBJ : #CHECK IGNORE_LINE
    If !fstat
      [M]CUR(nolign-1)=[F:BPS]CUR
      If !GIMPORT : Affzo [M]CUR(nolign-1) : Endif
      If [F:PPC]CRICURNUM>ICRIT
        Case [F:PPC]CRICURNUM
          When 1 : [M]CRIT1(nolign-1)=[F:BPS]CUR : Affzo [M]CRIT1(nolign-1)
          When 2 : [M]CRIT2(nolign-1)=[F:BPS]CUR : Affzo [M]CRIT2(nolign-1)
          When 3 : [M]CRIT3(nolign-1)=[F:BPS]CUR : Affzo [M]CRIT3(nolign-1)
          When 4 : [M]CRIT4(nolign-1)=[F:BPS]CUR : Affzo [M]CRIT4(nolign-1)
          When 5 : [M]CRIT5(nolign-1)=[F:BPS]CUR : Affzo [M]CRIT5(nolign-1)
        Endcase
      Endif
    Endif
  Endif
  If find([F:PPC]FLDTYP(ICRIT-1),"ITM")
    Call LECTURE("ITM",VALEUR,"") From CONTOBJ : #CHECK IGNORE_LINE
    If !fstat
      [M]UOM(nolign-1)=[F:ITM]PUU
      If !GIMPORT : Affzo [M]UOM(nolign-1) : Endif
      If [F:PPC]CRIUOMNUM>ICRIT
        Case [F:PPC]CRIUOMNUM
          When 1 : [M]CRIT1(nolign-1)=[F:ITM]PUU : Affzo [M]CRIT1(nolign-1)
          When 2 : [M]CRIT2(nolign-1)=[F:ITM]PUU : Affzo [M]CRIT2(nolign-1)
          When 3 : [M]CRIT3(nolign-1)=[F:ITM]PUU : Affzo [M]CRIT3(nolign-1)
          When 4 : [M]CRIT4(nolign-1)=[F:ITM]PUU : Affzo [M]CRIT4(nolign-1)
          When 5 : [M]CRIT5(nolign-1)=[F:ITM]PUU : Affzo [M]CRIT5(nolign-1)
        Endcase
      Endif
    Endif
  Endif
Endif

Return

#------------------------------------------------------------------------
# --- definition des boutons des champs (critères,devise,unité,qté début)
#------------------------------------------------------------------------
$DEFBOUT_CRIT
# Issue 71069 - 2016-02-02 by SR : PJT
Local Integer I, I1, I2, I3, I4, NOL
Local Char    TD_CRIT (3) : # type de donnée
GBOUT1 = ""
# Issue 71069 - 2016-02-02 by SR : PJT : Initialiser I3
Case GSPLZON
  When "CRIT1"      : TD_CRIT=[F:PPC]FLDTYP(0) : I3=0
  When "CRIT2"      : TD_CRIT=[F:PPC]FLDTYP(1) : I3=1
  When "CRIT3"      : TD_CRIT=[F:PPC]FLDTYP(2) : I3=2
  When "CRIT4"      : TD_CRIT=[F:PPC]FLDTYP(3) : I3=3
  When "CRIT5"      : TD_CRIT=[F:PPC]FLDTYP(4) : I3=4
  When Default
Endcase
# Issue 71069 - 2016-01-29 by SR : PJT
If [F:PPC]FLD(I3) = "PJT" and GMODU(13) = 2 Then
  TD_CRIT = "OPP"
Endif
# End issue 71069
Case TD_CRIT
  When "ITM"         : GBOUT1=mess(22,198,1) : [M]OBJET="ITM"
  When "BPR", "BPS"  : GBOUT1=mess(73,198,1) : [M]OBJET="BPS"
  When "OPP"         : GBOUT1=mess(274,197,1): [M]OBJET="OPP"   # Issue 71069 - 2016-01-29 by SR : PJT
  When Default
Endcase

GBOUT2 = GXPLBOULIB(1)   : # pour critère-1 suivant
GBOUT3 = GXPLBOULIB(2)   : # pour critère-2 suivant
GBOUT4 = GXPLBOULIB(3)   : # pour critère-3 suivant
GBOUT5 = GXPLBOULIB(4)   : # pour critère-4 suivant
GBOUT6 = GXPLBOULIB(5)   : # pour critère-5 suivant
GBOUT7 = GXPLBOULIB(6)   : # pour devise suivante
GBOUT8 = GXPLBOULIB(7)   : # pour unité suivante

# Suppression des Boutons 2 à 8 (suivants) ?

If GBOUT2<>""  : # critère-1 + si BPR BPS ITM à partir ligne 2
  If !find ([F:PPC]FLDTYP(0),"BPR","BPS","ITM") | nolign<2
    Raz GBOUT2
  Endif
Endif
###########################
#  PAS DE SUIVANT SUR SAISIE TARIFS ACHATS (PB DES STRUCTURES DIFFERENTES
###########################
Raz GBOUT2
###########################

If nolign<4 : Raz GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8 : Endif

If GBOUT3<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT2(I)<>[M]CRIT2(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT2(I)=[M]CRIT2(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT3 : Endif
Endif

If GBOUT4<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT3(I)<>[M]CRIT3(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT3(I)=[M]CRIT3(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT4 : Endif
Endif

If GBOUT5<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT4(I)<>[M]CRIT4(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT4(I)=[M]CRIT4(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT5 : Endif
Endif

If GBOUT6<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CRIT5(I)<>[M]CRIT5(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CRIT5(I)=[M]CRIT5(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT6 : Endif
Endif

If GBOUT7<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]CUR(I)<>[M]CUR(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]CUR(I)=[M]CUR(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT7 : Endif
Endif

If GBOUT8<>""
  NOL=nolign-1 : I1=nolign : I2=nolign
  For I=NOL-1 To 0 Step -1
    If [M]UOM(I)<>[M]UOM(NOL-1) : I1=I : Break : Endif
  Next I
  If I1<nolign
    For I=I1 To 0 Step -1
      If [M]UOM(I)=[M]UOM(NOL-1) : I2=I+1 : Break : Endif
    Next I
  Endif
  If I2=nolign : Raz GBOUT8 : Endif
Endif


Return


#------------------------------------------------------------------------
# --- Bouton Tunnel des critères
#------------------------------------------------------------------------
$BOUT_CRIT
Local Char TD_CRIT (3) : # type de donnée
GBOUT1 = ""              : # pour les tunnels
Raz [M:PPLW]OBJET
Case GSPLZON
  When "CRIT1"      : TD_CRIT=[F:PPC]FLDTYP(0)
  When "CRIT2"      : TD_CRIT=[F:PPC]FLDTYP(1)
  When "CRIT3"      : TD_CRIT=[F:PPC]FLDTYP(2)
  When "CRIT4"      : TD_CRIT=[F:PPC]FLDTYP(3)
  When "CRIT5"      : TD_CRIT=[F:PPC]FLDTYP(4)
  When Default
Endcase
Case TD_CRIT
  When "ITM"        : GBOUT1=mess(22,198,1)  : [M:PPLW]OBJET="ITM"
  When "BPR", "BPS" : GBOUT1=mess(17,7,1)    : [M:PPLW]OBJET="BPS"
  When Default
Endcase
Return


#------------------------------------------------------------------------
# --- Bouton Critère-1 Suivant
#------------------------------------------------------------------------
$CRIT1_SUIVANT
# uniquement si critère alpha et certains fichiers
If nolign<2 : Return : Endif
Case [F:PPC]FLDTYP(0)
  When "BPR", "BPS"           : Gosub BPS_SUIVANT
  When "ITM"                  : Gosub ITM_SUIVANT
  When Default
Endcase
Return

$BPS_SUIVANT
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
Read [BPS]BPS0>[M]CRIT1(nolign-2)
If !fstat
  If [F:BPS]PLISTC = [F:PPC]PLISTC   : # la structure doit être identique
    [M]CRIT1(nolign-1)=[F:BPS]BPSNUM
    If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
    If !GIMPORT : Affzo [M]CRIT1(nolign-1) : Endif
    mkstat=99
  Else
    GERR = 1
    GMESSAGE = mess(141,199,1)
    mkstat=2
  Endif
Endif
Return

$ITM_SUIVANT
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
Filter [ITM] Where ITMREF>[M]CRIT1(nolign-2) & PHAFLG<>2
&            Order By ITM0
For [ITM]
  [M]CRIT1(nolign-1)=[F:ITM]ITMREF
  If GSPLZON="CRIT1" : VALEUR=[M]CRIT1(nolign-1) : Endif
  If !GIMPORT : Affzo [M]CRIT1(nolign-1) : Endif
  mkstat=99
  Break
Next
Filter [ITM]
Return


#------------------------------------------------------------------------
# --- Bouton Critère-2 Suivant
#------------------------------------------------------------------------
$CRIT2_SUIVANT
Local Integer I, I1, I2, NOL
If nolign<4 : Return : Endif
NOL=nolign-1
For I=NOL-1 To 0 Step -1 : # on remonte pour retrouver le prédédent différent
  I1=nolign
  If [M]CRIT2(I)<>[M]CRIT2(NOL-1) : I1=I : Break : Endif
Next I
If I1<nolign             : # on a trouve un précédent différent
  For I=I1 To 0 Step -1  : # on remonte maintenant pour trouver le même
    I2=nolign
    If [M]CRIT2(I)=[M]CRIT2(NOL-1) : I2=I+1 : Break : Endif
  Next I
  If I2<nolign
    [M]CRIT2(NOL)=[M]CRIT2(I2)
    If !GIMPORT : Affzo [M]CRIT2(NOL) : Endif
#    zonsui=GXPLBOUZS(2)+"("+num$(nolign-1)+")" : mkstat=99 : # positionnement ne marche pas
  Endif
Endif
Return


