#<AdxTL>@(#)0.0.0.0 $Revision$
##################################
# 104943 : version management in Work orders
#          - Enterprise Planning, planning workbench
##################################

#################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<1
    mkstat=2
Endif
End

##################################
# - Start-date (=Order date for SCO)
##################################
Subprog C_ECCVALMAJ(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR()

Call CTRECC([M]ITMREF,ABR,"ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

If find(GERR,1,4)
    GERR=1
    mkstat=2
Endif
End

##################################

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<2
    mkstat=2
Endif
End

##################################
# for usage in MBW1, MBW3, MBW3, SMW3
# - Start-date (=Order date for SCO)
##################################
Subprog C_ECCVALMIN(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR

Call CTRECC([M]ITMREF, ABR,"ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&           [M]STRDAT2,GERR,GMESSAGE) From ECCLIB

If find(GERR,1,4)
    GERR=1
    mkstat=2
Endif

End


##################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

If  VALEUR=""
& | dim([M:MBW3]ECCVALMAJ)<0
& | [M:MBW3]ECCVALMAJ=""
    End
Endif

If clalev([F:STL])=0 : Local File STOLOT [STL] : Endif
Read [STL]STL0(2)=[M:MBW3]ITMREF;VALEUR
Filter [STL]
If !fstat & !( [F:STL]ECCVALMAJ = [M:MBW3]ECCVALMAJ
&            & [F:STL]ECCVALMIN = [M:MBW3]ECCVALMIN)
    mkstat=2
    GMESSAGE = mess(395,184,1)
Endif

End

#**----------------------------------------------------------------<br/>
#* INIECCBOM : Return version number and BOM code for a date and BOM type
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = product managed with version
#* @param PFCY = site (optional)
#* @param PDAT = validity date (optional, if null -> date used is today)
#* @param PALTTYP = type of BOM (2=manufacturing, 3=sub-contracting)
#* @param PECCMAJ = major version (returned)
#* @param PECCMIN = minor version (returned)
#* @param PALT = BOM code (returned)
#**<br/>----------------------------------------------------------------
#*!
Subprog INIECCBOM(PITM,PFCY,PDAT,PALTTYP,PECCMAJ,PECCMIN,PALT)
Value Char PITM
Value Char PFCY
Value Date PDAT
Value Integer PALTTYP
Variable Char PECCMAJ
Variable Char PECCMIN
Variable Integer PALT

Local Date WDATE : WDATE=PDAT

Raz PECCMAJ

# BOM version management is different thant Stock version management
If !find(PALTTYP,2,3) End Endif

If WDATE=[0/0/0] WDATE=date$ Endif

# Get the BOM code available to use for versions
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]PITM
   Read [ITM]ITM0 = [L]PITM
   If fstat : Raz [F:ITM] : Endif
Endif
Case PALTTYP
    When 2 : PALT = [F:ITM]ECCBOMALT2(1)
    When 3 : PALT = [F:ITM]ECCBOMALT3(1)
Endcase
Look [TBO]TBO1=PFCY;PALT;PALTTYP
If fstat
    Look [TBO]TBO1="";PALT;PALTTYP
    If fstat
        # The BOM code is not valid for this site
        PALT=0
        End
    Endif
Endif

# Issue 112742 - 2015-12-01 by CCC : reorder selection of preloaded version
# 1- Look for a version available for the date : highest priority for the current version and after exceptions

# existence Major/Minor version for current flow type (= BOM alternative type in this case)
If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&          As [LNK]
&          Where [EVL]ITMREF=PITM
&              & [EVL]ECCTYP=PALTTYP
&              & [EVL]USESTA=2
&              & [EVL]STRDAT<=WDATE
&              & ( [F:EVL]ENDDAT=[0/0/0]
&                | [F:EVL]ENDDAT>=WDATE
&                | [F:EVL]EXNFLG=2 & ([F:EVL]EXNDAT=[0/0/0] | [F:EVL]EXNDAT>=WDATE) )
&              & [F:ECS]ECCSTA<>3
&            Order By STRDAT Desc
For [LNK]
    PECCMAJ = [F:EVL]ECCVALMAJ
    PECCMIN = [F:EVL]ECCVALMIN
    PALT    = [F:EVL]BOMALT
    Break
Next

# 2- Look for a version available later than the date asked
If PECCMAJ=""
    # existence Major/Minor version for current flow type (= BOM alternative type in this case)
    Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&              As [LNK]
&              Where [EVL]ITMREF=PITM
&                  & [EVL]ECCTYP=PALTTYP
&                  & [EVL]USESTA=2
&                  & [EVL]STRDAT>WDATE
&                  & [F:ECS]ECCSTA<>3
&                Order By STRDAT Asc
    For [LNK]
        PECCMAJ = [F:EVL]ECCVALMAJ
        PECCMIN = [F:EVL]ECCVALMIN
        PALT    = [F:EVL]BOMALT
        Break
    Next
Endif
End

#**----------------------------------------------------------------<br/>
#* INIECCITM : Return version number for a date
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = product managed with version
#* @param PFCY = site (optional)
#* @param PDAT = validity date (optional, if null -> date used is today)
#* @param PECCMAJ = major version (returned)
#* @param PECCMIN = minor version (returned)
#* @param PECCTYP = flow type of version  (2=manufacturing, 3=sub-contracting, 4=stock)
#**<br/>----------------------------------------------------------------
#*!
Subprog INIECCITM(PITM,PFCY,PDAT,PECCMAJ,PECCMIN,PECCTYP)
Value Char PITM
Value Char PFCY
Value Date PDAT
Variable Char PECCMAJ
Variable Char PECCMIN
Value Integer PECCTYP

Local Date WDATE : WDATE=PDAT

Raz PECCMAJ

If WDATE=[0/0/0] WDATE=date$ Endif

# existence Major/Minor version for current flow type (= '4' Stock in this case)
If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif

Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&          As [LNK]
&          Where [EVL]ITMREF=PITM
&              & [EVL]ECCTYP=PECCTYP
&              & [EVL]USESTA=2
&              & [EVL]STRDAT<=WDATE
&              & ([F:EVL]ENDDAT=[0/0/0] | [F:EVL]ENDDAT>=WDATE | [F:EVL]EXNFLG=2)
&              & ([F:EVL]EXNDAT=[0/0/0] | [F:EVL]EXNDAT>=WDATE | [F:EVL]EXNFLG=1)
&              & [F:ECS]ECCSTA<>3
&            Order By EXNFLG;ECCSEQ
For [LNK]
    PECCMAJ = [F:EVL]ECCVALMAJ
    PECCMIN = [F:EVL]ECCVALMIN
    Break
Next

End


######################################################################################
# Display or hide version fields in work order context
Subprog ECCAFF(ITM, ABR)
Value Char ITM
Value Char ABR
Local Char MABR(4+GLONABR)
If ABR="" : MABR="[M]" : Else MABR = "[M:"+ABR+"]" : Endif

If evalue("dim("+MABR+"ECCVALMAJ)")<0 | GIMPORT : End : Endif

Local Integer LACTMAJ, LACTMIN, LACTBOM
Local Integer I
I=func ECCLIB.NBRCPN(ITM)

If !I
    LACTMAJ = 0
    LACTMIN = 0
    LACTBOM = 1   # if no version management => BOMALT can be entered

Else
    # Issue 104943 - 2015-07-20 by BEEBE : implementing versioning - no modification
    # of version fields when WO status ist firm
    If clalev([F:ORD1])=0 | [F:ORD1]WIPSTA<>1 | [F:ORD1]WIPTYP<>5
        If I=1
            LACTMAJ = 1
            LACTMIN = 0
        Else
            LACTMAJ = 1
            LACTMIN = 1
        Endif
    Else
        LACTMAJ = 0
        LACTMIN = 0
    Endif
    LACTBOM=0   # if version management => BOMALT can't be entered
Endif

Affzo =MABR+"ECCVALMAJ"
If !LACTMAJ
   Diszo =MABR+"ECCVALMAJ"
Else
   Actzo =MABR+"ECCVALMAJ"
Endif

Affzo =MABR+"ECCVALMIN"
If !LACTMIN
   Diszo =MABR+"ECCVALMIN"
Else
   Actzo =MABR+"ECCVALMIN"
Endif

If evalue("dim("+MABR+"BOMALT)")>0
    Affzo =MABR+"BOMALT"
    If !LACTBOM
       Diszo =MABR+"BOMALT"
    Else
       Actzo =MABR+"BOMALT"
    Endif
Endif

If evalue("dim("+MABR+"BOMALT2)")>0
    Affzo =MABR+"BOMALT2"
    If !LACTBOM
       Diszo =MABR+"BOMALT2"
    Else
       Actzo =MABR+"BOMALT2"
    Endif
Endif
End

##################################

Subprog CTRECCPRD(ABR)
Value Char    ABR
Local Integer LRET
Local Char    MABR(4+GLONABR)
Local Date    WDATE

If ABR="" : MABR="[M] " : Else MABR = "[M:"+ABR+"]" : Endif

If evalue(MABR+"ECCVALMAJ")=""
   End
Endif

If evalue("dim("+MABR+"STRDAT2)")<0
    If evalue("dim("+MABR+"STRDAT)")>=0
        WDATE=evalue(MABR+"STRDAT")
    Endif
Else
    WDATE=evalue(MABR+"STRDAT2")
Endif

If WDATE=[0/0/0] : WDATE=date$ : Endif

Call CTRECC(evalue(MABR+"ITMREF")
&          ,ABR,"STRDAT"
&          ,evalue(MABR+"ECCVALMAJ")
&          ,evalue(MABR+"ECCVALMIN")
&          ,WDATE
&          ,GERR,GMESSAGE) From ECCLIB

If find(GERR,1,4)
   Call HIGHLIGHT(ABR,0) From ECCLIB
Endif

End

