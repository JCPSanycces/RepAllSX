#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ

Call OBJET("IDA",GBIDC1,"") From GOBJET
End

#----------------------------------------------------------------------------------------------------------------------------------
# Gestion des tables IDN-ID2-ID3-ID4-ID5-ID6-ID7-ID8
#----------------------------------------------------------------------------------------------------------------------------------
#DNA
###################################
$CHARGE_IDN
Read[IDN]IDN0=[F:IDA]YEAEMPDDS;[F:IDA]EMPDDS;[F:IDA]CTRNUM;[F:IDA]ETRDAT;[F:IDA]TYPDAE;[F:IDA]FLGDNA
If !fstat
 [M:IDN1]=[F:IDN]
 [M:IDN2]=[F:IDN]
 [M:IDN3]=[F:IDN]
Endif
Gosub CHARGE_ID2
Gosub CHARGE_ID3
Gosub CHARGE_ID4
Gosub CHARGE_ID5
Gosub CHARGE_ID6
Gosub CHARGE_ID7
Gosub CHARGE_ID8
If [M:IDN1]DNACCP<>1
 Effzo [M:IDN1]DNACCPNUM
 Grizo [M:IDN1]DNACCPNUM
Else
 Actzo [M:IDN1]DNACCPNUM
Endif
If [M:IDN1]LNK<>2
 Effzo [M:IDN1]TYPLNK
 Grizo [M:IDN1]TYPLNK
Else
 Actzo [M:IDN1]TYPLNK
Endif
Call GRISE_SORTIE ([M:IDN3]DNAENDDAT) From SUBIDA
[M:IDN3]RGMCOD1=[F:IDN]RGMCOD(0)
[M:IDN3]RGMCOD2=[F:IDN]RGMCOD(1)

Read[F:ID]ID0=[F:IDN]EMPDDS

# N4DS - L'écran IDN4 concerne les intermittents du spectacle, controlé par un code activité (INTMT)
If [V]GINTMT & clalev([M:IDN4]) 
    If [F:ID]FLGINT<>2 : # Le salarié n'est pas un intermittent
        Effzo[M:IDN4]
        Grizo[M:IDN4]
    Else
        Affzo[M:IDN4]
    Endif
Endif
Return

###################################
$CHARGE_ID2
nolign=0
For [ID2]ID20 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN2]=[F:ID2]
Next
[M:IDN2]NBRPRM = nolign
Return

###################################
$CHARGE_ID3
nolign=0
For [ID3]ID30 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN2]=[F:ID3]
Next
[M:IDN2]NBRIND1 = nolign
Return

###################################
$CHARGE_ID4
nolign=0
For [ID4]ID40 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN3]=[F:ID4]
Next
[M:IDN3]NBRPRV = nolign
Return

###################################
$CHARGE_ID5
nolign=0
For [ID5]ID50 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN2]=[F:ID5]
Next
[M:IDN2]NBRIND2 = nolign
Return

###################################
$CHARGE_ID6
Filter [ID6] Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
Read [F:ID6]ID60 Last
Filter [ID6]
If !fstat : [M:IDN1]=[F:ID6]: Endif
Return

###################################
$CHARGE_ID7
nolign=0
For [ID7]ID70 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN2]=[F:ID7]
Next
[M:IDN2]NBRDNG = nolign
Return

###################################
$CHARGE_ID8
If GINTMT=0 : Return : Endif
nolign=0
For [ID8]ID80 Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
 nolign += 1
 [M:IDN4]=[F:ID8]
Next
[M:IDN4]NBRDNH = nolign
Return


###################################
$SAUVE_IDN
Delete [IDN] Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$IDADDNA" : Return
Endif
[F:IDN]YEAEMPDDS=[F:IDA]YEAEMPDDS
[F:IDN]EMPDDS=[F:IDA]EMPDDS
[F:IDN]ETRDAT=[F:IDA]ETRDAT
[F:IDN]CTRNUM=[F:IDA]CTRNUM
[F:IDN]TYPDAE=[F:IDA]TYPDAE
[F:IDN]FLGDNA=[F:IDA]FLGDNA
[F:IDN]=[M:IDN1]
# N4DS - Info DNA un peu éclaté partout, on sauve aussi les valeurs stockées sur IDN2 et IDN3
[F:IDN]=[M:IDN2]
[F:IDN]=[M:IDN3]
[F:IDN]RGMCOD(0)=[M:IDN3]RGMCOD1
[F:IDN]RGMCOD(1)=[M:IDN3]RGMCOD2
Write [IDN]
If fstat<>0
 GOK = 0 : Call FSTA("IDN") From GLOCK 
Endif
Gosub SAUVE_ID2
Gosub SAUVE_ID3
Gosub SAUVE_ID4
Gosub SAUVE_ID5
Gosub SAUVE_ID6
Gosub SAUVE_ID7
Gosub SAUVE_ID8
Return

###################################
$SAUVE_ID2
Delete [ID2] Where YEAEMPDDS=[F:IDA]YEAEMPDDS & EMPDDS=[F:IDA]EMPDDS
&  & ETRDAT=[F:IDA]ETRDAT & CTRNUM=[F:IDA]CTRNUM & TYPDAE=[F:IDA]TYPDAE & FLGDNA=[F:IDA]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$IDADDNA2" : Return
Endif
For nolign=1 To [M:IDN2]NBRPRM
 [F:ID2]=[M:IDN2]
 [F:ID2]YEAEMPDDS=[F:IDA]YEAEMPDDS
 [F:ID2]EMPDDS=[F:IDA]EMPDDS
 [F:ID2]ETRDAT=[F:IDA]ETRDAT
 [F:ID2]CTRNUM=[F:IDA]CTRNUM
 [F:ID2]TYPDAE=[F:IDA]TYPDAE
 [F:ID2]FLGDNA=[F:IDA]FLGDNA
 [F:ID2]NUMLIG=nolign
 Write [ID2]
 If fstat<>0
  GOK = 0 : Call FSTA("ID2") From GLOCK : Break
 Endif
Next
Return

