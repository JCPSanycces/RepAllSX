 [F:ID3]YEAEMPDDS=[F:IDA]YEAEMPDDS
 [F:ID3]EMPDDS=[F:IDA]EMPDDS
 [F:ID3]ETRDAT=[F:IDA]ETRDAT
 [F:ID3]CTRNUM=[F:IDA]CTRNUM
 [F:ID3]TYPDAE=[F:IDA]TYPDAE
