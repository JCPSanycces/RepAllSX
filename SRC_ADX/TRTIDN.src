 [F:ID7]YEAEMPDDS=[F:IDA]YEAEMPDDS
 [F:ID7]EMPDDS=[F:IDA]EMPDDS
 [F:ID7]ETRDAT=[F:IDA]ETRDAT
 [F:ID7]CTRNUM=[F:IDA]CTRNUM
 [F:ID7]TYPDAE=[F:IDA]TYPDAE
 [F:ID7]FLGDNA=[F:IDA]FLGDNA
