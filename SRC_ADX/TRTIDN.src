For nolign=1 To [M:IDN2]NBRIND2
 [F:ID5]=[M:IDN2]
 [F:ID5]YEAEMPDDS=[F:IDA]YEAEMPDDS
 [F:ID5]EMPDDS=[F:IDA]EMPDDS
 [F:ID5]ETRDAT=[F:IDA]ETRDAT
 [F:ID5]CTRNUM=[F:IDA]CTRNUM
 [F:ID5]TYPDAE=[F:IDA]TYPDAE
 [F:ID5]FLGDNA=[F:IDA]FLGDNA
