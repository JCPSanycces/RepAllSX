#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
#  Librairie des traitements divers associés au suivi                                   #
# -----------------En déclaration de production, saisie stock-------------------------  #
#  MAJ_OF              : MAJ des quantité en Q et R en retour de contrôle qualité       #
#  CHARG_PARAM_STOENT  : Stocks 140  création                                           #
#  CHARG_PARAM_STOENTM : Stocks 140  modif                                              #
#  CTL_LIG_MTK :                                                                        #
#  MAJ_LIG_MTK :                                                                        #
#  CAL_AVAMFGQTY : Routine de calcul de la quantité productible par rapport à une mat.  #
#  REAJUST_TOUT: réajustement après Calcul de la qté productible                        #
#  MAJ_MTK     : Création automatique d'un suivi en réception de sous-traitance         #
#  DEL_SUIV    : suppression automatique d'un suivi en suppression de réception         #
#  DEL_QLYWRK  : suppression des réponses aux fiches techniques si abandon              #
#########################################################################################
# Issue X3-102712 - 2018-07-31 by BAKHA : Disable Non-conformance create button in Create/Amend mode

#####################################################################################
#                                                                                   #
#                    Traitement pour les stocks en V140                             #
#####################################################################################
#########################################################################
# MISE A JOUR OF suite à contrôle qualité                               #
# LQTYA   : quantité passée en statut "A"                               #
# LQTYR   : quantité passée en statut "R"                               #
# LVCRTYP : Type : OF ou Suivi de fabrication                           #
# LVCRNUM : Numéro d'OF ou de suivi de fabrication                      #
# LVCRLIN : Numéro de ligne d'OF ou de suivi de fabrication             #
#########################################################################
Subprog MAJ_OF (LQTYA,LQTYR,LVCRTYP,LVCRNUM,LVCRLIN)

Value Decimal  LQTYA,LQTYR
Value Integer  LVCRTYP
Value Char     LVCRNUM
Value Decimal  LVCRLIN

#----------------------------------------------------#
#--------------------------#
# ouverture des fichiers   #
#--------------------------#
If clalev([F:MTK]) = 0 Local File MFGHEADTRK   [MTK] : Endif
If clalev([F:MKI]) = 0 Local File MFGITMTRK    [MKI] : Endif
If clalev([F:MFG]) = 0 Local File MFGHEAD      [MFG] : Endif
If clalev([F:MFI]) = 0 Local File MFGITM       [MFI] : Endif
#
If LVCRTYP = 15
    #-----------------------------#
    # lecture enr décl prod       #
    #-----------------------------#
    Readlock [MKI]MKI0 = LVCRNUM;LVCRLIN
    If fstat = 1
              GOK = -1 : GLOCK = "$MFGITMTRK"-[F:MKI]MFGTRKNUM
              Call ROLL From GLOCK
              End
    Elsif fstat
              GOK = 0 : Call RSTA ("MKI",LVCRNUM) From GLOCK
              End
    Endif
    Read [F:MTK]MTK0   = LVCRNUM
    If fstat : Raz [F:MTK] : Endif

    # seulement si suivi sur OF
    If [F:MKI]PRODTYP = 1
        Call TRT_MFG(LQTYA,LQTYR,[F:MKI]MFGNUM,[F:MKI]MFGLIN)
        [F:MKI]QUARTNFLG = 2
        #point d'entrée  pour mise à jour spécifiques liées à [MKI] Issue 83469 GA 08/2012
        GPOINT = "BEFREWMKI" : Gosub ENTREE From EXEFNC
        Rewrite [MKI]
        If fstat
             GOK = 0 : Call FSTA ("MKI") From GLOCK
        Endif
    Endif
Else
   Call TRT_MFG(LQTYA,LQTYR,LVCRNUM,LVCRLIN)
Endif
End


##############################################################"
Subprog TRT_MFG(LQTYA,LQTYR,LVCRNUM,LVCRLIN)
Value Decimal  LQTYA,LQTYR
Value Char    LVCRNUM
Value Decimal LVCRLIN
#-----------------------------#
# lecture entête OF           #
#-----------------------------#
Readlock [MFG]MFG0 = LVCRNUM
If fstat = 1
          GOK = -1 : GLOCK = "$MFGHEAD"-LVCRNUM
          Call ROLL From GLOCK
          End
Elsif fstat
          GOK = 0 : Call RSTA ("MFG",LVCRNUM) From GLOCK
          End
Endif

#-----------------------------#
# lecture ligne article lancé #
#-----------------------------#
If LVCRLIN <> 0
   Readlock [MFI]MFI0 = LVCRNUM; LVCRLIN
   If fstat = 1
      GOK = -1 : GLOCK = "$MFGITM"-LVCRNUM-LVCRLIN
      Call ROLL From GLOCK
      End
   Elsif fstat
      GOK = 0 : Call RSTA ("MFI",LVCRNUM) From GLOCK
      End
   Endif
   If [F:MFI]ITMTYP <> 1 : End : Endif            # llc 06.04 pas si sous-produit
Else
   Filter [F:MFI] Where MFGNUM = LVCRNUM
   Readlock [F:MFI]MFI0 First
   If fstat = 1
      GOK = -1 : GLOCK = "$MFGITM"-LVCRNUM-LVCRLIN
      Call ROLL From GLOCK
      Filter [F:MFI]  # FQ 77545 GA 11/2011 ajout de la Raz
      End
   Elsif fstat
      GOK = 0 : Call RSTA ("MFI",LVCRNUM) From GLOCK
      Filter [F:MFI]  # FQ 77545 GA 11/2011 ajout de la Raz
      End
   Endif
   Filter [F:MFI]
   If [F:MFI]ITMTYP <> 1 : End : Endif            # llc 06.04 pas si sous-produit
Endif

#--------------------------------#
# mise a jour des qtés en Q et R #
#--------------------------------#
If LQTYA <> 0
    [F:MFG]QUACPLQTY -= LQTYA
    [F:MFI]QUACPLQTY -= LQTYA
Endif
If LQTYR <> 0
    [F:MFG]QUACPLQTY -= LQTYR
    [F:MFI]QUACPLQTY -= LQTYR
    [F:MFG]REJCPLQTY += LQTYR
    [F:MFI]REJCPLQTY += LQTYR
Endif

#point d'entrée  pour mise à jour spécifiques liées à [MFG] Issue 83469 GA 08/2012
GPOINT = "BEFREWMFG" : Gosub ENTREE From EXEFNC
Rewrite [MFG]
If fstat
         GOK = 0 : Call FSTA ("MFG") From GLOCK  : End
Endif

#point d'entrée  pour mise à jour spécifiques liées à [MFI] Issue 83469 GA 08/2012
GPOINT = "BEFREWMFI" : Gosub ENTREE From EXEFNC
Rewrite [MFI]
If fstat
         GOK = 0 : Call FSTA ("MFI") From GLOCK  : End
Endif
End


#####################################################################################
# Chargement des paramètres en saisie de l'écran de stock en création               #
#####################################################################################
Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer  LLIG
Case GFONC1
    When "GESMTK" : [M:ENT]STOFCY      = [M:MTK0]MFGFCY
                    [M:ENT]ITMREF      = [M:MTK2]ITMREF(LLIG)
                    [M:ENT]QTYTOENT    = [M:MTK2]UOMCPLQTY(LLIG)
                    [M:ENT]PCUTOENT    = [M:MTK2]UOM(LLIG)
                    [M:ENT]COETOENT    = [M:MTK2]UOMSTUCOE(LLIG)
                    [M:ENT]STU         = [M:MTK2]STU(LLIG)
                    [M:ENT]VCRNUM      = [M:MTK0]MFGTRKNUM
                    [M:ENT]VCRLIN      = [M:MTK2]ITMTRKLIN(LLIG)
                    [M:ENT]WSTOSEQ     = [M:MTK2]WSTOSEQ(LLIG)
                    [M:ENT]MVTDES      = [M:MTK2]MVTDES(LLIG)
                    [M:ENT]TRSFAM      = [F:MTS]TRSFAM
                    [M:ENT]SRGWAIFLG   = [F:MTS]SRGWAIFLG
                    [M:ENT]PRNCOD1     = [F:MTS]PRNCOD1
                    [M:ENT]PRNNBFLG1   = [F:MTS]PRNNBFLG1
                    [M:ENT]CCECODS     = [F:DTR]STOCCECOD
                    [M:ENT]TRSTYP      = 5                   : # Type mouvement (M.704)
                    [M:ENT]TRSCOD      = [M:MTK0]TRSCOD      : # code mouvement
                    [M:ENT]QUAFLG      = [M:MTK2]QUAFLG(LLIG): # Code contrôle qualité (2=Q uniquement)
                    [M:ENT]QUAFRE      = [M:MTK2]QUAFRE(LLIG): # hcb V6CQ
                    If dim([M:MTK2]WRH)>0
                      [M:ENT]XWRH      = [M:MTK2]WRH(LLIG)
                    Endif
                    [M:ENT]VCRNUMORI   = [M:MTK0]MFGNUM      : # Numéro d'OF
                    [M:ENT]VCRLINORI   = [M:MTK2]MFGLIN(LLIG)
                    [M:ENT]VCRTYPORI   = 10
                    [M:ENT]IPTDAT = [M:MTK0]MFGTRKDAT       : # Date imputation
                    Read [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK2]MFGLIN(LLIG)
                    If fstat : Raz [F:MFI] : Endif
                    If [F:MFI]LOT <> "" : GSAIFLG = "000000020000000" : Endif
                    # Issue 107513/8 - 2015-07-13 by JUSYN : Major and minor version
                    If dim([M:MTK2]ECCVALMAJORI) > 0
                        [M:ENT]ECCVALMAJORI  = [M:MTK2]ECCVALMAJORI(LLIG)   # original major version
                        [M:ENT]ECCVALMINORI  = [M:MTK2]ECCVALMINORI(LLIG)   # original minor version
                        [M:ENT]ECCBOMFLG     = 0
                    Endif
    When "FUNBENCHO","FUNBENCHI","FUNBENPLT":
                    [M:ENT]STOFCY      = [M:MBI]FCY
                    [M:ENT]ITMREF      = [M:MBI]ITMREF(LLIG)
                    [M:ENT]QTYTOENT    = [M:MBI]UOMCPLQTY(LLIG)
                    [M:ENT]PCUTOENT    = [M:MBI]UOM(LLIG)
                    [M:ENT]COETOENT    = [M:MBI]UOMSTUCOE(LLIG)
                    [M:ENT]STU         = [M:MBI]STU(LLIG)
                    [M:ENT]VCRNUM      = ""
                    [M:ENT]VCRLIN      = [M:MBI]WLINUM(LLIG)
                    [M:ENT]WSTOSEQ     = [M:MBI]WSTOSEQ(LLIG)
                    [M:ENT]MVTDES      = [M:MBI]MVTDES(LLIG)
                    If dim([M:MBI]WRH)>0
                      [M:ENT]XWRH      = [M:MBI]WRH(LLIG)
                    Endif
                    [M:ENT]TRSFAM      = [F:BTS]TRSFAM
                    [M:ENT]SRGWAIFLG   = [F:BTS]SRGWAIFLG
                    [M:ENT]PRNCOD1     = [F:BTS]PRNCOD1
                    [M:ENT]PRNNBFLG1   = [F:BTS]PRNNBFLG1
                    [M:ENT]CCECODS     = [F:DTR]STOCCECOD
                    [M:ENT]TRSTYP      = 5                   : # Type mouvement (M.704)
                    [M:ENT]TRSCOD      = [M:MBI]TRSCOD      : # code mouvement
                    [M:ENT]QUAFLG      = [M:MBI]QUAFLG(LLIG): # Code contrôle qualité (2=Q uniquement)
                    [M:ENT]VCRNUMORI   = [M:MBI]MFGNUM(LLIG)  : # Numéro d'OF
                    [M:ENT]VCRLINORI   = [M:MBI]MFGLIN(LLIG)
                    [M:ENT]VCRTYPORI   = 10
                    [M:ENT]IPTDAT = [M:MBI]IPTDAT(LLIG)       : # Date imputation
                    If [M:MBI]PRODTYP(LLIG) = 1
                        Read [F:MFI]MFI0 = [M:MBI]MFGNUM(LLIG);[M:MBI]MFGLIN(LLIG)
                        If fstat : Raz [F:MFI] : Endif
                        If [F:MFI]LOT <> "" : GSAIFLG = "000000020000000" : Endif
                    Endif
    When "FUNBENCHR"
                    [M:ENT]STOFCY      = [M:MBR]FCY
                    [M:ENT]ITMREF      = [M:MBR]ITMREF(LLIG)
                    [M:ENT]QTYTOENT    = [M:MBR]REIQTYPCU(LLIG)
                    [M:ENT]PCUTOENT    = [M:MBR]PCU(LLIG)
                    [M:ENT]COETOENT    = [M:MBR]PCUSTUCOE(LLIG)
                    [M:ENT]STU         = [M:MBR]STU(LLIG)
                    If dim([M:MBR]WRH)>0
                      [M:ENT]XWRH      = [M:MBR]WRH(LLIG)
                    Endif
                    [M:ENT]VCRNUM      = ""
                    [M:ENT]VCRLIN      = [M:MBR]WLINUM(LLIG)
                    [M:ENT]WSTOSEQ     = [M:MBR]WSTOSEQ(LLIG)
                    [M:ENT]MVTDES      = [M:MBR]MVTDES(LLIG)
                    [M:ENT]TRSFAM      = [F:BTS]TRSFAM
                    [M:ENT]SRGWAIFLG   = [F:BTS]SRGWAIFLG
                    [M:ENT]PRNCOD1     = [F:BTS]PRNCOD1
                    [M:ENT]PRNNBFLG1   = [F:BTS]PRNNBFLG1
                    [M:ENT]CCECODS     = [F:DTR]STOCCECOD
                    [M:ENT]TRSTYP      = 19                 : # Type mouvement (M.704)
                    [M:ENT]TRSCOD      = [M:MBR]TRSCODS     : # code mouvement
                    [M:ENT]QUAFLG      = 1                  : # Code contrôle qualité (2=Q uniquement)
                    # CCC (13/03/09) Bug 53214 : Alimentation des paramètre selon origine réintégration (annulation pesée ou directe)
                    If GMTK=""
                        If [M:MBR]MFGNUM(LLIG) <> ""
                            [M:ENT]STOFCYORI = [M:MBR]FCY
                            [M:ENT]VCRNUMORI = [M:MBR]MFGNUM(LLIG)
                            [M:ENT]VCRLINORI = [M:MBR]MFGLIN(LLIG)
                            [M:ENT]VCRSEQORI = [M:MBR]BOMSEQ(LLIG)
                            [M:ENT]VCRTYPORI = 10
                        Endif
                    Else
                            [M:ENT]STOFCYORI = [M:MBR]FCY
                            [M:ENT]VCRNUMORI = [M:MBR]MFGTRKNUM(LLIG)
                            [M:ENT]VCRLINORI = [M:MBR]MATTRKLIN(LLIG)
                            [M:ENT]VCRSEQORI = 0
                            [M:ENT]VCRTYPORI = 12 # Suivi matière
                    Endif
                    [M:ENT]IPTDAT = [M:MBR]IPTDAT(LLIG)       : # Date imputation
                    If dim([M:MBR]XLOT) & [M:MBR]XLOT(LLIG) <> "" : GSAIFLG = "000000020000000" : Endif
Endcase
[M:ENT]CUR = GLOCALDEV
[M:ENT]BPRNUM = ""
# Issue 112212 - 2015-11-10 by BEEBE : Initialize TYPBPR=1
[M:ENT]TYPBPR     = 1
End

#####################################################################################
# Chargement des paramètres en saisie de l'écran de stock en modification           #
#####################################################################################
Subprog CHARG_PARAM_STOENTM(LLIG,LTYP)
Value Integer  LLIG
Value Integer  LTYP
Case LTYP
    When 15 :
        If LLIG<>999999
          [M:ENM]STOFCY      = [M:MTK0]MFGFCY
          [M:ENM]ITMREF      = [M:MTK2]ITMREF(LLIG)
          [M:ENM]QTYTOENT    = [M:MTK2]UOMCPLQTY(LLIG)
          [M:ENM]PCUTOENT    = [M:MTK2]UOM(LLIG)
          [M:ENM]COETOENT    = [M:MTK2]UOMSTUCOE(LLIG)
          [M:ENM]STU         = [M:MTK2]STU(LLIG)
          [M:ENM]VCRNUM      = [M:MTK0]MFGTRKNUM
          [M:ENM]VCRLIN      = [M:MTK2]ITMTRKLIN(LLIG)
          [M:ENM]MVTDES      = [M:MTK2]MVTDES(LLIG)
          [M:ENM]TRSFAM      = [F:MTS]TRSFAM
          [M:ENM]ENTCOD      = [F:MTS]ENTCOD
          [M:ENM]SRGWAIFLG   = [F:MTS]SRGWAIFLG
          [M:ENM]PRNCOD1     = [F:MTS]PRNCOD1
          [M:ENM]PRNNBFLG1   = [F:MTS]PRNNBFLG1
          [M:ENM]PJT         = [M:MTK2]PJT(LLIG)
          [M:ENM]TRSTYP      = 5                    : # Type mouvement (M.704)
          [M:ENM]TRSCOD      = [M:MTK0]TRSCOD       : # Code mouvement
          [M:ENM]QUAFLG      = [M:MTK2]QUAFLG(LLIG) : # Code contrôle qualité (2=Q uniquement)
          [M:ENM]QUAFRE      = [M:MTK2]QUAFRE(LLIG) : # hcb V6CQ
          [M:ENM]UPDPRI      = 2                    : # Issue X3-31261/103947 - : Use entered price on WO modification
          If dim([M:MTK2]WRH)>0
            [M:ENM]XWRH      = [M:MTK2]WRH(LLIG)
          Endif
          If [M:MTK2]PRODTYP(LLIG) = 1
             Read [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK2]MFGLIN(LLIG)
             If fstat : Raz [F:MFI] : Endif
             If [F:MFI]LOT <> "" : GSAIFLG = "000000020000000" : Endif
          Endif
          # Issue 107513/8 - 2015-07-13 by JUSYN : Major and minor version - product
          If dim([M:MTK2]ECCVALMAJORI) > 0
              [M:ENM]ECCVALMAJORI  = [M:MTK2]ECCVALMAJORI(LLIG)   # original major version
              [M:ENM]ECCVALMINORI  = [M:MTK2]ECCVALMINORI(LLIG)   # original minor version
              [M:ENM]ECCBOMFLG     = 0
          Endif
        Else : # Cas de la suppression n'est plus utilisé à priori
          [M:ENM]STOFCY      = [F:MTK]MFGFCY
          [M:ENM]ITMREF      = [F:MKI]ITMREF
          [M:ENM]QTYTOENT    = [F:MKI]UOMCPLQTY
          [M:ENM]PCUTOENT    = [F:MKI]UOM
          [M:ENM]COETOENT    = [F:MKI]UOMSTUCOE
          [M:ENM]STU         = [F:MKI]STU
          [M:ENM]VCRNUM      = [F:MKI]MFGTRKNUM
          [M:ENM]VCRLIN      = [F:MKI]ITMTRKLIN
          [M:ENM]MVTDES      = ""
          [M:ENM]TRSFAM      = [F:MTS]TRSFAM
          [M:ENM]ENTCOD      = [F:MTS]ENTCOD
          [M:ENM]SRGWAIFLG   = [F:MTS]SRGWAIFLG
          [M:ENM]PRNCOD1     = [F:MTS]PRNCOD1
          [M:ENM]PRNNBFLG1   = [F:MTS]PRNNBFLG1
          [M:ENM]PJT         = [F:MKI]PJT
          [M:ENM]TRSTYP      = 5                    : # Type mouvement (M.704)
          [M:ENM]TRSCOD      = [F:MTK]TRSCOD        : # Code mouvement
          [M:ENM]QUAFLG      = [F:MKI]QUAFLG        : # Code contrôle qualité (2=Q uniquement)
          [M:ENM]UPDPRI      = 2                    : # Issue X3-31261/103947 - : Use entered price on WO modification
          If [F:MKI]PRODTYP  = 1
             [M:ENM]VCRNUMORI   = [F:MKI]MFGNUM      : # Numéro d'OF
             [M:ENM]VCRLINORI   = [F:MKI]MFGLIN
             [M:ENM]VCRTYPORI   = 10
             Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
             If fstat : Raz [F:MFI] : Endif
             If [F:MFI]LOT <> "" : GSAIFLG = "000000020000000" : Endif
          Endif
        Endif
    When 12 :
        If LLIG<>999999
          [M:ENM]STOFCY      = [M:MTK0]MFGFCY
          [M:ENM]ITMREF      = [M:MTK3]MATITMREF(LLIG)
          [M:ENM]QTYTOENT    = [M:MTK3]USEQTY(LLIG)
          [M:ENM]PCUTOENT    = [M:MTK3]STU(LLIG)
          [M:ENM]COETOENT    = 1
          [M:ENM]STU         = [M:MTK3]STU(LLIG)
          [M:ENM]VCRNUM      = [M:MTK0]MFGTRKNUM
          [M:ENM]VCRLIN      = [M:MTK3]MATTRKLIN(LLIG)
          [M:ENM]MVTDES      = [M:MTK3]MVTDES(LLIG)
          [M:ENM]TRSFAM      = [F:MTS]TRSFAM
          [M:ENM]ENTCOD      = [F:MTS]ENTCOD
          [M:ENM]SRGWAIFLG   = [F:MTS]SRGWAIFLG
          [M:ENM]PRNCOD1     = [F:MTS]PRNCOD1
          [M:ENM]PRNNBFLG1   = [F:MTS]PRNNBFLG1
          [M:ENM]PJT         = ""
          [M:ENM]TRSTYP      = 19                   : # Type mouvement (M.704)
          [M:ENM]TRSCOD      = [M:MTK0]TRSCODS      : # Code mouvement
          [M:ENM]QUAFLG      = 1
          If dim([M:MTK3]WRH)>0
            [M:ENM]XWRH      = [M:MTK3]WRH(LLIG)
          Endif
          If [M:MTK3]MATTYP(LLIG) = 3
              [M:ENM]VCRNUMORI = [M:MTK3]MFGNUMMA(LLIG)      : # Numéro d'OF
              [M:ENM]VCRLINORI = [M:MTK3]MFGLIN(LLIG)
              [M:ENM]VCRSEQORI = [M:MTK3]BOMSEQ(LLIG)
              [M:ENM]VCRTYPORI = 10
          Endif
          # Issue 107513/8 - 2015-08-17 by JUSYN : Major and minor version - product
          If dim([M:MTK3]ECCVALMAJORI) > 0
              [M:ENM]ECCVALMAJORI  = [M:MTK3]ECCVALMAJORI(LLIG)   # original major version
              [M:ENM]ECCVALMINORI  = [M:MTK3]ECCVALMINORI(LLIG)   # original minor version
              [M:ENM]ECCBOMFLG     = 0
          Endif
        Else : # Cas de la suppression n'est plus utilisé à priori
          [M:ENM]STOFCY      = [F:MTK]MFGFCY
          [M:ENM]ITMREF      = [F:MKM]ITMREF
          [M:ENM]QTYTOENT    = [F:MKM]USEQTY
          [M:ENM]PCUTOENT    = [F:MKM]STU
          [M:ENM]COETOENT    = 1
          [M:ENM]STU         = [F:MKM]STU
          [M:ENM]VCRNUM      = [F:MKM]MFGTRKNUM
          [M:ENM]VCRLIN      = [F:MKM]MATTRKLIN
          [M:ENM]MVTDES      = ""
          [M:ENM]TRSFAM      = [F:MTS]TRSFAM
          [M:ENM]ENTCOD      = [F:MTS]ENTCOD
          [M:ENM]SRGWAIFLG   = [F:MTS]SRGWAIFLG
          [M:ENM]PRNCOD1     = [F:MTS]PRNCOD1
          [M:ENM]PRNNBFLG1   = [F:MTS]PRNNBFLG1
          [M:ENM]TRSTYP      = 19                   : # Type mouvement (M.704)
          [M:ENM]TRSCOD      = [F:MTK]TRSCOD        : # Code mouvement
          [M:ENM]QUAFLG      = 1                    : # Code contrôle qualité (2=Q uniquement)
          If [F:MKM]MATTYP  = 3
              [M:ENM]VCRNUMORI = [F:MKM]MFGNUM
              [M:ENM]VCRLINORI = [F:MKM]MFGLIN
              [M:ENM]VCRSEQORI = [F:MKM]BOMSEQ
              [M:ENM]VCRTYPORI = 10
          Endif
        Endif

Endcase

# Issue 112212 - 2015-11-10 by BEEBE : Initialize TYPBPR=1, BPRNUM=space
[M:ENM]TYPBPR = 1
[M:ENM]BPRNUM = ""
End

#####################################################################################
$CTL_LIG_MTK
#------------------------------------------#
# Contrôle au sortir de la saisie de stock #
# ou modif de stock                        #
#------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(TRTLIG)<0    : Local Char     TRTLIG(1) : Endif
If dim(OLDQTE)<0    : Local Decimal  OLDQTE    : Endif
If dim(NEWQTE)<0    : Local Decimal  NEWQTE    : Endif
If dim(NEWMAXQTY)<0 : Local Decimal  NEWMAXQTY : Endif
If dim(SVGNOL)<0    : Local Integer  SVGNOL    : Endif
SVGNOL=nolign : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1

Case GFONC1
    When "FUNBENCHR","FUNBENPLT" :
        # 02.07 DEMANDE 39740 + 07.09 MM 56363
        If dim([M:ENT]SAIACTFLG)>0 & [M:ENT]SAIACTFLG=2
            NEWQTE = LQTYSTUACT
        Else
            NEWQTE =LQTYSTU
        Endif
    When Default :
        NEWQTE =LQTYSTU
Endcase

Case GFONC1
    When "GESMTK":
            If NEWQTE<>0 & NEWQTE<>[M:MTK2]CPLQTY(NOL)
              #-- Recherche de la nouvelle quantité maxi
              Raz NEWMAXQTY
              If [M:MTK2]MFGNUMIT(NOL)<>""
                Gosub CAL_MAXQTYMTK
              Else
               NEWMAXQTY=99999999999.999999
              Endif
              Raz mkstat
              #-- Contrôle de la quantité
              If [M:MTK2]MFGNUMIT(NOL)<>""
                Gosub CTL_QTY
                If mkstat : Goto FIN_CTL : Endif
              Endif
            Endif
    When "FUNBENCHO", "FUNBENCHI","FUNBENPLT":
            If NEWQTE<>0 & NEWQTE<>[M:MBI]CPLQTY(NOL)
              #-- Recherche de la nouvelle quantité maxi
              Raz NEWMAXQTY
              If [M:MBI]MFGNUM(NOL)<>""
                Gosub CAL_MAXQTYMTK
              Else
               NEWMAXQTY=99999999999.999999
              Endif
              Raz mkstat
              #-- Contrôle de la quantité
              If [M:MBI]MFGNUM(NOL)<>""
                Gosub CTL_QTY
                If mkstat : Goto FIN_CTL : Endif
              Endif
            Endif
    When "FUNBENCHR","FUNBENPLT" :
            # il faut contrôler que la quantité réintégrée n'est pas supérieure à la quantité sortie
            # et de plus contrôles par LOT/SLO SERIES si gestion LOT/SLO/SERIES
            If NEWQTE > [M:MBR]USEQTY(NOL)
               Call ERREUR (mess(38,190,1) - num$([M:MBR]USEQTY(NOL))) From GESECRAN
               Raz GMESSAGE
               mkstat = 2
               Goto FIN_CTL
            Endif

            If dim([M:MBR]LOTMGTCOD) & [M:MBR]LOTMGTCOD(NOL) <> 1
                Gosub CTL_QTELOT
                If mkstat : Goto FIN_CTL : Endif
            Endif
            If dim([M:ENTW]SERNUM) & [M:MBR]SERMGTCOD(NOL) <> 1  & [M:ENTW]SERNUM(NOL) = ""
                Gosub CTL_SERNUM
                If mkstat : Goto FIN_CTL : Endif
            Endif
Endcase
$FIN_CTL
nolign=SVGNOL
Return


#######################################################################################
$MAJ_LIG_MTK
#----------------------------------------------#
# Mise à jour de la ligne de décl de prod      #
# au retour du moteur de stock                 #
# LLIG contient le numéro de ligne du document #
#----------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(OLDQTE)<0    : Local Decimal  OLDQTE    : Endif
If dim(OLDWCOEFF)<0 : Local Decimal  OLDWCOEFF : Endif
If dim(OLDUOM)<0    : Local Char     OLDUOM(GLONUOM) : Endif
# 02.07 demande 39740
If dim(WRKQTE)<0    : Local Decimal  WRKQTE    : Endif
NOL=LLIGDOC
nolign=NOL+1
Case GFONC1
    When "GESMTK" :
                    #-- Sauvegarde de la quantité en US avant maj
                    OLDQTE=[M:MTK2]CPLQTY(NOL)
                    OLDUOM=[M:MTK2]UOM(NOL)
                    OLDWCOEFF=[M:MTK2]UOMSTUCOE(NOL)
                    If LQTYSTU=0 & [M:MTK2]CREFLG(NOL)<>0
                       [M:MTK2]UOMCPLQTY(NOL)=0
                       [M:MTK2]CPLQTY(NOL)=0
                       Return
                    Endif
                    If [F:ITM]ITMREF<>[M:MTK2]ITMREF(NOL)
                       Read [ITM]ITM0=[M:MTK2]ITMREF(NOL)
                       If fstat : Raz [F:ITM] : Endif
                    Endif
                    If LQTYSTU <> [M:MTK2]CPLQTY(NOL)    : # si qté modifiée
                      #-- Si l'unité est la même et coeff unique sur toute les lg
                        If LCOEF<>0
                            If LPCU=[M:MTK2]UOM(NOL)
                              [M:MTK2]UOMCPLQTY(NOL) = LQTYSTU / LCOEF
                              [M:MTK2]UOMSTUCOE(NOL)= LCOEF
                              [M:MTK2]CPLQTY(NOL)=LQTYSTU
                                # on a tout saisi en US, on reconvertit dans l'unité de déclaration
                                # si on obtient un chiffre rond ok sinon on met tout en US
                            Elsif LPCU=[M:MTK2]STU(NOL)
                              NEWQTE   =LQTYSTU/[M:MTK2]UOMSTUCOE(NOL)
                              GBIDD1=NEWQTE
                              Call QTEARR(GBIDD1,[M:MTK2]UOM(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                    [M:MTK2]UOMCPLQTY(NOL)= GBIDD1
                              Else
                                    [M:MTK2]UOM(NOL)=[F:ITM]STU
                                    [M:MTK2]UOMCPLQTY(NOL)= LQTYSTU
                                    [M:MTK2]UOMSTUCOE(NOL)=1
                              Endif
                              [M:MTK2]CPLQTY(NOL)=LQTYSTU
                              [M:MTK2]STU(NOL)   =[F:ITM]STU
                            # on a tout saisie dans une autre unité, on reconvertit dans l'unité de déclaration
                            # si on obtient un chiffre rond ok sinon on met tout en US
                            Else
                              NEWQTE   =LQTYSTU/[M:MTK2]UOMSTUCOE(NOL)
                              GBIDD1=NEWQTE
                              Call QTEARR(GBIDD1,[M:MTK2]UOM(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                 [M:MTK2]UOMCPLQTY(NOL)= GBIDD1
                              Else
                                 [M:MTK2]UOM(NOL)=[F:ITM]STU
                                 [M:MTK2]UOMCPLQTY(NOL)= LQTYSTU
                                 [M:MTK2]UOMSTUCOE(NOL)=1
                              Endif
                              [M:MTK2]CPLQTY(NOL)=LQTYSTU
                              [M:MTK2]STU(NOL)   =[F:ITM]STU
                            Endif
                        Else
                             #-- Sinon on met tout en US
                            [M:MTK2]UOM(NOL)=[F:ITM]STU
                            [M:MTK2]UOMCPLQTY(NOL)= LQTYSTU
                            [M:MTK2]UOMSTUCOE(NOL)=1
                            [M:MTK2]CPLQTY(NOL)=LQTYSTU
                        Endif
                        # CCC (28/02/08) Bug 45922 : Recalul des quantités consommées suite à modification de la quantité produite
                        Call UPDMATQTY(NOL) From SUBMTK2
                    Endif
                    If [M:MTK2]UOM(NOL)=[M:MTK2]STU(NOL)
                        Affzo [M:MTK2]UOMSTUCOE(NOL) : # pb diszo
                        Diszo [M:MTK2]UOMSTUCOE(NOL)
                        Affzo [M:MTK2]UOMSTUCOE(NOL) : # pb diszo
                       [M:MTK2]WSTOSAI(NOL)=left$([M:MTK2]WSTOSAI(NOL),2)+"2"+right$([M:MTK2]WSTOSAI(NOL),4)
                    Endif
                    #----- Màj indicateurs de solde si quantité modifiée
                    If OLDQTE <> [M:MTK2]CPLQTY(NOL)
                       If [M:MTK2]CPLQTY(NOL)  < [M:MTK2]MFIRMNQTY(NOL)
                                                 [M:MTK2]CLEFLG(NOL) = 1
                       Else                      [M:MTK2]CLEFLG(NOL) = 2
                       Endif
                     Endif

                     Affzo [M:MTK2]UOM(NOL), ITMREF(NOL), UOMCPLQTY(NOL), CPLQTY(NOL), UOMSTUCOE(NOL), CLEFLG(NOL)

    When "FUNBENCHO","FUNBENCHI","FUNBENPLT":
                     #-- Sauvegarde de la quantité en US avant maj
                    OLDQTE=[M:MBI]CPLQTY(NOL)
                    OLDUOM=[M:MBI]UOM(NOL)
                    OLDWCOEFF=[M:MBI]UOMSTUCOE(NOL)
                    If [F:ITM]ITMREF<>[M:MBI]ITMREF(NOL)
                       Read [ITM]ITM0=[M:MBI]ITMREF(NOL)
                       If fstat : Raz [F:ITM] : Endif
                    Endif
                    If LQTYSTU <> [M:MBI]CPLQTY(NOL)    : # si qté modifiée
                      #-- Si l'unité est la même et coeff unique sur toute les lg
                          If LCOEF<>0
                            If LPCU=[M:MBI]UOM(NOL)
                              [M:MBI]UOMCPLQTY(NOL) = LQTYSTU / LCOEF
                              [M:MBI]UOMSTUCOE(NOL)= LCOEF
                              [M:MBI]CPLQTY(NOL)=LQTYSTU
                                # on a tout saisi en US, on reconvertit dans l'unité de déclaration
                                # si on obtient un chiffre rond ok sinon on met tout en US
                            Elsif LPCU=[M:MBI]STU(NOL)
                              NEWQTE   =LQTYSTU/[M:MBI]UOMSTUCOE(NOL)
                              GBIDD1=NEWQTE
                              Call QTEARR(GBIDD1,[M:MBI]UOM(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                    [M:MBI]UOMCPLQTY(NOL)= GBIDD1
                              Else
                                    [M:MBI]UOM(NOL)=[F:ITM]STU
                                    [M:MBI]UOMCPLQTY(NOL)= LQTYSTU
                                    [M:MBI]UOMSTUCOE(NOL)=1
                              Endif
                              [M:MBI]CPLQTY(NOL)=LQTYSTU
                              [M:MBI]STU(NOL)   =[F:ITM]STU
                            # on a tout saisie dans une autre unité, on reconvertit dans l'unité de déclaration
                            # si on obtient un chiffre rond ok sinon on met tout en US
                            Else
                              NEWQTE   =LQTYSTU/[M:MBI]UOMSTUCOE(NOL)
                              GBIDD1=NEWQTE
                              Call QTEARR(GBIDD1,[M:MBI]UOM(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                 [M:MBI]UOMCPLQTY(NOL)= GBIDD1
                              Else
                                 [M:MBI]UOM(NOL)=[F:ITM]STU
                                 [M:MBI]UOMCPLQTY(NOL)= LQTYSTU
                                 [M:MBI]UOMSTUCOE(NOL)=1
                              Endif
                              [M:MBI]CPLQTY(NOL)=LQTYSTU
                              [M:MBI]STU(NOL)   =[F:ITM]STU
                          Endif
                     Else
                         #-- Sinon on met tout en US
                        [M:MBI]UOM(NOL)=[F:ITM]STU
                        [M:MBI]UOMCPLQTY(NOL)= LQTYSTU
                        [M:MBI]UOMSTUCOE(NOL)=1
                        [M:MBI]CPLQTY(NOL)=LQTYSTU
                     Endif
                    Endif
                    If [M:MBI]UOM(NOL)=[M:MBI]STU(NOL)
                        Affzo [M:MBI]UOMSTUCOE(NOL) : # pb diszo
                        Diszo [M:MBI]UOMSTUCOE(NOL)
                        Affzo [M:MBI]UOMSTUCOE(NOL) : # pb diszo
                       [M:MBI]WSTOSAI(NOL)=left$([M:MBI]WSTOSAI(NOL),2)+"2"+right$([M:MBI]WSTOSAI(NOL),4)
                    Endif
                    #----- Màj indicateurs de solde si quantité modifiée
                    If OLDQTE <> [M:MBI]CPLQTY(NOL) & [M:MBI]PRODTYP(NOL) = 1
                       If [M:MBI]CPLQTY(NOL)  < [M:MBI]MFIRMNQTY(NOL)
                                                 [M:MBI]CLEFLG(NOL) = 1
                       Else                      [M:MBI]CLEFLG(NOL) = 2
                       Endif
                     Endif

                     Affzo [M:MBI]UOM(NOL), ITMREF(NOL), UOMCPLQTY(NOL), CPLQTY(NOL), UOMSTUCOE(NOL), CLEFLG(NOL)
    When "FUNBENCHR","FUNBENPLT" :
                    #-- Sauvegarde de la quantité en US avant maj
                    OLDQTE=[M:MBR]REIQTY(NOL)
                    OLDUOM=[M:MBR]PCU(NOL)
                    OLDWCOEFF=[M:MBR]PCUSTUCOE(NOL)
                    If [F:ITM]ITMREF<>[M:MBR]ITMREF(NOL)
                       Read [ITM]ITM0=[M:MBR]ITMREF(NOL)
                       If fstat : Raz [F:ITM] : Endif
                    Endif
                    # 02.07 demande 39740 + 07.09 mm 56363
                    If dim([M:ENT]SAIACTFLG)>0 & [M:ENT]SAIACTFLG=2
                        WRKQTE = LQTYSTUACT
                    Else
                        WRKQTE = LQTYSTU
                    Endif
                    If WRKQTE <> [M:MBR]REIQTY(NOL)    : # si qté modifiée
                      #-- Si l'unité est la même et coeff unique sur toute les lg
                          If LCOEF<>0
                            If LPCU=[M:MBR]PCU(NOL)
                              [M:MBR]REIQTYPCU(NOL) = WRKQTE / LCOEF
                              [M:MBR]PCUSTUCOE(NOL)= LCOEF
                              [M:MBR]REIQTY(NOL)= WRKQTE
                              # on a tout saisi en US, on reconvertit dans l'unité de de conditionnement
                              # si on obtient un chiffre rond ok sinon on met tout en US
                            Elsif LPCU=[M:MBR]STU(NOL)
                              NEWQTE    = WRKQTE/[M:MBR]PCUSTUCOE(NOL)
                              GBIDD1=NEWQTE
                              Call QTEARR(GBIDD1,[M:MBR]PCU(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                    [M:MBR]REIQTYPCU(NOL)= GBIDD1
                              Else
                                    [M:MBR]PCU(NOL)=[F:ITM]STU
                                    [M:MBR]REIQTYPCU(NOL)= WRKQTE
                                    [M:MBR]PCUSTUCOE(NOL)=1

                              Endif
                              [M:MBR]REIQTY(NOL) = WRKQTE
                              [M:MBR]STU(NOL)   =[F:ITM]STU
                            # on a tout saisie dans une autre unité, on reconvertit dans l'unité de conditionnement
                            # si on obtient un chiffre rond ok sinon on met tout en US
                            Else
                              NEWQTE   = WRKQTE/[M:MBR]PCUSTUCOE(NOL)
                              GBIDD1=NEWQTE

                              Call QTEARR(GBIDD1,[M:MBR]PCU(NOL)) From TRTDIV
                              If NEWQTE=GBIDD1
                                 [M:MBR]REIQTYPCU(NOL)= GBIDD1
                              Else
                                 [M:MBR]PCU(NOL)=[F:ITM]STU
                                 [M:MBR]REIQTYPCU(NOL) = WRKQTE
                                 [M:MBR]PCUSTUCOE(NOL)=1
                              Endif
                              [M:MBR]REIQTY(NOL) = WRKQTE
                              [M:MBR]STU(NOL)   =[F:ITM]STU
                          Endif
                     Else
                         #-- Sinon on met tout en US
                        [M:MBR]PCU(NOL)=[F:ITM]STU
                        [M:MBR]REIQTYPCU(NOL) = WRKQTE
                        [M:MBR]PCUSTUCOE(NOL)=1
                        [M:MBR]REIQTY(NOL) = WRKQTE
                     Endif
                    Endif
                    If [M:MBR]PCU(NOL)=[M:MBR]STU(NOL)
                        Affzo [M:MBR]PCUSTUCOE(NOL) : # pb diszo
                        Diszo [M:MBR]PCUSTUCOE(NOL)
                        Affzo [M:MBR]PCUSTUCOE(NOL) : # pb diszo
                       [M:MBR]WSTOSAI(NOL)=left$([M:MBR]WSTOSAI(NOL),2)+"2"+right$([M:MBR]WSTOSAI(NOL),4)
                    Endif
                     Affzo [M:MBR]PCU(NOL), ITMREF(NOL), REIQTYPCU(NOL), REIQTY(NOL), PCUSTUCOE(NOL)

Endcase
Return


###########################################################################
## calcul de la quantité productible
###########################################################################
Subprog CAL_AVAMFGQTY
Local    Decimal PCTMAT
Local    Decimal WAVAMFGQTY
Local    Integer WRET
Local    Decimal LDIS
Local    Decimal WDISSHT, WALLQTY, WALLQTYSHT

Read [F:ITM]ITM0 = [F:MFM]ITMREF
If fstat : Raz [F:ITM]
#Else
#    Call LECSRU([M:MTK0]MFGFCY,[F:ITM]TCLCOD,6,[M:MTK0]TRSCODS,"",WRET) From STKLIB
Endif

If [F:MFM]USEQTY >= [F:MFM]RETQTY
    WAVAMFGQTY  = [F:MFG]EXTQTY - [F:MFG]CPLQTY
Else
   # Issue 120426 GH 26/12/2016 - calculation of available stock considers stock status authorized
   #                              and the version (if exclusive) for the stock rule for WO issue
   #Call LECITV2([M:MTK0]MFGFCY,[F:ITM]ITMREF,WRET) From MFGLIB
   #Call STODISTOT("",0,7,"",LDIS) From STKLIB
   Local Char WECCVALMAJ(GLONECS)
   If [F:MFM]ECCVALMAJ<>''
      Call LECSRU([M:MTK0]MFGFCY,[F:ITM]TCLCOD,6,[M:MTK0]TRSCODS,"",WRET) From STKLIB
      If !WRET & [F:SRU]ORDVER=2
         WECCVALMAJ=[F:MFM]ECCVALMAJ
      Endif
   Endif
   Call STODISALL([M:MTK0]MFGFCY,[F:MFM]ITMREF,10,2,2,1,2,"","",WECCVALMAJ,LDIS,WRET) From STKALL
   #
   If find([F:MFM]ALLSTA,4,5)
        Call CTLALL([F:MFM]MFGFCY,10,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,6,[M:MTK0]TRSCODS,
&       "",1,WALLQTY,WALLQTYSHT,WRET) From STKALL
        LDIS    += WALLQTY
   Elsif  find([F:MFM]ALLSTA,2,3)
       # Issue 90717 GA 06/2013 avant WDIS ???
        LDIS += [F:MFM]ALLQTY
   Endif
   If LDIS <= 0 : End : Endif
   If LDIS > [F:MFM]RETQTY - [F:MFM]USEQTY
         WAVAMFGQTY  = [F:MFG]EXTQTY - [F:MFG]CPLQTY
   Else
      WDISSHT  = ([F:MFM]RETQTY - [F:MFM]USEQTY) - LDIS
       PCTMAT      = WALLQTYSHT / [F:MFM]RETQTY
       WAVAMFGQTY  = [F:MFG]EXTQTY - ([F:MFG]EXTQTY * PCTMAT)
       WAVAMFGQTY -= [F:MFG]CPLQTY
       WAVAMFGQTY  = arr(WAVAMFGQTY,0)
   Endif
Endif
If (WAVAMFGQTY < GAVAMFG) | (GAVAMFG = 9999999999)
    [M:MTI2]AVAMFGQTY  = WAVAMFGQTY
    GAVAMFG            = WAVAMFGQTY
Endif

#
End

########################################
#Ajustement des différentes qtés à suivre suivant la qté productible
$REAJUST_TOUT
Local Decimal WCOEFF,WQTE , WQTYDIM
Local Integer J, WRET, WNO_REAJUST

#[M:MTI2]AVAMFGQTY EST TOUJOURS EN UNITé DE STOCK
#QTESUIVOPE etc ... Sont en US si multi article ou UL sinon
#Attention donc à la conversion
WCOEFF = [M:MTI2]AVAMFGQTY/[F:MFG]RMNEXTQTY
# CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
# Ce sont les quantités qui sont arrondies
## 01.02 demande 12597
#WCOEFF = arr(WCOEFF,0.00000001)
#
If [F:MFG]ITMLINNBR = 1
   Filter [F:MFI] Where MFGNUM = [M:MTK0]MFGNUM
   Read [F:MFI]MFI0 First : If fstat Raz [F:MFI]  : Endif
   If [F:MFI]UOMSTUCOE = 0 : [F:MFI]UOMSTUCOE = 1 : Endif
   Filter [F:MFI]  # FQ 77545 GA 11/2011 ajout de la Raz
Endif
If [F:MTS]OPETRKFLG = 2
   If [F:MFG]ITMLINNBR = 1
       [M:MTK1]QTESUIVOPE = [M:MTI2]AVAMFGQTY / [F:MFI]UOMSTUCOE
   Else
       [M:MTK1]QTESUIVOPE = [M:MTI2]AVAMFGQTY
   Endif
#Si le tableau des opé est déjà chargé, ajustement des qtés realisées des opé
   If [M:MTK1]NBOPE <> 0
      For J = 0 To [M:MTK1]NBOPE-1
          [M:MTK1]CPLQTY(J) = [M:MTK1]EXTQTY(J)* WCOEFF
          Call QTEARR([M:MTK1]EXTQTY(J),[M:MTK1]OPEUOM(J)) From TRTDIV
      Next J
    Endif
    Affzo [M:MTK1]
Endif
If [F:MTS]ITMTRKFLG = 2
    If [F:MFG]ITMLINNBR = 1
       [M:MTK2]QTESUIVITM = [M:MTI2]AVAMFGQTY / [F:MFI]UOMSTUCOE
    Else
       [M:MTK2]QTESUIVITM = [M:MTI2]AVAMFGQTY
    Endif
#Si le tableau des articles lancés est déjà chargé, ajustement des qtés realisées des art
   If [M:MTK2]NBITM <> 0
      For J = 0 To [M:MTK2]NBITM-1
          [M:MTK2]CPLQTY(J)  = [M:MTK2]EXTQTY(J)* WCOEFF
          Call QTEARR([M:MTK2]CPLQTY(J),[M:MTK2]STU(J)) From TRTDIV
          [M:MTK2]UOMCPLQTY(J) = [M:MTK2]CPLQTY(J)/[M:MTK2]UOMSTUCOE
          Call QTEARR([M:MTK2]UOMCPLQTY(J),[M:MTK2]UOM(J)) From TRTDIV
          Call DELSTOENTW(J,J,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
          Call STJSTOENTW("MTK2",5,15,[M:MTK0]MFGTRKDAT,J,[M:MTK2]NBITM,"MTS",3,WRET) From STKENT
      Next J
    Endif
    Affzo [M:MTK2]
Endif
If [F:MTS]MATTRKFLG = 2
   If [F:MFG]ITMLINNBR = 1
       [M:MTK3]QTESUIVMAT = [M:MTI2]AVAMFGQTY / [F:MFI]UOMSTUCOE
   Else
       [M:MTK3]QTESUIVMAT = [M:MTI2]AVAMFGQTY
   Endif
#Si le tableau des matières est déjà chargé, ajustement des qtés realisées des mat
#SSI le mode de consommation matière n'est pas immédiat
#De plus on tient compte de la valeur "selon qté prevue"

   If [F:MTS]CONSMAT > 1 & [M:MTK3]NBMAT <> 0
          Raz WNO_REAJUST
          For J = 0 To [M:MTK3]NBMAT-1
              WQTE = [M:MTK3]RETQTY(J)* WCOEFF
              If [F:MTS]CONSMAT = 3 | WQTE <= [M:MTK3]MFMEXTQTY(J)
                  WQTYDIM=[M:MTK3]USEQTY(J)-WQTE
                  If WQTYDIM > 0
                      [M:MTK3]USEQTY(J) = WQTE
                      Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                     # Diminution de la qté stockée dans STOSORW
                      Call QTEARR(WQTYDIM,[M:MTK3]STU(J)) From TRTDIV
                      If WQTYDIM > 0
                          Call DIM_STOSORW(J,"MTK3",[M:MTK0]MFGFCY,WQTYDIM,WRET) From STKSOR
                      Endif
                  Else
                      WNO_REAJUST = 1
                  Endif
              Endif
          Next J
   Endif
   Affzo [M:MTK3]
   If WNO_REAJUST = 1 : Call MESSAGE(mess(205,190,1)) From GESECRAN : Endif
Endif
Return

###############################################################################
#---------------------------------------------------#
#Appelé en création de réception d'un article de    #
# sous-traitance                                    #
#---------------------------------------------------#
Subprog MAJ_MTK(LSTOSEQ,LRET)
Value Integer LSTOSEQ
Variable Integer LRET

Local Integer WDACMST,WOPENUM,WOPESPLNUM,WOPECLENBR, WITMCLENBR, WMATCLENBR,WMFGMST
Local Integer WNBOPE,WNBITM,WNBMAT,WLIN,WFICFLG,STAT :# 170100
Local Char    WMFGNUM(GLONVCR),WMTKNUM(GLONVCR),WOPEUOM(GLONUOM)
Local Decimal WCOEFF,WCOEFFPROD,WWQTY,WALLQTY,WSHTQTY,WWALLQTY,WWSHTQTY
Local Decimal WCOEFFITM # Issue 101197 - 2014-12-12 by CCC
Local Decimal WCPLQTY,WREJQTY,WQUAQTY,WWCPLQTY,WWQUAQTY,WWREJQTY,WOPECPLQTY,WOPEREJQTY, WALLREJQTY
Local Decimal WOPEWORCOE,WMFICPLQTY,WMFIREJQTY     # FQ 69705 GA 12/2010 ajout WMFICPLQTY,WMFIREJQTY
Local Decimal WMFGCPLQTY,WMFGREJQTY                # Issue 87908 GA 04/2013
Local Integer WRETOUR
Local Char    WNUMTEX(12)
Local Decimal WOPETOTQTY
Local Char    WMSGSUI(250) # 08.02 demande 14023
Local Integer WRET
Local Decimal WPRIX, WQTYSTU, WPRISTU, WCPR, WQTYUO, WPRIUO
Local Decimal WCPLHOU
Local Char    WCCE(15)
Local Integer WCLEFLG :# 191000 Solder l'opération selon flag solde de la ligne commande
Local Char    MKMPARAM(10)
Local Integer WCUNFLG, WRET
# llc 09.02 15971
Local Decimal WUNTTIM
Local Integer LRET
Local Decimal LQTA, LSHT, PRI
Local Integer LNBR, LNBJ
Local Char    WLOT(GLONLOT)
Local Integer WOK # 57910 mm 12.09
Global Shortint GMFGTRACE         : # affichage d'une trace en gestion
Local Integer WOPENUMCLE # Issue 81433 GA 06/2012

Global Integer GTITRE , GMTKALLMGT
#Récupération de la valeur du code activité titre
Call LECACT("TIT",GTITRE) From TRTX3
#

Gosub OPEN_FILE
Local File MFGOPE [YFO]
If [F:MTS]MTSTYP <> 2 | [F:MTS]MTSNUM <> GMTKMTSNUM
   Read [F:MTS]MTS0 = 2;GMTKMTSNUM
   If fstat : Raz [F:MTS] : Endif
Endif
Raz WMTKNUM
If [F:MTS]OPETRKFLG = 2 |[F:MTS]ITMTRKFLG = 2 | [F:MTS]MATTRKFLG = 2
#----- Récupération compteur suivi
   If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
   Local Integer WOK
   Call LECTCA(8,WOK) From SUBTCA
   If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : GOK=0 : LRET = 1 : End : Endif
   Call NUMERO([F:TCA]CODNUM(2),[F:PTH]PRHFCY,[F:PTH]RCPDAT,"",WMTKNUM,STAT) From SUBANM
   If STAT <> 0: Call ERREUR(mess(60,199,1)-[F:TCA]CODNUM(2)-num$([L]STAT)) From GESECRAN: GOK = 0 : LRET = 1 : End : Endif
Else  End
Endif
Read [F:OPS]OPS2= [F:PTD]POHNUM;[F:PTD]POPLIN;1
If fstat
   Raz [F:OPS]
   # FQ 68123 & 68299 GA 10/2010 pb si on ne retrouve pas la ligne [F:OPS]
   Read [F:MFO]MFO1=[F:PTD]POHNUM;[F:PTD]POPLIN;1
   If !fstat
     WMFGNUM    = [F:MFO]MFGNUM
     WOPENUM    = [F:MFO]OPENUM
     WOPESPLNUM = [F:MFO]OPESPLNUM
     [F:OPS] = [F:MFO]
   Elsif [F:PTD]VCRTYPORI=10
   # FQ 74662 GA 08/2011 si opération d'OF non rattachée à la commande
     WMFGNUM    = [F:PTD]VCRNUMORI
     WOPENUM    = [F:PTD]VCRLINORI
     WOPESPLNUM = [F:PTD]VCRSEQORI
     Read [F:MFO]MFO0=WMFGNUM;WOPENUM;WOPESPLNUM
     If !fstat
        [F:OPS] = [F:MFO]
       # Issue 93977 GA 11/2013
        WOPENUM    = [F:MFO]OPENUM
        WOPESPLNUM = [F:MFO]OPESPLNUM
     Endif
   Endif
Else
   WMFGNUM    = [F:OPS]MFGNUM
   WOPENUM    = [F:OPS]OPENUM
   WOPESPLNUM = [F:OPS]OPESPLNUM
Endif

# Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
## Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
#WOPENUMCLE = 100*WOPENUM+WOPESPLNUM
## Issue 89134 GA 04/2013 il faut avoir PTDLIN dans la clé [F:PWS]
#WOPENUMCLE = 10*[F:PTD]PTDLIN + WOPENUMCLE
Local Integer WVCRSEQ : WVCRSEQ=100*WOPENUM+WOPESPLNUM
Gosub CAL_WOPENUMCLE From SUBPTHC

# Issue 95496 - 2014-03-17 by CCC : WOF
#Local Integer WVCRSEQ : WVCRSEQ=100*WOPENUM+WOPESPLNUM
#Gosub CAL_WOPENUMCLE From SUBPTHC

# boucle de recherche quantité prévue totale
WOPETOTQTY = 0
For [MFO]MFO0 Where MFGNUM=[F:OPS]MFGNUM & OPENUM=[F:OPS]OPENUM
    WOPETOTQTY += [F:MFO]EXTQTY
Next
# récupération de l'indicateur solde de la ligne commande    # 09.04 25259
WCLEFLG = [M:PTH1]WSOLDE(nolign-1)
#
If [F:MFO]MFGNUM<>WMFGNUM | [F:MFO]OPENUM<>WOPENUM | [F:MFO]OPESPLNUM<>WOPESPLNUM
 # Issue 84466 GA 10/2012
 # Read [F:MFO]MFO0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
  Read [F:MFO]MFO0=WMFGNUM;WOPENUM;WOPESPLNUM
  If fstat : Raz [F:MFO] : Endif
Endif
If [F:MFG]MFGNUM<>WMFGNUM
  Read [F:MFG]MFG0 = WMFGNUM   # Issue 84466 GA 10/2012 before [F:MFO]MFGNUM
  If fstat : Raz [F:MFG] : Endif
Endif
Raz WOPECPLQTY, WOPEREJQTY, WOPEWORCOE, WOPEUOM
Raz WMFICPLQTY, WMFIREJQTY     # FQ 69705 GA 12/2010 ajout WMFICPLQTY,WMFIREJQTY
Raz WMFGCPLQTY, WMFGREJQTY     # Issue 87908 GA 02/2013

# llc 04.02, si UA = UO, pas de conversion
If [F:MFO]OPEUOM = [F:PTD]PUU
    WOPECPLQTY = [F:PTD]QTYPUU
    WOPEREJQTY = [F:PTD]RRRQTYPUU
Elsif [F:MFO]OPEUOM = [F:PTD]STU
    WOPECPLQTY = [F:PTD]QTYSTU
    WOPEREJQTY = [F:PTD]RRRQTYSTU
Else
    Call CALCUL_QTY([F:PTD]QTYSTU,[F:PTD]STU,WOPECPLQTY,[F:MFO]OPEUOM,GBIDD1) From TRTX3
    Call CALCUL_QTY([F:PTD]RRRQTYSTU,[F:PTD]STU,WOPEREJQTY,[F:MFO]OPEUOM,GBIDD1) From TRTX3
Endif
# FQ 69705 GA 12/2010 pb si on traite plusieurs opé en même temps (si opé borne)
###WOPEWORCOE = 1
###Case [F:MTS]OPEUOMMOD
###     When 1 :
###        WOPEWORCOE = 1
###        WOPEUOM    = [F:MFO]OPEUOM
###     When 2 :
###        Case [F:MTS]OPEUOMTYP
###            When 1 :
###                 WOPEWORCOE = 1
###                 WOPEUOM    = [F:MFO]OPEUOM
###            When 2 :
###                 WOPEWORCOE = [F:MFO]OPESTUCOE
###                 WOPEUOM    = [F:MFG]STU
###                 WOPECPLQTY /= WOPEWORCOE
###                 WOPEREJQTY /= WOPEWORCOE
###        Endcase
###Endcase
# FQ 69705 GA 12/2010 revenir à la qté Article lancé si le service est commandé avec une autre unité
If [F:PTD]STU<>[F:MFG]STU & [F:MFO]OPESTUCOE<>0
    WMFGCPLQTY = [F:PTD]QTYSTU / [F:MFO]OPESTUCOE
    WMFGREJQTY = [F:PTD]RRRQTYSTU / [F:MFO]OPESTUCOE
    Call QTEARR(WMFGCPLQTY,[F:MFG]STU) From TRTDIV
    Call QTEARR(WMFGREJQTY,[F:MFG]STU) From TRTDIV
Else
    WMFGCPLQTY = [F:PTD]QTYSTU
    WMFGREJQTY = [F:PTD]RRRQTYSTU
Endif

#Récupération du flag édité
Local Integer WPRN
WPRN = 1
Local File MFGPRN [MFP]
Read [F:MFP]MFP0 = [F:MFG]MFGNUM
If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
Close Local File [F:MFP]

# FQ 64125 GA 05/2010
Gosub CTL_TECCRD

#
# Allocation à l'OF obligatoire
Call PARAM([F:MFG]MFGFCY,"MTKALLMGT",MKMPARAM) From ADOVAL
GMTKALLMGT = val(MKMPARAM)
# allocation globale OF si nécessaire
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
    Call ALLOC_OF("C", 0, [F:MFG]MFGNUM, 1, 1, WRET) From MFGALL
    If WRET <> 0 : GOK = 0 : End : Endif
Endif

#----------------------------- Si suivi opération -----------------------------------#
If [F:MTS]OPETRKFLG = 2                                       # Suivi opération
#Récup de DACMST. Même si = 1 (Suivi = NON) on suit quand même les opé de sst
  Read [F:ROS]ROS0 = [F:MFG]MFGFCY;[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFO]OPENUM
  If fstat : Raz [F:ROS] : Endif
  Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
  If fstat : Raz [F:SCH] : Endif
  WDACMST = [F:SCH]DACMST
  WMFGMST = [F:SCH]MFGMST
#Si opération borne il faut suivre les opé à suivre en même temps
  If [F:SCH]DACMST = 3
    Local Shortint WOPE
    Local Integer WBREAK
#Recherche de la précédente opération à suivre (normale ou borne)
    Raz WBREAK,WOPE
    Filter [F:YFO] Where MFGNUM = [F:MFO]MFGNUM & OPENUM < [F:MFO]OPENUM Order By Key MFO0 Desc
    For [F:YFO]
        Read [F:SCH]SCH0 = [F:YFO]MFGNUM;[F:YFO]OPENUM;[F:YFO]OPESPLNUM
        If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
    Next
    If WBREAK = 1 : WOPE = [F:YFO]OPENUM : Endif
    Filter [F:YFO]
#Traitement des opé entre les deux bornes(borne supérieure comprise) sauf opé soldées
    Filter [F:YFO] Where MFGNUM = [F:MFO]MFGNUM & OPENUM > WOPE & OPENUM <= [F:MFO]OPENUM &
&                        MFOTRKFLG < 5
  Else
    Filter [F:YFO] Where MFGNUM = [F:MFO]MFGNUM & OPENUM = [F:MFO]OPENUM &
&                        OPESPLNUM = [F:MFO]OPESPLNUM & MFOTRKFLG < 5
  Endif
  WLIN = 0
  For [YFO]
        If [F:YFO]OPENUM = WOPENUM & [F:YFO]OPESPLNUM <> WOPESPLNUM : Goto NEXTYFO : Endif
#On ne prend pas les opérations exclues ou  commandées ou  sous-traitées
        If [F:YFO]OPENUM = WOPENUM & [F:YFO]OPESPLNUM = WOPESPLNUM
            Goto TRT_OPE
        Endif
        If [F:YFO]OPESTA > 5 : Goto NEXTYFO : Endif
        Read [F:MWS]WST0 = [F:YFO]EXTWST;[F:YFO]MFGFCY
        If fstat | [F:MWS]WSTTYP = 3 : Goto NEXTYFO : Endif
$TRT_OPE
        WLIN += 1

        # FQ 69705 GA 12/2010 pb d'unité si on traite plusieurs opé en même temps (si opé borne)
        WOPEWORCOE = 1
        Case [F:MTS]OPEUOMMOD
         When 1 :
            WOPEWORCOE = 1
            WOPEUOM    = [F:YFO]OPEUOM
         When 2 :
            Case [F:MTS]OPEUOMTYP
                When 1 :
                     WOPEWORCOE = 1
                     WOPEUOM    = [F:YFO]OPEUOM
                When 2 :
                     WOPEWORCOE = [F:YFO]OPESTUCOE
                     WOPEUOM    = [F:MFG]STU
            Endcase
        Endcase
        If WOPEWORCOE=0 WOPEWORCOE=1 Endif
        # Fin - FQ 69705 GA 12/2010 pb d'unité si on traite plusieurs opé en même temps (si opé borne)

        # V 150 lire l'encours de charge pour récupérer l'affaire
        Read [F:OPS]OPS1=[F:YFO]MFGNUM;[F:YFO]OPENUM;[F:YFO]OPESPLNUM
        If fstat : Raz [F:OPS] : Endif
#Création enregistrement suivi opé
        Raz [F:MKO]
        [F:MKO]          = [F:YFO]

        [F:MKO]ITMREF = [F:MFG]ROUNUM
        [F:MKO]ROUALT = [F:MFG]ROUALT
        [F:MKO]TIMTYP    = 1
        [F:MKO]PJT       = [F:OPS]PJT
        [F:MKO]OPEWORCOE = WOPEWORCOE
        [F:MKO]OPEUOM    = WOPEUOM
        Raz [F:MKO]INVQTY : # GH 29/03/2016 bug 114705 to not alterate cost calculation for subcontracting

        Raz [F:MKO]CPLPRI #X3-94884. MJH 06/26/2018. If this is populated it will override the cost in the receipt in WIPCOST.

         # Issue 97320 GA 07/2014 case [F:MTS]OPEUOMTYP=2
        If [F:MKO]OPEUOM=[F:MFG]STU & [F:MTS]OPEUOMTYP=2
            [F:MKO]CPLQTY    = WMFGCPLQTY
            [F:MKO]REJCPLQTY = WMFGREJQTY
        Elsif [F:YFO]OPENUM = WOPENUM & [F:YFO]OPESPLNUM = WOPESPLNUM
            [F:MKO]CPLQTY    = WOPECPLQTY
            [F:MKO]REJCPLQTY = WOPEREJQTY
        Elsif [F:YFO]OPEUOM=[F:MFG]STU # FQ 69705 GA 12/2010 opé non borne, en US article lancé
            [F:MKO]CPLQTY    = (WMFGCPLQTY/WOPEWORCOE) * [F:YFO]OPESTUCOE
            [F:MKO]REJCPLQTY = (WMFGREJQTY/WOPEWORCOE) * [F:YFO]OPESTUCOE
        Else
            [F:MKO]CPLQTY    = (WOPECPLQTY/WOPEWORCOE) * [F:YFO]OPESTUCOE
            [F:MKO]REJCPLQTY = (WOPEREJQTY/WOPEWORCOE) * [F:YFO]OPESTUCOE
        Endif
        Call QTEARR([F:MKO]CPLQTY,WOPEUOM) From TRTDIV
        Call QTEARR([F:MKO]REJCPLQTY,WOPEUOM) From TRTDIV

        [F:MKO]OPETRKLIN = WLIN
        [F:MKO]CPLLAB    = [F:YFO]EXTLAB
        [F:MKO]CPLWST    = [F:YFO]EXTWST

         # llc 09.02 15971
         If [F:YFO]EXTQTY > 0
            # WUNTTIM = [F:YFO]EXTOPETIM / [F:YFO]EXTQTY # Issue 88358 GH 18/05/2018
            WUNTTIM = [F:YFO]EXTOPETIM * [F:MKO]OPEWORCOE / [F:YFO]EXTQTY
         Endif
        If [F:YFO]ROOTIMCOD <> 3
            [F:MKO]CPLOPETIM = WUNTTIM * [F:MKO]CPLQTY                        # llc 09.02 15971
        Else
            [F:MKO]CPLOPETIM = [F:YFO]EXTOPETIM - [F:YFO]CPLOPETIM
        Endif
        If [F:MKO]CPLOPETIM < 0 : [F:MKO]CPLOPETIM = 0 : Endif
        [F:MKO]CPLSETTIM = [F:YFO]EXTSETTIM - [F:YFO]CPLSETTIM
        If [F:MKO]CPLSETTIM < 0 : [F:MKO]CPLSETTIM = 0 : Endif
        # 11.06 demande 38402
        [F:MKO]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[F:MKO]CPLOPETIM)
        [F:MKO]CPLSETTIM = func TRTX3.ARRTYP("","","TIH",[F:MKO]CPLSETTIM)
        If [F:YFO]OPENUM = WOPENUM : [F:MKO]DACMST   = WDACMST
                                     [F:MKO]POHNUM   = [F:PTD]POHNUM
                                     [F:MKO]POPLIN   = [F:PTD]POPLIN
                                     [F:MKO]POPSEQ   = 1
                                     [F:MKO]PTHNUM   = [F:PTD]PTHNUM
                                     [F:MKO]PTDLIN   = [F:PTD]PTDLIN
                                     [F:MKO]BPSNUM   = [F:PTH]BPSNUM
                                     # Issue X3-25003 - 2018-02-26 by SR : If new stock valuation method enabled, don't touch CPLPRI and INVQTY which will be updated later
                                     If clalev([F:POH]) > 0
                                        If [F:POH]POHNUM <> [F:PTD]POHNUM
                                          Read [F:POH]POH0 = [F:PTD]POHNUM
                                          If fstat : Raz [F:POH] : Endif
                                        Endif
                                     Endif
                                     # Only if New method not enabled
                                     If clalev([F:POH])< 1 | [F:POH]POHNUM <> [F:PTD]POHNUM | GPRIFLG <> 2 | GPSVSTRDAT > [F:POH]CREDAT
                                        Gosub MAJ_PRIX_SUIVI
                                     Endif
                                     # End issue X3-25003
        Else                         [F:MKO]DACMST   = 1
                                     [F:MKO]OPEBORNE = WOPENUM
        Endif
        [F:MKO]IPTDAT    = [F:PTH]RCPDAT
        [F:MKO]DACDAT    = date$
        [F:MKO]DACHOU    = left$(time$,2)+mid$(time$,4,2)
        [F:MKO]CREDAT    = date$
        [F:MKO]CREUSR    = GUSER
        [F:MKO]EXPNUM    = [C]EXPORT
        Raz [F:MKO]UPDUSR
        Raz [F:MKO]UPDDAT
#-- duplication du texte lie a l'opé de l'OF
         If [F:YFO]MFOTEX <>""
             [F:MKO]MKOTEX  = [F:YFO]MFOTEX
             If left$([F:MKO]MKOTEX,3)="MFO"
                Call DUP_CLOB("MKO",[F:MKO]MKOTEX,GOK) From TRTX3TEX
             Endif
         Endif
         [F:MKO]MFGTRKNUM = WMTKNUM
         #point d'entrée  pour mise à jour spécifiques liées à [MKO] GA 05/2008 e-Signature
         GPOINT = "BEFWRIMKO" : Gosub ENTREE From EXEFNC
         Write [F:MKO]
         If fstat
             GOK = 0 : Call FSTA("MKO") From GLOCK
             LRET = 1 : Break
         Endif
        # Issue 71432 - 2011-02-08 by CCC : la classe [MFO] peut est nécessaire à l'initialisation des sections
         Readlock [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
         If fstat=1  GOK=-1 : GLOCK="$MFGOPE"-num$([F:MKO]OPENUM) : Break
         Elsif fstat GOK=0  : Call RSTA("MFO",num$([F:MKO]OPENUM)) From GLOCK : Break
         Endif
         Gosub MAJMKO_CPTANALIN
#----- MISE à jour statistiques ligne suivi opé -----#
         Call VALSTA("MKO",1) From SUBPS2
         If GOK < 1 : Break : Endif

        # FQ 64125 GA 05/2010
         Gosub UPD_TECCRD

#Maj Opération
        # [F:MFO] a pu être modifiée par VALSTA
         If [F:MFO]MFGNUM    <> [F:MKO]MFGNUM
&         | [F:MFO]OPENUM    <> [F:MKO]OPENUM
&         | [F:MFO]OPESPLNUM <> [F:MKO]OPESPLNUM
             Readlock [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
             If fstat=1  GOK=-1 : GLOCK="$MFGOPE"-num$([F:MKO]OPENUM) : Break
             Elsif fstat GOK=0  : Call RSTA("MFO",num$([F:MKO]OPENUM)) From GLOCK : Break
             Endif
         Endif
         If [F:MFO]OPENUM = WOPENUM & [F:MFO]OPESPLNUM = WOPESPLNUM
            Gosub MAJ_PRIX_OPE
         Endif
# llc 03.01 multi-exemplaire
#         If [F:MFO]CPLWST <> [F:MKO]CPLWST :  [F:MFO]CPLWSTNBR += 1 : Endif
         [F:MFO]CPLWSTNBR = [F:MFO]EXTWSTNBR
         If [F:MFO]CPLWST = "" : [F:MFO]CPLWST = [F:MKO]CPLWST : Endif
         If [F:MFO]CPLLAB = "" : [F:MFO]CPLLAB = [F:MKO]CPLLAB : Endif
         [F:MFO]CPLQTY    += [F:MKO]CPLQTY    * [F:MKO]OPEWORCOE
         [F:MFO]REJCPLQTY += [F:MKO]REJCPLQTY * [F:MKO]OPEWORCOE
         [F:MFO]CPLSETTIM += [F:MKO]CPLSETTIM
         [F:MFO]CPLOPETIM += [F:MKO]CPLOPETIM
         # llc 09.02 15971
         If [F:MFO]EXTQTY > 0
             WUNTTIM = [F:MFO]EXTOPETIM / [F:MFO]EXTQTY
         Endif
         If [F:MFO]CPLUNTTIM = 0 : [F:MFO]CPLUNTTIM = WUNTTIM                # llc 09.02 15971
         Else [F:MFO]CPLUNTTIM = avg(WUNTTIM,[F:MFO]CPLUNTTIM)               # llc 09.02 15971
         Endif
         # CCC (10/01/08) DM 44021
         #If [F:MFO]TRKFIRST = "00/00/00" : [F:MFO]TRKFIRST = [F:PTH]RCPDAT : Endif
         If [F:MFO]TRKLAST<[F:PTH]RCPDAT
            [F:MFO]TRKLAST   = [F:PTH]RCPDAT
         Endif
         If [F:MFO]TRKLASTC<date$
            [F:MFO]TRKLASTC  = date$
         Endif
         If [F:MFO]TRKFIRST>[F:PTH]RCPDAT | [F:MFO]TRKFIRST = "00/00/00"
             [F:MFO]TRKFIRST = [F:PTH]RCPDAT
         Endif
         If [F:MFO]TRKFIRSTC>date$ | [F:MFO]TRKFIRSTC = "00/00/00"
             [F:MFO]TRKFIRSTC = date$
         Endif
        # 191000 Solde de la ligne si tout est réalisé ou si la ligne de commande est soldée
         Call CONT_SOLDE_OPE([F:MFO]MFGFCY,[F:MKO]CPLWST,[F:MFO]CPLQTY,[F:MFO]EXTQTY,WRET) From MFGLIBO
         If WRET = 1 | ([F:MFO]EXTQTY <= [F:MFO]CPLQTY)    # 09.04 25259
            [F:MFO]OPESTA = 5
            [F:MFO]MFOTRKFLG = 5
        # 04.01 demande 8947
        #Si on n'est pas sur l'opé de sous-traitance on incrémente le compteur des
        #lignes soldées sinon on fera un CTR_SOLDE plus tard
            If [F:MFO]OPENUM <> WOPENUM | [F:MFO]OPESPLNUM <> WOPESPLNUM
                WOPECLENBR+=1
            Endif
         Else
            [F:MFO]OPESTA = 4
            [F:MFO]MFOTRKFLG = 4
         Endif
         # CCC (10/01/08) DM 44021
#         If [F:MFO]OPESTA = 5
#            [F:MFO]TRKLAST = [F:PTH]RCPDAT
#         Endif
         Gosub  MAJ_SUIVANTE From SUBMTKC
         If GOK < 1 : Break : Endif         # FQ 69909 Ctrl des sources avant End
         Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
         Read [F:MFI]MFI0 First
         If !fstat
             Call UPDATE_OWX("PM",[F:MFI]PJT) From MFGLIBO
         Endif
         Filter [MFI]
         #point d'entrée  pour mise à jour spécifiques liées à [MFO] Issue 83469 GA 08/2012
         GPOINT = "BEFREWMFO" : Gosub ENTREE From EXEFNC
         Rewrite [F:MFO]
         If fstat
            GOK = 0 : Call FSTA("MFO") From GLOCK : Break
         Endif
         If [F:MFO]MFOTRKFLG = 5
             Local Integer WPREC : WPREC = [F:MFO]OPENUM
             Gosub CTR_SOLDE From FUNMFGS
         Endif
#----- MISE à jour statistiques ligne opé -----#
         Call VALSTA("MFO",1) From SUBPS2
         If GOK < 1 : Break : Endif
#Maj du fichier WORKSTATIO
         Readlock [F:MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
         If !fstat
             WCPLHOU = [F:MKO]CPLOPETIM
             If [F:MKO]TIMUOMCOD = 2 : WCPLHOU = WCPLHOU / 60 : Endif
             [F:MWS]CPLHOUTIM += func TRTX3.ARRTYP("","","TIH",WCPLHOU)
             Rewrite [F:MWS]
             If fstat
                 GOK = 0 : Call FSTA("MWS") From GLOCK : Break
             Endif
         Endif
#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
         If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
         GWIPCOST = "SCEOPETRK_NEW"     # au lieu de OPETRK_NEW 21/08/03 (TB)
         WRET = 0
         GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
         If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------
         If [F:MWS]WSTTYP=3
             Call SCEOPETRK_NEW(10,WRET) From MWIPLIB   # (TB) Intégration WIP # V6 GA 05/2008 ajout VCRTYP=10
         Else
             Call OPETRK_NEW(WRET) From MWIPLIB  # CCC (2009-11-02) Bug 59458 : Création des wipcost des 2 postes (CPLWST et CPLLAB)
         Endif
         If WRET > 0 : GOK = 0 : Break : Endif

         WNBOPE += 1
  $NEXTYFO
  Next
  Filter  [F:YFO]
  If GOK < 1 : LRET = 1 : Endif  # End après les Close
Endif
#Close Local File [F:ROS] # FQ 76070
#Close Local File [F:MWS] # FQ 76070
Close Local File [F:YFO]
If GOK < 1 : End : Endif
#-------------------------------- si déclaration de production ----------------------------#
If [F:MTS]ITMTRKFLG = 2  & WMFGMST = 2                                      # Déclaration de prod.
   Local        Integer WLINITM
   Raz WLINITM

 # FQ 69508 GA 04/2011 autoriser et traiter le cas des sous-produits
   #For [F:MFI] Where MFGNUM = [F:MFG]MFGNUM &  ITMTYP <> 2
   For [F:MFI] Where MFGNUM = [F:MFG]MFGNUM

       # Issue 87908 GA 04/2013 idem TRTACHSCO1/SUBPTHC
       Local Decimal COEFF_MFI
       If [F:MFG]EXTQTY = [F:MFI]EXTQTY | [F:MFG]EXTQTY = 0
       # OF mono-article la qté totale = qté article lancé
         COEFF_MFI = 1
         WMFICPLQTY = [F:PTD]QTYSTU
         WMFIREJQTY = [F:PTD]RRRQTYSTU
       Else
         COEFF_MFI  = [F:MFI]EXTQTY / [F:MFG]EXTQTY
         WMFICPLQTY = [F:PTD]QTYSTU     * COEFF_MFI
         WMFIREJQTY = [F:PTD]RRRQTYSTU  * COEFF_MFI
       Endif

       # FQ 67334 & 68123 GA 10/2010 [F:PWS]VCRLIN,VCRSEQ correspondent à [M:PSTT]OPENUM,OPESPLNUM
       #Read [F:PWS]PWS0=adxuid(1);"PTH";10;[F:MFI]MFGNUM;[F:MFI]MFGLIN
       # FQ 75839 GA 08/2011 [F:PWS] clé re-modifiée VCRLIN=WMFGLIN & VCRSEQ=WOPENUM
       # Read [F:PWS]PWS0=adxuid(1);"PTH";10;[F:MFI]MFGNUM;WOPENUM;WOPESPLNUM
       # Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS] => use WOPENUMCLE

       # Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
       #Read [F:PWS]PWS0=adxuid(1);"PTH";10;[F:MFI]MFGNUM;[F:MFI]MFGLIN;WOPENUMCLE
       Read [F:PWS]PWS0=adxuid(1);"PTH";10;[F:MFI]MFGNUM;[F:MFI]MFGLIN;LSTOSEQ
       If !fstat & [F:PWS]QTYSTU <> 0                                       # 01.06 demande 34052
            #Lecture éventuelle de article et article-site
            Read [F:ITM]ITM0 = [F:MFI]ITMREF
            If fstat GOK=0  : Call RSTA("ITM",[F:MFI]ITMREF) From GLOCK : Break : Endif
            Read [F:ITF]ITF0 = [F:MFI]ITMREF;[F:MFI]MFGFCY
            If fstat GOK=0  : Call RSTA("ITF",[F:MFI]ITMREF+[F:MFI]MFGFCY) From GLOCK : Break : Endif
            #Création enregistrement suivi decl prod
            Raz [F:MKI]
            WLINITM += 1
            [F:MKI]          = [F:MFI]
            [F:MKI]PRODTYP   = 1
            WMFICPLQTY       = [F:PWS]QTYSTU # Issue 87908 GA 04/2013
            [F:MKI]CPLQTY    = WMFICPLQTY    # Issue 87908 GA 04/2013 Raz Issue 81433 GA 06/2012 avant [F:PWS]QTYSTU
            If [F:MKI]UOM<>[F:MKI]STU & [F:MKI]UOMSTUCOE<>0   # Issue 87908 GA 04/2013
               [F:MKI]UOMCPLQTY = [F:MKI]CPLQTY / [F:MKI]UOMSTUCOE
               Call QTEARR([F:MKI]UOMCPLQTY,[F:MKI]UOM) From TRTDIV
            Else
               [F:MKI]UOMCPLQTY = [F:MKI]CPLQTY
            Endif
            [F:MKI]IPTDAT    = [F:PTH]RCPDAT
            # Issue 82325 GA 06/2012
            Local Shortint I : I=find([F:PWS]WSTOSEQ,[M:ENTW]WSTOSEQ)-1
            If dim([F:MKI]WRH)>0 & I>=0 & dim([M:ENTW]WRH(I))>0 & [M:ENTW]WRH(I)<>""
               [F:MKI]WRH=[M:ENTW]WRH(I)
            Endif
            [F:MKI]MFGTRKNUM = WMTKNUM
            [F:MKI]ITMTRKLIN = WLINITM
            [F:MKI]CREDAT    = date$
            [F:MKI]CREUSR    = GUSER
            [F:MKI]EXPNUM    = [C]EXPORT
            Raz [F:MKI]UPDUSR
            Raz [F:MKI]UPDDAT
            # 05.06 point d'entrée demande 36292
            GPOINT = "MKIMAJ"
            Gosub  ENTREE From EXEFNC
            # Issue 75998 - 2011-09-05 by CCC : Les sections doivent être alimentées avant de créer les WIPCOST
            Gosub MAJMKI_CPTANALIN
#
            # Maj stocks
            Raz [M:STW]
            [M:STW]STOFCY    = [F:MKI]MFGFCY            : # Site
            [M:STW]TRSTYP    = 5                        : # Type mouvement (M.704)
            [M:STW]VCRTYP    = 15                       : # Type pièce (M.701)
            [M:STW]VCRNUM    = [F:MKI]MFGTRKNUM         : # Numéro pièce
            [M:STW]VCRLIN    = [F:MKI]ITMTRKLIN         : # Numero ligne
            [M:STW]ITMREF    = [F:MKI]ITMREF            : # Article
            [M:STW]BPRNUM    = [F:PTD]BPSNUM            : # Tiers
            [M:STW]PJT       = [F:MFI]PJT               : # Affaire
            # FQ 68437 GA 10/2010 si [F:PWS]TRSCOD n'est pas ok (repris sur [M:PTH1]TRSCOD), prendre [F:MTS]TRSCOD
            If [F:PWS]TRSCOD<>""
               [M:STW]TRSCOD    = [F:PWS]TRSCOD         : # Code mouvement
            Else
               [M:STW]TRSCOD    = [F:MTS]TRSCOD         : # Code mouvement
            Endif
            # FQ 67539 GA 09/2010 si [F:PWS]TRSFAM n'est pas ok (repris sur [M:PTH1]TRSFAM(I)), prendre [F:MTS]TRSFAM
            If [F:PWS]TRSFAM<>""
               [M:STW]TRSFAM    = [F:PWS]TRSFAM         : # Famille mouvement
            Else
               [M:STW]TRSFAM    = [F:MTS]TRSFAM         : # Famille mouvement
            Endif
            [M:STW]IPTDAT    = [F:MKI]IPTDAT            : # Date imputation
         # 11.06 demande 38306
            [M:STW]ENTCOD = [F:MTS]ENTCOD
            [M:STW]CCECOD    = "STKEOF"
            [M:STW]VCRTYPORI = 10
            [M:STW]VCRNUMORI = [F:MKI]MFGNUM
            [M:STW]VCRLINORI = [F:MKI]MFGLIN
            [M:STW]TRAFLG   = 2                        : # Trace normal
            [M:STW]CUR = GLOCALDEV
            [M:STW]BPRNUM = ""

            PRI = func STKVAL.DEFPRIMKI([F:PWS]WSTOSEQ)
            [M:STW]PRIORDH  = PRI
            #----- Alimentation du masque de travail -----#
            [M:STW]MVTDES     = [F:PWS]MVTDES       : # Désignation mouvement
            #----- Création ligne a entrée -----#
            Raz LQTA,LSHT,LNBR,LNBJ,LRET
            Call ALISTOWORK(2,[F:PWS]WSTOSEQ,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
            If LRET : GOK = 0 : Break : Endif
            # Si premier suivi et lot à réserver au premier suivi le récupérer là
            WLOT = [M:STW]LOT
            #----- Appel du sous-programme de mise à jour des stocks -----#
            Call MAJ_STOCK From STKMAJ
            If GOK<1  Break : Endif
            [F:MKI]LOT = WLOT
            #point d'entrée  pour mise à jour spécifiques liées à [MKI] Issue 83469 GA 08/2012
            GPOINT = "BEFWRIMKI" : Gosub ENTREE From EXEFNC
            Write [F:MKI]
            If fstat
               GOK = 0 : Call FSTA("MKI") From GLOCK : Break
            Endif
            #----- MISE à jour statistiques ligne suivi article lancé -----#
            Call VALSTA("MKI",1) From SUBPS2
            If GOK < 1 : Break : Endif

            If [F:MFI]ITMTYP=1          # FQ 76070 GA 09/2011 sauf sous-produit
               WCPLQTY += [F:MKI]CPLQTY
               WREJQTY += [M:STW]RRRQTY
               WQUAQTY += [M:STW]QQQQTY
            Endif
            #Maj Article lancé
            Readlock [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
            If fstat=1  GOK=-1 : GLOCK="$MFGITM"-[F:MKI]ITMREF : Break
            Elsif fstat GOK=0  : Call RSTA("MFI",[F:MKI]ITMREF) From GLOCK : Break
            Endif
            [F:MFI]CPLQTY += [F:MKI]CPLQTY
            Call QTEARR([F:MFI]CPLQTY,[F:MFI]STU) From TRTDIV
            [F:MFI]REJCPLQTY += [M:STW]RRRQTY
            Call QTEARR([F:MFI]REJCPLQTY,[F:MFI]STU) From TRTDIV
            [F:MFI]QUACPLQTY += [M:STW]QQQQTY
            Call QTEARR([F:MFI]QUACPLQTY,[F:MFI]STU) From TRTDIV
            [F:MFI]RMNEXTQTY = [F:MFI]EXTQTY - [F:MFI]CPLQTY
            If [F:MFI]RMNEXTQTY < 0 : [F:MFI]RMNEXTQTY = 0 : Endif

            If [F:MFI]CPLQTY >= [F:MFI]EXTQTY : [F:MFI]MFITRKFLG = 5
            Else                              : [F:MFI]MFITRKFLG = 4
            Endif

            #  12.02 demande 16844
            GPOINT = "MFICLEMAJ"
            Gosub  ENTREE From EXEFNC
            If [F:MFI]MFITRKFLG = 5 : WITMCLENBR+=1 : Endif


            If    [F:MFI]MFITRKFLG = 4 : [F:MFI]ITMSTA = 2
            Elsif [F:MFI]MFITRKFLG = 5 : [F:MFI]ITMSTA = 3
            Endif
            If [F:MFI]TRKFIRST = "00/00/00"
                # [F:MFI]TRKFIRST = [F:PTH]RCPDAT
                # selon para    mètre général, on récupère le LOT au premier suivi
                  If [F:ITM]LOTMGTCOD > 1 & [F:MFI]LOT = "" & GLOTMGT = 4 & WLOT <> ""
                     [F:MFI]LOT = WLOT
                  Endif
            Endif
            # CCC (10/01/08) DM 44021
            If [F:MFI]TRKLAST<[F:PTH]RCPDAT
               [F:MFI]TRKLAST   = [F:PTH]RCPDAT
            Endif
            If [F:MFI]TRKLASTC<date$
               [F:MFI]TRKLASTC  = date$
            Endif
            If [F:MFI]TRKFIRST>[F:PTH]RCPDAT | [F:MFI]TRKFIRST = "00/00/00"
                [F:MFI]TRKFIRST = [F:PTH]RCPDAT
            Endif
            If [F:MFI]TRKFIRSTC>date$ | [F:MFI]TRKFIRSTC = "00/00/00"
                [F:MFI]TRKFIRSTC = date$
            Endif
            #If [F:MFI]MFITRKFLG = 5 : [F:MFI]TRKLAST = [F:PTH]RCPDAT : Endif

            #point d'entrée  pour mise à jour spécifiques liées à [MFI] Issue 83469 GA 08/2012
            GPOINT = "BEFREWMFI" : Gosub ENTREE From EXEFNC
            Rewrite [F:MFI]
            If fstat
               GOK = 0 : Call FSTA("MFI") From GLOCK : Break
            Endif

            # MTO - mise à jour des affectations
            Call MAJ_MTO("C", [F:MKI]CPLQTY) From MTKMTOLIB
            If GOK < 1 : Break : Endif

            #Maj encours et mvts article
            Gosub TRT_WIP From SUBMTKC
            If GOK < 1 : Break : Endif

            # 79966
            Gosub MAJMFGHEAD From MFGLIB

            Gosub TRT_MVT From SUBMTKC
            If GOK < 1 : Break : Endif
            # ----------------- TEST LLC 150 Gestion a la commande
            #Si production pour une commande allocation automatique pour celle-ci
#            If [F:MFI]FMI = 5
#               Call MAJ_ALLOCATION("C",[F:MKI]CPLQTY,[F:MKI]ITMTRKLIN) From SUBMTKC
#               If GOK < 1 : Break : Endif
#            Endif
            #----- MISE à jour statistiques ligne article lancé -----#
            Call VALSTA("MFI",1) From SUBPS2
            If GOK < 1 : Break : Endif

            #----------------------------------------------------------------------------------------------
            # point d'entrée WIP costing 14548
            If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
            GWIPCOST = "ITMTRK_NEW"
            WRET = 0
            GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
            If WRET > 0 : GOK = 0 : Break : Endif
            #-------------------------------------------------------------------------------------------

            WNBITM += 1
        Endif
    Next
    If GOK < 1 : LRET = 1 : End : Endif
Endif
#------------------------------- Si suivi matière ----------------------------------------#
If [F:MTS]MATTRKFLG = 2                                       # Suivi matière
    Local        Integer WLINMAT
    Local        Integer WNO_REAJUST
    Local        Decimal LQTA, LSHT, LDIS
    Local        Integer LNBR, LNBJ, LRET
    Local        Decimal WWALLQTY,WWSHTQTY
    Local        Char    WORI(10) : WORI = "MTMK"

    Raz WNO_REAJUST
    Raz WLINMAT
#On ne traite pas les matières déjà soldées ni  exclues
    If WNBITM = 0
       Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & BOMOPE = [F:OPS]OPENUM & MFMTRKFLG <> 5 &
&                           MATSTA <> 4 &
&                           CPNTYP <> 5
    Else
    #  05.02 demande 14240 on ne suit que les matières sans n° d'opé ou n° d'opé en cours
       Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & MFMTRKFLG <> 5 &
&                           (BOMOPE = [F:OPS]OPENUM | BOMOPE = 0)   &
&                           MATSTA <> 4 &
&                           CPNTYP <> 5
       WCOEFFPROD = WCPLQTY  / [F:MFG]EXTQTY  # Issue 87908 GA 04/2013 avant WMFICPLQTY Ko si multi-articles
       # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
       # Ce sont les quantités qui sont arrondies
       ##  01.02 demande 12597
       #WCOEFFPROD = arr(WCOEFFPROD,0.00000001)
       #
    Endif
    For [F:MFM]MFM3                        # 10.02 Performances
        Raz WCUNFLG
        WLINMAT += 1
#Lecture éventuelle de article et article-site
       If [F:ITM]ITMREF <> [F:MFM]ITMREF
          Read [F:ITM]ITM0 = [F:MFM]ITMREF
          If fstat GOK=0  : Call RSTA("ITM",[F:MFM]ITMREF) From GLOCK : Break : Endif
       Endif
#On ne suit pas les matières  si plus rien à suivre
       If ([F:MFM]RETQTY - [F:MFM]USEQTY <= 0 ) : Goto NEXTMAT : Endif

       If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
          Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
          If fstat GOK=0  : Call RSTA("ITF",[F:MFM]ITMREF+[F:MFM]MFGFCY) From GLOCK : Break : Endif
       Endif
# 03.06 demande 35914
       GPE = 1

       # Issue 36129 - 2010-10-07 by CCC : En standard on ne suit que les composants liés aux composés suivis
       If WNBITM <> 0 & [F:MFM]MFGLIN <> 0
           Filter [F:MKI] Where  MFGTRKNUM = WMTKNUM & MFGNUM = [F:MFM]MFGNUM & MFGLIN = [F:MFM]MFGLIN
           Read [F:MKI]MKI0 First
           If fstat : GPE = 0 : Endif
           Filter [F:MKI]  # FQ 77545 GA 11/2011 ajout de la Raz
           # Issue 101197 - 2014-12-12 by CCC
           Read [MFI]MFI0=[F:MFM]MFGNUM;[F:MFM]MFGLIN
           WCOEFFITM  = [F:MKI]CPLQTY / [F:MFI]EXTQTY
       Endif

      # Mettre GPE = 0 pour exclure la ligne
       GPOINT = "MFMCTL"
       Gosub  ENTREE From EXEFNC
       If GPE = 0 : Goto NEXTMAT : Endif
#On ne suit pas les matières en inventaire si pas d'emplacement libéré
       If [F:ITF]CUNFLG = 2
          If [F:MFM]ALLSTA > 3
             Gosub REC_LOC From SUBMTKB
          Else
             #  04.02 Problèmes Perf
             Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                            Order By Key STO3
             Read [F:STO]STO3 First
             If fstat WCUNFLG = 2 : Endif
             Filter [F:STO]
          Endif
       Endif
       If WCUNFLG = 2 : Gosub NEXTMAT : Endif
#Selon transaction, on filtre sur le mode de déstockage   08.06 demande 37499
       If [F:MTS]STOCODDEF <> 3 & [F:ITF]STOCOD <> [F:MTS]STOCODDEF : Goto NEXTMAT : Endif
#Selon transaction, on ne suit pas les matières dont le mode de déstockage est manuel
       If [F:ITF]STOCOD = 1 & [F:MTS]STOCODMAN = 2 : Goto NEXTMAT : Endif

# si il n'y a aps du tout de stock ET Stock negatif interdit!! ( 08.05) on ne traite pas
       Call LECSRU([F:MFM]MFGFCY,[F:ITM]TCLCOD,6,[F:MTS]TRSCODS,"",LRET) From STKLIB
       If LRET = 1 : LDIS = 0
       Else
          Call LECITV2([F:ITF]STOFCY,[F:ITF]ITMREF,LRET) From MFGLIB
       # FQ 74662 GA 08/2011 ctrl du stock fait plus loin
       ###   If [F:MFM]LOC =  ""
       ###     Call STODISTOT("",0,[F:SRU]AUZSTA,"",LDIS) From STKLIB
       ###   Else
       ###     Call STODISPO("",[F:MFM]MFGFCY,[F:MFM]ITMREF,"*",[F:MFM]LOC,4,[F:SRU]AUZSTA,"","","",LDIS) From STKLIB
       ###   Endif
       ###   # llc 04.04 il faut tenir compte de la quantité allouée de la matière
       ###   LDIS += [F:MFM]ALLQTY
       Endif
       ###If LDIS = 0  & [F:ITM]NEGSTO <> 2
       ###   # 03.06 demande 34987
       ###   Raz WMSGSUI
       ###   WMSGSUI =  mess(202,190,1)+" : "+[F:MFM]MFGNUM - num$([F:MFM]BOMOPE) -[F:MFM]ITMREF -
       ###&                    mess(204,190,1)
       ###   GPURTRACE = 2
       ###   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
       ###   GOK=0      # FQ 74662 GA 08/2011 code retour en erreur
       ###   Goto NEXTMAT
       ###Endif
       If [F:MFM]MFGLIN <> 0
           Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
           If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Break : Endif   # llc 05.02 incohérence
       Else
           Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
           Read [F:MFI]MFI0 First
           If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Break : Endif   # llc 05.02 incohérence
           Filter [F:MFI]
       Endif
#Création enregistrement suivi mat
       Raz [F:MKM]
       [F:MKM]          = [F:MFM]
       [F:MKM]PJT       = [F:MFI]PJT
       [F:MKM]MATTYP    = 1
       [F:MKM]MATTRKLIN = WLINMAT
       [F:MKM]MFGTRKNUM = WMTKNUM
       [F:MKM]CUMMATSUI = 0
       [F:MKM]MFMITMREF = [F:MKM]ITMREF
       [F:MKM]IPTDAT    = [F:PTH]RCPDAT
       #  08.05 demande 29188
       If [F:MKO]OPENUM <> [F:MFM]BOMOPE
          Filter [F:MKO] Where MFGTRKNUM = WMTKNUM & OPENUM = [F:MFM]BOMOPE
          Read [F:MKO]MKO0 First
          If fstat : Raz [F:MKO] : Endif
       Endif
       Filter [F:MKO]
       [F:MKM]CPLWST = [F:MKO]CPLWST
#Si mode de conso = immédiat on consomme tout ce qui reste. Idem si forfait
       If [F:MTS]CONSMAT= 1 | [F:MFM]LIKQTYCOD = 2
          [F:MKM]USEQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
          If [F:MKM]USEQTY < 0 : [F:MKM]USEQTY = 0 : Endif
#si déclaration de production
       Elsif WNBITM <> 0
           # Issue 101197 - 2014-12-12 by CCC
           If [MFM]MFGLIN<>0
              [F:MKM]USEQTY    = [F:MFM]RETQTY * WCOEFFITM
           Else
              [F:MKM]USEQTY    = [F:MFM]RETQTY * WCOEFFPROD
           Endif
           If [F:MFM]USEQTY + [F:MKM]USEQTY > [F:MFM]RETQTY & [F:MTS]CONSMAT = 2
              [F:MKM]USEQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
           Endif
       Else
          If [F:MKO]OPENUM <> [F:MFM]BOMOPE
              Filter [F:MKO] Where MFGTRKNUM = WMTKNUM & OPENUM = [F:MFM]BOMOPE
              Read [F:MKO]MKO0 First
              If fstat GOK=0  : Call RSTA("MKO",num$([F:MFM]BOMOPE)) From GLOCK : Break : Endif   # llc 05.02 incohérence
              Filter [F:MKO]  # FQ 77545 GA 11/2011 ajout de la Raz
          Endif
#          Read [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;0
          If WOPETOTQTY <> 0 : WCOEFF = [F:MKO]CPLQTY / WOPETOTQTY
          Else               : WCOEFF = 1
          Endif
          # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
          # Ce sont les quantités qui sont arrondies
          ##  01.02 demande 12597
          #WCOEFF = arr(WCOEFF,0.00000001)
          #
          [F:MKM]USEQTY =  [F:MFM]RETQTY * WCOEFF
          If [F:MFM]USEQTY + [F:MKM]USEQTY > [F:MFM]RETQTY & [F:MTS]CONSMAT = 2
              [F:MKM]USEQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
          Endif
       Endif
       Call QTEARR([F:MKM]USEQTY,[F:MFM]STU) From TRTDIV
       If [F:MKM]USEQTY = 0 : Goto NEXTMAT : Endif
       If [F:MTS]LOCFOU  = 2 : [F:MKM]LOCPREF = [F:BPS]LOC
       Else                  : [F:MKM]LOCPREF = [F:MFM]LOC
       Endif
       # Issue 82325 GA 06/2012
       Local Shortint I : I=find([F:PWS]WSTOSEQ,[M:ENTW]WSTOSEQ)-1
       If dim([F:MKM]WRH)>0 & I>=0 & dim([M:ENTW]WRH(I))>0 & [M:ENTW]WRH(I)<>""
          [F:MKM]WRH=[M:ENTW]WRH(I)
       Elsif dim([F:MKM]WRH)>0 & dim([F:PTH]WRHE)>0 & [F:PTH]WRHE<>""
          [F:MKM]WRH=[F:PTH]WRHE
       Endif

       If [F:MKM]LOCPREF = "" : [F:MKM]LOCPREF = "*" : Endif
       [F:MKM]LOTPREF   = "*"
       [F:MKM]STAPREF   = [F:MFM]STA
       [F:MKM]CREDAT    = date$
       [F:MKM]CREUSR    = GUSER
       [F:MKM]EXPNUM    = [C]EXPORT
       [F:MKM]MFMEXTQTY = [F:MFM]RETQTY
       #  08.03 point d'entrée permettant une mise à jour de zones spécifiques demande 19291
       GPOINT = "MKMMAJ" : Gosub ENTREE From EXEFNC

       Raz [F:MKM]UPDUSR
       Raz [F:MKM]UPDDAT
    #---------------------------------------------#
    # duplication texte si pas accès a ce dernier #
    #---------------------------------------------#
      If [F:MFM]MFMTEX <> ""
          [F:MKM]MKMTEX = [F:MFM]MFMTEX
          If left$([F:MKM]MKMTEX,3)="MFM"
            Call DUP_CLOB("MKM",[F:MKM]MKMTEX,GOK) From TRTX3TEX
          Endif
      Endif
#
       WWQTY = [F:MKM]USEQTY
       # Maj Stock
       # Issue 108029 - 2015-11-06 by BEEBE : with GOK the processing remember whether a material couldn´t be tracked
       # and that´s why the complete processing may not be done. In a label/Subprog called in LOAD_SOW_SORTIE
       # GOK would be initialized. In order to consider the setting not at the last but e.g. the first material,
       # the setting of GOK will be saved and rejected after LOAD_ALP
       Local Integer LSAVGOK : LSAVGOK=GOK
       Gosub LOAD_MTMK       From MTKAUTLIB
       Gosub LOAD_SOW_SORTIE From MTKAUTLIB
       Gosub LOAD_STW        From MTKAUTLIB
       Gosub LOAD_ALP        From MTKAUTLIB
       GOK=LSAVGOK

       # Issue 75998 - 2011-09-05 by CCC : Les sections doivent être alimentées avant de créer les WIPCOST
       Gosub MAJMKM_CPTANALIN

       Raz LQTA,LSHT,LNBR,LNBJ,LRET
       If [F:MFM]ALLSTA > 1
          Call MAJALLORI([F:MKM]MATTRKLIN,LRET) From STKALL
          If LRET : GOK = 0 : Endif
          WWALLQTY = [M:ALP]DESQTY
          WWSHTQTY = [M:ALP]DESQTYSHT
       Endif
       Call ALISTOWORK(3,[F:MKM]MATTRKLIN,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
       If LRET : GOK = 0 : Break : Endif

       # Issue 93977 GA 11/2013 If ([F:ITM]NEGSTO <> 2 & [F:MKM]USEQTY>LQTA )
       # la qté thérorique a été écrasée, elle est dans WWQTY
       If ([F:ITM]NEGSTO <> 2 & WWQTY>LQTA ) | [M:STW]NBLIG=0
# FQ 74662 GA 08/2011 sortir en erreur si stock insuffisant
###               [F:MKM]USEQTY  = LQTA
###               If [F:MKM]USEQTY = 0
###                 Raz WMSGSUI
###                 WMSGSUI =  mess(202,190,1)+" : "+[F:MFM]MFGNUM - num$([F:MFM]BOMOPE) -[F:MFM]ITMREF -
###&                      mess(204,190,1)
###                  GPURTRACE = 2
###                  Call ECR_TRACE(WMSGSUI,-1) From GESECRAN
###                  Goto NEXTMAT
###               Else
###                 Raz WMSGSUI
###                 WMSGSUI =  mess(202,190,1)+" : "+[F:MFM]MFGNUM - num$([F:MFM]BOMOPE) -[F:MFM]ITMREF -
###&                 mess(186,190,1)
###                  GPURTRACE = 2
###                  Call ECR_TRACE(WMSGSUI,-1) From GESECRAN
###               Endif
         Raz WMSGSUI
         If [F:MKM]USEQTY = 0
           WMSGSUI =  mess(202,190,1)+" : "+[F:MFM]MFGNUM - num$([F:MFM]BOMOPE) -[F:MFM]ITMREF -
&                     mess(204,190,1)-[F:MFM]LOC
         Else
           WMSGSUI =  mess(202,190,1)+" : "+[F:MFM]MFGNUM - num$([F:MFM]BOMOPE) -[F:MFM]ITMREF -
&                     mess(186,190,1)-[F:MFM]LOC
         Endif
         GPURTRACE = 2
         # Issue 95984 GA 02/2014 annule et remplace correction 74662 (V6) trop contraigante: sens du PE inversé
         # Issue 93977 GA 11/2013
         # ajout d'un PE pour que la qté insuffisante puisse être BLOQUANTE dans certains cas
         GPE=0 : GPOINT = "MKMUSEQTY" : Gosub ENTREE From EXEFNC
         If GPE | [F:ITF]MFGSHTCOD = 1 # Matière bloquante si rupture
           Call ECR_TRACE(WMSGSUI,1) From GESECRAN
           GOK=0          # FQ 74662 GA 08/2011 code retour en erreur
         Else
           Call ECR_TRACE(WMSGSUI,-1) From GESECRAN
         Endif
         If [F:MKM]USEQTY=0 | GOK<1 Goto NEXTMAT Endif
       Endif
       If [M:STW]NBLIG>0 # Issue 93977 GA 11/2013 sinon Erreur "Aucune ligne à traiter"
         Call MAJ_STOCK() From STKMAJ
         If GOK < 1 : Break  : Endif
       Endif

       #point d'entrée  pour mise à jour spécifiques liées à [MKM] Issue 83469 GA 08/2012
       GPOINT = "BEFWRIMKM" : Gosub ENTREE From EXEFNC
       Write [F:MKM]
       If fstat
             GOK = 0 : Call FSTA("MKM") From GLOCK : Break
       Endif
       #----- MISE à jour statistiques ligne suivi matière -----#
       Call VALSTA("MKM",1) From SUBPS2
       If GOK < 1 : Break : Endif
       #si matière soldée on réinitialise à 0 les qtés allouées et en rupture
       #On supprime toutes les allocs liées à cette matière(si il en reste)
       #si matière non soldée , on réajuste les qtés allouées et en rupture
       Readlock [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
       If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MKM]ITMREF : Break
       Elsif fstat GOK=0  : Call RSTA("MFM",[F:MKM]ITMREF) From GLOCK : Break
       Endif
       [F:MFM]USEQTY += [F:MKM]USEQTY
       Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
       Raz WRET
       Call CONT_SOLDE_MAT([F:MFM]MFGFCY,[F:MFM]ITMREF,[F:MFM]USEQTY,[F:MFM]RETQTY,WRET) From MFGLIBM
       If WRET = 1                       : [F:MFM]MFMTRKFLG = 5
       Else                              : [F:MFM]MFMTRKFLG = 4
       Endif

       #  04.04 possibilité de forcer le solde de la matière demande 20301
       GPOINT = "MFMCLEMAJ" : Gosub ENTREE From EXEFNC

       If    [F:MFM]MFMTRKFLG = 4 : [F:MFM]MATSTA = 2
                                    If [F:MFM]ALLSTA > 3
                                       [F:MFM]ALLQTY -= WWALLQTY
                                       [F:MFM]SHTQTY -= WWSHTQTY
                                    Endif
       Elsif [F:MFM]MFMTRKFLG = 5 : [F:MFM]MATSTA = 3
                                    Gosub SUPALL_OF From SUBMTKC
                                    If GOK < 1 : Break : Endif
                                    Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
                                    WMATCLENBR+=1

       Endif
       # CCC (10/01/08) DM 44021
       #If [F:MFM]TRKFIRST = "00/00/00" : [F:MFM]TRKFIRST = [F:PTH]RCPDAT : Endif
       #If [F:MFM]MFMTRKFLG = 5 : [F:MFM]TRKLAST = [F:PTH]RCPDAT : Endif
       If [F:MFM]TRKLAST<[F:PTH]RCPDAT
          [F:MFM]TRKLAST   = [F:PTH]RCPDAT
       Endif
       If [F:MFM]TRKLASTC<date$
          [F:MFM]TRKLASTC  = date$
       Endif
       If [F:MFM]TRKFIRST>[F:PTH]RCPDAT | [F:MFM]TRKFIRST = "00/00/00"
           [F:MFM]TRKFIRST = [F:PTH]RCPDAT
       Endif
       If [F:MFM]TRKFIRSTC>date$ | [F:MFM]TRKFIRSTC = "00/00/00"
           [F:MFM]TRKFIRSTC = date$
       Endif
       Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
       #point d'entrée  pour mise à jour spécifiques liées à [MFM] Issue 83469 GA 08/2012
       GPOINT = "BEFREWMFM" : Gosub ENTREE From EXEFNC
       Rewrite [F:MFM]
       If fstat
          GOK = 0 : Call FSTA("MFM") From GLOCK : Break
       Endif

       # affectations
       Gosub MAJ_MTO_MFM From MFGMTOLIB

       #----- MISE à jour statistiques ligne matière -----#
       Call VALSTA("MFM",1) From SUBPS2
       If GOK < 1 : Break : Endif

# ----------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
       If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
       GWIPCOST = "MATTRK_NEW"
       WRET = 0
       GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
       If WRET > 0 : GOK = 0 : Break : Endif
#------------------------------------------------------------------------------------------------------------------

      WNBMAT += 1
$NEXTMAT
    Next
    Filter [F:MFM]  # FQ 77545 GA 11/2011 ajout de la Raz
    If GOK < 1 : LRET = 1 : End : Endif
Endif
If WNBOPE <> 0 | WNBITM <> 0 | WNBMAT <> 0
   Raz [F:MTK]
   [F:MTK]          = [F:MFG]
   [F:MTK]MFGTRKNUM = WMTKNUM
   [F:MTK]CREDAT    = date$
   [F:MTK]CREUSR    = GUSER
   [F:MTK]EXPNUM    = [C]EXPORT
   [F:MTK]NBROPE    = WNBOPE
   If [F:MTK]NBROPE > 0 : [F:MTK]OPETRKFLG = 2
   Else                 : [F:MTK]OPETRKFLG = 1
   Endif
   [F:MTK]NBRITM    = WNBITM
   If [F:MTK]NBRITM > 0 : [F:MTK]ITMTRKFLG = 2
   Else                 : [F:MTK]ITMTRKFLG = 1
   Endif
   [F:MTK]NBRMAT    = WNBMAT
   If [F:MTK]NBRMAT > 0 : [F:MTK]MATTRKFLG = 2
   Else                 : [F:MTK]MATTRKFLG = 1
   Endif
   [F:MTK]PTHNUM    = [F:PTH]PTHNUM
   [F:MTK]PTDLIN    = [F:PTD]PTDLIN
   [F:MTK]MFGTRKDAT = [F:PTH]RCPDAT
#-- dupli du texte entête OF sans saisie
   If [F:MFG]MFGTEX <> ""
       [F:MTK]MTKTEX = [F:MFG]MFGTEX
       If left$([F:MTK]MTKTEX,3)="MFG"
          Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
       Endif
    Endif
    # point d'entrée  pour mise à jour spécifiques liées à [MTK] Issue 83469 GA 08/2012
    GPOINT = "BEFWRIMTK" : Gosub ENTREE From EXEFNC
    Write [F:MTK]
    If fstat
       GOK = 0 : Call FSTA("MTK") From GLOCK
       LRET = 1
       End
    Endif
    Call MAJMFGHEAD([F:MTK]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN) From SUBMTKC
    If GOK < 1 : LRET = 1 : End : Endif

    Raz GPE
    GPOINT="UPDSCD"
    Gosub ENTREE From EXEFNC
    If !GPE
        #  08.02 si besoin maj de WORKLOAD demande 15029
        If [F:MTK]OPETRKFLG = 2 & find([F:MFG]SCDFLG,2,4)
            [M:JALK]CODORI = 1
            [M:JALK]CODMAJ = 0
            [M:JALK]CODTRS = 0                        # llc 11.02 16716
            [M:JALK]MFGFCY = [F:MFG]MFGFCY
            [M:JALK]MFGNUM = [F:MFG]MFGNUM
            [M:JALK]MFGSTA = [F:MFG]MFGSTA
            # llc 12.02 16779 + 17348
            If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
            If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                Read [PJA]PJA0=[M:JALK]MFGFCY
                If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
            Endif
            Call DEJALONNE From JALLIBA
            If [M:JALK]CODRET = 0
                Call JALONNE From JALLIB
            Endif
        Endif
    Endif
    If GOK < 1 : LRET = 1 : End : Endif
    #  08.02 demande 14023
    WMSGSUI = mess(79,190,1)+" : "+[F:MTK]MFGTRKNUM +" / " + mess(467,197,1) +" : "+ [F:MTK]MFGNUM
    GPURTRACE = 2
    Call ECR_TRACE(WMSGSUI,0) From GESECRAN
Endif
End

###################################################################################
$MAJMKO_CPTANALIN

If dim(WI)<1  Local Integer WI : Endif

# CCC (2009-09-10) Bug 57425 : INISEC peut casser la classe [F:CAL]
If !clalev([F:CAL2]) : Local File CPTANALIN [CAL2] : Endif

Raz [F:CAL2]
[F:CAL2]ABRFIC="MKO"
[F:CAL2]VCRNUM=[F:MKO]MFGTRKNUM
[F:CAL2]VCRLIN=[F:MKO]OPETRKLIN
[F:CAL2]CPLCLE=[F:MKO]CPLWST
[F:CAL2]ANALIG=1

For WI=1 To max(GNBCOA,2)
    [F:CAL2]LED(WI-1)=GLEDSOC(WI)
    [F:CAL2]COA(WI-1)=GCOA(WI)
Next WI
Read [MWS]WST0=[F:MKO]CPLWST;[F:MKO]MFGFCY
# Issue 77417 - 2012-02-01 by CCC
#For WI=1 To max(GNBDIE,GOPTCANA)
For WI=1 To GNBDIE
    [F:CAL2]DIE(WI-1)=GDIE(WI)
    Raz WCCE
    Call INISEC(WCCE,"MKOAUT", WI ) From TRTX3CPT
    [F:CAL2]CCE(WI-1) = WCCE
Next WI

Write [CAL2]
If fstat  GOK=0 : Call FSTA("CAL2") From GLOCK : Return : Endif
#

If [F:MKO]CPLLAB = "" : Return : Endif
# Poste secondaire : l'enregistrement peut ne pas exister
Raz [F:CAL2]
[F:CAL2]ABRFIC="MKO"
[F:CAL2]VCRNUM=[F:MKO]MFGTRKNUM
[F:CAL2]VCRLIN=[F:MKO]OPETRKLIN
[F:CAL2]CPLCLE=[F:MKO]CPLLAB
[F:CAL2]ANALIG=1
#-----
For WI=1 To max(GNBCOA,2)
    [F:CAL2]LED(WI-1)=GLEDSOC(WI)
    [F:CAL2]COA(WI-1)=GCOA(WI)
Next WI
# lecture poste main d'oeuvre pour section de valo (contenant les CCE)(28/09)
Read [MWS]WST0=[F:MKO]CPLLAB;[F:MKO]MFGFCY
# Issue 77417 - 2012-02-01 by CCC
#For WI=1 To max(GNBDIE,GOPTCANA)
For WI=1 To GNBDIE
     [F:CAL2]DIE(WI-1)=GDIE(WI)
     Raz WCCE
     Call INISEC(WCCE,"MKOLABAUT",WI) From TRTX3CPT
     [F:CAL2]CCE(WI-1) = WCCE
Next WI

Write [CAL2]
If fstat  GOK=0 : Call FSTA("CAL2") From GLOCK : Return : Endif

Return


###################################################################################
$MAJMKI_CPTANALIN

If dim(WI)<1  Local Integer WI : Endif

# CCC (2009-09-10) Bug 57425 : INISEC peut casser la classe [F:CAL]
If !clalev([F:CAL2]) : Local File CPTANALIN [CAL2] : Endif

Raz [F:CAL2]
[F:CAL2]ABRFIC="MKI"
[F:CAL2]VCRNUM=[F:MKI]MFGTRKNUM
[F:CAL2]VCRLIN=[F:MKI]ITMTRKLIN
[F:CAL2]ANALIG=1

For WI=1 To max(GNBCOA,2)
    [F:CAL2]LED(WI-1)=GLEDSOC(WI)
    [F:CAL2]COA(WI-1)=GCOA(WI)
Next WI

#-----
# Issue 77417 - 2012-02-01 by CCC
#For WI=1 To max(GNBDIE,GOPTCANA)
For WI=1 To GNBDIE
    [F:CAL2]DIE(WI-1)=GDIE(WI)
    Raz WCCE
    Call INISEC(WCCE,"MKIAUT", WI ) From TRTX3CPT
    [F:CAL2]CCE(WI-1) = WCCE
Next WI
#-----
Write [CAL2]
If fstat  GOK=0 : Call FSTA("CAL2") From GLOCK : Return : Endif
#
Return

###################################################################################
$MAJMKM_CPTANALIN
If dim(WI)<1  Local Integer WI : Endif

# CCC (2009-09-10) Bug 57425 : INISEC peut casser la classe [F:CAL]
If !clalev([F:CAL2]) : Local File CPTANALIN [CAL2] : Endif

Raz [F:CAL2]
[F:CAL2]ABRFIC="MKM"
[F:CAL2]VCRNUM=[F:MKM]MFGTRKNUM
[F:CAL2]VCRLIN=[F:MKM]MATTRKLIN
[F:CAL2]ANALIG=1

For WI=1 To max(GNBCOA,2)
    [F:CAL2]LED(WI-1)=GLEDSOC(WI)
    [F:CAL2]COA(WI-1)=GCOA(WI)
Next WI
#-----
# Issue 77417 - 2012-02-01 by CCC
#For WI=1 To max(GNBDIE,GOPTCANA)
For WI=1 To GNBDIE
    [F:CAL2]DIE(WI-1)=GDIE(WI)
    Raz WCCE
    Call INISEC(WCCE,"MKMAUT", WI) From TRTX3CPT
    [F:CAL2]CCE(WI-1) = WCCE
Next WI
#-----

Write [CAL2]
If fstat  GOK=0 : Call FSTA("CAL2") From GLOCK : Return : Endif

Return

#####################################################
$MAJ_PRIX_SUIVI

# Prix réalisé n'est mis à jour que s'il y a eu facturation de sous-traitance # (TB  03/2001)
# dans le PRF et l'agrégation de suivi, le prix réel sera par défaut = à EXTPRI
If [F:PTD]INVQTYPUU = 0  Return  Endif

Gosub RECH_CPR

If [F:ITP]PUUSTUCOE <> 0
    WQTYSTU = [F:PTD]INVQTYPUU * [F:ITP]PUUSTUCOE
Else
    If [F:ITM]PUUSTUCOE <> 0
        WQTYSTU = [F:PTD]INVQTYPUU * [F:ITM]PUUSTUCOE
    Else
        WQTYSTU = [F:PTD]INVQTYPUU
    Endif
Endif

# Issue 97060 GA 04/2014 avoid the error "divided by zero"
If [F:MFO]OPESTRCOE<>0
    WQTYUO = WQTYSTU / [F:MFO]OPESTRCOE
    WPRIUO = WCPR    * [F:MFO]OPESTRCOE
Else
    WQTYUO = WQTYSTU
    WPRIUO = WCPR
Endif

[F:MKO]INVQTY += WQTYUO
[F:MKO]CPLPRI += WPRIUO
Return

#####################################################
$MAJ_PRIX_OPE
If [F:PTD]INVQTYPUU = 0 : Return : Endif

# mise à jour données opération
If [F:MFO]INVQTY = 0
    [F:MFO]INVQTY += WQTYUO
    [F:MFO]CPLPRI += WPRIUO
 Else
    If WQTYUO <> 0
        WRKQTY         = [F:MFO]INVQTY + WQTYUO
        WRKPRI         = ([F:MFO]INVQTY * [F:MFO]CPLPRI) + (WQTYUO * WPRIUO)
        [F:MFO]CPLPRI  = WRKPRI / WRKQTY
        [F:MFO]INVQTY += WQTYUO
    Else
        WRKPRI         = ([F:MFO]INVQTY * [F:MFO]CPLPRI) + WPRIUO
        [F:MFO]CPLPRI  = WRKPRI / [F:MFO]INVQTY
    Endif
Endif
Return

#####################################################
$RECH_CPR
#--- recherche de la derniere ligne de facture
Filter [PID] Where TYPORI = 1 and NUMORI = [F:POQ]POHNUM and LINORI = [F:POQ]POPLIN
&            and   SEQORI = [F:POQ]POQSEQ   Order By Key PID1 Desc
For [PID]
    Read [PIH]PIH0 = [F:PID]NUM
    If fstat = 0
        If [F:PIH]STA = 3
            WCPR = [F:PID]CPR
            Break
        Endif
    Endif
Next
Filter [PID]

If WCPR = 0
    WCPR = [F:POP]NETPRI
    If [F:ITP]CPRCOE = 0
              # prendre les frais hors prix net dans le tarif
              # qui entre dans calcul prix de valorisation
              # a faire ???????????????????
              # ???????????????????????
    Else WCPR *= [F:ITP]CPRCOE
    Endif
    Call CONVERT([F:POH]CUR,GCUR,GCUR,[F:POH]CHGTYP,[F:POH]ORDDAT,WCPR,WCPR, STAT) From TRTDEV
    #--- attention ce prix est dans l'unité de la commande UOM
    #-- il faut le transformer en US
    If [F:POQ]UOM <> [F:POQ]STU
        If [F:POQ]UOM <> [F:POQ]PUU
            WCPR /= [F:POQ]UOMPUUCOE
        Endif
    #--- recherche coef US - UA
        GBIDD1 = 1
        GBIDD2 = 0
        Call PCAL_QTY(GBIDD1,[F:POQ]PUU,GBIDD2,[F:POQ]STU,[F:POP]ITMREF,
&                     [F:POH]BPSNUM,1,GBIDD3) From TRTACHQTE1
        If GBIDD3 <> 0  : WCPR  /= GBIDD3 : Endif
    Endif
Endif
Return

#########################################################################
#suppression d'un suivi en suppression de réception
Subprog DEL_SUIV(LRET)
Variable Integer LRET
Local Char WGREP(2)
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Decimal WCPLQTY,WREJQTY,WQUAQTY
Global Date GWIPTDAT
Global Shortint GMFGTRACE         : # affichage d'une trace en gestion
Local Integer OK : OK = 1
Gosub OPEN_FILE
# 06.06 demande 36615
Read [MTS] MTS0 = 2;GMTKMTSNUM
#Issue X3-55214 30/10/2017 by GEBIL : SVGNOL Variable nonexistent
#If fstat : Raz[F:MTS] : LRET = 1 : Return : Endif
If fstat : Raz[F:MTS] : Call ERREUR("MTKMTSNUM :"-mess(171,133,1)) From GESECRAN : LRET = 1 : End : Endif
Readlock [F:MTK]MTK2 = [F:PTD]PTHNUM;[F:PTD]PTDLIN
If fstat = 5 : End : Endif
If fstat=1  GOK=-1 : GLOCK="$MFGHEADTRK"-[F:PTH]PTHNUM-num$([F:PTD]PTDLIN) : End
Elsif fstat GOK=0  : Call RSTA("MTK",[F:MTK]PTHNUM-num$([F:PTD]PTDLIN)) From GLOCK : End
Endif
Read [F:MFG]MFG0 = [F:MTK]MFGNUM
If fstat : Raz [F:MFG] : Endif
#contrôle que l'OF n'est pas clos et que la période est ouverte pour maj du stock
Gosub VERF_ANU From SUBMTKA
If OK = 0 : LRET = 1 : End : Endif
#Il faut forcer GREP à "A" (en suppression simple d'une ligne GREP = "M" et c'est pas bon!!!)
WGREP = GREP
GREP  = "A"

Gosub ANNULE_SUIV From SUBMTKC

GREP = WGREP
If GOK = 1
   Delete [F:MTK]
   If fstat :GOK = 0 : GLOCK = "$"+"MFGHEADTRK" : Endif
Endif
If GOK < 1 : LRET = 1 : End : Endif
End

#########################################################################
$OPEN_FILE
If clalev([M:ORDK]) = 0 : Local Mask ORDK      [ORDK]: Endif       # pour générer encours
If clalev([M:OPSK]) = 0 : Local Mask OPSK      [OPSK]: Endif       # masque encours charge
If clalev ([M:MTMK])= 0 : Local Mask MTMK      [MTMK]: Endif        # buffer suivi matière automatique
If clalev ([M:STW]) = 0 : Local Mask STOWORK   [STW] : Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If clalev ([M:ALP]) = 0 : Local Mask ALLPAR    [ALP] : Endif
If clalev ([M:SOW]) = 0 : Local Mask STOSORW   [SOW] : Endif
# ouverture tables si nécessaire
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif  # ordre de fabrication
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif  # articles lancés
If clalev([F:MFM]) = 0 : Local File MFGMAT     [MFM] : Endif  # matières OF
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif  # opérations OF
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif  # poste de charge
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif  # article
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif  # catégories article
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif  # mouvements article
If clalev([F:MTK]) = 0 : Local File MFGHEADTRK [MTK] : Endif  # suivi de fabrication
If clalev([F:MKI]) = 0 : Local File MFGITMTRK  [MKI] : Endif  # suivi articles lancés
If clalev([F:MKM]) = 0 : Local File MFGMATTRK  [MKM] : Endif  # suivi matières OF
If clalev([F:MKO]) = 0 : Local File MFGOPETRK  [MKO] : Endif  # suivi opérations OF
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif  # allocations
If clalev([F:STS]) = 0 : Local File STOSER     [STS] : Endif  # numéros de série
If clalev([F:TRU]) = 0 : Local File TABALLRUL  [TRU] : Endif
If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:CAL]) = 0 : Local File CPTANALIN  [CAL] : Endif
# 06.06 demande 36615
If clalev([F:MTS]) = 0 : Local File MFGTRS     [MTS] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
If GREP <> "A"
   If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif  # encours charge
   If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif  # jalonnements
   If clalev([F:ROS]) = 0 : Local File ROUSCD     [ROS] : Endif  # Gamme/Jalonnement opérations
Endif
#  08.02 demande 15029
Local Mask JALK   [JALK]                                             # ecran pour jalonnement
If clalev([F:PJA])<=0 : Local File PARJAL     [PJA] : Endif          # Paramètres jalonnement
#

Return


$OUVERTURE_TRACE
#---------------------------------------#
# Ouverture fichier trace si nécessaire #
#---------------------------------------#
If GMFGTRACE=0 & !GIMPORT
  Call OUVRE_TRACE(mess(193,197,1)) From LECFIC : GMFGTRACE=1
Endif
Return

$LECTURE_TRACE
#----------------------------------------#
# Lecture du fichier trace si nécessaire #
#----------------------------------------#
If GMFGTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  GMFGTRACE=0
Endif
Return

$LECT_EFFAC_TRACE
#----------------------------------------------------------#
# Lecture et effacement trace si abandon de la transaction #
#----------------------------------------------------------#
If GMFGTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call SUPP_TRACE  From LECFIC
  GMFGTRACE=0
Endif
Return

$FERMETURE_TRACE
#---------------------------------------#
# Fermeture fichier trace si nécessaire #
#---------------------------------------#
If GMFGTRACE<>0 & !GIMPORT
   Call FERME_TRACE From LECFIC : GMFGTRACE=0
Endif
Return


$CAL_MAXQTYMTK
#---------------------------------------------------#
# Calcul de la quantité maxi restant à déclarer     #
# nolign doit être correct                          #
#---------------------------------------------------#
If dim(NOL) <0      : Local Shortint NOL       : NOL=nolign-1 : Endif
If dim(J)<0         : Local Shortint J         : Endif
If dim(NEWMAXQTY)<0 : Local Decimal  NEWMAXQTY : Endif
If dim(SVGNOL)<0    : Local Shortint SVGNOL    : Endif
SVGNOL= nolign
Case GFONC1
    When "GESMTK" :
                If [M:MTK2]MFGNUMIT(NOL)<>""
                  #----- Lecture ligne commande quantités si nécessaire -----#
                  If [F:MFI]MFGNUM<>[M:MTK2]MFGNUMIT(NOL) | [F:MFI]MFGLIN<>[M:MTK2]MFGLIN(NOL)
                    Read [F:MFI] MFI0=[M:MTK2]MFGNUMIT(NOL);[M:MTK2]MFGLIN(NOL)
                    If fstat  Raz [F:MFI] : Endif
                  Endif
                  If [F:MFI]MFGNUM<>""
                    NEWMAXQTY=[F:MFI]EXTQTY-[F:MFI]CPLQTY
                    NEWMAXQTY+=[M:MTK2]CPLQTY(NOL)
                    NEWMAXQTY-=NEWQTE
                    For J=0 To [M:MTK2]NBITM-1
                      If [M:MTK2]MFGNUMIT(J)=[F:MFI]MFGNUM & [M:MTK2]MFGLIN(J)=[F:MFI]MFGLIN &
&                        J<>NOL
                         If [M:MTK2]CREFLG(J)=0
                          NEWMAXQTY-=[M:MTK2]CPLQTY(J)
                        Endif
                       Endif
                    Next J
                  Endif
                Endif
    When "FUNBENCHO","FUNBENCHI","FUNBENPLT" :
                If [M:MBI]PRODTYP(NOL) = 1
                  #----- Lecture ligne commande quantités si nécessaire -----#
                  If [F:MFI]MFGNUM<>[M:MBI]MFGNUM(NOL) | [F:MFI]MFGLIN<>[M:MBI]MFGLIN(NOL)
                    Read [F:MFI] MFI0=[M:MBI]MFGNUM(NOL);[M:MBI]MFGLIN(NOL)
                    If fstat  Raz [F:MFI] : Endif
                  Endif
                  If [F:MFI]MFGNUM<>""
                    NEWMAXQTY=[F:MFI]EXTQTY-[F:MFI]CPLQTY
                    NEWMAXQTY+=[M:MBI]CPLQTY(NOL)
                    NEWMAXQTY-=NEWQTE
                    For J=0 To [M:MBI]NBLIG-1
                      If [M:MBI]PRODTYP(NOL) = 1 & [M:MBI]MFGNUM(J)=[F:MFI]MFGNUM & [M:MBI]MFGLIN(J)=[F:MFI]MFGLIN &
&                        J<>NOL
                          NEWMAXQTY-=[M:MBI]CPLQTY(J)
                       Endif
                    Next J
                  Endif
                Endif
    When Default :
Endcase

nolign=SVGNOL
Return




$CTL_QTY
#---------------------------------------------------------------#
# Message si la quantité est supérieure au reste à produire     #
# NOL doit contenir le numéro de ligne à traiter                #
#---------------------------------------------------------------#
If dim(NEWMAXQTY)<0 : Local Decimal NEWMAXQTY : Endif
OK=2
Raz GERR
Case GFONC1
    When "GESMTK" :
                    If [M:MTK2]MFGNUMIT(NOL)<>""
                       If NEWMAXQTY<0
                            Call OUINON ([F:MFI]MFGNUM-[F:MFI]ITMREF+"\"+mess(54,190,1),OK) From GESECRAN
                            If OK<>2 : mkstat = 1 : Return : Endif
                       Endif
                    Endif
    When "FUNBENCHO","FUNBENCHI","FUNBENPLT" :
                    If [M:MBI]PRODTYP(NOL)=1
                       If NEWMAXQTY<0
                            Call OUINON ([F:MFI]MFGNUM-[F:MFI]ITMREF+"\"+mess(54,190,1),OK) From GESECRAN
                            If OK<>2 : mkstat = 1 : Return : Endif
                       Endif
                    Endif
Endcase
Return



###########################################################
$CTL_QTELOT
# En réintégration ,si article géré en lot, il nous reste à contrôler que la quantité saisie
# dans le moteur d'entrée n'est pas supérieure à ce que l'on avait sorti sur ce lot
# les autres contrôles (lot/sous-lot et série effectivement sortis précédemment) ont déjà été fait dans le moteur
# pour la ligne document en cours de traitement :
# boucler sur les lignes du STOENT  et contrôler que la qté pour le lot saisi est correcte
Local Integer I,J,K,OK
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Decimal WQTYSTUACT
Local Decimal WPOT
OK = 1
Raz WSLO
For I = 0 To [M:ENT]NBLIG-1
    If I = 0
       WLOT = [M:ENT]LOTAFF(I)
       K = 0
       K = find(WLOT,[M:ENT]LOT(0..[M:ENT]NBLIGLOT-1))
       If K : WPOT = [M:ENT]POT(K-1)
       Else : WPOT = 100
       Endif
       If dim([M:ENT]SAIACTFLG)>0 & [M:ENT]SAIACTFLG=2
           WQTYSTUACT = [M:ENT]QTYSTU(I)
       Else
           WQTYSTUACT = [M:ENT]QTYSTU(I) * WPOT/100
       Endif
       If dim([M:ENT]SLOAFF)>0
          WSLO = [M:ENT]SLOAFF(I)
       Endif
    Else
       If ([M:ENT]LOTAFF(I) <> WLOT | (dim([M:ENT]SLOAFF)>0 & [M:ENT]SLOAFF(I) <> WSLO))
            For J = 0 To [M:MKL]NBLIG-1
                If [M:MKL]WLINUM(J) = [M:MBR]WLINUM(NOL)
                   If [M:MKL]LOT(J) = WLOT  & [M:MKL]SLO(J) = WSLO
                      If WQTYSTUACT   > [M:MKL]QTYSTUACT(J) : OK = 0 : Break 2: Endif
                      WLOT       = [M:ENT]LOTAFF(I)
                      If dim([M:ENT]SLOAFF)>0
                          WSLO   = [M:ENT]SLOAFF(I)
                      Endif
                      K = 0
                      K = find(WLOT,[M:ENT]LOT(0..[M:ENT]NBLIGLOT-1))
                      If K : WPOT = [M:ENT]POT(K-1)
                      Else : WPOT = 100
                      Endif
                      If dim([M:ENT]SAIACTFLG)>0 & [M:ENT]SAIACTFLG=2
                         WQTYSTUACT = [M:ENT]QTYSTU(I)
                      Else
                         WQTYSTUACT = [M:ENT]QTYSTU(I) * WPOT/100
                      Endif
                      Break
                   Endif
                Endif
            Next
       Else
         If dim([M:ENT]SAIACTFLG)>0 & [M:ENT]SAIACTFLG=2
               WQTYSTUACT += [M:ENT]QTYSTU(I)
         Else
               WQTYSTUACT += [M:ENT]QTYSTU(I) * WPOT/100
         Endif
       Endif
    Endif
Next

#pour le dernier
If OK = 1 & WQTYSTUACT <> 0
   For J = 0 To [M:MKL]NBLIG-1
                If [M:MKL]WLINUM(J) = [M:MBR]WLINUM(NOL)
                   If  [M:MKL]LOT(J) = WLOT  & [M:MKL]SLO(J) = WSLO
                     # FQ 63764 GA 04/2010 ATTENTION: [M:MKL]QTYSTUACT(J) est parfois < 0 ou > 0
                     # If WQTYSTUACT    > [M:MKL]QTYSTUACT(J) : OK = 0 : Break : Endif
                       If abs(WQTYSTUACT) > abs([M:MKL]QTYSTUACT(J)) : OK = 0 : Break : Endif
                       Break
                  Endif
                Endif
   Next
Endif


#si OK = 0 c'est qu'on a un problème...
If OK = 0 : Call ERREUR (mess(216,193,1)- ":" - WLOT - "/" - WSLO) From GESECRAN : mkstat = 1 : Return : Endif
Return

###########################################################
$CTL_SERNUM
# En réintégration ,si article géré en serie, les numéros de série doivent être renseignés
Local Integer I,J,OK
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
OK = 1
For I = 0 To [M:ENT]NBLIG-1
       If [M:ENT]SERNUM(I) = ""
           Call ERREUR (mess(93,182,1)) From GESECRAN : mkstat = 1
           Break
       Endif
Next
Return




###########################################################
$DEL_QLYWRK
Call DEBTRANS From GLOCK
If clalev ([F:QLW]) <= 0 : Local File QLYWRK [QLW] : Endif
Trbegin [QLW]
Delete [F:QLW] Where PRONUM = adxuid(1)
If fstat : Rollback : Else : Commit : Endif
Return


#########################################################################
# gestion tunnels réception vers plans production/consommation
# initialisation des boutons (appelé en IB_NBLIG de SUBPTH)
$INIT_BGP
# Issue X3-110615 - 2018-09-28 by JUSYN : Return to former solution. NCSBOUT if NCS active
# Issue X3-84473 - 2018-06-26 by ALSHE : Redefine button 13 if NCS is active to create Non-conformance
# If GREP <> "" : Raz GBOUT13, GBOUT14 : Return  : Endif
If GREP <> ""                              : Raz GBOUT13, GBOUT14 : Endif
If [F:ITM]SCSFLG <> 2 & [F:ITM]SCPFLG <> 2 : Raz GBOUT13, GBOUT14 : Endif # GA 06/2006
#If GMODU(8) <> 2                          : Raz GBOUT13, GBOUT14  : Return : Endif # GA 06/2006

If GMODU(8)=2 # FQ 77213 GA 10/2011 ssi module GPAO

    If clalev([F:MTK]) = 0 Local File MFGHEADTRK   [MTK] : Endif
    If clalev([F:MFG]) = 0 Local File MFGHEAD      [MFG] : Endif

    # lecture suivi pour récupérer n° OF
    Readlock [F:MTK]MTK2 = [M:PTH0]PTHNUM;[M:PTH1]PTDLIN(nolign-1)
    If fstat = 5 : Raz GBOUT13, GBOUT14 : Endif

    # lecture OF, test statut clos
    Read [MFG]MFG0=[F:MTK]MFGNUM
    If fstat : Raz GBOUT13, GBOUT14 : Endif

    If [F:MFG]MFGSTA = 4 : Raz GBOUT13, GBOUT14 : Return : Endif
Endif
Gosub NCSBOUT

Return

#########################################################################
# renamed RAZBOUT to NCSBOUT
# Issue X3-84473 - 2018-06-26 by ALSHE : Redefine button 13 if NCS is active to create Non-conformance
$NCSBOUT
    # Issue X3-102712 - Disable Non-conformance create button in Create/Amend mode
    If func AFNC.ACTIV("NCS") and !find (GREP, "C","D","M","A")
        GBOUT13=mess(508,198,1) # Create Non-conformance
        Raz GBOUT14
    Endif
Return
# End issue X3-110615
#########################################################################
# gestion tunnels réception vers plans production/consommation
$AB13_BGP
Local Char    WCLE1 (GLONVCR)
Local Integer WRET
If clalev([F:MTK]) = 0 Local File MFGHEADTRK   [MTK] : Endif
# lecture suivi pour récupérer n° OF
Readlock [F:MTK]MTK2 = [M:PTH0]PTHNUM;[M:PTH1]PTDLIN(nolign-1)
If fstat = 5 : Return : Endif

WCLE1 = [F:MTK]MFGNUM
WRET  = 0
Return


##############################################################################
# Vérifications - si des qés sont allouées ou des numéros de série sortis    #
#               - si le stock est là                                         #
# -------------------------------------------------------------------------- #
# En entrée :                                                                #
#  GMESSAGE : Renseigné si erreur autrement vide                             #
#----------------------------------------------------------------------------#
$VERIF_QTEALL
#----- Déclaration des variables nécessaires au calcul -----#
If dim(WNBR_STOCOU)<0   Local Shortint WNBR_STOCOU      : Endif
If dim(WTAB_STOCOU)<0   Local Decimal  WTAB_STOCOU(100) : Endif
If dim(WTAB_STOQTY)<0   Local Decimal  WTAB_STOQTY(100) : Endif
If dim(WCUM_STJQTYA)<0  Local Decimal  WCUM_STJQTYA     : Endif
If dim(WCUM_STJQTYQ)<0  Local Decimal  WCUM_STJQTYQ     : Endif
If dim(WCUM_STJQTYR)<0  Local Decimal  WCUM_STJQTYR     : Endif
If dim(WSTOCOU)<0       Local Decimal  WSTOCOU          : Endif
If dim(WSTUDIS)<0       Local Decimal  WSTUDIS          : Endif
If dim(WSTUDISTOT)<0    Local Decimal  WSTUDISTOT       : Endif
If dim(WPLF)<0          Local Libelle  WPLF             : Endif
If dim(WSCO)<0          Local Libelle  WSCO             : Endif
If dim(WLOCTYP)<0       Local Integer  WLOCTYP          : Endif
Local Integer WSTA
Local Decimal WDISA, WDISQ, WDISR, WDIS
Local Decimal WCUM, WGLOALL

#-----
Raz GMESSAGE
For [MKI] MKI0 Where MFGTRKNUM=[F:MTK]MFGTRKNUM
    If [F:MKI]FMI <> 5 : Gosub VERIF_LINQTEALL : Endif          # 68911
    If GMESSAGE<>""  Break : Endif
Next
Return

############################
# Vérification d'une ligne #
#--------------------------#
$VERIF_LINQTEALL

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif


#----- Lecture article, catégorie, cumuls article-site si nécessaire -----#
If [F:ITM]ITMREF<>[F:MKI]ITMREF
  Read [ITM] ITM0=[F:MKI]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif

If [F:ITM]STOMGTCOD<2  Return : Endif : # Si article non géré en stock, c'est fini !

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:MKI]MFGFCY | [F:ITF]ITMREF <> [F:MKI]ITMREF
   Read [ITF]ITF0 = [F:MKI]ITMREF;[F:MKI]MFGFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITF]STOMGTCOD<2  Return : Endif : # Si article non géré en stock, c'est fini !

If [F:ITG]STOFCY<>[F:MKI]MFGFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
  Read [ITG] ITG0=[F:MKI]MFGFCY;[F:ITM]TCLCOD
  If fstat
    Read [ITG] ITG1=[F:ITM]TCLCOD;"" : If fstat  Raz [F:ITG] : Endif
  Endif
Endif
If [F:ITG]TCLCOD=""  Return : Endif : # Si catégorie article non trouvée, c'est fini !
If [F:ITV]ITMREF<>[F:MKI]ITMREF | [F:ITV]STOFCY<>[F:MKI]MFGFCY
  Read [ITV] ITV0=[F:MKI]ITMREF;[F:MKI]MFGFCY : If fstat  Raz [F:ITV] : Endif
Endif
#-----
Raz WTAB_STOCOU,    WNBR_STOCOU,    WTAB_STOQTY
Raz WCUM_STJQTYA
Raz WCUM_STJQTYQ
Raz WCUM_STJQTYR
Raz WPLF, WSCO, WLOCTYP
Raz WSTUDIS, WSTUDISTOT
#----- Rep
For [STJ] STJ1 Where STOFCY=[F:MKI]MFGFCY
&                  & VCRTYP=15
&                  & VCRNUM=[F:MKI]MFGTRKNUM
&                  & VCRLIN=[F:MKI]ITMTRKLIN
&                  & REGFLG<>2
  Case left$([F:STJ]STA,1)
    When "A" : WCUM_STJQTYA+=[F:STJ]QTYSTU
    When "Q" : WCUM_STJQTYQ+=[F:STJ]QTYSTU
    When "R" : WCUM_STJQTYR+=[F:STJ]QTYSTU
  Endcase
  #--- Issue X3-53322 : ajout LPN
  Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&             [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&             [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&             [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
  If WSTOCOU<>0
    If WNBR_STOCOU=0
      WTAB_STOCOU(0)=WSTOCOU
      WTAB_STOQTY(0)=[F:STJ]QTYSTU
      WNBR_STOCOU+=1
    Else I=find(WSTOCOU,WTAB_STOCOU(0..WNBR_STOCOU-1))
      If I=0
        WTAB_STOCOU(WNBR_STOCOU)=WSTOCOU
        WTAB_STOQTY(WNBR_STOCOU)=[F:STJ]QTYSTU
        WNBR_STOCOU+=1
      Else
        WTAB_STOQTY(I-1)+=[F:STJ]QTYSTU
      Endif
    Endif
    If WNBR_STOCOU>=dim(WTAB_STOCOU)-1  Break : Endif : # Par sécurité, ne devrait jamais arriver !
  Endif
Next
For I=0 To WNBR_STOCOU-1
  Read [STO] STO0=[F:MKI]MFGFCY;WTAB_STOCOU(I)
  If !fstat
    #----- Disponible sur la ligne de stock
    Call STODIS("[F:STO]","[F:ITM]","",GBIDD1,WSTUDIS,GBIDD3) From STKLIB
    If WTAB_STOQTY(I)>WSTUDIS
       Gosub CHARG_ERR2 : Break
    Endif
    #-----
    Case [F:STO]LOCCAT
      When  2  : WPLF=1  : # stock à quai
      When  4  : WSCO=1  : # stock chez sous-traitance
    Endcase
  Endif
Next I
If GMESSAGE<>"" : Return : Endif

#----- Contrôle stock en global en fonction statut et emplacement -----#
If WPLF=1  WLOCTYP+=1 : Endif
If WSCO=1  WLOCTYP+=4 : Endif

If WCUM_STJQTYA>0 WSTA+=1 Endif
If WCUM_STJQTYQ>0 WSTA+=2 Endif
If WCUM_STJQTYR>0 WSTA+=4 Endif

Call STODISMOD("",WLOCTYP,WSTA,"",WDISA,WDISQ,WDISR,WGLOALL) From STKLIB

#----- Contrôle par statut -----#
If WCUM_STJQTYA>WDISA | WCUM_STJQTYQ>WDISQ | WCUM_STJQTYR>WDISR
  Gosub CHARG_ERR2 : Return
Endif

#----- Contrôle avec prise en compte alloué global -----#
If WGLOALL<>0
  If [F:ITG]GLOAAAFLG=2
     WDIS+=WDISA
     WCUM+=WCUM_STJQTYA
  Endif
  If [F:ITG]GLOQQQFLG=2
     WDIS+=WDISQ
     WCUM+=WCUM_STJQTYQ
  Endif
  If [F:ITG]GLORRRFLG=2
     WDIS+=WDISR
     WCUM+=WCUM_STJQTYR
  Endif
  If WCUM > WDIS-WGLOALL
    Gosub CHARG_ERR2 : Return
  Endif
Endif

Return

#----------------------------------------------------------#
# FQ 64125 GA 05/2010
# Contrôle présence d'une fiche technique selon GCTLFICTEC
#----------------------------------------------------------#
$CTL_TECCRD
GPE = 0 : GPOINT = "CTLFICTEC" : Gosub ENTREE From EXEFNC
#Controle fiche technique renseignée - 57910 mm 12.09
# FQ 64125 GA 05/2010 le blocage GCTLFICTEC doit intervenir
#                     1) si et seulement si TECCRD renseigné sur l'opération
#                     2) si aucune réponse n'a été enregistrée dans
#If [F:MFO]TECCRD = "" & GCTLFICTEC <> 1
If [F:MFO]TECCRD <> "" & GCTLFICTEC <> 1 & !GPE
  If clalev([F:QLW])<= 0 : Local File QLYWRK [QLW] : Endif
  Filter [F:QLW] Where PRONUM = adxuid(1) & LINNUM = WLIN & VCRTYP = 12
  Look [F:QLW]QLW0 First
  If !fstat : Filter [F:QLW]: Return : Endif # Ok si des réponses sont présentes

  WOK = 0
  If GCTLFICTEC = 2
   # FQ 63365 GA 03/2010 afficher l'info dans la trace (idem erreurs sur les composants stock)
   # Paramètre
    Call ECR_TRACE(mess(143,105,1)-"CTLFICTEC:"-mess(23,190,1)- num$([F:MFO]OPENUM),0)From GESECRAN
   #
    Call AVERTIR (mess(23,190,1)-num$([F:MFO]OPENUM), WOK)From GESECRAN
    If WOK <> 2 : LRET = 1 : End : Endif
  Elsif  GCTLFICTEC = 3
   # FQ 63365 GA 03/2010 afficher l'erreur dans la trace (idem erreurs sur les composants stock)
    Call ECR_TRACE(mess(143,105,1)-"CTLFICTEC:"-mess(23,190,1)- num$([F:MFO]OPENUM)- "." - mess(249,190,1),1)From GESECRAN
   #
    Call ERREUR(mess(23,190,1)- num$([F:MFO]OPENUM)- "." - mess(249,190,1))From GESECRAN
    LRET = 1 : End
  Endif
  Filter [F:QLW]  # FQ 77545 GA 11/2011 ajout de la Raz
Endif
Return

#----------------------------------------------------------#
# FQ 64125 GA 05/2010
# Réponses fiche technique copiées dans le suivi MTKCRDASW
#----------------------------------------------------------#
$UPD_TECCRD
If [F:MFO]TECCRD <> ""
    If clalev([F:QLW])<= 0 : Local File QLYWRK [QLW] : Endif
    If clalev([F:MTA])<= 0 : Local File MTKCRDASW [MTA] : Endif
    Filter [F:QLW] Where PRONUM = adxuid(1) & LINNUM = WLIN & VCRTYP = 12
    Look [F:QLW]QLW0 First
    If fstat : Filter [F:QLW]: Return : Endif
    For [F:QLW]
        Raz [F:MTA]
            [F:MTA]= [F:QLW]
            [F:MTA]MFGTRKNUM = [F:MKO]MFGTRKNUM
            [F:MTA]OPETRKLIN = [F:MKO]OPETRKLIN
            [F:MTA]OPENUM    = [F:MKO]OPENUM
            [F:MTA]MFGNUM    = [F:MKO]MFGNUM
            [F:MTA]EXPNUM    = [C]EXPORT
            # Issue 83469 GA 08/2012
            GPOINT = "BEFWRIMTA" : Gosub ENTREE From EXEFNC
            Write [F:MTA]
            If fstat
               GOK = 0 : Call FSTA("MTA") From GLOCK : Break
            Endif
    Next
    Filter [F:QLW]
    Delete [F:QLW] Where PRONUM = adxuid(1) & LINNUM = WLIN
    If GOK = 0 : GLOCK = "$"+"QLYWRK" : Endif
Endif
Return

#----------------------------------------------------------#
# Stock disponible insuffisant : suppression  impossible ! #
#----------------------------------------------------------#
$CHARG_ERR2
GMESSAGE=[F:MKI]MFGTRKNUM-[F:MKI]ITMREF-mess(817,196,1)
Return

