#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCAUSAPP_RSTD, Approvers

#####################
# METHODS           #
#####################
$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
  Endcase
Return

# --------------------------------------------------
# Add filter to Users [AUS] to return Approvers.
$AQUERY_CRITERIA_AFTER

  Local Integer APPROVER_COUNT
  Local Char CCMAPPROVE(30)
  Local Char APPROVER(10)(1..)
  Local Integer I

  If (clalev([AUS]) = 0) : Local File AUTILIS [AUS] : Endif

  # Build array (APPROVER) of Approver users ...
  APPROVER_COUNT = 0
  For [AUS] Where ENAFLG = 2
    Call PARAMUTIL("CCMAPPROVE", CCMAPPROVE, [F:AUS]USR, "") From SUBAUS
    If (CCMAPPROVE = "2")
      APPROVER_COUNT += 1
      APPROVER(APPROVER_COUNT) = [F:AUS]USR
    Endif
  Next

  # Build 'where clause' (PQRY.QWHERE) from array (above) ...
  If (APPROVER_COUNT = 0)
    If (PQRY.QWHERE <> "")
      PQRY.QWHERE = "(" +PQRY.QWHERE +") and 1 eq 0"
    Else
      PQRY.QWHERE = "1 eq 0"
    Endif
  Else
    For I = 1 To APPROVER_COUNT
      If (I = 1)
        If (PQRY.QWHERE <> "")
          PQRY.QWHERE = "(" +PQRY.QWHERE +") and USR in ('" +APPROVER(1) +"'"
        Else
          PQRY.QWHERE = "USR in ('" +APPROVER(1) +"'"
        Endif
      Else
        PQRY.QWHERE = PQRY.QWHERE +", '"+APPROVER(I)+"'"
      Endif
    Next I
    PQRY.QWHERE = PQRY.QWHERE +")"
  Endif

Return

# --------------------------------------------------
# Populate role and department.
$AQUERY_TRANS_AFTER

  Local Char ROLE(30), DEPT(30)

  Call PARAMUTIL("CCMROLE", ROLE, this.AUS.USR, "") From SUBAUS
  Call PARAMUTIL("CCMDEPT", DEPT, this.AUS.USR, "") From SUBAUS
  If (ROLE <> "" & ROLE <> "1")
    this.ROLE = mess(val(ROLE), 2036, 1)
  Else
    this.ROLE = ""
  Endif
  If (DEPT <> "" & DEPT <> "1")
    this.DEPARTMENT = mess(val(DEPT), 2037, 1)
  Else
    this.DEPARTMENT = ""
  Endif

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


