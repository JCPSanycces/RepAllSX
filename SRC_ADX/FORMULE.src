#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char FORMULE(250)
Local Char FILTAB(10)(1..3)
Local Char TEXCON(50)
Local Char VARSUP(10)(1..10)
FILTAB(1) = "GACCENTRY"
Call B1_FORMUL(FORMULE,FILTAB,TEXCON,VARSUP)
End

Subprog C_FORMULE(VALEUR)
Variable Char VALEUR()
Local Integer E
If VALEUR="" : End : Endif
E = parse(VALEUR)
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(E)
# Expression incorrecte
 mkstat = 2
Endif
End

######################################################################
Subprog AS_FORMULE
GBOUT1 = mess(27,126,1) : # Editeur formule
GFRMNB = 0
End
######################################################################
Subprog B2_FORMULE(VALEUR)
Variable Char VALEUR()
Call SELECT(VALEUR,1)
End
######################################################################
Subprog B3_FORMULE(VALEUR)
Variable Char VALEUR()
Call SELECT(VALEUR,2)
End
######################################################################
Subprog B4_FORMULE(VALEUR)
Variable Char VALEUR()
Call SELECT(VALEUR,3)
End
######################################################################
# Btn spécial pour accéder aux tables via un filtre passé en paramètre
# dans la table des formules (Environnt-- Param gén) T. Blanc 02/04/98
######################################################################
Subprog B4_FORMFLT(VALEUR,FILTAB)
Variable Char VALEUR()
Value    Char FILTAB()

Local Char    TEX(50)(200) , OPE(30)(200)
Local Char    ZONE(50) , CLE(20)
Local Char    ABREV(5) , FICHIER(10) , VARIA(30)
Local Integer NBTEX , CHOI , POS , VIRGULE
Local Integer I , J , K

ZONE = ""
Gosub VARIAFLT
If ZONE<>""
 VALEUR = vireblc(format$("KT:200X","("+VALEUR+")"),2)
 VALEUR = seg$(VALEUR,2,len(VALEUR)-1)
 VALEUR = VALEUR+ZONE
Endif
mkstat = 2
End

$VARIAFLT
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = mess(41,124,1) : # Champs d'une table
NBTEX += 1 : TEX(NBTEX) = mess(42,124,1) : # Variables système
CHOI = 1
Call SAITEX(NBTEX,TEX,CHOI,mess(40,124,1)) From GESECRAN
# Variables
If status<>7 & CHOI<>0
 Case CHOI
  When 1 : Gosub VARFLT
  When 2 : Gosub VARSYS
 Endcase
Endif
Return

$VARFLT
ABREV = "" : FICHIER = ""
# ouverture préalable du dico avec filtre
If FILTAB <> ""
   Local File ATABLE [ATB] Where evalue(FILTAB)
Else
   Local File ATABLE [ATB]
Endif
Call SELVAR(FICHIER,ABREV,VARIA) From SELFIC
If VARIA<>""
 ZONE = "[F:"+ABREV+"]"+VARIA
Endif
Return
######################################################################
Subprog SELECTAB(TABLE,VALEUR,TYP)
Value    Char    TABLE
Variable Char    VALEUR()
Value    Integer TYP
Goto SELECTION
######################################################################
Subprog SELECT(VALEUR,TYP)
Variable Char    VALEUR()
Value    Integer TYP
Local Char TABLE(10)

$SELECTION
Local Char    TEX(50)(200) , OPE(30)(200)
Local Char    ZONE(50) , CLE(20)
Local Char    ABREV(5) , FICHIER(10) , VARIA(30)
Local Integer NBTEX , CHOI , POS , VIRGULE
Local Integer I , J , K

ZONE = ""
Case TYP
 When 1 : Gosub OPERATEUR
 When 2 : Gosub FONCTION
 When 3 : Gosub VARIA
Endcase
If ZONE<>""
 VALEUR = vireblc(format$("KT:200X","("+VALEUR+")"),2)
 VALEUR = seg$(VALEUR,2,len(VALEUR)-1)
 VALEUR = VALEUR+ZONE
Endif
mkstat = 2
End

$OPERATEUR
NBTEX = 0
NBTEX += 1 : OPE(NBTEX) = "+"   : TEX(NBTEX) = mess(43,124,1)
# Addition
NBTEX += 1 : OPE(NBTEX) = "-"   : TEX(NBTEX) = mess(44,124,1)
# Soustraction
NBTEX += 1 : OPE(NBTEX) = "*"   : TEX(NBTEX) = mess(45,124,1)
# Multiplication
NBTEX += 1 : OPE(NBTEX) = "/"   : TEX(NBTEX) = mess(46,124,1)
# Division
NBTEX += 1 : OPE(NBTEX) = "^"   : TEX(NBTEX) = mess(47,124,1)
# Puissance
NBTEX += 1 : OPE(NBTEX) = "="   : TEX(NBTEX) = mess(48,124,1)
# Egal
NBTEX += 1 : OPE(NBTEX) = "<>"  : TEX(NBTEX) = mess(49,124,1)
# Différent
NBTEX += 1 : OPE(NBTEX) = "<"   : TEX(NBTEX) = mess(50,124,1)
# Inférieur
NBTEX += 1 : OPE(NBTEX) = "<="  : TEX(NBTEX) = mess(51,124,1)
# Inférieur ou égal
NBTEX += 1 : OPE(NBTEX) = ">"   : TEX(NBTEX) = mess(52,124,1)
# Supérieur
NBTEX += 1 : OPE(NBTEX) = ">="  : TEX(NBTEX) = mess(53,124,1)
# Supérieur ou égal
NBTEX += 1 : OPE(NBTEX) = "&"   : TEX(NBTEX) = mess(54,124,1)
# Et
NBTEX += 1 : OPE(NBTEX) = "|"   : TEX(NBTEX) = mess(55,124,1)
# Ou
NBTEX += 1 : OPE(NBTEX) = "!"   : TEX(NBTEX) = mess(104,124,1)
# Non
NBTEX += 1 : OPE(NBTEX) = "?"   : TEX(NBTEX) = mess(56,124,1)
# Ou exclusif
For I=1 To NBTEX
 TEX(I) = format$("K:4X",OPE(I))+TEX(I)
Next I
CHOI = 1
Call SAITEX(NBTEX,TEX,CHOI,mess(38,124,1)) From GESECRAN
# Opérateurs
If status<>7 & CHOI<>0
 ZONE = OPE(CHOI)
Endif
Return

$FONCTION
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = mess(57,124,1) : # Toutes fonctions
NBTEX += 1 : TEX(NBTEX) = mess(58,124,1) : # Arithmétiques
NBTEX += 1 : TEX(NBTEX) = mess(59,124,1) : # Chaînes
NBTEX += 1 : TEX(NBTEX) = mess(60,124,1) : # Date
NBTEX += 1 : TEX(NBTEX) = mess(61,124,1) : # Divers
CHOI = 1
Call SAITEX(NBTEX,TEX,CHOI,mess(62,124,1)) From GESECRAN
# Type de fonction
If status<>7 & CHOI<>0
 Case CHOI
  When 1 : TYP = 0 : Gosub CHARGE_FONC
  When 2 : TYP = 1 : Gosub CHARGE_FONC
  When 3 : TYP = 2 : Gosub CHARGE_FONC
  When 4 : TYP = 3 : Gosub CHARGE_FONC
  When 5 : TYP = 4 : Gosub CHARGE_FONC
 Endcase
 CHOI = 1
$SELFONC
 Selbox TEX(1..NBTEX) Titled mess(105,124,1) Using CHOI
 If status<>7 & CHOI<>0
  ZONE = OPE(CHOI)
 Endif
Endif
Return

$CHARGE_FONC
NBTEX = 0
If TYP=0 | TYP=1
 NBTEX += 1 : OPE(NBTEX) = "abs()"    : TEX(NBTEX) = mess(63,124,1)
# Valeur absolue
 NBTEX += 1 : OPE(NBTEX) = "mod()"    : TEX(NBTEX) = mess(64,124,1)
# Reste divison entière
 NBTEX += 1 : OPE(NBTEX) = "rnd()"    : TEX(NBTEX) = mess(65,124,1)
# Nombre au hasard
 NBTEX += 1 : OPE(NBTEX) = "sgn()"    : TEX(NBTEX) = mess(66,124,1)
# Signe
 NBTEX += 1 : OPE(NBTEX) = "sqr()"    : TEX(NBTEX) = mess(67,124,1)
# Racine carrée
 NBTEX += 1 : OPE(NBTEX) = "arr(,)"   : TEX(NBTEX) = mess(68,124,1)
# Arrondi
 NBTEX += 1 : OPE(NBTEX) = "ar2()"    : TEX(NBTEX) = mess(69,124,1)
# Arrondi 2 décimales
 NBTEX += 1 : OPE(NBTEX) = "int()"    : TEX(NBTEX) = mess(70,124,1)
# Partie entière
 NBTEX += 1 : OPE(NBTEX) = "fix()"    : TEX(NBTEX) = mess(71,124,1)
# Troncature
 NBTEX += 1 : OPE(NBTEX) = "avg()"    : TEX(NBTEX) = mess(72,124,1)
# Moyenne
 NBTEX += 1 : OPE(NBTEX) = "sum()"    : TEX(NBTEX) = mess(73,124,1)
# Somme
 NBTEX += 1 : OPE(NBTEX) = "max()"    : TEX(NBTEX) = mess(74,124,1)
# Maximum
 NBTEX += 1 : OPE(NBTEX) = "min()"    : TEX(NBTEX) = mess(75,124,1)
# Minimum
Endif
If TYP=0 | TYP=2
 NBTEX += 1 : OPE(NBTEX) = "left$(,)" : TEX(NBTEX) = mess(76,124,1)
# Partie gauche
 NBTEX += 1 : OPE(NBTEX) = "right$(,)": TEX(NBTEX) = mess(77,124,1)
# Partie droite
 NBTEX += 1 : OPE(NBTEX) = "mid$(,,)" : TEX(NBTEX) = mess(78,124,1)
# Sous-chaîne
 NBTEX += 1 : OPE(NBTEX) = "tolower()": TEX(NBTEX) = mess(79,124,1)
# Mise en minuscules
 NBTEX += 1 : OPE(NBTEX) = "toupper()": TEX(NBTEX) = mess(80,124,1)
# Mise en majuscules
 NBTEX += 1 : OPE(NBTEX) = "len()"    : TEX(NBTEX) = mess(81,124,1)
# Longueur
 NBTEX += 1 : OPE(NBTEX) = "val()"    : TEX(NBTEX) = mess(82,124,1)
# Valeur
 NBTEX += 1 : OPE(NBTEX) = "num$()"   : TEX(NBTEX) = mess(83,124,1)
# Transformation en chaîne
Endif
If TYP=0 | TYP=3
 NBTEX += 1 : OPE(NBTEX) = "day()"    : TEX(NBTEX) = mess(84,124,1)
# Jour (1..31)
 NBTEX += 1 : OPE(NBTEX) = "dayn()"   : TEX(NBTEX) = mess(85,124,1)
# Jour (1..7)
 NBTEX += 1 : OPE(NBTEX) = "day$()"   : TEX(NBTEX) = mess(86,124,1)
# Jour (alpha)
 NBTEX += 1 : OPE(NBTEX) = "month()"  : TEX(NBTEX) = mess(87,124,1)
# Mois (1..12)
 NBTEX += 1 : OPE(NBTEX) = "month$()" : TEX(NBTEX) = mess(88,124,1)
# Mois (alpha)
 NBTEX += 1 : OPE(NBTEX) = "week()"   : TEX(NBTEX) = mess(89,124,1)
# Semaine (1..53)
 NBTEX += 1 : OPE(NBTEX) = "year()"   : TEX(NBTEX) = mess(90,124,1)
# Année
 NBTEX += 1 : OPE(NBTEX) = "addmonth(,)"  : TEX(NBTEX) = mess(91,124,1)
# Ajout nombre de mois
 NBTEX += 1 : OPE(NBTEX) = "eomonth()"    : TEX(NBTEX) = mess(92,124,1)
# Fin de mois
 NBTEX += 1 : OPE(NBTEX) = "gdat$(,,)"    : TEX(NBTEX) = mess(93,124,1)
# Construction d'une date
Endif
If TYP=0 | TYP=4
 NBTEX += 1 : OPE(NBTEX) = "format$(,)"  : TEX(NBTEX) = mess(94,124,1)
# Formattage
 NBTEX += 1 : OPE(NBTEX) = "instr(,,)"   : TEX(NBTEX) = mess(95,124,1)
# Recherche sous-chaîne
 NBTEX += 1 : OPE(NBTEX) = "find(,)"     : TEX(NBTEX) = mess(96,124,1)
# Recherche valeur
 NBTEX += 1 : OPE(NBTEX) = "space$()"    : TEX(NBTEX) = mess(97,124,1)
# Chaîne d'espaces
 NBTEX += 1 : OPE(NBTEX) = "string$(,)"  : TEX(NBTEX) = mess(98,124,1)
# Répétition chaîne
 NBTEX += 1 : OPE(NBTEX) = "vireblc(,)"  : TEX(NBTEX) = mess(107,124,1)
# Suppression d'espaces
 NBTEX += 1 : OPE(NBTEX) = "pat(,)"      : TEX(NBTEX) = mess(99,124,1)
# Conformité à un modèle
Endif
For I=1 To NBTEX
 TEX(I) = format$("K:15X",OPE(I))+TEX(I)
Next I
Sorta NBTEX+1 TEX , OPE
Return

$VARIA
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = mess(41,124,1) : # Champs d'une table
NBTEX += 1 : TEX(NBTEX) = mess(42,124,1) : # Variables système
CHOI = 1
Call SAITEX(NBTEX,TEX,CHOI,mess(40,124,1)) From GESECRAN
# Variables
If status<>7 & CHOI<>0
 Case CHOI
  When 1 : Gosub VARTAB
  When 2 : Gosub VARSYS
 Endcase
Endif
Return
############################################################
$VARSYS
Gosub DEFVARSYS
For I=1 To NBTEX
 TEX(I) = format$("K:15X",OPE(I))+TEX(I)
Next I
CHOI = 1
Call SAITEX(NBTEX,TEX,CHOI,mess(40,124,1)) From GESECRAN
# Variables
If status<>7 & CHOI<>0
 ZONE = OPE(CHOI)
Endif
Return
############################################################
$DEFVARSYS
NBTEX = 0
NBTEX += 1 : OPE(NBTEX) = "date$"       : TEX(NBTEX) = mess(100,124,1)
# Date du jour
NBTEX += 1 : OPE(NBTEX) = "time$"       : TEX(NBTEX) = mess(101,124,1)
# Heure courante
NBTEX += 1 : OPE(NBTEX) = "datesyst"    : TEX(NBTEX) = mess(102,124,1)
# Date système
NBTEX += 1 : OPE(NBTEX) = "GUSER"       : TEX(NBTEX) = mess(103,124,1)
# Code utilisateur
NBTEX += 1 : OPE(NBTEX) = "GNOMUSER"    : TEX(NBTEX) = mess(175,124,1)
# Nom utilisateur
NBTEX += 1 : OPE(NBTEX) = "GLANGUE"     : TEX(NBTEX) = mess(176,124,1)
# Langue courante
NBTEX += 1 : OPE(NBTEX) = "GLANDEF"     : TEX(NBTEX) = mess(177,124,1)
# Langue par défaut
NBTEX += 1 : OPE(NBTEX) = "GSYSCUR"     : TEX(NBTEX) = mess(178,124,1)
# Devise de reporting
NBTEX += 1 : OPE(NBTEX) = "GFCYDEF"     : TEX(NBTEX) = mess(179,124,1)
# Site par défaut
NBTEX += 1 : OPE(NBTEX) = "GDEFSOC"     : TEX(NBTEX) = mess(180,124,1)
# Société par défaut
NBTEX += 1 : OPE(NBTEX) = "GBANDEF"     : TEX(NBTEX) = mess(181,124,1)
# Banque par défaut
NBTEX += 1 : OPE(NBTEX) = "GCSHDEF"     : TEX(NBTEX) = mess(182,124,1)
# Caisse par défaut
NBTEX += 1 : OPE(NBTEX) = "GOPTCANA"    : TEX(NBTEX) = mess(183,124,1)
# Nombre d'axes analytiques
Return
############################################################
# Michel Giet 14/10/99 : Ajout de variables supplémentaires éventuelles
$DEFVARLOC
NBTEX = 0
If dim(WVAT) > 0
  For  I = 0 To dim(WVAT)-1
    If I < dim(OPE)-1 & I < dim(TEX)-1
      NBTEX += 1
      OPE(NBTEX) = WVAS(I)
      TEX(NBTEX) = WVAT(I) 
    Endif 
  Next
Endif
Return
############################################################
$VARTAB
ABREV = "" : FICHIER = TABLE
Call SELVAR(FICHIER,ABREV,VARIA) From SELFIC
If VARIA<>""
 ZONE = "[F:"+ABREV+"]"+VARIA
Endif
Return
############################################################
## Version 120 uniquement
############################################################
Subprog B1_FORMUL(FORMULE,FILTAB,TEXCON,VARSUP)
Variable Char    FORMULE()
Variable Char    FILTAB()
Variable Char    TEXCON()
Variable Char    VARSUP()
#
Local    Char    WFIL(250) 
Local    Integer WCVD, WVAR, I, J, K, L
#
# Création des tables de conversion
WCVD = 0
For I = 0 To dim(TEXCON)-1
  If TEXCON(I) <> ""
    WCVD += 1
  Endif
Next 
#
If WCVD > 0
  Local Char WCVF(10)(WCVD)
  Local Char WCVZ(10)(WCVD)
  Local Char WCVT(50)(WCVD)
  Local Char WCVW(80)
  For I = 0 To WCVD - 1
    WCVW = TEXCON(I)
    J = instr(1,WCVW,",")
    K = instr(J+1,WCVW,",")
    WCVF(I) = seg$(WCVW,1,J-1)
    WCVZ(I) = seg$(WCVW,J+1,K-1)
    WCVT(I) = seg$(WCVW,K+1,len(WCVW))
  Next I
Endif
# Création table variables suplémentaires
WVAR = 0
For I = 0 To dim(VARSUP)-1
  If VARSUP(I) <> ""
    WVAR += 1
  Endif
Next 
#
If WVAR > 0
  Local Char WVAS(50)(WVAR)
  Local Char WVAT(50)(WVAR)
  Local Char WVAW(100)
  For I = 0 To WVAR - 1
    WVAW = VARSUP(I)
    J = instr(1,WVAW,",")
    WVAS(I) = seg$(WVAW,1,J-1)
    WVAT(I) = seg$(WVAW,J+1,len(WVAW))
  Next I
Endif
#
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif


Local Char    TT(10) , TABLE(10)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , SAVFOR(250)
Local Integer I , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL
Local Char    OPE(15)(1..50+WVAR) , TEX(50)(1..50+WVAR)
# Sélection des tables (Filtre si dimension = 1 / Liste si dimension <> 1)
NBTABLE=0
If dim(FILTAB) = 1 & FILTAB <> ""
  Filter [ATB] Where evalue(FILTAB)
&              Order By Key CODFIC
  For [ATB]
    If NBTABLE < dim(TABLE)
      NBTABLE += 1
      TABLE(NBTABLE) = [F:ATB]CODFIC
    Else 
      Break
    Endif
  Next
  Filter [ATB]
Else
  For I = 0 To dim(FILTAB)-1
    If FILTAB(I) <> ""
      Read [ATB]CODFIC=FILTAB(I)
      If fstat=0
        NBTABLE += 1
        TABLE(NBTABLE) = [F:ATB]CODFIC
      Endif
    Endif
  Next I
Endif
SAVFOR = FORMULE
FORMULE = vireblc(format$("KT:200X",FORMULE),2)
Goto DEB_FORMULE

##################################################
## Version 120 uniquement
##################################################
Subprog B1_FORMULE(FORMULE,TABLE1,TABLE2,TABLE3,TABLE4,TABLE5)
Variable Char    FORMULE()
Value    Char    TABLE1
Value    Char    TABLE2
Value    Char    TABLE3
Value    Char    TABLE4
Value    Char    TABLE5

If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:AMK])=0 : Local File AMSK     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif

Local Char    TT(10) , TABLE(15)(1..100)
Local Char    TEXTE(80) , DESIG(80) , CHAMP(80) , SAVFOR(250)
Local Integer E , I , NBTABLE , REPONSE , NBCHAMP , NBTEX , SAVSEL
Local Char    OPE(15)(1..50) , TEX(50)(1..50)

NBTABLE=0
For TT = TABLE1,TABLE2,TABLE3,TABLE4,TABLE5
 If TT<>""
  If left$(TT,3)="[M]"
   Read [AMK]CODMSK = right$(TT,4)
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = TT
   Endif
  Else
   Read [ATB]CODFIC = TT
   If !fstat
    NBTABLE += 1
    TABLE(NBTABLE) = [F:ATB]CODFIC
   Endif
  Endif
 Endif 
Next
SAVFOR = FORMULE
FORMULE = vireblc(format$("KT:250X",FORMULE),2)

$DEB_FORMULE
Formula FORMULE As [AAA_]

Field [AAA_]  5 , "" , "ZZ1" , mess(131,126,1) , "AIDE de la table" , "ZZ1" : # Nouvelle table
Field [AAA_]  5 , "" , "ZZ2" , mess(132,126,1) , "AIDE de la table" , "ZZ2" : # Nouvel écran

NBCHAMP = 0
For I=1 To NBTABLE
 TT = TABLE(I)
 If left$(TT,3)="[M]"
  TT = right$(TT,4) : Gosub MASQUE
 Else
  Gosub TABLE
 Endif
Next I

Gosub DEFVARSYS
Field [AAA_]  1 , "" , "VARIABLE" , mess(86,123,1) , "Aide de la table" , "VARIABLE"
For I=1 To NBTEX
 Field [AAA_]  2 , "VARIABLE" , "VARIABLE."+OPE(I) , TEX(I) , "Aide du champ" , OPE(I)
Next I
# Michel Giet (Variables locales)
If dim(WVAS) > 0
  Gosub DEFVARLOC
  Field [AAA_]  1 , "" , "VARLOC" , mess(212,100,1) , "Aide de la table" , "VARIABLE" 
  For I=1 To NBTEX
    Field [AAA_]  2 , "VARLOC" , "VARLOC."+OPE(I) , TEX(I) , "Aide du champ" , OPE(I)
 Next I
Endif

If dim([V]GFRMNB)>0 & GFRMNB>0
  Field [AAA_]  1 , "" , "VARSUP" , mess(212,100,1) , "Aide de la table" , "VARIABLE" 
  For I=1 To GFRMNB
    Field [AAA_]  2 , "VARSUP" , "VARSUP."+GFRMVAR(I) , GFRMVAR(I)-GFRMLIB(I) , "Aide du champ" , GFRMVAR(I)
 Next I
Endif

Boxact [AAA_]

$SAI
Boxinp [AAA_] Using REPONSE, FORMULE
Case REPONSE
 When 7       : FORMULE = SAVFOR : Goto FIN
 When 46      : Gosub VERIF : If E=0 : Infbox mess(157,100,1) : Endif : # OK
 When 1       : Gosub VERIF: If E=0 : Goto FIN : Else : Goto DEB_FORMULE : Endif
 When 47      : Gosub ADD_OBJET
 When Default : Infbox "REPONSE"-num$(REPONSE)
Endcase
Goto SAI

$FIN
Close Inpbox [AAA_]
End

$ADD_OBJET
Case FORMULE
 When "ZZ1" : Gosub ADD_TABLE
 When "ZZ2" : Gosub ADD_ECRAN
Endcase
Return

$ADD_TABLE
TT = ""
Call SELECT("ATB","$",TT,"") From SELOBJ
If TT<>"" and !find(TT,TABLE(1..NBTABLE))
 NBTABLE += 1
 TABLE(NBTABLE) = TT
 Gosub TABLE
Endif
Return

$ADD_ECRAN
TT = ""
Call SELECT("AMK","$",TT,"") From SELOBJ
If TT<>""
 Gosub MASQUE
Endif
Return

$TABLE
Read [ATB]CODFIC = TT
Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
Field [AAA_]  1 , "" , [F:ATB]CODFIC , [F:ATB]CODFIC+"   "+TEXTE , "AIDE de la table" , [F:ATB]ABRFIC
FORMULE = TT : Gosub CHAMP
Return

$CHAMP
Read [ATB]CODFIC = FORMULE
For [ATZ]CODZONE Where CODFIC=FORMULE
 Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
 If [F:ATZ]CODACT<>""
  Read [ACV]CODACT = [F:ATZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:ATZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:ATZ]DIME
 Endif
 For J=1 To DIME
  If DIME=1
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-TEXTE
   CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
  Else
# Michel Giet
   If dim(WCVF) > 0
     WCVW  = [F:ATZ]CODZONE+"("+num$(J-1)+")"
     Gosub CONVTEX
   Endif
   DESIG = [F:ATZ]CODZONE-"("+num$(J-1)+")"-TEXTE
   CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE+"("+num$(J-1)+")"
  Endif
  Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:ATZ]CODZONE+"_"+num$(J) , DESIG , "Aide du champ" , CHAMP
  NBCHAMP += 1
 Next J
Next
Return
# Michel Giet : possibilité de convertir le libellé du champs (tarifs)
# 
$CONVTEX
For L = 0 To dim(WCVF)-1
  If WCVF(L) = [F:ATZ]CODFIC & WCVZ(L)= WCVW
    TEXTE = WCVT(L)
    Break
  Endif
Next L
Return

$MASQUE
Read [AMK]CODMSK = TT
Call TEXTE([F:AMK]INTMSK,TEXTE) From OBJDIV
Field [AAA_]  1 , "" , [F:AMK]CODMSK , [F:AMK]CODMSK+"   "+TEXTE , "Aide de l'écran" , [F:AMK]ABRMSK
FORMULE = TT : Gosub ZONE
Return

$ZONE
For [AMZ]CODZON Where CODMSK=FORMULE
 Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If [F:ACV]FLACT=2
   If [F:ACV]DIME<>0
    DIME = [F:ACV]DIME
   Else
    DIME = [F:AMZ]DIME
   Endif
  Else
   DIME = 0
  Endif
 Else
  DIME = [F:AMZ]DIME
 Endif
 If [F:AMK]TYPBLOC([F:AMZ]NUMBLOC-1)=1
  If [F:AMZ]CODTYP="ABS"
   DESIG = [F:AMZ]CODZON-TEXTE
   CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON , DESIG , "Aide du champ" , CHAMP
   NBCHAMP += 1
  Else
   DESIG = [F:AMZ]CODZON-"()"-TEXTE
   CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON+"(indice)"
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON , DESIG , "Aide du champ" , CHAMP
   NBCHAMP += 1
  Endif
 Else
  For J=1 To DIME
   If DIME=1
    DESIG = [F:AMZ]CODZON-TEXTE
    CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON
   Else
    DESIG = [F:AMZ]CODZON-"("+num$(J-1)+")"-TEXTE
    CHAMP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON+"("+num$(J-1)+")"
   Endif
   Field [AAA_]  2 , FORMULE , FORMULE+"."+[F:AMZ]CODZON+"_"+num$(J) , DESIG , "Aide du champ" , CHAMP
   NBCHAMP += 1
  Next J
 Endif
Next
Return

$VERIF
If FORMULE=""
 E = 0
Else
 E = abs(parse(FORMULE))
 If E
  Errbox errmes$(E)+chr$(13)+errm
 Endif
Endif
Return

End



