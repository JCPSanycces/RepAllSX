###################################
$ITMREF_CONTROL
  Local File ITMMASTER  [ITM]
  Local File ITMFACILIT [ITF]
  Read [F:ITM]ITM0 = this.ITMREF
  If fstat
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
      Return
  Endif
  # Article de type "Service" non autorisé
  If [F:ITM]SCSFLG=2
    [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(164,199,1), [V]CST_AERROR)
  Else
    #----- Article non acheté  non autorisé -----#
    If [F:ITM]PURFLG<>2
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(70,197,1), [V]CST_AERROR)
    Else
      #----- Article géré en stock : Article-site obligatoire ---#
      If [F:ITM]STOMGTCOD > 1
         Read [F:ITF]ITF0 = this.ITMREF;this.PSHFCY
         If fstat
          [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(139,197,1), [V]CST_AERROR)
         Endif
      Endif
    Endif
  Endif
Return

###################################
$ITMREF_PROPAGATE
  Local Char    CTX_PURVACBPR(GLONTVB)
  Local Integer CTX_PURCHGTYP(1)
  Local Integer I, WRET
  Local Decimal WCOEUOM
  Local Decimal WQTY
  Local File ITMMASTER  [ITM]
  Read [F:ITM]ITM0 = this.ITMREF
  If fstat
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
      Return
  Endif

  # load Lead-Time
  this.OFS = [F:ITM]OFS

  # VACITM
  Local Integer WRET
  For I = 1 To 3
      this.C_VACITM(I).VACITM = [F:ITM]VACITM(I-1)
  Next I

  #----- Si aucun appel d'offre pris en compte -----#
  If this.PQHNUM =""
    this.STU = [F:ITM]STU
    If this.PUU = ""
      this.PUU = [F:ITM]PUU
    Endif
    # if quantity already entered
    If this.QTYPUU <> 0
      #----- Conversion quantité en US dans la nouvelle unité à partir de l'UA ----------#
      Call PCAL_QTY(this.QTYPUU,this.PUU,this.QTYSTU,[F:ITM]STU,
&             this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
      #----- Conversion qté consommée en US dans la nouvelle unité à partir de l'UA -----#
      If this.WQTYORDSTU<>0
        Call PCAL_QTY(this.WQTYORDSTU,this.STU,this.WQTYORDPUU,this.PUU,
&               this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
      Endif
    Else
      Raz this.QTYSTU
    Endif
  Endif
#-------
Return

###################################
$QTYPUU_CONTROL
  If this.WQTYORDPUU<>0 & this.QTYPUU < this.WQTYORDPUU
     [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(3,194,1), [V]CST_AERROR)
  Endif
Return

###################################
$QTYPUU_PROPAGATE
  Local Decimal WCOEUOM
  #----- Conversion quantité dans la nouvelle unité à partir de l'US -----#
  Call PCAL_QTY(this.QTYPUU,this.PUU,this.QTYSTU,this.STU,
&             this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
Return

###################################
$PUU_PROPAGATE
#MAE, déplacé sur la représentation
#Local Decimal WCOEUOM
##----- Conversion quantité dans la nouvelle unité à partir de l'US -----#
#Call PCAL_QTY(this.QTYSTU,this.STU,this.QTYPUU,this.PUU,
#&             this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
##----- Conversion qté consommée dans la nouvelle unité à partir de l'US -----#
#If this.WQTYORDPUU<>0 | this.WQTYORDSTU<>0
#  Call PCAL_QTY(this.WQTYORDSTU,this.STU,this.WQTYORDPUU,this.PUU,
#&               this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
#Endif
#-----
Return

###################################
$BPSNUM_CONTROL
  Local File    BPARTNER [BPR]
  Local Integer WRET
  Local Char WMESSAGE(80)
  If this.BPSNUM <> AVOID.ACHAR
    WRET =  func TRTACHCTL1_SYRA.C_BPSNUM(this.BPSNUM,WMESSAGE)
    If WRET <> [V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, WRET)
      Return
    Endif
     #----- Contrôle que le fournisseur n'appartienne pas au même site que la demande -----#
     Read [F:BPR]BPR0 = this.BPSNUM
     If fstat
        [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
        Return
    Endif
     If [F:BPR]FCY=this.PSHFCY
        ASTATUS =fmet this.ASETERROR ("BPSNUM", mess(307,194,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################
$BPSNUM_PROPAGATE
  Local File BPSUPPLIER [BPS]
  Local File ITMMASTER  [ITM]
  Local File ITMBPS     [ITP]
  Local Char    WPUU(GLONUOM), WUOM(GLONUOM)
  Local Decimal WQTY, WTEUA, WCOEUOM
  Read [F:BPS]BPS0 = this.BPSNUM
  If fstat
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
      Return
  Endif
  this.CUR   = [F:BPS]CUR
  this.CHGTYP= [F:BPS]CHGTYP
  #-------
  this.VACBPR = [F:BPS]VACBPR
  Call LOAD_VACBPR_LEG(this) From TRTLOADPROPLEG_SYRA

#--- TS
#Local Integer WRET
#Local File TABVACBPR [TVB]
#Call LEC_TVB_LEG(this.ACTX,this.LEG,this.VACBPR,WRET) From TRTLECLEG_SYRA
#If WRET : Raz [F:TVB] : Endif
#this.VACTYP=[F:TVB]REGVAC
Return

###################################
$EXTRCPDAT_PROPAGATE
  # Initialisation du type de ligne et des comptes
  If this.ITMREF<>AVOID.ACHAR
    # Là il faudra brancher les composants qui vont bien
    #Call INIT_COMPTES_LIGNE (NOL) From SUBPSH
    #Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL)) : # Initialisation type d'achat
    #GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPSH
  Endif
  # Planned Order Date
  If this.EXTORDDAT = AVOID.ADATE
    this.EXTORDDAT =this.EXTRCPDAT-this.OFS
  Endif
Return

###################################
$EXTRCPDAT_CONTROL
  #Date inférieure à la date du jour
  If this.ASTALIN = [V]CST_ANEW & this.EXTRCPDAT < date$
    [L]ASTATUS = fmet this.ASETERROR ("EXTRCPDAT", mess(65,194,1), [V]CST_AERROR)
    Return
  Endif
Return

###################################
$NETPRI_PROPAGATE
  this.GROPRI = this.NETPRI
  this.PRIREN = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "DACMANPUR")
  # Il faudra initialiser le tarif si première ligne
  # Il faudra initialiser les comptes,etc ...
  #----- Line amount calculation --#
  # Utile ici ???
  this.LINAMT=this.NETPRI*this.QTYPUU
  Call ARRDEV(this.LINAMT,this.CUR,this.CPY) From TRTDIV_SYRA
Return

###################################
$LEG_GET
  Local Instance FACILITY Using C_FACILITY
  FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]ASTATUS = fmet FACILITY.AREAD(this.PSHFCY)

  If [L]ASTATUS=[V]CST_AOK
    Local Instance VATX Using C_TABVAT
    VATX = NewInstance C_TABVAT AllocGroup FACILITY
    [L]ASTATUS = fmet VATX.AREAD("this.LEG",FACILITY.LEG)
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet VATX.AREAD("this.LEG",AVOID.ACHAR)
    Endif
    If [L]ASTATUS=[V]CST_AOK
        this.LEG = VATX.LEG
    Endif
    VATX = null
  Endif

  FreeGroup FACILITY
  FACILITY = null
Return

###################################
$PRHFCY_INIT #RBA $PRHFCY_INNIT
  Local Char WSITE(GLONFCY)
  #Initialisation du site de réception avec le site de la demande si il est site de stock sinon avec le site de stock par defaut
  If this.PSHFCY <> AVOID.ACHAR
    Call DEFRCPFCY(this.PSHFCY,WSITE) From TRTACHDEF1_SYRA
    this.PRHFCY = WSITE
  Endif
Return

###################################
$C_VACITM_VACITM_PROPAGATE
  # ------------------Initialisation LEG pour régime de taxe-----------------------#
  Call LOAD_VACITM_LEG(this) From TRTLOADPROPLEG_SYRA
Return

###################################
$C_VACITM_VAT_PROPAGATE
  # ------------------Initialisation LEG pour taxe --------------------------------#
  Call LOAD_VAT_LEG(this) From TRTLOADPROPLEG_SYRA
Return




