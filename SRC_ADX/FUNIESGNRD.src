$ALIM_AQ04BN
#Valores no inﾃｭcio do perﾃｭodo N (campo A5219)
Filter [F:BAL] Where CUR="EUR" & CPY=[L]CPY & FCY="" & (left$(ACC,1)="5" | left$(ACC,1)="8") & BPR="" & FIY=[F:FIY]FIYNUM&
& [F:BAL]LEDTYP=val(PLEDTYP)
For [F:BAL]
    If left$([F:BAL]ACC,2)="51"
      A04BA5219(1) = num$(val(A04BA5219(1)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="52"
      A04BA5219(2) = num$(val(A04BA5219(2)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="53"
      A04BA5219(3) = num$(val(A04BA5219(3)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="54"
      A04BA5219(4) = num$(val(A04BA5219(4)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,3)="551"
      A04BA5219(5) = num$(val(A04BA5219(5)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
