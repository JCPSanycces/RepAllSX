      A04BA5219(6) = num$(val(A04BA5219(6)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="56"
      A04BA5219(7) = num$(val(A04BA5219(7)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="57"
      A04BA5219(8) = num$(val(A04BA5219(8)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="58"
      A04BA5219(9) = num$(val(A04BA5219(9)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,2)="59"
      A04BA5219(10) = num$(val(A04BA5219(10)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
    If left$([F:BAL]ACC,3)="818"
      A04BA5219(11) = num$(val(A04BA5219(11)) + [F:BAL]CDTLED(0)-[F:BAL]DEBLED(0))
    Endif
Next
Filter [F:BAL]

