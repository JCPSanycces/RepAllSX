#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
#    GESTION DES DECLINAISONS - PAR TIERS ET SOCIETE                                 #
#------------------------------------------------------------------------------------#
# Traitement : BPEXCEPT                                                              #
# ---------------------                                                              #
# Gestion du masque BPEXCEPT et gestion de l'onglet Tiers/société de l'objet BPR     #
#                                                                                    #
######################################################################################
# ---------------------------------------------------------------------------------- #
#                               PROCEDURES APPELEES DEPUIS D'AUTRES TRAITEMENTS      #
# ---------------------------------------------------------------------------------- #
######################################################################################
$OUVRE_BPE
##########  Appelé depuis OUVRE de SUBBPR
  If !clalev([F:ACV])   Local File ACTIV   [ACV]    : Endif
  If !clalev([F:CPY])   Local File COMPANY [CPY]    : Endif  # 71937 : Multilégislation

  Gosub CHARGE_CODACT
  If [L]BPE_ACTIF
    If !clalev([F:BPE]) Local File BPEXCEPT [BPE] : Endif
  Endif
Return

$CHARGE_CODACT
##############
Local Integer BPE_ACTIF

  Read [ACV]CODACT = "MUL"
  If !fstat & [F:ACV]FLACT = 2
    BPE_ACTIF = 1
  Endif
Return

######################################################################################
Subprog CHARG_EXC(TIERS)
########################  Appelé depuis LIENS de SUBBPR
Value Char TIERS

  Gosub CHARGE_CODACT
  If [L]BPE_ACTIF
    Raz [M:BPE]
    nolign = 0
    Filter [BPE] Where BPRNUM=TIERS
    For [BPE]
      nolign += 1
      If nolign >= dim([M:BPE]CPY)
        Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
        GOK = 0
        Break
      Endif
      [M:BPE]                 = [F:BPE]
      [M:BPE]CPY   (nolign-1) = [F:BPE]CPY
      [M:BPE]VACBPC(nolign-1) = [F:BPE]VACBPC
      [M:BPE]VACBPS(nolign-1) = [F:BPE]VACBPS
      [M:BPE]PTEBPC(nolign-1) = [F:BPE]PTEBPC
      [M:BPE]PTEBPS(nolign-1) = [F:BPE]PTEBPS
      [M:BPE]DEPBPC(nolign-1) = [F:BPE]DEPBPC
      [M:BPE]DEPBPS(nolign-1) = [F:BPE]DEPBPS
      [M:BPE]ACCBPC(nolign-1) = [F:BPE]ACCBPC
      [M:BPE]ACCBPS(nolign-1) = [F:BPE]ACCBPS
      [M:BPE]ACEAUZ(nolign-1) = [F:BPE]ACEAUZ
      # 71937 : Multilégislation
      # Législation non renseignée  : On récupère si possible la législation de la société
      Call LEC_CPY([F:BPE]CPY) From CPTLEC
      [M:BPE]LEG(nolign-1)=[F:CPY]LEG
      # 71937 : Multilégislation
    Next
    [M:BPE]NBLIG = nolign
    Filter [BPE]
  Endif
End

######################################################################################
Subprog ANN_EXC(TIERS)
######################  Appelé depuis ANNULE de SUBBPR
Value Char TIERS

  Gosub CHARGE_CODACT
  If [L]BPE_ACTIF
    Delete [BPE] Where BPRNUM=TIERS
    If fstat=1
      GOK = -1 : GLOCK = "BPEXCEPT"-TIERS
    Elsif fstat>5
      GOK = 0 : Call RSTA("BPE",TIERS) From GLOCK
    Endif
  Endif
End

######################################################################################
Subprog CRE_EXC(TIERS)
######################  Appelé depuis CREATION ou MODIF de SUBBPR
Value Char    TIERS

  Gosub CHARGE_CODACT
  If [L]BPE_ACTIF
    Delete [BPE] Where BPRNUM=TIERS
    If fstat=1
      GOK = -1
      GLOCK = "$BPEXCEPT"-TIERS
      End
    Elsif fstat>5
      GOK = 0
      Call RSTA("BPE",TIERS) From GLOCK
      End
    Endif

    For nolign=1 To [M:BPE]NBLIG
      Raz [F:BPE]
      [F:BPE]       = [M:BPE]
      [F:BPE]BPRNUM = TIERS
      [F:BPE]CPY    = [M:BPE]CPY   (nolign-1)
      [F:BPE]VACBPC = [M:BPE]VACBPC(nolign-1)
      [F:BPE]VACBPS = [M:BPE]VACBPS(nolign-1)
      [F:BPE]PTEBPC = [M:BPE]PTEBPC(nolign-1)
      [F:BPE]PTEBPS = [M:BPE]PTEBPS(nolign-1)
      [F:BPE]DEPBPC = [M:BPE]DEPBPC(nolign-1)
      [F:BPE]DEPBPS = [M:BPE]DEPBPS(nolign-1)
      [F:BPE]ACCBPC = [M:BPE]ACCBPC(nolign-1)
      [F:BPE]ACCBPS = [M:BPE]ACCBPS(nolign-1)
      [F:BPE]ACEAUZ = [M:BPE]ACEAUZ(nolign-1)
      Write [BPE]
      If fstat
        GOK=0 : Call FSTA("BPE") From GLOCK : Break
      Endif
    Next
  Endif
End


######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ACTIONS CHAMPS : Ecran BPEXCEPT  (BPE)               #
# ---------------------------------------------------------------------------------- #
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer I

  I = 0
  I = find(VALEUR,[M:BPE]CPY(0..indice-1),"&&&",[M:BPE]CPY(indice+1..[M:BPE]NBLIG-1))
  If I<>0
    GMESSAGE = mess(27,111,1)-num$(I) : # Société déjà saisie ligne
    mkstat = 2
    End
  Endif
  GSOCIETE = VALEUR
  # 71937 : Multilégislation
  # Législation non renseignée  : On récupère si possible la législation de la société
  If clalev([F:CPY]) =0 : Local File COMPANY [CPY] : Endif
  Call LEC_CPY(VALEUR) From CPTLEC
  [M]LEG(nolign-1)=[F:CPY]LEG
  # 71937 : Multilégislation
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BPEXCEPT) 31/10/2008 16:29:26 (TS)
######################################################################################
Subprog AVANT_NBLIG
GSOCIETE = [M]CPY(nolign-1)
# 71937 : Multilégislation
# Législation non renseignée  : On récupère si possible la législation de la société
If clalev([F:CPY]) =0 : Local File COMPANY [CPY] : Endif
Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
[M]LEG(nolign-1)=[F:CPY]LEG
# 71937 : Multilégislation

End


######################################################################################
## Section automatically added (screen BPEXCEPT) 13/05/2013 08:51:38 (JUCON)
## Law of bad debt SAM #88427
######################################################################################
Subprog C_PAYDAY(VALEUR)
Variable Decimal VALEUR
Local Decimal MAXD
Local Char VALPAR

  Call PARAML([M:BPE]CPY(nolign-1),"DMAXAGR",VALPAR) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  MAXD = val(VALPAR)
  If VALEUR> MAXD and MAXD<>0
    GMESSAGE=mess(10268,200,1)-mess(54,147,1)-num$(MAXD)-mess(38,104,1):  mkstat=2
  Endif

End


######################################################################################

#*****************************************************************************************************
# SAM 110033: Swiss localization: skip field when parameter SWICUSBVR = No
#*****************************************************************************************************
Subprog AS_PAYBANBVR(VALEUR)
Variable Char    VALEUR()
Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
Call PARAM([M:BPE]CPY(nolign-1),"SWICUSBVR",P_SWICUSBVR) From ADOVAL
If P_SWICUSBVR <> "2" and !GIMPORT  # Parameter not set -> hide
   mkstat=2
Endif
End

#*****************************************************************************************************
# SAM 110033: Swiss localization: control if bank belongs to CPY and if FCY of bank is empty
#*****************************************************************************************************
Subprog C_PAYBANBVR(VALEUR)
Variable Char    VALEUR()
Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
Call PARAM([M:BPE]CPY(nolign-1),"SWICUSBVR",P_SWICUSBVR) From ADOVAL
If P_SWICUSBVR = "2" and VALEUR <> ""  # Parameter set and bank entered -> do additional checks
   Local Integer OK
   If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
   Call LEC_BAN(VALEUR) From CPTLEC
   If fstat=0
      If [F:BAN]CPY <> [M:BPE]CPY(nolign-1)
         GMESSAGE = func AFNC.MES2( mess(55,3648,1), VALEUR,[M:BPE]CPY)
            # The payment bank account $1$ does not belong to the company $2$.
         mkstat = 2
      Elsif [F:BAN]FCY <> ""
         GMESSAGE = func AFNC.MES2( mess(56,3648,1), VALEUR,[F:BAN]FCY)
            # The payment bank account $1$ must be defined only on company level and may not be restricted to a single site ($2$).
         mkstat = 2
      Elsif [F:BAN]BVRNUM = ""
         GMESSAGE = func AFNC.MES1( mess(57,3648,1), VALEUR)
            # No ISR customer number given in bank account $1$. Please enter an ISR customer number in the bank account management.
         mkstat = 2
      Endif
   Endif
Endif
End


#*****************************************************************************************************
# SAM 110033: Swiss localization: activation/deactivation of field PAYBANBVR depending on parameter SWICUSBVR
#*****************************************************************************************************
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
If GIMPORT <> 0 End Endif
If VALEUR<>"" & dim([M:BPE]PAYBANBVR)>0
    Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
    Call PARAM(VALEUR,"SWICUSBVR",P_SWICUSBVR) From ADOVAL
    If P_SWICUSBVR = "2"  # Parameter set -> activate field
       Chgstl [M:BPE]PAYBANBVR(nolign-1) With ""
    Else
       Chgstl [M:BPE]PAYBANBVR(nolign-1) With "INACTIV"
    Endif
Endif
End


#*****************************************************************************************************
# SAM 110033: Swiss localization: selection criteria of paying bank field
#*****************************************************************************************************
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return


$SEL_TABLE
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
Default File [BAN]
OBJET = "BAN"
CRITERE = 'CPY="'+num$(PARAM(1))+'" & FCY=""'

Return
