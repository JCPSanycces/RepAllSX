#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential file
# Supervisor
## ACLA-CLASSE ## EDISEQFIL
# 2018-11-06 07:05:05 824

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDISEQFIL
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_MSGFOR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_CACHEUUID From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_ABRCLA From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_REPCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_CODACT From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_FILDES From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_MSGDIR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_TYPFIL From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_CODDBA From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_FLDLIM From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_SEPREC From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_SEPFLD From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_SEPDEC From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_OPTCHA From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_OPTDAT From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_OPTMNL From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_VALID From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_FLGMUX From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_KEYALIAS From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_KEYDES From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_KEYPROPERTY From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_KEYPROTOPATH From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC2EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC2EDISEQFIL : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC2EDISEQFIL : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDISEQFIL : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDISEQFIL
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFOR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDISEQFIL
Gosub LNKPRO_MSGCOD From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub LNKPRO_MSGREL From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub LNKPRO_MSGFILNOR From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub LNKPRO_CODACT From WMC1EDISEQFIL : Gosub TESTALLSTAT
For AINDCLA=1 To maxtab(this.ESFD)
 If this.ESFD(AINDCLA)<>null& find(this.ESFD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESFF)
 If this.ESFF(AINDCLA)<>null& find(this.ESFF(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFF(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.ESFN(AINDCLA)<>null& find(this.ESFN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.ESFN(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_KEYALIAS From WMC1EDISEQFIL : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC2EDISEQFIL : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC2EDISEQFIL : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



