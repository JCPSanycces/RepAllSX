#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe ORDERS - EVENTS
###################################################################################################
$AREAD_AFTER
Local Integer WRET

  # Issue X3-34326 - 2017-04-26 by FGR
  WRET = fmet this.LOAD_TECPJT()
Return

###################################################################################################
$ACONTROL
Return

###################################################################################################
$AINSERT_CONTROL_BEFORE
Local Char SMESSAGE(250)
Local Integer IRET
Local Char SNUMERO(GLONVCR)

  # ---------------------------------
  IRET = func ANM_TOOL.NUMERO(this.ACTX, "WIP", this.ORIFCY, this.STRDAT, "", SNUMERO, SMESSAGE)
  If IRET = [V]CST_AERROR Then
    [L]ASTATUS = fmet this.ASETERROR("", mess(22,7770,1) - "(" + "WIP" + ") :" - SMESSAGE, [V]CST_AERROR)
    Return
  Endif
  this.WIPNUM = SNUMERO
  # ---------------------------------
  Gosub AINSERT_UPDATE_CONTROL_BEFORE
  # ---------------------------------
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  # ---------------------------------
  Gosub AINSERT_UPDATE_CONTROL_BEFORE
  # ---------------------------------
Return

###################################################################################################
$AINSERT_UPDATE_CONTROL_BEFORE
Local Decimal NRMNEXTQTY

  # ---------------------------------
  If this.ENDDAT = [0/0/0] Then
    this.ENDDAT = this.STRDAT
  Endif
  # ---------------------------------
  NRMNEXTQTY  = this.EXTQTY
  NRMNEXTQTY -= this.CPLQTY
  If NRMNEXTQTY < 0 Then
    NRMNEXTQTY = 0
  Endif
  this.RMNEXTQTY = NRMNEXTQTY
  # ---------------------------------
Return

