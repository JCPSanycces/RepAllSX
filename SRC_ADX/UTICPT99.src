#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT97 - VNEXT   UTI process                                    Module CPT   #
#            correction utility
# UTICPT99 -  to reset the VATFRMENT and VATENTFRM tables before structure changes
# Issue X3-100993 - 2018-07-18 by MDJ : To do also on X3 folder
# Issue X3-83028  - 2018-05-18 by CBO : Add a parameter to modify or not purchase order
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
  Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

  If WDOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Reset of VEF and VFE tables") From LECFIC
    Call MAJ_UTICPT99(WDOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  Close Local File

End

##########################################################################
Subprog MAJ_UTICPT99(DOSSIER)
Value Char DOSSIER()

  If filinfo(filpath("FIL","VATENTFRM","fde",DOSSIER),0)<=0  :   End : Endif  # X3-100993

  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTICPT99 : Not to perform on archive folder : " + DOSSIER, 0) From GESECRAN
    End
  Endif

  Call ECR_TRACE("UTICPT99 : Start of process on : " + DOSSIER, 0) From GESECRAN

  #----- OPEN FILES -----#
  If clalev([F:VEF])  =0  Local File =DOSSIER+".VATENTFRM"   [VEF] : Endif
  If clalev([F:VFE])  =0  Local File =DOSSIER+".VATFRMENT"   [VFE] : Endif

  Call DEBTRANS From GLOCK

$RAZVEF
  Trbegin [VEF]
  Delete [F:VEF] Where 1=1
  If !fstat
    Call ECR_TRACE("Reset of Table VEF - OK  " + DOSSIER, 0) From GESECRAN
  Else
    Call ECR_TRACE("Reset of Table VEF - failed  " + DOSSIER, 1) From GESECRAN
    Rollback : Goto RAZVFE
  Endif
  Commit

$RAZVFE
  Trbegin [VFE]
  Delete [F:VFE] Where 1=1
  If !fstat
    Call ECR_TRACE("Reset of Table VFE - OK  " + DOSSIER, 0) From GESECRAN
  Else
    Call ECR_TRACE("Reset of Table VFE - failed  " + DOSSIER, 1) From GESECRAN
    Rollback : Goto ENDRAZ
  Endif
  Commit

$ENDRAZ
  Close Local File [F:VEF]
  Close Local File [F:VFE]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI()

#X3-100993  If APPLI = GDOSX3
##X3-100993    End
##X3-100993  Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

  If [F:ADS]MODULE(2) <> 2 : End : Endif                                 : # 2 module compta

  Call MAJ_UTICPT99(APPLI)
End

