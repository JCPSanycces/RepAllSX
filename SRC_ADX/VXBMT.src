#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################
# Material consumption
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# FCY, MFGNUM, ITMREF, USEQTY, STU,  CLEFLG, BOMSEQ, MFGLIN,
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# WSTOSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No
#
########################################################

########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE
Global Char    GMMLNUM(GLONTRS)

# Issue 50246 - 2017-10-03 by STLIG : Available stock
Global Decimal GAVAILABLE_STOCK

Local Char CRIT1
Local Integer  VALOK

If clalev([F:BTS]) =0 : Local File BENCHTRS [BTS]  : Endif

GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Raz GMMLNUM

# GMMLNUM contains the consumption transaction
GMMLNUM = func ENVADC.SETMFGTRANS(61)

Gosub OUVRE_MBM From ENVADC

Local Mask STOCOUW [STCW]

Return

########################################################
$DEBUT
Local Integer WOK, WCPT
Global Char GTRAVT(250)
Gosub DEBUT_MBM From ENVADC
# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return
Endif

Gosub INIT_SCREEN

Return

########################################################
$SETBOUT

If !find("1",CHMEN) CHMEN+="1" Endif
Return

########################################################
$AVANT_OK

If [M]MFGNUM="" | [M]ITMREF="" | [M]USEQTY <=0
   GERR=1 : Call ERREUR(mess(17,7750,1)) From GESECRAN
   zonsui="[M:XBMT]MFGNUM"
   Return
Endif

If [M]ALLQTY=0
   Case GCTLALL :
    When 2 : OK=1 : Call AVERTIR(mess(700,197,1), OK) From GESECRAN
             If OK=1 GERR=1 : Endif
    When 3 : Call ERREUR(mess(700,197,1)) From GESECRAN
             GERR=1
   Endcase
Elsif [M]ALLQTY<[M]USEQTY
   Case GCTLALL :
    When 2 : OK=1 : Call AVERTIR(mess(318,184,1), OK) From GESECRAN
             If OK=1 GERR=1 : Endif
    When 3 : Call ERREUR(mess(318,184,1)) From GESECRAN
             GERR=1
   Endcase
Endif

Return

########################################################
$OK

GREP="C"
FIN=0

# Alimentation STOSORW
Call CHGSOW_MBM("XBMT",[M:XBMT]USEQTY,WRET) From STKADC
If WRET<>0 GERR=1 Endif

WORISVG = [M:XBMT]ORI

[L]WCPT = [M:XBMT]WCPT
Effzo [M:XBMT]1-99
[M:XBMT]WCPT    = [L]WCPT+1
[M:XBMT]FCY     = [M:MBM]FCY
[M:XBMT]MMLNUM  = GMMLNUM
[M:XBMT]ORI     = WORISVG
[M:XBMT]IPTDAT  = date$
Affzo [M:XBMT]1-99

zonsui="[M:XBMT]MFGNUM"

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE : Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA
If [M:MBM]NBLIG > 0
    Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif

Gosub INIT_SCREEN
Return

########################################################
$CRE
If [M:STCW]NBLIG<>0
   Gosub AVANT_OK
   If GERR=1 Return Endif
   # Alimentation  STOSORW
   Call CHGSOW_MBM("XBMT",[M:XBMT]USEQTY,WRET) From STKADC
   If WRET<>0 Return Endif
Endif

Gosub CRE_MBM From ENVADC

Gosub INIT_SCREEN
Return

########################################################
$CHECK
Local Integer WOK
If [M:MBM]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XBMT]MFGNUM" : Return
   Endif
Endif

Return

########################################################
$FIN

Gosub FIN_MBM From ENVADC

GVTMOD=0
Kill GTRAVT

Return

########################################################
$INIT_SCREEN

Gosub RAZ_MBM From ENVADC
Raz [M:XBMT]

[M:XBMT]MMLNUM  = GMMLNUM
[M:XBMT]TRSCODS = [F:BTS]TRSCODS
[M:XBMT]TRSTYP  = 6
[M:XBMT]FCY     = GXAFCY
[M:XBMT]IPTDAT  = date$
Actzo [XBMT]1-99
Affzo [XBMT]1-99
nolign=0
Default Mask [XBMT]
GREP="" : REP=""

Return



########################################################

Subprog AM_MMLNUM(VALEUR)
Variable Char    VALEUR()
GMMLNUM = VALEUR
[M:XBMT]TRSCODS = [F:BTS]TRSCODS
End

Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   mkstat=2 : End
Endif
Gosub C_MFGNUM_MBM From ENVADC
End

Subprog AS_ORI(VALEUR)
Variable Integer VALEUR
If dim([M]LOT)   <0 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1 : Endif
If dim([M]SLO)   <0 : GMENLOC(1)=1 : GMENLOC(3)=1 : Endif
If dim([M]SERNUM)<0 : GMENLOC(5)=1 : GMENLOC(6)=1 : Endif
If dim([M]LOC)   <0 : GMENLOC(7)=1 : GMENLOC(8)=1 : Endif
If dim([M]PALNUM)<0 : GMENLOC(9)=1 : GMENLOC(10)=1 : Endif
End

Subprog C_ORI(VALEUR)
Variable Integer VALEUR
Raz [F:MFM]
Case VALEUR
 When  1 : If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  2 : If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  3 : Grizo [M]ITMREF
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
           If dim([M]SLO)   >0 Actzo [M]SLO    Endif
 When  4 : Grizo [M]ITMREF
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOT)   >0 Actzo [M]LOT    Endif
 When  5 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  6 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]SERNUM)>0 Actzo [M]SERNUM Endif
 When  7 : If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           Actzo [M]ITMREF
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  8 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]PALNUM)>0 Grizo [M]PALNUM Endif
           If dim([M]LOC)   >0 Actzo [M]LOC    Endif
 When  9 : Actzo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
 When 10 : Grizo [M]ITMREF
           If dim([M]LOT)   >0 Grizo [M]LOT    Endif
           If dim([M]SLO)   >0 Grizo [M]SLO    Endif
           If dim([M]SERNUM)>0 Grizo [M]SERNUM Endif
           If dim([M]LOC)   >0 Grizo [M]LOC    Endif
           If dim([M]PALNUM)>0 Actzo [M]PALNUM Endif
Endcase
End

Subprog AM_ORI(VALEUR)
Variable Integer VALEUR
Raz [M]ITMREF
If dim([M]LOT)   >0 Raz [M]LOT    Endif
If dim([M]SLO)   >0 Raz [M]SLO    Endif
If dim([M]SERNUM)>0 Raz [M]SERNUM Endif
If dim([M]LOC)   >0 Raz [M]LOC    Endif
If dim([M]PALNUM)>0 Raz [M]PALNUM Endif
End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,5,7) & VALEUR="" mkstat=2 Endif
End

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,7,8) & VALEUR=""     mkstat=2 Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,2,3,4) & VALEUR="" mkstat=2 Endif
End

Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,1,3) & VALEUR=""     mkstat=2 Endif
End

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI,5,6) & VALEUR=""     mkstat=2 Endif
End

Subprog C_PALNUM(VALEUR)
Variable Char    VALEUR()
If find([M]ORI=9,10) & VALEUR=""    mkstat=2 Endif
End




Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
# Issue 110327
Local Integer LAFF
LAFF=1
Call LECFICSOR(VALEUR,[M:XBMT]FCY,[M:XBMT]TRSTYP,[M:XBMT]TRSCODS,LAFF) From STKECR
If mkstat End Endif
If [F:ITM]SERMGTCOD>1 & !find([M]ORI,5,6)
  Call ERREUR(mess(89,182,1)) From GESECRAN
  mkstat = 2
Endif
# End issue 110327
End




Subprog AS_USEQTY(VALEUR)
Variable Decimal VALEUR()
Local    Decimal WQTY, WQTA, WQTYMFM
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER), WSERF(GLONSER) # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
Local    Integer LRET
#--- Issue 103217
Local    Char    WPCU(GLONUOM)
Local    Decimal WPCUSTUCOE
#---

Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
# Recherche de l'article
#--- Issue 103217 : ajout WPCU et WPCUSTUCOE
# Issue 110327, ajout de WSERF
Call RECSTO(0,[F:BTS]TRSCODS,[M]ORI,[M]FCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
# La saisie doit concerner un seul article
If [M]ITMREF="*****"
   Call ERREUR(mess(315,184,1)) From GESECRAN
   Raz [M]ITMREF
   zonsui = "[M:XBMT]MFGNUM"
   End
Endif

# Si on n'a pas utilise la selection
If [F:MFM]MFGNUM = ""
   WCRITERE="MFGNUM=[M]MFGNUM"
   WCRITERE-="& ITMREF=[M]ITMREF & MATSTA <> 4"
   Filter [MFM] Where evalue (WCRITERE)
   Read [MFM] MFM0 First
   Filter [MFM]
   If fstat
      Call ERREUR(mess(23,100,1)) From GESECRAN
      zonsui = "[M:XBMT]MFGNUM"
      End
   Endif
Else
   Read [F:MFM]MFM0 = [M]MFGNUM;[M]MFGLIN;[M]BOMSEQ;[M]ITMREF
Endif
[M]MFGLIN=[F:MFM]MFGLIN
[M]BOMSEQ=[F:MFM]BOMSEQ
[M]TCLCOD=[F:ITM]TCLCOD

# Recherche des lignes de stock
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
#--- Issue 103217 : ajout WPCU et WPCUSTUCOE
#Call RECSTO(5,[F:BTS]TRSCODS,[M]ORI,[M]FCY,"",[M]ITMREF,
#&           WLOT,WSLO,WSER,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
# Issue 110327, ajout de WSERF
# Issue 110327 - 2016-11-04 by MAE : Pas de recherche de stock si SERMGTCOD = 4
If [F:ITM]SERMGTCOD <> 4
  #--- Issue 103217 : ajout WPCU et WPCUSTUCOE
  Call RECSTO(5,[F:BTS]TRSCODS,[M]ORI,[M]FCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
  If WQTY=0
    Call ERREUR(mess(314,184,1)) From GESECRAN
    zonsui = "[M:XBMT]MFGNUM"
    End
  Endif
  [M]ALLQTY = WQTA
Endif

# Issue 50246 - 2017-10-03 by STLIG : Set available stock from RECSTO
GAVAILABLE_STOCK = WQTY

# Calcul de la quantité restant à consommer
WQTYMFM =[F:MFM]RETQTY-[F:MFM]USEQTY
WQTYMFM-=sigma(I=0,[M:MBM]NBLIG-1,[M:MBM]USEQTY(I)*([M:MBM]MFGNUM(I)= [F:MFM]MFGNUM &
&                                                   [M:MBM]MFGLIN(I)= [F:MFM]MFGLIN &
&                                                   [M:MBM]BOMSEQ(I)= [F:MFM]BOMSEQ &
&                                                   [M:MBM]ITMREF(I)= [M]ITMREF))
If WQTYMFM<0 : Raz WQTYMFM : Endif
# Quantité à traiter = minimum de qté sélectionnée et qté restant à consommer
# Issue 50246 - 2017-10-03 by STLIG : Initially default material issue quantity

If ([M]USEQTY = 0)
   GPE = 0 : GPOINT = "ALL_LOTQTY" : Gosub  ENTREE From EXEFNC           #X3-63378.n
   If GPE <> 0                                                           #X3-63378.n
       GPE = 0                                                           #X3-63378.n
   Else                                                                  #X3-63378.n
       [M]USEQTY=min(WQTY,WQTYMFM)
   Endif                                                                 #X3-63378.n
Endif

#--- TS
#[M]WQTY   = [M]USEQTY
[M]WQTY   = WQTYMFM
#---

VALEUR    = [M]USEQTY
Call CONT_SOLDE_MAT([M]FCY,[M]ITMREF,[M]USEQTY,[M]WQTY,LRET) From MFGLIBM
If LRET=1
   [M]CLEFLG=2
Else
   [M]CLEFLG=1
Endif

If [M]ITMREF<>"" Affzo [M]ITMREF Endif
If dim([M]LOT)>0
   [M]LOT=WLOT : Affzo [M]LOT
   If dim([M]SLO)>0
      [M]SLO=WSLO : Affzo [M]SLO
   Endif
Endif
If dim([M]SER)>0
   [M]SER=WSER : Affzo [M]SER
Endif
If dim([M]LOC)>0
   [M]LOC=WLOC : Affzo [M]LOC
Endif
Affzo [M]ALLQTY
End

Subprog C_USEQTY(VALEUR)
Variable Decimal VALEUR
# Issue 110327
Local    Decimal WQTY, WQTA
Local    Char    WLOT(GLONLOT)
Local    Char    WSLO(GLONSLO)
Local    Char    WSER(GLONSER)
Local    Char    WSERF(GLONSER)   # Issue 110327
Local    Char    WLOC(GLONLOC)
Local    Char    WPAL(GLONPAL)
Local    Char    WSTA(GLONSTA)
Local    Char    WPCU(GLONUOM)
Local    Decimal WPCUSTUCOE
Local    Decimal LQTYF
# End issue 110327
If VALEUR=0 mkstat=2 Endif
# Issue 110327
Raz [M:STCW]
If dim([M]LOT)   >0 WLOT=[M]LOT    Endif
If dim([M]SLO)   >0 WSLO=[M]SLO    Endif
If dim([M]SERNUM)>0 WSER=[M]SERNUM Endif
If dim([M]SERNUMF)>0 WSERF=[M]SERNUMF Endif   # Issue 110327
If dim([M]LOC)   >0 WLOC=[M]LOC    Endif
If dim([M]PALNUM)>0 WPAL=[M]PALNUM Endif
If dim([M]STA)>0 WSTA=[M]STA Endif
# Issue 110327 - 2016-10-13 by MAE : gestion de SERMGTCOD= 4
If [F:ITM]SERMGTCOD = 4 &  ([M]ORI = 5 | [M]ORI = 6)
    [M:ALP]TRSTYP     = [M:XBMT]TRSTYP
    [M:ALP]TRSCOD     = [M:XBMT]TRSCODS
    [M:ALP]STOFCY     = [M]FCY
    [M:ALP]ITMREF     = [F:ITM]ITMREF
    [M:ALP]BESDAT     = [M:XBMT]IPTDAT
    [M:ALP]DLVDAT     = [M:XBMT]IPTDAT
    [M:ALP]VCRNUMORI  = [M]MFGNUM
    [M:ALP]VCRLINORI  = [M]MFGLIN
    [M:ALP]PECINTLOC  = 2
    [M:ALP]PECSCOLOC  = 1
    [M:ALP]PECPLFLOC  = 2
    [M:ALP]STA        = "*"
    # Détermination no série fin
    Call CTLSORSER("XBMO",0,[M]SERNUM,VALEUR,WSERF,LQTYF) From STKSOR
    If LQTYF=0
      Raz VALEUR, [M]SERNUMF
    Else
      [M]SERNUMF=WSERF
    Endif
    WQTY = VALEUR
    Call RECSTO(5,[M:XBMT]TRSCODS,[M]ORI,[M]FCY,"",[M]ITMREF,
&           WLOT,WSLO,WSER,WSERF,WLOC,WPAL,WSTA,WPCU,WPCUSTUCOE,WQTY,WQTA) From STKADC
    If WQTY=0
      Call ERREUR(mess(314,184,1)) From GESECRAN
      zonsui = "[M:XBMO]ITMREF"
      End
     Else
      If dim([M]LOT)   >0  [M]LOT = WLOT  : Affzo [M]LOT  Endif
      If dim([M]SLO)   >0  [M]SLO = WSLO  : Affzo [M]SLO   Endif
      If dim([M]LOC)   >0  [M]LOC = WLOC   : Affzo [M]LOC Endif
      If dim([M]PALNUM)>0  [M]PALNUM = WPAL : Affzo [M]PALNUM Endif
      If dim([M]STA)>0     [M]STA = WSTA : Affzo [M]STA Endif
    Endif
    [M]ALLQTY = WQTA
Else

  # Issue 50246 - 2017-10-03 by STLIG : Test for material issue quantity > available stock (not required quantity)
  If (VALEUR > GAVAILABLE_STOCK)
    mkstat=2 : Call ERREUR(mess(446,196,1)) From GESECRAN
  Endif

Endif

End

Subprog AM_USEQTY(VALEUR)
Variable Decimal VALEUR
Local Integer LRET
Call CONT_SOLDE_MAT([M]FCY,[M]ITMREF,VALEUR,[M]WQTY,LRET) From MFGLIBM
If LRET=1
   [M]CLEFLG=2
Else
   [M]CLEFLG=1
Endif
Affzo [M]CLEFLG
End

######################################################################################
# Issue 110327
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXBMT) 07/03/2017 15:46:43 (MAE)
######################################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
If [F:ITM]SERMGTCOD = 0
   Filter [STS] Where SERNUM = VALEUR and STOFCY = [M]FCY
   Read [STS]First
   If fstat
      Call ERREUR(mess(43,196,1)) From GESECRAN
      mkstat=2 : End
   Endif
   LAFF=1
   Call LECFICSOR([F:STS]ITMREF,[M]FCY,[M:XBMT]TRSTYP,[M:XBMT]TRSCODS,LAFF) From STKECR
   If mkstat End Endif
   Filter [STS]
Endif
End
# End issue 110327
######################################################################################
