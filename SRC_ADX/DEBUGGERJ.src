##############################################################################
##
## Bibliothèque de subprog utilitaires de manipulation des paramètres
## contenus dans la globale GIAADXCTX qui est une copie de la variable 
## système "adxctx"
##
## voir déclaration et valorisation de GIAADXCTX dans le traitement IAMAIN
##
## Exemple de contenu de GIAADXCTX
## ADAPI:NA1:debug.on=on;debug.trt=;debug.sub=;debug.line=0;debug.host=172.16.9.242;debug.port=1789;trace.on=off;trace.filepath=%24HOME%2Ftmp;trace.dbglong=200;
##
##############################################################################

End:# y a rien à executer en direct dans ce traitement !

######################################################################
# Appelé sur onkey à partir de EXEFNC
######################################################################

Subprog ON_KEY
If clalev([M:DBG]) : # Le debugger est actif
 [M:DBG]TRATRA = 1
Else
 #CHECK UNUSED_BEGIN
 Dbgaff : # Voulu pour la bascule du mode trace
 #CHECK UNUSED_END
Endif
End



#########################################
# REPLACE_IN_STRING
# remplace une portion d'une chaine par une autre
#########################################
Subprog REPLACEINSTR(IACTX_STR,IACTX_START,IACTX_END,IACTX_VALUE)
  Variable Char    IACTX_STR()
  Value    Integer IACTX_START
  Value    Integer IACTX_END
  Value    Char    IACTX_VALUE()

  Local Char WSTR(250)
  WSTR =  left$([L]IACTX_STR,[L]IACTX_START)
  WSTR += [L]IACTX_VALUE
  WSTR += right$([L]IACTX_STR,[L]IACTX_END)
  [L]IACTX_STR = WSTR
End
#########################################
# SET_PARAM
# valorise un paramètre sous la forme id=value
#########################################
Subprog SET_PARAM(IACTX_ID,IACTX_VALUE)
  Value Char IACTX_ID()
  Value Char IACTX_VALUE()

  Local Integer WI
  Local Integer WJ

  [L]IACTX_ID += "="

  [L]WI = instr(1,[V]GIAADXCTX,[L]IACTX_ID)
  If [L]WI
    [L]WJ = instr([L]WI,[V]GIAADXCTX,";")
    If [L]WJ
      [L]IACTX_VALUE = [L]IACTX_ID + [L]IACTX_VALUE
      Call REPLACEINSTR([V]GIAADXCTX,[L]WI-1,[L]WJ,[L]IACTX_VALUE ) 
    Endif
  Else :# si le parmètre n'était pas présent => ajout à la fin
    [V]GIAADXCTX += [L]IACTX_ID + [L]IACTX_VALUE +";"
  Endif
End
#########################################
# SET_PARAM_BOOL
# valorise un paramètre avec les valeurs "on" ou "off"
# en fonction d'un booleen numérique 1 ou 0
#########################################
Subprog SET_PARAM_BOOL(IACTX_ID,IACTX_ON)
  Value Char IACTX_ID()
  Value Integer IACTX_ON
  
  Local Char WFLAG(250)
  If [L]IACTX_ON= 1
    [L]WFLAG= "on"
  Else
    [L]WFLAG= "off"
  Endif

  Call SET_PARAM([L]IACTX_ID,[L]WFLAG) 
End

#########################################
# GET_PARAM
# retourne la valeur par défaut si le 
# paramètre est absent
#########################################
Subprog GET_PARAM(IACTX_ID,IACTX_VALUE,IACTX_DEFAULT)
  Value    Char IACTX_ID()
  Variable Char IACTX_VALUE()
  Value    Char IACTX_DEFAULT()

  Local Integer WI
  Local Integer WJ

  [L]IACTX_ID += "="

  [L]WI = instr(1,[V]GIAADXCTX,[L]IACTX_ID)
  If [L]WI
    [L]WI + =len([L]IACTX_ID)
    [L]WJ = instr([L]WI,[V]GIAADXCTX,";")
    If [L]WJ>[L]WI
      [L]IACTX_VALUE = seg$([V]GIAADXCTX,[L]WI,[L]WJ-1)
    Else
      [L]IACTX_VALUE = ""
    Endif
  Else
    [L]IACTX_VALUE = [L]IACTX_DEFAULT
  Endif

End
#########################################
# GET_PARAM_BOOL
# retourne un boolean numérique 1 ou 0 en
# en fonction de la valeur du paramètre "on" ou "off"
#########################################
Subprog GET_PARAM_BOOL(IACTX_ID,IACTX_ON)
  Value    Char IACTX_ID()
  Variable Integer IACTX_ON
  
  Local Char WFLAG(250)
  [L]WFLAG = ""

  Call GET_PARAM([L]IACTX_ID,[L]WFLAG ,"off") 

  If [L]WFLAG = "on"
    [L]IACTX_ON = 1
  Else
    [L]IACTX_ON = 0
  Endif
End
#########################################
# GET_DEBUG_ON
# retourne un boolean numérique 1 ou 0 en
# fonction de la valeur du paramètre "debug.on"
#########################################
Subprog GET_DEBUG_ON(IACTX_ON)
  Variable Integer IACTX_ON
  Call GET_PARAM_BOOL("debug.on",[L]IACTX_ON) 
End
#########################################
# SET_DEBUG_ON
# fixe la valeur du paramètre "debug.on" en 
# fonction de la 
#########################################
Subprog SET_DEBUG_ON(IACTX_ON)
  Value Integer IACTX_ON
  Call SET_PARAM_BOOL("debug.on",[L]IACTX_ON) 
End
#########################################
# GET_HOST
# retourne la valeur du paramètre "debug.host"
#########################################
Subprog GET_HOST(IACTX_HOST)
  Variable Char IACTX_HOST()
  Call GET_PARAM("debug.host",[L]IACTX_HOST,"unknown") 
End
#########################################
# SET_HOST
# fixe la valeur du paramètre "debug.host"
#########################################
Subprog SET_HOST(IACTX_HOST)
  Value Char IACTX_HOST()
  Call SET_PARAM("debug.host",[L]IACTX_HOST) 
End
#########################################
# GET_PORT
# retourne la valeur du paramètre "debug.port"
#########################################
Subprog GET_PORT(IACTX_PORT)
  Variable Char IACTX_PORT()
  Call GET_PARAM("debug.port",[L]IACTX_PORT,"-1") 
End
#########################################
# SET_PORT
# fixe la valeur du paramètre "debug.port"
#########################################
Subprog SET_PORT(IACTX_PORT)
  Value Char IACTX_PORT()
  Call SET_PARAM("debug.port",[L]IACTX_PORT) 
End

Subprog SETDEBUGJON
If GBROWS<>0 : End : Endif
If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif
[V]GIAADXCTX = "X3_CS:NA1:"               : # entête "X3_CS:session client X3" + "NA1:session primaire"
Call SET_DEBUG_ON(1) From DEBUGGERJ       : # 0=debugger socket "off"
Call SET_PORT("1789") From DEBUGGERJ      : # Port*

Local Char RETOUR(250)
Local Integer K
Call PARCLI("ComputerName",RETOUR) From GLOBVAR
Call SET_HOST(RETOUR) From DEBUGGERJ : # @ip du pc
#Call SET_HOST("172.16.9.153") From DEBUGGERJ : # @ip du pc
End

Subprog SETDEBUGJOFF
If GBROWS<>0 and dim([V]GIAADXCTX)>0 : Kill [V]GIAADXCTX : Endif
End
