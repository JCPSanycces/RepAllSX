#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Local Integer ANOWRITE
Local Char GLOBEML(GLONEML)
Global Integer GLOBILINE


#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
ANOWRITE = 1

#Read the data from the class and transfer to the mask (Default Values)
Global Instance I_ESSEMPPERCNT Using C_ESSEMPPERCNT

GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level



#Manage Localisations
Call MANAGE_LOCALISATION("ESSPERCNT") From DIVPAYE
Return


$DEBUT
Local Char EMPCODE(GLONEML)
EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

#Filter child table on EMCODE
Gosub CHARGE_ALL

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPERCNTHIDE
Call SHOW_LEGACTCALLS From WESSPERCNTSHOW

Affzo [M:ESPRC]1-99

Return


$OK
Local Integer WORKFLOWTRIGGER
Local Integer NI,MY_STATUS
Local Integer WRKFLOW_STAT_PERCNT

[L]WRKFLOW_STAT_PERCNT     = [V]CST_ANOTDEFINED

#Trigger workflow
[L]WRKFLOW_STAT_PERCNT  = fmet I_ESSEMPPERCNT.EMP_WRKREQ(I_ESSEMPPERCNT.REFNUM,"EMPLOID","ESSEMPPERCNT","T","EMPLOIDRT","IDRT")
If [L]WRKFLOW_STAT_PERCNT <> [V]CST_AOK and [L]WRKFLOW_STAT_PERCNT <> [V]CST_ANOTDEFINED
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPPERCNT) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]WRKFLOW_STAT_PERCNT <> [V]CST_AWARNING and [L]WRKFLOW_STAT_PERCNT <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

If [L]WRKFLOW_STAT_PERCNT = [V]CST_ANOTDEFINED
  GMESSAGE = mess(0016,10727,1)
  GERR = 2
  Return
Endif

If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2
Return



$CHARGE_ALL
Local Integer MY_STATUS

#
#Local Instance I_ESSEMPCNT Using C_ESSEMPCNT
#I_ESSEMPCNT = NewInstance C_ESSEMPCNT AllocGroup null
#[L]MY_STATUS = fmet I_ESSEMPCNT.AREAD(EMPCODE)
#Infbox "MY_STATUS "+num$(MY_STATUS)
#Return
#-------------------------------Hybrid----------------------------------#
nolign = 0

I_ESSEMPPERCNT = NewInstance C_ESSEMPPERCNT AllocGroup null
[L]MY_STATUS = fmet I_ESSEMPPERCNT.AREAD(EMPCODE)

If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPPERCNT) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif
#Transfer class
Gosub SET_ALL

[M:ESPRC]NBCNT = nolign
#-------------------------------Hybrid----------------------------------#
Affzo [M:ESPRC]1-99
Return

$SET_ALL
Local Integer NI
If I_ESSEMPPERCNT.PERCNT <> null
  For NI = 1 To maxtab(I_ESSEMPPERCNT.PERCNT)
    If I_ESSEMPPERCNT.PERCNT(NI) <> null and find(I_ESSEMPPERCNT.PERCNT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      SetInstance [M:ESPRC]10 With I_ESSEMPPERCNT.PERCNT(NI)
    Endif
  Next
Endif
Return

Subprog UPDATE_ESSEMPPERCNT_PERCNT(VNLINE)
Value Integer VNLINE
SetInstance [M:ESPRC]10 With I_ESSEMPPERCNT.PERCNT(VNLINE)
Affzo [M:ESPRC]10

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPERCNTHIDE
Call SHOW_LEGACTCALLS From WESSPERCNTSHOW

End


Subprog SHOW_ESSEMPPERCNT_PERCNT(VNLINE)
Value Integer VNLINE

SetInstance [M:ESPRC]10 With I_ESSEMPPERCNT.PERCNT(VNLINE)
[M:ESPRC]TCH_NUMLIG(nolign-1) = VNLINE   # Line index in the collection
End


Subprog C_NBCNT
Local Integer ILINE,IRET
If status = 82 or status = 73 Then
# Insert line
  ILINE = fmet I_ESSEMPPERCNT.ADDLINE("PERCNT", [V]CST_ALASTPOS)
  If ILINE <> [V]CST_ANOTDEFINED Then
    Call AM_TCH_NUMLIG(ILINE)
    Call SHOW_ESSEMPPERCNT_PERCNT(ILINE)
    GLOBILINE = ILINE
  Else
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSEMPPERCNT)
    GERR = 4
    mkstat = 2
    GOK = 1
    End
  Endif
  Affzo [M:ESPRC]10

  #Manage localisations
  Call HIDE_ACTIVITYFIELDS From WESSPERCNTHIDE
  Call SHOW_LEGACTCALLS From WESSPERCNTSHOW

Elsif status = 65 #or status = 71 Then
  If status = 65
    ILINE = [M:ESPRC]TCH_NUMLIG(nolign-1)
  Elsif status = 71
    ILINE = maxtab(I_ESSEMPPERCNT.PERCNT)
  Endif
  # Delete a line
  IRET = fmet I_ESSEMPPERCNT.ADELLINE("PERCNT",  I_ESSEMPPERCNT.PERCNT(ILINE).AORDER)

  If IRET = [V]CST_ANOTDEFINED Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSEMPPERCNT)
    GOK = 0
    GERR = 1
    mkstat = 2
  Endif
Elsif status = 71 Then
  If GLOBILINE <> AVOID.AINT and [M:ESPRC]NAMCNT(nolign-1)=AVOID.ACHAR and [M:ESPRC]SRNCNT(nolign-1)=AVOID.ACHAR
    # Delete a line
    IRET = fmet I_ESSEMPPERCNT.ADELLINE("PERCNT",  I_ESSEMPPERCNT.PERCNT(GLOBILINE).AORDER)
    Raz GLOBILINE
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSEMPPERCNT)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
Endif
End

Subprog C_CNTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
  Goto CNTTYP
Endif
End

Subprog C_NAMCNT(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  Goto NAMCNT
Endif
End

Subprog C_SRNCNT(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  Goto SRNCNT
Endif
End


Subprog AM_CNTTYP(VALEUR)
Variable Integer VALEUR
$CNTTYP
Local Integer S
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)>0 or func DIVPAYE.IS_KZA(GCURLEG)>0 or func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)>0
  I_ESSEMPPERCNT.PERCNT([M:ESPRC]TCH_NUMLIG(nolign-1)).CNTTYP = VALEUR

  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPPERCNT) From ESS_WRKFLOW_FUNC_HYBRID
  If GERR = 1 Then
    I_ESSEMPPERCNT.PERCNT([M:ESPRC]TCH_NUMLIG(nolign-1)).CNTTYP = I_ESSEMPPERCNT.PERCNT([M:ESPRC]TCH_NUMLIG(nolign-1)).snapshot.CNTTYP
    S = fmet I_ESSEMPPERCNT.PERCNT([M:ESPRC]TCH_NUMLIG(nolign-1)).ADELETERRORALL() #Mandatory - snapshot will reset to void
    GERR = 1
    mkstat = 2
    End
  Else
    Call UPDATE_ESSEMPPERCNT_PERCNT([M:ESPRC]TCH_NUMLIG(nolign-1))
  Endif
Endif
End

