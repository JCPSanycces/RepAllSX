  I_ESSEMPPERCNT.PERCNT(VALEUR).TCH_NUMLIG = I_ESSEMPPERCNT.PERCNT(VALEUR).snapshot.TCH_NUMLIG
  S = fmet I_ESSEMPPERCNT.PERCNT(VALEUR).ADELETERRORALL() #Mandatory - snapshot will reset to void
  GERR = 1
  mkstat = 2
  End
Else
  Call UPDATE_ESSEMPPERCNT_PERCNT(VALEUR)
Endif
End

