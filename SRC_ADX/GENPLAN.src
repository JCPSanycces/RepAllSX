 Endif
Next I

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANRAZ"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANRAZ"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANRAZ"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANRAZ"+num$(I),"adx",0),STAT) From ORDSYS
 Else
