   If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : Endif
