 Endif
Next I

Return

##################################
## Evaluation des rubriques
##################################
$CALRUB
SPA = 0
NBRUB = 0
NBPLAN = 0
NBPAS = 0
Gosub OUVRE
For [RUB]RUB1 Where LEG=LEGPLAN
 OKRUB = 1
 If [F:RUB]CODACT<>""
  Read [ACV]CODACT = [F:RUB]CODACT
  If fstat or [F:ACV]FLACT<>2
   OKRUB = 0
  Endif
 Endif
 If OKRUB
  NBRUB += 1
  NBPAS +=1
  If NBRUB>MAXRUB
   Gosub FERME
   NBRUB = 1
   Gosub OUVRE
  Endif
  Wrseq
  Wrseq "## Rubrique ";[F:RUB]COD
  Wrseq
  Wrseq space$(SPA);'RUB = "'+[F:RUB]COD+'"'
  If [F:RUB]DESPRN<>""
   If [F:RUB]TYPRUB=6 & instr(1,[F:RUB]DESPRN,"F:ORG")
    Wrseq space$(SPA);"CAISSE = ";num$([F:RUB]CAI);" : Gosub SET_CAISSE From GPLAN"
   Endif
   Wrseq space$(SPA);"LIBRUB = ";vireblc(format$("KT:250X",[F:RUB]DESPRN),2)
  Else
   Wrseq space$(SPA);"LIBRUB = ''"
  Endif
  Wrseq space$(SPA);'If PASAPAS=0 | PASAPAS='+num$(NBPAS)
  SPA +=1
  Wrseq space$(SPA);'If PASAPAS<>0 : PASAPAS = '+num$(NBPAS+1)+' : Endif'
  FLIF = 0

  If [F:RUB]ROW <= 15000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB1("+num$([F:RUB]ROW)+")=1)"
  Elsif[F:RUB]ROW <= 30000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB2("+num$([F:RUB]ROW-15000)+")=1)"
  Elsif[F:RUB]ROW <= 45000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB3("+num$([F:RUB]ROW-30000)+")=1)"
  Elsif[F:RUB]ROW <= 60000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB4("+num$([F:RUB]ROW-45000)+")=1)"
  Elsif[F:RUB]ROW <= 75000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB5("+num$([F:RUB]ROW-60000)+")=1)"
  Elsif[F:RUB]ROW <= 90000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB6("+num$([F:RUB]ROW-75000)+")=1)"
  Elsif[F:RUB]ROW < 100000
   Wrseq space$(SPA);"OKRUB  = (GPRFTAB7("+num$([F:RUB]ROW-90000)+")=1)"
  Endif

  For [ECD]ECD0 Where LEG=LEGPLAN and RUB=[F:RUB]COD
   Read [ECH]ECH0 = LEGPLAN;[F:ECD]COD
   If [F:ECD]CCL=2
    Wrseq space$(SPA);"If !OKRUB";
   Else
    Wrseq space$(SPA);"If OKRUB";
   Endif
   If [F:ECD]DATSTR<>[0/0/0]
    Wrseq " & DATPAY>=["+format$(GFMD,[F:ECD]DATSTR)+"]";
   Endif
   If [F:ECD]DATEND<>[0/0/0]
    Wrseq " & DATPAY<=["+format$(GFMD,[F:ECD]DATEND)+"]";
   Endif
   Wrseq " : ## Exception"-[F:ECH]COD
   SPA += 1

   If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
       Wrseq space$(SPA);'Read [F:ECH]ECH0 = "' + LEGPLAN + '";"' + [F:ECH]COD + '"'
   Endif

   Gosub EXCEPTION
   If FLCRIT : SPA += 1 : Endif
   If [F:ECH]POP<>""
   #MIPEA - 2016-08-15 - X3PEOP-763 - START
   Wrseq space$(SPA);'Read [HRPOA]POA0 = [F:ECH]POP;MATRI;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT'
   #Wrseq space$(SPA);'Read [HRPOA]POA0 = "';[F:ECH]POP;'";MATRI'
   #MIPEA - 2016-08-15 - X3PEOP-763 - END
    Wrseq space$(SPA);'If !fstat'
    SPA += 1
   Endif
   If [F:ECD]CCL=2
    Wrseq space$(SPA);"OKRUB = 1"
   Else
    Wrseq space$(SPA);"OKRUB = 0"
   Endif
   If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
   If FLCRIT : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
   SPA -= 1
   Wrseq space$(SPA);"Endif"
  Next
  If [F:RUB]VLYSTR<>[0/0/0]
   Wrseq space$(SPA);"OKRUB *= (DATDEB>=["+format$(GFMD,[F:RUB]VLYSTR)+"])"
  Endif
  If [F:RUB]VLYEND<>[0/0/0]
   Wrseq space$(SPA);"OKRUB *= (DATFIN<=["+format$(GFMD,[F:RUB]VLYEND)+"])"
  Endif
  For I=1 To dim([F:RUB]CNDCAL)
   If [F:RUB]CNDCAL(I-1)<>""
    Call CONVERT([F:RUB]CNDCAL(I-1))
    Wrseq space$(SPA);"OKRUB *= (";vireblc(format$("KT:250X",[F:RUB]CNDCAL(I-1)),2);")"
   Endif
  Next I
  Wrseq space$(SPA);"If OKRUB"
  SPA += 1 : FLIF = 1

#JASMI - 2016-09-16 - X3PEOP-763 - START
#  If [F:RUB]CUMNUMADI<>"" & RAZCUMRUB(val(right$([F:RUB]CUMNUMADI,len([F:RUB]CUMNUMADI))))<>len(mess(0,10334,1))
  If [F:RUB]CUMNUMADI<>"" & RAZCUMRUB(val(right$([F:RUB]CUMNUMADI,len([F:RUB]CUMNUMADI))))<>7
#JASMI - 2016-09-16 - X3PEOP-763 - END

#JASMI - 2016-09-16 - X3PEOP-763 - START
#   Wrseq space$(SPA);'CUMNUMADI = ';[F:RUB]CUMNUMADI
   Wrseq space$(SPA);'CUMNUMADI = "';[F:RUB]CUMNUMADI+'"'
#JASMI - 2016-09-16 - X3PEOP-763 - END
  Endif

  Case [F:RUB]TYPRUB

  When 1 : # Montant=base

   If [F:RUB]BAS<>""
    Call CONVERT([F:RUB]BAS)
    If [F:RUB]DEC=9
     Wrseq space$(SPA);PRUB+[F:RUB]COD;" = fix(";vireblc(format$("KT:250X",[F:RUB]BAS),2);")"
    Else
     Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]BAS),2);
     If [F:RUB]DEC=0
      Wrseq ",";num$(ARO);")"
     Else
      Wrseq ",";num$([F:RUB]DEC);")"
     Endif
    Endif
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = 0"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = '+PRUB+[F:RUB]COD
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 1' :#77022
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 2 : # Montant=base*taux

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = fix(BASE*TAUX)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   SPA -=1
   Wrseq space$(SPA);'Endif'
   Gosub ENTREEPAS

   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = fix(BASE*TAUX)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 3 : # Montant=base*taux/100

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = fix(BASE*TAUX/100)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   SPA -=1
   Wrseq space$(SPA);'Endif'
   Gosub ENTREEPAS

   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = fix(BASE*TAUX/100)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 4 : # Intervalle
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   For I=1 To [F:RUB]ITVNBR
    Wrseq space$(SPA);
    If I=1 : Wrseq "If "; : Else : Wrseq "Elsif "; : Endif
    If num$([F:RUB]ITVLIM(I))=num$(val(num$([F:RUB]ITVLIM(I))))
     Wrseq "BASE<";num$([F:RUB]ITVLIM(I))
    Elsif num$([F:RUB]ITVLIM(I))=""
     Wrseq "BASE<";num$(0)
    Else
     Wrseq "BASE<V_";num$([F:RUB]ITVLIM(I))
    Endif
    If [F:RUB]ITVAMT(I-1)<>""
     Call CONVERT([F:RUB]ITVAMT(I-1))
     If [F:RUB]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT(I-1)),2);",";num$(ARO);")"
     Elsif [F:RUB]DEC=9
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = fix(";vireblc(format$("KT:250X",[F:RUB]ITVAMT(I-1)),2);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT(I-1)),2);",";num$([F:RUB]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = 0"
    Endif
   Next I
   If [F:RUB]ITVNBR>0
    Wrseq space$(SPA);"Else"
    If [F:RUB]ITVNBR>1 & [F:RUB]ITVAMT([F:RUB]ITVNBR-1)<>""
     Call CONVERT([F:RUB]ITVAMT([F:RUB]ITVNBR-1-1))
     If [F:RUB]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT([F:RUB]ITVNBR-1)),2);",";num$(ARO);")"
     Elsif [F:RUB]DEC=9
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = fix(";vireblc(format$("KT:250X",[F:RUB]ITVAMT([F:RUB]ITVNBR-1)),2);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT([F:RUB]ITVNBR-1)),2);",";num$([F:RUB]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = 0"
    Endif
    Wrseq space$(SPA);"Endif"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 5 : # Assiette

   Gosub DEBEXO
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If NEXO2
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+" = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOS"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+" = BASE-PEXOS"
    Wrseq space$(SPA);"Endif"
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+"(2) = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOP"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+"(2) = BASE-PEXOP"
    Wrseq space$(SPA);"Endif"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD+" = BASE"
    Wrseq space$(SPA);PRUB+[F:RUB]COD+"(2) = BASE"
   Endif
   If [F:RUB]CUMBAS<>""
    Wrseq space$(SPA);PCUM+[F:RUB]CUMBAS+" += BASE"
   Endif
   If [F:RUB]REG<>2
    Wrseq space$(SPA);"SOMTR = 0"
   Endif
   OK = 0
   For K=0 To dim([F:RUB]AMTMAX)-1
    If [F:RUB]AMTMAX(K)<>""
     OK = 1
     Call CONVERT([F:RUB]AMTMAX(K))
     Wrseq space$(SPA);"PLAFOND = ";vireblc(format$("KT:250X",[F:RUB]AMTMAX(K)),2)
     If [F:RUB]REG=2
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),";PCUM;[F:RUB]CUMMAX(K);"(1)+PLAFOND)"
      For J=0 To K
       If [F:RUB]CUMAMT(J)<>""
        Wrseq space$(SPA);"TRANCHE -= ";PCUM;[F:RUB]CUMAMT(J)
       Endif
      Next J
     Else
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),PLAFOND)-SOMTR : SOMTR += TRANCHE"
     Endif
     If [F:RUB]DEC=0
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$(ARO);")"
     Elsif [F:RUB]DEC=9
      Wrseq space$(SPA);"TRANCHE = fix(TRANCHE)"
     Else
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$([F:RUB]DEC);")"
     Endif
     Wrseq space$(SPA);'MEM    = 1'
     Wrseq space$(SPA);'RANG   = '+num$([F:RUB]ROW)
     Wrseq space$(SPA);'TAUX   = PLAFOND'
     Wrseq space$(SPA);'MONT   = TRANCHE'
     If K<3
      Wrseq space$(SPA);'[L]TYP = '+num$(K+3)
     Else
      Wrseq space$(SPA);'[L]TYP = '+num$(K+7)
     Endif
     Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
     Wrseq space$(SPA);"If GOK<1 : Return : Endif"

     Gosub FINEXO
     Gosub RETOURPAS
     If FLIF
      SPA -= 1
      Wrseq space$(SPA);"Endif"
     Endif
     SPA -=1
     Wrseq space$(SPA);'Endif'
     Gosub ENTREEPAS
     Gosub DEBEXO

     If [F:RUB]CUMMAX(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUB]CUMMAX(K);" += PLAFOND"
     Endif
     If [F:RUB]CUMAMT(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUB]CUMAMT(K);" += TRANCHE"
     Endif
     If NEXO2
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOS"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUB]COD;" = TRANCHE-PEXOS : PEXOS = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOS -= TRANCHE"
      Wrseq space$(SPA);"Endif"
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOP"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUB]COD;" = TRANCHE-PEXOP : PEXOP = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOP -= TRANCHE"
      Wrseq space$(SPA);"Endif"
     Else
      Wrseq space$(SPA);PTRS(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);PTRP(K);[F:RUB]COD;" = TRANCHE"
     Endif
    Endif
   Next I
   If !OK
    Wrseq space$(SPA);'MEM     = 1'
    Wrseq space$(SPA);'RANG    = '+num$([F:RUB]ROW)
    Wrseq space$(SPA);'[L]TYP  = dim([F:RUB]AMTMAX)'
    Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
    Wrseq space$(SPA);"If GOK<1 : Raz BASE : Return : Endif"
   Endif
   Wrseq space$(SPA);"Raz BASE"
   Gosub FINEXO

  When 6 : # Cotisation
   Gosub DEBEXO
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUB]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOS<>0 : BASE = max(0,BASE-PEXOS) : Endif"
    Wrseq space$(SPA);"If BASE<0 & PEXOS<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOS/100)"
   Endif
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = fix(BASE*TAUX/100)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2
    If [F:RUB]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   Gosub FINEXO
   Gosub RETOURPAS
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   SPA -=1
   Wrseq space$(SPA);'Endif'
   Gosub ENTREEPAS
   Gosub DEBEXO
   If [F:RUB]DESPRN<>""
    If [F:RUB]TYPRUB=6 & instr(1,[F:RUB]DESPRN,"F:ORG")
     Wrseq space$(SPA);"CAISSE = ";num$([F:RUB]CAI);" : Gosub SET_CAISSE From GPLAN"
    Endif
    Wrseq space$(SPA);"LIBRUB = ";vireblc(format$("KT:250X",[F:RUB]DESPRN),2)
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUB]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOP<>0 : BASE = max(0,BASE-PEXOP) : Endif"
    Wrseq space$(SPA);"If BASE<0 & PEXOP<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOP/100)"
   Endif
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = fix(BASE*TAUX/100)"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2
    If [F:RUB]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub FINEXO
   Gosub RETOURPAS

  When 7 : # Grille

   Wrseq space$(SPA);'GRILLE = "';[F:RUB]TBLCOD;'"'
   Wrseq space$(SPA);'GRICOL = ';num$([F:RUB]TBLCOL)
   Wrseq space$(SPA);"Raz GRICLE"
   For I=0 To 2
    If [F:RUB]TBLFRM(I)<>""
     Wrseq space$(SPA);"GRICLE(";num$(I);") = num$(";vireblc(format$("KT:250X",[F:RUB]TBLFRM(I)),2);")"
    Endif
   Next I
   Wrseq space$(SPA); "If [L]RETRO : Gosub LECGRILLE From TRTRETCAL : Endif"
   Wrseq space$(SPA);"Gosub GRILLE From GPLAN"
   Wrseq space$(SPA); "If [L]RETRO : Gosub ANUGRILLE From TRTRETCAL : Endif"
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);"MONT = fix(MONT)"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUB]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 8 : # Historique

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"DATED = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"DATED = [0/0/0]"
   Endif
   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"DATEF = ";
    Gosub WR_RAT2
    Wrseq space$(SPA);"If DATEF>=DATPAY : DATEF = DATPAY-1 : Endif"
   Else
    Wrseq space$(SPA);"DATEF = DATPAY-1"
   Endif
   Call HISTO(SPA)
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);"MONT = fix(MONT)"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUB]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 9 : # Spécifique

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   #FRLAA - Check "STDPLAN"+GCURLEG
   Wrseq space$(SPA);'If STDPLAN : ACTION = "CALRUB" : Gosub ACTION From ="STDPLAN"+GCURLEG : Endif'
   Wrseq space$(SPA);'If SPEPLAN : ACTION = "CALRUB" : Gosub ACTION From ="SPEPLAN"+GCURLEG : Endif'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Elsif [F:RUB]DEC=9
    Wrseq space$(SPA);"MONT = fix(MONT)"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;' = MONT'
   Wrseq space$(SPA);'TYP  = 1'
   #FRLAA - 2016-03-30 - REQUIREMENT 114309 US 147 - START
   If [F:RUB]TMPCAL<>2
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   #FRLAA - 2016-03-30 - REQUIREMENT 114309 US 147 - END
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  When 10 : # Régularisation

   Wrseq space$(SPA);'K = find("';[F:RUB]RGL;'",REGRUB1(1..NBREGUL))'
   Wrseq space$(SPA);'OKRUB *= (K<>0) & REGUL=0'
   Wrseq space$(SPA);"If OKRUB"
   SPA += 1
   Read [RGL]RGL0  = [F:RUB]LEG;[F:RUB]RGL
   Read [RUB2]RUB0 = [F:RGL]LEG;[F:RGL]RUB
   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL1(K)"
   Wrseq space$(SPA);"TYP  = 7"
   Wrseq space$(SPA);PRUB+[F:RUB]COD;'(1) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   Gosub RETOURPAS
   SPA -=1
   Wrseq space$(SPA);'Endif'
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   SPA -=1
   Wrseq space$(SPA);'Endif'
   Gosub ENTREEPAS

   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL2(K)"
   Wrseq space$(SPA);"TYP  = 8"
   Wrseq space$(SPA);PRUB+[F:RUB]COD;'(2) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub RETOURPAS

  Endcase

  ## Cumuls
  If [F:RUB]NBRCUM<>0
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   SPA -=1
   Wrseq space$(SPA);'Endif'
   Gosub ENTREEPAS
  Endif
  For I=0 To [F:RUB]NBRCUM-1
  #91750
   If [F:RUB]CNDCUM(I)<>""
    Call CONVERT([F:RUB]CNDCUM(I))
    Wrseq space$(SPA);"OKCUM = (";vireblc(format$("KT:250X",[F:RUB]CNDCUM(I)),2);")"
    Wrseq space$(SPA);"If OKCUM"
    SPA +=1
   Endif
   #
   Case [F:RUB]OPTCUM(I)
    When 1 : # -PS
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" -= ";PRUB;[F:RUB]COD
    When 2 : # -PP
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" -= ";PRUB;[F:RUB]COD;"(2)"
    When 3 : # +PS
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" += ";PRUB;[F:RUB]COD
    When 4 : # +PP
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" += ";PRUB;[F:RUB]COD;"(2)"
    When 5 : # RAZ
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" = 0"
   Endcase
   #91750
   If [F:RUB]CNDCUM(I)<>""
    SPA -=1
    Wrseq space$(SPA);"Endif"
   Endif
   #
Next I
  If FLIF
   SPA -= 1
   Wrseq space$(SPA);"Endif"
  Endif
  Wrseq space$(SPA) ; "If [L]RETRO_RAPPEL : Gosub RAPPEL From TRTRETCAL : Endif"
  SPA -=1
  Wrseq space$(SPA);'Endif'
 Endif
Next
Wrseq
Wrseq 'If PASAPAS<>0 : FINPAS = 1 : Endif'
Wrseq
Gosub FERME
Return

$WR_BAS
Call CONVERT([F:RUB]BAS)
Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
Return

$WR_RAT1
Call CONVERT([F:RUB]RAT1)
Wrseq vireblc(format$("KT:250X",[F:RUB]RAT1),2)
Return

$WR_RAT2
Call CONVERT([F:RUB]RAT2)
Wrseq vireblc(format$("KT:250X",[F:RUB]RAT2),2)
Return

$RETOURPAS
Wrseq space$(SPA);'If PASAPAS<>0 & (TYPPAS=2 | (TYPPAS=1 & [M:PAS]GOTORUB=RUB))'
SPA +=1
Wrseq space$(SPA);"FINPAS = 2"
Wrseq space$(SPA);"Return"
SPA -=1
Wrseq space$(SPA);"Endif"
Return

$ENTREEPAS
Wrseq
Wrseq "## Suite Rubrique ";[F:RUB]COD
Wrseq
NBPAS +=1
Wrseq space$(SPA);'If PASAPAS=0 | PASAPAS='+num$(NBPAS)
SPA +=1
Wrseq space$(SPA);'If PASAPAS<>0 : PASAPAS = '+num$(NBPAS+1)+' : Endif'
Wrseq space$(SPA);"If OKRUB"
SPA += 1 : FLIF = 1
Return

## Exonérations
$DEBEXO
NEXO1 = 0
NEXO2 = 0
FLIF2 = 0
For [EXO]EXO1 Where LEG=[L]LEGPLAN & RUBCOD=[F:RUB]COD
 If [F:EXO]FLG=2
  NEXO2 += 1
  Wrseq space$(SPA);'CEXO('+num$(NEXO2)+') = "'+[F:EXO]COD+'"'
  Wrseq space$(SPA);'TEXO1('+num$(NEXO2)+') = '+num$([F:EXO]RAT1);
  If [F:EXO]RAT1=100 & [F:EXO]MAX1<>""
   Wrseq space$(SPA);' : PEXO1('+num$(NEXO2)+') = max(0,'+PRUB+[F:EXO]MAX1+')'
  Else
   Wrseq
  Endif
  Wrseq space$(SPA);'TEXO2('+num$(NEXO2)+') = '+num$([F:EXO]RAT2);
  If [F:EXO]RAT2=100 & [F:EXO]MAX2<>""
   Wrseq space$(SPA);' : PEXO2('+num$(NEXO2)+') = max(0,'+PRUB+[F:EXO]MAX2+')'
  Else
   Wrseq
  Endif
  CEXO2(NEXO2) = [F:EXO]COD
 Else
  NEXO1 += 1
  CEXO1(NEXO1) = [F:EXO]COD
 Endif
Next
If NEXO1 or NEXO2
 Wrseq space$(SPA);"OK = 1"
Endif
If NEXO1
 For J=1 To 4
  Wrseq space$(SPA);' If [F:HRCTR]EXOCOD'+num$(J)+'<>"" & find([F:HRCTR]EXOCOD'+num$(J);
  For I=1 To NEXO1
   Wrseq ',"'+CEXO1(I)+'"';
  Next I
  Wrseq ')'
  Wrseq "&  & ([F:HRCTR]EXOSTR"+num$(J)+"=[0/0/0] | DATPAY>=[F:HRCTR]EXOSTR"+num$(J)+")"
  Wrseq "&  & ([F:HRCTR]EXOEND"+num$(J)+"=[0/0/0] | DATPAY<=[F:HRCTR]EXOEND"+num$(J)+")"
  Wrseq space$(SPA);"  OK = 0"
  Wrseq space$(SPA);" Endif"
 Next J
Endif
If NEXO2
 Wrseq space$(SPA);'NEXO = '+num$(NEXO2)
 Wrseq space$(SPA);'Gosub TSTEXO From GPLAN'
Endif
If NEXO1 or NEXO2
 Wrseq space$(SPA);"If OK"
 SPA += 1 : FLIF2 = 1
Endif
Return

$FINEXO
If FLIF2
 SPA -= 1
 Wrseq space$(SPA);"Endif"
Endif
Return

$OUVRE
NBPLAN += 1
#FRLAA Check "WP+LEGPLAN"
PROG = "WP"+[L]LEGPLAN+"PLAN"+num$(NBPLAN)
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "$PLAN"
Return

$FERME
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

