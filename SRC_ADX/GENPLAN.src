$CASE_VAR
Local Integer IVAL, NBVAR
Wrseq "   Case [F:VLA]VARCOD"
For [VRA]VRA0 Where FLGEXS<>2 & LEG=LEGPLAN
 OK = 0
 Case NIV
  When 1 : If [F:VRA]FLGFDR=2 : OK = 1 : Endif
  When 2 : If [F:VRA]FLGCPY=2 : OK = 1 : Endif
  When 3 : If [F:VRA]FLGFCY=2 : OK = 1 : Endif
  When 4 : If [F:VRA]FLGEMP=2 : OK = 1 : Endif
 Endcase
 If OK
  NBVAR+=1
  If NIV<4
   IVAL+=1
   Wrseq '    When '+format$('K:12X','"'+[F:VRA]COD+'"')+' : '+format$('K:15X',PVAR+[F:VRA]COD)+' = [F:VLA]VARVAL'
&              +' : GVARVAL'+num$(NIV)+'('+num$(IVAL)+') = [F:VLA]VARVAL'
&              +' : GVARCOD'+num$(NIV)+'('+num$(IVAL)+') = [F:VLA]VARCOD'
  Else
   Wrseq '    When '+format$('K:12X','"'+[F:VRA]COD+'"')+' : '+format$('K:15X',PVAR+[F:VRA]COD)+' = [F:VLA]VARVAL'
  Endif
 Endif
Next
Wrseq "   Endcase"
If NIV<4
 Wrseq '   GNBRCOD'+num$(NIV)+' = '+num$(NBVAR)
Endif
Return

$RECUP_VAR
Local Integer IVAL
For [VRA]VRA0 Where FLGEXS<>2 & LEG=LEGPLAN
 OK = 0
 Case NIV
  When 1 : If [F:VRA]FLGFDR=2 : OK = 1 : Endif
  When 2 : If [F:VRA]FLGCPY=2 : OK = 1 : Endif
  When 3 : If [F:VRA]FLGFCY=2 : OK = 1 : Endif
 Endcase
 If OK
  IVAL+=1
  Wrseq '  If find("'+[F:VRA]COD+'", GVARCOD'+num$(NIV)+'(1..GNBRCOD'+num$(NIV)+'))'
&       +' : '+format$('K:15X',PVAR+[F:VRA]COD)+' = GVARVAL'+num$(NIV)+'('+num$(IVAL)+')'
&       +' : Endif'
 Endif
Next
Return
#MIPEA - 2018-04-11 - X3-83435 - START
#########################################
$MAJCUMEXT
PROG = "WP"+[L]LEGPLAN+"PLANCUMEXT"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''

Wrseq "$SETCUM"
Wrseq " For ";PHIS;"HSP3 Where BUL=[F:VEP3]BUL & TYP=6 & AMT<>0"
Wrseq "  Case ";PHIS;"RUB"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq '   When ';format$('K:13X','"'+[F:CUM]CUMCOD+'"');' : ';
 Wrseq format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';PHIS;'AMT'
Next
Wrseq "  Endcase"
Wrseq " Next"
Wrseq
Wrseq "Return"
Wrseq

Wrseq "$SAVECUM"
Wrseq "## Sauvegarde des cumuls"
For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(2)');' = ';PCUM;[F:CUM]CUMCOD;'(1)'
Next
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return
#MIPEA - 2018-04-11 - X3-83435 - END
#########################################
## Lecture des cumuls
#########################################
$MAJCUM
PROG = "WP"+[L]LEGPLAN+"PLANCUM"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "$LECTURE"
Wrseq "## Lecture cumuls mois précédent"
Wrseq "Filter [VEP3] Where EMP=MATRI & BUL<BULLETIN & CTRNUM=CTR"
Wrseq "Read [VEP3]VEP5 Last"
Wrseq "Filter [VEP3]"
Wrseq "If fstat>2 : DATPREC = [0/0/0] : Else : DATPREC = [F:VEP3]ENDDAT : Endif"
#MIPEA - 2016-11-28 - X3PEOP-1200- START
Wrseq "If fstat>2 : PERCODPREC = '' : Else : PERCODPREC = [F:VEP3]PERCOD : Endif"
