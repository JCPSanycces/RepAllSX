   #MIPEA - 2016-08-15 - X3PEOP-763 - END
   Wrseq space$(SPA);'If !fstat'
   SPA += 1
  Endif
#MIPEA - 2016-11-23 - X3PEOP-1200- START
  INICUMECH(P) = [F:ECC]TYP
#MIPEA - 2016-11-23 - X3PEOP-1200- END
  Wrseq space$(SPA);'INICUM = "'+[F:ECC]TYP+[F:ECC]TYP+'"'
  If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  If FLIF : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
 Next
 K = 0
#MIPEA - 2016-11-23 - X3PEOP-1200- START
  For [F:CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP<=1 & LEG=LEGPLAN
