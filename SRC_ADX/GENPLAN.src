 If K : Wrseq " Endif" : Endif
Next P
Wrseq ' ';'For K=1 To find("",CUMSVG)-1'
Wrseq ' ';' Assign "'+PCUM+'"+CUMSVG(K) With evalue("'+PCUMSVG+'"+CUMSVG(K))'
Wrseq ' ';'Next'
Wrseq "Else"
For [CUM]CUM0 Where CUMREP<>"" & CUMTYP<=1 & LEG=LEGPLAN
 Wrseq " ";PCUM;[F:CUM]CUMCOD;" = ";vireblc(format$("KT:250X",[F:CUM]CUMREP),2)
Next
