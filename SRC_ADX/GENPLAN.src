#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
#88856 : Etiquette active
$MAJCUM0
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
#JASMI - 2017-08-08 - X3-52263 - START
#[L]PROG = "WP"+[L]LEGPLAN+"PLANCUM"
[L]PROG = "WP"+[L]LEGPLAN+"PLANCUME"
#JASMI - 2017-08-08 - X3-52263 - END
#[L]PROG = "WPPLANCUME"
[L]INDPROG = 0
#[L]FICSRC = filpath("TRT", [L]PROG, "src", [L]APPLI)
[L]FICSRC = filpath("TRT", [L]PROG + num$([L]INDPROG), "src", [L]APPLI)
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Openo [L]FICSRC , 0
Wrseq [L]TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "$ECRITURE"
#JASMI - 2016-07-26 - START
#For [CUM]CUM1 Where CUMTMP<>2
For [CUM]CUM1 Where CUMTMP<>2 & LEG=LEGPLAN
#JASMI - 2016-07-26 - END
    If [L]NBCUM >= [L]MAXCUM
        [L]INDPROG += 1
        # => On va appeler la "suite" de l'étiquette ECRITURE dans un autre programme
        Wrseq "Gosub ECRITURE From"-[L]PROG+num$([L]INDPROG)
        Wrseq "Return"
        Openo
        [L]FICSRC = filpath("TRT", [L]PROG + num$([L]INDPROG), "src", [L]APPLI)
        Openo [L]FICSRC , 0
        Wrseq [L]TETADO-"Plan de paye"
        Wrseq "$ECRITURE"
        Raz [L]NBCUM
    Endif
    Wrseq 'RANG = ';format$("N:5#",[F:CUM]CUMROW);" : ";
    Wrseq 'RUB  = "';[F:CUM]CUMCOD;'" : ';
    Wrseq "MONT = ";PCUM;[F:CUM]CUMCOD;" : ";
    Wrseq "BASE = ";PCUM;[F:CUM]CUMCOD;"(2) : ";
    Wrseq "Gosub MAJCUM From GPLAN"
    Wrseq "If GOK<1 : Return : Endif"
    [L]NBCUM += 1
Next
K = 0
#JASMI - 2016-07-26 - START
#For [CUM]CUM0 Where CUMNUM>1 #MIPEA change here to be checked  ###CUMNUMADI>1#Frlaa Dev review check
For [CUM]CUM0 Where CUMNUMADI<>"" & LEG=LEGPLAN
#JASMI - 2016-07-26 - END
 K += 1
 If K=1
 Endif
#JASMI - 2016-07-26 - START
# Wrseq "[F:EPC]CUM"+num$([F:CUM]CUMNUM-1);" = ";PCUM;[F:CUM]CUMCOD
 Wrseq "[F:EPC]CUM"+num$(val(right$([F:CUM]CUMNUMADI,len([F:CUM]CUMNUMADI))));" = ";PCUM;[F:CUM]CUMCOD
#JASMI - 2016-07-26 - END
Next
If K
 Wrseq "If STACUM"
 Wrseq " Write [EPC]"
 Wrseq "Else"
 Wrseq " Rewrite [EPC]"
 Wrseq "Endif"
 Wrseq "If fstat"
 Wrseq ' GOK = 0 : Call FSTA("EPC") From GLOCK : Return'
 Wrseq "Endif"
Endif
Wrseq "Return"
Openo
For [L]NBCUM = 0 To [L]INDPROG
  Call VALID("TRT", [L]PROG + num$([L]NBCUM), [L]APPLI, [L]OK) From VALMSKSUB
Next
Return
 #FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END

#########################################
## Raz des cumuls
#########################################
$MAJCUM1
PROG = "WP"+[L]LEGPLAN+"PLANCUM1"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "## Raz"
Wrseq "$RAZCUM"
K = 0
For [CUM]CUM0 Where LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Raz "; : Else : Wrseq ","; : Endif
 Wrseq PCUM+[F:CUM]CUMCOD;
 K += 1
Next
Wrseq
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

#########################################
## Mise à jour des cumuls
#########################################
$MAJCUM2
PROG = "WP"+[L]LEGPLAN+"PLANCUM2"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
For INIV=2 To 4
 Wrseq "$LECTURE"+num$(INIV)
 Wrseq "## Critère"
 Case INIV
  When  2 : # Par société
   Wrseq "For I=1 To [V]GNBSITE"
   Wrseq " If [V]GSOCSITE(I)=SOCIETE : [L]CRITERE+=',"+'"'+"'+[V]GSITE(I)+'"+'"'+"' : Endif"
   Wrseq "Next"
   Wrseq "If instr(2,[L]CRITERE,',')"
   Wrseq " [L]CRITERE='find(FCY'+[L]CRITERE+')<>0'"
   Wrseq "Else"
   Wrseq " [L]CRITERE='FCY='+right$([L]CRITERE,2)"
   Wrseq "Endif"
  When  3 : # par site
   Wrseq "CRITERE = 'FCY=SITE'"
  When  4 : # par salarié
   Wrseq "CRITERE = 'CTRNUM<>"+'""'+"'"
 Endcase
 Wrseq
 Wrseq "## Lecture cumuls mois précédent"
 Wrseq "Filter [VEP3] Where EMP=MATRI  & BUL<BULLETIN & evalue(CRITERE)"
 Wrseq "Read [VEP3]VEP5 Last"
 Wrseq "Filter [VEP3]"
 Wrseq "If fstat>2 : DATPREC = [0/0/0] : Else : DATPREC = [F:VEP3]ENDDAT : Endif"
#MIPEA - 2016-11-28 - X3PEOP-1200- START
Wrseq "If fstat>2 : PERCODPREC = '' : Else : PERCODPREC = [F:VEP3]PERCOD : Endif"
Wrseq "If fstat>2 : PERYEAPREC = 0 : Else : PERYEAPREC = [F:VEP3]PERYEA : Endif"
Wrseq "If fstat>2 : PERNUMPREC = 0 : Else : PERNUMPREC = [F:VEP3]PERNUM : Endif"
#MIPEA - 2016-11-28 - X3PEOP-1200- END
 Wrseq "If DATPREC<>[0/0/0]"
 Wrseq " For ";PHIS;"HSP3 Where BUL=[F:VEP3]BUL & TYP=6 & AMT<>0"
 Wrseq "  Case ";PHIS;"RUB"
 For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP=INIV & LEG=LEGPLAN
  Wrseq '   When ';format$('K:13X','"'+[F:CUM]CUMCOD+'"');' : ';
  Wrseq format$('K:15X',PCUM+[F:CUM]CUMCOD);' = ';PHIS;'AMT'
 Next
 Wrseq "  Endcase"
 Wrseq " Next"
 Wrseq
 Wrseq "## Réinitialisation des cumuls"
 Wrseq " J = month(DATPREC)+1"
 Wrseq " K = month(DATFIN)+12*(year(DATFIN)-year(DATPREC))"
 For P=1 To len(mess(0,10334,1))
#MIPEA - 2016-11-23 - X3PEOP-1200- START
  Wrseq ' INICUM = "'+INICUM(P)+'"'+' #Periodicity-'+mess(P,10334,1)
#  Wrseq ' INICUM = "'+INICUM(P)+'"'
#MIPEA - 2016-11-23 - X3PEOP-1200- END
  For [ECC]ECC1 Where LEG=LEGPLAN and PER=P
   Read [ECH]ECH0 = LEGPLAN;[F:ECC]COD
   FLIF = 0
   If [F:ECH]FCY<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'SITE="';[F:ECH]FCY;'"'
   Endif
   If [F:ECH]PRF<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'PROFIL="';[F:ECH]PRF;'"'
   Endif
   If [F:ECH]SRV<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'SERVICE="';[F:ECH]SRV;'"'
   Endif
   If [F:ECH]EMPSTR<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'MATRI>="';[F:ECH]EMPSTR;'"'
   Endif
   If [F:ECH]EMPEND<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'MATRI<="';[F:ECH]EMPEND;'"'
   Endif
   If [F:ECH]CRI<>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq "(";vireblc(format$("KT:250X",[F:ECH]CRI),2);")"
   Endif
   If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <>""
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq '( find([F:HRCTR]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+format$("D:YYYYMMDD",[F:HRCTR]CTRDAT) , [F:ECH]CTRCRI) )'
   Endif
   If [F:ECC]DATSTR<>[0/0/0]
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'DATPAY>=[';format$(GFMD,[F:ECC]DATSTR);"]"
   Endif
   If [F:ECC]DATEND<>[0/0/0]
    If !FLIF : FLIF = 1 : Wrseq " If "; : Else : Wrseq "& &  "; : Endif
    Wrseq 'DATPAY<=[';format$(GFMD,[F:ECC]DATEND);"]"
   Endif
   SPA = 2
   If [F:ECH]POP<>""
   #MIPEA - 2016-08-15 - X3PEOP-763 - START
   Wrseq space$(SPA);'Read [HRPOA]POA0 = [F:ECH]POP;MATRI;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT'
   #Wrseq space$(SPA);'Read [HRPOA]POA0 = "';[F:ECH]POP;'";MATRI'
   #MIPEA - 2016-08-15 - X3PEOP-763 - END
    Wrseq space$(SPA);'If !fstat'
    SPA += 1
   Endif
   Wrseq space$(SPA);'INICUM = "'+[F:ECC]TYP+[F:ECC]TYP+'"'
   If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
   If FLIF : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  Next
  K = 0
#MIPEA - 2016-11-23 - X3PEOP-1200- START
For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP=INIV & LEG=LEGPLAN
## PEVAN - 2018-05-02 - X3-86069 - START
#   If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC)' : Endif
   If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : Endif
## PEVAN - 2018-05-02 - X3-86069 - END
   K += 1
   Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
   Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
  Next
  For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP=INIV & LEG=LEGPLAN
## PEVAN - 2018-05-02 - X3-86069 - START
#   If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC)' : Endif
   If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : Endif
## PEVAN - 2018-05-02 - X3-86069 - END
   K += 1
   Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
  Next
#  For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI<>"" & CUMTYP=INIV & LEG=LEGPLAN
#   If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : Endif
#   K += 1
#   Wrseq '  ';format$('K:23X',PCUMSVG+[F:CUM]CUMCOD);' = ';vireblc(format$("KT:250X",[F:CUM]CUMINI),2)
#   Wrseq '  ';'CUMSVG(find("",CUMSVG)) = "'+[F:CUM]CUMCOD+'"'
#  Next
#  For [CUM]CUM0 Where CUMTMP<>2 & CUMPER=P & CUMINI="" & CUMTYP=INIV & LEG=LEGPLAN
#   If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : Endif
#   K += 1
#   Wrseq '  ';format$('K:15X',PCUM+[F:CUM]CUMCOD);' = 0'
#  Next
   #FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
  #105783 : First item is 'none' ---> Add -1
#MIPEA - 2016-11-23 - X3PEOP-1200- END
  #MIPEA - 2016-10-27 - X3PEOP-1200 - START
    For J=1 To [L]NBCUMTTL
   #For J=1 To len(mess(0,349,1))-1
   #MIPEA - 2016-10-27 - X3PEOP-1200 - END
   If RAZCUMRUB(J)=P
#MIPEA - 2016-11-23 - X3PEOP-1200- START
## PEVAN - 2018-05-02 - X3-86069 - START
#    If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC)' : Endif
    If K=0 : Wrseq ' If Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : Endif
## PEVAN - 2018-05-02 - X3-86069 - END
#    If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : Endif
#MIPEA - 2016-11-23 - X3PEOP-1200- END
    K += 1
    Wrseq "  [F:EPC]CUM"+num$(J);" = 0"
   Endif
  Next J


#  If [L]NBCUMTTL>0
#    For J=1 To [L]NBCUMTTL
#     If RAZCUMRUB(J)=P
#      If K=0 : Wrseq ' If K>=J & instr(1,seg$(INICUM,J,K),"O")' : Endif
#      K += 1
#      Wrseq "  [F:EPC]CUM"+num$(J);" = 0"
#     Endif
#    Next J
#  Endif

 #FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END

  If K : Wrseq " Endif" : Endif
 Next P
 Wrseq ' ';'For K=1 To find("",CUMSVG)-1'
 Wrseq ' ';' Assign "'+PCUM+'"+CUMSVG(K) With evalue("'+PCUMSVG+'"+CUMSVG(K))'
 Wrseq ' ';'Next'
 Wrseq "Else"
 For [CUM]CUM0 Where CUMREP<>"" & CUMTYP=INIV & LEG=LEGPLAN
  Wrseq " ";PCUM;[F:CUM]CUMCOD;" = ";vireblc(format$("KT:250X",[F:CUM]CUMREP),2)
 Next
 Wrseq "Endif"
 Wrseq "## Sauvegarde des cumuls"
 For [CUM]CUM1 Where CUMTMP<>2 & CUMTYP=INIV & LEG=LEGPLAN
  Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(2)');' = ';PCUM;[F:CUM]CUMCOD;'(1)'
 Next
 Wrseq "Return"
 Wrseq
Next
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

Subprog ADDCRIT(CRITERE,SUBCRIT)
Variable Char CRITERE
Value    Char SUBCRIT
If CRITERE<>""
 CRITERE -= "&"-SUBCRIT
Else
 CRITERE = SUBCRIT
Endif
End

Subprog SETPAR
Local Integer ILEG
Local Char LEGPLAN (GLONADI)
[L]LEGPLAN=GCURLEG
ILEG=find([L]LEGPLAN,GDOSLEG(1..GNBLEG))
If GMAS
 Call SETPAR From GENPLANMS
Endif
If GOK=1
 Local Integer VALPAR
 VALPAR = 1
 Goto MAJPAR
Endif
#MIPEA - 2016-07-20 - REQ 114309 US274 - START
End
#MIPEA - 2016-07-20 - REQ 114309 US274 - END

Subprog RAZPAR
Local Integer VALPAR
VALPAR = 0
Goto MAJPAR

$MAJPAR
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Call DEBTRANS From GLOCK
Gosub TR_PAR
GPLANOK(ILEG) = VALPAR
End

$TR_PAR
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "*";[L]LEGPLAN;"PLAN"
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL PLAN" : Goto ROLL_PAR
 Elsif fstat
  Raz [F:ADW]
  [F:ADW]CMP = "*"
  [F:ADW]FCY = [L]LEGPLAN
  [F:ADW]PARAM = "PLAN"
  [F:ADW]VALEUR = num$(VALPAR)
  Write [ADW]
 Elsif [F:ADW]VALEUR<>num$(VALPAR)
  [F:ADW]VALEUR = num$(VALPAR)
  Rewrite [ADW]
#MIPEA - 2018-03-15- US X3-81875- START
  If dim(GACTX)>=0
    Local Integer WIND_RESULT
    WIND_RESULT= fmet GACTX.APARAM._ACLEAN
  Endif
#MIPEA - 2018-03-15- US X3-81875- END
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_PAR
 Endif
Commit
Return

$AB_PAR
Rollback
Return

$ROLL_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif

$EXCEPTION
FLCRIT = 0
If [F:ECH]FCY<>""
 Gosub EXCEPT
 Wrseq 'SITE="'+[F:ECH]FCY+'"'
Endif
If [F:ECH]PRF<>""
 Gosub EXCEPT
 Wrseq 'PROFIL="'+[F:ECH]PRF+'"'
Endif
If [F:ECH]SRV<>""
 Gosub EXCEPT
 Wrseq 'SERVICE="'+[F:ECH]SRV+'"'
Endif
If [F:ECH]EMPSTR<>""
 Gosub EXCEPT
 Wrseq 'MATRI>="'+[F:ECH]EMPSTR+'"'
Endif
If [F:ECH]EMPEND<>""
 Gosub EXCEPT
 Wrseq 'MATRI<="'+[F:ECH]EMPEND+'"'
Endif
If [F:ECH]CRI<>""
 Gosub EXCEPT
 Wrseq "(";vireblc(format$("KT:250X",[F:ECH]CRI),2);")"
Endif
If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
 Gosub EXCEPT
 Wrseq 'find([F:HRCTR]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+format$("D:YYYYMMDD",[F:HRCTR]CTRDAT), [F:ECH]CTRCRI)'
Endif
Return

$EXCEPT
If FLCRIT
 Wrseq "&";space$(SPA);"& ";
Else
 Wrseq space$(SPA);"If ";
 FLCRIT = 1
Endif
Return

Subprog CONVERT(FORMULE)
Variable Char FORMULE()
Local Integer I , J , T , OK
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 1
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  If find(OP,"R_","C_") & mid$(FORMULE,I+1,1)<>"("
   FORMULE = left$(FORMULE,I)+"(1)"+right$(FORMULE,I+1)
   I += 3
  Endif
  I += 1
 Else
  I += 1
 Endif
Wend
End

Subprog HISTO(SPA)
Value Integer SPA
Local Integer I , J , K
Local Char    FORMULE(250) , EXPRESS(250)
Local Char    OPE(2) , CODE(20)
FORMULE = vireblc(format$("KT:250X",[F:RUB]BAS),2)
I = 1
EXPRESS = ""
K = 0
While I<=len(FORMULE)
 OPE = mid$(FORMULE,I,2)
 If find(OPE,"R_","V_","C_")
  J = I+2 : I += 2
  While I<len(FORMULE) & (instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_(",mid$(FORMULE,I+1,1))
&                    | (instr(1,")",mid$(FORMULE,I+1,1)) & instr(1,"(",mid$(FORMULE,I-1,1)) ))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Wrseq space$(SPA);'RUBHIS = "';CODE;'"'
  Case OPE
   When "R_"
    Wrseq space$(SPA);"Gosub HISTORUB From GPLAN"
    If mid$ (CODE,len(CODE)-2,3)='(2)' : K+=1 : Endif
   When "C_"
    Wrseq space$(SPA);"Gosub HISTOCUM From GPLAN"
   When "V_"
    Wrseq space$(SPA);"Gosub HISTOVAR From GPLAN"
  Endcase
  K += 1
  Wrseq space$(SPA);"HVAR("+num$(K)+") = MONT"
  EXPRESS += "HVAR("+num$(K)+")"
 Else
  EXPRESS += mid$(FORMULE,I,1)
 Endif
 I += 1
Wend
Wrseq space$(SPA);"MONT = ";EXPRESS
End

#####################################################
## Traitement pour déclaration des rubriques
#####################################################
$DECRUB
SAVRUB = ""
J=0
For I=1 To 500
 PROG = "WP"+[L]LEGPLAN+"PLANDEC"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-"Plan de paye"
 #MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
 Wrseq "## Déclaration rubriques"
 Wrseq "$DECLARE"
 K = 0
 For [RUB]RUB0 Where COD > SAVRUB & LEG=LEGPLAN
  J+=1
  If J>MAXDEC
   J=0 : Break
  Endif
  SAVRUB = [F:RUB]COD
  If K>6 : Wrseq : K = 0 : Endif
  If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
  Wrseq PRUB+[F:RUB]COD;"(1..2)";
  Wrseq ",";
  Wrseq PBAS+[F:RUB]COD;
  K += 2
 Next
 Wrseq
 Wrseq "Return"
 Openo
 Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
 If OK
  NBDECPLAN += 1
 Endif
 If [F:RUB]COD = "" or J <> 0 : # plus rien à traiter
  Break
 Endif
Next I
Return

#####################################################
## Traitement pour raz des rubriques
#####################################################
$RAZRUB
SAVRUB = ""
J=0
For I=1 To 500
 PROG = "WP"+[L]LEGPLAN+"PLANRAZ"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-"Plan de paye"
 #MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
 Wrseq "## Raz rubriques"
 Wrseq "$RAZRUB"
 K = 0
 For [RUB]RUB0 Where COD > SAVRUB & LEG=LEGPLAN
  J+=1
  If J>MAXRAZ
   J=0 : Break
  Endif
  SAVRUB = [F:RUB]COD
  If K>6 : Wrseq : K = 0 : Endif
  If K=0 : Wrseq "Raz "; : Else : Wrseq ","; : Endif
  Wrseq PRUB+[F:RUB]COD;
  Wrseq ",";
  Wrseq PBAS+[F:RUB]COD;
  K += 2
 Next
 Wrseq
 If J <> 0 : # On raz les tranches sur le dernier traitement généré
  Wrseq "## Raz tranches"
  For [RUB]RUB0 Where TYPRUB=5 & LEG=LEGPLAN
   J+=1
   If J > MAXRAZ
    Wrseq
    Wrseq "Return"
    Openo
    Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
    If OK
     NBRAZPLAN += 1
    Endif
    J=0
    I+=1
    PROG = "WP"+[L]LEGPLAN+"PLANRAZ"+num$(I)
    FICSRC = filpath("TRT",PROG,"src",APPLI)
    Openo FICSRC , 0
    Wrseq TETADO-"Plan de paye"
    #MIPEA - 2016-07-25 - REQ 114309 US274 - START
    Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
    Wrseq '# User :'-GUSER
    Wrseq '# Date :'-format$("DD4",date$)
    Wrseq ''
    #MIPEA - 2016-07-25 - REQ 114309 US274 - END
    Wrseq "## Raz tranches"
    Wrseq "$RAZRUB"
   Endif
   Wrseq "Raz ";PTRS(0);[F:RUB]COD;",";PTRS(1);[F:RUB]COD;",";PTRS(2);[F:RUB]COD
   Wrseq "Raz ";PTRS(3);[F:RUB]COD;",";PTRS(4);[F:RUB]COD;",";PTRS(5);[F:RUB]COD
   Wrseq "Raz ";PTRS(6);[F:RUB]COD;",";PTRS(7);[F:RUB]COD;",";PTRS(8);[F:RUB]COD
   Wrseq "Raz ";PTRP(0);[F:RUB]COD;",";PTRP(1);[F:RUB]COD;",";PTRP(2);[F:RUB]COD
   Wrseq "Raz ";PTRP(3);[F:RUB]COD;",";PTRP(4);[F:RUB]COD;",";PTRP(4);[F:RUB]COD
   Wrseq "Raz ";PTRP(6);[F:RUB]COD;",";PTRP(7);[F:RUB]COD;",";PTRP(8);[F:RUB]COD
  Next
 Endif
 Wrseq
 Wrseq "Return"
 Openo
 Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
 If OK
  NBRAZPLAN += 1
 Endif
 If [F:RUB]COD = "" or J <> 0 : # plus rien à traiter
  Break
 Endif
Next
Return

#####################################################
## Traitement pour déclaration des variables
#####################################################
$DECVAR
PROG = "WP"+[L]LEGPLAN+"PLANDECV"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "## Déclaration variables"
Wrseq "$DECLARE"
K = 0
For [VRA]VRA0 Where FLGEXS<>2 & LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PVAR+[F:VRA]COD;
 K += 1
Next
Wrseq
Wrseq "Return"
Wrseq
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

#####################################################
## Traitement pour déclaration des cumuls
#####################################################
$DECCUM
PROG = "WP"+[L]LEGPLAN+"PLANDECC"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-"Plan de paye"
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "## Déclaration cumuls"
Wrseq "$DECLARE"
K = 0
For [CUM]CUM0 Where LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PCUM+[F:CUM]CUMCOD;"(1..2)";
 K += 1
Next
Wrseq
K = 0
For [CUM]CUM0 Where [F:CUM]CUMINI<>"" & [F:CUM]CUMTMP<>2 & LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PCUMSVG+[F:CUM]CUMCOD;
 K += 1
Next
Wrseq "Return"
Wrseq
Wrseq "# Réaffectation des cumuls"
Wrseq "$AFFCUM"
For [CUM]CUM1 Where CUMTMP<>2 & LEG=LEGPLAN
 Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(1)');' = ';PCUM;[F:CUM]CUMCOD;'(2)'
Next
For [CUM]CUM1 Where CUMTMP=2 & LEG=LEGPLAN
 Wrseq "Raz "+PCUM+[F:CUM]CUMCOD
Next
Wrseq "Return"
Wrseq
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

#############################################################################
## #91912
## Création d'un fichier XML pour dépendance des rubriques de rétroactivité
#############################################################################
$GENRUBXML
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
Local Char LSTOBJUSED(15)(0..500) :#95878
#Local Char LSTOBJUSED(15)(0..)
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END
Local Char BACKPAY(1) # "1" if heading is checked "backpay authorized" otherwise "0"
Local Integer I, NBSPACE
Local Char LSTEMPVAR(GLONAVA)(0..)

If !clalev([F:RUB]) : Local File RUBRIQUE [RUB] : Endif

I=0
If !clalev([F:DIC]) : Local File DICOEMP [DIC] : Endif

#95878
If nbrecord([DIC])>0
   Local Char LSTEMPVAR(GLONAVA)(0..nbrecord([DIC]))
Else
   Local Char LSTEMPVAR(GLONAVA)
Endif
#end 95878
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
For [DIC]DIC3 Where TBL="EMPLOCTR" and FLGRET=2
  LSTEMPVAR(I)=[DIC]FLD
  I+=1
Next
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END

I=0
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
PROG="W"+[L]LEGPLAN+"XMLRUBDEP"
#FICSRC = filpath("BQE",PROG,"xml")
FICSRC = filpath("tmp",PROG,"xml")
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END
Openo FICSRC , 0 Using [HHH]
Wrseq '<?xml version="1.0" encoding="UTF-8" ?>' Using [HHH]
Wrseq '<!--' Using [HHH]
Wrseq '    Type "R" = headings' Using [HHH]
Wrseq '    Type "V" = variables' Using [HHH]
Wrseq '    Type "F" = table "EMPLOCTR" field' Using [HHH]
Wrseq '    Type "T" = work-related accidents' Using [HHH]
Wrseq '    Type "G" = grids' Using [HHH]
Wrseq '-->' Using [HHH]
Wrseq '<headings>' Using [HHH]

For [F:RUB]RUB0 Where LEG=LEGPLAN
  NBSPACE=3
  Raz LSTOBJUSED
  Call SETLSTOBJUSED(LSTOBJUSED, LSTEMPVAR)

  If LSTOBJUSED(0)<>""
    [L]BACKPAY="0"
    If [F:RUB]FLGRET=2 : BACKPAY="1" : Endif
    Wrseq space$(NBSPACE)+'<heading code="'+[F:RUB]COD+'" backpay="'+BACKPAY+'">' Using [HHH]
    NBSPACE+=3
    For I=0 To dim(LSTOBJUSED)-1
      If LSTOBJUSED(I)="" : Break : Endif
      Wrseq space$(NBSPACE)+'<use type="'+left$(LSTOBJUSED(I),1)+'">'+right$(LSTOBJUSED(I),3)+'</use>' Using [HHH]
    Next I
    NBSPACE-=3
    Wrseq space$(NBSPACE)+'</heading>' Using [HHH]
  Endif
Next
Filter [F:RUB]
Wrseq '</headings>' Using [HHH]
Openo Using [HHH]
Return

Subprog SETLSTOBJUSED(LSTOBJUSED, LSTEMPVAR)
  Variable Char LSTOBJUSED()(0..)
  Const Char LSTEMPVAR()()
  Local Integer I, POSSTR, NBOBJUSED

  NBOBJUSED=0
  If [F:RUB]CNDCAL<>""
    Call GETLSTOBJUSED([F:RUB]CNDCAL,LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
  Endif

  For I=0 To [F:RUB]NBRCUM-1
    If [F:RUB]CUM(I)="" : Break : Endif
    If [F:RUB]CNDCUM(I)<>""
      Call GETLSTOBJUSED([F:RUB]CNDCUM(I),LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
    Endif
  Next I

  If [F:RUB]TYPRUB<10
    If [F:RUB]TYPRUB<>7
      If [F:RUB]BAS<>""
        Call GETLSTOBJUSED([F:RUB]BAS,LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
      Endif
      If [F:RUB]TYPRUB=5
        For I=0 To dim([F:RUB]AMTMAX)-1
          If [F:RUB]AMTMAX(I)="" : Break : Endif
          Call GETLSTOBJUSED([F:RUB]AMTMAX(I),LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
        Next I
      Elsif find([F:RUB]TYPRUB,2,3,6,8,9)
        If [F:RUB]RAT1<>""
          Call GETLSTOBJUSED([F:RUB]RAT1,LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
        Endif
        If [F:RUB]RAT2<>""
          Call GETLSTOBJUSED([F:RUB]RAT2,LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
        Endif
      Endif
    Else
      If [F:RUB]TBLCOD<>""
        LSTOBJUSED(NBOBJUSED)="G_"+[F:RUB]TBLCOD
        NBOBJUSED+=1
      Endif
      For I=0 To dim([F:RUB]TBLFRM)-1
        If [F:RUB]TBLFRM(I)="" : Break : Endif
        Call GETLSTOBJUSED([F:RUB]TBLFRM(I),LSTEMPVAR,LSTOBJUSED,NBOBJUSED)
      Next I
    Endif
  Endif
End

Subprog GETLSTOBJUSED(FORMULE, LSTEMPVAR, LSTOBJUSED,NBOBJUSED)
  Value Char FORMULE
  Const Char LSTEMPVAR()()
  Variable Char LSTOBJUSED()(0..)
  Variable Integer NBOBJUSED
  Local Integer I, J, VTYPOBJ
  Local Char OP(2), OP2(2), OP3(3), OP7(7), CUROBJ(15)

  I=0
  While I<len(FORMULE)-1
    Raz OP, J
    OP2=mid$(FORMULE,I,2)
    OP3=mid$(FORMULE,I,3)
    OP6=mid$(FORMULE,I,6)
    OP7=mid$(FORMULE,I,7)

    If find(OP2,"R_","V_")
      I+=2 : J=I : OP=OP2
    Elsif find(OP3,"[F]")
      I+=3 : J=I : OP="F_"
    Elsif find(OP6,"TXRISK")
      I+=6 : J=I : OP="T_"
    Elsif find(OP7,"[F:HRCTR]")
      I+=7 : J=I : OP="F_"
    Endif
    If J
      If OP<>"T_"
        While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
         I += 1
        Wend
        CUROBJ=seg$(FORMULE,J,I)

        If OP="F_" & !find(CUROBJ,LSTEMPVAR) : End : Endif :#if it's a table field, we save it only if it's an emploctr field.
      Else
        CUROBJ=OP6
      Endif
      CUROBJ=OP+CUROBJ
      If !find(CUROBJ,LSTOBJUSED)
        LSTOBJUSED(NBOBJUSED) = CUROBJ
        NBOBJUSED+=1
      Endif
    Else
      I+=1
    Endif
  Wend
End
###end 91912

################################################################################
# Appelé par TRT/ADOVAL (Valeurs paramètres)
################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM, VALEUR
Variable Integer OK

#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - START
#Parameters RUBCUM are linked to the local menu 334.
#Some items aren't available per legislation (country)
#We can't hide bad items, so we have to control the selected value !
If left$(PARAM,6)="RUBCUM"
#MIPEA - 2016-08-15 - X3PEOP-763 - START
  If !func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
 #If !func AFNC.ACTIV("KSA") Then
 #MIPEA - 2016-08-15 - X3PEOP-763 - END
  If val(VALEUR)>7 : [L]OK=0 : Endif
 Endif
#MIPEA - 2016-08-15 - X3PEOP-763 - START
  If !func DIVPAYE.IS_KFR_LEG(GCURLEG)
 #If !func AFNC.ACTIV("KFR") Then
#MIPEA - 2016-08-15 - X3PEOP-763 - END
  If val(VALEUR)=6 | val(VALEUR)=7 : [L]OK=0 : Endif
 Endif
#MIPEA - 2016-08-15 - X3PEOP-763 - START
  If !func DIVPAYE.IS_KFR_LEG(GCURLEG) & !func DIVPAYE.IS_KPO_LEG(GCURLEG)
 #If !func AFNC.ACTIV("KFR") & !func AFNC.ACTIV("KPO") Then
#MIPEA - 2016-08-15 - X3PEOP-763 - END
  If val(VALEUR)=2 | val(VALEUR)=3 : [L]OK=0 : Endif
 Endif
 If !OK
  #Valeur incorrecte
  Call ERREUR(mess(83,123,1)) From GESECRAN
  End
 Endif
Endif
#FRLAA - 2016-03-31 - REQUIREMENT 114309 US 147 - END

Local Integer VOK
VOK=0
Case [L]PARAM
 When "MAXRUB","NBRDEC","DMA","GARANTNET","SUBROG", "TEMSUBRO","HRSDIF" :
  VOK=1
Endcase
If !VOK
 If left$(PARAM,6)="PERCUM" | left$(PARAM,6)="RUBCUM" | left$(PARAM,3)="PAE" | left$(PARAM,3)="NET" | left$(PARAM,6)="PAYACP"
&                           | left$(PARAM,6)="PAYNET"
  VOK=1
 Endif
Endif
If VOK
 Call SETPAR From GENPLAN
 If GOK<=0
  #Modifications non validées : Génération plan de paie
  Call ERREUR(mess(18,176,1)-":"- mess(18,702,1)) From GESECRAN
  [L]OK=0
 Else
  [L]OK=1
 Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran GENPLAN) 28/08/2012 18:15:27 (DBA)
######################################################################################
Subprog AM_ALLLEG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LEG="" : Grizo [M]LEG
Else
 [M]LEG=GLEGFIL : Actzo [M]LEG
 Call AM_LEG([M]LEG) From DIVPAYE
Endif
Affzo [M]LEG
End

