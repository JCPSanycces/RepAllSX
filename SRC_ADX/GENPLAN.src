#Call GENPLAN(nomap,0,'FRA')
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "GENPLAN"
Call TRAITE_CHAR(VALEUR,PARAM,"","GENPLAN","GENPLAN",3,"") From GTRAITE

End

$ACTION
Case ACTION
 When "INIT_DIA": Gosub INIT_DIA
 When "TIT_DIA" : TITCRIT = mess(18,10702,1) : GCURLEG = GLEGFIL
 When "EXEC" :
 If dim([M:DIA]ALLLEG)>0 & [M:DIA]ALLLEG=2
  Call GENDOS (nomap)
 Else
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Call GENPLAN(nomap,0,GCURLEG)    :#Later add a screen to enter the code legislation wanted...
 Endif
 When "SORTIE"  : Gosub SORTIE
Endcase
Return

$INIT_DIA
Raz [M:DIA]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer I
For I=1 To GNBLEG
 Call GENPLAN(APPLI,0,GDOSLEG(I))
Next
End

Subprog GENPLAN(APPLI,TRANS,LEGPLAN)
Value Char    APPLI
Value Integer TRANS
Value Char LEGPLAN
Local Integer I , J , K , P , OK , NIV , TEMPON, INIV
Local Integer SPA , FLIF , FLIF2 , STAT, FLCRIT
Local Char    CRITERE(250) , PROG(GLONADC) , FICSRC(250)
Local Char    SAVIFS(5) , SAVIRS(5) , TETADO(50)
Local Integer NBPLAN , NBRUB , MAXRUB , DIMRUB, NBPAS
Local Char    PRUB(5) , PVAR(5) , PHIS(10) , PCUM(5) , PTRS(5)(0..8) , PTRP(5)(0..8) :#Tax band
#65041
Local Char    PBAS(5)
Local Integer NEXO1 , NEXO2
Local Char    CEXO1(GLONEXO)(1..100) , CEXO2(GLONEXO)(1..100)
Local Decimal ARO
#MIPEA - 2016-11-14 - X3PEOP-1200- START
Local Char    INICUM(24)(1..len(mess(0,10334,1)))
#Local Char    INICUM(30)(1..len(mess(0,10334,1)))
#MIPEA - 2016-11-14 - X3PEOP-1200- END
#MIPEA - 2016-11-14 - X3PEOP-1200- START
Local Char    INICUMECH(24)(1..len(mess(0,10334,1)))
#MIPEA - 2016-11-14 - X3PEOP-1200- END
Local Char    PARAM(250)
Local Char    PCUMSVG(5)

Local Char    SAVRUB(GLONRUB)
Local Integer NBDECPLAN  : # nb traitements de déclaration générés
Local Integer MAXDEC     : # nb de rubriques par traitement de déclaration
Local Integer NBRAZPLAN  : # nb traitements de déclaration générés
Local Integer MAXRAZ     : # nb de rubriques par traitement de déclaration
Local Char    RGLDES(GLONAX3)
MAXDEC = 1000
MAXRAZ = 1000

#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - START
# 88856 Découpage du WPPLANCUM0 en WPPLANCUMEx
Local Integer MAXCUM             : # nb maximum de cumul par WPPLANCUM0x
Local Integer INDPROG, NBCUM     : # Indice programme , nbcumul déjà écrit dans ce programme
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - END

#90804
Local Integer IPLANVLA

If clalev([ADI])=0 : Local File ATABDIV [ADI] : Endif
Filter [ADI] Where NUMTAB=10349 & LEG=[L]LEGPLAN
Local Integer NBCUMTTL
NBCUMTTL=rowcount([ADI])
Filter [ADI]
If [L]NBCUMTTL>0
  Local Integer RAZCUMRUB(1..[L]NBCUMTTL)
Else
  Local Integer RAZCUMRUB
Endif

TEMPON = GTEMPON
Call TEMPON(mess(18,10702,1)) From GESECRAN

Local Char    PMAXRUB(10)
Call PARAM("","MAXRUB",PMAXRUB) From ADOVAL
MAXRUB  = val(PMAXRUB)

Local Integer ILEG
ILEG=find([L]LEGPLAN,GDOSLEG(1..GNBLEG))

DIMRUB  = 10000     : # Nb max de rubriques
PRUB    = "R_"      : # Préfixe rubrique
PVAR    = "V_"      : # Préfixe variable
PCUM    = "C_"      : # Préfixe cumul
PCUMSVG = "X_"      : # Préfixe réinitialisation des cumuls # 31083
PTRS(0) = "TA_"     : # Tranche A salarié
PTRS(1) = "TB_"     : # Tranche B salarié
PTRS(2) = "TC_"     : # Tranche C salarié
PTRP(0) = "EA_"     : # Tranche A employeur
PTRP(1) = "EB_"     : # Tranche B employeur
PTRP(2) = "EC_"     : # Tranche C employeur
#Tax band
PTRS(3) = "TD_"     : # Tranche D salarié
PTRS(4) = "TE_"     : # Tranche E salarié
PTRS(5) = "TF_"     : # Tranche F salarié
PTRS(6) = "TG_"     : # Tranche G salarié
PTRS(7) = "TH_"     : # Tranche H salarié
PTRS(8) = "TI_"     : # Tranche I salarié
PTRP(3) = "ED_"     : # Tranche D employeur
PTRP(4) = "EE_"     : # Tranche E employeur
PTRP(5) = "EF_"     : # Tranche F employeur
PTRP(6) = "EG_"     : # Tranche G employeur
PTRP(7) = "EH_"     : # Tranche H employeur
PTRP(8) = "EI_"     : # Tranche I employeur

PHIS    = "[F:HSP]" : # Historique de paye
ARO     = 0.01      : # Arrondi par défaut
PBAS    = "B_"      : # Préfixe base de rubrique

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Local File =APPLI+".RUBRIQUE"  [RUB]
Local File =APPLI+".RUBRIQUE"  [RUB2]
Local File =APPLI+".VARIA"     [VRA]
Local File =APPLI+".EXOPAY"    [EXO]
Local File =APPLI+".CUMUL"     [CUM]
Local File =APPLI+".EXCEPTH"   [ECH]
Local File =APPLI+".EXCEPTD"   [ECD]
Local File =APPLI+".EXCEPTC"   [ECC]
Local File =APPLI+".REGUL"     [RGL]
Local File =APPLI+".ADOVAL"    [ADW]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".ATABIND"   [ATI]
#** V7 : Waiting Time Mangement **#
#**Local File =APPLI+".TIMCOD"   [TIM]
#**
#ADNGO - 2017-02-15 - START
#Local File =APPLI+".TIMCOD"    [TIM] #FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - Wait for time management
Local File =APPLI+".TIMCOD"    [TIM] #FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - Wait for time management
#ADNGO - 2017-02-15 - END
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - START
Local Char    PMAXRUB(10)
Call PARAM("","MAXRUB",PMAXRUB) From ADOVAL
MAXRUB  = val(PMAXRUB)

# 88856
Call PARAM("","MAXCUM",PMAXRUB) From ADOVAL
MAXCUM  = val(PMAXRUB)
If !MAXCUM : MAXCUM = 750 : Endif
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - END




GNBEMPTAB = 0
For [ATB]CODFIC Where left$(CODFIC,5)="EMPLO"
 GNBEMPTAB += 1
 GEMPTAB(GNBEMPTAB) = [F:ATB]CODFIC
 Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
 Case [F:ATI]DESCRIPT
  When "REFNUM"        : GTYPTAB(GNBEMPTAB) = 1
  When "REFNUM+NUMLIG" : GTYPTAB(GNBEMPTAB) = 2
  When Default         : GTYPTAB(GNBEMPTAB) = 3
 Endcase
Next
Sorta GNBEMPTAB GEMPTAB,GTYPTAB Order By GTYPTAB(indice+1)


For I=1 To len(mess(0,10334,1))
#MIPEA - 2016-10-27 - X3PEOP-1200 - START
If I <> 12
  Call PARAM([L]LEGPLAN,"PERCUM"+num$(I),INICUM(I)) From ADOVAL
  INICUM(I) = left$(INICUM(I)+INICUM(I)+string$(24,"N"),24)
Else
  INICUM(I) = "XXXXXXXXXXXX"
Endif
# Call PARAM([L]LEGPLAN,"PERCUM"+num$(I),INICUM(I)) From ADOVAL
# INICUM(I) = left$(INICUM(I)+INICUM(I)+string$(24,"N"),24)
#MIPEA - 2016-10-27 - X3PEOP-1200 - END
Next I
If [L]NBCUMTTL>0
   For I=1 To [L]NBCUMTTL
    Call PARAM([L]LEGPLAN,"RUBCUM"+num$(I),PARAM) From ADOVAL
    RAZCUMRUB(I) = val(PARAM)
  Next I
Endif

Local Integer  VTPS
#ADNGO - 2017-02-16 - START
#** V7 : Waiting Time Management **#
#**VTPS=func AFNC.ACTIV("TPS")
VTPS=func AFNC.ACTIV("TPS")
#VTPS=0
#**
#ADNGO - 2017-02-16 - END
#82486 : Amélio des perfs
If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif

Gosub EFFACE  : # Effacement plan précédent
Gosub DECRUB  : # Déclaration des rubriques - 54837 WGA
Gosub DECVAR  : # Déclaration des Variables - 81675
Gosub DECCUM  : # Déclaration des Cumuls    - 81675
Gosub RAZRUB  : # Raz des rubriques - 69990
Gosub CALRUB  : # Génération des rubriques
Gosub LECVAR  : # Lecture des variables
#MIPEA - 2018-04-11 - X3-83435 - START
Gosub MAJCUMEXT : ## Sauvegarde des cumuls ## backing up the totals
#MIPEA - 2018-04-11 - X3-83435 - END
Gosub MAJCUM  : # Lecture des cumuls
#61355
Gosub MAJCUM0  : # Ecriture des cumuls
Gosub MAJCUM1  : # Raz à jour des cumuls
#
Gosub MAJCUM2 : # Mise à jour des cumuls par niveau

Gosub GENRUBXML :#91912
#######################################
## Programme principal
#######################################

PROG = "WP"+[L]LEGPLAN+"PLAN"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - START
Wrseq TETADO-mess(21,26,1) : # Plan de paye
#Wrseq TETADO-mess(18,26,1) : # Plan de paye
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - END
#MIPEA - 2016-07-25 - REQ 114309 US274 - START
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "Subprog PLAN(BULLETIN,PASAPAS,TYPPAS)"
Wrseq "Value    Char    BULLETIN"
Wrseq "Variable Integer PASAPAS"
Wrseq "Value    Integer TYPPAS"
Wrseq

Wrseq "Gosub CPLAN"
Wrseq

Wrseq "End"
Wrseq

Wrseq "$CPLAN"
Wrseq "## Tables"
Wrseq "Local Char TABLE(10)"
Wrseq "Gosub OUVFIC"
Wrseq "For TABLE = ";
For I=1 To GNBEMPTAB
 If I>1 : Wrseq ","; : Endif
 Wrseq '"';GEMPTAB(I);'"';
Next I
Wrseq
Wrseq " Gosub DEFAUT From WPDEFTABLE"
Wrseq "Next"

If VTPS
 Wrseq "Default File [TIR]"
 Wrseq "Default File [TID]"
Endif

Wrseq

Wrseq "## Variables locales"
Wrseq "Local Integer GTPS : GTPS=0    # Waiting time management"
Wrseq "Local Char    MATRI(GLONEML)"
Wrseq "Local Char    CTR(GLONHRCTR)"
Wrseq "Local Date    DATPAY, DATVEP, SAVDATVEP"
Wrseq "Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY)"
Wrseq "Local Decimal BASE , TAUX , MONT , TRANCHE , PLAFOND , SOMTR"
Wrseq "Local Char    PROFIL(GLONPRF) , SERVICE(GLONSRV) , CODE(GLONRUB) , RUB(GLONRUB)"
Wrseq "Local Integer I , J , K , N , OK , RANG , MEM , TYP , ENVERS , R"
Wrseq "Local Integer NEXO"
Wrseq "Local Char    CEXO(GLONEXO)(1..100) , CODEXO(GLONEXO)"
Wrseq "Local Decimal TEXO1(1..100) , TEXO2(1..100)"
Wrseq "Local Decimal PEXO1(1..100) , PEXO2(1..100)"
Wrseq "Local Decimal TEXOS , TEXOP , PEXOS , PEXOP"
Wrseq "Local Date    DEBEXO , FINEXO"
Wrseq "Local Char    GRILLE(GLONGRI) , GRICLE(30)(0..2)"
Wrseq "Local Integer LIGC , GRICOL"
Wrseq "Local Date    DATED , DATEF"
Wrseq "Local Date    DATCUR , DATDEB , DATFIN , MOIPAY , DATMAT , DATPAI, PERDEB, PERFIN"
Wrseq "Local Integer STAT"
Wrseq "Local Integer MOIS , ANNEE , DMA , CUMINI"
Wrseq "Local Integer PAYMON, PAYYEA"
Wrseq "Local Char    CODRISK(GLONVAC)"
Wrseq "Local Decimal TXRISK , VALCUM , CUMINI"
Wrseq "Local Decimal AROVAR , MAXESSAI , PAETOL"
Wrseq "Local Char    PAERUB(GLONRUB) , PAEVAR(GLONVRA) , PAEVAL(GLONVRA)"
Wrseq "Local Char    NETVAR(GLONVRA)(1..9) , NETAJS(GLONVRA)(1..9) , NETRUB(GLONRUB)(1..9) , RUBHIS(GLONRUB+3)"
Wrseq "Local Char    NETTIM(250)(1..9) , NETRUBCAL(GLONRUB)(1..9)"
Wrseq "Local Decimal NETRUBC(1..9)"
Wrseq "Local Integer NETENBRUT , ROWHIS"
Wrseq "Local Char    PAYACPT1(GLONRUB) , PAYACPT2(GLONRUB) ,PAYACPT3(GLONRUB) , PAYNET(GLONRUB)(1..5)"
Wrseq "Local Integer RGACPT1 , RGACPT2 , RGACPT3, RGNET(1..5)"
Wrseq "Local Integer DIFHOU"
Wrseq "Local Integer SAVPAS, SAVPASR"
Wrseq "Local Integer OKRUB"
Wrseq "Local Integer OKCUM"        #91750
Wrseq "Local Char    INICUM(24)"
Wrseq "Local Decimal OLDRES1 , OLDRES2 , NEWRES1 , NEWRES2"
Wrseq "Local Integer REGUL , NBREGVAR , REGROW , OKREG , NBREGUL"
Wrseq "Local Decimal REGVAL(1..10) , REGVAL1(1..500) , REGVAL2(1..500)"
Wrseq "Local Char    REGRUB(GLONRUB) , REGVAR(GLONVRA)(1..10) , REGRUB1(GLONRUB)(1..500) , REGREG(GLONRUB)"
Wrseq "Local Char    REGVARVAL(GLONVRA)(1..10)"
Wrseq "Local Date    REGDEB , REGFIN , SAVDATPAY"
Wrseq "Local Char    SAVBUL(GLONVCR)"
Wrseq "Local Date    SAVCTRDAT"                :##**72216
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - START
Wrseq "Local Integer STACUM , CUMNUM"
#Wrseq "Local Integer STACUM"
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - END
Wrseq "Local Integer NRUBCUM , RUBCUMN(1..500)"
Wrseq "Local Char    RUBCUM(GLONRUB)(1..500)"
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - START
Wrseq "Local Char    LIBRUB(250), CUMNUMADI(GLONADI)"
#Wrseq "Local Char    LIBRUB(GLONDES), CUMNUMADI(GLONADI)"
#FRLAA - 2016-03-18 - REQUIREMENT 114309 US 77 - END
Wrseq "Local Decimal ACOMPTE1 , ACOMPTE2"
Wrseq "Local Integer RECAL , SIMUL"
Wrseq "Local Decimal HVAR(1..30)"
Wrseq "Local Integer STDPLAN"
Wrseq "Local Integer SPEPLAN"
Wrseq "Local Char    ACTION(20)"
Wrseq "Local Char    PARA(20), PARA1(20)"
Wrseq "Local Char    CRITERE(250)"
Wrseq "Local Integer RAZCUM, MULCTR"
Wrseq "Local Char    CUMSVG(GLONCUM)(1..500)"
Wrseq "Local Char    LEGPLAN (GLONADI)"
#MIPEA - 2016-11-15 - X3PEOP-1200- START
Wrseq "Local Char    PERCOD (GLONHRPEO)"
Wrseq "Local Shortint PERYEA, PERNUM"
#MIPEA - 2016-11-15 - X3PEOP-1200- END
#ADNGO - 2017-02-16 - START
#** V7 : Waiting Time Mangement **#
#**Wrseq "Local Char    CODCP(GLONTPS) (1..max(1,nbrecord([F:TIM])))"
Wrseq "Local Char    CODCP(GLONTPS) (1..max(1,nbrecord([F:TIM])))"
#*!
#Wrseq "Local Char    CODCP(5) (1..50)"
#**
#ADNGO - 2017-02-16 - END
Wrseq "Local Integer NBCODCP"

Wrseq "Gosub DECLARATION_RETRO From TRTRETCAL"

# Dans le cadre de la rétroactivité on va jouer avec des assign
# on va donc se conserver quelque part les valeurs servant de préfixe
# aux différentes variables

Wrseq 'Local Char PRUB(10) : [L]PRUB = "' + [L]PRUB + '" : # Préfixe rubrique'
Wrseq 'Local Char PVAR(10) : [L]PVAR = "' + [L]PVAR + '" : # Préfixe variable'
Wrseq 'Local Char PCUM(10) : [L]PCUM = "' + [L]PCUM + '" : # Préfixe cumul'
Wrseq 'Local Char PCUMSVG(10) : [L]PCUMSVG = "' + [L]PCUMSVG + '" : # Préfixe réinitialisation des cumuls'
#Tax band
Wrseq 'Local Char PTRS(10)(0..8), PTRP(10)(0..8)'
For I=0 To 8
 Wrseq '[L]PTRS ('+num$(I)+') = "' + [L]PTRS(I)+ '" : # Tranche A,B,C... salarié'
 Wrseq '[L]PTRP ('+num$(I)+') = "' + [L]PTRP(I)+ '" : # Tranche A,B,C... employeur'
Next
Wrseq 'Local Char PHIS(10) : [L]PHIS = "' + [L]PHIS + '" : # Historique de paye'
Wrseq 'Local Char PBAS(10) : [L]PBAS = "' + [L]PBAS + '" : # Préfixe base de rubrique'

Wrseq

Wrseq "## Divers"
Call PARAM("","NBRDEC",PARAM) From ADOVAL
Wrseq "AROVAR = "+num$(10^(-val(PARAM)))
Call PARAM([L]LEGPLAN,"PAENBR",PARAM) From ADOVAL
Wrseq "MAXESSAI = "+num$(val(PARAM)) : # Au cas où...
Call PARAM([L]LEGPLAN,"PAETOL",PARAM) From ADOVAL
Wrseq "PAETOL = "+num$(val(PARAM))
Call PARAM([L]LEGPLAN,"PAERUB",PARAM) From ADOVAL
Wrseq 'PAERUB = "'+PARAM+'"'
Call PARAM([L]LEGPLAN,"PAEVAR",PARAM) From ADOVAL
Wrseq 'PAEVAR = "'+PARAM+'"'
Call PARAM([L]LEGPLAN,"PAEVAL",PARAM) From ADOVAL
Wrseq 'PAEVAL = "'+PARAM+'"'
K = 0
For I=1 To 9
 Call PARAM([L]LEGPLAN,"NETVAR"+num$(I),PARAM) From ADOVAL
 If PARAM="" : Break : Endif
 K += 1
 Wrseq 'NETVAR('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETAJS"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETAJS('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETRUB"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETRUB('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETTIM"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETTIM('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETRUBCAL"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETRUBCAL('+num$(K)+') = "'+PARAM+'"'
Next I
Wrseq "NETENBRUT = "+num$(K)
Call PARAM([L]LEGPLAN,"PAYACPT1",PARAM) From ADOVAL
If PARAM<>""
 Wrseq 'PAYACPT1 = "'+PARAM+'"'
 Read [RUB]RUB0 = [L]LEGPLAN;PARAM
 Wrseq "RGACPT1 = ";[F:RUB]ROW
Endif
Call PARAM([L]LEGPLAN,"PAYACPT2",PARAM) From ADOVAL
If PARAM<>""
 Wrseq 'PAYACPT2 = "'+PARAM+'"'
 Read [RUB]RUB0 = [L]LEGPLAN;PARAM
 Wrseq "RGACPT2 = ";[F:RUB]ROW
Endif
Call PARAM([L]LEGPLAN,"PAYACPT3",PARAM) From ADOVAL
If PARAM<>""
 Wrseq 'PAYACPT3 = "'+PARAM+'"'
 Read [RUB]RUB0 = [L]LEGPLAN;PARAM
 Wrseq "RGACPT3 = ";[F:RUB]ROW
Endif
For I=1 To 5
 Call PARAM([L]LEGPLAN,"PAYNET"+num$(I),PARAM) From ADOVAL
 If PARAM<>""
  Wrseq 'PAYNET('+num$(I)+') = "'+PARAM+'"'
  Read [RUB]RUB0 = [L]LEGPLAN;PARAM
  Wrseq "RGNET("+num$(I)+") = ";[F:RUB]ROW
 Endif
Next I
Wrseq "NRUBCUM = 0"

For [RUB]RUB0 Where CUMNUM>1 & LEG=LEGPLAN
 Wrseq 'NRUBCUM += 1 : RUBCUM(NRUBCUM) = "';[F:RUB]COD;'" : RUBCUMN(NRUBCUM) = ';num$(val(right$([F:RUB]CUMNUMADI,len([F:RUB]CUMNUMADI))))

Next
# (C) PROSPER 22/11/10 - Ajout d'un mode spécial pour rétroactivité
# => Utilisé pour charger le "bon" contrat et les "bonnes" variables en prenant en compte des dates
#    différentes
# Wrseq "Case PASAPAS"
# Wrseq " When -1 : RECAL = 1 : PASAPAS = 0 : SIMUL = 0"
# Wrseq " When -2 : RECAL = 2 : PASAPAS = 0 : SIMUL = 0"
# Wrseq " When -3 : RECAL = 1 : PASAPAS = 0 : SIMUL = 1"
Wrseq "Case PASAPAS"
Wrseq " When -1 : RECAL = 1 : PASAPAS = 0 : SIMUL = 0 : RETRO = 0"
Wrseq " When -2 : RECAL = 2 : PASAPAS = 0 : SIMUL = 0 : RETRO = 0"
Wrseq " When -3 : RECAL = 1 : PASAPAS = 0 : SIMUL = 1 : RETRO = 0"
Wrseq " When -4 : RECAL = 0 : PASAPAS = 0 : SIMUL = 0 : RETRO = 1"
Wrseq " When -5 : RECAL = 0 : PASAPAS = 0 : SIMUL = 0 : RETRO = 2"
Wrseq "Endcase"
Wrseq 'Call EXISTE_ADX("","","STDPLAN'+GCURLEG+'",R) From ORDSYS'
Wrseq "If R>0 : STDPLAN = 1 : Endif"
Wrseq 'Call EXISTE_ADX("","","SPEPLAN'+GCURLEG+'",R) From ORDSYS'
Wrseq "If R>0 : SPEPLAN = 1 : Endif"
Wrseq
#ADNGO - 2017-02-16 - START
#** V7 : Waiting Time Mangement **#
#** Wrseq "## Temps"
#** I=1
#** For [F:TIM]TIM0 Where [F:TIM]CATTIM=3
#**  Wrseq 'CODCP('+num$(I)+') = "'+[F:TIM]COD+'"'
#**  I+=1
#** Next
#** Wrseq "NBCODCP = "+num$(I-1)
#**Wrseq
Wrseq "## Temps"
 I=1
 For [F:TIM]TIM0 Where [F:TIM]CATTIM=3 & LEG = GCURLEG
  Wrseq 'CODCP('+num$(I)+') = "'+[F:TIM]COD+'"'
  I+=1
 Next
 Wrseq "NBCODCP = "+num$(I-1)
Wrseq
#**
#ADNGO - 2017-02-16 - END
Wrseq "## Rubriques"
For I = 1 To NBDECPLAN
 Wrseq "Gosub DECLARE From WP"+[L]LEGPLAN+"PLANDEC"+num$(I)+" : # Déclaration des rubriques "
Next I
Wrseq


Wrseq "## Variables"
Wrseq "Gosub DECLARE From WP"+[L]LEGPLAN+"PLANDECV : # Déclaration des variables " : # 81675
Wrseq

Wrseq "## Cumuls"
Wrseq "Gosub DECLARE From WP"+[L]LEGPLAN+"PLANDECC : # Déclaration des cumuls " : # 81675
Wrseq

#Tax band
Wrseq "## Tranches"
For [RUB]RUB0 Where TYPRUB=5 & LEG=LEGPLAN
 Wrseq "Local Decimal ";PTRS(0);[F:RUB]COD;",";PTRS(1);[F:RUB]COD;",";PTRS(2);[F:RUB]COD
 Wrseq "Local Decimal ";PTRS(3);[F:RUB]COD;",";PTRS(4);[F:RUB]COD;",";PTRS(5);[F:RUB]COD
 Wrseq "Local Decimal ";PTRS(6);[F:RUB]COD;",";PTRS(7);[F:RUB]COD;",";PTRS(8);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(0);[F:RUB]COD;",";PTRP(1);[F:RUB]COD;",";PTRP(2);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(3);[F:RUB]COD;",";PTRP(4);[F:RUB]COD;",";PTRP(5);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(6);[F:RUB]COD;",";PTRP(7);[F:RUB]COD;",";PTRP(8);[F:RUB]COD
Next
Wrseq

#62279 : Isolement dans une étiquette à part pour pouvoir l'appeler dans GPLAN lors du calcul des réguls
Wrseq "## Lecture tables"
Wrseq "Gosub LECTAB"
Wrseq
#

## Traitement des réguls
For [RGL]RGL0 Where LEG=LEGPLAN & ENAFLG=2
 Filter [RUB] Where TYPRUB=10 & RGL=[F:RGL]COD & LEG=LEGPLAN
 Read [RUB]RUB0 First
 Filter [RUB]
 If fstat<=2
  Call LECTEXTRA(RGLDES,"REGUL","DES",LEGPLAN,[F:RGL]COD) From ATEXTRA
  Wrseq "## Régularisation"-[F:RGL]COD-RGLDES
  Wrseq
  Wrseq "OKREG = 1"
  If dim([F:RGL]CTRCRI) > 0 & [F:RGL]CTRCRI(0) <> ""
    Wrseq 'Read [F:RGL]RGL0 = "'+[F:RGL]LEG+'";"'+[F:RGL]COD+'"'
  Endif

  Wrseq "If OKREG"
  If [F:RGL]ENASTR<>[0/0/0]
   Wrseq '& & PERDEB>=['+format$(GFMD,[F:RGL]ENASTR)+']'
  Endif
  If [F:RGL]ENAEND<>[0/0/0]
   Wrseq '& & PERFIN<=['+format$(GFMD,[F:RGL]ENAEND)+']'
  Endif
  If [F:RGL]FCY<>""
   Wrseq '& & SITE="'+[F:RGL]FCY+'"'
  Endif
  If [F:RGL]PRF<>""
   Wrseq '& & PROFIL="'+[F:RGL]PRF+'"'
  Endif
  If [F:RGL]SRV<>""
   Wrseq '& & SERVICE="'+[F:RGL]SRV+'"'
  Endif
  If [F:RGL]EMPSTR<>""
   Wrseq '& & MATRI>="'+[F:RGL]EMPSTR+'"'
  Endif
  If [F:RGL]EMPEND<>""
   Wrseq '& & MATRI<="'+[F:RGL]EMPEND+'"'
  Endif
  If [F:RGL]CRI<>""
   Wrseq '& & (';vireblc(format$("KT:250X",[F:RGL]CRI),2);')'
  Endif
  If dim([F:RGL]CTRCRI) > 0 & [F:RGL]CTRCRI(0) <> ""
   Wrseq '& & find([F:HRCTR]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+format$("D:YYYYMMDD",[F:HRCTR]CTRDAT), [F:RGL]CTRCRI)'
  Endif
  SPA = 1
  If [F:RGL]POP<>""
   #MIPEA - 2016-08-15 - X3PEOP-763 - START
   #Wrseq space$(SPA);'Read [POA]POA0 = "';[F:ECH]POP;'";MATRI'
   Wrseq space$(SPA);'Read [HRPOA]POA0 = [F:RGL]POP;MATRI;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT'
   #MIPEA - 2016-08-15 - X3PEOP-763 - END
   Wrseq space$(SPA);'If !fstat'
   SPA += 1
  Endif
  Read [RUB]RUB0 = [F:RGL]LEG;[F:RGL]RUB
  Wrseq space$(SPA);'REGREG = "'+[F:RGL]COD+'"'
  If [F:RGL]STRDAT=[0/0/0]
   Wrseq space$(SPA);'REGDEB = [0/0/0]'
  Else
   Wrseq space$(SPA);'REGDEB = ['+format$(GFMD,[F:RGL]STRDAT)+']'
  Endif
  If [F:RGL]ENDDAT=[0/0/0]
   Wrseq space$(SPA);'REGFIN = [0/0/0]'
  Else
   Wrseq space$(SPA);'REGFIN = ['+format$(GFMD,[F:RGL]ENDDAT)+']'
  Endif
  Wrseq space$(SPA);'REGRUB = "';[F:RGL]RUB;'"'
  Wrseq space$(SPA);'REGROW = ';num$([F:RUB]ROW)
  Wrseq space$(SPA);'NBREGVAR = ';num$([F:RGL]NBRVAR)
  For I=1 To [F:RGL]NBRVAR
   Wrseq space$(SPA);'REGVAR('+num$(I)+')    = "'+[F:RGL]VARCOD(I-1)+'"'
   Wrseq space$(SPA);'REGVAL('+num$(I)+')    = '+num$([F:RGL]VARVAL(I-1))
   Wrseq space$(SPA);'REGVARVAL('+num$(I)+') = "'+[F:RGL]VARCOD2(I-1)+'"'
  Next I
  Wrseq space$(SPA);'REGUL = 1 : Gosub REGUL From GPLAN'
  If [F:RGL]POP<>""
   SPA -= 1 : Wrseq space$(SPA);"Endif"
  Endif
  SPA -= 1 : Wrseq 'Endif'
  Wrseq
 Endif
Next

