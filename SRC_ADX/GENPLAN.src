Wrseq "If fstat>2 : PERNUMPREC = 0 : Else : PERNUMPREC = [F:VEP3]PERNUM : Endif"
#MIPEA - 2016-11-28 - X3PEOP-1200- END
Wrseq "If fstat>2 "
Wrseq " [L]RAZCUM=0"
Wrseq "Else"
Wrseq " Filter [CTR2] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[F:VEP3]ENDDAT"
Wrseq " Read [CTR2]CTR0 Last"
Wrseq " Filter [CTR2]"
Wrseq " If fstat<2 & [F:CTR2]CTRDAT<>[F:HRCTR]CTRDAT & [F:CTR2]RAZCUM=2 : [L]RAZCUM=1 : Else [L]RAZCUM=0 : Endif"
Wrseq "Endif"
Wrseq "If DATPREC<>[0/0/0]"
#MIPEA - 2018-04-11 - X3-83435 - START
Wrseq "Gosub SETCUM From WP"+[L]LEGPLAN+"PLANCUMEXT"
