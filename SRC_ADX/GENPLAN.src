Wrseq " If !fstat"
Wrseq '  For [VLA]VLA0 Where TYP=4 & LEG="" & CPY="" & FCY="" & EMP=MATRI & DAT=[F:VEP3]PYRDAT & BUL=BULLETIN'
NIV = 4 : Gosub CASE_VAR
Wrseq "  Next"
Wrseq " Endif"
Wrseq "Endif"
Wrseq "If [L]RETRO : Gosub LECVRA From TRTRETCAL : Endif"
Wrseq "Return"
Openo
