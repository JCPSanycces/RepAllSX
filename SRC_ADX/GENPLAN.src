Wrseq '# User :'-GUSER
Wrseq '# Date :'-format$("DD4",date$)
Wrseq ''
#MIPEA - 2016-07-25 - REQ 114309 US274 - END
Wrseq "## Raz"
Wrseq "$RAZVAR"
K = 0
For [VRA]VRA0 Where FLGEXS<>2 & LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Raz "; : Else : Wrseq ","; : Endif
 Wrseq PVAR+[F:VRA]COD;
 K += 1
Next
Wrseq
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

#90804 : Commun avec GENPLANMS
$COMMUN_LECVAR
