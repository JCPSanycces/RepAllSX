#104072 : Ajout d'un point d'entrée en fin de génération de plan de paie
# => Utilisé par ACP pour générer des variables et cumuls historisés afin d'avoir en ligne
#    des variables HV_nomvar et des cumuls HC_nomcum
[V]GPOINT = "FINGENPLAN" : Gosub ENTREE From EXEFNC
#FRLAA - 2016-03-30 - REQUIREMENT 114309 US 147 - END

## Plan valide
If TRANS
 Update [ADW] Where CMP="*" & FCY=[L]LEGPLAN & PARAM="PLAN" With VALEUR="0"
Else
 Trbegin [ADW]
  Update [ADW] Where CMP="*" & FCY=[L]LEGPLAN & PARAM="PLAN" With VALEUR="0"
 Commit
Endif
If APPLI=nomap
 GPLANOK(ILEG) = 0
 GPRFRUB = ""
Endif
Call TEMPOFF From GESECRAN
If TEMPON
 Call TEMPON("O") From GESECRAN
Endif
End

##################################
## Effacement plan de paye
##################################

$EFFACE
Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLAN",STAT) From ORDSYS
If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLAN","src",0),0)>=0
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLAN","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLAN","adx",0),STAT) From ORDSYS
Endif

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLAN"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLAN"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLAN"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLAN"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANDECC",STAT) From ORDSYS
If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECC","src",0),0)>=0
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECC","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECC","adx",0),STAT) From ORDSYS
Endif

Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANDECV",STAT) From ORDSYS
If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECV","src",0),0)>=0
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECV","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDECV","adx",0),STAT) From ORDSYS
Endif

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANDEC"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANDEC"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDEC"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANDEC"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANVRA",STAT) From ORDSYS
If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANVRA","src",0),0)>=0
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANVRA","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANVRA","adx",0),STAT) From ORDSYS
Endif

Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANCUM",STAT) From ORDSYS
If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM","src",0),0)>=0
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM","adx",0),STAT) From ORDSYS
Endif

For I=0 To 2
 Call EFFACE_ADX("",nomap,"WP"+[L]LEGPLAN+"PLANCUM"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WP"+[L]LEGPLAN+"PLANCUM"+num$(I),"adx",0),STAT) From ORDSYS
 Else
