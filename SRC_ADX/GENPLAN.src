    If    K=0 : Wrseq ' If [L]RAZCUM | Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : K=1
    Elsif K=1 : Wrseq ' Elsif [L]RAZCUM | Func DIVPAYE.CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,"'+num$(P)+'")' : K=2
