#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry CAT
######################################################################################
## Comment section
##
## Issue 110700 - 2016-07-15 by RICAR : Electronic invoices: connect with Sage component
##
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LECTURE"     : Gosub LECTURE
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

######################################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(255),WFIL4(255),WFIL5(255)
Local Char    DEBNUM(20), FINNUM(20)
Local Date    DEBDAT, FINDAT
Local Integer I, STAT, CONTADOCS

If !clalev([F:EFSIH]) : Local File SINVOICE       [EFSIH] : Endif
If !clalev([F:EFDKD]) : Local File DKSDATA        [EFDKD] : Endif
If !clalev([F:EFBPC]) : Local File BPCUSTOMER     [EFBPC] : Endif
If !clalev([F:EFBPR]) : Local File BPARTNER       [EFBPR] : Endif
If !clalev([F:EFCPY]) : Local File COMPANY        [EFCPY] : Endif

Return

######################################################################################
$LECTURE

If [M:CEI1]CPY = "" : Return : Endif

Gosub CHANGE_MSK From GCONSULT

If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER

If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres

If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCEI]TRI
        When 0 , 1 : # tri par numéro
            Gosub LNK_PAR_NUM_ASC
        When 2 : # tri par date
            Gosub LNK_PAR_DAT_ASC
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCEI]TRI
        When 0 , 1 : # tri par numéro
            Gosub LNK_PAR_NUM_DESC
        When 2 : # tri par date
            Gosub LNK_PAR_DAT_DESC
    Endcase
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CEI2] : Endif

#-- lecture
$BOUCLE

For [LNK]
  #carregamento dos dados
  If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:CEI2] : Endif
    NBLU = 2
  Endif
  If CHGPAG > 0
    If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
    #If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
    NOL    += 1
    If NOL=0
      DEBNUM = [F:EFSIH]NUM
      DEBDAT = [F:EFSIH]ACCDAT
    Endif
    FINNUM = [F:EFSIH]NUM
    FINDAT = [F:EFSIH]ACCDAT
  Else
    If NOL <= 0 : RETOUR=2 : Break : Endif
    #If NOL <= 0 : RETOUR=2 : Return : Endif
    NOL    -= 1
    If NOL=MAXLIG-1
      FINNUM = [F:EFSIH]NUM
      FINDAT = [F:EFSIH]ACCDAT
    Endif
    DEBNUM = [F:EFSIH]NUM
    DEBDAT = [F:EFSIH]ACCDAT
  Endif
  # Modifié par Dominique BOPP après discussion avec Jacky LESAGE
  # Objectif : disposer d'un maximum de rubriques possibles dans l'écran de consultation des devis
  nolign = NOL+1
  [M:CEI2] = [F:EFSIH] : # Un trans-classe pour commencer
  [M:CEI2] = [F:EFDKD]
  [M:CEI2] = [F:EFSIH]
  If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
    Break
  Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
    Break
  Endif
  $SUIV
Next

Filter [F:EFSIH]
Filter [F:EFDKD]
Filter [F:EFBPC]
Filter [F:EFBPR]
Filter [F:EFCPY]

Return

######################################################################################
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER

WFIL    = "1=1"
WFIL1   = "1=1"
WFIL2   = "1=1"
WFIL3   = "1=1"
WFIL4   = "1=1"
WFIL5   = "1=1"

# Company
WFIL += " &((find('" + [M:CEI1]CPY + "', [F:EFSIH]CPY)))"

# Site
If [M:CEI1]FCY <> ""
  WFIL    +=    " & find('"+[M:CEI1]FCY+"',[F:EFSIH]FCY)"
Endif

# BPR
If [M:CEI1]BPRNUMSTR <> ""
  WFIL    +=    " & [F:EFSIH]BPR >= [M:CEI1]BPRNUMSTR"
Endif

# BPR FIN
If [M:CEI1]BPRNUMEND<> ""
  WFIL    +=    " & [F:EFSIH]BPR <= [M:CEI1]BPRNUMEND"
Endif

# Document num STR
If [M:CEI1]NUMDEB <> ""
  WFIL1    +=    " & [F:EFDKD]DOCNUM >= [M:CEI1]NUMDEB "
Endif

# Document num FIN
If [M:CEI1]NUMFIN <> ""
  WFIL1    +=    " & [F:EFDKD]DOCNUM <= [M:CEI1]NUMFIN "
Endif

# Invoice Start date
If [M:CEI1]INVDATDEB <> [0/0/0]
  WFIL1    +=    " & [F:EFSIH]ACCDAT >=["+format$(GFMD,[M:CEI1]INVDATDEB)+"]"
Endif

# Invoice End date
If [M:CEI1]INVDATFIN <> [0/0/0]
  WFIL2    +=    " & [F:EFSIH]ACCDAT<=["+format$(GFMD,[M:CEI1]INVDATFIN)+"]"
Endif

# Expiry Start date
If [M:CEI1]EXPDATDEB <> [0/0/0]
  WFIL2    +=    " & [F:EFSIH]ACCDAT >=["+format$(GFMD,[M:CEI1]EXPDATDEB)+"]"
Endif

# Expiry End date
If [M:CEI1]EXPDATFIN <> [0/0/0]
  WFIL2    +=    " & [F:EFSIH]ACCDAT<=["+format$(GFMD,[M:CEI1]EXPDATFIN)+"]"
Endif

If GFONCTION = 'CONSCAT'
  If [M:CEI1]ALLSTATUS <> 2
    WFIL3     +=   " & [F:EFDKD]ATEI = [M:CEI1]ATEI"
  Else
    WFIL3     +=   " & [F:EFDKD]ATEI >= 1"
  Endif
Else
  If [M:CEI1]ALLSTATUS <> 2
    WFIL3     +=   " & [F:EFDKD]BPEI = [M:CEI1]BPEI"
  Else
    WFIL3     +=   " & [F:EFDKD]BPEI >= 1"
  Endif
Endif


If [M:CEI1]ALLDOCTYP <> 2
#  WFIL3     +=   " & ([F:EFDKD]BPEI = [M:CEI1]BPEI )" #TODO ??
  WFIL3     +=   " & [F:EFSIH]INVTYP = [M:CEI1]INVTYP"
Endif

#If[M:CEI1]ALLDOCTYP  <>  2
#Endif

Case CHGPAG
  When 3 : # rafraichissement
    Case [M:CCEI]TRI
      When 0 , 1 : # tri par numéro
        If [M:CCEI]SORT = 1
          WFIL1 += "&[F:EFSIH]NUM>=DEBNUM"
        Else
          WFIL1 += "&[F:EFSIH]NUM<=DEBNUM"
        Endif
      When 2 : # tri par date
        If [M:CCEI]SORT = 1
          WFIL1 += "&([F:EFSIH]ACCDAT>DEBDAT | ([F:EFSIH]ACCDAT=DEBDAT & [F:EFSIH]NUM>=DEBNUM))"
        Else
          WFIL1 += "&([F:EFSIH]ACCDAT<DEBDAT | ([F:EFSIH]ACCDAT=DEBDAT & [F:EFSIH]NUM<=DEBNUM))"
        Endif
    Endcase
  When 2 : # suite
    Case [M:CCEI]TRI
      When 0 , 1 : # tri par numéro
        If [M:CCEI]SORT = 1
          WFIL1 += "&[F:EFSIH]NUM>FINNUM"
        Else
            WFIL1 += "&[F:EFSIH]NUM<FINNUM"
        Endif
      When 2 : # tri par date
        If [M:CCEI]SORT = 1
            WFIL1 += "&([F:EFSIH]ACCDAT>FINDAT | ([F:EFSIH]ACCDAT=FINDAT & [F:EFSIH]NUM>FINNUM))"
        Else
            WFIL1 += "& ([F:EFSIH]ACCDAT<FINDAT | ([F:EFSIH]ACCDAT=FINDAT & [F:EFSIH]NUM<FINNUM))"
        Endif
    Endcase
  When -2 : # retour
    Case [M:CCEI]TRI
      When 0 , 1 : # tri par numéro
        If [M:CCEI]SORT = 1
            WFIL1 += "&[F:EFSIH]NUM<DEBNUM"
        Else
            WFIL1 += "&[F:EFSIH]NUM>DEBNUM"
        Endif
      When 2 : # tri par date
        If [M:CCEI]SORT = 1
            WFIL1 += "& ([F:EFSIH]ACCDAT<DEBDAT | ([F:EFSIH]ACCDAT=DEBDAT & [F:EFSIH]NUM<DEBNUM))"
        Else
            WFIL1 += "&([F:EFSIH]ACCDAT>DEBDAT | ([F:EFSIH]ACCDAT=DEBDAT & [F:EFSIH]NUM>DEBNUM))"
        Endif
    Endcase
Endcase

Return
######################################################################################
$EXEBOUT

Case BOUT
    When "2"
        Gosub SET_EFAT
    When "1"
        Gosub GET_EFAT
Endcase

Return
######################################################################################
$SETBOUT

#If !find(2,[M:CEI2]UPDFLG(0..dim([M:CEI2]UPDFLG)-1))
#  Call VIREBOUT(CHAINE,"1") From GOBJET
#Endif
#
#If !find(2,[M:CEI2]UPDFLG(0..dim([M:CEI2]UPDFLG)-1))
#  Call VIREBOUT(CHAINE,"2") From GOBJET
#Endif

Return
######################################################################################
$SET_EFAT

Local Integer PTRACE

If GTRACE=""
  Call OUVRE_TRACE(mess(219,7711,1)) From LECFIC
  PTRACE = 1
Endif

If (func AFNC.PARAM("PORDKS",[M:CEI1]CPY)="2") & (func AFNC.ACTIV("EFAT"))
  For I = 0 To [M:CEI2]NBLIG-1
    If GFONCTION="CONSCAT"
     If [M:CEI2]ACTSTATUS(I) = 2 & find([M:CEI2]ATEI(I),1,2)
      Call ECR_TRACE([M:CEI2]NUM(I),0) From GESECRAN
      Call SEND_INV_TO_EFAT([M:CEI2]NUM(I),1,0,[L]STAT) From PORLEGEFATLIB
     Endif
    Else
     If [M:CEI2]ACTSTATUS(I) = 2 & find([M:CEI2]BPEI(I),1,2,4,5)
      Call ECR_TRACE([M:CEI2]NUM(I),0) From GESECRAN
      Call SEND_INV_TO_EFAT([M:CEI2]NUM(I),0,1,[L]STAT) From PORLEGEFATLIB
     Endif
    Endif
  Next
Endif

If PTRACE = 1
  Call FERME_TRACE                                    From LECFIC
  Call LEC_TRACE                                      From LECFIC
Endif

Gosub LECTURE From GCONSULT
Gosub CLECUR  From GCONSULT

Return
######################################################################################
$GET_EFAT

Local Integer PTRACE

If GTRACE=""
  Call OUVRE_TRACE(mess(219,7711,1)) From LECFIC
  PTRACE = 1
Endif

If (func AFNC.PARAM("PORDKS",[M:CEI1]CPY)="2") & (func AFNC.ACTIV("EFAT"))
  For I = 0 To [M:CEI2]NBLIG-1
    If [M:CEI2]ACTSTATUS(I) = 2 #& [M:XPE2]XPBPEI(I) >=2 & [M:XPE2]XPBPEI(I) <7
      Call ECR_TRACE([M:CEI2]NUM(I),0) From GESECRAN
      Call GET_INV_FROM_EFAT([M:CEI2]NUM(I), [L]STAT) From PORLEGEFATLIB
    Endif
  Next
Endif

If PTRACE = 1
  Call FERME_TRACE                                    From LECFIC
  Call LEC_TRACE                                      From LECFIC
Endif

Gosub LECTURE From GCONSULT
Gosub CLECUR  From GCONSULT

Return
######################################################################################
$LNK_PAR_NUM_ASC
Case [M:CCEI]SORT
    When 0 , 1
#      Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&          [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&          [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&          [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  NUM Asc
      Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&          [F:EFCPY]CPY0 = [F:EFSIH]CPY
&     As [LNK]
&     Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&     and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&     Order By  NUM Asc
#and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"

    When 2
#      Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&          [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&          [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&          [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  NUM Desc
      Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&          [F:EFCPY]CPY0 = [F:EFSIH]CPY
&     As [LNK]
&     Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&     and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&     Order By  NUM Desc
#&     and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"

Endcase

Return
###########################################################################################################
$LNK_PAR_DAT_ASC
Case [M:CCEI]SORT
  When 0 , 1
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  ACCDAT Asc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  ACCDAT Asc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"

  When 2
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  ACCDAT Desc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  ACCDAT Desc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
Endcase

Return
##################################################################################################################
$LNK_PAR_NUM_DESC
Case [M:CCEI]SORT
  When 0 , 1
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  NUM Desc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  NUM Desc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
  When 2
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  NUM Asc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  NUM Asc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
Endcase

Return
###########################################################################################################
#
###########################################################################################################
$LNK_PAR_DAT_DESC
Case [M:CCEI]SORT
  When 0 , 1
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  ACCDAT Desc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  ACCDAT Desc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
  When 2
#    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
#&        [F:EFBPC]BPC0 = [F:EFSIH]BPR,
#&        [F:EFBPR]BPR0 = [F:EFSIH]BPR,
#&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
#& As [LNK]
#& Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
#& and [F:EFBPC]ELECTINV = 2 and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
#& and [F:EFSIH]ACCDAT >= [F:EFBPC]STRDATEFAT
#& and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
#& Order By  ACCDAT Asc
    Link [F:EFSIH] With [F:EFDKD]DKD0 = "SAFT-PT";[F:EFSIH]SIVTYP;[F:EFSIH]NUM,
&        [F:EFCPY]CPY0 = [F:EFSIH]CPY
&   As [LNK]
&   Where ([F:EFSIH]INVTYP = 1 or [F:EFSIH]INVTYP = 2) and [F:EFSIH]STA = 3
&   and evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&   Order By  ACCDAT Asc
#&   and [F:EFDKD]BPEI >= 1 & [F:EFCPY]LEG = "POR"
Endcase

Return
