Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()

# Issue 110700
If VALEUR <> "" : [M]NUMFIN= VALEUR : Endif
# End issue 110700

End

Subprog AM_ALLSTATUS(VALEUR)
Variable Integer VALEUR

# Issue 110700
If GFONCTION = 'CONSCAT'
  If VALEUR = 2 : Diszo [M]ATEI : Else : Actzo [M]ATEI : Endif
Else
  If VALEUR = 2 : Diszo [M]BPEI : Else : Actzo [M]BPEI : Endif
Endif
# End issue 110700

End

Subprog AM_ALLDOCTYP(VALEUR)
Variable Integer VALEUR

# Issue 110700
If VALEUR = 2 : Diszo [M]INVTYP : Else : Actzo [M]INVTYP  : Endif
# End issue 110700

End

Subprog AS_INVTYP(VALEUR)
Variable Integer VALEUR

# Issue 110700
Discombo 5 From INVTYP
# End issue 110700

End


