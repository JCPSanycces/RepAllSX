######################################################################################
$REFRESH_FROM_DKS

If !clalev([DKD2]) : Local File DKSDATA[DKD2] : Endif

Read [F:DKD2]DKD0 = "SAFT-PT";[M:CEI2]SIVTYP(nolign-1);[M:CEI2]NUM(nolign-1)
If !fstat
  [M:CEI2]BPEI(nolign-1)       = [F:DKD2]BPEI
  [M:CEI2]ACCESSDATE(nolign-1) = [F:DKD2]ACCESSDATE
  [M:CEI2]ACCESSTIME(nolign-1) = [F:DKD2]ACCESSTIME
  [M:CEI2]EXPDATE(nolign-1)    = [F:DKD2]EXPDATE

  Affzo [M:CEI2]BPEI(nolign-1)          :    Actzo [M:CEI2]BPEI(nolign-1)
  Affzo [M:CEI2]ACCESSDATE(nolign-1)    :    Actzo [M:CEI2]ACCESSDATE(nolign-1)
  Affzo [M:CEI2]ACCESSTIME(nolign-1)    :    Actzo [M:CEI2]ACCESSTIME(nolign-1)
  Affzo [M:CEI2]EXPDATE(nolign-1)       :    Actzo [M:CEI2]EXPDATE(nolign-1)
Endif

Close Local File [DKD2]

Return
