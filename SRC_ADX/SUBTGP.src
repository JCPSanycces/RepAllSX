#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier TGRSSP
Call OBJET ("TGP", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "RAZCRE"       : Gosub RAZCRE
    When "SETBOUT"      : Gosub SETBOUT
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET    
Return

##########################################################################################################
$RAZCRE
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESTGL" Then
      Call AM_TGR([M:TGL0]TGRTAB)
    Endif
  Endif
Return

##########################################################################################################
$FILTRE
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FMGD1" Then
      If GNAVIG(GPILNAV) = "GESTGP" Then
        Default File [TGP]
        FILTSUP = "[F:TGP]TGR = [M:MGD1]CURTGR"
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESTGL" Then
      If GNAVIG(GPILNAV) = "GESTGP" Then
        Default File [TGP]
        FILTSUP = "[F:TGP]TGR = [M:TGL0]TGRTAB"
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FILGAUCHE
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FMGD1" Then
      If GNAVIG(GPILNAV) = "GESTGP" Then
        Default File [TGP]
        If currbox = "GAU_CHE" Then
          FILGAUCHE = "[F:TGP]TGR = [M:MGD1]CURTGR"
        Endif
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESTGL" Then
      If GNAVIG(GPILNAV) = "GESTGP" Then
        Default File [TGP]
        If currbox = "GAU_CHE" Then
          FILGAUCHE = "[F:TGP]TGR = [M:TGL0]TGRTAB"
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$LIENS
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGP0]TGR, [M:TGP0]TGRSSPNUM) From SUBTGPB
  Call SETTABSRT([M:TGP1]FIESRT) From SUBTGPB
  Affzo [M:TGP1]1-99
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:TGP1]TABSRT = "" Then
    #La table de tri n'est pas indiquée.
    GMESSAGE = mess(602,196,1)
    GERR = 3
    OK = 0
    Return
  Endif
  # Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau des champs affichés
  Gosub CHKFIESRT From SUBTGPB
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 06/03/2009 : X3SUIVI52963 Texte traduisible
  Call MAJTEXTRA([M:TGP0]TGRAXX, "TGRSSP", "TGRAXX", [M:TGP0]TGRSSPNUM, "") From ATEXTRA
  #Enregistre une description standard ou personnalisée des champs
  Gosub SAVEFIE From SUBTGPB
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
Return

##########################################################################################################
$APRES_CRE
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGP0]TGR, [M:TGP0]TGRSSPNUM) From SUBTGPB
  Affzo [M:TGP1]1-99
Return

##########################################################################################################
$APRES_MOD
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGP0]TGR, [M:TGP0]TGRSSPNUM) From SUBTGPB
  Affzo [M:TGP1]1-99
Return

##########################################################################################################
$AV_ANNULE
  Delete [TLF] Where [F:TLF]TGRTAB = [M:TGP0]TGR
  If fstat Then
    GOK = 0
    Call FSTA("TLF") From GLOCK
  Endif
Return

##########################################################################################################
$ANNULE
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call SUPTEXTRA("TGRSSP", "TGRAXX", [M:TGP0]TGRSSPNUM, "") From ATEXTRA
Return

##########################################################################################################
Subprog AM_TGR(VALEUR)
Variable Char    VALEUR()

Local Char SZTGRMAIKEY

  SZTGRMAIKEY = ""
  [M:TGP0]TGR = VALEUR
  #Défini une clé primaire par défaut et le champ de tri
  Filter [ATI] Where [F:ATI]CODFIC = [M:TGP0]TGR
  For [ATI]
    If !instr(1, [F:ATI]DESCRIPT, "+") Then
      If [F:ATI]HOMONYM = 1 Then
        SZTGRMAIKEY = [F:ATI]DESCRIPT
        [M:TGP1]FIESRT = [F:ATI]DESCRIPT
        [M:TGP1]TABSRT = [M:TGP0]TGR
        [M:TGP1]FIESRTTYP = 1
        Break
      Endif
    Endif
  Next
  Filter [ATI]
  #Charge la description des champs affichés
  If [M:TGP0]TGRSSPNUM <> "" Then
    Call LOADFIE([M:TGP0]TGR, [M:TGP0]TGRSSPNUM) From SUBTGPB
  Else
    #LSE 09/01/2007
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESTGL" Then
        Call LOADFIE([M:TGP0]TGR, [M:TGP0]TGRSSPNUM) From SUBTGPB
      Endif
    Endif
  Endif
  #Défini un champ de tri si une clé primaire n'a pas été trouvée
  If SZTGRMAIKEY = "" Then
    If [M:TGP1]NBFIE > 0 Then
      [M:TGP1]FIESRT = [M:TGP1]TGRFIE(0)
      [M:TGP1]TABSRT = [M:TGP1]TGRTABLNK(0)
      [M:TGP1]FIESRTTYP = 1
    Endif
  Endif
  Affzo [M:TGP0]1-99
  Affzo [M:TGP1]1-99
End

##########################################################################################################
Subprog AS_TGRTABLNK(VALEUR)
Variable Char    VALEUR()

  VALEUR = [M:TGP0]TGR
  [M:TGP1]TGRTABLNK(nolign-1) = VALEUR
  Affzo [M:TGP1]TGRTABLNK(nolign-1)
End

##########################################################################################################
Subprog C_TGRTABLNK(VALEUR)
Variable Char    VALEUR()

Local Integer IFOUND

  IFOUND = 0
  If VALEUR = [M:TGP0]TGR Then
    IFOUND = 1
  Else
    Filter [TLL] Where [F:TLL]TGRTAB = [M:TGP0]TGR
    For [TLL]
      If VALEUR <> "" Then
        If [F:TLL]TGRLNK <> "" Then
          If [F:TLL]TGRLNK = VALEUR Then
            IFOUND = 1
            Break
          Endif
        Endif
      Endif
    Next
    Filter [TLL]
  Endif
  If !IFOUND Then
    #La table indiquée n'a pas été liée avec la cible
    GMESSAGE = mess(600,196,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_TGRTABLNK(VALEUR)
Variable Char    VALEUR()

  [M:TGP1]TGRTABLNK(nolign-1) = VALEUR
  [M:TGP1]TGRFIE(nolign-1) = ""
  [M:TGP1]TGRFIENAM(nolign-1) = ""
  Affzo [M:TGP1]TGRTABLNK(nolign-1)
  Affzo [M:TGP1]TGRFIE(nolign-1)
  Affzo [M:TGP1]TGRFIENAM(nolign-1)
End

##########################################################################################################
Subprog C_TGRFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IZ
Local Integer INOL
Local Integer INBOCC
Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:TGP1]TGRTABLNK(nolign-1), VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    GERR = 2
    End
  Else
    INOL = nolign-1
    INBOCC = [M:TGP1]NBFIE-1
    #Vérifie si le champ n'a pas déjà été préalablement saisi dans le tableau
    For IZ = 0 To INBOCC
      If IZ <> INOL Then
        If [M:TGP1]TGRFIE(IZ) = VALEUR and [M:TGP1]TGRFIE(IZ) <> "" Then
          If [M:TGP1]TGRTABLNK(IZ) = [M:TGP1]TGRTABLNK(nolign-1) Then
            VALEUR = ""
            GMESSAGE = mess(24,123,1) - num$(IZ+1) : # Code déjà existant en ligne
            mkstat = 2
            GERR = 2
          Endif
        Endif
      Endif
      If GERR > 0 Then
        Break
      Endif
    Next
    If GERR Then
      End
    Endif
    If VALEUR <> "" Then
      Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(nolign-1);SZLEFTCRIFIE
      If fstat Then
        # XX n'est pas un champ de la table : YY
        GMESSAGE = VALEUR - mess(574,196,1) - [M:TGP1]TGRTABLNK(nolign-1)
        mkstat = 2
        GERR = 1
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TGRFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IFIEITER
Local Integer INOLCTL
Local Integer IMAXSRT
Local Char SZTEXTE(100)
Local Char SZLEFTCRIFIE(GLONAVA)

  INOLCTL = nolign-1
  IMAXSRT = 0
  SZTEXTE = ""
  [M:TGP1]TGRFIE(nolign-1) = VALEUR
  # FGR 12/01/2009 : X3SUIVI51579
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND(VALEUR)
  Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(nolign-1);SZLEFTCRIFIE
  If fstat Then
    [M:TGP1]TGRFIENAM(nolign-1) = ""
  Else
    Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
    [M:TGP1]TGRFIENAM(nolign-1) = left$(SZTEXTE, 40)
  Endif
  If [M:TGP1]TGRFIEORD(nolign-1) = 0 Then
    #Calcule une numéro maxi pour le nouveau champs
    For IFIEITER = 0 To dim([M:TGP1]TGRFIE)-1
      If IFIEITER <> INOLCTL Then
        If [M:TGP1]TGRFIE(IFIEITER) <> "" Then
          If [M:TGP1]TGRFIEORD(IFIEITER) > IMAXSRT Then
            IMAXSRT = [M:TGP1]TGRFIEORD(IFIEITER)
          Endif
        Endif
      Endif
    Next
    [M:TGP1]TGRFIEORD(nolign-1) = IMAXSRT + 1
  Endif
  Affzo [M:TGP1]TGRFIE(nolign-1)
  Affzo [M:TGP1]TGRFIENAM(nolign-1)
  Affzo [M:TGP1]TGRFIEORD(nolign-1)
End

##########################################################################################################
Subprog C_FIESRT(VALEUR)
Variable Char    VALEUR()

Local Integer IFIEFOUND
Local Integer Z2
Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:TGP1]TABSRT, VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    GERR = 1
    End
  Else
    IFIEFOUND = 0
    #Contrôle si le champs fait partie de la liste des champs affichés
    For Z2 = 0 To [M:TGP1]NBFIE-1
      If [M:TGP1]TGRFIE(Z2) = VALEUR Then
        IFIEFOUND = 1
        Break
      Endif
    Next
    If !IFIEFOUND Then
      #Ce champs ne fait pas partie de la liste ci-dessus. Saisie refusée.
      GMESSAGE = mess(750,196,1) - mess(627,196,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FIESRT(VALEUR)
Variable Char    VALEUR()

Local Integer ITER

  [M:TGP1]FIESRT = VALEUR
  If [M:TGP1]FIESRT <> "" Then
    For ITER = 0 To [M:TGP1]NBFIE-1 
      If [M:TGP1]TGRFIE(ITER) = [M:TGP1]FIESRT Then
        [M:TGP1]TABSRT = [M:TGP1]TGRTABLNK(ITER)
        Break
      Endif
    Next
  Endif
  Call SETTABSRT([M:TGP1]FIESRT) From SUBTGPB
  Affzo [M:TGP1]FIESRT
End

##########################################################################################################
Subprog C_TABSRT(VALEUR)
Variable Char    VALEUR()

Local Integer Z2
Local Integer IFOUND

  IFOUND = 0
  For Z2 = 0 To [M:TGP1]NBFIE-1 
    If [M:TGP1]TGRFIE(Z2) = [M:TGP1]FIESRT Then
      If [M:TGP1]TGRTABLNK(Z2) = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Endif
  Next
  If !IFOUND Then
    #La table indiquée est incorrecte. Saisie refusée.
    GMESSAGE = mess(601,196,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog B1_TGRSSPNUM(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR

  SZVALEUR = VALEUR
  Call SETUSERTGP(SZVALEUR, [M:TGP0]TGR) From SUBTGPB
End

##########################################################################################################
Subprog C_TGR(VALEUR)
Variable Char    VALEUR()

  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FMGD1" Then
      If VALEUR <> [M:MGD1]CURTGR Then
        #Il n'est pas possible de définir un support de présentation
        # pour une cible différente de celle du ciblage sélectionné.
        GMESSAGE = mess(767,196,1)
        GERR = 1
        mkstat = 2
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESTGL" Then
      If VALEUR <> [M:TGL0]TGRTAB Then
        #Il n'est pas possible de définir un support de présentation
        # pour une cible différente de la cible courante.
        GMESSAGE = mess(768,196,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TGRFIEORD(VALEUR)
Variable Decimal VALEUR

  #Vérifie si le calcul des positions est activé
  Read [DVA]DVA0="PSS";GUSER
  If fstat Then
    [M:TGP1]TGRFIEORD(nolign-1) = VALEUR
    Affzo [M:TGP1]TGRFIEORD(nolign-1)
    End
  Else
    If [F:DVA]INTX(0) = 0 Then
      [M:TGP1]TGRFIEORD(nolign-1) = VALEUR
      Affzo [M:TGP1]TGRFIEORD(nolign-1)
      End
    Endif
  Endif

#Maintien une suite logique de numéros d'ordres
Local Integer INOL
Local Integer ITERTAB
Local Integer ITERWHOLE
Local Integer ITERMORE
Local Integer ITERLACK
Local Integer INUMFOUND
Local Integer IMINI
Local Integer ITESTMINI
Local Integer IVALEXIST
Local Integer IHOMONYME
Local Integer IPHOTO(250)
Local Integer ITERPHOTO
Local Integer IMAXPHOTO
Local Integer IGOODINDEX
Local Integer ICOMPUTE(250)
Local Integer ICOUNT
Local Integer IVALPASSED
Local Integer ITEROCC

  INOL = nolign-1
  INUMFOUND = 0
  ITESTMINI = 0
  IMINI = 0
  Call TEMPON(mess(44, 182, 2)) From GESECRAN
  If VALEUR >= dim([M:TGP1]TGRFIEORD) Then
    VALEUR = dim([M:TGP1]TGRFIEORD)-1
  Endif
  [M:TGP1]TGRFIEORD(nolign-1) = VALEUR
  #Charge IPHOTO
  Raz IPHOTO
  For ITERWHOLE = 0 To dim([M:TGP1]TGRFIEORD)-1
    IPHOTO(ITERWHOLE) = [M:TGP1]TGRFIEORD(ITERWHOLE)
  Next
  For ITERWHOLE = 1 To dim([M:TGP1]TGRFIEORD)-1
    #Compte les occurences de chaque chiffre
    Raz ICOMPUTE
    For ITEROCC = 1 To dim([M:TGP1]TGRFIEORD)-1
      ICOUNT = 0
      For ITERTAB = 0 To [M:TGP1]NBFIE-1
        If [M:TGP1]TGRFIEORD(ITERTAB) = ITEROCC Then
          ICOUNT += 1
        Endif
      Next
      ICOMPUTE(ITEROCC) = ICOUNT
    Next
    #Cherche si VALEUR est égale à ITERWHOLE
    IVALEXIST = 0
    For ITERTAB = 0 To [M:TGP1]NBFIE-1
      If [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE Then
        If ITERTAB = INOL Then
          IVALEXIST = 1
          Break
        Endif
      Endif
    Next
    #Réalise les contrôles nécessaires à la priorité des incrémentations
    If ICOMPUTE(ITERWHOLE) > 1 Then
      If ITERWHOLE <> [M:TGP1]TGRFIEORD(INOL) Then
        #On recherche le chiffre avec le poids initiale le plus fort
        IMAXPHOTO = 0
        For ITERPHOTO = 0 To dim(IPHOTO)-1
          If [M:TGP1]TGRFIEORD(ITERPHOTO) = ITERWHOLE Then
            If IPHOTO(ITERPHOTO) > IMAXPHOTO Then
              IMAXPHOTO = IPHOTO(ITERPHOTO)
              IGOODINDEX = ITERPHOTO
            Endif
          Endif
        Next
      Endif
    Endif
    #Cherche ITERWHOLE dans le tableau
    ITERMORE = ITERWHOLE
    IVALPASSED = 0
    INUMFOUND = 0
    For ITERTAB = 0 To [M:TGP1]NBFIE-1
      If [M:TGP1]TGRFIEORD(ITERTAB) > 0 Then
        If [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE Then
          If ITERTAB = INOL Then
            VALEUR = ITERWHOLE
            [M:TGP1]TGRFIEORD(ITERTAB) = VALEUR
          Else
            If ICOMPUTE(ITERWHOLE) > 1 Then
              If ITERWHOLE = [M:TGP1]TGRFIEORD(INOL) Then
                [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE + 1
              Else
                If ITERTAB = IGOODINDEX Then
                  [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE + 1
                Else
                  [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE
                Endif
              Endif
            Else
              [M:TGP1]TGRFIEORD(ITERTAB) = ITERWHOLE
            Endif
          Endif
          ITERMORE += 1
          INUMFOUND = 1
        Endif
      Endif
    Next
    If !INUMFOUND Then
      #On recherche le chiffre immédiatement supérieur à ITERWHOLE
      IMINI = 250
      INUMFOUND = 0
      For ITERTAB = 0 To [M:TGP1]NBFIE-1
        If [M:TGP1]TGRFIEORD(ITERTAB) > 0 Then
          ITESTMINI = [M:TGP1]TGRFIEORD(ITERTAB) - ITERWHOLE
          If ITESTMINI > 0 Then
            If ITESTMINI < IMINI Then
              IMINI = ITESTMINI
              ITERMORE = [M:TGP1]TGRFIEORD(ITERTAB)
            Endif
          Endif
        Endif
      Next
      #Cherche si VALEUR est égale à ITERMORE
      #Cherche également si un homonyme de valeur est présent
      IVALEXIST = 0
      IHOMONYME = 0
      For ITERTAB = 0 To [M:TGP1]NBFIE-1
        If [M:TGP1]TGRFIEORD(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            IVALEXIST = 1
          Else
            IHOMONYME = 1
          Endif
        Endif
      Next
      ITERLACK = ITERMORE - IMINI
      For ITERTAB = 0 To [M:TGP1]NBFIE-1
        If [M:TGP1]TGRFIEORD(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            If IHOMONYME Then
              VALEUR = (ITERMORE - IMINI) + 1
            Else
              VALEUR = ITERMORE - IMINI
            Endif
            [M:TGP1]TGRFIEORD(ITERTAB) = VALEUR
          Else
            If IVALEXIST Then
              If ITERLACK = [M:TGP1]TGRFIEORD(INOL) Then
                ITERLACK += 1
                [M:TGP1]TGRFIEORD(ITERTAB) = ITERLACK
              Else
                [M:TGP1]TGRFIEORD(ITERTAB) = ITERLACK
              Endif
            Else
              [M:TGP1]TGRFIEORD(ITERTAB) = ITERLACK
            Endif
          Endif
          ITERLACK += 1
        Endif
      Next
    Endif
  Next
  Call TEMPOFF From GESECRAN
  Affzo [M:TGP1]1-99
End

##########################################################################################################
Subprog IB_NBFIE
  Gosub ACTIVEPSS From SUBTGLB
End

##########################################################################################################
Subprog B1_NBFIE
  Gosub SETPSS From SUBTGLB
End

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un support de présentation       #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File TGRSSP [TGP1]
    Local File TGRLISFIE [TLF1]
    Local File ATEXTRA [AXX1]
  Else
    Local File =[M]DOSORG+".TGRSSP" [TGP1]
    Local File =[M]DOSORG+".TGRLISFIE" [TLF1]
    Local File =[M]DOSORG+".ATEXTRA" [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TGRSSP [TGP2]
    Local File TGRLISFIE [TLF2]
    Local File ATEXTRA [AXX2]
  Else
    Local File =[M]DOSDES+".TGRSSP" [TGP2]
    Local File =[M]DOSDES+".TGRLISFIE" [TLF2]
    Local File =[M]DOSORG+".ATEXTRA" [AXX2]
  Endif
  OK = 1
  Look [TGP2]TGP0=TABLE
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [TGP1], [TLF1], [TGP2], [TLF2], [AXX1], [AXX2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'un support de présentation#
  #--------------------------------------------------#
  GOK = 1
  Trbegin [TGP2]
  Delete [TLF2] Where TGRSSPNUM=TABLE
  If fstat = 1 Then
    GOK = -1  
    GLOCK = "$" + [M]DOSDES + ".TGRLISFIE" - TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("TLF2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [TGP2] Where TGRSSPNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".TGRSSP" - TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("TGP2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  If GOK = 1 Then
    Read [TGP1]TGP0=TABLE
    If !fstat Then
      [F:TGP2] = [F:TGP1]
      Write [TGP2]
      If fstat Then
        GOK = 0
        Call FSTA("TGP2") From GLOCK  
        Goto AB_COPIE  
      Endif
      # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
      Call COPTEXTRA("TGRSSP", "TGRAXX", [M:TGP0]TGRSSPNUM, "") From ATEXTRA
      If GOK = 0 Then
        Goto AB_COPIE
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [TLF1] Where [F:TLF1]TGRSSPNUM = TABLE
    For [TLF1]
      [F:TLF2] = [F:TLF1]
      Write [TLF2]
      If fstat Then
        GOK = 0
        Call FSTA("TLF2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [TLF1]
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK  
  If !GROLL Then
    Goto TRT_COPIE 
  Endif 
Return
