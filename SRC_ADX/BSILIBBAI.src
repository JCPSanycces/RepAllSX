#**
#* Retrieve the currency code for 02 segment
#*!
Funprog CURRENCY_CODE_SEGMENT_02(W_LINECLEARED)
  Value Clbfile W_LINECLEARED
  Local Char W_RECORD_CODE(2)
  Local Char W_ULTIMATE_RECEIVER_IDENTIFICATION(1)
  Local Char W_ORIGINATOR_IDENTIFICATION(1)
  Local Char W_GROUP_STATUS(1)
  Local Char W_AS_OF_DATE(6)
  Local Char W_AS_OF_TIME(1)
  Local Char W_CURRENCY_CODE(3)
  Local Integer W_POS : W_POS = 1

  W_RECORD_CODE                       = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_ULTIMATE_RECEIVER_IDENTIFICATION  = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_ORIGINATOR_IDENTIFICATION         = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_GROUP_STATUS                      = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_AS_OF_DATE                        = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_AS_OF_TIME                        = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_CURRENCY_CODE                     = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)

End W_CURRENCY_CODE

#**
#* Retrieve the currency code for 03 segment
#*!
Funprog CURRENCY_CODE_SEGMENT_03(W_LINECLEARED)
  Value Clbfile W_LINECLEARED
  Local Char W_RECORD_CODE(2)
  Local Char W_CUSTOMER_ACCOUNT_NUMBER(1)
  Local Char W_CURRENCY_CODE(3)
  Local Integer W_POS : W_POS = 1

  W_RECORD_CODE              = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_CUSTOMER_ACCOUNT_NUMBER  = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)
  W_CURRENCY_CODE            = func BSILIBBAI.GET_NEXT_FIELD(W_LINECLEARED, W_POS)

End W_CURRENCY_CODE

#**
#* Handle 03 segment to retrieve 010 and 015 type code
#*!
Funprog HANDLE_SEGMENT_03(W_AMOUNTFIELD,TMPSTMCOD,TRANSCOUNTER,STATCOUNTER,CURRLIN,IMPORTNAME, W_CURRENT_TMPSTMCOD, W_PREVIOUS_TMPSTMCOD, W_TMPSTMCOD_FIRST,W_TMPSTMCOD_LAST,W_TRANSCOUNTER_FIRST,
& W_TRANSCOUNTER_LAST,
& PRVREC, CURREC)
  Value Clbfile W_AMOUNTFIELD
  Variable Char TMPSTMCOD
  Variable Char W_CURRENT_TMPSTMCOD, W_PREVIOUS_TMPSTMCOD, W_TMPSTMCOD_FIRST, W_TMPSTMCOD_LAST
  Variable Integer TRANSCOUNTER
  Variable Integer W_TRANSCOUNTER_FIRST, W_TRANSCOUNTER_LAST
  Variable Integer STATCOUNTER
  Variable Integer CURRLIN
  Variable Char IMPORTNAME
  Value    Char PRVREC
  Value    Char CURREC

  Local Integer TC_IS_RESOLVED
  Local Char RETURNMESSAGE(200)
  Local Char W_TYPE_CODE(3)
  Local Char W_THERE_IS_TYPE_CODE_010(1)  : W_THERE_IS_TYPE_CODE_010 = "N"
  Local Char W_THERE_IS_TYPE_CODE_015(1)  : W_THERE_IS_TYPE_CODE_015 = "N"
  Local Char W_TYPE_CODE_010(3)           : W_TYPE_CODE_010 = "010"
  Local Char W_TYPE_CODE_015(3)           : W_TYPE_CODE_015 = "015"
  Local Char W_CREDIT(1)                  : W_CREDIT = "C"
  Local Char W_DEBIT(1)                   : W_DEBIT = "D"
  Local Char W_NO(1)                      : W_NO = "N"
  Local Char W_YES(1)                     : W_YES = "S"
  Local Decimal W_INTEGER_AMOUNT, W_INTEGER_AMOUNT_010, W_INTEGER_AMOUNT_015
  Local Integer W_COUNTER, W_POS : W_POS = 1
  Local Integer W_DIV_100 : W_DIV_100 = 100
  Local Integer W_ZERO_NUMBER : W_ZERO_NUMBER = 0
  Local Char W_FUNDS_TYPE(1), W_ITEM_COUNT(30), W_CHAR_AMOUNT(30)
  Local Char W_DUMMY_CUR(3)
  Local Integer LEVEL

  LEVEL = 2 # line 3 from the BAI file -> summary
  W_DUMMY_CUR = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)

  While W_POS < len(W_AMOUNTFIELD)
    W_TYPE_CODE   = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
    W_CHAR_AMOUNT = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
    W_ITEM_COUNT  = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
    W_FUNDS_TYPE  = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
    Gosub PARSE_FUNDS_TYPE

    Case W_TYPE_CODE
      When W_TYPE_CODE_010
        W_INTEGER_AMOUNT = val(W_CHAR_AMOUNT)
        [F:BSIIMP]BLCSTR = abs((W_INTEGER_AMOUNT) / W_DIV_100)
        W_COUNTER = W_POS
        If W_INTEGER_AMOUNT >= W_ZERO_NUMBER : [F:BSIIMP]BLCSTRSNS = W_CREDIT : Else : [F:BSIIMP]BLCSTRSNS = W_DEBIT : Endif
        W_THERE_IS_TYPE_CODE_010 = W_YES
        W_INTEGER_AMOUNT_010 = W_INTEGER_AMOUNT
      When W_TYPE_CODE_015
        W_INTEGER_AMOUNT = val(W_CHAR_AMOUNT)
        [F:BSIIMP]BLCEND = abs((W_INTEGER_AMOUNT) / W_DIV_100)
        W_COUNTER = W_POS
        If W_INTEGER_AMOUNT >= W_ZERO_NUMBER : [F:BSIIMP]BLCENDSNS = W_CREDIT : Else : [F:BSIIMP]BLCENDSNS = W_DEBIT : Endif
        W_THERE_IS_TYPE_CODE_015 = W_YES
        W_INTEGER_AMOUNT_015 = W_INTEGER_AMOUNT
       When Default
      Gosub RESOLVETYPECODE
         If TC_IS_RESOLVED = [V]CST_ATRUE
                 W_INTEGER_AMOUNT = val(W_CHAR_AMOUNT)
                 [F:BSIIMP]BLCEND = abs((W_INTEGER_AMOUNT) / W_DIV_100)
                 If [F:BSIITCD]SIG = 1
                       [F:BSIIMP]BLCENDSNS = W_CREDIT
                        Call ECR_TRACE("#Info# line 03- Type code: " + W_TYPE_CODE + " Bank: " + [F:BSIITCD]BAN +  " --> Credit" ,-1) From GESECRAN
                  Else
                        [F:BSIIMP]BLCENDSNS = W_DEBIT
                        Call ECR_TRACE("#Info# line 03- Type code: " + W_TYPE_CODE + " Bank: " + [F:BSIITCD]BAN +  " --> Debit",-1) From GESECRAN
                  Endif
         Else
                  Call ECR_TRACE("#Warning# - " + RETURNMESSAGE,-1) From GESECRAN

         Endif

    Endcase
  Wend

  If W_THERE_IS_TYPE_CODE_010 = W_NO : Raz [F:BSIIMP]BLCSTR : Raz [F:BSIIMP]BLCSTRSNS : Endif
  If W_THERE_IS_TYPE_CODE_015 = W_NO : Raz [F:BSIIMP]BLCEND : Raz [F:BSIIMP]BLCENDSNS : Endif
  If W_THERE_IS_TYPE_CODE_010 = W_YES and W_INTEGER_AMOUNT_010 = W_ZERO_NUMBER : Raz [F:BSIIMP]BLCSTRSNS : Endif
  If W_THERE_IS_TYPE_CODE_015 = W_YES and W_INTEGER_AMOUNT_015 = W_ZERO_NUMBER : Raz [F:BSIIMP]BLCENDSNS : Endif
  If W_THERE_IS_TYPE_CODE_010 = W_YES and W_INTEGER_AMOUNT_010 = W_ZERO_NUMBER
& and W_THERE_IS_TYPE_CODE_015 = W_YES and W_INTEGER_AMOUNT_015 = W_ZERO_NUMBER
    Raz [F:BSIIMP]BLCSTRSNS, [F:BSIIMP]BLCENDSNS
  Endif

  Local Integer STAT                : STAT = 0
    If !(PRVREC = "03" and CURREC = "49")
      Gosub CREATE_HEADER From BSIIMPORT
    Endif

End ""

#**
#* Extract text information from string field of import file and split it to FREREF fields
#*!
Funprog HANDLE_SEGMENT_16(W_AMOUNTFIELD, W_CURRENT_TMPSTMCOD, W_PREVIOUS_TMPSTMCOD, W_TMPSTMCOD_FIRST,W_TMPSTMCOD_LAST,W_TRANSCOUNTER_FIRST,W_TRANSCOUNTER_LAST)
  Variable Char W_CURRENT_TMPSTMCOD, W_PREVIOUS_TMPSTMCOD, W_TMPSTMCOD_FIRST, W_TMPSTMCOD_LAST
  Variable Integer W_TRANSCOUNTER_FIRST, W_TRANSCOUNTER_LAST
  Value Clbfile W_AMOUNTFIELD
  Local Clbfile W_FIELD(0)
  Local Char W_FUNDS_TYPE(1), W_TYPE_CODE(3), W_REF_BANK(30), W_CUST_REF(30)
  Local Char W_CREDIT(1) : W_CREDIT = "C"
  Local Char W_DEBIT(1) : W_DEBIT = "D"
  Local Integer W_COUNTER, W_POS : W_POS = 1
  Local Integer W_DIV_100 : W_DIV_100 = 100
  Local Integer W_ZERO_NUMBER : W_ZERO_NUMBER = 0
  Local Decimal W_INTEGER_AMOUNT
  Local Char RETURNMESSAGE(200)
  Local Integer TC_IS_RESOLVED
  Local Integer LEVEL

  LEVEL = 3 # line 16 = detail
  RETURNMESSAGE = ""

  W_TYPE_CODE       = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
  [F:BSIIMPD]AMTCUR = val(func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)) / W_DIV_100
  If [F:BSIIMPD]AMTCUR >= W_ZERO_NUMBER : [F:BSIIMPD]SNS = W_CREDIT : Else : [F:BSIIMPD]SNS = W_DEBIT : Endif
  W_FUNDS_TYPE      = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)

  Gosub PARSE_FUNDS_TYPE

  W_REF_BANK        = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)
  W_CUST_REF        = func BSILIBBAI.GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)

  Gosub RESOLVETYPECODE

  If TC_IS_RESOLVED = [V]CST_ATRUE
        If [F:BSIITCD]SIG = 1  ## 1 = CR 2 = DB
            [F:BSIIMPD]SNS  = W_CREDIT
            Call ECR_TRACE("#Info# 16- TC: " + W_TYPE_CODE + " Bank: " + W_REF_BANK + " --> Credit",-1) From GESECRAN
        Else
            Call ECR_TRACE("#Info# 16- TC: " + W_TYPE_CODE + " Bank: " + W_REF_BANK + " --> Debit",-1) From GESECRAN
            [F:BSIIMPD]SNS  = W_DEBIT
        Endif
        RETURNMESSAGE = ""
  Else
         ## block the import process
        RETURNMESSAGE = "#Error# - " + RETURNMESSAGE
  Endif
  W_FIELD = mid$(W_AMOUNTFIELD, W_POS, len(W_AMOUNTFIELD) - (W_POS - 1)) : Setlob [F:BSIIMPD]FREREF With W_FIELD

End RETURNMESSAGE

#**
#* Returns next field
#*
#* @param  : string to be parsed
#* @param  : position in the string to start looking for field separator
#* @return : contents of the next field in the string
#*!
Funprog GET_NEXT_FIELD(W_CURRENT_FIELD, W_INITIAL_POSITION)
  Variable Clbfile W_CURRENT_FIELD()()
  Variable Integer W_INITIAL_POSITION
  Local Char W_NEXT_FIELD(255), W_FLDSEP(1) : W_FLDSEP = ","
  Local Integer I

  I = instr(W_INITIAL_POSITION, W_CURRENT_FIELD, W_FLDSEP)
  If I <> 0
    W_NEXT_FIELD = seg$(W_CURRENT_FIELD, W_INITIAL_POSITION, I - 1)
    W_INITIAL_POSITION = I + 1
  Else
    W_NEXT_FIELD = seg$(W_CURRENT_FIELD, W_INITIAL_POSITION, len(W_CURRENT_FIELD))
    W_INITIAL_POSITION = len(W_CURRENT_FIELD)
  Endif
End W_NEXT_FIELD

#**
#* Parse funds type
#*!
$PARSE_FUNDS_TYPE
  Local Clbfile DUMMY
  Case W_FUNDS_TYPE
    When "0"
    When "1"
    When "2"
    When "S"
      DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # Immediate availability amount
      DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # One-day availability amount
      DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # > 1 day availability amount
    When "V"
      DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # Value date
      DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # Value time
    When "D"
      Local Char NO_OF_FIELDS(5)
      Local Integer I : I = 1
      NO_OF_FIELDS = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS)  # No. of availability distros.
      While I <= val(NO_OF_FIELDS)
        DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS) # Availability in days
        DUMMY = func GET_NEXT_FIELD(W_AMOUNTFIELD, W_POS) # available amount
        I += 1
      Wend
    When "Z", ""
  Endcase
Return


#**
#**resolve the type codes
#**input: level (2 summary , 3 detail)
#**output TC_IS_RESOLVED (true/FALSE), RETURNMESSAGE (string)
#**
$RESOLVETYPECODE
Local Char  W_BANK(30)
W_BANK        = [M:BSIIMP]BAN    ## bank from screen
If W_BANK = ""
W_BANK = [F:BAN]BAN ##BANK From File (account identifier)
Endif

If [F:BAN]BAN <> "" and W_BANK <> "" and W_BANK <> [F:BAN]BAN
 TC_IS_RESOLVED = [V]CST_AFALSE
 RETURNMESSAGE = "Bank is not defined. Type codes can not be resolved."
 Return
Endif

  Read [F:BSIIMPTC]BSITC1 = W_BANK
        If !fstat
        Else   # if there is no set of type codes for the used bank we use the default type codes set (empty bank)
          Call ECR_TRACE("#Info# No type code set found for bank: " + W_BANK + " default Type code set will be used instead.",-1) From GESECRAN
          W_BANK = ""
        Endif

    Read [F:BSIITCD]BSITCD2 = W_BANK;W_TYPE_CODE;LEVEL #level 3 means detail
        If !fstat
              ##      [F:BSIITCD]SIG  "Credit"/"Debit"
            TC_IS_RESOLVED = [V]CST_ATRUE
            RETURNMESSAGE = "Related Type code retrieved for this bank and type code set: " +  W_BANK +"/"+ W_TYPE_CODE

        Else
            TC_IS_RESOLVED = [V]CST_AFALSE
            RETURNMESSAGE = "Could not retrieve any related Type code for this bank and type code set: " +  W_BANK +"/"+ W_TYPE_CODE
        Endif


Return

