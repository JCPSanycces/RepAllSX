# Gestion du masque MANL

##########################################################################
## Etiquette ajoutée par le superviseur 04/09/2003 14:02:29 (MM)
##########################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM From FUNMANL
Endif                               # mm 12.02
End

Subprog AM_CLCANA(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1: [M:DIA]STRANA = [0/0/0]
    When 2: LASTMONTH = addmonth(date$,-1)
            [M:DIA]STRANA = gdat$(1,month(LASTMONTH),year(LASTMONTH))
Endcase
Affzo [M:DIA]STRANA
End

Subprog C_STRANA(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]MSTDAT : mkstat = 2 : Endif
End

Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

