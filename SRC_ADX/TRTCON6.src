#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la saisie des valeurs d'indices         Module CRM         7 septembre 2000
#                des contrats de services
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "CLE_GAUCHE"   : Gosub CLE_GAUCHE
    When "ENR"          : Gosub ENREG
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:CIX]) : Local File CONTIDX [CIX] : Endif
Return

##########################################################################################################
$FILGAUCHE
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "NUMTAB=410", "&") From GOBJSUB
Return

##########################################################################################################
$DEBUT
  Gosub TIROIR
  Filter [ADI] Where [F:ADI]NUMTAB = 410 Order By [F:ADI]CODE Asc
  For [ADI]
    [M:CON6]INDCODE=[F:ADI]CODE
    Break
  Next
  Filter [ADI]
  If [M:CON6]INDCODE <> "" Then
    Gosub LOAD_VALEUR
  Endif
  Affzo [M:CON6]1-99
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CON6]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
  Gosub LOAD_VALEUR
  REP = ""
  Affzo [M:CON6]1-99
Return

##########################################################################################################
$ENREG
Local Integer IBERROR
Local Integer ILIGNE

  IBERROR = 0
  Call DEBTRANS From GLOCK
  Trbegin [CIX]
  ILIGNE = 0
  Delete [CIX] Where [F:CIX]IND=[M:CON6]INDCODE
  If fstat <> 0 Then
    #Erreur lors de la mise à jour des valeurs de l'indice
    GMESSAGE = mess(592,177,1)
    IBERROR = 1
  Endif
  ILIGNE = 0
  While ILIGNE < [M:CON6]NBVAL and IBERROR = 0
    If [M:CON6]INDDAT(ILIGNE) <> [00/00/00] and [M:CON6]INDVAL(ILIGNE) <> 0 Then
      [F:CIX]IND = [M:CON6]INDCODE
      [F:CIX]INDDAT = [M:CON6]INDDAT(ILIGNE)
      [F:CIX]INDVAL = [M:CON6]INDVAL(ILIGNE)
      Write [CIX]
      If fstat <> 0 Then
        #Erreur lors de la mise à jour des valeurs de l'indice
        GMESSAGE = mess(592,177,1)
        IBERROR = 1
        Break
     Endif
    Endif
    ILIGNE += 1
  Wend
  If IBERROR = 1 Then
    Rollback
    GOK = 0
    GERR = 1
  Else
    Commit
    Gosub LOAD_VALEUR
    REP = ""
  Endif
  Affzo [M:CON6]1-99
Return

##########################################################################################################
$APRES_MODIF
  #If COUZON = "INDDAT" or COUZON = "INDVAL" Then                    # Issue X3-46729 - 2017-06-30 by FGR
  If COUZON = "INDDAT" or COUZON = "INDVAL" or COUZON = "NBVAL" Then # Issue X3-46729 - 2017-06-30 by FGR
    REP = "M"
  Elsif COUZON = "INDCODE" Then
    REP = ""
  Endif
Return

##########################################################################################################
$TIROIR
  #-----------------------------------------------------------------------#
  # Remplissage de la liste de picking                                    #
  #-----------------------------------------------------------------------#
  ILIS = val(right$(currbox,8))
  Gosub REMPLIT From GSAISIE
Return

##########################################################################################################
CLE_GAUCHE
  If [M:CON6]INDCODE <> [F:ADI]CODE Then
    [M:CON6]INDCODE = [F:ADI]CODE
    Gosub LOAD_VALEUR
    REP = ""
    Affzo [M:CON6]1-99
  Endif
Return

##########################################################################################################
$LOAD_VALEUR
Local Integer IINDICE

  Effzo [M:CON6]20
  [M:CON6]NBVAL = 0
  IINDICE = 0
  Filter [CIX] Where [F:CIX]IND = [M:CON6]INDCODE Order By [F:CIX]INDDAT Desc
  For [CIX] Hint Key CIX1
    If IINDICE >= dim([M:CON6]INDDAT) Then
      Break
    Endif
    [M:CON6]INDDAT(IINDICE) = [F:CIX]INDDAT
    [M:CON6]INDVAL(IINDICE) = [F:CIX]INDVAL
    IINDICE += 1
  Next
  [M:CON6]NBVAL = IINDICE
  Filter [CIX]
Return

