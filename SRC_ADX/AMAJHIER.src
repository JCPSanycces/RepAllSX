#<AdxTL>@(#)2.0.0.0 $Revision$
#     Mise à jour des nomenclatures
#     par l'XSL standard de mise à jour nomenclature
#
#     Les champs suivants doivent etre présents dans le tableau :
#
#     NBCMP     : Nombre de composants (variable bas de tableau)
#     PARENT    : Père de l'enregistrement courant
#     KEYC      : Clé de l'enregistrement courant
#     LIBSHORT  : Libellé court
#     LIBL1     : Libellé long
#     ICO       : Icône
#     IMG       : Image
#     QTE       : Quantité
#     UNITE     : Unité
#
#     Les paramètres :
#
#     CODACT  : Code action 
#           D : Delete
#           M : Modify
#           E : clic dernier élément
#     NLI     : Numéro de ligne du composant à traiter (1 à n)
#     FATHVAL : Valeur du père de rattachement
#     RANGNIV : Rang de rattachement par rapport au père (1 à n)
#               Si RANGNIV<0 on rattache "avant", si >0 "après"
#     MESSAGE : Message 
#     CODRET  : 1 Si OK


Subprog MAJHIER(CODACT,NLI,FATHVAL,RANGNIV,MESSAGE,CODRET)
Value Char CODACT
Value Integer NLI
Value Integer FATHVAL
Value Integer RANGNIV
Variable Char MESSAGE
Variable Integer CODRET
Local Integer I,LIGREF,NBTODEL,TROUV,LIGCOU,LIGDEL,NBSUP
Local Char FATHTODEL(30)(1..1000)
CODRET=1
Case CODACT
  When "M" : Gosub MODNOM
  When "D" : Gosub SUPNOM
  When "E" : Gosub CLICNOM
  When Default : MESSAGE=mess(25,126,1) : CODRET=3 : # "Code incorrect"
Endcase

End

$CLICNOM
#  C'est ici que l'on doit définir la fonction à appeler sur clic
# Point d'entrée
GPOINT = "CLICNOM" : Gosub ENTREE From EXEFNC
Return

$SUPNOM:
 NBTODEL+=1 : FATHTODEL(NBTODEL)=[M]KEYC(NLI-1)
 Dela NLI-1 [M]NBCMP : NBSUP+=1  
#   Recherche et détruit tous les enreg qui ont pour PERE celui détruit
#   Incrémente la liste des pères à détruire
$DETREC
 TROUV=0
 For I=[M]NBCMP-1 To 0 Step -1
  If find([M]PARENT(I),FATHTODEL(1..NBTODEL))
    If !find([M]KEYC(I),FATHTODEL(1..NBTODEL))
      NBTODEL+=1
      TROUV=1
      FATHTODEL(NBTODEL)=[M]KEYC(I)
    Endif
    Dela I [M]NBCMP : NBSUP+=1
  Endif
 Next I
 If TROUV=1 : Goto DETREC : Endif
 [M]NBCMP-=NBSUP
 Affzo [M]
 If I>=1 : zonsui=[M]NBCMP(I-1) : Endif
Return


$MODNOM:
  LIGREF=FATHVAL
  If LIGREF=0
 #   "Erreur de données" 
    MESSAGE=mess(88,151,1)
    CODRET=2
    Return
  Endif
  If RANGNIV=0
    [M]PARENT(NLI-1)=[M]KEYC(LIGREF-1)
  Else
    [M]PARENT(NLI-1)=[M]PARENT(LIGREF-1)
  Endif
#  Sauve ligne courante
 Gosub SAVLIGCOU

#  Décalage des lignes
 LIGCOU=LIGREF
 If RANGNIV<0 : LIGCOU=LIGREF-1 : Endif
 Insa LIGCOU [M]NBCMP
 [M]NBCMP+=1
#  Charge la nouvelle ligne
 Gosub RESTLIGCOU 

 LIGDEL=NLI-1
 If LIGCOU<NLI : LIGDEL+=1 : Endif
 Dela LIGDEL [M]NBCMP
 [M]NBCMP-=1

 Affzo [M]
Return


$SAVLIGCOU
  Local Char PERREF(50),KEYCREF(50),DESILONREF(50),UNITEREF,IMGREF(30),ICOREF(30),DESISHREF(50)
  Local Decimal QTEREF
  PERREF=[M]PARENT(NLI-1)
  KEYCREF=[M]KEYC(NLI-1)
  If dim([M]LIBSHORT)>0 : DESISHREF=[M]LIBSHORT(NLI-1) : Endif
  If dim([M]LIBL1)>0    : DESILONREF=[M]LIBL1(NLI-1)   : Endif
  If dim([M]IMG)>0      : IMGREF=[M]IMG(NLI-1)         : Endif
  If dim([M]ICO)>0      : ICOREF=[M]ICO(NLI-1)         : Endif
  If dim([M]QTE)>0      : QTEREF=[M]QTE(NLI-1)         : Endif
  If dim([M]UNITE)>0    : UNITEREF=[M]UNITE(NLI-1)     : Endif
Return

$RESTLIGCOU 
  [M]PARENT(LIGCOU)=PERREF
  [M]KEYC(LIGCOU)=KEYCREF
  If dim([M]LIBSHORT)>0 : [M]LIBSHORT(LIGCOU)=DESISHREF  : Endif
  If dim([M]LIBL1)>0    : [M]LIBL1(LIGCOU)=DESILONREF    : Endif
  If dim([M]IMG)>0      : [M]IMG(LIGCOU)=IMGREF          : Endif
  If dim([M]ICO)>0      : [M]ICO(LIGCOU)=ICOREF          : Endif
  If dim([M]QTE)>0      : [M]QTE(LIGCOU)=QTEREF          : Endif
  If dim([M]UNITE)>0    : [M]UNITE(LIGCOU)=UNITEREF      : Endif
Return
