#<AdxTL>@(#)6.0.0.0 $Revision$
##############################################################
# DOSDICMSK Remplissage du dico des mots clés d'aide
##############################################################
$DICAMC
Call ECR_TIME(mess(15,125,1)-mess(259,125,1)) From DOSSUB
# MAJ dictionnaire - Mot Clé
Local File =GDOSREF+".AMOTCLE"    [AMC]

Local File =[F:ADS]DOSSIER+".AMOTCLE"    [DAMC]
&         ,=[F:ADS]DOSSIER+".ACTIV"      [DACV]

Local File =[F:ADS]DOSSIER+".ATABLE"  [DATB]
Local File =[F:ADS]DOSSIER+".ASHW"    [DASW]
Local File =[F:ADS]DOSSIER+".ACLASSE" [DACLA]
Local File =[F:ADS]DOSSIER+".AMSK"    [DAMK]

Local File =[F:ADS]DOSSIER+".ATABZON"    [DATZ]
Local File =[F:ADS]DOSSIER+".ASHWSEC"    [DASWS]
Local File =[F:ADS]DOSSIER+".ASHWBLC"    [DASWB]
Local File =[F:ADS]DOSSIER+".ASHWEXPPRO" [DASWR]
Local File =[F:ADS]DOSSIER+".ACLAFLD"    [DACLAF]
Local File =[F:ADS]DOSSIER+".AMSKZON"    [DAMZ]

Local Integer WMODAMC
Local Char WACTIV(GLONACV)
Local Char WBLC(20),WREP(GLONASW)
Local Char WACTBLC (GLONACV), WACTSEC(GLONACV)

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(259,125,1),"") From GESECRAN
Endif

## Effacement anciens mots-clés d'aide

If !GCRE
 Trbegin [DAMC]
  For [DAMC]AMC0(2) Where IDENT1<GXX & left$(IDENT1,1)<>"W"
    WACTIV=""
    Case [F:DAMC]TYPZON
      When 1 : Read [DATB]CODFIC=[F:DAMC]IDENT1
               WACTIV=[F:DATB]CODACT
      When 2 : Read [DAMK]CODMSK=[F:DAMC]IDENT1
               WACTIV=[F:DAMK]CODACT
      When 3 : Read [DACLA]ACLA0=[F:DAMC]IDENT1
               WACTIV=[F:DACLA]CODACT
      When 4 : Read [DASW]ASW0=[F:DAMC]IDENT1
               WACTIV=[F:DASW]CODACT
    Endcase
    Call SPEC(WACTIV,SPEC) From DOSSUB
    If !SPEC
      For [DAMC]AMC0
        Case [F:DAMC]TYPZON
          When 1 : Read [DATZ]CODZONE=[F:DAMC]IDENT1;[F:DAMC]IDENT2
                   WACTIV=[F:DATZ]CODACT
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 2 : Read [DAMZ]CODE=[F:DAMC]IDENT1;[F:DAMC]IDENT2
                   WACTIV=[F:DAMZ]CODACT
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 3 : Read [DACLAF]ACLAF0=[F:DAMC]IDENT1;[F:DAMC]IDENT2
                   WACTIV=[F:DACLAF]ACTFLD
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 4 : Read [DASWR]ASWR0=[F:DAMC]IDENT1;[F:DAMC]IDENT2
                   WREP=[F:DAMC]IDENT1
                   WBLC=[F:DASWR]BLCPRO
                   Gosub FIND_ACTBLCSEC
                   Call SPEC(WACTBLC,SPEC) From DOSSUB
                   If !SPEC
                     Call SPEC(WACTSEC,SPEC) From DOSSUB
                   Endif
        Endcase
        If !SPEC
          Read [AMC]AMC0 = [F:DAMC]TYPZON;[F:DAMC]IDENT1;[F:DAMC]IDENT2
          If fstat
           Call ECR_TRACE(mess(260,125,1)-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,0) From GESECRAN
           Delete [DAMC] Curr
           If fstat=1 : Call ERREUR("AMOTCLE"-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,3) From DOSDIC : Endif
          Endif
        Endif
      Next
    Endif
  Next
 Commit
Endif

## Mise à jour

Filter [AMC] Where IDENT1<GXX & left$(IDENT1,1)<>"W"
For [AMC]AMC0
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(259,125,1),num$([F:AMC]TYPZON)-[F:AMC]IDENT1-[F:AMC]IDENT2) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DAMC]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAMC]AMC0 = [F:AMC]TYPZON;[F:AMC]IDENT1;[F:AMC]IDENT2
  If !fstat
    OLD = 1
    Case [F:DAMC]TYPZON
      When 1 : Read [DATB]CODFIC=[F:DAMC]IDENT1
               WACTIV=[F:DATB]CODACT
      When 2 : Read [DAMK]CODMSK=[F:DAMC]IDENT1
               WACTIV=[F:DAMK]CODACT
      When 3 : Read [DACLA]ACLA0=[F:DAMC]IDENT1
               WACTIV=[F:DACLA]CODACT
      When 4 : Read [DASW]ASW0=[F:DAMC]IDENT1
               WACTIV=[F:DASW]CODACT
    Endcase
    Call SPEC(WACTIV,SPEC) From DOSSUB
  Endif

  If !SPEC
    #on doit trouver l'élément correspondant à l'aide
    Case [F:AMC]TYPZON
      When 1 : Read [DATZ]CODZONE=[F:AMC]IDENT1;[F:AMC]IDENT2
      When 2 : Read [DAMZ]CODE=[F:AMC]IDENT1;[F:AMC]IDENT2
      When 3 : Read [DACLAF]ACLAF0=[F:AMC]IDENT1;[F:AMC]IDENT2
      When 4 : Read [DASWR]ASWR0=[F:AMC]IDENT1;[F:AMC]IDENT2
    Endcase
    If fstat
      NEWREC=0
    Else
      NEWREC=1
      If OLD
        Case [F:DAMC]TYPZON
          When 1 : WACTIV=[F:DATZ]CODACT
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 2 : WACTIV=[F:DAMZ]CODACT
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 3 : WACTIV=[F:DACLAF]ACTFLD
                   Call SPEC(WACTIV,SPEC) From DOSSUB
          When 4 : WREP=[F:AMC]IDENT1
                   WBLC=[F:DASWR]BLCPRO
                   Gosub FIND_ACTBLCSEC
                   Call SPEC(WACTBLC,SPEC) From DOSSUB
                   If !SPEC
                     Call SPEC(WACTSEC,SPEC) From DOSSUB
                   Endif
        Endcase
      Endif
    Endif
  Endif

  If !SPEC

   If OLD & !NEWREC : # On le vire

     Call ECR_TRACE(mess(260,125,1)-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,0) From GESECRAN
     Delete [DAMC] Curr
     If fstat=1 : Call ERREUR("AMOTCLE"-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,3) From DOSDIC : Endif

   Elsif NEWREC & !OLD : # C'est un nouvel enreg

    Raz [F:DAMC]
    RWO = 1
    [F:DAMC] = [F:AMC]
    Write [DAMC]
    If fstat : Call ERREUR("AMOTCLE"-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,1) From DOSDIC : Endif

   Elsif NEWREC & OLD : # enreg modifié ??

    DIFF = 0

    ## Comparaison

    If [F:AMC]MOTCLE   <> [F:DAMC]MOTCLE    : DIFF = 1 : Endif
    If [F:AMC]INFBUL   <> [F:DAMC]INFBUL    : DIFF = 1 : Endif
    If [F:AMC]UNAFFHTM <> [F:DAMC]UNAFFHTM  : DIFF = 1 : Endif

    # Réécriture

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff mot clé"-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DAMC] = [F:AMC]
     Rewrite [DAMC]
     If fstat : Call ERREUR("AMOTCLE"-num$([F:DAMC]TYPZON)-[F:DAMC]IDENT1-[F:DAMC]IDENT2,2) From DOSDIC : Endif
    Endif
   Endif : # (new & old)
  Endif : # (spec)

 Commit

Next

Close Local File [DATZ] , [DASWS], [DASWB] , [DASWR] , [DACLAF] , [DAMZ]
Close Local File [DATB] , [DASW] , [DACLA] , [DAMK]
Close Local File [DAMC] , [DACV]
Close Local File [AMC]
Return


#--------------------------------------------#
# Find actvity code for a bloc/section (WBLC)
#--------------------------------------------#
$FIND_ACTBLCSEC
Raz WACTBLC, WACTSEC

Read [DASWB]ASWB0=WREP;WBLC
If !fstat
  WACTBLC=[F:DASWB]ACTBLC
  Read [DASWS]ASWS0=WREP;[F:DASWB]SECBLC
  If !fstat
    WACTSEC=[F:DASWS]ACTSEC
  Endif
Endif
Return
