#<AdxTL>@(#)6.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Récupération des textes de SUPERV6 par rapport à SUPERV
#----------------------------------------------------------------------------------------#

Call RECUP
End

#---------------------------------#
Subprog RECUP

Local Char DOSSIER(GLONADD) , ZFLD(GLONAVA)(1..50) , MESSA(250)
Local Integer NFLD , I , J , D , DD , ZDIF(1..999) , NDIF , N , ND

DOSSIER = "aydaix06:16006@SUPERV6"

Call OUVRE_TRACE("Récupération des textes"-DOSSIER) From LECFIC

Local File ATABZON [ATZ] , ATEXTE [ATX]
Local File =DOSSIER+".ATABZON" [DATZ] , =DOSSIER+".ATEXTE" [DATX]

Raz NDIF , ZDIF
For [ATZ]CODZONE(1) Where CODTYP="ATX" & CODFIC<>"AMENUSER"
 Raz NFLD , ZFLD
 For [ATZ]CODZONE
  NFLD += 1
  ZFLD(NFLD) = [F:ATZ]CODZONE
 Next ATZ
 If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",DOSSIER),0)>0
  Local File =[F:ATZ]CODFIC [T] , =DOSSIER+"."+[F:ATZ]CODFIC [DT] 
  For [T]
   [F:DT] = [F:T]
   Read [DT] =
   If !fstat
    For I=1 To NFLD
     D = evalue("dim([F:T]"+ZFLD+")")
     DD = evalue("dim([F:DT]"+ZFLD+")")
     If D & DD
      For J=0 To min(D-1,DD-1)
       N = evalue("[F:T]"+ZFLD+"("+num$(J)+")")
       ND = evalue("[F:DT]"+ZFLD+"("+num$(J)+")")
       Read [ATX]NUMERO="FRA";N
       If !fstat
        Read [DATX]NUMERO="FRA";ND
        If !fstat & [F:ATX]TEXTE<>[F:DATX]TEXTE & func AFNC.CLETBL([F:ATZ]CODFIC,"T")<"W"
         MESSA = [F:ATZ]CODFIC-[F:ATZ]CODZONE-"("+func AFNC.CLETBL([F:ATZ]CODFIC,"T")+") :"  
         If !find(ND,ZDIF(1..NDIF))
          NDIF += 1
          ZDIF(NDIF) = ND
          Call ECR_TRACE(MESSA-'"'+[F:ATX]TEXTE+'-'+num$(N)+'" doit remplacer "'+[F:DATX]TEXTE+'-'+num$(ND)+'"',1) From GESECRAN
         Else
          Call ECR_TRACE(MESSA-num$(N)+"/"+num$(ND)-[F:ATX]TEXTE+"<>"+[F:DATX]TEXTE,-1) From GESECRAN
         Endif
        Endif
       Endif
      Next J
     Endif
    Next I
   Endif
  Next T
  Close Local File [T] , [DT]
 Endif
Next ATZ 
  
Close Local File
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

