Return

#-----
$BUICOD
  Case [L]ARULE
    When "GET"
      # Get building from location
      If  this.LCTCOD <> AVOID.ACHAR
        Local Instance LCT Using C_PHYLCT : LCT = NewInstance C_PHYLCT AllocGroup null
        Local Char PROPERTIES(GLONAVA)(1..1)
        Local Char VALUES(255)        (1..1)
        Local Integer RET
        [L]PROPERTIES(1) = "BUICOD"
        [L]RET = fmet LCT.GET_PROPERTIES_VALUE(this.LCTCOD, [L]PROPERTIES, [L]VALUES)
        this.BUICOD = VALUES(1)
        FreeGroup LCT
#       Local File PHYLCT [LCT]
#       Read [LCT]LCT0=this.LCTCOD
#       If fstat : Raz [F:LCT] : Endif
#       this.BUICOD = [F:LCT]BUICOD
#       LogicClose File [LCT]
      Endif
 Endcase
Return

#-----
$GEOLOC
  Case [L]ARULE
    When "GET"
      # No double quote or comma in the geolocation
      Local Integer I
      For I=1 To len(this.GEOLOC)
        If find(seg$(this.GEOLOC,I,I),'"',',') : this.GEOLOC = func GLOFUNC.SETRNGSTR(this.GEOLOC,I," ") : Endif
      Next
 Endcase
Return

#-----
$REFTAB1
  Case [L]ARULE
    When "GET"
      # Get the table reference of USRFLDA1
      Local Integer NUMTAB : [L]NUMTAB = 0
      Local Integer RNG : RNG=1
      Gosub GET_REFTAB
      this.REFTAB1= [L]NUMTAB
  Endcase
Return

$GET_REFTAB
  Local Integer B_FOUND : [L]B_FOUND = [V]CST_ATRUE
  Local File FREFLD [FRF_]
  Read [FRF_]FRF0= [V]CST_OMPHY;this.CPY
  If (fstat) Then
    Read [FRF_]FRF0= [V]CST_OMPHY;""
    If (fstat)
      [L]B_FOUND = [V]CST_AFALSE
    Endif
  Endif
  If ([L]B_FOUND = [V]CST_ATRUE) : [L]NUMTAB = [F:FRF_]ALPREF([L]RNG-1) : Endif
  LogicClose File [FRF_]
Return

