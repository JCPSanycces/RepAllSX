$PROPERTIES
  Case CURPRO
    When "CPY"               : Gosub CPY
    When "PHYCAT"            : Gosub PHYCAT
    When "CURCND"            : Gosub CURCND
    When "ENAFLG"            : Gosub ENAFLG
    When "ISSTYP"            : Gosub ISSTYP
    When "LCTCOD"            : Gosub LCTCOD
    When "BUICOD"            : Gosub BUICOD
    When "GEOLOC"            : Gosub GEOLOC
    When "REFTAB1"           : Gosub REFTAB1
    When "REFTAB2"           : Gosub REFTAB2
    When "REFTAB3"           : Gosub REFTAB3
    When "REFTAB4"           : Gosub REFTAB4
    When "REFTAB5"           : Gosub REFTAB5
    When "REFTAB6"           : Gosub REFTAB6
    When "REFTAB7"           : Gosub REFTAB7
    When "REFTAB8"           : Gosub REFTAB8
    When "REFTAB9"           : Gosub REFTAB9
    When "REFTAB10"          : Gosub REFTAB10

    When "PHYMVT.MVTISSTYP"  : Gosub PHYMVT_MVTISSTYP

  Endcase
Return

#-----
$CPY
  Case [L]ARULE
     When "PROPAGATE"
       Local Integer REFTAB
       [L]REFTAB = this.REFTAB1
       [L]REFTAB = this.REFTAB2
       [L]REFTAB = this.REFTAB3
       [L]REFTAB = this.REFTAB4
       [L]REFTAB = this.REFTAB5
       [L]REFTAB = this.REFTAB6
       [L]REFTAB = this.REFTAB7
       [L]REFTAB = this.REFTAB8
       [L]REFTAB = this.REFTAB9
       [L]REFTAB = this.REFTAB10
#    When "INIT"
#    When "GET"
#    When "CONTROL"
  Endcase
Return

#-----
$PHYCAT
  Case [L]ARULE
    When "INIT"
      # X : To define
      this.PHYCAT = "X"
#    When "GET"
#    When "CONTROL"
#    When "PROPAGATE"
  Endcase
Return

#-----
$CURCND
  Case [L]ARULE
    When "INIT"
      # Vide
      this.CURCND  = AVOID.ACHAR
  Endcase
Return

#-----
$ENAFLG
  Case [L]ARULE
    When "INIT"
      # Yes
      this.ENAFLG  = [V]CST_AYES
  Endcase
Return

#-----
$ISSTYP
  Case [L]ARULE
    When "INIT"
      # Not issued
      this.ISSTYP  = [V]CST_PDNOTISS
  Endcase
Return


