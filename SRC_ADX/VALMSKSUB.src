#<AdxTL>@(#)0.0.0.0 $Revision$ Validation des écrans
#################################################################################
## VALMSKSUB Calcul format adonix et largeur de la zone
#################################################################################
$CALCUL
If LIG_LGR(B,L)<>0
 MAXLNG = LIG_LGR(B,L)
Else
 MAXLNG = LCHMAX
Endif

## Affectation du type de format  LIG_FTY (+K, -N, ...)

If LIG_ZON(B,L)=BLC_BAS(B) & BLC_TYP(B)=1
 LIG_FNU(B,L) = TABLO
Else
 Gosub FORMA
 If LIG_ACC(B,L)<>"" & LIG_SAI(B,L)<3 : LIG_OPT(B,L) += "c" : Endif
 Case LIG_SAI(B,L)
  When 1
  When 2   : LIG_FOP(B,L) = "P"+LIG_FOP(B,L) : # Affiché
  When 3,4 : # Invisible
   If LIG_TRF(B,L)<>2       : #  Uniquement pour les champs non techniques
    If left$(LIG_FTY(B,L),2)='="'
     LIG_FTY(B,L) = '="-'+right$(LIG_FTY(B,L),3)
    Else
     LIG_FTY(B,L) = "-"+LIG_FTY(B,L)
    Endif
   Endif
 Endcase
 If LIG_TRF(B,L)=2 and instr(1,LIG_FOP(B,L),"P")=0 : LIG_FOP(B,L)="P"+LIG_FOP(B,L) : Endif

# On ne met plus de "+" ou de "/" devant les formats tableaux

 If BLC_TYP(B)=1 & LIG_SAI(B,L)<3
  Case LIG_MOD(B,L)
   When 0,1 : # Fiche + tableau
    MODEFICHE = "" : # "+"
   When 2 : # Fiche
    MODEFICHE = "" : # "/"
   When Default : # Tableau
    MODEFICHE = ""
  Endcase
  If MODEFICHE<>""
   If left$(LIG_FTY(B,L),2)='="'
    LIG_FTY(B,L) = '="'+MODEFICHE+right$(LIG_FTY(B,L),3)
   Else
    LIG_FTY(B,L) = MODEFICHE+LIG_FTY(B,L)
   Endif
   If LIG_FMT(B,L)<>""
    If MODEFICHE<>""
     If left$(LIG_FMT(B,L),2)='="'
      LIG_FMT(B,L) = '="'+MODEFICHE+right$(LIG_FMT(B,L),3)
     Elsif left$(LIG_FMT(B,L),1)='='
      LIG_FMT(B,L) = '="'+MODEFICHE+'"+'+right$(LIG_FMT(B,L),2)
     Else
      LIG_FMT(B,L) = MODEFICHE+LIG_FMT(B,L)
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
Return

###########################################################################
## Affectation du type de format    LIG_FTY (K, LO234, ...)
## Calul du numéro de format        LIG_FNU (302,303,...)
## Calcul de la chaine de format    LIG_FCH (10X, 5#, ...)
## Calcul de la longueur            LIG_FLN
## Calcul de la hauteur             LIG_FLI
## Affectation des options          LIG_FOP
###########################################################################

$FORMA
OPTSAI = LIG_OPT(B,L)
LONG   = LIG_LNG(B,L)
Case LIG_TYI(B,L)

 When 1 : # Libellé

  LIG_FNU(B,L) = "302" : # Entier long pour que ça marche
  LIG_FCH(B,L) = num$(LONG)+"X"
  Gosub OPTLIB

  Case LIG_GRA(B,L)

   When 2 : # Case à cocher

    LIG_FTY(B,L) = "LO"
#   LIG_FLN(B,L) = -int(-COEF1*max(LONG,BLC_LNG(B))) + 2
    LIG_FLN(B,L) = -int(-COEF1*LONG) + 2
    LIG_FLI(B,L) = 1

   When 3,4 : # Radio-bouton vertical

    LIG_FTY(B,L) = "LRA"+num$(LIG_LIB(B,L))
#   LIG_FLN(B,L) = -int(-COEF1*max(LONG,BLC_LNG(B))) + 2
    LIG_FLN(B,L) = -int(-COEF1*LONG) + 2
    LIG_FCH(B,L) = num$(-int(-COEF1*LONG))+"X"
    LIG_FLI(B,L) = func LENMESS(LIG_LIB(B,L)) : # len(mess(0,LIG_LIB(B,L),1))
    If LIG_GRA(B,L)=3 : # Avec cadre
     LIG_FLI(B,L) += 2
     LIG_FLN(B,L) += 3
    Endif

   When 5,6 : # Radio-bouton horizontal

    LIG_FTY(B,L) = "LrA"+num$(LIG_LIB(B,L))
    LIG_FLN(B,L) = (-int(-COEF1*LONG)+2)*func LENMESS(LIG_LIB(B,L)) : # len(mess(0,LIG_LIB(B,L),1))
    LIG_FCH(B,L) = num$(-int(-COEF1*LONG))+"X"
    LIG_FLI(B,L) = 1
    If LIG_GRA(B,L)=5 : # Avec cadre
     LIG_FLI(B,L) += 2
     LIG_FLN(B,L) += 2
    Endif

   When Default : # Combo-box

    LIG_FTY(B,L) = "LA"+num$(LIG_LIB(B,L))
    LIG_FLN(B,L) = -int(-COEF1*LONG)+3
    LIG_FLI(B,L) = 1

  Endcase

 When 7 : # Alpha

  LIG_FTY(B,L) = "K"
  LIG_FNU(B,L) = "378"
  Gosub OPTCAR

  Case LIG_GRA(B,L)

   When 9 : # Photo

    LIG_FTY(B,L) = "KI"+num$(LIG_GP3(B,L))
    LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
    LIG_LNG(B,L) = int(LIG_GP2(B,L)/COEF1)
    LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
    LIG_FLN(B,L) = LIG_GP2(B,L)
    LIG_FLI(B,L) = LIG_GP1(B,L)
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

   When 10 : # Texte multi-ligne

    LIG_FTY(B,L) = "K"
    LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
    LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
    LIG_FLN(B,L) = LIG_GP2(B,L)
    LIG_FLI(B,L) = LIG_GP1(B,L)
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

   When 11 : # Fichier rtf "relatif" (à virer du type alpha)

    Case LIG_GP3(B,L)
     When 2       : LIG_FTY(B,L) = "KR1" : # rtf
     When 3       : LIG_FTY(B,L) = "KR2" : # txt
     When Default : LIG_FTY(B,L) = "KR"  : # Indéterminé
    Endcase
    LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
    LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
    LIG_FLN(B,L) = LIG_GP2(B,L)
    LIG_FLI(B,L) = LIG_GP1(B,L)
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

   When 12 : # Fichier rtf "absolu" (à virer du type alpha)

    Case LIG_GP3(B,L)
     When 2       : LIG_FTY(B,L) = "KH1" : # rtf
     When 3       : LIG_FTY(B,L) = "KH2" : # txt
     When Default : LIG_FTY(B,L) = "KH"  : # Indéterminé
    Endcase

    LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
    LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
    LIG_FLN(B,L) = LIG_GP2(B,L)
    LIG_FLI(B,L) = LIG_GP1(B,L)
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

   When 13 : # Icône

    If LIG_SAI(B,L)=1
     LIG_FTY(B,L) = "KIB"
    Else
     LIG_FTY(B,L) = "KIL"
    Endif
    If LIG_LGR(B,L)<>0 : LONG = LIG_LGR(B,L) : Endif
    LIG_FLN(B,L) = LONG : # LIG_GP2(B,L)
    LIG_FCH(B,L) = num$(LONG)+"X"
    LIG_FLI(B,L) = 1
    LIG_FOP(B,L) = ""

   When Default : # Chaine normale

    If left$(LIG_FCH(B,L),1)="="
     LIG_FTY(B,L) = '="K'
     LIG_FCH(B,L) = '"+'+right$(LIG_FCH(B,L),2)
     If LIG_LGR(B,L)<>0 : LONG = LIG_LGR(B,L) : Endif
    Elsif LIG_FCH(B,L)=""
     If LIG_LNG(B,L)>MAXLNG
      LIG_FCH(B,L)  = num$(MAXLNG)+CARFMT+">"+num$(LIG_LNG(B,L)-MAXLNG)+CARFMT
      LONG          = MAXLNG
      LIG_LGR(B,L)  = MAXLNG
     Else
      LIG_FCH(B,L) = num$(LIG_LNG(B,L))+CARFMT
     Endif
    Else
     Gosub LONGALPHA
    Endif
    LIG_FLI(B,L) = 1
    If !instr(1,LIG_OPT(B,L),"M") & !instr(1,LIG_OPT(B,L),"C") & LONG>10
     If    LONG<=15 : LONG = -int(-COEF3*LONG)
     Elsif LONG<=20 : LONG = -int(-COEF4*LONG)
     Elsif LONG<=50 : LONG = -int(-COEF5*LONG)
     Else           : LONG = -int(-COEF6*LONG)
     Endif
    Endif
    LIG_FLN(B,L) = LONG
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

  Endcase

  # On rajoute une ligne pour les objets textes/photos qui ont un titre (demande ccora)

  If find(LIG_GRA(B,L),9,10,11,12) & (LIG_TIT(B,L)<>0 or LIG_EVL(B,L)<>"")
   LIG_FLI(B,L) += 1
  Endif

 When 9 : # Blob

  LIG_FNU(B,L) = "380"
  Gosub OPTCAR

  LIG_FTY(B,L) = "KI"+num$(LIG_GP3(B,L))
  LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
  LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
  LIG_FLN(B,L) = LIG_GP2(B,L)
  LIG_FLI(B,L) = LIG_GP1(B,L)
  If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

 When 10 : # Clob

  LIG_FNU(B,L) = "381"
  Gosub OPTCAR

  Case LIG_GP3(B,L)
   When 2       : LIG_FTY(B,L) = "KR1" : # rtf
   When 3       : LIG_FTY(B,L) = "KR2" : # txt
   When Default : LIG_FTY(B,L) = "KR"  : # Indéterminé
  Endcase

  LIG_FOP(B,L) = "{-1,-1,-1,"+num$(8*LIG_GP1(B,L))+"}"
  LIG_FCH(B,L) = num$(LIG_LNG(B,L))+"X"
  LIG_FLN(B,L) = LIG_GP2(B,L)
  LIG_FLI(B,L) = LIG_GP1(B,L)
  If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

 When 2,3,4,5,6 : # Numérique

  LIG_FNU(B,L) = "303"
  LIG_FTY(B,L) = "N"
  Gosub OPTNUM
  If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

  Case LIG_GRA(B,L)

   When 8 : # Barre de progression

    LIG_FTY(B,L) = "p"
    If LIG_GP2(B,L)=0 : LIG_GP2(B,L) = 20 : Endif
    LIG_FCH(B,L) = num$(LIG_GP2(B,L))+"X"
    LIG_FOP(B,L) = ""
    LIG_FLN(B,L) = LIG_GP2(B,L)
    LIG_FLI(B,L) = 1

   When Default : # Numérique normal

    LG1 = int(LONG)
    LG2 = 10*(LONG-LG1)
    While LG2<>int(LG2) : LG2 *= 10 : Wend
    LONG = LG1+LG2+(LG2<>0)
    If left$(LIG_FCH(B,L),1)="="
     LIG_FTY(B,L) = '="N'
     LIG_FCH(B,L) = '"+'+right$(LIG_FCH(B,L),2)
    Elsif LIG_FCH(B,L)=""
     LIG_FCH(B,L) = num$(LIG_LNG(B,L))+CARFMT
    Else
     Gosub LONGNUM
    Endif
    If instr(1,LIG_FOP(B,L),"3")
     LONG += int((LG1-1)/3)
    Endif
    LONG = -int(-COEF7*LONG)
    If LONG>15 : LONG -= 1 : Endif
    LIG_FLN(B,L) = LONG
    LIG_FLI(B,L) = 1
    If LIG_TRF(B,L)=2 & instr(1,LIG_FTY(B,L),CARTRS)=0 : LIG_FTY(B,L)+=CARTRS : Endif

  Endcase

 When 8 : # Date

  LIG_FNU(B,L) = "307"
  LIG_FTY(B,L) = "D"
  Gosub OPTDAT
  If left$(LIG_FCH(B,L),1)="="
   LIG_FTY(B,L) = '="D'
   LIG_FCH(B,L) = '"+'+right$(LIG_FCH(B,L),2)
  Elsif LIG_FCH(B,L)=""
   L2 = 1
   For L1=1 To 7
    If instr(1,OPTSAI,num$(L1))
     L2 = L1 : Break
    Endif
   Next L1
   LIG_FTY(B,L) = '="D'
   LIG_FCH(B,L) = '"+'
   Case L2
    When 1 : LONG = func VALMSKLEC.LG(GFMDAT,8)   : LIG_FCH(B,L) += "GFMDAT"
    When 2 : LONG = func VALMSKLEC.LG(GFMDAT4,10) : LIG_FCH(B,L) += "GFMDAT4"
    When 3 : LONG = func VALMSKLEC.LG(GFMDAT3,15) : LIG_FCH(B,L) += "GFMDAT3"
    When 4 : LONG = func VALMSKLEC.LG(GFMDAT9,20) : LIG_FCH(B,L) += "GFMDAT9" : LIG_FOP(B,L) += "<"
    When 5 : LONG = func VALMSKLEC.LG(GFMJOU,5)   : LIG_FCH(B,L) += "GFMJOU"
    When 6 : LONG = func VALMSKLEC.LG(GFMMOI,5)   : LIG_FCH(B,L) += "GFMMOI"
    When 7 : LONG = func VALMSKLEC.LG(GFMMOI4,7)  : LIG_FCH(B,L) += "GFMMOI4"
   Endcase
  Else
   Gosub LONGDAT
  Endif
  If    LONG<=5  : LONG = -int(-COEF8*LONG)
  Elsif LONG<=10 : LONG = -int(-COEF9*LONG)
  Else           : LONG = -int(-COEF10*LONG)
  Endif
  LIG_FLN(B,L) = LONG
  LIG_FLI(B,L) = 1

Endcase

Return

## Calcul longueur d'un format alpha ou date

$LONGALPHA
$LONGDAT
COM = 0 : REP = 0
LONG = 0
For I=1 To len(LIG_FCH(B,L))
 C = mid$(LIG_FCH(B,L),I,1)
 If C="["     : COM = 1
 Elsif COM=1
  If C="]"    : COM = 0 : REP = 0 : Else : LONG += 1 : Endif
 Elsif C=">"  : Break
 Elsif instr(1,"0123456789",C)
  REP = 10*REP+val(C)
 Else
  If REP=0 : REP = 1 : Endif
  LONG += REP
  REP = 0
 Endif
Next I
Return

## Calcul longueur d'un format numérique

$LONGNUM
LG1 = 0 : LG2 = 0 : COM = 0 : REP = 0 : DECIM = 0
LONG = 0 : LNGCOM = 0
For I=1 To len(LIG_FCH(B,L))
 C = mid$(LIG_FCH(B,L),I,1)
 If C="[" : COM = 1
 Elsif COM
  If C="]" : COM = 0 : Else : LNGCOM += 1 : Endif
 Elsif C="."  : LG1 += REP : DECIM = 1 : REP = 0
 Elsif instr(1,"0123456789",C)
  REP = 10*REP+val(C)
 Else
  If DECIM
   LG2 += REP
  Else
   LG1 += REP
  Endif
  REP = 0
 Endif
Next I
LONG = LG1+LG2+DECIM+LNGCOM
Return

#######################################################################
## Décodage des options et du caractère de saisie
#######################################################################
$OPTCAR
LIG_FOP(B,L) = ""
If instr(1,OPTSAI,"C")
 CARFMT = "c"
Elsif instr(1,OPTSAI,"A")
 If instr(1,OPTSAI,"#") : CARFMT = "B" : Else : CARFMT = "A" : Endif
Elsif instr(1,OPTSAI,"#")
 CARFMT = "#"
Else
 CARFMT = "X"
Endif
If    instr(1,OPTSAI,"T") : LIG_FOP(B,L) += "T"            : # Tokenisé
Elsif instr(1,OPTSAI,"D") : LIG_FOP(B,L) += "TD"           : # Token interdites
Endif
If    instr(1,OPTSAI,"1") : LIG_FOP(B,L) += "1"  : Endif   : # Au moins 1 caractère
If    instr(1,OPTSAI,"z") : LIG_FOP(B,L) += "z"  : Endif   : # Commentaires non affichés
If    instr(1,OPTSAI,"=") : LIG_FOP(B,L) += "="            : # Centré
Elsif instr(1,OPTSAI,"<") : LIG_FOP(B,L) += "<"            : # Cadré à gauche
Elsif instr(1,OPTSAI,">") : LIG_FOP(B,L) += ">"            : # Cadré à droite
Endif
If    instr(1,OPTSAI,"U") : LIG_FOP(B,L) += "U" : Endif    : # Format fichier
If    instr(1,OPTSAI,"W") : LIG_FOP(B,L) += "W" : Endif    : # Non creusé
If    instr(1,OPTSAI,"X") : LIG_FOP(B,L) += "X" : Endif    : # Saisie masquée
If    instr(1,OPTSAI,"c") : LIG_FOP(B,L) += "c" : Endif    : # Colorisé
Return

$OPTNUM
LIG_FOP(B,L) = ""
If instr(1,OPTSAI,"F") & LONG=int(LONG)                    : # Flottant si pas de décimales
 CARFMT = "F"
Else
 CARFMT ="#"
Endif
If instr(1,OPTSAI,"+") : LIG_FOP(B,L) += "+" : Endif       : # Nb > 0
If instr(1,OPTSAI,"z") : LIG_FOP(B,L) += "z" : Endif       : # Zéro non affiché
If instr(1,OPTSAI,"0") : LIG_FOP(B,L) += "0" : Endif       : # Paddé avec des 0
If instr(1,OPTSAI,"3") : LIG_FOP(B,L) += "3" : Endif       : # Séparateur de 3 chiffres
If instr(1,OPTSAI,"W") : LIG_FOP(B,L) += "W" : Endif       : # Non creusé
If instr(1,OPTSAI,"-") : LIG_FOP(B,L) += "-" : Endif       : # Signe forcé
If instr(1,OPTSAI,"D") : LIG_FOP(B,L) += "D" : Endif       : # Signe après
If instr(1,OPTSAI,"c") : LIG_FOP(B,L) += "c" : Endif       : # Colorisé
Return

$OPTDAT
LIG_FOP(B,L) = ""
If instr(1,OPTSAI,"z") : LIG_FOP(B,L) += "z" : Endif       : # Commentaires non affichés
If instr(1,OPTSAI,"Z") : LIG_FOP(B,L) += "Z" : Endif       : # Date nulle autorisée
If instr(1,OPTSAI,"W") : LIG_FOP(B,L) += "W" : Endif       : # Non creusé
If instr(1,OPTSAI,"c") : LIG_FOP(B,L) += "c" : Endif       : # Colorisé
If LIG_OBL(B,L)<>2 & !instr(1,LIG_FOP(B,L),"Z")            : # Date non obligatoire => date nulle
 LIG_FOP(B,L) += "Z"
Endif
Return

$OPTLIB
LIG_FOP(B,L) = ""
If instr(1,OPTSAI,"W") : LIG_FOP(B,L) += "W" : Endif       : # Non creusé
If instr(1,OPTSAI,"c") : LIG_FOP(B,L) += "c" : Endif       : # Colorisé
Return


Funprog LENMESS(CHAP)
Value Integer CHAP
Local Integer LENMESS
Read [AST]CLE = CHAP;0;GLANGUE
If !fstat
 LENMESS =  len([AST]LANMES)
Else
 LENMESS = len(mess(0,CHAP,1))
Endif
End LENMESS

####################################################
## Validation Trt / Ecran
####################################################
Subprog VALID(REPERT,PROG,DOSSIER,OK)
Value    Char    REPERT
Value    Char    PROG
Value    Char    DOSSIER
Variable Integer OK

Local Integer STAT , SAVSEEK
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

SAVIFS = adxifs
SAVIRS = adxirs
Case REPERT
 When "TRT"
  ORDSYS(1) = "valtrt"
  #106034
  If dim([V]CST_AFALSE)<=0
    # Pour les constantes
    Call DEFVAR From ASYRCONST
  Endif
  #102739
  If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE & func ADS_TOOL.ISTRUSTEDTRT(PROG)=[V]CST_AFALSE
    If func ORDSYS.VERSRUN(MACHINE+string$(MACHINE="",adxmac(0)))>="17r.218"
      ORDSYS(1) -='-t'
    Endif
  Endif
  #
  If func AFNC.PARTSEP(ver$(0),2," ")>="16r.216" & MACHINE=""
   ORDSYS(1) -= "-l"-GLANGUE
  Endif
  ORDSYS(1) -= APPLI-PROG
  MESSA = mess(20,123,1) : # Erreur en validation du traitement
 When Default
  ORDSYS(1) = "valmsk"-APPLI-REPERT+"/"+PROG
  MESSA = mess(21,123,1) : # Erreur en validation du masque
Endcase
If GTRACE<>""
 FICTRA = filpath("TRA",GTRACE,"tra",nomap)
 Openo FICTRA,-1
 SAVSEEK = adxseek(1)
 Openo
Else
 FICTRA = filpath("tmp",PROG,"tra",APPLI,"",MACHINE)
 Openo FICTRA,0
 Openo
Endif
ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
If STAT
 Call ECR_TRACE(mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+ORDSYS(1),1) From GESECRAN : # Erreur
Endif
If GTRACE=""
 adxifs = ""
 adxirs = chr$(10)
 Openi FICTRA
 Raz MESSAGE
 Rdseq MESSAGE(1)
 Rdseq MESSAGE(2)
 Rdseq MESSAGE(3)
 Rdseq MESSAGE(4)
 Rdseq MESSAGE(5)
 Openi
 If MESSAGE(1)<>""
  OK = 0
  Call ECR_TRACE(MESSA-PROG+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4),1)
& From GESECRAN
 Else
  OK = 1
  Call EFFACE(FICTRA,STAT) From ORDSYS
  If STAT
   Call ECR_TRACE(mess(6,123,1)-num$(STAT)-"EFFACE"+"\|"+FICTRA,1) From GESECRAN : # Erreur
  Endif
 Endif
Else
 Openo FICTRA,-1
 STAT = adxseek(1)
 Openo
 If STAT<>SAVSEEK
  OK = 0
  Call ECR_TRACE(MESSA-PROG,1) From GESECRAN
 Else
  OK = 1
 Endif
Endif
#X3 109590 - STAT = adxmpr 
Onerrgo RIEN
If OK=1  and REPERT="TRT" :#X3 109590: the runtime index has to be updated:
  STAT = pushScript([L]MACHINE,[L]DOSSIER,[L]PROG)
Endif
#X3 109590 - adxmpr = STAT
Onerrgo
adxifs = SAVIFS
adxirs = SAVIRS
End

$RIEN
Resume





















