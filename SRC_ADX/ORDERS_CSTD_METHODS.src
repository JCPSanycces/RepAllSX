#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe ORDERS - METHODS
###################################################################################################
$LOAD_TECPJT
Local Integer NLINE

  # Issue X3-34326 - 2017-04-26 by FGR : Everything is allowed in ORDERS. This is the creator which manage the rules
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------------
  If this.TECPJT = null Then
    NLINE = fmet this.ADDLINE("TECPJT",[V]CST_ALASTPOS)
  Endif
  this.TECPJT.IMODULE      = 9
  this.TECPJT.SFROM        = AVOID.ACHAR         # Used only for SQH/SOH/SIH
  this.TECPJT.IBOOCRM      = [V]CST_AYES
  this.TECPJT.IBOOPJM      = [V]CST_AYES
  this.TECPJT.IBOOPJMBUD   = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC5  = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC6  = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC7  = [V]CST_AYES
  this.TECPJT.IUSEDISPJM   = [V]CST_AYES
  this.TECPJT.IUSEDISBUD   = [V]CST_AYES
  this.TECPJT.IUSEDISTAC   = [V]CST_AYES
  this.TECPJT.SSITE        = this.STOFCY
  this.TECPJT.SSOCIETE     = AVOID.ACHAR
  this.TECPJT.SBPR         = AVOID.ACHAR
  this.TECPJT.SAIN         = AVOID.ACHAR
  this.TECPJT.SPJTFLDH     = AVOID.ACHAR
  this.TECPJT.SCOLLECTION  = AVOID.ACHAR
  this.TECPJT.SPJTFLDD     = AVOID.ACHAR
  this.TECPJT.TCHSNGDOCANS = [V]CST_AYES         # 1 : NO
                                                 # 2 : Yes
                                                 # 3 : Yes if same value
  # -----------------------------------
Return

###################################################################################################
$_WIP_CREATE
#Variable Instance WIP_PARAM Using C_ORDK : #
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  [L]ARET_VALUE = fmet this.WIP_AUTOMAP(WIP_PARAM)
  # --------------------------------------------
  # Issue X3-3564/119081 - 2016-10-12 by FGR : BEGIN move in WIP_AUTOMAP
  #If this.ORIFCY = AVOID.ACHAR Then
  #  this.ORIFCY = this.STOFCY
  #Endif
  # Issue X3-3564/119081 - 2016-10-12 by FGR : END
  # --------------------------------------------
Return

###################################################################################################
$_WIP_UPDATE
#Variable Instance WIP_PARAM Using C_ORDK : #
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  [L]ARET_VALUE = fmet this.WIP_AUTOMAP(WIP_PARAM)
  # --------------------------------------------
Return

###################################################################################################
$_WIP_CONSUM
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  this.CPLQTY += WIP_PARAM.CPLQTY
  # --------------------------------------------
Return

###################################################################################################
$WIP_AUTOMAP
#Variable Instance WIP_PARAM Using C_ORDK : #
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  this.WIPTYP = WIP_PARAM.WIPTYP
  this.WIPSTA = WIP_PARAM.WIPSTA
  this.WIPNUM = WIP_PARAM.WIPNUM
  this.ITMREF = WIP_PARAM.ITMREF
  If dim(WIP_PARAM.ECCVALMAJ) >= 0 Then
    this.ECCVALMAJ  = WIP_PARAM.ECCVALMAJ         # ECC
  Endif
  If dim(WIP_PARAM.ECCVALMIN) >= 0 Then
    this.ECCVALMIN  = WIP_PARAM.ECCVALMIN         # ECC
  Endif
  this.ORIFCY = WIP_PARAM.ORIFCY
  this.STOFCY = WIP_PARAM.STOFCY
  this.PJT = WIP_PARAM.PJT
  this.BPRNUM = WIP_PARAM.BPRNUM
  this.MTOREF = WIP_PARAM.MTOREF
  this.VCRTYP = WIP_PARAM.VCRTYP
  this.VCRNUM = WIP_PARAM.VCRNUM
  this.VCRLIN = WIP_PARAM.VCRLIN
  this.VCRSEQ = WIP_PARAM.VCRSEQ
  this.STRDAT = WIP_PARAM.STRDAT
  this.ENDDAT = WIP_PARAM.ENDDAT
  this.EXTQTY = WIP_PARAM.EXTQTY
  this.CPLQTY = WIP_PARAM.CPLQTY
  this.ALLQTY = WIP_PARAM.ALLQTY
  this.SHTQTY = WIP_PARAM.SHTQTY
  this.FMI = WIP_PARAM.FMI
  this.MRPMES = WIP_PARAM.MRPMES
  this.MRPDAT = WIP_PARAM.MRPDAT
  this.MRPQTY = WIP_PARAM.MRPQTY
  this.VCRTYPORI = WIP_PARAM.VCRTYPORI
  this.VCRNUMORI = WIP_PARAM.VCRNUMORI
  this.VCRLINORI = WIP_PARAM.VCRLINORI
  this.VCRSEQORI = WIP_PARAM.VCRSEQORI
  this.ITMREFORI = WIP_PARAM.ITMREFORI
  this.BOMALT = WIP_PARAM.BOMALT
  this.BOMALTTYP = WIP_PARAM.BOMALTTYP
  this.ORI = WIP_PARAM.ORI
  this.PIO = WIP_PARAM.PIO
  this.ABBFIL = WIP_PARAM.ABBFIL
  this.BOMOPE = WIP_PARAM.BOMOPE
  this.ORDSTA = WIP_PARAM.ORDSTA
  # --------------------------------------------
  # Issue X3-3564/119081 - 2016-10-12 by FGR : BEGIN
  If this.ASTALIN = [V]CST_ANEW Then
    If this.ORIFCY = AVOID.ACHAR Then
      this.ORIFCY = this.STOFCY
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    If this.ORIFCY = AVOID.ACHAR Then
      this.ORIFCY = this.snapshot.ORIFCY
    Endif
  Endif
  # Issue X3-3564/119081 - 2016-10-12 by FGR : END
  # --------------------------------------------
Return

