#################################################################################
# Table structure with old and new fields                                       #
#################################################################################
Subprog AMAJ

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ82 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

# 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)
#   - EXE_UTITRC82 : Update of SFOOTINV table
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call UTI_MOUL([F:ADS]DOSSIER) From UTITRC82
Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif
# 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
# New structure of tables                                                       #
#################################################################################
Subprog MAJ

End

