#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque STOCKPUT
############################################################
# Purge de la traçabilité des stocks
############################################################
$ACTION
Case ACTION
  When "EXEC"         : Gosub EXEC_PURSTK
  When "TERMINE"      : Gosub TERMINE_PURSTK
  When "INIT_DIA"     : Gosub INIT_DIA_PURSTK
  When "OK"           : Gosub OK_PURSTK
  When "END"          : Gosub END_PURSTK
Endcase 
Return

#############################################################
$EXEC_PURSTK
If [M:DIA]STOFCY <> ""
  Gosub TRAITEMENT
Endif
Return
#############################################################
$TERMINE_PURSTK
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_PURSTK
Raz [M:DIA]
[M:DIA]STOFCY = GFCYDEF(0)
If dim([M:DIA]SERFLG) > 0
  [M:DIA]SERFLG = 2
Endif
[M:DIA]SIM    = 2   # hcb 040105 26446

Return
#############################################################
$OK_PURSTK
FIN  = 1
Return
#############################################################
$END_PURSTK
Raz [M:DIA]
FIN = 1
Return
############################################################
$TRAITEMENT
Local Char      WMSG(120)
Local Integer   I, J, K, L
If GSERVEUR
  Onerrgo ERRBATCH
Endif
Local File ITMFACILIT [ITF]
Local File STOTRK     [STR]
Local File STOSER     [STS]

If [M:DIA]SIM=1
     Call TEMPON (mess(396,197,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(396,197,1)) From LECFIC
     Endif 
Else Call TEMPON (mess(885,196,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(885,196,1)-":"-mess(396,197,1)) From LECFIC
     Endif
Endif
#
Filter [ITF] Where STOFCY = [M:DIA]STOFCY 
&            Order By Key ITF1
For [ITF]
  Gosub PURSTK
  Case GOK
    When  1 :
    When -1 :
      WMSG = mess(20,100,1)+" : "+[F:ITF]ITMREF
      Call ECR_TRACE(WMSG,1) From GESECRAN
    When Default : 
      Break
  Endcase
Next
Filter [ITF]
#
WMSG = mess(107,184,1)+" ("+format$("D:",[M:DIA]DATREF)+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [STR]
Close Local File [STS]
Close Local File [ITF]
Call TEMPOFF From GESECRAN
Return
############################################################
$PURSTK
Trbegin [STR]
Call DEBTRANS From GLOCK
$PURSTK1
GOK = 1
Filter [STR] Where STOFCY = [F:ITF]STOFCY &
&                  ITMREF = [F:ITF]ITMREF &
&                  IPTDAT < [M:DIA]DATREF 
&            Order By Key STR0
For [STR]
  Readlock [STR] Curr
  Case fstat
    When 0 :
      If dim([M:DIA]SERFLG) > 0 & [M:DIA]SERFLG = 2 & [F:STR]VCRTYP <> 0 & [F:STR]VCRNUM <> ""
        Gosub PURSER
        If GOK <> 1
          Break
        Endif
      Endif  
      WMSG = mess(396,197,1)-[F:STR]STOFCY-[F:STR]ITMREF+" "
      If [F:STR]LOT <> ""
        WMSG += mess(3,749,1)-[F:STR]LOT+" "
      Endif
      WMSG += num$([F:STR]IPTDAT)+" "
      If [F:STR]VCRTYP <> 0
        WMSG += mess([F:STR]VCRTYP,701,1)-[F:STR]VCRNUM
      Endif 
      Call ECR_TRACE(WMSG,0) From GESECRAN
      If SIM=1
        Delete [STR]
        If fstat
          GOK = 0
          Call FSTA("STR") From GLOCK
          Break   
        Endif
      Endif
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("STR") From GLOCK
      Break   
  Endcase
Next
Filter [STR] 
Case GOK
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If GROLL 
      Return 
    Else 
      Goto PURSTK1
    Endif
  When 1 : 
    Commit
  When Default :
    Rollback
Endcase
Return
############################################################
$PURSER
Filter [STS] Where ITMREF  = [F:STR]ITMREF &
&                  SDHTYP  = [F:STR]VCRTYP &
&                  SDHNUM  = [F:STR]VCRNUM &
&                  SDDLIN  = [F:STR]VCRLIN &
&                  STOFCY  = [F:STR]STOFCY &
&                  ISSDAT <> [0/0/0]
&            Order By Key STS2
For [STS]
  Readlock [STS] Curr
  Case fstat
    When 0 :
        If [M:DIA]SIM=1
           Delete [STS]
              If fstat
                 GOK = 0
                 Call FSTA("STS") From GLOCK
                 Break   
              Endif
        Endif
      WMSG = [F:STR]STOFCY-[F:STR]ITMREF-mess(397,197,1)-[F:STS]SERNUM+" "
      If [F:STS]SDHTYP <> 0
        WMSG += mess([F:STS]SDHTYP,701,1)-[F:STS]SDHNUM+" "
      Endif
      WMSG += num$([F:STS]ISSDAT)
      Call ECR_TRACE(WMSG,0) From GESECRAN
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("STS") From GLOCK
      Break   
  Endcase
Next
Filter [STS] 
Return
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
############################################################
# Actions écran STOCKPUM
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char WPAR(05)
Call PARAM(VALEUR,"MARPURTRK",WPAR) From ADOVAL
If val(WPAR) = 0
  WPAR = "60"
Endif
[M:DIA]DATREF    =addmonth(date$,val(WPAR)*-1)
[M:DIA]DATREFMAX =addmonth(date$,val(WPAR)*-1)
End
############################################################
Subprog C_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]DATREFMAX
  mkstat = 2
  GMESSAGE = mess(309,199,1)-num$([M:DIA]DATREFMAX)
Endif
End




