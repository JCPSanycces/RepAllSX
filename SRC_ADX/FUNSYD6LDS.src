#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. (exemple)
#############################################################################
$COR_SET_HEA_INFO
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      If GREP = "C" Then
        [M:COR0]CNTNUM = [F:LDS6]PSTNUM
        [M:COR0]UPDCNTNUM = 0
      Endif
    When "CPYEML"
      #E-mail professionnel
      If GREP = "C" Then
        [M:COR2]CPYEML = [F:LDS6]CPYEML
      Endif
    When "HOMEML"
      #E-mail personnel
      If GREP = "C" Then
        [M:COR3]HOMEML = [F:AIN6]CNTEMA      
      Endif
    When "CPYZIP"
      #Code postal professionnel
      If GREP = "C" Then
        [M:COR2]CPYZIP = [F:LDS6]CPYZIP    
      Endif
    When "HOMZIP"
      #Code postal personnel
      If GREP = "C" Then
        [M:COR3]HOMZIP = [F:AIN6]ZIP      
      Endif
    When "CPYSAT"
      #Etat professionnel
      If GREP = "C" Then
        [M:COR2]CPYSAT = [F:LDS6]CPYSAT
      Endif
    When "HOMSAT"
      #Etat personnel
      If GREP = "C" Then
        [M:COR3]HOMSAT = [F:AIN6]SAT
      Endif
    When "LNA"
      #Nom
      If GREP = "C" Then        
        [M:COR0]LNA = [F:AIN6]CNTLNA      
      Endif
      #On affectele représentant de forcage
      [M:COR0]FORCAGEREP = GSZREPSYNC            
    When "CPYCRY"
      #Pays (prodessionel)
      If GREP = "C" Then
        [M:COR2]CPYCRY = [F:LDS6]CPYCRY
      Endif
    When "CPYCRYNAM"
      #Libellé Pays (prodessionel)
      If GREP = "C" Then
        [M:COR2]CPYCRYNAM = [F:LDS6]CPYCRYNAM
      Endif
    When "HOMCRY"
      #Pays (personnel)
      If GREP = "C" Then
        [M:COR3]HOMCRY = [F:AIN6]CRY
      Endif
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      If GREP = "C" Then
        [M:COR3]HOMCRYNAM = [F:AIN6]CRYNAM
      Endif
    When "FNA"
      #Prénom
      If GREP = "C" Then
        [M:COR0]FNA = [F:AIN6]CNTFNA     
      Endif
    When "CPYADD"
      #Adresse rue (professionnel)
      If GREP = "C" Then
        Case indice
          When 0
            [M:COR2]CPYADD(0) = [F:LDS6]CPYADD(0)
          When 1    
            [M:COR2]CPYADD(1) = [F:LDS6]CPYADD(1)
          When 2
            [M:COR2]CPYADD(2) = [F:LDS6]CPYADD(2)
        Endcase
      Endif
    When "HOMADD"
      #Adresse rue (personnel)
      If GREP = "C" Then
        Case indice
          When 0
            [M:COR3]HOMADD(0) = [F:AIN6]ADD(0)
          When 1    
            [M:COR3]HOMADD(1) = [F:AIN6]ADD(1)
          When 2
            [M:COR3]HOMADD(2) = [F:AIN6]ADD(2)
        Endcase
      Endif
    When "BPRNUM"
      #Code tiers
      If GREP = "C" Then
        [M:COR2]BPRNUM = ""
        [M:COR2]UPDBPRNUM = 0
      Endif
    When "BPRLIB"
      #Libellé tiers
      If GREP = "C" Then
        [M:COR2]BPRLIB = [F:LDS6]CPYNAM
      Endif
    When "CPYFAX"
      #Fax (professionnel)
      If GREP = "C" Then
        [M:COR2]CPYFAX = [F:LDS6]CPYFAX
      Endif
    When "HOMFAX"
      #Fax (personnel)
      If GREP = "C" Then
        [M:COR3]HOMFAX = [F:AIN6]CNTFAX
      Endif
    When "CPYTEL"
      #Téléphone (professionnel)
      If GREP = "C" Then
        [M:COR2]CPYTEL = [F:LDS6]CPYTEL
      Endif
    When "HOMTEL"
      #Téléphone (personnel)
      If GREP = "C" Then
        [M:COR3]HOMTEL = [F:AIN6]CNTETS      
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      If GREP = "C" Then
        [M:COR3]HOMMOB = [F:AIN6]CNTMOB
      Endif
    When "FNC"    
      #code fonction
      If GREP = "C" Then
        [M:COR2]FNC = [F:LDS6]FNC
      Endif
    When "FNCLIB"
      #Libellé fonction
      If GREP = "C" Then
        [M:COR2]FNCLIB = [F:LDS6]FNCLIB
      Endif
    When "TTL"
      #Civilité
      If GREP = "C" Then
        [M:COR0]TTL = [F:AIN6]CNTTTL
      Endif
    When "CPYCTY"
      #Ville (professionnel)
      If GREP = "C" Then
        [M:COR2]CPYCTY = [F:LDS6]CPYCTY
      Endif
    When "HOMCTY"
      #Ville (personnel)
      If GREP = "C" Then
        [M:COR3]HOMCTY = [F:AIN6]CTY
      Endif
#   When "CPYBPANUM"
#     #code adresse
#     If GREP = "C" Then
#       [M:COR2]CPYBPANUM = [F:LDS6]CPYBPANUM
#       [M:COR2]CPYBPATYP = [F:LDS6]CPYBPATYP
#     Endif
    When "CPYBPADES"
      #Inttitulé adresse
      If GREP = "C" Then
        [M:COR2]CPYBPADES = [F:LDS6]CPYBPADES
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        [M:COR4]COPREP(0) = GSZREPSYNC
      Endif
  Endcase
Return
