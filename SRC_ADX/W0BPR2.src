#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BPR2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
If varmode([M]ACCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCAC"
 Call CONTCAC([M]ACCCOD,"17") From SUBCAC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CAC","!",[M]ACCCOD,"17",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GRUGPY
mkstat = 0
zoncou = "GRUGPY"
indice = 0
WCHAR = [M]GRUGPY
If varmode([M]GRUGPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRUGPY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!C",[M]GRUGPY,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GRUGPY" : GZNUM = 23953 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]GRUGPY or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_GRUGPY([M]GRUGPY) From SUBBPR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GRUGPY" : GZNUM = 23953 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone GRUCOD
mkstat = 0
zoncou = "GRUCOD"
indice = 0
If varmode([M]GRUCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRUCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ACS
mkstat = 0
zoncou = "ACS"
indice = 0
If varmode([M]ACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]ACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACS" : GZNUM = 53774 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FISCOD
mkstat = 0
zoncou = "FISCOD"
indice = 0
If varmode([M]FISCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FISCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone VATNUM
mkstat = 0
zoncou = "VATNUM"
indice = 0
If varmode([M]VATNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VATNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BPRGTETYP
mkstat = 0
zoncou = "BPRGTETYP"
indice = 0
If varmode([M]BPRGTETYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPRGTETYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]BPRGTETYP,"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "BPRGTETYP" : GZNUM = 25290 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]BPRGTETYP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]BPRGTETYP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BPRGTETYP" : GZNUM = 25290 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CFOEXD
mkstat = 0
zoncou = "CFOEXD"
indice = 0
IMPENT = [M]CFOEXD
If varinit([M]CFOEXD,indice)=0
 IMPENT = 1
Endif
If varmode([M]CFOEXD,indice)=0
 [M]CFOEXD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CFOEXD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CFOEXD(indice)
 Endif
Endif
[M]CFOEXD = IMPENT

## Zone MODPAM
mkstat = 0
zoncou = "MODPAM"
indice = 0
If varinit([M]MODPAM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]MODPAM,"311","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]MODPAM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "MODPAM" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]MODPAM,"311","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MODPAM" : GZNUM = 40935 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]MODPAM,"311",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "MODPAM" : GZNUM = 40935 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CPYREL
mkstat = 0
zoncou = "CPYREL"
indice = 0
IMPENT = [M]CPYREL
If varinit([M]CPYREL,indice)=0
 IMPENT = 1
Endif
If varmode([M]CPYREL,indice)=0
 [M]CPYREL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPYREL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CPYREL(indice)
 Endif
Endif
[M]CPYREL = IMPENT

## Zone CSLBPR
mkstat = 0
zoncou = "CSLBPR"
indice = 0
If varmode([M]CSLBPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CSLBPR" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPR","!$M",[M]CSLBPR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CSLBPR" : GZNUM = 12138 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "BPR2"
Return

