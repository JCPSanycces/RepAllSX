####################################################################
# IMPRSE : traitement correspondant au modèle d'import / export RSE
#          (ressources de 'laction commerciale)
# - 25/09/2008 : SYMEU
####################################################################
$ACTION
  Case ACTION
    When "IMPORT"
      Gosub IMPORT
  Endcase
Return

##########################################################################
#                                  IMPORT                                #
##########################################################################
#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
  Case IMPFIC
    When "HD6"      
      #Affectation clob compte rendu
      [M:RSS1]FULDES = [F:HD6]CLOB
  Endcase
Return




