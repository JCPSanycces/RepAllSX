 If GOK
     If !GSERVEUR
     Call  ECR_TRACE(mess(673,GML_MSGFAS,1),0)  From GESECRAN
     Endif
     #> Suppression des globales
     Call  KILL_GLO_SILTRT() From  TRCPROCOM
     Return
 Else
  GOK=0
  If dim(GT_OBJ_REF)>0
   Call  ECR_TRACE(mess(671,GML_MSGFAS,1),1) From GESECRAN
   Call  ECR_TRACE(GT_OBJ_REF(0),0) From GESECRAN
   For  I=1 To dim(GT_LIS_ERR)
     LIGNE = GT_LIS_ERR(I-1)
     Call  ECR_TRACE(num$(I)-LIGNE,0) From GESECRAN
   Next  I
  Else
   Call  ECR_TRACE(GT_LIS_ERR(0),0)  From GESECRAN
  Endif
 Endif
 #FQ-54268
 #> Suppression des globales
 Call  KILL_GLO_SILTRT() From  TRCPROCOM

 # Issue 109371  LEC_TRACE()  From LECFIC
 If !GSERVEUR : Call  LEC_TRACE()  From LECFIC : Endif

Return
