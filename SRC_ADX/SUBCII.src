######################################################################################
## Apres modif sur la référence CIGCOD                                              ##
######################################################################################
Subprog AM_CIGCOD(VALEUR)
Variable Char    VALEUR()

##------------------------------------------------------------------------------------------------##
## - Recherche de la référence de cession intra-groupe                                            ##
##------------------------------------------------------------------------------------------------##
[M:CII]CIGCOD = VALEUR

Read [F:CIG]= [M:CII]CIGCOD
If [S]fstat = 0
    If [F:CIG]CIGSTA =   GVML_CIGSTAP
        GMESSAGE = mess(58,GML_MSGCIG,1)
        GOK=0
        OK=0
        mkstat=2
        End
    Elsif [F:CIG]CIGSTA =  GVML_CIGSTAE
        GERR=1
        GMESSAGE = mess(2,GML_MSGCIG,1)
        GOK=0
        OK=0
        mkstat=2
        End
    Else
        GCIG_CIGCOD =   [M:CII]CIGCOD
    Endif

    [M:CII]DES    = [F:CIG]DES
    [M:CII]CIGTYP = [F:CIG]CIGTYP
    [M:CII]CIGSTA = [F:CIG]CIGSTA
    [M:CII]EFFDAT = [F:CIG]EFFDAT

Else
    GERR=1
    GMESSAGE = mess(1,GML_MSGCIG,1)
    GOK=0
    OK=0
    mkstat=2
    End
Endif

Affzo [CII]

End

####################################################################################################
## $SEL_LISTE: Affichage d'une boite de selection contenant                                       ##
##              la liste des tables recodifiables                                                 ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
## Le champ CIGCOD posséde une sélection appelant l'action SELCIG1                                ##
## L'action SELCIG1 (modele standard SEL_LISTE) appelle le traitement standard SUBREC             ##
## Le traitement standard SUBREC afin une dialogue afin de savoir si on présente les CIG          ##
## avec statut 'en préparation'  ou 'sorties traitées'                                            ##
##------------------------------------------------------------------------------------------------##
$SEL_LISTE
  Case LISTE
    When "SELCIG2"    : Gosub SELCIG2
  Endcase
Return


$SELCIG2
Local Integer I
##------------------------------------------------------------------------------------------------##
## Selection des CIG                                                                              ##
##------------------------------------------------------------------------------------------------##
Filter [F:CIG] Where CIGSTA=GVML_CIGSTAS
TIT = mess(7,GML_MSGCIG,1)
I = 0
For [F:CIG]
  I    += 1
  TEX(I)   = [F:CIG]CIGCOD
  TEXTE(I) = mess(55,GML_MSGCIG,1)+format$("Kb:10X", [F:CIG]CIGCOD)+ '      '+ format$("Kb:20X", [F:CIG]DES)+ '      '+ mess(59,GML_MSGCIG,1) +   mess([F:CIG]CIGSTA,GML_CIGSTA,1)

Next
Filter [F:CIG]

NBTEX = I

Return
#########################################################################################
#   Le calcul de la durée résiduelle est ici de façon  provisoire :
#  il a été copié depuis GLOBB8 et GLOBB9 (MWA)
#########################################################################################
Subprog  CAL_DUREE_RESID_ANNEE (PDTDBAMT, PDTDB, PDTFNAMT, PTYPPRODAT, RDUR_RES_ANN)
#
# - Objet  : Calcule la durée d'amortissement résiduelle qui correspond à un nombre d'années
#            calculé à partir de la durée restant à amortir qui correspond
#            au nombre de jours, de semaines de mois ou d'année selon le type prorata
#            restant à courir jusqu'à la fin de l'amortissement
#
# - Entrée :
#
# - Sortie : Durée d'amortissement résiduelle
#   Boite noire calc_dur_rest_amt (gcfc10)
#
Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Value     Char     PTYPPRODAT
Variable  Decimal  RDUR_RES_ANN : RDUR_RES_ANN = 0

Local     Char     LTYP
Local     Decimal  LDUR_RESTAMT              : # Durée restant à amortir

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, PTYPPRODAT, LDUR_RESTAMT)
  RDUR_RES_ANN = LDUR_RESTAMT

End
#########################################################
Subprog  CAL_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, PTYPPRODAT, RDUR_RESTAMT)
#
# - Objet  : Calcule la durée restant à amortir qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#            restant à courir jusqu'à la fin de l'amortissement
#
# - Entrée :
#
# - Sortie : Durée restant à amortir
#   Boite noire calc_dur_rest_amt (gcfc10)
#

Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Value     Char     PTYPPRODAT
Variable  Decimal  RDUR_RESTAMT : RDUR_RESTAMT = 0

Local     Date     LDAT

  LDAT = max(PDTDBAMT,PDTDB)
  # Si date de début > fin d'amortissement
  # la durée restant à amortir est nulle
  # ---------------------------
  If ( LDAT <= PDTFNAMT )
    # Durée restant à amortir selon type de prorata
    RDUR_RESTAMT = func SUBCII.CAL_DAT_DIFF(LDAT, PDTFNAMT, PTYPPRODAT)
  Endif
  # ---------------------------

End
#########################################################
Funprog CAL_DAT_DIFF( PDTDB, PDTFN, PTYP )
#
# - Objet  : Rend le nombre de jours, de semaines, de mois ou d'année entre deux dates
#            selon le type passé en paramètre.
# - Entrée : Date début
#            Date fin
#            Type "Y" Année, "M" Mois, "W" Semaine, "D" Jours
# - Sortie : Nombre de jours, de semaines de mois ou d'année entre les deux dates
#   Boite noire DTDIFF (as400)
#
Value Date      PDTDB, PDTFN
Value Char      PTYP
Local Integer   RTRN
Local Date      LDAT

  RTRN = 0
  If (func SUBCII.CAL_DAT_ISNOTNULL(PDTDB) and func SUBCII.CAL_DAT_ISNOTNULL(PDTFN))
    Case PTYP
      When "Y"     : RTRN = (year(PDTFN)-year(PDTDB))+1
      When "M"     : RTRN = ((year(PDTFN)-year(PDTDB))*12)+ (month(PDTFN)-month(PDTDB))+1
      When "W"     : RTRN = arr(((PDTFN-PDTDB)+1)/7,1)
      When "D"     : RTRN = (PDTFN-PDTDB)+1
      When "Q"     : RTRN = ((year(PDTFN)-year(PDTDB))*24)+ ((month(PDTFN)-month(PDTDB))*2)+2
                     If (day(PDTDB) > 15 )   : RTRN -= 1 : Endif
                     If (day(PDTFN) < 16 )   : RTRN -= 1 : Endif
      When Default : RTRN = 0
    Endcase
  Endif
End RTRN
#########################################################
Funprog CAL_DAT_ISNOTNULL( PDAT )
# - Objet  : Renvoie 1 si la date n'est pas nulle.
#
# - Entrée : Date à tester
#
# - Sortie : 0 date nulle 1 date non nulle
#
#
Const Date     PDAT
Local Shortint RTRN
  RTRN = 0
  If ( PDAT <> [0/0/0] )   : RTRN = 1  : Endif
End RTRN
########################################
Subprog INIT_CNX_ACALCULER (PSOCIETE, PTBCNX, PTYPCLC)
# Initialise les contextes à calculer
Value Char       PSOCIETE
Variable Integer PTBCNX(0..G300MAX-1)
Value Integer    PTYPCLC

Local Integer N_I, NPLANGERE, NCNXAE

  Call VIDE_LISTE_CNX_ACALCULER (PTBCNX, GVML_TCNOCLC)
  If PTYPCLC <> GVML_TCNOCLC
    If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
    #------------------------------
    For [CNX]CNX0 Where CPY=PSOCIETE
      Call NB_PLAN_GERE (NPLANGERE)
      If NPLANGERE > 0
        If GNIVTRACE > 2
          # 14 Contexte à calculer :
          # 15 Type de calcul :
          # Call ECR_TRACE(mess(14,GML_MSGCAL,1)-num$([F:CNX]CNX)-mess(15,GML_MSGCAL,1)-num$(PTYPCLC),0) From =GGLOCALC3
        Endif
        #--------------------
         PTBCNX(NCNXAE, GTBCNXTCLC) = PTYPCLC
        Endif
      #--------------------
      # Suite de la boucle
    Next CNX0
  Endif
End
########################################
Subprog NB_PLAN_GERE (RTROUVE)
# Rend le nombre de plan du contexte qui sont géré
# Utilise  la table [F:CNX] qui doit être lue avant
Variable Integer RTROUVE

Local Integer N_I

  RTROUVE = 0
  If [F:CNX]NBPLC > 0
    #For N_I = 0 To [F:CNX]NBPLC-1
    #  If [F:CNX]PLNPRO(N_I) = G_OUI
      RTROUVE += 1
   Endif
    #------------------------------------
    # Suite de la boucle
  #Next N_I
End
########################################
Subprog VIDE_LISTE_CNX_ACALCULER (PTBCNX, PCODECNX)
Variable Integer PTBCNX(1..,0..)
Value Integer PCODECNX

Local Integer N_I

  Raz PTBCNX
  For N_I = 1 To GMAXCNXC
    PTBCNX(N_I, GTBCNXTCLC) = PCODECNX          : # Type de calcul
    PTBCNX(N_I, GTBCNXEXE)  = GVML_TECOURA      : # Exercice calculé (courant/suivant)
    PTBCNX(N_I, GTBCNXCLS)  = G_NON             : # Calcul optimisé
    PTBCNX(N_I, GTBCNXEVE)  = G_NON             : # Création des événements exercice non périodique
    PTBCNX(N_I, GTBCNXCSO)  = G_NON             : # Calcul société
    #------------------------------
    # Suite de la boucle
  Next N_I
End
