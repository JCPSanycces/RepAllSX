Filter[F:CIB] Where (CPYSRC  =  [F:CIR]CPYSRC and CIGCOD =  [M:CII]CIGCOD) and
&                   (ISSSAT  = GVML_ETATSSM   or ISSSAT  = GVML_ETATSAS ) and
&                   (FLGAASCCL <> G_OUI)
For [F:CIB]
