#=========================================================================
#<*Fq-53346 PREPARATION DES PARAMETRES NECESSAIRES AU TRAITEMENT EN MODE SILENCIEUX
#=============================================================================
#----- Sortie des biens
$ALIM_MASK

 If dim(G_SORREG)      <=0   : Global Date G_SORREG                   : Endif
 If dim(G_SORREGT)     <=0   : Global Date G_SORREGT                  : Endif
 If dim(G_SORREGI)     <=0   : Global Date G_SORREGI                  : Endif
 If dim(G_TBSORREG)    <=0   : Global Date G_TBSORREG(0..G301MAX-1)   : Endif
 If dim(G_TBSORREGT)   <=0   : Global Date G_TBSORREGT(0..G301MAX-1)  : Endif
 If dim(G_TBSORREGI)   <=0   : Global Date G_TBSORREGI(0..G301MAX-1)  : Endif


 # Flag de simulation
 FLGSIM          =  G_NON
 [M:MHC]FLGSIM   =  G_NON

 # Alimentation de l'en-tête
 [M:MHC]FLGCPY(find([F:CIB]CPYSRC,[M:MHC]CPY)-1)  = G_OUI
 [M:MHC]FLGFCY(find([F:CIB]FCYSRC,[M:MHC]FCY)-1)  = G_OUI

 # Alimentation de l'onglet sélection pour fournir la référence du bien à traiter
 [M:ASL]TBL1          = "FXDASSETS"
 [M:ASL]FLD1          = "AASREF"
 [M:ASL]OPE1          = 2

 [M:ASL]VAL1          = [F:CIB]AASREF
 [M:ASL]VALI1         = [F:CIB]AASREF
 [M:FASS]ISSDAT       = [F:CIB]ISSDAT
 [M:FASS]ISSTYP       = [F:FASS]ISSTYP
 #FQ-67465 [M:FASS]ISSDATRUL    = [F:FASS]ISSDATRUL
 [M:FASS]ISSDATRUL    = GVML_IRJPREC          #Fq-67465 Pas de dotation le jour de sortie
 # #Fq-67638   [M:FASS]ISSAMTTYP    = GVML_TVAUCUN
 [M:FASS]ISSAMTTYP    = GVML_TVSAISI #Pour que le TRTFASISS prenne en compte la valeur de ISSAMT
 #Fq-86935 [M:FASS]ISSAMT       = [F:CIB]ISSAMT
 If [F:CIB]ISSAMTUPD <> 0
     [M:FASS]ISSAMT  = [F:CIB]ISSAMTUPD
 Else
    [M:FASS]ISSAMT = [F:CIB]ISSAMT
 Endif
 [M:FASS]PYBVATTYP    = [F:FASS]PYBVATTYP
 [M:FASS]CCLISSFLG    = G_NON
 #FQ82039
 If [M:FASS]BRDPLN = 0
    [M:FASS]BRDPLN = 1
 Endif
 [M:FASS]TTPRINC   = G_NON
 [M:FASS]ISSCMPFLG = G_OUI  #FQ110238

Return

####################################################################
# 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
####################################################################
# Recherche du code de l'élément physique
####################################################################
$RECH_PHYREF
  Local Integer TROUVE        # indique si l'élément est trouvé dans le champ PHYREFOLD d'un élément
  Local Char ELT_TROUVE       # indique dans quel élément l'élément en cours a été trouvé dans PHYREFOLD
  Local Char CODE_ELT         # prochain code de l'élément physique
  Local Integer LINDICE       # indice dans G_ELEMENTS du trou trouvé
  Local Integer NB_ELT        # nb d'éléments ayant un code élément
  Local Integer NB_ELT_PHY    # nb d'éléments ayant le code élément calculé

  # Appel du compteur de document
# FQ109840
#  Call PARAM([F:PHYC]CPY,"PHYNUMBCO",LVALEUR) From ADOVAL
#  GPHYNUMBCO = val(LVALEUR)

# FQ109841
#  Call PARAM([F:PHYC]CPY,"PHYFMTCOU",GPHYFMTCOU) From ADOVAL
#  If GPHYNUMBCO = G_OUI and vireblc([F:FASC]AASREF,4) <> ""
#    # Le paramètre PHYFMTCOU n'est pas renseigné : on ne va pas plus loin
#    If vireblc(GPHYFMTCOU,4) = ""
#      Call ECR_TRACE_FIC("",GTRC_PARAM,[F:PHYC]CPY-[F:FASC]AASREF-':'-mess(101,GML_MSGPHY,1),0,1) From TRACEABX3
#      GOK = 0
#      Return
#    Endif
#  Endif

$RECH_PHYREF_2

# FQ109840
#  If GPHYNUMBCO = G_OUI and vireblc([F:FASC]AASREF,4) <> ""
#    # On ne peut pas appeler la méthode GET_NUMEROPHY de GLOBIENS, car elle recherche le numéro d'élément
#    # dans PHYELT. Or, si on crée plusieurs éléments, il faut aussi tenir compte des numéros créés par
#    # la cession intra-groupe
#    Call CHERCHE_ELT([F:FASC]AASREF,STAT,WCNUMERO) From TRTPHYTOOL
#  Else
#    # FQ85464
#    Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[F:PHYC]CPY,WSITECIBLE,date$,WCNUMERO,STAT)  From GLOBIENS
#  Endif
  Call GET_NUMERO("PHY",GVMLNUMPHY-1,1,[F:PHYC]CPY,WSITECIBLE,date$,WCNUMERO,STAT)  From GLOBIENS
  If ( STAT )   : GOK = 0 : Return : Endif
  # Issue 117229   If WCNUMERO <> ""  control that there is no blank(s) in the middle of the counter
  If WCNUMERO <> "" and !(pat(WCNUMERO, "* *"))
    [F:PHYC]PHYREF = WCNUMERO
  Else
    #**Si problème de numérotation auto : affectation d'une référence par défaut au nouvel élément
    #** société cible + ancienne référence de l'élément
    WPHYREFN = sum(num$([F:PHYC]CPY), num$([F:PHYS]PHYREF))
    [F:PHYC]PHYREF = WPHYREFN
  Endif
  If WCNUMERO = ""
    # cas où on a mis un code élément à partir de la société et de l'ancien code : si l'élément
    # existe déjà, on va boucler, donc on sort
    Return
  Endif

  # Quand on a le code de l'élément, on regarde s'il n'existe pas déjà dans le champ PHYREFOLD d'un élément
# FQ109840
#  If GPHYNUMBCO = G_OUI and [F:PHYC]PHYREF <> ""
#    Call EXIST_ELT_AVEC_PHYREFOLD([F:PHYC]PHYREF,TROUVE,ELT_TROUVE) From TRTPHYTOOL
#    If TROUVE = G_OUI
#      Goto RECH_PHYREF_2
#    Endif
#    # Vérification que l'élément n'existe pas déjà, sinon on va chercher le prochain numéro
#    Call RECH_ELT([F:PHYC]PHYREF,NB_ELT_PHY) From TRTPHYTOOL
#    If NB_ELT_PHY > 0
#      Goto RECH_PHYREF_2
#    Endif
#  Endif

Return
##--------------------------------------------------------------------------------------------##
## Appel des recodifications massives pour toutes les recodifications dont la reférence       ##
## de cession intra-groupe = la référence CIG traitée et pour chaque société cible dont       ##
## les biens ont été créés par la cession intra-groupe                                        ##
##--------------------------------------------------------------------------------------------##
$TRT_RECOD

Filter[F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC)
For [F:CDF]
    WCSOCCIBLE  = ""
    Filter[F:CIR] Where [F:CIR]CIGCOD =  [M:CII]CIGCOD Order By CPYDES Asc
    For [F:CIR] With Stability
       If WCSOCCIBLE  <> [F:CIR]CPYDES
            Call TRT_RECODIF([F:CDF]REFCDF,[F:CIR]CPYDES, [M:CII]FLGSIM, WIRETOUROK) From TRTRECOD
            If WIRETOUROK <> G_OUI
                WITRTOK      = G_NON
                WIERREUTROUV = G_OUI
            Endif
            Gosub EDIT_CR_BIENS_CREES
            WCSOCCIBLE  = [F:CIR]CPYDES
       Endif
    Next
    Filter[F:CIR]
Next
Filter[F:CDF]

Return
####################################################################
# Contrôle des sections analytiques du bien à créer
#####################################################################
$CTRL_CCE_COMPL
Local Integer WCDFCCE
Local Integer I_AXE

#For I_AXE=1 To GOPTCANA #Fq-83418
For I_AXE = 1 To [M:FPC]NBDIE
   WCDFCCE= 0
   If [F:FASS]DIE(I_AXE-1) <> "" and [F:FASS]CCE(I_AXE-1)<> ""
      Read [CCE]CCE0=[F:FASS]DIE(I_AXE-1) ;[F:FASS]CCE(I_AXE-1)
      If ( [F:CCE]FCY <> "" ) and  ([F:CCE]FCY = [F:FASS]FCY or [F:CCE]FCY = [F:FASS]CPY )
         Filter[F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC)
         For [F:CDF]
            If  ( left$([F:CDF]TABNAM,3) = "CCE"  and right$([F:CDF]TABNAM,4) = num$(I_AXE) )
                WCDFCCE+=1
                Break
             Endif
          Next
          Filter[F:CDF]

          If WCDFCCE = 0
             #--> Section réservée à la société /site : 'Vous devez la recodifier.
             GMESSAGE1= "Axe"-num$(I_AXE)-" "-mess(345,GML_MSGFAS,1)-" "-[F:FASS]CCE(I_AXE-1)-mess(231,GML_MSGCIG,1)-[F:FASS]CPY  # "SECTION reservée au site"
             GMESSAGE2= " : "- mess(232,GML_MSGCIG,1)
             WCLIGNE= format$("Kb:2X", "") + format$("Kb:5X", [F:FASS]CPY) + format$("Kb:2X", "") + format$("Kb:20X", [F:FASS]AASREF)
&         +  GMESSAGE1 + GMESSAGE2
             GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
             #*FQ101833 WTRTOK   = G_NON
             WITRTOK  = G_NON
           Endif
        Endif
   Endif
Next

Return
##---------------------------------------------------------------------------------------------------------##
### - Fq-83418 Arrêt trt si toutes les sections obligatoires n'ont pas de paramétrage de recodification
##----------------------------------------------------------------------------------------------------------##
$TEST_RECOD_CCE

Local Integer I_AXE
Local Integer WRECCCE, WNORECCCE, WNORECCCEOB
WRECCCE = 0
WNORECCCE   = G_NON
WNORECCCEOB = G_NON

#  If !clalev([M:FCP])# Issue 115510
     #> Chargement du masque de travail contenant le paramétrage comptable de la société cible
     Local Integer ERR
     Call LOAD_FASPARCPY([F:CIR]CPYDES,"",G_NON,ERR) From GLOFCYCPY
#  Endif# Issue 115510

  WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

  For I_AXE = 1 To [M:FPC]NBDIE
     WRECCCE = 0
     # On regarde s'il existe une recodification pour les axes analytiques de la société cible
     Filter [F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC and
&          left$([F:CDF]TABNAM,3) = "CCE"  and right$([F:CDF]TABNAM,4) = num$(I_AXE)  and
&            [F:CDF]CCEDIE= [M:FPC]DIE(I_AXE-1))
        For [CDF]
           WRECCCE+=1
            Break
         Next
     Filter[CDF] # [F:CDF]

     If WRECCCE=0
         # Si pas de recodification : L'axe est-il obligatoire pour le référentiel analytique de la société cible ?
         If [M:FPC]OBYDIE(I_AXE-1)=G_OUI
             WNORECCCEOB   = G_OUI
             WITRTOK       = G_NON
          Else
              WNORECCCE   = G_OUI
          Endif
       Endif

      If  WNORECCCEOB = G_OUI
         WCLIGNE="=========================================================================================================="
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
         WCLIGNE="=========================================================================================================="
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
         #--> ARRET DU TRAITEMENT
         WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
         WCLIGNE="=========================================================================================================="
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
         WCLIGNE="=========================================================================================================="
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
         #*FQ-83418  GMESSAGE = mess(2,GML_MSGCIG,1)-num$(I_AXE)-"("+mess(I_AXE,3290,1)+")"
         #*FQ-83418  WCLIGNE= "        "  + GMESSAGE
         #*FQ-83418  Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
         WCLIGNE="        "  + mess(228,GML_MSGCIG,1)+ " : "+mess(338,GML_MSGFAS,1)+ " "+ [M:FPC]DIE(I_AXE-1)
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
         WITRTOK      = G_NON
         Break
      Endif

      If WNORECCCE = G_OUI
         #--> Axe analytique : Attention pas de recodification pour cet axe
         GMESSAGE = mess(338,GML_MSGFAS,1)- [M:FPC]DIE(I_AXE-1)-"("+mess((I_AXE+1),3290,1)+") "- mess(229,GML_MSGCIG,1)
         WCLIGNE= "        "  + GMESSAGE
         Call ECR_TRACE_FIC("",GTRC_CRERREU,WCLIGNE,-1,1) From TRACEABX3
         WITRTOK      = G_OUI
      Endif
   Next #I_AXE

Return

