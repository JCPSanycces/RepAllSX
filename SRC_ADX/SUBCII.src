################################################################################################
##                Traitement d'entrée des biens (cession intra-groupe)                          ##
##                                                                                              ##
##################################################################################################
##----------------------------------------------------------------------------------------------##
##  La fonction GESCII permet d'inserer l'action GESCII dans le menu                            ##
##  L'action GESCII appelle :                                                                   ##
##       - La fenètre DCIGINT qui appelle l'écran CII0                                          ##
##       - Le traitement SUBCII                                                                 ##
##----------------------------------------------------------------------------------------------##
## PRE_CONTROLE_TRAITEMENT : Traitement de pré-controle                                         ##
##   -Arret du traitement si les entités gérées n'ont pas de numérotation automatique           ##
##   -Pour chaque société source, le trt verrouille les contextes et les biens (LOCK_SOC_OBJET) ##
##   -Pour chaque société cible, le trt verrouille les contextes et les biens  (LOCK_SOC_OBJET) ##
##   -Date effet doit être dans exe. courant des soc source et soc cible pour tous contextes gérés##
## EXEC           : si click sur OK      : Déroulement du traitement Entrée des biens de la CIG ##
## - Boucle sur les paramétrages de la CIG                                                      ##
##    - Boucle sur les sociétés sources                                                         ##
##       - TRAIT_UN_CIB  : Boucle sur les biens de la table temporaire                          ##
##               Gosub TRAIT_UN_CIB_SOC_DES                                                     ##
##                  - TRF_FAS_VAL_DIV                                                           ##
##                  - TRF_FAS_VAL_ONGLET_AUTRES_REGLES                                          ##
##                  - Write Fas                                                                 ##
##                  - CREATION_AMORTISSEMENTS_DES                                               ##
##                     Pour chaque plan paramétré  du bien :                                    ##
##                        - CREATION_UN_AMORTISSEMENT_DES                                       ##
##                        - Write Dep                                                           ##
##                  - CREATION_AMORTISSEMENT_PMV                                                ##
##               Gosub TRAIT_UN_CIB_SOC_SRC                                                     ##
##                  - Maj montant de sortie                                                     ##
##                  - Insertion nouvel acheteur                                                 ##
##                  - Rewrite Fas                                                               ##
##                  - Maj de l'indicateur de recalcul pour les DEPREC du bien                   ##
## Call TRT_RECODIF From TRTRECOD pour chaque société cible                                     ##
## CALCUL_SOC_SRC : Lancement du calcul pour chaque bien de la société source modifié           ##
## TRF_PMV_DS_SOC_DES : Recopie de la +/- dans soc cible pour l'amortir dans un plan dedié      ##
## CALCUL_SOC_DES : Lancement du calcul pour chaque bien de la société cible créé               ##
## MAJ_PARAM                                                                                    ##
## UNLOCK_ALL                                                                                   ##
## KILL_GLOBAL                                                                                  ##
##----------------------------------------------------------------------------------------------##
$ACTION
 #Infbox 'action ' + ACTION
Case ACTION
 When "INIT"         : Gosub INIT           : # Action appelée avant l'ouverture de l'écran (avant étiquette DEBUT)
 When "OUVRE_BATCH"  : Gosub OUVRE_BATCH    : # Issue 109371 Pour exécution en batch
 When "INIT_DIA"     : Gosub INIT_DIA       : # Issue 109371 Pour exécution en batch
 When "OUVRE"        : Gosub OUVRE          : # Issue 109371 Pour exécution en batch
 When "DEBUT"        : Gosub DEBUT          : # Action appelée avant l'ouverture de l'écran (avant étiquette DEBUT)
 When "EXEC"         : Gosub EXEC           : # Action appelée sur click sur bouton OK
 When "TERMINE"      : Gosub TERMINE        : # Action appelée en fin de traitement
 When "SEL_LISTE"    : Gosub SEL_LISTE      : # Sélection des CIG par click droit
 When "END"          : Gosub FIN
 When Default
Endcase

Return
##################################################################################################
## Appel INIT en OUVRE_BATCH / INIT_DIA et OUVRE                                                       ##
##################################################################################################
$OUVRE_BATCH        : # Issue 109371
 # -- Ouverture des fichiers
  Gosub INIT
Return

$INIT_DIA         : # Issue 109371
# Action - Traitement ( Standard & Saisie et Execution - Batch)
  Gosub INIT
Return

$OUVRE         : # Issue 109371
  Gosub INIT
Return

##################################################################################################
## $INIT : Initialisation de l'écran                                                            ##
##################################################################################################
$INIT

GOK = 1

If clalev([F:LOF])  =0 : Local File LAYOUTFAS [LOF]         : Endif : # Table des dépenses
If G_ACTLEA = G_OUI
  If clalev([F:LEA])  =0 : Local File LEASE     [LEA]       : Endif : # Table des contrats location financement
  If clalev([F:LEA2]) =0 : Local File LEASE     [LEA2]      : Endif : # Ecriture nouvelle reference contrats location financement
  If clalev([F:LBB])  =0 : Local File LEABILBOOK[LBB]       : Endif : # Echéancier contrat location financement
  If clalev([F:LBBC]) =0 : Local File LEABILBOOK[LBBC]      : Endif : # Ecriture échéancier  contrat location financement
Endif
If G_ACTGRT = G_OUI
  If clalev([F:GRT])  =0 : Local File GRANTS  [GRT]         : Endif : # Table des subventions
Endif
If clalev([F:ADP])  =0 : Local File ADOPAR    [ADP]         : Endif : # Table des valeurs parametres
If clalev([F:ALK])  =0 : Local File APLLCK    [ALK]         : Endif : # Table des verrous
If clalev([F:ATB])  =0 : Local File ATABLE    [ATB]         : Endif : # Table des Tables
If clalev([F:FAS])  =0 : Local File FXDASSETS [FAS]         : Endif : # Biens comptables (Numérotation automatique)
If clalev([F:FASS]) =0 : Local File FXDASSETS [FASS]        : Endif : # Biens comptables (Société source)
If clalev([F:FASC]) =0 : Local File FXDASSETS [FASC]        : Endif : # Biens comptables (Société cible)
If clalev([F:FASE]) =0 : Local File FXDASSETS [FASE]        : Endif : # Biens comptables ( n° ensemble )
If clalev([F:FASV]) =0 : Local File FXDASSETS [FASV]        : Endif : # Biens comptables (sauve FAS) #FQ94220
If clalev([F:CIBP]) =0 : Local File CIGFXDSOR [CIBP]        : Endif : # Biens comptables (N° bien principal)
If clalev([F:CIG])  =0 : Local File CIGDEF    [CIG]         : Endif : # Définition  CIG
If clalev([F:CIR])  =0 : Local File CIGREX    [CIR]         : Endif : # Paramétrage CIG
If clalev([F:CIB])  =0 : Local File CIGFXDSOR [CIB]         : Endif : # Table temporaire des sorties CIG
If clalev([F:DEP])  =0 : Local File DEPREC    [DEP]         : Endif : # Dotations pour sous-programmes
If clalev([F:DEPS]) =0 : Local File DEPREC    [DEPS]        : Endif : # Dotations (Société source)
If clalev([F:DEPC]) =0 : Local File DEPREC    [DEPC]        : Endif : # Dotations (Société cible)
If clalev([F:CDF])  =0 : Local File CDFPAR    [CDF]         : Endif : # Table de  paramétrage recodification
If clalev([F:CDC])  =0 : Local File CDFCOD    [CDC]         : Endif : # Nouveaux codes de recodification
If clalev([F:CDY])  =0 : Local File CDFFCY    [CDY]         : Endif : # Sites financiers sélectionnés dans la recodification
If clalev([F:FCY])  =0 : Local File FACILITY  [FCY]         : Endif : # Tables des sites
If clalev([F:BPR])  =0 : Local File BPARTNER  [BPR]         : Endif : # Tables des tiers
If clalev([F:CPY])  =0 : Local File COMPANY   [CPY]         : Endif : # Tables des sociétés
If clalev([F:CNX])  =0 : Local File CONTEXT   [CNX]         : Endif : # Tables des contextes
If clalev([F:FIS])  =0 : Local File FISCYEAR  [FIS]         : Endif : # Tables des éxercices
If clalev([F:CCE])  =0 : Local File CACCE     [CCE]         : Endif : # Table des sections analytiques
If GPHY = G_OUI   #Fq-63483
   If clalev([F:PHY])  =0 : Local File PHYELT    [PHY]         : Endif : # Eléments physiques (Numérotation automatique)
   If clalev([F:PHYS]) =0 : Local File PHYELT    [PHYS]        : Endif : # Eléments physiques (Société source)
   If clalev([F:PHYC]) =0 : Local File PHYELT    [PHYC]        : Endif : # Eléments physiques (Société cible)
Endif
Local Mask CII0 [CII]
Raz [M:CII]
If !clalev([M:FPC])  : Local Mask FASPARCPY [FPC]  : Endif  #*FQ-83418

 # Issue 109371 : déclaration globales pour la trace en Batch
 If GSERVEUR
   Global Integer GSEQTRACE           : # Numéro de séquence de trace
   Global Integer GNUMTRACE(2)        : # Numéro de trace
 Endif

Return
####################################################################################################
## $DEBUT : Permet d'afficher les valeurs pas defaut de l'écran                                   ##
####################################################################################################
$DEBUT

Global Integer GISEL
Global Integer GIPLN

# début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
If GPHY = G_OUI
  Global Char G_ELEMENTS(GLONPHY)(1..999) # Va servir à stocker les éléments rattachés à un bien
Endif
Global Integer G_NEW_BIEN     # Mis à G_OUI quand on change de bien
G_NEW_BIEN = G_NON
# fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

[M:CII]EDIFAS = G_OUI
[M:CII]CIGCOD = ""
[M:CII]DES    = ""
[M:CII]CIGTYP = 0
[M:CII]CIGSTA = 0
[M:CII]EFFDAT = [0/0/0]

If [M:CII]CIGCOD=""
   #--- Si Ref CIG deja lue dans la session et le statut est OK pour ce traitement --------------#
   If GCIG_CIGCOD <> ""
       Read [F:CIG]= GCIG_CIGCOD
         If [S]fstat = 0 and [F:CIG]CIGSTA = GVML_CIGSTAS
           [M:CII]CIGCOD = [F:CIG]CIGCOD
           [M:CII]DES    = [F:CIG]DES
           [M:CII]CIGTYP = [F:CIG]CIGTYP
           [M:CII]CIGSTA = [F:CIG]CIGSTA
           [M:CII]EFFDAT = [F:CIG]EFFDAT
         Endif
   Else
       Filter [F:CIG] Where [F:CIG]CIGSTA = GVML_CIGSTAS Order By CIGCOD
       Read [F:CIG] First
       Filter [F:CIG]
       If fstat=0
          [M:CII]CIGCOD = [F:CIG]CIGCOD
          [M:CII]DES    = [F:CIG]DES

          [M:CII]CIGTYP = [F:CIG]CIGTYP
          [M:CII]CIGSTA = [F:CIG]CIGSTA
          [M:CII]EFFDAT = [F:CIG]EFFDAT
       Endif
   Endif
Endif

Affzo [CII]
Return
####################################################################################################
####################################################################################################
####################################################################################################
## $FIN :                                                                                         ##
####################################################################################################
$FIN

FIN = 1 : GOK = 0
Return
####################################################################################################
## $EXEC                                                                                          ##
####################################################################################################
$EXEC

Local Char    WCNOMPROG
Local Char    WCLIGNE (GTRC_LGLIGTR)
Local Char    WCDESI
Local Char    WCLIGFIXE1 (60)
Local Char    WCLIGFIXE2 (50)
Local Char    WC10BLANC  (10)
Local Char    WCTIRET
Local Char    WCOUINON
Local Char    WCDESIFIXE (150)
Local Char    WCTEXTEJAUGE(50)
Local Char    WCSOCSOURCE
Local Char    WCSOCCIBLE
Local Char    WCDEBUTLIGNE (70)
Local Char    WCSOCSRC2
Local Integer WIVIDE
Local Integer WNBTOTAL
Local Integer WAFFICHINBOX
Local Integer I
Local Integer WITRTOK
Local Integer WILOCK
Local Integer WIUNLOCK
Local Integer LOK
Local Integer WIFINFIC
Local Integer WIFASTRT
Local Integer WISOCTRT
Local Integer WINBTALLSOC
Local Integer WINBTUNESOC
Local Integer WINBSOC
Local Integer WINBATRAITER
Local Integer WISELOK
Local Integer WICODERET
Local Integer MOTEUR_ACTIF
Local Integer WIRETOUROK
Local Integer WIERREUTROUV
Local Integer WIPLANCOMPT
Local Integer WIPLANIAS
Global Integer GEDIFAS : GEDIFAS=G_OUI

Local Date    WDDERCLOTPER
Local Date    WDFINEXE
Local Date    WDDATE(1..5)


CALC_MOTEUR  = G_NON
MOTEUR_ACTIF = G_NON
WAFFICHINBOX = G_NON  : ## Debug ..................
TRA          = 1      : ## affichage trace et conservation
WCTIRET      = '------------------'
WC10BLANC    = "          "
WCNOMPROG    = 'SUBCII'
WNBTOTAL     = 0
WIFINFIC     = G_NON
WCSOCSRC2    = ""
WCSOCSOURCE  = ""
WCSOCCIBLE   = ""
WIFASTRT     = 0
WINBTALLSOC  = 0
WINBTUNESOC  = 0
WINBLALLSOC  = 0
WINBSOC      = 0
WINBATRAITER = 0
GIPLN        = 0
WISELOK      = G_OUI
WICODERET    = 0
MOTEUR_ACTIF = G_NON
WIERREUTROUV = G_NON

If GOK = 0
  Return
Endif

##-----------------------------------------------------------------------------------##
## Ajout Demande de confirmation du traitement en réél                               ##
##-----------------------------------------------------------------------------------##
If [M:CII]FLGSIM = G_NON
    Call OUINON(mess(199,GML_MSGCIG,1), LOK) From GESECRAN
    If ( LOK = G_OUI)
        GOK = 1
        FIN = 1
    Else
        GOK = 0
        FIN = 0
        End
    Endif
Else
    GOK = 1
    FIN = 1
Endif
##------------------------------------------------------------------------------------------------##
## - Edition des paramètres de traitement                                                         ##
##------------------------------------------------------------------------------------------------##
# 83--> Entrée des biens dans les sociétés cibles (Cession intra-groupe)
If !GSERVEUR : Call OUVRE_TRACE_FIC(mess(83,GML_MSGCIG,1),1) From TRACEABX3 : Endif
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
# 66--> CESSION INTRA-GROUPE
WCLIGNE="                            " + mess(66,GML_MSGCIG,1) + " " + mess(63,GML_MSGCIG,1) + "                                             "
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="" :  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
# 4--> PARAMETRES GENERAUX
WCLIGNE="                            "  + mess(4,GML_MSGCIG,1) + "                                             "
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

# 5-->  Nom du Traitement
# 7-->  Référence de Cession Intra-groupe
# 8-->  Type de cession
# 59--> Statut
# 16--> Régime fiscal
# 10--> Date d'effet
# 6-->  Edition des biens traités
# 95--> Simulation
# 103--> Calcul de la société cible

WCDESIFIXE= format$("Kb:60X", mess(5,GML_MSGCIG,1))  : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCNOMPROG ,0,1) From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(7,GML_MSGCIG,1))  : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + [M:CII]CIGCOD + "   "  + [F:CIG]DES  ,0,1  )From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(8,GML_MSGCIG,1))  : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess([M:CII]CIGTYP,GML_TYPOPCIG,1),0,1  ) From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(59,GML_MSGCIG,1)) : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess([M:CII]CIGSTA,GML_CIGSTA,1),0,1) From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(16,GML_MSGCIG,1)) : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess([F:CIG]CIGFIS,GML_RGFISCIG,1),0,1) From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(10,GML_MSGCIG,1)) : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + format$("DD2",[M:CII]EFFDAT),0,1) From TRACEABX3

If [M:CII]EDIFAS = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
WCDESIFIXE= format$("Kb:60X", mess(6,GML_MSGCIG,1))
Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3
If [M:CII]FLGSIM = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
# 95-Simulation :
WCDESIFIXE= format$("Kb:60X", mess(95,GML_MSGCIG,1))
Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3
If [M:CII]FLGCAL = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
# 103- Calcul de la société cible :
WCDESIFIXE= format$("Kb:60X", mess(103,GML_MSGCIG,1))
Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3

Gosub PRE_CONTROLE_TRAITEMENT

################################################
#  Point d'entrée (FQ-67165)                   #
#  Contrôles supplémentaires avant traitement  #
################################################
If WITRTOK = G_OUI  #Fq-67165
   GPOINT = "CTRCII" : Gosub ENTREE From EXEFNC
   #### Point d'entrée - Fin ######################
Endif
If WITRTOK = G_NON
   # Issue 109371 IF !GSERVEUR  :  Call FERME_TRACE_FIC (1) From TRACEABX3 : Endif
   If !GSERVEUR
     Call FERME_TRACE_FIC (1) From TRACEABX3
   Else
     Call LEC_TRACE_FIC(1)  From TRACEABX3
   Endif
   Gosub UNLOCK_ALL
   Return
Endif

WCLIGNE="" :  Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
# 21--> PARAMETRES SOCIETES
WCLIGNE="                            " + mess(21,GML_MSGCIG,1)
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
# 17--> Société source  18--> Société cible
WCDESIFIXE= format$("Kb:10X", WC10BLANC ) + format$("Kb:20X",  mess(17,GML_MSGCIG,1) ) +  format$("Kb:20X", mess(18,GML_MSGCIG,1))
Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE    ,0,1) From TRACEABX3
WCDESIFIXE= format$("Kb:10X", WC10BLANC ) + format$("Kb:20X",  WCTIRET        ) +  format$("Kb:20X", WCTIRET       )
Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE    ,0,1) From TRACEABX3

##------------------------------------------------------------------------------------------------##
## - Recherche des paramétages CIG                                                                ##
##------------------------------------------------------------------------------------------------##
WCSOCSOURCE  = ""
WCSOCCIBLE   = ""

GTRANS=1
Trbegin FXDASSETS[FAS]

Filter[F:CIR] Where [F:CIR]CIGCOD =  [M:CII]CIGCOD Order By CPYSRC Asc; CPYDES Asc
For [F:CIR]
   WIPLANIAS   = 0
   WIPLANCOMPT = 0
   If WCSOCSOURCE <>  [F:CIR]CPYSRC or  WCSOCCIBLE  <> [F:CIR]CPYDES
       If WCSOCSOURCE <>  [F:CIR]CPYSRC
          WINBSOC += 1
       Endif
       WCSOCSOURCE = [F:CIR]CPYSRC
       WCSOCCIBLE  = [F:CIR]CPYDES
       WCDESIFIXE  = format$("Kb:10X", WC10BLANC ) + format$("Kb:20X",  [F:CIR]CPYSRC) +  format$("Kb:20X", [F:CIR]CPYDES)
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE    ,0,1) From TRACEABX3
   Endif

   For GIPLN = 0 To 9
       WCDESIFIXE= ""       : Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       If [F:CIR]DPRPLN(GIPLN) = G301CPT
           WIPLANCOMPT = GIPLN
       Endif
       If [F:CIR]DPRPLN(GIPLN) = G301IAS
           WIPLANIAS   = GIPLN
       Endif

       If [F:CIR]DPRPLN(GIPLN) = 0
           Break
       Endif
       # 38--> Plan
       # 39--> Règle de gestion
       # 27--> Plan modèle
       # 40--> Mode
       # 41--> Durée
       # 42--> Durée défaut
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(38,GML_MSGCIG,1)) + " : " + mess([F:CIR]DPRPLN(GIPLN),GML_NPLAN,1)
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(39,GML_MSGCIG,1)) + " : " + mess([F:CIR]RULPRO(GIPLN),GML_CIGRGEST,1)
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X",  mess(27,GML_MSGCIG,1)) + " : " + string$([F:CIR]PLNTPL(GIPLN) > 0,  mess([F:CIR]PLNTPL(GIPLN),GML_NPLAN,1))
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(40,GML_MSGCIG,1)) + " : " + num$([F:CIR]DPRDPM(GIPLN))
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(41,GML_MSGCIG,1)) + " : " + string$([F:CIR]DPRDUR(GIPLN) > 0, mess([F:CIR]DPRDUR(GIPLN),GML_CIGDURES,1))
       Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
       WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(42,GML_MSGCIG,1)) + " : " + num$([F:CIR]DPRDURDEF(GIPLN))
      Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   Next

   # 43--> Base TP/TF
   # 213--> Pour les biens acquis jusqu'au
   # 44--> Date achat/mise en service
   # 45--> Etat à l'achat
   # 46--> Base +/- value
   # 47--> +/- value intra-groupe
   # 48--> Plan +/- value (société source)
   # 49--> Plan +/- value (société cible)
   # 50--> Date réintégration (société cible)
   # 51--> Mode amortissemement +/- value (société cible)
   # 52--> Durée amortissemement +/- value (société cible)
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(43,GML_MSGCIG,1)) + " : " + mess([F:CIR]TAXBASTPF,GML_CIGTPTF,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(213,GML_MSGCIG,1)) + " : " + format$("DD2",[F:CIR]RULTPFDAT)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(44,GML_MSGCIG,1)) + " : " + mess([F:CIR]PURITSDAT,GML_CIGDATE,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(45,GML_MSGCIG,1)) + " : " + mess([F:CIR]PURNAT,GML_CIGETAT,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(46,GML_MSGCIG,1)) + " : " + mess([F:CIR]BASGAL,GML_CIGBASP,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(47,GML_MSGCIG,1)) + " : " + mess([F:CIR]GALPRO,1,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(48,GML_MSGCIG,1)) + " : " + mess([F:CIR]GALPLNSRC,GML_NPLAN,1)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(49,GML_MSGCIG,1)) + " : " + string$([F:CIR]GALPLNDES > 0, mess([F:CIR]GALPLNDES,GML_NPLAN,1))
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   If  [F:CIR]GALDAT > [0/0/0]
     WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(50,GML_MSGCIG,1)) + " : " + format$("DD2",[F:CIR]GALDAT)
   Else
     WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(50,GML_MSGCIG,1)) + " : "
   Endif
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(51,GML_MSGCIG,1)) + " : " + num$([F:CIR]GALDPM)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   WCDESIFIXE= format$("Kb:15X", WC10BLANC ) + format$("Kb:48X", mess(52,GML_MSGCIG,1)) + " : " + num$([F:CIR]GALDUR)
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3

Next
Filter[F:CIR]


WCLIGNE="  "  :  Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
# 94--> LISTE DES BIENS NON CREES (ERREUR)
WCLIGNE="                            " + mess(94,GML_MSGCIG,1)+ "                                      "
Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="  "  :  Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
# 32--> Soc. Bien Explication
WCLIGNE="  " + mess(32,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="  ---  -------------       ----------------------------------------------"
Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3

#If WAFFICHINBOX = G_OUI
# Infbox 'NOM PROG = ' - WCNOMPROG - ' / PARAGRAPHE = $EXEC'
#Endif

If [M:CII]EDIFAS= G_OUI
  WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="=========================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  # 37--> LISTE DES BIENS SORTIS
  WCLIGNE="                            "  + mess(37,GML_MSGCIG,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="=========================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="  "  :  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  # 29--> Soc. Bien Désignation Montant de vente Plan +/- value
  WCLIGNE= mess(29,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="---    -----------          -----------             ----------------      -------------   --------------- "
  Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3

  WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="=========================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
   # 220--> LISTE DES ELEMENTS PHYSIQUES SORTIS
  WCLIGNE="                            "  + mess(220,GML_MSGCIG,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="=========================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="  "  :  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
  # 37TRC--> Soc. Elément Désignation Bien
  WCLIGNE= mess(37,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="---    -----------          --------------------  ------------         "
  Call ECR_TRACE_FIC ("",GTRC_CRLST1,WCLIGNE,0,1) From TRACEABX3
Endif

WIFASTRT      = 0
WISOCTRT      = 0

# Ouverture du calcul
Local    Char    PCPY                          : # Société
Local    Integer PTBCNX(1..GMAXCNXC,0..GTBCNX) : # Contextes à  calculer
Local    Char    PIPEDEM                       : # Canal d'écriture
Local    Char    PIPEREP                       : # Canal de lecture
Local    Integer RERROR
Local    Char    LNIVTRACE(1), LCALVIETRA(1)
Local    Char    LCPY(GLONCPY)
If dim(GTRCCPY)<0
   Global   Char    GTRCCPY(GLONCPY)
   GTRCCPY= WCSOCSOURCE
Endif
Raz PIPEDEM
Raz PIPEREP
# ------------------------------
If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
If clalev([F:FIS])  = 0 : Local File FISCYEAR    [FIS]  : Endif : # Exercices
If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
# ------------------------------
GNIVTRACE  = 0
LCALVIETRA = num$(G_OUI)
##------------------------------------------------------------------------------------------------##
## Boucle sur les paramétrages CIG corrrespondant à la CIG traitée                                ##
## puis pour chaque société source                                                                ##
##------------------------------------------------------------------------------------------------##
WCSOCSOURCE  = ""
WCSOCCIBLE   = ""

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD) Order By CPYSRC Asc
For [F:CIR]
    If WCSOCSOURCE <>  [F:CIR]CPYSRC

      WCLIGNE = ""    :  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

      ##---------------------------------------------------------------------------------------------##
      ## Comptabilisation du nombre total de biens à sortir pour la société                          ##
      ##---------------------------------------------------------------------------------------------##
       Filter[F:CIB] Where ([F:CIB]CPYSRC =  [F:CIR]CPYSRC and [F:CIB]CIGCOD =  [M:CII]CIGCOD)
       WINBATRAITER   = rowcount ([F:CIB])
       Filter [F:CIB]
       # 86--> Cession intra-groupe
       WCTEXTEJAUGE  = mess(86,GML_MSGCIG,1) + ' : ' +  [M:CII]CIGCOD
       Call TEMPOFF() From GESECRAN
       Call OUVRE_BOITE(WCTEXTEJAUGE, WINBATRAITER    ) From GESECRAN
       # 110--> Lecture des biens à sortir
       WCTEXTEJAUGE  = mess(110,GML_MSGCIG,1)
       Call SET_BOITE(WCTEXTEJAUGE, WINBATRAITER      ) From GESECRAN

       WCSOCSOURCE = [F:CIR]CPYSRC
       WINBTUNESOC = 0
       ##---------------------------------------------------------------------------------------------##
       ## Lecture des biens a céder correspondant à CIB                                               ##
       ##---------------------------------------------------------------------------------------------##
       Filter[F:CIB] Where ([F:CIB]CPYSRC =[F:CIR]CPYSRC and [F:CIB]CIGCOD =[M:CII]CIGCOD and [F:CIB]FLGAASCCL = G_NON) Order By  [F:CIB]CMP Asc; [F:CIB]FLGCMP Asc; [F:CIB]SET Asc
       For [F:CIB] With Stability
          ##---------------------------------------------------------------------------------------------##
          ## Traitement de un CIB                                                                        ##
          ##---------------------------------------------------------------------------------------------##
          Gosub TRAIT_UN_CIB
          If GOK = 0 : Break 2 : Endif  #*Fq-86480
          ##---------------------------------------------------------------------------------------------##
          ## Rewrite CIB avec la nouvelle référence du bien                                              ##
          ##---------------------------------------------------------------------------------------------##
          Rewrite [F:CIB]
          If (fstat)
             GOK = 0 : Call FSTA("CIB") From GLOCK
             Break 2
          Endif
          ##---------------------------------------------------------------------------------------------##
          ## évolution de l'avancement de la jauge                                                       ##
          ##---------------------------------------------------------------------------------------------##
          WINBTALLSOC  += 1
          WINBTUNESOC  += 1
          # 30--> Société:  31--> Biens:
          WCTEXTEJAUGE=   mess(30,GML_MSGCIG,1) + [F:CIR]CPYSRC + '     ' + mess(31,GML_MSGCIG,1)+num$(WINBTUNESOC)+'/'+num$(WINBATRAITER)
          Call AFF_BOITE(WCTEXTEJAUGE,WINBTUNESOC,LOK) From GESECRAN
       Next
       Filter[F:CIB]
       Call FERME_BOITE From GESECRAN

   Endif
Next
Filter[F:CIR]

If GOK = 0
   WITRTOK=G_NON  #*Fq-86480
Endif

## Fermeture du calcul
#*V5 Call FERME_CANAL_C (PIPEDEM, PIPEREP, RERROR) From =GGLOCALC

Gosub POST_CONTROLE_TRAITEMENT

##---------------------------------------------------------------------------------------------##
## Edition dans le compte-rendu de l'entete du nombre et de la liste des biens créés           ##
##---------------------------------------------------------------------------------------------##
WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
# 221--> NOMBRE DE BIENS ET ELEMENTS PHYSIQUES CREES
WCLIGNE="                            " + mess(221,GML_MSGCIG,1)+ "                                      "
Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WCLIGNE= mess(38,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="--------------           -------------                    -------------    -------------"
Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3

WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
# 85-> LISTE DES BIENS CREES
WCLIGNE="                            "  + mess(85,GML_MSGCIG,1)
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE= mess(31,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="---    -----------          --------------------  ------------   -------------    --------------------  "
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3

Gosub TRT_RECOD

WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
# 219--> LISTE DES ELEMENTS PHYSIQUES CREES
WCLIGNE="                            "  + mess(219,GML_MSGCIG,1)
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="=========================================================================================================="
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="  "  :  Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
# 36--> Soc. Elément Désignation Bien Anc référence elt Anc référence bien
WCLIGNE= mess(36,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="---    -----------          --------------------  ------------         -----------             -----------  "
Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3

Gosub COMMIT_ROOLBACK

##--------------------------------------------------------------------------------------------##
## Le calcul de la société source est necessaire pour avoir la valeur nette de la société     ##
## source qui sera reconduit vers un plan libre de la société cible                           ##
##--------------------------------------------------------------------------------------------##

 Local Char SVTRACE(GLONTRA)
 SVTRACE = GTRACE

 Gosub CALCUL_SOC_SRC

If [M:CII]FLGSIM <> G_OUI  and WITRTOK = G_OUI
   Trbegin FXDASSETS[FAS]
   Gosub TRF_PMV_DS_SOC_DES
   Gosub COMMIT_ROOLBACK
   If [M:CII]FLGCAL  = G_OUI
      ##-------------------------------------------------------------------------------------##
      ## Calcul société cible appelé que si le Trt CIG  n'est pas en simulation               ##
      ##-------------------------------------------------------------------------------------##
      Gosub CALCUL_SOC_DES
   Endif
   If WITRTOK = G_OUI
     Gosub SORTIR_BIENS  # Fq-53346
     Gosub MAJ_PARAM
   Endif
Endif

#Fq-94220b
If [M:CII]FLGSIM <> G_OUI  and WITRTOK = G_OUI
   Filter[F:FASC] Where [F:FASC]CIGCOD =  [M:CII]CIGCOD Order By CPY Asc; GRUORICPY Asc;[F:FASC]AASREF Asc
   For [F:FASC]
      Gosub CREATION_EVT_IMMOBILISATION
   Next # [FASC]
   Filter[F:FASC]
Endif #Fq-94220b END


Gosub UNLOCK_ALL

 GTRACE = SVTRACE
 If GLTRACE = 0   # le passage dans le calcul remets GLTRACE à zéro ==> plus d'affichage de la trace
 Local Char    FICTRA(250)
    FICTRA = filpath("TRA",GTRACE,"tra",0)
    GLTRACE   = filinfo(FICTRA,7)
 Endif

  # Issue 109371 -IF !GSERVEUR  :  Call FERME_TRACE_FIC (1) From TRACEABX3 : Endif
  If !GSERVEUR
    Call FERME_TRACE_FIC (1) From TRACEABX3
  Else
    Call LEC_TRACE_FIC(1)  From TRACEABX3
  Endif

Gosub KILL_GLOBAL


Return
####################################################################################################
## $COMMIT_ROOLBACK: COMMIT ou ROLLBACK                                                           ##
####################################################################################################
$COMMIT_ROOLBACK

If GOK <> 0 and   [M:CII]FLGSIM = G_NON  and WIRETOUROK = G_OUI and WITRTOK = G_OUI
    Commit
    If WAFFICHINBOX = G_OUI
        Infbox 'Commit'
    Endif
Else
    Rollback
    If WAFFICHINBOX = G_OUI
        Infbox 'Rollback'
    Endif
Endif

GTRANS=0

Return
####################################################################################################
## $TRAIT_UN_CIB_SOC_SRC : Traitement d'une ligne de la table CIB pour la société source          ##
####################################################################################################
$TRAIT_UN_CIB_SOC_SRC

Local Integer RERROR
Local Integer LCDRET
Local Integer WICONTEXTE
Local Integer LJAUGE
Local Integer I_PLN     # Indice de parcours des plans d'amortissement
Local Char    WK_EVTINT   # Code interne des événements de sortie.
  ########################################################################
  #  Point d'entrée (Fq-70348)                                           #
  #  conditionnement génération des evts d'annulation de sortie          #
  #  si pas de génération d'evt d'annulation de sortie dans certains cas #
  #  alimenter GOK avec une valeur <> 1                                  #
  ########################################################################
  GOK=1
  GPOINT = "EVTISSANU" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
  #### Point d'entrée - Fin ######################
  If GOK = 1 #*Fq-70348
    ##------------------------------------------------------------------------------------------------##
    ## Annulation de l'événement de sortie si :
    ##  - un bien a été créé dans un exercice antérieur et est sorti après la date d'effet de la CIG (ISSAT=GVML_ETATSSM)
    ##  ou
    ##  - un bien a été été sorti après (ou au jour de) la date d'effet de la CIG  ( ISSDAT >= EFFDAT )
    ##------------------------------------------------------------------------------------------------##
     #Fq-70129 If [F:CIB]ISSSAT    = GVML_ETATSSM
     If ( [F:CIB]ISSSAT    = GVML_ETATSSM )  or ([F:FASS]ISSDAT >= [M:CII]EFFDAT )
        If !clalev([F:EVT0]) : Local File EFASISS [EVT0] : Endif   #*Fq-48615
        If !clalev([F:EVT1]) : Local File EFASISS [EVT1] : Endif   #*Fq-48615

        For I_PLN=1 To G301MAX
           If func GLOBIENS.CPY_PLN_GERE([F:CIR]CPYSRC,I_PLN)=G_OUI
              WK_EVTINT="FASISS"+num$(I_PLN)
              #Fq-69673 Filter [F:EVT0] Where (CPY=[F:CIR]CPYSRC & DPRPLN=I_PLN & REF=[F:CIB]AASREF & EVTDAT=[F:CIB]ISSDAT & SNSEVE<>GVML_TEAACT)
              Filter [F:EVT0] Where (CPY=[F:CIR]CPYSRC & DPRPLN=I_PLN & REF=[F:CIB]AASREF & EVTDAT=[F:FASS]ISSDAT & SNSEVE<>GVML_TEAACT)
              Read [F:EVT0]EVE0 Last
              Filter [EVT0]
              If !fstat
                 If func GENEVE.EXISTE_EXTOURNE_EVE(RERROR)=G_NON
                    #Fq-69673 Call EXTOURNE_EVE(GVML_OMBIEN,[F:CIR]CPYSRC,[F:FASS]FCY,[F:CIB]AASREF, 0,WK_EVTINT,[F:CIB]ISSDAT, RERROR) From GENEVE
                    Call EXTOURNE_EVE(GVML_OMBIEN,[F:CIR]CPYSRC,[F:FASS]FCY,[F:CIB]AASREF, 0,WK_EVTINT,[F:FASS]ISSDAT, RERROR) From GENEVE
                 Endif
              Else
                 Break
                 #*Fq-70348 GOK=0
              Endif
           Endif
        Next I_PLN
        If clalev([F:EVT0]) : Close Local File [EVT0] : Endif
        If clalev([F:EVT1]) : Close Local File [EVT1] : Endif
     Endif
  Endif #*Fq-70348

GOK=1
##------------------------------------------------------------------------------------------------##
## Modification du bien de la societe source si Etat sortie CIG du bien = 'BIEN A ANNULER'        ##
##-------------------------------------------------Fq-70129-----------------------------------------------##
If [F:CIB]ISSSAT      = GVML_ETATSAA
   [F:FASS]UPDDAT     = [M:CII]EFFDAT        #Date sortie : non, car sinon génération d'1 evt de sortie
   [F:FASS]ISSDAT     = [0/0/0]              #Fq-70129  Date sortie remise à [0/0/0]
   [F:FASS]ISSDATRUL   = 0                   #Fq-70129 Champ non renseigné
   [F:FASS]UPDUSR      = GUSER
    # Motif sortie
    Case [M:CII]CIGTYP
      When GVML_TOAPPOR    : [F:FASS]ISSTYP = GVML_TSAPPOR
      When GVML_TOFUSIO    : [F:FASS]ISSTYP = GVML_TSFUSIO
      When GVML_TOSCISS    : [F:FASS]ISSTYP = GVML_TSSCISS
      When GVML_TOVTEIG    : [F:FASS]ISSTYP = GVML_TSCIG
    Endcase
    [F:FASS]BUY        = [F:CIR]CPYDES        # Acheteur (table BPARTNER)
    Gosub INSERT_ACHETEUR
Endif
##------------------------------------------------------------------------------------------------##
## Modification du bien de la societe source si Etat sortie CIG du bien = 'BIEN SORTI A MODIFIER' ##
## ou 'BIEN A SORTIR'                                                                             ##
##------------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT    = GVML_ETATSSM or [F:CIB]ISSSAT    = GVML_ETATSAS
    WDMTSORTIE = 0
    If [F:CIB]ISSAMTUPD <> 0
        WDMTSORTIE = [F:CIB]ISSAMTUPD
    Else
        WDMTSORTIE = [F:CIB]ISSAMT
    Endif
    [F:FASS]ISSTYP     = 0
    [F:FASS]ISSDAT     = [0/0/0]
    [F:FASS]ISSAMT     = 0
    [F:FASS]PYBVATTYP  = 0
    [F:FASS]ISSVATRAT  = 0
    [F:FASS]ISSVATAMT  = 0
    [F:FASS]EXTISSFLG  = G_NON
    [F:FASS]ACGCPLDED  = 0
    [F:FASS]IASCPLDED  = 0
    [F:FASS]BUY        = ""
    # Le bien devra être recalculé
    [F:FASS]FLGCLC     = G_OUI
    Filter [CNX] Where CPY= [F:FASS]CPY
    For [CNX]
       [F:FASS]FLGCNXCLC([F:CNX]CNX-1)     = G_OUI
    Next
    Filter [CNX] #FQ-67475
    [F:FASS]ISSDAT     = [M:CII]EFFDAT         # Date sortie
    Case [M:CII]CIGTYP
      When GVML_TOAPPOR    : [F:FASS]ISSTYP = GVML_TSAPPOR
      When GVML_TOFUSIO    : [F:FASS]ISSTYP = GVML_TSFUSIO
      When GVML_TOSCISS    : [F:FASS]ISSTYP = GVML_TSSCISS
      When GVML_TOVTEIG    : [F:FASS]ISSTYP = GVML_TSCIG
    Endcase
    [F:FASS]ISSAMT      = WDMTSORTIE            # Montant sortie
    [F:FASS]PYBVATTYP   = GVML_RVTVA00          # Reversement de TVA
    [F:FASS]ISSDATRUL   = GVML_IRJPREC          #Fq-67465 Pas de dotation le jour de sortie
    #[F:FASS]ISSVATRAT  = ISSVATRAT             # Taux TVA sortie  19,6
    [F:FASS]BUY         = [F:CIR]CPYDES         # Acheteur (table BPARTNER)
    # Issue 109371 [F:FASS]GRUISSREF   = [F:CIG]CIGCOD #FQ-68409b
    # Issue 109371 [F:FASS]GRUEFFDAT   = [F:CIG]EFFDAT #FQ-68409b
    [F:FASS]GRUISSREF   = [M:CII]CIGCOD #FQ-68409b
    [F:FASS]GRUEFFDAT   = [M:CII]EFFDAT #FQ-68409b

    Gosub CALC_VALEURS_SORTIE

    Gosub INSERT_ACHETEUR
    ##--------------------------------------------------------------------------------------------##
    ## Ecriture de FAS de la societe source                                                       ##
    ##--------------------------------------------------------------------------------------------##
    Rewrite [F:FASS]
    If (fstat)
          GOK = 0 : Call FSTA("FASS") From GLOCK
          Return
    Endif
    ##--------------------------------------------------------------------------------------------##
    ## Nota : le calcul n'est pas lancé pour chaque bien                                          ##
    ##--------------------------------------------------------------------------------------------##
    ## Une fonction de calcul sera lancée en fin de traitement , sur option de l'utilisateur      ##
    ## (indicateur de traitement), et traitera tous les biens d'une société passée en paramêtre   ##
    ## qui auront été modifié depuis la date de dernier calcul                                    ##
    ##--------------------------------------------------------------------------------------------##
    ##--------------------------------------------------------------------------------------------##
    ## Maj de l'indicateur de recalcul pour les DEPREC du bien                                    ##
    ##--------------------------------------------------------------------------------------------##
    For I_PLN=1 To G301MAX
      # Est-ce que ce plan est géré ?
      If func GLOBIENS.CPY_PLN_GERE([F:FASS]CPY,I_PLN)=G_OUI

           ##-----------------------------------------------------------------------------------------##
           ## Récupère le contexte du plan                                                            ##
           ##-----------------------------------------------------------------------------------------##
           Call GET_CNX_FROM_PLAN([F:FASS]CPY,I_PLN,WICONTEXTE) From GLOBIENS
           ##-----------------------------------------------------------------------------------------##
           ## Fin exercice et fin de période du contexte correspondant au plan  a creer               ##
           ##-----------------------------------------------------------------------------------------##
           Call GET_CNX_DAT([F:FASS]CPY,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS
           [F:DEPS]FIYENDDAT = WDDATE(2)
           [F:DEPS]PERENDDAT = WDDATE(4)
           #> Lecture DEPREC
           Read [F:DEPS]DEP0=[F:FASS]AASREF;I_PLN;WDDATE(2);WDDATE(4)
           If fstat=0
             #Fq-67465 [F:FASS]GAL(I_PLN) =  [F:CIB]GAL
             [F:FASS]GAL(I_PLN-1) =  [F:CIB]GAL
             # Statut = "non-calculé" uniquement pour biens non-annulés
             If [F:FASS]OWNTYP     <>  GVML_TDANNUL
                [F:DEPS]DEPSTA     =  GVML_SCNOCAL
             Endif
             Rewrite [F:DEPS]
             If (fstat)
                    GOK = 0 : Call FSTA("DEPS") From GLOCK
                    Return
             Endif
          Endif
      Endif
    Next I_PLN
    ##--------------------------------------------------------------------------------------------##
    ## Edition ligne dans compte-rendu (LISTE DES BIENS SORTIS)                                   ##
    ##--------------------------------------------------------------------------------------------##
    If [M:CII]EDIFAS = G_OUI
         WCLIGNE= [F:FASS]CPY  + format$("KB:4X", "")  +  format$("KB:20X", [F:FASS]AASREF)   + " "
&                              + format$("KB:21X", [F:FASS]AASDES1)+ '   ' + ' '
&                              + format$("KB:21X", num$(WDMTSORTIE))  + ' '
&                              + format$("KB:15X", string$([F:CIB]PLN > 0, mess([F:CIB]PLN,GML_NPLAN,1)))
&                              + format$("KB:15X", num$([F:CIB]GAL))
       Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
    Endif

Endif
##--------------------------------------------------------------------------------------------##
## Annulation du bien de la societe source si Etat sortie CIG du bien = 'BIEN A ANNULER'      ##
##--------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT    = GVML_ETATSAA

    ##----------------------------------------------------------------------------------------##
    ## Extourne de tous les evenements car annulation du bien                                 ##
    ##----------------------------------------------------------------------------------------##
    LJAUGE = G_NON
    Call DETRICOTE_EVE ( GVML_OMBIEN,
&                       [F:FASS]CPY,
&                       [F:FASS]AASREF,
&                       0,
&                       [F:FASS]PURDAT,
&                       LJAUGE ,
&                       LCDRET) From GENEVE
    If (LCDRET > 20 )
        GOK = 0 : GSUPOK = G_NON
        Call FSTA("EFASCRT") From GLOCK
        Return
    Endif
    ##----------------------------------------------------------------------------------------##
    ## Ecriture de FAS de la societe source                                                   ##
    ##----------------------------------------------------------------------------------------##
    [F:FASS]OWNTYP     = GVML_TDANNUL
    [F:FASS]FLGCLC     = G_NON
    [F:FASS]GRUISSREF  = [F:CIG]CIGCOD #FQ-68409b
    [F:FASS]GRUEFFDAT  = [F:CIG]EFFDAT #FQ-68409b
    Filter [CNX] Where CPY= [F:FASS]CPY
    For [CNX]
       [F:FASS]FLGCNXCLC([F:CNX]CNX-1)     = G_NON
    Next
    Filter [CNX] #FQ-67475
    Rewrite [F:FASS]
    If (fstat)
       GOK = 0 : Call FSTA("FASS") From GLOCK
       Return
    Endif
     #*Fq-69885---
    If [F:FASS]OWNTYP     = GVML_TDANNUL
      If clalev([F:FLU])=0  : Local File FXDLIFL  [FLU]  :  Endif
      Delete [F:FLU] Where AASREF=[F:FASS]AASREF
      Close Local File [FLU]
    Endif  #*Fq-69885---
    ##--------------------------------------------------------------------------------------------##
    ## Edition ligne dans compte-rendu                                                            ##
    ##--------------------------------------------------------------------------------------------##
    If [M:CII]EDIFAS = G_OUI
      # 106--> Bien annulé
      WCLIGNE= [F:FASS]CPY + format$("KB:4X", "")  +  format$("KB:20X", [F:FASS]AASREF)   + " " +  format$("KB:21X", [F:FASS]AASDES1)+ '   '  + format$("KB:15X", mess(106,GML_MSGCIG,1))
      Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
    Endif

Endif

If GPHY = G_OUI   #Fq-63483
   Gosub MAJ_ELTPHY_SRC
Endif

Return
####################################################################################################
## $CALCUL_SOC_SRC : Lancement du calcul pour chaque bien de la société source modifié            ##
####################################################################################################
$CALCUL_SOC_SRC
Local Integer WINBOK
Local Integer TBCNX(1..GMAXCNXC)      : # Contextes à calculer, Type de Paramètres
# Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
Local Char    TBFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
Local Decimal RERROR
#Local Integer WITYPEDECALCUL
Local Integer N_FCY, N_S, N_E, N_CNX

Global Char   GTRCCPY(GLONCPY)
If dim(GNOTRCCALC)>=0
    Kill GNOTRCCALC
Endif

# 102--> Calcul de la société source
WCTEXTEJAUGE  = mess(102,GML_MSGCIG,1) + ' : ' +  [M:CII]CIGCOD

WINBATRAITER  = 1
WINBOK        = 1

Call TEMPOFF() From GESECRAN
Call OUVRE_BOITE(WCTEXTEJAUGE, WINBATRAITER    ) From GESECRAN
Call SET_BOITE(WCTEXTEJAUGE, WINBATRAITER      ) From GESECRAN

WCSOCSOURCE  = ""

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCSOURCE <>  [F:CIR]CPYSRC
       # Chargement table des sites de la société à calculer
        If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  :  Endif
        Raz TBFCY : N_FCY = 1
        For [FCY]FCY1 Where LEGCPY=[F:CIR]CPYSRC
          TBFCY(N_FCY) = [F:FCY]FCY
          N_FCY += 1
        Next FCY1
       # Chargement table des contextes de la société à calculer
        If clalev([F:CNX])=0  : Local File CONTEXT  [CNX]  :  Endif
        Raz TBCNX : N_CNX = 1

        For [CNX]CNX0 Where CPY=[F:CIR]CPYSRC
          TBCNX(N_CNX) = [F:CNX]CNX
          N_CNX += 1
        Next CNX0

        GTRCCPY = [F:CIR]CPYSRC

        Global Integer G_CLCTRC : G_CLCTRC = 0   # 0 : pas de trace/1 : trace
        Gosub AVANT_CALCULER_SOCIETE From GLOBB0

        # -Branchement calcul optimisé FQ88613
        Call CALCULER_SOCIETE([F:CIR]CPYSRC, TBFCY, TBCNX, G_NON, RERROR) From GLOBB
        #*FQ101833 If RERROR : WITRTOK=G_NON : Break : Endif
        If (RERROR)
          WITRTOK=G_NON : GOK=0
        Endif #*FQ101833 END

        Gosub APRES_CALCULER_SOCIETE  From GLOBB0

        # faire evolution de la jauge
        # 30--> Société:
        WCTEXTEJAUGE=   mess(30,GML_MSGCIG,1) + [F:CIR]CPYSRC
        If !GBROWS  #Fq-82408
           Call AFF_BOITE(WCTEXTEJAUGE,WINBOK,LOK) From GESECRAN
        Endif
        WCSOCSOURCE = [F:CIR]CPYSRC
    Endif
Next
Filter[F:CIR]

Call FERME_BOITE From GESECRAN

Return
####################################################################################################
## $CALCUL_SOC_DES : Lancement du calcul pour chaque bien de la société cible créé                ##
####################################################################################################
$CALCUL_SOC_DES
Local Integer WINBOK
Local Integer TBCNX(1..GMAXCNXC)      : # Contextes à calculer, Type de Paramètres
# Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
Local Char    TBFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
Local Decimal RERROR
#Local Integer WITYPEDECALCUL
Local Integer N_FCY, N_S, N_E, N_CNX

Global Char   GTRCCPY(GLONCPY)

If dim(GNOTRCCALC)>=0
    Kill GNOTRCCALC
Endif

# 102--> Calcul de la société source
WCTEXTEJAUGE  = mess(102,GML_MSGCIG,1) + ' : ' +  [M:CII]CIGCOD

WINBATRAITER  = 1
WINBOK        = 1

Call TEMPOFF() From GESECRAN
Call OUVRE_BOITE(WCTEXTEJAUGE, WINBATRAITER    ) From GESECRAN
Call SET_BOITE(WCTEXTEJAUGE, WINBATRAITER      ) From GESECRAN

WCSOCCIBLE  = ""

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCCIBLE <>  [F:CIR]CPYDES
       # Chargement table des sites de la société à calculer
       Raz TBFCY : N_FCY = 1
        If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  :  Endif
        For [FCY]FCY1 Where LEGCPY=[F:CIR]CPYDES
          TBFCY(N_FCY) = [F:FCY]FCY
          N_FCY += 1
        Next FCY1
        # Chargement table des contextes de la société à calculer
        If clalev([F:CNX])=0  : Local File CONTEXT  [CNX]  :  Endif
        Raz TBCNX : N_CNX = 1
        For [CNX]CNX0 Where CPY=[F:CIR]CPYDES
          TBCNX(N_CNX) = [F:CNX]CNX
          N_CNX += 1
        Next CNX0

        GTRCCPY = [F:CIR]CPYDES

        Global Integer G_CLCTRC : G_CLCTRC = 0  # 0 : pas de trace/1 : trace
        Gosub AVANT_CALCULER_SOCIETE  From GLOBB0
        # -Branchement calcul optimisé
        Call CALCULER_SOCIETE([F:CIR]CPYDES, TBFCY, TBCNX, G_NON, RERROR) From GLOBB
        #*FQ101833 Si erreur dans calcul ==> rollback du traitement
        If (RERROR)
            WITRTOK=G_NON : GOK=0
        Endif #*FQ101833 END

        Gosub APRES_CALCULER_SOCIETE  From GLOBB0
        # faire evolution de la jauge
        # 30-->  Société:
        WCTEXTEJAUGE=   mess(30,GML_MSGCIG,1) + [F:CIR]CPYDES
        If !GBROWS  #Fq-82408
           Call AFF_BOITE(WCTEXTEJAUGE,WINBOK,LOK) From GESECRAN
        Endif
        WCSOCCIBLE = [F:CIR]CPYDES
    Endif
Next

Filter[F:CIR]

Call FERME_BOITE From GESECRAN

Return
####################################################################################################
## $MAJ_PARAM : Edition dans le compte-rendu des biens créés                            ##
##########################################################################################
$MAJ_PARAM

If WITRTOK = G_OUI and [M:CII]FLGSIM <>  G_OUI #Fq-67465
  Read[CIG]CIG0= [M:CII]CIGCOD  # Issue 109371 - 2015-07-30 by MDJ : comment
  If fstat=0
    ## - La CIG prend le statut Entrées traitées                                                ##
    [F:CIG]CIGSTA = GVML_CIGSTAE
    [F:CIG]OPEDAT = date$
    [F:CIG]PROUSR = GUSER
    Rewrite [F:CIG] = [M:CII]CIGCOD
  Endif

  #Fq-67465
  Delete [CIB] Where CIGCOD = [M:CII]CIGCOD
  If fstat
    Return
  Endif

  #Fq-68409
  Filter [CDF] Where REFTRFCMP = [M:CII]CIGCOD
  For [CDF] With Stability
     [F:CDF]PROSTA    = GVML_RECTRTC
     [F:CDF]PRODAT    = date$
     [F:CDF]PROUSR    = GUSER
      Rewrite [F:CDF]
      If [S]fstat <> 0
            Infbox 'Rewrite [F:CDF] stat = ' + num$( fstat )
      Endif
   Next
   Filter [CDF]
Endif

Return
####################################################################################################
## $TRF_PMV_DS_SOC_DES : Recopie de la +/- dans soc cible pour l'amortir dans un plan dedié ##
####################################################################################################
$TRF_PMV_DS_SOC_DES
Local Integer WINBATRAITER
Local Integer WINBOK
Local Integer WICONTEXTE

WINBOK = 0
##---------------------------------------------------------------------------------------##
## Si la +/- value créée, par la cession intra-groupe, dans la société source doit être  ##
## transférée vers la société cible, elle sera amortie dans un plan dédié et a donc      ##
## besoin des informations suivantes :                                                   ##
##   - Plan dédié à l’amortissement de la +/- value de cession intra-groupe              ##
##   - Date de début d’amortissement nommée date de réintégration                        ##
##   - * d’amortissement                                                                 ##
##   - Durée d’amortissement                                                             ##
##---------------------------------------------------------------------------------------##

##------------------------------------------------------------------------------------------------##
## Boucle sur les paramétrages CIG correspondant à la CIG traitée                                 ##
## puis pour chaque société source                                                                ##
##------------------------------------------------------------------------------------------------##

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD) Order By CPYSRC Asc
WINBATRAITER   = rowcount ([F:CIR])
# 104--> Recopie +/- value vers société cible
WCTEXTEJAUGE  = mess(104,GML_MSGCIG,1)
Call TEMPOFF() From GESECRAN
Call OUVRE_BOITE(WCTEXTEJAUGE, WINBATRAITER    ) From GESECRAN
Call SET_BOITE(WCTEXTEJAUGE, WINBATRAITER      ) From GESECRAN

For [F:CIR]
    # Evolution de la jauge
    WINBOK += 1
    WCTEXTEJAUGE=   mess(30,GML_MSGCIG,1)  + '     ' +num$(WINBOK)+'/'+num$(WINBATRAITER)
    Call AFF_BOITE(WCTEXTEJAUGE ,WINBOK,LOK) From GESECRAN
    If [F:CIR]GALPRO = G_OUI

           ##-------------------------------------------------------------------------------##
           ## Récupère le contexte du plan                                                  ##
           ##-------------------------------------------------------------------------------##
           Call GET_CNX_FROM_PLAN([F:CIB]CPYSRC,[F:CIR]GALPLNSRC,WICONTEXTE) From GLOBIENS
           ##---------------------------------------------------------------------------------------------##
           ## Récup date debut et fin d'exercice du contexte correspondant au plan amort lu de soc source ##
           ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ##
           ##---------------------------------------------------------------------------------------------##
           Call GET_CNX_DAT([F:CIB]CPYSRC,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS
           ##---------------------------------------------------------------------------------------------##
           ## Lecture des biens a céder correspondant à CIB                                               ##
           ##---------------------------------------------------------------------------------------------##
           Filter[F:CIB] Where ([F:CIB]CPYSRC =  [F:CIR]CPYSRC and [F:CIB]CPYDES =  [F:CIR]CPYDES and [F:CIB]CIGCOD =  [M:CII]CIGCOD)
           For [F:CIB]
                Read [F:DEPS]DEP0 = [F:CIB]AASREF; [F:CIR]GALPLNSRC; WDDATE(2); WDDATE(4)
               If [S]fstat = 0
                  Gosub CREATION_AMORTISSEMENT_PMV
               Endif
            Next
           Filter[F:CIB]
   Endif
Next

Filter[F:CIR]

Call FERME_BOITE From GESECRAN

Return
######################################################################################################
## $CREATION_AMORTISSEMENT_PMV: la +/- value créée est amortie dans un plan dédié de la societe cible ##
######################################################################################################
$CREATION_AMORTISSEMENT_PMV
Local Integer WIDEPCEXIST
Local Integer WICONTEXTE
Local Char WCDEVPS
Local Char WCDEVPC
##-----------------------------------------------------------------------------------------##
## Récupère le contexte du plan                                                            ##
##-----------------------------------------------------------------------------------------##
Call GET_CNX_FROM_PLAN([F:FASC]CPY,[F:CIR]DPRPLN(GIPLN),WICONTEXTE) From GLOBIENS
Call GET_CNX_DAT([F:FASC]CPY,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS

WIDEPCEXIST = G_NON
Read [F:DEPC]DEP0 = [F:CIB]AASREFNEW ; [F:CIR]GALPLNDES; WDDATE(2); WDDATE(4)
If [S]fstat = 0
  WIDEPCEXIST = G_OUI
Endif

Gosub INIT_DEP
[F:DEPC]DEPSTA     = GVML_SCNOCAL

##-----------------------------------------------------------------------------------------##
## Fin exercice et fin de période du plan  a creer                                         ##
##-----------------------------------------------------------------------------------------##
[F:DEPC]FIYENDDAT = WDDATE(2)
[F:DEPC]PERENDDAT = WDDATE(4)

##-----------------------------------------------------------------------------------------##
## Société , référence, plan , Date début d'amort , mode , durée                           ##
##-----------------------------------------------------------------------------------------##
[F:DEPC]CPY        = [F:CIR]CPYDES
[F:DEPC]AASREF     = [F:CIB]AASREFNEW
[F:DEPC]DPRPLN     = [F:CIR]GALPLNDES
[F:DEPC]STRDPRDAT  = [F:CIR]GALDAT
[F:DEPC]DPM        = [F:CIR]GALDPM
[F:DEPC]DPRDUR     = [F:CIR]GALDUR
##-----------------------------------------------------------------------------------------##
## Base amort : +-/ value source                                                           ##
##-----------------------------------------------------------------------------------------##

# Récupération de la devise du plan alimentant la +/- value de la societe cible

WCDEVPS = ""
WCDEVPC = ""
Call GET_CNX_FROM_PLAN([F:CIR]CPYSRC,[F:CIR]GALPLNSRC,WICONTEXTE) From GLOBIENS
If WICONTEXTE < 0   #*Fq-54639
   WICONTEXTE = 0
Endif
Read [F:CNX]CNX0=[F:CIR]CPYSRC;WICONTEXTE
If fstat = 0
     WCDEVPS = [F:CNX]CUR
Else
     WCDEVPS = GEURO
Endif
Call GET_CNX_FROM_PLAN([F:CIR]CPYDES,[F:CIR]GALPLNDES,WICONTEXTE) From GLOBIENS
If WICONTEXTE < 0   #*Fq-54639
   WICONTEXTE = 0
Endif
Read [F:CNX]CNX0=[F:CIR]CPYDES;WICONTEXTE
If fstat = 0
     WCDEVPC = [F:CNX]CUR
Else
     WCDEVPC = GEURO
Endif

If WCDEVPS  = WCDEVPC
    [F:DEPC]BSEVAL =  [F:CIB]GAL     #*V5 [F:DEPS]GRUGAL
    [F:DEPC]DPRBAS =  [F:CIB]GAL     #*V5 [F:DEPS]GRUGAL
Else
    WCDEV1  = WCDEVPS
    WCDEV2  = WCDEVPC
    WDMONT1           = [F:CIB]GAL   #*V5 [F:DEPS]GRUGAL
    Gosub CONV_DEVISE
   [F:DEPC]BSEVAL     = WDMONT2
   [F:DEPC]DPRBAS     = WDMONT2
Endif
##-----------------------------------------------------------------------------------------##
##  Date début exercice, Date début période                                                ##
##-----------------------------------------------------------------------------------------##
[F:DEPC]FIYSTRDAT  = WDDATE(1)
[F:DEPC]PERSTRDAT  = WDDATE(3)
[F:DEPC]DEPSTA     = GVML_SCNOCAL
[F:DEPC]FCY        = WSITECIBLE #FQ-67465
If [F:FASC]ISSDAT <> [0/0/0]
  [F:DEPC]FLGUPDISS = G_OUI #Fq-70292
Endif
##-----------------------------------------------------------------------------------------##
## Ecriture de l'enregistrement DEP                                                        ##
##-----------------------------------------------------------------------------------------##
#
#*FQ101833 Alimentation des PERREFCLC*
If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLC <> [F:DEPC]PERSTRDAT )
    If ( [F:DEPC]PERCLOCUM <> 0 and [F:DEPC]DPM = G_DPMRE )
  [F:DEPC]PERREFCLC  = [F:DEPC]PERSTRDAT
Else
  [F:DEPC]PERREFCLC  = [F:DEPC]FIYSTRDAT
   Endif
Endif

If ([F:DEPC]PERREFCLCT <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLCT <> [F:DEPC]PERSTRDAT )
    If ( [F:DEPC]PERCLOCUMT <> 0 and [F:DEPC]DPMT = G_DPMRE )
        [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT
    Else
  [F:DEPC]PERREFCLCT = [F:DEPC]FIYSTRDAT
   Endif
Endif

If ( [F:DEPC]PERREFCLCI <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLCI <> [F:DEPC]PERSTRDAT )
    If ( [F:DEPC]PERCLOCUMI <> 0 and [F:DEPC]DPMI = G_DPMRE )
        [F:DEPC]PERREFCLCI = [F:DEPC]PERSTRDAT
    Else
        [F:DEPC]PERREFCLCI = [F:DEPC]FIYSTRDAT
   Endif
Endif
#*FQ101833 END

 [F:DEPC]LSTCLODAT =[0/0/0] #FQ106349

If WIDEPCEXIST = G_OUI
   Rewrite [F:DEPC]
Else
   Write [F:DEPC]
Endif
If (fstat)
     GOK = 0 : Call FSTA("DEPC") From GLOCK
     Return
Endif

Return
####################################################################################################
## $EDIT_CR_BIENS_CREES : Edition dans le compte-rendu des biens créés                            ##
####################################################################################################
$EDIT_CR_BIENS_CREES
Local Integer WINBCREESOC
Local Integer WINBCREETOT
Local Integer WINBCREESOCP
Local Integer WINBCREETOTP
Local Char    WCSOCSOURCE
Local Char    WCSOCCIBLE

WINBCREESOC  = 0
WINBCREETOT  = 0
WINBCREESOCP = 0
WINBCREETOTP = 0

##------------------------------------------------------------------------------------------------##
## Edition de la liste des biens crees                                                            ##
##------------------------------------------------------------------------------------------------##
Filter[F:FASC] Where [F:FASC]CIGCOD =  [M:CII]CIGCOD Order By CPY Asc; GRUORICPY Asc;[F:FASC]AASREF Asc
WCSOCSOURCE  = ""
WCSOCCIBLE   = ""
For [F:FASC]
     ##------------------------------------------------------------------------------------------------##
     ## A rupture societe : Edition du nombre de Biens créés                                           ##
     ##------------------------------------------------------------------------------------------------##
     If (WCSOCSOURCE <>  [F:FASC]GRUORICPY and WCSOCSOURCE  <> "" ) or (WCSOCCIBLE <>  [F:FASC]CPY and WCSOCCIBLE  <> "")
         WCLIGNE = format$("Kb:26X",WCSOCSOURCE)   +  format$("Kb:23X",WCSOCCIBLE )  +  format$("Kb:9X","")
&                + num$(WINBCREESOC)
&                + mid$('                    ',1,18-len(num$(WINBCREESOC))) + num$(WINBCREESOCP)
         Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
         WINBCREETOT  +=  WINBCREESOC
         WINBCREETOTP +=  WINBCREESOCP
         WINBCREESOC   = 0
         WINBCREESOCP  = 0
     Endif
     WCSOCSOURCE  = [F:FASC]GRUORICPY
     WCSOCCIBLE   = [F:FASC]CPY
     WINBCREESOC += 1

     # Dénombrement des élts phy rattachés au bien
     If GPHY = G_OUI   #Fq-63483
        Filter [F:PHYC] Where [F:PHYC]AASREF=[F:FASC]AASREF
        WINBCREESOCP += rowcount([PHYC])
        Filter [F:PHYC]
      Endif   #Fq-63483

     ##------------------------------------------------------------------------------------------------##
     ## LISTE BIENS CREES : Edition de chaque bien créé  si la recodification s'est bien passée        ##
     ##------------------------------------------------------------------------------------------------##
     If WIRETOUROK = G_OUI and [M:CII]EDIFAS= G_OUI and GEDIFAS=G_OUI
         WCLIGNE= [F:FASC]CPY + format$("KB:4X", "")  +  format$("KB:21X", [F:FASC]AASREF)
&                             + format$("KB:20X", [F:FASC]AASDES1)  + '  '
&                             + format$("KB:15X",  format$("DD2",[F:FASC]PURDAT))
&                             + format$("KB:17X", num$([F:FASC]ACGETRNOT))
&                             + format$("KB:22X",[F:FASC]GRUORICPY+ ' ' + [F:FASC]GRUORIAAS)
         Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
         ##------------------------------------------------------------------------------------------------##
         ## Edition des plans créés pour le bien traité                                                    ##
         ##------------------------------------------------------------------------------------------------##
         #Fq-94220b Gosub CREATION_EVT_IMMOBILISATION
      Endif
Next
##------------------------------------------------------------------------------------------------##
## Edition du nombre de Biens créés pour la derniere societé traitée                              ##
##------------------------------------------------------------------------------------------------##
WCLIGNE = format$("Kb:26X",WCSOCSOURCE)   +  format$("Kb:23X",WCSOCCIBLE)  +  format$("Kb:9X","") +  num$(WINBCREESOC)
&       + mid$('                    ',1,18-len(num$(WINBCREESOC))) + num$(WINBCREESOCP)
Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
WINBCREETOT +=  WINBCREESOC : WINBCREETOTP +=  WINBCREESOCP
WINBCREESOC = 0             : WINBCREESOCP  = 0
GEDIFAS=G_NON
Filter[F:FASC]
   ##------------------------------------------------------------------------------------------------##
   ## - Edition des compteurs  de biens toutes sociétés                                              ##
   ##------------------------------------------------------------------------------------------------##
   WCLIGNE=  format$("Kb:58X","")   + format$("Kb:30X",'------------------------------')
   Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
   # 35--> Total Général
   WCLIGNE = format$("Kb:4X","") + format$("KB:16X",mess(35,GML_MSGCIG,1))     +  format$("Kb:38X","") +  num$(WINBCREETOT )
&          + mid$('                    ',1,18-len(num$(WINBCREETOT))) + num$(WINBCREETOTP)
   Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3

   If WIERREUTROUV = G_OUI
       WCLIGNE =  ""  :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
       # 96--> AUCUNE MISE A JOUR N'A ETE REALISEE SUR LES SOCIETES SOURCES ET LES
       # 97--> SOCIETES CIBLES CAR DES ERREURS SONT INTERVENUES
       WCLIGNE =  format$("Kb:15X","") + mess(96,GML_MSGCIG,1)
       Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
       WCLIGNE =  format$("Kb:15X","") + mess(97,GML_MSGCIG,1)
       Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
   Endif

Return
####################################################################################################
## $EDIT_CR_ELTPHY_CREES : Edition dans le compte-rendu des éléments physiques créés              ##
####################################################################################################
$EDIT_CR_ELTPHY_CREES
Local Integer WINBCREESOC
Local Integer WINBCREETOT
Local Char    WCSOCSOURCE
Local Char    WCSOCCIBLE

  WINBCREESOC = 0
  WINBCREETOT = 0

  ##------------------------------------------------------------------------------------------------##
  ## Edition de la liste des éléments physiques créés                                               ##
  ##------------------------------------------------------------------------------------------------##
  Filter [F:FASC] Where [F:FASC]CIGCOD =  [M:CII]CIGCOD Order By CPY Asc; GRUORICPY Asc;[F:FASC]AASREF Asc
  WCSOCSOURCE  = ""
  WCSOCCIBLE   = ""
  For [F:FASC]
    ##------------------------------------------------------------------------------------------------##
    ## A rupture societe : Edition du nombre d'Eléments créés                                         ##
    ##------------------------------------------------------------------------------------------------##
    If (WCSOCSOURCE <> [F:FASC]GRUORICPY and WCSOCSOURCE  <> "" ) or (WCSOCCIBLE <>  [F:FASC]CPY and WCSOCCIBLE  <> "")
      WCLIGNE = format$("Kb:26X",WCSOCSOURCE)   +  format$("Kb:23X",WCSOCCIBLE )  +  format$("Kb:9X","") +  num$(WINBCREESOC)
      Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
      WINBCREETOT +=  WINBCREESOC
      WINBCREESOC = 0
    Endif

    WCSOCSOURCE  = [F:FASC]GRUORICPY
    WCSOCCIBLE   = [F:FASC]CPY
    WINBCREESOC += 1

    ##------------------------------------------------------------------------------------------------##
    ## LISTE ELTS PHY CREES : Edition de chaque élt créé si la recodification s'est bien passée       ##
    ##------------------------------------------------------------------------------------------------##
    Filter [F:PHYC] Where [F:PHYC]AASREF=[F:FASC]AASREF
    For [F:PHYC]
      # 49517 (SYMEU) : 4ème ligne : 24X au lieu de 22X
      If WIRETOUROK = G_OUI and [M:CII]EDIFAS= G_OUI and GEDIFAS=G_OUI
        WCLIGNE= [F:PHYC]CPY + format$("KB:4X", "")  +  format$("KB:21X", [F:PHYC]PHYREF)
&                            + format$("KB:20X", [F:PHYC]PHYDES1)  + '  '
&                            + format$("KB:21X",  [F:FASC]AASREF)
&                            + format$("KB:24X",[F:FASC]GRUORICPY+ ' ' + [F:PHYC]GRUORIPHY)
&                            + format$("KB:22X",[F:FASC]GRUORICPY+ ' ' + [F:FASC]GRUORIAAS)
        Call ECR_TRACE_FIC("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
      Endif
    Next
    Filter [F:PHYC]
  Next

  ##------------------------------------------------------------------------------------------------##
  ## Edition du nombre d'Eléments créés pour la derniere societé traitée                            ##
  ##------------------------------------------------------------------------------------------------##
  WCLIGNE = format$("Kb:26X",WCSOCSOURCE)   +  format$("Kb:23X",WCSOCCIBLE)  +  format$("Kb:9X","") +  num$(WINBCREESOC)     :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
  WINBCREETOT +=  WINBCREESOC
  WINBCREESOC = 0
  GEDIFAS=G_NON
  Filter[F:FASC]

  ##------------------------------------------------------------------------------------------------##
  ## - Edition des compteurs d'éléments toutes sociétés                                             ##
  ##------------------------------------------------------------------------------------------------##
  WCLIGNE=  format$("Kb:58X","")   + format$("Kb:10X",'-------')
  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
  # 35--> Total Général
  WCLIGNE = format$("Kb:4X","") + format$("KB:16X",mess(35,GML_MSGCIG,1))     +  format$("Kb:38X","") +  num$(WINBCREETOT )
  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3

  If WIERREUTROUV = G_OUI
    # 96--> AUCUNE MISE A JOUR N'A ETE REALISEE SUR LES SOCIETES SOURCES ET LES
    # 97--> SOCIETES CIBLES CAR DES ERREURS SONT INTERVENUES
    WCLIGNE =  ""  :  Call ECR_TRACE_FIC("",GTRC_CRLST2,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE =  format$("Kb:15X","") + mess(96,GML_MSGCIG,1)
    Call ECR_TRACE_FIC("",GTRC_CRACT1,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE =  format$("Kb:15X","") + mess(97,GML_MSGCIG,1)
     Call ECR_TRACE_FIC("",GTRC_CRACT1,WCLIGNE,0,1) From TRACEABX3
  Endif
Return
####################################################################################################
## $TRAIT_UN_CIB : Traitement d'une ligne de la table CIB                                         ##
####################################################################################################
$TRAIT_UN_CIB

Local Decimal WDMTSORTIE

Read [F:FASS]FAS1 = [F:CIB]CPYSRC; [F:CIB]AASREF
If [S]fstat = 0
    Gosub CTRL_CCE_COMPL
    ##--------------------------------------------------------------------------------------------##
    ## on traite en 1er la soc cible car, si l'enregistrement source était déjà sortie            ##
    ## (après la date d'effet), on modifie la date et montant de sortie dans l'enregistrement     ##
    ## source, alors que ces 2 valeurs doivent etre conservées dans l'enr cible                   ##
    ##--------------------------------------------------------------------------------------------##
    If WITRTOK=G_OUI
      Gosub TRAIT_UN_CIB_SOC_DES
    Endif
    If WITRTOK=G_OUI
      Gosub TRAIT_UN_CIB_SOC_SRC
    Endif
Else
   # 84--> : Bien non trouvé
    WCLIGNE= [F:CIB]CPYSRC + format$("KB:4X", "")  +  format$("KB:20X", [F:CIB]AASREF)   + "  : " + format$("KB:16X",mess(84,GML_MSGCIG,1))
    Call ECR_TRACE_FIC ("",GTRC_CRACT2,WCLIGNE,0,1) From TRACEABX3
Endif

Return
####################################################################################################
## $TRAIT_UN_CIB_SOC_DES : Traitement d'une ligne de la table CIB pour la société cible           ##
####################################################################################################
$TRAIT_UN_CIB_SOC_DES

##--------------------------------------------------------------------------------------------##
## Gestion de la table FAS                                                                    ##
##--------------------------------------------------------------------------------------------##
Gosub TRF_FAS_VAL_DIV
If GOK=0 : WITRTOK=G_NON :  Return : Endif  #*Fq-86480
##--------------------------------------------------------------------------------------------##
## Si GVML_ETATSAA (BIEN A ANNULER) --> le bien est reconduit tel que dans la société cible   ##
##--------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT  <> GVML_ETATSAA
   Gosub TRF_FAS_VAL_ONGLET_AUTRES_REGLES
Endif
##--------------------------------------------------------------------------------------------##
## Gestion des contrats de location financement                                               ##
##--------------------------------------------------------------------------------------------##
If G_ACTLEA = G_OUI
  If [F:FASC]LEAREF <> ""
     Gosub TRT_CONTRAT_LOCFI
  Endif
Endif
##--------------------------------------------------------------------------------------------##
## Report des éventuelles dépenses associées au bien annulé                                     ##
##--------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT  = GVML_ETATSAA
   Gosub TRT_DEPENSE
Endif
################################################
#  Point d'entrée                              #
# Modifications spécifiques sur                #
# l'enregistrement FASC                       #
################################################
GOK=1
GPOINT = "MAJFASC" : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif
#### Point d'entrée - Fin ######################
# ------------------- Write FAS dans la nouvelle société ---------------#
If [F:FASC]AASREF = ""  or [F:FASC]FCY = "" :  GOK = 0 : Call FSTA("FASC") From GLOCK : Return : Endif
[F:FASC]FLGCLC   = G_OUI
 Filter [CNX] Where CPY= [F:FASC]CPY
 For [CNX]
  [F:FASC]FLGCNXCLC([F:CNX]CNX-1)     = G_OUI
 Next
 Filter [CNX]

 If GOK<1  :   Return  :  Endif

 # Issue 109371 [F:FASC]GRUISSREF = [F:CIG]CIGCOD #FQ-69647
 # Issue 109371 [F:FASC]GRUEFFDAT = [F:CIG]EFFDAT #FQ-69647
 [F:FASC]GRUISSREF = [M:CII]CIGCOD
 [F:FASC]GRUEFFDAT = [M:CII]EFFDAT

  Write [F:FASC]
  If (fstat)
       GOK = 0 : Call FSTA("FASC") From GLOCK
       Return
  Endif
##--------------------------------------------------------------------------------------------##
## Gestion de la table DEP                                                                    ##
##--------------------------------------------------------------------------------------------##
Gosub CREATION_AMORTISSEMENTS_DES

If GPHY = G_OUI   #Fq-63483
   Gosub CREATION_ELTPHY_DES
Endif

Return
####################################################################################################
## $TRT_DEPENSE  : Report des éventuels dépenses associées au bien annulé                         ##
####################################################################################################
$TRT_DEPENSE

##--------------------------------------------------------------------------------------------##
##  On annule la dépense de la société d'origine et la recréé dans la nouvelle société        ##
##  On lui affecte les nouveaux numéro de biens comptables                                    ##
##--------------------------------------------------------------------------------------------##
Filter[F:LOF] Where [F:LOF]AASREF =  [F:FASC]GRUORIAAS
For [F:LOF]
        [F:LOF]CPY       = [F:FASC]CPY
        #[F:LOF]FCY       = [F:FASC]FCY
        [F:LOF]AASREF    = [F:FASC]AASREF
#        [F:LOF]LOC       = ""  FQ100398/13
        [F:LOF]CREORI    = GVML_COCESIG
        Rewrite [F:LOF]
        If (fstat)
             GOK = 0 : Call FSTA("LOF") From GLOCK
             Break
        Endif
Next
Filter[F:LOF]

Return
####################################################################################################
## $TRT_CONTRAT_LOCFI  : Gestion des contrats de location financement                             ##
####################################################################################################
$TRT_CONTRAT_LOCFI

Local Char WLEAREFN # Issue 117229
##--------------------------------------------------------------------------------------------##
## Test afin de voir s'il y a un contrat location financement ayant dans référence d'origine  ##
## (LEAREFORI) la valeur trouvé dans le bien :                                                ##
##    - Si oui : On met la nouvelle référence sur le bien                                     ##
##    - Si non : On passe l'ancienne référence dans la table LEASE au statut 'cédé'           ##
##               On créé une nouvelle référence dans la table LEASE                           ##
##               On met la nouvelle référence LEASE sur le bien                               ##
##--------------------------------------------------------------------------------------------##
Read [F:LEA]LEA3 = [F:FASC]LEAREF
If fstat = 0
    [F:FASC]LEAREF = [F:LEA]LEAREF
Else
    # On passe l'ancienne référence dans la table LEASE au statut 'cédé'
    Read [F:LEA]LEA0 = [F:FASC]LEAREF
    If fstat = 0
        [F:LEA2] = [F:LEA]
        [F:LEA]LEASTA = GVML_STCEDE
        Rewrite [F:LEA]
        If (fstat)
             GOK = 0 : Call FSTA("LEA") From GLOCK
             Return
        Endif
    Endif

    # Alimentation de la Numérotation automatique du bien
    If GLEAAUTNUM = 2 or GLEAAUTNUM = 3
      # Appel du compteur de document FQ85464
      Call GET_NUMERO("LEA",GVML_NUMLEA-1,1,[F:FASC]CPY,[F:FASC]FCY,date$,WCNUMERO,STAT) From GLOBIENS
      If ( STAT )   : GOK = 0 : Return : Endif
        #[F:LEA2]FCY      = [F:FASC]FCY
        [F:LEA2]CPY       = [F:FASC]CPY
        [F:LEA2]LEAREFORI = [F:LEA2]LEAREF
        [F:LEA2]CIGCOD    = [M:CII]CIGCOD
        # Issue 117229  control that there is no blank(s) in the middle of the counter
        If WCNUMERO <> "" and !(pat(WCNUMERO, "* *"))
        [F:LEA2]LEAREF    = WCNUMERO
        Else
          #**Si problème de numérotation auto : affectation d'une référence par défaut au nouveau CLF
          #** société cible + ancienne référence du contrat
          WLEAREFN = sum(num$([F:FASC]CPY), num$([F:LEA2]LEAREF))
          [F:LEA2]LEAREF = WLEAREFN
        Endif
        [F:LEA2]LEASTA    = GVML_STENCOU
        [F:LEA2]CREORI    = GVML_COCESIG
        [F:LEA2]CREDAT    = date$
        Write [F:LEA2]
        If (fstat)
             GOK = 0 : Call FSTA("LEA2") From GLOCK
             Return
        Endif
        [F:FASC]LEAREF    = WCNUMERO
      Endif
Endif

#*L'échéancier est transféré sur le nouveau contrat
Filter [LBB] Where LEAREF =  [F:FASS]LEAREF
 For  [LBB]
   [F:LBBC] = [F:LBB]
   [F:LBBC]CPY        = [F:FASC]CPY
   #[F:LBBC]FCY        = [F:FASC]FCY
   [F:LBBC]LEAREF     = [F:FASC]LEAREF
    Write [F:LBBC]
    If (fstat)
         GOK = 0 : Call FSTA("LBBC") From GLOCK
         Break
    Endif
  Next
Filter [LBB]

Return
####################################################################################################
## $TRF_FAS_VAL_DIV : Transfert des valeurs de la société source vers la société cible            ##
####################################################################################################
$TRF_FAS_VAL_DIV
Local Char    WCNUMERO
Local Char    WCDEV1
Local Char    WCDEV2
Local Char    WCDEVCC
Local Char    WCDEVIC
Local Char    WCDEVCS
Local Char    WCDEVIS
Local Char    WSITECIBLE
Local Decimal WDMONT1
Local Decimal WDMONT2
Local Decimal WCRATIO
Local Integer WICONTEXTE
Local Char    WAASREFN

[F:FASC]         = [F:FASS]

#* Si bien annulé dans société Source ==> bien repris à l'identique dans société Cible
If [F:CIB]ISSSAT  <> GVML_ETATSAA
  #* Pas de TVA pour les biens acquis par Cession intra-groupe
  # Zones réinitialisées : cadre budgétaire
  [F:FASC]BUDFIY  = 0
#FQ-93493 On garde les valeurs du bien d'origine qui seront éventuellement recodifiées ensuite (recodif. Types données ADI)
#FQ-93493 [F:FASC]INVTYP  = ""
  [F:FASC]INVPLN  = ""
#FQ-93493 [F:FASC]BUDREF  = ""
#FQ-93493 [F:FASC]INVREQ  = ""
  [F:FASC]CONNUM  = ""
  [F:FASC]ORDREF  = ""
  [F:FASC]ORDLIG  = 0
  # Zones réinitialisées : regul tva
  [F:FASC]VATREGAMT = 0
  [F:FASC]VATREGCUM = 0
  [F:FASC]IASVATREG = 0
  [F:FASC]IASREGCUM = 0
  # Zones réinitialisées : dernier transfert ana./geo
  [F:FASC]TRFDAT = [0/0/0]
  [F:FASC]CREORI = GVML_COCESIG
  [F:FASC]CREDAT = date$
Endif

WCDEVCS = ""
WCDEVCC = ""

Call GET_CNX_FROM_PLAN([F:CIR]CPYSRC,G301CPT,WICONTEXTE) From GLOBIENS

If WICONTEXTE > 0
    # Récupération de la devise comptable source
    Read [F:CNX]CNX0=[F:CIR]CPYSRC;WICONTEXTE
    If fstat = 0
         WCDEVCS = [F:CNX]CUR
    Else
         WCDEVCS = GEURO
    Endif

    # Récupération de la devise comptable cible
    Read [F:CNX]CNX0=[F:CIR]CPYDES;WICONTEXTE
    If fstat = 0
         WCDEVCC = [F:CNX]CUR
    Else
         WCDEVCC = GEURO
    Endif

Else
    WCDEVCS = GEURO
    WCDEVCC = GEURO
Endif


WCDEVIS = ""
WCDEVIC = ""
Call GET_CNX_FROM_PLAN([F:CIR]CPYSRC,G301IAS,WICONTEXTE) From GLOBIENS

If WICONTEXTE > 0

    # Récupération de la devise IAS source
    Read [F:CNX]CNX0=[F:CIR]CPYSRC;WICONTEXTE
    If fstat = 0
         WCDEVIS = [F:CNX]CUR
    Else
         WCDEVIS = GEURO
    Endif

    # Récupération de la devise IAS cible
    Read [F:CNX]CNX0=[F:CIR]CPYDES;WICONTEXTE
    If fstat = 0
         WCDEVIC = [F:CNX]CUR
    Else
         WCDEVIC = GEURO
    Endif

Else
    WCDEVIS = GEURO
    WCDEVIC = GEURO
Endif

# Alimentation de la Société
[F:FASC]CPY  = [F:CIR]CPYDES

Link [F:CDC] With [F:CDF]CDF0=REFCDF As [LCDC] Where ([F:CDF]REFTRFCMP = [M:CII]CIGCOD)
&                                                and ([F:CDF]PROSTA    = GVML_RECATRC)
&                                                and ([F:CDF]TABNAM    = "FCY")

Filter [F:LCDC] Where VALOLDCOD = [F:FASS]FCY
Read [LCDC] First : # Une seule ligne possible
Filter [F:LCDC]
If !fstat
  #<<<<Fq-86480
  Read [F:FCY]FCY0 = [F:CDC]VALNEWCOD
  If [S]fstat = 0
     If [F:FCY]LEGCPY <> [F:CDF]CPYDES
        #-354--> Site financier incompatible avec la société du bien
        GMESSAGE = num$([F:CDC]VALNEWCOD)-" "-mess (354,GML_MSGFAS,1)-" "- num$([F:CDF]CPYDES)
        GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,GMESSAGE,1,1) From TRACEABX3
        GOK = 0
        Return
     Endif
  Else
     #-85-86--> Site inexistant
     GMESSAGE = num$([F:CDC]VALNEWCOD)- " : "-mess(36,GML_MSGREC,1)
     GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,GMESSAGE,1,1) From TRACEABX3
     GOK = 0
     Return
  Endif  #>>>>Fq-86480
  WSITECIBLE     = [F:CDC]VALNEWCOD
  [F:FASC]FCY    = [F:CDC]VALNEWCOD
Endif
# FIN FQ90270

 ##################################################
 #  Point d'entrée  (FQ-66672)                    #
 # Modifications spécifiques sur l'enregistrement #
 # de la table temporaire [CIB]                   #
 ##################################################
 GOK=1
 GPOINT = "MAJCIB" : Gosub ENTREE From EXEFNC
 If GOK<1 : Return : Endif
 #### Point d'entrée - Fin ######################

# Alimentation de la Numérotation automatique du bien
If ( GAASAUTNUM = GVML_OBLIG or GAASAUTNUM = GVML_FACUL )
   Local Integer STAT
   # Appel du compteur de document FQ85464
   Call GET_NUMERO("FAS",GVML_NUMAAS-1,1,[F:FASC]CPY,WSITECIBLE,date$,WCNUMERO,STAT)  From GLOBIENS
   If ( STAT )   : GOK = 0 : Return : Endif
   # Issue 117229 if  WCNUMERO <> "" control taht thereis no blank(s) in the middle of the counter
   If WCNUMERO <> "" and !(pat(WCNUMERO, "* *"))
     [F:FASC]AASREF   = WCNUMERO
   Else
      #**Si problème de numérotation auto : affectation d'une référence par défaut au nouveau bien
      #** société cible + ancienne référence du bien
      WAASREFN = sum(num$([F:FASC]CPY), num$([F:FASS]AASREF))
     [F:FASC]AASREF = WAASREFN
   Endif
   [F:CIB]AASREFNEW = [F:FASC]AASREF
   Rewrite [F:CIB]
   If (fstat)
         GOK = 0 : Call FSTA("CIB") From GLOCK
         Return
   Endif
Endif

##-------------------------------------------------------------------------------------------------##
## Alimentation du N° Bien principal: - Les enreg CIB sont triés par N° Bien principal puis par    ##
## les biens dont le N° Bien principal= n° du bien sont traité en 1er                              ##
##-------------------------------------------------------------------------------------------------##
## Si ds table temporaire, N°Bien princ diff n° bien traité --> recherche  de la nouvelle          ##
## référence du bien principale ds table temporaire                                                ##
##-------------------------------------------------------------------------------------------------##
If [F:CIB]CMP <> "" and  [F:CIB]CMP <> [F:CIB]AASREF
    Read [F:CIBP]CIB0 = [F:CIB]CIGCOD; [F:CIR]CPYSRC; [F:CIB]REFSELCIG; [F:CIB]CMP
    If [S]fstat = 0
      [F:FASC]CMP = [F:CIBP]AASREFNEW
    Endif
Endif

##-------------------------------------------------------------------------------------------------##
## N° ensemble : - Les enregistrements CIB sont triés par N° ensemble                              ##
##-------------------------------------------------------------------------------------------------##
## Si dans bien source, N° ensemble = n° bien --> Dans bien cible : n° ensemble = Nouveau n° bien  ##
## Si dans bien source, N° ensemble diff n° bien --> recherche du bien de la société cible ayant   ##
## comme ancienne référence, la valeur n° d'ensemble du bien source --> lorque que le bien est     ##
## trouvé, sa référence est mis dans le n° d'ensemle du bien cible                                 ##
##-------------------------------------------------------------------------------------------------##

#**Pour un bien acquis par une opération de CIG, il faut systématiquement lui mettre comme
#**N° d'ensemble sa référence.

[F:FASC]SET = [F:FASC]AASREF
#------------------------------------------------------------------------------------------------ ##
# Alimentation de la  Date achat/mise en service : Table 333                                      ##
#--------- GML_DATEEFF= 1 Date effet    ou  GML_RECONDA=2 Reconduction date ----------------------##
#------------------------------------------------------------------------------------------------ ##
# Si "Etat sortie CIG" = Bien sorti a modifier ou bien a sortir
If [F:CIB]ISSSAT    = GVML_ETATSSM or [F:CIB]ISSSAT    = GVML_ETATSAS
    # Issue 109371 [F:FASC]AASIPTDAT   = [F:CIG]EFFDAT       # Date comptabilisation (ou imputation)
    [F:FASC]AASIPTDAT   = [M:CII]EFFDAT       # Date comptabilisation (ou imputation)
    If ([F:CIR]PURITSDAT = GML_DATEEFF)  and ([F:FASS]PURDAT < [F:CIG]EFFDAT)
        # Issue 109371 F:FASC]PURDAT      = [F:CIG]EFFDAT       # Date achat bien
        # Issue 109371 [F:FASC]ITSDAT     = [F:CIG]EFFDAT       # Date mise en service
        [F:FASC]PURDAT      = [M:CII]EFFDAT       # Date achat bien
        [F:FASC]ITSDAT      = [M:CII]EFFDAT       # Date mise en service
    Elsif ([F:CIR]PURITSDAT = GML_RECONDA) or ([F:FASS]PURDAT >=  [F:CIG]EFFDAT)
        [F:FASC]PURDAT      = [F:FASS]PURDAT      # Date achat bien
        [F:FASC]ITSDAT      = [F:FASS]ITSDAT      # Date mise en service
    Endif
Endif
##-------------------------------------------------------------------------------------------------##
## Alimentation de la  Valeur entrée HT PCG :                                                      ##
##        - Valeur entrée HT PCG, TVA facturée, TVA récupérée                                      ##
##-------------------------------------------------------------------------------------------------##
# Si "Etat sortie CIG" = Bien sorti a modifier ou bien a sortir
If [F:CIB]ISSSAT    = GVML_ETATSSM or [F:CIB]ISSSAT  = GVML_ETATSAS

  If [F:CIR]RULPRO(WIPLANCOMPT) = GML_VBPRICES         : # Valeur brute = prix de cession
      #** Si nature PCG <> charge
      If [F:FASS]GACACN <>  GVML_NICHARG
          If [F:CIB]ISSAMTUPD <> 0
              [F:FASC]ACGETRNOT = [F:CIB]ISSAMTUPD
          Else
              [F:FASC]ACGETRNOT = [F:CIB]ISSAMT
          Endif
      Else
          #** Si nature PCG = charge
          [F:FASC]ACGETRNOT = 0
      Endif
   Elsif [F:CIR]RULPRO(WIPLANCOMPT) = GML_VBVANPLM         : # Valeur brute = valeur nette plan modèle
        ##--------------------------------------------------------------------------------------------##
        ## Calcule la valeur nette à la date de sortie                                                ##
        ##--------------------------------------------------------------------------------------------##
        #** Si nature PCG <> charge
        If [F:FASS]GACACN <>  GVML_NICHARG
               [F:FASC]ACGETRNOT  =  [F:CIB]NVA
        Else
          #** Si nature PCG = charge
          [F:FASC]ACGETRNOT = 0
        Endif
    Endif

    #*Fq-46680 ----------- TVA facturée PCG = Montant achat HT * ( Taux TVA facturée / 100 ) ------------#
    #*Fq-46680 [F:FASC]IVCVATAMT = [F:FASC]ACGETRNOT * ([F:FASC]IVCVATRAT / 100 )
    # ----------- TVA facturée PCG = TVA transféré calculée ------------#
    [F:FASC]IVCVATAMT = [F:CIB]IVCVATAMT
    Call GET_MNT_ARRONDI ([F:FASC]IVCVATAMT, [F:FASC]ACGCUR, [F:FASC]IVCVATAMT ) From GLOBIENS
    [F:FASC]IVCVATRAT = [F:CIB]IVCVATRAT

    #*Fq-46680 ----------- TVA récupérée = TVA facturée * ( Taux TVA récupérée / 100 ) ------------------#
    #*Fq-46680 [F:FASC]DEDVATAMT = [F:FASC]IVCVATAMT * ([F:FASC]DEDVATRAT / 100 )
    # ----------- TVA récupérée PCG = TVA récupérée recalculée ------------#
    [F:FASC]DEDVATAMT   = [F:CIB]DEDVATAMT
    Call GET_MNT_ARRONDI ([F:FASC]DEDVATAMT, [F:FASC]ACGCUR, [F:FASC]DEDVATAMT) From GLOBIENS
    [F:FASC]DEDVATRAT   = [F:CIB]DEDVATRAT
Else
    # Si "Etat sortie CIG = Bien a annuler --> reconduit dans societe cible
    #la base d'origine est conservé
Endif

##-------------------------------------------------------------------------------------------------##
## Alimentation si le plan IAS est géré : Valeur entrée HT IAS, TVA facturée, TVA récupérée,       ##
##                                        devise , type de cours , cours devise , nature et compte ##
##-------------------------------------------------------------------------------------------------##
WCRATIO  = 1

If func GLOBIENS.CPY_PLN_GERE([F:FASC]CPY, G301IAS )=G_OUI

    #----- Lecture contexte IAS
    Read [CNX] CNX0=[F:FASC]CPY;G300IAS

    If func GLOBIENS.CPY_PLN_GERE([F:FASS]CPY, G301IAS )=G_OUI
        # Si "Etat sortie CIG" = Bien sorti a modifier ou bien a sortir
        If [F:CIB]ISSSAT    = GVML_ETATSSM or [F:CIB]ISSSAT  = GVML_ETATSAS

            If [F:CIR]RULPRO(WIPLANIAS) = GML_VBPRICES       : # Valeur brute = prix de cession
                #**Si nature PCG <> charge
                If [F:FASS]IASACN <>  GVML_NICHARG
                    If [F:CIB]ISSAMTUPD <> 0
                        [F:FASC]IASETRNOT = [F:CIB]ISSAMTUPD
                    Else
                        [F:FASC]IASETRNOT = [F:CIB]ISSAMT
                    Endif
                Else
                    #**Si nature PCG = charge
                    [F:FASC]IASETRNOT = 0
                Endif
            Elsif [F:CIR]RULPRO(WIPLANIAS) = GML_VBVANPLM         : # Valeur brute = valeur nette plan modèle
               ##--------------------------------------------------------------------------------------------##
               #**Si nature IAS <> charge
               If [F:FASS]IASACN <>  GVML_NICHARG
                  [F:FASC]IASETRNOT  =  [F:CIB]NVA
               Else
                  #**Si nature IAS = charge
                  [F:FASC]IASETRNOT  = 0
               Endif
            Endif
         Endif
         If [F:CNX]CUR <> WCDEVCS
           If [F:FASS]IASETRNOT = 0
               WDMONT1 =   [F:FASC]ACGETRNOT
           Else
               WDMONT1 =   [F:FASC]IASETRNOT
           Endif
           WCDEV1  =   WCDEVCS
           WCDEV2  =   [F:CNX]CUR
           Gosub CONV_DEVISE
           [F:FASC]IASETRNOT  = WDMONT2
           If  WDMONT1 <> 0
               WCRATIO  = WDMONT2 / WDMONT1
           Endif
           [F:FASC]IASCURTYP  = [F:CNX]CURTYP
           [F:FASC]IASRATCUR  = WCOURS
         Endif
  Else     # plan IAS non géré dans la société source
        Local Char    LIASACC
        Local Integer LIASACN
        Local Char    LGAC
        Local Integer LGACACN
        [F:FASC]IASCUR     = [F:CNX]CUR
        [F:FASC]IASCURTYP  = [F:CNX]CURTYP
        Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, [F:FASC]ACCCOD, GGACIMMO, GIASIMMO, LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
        [F:FASC]IASACN     = LIASACN
        [F:FASC]IASACC     = LIASACC
        WDMONT1 = [F:FASC]ACGETRNOT
        WCDEV1  =   WCDEVCS
        WCDEV2  =   [F:CNX]CUR
        Gosub CONV_DEVISE
        [F:FASC]IASETRNOT  = WDMONT2
        If  WDMONT1 <> 0
            WCRATIO  = WDMONT2 / WDMONT1
        Endif
        [F:FASC]IASRATCUR  = WCRATIO
    Endif
    #*Fq-46680 ----------- TVA facturée IAS/IFRS = Montant achat HT * ( Taux TVA facturée / 100 ) ------------#
    #*Fq-46680 [F:FASC]IVCVATAMTI = [F:FASC]IASETRNOT * ([F:FASC]IVCVATRATI / 100 )
    # ----------- TVA facturée IAS/IFRS = TVA transféré calculée ------------#
    [F:FASC]IVCVATAMTI = [F:CIB]IVCVATAMTI
    Call GET_MNT_ARRONDI ([F:FASC]IVCVATAMTI, [F:FASC]IASCUR, [F:FASC]IVCVATAMTI ) From GLOBIENS
    [F:FASC]IVCVATRATI = [F:CIB]IVCVATRATI

    #*Fq-46680 ----------- TVA récupérée = TVA facturée * ( Taux TVA récupérée / 100 ) ------------------#
    #*Fq-46680 [F:FASC]DEDVATAMTI = [F:FASC]IVCVATAMTI * ([F:FASC]DEDVATRATI / 100 )
    # ----------- TVA récupérée IAS/IFRS = TVA récupérée recalculée ------------#
    [F:FASC]DEDVATAMTI = [F:CIB]DEDVATAMTI
    Call GET_MNT_ARRONDI ([F:FASC]DEDVATAMTI, [F:FASC]IASCUR, [F:FASC]DEDVATAMTI) From GLOBIENS
    [F:FASC]DEDVATRATI = [F:CIB]DEDVATRATI

Else     # Plan IAS non géré dans la société cible
    [F:FASC]IASETRNOT  = 0
    [F:FASC]IVCVATAMTI = 0
    [F:FASC]DEDVATAMTI = 0
    [F:FASC]IASCUR     = ""
    [F:FASC]IASCURTYP  = 0
    [F:FASC]IASRATCUR  = 0
    [F:FASC]IASACN     = 0
    [F:FASC]IASACC     = ""

Endif

# Alimentation des Valeurs concernant la CIG
[F:FASC]CIGCOD    = [M:CII]CIGCOD          # Référence CIG
[F:FASC]GRUORICPY = [F:CIR]CPYSRC          # Société origine CIG
[F:FASC]GRUORIAAS = [F:FASS]AASREF         # Bien origine CIG
[F:FASC]FISOPETYP = [F:CIG]CIGFIS          # Régime fiscal CIG
# Issue 109371[F:FASC]ISSOPETYP = [F:CIG]CIGTYP          # type opération CIG
[F:FASC]ISSOPETYP = [M:CII]CIGTYP          # type opération CIG
[F:FASC]AASORINBV = [F:CIB]NVA             # VNC bien origine CIG
[F:FASC]ORIPURDAT = [F:FASS]PURDAT         # Date achat bien CIG
[F:FASC]GRUTAXBAS = [F:FASS]TAXBAS         # Base taxe CIG

If  [F:FASS]ACGETRNOT =  0
    If WCDEVCS  = WCDEVCC
         [F:FASC]ORIPURAMT = [F:FASS]ACGETRNOT            # Val entrée HT PCG
    Else
        # Conversion
        WDMONT1           = [F:FASS]IASETRNOT             # Val entrée HT IFRS
        WCDEV1  = WCDEVCS
        WCDEV2  = WCDEVCC
        Gosub CONV_DEVISE
        [F:FASC]ORIPURAMT = WDMONT2
    Endif
Else
    [F:FASC]ORIPURAMT = [F:FASS]ACGETRNOT                 # Val entrée HT PCG
Endif

Return
###################################################################################################
## $CONV_DEVISE : Conversion d'un montant de la devise PCG vers un montant de la devise IAS      ##
###################################################################################################
$CONV_DEVISE
Local Integer WIRET
Local Integer WSPSTAT
Local Decimal WCOURS

# ------------- Conversion de devise
 Call CONVERT3(WCDEV1 , WCDEV2 , WCDEV2 , [F:FASC]IASCURTYP, [F:FASC]PURDAT, WDMONT1  , WDMONT2 ,0, WIRET) From CPTSUB
 Call COURDEV (WCDEV1,WCDEV2,[F:FASC]IASCURTYP,[F:FASC]PURDAT,WCOURS,WSPSTAT) From TRTDIV

If WIRET = 0
  Call GET_MNT_ARRONDI (WDMONT2, WCDEV2, WDMONT2 ) From GLOBIENS
Else
  WDMONT2 = WDMONT1
Endif

Return
####################################################################################################
## $TRF_FAS_VAL_ONGLET_AUTRES_REGLES : Transfert des valeurs suivant parametrage 'Autres règles'  ##
####################################################################################################
$TRF_FAS_VAL_ONGLET_AUTRES_REGLES

Local Decimal WM50
Local Decimal WM90
#------------------------------------------------------------------------------------------------ ##
#** Prise en compte nouvelles règles :
# Table 332       : "Base TP/TF"                                                                  ##
#-- GML_TPRECON=1 : Reconduction                                                                  ##
#-- GML_TPMAX90=2 : Max (Valeur Apport / 90% base taxe source)                                    ##
#-- GML_TP90BAS=3 : 90% base taxe source                                                          ##
#-- GML_TPMAX50=4 : Max (Valeur Apport / 90% base taxe source)                                    ##
#-- GML_TP50BAS=5 : 50% base taxe source                                                          ##
#-- GML_TPVALAP=6 : Valeur d'apport                                                               ##
#------------------------------------------------------------------------------------------------ ##
# Si type de détention différent de "En propriété" ou date d'achat <= date prise en compte règle base TP/TF
# la base de taxe sera systématiquement la valeur d'apport
If [F:FASS]OWNTYP <> GVML_TDPROPR or  [F:FASS]PURDAT > [F:CIR]RULTPFDAT
     [F:FASC]TAXBAS = [F:FASC]ACGETRNOT
Else

  Case  [F:CIR]TAXBASTPF

      When GML_TPRECON
          [F:FASC]TAXBAS = [F:FASS]TAXBAS

      When GML_TPMAX90
          If [F:FASS]TAXBAS = 0
             WM90  = 0
          Else
             WM90  = [F:FASS]TAXBAS * 90 / 100
          Endif
          If [F:FASC]ACGETRNOT > WM90
              [F:FASC]TAXBAS = [F:FASC]ACGETRNOT
          Else
              [F:FASC]TAXBAS = WM90
          Endif

      When  GML_TP90BAS
          If [F:FASS]TAXBAS = 0
              [F:FASC]TAXBAS = 0
          Else
              [F:FASC]TAXBAS = [F:FASS]TAXBAS * 90 / 100
          Endif

      When GML_TPMAX50
          If [F:FASS]TAXBAS = 0
               WM50  = 0
          Else
               WM50  = [F:FASS]TAXBAS * 50 / 100
          Endif
          If [F:FASC]ACGETRNOT > WM50
              [F:FASC]TAXBAS = [F:FASC]ACGETRNOT
          Else
              [F:FASC]TAXBAS = WM50
          Endif

      When  GML_TP50BAS
          If [F:FASS]TAXBAS = 0
              [F:FASC]TAXBAS = 0
          Else
              [F:FASC]TAXBAS = [F:FASS]TAXBAS * 50 / 100
          Endif

      When GML_TPVALAP
          [F:FASC]TAXBAS = [F:FASC]ACGETRNOT
    Endcase

Endif
#------------------------------------------------------------------------------------------------ ##
# Table 334       : "Etat à l'entrée du bien"                                                     ##
#--- GML_OCCASION=1: Occasion    ou GML_RECONETA=2:  Reconduction état précédent -----------------##
#------------------------------------------------------------------------------------------------ ##
If [F:CIR]PURNAT = GML_OCCASION
    [F:FASC]PURNAT= GVML_NAOCCAS
Elsif [F:CIR]PURNAT = GML_RECONETA
    [F:FASC]PURNAT= [F:FASS]PURNAT
Endif

#------------------------------------------------------------------------------------------------ ##
# Table 335       : "Base +/- value"                                                              ##
#--- GML_VASPVAAP=1 :Valeur apport    ou GML_VASPRECO=2 : Reconduction base précédente  ----------##
#------------------------------------------------------------------------------------------------ ##
If [F:CIR]BASGAL = GML_VASPVAAP
    [F:FASC]GALREFBAS= [F:FASC]ACGETRNOT
Elsif [F:CIR]BASGAL = GML_VASPRECO
    [F:FASC]GALREFBAS= [F:FASS]GALREFBAS
Endif

#------------------------------------------------------------------------------------------------ ##
# Table 357       : "Nature d'entrée"                                                             ##
#------------------------------------------------------------------------------------------------ ##
# Si "Etat sortie CIG" = Bien sorti a modifier ou bien a sortir
If [F:CIB]ISSSAT    = GVML_ETATSSM or [F:CIB]ISSSAT    = GVML_ETATSAS
    If [M:CII]CIGTYP  =  GVML_TOAPPOR         : # APPORT PARTIEL D'ACTIF
           [F:FASC]ETRNAT= GVML_NEAPPOR
    Elsif [M:CII]CIGTYP  =  GVML_TOFUSIO         : # FUSION
           [F:FASC]ETRNAT= GVML_NEFUSIO
    Elsif [M:CII]CIGTYP  =  GVML_TOSCISS         : # SCISSION
           [F:FASC]ETRNAT= GVML_NESCISS
    Elsif [M:CII]CIGTYP  =  GVML_TOVTEIG         : # VENTE INTRA-GROUPE
           [F:FASC]ETRNAT= GVML_NEVTEIG
    Endif
Else
   # Si "Etat sortie CIG = Bien a annuler --> reconduit à l'identique dans societe cible
   #la nature d'achat reste le nature d'achat d'origine
   [F:FASC]ETRNAT= [F:FASS]ETRNAT
Endif

Return
####################################################################################################
## $CREATION_EVT_IMMOBILISATION : Création de l'evenement d'immobilisation pour chaque plan       ##
####################################################################################################
$CREATION_EVT_IMMOBILISATION
Local Integer LCDRET
Local Char    LCDINT(10)

GIPLN   = 0

   [F:FASV] = [F:FAS]  #FQ94220
   [F:FAS]  = [F:FASC] #FQ94220 copie de [FASC] dans [FAS] pour la génération de l'événement
   ##---------------------------------------------------------------------------------------------##
   ## Lecture suivante du plan d'amortissement a creer dans la société cible                      ##
   ##---------------------------------------------------------------------------------------------##
   For GIPLN = 0 To [F:CIR]NBRPLN-1
      LCDINT= "FASCRT"+num$([F:CIR]DPRPLN(GIPLN))
      Call GENER_EVE ( GVML_OMBIEN,
&                     [F:FASC]CPY,
&                     [F:FASC]FCY,
&                     [F:FASC]AASREF,
&                     0,
&                     LCDINT,
&                     [F:FASC]PURDAT,
&                     [0/0/0],
&                     LCDRET)  From GENEVE
      If (LCDRET > 20 )
         GOK = 0
         Call FSTA("EFASCRT") From GLOCK
      Endif
   Next
   [F:FAS] = [F:FASV] #FQ94220

Return
####################################################################################################
## $CREATION_AMORTISSEMENTS_DES : Transfert des valeurs de la société source vers la société cible ##
##  pour la table DEP                                                                              ##
#####################################################################################################
$CREATION_AMORTISSEMENTS_DES
Local Integer WIDEPOK
Local Integer RERROR

GIPLN   = 0
WIDEPOK = G_OUI

Gosub CALC_VALEURS_SORTIE

If !GOK : Return : Endif
##---------------------------------------------------------------------------------------------##
## Lecture suivante du plan d'amortissement a creer dans la société cible                      ##
##---------------------------------------------------------------------------------------------##
For GIPLN = 0 To [F:CIR]NBRPLN-1

   ##-----------------------------------------------------------------------------------------##
   ## Alimentation des valeurs du plan                                                        ##
   ##-----------------------------------------------------------------------------------------##
   WIDEPOK = G_OUI

   Gosub CREATION_UN_AMORTISSEMENT_DES

   If WIDEPOK = G_OUI
       ##-----------------------------------------------------------------------------------------##
       ## Ecriture de l'enregistrement DEP                                                        ##
       ##-----------------------------------------------------------------------------------------##
       [F:DEPC]DEPSTA  = GVML_SCNOCAL

       #*FQ101833 Alimentation des PERREFCLC*
       If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLC <> [F:DEPC]PERSTRDAT )
          If ( [F:DEPC]PERCLOCUM <> 0 and [F:DEPC]DPM = G_DPMRE )
         [F:DEPC]PERREFCLC  = [F:DEPC]PERSTRDAT
       Else
         [F:DEPC]PERREFCLC  = [F:DEPC]FIYSTRDAT
          Endif
        Endif

        If ([F:DEPC]PERREFCLCT <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLCT <> [F:DEPC]PERSTRDAT )
           If ( [F:DEPC]PERCLOCUMT <> 0 and [F:DEPC]DPMT = G_DPMRE )
              [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT
           Else
         [F:DEPC]PERREFCLCT = [F:DEPC]FIYSTRDAT
           Endif
        Endif

        If ( [F:DEPC]PERREFCLCI <> [F:DEPC]FIYSTRDAT and [F:DEPC]PERREFCLCI <> [F:DEPC]PERSTRDAT )
           If ( [F:DEPC]PERCLOCUMI <> 0 and [F:DEPC]DPMI = G_DPMRE )
              [F:DEPC]PERREFCLCI = [F:DEPC]PERSTRDAT
           Else
              [F:DEPC]PERREFCLCI = [F:DEPC]FIYSTRDAT
           Endif
        Endif
        #*FQ101833 END

       [F:DEPC]LSTCLODAT =[0/0/0] #FQ106349

       Write [F:DEPC]
       If (fstat)
             GOK = 0 : Call FSTA("DEPC") From GLOCK
             Break
       Endif
   Else
       #
   Endif
Next

Return
####################################################################################################
## Fq-67475 CALCULER_VALEURS_SORTIE: calcul des valeurs nettes des plans du bien                          ##
####################################################################################################
 $CALC_VALEURS_SORTIE
     ##--------------------------------------------------------------------------------------------##
     ## Calcule la valeur nette à la date de sortie                                                ##
     ##--------------------------------------------------------------------------------------------##
     Local    Decimal VALNETTE(0..G301MAX)   : # Valeurs nettes pour chaque bien par plan
     Local    Date    LSORREG (0..G301MAX-1)
     Local    Date    LSORREGT(0..G301MAX-1)
     Local    Date    LSORREGI(0..G301MAX-1)
     Local    Decimal CPLDED(0..0,1..GMAXCNXC)          : # TVA Déductible complémentaire
     Local    Integer CODERR
     Local    Integer WISSTYP # Issue 109371

     Global   Decimal DOTCUM(0..G301MAX)    : # Cumul per + dot per  pour chaque bien par plan
     Global   Decimal DOTCUMI(0..G301MAX)   : # Cumul per + dot per  pour chaque bien par plan
     Global   Decimal DOTCUMT(0..G301MAX)   : # Cumul per + dot per  pour chaque bien par plan
     #FQ103293 - Ajout cumuls périodiques autres que les PERCLOCUMs --------------------------
     Global   Decimal PERCLOEXC(0..G301MAX)    : # Cumul périodes closes amt excep.
     Global   Decimal PERCLOEXCT(0..G301MAX)   : # Cumul P-1 amt exc T
     Global   Decimal PERCLOEXCI(0..G301MAX)   : # Cumul P-1 amt exc I
     Global   Decimal PERLEGCUM (0..G301MAX)   : # Cumul lien légal P-1
     Global   Decimal PERLEGRVE (0..G301MAX)   : # C repr lien lég P-1
     Global   Decimal PERIMLCUM (0..G301MAX)   : # Cumul Dépréciation P-1
     Global   Decimal PERRVECUM (0..G301MAX)   : # Cumul Reprise Dépréciation  P-1
     Global   Decimal PERTRFCUM (0..G301MAX)   : # Rep Dép à transférer en Amt Exc P-1
     Global   Decimal IMLBLC (0..G301MAX)      : # Solde dépréciation début  période
     Global   Decimal PERRVACUM (0..G301MAX)   : # Cumul P-1 montant réévaluation
     Global   Decimal PERRVADEV (0..G301MAX)   : # Cum per clos rs réév
     Global   Decimal PERQTYCUM (0..G301MAX)   : # Cumul UO périodes closes exercice
     Global   Decimal PERLNKCUM (0..G301MAX)   : # Cumul lien plan P-1
     If (G_ACTCCN = G_OUI)  # Issue 113528
       Global   Decimal P_1CADCRB (0..G301MAX)   : # Cumul P- 1 Prélèvement de Caducité
     Endif
     #*FQ103293 END -----------------------------------
     #*
     # Ouverture de l'écran FASS pour TRTFASISS
     If !(clalev([M:FASS])) : Local Mask FASISSP [FASS] : Endif
     [M:FASS] = [F:FAS]
     #FQ-67465 [M:FASS]ISSDATRUL   = [F:FAS]ISSDATRUL
     [M:FASS]ISSDATRUL  = GVML_IRJPREC          #Fq-67465 Pas de dotation le jour de sortie
     [M:FASS]R76COE      = [F:FAS]R76COE
     [M:FASS]EXTISSFLG   = G_NON   #Fq-68380
     [M:FASS]ISSVATRAT   = [F:FAS]ISSVATRAT
     [M:FASS]PYBVATTYP   = [F:FAS]PYBVATTYP
     #FQ82039
     If [M:FASS]BRDPLN = 0
        [M:FASS]BRDPLN = 1
     Endif
     [M:FASS]TTPRINC = G_NON

      Case [M:CII]CIGTYP
        When GVML_TOAPPOR    : WISSTYP = GVML_TSAPPOR
        When GVML_TOFUSIO    : WISSTYP = GVML_TSFUSIO
        When GVML_TOSCISS    : WISSTYP = GVML_TSSCISS
        When GVML_TOVTEIG    : WISSTYP = GVML_TSCIG
      Endcase

      #*Fq-68073 ------------------------------------------------------------
      If ( clalev([M:PCPT])=0 ) :  Local Mask CALDEP     [PCPT]   : Endif
      If ( clalev([M:PFIS])=0 ) :  Local Mask CALDEP     [PFIS]   : Endif
      If ( clalev([M:PMIN])=0 ) :  Local Mask CALDEP     [PMIN]   : Endif
      If ( clalev([M:PORI])=0 ) :  Local Mask CALDEP     [PORI]   : Endif
      If ( clalev([M:PR76])=0 ) :  Local Mask CALDEP     [PR76]   : Endif
      If ( clalev([M:PIAS])=0 ) :  Local Mask CALDEP     [PIAS]   : Endif
      If ( clalev([M:PTEC])=0 ) :  Local Mask CALDEP     [PTEC]   : Endif
      If ( clalev([M:PRET])=0 ) :  Local Mask CALDEP     [PRET]   : Endif
      If ( clalev([M:PSUB])=0 ) :  Local Mask CALDEP     [PSUB]   : Endif
      If ( clalev([M:PLI1])=0 ) :  Local Mask CALDEP     [PLI1]   : Endif
      If ( clalev([M:PLI2])=0 ) :  Local Mask CALDEP     [PLI2]   : Endif
      If ( clalev([M:PLI3])=0 ) :  Local Mask CALDEP     [PLI3]   : Endif
      If ( clalev([M:PLI4])=0 ) :  Local Mask CALDEP     [PLI4]   : Endif
      If ( clalev([M:PLI5])=0 ) :  Local Mask CALDEP     [PLI5]   : Endif
      If ( clalev([M:PLI6])=0 ) :  Local Mask CALDEP     [PLI6]   : Endif
      If ( clalev([M:EGCF])=0 ) :  Local Mask CALFIY     [EGCF]  :  Endif        : # Comptable & fiscal
      If ( clalev([M:EIAS])=0 ) :  Local Mask CALFIY     [EIAS]  :  Endif
      If ( clalev([M:ETEC])=0 ) :  Local Mask CALFIY     [ETEC]  :  Endif
      If ( clalev([M:ERET])=0 ) :  Local Mask CALFIY     [ERET]  :  Endif
      If ( clalev([M:ESUB])=0 ) :  Local Mask CALFIY     [ESUB]  :  Endif
      If ( clalev([M:ELI1])=0 ) :  Local Mask CALFIY     [ELI1]  :  Endif
      If ( clalev([M:ELI2])=0 ) :  Local Mask CALFIY     [ELI2]  :  Endif
      If ( clalev([M:ELI3])=0 ) :  Local Mask CALFIY     [ELI3]  :  Endif
      If ( clalev([M:ELI4])=0 ) :  Local Mask CALFIY     [ELI4]  :  Endif
      If ( clalev([M:ELI5])=0 ) :  Local Mask CALFIY     [ELI5]  :  Endif
      If ( clalev([M:ELI6])=0 ) :  Local Mask CALFIY     [ELI6]  :  Endif
      If ( clalev([M:DIV])=0 )  :  Local Mask CALDIV     [DIV]   :  Endif        : # Infos diverses
      If ( clalev([M:DIV2])=0 ) :  Local Mask CALDIV2    [DIV2]  :  Endif        : # Infos diverses FQ77877
      Local Integer  IP   # indice période courant
      Local Integer  IEC  # indice période courante
      Local Date     IEC  # indice exercice courant
      Local Date     IPC  # date période courante
      Local Date     IPCP # date période courante
      Local Char     PMASK
      Call CALCULER_VALEURS_SORTIE ("[F:FASS]", WISSTYP, [M:CII]EFFDAT, VALNETTE, LSORREG, LSORREGT, LSORREGI, CODERR) From TRTFASISS
      Local Integer I_PLN, I_PLAN
      #FQ-94835 I_PLN = G301LI2 to G301LI6 : wrong masks sent to GLOBB (always "PLI1")
      For I_PLN = 1 To G301MAX
        I_PLAN = find(I_PLN, [M:DIV]PLNCAA)
        If I_PLAN = 0 Goto NEXTPLAN : Endif
        Case I_PLN
        When  G301CPT
             PMASK = "[M:PCPT]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301CPT, "[M:PCPT]", IPCP) From GLOBB
             IP = find(IPCP, [M:PCPT]PERSTRDAT )
        When  G301FIS
             PMASK = "[M:PFIS]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301FIS, "[M:PFIS]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PFIS]PERSTRDAT )
        When  G301MIN
            PMASK = "[M:PMIN]"
            Call EVALUE_PERIODE_COURANTE_PLAN (G301MIN, "[M:PMIN]", IPCP)  From GLOBB
            IP = find(IPCP, [M:PMIN]PERSTRDAT )
        When  G301ORI
            PMASK = "[M:PORI]"
            Call EVALUE_PERIODE_COURANTE_PLAN (G301ORI, "[M:PORI]", IPCP)  From GLOBB
            IP = find(IPCP, [M:PORI]PERSTRDAT )
        When  G301R76
            PMASK = "[M:PR76]"
            Call EVALUE_PERIODE_COURANTE_PLAN (G301R76, "[M:PR76]", IPCP)  From GLOBB
            IP = find(IPCP, [M:PR76]PERSTRDAT )
        When  G301IAS
         PMASK = "[M:PIAS]"
         Call EVALUE_PERIODE_COURANTE_PLAN (G301IAS, "[M:PIAS]", IPCP)  From GLOBB
         IP = find(IPCP, [M:PIAS]PERSTRDAT )
        When  G301TEC
             PMASK = "[M:PTEC]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301TEC, "[M:PTEC]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PTEC]PERSTRDAT )
        When  G301RET
             PMASK = "[M:PRET]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301RET, "[M:PRET]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PRET]PERSTRDAT )
        When  G301SUB
             PMASK = "[M:PSUB]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301SUB, "[M:PSUB]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PSUB]PERSTRDAT )
        When  G301LI1
             PMASK = "[M:PLI1]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301LI1, "[M:PLI1]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PLI1]PERSTRDAT )
        When  G301LI2
         PMASK = "[M:PLI2]"
          Call EVALUE_PERIODE_COURANTE_PLAN (G301LI2, "[M:PLI2]", IPCP)  From GLOBB
         IP = find(IPCP, [M:PLI2]PERSTRDAT )
       When  G301LI3
              PMASK = "[M:PLI3]"
              Call EVALUE_PERIODE_COURANTE_PLAN (G301LI3, "[M:PLI3]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PLI3]PERSTRDAT )
       When  G301LI4
             PMASK = "[M:PLI4]"
              Call EVALUE_PERIODE_COURANTE_PLAN (G301LI4, "[M:PLI4]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PLI4]PERSTRDAT )
       When  G301LI5
         PMASK = "[M:PLI5]"
         Call EVALUE_PERIODE_COURANTE_PLAN (G301LI5, "[M:PLI5]", IPCP)  From GLOBB
         IP = find(IPCP, [M:PLI5]PERSTRDAT )
       When  G301LI6
             PMASK = "[M:PLI6]"
             Call EVALUE_PERIODE_COURANTE_PLAN (G301LI6, "[M:PLI6]", IPCP)  From GLOBB
             IP = find(IPCP, [M:PLI6]PERSTRDAT )
       When  Default
      Endcase

      #*FQ103293 DOTCUM(I_PLN-1)  = (evalue(PMASK+"PERCLOCUM(IP-1)"))  + (evalue(PMASK+"PERCLOEXC(IP-1)"))  + (evalue(PMASK+"PERENDDPE(IP-1)")) + (evalue(PMASK+"PEREXCDPR(IP-1)"))
      #*FQ103293 DOTCUMI(I_PLN-1) = (evalue(PMASK+"PERCLOCUMI(IP-1)")) + (evalue(PMASK+"PERCLOEXCI(IP-1)")) + (evalue(PMASK+"DPEI(IP-1)")) + (evalue(PMASK+"PEREXCDPRI(IP-1)"))
      #*FQ103293 DOTCUMT(I_PLN-1) = (evalue(PMASK+"PERCLOCUMT(IP-1)")) + (evalue(PMASK+"PERCLOEXCT(IP-1)")) + (evalue(PMASK+"DPET(IP-1)"))+ (evalue(PMASK+"PEREXCDPRT(IP-1)"))

      #*FQ103293 DOTCUM/DOTCUMI/DOTCUMT sont conservés pour l'alimentation des PERCLOCUM/PERCLOCUMI/PERCLOCUMT pour raison de compatibilité
      #* avec l'antériorité (point d'entrée MAJDOTCUM permettant l'alimentation des PERCLOCUMs)
      #*
      # PERCLOCUM += PERENDDPE
      DOTCUM(I_PLN-1)  = evalue(PMASK+"PERCLOCUM(IP-1)") +  evalue(PMASK+"PERENDDPE(IP-1)")
      # PERCLOEXC += PEREXCDPR
      PERCLOEXC(I_PLN-1)  = evalue(PMASK+"PERCLOEXC(IP-1)") +  evalue(PMASK+"PEREXCDPR(IP-1)")

      # PERCLOCUMT += DPET
      DOTCUMT(I_PLN-1)  = evalue(PMASK+"PERCLOCUMT(IP-1)") +  evalue(PMASK+"DPET(IP-1)")
      # PERCLOEXCT += PEREXCDPRT
      PERCLOEXCT(I_PLN-1)  = evalue(PMASK+"PERCLOEXCT(IP-1)") +  evalue(PMASK+"PEREXCDPRT(IP-1)")

      # PERCLOCUMI += DPEI
      DOTCUMI(I_PLN-1)  = evalue(PMASK+"PERCLOCUMI(IP-1)") +  evalue(PMASK+"DPEI(IP-1)")
      # PERCLOEXCI += PEREXCDPRI
      PERCLOEXCI(I_PLN-1)  = evalue(PMASK+"PERCLOEXCI(IP-1)") +  evalue(PMASK+"PEREXCDPRI(IP-1)")

      # PERLEGCUM  += LEG
      PERLEGCUM(I_PLN-1)  = evalue(PMASK+"PERLEGCUM(IP-1)") +  evalue(PMASK+"LEG(IP-1)")
      # PERLEGRVE  += LEGRVE
      PERLEGRVE(I_PLN-1)  = evalue(PMASK+"PERLEGRVE(IP-1)") +  evalue(PMASK+"LEGRVE(IP-1)")

      # PERIMLCUM += IML
      PERIMLCUM(I_PLN-1)  = evalue(PMASK+"PERIMLCUM(IP-1)") +  evalue(PMASK+"IML(IP-1)")
      # PERRVECUM += IMLRVE
      PERRVECUM(I_PLN-1)  = evalue(PMASK+"PERRVECUM(IP-1)") +  evalue(PMASK+"IMLRVE(IP-1)")
      # PERTRFCUM += IMLRVETRF
      PERTRFCUM(I_PLN-1)  = evalue(PMASK+"PERTRFCUM(IP-1)") +  evalue(PMASK+"IMLRVETRF(IP-1)")
      # IMLBLC += IML -(IMLRVE+IMLRVETRF)
      IMLBLC(I_PLN-1)  = evalue(PMASK+"IMLBLC(IP-1)")  +  evalue(PMASK+"IML(IP-1)")- (evalue(PMASK+"IMLRVE(IP-1)") + evalue(PMASK+"IMLRVETRF(IP-1)"))

      # PERRVACUM += RVAAMT
      PERRVACUM(I_PLN-1)  = evalue(PMASK+"PERRVACUM(IP-1)") +  evalue(PMASK+"RVAAMT(IP-1)")
      # PERRVADEV += RVACRB
      PERRVADEV(I_PLN-1)  = evalue(PMASK+"PERRVADEV(IP-1)") +  evalue(PMASK+"RVACRB(IP-1)")

      # PERQTYCUM += PERQTY
      PERQTYCUM(I_PLN-1)  = evalue(PMASK+"PERQTYCUM(IP-1)") +  evalue(PMASK+"PERQTY(IP-1)")

      # PERLNKCUM += LNK
      PERLNKCUM(I_PLN-1)  = evalue(PMASK+"PERLNKCUM(IP-1)") +  evalue(PMASK+"LNK(IP-1)")

      If (G_ACTCCN = G_OUI)  # Issue 113528
        #  P_1CADCRB += PERCADCRB
        P_1CADCRB(I_PLN-1)  = evalue(PMASK+"P_1CADCRB(IP-1)") +  evalue(PMASK+"PERCADCRB(IP-1)")
      Endif

      #*FQ103293 END --------------------------------------------------------------------------------------

#####################################################
#  Point d'entrée (FQ-69969)                        #
# Préparation alimentation du champ PERCLOCUM       #
#####################################################
   GPOINT = "MAJDOTCUM" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
  $NEXTPLAN
 Next  I_PLN
  #*Fq-68073 ------------------------------------------------------------
  #*
  #*!
Return
####################################################################################################
## $CREATION_UN_AMORTISSEMENT_DES : Transfert des valeurs de la soc source vers la soc cible      ##
####################################################################################################
$CREATION_UN_AMORTISSEMENT_DES
Local Integer WIPLANLU
Local Decimal WDDURRES
Local Integer WICONTEXTE
Local Char    WCDEV1S
Local Char    WCDEV1C
Local Decimal WNDPRBAS    # mdj 21-04-2006

Local Integer LOK

WCDEV1S = ""
WCDEV1C = ""
WNDPRBAS = 0
##-----------------------------------------------------------------------------------------##
## Lecture du plan d'origine pour recopie                                                  ##
##-----------------------------------------------------------------------------------------##

# si règle reprise plan cible = "Val ide. au plan modèle " ou "VB=VN du plan modèle"
# plan lu = plan modèle
If [F:CIR]RULPRO(GIPLN) = GML_VAIDEPLM or [F:CIR]RULPRO(GIPLN) = GML_VBVANPLM
   WIPLANLU =  [F:CIR]PLNTPL(GIPLN)
# si règle reprise plan cible = "Val reprise à l'identiqu " ou "VB=prix de cession"
# plan lu = plan cible
Else
     WIPLANLU =  [F:CIR]DPRPLN(GIPLN)
Endif
##-----------------------------------------------------------------------------------------##
## Récupère le contexte du plan                                                            ##
##-----------------------------------------------------------------------------------------##
Call GET_CNX_FROM_PLAN([F:CIR]CPYSRC,WIPLANLU,WICONTEXTE) From GLOBIENS
If WICONTEXTE < 0   #*Fq-54639
   WICONTEXTE = 0
Endif
Read [F:CNX]CNX0=[F:CIR]CPYSRC;WICONTEXTE
If fstat = 0
       WCDEV1S = [F:CNX]CUR
Else
  Read [F:CNX]CNX0=[F:CIR]CPYDES;WICONTEXTE
  If fstat = 0
       WCDEV1S = [F:CNX]CUR
  Else
       WCDEV1S = GEURO
  Endif
Endif
##-----------------------------------------------------------------------------------------##
## Récup date deb et fin d'exer pour contexte correspondant au plan amort lu de soc source ##
## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1  ##
##-----------------------------------------------------------------------------------------##
Call GET_CNX_DAT([F:FASS]CPY,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS
  Read [F:DEPS]DEP0 = [F:FASS]AASREF; WIPLANLU ; WDDATE(2); WDDATE(4)
  If [S]fstat = 0
     WIDEPOK = G_OUI
  Else
     # Le plan à alimenter n'existe pas dans la société source
     Call GET_CNX_DAT([F:FASC]CPY,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS
     If [S]fstat = 0
        WIDEPOK = G_OUI
     Else
        WIDEPOK = G_NON
        Return
     Endif
  Endif
##-----------------------------------------------------------------------------------------##
## Rubrique : Gestion des règles  de reprise du plan                                       ##
##-----------------------------------------------------------------------------------------##
##--------------------------------------------------------------------------------------------##
## Si Etat sortie CIG du bien : BIEN A ANNULER                                                ##
##--------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT    = GVML_ETATSAA
   [F:DEPC]     = [F:DEPS]
   # Rien d'autres a reprendre car reprise identique si bien source annulé car > date effet
Else
    ##--------------------------------------------------------------------------------------------##
    ## Si Etat sortie CIG du bien différent de BIEN A ANNULER                                     ##
    ##--------------------------------------------------------------------------------------------##
    If [F:CIR]RULPRO(GIPLN) = GML_VAIDEPLM          : # Valeur identique au plan modèle
       [F:DEPC]     = [F:DEPS]
       # Rien d'autres a reprendre car reprise identique a un plan
    Elsif [F:CIR]RULPRO(GIPLN) = GML_VAIDENTI         : # Valeur reprise à l'identique
       [F:DEPC]     = [F:DEPS]
      # Rien d'autres a reprendre car reprise identique a un plan
    Elsif [F:CIR]RULPRO(GIPLN) = GML_VBPRICES         : # Valeur brute = prix de cession
       Gosub INIT_DEP
       [F:DEPC]DEPSTA     = GVML_SCNOCAL
    Elsif [F:CIR]RULPRO(GIPLN) = GML_VBVANPLM         : # Valeur brute = valeur nette plan modèle
       Gosub INIT_DEP
       [F:DEPC]DEPSTA     = GVML_SCNOCAL
    Endif
Endif
[F:DEPC]DEPSTA     = GVML_SCNOCAL   #*Fq-55346
##-----------------------------------------------------------------------------------------##
## Société , référence et plan                                                             ##
##-----------------------------------------------------------------------------------------##
[F:DEPC]CPY    = [F:CIR]CPYDES
[F:DEPC]FCY        = WSITECIBLE            : #Fq-67465  Site des deprec = site du bien
#*Fq-66878 [F:DEPC]AASREF = [F:FASC]AASREF
[F:DEPC]AASREF = [F:CIB]AASREFNEW
[F:DEPC]DPRPLN = [F:CIR]DPRPLN(GIPLN)
If [F:FASC]ISSDAT <> [0/0/0]
  [F:DEPC]FLGUPDISS = G_OUI #Fq-70292
Endif
##--------------------------------------------------------------------------------------------##
## Si Etat sortie CIG du bien différent de BIEN A ANNULER                                     ##
##--------------------------------------------------------------------------------------------##
If [F:CIB]ISSSAT    <> GVML_ETATSAA
    ##-----------------------------------------------------------------------------------------##
    ## Récupère le contexte du plan                                                            ##
    ##-----------------------------------------------------------------------------------------##
    Call GET_CNX_FROM_PLAN([F:CIR]CPYDES,[F:CIR]DPRPLN(GIPLN),WICONTEXTE) From GLOBIENS
   If WICONTEXTE < 0   #*Fq-54639
      WICONTEXTE = 0
   Endif
    Read [F:CNX]CNX0=[F:CIR]CPYDES;WICONTEXTE
    If fstat = 0
         WCDEV1C = [F:CNX]CUR
    Else
         WCDEV1C = GEURO
    Endif

    ##-----------------------------------------------------------------------------------------##
    ## Fin exercice et fin de période du contexte correspondant au plan a creer                ##
    ##-----------------------------------------------------------------------------------------##
    Call GET_CNX_DAT([F:FASC]CPY,WICONTEXTE,WDDATE,WICODERET) From GLOBIENS
    [F:DEPC]FIYENDDAT = WDDATE(2)
    [F:DEPC]PERENDDAT = WDDATE(4)
    If [F:FASC]ISSDAT <> [0/0/0]
      [F:DEPC]FLGUPDISS = G_OUI #Fq-70292
    Endif

    ##-----------------------------------------------------------------------------------------##
    ## Date début d'amort, Date début exercice, Date début période, indicateur non calculé     ##
    ##-----------------------------------------------------------------------------------------##
    ##-----------------------------------------------------------------------------------------##
    ## Règle reprise plan cible="Valeur brute=prix de cession" ou "Valeur brute=VN plan modèle ##
    ##-----------------------------------------------------------------------------------------##
    If [F:CIR]RULPRO(GIPLN) = GML_VBPRICES    or  [F:CIR]RULPRO(GIPLN) = GML_VBVANPLM
        [F:DEPC]STRDPRDAT  = [M:CII]EFFDAT
        [F:DEPC]FIYSTRDAT  = WDDATE(1)
        [F:DEPC]PERSTRDAT  = WDDATE(3)
        ##-----------------------------------------------------------------------------------------##
        ## Mode d'amortissement : Vb = prix de cession  ou Vb = valeur nette plan modèle           ##
        ##-----------------------------------------------------------------------------------------##
        If [F:CIR]DPRDPM(GIPLN) = ""
              [F:DEPC]DPM        = [F:DEPS]DPM
        Else
              [F:DEPC]DPM        = [F:CIR]DPRDPM(GIPLN)
        Endif
        ##-----------------------------------------------------------------------------------------##
        ## Durée d'amort : Durée résiduelle ou Reconduction durée précédente                       ##
        ##-----------------------------------------------------------------------------------------##
        If [F:CIR]DPRDUR(GIPLN) = GVML_CIGDRES
            WDDURRES = 0
            # Durée résiduelle calculée = ( Date fin Amt plan source - Date déb amt du nouveau bien  )
            WDDURRES  = arr( ([F:DEPS]ENDDPRDAT - [F:DEPC]STRDPRDAT ) / 365 , 0.01 )
            If WDDURRES <= 0
                [F:DEPC]DPRDUR  = [F:CIR]DPRDURDEF(GIPLN)
            Else
                [F:DEPC]DPRDUR  = WDDURRES
                [F:DEPC]ENDDPRDAT  = [F:DEPS]ENDDPRDAT
            Endif
        Elsif [F:CIR]DPRDUR(GIPLN) = GVML_CIGDPRE : # 2 Reconduction durée précédente
                [F:DEPC]DPRDUR  = [F:DEPS]DPRDUR
        Endif

        ##-----------------------------------------------------------------------------------------##
        ## Si durée d'amort < 3 ans et degressif --> passe a lineaire                              ##
        ##-----------------------------------------------------------------------------------------##

        If [F:DEPC]DPM  = G_DPMDF  and [F:DEPC]DPRDUR < 3
                  [F:DEPC]DPM        = G_DPMLP
        Endif

        ##-----------------------------------------------------------------------------------------##
        ## Valeur bilan (init et rééval) : Vb = prix de cession ou Vb = valeur nette plan modèle   ##
        ##-----------------------------------------------------------------------------------------##

        WCDEV1  = WCDEV1S
        WCDEV2  = WCDEV1C

        If [F:CIR]RULPRO(GIPLN) = GML_VBPRICES
            If [F:CIB]ISSAMTUPD <> 0
                If WCDEV1S  = WCDEV1C
                    [F:DEPC]BSEVAL    = [F:CIB]ISSAMTUPD
                    [F:DEPC]DPRBAS    = [F:CIB]ISSAMTUPD
                Else
                    WDMONT1           = [F:CIB]ISSAMTUPD
                    Gosub CONV_DEVISE
                   [F:DEPC]BSEVAL     = WDMONT2
                   [F:DEPC]DPRBAS     = WDMONT2
                Endif
             Else
                If WCDEV1S  = WCDEV1C
                    [F:DEPC]BSEVAL = [F:CIB]ISSAMT
                    [F:DEPC]DPRBAS = [F:CIB]ISSAMT
                Else
                    WDMONT1           = [F:CIB]ISSAMT
                    Gosub CONV_DEVISE
                   [F:DEPC]BSEVAL     = WDMONT2
                   [F:DEPC]DPRBAS     = WDMONT2
                Endif
            Endif
        Elsif [F:CIR]RULPRO(GIPLN) = GML_VBVANPLM
              ## Recalcul valeur nette sur plans société source si VB=VN du plan modèle
              ## FQ-67475  déplacé au début de $CREATION_AMORTISSEMENTS_DES
              ##--------------------------------------------------------------------------------------------##
              ## Calcule la valeur nette à la date de sortie                                                ##
              ##--------------------------------------------------------------------------------------------##
#              Local    Decimal VALNETTE(0..G301MAX)   : # Valeurs nettes pour chaque bien par plan
#              #FQ53487
#              Local    Date    LSORREG (0..G301MAX-1)
#              Local    Date    LSORREGT(0..G301MAX-1)
#              Local    Date    LSORREGI(0..G301MAX-1)
#
#              Local    Decimal CPLDED(0..0,1..GMAXCNXC)          : # TVA Déductible complémentaire
#              Local    Integer CODERR
#              # Ouverture de l'écran FASS pour TRTFASISS
#              If !(clalev([M:FASS])) : Local Mask FASISSP [FASS]
#                 [M:FASS]=[M:FASS]
#              Endif
#              [M:FASS] = [F:FASS]
#              [M:FASS]ISSDATRUL   = [F:FASS]ISSDATRUL
#              [M:FASS]R76COE      = [F:FASS]R76COE
#              [M:FASS]EXTISSFLG   = [F:FASS]EXTISSFLG
#              [M:FASS]ISSVATRAT   = [F:FASS]ISSVATRAT
#              [M:FASS]PYBVATTYP   = [F:FASS]PYBVATTYP
#              # Call CALCULER_VALEURS_SORTIE ( "[F:DEPS]", GVML_TSCIG , [M:CII]EFFDAT, VALNETTE, CODERR) From TRTFASISS
#              #-Fq258
#              #*Fq-66878 sauvegarde Dotations (Société cible) car classe [F:DEPC] utilisée par ailleurs dans le TRTFASISS
#              If clalev([F:SDEP]) =0 : Local File DEPREC    [SDEP]        : Endif   #*Fq-66878
#              [F:SDEP] = [F:DEPC]   #*Fq-66878
#              Call CALCULER_VALEURS_SORTIE("[F:FASS]",GVML_TSCIG,[M:CII]EFFDAT,VALNETTE,LSORREG,LSORREGT,LSORREGI,CODERR) From TRTFASISS
#              [F:DEPC] = [F:SDEP]   #*Fq-66878
               #If !CODERR
                 #*Fq-66878 WNDPRBAS= VALNETTE([F:DEPS]DPRPLN)
                 WNDPRBAS= VALNETTE([F:DEPS]DPRPLN-1)
               #*Fq-72676 If WNDPRBAS = 0
               #*Fq-72676  WNDPRBAS= [F:CIB]NVA
               #*Fq-72676 Endif
               If WNDPRBAS <> 0 #*Fq-72676
                 Call GET_MNT_ARRONDI (WNDPRBAS, WCDEV1S,WNDPRBAS) From GLOBIENS
               Endif #*Fq-72676
              If WCDEV1S  = WCDEV1C
                 # NBV OU RECALCVUL VALEUR NETTE
                 [F:DEPC]BSEVAL  = WNDPRBAS
                 [F:DEPC]DPRBAS  = WNDPRBAS
              Else
                 WDMONT1           = WNDPRBAS
                 Gosub CONV_DEVISE
                 [F:DEPC]BSEVAL     = WDMONT2
                 [F:DEPC]DPRBAS     = WDMONT2
              Endif
        Endif
    Endif
    # Si Valeur identique au plan modèle ou si Valeur reprise à l'identique  et si plan cible
    # est dans une autre devise --> conversion
    If [F:CIR]RULPRO(GIPLN) = GML_VAIDEPLM          or  [F:CIR]RULPRO(GIPLN) = GML_VAIDENTI
        [F:DEPC]STRDPRDAT  = [F:DEPS]STRDPRDAT
        [F:DEPC]FIYSTRDAT  = [F:DEPS]FIYSTRDAT
        [F:DEPC]PERSTRDAT  = [F:DEPS]PERSTRDAT
        #FQ-68073
        [F:DEPC]PERCLOCUM  = DOTCUM([F:DEPS]DPRPLN-1)
        [F:DEPC]PERCLOCUMI = DOTCUMI([F:DEPS]DPRPLN-1)
        [F:DEPC]PERCLOCUMT = DOTCUMT([F:DEPS]DPRPLN-1)

        #*FQ103293 -----------------------------------------------
         [F:DEPC]PERCLOEXC  = PERCLOEXC([F:DEPS]DPRPLN-1)
         [F:DEPC]PERCLOEXCT = PERCLOEXCT([F:DEPS]DPRPLN-1)
         [F:DEPC]PERCLOEXCI = PERCLOEXCI([F:DEPS]DPRPLN-1)

         [F:DEPC]PERLEGCUM = PERLEGCUM([F:DEPS]DPRPLN-1)
         [F:DEPC]PERLEGRVE = PERLEGRVE([F:DEPS]DPRPLN-1)

         [F:DEPC]PERIMLCUM = PERIMLCUM([F:DEPS]DPRPLN-1)
         [F:DEPC]PERRVECUM = PERRVECUM([F:DEPS]DPRPLN-1)
         [F:DEPC]PERTRFCUM = PERTRFCUM([F:DEPS]DPRPLN-1)
         [F:DEPC]IMLBLC    = IMLBLC([F:DEPS]DPRPLN-1)

         [F:DEPC]PERRVACUM = PERRVACUM([F:DEPS]DPRPLN-1)
         [F:DEPC]PERRVADEV = PERRVADEV([F:DEPS]DPRPLN-1)

         [F:DEPC]PERQTYCUM = PERQTYCUM([F:DEPS]DPRPLN-1)
         [F:DEPC]PERLNKCUM = PERLNKCUM([F:DEPS]DPRPLN-1)

         If (G_ACTCCN = G_OUI)  # Issue 113528
           [F:DEPC]P_1CADCRB = P_1CADCRB([F:DEPS]DPRPLN-1)
         Endif
         #*FQ103293 END ----------------------------------------

        #FQ-68073
        If WCDEV1S  <> WCDEV1C
                WDMONT1           = [F:DEPC]DPRBAS
                Gosub CONV_DEVISE
               [F:DEPC]DPRBAS     = WDMONT2

                WDMONT1           = [F:DEPC]BSEVAL
                Gosub CONV_DEVISE
               [F:DEPC]BSEVAL     = WDMONT2

                WDMONT1           = [F:DEPC]BSEVAL
                Gosub CONV_DEVISE
               [F:DEPC]BSEVAL     = WDMONT2

                WDMONT1           = [F:DEPC]BSEVAL
                Gosub CONV_DEVISE
               [F:DEPC]BSEVAL     = WDMONT2

               [F:DEPC]DEPSTA     = GVML_SCNOCAL

          Endif
    Endif
Endif

Return
####################################################################################################
## $INSERT_ACHETEUR : Insertion nouvel acheteur s'il n'existe pas                                 ##
####################################################################################################
$INSERT_ACHETEUR

Read [F:BPR]= [F:FASS]BUY
If [S]fstat <> 0
    [F:BPR]BPRNUM   = [F:FASS]BUY    # Nom acheteur
    Read [F:CPY]= [F:FASS]BUY
    If [S]fstat =  0
        [F:BPR]BPRNAM   = [F:CPY]CPYNAM     # Designation acheteur
    Endif
    [F:BPR]CUR      = GCUR           # Devise
    [F:BPR]BPCFLG   = G_OUI          # Client
    [F:BPR]BPSFLG   = G_NON          # Fournisseur
    [F:BPR]CREUSR   = GUSER          # Utilisateur (création)
    [F:BPR]CREDAT   = [M:CII]EFFDAT  # Date création
    [F:BPR]UPDUSR   = GUSER          # Utilisateur (modification)
    [F:BPR]UPDDAT   = [M:CII]EFFDAT  # Date modification
    Write [F:BPR]
    If (fstat)
          GOK = 0 : Call FSTA("BPR") From GLOCK
          Return
    Endif
Endif

Return
####################################################################################################
## $INIT_DEP : Initiallisation d'un enregistrement DEPREC                                         ##
####################################################################################################
$INIT_DEP
Raz [F:DEPC]

[F:DEPC]ALWAMTFLG  = G_NON                  : # Mt règl part forc ex
[F:DEPC]ALWCOD     = GVML_RPAUCUN           : # Type règle particul   : TABLE 368
[F:DEPC]ALWCUMFLG  = G_NON                  : # Cum règl part forcé
[F:DEPC]DEPSTA     = GVML_SCNOCAL           : # Statut clôture        : TABLE 310
[F:DEPC]DPRCUMFLG  = G_NON                  : # Cumul amort ex forcé
[F:DEPC]DPRRAT     = 0                      : # Taux d'amortissement
[F:DEPC]DPRRATFLG  = G_NON                  : # Taux d'amort forcé
[F:DEPC]ENDDPEFLG  = G_NON                  : # Dot exercice forcée
[F:DEPC]IMLFLG     = G_NON                  : # Dépréciation forcée
[F:DEPC]IMLRVEFLG  = G_NON                  : # Repr dépréc forcée
[F:DEPC]PRATYP     = [F:DEPS]PRATYP         : # Type de prorata par défaut #*Fq-66878
[F:DEPC]MTCDEVADJ  = 1                      : # Rattrap éc chg méth
[F:DEPC]PERDPEFLG  = G_NON                  : # Dotation pér forcée
[F:DEPC]RATCUR     = 1                      : # Cours devise
[F:DEPC]RVACOE     = 0                      : # Coef réévaluation
[F:DEPC]RVATYP     = 1                      : # Type réévaluation

Return
####################################################################################################
## $TERMINE :      Gestion de la fin du traitement                                                ##
####################################################################################################
$TERMINE
If WAFFICHINBOX =  G_OUI
   #Infbox 'NOM PROG = ' - WCNOMPROG - ' / PARAGRAPHE = $TERMINE'
Endif

Return
####################################################################################################
## LOCK_SOC_OBJET : Lock de la société d'un objet                                                 ##
####################################################################################################
$LOCK_SOC_OBJET
Local Integer WILOCK
Local Char WCOBJLOCKLG
Local Char WCUSERLOCK (80)
#--- Test si les enregistrements de la société déjà lockés (WILOCK =0) ---##
#--- si non , lockage des enregistrements de la société  ---##

WILOCK =  func GLOBIENS.IS_SYMBOLE_LOCKED (WCOBJLOCK , WCSOCTRT  , "")

If WILOCK = 1
    WILOCK =  func GLOBIENS.LOCK_SYMBOLE (WCOBJLOCK , WCSOCTRT  , "", 5 )
Elsif WILOCK = 0

    If WI1ERERR1     = G_NON
                WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                # 70--> ARRET DU TRAITEMENT
                WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WCLIGNE="=========================================================================================================="
                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                WI1ERERR1     = G_OUI
    Endif

   #--- Recherche du nom de la table lockée --------------------------------------------------------------##
   Read [F:ATB]ABRFIC = WCOBJLOCK
   If [S]fstat =  0
        # Décodification de l'intitulé qui a été récupéré sous forme de nombre
        Call TEXTE([F:ATB]INTITFIC,WCOBJLOCKLG ) From OBJDIV
   Endif

   #--- Recherche de l'utilisateur qui lock --------------------------------------------------------------##

   WCUSERLOCK = func GLOBIENS.QUI_LOCKE ()
   WIUNOBJLOCK = G_OUI
   #--- Edition de la ligne d'erreur           -----------------------------------------------------------##
   # 72--> L'objet
   # 73--> est utilisé par la société
   WCLIGNE=   mess(72,GML_MSGREC,1) - "'" + WCOBJLOCKLG + "'" + " " + mess(73,GML_MSGREC,1) - WCSOCTRT   + '.    ' + WCUSERLOCK
   Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Endif

Return
####################################################################################################
## $PRE_CONTROLE_TRAITEMENT :   Pré controle du traitement                                        ##
####################################################################################################
$PRE_CONTROLE_TRAITEMENT

Local Char    WCOBJLOCK
Local Char    WCMESS1 (120)
Local Char    WCMESS2 (120)
Local Char    WCBIDON
Local Integer WINAMOBJ
Local Char WCSOCSOURCE
Local Char WCSOCCIBLE
Local Char WCSOCTRT
Local Integer WI1ERERR1
Local Integer WI1ERERR2
Local Integer WIERR3
Local Integer WIALLOBJLOCK
Local Integer WIUNOBJLOCK
Local Integer WIGRTGERE
Local Integer WILEAGERE
Local Integer WILOFGERE
Local Integer WIRECODFCY
Local Integer WIXRECODFCY
Local Integer NBR_FCY
Local Integer NBENR
Local Integer WICONTEXTE

Local Date    WDDATEDEB1
Local Date    WDDATEFIN1
Local Date    WDDATEDEB2
Local Date    WDDATEFIN2

WIALLOBJLOCK = G_NON
WIUNOBJLOCK  = G_NON
WITRTOK      = G_OUI
WIRECODFCY   = G_NON
WIXRECODFCY  = G_NON
WIERR3       = G_NON
NBR_FCY      = 0
NBENR        = 0
##------------------------------------------------------------------------------------------------##
## - Arret du traitement s'il n'y a pas de recodification des sites dont la référence de CIG est  ##
##   égale à la référence de CIG traitée                                                          ##
## - Arret du traitement s'il y plusieurs référence de recodification des sites                   ##
##------------------------------------------------------------------------------------------------##

Filter[F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC)
For [F:CDF]
   If [F:CDF]TABNAM  = "FCY"
        If WIRECODFCY   = G_OUI
            WIXRECODFCY   = G_OUI
        Endif
        WIRECODFCY   = G_OUI
   Endif
Next
Filter[F:CDF]

If WIRECODFCY   = G_NON
    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    # 70--> ARRET DU TRAITEMENT
    WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    # 87--> Absence de recodification des sites pour cette cession intra-groupe
    # 88--> Veuillez créer une recodification pour tous les sites des sociétés sources traitées
    WCLIGNE="              "  + mess(87,GML_MSGCIG,1) + "                                             "
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="        "  + mess(88,GML_MSGCIG,1) + "                                             "
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WITRTOK      = G_NON
    Return
Endif

##------------------------------------------------------------------------------------------------##
## - Arrêt trt si tous les sites de toutes les sociétés sources ne sont pas recodifiés            ##
##------------------------------------------------------------------------------------------------##
# On commence par compter le nombre de sites sélectionnés

NBR_FCY=0
Filter[F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC and [F:CDF]TABNAM  = "FCY")
For [F:CDF]
    Filter[F:CDY] Where ([F:CDY]REFCDF =  [F:CDF]REFCDF)
    For [F:CDY]
      If [F:CDY]FLGFCY = G_OUI
         NBR_FCY+=1
      Endif
    Next
    Filter[F:CDY]
Next
Filter[F:CDF]

# Déclaration et Remplissage de la variable destinée à recevoir les sites à sélectionner

If dim(LIST_FCY)>0 : Kill LIST_FCY : Endif
#*FQ-66813  Global Char    LIST_FCY(5)(0..NBR_FCY)
Global Char    LIST_FCY(GLONFCY)(0..NBR_FCY)
Local Integer I_LIST_FCY
I_LIST_FCY = 0

Filter[F:CDF] Where ([F:CDF]REFTRFCMP =  [M:CII]CIGCOD and [F:CDF]PROSTA = GVML_RECATRC and [F:CDF]TABNAM  = "FCY")
For [F:CDF]
    Filter[F:CDC] Where ([F:CDC]REFCDF =  [F:CDF]REFCDF)
    For [F:CDC]
    If [F:CDC]VALNEWCOD <> ""
        I_LIST_FCY+=1
        LIST_FCY(I_LIST_FCY-1)=[F:CDC]VALOLDCOD
    Endif
    Next
    Filter[F:CDC]
Next
Filter[F:CDF]
##------------------------------------------------------------------------------------------------##
## Test pour savoir quels sont les entités gérées pour les sociétés sources                       ##
##------------------------------------------------------------------------------------------------##
WIGRTGERE = G_NON
WILEAGERE = G_NON
WILOFGERE = G_NON
WIERR3    = G_NON

If clalev([F:LOF])  =0 : Local File LAYOUTFAS [LOF]         : Endif : # Table des dépenses
If G_ACTLEA = G_OUI
  If clalev([F:LEA])  =0 : Local File LEASE     [LEA]         : Endif : # Table des contrats location fianancement
Endif
If G_ACTGRT = G_OUI
   If clalev([F:GRT])  =0 : Local File GRANTS    [GRT]         : Endif : # Table des subventions
Endif

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
     Gosub TEST_RECOD_CCE  #Fq-83418
     If WITRTOK <> G_OUI : WIERR3= G_OUI : Break : Endif
     If WCSOCSOURCE <>  [F:CIR]CPYSRC
        Filter [F:LOF] Where [F:LOF]CPY = [F:CIR]CPYSRC
        Read[F:LOF] First
        If [S]fstat = 0
            WILOFGERE = G_OUI
        Endif
        Filter [F:LOF]
        If G_ACTLEA = G_OUI
            Filter [F:LEA] Where [F:LEA]CPY = [F:CIR]CPYSRC
            Read[F:LEA] First
            If [S]fstat = 0
                WILEAGERE = G_OUI
            Endif
            Filter [F:LEA]
        Endif

        If G_ACTGRT = G_OUI
            Filter [F:GRT] Where [F:GRT]CPY = [F:CIR]CPYSRC
            Read[F:GRT] First
            If [S]fstat = 0
                WIGRTGERE = G_OUI
            Endif
            Filter [F:GRT]
        Endif
        For [FCY] Where LEGCPY = [F:CIR]CPYSRC With Stability
          NBENR=0
          Filter[CIB] Where FCYSRC=[F:FCY]FCY and CPYSRC = [F:CIR]CPYSRC
            Read[CIB]First
            If fstat=0
              NBENR=rowcount ([F:CIB])
            Endif    #Fq-70230>
            Filter[CIB]
            If NBENR <> 0
               Read [F:CDC]CDC=[F:CDF]REFCDF;[F:CIB]FCYSRC
               #Fq-78191 Fq-70230 If  (fstat <> 0) or ([F:CDC]VALNEWCOD = "")
               If find([F:FCY]FCY,LIST_FCY) = 0
                 If WIERR3    = G_NON
                    WIERR3    = G_OUI
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    # 70--> ARRET DU TRAITEMENT
                    WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  Endif
                  WCLIGNE= mess(189,GML_MSGCIG,1)-  [F:FCY]FCY - mess(190,GML_MSGCIG,1) +  [F:FCY]FCY  - mess(191,GML_MSGCIG,1) + [F:CIR]CPYSRC + ')' - mess(93,GML_MSGCIG,1)
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
               Endif
            Endif
         Next
         WCSOCSOURCE =  [F:CIR]CPYSRC
      Endif
   Next
   Filter[F:CIR]

If WIERR3    = G_OUI
     WITRTOK      = G_NON
     WCLIGNE="=========================================================================================================="
     Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Return
Endif

##------------------------------------------------------------------------------------------------##
## Arret du traitement si les entités gérées n'ont pas de numérotation automatique                ##
##------------------------------------------------------------------------------------------------##
If GAASAUTNUM = GVML_AUCUNE or (WIGRTGERE = G_OUI and GGRTAUTNUM = GVML_AUCUNE ) or (WILEAGERE = G_OUI and GLEAAUTNUM = GVML_AUCUNE  )or (WILOFGERE = G_OUI and GLOFAUTNUM = GVML_AUCUNE  )

    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    If GAASAUTNUM = GVML_AUCUNE
         # 79--> Numérotation automatique inexistante pour les biens comptables
         WCLIGNE="               "  + mess(79,GML_MSGCIG,1) + "                                             "
         Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Elsif GLOFAUTNUM = GVML_AUCUNE
         # 80--> Numérotation automatique inexistante pour les dépenses
         WCLIGNE="               "  + mess(80,GML_MSGCIG,1) + "                                             "
         Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Elsif GGRTAUTNUM = GVML_AUCUNE
         # 81--> Numérotation automatique inexistante pour les subventions
         WCLIGNE="               "  + mess(81,GML_MSGCIG,1) + "                                             "
         Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Elsif GLEAAUTNUM = GVML_AUCUNE
         # 82--> 'Numérotation automatique inexistante pour les contrats location financement
         WCLIGNE="               "  + mess(82,GML_MSGCIG,1) + "                                             "
         Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif
    WCLIGNE="=========================================================================================================="
    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WITRTOK      = G_NON
    Return
Endif

##------------------------------------------------------------------------------------------------##
## Pour chaque société source, le traitement verrouille les contextes et les biens                ##
##------------------------------------------------------------------------------------------------##

WCSOCSOURCE  = ""

WI1ERERR1     = G_NON
Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCSOURCE <>  [F:CIR]CPYSRC

       WCSOCTRT  = [F:CIR]CPYSRC

       WIUNOBJLOCK = G_NON
       #---- Test si la société est lockée pour l'objet FAS  ----------------------#
       WCOBJLOCK   = "FAS"
       Gosub LOCK_SOC_OBJET
       If WIUNOBJLOCK = G_OUI
             WITRTOK      = G_NON
             WIALLOBJLOCK = G_OUI
       Endif
       #---- Test si la société est lockée pour l'objet DEP  ----------------------#
       WCOBJLOCK   = "DEP"
       Gosub LOCK_SOC_OBJET
       If WIUNOBJLOCK = G_OUI
             WITRTOK      = G_NON
             WIALLOBJLOCK = G_OUI
       Endif

       WCSOCSOURCE = [F:CIR]CPYSRC
    Endif
Next

Filter[F:CIR]

##------------------------------------------------------------------------------------------------##
## Pour chaque société cible, le traitement verrouille les contextes et les biens                ##
##------------------------------------------------------------------------------------------------##

WCSOCCIBLE  = ""

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCCIBLE <>  [F:CIR]CPYDES

       WCSOCTRT  = [F:CIR]CPYDES

       WIUNOBJLOCK = G_NON
       #---- Test si la société est lockée pour l'objet FAS  ----------------------#
       WCOBJLOCK   = "FAS"
       Gosub LOCK_SOC_OBJET
       If WIUNOBJLOCK = G_OUI
             WITRTOK      = G_NON
             WIALLOBJLOCK = G_OUI
       Endif
       #---- Test si la société est lockée pour l'objet DEP  ----------------------#
       WCOBJLOCK   = "DEP"
       Gosub LOCK_SOC_OBJET
       If WIUNOBJLOCK = G_OUI
             WITRTOK      = G_NON
             WIALLOBJLOCK = G_OUI
       Endif

       WCSOCCIBLE = [F:CIR]CPYDES
    Endif
Next

Filter[F:CIR]

If WIALLOBJLOCK = G_OUI
    # Les enregistrements de la société sont verrouillés par un autre processus. Il ne peut être utilisé.
    WCMESS1  = mess(74,GML_MSGCIG,1)
    WCMESS2  = mess(71,GML_MSGREC,1)
    Errbox  WCMESS1,WCMESS2
    GOK=0
    OK=0
    Gosub UNLOCK_ALL
    Return
Endif

##------------------------------------------------------------------------------------------------##
## La date d’effet de l’opération doit être comprise dans l’exercice courant de chacune des       ##
## sociétés source et sociétés cible. Ceci pour tous les contextes qu’elles gèrent.               ##
##------------------------------------------------------------------------------------------------##
WCSOCSOURCE  = ""
WCSOCCIBLE   = ""

WI1ERERR1     = G_NON

##---------------------------------------------------------------------------------------------##
## Controle date effet par rapport aux plans de l'onglet 'sélection' pour les sociétés sources ##
##---------------------------------------------------------------------------------------------##

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCSOURCE <>  [F:CIR]CPYSRC
       GISEL = 0
       ##---------------------------------------------------------------------------------------------##
       ## Lecture de la référence de sélection suivante                                               ##
       ##---------------------------------------------------------------------------------------------##
       For GISEL = 0 To [F:CIR]NBRPLN-1
           ##-----------------------------------------------------------------------------------------##
           ## Récupère le contexte du plan                                                            ##
           ##-----------------------------------------------------------------------------------------##
           Call GET_CNX_FROM_PLAN([F:CIR]CPYSRC,[F:CIR]DPRPLN(GISEL),WICONTEXTE) From GLOBIENS
           ##---------------------------------------------------------------------------------------------##
           ## Récup date deb et fin d'exe pour contexte correspondant au plan parametré pour chaque sél   ##
           ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1      ##
           ##---------------------------------------------------------------------------------------------##
           Call GET_CNX_DAT([F:CIR]CPYSRC,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS
           If [M:CII]EFFDAT < WDDATE(1) or [M:CII]EFFDAT > WDDATE(2)  : # Debut et Fin exercice
               If WI1ERERR1     = G_NON
                  WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="=========================================================================================================="
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  Call ECR_TRACE_FIC("",GTRC_PARAM,mess(77,GML_MSGCIG,1),0,1) From TRACEABX3
                  Call ECR_TRACE_FIC("",GTRC_PARAM,mess(25,GML_MSGTRC,1),0,1) From TRACEABX3
                  WCLIGNE="---  ---------                ------------      --------------    ------------ "
                  Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                  WI1ERERR1     = G_OUI
               Endif
               WCDESIFIXE= format$("Kb:5X", [F:CIR]CPYSRC)
&                        + format$("Kb:13X",[F:CIR]REFSELCIG(GISEL)) + format$("Kb:12X", "")
&                        + format$("Kb:14X", string$([F:CIR]SALPRIPLN(GISEL) > 0, mess([F:CIR]SALPRIPLN(GISEL),GML_NPLAN,1)))
&                        + format$("Kb:4X", "")  + format$("DD2", WDDATE(1))
&                        + format$("Kb:10X", "") + format$("DD2", WDDATE(2))
&                        + format$("Kb:5X", "")  + mess(69,GML_MSGCIG,1)
               Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE    ,0,1) From TRACEABX3
               WITRTOK = G_NON
           Endif
       Next

       WCSOCSOURCE = [F:CIR]CPYSRC
    Endif
Next
Filter[F:CIR]

##---------------------------------------------------------------------------------------------##
## Controle que tous les plans gérés (par les sociétés cibles ) sont paramétrés                ##
##---------------------------------------------------------------------------------------------##
Local Integer WIPLN1
Local Integer WIPLN2

WCSOCSOURCE = ""
WCSOCCIBLE  = ""
WI1ERERR1   = G_NON

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCCIBLE <>  [F:CIR]CPYDES or WCSOCSOURCE <>  [F:CIR]CPYDES

        ##---------------------------------------------------------------------------------------------##
        ## Boucle sur les contextes  de la société cible                                               ##
        ##---------------------------------------------------------------------------------------------##
        Filter[F:CNX] Where ([F:CNX]CPY = [F:CIR]CPYDES)
        For [F:CNX]

           ##---------------------------------------------------------------------------------------------##
           ## Boucle sur les plans d'amortissements du contexte traité                                    ##
           ##---------------------------------------------------------------------------------------------##
           For WIPLN1 = 0 To [F:CNX]NBPLC-1
                  #*V5If [F:CNX]PLNPRO(WIPLN1) = G_OUI
                      WIPLANTROUVE = G_NON
                      For WIPLN2 = 0 To [F:CIR]NBRPLN-1
                           If [F:CNX]PLNCAA(WIPLN1)  = [F:CIR]DPRPLN(WIPLN2) or [F:CNX]PLNCAA(WIPLN1)  = [F:CIR]GALPLNDES

                                 WIPLANTROUVE = G_OUI
                           Endif
                      Next
                      If WIPLANTROUVE = G_NON

                          If WI1ERERR1     = G_NON
                                WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WCLIGNE="=========================================================================================================="
                                Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                                WI1ERERR1     = G_OUI
                           Endif
                           WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                           Call ECR_TRACE_FIC("",GTRC_PARAM,mess(107,GML_MSGCIG,1) + [F:CIR]CPYSRC + ' ' + mess(109,GML_MSGCIG,1) + [F:CIR]CPYDES  ,0,1) From TRACEABX3
                           WCLIGNE= '  ' + mess(108,GML_MSGCIG,1) + string$([F:CNX]PLNCAA(WIPLN1) > 0, mess([F:CNX]PLNCAA(WIPLN1),GML_NPLAN,1))
                           Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                           WITRTOK = G_NON
                      Endif
                  #*V5 Endif
           Next
        Next

        Filter[F:CNX]

        WCSOCCIBLE  = [F:CIR]CPYDES
        WCSOCSOURCE = [F:CIR]CPYSRC
    Endif
Next

Filter[F:CIR]

##---------------------------------------------------------------------------------------------##
## Controle date effet par rapport aux plans de l'onglet 'plans amortissement'                 ##
## pour les sociétés cibles                                                                    ##
##---------------------------------------------------------------------------------------------##
WI1ERERR2     = G_NON

Filter[F:CIR] Where ([F:CIR]CIGCOD =  [M:CII]CIGCOD)
For [F:CIR]
    If WCSOCCIBLE <>  [F:CIR]CPYDES
       GIPLN = 0

       ##---------------------------------------------------------------------------------------------##
       ## Lecture du plan d'amortissement suivant                                                     ##
       ##---------------------------------------------------------------------------------------------##
       For GIPLN = 0 To [F:CIR]NBRPLN-1
           WDDATEDEB1  = [0/0/0]
           WDDATEFIN1  = [0/0/0]
           WDDATEDEB2  = [0/0/0]
           WDDATEFIN2  = [0/0/0]

           ##-----------------------------------------------------------------------------------------##
           ## Récupère le contexte du plan                                                            ##
           ##-----------------------------------------------------------------------------------------##
           Call GET_CNX_FROM_PLAN([F:CIR]CPYDES,[F:CIR]DPRPLN(GISEL),WICONTEXTE) From GLOBIENS
           ##-----------------------------------------------------------------------------------------##
           ## Récup date deb et fin d'exe pour contexte correspondant au plan amortissement soc cible ##
           ## Récup date deb et fin d'exe pour contexte correspondant au plan modèle        soc cible ##
           ## Occurs : 1-->DATSTRFIY, 2-->DATENDFIY, 3-->DATSTRPER, 4-->DATENDPER, 5-->DATSTRFIY - 1  ##
           ##-----------------------------------------------------------------------------------------##
           Call GET_CNX_DAT([F:CIR]CPYDES,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS
           WDDATEDEB1 = WDDATE(1)
           WDDATEFIN1 = WDDATE(2)
           If [F:CIR]PLNTPL(GIPLN) <> 0
              Call GET_CNX_FROM_PLAN([F:CIR]CPYDES,[F:CIR]PLNTPL(GISEL),WICONTEXTE) From GLOBIENS
              Call GET_CNX_DAT([F:CIR]CPYDES,WICONTEXTE ,WDDATE,WICODERET) From GLOBIENS
              WDDATEDEB2 = WDDATE(1)
              WDDATEFIN2 = WDDATE(2)
           Endif
           If [M:CII]EFFDAT < WDDATEDEB1  or [M:CII]EFFDAT > WDDATEFIN1  or ([M:CII]EFFDAT < WDDATEDEB2 and WDDATEDEB2 <> [0/0/0])
&          or ([M:CII]EFFDAT > WDDATEFIN2 and WDDATEFIN2  <> [0/0/0])
               If WI1ERERR1     = G_NON
                    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="                            "  + mess(70,GML_MSGCIG,1) + "                                             "
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="=========================================================================================================="
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WI1ERERR2     = G_OUI
               Endif
               If WI1ERERR2     = G_NON
                    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    Call ECR_TRACE_FIC("",GTRC_PARAM,mess(78,GML_MSGCIG,1),0,1) From TRACEABX3
                    Call ECR_TRACE_FIC("",GTRC_PARAM,mess(28,GML_MSGTRC,1),0,1) From TRACEABX3
                    WCLIGNE="---  -------------------      -----------       --------------    ------------  "
                    Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WCLIGNE="" : Call ECR_TRACE_FIC("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
                    WI1ERERR2     = G_OUI
               Endif
               WCDESIFIXE= format$("Kb:5X", [F:CIR]CPYDES)
&                        + format$("Kb:13X", string$([F:CIR]DPRPLN(GIPLN) > 0,mess([F:CIR]DPRPLN(GIPLN),GML_NPLAN,1)))
&                        + format$("Kb:12X", "")
&                        + format$("Kb:14X", string$([F:CIR]PLNTPL(GIPLN) > 0,mess([F:CIR]PLNTPL(GIPLN),GML_NPLAN,1)))
&                        + format$("Kb:4X", "")  +   format$("DD2", WDDATE(1))
&                        + format$("Kb:10X", "") +   format$("DD2", WDDATE(2))
&                        + format$("Kb:5X", "") + mess(69,GML_MSGCIG,1)
               Call ECR_TRACE_FIC("",GTRC_PARAM,WCDESIFIXE    ,0,1) From TRACEABX3
               WITRTOK = G_NON
           Endif
       Next
       WCSOCCIBLE = [F:CIR]CPYDES
    Endif
Next

Filter[F:CIR]

Return
####################################################################################################
## $TEST_TOUS_PLANS_PARAMETRES :   Vérification que tous les plans sont parametres dans la CIG    ##
####################################################################################################
$TEST_TOUS_PLANS_PARAMETRES

Return
####################################################################################################
## $POST_CONTROLE_TRAITEMENT :   Post controle du traitement                                      ##
####################################################################################################
$POST_CONTROLE_TRAITEMENT

Return
####################################################################################################
## $KILL_GLOBAL : KIll de toutes les globales                                                     ##
####################################################################################################
KILL_GLOBAL

If dim(GISEL  )          >0      : Kill GISEL      : Endif
If dim(GIPLN  )          >0      : Kill GIPLN      : Endif
If dim(LIST_FCY)         >0      : Kill LIST_FCY   : Endif

Return
####################################################################################################
## $UNLOCK_ALL : Test si la société est lockée pour l'objet traité                                 ##
####################################################################################################
$UNLOCK_ALL
Local Char    WCOBJLOCK
Local Char    WCMESS1 (120)
Local Char    WCMESS2 (120)
Local Integer WINAMOBJ
Local Integer WIALLOBJLOCK
Local Integer WIUNOBJLOCK

WIUNOBJLOCK  = G_NON
WIALLOBJLOCK = G_NON
WCSOCSOURCE  = ""
WI1ERERR1     = G_NON

WCOBJLOCK   = 'FAS'
WIUNOBJLOCK = G_NON
Call  UNLOCK_SYMBOLE (WCOBJLOCK , "", "") From GLOBIENS
If WIUNOBJLOCK = G_OUI
           WIALLOBJLOCK = G_OUI
Endif

WCOBJLOCK   = 'DEP'
Call  UNLOCK_SYMBOLE (WCOBJLOCK , "", "") From GLOBIENS
If WIUNOBJLOCK = G_OUI
           WIALLOBJLOCK = G_OUI
Endif

Return
####################################################################################################
## UNLOCK_SOC_OBJET : Unlock de la société d'un objet                                             ##
####################################################################################################
$UNLOCK_SOC_OBJET

Return

####################################################################################################
## CREATION_ELTPHY_DES : Création des éléments physiques du bien dans la soc destinatrice         ##
####################################################################################################
 # FQ100398/13
$CREATION_ELTPHY_DES
Local Char    WSITECIBLE
Local Char    WCNUMERO
Local Integer STAT
Local Char    WPHYREFN
Local Char    LOC_DEF
Local Integer I
Local Integer LCDRET
Local Char WMESS(200)

Local Integer RET, STA : # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element

  # début 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien
  G_NEW_BIEN = G_OUI
  # fin 49517 (SYMEU) : Numérotation des éléments physiques à partir du bien

  Filter [PHYS] Where AASREF=[F:FASS]AASREF
  For [PHYS]

    Local Instance WCLASSE_OBJ Using C_PHYELT
    WCLASSE_OBJ = NewInstance  C_PHYELT AllocGroup null

    WCLASSE_OBJ.snapshotEnabled=1

    [L]RET = fmet WCLASSE_OBJ.AINIT()
    [L]RET = fmet WCLASSE_OBJ.AREAD([F:PHYS]PHYREF)


    [F:PHYC] = [F:PHYS]

    # Alimentation de la Société
    WCLASSE_OBJ.CPY    = [F:FASC]CPY

    # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
    WCLASSE_OBJ.FCY    = [F:FASC]FCY
    WCLASSE_OBJ.PHYREF = AVOID.ACHAR

    # Alimentation du bien rattaché
    WCLASSE_OBJ.AASREF = [F:FASC]AASREF

    # Alimentation de l'élément physique d'origine
    WCLASSE_OBJ.GRUORIPHY = [F:PHYS]PHYREF         # Elément origine CIG

    # Remise à zéro des mouvements en attente
    [L]STA = [V]CST_AOK
    While [L]STA = [V]CST_AOK
      [L]STA = fmet WCLASSE_OBJ.ADELLINE("PHYMVT", [V]CST_ALASTPOS)
    Wend

    # Alimentation de la localisation
    # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
    # WCLASSE_OBJ.LCTCOD = func PHYLCT_CSTD.GET_DEFAULT_LOCATION( [F:PHYC]FCY, LCDRET, WMESS)
    WCLASSE_OBJ.LCTCOD = func PHYLCT_CSTD.GET_DEFAULT_LOCATION( [F:FASC]FCY, LCDRET, WMESS)
    If (LCDRET) Then
      GMESSAGE = WMESS
      GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,GMESSAGE,1,1) From TRACEABX3  : # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
      WITRTOK  = G_NON
      GOK = 0
    Endif
    WCLASSE_OBJ.CREORI = GVML_COCESIG # Origine intragroupe

    # Alimentation des informations de création
#    [F:PHYC]UPDUSR   = ""
#    [F:PHYC]UPDDAT   = [0/0/0]

    [L]RET = fmet WCLASSE_OBJ.AINSERT()
    If [L]RET <> [V]CST_AOK
      [L]RET =  [V]CST_AFALSE
      GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(WCLASSE_OBJ)
      GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,GMESSAGE,1,1) From TRACEABX3  : # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
      WITRTOK  = G_NON
      GOK = 0
    Endif
    # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
    #FreeGroup WCLASSE_OBJ

    ##--------------------------------------------------------------------------------------------##
    ## Edition ligne dans compte-rendu                                                            ##
    ##--------------------------------------------------------------------------------------------##
    If [M:CII]EDIFAS = G_OUI
      # 49517 (SYMEU) : 4ème ligne : 24X au lieu de 22X
      WCLIGNE= WCLASSE_OBJ.CPY + format$("KB:4X", "")  +  format$("KB:21X", WCLASSE_OBJ.PHYREF)
&                          + format$("KB:20X", WCLASSE_OBJ.PHYDES1)  + '  '
&                          + format$("KB:21X", [F:FASC]AASREF)
&                          + format$("KB:24X", [F:FASC]GRUORICPY+ ' ' + [F:PHYC]GRUORIPHY)
&                          + format$("KB:22X", [F:FASC]GRUORICPY+ ' ' + [F:FASC]GRUORIAAS)
      Call ECR_TRACE_FIC ("",GTRC_CRACT1,WCLIGNE,0,1) From TRACEABX3
    Endif

    # Issue X3-61543 - 2017-11-02 by MWA : Intra group impossible if physical element
    FreeGroup WCLASSE_OBJ
  Next
  Filter [PHYS]

Return

