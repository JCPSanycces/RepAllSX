#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################
Subprog TRCMAJ80

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ80: Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Onerrgo

End
#################################################################################
$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume

