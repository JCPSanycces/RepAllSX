#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMAPPROVER_CSTD, Change Request - Approver Collection

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Increment collection row's line number (APPRLN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

      this.APPRLN = 1 + max (this.APARENT.CCMAPPROVER(1..maxtab(this.APARENT.CCMAPPROVER)).APPRLN)
Return


#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "APPRUSER.CONTROL"
      Gosub VALIDATE_APPROVER
    When "TRANSTYPE.CONTROL"
      Gosub CHECK_APPROVER_AUTHORISATION
  Endcase

Return

# --------------------------------------------------
# Validate Approver (APPRUSER)
$VALIDATE_APPROVER

  Local Char CCMAPPROVE(30)
  Local Char MESSAGE(100)

  ASTATUS = fmet this.ADELETEERROR("APPRUSER")

  Call PARAMUTIL("CCMAPPROVE", CCMAPPROVE, this.APPRUSER, "") From SUBAUS
  If (CCMAPPROVE <> "2")
    MESSAGE = func ASYRFNC.MES1(mess(75,2038,1),this.APPRUSER)
    ASTATUS = fmet this.ASETERROR("APPRUSER", MESSAGE, CST_AERROR)
  Endif

  If (ASTATUS = CST_AOK)
    Gosub CHECK_APPROVER_AUTHORISATION
  Endif

Return

# --------------------------------------------------
# Check Approver Site (Change Request) and Transaction Type authorisation.
$CHECK_APPROVER_AUTHORISATION

  Local Char ERROR_MESSAGE(100)
  Local Integer STAT

  ASTATUS = fmet this.ADELETEERROR("APPRUSER")
  If (fmet this.APARENT.CHECK_USER_SITE(this.APPRUSER, this.APARENT.SITE, this.TRANSTYPE) = CST_AERROR)

    Local Instance AUTILIS Using C_AUTILIS
    AUTILIS = NewInstance C_AUTILIS AllocGroup null
    STAT = fmet AUTILIS.AREAD(this.APPRUSER)

    ERROR_MESSAGE = func ASYRFNC.MES4(mess(59,2038,1),
&     this.APPRUSER,
&     AUTILIS.NOMUSR,
&     mess(this.TRANSTYPE,2039,1),
&     this.APARENT.SITE)
    ASTATUS = fmet this.ASETERROR("APPRUSER", ERROR_MESSAGE, CST_AERROR)

    FreeGroup AUTILIS

  Endif

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

