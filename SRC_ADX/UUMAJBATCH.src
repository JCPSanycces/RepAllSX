#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
## Init champ CNTERR dans les tables du serveur batch
##############################################################################
Call PATCH_X3(nomap)
End

Subprog PATCH(DOSSIER)
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Local Integer MAJ
If DOSSIER<>GDOSX3 : End : Endif
Local File ABATABT [ABA]  , ABATGRP [ABG] , ABATRQT [ABR]
If dim([F:ABR]CNTERR)<1 : End : Endif
# Mise à jour de la table 
Call ECR_TRACE(mess(81,125,1)-"ABATABT/ABATGRP/ABATRQT:"-time$,0) From GESECRAN
Trbegin [ABR]
 Update [ABG] Where CNTERR=0 With CNTERR=1
 Update [ABA] Where CNTERR=0 With CNTERR=1
 Update [ABR] Where CNTERR=0 With CNTERR=1
Commit

Close Local File
End

