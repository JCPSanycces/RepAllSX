####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
Gosub _ALOADATTRIBUTE_CTRNUM From WMC1EMPLOCTRUKI : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOCTRUKI : Gosub TESTALLSTAT
