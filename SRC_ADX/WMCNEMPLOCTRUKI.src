Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
For AINDCLA=1 To 3
 If this.UKADD(AINDCLA)<>null& find(this.UKADD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.UKADD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_TAXCOD From WMC1EMPLOCTRUKI : Gosub TESTALLSTAT
Gosub LNKPRO_NICAT From WMC1EMPLOCTRUKI : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC2EMPLOCTRUKI : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC2EMPLOCTRUKI : Gosub TESTALLSTAT
Gosub LNKPRO_TCH_CRY From WMC3EMPLOCTRUKI : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



