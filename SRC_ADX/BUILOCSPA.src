#<AdxTL>@(#)2.0.0.0 $Revision$
# Management of Cadastre data
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_RENT
  When "AV_CHOIX" : Affzo [M:BLS]
  When "OK"       : Gosub OK_RENT
  When "END"      : Gosub END_RENT
Endcase
Return

$OUVRE_RENT

If clalev([M:BLS])=0: Local Mask BUILOCSPA [BLS]: Endif
If clalev([F:BLS])=0: Local File BUILOCSPA [BLS]: Endif
Local Integer NL
NL=val(PARAM(1))
Raz [M:BLS]
If dim ([M:VSP2]BUILOC)>0  and [M:VSP2]BUILOC(NL)<>0
    Read [BLS]BLS0=[M:VSP2]NUM(NL)
    If !fstat
        [M:BLS]BUILOC=[F:BLS]BUILOC
        [M:BLS]CDRREF=[F:BLS]CDRREF
        [M:VSP2]BUILOC(NL)=[M:BLS]BUILOC
        [M:VSP2]CDRREF(NL)=[M:BLS]CDRREF
        Affzo [M:VSP2]BUILOC(NL)
        Affzo [M:VSP2]CDRREF(NL)

    Elsif [M:VSP2]CDRREF(NL)<>""
        [M:BLS]BUILOC=[M:VSP2]BUILOC(NL)
        [M:BLS]CDRREF=[M:VSP2]CDRREF(NL)
    Endif
Endif

Affzo [M:BLS]

Return

$OK_RENT

    [M:VSP2]BUILOC(NL)=[M:BLS]BUILOC
    [M:VSP2]CDRREF(NL)=[M:BLS]CDRREF
    Affzo [M:VSP2]BUILOC(NL)
    Affzo [M:VSP2]CDRREF(NL)

Return

$END_RENT
NL=-1
Return

