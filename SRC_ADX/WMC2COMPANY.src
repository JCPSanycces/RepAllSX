#<AdxTL>@(#)0.0.0.0 $Revision$Class Company
# Supervisor
## ACLA-CLASSE ## COMPANY
# 2018-11-06 07:04:11 169

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 31 : AUUID Single identifier ( Field  Uuident)
####################################################################

$SET_AUUID
If [L]_AOLDVAL<>this.AUUID
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_AUUID
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.AUUID
 Gosub PROPAGATE_AUUID
Endif
Return

$INIT_AUUID
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "AUUID"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_AUUID
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "AUUID"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_AUUID                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_AUUID                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_AUUID
[L]CURPRO = "AUUID"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.AUUID=NullUuid
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_AUUID
[L]CURPRO = "AUUID"
Return

$_AOTHERS_AUUID
[L]CURPRO = "AUUID"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_AUUID
[L]CURPRO = "AUUID"
Return

$PROPAGATE_AUUID
this.isReadonly = 0
[L]CURPRO = "AUUID"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_AUUID
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "AUUID"
$_LNKPRO_AUUID
Return


####################################################################
# 32 : LOGO Logo ( Field ABIMG 1)
####################################################################

$GET_LOGO
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "LOGO"
Local Char _CNT(100)
Local Tinyint _EXI : [L]_EXI=1
[L]ASTATUS = fmet this.AREAD_BLB("LOGO",
& "LOGO"
& +[V]CST_AURLSEPLOB+this.CPY
& +[V]CST_AURLSEPLOB+""
& +[V]CST_AURLSEPLOB+""
& ,[L]_CNT,this.LOGO)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isLoaded")<>"true"
 [L]ASTATUS = fmet this.ASETATTRIBUTE([L]CURPRO,"$isLoaded","true")
Endif
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return

$SET_LOGO
If fmet this.AGETATTRIBUTE("LOGO","$isLoaded")<>"true" or [L]_AOLDVAL<>this.LOGO
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_LOGO
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If fmet this.AGETATTRIBUTE("LOGO","$isLoaded")<>"true" or [L]_AOLDVAL<>this.LOGO
 Gosub PROPAGATE_LOGO
Endif
Return

$INIT_LOGO
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "LOGO"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_LOGO
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "LOGO"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_LOGO                  : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_LOGO                  : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_LOGO
[L]CURPRO = "LOGO"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & len(this.LOGO)=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_LOGO
[L]CURPRO = "LOGO"
Return

$_AOTHERS_LOGO
[L]CURPRO = "LOGO"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_LOGO
[L]CURPRO = "LOGO"
Return

$PROPAGATE_LOGO
this.isReadonly = 0
[L]CURPRO = "LOGO"
[L]ASTATUS = fmet this.ASETATTRIBUTE([L]CURPRO,"$isLoaded","true")
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_LOGO
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "LOGO"
$_LNKPRO_LOGO
Local Tinyint _EXI : [L]_EXI=1
Gosub READ_EXI_LOGO From WMC0COMPANY
[L]ASTATUS = fmet this.ASETATTRIBUTE("LOGO","$isLobFound",func ASYRSUB.BOOLEAN_TO_SYR([L]_EXI+1))
Return


####################################################################
# 35 : ORICERFLG Self-certification of origin ( Field Local menu number 1)
####################################################################

$SET_ORICERFLG
If [L]_AOLDVAL<>this.ORICERFLG
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_ORICERFLG
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.ORICERFLG
 Gosub PROPAGATE_ORICERFLG
Endif
Return

$INIT_ORICERFLG
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "ORICERFLG"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.ORICERFLG=0 and fmet this.AGETATTRIBUTE("ORICERFLG","$isMandatory")="true"
 this.ORICERFLG = 1
Endif
Return
 
$CONTROL_ORICERFLG
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "ORICERFLG"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_ORICERFLG             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_ORICERFLG             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_ORICERFLG
[L]CURPRO = "ORICERFLG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.ORICERFLG=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ORICERFLG
[L]CURPRO = "ORICERFLG"
If this.ORICERFLG<0 or this.ORICERFLG>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.ORICERFLG)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_ORICERFLG
[L]CURPRO = "ORICERFLG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ORICERFLG
[L]CURPRO = "ORICERFLG"
Return

$PROPAGATE_ORICERFLG
this.isReadonly = 0
[L]CURPRO = "ORICERFLG"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ORICERFLG
Gosub DECLARE_VAR From WMC0COMPANY
[L]CURPRO = "ORICERFLG"
$_LNKPRO_ORICERFLG
Return

$_ALOADATTRIBUTE_ORICERFLG
[L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isMandatory","true")
Return


