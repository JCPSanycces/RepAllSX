#JOJAC - 2016-08-04 - X3PEOP-??? - START
Subprog CONTECH(COD)
Variable Char    COD()

If GFONCTION = "GESECH" | COD="" : End : Endif

If clalev([F:ECH])=0 : Local File EXCEPTH [ECH] : Endif

If COD <> ""
  Filter [F:ECH] Where COD=[L]COD
  Read [F:ECH] First
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:ECH]
      Read [F:ECH]ECH0 = GCURLEG;[L]COD
      If fstat
        Filter [F:ECH] Where COD=[L]COD
        Read [F:ECH] First
        GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:ECH]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:ECH]
End

$SEL_TABLE
Case TABLE
  When "HRSELECH"
    If clalev ([F:ECH])=0 : Local File EXCEPTH [ECH] : Endif
    Filter [F:ECH]
    OBJET     = "ECH"
    If PARAM(1)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ECH]LEG="'+PARAM(1)+'" | [F:ECH]LEG="")',"&") From GOBJSUB
    Endif
Endcase
Return

Subprog TUNECH(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONECH)
 TOKILL = 1
Endif
If clalev([F:ECH])=0 : Local File EXCEPTH [ECH] : Endif
# To update the PRF code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#If no code is specified, it's better to select one of the curent legislation
  Filter [ECH] Where LEG=GCURLEG
  Read [F:ECH] First
  Filter [ECH]
  If !fstat : VCOD=[F:ECH]COD : Endif
Else
  Read [ECH]ECH0 = GCURLEG;VCOD
Endif
Call OBJET("ECH",VCOD,GCURLEG) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif
End
#JOJAC - 2016-08-04 - X3PEOP-??? - END

