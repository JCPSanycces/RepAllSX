#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
GBIDC1 = ""
Call OBJET("ECH",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "SETBOUT"     : Gosub SETBOUT
 When "FERME"       : Gosub FERME
 When "EXEC"
  Case GACTION
   When "EXCEPTION" : Gosub EXCEPTION
  Endcase
 When "ANNULE"      : Gosub ANNULE
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

########################
$OUVRE
Local Integer I, J, POS
Local Char CTRNUM([V]GLONHRCTR), REFNUM([V]GLONEML), CTRCRI([V]GLONEML+[V]GLONHRCTR+1+10)
##**82073
Local Date CTRDAT
If clalev([F:ECH2])=0: Local File EXCEPTH [ECH2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:ECH]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:ECH0]LEG)>=0 : [M:ECH0]LEG=[F:ECH]LEG: Endif
 GCURLEG=[F:ECH]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:ECH0]LEG)>=0
  GCURLEG=[M:ECH0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

########################
$LIENS
If dim([F:ECH]LEG)>0
  GCURLEG=[F:ECH]LEG
Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M:ECH0]DES,"EXCEPTH","DES",GCURLEG,[M:ECH0]COD) From ATEXTRA

nolign = 0
For [ECV] Where LEG=GCURLEG and COD=[F:ECH]COD
 nolign += 1
 [M:ECH3] = [F:ECV]
 [M:ECH3]DATDEB(nolign-1) = [F:ECV]DATSTR
 [M:ECH3]DATFIN(nolign-1) = [F:ECV]DATEND
Next
[M:ECH3]NBVRA = nolign
nolign = 0
For [ECD]ECD0 Where LEG=GCURLEG and COD=[F:ECH]COD
 nolign += 1
 [M:ECH2] = [F:ECD]
Next
[M:ECH2]NBRUB = nolign
nolign = 0
For [ECC] Where LEG=GCURLEG and COD=[F:ECH]COD
 nolign += 1
 [M:ECH4] = [F:ECC]
 [M:ECH4]DATSTR(nolign-1) = [F:ECC]DATSTR
 [M:ECH4]DATEND(nolign-1) = [F:ECC]DATEND
Next
[M:ECH4]NBCUM = nolign
##**82073
Raz [L]REFNUM, [L]CTRNUM, [L]I, [L]J, [L]CTRCRI, [L]CTRDAT
For [L]I = 0 To min(dim([F:ECH]CTRCRI) - 1, dim([M:ECH1]REFNUM) - 1)
    If [F:ECH]CTRCRI([L]I) = ""
        Break
    Endif
    [L]CTRCRI = [F:ECH]CTRCRI([L]I)
    [L]POS = instr(1, [L]CTRCRI, "~")
    If [L]POS > 0
        [L]REFNUM = mid$([L]CTRCRI, 1, [L]POS-1)
        [L]CTRCRI = right$([L]CTRCRI, [L]POS+1)
        [L]POS = instr(1, [L]CTRCRI, "~")
        If [L]POS > 0
            [L]CTRNUM = mid$([L]CTRCRI, 1, [L]POS-1)
            [L]CTRDAT = right$([L]CTRCRI, [L]POS+1)
        Endif
    Endif
    Read [F:HRCTR]CTR0=[L]REFNUM;[L]CTRNUM;[L]CTRDAT
    If ! fstat
            [M:ECH1]REFNUM([L]J) = [F:HRCTR]REFNUM
            [M:ECH1]CTRNUM([L]J) = [F:HRCTR]CTRNUM
            [M:ECH1]CTRDAT([L]J) = [F:HRCTR]CTRDAT

            [L]J += 1
            If [L]J >= dim([M:ECH1]REFNUM)
                # mess(26, 100, 1) : Tableau plein
                Call ERREUR("NBCTR : "-mess(26,100,1)) From GESECRAN
                Break
            Endif
    Endif
Next
[M:ECH1]NBCTR = [L]J
Return

########################
$SETBOUT
If !CLECUR or GREP<>""
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return

#########################
$INICRE
Gosub SET_CTRCRI
Return

#########################
$INIMOD
Gosub SET_CTRCRI
Return

#########################
$SET_CTRCRI
##**82073
# Sauvegarde de REFNUM~CTRNUM~CTRDAT dans CTRCRI
# pour évaluation de l'exception au calcul de la rubrique
Raz [F:ECH]CTRCRI
For [L]I = 0 To min([M:ECH1]NBCTR - 1, dim([F:ECH]CTRCRI) - 1)
    If [M:ECH1]REFNUM([L]I) = "" : Break : Endif
    [F:ECH]CTRCRI([L]I) = [M:ECH1]REFNUM([L]I) + "~" + [M:ECH1]CTRNUM([L]I)+ "~" + format$("D:YYYYMMDD",[M:ECH1]CTRDAT([L]I))
Next
Return

########################
$MODIF
Delete [ECD] Where LEG=GCURLEG & COD=[F:ECH]COD
If fstat=1
 GOK = -1 : GLOCK = "$EXCEPTD"-[F:ECH]COD : Return
Endif
Delete [ECV] Where LEG=GCURLEG & COD=[F:ECH]COD
If fstat=1
 GOK = -1 : GLOCK = "$EXCEPTV"-[F:ECH]COD : Return
Endif
Delete [ECC] Where LEG=GCURLEG & COD=[F:ECH]COD
If fstat=1
 GOK = -1 : GLOCK = "$EXCEPTC"-[F:ECH]COD : Return
Endif
Gosub CREATION
Return

########################
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
For nolign=1 To [M:ECH2]NBRUB
 [F:ECD] = [F:ECH]
 [F:ECD] = [M:ECH2]
 [F:ECD]LIG = nolign
 Write [ECD]
 If fstat
  GOK = 0 : Call FSTA("ECD") From GLOCK : Break
 Endif
Next nolign
For nolign=1 To [M:ECH3]NBVRA
 [F:ECV] = [F:ECH]
 [F:ECV] = [M:ECH3]
 [F:ECV]LIG = nolign
 [F:ECV]DATSTR = [M:ECH3]DATDEB(nolign-1)
 [F:ECV]DATEND = [M:ECH3]DATFIN(nolign-1)
 Write [ECV]
 If fstat
  GOK = 0 : Call FSTA("ECV") From GLOCK : Break
 Endif
Next nolign
For nolign=1 To [M:ECH4]NBCUM
 [F:ECC] = [F:ECH]
 [F:ECC] = [M:ECH4]
 [F:ECC]LIG = nolign
 [F:ECC]DATSTR = [M:ECH4]DATSTR(nolign-1)
 [F:ECC]DATEND = [M:ECH4]DATEND(nolign-1)
 Write [ECC]
 If fstat
  GOK = 0 : Call FSTA("ECC") From GLOCK : Break
 Endif
Next nolign
Return

########################
$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("EXCEPTH","DES",CLECUR1,"","EXCEPTH","DES",GCURLEG,[F:ECH]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:ECH0]DES,"EXCEPTH","DES",GCURLEG,[F:ECH]COD) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("EXCEPTH","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call SETPAR From GENPLAN
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("EXCEPTH","DES",[L]CODE,SUPP) From ATEXTRA
Return

########################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
  Look [ECH2]ECH0=VALEUR;[M:ECH0]COD
  If fstat>1
    Effzo [M:ECH1] : Effzo [M:ECH2] : Effzo [M:ECH3] : Effzo [M:ECH4]
  Endif
Endif
GCURLEG = VALEUR
End


Subprog C_RUB(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]RUB(0..[M]NBRUB-1)) From OBJDIV
End

Subprog C_VRA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VRA(0..[M]NBVRA-1)) From OBJDIV
End

Subprog C_EMPSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]EMPSTR & [M]EMPEND=""
 [M]EMPEND = VALEUR
Endif
End

Subprog C_PER(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR,[M]PER(0..[M]NBCUM-1)) From OBJDIV
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
Local Integer I
VALEUR = toupper(VALEUR)
VALEUR = left$(VALEUR+string$(12,"N"),12)
For I=1 To len(VALEUR)
 If mid$(VALEUR,I,1)<>"O" & mid$(VALEUR,I,1)<>"N"
  mkstat = 1 : Break
 Endif
Next I
End

Subprog AV_REFNUM(VALEUR)
Variable Char     VALEUR
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
 Call SELCTR([M:ECH1]REFNUM(nolign-1),eomonth(GMOIPAY),GMOIPAY,VALEUR) From DIVPAYE
Endif
If [F:ID]FLGMULCTR<>2 : mkstat=2 : End : Endif
End

$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

##########################################################################
## Liste des salariés
##########################################################################
$EXCEPTION
Local Char ECHDES([V]GLONAX3)
Read [ECH]ECH0 = GCURLEG;[M:ECH0]COD
Call LECTEXTRA(ECHDES,"EXCEPTH","DES",GCURLEG,[F:ECH]COD) From ATEXTRA
#MIPEA - 2016-06-10 - REQ 114309 US47 - START
###Call POPULATION(GCURLEG,[F:ECH]FCY,[F:ECH]PRF,[F:ECH]SRV,[F:ECH]EMPSTR,[F:ECH]EMPEND,[F:ECH]POP
###&              ,[F:ECH]CRI, [F:ECH]CTRCRI,
###&              mess(113,10703,1)-":"-[F:ECH]COD-ECHDES)
#JASMI - 2017-10-17 - X3-60008 - START
#Call POPULATION(GCURLEG,[F:ECH]FCY,[F:ECH]PRF,[F:ECH]SRV,[F:ECH]EMPSTR,[F:ECH]EMPEND,[F:ECH]POP
#&              ,[F:ECH]CRI, [F:ECH]CTRCRI,
#&              mess(113,10703,1)-":"-[F:ECH]COD-[F:ECH]DES)
Call POPULATION(GCURLEG,[F:ECH]FCY,[F:ECH]PRF,[F:ECH]SRV,[F:ECH]EMPSTR,[F:ECH]EMPEND,[F:ECH]POP
&              ,[F:ECH]CRI, [F:ECH]CTRCRI,
&              mess(113,10703,1)-":"-[F:ECH]COD-[M:ECH0]DES)
#JASMI - 2017-10-17 - X3-60008 - END
#MIPEA - 2016-06-10 - REQ 114309 US47 - END

TRA = 1
Return

##################################################################################
Subprog POPULATION(LEG,SITE,PROFIL,SERVICE,MATDEB,MATFIN,POPUL,CRITERE,TCTRCRI,TIT)
Value Char LEG
Value Char SITE
Value Char PROFIL
Value Char SERVICE
Value Char MATDEB
Value Char MATFIN
Value Char POPUL
Value Char CRITERE
Value Char TCTRCRI()()
Value Char TIT

Local Integer NBSAL , NBSIT , WOK, I
Local Char    LIGNE(250) , MATRI(GLONEML)
Local Date    DATMAT
Local Char CTRCRI(type([L]TCTRCRI)-10)

Gosub OUVRE From WPDEFTABLE
If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

Call OUVRE_TRACE(mess(115,10703,1)) From LECFIC : # Liste des salariés concernés
Call ECR_TRACE(TIT,0) From GESECRAN : # Exception
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
DATMAT = date$
NBSAL = 0
For [ID]ID2(1) Where ENAFLG=2 & FLGPAY=2
 NBSIT = 0
 Read [FCY]FCY0 = [F:ID]FCY
 Read [CPY]CPY0 = [FCY]LEGCPY
 If [CPY]LEG=LEG
   For [ID]ID2(2)
    For [ID]ID2
     MATRI = [F:ID]REFNUM
     Gosub LECEMP From WPDEFTABLE
     WOK = 1
     If (SITE<>""    & [F:HRCTR]ETRFCY<>SITE)
&     | (PROFIL<>""  & [F:HRCTR]PROPRF<>PROFIL)
&     | (SERVICE<>"" & [F:HRCTR]ETRSRV<>SERVICE)
&     | (MATDEB<>""  & MATRI<MATDEB)
&     | (MATFIN<>""  & MATRI>MATFIN)
      WOK = 0
     Endif
     If WOK & POPUL<>""
      Read [HRPOA]POA0 = POPUL;MATRI
      If fstat
       WOK = 0
      Endif
     Endif
     If WOK & CRITERE<>""
      If !evalue(CRITERE)
       WOK = 0
      Endif
     Endif

     # (C) PROSPER : si tableau des contrats , alors on regarde si le salarié apparaît à l'intérieur
     # P06 / 66101

     If WOK & [L]TCTRCRI(0) <> ""

          # Balayage des contrats

          WOK = 0    : # Par principe, il n'est pas dans notre tableau

          For [L]I = 0 To dim([L]TCTRCRI)-1
              [L]CTRCRI = [L]TCTRCRI([L]I)
              If [L]CTRCRI = "" : Break : Endif : # Sortie anticipée, dernier élément chargé trouvé.
              If pat([L]CTRCRI, [L]MATRI + "~*") : # On a une entrée correspondant au salarié
                  [L]WOK = 1 : Break
              Endif
          Next

     Endif

     If WOK
      LIGNE  = format$("K:"+num$(GLONEML+2)+"X",[F:ID]REFNUM)
      LIGNE += [F:ID]NAM-[F:ID]SRN
      Gosub LIGNE
     Endif
    Next
   Next
   If NBSIT
    Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
   Endif
 Endif : #End If [CPY]LEG=LEG
Next
If NBSAL=0
 Call ECR_TRACE(mess(116,10703,1),0) From GESECRAN : # Aucun salarié concerné
Else
 Call ECR_TRACE(mess(117,10703,1)-":"-num$(NBSAL),0) From GESECRAN : # Nombre de salariés concernés
Endif
Call FERME_TRACE From LECFIC
End

$LIGNE
If NBSIT=0
 Gosub TETE
Endif
Call ECR_TRACE(LIGNE,0) From GESECRAN
NBSAL += 1
NBSIT += 1
Return

$TETE
Call ECR_TRACE(mess(43,10702,1)-":"-[F:ID]FCY-[F:FCY]FCYNAM,0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Return

#####################################################################
# CHARGE_CONTRAT : renvoi un tableau de contrat
#####################################################################
Subprog CHARGE_CONTRAT(FCY, PRF, SRV, EMPSTR, EMPEND, POP, CRI, DAT1, DAT2,
&                        NBCTR, TREFNUM, TCTRNUM, TCTRDAT, SILENCE)
Value Char FCY(), PRF(), SRV(), EMPSTR(), EMPEND(), POP(), CRI()
Variable Integer NBCTR
Variable Char TREFNUM()(), TCTRNUM()()
Variable Date TCTRDAT()
Value Integer SILENCE

If !clalev([F:ID])    : Local File EMPLOID  [ID]    : Endif
If !clalev([F:AD])    : Local File EMPLOAD  [AD]    : Endif
If !clalev([F:CPT])   : Local File EMPLOCPT [CPT]   : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:HRPOA]) : Local File POPULA   [HRPOA] : Endif
If !clalev([F:FCY])   : Local File FACILITY [FCY]   : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]   : Endif

Local Char CRITERE(250)
Local Integer OK, STATUT

If [L]FCY <> ""
    If [L]CRITERE <> "" : [L]CRITERE -= "& " : Endif
    [L]CRITERE += "[F:HRCTR]ETRFCY = [L]FCY"
Endif

If [L]PRF <> ""
    If [L]CRITERE <> "" : [L]CRITERE -= "& " : Endif
    [L]CRITERE += "[F:HRCTR]PROPRF = [L]PRF"
Endif

If [L]EMPSTR <> ""
    If [L]CRITERE <> "" : [L]CRITERE -= "& " : Endif
    [L]CRITERE += "[F:HRCTR]REFNUM >= [L]EMPSTR"
Endif

If [L]EMPSTR <> ""
    If [L]CRITERE <> "" : [L]CRITERE -= "& " : Endif
    [L]CRITERE += "[F:HRCTR]REFNUM <= [L]EMPEND"
Endif

# Seuls les contrats "valides" sont proposés en selection, il est possible
# de saisir volontairement un contrat "invalide"
If [L]CRITERE <> "" : [L]CRITERE -= "& " : Endif

##**82073
[L]CRITERE += "[F:HRCTR]CTRDAT<=[L]DAT2 & ([F:HRCTR]XITDAT = [0/0/0] or [F:HRCTR]XITDAT>=[L]DAT1)"

If [L]CRITERE = "" : [L]CRITERE = "1" : Endif

# Si présence d'une population, on lance le balayage à partir de cette dernière
# statistiquement le critère n'en sera que plus pertinent.
# On fait une jolie jointure pour tenter de prendre en compte un maximum d'éléments
# sélectionnables via le critère libre
[L]STATUT = 1
If [L]POP <> ""
    Link [F:HRPOA] With
&        [F:ID]ID0 ~= [F:HRPOA]REFNUM ,
&        [F:AD]AD0 = [F:HRPOA]REFNUM ,
&        [F:CPT]CPT0 = [F:HRPOA]REFNUM
&        As [LNK]
&        Where [F:HRPOA]COD = [L]POP

    For [F:LNK]
        Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:HRPOA]REFNUM
&                        & evalue([L]CRITERE)
##**82073
#&                        Order By Key CLE = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT Desc
#        For [F:HRCTR]CLE(2)
        For [F:HRCTR]
            Gosub MEMO_CHARGE_CONTRAT
            If [L]STATUT < 1 : Break 2 : Endif
        Next
        Filter [F:HRCTR]
    Next
Else
    # Pas de population, on part sur les contrats en espérant que le critère soit
    # relativement discriminant
    Link [F:HRCTR] With
&        [F:ID]ID0 ~= [F:HRCTR]REFNUM ,
&        [F:AD]AD0 = [F:HRCTR]REFNUM ,
&        [F:CPT]CPT0 = [F:HRCTR]REFNUM
&        As [LNK]
&        Where evalue([L]CRITERE)
##**82073
#&        Order By Key CLE = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT Desc
#    For [F:LNK]CLE (2)
    For [F:LNK]
        Gosub MEMO_CHARGE_CONTRAT
        If [L]STATUT < 1 : Break : Endif
    Next
Endif
End

########################
$MEMO_CHARGE_CONTRAT
[L]OK = 1
# Critère libre
If [L]CRI <> ""
    If not evalue([L]CRI)
        [L]OK = 0
    Endif
Endif
#Contrôle LEG du contrat
If GCURLEG<>""
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  If !fstat : Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ : Endif
  If (fstat | GCURLEG<>[F:CPY]LEG) : [L]OK = 0 : Endif
Endif
# Autorisation d'accès
If [L]OK = 1
    Call CONTROLE([F:HRCTR]REFNUM, [F:HRCTR]CTRDAT, [F:HRCTR]CTRNUM, "", [L]OK, 1) From DIVPAYE
    If [L]OK = 1
        If [L]NBCTR >= dim([L]TREFNUM)
            If [L]SILENCE <> 2
                # mess(26,100,1) : Tableau plein
                Call MESSAGE(mess(26,100,1)) From GESECRAN
            Endif
            [L]STATUT = 0 : Return
        Endif
        [L]TREFNUM([L]NBCTR) = [F:HRCTR]REFNUM
        [L]TCTRNUM([L]NBCTR) = [F:HRCTR]CTRNUM
        [L]TCTRDAT([L]NBCTR) = [F:HRCTR]CTRDAT
        [L]NBCTR += 1
    Endif
Endif
Return

#####################################
# B1_NBCTR : Chargement des contrats
#####################################
Subprog B1_NBCTR

Local Integer NBCTR, OK
[L]OK = 2

# Si aucun critère ... interdiction de charger quelquechose qui manifestement fera exploser le
# tableau
If vireblc([M:ECH1]FCY+[M:ECH1]PRF+[M:ECH1]SRV+[M:ECH1]EMPSTR+[M:ECH1]EMPEND+
&                [M:ECH1]POP+[M:ECH1]CRI, 4) = ""
    # mess(169,10702,1) : Aucun filtre défini - Opération impossible
    Call ERREUR(mess(169,10702,1)) From GESECRAN
    mkstat = 2 : End
Endif

If [M:ECH1]NBCTR > 0
    # mess(161,10702,1) : Attention, des données sont présentes, elles seront effacées.
    # mess(172,100,1) : Voulez-vous-poursuivre le traitement en cours
    Call OUINON(mess(161,10702,1)+"\"+mess(172, 100, 1),
&                [L]OK) From GESECRAN
Endif

If [L]OK = 2
    Raz [M:ECH1] NBCTR
    Raz [L]NBCTR
    Call CHARGE_CONTRAT([M:ECH1]FCY, [M:ECH1]PRF, [M:ECH1]SRV, [M:ECH1]EMPSTR, [M:ECH1]EMPEND,
&                    [M:ECH1]POP, [M:ECH1]CRI, GMOIPAY, eomonth(GMOIPAY),
&                    [L]NBCTR, [M:ECH1]REFNUM, [M:ECH1]CTRNUM, [M:ECH1]CTRDAT, 1)
    [M:ECH1]NBCTR = [L]NBCTR
    Affzo [M:ECH1]

    mkstat = 4    : # Déclenchement du passage en modif

Endif
End
######################################################################################
