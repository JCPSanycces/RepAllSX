#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ATD",GBIDC1,GBIDC2) From GOBJET
End

#### SUBTRD : Traduction Menu & Messages   ##########
$ACTION
Case ACTION
 When "OUVRE_BOITE"      : Gosub OUVRE_BOITE
 When "OUVRE"            : Gosub OUVRE
 When "FERME"            : Gosub FERME
 When "FILTRE"           : Gosub FILTRE
 When "FILGAUCHE"        : Gosub FILGAUCHE 
 When "TIROIR"           : Gosub TIROIR 
 When "LIENS"            : Gosub LIENS
 When "VERIF_MOD"        : Gosub VERIF_MOD
 When "SETBOUT"          : Gosub SETBOUT
 When "ABANDON"          : Gosub ABANDON
 When "AFFMASK"          : Gosub AFFMASK

 When "SEL_LISTE"        : Gosub SEL_LISTE
Endcase
Return

$OUVRE_BOITE
Local Char BROWA(20)
I = find("ZZZ",OBJLIS(1..dim(OBJLIS)-1))
If I
 BROWA = "GAU_CHE"+num$(I)
Endif
Return
 
$OUVRE
Gosub DEFVAR From AGLOBTRAD
If filinfo(filpath("",GMAGIC,""),0)>=0

        # rien n'est fait en web pour remonter les trad dans superv
        # alors je desactive la fonction si web.
        If GBROWS <>0
            GERR = 1
            GMESSAGE = mess (127,100,1)
            OK = 0    
        Else
             For ILAN=1 To GNBLANSTD
                 If GUSER=GUSRLAN(ILAN) and GLANGUE=GLANSTD(ILAN) and nomap=GREFER(ILAN)
                   # idem si en c/s mais avec les user X...
                    GERR = 1
                    GMESSAGE = mess (127,100,1)
                    OK = 0    
                 Endif
            Next ILAN
        Endif
Endif





If !clalev([F:AST2]) : Local File APLSTD [AST2] : Endif
[M:TRA2]LAN = GLANREF
Return

$FERME
Return

$AFFMASK
[M:TRA2]LANCHP = 1       #val par défaut pour ini cle de lecture
[M:TRA2]LANNUM = 1       #(evite msg "acces impossible a cette fiche")
Return

####################################################################
$FILTRE
Default File [AST]
If [M:TRA2]LAN=""
 [M:TRA2]LAN = GLANREF
Endif
FILTSUP = '(([M:TRA2]LAN<>""&[F:AST]LAN=[M:TRA2]LAN)|([M:TRA2]LAN=""&[F:AST]LAN=GLANGUE)) &'
FILTSUP += '[F:AST]LANCHP<>0 &[F:AST]LANCHP <>200 &[F:AST]LANCHP< 10000 & [F:AST]LANNUM<>0'
Return

$FILGAUCHE
# filtre pour affichage liste gauche : Ne pas mettre les records avec LANNUM=0
FILGAUSUP =  "[F:AST]LAN=[M:TRA2]LAN & [F:AST]LANCHP<>0 & [F:AST]LANCHP<>200"
FILGAUSUP -= "& [F:AST]LANCHP<>10000 & [F:AST]LANNUM<>0"
Return

#rajouté le 03/08/01 pour test Web car les sous-niveaux ne sont pas rechargés
$TIROIR
If currbox = BROWA
 Gosub FILGAUCHE
 Gosub REMPLIT_1 From =WINPROG
Endif
Return

$ABANDON
If not GIMPORT
   Effzo [M:TRA2]ZTEXTE
   Effzo [M:TRA2]LANCHP
   Effzo [M:TRA2]LANNUM
   Effzo [M:TRA2]LANMES
Endif

$LIENS
If not GIMPORT
    If GLANTRAD<>""
     [M]ZLAN = GLANTRAD
     Read [AST2]CLE = [F:AST]LANCHP;[F:AST]LANNUM;GLANTRAD
     If fstat = 0   
      [M:TRA2]ZTEXTE = [F:AST2]LANMES
     Else
      [M:TRA2]ZTEXTE = "?"
     Endif
    Endif
Endif
Return

$VERIF_MOD
Gosub MISE_A_JOUR
If not GIMPORT
 Gosub DEGRISE_CLE From =WINPROG
 REP = "" : GREP = ""
 OK  = 0
Endif  
Return

$MISE_A_JOUR
If [M:TRA2]LANCHP = 0 : Return : Endif

Trbegin [AST]    
 Readlock [AST]CLE =[M:TRA2]LANCHP;[M:TRA2]LANNUM;[M:TRA2]ZLAN
 If fstat=1 
  GOK=-1 : GLOCK="$APLSTD"-num$([M:TRA2]LANNUM) : Goto ROLL_TR_MTEX 
 Elsif fstat  
  If vireblc([M:TRA2]ZTEXTE,0) <>  ""  
   [F:AST]LAN     = [M:TRA2]ZLAN
   [F:AST]LANNUM  = [M:TRA2]LANNUM
   [F:AST]LANMES  = [M:TRA2]ZTEXTE
   [F:AST]CREDAT  = date$  
   [F:AST]UPDDAT  = date$ 
   If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM  = time : Endif
   [F:AST]CREUSR  = GUSER 
   [F:AST]UPDUSR = GUSER
   Write [AST]
  Endif  
 Else  
  [F:AST]LANMES  = [M:TRA2]ZTEXTE
  [F:AST]UPDDAT  = date$   
  If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM  = time : Endif
  [F:AST]UPDUSR  = GUSER
  Rewrite [AST]     
 Endif  
 If fstat 
  GOK=0 : Call FSTA("AST") From GLOCK : Goto AB_TR_MTEX 
 Endif 
Commit
Return

$AB_TR_MTEX    
Rollback    
Return    
    
$ROLL_TR_MTEX    
Call ROLL From GLOCK    
If GROLL : Return : Else : Goto MISE_A_JOUR : Endif     

$SETBOUT
# Laisser les boutons Enregistre/Abandon /FIn
#Supprimer les boutons Creer/Supprimer
If !GIMPORT
 Call VIREBOUT (CHAINE,"AC") From GOBJET   # A pour annul/supp et C pour création
Endif
Return

########################################
Subprog AM_LAN(VALEUR)
Variable Char VALEUR()
If not GIMPORT 
    Filter  [AST] Where LAN=VALEUR & LANCHP >0 
    Fillbox [TRD]  
    Filter  [AST]  
Endif
[M:TRA2]LAN=VALEUR
End

########################################
Subprog AS_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
End

########################################
Subprog AP_LANCHP(VALEUR)
[M:TRA2]LANCHP=VALEUR
End 

########################################
Subprog AM_LANCHP(VALEUR)
Variable Decimal VALEUR
If [M:TRA2]ZLAN <>""
 Read[AST]CLE=VALEUR;[M:TRA2]LANNUM;[M:TRA2]ZLAN
 If fstat = 0   
     [M:TRA2]ZTEXTE = [F:AST]LANMES
 Else
     [M:TRA2]ZTEXTE="?"
 Endif
 If not GIMPORT 
   Affzo [M:TRA2]ZTEXTE
 Endif
Endif
End

########################################
Subprog AS_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
End

########################################
Subprog AP_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Affzo [M:TRA2]LANCHP

Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]LAN
If fstat = 0   
    [M:TRA2]LANMES = [F:AST]LANMES
    If not GIMPORT
        Affzo [M:TRA2]LANMES
        If GLANTRAD<>"" 
            Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;GLANTRAD
            If fstat = 0   
             [M:TRA2]ZTEXTE = [F:AST]LANMES
            Else
             [M:TRA2]ZTEXTE="?"
            Endif
            Affzo [M:TRA2]ZTEXTE
        Endif
    Endif
Else
    mkstat=2
Endif
End

########################################
Subprog AM_LANNUM(VALEUR)
Variable Decimal VALEUR

Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]ZLAN
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
If not GIMPORT 
  Affzo [M:TRA2]ZTEXTE
Endif
End

########################################
Subprog AM_ZLAN(VALEUR)
Variable Char    VALEUR()
If GIMPORT : End : Endif 
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM;VALEUR
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
[M:TRA2]ZLAN=VALEUR
GLANTRAD = VALEUR
End

##############################################################
Subprog REAFFICHE_ZTEXTE(VALEUR)
Variable Decimal VALEUR

 Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]ZLAN
   If fstat = 0   
       [M:TRA2]ZTEXTE = [F:AST]LANMES
   Else
       [M:TRA2]ZTEXTE="?"
   Endif
   Affzo [M:TRA2]ZTEXTE 
End

##############################################################
$SEL_LISTE
Case LISTE
 When "ASAILIB"    : Gosub SAILIB
Endcase
Return

$SAILIB
Local Integer CHAP
CHAP = val(PARAM(1))
For [AST]CLE Where LANCHP=CHAP & LAN=GLANREF
 If NBTEX>=dim(TEX)-1 : Break : Endif
 NBTEX += 1
 TEX(NBTEX) = num$([F:AST]LANNUM)
 TEXTE(NBTEX) = TEX(NBTEX)-[F:AST]LANMES
Next
Return


