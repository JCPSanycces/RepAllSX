#<AdxTL>@(#)0.0.0.0 $Revision$

# Gestion du masque LPNCHG
##################################################################################
# Traitement TRTLPNCHG - Saisie des contenants pour une ligne de stock           #
#                         Depuis les documents correspondant au parametre LABR   #
#                         l enregistrement des données saisies dans cette fenetre#
#                         est fait dans l'ecran de travail STOCHGW.              #
##################################################################################
# Action SAICHGLPN
# Paramètres - LABR Abréviation masque
#            - LNOL No ligne écran (nolign-1)
#
########################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
Endcase

Return

#########################################################################
$OUVRE
Global Char    PABR            : # Abréviation masque origine
Global Integer LLIGDOC            : # No ligne courante (nolign-1) masque origine
Local Integer I, OK
Local Decimal WDISPO
# Récupération des paramètres
PABR    = PARAM(1)
LLIGDOC    = val(PARAM(2))

Return

#########################################################################
$DEBUT
Local Integer WLIGNE
Raz WLIGNE
Raz I
If [M:LPNO]OUVCHGLPN(nolign-1)=1
  WLIGNE = 2
Else
  WLIGNE = 1
Endif
Gosub CHARG_BC1_LPNC
Gosub CHARG_TAB_LPNC
[M:LPNC]NBLIG = I+1
Affzo [M:LPNC]

Return

####################################################################  #####
$SETBOUT
If WLIGNE = 9 | GOUVCHGS = 9
   Call VIREBOUT(CHBOU,"EA")From GOBJET
   Return
Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

###########################################################################
# CHARG_BC1_LPNC : chargement  masque SAICHGLPN partie bloc 1
###########################################################################
$CHARG_BC1_LPNC
Raz [M:LPNC]
[M:LPNC]STOFCY     = evalue("[M:"+PABR+"]STOFCY")
If dim([M:LPNC]WRH)<> 0
  [M:LPNC]WRH        = [M:LPNO]WRHDESH
Endif

#Raz [M:LPNC]MODFLG(PNOL)

[M:LPNC]ITMREF       = [M:LPNO]ITMREF   (LLIGDOC)
[M:LPNC]QTYPCUH      = [M:LPNO]QTYPCU   (LLIGDOC)
[M:LPNC]PCUH         = [M:LPNO]PCU      (LLIGDOC)
[M:LPNC]QTYSTU       = [M:LPNO]QTYSTUDES(LLIGDOC)
[M:LPNC]STU          = [M:LPNO]STU      (LLIGDOC)
[M:LPNC]LPNNUM       = [M:LPNO]LPNNUMDES(LLIGDOC)
[M:LPNC]LOCDESH      = [M:LPNO]LOCDES   (LLIGDOC)
[M:LPNC]STOCOU       = [M:LPNO]WSTOCOU  (LLIGDOC)
If dim([M:LPNC]LOC) > 0
  [M:LPNC]LOC       = [M:LPNO]LOC      (LLIGDOC)
Endif
If dim([M:LPNC]LOT) > 0
  [M:LPNC]LOT       = [M:LPNO]LOT      (LLIGDOC)
Endif
If dim([M:LPNC]SLO) > 0
  [M:LPNC]SLO       = [M:LPNO]SLO      (LLIGDOC)
Endif
[M:LPNC]WSTOSEQ    = [M:LPNO]WSTOSEQ  (LLIGDOC)
[M:LPNC]PCUSTUCOEH  = [M:LPNO]PCUSTUCOE (LLIGDOC)


Return

###########################################################################
# CHARG_TAB_LPNC chargement  masque SAILPNCHG partie tableau
###########################################################################
$CHARG_TAB_LPNC

[M:LPNC]QTYPCU    (I) = [M:LPNO]QTYPCU (LLIGDOC)
[M:LPNC]PCUSTUCOE (I) = [M:LPNO]PCUSTUCOE    (LLIGDOC)
[M:LPNC]PCU       (I) = [M:LPNO]PCU     (LLIGDOC)
[M:LPNC]QTYSTUDES (I) = [M:LPNC]QTYPCU    (I) * [M:LPNC]PCUSTUCOE    (I)
Call QTEARR([M:LPNC]QTYSTUDES(I), [M:LPNC]STU) From TRTDIV
[M:LPNC]LPNNUMDES    (I) = [M:LPNO]LPNNUMDES    (LLIGDOC)
If [F:LPN]LPNNUM <> [M:LPNO]LPNNUMDES    (LLIGDOC)
  Read [LPN]LPN0 = [M:LPNO]LPNNUMDES    (LLIGDOC)
Endif
If [F:LPN]LPNSTAT = 2
  Diszo [M:LPNC]LOCDES(I)
Else
  Actzo [M:LPNC]LOCDES(I)
Endif

[M:LPNC]LOCDES    (I) = [M:LPNO]LOCDES    (LLIGDOC)
[M:LPNC]LOCTYPDES (I) = [M:LPNO]LOCTYPDES (LLIGDOC)
[M:LPNC]COEDES    (I) = [M:LPNO]COEDES    (LLIGDOC)
[M:LPNC]PCUDES    (I) = [M:LPNO]PCUDES    (LLIGDOC)
[M:LPNC]STADES    (I) = [M:LPNO]STADES    (LLIGDOC)

[M:LPNC]WLOCSEQ      (I) = [M:LPNO]WLOCSEQ   (LLIGDOC)
[M:LPNC]SERNUM       (I) = [M:LPNO]SERNUM    (LLIGDOC)
[M:LPNC]SERNUMF      (I) = [M:LPNO]SERNUMF   (LLIGDOC)
[M:LPNC]WSTOSEQIND   (I) = [M:LPNO]WSTOSEQIND(LLIGDOC)
If dim([M:LPNC]PALNUMDES) > 0
    [M:LPNC]PALNUMDES (I) = [M:LPNO]PALNUMDES    (LLIGDOC)
Endif
If dim([M:LPNC]CTRNUMDES) > 0
  [M:LPNC]CTRNUMDES (I) = [M:LPNO]CTRNUMDES    (LLIGDOC)
Endif


If WLIGNE <> 2                                         # hcb 62634
  #Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)

  Y = find([M:LPNC]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
  If Y >= 0
    While Y<[M:SGW]NBLIG & [M:LPNC]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
      [M:LPNC]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
      [M:LPNC]PCUSTUCOE (I)    = [M:LPNO]PCUSTUCOE    (LLIGDOC)
      [M:LPNC]PCU       (I) = [M:LPNO]PCU     (LLIGDOC)
      If [M:LPNO]PCUSTUCOE    (LLIGDOC) <> 0
        [M:LPNC]QTYPCU       (I) = [M:SGW]WQTYSTUDES(Y) /[M:LPNO]PCUSTUCOE    (LLIGDOC)
      Else
        [M:LPNC]QTYPCU       (I) = 0
      Endif
      [M:LPNC]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
      [M:LPNC]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
      [M:LPNC]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
      [M:LPNC]LOCTYPDES (I) = [M:SGW]WLOCTYPDES (Y)
      [M:LPNC]LOCDES    (I) = [M:SGW]WLOCDES    (Y)
      [M:LPNC]LPNNUMDES  (I) = [M:SGW]WLPNNUMDES (Y)
      [M:LPNC]COEDES    (I) = [M:SGW]WCOEDES    (Y)
      [M:LPNC]PCUDES    (I) = [M:SGW]WPCUDES    (Y)
      [M:LPNC]STADES    (I) = [M:SGW]WSTADES    (Y)
      If dim([M:LPNC]PALNUMDES) > 0
        [M:LPNC]PALNUMDES (I) = [M:SGW]WPALNUMDES    (Y)
      Endif
      If dim([M:LPNC]CTRNUMDES) > 0
        [M:LPNC]CTRNUMDES (I) = [M:SGW]WCTRNUMDES    (Y)
      Endif
      Y+=1
      I +=1
    Wend
    If I > 0 : I -=1 : Endif
  Endif
  [M:LPNC]NBLIG = I

  If [M:LPNC]NBLIG > 1 & WLIGNE = 0
    Diszo [M:LPNC]
    WLIGNE = 9
  Endif
Endif
Return

###############################################################################
# DELSTOCHGW_IND : Efface le détail de N lignes de document changement stock
###############################################################################
# Paramètres E : PFCY   = Site de départ
#                PSEQ   = Séquence
#                PCOU   = Stocou
#                PSEQINS= Indice
#                PDELLOC= Indique s'il faut supprimer les réservations d'emplacement
#
#            S : PRET   = Code retour (0=OK, 1=Erreur)
#
# Appelé dans le cadre de la suppression d'un bloc de ligne
###############################################################################
Subprog DELSTOCHGW_IND(PFCY, PSEQ, PCOU, PSEQIND, PDELLOC, PRET )
Value    Char    PFCY
Value    Integer PSEQ
Value    Decimal PCOU
Value    Integer PSEQIND
Value    Integer PDELLOC
Variable Integer PRET

Local Integer WTRBEGIN, I, IND
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA

Raz WTRBEGIN

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif


For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)>0 & PSEQ = [M:SGW]WSTOSEQ(I) & PCOU = [M:SGW]WSTOCOU(I) & PSEQIND = [M:SGW]WSTOSEQIND(I)
        Readlock [STO1]STO0=PFCY;[M:SGW]WSTOCOU(I)
        If fstat
            If fstat=1
                GOK=0
                Call RSTA("STO1",PFCY-num$([M:SGW]WSTOCOU(I))) From GLOCK
                LRET=1 : Break
            Endif
        Else
            LWIPQTY = [M:SGW]WWIPQTY(I)
            LWIPQTA = [M:SGW]WWIPQTA(I)
            [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY-LWIPQTY)
            [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA-LWIPQTA)

            # Suppression qté en cours de traitement
            LSTOCOU = [F:STO1]STOCOU
            Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
            Rewrite [STO1]
            If fstat
                GOK=0  : Call FSTA("STO1") From GLOCK
                LRET=1 : Break
            Endif
            # Suppression série en cours de traitement
            If [M:SGW]WSERNUM(I) <> ""
                Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I),[M:SGW]WQTYSTUDES(I),PRET) From STKLIB
            Endif
            If PRET <>0
               Break
            Endif
            [M:SGW]WSTOCOU   (I) = 0
            [M:SGW]WSTOSEQ   (I) = 0
            [M:SGW]WSTOSEQIND(I) = 0
            IND+=1
        Endif
    Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
    If GOK=0
        Rollback
        End
    Else
        Commit
        Raz WTRBEGIN
    Endif
Endif


End


#########################################################################
$AVANT_ENR

Return

#########################################################################
$ENR
Local Integer WNBLIG, LRET
Local Decimal LQTYSTU
Local Integer LSEQ
Local Integer I
Local Integer WTRBEGIN
Local Char    LSTA(GLONSTA)
Local Char    LLOCTYP(GLONTLO)
Local Char    LLOC(GLONLOC)
Local Char    LSER(GLONSER), LSERF(GLONSER)
Local Integer LQLYFLG
Local Char    LLPN(GLONLPN)               # hcb X3-77043
Local Char    LPAL(GLONPAL)               # hcb 110505 28601
Local Char    LCTR(GLONCTR)               # hcb 110505 28601
Raz LPAL, LCTR                            # hcb 110505 28601
Local Integer I                           # hcb 110505 28601
Raz LQTYSTU
Raz LSEQ
Raz I
Raz WTRBEGIN

OK=1

# Contrôle de l'insertion
WNBLIG = [M:LPNC]NBLIG
#---
If [M:SGW]NBLIG+WNBLIG >= dim([M:SGW]WSTOSEQ)-1
  OK=0: GERR=1
  GMESSAGE=mess(122,199,1)   # insertion impossible
  Return
Endif
LRET = 1
If [M:LPNC]NBLIG=1
    # Si une seule
    IC=0
    If [M:LPNC]LPNNUMDES(IC)<>""
      Read [ITM]ITM0=[M:LPNC]ITMREF
      Read [LPN]LPN0=[M:LPNC]LPNNUMDES(IC)
      #--- Contrôle du mono-lot pour le LPN concerné
      If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
        Filter [STO] Where LPNNUM=[M:LPNC]LPNNUMDES(IC) & (ITMREF<>[M:LPNC]ITMREF | LOT<>[M:LPNC]LOT)
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNC]LPNNUMDES(IC),"")) From GESECRAN
          #Raz OK : Return
        Endif
      #--- Contrôle du mono-article pour le LPN concerné
      Elsif [F:LPN]MONITMFLG=2
        Filter [STO] Where LPNNUM=[M:LPNC]LPNNUMDES(IC) & ITMREF<>[M:LPNC]ITMREF
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNC]LPNNUMDES(IC),"")) From GESECRAN
          #Raz OK : Return
        Endif
      Endif
    Endif
  # Plusieurs lignes dans LPNC
  Else
    For I=0 To [M:LPNC]NBLIG-1
      If [M:LPNC]LPNNUMDES(I)<>""
        If [F:ITM]ITMREF<>[M:LPNC]ITMREF
          Read [ITM]ITM0=[M:LPNC]ITMREF
        Endif
        If [F:LPN]LPNNUM<>[M:LPNC]LPNNUMDES(I)
          Read [LPN]LPN0=[M:LPNC]LPNNUMDES(I)
        Endif
        J=0
        #--- Contrôle du mono-lot pour le LPN concerné
        If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
#          J=sigma(I+1,[M:LPNC]NBLIG-1,1*([M:LPNC]LPNNUMDES(indcum)=[M:LPNC]LPNNUMDES(I)))
#          If J>=1
#            LRET=0
#          Else
            Filter [STO] Where LPNNUM=[M:LPNC]LPNNUMDES(I) & (ITMREF<>[M:LPNC]ITMREF | LOT<>[M:LPNC]LOT)
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          #Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNC]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        #--- Contrôle du mono-article pour le LPN concerné
        Elsif [F:LPN]MONITMFLG=2
          Filter [STO] Where LPNNUM=[M:LPNC]LPNNUMDES(I) & ITMREF<>[M:LPNC]ITMREF
          Look [STO]STO3 First
          If !fstat : LRET=0 : Endif
          Filter [STO]
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNC]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        Endif
        #--- Contrôle du mono-emplacement par LPN
        K=sigma(I+1,[M:LPNC]NBLIG-1,1*([M:LPNC]LPNNUMDES(indcum)=[M:LPNC]LPNNUMDES(I)))
        L=sigma(I+1,[M:LPNC]NBLIG-1,1*([M:LPNC]LPNNUMDES(indcum)=[M:LPNC]LPNNUMDES(I))
&               & [M:LPNC]LOCDES(indcum)=[M:LPNC]LOCDES(I))
        If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:LPNC]LPNNUMDES(I),[M:LPNC]LOCDES(I))) From GESECRAN
          LRET=0 : Break
        Endif
      Endif
    Next I
Endif
If LRET = 0 : OK = 0 : GERR=1: Return : Endif

Call DELSTOCHGW("LPNO", [M:LPNC]STOFCY, LLIGDOC, LLIGDOC,1, LRET) From SUBSCSB
LSEQ = [M:LPNC]WSTOSEQ
Call FILLCHGW("LPNC", 0, [M:LPNC]NBLIG, LSEQ, [M:LPNC]STOFCY, LRET, LQTYSTU) From SUBSCSB
If LRET<>0 | GERR=2
  LRET=99
Endif
If LQTYSTU=0
  Call ERREUR(mess(367,199,1)) From GESECRAN    # Pas de stock disponible
Endif
Call RECCHG_M( [M:LPNC]WSTOSEQ, LSTA, LLOCTYP, LLOC, LSER, LSERF, LQLYFLG, "LPNC", LLIGDOC, LPAL, LCTR, LLPN) From SUBSCSB
#tous les numéros de série sont renseignés ?
If [F:ITM]SERMGTCOD = 4
  Raz I
  For I=0 To [M:LPNC]NBLIG-1
        J=find([M:LPNC]WSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
          If [M:LPNC]WSTOSEQIND(I) = [M:SGW]WSTOSEQIND(J-1)
            If [M:SGW]WSERNUM(J-1) = "" & [M:SGW]WQTYSTUDES(J-1) <> 0
             GMESSAGE=mess(3,40,1)-num$(I+1)-mess(246,199,1)
             OK=0    : GERR = 1 : Break
            Endif
          Endif
    Next I
Endif
If OK =0 Return : Endif
#fin numéros de série
[M:LPNO]LPNNUMDES(LLIGDOC) = LLPN
[M:LPNO]LOCDES(LLIGDOC)    = LLOC
[M:LPNO]SERNUM(LLIGDOC)    = LSER
[M:LPNO]SERNUMF(LLIGDOC)   = LSERF
FIN = 1
Return

#########################################################################
$ABA

Gosub DEBUT

Return
#########################################################################
$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#########################################################################
$FIN
Return

#########################################################################
$FINSAI
Default Mask "["+PABR+"]"

Affzo [M]
mkstat=4

Return
###########################################################################

Subprog AVANT_NBLIG
Local Integer I
Local Integer J
Local Integer WLIGNE
WLIGNE = 2
I =nolign-1
# on ne copie juste sur les nouvelles lignes
If find(status,73,82)
   Gosub CHARG_TAB_LPNC
   Raz   [M:LPNC]QTYPCU    (I)
   Raz   [M:LPNC]LPNNUMDES    (I)
   Raz   [M:LPNC]LOCDES       (I)
Endif
If [M:LPNC]QTYPCU          (I) = 0
   [M:LPNC]QTYPCU          (I) = abs([M:LPNC]QTYPCUH) - sum([M:LPNC]QTYPCU(0..[M:LPNC]NBLIG-1))
   If [M:LPNC]QTYPCU    (I) < 0
      [M:LPNC]QTYPCU    (I) = 0
   Endif
   [M:LPNC]QTYSTUDES (I) = [M:LPNC]QTYPCU    (I) * [M:LPNC]PCUSTUCOE    (I)
   Call QTEARR([M:LPNC]QTYSTUDES(I), [M:LPNC]STU) From TRTDIV
   Affzo [M:LPNC]QTYPCU (I)
Endif
End

Subprog C_NBLIG
Local Integer LRET
End
Case status
     When 65     :                       # Suppression d'une ligne
          If [M:LPNC]QTYSTUDES(nolign-1) <> 0 & [M:LPNC]WENR      (nolign-1) = 2
             Call DEL_STOSERW([M:LPNC]ITMREF,[M:LPNC]SERNUM(nolign-1),[M:LPNC]QTYSTUDES(nolign-1),LRET) From STKLIB
           Else
             mkstat = 2
          Endif

     When 68, 83 :                       # Suppression d'un groupe de lignes
          For I=nolign-1 To nolign1-1
              If [M:LPNC]QTYSTUDES(nolign-1) <> 0 & [M:LPNC]WENR      (nolign-1) = 2
                 Call DEL_STOSERW([M:LPNC]ITMREF,[M:LPNC]SERNUM(nolign-1),[M:LPNC]QTYSTUDES(nolign-1),LRET) From STKLIB
              Endif
          Next
     Endcase
     If LRET
        mkstat=2
     Endif

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 19/03/2018 13:21:51 (MAE)
######################################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
  #calcul de la qté en US
  WQTYSTU = VALEUR*[M:LPNC]PCUSTUCOE(nolign-1)
  Call QTEARR(WQTYSTU, [M:LPNC]STU) From TRTDIV
  [M:LPNC]QTYSTUDES(nolign-1) = WQTYSTU
  Affzo [M:LPNC]QTYSTUDES(nolign-1)
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 19/03/2018 15:43:13 (MAE)
######################################################################################
Subprog AM_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
 Read [LPN]LPN0 = VALEUR
  [M:LPNC]LOCDES(nolign-1) = [F:LPN]LOC
  Affzo [M:LPNC]LOCDES(nolign-1)
  If [F:LPN]LOC <> AVOID.ACHAR & [F:LPN]LPNSTAT = 2
      Diszo [M:LPNC]LOCDES(nolign-1)
      #controle de l'emplacement du LPN : s'il a du stock, il n'est pas modifiable
      Call STKCTREMP([M:LPNC]WLOCSEQ,36,"",[M:LPNC]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNC]LOCTYPDES(nolign-1),[M:LPNC]LOCDES(nolign-1),"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
  Else
    Actzo [M:LPNC]LOCDES(nolign-1)
    zonsui = [M:LPNC]LOCDES(nolign-1)
  Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 20/03/2018 10:06:44 (MAE)
######################################################################################
Subprog AM_LOCDES(VALEUR)
Variable Char    VALEUR()
#lecture de l'emplacement pour le type d'emplacement
If VALEUR <> AVOID.ACHAR
  Read [STC]STC0 = [M:LPNC]STOFCY;VALEUR
  If fstat
   GMESSAGE = mess(125,184,1)
   mkstat=2 : End
  Endif
  [M:LPNC]LOCTYPDES(nolign-1) = [F:STC]LOCTYP
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 20/03/2018 10:09:02 (MAE)
######################################################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
  #controle de l'emplacement du LPN
  Call STKCTREMP([M:LPNC]WLOCSEQ,36,"",[M:LPNC]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNC]LOCTYPDES(nolign-1),VALEUR,"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
  If mkstat = 2 : End : Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 20/03/2018 16:04:07 (MAE)
######################################################################################
Subprog B1_NBLIG
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Local Integer I
Raz I
GOUVCHGS = 2
Call DELSTOCHGW("LPNO", [M:LPNC]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB   #écran appelant
LSEQ = [M:LPNC]WSTOSEQ
Call FILLCHGW("LPNC", I, [M:LPNC]NBLIG-I, LSEQ, [M:LPNC]STOFCY, LRET, LQTYSTU) From SUBSCSB
End


######################################################################################
###############################################################################
# LOAD_FROM_SGW : Charge l'écran SAILPNCHG [LPNC] à partir de STOCHGW [SGW]
###############################################################################
$LOAD_FROM_SGW

Local Integer I, J
Local Char    WSTOFCY(GLONFCY)
[M:LPNC]WSTOSEQ = [M:CHGS]WSTOSEQ

#------ Se positionne dans SGW ------#
I = find([M:LPNC]WSTOSEQ, [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
If I>=0
        While I<[M:SGW]NBLIG & [M:LPNC]WSTOSEQ=[M:SGW]WSTOSEQ(I)
        If I>0 & [M:LPNC]WSTOSEQ=[M:SGW]WSTOSEQ(I-1) & [M:SGW]WLIGDET(I-1)=[M:SGW]WLIGDET(I) & [M:SGW]WSTOSEQIND(I) = 0   # hcb 110327
            [M:LPNC]SERNUMF([M:LPNC]NBLIG)   = [M:SGW]WSERNUMF(I)
            [M:LPNC]QTYSTUDES([M:LPNC]NBLIG) += [M:SGW]WQTYSTUDES(I)
        Else
            [M:LPNC]QTYSTUDES([M:LPNC]NBLIG) = [M:SGW]WQTYSTUDES(I)
            [M:LPNC]QLYCTLFLG([M:LPNC]NBLIG) = [M:SGW]QLYCTLFLG(I)
            If dim([M:LPNC]SERNUM)>0
                [M:LPNC]SERNUM([M:LPNC]NBLIG)    = [M:SGW]WSERNUM(I)
                [M:LPNC]SERNUMF([M:LPNC]NBLIG)   = [M:SGW]WSERNUMF(I)
            Endif
            If dim([M:LPNC]LOCTYPDES)>0
                [M:LPNC]LOCTYPDES([M:LPNC]NBLIG) = [M:SGW]WLOCTYPDES(I)
            Endif
            If dim([M:LPNC]LOCDES)>0
                [M:LPNC]LOCDES([M:LPNC]NBLIG)    = [M:SGW]WLOCDES(I)
            Endif
            [M:LPNC]PCUDES([M:LPNC]NBLIG)    = [M:SGW]WPCUDES(I)
            [M:LPNC]COEDES([M:LPNC]NBLIG)    = [M:SGW]WCOEDES(I)
            If dim([M:LPNC]WLOCSEQ)>0
                [M:LPNC]WLOCSEQ([M:LPNC]NBLIG)    = [M:SGW]WLOCSEQ(I)
            Endif
       #                                                                             # hcb 110327 deb
            If dim([M:LPNC]WSTOSEQIND)>0
               [M:LPNC]WSTOSEQIND([M:LPNC]NBLIG)    = [M:SGW]WSTOSEQIND(I)
            Endif
            [M:LPNC]PCUSTUCOE ([M:LPNC]NBLIG) = [M:LPNC]PCUSTUCOEH
            If [M:LPNC]PCUSTUCOEH <> 0
              [M:LPNC]QTYPCU    ([M:LPNC]NBLIG) = [M:LPNC]QTYSTUDES ([M:LPNC]NBLIG)/[M:LPNC]PCUSTUCOEH
            Endif
            Call QTEARR([M:LPNC]QTYPCU    ([M:LPNC]NBLIG), [M:LPNC]PCUH) From TRTDIV
            [M:LPNC]LPNNUMDES    ([M:LPNC]NBLIG) = [M:SGW]WLPNNUMDES    (I)
            If dim([M:LPNC]PALNUMDES)>0
                [M:LPNC]PALNUMDES([M:LPNC]NBLIG) = [M:SGW]WPALNUMDES(I)
            Endif
            If dim([M:LPNC]CTRNUMDES)>0
                [M:LPNC]CTRNUMDES([M:LPNC]NBLIG) = [M:SGW]WCTRNUMDES(I)
            Endif
#                                                                                    # hcb 110327 fin
        Endif
        If I+1>=[M:SGW]NBLIG
&        | [M:LPNC]WSTOSEQ<>[M:SGW]WSTOSEQ(I+1)
&        | [M:LPNC]WSTOSEQ=[M:SGW]WSTOSEQ(I+1) & [M:SGW]WLIGDET(I)<>[M:SGW]WLIGDET(I+1)
&        | [M:SGW]WSTOSEQIND(I) <> 0                                                     # hcb 110327
            [M:LPNC]NBLIG += 1
        Endif
        I+=1
    Wend
Endif
If [F:ITM]SERMGTCOD>1
    Actzo [M:LPNC]SERNUM
    If [F:ITM]SERMGTCOD=3
        Diszo [M:LPNC]SERNUM(0)    #Le premier n° de série est fixé
    Endif
Endif

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNCHG) 23/03/2018 12:36:15 (MAE)
######################################################################################
Subprog APRES_NBLIG
Local Integer LRET
Local Decimal LQTY
Gosub SET_NOL
If [F:ITM]SERMGTCOD = 4
   Local Integer LSEQIND
   Call WSTOSEQIND ("LPNC",NOL+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:LPNC]WSTOSEQIND(NOL) = LSEQIND
Endif
End


