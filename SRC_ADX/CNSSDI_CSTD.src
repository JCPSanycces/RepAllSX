#<AdxTL>@(#)0.0.0.0 $Revision$

#classe CNSSDI
# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
     When "CNSSDI" : Gosub CALCULSDI
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Case CURPRO
  #Endcase
Return




#$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#        When "CNSSDI" :
#                               Gosub CALCULSDI
#        When Default
#      Endcase
#Endcase
#Return

############################################################
#CALCULSDI
#renseigne le tableau avec :
# - date
# - stock disponible à la vente
# - total ressources
#  err       = 0 (non) / 1 (oui)
############################################################
$ CALCULSDI
Local Libelle  JERR
Local Integer    WERR                       : # si erreur => positionné avec [V]CST_Axxx selon erreur
Local Integer    WSEM         : WSEM = 1  : # Premier jour ouvré semaine
Local Integer    WCOLSDI      : WCOLSDI = 12 : # Nombre de colonnes
Local Integer    WNBT         : WNBT = 14 : # Nombre de types d'ordres +1
Local Integer    WNBL         : WNBL = 18 : # Nombre de lignes +1
Local Char       WFILS(250), WFILSPE(250)
Local Char       WFILEXY(250)
Local Decimal    TLIG(WNBL,WCOLSDI)    : # Cumuls lignes

Local File ITMMASTER  [ITM]
Local File TABUNIT    [TUN]
Local File ITMFACILIT [ITF]
Local File ITMMVT     [ITV]
Local File ITMMVT     [ITV1]
Local File ORDERS     [ORD]
Local File STOALL     [STA]
Local File STOCK      [STO]
Local File STOLOT     [STL]
Local File STOLOTFCY  [SLF]
#a modifier plus tard
#If GMODU(5)=2
  Local File SDELIVERYD [SDD]
  Local File SINVOICED  [SID]
#Endif
Local Integer CST_WRKDAY


Local Integer    ITYP
Local Integer    IDAT
Local Integer    ISTA
Local Integer    ISIG
Local Char       WINT(30)(40)
Local Decimal    TCUM(WNBT,WCOLSDI,5,2) : # Cumuls par type d'ordre, date, statut, signe
Local Char       TTAB(120)(WNBL)         : # Contenu des lignes
Local Integer    WLNE(WNBL)             : # Titres lignes
Local Char       WTAB(120)
Local Char       WZON(5)
Local Integer    WLIN
Local Char       WDIRECT(15)
Local Date       WDTED
Local Date       WDTEF
Local Integer    WSEMD
Local Integer    WSEMF
Local Integer    WYEA
Local Integer    WMON
Local Integer    WSEMNB
Local Date       WDATD(WCOLSDI)
Local Date       WDATF(WCOLSDI)
Local Char       WNUMCOL(40)
Local Date       WDTE
Local Decimal    WPHYSTO,WSCOPHYSTO,WSCOPHYALL,WWAISTO,WGLOALL,WSCCLNDSTO,WTRFSTO
Local Char  ERRMSG(100)


ARET_VALUE= [V]CST_AFALSE
Raz WPHYSTO,WSCOPHYSTO,WSCOPHYALL,WWAISTO,WGLOALL,WSCCLNDSTO,WTRFSTO

#si l'article ou le site ne sont pas renseignés=>erreur
If W_ITMREF = "" | W_FCY = ""
  [L]WERR = [V]CST_AERROR
  Goto LECTURE_FIN
Endif

# Lecture paramètre premier jour ouvré
CST_WRKDAY = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER,"FIRWRKDAY")

If CST_WRKDAY < 1 | CST_WRKDAY > 7
  WSEM = 1
Else
  WSEM = CST_WRKDAY
Endif
Gosub MEI_CONSTANTES
Gosub CAL_COLONNES
# Lecture ITMMASTER
Read [F:ITM]ITM0=W_ITMREF
If fstat
  Raz [F:ITM] : WERR = [V]CST_AERROR
  Goto LECTURE_FIN
Endif
# Lecture unité stock
Read [F:TUN]TUN0=[F:ITM]STU
If fstat
  Raz [F:TUN]
Endif

#remplissage de l'instance avec la classe F
SetInstance this With [F:ITM]

# Lecture article - site
If W_FCY <> ""
  Read [F:ITF]ITF0=W_ITMREF;W_FCY
  If fstat
    Raz [F:ITF]
  Endif
Endif

Raz TCUM, TLIG
Raz [F:ITV]
#

Filter [F:ITV1] Where ITMREF = W_ITMREF & STOFCY = W_FCY
&             Order By Key ITV0
#
For [F:ITV1]
  Call STKDETSTO("[F:ITV1]","[F:ITV]",this,"",WINT,3,0,WERR) From STKACT_SYRA
Next

Filter [ITV1]

Call STKDETSTO("[F:ITV]","",this,"",WINT,2,0,WERR) From STKACT_SYRA

this.ORDSTO = this.C_FLD(33).VALFLD  #Stock en réappro

#
#Calcul du stock actuel (stock interne A)
WPHYSTO     += [F:ITV]PHYSTO    + [F:ITV]PLFPHYSTO
WSCOPHYSTO  += [F:ITV]SCOPHYSTO
WSCOPHYALL  += [F:ITV]SCOPHYALL
WWAISTO     += [F:ITV]WAISTO
WGLOALL     += [F:ITV]GLOALL
WSCCLNDSTO  += [F:ITV]SCCLNDSTO
WTRFSTO     += [F:ITV]TRFSTO


#A modifier pour passer en syracuse
#If GMODU(5)=2
# Ajout dans allocations 1ère période factures, livraisons directes, retour fournisseur
  Filter [STA] Where ITMREF = W_ITMREF &
&                    STOFCY = W_FCY    &
&                    ALLTYP = 2              &
&                    (VCRTYP = 4 | VCRTYP = 5 | VCRTYP = 8)
&              Order By Key STA0
  For [STA]
    Raz WDIRECT
    If [F:STA]VCRTYP=4
      Read [SDD]SDD0=[F:STA]VCRNUM;[F:STA]VCRLIN
      WDIRECT=[F:SDD]SOHNUM
    Else
      Read [SID]SID0=[F:STA]VCRNUM;[F:STA]VCRLIN
      WDIRECT=[F:SID]SOHNUM
    Endif
    If WDIRECT=""
       Read [ORD]ORD3=W_FCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
       If fstat
         TLIG(1,0) += [F:STA]QTYSTU
       Endif
    Endif
  Next
  Filter [STA]
#Endif


#En Syracuse, les points d'entrée ne sont pas encore gérés
WFILSPE="1=1"
#If PROGSPE<>""
#  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
#Endif
Filter [ORD] Where STOFCY = W_FCY      &
&                  ITMREF = W_ITMREF   &
&                  evalue (WFILSPE)          &
&                  WIPSTA = 1 & FMI < 2
&               Order By Key ORD1
For [ORD]
      Gosub TRT_SEL
      Gosub TRT_CUMUL
Next
Filter [ORD]

# Préparation du tableau
For WLIN = 0 To WNBL-1
  WTAB = TTAB(WLIN)
  Gosub CUM_COL
Next WLIN


# Calcul disponible 140
WQTY = WPHYSTO

# SI ON DÉDUIT UNIQUEMENT LE STOCK SOUS TRAITANT ET PAS LES ALLOCATIONS,
# on rajoute le stock sous traitant alloué car il est déduit du stock disponible lorsque les allocations sont déduites
WQTY += WSCOPHYALL

#Fin bg 78980

WTRF = 0

this.FIRAVADAT = [0/0/0]
For IDAT = 0 To WCOLSDI-1
  WQTY += TLIG(2,IDAT)
  WQTY -= TLIG(0,IDAT)
  WQTY -= TLIG(1,IDAT)
  TLIG(3,IDAT) = WQTY
  If WQTY > 0 & this.FIRAVADAT = [0/0/0] & IDAT > 0
    this.FIRAVADAT = WDATD(IDAT)
  Endif
Next IDAT

# Calcul disponible à la vente 140
WQTY = WPHYSTO

For IDAT = 0 To WCOLSDI-1
  WQTY += TLIG(2,IDAT)
  WQTY -= TLIG(1,IDAT)
  WQTY -= TLIG(7,IDAT)
  WQTY -= TLIG(8,IDAT)
  TLIG(4,IDAT) = WQTY
Next IDAT
For IDAT = 0 To WCOLSDI-2
  WQTY = TLIG(4,IDAT)
  I = IDAT+1
  While TLIG(2,I) = 0 & I < WCOLSDI-1
    WQTY -= TLIG(7,I)
    WQTY -= TLIG(8,I)
    I += 1
  Wend
  TLIG(4,IDAT) = WQTY
Next IDAT

Local Integer IJ
this.PHYSTO = WPHYSTO
#le chargement se fera dans la classe appelante, dans la représentation
# Chargement des quantités dans le tableau
For WLIN=2 To 3
    If this.C_STODISPO(WLIN) = null
      IJ = fmet this.ADDLINE("C_STODISPO",WLIN)
      If IJ = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", "Data Class CNSSDI : Method call CALCULSDI result error for this.ADDLINE C_STODISPO:", [V]CST_AERROR)
        Return
      Endif
    Endif
    If (WLIN = 2) #TLIG(2): total ressources
      I = WLIN
    Elsif WLIN = 3 #TLIG(4): dispo à la vente
      I = WLIN + 1
    Endif
    this.C_STODISPO(IJ).COL00 = num$(TLIG(I,0))   #Date
    this.C_STODISPO(IJ).COL01 = num$(TLIG(I,1))
    this.C_STODISPO(IJ).COL02 = num$(TLIG(I,2))
    this.C_STODISPO(IJ).COL03 = num$(TLIG(I,3))
    this.C_STODISPO(IJ).COL04 = num$(TLIG(I,4))
    this.C_STODISPO(IJ).COL05 = num$(TLIG(I,5))
    this.C_STODISPO(IJ).COL06 = num$(TLIG(I,6))
    this.C_STODISPO(IJ).COL07 = num$(TLIG(I,7))
    this.C_STODISPO(IJ).COL08 = num$(TLIG(I,8))
    this.C_STODISPO(IJ).COL09 = num$(TLIG(I,9))
    this.C_STODISPO(IJ).COL10 = num$(TLIG(I,10))
    this.C_STODISPO(IJ).COL11 = num$(TLIG(I,11))
Next WLIN
NOL = WNBL-1
#
$LECTURE_FIN
If WERR > [V]CST_AINFO
  [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
  ARET_VALUE= WERR
Else
  #--Loading the Document from the Result class (Help yourself...)
  WERR = fmet W_STKCNSSDI.LOADRESULTSDI(this)
Endif
If WERR > [V]CST_AINFO
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class CNSSDI: Method call CALCULSDI error returned by MYDOC.LOADRESULTSDI", WERR)
Endif

Return
###########################################################
$LEC_RER
# Recherche allocations globales
WGLO = 0

Filter [STA] Where VCRTYP = [F:ORD]VCRTYP &
&                  VCRNUM = [F:ORD]VCRNUM &
&                  VCRLIN = [F:ORD]VCRLIN &
&                  VCRSEQ = [F:ORD]VCRSEQ &
&                  ALLTYP = 1
&            Order By Key STA1
Look [STA]STA1(4) First
If !fstat
  WGLO = 1
Endif
Filter [STA]
WALL = [F:ORD]ALLQTY
WQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY - [F:ORD]MTOQTY    # hcb 83895


Return
###########################################################
$CUM_COL
While left$(WTAB,5) <> ""
   WZON = left$(WTAB,5)
   ITYP = val(mid$(WZON,1,2))
   ISTA = val(mid$(WZON,3,1))
   ISIG = val(mid$(WZON,4,1))
For IDAT = 0 To WCOLSDI-1
    TLIG(WLIN-1,IDAT) += TCUM(ITYP,IDAT,ISTA,ISIG)
    Next IDAT
    WTAB = mid$(WTAB,6,95)
 Wend
Return
############################################################
# Cumul selon Type date statut signe
$TRT_CUMUL
# Correction quantité restante par % perte
#If [F:ORD]WIPTYP = 5 & find([F:ORD]WIPSTA,1,2,3) & WSHRFLG = 2 & [F:ITF]SHR > 0
#  [F:ORD]EXTQTY    = arr(([F:ORD]EXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
#  [F:ORD]RMNEXTQTY = arr(([F:ORD]RMNEXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
#Endif
#
If [F:ORD]RMNEXTQTY >= 0
  ISIG = 0
Else
  ISIG = 1
Endif
Case [F:ORD]WIPTYP
  When 1,3,6,12    :
    Gosub LEC_RER
    If WQTY < 0
      WQTY = 0
    Endif
  When Default :
    WALL = 0
    WQTY = ([F:ORD]RMNEXTQTY - [F:ORD]MTOQTY)  # hcb 83895
    If WQTY < 0                                # hcb 83895
      WQTY = 0
    Endif
Endcase
If [F:ORD]ENDDAT <= WDATF(WCOLSDI-1)
  If [F:ORD]ENDDAT < WDATD
    IDAT = 0
    TCUM(ITYP,IDAT,ISTA,ISIG) += WQTY
    If WALL <> 0
       TCUM(0,IDAT,ISTA,ISIG) += WALL
    Endif
  Else
    For IDAT = 0 To WCOLSDI-1
      If [F:ORD]ENDDAT >= WDATD(IDAT) & [F:ORD]ENDDAT <= WDATF(IDAT)
        TCUM(ITYP,IDAT,ISTA,ISIG) += WQTY
        If WALL <> 0
         TCUM(0,IDAT,ISTA,ISIG) += WALL
        Endif
        Break
      Endif
    Next IDAT
  Endif
Endif
Return
###########################################################
# Positionnement valeurs par défaut de départ
$MEI_CONSTANTES
# Types d'ordres par ligne
TTAB(0)  = ""
TTAB(1)  = "0110 0120 0130 0140 0310 0320 0330 0610 0620 0630 0611 0621 0631 0810 0820 0830 1230"
TTAB(2)  = "0010 0020 0030 0040 "
TTAB(3)  = "0210 0220 0230 0240 0510 0520 0530 0540 0710 0720 0730 0740 0910 0920 0930 0940 1310 1320 1330"
TTAB(4)  = "*"
TTAB(5)  = "*"
TTAB(6)  = "*"
TTAB(7)  = ""
TTAB(8)  = "0110 0310 0610 0810"
TTAB(9)  = "0140 "
TTAB(10) = "0120 0320 0620 0820"
TTAB(11) = "0330 0630"
TTAB(12) = "0130 0330 0630 0830"
TTAB(13) = ""
TTAB(14) = "0210 0510 0611 0710 0910 1310"
TTAB(15) = "0240 0540 1340"
TTAB(16) = "0220 0520 0621 0720 0920 1320"
TTAB(17) = "0230 0530 0730 0631 0930 1330"
# Titres lignes
WLNE(0)  = 0
WLNE(1)  = 112
WLNE(2)  = 113
WLNE(3)  = 114
WLNE(4)  = 115
WLNE(5)  = 116
WLNE(6)  = 117
WLNE(7)  = 0
WLNE(8)  = 118
WLNE(9)  = 119
WLNE(10) = 120
WLNE(11) = 121
WLNE(12) = 122
WLNE(13) = 0
WLNE(14) = 123
WLNE(15) = 124
WLNE(16) = 125
WLNE(17) = 126
Return

###########################################################
# Titres colonnes
$CAL_COLONNES
If WSEM = 1
  WCOR = 7
Else
  WCOR = WSEM-1
Endif
If this.C_STODISPO(1) = null
  WLIG = fmet this.ADDLINE("C_STODISPO",1)
  If WLIG = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class CNSSDI : Method call AINIT result error for this.ADDLINE C_STODISPO:", [V]CST_AERROR)
    Return
  Endif
Endif
# Autres colonnes selon périodicité
Case W_PERCOD
  When 1 :
    this.C_STODISPO(1).COL00 = "--"-format$("D:DD[/]MM[/]YYYY",W_REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = W_REFPER-1
    For I = 1 To WCOLSDI-1
      WDATD(I) = WDATF(I-1)+1
      WDATF(I) = WDATF(I-1)+1
      If I<10: WNUMCOL = "COL0"+num$(I) Else WNUMCOL ="COL"+num$(I) Endif
      Assign "this.C_STODISPO(1)."+WNUMCOL With format$("D:DD[/]MM[/]YYYY",WDATD(I))
    Next I
  When 2 :
    this.C_STODISPO(1).COL00 = "--"-format$("D:DD[/]MM[/]YYYY",W_REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = W_REFPER-1
    If dayn(W_REFPER) = WSEM
      WDATD(1) = W_REFPER
      WDATF(1) = W_REFPER+6
    Else
      WDATD(1) = W_REFPER
      WDATF(1) = W_REFPER
      While dayn(WDATF(1)) <> WCOR
        WDATF(1) += 1
      Wend
    Endif
    this.C_STODISPO(1).COL01 = format$("D:DD[/]MM[/]YYYY",WDATD(1))+"++"
    For I = 2 To WCOLSDI-1
      WDATD(I) = WDATF(I-1)+1
      WDATF(I) = WDATF(I-1)+7
      If I<10: WNUMCOL = "COL0"+num$(I) Else WNUMCOL ="COL"+num$(I) Endif
      Assign "this.C_STODISPO(1)."+WNUMCOL With format$("D:DD[/]MM[/]YYYY",WDATD(I))+"++"
    Next I
  When 3 :
    WDTE = W_REFPER
    Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEMNB) From CBNLIB            # 08.07 42722
    this.C_STODISPO(1).COL00 = "--"-format$("D:DD[/]MM[/]YYYY",W_REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = W_REFPER-1
    WDTE = gdat$(15,month(WDTED+7),year(WDTED+7))
    For I = 1 To WCOLSDI-1 :
      If I = 1
        WDATD(I) = W_REFPER
      Else
        WDATD(I) = WDATF(I-1)+1                                                # hcb 38330
      Endif
      WDATF(I) = eomonth(WDATD(I))
      If I<10: WNUMCOL = "COL0"+num$(I) Else WNUMCOL ="COL"+num$(I) Endif                                         # hcb 38330
If month$(WDATD(I)+7) <> month$(WDATD(I))
      Assign "this.C_STODISPO(1)."+WNUMCOL With month$(WDATD(I))-num$(year(WDATD(I)))
Else
      Assign "this.C_STODISPO(1)."+WNUMCOL With month$(WDATD(I)+7)-num$(year(WDATD(I)+7))
Endif
      WDTE = addmonth(WDTE,1)
    Next I
Endcase
Return
############################################################
$TRT_SEL
WSEL = 1
If [F:ORD]WIPTYP > 0 &
&  [F:ORD]WIPSTA > 0
    WSEL = 2
    ITYP = [F:ORD]WIPTYP
    ISTA = [F:ORD]WIPSTA
    If [F:ORD]FMI > 1 WSEL = 1: Endif
Endif
Return

############################################################

