#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification
# Modifications :
# Issue X3-59028 - 2018-01-09 by CBO : Changes of accounting task for mindo
######################################################################################

GBIDI1 = 1
Call OBJET("GAU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"           : Gosub OUVRE
 When "LIENS"           : Gosub LIENS
 When "SETBOUT"         : Gosub SETBOUT
 When "AVANTBOUT"       : Gosub AVANTBOUT
 When "EXEBOUT"         : Gosub EXEBOUT
 When "APRES_MOD"       : Gosub APRES_MOD
 When "CREATION"        : Gosub CREATION
 When "MODIF"           : Gosub MODIF
 When "APRES_CRE"       : Gosub APRES_CRE
 When "FILTRE"          : Gosub FILTRE
 When "FILGAUCHE"       : Gosub FILGAUCHE
 When "INICRE"          : Gosub INICRE
 When "INIMOD"          : Gosub INIMOD
 When "EFFMASK"         : Gosub EFFMASK
 When "AFFMASK"         : Gosub EFFMASK
 When "RAZCRE"          : Gosub RAZCRE
 When "AV_ANNULE"       : Gosub AV_ANNULE
 When "ANNULE"          : Gosub ANNULE
 When "VERF_CHG"        : Gosub VERF_CHG
 When "CHANGE"          : Gosub CHANGE
 When "AP_CHANGE"       : Gosub AP_CHANGE
 When "DEFTRANS"        : Gosub DEFTRANS
 When "FERME"           : Gosub FIN
 When "ABANDON"         : Gosub ABANDON
Endcase
Return

$FIN
# Pour forcer un réaffichage de la pièce auto défini dans le paramétrage du lettrage des pièces auto (fonction GESGRA)
If TUNNEL
 mkstat = GSTALIT
Endif
If dim(GGAUCODOK)>0
 Kill GNBGAUCODOK,GGAUCODOK
Endif

Return

$OUVRE
Local Char    CLEGAU(10) , CLEGAD(10) , CLECPT(80)
Local Char    FICSRC(250) , NOMTRT(10) , WCHAINE(255) , ZONE(80)
Local Char    CODAXE(GLONDIE)
Local Integer FLGCCE(1..20) , AXE , NLEG


# Accessibilité au bouton "Ligne"
Local Integer OKAUZ
Local Char    AUZ(15)
Call DROITSITEF("GESGAD","",AUZ,OKAUZ) From CPTSUB
#

If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON    [AMZ] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:ACT])=0 : Local File ACTION     [ACT] : Endif
If clalev([F:ATR])=0 : Local File ACTPAR     [ATR] : Endif
If clalev([F:AAR])=0 : Local File ACTCODPAR  [AAR] : Endif
If clalev([F:GVG])=0 : Local File GVARGAU    [GVG] : Endif  : # Variables pièces auto
If clalev([F:GVP])=0 : Local File GVARPARGAU [GVP] : Endif  : # Paramètres variables pièces auto
If clalev([F:GVV])=0 : Local File GVARPARVAL [GVV] : Endif  : # Valeurs paramètres pièces auto
If clalev([F:GAG2])=0 : Local File GAUTACEF  [GAG2] : Endif : # Formules pièces auto

If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:DSP])=0 : Local File CADSP      [DSP] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif

If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif


Onerrgo ERREUR
If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif
If clalev([F:GDE])=0 : Local File GDIAENTRY  [GDE] : Endif
Onerrgo
#

Return

$DEFTRANS
Return

$FILTRE
If dim([M:ADWP]PARAM)>0 & [M:ADWP]PARAM(nolign-1)="ACCCHGENT"
    FILTSUP="TBL='STJTMP'"
Endif
Return

$FILGAUCHE
# Liste gauche par législation
If currbox="GAU_CHE" & dim([F:GAU]ACTLEG)>0 & GNBLEG>1
 Local Char LEGUSER(GLONADW)
 Call PARAMUTIL("LEGFIL",LEGUSER,GUSER,"") From SUBAUS
 If LEGUSER<>""
  # Si le paramètre LEGFIL est renseigner, afficher dans la liste gauche les lignes
  # pour lesquelles la législation de LEGFIL est active.
  FILGAUCHE = 'find("'+LEGUSER+'",[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))'
 Else
  # Si le paramètre LEGFIL est vide, afficher dans la liste gauche toutes les lignes
  # pour lesquelles au moins une des législations déclarées dans le dossier est active
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER = nomap
  If !fstat
   If !clalev([F:GAU3]) : Local File GAUTACE [GAU3] : Endif
   Global Char GGAUCODOK(GLONGAU)(1..max(1,nbrecord([GAU3])))
   Global Integer GNBGAUCODOK : GNBGAUCODOK=0
   For [GAU3]GAU0
    If func SUBGAD.TABCMP([F:ADS]DOSLEG(0..[F:ADS]NBLEG),[F:GAU3]ACTLEG(0..dim([F:GAU3]ACTLEG)-1))=1
     GNBGAUCODOK+=1
     GGAUCODOK(GNBGAUCODOK)=[F:GAU3]COD
    Endif
   Next
   FILGAUCHE -= 'find(COD,GGAUCODOK(1..GNBGAUCODOK))>0'
  Endif
 Endif
Endif
Return

$SETBOUT
If CLECUR=0 | REP<>"" | VERROU=0
 Call VIREBOUT(CHAINE,"U") From GOBJET
Endif
# Accessibilité au bouton "Ligne"
If CLECUR=0 | REP<>"" | !OKAUZ
 Call VIREBOUT(CHAINE,"O") From GOBJET
Endif
Return

$AVANTBOUT
Case BOUT
 When "O" : # Lignes
#  If !VERROU
#   GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
#   OK = 0 : Return
#  Endif
Endcase
Return

$EXEBOUT
Case REP
 When "O" : # Lignes
  If [L]AUZ<>""
   CLEGAU = CLECUR1
   CLEGAD = "1"
   Gosub VALTRT
  Endif
Endcase
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GAUTACE","DESTRA",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
Gosub CHARGE_INTIT
If [F:GAU]TBL<>""
 Read [ATB]CODFIC = [F:GAU]TBL
 [M]ABREV = [F:ATB]ABRFIC
 For I=0 To dim([M]FORCND)-1
  Call SUBST([M]FORCND(I),"TB0",[M]ABREV)
  [M]FORCND(I) = format$("KTv2:250X",[M]FORCND(I))
 Next
 Call SUBST([M]FORCND2,"TB0",[M]ABREV)
 [M]FORCND2 = format$("KTv2:250X",[M]FORCND2)
 If [F:GAU]REITBL<>""
  Read [ATB]CODFIC = [F:GAU]REITBL
  [M]REIABREV = [F:ATB]ABRFIC
  Call SUBST([M]FORCND2,"TB4",[M]REIABREV)
  [M]FORCND2 = format$("KTv2:250X",[M]FORCND2)
  For I=0 To dim([M]FORCND)-1
   Call SUBST([M]FORCND(I),"TB4",[M]REIABREV)
   [M]FORCND(I) = format$("KTv2:250X",[M]FORCND(I))
  Next
 Endif
Endif
Raz [M]FORCLC
For [GAG] Where COD=[F:GAU]COD & LINNUM=0
 J = find([F:GAG]FLD,[M]FLD(0..[M]NBLIG-1))
 If J
  [M]FORCLC(J-1) = [F:GAG]FORCLC
  If [F:GAU]TBL<>""
   Call SUBST([M]FORCLC(J-1),"TB0",[M]ABREV)
   [M]FORCLC(J-1) = format$("KTv2:250X",[M]FORCLC(J-1))
   If [F:GAU]REITBL<>""
    Call SUBST([M]FORCLC(J-1),"TB4",[M]REIABREV)
    [M]FORCLC(J-1) = format$("KTv2:250X",[M]FORCLC(J-1))
   Endif
  Endif
 Endif
Next
If dim([F:GAU]ACTLEG)>0
 #Chargement du tableau
 Filter [ADI] Where NUMTAB=909
  For [ADI]CODE
   [M:GAU1]LEG([M:GAU1]NBLEG) = [F:ADI]CODE
   If find([F:ADI]CODE,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
    [M:GAU1]ACT([M:GAU1]NBLEG) = 2
   Else
    [M:GAU1]ACT([M:GAU1]NBLEG) = 1
   Endif
   [M:GAU1]NBLEG +=1
  Next
 Filter [ADI]
Endif
Gosub GRISE_TRC
If [M:GAU1]REITBL<>""
 Actzo [M:GAU1]REIFLD
Else
 Grizo [M:GAU1]REIFLD
Endif
Return

$RAZCRE
Gosub CHARGE_INTIT
Affzo [GAU1]15
Gosub CHARGE_LEG
Return

$CHARGE_LEG
Filter [ADI] Where NUMTAB=909
For [ADI]CODE
 [M:GAU1]LEG([M:GAU1]NBLEG) = [F:ADI]CODE
 [M:GAU1]ACT([M:GAU1]NBLEG) = 2
 [M:GAU1]NBLEG +=1
Next
Filter [ADI]
Affzo [GAU1]NBLEG,LEG,ACT
Return

$GRISE_TRC
Local Char ACT(GLONACT) : ACT = [F:GAU]TRCACT
If [M:GAU1]GRPFLG<>2 & [M:GAU1]TBL<>"PAYMENTH"
 Effzo [M:GAU2]
 Grizo [M:GAU2]
Elsif [M:GAU2]TRCFLG<>2
 Actzo [M:GAU2]TRCFLG
 Effzo [M:GAU2]TRCTBL, TRCKEY
 Effzo [M:GAU2]10
 Effzo [M:GAU2]20
 Grizo [M:GAU2]TRCTBL, TRCKEY
 Grizo [M:GAU2]10
 Grizo [M:GAU2]20
Else
 Actzo [M:GAU2]
 If [M:GAU2]TRCTBL="" : Effzo [M:GAU2]TRCKEY : Grizo [M:GAU2]TRCKEY  : Endif
 If [L]ACT<>""
  Gosub CHARGE_PAR
 Endif
Endif
Return

$CHARGE_PAR
# Libel
If [L]ACT<>"GASACCNUM1"
 # Code paramètres
 [M]LIBTRCCODPAR = format$("K:30X",mess(23,124,1))
 # Valeurs paramètres
 [M]LIBTRCVALPAR = format$("K:30X",mess(49,126,1))
Else
 # Code
 [M]LIBTRCCODPAR = format$("K:30X",mess(37,100,1))
 # Champ
 [M]LIBTRCVALPAR = format$("K:30X",mess(36,124,1))
Endif
Raz [M]NBPAR, [M]TRCCODPAR, [M]TRCVALPAR
While [L]ACT<>""
 Read [ACT]ACTION = [L]ACT
 For [ATR]NOPAR Where ACTION=[L]ACT
  If [F:ATR]NOPAR>1 or [F:ACT]TYPACT<>2
   If !find([F:ATR]CODPAR,[M]TRCCODPAR(0..[M]NBPAR-1))
    [M]TRCCODPAR([M]NBPAR) = [F:ATR]CODPAR
    K = find([F:ATR]CODPAR,[F:GAU]TRCCODPAR(0..dim([F:GAU]TRCCODPAR)-1))
    If K
     [M]TRCVALPAR([M]NBPAR) = [F:GAU]TRCVALPAR(K-1)
    Endif
    Read [AAR]CODPAR = [F:ATR]CODPAR
    [M]NBPAR += 1
   Endif
  Endif
 Next ATR
 [L]ACT = [F:ACT]ACTSUI
Wend
Return

$ABANDON
If GREP="D"
 Call DEL_PARVAR([M]COD)
Endif
Return

$EFFMASK
Return

$INICRE
$INIMOD
If dim([F:GAU]DES)>0
 [F:GAU]DES = [M:GAU0]DESTRA
Endif
If [F:GAU]TBL<>""
 Call SUBST([F:GAU]FORCND2,[M]ABREV,"TB0")
 If [F:GAU]REITBL<>""
  Call SUBST([F:GAU]FORCND2,[M]REIABREV,"TB4")
 Endif
 For I=0 To dim([M]FORCND)-1
  Call SUBST([F:GAU]FORCND,[M]ABREV,"TB0")
  If [F:GAU]REITBL<>""
   Call SUBST([F:GAU]FORCND,[M]REIABREV,"TB4")
  Endif
 Next
Endif
# Gestion en plus d'un tableau des legislation active pour liste gauche
If dim([F:GAU]ACTLEG)>0
 For I=0 To dim([F:GAU]ACTLEG)-1
  [F:GAU]ACTLEG(I)=""
 Next
 NLEG=0
 [F:GAU]NBRLEG=0
 For I=0 To [M:GAU1]NBLEG-1
  If [M:GAU1]ACT(I)=2
   [F:GAU]ACTLEG(NLEG)=[M:GAU1]LEG(I)
   [F:GAU]NBRLEG+=1
   NLEG+=1
  Endif
 Next
Endif
Return

$CREATION
For I=0 To [M]NBLIG-1
 If [M]FORCLC(I)<>""
  WCHAINE = [M]FORCLC(I)
  If [F:GAU]TBL<>""
   Call SUBST(WCHAINE,[M]ABREV,"TB0")
   If [F:GAU]REITBL<>""
    Call SUBST(WCHAINE,[M]REIABREV,"TB4")
   Endif
  Endif
  [F:GAG]COD    = [F:GAU]COD
  [F:GAG]LINNUM = 0
  [F:GAG]FLD    = [M]FLD(I)
  [F:GAG]FORCLC = WCHAINE
  Write [GAG]
  If fstat
   GOK = 0 : Call FSTA("GAG") From GLOCK : Break
  Endif
 Endif
Next I
If GOK<1 : Return : Endif
If REP="D"
 For [GAD]GAD0 Where COD=CLECUR1
  [F:GAD]COD = [F:GAU]COD
  Write [GAD]
  If fstat
   GOK=0 : Call FSTA("GAD") From GLOCK : Break
  Endif
  Gosub TEXTRA2
  If GOK<1 : Break : Endif
  For [GAG]GAG0 Where COD=CLECUR1 & LINNUM=[F:GAD]LINNUM
   [F:GAG]COD = [F:GAU]COD
   Write [GAG]
   If fstat
    GOK=0 : Call FSTA("GAG") From GLOCK : Break 2
   Endif
  Next
 Next
Endif
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Delete [GAG] Where COD=[F:GAU]COD & LINNUM=0
If fstat=1
 GOK=-1 : GLOCK = "$GAUTACEF"-[F:GAU]COD-"0" : Return
Endif
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub CREATION
Return

$AV_ANNULE
# Quand on supprime une piece auto , on sup tous les textes trad rattachés à cette piéce
# et on doit aussi supprimer tous les textes trad rattachés aux lignes qui vont être
# supprimées.
For [GAD]GAD0 Where COD=[M]COD
 Call SUPTEXTRA("GAUTACED","DESTRA",[M]COD,num$([F:GAD]LINNUM)) From ATEXTRA
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif
Return


$ANNULE
Local Char    FIC1(250)
Local Integer NUFIC , SYSTA
FIC1 = filpath("TRT","WMGAU"+[L]CODE,"src",APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
For NUFIC=1 To 98
 FIC1 = filpath("TRT","WMGAV"+[L]CODE+chr$(64+NUFIC),"src",APPLI)
 If filinfo(FIC1,0)<=0 : Break : Endif
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Next NUFIC
Call EXISTE_ADX("",APPLI,"WMGAU"+[L]CODE,SYSTA) From ORDSYS
If SYSTA
 Call EFFACE_ADX("",APPLI,"WMGAU"+[L]CODE,SYSTA) From ORDSYS
Endif
For NUFIC=1 To 98
 Call EXISTE_ADX("",APPLI,"WMGAV"+[L]CODE+chr$(64+NUFIC),SYSTA) From ORDSYS
 If SYSTA<=0 : Break : Endif
 Call EFFACE_ADX("",APPLI,"WMGAV"+[L]CODE+chr$(64+NUFIC),SYSTA) From ORDSYS
Next NUFIC

Call SUPTEXTRA("GAUTACE","DESTRA",[M]COD,"") From ATEXTRA
If GOK<1 : Return : Endif

Call SUPTEXTRA("GAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
If GOK<1 : Return : Endif
Return

$VERF_CHG
# Quand on change la clé d une piece auto , on doit changer la clé pour ts les textes trad
# rattachéS à cette piéce ainsi que changer la clé de ts les textes trad rattachés aux
#lignes de la piéce auto
For [GAD]GAD0 Where COD=[M]COD
 Call CHGTEXTRA("GAUTACED","DESTRA",[M]COD,num$([F:GAD]LINNUM),NCODE,num$([F:GAD]LINNUM)) From ATEXTRA
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif
Return

$CHANGE
Local Char    FIC1(250) , FIC2(250)
Local Integer NUFIC , SYSTA

FIC1 = filpath("TRT","WMGAU"+OCODE,"src",APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
For NUFIC=1 To 98
 FIC1 = filpath("TRT","WMGAV"+OCODE+chr$(64+NUFIC),"src",APPLI)
 If filinfo(FIC1,0)<=0 : Break : Endif
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Next NUFIC

Call EXISTE_ADX("",APPLI,"WMGAU"+OCODE,SYSTA) From ORDSYS
If SYSTA
 Call EFFACE_ADX("",APPLI,"WMGAU"+OCODE,SYSTA) From ORDSYS
Endif
For NUFIC=1 To 98
 Call EXISTE_ADX("",APPLI,"WMGAV"+OCODE+chr$(64+NUFIC),SYSTA) From ORDSYS
 If SYSTA<=0 : Break : Endif
 Call EFFACE_ADX("",APPLI,"WMGAV"+OCODE+chr$(64+NUFIC),SYSTA) From ORDSYS
Next NUFIC
Return

$AP_CHANGE
Call CHGTEXTRA("GAUTACE","DESTRA",[M]COD,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GAUTACE","SHOTRA",[M]COD,"",NCODE,"") From ATEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GAUTACE","DESTRA",CLECUR1,"","GAUTACE","DESTRA",[M]COD,"")  From ATEXTRA
 Call DUPTEXTRA("GAUTACE","SHOTRA",CLECUR1,"","GAUTACE","SHOTRA",[M]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GAUTACE","DESTRA",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GAUTACE","SHOTRA",[M]COD,"") From ATEXTRA
Return

$TEXTRA2
## En duplication d'un code pièce auto, on veut récupérer les intitulés traduisibles de toutes les lignes de
## pièces autos
Call DUPTEXTRA("GAUTACED","DESTRA",CLECUR1,num$([F:GAD]LINNUM),"GAUTACED","DESTRA",[M]COD,num$([F:GAD]LINNUM)) From ATEXTRA
Return

$CHARGE_INTIT
Local Integer I, J, TYPREF
I = -1

I += 1 : [M]FLD(I) = "CAT" : [M]INTIT(I) = mess(8,105,1)   : # Catégorie
I += 1 : [M]FLD(I) = "STA" : [M]INTIT(I) = mess(9,105,1)   : # Etat
I += 1 : [M]FLD(I) = "GTE" : [M]INTIT(I) = mess(10,105,1)  : # Type de pièce
I += 1 : [M]FLD(I) = "NUM" : [M]INTIT(I) = mess(11,105,1)  : # Numéro de pièce
I += 1 : [M]FLD(I) = "FCY" : [M]INTIT(I) = mess(12,105,1)  : # Site
I += 1 : [M]FLD(I) = "JOU" : [M]INTIT(I) = mess(13,105,1)  : # Journal
I += 1 : [M]FLD(I) = "DAT" : [M]INTIT(I) = mess(14,105,1)  : # Date comptable
I += 1 : [M]FLD(I) = "ENT" : [M]INTIT(I) = mess(53,105,1)  : # Date de saisie
I += 1 : [M]FLD(I) = "DUD" : [M]INTIT(I) = mess(15,105,1)  : # Date d'échéance
I += 1 : [M]FLD(I) = "BAN" : [M]INTIT(I) = mess(99,105,1)  : # Date de banque
I += 1 : [M]FLD(I) = "VAL" : [M]INTIT(I) = mess(54,105,1)  : # Date de valeur
I += 1 : [M]FLD(I) = "RVS" : [M]INTIT(I) = mess(55,105,1)  : # Date d'extourne
I += 1 : [M]FLD(I) = "VCR" : [M]INTIT(I) = mess(36,105,1)  : # Libellé
I += 1 : [M]FLD(I) = "PJT" : [M]INTIT(I) = mess(217,105,1): # Project
I += 1 : [M]FLD(I) = "REF" : [M]INTIT(I) = mess(17,105,1)  : # Référence pièce
I += 1 : [M]FLD(I) = "CUR" : [M]INTIT(I) = mess(18,105,1)  : # Devise
I += 1 : [M]FLD(I) = "TCR" : [M]INTIT(I) = mess(21,105,1)  : # Type de cours
I += 1 : [M]FLD(I) = "CIB" : [M]INTIT(I) = mess(60,105,1)  : # Code interbancaire
I += 1 : [M]FLD(I) = "BVC" : [M]INTIT(I) = mess(22,105,1)  : # Document d'origine
I += 1 : [M]FLD(I) = "BVD" : [M]INTIT(I) = mess(23,105,1)  : # Date document
I += 1 : [M]FLD(I) = "DAS" : [M]INTIT(I) = mess(215,105,1) : # Déclaration honoraires
I += 1 : [M]FLD(I) = "SIM" : [M]INTIT(I) = mess(25,105,1)  : # Référence simulation
I += 1 : [M]FLD(I) = "COR" : [M]INTIT(I) = mess(26,105,1)  : # Devise d'origine
I += 1 : [M]FLD(I) = "PAZ" : [M]INTIT(I) = mess(57,105,1)  : # Bon à payer
I += 1 : [M]FLD(I) = "FUP" : [M]INTIT(I) = mess(56,105,1)  : # Relance
For TYPREF=1 To len(mess(0,2644,1))
 I += 1 : [M]FLD(I) = "MLT"+num$(TYPREF) : [M]INTIT(I) = mess(168,105,1)-mess(TYPREF,2644,1) : # Cours multiplicateur/type référentiel
 I += 1 : [M]FLD(I) = "DIV"+num$(TYPREF) : [M]INTIT(I) = mess(169,105,1)-mess(TYPREF,2644,1) : # Cours diviseur/type référentiel
Next
I += 1 : [M]FLD(I) = "DIA" : [M]INTIT(I) = mess(102,105,1) : # Schéma de saisie


# Zones supp de l'écran GACCENTR1
For [AMZ]CODE Where CODMSK="GACCENTR1" & CODZON>="X" & CODACT<>"" & NUMBLOC<>6
 I += 1 : [M]FLD(I) = [F:AMZ]CODZON
 Call TEXTE([F:AMZ]INTIT,[M]INTIT(I)) From OBJDIV
Next

# Pour pouvoir ajouter des lignes au paramétrage
GPOINT = "CHARGE" : Gosub ENTREE From EXEFNC

[M]NBLIG = I+1
Return

################################################
# Issue X3-122423 - 2017-04-17 by VAVIL
Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
If AB1="" : End : Endif
Local Integer K
Local Char    SEP(1)
CHAINE = toupper(CHAINE)
Repeat
SEP = ":"
K = instr(1,CHAINE,SEP+AB1+"]")
If !K
  SEP = "["
  K = instr(1,CHAINE,SEP+AB1+"]")
Endif
If K
  CHAINE = left$(CHAINE,K-1)+SEP+AB2+"]"+right$(CHAINE,K+len(AB1)+2)
Endif
Until K=0
End

#Subprog SUBST(CHAINE,AB1,AB2)
#Variable Char CHAINE
#Value    Char AB1
#Value    Char AB2
#If AB1="" : End : Endif
#Local Integer K
#CHAINE = toupper(CHAINE)
#Repeat
# K = instr(1,CHAINE,AB1+"]")
# If K
#  CHAINE = left$(CHAINE,K-1)+AB2+"]"+right$(CHAINE,K+len(AB1)+1)
# Endif
#Until K=0
#End
# End issue 122423
$APRES_MOD
$APRES_CRE
Gosub VERIF

$VALTRT
Call TEMPON("V") From GESECRAN
Call VALIDATION([F:GAU]COD,nomap)
Call TEMPOFF From GESECRAN
Local Integer PSUBB
Call EXISTE_ADX("","","BATCHCPT",PSUBB) From ORDSYS
# Issue X3-59028
#If PSUBB
# Call SETFLG From BATCHCPT : # Flag pour le batch
#Endif
# End Issue X3-59028
Return

Subprog GENDOS(APPLI)
Value Char APPLI()

Local File =APPLI+".ATABLE"     [ATB]
Local File =APPLI+".ATABZON"    [ATZ]
Local File =APPLI+".ATABIND"    [ATI]
Local File =APPLI+".AMSKZON"    [AMZ]
Local File =APPLI+".ATYPE"      [ATY]
Local File =APPLI+".GAUTACE"    [GAU]
Local File =APPLI+".GAUTACED"   [GAD]
Local File =APPLI+".GAUTACEF"   [GAG]
Local File =APPLI+".GVARGAU"    [GVG]
Local File =APPLI+".GVARPARVAL" [GVV]
Local File =APPLI+".GVARPARGAU" [GVP]

Local File =APPLI+".GTYPACCENT" [GTE]
Local File =APPLI+".FACILITY"   [FCY]
Local File =APPLI+".TABCUR"     [TCU]
Local File =APPLI+".GACCOUNT"   [GAC]
Local File =APPLI+".BPARTNER"   [BPR]
Local File =APPLI+".TABUNIT"    [TUN]
Local File =APPLI+".CADSP"      [DSP]
Local File =APPLI+".TABVAT"     [TVT]
Local File =APPLI+".CACCE"      [CCE]
Local File =APPLI+".GDIE"       [DIE]

Onerrgo ERREUR
 Local File =APPLI+".GJOURNAL"   [JOU]
 Local File =APPLI+".GDIAENTRY"  [GDE]
Onerrgo
#

Local Char    WCHAINE(255) , TABLE(10) , ABR(GLONABR)(1..50), ABRL1(GLONABR), ABRL2(GLONABR)
Local Char    CONSTANTE(80) , SVG_CONSTANTE(80) , OBJET(5) , ZONE(GLONAVA)
Local Integer K1 , K2 , K3 , NBABR , TYP1 , TYP2, K4
Local Decimal MINI , MAXI
Local Integer TYPECR

For [GAU]
 If func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:GAU]CODACT,[F:GAU]MODULE) : # Issue 120223 - 2017-03-02 by GLE : check the automatic journal is enabled before validate it
  Call ECR_TRACE([F:GAU]COD,0) From GESECRAN
  Call VALIDATION([F:GAU]COD,APPLI)
  # Demande 42727
  Gosub VERIF_AUTO
 Endif
Next
End

Subprog VALIDATION(COD,DOSSIER)
Value Char COD
Value Char DOSSIER
Local Char    CLEGAU(10) , CLEGAD(10) , CLECPT(80) , MAGIC(30)
Local Char    FICSRC(GDIMFIC) , NOMTRT(GLONADC) , NOMSUP(GLONADC)
Local Char    WCHAINE(255) , ZONE(80) , CHAMP(20)
Local Char    TVARIA(15)(1..10)
Local Char    CHAINE_PARAM(255)
Local Char    FORMULE(255)
Local Char    TRAITEMENT(10)
Local Char    SUB_PROG(10)
Local Char    CODVARIA(80) : # Code paramètre correspondant à la variable à évaluer
Local Char    TYPVARIA(20) : # Type du paramètre correspondant à la variable à évaluer
Local Char    DIMVAR(10)   : # Dimension variable si de type char
Local Char    MESSA(80)
Local Char    TMESSA(80)(1..dim([F:GAU]LIKTBL))
Local Integer VARIA, NBVAR, IND, STAT
Local Integer FLGCCE(1..20) , AXE , I , J , DIME , OK
Local Integer NBERR, ERR
Local Char    ABRLNK(GLONABR)
Local Char    MACHINE(80), APPLI(80)
Local Integer OUVRE , MAXLIG , NBRLIG

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:GVG])=0  : Local File =APPLI+".GVARGAU"    [GVG] : Endif : # Variables pièces auto
If clalev([F:GVV])=0  : Local File =APPLI+".GVARPARVAL" [GVV] : Endif : # Valeurs variables pièces auto
If clalev([F:GVP])=0  : Local File =APPLI+".GVARPARGAU" [GVP] : Endif : # Valeurs variables pièces auto
If clalev([F:GAG2])=0 : Local File =APPLI+".GAUTACEF"  [GAG2] : Endif : # Formules pièces autos

If clalev([F:GTE])=0 : Local File =APPLI+".GTYPACCENT" [GTE] : Endif
If clalev([F:FCY])=0 : Local File =APPLI+".FACILITY"   [FCY] : Endif
If clalev([F:TCU])=0 : Local File =APPLI+".TABCUR"     [TCU] : Endif
If clalev([F:GAC])=0 : Local File =APPLI+".GACCOUNT"   [GAC] : Endif
If clalev([F:BPR])=0 : Local File =APPLI+".BPARTNER"   [BPR] : Endif
If clalev([F:TUN])=0 : Local File =APPLI+".TABUNIT"    [TUN] : Endif
If clalev([F:DSP])=0 : Local File =APPLI+".CADSP"      [DSP] : Endif
If clalev([F:TVT])=0 : Local File =APPLI+".TABVAT"     [TVT] : Endif
If clalev([F:CCE])=0 : Local File =APPLI+".CACCE"      [CCE] : Endif
If clalev([F:DIE])=0 : Local File =APPLI+".GDIE"       [DIE] : Endif
Onerrgo ERREUR
 If clalev([F:JOU])=0 : Local File =APPLI+".GJOURNAL"   [JOU] : Endif
 If clalev([F:GDE])=0 : Local File =APPLI+".GDIAENTRY"  [GDE] : Endif
Onerrgo
#

SAVIRS = adxirs
SAVIFS = adxifs
SAVIUM = adxium

Read [GAU]GAU0 = COD
MAGIC   = mess(77,133,1) : # Superviseur Adonix
NOMTRT  = "WMGAU"+[F:GAU]COD
NOMSUP  = "WMGAV"+[F:GAU]COD
OUVRE   = 0
MAXLIG  = 20

#------------------------------------------------------------------------------------------------------#
# MAXLIG = Nombre de lignes maxi d'un paramètrage de pièce auto
# Au-delà de cette limite, les lignes supplémentaires sont générées par tranches de MAXLIG lignes
# dans un traitement WMGAVxy où x est le code paramètrage et y est une lettre à partir de A.
#------------------------------------------------------------------------------------------------------#

Gosub TRT_SUP

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

Gosub TRT_OUVRE
Gosub ETIQUETTE
Gosub TRT_FIN

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
End

$ERREUR
ERR=errn
Resume

##########################
$TRT_SUP
For I=1 To 98
 If filinfo(filpath("TRT",NOMSUP+chr$(64+I),"src",APPLI,"",MACHINE),0)<=0
  Break
 Endif
 Call EFFACE(filpath("TRT",NOMSUP+chr$(64+I),"src",APPLI,"",MACHINE),STAT) From ORDSYS
Next I

For I=1 To 98
 Call EXISTE_ADX(MACHINE,APPLI,NOMSUP+chr$(64+I),STAT) From ORDSYS
 If STAT<=0 : Break : Endif
 Call EFFACE_ADX(MACHINE,APPLI,NOMSUP+chr$(64+I),STAT) From ORDSYS
Next I
Return

##########################
$TRT_OUVRE
Case OUVRE
 When 0
  FICSRC = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
  Openo FICSRC,0
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
  Wrseq "#"-MAGIC
  Wrseq "#"-mess(88,105,1)-COD
  Wrseq
 When 99
  Openo
  FICSRC = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
  Openo FICSRC,-1
 When Default
  Openo
  FICSRC = filpath("TRT",NOMSUP+chr$(64+OUVRE),"src",APPLI,"",MACHINE)
  Openo FICSRC,0
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
  Wrseq "#"-MAGIC
  Wrseq "#"-mess(88,105,1)-COD
  Wrseq
Endcase
OUVRE += 1
Return

##########################
$TRT_FIN
Wrseq
Openo
If NBERR
 For I=1 To NBERR
  Call ECR_TRACE(TMESSA(I),0) From GESECRAN
 Next I
Endif
Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
If OUVRE>1
 For I=1 To 98
  If filinfo(filpath("TRT",NOMSUP+chr$(64+I),"src",APPLI,"",MACHINE),0)<=0
   Break
  Endif
  Call VALID("TRT",NOMSUP+chr$(64+I),DOSSIER,STAT) From VALMSKSUB
 Next I
Endif
Return

##########################
$ETIQUETTE
Wrseq "$OUVRE"
For I=0 To [F:GAU]NBRTBL-1
 Read [ATB]CODFIC = [F:GAU]LIKTBL(I)
 Wrseq "If clalev([F:"+[F:ATB]ABRFIC+"])=0"
 Wrseq " Local File "+[F:GAU]LIKTBL(I)+" ["+[F:ATB]ABRFIC+"]"
 Wrseq "Endif"
Next I
If find("PINVOICE",[F:GAU]TBL,[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1)) |
&  find("SINVOICE",[F:GAU]TBL,[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1))
 Wrseq "If clalev([F:DUD])=0"
 Wrseq " Local File GACCDUDATE [DUD]"
 Wrseq "Endif"
Endif
Wrseq "Return"
Wrseq ""
Wrseq "$LIENS"
Local Integer FLGCPY
FLGCPY = 0
For I=0 To [F:GAU]NBRTBL-1
 If [F:GAU]TBL="PAYMENTH" & find([F:GAU]LIKTBL(I),"COMPANY","TABPAYTYP","BANK")
  Case [F:GAU]LIKTBL(I)
   When "COMPANY"
    If FLGCPY=0
     Wrseq "Call LEC_CPY([F:TB0]CPY) From CPTLEC"
     FLGCPY = 1
    Endif
   When "TABPAYTYP"
    If FLGCPY=0
     Wrseq "Call LEC_CPY([F:TB0]CPY) From CPTLEC"
     FLGCPY = 1
    Endif
    Wrseq "Call LEC_TPY_LEG([F:CPY]LEG,[F:TB0]PAYTYP) From CPTLEC"
   When "BANK"
    Wrseq "Call LEC_BAN([F:TB0]BAN) From CPTLEC"
  Endcase
 Elsif [F:GAU]LIKTBL(I)<>""
  Read [ATB]CODFIC = [F:GAU]LIKTBL(I)
  CHAMP = [F:GAU]LIKFLD(I)
  J = instr(1,CHAMP,"(")
  If J
   DIME  = val(right$(CHAMP,J+1))
   CHAMP = left$(CHAMP,J-1)
  Else
   DIME  = 0
  Endif

  ERR = 0

  Read [ATZ]LIEN = [F:GAU]LIKTBL(I);[F:GAU]TBL;CHAMP
  If !fstat : OK = 1
   ABRLNK = "TB0"
  Endif
  If !OK & [F:GAU]REITBL <> ""
   Read [ATZ]LIEN = [F:GAU]LIKTBL(I);[F:GAU]REITBL;CHAMP
   If !fstat : OK = 1 : ABRLNK = "TB4" : Endif
  Endif
  # si lien incorrect on ne génère pas le Read= dans $LIENS et on
  # indique l'erreur dans la trace
  # on gère les liens "en cascade"
  If !OK
   ERR = 1
   For J=0 To I-1
    Read [ATZ]LIEN(2) = [F:GAU]LIKTBL(I);[F:GAU]LIKTBL(J)
    If !fstat
     Read [ATB]CODFIC = [F:GAU]LIKTBL(J)
     ABRLNK = [F:ATB]ABRFIC
     Read [ATB]CODFIC = [F:GAU]LIKTBL(I)
     ERR = 0 : Break
    Endif
   Next J
  Endif

  Read [ATI]NUMLIG(2) = [F:GAU]LIKTBL(I);1
  If fstat : ERR = 1 : Endif

  If !ERR
   Onerrgo ERREUR
   If instr(1,[F:ATZ]EXPLIEN,"[V]GSUPCLE") & instr(1,[F:ATI]DESCRIPT,"LEG")
    If clalev([F:TB0]) : Close File [TB0] : Endif
    Local File =APPLI+"."+[F:GAU]TBL [TB0]
    If dim([F:TB0]CPY) >0
     Wrseq "If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif"
     Wrseq "Call LEC_CPY([F:TB0]CPY) From CPTLEC"
    Endif
   Endif
   Onerrgo
   If [F:GAU]LIKTBL(I)="COMPANY"
    Wrseq "Call LEC_CPY(";
   Else
    Wrseq "Read ["+[F:ATB]ABRFIC+"]"+[F:ATI]CODIND+" = ";
   Endif
   If [F:ATZ]EXPLIEN=""
    If [F:GAU]REITBL<>"" & right$([F:GAU]LIKFLD(I),J+1) = "indice)"
     Wrseq "[F:"+ABRLNK+"]"+CHAMP+"(indice)";
    Else
     Wrseq "[F:"+ABRLNK+"]"+CHAMP;
    Endif
   Else
    WCHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
    Repeat
     J = instr(1,WCHAINE,"indice")
     If J
      WCHAINE = left$(WCHAINE,J-1)+num$(DIME)+right$(WCHAINE,J+6)
     Endif
    Until J=0
    J = 0
    While WCHAINE<>""
     K = instr(1,WCHAINE,";")
     If K
      ZONE = left$(WCHAINE,K-1) : WCHAINE = right$(WCHAINE,K+1)
     Else
      ZONE = WCHAINE : WCHAINE = ""
     Endif
     J += 1
     If J>1 : Wrseq ";"; : Endif
     If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
      Wrseq "[F:"+ABRLNK+"]"+ZONE;
     Else
      If instr(1,[F:ATZ]EXPLIEN,"[V]GSUPCLE") & instr(1,[F:ATI]DESCRIPT,"LEG") & dim([F:TB0]CPY) >0
       Wrseq "[F:CPY]LEG"
       WZONE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
       K = instr(1,WZONE,";")
       If K
        WZONE = left$(WZONE,K-1)
       Endif
       Wrseq "If fstat"
       Wrseq " Read ["+[F:ATB]ABRFIC+"]"+[F:ATI]CODIND+" = ";
       Wrseq "[F:"+ABRLNK+"]"+WZONE+';""'
       Wrseq "Endif"
      Else
       Wrseq  ZONE;
      Endif
     Endif
    Wend
   Endif
   If [F:GAU]LIKTBL(I)="COMPANY"
    Wrseq ") From CPTLEC"
   Endif
   Wrseq

  Elsif ERR
   NBERR += 1
   TMESSA(NBERR) = [F:GAU]COD-mess(10,114,1)-[F:GAU]LIKTBL(I)
  Endif

 Endif
Next

If find([F:GAU]TBL,"PINVOICE","SINVOICE")
 Wrseq "Filter [DUD] Where ACCNUM=[F:TB0]ACCNUM"
 I=1
Elsif find("PINVOICE",[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1))
 Wrseq "Filter [DUD] Where ACCNUM=[F:PIH]ACCNUM"
 I=1
Elsif find("SINVOICE",[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1))
 Wrseq "Filter [DUD] Where ACCNUM=[F:SIH]ACCNUM"
 I=1
Else
 I=0
Endif
If I
 Wrseq "Read [DUD]DUD1 First"
 Wrseq "If fstat>2 : Raz [F:DUD] : Endif"
 Wrseq "Filter [DUD]"
Endif
#---
Wrseq "Return"
Wrseq
Wrseq "$CLE"
If [F:GAU]KEYTBL<>""
 Read [ATI]CODIND = [F:GAU]TBL;[F:GAU]KEYTBL
Else
 Read [ATI]NUMLIG(2) = [F:GAU]TBL;1
Endif
WCHAINE = [F:ATI]DESCRIPT
K = 0
While WCHAINE<>""
 I = instr(1,WCHAINE,"+")
 J = instr(1,WCHAINE,"-")
 If     I & J : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I
  ZONE = left$(WCHAINE,I-1) : WCHAINE = right$(WCHAINE,I+1)
 Else
  ZONE = WCHAINE : WCHAINE = ""
 Endif
 K += 1
 Wrseq 'CLE('+num$(K)+') = "'+ZONE+'"'
Wend
Wrseq "NBCLE  = "+num$(K)
Wrseq "INDCUR = "+num$([F:ATI]NUMLIG)
Wrseq "Return"
Wrseq

Wrseq "$LNKTBL"
If [F:GAU]REITBL<>""
 Local Char ABRLNK1(3), ABRLNK2(3)
 Local Char DESCRIP(30), INDEX(10)
 ABRLNK1 = "TB0"
 ABRLNK2 = "TB4"
 Read [ATI]CODIND = [F:GAU]TBL;[F:GAU]KEYTBL
 INDEX = [F:ATI]CODIND
 Filter [ATI] Where CODFIC = [F:GAU]REITBL
 Read [ATI]CODIND First
 Filter [ATI]
 DESCRIP = [F:GAU]REIFLD+"+"+[F:ATI]DESCRIPT
 Call SUBST2(DESCRIP,"+",";")
 ## Bug 57329 Pour résoudre le problème de perf en comptabilisation de règlement
 If [F:GAU]TBL="PAYMENTH" & [F:GAU]REITBL="PAYMENTD" & [F:GAU]REIFLD="CURLIN"
  Wrseq 'If left$(CRITERE,11)="[F:TB0]NUM="'
  Wrseq ' CRITERE = "[F:TB4"+right$(CRITERE,7)'
  Wrseq 'Endif'
 Endif
 Wrseq "Link ["+ABRLNK2+"] With ["+ABRLNK1+"]"+INDEX+"=["+ABRLNK2+"]"+ZONE+" As [LNK]"
 Wrseq "& Where evalue(CRITERE)"
 Wrseq "& Order by Key CLE="+DESCRIP
Endif
Wrseq "Return"
Wrseq

Wrseq "$AP_LIENS"
If [F:GAU]ACTLIK<>""
 Wrseq "Gosub"-[F:GAU]ACTLIK-"From"-[F:GAU]PRGLIK
Endif
Wrseq "Return"
Wrseq

Wrseq "$AP_PIECE"
If [F:GAU]ACTAFTVCR<>""
 Wrseq "Gosub"-[F:GAU]ACTAFTVCR-"From"-[F:GAU]PRGAFTVCR
Endif
Wrseq "Return"
Wrseq

Wrseq "$EVAL0"
Wrseq "Case EXPR"
For [GAG] Where COD=[F:GAU]COD & LINNUM=0
 If [F:GAG]FORCLC<>""
  Wrseq ' When "'+[F:GAG]FLD+'" : ';
  Wrseq ' ZONE = ';vireblc(format$("KT:255X",[F:GAG]FORCLC),2)
 Endif
Next
Wrseq "Endcase"
Wrseq "Return"
Wrseq
Wrseq "$SPE0"
For [AMZ]CODE Where CODMSK="GACCENTR1" & CODZON>="X" & CODACT<>"" & NUMBLOC<>6
 Read [ATY]CODTYP = [F:AMZ]CODTYP
 Case [F:ATY]TYPTYP
  When 1         : Wrseq "Call EVAL_INT";
  When 2,3,4,5,6 : Wrseq "Call EVAL_NUM";
  When 7         : Wrseq "Call EVAL_CHAR";
  When 8         : Wrseq "Call EVAL_DATE";
 Endcase
 Wrseq '([M]'+[F:AMZ]CODZON+',"'+[F:AMZ]CODZON+'",1,0,';
 Case [F:ATY]TYPTYP
  When 1         : Wrseq '0';
  When 2,3,4,5,6 : Wrseq '0';
  When 7         : Wrseq '""';
  When 8         : Wrseq '[0/0/0]';
 Endcase
 Wrseq ',STAT) From CPTAUTO'
Next
Wrseq "Return"
Wrseq
Wrseq "$SPE1"
For [AMZ]CODE Where CODMSK="GACCENTR1" & CODZON>="X" & CODACT<>"" & NUMBLOC=6
 Read [ATY]CODTYP = [F:AMZ]CODTYP
 Case [F:ATY]TYPTYP
  When 1         : Wrseq "Call EVAL_INT";
  When 2,3,4,5,6 : Wrseq "Call EVAL_NUM";
  When 7         : Wrseq "Call EVAL_CHAR";
  When 8         : Wrseq "Call EVAL_DATE";
 Endcase
 Wrseq '([M]'+[F:AMZ]CODZON+'(NOL),"'+[F:AMZ]CODZON+'",2,0,';
 Case [F:ATY]TYPTYP
  When 1         : Wrseq '0';
  When 2,3,4,5,6 : Wrseq '0';
  When 7         : Wrseq '""';
  When 8         : Wrseq '[0/0/0]';
 Endcase
 Wrseq ',STAT) From CPTAUTO'
Next
Wrseq "Return"
Wrseq
[L]NBRLIG = 0

For [GAD]GAD0 Where COD=[F:GAU]COD
 [L]NBRLIG += 1
 If [L]NBRLIG>[L]MAXLIG & mod([L]NBRLIG-1,[L]MAXLIG)=0
  Gosub TRT_OUVRE
 Endif
 Wrseq "$EVAL"+num$([F:GAD]LINNUM)
 Wrseq "Case EXPR"
 Raz FLGCCE



 For [GAG]GAG0 Where COD=[F:GAD]COD & LINNUM=[F:GAD]LINNUM
  If [F:GAG]FORCLC<>"" or (left$([F:GAG]FLD,3)="CCE" and [F:GAD]CCEDEF<>"")
   Wrseq ' When "'+[F:GAG]FLD+'"'
   If [F:GAG]FORCLC<>""
    Gosub ANALYSE_FORMULE
   Else
    Wrseq '  ZONE = ""'
   Endif
   If (left$([F:GAG]FLD,3)="CCE" and [F:GAD]CCEDEF<>"")
    FLGCCE(val(right$([F:GAG]FLD,4))) = 1
    Read [GAG2]GAG0 = [F:GAD]COD;[F:GAD]LINNUM;"DIE"+right$([F:GAG]FLD,4)
    If !fstat
     Wrseq '  If ZONE="" : Call INISEC(ZONE,"'+[F:GAD]CCEDEF+'",'+[F:GAG2]FORCLC+') From SUBCDE : Endif'
    Endif
   Endif
  Endif
 Next GAG
 If [F:GAD]CCEDEF<>""
  For AXE=1 To max(GOPTCANA,20)
   Read [GAG]GAG0 = [F:GAD]COD;[F:GAD]LINNUM;"DIE"+num$(AXE)
   If !fstat
    Wrseq ' When "CCE'+num$(AXE)+'"'
    If FLGCCE(AXE)=0
     Wrseq '  If ZONE="" : Call INISEC(ZONE,"'+[F:GAD]CCEDEF+'",'+[F:GAG]FORCLC+') From SUBCDE : Endif'
    Endif
   Endif
  Next AXE
 Endif
 Wrseq "Endcase"
 Wrseq "Return"
 Wrseq ""
 Wrseq "$ACC"+num$([F:GAD]LINNUM)
 If [F:GAD]NBRTYP>0
  Wrseq "Case val(EXPR)"
  For I=0 To [F:GAD]NBRTYP-1
   If [F:GAD]ACCKEY(I)<>""
    Wrseq ' When '+num$(I)+' : ';
    Wrseq ' ZONE = num$(';vireblc(format$("KT:255X",[F:GAD]ACCKEY(I)),2)+')'
   Endif
  Next I
  Wrseq "Endcase"
 Endif
 Wrseq "Return"
 Wrseq
 Wrseq "$CLE"+num$([F:GAD]LINNUM)
 If [F:GAD]LINTBL2<>""
  Read [ATI]NUMLIG(2) = [F:GAD]LINTBL2;1
  WCHAINE = [F:ATI]DESCRIPT
  K = 0
  While WCHAINE<>""
   I = instr(1,WCHAINE,"+")
   J = instr(1,WCHAINE,"-")
   If     I & J : I = min(I,J)
   Elsif J & !I : I = J
   Endif
   If I
    ZONE = left$(WCHAINE,I-1) : WCHAINE = right$(WCHAINE,I+1)
   Else
    ZONE = WCHAINE : WCHAINE = ""
   Endif
   K += 1
   Wrseq 'CLE2('+num$(K)+') = "'+ZONE+'"'
  Wend
  Wrseq "NBCLE2 = "+num$(K)
 Endif
 Wrseq "Return"
 Wrseq

 Wrseq "$LIENS"+num$([F:GAD]LINNUM)
 Local Char    LISCAC(100)(1..dim([F:GAD]TYPACCCOD))
 Local Integer NBRLISCAC
 NBRLISCAC = 0
 For I=0 To [F:GAD]NBRTYP-1
  If !find(format$("K:3X",num$([F:GAD]TYPACCCOD(I)))+vireblc(format$("KT:255X",[F:GAD]ACCKEY(I)),2),LISCAC(1..NBRLISCAC))
   [L]NBRLISCAC += 1
   [L]LISCAC(NBRLISCAC) = format$("K:3X",num$([F:GAD]TYPACCCOD(I)))+vireblc(format$("KT:255X",[F:GAD]ACCKEY(I)),2)
   CLECPT = vireblc(format$("KT:255X",[F:GAD]ACCKEY(I)),2)
   If CLECPT="" : CLECPT='""' : Endif
   If GPRODUIT=2 : # Produit Paye

#CHECK UNUSED_BEGIN
    Case [F:GAD]TYPACCCOD(I)
     When 1 : # Salarié
      Wrseq 'If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif'
      Wrseq 'Call LECTURE("EML",'+CLECPT+',"") From CONTOBJ'
     When 2 : # Service
      Wrseq 'If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif'
      Wrseq 'Call LECTURE("SRV",'+CLECPT+',"") From CONTOBJ'
     When 3 : # Profil
      Wrseq 'If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif'
      Wrseq 'Call LECTURE("PRF",GCURLEG,'+CLECPT+') From CONTOBJ'
     When 4 : # Société
      Wrseq 'If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif'
      Wrseq 'Call LECTURE("CPY",'+CLECPT+',"") From CONTOBJ'
     When 5 : # Site
      Wrseq 'If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif'
      Wrseq 'Call LECTURE("FCY",'+CLECPT+',"") From CONTOBJ'
     When 6 : # Devise
      Wrseq 'If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif'
      Wrseq 'Call LECTURE("TCU",'+CLECPT+',"") From CONTOBJ'
    Endcase
#CHECK UNUSED_END

   Elsif GPRODUIT=3 : #Produit ABELX3
#CHECK UNUSED_BEGIN

    Case [F:GAD]TYPACCCOD(I)
     When 1 : # Devise
      Wrseq 'If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif'
      Wrseq 'Call LECTURE("TCU",'+CLECPT+',"") From CONTOBJ'
     When 2 : # Site
      Wrseq 'If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif'
      Wrseq 'Call LECTURE("FCY",'+CLECPT+',"") From CONTOBJ'
     When 3 : # Société
      Wrseq 'If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif'
      Wrseq 'Call LECTURE("CPY",'+CLECPT+',"") From CONTOBJ'
     When 4 : # Utilisateur
      Wrseq 'If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif'
      Wrseq 'Call LECTURE("AUS",'+CLECPT+',"") From CONTOBJ'
     When 5 : # Immobilisation
    Endcase
#CHECK UNUSED_END

   Else
    Case [F:GAD]TYPACCCOD(I)
     When 1 : # Article
      Wrseq 'If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif'
      Wrseq 'Call LEC_ITM('+CLECPT+') From CPTLEC'
     When 2 : # Client
      Wrseq 'If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif'
       Wrseq 'Call LEC_BPC('+CLECPT+') From CPTLEC'
     When 3 : # Fournisseur
      Wrseq 'If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif'
      Wrseq 'Call LEC_BPS('+CLECPT+') From CPTLEC'
     When 4 : # Représentants
      Wrseq 'If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif'
      Wrseq 'Call LECTURE("REP",'+CLECPT+',"") From CONTOBJ'
     When 5 : # Acheteurs
      Wrseq 'If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif'
      Wrseq 'Call LECTURE("AUS",'+CLECPT+',"") From CONTOBJ'
     When 6 : # Pièces
     When 7 : # Société
      Wrseq 'If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif'
      Wrseq 'Call LEC_CPY('+CLECPT+') From CPTLEC'
     When 8 : # Site
      Wrseq 'If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif'
      Wrseq 'Call LEC_FCY('+CLECPT+') From CPTLEC'
     When 9 : # Devise
      Wrseq 'If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif'
      Wrseq 'Call LEC_TCU('+CLECPT+') From CPTLEC'
     When 10 : # Taxes
      Wrseq 'If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif'
      Wrseq 'Call LEC_TVT_LEG(GCURLEG,'+CLECPT+') From CPTLEC'
     When 11 : # Pieds de facture ventes
      Wrseq 'If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif'
      Wrseq 'Call LECTURE("SFI",num$('+CLECPT+'),"") From CONTOBJ'
     When 12 : # Escomptes
      Wrseq 'If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif'
      Wrseq 'Call LEC_TDA(GCURLEG,'+CLECPT+') From CPTLEC'
     When 13 : # Banque
      Wrseq 'If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif'
      Wrseq 'Call LEC_BAN('+CLECPT+') From CPTLEC'
     When 14 : # Règlement
      Wrseq 'If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif'
      Wrseq 'Call LEC_CDA_LEG(GCURLEG,'+CLECPT+') From CPTLEC'
     When 16 : # Pieds de facture achats
      Wrseq 'If clalev([F:PFI])=0 : Local File PFOOTINV [PFI] : Endif'
      Wrseq 'Call LECTURE("PFI",num$('+CLECPT+'),"") From CONTOBJ'
     When 17 : # Tiers divers
      Wrseq 'If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif'
      Wrseq 'Call LEC_BPR('+CLECPT+') From CPTLEC'
     When 18 : # Sections valorisations
      Wrseq 'If clalev([F:MWC])=0 : Local File WORKCOST [MWC] : Endif'
      Wrseq 'Call LECTURE("MWC",'+CLECPT+',"") From CONTOBJ'
    Endcase
   Endif
  Endif
 Next I
 For I=0 To [F:GAD]NBRTBL-1
  If [F:GAD]LINTBL1="PAYMENTD" & find([F:GAD]LIKTBL(I),"GACCDENCOD","TABCUR","TABVAT","COMPANY","BANK")
   Case [F:GAD]LIKTBL(I)
    When "GACCDENCOD"
     Wrseq "Call LEC_CDA_LEG(GCURLEG,[F:TB1]DENCOD) From CPTLEC"
    When "TABCUR"
     Wrseq "Call LEC_TCU([F:TB1]CURLIN) From CPTLEC"
    When "TABVAT"
     Wrseq "Call LEC_TVT_LEG(GCURLEG,[F:TB1]VATLIN) From CPTLEC"
    When "COMPANY"
     Wrseq "Call LEC_CPY([F:TB0]CPY) From CPTLEC"
    When "BANK"
     Wrseq "Call LEC_BAN([F:TB0]BAN) From CPTLEC"
   Endcase
  Else

   Read [ATB]CODFIC = [F:GAD]LIKTBL(I)
   CHAMP = [F:GAD]LIKFLD(I)
   J = instr(1,CHAMP,"(")
   If J
    DIME  = val(right$(CHAMP,J+1))
    CHAMP = left$(CHAMP,J-1)
   Else
    DIME  = 0
   Endif
   OK = 0
   If [F:GAD]LINTBL1<>""
    Read [ATZ]LIEN = [F:GAD]LIKTBL(I);[F:GAD]LINTBL1;CHAMP
    If !fstat : OK = 1 : TABL = "[F:TB1]" : Endif
   Endif
   If !OK & [F:GAD]LINTBL2<>""
    Read [ATZ]LIEN = [F:GAD]LIKTBL(I);[F:GAD]LINTBL2;CHAMP
    If !fstat : OK = 1 : TABL = "[F:TB2]" : Endif
   Endif
   If !OK
    Read [ATZ]LIEN = [F:GAD]LIKTBL(I);[F:GAU]TBL;CHAMP
    If !fstat
     OK = 1
     TABL = "[F:TB0]"
    Endif
   Endif
   If !OK
    For J=0 To I-1
     Read [ATZ]LIEN(2) = [F:GAD]LIKTBL(I);[F:GAD]LIKTBL(J)
     If !fstat
      Read [ATB]CODFIC = [F:GAD]LIKTBL(J)
      TABL = "[F:"+[F:ATB]ABRFIC+"]"
      Read [ATB]CODFIC = [F:GAD]LIKTBL(I)
      OK = 1 : Break
     Endif
    Next J
   Endif
   If OK
    Wrseq "If clalev([F:"+[F:ATB]ABRFIC+"])=0 : Local File "
&          +[F:ATB]CODFIC+" ["+[F:ATB]ABRFIC+"] : Endif"
    Read [ATI]NUMLIG(2) = [F:GAD]LIKTBL(I);1
    Wrseq "Read ["+[F:ATB]ABRFIC+"]"+[F:ATI]CODIND+" = ";
    If [F:ATZ]EXPLIEN=""
     If [F:GAD]LINTYP=2 & [F:ATZ]DIME>1 & [L]DIME=0
      Wrseq TABL+[F:ATZ]CODZONE+"(indice)";
     Else
      Wrseq TABL+CHAMP;
     Endif
    Else
     WCHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
     Repeat
      J = instr(1,WCHAINE,"indice")
      If J
       WCHAINE = left$(WCHAINE,J-1)+num$(DIME)+right$(WCHAINE,J+6)
      Endif
     Until J=0
     J = 0
     While WCHAINE<>""
      K = instr(1,WCHAINE,";")
      If K
       ZONE = left$(WCHAINE,K-1) : WCHAINE = right$(WCHAINE,K+1)
      Else
       ZONE = WCHAINE : WCHAINE = ""
      Endif
      J += 1
      If J>1 : Wrseq ";"; : Endif
      If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
       Wrseq TABL+ZONE;
      Else
       If instr(1,[F:ATZ]EXPLIEN,"[V]GSUPCLE") & instr(1,[F:ATI]DESCRIPT,"LEG")
        Wrseq "GCURLEG"
        WZONE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
        K = instr(1,WZONE,";")
        If K
         WZONE = left$(WZONE,K-1)
        Endif
        Wrseq "If fstat"
        Wrseq " Read ["+[F:ATB]ABRFIC+"]"+[F:ATI]CODIND+" = ";
        Wrseq  TABL+WZONE+';""'
        Wrseq "Endif"
       Else
        Wrseq  ZONE;
       Endif
      Endif
     Wend
    Endif
    Wrseq
   Endif
  Endif
 Next I
 Wrseq "Return"
 Wrseq
Next GAD
If OUVRE>1
 OUVRE = 99
 Gosub TRT_OUVRE
Endif
For ZONE="CLE","LIENS","EVAL","ACC","AP_LIENS","AV_CREAT","AP_CREAT"
 Wrseq "$"+ZONE+"_X"
 Wrseq "Case [F:GAD]LINNUM"
 [L]NBRLIG = 0
 For [GAD]GAD0 Where COD=[F:GAU]COD
  [L]NBRLIG += 1
  If find(ZONE,"AP_LIENS") & [F:GAD]ACTAFTLIK<>""
   Wrseq " When"-num$([F:GAD]LINNUM)+" : Gosub"-[F:GAD]ACTAFTLIK-"From"-[F:GAD]PRGAFTLIK
  Elsif find(ZONE,"AV_CREAT") & [F:GAD]ACTBEFLIN<>""
   Wrseq " When"-num$([F:GAD]LINNUM)+" : Gosub"-[F:GAD]ACTBEFLIN-"From"-[F:GAD]PRGBEFLIN
  Elsif find(ZONE,"AP_CREAT") & [F:GAD]ACTAFTLIN<>""
   Wrseq " When"-num$([F:GAD]LINNUM)+" : Gosub"-[F:GAD]ACTAFTLIN-"From"-[F:GAD]PRGAFTLIN
  Elsif !find(ZONE,"AP_LIENS","AP_CREAT","AV_CREAT")
   Wrseq " When"-num$([F:GAD]LINNUM)+" : Gosub "+ZONE+num$([F:GAD]LINNUM);
   If [L]NBRLIG>[L]MAXLIG
    Wrseq " From "+NOMSUP+chr$(64+int(([L]NBRLIG-1)/[L]MAXLIG))
   Else
    Wrseq
   Endif
  Endif
 Next
 Wrseq "Endcase"
 Wrseq "Return"
 Wrseq
Next ZONE
Return

$ANALYSE_FORMULE
FORMULE = vireblc(format$("KT:255X",[F:GAG]FORCLC),2)
Call CHARGE_VARIABLE(FORMULE,TVARIA,NBVAR,MESSA,STAT) From TRTVARPAR
If STAT : Return : Endif
For VARIA = 1 To NBVAR
 Gosub LIRE_PARAM
 # Appel au sous-programme évaluant chaque variable de l'expression
 Wrseq "  Local Integer STAT"
 If !find(TVARIA(VARIA),TVARIA(1..VARIA-1)) : # Possible si une variable est référencée 2 fois...
  Wrseq "  Local"-TYPVARIA-CODVARIA+DIMVAR
  Wrseq "  Call"-SUB_PROG+"("+CHAINE_PARAM+") From"-TRAITEMENT
 Endif
 IND = instr(1,FORMULE,"V_"+TVARIA(VARIA))
 FORMULE = left$(FORMULE,IND-1)+"[L]"+CODVARIA+right$(FORMULE,IND+len("V_"+TVARIA(VARIA)))
Next VARIA
Wrseq '  ZONE = ';FORMULE
Return

$LIRE_PARAM
Read [GVG]GVG0 = TVARIA(VARIA)
If !fstat
 TRAITEMENT = [F:GVG]CODTRT
 SUB_PROG   = [F:GVG]SUBPRG
 Raz CHAINE_PARAM
 For [GVP]GVP0 Where CODVAR=TVARIA(VARIA)
  # NB : chaque variable contient un et un seul paramètre passé par adresse
  If [F:GVP]ADRVAL = 1 : # par adresse ==> résultat de la variable
   CHAINE_PARAM    += "[L]"+[F:GVP]CODPAR+","
   Case [F:GVP]TYPPAR
    When 1
     TYPVARIA = "Char"
    When 2
     TYPVARIA = "Integer"
    When 3
     TYPVARIA = "Decimal"
    When 4
     TYPVARIA = "Date"
    When 5
     TYPVARIA = "Libelle"
   Endcase
   CODVARIA         = [F:GVP]CODPAR
   If [F:GVP]TYPPAR = 1 : # Char
    DIMVAR = "(30)" : # PP : Pas génial en dur...
   Else
    DIMVAR = ""
   Endif
  Else                 : # Par valeur
   Read [GVV]GVV0 = [F:GAU]COD;[F:GAD]LINNUM;[F:GAG]FLD;TVARIA(VARIA);[F:GVP]CODPAR
   If !fstat
    CHAINE_PARAM += [F:GVV]VALPAR+","
   Endif
  Endif
 Next GVP
 CHAINE_PARAM += "STAT,"
Endif
If CHAINE_PARAM<>""
 CHAINE_PARAM = left$(CHAINE_PARAM,len(CHAINE_PARAM)-1)
Endif
Return

Subprog SUBST2(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
Local Integer K
Repeat
 K = instr(1,CHAINE,AB1)
 If K
  CHAINE = left$(CHAINE,K-1)+AB2+right$(CHAINE,K-1+len(AB1)+1)
 Endif
Until K=0
End


###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File GAUTACE    [GAUO]
 Local File GAUTACED   [GADO]
 Local File GAUTACEF   [GAGO]
 Local File GVARPARVAL [GVVO]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GAUTACE"    [GAUO]
 Local File =[M]DOSORG+".GAUTACED"   [GADO]
 Local File =[M]DOSORG+".GAUTACEF"   [GAGO]
 Local File =[M]DOSORG+".GVARPARVAL" [GVVO]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GAUTACE    [GAUD]
 Local File GAUTACED   [GADD]
 Local File GAUTACEF   [GAGD]
 Local File GVARPARVAL [GVVD]
 Local File ATEXTRA  [AXX2]
 Local File ATABDIV  [ADID]
Else
 Local File =[M]DOSDES+".GAUTACE"    [GAUD]
 Local File =[M]DOSDES+".GAUTACED"   [GADD]
 Local File =[M]DOSDES+".GAUTACEF"   [GAGD]
 Local File =[M]DOSDES+".GVARPARVAL" [GVVD]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
 Local File =[M]DOSDES+".ATABDIV"  [ADID]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GAUO], [GADO], [GAGO], [GVVO], [GAUD], [GADD], [GAGD], [GVVD]
Close Local File [AXX1], [AXX2],[ADID]
If clalev([F:ADSO])>0 : Close Local File [ADSO] : Endif
If clalev([F:ADSD])>0 : Close Local File [ADSD] : Endif
Return

$TR_COP
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)
GOK = 1
Trbegin [GAUD] , [GADD] , [GAGD] , [GVVD]
 Delete [GAGD] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GAUTACEF" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GAG2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [GVVD] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GVARPARVAL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GAG2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GADD] Where COD=TABLE
  Read [GADO]GAD0 = [F:GADD]COD;[F:GADD]LINNUM
  If fstat
   Delete [GADD]
   If fstat=1
    GOK = -1 : GLOCK = "$"+[M]DOSDES+".GAUTACED" : Break
   Endif
  Endif
 Next
 If GOK<0 : Goto ROLL_TR_COP : Endif
 For [GADO] Where COD=TABLE
  Read [GADD]GAD0 = [F:GADO]COD;[F:GADO]LINNUM
  If fstat
   [F:GADD] = [F:GADO]
   #--------------------
   For I=0 To dim([F:GADD]ACTLEG)-1
    [F:GADD]ACTLEG(I)=""
   Next
   [F:GADD]NBRLEG=0
   Filter [ADID] Where NUMTAB=909
   For [ADID]CODE
    If find([F:ADID]CODE,[F:GADO]ACTLEG(0..[F:GADO]NBRLEG-1))
     [F:GADD]ACTLEG([F:GADD]NBRLEG)=[F:ADID]CODE
     [F:GADD]NBRLEG+=1
    Endif
   Next
   Filter [ADID]
   #----------------------
   Call COPTEXTRA("GAUTACED","DESTRA",TABLE,num$([F:GADO]LINNUM)) From ATEXTRA
   Call COPTEXTRA("GAUTACED","SHOTRA",TABLE,num$([F:GADO]LINNUM)) From ATEXTRA
   Write [GADD]
  Else
   DESIG1 = [F:GADD]DES
   [F:GADD] = [F:GADO]
   #--------------------
   For I=0 To dim([F:GADD]ACTLEG)-1
    [F:GADD]ACTLEG(I)=""
   Next
   [F:GADD]NBRLEG=0
   Filter [ADID] Where NUMTAB=909
   For [ADID]CODE
    If find([F:ADID]CODE,[F:GADO]ACTLEG(0..[F:GADO]NBRLEG-1))
     [F:GADD]ACTLEG([F:GADD]NBRLEG)=[F:ADID]CODE
     [F:GADD]NBRLEG+=1
    Endif
   Next
   Filter [ADID]
   #----------------------
   [F:GADD]DES = DESIG1
   Call COPTEXTRA("GAUTACED","DESTRA",TABLE,num$([F:GADO]LINNUM)) From ATEXTRA
   Call COPTEXTRA("GAUTACED","SHOTRA",TABLE,num$([F:GADO]LINNUM)) From ATEXTRA
   Rewrite [GADD]
  Endif
  If fstat
   GOK = 0 : Call FSTA("GAD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [GAGO] Where COD=TABLE
  [F:GAGD] = [F:GAGO]
  Write [GAGD]
  If fstat
   GOK = 0 : Call FSTA("GAG2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [GVVO] Where COD=TABLE
  [F:GVVD] = [F:GVVO]
  Write [GVVD]
  If fstat
   GOK = 0 : Call FSTA("GVV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Read [GAUO]GAU0 = TABLE
 Read [GAUD]GAU0 = TABLE
 If fstat
  [F:GAUD] = [F:GAUO]
  #--------------------
   For I=0 To dim([F:GAUD]ACTLEG)-1
    [F:GAUD]ACTLEG(I)=""
   Next
   [F:GAUD]NBRLEG=0
   Filter [ADID] Where NUMTAB=909
   For [ADID]CODE
    If find([F:ADID]CODE,[F:GAUO]ACTLEG(0..[F:GAUO]NBRLEG-1))
     [F:GAUD]ACTLEG([F:GAUD]NBRLEG)=[F:ADID]CODE
     [F:GAUD]NBRLEG+=1
    Endif
   Next
   Filter [ADID]
   #----------------------
  Call COPTEXTRA("GAUTACE","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("GAUTACE","SHOTRA",TABLE,"") From ATEXTRA
  If dim([F:GAUD]CREUSR)>0 : [F:GAUD]CREUSR = GUSER   : Endif
  If dim([F:GAUD]CREDAT)>0 : [F:GAUD]CREDAT = date$   : Endif
  If dim([F:GAUD]UPDUSR)>0 : [F:GAUD]UPDUSR = ""      : Endif
  If dim([F:GAUD]UPDDAT)>0 : [F:GAUD]UPDDAT = [0/0/0] : Endif
  Write [GAUD]
 Else
  DESIG1 = [F:GAUD]DES
  DESIG2 = [F:GAUD]DESSHO
  [F:GAUD] = [F:GAUO]
  #--------------------
   For I=0 To dim([F:GAUD]ACTLEG)-1
    [F:GAUD]ACTLEG(I)=""
   Next
   [F:GAUD]NBRLEG=0
   Filter [ADID] Where NUMTAB=909
   For [ADID]CODE
    If find([F:ADID]CODE,[F:GAUO]ACTLEG(0..[F:GAUO]NBRLEG-1))
     [F:GAUD]ACTLEG([F:GAUD]NBRLEG)=[F:ADID]CODE
     [F:GAUD]NBRLEG+=1
    Endif
   Next
   Filter [ADID]
   #----------------------
  Call COPTEXTRA("GAUTACE","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("GAUTACE","SHOTRA",TABLE,"") From ATEXTRA
  If dim([F:GAUD]UPDUSR)>0 : [F:GAUD]UPDUSR = GUSER   : Endif
  If dim([F:GAUD]UPDDAT)>0 : [F:GAUD]UPDDAT = date$   : Endif
  [F:GAUD]DES    = DESIG1
  [F:GAUD]DESSHO = DESIG2
  Rewrite [GAUD]
 Endif
 If fstat
  GOK = 0 : Call FSTA("GAU2") From GLOCK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


#############################################
## Vérification (sommaire) des formules
#############################################
$VERIF
Local Char    WCHAINE(255) , TABLE(10) , ABR(GLONABR)(1..50)
Local Char    CONSTANTE(80) , SVG_CONSTANTE(80) , OBJET(5) , ZONE(GLONAVA)
Local Integer K1 , K2 , K3 , K4 , NBABR , TYP1 , TYP2
Local Decimal MINI , MAXI
Local Integer NBTAB
Local Char    TAB(GLONATB)(1..999)
Raz NBTAB, TAB
Read [ATB]CODFIC = [F:GAU]TBL
NBABR = 1 : ABR(NBABR) = [F:ATB]ABRFIC
Read [ATB]CODFIC = [F:GAU]REITBL
NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
For K1=0 To [F:GAU]NBRTBL-1
 Read [ATB]CODFIC = [F:GAU]LIKTBL(K1)
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Next K1
For K1=0 To dim([M:GAU1]FORCND)-1
 WCHAINE = [M:GAU1]FORCND(K1)
 CHAMP  = ""
 If WCHAINE<>""
  Gosub VERF_FORMULE
 Endif
Next
WCHAINE = [M:GAU1]FORCND2
CHAMP  = ""
If WCHAINE<>""
 Gosub VERF_FORMULE
Endif
For K=0 To [M:GAU1]NBLIG-1
 WCHAINE = [M:GAU1]FORCLC(K)
 CHAMP  = [M:GAU1]FLD(K)
 If WCHAINE<>""
  Gosub VERF_FORMULE
 Endif
Next K
Return


$VERF_FORMULE
K1 = 0
Repeat
 K2 = instr(K1+1,WCHAINE,"[")
 If K2
  K3 = instr(K2+1,WCHAINE,"]")
  If K3
   TABLE = seg$(WCHAINE,K2+1,K3-1)
   TABLE = toupper(TABLE)
   If instr(1,TABLE,"/")=0 & left$(TABLE,2)<>"M:": # Sinon ça peut être une date, une zone écran
    If left$(TABLE,2)="F:" : TABLE = right$(TABLE,3) : Endif
    If pat(TABLE,"!*") & !find(TABLE,ABR(1..NBABR))
&      & !(TABLE="DUD" &
&          (find("PINVOICE",[F:GAU]TBL,[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1)) |
&           find("SINVOICE",[F:GAU]TBL,[F:GAU]LIKTBL(0..[F:GAU]NBRTBL-1))))
      If (dim(GZWARNGAUT)<0 | GZWARNGAUT<>1)
       If !find(TABLE,TAB(1..NBTAB)) & TABLE<>"GAU"
        NBTAB += 1
        TAB(NBTAB) = TABLE
        If GTRACE<>""
         Call ECR_TRACE(CHAMP-":"-TABLE-mess(17,123,1),0) From GESECRAN
        Else
         Call MESSAGE(CHAMP-":"-TABLE-mess(17,123,1)) From GESECRAN
        Endif
       Endif
      Endif
    Endif
   Endif
  Endif
 Endif
 K1 = K2+1
Until K2=0
# Serait-ce une constante alpha ?
If left$(WCHAINE,1)="'" or left$(WCHAINE,1)='"'
 L = len(WCHAINE)
 If right$(WCHAINE,L)=left$(WCHAINE,1) & !instr(1,seg$(WCHAINE,2,L-1),left$(WCHAINE,1))
  Case CHAMP
   When "CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9","CCE10","CCE11","CCE12","CCE13"
&      ,"CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
   SVG_CONSTANTE = CONSTANTE
  Endcase
  CONSTANTE = seg$(WCHAINE,2,L-1)
  Gosub TYP
  If TYP2<>2
   If GTRACE<>""
    Call ECR_TRACE(CHAMP-":"-CONSTANTE-mess(37,124,1),0) From GESECRAN
   Else
    Call MESSAGE(CHAMP-":"-CONSTANTE-mess(37,124,1)) From GESECRAN
   Endif
  Endif
  mkstat = 0
  OBJET = ""
  Case CHAMP

   When "JOU" : If clalev([F:JOU])
                 OBJET = "JOU" : GMESSAGE = mess(13,105,1) : Read [JOU]JOU0(1) = CONSTANTE
                Endif
#JASMI - 2017-04-10 - Req. 122336 - START
#   When "GTE" : OBJET = "GTE" : GMESSAGE = mess(10,105,1) : Read [GTE]GTE0(1) = CONSTANTE
   When "GTE" : If clalev([F:GTE])
                 OBJET = "GTE" : GMESSAGE = mess(10,105,1) : Read [GTE]GTE0(1) = CONSTANTE
                Endif
#JASMI - 2017-04-10 - Req. 122336 - END

   When "FCY" : OBJET = "FCY" : GMESSAGE = mess(12,105,1) : Read [FCY]FCY0 = CONSTANTE
   When "CUR" : OBJET = "TCU" : GMESSAGE = mess(18,105,1) : Read [TCU]TCU0 = CONSTANTE
   When "COR" : OBJET = "TCU" : GMESSAGE = mess(18,105,1) : Read [TCU]TCU0 = CONSTANTE
   When "BPR" : OBJET = "BPR" : GMESSAGE = mess(31,105,1) : Read [BPR]BPR0 = CONSTANTE
   When "UNT" : OBJET = "TUN" : GMESSAGE = mess(34,105,1) : Read [TUN]TUN0 = CONSTANTE
   When "DSP" : OBJET = "DSP" : GMESSAGE = mess(38,105,1) : Read [DSP]DSP0 = CONSTANTE;1
   When "TAX" : OBJET = "TVT" : GMESSAGE = mess(39,105,1) : Read [TVT]TVT0(1) = CONSTANTE
   When "DIE1","DIE2","DIE3","DIE4","DIE5","DIE6","DIE7","DIE8","DIE9","DIE10","DIE11","DIE12","DIE13"
&      ,"DIE14","DIE15","DIE16","DIE17","DIE18","DIE19","DIE20"
    OBJET = "DIE" : Read [DIE]DIE0 =  CONSTANTE

   When "CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9","CCE10","CCE11","CCE12","CCE13"
&      ,"CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
    OBJET = "CCE" : GMESSAGE = mess(48,105,1) : Read [CCE]CCE0 =  SVG_CONSTANTE;CONSTANTE
   When "DIA" :
    If clalev([F:GDE]) : OBJET = "GDE" : GMESSAGE = mess(102,105,1) : Read [GDE]DIA = CONSTANTE : Endif
  Endcase
  If OBJET<>""
   If fstat
    GMESSAGE = CHAMP-GMESSAGE+"\"+CONSTANTE-mess(23,100,1)
    If GTRACE<>""
     Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Else
     Call MESSAGE(GMESSAGE) From GESECRAN
    Endif
   Endif
  Endif
  GMESSAGE  = ""
 Endif
Endif

# Une constante numérique ?

If num$(val(WCHAINE))=WCHAINE
 Gosub TYP
 If TYP2<>1
  If GTRACE<>""
   Call ECR_TRACE(CHAMP-":"-WCHAINE-mess(37,124,1),1) From GESECRAN
  Else
   Call MESSAGE(CHAMP-":"-WCHAINE-mess(37,124,1)) From GESECRAN
  Endif
 Endif
 Case CHAMP
  When "CAT" : MINI = 1 : MAXI = len(mess(0,618,1))
  When "STA" : MINI = 1 : MAXI = 2
  When "DAS" : MINI = 1 : MAXI = 2
  When "TCR" : MINI = 1 : MAXI = len(mess(0,202,1))
  When "PAZ" : MINI = 1 : MAXI = len(mess(0,510,1))
  When "FUP" : MINI = 1 : MAXI = 2
  When "SNS" : MINI = -1 : MAXI = +1
  When Default : MAXI = 0
 Endcase
 If MAXI>0 & (val(WCHAINE)<MINI or val(WCHAINE)>MAXI)
  If GTRACE<>""
   Call ECR_TRACE(CHAMP-":"-mess(83,123,1)-WCHAINE,0) From GESECRAN
  Else
   Call MESSAGE(CHAMP-":"-mess(83,123,1)-WCHAINE) From GESECRAN
  Endif
 Endif
Endif
# Un champ tout bête
If left$(WCHAINE,3)="[F:" | left$(WCHAINE,4)="-[F:"
 If left$(WCHAINE,1)="-" : # Champ (numérique) précédé d'un (-)
  WCHAINE = right$(WCHAINE,2)
 Endif
 K1 = instr(1,WCHAINE,"]")
 If K1
  TABLE = toupper(seg$(WCHAINE,4,K1-1))
  ZONE  = right$(WCHAINE,K1+1)
  K4 = instr(1,ZONE,"(") : # Champ dimensionné
  If K4
   ZONE = left$(ZONE,K4-1)
  Endif
  If vireblc(format$("K:"+num$(GLONAVA)+"B",ZONE),2)=ZONE
   Read [ATB]ABRFIC = TABLE
   Read [ATZ]CODZONE = [F:ATB]CODFIC;ZONE
   If fstat
    If GTRACE<>""
     If CHAMP<>""
      Call ECR_TRACE(CHAMP-":"-WCHAINE-mess(41,100,1),0) From GESECRAN
     Else
      Call ECR_TRACE(WCHAINE-mess(41,100,1),0) From GESECRAN
     Endif
    Else
     If CHAMP<>""
      Call MESSAGE(CHAMP-":"-WCHAINE-mess(41,100,1)) From GESECRAN
     Else
      Call MESSAGE(WCHAINE-mess(41,100,1)) From GESECRAN
     Endif
    Endif
   Elsif CHAMP<>""
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    Case [F:ATY]TYPTYP
     When 1,2,3,4,5,6 : TYP1 = 1
     When 7           : TYP1 = 2
     When 8           : TYP1 = 3
    Endcase
    Gosub TYP
    If TYP1<>TYP2 & !(CHAMP>"X")
     If GTRACE<>""
      Call ECR_TRACE(CHAMP-":"-WCHAINE-mess(37,124,1),0) From GESECRAN
     Else
      Call MESSAGE(CHAMP-":"-WCHAINE-mess(37,124,1)) From GESECRAN
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
Return

$TYP
Case CHAMP
 When "CAT","STA","RAT","RPT","TCR","DAS","PAZ","FUP","STR","END","AMT","AMTL1", "AMTL2"
&    ,"AMTL3","AMTL4","AMTL5","AMTL6","AMTL7","AMTL8","AMTL9","AMTL10"
&    ,"QTY","SNS","AMTA","QTYA","MLT1","MLT2","MLT3","MLT4","MLT5","MLT6","MLT7","MLT8","MLT9","MLT10"
&    ,"DIV1","DIV2","DIV3","DIV4","DIV5","DIV6","DIV7","DIV8","DIV9","DIV10"
  TYP2 = 1
 When "GTE","NUM","FCY","JOU","VCR","REF","CIB","BVC","SIM","CUR","COR","ACC1",
&     "ACC2","ACC3","ACC4","ACC5","ACC6","ACC7","ACC8","ACC9","BPR"
&    ,"UNT","DSP","TAX","CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9"
&    ,"CCE10","CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
&    ,"DIE1","DIE2","DIE3","DIE4","DIE5","DIE6","DIE7","DIE8","DIE9"
&    ,"DIE10","DIE11","DIE12","DIE13","DIE14","DIE15","DIE16","DIE17","DIE18","DIE19","DIE20"
&    ,"ST1","ST2","ST3","OFF","DES","DIA"
  TYP2 = 2
 When "DAT","ENT","DUD","BAN","VAL","RVS","BVD"
  TYP2 = 3
 When Default
  TYP2 = 2
Endcase
Return


$VERIF_AUTO
TYPECR  = [F:GAU]TYP
Local Integer NBTAB
Local Char    TAB(GLONATB)(1..999)
Raz NBTAB, TAB
# Verif "En-tête"
Read [ATB]CODFIC = [F:GAU]TBL
NBABR = 1 : ABR(NBABR) = [F:ATB]ABRFIC
Read [ATB]CODFIC = [F:GAU]REITBL
NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
For K1=0 To [F:GAU]NBRTBL-1
 Read [ATB]CODFIC = [F:GAU]LIKTBL(K1)
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Next K1
For K1=0 To dim([F:GAU]FORCND)-1
 WCHAINE = [F:GAU]FORCND(K1)
 If WCHAINE<>""
  Call SUBST(WCHAINE,"TB0",ABR(1))
  Call SUBST(WCHAINE,"TB4",ABR(2))
  CHAMP  = ""
  Gosub VERF_FORMULE
 Endif
Next K
WCHAINE = [F:GAU]FORCND2
If WCHAINE<>""
 Call SUBST(WCHAINE,"TB0",ABR(1))
 Call SUBST(WCHAINE,"TB4",ABR(2))
 CHAMP  = ""
 Gosub VERF_FORMULE
Endif
For [F:GAG] Where COD=[F:GAU]COD & LINNUM=0
 WCHAINE = [F:GAG]FORCLC

 If WCHAINE<>""
  Call SUBST(WCHAINE,"TB0",ABR(1))
  Call SUBST(WCHAINE,"TB4",ABR(2))
  CHAMP  = [F:GAG]FLD
  Gosub VERF_FORMULE
 Endif
Next

# Verif "Ligne"
For [GAD] Where COD=[F:GAU]COD
 Read [ATB]CODFIC = [F:GAU]TBL
 NBABR = 1 : ABR(NBABR) = [F:ATB]ABRFIC
 For K1=0 To [F:GAU]NBRTBL-1
  Read [ATB]CODFIC = [F:GAU]LIKTBL(K1)
  NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
 Next K1
 If [F:GAD]LINTBL1<>""
  Read [ATB]CODFIC = [F:GAD]LINTBL1
  NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC : ABRL1=[F:ATB]ABRFIC
 Endif
 If [F:GAD]LINTBL2<>""
  Read [ATB]CODFIC = [F:GAD]LINTBL2
  NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC : ABRL2=[F:ATB]ABRFIC
 Endif
 For K1=0 To [F:GAD]NBRTBL-1
  Read [ATB]CODFIC = [F:GAD]LIKTBL(K1)
  NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
 Next K1

 For K=0 To dim([F:GAD]FORCND)-1
  WCHAINE = [F:GAD]FORCND(K)
  CHAMP  = ""
  If WCHAINE<>""
   Call SUBST(WCHAINE,"TB0",ABR(1))
   If [F:GAD]LINTBL1<>"" : Call SUBST(WCHAINE,"TB1",ABRL1) : Endif
   If [F:GAD]LINTBL2<>"" : Call SUBST(WCHAINE,"TB2",ABRL2) : Endif
   Gosub VERF_FORMULE From SUBGAU
  Endif
 Next K

 For [GAG] Where COD=[F:GAU]COD & LINNUM=[F:GAD]LINNUM
  WCHAINE = [F:GAG]FORCLC
  CHAMP   = [F:GAG]FLD
  If WCHAINE<>""
   If CHAMP = "LIB" : WCHAINE = "'"+WCHAINE+"'" : Endif
   Call SUBST(WCHAINE,"TB0",ABR(1))
   If [F:GAD]LINTBL1<>"" : Call SUBST(WCHAINE,"TB1",ABRL1) : Endif
   If [F:GAD]LINTBL2<>"" : Call SUBST(WCHAINE,"TB2",ABRL2) : Endif
   Gosub VERF_FORMULE From SUBGAU
  Endif
 Next
Next
Return


############################################################
Subprog DUP_PARVAR(ORG,DES)
Value Char    ORG
Value Char    DES
If clalev([F:GVV])=0
 Local File GVARPARVAL [GVV]
Endif
If clalev([F:GVV2])=0
 Local File GVARPARVAL [GVV2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_DUPLI
End

$TR_DUPLI
GOK = 1
Trbegin [GVV]
 Gosub DUPLIPAR
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback : Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_DUPLI : Endif
 Endif
Commit
Return

$DUPLIPAR
Delete [GVV] Where COD = DES
If fstat=1
 GOK=-1 : GLOCK = "$GVARPARVAL"-DES : Return
Endif
For [GVV2]GVV0 Where COD = ORG
 [F:GVV]    = [F:GVV2]
 [F:GVV]COD = DES
 Write [GVV]
 If fstat
  GOK = 0 : Call FSTA("GVV") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return


############################################################
Subprog DEL_PARVAR(DES)
Value Char    DES
If clalev([F:GVV])=0
 Local File GVARPARVAL [GVV]
Endif
Call DEBTRANS From GLOCK
Gosub TR_DELPARVAR
End

$TR_DELPARVAR
GOK = 1
Trbegin [GVV]
 Gosub DELPARVAR
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback : Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_DELPARVAR : Endif
 Endif
Commit
Return

$DELPARVAR
Delete [GVV] Where COD = DES
If fstat=1
 GOK=-1 : GLOCK = "$GVARPARVAL"-DES : Return
Endif
If GOK<1 : Return : Endif
Return


##################################################
## Etiquettes masques  - Ecran GAU1             ##
##################################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
If clalev([F:GAU2])=0 : Local File GAUTACE    [GAU2] : Endif  : # Pièces auto
If [M]COD<>"" & [M]COD<>VALEUR
 Read [GAU2]GAU0 = [M]COD
 If fstat
  # Dem 58349 : Le code pièce auto saisi précédemment n'existe pas. On est dans le cas où on a voulu créé un code mais avant d'activer
  # la création, on a changé la codification : il faut remettre d'aplomb les variables de pièces autos
  Read [GAU2]GAU0 = VALEUR
  If fstat
   Call DUP_PARVAR([M]COD,VALEUR)
  Endif
  ## Dem 58127
  Call DEL_PARVAR([M]COD)
 Else
  # Cas simple de la duplication... [M]COD existe et VALEUR n'existe pas.
  Read [GAU2]GAU0 = VALEUR
  If fstat
   Call DUP_PARVAR([M]COD,VALEUR)
  Endif
 Endif
Endif
End

Subprog D_TBL(VALEUR)
Variable Char     VALEUR
End

Subprog AM_TBL(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATB",VALEUR,"") From CONTOBJ
[M]ABREV = [F:ATB]ABRFIC
End

Subprog AV_TBLDES(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATB",[M]TBL,"") From CONTOBJ
If fstat : VALEUR=""
Else Call TEXTE([F:ATB]INTITFIC,VALEUR) From OBJDIV
Endif
End

Subprog AS_REITBL(VALEUR)
Variable Char    VALEUR()
If clalev([F:GRA])=0
 Local File GRPAUTACE [GRA]  : # Groupes pièces auto
Endif
End

Subprog AP_REITBL(VALEUR)
Variable Char    VALEUR()
If clalev([F:ATB])=0
 Local File ATABLE [ATB]
Endif
Read [ATB]CODFIC = VALEUR
If !fstat
 [M]REIABREV = [F:ATB]ABRFIC
Endif
If VALEUR<>""
 Actzo [M:GAU1]REIFLD
Else
 Effzo [M:GAU1]REIFLD
 Grizo [M:GAU1]REIFLD
Endif
End

Subprog AS_REIFLD(VALEUR)
Variable Char    VALEUR()
If [M]REITBL="" : mkstat=1 : End : Endif
End

Subprog C_REIFLD(VALEUR)
Variable Char    VALEUR()
Look [ATZ]CODZONE = [M]REITBL ; VALEUR
If fstat
 GMESSAGE = mess(41,100,1) : mkstat = 2 : End
Endif
End

Subprog C_KEYTBL(VALEUR)
Variable Char VALEUR()
Local Integer OK
If VALEUR="" : End : Endif
OK=0
For [ATI] Where CODFIC=[M]TBL
 If VALEUR=[F:ATI]CODIND
  OK=1 : Break
 Endif
Next
If !OK
 GMESSAGE = VALEUR-":"-mess(6,114,1)
 mkstat = 2
Endif
End

Subprog C_LIKTBL(VALEUR)
Variable Char    VALEUR()
Local Integer J
Call UNICITE(VALEUR,[M]LIKTBL(0..[M]NBRTBL-1)) From OBJDIV
If mkstat : End : Endif
Read [ATZ]LIEN(2) = VALEUR;[M]TBL
If fstat
 For J=0 To indice-1
  Read [ATZ]LIEN(2) = VALEUR;[M]LIKTBL(J)
  If !fstat : Break : Endif
 Next J
 If fstat
  GMESSAGE = mess(45,105,1) : mkstat = 2 : End
 Endif
Endif
If [M]LIKFLD(nolign-1)=""
 [M]LIKFLD(nolign-1) = [F:ATZ]CODZONE
Endif
End

Subprog C_LIKFLD(VALEUR)
Variable Char    VALEUR()
Local Char    CHAMP(20)
Local Integer DIME , DIMAX , I , J
VALEUR = toupper(VALEUR)
CHAMP = VALEUR
I = instr(1,CHAMP,"(")
If I
 DIME  = val(right$(CHAMP,I+1))
 CHAMP = left$(CHAMP,I-1)
Else
 DIME = 0
Endif
If [F:GAU]GRPFLG<>3 | right$(VALEUR,I+1) <> "INDICE)"
 If DIME=0
  VALEUR = CHAMP
 Else
  VALEUR = CHAMP+"("+num$(DIME)+")"
 Endif
Endif
Read [ATZ]LIEN = [M]LIKTBL(nolign-1);[M]TBL;CHAMP
If fstat & [F:GAU]REITBL <> ""
 Read [ATZ]LIEN = [M]LIKTBL(nolign-1);[M]REITBL;CHAMP
Endif
If fstat
 For J=0 To indice-1
  Read [ATZ]LIEN = [M]LIKTBL(nolign-1);[M]LIKTBL(J);CHAMP
  If !fstat : Break : Endif
 Next J
 If fstat
  GMESSAGE = mess(45,105,1) : mkstat = 2 : End
 Endif
Endif
DIMAX = [F:ATZ]DIME
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Endif
If DIME>DIMAX-1
 GMESSAGE = mess(46,105,1)
 mkstat = 2 : End
Endif
End

Subprog AS_TYPVCR(VALEUR)
Variable Integer    VALEUR()
If [M]TBL<>"PAYMENTH" : mkstat=1 : End : Endif
If clalev([F:GRA])=0
 Local File GRPAUTACE [GRA]  : # Groupes pièces auto
Endif
End

Subprog C_TYPVCR(VALEUR)
Variable Integer    VALEUR()
If [M]TBL<>"PAYMENTH"
 If clalev([F:GRA])=0
  Local File GRPAUTACE [GRA]  : # Groupes pièces auto
 Endif
 Filter [GRA] Where find([M:GAU0]COD,[F:GRA]CODACE(0..dim([F:GRA]CODACE)-1))
 Read [GRA]GRA0 First
 Filter [GRA]
 If !fstat
  GMESSAGE = mess(10,123,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog B1_NBLEG
#Sélectionner tout / Enable All
For I=0 To [M:GAU1]NBLEG-1
 [M:GAU1]ACT(I) = 2
Next
Affzo [M:GAU1]1-99
mkstat=4
End

Subprog B2_NBLEG
#Désélectionner tout / Disable All
For I=0 To [M:GAU1]NBLEG-1
 [M:GAU1]ACT(I) = 1
Next
Affzo [M:GAU1]1-99
mkstat=4
End

Subprog B3_NBLEG
#Inverser sélection / Reverse selection
#Sélectionner tout/ Active All
For I=0 To [M:GAU1]NBLEG-1
 Case [M:GAU1]ACT(I)
  When 1 : [M:GAU1]ACT(I) = 2
  When 2 : [M:GAU1]ACT(I) = 1
 Endcase
Next
Affzo [M:GAU1]1-99
mkstat=4
End

##################################################
## Etiquettes masques  - Ecran GAU2             ##
##################################################

Subprog C_TRCFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & ([M:GAU1]GRPFLG=2 or [M:GAU1]TBL="PAYMENTH")
 Actzo [M:GAU2]TRCTBL, TRCKEY
 Actzo [M:GAU2]10
 Actzo [M:GAU2]20
 If [M:GAU2]TRCTBL=""
  [M:GAU2]TRCTBL = [M:GAU1]TBL
  Read [ATI]NUMLIG(2) = [M:GAU2]TRCTBL;1
  [M:GAU2]TRCKEY = [F:ATI]CODIND
 Endif
Else
 Effzo [M:GAU2]TRCTBL, TRCKEY
 Effzo [M:GAU2]10
 Effzo [M:GAU2]20
 Grizo [M:GAU2]TRCTBL, TRCKEY
 Grizo [M:GAU2]10
 Grizo [M:GAU2]20
Endif
End

Subprog C_TRCTBL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Actzo [M:GAU2]TRCKEY
Else
 Effzo [M:GAU2]TRCKEY
 Grizo [M:GAU2]TRCKEY
Endif
End

Subprog AM_TRCTBL(VALEUR)
Variable Char    VALEUR()
Read [ATI]NUMLIG(2) = VALEUR;1
[M:GAU2]TRCKEY = [F:ATI]CODIND
Affzo [M:GAU2]TRCKEY
End


Subprog AS_TRCKEY(VALEUR)
Variable Char    VALEUR()
Filter [AOB] Where NOMFIC=[M]TRCTBL & TYPGES=1
Read [AOB]NOMFIC First
If !fstat
 Read [ATI]NUMLIG(2) = VALEUR;1
 [M:GAU2]TRCKEY = [F:ATI]CODIND
 Affzo [M:GAU2]TRCKEY : mkstat = 2 : End
Endif
End

Subprog C_TRCKEY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

OK = 0
For [ATI] Where CODFIC=[M:GAU2]TRCTBL
 If VALEUR=[F:ATI]CODIND
  OK = 1 : Break
 Endif
Next
If !OK
 GMESSAGE = VALEUR-":"-mess(6,114,1)
 mkstat = 2
Else
 If [M:GAU2]TRCTBL<>[M:GAU1]TBL

  Local Decimal NBRKEY
  Local Char PKEY(GLONAVA)(1..20)
  Call KEY_FIELD([F:ATI]DESCRIPT,PKEY,NBRKEY) From CPTTRCVCR

  OK = 0
  For I=1 To NBRKEY
   Read [ATZ]CODZONE = [M:GAU1]TBL;PKEY(I)
   If fstat : OK = 1 : Break : Endif
  Next
  If OK
   GMESSAGE = VALEUR-":"-mess(1,127,1)
   mkstat = 2
  Endif
 Endif
Endif
End

Subprog C_TRCACT(VALEUR)
Variable Char    VALEUR()
Local Char ACT(GLONACT)
Local Integer OK
If VALEUR<>""
 OK = 0
 ACT = VALEUR
 While ACT<>""
  Call LECTURE("ACT",ACT,"") From CONTOBJ
  If fstat : Break : Endif
  # Action gérée : Objet, Consultation, Fenêtre
  If find([F:ACT]TYP,1,2,4) : OK = 1 : Break : Endif
  ACT = [F:ACT]ACTSUI
 Wend
 If !OK
  GMESSAGE = VALEUR-":"-mess([F:ACT]TYP,81,1)+"\"+mess(153,133,1)
  mkstat = 2 : End
 Endif
Endif
[M]TRCACT = VALEUR
End

Subprog AM_TRCACT(VALEUR)
Variable Char    VALEUR()
Local Char ACT(GLONACT) : ACT = VALEUR
Gosub CHARGE_PAR
If !GIMPORT
 Actzo [M:GAU2]20
 Affzo [M:GAU2]20
Endif
End

Subprog IB_TRCVALPAR
Raz GBOUT1
If [M:GAU2]TRCACT="GASACCNUM1"
 GBOUT1 = mess(18,100,1)
Endif
End

Subprog C_TRCVALPAR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If [M:GAU2]TRCACT="GASACCNUM1"
 VALEUR= toupper(VALEUR)
 Read [ATZ]CODZONE = [M:GAU2]TRCTBL;VALEUR
 If fstat : GMESSAGE=mess(41,100,1) : mkstat=2 : End : Endif
Endif
End


