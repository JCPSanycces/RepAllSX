#<AdxTL>@(#)4.0.0.0 $Revision$

#
#--- Programme de mise a jour de la table SCALES  / Centrale de pesée
#


Call OBJET ("SLE" , GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "STATUT"      : Gosub STATUT
 When "AVANT_MODFIC": Gosub AVANT_MODFIC
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "ABANDON"     : Gosub ABANDON
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "CHANGE"      : Call CHANGE_AXX ("SCALES",[L]SUPP(0),[L]OCODE,[L]SUPP(0),[L]NCODE) From TRTX3TEX
 When Default
Endcase
Return



#********************************************************************** OUVRE
$OUVRE
Return

#********************************************************************** SETBOUT
$SETBOUT
#--- activation desactivation des boutons
If GREP="C" | GREP="D" | [M:SLE0]SLE <> ""
   CHMEN += "F"   # v 140
Endif

Return

#********************************************************************** RAZCRE
$RAZCRE
Call RAZ_CLOB From ACLOB

#--- suppression icone texte an bas a droite de l ecran
 Call RESET_IMAGE (4) From GESECRAN   :


Grizo [M:SLE1]USRUSR
Affzo [M:SLE1]USRUSR

Grizo [M:SLE1]MODSCALE    # 114545 mm 09.2016
Affzo [M:SLE1]MODSCALE    # 114545 mm 09.2016

[M:SLE1]BAURAT = 2400
[M:SLE1]PRY    = 3
[M:SLE1]SYZBYT = 7
[M:SLE1]STPBYT = 1


Return


#********************************************************************** RAZDUP

$RAZDUP

Local Integer WRET,I
Call RAZ_CLOB From ACLOB
Call DUP_CLOB("SLE",[M:SLE0]TEX,WRET) From TRTX3TEX
If WRET<1 Raz [M:SLE0]TEX : Endif

Grizo [M:SLE1]USRUSR
Grizo [M:SLE1]MODSCALE    # 114545 mm 09.2016

Raz [M:SLE2]LASCBTDAT    #X3-38240.n
Raz [M:SLE2]NBRWGGCBT    #X3-38240.n

Return


#********************************************************************** INICRE
$INICRE


If [M:SLE0]TEX<>""
      Call CRE_CLOB([M:SLE0]TEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:SLE]TEX = [M:SLE0]TEX
Endif


Return

#********************************************************************** AVANTBOUT
#    Avant l'execution des boutons et des menus
$AVANTBOUT

 Return

#********************************************************************** STATUT

$STATUT
#-------------------------------------------------#
# gestion des textes                              #
#-------------------------------------------------#
Local Integer WRETOUR
Local Char    WNUMTEX(12)

If mkstat=4 & GREP=""
   #MAE, bg 50938
   #GREP="M" : REP="M"
   #Gosub SETBOUT From GOBJSUB
   Gosub ENTRE_MODIF From GOBJSUB
Endif
#---  activation icone texte en bas a droite de l ecran
If [M:SLE0]TEX <> "" & !GIMPORT
   Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT
   Call RESET_IMAGE (4) From GESECRAN
Endif


Return

#********************************************************************** ABANDON

$ABANDON
Local Integer WRET

If GREP = "D"
      Call SUP_CLOB([M:SLE0]TEX,WRET) From TRTX3TEX
Endif
Call RAZ_CLOB From ACLOB
Return

#********************************************************************** ANNULE

$ANNULE
Local Integer WRET
#---  en cas d annulation de la fiche il faut aussi supprimer le texte si existant
Call SUP_CLOB([M:SLE0]TEX,WRET) From TRTX3TEX
Call RAZ_CLOB From ACLOB
#--- maj de la table des libéllés traduisibles
Delete [AXX] Where CODFIC="SCALES" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif
Return


#********************************************************************** LIENS

$LIENS
Call RAZ_CLOB From ACLOB
#---  activation de l icone texte coin droit en bas

If [M:SLE0]TEX <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

 Grizo [M:SLE1]USRUSR
# 114545 mm 09.2016
If [M:SLE1]PILNAM <> "06"
    Grizo [M:SLE1]MODSCALE
Else
    Actzo [M:SLE1]MODSCALE
Endif
Affzo [M:SLE1]MODSCALE

#---  si numero Code calibrage different de 0 activation des zones
#     sinon desactivation

If [M:SLE2]CBTCOD = 1
    Grizo [M:SLE2]NBRDAY
    Grizo [M:SLE2]NBRWGG
    Grizo [M:SLE2]CGD
    Grizo [M:SLE2]CBTLBE
          [M:SLE2]NBRDAY = 0
          [M:SLE2]NBRWGG = 0
          [M:SLE2]CGD    = ""
          [M:SLE2]CBTLBE = ""
 Endif

If  [M:SLE2]CBTCOD = 2
       Actzo [M:SLE2]NBRDAY
       Grizo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRWGG = 0
 Endif

  If [M:SLE2]CBTCOD = 3
       Grizo [M:SLE2]NBRDAY
       Actzo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRDAY = 0
Endif

If   [M:SLE2]CBTCOD = 4
       Actzo [M:SLE2]NBRDAY
       Actzo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
Endif

If   [M:SLE2]CBTCOD = 5
       Grizo [M:SLE2]NBRDAY
       Grizo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRDAY = 0
             [M:SLE2]NBRWGG = 0
Endif

Affzo [M:SLE2]NBRDAY
Affzo [M:SLE2]NBRWGG
Affzo [M:SLE2]CGD
Affzo [M:SLE2]CBTLBE

Return



####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
If [M:SLE0]TEX="" & [F:SLE]TEX <> ""
   Call SUP_CLOB([F:SLE]TEX,WRET) From TRTX3TEX
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M:SLE0]DESAXX,"SCALES","DESAXX",[M:SLE0]SLE,[M:SLE0]FCY) From ATEXTRA
Call MAJTEXTRA([M:SLE0]SHOAXX,"SCALES","SHOAXX",[M:SLE0]SLE,[M:SLE0]FCY) From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M:SLE0]DESAXX,"SCALES","DESAXX",[M:SLE0]SLE,[M:SLE0]FCY) From ATEXTRA
Call MAJTEXTRA([M:SLE0]SHOAXX,"SCALES","SHOAXX",[M:SLE0]SLE,[M:SLE0]FCY) From ATEXTRA

Return


#********************************************************************** ACTIONS ecran
#**************************************************************** ecran SLE1

# le Box doit exister dans la table lieu / box
########################################
Subprog C_BOX(VALEUR)
Variable Char    VALEUR()
#Filter [F:SBX] Where BOX = VALEUR and STI = [M:SLE1]STI
#Look [F:SBX]SBX0 First
#If fstat : GMESSAGE = mess(24,100,1) : mkstat = 1 : Endif
#Filter [F:SBX]
#End

If clalev ([SBX])=0 : Local File STATIONBOX [SBX] : Endif
# contrôle existence
#If VALEUR <> ""
   Read [SBX]SBX0=VALEUR;[M:SLE0]FCY

        If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Endif

#Endif
End




########################################
Subprog AM_BOX(VALEUR)
Variable Char    VALEUR()

If clalev ([SBX])=0 : Local File STATIONBOX [SBX] : Endif



[M:SLE1]STI       = [F:SBX]STI
Affzo [M:SLE1]STI

End

########################################
# Le numero de port doit etre de 0 à 8
# mess(6,199,1) = valeur incorrecte

Subprog C_CAG(VALEUR)
Variable Decimal VALEUR

If VALEUR = 9 : GMESSAGE = mess(6,199,1) : mkstat = 1 : Endif

End

#**************************************************************** ecran SLE2
########################################
#---  Activation ou Desactivation des zones selon le code calibrage
#     code calibrage     1  = pas de calibrage
#                        2  = nombre de jours
#                        3  = nombre de pesées
#                        4  = nbre jours et pesees
#                        5  = chaque pesées


#     code calibrage       1     2     3      4      5

#     nombre jours         D     A     D      A      D
#     nombre pesee         D     D     A      A      D
#     guide calibrage      D     A     A      A      A
#     etiquette calibrage  D     A     A      A      A

Subprog AM_CBTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    Grizo [M:SLE2]NBRDAY
    Grizo [M:SLE2]NBRWGG
    Grizo [M:SLE2]CGD
    Grizo [M:SLE2]CBTLBE
          [M:SLE2]NBRDAY = 0
          [M:SLE2]NBRWGG = 0
          [M:SLE2]CGD    = ""
          [M:SLE2]CBTLBE = ""
Endif

If VALEUR = 2
       Actzo [M:SLE2]NBRDAY
       Grizo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRWGG = 0
Endif

If VALEUR = 3
       Grizo [M:SLE2]NBRDAY
       Actzo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRDAY = 0
Endif

If VALEUR = 4
       Actzo [M:SLE2]NBRDAY
       Actzo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRDAY = 0
Endif

If VALEUR = 5
       Grizo [M:SLE2]NBRDAY
       Grizo [M:SLE2]NBRWGG
       Actzo [M:SLE2]CGD
       Actzo [M:SLE2]CBTLBE
             [M:SLE2]NBRDAY = 0
             [M:SLE2]NBRWGG = 0
Endif

[M:SLE2]CBTCOD = VALEUR
Affzo [M:SLE2]CBTCOD
Affzo [M:SLE2]NBRDAY
Affzo [M:SLE2]NBRWGG
Affzo [M:SLE2]CGD
Affzo [M:SLE2]CBTLBE
End



#**************************************************************** ecran SLE3



########################################
# la portée minimum doit etre inferieure à la portee maximum
# mess(2,2324,1) = portee minimum > ou = a la portée maximum

Subprog C_MINRGE(VALEUR)
Variable Decimal VALEUR

If [M:SLE3]MAXRGE = VALEUR : GMESSAGE = mess(2,2324,1) : mkstat = 1 : Endif
If [M:SLE3]MAXRGE < VALEUR : GMESSAGE = mess(2,2324,1) : mkstat = 1 : Endif


End

########################################
# la tare maximum doit etre inferieure à la portee maximum
# mess(3,2324,1) = tare maximum > a la portée maximum


Subprog C_MAXTAR(VALEUR)
Variable Decimal VALEUR

If VALEUR > [M:SLE3]MAXRGE : GMESSAGE = mess(3,2324,1) : mkstat = 1 : Endif

End


########################################

########################################
Subprog AM_BAURAT(VALEUR)
Variable Decimal VALEUR
If VALEUR =    0 End : Endif
If VALEUR =  600 End : Endif
If VALEUR = 1200 End : Endif
If VALEUR = 2400 End : Endif
If VALEUR = 4800 End : Endif
If VALEUR = 9600 End : Endif
GMESSAGE = mess(6,199,1) : mkstat = 1

End

########################################
Subprog AM_SYZBYT(VALEUR)
Variable Decimal VALEUR
If VALEUR  < 7 : GMESSAGE = mess(6,199,1) : mkstat = 1 : Endif
If VALEUR  > 8 : GMESSAGE = mess(6,199,1) : mkstat = 1 : Endif
End

########################################
Subprog C_BAURAT(VALEUR)
Variable Decimal VALEUR
If VALEUR =    0 End : Endif
If VALEUR =  600 End : Endif
If VALEUR = 1200 End : Endif
If VALEUR = 2400 End : Endif
If VALEUR = 4800 End : Endif
If VALEUR = 9600 End : Endif
GMESSAGE = mess(6,199,1) : mkstat = 1

End

########################################
Subprog C_SYZBYT(VALEUR)
Variable Decimal VALEUR

If VALEUR  < 7 : GMESSAGE = mess(6,199,1) : mkstat = 1 : Endif
If VALEUR  > 8 : GMESSAGE = mess(6,199,1) : mkstat = 1 : Endif


End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SLE1) 21/10/2016 13:05:22 (MM)
######################################################################################
Subprog AP_PILNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR  ="06"
 Actzo [M:SLE1]MODSCALE
Else
 # X3-38644  mm 09.2017
 [M:SLE1]MODSCALE=""
 Grizo [M:SLE1]MODSCALE
Endif
End


