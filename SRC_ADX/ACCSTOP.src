#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACCSTOP","",1,"") From GTRAITE
End

# Arrêt de la tâche batch comptable

$ACTION
Case ACTION
 When "EXEC" : Call STOPPE
Endcase
Return

Subprog STOPPE
Local File BATCH [BTC]
Local Char    TACHE(10) , PARAM(10) , CRITERE(250)
Local Integer MULTI
Call PARAM("","MULBATCH",PARAM) From ADOVAL
MULTI = (val(PARAM)=2)
If MULTI
 CRITERE = 'COD<>"ACCENTRY"'
Else
 CRITERE = 'COD="ACCENTRY"'
Endif
Trbegin [BTC]
 For [BTC]BTC0 Where evalue(CRITERE)
  TACHE = [F:BTC]COD
  Openo filpath("TRA",TACHE,"tra",0), -1
  Wrseq GUSER-":"-mess(32,114,1)
  Openo
  [F:BTC]STA = 2
  Rewrite [BTC]
  Call ECR_TRACE(mess(32,114,1)-TACHE,0) From GESECRAN
 Next
Commit
End

