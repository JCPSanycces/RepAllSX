#<AdxTL>@(#)5.0.0.0 $Revision$
## <ALLEMAGNE>
Subprog BASE_CALCUL(TYPPCE,NUMPCE,ACC_NUM,DUD_LIG,BASDEP)
Value    Char    TYPPCE         : # Type de pièce
Value    Char    NUMPCE         : # Numéro de pièce
Value    Integer ACC_NUM()      : # Numéro interne (accnum) de l'échéance à règler
Value    Integer DUD_LIG()      : # Numéro échéance à règler
Variable Decimal BASDEP         : # Base pour le calcul montant esc/agio 
## Demande : pouvoir exclure certains charges/produits dans le calcul du montant d'escompte/agio
## Cette demande est réalisée sur des pièces comptables pour lesquelles il existe la facture dans
## PINVOICE/SINVOICE (pas possible de faire cela sur les pièces de relévés d'échéancves, etc...) 
If !clalev([F:PIH])  : Local File PINVOICE   [PIH]  : Endif  : # En-tête factures fournisseurs
If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif  : # En-tête factures clients
If !clalev([F:DAE4]) : Local File GACCENTRYD [DAE4] : Endif : # Lignes pièces comptables
If !clalev([F:DDD])  : Local File GACCDUDATE [DDD]  : Endif  : # Echéances
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif  : # Comptes
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif  : # Devises
Local Char    SOCIETE(GLONCPY), PLAN(GLONCOA)
Local Integer FLGFAC, CEE_FLG
Local Decimal BASE_DEP : # Base pour le calcul d'escomptes/agios
Local Decimal TTC
FLGFAC = 0 : CEE_FLG = 0
Read [DDD]DUD1 = [L]ACC_NUM;[L]DUD_LIG
If !fstat
 Read [F:SIH]SIH0 = [F:DDD]NUM
 If !fstat 
  FLGFAC = 1 : SOCIETE = [F:SIH]CPY
 Else
  Read [F:PIH]PIH0 = [F:DDD]NUM
  If !fstat
   FLGFAC = 2 : [L]CEE_FLG=[F:PIH]CEEFLG : SOCIETE = [F:PIH]CPY
  Endif
 Endif
Endif
If FLGFAC : # C'est une facture
 Call LECTURE("TCU",[F:DDD]CUR,"") From CONTOBJ
 ARD=[F:TCU]CURRND 
 Gosub CAL_BASE
Endif
End

$CAL_BASE
Raz BASE_DEP, TTC
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(SOCIETE,GTYPGEN,PLAN) From CPTDIV
## Si la facture n'est pas validée en compta (=écritures inexistantes), le montant d'escompte sera calculé
## comme avant sur le montant total de l'échéance
For [DAE4]DAE0 Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=GTYPGEN
 If [F:DAE4]ACCNUM=[L]ACC_NUM
  TTC = [F:DAE4]AMTCUR
 Else
  Call LECTURE("GAC",[F:DAE4]ACC,PLAN) From CONTOBJ
  If !fstat & find([F:GAC]FLGVAT,1,2) & [F:GAC]FLGDEP=2
   BASE_DEP += [F:DAE4]AMTCUR
   If [F:DAE4]TAX<>""
    Gosub CALTAXE
    BASE_DEP += [L]AMTTAX1+[L]AMTTAX2+[L]AMTVAT
   Endif
  Endif
 Endif
Next
## Le montant de base (montant passé en paramètres du sous-programme ESC_AGIO et qui correspond au montant
## de l'échéance restant à règler) doit être proratisé par rapport aux montants (HT+TVA) des comptes à
## prendre en compte pour le montant de l'escompte/agio
If TTC
 BASDEP = arr(BASDEP*([L]BASE_DEP/TTC),ARD)
Endif
Return

$CALTAXE
Local Char    TAXES(GLONVAT)(1..3)
Local Integer TYPREG , STAT
Local Decimal MONTVAT(1..3), MONTDED(1..3)
Local Decimal AMTTAX1, AMTTAX2, AMTVAT
If dim([F:DAE4]TAX2)>0
 TAXES(1) = [F:DAE4]TAX2  : # Code taxe 1
Endif
If dim([F:DAE4]TAX3)>0
 TAXES(2) = [F:DAE4]TAX3  : # Code taxe 2
Endif
TAXES(3) = [F:DAE4]TAX    : # Code TVA
Call CALTAXE([F:DAE4]CPY,[F:DAE4]ACCDAT,"",[F:DAE4]CUR,3,TAXES,1,[F:DAE4]AMTCUR,MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
If FLGFAC=1 & TYPREG<>1
 Raz MONTVAT, MONTDED
Elsif FLGFAC=2 & TYPREG<>1 & (TYPREG<>4 | [L]CEE_FLG)
 Raz MONTVAT, MONTDED
Endif
[L]AMTTAX1 = MONTVAT(1)
[L]AMTTAX2 = MONTVAT(2)
[L]AMTVAT  = MONTVAT(3)
Return
## <Fin ALLEMAGNE>

