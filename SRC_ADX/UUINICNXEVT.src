#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# UUINICNXEVT                                                                    #
# GBO - Initialisation du champ CNX dans les événements                          #
# 21/01/2009 Fq-51634                                                            #
##################################################################################
Call PATCH(nomap)
End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","EFASISS","fde",PAPPLI),0)<=0
      End
Else
   Gosub EXE_UUINICNXEVT
Endif

End

#######################################################################
# Pour exécution depuis intégration de patch
########################################################################
Subprog PATCH(PAPPLI)
Value Char APPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","EFASISS","fde",PAPPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif 

  Gosub EXE_UUINICNXEVT

End

#--------------------------------------------
# Initialisation du champ CNX dans les
# événements 
#--------------------------------------------
$EXE_UUINICNXEVT
 Local Char    LIBTYP(80)
 Local Char    LREQ(255)
 Local Integer I_PLN, LCNX, LUPDEVT
 If GTRACE="" : Call OUVRE_TRACE("Fq 51634 - CNX field intialization in events tables") From LECFIC : Local Integer LTRACE : Endif
 Call ECR_TRACE("---------------------------------------------------",0) From GESECRAN
 Call ECR_TRACE("Fq 51634 - CNX field intialization in events tables",0) From GESECRAN
 Call ECR_TRACE("---------------------------------------------------",0) From GESECRAN
 If !clalev([F:ADI]) : Local File =PAPPLI+"."+"ATABDIV" [ADI] : Endif
 If !clalev([F:CPY]) : Local File =PAPPLI+"."+"COMPANY" [CPY] : Endif
 If !clalev([F:CNX]) : Local File =PAPPLI+"."+"CONTEXT" [CNX] : Endif
 Filter [F:ADI] Where NUMTAB = 962 
 For [F:ADI]
  If !(filinfo(filpath("FIL",[F:ADI]A2,"fde",PAPPLI),0)<=0)
   If clalev([F:EVT]) : Close Local File [EVT] : Endif
   Local File =PAPPLI+"."+[F:ADI]A2 [EVT] : Trbegin [EVT] : GOK=1
   Call LECTEXTRA(LIBTYP,"ATABDIV","LNGDES","962",[F:ADI]CODE) From ATEXTRA
   Call ECR_TRACE(" =>"-LIBTYP,0) From GESECRAN     
   If [F:ADI]N1=G_NON
    Update [EVT] Where 1=1 With CNX=0
    If fstat
     GOK=0 
     Call ECR_TRACE("UUINICNXEVT-I-fstat="+num$(fstat),1) From GESECRAN 
    Else
     Call ECR_TRACE(space$(15)+num$(adxuprec)-":"-"updated events",0) From GESECRAN
    Endif
   Elsif [F:ADI]N1=G_OUI
    LUPDEVT=0
    For [F:CPY]
     For [F:CNX] Where CPY=[F:CPY]CPY
      For I_PLN=1 To [F:CNX]NBPLC
       LREQ="DPRPLN=[F:CNX]PLNCAA(I_PLN-1) & CPY=[F:CPY]CPY"
       Update [EVT] Where evalue(LREQ) With CNX=[F:CNX]CNX
       If fstat
        GOK=0 
        Call ECR_TRACE("UUINICNXEVT-II-fstat="+num$(fstat),1) From GESECRAN
        Break         
       Else
        If adxuprec
         LUPDEVT+=adxuprec
        Endif
       Endif       
      Next I_PLN
     Next 
    Next   
    If GOK : Call ECR_TRACE(space$(15)+num$(LUPDEVT)-":"-"updated events",0) From GESECRAN : Endif
   Endif
   If GOK
    Commit
   Else
    Rollback
   Endif
  Endif
 Next
 Filter [F:ADI]
 Call ECR_TRACE("-----------------",0) From GESECRAN
 If dim(LTRACE)>0 : Call LEC_TRACE From LECFIC : Endif
Return



