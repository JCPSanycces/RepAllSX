#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM013
# Issue X3-18442/120906 - 2017-01-13 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM013(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM013(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Decimal NITTQTY

  IERR = 0
  Call ECR_TRACE("UTIPJM013: Process Start on : "+SZAPPLI, 0) From GESECRAN
  #
  If filinfo(filpath("FIL", "PJMTSKITM", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  If filinfo(filpath("FIL", "ORDERS", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSKITM" [JTT]
  Local File =SZAPPLI + ".ITMMASTER" [ITM]
  Local File =SZAPPLI + ".ORDERS" [ORD]
  # -------------------------
  Trbegin [JTT]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM013: Updating PJMTSKITM/ORDERS", 0) From GESECRAN
  Filter [JTT] Where [F:JTT]WIPNUM <> ""
  For [JTT]JTT0
    Read [ITM]ITM0=[F:JTT]ITMREF
    If [F:ITM]STOMGTCOD <> 2 Then
      NCOUNT += 1
      Filter [ORD] Where [F:ORD]WIPTYP = 14 and [F:ORD]WIPNUM = [F:JTT]WIPNUM and [F:ORD]ITMREF = [F:JTT]ITMREF
      For [ORD]
        Delete [ORD]Curr
      Next
      Filter [ORD]
      #
      [F:JTT]WIPNUM = ""
      Rewrite [JTT]
      If fstat Then
        Call ECR_TRACE("File PJMTSKITM/ORDERS(a)" - [F:JTT]OPPNUM - [F:JTT]TASCOD - [F:JTT]ITMREF - num$([F:JTT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [JTT]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM013: PJMTSKITM/ORDERS" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM013: PJMTSKITM/ORDERS" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM013 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM013 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  If filinfo(filpath("FIL","ORDERS","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ORDERS") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM013(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  If filinfo(filpath("FIL","ORDERS","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ORDERS") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM013(APPLI)
End

