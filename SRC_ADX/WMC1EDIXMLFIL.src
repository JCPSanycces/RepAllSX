####################################################################
# 3 : MSGFILNOR File standard ( Field Miscellaneous table number)
####################################################################

$SET_MSGFILNOR
If [L]_AOLDVAL<>this.MSGFILNOR
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_MSGFILNOR
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.MSGFILNOR
 Gosub PROPAGATE_MSGFILNOR
Endif
Return

$INIT_MSGFILNOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFILNOR"
[L]ASTATUS =  func ADI_TOOL.ADI_INI(this,"MSGFILNOR",this.MSGFILNOR,2002)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_MSGFILNOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFILNOR"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_MSGFILNOR             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_MSGFILNOR             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_MSGFILNOR
[L]CURPRO = "MSGFILNOR"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.MSGFILNOR,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_MSGFILNOR
[L]CURPRO = "MSGFILNOR"
If vireblc(this.MSGFILNOR,2)<>vireblc(format$("K:20B",this.MSGFILNOR),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_MSGFILNOR
[L]CURPRO = "MSGFILNOR"
[L]ASTATUS =  func ADI_TOOL.ADI_CONT(this,"MSGFILNOR",this.MSGFILNOR,2002,"")
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_MSGFILNOR
[L]CURPRO = "MSGFILNOR"
Return

$PROPAGATE_MSGFILNOR
this.isReadonly = 0
[L]CURPRO = "MSGFILNOR"
Gosub _LNKPRO_MSGFILNOR
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_MSGFILNOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFILNOR"
$_LNKPRO_MSGFILNOR
If vireblc(this.MSGFILNOR,2)<>""
 # Link ATABDIV
 Local File ATABDIV [WADI]
 Read [F:WADI]CODE = 2002;this.MSGFILNOR
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WADI]
Endif
Return

$_ALOADATTRIBUTE_MSGFILNOR
[L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$isMandatory","true")
Return


####################################################################
# 4 : MSGFOR Message file format ( Field Local menu number 2013)
####################################################################

$SET_MSGFOR
If [L]_AOLDVAL<>this.MSGFOR
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_MSGFOR
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.MSGFOR
 Gosub PROPAGATE_MSGFOR
Endif
Return

$INIT_MSGFOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFOR"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.MSGFOR=0 and fmet this.AGETATTRIBUTE("MSGFOR","$isMandatory")="true"
 this.MSGFOR = 1
Endif
Return
 
$CONTROL_MSGFOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFOR"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_MSGFOR                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_MSGFOR                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_MSGFOR
[L]CURPRO = "MSGFOR"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.MSGFOR=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_MSGFOR
[L]CURPRO = "MSGFOR"
If this.MSGFOR<0 or this.MSGFOR>len(mess(0,2013,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"2013 ->"-num$(this.MSGFOR)-mess(99,123,1)):  Return : # Local menu "2013 -> Invalid option
Endif
Return

$_AOTHERS_MSGFOR
[L]CURPRO = "MSGFOR"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_MSGFOR
[L]CURPRO = "MSGFOR"
Return

$PROPAGATE_MSGFOR
this.isReadonly = 0
[L]CURPRO = "MSGFOR"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_MSGFOR
Gosub DECLARE_VAR From WMC0EDIXMLFIL
[L]CURPRO = "MSGFOR"
$_LNKPRO_MSGFOR
Return

$_ALOADATTRIBUTE_MSGFOR
[L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFOR","$isMandatory","true")
Return


