#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
# BPCOSTCTL : Liste des clients en dépassement d'encours              #
# --------------------------------------------------------------------- #
#########################################################################
# Bug 62801
# On rajoute la société en critère quand OSTCTL = Société
$ACTION
Case ACTION
  When "OUVRE"   : Gosub OUVRE2
Endcase
Return

$OUVRE2
Local Char    WSOCIETE(GLONCPY)
Local Char    WSITE(GLONFCY)

Local Integer ISITE

GBIDI2=find("société",[M:RPT]PARCOD)
If dim(GOSTCTL)>0 & GOSTCTL = 1 Then
  If GBIDI2
    [M:RPT]VALEUR1(GBIDI2-1)=""
    [M:RPT]VALINT1(GBIDI2-1)=""
    [M:RPT]VALEUR2(GBIDI2-1)=""
    [M:RPT]VALINT2(GBIDI2-1)=""
    Affzo [RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
    Diszo [RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
  Endif  
Else
  WSITE = GFCYDEF(9)
  If WSITE<>""
   ISITE = find(WSITE,GSITE(1..GNBSITE))
   If ISITE
    WSOCIETE = GSOCSITE(ISITE)
   Else
    WSOCIETE = WSITE
   Endif
   If GBIDI2
      [M:RPT]VALEUR1(GBIDI2-1)= WSOCIETE
      [M:RPT]VALINT1(GBIDI2-1)= WSOCIETE
      [M:RPT]VALEUR2(GBIDI2-1)= ""
      [M:RPT]VALINT2(GBIDI2-1)= ""
      Affzo [RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
  Endif  
Endif

Endif
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
#-----
Call EXEC(NBPAR,PARAMETRE)
#-----
End

#########################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()

#-----
Gosub OUVRE   : # Ouverture des tables
If GERREUR  GERREUR=0 : End : Endif 
#-----
Gosub DECLARE : # Déclaration des variables globales
#-----
[L]CRITERE = "1=1"

For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"           : [L]ETAT     = [L]VALEUR
      When "__REQUETE"       : [L]NUMREQ   = val([L]VALEUR)
      When "clientdeb"       : [L]CRITERE -= "& BPCNUM>='"+[L]VALEUR+"'"
      When "clientfin"       : [L]CRITERE -= "& BPCNUM<='"+[L]VALEUR+"'" 
      When "clientrskdeb"    : [L]CRITERE -= "& BPCRSK>='"+[L]VALEUR+"'"
      When "clientrskfin"    : [L]CRITERE -= "& BPCRSK<='"+[L]VALEUR+"'" 
      When "categdeb"        : If VALEUR>" " : [L]CRITERE -= "& BCGCOD>='"+[L]VALEUR+"'" : Endif
      When "categfin"        : [L]CRITERE -= "& BCGCOD<='"+[L]VALEUR+"'"
      When "fam1deb"         : If VALEUR>" " : [L]CRITERE -= "& TSCCOD(0)>='"+[L]VALEUR+"'" : Endif
      When "fam1fin"         : [L]CRITERE -= "& TSCCOD(0)<='"+[L]VALEUR+"'"
      When "typeblocage"     : [L]TYPEBLOCAGE = val([L]VALEUR)
      When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
      When "société"         : WCPY = [L]VALEUR  
    Endcase
  Endif
Next

#-----
# Bug 62801
# Quand on a un client à risque # du client 
# Les valeurs de l'encours autorisé sont celles du client à risque

Case [L]TYPEBLOCAGE
  When 1 : [L]CRITERE -= "& (OSTCTL = 3 | BPCRSK <> BPCNUM )"
  When 2 : [L]CRITERE -= "& (OSTCTL = 1 | BPCRSK <> BPCNUM)"
  When 3 : [L]CRITERE -= "& (OSTCTL = 1|OSTCTL = 3 | BPCRSK <> BPCNUM)"
Endcase
Filter [BPC] Where evalue([L]CRITERE)
Gosub TRT_BPC
End

#########################################################################

$TRT_BPC
# Bug 62801
# Quand on a un client à risque # du client 
# Les valeurs de l'encours autorisé sont celles du client à risque
# Donc on récupère celle-ci pour l'état
Local Decimal WOSTAUZ 
Local Integer WOSTCTL 
Local Integer SPSTAT
Local Char    WCUR(GLONCUR), WCURSOC(GLONCUR), WCURPARAM(GLONCUR) : # Devise passée en paramètre

Raz WNUMLIG 
WCURPARAM=GCURSHR : # Initialisation de la devise passée en paramètre par la devise dossier

Default File [BPC]
For [F:BPC] BPC0
ENCOURS = 0
ENCOURSCTL = 0
WOSTCTL = [F:BPC]OSTCTL
WOSTAUZ = [F:BPC]OSTAUZ

If [F:BPC]BPCRSK <> [F:BPC]BPCNUM Then
  Read [F:BPK]BPC0 = BPCRSK
  If !fstat Then
     WOSTCTL = [F:BPK]OSTCTL
     WOSTAUZ = [F:BPK]OSTAUZ
  Endif 
Endif 

If  ([L]TYPEBLOCAGE = 1 and WOSTCTL = 3) or 
&   ([L]TYPEBLOCAGE = 2 and WOSTCTL = 1) or
&   ([L]TYPEBLOCAGE = 3 and (WOSTCTL = 1 or WOSTCTL = 3)) Then

      # Bug 62801 si le niveau de controle est par société il faut convertir les
      # les montants en-cours du client en devise société, car elle sont en devise dossier
  If dim(GOSTCTL)>0 & GOSTCTL <> 1 Then
     Read [F:CPY1] CPY0 = WCPY
     If !fstat Then
        If [F:CPY1]ACCCUR <> "" and WOSTAUZ<>0 Then
           WCUR=[F:CPY1]ACCCUR
           WCURSOC=[F:CPY1]ACCCUR     : # La devise utilisée pour calculer les mnts actualisés est la devise société
           WCURPARAM=[F:CPY1]ACCCUR     : # la devise passée en paramètre est la devise société
           Call CONVERT(GCURSHR,WCUR,WCURSOC,[F:BPC]CHGTYP,date$,
&                       WOSTAUZ,WOSTAUZ,SPSTAT) From TRTDEV
        Endif 
     Endif
  Endif

#  If WOSTCTL = 3
#     Gosub TR
#  Else
#  Endif
      # Bug 62801 si la société n'est pas renseignée c'est que l'on veut le calcul
      # de l'encours par dossier
      # Pour l'état BPCOSTCTL on utilise la société du site par défaut de l’utilisation
  If WCPY = "" and GOSTCTL <> 1 Then
     Read [F:FCY]FCY0 = GFCYDEF
     If !fstat Then
          WCPY = [F:FCY]LEGCPY
     Endif 
  Endif    
  ENCOURS = func TRTBPMVT.CALOSTCPY(WCPY,[F:BPC]BPCRSK,[F:BPC]CHGTYP, date$)
  If WOSTAUZ<ENCOURS or WOSTCTL = 3 : # Bug 62801
    ENCOURSCTL = func TRTBPMVT.CALOSTCPYCTL(WCPY,[F:BPC]BPCNUM,[F:BPC]CHGTYP, date$)
    Gosub TR
  Endif
Endif  
Next 
Return

#########################################################################

$TR
Trbegin [ARM]
#----- Création d'un enregistrement dans la table AREPORTM -----#
WNUMLIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [F:ARP]RPTCOD
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = WNUMLIG
# Bug 62801
# client à risque 
#[F:ARM]CLEA1  = [F:BPC]BPCNUM
[F:ARM]CLEA1  = [F:BPC]BPCRSK
[F:ARM]CLEA2  = [F:BPC]BPCNUM
[F:ARM]CLEA3 = WCURPARAM : # Devise passée en paramètre
[F:ARM]CREDAT = date$
[F:ARM]CLEMD1 = ENCOURS
[F:ARM]CLEMD2 = WOSTAUZ
[F:ARM]CLEMD3 = ENCOURSCTL
[F:ARM]CLEN1 = WOSTCTL
Write [F:ARM]   
If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR : Endif
#-----
Commit 
Return 
 
$ROLL_TR
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR : Endif 
 
$AB_TR
Rollback 
Return 

#########################################################################
 
$OUVRE 
Local File BPCUSTOMER [BPC], AREPORTM [ARM], FACILITY [FCY], BPCUSTOMER [BPK], COMPANY [CPY1]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP), WCPY(GLONCPY)
Local Integer WNUMLIG, NUMREQ, I, J, TYPEBLOCAGE
Local Decimal ENCOURS,ENCOURSCTL
Return 
