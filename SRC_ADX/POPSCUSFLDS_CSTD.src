#<AdxTL>@(#)0.0.0.0 $Revision$
# Class POPSCUSFLDS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "INITIALIZE" : Gosub INITIALIZE
    When "INITIATE" : Gosub INITIATE
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**------------------------------------------------------------------------------------------------<br/>
#* INITIALIZE : Create the custom field definitions if they do not exist or update them if they do.
#**<br/>-------------------------------------------------------------------------------------------<br/>
#**<br/>----------------------------------------------------------------
#*!
$INITIALIZE
    Local Instance POPSCUSFLDS(1..16) Using C_POPSCUSFLDS
    Local Instance NEWPOPSCF Using C_POPSCUSFLDS
    Local Integer OK

    Gosub CREATEBASEFIELDS

    NEWPOPSCF = NewInstance C_POPSCUSFLDS AllocGroup null
    For I = 1 To 16
        [L]OK = fmet NEWPOPSCF.AREAD(POPSCUSFLDS(I).MENNUM, POPSCUSFLDS(I).MESNUM)
        If [L]OK = [V]CST_AOK
            POPSCUSFLDS(I).AUUID = NEWPOPSCF.AUUID
            [L]OK = fmet POPSCUSFLDS(I).AUPDATE()
        Else
            POPSCUSFLDS(I).AUUID = NullUuid
            [L]OK = fmet POPSCUSFLDS(I).AINSERT()
        Endif
    Next

    FreeGroup NEWPOPSCF
    FreeGroup POPSCUSFLDS(1..16)
Return

#**--------------------------------------------<br/>
#* INITIATE : Initialize the class with values.
#**<br/>---------------------------------------<br/>
#* @param MENNUM   = Local menu number
#* @param MESNUM   = Local menu message number
#* @param FORMULE  = Formula the retrieve value
#* @param ENTTYP   = Entity type (WO or OP)
#* @param FLDTYP   = Field type (String, integer, etc.)
#* @param FLDORD   = Numerical order
#* @param AUUID    = UUID to provide unique identity
#**<br/>----------------------------------------------------------------
#*!
$INITIATE
    this.MENNUM = [L]MENNUM
    this.MESNUM = [L]MESNUM
    this.FORMULE = [L]FORMULE
    this.ENTTYP = [L]ENTTYP
    this.FLDTYP = [L]FLDTYP
    this.FLDORD = [L]FLDORD
Return

# Populate classes with the fixed custom fields.
$CREATEBASEFIELDS
    Local Integer OK

    POPSCUSFLDS(1) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet POPSCUSFLDS(1).INITIATE(3502, 1, "[F:BPC]BPCNUM-[F:BPC]BPCNAM", "WO", "Text", 1)
    POPSCUSFLDS(2) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(2).INITIATE(3502, 2, "[F:BPC]BPCNAM", "WO", "Text", 2)
    POPSCUSFLDS(3) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(3).INITIATE(3502, 3, "[F:MFI]PJT", "WO", "Text", 3)
    POPSCUSFLDS(4) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(4).INITIATE(3502, 4, "[F:MFI]TCLCOD", "WO", "Text", 4)
    POPSCUSFLDS(5) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(5).INITIATE(3502, 5, "[F:ITM]CFGLIN", "WO", "Text", 5)
    POPSCUSFLDS(6) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(6).INITIATE(3502, 6, "[F:MFI]TSICOD(0)", "WO", "Text", 6)
    POPSCUSFLDS(7) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(7).INITIATE(3502, 7, "[F:MFI]TSICOD(1)", "WO", "Text", 7)
    POPSCUSFLDS(8) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(8).INITIATE(3502, 8, "[F:MFI]TSICOD(2)", "WO", "Text", 8)
    POPSCUSFLDS(9) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(9).INITIATE(3502, 9, "[F:MFI]VCRNUMORI", "WO", "Text", 9)
    POPSCUSFLDS(10) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(10).INITIATE(3503, 1, "[F:MFO]EXTLAB", "OP", "Text", 1)
    POPSCUSFLDS(11) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(11).INITIATE(3503, 2, "[F:MFO]TECCRD", "OP", "Text", 2)
    POPSCUSFLDS(12) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(12).INITIATE(3503, 3, "[F:MFO]OPEPLNNUM", "OP", "Text", 3)
    POPSCUSFLDS(13) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(13).INITIATE(3503, 4, "[F:MFO]FXGNUM", "OP", "Text", 4)
    POPSCUSFLDS(14) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(14).INITIATE(3503, 5, "[F:MFO]PRGNUM", "OP", "Text", 5)
    POPSCUSFLDS(15) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(15).INITIATE(3503, 6, "[F:MFO]SCHGRP", "OP", "Text", 6)
    POPSCUSFLDS(16) = NewInstance  C_POPSCUSFLDS AllocGroup null
    [L]OK = fmet [L]POPSCUSFLDS(16).INITIATE(3503, 7, "[F:MFO]SCHSBB", "OP", "Text", 7)

Return

