End

######################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"   : Gosub DEBUT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#**
#* INIT
#*!
$INIT
Return

#**
#* DEBUT
#*!
$DEBUT
Return

#**
#* EXEC
#*!
$EXEC
Local Char FILESRV(250),FILECLI(250)
Local Char MESSAGE(250)
Local Integer STAT

Gosub ENUM_VOLFIL_TYPE  From ASYRSTO

# 113345 : forced /
PARAM(1) = ctrans(PARAM(1),"\","/")

STAT = func ASYRSTO.CTL_VOLFIL(2, PARAM(1),[L]FILESRV,E_TYPE_FILEREAD,MESSAGE)
If !STAT
 Call COPCLI(FILESRV,FILECLI,STAT) From ORDSYS
Else
 MESSAGE = func AFNC.MES1(mess(49,149,1),PARAM(1))
 Call ERREUR(MESSAGE) From GESECRAN
Endif
Return

