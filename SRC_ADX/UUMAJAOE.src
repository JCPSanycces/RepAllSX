#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour balise champ dans les modèles d'import/export
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update field BAL on file AOBJEXTD") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub BAL
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub BAL
End

#-------------------#
$BAL

Local Integer K , DIME
Local Char    FLD(30) , BAL(30)

Local File =DOSSIER+".AOBJEXTD" [AOD] , =DOSSIER+".AOBJEXT" [AOE] , =DOSSIER+".ATABLE" [ATB]

If dim([F:AOD]BAL)<0
 Close Local File [AOD],[AOE],[ATB]
 Return 
Endif

# Mise à jour de la table AOBJEXTD
Call ECR_TRACE(mess(81,125,1)-"AOBJEXTD:"-time$,0) From GESECRAN
Trbegin [AOD]
 For [AOE] Where TYPFIL=5 : # Html
  For [AOD] Where EXT=[F:AOE]EXT & BAL=""
   Gosub SET_BAL
   Rewrite [AOD]
   If fstat
    Call ERREUR("AOBJEXTD"-[F:AOE]EXT,2) From DOSDIC
   Endif 
  Next AOD
 Next AOE
Commit

Close Local File [AOD],[AOE],[ATB]

Return

#-----------------#
$SET_BAL
Case left$([F:AOD]FLD,1)
 When "/","*","=","'",'"',""
  BAL = [F:AOD]TYP+"__"+num$([F:AOD]NUMLIG)
 When Default 
  FLD = [F:AOD]FLD
  K = instr(1,FLD,"(")
  If K
   DIME = val(right$(FLD,K+1))
   FLD = left$(FLD,K-1)
   BAL = FLD+"_"+num$(DIME)
  Else
   BAL = FLD
  Endif
Endcase
Read [ATB]CODFIC=[F:AOD]FIL
[F:AOD]BAL = [F:ATB]ABRFIC+"_"+BAL
Return
