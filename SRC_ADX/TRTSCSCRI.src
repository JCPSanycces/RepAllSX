##########################################################################
## Etiquette ajoutée par le superviseur 11/09/2003 08:27:05 (CCC)
##########################################################################
Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
    If [M:SCR]LOTEND=[M:SCR]LOTSTR | [M:SCR]LOTEND<VALEUR
        [M:SCR]LOTEND = VALEUR
        Affzo [M:SCR]LOTEND
    Endif
End

Subprog C_LOTEND(VALEUR)
Variable Char    VALEUR()
    If [M:SCR]LOTSTR>VALEUR
        GMESSAGE = mess(44,199,1)
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:SCR]LOTSTR
    Endif
    If dim([M:SCR]SLOSTR)>0
        If VALEUR=[M:SCR]LOTSTR
            Actzo [M:SCR]SLOSTR,SLOEND
        Else
            Effzo [M:SCR]SLOSTR,SLOEND
            Diszo [M:SCR]SLOSTR,SLOEND
        Endif
    Endif
End

Subprog AM_SLOSTR(VALEUR)
