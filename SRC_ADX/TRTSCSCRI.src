#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAISCSCRI"
Call SAISIE_NUM(VALEUR,PARAM,"ISCSCRI","TRTSCSCRI") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

###################################################################################
# TRTSCSCRI    Saisie des filtres pour la liste de picking des changements stock  #
###################################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Integer I,J

Raz[M:SCR] : Transmask [M:SCS1] To [M:SCR]  # Issue 25606_Transmask [M:SCR] = [M:SCS1]
If [M:SCS1]STOFCY="" | [M:SCS1]FCYDES=""
    Call ERREUR(mess(215,193,1)) From GESECRAN
    FIN=1
    Return
Endif

If [M:SCS1]BETFCYCOD<>1 | [F:SRT]CHGEMPCOD<>2
   Grizo [M:SCR]25
Endif

If [M:SCS1]BETFCYCOD=5
   If dim([M:SCR]WRHSTR)>0
      Grizo [M:SCR]WRHSTR, WRHEND
   Endif
Endif

Affzo [M:SCR]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

[M:SCS1] = [M:SCR]

If find([M:SCS1]BETFCYCOD,1,2,4)            # interne , inter-sites , transfert sous-traitant
   If dim([M:SCS1]WRHSEL)>0
      If [M:SCR]WRHSTR = [M:SCR]WRHEND
         [M:SCS1]WRHSEL = [M:SCR]WRHSTR
      Else
         [M:SCS1]WRHSEL = ""
      Endif
      Affzo [M:SCS1]WRHSEL
   Endif
Endif
If [M:SCS1]BETFCYCOD=1                      # interne
   If dim([M:SCS1]LOCSEL)>0
      If [M:SCR]LOCSTR = [M:SCR]LOCEND
         Read [STC]STC0=[M:SCR]STOFCY;[M:SCR]LOCSTR
         If !fstat
            [M:SCS1]LOCSEL = [M:SCR]LOCSTR
         Else
            [M:SCS1]LOCSEL = ""
         Endif
      Else
         [M:SCS1]LOCSEL = ""
      Endif
      Affzo [M:SCS1]LOCSEL
   Endif
#                                           # hcb x3-67989 deb
   If dim([M:SCS1]LPNSEL)>0
      If [M:SCR]LPNSTR  = [M:SCR]LPNEND
         [M:SCS1]LPNSEL = [M:SCR]LPNSTR
      Else
         [M:SCS1]LPNSEL = ""
      Endif
      Affzo [M:SCS1]LPNSEL
   Endif
#                                           # hcb x3-67989 end

Endif

Affzo [M:SCS1]ITMREFSEL

FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return


Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
    Read [ITF]ITF0 = VALEUR;[M:SCS1]STOFCY
    If !fstat
        Read [ITFD]ITF0 = VALEUR;[M:SCS1]FCYDES
    Endif
    If fstat
        mkstat = 2
    Endif
    If !mkstat
        If dim([M:SCR]SERNUMSTR)>0
            If [F:ITM]SERMGTCOD>1
                Actzo [M:SCR]SERNUMSTR,SERNUMEND
            Else
                Effzo [M:SCR]SERNUMSTR,SERNUMEND
                Diszo [M:SCR]SERNUMSTR,SERNUMEND
            Endif
        Endif

        #If [F:ITM]LOTMGTCOD>1
        #    Actzo [M:SCR]LOTSTR,LOTEND
        #Else
        #    Effzo [M:SCR]LOTSTR,LOTEND
        #    Diszo [M:SCR]LOTSTR,LOTEND
        #Endif
        If [F:ITM]LOTMGTCOD<=1
            If dim([M:SCR]LOTSTR)>0
                Effzo [M:SCR]LOTSTR,LOTEND
                Diszo [M:SCR]LOTSTR,LOTEND
            Endif
            If dim([M:SCR]SLOSTR)>0
                Effzo [M:SCR]SLOSTR,SLOEND
                Diszo [M:SCR]SLOSTR,SLOEND
            Endif
        Elsif [F:ITM]LOTMGTCOD=4
            If dim([M:SCR]LOTSTR)>0
                Actzo [M:SCR]LOTSTR,LOTEND
            Endif
            If dim([M:SCR]SLOSTR)>0
                Actzo [M:SCR]SLOSTR,SLOEND
            Endif
        Else
            If dim([M:SCR]LOTSTR)>0
                Actzo [M:SCR]LOTSTR,LOTEND
            Endif
            If dim([M:SCR]SLOSTR)>0
                Effzo [M:SCR]SLOSTR,SLOEND
                Diszo [M:SCR]SLOSTR,SLOEND
            Endif
        Endif

        If dim([M:SCR]LOCSTR)>0
            If [F:ITF]LOCMGTCOD=2
                Actzo [M:SCR]LOCSTR,LOCEND
            Else
                Effzo [M:SCR]LOCSTR,LOCEND
                Diszo [M:SCR]LOCSTR,LOCEND
            Endif
        Endif
        Affzo [M:SCR]20
    Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 10/09/2003 18:52:09 (CCC)
##########################################################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOEF

    If find(VALEUR,[M:SCR]UOM)
        mkstat=2
        End
    Endif

    Call CTLUOM ([M:SCR]ITMREFSEL,3,"", VALEUR,LCOEF, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif


End


