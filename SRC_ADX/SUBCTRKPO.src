##JOJAC - 2016-06-02 - REQ114309 US215 - START
$ACTION
#If GUSER = 'JOJAC' : Infbox 'KPO'+ACTION : Endif
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "LIENS"    : Gosub LIENS
  When "CREATION" : Gosub CREATION
  When "MODIF"    : Gosub MODIF
  When "ANNULE"   : Gosub ANNULE
  When "STYLE"    : Gosub STYLE
  When "VERIF_CRE": Gosub VERIF_CRE # Issue 105418 US08
  When "VERIF_MOD": Gosub VERIF_MOD # Issue 105418 US08
Endcase
Return

$VERIF_CRE
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KPO_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - START
Gosub VERIF
Return

$VERIF_MOD
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KPO_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - START
Gosub VERIF
Return

$VERIF
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KPO_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - START
# Issue 105418 US08
If dim([L]ACTXPCTR)>0
  If [L]ACTXPCTR>0
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#    Filter [F:XPL] Where [F:XPL]REFNUM=[F:CTR]REFNUM & [F:XPL]CTRNUM=[F:CTR]CTRNUM & [F:XPL]CTRDAT>=[M:CTR0]CTRDAT
#&   Order By [F:XPL]CTRDAT Desc
    Filter [F:XPL] Where [F:XPL]REFNUM=[F:HRCTR]REFNUM & [F:XPL]CTRNUM=[F:HRCTR]CTRNUM & [F:XPL]CTRDAT>=[M:CTR0]CTRDAT
&   Order By [F:XPL]CTRDAT Desc
##JOJAC - 2016-06-02 - REQ114309 US215 - END
    Read [F:XPL] First
    If !fstat
      #There is allready a historic record of this contract in the date $1$. Please enter a greater date.
      GMESSAGE = func AFNC.MES1(mess(60,11561,1),num$([F:XPL]CTRDAT))
      OK       = 0
      Return
    Endif
    Filter [F:XPL]
  Endif
Endif
Return

