$OUVRE
#JOJAC - 2016-06-09 - REQ114309 US215 - START
# Issue 110164 - 2016-01-15 by BRBAN : Needed to KAO too
#If func AFNC.ACTIV("KPOAO")
#If !func DIVPAYE.IS_KPO_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - START
# Issue 110164 - 2016-01-15 by BRBAN : Needed to KAO too
  If clalev([F:CTRPO])=0 : Local File EMPLOCTRPOR [CTRPO] : Endif
  If clalev([F:IDPOR])=0 : Local File EMPLOIDPOR  [IDPOR] : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - START
#Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - END
Return
######################################################################################
######################################################################################
$LIENS
# Issue 110164 - 2016-01-15 by BRBAN : Needed to KAO too
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KPOAO")
If func DIVPAYE.IS_KPO_LEG(GCURLEG) | func DIVPAYE.IS_KAO_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  Read [F:CTRPO]CTRPO0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
  If !fstat
    [M:CTR0] = [F:CTRPO]
    [M:CTR5] = [F:CTRPO]
  Endif
Endif

# Issue 105418 - 2016-04-26 by BRBAN : Need to hide the field NUMCCP if PORMI is on
If func AFNC.ACTIV("PORMI")>0
  If dim([M:CTR2]NUMCCP)>0
    Chgfmt [M:CTR2]NUMCCP With "-K:20"
  Endif
Endif
Return
######################################################################################
######################################################################################
$CREATION
# Issue 110164 - 2016-01-15 by BRBAN : Needed to KAO too
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KPOAO")
If func DIVPAYE.IS_KPO_LEG(GCURLEG) | func DIVPAYE.IS_KAO_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  Gosub WRITE_KPO
Endif

Return
######################################################################################
######################################################################################
$MODIF
# Issue 110164 - 2016-01-15 by BRBAN : Needed to KAO too
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KPOAO")
If func DIVPAYE.IS_KPO_LEG(GCURLEG) | func DIVPAYE.IS_KAO_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  Gosub WRITE_KPO
Endif
Return
######################################################################################
######################################################################################
$WRITE_KPO
Read [F:CTRPO]CTRPO0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
If !fstat
  [F:CTRPO] = [M:CTR0]
  [F:CTRPO] = [M:CTR5]
  Rewrite [F:CTRPO]
  If fstat : Call FSTA("CTRPO") From GLOCK  : Endif
Else
  [F:CTRPO] = [M:CTR0]
  [F:CTRPO] = [M:CTR5]
  Write [F:CTRPO]
  If fstat : Call FSTA("CTRPO") From GLOCK  : Endif
Endif
Return
######################################################################################
######################################################################################
$ANNULE
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KPOAO")
If func DIVPAYE.IS_KPO_LEG(GCURLEG) | func DIVPAYE.IS_KAO_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  Delete [F:CTRPO] Where [F:CTRPO]REFNUM = [M:CTR0]REFNUM &  [F:CTRPO]CTRNUM=[M:CTR0]CTRNUM &  [F:CTRPO]CTRDAT=[M:CTR0]CTRDAT
  If fstat : Call FSTA("CTRPO") From GLOCK  : Endif
Endif

Return
######################################################################################
######################################################################################
$MAJ_EMPLOID
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KPO") & GOK<>0
If func DIVPAYE.IS_KPO_LEG(GCURLEG) & GOK<>0
#JASMI - 2016-06-02 - REQ 114309 - END
  If clalev([F:IDPOR])=0 : Local File EMPLOIDPOR [IDPO] : Endif
  If clalev([F:AD])=0    : Local File EMPLOAD    [AD]   : Endif

  If [F:CTR1]ETRFCY<>[F:ID]FCY
    Read [F:IDPOR]IDPOR0=[F:ID]REFNUM
    If !fstat
      Call AFF_SRCRET([F:ID]SITFAM,[F:CTR1]ETRFCY,[F:IDPOR]NBRHLD,[F:IDPOR]SRCRET,[F:AD]FLGHDC,[F:IDPOR]COIPLN) From SUBEMLKPO
      Rewrite [F:IDPOR]
    Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
Subprog CTRL_OCPCOD(VALEUR)
Variable Char    VALEUR()
# Issue 111058 - 2015-10-12 by BRBAN : Field is no longer mandatory
#If VALEUR=''
#  GMESSAGE = mess(1,751,1)
#  mkstat=2
#Endif
End
######################################################################################
######################################################################################
Subprog CTRL_IRCTAPL(VALEUR)
Variable Char VALEUR()
Local Integer MESSERR : [L]MESSERR = 0
Case VALEUR
  When '01','02','03','04'
    If !(find(mid$([M:CTR5]IRCTCOD,1,1),"1","2","4") & !find(mid$([M:CTR5]IRCTCOD,2,1),"1","2","7"))
      [L]MESSERR = 1
    Endif
  When '05'
    If !find(mid$([M:CTR5]IRCTCOD,1,2),"12","17","21","22","27","41","42","47")
      [L]MESSERR = 1
    Endif
  When '06'
    If !find(mid$([M:CTR5]IRCTCOD,1,1),"9")
      [L]MESSERR = 1
    Endif
  When '07'
    If !find(mid$([M:CTR5]IRCTCOD,1,1),"3")
      [L]MESSERR = 1
    Endif
Endcase
If [L]MESSERR = 1
  Call ERREUR(mess(15,11553,1)) From GESECRAN
  mkstat = 2
Endif
End


#JOJAC - 2016-06-02 - REQ114309 US215 - END

