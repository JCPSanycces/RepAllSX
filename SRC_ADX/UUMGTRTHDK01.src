#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGTRTHDK01   Service contracts migration script       HelpDesk module  #
############################################################################
# Issue 112151 - 20151031 by LD : Pb Writing with duplicate key
#              - 20151105 by LD : Pb Writing with duplicate key
# Issue 106947 - 20151103 by LD : Migration of historic folder

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # End issue 106947
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # End issue 106947

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTHDK01") From LECFIC
  Endif

 #Call RAZ_UUMGTRTHDK01(DOSSIER)
  Call MAJ_UUMGTRTHDK01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End
##########################################################################
Subprog MAJ_UUMGTRTHDK01(DOSSIER)
Value Char DOSSIER

# Issue 106947
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# End issue 106947

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(11)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMCONM
Call MIGTABNAME (DOSSIER,"CONTSERV", WNAMCONM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMCONM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",2,ERR) From TRTMIG : #2=En cours

###################

#Local Char WTAB_CON (30) (adxwrb) #Gbn-110408
Local Shortint WCPT_CON

Call ECR_TIME("UUMGTRTHDK01 Service contracts : Update CONTSERV") From DOSSUB
Call ECR_TRACE("UUMGTRTHDK01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Local Char WTAB_CON (30) (adxwrb) #Gbn-110408
Call MIGTABINIT (DOSSIER,"CONTSERV",ERR) From TRTMIG #Gbn-107083

Call ECR_TIME("UUMGTRTHDK01 Service contract Process : Update CONTSERV ...") From DOSSUB

#----- Ouverture des fichiers -----#
If clalev([F:CON])  = 0 : Local File =DOSSIER+".CONTSERV"  [CON]  : Endif   # Fichier X3 "Vide"

If clalev([F:CONM]) = 0 : Local File =DOSSIER+"."+WNAMCONM [CONM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
# Issue 112151
#Local Integer NBMIGKEY : NBMIGKEY=2
Local Integer NBMIGKEY : NBMIGKEY=3
# End issue 112151
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# 100121 : Init GLOCUSATAX pour la valorisation
Local Char WPARAM(GLONADP)
# 100121

# Déclaration des variables communes de travail
Local Integer I, J

#déclaration des variables locales de travail
Local Char     WSITE : Raz WSITE

Gosub OUVRE_HDK From UUMGTRTHDK00

If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
Call MIGGETKEY (DOSSIER,"UUMGTRTHDK01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
# Issue 112151
#STOP=val(TABMIGKEY(2)) #Gbn-106946
STOP=val(TABMIGKEY(3))
# End issue 112151

# Issue 112151
Filter [CONM] Order By Key CLE=SALFCY;CONNUM
# End issue 112151

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTHDK01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_HDK01
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:CONM]SALFCY=TABMIGKEY(1) & [F:CONM]CONNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:CONM]SALFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [CON]
GOK = 1

#Gbn-106946
# Issue 112151
#For [CONM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
For [CONM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
# End issue 112151
  #rupture par site,contrat
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
    FLUX="UUMGTRTHDK01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  Gosub RAZ_CON #101380
  [F:CON] = [F:CONM]

  If WSITE<>[F:CONM]SALFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:CONM]SALFCY) From TRTX3CPT
      Call GLOBVAR([F:CONM]SALFCY) From WWGLOBVEN
      WSITE=[F:CONM]SALFCY
      #108649.so
      #If GACTKUS
      #    Call PARAM([F:CONM]SALFCY,"USATAX",WPARAM) From ADOVAL
      #    GLOCUSATAX=val(WPARAM)
      #    If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
      #Else
      #    Raz GLOCUSATAX
      #Endif
      #108649.eo
  Endif

  If dim([F:CON]DIE)>0 & [F:CON]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
          [F:CON]DIE(I-1)=GDIE(I)
      Next I
  Endif

  #101380 SST Line Level Override .sn
  # Source folder version before V8 [AKIRA]
  If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
    Gosub MAJ80_CON
    If GOK<1 : Break : Endif
  Endif
  #101380 SST Line Level Override .en

  # --- alimentation des champs et écriture enreg
  # Issue 106947
#  If NEWMOTEUR
#      Gosub CON_STK : # pour stocker ref
#      WriteB [F:CON]
#  Else
#      Write [F:CON]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CONTSERV, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CON_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File CONTSERV(CONNUM)"-[F:CON]CONNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub CON_STK : # pour stocker ref
  WriteB [F:CON]
  If fstat
    Call ECR_TRACE("File CONTSERV, Error ="-num$(fstat),1) From GESECRAN
    Gosub CON_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # End Issue 106947

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:CONM]SALFCY
    TABMIGKEY(2) = [F:CONM]CONNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 106947
  #If NEWMOTEUR & adxwrb>1
  # End issue 106947
    Flush [F:CON]
    If fstat
        Call ECR_TRACE("File CONTSERV, Error ="-num$(fstat),1) From GESECRAN
        Gosub CON_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  # Issue 106947
  #Endif
  # End issue 106947

  # Stocker les valeurs de ACLE1/STOP dans la table AMIGKEY.
  If STOP
      # Issue 112151
      #TABMIGKEY(1)=num$(STOP)
      TABMIGKEY(3)=num$(STOP)
      # End issue 112151
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTHDK01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTHDK01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_HDK01
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN

# Issue 112151
Filter [CONM]
# End issue 112151

Close Local File [CON]
Close Local File [CONM]

Call ECR_TIME("UUMGTRTHDK01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"CONTSERV",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTHDK01") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGTRTHDK01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(11)<>2 : # N= no module
  End
Endif

#Gbn-101445
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTHDK01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMCONM
Call MIGTABNAME (DOSSIER,"CONTSERV", WNAMCONM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMCONM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"CONTSERV",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTHDK01",ERR) From TRTMIG

End
##############################################################################################
$CON_STK
Call STK (WTAB_CON,WCPT_CON,[F:CON]CONNUM) From TRTMIG
Return

##############################################################################################
#################################################
$CON_ERRTRA
Call ERRTRA (WTAB_CON,WCPT_CON,"File CONTSERV(CONNUM)=") From TRTMIG
Return

########################################################################
$RAZ_CON
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:CON]CPY,GSOC)) #108649.n
      For I=0 To dim([F:CON]INVDTA)-1
          If [F:CON]INVDTA(I)<>0
              Raz [F:CON]SFISSTCOD(I)
          Endif
      Next
  Endif
Return

########################################################################
# Initialization of the new fields for V8 [AKIRA]
########################################################################
$MAJ80_CON
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:CON]CPY,GSOC)) #108649.n
      For I=0 To dim([F:CON]INVDTA)-1
          If [F:CON]INVDTA(I)<>0
              Local Integer WJ
              WJ=find([F:CON]INVDTA(I),WSFINUM(0..WNBSFI))
              If WJ>0 : [F:CON]SFISSTCOD(I)=WSFISSTCOD(WJ-1) : Endif
          Endif
      Next
  Endif
Return


########################################################################
$TRT_SQL

#2- alimenter la nouvelle colonne si vide
#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [CONM]
GOK = 1

Gosub TRT_SQL1

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMCONM+" SET SALFCY_0="
REQSQL(1)="(SELECT CON.SALFCY_0 FROM"-DOSSIER+"."+WNAMCONM+" CON Where CON.CONNUM_0="+WNAMCONM+".CONNUM_0)"
REQSQL(2)=" WHERE "+WNAMCONM+".SALFCY_0<>(SELECT CON.SALFCY_0 From"-DOSSIER+"."+WNAMCONM+" CON Where CON.CONNUM_0="+WNAMCONM+".CONNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# End issue 106947
Call MAJ_UUMGTRTHDK01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTHDK01(APPLI)
End

