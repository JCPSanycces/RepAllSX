#<AdxTL>@(#)6.0.0.0 $Revision$
##################################################################
#  Actions utilisées pour gérer les schémas de saisie comptable  #
##################################################################
#
# CBO   02.11.17 X3-63656  Error when CCE dimension > 9 (and trt reorganized)
#
##################################################################
# Avant_zone
##################################################################

Subprog FLDAVTCAR(VALEUR, CODZON)
Variable Char VALEUR()
Value    Char CODZON()

Local Integer TYD

  TYD = 1
  Goto FLDAVT

Subprog FLDAVTINT(VALEUR, CODZON)
Variable Integer VALEUR
Value    Char    CODZON()

Local Integer TYD

  TYD = 2
  Goto FLDAVT

Subprog FLDAVTDCB(VALEUR, CODZON)
Variable Decimal VALEUR
Value    Char    CODZON()

Local Integer TYD

  TYD = 3
  Goto FLDAVT

Subprog FLDAVTDAT(VALEUR, CODZON)
Variable Date VALEUR
Value    Char CODZON()

Local Integer TYD

  TYD = 4

$FLDAVT

  If mkstat
    End
  Endif

  Gosub SETFLDMSK
  Local Char WLEFTPART(10), WRIGHTPART(GLONDIE) # Issue X3-63656

  # Case type ex CCE2.MAR or CCE15.PRO
  I = instr(1, CODZON, ".")
  If I
    # Issue X3-63656
    WRIGHTPART = right$(CODZON, I + 1)
    If WRIGHTPART = ""
      End
    Endif

    WLEFTPART = left$(CODZON, I - 2)
    Gosub TRT_CCE_GT9
    WZON += "." + WRIGHTPART

# WZON=left$(CODZON,I-2)+"."+right$(CODZON,I+1)
 # End Issue X3-63656
  Else
    WZON = CODZON
  Endif

  Read [GDD]GDD0 = [F:GDE]DIA; WZON
  If fstat
    End
  Endif

  # Si la zone est affichée, on réeffectue l'init
  If [F:GDD]DAC = 2 and [F:GDD]DEFVAL <> ""
    Local Integer ERR
    Onerrgo ERREVAL
    VALEUR = evalue([F:GDD]DEFVAL)
    Onerrgo
    If ERR
      Call ERREUR(mess(65, 106, 1) + "\" + vireblc(format$("KT:80X", [F:GDD]DEFVAL), 2) + "\" + errmes$(ERR) + "\" + errm)
&     From GESECRAN
      # Erreur en évaluation de la formule
    Endif
  Endif

  # Si la zone est affichée, on fait le contrôle et on la saisit quand même si c'est incorrect
  If [F:GDD]DAC = 2

    I = instr(1, CODZON, ".")
    If I
      WZON = left$(CODZON, I - 1)
    Else
      WZON = CODZON
    Endif

    Case TYD:
      When 1 :  Call CTLCAR("C", WZON, VALEUR, NOMMSK)        # Appel l'étiquette de CONTROLE
      When 2 :  Call CTLINT("C", WZON, VALEUR, NOMMSK)        # Appel l'étiquette de CONTROLE
      When 3 :  Call CTLDCB("C", WZON, VALEUR, NOMMSK)        # Appel l'étiquette de CONTROLE
      When 4 :  Call CTLDAT("C", WZON, VALEUR, NOMMSK)        # Appel l'étiquette de CONTROLE
    Endcase

    If [F:GDE]FLGLOT <> 2

      Case WZON
      When "FCY", "CUR", "TYP"
        If mkstat
          mkstat = 0
          End
        Endif
        Call CTLCAR("AM", WZON, VALEUR, NOMMSK)      # Appel l'étiquette de APRES_MODIF

      When "NUM", "JOU", "ACC", "BPR"
        If mkstat
          mkstat = 0
          End
        Endif
        Call CTLCAR("AP", WZON, VALEUR, NOMMSK)       # Appel l'étiquette de APRES_ZONE

      When "ACCDAT"
        If mkstat
          mkstat = 0
          End
        Endif
        Call CTLDAT("AP", WZON, VALEUR, NOMMSK)       # Appel l'étiquette de APRES_ZONE

      When Default
      Endcase

    Else

      Case WZON

      When "NEW", "ACCDAT", "ACC", "BPR"              # Appel l'étiquette de CONTROLE & d'APRES_ZONE

        Case TYD:
        When 1
          If mkstat
            mkstat = 0
            End
          Endif
          Call CTLCAR("AP", WZON, VALEUR, NOMMSK)
        When 2
          If mkstat
            mkstat = 0
            End
          Endif
          Call CTLINT("AP", WZON, VALEUR, NOMMSK)
        When 3
          If mkstat
            mkstat = 0
            End
          Endif
          Call CTLDCB("AP", WZON, VALEUR, NOMMSK)
        When 4
          If mkstat
            mkstat = 0
            End
          Endif
          Call CTLDAT("AP", WZON, VALEUR, NOMMSK)
        Endcase

      When Default
      Endcase
    Endif

    If mkstat
      mkstat = 0
    Else
      mkstat = 2
    Endif
  Endif

End

Subprog CTLCAR(ACT, ETQ, VLR, MSK)
Value Char    ACT()      # Abréviation de l'action
Value Char    ETQ()      # Nom de l'étiquette
Value Char    VLR()      # Valeur du paramètre
Value Char    MSK()      # Nom du masque

  Goto CTL

Subprog CTLINT(ACT, ETQ ,VLR, MSK)
Value Char    ACT()      # Abréviation de l'action
Value Char    ETQ()      # Nom de l'étiquette
Value Integer VLR()      # Valeur du paramètre
Value Char    MSK()      # Nom du masque

  Goto CTL

Subprog CTLDCB(ACT, ETQ, VLR, MSK)
Value Char    ACT()      # Abréviation de l'action
Value Char    ETQ()      # Nom de l'étiquette
Value Decimal VLR()      # Valeur du paramètre
Value Char    MSK()      # Nom du masque

  Goto CTL

Subprog CTLDAT(ACT, ETQ, VLR, MSK)
Value Char    ACT()      # Abréviation de l'action
Value Char    ETQ()      # Nom de l'étiquette
Value Date    VLR()      # Valeur du paramètre
Value Char    MSK()      # Nom du masque

  Goto CTL

$CTL

Local Integer I, ERR

  For I=1 To 9
    Raz ERR
    Onerrgo RIEN
    Call =ACT + "_" + ETQ With VLR From="W" + num$(I) + MSK
    Onerrgo
    If ERR = 0
      Break
    Endif
  Next
End

$RIEN
  ERR = errn
Resume

##################################################################
# Init
##################################################################

Subprog FLDDEFCAR(VALEUR, CODZON)
Variable Char VALEUR()
Value    Char CODZON()

  Goto FLDDEF

Subprog FLDDEFINT(VALEUR, CODZON)
Variable Integer VALEUR
Value    Char    CODZON()

  Goto FLDDEF

Subprog FLDDEFDCB(VALEUR, CODZON)
Variable Decimal VALEUR
Value    Char    CODZON()

  Goto FLDDEF

Subprog FLDDEFDAT(VALEUR, CODZON)
Variable Date VALEUR
Value    Char CODZON()

$FLDDEF

Local Char WLEFTPART(10), WRIGHTPART(GLONDIE) # Issue X3-63656

  # Case type ex CCE2.MAR or CCE15.PRO
  I = instr(1, CODZON, ".")
  If I
    # Issue X3-63656
    WRIGHTPART = right$(CODZON, I + 1)
    If WRIGHTPART = ""
      End
    Endif

    WLEFTPART = left$(CODZON, I - 2)
    Gosub TRT_CCE_GT9
    WZON += "." + WRIGHTPART

# WZON=left$(CODZON,I-2)+"."+right$(CODZON,I+1)
 # End Issue X3-63656
  Else
    WZON = CODZON
  Endif

  Read [GDD]GDD0 = [F:GDE]DIA; WZON
  If fstat = 0 and [F:GDD]DEFVAL <> ""
    Local Integer ERR
    Onerrgo ERREVAL
    VALEUR = evalue([F:GDD]DEFVAL)
    Onerrgo
    If ERR
      Call ERREUR(mess(65,106,1) + "\" + vireblc(format$("KT:80X", [F:GDD]DEFVAL), 2) + "\" + errmes$(ERR)+"\"+errm)
&     From GESECRAN
# Erreur en évaluation de la formule
    Endif
  Endif

End

$ERREVAL
  ERR = errn
Resume

##################################################################
# Contrôle
##################################################################

Subprog FLDCTLCAR(VALEUR, CODZON)
Variable Char VALEUR()
Value    Char CODZON()

Local Integer TYD

  TYD = 1
  Goto FLDCTL

Subprog FLDCTLINT(VALEUR, CODZON)
Variable Integer VALEUR
Value    Char    CODZON()

Local Integer TYD

  TYD = 2
  Goto FLDCTL

Subprog FLDCTLDCB(VALEUR, CODZON)
Variable Decimal VALEUR
Value    Char    CODZON()

Local Integer TYD

  TYD = 3
  Goto FLDCTL

Subprog FLDCTLDAT(VALEUR, CODZON)
Variable Date VALEUR
Value    Char CODZON()

Local Integer TYD

  TYD = 4

$FLDCTL

##Gosub SETFLDMSK
Local Char WLEFTPART(10), WRIGHTPART(GLONDIE) # Issue X3-63656

  # Case type ex CCE2.MAR or CCE15.PRO
  I = instr(1, CODZON, ".")
  If I
    # Issue X3-63656
    WRIGHTPART = right$(CODZON, I + 1)
    If WRIGHTPART = ""
      End
    Endif

    # Issue X3-63656
    WLEFTPART = left$(CODZON, I - 2)
    Gosub TRT_CCE_GT9
    WZON += "." + WRIGHTPART

# WZON=left$(CODZON,I-2)+"."+right$(CODZON,I+1)
# End Issue X3-63656
  Else
    WZON=CODZON
  Endif

  Read [GDD]GDD0 = [F:GDE]DIA; WZON
  If fstat = 0 and [F:GDD]CTL <> ""
    Case TYD
      When 1 :  Call CONTACL_CHAR([F:GDD]CTL, [F:GDD]DEFVAL, VALEUR) From SUBACL
      When 2 :  Call CONTACL_LIB([F:GDD]CTL, [F:GDD]DEFVAL, VALEUR) From SUBACL
      When 3 :  Call CONTACL_NUM([F:GDD]CTL, [F:GDD]DEFVAL, VALEUR) From SUBACL
      When 4 :  Call CONTACL_DAT([F:GDD]CTL, [F:GDD]DEFVAL, VALEUR) From SUBACL
    Endcase
  Endif

End

$SETFLDMSK

Local Char MSKDEF(4), NOMMSK(30), WZON(30)
# Au niveau des axes, CODZON = "CCEx.YYY"
#   => x = 1 à 20 : utile pour les étiquettes D,AVT,C de SUBGA0
#   FLD de GDIAENTRYD  = "CCE.YYY"
#   Champ sous les écrans de pièces = CCEx

  I = instr(1, CODZON, ".")
  If I
    WZON=left$(CODZON, I - 1)
  Else
    WZON = CODZON
  Endif
  If [F:GDE]FLGLOT <> 2
    For K=0 To 2
      If evalue("dim([M:HAE" + num$(K) + "]" + WZON + ") > 0")
        Case K
        When 0
          MSKDEF = "HAE0"
          NOMMSK = "WMAC0" + [F:GDE]DIA
        When 1
          MSKDEF = "HAE1"
          NOMMSK = "WMAC1" + [F:GDE]DIA
        When 2
          MSKDEF = "HAE2"
          NOMMSK = "WMAC2" + [F:GDE]DIA
        Endcase
        Break
      Endif
    Next K
  Else
    MSKDEF = "HAE1"
  Endif

Return

# Issue X3-63656
# Special eExtracts CCE code when dim is > 9
$TRT_CCE_GT9

  If left$(WLEFTPART, 3) = "CCE" and  len(WLEFTPART) > 3
    WZON = left$(WLEFTPART, 3)
  Else
    WZON = WLEFTPART
  Endif

Return

