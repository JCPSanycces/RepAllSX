#**
#* This method computes and returns the average of two values
#*  
#* @public
#* 
#* @param VAL1 Value 1
#* @param VAL2 Value 2
#*
#* @return the average
#* @since Version 6.2
#* 
#*!
Funprog AVERAGE(VAL1,VAL2)
Value Integer VAL1 , VAL2
Local Integer A
A = ( VAL1 + VAL2 ) / 2
End A










#**
#* Display a message box !
#*
#* @param MESSAGE test
#*!
Subprog DISPLAY(MESSAGE)
Value Char MESSAGE

If MESSAGE = ""
MESSAGE = "# empty #"
Endif

Infbox MESSAGE

End















