#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation CHORUS JUCON 01/07/2018                                    #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK, WOKK : WOK     = [V]CST_AOK
  Local Integer WSTATUS   : WSTATUS = [V]CST_AOK

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.SIV.SALFCY,WCATACT)

  If WOKK=0
    WSTATUS = [V]CST_AERROR
    WERR = mess(74,100,1)    #Unauthorized Function
  Else
    Case WCATACT
      When 1 :
        Case WPARCOD
          When "CHORUS" : Gosub CHORUS_ISSUE
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
      When 2 :
        Case WPARCOD
          When "CHORUS" : Gosub CHORUS_RECEIPT
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
    Endcase
  Endif

  ARET_VALUE = WSTATUS
Return

################################################################################
$CHORUS_ISSUE
  #####################################
  #       Properties for tags         #
  #####################################
  this.SCHNAM="schemeName='1'"
  this.LISTID="listID='UN/ECE 4461 Subset' listAgencyID='NES' listAgencyName='Northern European Subset' listName='Payment Means'"
  this.CURID ="currencyID='"+this.SIV.CUR+"'"
  #####################################
  #####           HEAD          #######
  #####################################
  Local Char WCODE(20), WREP(20), WLEG(3), WLAN(3), WPROP(25)
  Local Integer WNB: WNB=1

  Local Char NUMDOC(20)
  NUMDOC=this.SIV.NUM

  WREP=right$(this.AINF.NAMCLA,3)
  WLEG=this.SIV.SIVTYP_LEG
  WLAN=this.ACTX.LAN
  Local Char WCPY(5) : WCPY=this.SIV.CPY

  Local Char WSEPDEC(1)

  WSEPDEC="."

  this.SIV.VERSION="2.1"

  Local Decimal RETEN, ANTIC, RETENF
  Local Integer K,OKTVT, OKTVB, DTARET(1..)

  If WLEG=""
    Local File COMPANY [CPY]
    Read [CPY]CPY0=this.SIV.CPY
    If fstat=[V]CST_AOK
      WLEG=[F:CPY]LEG
    Endif
    LogicClose File [CPY]
  Endif

  For I=1 To maxtab(this.SIV.C_PAM)
    ANTIC+=this.SIV.C_PAM(I).INSATI
  Next

  Local File TABVAT [TVT]
  For I=1 To maxtab(this.SIV.SVV)
    Read [TVT]TVT0=this.SIV.SVV(I).VAT;WLEG
    If fstat<>[V]CST_AOK
      Read [TVT]TVT0=this.SIV.SVV(I).VAT;""
      If fstat=[V]CST_AOK : OKTVT=1 :Endif
    Else OKTVT=1
    Endif
    If OKTVT=1
      If [F:TVT]VATTYP=3
        K+=1
        DTARET(K)=I
        If this.SIV.SVV(I).CUR="EUR"
          RETEN+=abs(this.SIV.SVV(I).AMTTAX)
        Else
          RETEN+=abs(this.SIV.SV(I).AMTTAX)*this.SIV.SIH(WNB).C_RATCOL(1).RATMLT
        Endif
      Endif
    Endif
  Next
  LogicClose File [TVT]

  Local File SFOOTINV [SFI]
  For I=1 To maxtab(this.SIV.SVF)
    Read [SFI]SFI0= this.SIV.SVF(I).DTA
    If fstat=[V]CST_AOK
      If this.SIV.SIH(WNB).VAC<>[F:SFI]VACITM
        Local File TABVACBPR [TVB]
        Read [TVB]TVB0=[F:SFI]VACITM;WLEG
        If fstat<>[V]CST_AOK
          Read [TVB]TVB0=[F:SFI]VACITM;""
          If fstat=[V]CST_AOK : OKTVB=1 :Endif
        Else OKTVB=1
        Endif
        If OKTVB=1
          Local File TABVAT [TVT]
          Read [TVT]TVT0=[F:TVB]VAT;WLEG
          If fstat=[V]CST_AOK and [F:TVT]VATTYP=3: OKTVB=2
          Else
            Read [TVT]TVT0=[F:TVB]VAT;""
            If fstat=[V]CST_AOK and [F:TVT]VATTYP=3: OKTVB=2: Endif
          Endif
          If OKTVB=2
            If this.SIV.SVV(I).CUR="EUR"
              RETENF+=abs(this.SIV.SVF(I).DTAAMT)
            Else
              RETENF+=abs(this.SIV.SVF(I).DTAAMT)*this.SIV.SIH(WNB).C_RATCOL(1).RATMLT
            Endif
          Endif
          LogicClose File [TVT]
        Endif
        LogicClose File [TVB]
      Endif
    Endif
  Next
  LogicClose File [SFI]

  If RETEN <> 0 : Raz RETENF: Endif     # If witholding is indicated like a tax, we don´t have to use retention in the element foot

  #########################
  # Filling INVTYP values #
  #########################
  Local File ASHWPAR [ASWP]   # Transcoding INVTYP (in STD table 220)
  Filter [ASWP] Where CODREP=WREP and CODLNK="CHINVTYP"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB
    WTYP=num$(this.SIV.INVTYP)
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    If WNODE<>"":
      this.SIV.CHINVTYP= left$(WNODE,3)
    Else
      Case this.SIV.INVTYP
        When 1,3,5:  this.SIV.CHINVTYP="380"
        When 2,4  :  this.SIV.CHINVTYP="381"
      Endcase
    Endif
  Endif
  LogicClose File [ASWP]


  ###############################
  # Filling Seller Party values #
  ###############################
  Local Char WFFCY(5)
  Local Char WCPY(5)

  Local File FACILITY [FCY]
  Read [FCY]FCY0=this.SIV.SALFCY
  If fstat=[V]CST_AOK
    WFFCY=[F:FCY]FINRSPFCY
    WCPY=[F:FCY]LEGCPY
  Endif
  If WFFCY<>""
    WCODE=func TRTFUNEDI.INV_EDICODE_FCY(WFFCY,WPARCOD)
    WSEQ = fmet this.SIV.ADDLINE('CPYDES',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.CPYDES.ADDLINE('C_SEL',[V]CST_ALASTPOS)
    this.SIV.CPYDES.C_SEL.IDSELLER=func TRTFUNEDI.INV_EDICODE_SE(WFFCY,WCPY,WPARCOD,this.SIV.BPCORD)
  Endif
  LogicClose File [FCY]

  Local File COMPANY [CPY]
  Read [CPY]CPY0=WCPY
  If fstat=[V]CST_AOK
    WSEQ = fmet this.SIV.CPYDES.ADDLINE('C_NAM',[V]CST_ALASTPOS)
    this.SIV.CPYDES.C_NAM(WSEQ).CPYNAME=[F:CPY]CPYNAM

    WSEQ = fmet this.SIV.CPYDES.ADDLINE('C_LEG',[V]CST_ALASTPOS)
    If func AFNC.ACTIV("DAS")= 2
      Local File DADCPY [DCP]
      Read [DCP]DCP0=WCPY
      If fstat=[V]CST_AOK
        If [F:DCP]DADCPYNAM<>""
          this.SIV.CPYDES.C_LEG(WSEQ).CPYNAME1=[F:DCP]DADCPYNAM
        Else
          this.SIV.CPYDES.C_LEG(WSEQ).CPYNAME1=[F:CPY]CPYNAM
        Endif
        this.SIV.CPYDES.C_LEG(WSEQ).CPYADD=[F:DCP]STREET
        this.SIV.CPYDES.C_LEG(WSEQ).CPYCTY=[F:DCP]CTYNAM
        this.SIV.CPYDES.C_LEG(WSEQ).CPYPOSCOD=[F:DCP]DADPOSCOD
        this.SIV.CPYDES.C_LEG(WSEQ).CPYCRY="FR"
        LogicClose File [DCP]
      Endif
    Else
      this.SIV.CPYDES.C_LEG(WSEQ).CPYNAME1=this.SIV.CPYDES.C_NAM(WSEQ).CPYNAME
      Local File BPADDRESS [BPA]
      Read [BPA]BPA0=2;WCPY;[F:CPY]BPAADD
      If fstat=[V]CST_AOK
        this.SIV.CPYDES.C_LEG(WSEQ).CPYADD=[F:BPA]BPAADDLIG(0)
        this.SIV.CPYDES.C_LEG(WSEQ).CPYCTY=[F:BPA]CTY
        this.SIV.CPYDES.C_LEG(WSEQ).CPYPOSCOD=[F:BPA]POSCOD
        this.SIV.CPYDES.C_LEG(WSEQ).CPYCRY=[F:BPA]CRY
      Endif
      LogicClose File [BPA]
    Endif

    Local File CONTACT [CNT]
    Filter [CNT] Where BPATYP=2 and BPANUM=WCPY
    Read [CNT]CNT0 First
    If fstat=[V]CST_AOK
      WSEQ = fmet this.SIV.ADDLINE('C_ACC',[V]CST_ALASTPOS)
      this.SIV.C_ACC(WSEQ).CPYTEL =[F:CNT]TEL
      this.SIV.C_ACC(WSEQ).CPYFAX =[F:CNT]FAX
      this.SIV.C_ACC(WSEQ).CPYMAIL=[F:CNT]WEB
    Endif
  Endif
  LogicClose File [CPY]

  ###############################
  # Filling Buyer Party values  #
  ###############################
  Local File EDIBPRPAR [EBP]
  Read [EBP]EBP0=1;this.SIV.BPCINV;this.SIV.BPAADD;WPARCOD
  If fstat=[V]CST_AOK
    WSEQ = fmet this.SIV.ADDLINE('BPCDES',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.BPCDES.ADDLINE('C_NAM',[V]CST_ALASTPOS)
    this.SIV.BPCDES.C_NAM(WSEQ).IDBUYER=[F:EBP]EXCEDICOD
  Endif
  LogicClose File [EBP]

  Local File BPADDRESS [BPA]
  Read [BPA]BPA0=1;this.SIV.BPCORD;this.SIV.BPAADD
  If fstat=[V]CST_AOK
    this.SIV.BPCDES.BPCADD=[F:BPA]BPAADDLIG(0)
    this.SIV.BPCDES.BPCCTY=[F:BPA]CTY
    this.SIV.BPCDES.BPCPOSCOD=[F:BPA]POSCOD
    this.SIV.BPCDES.BPCCRY=[F:BPA]CRY
  Endif
  LogicClose File [BPA]

  #####################################
  # Filling Delivery location values  #
  #####################################
  WSEQ = fmet this.SIV.ADDLINE('BPDDES',[V]CST_ALASTPOS)
  If this.SIV.BPDADD<>null
    this.SIV.BPDDES.BPDADD=this.SIV.BPDADD
    this.SIV.BPDDES.BPDADDLOC=this.SIV.BPDADD
  Else
    this.SIV.BPDDES.BPDADD=this.SIV.BPAADD
    this.SIV.BPDDES.BPDADDLOC=this.SIV.BPAADD
  Endif

  If this.SIV.BPDDES.BPDADD=""
    this.SIV.BPDDES.BPDADD="1"
  Endif
  If this.SIV.BPDDES.BPDADDLOC=""
    this.SIV.BPDDES.BPDADDLOC=this.SIV.BPDDES.BPDADD
  Endif

  If this.SIV.C_BPDNAM<>null
    this.SIV.BPDDES.BPDADDNAM=this.SIV.C_BPDNAM(1).BPDNAM
  Endif

  If this.SIV.C_BPDADDLIG<>null
    this.SIV.BPDDES.BPDADDLIG=this.SIV.C_BPDADDLIG(1).BPDADDLIG
  Endif
  this.SIV.BPDDES.BPDCTY=this.SIV.BPDCTY
  this.SIV.BPDDES.BPDPOSCOD=this.SIV.BPDPOSCOD
  this.SIV.BPDDES.BPDCRY=this.SIV.BPDCRY

  ##############################
  # FillingPayments values     #
  ##############################
  Local Char WDUDPAM (5)(1..), WDUDDAT (10)(1..)
  Local Integer  WSTA (1..)

  WSTA=func TRTFUNEDI.FACE_OPIT(this.SIV.NUM,WDUDPAM,3)
  WSTA=func TRTFUNEDI.FACE_OPIT(this.SIV.NUM,WDUDDAT,1)

  Local File ASHWPAR [ASWP]   # Transcoding PAM (in STD table 233)

  If WDUDPAM(1)<>"" #only one is used in Chorus
    WSEQ = fmet this.SIV.ADDLINE('C_DUD',[V]CST_ALASTPOS)
    this.SIV.C_DUD(WSEQ).PAYCOD   =WDUDPAM(1) #only one is used in Chorus
    this.SIV.C_DUD(WSEQ).PAYDUEDAT=WDUDDAT(1)
    Filter [ASWP] Where CODREP=WREP and CODLNK="PAYCOD"
    Read [ASWP] First
    If fstat=[V]CST_AOK
      Local Char WTYP(20)
      Local Integer WTAB
      WTYP=WDUDPAM(1)
      WTAB=val([F:ASWP]VALEUR)
      this.SIV.C_DUD(WSEQ).PAYCOD=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      If this.SIV.C_DUD(WSEQ).PAYCOD="": this.SIV.C_DUD(WSEQ).PAYCOD="31" : Endif
      Filter [ASWP]
    Endif
    LogicClose File [ASWP]
  Endif

  #################################
  # Filling sales invoice tax     #
  #################################
  Local Integer WTOTTAX
  For I=1 To maxtab(this.SIV.SVV)
    WSEQ = fmet this.SIV.SVV(I).ADDLINE('C_TAX',[V]CST_ALASTPOS)
    WPROP=format$("N:9.2#",this.SIV.SVV(I).BASTAX)
    this.SIV.SVV(I).C_TAX(WSEQ).SVVBASTAX= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:3.2#", this.SIV.SVV(I).VATRAT)
    this.SIV.SVV(I).C_TAX(WSEQ).SVVVATRAT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:9.2#",this.SIV.SVV(I).AMTTAX)
    this.SIV.SVV(I).C_TAX(WSEQ).SVVAMTTAX =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WTOTTAX+=val(this.SIV.SVV(I).C_TAX(WSEQ).SVVAMTTAX)
    WSEQ = fmet this.SIV.SVV(I).ADDLINE('SDES',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.SVV(I).SDES.ADDLINE('SVD',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.SVV(I).SDES.SVD.ADDLINE('SD',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.SVV(I).SDES.SVD.SD.ADDLINE('C_DES',[V]CST_ALASTPOS)
    Case this.SIV.INVTYP
      When 1,3,5:  this.SIV.SVV(I).SDES.SVD.SD.C_DES(WSEQ).VATDES="TVA DEBIT"
      When 2,4  :  this.SIV.SVV(I).SDES.SVD.SD.C_DES(WSEQ).VATDES="TVA ENCAISSEMENT"
    Endcase
  Next

  WSEQ = fmet this.SIV.ADDLINE('C_TOT',[V]CST_ALASTPOS)
  WPROP=format$("N:13.2#",WTOTTAX)
  this.SIV.C_TOT(WSEQ).TOTTAXMNT= func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  #################################
  # Filling sales invoice amounts #
  #################################
  WSEQ = fmet this.SIV.ADDLINE('C_LMT',[V]CST_ALASTPOS)
  WPROP=format$("N:13.2#",this.SIV.SIH(WNB).AMTATI)
  this.SIV.C_LMT(WSEQ).CHAMTATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N:13.2#",this.SIV.SIH(WNB).AMTNOT)
  this.SIV.C_LMT(WSEQ).CHAMTNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N:13.2#",this.SIV.SIH(WNB).AMTATI-RETENF-ANTIC)
  this.SIV.C_LMT(WSEQ).PAYATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  ####################################
  ######           LINES         #####
  ####################################
  Local Integer WNBL
  For I=1 To maxtab(this.SIV.SID)
    WNBL+=1
    this.SIV.SID(I).QTYUN=this.SIV.SID(I).STU
    this.SIV.SID(I).NUMLIN=WNBL
    If this.SIV.SID(I).SDHNUM<>""
      WSEQ = fmet this.SIV.SID(I).ADDLINE('C_SDH',[V]CST_ALASTPOS)
      this.SIV.SID(I).C_SDH(WSEQ).SDHID=this.SIV.SID(I).SDHNUM
      Local File SDELIVERY [SDH]
      Read[SDH]SDH0=this.SIV.SID(I).SDHNUM
      If fstat=[V]CST_AOK
        this.SIV.SID(I).C_SDH(WSEQ).SDHDAT=format$("D:YYYY[-]MM[-]DD",[F:SDH]SHIDAT)
      Endif
      LogicClose File [SDH]
    Endif

    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=this.SIV.SID(I).ITMREF
    If fstat= [V]CST_AOK
      WSEQ = fmet this.SIV.SID(I).ADDLINE('C_ITM',[V]CST_ALASTPOS)
      this.SIV.SID(I).C_ITM(WSEQ).CHITMREF=[F:ITM]EANCOD
      this.SIV.SID(I).C_ITM(WSEQ).CHITMDES=[F:ITM]ITMDES1
    Endif
    LogicClose File [ITM]

    WSEQ = fmet this.SIV.SID(I).ADDLINE('CHSID',[V]CST_ALASTPOS)
    WSEQ = fmet this.SIV.SID(I).CHSID(WSEQ).ADDLINE('CHSID',[V]CST_ALASTPOS)
    WPROP=format$("N:3.2#",this.SIV.SID(I).RATTAXLIN)
    this.SIV.SID(I).CHSID(WSEQ).CHSID(WSEQ).LINPERTAX=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    WSEQ = fmet this.SIV.SID(I).CHSID(WSEQ).CHSID(WSEQ).ADDLINE('C_DES',[V]CST_ALASTPOS)
    Case this.SIV.INVTYP
      When 1,3,5:  this.SIV.SID(I).CHSID(WSEQ).CHSID(WSEQ).C_DES(WSEQ).LINTAXTYP="TVA DEBIT"
      When 2,4  :  this.SIV.SID(I).CHSID(WSEQ).CHSID(WSEQ).C_DES(WSEQ).LINTAXTYP="TVA ENCAISSEMENT"
    Endcase

    WPROP=format$("N:13.2#",this.SIV.SID(I).AMTNOTLIN)
    this.SIV.SID(I).CHAMTLIN=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:10#",this.SIV.SID(I).QTY)
    this.SIV.SID(I).CHQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    WPROP=format$("N:13.2#",this.SIV.SID(I).GROPRI)
    this.SIV.SID(I).BASLINMNT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N:4#",this.SIV.SID(I).QTY)
    this.SIV.SID(I).QTYPRI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  Next

  Local Char WREST(250)
  WREST=mess(280,143,1)+": OK" # Displayed properties updated
  Call ADDDIAGNOSE(this.ACTX,WREST,[V]CST_AINFO) From ASYRASYNC

  WOK= func EDILIBPDF.GET_FLOW_PDF(NUMDOC)
  If WOK=0
    Gosub PRINT_CLASSIC From EDILIBPDF
    If WSTATUS<>[V]CST_AOK
      If WERR="": WERR=mess(207,2006,1): Endif # Error generating the attachment
    Else
      WSTATUS=[V]CST_AINFO
      WERR=mess(208,2006,1) # Attachment successfully generated
    Endif
    Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC

    If WTEST=2
      WSTATUS=[V]CST_AINFO
      WERR=mess(213,2006,1) # Email protocol is not managed in test mode
      Call ADDDIAGNOSE(this.ACTX,WERR,WSTATUS) From ASYRASYNC
    Endif
  Endif

  WSTATUS=[V]CST_AOK

Return

################################################################################
$CHORUS_RECEIPT
Return

