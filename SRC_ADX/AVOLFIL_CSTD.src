#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AVOLFIL

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINIT"                    : Gosub AINIT
      When "ADELETE"            : Gosub ADELETE
      When "AINSERT"             : Gosub AINSERT
      When "AUPDATE"             : Gosub AUPDATE
      When "AREAD_AFTER"        : Gosub AREAD_AFTER
      When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
      When "ACREATE_CONTROL_BEFORE" : Gosub ACREATE_CONTROL_BEFORE
      When "ADELETE_CONTROL_BEFORE" : Gosub ADELETE_CONTROL_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When 'CONTENTS'
    Case [L]ARULE
      When  'PROPAGATE' : Gosub CONTENTS_PROPAGATE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
   When "GETFILEINFO"       : Gosub GETFILEINFO
   When "GETFILEDATETIME"   : Gosub GETFILEDATETIME
   When "GETFILECOM"        : Gosub GETFILECOM
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



#**
#* CONTROL_BEFORE
#*!
$AUPDATE_CONTROL_BEFORE
$ACREATE_CONTROL_BEFORE
$ADELETE_CONTROL_BEFORE
Local Instance _AVOLUME Using R_AVOLUME
_AVOLUME = NewInstance R_AVOLUME AllocGroup null
[L]ASTATUS = fmet _AVOLUME.AREAD(this.VOLUME)
If fmet _AVOLUME.ACTX.AGETACSRIGHTM(this,_AVOLUME.AVOLUME.CODACC,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR
Endif
FreeGroup _AVOLUME
Return

#**
#* AREAD_AFTER
#*!
$AREAD_AFTER
Local Instance _AVOLUME Using C_AVOLUME
_AVOLUME = NewInstance C_AVOLUME AllocGroup null
[L]ASTATUS = fmet _AVOLUME.AREAD(this.VOLUME)
this.CODACC = _AVOLUME.CODACC
FreeGroup _AVOLUME
Return

#**
#* GETFILEINFO
#*!
$GETFILEINFO
ASTATUS = func ASYRSTO.GETFILEINFO(this.VOLUME,this.FULLNAME,[L]ATTRIBUTE,FILEINFO)
Return

#**
#* GETFILEDATETIME
#*!
$GETFILEDATETIME
ASTATUS = func ASYRSTO.GETFILEDATETIME(this.VOLUME,this.FULLNAME,FDATETIME)
Return

#**
#* GETFILECOM
#*!
$GETFILECOM
ASTATUS = func ASYRSTO.GETFILECOM(this.VOLUME,this.FULLNAME,GETFILECOM)
Return

#**
#* AINIT
#*!
$AINIT
Return

#**
#* ADELETE
#*!
$ADELETE
ASTATUS = func ASYRSTO.DELETEFILE(this.VOLUME,this.FULLNAME)
Return

#**
#* AINSERT
#*!
$AINSERT
$AUPDATE
Local Integer FILEINFO
If !len(this.CONTENTS)ST_AERROR
 [L]ASTATUS = fmet this.ASETERROR("CONTENTS",mess(34,149,1),[V]C)
Else
  [L]ASTATUS = func ASYRSTO.WRITEBLOB(this.VOLUME,this.FULLNAME,this.CONTENTS)
 Endif
Return

#**
#* PROPAGATE
#*!

$CONTENTS_PROPAGATE
Local Integer I
If [L]ARULE = 'PROPAGATE'
 If [L]CURPRO = 'CONTENTS'
  this.FULLNAME =fmet this.APARENT.AGETVALPARAMURL("FULLNAME")
  Local Integer _FILINFO,ATTRIBUTE,FILEINFO
  _FILINFO = func ASYRSTO.GETFILEINFO(this.VOLUME,this.FULLNAME,[L]ATTRIBUTE,FILEINFO)
  If _FILINFO  = [V]CST_AOK and FILEINFO>0
   If find(int(mod(FILEINFO/2^12,16)),0,8)=0 : # Répertoire
    this.FULLNAME += string$(this.FULLNAME<>"","/")+fmet this.APARENT.AGETVALPARAMURL("x-file-name")
   Else  # Fichier normal
    Local Char PARTFULLNAME(250)(1..)
    Local Integer NBPART
    NBPART =func ASYRSUB.SPLIT(PARTFULLNAME,this.FULLNAME,"/")
    this.FULLNAME = ""
    For I=1 To NBPART-1
     this.FULLNAME += PARTFULLNAME(I)+"/"
    Next
    this.FULLNAME += fmet this.APARENT.AGETVALPARAMURL("x-file-name")
   Endif
  Else
   this.FULLNAME = fmet this.APARENT.AGETVALPARAMURL("x-file-name")
  Endif
 Elsif  [L]CURPRO = 'FULLNAME'
     [L]ASTATUS = fmet this.ASETERROR("CONTENTS","",[V]CST_AOK )
 Endif
Endif
Return


