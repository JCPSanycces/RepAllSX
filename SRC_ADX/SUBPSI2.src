#########################################################################  
# SUBPSI2 : Gestion du masque PSELITP2                     MBT 05/12/97 #  
#           Sélection des articles d'un fournisseur                     #  
#########################################################################  
  
  
Subprog AS_NBITP
#-----------------------------------------------------------#
# Affichage référence et désignation article du fournisseur #
#-----------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
If nolign>0 & nolign<=[M]NBITP & [M]NBITP>0
#-----------------------------------------------------------# 
# Réaffichage ligne que l'on a quitté en normal (noir)      # 
#-----------------------------------------------------------#  
#  If [M]LIGNE<>0
#     pcolor=GCOUL(0) : Affzo ITMREF([M]LIGNE-1), ITMDES1([M]LIGNE-1) 
#  Endif 
#-----------------------------------------------------------#
# Affichage ligne sur laquelle on est positionné en rouge   #
#-----------------------------------------------------------#
#  pcolor=GCOUL(1) : Affzo ITMREF(NOL), ITMDES1(NOL)
#  [M]LIGNE=NOL+1
   [M]WITMREF =[M]ITMREFBPS(NOL)
   [M]WITMDES1=[M]ITMDESBPS(NOL)
   Affzo 10 
Endif
End 

Subprog AV_NBITP 
#-----------------------------------------------------------# 
# Affichage référence et désignation article du fournisseur # 
#-----------------------------------------------------------# 
If status=71 | status=1
   Local Integer NOL 
   NOL=min(nolign,[M]NBITP)
#-----------------------------------------------------------#  
# Réaffichage ligne que l'on a quitté en normal (noir)      #  
#-----------------------------------------------------------#  
   If [M]LIGNE<>0  
      pcolor=GCOUL(0) : Affzo ITMREF([M]LIGNE), ITMDES1([M]LIGNE)  
   Endif  
#-----------------------------------------------------------# 
# Affichage ligne sur laquelle on est positionné en rouge   # 
#-----------------------------------------------------------# 
   pcolor=GCOUL(1) : Affzo ITMREF(NOL-1), ITMDES1(NOL-1)
   [M]LIGNE=NOL  
Endif
End  
