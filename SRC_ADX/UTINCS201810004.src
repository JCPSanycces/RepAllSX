#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTINCS201810004
# Issue X3-112819 - 2018-10-19 by BAKHA : Update object NCSA with discriptions
###################################################################################################
Local Char DOSSIER(30)

    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
        If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
        Read [ADS]DOSSIER=[L]DOSSIER
        If fstat Then
            Raz [F:ADS]
        Endif
        Call TEMPON("O") From GESECRAN
        Call OUVRE_TRACE("Update object NCSA with discriptions") From LECFIC
        # -------------------------
        Call MAJ_UTINCS201810004(DOSSIER)
        # -------------------------
        Call TEMPOFF From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
End

##########################################################################
Subprog MAJ_UTINCS201810004(DOSSIER)
Value Char DOSSIER

    Local Char WOBJ(20) : WOBJ = "NCSH"

    If clalev([F:AOL]) = 0 : Local File = DOSSIER+".AOBJLST" [AOL] : Endif

    Call ECR_TRACE("MAJ_UTINCS201810004: Process Start on : "+DOSSIER,0) From GESECRAN


    Call DEBTRANS From GLOCK

    Trbegin [AOL]

    Readlock [AOL]AOL0="NCSA"
    If fstat = 0 and [F:AOL]NBSEL = 3
      # reset number of selection fields
      [F:AOL]NBSEL = 5
      # fix issues with description fields
      [F:AOL]SELFIC(2) = ""
      [F:AOL]SELFIC(3) = "PLANACT"
      [F:AOL]SELEXP(2) = "[F:AXXA]TEXTE"
      [F:AOL]SELEXP(4) = "[F:AXXB]TEXTE"
      [F:AOL]SELINT(0) = 89
      [F:AOL]SELINT(1) = 90
      [F:AOL]SELINT(2) = 12402
      [F:AOL]SELINT(3) = 3209
      [F:AOL]SELINT(4) = 12402
      [F:AOL]SELTYP(2) = "DES"
      [F:AOL]SELTYP(4) = "DES"
      [F:AOL]SELZON(2) =""
      [F:AOL]SELZON(3) ="TRANTYPE"

      Rewrite [F:AOL]

    Endif
    Filter [F:AOL]

    Commit

    Close Local File [AOL]

    Call ECR_TRACE("MAJ_UTINCS201810004: Process End", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810004(DOSSIER)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

    Call MAJ_UTINCS201810004(DOSSIER)

End

