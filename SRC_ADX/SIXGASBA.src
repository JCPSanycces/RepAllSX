#<AdxTL>@(#)11.0.0.0 $Revision$
############################################################################
#  SIXGASBA : pour traitements de bascule Integrale --> X3                 #
############################################################################
#                                                                          #
# Subprog SIXGASBA                                                         #
#     Reprise du brouillard purement analytique                            # 
#  => Création de pièces comptables X3 de type analytique en état          #
#     provisoire
#                                                                          #
# PREREQUIS :                                                              #
# ***********                                                              #
#   - Les tables de base et de paramétrage ont dues être intégrées         #
#     et contrôlées                                                        #
#   - Les types de pièces et les compteurs de numérotation ont dues être   #
#     définis (on livre des types de pièces associés à des codes           #
#     compteurs documents mais le paramétrage doit être accepté ou         #
#     modifié en fonction des besoins                                      #
#                                                                          #
# Les OD purement analytiques sont reprises en devise locale               #
#                                                                          #
############################################################################

Gosub SI_CONTEXT From SIXFONCTION

Local File SIPARX3  [SPX]
Read [SPX] First

Global Integer X_NB
If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIBROCBANA"  [XGAA]  : Endif  # Historique analytique
Call OUVRE_BOITE("XIBROCBANA",nbrecord([XGAA])) From GESECRAN
Raz X_NB

Call EXEC From SIXGASBA

Kill X_NB

End


#########################################################################
Subprog EXEC

If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIBROCBANA"  [XGAA]  : Endif  # Historique analytique
If !clalev([F:XAA2]) : Local File =SI_DOSSIER+".XIBROCBANA"  [XAA2]  : Endif  # Historique analytique

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"     [SPX]   : Endif  # Paramétrage migration

Read [SPX] First

Filter [XGAA] Where FLGREP<>2
Read [XGAA]IND0 First
Filter [XGAA]
If fstat : End : Endif 

Local Integer WOUV_TRACE
If GTRACE = ""
 # Brouillard analytique
 Call OUVRE_TRACE("SIXGASA : "+SI_MES(197)) From LECFIC         
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Brouillard analytique => Création écritures analytiques provisoires ------#
Call ECR_TIME(SI_MES(197)-"=>"-SI_MES(138)) From DOSSUB

If [F:SPX]OPTANA<>2
 ## L'option 'Reprise analytique' n'a pas été demandée
 Call ECR_TRACE(SI_MES(198),1) From GESECRAN
 End
Endif
Call SI_GASA
If GOK<>1 : Goto FIN_GAS : Endif


$FIN_GAS
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


######################################################################################
## Traitement brouillard purement analytique
######################################################################################
Subprog SI_GASA

If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIBROCBANA"     [XGAA]  : Endif  # Brouillard analytique
If !clalev([F:XAA2]) : Local File =SI_DOSSIER+".XIBROCBANA"     [XAA2]  : Endif  # Brouillard analytique

Gosub OUVFIC From SIXGASA

Gosub DECLARE From SIXGASA
If STAT : End : Endif

SI_SUBPRG = "SIXGASBA"
SI_TABLE  = "XIBROCBANA"
Gosub SI_CRITSUP From SIXFONCTION

CRITERE="1=1"

Call VARGLOBANA(MESSA,STAT) From SIXGAS
If STAT
 ## Nb d'axes définis dans l'Intégrale pas cohérent avec le dimensionnement du code activité ANA => On arrête
 Call ECR_TRACE(MESSA,1) From GESECRAN : End
Endif

Read [SPX] First

## Qu'une société forcément...
Read [CPY]CPY0 First
If !fstat
 [L]SOCIETE   = [F:CPY]CPY
 [L]SITE      = [F:CPY]MAIFCY
 [L]ORIGINE   = "B"
 [L]DATPREMEX = [F:CPY]STRPER
 If [L]DATPREMEX = [0/0/0]
  # Date début premier exercice non définie
  Call ECR_TRACE(SI_MES(132),1) From GESECRAN : End
 Endif
 Call GETSOC([L]SITE) From DEVSUB
 Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY
Endif

Read [XSOC]  First
If !fstat
 [L]DEVLOC = [F:XSOC]DVSIPC
Endif
Read [XSO1]  First
 
NBJOUANA = 0
For [XGAA]IND0(1)
 Read [XJRN]IND0 = [F:XGAA]CODJRN
 If !fstat & [F:XJRN]TYPJRN="L"
  NBJOUANA += 1
  TBJOUANA(NBJOUANA) = [F:XGAA]CODJRN
 Endif
Next

Filter [XGAA] Where evalue(CRITERE) & FLGREP<>2 & NATMVT<>"I" & find(CODJRN,TBJOUANA(1..NBJOUANA)) & X3DAT>=[L]DATPREMEX
&                   Order By Key CLE = NUMLOT ; DATSAILOT ; NUMORDLOT ; NUMVTLLOT


## Parcours des écritures du brouillard analytique par N° lot/date saisie lot : 
## une transaction par couple N° lot/date saisie lot

Call ECR_TRACE("",0) From GESECRAN 

For [XGAA]CLE(2)
 ## On exclut les pièces d'A-nouveaux (sauf celle qui correspond au premier exercice repris).
 ## La seule manière de reconnaître les pièces d'A-nouveaux analytiques est de se baser sur le libellé de
 ## l'écriture. Le libellé commence par "Reprise des soldes au" suivi de la date de génération de l'A-nouveau
 ## => Reprise des écritures ana associées à une date égale à la date début premier exercice repris et quel
 ##    que soit le libelle ET celle qui sont > à [L]DATPREMEX mais qui ne commencent pas par 
 ##    "Reprise des soldes au" (pour exclure les A-nouveaux analytiques générés sur l'exercice suivant le
 ##    premier exercice repris
 If [F:XGAA]X3DAT=[L]DATPREMEX or ([F:XGAA]X3DAT>[L]DATPREMEX and left$([F:XGAA]LIBECR,21)<>"Reprise des soldes au")
  Call DEBTRANS From GLOCK
  # Reprise Lot... Date
  Call ECR_TRACE(SI_MES(135)-mess(23,107,1)-num$([F:XGAA]NUMLOT)-";"-mess(88,100,1)-format$(GFMDAT,[F:XGAA]DATSAILOT),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  Gosub TR_PCE
  Call ECR_TRACE("",0) From GESECRAN 
 Endif
Next
End


$TR_PCE

Trbegin [HAE], [DAE], [DAA], [XGAA], [PER]

 Gosub OUV_PER From SIXGASA

 Gosub PIECE : # Une pièce par N° lot + date saisie lot pour les écritures purement ana
 
 Gosub CLO_PER From SIXGASA

 If GOK>0 & SI_SIMU<>2
  Commit
 Else
  Rollback
  If STAT | GOK<1
   # Lot.. Date... Reprise non faite => à relancer
   Call ECR_TRACE(mess(23,107,1)-num$([F:XGAA]NUMLOT)-";"-mess(3,11,1)-format$(GFMDAT,[F:XGAA]DATSAILOT)-":"-SI_MES(139),0) From GESECRAN
   Return
  Endif
 Endif
Return


$PIECE
STAT = 0 : SPSTAT = 0
LOT      = [F:XGAA]NUMLOT 
DATCPT   = [F:XGAA]DATSAILOT
OKDEV = 0 : [L]DEVPCE=[L]DEVLOC : # Reprise en devise locale
Gosub RAZPCE
Gosub LIGNE
If GOK<1 : Return : Endif
Return

$RAZPCE
Raz TOTDEB, TOTCDT, TOTDEBLOC, TOTCDTLOC
Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
Return


$LIGNE
For [XGAA]CLE(3)

 Call AFFBOITE(num$([F:XGAA]NUMLOT)-format$("D:"+GFMDAT4,[F:XGAA]DATSAILOT)) From SUBSIM

 DATCPT   = [F:XGAA]DATECR

 NOL = [M:HAE2]NBLIG
 [M:HAE2]ACC1(NOL) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAA]CPTGNR,"GACCOUNT","")
 Call LECTURE("GAC",[M:HAE2]ACC1(NOL),[L]COAANA) From CONTOBJ
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 [M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
 [M:HAE2]DES(NOL) = [F:XGAA]LIBECR
 
 If [F:XGAA]SENECR = "C"
  [M:HAE2]CDT(NOL)  = [F:XGAA]MNTDBTFRS
  [L]TOTCDT    += [M:HAE2]CDT(NOL)
  [L]TOTCDTLOC += [F:XGAA]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAA]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAA]MNTDBTFRS
 Elsif [F:XGAA]SENECR = "D"
  [M:HAE2]DEB(NOL) = [F:XGAA]MNTDBTFRS
  [L]TOTDEB += [M:HAE2]DEB(NOL)
  [L]TOTDEBLOC += [F:XGAA]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAA]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAA]MNTDBTFRS
 Endif
 Assign "[M]AMTFLG"+num$(GTYPANA)+"("+num$(NOL)+")" With 1

 Gosub INICNACCE
 [F:XGAA]FLGREP = 2
 Rewrite [F:XGAA]
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("XIBROCBANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]LOT-format$(GFMDAT,[L]DATCPT)-num$([F:XGAA]NUMORDLOT)-num$([F:XGAA]NUMORDLOT),1) From GESECRAN
  GOK = 0 : Break
 Endif

 [M:HAE2]NBLIG += 1

 ## Trop de lignes => On crée la pièce et on passe par un compte d'attente

 If [M:HAE2]NBLIG>=MAXECT
  Gosub VALPCE From SIXGASA
  If GOK<1 : Break : Endif
  STAT = 0 : SPSTAT = 0
  Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
  Raz [M:HAE2]NBLIG
  NOL = [M:HAE2]NBLIG
 Endif

Next : # For [XGAA]CLE(3) (parcours des écritures analytiques d'un même n°lot/date saisie lot)

If GOK<1 : Return : Endif

## Création de la pièce (forcément la dernière du groupe)
If [M:HAE2]NBLIG>0
 Gosub VALPCE From SIXGASA
 If GOK<1 : Return: Endif
Endif
If GOK<1 : Return: Endif
Return


$INICNACCE
REPART_ANA = 0
Filter [XAA2] Where NUMLOT=[L]LOT & DATSAILOT=[L]DATCPT & NUMORDLOT=[F:XGAA]NUMORDLOT 
Read [XAA2] Last 
Filter [XAA2]
If !fstat & [F:XAA2]NUMVTLLOT>1
 REPART_ANA = 1
Endif
FIRSTVENT = 1

If !REPART_ANA
  Gosub LECCNA From SIXGASA
  If [M:HAE2]ACC1(NOL)<>""
   [M:HAE2]QTY(NOL) = arr([F:XGAA]QTE,AROQTE)
   ## Le sous-programme INICCE va initialiser [M:HAE2]CCE1, [M:HAE2]CCE2,...
   Call INICCE([F:XGAA]SECANA,"[M:HAE2]CCE",NOL) From SIXGAS
  Endif
  [F:XGAA]FLGREP = 2
  Rewrite [F:XGAA]
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("XIBROCBANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]LOT-format$(GFMDAT,[L]DATCPT)-num$([F:XGAA]NUMORDLOT),1) From GESECRAN
   GOK = 0 : Return
  Endif
Else
  Gosub LECCNA From SIXGASA
  If [M:HAE2]CNA(NOL)<>""
   ## Parcours de toutes les répartitions analytiques
   For [XGAA] 
    Gosub VENTILE
    If GOK<1 : Break : Endif
   Next
   If GOK<1 : Return : Endif
  Endif
Endif
Return

$VENTILE
If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
 # Trop ventilations analytiques
 Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
 GOK = 0 : Return
Endif
[M:VT2]PTVENT += 1
If [M:HAE2]PTV(NOL)=0 
 [M:HAE2]PTV(NOL) = [M:VT2]PTVENT
Endif
[M:HAE2]PTF(NOL) = [M:VT2]PTVENT
[M:HAE2]DSP(NOL) = "$"
Call INICCE([F:XGAA]SECANA,"[M:VT2]TBCCE",[M:VT2]PTVENT) From SIXGAS

[M:VT2]TBAMT([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS

If dim([M:VT2]TBLOC)>0
 [M:VT2]TBLOC([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS
Endif
If dim([M:VT2]TBRPT)>0
 [M:VT2]TBRPT([M:VT2]PTVENT) = [F:XGAA]MNTDBTFRS
Endif

[M:VT2]TBQTY([M:VT2]PTVENT) = arr([F:XGAA]QTE,AROQTE)
[M:HAE2]QTY(NOL) = arr(sum([M:VT2]TBQTY([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL))),AROQTE)
[F:XGAA]FLGREP = 2
Rewrite [F:XGAA]
If fstat
 # Erreur d'écriture
 Call ECR_TRACE("XIBROCBANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-[L]LOT-format$(GFMDAT,[L]DATCPT)-num$([F:XGAA]NUMORDLOT),1) From GESECRAN
 GOK = 0 : Return
Endif 
Return
