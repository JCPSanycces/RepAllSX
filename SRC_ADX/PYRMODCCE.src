#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CYM",GBIDC1,GBIDC2) From GOBJET
End

#######################################################################################
## Génération auto pyramide
#######################################################################################
$ACTION
Case ACTION
 When "INIT"           : Gosub INIT
 When "INIT_DIA"       : Gosub INIT_DIA
 When "CONTROLE"       : Gosub CONTROLE
 When "EXEC"           : Gosub EXEC
Endcase
Return

######################################################################################
$INIT
If clalev([F:CCE]) = 0 : Local File CACCE   [CCE] : Endif
If clalev([F:CYM]) = 0 : Local File GCCEPYM [CYM] : Endif
TMP = 1
Return

$INIT_DIA
Local Integer I
Raz [M]
[M]PYM    = PARAM(2)
[M]DIE    = PARAM(1)
[M]NRLEV = 5
[M]LENLEV(0) = 0 : [M]NIVEAU(0) = 10
[M]LENLEV(1) = 1 : [M]NIVEAU(1) = 20
[M]LENLEV(2) = 2 : [M]NIVEAU(2) = 30
[M]LENLEV(3) = 3 : [M]NIVEAU(3) = 40
[M]LENLEV(4) = 4 : [M]NIVEAU(4) = 50
Return

$CONTROLE
If [M]NRLEV<1
 GMESSAGE = mess(101,102,1) : # Il faut au moins une ligne
 GERR = 1 : SAI = 1 : Return
Else
 For I=2 To [M]NRLEV
  If [M]NIVEAU(I-1)<=[M]NIVEAU(I-2)
   GMESSAGE = mess(103,102,1)-num$(I-1) : # Niveau incorrect en ligne
   GERR = 1 : SAI = 1 : Break
  Elsif [M]LENLEV(I-1)<=[M]LENLEV(I-2)
   GMESSAGE = mess(102,102,1)-num$(I-1) : # Longueur incorrecte en ligne
   GERR = 1 : SAI = 1 : Break
  Endif
 Next I
Endif
Return

$EXEC
Call CREATEPYM([M]PYM,[M]NRLEV,[M]LENLEV,[M]NIVEAU,([M]JOK=2),([M]HOM=2))
Return

######################################################################################
## Ecran PYRMODCCE
######################################################################################
Subprog C_NIVEAU(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or (nolign>1 & VALEUR<=[M]NIVEAU(nolign-2))
 GMESSAGE = mess(98,102,1) : # Niveau incorrect
 mkstat = 2 : End
Endif
End

Subprog C_LENLEV(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 or (nolign>1 & VALEUR<=[M]LENLEV(nolign-2))
 GMESSAGE = mess(99,102,1) : # Longueur incorrecte
 mkstat = 2 : End
Endif
End

######################################################################################
# Subprogs to handle pyramid automatic creation according to account pattern
######################################################################################

Subprog CREATEPYM(PYRAMIDE,NBNIV,LONG,NIVEAU,JOK,HOMOGENE)
Value Char    PYRAMIDE
Value Integer NBNIV
Value Integer LONG(1..)
Value Integer NIVEAU(1..)
Value Integer JOK
Value Integer HOMOGENE

Local Char    AXE(GLONDIE) , RACCUR(GLONCCE) , RACINE(GLONCCE)
Local Integer RANG , LIGNE
Local Char    HOMOG(10)

If clalev([F:CCE]) = 0 : Local File CACCE      [CCE] : Endif
If clalev([F:CYM]) = 0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:CRY]) = 0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CR2]) = 0 : Local File GCCEGRUPYM [CR2] : Endif
If clalev([F:CYK]) = 0 : Local File GCCEPYMLIK [CYK] : Endif
If clalev([F:CYP]) = 0 : Local File GCCEPYMPRT [CYP] : Endif

HOMOG = string$(10,"X")
Read [CYM]CYM0 = PYRAMIDE
AXE = [F:CYM]DIE
Call EFFACE(PYRAMIDE,0) From PYRDELCCE
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Call PYRAMPRT(PYRAMIDE,AXE,nomap) From LIENPYRCCE
 Call PYRAMLIK(PYRAMIDE,AXE,nomap) From LIENPYRCCE
Endif
End

$TR1
GOK = 1
Trbegin [CRY]

 For NIV=NBNIV To 1 Step -1
  #
  # Création des groupes liés aux racines de comptes
  #
  RACCUR = ""
  RANG   = 0
  If NIV=NBNIV
   If HOMOGENE
    Filter [CCE] Where DIE=AXE
   Else
    Filter [CCE] Where DIE=AXE & len([F:CCE]CCE)>=LONG(NIV)
   Endif
  Else
   Filter [CCE] Where DIE=AXE & len([F:CCE]CCE)>=LONG(NIV) & len([F:CCE]CCE)<LONG(NIV+1)
  Endif
  If !HOMOGENE or NIV=NBNIV
   For [CCE]CCE0
    RACINE = left$([F:CCE]CCE+HOMOG,LONG(NIV))
    If RACINE<>RACCUR or !(JOK & NIV=NBNIV)
     If RACINE<>RACCUR
      RACCUR = RACINE
      Filter [CRY] Where PYM=PYRAMIDE & GRU=RACINE
      Read [CRY]CRY0 Last
      Filter [CRY]
      If fstat<=2
       LIGNE = [F:CRY]LIN
      Else
       LIGNE  = 0
      Endif
      RANG  += 10
     Endif
     Raz [F:CRY]
     [F:CRY]PYM    = PYRAMIDE
     [F:CRY]GRU    = RACCUR
     [F:CRY]LEV    = NIVEAU(NIV)
     Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GCCEGRUPYM","DESTRA",PYRAMIDE,RACCUR) From ATEXTRA
     Call MAJTEXTRA(RACCUR,"GCCEGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From ATEXTRA
     If dim([F:CRY]DES)>0
      [F:CRY]DES    = mess(100,102,1)-RACCUR : # Groupe
     Endif
     [F:CRY]PRNROW = RANG
     If JOK & NIV=NBNIV & len([F:CCE]CCE)>=LONG(NIV)
      [F:CRY]CCE    = left$([F:CCE]CCE,LONG(NIV))+"*"
     Else
      [F:CRY]CCE    = [F:CCE]CCE
     Endif
     LIGNE += 1
     [F:CRY]LIN    = LIGNE
     [F:CRY]BUDTRK = [F:CCE]BUDTRK
     If dim([F:CRY]CREDAT)>0 : [F:CRY]CREDAT = date$ : Endif
     If dim([F:CRY]CREUSR)>0 : [F:CRY]CREUSR = GUSER : Endif
     If dim([F:CRY]CRETIM)>0 : [F:CRY]CRETIM = time  : Endif
     Write [CRY]
     If fstat
      GOK = 0 : Call FSTA("CRY") From GLOCK : Break
     Endif
    Endif
   Next
  Endif
  Filter [CCE]
  #
  # Groupes de cumuls du niveau inférieur
  #
  If NIV<NBNIV
   RACCUR = ""
   Filter [CRY] Where PYM=PYRAMIDE & LEV=NIVEAU(NIV+1) & LIN=1 Order By Key CLE=GRU
   For [CRY]CLE
    RACINE = left$([F:CRY]GRU+HOMOG,LONG(NIV))
    If RACINE=""
     RACINE = mess(115,102,1) : # TOTAL
    Endif
    If RACINE<>RACCUR
     Filter [CR2] Where PYM=PYRAMIDE & GRU=RACINE
     Read [CR2]CRY0 Last
     Filter [CR2]
     If fstat<=2
      LIGNE = [F:CR2]LIN
     Else
      LIGNE  = 0
     Endif
     RACCUR = RACINE
     RANG  += 10
     Raz [F:CR2]
     [F:CR2] = [F:CRY]
     [F:CR2]GRU    = RACCUR
     [F:CR2]LEV    = NIVEAU(NIV)
     Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GCCEGRUPYM","DESTRA",PYRAMIDE,RACCUR) From ATEXTRA
     Call MAJTEXTRA(RACCUR,"GCCEGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From ATEXTRA
     If dim([F:CR2]DES)>0
      [F:CR2]DES    = mess(100,102,1)-RACCUR : # Groupe
     Endif
     [F:CR2]PRNROW = RANG
     [F:CR2]SBBGRU = [F:CRY]GRU
     [F:CR2]CCE    = ""
    Else
     [F:CR2]SBBGRU = [F:CRY]GRU
    Endif
    LIGNE += 1
    [F:CR2]LIN = LIGNE
    If dim([F:CR2]CREDAT)>0 : [F:CR2]CREDAT = date$ : Endif
    If dim([F:CR2]CREUSR)>0 : [F:CR2]CREUSR = GUSER : Endif
    If dim([F:CR2]CRETIM)>0 : [F:CR2]CRETIM = time  : Endif
    Write [CR2]
    If fstat
     GOK = 0 : Call FSTA("CR2") From GLOCK : Break
    Endif
   Next
   Filter [CRY]
  Endif
 Next NIV
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

