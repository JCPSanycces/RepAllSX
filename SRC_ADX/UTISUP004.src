#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################
# MOULINETTE POUR MAJ des Documentations dont le module est Ă  0 pour les DOCS crĂŠes automatiquement #
################################################################################

##################################################################
#Comments(1)                                                     #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER<>""
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTISUP004 : Module documentation Update for Module=0") From LECFIC
    Call EXE_UTIXXX(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

#######################################################################
# Pour exĂŠcution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

  Call EXE_UTIXXX(APPLI)
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exĂŠcution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est dĂŠjĂ  ouvert / l'intĂŠgration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention Ă  la dĂŠclaration des fichiers : pensez que le client n'a pas forcĂŠmment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################
Subprog EXE_UTIXXX(APPLI)
Value Char APPLI()
Local Libelle  SIMFLG
Local Integer  OLD_MODULE, NEW_MODULE
Local Integer  OK, NB_DOCS_OK, NB_DOCS_MAJ, NB_DOCS_KO
Local Char     WMSG(100), WMSG0(100)
Local Char     DOC_CODE(30), DOC_TYPE(GLONADI)
Local Char     WTIRET(1)        : [L]WTIRET="_"
Local Char     FILTRE_TYP(100)  : [L]FILTRE_TYP = " find(TYP,'ACT','ADC','AGB','APR','ASU')<>0 "
Local Char     FILTRE_MOD(100)  : [L]FILTRE_MOD = " MODULE=0 "


  #### Corps de la moulinette - DEBUT
  ## Doit s'executer sur tous les dossiers
  WMSG0="Documentation Update for MODULE=0"
  Call ECR_TIME("UTISUP004 -"-WMSG0-"Process Start on : "+APPLI) From DOSSUB
  Call ECR_TRACE("                    > Process descritption : Documentation update for ACT,ADC,AGB,APR,ASU when module=0",0) From GESECRAN
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

  If !clalev([F:ADO3]) Local File =APPLI+".ADOCUMENT" [ADO3] : Endif

  # Process de MAJ rĂŠalisĂŠ pour toutes les documentations dont le module est Ă  0 pour les Documentations crĂŠĂŠes automatiquement
  Gosub MAJ_DOC

  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Call ECR_TIME("UTISUP004 -"-WMSG0-"Process End on : "+APPLI) From DOSSUB
  
  Close Local File [ADO3]
  #### Corps de la moulinette - FIN
End

#----------------------------------------------------------#
$MAJ_DOC
  Trbegin [ADO3]
    Gosub MAJ_DOC_ADO3
  Commit
Return

#----------------------------------------------------------#
$MAJ_DOC_ADO3
    Raz [L]NB_DOCS_OK,[L]NB_DOCS_MAJ, [L]NB_DOCS_KO

    For [ADO3]ADO0  Where evalue([L]FILTRE_TYP) & evalue([L]FILTRE_MOD) With Lock
      WMSG=[ADO3]LAN+"~"+[ADO3]TYP+"~"+[ADO3]COD+"~"+"~"+num$([ADO3]LEV)+"~"+num$([ADO3]SUBLEV)
      [L]DOC_TYPE=[ADO3]TYP
      Gosub DOC_RECH_CLE_MULTIPLE From AGENLIBA
      If IF_DOC_TABLE
        Gosub DEFAUT From ="WO"+[L]DOC_TYPE
        # JPGA 19/08/2009 Bug-52238 : Alimentation dynamique des ĂŠlĂŠments de clĂŠ multiples d'index (4 au max)
        [L]DOC_CODE=[F:ADO3]COD
        Gosub DOC_ALIM_CLE_MULTIPLE From AGENLIBA
        Read [F] =
        If !fstat
          [L]OLD_MODULE=[ADO3]MODULE
          [L]NEW_MODULE=[F]MODULE
          [ADO3]MODULE=[L]NEW_MODULE
          Rewrite [ADO3]
          If !fstat
            NB_DOCS_MAJ+=1                          # MAJ OK
            Call ECR_TRACE(WMSG+space$(66-len(WMSG))+"- OK  (OLD MODULE="+num$([L]OLD_MODULE)-"- NEW MODULE="+num$([L]NEW_MODULE)+")",0) From GESECRAN
          Else
            NB_DOCS_KO+=1                           # KO : Update failed
            Call ECR_TRACE(WMSG+space$(66-len(WMSG))+"- Error Rewrite ="-num$(fstat),1) From GESECRAN
          Endif
        Else
          Delete [ADO3]ADO0 Curr
          If !fstat
            NB_DOCS_OK+=1                           # OK : Objet inexistant : Delete rĂŠalisĂŠ
            Call ECR_TRACE(WMSG+space$(66-len(WMSG))+"- OK  ("-[L]DOC_TYPE-":"-mess(161,123,1)-"DELETE OK)",0) From GESECRAN
          Else
            NB_DOCS_KO+=1                           # KO : Objet inexistant : Delete KO
            Call ECR_TRACE(WMSG+space$(66-len(WMSG))+"- Error Read on"-[L]DOC_TYPE-":"-mess(161,123,1)-"DELETE KO",-1) From GESECRAN
          Endif
        Endif
      Else
            NB_DOCS_KO+=1                           # KO : Table inexistante
            Call ECR_TRACE(WMSG+space$(66-len(WMSG))+"- Error Open on"-[L]DOC_TYPE-":"-mess(124,124,1),-1) From GESECRAN
      Endif
      NB_DOCS_OK+=1
    Next ADO3

    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE(">> Main Documentation Update :"-num$(NB_DOCS_MAJ)+"/"+num$(NB_DOCS_OK)-"records ("+num$(NB_DOCS_KO)+" failed)",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return
#----------------------------------------------------------#

###################################################################################################
#Comments(3)                                                                                      #
# Pour exĂŠcution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'ĂŠxĂŠcuter dans le dossier GX (moulinette applicative)        #
#        ==> DĂŠcocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'ĂŠxĂŠcuter uniquement dans les dossiers ayant activĂŠ un module donnĂŠ #
#        ==> DĂŠcocher la ligne 2  et renseigner le nÂ° de module                                   #
#            attention Ă  la numĂŠrotation du module qui commence Ă  0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call EXE_UTIXXX(APPLI)
End
