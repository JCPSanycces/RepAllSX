#<AdxTL>@(#)4.0.0.0 $Revision$
Call UTF8("TRT","ZZMB140","src",nomap,1)
# Call UTF8_REP2("TRT","VX3PKO","src",nomap,3,"TRTDIFF")
End

#######################################################
## Moulinette de conversion d'un source ASCII=>UTF8
#######################################################
Subprog UTF8(REP,PROG,EXT,APPLI,SNS)
Value Char    REP
Value Char    PROG
Value Char    EXT
Value Char    APPLI
Value Integer SNS
Local Char    REP2(20)
REP2 = REP

Goto TRT

#######################################################
Subprog UTF8_REP2(REP,PROG,EXT,APPLI,SNS,REP2)
Value Char    REP
Value Char    PROG
Value Char    EXT
Value Char    APPLI
Value Integer SNS
Value Char    REP2

Goto TRT

#######################################################
$TRT
Local Char    FICORG(250) , FICDES(250) , FICDES2(250) , LIGNE(250)
Local Char    SAVIFS(5) , SAVIRS(5) , TETADO(50) , COMMAND(250)
Local Integer SAVIUM
Local Integer FMTORG , FMTDES

Case SNS
 When 1 : # Ascii => UTF8
  FMTORG = GASCII
  FMTDES = GUTF8
 When 2 : # Ascii => UCS2
  FMTORG = GASCII
  FMTDES = GUCS2
 When 3 : # UTF8 => Ascii
  FMTORG = GUTF8
  FMTDES = GASCII
 When 4 : # UTF8 => UCS2
  FMTORG = GUTF8
  FMTDES = GUCS2
 When 5 : # UCS2 => Ascii
  FMTORG = GUCS2
  FMTDES = GASCII
 When 6 : # UCS2 => UTF8
  FMTORG = GUCS2
  FMTDES = GUTF8
Endcase

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If APPLI="" : APPLI = nomap : Endif

FICORG  = filpath(REP,PROG,EXT,APPLI)
FICDES  = filpath(REP2,PROG,"utf8",APPLI)
FICDES2 = filpath(REP2,PROG,EXT,APPLI)

If filinfo(FICORG,0)<=0 : End : Endif

adxifs = ""
adxirs = chr$(10)
fstat = 0
Openi FICORG

## Pour les traitements on essaye de contrôler

If REP="TRT" & EXT="src" & find(FMTDES,GASCII,GUTF8) & find(FMTORG,GASCII,GUTF8)
 adxium = GASCII : Rdseq LIGNE
 If mid$(LIGNE,7,1)>="L" & FMTDES=GUTF8 : # c'est déjà fait!!
  Openi
  Goto FIN
 Elsif mid$(LIGNE,7,1)<"L" & FMTDES=GASCII : # c'est déjà fait!!
  Openi
  Goto FIN
 Else
  Openo FICDES,0
  adxium = FMTDES
  If FMTDES<>GASCII
   TETADO = "#<AdxT"+GADOVERS+">@(#)"
   Wrseq TETADO+right$(LIGNE,len(TETADO)+1)
  Else
   TETADO = "#<AdxTJ>@(#)"
   Wrseq TETADO+right$(LIGNE,len(TETADO)+1)
  Endif
 Endif
Else
 Openo FICDES,0 
Endif

adxium = FMTORG : Rdseq LIGNE
While fstat=0
 adxium = FMTDES  : Wrseq LIGNE
 adxium = FMTORG : Rdseq LIGNE
Wend
Openi
Openo
System COMMAND="ae_mv"-FICDES-FICDES2

$FIN
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

