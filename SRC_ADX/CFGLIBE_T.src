#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################
# Exemple de montage batch
############################################################
GSERVEUR=1
Call OUVRE_TRACE("Configurator interface") From LECFIC
Local Mask CFGFUN [CFGF]
Local Integer W_I
# Chargement des paramètres \ Parameters loading
Raz [M:CFGF]
[M:CFGF]FCY    = "GAL"   : # Site
#[M:CFGF]SCENUM = "JP2A"  : # Scénario        JP2A:multi-niveau
#[M:CFGF]SCENUM = "JP12"  : # Scénario        JP12:gamme
[M:CFGF]SCENUM = "JP04"  : # Scénario        JP04:composé-composant
[M:CFGF]BPRNUM = ""      : # Numéro tiers
[M:CFGF]IPTDAT = date$   : # Date de référence
#
# Appel de la routine d'initialisation / Initialization call
#
Gosub CFGINIBAT From CFGLIBE
If [M:CFGF]RETCOD=0    # init ok
    #
    # Chargement des réponses dans l'écran / Loading of answers
    #
    Case [M:CFGF]SCENUM        # selon scénario
    When "JP2A"
        For W_I = 0 To [M:CFGF]QSTNBR-1
          Case [M:CFGF]QSTNUM(W_I)
            When "JWQN1" : [M:CFGF]ASWNUM(W_I) = 1
            When "JWQN4" : [M:CFGF]ASWNUM(W_I) = 1       # Borné de 1 à 3
          Endcase
        Next W_I
    When "JP04"
        For W_I = 0 To [M:CFGF]QSTNBR-1
          Case [M:CFGF]QSTNUM(W_I)
            When "JWQNH1" : [M:CFGF]ASWNUM(W_I) = 1
            When "JWQNCH1" : [M:CFGF]ASWNUM(W_I) = 1
            When "JWQN1" : [M:CFGF]ASWNUM(W_I) = 3
            When "JWQNH2" : [M:CFGF]ASWNUM(W_I) = 1
            When "JWQB1" : [M:CFGF]ASWNUM(W_I) = 0       # Bool 0 ou 1
          Endcase
        Next W_I
    Endcase

#        When "JWQA1" : [M:CFGF]ASWALP(W_I) = "Batch 10"
#        When "JWQN1" : [M:CFGF]ASWNUM(W_I) = 2        # 3 provoque une / par 0
#        When "JWQN2" : [M:CFGF]ASWNUM(W_I) = 2       # Borné de 1 à 3
#        When "PUTA" : [M:CFGF]ASWALP(W_I) = "XS"


    #
    # Execution du scénario / Run of the script
    #
    
    #Call MESSAGE("Phase génération") From gesecran
    Gosub CFGEXEBAT From CFGLIBE
    # Infbox "GERR _T"-num$(GERR) 
    If GERR = 2    # fin correcte
        Call MESSAGE("Bilan: \S_AUTCFG:"-num$(S_AUTCFG)-"GERR:"-num$(GERR)-"\Mes:"-GMESSAGE) From gesecran
    Else           #  Gestion en cas d'erreur
        If dim(S_AUTCFG) < 0 | S_AUTCFG=0   # erreur en phase de préparation
            Call ERREUR("Anomalie: GERR:"-num$(GERR)-"\Mes:"-GMESSAGE) From gesecran
        Else
            Call ERREUR("Anomalie: \S_AUTCFG:"-num$(S_AUTCFG)-"S_AUTERR:"-S_AUTERR-"\GERR:"-num$(GERR)-"\Mes:"-GMESSAGE) From gesecran
        Endif
    Endif
    #
# Fin de programme / end program
    #
Else
Call MESSAGE("Erreur en initialisation: \RETCOD:"-num$([M:CFGF]RETCOD)-"GERR:"-num$(GERR)-"\Mes:"-GMESSAGE) From gesecran
Endif
Gosub CFGENDBAT From CFGLIBE
Call FERME_TRACE From LECFIC
GSERVEUR=0
Call LEC_TRACE From LECFIC  # Attention remet GERR à 0
Close Local Mask
End

