#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBLA","UTIRECBLA",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If dim(DOSSIER)<1
 Local Char DOSSIER(GLONADP)
 DOSSIER = nomap
Endif

If clalev([F:HAE])=0 : Local File =DOSSIER+".GACCENTRY"     [HAE] : Endif
If clalev([F:DAE])=0 : Local File =DOSSIER+".GACCENTRYD"    [DAE] : Endif
If clalev([F:DAA])=0 : Local File =DOSSIER+".GACCENTRYA"    [DAA] : Endif
If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif
If clalev([F:PER])=0 : Local File =DOSSIER+".PERIOD"        [PER] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:GAC])=0 : Local File =DOSSIER+".GACCOUNT"      [GAC] : Endif
If clalev([F:BLA])=0 : Local File =DOSSIER+".BALANA"        [BLA] : Endif
If clalev([F:TCU])=0 : Local File =DOSSIER+".TABCUR"        [TCU] : Endif
If clalev([F:FGR])=0 : Local File =DOSSIER+".FACGROUP"      [FGR] : Endif
If clalev([F:CCE])=0 : Local File =DOSSIER+".CACCE"         [CCE] : Endif     # Pour les ANV
If clalev([F:FIY2])=0 : Local File =DOSSIER+".FISCALYEAR"   [FIY2] : Endif    # Pour les ANV
If clalev([F:DIE])=0 : Local File =DOSSIER+".GDIE"          [DIE] : Endif

If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0 : Local File =DOSSIER+".GLED"          [LED] : Endif
If clalev([F:COA])=0 : Local File =DOSSIER+".GCOA"          [COA] : Endif
If clalev([F:CLS])=0 : Local File =DOSSIER+".GACCCLS"       [CLS] : Endif

If clalev([F:HAT])=0 : Local File =DOSSIER+".GACCTMP"        [HAT] : Endif
If clalev([F:DAT])=0 : Local File =DOSSIER+".GACCTMPD"       [DAT] : Endif

Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Call SETMAINREF([M:DIA]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
Return

$EXEC
Call RECUPBLA([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]LEDTYP,
&             [M:DIA]EXERCICE,[M:DIA]DEVISE,[M:DIA]BALANA,[M:DIA]COMPTE,[M:DIA]CLCRAN,GSERVEUR,0)
TRA = 1
Return

##########################################################################################################
$INISOC
Local Integer LNBSOC : LNBSOC=nbrecord([F:CPY])
GDIMSOC=LNBSOC+20
Global Char    GSOC(GLONCPY)(1..GDIMSOC)
Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
Global Integer GEXEAN(1..GDIMSOC,1..10)
Return

##########################################################################################################
Subprog RECUPBLA2(DOSSIER,SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,CLCRAN,BATCH,DIRECT)
Value Char    DOSSIER
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer CLCRAN
Value Integer BATCH
Value Integer DIRECT

If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0 : Local File =DOSSIER+".GLED"          [LED] : Endif
If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif  # Utile pour EXEAN
If clalev([F:CCE])=0 : Local File =DOSSIER+".CACCE"         [CCE] : Endif  # Utile pour SETGLBDIE
If clalev([F:DIE])=0 : Local File =DOSSIER+".GDIE"          [DIE] : Endif  # Utile pour RAN

If clalev([F:ADW9])=0 : Local File =DOSSIER+".ADOVAL"        [ADW9] : Endif
GRANA =1
Read [ADW9]ADW0 = "";"";"FRWANA"
If !fstat : GRANA = val([F:ADW9]VALEUR) : Endif

Local Integer ISOC
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 Gosub INISOC
Endif

Call LEC_CPY(SOCIETE) From CPTLEC
Local Integer IGCM
IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
If !IGCM
 If GNBSOC<>nbrecord([F:CPY]) : Gosub INISOC : Endif
 Call GLOBVAR From SETGLBGCM
Endif

Call GLOBVAR From SETGLBLED
If GRANA=2
 Call GLOBVAR From SETGLBDIE
 Call EXEAN From GLOBCPT
Endif

Goto RECUP

##########################################################################################################
Subprog RECUPBLA(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,CLCRAN,BATCH,DIRECT)
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer CLCRAN
Value Integer BATCH
Value Integer DIRECT    : # Paramètres de récup non saisis

Local Char DOSSIER(GLONADP)
DOSSIER = nomap

$RECUP
Gosub OUVRE

# Indice de travail
Local Integer MAXPER, MAXDEV
MAXPER=func AFNC.ACTIV("PER")
MAXDEV = nbrecord([TCU])

# Variable pour le filtre standard
Local Char   FILTECT(250)(0..4)
Local Integer IFILE

# Variable générale
Local Integer ISOC               # Indice de société sous GSOC
Local Date    DATDEB , DATFIN    # Date début et fin d'exercice

# Variable commune de travails
Local Char    DEVBAL(GLONCUR) , SITBAL(GLONFCY)

Local Integer TEST            # Variable qui permet d'ajouter des éléments dans la trace.
Local Integer FLGL            # Flag de différence entre Vérification GL et Vérification Equilibre
Local Integer OK              # Flag pour le controle de mono-société.
Local Integer ANOM            # Nombre d'anomalies rencontrées
Local Integer I,J,K

Local Integer AXE
Local Char    BALAXE(GLONDIE) , SECTION(GLONCCE)

# Variables : Feature 79527 - SP2US26
Local Char   FILTHAT(250)(0..4)
Local Integer IFILH

######################### Trace détaillée si TEST=1
TEST  = 0

#-- Vérification d'équilibre : Pas de critère sur compte
If BALANA=1 : COMPTE = "" :  Endif

If !(BATCH | DIRECT)
 If BALANA=3
  Call OUVRE_TRACE(mess(73,116,1)) From LECFIC        # Récupération balance analytique
 Else
  Call OUVRE_TRACE(mess(74,116,1)) From LECFIC        # Vérification balance analytique
 Endif
Endif

If !TEST & BALANA=3 & !DIRECT
 Call MONOCPY(SOCIETE, OK) From AX3MONO # <JFL>
 If !OK : Goto FIN : Endif
Endif

GSOCIETE = [L]SOCIETE
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
If SOCIETE<>[F:FIY]CPY | [L]LEDTYP<>[F:FIY]LEDTYP | EXERCICE<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = SOCIETE;LEDTYP;EXERCICE
 If fstat
  Call ECR_TRACE(SOCIETE-num$(EXERCICE)-mess(52,116,1),1) From GESECRAN     # Exercice incorrect
  ANOM = 1 : Goto FIN
 Endif
Endif
DATDEB = [F:FIY]FIYSTR
DATFIN = [F:FIY]FIYEND
ISOC = find(SOCIETE,GSOC(1..GNBSOC))

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED(LEDTYP-1)) From CPTLEC
Call LEC_COA([F:LED]COA) From CPTLEC

#-- Feature 79527 - SP2US26
Gosub VERF_HAT
Read [LNK] First
If !fstat
 If BALANA=3
  Call ECR_TRACE(mess(186,123,1)+"."-mess(49,114,1),1) From GESECRAN
  Goto FIN
 Else
  Call ECR_TRACE(mess(43,187,1)+"."-mess(49,114,1),-1) From GESECRAN
 Endif
Endif

Case BALANA
 When 1
  FLGL = 0 : Gosub TSTBAL
 When 2
  FLGL = 1 : Gosub TSTBAL
 When 3
  Gosub RECBAL
Endcase

$FIN
If BALANA=3 & !DIRECT
 Call MULTICPY(SOCIETE) From AX3MONO # <JFL>
Endif
If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC
Endif
End


############################################################################################################
#-- Resynchronisation de la balance
############################################################################################################
$RECBAL

# Variable pour le filtre de pagination (gestion snapshot too old)
Local Char    FILTPAG(250)(0..4)
Local Integer IFILP
Local Char    CPTDEB(GLONGAC),TRSDEB(GLONBPR),CCEDEB(GLONCCE)(1..9)
Local Char    CPTCUR(GLONGAC),TRSCUR(GLONBPR),CCECUR(GLONCCE)(1..9)
Local Integer FLCCE(1..9), RGCLE

# Variable pour le filtre de RAZ balance
Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

#-- Variable pour la re-synchronisation des montants
Local Decimal DEB1(1..MAXDEV,0..MAXPER) , CRE1(1..MAXDEV,0..MAXPER)      #-- Montants Lignes Compte/Tiers (Devise Transaction)
Local Decimal DEB2(1..MAXDEV,0..MAXPER) , CRE2(1..MAXDEV,0..MAXPER)      #-- Montants Lignes Compte/Tiers (Devise Référentiel)
Local Decimal CDEB1(1..MAXDEV,0..MAXPER) , CCRE1(1..MAXDEV,0..MAXPER)    #-- Cumuls Lignes Tiers (Devise Transaction)
Local Decimal CDEB2(1..MAXDEV,0..MAXPER) , CCRE2(1..MAXDEV,0..MAXPER)     #-- Cumuls Lignes Tiers (Devise Référentiel)

#-- Stockage du nombre & intitulé de devises parcourues (Mnts Lignes + Cumuls Lignes Tiers)
Local Integer NBDEV, CNBDEV
Local Char    TBDEV(GLONCUR)(1..MAXDEV),CTBDEV(GLONCUR)(1..MAXDEV)

#-- Variable pour stocker les autres valeurs
Local Integer BALREP, BALFIY
Local Char    BALCPY(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BALBPR(GLONBPR), BALCUR(GLONCUR), PARTNER(GLONBPR)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)

#-- Paramètres d'optimisation des boucles pour éviter le vieux snapshot too old
Local Integer NBECR, TOTECR, ECRMAX  : ECRMAX = 10000     # Nombre pièces à re-synchroniser
Local Integer NBCPT, TOTCPT, CPTMAX  : CPTMAX = 200       # Nombres comptes re-synchroniser
Local Integer STOP


Local Integer NBAXI                # Nombre d'axe pour le référentiel
Local Integer FLSOC,FLSIT,FLDEV    # Flag de travail
Local Integer K,IDEV

#-- A-nouveaux : A revoir
Local Integer ANVIND
Local Decimal ANVDEB(0..9) , ANVCDT(0..9) , ANVDEBLED(0..9) , ANVCDTLED(0..9)
Local Decimal TEMPAMT, TEMPQTY
Local Date  DATDEB2
Local Char    SECTION(GLONCCE)
Local Integer ICR, RANA, SVG_RAN, R_ANA, NUMAXE, EXERC
#--

#-- Information sur le nombres d'axes à gérer
Call INDLED([F:GCM]LED(LEDTYP-1),"",I,J) From CPTDIV
NBAXI = GLEDDIENBR(I)
If !NBAXI : Return : Endif

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(73,116,1),0) From GESECRAN                                    # Récupération balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                             # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                      # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                    # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                               # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                            # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                            # Nature
Endif

#-- Début récupération
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- Remise à zéro
Call ECR_TRACE(mess(149,124,1),0) From GESECRAN
Gosub RAZBAL

#-- Information sur la devise
If DEVISE=""
 FLDEV = 0
Else
 FLDEV = 1
Endif

#-- Récupération par site
If TOUSITE=2 or SITE=""
 If TOUSITE=2
  FLSOC = 1 : FLSIT = 1
 Else
  FLSOC = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITE = [F:FCY]FCY
  Gosub BALSIT
 Next
Else
 FLSOC = 0 : FLSIT = 1
 Gosub BALSIT
Endif
Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin récupération
Return


$BALSIT
DATDEB2 = DATDEB
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAA]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB2)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

Filter [DAA] Where evalue(FILTECT)
Look [DAA] First
If fstat : Return : Endif

Case NBAXI
 When 1
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);ACCNUM;ANALIN
  RGCLE = 6
 When 2
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);ACCNUM;ANALIN
  RGCLE = 7
 When 3
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);ACCNUM;ANALIN
  RGCLE = 8
 When 4
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);ACCNUM;ANALIN
  RGCLE = 9
 When 5
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);ACCNUM;ANALIN
  RGCLE = 10
 When 6
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);ACCNUM;ANALIN
  RGCLE = 11
 When 7
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);ACCNUM;ANALIN
  RGCLE = 12
 When 8
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);ACCNUM;ANALIN
  RGCLE = 13
 When 9
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);CCE(8);ACCNUM;ANALIN
  RGCLE = 14
Endcase

TOTECR = 0
TOTCPT = 0
CPTDEB = ""
TRSDEB = ""
For I=1 To 9
 Raz CCEDEB(I)
 Raz FLCCE(I)
Next

#RecuBAL: RAZREP

#-- Link GACCOUNT & GACCENTRYD & GACCENTRY
Link [DAA] With [GAC]GAC0~=[F:DAA]COA;[F:DAA]ACC, [HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&               [DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTECT)

#-- Boucle optimisée pour éviter le snapshot too old tout en utilisant les index
Gosub SET_FIRST From TRTFIRST
$BOUCLE_BAL
NBECR  = 0
NBCPT  = 0
STOP = 0
Raz FILTPAG, IFILP

J=NBAXI
While J>0
 If FLCCE(J)
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:DAA]BPR="'+TRSDEB+'"'," & ") From GOBJSUB
  For I=1 To J-2
   Call ADDCRIT(FILTPAG,IFILP,"CCE("+num$(I)+")",'[F:DAA]CCE('+num$(I-1)+')="'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Next
  Call ADDCRIT(FILTPAG,IFILP,"CCE("+num$(I)+")",'[F:DAA]CCE('+num$(I-1)+')>"'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Break
 Endif
 J-=1
Wend
If J=0
 If TRSDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:DAA]BPR>"'+TRSDEB+'"'," & ") From GOBJSUB
 Elsif CPTDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC>"'+CPTDEB+'"'," & ") From GOBJSUB
 Endif
Endif

If FILTPAG="" : FILTPAG="1=1" : Endif

#-- Ligne de pièces analytique
For [LNK]CLE(4) Where evalue(FILTPAG) : # Société + site + compte
 BALACC = [F:GAC]ACC
 If TRSDEB="" & [F:GAC]SAC=2
  Gosub RAZCOL
 Endif

 For [LNK]CLE(5)

  If NBCPT>=CPTMAX or NBECR>=ECRMAX
   STOP = 1
   CPTDEB = CPTCUR
   TRSDEB = TRSCUR
   For I=1 To NBAXI
    Assign "CCEDEB("+num$(I)+")" With evalue("CCECUR("+num$(I)+")")
   Next
   FLCCE(NBAXI)=1
   Break 2
  Endif
  CPTCUR = [F:DAA]ACC
  TRSCUR = [F:DAA]BPR

  Gosub BALCPT

  NBCPT += 1
 Next
Next

TOTCPT += NBCPT
TOTECR += NBECR
If TEST : Call ECR_TRACE(time$-"break"-num$(TOTCPT)-num$(TOTECR),0) From GESECRAN : Endif
If STOP
 Goto BOUCLE_BAL
Else
 J=NBAXI
 While J>1
  If FLCCE(J)
   FLCCE(J) = 0
   FLCCE(J-1) = 1
   Goto BOUCLE_BAL
  Endif
  J-=1
 Wend
 If FLCCE(1)
  FLCCE(1) = 0
  Goto BOUCLE_BAL
 Elsif TRSDEB<>""
  TRSDEB = ""
  Goto BOUCLE_BAL
 Endif
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [DAA]
Return

$BALCPT
For [LNK]CLE(RGCLE)
 Raz DEB1, DEB2
 Raz CRE1, CRE2
 Raz NBDEV, TBDEV

 For [LNK]CLE
  NBECR += 1
  If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
   Call INDLED([F:DAA]LED,"",I,J) From CPTDIV
   If sigma(0,GLEDDIENBR(I)-1,[F:DAA]CCE(indcum))<>"" | GLEDDIEIPT(I)=2
    If !FLDEV | DEVISE=[F:HAE]CUR
     IDEV = find([F:HAE]CUR,TBDEV(1..NBDEV))
     If !IDEV : NBDEV += 1 : TBDEV(NBDEV) = [F:HAE]CUR : IDEV = NBDEV : Endif
     Gosub CUMCPT
    Endif
   Endif
  Endif
  For I=1 To NBAXI
    Assign "CCECUR("+num$(I)+")" With evalue("[F:DAA]CCE("+num$(I-1)+")")
  Next
 Next
 If NBDEV
  Gosub MAJCPT
 Endif
Next
Return

$CUMCPT
If [F:DAE]FIY = EXERCICE
 If [F:DAA]SNS>0
   DEB1(IDEV,[F:DAE]PER)  += [F:DAA]AMTCUR
   DEB2(IDEV,[F:DAE]PER)  += [F:DAA]AMTLED
 Else
  CRE1(IDEV,[F:DAE]PER)  += [F:DAA]AMTCUR
  CRE2(IDEV,[F:DAE]PER)  += [F:DAA]AMTLED
 Endif
Endif
Return

$MAJCPT
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [BLA]
BALREP = 0
BALCPY = SOCIETE
BALACC = CPTCUR
BALBPR = TRSCUR
BALFIY = EXERCICE

For I=1 To NBAXI
 Assign "BALSEC"+num$(I) With evalue("[F:DAA]CCE("+num$(I-1)+")")
Next
For I=NBAXI+1 To 9
 Assign "BALSEC"+num$(I) With ""
Next

If TEST : Call ECR_TRACE(time$-"bla"-SITE-CROISE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif

Gosub CREBAL
If GOK<1 : Goto AB_TR2 : Endif

If GRANA=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE & CLCRAN
 Gosub RAN
 If GOK<1 : Goto AB_TR2 : Endif
 If BALACC<>""
  BALFIY = EXERCICE+1
  BALREP = 1
  Gosub CREBAL
  If GOK<1 : Goto AB_TR2 : Return : Endif
 Endif
Endif
##
Commit
Return

$RAN
Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
 If [F:LED]EQLRANANA=2
  If [F:COA]ACCMIS(10)=""
   # Compte de résultat non défini
   GOK = 0 : Call ECR_TRACE(mess(106,106,1)-"("+[F:COA]COA+")",1) From GESECRAN : Return
  Endif
  BALACC = [F:COA]ACCMIS(10)
  BALBPR = ""
  Raz BALSEC1,BALSEC2,BALSEC3,BALSEC4,BALSEC5,BALSEC6,BALSEC7,BALSEC8,BALSEC9
 Else
  BALACC = ""
 Endif
Else
 Local Integer COND
 For AXE=1 To NBAXI
  BALAXE  = [F:DAA]DIE(AXE-1)
  SECTION = [F:DAA]CCE(AXE-1)
  If BALAXE<>"" & SECTION<>""
   J = find(BALAXE,GDIECOD(1..GDIENBR))
   [L]COND = 0
   If J : If GDIEPRJ(J)=2 : [L]COND=1 : Endif : Endif
   If [L]COND
    SECTION = ""
   Else
    Call LEC_CCE(SECTION,BALAXE) From CPTLEC
    If [F:CCE]FRW<>2
     SECTION = ""
    Endif
   Endif
  Endif
  Assign "BALSEC"+num$(AXE) With SECTION
 Next AXE
Endif
Return

############################################################################################################
#-- Ré écriture de la Balance
############################################################################################################
$CREBAL
For IDEV=1 To NBDEV
 If DEVISE="" or DEVISE=TBDEV(IDEV)
  BALCUR = TBDEV(IDEV)
  # MAJ Société
  If FLSOC
   BALFCY = ""
   Gosub MAJBAL
   If GOK<1 : Return : Endif
  Endif
  # MAJ Site
  If FLSIT
   BALFCY = [F:DAA]FCYLIN
   Gosub MAJBAL
   If GOK<1 : Return : Endif
  Endif
 Endif
Next IDEV
Return

$MAJBAL
If BALACC<>""
 PARTNER = BALBPR
 Gosub MAJ_BAL
 If GOK = 0 : Return : Endif
 ## Si le compte est auxiliarisé, écriture de l'enregistrement correspondant au cumul du collectif (tous tiers confondus)
 If [F:GAC]SAC = 2
  PARTNER = ""
  Gosub MAJ_BAL
  If GOK = 0 : Return : Endif
 Endif
Endif
Return

$MAJ_BAL
Readlock [BLA]BLA0 = [L]LEDTYP;BALCPY;BALFCY;BALFIY;BALACC;PARTNER;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
If fstat
 Raz [F:BLA]
 [F:BLA]LEDTYP = [L]LEDTYP
 [F:BLA]CPY    = BALCPY
 [F:BLA]FCY    = BALFCY
 [F:BLA]FIY    = BALFIY
 [F:BLA]ACC    = BALACC
 [F:BLA]BPR    = PARTNER
 [F:BLA]CCE1   = BALSEC1
 [F:BLA]CCE2   = BALSEC2
 [F:BLA]CCE3   = BALSEC3
 [F:BLA]CCE4   = BALSEC4
 [F:BLA]CCE5   = BALSEC5
 [F:BLA]CCE6   = BALSEC6
 [F:BLA]CCE7   = BALSEC7
 [F:BLA]CCE8   = BALSEC8
 [F:BLA]CCE9   = BALSEC9
 [F:BLA]CUR    = BALCUR
 [F:BLA]ACCNUM = uniqid([F:BLA])
 [F:BLA]LED    = [F:DAA]LED
 [F:BLA]COA    = [F:DAA]COA
 [F:BLA]CURLED = [F:DAA]CURLED
 For I=1 To 9
  Assign "[F:BLA]DIE("+num$(I-1)+")"  With evalue("[F:DAA]DIE("+num$(I-1)+")")
 Next
 Gosub CALBAL
 Write [BLA]
Else
 [F:BLA]LED    = [F:DAA]LED
 [F:BLA]COA    = [F:DAA]COA
 [F:BLA]CURLED = [F:DAA]CURLED
 For I=1 To 9
  Assign "[F:BLA]DIE("+num$(I-1)+")"  With evalue("[F:DAA]DIE("+num$(I-1)+")")
 Next
 Gosub CALBAL
 Rewrite [BLA]
Endif
If fstat
 GOK=0 : Call FSTA("BLA") From GLOCK : Return
Endif
Return


$CALBAL
If BALREP
 For K=0 To MAXPER-1
  [F:BLA]DEB(0)    += DEB1(IDEV,K)
  [F:BLA]CDT(0)    += CRE1(IDEV,K)
  [F:BLA]DEBLED(0) += DEB2(IDEV,K)
  [F:BLA]CDTLED(0) += CRE2(IDEV,K)
 Next K
 If [F:BLA]DEB(0)>[F:BLA]CDT(0)
  [F:BLA]DEB(0) = [F:BLA]DEB(0) - [F:BLA]CDT(0)
  [F:BLA]CDT(0) = 0
 Else
  [F:BLA]CDT(0) = [F:BLA]CDT(0) - [F:BLA]DEB(0)
  [F:BLA]DEB(0) = 0
 Endif
 If [F:BLA]DEBLED(0)>[F:BLA]CDTLED(0)
  [F:BLA]DEBLED(0) = [F:BLA]DEBLED(0) - [F:BLA]CDTLED(0)
  [F:BLA]CDTLED(0) = 0
 Else
  [F:BLA]CDTLED(0) = [F:BLA]CDTLED(0) - [F:BLA]DEBLED(0)
  [F:BLA]DEBLED(0) = 0
 Endif
Else
 For K=0 To MAXPER-1
  [F:BLA]DEB(K)    += DEB1(IDEV,K)
  [F:BLA]CDT(K)    += CRE1(IDEV,K)
  [F:BLA]DEBLED(K) += DEB2(IDEV,K)
  [F:BLA]CDTLED(K) += CRE2(IDEV,K)
 Next K
Endif
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

############################################################################################################
#- Collectif
############################################################################################################
######################################################
$RAZCOL
If TEST : Call ECR_TRACE("raz collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Raz CDEB1, CDEB2
Raz CCRE1, CCRE2
Raz CNBDEV, CTBDEV
Return


#########################################################################################################
## Vérification de la balance
#########################################################################################################
$TSTBAL
ANOM = 0

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(74,116,1),0) From GESECRAN                                     # Vérification balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                              # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                       # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                     # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                                # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                             # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                             # Nature
Endif
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Début vérification
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub VERIF
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin Vérification
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN                          # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN                                     # Aucune anomalie
Endif
Return

$VERIF
Local Integer FLG1, FLG2

Local Integer MAXSIT
MAXSIT = 5

# Ajout du filtre sur les sites financiers
Link [FGR] With [FCY]FCY0=[F:FGR]FCY
& As [LFGR]
& Where [FGR]CPY=SOCIETE & [FCY]FINFLG=2

For [LFGR]FGR0
 MAXSIT += 1
Next


Local Char    TBCUR(GLONCUR)(1..MAXDEV)
Local Char    TBSIT(GLONFCY)(1..MAXSIT)
Local Char    TIERS(GLONBPR)

# Montants transaction
Local Decimal BALDEB(0..MAXPER) , BALCRE(0..MAXPER)
Local Decimal COLDEB(0..MAXPER) , COLCRE(0..MAXPER)
Local Decimal GLDEB(1..MAXDEV,0..MAXPER) , GLCRE(1..MAXDEV,0..MAXPER)
Local Decimal SOCDEB(1..MAXDEV,0..MAXPER) , SOCCRE(1..MAXDEV,0..MAXPER)
Local Decimal SITDEB(1..MAXSIT,1..MAXDEV,0..MAXPER) , SITCRE(1..MAXSIT,1..MAXDEV,0..MAXPER)

# Montant Référentiel
Local Decimal BALDEBLED(0..MAXPER) , BALCRELED(0..MAXPER)
Local Decimal COLDEBLED(0..MAXPER) , COLCRELED(0..MAXPER)
Local Decimal GLDEBLED(1..MAXDEV,0..MAXPER) , GLCRELED(1..MAXDEV,0..MAXPER)
Local Decimal SOCDEBLED(1..MAXDEV,0..MAXPER) , SOCCRELED(1..MAXDEV,0..MAXPER)
Local Decimal SITDEBLED(1..MAXSIT,1..MAXDEV,0..MAXPER) , SITCRELED(1..MAXSIT,1..MAXDEV,0..MAXPER)

Local Integer ANREEL,P,IND,POIERR
Local Integer NBCUR, NBSIT

If FLGL
 If EXERCICE>1
  Read [FIY]FIY0 = SOCIETE;LEDTYP;EXERCICE-1
  If !fstat & [FIY]FIYSTA >2
   # Les montants de l'indice 0 de la BALANCE ne proviennent pas d'AN reconstitués mais d'AN réels...
   ANREEL = 1
  Else
   ANREEL = 0
  Endif
 Else
  ANREEL = 0
 Endif
 Gosub VERECT
Else
 Gosub EQLBAL
Endif
Return

###############################################
## Vérif balance - grand-livre
###############################################

## Phase 1, écritures

$VERECT
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAA]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAA]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

NBCUR = 0
NBSIT = 0

Filter [BLA]

Link [DAA] With [GAC]GAC0~=[F:DAA]COA;[F:DAA]ACC, [F:HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&                          [F:DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTECT)
&   Order By Key CLE = [F:DAA]ACC;[F:DAA]BPR;[F:DAA]FCYLIN;[F:DAA]ACCDAT;[F:DAA]ACCNUM

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(1)   : # Compte
 COMPTE = [F:DAA]ACC
 Raz SITDEB, SITCRE, SITDEBLED, SITCRELED
 For [LNK]CLE(2)  : # Tiers
  TIERS = [F:DAA]BPR
  Raz SOCDEB, SOCCRE, SOCDEBLED,SOCCRELED
  For [LNK]CLE(3) : # Site
   Raz GLDEB, GLCRE, GLDEBLED, GLCRELED
   SITBAL = [F:DAA]FCYLIN
   For [LNK]CLE   : # Détail
    If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
     K = find([F:DAA]CUR,TBCUR(1..NBCUR))
     If !K
      NBCUR += 1 : K = NBCUR
      TBCUR(NBCUR) = [F:DAA]CUR
     Endif
     If [F:DAA]SNS>0
      GLDEB(K,[F:DAE]PER)    += [F:DAA]AMTCUR
      GLDEBLED(K,[F:DAE]PER) += [F:DAA]AMTLED
     Else
      GLCRE(K,[F:DAE]PER)    += [F:DAA]AMTCUR
      GLCRELED(K,[F:DAE]PER) += [F:DAA]AMTLED
     Endif
    Endif
   Next
   # Vérif pour 1 compte  1 tiers et 1 site
   Gosub VER_BPR_SIT
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SOCDEB(K,P)    += GLDEB(K,P)
     SOCCRE(K,P)    += GLCRE(K,P)
     SOCDEBLED(K,P) += GLDEBLED(K,P)
     SOCCRELED(K,P) += GLCRELED(K,P)
    Next K
   Next P
   J = find(SITBAL,TBSIT(1..NBSIT))
   If !J
    NBSIT += 1 : J = NBSIT
    TBSIT(NBSIT) = SITBAL
   Endif
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SITDEB(J,K,P)    += GLDEB(K,P)
     SITCRE(J,K,P)    += GLCRE(K,P)
     SITDEBLED(J,K,P) += GLDEBLED(K,P)
     SITCRELED(J,K,P) += GLCRELED(K,P)
    Next K
   Next P
  Next
  # Vérif pour 1 compte  1 tiers et société
  If TOUSITE=2 : Gosub VER_BPR_SOC : Endif
 Next
 # Vérif pour 1 compte collectif, société et site
 If [F:GAC]SAC=2
  Gosub VER_CPT
 Endif
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [DAA]
Return

###############################################
## Sous-programmes d'erreurs
###############################################
$VER_BPR_SIT
If TIERS="" &  [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SIT"-SITBAL-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
 # If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif

 Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
 For [BLA]BLA0 Where [F:BLA]LEDTYP=[L]LEDTYP & [F:BLA]CPY=SOCIETE & [F:BLA]FCY=SITBAL & [F:BLA]FIY=EXERCICE & [F:BLA]ACC=COMPTE & [F:BLA]BPR=TIERS & [F:BLA]CUR=DEVBAL
  For P=IND To MAXPER-1
   BALDEB(P)     += [F:BLA]DEB(P)
   BALCRE(P)     += [F:BLA]CDT(P)
   BALDEBLED(P)  += [F:BLA]DEBLED(P)
   BALCRELED(P)  += [F:BLA]CDTLED(P)
  Next P
 Next

 For P=IND To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If BALDEB(P)<>GLDEB(K,P) | BALCRE(P)<>GLCRE(K,P)             : FLG1=1 : Endif
  If BALDEBLED(P)<>GLDEBLED(K,P) | BALCRELED(P)<>GLCRELED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   If P=0
    Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
   Else
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                       #  Période
   Endif

   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,GLDEB(K,P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,GLCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel
    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,GLDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,GLCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif

  Endif
 Next P
Next K
Return

$VER_BPR_SOC
If TIERS="" &  [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SOC"-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
 Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
 For [BLA]BLA0 Where [F:BLA]LEDTYP=[L]LEDTYP & [F:BLA]CPY=SOCIETE & [F:BLA]FCY="" & [F:BLA]FIY=EXERCICE & [F:BLA]ACC=COMPTE & [F:BLA]BPR=TIERS & [F:BLA]CUR=DEVBAL
  For P=IND To MAXPER-1
   BALDEB(P)     += [F:BLA]DEB(P)
   BALCRE(P)     += [F:BLA]CDT(P)
   BALDEBLED(P)  += [F:BLA]DEBLED(P)
   BALCRELED(P)  += [F:BLA]CDTLED(P)
  Next P
 Next

 For P=IND To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If BALDEB(P)<>SOCDEB(K,P) | BALCRE(P)<>SOCCRE(K,P)             : FLG1=1 : Endif
  If BALDEBLED(P)<>SOCDEBLED(K,P) | BALCRELED(P)<>SOCCRELED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   If P=0
    Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
   Else
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
   Endif
   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,SOCDEB(K,P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,SOCCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,SOCDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,SOCCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif
  Endif
 Next P
Next K
Return


$VER_CPT
If TEST : Call ECR_TRACE(time$-"VER_CPT"-COMPTE,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif

 Raz SOCDEB, SOCCRE, SOCDEBLED, SOCCRELED
 For J=1 To NBSIT
  SITBAL = TBSIT(J)
  Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
  For [BLA]BLA0 Where [F:BLA]LEDTYP=[L]LEDTYP & [F:BLA]CPY=SOCIETE & [F:BLA]FCY=SITBAL & [F:BLA]FIY=EXERCICE & [F:BLA]ACC=COMPTE & [F:BLA]BPR="" & [F:BLA]CUR=DEVBAL
   For P=IND To MAXPER-1
    BALDEB(P)     += [F:BLA]DEB(P)
    BALCRE(P)     += [F:BLA]CDT(P)
    BALDEBLED(P)  += [F:BLA]DEBLED(P)
    BALCRELED(P)  += [F:BLA]CDTLED(P)
   Next P
  Next

  For P=IND To MAXPER-1
   SOCDEB(K,P)    += SITDEB(J,K,P)
   SOCCRE(K,P)    += SITCRE(J,K,P)
   SOCDEBLED(K,P) += SITDEBLED(J,K,P)
   SOCCRELED(K,P) += SITCRELED(J,K,P)

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If BALDEB(P)<>SITDEB(J,K,P) | BALCRE(P)<>SITCRE(J,K,P)             : FLG1=1 : Endif
   If BALDEBLED(P)<>SITDEBLED(J,K,P) | BALCRELED(P)<>SITCRELED(J,K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-SITBAL-COMPTE,POIERR) From GESECRAN            #  Erreur
    If P=0
     Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
    Else
     Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Endif
    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,SITDEB(J,K,P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SITCRE(J,K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,SITDEBLED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SITCRELED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

     ANOM += 1
    Endif
   Endif
  Next P
 Next J
 If TOUSITE=2   :# 17783

  If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
  Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
  For [BLA]BLA0 Where [F:BLA]LEDTYP=[L]LEDTYP & [F:BLA]CPY=SOCIETE & [F:BLA]FCY="" & [F:BLA]FIY=EXERCICE & [F:BLA]ACC=COMPTE & [F:BLA]BPR="" & [F:BLA]CUR=DEVBAL
   For P=IND To MAXPER-1
    BALDEB(P)     += [F:BLA]DEB(P)
    BALCRE(P)     += [F:BLA]CDT(P)
    BALDEBLED(P)  += [F:BLA]DEBLED(P)
    BALCRELED(P)  += [F:BLA]CDTLED(P)
   Next P
  Next

  For P=IND To MAXPER-1

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If BALDEB(P)<>SOCDEB(K,P) | BALCRE(P)<>SOCCRE(K,P)             : FLG1=1 : Endif
   If BALDEBLED(P)<>SOCDEBLED(K,P) | BALCRELED(P)<>SOCCRELED(K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE,POIERR) From GESECRAN            #  Erreur
    If P=0
     Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
    Else
     Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Endif

    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,SOCDEB(K,P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SOCCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,SOCDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SOCCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel
     ANOM += 1
    Endif
   Endif
  Next P
 Endif
Next K
Return



###############################################
## Equilibre de la balance
###############################################

$EQLBAL
Raz FILTECT, IFILE
Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:BLA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:BLA]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FIY",'[F:BLA]FIY='+num$(EXERCICE)," & ") From GOBJSUB
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:BLA]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
If [F:LED]FCYBAL=2
 If TOUSITE<>2
  Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:BLA]FCY="'+SITE+'"'," & ") From GOBJSUB
 Endif
Else
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:BLA]FCY=""'," & ") From GOBJSUB
Endif

Link [BLA] With [GAC]GAC0~=[F:BLA]COA;[F:BLA]ACC
&   As [LNK]
&   Where evalue(FILTECT)
&   Order By Key CLE = [F:BLA]LEDTYP;[F:BLA]CPY;[F:BLA]CUR;[F:BLA]FCY;[F:BLA]ACC;[F:BLA]BPR;[F:BLA]ACCNUM

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(3) : # Devise
 DEVBAL = [F:BLA]CUR
 POIERR = 1  : # Bug 7889 : controles bloquants uniquement en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 For [LNK]CLE(4) : # Site
  SITBAL = [F:BLA]FCY
  Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
  For [LNK]CLE(5) : # Compte
   COMPTE = [F:BLA]ACC
   Raz COLDEB, COLCRE, COLDEBLED, COLCRELED
   For [LNK]CLE : # Tiers
    TIERS = [F:BLA]BPR
    If TIERS=""
     For P=0 To MAXPER-1
      BALDEB(P) += [F:BLA]DEB(P)
      BALCRE(P) += [F:BLA]CDT(P)
      BALDEBLED(P) += [F:BLA]DEBLED(P)
      BALCRELED(P) += [F:BLA]CDTLED(P)
     Next P
     If [F:GAC]SAC=2
      Gosub BAL_COL
     Endif
    Else
     For P=0 To MAXPER-1
      COLDEB(P) += [F:BLA]DEB(P)
      COLCRE(P) += [F:BLA]CDT(P)
      COLDEBLED(P) += [F:BLA]DEB(P)
      COLCRELED(P) += [F:BLA]CDT(P)
     Next P
    Endif
   Next
  Next
  Gosub BAL_SIT
 Next
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [BLA]
Return

$BAL_SIT
If TEST : Call ECR_TRACE(time$-"BAL_SIT"-DEVBAL-SITBAL,0) From GESECRAN : Endif
For P=0 To MAXPER-1

 # Montant Transaction et Montant référentiel
 Raz FLG1, FLG2
 If BALDEB(P)<>BALCRE(P)       : FLG1=1 : Endif
 If BALDEBLED(P)<>BALCRELED(P) : FLG2=1 : Endif

 If FLG1 or FLG2
  Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
  Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-mess(64,116,1),POIERR) From GESECRAN            # Balance déséquilibrée
  If P=0
   Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
  Else
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        # Période
  Endif

  If FLG1
   Call LEC_TCU(DEVBAL) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(65,116,1))
&                +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+DEVBAL+"   "
&                +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Total Balance
  Endif

  If FLG2
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel
   ANOM += 1
  Endif
 Endif
Next P
Return

$BAL_COL
If TEST : Call ECR_TRACE(time$-"BAL_COL"-DEVBAL-SITBAL-COMPTE,0) From GESECRAN : Endif
For P=0 To MAXPER-1
 # Montant Transaction et Montant référentiel
 Raz FLG1, FLG2
 If COLDEB(P)<>COLCRE(P)       : FLG1=1 : Endif
 If COLDEBLED(P)<>COLCRELED(P) : FLG2=1 : Endif

 If FLG1 or FLG2
  Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
  Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-mess(64,116,1),POIERR) From GESECRAN       # Balance déséquilibrée
  If P=0
   Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
  Else
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                          # Période
  Endif

  If FLG1
   Call LEC_TCU(DEVBAL) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(65,116,1))
&                +format$("N:"+[F:TCU]CURFMT1,COLDEB(P))+" "+DEVBAL+"   "
&                +format$("N:"+[F:TCU]CURFMT1,COLCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Total Balance
  Endif

  If FLG2
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                +format$("N:"+[F:TCU]CURFMT1,COLDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                +format$("N:"+[F:TCU]CURFMT1,COLCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel
   ANOM += 1
  Endif
 Endif


Next P
Return



########################################
$RAZBAL

Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
#Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

If TOUSITE=2
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITBAL = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TR1
 Next
 SITBAL = ""
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 If SITE<>""
  SITBAL = SITE
 Else
  SITBAL = ""
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
Return

$TR1
If TEST : Call ECR_TRACE(time$-"raz n"-SITBAL,0) From GESECRAN : Endif
GOK = 1

Trbegin [BLA]
Delete [BLA] Where evalue(FILTBAL) & FIY=EXERCICE & FCY=SITBAL
If fstat=1
 GOK = -1 : GLOCK = "$BALANA" : Goto ROLL_TR1
Endif
Commit

#-- Gestion des à nouveaux
If GRANA=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE & CLCRAN

  Raz FILTBAL, IFILTA
  Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
  Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
  If COMPTE<>""
   Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
  Endif
  If DEVISE<>""
   Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
  Endif

  Trbegin [BLA]
   If TEST : Call ECR_TRACE(time$-"raz n+1"-DEVISE-CRBAL-SITBAL,0) From GESECRAN : Endif
   Update [BLA] Where FIY=EXERCICE+1 & evalue(FILTBAL) & FCY=SITBAL
&               With DEB(0)=0,CDT(0)=0,DEBLED(0)=0,CDTLED(0)=0
   If fstat
    GOK = 0 : Call FSTA("BLA") From GLOCK : Goto AB_TR1 : Return
   Endif
  Commit
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return


#-- Feature 79527 - SP2US26
$VERF_HAT
Raz FILTHAT, IFILH

Call ADDCRIT(FILTHAT,IFILH,"LEDTYP",'[F:DAT]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTHAT,IFILH,"CPY",'[F:DAT]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If SITE<>""
 Call ADDCRIT(FILTHAT,IFILH,"FCY",'[F:DAT]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTHAT,IFILH,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTHAT,IFILH,"ACC",'[F:DAT]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTHAT,IFILH,"CUR",'[F:DAT]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif


#-- Link GACCOUNT & GACCENTRY
Link [DAT] With [HAT]HAT0~=[F:DAT]TYP;[F:DAT]NUM As [LNK]
&              Where [F:HAT]FLG>=100 & evalue(FILTHAT)
Return

###################################################################################
###################################################################################
###################    Etiquette du masque          ###############################
###################################################################################
###################################################################################
########################################
Subprog AM_SOCIETE(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Filter [FIY] Where CPY=VALEUR & LEDTYP=GTYPANA & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
[M]EXERCICE = [F:FIY]FIYNUM
[M]DATDEB   = [F:FIY]FIYSTR
[M]DATFIN   = [F:FIY]FIYEND
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

########################################
Subprog AS_TOUSITE(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSITE = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End

########################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M:DIA]SOCIETE,3) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char LED(GLONLED),DEV(GLONCUR)
Local Integer ILED
Call LECLED([M:DIA]SOCIETE,VALEUR,LED,DEV) From CPTDIV
ILED = find(LED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M:DIA]COA = GLEDCOA(ILED)
End

########################################
Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Filter [FIY] Where CPY=[M]SOCIETE & LEDTYP=[M:DIA]LEDTYP & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 VALEUR = [F:FIY]FIYNUM
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
Endif
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;[M:DIA]LEDTYP;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : mkstat = 2 : End    # Exercice incorrect
Endif
If [F:FIY]FIYSTA=1
 GMESSAGE=mess(20,101,1) : mkstat=2 : End : # Exercice non ouvert
Elsif [F:FIY]FIYSTA>2
 Local Integer OK
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN : # Exercice clôturé
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End

########################################
Subprog C_DEVISE(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AS_BALANA(VALEUR)
Variable Integer VALEUR
End

Subprog C_BALANA(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:DIA]TOUSITE<>2
 Local Char CODLED(GLONLED), DEVLED(GLONCUR)
 Call LECLED([M:DIA]SOCIETE,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",[L]CODLED,"") From CONTOBJ
 If [F:LED]FCYBAL<>2
  ## CODLED : Le référentiel n'est pas coché 'Equilibre par site'
  GMESSAGE = mess(207,107,1)
  mkstat = 2 : End
 Endif
Endif
End

########################################
Subprog AS_CLCRAN(VALEUR)
Variable Integer VALEUR
If [M]BALANA<>3 : mkstat = 1 : End :Endif
End

Subprog C_CLCRAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local Integer OK
 # Etes-vous sûr de vouloir reconstituer les A-nouveaux
 OK = 2 : Call AVERTIR(mess(123,116,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End
