#<AdxTL>@(#)5.0.0.0 $Revision$
Call RAZDOS(0)
End

##########################
Subprog RAZDOS(SIMUL)
Value Integer SIMUL
Local Char VALEUR(30), PARAM(30)(1..2)
PARAM(1) = num$(SIMUL)
Call TRAITE_CHAR(VALEUR,PARAM,"","RAZDOS","RAZDOS",3,"") From GTRAITE
End

##########################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TITRE"       : Gosub TIT
Endcase
Return

##########################
$INIT
Local Char    APPLI(GLONADS) , ORDSYS(250) , ERM(200)
Local Integer OK , STAT , NBZONE
Local Char    FICHIER(GLONATB) , ZONE(GLONAVA)(1..100)
Local Integer I , J , K , DIME , TYP, SIMUL , ER , OKTRT
SIMUL = val(PARAM(1))
Local Mask SAIDOS [DIA]
Return

##########################
$TIT
TIT = mess(5,115,1) : # Remise à zéro d'un dossier
Return

##########################
$CONTROLE
If [M:DIA]DOSSIER="" : FIN = 1 : Return : Endif

APPLI = [M:DIA]DOSSIER

K = 1
If APPLI=nomap & GADONIX=2 : # Pas chez nous !
 K = 0
Else
 Local File =APPLI+".ADOVAL" [ADW_]
 Read [ADW_]ADW0 = "";"";"ADONIX"
 If !fstat & [F:ADW_]PARAM="2"
  K = 0
 Endif
 Close Local File [ADW_]
Endif
If !K
 #Opération impossible sur ce dossier
 #Call ERREUR("Ca va pas, non ??") From GESECRAN
 Call ERREUR(mess(112,125,1)-APPLI) From GESECRAN
 FIN = 1 : Return
Endif

If APPLI<>nomap & nomap<>GDOSX3
 Call ERREUR(mess(286,125,1)) From GESECRAN
 FIN = 1 : Return
Endif
Return

##########################
$EXEC

Gosub CONTROLE
If FIN=1 : Return  : Endif

# Remise à zéro d'un dossier
If nomap=APPLI
 Call MONO(OK) From AX3MONO
Else
 Call MONO(APPLI,OK) From DOSSUB
Endif
If !OK : FIN = 1 : Return : Endif

If !GSERVEUR
 Call OUINON(mess(166,100,1)+"\"+mess(167,100,1)-APPLI,OK) From GESECRAN
 # Etes-vous bien sûr....
 If OK<>2
  If nomap=APPLI
   Call MULTI(OK) From AX3MONO
  Else
   Call MULTI(APPLI) From DOSSUB
  Endif
  FIN = 1 : Return
 Endif
Endif

If !GSERVEUR
 Call TEMPON(mess(149,124,1)) From GESECRAN : # Remise à zéro en cours
 Call OUVRE_TRACE(mess(5,115,1)-APPLI) From LECFIC
Endif

If SIMUL
 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN
 # Simulation
Endif

TRA = 1

If APPLI=nomap
 Local File ATABLE [ATB] , ATABZON [ATZ]
Else
 Local File =APPLI+".ATABLE" [ATB] , =APPLI+".ATABZON" [ATZ]
Endif

# Tables remises à zéro

For [ATB] Where ZERO=2
 Call ECR_TRACE(mess(52,123,1)-[F:ATB]CODFIC,0) From GESECRAN
 # Remise à zéro de la table
 If !SIMUL
  If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",APPLI),0)>=0
   ORDSYS = "valfil -s -z"
   If [F:ATB]FLG130=2
    ORDSYS -= "-a"
   Endif
   ORDSYS -= APPLI-[F:ATB]CODFIC
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Endif
 Endif
Next ATB

# Champs remis à zéro

For [ATZ]CODZONE(1) Where ZERO=2
 FICHIER = [F:ATZ]CODFIC
 NBZONE = 0
 For [ATZ]CODZONE
  NBZONE += 1
  ZONE(NBZONE) = [F:ATZ]CODZONE
 Next ATZ
 Call ECR_TRACE(mess(52,123,1)-FICHIER,0) From GESECRAN
 # Remise à zéro de la table
 Call ECR_TRACE(mess(149,123,1)-":"-sigma(1,NBZONE,ZONE(indcum)+" "),0) From GESECRAN
 If !SIMUL
  OK = 1
  If APPLI=nomap
   If filinfo(filpath("FIL",FICHIER,"fde"),0)>=0
    Local File =FICHIER [AAA_]
   Else
    OK = 0
   Endif
  Else
   If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>=0
    Local File =APPLI+"."+FICHIER [AAA_]
   Else
    OK = 0
   Endif
  Endif
  If OK
   Call DEBTRANS From GLOCK
   Gosub TR1
   Close Local File [AAA_]
  Endif
 Endif
Next ATZ

# Compteurs X3 remis à 0

Call ECR_TRACE(mess(52,123,1)-"AVALNUM",0) From GESECRAN
If !SIMUL
 If APPLI=nomap
  Local File ACODNUM [ANM] , AVALNUM [AVN]
 Else
  Local File =APPLI+".ACODNUM" [ANM] , =APPLI+".AVALNUM" [AVN]
 Endif
 For [ANM]ANM0 Where ZERO=2
  Trbegin [AVN]
   Delete [AVN] Where CODNUM=[F:ANM]CODNUM
   If [F:ANM]SEQ=2 : # Sequence BDD => Razer le uniqid
    ER = 0
    #101730
    #If func AFNC.PARTSEP(ver$(0),2," ")>="16r.225"
    If func AFNC.PARTSEP(ver$(0),2," ")>="17r.218"
     #valfil –i no_sequence DOSSIER TABLE
     Call SYSTEME(adxmac(0),"valfil -i"-num$(1)-APPLI-[F:ANM]SEQTBL,"",ER) From ORDSYS
    Else
     Onerrgo ERRSQL
     Case GTYPDBA
      When 1 : # Oracle
       Execsql From "3" Sql "Drop Sequence "+APPLI+".SEQ_"+[F:ANM]SEQTBL
       Execsql From "3" Sql "Create Sequence "+APPLI+".SEQ_"+[F:ANM]SEQTBL+" start with 1"
       #dbgstr(128) = "drop Sequence SEQ_"+[F:ANM]SEQTBL
       #dbgstr(128) = "create Sequence SEQ_"+[F:ANM]SEQTBL+" start with 1"
      When 2 : # Sql server
       #Execsql From "5" Sql "Update dbo.SS_SEQUENCE set value=1 where name='"+[F:ANM]SEQTBL+"'"+" and usr='"+APPLI+"'"
       Local Char WVERSSQL(30)
       Call NOVERS_SQL(WVERSSQL,ER) From SQLPROP
       If val(WVERSSQL)<11 : #version < SQL2012
        Execsql From "5" Sql "DBCC CHECKIDENT('"+APPLI+".$SEQ_"+[F:ANM]SEQTBL+"',RESEED,"+num$(1)+")"
       Else
        Execsql From "5" Sql "ALTER SEQUENCE "+APPLI+".SEQ_"+[F:ANM]SEQTBL+" restart with 1"
       Endif
       #dbgstr(128) = 'Update dbo.SS_SEQUENCE set value=1 where name="'+[F:ANM]SEQTBL+'" and usr="'+APPLI+'"'
     Endcase
     Onerrgo
    Endif
    If ER
     Call ECR_TRACE(APPLI+".SEQ_"+[F:ANM]SEQTBL-":"-mess(103,139,1)-"("+ERM+")",1) From GESECRAN : # Séquence inexistante
    Endif
   Endif
  Commit
 Next ANM
 Close Local File [ANM] , [AVN]
Endif

# Compteurs remis à 1

Call ECR_TRACE(mess(52,123,1)-"APLCOM",0) From GESECRAN
If !SIMUL
 If APPLI=nomap
  Local File APLCOM [COM]
 Else
  Local File =APPLI+".APLCOM" [COM]
 Endif
 Trbegin [COM]
  For [COM]
   Case [F:COM]COMTYP
    When 7,8     : [F:COM]COMFLD = ""
    When Default : [F:COM]COMFLD = "1"
   Endcase
   Rewrite [COM]
  Next COM
 Commit
 Close Local File [COM]
Endif

# Epuration de la table ATEXTRA

Call ECR_TRACE(mess(30,133,1)-"ATEXTRA",0) From GESECRAN
If !SIMUL
 If APPLI=nomap
  Local File ATEXTRA [AXX1] , ATEXTRA [AXX2]
 Else
  Local File =APPLI+".ATEXTRA" [AXX1] , =APPLI+".ATEXTRA" [AXX2]
 Endif
 Trbegin [AXX1]
  For [AXX1]AXX0(1)
   Read [ATB]CODFIC=[F:AXX1]CODFIC
   If fstat | [F:ATB]ZERO=2
    Delete [AXX2] Where CODFIC=[F:AXX1]CODFIC
    If fstat
     Call ERREUR([F:AXX1]CODFIC,2) From DOSDIC
    Endif
   Endif
  Next AXX1
 Commit
 Close Local File [AXX1] , [AXX2]
Endif

# X3BY Il ne reste plus que les cas particuliers
Call EXISTE_ADX("","","RAZDOSB",OKTRT) From ORDSYS
If OKTRT>0 : Gosub RAZDOS From RAZDOSB : Endif

If nomap=APPLI
 Call MULTI(OK) From AX3MONO
Else
 Call MULTI(APPLI) From DOSSUB
Endif

If !GSERVEUR
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return

##########################
$ERRSQL
ER = errn
ERM = errm
Resume

##########################
$TR1
GOK = 1
Trbegin [AAA_]
 For [AAA_]
  For I=1 To NBZONE
   DIME = evalue("dim([F:AAA_]"+ZONE(I)+")")
   TYP  = evalue("type([F:AAA_]"+ZONE(I)+")")
   For J=1 To DIME
    Case TYP
     When 1
      Assign "[F:AAA_]"+ZONE(I)+"("+num$(J-1)+")" With 1
     When 2,4,5,6,7,8,9
      Assign "[F:AAA_]"+ZONE(I)+"("+num$(J-1)+")" With 0
     When 3
      Assign "[F:AAA_]"+ZONE(I)+"("+num$(J-1)+")" With [0/0/0]
     When Default
      Assign "[F:AAA_]"+ZONE(I)+"("+num$(J-1)+")" With ""
    Endcase
   Next J
  Next I
  Rewrite [AAA_]
  If fstat
   Call ECR_TRACE(mess(27,125,1)-FICHIER,1) From GESECRAN
#  Erreur de réécriture
  Endif
 Next AAA_
Commit
Return

######################################################################################
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
Call C_DOSSIER(VALEUR) From DOSCONT
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran RAZDOS) 15-06-2013 11:17:49 (ADMIN)
######################################################################################
Subprog IB_DOSSIER
End


######################################################################################
