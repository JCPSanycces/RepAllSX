#########################################################
Subprog  CAL_DOT_EXE_SA
#
# - Objet  : Pas de dotation Exercice pour le mode "Sans amortissement"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#

  #=================
  # Taux / Duree
  #=================
  [M:DIV]TXAMT      = 0.
  [M:DIV]DURAMTREG  = 0.

  #=================
  # Date Fin Amort.
  #=================
  # Sans Date de Fin d'Amortissement
  Gosub CAL_DATE_FIN_AMORT_SA From =G_GLOB8

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  Call ECR_FICH
& ("FS1", 7, "CAL_DOT_EXE_SA **** Dotation EXERCICE   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_1P
#
# - Objet  : Solde valeur nette dans la période courante pour le mode "One period"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#   FQ84110

  #=================
  # Taux / Duree
  #=================
  [M:DIV]TXAMT      = 1.
  [M:DIV]DURAMTREG  = 0.

  #=================
  # Date Fin Amort.
  #=================
  # Sans Date de Fin d'Amortissement
  Gosub CAL_DATE_FIN_AMORT_1P From =G_GLOB8

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]DTDBAMTREG <= [M:DIV]DTFNEXE ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif

  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]ECACUME_1R = 0
    When "T"
      [M:DIV]ECACUME_1T = 0
    When "I"
      [M:DIV]ECACUME_1I = 0
  Endcase

  Call ECR_FICH
& ("FS1", 7, "CAL_DOT_EXE_1P **** Dotation EXERCICE   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_LP
#
# - Objet  : Calcule la dotation de l'exercice selon le mode LP
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC10
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Aide fiscale / Avant
  #=================
  # Valeur amortissable diminuée de l'Aide fiscale (25%, 50%, 39 bis) attribuée à la 1ére dotation exercice
  [M:DIV]VALAMT -= [M:DIV]AFI

  #=================
  # Taux / Duree
  #=================
  #---------------------
  If ( [F:DEPC]ALWCOD = GVML_RPALOGI ) Then
    # -- Logiciel sur 12 mois
    [M:DIV]TXAMT     = 1.
    [M:DIV]DURAMTREG = 1.
  Else
    If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
      [M:DIV]TXAMT = [F:DEPC]DPRRAT
      # Calcul de la durée à partir du taux forcé
      Call  CAL_DUREE_SELON_TAUX_LINEAIRE ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From =G_GLOB8
    Else
      # Durée en année et centième d'année
      [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
      # Calcul du taux linéaire à partir de la durée FQ62812
      Call CAL_TAUX_LINEAIRE ([M:DIV]FLGRNDCHG, [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
    Endif
  Endif
  #---------------------

  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_LP From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Aide                  =" + num$([M:DIV]AFI)        ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Taux  Linéaire        =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Gestion de la priorité (Taux/Fin) d'amortissement
  # FQ81224 FQ92196
  Local Integer B_TXPRI : B_TXPRI = 0
  If ( [M:DIV]FLGTXPRI = G_OUI and [M:DIV]VLNAMT <> 0 and [F:DEPC]DPRRATFLG = G_OUI  and
&      ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE or func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) ) Then
    B_TXPRI = 1
    # Si le taux d'amortissement est prioritaire et que la valeur nette n'est pas nulle
    # Fin d'amortissement repoussée au delà de la fin d'exercice
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXE, 1, "D" )
    Local Date WDTFNEXE, WDTDBEXE
    Local Integer WINDEXE
    # Début/Fin exercice
    #Call CAL_EXERCICE_SELON_DATE  ( [M:DIV]DTFNAMT , GVML_TPJOUR, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]DTFNAMT : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
    WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]DTFNAMT = WDTFNEXE
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amort. * Taux  Lin. * ( Durée Dét. Exe. / Durée Exe. )") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Dét. Exe. / Durée résid. )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  #=================
  # Aide fiscale / Après
  #=================
  # La dotation de l'Exercice dans lequel débute l'amortissement est augmentée de l'aide fiscale
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Ajout aide fiscale    =" + num$([M:DIV]AFI) ) From =G_GLOB0
    WDOTEXE += [M:DIV]AFI
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Taux prioritaire FQ81224
  If ( B_TXPRI ) Then
    If ( [M:DIV]DOTEXE = 0 ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
    Else
      WDURRES  = ([M:DIV]VLNAMT / [M:DIV]DOTEXE ) * 365.25
      [M:DIV]DTFNAMT = (func GLOBB9.CAL_DAT_PLUS( max([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE), WDURRES, "D" )) - 1
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_DF
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DF
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC20
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Aide fiscale / Avant
  #=================
  # Pour l'Exercice dans lequel débute l'amortissement
  # la valeur nette amortissement est diminuée de l'aide fiscale
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  and
&      [M:DIV]AFI <> 0 ) Then
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Valeur nette          =" + num$([M:DIV]VLNAMT)   ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Exerc. début d'amort. : Aide fiscale à déduire de la val. nette") From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Aide                  =" + num$([M:DIV]AFI)        ) From =G_GLOB0
    [M:DIV]VLNAMT -= [M:DIV]AFI
  Endif

  #=================
  # Reprise différé sur durée résiduelle
  #=================
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]DIFRGL = GVML_RGREPDR and [F:DEPC]DFDBLC <> 0) Then
    # Lorsqu'il y a reprise de différé sur durée résiduelle,
    # le solde de différé est réintégré à la valeur nette amortissable (fiscal)
    # cela equivaut à l'abandon du solde de dérogatoire qui est remis à 0 à la prochaine clôture exercice
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Valeur nette          =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Reprise de différé : Solde différé à ajouter à la val. nette") From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Solde de différé      =" + num$([F:DEPC]DFDBLC)) From =G_GLOB0
    [M:DIV]VLNAMT += [F:DEPC]DFDBLC
  Endif

  If ([M:DIV]NIVDET > 7) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DF - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Aide                  =" + num$([M:DIV]AFI)        ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Déb. Exercice  résid. =" + num$([M:DIV]EXEDATREF)  ) From =G_GLOB0
  Endif
  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  If ( [M:DIV]DURAMTREG < 3. ) Then : [M:DIV]DURAMTREG = 3. : Endif
  # Taux dégressif
  # FQ51021 FQ62812
  # Call CAL_TAUX_MODE_DF
  # &      ([M:DIV]DTFNEXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [F:DEPC]ALWCOD, [M:DIV]TXAMT) From =G_GLOB8
  Call CAL_TAUX_MODE_DF
&      ([M:DIV]FLGRNDCHG,[F:WFAS]PURDAT, [M:DIV]DTFNEXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [F:DEPC]ALWCOD, [M:DIV]TXAMT) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Taux  d'amortissement =" + num$([M:DIV]TXAMT)) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Date de fin d'amortissement pour le mode DF Dégressif français
  Gosub CAL_DATE_FIN_AMORT_DF From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1", 7,
& "Dotation dégressive = Val. nette déb. exe. * * Taux  d'amortissement * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
  WDOTEXEDEG = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DF - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT
&       ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
& From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Linéaire Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  # Pour le calcul de la dotation linéaire sur durée résiduelle d'un exercice qui n'est pas le dernier
  # à amortir, si la durée résiduelle ne correspond pas à un nombre entier d'exercice de référence,
  # la durée résiduelle est ajustée à l'entier supérieur. Autrement dit,
  # Si la durée restant à amortir ne correspond à un multiple de 12 mois
  # et qu'il ne s'agit pas du dernier exercice d'amortissement
  # la durée restant à amortir est ajustée au multiple de 12 immédiatement supérieur
  # afin d'obtenir une durée restant à amortir correspondant à un nombre entier d'exercices de référence
  # FQ96396
    If (mod(WDURRES, [M:DIV]DUREXE) <> 0 and [M:DIV]DTFNAMT > [M:DIV]DTFNEXE) Then
      WDURRES = ( int( WDURRES/[M:DIV]DUREXE) * [M:DIV]DUREXE ) + [M:DIV]DUREXE
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Linéaire Durée Résid. ajustée  =" +  num$(WDURRES ) ) From =G_GLOB0
    Endif

  #---------------------------------------------
  # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
  #---------------------------------------------
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    Call ECR_FICH("FS1", 7,
&   "Dotation linéaire = Val. nette déb. exe. * (Durée Détention Exe. / Durée résiduelle)") From =G_GLOB0
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DF - Linéaire val.rés. / dur. rés. ......... ="-num$(WDOTEXELIN)) From =G_GLOB0

  # Détermination de la dotation exercice
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif

  #----------------------------------------
  If ( [F:DEPC]ALWCOD = GVML_RPAID30 ) Then
    Local Decimal LDOTEXE
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DF - Dotation exercice avant majoration ="-num$([M:DIV]DOTEXE)) From =G_GLOB0
    # Règle fiscale "Majo amt 30% [17/10/01-31/12/02]
    # L'amortissement calculé est majoré de 30% au titre des 12 premiers mois suivant l'acquisition
    LDOTEXE = [M:DIV]DOTEXE
    [M:DIV]LVLLIB = "CAL_REGLE_DF_AMT30_2001" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_REGLE_DF_AMT30_2001 ( LDOTEXE, [M:DIV]DOTEXE, [F:DEPC]ALWAMT) From =G_GLOB6
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DF - Dotation exercice après majoration ="-num$([M:DIV]DOTEXE)) From =G_GLOB0
  Endif
  #----------------------------------------

  #=================
  # Aide fiscale / Après
  #=================
  # La dotation de l'Exercice dans lequel débute l'amortissement est augmentée de l'aide fiscale
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and
&      [M:DIV]AFI <> 0) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Ajout de l'aide fiscale à la dotation exercice et à la valeur nette" ) From =G_GLOB0
    [M:DIV]DOTEXE += [M:DIV]AFI
    # Valeur nette avec aide fiscale intégrée
    [M:DIV]VLNAMT += [M:DIV]AFI
  Endif

  # Si valeur nette non nulle et fin d'amortissement antérieur à l'exercice courant elle est soldée
  # Elle doit aussi être soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DF - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_LV
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Linéaire au delà valeur résiduelle"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc14
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation de l'exercice

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #=================
  # Taux / Duree
  #=================
  # FQ74664
  [M:DIV]TXAMT     = [F:DEPC]DPRRAT
  [M:DIV]DURAMTREG = 0

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LV - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LV - Taux                  =" + num$([M:DIV]TXAMT) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  # Sans Date de Fin d'Amortissement
  Gosub CAL_DATE_FIN_AMORT_LV From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LV - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE,   [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT,  [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LV - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LV - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( [M:DIV]DUREXE <> 0 ) Then
    Call ECR_FICH("FS1", 7, "Dotation exercice = Base * Taux * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
    WDOTEXE = [M:DIV]BASAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE)
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE: [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LV - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End



#########################################################
Subprog  CAL_DOT_EXE_SY
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "SOFTY"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc40
#

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice partie 1
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée restant à amortir
Local Decimal WDURANN  : WDURANN  = 0.       : # Durée annuité
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
Local Decimal WDOTEX1  : WDOTEX1  = 0.       : # Dotation de l'exercice partie 1
Local Decimal WDOTEX2  : WDOTEX2  = 0.       : # Dotation de l'exercice partie 2
Local Integer WANN     : WANN     = 0        : # Annuité courante
Local Integer WSOFTY   : WSOFTY   = 0        : # Somme des années (Durée 3 / SOFTY = 6 i.e 1+2+3)

Local Date    LDTDB    : LDTDB    = [0/0/0]  : # Date début annuité partie 1
Local Date    LDTFN    : LDTFN    = [0/0/0]  : # Date fin annuité partie 1
Local Date    LDTDB2   : LDTDB2   = [0/0/0]  : # Date début annuité partie 2
Local Date    LDATSAV  : LDATSAV  = [0/0/0]  : # Date sauvegardée

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Durée Fin Amort.
  #=================
  # La durée d'amortissement est un nombre d'années entières, elle est arrondie à l'année supérieure
  [M:DIV]DURAMTREG = arr([F:DEPC]DPRDUR+0.4, 1)

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_SY From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Valeur amortissable   =" + num$([M:DIV]VALAMT) ) From =G_GLOB0


  #----------------------------------------
  # Recherche de l'année courante (WANN)  # FQ63646
  #           de la date de début pour calcul 1ère partie de la dotation (LDTDB)
  #           de la date de début pour calcul 2ème partie de la dotation (LDTDB2)
  LDTDB  = [M:DIV]DTDBAMTREG
  WANN = 1
  While ( LDTDB < [M:DIV]DTDBEXE )
    WANN += 1 : LDATSAV = LDTDB
    LDTDB = func GLOBB9.CAL_DAT_PLUS( LDTDB, 1, "Y" )
  Wend
  If ( LDTDB <> [M:DIV]DTDBAMTREG and LDTDB <> [M:DIV]DTDBEXE ) Then
    WANN -= 1 : LDTDB = LDATSAV
  Endif
  # Date de début pour calcul 2ème partie de la dotation
  LDTDB2 = func GLOBB9.CAL_DAT_PLUS( LDTDB,  1, "Y" )
  # Date de fin pour calcul 1ère partie de la dotation
  LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB2, -1, "D" )
  [M:DIV]DTFN1  = LDTFN : # Pour calcul périodique
  # Somme des années : Ex. Durée 3 ans => SOFTY = 6 (1+2+3) équivalent à (n+(n+1))/2 avec n= durée
  WSOFTY  = ([M:DIV]DURAMTREG *([M:DIV]DURAMTREG +1) )/2
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Somme des années      =" + num$(WSOFTY) ) From =G_GLOB0
  #----------------------------------------

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    # --------------
    # --- Partie 1
    # --------------
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Annuité partie 1           =" + num$(WANN) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date début Partie 1        =" + num$(LDTDB ) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date fin partie 1          =" + num$(LDTFN ) ) From =G_GLOB0
    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,    LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
    [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Durée Détention partie 1   =" + num$(WDURDET) ) From =G_GLOB0
    # Calcul de la durée de l'exercice selon le type de prorata
    Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Durée annuité partie 1     =" + num$(WDURANN) ) From =G_GLOB0

    # calcul de la dotation exercice partie 1
    If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
      [M:DIV]TXAMT1 = ([M:DIV]DURAMTREG+1 - WANN) / WSOFTY
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Taux amort. partie 1       =" + num$([M:DIV]TXAMT1) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8,
&     "Dotation partie 1 = Val. amortissable * Taux amort.partie 1 * (Durée Détention partie 1 / Durée annuité partie 1)") From =G_GLOB0
      WDOTEX1 = [M:DIV]VALAMT * [M:DIV]TXAMT1   * ( WDURDET / WDURANN )
      #Call CAL_ARRONDI_MNT (WDOTEX1, [M:DIV]CUR , WDOTEX1) From =G_GLOB8
      [M:DIV]PV(0)= WDOTEX1: [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX1 = [M:DIV]RV(1)
    Else
      WDOTEX1 = 0
    Endif
    Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_SY - Dotation exercice partie 1 =" + num$(WDOTEX1) ) From =G_GLOB0
    # --------------
    # --- Partie 2
    # --------------
    While ( [M:DIV]DTFNEXE > LDTFN  and
&           ( [M:DIV]DATSOREXE = [0/0/0] or  [M:DIV]DATSOREXE  > LDTFN )   )
      WANN += 1 : LDTDB = LDTDB2
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date début partie 2       =" + num$(LDTDB ) ) From =G_GLOB0
      # Date de fin pour calcul 2ème partie de la dotation
      LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB,   1, "Y" )
      LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTFN,  -1, "D" )
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Date fin   partie 2       =" + num$(LDTFN ) ) From =G_GLOB0
      # Calcul de la durée de l'annuité selon le type de prorata
      Call CAL_DUR_EXE_REF (LDTDB, LDTFN, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
      Call ECR_FICH("FS1", 8, "   Durée annuité partie 2     =" + num$(WDURANN) ) From =G_GLOB0
      # Durée de détention dans l'exercice
#     Call  CAL_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,   LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
#&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
      [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Durée Détention partie 2  =" + num$(WDURDET) ) From =G_GLOB0

      # calcul de la dotation exercice partie 2
      If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
        [M:DIV]TXAMT2 = ([M:DIV]DURAMTREG+1 - WANN) / WSOFTY
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SY - Taux amort. partie 2       =" + num$([M:DIV]TXAMT2) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8,
&       "Dotation partie 2 = Val. amortissable * Taux amort.partie 2 * (Durée Détention partie 2 / Durée annuité partie 2)") From =G_GLOB0
        WDOTEX2 = [M:DIV]VALAMT * [M:DIV]TXAMT2 * ( WDURDET / WDURANN )
        #Call CAL_ARRONDI_MNT (WDOTEX2, [M:DIV]CUR , WDOTEX2) From =G_GLOB8
        [M:DIV]PV(0)= WDOTEX2: [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX2 = [M:DIV]RV(1)
      Else
        WDOTEX2 = 0
      Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Dotation exercice partie 2 =" + num$(WDOTEX2) ) From =G_GLOB0
    Wend
    # --------------
    # --- Dotation
    # --------------
    # Dotation exercice = Dotation partie 1  + Dotation partie 2
    WDOTEXE = WDOTEX1 + WDOTEX2
    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Solde du reste à amortir ") From =G_GLOB0
    Endif

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice
    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Taux Partie 1 & partie 2 pour périodique FQ63646
    If ( WSOFTY <> 0 ) Then
      [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
      [M:DIV]TXAMT2 = 0.
    Endif

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SY - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Pas de Taux d'amortissement
  [M:DIV]TXAMT = 0.

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_PR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Progressif"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc42
#

Local Decimal WDURAMT  : WDURAMT  = 0.       : # Durée d'amortissement arrondie à l'année supérieure
Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice partie 1
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée restant à amortir
Local Decimal WDURANN  : WDURANN  = 0.       : # Durée annuité
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
Local Decimal WDOTEX1  : WDOTEX1  = 0.       : # Dotation de l'exercice partie 1
Local Decimal WDOTEX2  : WDOTEX2  = 0.       : # Dotation de l'exercice partie 2
Local Integer WANN     : WANN     = 0        : # Annuité courante
Local Integer WSOFTY   : WSOFTY   = 0        : # Somme des années (Durée 3 / SOFTY = 6 i.e 1+2+3)

Local Date    LDTDB    : LDTDB    = [0/0/0]  : # Date début annuité partie 1
Local Date    LDTFN    : LDTFN    = [0/0/0]  : # Date fin annuité partie 1
Local Date    LDTDB2   : LDTDB2   = [0/0/0]  : # Date début annuité partie 2
Local Date    LDATSAV  : LDATSAV  = [0/0/0]  : # Date sauvegardée

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Durée Fin Amort.
  #=================
  # La durée d'amortissement est un nombre d'années entières, elle est arrondie à l'année supérieure
  [M:DIV]DURAMTREG = arr([F:DEPC]DPRDUR+0.4, 1)

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_PR From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Valeur amortissable   =" + num$([M:DIV]VALAMT) ) From =G_GLOB0

  #=================
  # Dotation.
  #=================
  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    # Recherche de l'annuité courante (WANN)
    #           de la date de début pour calcul 1ère partie de la dotation (LDTDEB)
    #           de la date de début pour calcul 2ème partie de la dotation (LDTDEB2)
    LDTDB  = [M:DIV]DTDBAMTREG
    WANN = 1
    While ( LDTDB < [M:DIV]DTDBEXE )
      WANN += 1 : LDATSAV = LDTDB
      LDTDB = func GLOBB9.CAL_DAT_PLUS( LDTDB, 1, "Y" )
    Wend
    If ( LDTDB <> [M:DIV]DTDBAMTREG and LDTDB <> [M:DIV]DTDBEXE ) Then
      WANN -= 1 : LDTDB = LDATSAV
    Endif

    # Somme des années : Ex. Durée 3 ans => SOFTY = 6 (1+2+3) équivalent à (n+(n+1))/2 avec n= durée
    WSOFTY  = ([M:DIV]DURAMTREG *([M:DIV]DURAMTREG +1) )/2
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Somme des années      =" + num$(WSOFTY)  ) From =G_GLOB0

   # --------------
    # --- Partie 1
    # --------------
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Annuité partie 1           =" + num$(WANN) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Date début Partie 1        =" + num$(LDTDB ) ) From =G_GLOB0
    # Date de début pour calcul 2ème partie de la dotation
    LDTDB2 = func GLOBB9.CAL_DAT_PLUS( LDTDB,  1, "Y" )
    # Date de fin pour calcul 1ère partie de la dotation
    LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB2, -1, "D" )
    [M:DIV]DTFN1  = LDTFN : # Pour calcul périodique
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Date fin partie 1          =" + num$(LDTFN ) ) From =G_GLOB0
    # La durée d'amortissement est arrondie à l'année supérieure
    WDURAMT = arr([M:DIV]DURAMTREG+0.4, 1)
    # Calcul de la durée de l'annuité selon le type de prorata
    Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Durée annuité partie 1     =" + num$(WDURANN) ) From =G_GLOB0
    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,   LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
    [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Durée Détention partie 1   =" + num$(WDURDET) ) From =G_GLOB0

    # calcul de la dotation exercice partie 1
    If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
      [M:DIV]TXAMT1 = ( WANN / WSOFTY )
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Taux amort. partie 1       =" + num$([M:DIV]TXAMT1) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8,
&     "Dotation partie 1 = Val. amortissable * Taux amort.partie 1 * (Durée Détention partie 1 / Durée annuité partie 1)") From =G_GLOB0
      WDOTEX1 = [M:DIV]VALAMT * [M:DIV]TXAMT1 * ( WDURDET / WDURANN )
      #Call CAL_ARRONDI_MNT (WDOTEX1, [M:DIV]CUR , WDOTEX1) From =G_GLOB8
      [M:DIV]PV(0)= WDOTEX1 : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX1 = [M:DIV]RV(1)
    Else
      WDOTEX1 = 0
    Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Dotation exercice partie 1 =" + num$(WDOTEX1) ) From =G_GLOB0
    # --------------
    # --- Partie 2
    # --------------
    While ( [M:DIV]DTFNEXE > LDTFN  and
&           ( [M:DIV]DATSOREXE = [0/0/0] or  [M:DIV]DATSOREXE  > LDTFN )   )
      WANN += 1 : LDTDB = LDTDB2
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Date début partie 2       =" + num$(LDTDB ) ) From =G_GLOB0
      # Date de fin pour calcul 2ème partie de la dotation
      LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB,   1, "Y" )
      LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTFN,  -1, "D" )
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Date fin   partie 2       =" + num$(LDTFN ) ) From =G_GLOB0
      # Calcul de la durée de l'annuité selon le type de prorata
      Call CAL_DUR_EXE_REF (LDTDB, LDTFN, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Durée annuité partie 2     =" + num$(WDURANN) ) From =G_GLOB0
      # Durée de détention dans l'exercice
#     Call  CAL_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE, LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
#&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
      [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Durée Détention partie 2  =" + num$(WDURDET) ) From =G_GLOB0

      # calcul de la dotation exercice partie 2
      If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
        [M:DIV]TXAMT2 = ( WANN / WSOFTY )
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PR - Taux amort. partie 2       =" + num$([M:DIV]TXAMT2) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8,
&       "Dotation partie 2 = Val. amortissable * Taux amort.partie 2 * (Durée Détention partie 2 / Durée annuité partie 2)") From =G_GLOB0
        WDOTEX2 = [M:DIV]VALAMT * [M:DIV]TXAMT2 * ( WDURDET / WDURANN )
        #Call CAL_ARRONDI_MNT (WDOTEX2, [M:DIV]CUR , WDOTEX2) From =G_GLOB8
        [M:DIV]PV(0)= WDOTEX2 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX2 = [M:DIV]RV(1)
      Else
        WDOTEX2 = 0
      Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Dotation exercice partie 2 =" + num$(WDOTEX2) ) From =G_GLOB0
    Wend
    # --------------
    # --- Dotation
    # --------------
    # Dotation exercice = Dotation partie 1  + Dotation partie 2
    WDOTEXE = WDOTEX1 + WDOTEX2
    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Solde du reste à amortir ") From =G_GLOB0
    Endif

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT,  [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PR - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Pas de Taux d'amortissement
  [M:DIV]TXAMT = 0.

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_FM
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Forme & Moules"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc11
#

Local Decimal WTXAMT       : WTXAMT   = 0.  : # Taux d'amortissement
Local Decimal WDURDET      : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES      : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE      : WDOTEXE  = 0.  : # Dotation de l'exercice
Local Decimal WTABTX(0..35)                 : # Table des taux mensuels

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Durée / Taux Amort.
  #=================
  [M:DIV]DURAMTREG = 3.
  [M:DIV]TXAMT   = 0.

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_FM From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_FM - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Val. amortissable     =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    # Charge taux mensuels 36 mois (12 mois 50%, 12 mois 30%, 12 mois 20%)
    Local Integer LNBTX       : LNBTX       = 36
    Local Integer IM
    For IM = 0 To 11 : WTABTX(IM) = 0.5/12 : WTABTX(IM+12) = 0.3/12 : WTABTX(IM+24) = 0.2/12 : Next IM

    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    Local Integer LRGLTXAMT  : LRGLTXAMT  = GVML_COBSMTM   : # Règle Taux    : Taux mensuel
    Local Integer LRGLAMTMIN : LRGLAMTMIN = GVML_COSANS    : # Règle Amt min : Aucune
    Local Decimal LTXAMTMIN  : LTXAMTMIN  = 0.0            : # Règle Tx min  : 0.
    Local Integer LRGLAMTMAX : LRGLAMTMAX = GVML_COSANS    : # Règle Amt max : Aucune
    Local Decimal LTXAMTMAX  : LTXAMTMAX  = 0.0            : # Règle Tx max  : 0.

    # calcul de la Dotation exercice
    Call CAL_DOT_TX_MENSUEL
&        (WTABTX, LNBTX, 1, [M:DIV]VALAMT, LRGLTXAMT, LRGLAMTMIN, LTXAMTMIN, LRGLAMTMAX, LTXAMTMAX,
&         [M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DUREXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]DTFNAMT,
&         [M:DIV]DATSOREXE, [M:DIV]BASAMT, [F:DEPC]RSDVAL, [M:DIV]VLNAMT,   WDOTEXE )
&   From =G_GLOB7
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. amortissable * (12 mois 50%, 12 mois 30%, 12 mois 20%)") From =G_GLOB0

    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_FM - Solde du reste à amortir ") From =G_GLOB0
    Endif

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT,  [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_FM - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_FM - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_FM - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_LG
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Linge"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc46
#

Local Decimal WTXAMT       : WTXAMT   = 0.  : # Taux d'amortissement
Local Decimal WDURDET      : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES      : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE      : WDOTEXE  = 0.  : # Dotation de l'exercice
Local Decimal WTABTX(0..17)                 : # Table des taux mensuels

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Durée / Taux Amort.
  #=================
  [M:DIV]DURAMTREG = 1.5
  [M:DIV]TXAMT   = 0.

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_LG From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LG - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_FM - Val. amortissable     =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif
  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    # Charge taux mensuels 18 mois (1 mois 40%, 1 mois 12%, les mois suivants 3%)
    Local Integer LNBTX       : LNBTX       = 18
    Local Integer IM
    For IM = 0 To 17
      Case IM
       When 0       : WTABTX(IM) = 0.40
       When 1       : WTABTX(IM) = 0.12
       When Default : WTABTX(IM) = 0.03
      Endcase
    Next IM

    #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    Local Integer LRGLBASAMT : LRGLBASAMT = GVML_TBVLAMT   : # Règle Base    : Valeur amortissable
    Local Integer LRGLTXAMT  : LRGLTXAMT  = GVML_COBSMTM   : # Règle Taux    : Taux mensuel
    Local Integer LRGLAMTMIN : LRGLAMTMIN = GVML_COSANS    : # Règle Amt min : Aucune
    Local Decimal LTXAMTMIN  : LTXAMTMIN  = 0.0            : # Règle Tx min  : 0.
    Local Integer LRGLAMTMAX : LRGLAMTMAX = GVML_COSANS    : # Règle Amt max : Aucune
    Local Decimal LTXAMTMAX  : LTXAMTMAX  = 0.0            : # Règle Tx max  : 0.

    # calcul de la Dotation exercice
    Call CAL_DOT_TX_MENSUEL
&        (WTABTX, LNBTX, 1, [M:DIV]VALAMT, LRGLTXAMT, LRGLAMTMIN, LTXAMTMIN, LRGLAMTMAX, LTXAMTMAX,
&         [M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DUREXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG,
&         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,
&         [M:DIV]BASAMT,  [F:DEPC]RSDVAL, [M:DIV]VLNAMT, WDOTEXE ) From =G_GLOB7
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. amortissable * (1 mois 40%, 1 mois 12%, les 16 mois suivants 3%)") From =G_GLOB0

    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LG - Solde du reste à amortir ") From =G_GLOB0
    Endif
  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT,  [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LG - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
   Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LG - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_RE
#
# - Objet  : Calcule la dotation de l'exercice selon le mode Résiduel
#
#   Rem. 1°) Lorsque le porata temporis est "1/2 année"
#            Le début d'amt pour la dotation exercice est le milieu du semestre du début d'amt
#            Le début d'amt pour la dotation période  est le début de mois du début d'amt (prorata mois)
#        2°) Lorsque le prorara temporis est "1/2 année" ou "1/2 mois"
#            Calcul de la dotation exercice sans tenir compte de la date de sortie
#            Puis la dotation exercice est proratée par rapport à la date de sortie
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire GCFC32
#

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
Local Date    WDTDBAMT   :                   : # Date de début d'amort régularisé pour dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Début d'amort.    =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Fin   d'amort.    =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Date sortie       =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Date sortie Exe   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Base              =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Valeur résiduelle =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Cumul  E-1        =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Cumul  P-1        =" + num$([F:DEPC]PERCLOCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, " " ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Date de référence     =" + num$([M:DIV]EXEDATREF) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  # FQ54343
  # Si le mode est Résiduel "jour" et que la fin d'amortissement est forcée, elle prime sur le calcul.
  #-1 ------------------------
  If ([M:DIV]TYPPRO = GVML_TPJOUR and [F:DEPC]ENDDPRFLG = G_OUI ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Fin d'amortissement FORCEE  "        ) From =G_GLOB0
  #-1 ------------------------
  Else
    Gosub CAL_DATE_FIN_AMORT_RE From =G_GLOB8
  Endif
  #-1 ------------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #***********************************************************************
  If ( [M:DIV]TYPPRO = GVML_TPHLFY or [M:DIV]TYPPRO = GVML_TPHLFQ ) Then

  # Si prorata "Half Year"
  # le début d'amort. pour le calcul de la dot. exe. est le milieu du semestre d'acquistion
  # le début d'amort. pour le calcul de la dot. per. est le début du mois d'acquistion
  If ( [M:DIV]TYPPRO = GVML_TPHLFY ) Then
    # Au début du deuxième Semestre de l'année du début d'amortissement
    WDTDBAMT = gdat$(01, 07, year([F:DEPC]STRDPRDAT) )
  Else
    WDTDBAMT = [M:DIV]DTDBAMTREG
  Endif

  # Durée de détention dans l'exercice (sans prendre en compte la date de sortie)
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&      [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATNUL : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT (WDTDBAMT, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT,
&                          WDURRES) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( WDURRES <> 0 ) Then
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
    WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  # Prise en compte de la date de sortie
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # Durée de détention dans l'exercice ( sans tenir compte de la date de fin d'amortissement
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&        [M:DIV]DATNUL, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DATNUL
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Prise en compte de la SORTIE" ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Dotation à prorater   =" + num$(WDOTEXE) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RE - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Dotation à prorater * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
    WDOTEXE = WDOTEXE * ( WDURDET / [M:DIV]DUREXE )
  Endif

  #***********************************************************************
  Else

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT,
&                          WDURRES) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( WDURRES <> 0 ) Then
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
    WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la dotation
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RE - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Pas de Taux d'amortissement
  [M:DIV]TXAMT = 0.

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog  CAL_DOT_EXE_UO
#
# - Objet  : Calcule la dotation de l'exercice selon le mode Unité d'oeuvre
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire GCFC50
#

Local Decimal WVALNET  : WVALNET  = 0.  : # Valeur nette début d'exercice
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation de l'exercice
Local Decimal WQTE     : WQTE     = 0.  : # Nombre d'UO de référence pour la période/exercice
Local Decimal WDURREF  : WDURREF  = 0.  : # Durée de la période/exercice
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans la période/exercice
Local Decimal WUOEXE   : WUOEXE   = 0.  : # Nombre d'UO pour l'exercice résiduel

Local Integer IPP      : # Indice plan de production
Local Integer IPC      : # Indice période courante
Local Integer IDBE     : # Indice début exercice
Local Integer IFNE     : # Indice fin exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  [M:DIV]TXAMT     = 0.
  #---------------------

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_UO From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UO - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Si fin du plan de production est renseignée et antérieure au début d'amortissement
  # Pas de calcul, la dotation exercice est égale à 0
  If ( [M:DIV]DTFNPPL <> [0/0/0] and [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG ) Then
    [F:DEPC]FIYQTY = 0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Incohérence Amortissement & Plan de Production "  ) From =G_GLOB0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Fin plan production   ="+ num$([M:DIV]DTFNPPL   )  ) From =G_GLOB0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Début d'amort.        ="+ num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
    Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UO - UO exercice           =" + num$([F:DEPC]FIYQTY  ) ) From =G_GLOB0
    Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UO - Dotation exe.         =" + num$([M:DIV]DOTEXE   ) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
   End
  # ***
  Endif

  #====================
  # Plan de production
  #====================

  # Indice période courante
  IPC  = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
  # FQ 100742_2
  # FQ114372
  #If (IPC = 0 and [F:DEPC]PERSTRDAT > [M:PPL]PERSTRDAT([M:PPL]NB_PPL-1)) Then
  If ([M:PPL]NB_PPL = 0 or (IPC = 0 and [F:DEPC]PERSTRDAT > [M:PPL]PERSTRDAT([M:PPL]NB_PPL-1))) Then
    Local Integer I_EXE, I_PER
    I_EXE = find([F:DEPC]FIYENDDAT, [M:FIY]DATENDFIY)
    #>>>>>>>>>>>>>>>>>>>>
    For I_PER = 1 To [M:FIY]NBRPER(I_EXE-1)
      [M:PPL]NB_PPL = [M:PPL]NB_PPL + 1
      If ( [M:PPL]NB_PPL > [M:DIV]PPLMAX ) Then : Break : Endif
      [M:PPL]FIYSTRDAT([M:PPL]NB_PPL-1) = [M:FIY]DATSTRFIY(I_EXE-1)
      [M:PPL]PERSTRDAT([M:PPL]NB_PPL-1) = [M:FIY]DATSTRPER( [M:FIY]INDDEBPER(I_EXE-1) + I_PER - 2 )
      [M:PPL]FIYENDDAT([M:PPL]NB_PPL-1) = [M:FIY]DATENDFIY(I_EXE-1)
      [M:PPL]PERENDDAT([M:PPL]NB_PPL-1) = [M:FIY]DATENDPER( [M:FIY]INDDEBPER(I_EXE-1) + I_PER - 2 )
      [M:PPL]EXTQTY([M:PPL]NB_PPL-1)    = 0
      [M:PPL]CPLQTY([M:PPL]NB_PPL-1)    = 0
      [M:PPL]RSDQTY([M:PPL]NB_PPL-1)    = 0
      [M:PPL]FIYQTY([M:PPL]NB_PPL-1)    = 0
      If ([F:DEPC]PERENDDAT =  [M:PPL]PERENDDAT([M:PPL]NB_PPL-1)) Then : IPC = [M:PPL]NB_PPL : Endif
    Next
    #<<<<<<<<<<<<<<<<<<<<<<<<<
    # Arrêt du traitement dans le cas où l'on dépasse les limites du plan de production (activité PPL)
    If ( [M:PPL]NB_PPL > [M:DIV]PPLMAX ) Then
      [M:DIV]ERRID = 31 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif

  # Indice début exercice courant
  IDBE  = find([F:DEPC]FIYSTRDAT, [M:PPL]PERSTRDAT)
  If (IDBE = 0 ) Then : IDBE = 1 : Endif
  # Indice fin exercice courant
  IFNE  = find([F:DEPC]FIYENDDAT, [M:PPL]PERENDDAT)
  # FQ93904
  If (IFNE = 0 ) Then : IFNE = [M:PPL]NB_PPL : Endif

  #-1 -------------------------
  If ( [M:DIV]BCALPPL ) Then
    [M:DIV] BCALPPL = 0
    [M:PPL]IPSO = 0
    Raz [M:PPL]IFNA
    Raz [M:PPL]PERQTY
    Raz [M:PPL]RSDQTY

    # UO période jusqu'à fin d'amortissement ( UO période déb & fin amort proratée selon la détention )
    Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - [M:PPL]PERQTY() UO pér. selon détention aux bornes de l'intervalle d'amortissement" )  From =G_GLOB0
    Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - -------------------------" )                    From =G_GLOB0
    # >>>>>>>>>>>>
    For IPP = 1 To [M:PPL]NB_PPL
      # UO période référence : Prévues/Réalisées
      If ( [M:PPL]CPLQTY(IPP-1) <> 0 ) Then
        WQTE = [M:PPL]CPLQTY(IPP-1)
      Else
        WQTE = [M:PPL]EXTQTY(IPP-1)
      Endif
      # Durée de détention dans la période/exercice ( sans tenir compte de la date de sortie)
#      Call CAL_DUR_DET
#&         ([M:PPL]PERSTRDAT(IPP-1),  [M:PPL]PERENDDAT(IPP-1), [M:DIV]DATNUL, [M:DIV]DATNUL,
#&          [M:DIV]DTDBAMTREG, [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET
#&         ) From =G_GLOB8
      [M:DIV]PD(0)= [M:PPL]PERSTRDAT(IPP-1) : [M:DIV]PD(1)= [M:PPL]PERENDDAT(IPP-1)
      [M:DIV]PD(2)= [M:DIV]DATNUL  : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG
      [M:DIV]PD(5)= [M:DIV]DTFNAMT : [M:DIV]PD(6)= [M:DIV]DATNUL : [M:DIV]PD(7)= [M:DIV]DETVTEDAT
      [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif

      # Durée de la période/exercice
      Call CAL_DAT_DIFF( [M:PPL]PERSTRDAT(IPP-1), [M:PPL]PERENDDAT(IPP-1), [M:DIV]TYPPRODAT,
&                        WDURREF ) From =G_GLOB9
      # UO période pour le plan
      [M:PPL]PERQTY(IPP-1) = WQTE * ( WDURDET / WDURREF )
      Call QTEARR([M:PPL]PERQTY(IPP-1), [M:PPL]UOM) From TRTDIV

      If ( [M:DIV]NIVDET > 9 ) Then
        Call ECR_FICH("FS1", 10,
&           "CAL_DOT_EXE_UO - Période "
&                           -num$([M:PPL]PERSTRDAT(IPP-1))-"-"-num$([M:PPL]PERENDDAT(IPP-1))) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - Durée période    ="  + num$(WDURREF)             ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - UO période       ="  + num$(WQTE)                ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - Durée détention  ="  + num$(WDURDET)             ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - UO pér./détention="  + num$([M:PPL]PERQTY(IPP-1))) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UO - -------------------------" )                    From =G_GLOB0
      Endif
      # Indice fin d'amortissement
      If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:PPL]PERSTRDAT(IPP-1),
&                                                    [M:PPL]PERENDDAT(IPP-1),"I")) Then
        [M:PPL]IFNA = IPP
        Break
      Endif
    Next IPP
    # <<<<<<<<<<<<


    If ( [M:PPL]IFNA = 0 ) Then
      # Si la date de fin d'amortissement est au delà de l'horizon du plan de production
      # L'indice récupére l'horizon du plan de production
      [M:PPL]IFNA = [M:PPL]NB_PPL
    Endif


    #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    # UO résiduelle début de période
    # début de période courante
    Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - [M:PPL]RSDQTY() UO Résid. selon détention  aux bornes de l'intervalle d'amortissement" )  From =G_GLOB0
    Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - -------------------------" ) From =G_GLOB0

    [M:PPL]RSDQTY(IPC-1)= sum( [M:PPL]PERQTY (IPC-1..[M:PPL]IFNA-1) )
    Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - Période           "
&                  - format$([M:DIV]DATFMT,[M:PPL]PERSTRDAT(IPC-1)) + " - "
&                  + format$([M:DIV]DATFMT,[M:PPL]PERENDDAT(IPC-1))                         ) From =G_GLOB0
    Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO résid déb per ="+ num$([M:PPL]RSDQTY(IPC-1))) From =G_GLOB0
    Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO pér./détention="+ num$([M:PPL]PERQTY(IPC-1))) From =G_GLOB0
    #-----------------------
    If ( IPC <> [M:PPL]IFNA ) Then
      # >>>>>>>>>>>>
      For IPP = IPC+1 To [M:PPL]IFNA
        # début de période n
        [M:PPL]RSDQTY(IPP-1) = [M:PPL]RSDQTY(IPP-2) - [M:PPL]PERQTY(IPP-2)
        If ([M:DIV]NIVDET > 8 ) Then
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - Période "
&                      + format$([M:DIV]DATFMT,[M:PPL]PERSTRDAT(IPP-1)) + " - "
&                      + format$([M:DIV]DATFMT,[M:PPL]PERENDDAT(IPP-1))                         ) From =G_GLOB0
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO résid déb per ="+ num$([M:PPL]RSDQTY(IPP-1))) From =G_GLOB0
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO période       ="+ num$([M:PPL]PERQTY(IPP-1))) From =G_GLOB0
        Endif
        # Indice période de Sortie
        If ( [M:DIV]DATSOREXE <> [0/0/0] and
&            func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE,[M:PPL]PERSTRDAT(IPP-1),
&                                                        [M:PPL]PERENDDAT(IPP-1),"I")) Then
          [M:PPL]IPSO = IPP
        Endif
      Next IPP
      # <<<<<<<<<<<<
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - -------------------------" ) From =G_GLOB0
    Endif
    #-----------------------

    # FQ93904
    # Indice période de Sortie
    If ( [M:DIV]DATSOREXE <> [0/0/0] and [M:PPL]IPSO = 0 ) Then FQ100742_2
      [M:PPL]IPSO = IPC
    Endif

    # UO période de Sortie
    If ([M:PPL]IPSO) Then
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - Evaluation UO pour la période de sortie"        ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,
&         "CAL_DOT_EXE_UO - "-num$([M:PPL]PERSTRDAT([M:PPL]IPSO-1))-"-"-num$([M:PPL]PERENDDAT([M:PPL]IPSO-1))) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO pér. prod. ="  + num$([M:PPL]PERQTY([M:PPL]IPSO-1)) ) From =G_GLOB0
      # Durée de détention dans la période/exercice
#     Call  CAL_DUR_DET
#&         ([M:PPL]PERSTRDAT([M:PPL]IPSO-1),  [M:PPL]PERENDDAT([M:PPL]IPSO-1), [M:DIV]DATNUL, [M:DIV]DATNUL,
#&          [M:DIV]DTDBAMTREG, [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET
#&         ) From =G_GLOB8
      [M:DIV]PD(0)= [M:PPL]PERSTRDAT([M:PPL]IPSO-1) : [M:DIV]PD(1)= [M:PPL]PERENDDAT([M:PPL]IPSO-1)
      [M:DIV]PD(2)= [M:DIV]DATNUL  : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG
      [M:DIV]PD(5)= [M:DIV]DTFNAMT : [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT
      [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      # Durée de la période/exercice
      Call CAL_DAT_DIFF( [M:PPL]PERSTRDAT([M:PPL]IPSO-1), [M:PPL]PERENDDAT([M:PPL]IPSO-1), [M:DIV]TYPPRODAT,
&                        WDURREF ) From =G_GLOB9
      [M:PPL]PERQTY([M:PPL]IPSO-1) = [M:PPL]PERQTY([M:PPL]IPSO-1) * ( WDURDET / WDURREF )
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - Dur détention ="  + num$(WDURDET)               ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - Dur référence ="  + num$(WDURREF)               ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - UO période    ="  + num$([M:PPL]PERQTY([M:PPL]IPSO-1)) ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UO - -------------------------" ) From =G_GLOB0
  Endif
  Endif
  #-1 -------------------------

  # FQ62320
  If ([M:PPL]IPSO) Then
    # Nombre d'UO pour l'exercice résiduel
    WUOEXE = sum([M:PPL]PERQTY(IPC-1..min([M:PPL]IPSO, IFNE,[M:PPL]IFNA)-1))
    # UO exercice complet
    [F:DEPC]FIYQTY = sum([M:PPL]PERQTY(IDBE-1..min([M:PPL]IPSO, IFNE,[M:PPL]IFNA)-1))
  Else
    # Nombre d'UO pour l'exercice résiduel
    WUOEXE = sum([M:PPL]PERQTY(IPC-1..min(IFNE,[M:PPL]IFNA)-1))
    # UO exercice complet
    [F:DEPC]FIYQTY = sum([M:PPL]PERQTY(IDBE-1..min(IFNE,[M:PPL]IFNA)-1))
  Endif

  If ([M:DIV]NIVDET > 6 ) Then
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Déb. Exercice         ="+ num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Fin  Exercice         ="+ num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Début d'amort.        ="+ num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Fin   d'amort.        ="+ num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Date de sortie        ="+ num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Date de sortie Exe    ="+ num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Base                  ="+ num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Valeur résiduelle     ="+ num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Cumul  E-1            ="+ num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - Durée amort.          ="+ num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UO - UO exercice           ="+ num$([F:DEPC]FIYQTY)    ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UO - Valnet amort déb exe  ="+ num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UO - UO exercice Résiduel  ="+ num$(WUOEXE)            ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UO - UO Résiduel déb pér.  ="+ num$([M:PPL]RSDQTY(IPC-1))) From =G_GLOB0
  Endif

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( [M:PPL]RSDQTY(IPC-1)<> 0 ) Then
    Call ECR_FICH("FS1", 7,
&   "CAL_DOT_EXE_UO - Dot. Exe. = Val. nette déb. exe. * ( UO exercice résiduel / UO Résiduel déb pér.)") From =G_GLOB0
    WDOTEXE = [M:DIV]VLNAMT * WUOEXE / [M:PPL]RSDQTY(IPC-1)
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la dotation
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  # FQ100742_2
  # Si période courante se situe au delà de la fin d'amortissement et qu'une valeur nette existe
  # elle est soldée si le bien n'est pas sortie
  If ( [M:DIV]DTFNAMT < [M:PPL]PERSTRDAT(IPC-1) and [M:DIV]VLNAMT <> 0 and [F:WFAS]ISSDAT = [0/0/0]  ) Then
    [M:DIV]DOTEXE  = [M:DIV]VLNAMT
    [M:DIV]FLGSLDPER = 1
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Fin amort dépassé > Valeur nette => Solde ") From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UO - Dotation exe. Résiduel=" +
&                                           num$([M:DIV]DOTEXE  ) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End



#########################################################
Subprog  CAL_DOT_EXE_CA
#
# - Objet  : Calcule la dotation de l'exercice selon le mode CA
#            Caducité sur valeur brute
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC10
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice
Local Decimal WSUB     : WSUB     = 0.  : # Subvention

Local Date  WDTFNAMT

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Duree
  #=================
  #---------------------
  If ( [F:DEPC]DPRDUR = 0 ) Then
    # La durée d'amortissement n'est pas renseignée, elle est égale à l'intervalle
    # en centième d'années [Début d'amortissement - Fin de concession ]
    If ( day([M:DIV]DTFNCON+1) = day([M:DIV]DTDBAMTREG) and month([M:DIV]DTFNCON+1) = month([M:DIV]DTDBAMTREG) ) Then
      # Durée année entière si jjmm(date fin+1) = jjmm(date début)
      [M:DIV]DURAMTREG = year([M:DIV]DTFNCON +1 )- year([M:DIV]DTDBAMTREG)
    Else
      [M:DIV]DURAMTREG = arr( ([M:DIV]DTFNCON - [M:DIV]DTDBAMTREG + 1) / 365, 0.01)
    Endif
  Else
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, [F:DEPC]DPRDUR, [M:DIV]TYPPRO, WDTFNAMT) From =G_GLOB9
    If ( WDTFNAMT > [M:DIV]DTFNCON and [M:DIV]DTFNCON <> [0/0/0] ) Then
      # Si la fin d'amortissement calculée est au delà de la fin de concession
      # la fin d'amortissement a été ramenée à la fin de concession
      # la durée d'amortissement pour le calcul se base sur la fin de concession
      If ( day([M:DIV]DTFNCON+1) = day([M:DIV]DTDBAMTREG) and month([M:DIV]DTFNCON+1) = month([M:DIV]DTDBAMTREG) ) Then
        # Durée année entière si jjmm(date fin+1) = jjmm(date début)
        [M:DIV]DURAMTREG = year([M:DIV]DTFNCON +1 )- year([M:DIV]DTDBAMTREG)
      Else
        [M:DIV]DURAMTREG = arr( ([M:DIV]DTFNCON - [M:DIV]DTDBAMTREG + 1) / 365, 0.01)
      Endif
    Else
      [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
    Endif
  Endif

  # Récupération de la durée appliquée
  [M:DIV]APLDUR = [M:DIV]DURAMTREG

  #=================
  # Taux
  #=================
  # Calcul du taux linéaire à partir de la durée
  [M:DIV]TXAMT = arr( 1/[M:DIV]DURAMTREG, 0.0001)

  #=================
  # Date Fin Amort.
  #=================
  Gosub CAL_DATE_FIN_AMORT_CA From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #========
  # Base
  #========
  # Base d'amortissement recalculée (subvention déduite)
  [M:DIV]VALAMT = [M:DIV]BASAMT - [M:DIV]SUB

  #---------------------

  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Subvention            =" + num$(WSUB)              ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CA - Valeur nette          =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Val.amt.(Base-subv.)  =" + num$([M:DIV]VALAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Taux  Linéaire        =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0
  Endif
  #---------------------

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-------------------------------------
  Case [F:DEPC]ALWCOD
    When GVML_RPCONCE
    #---------------------------
    #- REGUL/REINT AMORTISSEMENT
      # Ecart Cumul E-1 en Amortissement Exceptionnel
      # Pas de réévaluation pas de dépréciation pour ce mode (Initial, Théorique Réel sont identiques)
      [M:DIV]AMTEXC       = [M:DIV]ECACUME_1R
      [M:DIV]ECACUME_1R   = 0.
    When GVML_RPABCON
    #---------------------------
    #- ABANDON CADUCITE
      # Cumul E-1 extourné Amortissement Exceptionnel
      # Pas de réévaluation pas de dépréciation pour ce mode (Initial, Théorique Réel sont identiques)
      [M:DIV]AMTEXC = -[F:DEPC]DPRCUM
      [M:DIV]DOTEXE = 0.
    When GVML_RPAUCUN
    #---------------------------
    #- AUCUNE REGLE PARTICULIERE
    When Default
      ## ????
  Endcase
  #-------------------------------------

  #-1 --------------------
  If ( [F:DEPC]ALWCOD <> GVML_RPABCON ) Then
    #-2 --------------------
    If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
      # La date de fin d'amortissement n'appartient pas à l'exercice

      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Durée Exercice        ="+num$([M:DIV]DUREXE)) From =G_GLOB0

      #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
      # calcul de la dotation exercice
      If ( [M:DIV]DUREXE <> 0 ) Then
        # Base * taux * prorata de détention dans l'exercice
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Val.amt.(Base-subv.) * Taux  Linéaire * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
        WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
      Else
        WDOTEXE = 0
      Endif
      #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
      [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
      #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    #-2 --------------------
    Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La date de fin d'amortissement appartient à l'exercice

      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
      # Calcul de la durée restant à amortir
      Call  CAL_DUR_REST_AMT
&           ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&     From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
        WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        WDOTEXE = 0
      Endif
    Endif
    #-2 --------------------
  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CA - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # On ne met pas à jour la durée d'amortissement
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_RA
#
# - Objet  : Calcule la dotation de l'exercice selon le mode Caducité sur valeur nette
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire GCFC32
#

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
Local Decimal WSUB     : WSUB     = 0.       : # Subvention

Local Date WDTFNAMT

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Duree
  #=================
  #-1 --------------------
  If ( [F:DEPC]DPRDUR = 0 ) Then
    #-2 --------------------
    If ( [F:DEPC]ENDDPRFLG = G_OUI ) Then
      # La durée d'amortissement n'est pas renseignée et la date de fin d'amortissement est forcée,
      # Dans ce cas la durée est égale à L'intervalle
      # en centième d'années [min( Fin d'amortissement, Fin de concession) - Début d'amortissement]
      Local Date LDATMIN
      If ( [M:DIV]DTFNCON > [F:DEPC]ENDDPRDAT and [F:DEPC]ENDDPRDAT <> [0/0/0] ) Then
        LDATMIN = [F:DEPC]ENDDPRDAT
      Else
        LDATMIN = [M:DIV]DTFNCON
      Endif
      # FQ52495
      If ( day(LDATMIN +1) = day([M:DIV]DTDBAMTREG) and month(LDATMIN +1) = month([M:DIV]DTDBAMTREG) ) Then
        # Durée année entière si jjmm(date fin+1) = jjmm(date début)
        [M:DIV]DURAMTREG = year(LDATMIN +1 )- year([M:DIV]DTDBAMTREG)
      Else
        [M:DIV]DURAMTREG = arr( (LDATMIN - [M:DIV]DTDBAMTREG + 1) / 365, 0.01)
      Endif
      #-2 --------------------
    Else
      # La durée d'amortissement n'est pas renseignée et la date de fin d'amortissement n'est pas forcée,
      # Dans ce cas la durée est égale à L'intervalle en centième d'années [Fin de concession - Début d'amortissement]
      # FQ52495
      If ( day([M:DIV]DTFNCON+1) = day([M:DIV]DTDBAMTREG) and month([M:DIV]DTFNCON+1) = month([M:DIV]DTDBAMTREG) ) Then
        # Durée année entière si jjmm(date fin+1) = jjmm(date début)
        [M:DIV]DURAMTREG = year([M:DIV]DTFNCON +1 )- year([M:DIV]DTDBAMTREG)
      Else
        [M:DIV]DURAMTREG = arr( ([M:DIV]DTFNCON - [M:DIV]DTDBAMTREG + 1) / 365, 0.01)
      Endif
      Endif
      #-2 --------------------
  #-1 --------------------
  Else
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, [F:DEPC]DPRDUR, [M:DIV]TYPPRO, WDTFNAMT) From =G_GLOB9
    If ( WDTFNAMT > [M:DIV]DTFNCON and [M:DIV]DTFNCON <> [0/0/0] ) Then
      # Si la fin d'amortissement calculée est au delà de la fin de concession
      # la fin d'amortissement a été ramenée à la fin de concession
      # la durée d'amortissement pour le calcul se base sur la fin de concession
      If ( day([M:DIV]DTFNCON+1) = day([M:DIV]DTDBAMTREG) and month([M:DIV]DTFNCON+1) = month([M:DIV]DTDBAMTREG) ) Then
        # Durée année entière si jjmm(date fin+1) = jjmm(date début)
        [M:DIV]DURAMTREG = year([M:DIV]DTFNCON +1 )- year([M:DIV]DTDBAMTREG)
      Else
        [M:DIV]DURAMTREG = arr( ([M:DIV]DTFNCON - [M:DIV]DTDBAMTREG + 1) / 365, 0.01)
      Endif
    Else
      [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
    Endif
  Endif
  #-1 --------------------

  # Récupération de la durée appliquée
  [M:DIV]APLDUR = [M:DIV]DURAMTREG

  #=================
  # Taux
  #=================
  [M:DIV]TXAMT = 0.

  #=================
  # Date Fin Amort.
  #=================
  Gosub CAL_DATE_FIN_AMORT_CA From =G_GLOB8


  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Début d'amort.    =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Fin   d'amort.    =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Date  sortie      =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Date  sortie Exe  =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Subvention        =" + num$(WSUB)              ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Base              =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Valeur résiduelle =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Cumul  E-1        =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RA - Cumul  P-1        =" + num$([F:DEPC]PERCLOCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, " " ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Date de référence     =" + num$([M:DIV]EXEDATREF) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( WDURRES <> 0 ) Then
    WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la dotation
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RA - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # On ne met pas à jour la durée d'amortissement
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End






#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343



#########################################################
Subprog CAL_AVANT_CCN_PROV_EXE ()
#
# - Objet  : Calcule la provsion pour l'exercice
#
#
# - Entrée : [M:DIV] Structure Cdota
#
  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Valeur de remplacement
  If ( [M:DIV]RNWVALFRC ) Then
    # La valeur de remplacement forcée est uniquement utilisée sur l'exercice courant
    [F:RPRC]ENDRNWVAL = [M:DIV]RNWVALFRC
    [F:RPRC]RNWVALFLG = G_OUI
    # Une seule fois
    [M:DIV]RNWVALFRC  = 0
    # Affectation du coefficient d'actualisation
    If ( [F:RPRC]STRRNWVAL = 0 ) Then
      [F:RPRC]RNWVALCOE = 1.
    Else
      [F:RPRC]RNWVALCOE = arr( 1 + (([F:RPRC]ENDRNWVAL-[F:RPRC]STRRNWVAL)/[F:RPRC]STRRNWVAL), 0.000001)
    Endif
  Else
    # Affectation du coefficient d'actualisation
    If ( [F:DEPC]STRDPRDAT > [F:RPRC]FIYENDDAT ) Then
      [F:RPRC]RNWVALCOE = 1.
    Else
      [F:RPRC]RNWVALCOE = [M:DIV]COEACT
    Endif

    [F:RPRC]ENDRNWVAL = [F:RPRC]STRRNWVAL * [F:RPRC]RNWVALCOE
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT ([F:RPRC]ENDRNWVAL, [M:DIV]CUR , [F:RPRC]ENDRNWVAL) From =GLOBB8
    [M:DIV]PV(0)= [F:RPRC]ENDRNWVAL : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : [F:RPRC]ENDRNWVAL = [M:DIV]RV(1)
  Endif

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTRNWVAL               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI4FR ) Then : # FQ114113
    GPOINT = "AFTRNWVAL"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # Type de prorata en jours
  [M:DIV]TYPPRODAT = "D"
  [M:DIV]TYPPRO    = GVML_TPJOUR

  #--
  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, [F:DEPC]FIYSTRDAT, "D", [M:DIV]DTDBEXE) From GLOBB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= [F:DEPC]FIYSTRDAT : [M:DIV]PC(0)= "D"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From GLOBB8
  [M:DIV]DTDBEXE = [M:DIV]RD(0)
  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, [F:DEPC]FIYENDDAT, "F", [M:DIV]DTFNEXE) From GLOBB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= [F:DEPC]FIYENDDAT : [M:DIV]PC(0)= "F"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From GLOBB8
  [M:DIV]DTFNEXE = [M:DIV]RD(0)
  # Ajustement dates période (pour affectation éventuelle [M:DIV]EXEDATREF avec [M:DIV]DTDBPER )
  Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO,
&      [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From GLOBB5

  #-- Début exercice (par défaut)
  [M:DIV]EXEDATREF  = [M:DIV]DTDBEXE
  #-- Début exercice (par défaut)
  [M:DIV]DTDBAMTREG = [F:DEPC]STRDPRDAT
  # Date de fin d'amortissement (fin amortissement industriel soit date de renouvellement si elle a été forcée)
  # FQ122306 [M:DIV]DTFNAMT    = [F:WFAS]RNWDAT
  [M:DIV]DTFNAMT    = [F:WFAS]RNWDAT
  If ([M:DIV]DTFNAMT = [0/0/0] or [M:DIV]DTFNAMT > [M:DIV]DTFNCON) Then
    [M:DIV]DTFNAMT = [M:DIV]DTFNCON
  Endif
  # Date de sortie
  [M:DIV]DATSOREXE  = [F:WFAS]ISSDAT


End


#########################################################
Subprog CCN_PROV_EXE ()
#
# - Objet  : Calcule la provsion pour l'exercice
#
#
# - Entrée : [M:DIV] Structure Cdota
#
 #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

 Local Decimal LBASIND

 If ( [F:WFAS]RNWFLG = G_OUI ) Then
   # Si le type d'apport est "Concédant", la provision est calculée en ne tenant compte que de la valeur de remplacement
   If ( [F:WFAS]CCNETRNAT = GVML_NECONCD ) Then
     LBASIND = 0
     Call ECR_FICH("FS1", 6, "CCN_PROV_EXE - !!! Apport Concédant => Valeur rempl. actu. uniquement prise en compte !!!") From =G_GLOB0
   Else
     LBASIND = [F:DEPC]DPRBAS
   Endif

   # Provisions exercice pour le comptable
   Call CCN_PROV_CPT_EXE (LBASIND, [F:RPRC]ENDRNWVAL, [F:RPRC]E_1ACGRPR, [M:DIV]EXEACGRPR) From =G_GLOB4FR

   # Provisions exercice pour le fiscal
   Call CCN_PROV_FIS_EXE (LBASIND, [F:RPRC]ENDRNWVAL, [F:RPRC]E_1FISRPR, [M:DIV]EXEFISRPR) From =G_GLOB4FR
 Else
   # Pas de provision s'il n'y a pas d'obligation effective de renouvellement
   # S'il existe des cumuls E-1 ou P-1 ils sont à reprendre
   # [M:DIV]EXEACGRPR = ([F:RPRC]E_1ACGRPR + [F:RPRC]P_1ACGRPR) * -1
   # [M:DIV]EXEFISRPR = ([F:RPRC]E_1FISRPR + [F:RPRC]P_1FISRPR) * -1
   [M:DIV]EXEACGRPR = [F:RPRC]E_1ACGRPR * -1
   [M:DIV]EXEFISRPR = [F:RPRC]E_1FISRPR * -1
 Endif

 # Reprise Provisions Fiscal - Exercice
 Call CCN_REPR_PROV_FIS_EXE ([F:WFAS]RVERPRVAL, [F:RPRC]E_1RVERPR, [M:DIV]EXERVERPR) From =G_GLOB4FR

 # Reprise Ecart de caducité - Exercice
 Call CCN_SUP_CAD_FIS_EXE ([F:WFAS]CCNCADDEV, [F:RPRC]E_1SUPCAD, [M:DIV]EXESUPCAD) From =G_GLOB4FR

 # Si bien "En cours" pas de provisions pour renouvellement
 If ( [F:WFAS]GACACN = GVML_NIENCOU ) Then
   [M:DIV]EXEACGRPR = 0
   [M:DIV]EXEFISRPR = 0
   [M:DIV]EXERVERPR = 0
   [M:DIV]EXESUPCAD = 0
 Endif

 # Pas de provision fiscale au delà de la date de renouvellement (La provision comptable est calculée)
 # FQ122306
 #If (  [F:RPRC]FIYSTRDAT > [F:WFAS]RNWDAT ) Then
 If (  [F:WFAS]RNWDAT <> [0/0/0] and [F:RPRC]FIYSTRDAT > [F:WFAS]RNWDAT ) Then
   If ( [F:WFAS]RNWFLG = G_OUI ) Then
     [M:DIV]EXEFISRPR = 0
   Endif
   [M:DIV]EXERVERPR = 0
   [M:DIV]EXESUPCAD = 0
 Endif

 # Pas de provision au delà de la date de sortie
 If (  [F:WFAS]ISSDAT <> [0/0/0] and [F:RPRC]FIYSTRDAT > [F:WFAS]ISSDAT ) Then
   [M:DIV]EXEACGRPR = 0
   [M:DIV]EXEFISRPR = 0
   [M:DIV]EXERVERPR = 0
   [M:DIV]EXESUPCAD = 0
 Endif

End

#------------------------------------------
Subprog CCN_PROV_CPT_EXE (PVALINI, PVALFIN, PCUMPRV, RPRVCPT)


Value    Decimal PVALINI    : # Valeur initiale ( Base amortissement industriel )
Value    Decimal PVALFIN    : # Valeur de remplacement du bien
Value    Decimal PCUMPRV    : # Cumul des provisions comptables déjà constatées
Variable Decimal RPRVCPT    : # Provision comptable exercice

  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #--
  RPRVCPT = 0

  # FQ96994
  # Si la valeur de remplacement est inférieure ou égale à la valeur de remplacement
  # Aucune provision comptable n'est à constater.
  If (abs(PVALFIN) <=  abs(PVALINI)) Then
    RPRVCPT = - PCUMPRV
    Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Base amort. industiel  =" +  num$(PVALINI) )       From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Val. rempl. actualisée =" +  num$(PVALFIN) )       From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Val. rempl. <= Val. intiale donc Provision comptable ="-num$(RPRVCPT)) From =G_GLOB0
    End
  Endif

  # Provision comptable
  # La provision constatée au niveau comptable pour le remplacement du bien N est égale à :
  # ( Valeur de remplacement - Valeur initiale ) - Cumul des provisions Cumul des prov. E-1
  # et ce, valeur bilan plan subvention déduite

  # FQ104529 Aménagement en attendant une solution plus propre
  # Si apport concédant et coefficient d'acutalisation = 1 alors pas de provision comptable pour renouvellement
  #RPRVCPT =  (PVALFIN - PVALINI) - PCUMPRV
  If ( [F:WFAS]CCNETRNAT = GVML_NECONCD and [M:DIV]COEACT = 1.)
    RPRVCPT =  (0 - PCUMPRV)
  Else
    RPRVCPT =  (PVALFIN - PVALINI) - PCUMPRV
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (RPRVCPT, [M:DIV]CUR , RPRVCPT) From =GLOBB8
  [M:DIV]PV(0)= RPRVCPT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From GLOBB8 : RPRVCPT = [M:DIV]RV(1)

  Call ECR_FICH("FS1", 6, "CCN_PROV_CPT_EXE - Détermination Prov. Cpt. Exe.")                    From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Base amort. industiel  =" +  num$(PVALINI) )       From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Val. rempl. actualisée =" +  num$(PVALFIN) )       From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - Cumul prov. cpt. E-1   =" +  num$(PCUMPRV) )       From =G_GLOB0
  Call ECR_FICH("FS1", 7,
&   "CCN_PROV_CPT_EXE - Prov CPT exe  = ( Val rempl actu - Base amort indus ) - Cumul Prov E-1") From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_CPT_EXE - *** Prov. Cpt Exe.     =" +  num$(RPRVCPT) )       From =G_GLOB0

End

#------------------------------------------
Subprog CCN_PROV_FIS_EXE ( PVALINI, PVALFIN, PCUMPRV, RPRVFIS)

Value    Decimal PVALINI    : # Valeur initiale ( Base amortissement industriel )
Value    Decimal PVALFIN    : # Valeur de remplacement du bien
Value    Decimal PCUMPRV    : # Cumul des provisions fiscales déjà constatées
Variable Decimal RPRVFIS    : # Provision fiscale exercice

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
Local Decimal WPRVEXE  : WPRVEXE  = 0.       : # Provision de l'exercice

  #--
  RPRVFIS = 0

  # FQ96994
  # Si la valeur de remplacement est inférieure ou égale à la valeur de remplacement
  # Aucune provision comptable n'est à constater.
  If (abs(PVALFIN) <=  abs(PVALINI)) Then
    RPRVFIS = - PCUMPRV
    Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Val. rempl. <= Val. intiale donc Provision fiscale ="-num$(RPRVFIS)) From =G_GLOB0
    End
  Endif

  # Calcul de la durée d'utilisation fin exe  [Deb Amort Indus, min(Fin Exe, Date renouv.)]
# Call  CAL_DUR_DET
#&      ([M:DIV]DTDBAMTREG, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]DTDBAMTREG : [M:DIV]PD(1)= [M:DIV]DTFNEXE    : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL     : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE  : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif

  # Calcul de la durée d'utilisation globale  [Deb Amort indus , Date renouv.]
# Call  CAL_DUR_DET
#&      ([M:DIV]DTDBAMTREG, [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DATNUL,
#&      [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From GLOBB8
  # FQ66190
  [M:DIV]PD(0)= [M:DIV]DTDBAMTREG : [M:DIV]PD(1)= [M:DIV]DTFNAMT    : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL     : [M:DIV]PD(4)= [M:DIV]DATNUL     : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATNUL     : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURRES = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif

  # Provision fiscale
  # La provision constatée au niveau fiscal pour le remplacement du bien N est égale à :
  # ( Val. rempl. actu. - Val. initiale ) * Durée détention Exe. / Durée résiduelle  - Cumul des prov. E-1
  # et ce, valeur bilan plan subvention déduite
  # calcul de la provision exercice
  If ( WDURRES <> 0 ) Then
    # FQ104529 Aménagement en attendant une solution plus propre
    # Si apport concédant et coefficient d'acutalisation = 1 alors pas de provision comptable pour renouvellement
    #WPRVEXE = ((PVALFIN-PVALINI)*(WDURDET/WDURRES)) - PCUMPRV
    If ( [F:WFAS]CCNETRNAT = GVML_NECONCD and [M:DIV]COEACT = 1.)
      WPRVEXE =  (0 - PCUMPRV)
    Else
      WPRVEXE = ((PVALFIN-PVALINI)*(WDURDET/WDURRES)) - PCUMPRV
    Endif
  Else
    WPRVEXE = 0
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WPRVEXE, [M:DIV]CUR , RPRVFIS) From GLOBB8
  [M:DIV]PV(0)= WPRVEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RPRVFIS = [M:DIV]RV(1)


  Call ECR_FICH("FS1", 6, "CCN_PROV_FIS_EXE - Détermination Prov. Fisc. Exe."                                    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Début amortissement                  =" +  num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Deb => Date renouvellement           =" +  num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Fin => Date fin exercice             =" +  num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Fin => Date sortie                   =" +  num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Fin => Date fin amort industriel     =" +  num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Dur util fin exe [Deb AMI, Fin Exe]  =" +  num$(WDURDET)           ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Dur util globale [Deb AMI, Renouv.]  =" +  num$(WDURRES)           ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Val. rempl. actualisée               =" +  num$(PVALFIN)           ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Base amort. industiel                =" +  num$(PVALINI)           ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - Cumul prov. fisc E-1   =" +  num$(PCUMPRV)                         ) From =G_GLOB0
  Call ECR_FICH("FS1", 7,
&   "CCN_PROV_FIS_EXE - Prov FIS exe = (Val rempl actu - Base amort Indus) * (Dur util. fin exe/ Dur Util. Globale) - Cum Prov Fis E-1") From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_PROV_FIS_EXE - *** Prov. Fisc. Exe.   =" +  num$(RPRVFIS) ) From =G_GLOB0

End

#------------------------------------------
Subprog CCN_REPR_PROV_FIS_EXE (PPRVREP, PCUMREP, RREPPRV)


Value    Decimal PPRVREP    : # Provisions fiscales à reprendre
Value    Decimal PCUMREP    : # Cumul de reprise de provisions fiscales déjà constatées
Variable Decimal RREPPRV    : # Reprise provision fiscale exercice

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
Local Decimal WREPEXE  : WREPEXE  = 0.       : # Reprise provision de l'exercice

  #--
  RREPPRV = 0

  # Durée de détention dans l'exercice [ max(Deb Exe, Deb Amort Indus) , min(Fin Exe, Date renouv.)]
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE    : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif

  # Calcul de la durée restant à amortir  [ max(Deb Exe, Deb Amort Indus) , Date renouv.]
  Call  CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From GLOBB8

  # Provision fiscale
  # La provision constatée au niveau fiscal pour le remplacement du bien N est égale à :
  # ( Val. rempl. actu. - Val. initiale ) * Durée détention Exe. / Durée résiduelle  - Cumul des prov. E-1
  # et ce, valeur bilan plan subvention déduite
  # calcul de la provision exercice
  If ( WDURRES <> 0 ) Then
    WREPEXE = ((PPRVREP- PCUMREP) *(WDURDET/WDURRES))
  Else
    WREPEXE = 0
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WREPEXE, [M:DIV]CUR , RREPPRV) From GLOBB8
  [M:DIV]PV(0)= WREPEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RREPPRV = [M:DIV]RV(1)


  Call ECR_FICH("FS1", 6, "CCN_REPR_PROV_FIS_EXE - Détermination Reprise Prov. Fisc. Exe.")     From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_REPR_PROV_FIS_EXE - Durée Détention Exe.   =" +  num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_REPR_PROV_FIS_EXE - Durée Résid. à amort.  =" +  num$(WDURRES) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_REPR_PROV_FIS_EXE - Provision à reprendre  =" +  num$(PPRVREP) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_REPR_PROV_FIS_EXE - Cumul Repr. Prov.  E-1 =" +  num$(PCUMREP) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7,
&   "CCN_REPR_PROV_FIS_EXE - Reprise Prov Fisc = (Prov Fisc à reprendre * (Dur Dét Exe/Dur Rési) - Cum Repr Prov Fis E-1") From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_REPR_PROV_FIS_EXE - *** Repr Prov Fisc Exe =" +  num$(RREPPRV) ) From =G_GLOB0

End

#------------------------------------------
Subprog CCN_SUP_CAD_FIS_EXE (PSUPCAD, PCUMREP, RSUPCAD)


Value    Decimal PSUPCAD    : # Ecart de caducité
Value    Decimal PCUMREP    : # Cumul de reprise de l'écart de caducité
Variable Decimal RSUPCAD    : # Reprise de l'écart de caducité exercice

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
Local Decimal WREPEXE  : WREPEXE  = 0.       : # Reprise écart de caducité exercice

  #--
  RSUPCAD = 0

  # Durée de détention dans l'exercice [ max(Deb Exe, Deb Amort Indus) , min(Fin Exe, Date renouv.)]
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET ) From GLOBB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE    : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From GLOBB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif

  # FQ68803
  # Calcul de la durée fin concession  [ Deb Amort Indus), Date fin de concession ]
  # Call  CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]DATNUL, [M:DIV]DTFNCON, [M:DIV]TYPPRODAT, WDURRES) From GLOBB8
  # Calcul de la durée fin concession  [ Deb Exercice, Date fin de concession ]
  Call  CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNCON, [M:DIV]TYPPRODAT, WDURRES) From GLOBB8

  # Reprise supplément de caducité
  # (Supplément de caducité - Cumul Suppl. Cad. E-1) * ( Durée détention / Durée résiduelle)

  If ( WDURRES <> 0 ) Then
    WREPEXE = ((PSUPCAD - PCUMREP) *(WDURDET/WDURRES))
  Else
    WREPEXE = 0
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WREPEXE, [M:DIV]CUR , RREPPRV) From GLOBB8
  [M:DIV]PV(0)= WREPEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RSUPCAD = [M:DIV]RV(1)


  Call ECR_FICH("FS1", 6, "CCN_SUP_CAD_FIS_EXE - Détermination Reprise Ecart de Caducité Exe.")    From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_SUP_CAD_FIS_EXE - Durée Détention Exe.           =" +  num$(WDURDET) )      From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_SUP_CAD_FIS_EXE - Durée conc.[Deb AMI, Fin Conc] =" +  num$(WDURRES) )      From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_SUP_CAD_FIS_EXE - Supplement de caducité         =" +  num$(PSUPCAD) )      From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_SUP_CAD_FIS_EXE - Cumul Suppl. Caducité E-1      =" +  num$(PCUMREP) )      From =G_GLOB0
  Call ECR_FICH("FS1", 7,
&   "CCN_SUP_CAD_FIS_EXE - Reprise Suppl. Caducité = (Supplément caducité - Cumul Suppl. Caducité E-1 ) * (Dur Dét Exe/Dur Conc.)") From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CCN_SUP_CAD_FIS_EXE - *** Reprise Suppl. Caducité =" +  num$(RSUPCAD) ) From =G_GLOB0

End

