##########################################################################################################
$LOADSYN
  Case [M:SYN0]CXT
    When "SRE"
      [M:SYN1]SYN = [M:SRE1]SREDES
      [M:SYN2]DES = [M:SRE1]SREFULDES
    When "SET"
      [M:SYN1]SYN = [M:SET1]DES
      [M:SYN2]DES = [M:SET1]FULDES
    When "ITN"
      [M:SYN1]SYN = [M:ITN4]RPO
      [M:SYN2]DES = [M:ITN4]FULRPO
    When "ITNOBJ"
      [M:SYN1]SYN = [M:ITN1]OBJ
      [M:SYN2]DES = [M:ITN1]FULOBJ
    When "HDK4"
      [M:SYN1]SYN = [M:HDK4]RPO
      [M:SYN2]DES = [M:HDK4]FULRPO
    When "SOLSRE", "FSOLSRE"
      [M:SYN1]SYN = [M:SOL1]PBLDES
      [M:SYN2]DES = [M:SOL1]PBLFULDES
    When "SOL", "FSOL"
      [M:SYN1]SYN = [M:SOL2]SOLDES
      [M:SYN2]DES = [M:SOL2]SOLFULDES
    When "BAPOBJ"
      [M:SYN1]SYN = [M:BAP1]APTOBJ
      [M:SYN2]DES = [M:BAP1]FULOBJ
    When "BAPRPO"
      [M:SYN1]SYN = [M:BAP4]APTRPO
      [M:SYN2]DES = [M:BAP4]FULRPO
    When "TSKOBJ"
      [M:SYN1]SYN = [M:TSK1]TSKDES
      [M:SYN2]DES = [M:TSK1]FULOBJ
    When "TSKRPO"
      [M:SYN1]SYN = [M:TSK2]TSKRPO
      [M:SYN2]DES = [M:TSK2]FULRPO
    When "CLLOBJ"
      [M:SYN1]SYN = [M:CLL1]CLLOBJ
      [M:SYN2]DES = [M:CLL1]FULOBJ
    When "CLLRPO"
      [M:SYN1]SYN = [M:CLL3]CLLRPO
      [M:SYN2]DES = [M:CLL3]FULRPO
    When "CRMG"
      [M:SYN1]SYN = [M:CRMG]RPO
      [M:SYN2]DES = [M:CRMG]FULRPO
    When "CMG"
      [M:SYN1]SYN = [M:CMG2]DES
      [M:SYN2]DES = [M:CMG2]FULOBJ
    When "OMM"
      [M:SYN1]SYN = [M:OMM1]OBJ
      [M:SYN2]DES = [M:OMM1]FULOBJ
    When "OMP"
      [M:SYN1]SYN = [M:OMP1]OBJ
      [M:SYN2]DES = [M:OMP1]FULOBJ
    When "OMT"
      [M:SYN1]SYN = [M:OMT1]OBJ
      [M:SYN2]DES = [M:OMT1]FULOBJ
    When "OMN"
      [M:SYN1]SYN = [M:OMN1]OBJ
      [M:SYN2]DES = [M:OMN1]FULOBJ
    When Default
      Raz [M:SYN1]
  Endcase
Return
