#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Saisie des synthèses                                            Module CRM          4 Décembre 2003
##########################################################################################################
# FGR 06/08/2014 : X3SUIVI95250 : Tout revu. Il n'y a plus qu'une action  SAISYN2
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Local Integer ISYNHBDISP
Local Integer ITESTVCR

  ISYNHBDISP = 0
  ITESTVCR = 1
  If PARAM(1) = "" Then
    #Aucun contexte n'a été communiqué. Accès refusé.
    GMESSAGE = mess(828,182,1)
    GERR = 1
    FIN = 1
    Return
  Elsif PARAM(1) = "FSOLSRE" or PARAM(1) = "FSOL" Then
    ITESTVCR = 0
  Elsif PARAM(1) = "OMM" or PARAM(1) = "OMP" or PARAM(1) = "OMT" or PARAM(1) = "OMN" Then
    If type(GSZWIZCOD) > 0 Then
      ITESTVCR = 0
    Endif
  Endif
  If ITESTVCR Then
    If PARAM(2) = "" and PARAM(3) = "" Then
      #Aucun numéro de pièce n'a été communiqué. Accès refusé.
      GMESSAGE = mess(830,182,1)
      GERR = 1
      FIN = 1
      Return
    Endif
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:SYN0]DIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:SYN0]TTR = ""
  [M:SYN0]CXT = PARAM(1)
  [M:SYN0]CXTGREP = PARAM(2)
  [M:SYN0]VCRNUM = PARAM(3)
  Case [M:SYN0]CXT
    When "SRE"
      #Synthèse de la description de la demande de service.
      [M:SYN0]TTR = mess(832,182,1)
    When "SET"
      #Synthèse de la description du modèle de demande de service.
      [M:SYN0]TTR = mess(858,182,1)
    When "ITN"
      #Synthèse du compte-rendu de l'intervention.
      [M:SYN0]TTR = mess(833,182,1)
    When "ITNOBJ"
      #Synthèse du complément d'informations de l'intervention.
      [M:SYN0]TTR = mess(853,182,1)
    When "HDK4"
      #Synthèse du compte-rendu de l'intervention.
      [M:SYN0]TTR = mess(833,182,1)
    When "SOLSRE", "FSOLSRE"
      #Synthèse de la description de la demande de service d'origine.
      [M:SYN0]TTR = mess(834,182,1)
    When "SOL", "FSOL"
      #Synthèse de la description de la solution.
      [M:SYN0]TTR = mess(835,182,1)
    When "BAPOBJ"
      #Synthèse de l'objectif du rendez-vous.
      [M:SYN0]TTR = mess(863,182,1)
    When "BAPRPO"
      #Synthèse du compte-rendu du rendez-vous.
      [M:SYN0]TTR = mess(864,182,1)
    When "TSKOBJ"
      #Synthèse de la description de la tâche
      [M:SYN0]TTR = mess(869,182,1)
    When "TSKRPO"
      #Synthèse du compte-rendu de la tâche
      [M:SYN0]TTR = mess(870,182,1)
    When "CLLOBJ"
      #Synthèse de l'objet de l'appel
      [M:SYN0]TTR = mess(875,182,1)
    When "CLLRPO"
      #Synthèse du compte-rendu de l'appel
      [M:SYN0]TTR = mess(876,182,1)
    When "CRMG"
      Case [M:CRMG]VCRTYP
        When "BAP"
          #Synthèse du compte-rendu du rendez-vous.
          [M:SYN0]TTR = mess(864,182,1)
        When "CLL"
          #Synthèse du compte-rendu de l'appel
          [M:SYN0]TTR = mess(876,182,1)
        When "TSK"
          #Synthèse du compte-rendu de la tâche
          [M:SYN0]TTR = mess(870,182,1)
        When Default
      Endcase
    When "CMG"
      #Synthèse de la description de la campagne
      [M:SYN0]TTR = mess(879,182,1)
    When "OMM"
      #Synthèse de la description du publipostage
      [M:SYN0]TTR = mess(882,182,1)
    When "OMP"
      #Synthèse de la description de la campagne d'appels
      [M:SYN0]TTR = mess(883,182,1)
    When "OMT"
      #Synthèse de la description du salon professionnel
      [M:SYN0]TTR = mess(884,182,1)
    When "OMN"
      #Synthèse de la description de la campagne presse
      [M:SYN0]TTR = mess(885,182,1)
    When Default
  Endcase
  If [M:SYN0]TTR = "" Then
    #Saisie de la synthèse
    [M:SYN0]TTR = mess(827,182,1)
  Endif
  Gosub LOADSYN
  [M:SYN1]PRESYN = [M:SYN1]SYN
  Affzo [M:SYN0]1-99
  Affzo [M:SYN1]1-99
  Affzo [M:SYN2]1-99
  ISYNHBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If ISYNHBDISP Then
    Raz [M:SYN0]
    Raz [M:SYN1]
    Raz [M:SYN2]
  Endif
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  [M:SYN0]DIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Traitement du bouton OK
#########################################################
#########################################################
# FGR 28/08/2014 : X3SUIVI95250
$ONOK
Local Integer ISETMKSTAT4

  If [M:SYN1]PRESYN = [M:SYN1]SYN Then
    [M:SYN0]DIRTY = 0
    Return
  Endif
  If [M:SYN0]CXTGREP = "FSOLSRE" or [M:SYN0]CXTGREP = "FSOL" Then
    [M:SYN0]CXTGREP = "C"
  Endif
  If PARAM(1) = "OMM" or PARAM(1) = "OMP" or PARAM(1) = "OMT" or PARAM(1) = "OMN" Then
    If type(GSZWIZCOD) > 0 Then
      [M:SYN0]CXTGREP = "C"
    Endif
  Endif
  ISETMKSTAT4 = 0
  If [M:SYN0]CXTGREP = "" Then
    ISETMKSTAT4 = 1
    Case [M:SYN0]CXT
      When "HDK4"
        ISETMKSTAT4 = 0
        Call DEBTRANS From GLOCK
        Trbegin [ITN]
        Readlock [ITN]ITN0=[M:SYN0]VCRNUM
        If fstat Then
          #Erreur lors de l'enregistrement de la synthèse. Modification en cours sur un autre poste.
          GMESSAGE = mess(829,182,1)
          GERR = 1
          Rollback
          FIN = 0
          Return
        Else
          [F:ITN]RPO = [M:SYN1]SYN
          [F:ITN]RPOFLG = 1
          Rewrite [ITN]
          If fstat Then
            #L'enregistrement de la synthèse à échoué.
            GMESSAGE = mess(831,182,1)
            GERR = 1
            Rollback
            FIN = 0
            Return
          Else
            Commit
          Endif
        Endif
      When "CRMG"
        ISETMKSTAT4 = 0
        Case [M:CRMG]VCRTYP
          When "BAP"
            Call DEBTRANS From GLOCK
            Trbegin [BAP]
            Readlock [BAP]APP0=[M:SYN0]VCRNUM
            If fstat Then
              #Erreur lors de l'enregistrement de la synthèse. Modification en cours sur un autre poste.
              GMESSAGE = mess(829,182,1)
              GERR = 1
              Rollback
              FIN = 0
              Return
            Else
              [F:BAP]APTRPO = [M:SYN1]SYN
              [F:BAP]RPOFLG = 1
              Rewrite [BAP]
              If fstat Then
                #L'enregistrement de la synthèse à échoué.
                GMESSAGE = mess(831,182,1)
                GERR = 1
                Rollback
                FIN = 0
                Return
              Else
                Commit
              Endif
            Endif
          When "CLL"
            Call DEBTRANS From GLOCK
            Trbegin [CLL]
            Readlock [CLL]CLL0=[M:SYN0]VCRNUM
            If fstat Then
              #Erreur lors de l'enregistrement de la synthèse. Modification en cours sur un autre poste.
              GMESSAGE = mess(829,182,1)
              GERR = 1
              Rollback
              FIN = 0
              Return
            Else
              [F:CLL]CLLRPO = [M:SYN1]SYN
              [F:CLL]RPOFLG = 1
              Rewrite [CLL]
              If fstat Then
                #L'enregistrement de la synthèse à échoué.
                GMESSAGE = mess(831,182,1)
                GERR = 1
                Rollback
                FIN = 0
                Return
              Else
                Commit
              Endif
            Endif
          When "TSK"
            Call DEBTRANS From GLOCK
            Trbegin [TSK]
            Readlock [TSK]TSK0=[M:SYN0]VCRNUM
            If fstat Then
              #Erreur lors de l'enregistrement de la synthèse. Modification en cours sur un autre poste.
              GMESSAGE = mess(829,182,1)
              GERR = 1
              Rollback
              FIN = 0
              Return
            Else
              [F:TSK]TSKRPO = [M:SYN1]SYN
              [F:TSK]RPOFLG = 1
              Rewrite [TSK]
              If fstat Then
                #L'enregistrement de la synthèse à échoué.
                GMESSAGE = mess(831,182,1)
                GERR = 1
                Rollback
                FIN = 0
                Return
              Else
                Commit
              Endif
            Endif
        Endcase
      When "CMG"
        ISETMKSTAT4 = 1  # NOTE FGR : Celui-là c'est normal qu'il soit à 1
        Call MNGUPDSYN("CMGSYN", [M:SYN0]VCRNUM) From SUBCMGB
      When Default
    Endcase
  Endif
  Case [M:SYN0]CXT
    When "SRE"
      [M:SRE1]SREDESICO = "117"
      [M:SRE1]SREDESFLG = 1
      [M:SRE1]SREDES = [M:SYN1]SYN
      Affzo [M:SRE1]1-99
    When "SET"
      [M:SET1]DESICO = "117"
      [M:SET1]DESFLG = 1
      [M:SET1]DES = [M:SYN1]SYN
      Affzo [M:SET1]1-99
    When "ITN"
      [M:ITN4]RPOICO = "117"
      [M:ITN4]RPOFLG = 1
      [M:ITN4]RPO = [M:SYN1]SYN
      Affzo [M:ITN4]1-99
    When "ITNOBJ"
      [M:ITN1]OBJICO = "117"
      [M:ITN1]OBJFLG = 1
      [M:ITN1]OBJ = [M:SYN1]SYN
      Affzo [M:ITN1]1-99
    When "HDK4"
      [M:HDK4]RPOICO = "117"
      [M:HDK4]RPOFLG = 1
      [M:HDK4]RPO = [M:SYN1]SYN
      Affzo [M:HDK4]1-99
    When "SOLSRE", "FSOLSRE"
      [M:SOL1]PBLDESICO = "117"
      [M:SOL1]PBLDESFLG = 1
      [M:SOL1]PBLDES = [M:SYN1]SYN
      Affzo [M:SOL1]1-99
    When "SOL", "FSOL"
      [M:SOL2]SOLDESICO = "117"
      [M:SOL2]SOLDESFLG = 1
      [M:SOL2]SOLDES = [M:SYN1]SYN
      Affzo [M:SOL1]1-99
    When "BAPOBJ"
      [M:BAP1]OBJICO = "117"
      [M:BAP1]OBJFLG = 1
      [M:BAP1]APTOBJ = [M:SYN1]SYN
      Affzo [M:BAP1]1-99
    When "BAPRPO"
      [M:BAP4]RPOICO = "117"
      [M:BAP4]RPOFLG = 1
      [M:BAP4]APTRPO = [M:SYN1]SYN
      Affzo [M:BAP4]1-99
    When "TSKOBJ"
      [M:TSK1]OBJICO = "117"
      [M:TSK1]OBJFLG = 1
      [M:TSK1]TSKDES = [M:SYN1]SYN
      Affzo [M:TSK1]1-99
    When "TSKRPO"
      [M:TSK2]RPOICO = "117"
      [M:TSK2]RPOFLG = 1
      [M:TSK2]TSKRPO = [M:SYN1]SYN
      Affzo [M:TSK2]1-99
    When "CLLOBJ"
      If [M:CLL1]FULOBJ = [M:CLL3]FULRPO Then
        [M:CLL1]OBJICO = "117"
        [M:CLL1]OBJFLG = 1
        [M:CLL1]CLLOBJ = [M:SYN1]SYN
        Affzo [M:CLL1]1-99
        [M:CLL3]RPOICO = "117"
        [M:CLL3]RPOFLG = 1
        [M:CLL3]CLLRPO = [M:SYN1]SYN
        Affzo [M:CLL3]1-99
      Else
        [M:CLL1]OBJICO = "117"
        [M:CLL1]OBJFLG = 1
        [M:CLL1]CLLOBJ = [M:SYN1]SYN
        Affzo [M:CLL1]1-99
      Endif
    When "CLLRPO"
      If [M:CLL1]FULOBJ = [M:CLL3]FULRPO Then
        [M:CLL1]OBJICO = "117"
        [M:CLL1]OBJFLG = 1
        [M:CLL1]CLLOBJ = [M:SYN1]SYN
        Affzo [M:CLL1]1-99
        [M:CLL3]RPOICO = "117"
        [M:CLL3]RPOFLG = 1
        [M:CLL3]CLLRPO = [M:SYN1]SYN
        Affzo [M:CLL3]1-99
      Else
        [M:CLL3]RPOICO = "117"
        [M:CLL3]RPOFLG = 1
        [M:CLL3]CLLRPO = [M:SYN1]SYN
        Affzo [M:CLL3]1-99
      Endif
    When "CRMG"
      [M:CRMG]RPOICO = "117"
      [M:CRMG]RPOFLG = 1
      [M:CRMG]RPO = [M:SYN1]SYN
      Affzo [M:CRMG]1-99
    When "CMG"
      [M:CMG2]OBJICO = "117"
      [M:CMG2]OBJFLG = 1
      [M:CMG2]DES = [M:SYN1]SYN
      Affzo [M:CMG2]1-99
    When "OMM"
      [M:OMM1]OBJICO = "117"
      [M:OMM1]OBJFLG = 1
      [M:OMM1]OBJ = [M:SYN1]SYN
      Affzo [M:OMM1]1-99
    When "OMP"
      [M:OMP1]OBJICO = "117"
      [M:OMP1]OBJFLG = 1
      [M:OMP1]OBJ = [M:SYN1]SYN
      Affzo [M:OMP1]1-99
    When "OMT"
      [M:OMT1]OBJICO = "117"
      [M:OMT1]OBJFLG = 1
      [M:OMT1]OBJ = [M:SYN1]SYN
      Affzo [M:OMT1]1-99
    When "OMN"
      [M:OMN1]OBJICO = "117"
      [M:OMN1]OBJFLG = 1
      [M:OMN1]OBJ = [M:SYN1]SYN
      Affzo [M:OMN1]1-99
    When Default
  Endcase
  [M:SYN0]DIRTY = 0
  [M:SYN1]PRESYN = [M:SYN1]SYN
  # FGR 28/08/2014 : X3SUIVI95250 (début)
  If PARAM(2) = "" Then
    If ISETMKSTAT4 = 1 Then
      PARAM(4) = "4"
    Endif
  Endif
  # FGR 28/08/2014 : X3SUIVI95250 (début)
Return

