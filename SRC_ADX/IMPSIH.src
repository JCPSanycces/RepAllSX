#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE

Raz GIMP
Global Integer GDEVSOCRND  : # stockage code arrondi devise societe

If clalev([F:SIH])=0    : Local File SINVOICE   [SIH]   : Endif
If clalev([F:SIV])=0    : Local File SINVOICEV  [SIV]   : Endif
If clalev([F:SVF])=0    : Local File SVCRFOOT   [SVF]   : Endif
If clalev([F:SVV])=0    : Local File SVCRVAT    [SVV]   : Endif

If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR     [TCU]   : Endif

If clalev([F:BPR])=0    : Local File BPARTNER   [BPR]   : Endif
If clalev([F:BPC])=0    : Local File BPCUSTOMER [BPC]   : Endif
If clalev([F:BPD])=0    : Local File BPDLVCUST  [BPD]   : Endif
If clalev([F:BPT])=0    : Local File BPCARRIER  [BPT]   : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:SOH])=0    : Local File SORDER     [SOH]   : Endif
If clalev([F:SOP])=0    : Local File SORDERP    [SOP]   : Endif
If clalev([F:SOQ])=0    : Local File SORDERQ    [SOQ]   : Endif
If clalev([F:SDH])=0    : Local File SDELIVERY  [SDH]   : Endif
If clalev([F:TVT])=0    : Local File TABVAT     [TVT]   : Endif
If clalev([F:DUD])=0    : Local File GACCDUDATE [DUD]   : Endif

If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:ITS])=0    : Local File ITMSALES   [ITS]   : Endif
If clalev([F:ITU])=0    : Local File ITMBPC     [ITU]   : Endif

If clalev([F:SID1])=0   : Local File SINVOICED  [SID1]  : Endif

Local Integer WRET :#--CPO 71937

#--- pour les textes
Gosub OUVRE_TEXTE
#---
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
#-----

Return

#######################################################################

$EXPORT



Case EXPFIC


  When "SIH"
    If [F:SIV]NUM<>[F:SIH]NUM
      Read [F:SIV]SIV0=[F:SIH]NUM
      If fstat : Raz [F:SIV] : Endif
    Endif

  When "SIV"
    If [F:SIH]NUM<>[F:SIV]NUM
      Read [F:SIH]SIH0=[F:SIV]NUM
      If fstat : Raz [F:SIH] : Endif
    Endif

    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:SIV]SIHTEX1)>0 & [F:SIV]SIHTEX1<>""
          G_CLE_CLOB=[F:SIV]SIHTEX1 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:SIV]SIHTEX2)>0 & [F:SIV]SIHTEX2<>""
          G_CLE_CLOB=[F:SIV]SIHTEX2 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

Endcase

Case EXPFIC

  When "SIH", "SIV"
    Raz [F:CPY], [F:FCY]
    Raz [F:BPR], [F:BPC], [F:BPD], [F:BPT], [F:BPA]
    Raz [F:SOH], [F:SDH], [F:TVT], [F:DUD]
    Raz [F:ITM], [F:ITS], [F:ITU]
    Raz [F:SID1]
    If [F:CPY]CPY<>[F:SIH]CPY
      Read [CPY]CPY0=[F:SIH]CPY
      If fstat : Raz [F:CPY] : Endif
    Endif
    If [F:CPY]ACCCUR<>[F:TCU]CUR
      Read [TCU]TCU0=[F:CPY]ACCCUR
      If fstat : Raz [F:TCU] : Endif
    Endif
    GDEVSOCRND=[F:TCU]CURRND

  When "SID"
    Raz [F:ITM], [F:ITS], [F:ITU]
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:SID]SIDTEX)>0 & [F:SID]SIDTEX<>""
          G_CLE_CLOB=[F:SID]SIDTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif

Endcase
Return

#######################################################################

$EXP_ZONE

Case EXPZON
  When "GIMP(3)"    : Gosub E_GIMP3    : # Chgt adresse société
  When "GIMP(4)"    : Gosub E_GIMP4    : # Chgt site vente
  When "GIMP(5)"    : Gosub E_GIMP5    : # Chgt client facture
  When "GIMP(6)"    : Gosub E_GIMP6    : # Chgt client commande
  When "GIMP(7)"    : Gosub E_GIMP7    : # Chgt client payeur
  When "GIMP(8)"    : Gosub E_GIMP8    : # Chgt client livré
  When "GIMP(9)"    : Gosub E_GIMP9    : # Chgt transporteur

  When "GIMP(10)"   : Gosub E_GIMP10   : # Type document (Avoir=04 / Facture=05)
  When "GIMP(15)"   : Gosub E_GIMP15   : # Commande
  When "GIMP(16)"   : Gosub E_GIMP16   : # Livraison
  When "GIMP(31)"   : Gosub E_GIMP31   : # Taxe1 (chgt enregistrement)
  When "GIMP(32)"   : Gosub E_GIMP32   : # Taxe2 (chgt enregistrement)
  When "GIMP(33)"   : Gosub E_GIMP33   : # Taxe3 (chgt enregistrement)
  When "GIMP(34)"   : Gosub E_GIMP34   : # Taxe4 (chgt enregistrement)
  When "GIMP(35)"   : Gosub E_GIMP35   : # Taxe5 (chgt enregistrement)
  When "GIMP(41)"   : Gosub E_GIMP41   : # Echeance1 (chgt enregistrement)
  When "GIMP(42)"   : Gosub E_GIMP42   : # Echeance2 (chgt enregistrement)
  When "GIMP(43)"   : Gosub E_GIMP43   : # Echeance3 (chgt enregistrement)
  When "GIMP(44)"   : Gosub E_GIMP44   : # Echeance4 (chgt enregistrement)
  When "GIMP(45)"   : Gosub E_GIMP45   : # Echeance5 (chgt enregistrement)

  When "GIMP(52)"   : Gosub E_GIMP52   : # Chgt article
  When "GIMP(53)"   : Gosub E_GIMP53   : # Poids brut ligne
  When "GIMP(54)"   : Gosub E_GIMP54   : # Total Taxes ligne  (dev.facture)

  When "GIMP(61)"   : GBIDI1=1    : Gosub E_GIMP6170  : # elt facturation rang 1
  When "GIMP(62)"   : GBIDI1=2    : Gosub E_GIMP6170  : # elt facturation rang 2
  When "GIMP(63)"   : GBIDI1=3    : Gosub E_GIMP6170  : # elt facturation rang 3
  When "GIMP(64)"   : GBIDI1=4    : Gosub E_GIMP6170  : # elt facturation rang 4
  When "GIMP(65)"   : GBIDI1=5    : Gosub E_GIMP6170  : # elt facturation rang 5
  When "GIMP(66)"   : GBIDI1=6    : Gosub E_GIMP6170  : # elt facturation rang 6
  When "GIMP(67)"   : GBIDI1=7    : Gosub E_GIMP6170  : # elt facturation rang 7
  When "GIMP(68)"   : GBIDI1=8    : Gosub E_GIMP6170  : # elt facturation rang 8
  When "GIMP(69)"   : GBIDI1=9    : Gosub E_GIMP6170  : # elt facturation rang 9
  When "GIMP(70)"   : GBIDI1=10   : Gosub E_GIMP6170  : # elt facturation rang 10

  When Default

Endcase

Return

#----------------------------------------------------------------------
#   Société ( [F:CPY] + [F:BPA] société )
$E_GIMP3
If [F:CPY]CPY<>[F:SIH]CPY
  Read [CPY]CPY0=[F:SIH]CPY
    If fstat : Raz [F:CPY] : Endif
Endif
Read [BPA]BPA0=2;[F:SIH]CPY;[F:CPY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Site vente ( [F:FCY] + [F:BPA] site vente )
$E_GIMP4
If [F:FCY]FCY<>[F:SIH]FCY
  Read [FCY]FCY0=[F:SIH]FCY
    If fstat : Raz [F:FCY] : Endif
Endif
Read [BPA]BPA0=3;[F:SIH]FCY;[F:FCY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client facture ( [F:BPR] + [F:BPC] + [F:BPA] client facture )
$E_GIMP5
If [F:BPC]BPCNUM<>[F:SIH]BPR
  Read [BPC]BPC0=[F:SIH]BPR
  If fstat : Raz [F:BPC] : Endif
Endif
If [F:BPR]BPRNUM<>[F:SIH]BPR
  Read [BPR]BPR0=[F:SIH]BPR
  If fstat : Raz [F:BPR] : Endif
Endif
Raz [F:BPA]
# -- test si adresse modifiée
If [F:SIH]BPRNAM <> ""   |  [F:SIH]BPAADDLIG <> "" |
&  [F:SIH]POSCOD <> ""   |  [F:SIH]CTY <> ""       |
&  [F:SIH]SAT    <> ""   |
&  [F:SIH]CRY    <> ""   |  [F:SIH]CRYNAM <> ""
  [F:BPA]BPADES       = [F:SIH]BPRNAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SIH]BPAADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SIH]BPAADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SIH]BPAADDLIG(2)
  [F:BPA]POSCOD       = [F:SIH]POSCOD
  [F:BPA]CTY          = [F:SIH]CTY
  [F:BPA]SAT          = [F:SIH]SAT
  [F:BPA]CRY          = [F:SIH]CRY
  [F:BPA]CRYNAM       = [F:SIH]CRYNAM
Else
  Read [BPA]BPA0=1;[F:SIH]BPR;[F:SIH]BPAINV
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Client commande ( [F:BPC] + [F:BPA] client cde : adresse)
$E_GIMP6
#   si absence SINVOICEV : client cde = client facture
If [SIV]NUM="" : Gosub E_GIMP5 : Return : Endif
If [F:BPC]BPCNUM<>[F:SIV]BPCORD
  Read [BPC]BPC0=[F:SIV]BPCORD
  If fstat : Raz [F:BPC] : Endif
Endif
#   si client divers (prendre adresse de facture)
If [F:BPC]BPCTYP=2 : Gosub E_GIMP5 : Return : Endif
#   adresse par defaut
Raz [F:BPA]
Read [BPA]BPA0=1;[F:SIV]BPCORD;[F:BPC]BPAADD
  If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client payeur ( [F:BPC] + [F:BPA] client payeur : adresse )
$E_GIMP7
If [F:BPC]BPCNUM<>[F:SIH]BPRPAY
  Read [BPC]BPC0=[F:SIH]BPRPAY
  If fstat : Raz [F:BPC] : Endif
Endif
#   si client divers (prendre adresse de facture)
If [F:BPC]BPCTYP=2 : Gosub E_GIMP5 : Return : Endif
#   adresse par defaut
Raz [F:BPA]
Read [BPA]BPA0=1;[F:SIH]BPRPAY;[F:BPC]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client livré ( [F:BPD] + [F:BPA] )
$E_GIMP8
Raz [F:BPD], [F:BPA]
#   si absence SINVOICEV : client livré = client facture
If [SIV]NUM="" : Gosub E_GIMP5 : Return : Endif
#
Read [F:BPD]BPD0=[F:SIV]BPCORD; [F:SIV]BPAADD
If fstat : Raz [F:BPD] : Endif
# -- test si adresse modifiée
If [F:SIV]BPDNAM    <> ""   |  [F:SIV]BPDADDLIG <> ""  |
&  [F:SIV]BPDPOSCOD <> ""   |  [F:SIV]BPDCTY    <> ""  |
&  [F:SIV]BPDSAT    <> ""   |
&  [F:SIV]BPDCRY    <> ""   |  [F:SIV]BPDCRYNAM <> ""
  [F:BPA]BPADES       = [F:SIV]BPDNAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SIV]BPDADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SIV]BPDADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SIV]BPDADDLIG(2)
  [F:BPA]POSCOD       = [F:SIV]BPDPOSCOD
  [F:BPA]CTY          = [F:SIV]BPDCTY
  [F:BPA]SAT          = [F:SIV]BPDSAT
  [F:BPA]CRY          = [F:SIV]BPDCRY
  [F:BPA]CRYNAM       = [F:SIV]BPDCRYNAM
Else
  Read [BPA]BPA0=1;[F:SIV]BPCORD;[F:SIV]BPAADD
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Transporteur ( [F:SDH] + [F:BPT] + [F:BPA] )
$E_GIMP9
Raz [F:SDH], [F:BPT], [F:BPA]
If [F:SIV]NUM="" : Return : Endif
#   lecture du 1er enr. détail de la facture
Filter [SID1] Where NUM=[F:SIV]NUM
Read [SID1]SID0 First
If !fstat & [F:SID1]NUM=[F:SIV]NUM
  If [F:SID1]SDHNUM<>""
    Read [F:SDH]SDH0=[F:SID1]SDHNUM
    If !fstat & [F:SDH]BPTNUM<>""
        Read [BPT]BPT0=[F:SDH]BPTNUM
        If fstat : Raz [F:BPT] : Endif
        Read [F:BPA]BPA0=1;[F:SDH]BPTNUM;[F:BPT]BPAADD
        If fstat : Raz [F:BPA] : Endif
    Endif
  Endif
Endif
Filter [SID1]
Return

#----------------------------------------------------------------------
#   Type document (Avoir=04 / Facture=05)
$E_GIMP10
If [F:SIH]INVTYP=2  GIMP(10)="04"  Else  GIMP(10)="05" Endif
Return

#----------------------------------------------------------------------
#   Commande (de 1ere ligne facture si ligne entete)
$E_GIMP15
Case EXPFIC
  When "SIH", "SIV"
    Raz [F:SOH]
    If [F:SIV]NUM="" : Return : Endif
#      lecture du 1er enr. détail de la facture
    Filter [SID1] Where NUM=[F:SIV]NUM
    Read [SID1]SID0 First
    If !fstat & [F:SID1]NUM=[F:SIV]NUM & [F:SID1]SOHNUM<>""
      Read [F:SOH]SOH0=[F:SID1]SOHNUM
      If fstat : Raz [F:SOH] : Endif
      Read [F:SOP]SOP0=[F:SID1]SOHNUM;[F:SID1]SOPLIN;[F:SID1]SOPLIN
      If fstat : Raz [F:SOP] : Endif
      Read [F:SOQ]SOQ0=[F:SID1]SOHNUM;[F:SID1]SOPLIN;[F:SID1]SOQSEQ
      If fstat : Raz [F:SOQ] : Endif
    Endif
    Filter [SID1]
  When "SID"
    Raz [F:SOH]
    If [F:SID]SOHNUM<>"" & [F:SOH]SOHNUM<>[F:SID]SOHNUM
      Read [F:SOH]SOH0=[F:SID]SOHNUM
      If fstat : Raz [F:SOH] : Endif
      Read [F:SOP]SOP0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOPLIN
      If fstat : Raz [F:SOP] : Endif
      Read [F:SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
      If fstat : Raz [F:SOQ] : Endif
    Endif
Endcase
Return

#----------------------------------------------------------------------
#   Livraison (de 1ere ligne facture si ligne entete)
$E_GIMP16
Case EXPFIC
  When "SIH", "SIV"
    Raz [F:SDH]
    If [F:SIV]NUM="" : Return : Endif
#      lecture du 1er enr. détail de la facture
    Filter [SID1] Where NUM=[F:SIV]NUM
    Read [SID1]SID0 First
    If !fstat & [F:SID1]NUM=[F:SIV]NUM & [F:SID1]SDHNUM<>""
      Read [F:SDH]SDH0=[F:SID1]SDHNUM
      If fstat : Raz [F:SDH] : Endif
    Endif
    Filter [SID1]
  When "SID"
    Raz [F:SDH]
    If [F:SID]SDHNUM<>"" & [F:SDH]SDHNUM<>[F:SID]SDHNUM
      Read [F:SDH]SDH0=[F:SID]SDHNUM
      If fstat : Raz [F:SDH] : Endif
    Endif
Endcase
Return

#----------------------------------------------------------------------
#   Taxe1 ( [F:TVT] )
$E_GIMP31

Raz [F:TVT]
If [F:SIH]TAX(0)<>""
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(0),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(0)
  #--/CPO
  If [F:SIH]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(0)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
   Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Taxe2 ( [F:TVT] )
$E_GIMP32
Raz [F:TVT]
If [F:SIH]TAX(1)<>""
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(1),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(1)
  #--/CPO
  If [F:SIH]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(1)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
   Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Taxe3 ( [F:TVT] )
$E_GIMP33

Raz [F:TVT]
If [F:SIH]TAX(2)<>""
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(2),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(2)
  #--/CPO
  If [F:SIH]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(2)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
   Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Taxe4 ( [F:TVT] )
$E_GIMP34
Raz [F:TVT]
If [F:SIH]TAX(3)<>""
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(3),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(3)
  #--/CPO
  If [F:SIH]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(3)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
   Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Taxe5 ( [F:TVT] )
$E_GIMP35
Raz [F:TVT]
If [F:SIH]TAX(4)<>""
  #--CPO 71937 TVT et multi-lèg
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(4),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(4)
  #--/CPO
  If [F:SIH]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(4)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
   Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Echeance1 ( [F:DUD] )
$E_GIMP41
Local Integer I1
Raz [F:DUD]
#p Filter [DUD] Where NUM=[F:SIH]NUM Order By Key DUD1
#p For [DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=1 : Break : Endif
  Endif
Next
If I1<>1 : Raz [F:DUD] : Endif
#p Filter [DUD]
Return

#----------------------------------------------------------------------
#   Echeance2 ( [F:DUD] )
$E_GIMP42
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=2 : Break : Endif
  Endif
Next
If I1<>2 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance3 ( [F:DUD] )
$E_GIMP43
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=3 : Break : Endif
  Endif
Next
If I1<>3 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance4 ( [F:DUD] )
$E_GIMP44
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=4 : Break : Endif
  Endif
Next
If I1<>4 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance5 ( [F:DUD] )
$E_GIMP45
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=5 : Break : Endif
  Endif
Next
If I1<>5 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Texte ligne facture
$E_GIMP51

Return

#----------------------------------------------------------------------
#   Chgt article ( [F:ITM] + [F:ITS] + [F:ITU] )
$E_GIMP52
Raz [F:ITM], [F:ITS], [F:ITU]
If [F:ITM]ITMREF<>[F:SID]ITMREF
  Read [ITM]ITM0=[F:SID]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:SID]ITMREF
  Read [ITS]ITS0=[F:SID]ITMREF
  If fstat : Raz [F:ITS] : Endif
Endif
If [F:ITU]ITMREF<>[F:SID]ITMREF | [F:ITU]BPCNUM<>[F:SIV]BPCORD
  Read [ITU]ITU0=[F:SID]ITMREF;[F:SIV]BPCORD
  If fstat : Raz [F:ITU] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Poids brut ligne
$E_GIMP53

Return

#----------------------------------------------------------------------
#   Total taxes ligne ( dev. facture )
$E_GIMP54
GIMP(54)=num$(sum([F:SID]AMTTAXLIN))
Return

##----------------------------------------------------------------------
##   Frais facture ( éléments de facturation )
#$E_GIMP6170
#Local  Integer IFR
#Global Decimal DTAAMT    : # base ( % ou montant )
#Global Decimal DTANOT    : # montant ht
#Global Decimal DTAVATRAT : # taux taxe
#Global Decimal DTAVATAMT : # montant taxe
#If GBIDI1 > dim([F:SIV]INVDTA) : Return : Endif
#IFR = find([F:SIV]INVDTA(GBIDI1-1),[F:SIV]DTA)
#If IFR
#  DTAAMT   = [F:SIV]DTAAMT(IFR-1)
#  DTANOT   = [F:SIV]DTANOT(IFR-1)
#  DTAVATRAT= [F:SIV]DTAVATRAT(IFR-1)
#  DTAVATAMT= [F:SIV]DTAVATAMT(IFR-1)
#Endif
#Return


#----------------------------------------------------------------------
#   Frais facture ( éléments de facturation )
$E_GIMP6170
Local  Integer IFR
Global Decimal DTAAMT    : # base ( % ou montant )
Global Decimal DTANOT    : # montant ht
Global Decimal DTAVATRAT : # taux taxe
Global Decimal DTAVATAMT : # montant taxe

If GBIDI1 > dim([F:SIV]INVDTA) : Return : Endif
#IFR = find([F:SIV]INVDTA(GBIDI1-1),[F:SIV]DTA)
Read [SVF]SVF1=4;[F:SIH]NUM;[F:SIV]INVDTA(GBIDI1-1)
If !fstat
  DTAAMT   = [F:SVF]DTAAMT
  DTANOT   = [F:SVF]DTANOT
  DTAVATRAT= [F:SVF]DTAVATRAT(0)
  DTAVATAMT= [F:SVF]DTAVATAMT(0)
Endif
Return

