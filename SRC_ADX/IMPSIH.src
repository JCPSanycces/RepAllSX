#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################
# IMPSIH : Import Standard des Factures
#          Export Standard des Factures
#----------------------------------------------------------------------
# Import :
#   - Utilisation de la transaction du paramètre TRSFAC
#     ( pour utilisation eventuelle du Code mouvement stock )
#   - Si import avec STOMVTFLG=2 ( m.a.j. stock = oui )
#     Sortie de stock auto. : création des allocations détaillées
#     ( Nota : les mvts de sortie sont créés à la validation facture )
#     Pour les avoirs JAMAIS d'entrée en stock
#   - Si import du calcul, le montant TTC doit être importé
#     les tables SVCRVAT et SVCRFOOT doivent être importées
#     les mnts des éléments de facturation saisis doivent être importées avec SVCRFOOT
#######################################################################
# Issue 114462 - 20160415 by LD : import SIH number of lines screen SPCACTIF
# Issue X3-65938 - 20171206 by LD : Errors when accounting module is not enabled in the folder
# Issue X3-38291 - 20180102 by LD : Import facture Ventes: STARPT pris en compte si FRADGI=oui

$ACTION
Case ACTION
 When "IMP_AVANT_OUVRE" : Gosub IMP_AVANT_OUVRE
 When "IMP_OUVRE"       : Gosub IMP_OUVRE
 When "IMP_DEFTRT"      : Gosub IMP_DEFTRT
 When "IMPORT"          : Gosub IMPORT
 When "IMP_ZONE"        : Gosub IMP_ZONE
 When "IMP_TAB"         : Gosub IMP_TAB
 When "IMP_VERIF_CRE"   : Gosub IMP_VERIF_CRE
 When "IMP_VERIF_MOD"   : Gosub IMP_VERIF_CRE
 When "EXP_OUVRE"       : Gosub EXP_OUVRE
 When "EXPORT"          : Gosub EXPORT
 When "EXP_ZONE"        : Gosub EXP_ZONE
 When "IMP_AVANT_MOD"   : Gosub IMP_AVANT_MOD
 When "IMP_INICRE"      : Gosub IMP_INICRE
 When "IMP_CREATION"    : Gosub IMP_CREATION
 When "IMP_FERME"       : Gosub IMP_FERME      # FGR 27/01/2010 : X3SUIVI61713
 When "AP_IMPORT"       : Gosub AP_IMPORT      # FGR 27/01/2010 : X3SUIVI61713
Endcase

Return

#######################################################################
$IMP_AVANT_OUVRE
Local Integer OKTRT
Local Char SNOMTRT(GLONADC)

  # FGR 22/12/2014 : X3SUIVI104963 : # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
  If !clalev([F:CFL])  Local File CPTFOOTLNK [CFL] : Endif
  #-----
  # Bug 78716 : Les écrans WSIH4CNO et WSIH4INV doivent être validés
  If filinfo(filpath("ECR","WSIH4CNO","msk",0),0)<0 | filinfo(filpath("ECR","WSIH4INV","msk",0),0)<0 Then
    If GTRACE<>""
      Call ECR_TRACE(mess(108,141,1)-":"-mess(246,191,1), 1) From GESECRAN
      OK = 0
    Endif
  Else
    For SNOMTRT = "W0WSIH4INV", "W0WSIH4CNO"
      Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS
      If OKTRT > 0 Then
        # Il existe, c'est bon
      Else
        # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
        If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
        If [F:ADS]DOSSIER <> nomap Then
          Read [F:ADS]DOSSIER=nomap
        Endif
        If SNOMTRT = "W0WSIH4INV" Then
          Call VALID("WSIH4INV", nomap, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OKTRT) From VALMSK
        Else
          Call VALID("WSIH4CNO", nomap, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OKTRT) From VALMSK
        Endif
        Call EXISTE_ADX("", "", SNOMTRT, OKTRT) From ORDSYS
        If OKTRT > 0 Then
          # Il existe, c'est bon
        Else
          Call ECR_TRACE(mess(108,141,1) - ":" - mess(246,191,1), 1) From GESECRAN
          OK = 0
          Break
        Endif
      Endif
    Next
  Endif
Return

