$CHARG_ZL
I=find(ZONEF,GZONFIC3)
If I
  If GZONOK3(I-1)
    If evalue("dim([M:SIH4]"+ZONEF+"(nolign-1))")>0
      Assign "[M:SIH4]"+ZONEF+"(nolign-1)" With evalue("[F:SID]"+ZONEF)
    Endif
  Endif
Endif
Return
# End issue 114462

#######################################################################
# le complément de garnissage de l'ecran SIHV devrait être logiquement
# dans IMP_INICRE mais il est mis dans IMP_VERIF_CRE de façon à se
# dérouler avant INICRE standard
#----------------------------------------------------------------------
$IMP_VERIF_CRE
Local Integer ITS,ITL,ITP
Local Integer JLC        : # compteur nbre de lignes concernées par le saupoudrage
Local Decimal TOTLIG     : # cumul des montants de la taxe dans les lignes
Local Decimal TOTLIG1
Local Decimal REPARTIR   : # montant à repartir
Local Decimal UNITEREP   : # unite de repartition
Local Char    WVAT (GLONVAT)
If [F:TCU]CUR<>[M:SIH0]CUR
  Read [TCU]TCU0=[M:SIH0]CUR
Endif

# Chargement des tableaux SIHX à partir des lignes
# - avec calcul : traitement normal
# - sans calcul : tableaux crees uniquement pour permettre la répartition des taxes
#                 à la ligne par ventilation

Local Char     WKU_MAJ : WKU_MAJ="2"
Gosub CHARG_TABLEAUX From TRTVENFACC

If G_SIH_CAL="C"
  Gosub CAL_FACTURE    From TRTVENFACC  : # Calcul de la facture
  Gosub TAXES_LIGNES   From TRTVENFACV  : # Ajustement des taxes à la ligne
Else
  Gosub NO_CAL_FACTURE                  : # Pas de recalcul
Endif

# Si les montants total HT et TTC sont paramétrés,
# controle bloquant avec le résultat des autre données importées
If G_FLGNOT & G_AMTNOT & G_AMTNOT<>[M:SIHV]INVNOT
  GMESSAGE = mess(176,192,1)-"\"+mess(14,100,1)
  OK=0
Endif
If G_FLGATI & G_AMTATI & G_AMTATI<>[M:SIHV]INVATI
  Raz GMESSAGE
  GMESSAGE = mess(177,192,1)-"\"+mess(14,100,1)
  OK=0
Endif

If G_SIH_STA > 1 & func FRADSILIB.DSFRA("SIH", [F:SIV]CPY)
  GMESSAGE = mess(560,192,1)
  OK = 0
Endif

Return

#----------------------------------------------------------------------

$NO_CAL_FACTURE

# Le masque SIHX garni n'est pas utilisé en import
# import directement dans SIHV

# Dans le tableau des taxes
For I=0 To dim([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(I)="" : Break : Endif
#   si montant taxe <> 0 et taux = 0         --> recherche du taux
  If [M:SIHV]XVAMT(I)<>0 & [M:SIHV]XVRAT(I)=0
    WVAT=[M:SIHV]XVTAX(I) : Gosub LEC_VAT From TRTVENFACC
    [M:SIHV]XVRAT(I)=[F:TRA]VATRAT
  Endif
#   si montant soumis = 0 et taux = 0 --> montant soumis = montant HT (pour prorata)
  If [M:SIHV]XVSMI(I)=0 & [M:SIHV]XVRAT(I)=0 : [M:SIHV]XVSMI(I)=[M:SIHV]XVNOT(I) : Endif
#   si montant taxe <> 0 et montant soumis = 0
#     calculer la taxe avec le mt Ht : si resultat identique a mt taxe importe
#     le mt soumis = mt ht (pads de calcul pour eviter les incoherences d'arrondi)
  If [M:SIHV]XVAMT(I)<>0 & [M:SIHV]XVSMI(I)=0
    If [M:SIHV]XVRAT(I)<>0  : # pas de division par zero
      If arr(([M:SIHV]XVNOT(I)*[M:SIHV]XVRAT(I)/100),[F:TCU]CURRND)=[M:SIHV]XVAMT(I)
          [M:SIHV]XVSMI(I)=[M:SIHV]XVNOT(I)
        Else
          [M:SIHV]XVSMI(I)=arr(([M:SIHV]XVAMT(I)*100)/[M:SIHV]XVRAT(I),[F:TCU]CURRND)
      Endif
    Endif
  Endif
#   si c'est une taxe secondaire --> montant HT = 0
  If [M:SIHV]XVTYP(I)<>1 : [M:SIHV]XVNOT(I)=0 : Endif
Next I

#   si taxe secondaire --> somme autres taxes doit etre = a somme taxes secondaires

# Dans le tableau des pieds
For I=0 To dim([M:SIHV]XFNUM)-1
  If [M:SIHV]XFNUM(I)=0 : Break : Endif
  If [M:SIHV]XFTAX(I)<>""
#   si montant taxe <> 0 et taux = 0 --> recherche du taux
    If [M:SIHV]XFVATAMT(I)<>0 & [M:SIHV]XFRAT(I)=0
      WVAT=[M:SIHV]XFTAX(I) : Gosub LEC_VAT From TRTVENFACC
      [M:SIHV]XFRAT(I)=[F:TRA]VATRAT
    Endif
#   si montant taxe <> 0 et montant soumis = 0
#     calculer la taxe avec le mt Ht : si resultat identique a mt taxe importe
#     le mt soumis = mt ht (pas de calcul pour eviter les incoherences d'arrondi)
#                                               (en général=HT pied)
    If [M:SIHV]XFVATAMT(I)<>0 & [M:SIHV]XFSMI(I)=0
      If [M:SIHV]XFRAT(I)<>0  : # pas de division par zero
        If arr(([M:SIHV]XFNOT(I)*[M:SIHV]XFRAT(I)/100),[F:TCU]CURRND)=[M:SIHV]XFVATAMT(I)
            [M:SIHV]XFSMI(I)=[M:SIHV]XFNOT(I)
          Else
            [M:SIHV]XFSMI(I)=arr(([M:SIHV]XFVATAMT(I)*100)/[M:SIHV]XFRAT(I),[F:TCU]CURRND)
        Endif
      Endif
    Endif
  Endif

Next I

# Dans le tableau des lignes
#   ajustement des taxes du tableau des taxes dans les lignes

Gosub TAXES_LIGNES From TRTVENFACV

# Repartition taxes secondaires dans colonne Autres taxes
#   des taxes principales
Raz [M:SIHV]XVSUP

For ITS=0 To dim([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(ITS)="" : Break : Endif
  If [M:SIHV]XVTYP(ITS)>1
    For ITL=0 To [M:SIH4]NBLIG-1
      If [M:SIH4]VAT2(ITL)=[M:SIHV]XVTAX(ITS)
       ITP = find ([M:SIH4]VAT1(ITL),[M:SIHV]XVTAX)
        If ITP : [M:SIHV]XVSUP(ITP-1) += [M:SIH4]AMTTAXLIN2(ITL) : Endif
      Endif
      If [M:SIH4]VAT3(ITL)=[M:SIHV]XVTAX(ITS)
       ITP = find ([M:SIH4]VAT1(ITL),[M:SIHV]XVTAX)
        If ITP : [M:SIHV]XVSUP(ITP-1) += [M:SIH4]AMTTAXLIN3(ITL) : Endif
      Endif
    Next ITL
  Endif
Next ITS

# Garnissage de la colonne TTC du tableau des taxes
Raz [M:SIHV]XVATI
For ITS=0 To dim([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(ITS)="" : Break : Endif
  If [M:SIHV]XVTYP(ITS)=1                      : # colonne TTC uniquement si taxe principale
     [M:SIHV]XVATI(ITS)= [M:SIHV]XVNOT(ITS)+[M:SIHV]XVAMT(ITS)+[M:SIHV]XVSUP(ITS)
  Endif

#  If func AFNC.ACTIV("KAB")
     If [M:SIHV]XVTYP(ITS)>3                   : # colonne TTC car les taxes annexes (globales facture)
        [M:SIHV]XVATI(ITS)= [M:SIHV]XVAMT(ITS) : # ne sont pas répercutées sur les lignes taxes principales
     Endif                                     : # liées aux produits
#  Endif

Next ITS

# Garnissage de la colonne TTC du tableau des pieds
Raz [M:SIHV]XFATI
For ITS=0 To dim([M:SIHV]XFTAX)-1
# V6
#  If [M:SIHV]XFTAX(ITS)="" : Break : Endif
  [M:SIHV]XFATI(ITS)= [M:SIHV]XFNOT(ITS)+[M:SIHV]XFVATAMT(ITS)
Next ITS

# Garnissage du cumul HT et TTC de la facture
[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)

Return

#######################################################################
# Import du statut : si facture validée recherche de ACCNUM
# Ordre de recherche ACCNUM
# (dans les echeances sinon dans la pièce comptable sinon nouveau numero)
#----------------------------------------------------------------------
$IMP_INICRE

If G_SIH_STA
  # Bug 74845 : Import du flag statut
  If G_SIH_STA=2        : # Facture imprimée
    G_SIH_STARPT=2      : # Statut impression=Oui
    If GSIVCFM=3        : # Si Impression facture obligatoire=Oui après validation
        G_SIH_STA=3     : # Statut facture=Validée
    Else
        G_SIH_STA=1     : # Statut facture=Non Validée
    Endif
  Endif
  # Bug 74845
  [F:SIV]INVSTA=G_SIH_STA
Endif
If !find([F:SIV]INVSTA,1,2,3) : [F:SIV]INVSTA=1 : Endif
[F:SIH]STA=[F:SIV]INVSTA

If G_SIH_STARPT=2
  [F:SIH]STARPT=G_SIH_STARPT
  # Issue X3-38291
  # Si Impression facture obligatoire=Oui après validation, le flag imprimé ne peut être à Oui que si la facture est validée
  # If Mandatory invoice printing=Yes after validation, printing status can be equal to Yes only if the invoice is validated
  If GSIVCFM=3 & [F:SIH]STA<>3
    [F:SIH]STARPT=1
  Endif
  # End issue X3-38291
Else
  # Bug 74845 : Import du statut impression
  # Issue X3-38291
  # See with CH : No longer necessary to force STARPT=2 in this situation
  # STARPT has not been imported or has been imported with value 0 or 1
  # STARPT can have the value 1 in all cases
#  If G_SIH_STA=3        : # Facture validée
#    [F:SIH]STARPT=2     : # Statut impression=Oui
#  Elsif G_SIH_STA=1     : # Facture non imprimée et non validée
#    [F:SIH]STARPT=1     : # Statut impression=Non
#  Endif
  [F:SIH]STARPT=1     : # Statut impression=Non
  # Issue X3-38291
  # Bug 74845 : Import du flag statut
Endif #Fq74333-Gbn
[F:SIV]STARPT=[F:SIH]STARPT : # Bug 74845

If [F:SIV]INVSTA<3   : # la facture n'est pas validée
  Call ACCNUM([F:SIH]ACCNUM) From SUBGAS : # recuperation du no. interne

Else                 : # la facture est validée ( il est conseille de fournir [F:SIH]ACCNUM )
# recherche du no ACCNUM dans GACCDUDATE
  If [F:SIH]ACCNUM=0
    Filter [DUD] Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
    Read [DUD] First
    If !fstat : [F:SIH]ACCNUM=[F:DUD]ACCNUM : Endif
    Filter [DUD]
  Endif
  # Issue X3-65938
  # FYI, ACCNUM managed the fact that accouting module is present or not by testing GCOMPTA
  # Extract from GLOBX3 :If GMODU(2)=2
  #                       GCOMPTA = 1
  #                      Else
  #                       GCOMPTA = 3
  #                      Endif
  If GMODU(2) = 2
  # End issue X3-65938
      # recherche du no ACCNUM dans GACCENTRYD
      If [F:SIH]ACCNUM=0
        Filter [DAE] Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
        Read [DAE] First
        If !fstat : [F:SIH]ACCNUM=[F:DAE]ACCNUM : Endif
        Filter [DAE]
      Endif
  # Issue X3-65938
  Endif
  # End issue X3-65938

# recherche du no ACCNUM
  If [F:SIH]ACCNUM=0
  Call ACCNUM([F:SIH]ACCNUM) From SUBGAS : # recuperation du no. interne
  Endif

Endif

Return

#######################################################################
# Les echeances et l'encours client
#######################################################################
$IMP_CREATION
#----------------------------------------------------------------------
# Calcul des echeances : si c'est une facture non validée
#----------------------------------------------------------------------
If find([F:SIV]INVTYP,1,2) & [F:SIV]INVSTA<3
    Call CRE_ECHEANCES From TRTVENFACC
    If GOK < 1 : Return : Endif
Endif
