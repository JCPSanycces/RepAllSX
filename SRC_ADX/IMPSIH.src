# 102423 : Belgium Early discounts
# Distributed elt on the lines
If G_DDTA
    Local Integer JL
    Local Integer DDTANUM
    Local Decimal DDTANOT
    Local Decimal DDTADEP

    For JL=1 To G_VALSFL
        If evalue ("dim([M:SIHV]DDTANUM"+format$("N0:2",JL)+")")>0
           If evalue ("[F:SID]DDTANUM("+num$(JL-1)+")")<>0
              [L]DDTANUM=evalue ("[F:SID]DDTANUM("+num$(JL-1)+")")
              [L]DDTANOT=evalue ("[F:SID]DDTANOT("+num$(JL-1)+")")

              If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0
                  [L]DDTADEP=evalue ("[F:SID]DDTADEP("+num$(JL-1)+")")
              Endif

              Assign ("[M:SIHV]DDTANUM"+format$("N0:2",JL)+"("+num$(nolign-1)+")") With [L]DDTANUM
              Assign ("[M:SIHV]DDTANOT"+format$("N0:2",JL)+"("+num$(nolign-1)+")") With [L]DDTANOT
              Assign ("[M:SIHV]DDTADEP"+format$("N0:2",JL)+"("+num$(nolign-1)+")") With [L]DDTADEP

           Endif
        Else
           Break
        Endif
    Next JL
Endif
# 102423

# a completer si nécessaire

Return

