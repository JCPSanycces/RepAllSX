#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
$SETMODE_OFF
Setmode
Return

$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return

#######################################################################
#                        IMPORT
#######################################################################

$IMP_OUVRE
Local  Shortint ICLOSE, ITAB
Global Char     G_SIH_DEL          : # "D" = delete
Global Char     G_SIH_CAL          : # "C" = calcul de la facture
Global Integer  G_SIH_STA          : # stockage statut facture
Global Integer  G_SIH_STARPT       : # stockage statut Imptimée #Fq74333-Gbn
Global Integer  G_FLGNOT, G_FLGATI : # pour tester la cohérence de l'import
Global Decimal  G_AMTNOT, G_AMTATI : # pour tester la cohérence de l'import
Global Integer  G_BPCORD           : # import client commande zone non saisissable entete
Global Integer  G_SIHORI           : # import zone non saisissable entete
Global Integer  G_SIHORINUM        : #   idem
Global Integer  G_SIHORIDAT        : #   idem
Global Integer  G_SIHORITYP        : #   idem     :  # 107888 : Scheduled invoices : (LD:11/05/16)
Global Integer  G_ENTCOD           : #   idem
Global Integer  G_TRSCOD           : #   idem
Global Integer  G_VACITM1          : # pour maj niveau taxe 1 après valeur par defaut
Global Integer  G_VACITM2          : # pour maj niveau taxe 2 après valeur par defaut
Global Integer  G_VACITM3          : # pour maj niveau taxe 3 après valeur par defaut
Global Integer  G_PJTV             : # pour maj PJT entête
Global Integer  G_PJT              : # pour maj PJT détail
Global Integer  G_STOMGTCOD        : # import zone non saisissable ligne
#-- X3Suivi 86446 : on ne declenche pas la nomenclature si champ TYPLIN  est dans modele import ----#
Global Integer  G_LINTYP           : # indique si LINTYP est dans le modele --> si oui, on ne declenche pas les nomenclatures

# Import des infos douanières
Global Integer  G_EECNUM
Global Integer  G_EECNAT
Global Integer  G_EECNATR
Global Integer  G_EECSCH
Global Integer  G_EECSCHR
Global Integer  G_EECLOC
Global Integer  G_EECTRN
Global Integer  G_EECICT
Global Integer  G_ICTCTY
Global Integer  G_FFWNUM
Global Integer  G_FFWADD

Global Integer  G_SIH_SIVTYP       : # pour determiner GMANCOU   bug 35691
Global Integer  G_SIV_SIVTYP       : # pour determiner GMANCOU   bug 35691

# ---
Global Integer G_BPRNAM, G_BPDNAM, G_BPYNAM
Global Integer G_CNINAM, G_CNDNAM
Global Integer G_BPAINV, G_BPAPAY           : # import adresse tiers payeur
Global Integer G_FOCFLG                     : # Bug 72575

Global Char GSTBFIC(GLONABR)(dim([M:IMP2]ABREV))   # FGR 27/01/2010 : X3SUIVI61713
Global Char GLASTFLGREC(10)                        # FGR 27/01/2010 : X3SUIVI61713

Global Integer G_UMRNUM                     :#--CPO 87923 Gestion des prélèvements SDD

# 102423 : Belgium Early discounts
Global Integer G_DEPRAT                     : # Discount rate
Global Integer G_BASDEP                     : # Discount base
Global Integer G_DDTA                       : # Distributed elt on the lines
# 102423

Local  Integer WNOL

Local  Char    WNEWPJT (GLONPJT)
Local  Integer WRET :#--CPO 71937

Raz [V]GIMP
Raz [V]G_SIH_DEL, [V]G_SIH_CAL, [V]G_FLGNOT, [V]G_FLGATI, [V]G_AMTNOT, [V]G_AMTATI
Raz [V]G_BPCORD
Raz [V]G_BPAINV, [V]G_BPAPAY
Raz [V]G_SIHORI, [V]G_SIHORINUM, [V]G_SIHORIDAT, [V]G_ENTCOD, [V]G_TRSCOD
Raz [V]G_SIHORITYP                                : # 107888 : Scheduled invoices : (LD:11/05/16)
Raz [V]G_STOMGTCOD
Raz [V]G_SIH_SIVTYP, G_SIV_SIVTYP
Raz [V]G_EECNUM, [V]G_EECNAT, [V]G_EECNATR, [V]G_EECSCH, [V]G_EECSCHR, [V]G_EECLOC, [V]G_EECTRN, [V]G_EECICT
Raz [V]G_ICTCTY, [V]G_FFWNUM,  [V]G_FFWADD

# pour recherche de GMANCOU
If clalev([F:TSV])=0 : Local File TABSIVTYP   [TSV] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF   [TCA] : Endif

# pour recherche ACCNUM si import facture validée
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif

# Issue X3-65938
#If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE] : Endif
If GMODU(2) = 2
    If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE] : Endif
Endif
# End issue X3-65938

# Issue 114462
