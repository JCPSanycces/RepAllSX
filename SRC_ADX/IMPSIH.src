#For [ATZ]CODZONE
#  If [F:ATZ]DIME=0
#    [F:ATZ]DIME= evalue("dim([F:SID]"+[F:ATZ]CODZONE+")")
#  Endif
#  If [F:ATZ]DIME>1
#    For I=0 To [F:ATZ]DIME-1
#      ITAB +=1 : [M:SP1]ZONFIC3(ITAB)=[F:ATZ]CODZONE+"("+num$(I)+")"
