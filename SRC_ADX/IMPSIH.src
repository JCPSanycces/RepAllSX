#Next I

# But : accélération le traitement
# Stockage de la liste des champs de SINVOICED présent dans le paramétrage dans un tableau de globales
# Tableau de globales dimensioné à 512 car c'est le max de colonnes d'une table
# evite ainsi un call répétitifIf clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : ICLOSE=1 : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : ICLOSE=1 : Endif
Filter [ATZ] Where CODFIC="SINVOICED"

Global Char    GZONFIC3(GLONAVA)(512)
Global Integer GZONOK3(512)

Raz GZONFIC3, GZONOK3, ITAB
For [ATZ]CODZONE
  If [F:ATZ]DIME=0
    [F:ATZ]DIME= evalue("dim([F:SID]"+[F:ATZ]CODZONE+")")
  Endif
  If [F:ATZ]DIME>1
    For I=0 To [F:ATZ]DIME-1
      ITAB +=1 : GZONFIC3(ITAB)=[F:ATZ]CODZONE+"("+num$(I)+")"
    Next I
  Else
    ITAB +=1 : GZONFIC3(ITAB)=[F:ATZ]CODZONE
  Endif
Next
Filter [ATZ]
If ICLOSE : Close Local File [ATZ] : Endif

For I=1 To dim(GZONFIC3)-1
  If GZONFIC3(I)="" : Break : Endif
  Call TST_CHAMP ("SID",GZONFIC3(I),GZONOK3(I)) From SUBIMPOBJ
Next I
# End issue 114462

#-----------------------------------------------------------------------#
# Recherche de la transaction de facture ( paramètre : TRSFAC )         #
# ( transaction identique pour factures et avoirs )                     #
#-----------------------------------------------------------------------#
If !clalev ([F:SLT]) : Local File SALTRS  [SLT] : Endif
#----- Sélection de la transaction de facture -----#        : # Bug 72968
Call PARAML("","TRSFAC",GTRSFAC) From ADOVAL                 : # Bug 72968      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GFLAG=GTRSFAC
Read [SLT] SLT0=5;GFLAG
If fstat
  GFLAG=""
  Filter [SLT] Where STRTYP=5 & ENAFLG=2 & find (INVTYP,1,4)
  Read [SLT] SLT0 First
  Filter [SLT]
  If fstat
    If GTRACE<>""
      Call ECR_TRACE(mess(287,192,1),1) From GESECRAN
    Endif
  Endif
  GFLAG=[F:SLT]STRNUM
Endif
[F:SLT]STKFLG   =2 : # On force la détermination du stock à sortir à "Oui"
[F:SLT]PRNCOD1  =1 : # On force l'impression d'étiquettes à "Non"
[F:SLT]PRNNBFLG1=1 : # On force le nbre d'impression à "Non"
#-----
GSLTSTKFLG=[F:SLT]STKFLG
GSLTENTCOD=[F:SLT]ENTCOD                                    : # Bug 72968
WSLTTRSCOD=[F:SLT]TRSCOD                                    : # Bug 72968
WSLTTRSFAM=[F:SLT]TRSFAM                                    : # Bug 72968

Call TST_CHAMP ("SIH","AMTNOT",G_FLGNOT)       From SUBIMPOBJ
Call TST_CHAMP ("SIH","AMTATI",G_FLGATI)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","BPCORD",G_BPCORD)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","BPAPAY",G_BPCORD)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","SIHORI",G_SIHORI)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","SIHORINUM",G_SIHORINUM) From SUBIMPOBJ
Call TST_CHAMP ("SIV","SIHORIDAT",G_SIHORIDAT) From SUBIMPOBJ
Call TST_CHAMP ("SIV","SIHORITYP",G_SIHORITYP) From SUBIMPOBJ   : # 107888 : Scheduled invoices : (LD:11/05/16)
Call TST_CHAMP ("SIV","ENTCOD",G_ENTCOD)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","TRSCOD",G_TRSCOD)       From SUBIMPOBJ
Call TST_CHAMP ("SID","VACITM(0)",G_VACITM1)   From SUBIMPOBJ
Call TST_CHAMP ("SID","VACITM(1)",G_VACITM2)   From SUBIMPOBJ
Call TST_CHAMP ("SID","VACITM(2)",G_VACITM3)   From SUBIMPOBJ
Call TST_CHAMP ("SIV","PJT", G_PJTV)           From SUBIMPOBJ
Call TST_CHAMP ("SID","PJT", G_PJT)            From SUBIMPOBJ
Call TST_CHAMP ("SID","STOMGTCOD",G_STOMGTCOD) From SUBIMPOBJ

Call TST_CHAMP ("SIH","BPAINV",G_BPAINV)       From SUBIMPOBJ
Call TST_CHAMP ("SIH","BPAPAY",G_BPAPAY)       From SUBIMPOBJ
Call TST_CHAMP ("SIH","BPRNAM",G_BPRNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","BPDNAM",G_BPDNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SIH","BPYNAM",G_BPYNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","CNINAM",G_CNINAM)       From SUBIMPOBJ
Call TST_CHAMP ("SIV","CNDNAM",G_CNDNAM)       From SUBIMPOBJ
Call TST_CHAMP ("SID","FOCFLG",G_FOCFLG)       From SUBIMPOBJ   : # Bug 72575

Call TST_CHAMP ("SIH","SIVTYP",G_SIH_SIVTYP)   From SUBIMPOBJ
Call TST_CHAMP ("SIV","SIVTYP",G_SIV_SIVTYP)   From SUBIMPOBJ

Call TST_CHAMP ("SIV","BPIEECNUM", G_EECNUM)   From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECNAT", G_EECNAT)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECNATR",G_EECNATR)     From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECSCH", G_EECSCH)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECSCHR",G_EECSCHR)     From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECLOC", G_EECLOC)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECTRN", G_EECTRN)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","EECICT", G_EECICT)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","ICTCTY", G_ICTCTY)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","FFWNUM", G_FFWNUM)      From SUBIMPOBJ
Call TST_CHAMP ("SIV","FFWADD", G_FFWADD)      From SUBIMPOBJ

#-- X3Suivi 86446 : on ne declenche pas la nomenclature si champ TYPLIN  est dans modele import ----#
Call TST_CHAMP ("SID","LINTYP",G_LINTYP)       From SUBIMPOBJ

#--CPO 75604
Global Integer G_DTA
Call TST_CHAMP ("SVF","DTA",G_DTA)             From SUBIMPOBJ
Local Integer WDIMINVDTA

#--CPO 87923 Gestion des prélèvements SDD
Call TST_CHAMP ("SIH","UMRNUM", G_UMRNUM)      From SUBIMPOBJ

# 102423 : Belgium Early discounts
Call TST_CHAMP ("SIH","DEPRAT",     G_DEPRAT)   From SUBIMPOBJ  : # Discount rate
Call TST_CHAMP ("SIH","BASDEP",     G_BASDEP)   From SUBIMPOBJ  : # Discount base
Call TST_CHAMP ("SID","DDTANUM(0)", G_DDTA)     From SUBIMPOBJ  : # Distributed elt on the lines
# 102423

# 87032 : Import des cours devise
Global Integer G_RATMLT (0..9),G_RATDIV (0..9)
Local  Char    WFLD
Local  Integer WI
For WI=0 To dim([F:SIH]RATMLT)-1
  WFLD="RATMLT("+num$(WI)+")"
  Call TST_CHAMP ("SIH",WFLD,G_RATMLT(WI))   From SUBIMPOBJ
  WFLD="RATDIV("+num$(WI)+")"
  Call TST_CHAMP ("SIH",WFLD,G_RATDIV(WI))   From SUBIMPOBJ
Next
# 87032

# ---
#  si la donnée montant TTC de la facture n'est pas paramétrée
#  il faut calculer la facture
Raz G_SIH_CAL
If G_FLGATI=0 : G_SIH_CAL="C" : Endif

Gosub OUVRE_SIHX From TRTVENFACC
Gosub OUVRE_TEXTE

If clalev([M:SIHI])=0 : Local Mask WSIH4INV [SIHI] : Endif
If clalev([M:SIHC])=0 : Local Mask WSIH4CNO [SIHC] : Endif

#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]

#-----
Return

#---------------------------------------------------------------------
# --- Fin import
$IMP_FERME
  # FGR 27/01/2010 : X3SUIVI61713
  If dim(GSTBFIC) > 0 Then
    Kill GSTBFIC
  Endif
  If dim(GLASTFLGREC) > 0 Then
    Kill GLASTFLGREC
  Endif

#-- X3Suivi 86446 : on ne declenche pas la nomenclature si champ TYPLIN  est dans modele import ----#
If dim(G_LINTYP)>0     : Kill G_LINTYP     : Endif
If dim(G_FOCFLG)>0     : Kill G_FOCFLG     : Endif  :#  Bug 72575
If dim(G_DTA)>0        : Kill G_DTA        : Endif  :#--CPO 75604
If dim(G_UMRNUM)>0     : Kill G_UMRNUM     : Endif  :#--CPO 87923 Gestion des prélèvements SDD

# 102423 : Belgium Early discounts
If dim(G_DEPRAT)>0     : Kill G_DEPRAT     : Endif  : # Discount rate
If dim(G_BASDEP)>0     : Kill G_BASDEP     : Endif  : # Discount base
If dim(G_DDTA)>0       : Kill G_DDTA       : Endif  : # Distributed elt on the lines
# 102423

# Issue 114462
If dim(GZONFIC3)>0     : Kill GZONFIC3 : Endif
If dim(GZONOK3)>0      : Kill GZONOK3  : Endif
# End issue 114462

# 84038 : Si erreur sur la facture précédente qui vient d'être importée,
#         Si cette facture était directe avec mouvement de stock
#         --> Suppression des allocations stockées dans écran de travail STOSORW
#             (Qtés en cours de traitement)
#         Seul endroit trouvé où on a la main pour la faire avec IMP_FERME
#         Inutile en mode test (la classe [M] n'est pas ouverte)
If dim ([M:SIH0]INVTYP)>0
    If [M:SIH4]NBLIG<>0 & [M:SIH0]INVTYP=1 & (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2) |
&                           [M:SIH1]SIHORI=2 | [M:SIH1]SIHORI=3)
        Local Integer WI, WRET
        For WI=0 To [M:SIH4]NBLIG-1
            Call DELSTOSORW(WI,WI,"SIH4",[M:SIH4]DSTOFCY(WI),WRET) From STKSOR
            If WRET<>0 Break Endif
        Next
    Endif
Endif
# 84038

Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#     entete *71 à *78 / pied *81 à *88 / ligne *91 à *98
#     les zones TSTCHAMP  1 à  8 determinent l'entete
#     les zones TSTCHAMP 11 à 18 determinent le pied
#     les zones TSTCHAMP 21 à 28 determinent le detail
# lignes entete
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="SIV*71" : TSTCHAMP(2) ="SIV*72" : TSTCHAMP(3) ="SIV*73" : TSTCHAMP(4) ="SIV*74"
TSTCHAMP(5) ="SIV*75" : TSTCHAMP(6) ="SIV*76" : TSTCHAMP(7) ="SIV*77" : TSTCHAMP(8) ="SIV*78"
# lignes pied
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="SIV*81" : TSTCHAMP(12)="SIV*82" : TSTCHAMP(13)="SIV*83" : TSTCHAMP(14)="SIV*84"
TSTCHAMP(15)="SIV*85" : TSTCHAMP(16)="SIV*86" : TSTCHAMP(17)="SIV*87" : TSTCHAMP(18)="SIV*88"
# lignes detail
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="SID*91" : TSTCHAMP(22)="SID*92" : TSTCHAMP(23)="SID*93" : TSTCHAMP(24)="SID*94"
TSTCHAMP(25)="SID*95" : TSTCHAMP(26)="SID*96" : TSTCHAMP(27)="SID*97" : TSTCHAMP(28)="SID*98"
Gosub OUVRE_TEXTE From TRTX3IMP
# ---
Return

#######################################################################
#   Modification du traitement masque SIH4

$IMP_DEFTRT
If TRTMSK="W0SIH4"
   If [M:SIH0]INVTYP=2
      TRTMSK="W0WSIH4CNO"
   Else
      TRTMSK="W0WSIH4INV"
   Endif
Endif
Return

#######################################################################
#   Modification de facture interdite en import

$IMP_AVANT_MOD
#Call TRACE(2,mess(175,192,1)) From SUBIMPOBJ
#OK=0
Return

#######################################################################
#   Lecture d'un enregistrement

$IMPORT
Local Integer OKCHAMP
Local Integer I
Local Char    LEGIS(GLONADI)
Local Integer WRET            : #- X3Suivi 71937 Multi-législation -#

Gosub IMPORT_TEXTE

#--- Entête facture = SIH + SIV ne pas se fier a IMPFIC ---------------
# Issue X3-38291
# Attention avec IMPFIC  : C'est le code table donné dans l'onglet Entête tableau identificateur du modèle d'import
#                          ce n'est pas le code table donné dans l'onglet Champs tableau champs !!
# Be careful with IMPFIC : Equal to the table given in Head folder and Identificator grid of the import template
#                          not equal to the table given in Fields folder and fields grid !!
# End issue X3-38291
Case IMPFIC

  When "SIH", "SIV" :

    #-- Sauvegarde des totaux HT et TTC
    G_AMTNOT=[F:SIH]AMTNOT : G_AMTATI=[F:SIH]AMTATI

    #-- Sauvegarde du statut de la facture (si paramétré dans SIH))
    # Issue X3-38291
    # Attention avec IMPFIC  : C'est le code table donné dans l'onglet Entête tableau identificateur du modèle d'import
    #                          ce n'est pas le code table donné dans l'onglet Champs tableau champs !!
    # Be careful with IMPFIC : Equal to the table given in Head folder and Identificator grid of the import template
    #                          not equal to the table given in Fields folder and fields grid
    #Call TST_CHAMP(IMPFIC,"STA",OKCHAMP) From SUBIMPOBJ
    Call TST_CHAMP("SIH","STA",OKCHAMP) From SUBIMPOBJ
    # End issue X3-38291
    If OKCHAMP
      G_SIH_STA=[F:SIH]STA
      # V6.2 : Certification
      #  Par souci de compatibilité, l'ancienne valeur 2 (Validée) n'étant plus utilisée, on force à la nvelle valeur 3
      # Bug 74845 : Init en INICRE car nécessite la valeur de GSIVCFM (paramètre site)
      #If G_SIH_STA=2 G_SIH_STA=3 Endif : # Bug 74845
    Endif

    #-- Sauvegarde du statut de la facture (si paramétré dans SIV)
    # Issue X3-38291
    # Attention avec IMPFIC  : C'est le code table donné dans l'onglet Entête tableau identificateur du modèle d'import
    #                          ce n'est pas le code table donné dans l'onglet Champs tableau champs !!
    # Be careful with IMPFIC : Equal to the table given in Head folder and Identificator grid of the import template
    #                          not equal to the table given in Fields folder and fields grid
    #Call TST_CHAMP(IMPFIC,"INVSTA",OKCHAMP) From SUBIMPOBJ
    Call TST_CHAMP("SIV","INVSTA",OKCHAMP) From SUBIMPOBJ
    # End issue X3-38291
    If OKCHAMP
      G_SIH_STA=[F:SIV]INVSTA
      # V6.2 : Certification
      #  Par souci de compatibilité, l'ancienne valeur 2 (Validée) n'étant plus utilisée, on force à la nvelle valeur 3
      # Bug 74845 : Init en INICRE car nécessite la valeur de GSIVCFM (paramètre site)
      #If G_SIH_STA=2 G_SIH_STA=3 Endif : # Bug 74845 : Init en INICRE car nécessite la valeur de GSIVCFM
    Endif

    #-- Sauvegarde du statut d'impression de la facture #Fq74333-Gbn
    # Issue X3-38291
    # Attention avec IMPFIC  : C'est le code table donné dans l'onglet Entête tableau identificateur du modèle d'import
    #                          ce n'est pas le code table donné dans l'onglet Champs tableau champs !!
    # Be careful with IMPFIC : Equal to the table given in Head folder and Identificator grid of the import template
    #                          not equal to the table given in Fields folder and fields grid
#    Call TST_CHAMP(IMPFIC,"STARPT",OKCHAMP) From SUBIMPOBJ    : # Bug 74845
#    If OKCHAMP                                                : # Bug 74845
#      If IMPFIC="SIH" & [F:SIH]STARPT=2                       : # Bug 74845
#        G_SIH_STARPT = [F:SIH]STARPT
#      Endif                                                   : # Bug 74845
#      If IMPFIC="SIV" & [F:SIV]STARPT=2                       : # Bug 74845
#        G_SIH_STARPT = [F:SIV]STARPT                          : # Bug 74845
#      Endif                                                   : # Bug 74845
#    Endif                                                     : # Bug 74845
    Call TST_CHAMP("SIH","STARPT",OKCHAMP) From SUBIMPOBJ    : # Bug 74845
    If OKCHAMP
      If [F:SIH]STARPT=2
        G_SIH_STARPT = [F:SIH]STARPT
      Endif
    Endif
    Call TST_CHAMP("SIV","STARPT",OKCHAMP) From SUBIMPOBJ    : # Bug 74845
    If OKCHAMP
      If [F:SIV]STARPT=2
        G_SIH_STARPT = [F:SIV]STARPT
      Endif
    Endif
    # End issue X3-38291

    #-- Chargement ecran adresse client facture (si raison sociale parametree)
    If G_BPRNAM
        [M:ADB3]ADBBPR       = [F:SIH]BPR
        [M:ADB3]BPRNAM(0)    = [F:SIH]BPRNAM(0)
        [M:ADB3]BPRNAM(1)    = [F:SIH]BPRNAM(1)
        [M:ADB3]BPAADDLIG(0) = [F:SIH]BPAADDLIG(0)
        [M:ADB3]BPAADDLIG(1) = [F:SIH]BPAADDLIG(1)
        [M:ADB3]BPAADDLIG(2) = [F:SIH]BPAADDLIG(2)
        [M:ADB3]POSCOD       = [F:SIH]POSCOD
        [M:ADB3]CTY          = [F:SIH]CTY
        [M:ADB3]SAT          = [F:SIH]SAT
        [M:ADB3]CRY          = [F:SIH]CRY
        [M:ADB3]CRYNAM       = [F:SIH]CRYNAM
        [M:ADB3]CNTNAM       = [F:SIV]CNINAM
    #--        If dim([M:ADB3]EECNUM)>0 [M:ADB3]EECNUM=[F:SIV]BPIEECNUM Endif
        [M:ADB3]ADBFLG = 2
    Endif

    #-- Chargement systématique de l'adresse client facture si elle est paramétrée
    If G_BPAINV
        [M:ADB3]BPAADD       = [F:SIH]BPAINV
    Endif

    #-- Chargement systématique du contact client facture s'il est paramétré
    If G_CNINAM
        [M:ADB3]CNTNAM       = [F:SIV]CNINAM
    Endif

    #-- Chargement ecran adresse tiers payeur (si raison sociale parametree)
    If G_BPYNAM
        [M:ADI4]ADBBPR       = [F:SIH]BPRPAY
        [M:ADI4]BPRNAM(0)    = [F:SIH]BPYNAM(0)
        [M:ADI4]BPRNAM(1)    = [F:SIH]BPYNAM(1)
        [M:ADI4]BPAADDLIG(0) = [F:SIH]BPYADDLIG(0)
        [M:ADI4]BPAADDLIG(1) = [F:SIH]BPYADDLIG(1)
        [M:ADI4]BPAADDLIG(2) = [F:SIH]BPYADDLIG(2)
        [M:ADI4]POSCOD       = [F:SIH]BPYPOSCOD
        [M:ADI4]CTY          = [F:SIH]BPYCTY
        [M:ADI4]SAT          = [F:SIH]BPYSAT
        [M:ADI4]CRY          = [F:SIH]BPYCRY
        [M:ADI4]CRYNAM       = [F:SIH]BPYCRYNAM
        [M:ADI4]ADBFLG = 2
    Endif

    #--   Chargement systématique de l'adresse tiers payeur si elle est paramétrée
    If G_BPAPAY
        [M:ADI4]BPAADD       = [F:SIH]BPAPAY
    Endif

    #--CPO 71937 Si la société n'est pas dans le fichier d'import, il faut la lire depuis le SALFCY
    If [F:SIH]CPY="" and [F:SIV]CPY=""
    	#--lire la société du site
    	GFCY=[F:SIV]SALFCY
    	Call GETDEV([F:SIV]SALFCY) From DEVSUB
    	[F:SIH]CPY=GSOCIETE
    	[F:SIV]CPY=GSOCIETE
    Elsif [F:SIH]CPY=""
    	 [F:SIH]CPY=[F:SIV]CPY
    Else
    	 [F:SIV]CPY=[F:SIH]CPY
    Endif
		#--/

    #-- Gestion du compteur
    If G_SIH_SIVTYP
       #- X3Suivi 71937 Multi-législation -#
       Call GETLEG([F:SIH]CPY,"G",LEGIS) From TRTLECLEG
       If LEGIS='' : Call GETLEG([F:SIH]CPY,"T",LEGIS) From TRTLECLEG: Endif
       #Read [TSV]TSV0=[F:SIH]SIVTYP
       Call LEC_TSV_LEG(LEGIS,[F:SIH]SIVTYP,WRET) From TRTLECLEG
       #--CPO 71937 T757 Contrôle de cohérence
       If WRET : Raz [F:TSV] : Endif
       Raz mkstat
       Call CONTTSV([F:SIH]SIVTYP,LEGIS,"","",[F:SIH]FCY,"",[F:SIH]CPY) From SUBTSV
       If mkstat OK=0 : GERR=1 : Return : Endif
       #--/
    Endif
    If G_SIV_SIVTYP
       #- X3Suivi 71937 Multi-législation -#
       Call GETLEG([F:SIV]CPY,"G",LEGIS) From TRTLECLEG
       If LEGIS='' : Call GETLEG([F:SIV]CPY,"T",LEGIS) From TRTLECLEG: Endif
       #Read [TSV]TSV0=[F:SIV]SIVTYP
       Call LEC_TSV_LEG(LEGIS,[F:SIV]SIVTYP,WRET) From TRTLECLEG
       #--CPO 71937 T757 Contrôle de cohérence
       If WRET : Raz [F:TSV] : Endif
       Raz mkstat
       Call CONTTSV([F:SIV]SIVTYP,LEGIS,"","",[F:SIV]SALFCY,"",[F:SIV]CPY) From SUBTSV
       If mkstat OK=0 : GERR=1 : Return : Endif
       #--/
    Endif
    If G_SIH_SIVTYP | G_SIV_SIVTYP
       If clalev([F:TCA])=0 : Local File TABCOUAFF   [TCA] : Endif
       Call LECTCA(5,WOK) From SUBTCA
       If fstat Raz [F:TCA] Endif
       Case [F:TSV]INVTYP
          When 1   : GMANCOU = [F:TCA]MANCOU(3)  : # Facture
          When 2   : GMANCOU = [F:TCA]MANCOU(4)  : # Avoir
          When 5   : GMANCOU = [F:TCA]MANCOU(5)  : # Proforma
       Endcase
       #--      Suivant GMANCOU --> [M:SIH0]NUM actif / inactif pour être importe correctement
       If GREP="C"
          Gosub SETMODE_ON  From TRTX3IMP
          If GMANCOU=1 : Diszo [M:SIH0]NUM : Endif
          If GMANCOU=2 : Actzo [M:SIH0]NUM : Endif
          Gosub SETMODE_OFF From TRTX3IMP
       Endif
    Endif

    #-- Si le type de facture est paramétré, [F:TSV] vient d'être lu
    #-- Si le type de facture n'est pas paramétré, [F:TSV] a été lu dans RAZCRE
    #-- Si avoir ou proforma : jamais de maj des stocks
    If find([F:TSV]INVTYP,2,5) : [F:SIV]STOMVTFLG=1 : Endif

    #-- Si facture directe validée : jamais de maj des stocks            : # Bug 67856
    If [F:TSV]INVTYP=1 & G_SIH_STA=3 : [F:SIV]STOMVTFLG=1 : Endif    : # Bug 67856

Endcase

Case IMPFIC

  When "SIV" :

#-- Initialisation des variables de traitement (inutilisé actuellement)
#   G_SIH_DEL=GIMP(1)
#   G_SIH_CAL=GIMP(2)

# --------------------------------------------------------------------#
#   Chargement de l'ecran adresse client livré                        #
#   Si la raison sociale est paramétrée                               #
# --------------------------------------------------------------------#
    If G_BPDNAM
        [M:ADB2]ADBBPR       = [F:SIV]BPCORD
        [M:ADB2]BPRNAM(0)    = [F:SIV]BPDNAM(0)
        [M:ADB2]BPRNAM(1)    = [F:SIV]BPDNAM(1)
        [M:ADB2]BPAADDLIG(0) = [F:SIV]BPDADDLIG(0)
        [M:ADB2]BPAADDLIG(1) = [F:SIV]BPDADDLIG(1)
        [M:ADB2]BPAADDLIG(2) = [F:SIV]BPDADDLIG(2)
        [M:ADB2]POSCOD       = [F:SIV]BPDPOSCOD
        [M:ADB2]CTY          = [F:SIV]BPDCTY
        [M:ADB2]SAT          = [F:SIV]BPDSAT
        [M:ADB2]CRY          = [F:SIV]BPDCRY
        [M:ADB2]CRYNAM       = [F:SIV]BPDCRYNAM
        [M:ADB2]CNTNAM       = [F:SIV]CNDNAM
        [M:ADB2]ADBFLG = 2
    Endif
#   Chargement systématique du contact client livré s'il est paramétré
    If G_CNDNAM
        [M:ADB2]CNTNAM       = [F:SIV]CNDNAM
    Endif

#-- Chargement de l'ecran de valorisation SIHV
    Raz [M:SIHV]

##--     le tableau des taxes
#    For I=0 To dim([F:SIV]VAT)-1
#      If [F:SIV]VAT(I)<>"" & [M:SIHV]NBVAT<dim([M:SIHV]XVTAX)
#        Read [F:TVT]TVT0=[F:SIV]VAT(I)
#        If fstat : Raz [F:TVT] : Endif
#        [M:SIHV]XVTYP(I) = [F:TVT]VATTYP
#        [M:SIHV]XVBAS(I) = [F:TVT]VATBAS
#        [M:SIHV]XVCHA(I) = [F:TVT]VATCHA
#        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO(I)) From TRTX3TEX
#        [M:SIHV]XVTAX(I) = [F:SIV]VAT(I)
#        [M:SIHV]XVNOT(I) = [F:SIV]VATGRO(I)
#        [M:SIHV]XVSMI(I) = [F:SIV]VATNET(I)
#        [M:SIHV]XVRAT(I) = [F:SIV]VATRAT(I)
#        [M:SIHV]XVAMT(I) = [F:SIV]VATAMT(I)
#        [M:SIHV]XVSUP(I) = [F:SIV]VATSUPAMT(I)
#        [M:SIHV]NBVAT +=1
#      Endif
#    Next I

#       si la donnée xvsup n'est pas garnie, il faut ajuster les montants après déroulement
#       de toutes les lignes (voir repartition utilisée pour le calcul)

#--      le tableau des pieds de facture
#     For I=0 To dim([F:SIV]DTA)-1
#      If [F:SIV]DTA(I)<>0 & [M:SIHV]NBFOOT<dim([M:SIHV]XFNUM)
#        [M:SIHV]XFNUM(I)    = [F:SIV]DTA(I)
#        [M:SIHV]XFNOT(I)    = [F:SIV]DTANOT(I)
#        [M:SIHV]XFSMI(I)    = [F:SIV]DTANET(I)
#        [M:SIHV]XFTAX(I)    = [F:SIV]DTAVAT(I)
#        [M:SIHV]XFRAT(I)    = [F:SIV]DTAVATRAT(I)
#        [M:SIHV]XFDTAAMT(I) = [F:SIV]DTAAMT(I)
#        [M:SIHV]XFVATAMT(I) = [F:SIV]DTAVATAMT(I)
#        [M:SIHV]NBFOOT +=1
#      Endif
#    Next I

    When "CAL"
#--------------------------------------------------------------------#
# Traitement des comptes et sections analytiques des lignes commande #
#            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"SID"'               #
#--------------------------------------------------------------------#
        [F:CAL]ABRFIC="SID"
        [F:CAL]VCRTYP=0
        Call IMPORT_ACCCCE(WNOL,"[M:SIH4]LINACC","","[M:SIH4]CCE") From TRTX3CPT
        nolign=WNOL+1 : status=75 : # Modif élément
    When "SID" :
# -------------------------------------------------------------------#
#     Détails facture                                                #
# -------------------------------------------------------------------#
        Raz WNOL
#-- reservation de variables de comparaison
        Gosub IMP_DECLARE From TRTX3IMP
        If GREP = "M"
            ICLEPRIM (0) = "SIDLIN" : ICLEBRK(1)=1
            ICLEPRIM (1) = "ITMREF"
            NBASTAB = "NBLIG"
            Gosub RECHERCHE_LIGNE From TRTX3IMP
            If nolign=0 : G_NLDET=1 : Endif
            WNOL=nolign-1
#           --> Traitement de suppression d'une ligne
            Call TST_CHAMP(IMPFIC,"QTY",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & [F:SID]QTY = 0 & [M:SIH0]INVTYP<>2 & nolign <> 0
                 status=65
                 # --> Contrôle de suppression de lignes
                 Call C_NBLIG From W1SIH4
                 If mkstat OK=0 : Return : Endif
                 Call AVANT_NBLIG From W1SIH4
                 Call APRES_NBLIG From W1SIH4
            Endif
            # Si ligne de facture avec mouvement de stock, on refuse la modif
            If nolign <> 0
                If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(nolign-1)<>1 &
&                  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&                   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(nolign-1)=""))
                     Call TRACE(2,[M:SIH0]NUM-":"-[M:SIH4]ITMREF(nolign-1)-":"-mess(298,192,1)) From SUBIMPOBJ
                     OK=0 : Return
                Endif
            Endif

            Return
        Endif
        If WNOL=0 WNOL=[M]NBLIG Endif
  When "SVV" :
# -------------------------------------------------------------------#
#     Taxes                                                          #
# -------------------------------------------------------------------#
      If [F:SVV]VAT<>"" & dim([M:SIHV]XVTAX)>0
      #--CPO 71937 TVT et multi-lèg
      Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
        #Read [F:TVT]TVT0=[F:SVV]VAT
        #If fstat : Raz [F:TVT] : Endif
        #--/CPO
        [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP
        [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
        [M:SIHV]XVCHA([M:SIHV]NBVAT) = [F:TVT]VATCHA
        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
        [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
        [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
        [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
        [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
        [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
        [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
        # 102423 : Belgium Early discounts
        # Discount bases
        If (find(GDEPMGTMOD, 1,2,3) & [M:SIH0]INVTYP=1) | GDEPMGTMOD=5
            If [F:SVV]BASDEPNOT <> 0
                [M:SIHV]XVBASDEP([M:SIHV]NBVAT) = [F:SVV]BASDEPNOT
            Endif
            If [F:SVV]BASDEPATI <> 0
                [M:SIHV]XVBASDEP([M:SIHV]NBVAT) = [F:SVV]BASDEPATI
            Endif
        Endif
        # 102423
        [M:SIHV]NBVAT +=1
      Endif
  When "SVF" :
# -------------------------------------------------------------------#
#     Pieds                                                          #
# -------------------------------------------------------------------#
#--      le tableau des pieds de facture
      Raz WNOL
      If [F:SVF]DTA<>0 & dim([M:SIHV]XFNUM)>0
        [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
        [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
        [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

        Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
        For I=0 To dim([F:SVF]DTANET)-1
             If [F:SVF]DTAVAT(I)="" Break Endif
             Assign "[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
             Assign "[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
             Assign "[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
             Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
             Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)

             # 102423 : Belgium Early discounts
             # Discount amounts
             If GDEPMGTMOD=5 & [M:SIH2]DEP<>"" & [M:SIH2]DEPRAT<>0
                Assign "[M:SIHV]DTADEP"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATDEP(I)
             Endif
             # 102423

             [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)
        Next
        If I=1
             [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANET(I-1)
             [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
             [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
        Endif
        # Si import du calcul :
        # --> Les mnts des éléments de facturation saisis doivent être importés depuis SVCRFOOT et non depuis SINVOICEV
        [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
        K=find([F:SVF]DTA,[M:SIH2]INVDTA(0..dim([M:SIH2]INVDTA)-1))
        If K
            [M:SIH2]INVDTAAMT(K-1) = [F:SVF]DTAAMT
            nolign = K : indice = nolign-1 : [M]NBFAC = nolign : status = 75
            Call SAI_NBFAC("SVF","IMP_ZONE","SUBIMPOBJ") From W0SIH2
        Endif
        [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

        # 102423 : Belgium Early discounts
        # Discount amounts
        If GDEPMGTMOD=5 & [M:SIH2]DEP<>"" & [M:SIH2]DEPRAT<>0
            [M:SIHV]DTADEP([M:SIHV]NBFOOT)    = [F:SVF]DTADEP
        Endif
        # 102423

        [M:SIHV]NBFOOT +=1

        If WNOL=0 WNOL=[F:SVF]DTA Endif
      Endif

   When "CFL"
     #----------------------------------------------------------------------------#
     # Traitement des comptes et sections analytiques des éléments de facturation #
     #                 left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"SVF"'                  #
     #----------------------------------------------------------------------------#
       K=find([F:CFL]VCRSEQ,[M:SIHV]XFNUM(0..[M:SIHV]NBFOOT-1))
       If K>=1
         [L]CAS_IMP_SFICCE = 1
         WNOL=K-1
         [F:CFL]ABRFIC="SVF"
         [F:CFL]VCRTYP=4
         [F:CAL]=[F:CFL]
         Call IMPORT_ACCCCE(WNOL,"[M:SIHV]SFIACC","[M:SIHV]DSP","[M:SIHV]SFICCE")    From TRTX3CPT
         nolign=WNOL+1 : status=75 : # Modif élément
       Endif
Endcase

Return

#----------------------------------------------------------------------
$IMPORT_TEXTE
Raz G_NLDET

Case IMPFIC
  When "SIV" :

    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif

    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif

  When "SID"

    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif

Endcase

Return

#######################################################################

$IMP_ZONE
Local Integer WRET :#--CPO 71937 Multi-législation
#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
Gosub TRT_IMP_ZONE

If IMPFIC="SIV" | IMPFIC="SIH"

#       Texte entete
      #If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C"                                              # FGR 14/08/2015 : X3SUIVI110299
      If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & (GREP="C" or GREP = "M") Then                          # FGR 14/08/2015 : X3SUIVI110299
         If GREP = "M" and [M:SIH0]SIHTEX1 <> "" and [M:SIH0]SIHTEX1 <> [M:ITC]T_CLE_CLOB(1) Then  # FGR 14/08/2015 : X3SUIVI110299
           Delete [TXC]TXC0=[M:SIH0]SIHTEX1                                                        # FGR 14/08/2015 : X3SUIVI110299
         Endif                                                                                     # FGR 14/08/2015 : X3SUIVI110299
         [M:SIH0]SIHTEX1=[M:ITC]T_CLE_CLOB(1)
      Endif

#       Texte pied
      #If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C"                                              # FGR 14/08/2015 : X3SUIVI110299
      If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & (GREP="C" or GREP = "M") Then                          # FGR 14/08/2015 : X3SUIVI110299
         If GREP = "M" and [M:SIH0]SIHTEX2 <> "" and [M:SIH0]SIHTEX2 <> [M:ITC]T_CLE_CLOB(2) Then  # FGR 14/08/2015 : X3SUIVI110299
           Delete [TXC]TXC0=[M:SIH0]SIHTEX2                                                        # FGR 14/08/2015 : X3SUIVI110299
         Endif                                                                                     # FGR 14/08/2015 : X3SUIVI110299
         [M:SIH0]SIHTEX2=[M:ITC]T_CLE_CLOB(2)
      Endif
Endif

Case IMPFIC

  When "SIH", "SIV"

    Case IMPZON
      When "SIVTYP" : #--CPO 71937 Multi-législation
      		#--Juste une re-lecture suivie de l'init des données découlant du SIVTYP
      		#--Le SIVTYP est initialisé dans $IMPORT
          Call LEC_TSV_LEG(GCURLEG,[M]SIVTYP,WRET) From TRTLECLEG
          If !WRET Gosub CHARG_SIVTYP From SUBSIHB Endif
      When "INVDAT"
#        If [F:SIH]ACCDAT<>[00/00/00] : [M:SIH0]INVDAT=[F:SIH]ACCDAT : IMPMOD=1 : OK=0 : Endif
        If [F:SIH]ACCDAT<>[00/00/00] & [F:SIH]ACCDAT<>[M:SIH0]INVDAT : [M:SIH0]INVDAT=[F:SIH]ACCDAT : IMPMOD=1 : OK=0 : Endif
      When "BPAADD"
        If G_BPCORD    : [M:SIH1]BPCORD=[F:SIV]BPCORD : GBPCNUM=[F:SIV]BPCORD : Endif
      When "VACBPR"
        If vireblc([F:SIH]VAC,2)<>"" : [M:SIH1]VACBPR=[F:SIH]VAC    : Endif

#          traitement des donnees non saisissables entete sur champ PRITYP
#          ( choix de PRITYP car toujours present )
      When "PRITYP"
        If G_SIHORI    : [M:SIH1]SIHORI      =[F:SIV]SIHORI               : Endif
        If G_SIHORINUM : [M:SIH1]SIHORINUM   =vireblc([F:SIV]SIHORINUM,2) : Endif
        If G_SIHORIDAT : [M:SIH1]SIHORIDAT   =[F:SIV]SIHORIDAT            : Endif
        If G_SIHORITYP : [M:SIH1]SIHORITYP   =[F:SIV]SIHORITYP            : Endif  : # 107888 : Scheduled invoices : (LD:11/05/16)
        If G_ENTCOD    : [M:SIH0]ENTCOD      =[F:SIV]ENTCOD               : Endif
        If G_TRSCOD    : [M:SIH0]TRSCOD      =[F:SIV]TRSCOD               : Endif
        If G_EECNUM    : [M:SIH0]BPIEECNUM   =[F:SIV]BPIEECNUM            : Endif
        If G_EECLOC    : [M:SIH0]EECLOC      =[F:SIV]EECLOC               : Endif
        If G_EECTRN    : [M:SIH0]EECTRN      =[F:SIV]EECTRN               : Endif
        If G_EECICT    : [M:SIH0]EECICT      =[F:SIV]EECICT               : Endif
        If G_ICTCTY    : [M:SIH0]ICTCTY      =[F:SIV]ICTCTY               : Endif
        If G_FFWNUM    : [M:SIH0]FFWNUM      =[F:SIV]FFWNUM               : Endif
        If G_FFWADD    : [M:SIH0]FFWADD      =[F:SIV]FFWADD               : Endif
        If G_EECNAT    : [M:SIH0]EECNAT      =[F:SIV]EECNAT               : Endif
        If G_EECNATR   : [M:SIH0]EECNATR     =[F:SIV]EECNATR              : Endif
        If G_EECSCH    : [M:SIH0]EECSCH      =[F:SIV]EECSCH               : Endif
        If G_EECSCHR   : [M:SIH0]EECSCHR     =[F:SIV]EECSCHR              : Endif
        # 102423 : Belgium Early discounts
        # Discount rate
        If find(GDEPMGTMOD,1,5) & [M:SIH2]DEP<>""
            If G_DEPRAT    : [M:SIH2]DEPRAT  =[F:SIH]DEPRAT               : Endif
        Endif
        # Discount base
        If (find(GDEPMGTMOD, 1,2,3) & [M:SIH0]INVTYP=1) | GDEPMGTMOD=5
            If G_BASDEP    : [M:SIHV]BASDEP  =[F:SIH]BASDEP               : Endif
        Endif
        # 102423

      When "STRDUDDAT"
#          avoirs sur factures :
#          chargement des cours devise et reporting en vigueur à la date de facture
        If G_SIHORIDAT
           If [M:SIH1]SIHORI=4 & [M:SIH1]SIHORINUM<>""
#              Call COURSITE([M:SIH2]CUR,GFCY,[M:SIH2]CURTYP,[M:SIH1]SIHORIDAT,[M:SIH2]RATCUR,GBIDI2) From TRTDEV
#              Call COURDEV([M:SIH2]CUR,GSYSCUR,[M:SIH2]CURTYP,[M:SIH1]SIHORIDAT,[M:SIH2]RATRPT,GBIDI2) From TRTDIV
              #----- Chargement zones devises et cours -----#
              Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS
           Endif
        Endif
        # 87032 : Import des cours devise
        If sum(G_RATMLT,G_RATDIV)<>0
            Local Integer WI
            For WI=0 To dim([F:SIH]RATMLT)-1
              If G_RATDIV(WI)
                Assign ("[M:SIH2]RATDIV("+num$(WI)+")") With [F:SIH]RATDIV(WI)
              Endif
              If G_RATMLT(WI)
                Assign ("[M:SIH2]RATMLT("+num$(WI)+")") With [F:SIH]RATMLT(WI)
              Endif
            Next
            Local Integer INDLED
            # GTYPGEN : Type du référentiel général principal de la société
            # (initialisé par Call SETMAINREF(CPY,GTYPGEN,GTYPANA) From CPTDIV
            INDLED=find(GTYPGEN,[M:SCL]LEDTYP(0..[M:SCL]NBRC-1))
            If INDLED
              [M:SIH2]RAT1=[M:SIH2]RATDIV(INDLED-1)
              [M:SIH2]RAT2=[M:SIH2]RATMLT(INDLED-1)
            Endif
        Endif
        # 87032
      When "CCE"
        If [F:SIH]CCE(indice)=""  OK=0 : Endif
      When "INVDTAAMT"
#          Si import du calcul, ce champs doit être récupéré de SVCRFOOT
        If G_SIH_CAL<>"C" OK=0 : Raz [M:SIH2]INVDTAAMT : Endif
      When "UMRNUM"
        #--CPO 87923 Gestion des prélèvements SDD
        If G_UMRNUM
          If dim([M:SIH2]UMRNUM)>0
            If func AFNC.ACTIV("SDD") & func AFNC.PARAM("SDDMGT",GSOCIETE)="2"
              #--Si la condition de paiement est gérée avec SDD
              If func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)=G_YES
                [M:SIH2]SDDFLG=G_YES
                If [F:SIH]UMRNUM=""
                  #--Si pas déjà renseigné dans le fichier d'import:
                  #--Init avec Mandat par défaut et Statut=2 (Validé)
                  Call INIT_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,2,2,[M:SIH2]UMRNUM) From INVSDDLIB
                Else
                  [M:SIH2]UMRNUM=[F:SIH]UMRNUM
                Endif
              Else
                #--Si condition de paiement non SEPA
                  [M:SIH2]SDDFLG=1
              Endif
              Gosub GRIZO_UMRNUM From TRTVENSDD
              IMPMOD=1 : OK=0
            Endif
          Endif
        Endif
        #--/
    Endcase

  When "SVF"
    Case IMPZON
      When "INVDTAAMT"
        If G_SIH_CAL="C"
#          Pas d'import du calcul, ce champs doit être récupéré de SINVOICEV
            OK=0
        Else
#          Import du calcul, ce champs doit être récupéré de SVCRFOOT
            [M:SIH2]INVDTAAMT(nolign-1)=[F:SVF]DTAAMT
        Endif
    Endcase

Endcase
Return

#######################################################################

$IMP_TAB

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
#Gosub TRT_IMP_ZONE
Local Char     IMPZONFIC(30) : IMPZONFIC =""
Local Char     IMPZONMSK(30) : IMPZONMSK =""
# ---------------------------------------------------------------
# Traitement particulier après chargement de l'enr. importé
# ---------------------------------------------------------------
# --> Raz [F:SIH] [F:SIV] [F:SID]
#     Les zones paramétrées sont chargées
#     Les zones non paramétrées sont vides
#     En création [M] n'est pas chargé
#     En modif.   [M] est chargé avec l'enr à modifier
# ---------------------------------------------------------------

Case IMPFIC
  When "SID" :
    Case IMPZON
      When "QTY"
        If G_STOMGTCOD & find([F:SID]STOMGTCOD,1,2,3)
           [M:SIH4]STOMGTCOD(nolign-1)=[F:SID]STOMGTCOD
        Endif
        #----- Texte detail sur QTY (champ obligatoire)
        If G_DET & [M:ITC]T_CLE_CLOB(3)<>""
           #If GREP="C" | (GREP="M" & G_NLDET)                                                                              # FGR 14/08/2015 : X3SUIVI110299
           If GREP="C" or GREP = "M" Then                                                                                   # FGR 14/08/2015 : X3SUIVI110299
              If GREP = "M" and [M:SIH4]SIDTEX(nolign-1) <> "" and [M:SIH4]SIDTEX(nolign-1) <> [M:ITC]T_CLE_CLOB(3) Then    # FGR 14/08/2015 : X3SUIVI110299
                Delete [TXC]TXC0=[M:SIH4]SIDTEX(nolign-1)                                                                   # FGR 14/08/2015 : X3SUIVI110299
              Endif                                                                                                         # FGR 14/08/2015 : X3SUIVI110299
              [M:SIH4]SIDTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
           Endif
        Endif

      When "DPJT"

       If G_PJT & [F:SID]PJT<>[M:SIH4]DPJT(nolign-1)
           #--- X3Suivi 71065 : Gestion code affaire dans les ventes ---#
           GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC([F:SIV]SALFCY)
           WNEWPJT = [F:SIV]PJT
           If  GPJTSNGDOC = G_OUI
              If WNEWPJT <> [F:SID]PJT
               If !G_PJTV
                #-- Tentative d'import affaire ligne $1$ <> affaire entête $2$ (Mono-Affaire) --> Rejet de la valeur ligne
                Call ECR_TRACE(func AFNC.MES2(mess(1055,196, 1), [F:SID]PJT, WNEWPJT ),0) From GESECRAN
               Else
                 #-- Affaire ligne $1$ <> entête $2$. Maj de l'affaire ligne à partir de l'entête  (Société Mono-Affaire)--#
                 Call ECR_TRACE(func AFNC.MES2(mess(1050,196, 1), [F:SID]PJT, WNEWPJT ),0) From GESECRAN
                [M:SIH4]DPJT(nolign-1)= WNEWPJT : OK=0: IMPMOD=1
               Endif
              Else
               [M:SIH4]DPJT(nolign-1)=[F:SID]PJT : OK=0: IMPMOD=1
               Endif
           Else
            [M:SIH4]DPJT(nolign-1)=[F:SID]PJT : OK=0: IMPMOD=1
           Endif
        Endif

      When "VACITM1"
        If G_VACITM1 & [F:SID]VACITM(0)<>[M:SIH4]VACITM1(nolign-1) & [F:SID]VACITM(0)<>""
           [M:SIH4]VACITM1(nolign-1)=[F:SID]VACITM(0) : OK=0: IMPMOD=1
        Endif

      When "VACITM2"
        If G_VACITM2 & [F:SID]VACITM(1)<>[M:SIH4]VACITM2(nolign-1)
           [M:SIH4]VACITM2(nolign-1)=[F:SID]VACITM(1) : OK=0: IMPMOD=1
        Endif

      When "VACITM3"
        If G_VACITM3 & [F:SID]VACITM(2)<>[M:SIH4]VACITM3(nolign-1)
           [M:SIH4]VACITM3(nolign-1)=[F:SID]VACITM(2) : OK=0: IMPMOD=1
        Endif
      #-- 12/02/09 : Correction suite mail MBT

      When "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
        If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par SINVOICED
        Endif
        # Import des champs affichés, invisibles
        If IMPZON="CCE1" : Gosub CHARG_LIGNE Endif
        #-----
    Endcase
Endcase
Return

#------------------------------------------------------------------
# Traitements de IMP_ZONE et IMP_TAB
#------------------------------------------------------------------
$TRT_IMP_ZONE
Case IMPFIC
  When "SIH", "SIV" :
    #----------------------------------------------------------#
    # Entête facture : Déterminer la bonne abréviation fichier #
    #----------------------------------------------------------#
    Local Shortint I
    Local Char SZSIHFIC(50)    # FGR 27/01/2010 : X3SUIVI61713

    I=find(IMPZON,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    If I=0
      I=find(IMPZON+"(0)",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    # FGR 27/01/2010 : X3SUIVI61713 (début)
    #If I<>0 IMPFIC=left$([M:AOE2]ZONE(I-1),3) : Endif
    If I <> 0 Then
      SZSIHFIC = left$([M:AOE2]ZONE(I-1),3)
      If find(SZSIHFIC, GSTBFIC(0..dim(GSTBFIC)-1)) <> 0 and find(SZSIHFIC, "SIH", "SIV") <> 0 Then
        IMPFIC = SZSIHFIC
      Else
        If IMPFIC = SZSIHFIC and find(SZSIHFIC, "SIH", "SIV") <> 0 Then
          # Si la zone détectée est sur un fichier et qu'il ne fait pas parti de ce qui est importé,
          # on passe sur l'autre pour éviter des erreurs.
          If IMPFIC = "SIH" Then
            IMPFIC = "SIV"
          Else
            IMPFIC = "SIH"
          Endif
        Endif
      Endif
    Endif
    # FGR 27/01/2010 : X3SUIVI61713 (fin)
Endcase
Return

#######################################################################
$AP_IMPORT
  # FGR 27/01/2010 : X3SUIVI61713 (début)
  Case IMPFIC
    When "SIH", "SIV"
      Local Integer I
      Local Integer K

      If SEPNUM > 0 Then      # FGR 02/11/2010 : X3SUIVI68736 : a faire slt dans ce cas
        If GLASTFLGREC <> [M:AOE1]FLGREC(SEPNUM-1) Then
          GLASTFLGREC = [M:AOE1]FLGREC(SEPNUM-1) # Optimisation pour ne le refaire que si nécessaire
          Raz GSTBFIC
          K = 0
          For I = 0 To [M:IMP2]NBFIC-1
            If [M:IMP2]FLG(I) = [M:AOE1]FLGREC(SEPNUM-1) Then
              GSTBFIC(K) = [M:IMP2]ABREV(I)
              K += 1
            Endif
          Next I
        Endif
      Endif                   # FGR 02/11/2010 : X3SUIVI68736 : a faire slt dans ce cas

      # 84038 : Si erreur sur la facture précédente qui vient d'être importée,
      #         Si cette facture était directe avec mouvement de stock
      #         --> Suppression des allocations stockées dans écran de travail STOSORW
      #             (Qtés en cours de traitement)
      #         Seul endroit trouvé où on a la main pour le faire avec IMP_FERME
      # Si erreur lors de l'import cad si mkstat=2 alors GREP est mis à "" après SAIMSK)
      #         Inutile en mode test (la classe [M] n'est pas ouverte)
      If GREP="" & dim ([M:SIH0]INVTYP)>0
          If [M:SIH4]NBLIG<>0 & [M:SIH0]INVTYP=1 & (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2) |
&                               [M:SIH1]SIHORI=2 | [M:SIH1]SIHORI=3)
              Local Integer WI, WRET
              For WI=0 To [M:SIH4]NBLIG-1
                  Call DELSTOSORW(WI,WI,"SIH4",[M:SIH4]DSTOFCY(WI),WRET) From STKSOR
                  If WRET<>0 Break Endif
              Next
          Endif
      Endif
      # 84038

    When Default
  Endcase
  # FGR 27/01/2010 : X3SUIVI61713 (fin)
Return

#------------------------------------------------------------------
#  Les données invisibles ou affichées paramétrées ne sont
#  pas appelées dans IMP_TAB
#  Le chargement est effectué lors de l'appel de CCE1
#    ( a ce moment la classe [F:SID] est toujours présente et toutes
#      les zones saisissables qui initialisent des données ligne de [M:SIH4]
#      sont deja traitees : pas de risques d'ecrasement
#------------------------------------------------------------------
$CHARG_LIGNE
Local Char ZONEF (15)
ZONEF="SOHNUM"       : Gosub CHARG_ZL     : # no commande
ZONEF="SOPLIN"       : Gosub CHARG_ZL     : # no ligne commande
ZONEF="SOQSEQ"       : Gosub CHARG_ZL     : # no sequence
# 107888 : Scheduled invoices : (LD:19/05/16)
ZONEF="VCRINVCNDLIN" : Gosub CHARG_ZL     : # Ligne échéance
ZONEF="VCRINVCNDTYP" : Gosub CHARG_ZL     : # Origine échéance
# 107888 : Scheduled invoices : (LD:19/05/16)
ZONEF="SDHNUM"       : Gosub CHARG_ZL     : # no livraison
ZONEF="SDDLIN"       : Gosub CHARG_ZL     : # no ligne livraison
ZONEF="CONNUM"       : Gosub CHARG_ZL     : # contrat

# Issue 114462
#I=find("SIHORINUM",[M:SP1]ZONFIC3)        : # no facture origine
#If I & [M:SP1]ZONOK3(I-1) : [M:SIH4]XSIHORINUM(nolign-1)=[F:SID]SIHORINUM : Endif
I=find("SIHORINUM",GZONFIC3)        : # no facture origine
If I & GZONOK3(I-1) : [M:SIH4]XSIHORINUM(nolign-1)=[F:SID]SIHORINUM : Endif
# End issue 114462

ZONEF="SIDORILIN"    : Gosub CHARG_ZL     : # no ligne facture origine
ZONEF="SRHNUM"       : Gosub CHARG_ZL     : # no retour
ZONEF="SRDLIN"       : Gosub CHARG_ZL     : # no ligne retour
ZONEF="PRIREN"       : Gosub CHARG_ZL     : # motif prix
ZONEF="NETPRI"       : Gosub CHARG_ZL     : # prix net
ZONEF="NETPRINOT"    : Gosub CHARG_ZL     : # prix net en ht
ZONEF="NETPRIATI"    : Gosub CHARG_ZL     : # prix net en ttc
ZONEF="PFM"          : Gosub CHARG_ZL     : # marge
ZONEF="DISCRGREN1"   : Gosub CHARG_ZL     : # motif remise/frais1
ZONEF="DISCRGREN2"   : Gosub CHARG_ZL     : # motif remise/frais2
ZONEF="DISCRGREN3"   : Gosub CHARG_ZL     : # motif remise/frais3
ZONEF="DISCRGREN4"   : Gosub CHARG_ZL     : # motif remise/frais4
