#SAM 108421 : ACTIONS replaces ACTIONS_OLD
Subprog ACTIONS(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,UID,PCUR)
Variable Instance  UPD(1..)  Using C_ADELTA
Variable Integer   ORD(1..)
Variable Instance  WREP      Using OBJECT
Variable Instance  REP       Using C_AREPENT
Variable Instance  PSYR      Using C_ASYR
Variable Instance  JSO(1..) Using C_ASYRJSO
Variable Integer   NIV
Variable Instance TBNIV(1..) Using C_ASYRJSO
Value    Uuident   UID
Value Integer PCUR

Local Integer LCUR: LCUR=PCUR
Local Integer TROUVE

Local Integer I , J , K , E , N , D , VRI
Gosub DEFVAR From ASYRJSO
K = 0
For I=LCUR To maxtab(UPD)
 VRI = I
 If UPD(VRI)<>null & TROUVE & UPD(VRI).UID<>UID : Break : Endif
 #SAM 10842 : 1 If UPD(VRI)<>null & UPD(VRI).CAT=3 & UPD(VRI).UID=UID
 If UPD(VRI)<>null & UPD(VRI).CAT=3 & UPD(VRI).UID=UID & UPD(VRI).PRO<>"$abort"
  TROUVE=1
  If K=0
   K = 1
   NODEPRO = '"$actions"'
   Gosub ADDOBJECT From ASYRJSO

  Endif
  NODEPRO = '"'+UPD(VRI).PRO+'"'
  Gosub ADDOBJECT From ASYRJSO

  If maxtab(UPD(VRI).CHR)>0 & UPD(VRI).CHR<>null
   NODEPRO = '"$title"'
   NODESVAL = func STRING_TO_SYR(func ASYRSUB.AGETCHR(UPD(VRI).CHR))
   Gosub ADDSTRING From ASYRJSO

  Endif
  For J=1 To maxtab(UPD(VRI).ATT)
   NODEPRO = '"'+UPD(VRI).ATT(J).COD+'"'
   NODESVAL = func STRING_TO_SYR(UPD(VRI).ATT(J).ATT)
   Gosub ADDSTRING From ASYRJSO
  Next J
  Gosub DIAGNOSES
  Gosub OPERETURN : #109788
  If UPD(VRI).PRO = "$save"
   Gosub LINKS_SAVE
  Else
   Gosub LINKS
  Endif
  Gosub ENDNIV From ASYRJSO
 Endif
Next I
If K
 Gosub ENDNIV From ASYRJSO
Endif
End

#-------------------------------------#
$DIAGNOSES
D = 0
For E=1 To maxtab(UPD(VRI).ERR)
 If UPD(VRI).ERR(E).MES<>""
  If D=0
   D = 1
   NODEPRO = '"$diagnoses"'
   Gosub ADDARRAY From ASYRJSO
  Endif
  NODEPRO = ''
  Gosub ADDOBJECT From ASYRJSO

  NODEPRO = '"$severity"'
  NODESVAL = '"'+func ASYRSUB.ERROR(UPD(VRI).ERR(E).STA)+'"'
  Gosub ADDSTRING From ASYRJSO

  NODEPRO = '"$message"'
  NODESVAL = ""
  If NODESVAL="" : NODESVAL += '"' : Endif
  NODESVAL += func STRING_TO_SYR(UPD(VRI).ERR(E).MES)
  #113106
  #If UPD(VRI).ERR(E).NUM<>0
  # If NODESVAL="" : NODESVAL += '"' : Endif
  # NODESVAL += ' ('+num$(UPD(VRI).ERR(E).NUM)+')'
  #Endif
  If NODESVAL<>"" : NODESVAL += '"' : Endif
  Gosub ADDSTRING From ASYRJSO
  Gosub ENDNIV From ASYRJSO
 Endif
Next E
If D
 Gosub ENDNIV From ASYRJSO
Endif
Return
#-------------------------------------#
$OPERETURN
For E=1 To maxtab(UPD(VRI).RET)
 If UPD(VRI).RET(E).CLB<>""
  NODEPRO = '"$return"'
  NODESVAL = UPD(VRI).RET(E).CLB
  Gosub ADDSTRING From ASYRJSO
 Endif
Next E
Return


#---------------------#
# 1  $create
# 2  $details
# 3  $edit
# 4  $delete
# 5  $query
# 6  $print
# 7  $excel
# 8  $execute
# 9  $lookup
# 10 $summary
# 11 $duplicate
#----------------------#

$LINKS
L = 0

For J=1 To maxtab(UPD(VRI).LNK)
 If L=0
  L = 1
  NODEPRO = '"$links"'
  Gosub ADDOBJECT From ASYRJSO

 Endif
 NODEPRO = '"'+UPD(VRI).LNK(J).COD+'"'
 Gosub ADDOBJECT From ASYRJSO

 If UPD(VRI).LNK(J).NAM<>"" : # Only for attributes
  NODEPRO = '"$title"'
  NODESVAL = '"'+UPD(VRI).LNK(J).NAM+'"'
  Gosub ADDSTRING From ASYRJSO

  NODEPRO = '"$type"'
  Case UPD(VRI).LNK(J).CMP
   When 6       : NODESVAL = '"Print"'
   When Default : NODESVAL = '"'+PSYR.PRELNK+'"'
  Endcase
  Gosub ADDSTRING From ASYRJSO

  Case UPD(VRI).LNK(J).CMP
   When 1,3 : # create/edit
    NODEPRO = '"$method"'
    NODESVAL = '"POST"'
    Gosub ADDSTRING From ASYRJSO
   When 4
    NODEPRO = '"$method"'
    NODESVAL = '"DELETE"'
    Gosub ADDSTRING From ASYRJSO
    NODEPRO = '"$confirm"'
    NODESVAL = '"'+func STRING_TO_SYR(mess(209,124,1))+'"' : # Voulez-vous supprimer l'enregistrement
    Gosub ADDSTRING From ASYRJSO
  Endcase
  NODEPRO = '"$url"'
  NODESVAL = '"{$baseUrl}/'+UPD(VRI).LNK(J).CLA

  Case UPD(VRI).LNK(J).CMP
   When 1
    NODESVAL += '/'+PSYR.URLNEW+PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$edit'
   When 2,3,4,6
    If UPD(VRI).LNK(J).CLA=REP.CLA or UPD(VRI).LNK(J).CMP=2
     NODESVAL += "('{$key}')"
    Else
     M = 0
     For N=1 To dim(UPD(VRI).LNK(J).CLE)
      If UPD(VRI).LNK(J).CLE(N)<>""
       If M=0
        M = 1
        NODESVAL += "('"
       Else
        NODESVAL += "~"
       Endif
       If find(left$(UPD(VRI).LNK(J).CLE(N).PRO,1),"'",'"')
        NODESVAL += func ASYRJSO.PARAM(UPD(VRI).LNK(J).CLE(N).PRO)
       Else
        NODESVAL += "{"+UPD(VRI).LNK(J).CLE(N).PRO+"}"
       Endif
      Endif
     Next N
     If M
      NODESVAL += "')"
     Endif
    Endif
    If UPD(VRI).LNK(J).CMP=3 : # edit
     NODESVAL += '/'+PSYR.URLUPD+PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$edit'
    Else
     NODESVAL += PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$details'
    Endif
   When 5
    NODESVAL += PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$query'
   When 9
    NODESVAL += PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$lookup'
   When 10
    NODESVAL += PSYR.URLREP+UPD(VRI).LNK(J).REP+'.$summary'
  Endcase
  For P=1 To maxtab(UPD(VRI).LNK(J).PAR)
   If UPD(VRI).LNK(J).PAR(P)<>null
    NODESVAL += '?'+UPD(VRI).LNK(J).PAR(P).PAR+'='
    If find(left$(UPD(VRI).LNK(J).PAR(P).PRO,1),"'",'"')
     NODESVAL += func ASYRJSO.PARAM(UPD(VRI).LNK(J).PAR(P).PRO)
    Else
     NODESVAL += "{"+UPD(VRI).LNK(J).PAR(P).PRO+"}"
    Endif
   Endif
  Next P
  NODESVAL += '"'
  Gosub ADDSTRING From ASYRJSO
Endif

 For T=1 To maxtab(UPD(VRI).LNK(J).ATT)
  If UPD(VRI).LNK(J).ATT(T)<>null
   NODEPRO = '"'+UPD(VRI).LNK(J).ATT(T).COD+'"'
   NODESVAL = func STRING_TO_SYR(UPD(VRI).LNK(J).ATT(T).ATT)
   Gosub ADDSTRING From ASYRJSO
  Endif
 Next T
 Gosub ENDNIV From ASYRJSO
Next J
If L
 Gosub ENDNIV From ASYRJSO
Endif
Return



$LINKS_SAVE
NODEPRO = '"$links"'
Gosub ADDOBJECT From ASYRJSO

 For J=1 To maxtab(UPD(VRI).LNK)
  If UPD(VRI).LNK(J).COD = "$details"
  NODEPRO = '"'+"$redirect"+'"'
  Gosub ADDOBJECT From ASYRJSO

  NODEPRO = '"$url"'
  #109456
  #NODESVAL = '"{$baseUrl}/'+REP.REP+'(' +"'" + '{$key}' +"'" + ')?representation='+REP.CLA+'.$details"'
  NODESVAL = '"{$baseUrl}/'+REP.CLA+'(' +"'" + '{$key}' +"'" + ')?representation='+REP.REP+'.$details"'
  Gosub ADDSTRING From ASYRJSO

  For T=1 To maxtab(UPD(VRI).LNK(J).ATT)
   If UPD(VRI).LNK(J).ATT(T)<>null
    NODEPRO = '"'+UPD(VRI).LNK(J).ATT(T).COD+'"'
    NODESVAL = func STRING_TO_SYR(UPD(VRI).LNK(J).ATT(T).ATT)
    Gosub ADDSTRING From ASYRJSO
   Endif
  Next T
  Gosub ENDNIV From ASYRJSO
  Break
 Endif
Next J
Gosub ENDNIV From ASYRJSO #$links
Return

#------------------------------------------------#
Funprog STRING_TO_SYR(CHR)
Value Char CHR
Local Char CHAINE(255)
If (left$(CHR,1)='"' & right$(CHR,len(CHR))='"') or (left$(CHR,1)="'" & right$(CHR,len(CHR))="'")
 CHAINE = '"'+func ASYRSUB.STRING_TO_SYR(seg$(CHR,2,len(CHR)-1))+'"'
Else
 CHAINE = func ASYRSUB.STRING_TO_SYR(CHR)
Endif
End CHAINE

#---------------------------------------------#
Subprog SORT_DELTA(UPD,ORD)
Variable Instance UPD(1..) Using C_ADELTA
Variable Integer  ORD(1..)
Local Integer I , NUM , ORG(1..dim(ORD))
Local Uuident UID
UID = NullUuid
Call SORT_INS(UPD,ORG,NUM,UID)
For I=1 To NUM
 ORD(I) = I
Next I
Sorta NUM ORG,ORD Order By ORG(indice+1)
End

#--------------------------------------------------------#
Subprog SORT_INS(UPD,ORG,NUM,UID)
Variable Instance UPD(1..) Using C_ADELTA
Variable Integer  ORG(1..) , NUM
Value    Uuident  UID
Local Uuident  TBUID(1..500) , UIDREF
Local Integer  TBIND(1..500) , TBNUM(1..500) , NBUID
Local Integer I
For I=1 To maxtab(UPD)
 If UPD(I).UIDPAR=UID
  If !find(UPD(I).UID,TBUID(1..NBUID))
   NBUID += 1
   TBUID(NBUID) = UPD(I).UID
   If UPD(I).IND<0 : TBIND(NBUID)= (-1-UPD(I).IND) : Else : TBIND(NBUID)= UPD(I).IND : Endif
   #TBIND(NBUID) = UPD(I).IND : #  112782
   TBNUM(NBUID) = I
  Endif
 Endif
Next I
Sorta NBUID TBIND, TBUID Order By TBIND(indice+1),TBNUM(indice+1)
For I=1 To NBUID
 For J=1 To maxtab(UPD) :# TBNUM(I)
  If UPD(J).UID=TBUID(I)
   NUM += 1
   ORG(J) = NUM
  Endif
 Next J
 If TBUID(I)<>NullUuid
  Call SORT_INS(UPD,ORG,NUM,TBUID(I))
 Endif
Next I
End

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$TRACE_UPD
For I=1 To maxtab(UPD)
 WCHAINE = "i="+num$(I)-"ord="+num$(ORD(I))-"cat="+num$(UPD(I).CAT)
 WCHAINE -= "col="+UPD(I).COL-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)-"uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 If UPD(I).CHR<>null : WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR) : Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Return

