#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------#
# JSON create generation
#----------------------------------------------------------------#

Subprog DETAIL_JSON(REP,WREP,ASWK,PSYR,UPD,WCLOB)
Variable Instance  REP       Using C_AREPENT
Variable Instance  WREP      Using OBJECT
Variable Instance  ASWK      Using C_ASYRWRK
Variable Instance  PSYR      Using C_ASYR
Variable Instance  UPD(1..)  Using C_ADELTA
Variable Clbfile   WCLOB

Local Instance  JSO(1..) Using C_ASYRJSO

Local Integer I , J , K , L , M , N , A
Local Integer E , P
Local Char    VRA(250) , VRB(250) , VRC(250) , VRP(250)
Local Integer VRI , REF
Local Uuident UID , UIDPAR
Local Integer ORD(1..6000)

Local  Char IDXUUID(250)(1..)
Local  Char IDXINS(250)(1..)
Local Integer IDXCOUNT
Local Integer LCUR

Gosub INIVAR From ASYRJSO

# Sort UPD instances by parent uuid & name of properties with dimension
# If ORD(I)<=0 there are may be an orphan instance & the representation must be corrected

Gosub SORTA_UPD
# Load header

Gosub HEADER

# Load properties, errors, attribute & links
Local Integer CUR : LCUR=1
Gosub SEARCH_UUID_MASTER
UIDPAR = NullUuid

Call PROPERTIES(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,UID,UIDPAR,LCUR)

# Create json

Call GENERATE_JSON(TBNIV(1),WCLOB) From ASYRJSO

End

$SORTA_UPD
Local Uuident TBUID(1..),TBUIDPAR(1..)
Local Integer NBUID,TBIND(1..),TBSTRPAR(1..),STR
For I=1 To maxtab(UPD)
  TBUID(I)= UPD(I).UID
  TBUIDPAR(I)= UPD(I).UIDPAR
  If UPD(I).IND<0 : TBIND(I)= (-1-UPD(I).IND) : Else : TBIND(I)= UPD(I).IND : Endif
  #TBIND(I)= UPD(I).IND : # 112782
Next
Sorta maxtab(UPD) UPD,[L]TBUIDPAR,TBIND,TBUID Order By [L]TBUIDPAR(indice+1),TBIND(indice+1),TBUID(indice+1)
Raz TBUIDPAR,TBIND,TBUID
For I=maxtab(UPD) To 1 Step -1
# First set strpar
 J = find(UPD(I).UID,TBUID(1..NBUID))
 If J
   UPD(I).STRPAR =  TBSTRPAR(J)
 Else
   UPD(I).STRPAR =  0
 Endif
 # next update tstrpar
 J = find(UPD(I).UIDPAR,TBUID(1..NBUID))
 If !J
  NBUID += 1
  TBUID(NBUID) = UPD(I).UIDPAR
  TBSTRPAR(NBUID) = I
 Else
  TBSTRPAR(J) = I
 Endif
Next
#107736
For I=1 To maxtab(UPD)
 If UPD(I).STRPAR =  0
  J = find(UPD(I).UID,TBUID(1..NBUID))
  If J & TBSTRPAR(J)>0
    UPD(I).STRPAR =  TBSTRPAR(J)
  Endif
 Endif
Next
#  Openo filpath("TRA","SCRIPT_CCCL_UPD_TABTRI4","csv") ,0 Using [JSON]
#  Iomode adxirs chr$(10) Using [JSON]
#  Iomode adxifs "" Using [JSON]
#  Iomode adxium GASCII Using [JSON]
#  For J=1 To maxtab(UPD)
#   If UPD(J)<>null
#    Wrseq UPD(J).PRO+";"+num$(UPD(J).UID)+";"+num$(UPD(J).IND)+";"+num$(UPD(J).UIDPAR)+";"+num$(UPD(J).STRPAR)+";"+num$(maxtab(UPD(J).ATT)) Using [JSON]
#   Endif
#  Next J
#  Openo Using [JSON]
Return

#----------------------------#
$SEARCH_UUID_MASTER
UID = NullUuid
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UIDPAR=NullUuid & UPD(I).UID<>NullUuid
  UID = UPD(I).UID
  Break
 Endif
Next I
Return

#---------------------------------#
$HEADER
Local Char INSPAR(250)
Local Char INSCLA(250)

NIV = 1
NODEPRO='' : Gosub ADDOBJECT From ASYRJSO

If maxtab(ASWK)>0 & ASWK<>null
 If ASWK.TRCKID<>NullUuid
  NODEPRO = '"$trackingId"'
  NODESVAL = '"'+func ASYRSUB.STRING_TO_SYR(num$(ASWK.TRCKID))+'"'
  Gosub ADDSTRING From ASYRJSO
 Endif
TRCKID
 NODEPRO = '"$baseUrl"'
 NODESVAL = '"'+PSYR.PREFIX+'"'
 Gosub ADDSTRING From ASYRJSO
 NODEPRO = '"$prototype"'
 NODESVAL = '"{$baseUrl}/$prototype('+"'{$representation}.$thumb')"+'"'
 Gosub ADDSTRING From ASYRJSO
 NODEPRO = '"$representation"'
 If ASWK.OPERAT
  NODESVAL = '"'+ASWK.REPRES+'"'
 Else
  NODESVAL = '"'+REP.REP+'"'
 Endif
 Gosub ADDSTRING From ASYRJSO

 NODEPRO = '"$url"'
 If ASWK.OPERAT=2
  NODESVAL = '"{$baseUrl}/'+PSYR.CODCLA+"('"+ASWK.KEYURL+"')"+PSYR.URLREP+ASWK.REPRES+"."+ASWK.FACET+'"'
 Elsif ASWK.TRCKID<>NullUuid
  NODESVAL = '"{$baseUrl}/'+PSYR.URLUPD+"('"+func ASYRSUB.STRING_TO_SYR(num$(ASWK.TRCKID))+"')"+PSYR.URLREP+REP.REP+'.$edit"'
 Else
  NODESVAL = '"{$baseUrl}/'+PSYR.CODCLA+"('"+ASWK.KEYURL+"')"+PSYR.URLREP+REP.REP+'.$edit"'
 Endif
 Gosub ADDSTRING From ASYRJSO

 NODEPRO = '"$type"'
 NODESVAL = '"'+PSYR.PRELNK+'"'
 Gosub ADDSTRING From ASYRJSO

 NODEPRO = '"$etag"'
 NODESVAL = num$(ASWK.NUMWRK)
 Gosub ADDSTRING From ASYRJSO
 NODEPRO = '"ETag"'
 #LSE 2015/11/27 SAM 112838
 #If REP.ICL<>"" & evalue("dim(WREP."+REP.ICL+")")>0
 If REP.ICL<>"" & evalue("dim(WREP."+REP.ICL+")")>0  & evalue("dim(WREP."+REP.ICL+".updtick)")>0
   NODESVAL = num$(evalue("WREP."+REP.ICL+".updtick"))
 Else
  NODESVAL = num$(WREP.updTick)
 Endif
 Gosub ADDSTRING From ASYRJSO
Endif

INSPAR = "WREP"
INSCLA = REP.ICL

# Header fields

TYP = 7
VRA = PROENT(1)
VRC = "uuid"
Gosub HEADER_PRO From ASYRDATDET
Return

#--------------------------------------------------------------------#
Subprog PROPERTIES(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,UID,UIDPAR,PCUR)
Variable Instance UPD(1..) Using C_ADELTA
Variable Integer  ORD(1..)
Variable Instance WREP     Using OBJECT
Variable Instance REP      Using C_AREPENT
Variable Instance PSYR     Using C_ASYR
Variable Instance JSO(1..) Using C_ASYRJSO
Variable Integer  NIV
Variable Instance  TBNIV(1..) Using C_ASYRJSO
Value    Uuident  UID , UIDPAR
Value Integer PCUR

Local Integer LCUR : LCUR=PCUR

Local Integer I , J , K , C , D , L , A , H , E , U , V
Local Integer NBR , NBK , LOU , ENT
Local Integer NBGRP , VRI , VRJ , REF , CAS
Local Uuident UIDLIG , UIDPRO
Local Uuident TBUIDERR(1..)
Local Integer TBORD(1..) , TBORG(1..)
Local Char    WINS(250) , WINF(250) , NAMCOL(80)
Local Char    PROONE(30) , CURPRO(30)
Local Integer MAXKEY , MAXGRP , RIGHTACCESS
MAXGRP = maxtab(REP.COL)+1
MAXKEY = 20
Local Char    TBLOO(30)(1..MAXKEY) , TBGRP(250)(1..MAXGRP)

Gosub DEFVAR From ASYRJSO
Local Integer TROUVE
For I=LCUR To maxtab(UPD)
 VRI=I
 If UPD(VRI)<>null
  If TROUVE &  UPD(VRI).UID<>UID : Break : Endif
  If UPD(VRI).UIDPAR=UIDPAR & UPD(VRI).UID=UID
   LCUR=I
   TROUVE=1
   VRJ = VRI
   Gosub ADDPRO
  Endif
 Endif
Next
If UPD(LCUR).STRPAR>0
 LCUR = UPD(LCUR).STRPAR
 TROUVE=0
 For I=LCUR To maxtab(UPD)
  VRI=I
  If UPD(VRI)<>null
   If TROUVE & UPD(VRI).UIDPAR<>UID : Break : Endif
   If UPD(VRI).UIDPAR=UID
    TROUVE=1
    LCUR=I
    If UPD(VRI).PRO=func ASYRSUB.KILCOL
     Gosub COLLECTION_EMPTY
    Elsif !find(UPD(VRI).COL,TBGRP(1..NBGRP))
     NBGRP += 1
     TBGRP(NBGRP) = UPD(VRI).COL
     [L]NBR = 0
     For J=1 To maxtab(REP.COL)
      If REP.COL(J)<>null & ctrans(REP.COL(J).GRI,".","")=UPD(VRI).COL
       [L]NBR = REP.COL(J).NBR : Break
      Endif
     Next J
     If [L]NBR=1
      If UPD(VRI).CAT=2
       # Collection with one property reference
       Gosub PROPERTIES_ARRAY_REF
      Else
       # Collection with one property no reference
       Gosub PROPERTIES_ARRAY_NOREF
      Endif
     Else
      # It's a collection of instances
      Gosub PROPERTIES_COLLECTION
     Endif
    Endif
   Endif
  Endif
 Next
Endif
Call EVENTS(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,"",UID,UIDPAR,PCUR)
End

#-------------------------------#
$PROPERTIES_COLLECTION
C = 0
UIDLIG = NullUuid
Local Integer CCUR : CCUR=LCUR
Local Integer TROUVE
For J=LCUR To maxtab(UPD)
 VRJ = J
 If UPD(VRJ)<>null
 If TROUVE & UPD(VRJ).UIDPAR<>UID : Break : Endif
  If UPD(VRJ).UIDPAR=UID & UPD(VRI).COL=UPD(VRJ).COL & UPD(VRJ).UID<>UIDLIG
   TROUVE=1
   LCUR=J-1
   UIDLIG = UPD(VRJ).UID
   If C=0
    C = 1
    NODEPRO = '"'+ctrans(UPD(VRJ).COL,".","")+'"'
    Gosub ADDARRAY From ASYRJSO
   Endif
   NODEPRO =''
   Gosub ADDOBJECT From ASYRJSO

   NODEPRO = '"$uuid"'
   NODESVAL = '"'+num$(UPD(VRJ).UID)+'"'
   Gosub ADDSTRING From ASYRJSO

   If UPD(VRJ).IND>=0
    NODEPRO = '"'+func ASYRSUB.CODATT("i")+'"'
    NODESVAL = num$(UPD(VRJ).IND-1)
    Gosub ADDSTRING From ASYRJSO
   Endif
   A = func ATTDEL(UPD(VRJ).ATT)
   If A
    NODEPRO = '"'+func ASYRSUB.CODATT("s")+'"'
    NODESVAL = func STRING_TO_SYR(UPD(VRJ).ATT(A).ATT)
    Gosub ADDSTRING From ASYRJSO
   Endif
   Call PROPERTIES(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,UPD(VRJ).UID,UPD(VRJ).UIDPAR,VRJ)
   Gosub ENDNIV From ASYRJSO
  Endif
 Endif
Next J
If C
 Gosub ENDNIV From ASYRJSO
Endif
Return

#--------------------------#
$ADDPRO
Local Integer NBA

K = find(UPD(VRJ).PRO,REP.PRO(1..maxtab(REP.PRO)).PRO)
If K & UPD(VRJ).PRO<>""
 If UPD(VRJ).CHR<>null
  If REP.PRO(K).ACS<>""
   [L]RIGHTACCESS = 1
   For A=1 To maxtab(UPD(VRJ).ATT)
    If UPD(VRJ).ATT(A)<>null & UPD(VRJ).ATT(A).COD=[V]CST_ARIGHTACCESS & UPD(VRJ).ATT(A).ATT="false"
     [L]RIGHTACCESS = 0
     Break
    Endif
   Next
   If [L]RIGHTACCESS=0 : Return : Endif
  Endif
  REF = (REP.PRO(K).PLK=2)
  If REF
   NODEPRO = '"'+UPD(VRJ).PRO+'"'
   NODESVAL = func ASYRSUB.AGETCHR(UPD(VRJ).CHR)
   Gosub ADDSTRING From ASYRJSO

   NBA = 0
   Gosub DESCRIPTION
   If NBA
    Gosub ENDNIV From ASYRJSO
   Endif
  Elsif UPD(VRJ).PRO<>"AORDER"
   NODEPRO = '"'+UPD(VRJ).PRO+'"'
   NODESVAL = func ASYRSUB.AGETCHR(UPD(VRJ).CHR)
   Gosub ADDSTRING From ASYRJSO

  Endif
 Elsif find(REP.PRO(K).TYP,8,9)>0 : # For BLOBs and CLOBs find(REP.PRO(K).TYP,9,10) : bug 97336 menu local mal affiché CCL
  NBA = 0
  For A=1 To maxtab(UPD(VRJ).ATT)
   If NBA = 0
    NODEPRO = '"'+UPD(VRJ).PRO+'"'
    Gosub ADDOBJECT From ASYRJSO

    NBA = 1
   Endif
   NODEPRO = '"'+UPD(VRJ).ATT(A).COD+'"'
   If find(UPD(VRJ).ATT(A).TYP,4,5)
     NODESVAL  = UPD(VRJ).ATT(A).ATT
   Else
     NODESVAL  = '"'+func STRING_TO_SYR(UPD(VRJ).ATT(A).ATT)+'"'
   Endif
   Gosub ADDSTRING From ASYRJSO
  Next A
  If NBA = 1
   Gosub ENDNIV From ASYRJSO
  Endif
 Endif
Endif
Return

#---------------------------------#
$DESCRIPTION
Local Integer FTITLE : FTITLE=0
Local Integer NBA

For A=1 To maxtab(UPD(VRJ).ATT)
 # Special attributes $title & $description for ref properties
 If UPD(VRJ).ATT(A)<>null
  If func ASYRSUB.ATTOKREF(UPD(VRJ).ATT(A).COD)
   If NBA=0
    NBA = 1
    NODEPRO = '"'+UPD(VRJ).PRO+func ASYRJSO.REF+'"'
    Gosub ADDOBJECT From ASYRJSO
   Endif
   If UPD(VRJ).ATT(A).COD = "$title" : FTITLE=1 :Endif
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,UPD(VRJ).ATT(A).COD,UPD(VRJ).ATT(A).TYP,UPD(VRJ).ATT(A).ATT) From ASYRJSO

  Endif
 Endif
Next A
# $title is Mandatory for property reference
If !FTITLE
  If NBA=0
   NBA = 1
   NODEPRO = '"'+UPD(VRJ).PRO+func ASYRJSO.REF+'"'
   Gosub ADDOBJECT From ASYRJSO
  Endif

  NODESVAL=fmet WREP.AGETATTRIBUTE(UPD(VRJ).PRO,func ASYRSUB.CODATT("T"))
  #107736
  If NODESVAL<>""
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,func ASYRSUB.CODATT("T"),3,NODESVAL) From ASYRJSO
  Else
   NODEPRO = '"'+func ASYRSUB.CODATT("T")+'"'
   NODESVAL='""'
   Gosub ADDSTRING From ASYRJSO
  Endif
Endif
Return

#---------------------------------#
$COLLECTION_EMPTY
NODEPRO = '"'+ctrans(UPD(VRI).COL,".","")+'"'
NODESVAL = "[]"
Gosub ADDSTRING From ASYRJSO
Return

#------------------------#
$LOOKUP_KEYS
NBK = 0
CURPRO = ""
For H=1 To maxtab(REP.PRO(K).LNK(LOU).CLE)
 If REP.PRO(K).LNK(LOU).CLE(H)<>null
  NBK += 1
  If REP.PRO(K).LNK(LOU).CLE(H).LOO<>""
   TBLOO(NBK) = '{'+REP.PRO(K).LNK(LOU).CLE(H).LOO+'}'
  Elsif find(left$(REP.PRO(K).LNK(LOU).CLE(H).VPR,1),"'",'"')
   TBLOO(NBK) = func ASYRJSO.PARAM(REP.PRO(K).LNK(LOU).CLE(H).VPR)
  Else
   TBLOO(NBK) = '{'+REP.PRO(K).LNK(LOU).CLE(H).PAR+'}'
  Endif
  If REP.PRO(K).LNK(LOU).CLE(H).PRO=REP.PRO(K).PRO
   CURPRO = seg$(TBLOO(NBK),2,len(TBLOO(NBK))-1)
  Endif
 Endif
Next C
Return

#------------------------------#
$PROPERTIES_ARRAY_REF
Local Char WPRO(250)

PROONE = UPD(VRI).PRO
K = find(UPD(VRI).PRO,REP.PRO(1..maxtab(REP.PRO)).PRO)
If K
 LOU = find("$lookup",REP.PRO(K).LNK(1..maxtab(REP.PRO(K).LNK)).COD)
 If LOU
  Gosub LOOKUP_KEYS
  If CURPRO<>""
   PROONE = CURPRO
  Endif
 Endif
Endif

# Errors & find values properties in class
#TODO Call FIND_UUID_INSTANCE(WREP,UID,"",WINS) From ASYRUID
Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UID,"WREP",WINS) From ASYRUID

If WINS="WREP."+REP.ICL
 WINS = "WREP"
Endif
K = find(UPD(VRI).PRO,REP.PRO(1..maxtab(REP.PRO)).PRO)
NAMCOL = REP.PRO(K).GRI
For L=len(NAMCOL) To 1 Step -1
 If mid$(NAMCOL,L,1)="."
  WINF   = left$(NAMCOL,L-1)
  NAMCOL = right$(NAMCOL,L+1)
  Break
 Endif
Next L
If WINS<>"" & NAMCOL<>""
 C = 0
 WINF = func ASYRDELCLI.PATH_PROCOL(WINS,WINF)
 U = 0
 For L=1 To evalue("maxtab("+WINF+"."+NAMCOL+")")
  If evalue(WINF+"."+NAMCOL+"("+num$(L)+")")<>null & !find(evalue(WINF+"."+NAMCOL+"("+num$(L)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
   U += 1
   TBORD(U) = evalue(WINF+"."+NAMCOL+"("+num$(L)+").AORDER")
   TBORG(U) = L
  Endif
 Next L
 Sorta U TBORD , TBORG Order By TBORD(indice+1)
 For L=1 To U
  If C=0
   C = 1
   NODEPRO = '"'+ctrans(UPD(VRI).COL,".","")+'"'
   Gosub ADDARRAY From ASYRJSO
  Endif
  NODEPRO =''
  Gosub ADDOBJECT From ASYRJSO

  UIDLIG = evalue(WINF+"."+NAMCOL+"("+num$(TBORG(L))+").AUUID")
  NODEPRO = '"$uuid"'
  NODESVAL = '"'+num$(UIDLIG)+'"'
  Gosub ADDSTRING From ASYRJSO

  NODEPRO = '"'+PROONE+'"'
  WPRO = func ASYRDELCLI.PATH_PROCOL(WINF+"."+NAMCOL+"("+num$(TBORG(L))+")",REP.PRO(K).PTH)
  NODESVAL = func ASYRDATEDT.VALUE_PROPERTY(WREP,REP.PRO(K).TYP,WPRO,REP.PRO(K).PRO)
  Gosub ADDSTRING From ASYRJSO

VRJ = find(UIDLIG,UPD(1..maxtab(UPD)).UID)
  If VRJ<>0
   Gosub EVENTS_REF
  Endif
  Gosub ENDNIV From ASYRJSO
 Next L
 If C
  Gosub ENDNIV From ASYRJSO
 Endif
Endif
Return

#-------------------------------#
$EVENTS_REF

# Errors

Raz D
For E=1 To maxtab(UPD(VRJ).ERR)
 If UPD(VRJ).ERR(E)<>null
  If UPD(VRJ).ERR(E).MES<>""
   If D=0
    D = 1
    NODEPRO = '"$diagnoses"'
    Gosub ADDARRAY From ASYRJSO

   Endif
   NODEPRO = ''
   Gosub ADDOBJECT From ASYRJSO

   NODEPRO = '"$severity"'
   NODESVAL = '"'+func ASYRSUB.ERROR(UPD(VRJ).ERR(E).STA)+'"'
   Gosub ADDSTRING From ASYRJSO

   NODEPRO = '"$message"'
   NODESVAL = ""
   If NODESVAL="" : NODESVAL += '"' : Endif
   NODESVAL += func STRING_TO_SYR(UPD(VRJ).ERR(E).MES)
   #113106
   #If UPD(VRJ).ERR(E).NUM<>0
   # If NODESVAL="" : NODESVAL += '"' : Endif
   # NODESVAL += ' ('+num$(UPD(VRJ).ERR(E).NUM)+')'
   #Endif
   If NODESVAL<>"" : NODESVAL += '"' : Endif
   Gosub ADDSTRING From ASYRJSO

   Gosub ENDNIV From ASYRJSO
  Endif
 Endif
Next E
If D
 Gosub ENDNIV From ASYRJSO
Endif

# Attributes

For A=1 To maxtab(UPD(VRJ).ATT)
 If UPD(VRJ).ATT(A)<>null
  If !func ASYRSUB.ATTOKREF(UPD(VRJ).ATT(A).COD) & func ASYRSUB.ATTOKJSON(UPD(VRJ).ATT(A).COD)
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,UPD(VRJ).ATT(A).COD,UPD(VRJ).ATT(A).TYP,UPD(VRJ).ATT(A).ATT) From ASYRJSO
  Endif
 Endif
Next A

# Links (todo)

Return

#-----------------------------------------#
$PROPERTIES_ARRAY_NOREF
Local Char    WPRO(250)

# Values properties only
Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UID,"WREP",WINS) From ASYRUID

If WINS="WREP."+REP.ICL
 WINS = "WREP"
Endif
K = 0
For J=1 To maxtab(REP.PRO)
 If REP.PRO(J)<>null & ctrans(REP.PRO(J).GRI,".","")=UPD(VRI).COL
  K = J : Break
 Endif
Next J
If K=0 : Return : Endif

If REP.PRO(K).ACS<>""
 [L]RIGHTACCESS = 1
 For A=1 To maxtab(UPD(VRJ).ATT)
  If UPD(VRJ).ATT(A)<>null & UPD(VRJ).ATT(A).COD=[V]CST_ARIGHTACCESS & UPD(VRJ).ATT(A).ATT="false"
   [L]RIGHTACCESS = 0
   Break
  Endif
 Next
 If [L]RIGHTACCESS=0 : Return : Endif
Endif

NAMCOL = REP.PRO(K).GRI
Call TRACE("namcol="+NAMCOL) From ASYRCOM
For L=len(NAMCOL) To 1 Step -1
 If mid$(NAMCOL,L,1)="."
  WINF   = left$(NAMCOL,L-1)
  NAMCOL = right$(NAMCOL,L+1)
  Break
 Endif
Next L
If WINS<>"" & NAMCOL<>""
 C = 0
 WINF = func ASYRDELCLI.PATH_PROCOL(WINS,WINF)
 U = 0
 For L=1 To evalue("maxtab("+WINF+"."+NAMCOL+")")
  If evalue(WINF+"."+NAMCOL+"("+num$(L)+")")<>null & !find(evalue(WINF+"."+NAMCOL+"("+num$(L)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
   U += 1
   TBORD(U) = evalue(WINF+"."+NAMCOL+"("+num$(L)+").AORDER")
   TBORG(U) = L
  Endif
 Next L
 Sorta U TBORD , TBORG Order By TBORD(indice+1)

 For L=1 To U
  If C=0
   C = 1
   NODEPRO = '"'+ctrans(UPD(VRI).COL,".","")+'"'
   Gosub ADDARRAY From ASYRJSO
  Endif
  NODEPRO = ''
  UIDLIG = evalue(WINF+"."+NAMCOL+"("+num$(TBORG(L))+").AUUID")
  WPRO = func ASYRDELCLI.PATH_PROCOL(WINF+"."+NAMCOL+"("+num$(TBORG(L))+")",REP.PRO(K).PTH)
  NODESVAL = func ASYRDATEDT.VALUE_PROPERTY(WREP,REP.PRO(K).TYP,WPRO,REP.PRO(K).PRO)
  Gosub ADDSTRING From ASYRJSO
 Next L

 If C
  Gosub ENDNIV From ASYRJSO
 Endif
Endif
Return

#--------------------------------------------------------------------#
Subprog EVENTS(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,PRO,UID,UIDPAR,PCUR)
Variable Instance UPD(1..) Using C_ADELTA
Variable Integer  ORD(1..)
Variable Instance WREP     Using OBJECT
Variable Instance REP      Using C_AREPENT
Variable Instance PSYR     Using C_ASYR
Variable Instance JSO(1..) Using C_ASYRJSO
Variable Integer  NIV
Variable Instance TBNIV(1..) Using C_ASYRJSO
Value    Char     PRO
Value    Uuident  UID , UIDPAR
Value Integer PCUR

Local Integer LCUR : LCUR=PCUR
Local Integer I , J , K , L , P , C , D , E , U , V
Local Integer NBGRP , VRI , VRJ , REF , ENT , NBR , LOU
Local Uuident UIDLIG , UIDPRO
Local Char    PROJSO(30)
Local Uuident TBUIDERR(1..)
Local Integer TBORD(1..) , TBORG(1..)
Local Integer MAXKEY , MAXGRP
Local Char    WINS(250) , WINF(250) , NAMCOL(80) , PROONE(30)
MAXGRP = maxtab(REP.COL)+1
MAXKEY = 20
Local Char    TBLOO(30)(1..MAXKEY) , CURPRO(30) , TBGRP(250)(1..MAXGRP)

Gosub DEFVAR From ASYRJSO
# $diagnoses & attributes for properties
# Errors & attributes for collection reference are not $properties

ENT = 0
Local Integer TROUVE
For I=LCUR To maxtab(UPD)
 VRI=I
 If UPD(VRI)<>null
  If TROUVE  & UPD(VRI).UID<>UID : Break : Endif
  If UPD(VRI)<>null & UPD(VRI).CAT<>3
   If UPD(VRI).UIDPAR=UIDPAR & UPD(VRI).UID=UID
    #LCUR=I
    TROUVE=1
    VRJ = VRI
    If (maxtab(UPD(VRI).ERR)+func ATTNBR(UPD(VRI).ATT))>0
     PROJSO = UPD(VRI).PRO
     Gosub EVENTS_PRO
    Endif
   Endif
  Endif
 Endif
Next

If UPD(LCUR).STRPAR>0 :# to do if children
 LCUR = UPD(LCUR).STRPAR : #107736
 TROUVE=0
 Local Integer TROUVE2
 For I=LCUR To maxtab(UPD)
  VRI=I
  If UPD(VRI)<>null & UPD(VRI).CAT<>3
   If TROUVE & UPD(VRI).UIDPAR<>UID : Break : Endif
   If UPD(VRI).UIDPAR=UID
    TROUVE=1
    #LCUR=I
   If UPD(VRI).PRO<>func ASYRSUB.KILCOL & !find(UPD(VRI).COL,TBGRP(1..NBGRP))
    NBGRP += 1
    TBGRP(NBGRP) = UPD(VRI).COL
    [L]NBR = 0
    For J=1 To maxtab(REP.COL)
     If REP.COL(J)<>null & ctrans(REP.COL(J).GRI,".","")=UPD(VRI).COL
      [L]NBR = REP.COL(J).NBR : Break
     Endif
    Next J
    If [L]NBR=1 & UPD(VRI).CAT<>2 : # Property not reference
     # Find events
      E = 0
      TROUVE2=0
      For J=VRI To maxtab(UPD)
       VRJ = J
       If TROUVE2 & UPD(VRJ)<>null & UPD(VRI).UIDPAR<>UID : Break : Endif
       If UPD(VRJ)<>null & UPD(VRI).PRO=UPD(VRJ).PRO & UPD(VRI).UIDPAR=UID
        TROUVE2=1
        E += (maxtab(UPD(VRJ).ERR)+func ATTNBR(UPD(VRJ).ATT))
        If E : Break :  Endif
       Endif
      Next J
      If E
       Gosub EVENTS_ARRAY_NOREF
      Endif
     Endif
    Endif
   Endif
  Endif
 Next
Endif

If ENT
 Gosub ENDNIV From ASYRJSO
Endif

# $actions & $links
TROUVE=0
For I=PCUR To maxtab(UPD) : #107736
 VRI = I
 If UPD(VRI)<>null & UPD(VRI).CAT=3
  If TROUVE & UPD(VRI).UID<>UID : Break : Endif
  If UPD(VRI).UIDPAR=UIDPAR & UPD(VRI).UID=UID
   TROUVE=1
   Call ACTIONS(UPD,ORD,WREP,REP,PSYR,JSO,NIV,TBNIV,UID,VRI)
   Break
  Endif
 Endif
Next I
End

#---------------------------------------------#
Funprog ATTNBR(ATT)
Variable Instance ATT(1..) Using C_ADELTAATT
Local Integer A , NBR
NBR = 0
For A=1 To maxtab(ATT)
 If ATT(A)<>null & !func ASYRSUB.ATTOKREF(ATT(A).COD) & func ASYRSUB.ATTOKJSON(ATT(A).COD)
&  & !find(ATT(A).COD,func ASYRSUB.CODATT("s"),[V]CST_ARIGHTACCESS)
  NBR += 1
 Endif
Next A
End NBR

#---------------------------------------------#
Funprog ATTDEL(ATT)
Variable Instance ATT(1..) Using C_ADELTAATT
Local Integer A , DEL
DEL = 0
For A=1 To maxtab(ATT)
 If ATT(A)<>null & ATT(A).COD=func ASYRSUB.CODATT("s") : # $isDeleted
  DEL = A : Break
 Endif
Next A
End DEL

#----------------------------------------#
$EVENTS_ARRAY_NOREF
Raz E , C , TBUIDERR
Local Integer TROUVE
For J=LCUR To maxtab(UPD)
 VRJ = J
 If TROUVE & UPD(VRJ)<>null & UPD(VRJ).UIDPAR<>UID : Break : Endif
 If UPD(VRJ)<>null & UPD(VRI).COL=UPD(VRJ).COL & UPD(VRJ).UIDPAR=UID
  TROUVE=1
  If maxtab(UPD(VRJ).ERR)>0 or maxtab(UPD(VRJ).ATT)>0 or maxtab(UPD(VRJ).LNK)>0
   E += 1
   TBUIDERR(E) = UPD(VRJ).UID
  Endif
 Endif
Next J

# Errors only
#TODO Call FIND_UUID_INSTANCE(WREP,UID,"",WINS) From ASYRUID
Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UID,"WREP",WINS) From ASYRUID

If WINS="WREP."+REP.ICL
 WINS = "WREP"
Endif
For L=1 To maxtab(REP.COL)
 If ctrans(REP.COL(L).GRI,".","")=UPD(VRI).COL
  NAMCOL = REP.COL(L).GRI : Break
 Endif
Next L
For L=len(NAMCOL) To 1 Step -1
 If mid$(NAMCOL,L,1)="."
  WINF   = left$(NAMCOL,L-1)
  NAMCOL = right$(NAMCOL,L+1)
  Break
 Endif
Next L
If WINS<>"" & NAMCOL<>""
 WINF = func ASYRDELCLI.PATH_PROCOL(WINS,WINF)
 U = 0
 For L=1 To evalue("maxtab("+WINF+"."+NAMCOL+")")
  If evalue(WINF+"."+NAMCOL+"("+num$(L)+")")<>null & !find(evalue(WINF+"."+NAMCOL+"("+num$(L)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
   U += 1
   TBORD(U) = evalue(WINF+"."+NAMCOL+"("+num$(L)+").AORDER")
   TBORG(U) = L
  Endif
 Next L
 Sorta U TBORD , TBORG Order By TBORD(indice+1)
 For L=1 To U
  If ENT=0
   ENT = 1
   NODEPRO = '"$properties"'
   Gosub ADDOBJECT From ASYRJSO
  Endif
  If C=0
   C = 1
   NODEPRO = '"'+ctrans(UPD(VRI).COL,".","")+'"'
   Gosub ADDOBJECT From ASYRJSO

   NODEPRO = '"$items"'
   Gosub ADDARRAY From ASYRJSO
  Endif
  NODEPRO = ""
  Gosub ADDOBJECT From ASYRJSO

  UIDLIG = evalue(WINF+"."+NAMCOL+"("+num$(TBORG(L))+").AUUID")
  If find(UIDLIG,TBUIDERR)<>0
   VRJ = find(UIDLIG,UPD(1..maxtab(UPD)).UID)
   PROJSO = ""
   Gosub EVENTS_PRO
  Else
   NODEPRO = '"$diagnoses"'
   NODESVAL = "[]"
   Gosub ADDSTRING From ASYRJSO
  Endif
  Gosub ENDNIV From ASYRJSO
 Next L
 If C
  Gosub ENDNIV From ASYRJSO
  Gosub ENDNIV From ASYRJSO
 Endif
Endif
Return

#-------------------------------#
$EVENTS_PRO

# Errors

Raz D , P
For E=1 To maxtab(UPD(VRJ).ERR)
 If UPD(VRJ).ERR(E)<>null
  If ENT=0 & UPD(VRJ).PRO<>"" : # (UPD(VRJ).PRO<>"" or UPD(VRJ).COL<>"")
   ENT = 1
   NODEPRO = '"$properties"'
   Gosub ADDOBJECT From ASYRJSO
  Endif
  If P=0 & PROJSO<>""
   P = 1
   NODEPRO = '"'+PROJSO+'"'
   Gosub ADDOBJECT From ASYRJSO
  Endif
  If UPD(VRJ).ERR(E).MES<>""
   If D=0
    D = 1
    NODEPRO = '"$diagnoses"'
    Gosub ADDARRAY From ASYRJSO
   Endif
   NODEPRO = ''
   Gosub ADDOBJECT From ASYRJSO

   NODEPRO = '"$severity"'
   NODESVAL = '"'+func ASYRSUB.ERROR(UPD(VRJ).ERR(E).STA)+'"'
   Gosub ADDSTRING From ASYRJSO

   NODEPRO = '"$message"'
   NODESVAL = ""
   If NODESVAL="" : NODESVAL += '"' : Endif
   NODESVAL += func STRING_TO_SYR(UPD(VRJ).ERR(E).MES)
   #113106
   #If UPD(VRJ).ERR(E).NUM<>0
   # If NODESVAL="" : NODESVAL += '"' : Endif
   # NODESVAL += ' ('+num$(UPD(VRJ).ERR(E).NUM)+')'
   #Endif
   If NODESVAL<>"" : NODESVAL += '"' : Endif
   Gosub ADDSTRING From ASYRJSO
   Gosub ENDNIV From ASYRJSO
  Endif
 Endif
Next E
If P=1 & D=0
 NODEPRO = '"$diagnoses"'
 NODESVAL = "[]"
 Gosub ADDSTRING From ASYRJSO
Endif
If D
 Gosub ENDNIV From ASYRJSO
Endif

# Attributes

For A=1 To maxtab(UPD(VRJ).ATT)
 If UPD(VRJ).ATT(A)<>null
  If !func ASYRSUB.ATTOKREF(UPD(VRJ).ATT(A).COD) & func ASYRSUB.ATTOKJSON(UPD(VRJ).ATT(A).COD) & !find(UPD(VRJ).ATT(A).COD,[V]CST_ARIGHTACCESS,func ASYRSUB.CODATT("M"))
   If ENT=0 & (UPD(VRJ).PRO<>"" or UPD(VRJ).COL<>"")
    ENT = 1
    NODEPRO = '"$properties"'
    Gosub ADDOBJECT From ASYRJSO

   Endif
   If P=0 & PROJSO<>""
    P = 1
    NODEPRO = '"'+PROJSO+'"'
    Gosub ADDOBJECT From ASYRJSO
   Endif
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,UPD(VRJ).ATT(A).COD,UPD(VRJ).ATT(A).TYP,UPD(VRJ).ATT(A).ATT) From ASYRJSO
  Endif
 Endif
Next A

# Links (todo)

If P
 Gosub ENDNIV From ASYRJSO
Endif

Return

#----------------------------------------------------------#
