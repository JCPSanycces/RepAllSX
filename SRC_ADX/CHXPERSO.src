#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCHXPERSO","CHXPERSO","") From GSAISIE
End

#-------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "OK"           : Gosub OK
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SEL_TABLE"    : Gosub SEL_TABLE
Endcase
Return

#-------------------------------------------------------------------------#
$OUVRE
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR    [ADP] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
If clalev([F:AIM])=0 : Local File APRINTER  [AIM] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:AOB])=0 : Local File AOBJET    [AOB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AME])=0 : Local File AMETUTI   [AME] : Endif

Local Mask    CHX0 [CHX0], CHX1 [CHX1], CHX2 [CHX2]
Local Integer VERROU
Local Char    SYMBOLE(80)
Local Integer CRE , DEL , MAJ
Local Char    GRU(GLONADI) , CHP(GLONADI)

Local Char    TAB(255)(0..5)
Local Char    SITE(GLONFCY) , SOCIETE(GLONCPY) , LEG(GLONADI)
Local Integer K , NIVEAU , AFFOK , NBCHP
Local Char    MODULE(GLONADI)
Local Char    NAMCHP(30)(1..30) , CODCHP(GLONADI)(1..30)

Return

#------------------------------#
$VERROU
SYMBOLE = "AUS"+GUSER
If GCONSULT
 VERROU = 0
Else
 Lock =SYMBOLE With lockwait=0
 If fstat
  VERROU = 0
 Else
  VERROU = 1
 Endif
Endif
Return

#------------------------------#
$DEVERROU
If VERROU
 Unlock =SYMBOLE : VERROU = 0
Endif
Return

#------------------------------#
$SETBOUT
If GCONSULT
 Call VIREBOUT(CHBOU,"O") From GOBJET
 IMGFLG(5) = 1 : # Croix blanche
Else
 IMGFLG(5) = 0
Endif
If !VERROU & !GCONSULT
 Call VIREBOUT(CHBOU,"O") From GOBJET
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

#-------------------------------------------------------------------------#
$APRES_MODIF
If !VERROU
 Gosub VERROU
 If GCONSULT
  Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
  mkstat = 2
 Elsif !VERROU
  Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
  mkstat = 2
 Else
  Read [AUS]CODUSR = GUSER
  If fstat : FIN = 1 : Return : Endif
  Gosub CHARGE
  Gosub CHARGE_PARAM
  Affzo [M:CHX0]
  Affzo [M:CHX2]
 Endif
Endif
Return

#-------------------------------------------#
$CHARGE
Raz [M:CHX0] , [M:CHX1] , [M:CHX2]
[M:CHX0]  = [F:AUS]
[M:CHX1]  = [F:AUS]
[M:CHX2]  = [F:AUS]
[M:CHX1]NBRIMP = len(mess(0,22,1))
For I=0 To [M:CHX1]NBRIMP-1
 [M:CHX1]PRTDEF(I) = [F:AUS]PRTDEF(I)
Next I
Return

#-------------------------------------------------------------------------#
$DEBUT
Read [AUS]CODUSR = GUSER
If fstat : FIN = 1 : Return : Endif
Gosub CHARGE
Gosub CHARGE_PARAM
Affzo [M:CHX0]
Affzo [M:CHX2]
Gosub VERROU
Return

#----------------------------------------------------------------#
$FIN
Gosub DEVERROU
Return

#-------------------------------------------------------------------------#
$OK
If VERROU
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK = 1
  If GPRODUIT=1 : ## GEODE
   Local Char SAVDEP(GLONDEP), SAVFCY(GLONFCY)
   [L]SAVDEP = [V]GDEP : [L]SAVFCY = [V]GFCY
   Call INIGLOBVAR From GESUSER
   [V]GDEP = [L]SAVDEP : [V]GFCY = [L]SAVFCY
  Else
   Call INIGLOBVAR From GESUSER
  Endif
 Endif
Endif
Return

#-------------------------------------------#
$TR1
GOK = 1
Trbegin [AUS]
 Readlock [AUS]CODUSR = GUSER
 If fstat=1
  GOK = -1 : GLOCK = "$AUTILIS"-GUSER : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("AUS",GUSER) From GLOCK : Goto AB_TR1
 Endif
 [F:AUS] = [M:CHX0]
 [F:AUS] = [M:CHX2]
 [F:AUS]TIT = [M:CHX1]TIT
 For I=0 To [M:CHX1]NBRIMP-1
  [F:AUS]PRTDEF(I) = [M:CHX1]PRTDEF(I)
 Next I
 Rewrite [AUS]
 If fstat
  GOK = 0 : Call FSTA("AUS") From GLOCK : Goto AB_TR1
 Endif

 GRU = ""
 MAJ = 0
 For I=0 To [M:CHX1]NBVAR-1
  If GRU=""
   GRU = [M:CHX1]GRPPAR(I)
   CHP = [M:CHX1]CHAPITRE(I)
  Elsif GRU<>[M:CHX1]GRPPAR(I) or CHP<>[M:CHX1]CHAPITRE(I)
   If MAJ
    Gosub RAZJEU
    If GOK<1 : Break : Endif
   Endif
   GRU = [M:CHX1]GRPPAR(I)
   CHP = [M:CHX1]CHAPITRE(I)
   MAJ = 0
  Endif
  CRE = 0 : DEL = 0
  If [M:CHX1]NIVEAU(I)<>4
   Read [ADU]ADU0 = [M:CHX0]USR ; [M:CHX1]PARAM(I)
   If !fstat
    DEL = 1
   Endif
  Else
   CRE = 1
  Endif
  If DEL | CRE
   Readlock [ADU]ADU0 = [M:CHX0]USR ; [M:CHX1]PARAM(I)
   If fstat=1
    GOK=-1 : GLOCK = "$ADOVALAUS"-[M:CHX0]USR-[M:CHX1]PARAM(I) : Break
   Elsif fstat
    If CRE
     Raz [F:ADU]
     [F:ADU]CODUSR = [M:CHX0]USR
     [F:ADU]PARAM  = [M:CHX1]PARAM(I)
     [F:ADU]VALEUR = [M:CHX1]VALINT(I)
     [F:ADU]JEU = "" : MAJ = 1
     If dim([F:ADU]CREDAT)>0 : [F:ADU]CREDAT = date$ : Endif
     If dim([F:ADU]CREUSR)>0 : [F:ADU]CREUSR = GUSER : Endif
     If dim([F:ADU]CRETIM)>0 : [F:ADU]CRETIM = time  : Endif
     Write [ADU]
     If fstat
      GOK = 0 : Call FSTA("ADU") From GLOCK : Break
     Endif
    Endif
   Elsif DEL
    If [F:ADU]JEU<>"" : MAJ = 1 : Endif
    Delete [ADU] Where CODUSR=[M:CHX0]USR & PARAM=[M:CHX1]PARAM(I)
   Elsif CRE & ([F:ADU]VALEUR<>[M:CHX1]VALINT(I))
    If [F:ADU]JEU<>""
     [F:ADU]JEU = "" : MAJ = 1
    Endif
    [F:ADU]VALEUR = [M:CHX1]VALINT(I)
    If dim([F:ADU]UPDDAT)>0 : [F:ADU]UPDDAT = date$ : Endif
    If dim([F:ADU]UPDUSR)>0 : [F:ADU]UPDUSR = GUSER : Endif
    If dim([F:ADU]UPDTIM)>0 : [F:ADU]UPDTIM = time  : Endif
    Rewrite [ADU]
    If fstat
     GOK = 0 : Call FSTA("ADU") From GLOCK : Break
    Endif
   Endif
  Endif
 Next I

 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 If MAJ
  Gosub RAZJEU
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#----------------------#
$RAZJEU
For [ADP]ADP5 Where CHAPITRE=CHP & GRPPAR=GRU & NIVDEF=4 & MODIF=2
 Read [ADU]ADU0 = [M:CHX0]USR ; [F:ADP]PARAM
 If !fstat & [F:ADU]JEU<>""
  [F:ADU]JEU = ""
  If dim([F:ADU]UPDDAT)>0 : [F:ADU]UPDDAT = date$ : Endif
  If dim([F:ADU]UPDUSR)>0 : [F:ADU]UPDUSR = GUSER : Endif
  If dim([F:ADU]UPDTIM)>0 : [F:ADU]UPDTIM = time  : Endif
  Rewrite [ADU]
  If fstat
   GOK = 0 : Call FSTA("ADU") From GLOCK : Break
  Endif
 Endif
Next ADP
Return

#-------------------------------------------------------------------------#
# Chargement des parametres de l'onglet module
#-------------------------------------------------------------------------#

$CHARGE_PARAM

NBCHP = 0
For [ADP]ADP0(1)
 NBCHP += 1
 CODCHP(NBCHP) = [F:ADP]CHAPITRE
 Call LECTEXTRA(NAMCHP(NBCHP),"ATABDIV","LNGDES","901",CODCHP(NBCHP)) From ATEXTRA
Next ADP

nolign = 0
If [F:AUS]PRFFCT=""
 Read [AME]AME0=[F:AUS]CODMET
 Read [AFT]AFT0=[F:AME]PRFFCT
Else
 Read [AFT]AFT0=[F:AUS]PRFFCT
Endif
For [ADP]ADP5 Where NIVDEF=4 & MODIF=2 & AUSMODIF=2
 [L]SITE = ""
 [L]SOCIETE = ""
 [L]LEG = ""
 If [F:ADP]CHAPITRE<>""
  AFFOK=1
  If [F:ADP]ACS<>"" & GUSRACS<>2
   Read [ACC]CODACC = GUSER;[F:ADP]ACS
   If fstat or [F:ACC]MODIF<>2 : AFFOK = 0 : Endif
  Endif
  If AFFOK
   If [F:ADP]VALDEF=2
    # Récupération du site par défaut definit par module dans le profil fonction
    Call DFLCHAP([F:ADP]CHAPITRE,[L]SITE,AFFOK) From SUBAUS
    If AFFOK
     If [L]SITE<>"" & find([L]SITE,GSITE(1..GNBSITE))>0
      [L]SOCIETE = GSOCSITE(find([L]SITE,GSITE(1..GNBSITE)))
      [L]LEG = GLEGSOC(find([L]SOCIETE,GSOC))
     Endif
    Endif
   Endif
   Read [ADU]ADU0 = [M:CHX0]USR;[F:ADP]PARAM
   If !fstat or [F:ADP]VALDEF=1
    nolign += 1
    NIVEAU = 4
    Gosub ALIM_TAB
   Elsif AFFOK
    nolign+=1
    NIVEAU = 0
    Raz TAB
    Filter [ADW] Where PARAM=[F:ADP]PARAM
    For [ADW]
     If    [F:ADW]FCY<>"" and [F:ADW]FCY=[L]SITE                   : TAB(3) = [F:ADW]VALEUR
     Elsif [F:ADW]CMP<>"" and [F:ADW]CMP=[L]SOCIETE                : TAB(2) = [F:ADW]VALEUR
     Elsif [F:ADW]FCY<>"" and [F:ADW]FCY=[L]LEG and [F:ADW]CMP="*" : TAB(5) = [F:ADW]VALEUR
     Else                                                          : TAB(1) = [F:ADW]VALEUR
     Endif
    Next ADW
    Filter [ADW]
    If    TAB(3)<>"" : NIVEAU = 3 : Gosub ALIM_TAB
    Elsif TAB(2)<>"" : NIVEAU = 2 : Gosub ALIM_TAB
    Elsif TAB(5)<>"" : NIVEAU = 5 : Gosub ALIM_TAB
    Else               NIVEAU = 1 : Gosub ALIM_TAB
    Endif
   Endif
  Endif
 Endif
Next ADP
[M:CHX1]NBVAR = nolign
Affzo [M:CHX1]
For I=1 To [M:CHX1]NBVAR
 If dim([M:CHX1]AUTMOD)>0 & [M:CHX1]AUTMOD(I-1)=0
  Grizo [CHX1]VALEUR(I-1)
 Else
  Actzo [CHX1]VALEUR(I-1)
 Endif
Next I
Return

#-------------------------------------------------------------------------#
$ALIM_TAB

Gosub SETNOL

[M:CHX1] = [F:ADP]
[M:CHX1]DESCHP(NOL)   = NAMCHP(find([F:ADP]CHAPITRE,CODCHP))
[M:CHX1]NIVEAU(NOL)   = NIVEAU
[M:CHX1]SITE(NOL)     = [L]SITE
[M:CHX1]SOCIETE(NOL)  = [L]SOCIETE
If dim([M:CHX1]LEG)>0
 [M:CHX1]LEG(NOL)     = [L]LEG
Endif
If dim([M:CHX1]AUTMOD)>0
 [M:CHX1]AUTMOD(NOL)  = func ADOVAL.AUTMOD([L]SITE,[L]SOCIETE,[L]LEG,GUSER)
Endif

Call TEXTE([F:ADP]NAM,[M:CHX1]NAME(NOL)) From OBJDIV

Case [F:ADP]TYPVAL
 When 1 : [M:CHX1]FMT(NOL) = "Kf:"+num$(GLONADW)+"X"
 When 2 : [M:CHX1]FMT(NOL) = "Nf:10F"
 When 3 : [M:CHX1]FMT(NOL) = "Df:"+GFMDAT4
 When 4 : [M:CHX1]FMT(NOL) = "Nf:2#"
Endcase
Case [F:ADP]TYPVAL
 When 1 : [M:CHX1]TYP(NOL) = "A"   : [M:CHX1]LONG(NOL)  = GLONADW
 When 2 : [M:CHX1]TYP(NOL) = "DCB" : [M:CHX1]LONG(NOL)  = 15
 When 3 : [M:CHX1]TYP(NOL) = "D"   : [M:CHX1]LONG(NOL)  = 0
 When 4 : [M:CHX1]TYP(NOL) = "M"   : [M:CHX1]NOLIB(NOL) = [F:ADP]NOLIB
Endcase
If [F:ADP]OBJET<>""
 Filter [ATY] Where OBJLIEN=[F:ADP]OBJET
 K = 0
 For [ATY]
  K += 1 : If K>1 : Break : Endif
 Next ATY
 Filter [ATY]
 If K=1 & left$([F:ATY]FORTYP,1)<>"="
  [M]TYP(nolign-1) = [F:ATY]CODTYP
 Else
  Call EXISTE_ADX("","","WO"+[F:ADP]OBJET,K) From ORDSYS
  If K>0
   Gosub SETCLE From ="WO"+[F:ADP]OBJET
   Read [AOB]ABREV = [F:ADP]OBJET
   Read [ATZ]CODZONE = [F:AOB]NOMFIC;CLEPRIM
   [M]TYP(nolign-1) = [F:ATZ]CODTYP
  Endif
 Endif
Endif

Case NIVEAU
 When 5
  If [F:ADP]VALDEF=2
   Read [ADW]ADW0 = "*";[L]LEG;[M:CHX1]PARAM(NOL)
   If !fstat
    [M:CHX1]VALEUR(NOL) = [F:ADW]VALEUR
    [M:CHX1]LEG(NOL)    = [L]LEG
   Endif
  Endif
 When 4
  Read [ADU]ADU0 = [M:CHX0]USR;[M:CHX1]PARAM(NOL)
  If !fstat
   [M:CHX1]VALEUR(NOL) = [F:ADU]VALEUR
  Endif
 When 3
  If [F:ADP]VALDEF=2
   Read [ADW]ADW0 = "";[L]SITE;[M:CHX1]PARAM(NOL)
   If !fstat
    [M:CHX1]VALEUR(NOL) = [F:ADW]VALEUR
    [M:CHX1]SITE(NOL)   = [L]SITE
   Endif
  Endif
 When 2
  If [F:ADP]VALDEF=2
   Read [ADW]ADW0 = [L]SOCIETE;"";[M:CHX1]PARAM(NOL)
   If !fstat
    [M:CHX1]VALEUR(NOL)  = [F:ADW]VALEUR
    [M:CHX1]SOCIETE(NOL) = [L]SOCIETE
   Endif
  Endif
 When 1
  If [F:ADP]VALDEF=2
   Read [ADW]ADW0 = "";"";[M:CHX1]PARAM(NOL)
   If !fstat
    [M:CHX1]VALEUR(NOL) = [F:ADW]VALEUR
   Endif
  Endif
Endcase

[M:CHX1]VALINT(NOL) = [M:CHX1]VALEUR(NOL)

Call CHARGE([M:CHX1]VALEUR(NOL),[M:CHX1]TYP(NOL),[M:CHX1]NOLIB(NOL),[M:CHX1]LONG(NOL),[M:CHX1]VALINT(NOL))
&     From FMTVAR

Return

#-------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELTRNFNC" : Gosub SELTRNFNC
Endcase
Return

$SELTRNFNC
If clalev([F:ACT])=0 : Local File ACTION     [ACT] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION  [AFC] : Endif
Call LECTURE("AFC",[M]FNCCOD(nolign-1),"") From CONTOBJ
Case [F:AFC]CODINT
 When "MENU" : # Menu
  CRITERE = "TYPTRAIT=2"
  OBJET = "AFC"
 When Default
  If [F:AFC]ACTION<>""
   Read [ACT]ACTION = [F:AFC]ACTION
   Case [F:ACT]TYP
    When 1 : # Objet
     Local Char WOBJET(GLONAOB)
     WOBJET = seg$([F:AFC]VALPAR(0),2,len([F:AFC]VALPAR(0))-1)
     Case WOBJET
      When "ADI","ADV"
       OBJET = "ADV"
      When Default
       If clalev([F:AWI1])=0 : Local File AWINDOW [AWI1] : Endif
       If clalev([F:ATZ1])=0 : Local File ATABZON [ATZ1] : Endif
       Default File [AWI1]
       TIT(0) = mess(3,126,1) : # Choix transaction
       CRITERE = 'OBJ="'+WOBJET+'"'+' & TRN<>""'
       ORDRE   = "TRN"
       START   = "TRN"
       NBCOL = 0
       NBCOL += 1 : COL(NBCOL) = "[F:AWI1]TRN"    : Gosub TEXTE
       NBCOL += 1 : COL(NBCOL) = "[F:AWI1]LIBEL"  : Gosub TEXTE
     Endcase
    When 2 : # Consultation
     If clalev([F:GTC])=0 : Local File GTABACC [GTC] : Endif
     OBJET = "GTC"
     CRITERE = 'CNSCOD="'+[F:ACT]PARAM1+'"'
    When Default
     Case [F:AFC]ACTION
      When "AIMP1" : # Impression
       OBJET = "ARP"
      When "AMIEXE"
       OBJET = "AMI"
      When "ALISTE"
       OBJET = "ALH"
     Endcase
   Endcase
  Endif
Endcase
Return

$TEXTE
Read [ATZ1]CODZONE = "AWINDOW";right$(COL(NBCOL),instr(1,COL(NBCOL),"]")+1)
Call TEXTE([F:ATZ1]NOCOURT,TIT(NBCOL)) From OBJDIV
Return

#-------------------------------------------------------------------------#
Subprog AS_VALEUR(VALEUR)
Variable Char    VALEUR()
GMODIF = 4
End

Subprog AM_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Case GMODIF
 When 1 : [M]NIVEAU(NOL) = 1 : # Dossier
 When 2 : [M]NIVEAU(NOL) = 2 : # Société
 When 3 : [M]NIVEAU(NOL) = 3 : # Site
 When 4 : [M]NIVEAU(NOL) = 4 : # Utilisateur
 When 5 : [M]NIVEAU(NOL) = 5 : # Législation
Endcase
Affzo NIVEAU(NOL)
End

Subprog C_VALEUR(VALEUR)
Variable Char VALEUR
Call C_VALEUR(VALEUR) From ASAIPARAUS
End

Subprog IB_VALEUR
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If  [F:ADP]NBVAL<>0
& & [F:ADP]OBJET=""    # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if parameter of object
 GBOUT6 = mess(133,126,1) : # Liste de valeurs
Endif
Read [ADP]ADP1 = [M]PARAM(nolign-1)
If [F:ADP]VALDEF=2
 If [M]SITE(nolign-1)<>""
  Read [ADW]ADW0 = "";[M]SITE(nolign-1);[M]PARAM(nolign-1)
  If !fstat
   GBOUT5 = mess(288,123,1) : # Valeur standard
  Endif
 Endif
 If [M]SOCIETE(nolign-1)<>"" & GBOUT5=""
  Read [ADW]ADW0 = [M]SOCIETE(nolign-1);"";[M]PARAM(nolign-1)
  If !fstat
   GBOUT4 = mess(288,123,1) : # Valeur standard
  Endif
 Endif
 If dim([M]LEG)>0 & [M]LEG(nolign-1)<>"" & sum(GBOUT4+GBOUT5)=""
  Read [ADW]ADW0 = "*";[M]LEG(nolign-1);[M]PARAM(nolign-1)
  If !fstat
   GBOUT3 = mess(288,123,1) : # Valeur standard
  Endif
 Endif
 If sum(GBOUT3+GBOUT4+GBOUT5)=""
  Read [ADW]ADW0 = "";"";[M]PARAM(nolign-1)
  If !fstat
   GBOUT2 = mess(288,123,1) : # Valeur standard
  Endif
 Endif
Endif
End

Subprog B2_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "";"";[M]PARAM(NOL) : # Charge la valeur "dossier" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 1
 mkstat = 4
Endif
End

Subprog B3_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "*";[M]LEG(NOL);[M]PARAM(NOL) : #  Charge la valeur "législation" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 5
 mkstat = 4
Endif
End

Subprog B4_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = [M]SOCIETE(NOL);"";[M]PARAM(NOL) : #  Charge la valeur "société" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 2
 mkstat = 4
Endif
End

Subprog B5_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "";[M]SITE(NOL);[M]PARAM(NOL) : #  Charge la valeur "site" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 3
 mkstat = 4
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog B2_NBVAR
Hlpbox "ADP_"+[M:CHX1]CHAPITRE(nolign-1)+"_"+[M:CHX1]PARAM(nolign-1)
End

Subprog AS_FNCPAR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AFC",[M]FNCCOD(nolign-1),"") From CONTOBJ
If !find("#",[F:AFC]VALEUR) : mkstat = 1 : End : Endif
End

Subprog C_PRTDEF(VALEUR)
Variable Char VALEUR()
Local Integer NOL
NOL = nolign-1
If VALEUR<>""
 Call LECTURE("AIM",VALEUR,"") From CONTOBJ
 If [F:AIM]PRT=2 & [F:AIM]PRTNAT<>1 & [F:AIM]PRTNAT<>NOL+1
  GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")"
  mkstat = 1 : End
 Endif
Endif
If [F:AIM]ACS<>""
 Read [ACC]CODACC = GUSER;[F:AIM]ACS
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(6,133,1)-[M]USR-"("+[F:AIM]ACS+")" : # Imprimante non autorisée
  mkstat = 2 : End
 Endif
Endif
End

