$EMPLOID_SRN_CONTROL
If len(this.SRN)>25
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(76,00126,1)-num$(25),[V]CST_AERROR)
Endif
Return

$EMPLOID_NAM_CONTROL
If len(this.NAM)>30
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(76,00126,1)-num$(30),[V]CST_AERROR)
Endif
Return

$EMPLOID_PSD_CONTROL
If len(this.PSD)>20
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(76,00126,1)-num$(20),[V]CST_AERROR)
Endif
Return

