######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP3) 11/06/2007 09:43:54 (CCORA)
######################################################################################
Subprog CL_ECRD(VALEUR)
Variable Char    VALEUR()
If len([M:AVP3]AFLUX)=0
  Call ERREUR("Il faut d'abord générer le fichier XML par le bouton Validation") From GESECRAN
  End
Endif
If  left$([M:AVP3]FIC,2)<>"#@" or GBROWS=0
Local Integer OKH
#  Voulez vous remplacer le processus de référence ?
Call OUINON(mess(19,7837,1),OKH) From GESECRAN
 If OKH=2
   Openo [M:AVP3]FIC,0 Using [OUT]
   Iomode adxifs ""  Using [OUT]
   Iomode adxirs ""  Using [OUT]
   Iomode adxium GUTF8  Using [OUT]
   Local Char TABT(200)(1..500)
   Setlob TABT With [M:AVP3]AFLUX
   For indice=1 To dim(TABT)
     If TABT(indice)="" : Break 1 : Endif
     Wrseq TABT(indice) Using [OUT]
   Next indice
   Openo Using [OUT]
 Endif
Endif

End


