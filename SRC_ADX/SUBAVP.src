#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet AVP
Raz GPILOBJ , GNBMASKOUV

Call OBJET("AVP",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
## Etiquette ajoutée par le superviseur (Objet AVP) 01/06/2007 17:27:30 (CCORA)
######################################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"  
        If LISTE="SELICO"  : Gosub SELICO : Endif
 When "LIENS" : Gosub LIENS
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When default
Endcase
Return


$FILGAUCHE
FILGAUSUP(0) = "MENUR=''"
Return


$CREATION
$MODIF
Call MAJTEXTRA([M]INTIT1,"APORTVIG","INTIT1",[M]CODVI,"") From ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="APORTVIG" & ZONE="INTIT1" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return



$ADRMAP
Local Char REPT(250),DIRSEP,NAMEFIC(250)
Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
REPT="X3_ROOT"+DIRSEP+"X3CLI"+DIRSEP+"XPORTAL"+DIRSEP+"CORE"+DIRSEP+"portal"+DIRSEP+"xml"
NAMEFIC=filpath(REPT,"map","xml","X3_PUB")              
Return

$LIENS
Global Char PORTICO(200)
#Call TEXTE([M:AVP1]INTIT,[M:AVP1]ZINTIT) From OBJDIV
Local Integer NLI
Gosub ADRMAP
[M:AVP3]FIC=NAMEFIC
Gosub CHFAM
For indice=0 To [M:AVP1]NBPAR
  [M:AVP1]MODVAL(indice)=[F:AVP]MODVAL(indice)
  [M:AVP1]PROPVAL(indice)=[F:AVP]PROPVAL(indice)
Next indice

Local Char NOMICO(50)
[M:AVP1]ICONE=[F:AVP]ICONE
NOMICO=[M:AVP1]ICONE : Gosub AFFICO
Return


$TRTCOP
If [M]DOSORG=nomap 
 Local File APORTVIG  [AVP1]
 Local File ATEXTRA   [AXX1]
Else 
 Local File =[M]DOSORG+".APORTVIG" [AVP1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif 
If [M]DOSDES=nomap 
 Local File APORTVIG  [AVP2]
 Local File ATEXTRA [AXX2]
Else 
 Local File =[M]DOSDES+".APORTVIG" [AVP2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
OK = 1
If GTRACE="" 
 Read [AVP2]AVP0=TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Gosub OUVDOS From ATEXTRA
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif

Close Local File [AVP1] , [AVP2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AVP2] , [AXX2]
 Delete [AVP2] Where CODVI=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APORTVIG" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="APORTVIG" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [AVP1]AVP0=TABLE
  [F:AVP2] = [F:AVP1]
  Call COPTEXTRA("APORTVIG","INTIT1",TABLE,"") From ATEXTRA
  Write [AVP2]
  If fstat
   GOK = 0 : Call FSTA("AVP2") From GLOCK
  Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif



######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP1) 08/06/2007 15:52:10 (CCORA)
######################################################################################
Subprog AM_CODFA(VALEUR)
Variable Char    VALEUR()
Local Char CODFA : CODFA=VALEUR
Gosub CHFAM

For indice=0 To [F:ATP]NBPAR-1
  [M:AVP1]MODVAL(indice)=[F:ATP]PROPMOD(indice)
  [M:AVP1]PROPVAL(indice)=[M:AVP1]PROPDEF(indice)
Next indice
[M:AVP1]ICONE=[F:ATP]ICONE
Local Char NOMICO(50)
NOMICO=[M:AVP1]ICONE : Gosub AFFICO

Affzo [M]15-20
End


$CHFAM
If clalev([F:ATP])=0 : Local File APORTTYP [ATP] : Endif
Effzo [M]15
Effzo [M]20
Read [ATP]ATP0=CODFA
If fstat=0
  For indice=0 To [F:ATP]NBPAR-1
    [M:AVP1]PROPN(indice)=[F:ATP]PROPN(indice)
    [M:AVP1]PROPI(indice)=[F:ATP]PROPI(indice)
    [M:AVP1]PROPDEF(indice)=[F:ATP]PROPDEF(indice)
    Call TEXTE([M:AVP1]PROPI(indice),[M:AVP1]ZPROPI(indice)) From OBJDIV
  Next indice
  [M:AVP1]NBPAR=[F:ATP]NBPAR
Endif
Return

