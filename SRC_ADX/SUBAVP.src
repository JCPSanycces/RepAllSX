$SELICO
Local Char REPERT(200),DIRSEP
Raz TEXTE,TEX,NBTEX
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

If clalev([F:HLP_])>0 : Close Local File [HLP_] : Endif
REPERT=filpath("X3_ROOT"+DIRSEP+"RESSTD"+DIRSEP+"IMG","","","X3_PUB")

Local File (HLP(50)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>4
   If NBTEX>=dim(TEXTE) : Break 1 : Endif
   NBTEX+=1
   TEXTE(NBTEX)="RESSTD\"+[F:HLP_]HLP
   TEX(NBTEX)="RESSTD\"+[F:HLP_]HLP
 Endif
Next HLP_
Close Local File [HLP_]

REPERT=filpath("X3_ROOT"+DIRSEP+"RESVER"+DIRSEP+"IMG","","","X3_PUB")
Local File (HLP(50)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>4
   If NBTEX>=dim(TEXTE) : Break 1 : Endif
   NBTEX+=1
   TEXTE(NBTEX)="RESSTD\"+[F:HLP_]HLP
   TEX(NBTEX)="RESSTD\"+[F:HLP_]HLP
 Endif
Next HLP_
Close Local File [HLP_]

REPERT=filpath("X3_ROOT"+DIRSEP+"RESPER"+DIRSEP+"IMG","","","X3_PUB")
Local File (HLP(50)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HLP_]
For [HLP_] Where HLP<>""
 If len([F:HLP_]HLP)>4
   If NBTEX>=dim(TEXTE) : Break 1 : Endif
   NBTEX+=1
   TEXTE(NBTEX)="RESSTD\"+[F:HLP_]HLP
   TEX(NBTEX)="RESSTD\"+[F:HLP_]HLP
 Endif
Next HLP_
Close Local File [HLP_]
Return

$AFFICO
If dim(PORTICO)<0 : Global Char PORTICO(200) : Endif
If left$(NOMICO,5)="http:"
  PORTICO=[M:AVP1]ICONE
Else
  PORTICO=""
  Local Integer PA1 : PA1=instr(1,NOMICO,"\")
  If PA1<>0
    PORTICO="http://"+GVIRTDIR+"/X3_ROOT/"+left$(NOMICO,PA1-1)+"/IMG/"+right$(NOMICO,PA1+1)
  Endif
Endif
Call INITURL([M:AVP1]VISUICO,"ICOPORTAL","","") From INTRUTILA
Affzo [M:AVP1]VISUICO
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP1) 11/06/2007 16:09:32 (CCORA)
######################################################################################
Subprog C_ICONE(VALEUR)
Variable Char    VALEUR()

# Icône prise sur Internet
If dim(PORTICO)<0  : Global Char PORTICO(200) : Endif
If left$(VALEUR,5)="http:" : End : Endif
Local Char DIRSEP,TYPRES,NOMF(50)
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
Local Integer ERR,PA1 : PA1=instr(1,VALEUR,"\")
If PA1<>0
    TYPRES=left$(VALEUR,PA1-1)
    If !find(TYPRES,"RESSTD","RESPER","RESVER") : ERR+=1 : Endif
    NOMF=right$(VALEUR,PA1+1)
    If filinfo(filpath("X3_ROOT"+DIRSEP+TYPRES+DIRSEP+"IMG","","","X3_PUB")+DIRSEP+right$(VALEUR,PA1+1),7)<=0 : ERR+=1 : Endif
Endif
If ERR>0
  GMESSAGE=mess(20,7837,1)     :  # "Icône non trouvée" 
  mkstat=2
Endif
End

Subprog AP_ICONE(VALEUR)
Variable Char    VALEUR()
Local Char NOMICO(50)
NOMICO=VALEUR
Gosub AFFICO
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP1) 25/09/2007 18:08:34 (CCORA)
######################################################################################
Subprog IB_PROPVAL
If !find([M]CODFA,"TAB","FSH","PROC") or ([M]PROPN(nolign-1)<>"IDATA" and [M]PROPN(nolign-1)<>"METIER")
 GBOUTS="" : GBOUT1=""
Endif
End

Subprog S_PROPVAL(VALEUR)
Variable Char    VALEUR()
Local Char   PARAM(250)(1..10)

Local Char OPT,OBJ
Case [M]CODFA
  When "FSH"  : OBJ="APV" : OPT = "B"
  When "TAB"  : OBJ="APV" : OPT = "C"
  When "PROC" : If [M]PROPN(nolign-1)="IDATA" : OBJ="APR" : OPT = "A" : Else : OBJ="APO" : Endif
Endcase
Call SELECT(OBJ,OPT,VALEUR,"") From SELOBJ

End


######################################################################################
#CHECK IGNORE_BEGIN
Subprog MTEXTEVIG
Local File ATEXTRA [AXX]
Local File ATEXTE [ATX] 
Local Integer REW,NBWR,NBRW
Local File APROCESSUS [APR]
Trbegin [AXX]
For [APR]
  Read [AXX]AXX0="APROCESSUS";"INTIT1";"FRA";[F:APR]CODPRO;""
  REW=0
  If fstat=0 : REW=1 : Endif
  [F:AXX]CODFIC="APROCESSUS"
  [F:AXX]ZONE="INTIT1"
  [F:AXX]LANGUE="FRA"
  [F:AXX]IDENT1=[F:APR]CODPRO
  [F:AXX]IDENT2=""
  Call TEXTE([F:APR]INTIT,[F:AXX]TEXTE) From OBJDIV
  If REW=1
    Rewrite [AXX]
    NBRW+=1
  Else
    Write [AXX]
    NBWR+=1
  Endif
Next
#Infbox("Pour APROCESSUS  Nb écrit :"-num$(NBWR)-"   Nb réécrits :"-num$(NBRW))


NBRW=0 : NBWR=0
Local File APORTVIG [AVP]
For [AVP]
  Read [AXX]AXX0="APORTVIG";"INTIT1";"FRA";[F:AVP]CODVI;""
  REW=0
  If fstat=0 : REW=1 : Endif
  [F:AXX]CODFIC="APORTVIG"
  [F:AXX]ZONE="INTIT1"
  [F:AXX]LANGUE="FRA"
  [F:AXX]IDENT1=[F:AVP]CODVI
  [F:AXX]IDENT2=""
  Call TEXTE([F:AVP]INTIT,[F:AXX]TEXTE) From OBJDIV
  If REW=1
    Rewrite [AXX]
    NBRW+=1
  Else
    Write [AXX]
    NBWR+=1
  Endif
Next
Commit

#Infbox("Pour APORTVIG  Nb écrit :"-num$(NBWR)-"   Nb réécrits :"-num$(NBRW))

End
#CHECK IGNORE_END
######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP1) 14/05/2008 17:50:51 (CCORA)
######################################################################################
Subprog B1_PROPVAL(VALEUR)
Variable Char    VALEUR()
Local Char   PARAM(250)(1..10)

Local Char OPT,OBJ
Case [M]CODFA
  When "FSH","TAB"  : Call OBJET("APV",VALEUR,GBIDC2) From GOBJET
  When "PROC" : If [M]PROPN(nolign-1)="IDATA" : Call OBJET("APR",VALEUR,GBIDC2) From GOBJET  
                Else : Call OBJET("APO",VALEUR,GBIDC2) From GOBJET  : Endif
Endcase
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AVP1) 20/05/2009 17:00:53 (CCORA)
######################################################################################
Subprog C_PROPVAL(VALEUR)
Variable Char    VALEUR()

If [M]PROPN(nolign-1)<>"IDATA" and [M]PROPN(nolign-1)<>"METIER" : End : Endif
Case [M]CODFA
  When "FSH","TAB"  : Gosub CONTAPV
  When "PROC" : If [M]PROPN(nolign-1)="IDATA" : Gosub CONTAPR
                Else : Gosub CONTAPO : Endif
Endcase
End

$CONTAPV
If clalev([F:APV])=0 : Local File APTLVW [APV] : Endif
Read[APV]APV0=VALEUR
If fstat<>0
  GMESSAGE=mess(213,7900,1) : # Vue portail non trouvée
  mkstat=2
Endif
Return

$CONTAPO
If VALEUR="" : Return : Endif
If clalev([F:APO])=0 : Local File APROMEN [APO] : Endif
Local Integer NBPROC
NBPROC = 0
For [APO] Where CODMEN=VALEUR
 NBPROC += 1
Next APO
If NBPROC=0
  GMESSAGE=mess(154,124,1) : # Menu inexistant
  mkstat=2
Endif
If NBPROC>0 & func AFNC.ACTIV("LEG")
  Infbox(mess(140,127,1)) : # Attention ce menu processus est décliné par législation
Endif
Return

$CONTAPR
If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
Filter [APR] Where CODPRO=VALEUR
Local Integer NBPROC,NBPROL
NBPROC = 0
For [APR]
  If [F:APR]TYPEP=1 
    NBPROC+=1 
    If [F:APR]CODLEG<>"" : NBPROL+=1 : Endif
  Endif
Next
Filter [APR]
If NBPROC=0
  GMESSAGE=mess(52,127,1) : # Processus inexistant
  mkstat=2
Endif
If NBPROL>0 & func AFNC.ACTIV("LEG")
   If NBPROL=NBPROC
     Infbox(mess(125,127,1)) : # Attention ce processus n'est disponible que pour certaine(s) législation(s)
   Else
     Infbox(mess(126,127,1)) : # Attention ce processus est décliné par législation
   Endif
Endif


#Read[APR]APR0=VALEUR
#If fstat<>0 or [F:APR]TYPEP<>1
#  GMESSAGE=mess(52,127,1) : # Processus inexistant
#  mkstat=2
#Endif
Return

