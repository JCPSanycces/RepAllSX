#<AdxTL>@(#)2.0.0.0 $Revision$
#################################################################################
# UUMGTRTPUR51   Moulinette de Migration des mouvements fournisseurs  Module TC #
#################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR51") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR51(DOSSIER)
  Call MAJ_UUMGTRTPUR51(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTPUR51(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
Local Char WNAMMVSM
Call MIGTABNAME (DOSSIER,"BPSUPPMVT",WNAMMVSM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMVSM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"BPSUPPMVT",ERR) From TRTMIG
# Issue 108760 - 2015-06-15 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"LASTSUPMVT")<>  1
  Call MIGTABRAZ (DOSSIER,"LASTSUPMVT",ERR) From TRTMIG
Endif

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR51",ERR) From TRTMIG

End

########################################################################
########################################################################
Subprog MAJ_UUMGTRTPUR51(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1


Local Integer ERR

##1 - verifications
####################

Local Char WNAMMVSM
Call MIGTABNAME (DOSSIER,"BPSUPPMVT",WNAMMVSM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR51",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMVSM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR51",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR51",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_MVS (100) (adxwrb)

Local Shortint WCPT_MVS

Call ECR_TIME("UUMGTRTPUR51 tables MVS Process : Update MVS") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR51 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"BPSUPPMVT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:MVS])  = 0 : Local File =DOSSIER+".BPSUPPMVT"    [MVS]  : Endif   # Fichier X3 "Vide"
If clalev([F:MVS1])  = 0 : Local File =DOSSIER+".BPSUPPMVT"    [MVS1]  : Endif   # Fichier X3 "Vide"
If clalev([F:BPSM]) = 0 : Local File =DOSSIER+"."+WNAMMVSM   [MVSM] : Endif   # Fichier X3 renommé Avant Migration

Local File =[F:ADS]DOSSIER+".LASTSUPMVT"  [LSM]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
Local File =[F:ADS]DOSSIER+".PINVOICE"    [PIH]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU0]
Local File =[F:ADS]DOSSIER+".TABCHANGE"   [TCH]
#----- Tables achats -----#
If [F:ADS]MODULE(5)=2
  Local File =[F:ADS]DOSSIER+".PQUOTAT"   [PQH]
  Local File =[F:ADS]DOSSIER+".PORDER"    [POH]
  Local File =[F:ADS]DOSSIER+".PRECEIPT"  [PTH]
  Local File =[F:ADS]DOSSIER+".PRECEIPTD" [PTD]
Endif
#----- Table tiers -----#
If [F:ADS]MODULE(2)=2
  Local File =[F:ADS]DOSSIER+".PAYMENTH"  [PYH]
Endif
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Gosub INISOC From UUMGTRTPUR00

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J
#Déclaration des variables pour le traitement fonctionnel
Local Libelle  WIFFTYP
Local Libelle  WMVTTYP
Local Date     WMVTDAT
Local Char     VCRNUM (GLONVCR)
Local Char     WCUR   (GLONCUR)
Local Decimal  WAMT, WAMT2
Local Char     WIFFFCY(GLONFCY)
Local Char     WBPSNUM(GLONBPR)
Local Char     WFINRSPFCY(GLONFCY)
Local Integer  STA

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR51",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

Link [MVSM] With [BPS]BPS0~=[F:MVSM]BPSNUM
&    As [LNK]
&    Order By Key CLE = [F:MVSM]BPSNUM;[F:MVSM]FINRSPFCY

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR51" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_MVS00
Raz NB
If  STOP=1
  CRITERE = '[F:MVSM]BPSNUM=TABMIGKEY(1) & [F:MVSM]FINRSPFCY>TABMIGKEY(2)'
  STOP = 2
Elsif STOP=2
  CRITERE = '[F:MVSM]BPSNUM>TABMIGKEY(1)'
  STOP = 0
Else
  CRITERE = '1=1'
Endif


Trbegin [MVS]
GOK = 1

For [LNK]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR51" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #  version < V6, raz de toute la classe en v6
  If val(VERSION)<GMIGX3VER60
    Raz [F:MVS]
  Endif
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_MVS
  Endif
  #Appel proc de migration sur entete
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MVS
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_MVS
    If GOK<1 : Break : Endif
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:MVSM]BPSNUM
    TABMIGKEY(2) = [F:MVSM]FINRSPFCY
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR51",7,ERR) From TRTMIG : #7=Erreur
Else
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR51",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR51",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_MVS00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MVS]
Close Local File [MVSM]


#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPSUPPMVT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR51") From TRTMIG
Call ECR_TIME("UUMGTRTPUR51 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$MAJV6_MVS
    WBPSNUM   =[F:MVSM]BPSNUM
    WFINRSPFCY=[F:MVSM]FINRSPFCY
    Call GETDEV([F:ADS]DOSSIER,[F:MVSM]FINRSPFCY) From TRTX3CPT
    If [F:BPS]BPSNUM<>[F:MVSM]BPSNUM
      Read [BPS] BPS0=[F:MVSM]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    If [F:BPS]BPSINV=""  [F:BPS]BPSINV=[F:BPS]BPSNUM : Endif
    #-----
    #[F:MVS]BPSRSK =[F:BPS]BPSINV
    #[F:MVS]CPY    =GSOCIETE
    [F:MVS1]CUR    =[F:MVSM]ACCCUR
    [F:MVS1]=[F:MVSM]
    #----- Montants en devise transaction -----#
    [F:MVS1]ORDNOTC   =[F:MVSM]ORDAMT
    [F:MVS1]ORDATIC   =[F:MVSM]ORDAMT
    [F:MVS1]RCPNOTC   =[F:MVSM]RCPAMT
    [F:MVS1]RCPATIC   =[F:MVSM]RCPAMT
    [F:MVS1]BILAMTC(0)=[F:MVSM]BILAMT(0)
    [F:MVS1]BILAMTC(1)=[F:MVSM]BILAMT(1)
    [F:MVS1]BILAMTC(2)=[F:MVSM]BILAMT(2)
    [F:MVS1]BLCAMTC   =[F:MVSM]BLCAMT
    [F:MVS1]INVAMTC   =[F:MVSM]INVAMT
    #----- Montants en devise société -----#
    If [F:MVS1]CUR<>GLOCALDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]ORDNOTC,[F:MVS1]ORDNOTL,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]ORDATIC,[F:MVS1]ORDATIL,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]RCPNOTC,[F:MVS1]RCPNOTL,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]RCPATIC,[F:MVS1]RCPATIL,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(0),[F:MVS1]BILAMTL(0),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(1),[F:MVS1]BILAMTL(1),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(2),[F:MVS1]BILAMTL(2),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BLCAMTC,[F:MVS1]BLCAMTL,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]INVAMTC,[F:MVS1]INVAMTL,STA) From TRTDEV
    Else
      [F:MVS1]ORDNOTL   =[F:MVS1]ORDNOTC
      [F:MVS1]ORDATIL   =[F:MVS1]ORDATIC
      [F:MVS1]RCPNOTL   =[F:MVS1]RCPNOTC
      [F:MVS1]RCPATIL   =[F:MVS1]RCPATIC
      [F:MVS1]BILAMTL(0)=[F:MVS1]BILAMTC(0)
      [F:MVS1]BILAMTL(1)=[F:MVS1]BILAMTC(1)
      [F:MVS1]BILAMTL(2)=[F:MVS1]BILAMTC(2)
      [F:MVS1]BLCAMTL   =[F:MVS1]BLCAMTC
      [F:MVS1]INVAMTL   =[F:MVS1]INVAMTC
    Endif
    #----- Montants en devise dossier -----#
    If [F:MVS1]CUR<>GCURSHR
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]ORDNOTC,[F:MVS1]ORDNOTR,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]ORDATIC,[F:MVS1]ORDATIR,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]RCPNOTC,[F:MVS1]RCPNOTR,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]RCPATIC,[F:MVS1]RCPATIR,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(0),[F:MVS1]BILAMTR(0),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(1),[F:MVS1]BILAMTR(1),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BILAMTC(2),[F:MVS1]BILAMTR(2),STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]BLCAMTC,[F:MVS1]BLCAMTR,STA) From TRTDEV
      Call CONVERT([F:MVS1]CUR,GCURSHR,GLOCALDEV,[F:BPS]CHGTYP,date$,
&                  [F:MVS1]INVAMTC,[F:MVS1]INVAMTR,STA) From TRTDEV
    Else
      [F:MVS1]ORDNOTR   =[F:MVS1]ORDNOTC
      [F:MVS1]ORDATIR   =[F:MVS1]ORDATIC
      [F:MVS1]RCPNOTR   =[F:MVS1]RCPNOTC
      [F:MVS1]RCPATIR   =[F:MVS1]RCPATIC
      [F:MVS1]BILAMTR(0)=[F:MVS1]BILAMTC(0)
      [F:MVS1]BILAMTR(1)=[F:MVS1]BILAMTC(1)
      [F:MVS1]BILAMTR(2)=[F:MVS1]BILAMTC(2)
      [F:MVS1]BLCAMTR   =[F:MVS1]BLCAMTC
      [F:MVS1]INVAMTR   =[F:MVS1]INVAMTC
    Endif
    #----- Ecriture ou réécriture mouvements fournisseurs ([F:MVS2]) -----#
    Filter [MVS] Where BPSRSK=[F:BPS]BPSINV
&                     & CPY   = GSOCIETE
&                     & BPSNUM=[F:MVSM]BPSNUM
&                     & CUR   =[F:MVSM]ACCCUR
    Read [MVS] First
    If !fstat
      [F:MVS]ORDNOTC   +=[F:MVS1]ORDNOTC
      [F:MVS]ORDATIC   +=[F:MVS1]ORDATIC
      [F:MVS]RCPNOTC   +=[F:MVS1]RCPNOTC
      [F:MVS]RCPATIC   +=[F:MVS1]RCPATIC
      [F:MVS]BILAMTC(0)+=[F:MVS1]BILAMTC(0)
      [F:MVS]BILAMTC(1)+=[F:MVS1]BILAMTC(1)
      [F:MVS]BILAMTC(2)+=[F:MVS1]BILAMTC(2)
      [F:MVS]BLCAMTC   +=[F:MVS1]BLCAMTC
      [F:MVS]INVAMTC   +=[F:MVS1]INVAMTC
      #-----
      [F:MVS]ORDNOTL   +=[F:MVS1]ORDNOTL
      [F:MVS]ORDATIL   +=[F:MVS1]ORDATIL
      [F:MVS]RCPNOTL   +=[F:MVS1]RCPNOTL
      [F:MVS]RCPATIL   +=[F:MVS1]RCPATIL
      [F:MVS]BILAMTL(0)+=[F:MVS1]BILAMTL(0)
      [F:MVS]BILAMTL(1)+=[F:MVS1]BILAMTL(1)
      [F:MVS]BILAMTL(2)+=[F:MVS1]BILAMTL(2)
      [F:MVS]BLCAMTL   +=[F:MVS1]BLCAMTL
      [F:MVS]INVAMTL   +=[F:MVS1]INVAMTL
      #-----
      [F:MVS]ORDNOTR   +=[F:MVS1]ORDNOTR
      [F:MVS]ORDATIR   +=[F:MVS1]ORDATIR
      [F:MVS]RCPNOTR   +=[F:MVS1]RCPNOTR
      [F:MVS]RCPATIR   +=[F:MVS1]RCPATIR
      [F:MVS]BILAMTR(0)+=[F:MVS1]BILAMTR(0)
      [F:MVS]BILAMTR(1)+=[F:MVS1]BILAMTR(1)
      [F:MVS]BILAMTR(2)+=[F:MVS1]BILAMTR(2)
      [F:MVS]BLCAMTR   +=[F:MVS1]BLCAMTR
      [F:MVS]INVAMTR   +=[F:MVS1]INVAMTR
      #-----
      [F:MVS]UPDUSR=GUSER
      [F:MVS]UPDDAT=date$
      Rewrite [MVS]
      If fstat
        Call ECR_TRACE("File BPSUPPMVT"-[F:MVS]BPSRSK-[F:MVS]CPY-[F:MVS]BPSNUM-[F:MVS]CUR+
&                      ", Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Return
      Endif
    Else
      [F:MVS]=[F:MVS1]
      [F:MVS]BPSRSK =[F:BPS]BPSINV
      [F:MVS]CPY    =GSOCIETE
      [F:MVS]CUR    =[F:MVSM]ACCCUR
      Raz [F:MVS]UPDUSR, [F:MVS]UPDDAT
      [F:MVS]CREUSR=GUSER
      [F:MVS]CREDAT=date$
      Write [MVS]
      If fstat
        Call ECR_TRACE("File BPSUPPMVT"-[F:MVS]BPSRSK-[F:MVS]CPY-[F:MVS]BPSNUM-[F:MVS]CUR+
&                      ", Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Return
      Endif
    Endif
    #----- Si module achats actif -----#
    If [F:ADS]MODULE(5)=2
      #----- Ecriture Derniers mouvements appel d'offre -----#
      If [F:MVSM]LASPQHNUM<>""
        Read [PQH] PQH0=[F:MVSM]LASPQHNUM
        If !fstat
          WIFFTYP=1
          WMVTTYP=1
          WMVTDAT=[F:MVSM]LASPQHDAT
          WVCRNUM=[F:MVSM]LASPQHNUM
          WCUR   =""
          WAMT   =0
          WIFFFCY=[F:PQH]PQHFCY
          Gosub CREATION_LSM
          If GOK<1 : Return : Endif
        Endif
      Endif
      #----- Ecriture Derniers mouvements commande -----#
      If [F:MVSM]LASPOHNUM<>""
        Read [POH] POH0=[F:MVSM]LASPOHNUM
        If !fstat
          WIFFTYP=3
          WMVTTYP=3
          WMVTDAT=[F:MVSM]LASORDDAT
          WVCRNUM=[F:MVSM]LASPOHNUM
          WCUR   =[F:POH]CUR
          WAMT   =[F:POH]TTVORD
          WIFFFCY=[F:POH]POHFCY
          Gosub CREATION_LSM
          If GOK<1 : Return : Endif
        Endif
      Endif
      #----- Ecriture Derniers mouvements réception -----#
      If [F:MVSM]LASPTHNUM<>""
        Read [PTH] PTH0=[F:MVSM]LASPTHNUM
        If !fstat
          WIFFTYP=4
          WMVTTYP=4
          WMVTDAT=[F:MVSM]LASRCPDAT
          WVCRNUM=[F:MVSM]LASPTHNUM
          WCUR   =[F:PTH]CUR
          WAMT   =0
          # Issue 80368 - 2012-02-27 by VPO : pb de perf, ne passe pas toujours par l'index
          # on ajoute le hint
          #For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM
          For [PTD]PTD0 Hint Key PTD0 Where [F:PTD]PTHNUM=[F:PTH]PTHNUM
            If [F:PTD]NETCUR<>[F:PTH]CUR
              Call CONVERT([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                          [F:PTD]LINATIAMT,WAMT2,STA) From TRTDEV
            Else
              WAMT2=[F:PTD]LINATIAMT
            Endif
            WAMT+=WAMT2
          Next
          WIFFFCY=[F:PTH]PRHFCY
          Gosub CREATION_LSM
          If GOK<1 : Return : Endif
        Endif
      Endif
    Endif
    #----- Ecriture Derniers mouvements facture/avoir -----#
    If [F:MVSM]LASINVNUM<>""
      Read [PIH] PIH0=[F:MVSM]LASINVNUM
      If !fstat
        If [F:PIH]PIHTYP>2  WIFFTYP=7  Else  WIFFTYP=6 : Endif
        WMVTTYP=6
        WMVTDAT=[F:MVSM]LASINVDAT
        WVCRNUM=[F:MVSM]LASINVNUM
        WCUR   =[F:PIH]CUR
        WAMT   =[F:PIH]AMTATI
        WIFFFCY=[F:PIH]FCY
        Gosub CREATION_LSM
        If GOK<1 : Return : Endif
      Endif
    Endif
    #----- Ecriture Derniers mouvements règlement -----#
    If [F:ADS]MODULE(2)=2
      If [F:MVSM]LASPAYNUM<>""
        Read [PYH] PYH0=[F:MVSM]LASPAYNUM
        If !fstat
          WIFFTYP=8
          WMVTTYP=8
          WMVTDAT=[F:MVSM]LASPAYDAT
          WVCRNUM=[F:MVSM]LASPAYNUM
          WCUR   =[F:PYH]CUR
          WAMT   =[F:PYH]AMTCUR
          WIFFFCY=[F:PYH]FCY
          Gosub CREATION_LSM
          If GOK<1 : Return : Endif
        Endif
      Endif
    Endif
    #----- Suppression ancien enregistrement Mouvements fournisseurs -----#
    #Delete [MVS] Where BPSNUM=WBPSNUM & FINRSPFCY=WFINRSPFCY & CPY=""

Return
################################################
$RAZV7_MVS
Return
################################################
$MAJV7_MVS
Return
################################################
#---------------------------------------------------#
# Ecriture ou réécriture derniers mvts fournisseurs #
#---------------------------------------------------#
$CREATION_LSM
# Issue 108760 - 2015-06-15 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"LASTSUPMVT")= 1 : Return : Endif

Read [LSM] LSM0=[F:MVSM]BPSNUM;WIFFTYP;GSOCIETE
If !fstat
  [F:LSM]MVTTYP=WMVTTYP
  [F:LSM]MVTDAT=WMVTDAT
  [F:LSM]VCRNUM=WVCRNUM
  [F:LSM]CUR   =WCUR
  [F:LSM]AMT   =WAMT
  [F:LSM]IFFFCY=WIFFFCY
  [F:LSM]UPDUSR=GUSER
  [F:LSM]UPDDAT=date$
  Rewrite [LSM]
  If fstat
    Call ECR_TRACE("File LASTSUPMVT"-[F:MVSM]BPSNUM-num$(WIFFTYP)-GSOCIETE+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Return
  Endif
Else
  Raz [F:LSM]
  [F:LSM]BPSNUM=[F:MVSM]BPSNUM
  [F:LSM]IFFTYP=WIFFTYP
  [F:LSM]CPY   =GSOCIETE
  [F:LSM]MVTTYP=WMVTTYP
  [F:LSM]MVTDAT=WMVTDAT
  [F:LSM]VCRNUM=WVCRNUM
  [F:LSM]CUR   =WCUR
  [F:LSM]AMT   =WAMT
  [F:LSM]IFFFCY=WIFFFCY
  [F:LSM]CREUSR=GUSER
  [F:LSM]CREDAT=date$
  Write [LSM]
  If fstat
    Call ECR_TRACE("File LASTSUPMVT"-[F:MVSM]BPSNUM-num$(WIFFTYP)-GSOCIETE-WLSMFCY+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Return
  Endif
Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR51(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR51(APPLI)
End

