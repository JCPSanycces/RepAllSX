$ON_NBSFI
Onevent BEFORE_AREA Call AV_NBSFI From W1SIPAR3
Return

Subprog AV_NBSFI
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBSFI" : Gosub TIT_COL From W1SIPAR3
Endif
Gosub _AFF
End

$ON_TYP
Onevent INIT_AREA Call D_TYP(zc) From W1SIPAR3
Onevent BEFORE_INPUT Call AS_TYP(zc) From W1SIPAR3
Onevent CONTROL Call C_TYP(zc) From W1SIPAR3
Return

Subprog D_TYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_CODART
Onevent CONTROL Call C_CODART(zc) From W1SIPAR3
Onevent BEFORE_INPUT Call AS_CODART(zc) From W1SIPAR3
Return

Subprog AS_CODART(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CODART(zc) From W1SIPAR3
Gosub _AFF
End

Subprog C_CODART(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODART" : GZNUM = 0 : Endif
If !mkstat
 ## Action STD
 Call C_CODART(VALEUR) From SUBSIP
 If mkstat : GERR = 1 : GZONE = "CODART" : GZNUM = 0 : Endif
Endif
Gosub _AFF
End

Subprog S_CODART(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSIXCOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSIXCOR"
 PARMSK(1) = num$([M]TYP(nolign-1))
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELSIXCOR","SIXACTION","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_SFINUM
Onevent CONTROL Call C_SFINUM(zc) From W1SIPAR3
Onevent BEFORE_INPUT Call AS_SFINUM(zc) From W1SIPAR3
Onevent AFTER_CHANGE Gosub AMM_SFINUM From W1SIPAR3
Return

Subprog IB_SFINUM(VALEUR)
Variable Decimal VALEUR
## Action STD
Call IB_SFINUM From SUBSIP
Gosub _AFF
End

Subprog AS_SFINUM(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(11496,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call IB_SFINUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_SFINUM(zc) From W1SIPAR3
Onkey   2 Titled GBOUTS Call S_SFINUM(zc) From W1SIPAR3
Onkey 144 Titled GBOUTP Call P_SFINUM(zc) From W1SIPAR3
Gosub _AFF
End

Subprog C_SFINUM(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTNUM("SFI","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
 If !mkstat
  ## Action STD
  Call C_SFINUM(VALEUR) From SUBSIP
  If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SFINUM
Call AM_SFINUM(zc)
If !mkstat & GOBJET
 zoncou = "SFINUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SFINUM(VALEUR)
Variable Decimal VALEUR
If !mkstat & evalue("dim("+clanam([M])+"ZSFINUM)")>indice
 [M]SFINUM(indice) = VALEUR
 Affzo ZSFINUM(indice)
Endif
Gosub _AFF
End

Subprog S_SFINUM(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "SFI"
PARMSK(2) = ""
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_SFINUM(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("SFI",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_SFINUM(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("SFI",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSFINUM
Onevent BEFORE_AREA Gosub AV_ZSFINUM From W1SIPAR3
Return

$AV_ZSFINUM
Call LECTEXTRA(zc,"SFOOTINV","SHOAXX",num$([M]SFINUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_DTAREM
Onevent CONTROL Call C_DTAREM(zc) From W1SIPAR3
Onevent BEFORE_INPUT Call AS_DTAREM(zc) From W1SIPAR3
Onevent AFTER_CHANGE Gosub AMM_DTAREM From W1SIPAR3
Return

Subprog IB_DTAREM(VALEUR)
Variable Decimal VALEUR
## Action STD
Call IB_DTAREM From SUBSIP
Gosub _AFF
End

Subprog AS_DTAREM(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(11496,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call IB_DTAREM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DTAREM(zc) From W1SIPAR3
Onkey   2 Titled GBOUTS Call S_DTAREM(zc) From W1SIPAR3
Onkey 144 Titled GBOUTP Call P_DTAREM(zc) From W1SIPAR3
Gosub _AFF
End

Subprog C_DTAREM(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTNUM("SFI","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
 If !mkstat
  ## Action STD
  Call C_DTAREM(VALEUR) From SUBSIP
  If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_DTAREM
Call AM_DTAREM(zc)
If !mkstat & GOBJET
 zoncou = "DTAREM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DTAREM(VALEUR)
Variable Decimal VALEUR
If !mkstat & evalue("dim("+clanam([M])+"ZDTAREM)")>indice
 [M]DTAREM(indice) = VALEUR
 Affzo ZDTAREM(indice)
Endif
Gosub _AFF
End

Subprog S_DTAREM(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "SFI"
PARMSK(2) = ""
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_DTAREM(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("SFI",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_DTAREM(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("SFI",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDTAREM
Onevent BEFORE_AREA Gosub AV_ZDTAREM From W1SIPAR3
Return

$AV_ZDTAREM
Call LECTEXTRA(zc,"SFOOTINV","SHOAXX",num$([M]DTAREM(indice)),"") From ATEXTRA
Gosub _AFF
Return

