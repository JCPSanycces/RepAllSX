 If mkstat : GERR = 1 : GZONE = "DTAESC" : GZNUM = 1669 : Endif
 If !mkstat
  ## Action STD
  Call C_DTAESC(VALEUR) From SUBSIP
  If mkstat : GERR = 1 : GZONE = "DTAESC" : GZNUM = 1669 : Endif
 Endif
Endif
