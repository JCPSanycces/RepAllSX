zoncou = "LOCDES"
IMPENT = [M]LOCDES(indice)
WNUM = IMPENT
If varinit([M]LOCDES,indice)=0
 IMPENT = 1
Endif
If varmode([M]LOCDES,indice)=0
 Call INICOMBO(2707) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_LOCDES(IMPENT) From SUBITG
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2707,1))))
 Endif
 [M]LOCDES(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LOCDES" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LOCDES(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LOCDES" : GZNUM = 18828 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_LOCDES(IMPENT) From SUBITG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LOCDES" : GZNUM = 18828 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WNUM<>IMPENT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LOCDES(IMPENT) From SUBITG
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LOCDES" : GZNUM = 18828 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif
[M]LOCDES(indice) = IMPENT

