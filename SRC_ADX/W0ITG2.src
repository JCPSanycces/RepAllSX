Subprog SAI_NBINT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBINT
mkstat = 0
zoncou = "NBINT"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBINT From SUBITG
 GACTION = SAVACT
