#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITG2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone STOMGTCOD
mkstat = 0
zoncou = "STOMGTCOD"
indice = 0
IMPENT = [M]STOMGTCOD
WNUM = IMPENT
If varinit([M]STOMGTCOD,indice)=0
 IMPENT = 1
Endif
If varmode([M]STOMGTCOD,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_STOMGTCOD(IMPENT) From SUBITG
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]STOMGTCOD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STOMGTCOD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STOMGTCOD(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AP_STOMGTCOD(IMPENT) From SUBITG
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STOMGTCOD" : GZNUM = 2114 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_STOMGTCOD(IMPENT) From SUBITG
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "STOMGTCOD" : GZNUM = 2114 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]STOMGTCOD = IMPENT

