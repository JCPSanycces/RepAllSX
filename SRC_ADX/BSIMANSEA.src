#<AdxTL>@(#)0.0.0.0 $Revision$ Bank statement import
######################################################################################################
# Project       : Bank statement import (MT940)
# File          : BSIMANSEA
# Version       : 1.0
# Authors       : Todor Ganchovsky
# Creation Date : 2016-08-22
######################################################################################################
# Module        : Finance
# Description   : Bank statement import: manual open item search
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2016-10-05    | Bader  | U11     | EXEC: init BSIBAL, BALDUD, DEPAMT, BPRVCR fields
# 2016-10-10    | Bader  | U11     | EXEC: replace non existing variable OPENAMT by [F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR
# 2016-10-28    | Bader  | U11_01  | X3-6249 : EXEC: init new field BSISNS, new parameter (3) for bank sign
# 2016-11-08    | Bader  | U11_01  | X3-6891: BUILD_CRITERIA_1: add criterion to suppress factoring OI
######################################################################################################


$ACTION
    Case ACTION
        When "INIT"     : Gosub INIT
        When "INIT_DIA" : Gosub INIT_DIA
        When "CONTROLE" : Gosub CONTROLE
        When "EXEC"     : Gosub EXEC
        When Default
    Endcase
Return

$INIT
    Local Char LSTMCOD(GLONVCR) : LSTMCOD = PARAM(1)
    Local Integer LLIN          : LLIN = val(PARAM(2))
    Local Char LBANSNS(10)      : LBANSNS = PARAM(3)
    Local Char CRITERE1(250)
    Local Char CRITERE2(250) # for BPR

    If clalev([F:BSIDUD]) = 0 Then : Local File BSIDUD     [BSIDUD] : Endif
    If clalev([F:DUD])    = 0 Then : Local File GACCDUDATE [DUD]    : Endif
    If clalev([F:HAE])    = 0 Then : Local File GACCENTRY  [HAE]    : Endif
    If clalev([F:BPR])    = 0 Then : Local File BPARTNER   [BPR]    : Endif
    If clalev([F:BAN])    = 0 Then : Local File BANK       [BAN]    : Endif
Return

$INIT_DIA
    [M:BSIDUD]FLGORD = [V]CST_ANO
    [M:BSIDUD]BPRTYP = 1

    Gosub BUILD_CRITERIA_1
    Gosub BUILD_CRITERIA_2

    Link [F:DUD]
&   With [F:HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM,
&        [F:BPR]BPR0 = [F:DUD]BPRPAY
&   As [LNK]
    Filter [LNK] Where evalue([L]CRITERE1) and evalue([L]CRITERE2)
    [M:BSIDUD]CNT = rowcount([LNK])
    Filter [LNK]
    Affzo [M:BSIDUD]CNT
Return

$CONTROLE
    Local Integer N
    Filter [F:BSIDUD] Where [F:BSIDUD]STMCOD = [L]LSTMCOD and [F:BSIDUD]LIN = [L]LLIN
    [L]N = rowcount([F:BSIDUD])
    Filter [F:BSIDUD]

    Link [F:DUD]
&   With [F:HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM,
&        [F:BPR]BPR0 = [F:DUD]BPRPAY
&   As [LNK]

    Gosub BUILD_CRITERIA_1
    Gosub BUILD_CRITERIA_2
    Filter [LNK] Where evalue([L]CRITERE1) and evalue([L]CRITERE2)
    [M:BSIDUD]CNT = rowcount([LNK])
    Filter [LNK]

    If [M:BSIDUD]CNT + [L]N > 100 Then
        # A large number of open items is selected based on the current criteria. Only 100 can be displayed.
        [V]GMESSAGE = mess(73,7703,1)
        [V]GERR = 1
    Endif
Return

$EXEC
    Local Integer I
    Filter [F:BSIDUD] Where [F:BSIDUD]STMCOD = [L]LSTMCOD and [F:BSIDUD]LIN = [L]LLIN
    Read [F:BSIDUD]BSIDUD0 Last
    [L]I = [F:BSIDUD]LIN1 + 1
    Filter [F:BSIDUD]

    Link [F:DUD]
&   With [F:HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM,
&        [F:BPR]BPR0 = [F:DUD]BPRPAY
&   As [LNK]

    # used locally only for detecting duplications
    Local File BSIDUD [BSIDUD_]

    Gosub BUILD_CRITERIA_1
    Gosub BUILD_CRITERIA_2

    Local Integer LOK : [L]LOK = 1
    Local Integer LSELECTED, LMATCHED
    Local Decimal LDEPAMT           # discount
    Local Char LCURLEG(GLONADI)

    Trbegin [F:BSIDUD]
    For [LNK] Where evalue([L]CRITERE1) and evalue([L]CRITERE2)
        # check the open item is not already selected
        Filter [F:BSIDUD_] Where [F:BSIDUD_]STMCOD = [L]LSTMCOD and [F:BSIDUD_]LIN = [L]LLIN and [F:BSIDUD_]NUMDUD = [F:DUD]NUMDUD
        [L]LSELECTED = rowcount([F:BSIDUD_])
        Filter [F:BSIDUD_]
        # check the open item is not matched in any transaction
        Filter [F:BSIDUD_] Where [F:BSIDUD_]NUMDUD = [F:DUD]NUMDUD and [F:BSIDUD_]DUDSEL = [V]CST_AYES
        [L]LMATCHED = rowcount([F:BSIDUD_])
        Filter [F:BSIDUD_]

        If [L]LSELECTED = 0 and [L]LMATCHED = 0 Then
            # handle discount
            Raz LDEPAMT
            # check if amount in DUD equals amount in transaction
            If [F:DUD]DEP<>""
               # calculate discount
               [L]LCURLEG = [V]GCURLEG
               [V]GCURLEG = [F:BSIIP]LEG
               Call ESC_AGIO([F:DUD]DEP,[F:BSIIMPD]VALDAT-[F:BSIIP]DEPTOL,[F:DUD]DUDDAT,0,[F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR,[F:DUD]CUR,LDEPAMT,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From MODECHE
               [V]GCURLEG = [L]LCURLEG
               If LDEPAMT<>0                                      # TODO: check if not already correctly rounded!!
                  Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ  # read currency table
                  LDEPAMT = arr(LDEPAMT,[F:TCU]CURRND)            # rounding
               Endif
               If LDEPAMT < 0
                 LDEPAMT = 0
               Endif
            Endif
            Raz [F:BSIDUD]
            [F:BSIDUD]STMCOD = [L]LSTMCOD
            [F:BSIDUD]LIN = [L]LLIN
            [F:BSIDUD]LIN1 = [L]I
            [F:BSIDUD] = [F:DUD]
            [F:BSIDUD]DEPAMT = LDEPAMT
            [F:BSIDUD]BALDUD = abs([F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR)
            [F:BSIDUD]BSIBAL = abs([F:BSIDUD]BALDUD - LDEPAMT)
            [F:BSIDUD]BPRVCR = [F:HAE]BPRVCR
# Bader: 2016-10-28 X3-6249
            If LBANSNS = "C" or LBANSNS = "RD" : [F:BSIDUD]BSISNS = [F:DUD]SNS : Endif
            If LBANSNS = "D" or LBANSNS = "RC" : [F:BSIDUD]BSISNS = -[F:DUD]SNS : Endif
# Bader: 2016-10-28 X3-6249 end
            Write [F:BSIDUD]
            If fstat <> 0 Then
                [L]LOK = 0
                Break
            Endif
            [L]I += 1
        Endif
    Next
    If [L]LOK = 1 Then
        Commit
    Else
        Errbox(mess(71,7703,1))
        Rollback
    Endif

    Close Local File [BSIDUD_]

    # reload the matching screen
    [M:BSIMTC0]NBLIG = 0
    [M:BSIMTC0] = [F:BSIIMPD]
    Raz [M:BSIMTC0]TOTAMT
    Raz [M:BSIMTC0]TOTDEP
    [M:BSIMTC0]RSTAMT = [M:BSIMTC0]AMTCUR - [M:BSIMTC0]TOTAMT
    Gosub LIENS From SUBBSIMTC
    Affzo [M:BSIMTC0]
Return

$BUILD_CRITERIA_1
    [L]CRITERE1 = "[F:DUD]FLGCLE<2 & [F:DUD]CPY='" + [F:BSIIMPD]CPY + "'"

    If [F:BSIIMPD]FCYLIN <> "" Then
        [L]CRITERE1 -= "& [F:DUD]FCY='" + [F:BSIIMPD]FCYLIN + "'"
    Else
        Call LEC_BAN([F:BSIIMPD]BAN) From CPTLEC
        If fstat = 0 and [F:BAN]FCY <> "" Then
            [L]CRITERE1 -= "& [F:DUD]FCY='" + [F:BAN]FCY + "'"
        Endif
    Endif

    # X3-53530: BSI payment in currency - Corrections payment generation
    # TODO(R): currency restriction removed
    # [L]CRITERE1 -= "& [F:DUD]CUR='" + [F:BSIIMPD]CUR + "'"

    # 2016-11-08 Bader X3-6891 add criterion to suppress factoring OI
    [L]CRITERE1 -= "& [F:DUD]BPRFCT = ''"

    If [M:BSIDUD]AMTSTR <> 0 Then
        [L]CRITERE1 -= "& [F:DUD]AMTCUR>=" + num$([M:BSIDUD]AMTSTR)
    Endif
    If [M:BSIDUD]AMTEND <> 0 Then
        [L]CRITERE1 -= "& [F:DUD]AMTCUR<=" + num$([M:BSIDUD]AMTEND)
    Endif

    If [M:BSIDUD]INVNUM <> "" Then
        [L]CRITERE1 -= "& instr(1,tolower([F:DUD]NUM),tolower('" + [M:BSIDUD]INVNUM + "'))<>0"
    Endif

    If [M:BSIDUD]FLGORD = [V]CST_AYES Then
        [L]CRITERE1 -= "& [F:DUD]TYPDUD=1 & [F:DUD]DUDSTA=0 & find([F:DUD]TYP,'*SO','*PO')"
    Else
        [L]CRITERE1 -= "& [F:DUD]TYPDUD=2 & [F:DUD]DUDSTA=2"
    Endif

    If [M:BSIDUD]SRCNUM <> "" Then
        [L]CRITERE1 -= "& instr(1,tolower([F:HAE]BPRVCR),tolower('" + [M:BSIDUD]SRCNUM + "'))<>0"
    Endif
Return

$BUILD_CRITERIA_2
    [L]CRITERE2 = "[F:DUD]BPRTYP=" + num$([M:BSIDUD]BPRTYP) # always set

    If [M:BSIDUD]BPRNUM <> "" Then
        [L]CRITERE2 -= "& [F:DUD]BPRPAY='" + [M:BSIDUD]BPRNUM + "'"
#        [L]CRITERE2 -= "& instr(1,tolower([F:DUD]BPRPAY),tolower('" + [M:BSIDUD]BPRNUM + "'))<>0"
    Endif

    If [M:BSIDUD]BPNAM1 <> "" Then
        [L]CRITERE2 -= "& instr(1,tolower([F:BPR]BPRNAM(0)),tolower('" + [M:BSIDUD]BPNAM1 + "'))<>0"
    Endif

    If [M:BSIDUD]BPNAM2 <> "" Then
        [L]CRITERE2 -= "& instr(1,tolower([F:BPR]BPRNAM(1)),tolower('" + [M:BSIDUD]BPNAM2 + "'))<>0"
    Endif
# 2016-09-21 DNE INSERT BEGIN (x3-3936)
# Note: At the moment we do not support prepayment open items so we have remove
#       open items with TYP "*SO" and "*PO".
    [L]CRITERE2 -= "& !find(TYP,'*SO','*PO')"
# 2016-09-21 DNE INSERT END
Return


# Mask Management BSIMANSEA

########################################################################################################################
## Section automatically added (screen BSIMANSEA) 08/24/2016 14:39:08 (TOGAN)
########################################################################################################################
Subprog AM_AMTSTR(VALEUR)
    Variable Decimal VALEUR

    If [M:BSIDUD]AMTEND < VALEUR Then
        [M:BSIDUD]AMTEND = VALEUR
    Endif

    [M:BSIDUD]AMTSTR = VALEUR
    Gosub UPDATE_COUNT
End

Subprog C_AMTEND(VALEUR)
    Variable Decimal VALEUR
    If VALEUR < [M:BSIDUD]AMTSTR Then
        mkstat = 2
        Errbox(mess(70,7703,1))
    Endif
End

Subprog AM_AMTEND(VALEUR)
    Variable Decimal VALEUR
    [M:BSIDUD]AMTEND = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_INVNUM(VALEUR)
    Variable Char VALEUR()
    [M:BSIDUD]INVNUM = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_FLGORD(VALEUR)
    Variable Integer VALEUR
    [M:BSIDUD]FLGORD = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_SRCNUM(VALEUR)
    Variable Char VALEUR()
    [M:BSIDUD]SRCNUM = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPRTYP(VALEUR)
    Variable Integer VALEUR
    [M:BSIDUD]BPRTYP = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPRNUM(VALEUR)
    Variable Char VALEUR()
    [M:BSIDUD]BPRNUM = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPNAM1(VALEUR)
    Variable Char VALEUR()
    [M:BSIDUD]BPNAM1 = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPNAM2(VALEUR)
    Variable Char VALEUR()
    [M:BSIDUD]BPNAM2 = VALEUR
    Gosub UPDATE_COUNT
End

########################################################################################################################

$UPDATE_COUNT
    Local Char CRITERE1(250)
    Local Char CRITERE2(250)
    Gosub BUILD_CRITERIA_1
    Gosub BUILD_CRITERIA_2

    Link [F:DUD]
&   With [F:HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM,
&        [F:BPR]BPR0 = [F:DUD]BPRPAY
&   As [LNK]
    Filter [LNK] Where evalue([L]CRITERE1) and evalue([L]CRITERE2)
    [M:BSIDUD]CNT = rowcount([LNK])
    Filter [LNK]
    Affzo [M:BSIDUD]CNT
Return

########################################################################################################################

