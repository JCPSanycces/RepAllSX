#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la recherche d'une famille de compétence     Module support client aout 2000
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) = Numéro de ligne du tableau appelant
  #PARAM(2) = Contexte
  #PARAM(3) = Flag filtre client
  #PARAM(4) = Filtre client
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:PBL2]) : Local File FAMPB [PBL2] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Recherche arborescente de familles de compétence.
  [M:PBL3]TITCLA = mess(300,182,1)
  [M:PBL3]NUMLIG = val(PARAM(1))
  [M:PBL3]CONTEXT = PARAM(2)
  [M:PBL3]BPCFLG = val(PARAM(3))
  [M:PBL3]BPCPBL = PARAM(4)
  Diszo [M:PBL3]
  Gosub LOADTOPFAM
  Affzo [M:PBL3]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PBL3]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONSELECT
  #Fénêtre utilisée dans la gestion des utilisateurs
  VALEUR = [M:PBL3]PBL(nolign-1)
  Case [M:PBL3]CONTEXT
    When "MGG2"
      Affzo [M:MGG2]CRIVAL([M:PBL3]NUMLIG)
    When "SRE75"
      Affzo [M:SRE7]PBL([M:PBL3]NUMLIG)
    When "SRE720"
      Affzo [M:SRE7]SREPBLGRP
    When "SOL1"
      Affzo [M:SOL1]PBLGRP
    When "SRE3"
      Affzo [M:SRE3]PBLGRP([M:PBL3]NUMLIG)
      #SRE75 = Demandes de services Couverture par parc
      #SRE720 = Demandes de services Couverture globale
      #SOL1 = Création de solution
      #SRE3 = Recherche de solution
    When "SOL1"
      Affzo [M:SOL1]PBLGRP
    When "SRE3"
      Affzo [M:SRE3]PBLGRP([M:PBL3]NUMLIG)       #Recherche de solution
    When Default
      If GABREV = "CON" Then
        #Contrats de service
        Affzo [M:CONF]PBLGRPCOV([M:PBL3]NUMLIG)
      Elsif GABREV = "COT" Then
        #Modèles de contrats de service
        Affzo [M:CONF]PBLGRPCOV([M:PBL3]NUMLIG)
      Elsif GABREV = "QUE" Then
        #Queue
        Affzo [M:QUE2]PBLGRP
      Elsif GABREV = "BPR" Then
        #Tiers
        Affzo [M:PRX1]PBL([M:PBL3]NUMLIG)
      Elsif GABREV = "PBL" Then
        #Familles de compétences
        Affzo [M:PBL0]PAEGRPNUM
      Elsif GABREV = "PDB" Then
        #Débits de point
        Affzo [M:PDB0]PBL
      Elsif GABREV = "SET" Then
        #Modèle de demande de service
        Affzo [M:SET1]PBL
      Endif
  Endcase
  FIN = 1
Return

#########################################################
$LOADTOPFAM
Local Integer ILIGNE

  Raz [M:PBL3]NBPBL
  Raz [M:PBL3]PBL
  ILIGNE = 0
  Gosub RAZ_PBL3
  Effzo [M:PBL3]5
  Affzo [M:PBL3]1-99
  If [M:PBL3]CHOIX = "" Then
    Case [M:PBL3]BPCFLG
      When 0
        #Compétences hors client
        Filter [PBL] Where [F:PBL]PAEGRPNUM = "" and [F:PBL]PBLBPC = ""
      When 1
        #Compétences tous clients
        Filter [PBL] Where [F:PBL]PAEGRPNUM = ""
      When 2
        #Compétence client
        If [M:PBL3]BPCPBL <> "" Then
          Filter [PBL] Where [F:PBL]PAEGRPNUM="" and([F:PBL]PBLBPC=[M:PBL3]BPCPBL or [F:PBL]PBLBPC="")
        Else
          Filter [PBL] Where [F:PBL]PAEGRPNUM="" and [F:PBL]PBLBPC=""
        Endif
    Endcase
  Else
    Filter [PBL] Where [F:PBL]PAEGRPNUM = [M:PBL3]CHOIX
  Endif
  For [PBL]
    [M:PBL3]PBL(ILIGNE) = [F:PBL]NUM
    [M:PBL3]PARENT(ILIGNE) = [F:PBL]PAEGRPNUM
    Filter [PBL2] Where [F:PBL2]PAEGRPNUM = [F:PBL]NUM
    NBENREG = rowcount([PBL2])
    Filter [PBL2] 
    If NBENREG > 0 Then
      [M:PBL3]FILLE(ILIGNE) = 1
      [M:PBL3]ARBORES(ILIGNE) = "+"
    Else
      [M:PBL3]FILLE(ILIGNE) = 0
      [M:PBL3]ARBORES(ILIGNE) = "-"
    Endif       
    ILIGNE += 1
  Next
  Filter [PBL]
  [M:PBL3]NBPBL = ILIGNE
Return

##########################################################################################################
$RAZ_PBL3
  Raz [M:PBL3]NBPBL
  Raz [M:PBL3]ARBORES
  Raz [M:PBL3]PARENT
  Raz [M:PBL3]FILLE
  Raz [M:PBL3]PBL
Return
