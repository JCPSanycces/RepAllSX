#<AdxTL>@(#)12.0.0.0 $Revision$
########################################################################################################## 
## INVDACPAR   : Création de transactions Tiers
## BANK        : MAJ table BANK
## TABEXPENS   : MAJ Code frais
## GACCDENCOD  : MAJ destination comptable  
## FACTOR      : Création des codes comptables associés au Factor
## ADI313      : Transfert de données ADI  de V5 (327) vers V6 (313)
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
# Création  INVDACPAR   (Transaction tiers)
##-------------------------------------------------------------------------------------------------------#
$INVDACPAR
Call ECR_TIME(mess(81,125,1)-": INVDACPAR") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".GACM"       [GCM]   # Modèle comptable
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]   # Sociétés
Local File =[F:ADS]DOSSIER+".INVDACPAR"  [IDP]   # Transaction

Local Integer TYPDOC

Filter [CPY] Where CPYLEGFLG=2

Trbegin [IDP]
For [CPY]

 Read [F:GCM]GCM0 = [F:CPY]ACM
 For TYPDOC=1 To len(mess(0,2651,1))
  Raz [F:IDP]
  [F:IDP]CPY = [F:CPY]CPY
  [F:IDP]TYP = [L]TYPDOC
  For I=0 To dim([F:GCM]LED)-1
   If [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2 
    [F:IDP]NBRLED += 1
    [F:IDP]LEDTYP([F:IDP]NBRLED-1) = I+1
    If find([F:IDP]LEDTYP([F:IDP]NBRLED-1),[F:GCM]GENLEDTYP,[F:GCM]ANALEDTYP)
     [F:IDP]ACCDACFLG([F:IDP]NBRLED-1) = 2
     If [F:IDP]LEDTYP([F:IDP]NBRLED-1) = [F:GCM]GENLEDTYP
      [F:IDP]DAC([F:IDP]NBRLED-1) = 0
     Elsif [F:IDP]LEDTYP([F:IDP]NBRLED-1) = [F:GCM]ANALEDTYP
      [F:IDP]DAC([F:IDP]NBRLED-1) = 10
     Endif
    Else
     [F:IDP]ACCDACFLG([F:IDP]NBRLED-1) = 1
    Endif
   Endif
  Next I
  Write [F:IDP]
  If fstat
   Call ERREUR("INVDACPAR"-[F:IDP]CPY-num$([F:IDP]TYP),1) From DOSDIC
  Endif
 Next TYPDOC
Next
Commit
Filter [CPY]
Close Local File [GCM],[CPY],[IDP]
Return 


##-------------------------------------------------------------------------------------------------------#
# Mise à jour BANK (Banque)
##-------------------------------------------------------------------------------------------------------#
$BANK

Local File =[F:ADS]DOSSIER+".BANK" [BAN]

Call ECR_TIME(mess(81,125,1)-": BANK") From DOSSUB : # maj table

Trbegin [BAN]

 GOK = 1

 For [BAN]BAN0
  [F:BAN]COA    = PLGEN
  [F:BAN]UPDUSR = GUSER
  [F:BAN]UPDDAT = date$
  Rewrite [BAN]
  If fstat
   Call ERREUR("BANK"-[F:BAN]BAN,1) From DOSDIC
  Endif
 Next

Commit

Close Local File [BAN]

Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour TABEXPENS (code frais) :  AJOUT des axes analytiques
##-------------------------------------------------------------------------------------------------------#
$TABEXPENS
Local File =[F:ADS]DOSSIER+".TABEXPENS"  [TES]

Call ECR_TIME(mess(81,125,1)-": TABEXPENS") From DOSSUB : # maj table


Trbegin [TES]

 GOK = 1
 For [TES]TES0

  For I=1 To [L]MIGGOPTCANA
   [F:TES]DIE(I-1) = "AX"+num$(I)
  Next
  [F:TES]NBRCCE = [L]MIGGOPTCANA
  [F:TES]UPDUSR = GUSER
  [F:TES]UPDDAT = date$
  Rewrite [TES]
  If fstat
   GOK = 0 : Call ERREUR("TABEXPENS"-[F:TES]CODEXP,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  ## Bug 52812
  #If dim([F:TES]DES)>0
  # Call MAJTEXTRA([F:TES]DES,"TABEXPENS","DESTRA",[F:TES]CODEXP,"") From CPTMAJ30
  #Endif
  If dim([F:TES]DESEXP)>0
   Call MAJTEXTRA([F:TES]DESEXP,"TABEXPENS","DESTRA",[F:TES]CODEXP,"") From CPTMAJ30
  Endif
  ## Fin bug 52812
  If dim([F:TES]DESSHO)>0
   Call MAJTEXTRA([F:TES]DESSHO,"TABEXPENS","SHOTRA",[F:TES]CODEXP,"") From CPTMAJ30
  Endif

 Next

Commit

Close Local File [TES]
Return



##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCDENCOD  (destination comptable) 
##-------------------------------------------------------------------------------------------------------#
$GACCDENCOD
Local File =[F:ADS]DOSSIER+".GACCDENCOD"  [CDA]
Local File =[F:ADS]DOSSIER+".GACCCODE"    [CAC]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]


Call ECR_TIME(mess(81,125,1)-": GACCDENCOD") From DOSSUB : # maj table

Trbegin [CDA],[CAC]

 GOK = 1
 For [CDA]CDA0

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:CDA]DES)>0
   Call MAJTEXTRA([F:CDA]DES,"GACCDENCOD","DESTRA",[F:CDA]COD,"") From CPTMAJ30
  Endif
  If dim([F:CDA]DESSHO)>0
   Call MAJTEXTRA([F:CDA]DESSHO,"GACCDENCOD","SHOTRA",[F:CDA]COD,"") From CPTMAJ30
  Endif

  # Mail du 28/10/08 EquPdt => créer de manière auto si possible. 
  # Quand on avait un compte dans la zone ACOMPTE avant : 
  #   - on va créer maintenant un code comptable de code le n° du compte (et d’intitulé l’intitulé du compte) 
  #     -   le positionner dans la ligne client si collectif de type client. 
  #     ou
  #     -   le positionner dans la ligne fournisseur si collectif de type fournisseur. 

  # Pour le cas de la destination Banque/compte où on renseigne COMPTE,
  #   - idem création d’un code comptable de code le n° du compte (et d’intitulé le n° du compte)
  #   -  et si la destination est de type Dépense (comme les frais) on met le compte sur la ligne 1 du code comptable.

  # Zone ACOMPTE V5 renseignée => Création d'un code comptable
  If [CDA]ACCBPR<>""
   Read [CAC]CAC0 = 14;[F:CDA]ACCBPR
   If fstat   
    Raz [CAC]
    [F:CAC]COA = PLGEN
    Gosub WRI_CAC_BPR
    Gosub WRI_CAC
    If PLIAS<>""
     Raz [CAC]
     [F:CAC]COA = PLIAS
     Gosub WRI_CAC_BPR
     Gosub WRI_CAC
    Endif
   Endif
  Endif

  # Zone COMPTE V5 renseignée => Création d'un code comptable
  If [CDA]ACC<>""
   Read [CAC]CAC0 = 14;[F:CDA]ACC
   If fstat   
    Raz [CAC]
    [F:CAC]COA = PLGEN
    Gosub WRI_CAC_ACC
    Gosub WRI_CAC
    If PLIAS<>""
     Raz [CAC]
     [F:CAC]COA = PLIAS
     Gosub WRI_CAC_ACC
     Gosub WRI_CAC
    Endif
   Endif
   [F:CDA]ACCCOD = [CDA]ACC
   Rewrite [CDA]
   If fstat
    GOK = 0 : Call ERREUR("GACCDENCOD 14"-[F:CDA]ACCCOD,1) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [CDA], [CAC], [GAC]
Return


$WRI_CAC_BPR
[F:CAC]ACCCOD = [F:CDA]ACCBPR
# Lecture du compte V5
#  AUZBPR(0)=2 : Compte de type Client
#  AUZBPR(1)=2 : Compte de type Fournisseur
Read [F:GAC]GAC0 = [F:CDA]ACCBPR
If !fstat
 If [F:GAC]AUZBPR(0)=2
  [F:CAC]ACC(2) = [F:CDA]ACCBPR    # Ligne Compte d'accompte client
 Else
  [F:CAC]ACC(3) = [F:CDA]ACCBPR    # Ligne Compte d'accompte fournisseur
 Endif
Endif 
Return

$WRI_CAC_ACC
[F:CAC]ACCCOD = [F:CDA]ACC
Read [F:GAC]GAC0 = [F:CDA]ACC  # libellé
# ACCSNS  = 1  # Sens du règlement
# ACCSNS  = 2  # Dépense
# ACCSNS  = 3  # Recette
If [F:CDA]ACCSNS = 3
 [F:CAC]ACC(0) = [F:CDA]ACC    # Ligne GAIN
Else
 [F:CAC]ACC(1) = [F:CDA]ACC    # Ligne PERTE
Endif
Return

$WRI_CAC
[F:CAC]TYP    = 14
[F:CAC]TYPCAR = num$([F:CAC]TYP)
If dim([F:CAC]DES)>0 & dim([F:GAC]DES)>0  : [F:CAC]DES = [F:GAC]DES : Endif
If dim([F:CAC]DESSHO)>0 & dim([F:GAC]DESSHO)>0  : [F:CAC]DESSHO = [F:GAC]DESSHO : Endif
[F:CAC]CREUSR = GUSER
[F:CAC]CREDAT = date$
[F:CAC]CRETIM = time
[F:CAC]UPDUSR = GUSER
[F:CAC]UPDDAT = date$
[F:CAC]UPDTIM = time
Write [CAC]
If fstat
 GOK = 0 : Call ERREUR("GACCCODE"-[F:CAC]ACCCOD-[F:CAC]COA,1) From DOSDIC
Endif
# Gestion des intitulés (V6 : Libellé traduisible)
# Pour les intitulés des codes comptables, seuls TYP+ACCCOD
If dim([F:CAC]DES)>0
 Call MAJTEXTRA([F:CAC]DES,"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
Endif
If dim([F:CAC]DESSHO)> 0
 Call MAJTEXTRA([F:CAC]DESSHO,"GACCCODE","SHOTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
Endif
Return



##-------------------------------------------------------------------------------------------------------#
# FACTOR : Création des codes comptables associé au Factor FACTOR/GACCCODE
##-------------------------------------------------------------------------------------------------------#
$FACTOR
Local File =[F:ADS]DOSSIER+".FACTOR"     [FCT]
Local File =[F:ADS]DOSSIER+".GACCCODE"   [CAC]
Local File =[F:ADS]DOSSIER+".GACCOUNT"   [GAC]

Call ECR_TIME(mess(81,125,1)-": FACTOR") From DOSSUB : # maj table

Trbegin [FCT],[CAC]

 GOK = 1
 For [FCT]FCT0

  # => Création d'un code comptable
  # 
  Read [CAC]CAC0 = 17;[F:FCT]FCTCOD
  If fstat   
   Raz [CAC]
   [F:CAC]COA = PLGEN
   Gosub WRI_CAC_FCT
   If PLIAS<>""
    Raz [CAC]
    [F:CAC]COA = PLIAS
    Gosub WRI_CAC_FCT
   Endif
  Endif
  [F:FCT]ACCCOD = [F:FCT]FCTCOD
  Rewrite [FCT]
  If fstat
   GOK = 0 : Call ERREUR("FACTOR"-[F:FCT]FCTCOD,1) From DOSDIC
  Endif
 Next
Commit

Close Local File [FCT], [CAC], [GAC]
Return

$WRI_CAC_FCT
[F:CAC]TYP    = 21
[F:CAC]TYPCAR = num$([F:CAC]TYP)
[F:CAC]ACCCOD = [F:FCT]FCTCOD

[F:CAC]ACC(0) = [F:FCT]FCTCPTNUM
If [F:FCT]COLBPC<>""
 Read [F:GAC]GAC1 = [F:FCT]COLBPC
 If !fstat
  [F:CAC]ACC(1) = [F:GAC]ACC
 Endif
Endif
[F:CAC]ACC(2) = [F:FCT]FCTBPCACC

If dim([F:CAC]DES)>0 & dim([F:FCT]FCTNAM)>0    : [F:CAC]DES    = [F:FCT]FCTNAM : Endif
If dim([F:CAC]DESSHO)>0 & dim([F:FCT]SALCOD)>0 : [F:CAC]DESSHO = [F:FCT]SALCOD : Endif
[F:CAC]CREUSR = GUSER
[F:CAC]CREDAT = date$
[F:CAC]CRETIM = time
[F:CAC]UPDUSR = GUSER
[F:CAC]UPDDAT = date$
[F:CAC]UPDTIM = time
Write [CAC]
If fstat
 GOK = 0 : Call ERREUR("GACCCODE"-[F:CAC]ACCCOD-[F:CAC]COA,1) From DOSDIC
Endif
# Gestion des intitulés (V6 : Libellé traduisible)
# Pour les intitulés des codes comptables, seuls TYP+ACCCOD
If dim([F:CAC]DES)>0
 Call MAJTEXTRA([F:CAC]DES,"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
Endif
If dim([F:CAC]DESSHO)> 0
 Call MAJTEXTRA([F:CAC]DESSHO,"GACCCODE","SHOTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
Endif
Return




##-------------------------------------------------------------------------------------------------------#
# Transfert de données : ADI  de V5 (327) vers V6 (313)   F88878
##-------------------------------------------------------------------------------------------------------#
$ADI313
Call ECR_TIME(mess(81,125,1)-": ATABDIV 313") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI]   # Table diverse
Local File =[F:ADS]DOSSIER+".ATABDIV"  [ADI1]  # Table diverse
Local File =[F:ADS]DOSSIER+".ATEXTRA"  [AXX]


# Suppression ADI 313 
Trbegin [ADI]
 Delete [ADI] Where NUMTAB=313
 If fstat
  Call ERREUR("ATABDIV-313",3) From DOSDIC
 Endif
 Delete [AXX] Where CODFIC="ATABDIV" & IDENT1="313"
 If fstat
  Call ERREUR("ATEXTRA-ATABDIV-313",3) From DOSDIC
 Endif
Commit

# Transfert des données
Trbegin [ADI]
For [ADI1]Where NUMTAB=327
 [F:ADI]=[F:ADI1]
 [F:ADI]NUMTAB = 313
 Write [F:ADI]
 If fstat
  Call ERREUR("ATABDIV 313"-[F:ADI]CODE,1) From DOSDIC
 Endif

 # Transfert des textes
 Update [AXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="327" & IDENT2=[F:ADI]CODE With IDENT1="313"
 If fstat
  Call ERREUR("ATEXTRA-ATABDIV-LNGDES"-[F:ADI]CODE,2) From DOSDIC
 Endif
 Update [AXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="327"  & IDENT2=[F:ADI]CODE With IDENT1="313"
 If fstat
  Call ERREUR("ATEXTRA-ATABDIV-SHODES"-[F:ADI]CODE,2) From DOSDIC
 Endif

Next
Commit

Close Local File [ADI],[ADI1], [AXX]
Return
