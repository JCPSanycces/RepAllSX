#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque CONSSHO1
#############################################################################
#                        Consultation                                       #
#                        OF en rupture                                      #
#                                                                GPAO 10.00 #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site                                                                 #
# 2  = article                                                              #
# 3  = pièce                                                                #
# 4  = date début                                                           #
# 5  = affaire                                                              #
# 6  = tiers                                                                #
# 7  = tri                                                                  #
#                      1 - date                                             #
#                      2 - OF                                               #
#                      3 - article                                          #
############################################################################# 
Local Char PARAM(20)(1..10)
PARAM(1) = "INO"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = "1"
Call GCONSULT("SHO","",PARAM) From GCONSULT
End

#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$OUVRE
Local Integer WSRT,WRET
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)

If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif

Gosub DEFCRIT
If !find([M:CSHO]TRI,1,2,3) : [M:CSHO]TRI = 1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSSHO"
Return 

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:SHO1]MFGFCY = PARAM(I) : Endif
                 Endif
        When 2 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat 
                         [M:SHO1]ITMREFSTR = PARAM(I)
                         [M:SHO1]ITMREFEND = PARAM(I) 
                     Endif
                 Endif
        When 3 : # Pièce
                 If PARAM(I) <> ""
                     [M:SHO1]VCRNUMSTR = PARAM(I) 
                     [M:SHO1]VCRNUMEND = PARAM(I) 
                 Endif
        When 4 : # date début
                 If PARAM(I) <> ""    
                     If instr(1,PARAM(I),"/")
                         [M:SHO1]STRDATSTR = "["+PARAM(I)+"]"
                         [M:SHO1]STRDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:SHO1]STRDATSTR = PARAM(I)
                         [M:SHO1]STRDATEND = PARAM(I)
                     Endif
                 Endif
        #CHECK UNUSED_BEGIN
        When 5 : # Affaire
                 If PARAM(I) <> ""
                     [M:SHO1]PJTNUMSTR = PARAM(I) 
                     [M:SHO1]PJTNUMEND = PARAM(I) 
                 Endif
        When 6 : # Tiers
                 If PARAM(I) <> ""
                     [M:SHO1]BPCNUMSTR = PARAM(I) 
                     [M:SHO1]BPCNUMEND = PARAM(I) 
                 Endif
        #CHECK UNUSED_END
        When 7 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 3  : WSRT = 1 : Endif
                     [M:CSHO]TRI = WSRT
                 Endif    
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CSHO) vers le masque 0 (SHO1)
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:SHO1]MFGFCY = ""  : NBLU = 0 : Return : Endif
If PARAM(7) = "" : PARAM(7) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT 
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT  
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CSHO]TRI
      When 1 : # tri par date
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key CLE=[F:MFI]STRDAT
      When 2 : # tri par OF
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key MFI0
      When 3 : # tri par article
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key CLE=[F:MFI]ITMREF
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CSHO]TRI
      When 1 : # tri par date
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key CLE=[F:MFI]STRDAT Desc
      When 2 : # tri par OF
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key MFI0 Desc
      When 3 : # tri par article
               Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&                         Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3) &
&                               evalue(CUSFLT) 
&                         Order By Key CLE=[F:MFI]ITMREF Desc
    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:SHO2] : Endif

# lecture 
$BOUCLE

For [MFX]
  If NBLU = 1
     If CHGPAG = 2 | CHGPAG = -2 : Raz [M:SHO2] : Endif
     NBLU = 2
  Endif

  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
     NOL    += 1 
     If NOL=0 
         DEBNUM = [F:MFI]MFGNUM 
         DEBDAT = [F:MFI]STRDAT
         DEBITM = [F:MFI]ITMREF
     Endif
     FINNUM = [F:MFI]MFGNUM
     FINDAT = [F:MFI]STRDAT
     FINITM = [F:MFI]ITMREF
  Else
     If NOL <= 0 : RETOUR = 2 : Break : Endif
     NOL    -= 1 
     If NOL = MAXLIG-1 
         FINNUM = [F:MFI]MFGNUM 
         FINDAT = [F:MFI]STRDAT
         FINITM = [F:MFI]ITMREF
     Endif
     DEBNUM = [F:MFI]MFGNUM 
     DEBDAT = [F:MFI]STRDAT
     DEBITM = [F:MFI]ITMREF
  Endif
  nolign = NOL+1

  Gosub FILLTAB

$SUIV  
Next

Return

#############################################################################
# Chargements spéciaux
$FILLTAB 
[M:SHO2] = [F:MFG]
[M:SHO2] = [F:MFI]
If [F:ITM]ITMREF <> [F:MFI]ITMREF
    Read [ITM]ITM0 = [F:MFI]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
#[M:SHO2]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SHO2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Return


#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

# llc 05.02 14236 + 03.05 29305
CRITERE1 = "[F:MFG]MFGSTA=1&[F:MFG]SHTMATNBR>=1&[F:MFG]MFGTRKFLG<5&[F:MFG]MATCLENBR<[F:MFG]MATLINNBR"    

# site
If [M:SHO1]MFGFCY <> ""
   CRITERE = "[F:MFG]MFGFCY=[M:SHO1]MFGFCY"         
   Gosub LOAD_CRITERE2
Endif

# article
If [M:CSHO]ITMREFSTR <> ""
    CRITERE = "[F:MFI]ITMREF>=[M:CSHO]ITMREFSTR"    
    Gosub LOAD_CRITERE2
Endif
If [M:CSHO]ITMREFEND <> ""
    CRITERE = "[F:MFI]ITMREF<=[M:CSHO]ITMREFEND"            
    Gosub LOAD_CRITERE2
Endif

# OF
# sr 10.01 Correction de MFGNUMSTR en VCRNUMSTR demande 10877
If [M:CSHO]VCRNUMSTR <> ""
   CRITERE = "[F:MFG]MFGNUM>=[M:CSHO]VCRNUMSTR"         
   Gosub LOAD_CRITERE2
Endif
If [M:CSHO]VCRNUMEND <> ""
   CRITERE = "[F:MFG]MFGNUM<=[M:CSHO]VCRNUMEND"
   Gosub LOAD_CRITERE2
Endif

# date
If [M:CSHO]STRDATSTR <> [0/0/0]
   CRITERE = "[F:MFI]STRDAT>=[M:CSHO]STRDATSTR"        
   Gosub LOAD_CRITERE2
Endif
If [M:CSHO]STRDATEND <> [0/0/0]
   CRITERE = "[F:MFI]STRDAT<=[M:CSHO]STRDATEND"
   Gosub LOAD_CRITERE2
Endif

# affaire
If [M:CSHO]PJTSTR <> ""
    CRITERE = "[F:MFI]PJT>=[M:CSHO]PJTSTR"        
    Gosub LOAD_CRITERE3
Endif
If [M:CSHO]PJTEND <> ""
    CRITERE = "[F:MFI]PJT<=[M:CSHO]PJTEND"
    Gosub LOAD_CRITERE3
Endif

# Tiers
If [M:CSHO]BPCNUMSTR <> ""
    CRITERE = "[F:MFI]BPCNUM>=[M:CSHO]BPCNUMSTR"        
    Gosub LOAD_CRITERE3
Endif
If [M:CSHO]BPCNUMEND <> ""
    CRITERE = "[F:MFI]BPCNUM<=[M:CSHO]BPCNUMEND"
    Gosub LOAD_CRITERE3
Endif

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CSHO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
   When 2 : # suite
     Case [M:CSHO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT>FINDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM>FINNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF>FINITM"
           Gosub LOAD_CRITERE3
     Endcase
   When -2 : # retour
     Case [M:CSHO]TRI
       When 1 : # tri par date
           CRITERE = "[F:MFI]STRDAT<DEBDAT"
           Gosub LOAD_CRITERE3
       When 2 : # tri par OF
           CRITERE = "[F:MFI]MFGNUM<DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:MFI]ITMREF<DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
Endcase
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif

Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0 
    CRITERE1 += "("
Else 
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE  
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE  
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE  
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return



############################################################
# Etiquettes
############################################################

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFSTR = ""     : [M]ITMREFEND = VALEUR : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Endif
End

########################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMSTR = ""     : [M]VCRNUMEND = VALEUR  : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR  : Endif
End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]STRDATEND = eomonth(VALEUR) : Endif
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M]PJTSTR = ""     : [M]PJTEND = VALEUR : Endif
If [M]PJTEND < VALEUR : [M]PJTEND = VALEUR : Endif
End

########################################
Subprog AM_BPCNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]BPCNUMSTR = ""     : [M]BPCNUMEND = VALEUR : Endif
If [M]BPCNUMEND < VALEUR : [M]BPCNUMEND = VALEUR : Endif
End

########################################
Subprog AS_TRI(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog S_BPCNUMSTR(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog S_BPCNUMEND(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog B1_NBLIG
End

########################################
Subprog AS_NBLIG
End

# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"SHO") From SUBGTC

End

