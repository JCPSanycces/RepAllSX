#<AdxTL>@(#)11.0.0.0 $Revision$
#---------------------------------------------------------------------------
# TRTRETVAL : Validation rétroactivité
#             Appel "direct" pour validation de type 3 - Extourne
#             => saisie fenetre
#             Appel par subprog sur rétroactivité de type 1 ou 2
#             => subprog RETRO
#---------------------------------------------------------------------------
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = ""
PARBOUT(2) = "00000000"
PARBOUT(3) = "00000000"
FLGEXE = 1
GACTION = "TRTRETVAL"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"TRTRETVAL","TRTRETVAL","XYTRTRETVAL") From GSAISIE
End

$ACTION
# Call MESSAGE("Action :"-[L]ACTION) From GESECRAN
Case [L]ACTION
    When "DEBUT"
        Gosub DEBUT
    When "OUVRE"
        Gosub OUVRE
    When "OK"
        Gosub TRAITEMENT
    When "FIN"
        Gosub FIN
Endcase
Return

$DEBUT

# Récupération de paramètres éventuels
[L]WRETNUM = [L]PARAM(1)
[L]WDATEXT = [L]PARAM(2)
[L]WDATPAY = [L]PARAM(3)

If [L]WRETNUM <> ""
    [M:DIA]RETNUM = [L]WRETNUM
    Diszo [M:DIA]RETNUM
Endif
[M:DIA]DATEXT = [L]WDATEXT-5
[M:DIA]DATPAY = [L]WDATPAY-3

[M:DIA]FLGIMP = 1
Grizo [M:DIA]FDR
Grizo [M:DIA]PRT

Affzo [M:DIA]

Return

$OUVRE

#---------------------------------------------------------
# Ouverture des tables reprise sur EXTPAY pour l'extourne
#---------------------------------------------------------
Gosub OUVRE From WPDEFTABLE
If clalev([F:VEP])=0  : Local File VALEMP    [VEP]  : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:HSP2])=0 : Local File HISTOPAYE [HSP2] : Endif
If clalev([F:HRSDP])=0  : Local File SOLDPAY   [HRSDP]  : Endif
If clalev([F:VAN])=0  : Local File VALANA    [VAN]  : Endif
If clalev([F:CUM])=0  : Local File CUMUL     [CUM]  : Endif
If clalev([F:RUB])=0  : Local File RUBRIQUE  [RUB]  : Endif
If clalev([F:VLA])=0  : Local File VALEUR    [VLA]  : Endif
If clalev([F:ACC])=0  : Local File ACCES     [ACC]  : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif
If GINTMT=1
 If clalev([F:PSN])=0  : Local File PRESTATION[PSN]  : Endif
Endif
If clalev([F:VEP2])=0 : Local File VALEMP    [VEP2] : Endif
If clalev([F:HRCTR])=0: Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:ID])=0   : Local File EMPLOID   [ID]   : Endif
#------------------------------------
# Plus nos fichiers de rétroactivité
#------------------------------------
If clalev([F:RET])=0 : Local File RETRO    [RET] : Endif
If clalev([F:REC])=0 : Local File RETROCAL [REC] : Endif
If clalev([F:RER])=0 : Local File RETRORUB [RER] : Endif
If clalev([F:RES])=0 : Local File RETROSAL [RES] : Endif
If clalev([F:REV])=0 : Local File RETROVRA [REV] : Endif
If clalev([F:RVL])=0  : Local File RETROVAL [RVL]    : Endif
If clalev([F:HRHSR])=0  : Local File HISTOREGUL [HRHSR]  : Endif


If clalev([F:RESL])=0  : Local File RETROSAL  [RESL]  : Endif
If clalev([F:VEPL])=0  : Local File VALEMP    [VEPL]  : Endif
If clalev([F:HSPL])=0  : Local File HISTOPAYE [HSPL]  : Endif
If clalev([F:VANL])=0  : Local File VALANA    [VANL]  : Endif
If clalev([F:VLAL])=0  : Local File VALEUR    [VLAL]  : Endif
If clalev([F:BULL])=0  : Local File BULCAL    [BULL]  : Endif
If clalev([F:TCA])=0   : Local File TABCOUAFF [TCA]   : Endif


Local Integer NBMAXBUL, NBMAXBUL_EDITION
[L]NBMAXBUL = 50        : # Nb maxi de bulletin traité pour un salarié
[L]NBMAXBUL_EDITION = [L]NBMAXBUL * 100    : # Arbitraire ....

Local Char WRETNUM([V]GLONRET)
Local Date WDATEXT, WDATPAY, WSTRDAT, WENDDAT, WCTRDAT, WDATREG
Local Char TBUL_A_EXTOURNER(type([F:VEP]BUL)-10)([L]NBMAXBUL)
Local Char TBUL_EXTOURNE(type([F:VEP]BUL)-10)([L]NBMAXBUL)
Local Char TBUL_NOUVEAU(type([F:VEP]BUL)-10)([L]NBMAXBUL)
Local Char TBUL_EDITION(type([F:VEP]BUL)-10)([L]NBMAXBUL_EDITION)
Local Char WBUL(type([F:VEP]BUL)-10), WNEWBUL(type([F:VEP]BUL)-10)
Local Integer WCALPAY, WPRESTAT(1..100)

Local Integer NBBUL_A_EXTOURNER, NBBUL, OK, PASAPAS, NBBUL_EDITION, EXTOURNE_CORRECTE, WRECORD

Local Char WCTRNUM([V]GLONHRCTR)
Local Char WRECTYP(1)

[L]PASAPAS = 0

# A priori variable globale à déclarer car absente dans certains cas
If dim([V]GFLGERR) < 1 : Global Integer GFLGERR : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#####################
$TRAITEMENT
Call DEBTRANS From GLOCK
[V]GOK = 1
Trbegin [VEP],[RET],[VEPL],[HSPL],[VANL],[VLAL]
Gosub TR1
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
If [L]EXTOURNE_CORRECTE = 2 & [M:DIA]FLGIMP = 2 & [L]NBBUL_EDITION > 0
  Call IMPRIME([L]TBUL_EDITION, [M:DIA]PRT, 1) From TRTRETVAL
Endif
Return

##################
$TR1
[L]WDATEXT = [M:DIA]DATEXT
[L]WDATPAY = [M:DIA]DATPAY
[L]WRETNUM = [M:DIA]RETNUM
[L]WDATREG = eomonth([M:DIA]DATPAY)

Readlock [F:RET]RET0 = [L]WRETNUM
If fstat = 1
    [V]GOK = -1
    [V]GLOCK = "$RETRO"
    Return
Elsif fstat <> 0
    # mess(201,10702,1) : Fiche de rétroactivité non trouvée
    Call ERREUR(mess(201,10702,1)-[L]WRETNUM) From GESECRAN
    Return
Endif

If [F:RET]RETTYP <> 3
    # Aie aie aie, type de retroactivité non conforme avec ce programme ( <> "extourne" )
    Return
Endif

If [F:RET]STATUT <> 2
    # Aie aie aie, on est pas "en cours"
    Return
Endif

Call RENUMLAST_BULLETIN(1,[F:RET]RETNUM,[F:RET]DATMININT)
If !GOK
 #Erreur en renumérotation des bulletins postérieurs aux extournes
 Call ERREUR(mess(226,10702,1)-"(Z)") From GESECRAN
 Return
Endif

Raz [L]NBBUL_EDITION, [L]TBUL_EDITION

[L]EXTOURNE_CORRECTE = 2

For [F:RES]RES0 Where [F:RES]RETNUM = [F:RET]RETNUM
 # Pour un salarié / contrat
 # => Récupération de tous les bulletins concernés = tous les bulletins de ce jour à la date d'effet
 #    ( cf analyse )
 Raz [L]TBUL_A_EXTOURNER, [L]NBBUL_A_EXTOURNER, [L]TBUL_EXTOURNE, [L]NBBUL, [L]WRECORD
  # Récupération du bon contrat pour prendre la date d'effet "dessus" => probleme d'analyse
  # on nous dit qu'on laisse le droit (warning) de prendre des contrats non flaggés rétroactivité
  # si on les saisit en manuel dans le tableau .... On reste sur la date d'effet de la fiche.
  #    Filter [HRCTR] Where [F:HRCTR]REFNUM = [F:RES]REFNUM & [F:HRCTR]CTRNUM = [F:RES]CTRNUM
  # &                         & [F:HRCTR]FLGRET = 2
  #    Filter [F:HRCTR]

  #DBA : On n'extourne pas des extournes\extournées et les VAR ?!?

  Filter [F:VEP] Where [F:VEP]EMP = [F:RES]REFNUM
&                    & [F:VEP]CTRNUM = [F:RES]CTRNUM
&                    & [F:VEP]STRDAT >= [F:RET]DATEFF
&                    & [F:VEP]STA > 1
&                    & [F:VEP]RVSDAT=[0/0/0] & [F:VEP]RVS<>2
&                    Order By Key CLE = [F:VEP]EMP ; [F:VEP]PYRDAT Desc ; [F:VEP]BUL Desc
  For [F:VEP]CLE
   [L]TBUL_A_EXTOURNER([L]NBBUL_A_EXTOURNER) = [F:VEP]BUL
   [L]NBBUL_A_EXTOURNER += 1
  Next
  Filter [F:VEP]

  If ! NBBUL_A_EXTOURNER
   #On ne peut pas traiter qu'une partie des salariés ; C'est ou tous ou rien...
   #Aucun bulletin de paie à traiter
   Call ERREUR([F:RES]REFNUM-[F:RES]CTRNUM-mess(99,10701,1)) From GESECRAN
   [L]EXTOURNE_CORRECTE = 1 : Break
  Endif

  # mess(202,10702,1) : Extourne
  Call OUVRE_BOITE(mess(202,10702,1), [L]NBBUL_A_EXTOURNER) From GESECRAN

  For [L]NBBUL = 0 To [L]NBBUL_A_EXTOURNER - 1
   # Extourne effective
   [L]WBUL = [L]TBUL_A_EXTOURNER([L]NBBUL)
   Raz [L]WNEWBUL
   # mess(202,10702,1) : Extourne
   Call AFF_BOITE(mess(202,10702,1)-[L]WBUL, [L]NBBUL+1, [L]OK) From GESECRAN
   Call EXTOURNE([L]WBUL, [L]WDATEXT, 0, [L]WNEWBUL,0) From EXTPAY
   If [L]WNEWBUL <> ""
    [L]TBUL_EXTOURNE([L]NBBUL) = [L]WNEWBUL
    # Finalement, on ajoute le bulletin d'extourne à la série des éléments à éditer
    [L]TBUL_EDITION([L]NBBUL_EDITION) = [L]WNEWBUL
    [L]NBBUL_EDITION += 1
   Else
    [L]EXTOURNE_CORRECTE = 1 :  Break 2
   Endif
   [L]WBUL = [L]TBUL_EXTOURNE([L]NBBUL)
   [L]WNEWBUL = [L]TBUL_EXTOURNE([L]NBBUL)
   [L]WRECTYP = "E"                            : # Bulletin d'extourne
   Gosub MEMORISE_BULLETIN
   If [V]GOK<1
    [L]EXTOURNE_CORRECTE = 1 :  Break 2
   Endif
  Next

  # On reprends les bulletins originaux mais dans le "bon" sens maintenant
  For [L]NBBUL = [L]NBBUL_A_EXTOURNER-1 To 0 Step -1
     [L]WBUL = [L]TBUL_EXTOURNE([L]NBBUL)
     # mess(203,10702,1) : Duplication
     Call AFF_BOITE(mess(203,10702,1)-[L]WBUL, [L]NBBUL+1, [L]OK) From GESECRAN

     # Fabriquer le nouveau bulletin - Quel contrat prendre ! ? , celui qui serait "flaggué"
     # rétroactivité ? , si on en a plusieurs sur la période ?
     # => Le CREPAYEXT admet un paramètre ( entre WBUL et WNEWBUL )
     # 1 : fonctionnement standard, on cherche un contrat dont date de contrat <= date de fin de période
     # 2 : fonctionnement "rétro", on cherche un contrat dont date d'effet <= date de fin de période
     Read [F:VEP]VEP5 = [L]WBUL
     [L]WSTRDAT = [F:VEP]STRDAT : [L]WENDDAT = [F:VEP]ENDDAT
     [L]WCTRNUM = [F:VEP]CTRNUM
     [L]WCTRDAT = [L]WENDDAT
     Raz [L]WNEWBUL
     #74746: remplace param [L]WBUL par [L]TBUL_A_EXTOURNER([L]NBBUL)
     Call CREPAYEXT([F:RES]REFNUM, [L]WCTRNUM,
&                        [L]WDATPAY, [L]WSTRDAT, [L]WENDDAT,
&                        [L]WDATREG, [L]WDATEXT, [L]TBUL_A_EXTOURNER([L]NBBUL), 2, [F:RES]RETNUM, [L]WNEWBUL) From SUBVEP
     If [V]GOK<1
      [L]EXTOURNE_CORRECTE = 1 :  Break 2
     Endif

     [L]TBUL_NOUVEAU([L]NBBUL) = [L]WNEWBUL

     # On mémorise les bulletins à éditer : découplé volontairement du TBUL_NOUVEAU pour
     # permettre l'édition de tous les bulletins des salariés en dehors des boucles de traitement
     # + pour envisager l'édition des bulletins d'extournes si demande : il suffira alors de charger
     # dans TBUL_EDITION tout ce que l'on souhaite éditer, voire mm de charger un bulletin plusieurs
     # fois pour avoir des doubles
     [L]TBUL_EDITION([L]NBBUL_EDITION) = [L]WNEWBUL
     [L]NBBUL_EDITION += 1
     # Recalcul du bulletin
     [L]PASAPAS = -5            : # Mode spécial rétroactivité "extourne"
                                  # Repositionne sur le bon contrat en fonction
                                  # de la date d'effet + change les variables sites, société, dossier
                                  # mais pas salarié, déjà repositionnées dans le CREPAYEXT

     Global Char GRETNUM([V]GLONRET)    : # Quelle fiche de rétroactivité traite-t-on.
     [V]GRETNUM = [F:RET]RETNUM           # Déclaration au dernier moment pour limiter la portée.
     Call PLAN([L]WNEWBUL, [L]PASAPAS, 0) From GPLAN
     Kill [V]GRETNUM                    : # On kill dans la foulée pour ne pas laisser trainer de
                                          # variable susceptible de modifier le comportement du calcul.
     If [V]GOK<1
      [L]EXTOURNE_CORRECTE = 1 : Break 2
     Endif

     [L]WRECTYP = "N"                : # Nouveau bulletin
     Gosub MEMORISE_BULLETIN
     If [V]GOK<1
      [L]EXTOURNE_CORRECTE = 1 : Break 2
     Endif
  Next
  Call FERME_BOITE() From GESECRAN
Next
If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif

Call RENUMLAST_BULLETIN(2,[F:RET]RETNUM,[F:RET]DATMININT)
If !GOK
 #Erreur en renumérotation des bulletins postérieurs aux extournes
 Call ERREUR(mess(225,10702,1)) From GESECRAN
 [L]EXTOURNE_CORRECTE = 1
Endif

If [L]EXTOURNE_CORRECTE = 2
 # Mise à jour du flag STATUT sur la fiche de rétroactivité
 [F:RET]STATUT = len(mess(0,10645,1))
 Rewrite [F:RET]
 If fstat <> 0
  [V]GOK = 0
  Call FSTA("RET") From GLOCK
  Return
 Endif
Endif

Return

##############
$AB_TR1
Rollback
Return

#############
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#Renumérotation des bulletins chronologiquement postérieurs aux extournes et bulletins de remplacement
#afin de toujours être dans le bon ordre pour éventuel recalcul de cumuls en fin d'année !
#1) On donne un trés grand n° pour être sur qu'il soit à la fin (P_TYPNUM=1)
#2) Insertion des extournes et remplacements ;
#3) Renumérotation 'propre' des bulletins posts extournes et remplacements (P_TYPNUM=2)
#############################################
Subprog RENUMLAST_BULLETIN(P_TYPNUM,P_RETNUM,P_DATMIN)
Value Integer P_TYPNUM    :#1 Numéro fictif : 2 Vrai numéro
Value Char P_RETNUM()
Value Date P_DATMIN

Local Char NUMLAST(GLONVCR)
Local Decimal TEMPO
Local Char COMPTEUR(GLONANM)
Local Integer STAT

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif

GOK=1
For [F:RESL]RES0 Where [F:RESL]RETNUM = P_RETNUM
 Filter [F:VEPL] Where [F:VEPL]EMP = [F:RESL]REFNUM
&                    & [F:VEPL]CTRNUM = [F:RESL]CTRNUM & [VEPL]STA<2
&                    & [F:VEPL]PYRDAT >= P_DATMIN
 For [F:VEPL]VEP0

  If [F:VEPL]BUL=[L]NUMLAST : Break : Endif

  Case P_TYPNUM
   When 1 :
    If [L]NUMLAST=""
      [L]TEMPO=val(string$(GLONVCR-1,"8"))
    Else
      [L]TEMPO+=1
    Endif
    [L]NUMLAST="Z"+num$([L]TEMPO)

   When Default :
    Call LECTURE("FCY",[F:VEPL]FCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GSOCIETE=[F:CPY]CPY
    If GNBLEG = 1
      GCURLEG = GDOSLEG
    Else
      If dim([F:CPY]LEG)>0
        GCURLEG =[F:CPY]LEG
      Endif
    Endif

    Call LECTCA(15,STAT) From SUBTCA
    If !STAT
      GMESSAGE = mess(81,134,1)
      GOK = 0 : Break 2
    Else
      COMPTEUR= [F:TCA]CODNUM(4)
    Endif
    Call NUMERO(COMPTEUR,[F:VEPL]FCY,[F:VEPL]PYRDAT,[F:VEPL]CTRNUM,[L]NUMLAST,STAT) From SUBANM
    If STAT : GOK=0 : Break 2 : Endif
   Endcase

   Update [VANL] Where BUL=[VEPL]BUL With BUL=[L]NUMLAST
   Update [VLAL] Where BUL=[VEPL]BUL With BUL=[L]NUMLAST
   Update [HSPL] Where BUL=[VEPL]BUL With BUL=[L]NUMLAST
   Update [BULL] Where BUL=[VEPL]BUL With BUL=[L]NUMLAST

   [VEPL]BUL=[L]NUMLAST
   Rewrite [VEPL]
   If fstat <> 0
    [V]GOK = 0
    Call FSTA("VEPL") From GLOCK
    Break 2
   Endif
 Next
 Filter [F:VEPL]
Next
End

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#-------------------------------------------
# MEMORISE_BULLETIN : Mémoriser le bulletin
#-------------------------------------------
###########################################
$MEMORISE_BULLETIN
# On ajoute une ligne dans [REC] pour mémoriser ce nouveau bulletin
[L]WRECORD += 1
Raz [F:REC]
[F:REC]RETNUM = [F:RET]RETNUM
[F:REC]RECREFNUM = [F:RES]REFNUM
[F:REC]RECCTRNUM = [F:RES]CTRNUM
[F:REC]RECRUBCOD = ""
[F:REC]RECBUL = [L]WNEWBUL
[F:REC]RECDATMININT = [0/0/0]
[F:REC]RECORD = [L]WRECORD
[F:REC]RECTYP = [L]WRECTYP
Write [F:REC]
If fstat <> 0
 [V]GOK = 0
 Call FSTA("REC") From GLOCK
 Return
Endif
Return


#-------------------------------------------------------------
# Calcul des rétroactivités individuelles ou collective
# Version 1 en travaillant directement sur les tables
# pour minimiser l'impact sur le calcul de paye
# Prevoir une V2 travaillant en mémoire en basculant
# par exemple les infos de la fiche RETNUM et autres
# dans de pseudos enregistrements avec un RETNUM = -adxuid(1)
#-------------------------------------------------------------
Subprog RETRO(RETNUM, REFNUM, CTRNUM, MODE)
Value Char RETNUM(), REFNUM(), CTRNUM()
Value Integer MODE

Local Integer NBBUL, MAXBUL, NBRUB, MAXRUB, I, J, PASAPAS
[L]MAXBUL = 100
[L]MAXRUB = func AFNC.ACTIV("RRUB")

Local Char CRIRES(250)
Local Char TBUL([V]GLONVCR)(1..[L]MAXBUL), BUL([V]GLONVCR)
Local Char TRUB([V]GLONRUB)(1..[L]MAXRUB)

Local Decimal TRAPSAL(1..[L]MAXRUB), TRAPPAT(1..[L]MAXRUB)
Local Decimal TAMTSAL(1..[L]MAXRUB), TAMTPAT(1..[L]MAXRUB)
Local Decimal DIFFERENCE

#Détail des rappels par bulletin & par rubrique
Local Decimal THSRSAL(1..[L]MAXBUL,1..[L]MAXRUB)
Local Decimal THSRPAT(1..[L]MAXBUL,1..[L]MAXRUB)
Local Date TDAT(1..[L]MAXBUL)
Local Integer FLGHSR

#85110
Local Decimal TAMTSALNEW(1..[L]MAXRUB), TAMTPATNEW(1..[L]MAXRUB)

Local Date DATEFF

# A priori variable globale à déclarer car absente dans certains cas
If dim([V]GFLGERR) < 1 : Global Integer GFLGERR : Endif

Read [F:RET]RET0 = [L]RETNUM
If fstat <> 0 : End : Endif

Global Char GRETNUM([V]GLONRET)
[V]GRETNUM = [F:RET]RETNUM

Raz [L]CRIRES
If [L]MODE = 1
   [L]CRIRES = "[F:RES]REFNUM ='" + [L]REFNUM + "' & [F:RES]CTRNUM ='"+ [L]CTRNUM + "'"
Else
   [L]CRIRES = "1"
Endif

[L]DATEFF = [F:RET]DATEFF    : # La date d'effet vient de la fiche de rétroactivité (rétro collective)
[L]PASAPAS = -4              : # Flag calcul rétroactivité dans le PLAN() From GPLAN

# Chargement des rubriques sur lesquelles on veut connaitre les différences ... <nc>

Raz [L]NBRUB, [L]TRUB

For [F:RER]RER0 Where [F:RER]RETNUM = [F:RET]RETNUM
    [L]NBRUB += 1
    [L]TRUB([L]NBRUB) = [F:RER]RUBCOD
Next

# Pour tous les salariés de la fiche de rétroactivité (=> Filtre CRIRES pour n'en traiter qu'un)
For [F:RES]RES0 Where [F:RES]RETNUM = [F:RET]RETNUM
&                    & evalue([L]CRIRES)

    If [F:RET]RETTYP = 1
        # Rétroactivité individuelle, la date d'effet est dans le contrat
        Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:RES]REFNUM
&                            & [F:HRCTR]CTRNUM = [F:RES]CTRNUM
&                            & [F:HRCTR]FLGRET = 2
        Read [F:HRCTR]CTR1 Last
        Filter [F:HRCTR]
        If fstat <= 2
            [L]DATEFF = [F:HRCTR]RETDATEFF
        Else
            [L]DATEFF = [31/12/2999]            : # Histoire de ne rien annuler en cas de cata
        Endif
    Endif

    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    # Matricule XXX & Contrat YYYY
    Call ECR_TRACE(mess(179,10702,1)-':'-[F:RES]REFNUM-'&'-mess(156,10702,1)-':'-[F:RES]CTRNUM, 0) From GESECRAN

    # Constitution de la liste des bulletins à traiter, salarié par salarié

     Filter [F:VEP] Where [F:VEP]EMP = [F:RES]REFNUM
&                    & [F:VEP]CTRNUM = [F:RES]CTRNUM
&                    & [F:VEP]STRDAT >= [L]DATEFF
&                    & [F:VEP]STA > 1
&                    & [F:VEP]RVSDAT=[0/0/0] &  [F:VEP]RVS<>2    :#DBA et les VAR ?!?

    # On ne nous dit pas "quand" s'arrêter ... peut être faudrait il stopper à la date
    # d'intégration max
    # Ne prendre aussi que les bulletins calculé ?, comptabilisé ? , que faire sur les bulletins
    # extourné et d'extourne ??

    # => On décide déjà de ne prendre "que" les bulletins au moins calculé car sinon le calcul d'un
    #    différentiel sera faussé.

    Raz [L]TBUL, [L]NBBUL,[L]TDAT


    For [F:VEP]VEP0
        [L]NBBUL += 1
        [L]TBUL([L]NBBUL) = [F:VEP]BUL
        [L]TDAT([L]NBBUL) = [F:VEP]PYRDAT    
    Next

    Filter [F:VEP]

    # Raz du montant des rappels
    Raz [L]TRAPSAL, [L]TRAPPAT

    #Raz de détails des rappels
    Raz [L]THSRSAL, [L]THSRPAT

    Trbegin [VEP]

    For [L]I = 1 To [L]NBBUL

        [L]BUL = [L]TBUL([L]I)

        Raz [L]TAMTSAL, [L]TAMTPAT

        # Mémorisation des valeurs des rubriques avant recalcul

       Call ECR_TRACE(space$(1),0) From GESECRAN
       #Montants initiaux du bulletin n°
       Call ECR_TRACE(mess(230,10702,1)+[L]BUL, 0) From GESECRAN

        For [L]J = 1 To [L]NBRUB

            # Part salariale
            Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 1
            If fstat = 0
              [L]TAMTSAL([L]J) = [F:HSP]AMT
              #mess(63,10935,1) : Montant salarial
              Call ECR_TRACE(space$(3)+mess(63,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            Endif
            # Part patronale
            Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 2
            If fstat = 0
              [L]TAMTPAT([L]J) = [F:HSP]AMT
              #mess(64,10935,1) : Montant patronal
              Call ECR_TRACE(space$(3)+mess(64,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            Endif

            # Ne prendre que les réguls inclues dans la période de retro (Date d'effet..)
            # BUL= Bulletin de déversement & DAT= Date de paie du bulletin d'origine régularisé
            [L]FLGHSR=0
            For [F:HRHSR]HSR0 Where BUL=[L]BUL & RUB=[L]TRUB([L]J) & DAT>=[L]DATEFF
              If [F:HRHSR]TYP=7
               [L]TAMTSAL([L]J) += [F:HRHSR]AMT
               #mess(101,10702,1) : Régularisation
               #mess(63,10935,1) : Montant salarial
               Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(63,10935,1)-[F:HSP]RUB-num$([F:HRHSR]AMT), 0) From GESECRAN
              Else
               [L]TAMTPAT([L]J) += [F:HRHSR]AMT
               #mess(101,10702,1) : Régularisation
               #mess(64,10935,1) : Montant patronal
               Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(64,10935,1)-[F:HSP]RUB-num$([F:HRHSR]AMT), 0) From GESECRAN
              Endif
              [L]FLGHSR = 1
            Next

            # Si pas d'historique de réguls trouvé, on prend la totalité de la régul comme avant, si elle existe !
            If ![L]FLGHSR
             #85110 : Prendre les réguls (retro d'une retro)
             # Part salariale
             Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 7
             If fstat = 0
               [L]TAMTSAL([L]J) += [F:HSP]AMT
               #mess(101,10702,1) : Régularisation
               #mess(63,10935,1) : Montant salarial
               Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(63,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
              Endif
             # Part patronale
             Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 8
             If fstat = 0
               [L]TAMTPAT([L]J) += [F:HSP]AMT
               #mess(101,10702,1) : Régularisation
               #mess(64,10935,1) : Montant patronal
               Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(64,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
             Endif
             #
          Endif
        Next

        # Recalcul du bulletin - PASAPAS = -4 = mode rétroactivité - Bien penser à le remettre à -4
        #                                  avant chaque appel car passé en variable et raz dans trt GPLAN
        # On a créé et servi [V]GRETNUM avant l'appel afin de passer en "paramètre" la fiche de
        # rétroactivité sur laquelle on travaille

        [L]PASAPAS = -4
        Call PLAN([L]BUL, [L]PASAPAS, 0) From GPLAN

        # Recherche des rubriques que l'on contrôle

        #85110
        Raz [L]TAMTSALNEW, [L]TAMTPATNEW

        #Montants recalculés du bulletin n°
        Call ECR_TRACE(mess(231,10702,1)+[L]BUL, 0) From GESECRAN


        For [L]J = 1 To [L]NBRUB


            #85110
            ## Part salariale
            #Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 2
            #If fstat = 0
            #    If [L]TAMTSAL([L]J) <> [F:HSP]AMT
            #        [L]DIFFERENCE = [F:HSP]AMT - [L]TAMTSAL([L]J)
            #        [L]TRAPSAL([L]J) += [L]DIFFERENCE
            #    Endif
            #Elsif [L]TAMTSAL([L]J)
            #  [L]DIFFERENCE = - [L]TAMTSAL([L]J)
            #  [L]TRAPSAL([L]J) += [L]DIFFERENCE
            #Endif

            ## Part patronale
            #Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 2
            #If fstat = 0
            #    If [L]TAMTPAT([L]J) <> [F:HSP]AMT
            #        [L]DIFFERENCE = [F:HSP]AMT - [L]TAMTPAT([L]J)
            #        [L]TRAPPAT([L]J) += [L]DIFFERENCE
            #    Endif
            #Elsif [L]TAMTPAT([L]J)
            #  [L]DIFFERENCE = - [L]TAMTPAT([L]J)
            #  [L]TRAPPAT([L]J) += [L]DIFFERENCE
            #Endif

            # Part salariale
            Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 1
            If fstat = 0
              [L]TAMTSALNEW([L]J) = [F:HSP]AMT
              #mess(63,10935,1) : Montant salarial
              Call ECR_TRACE(space$(3)+mess(63,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            Endif

            ################## 89611 : Ne pas tenir compte des réguls (issues de GESRGL) calculées en simulation !
            #Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 7
            #If fstat = 0
            # [L]TAMTSALNEW([L]J) += [F:HSP]AMT
            # #mess(101,10702,1) : Régularisation
            # #mess(63,10935,1) : Montant salarial
            # Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(63,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            #Endif

            If [L]TAMTSALNEW([L]J)<>0
             If [L]TAMTSAL([L]J) <> [L]TAMTSALNEW([L]J)
                [L]DIFFERENCE = [L]TAMTSALNEW([L]J) - [L]TAMTSAL([L]J)
                [L]TRAPSAL([L]J) += [L]DIFFERENCE
                # Delta
                Call ECR_TRACE('---->'-mess(232,10702,1)-[L]TRUB([L]J)-num$([L]TRAPSAL([L]J)), 0) From GESECRAN
                [L]THSRSAL(I,J) = [L]DIFFERENCE
             Endif
            Elsif [L]TAMTSAL([L]J)
             [L]DIFFERENCE =  - [L]TAMTSAL([L]J)
             [L]TRAPSAL([L]J) += [L]DIFFERENCE
             # Delta
             Call ECR_TRACE('---->'-mess(232,10702,1)-[L]TRUB([L]J)-num$([L]TRAPSAL([L]J)), 0) From GESECRAN
              [L]THSRSAL(I,J) = [L]DIFFERENCE
            Endif


            # Part patronale
            Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 2
            If fstat = 0
              [L]TAMTPATNEW([L]J) = [F:HSP]AMT
              #mess(64,10935,1) : Montant patronal
              Call ECR_TRACE(space$(3)+mess(64,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            Endif

            ################## 89611 : Ne pas tenir compte des réguls (issues de GESRGL) calculées en simulation !
            #Read [F:HSP]HSP3 = [L]BUL ; [L]TRUB([L]J) ; 8
            #If fstat = 0
            # [L]TAMTPATNEW([L]J) += [F:HSP]AMT
            # #mess(101,10702,1) : Régularisation
            # #mess(64,10935,1) : Montant patronal
            # Call ECR_TRACE(space$(3)+mess(101,10702,1)-mess(64,10935,1)-[F:HSP]RUB-num$([F:HSP]AMT), 0) From GESECRAN
            #Endif

            If [L]TAMTPATNEW([L]J)<>0
             If [L]TAMTPAT([L]J) <> [L]TAMTPATNEW([L]J)
                [L]DIFFERENCE = [L]TAMTPATNEW([L]J) - [L]TAMTPAT([L]J)
                [L]TRAPPAT([L]J) += [L]DIFFERENCE
                # Delta
                Call ECR_TRACE('---->'-mess(232,10702,1)-[L]TRUB([L]J)-num$([L]TRAPPAT([L]J)), 0) From GESECRAN
                [L]THSRPAT(I,J) = [L]DIFFERENCE
             Endif
            Elsif [L]TAMTPAT([L]J)
             [L]DIFFERENCE =  - [L]TAMTPAT([L]J)
             [L]TRAPPAT([L]J) += [L]DIFFERENCE
             # Delta
             Call ECR_TRACE('---->'-mess(232,10702,1)-[L]TRUB([L]J)-num$([L]TRAPPAT([L]J)), 0) From GESECRAN
             [L]THSRPAT(I,J) = [L]DIFFERENCE
            Endif
        Next

    Next

    # On annule tout
    Rollback

    #77569 : Portugal need to recalculate all values...
    [V]GPE = 0
    GPOINT = "RETRO_SPECAL" : Gosub ENTREE From EXEFNC
    If [V]GPE = 1 : Break : Endif


    # Et maintenant on enregistre notre résultat
    Trbegin [REC],[HRHSR]

    Delete [F:REC] Where [F:REC]RETNUM = [F:RES]RETNUM
&                    & [F:REC]RECREFNUM = [F:RES]REFNUM
&                    & [F:REC]RECCTRNUM = [F:RES]CTRNUM

    For [L]I = 1 To [L]NBRUB
        If abs([L]TRAPSAL([L]I)) + abs([L]TRAPPAT([L]I)) <> 0
            Raz [F:REC]
            [F:REC]RETNUM = [F:RES]RETNUM
            [F:REC]RECREFNUM = [F:RES]REFNUM
            [F:REC]RECCTRNUM = [F:RES]CTRNUM
            [F:REC]RECRUBCOD = [L]TRUB([L]I)
            [F:REC]AMTRAPSAL = [L]TRAPSAL([L]I)
            [F:REC]AMTRAPPAT = [L]TRAPPAT([L]I)
            [F:REC]RECDATMININT = [F:RET]DATMININT
            [F:REC]RECORD = 0
            [F:REC]RECTYP = "R"                    : # Simple rappel
            Write [F:REC]
        Endif
    Next

    Delete [F:HRHSR] Where RETNUM = [F:RES]RETNUM
&                    & EMP = [F:RES]REFNUM
&                    & CTRNUM = [F:RES]CTRNUM

    For [L]I = 1 To [L]NBBUL
     For [L]J = 1 To [L]NBRUB
       If abs([L]THSRSAL(I,J))
         Raz [F:HRHSR]
         [F:HRHSR]BUL=""                :#Bulletin de déversement non encore connu ici
         [F:HRHSR]EMP=[F:RES]REFNUM
         [F:HRHSR]CTRNUM=[F:RES]CTRNUM
         [F:HRHSR]CTRDAT=[F:RES]CTRDAT
         [F:HRHSR]DAT=[L]TDAT(I)
         [F:HRHSR]RUB=[L]TRUB(J)
         [F:HRHSR]TYP=7
         [F:HRHSR]AMT=[L]THSRSAL(I,J)
         [F:HRHSR]TYPAMT=1 :#Auto
         [F:HRHSR]ORIBUL= [L]TBUL(I)
         [F:HRHSR]RETNUM=[F:RES]RETNUM
         Write [F:HRHSR]
        Endif
        If abs([L]THSRPAT(I,J))
         Raz [F:HRHSR]
         [F:HRHSR]BUL=""                :#Bulletin de déversement non encore connu ici
         [F:HRHSR]EMP=[F:RES]REFNUM
         [F:HRHSR]CTRNUM=[F:RES]CTRNUM
         [F:HRHSR]CTRDAT=[F:RES]CTRDAT
         [F:HRHSR]DAT=[L]TDAT(I)
         [F:HRHSR]RUB=[L]TRUB(J)
         [F:HRHSR]TYP=8
         [F:HRHSR]AMT=[L]THSRPAT(I,J)
         [F:HRHSR]TYPAMT=1 :#Auto
         [F:HRHSR]ORIBUL= [L]TBUL(I)
         [F:HRHSR]RETNUM=[F:RES]RETNUM
         Write [F:HRHSR]
        Endif
     Next J
   Next I

    # DBA : Anticipation future évolution...
    # Si historisation du contexte, mémorisation des infos au moment du calcul des rappels
    #If func AFNC.ACTIV("HIC") > 0
        # Lecture du contrat "courant"
    #    If [F:RET]RETTYP = 1
            #
    #    Elsif [F:RET]RETTYP = 2
            #
    #    Else
            #
    #    Endif
        # Call HISTOCTX(2, 'RET', [F:RES]RETNUM+"~"+[F:RES]REFNUM+"~"+[F:RES]CTRNUM) From TRTHIC
    #Endif

    Commit

    #77570 : Portugal need to save more data...
    [V]GPE = 0
    GPOINT = "RETRO_SPESAV" : Gosub ENTREE From EXEFNC
    If [V]GPE = 1 : Break : Endif

 Call ECR_TRACE(space$(1),0) From GESECRAN
Next

Kill [V]GRETNUM

If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif

If [V]GPE = 1 : End : Endif
End

##################################################
Subprog UNSET_BULREC(BUL)
Value Char BUL()
If not clalev([F:RET]) : Local File RETRO    [RET] : Endif
If not clalev([F:REC]) : Local File RETROCAL [REC] : Endif
Local Char TRETNUM([V]GLONRET)(1..100)
Local Integer I
Raz [L]TRETNUM, [L]I
For [F:REC]REC1 Where [F:REC]RECBUL = [L]BUL
    If not find([F:REC]RETNUM, [L]TRETNUM)
        [L]I += 1
        [L]TRETNUM([L]I) = [F:REC]RETNUM
    Endif
    # Si pas de rubcod , enregistrement "informatif" sur une extourne, il saute
    If [F:REC]RECRUBCOD = ""
        Delete [F:REC]
    Else
        [F:REC]RECBUL = ""
        Rewrite [F:REC]
    Endif
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("REC") From GLOCK
        Break
    Endif
Next
If [V]GOK < 1 : End : Endif
For [L]I = 1 To dim([L]TRETNUM)
    Filter [F:REC] Where [F:REC]RETNUM = [L]TRETNUM([L]I)
&                    & [F:REC]RECBUL <> ""
    Read [F:REC] First
    Filter [F:REC]
    If fstat <= 2
        # Il reste encore des lignes "flaggées"
    Else
        Readlock [F:RET]RET0 = [L]TRETNUM([L]I)
        If fstat = 1
            [V]GOK = -1
            [V]GLOCK = "$RETRO"
            Break
        Elsif fstat = 0
            [F:RET]STATUT = 2
            Rewrite [F:RET]
            If fstat <> 0
                [V]GOK = 0
                Call FSTA("RET") From GLOCK
                Break
            Endif
        Endif
    Endif
Next
If [V]GOK < 1 : End : Endif

If clalev([F:HRHSR])=0  : Local File HISTOREGUL [HRHSR] : Endif

#On ne supprime pas le détail des réguls de rétro, on vide le n° de bulletin de déversement afin de pouvoir redéverser
#sur un autre bulletin
Update [F:HRHSR] Where BUL=[L]BUL & RETNUM <>""  With BUL=""
If fstat
 [V]GOK = 0
 Call FSTA("HSR") From GLOCK
Endif
If [V]GOK < 1 : End : Endif
End

#-------------------------------------
# Impression d'un tableau de bulletin
#-------------------------------------
Subprog IMPRIME(TBUL, DESTINATION, MODE)
Value Char TBUL()(), DESTINATION()
Value Integer MODE
Local Char TBVAL(250)(1..100), TBPAR(80)(1..100), ETAT([V]GLONARP)
Local Char BUL(type([L]TBUL(0))-10)
Local Integer I, J, S_GIMPRIME

If not clalev([F:VEPW]) : Local File VALEMP [VEPW] : Endif
If not clalev([F:CTRW]) : Local File EMPLOCTR [CTRW] : Endif
If not clalev([F:FCYW]) : Local File FACILITY [FCYW] : Endif

For [L]I = 0 To dim([L]TBUL) - 1
    [L]BUL = [L]TBUL([L]I)
    If [L]BUL = "" : Break : Endif
    [L]ETAT = ""
    Read [F:VEPW]VEP5 = [L]BUL
    If fstat = 0
        If [F:VEPW]RPTBUL <> ""
            [L]ETAT = [F:VEPW]RPTBUL
        Else
            If dim([F:VEPW]CTRDAT) > 0 & [F:VEPW]CTRDAT <> [0/0/0]
                Filter [CTRW] Where [F:CTRW]REFNUM = [F:VEPW]EMP & [F:CTRW]CTRNUM = [F:VEPW]CTRNUM
&                                 & [F:CTRW]CTRDAT = [F:VEPW]CTRDAT
                # Si CTRDAT alors on en profite pour faire un lien strict et direct
            Else
                Filter [CTRW] Where [F:CTRW]REFNUM = [F:VEPW]EMP & [F:CTRW]CTRNUM = [F:VEPW]CTRNUM
&                                 & CTRDAT <= [F:VEPW]PYRDAT
            Endif
            Read [CTRW]CTR0 Last
            Filter [CTRW]
            If !fstat : [L]ETAT = [F:CTRW]RPTBUL : Endif
        Endif

        Read [F:FCYW]FCY0 = [F:VEPW]FCY

    Endif
    If [L]ETAT = ""
        Call PARAM(GCURLEG,"NOMRPTBUL",[L]ETAT) From ADOVAL :#81084
        # Attention => voir dans TRTAUT, le GETRPTBUL est différent , il appelle un PARAML
        # est ce normal ? on a deux GETRPTBUL , un dans SUBVEP appelé par l'impression ( Subprog  IMPRIME )
        # et un autre dans TRTAUT, appelé en création de bulletin.
    Endif

    [L]S_GIMPRIME = [V]GIMPRIME
    [V]GIMPRIME = 1

    Raz [L]TBPAR, [L]TBVAL, [L]J

    # Chargement des paramètres dans TBPAR / TBVAL car on ne dispose pas d'un contexte
    # permettant l'utilisation de valeurs / défaut
    # => Evolution : utilisation d'un masque générique pour mettre les valeurs dedans et les réutiliser
    #                par le paramétrage des valeurs / défaut ?

    [L]J += 1
    [L]TBPAR([L]J) = "matdeb" : [L]TBVAL([L]J) = [F:VEPW]EMP

    [L]J += 1
    [L]TBPAR([L]J) = "matfin" : [L]TBVAL([L]J) = [F:VEPW]EMP

    [L]J += 1
    [L]TBPAR([L]J) = "buldeb" : [L]TBVAL([L]J) = [L]BUL

    [L]J += 1
    [L]TBPAR([L]J) = "bulfin" : [L]TBVAL([L]J) = [L]BUL

    [L]J += 1
    [L]TBPAR([L]J) = "cpy" : [L]TBVAL([L]J) = [F:FCYW]LEGCPY

    [L]J += 1
    [L]TBPAR([L]J) = "fcydeb" : [L]TBVAL([L]J) = [F:VEPW]FCY

    [L]J += 1
    [L]TBPAR([L]J) = "fcyfin" : [L]TBVAL([L]J) = [F:VEPW]FCY

    [L]J += 1
    [L]TBPAR([L]J) = "srv" : [L]TBVAL([L]J) = [F:VEPW]SRV

    [L]J += 1
    [L]TBPAR([L]J) = "prf" : [L]TBVAL([L]J) = [F:VEPW]PRF

    [L]J += 1
    [L]TBPAR([L]J) = "datdeb" : [L]TBVAL([L]J) = [F:VEPW]PYRDAT

    [L]J += 1
    [L]TBPAR([L]J) = "datfin" : [L]TBVAL([L]J) = [F:VEPW]PYRDAT

    [L]J += 1
    [L]TBPAR([L]J) = "tri" : [L]TBVAL([L]J) = "1"

    [L]J += 1
    [L]TBPAR([L]J) = "impsel" : [L]TBVAL([L]J) = "1"

    Global Integer GRETROACTIVITE : [V]GRETROACTIVITE = 1 : # Valeur exploitée par MAJBUL pour nom de fichier

    Call ETAT([L]ETAT, [L]DESTINATION, [V]GLANGUE, 0, "", [L]TBPAR, [L]TBVAL) From AIMP3

    Kill [V]GRETROACTIVITE

    [V]GIMPRIME = [L]S_GIMPRIME
Next

End

#-------------------------------------------- ECRAN ---------------------------------------------

Subprog AV_PRT(VALEUR)
Variable Char     VALEUR
If [M:DIA]FLGIMP = 2
   Actzo [M:DIA]PRT
Else
   Grizo [M:DIA]PRT
Endif
End

Subprog AV_FDR(VALEUR)
Variable Char     VALEUR
If [M:DIA]FLGIMP = 2
   Actzo [M:DIA]FDR
Else
   Grizo [M:DIA]FDR
Endif
End

Subprog AM_FLGIMP(VALEUR)
Variable Integer  VALEUR
If [L]VALEUR = 2
   Actzo [M:DIA]FDR
   Actzo [M:DIA]PRT
Else
   Grizo [M:DIA]FDR
   Grizo [M:DIA]PRT
Endif
End
