#<AdxTL>@(#)2.0.0.0 $Revision$
#** FQ96833
#* Traitement de synchronisation des suivis UMAJSUIV
#*
#
#  Utilitaire de mise en cohérence des suivis initial et théorique
#  ------------------------------------------------
#
#  L'objectif de cet utilitaire est double :
#  D'une part réaligner autant que faire se peut les suivis théorique et initial
#  par rapport au suivi réel. Signaler d'autre part une situation d'incohérence
#  dans les suivis qui ne peut pas être corrigée de façon automatique.
#
#  D'une manière générale, l'ajustement de valeur se fait uniquement sur la période
#  courante et le bien est considéré comme étant à recalculer pour tous ses contextes.
#  Un bien qui n'a ni été réévalué ni déprécié doit avoir ses suivis théorique et
#  initial equivalents au réel. Un bien qui n'a pas été déprécié doit avoir son suivi
#  théorique aligné sur le réel Ces différents cas peuvent être corrigés automatiquement.
#  Un bien ayant été déprécié et non réévalué doit avoir ses suivis initial et théorique
#  équivalents. Si, dans cette situation, ces suivis sont différents, une autocorrection
#  est impossible. Néanmoins l'utilitaire signalera cette incohérence par un message
#  d'erreur dans la trace.
#
#  Un plan est considéré comme "réévalué" si sur la période courante RVACRB <> 0 ou
#  ( BSEVAL <> DPRBAS et BSEVAL <> 0 )
#  Un plan est considéré comme "déprécié" si il existe au moins un enregistrement DEPREC
#  antérieur à la période courante tel que IML <> 0.

#  Les champs réalignés sur les valeurs du suivi réel sont
#  Pour le suivi théorique :
#  PERREFCLCT, DPMT, EXECLOCUMT, ENDDPET, PERCLOCUMT, DPET, EXCCUMT, EXCDPRT, PERCLOEXCT, PEREXCDPRT, NBVT
#  Pour le suivi initial :
#  PERREFCLCI, DPMI, EXECLOCUMI, ENDDPEI, PERCLOCUMI, DPEI, EXCCUMI, EXCDPRI, PERCLOEXCI, PEREXCDPRI, NBVI
#
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "UMAJSUIV", "UMAJSUIV", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When "INIT"        : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : GOK=1
    When "END"         : GOK=0
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When "SETBOUT"     : Gosub SETBOUT
Endcase
Return

$INIT_DIA
$INIT
#############################################################################################################

    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif

    Local Mask UMAJSUIV   [DIA]

    Local Integer WTPLANS_SELEC(G301MAX), I, J
    Local Char LIBCALL(250)

Return

$OUVRE
Return

$SETBOUT

Return

$DEBUT
    # vérifier si l'utilisateur a les droits au site
#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        Infbox "droits restreints" - GUSRFCY(1) - GUSRFCY(2)
#    Endif

    If dim(WGCNX) < 0
        Global Integer WGCNX
    Endif

    If [M:DIA]CPYTOUS = G_NON
        Actzo [M:DIA]CPY
    Else
        Diszo [M:DIA]CPY
    Endif
    If [M:DIA]CNX = 0
        [M:DIA]CNX = G300CPFI
    Endif

    If [M:DIA]CNX <> WGCNX
        Gosub RAZ_TABPLN
        WGCNX = [M:DIA]CNX
        Gosub CHARGE_PLANS
    Endif

    Affzo [M:DIA]

Return


$CONTROLE

    If GOK < 1
        Return
    Endif

#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        GMESSAGE = "droits restreints" - GUSER - GUSRFCY(1) - GUSRFCY(2) - GUSRFCY(3) - GUSRFCY(4) - GUSRFCY(5)
#        GERR = 1
#        mkstat = 2
#        Return
#    Endif


# Contrôle de la date / société

#    If [M:DIA]CPY <> ""
#        Read [FIS]FIY2 = [M:DIA]CPY; [M:DIA]CNX; [M:DIA]DATFIN
#        If fstat
#            GMESSAGE = "Date de fin d'exercice non trouvée pour le contexte" - mess([M:DIA]CNX, 3100, 1)
#            GERR = 1
#            GOK = 0
#            Return
#        Endif
#    Endif

    If [M:DIA]SAUVE <> G_OUI and [M:DIA]FLGSIM <> G_OUI
#        GMESSAGE = "Confirmation sauvegarde effectuée obligatoire"
#        GMESSAGE = mess(31, 7784, 1)
        Call LIBCHPATZ(GLANGUE, "UMAJSUIV", "SAUVE", LIBCALL) From UMAJSUIV2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        Return
    Endif

    # tous les plans du contexte ?
    I = 0
    J = 0
    Raz WTPLANS_SELEC, GMESSAGE
    While I < [M:DIA]NBDPRPLN
        If [M:DIA]PLNCAA(I) > 0

            # plan à traiter
            If [M:DIA]MAJ(I) = G_OUI

                WTPLANS_SELEC(J) = [M:DIA]PLNCAA(I)
                J += 1
            Endif
        Endif

            I += 1
    Wend

    If GMESSAGE <> ""
        Return
    Endif

    If J = 0
#        GMESSAGE = "Aucun plan sélectionné"
       GMESSAGE = mess(35, 7784, 1)
        mkstat = 2
        GERR = 1
        GOK = 0
        Return
    Endif

Return


# traitement
$EXEC
Local Integer LOK

    If GOK = 0
        Return
    Endif

If GUSER <> "CBO"
    If [M:DIA]FLGSIM = G_NON
        Call OUINON(mess(188, 7774, 1), LOK) From GESECRAN
    Else
        Call OUINON(mess(176, 7774, 1), LOK) From GESECRAN
    Endif
    If (LOK = 1) Then
        FIN      = 0
        GERR     = 1
        Return
    Endif
Endif


    Call UMAJSUIV([M:DIA]CPY, [M:DIA]CNX, [M:DIA]FLGSIM,
&                WTPLANS_SELEC) From UMAJSUIV2

    GERR = 0
    GOK  = 1

Return

$TERMINE

    GERR = 0
    GMESSAGE = ""
    Close File [CNX]
    Close Mask [DIA]

    # FQxxxxx
    If dim(WGCNX) >= 0
        Kill WGCNX
    Endif
Return

$RAZ_TABPLN

    Raz [M:DIA]PLNCAA, MAJ
    [M:DIA]NBDPRPLN = 0

Return


$CHARGE_PLANS

    nolign = 0
    If [M:DIA]CPY = ""

        I = 1
        While I < G301MAX
            If mess(I, 3101, 1) <> ""

                Filter [CNX] Where CNX = WGCNX and find(I, PLNCAA) > 0
                Read [CNX]CNX0 First
                If fstat = 0
                    [M:DIA]PLNCAA(nolign)      = I
                    [M:DIA]MAJ(nolign) = G_NON
                    nolign += 1
                Endif
                Filter [CNX]
            Endif

            I += 1
        Wend
    Else

        Read [CNX]CNX0 = [M:DIA]CPY; WGCNX
        If fstat = 0

            I = 0
            While I < G301MAX - 1
                If [F:CNX]PLNCAA(I) > 0

                    [M:DIA]PLNCAA(nolign)      = [F:CNX]PLNCAA(I)
                    [M:DIA]MAJ(nolign) = G_NON
                    nolign += 1
                Endif

                I += 1
            Wend
        Endif

    Endif

    [M:DIA]NBDPRPLN = nolign

    Affzo [M:DIA]
Return
######################################################################################

######################################################################################

Subprog AM_CPYTOUS(VALEUR)
Variable Integer VALEUR

    If VALEUR = G_OUI
        [M:DIA]CPY = ""
        Diszo [M:DIA]CPY
    Else
        Actzo [M:DIA]CPY
    Endif

    If VALEUR <> [M]CPYTOUS and [M:DIA]NBDPRPLN > 0
        Gosub RAZ_TABPLN
    Endif
    Affzo [M:DIA]

End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

    If [M]CPYTOUS <> G_OUI & VALEUR = ""
        GMESSAGE = mess(27, GML_IMPFXD, 1)
        mkstat=1
        End
    Endif

    If VALEUR <> [M]CPY and [M:DIA]NBDPRPLN > 0
        Gosub RAZ_TABPLN
        Affzo [M:DIA]
    Endif

End

Subprog AS_CNX(VALEUR)
Variable Integer VALEUR

Local Integer I

    If [M:DIA]CPY = ""
        Raz GMENLOC
    Else
        For I = 1 To 11
            GMENLOC(I) = 1
        Next I
        For [CNX] Where CPY = [M:DIA]CPY
            GMENLOC([F:CNX]CNX) = 0
        Next
    Endif

End

Subprog AP_CNX(VALEUR)
Variable Integer VALEUR

Local Integer I
    # Chargement des plans du contexte sélectionné :
    # - pas de soc sélectionnée, tous les plans UTILISES pour ce contexte
    # - soc sélectionnée, tous les plans du contexte !


    If VALEUR = [M]CNX and [M:DIA]NBDPRPLN > 0
        End
    Endif

    Gosub RAZ_TABPLN
    WGCNX = VALEUR
    Gosub CHARGE_PLANS

End


# Séletion automatique de toutes les lignes (hors plans non supprimables)
Subprog B1_NBDPRPLN
Local Integer I

    For I = 0 To [M:DIA]NBDPRPLN - 1
        [M:DIA]MAJ(I) = G_OUI
    Next I
    Affzo [M:DIA]
End
