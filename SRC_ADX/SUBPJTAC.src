  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).POASTR =
&                  GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).snapshot.POASTR
    GERR = 1
    mkstat = 2
    End
  Else
