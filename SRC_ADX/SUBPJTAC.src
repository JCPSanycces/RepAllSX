Subprog C_NBPJTAC2
Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJTAC2]SEQNUM(nolign-1) = 0 Then
      ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ADDLINE("OPLNK", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_OPLNK_LINE(ILINE) From PJMACTTKO
        Affzo [M:PJTAC2]1-99
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ADELLINE("OPLNK", GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPLNK([M:PJTAC2]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

