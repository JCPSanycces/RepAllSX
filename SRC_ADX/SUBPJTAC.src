###################################################################################################
Subprog CHGTZN_OPECST()

Local Char STEXTE(250)
Local Char SUNIT(250)
Local Char STIMUOM(GLONUOM)

  STIMUOM = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, GZINSPJM.ACTX.AFOLDER, "HOURLYUNIT")
  Call TEXTE(15199, STEXTE) From OBJDIV
  Call TEXTE(2685, SUNIT) From OBJDIV
  STEXTE -= "(" + SUNIT - ":" - STIMUOM + ")"
  Chgtzn [M:PJTAC0B]OPECST With STEXTE # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
End

