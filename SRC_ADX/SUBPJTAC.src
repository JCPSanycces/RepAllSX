###################################################################################################
Subprog AM_POASTDQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal DTOTAL

  GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).POASTDQTY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).POASTDQTY =
&                  GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).snapshot.POASTDQTY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RAFFT_LINE([M:PJTAC1]COLLIN(nolign-1)) From PJMACTTKO
    Affzo [M:PJTAC1]55
    # -----------------------------
    DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT_SUM_POASTDQTY()
    If DTOTAL > [M:PJTAC0B]EXTQTY Then           # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
      GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).EXTQTY = DTOTAL
    Endif
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).POARMNQTY <>
&      GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT([M:PJTAC1]COLLIN(nolign-1)).snapshot.POARMNQTY Then
      DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT_SUM_POARMNQTY()
      If DTOTAL > [M:PJTAC0B]RMNQTY Then         # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
        GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RMNQTY = DTOTAL
      Endif
    Endif
    Call SHOW_RTKO_LINE([M:PJTAC0]COLLIN) From PJMACTTKO
    Affzo [M:PJTAC0]1-99
    Affzo [M:PJTAC0A]1-99    # Issue X3-99916 - 2018-07-12 by FGR
    Affzo [M:PJTAC0B]1-99    # Issue X3-99916 - 2018-07-12 by FGR
    Affzo [M:PJTAC0C]1-99    # Issue X3-99916 - 2018-07-12 by FGR
    Affzo [M:PJTAC0D]1-99    # Issue X3-99916 - 2018-07-12 by FGR
    # -----------------------------
  Endif
End

