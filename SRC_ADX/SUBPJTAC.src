          IREP = func TRTPJMREP.ASK_THE_QUESTION(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).TCHOPEENDAN)
          GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).TCHOPEENDAN = IREP
          IREP = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT_REPEAT_OPEEND()
          If IREP <> [V]CST_AOK Then
