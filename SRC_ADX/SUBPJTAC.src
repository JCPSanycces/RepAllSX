###################################################################################################
Funprog MANAGE_DATE_VALIDITY(AINSTANCE, SFIELD, STYP, SVAL, DDATE, SHOUR, RDATE, RHOUR)
Variable Instance AINSTANCE Using OBJECT
Value Char SFIELD
Value Char STYP()(1..)
Value Char SVAL()(1..)
Value Date DDATE
Value Char SHOUR
Variable Date RDATE
Variable Char RHOUR

Local Integer IRETURN_VALUE

  IRETURN_VALUE = [V]CST_AOK
  # -----------------------------
  If DDATE <> [0/0/0] Then
    IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(AINSTANCE, SFIELD, [M:PJTAC0]TASFCY, STYP, SVAL, DDATE, SHOUR, 1, RDATE, RHOUR)
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GERR = 1 Then
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End IRETURN_VALUE

###################################################################################################
$GET_WST
  ITYP = 0
  ITYP += 1
  STYP(ITYP) = "WST"
  SVAL(ITYP) = [M:PJTAC0A]EXTWST                 # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
  If [M:PJTAC0A]EXTLAB <> AVOID.ACHAR Then       # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
    ITYP += 1
    STYP(ITYP) = "WST"
    SVAL(ITYP) = [M:PJTAC0A]EXTLAB               # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
  Endif
Return

###################################################################################################
$GET_AUS
  ITYP += 1
  STYP(ITYP) = "AUS"
  SVAL(ITYP) = [M:PJTAC1]POACLB(nolign-1)
Return

