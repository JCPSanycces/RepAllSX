#<AdxTL>@(#)0.0.0.0 $Revision$ 
###################################################################################################
# Gestion du masque PJMTACT0
###################################################################################################
$ACTION
  Case ACTION
    When "BB1_EXTWST"        : Gosub BB1_EXTWST
    When "BB1_EXTLAB"        : Gosub BB1_EXTLAB
  Endcase
Return

###################################################################################################
$BB1_EXTWST
  If [F:MWS]WST <> AVOID.ACHAR Then
    VALEUR = [F:MWS]WST
  Endif
Return

###################################################################################################
$BB1_EXTLAB
  If [F:MWS]WST <> AVOID.ACHAR Then
    VALEUR = [F:MWS]WST
  Endif
Return

###################################################################################################
# PJMTACT0
###################################################################################################
Subprog AM_ROODESAXX(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ROODESAXX = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ROODESAXX = GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).snapshot.ROODESAXX
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RTKO_LINE([M:PJTAC0]COLLIN) From PJMACTTKO
    Affzo [M:PJTAC0]1-99
  Endif
End

###################################################################################################
Subprog AS_OPESTR(VALEUR)
Variable Date    VALEUR

  # Issue X3-101322 - 2018-08-09 by FGR
  If VALEUR = AVOID.ADATE and [M:PJTAC0]OPEEND <> AVOID.ADATE Then
    VALEUR = [M:PJTAC0]OPEEND
  Endif
End

###################################################################################################
Subprog AM_OPESTR(VALEUR)
Variable Date    VALEUR

Local Integer IREP
Local Integer IAFF
Local Integer IRETURN_VALUE
Local Date RDATE
Local Char STYP(5)(1..)
Local Char SVAL(5)(1..)
Local Integer ITYP

  Gosub GET_WST
  # -----------------------------
  IRETURN_VALUE = func MANAGE_DATE_VALIDITY(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN), "OPESTR", STYP, SVAL, VALEUR, AVOID.ACHAR, RDATE, AVOID.ACHAR)
  If IRETURN_VALUE < [V]CST_AERROR Then
    VALEUR = RDATE
  Else
    End
  Endif
  # -----------------------------
  GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPESTR = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPESTR = GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).snapshot.OPESTR
    GERR = 1
    mkstat = 2
    End
  Else
    VALEUR = GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPESTR
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ASTALIN = [V]CST_AUPD Then
      If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPESTR <> GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).snapshot.OPESTR Then
        IAFF = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT_COUNT()
        If IAFF > 0 Then
          IREP = func TRTPJMREP.ASK_THE_QUESTION(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).TCHOPESTRAN)
          GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).TCHOPESTRAN = IREP
          IREP = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT_REPEAT_OPESTR()
          If IREP <> [V]CST_AOK Then
            Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
            If GERR = 1 Then
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
          GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).TCHOPESTRAN = 2
          Call LOAD_SCREEN([M:PJTAC0]TASLIN, [M:PJTAC0]COLLIN) From PJMACTTKO
        Endif
      Endif
    Else
      Call SHOW_RTKO_LINE([M:PJTAC0]COLLIN) From PJMACTTKO
      Affzo [M:PJTAC0]1-99
    Endif
  Endif
End

###################################################################################################
Subprog AS_OPEEND(VALEUR)
Variable Date    VALEUR

  # Issue X3-101322 - 2018-08-09 by FGR
  If VALEUR = AVOID.ADATE and [M:PJTAC0]OPESTR <> AVOID.ADATE Then
    VALEUR = [M:PJTAC0]OPESTR
  Endif
End

