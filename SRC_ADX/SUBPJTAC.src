  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPLNK([M:PJTAC2]COLLIN(nolign-1)).OPELNKCSTR =
&   GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPLNK([M:PJTAC2]COLLIN(nolign-1)).snapshot.OPELNKCSTR
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPLNK_LINE([M:PJTAC2]COLLIN(nolign-1)) From PJMACTTKO
    Affzo [M:PJTAC2]5
  Endif
End

