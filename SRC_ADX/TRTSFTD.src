#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Shop floor tracking EMpoyee Defaults screen
# allow employees to update default Site, Work Center and Work Center Group
#
######################################################################################
$ACTION

  Case [L]ACTION
    When "DEBUT"    : Gosub DEBUT
    When "OK"       : Gosub OK
    When "OUVRE"    : Gosub OUVRE
    When "FERME"    : Gosub FERME
  Endcase

Return


######################################################################################
$OUVRE

  Global Integer EMPNO

Return


######################################################################################
$DEBUT
  Local Integer EMPNUM        : EMPNUM    = val(PARAM(1))
  Local Char    FUNCTION(25)  : FUNCTION  = PARAM(2)

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  EMPNO = EMPNUM

  Read [TMA]TMA0=[L]EMPNUM
  If !fstat
    [M:SFTD]DEFFCY = [F:TMA]DEFFCY
    [M:SFTD]DEFWCR = [F:TMA]DEFWCR
    [M:SFTD]DEFWST = [F:TMA]DEFWST
  Endif

  If FUNCTION<>"SFTPORTAL"
    Grizo [M:SFTD]DEFFCY
  Endif

  Affzo [M:SFTD]

Return

######################################################################################
$OK

  # Just in case the table pointer is incorrect
  If [F:TMA]EMPNUM<>[L]EMPNUM
    Read [TMA]TMA0=[L]EMPNUM
    If fstat
       GOK = 0 : Call FSTA("TMA") From GLOCK : Return
    Endif
  Endif

  If [M:SFTD]DEFFCY <> [F:TMA]DEFFCY | [M:SFTD]DEFWCR <> [F:TMA]DEFWCR | [M:SFTD]DEFWST <> [F:TMA]DEFWST
    [F:TMA]DEFFCY = [M:SFTD]DEFFCY
    [F:TMA]DEFWCR = [M:SFTD]DEFWCR
    [F:TMA]DEFWST = [M:SFTD]DEFWST

    Rewrite [TMA]
    If fstat
       GOK = 0 : Call FSTA("TMA") From GLOCK
    Endif
  Endif

Return

######################################################################################
$FERME
  LogicClose File [TMA]
Return

######################################################################################
Subprog C_DEFFCY(VALEUR)
Variable Char    VALEUR()

  If func SFTLIB.VALIDATE_WORK_CENTER(VALEUR, [M:SFTD]DEFWCR, [M:SFTD]DEFWST) = [V]CST_ANO
    mkstat=1
    Call ERREUR(mess(26,2422,1)) From GESECRAN
  Endif

  If VALEUR<>""
    If func SFTLIB.EMPTYP(EMPNO)=2 #Detail team
      If func AFNC.PARAM("SFTEMPCLK",VALEUR)<>"2"
        Call ERREUR(func AFNC.MES1(mess(111,2422,1),"SFTEMPCLK")) From GESECRAN
        mkstat=1
      Endif
    Endif
  Endif

End

######################################################################################
Subprog C_DEFWCR(VALEUR)
Variable Char    VALEUR()

  If func SFTLIB.VALIDATE_WORK_CENTER([M:SFTD]DEFFCY, VALEUR, [M:SFTD]DEFWST) = [V]CST_ANO
    mkstat=1
    Call ERREUR(mess(27,2422,1)) From GESECRAN
  Endif

End

######################################################################################
Subprog C_DEFWST(VALEUR)
Variable Char    VALEUR()

  If func SFTLIB.VALIDATE_WORK_CENTER([M:SFTD]DEFFCY, [M:SFTD]DEFWCR, VALEUR) = [V]CST_ANO
    mkstat=1
    Call ERREUR(mess(28,2422,1)) From GESECRAN
  Endif

End

