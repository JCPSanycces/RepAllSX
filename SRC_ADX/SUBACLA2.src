######################################################################################
Subprog AVANT_NBRCOL
[M:ACLA1]CODCOLOLD(nolign-1)=[M:ACLA1]CODCOL(nolign-1)
End

Subprog APRES_NBRCOL
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
Local Integer I,WINST
If [M:ACLA1]CODCOL(nolign-1)<>"" & [M:ACLA1]CODCOLOLD(nolign-1)<>"" & [M:ACLA1]CODCOL(nolign-1)<>[M:ACLA1]CODCOLOLD(nolign-1)
  For I=0 To [M]NBRFLD-1
   If [M:ACLA6]FLDGRP(I)=[M:ACLA1]CODCOLOLD(nolign-1)
    If [M:ACLA6]LNKCLA(I)<>"" & [M:ACLA6]FLDCLA(I)=[M:ACLA6]FLDGRP(I)
     WINST=1
     [M:ACLA6]FLDCLA(I) = [M:ACLA1]CODCOL(nolign-1)
     Affzo [M:ACLA6]FLDCLA(I)
    Endif
    [M:ACLA6]FLDGRP(I) = [M:ACLA1]CODCOL(nolign-1)
    Affzo [M:ACLA6]FLDGRP(I)
   Endif
  Next
  If WINST
   For I=0 To [M]NBRLNK-1
    If [M:ACLA3]REFLNK(I)=[M:ACLA1]CODCOLOLD(nolign-1)
     [M:ACLA3]REFLNK(I) = [M:ACLA1]CODCOL(nolign-1)
     Affzo [M:ACLA3]REFLNK(I)
    Elsif left$([M:ACLA3]REFLNK(I),len([M:ACLA1]CODCOLOLD(nolign-1)+"."))=[M:ACLA1]CODCOLOLD(nolign-1)+"."
     [M:ACLA3]REFLNK(I) = [M:ACLA1]CODCOL(nolign-1)+right$([M:ACLA3]REFLNK(I),len([M:ACLA1]CODCOLOLD(nolign-1)+"."))
     Affzo [M:ACLA3]REFLNK(I)
    Endif
   Next
  Endif
Endif
End


Subprog C_NBRCOL
Local Integer I
Case status
 When 65  : # suppression param dans tableau
  I=find([M:ACLA1]CODCOL(nolign-1),[M:ACLA6]FLDGRP)
  If I>0
    GMESSAGE = func AFNC.MES2(mess(89,140,1),num$(I),[M:ACLA6]FLDCLA(I-1))
    mkstat = 2
  Endif
Endcase
End


Subprog C_CODCOL(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>[M:ACLA1]CODCOL(nolign-1)
  # name covention
  #Call PLAGE_ZON([M:ACLA0]CODCLA,VALEUR) From CONTOBJ
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
 Endif
 Call UNICITE(VALEUR,[M:ACLA1]CODCOL(0..[M:ACLA1]NBRCOL-1)) From OBJDIV
 If mkstat : End : Endif
 Local Integer I
 I = find(VALEUR, [M:ACLA6]FLDCLA)
 If I>0 and [M:ACLA6]LNKCLA(I-1)=""
  GMESSAGE = mess(146,143,1) # Code déjà utilisé pour une propriété ou une collection.
  mkstat =2 : End
 Endif
End

