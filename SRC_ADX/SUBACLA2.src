End

Subprog C_WTABREF(VALEUR)
Variable Char    VALEUR()
#93128
Gosub OUVRE_ATAB From SUBACLA
Read [ATB]CODFIC = VALEUR
If !fstat & [ATB]FLG130=2
  GMESSAGE = VALEUR-":"-mess(129,139,1)+"\"+mess(5,124,1)
  mkstat=2 : End
Endif
If VALEUR <> [M:ACLA1]WTABREF & find(GREP,"C","D")=0
 Local Integer I
 I = find(2,[M:ACLA2]FLGOPE)
 If I>0
  Local Integer OK
  Call AVERTIR(mess(178,143,1)+". "+mess(177,143,1)+". "+mess(205,100,1),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
 Endif
Endif
End

