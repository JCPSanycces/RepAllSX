If !fstat
 If !func L_CHECK_PARAMETER([M:ACLA6]FLDCLA(nolign-1),[M:ACLA6]CODTYP(nolign-1),"TABCONT",[M:ACLA6]ACTFLD(nolign-1),VALEUR,[F:ATY]TYPTYP ,2,[M:ACLA6]FLDGRP(nolign-1), [M:ACLA0]CODCLA, 1, L_ERR_MSG)
  GMESSAGE = L_ERR_MSG
  mkstat = 2
 Endif
Endif
End

