Variable Char    VALEUR()
End

Subprog B3_WTABREF(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10) : TYP="AVW"
Gosub JUMP_VIEW_TABLE
End

Subprog B2_WTABREF(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10) : TYP="ATB"
Gosub JUMP_VIEW_TABLE
End

Subprog B1_WTABREF(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10)
If VALEUR<>""
 Local File AVIEW [AVW]
 Read [AVW]AVW0=VALEUR
 If !fstat
  TYP="AVW"
 Else
  TYP="ATB"
 Endif
Else
 TYP="ATB"
Endif
Gosub JUMP_VIEW_TABLE
End

$JUMP_VIEW_TABLE
Gosub CLOSE_ATAB From SUBACLA
# make the jump
If !GWEBSERV
 ## Action GOBJETC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC"
 Call OBJET_CHAR(VALEUR,TYP,"") From GOBJET
 GACTION = SAVACT
Endif
Return

Subprog AM_WTABREF(VALEUR)
Variable Char    VALEUR()
Gosub OUVRE_ATAB From SUBACLA
[M]TABREF= VALEUR
Read [ATB]CODFIC = [M]TABREF
If !fstat
 [M]WINT = mess(56,123,1)
  Actzo [M:ACLA1]FLGSEARCH
  [M]ISTABLE = 2
  [M]CONCATREF = format$("K:"+num$(GLONATB)+"X",[M]TABREF)+[F:ATB]ABRFIC
  [M:ACLA1]MODULE = [ATB]MODULE
  [M:ACLA1]CODACT = [ATB]CODACT
Else
 [M]WINT = mess(77,139,1)
 [M:ACLA1]FLGSEARCH=1 :  Affzo [M:ACLA1]FLGSEARCH : Grizo [M:ACLA1]FLGSEARCH
 [M]ISTABLE = 1
Endif
Affzo [M]WINT
Affzo [M:ACLA1]MODULE
Affzo [M:ACLA1]CODACT
Read [ATI]NUMLIG = [M]TABREF;1
If !fstat & [ATI]HOMONYM=1
 [M]WINDREF      = [F:ATI]CODIND
 [M:ACLA3]INDREF = [F:ATI]CODIND
 [M:ACLA3]AFFIND = [F:ATI]DESCRIPT
 [M:ACLA1]KEYINT = [F:ATI]DESCRIPT
 [M:ACLA1]WTABREF = VALEUR
 Gosub L_UPDATE_PARAM_KEY
 Gosub L_CLEAN_OPE
Endif
Affzo [M:ACLA3]TABREF
Affzo [M:ACLA3]INDREF
Affzo [M:ACLA1]KEYINT
Affzo [M:ACLA3]AFFIND
Grizo [M:ACLA1]KEYINT
Affzo [M]WINDREF

For I=0 To [M:ACLA5]NBMETSTD-1
 If [M:ACLA5]CODMETSTD(I)<>"R"
  [M:ACLA5]ENAMETSTD(I) = 1
 Endif
Next
Affzo  [M:ACLA5]ENAMETSTD
End


Subprog AM_KEYINT(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,4)
Gosub L_CLEAN_OPE
End

# ------------------ AM_WTABREF/AM_KEYINT/AM_TYPCLA internal use only ------------------- #
$L_CLEAN_OPE
Local Integer I, J, L_CLEAN
For I = 0 To [M:ACLA2]NBMET-1
 If [M:ACLA2]FLGOPE(I) = 2
  J = 0
  While J<[M:ACLA7]NBRPARDEF
   If [M:ACLA7]CODE(J)=[M:ACLA2]CODMET(I)
    Dela J,1,[M:ACLA7]NBRPARDEF [M:ACLA7]NBRPARDEF
    [M:ACLA7]NBRPARDEF -= 1
   Else
    J += 1
   Endif
  Wend
 Endif
Next

For I = 0 To [M:ACLA2]NBMET-1
 If [M:ACLA2]FLGOPE(I) = 2
 Dela I,1,[M:ACLA2]NBMET [M:ACLA2]NBMET
  [M:ACLA2]NBMET -= 1
  L_CLEAN = 1
 Endif
Next
If L_CLEAN = 1
 Affzo [M:ACLA2]
 Affzo [M:ACLA7]25
 Call MESSAGE(mess(137,143,1)) From GESECRAN
Endif
Return


# ------------------ AM_TYPCLA internal use only ------------------- #
$L_CLEAN_METHOD
Local Integer I, J, L_CLEAN
For I = 0 To [M:ACLA2]NBMET-1
  J = 0
  While J<[M:ACLA7]NBRPARDEF
   If [M:ACLA7]CODE(J)=[M:ACLA2]CODMET(I)
    Dela J,1,[M:ACLA7]NBRPARDEF [M:ACLA7]NBRPARDEF
    [M:ACLA7]NBRPARDEF -= 1
   Else
    J += 1
   Endif
  Wend
Next
For I = 0 To [M:ACLA2]NBMET-1
 Dela I,1,[M:ACLA2]NBMET [M:ACLA2]NBMET
 [M:ACLA2]NBMET -= 1
 L_CLEAN = 1
Next
If  L_CLEAN
 Affzo [M:ACLA2]
 Affzo [M:ACLA7]
Endif
Return


Subprog C_WINDREF(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
Read [ATI]CODIND = [M]WTABREF;VALEUR
If fstat
 GMESSAGE = mess(207,115,1) : # Index inexistant
 mkstat = 2 : End
Elsif !fstat & [F:ATI]HOMONYM<>1
 GMESSAGE = VALEUR-":"-mess(66,148,1) : # index incompatible
 mkstat = 2 : End
Endif
End

Subprog AM_WINDREF(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
Read [ATI]CODIND = [M]WTABREF;VALEUR
If !fstat
 [M:ACLA1]KEYINT = [F:ATI]DESCRIPT
 [M:ACLA3]INDREF = VALEUR
 [M:ACLA3]AFFIND = [M:ACLA1]KEYINT
 Affzo [M:ACLA1]KEYINT
 Affzo [M:ACLA3]INDREF
 Affzo [M:ACLA3]AFFIND
 [M:ACLA1]WINDREF = VALEUR
 Gosub L_UPDATE_PARAM_KEY
Endif
End

# ------------------ AM_WTABREF/AM_WINDREF internal use only ------------------- #
$L_UPDATE_PARAM_KEY
Local Integer L_I,L_J, L_KEY_UPDATED, L_NOLIGN, FLG_LOAD_FROM_SCREEN
Local Char L_LIST_PRO(250)
For L_I = 0 To [M:ACLA6]NBRFLD-1
 Read [ATY]CODTYP = [M:ACLA6]CODTYP(L_I)
 If !fstat and [F:ATY]CODCLA = [M:ACLA0]CODCLA
  # remove the old keys from [M:ACLA6]20
  For L_J = 0 To [M:ACLA8]WNBRPARALL-1
   If [M:ACLA8]WFLDCLA(L_J) = [M:ACLA6]FLDCLA(L_I) and [M:ACLA8]WTYPKEY(L_J)=2
    Dela L_J,1 [M:ACLA8]WNBRPARALL
    [M:ACLA8]WNBRPARALL-= 1
    L_J-=1
   Endif
  Next
  # prepare for the load
  [M:ACLA6]FLDCUR = [M:ACLA6]FLDCLA(L_I)
  If [M:ACLA6]LOBTAB(L_I)=""
   [M:ACLA6]CODTYPCUR = [M:ACLA6]CODTYP(L_I)
  Else
   [M:ACLA6]CODTYPCUR  = [M:ACLA6]CODTYP(L_I) + "." + [M:ACLA6]LOBTAB(L_I)+ "." + [M:ACLA6]LOBFLD(L_I)
  Endif
  Local Integer FLG_LOAD_FROM_SCREEN
  FLG_LOAD_FROM_SCREEN = 1
  # load the new keys
  Gosub L_LOAD_KEY
  L_KEY_UPDATED = 1
  If len(L_LIST_PRO)+ len([M:ACLA6]FLDCLA(L_I))<250
   L_LIST_PRO -= [M:ACLA6]FLDCLA(L_I)
  Endif
 Endif
Next
If L_KEY_UPDATED
 Call MESSAGE(mess(136,143,1)-":"-L_LIST_PRO) From GESECRAN
Endif
Return

Subprog S_PROCOL(VALEUR)
Variable Char    VALEUR()
 Gosub L_SELECTION_PRO
End

Subprog C_PROCOL(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR="" : End : Endif
K= find(VALEUR, [M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
If K=0
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [M:ACLA6]CODTYP(K-1)
If [ATY]TYPTYP<>2 and [ATY]TYPTYP <> 3
 GMESSAGE = mess(113,127,1) : # Type de donnée incompatible
 mkstat = 2 : End
Endif
End


