Subprog C_CODTYP(VALEUR)
Variable Char    VALEUR()

If [M:ACLA1]FLGBUFFER=2 & VALEUR=""
 GMESSAGE =mess(10,123,1) : # ZONE OBLIGATOIRE
 mkstat = 1 : End
Endif


 #Check ATYPE & LOBTAB+LOBFLD
 Read [ATY]CODTYP=VALEUR
 If !find([M:ACLA1]TYPCLA,3,4)
   If [F:ATY]TYPSELSYR=3 & [F:ATY]TYPPROSYR=""
      #Le prototype est obligatoire pour utiliser un type de données Rich media
      GMESSAGE=mess(249,143,1) : GERR=1 : mkstat=2 : End
#   Elsif [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=1
#     Local Integer J
#     For J=6 To 9
#      Read [ATYR]ATYR0=VALEUR;J
#      If fstat
#        # Les règles $1$ \sont obligatoires pour le type "$2$" sans gestion superviseur
#        GMESSAGE=func AFNC.MES2(mess(163,143,1),
#&               mess(J,7961,1),mess(3,7881,1))
#        GERR=1 : mkstat=2 : Break
#      Endif
#     Next J
#     If mkstat : End : Endif
   Endif
 Endif
End


Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Gosub SET_TYPREF From SUBACLA
If find([M]CODTYP(nolign-1),"",TYPREF) : mkstat = 1 : End : Endif
Read [ATY]CODTYP=[M]CODTYP(nolign-1)
If [F:ATY]TYPTYP<>1 or [F:ATY]NOLIB<>0 : mkstat=1 : End : Endif
End

Subprog AS_LONG(VALEUR)
Variable Decimal VALEUR
Gosub SET_TYPREF From SUBACLA
If find([M]CODTYP(nolign-1),"",TYPREF) : mkstat = 1 : End : Endif
Read [ATY]CODTYP=[M]CODTYP(nolign-1)
If [F:ATY]FORTYP<>"" or [F:ATY]LNGTYP<>0 or find([F:ATY]TYPTYP,8,11,12)
 mkstat=1 : End
Elsif find([F:ATY]TYPTYP,9,10)
 VALEUR=1
 mkstat=2 : End
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
Local Decimal ENTIER , DECIM
If [M]CODTYP(nolign-1)="W" : End : Endif
If VALEUR=0 : mkstat=1 : End : Endif
Read [ATY]CODTYP=[M]CODTYP(nolign-1)
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1  : If DECIM<>0 | ENTIER>50             : mkstat = 1 : Endif : # Libellé
 When 2  : If DECIM<>0 | ENTIER>4              : mkstat = 1 : Endif : # Entier court
 When 3  : If DECIM<>0 | ENTIER>8              : mkstat = 1 : Endif : # Entier long
 When 4  : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat = 1 : Endif : # DCB
 When 7  : If DECIM<>0 | ENTIER>250            : mkstat = 1 : Endif : # Char
# When 8  : If DECIM<>0 | !find(ENTIER,4,6,8)   : mkstat = 1 : Endif : # Date
# When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
# When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

Subprog C_FLDGRP(VALEUR)
Variable Char    VALEUR()

If [M:ACLA6]LNKCLA(nolign-1)<>"" & VALEUR =""
 GMESSAGE = mess(63,140,1)-[M:ACLA6]FLDCLA(nolign-1) : # Collection obligatoire pour un pointeur
 mkstat =2 : End
Endif

Local Integer INDEX, I
If VALEUR <> ""
 INDEX = find(VALEUR, [M:ACLA1]CODCOL)
 If !INDEX
  GMESSAGE = mess(144,143,1) : # Collection inexistante.
  mkstat =2 : End
 Endif

 # check that :
 # a colleciton applied to an instance must have the same code of the instance
 # a collection can not be used both for instance and property
 If [M:ACLA6]LNKCLA(nolign-1)<>"" and VALEUR <> [M:ACLA6]FLDCLA(nolign-1)
  GMESSAGE = mess(150,143,1) : # Collection d'une propriété d'instance doit avoir le même code que le code de la propriété.
  mkstat =2 : End
 Elsif [M:ACLA6]LNKCLA(nolign-1)=""
  For I = 0 To [M:ACLA6]NBRFLD-1
   If (I <> nolign-1) and (VALEUR = [M:ACLA6]FLDGRP(I))
    If [M:ACLA6]LNKCLA(I)<>""
     GMESSAGE = mess(151,143,1) # Collection déjà utilisé pour une propriété d'instance.
     mkstat =2 : End
    Endif
   Endif
  Next
 Endif
Endif
End

Subprog S_FLDGRP(VALEUR)
Variable Char    VALEUR()
Local Char    ZONE(20)
Local Integer NBR, CHOI

If [M:ACLA1]NBRCOL > 0
 Local Char    TEX(GLONDES)(1..[M:ACLA1]NBRCOL,1..2) , TIT(GLONDES)(0..2)
 For I=0 To [M:ACLA1]NBRCOL-1
  NBR+= 1
  TEX(NBR,1) = [M:ACLA1]CODCOL(I)
  TEX(NBR,2) = [M:ACLA1]INTITCOL(I)
 Next
 CHOI = 0
 TIT(0) = mess(22,123,1) # Selection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "FLDGRP") # Collection
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
 If NBR=1
  VALEUR = TEX(1,1)
 Elsif NBR>1
  Call SAITEX_COL_MAX(NBR,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
 Endif
 Endif
End

