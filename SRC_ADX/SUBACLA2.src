  [M]FLGINSCOL(nolign-1)=1 : Affzo [M]FLGINSCOL(nolign-1)  : Grizo [M]FLGINSCOL(nolign-1)
  [M]FLGSUPCOL(nolign-1)=1 : Affzo [M]FLGSUPCOL(nolign-1) : Grizo [M]FLGSUPCOL(nolign-1)
  [M]FLGAPDCOL(nolign-1)=1 : Affzo [M]FLGAPDCOL(nolign-1) : Grizo [M]FLGAPDCOL(nolign-1)
  [M]FLGTRICOL(nolign-1)=1 : Affzo [M]FLGTRICOL(nolign-1)  : Grizo [M]FLGTRICOL(nolign-1)
Endif
End

