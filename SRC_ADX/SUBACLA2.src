Subprog AS_RANTRT(VALEUR)
Variable Decimal VALEUR
If func SUBACLA2.TRT_ISRESERVED([M:ACLA1]MODULE,[M:ACLA1]TYPTRT(nolign-1),[M:ACLA1]CODTRT(nolign-1),[M:ACLA1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
If VALEUR<>0 : End : Endif
If nolign=1
 If GADONIX=2 & [M:ACLA1]TYPTRT(nolign-1)=1 : VALEUR = 1000 : Else : VALEUR = 1100 : Endif
Elsif nolign>=2
 VALEUR = [M]RANTRT(nolign-2)+100
 If VALEUR=1000 & [M:ACLA1]TYPTRT(nolign-1)<>1 : VALEUR = 1100 : Endif
Endif
End

