#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet ACLA2
Raz GPILOBJ , GNBMASKOUV
GPRODUIT = 0
GBIDC1 = "AOBJETS"
Call OBJET("ACLA",GBIDC1,GBIDC2) From GOBJET

End

$ACTION
Case ACTION
 When Default
Endcase
Return

Gosub ACLA0 : # ACLA3 Entete
Gosub ACLA1 : # ACLA1 general
Gosub ACLA2 : # ACLA2 Méthodes
Gosub ACLA5 : # ACLA5 met std
Gosub ACLA3 : # ACLA3 mapping
Gosub ACLA6 : # ACLA6 propriétés
Gosub ACLA4 : # ACLA4 Divers

######################################################################################
## écran ACLA0
######################################################################################
$ACLA0
Return

Subprog C_CODCLA(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
## écran ACLA3
######################################################################################
$ACLA3
Return

Subprog AS_NBRLNK
Effzo  [M:ACLA3]45
If [M:ACLA0]CODCLA="" | [M]REFLNK(nolign-1)=""
 Chgstl [M:ACLA3]NBRLNK With ""
 Raz [M:ACLA3]REFLNKCUR
 End
Endif
[M:ACLA3]REFLNKCUR = [M:ACLA3]REFLNK(nolign-1)
Gosub ADD_KEYPROMAP
Chgstl [M:ACLA3]NBRLNK With ""
Chgstl [M:ACLA3]NBRLNK(nolign-1) With "AMKCUR"
End

$ADD_KEYPROMAP
 Local Integer I,J
 Local Char CHAINE(250),CHAINE2(250),CLA(GLONACLA),SCLA(GLONACLA)
 CHAINE = [M:ACLA3]REFLNKCUR
 I = instr(1,CHAINE,".")
 While I>0
  If CHAINE2<>"" : CHAINE2+= "." : Endif
  CHAINE2 += left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
  I = instr(1,CHAINE,".")
 Wend
 J=find(CHAINE2,[M:ACLA3]REFLNK)
 If CHAINE2<>"" & J>0
  SCLA= [M:ACLA3]CLALNK(J-1)
 Else
  SCLA = [M:ACLA0]CODCLA
 Endif
 If CHAINE2<>"" : CHAINE2+= "." : Endif
 CHAINE2 += CHAINE
 J=find(CHAINE2,[M:ACLA3]REFLNK)
 If CHAINE2<>"" & J>0
  CLA= [M:ACLA3]CLALNK(J-1)
 Else
  CLA = [M:ACLA0]CODCLA
 Endif
Raz [M:ACLA3]NBRPROMAP
For I=0 To [M:ACLA3]WNBRPROMAP-1
 If [M:ACLA3]WREFLNK(I)=[M:ACLA3]REFLNKCUR
  [M:ACLA3]CLAORIMAP([M:ACLA3]NBRPROMAP) = CLA
  [M:ACLA3]CLAMAP([M:ACLA3]NBRPROMAP) = SCLA
  [M:ACLA3]TYPMAP([M:ACLA3]NBRPROMAP) = [M:ACLA3]WTYPMAP(I)
  [M:ACLA3]KEYMAP([M:ACLA3]NBRPROMAP) = [M:ACLA3]WKEYMAP(I)
  [M:ACLA3]PROMAP([M:ACLA3]NBRPROMAP) = [M:ACLA3]WPROMAP(I)
  [M:ACLA3]VALDEFMAP([M:ACLA3]NBRPROMAP) = [M:ACLA3]WVALDEFMAP(I)
  [M:ACLA3]NBRPROMAP += 1
 Endif
Next
Affzo [M:ACLA3] 45
Return

Subprog APRES_NBRLNK

End

Subprog C_NBRLNK
Local Integer I
Case status
 When 65  : # suppresion param dans tableau
  If [M]ABRLNK(nolign-1)=""
   Gosub OUVRE_ATAB From SUBACLA
   Read [ATB]CODFIC = [M]TABLNK(nolign-1)
   CHAINE = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(nolign-1))+[F:ATB]ABRFIC
  Else
   CHAINE = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(nolign-1))+[M]ABRLNK(nolign-1)
  Endif
  I= find(CHAINE,[M]CONCATLNK(0..dim([M]CONCATLNK)-1))
  If I>0
   Dela I-1,1 [M:ACLA3]CONCATLNK
  Endif

Endcase
End

Subprog AM_FLGA(VALEUR)
Variable Integer VALEUR
End

Subprog C_TABREF(VALEUR)
Variable Char    VALEUR()
Gosub OUVRE_ATAB From SUBACLA
Read [ATB]CODFIC = VALEUR
If !fstat
 [M]CONCATREF = format$("K:"+num$(GLONATB)+"X",[M]TABREF)+[F:ATB]ABRFIC
Endif
End

Subprog AM_TABREF(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
Read [ATI]NUMLIG = VALEUR;1
If !fstat
 [M:ACLA3]INDREF = [F:ATI]CODIND
 [M:ACLA3]AFFIND = [F:ATI]DESCRIPT
 Affzo [M:ACLA3]INDREF
 Affzo [M:ACLA3]AFFIND
Endif
End

Subprog AS_TABLNK(VALEUR)
Variable Char    VALEUR()
If [M:ACLA3]CLALNK(nolign-1)="" : mkstat = 1 : End : Endif
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
Read [ACLA]ACLA0 = [M:ACLA3]CLALNK(nolign-1)
If !fstat & [F:ACLA]TYPCLA=2
 mkstat = 2 : End
Endif
End

Subprog C_TABLNK(VALEUR)
Variable Char    VALEUR()
#93128
Gosub OUVRE_ATAB From SUBACLA
Read [ATB]CODFIC = VALEUR
If !fstat & [F:ATB]FLG130=2
  # Table en version 130 - Table non accessible
  GMESSAGE = VALEUR-":"-mess(129,139,1)+"\"+mess(5,124,1)
  mkstat=2 : End
Endif
End

Subprog B1_TABLNK(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10)
If VALEUR<>""
 Local File AVIEW [AVW]
 Read [AVW]AVW0=VALEUR
 If !fstat
  TYP="AVW"
 Else
  TYP="ATB"
 Endif
Else
 TYP="ATB"
Endif
Gosub JUMP_VIEW_TABLE
End

Subprog B2_TABLNK(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10) : TYP="ATB"
Gosub JUMP_VIEW_TABLE
End

Subprog B3_TABLNK(VALEUR)
Variable Char    VALEUR()
Local Char TYP(10) : TYP="AVW"
Gosub JUMP_VIEW_TABLE
End

Subprog C_ABRLNK(VALEUR)
Variable Char    VALEUR()
Local Char TABLE(GLONATB)
Local Integer NOL
NOL = nolign-1
TABLE = [M]TABLNK(nolign-1)
Gosub CONT_ABRLNK
End

$CONT_ABRLNK
Gosub OUVRE_ATAB From SUBACLA
Local Integer I
If VALEUR=""
 Read [ATB]CODFIC = TABLE
 [M]CONCATLNK(NOL) = format$("K:"+num$(GLONATB)+"X",TABLE)+[F:ATB]ABRFIC
Else
 [M]CONCATLNK(NOL) = format$("K:"+num$(GLONATB)+"X",TABLE)+VALEUR
Endif
I = find([M]CONCATLNK(NOL),[M]CONCATLNK(0..NOL-1),[M]CONCATLNK(NOL+1..dim([M]CONCATLNK)-1))
If I
 GMESSAGE = [M]CONCATLNK(NOL)-":"-mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat = 2 : Return
Elsif [M]CONCATLNK(NOL)=[M]CONCATREF
 GMESSAGE = mess(94,139,1) : # Déjà utilisé
 mkstat = 2 : Return
Endif
If VALEUR<>""
 Read [ATB]CODFIC = [M]TABREF
 If VALEUR=[F:ATB]ABRFIC
  GMESSAGE = VALEUR-":"-mess(94,139,1) : # Déjà utilisé
  mkstat = 2 : Return
 Else
  Call UNICITE(VALEUR,[M]ABRLNK) From OBJDIV
  If mkstat : Return : Endif
 Endif
Endif
Return

Subprog AS_TABORI(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABFIL
If VALEUR=""
 Local Char CHAINE(250),CHAINE2(250)
 Local Integer I
 CHAINE = [M]REFLNK(nolign-1)
 I=instr(1,CHAINE,".")
 If I>0
   While I>0
   CHAINE2 += string$(CHAINE2<>"",".")+left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
   I=instr(1,CHAINE,".")
  Wend
  If find(CHAINE2,[M]REFLNK(0..[M]NBRLNK-1))>0
   VALEUR =[M]TABLNK(find(CHAINE2,[M]REFLNK(0..[M]NBRLNK-1))-1)
  Endif
 Else
  VALEUR = [M]TABREF
 Endif
Endif
End

$CHARGE_TABFIL
Local Integer NB
Raz [M]TABFIL, ABRFIL
[M]TABFIL(0) = [M]TABREF
Gosub OUVRE_ATAB From SUBACLA
Read [ATB]CODFIC = [M]TABREF
[M]ABRFIL(0) = [F:ATB]ABRFIC
For I=1 To [M]NBRLNK
 If [M]TABLNK(I-1)<>[M]TABLNK(nolign-1)
  NB += 1
  [M]TABFIL(NB) = [M]TABLNK(I-1)
  If [M]ABRLNK(I-1)<>""
   [M]ABRFIL(NB) = [M]ABRLNK(I-1)
  Else
   Read [ATB]CODFIC = [M]TABLNK(I-1)
   [M]ABRFIL(NB) = [F:ATB]ABRFIC
  Endif
 Endif
Next I
Return

Subprog C_TABORI(VALEUR)
Variable Char    VALEUR()
#93128
Gosub OUVRE_ATAB From SUBACLA
Read [ATB]CODFIC = VALEUR
If !fstat & [F:ATB]FLG130=2
  GMESSAGE = VALEUR-":"-mess(129,139,1)+"\"+mess(5,124,1)
  mkstat=2 : End
Endif
Local Char TABLE (GLONATB)
TABLE = [M]TABLNK(nolign-1)
Gosub CONT_TABORI
End

$CONT_TABORI
If !find(VALEUR,[M]TABREF,[M]TABLNK)
 GMESSAGE = mess(93,139,1) : # Table non référencée
 mkstat = 2
Elsif VALEUR=TABLE
 #GMESSAGE = mess(97,139,1) : # Lien impossible sur la même table
 #mkstat = 2
Endif
Return

Subprog AS_ABRORI(VALEUR)
Variable Char    VALEUR()
If [M]TABORI(nolign-1) = [M]TABREF : VALEUR ="" : mkstat = 1 : Endif
End

Subprog C_ABRORI(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char AABREV(GLONABR),AABREV2(GLONABR)
Gosub OUVRE_ATAB From SUBACLA
Read [F:ATB]CODFIC = [M]TABORI(nolign-1)

# cas table ref
If [M]TABORI(nolign-1) = [M]TABREF & VALEUR = ""  : End : Endif
If [M]TABORI(nolign-1) = [M]TABREF & AABREV <> ""
 If [ATB]ABRFIC = VALEUR : End : Endif
 GMESSAGE = AABREV-":"-mess(285,139,1)-TABLE : # Abréviation non paramétrée pour la table
 mkstat = 2 : End
Endif

# cas table ligne
OK = 0
If VALEUR=""
 AABREV = [F:ATB]ABRFIC
Else
 AABREV = VALEUR
Endif

For I=0 To [M]NBRLNK-1
 If [M]ABRLNK(I)=""
  AABREV2 = [F:ATB]ABRFIC
 Else
  AABREV2 = [M]ABRLNK(I)
 Endif
 If [M]TABLNK(I)=[M]TABORI(nolign-1) & AABREV2=AABREV
  OK =1
  Break
 Endif
Next
If !OK
 GMESSAGE = AABREV-":"-mess(285,139,1)-[M]TABORI(nolign-1): # Abréviation non paramétrée pour la table
 mkstat = 2 : End
Endif
End

