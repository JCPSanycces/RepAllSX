#If func SUBACLA2.TRT_ISRESERVED([M:ACLA1]MODULE,[M:ACLA1]TYPTRT(nolign-1),[M:ACLA1]CODTRT(nolign-1),[M:ACLA1]ACTTRT(nolign-1))
#  mkstat = 2 : End
#Endif
End

Subprog C_NBRTRT
Case status
 When 65,83  : # suppressions
  If func SUBACLA2.TRT_ISRESERVED([M:ACLA1]MODULE,[M:ACLA1]TYPTRT(nolign-1),[M:ACLA1]CODTRT(nolign-1),[M:ACLA1]ACTTRT(nolign-1))
    GMESSAGE=mess(244,143,1)
    mkstat = 2 : End
  Endif
Endcase
End

