# etiquette for local use only
$L_SELECTION_PRO
 Local Integer NBFLD, CHOI,I,OK
 Local Char    TEX(GLONDES)(1..3000,1..3) , TIT(GLONDES)(0..3)

 For I = 0 To [M:ACLA6]NBRFLD-1
  If [M:ACLA6]FLDGRP(I) = "" and [M:ACLA6]LNKCLA(I) = ""
   NBFLD+= 1
   TEX(NBFLD,1) = [M:ACLA6]FLDCLA(I)
   TEX(NBFLD,2) = [M:ACLA6]ZINTFLD(I)
   TEX(NBFLD,3) = [M:ACLA6]CODTYP(I)
  Endif
 Next

 CHOI = 0
 TIT(0)=mess(8,31,1) # Sélection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "FLDCLA")  # Propriété
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "CODTYP")  # Type

 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Return

