Subprog AS_LOBTAB(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If !find([M:ACLA1]TYPCLA,3,4)
  If [M:ACLA6]CODTYP(NOL)<>""
    Read [ATY]CODTYP=[M:ACLA6]CODTYP(NOL)
    If fstat = 0
      If [F:ATY]TYPSELSYR<>3 : mkstat=1 : End : Endif
      If [F:ATY]SUPFLG<>2 : mkstat=1 : End : Endif
    Endif
  Else
    mkstat =1
  Endif
Else
  mkstat=1
Endif
End

Subprog C_LOBTAB(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_LOBFLD(VALEUR)
