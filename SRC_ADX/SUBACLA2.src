Subprog IB_CODTYP
Local Integer OKLIS : [L]OKLIS=0
 Read [ATY]CODTYP=[M]CODTYP(nolign-1)
 If !fstat & [F:ATY]TYPPROSYR<>""
  Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
  If !fstat & [F:ATYP]LISFLG=2
   [L]OKLIS=1
  Endif
 Endif
 If [L]OKLIS<>1
  Raz GBOUT2
 Endif
End

