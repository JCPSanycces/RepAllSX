Subprog C_REFLNK(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR=""
 [M]CLALNK(nolign-1)= "" : [M:ACLA3]FLGC(nolign-1) = 1 : [M:ACLA3]FLGU(nolign-1) = 1 : [M:ACLA3]FLGD(nolign-1) = 1 : Affzo [M:ACLA3]ABRFIL : End
Else
 # Issue 83200/2 - 2012-10-02 by VPO : unicité de REFLNK
 Call UNICITE(VALEUR,[M]REFLNK) From OBJDIV
 If mkstat : End : Endif
 Local Char TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50)
 Local Integer NBCLA,ISACTX
 Call DECODE_PRO(VALEUR,1,"PTR",nomap,"","",[M]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA=0 :  GMESSAGE=mess(83,123,1)  : mkstat =2 : End : Endif : # : VALEUR INCORRECTE
 [M]CLALNK(nolign-1) = TABCLA(NBCLA)
 Read [ACLA]ACLA0 = [M]CLALNK(nolign-1)
 If !fstat & [F:ACLA]TYPCLA=2
  [M]TABLNK(nolign-1) = [F:ACLA]TABREF
 Endif
 Affzo [M]CLALNK(nolign-1) : Affzo [M:ACLA3]TABLNK(nolign-1)
Endif
End

Subprog AM_REFLNK(VALEUR)
Variable Char    VALEUR()
[M:ACLA3]REFLNKCUR = VALEUR
End

Subprog C_TYPLNK(VALEUR)
Variable Integer VALEUR
Local Integer I,WMINI,WMAXI
Local Char WCODCOL(GLONAVB)
If instr(1,[M:ACLA3]REFLNK(nolign-1),".")>0
 Local Char TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50)
 Local Integer NBCLA,ISACTX
 Call DECODE_PRO([M:ACLA3]REFLNK(nolign-1),1,"PTR",nomap,"","",[M]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA=0 : End : Endif
 Read [ACLAF]ACLAF0 = TABCLA(NBCLA-1);TABPTR(NBCLA)
 If !fstat
  If [F:ACLAF]FLDGRP<>""
   Read [ACLAC]ACLAC0 =  [F:ACLAF]CODCLA;[F:ACLAF]FLDGRP
   If !fstat
    WCODCOL =  [ACLAC]CODCOL
    WMINI = [ACLAC]MINCOL-1
    WMAXI = [ACLAC]MAXCOL
   Endif
  Endif
 Endif
Else
 I = find([M:ACLA3]REFLNK(nolign-1),[M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
 If I>0
  I = find([M:ACLA6]FLDCLA(I-1),[M:ACLA1]CODCOL(0..[M:ACLA1]NBRCOL-1))
  If I>0
   WCODCOL = [M:ACLA1]CODCOL(I-1)
   WMINI = [M:ACLA1]MINCOL(I-1)-1
   WMAXI = [M:ACLA1]MAXCOL(I-1)
  Endif
 Endif
Endif
Case VALEUR
 When 1 : # 0..1
  If WMINI<>0 or WMAXI<>1 : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT
 When 2 : # 0..n
  If WCODCOL="" : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT
  If WMINI=1  : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT
  If WMAXI=1 : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT

 When 3 : # 1..1
  If WMINI<>1 or WMAXI<>1 : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT

 When 4 : # 1..n
  If WCODCOL="" : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT
  If WMINI=0  : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT
  If WMAXI=1 : GMESSAGE = mess(98,139,1)  :  mkstat = 2 : End : Endif : # : type DE LIEN INCORRECT

Endcase
End

Subprog AS_REFLNK(VALEUR)
Variable Char    VALEUR()
End

Subprog S_PROMAP(VALEUR)
Variable Char    VALEUR()
Call SEL_PROFROMCLASSE(VALEUR, [M:ACLA3]CLAMAP(nolign-1))
End


Subprog S_REFLNK(VALEUR)
Variable Char    VALEUR()
Call SEL_REFLNK(VALEUR,1)
End

Subprog SEL_REFLNK(VALEUR,TYPSEL)
Variable Char    VALEUR()
Value Integer TYPSEL
Local Integer NBFLD, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..4) , TIT(GLONDES)(0..4) ,CRITERE(250),WFLD(GLONACLA)
Local Char TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50)
Local Integer NBCLA,ISACTX,CRITERIA(50)


If VALEUR<>""
 Call DECODE_PRO(VALEUR,1,"PTR",nomap,"","",[M]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA=0 : VALEUR="" : Endif
Endif
If VALEUR = ""
 For I=0 To [M:ACLA6]NBRFLD-1
  If ([M:ACLA6]FLDCLA(I)<>"" & TYPSEL=0 & [M:ACLA6]CODTYP(I)<>"" ) or ([M:ACLA6]FLDCLA(I)<>"" & TYPSEL>0 & [M:ACLA6]CODTYP(I)="")
   NBFLD+= 1
   TEX(NBFLD,1) = [M:ACLA6]FLDCLA(I)
   TEX(NBFLD,2) = [M:ACLA6]ZINTFLD(I)
   TEX(NBFLD,3) = [M:ACLA0]CODCLA
   TEX(NBFLD,4) = [M:ACLA6]LNKCLA(I)
  Endif
 Next
Else
 For [F:ACLAF]ACLAF0 Where CODCLA=TABCLA(NBCLA) & FLDCLA<>""
  If (TYPSEL>0 & [F:ACLAF]CODTYP="") or (TYPSEL=0 & [F:ACLAF]CODTYP<>"")
   NBFLD+= 1
   TEX(NBFLD,1) = [F:ACLAF]FLDCLA
   Call TEXTE([F:ACLAF]INTFLD,TEX(NBFLD,2)) From OBJDIV
   TEX(NBFLD,3) = [F:ACLAF]CODCLA
   TEX(NBFLD,4) = [F:ACLAF]LNKCLA
  Endif
 Next
Endif
CHOI = 0
TIT(0)=mess(8,31,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "FLDCLA")  # Propriété
TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA0", "CODCLA")  # Code class
TIT(4)=mess(58,140,1) # Pointeur vers

If NBFLD=0 & VALEUR<>""
 [M]CLALNK(nolign-1) = TABCLA(NBCLA)
Else
 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  J = 0
  For [ACLAF]ACLAF0 Where CODCLA=TEX(CHOI,4) & FLDCLA<>"" :#& CODTYP=""
   If (TYPSEL>0 & [F:ACLAF]CODTYP="") or (TYPSEL=0 & [F:ACLAF]CODTYP<>"")
    J+=1 : Break
   Endif
  Next
  VALEUR = ""
  For I=1 To NBCLA
   VALEUR += string$(VALEUR<>"",".")+TABPTR(I)
  Next
  VALEUR += string$(VALEUR<>"",".")+TEX(CHOI,1)
  [M]CLALNK(nolign-1) = TEX(CHOI,4)
  If J
   Call SEL_REFLNK(VALEUR,TYPSEL)
  Endif
 Endif
Endif
End



Subprog AS_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Char TABLE (GLONATB)
TABLE = [M]TABLNK(nolign-1)
Gosub ASCLELNK
End

Subprog AM_CLELNK(VALEUR)
Variable Char    VALEUR()
[M:ACLA3]CLELNK(nolign-1) = VALEUR
Gosub DEL_LNKCURMAP
Gosub ADD_LNKCURMAP
Gosub ADD_KEYPROMAP
End

$ADD_LNKCURMAP
If [M:ACLA3]REFLNKCUR="" : Return : Endif
If !clalev([F:ATZ]) : Local File AVIEWFLD [ATZ] : Endif

Local Char INDFLD(GLONAVA)(1..16)
Local Integer NBCLE,OKADD
OKADD = 1
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
Read [ATI]CODIND =[M:ACLA3]TABLNK(nolign-1);[M:ACLA3]CLELNK(nolign-1)
If !fstat
 Call SETCLE([L]NBCLE,[L]INDFLD,[F:ATI]DESCRIPT) From LNKSUB
 For I=1 To [L]NBCLE
  Read [ATZ]CODZONE = [M:ACLA3]TABLNK(nolign-1) ;[L]INDFLD(I)
  If fstat
   Raz OKADD
   Break
  Endif
 Next
 If OKADD>0
  For I=1 To [L]NBCLE
   Read [ATZ]CODZONE = [M:ACLA3]TABLNK(nolign-1) ;[L]INDFLD(I)
   If !fstat
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat
     [M:ACLA3]WTYPMAP([M:ACLA3]WNBRPROMAP) =  [F:ATY]TYPTYP
     [M:ACLA3]WREFLNK([M:ACLA3]WNBRPROMAP) = [M:ACLA3]REFLNKCUR
     [M:ACLA3]WKEYMAP([M:ACLA3]WNBRPROMAP) = [L]INDFLD(I)
 #    Read [ACLAF]ACLAF0 = [M:ACLA3]CLALNK(nolign-1); [L]INDFLD(I)
 #    If !fstat
 #     [M:ACLA3]WPROORIMAP([M:ACLA3]WNBRPROMAP) = [L]INDFLD(I)
 #    Endif
     [M:ACLA3]WNBRPROMAP += 1
    Endif
   Endif
  Next
 Endif
Endif
Affzo [M:ACLA3]50
Return

$DEL_LNKCURMAP
If [M:ACLA3]REFLNKCUR="" : Return : Endif
For I=0 To [M:ACLA3]WNBRPROMAP-1
 If [M:ACLA3]WREFLNK(I) =  [M:ACLA3]REFLNKCUR
  Dela I,1 [M:ACLA3]WNBRPROMAP
  [M:ACLA3]WNBRPROMAP -= 1
  I-=1
 Endif
Next
Return

$ASCLELNK
If VALEUR=""
 If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
 Read [ATI]NUMLIG = TABLE;1
 If !fstat
  VALEUR = [F:ATI]CODIND
 Endif
Endif
Return

Subprog C_CLELNK(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
 Read [ATI]CODIND = [M]TABLNK(nolign-1);VALEUR
 If fstat
  GMESSAGE =  VALEUR-":"-mess(23,100,1)
  mkstat = 2 : End
 Elsif !fstat & [ATI]HOMONYM=2
  GMESSAGE = VALEUR-":"-mess(66,148,1) : # CLÉ AVEC HOMONYMES
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_CLESORT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
 Read [ATI]CODIND = [M]TABLNK(nolign-1);VALEUR
 If fstat
  GMESSAGE =  VALEUR-":"-mess(23,100,1)
  mkstat = 2 : End
 Elsif !fstat & [ATI]HOMONYM=2
  GMESSAGE = VALEUR-":"-mess(66,148,1) : # CLÉ AVEC HOMONYMES
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_CLESORT(VALEUR)
Variable Char    VALEUR()
If !find([M:ACLA3]TYPLNK(nolign-1),2,4) : mkstat = 1 : End : Endif
End

Subprog AS_EXPLNK(VALEUR)
Variable Char    VALEUR()
Gosub OUVRE_ATAB From SUBACLA
Local Char    CHAINE(80) , ZONE(80) , ABR(GLONABR) , CLE(GLONANX)
Local Integer NB , I
Local Integer OK , K
If VALEUR=""
 If find([M:ACLA3]TYPLNK(nolign-1),2,4)
  If [M:ACLA3]CLESORT(nolign-1)<>""
   [L]CLE = [M]CLESORT(nolign-1)
  Else
   [L]CLE = [M]CLELNK(nolign-1)
  Endif
 Else
  [L]CLE = [M]CLELNK(nolign-1)
 Endif
 Read [ATI]CODIND = [M]TABLNK(nolign-1);[L]CLE
 If !fstat
  Filter [ATZ] Where LIEN=[M]TABLNK(nolign-1) & CODFIC=[M]TABORI(nolign-1)
  Read [ATZ]LIEN First
  Filter [ATZ]
  If !fstat
   K = find([M]TABORI(nolign-1),[M]TABLNK)
   If K & [M]ABRLNK(K-1)<>""
    ABR = [M]ABRLNK(K-1)
   Else
    Read [ATB]CODFIC = [M]TABORI(nolign-1)
    ABR = [F:ATB]ABRFIC
   Endif
   Gosub ASEXPLNK
  Endif
 Endif
Endif
Gosub CHARGE_TABFIL
End

$ASEXPLNK
If [F:ATZ]EXPLIEN<>""
 CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
 VALEUR = ""
 Repeat
  K = instr(K,CHAINE,";")
  If K
   ZONE   = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   ZONE   = CHAINE
   CHAINE = ""
  Endif
  If VALEUR<>"" : VALEUR += ";" : Endif
  If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
   VALEUR += "[F:"+ABR+"]"+ZONE
  Else
   VALEUR += ZONE
  Endif
 Until CHAINE = ""
Else
 VALEUR = "[F:"+ABR+"]"+[F:ATZ]CODZONE
Endif
Return

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer ASTATUS
 ASTATUS = func ASYRLNKSUB.CONTROLE_ABR([M]TABFIL,[M]ABRFIL,[M]TABORI(nolign-1),[M]TABLNK(nolign-1)
&                 ,[M]CLELNK(nolign-1),[M]TYPLNK(nolign-1),VALEUR,GMESSAGE)
 If ASTATUS=0 : mkstat = 2 : End : Endif
Endif
End

Subprog AS_EXPSEL(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATB])  : Local File AVIEWTAB [ATB] : Endif
Raz [M]TABFIL, ABRFIL
[M]TABFIL(0) = [M]TABLNK(nolign-1)
If [M]ABRLNK(nolign-1)<>""
 [M]ABRFIL(0) = [M]ABRLNK(nolign-1)
Else
 Read [ATB]CODFIC = [M]TABFIL(0)
 [M]ABRFIL(0) = [F:ATB]ABRFIC
Endif
[M]HLPFOR(0) = "[F:"+[M]ABRFIL(0)+"]"+[M]TABFIL(0)
End

Subprog C_EXPSEL(VALEUR)
Variable Char    VALEUR()
If func SUBASW2.CONTROL_SDATA(VALEUR,GMESSAGE)=0
 mkstat =2 : End
Endif
End

Subprog AS_FLGA(VALEUR)
Variable Integer VALEUR
If [M:ACLA3]CLALNK(nolign-1)="" : mkstat = 1 : End : Endif
If [M:ACLA3]CLALNK(nolign-1)=[M:ACLA0]CODCLA : mkstat = 1 : End : Endif
Read [ACLA]ACLA0 = [M:ACLA3]CLALNK(nolign-1)
If fstat or (!fstat & !find([F:ACLA]TYPCLA,2,5))
 mkstat = 1 : End
Elsif !fstat & find([F:ACLA]TYPCLA,2,5)>0
 VALEUR =2
 mkstat = 2
Endif
End

Subprog AS_FLTREF(VALEUR)
Variable Char    VALEUR()
If [M:ACLA3]TABREF=""
    [S]mkstat=1
Endif
End

Subprog C_FLTREF(VALEUR)
Variable Char    VALEUR()
If func SUBASW2.CONTROL_SDATA(VALEUR,GMESSAGE)=0
 mkstat =2 : End
Endif
End

Subprog AS_FLGV(VALEUR)
Variable Integer VALEUR
If !clalev([F:ATB])  : Local File AVIEWTAB [ATB] : Endif
Read [ATB]CODFIC = [M]TABLNK(nolign-1)
If [M:ACLA3]FLGA(nolign-1) = 2 or [F:ATB]ISTABLE<>2 : mkstat = 1 : End : Endif
Local Char PATH(250),PATH2(250)
Local Integer I
PATH2 = [M:ACLA3]REFLNK(nolign-1)
I = instr(1,PATH2,".")
While I>0
 PATH += string$(PATH<>"",".")+left$(PATH2,I-1)
 PATH2 = right$(PATH2,I+1)
 I = instr(1,PATH2,".")
Wend
For I=0 To [M:ACLA3]NBRLNK-1
 If [M:ACLA3]REFLNK(I)=[L]PATH
  If [M:ACLA3]FLGV(I)=2
   VALEUR = 2
   mkstat = 2
   Break
  Endif
 Endif
Next
End

Subprog AM_FLGV(VALEUR)
Variable Integer VALEUR
End

Subprog AS_FLGR(VALEUR)
Variable Integer VALEUR
 If !clalev([F:ATB])  : Local File AVIEWTAB [ATB] : Endif
 Local Integer OK
 OK = 1
 # 1st check : if this CRUD is activated for the current class
 Call L_CHECK_CURCLA_CRUD("R", OK)
 If OK and [M:ACLA3]FLGA(nolign-1) = 2
  # 2nd check : if this CRUD is activated for the linked class
  Call L_CHECK_LNKCLA_CRUD([M:ACLA3]CLALNK(nolign-1), "R", OK)
 Endif
 # if any of the above checks failed, this field is disabled.
 If !OK : mkstat = 1 : End : Endif
End

Subprog AS_FLGC(VALEUR)
Variable Integer VALEUR
 Local Integer OK
  If !clalev([F:ATB])  : Local File AVIEWTAB [ATB] : Endif

 OK = 1
 # 1st check : if linked Class is filled
 If [M:ACLA3]CLALNK(nolign-1)=""
  OK = 0
 Else
  # 2nd check : if this CRUD is activated for the current class
  Call L_CHECK_CURCLA_CRUD("C", OK)
  If OK and [M:ACLA3]FLGA(nolign-1) = 2
   # 3rd check : if this CRUD is activated for the linked class
   Call L_CHECK_LNKCLA_CRUD([M:ACLA3]CLALNK(nolign-1), "C", OK)
  Endif
 Endif
 Read [ATB]CODFIC = [M]TABLNK(nolign-1)
 If [F:ATB]ISTABLE<>2
  OK = 0
 Endif
 # if any of the above checks failed, this field is disabled.
 If !OK : mkstat = 1 : End : Endif
End



