 If VALEUR <> "" and [M:ACLA1]CODCOL(nolign-1)<>""
  Read [ACV]CODACT = VALEUR
  If fstat
   # Code activité inexistant
   GMESSAGE = VALEUR+": "+mess(22,150,1)
   mkstat =2 : End
