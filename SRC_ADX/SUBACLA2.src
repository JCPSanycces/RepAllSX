#If [M]CODCLE(nolign-1) = "" : mkstat=1 : Endif
End

Subprog C_NBCLE
End

Subprog C_VALCLE(VALEUR)
Variable Char    VALEUR()
Local Char L_ERR_MSG(250), L_PARCOL(30)
Local Integer I
I = find([M:ACLA6]FLDCUR, [M:ACLA6]FLDCLA)
If I>0
 L_PARCOL = [M:ACLA6]FLDGRP(I-1)
 If !func L_CHECK_PARAMETER([M:ACLA6]FLDCLA(I-1),[M:ACLA6]CODTYP(I-1),[M:ACLA6]CODCLE(nolign-1),[M:ACLA6]ACTFLD(I-1),VALEUR, [M:ACLA6]TYPCLE(nolign-1), 2, L_PARCOL, [M:ACLA0]CODCLA, 1, L_ERR_MSG)
  GMESSAGE = L_ERR_MSG
  mkstat = 2
 Endif
Endif
End

