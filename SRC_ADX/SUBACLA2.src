Subprog AS_CODTRT(VALEUR)
Variable Char    VALEUR()
If func SUBACLA2.TRT_ISRESERVED([M:ACLA1]MODULE,[M:ACLA1]TYPTRT(nolign-1),[M:ACLA1]CODTRT(nolign-1),[M:ACLA1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
If VALEUR=""
 VALEUR = [M:ACLA0]CODCLA+string$([M]NBRTRT>0,num$([M]NBRTRT))
 Case [M:ACLA1]TYPTRT(nolign-1)
  When 1  : VALEUR += "_CSTD"
  When 2  : VALEUR += "_CVER"
  When 3  : VALEUR += "_CSPE"
 Endcase
Endif
End

