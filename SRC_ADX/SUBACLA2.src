Subprog AS_VALDEFMAP(VALEUR)
Variable Char    VALEUR()
If [M]PROMAP(nolign-1)<>""
 mkstat =1 : End
Endif
End

Subprog AM_PROMAP(VALEUR)
Variable Char    VALEUR()
For I=0 To [M:ACLA3]WNBRPROMAP-1
 If [M:ACLA3]WREFLNK(I)=[M:ACLA3]REFLNKCUR & [M:ACLA3]WKEYMAP(I)=[M:ACLA3]KEYMAP(nolign-1)
  [M:ACLA3]WPROMAP(I) = VALEUR
  Affzo [M:ACLA3]WPROMAP
 Endif
Next
End

Subprog AM_VALDEFMAP(VALEUR)
Variable Char    VALEUR()
For I=0 To [M:ACLA3]WNBRPROMAP-1
 If [M:ACLA3]WREFLNK(I)=[M:ACLA3]REFLNKCUR & [M:ACLA3]WKEYMAP(I)=[M:ACLA3]KEYMAP(nolign-1)
  [M:ACLA3]WVALDEFMAP(I) = VALEUR
  Affzo [M:ACLA3]WVALDEFMAP
 Endif
Next
End


######################################################################################
######################################################################################
##  ACLA6 Propriétés
######################################################################################
$ACLA6
Return

Subprog AS_NBRFLD

 Local Integer I,J

SAVNOLIG = nolign
 Effzo  [M:ACLA6]10
 Effzo  [M:ACLA6]15
 If [M:ACLA0]CODCLA="" | [M]FLDCLA(nolign-1)=""
  Raz [M:ACLA6]FLDCUR : End
 Endif

 # initialise FLDCUR, CODTYPCUR
 [M:ACLA6]FLDCUR= [M]FLDCLA(nolign-1)
 If [M:ACLA6]LOBTAB(nolign-1)=""
  [M:ACLA6]CODTYPCUR = [M:ACLA6]CODTYP(nolign-1)
 Else
  [M:ACLA6]CODTYPCUR  = [M:ACLA6]CODTYP(nolign-1) + "." + [M:ACLA6]LOBTAB(nolign-1) + "." + [M:ACLA6]LOBFLD(nolign-1)
 Endif
 [M:ACLA6]NOLINCUR=nolign

 # refresh [ACLA6]10, [ACLA6]15
 Gosub ADD_PARAM_FLDCLA
 If L_HAS_PARAM
  Chgstl [ACLA6]CODTYP(nolign-1) With "AMKACT"
  If [M:ACLA6]LOBTAB(nolign-1)<> ""
   Chgstl [ACLA6]LOBTAB(nolign-1) With "AMKACT"
  Endif
  If [M:ACLA6]LOBFLD(nolign-1)<> ""
   Chgstl [ACLA6]LOBFLD(nolign-1) With "AMKACT"
  Endif
  If [M:ACLA6]LOBCNT(nolign-1)<> ""
   Chgstl [ACLA6]LOBCNT(nolign-1) With "AMKACT"
  Endif
 Else
  Chgstl [ACLA6]CODTYP(nolign-1) With ""
  Chgstl [ACLA6]LOBTAB(nolign-1) With ""
  Chgstl [ACLA6]LOBFLD(nolign-1) With ""
  Chgstl [ACLA6]LOBCNT(nolign-1) With ""
 Endif
 Chgstl [ACLA6]FLDCLA With ""
 Chgstl [ACLA6]FLDCLA(nolign-1) With "AMKCUR"
 Gosub AFFZO_ACLA6
 Gosub AFFZO_ACLA8
End


Subprog C_NBRFLD
Local Integer NOL,J
Case status
 When 83  : # suppresion param dans tableau
  If nolign1=0 : nolign1 = nolign : Endif
  For NOL=nolign-1 To nolign1
   [M:ACLA6]FLDCUR  = [M:ACLA6]FLDCLA(NOL)
   Gosub DEL_PARAM_FLDCLA
  Next

 When 65 : # suppresion param dans tableau
  NOL=nolign-1
  [M:ACLA6]FLDCUR  = [M:ACLA6]FLDCLA(NOL)
  Gosub DEL_PARAM_FLDCLA

 When 73
  Raz [M:ACLA6]FLDCUR
  Effzo  [M:ACLA6]10
  Effzo  [M:ACLA6]15

Endcase
End

$ADD_PARAM_FLDCLA
 Local Integer J, L_HAS_PARAM

 L_HAS_PARAM = 0
 [M:ACLA6]NBRPAR = 0
 [M:ACLA6]NBCLE = 0

 Sorta [M:ACLA8]WNBRPARALL [M:ACLA8]WNBRPARALL Order By [M:ACLA8]WTYPPAR(indice),[M:ACLA8]WFLDCLA(indice),[M:ACLA8]WTYPKEY(indice),[M:ACLA8]WNUMPAR(indice),[M:ACLA8]WCODPAR(indice)
 For J=0 To [M:ACLA8]WNBRPARALL-1
  If [M:ACLA8]WTYPPAR(J)=1 & [M:ACLA8]WFLDCLA(J) = [M:ACLA6]FLDCUR & J<dim([M:ACLA8]WFLDCLA) & [M:ACLA8]WISKEY(J)<>2
   If [M:ACLA8]WCODTYP(J)=""
    [M:ACLA8]WCODTYP(J) = [M:ACLA6]CODTYPCUR
   Endif
   # Only the parameter/key related the current data type will be displayed
   If  [M:ACLA8]WCODTYP(J) = [M:ACLA6]CODTYPCUR
    L_HAS_PARAM = 1
    # Key:
    If [M:ACLA8]WTYPKEY(J)=2
     [M:ACLA6]CODCLE([M:ACLA6]NBCLE) = [M:ACLA8]WCODPAR(J)
     [M:ACLA6]INTCLE([M:ACLA6]NBCLE) = [M:ACLA8]WINTITPAR(J)
     [M:ACLA6]TYPCLE([M:ACLA6]NBCLE) = [M:ACLA8]WTYPINTPAR(J)
     [M:ACLA6]VALCLE([M:ACLA6]NBCLE) = [M:ACLA8]WVALEUR(J)
     [M:ACLA6]NBCLE += 1
    # Parameter:
    Else
     [M:ACLA6]CODPAR([M:ACLA6]NBRPAR)      = [M:ACLA8]WCODPAR(J)
     [M:ACLA6]INTITPAR([M:ACLA6]NBRPAR)    = [M:ACLA8]WINTITPAR(J)
     [M:ACLA6]TYPINTPAR([M:ACLA6]NBRPAR)   = [M:ACLA8]WTYPINTPAR(J)
     [M:ACLA6]CODCLAPAR([M:ACLA6]NBRPAR)   = [M:ACLA8]WCODCLAPAR(J)
     [M:ACLA6]ADRVAL([M:ACLA6]NBRPAR)      = [M:ACLA8]WADRVAL(J)
     [M:ACLA6]VALEUR([M:ACLA6]NBRPAR)      = [M:ACLA8]WVALEUR(J)
     [M:ACLA6]NBRPAR += 1
    Endif
   Endif
  Endif
 Next
Return

Subprog AVANT_NBRFLD
Case status
 When 67 # Paste
  [M:ACLA6]FLDCLA(nolign-1)= "PROPERTYCOPY"
  Affzo [M:ACLA6]FLDCLA(nolign-1)
  If [M:ACLA6]LOBTAB(nolign-1) <> ""
   Call L_AM_LOBTAB([M:ACLA6]LOBTAB(nolign-1),[M:ACLA6]LOBFLD(nolign-1), [M:ACLA6]FLDCLA(nolign-1))
  Else
   Call L_AM_CODTYP([M:ACLA6]CODTYP(nolign-1), [M:ACLA6]FLDCLA(nolign-1))
  Endif
Endcase
End



Subprog APRES_NBRFLD
 Local Char WCODTYP(30)
 # calculate CODTYP used in [M:ACLA8]WCODTYP
 WCODTYP = [M:ACLA6]CODTYP(nolign-1)
 If [M:ACLA6]LOBTAB(nolign-1) <> ""
  WCODTYP = WCODTYP+"."+[M:ACLA6]LOBTAB(nolign-1)+"."+[M:ACLA6]LOBFLD(nolign-1)
 Endif
 # remove the no longer used parameters/keys from [M:ACLA6]20
 For I = 0 To [M:ACLA8]WNBRPARALL-1
  If !find([M:ACLA8]WFLDCLA(I),[M:ACLA6]FLDCLA)
   Dela I,1 [M:ACLA8]WNBRPARALL
   [M:ACLA8]WNBRPARALL-= 1
   I-=1
  Elsif [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WFLDCLA(I) = [M:ACLA6]FLDCUR & [M:ACLA8]WCODTYP(I)<>WCODTYP
   Dela I,1 [M:ACLA8]WNBRPARALL
   [M:ACLA8]WNBRPARALL-= 1
   I-=1
  Elsif [M:ACLA8]WTYPPAR(I)=2 & [M:ACLA8]WFLDCLA(I) = [M:ACLA6]FLDCUR & [M:ACLA8]WCODTYP(I)<>[M:ACLA6]CODTYP(nolign-1)
   Dela I,1 [M:ACLA8]WNBRPARALL
   [M:ACLA8]WNBRPARALL-= 1
   I-=1
  Endif
 Next
End



$DEL_PARAM_FLDCLA
Local Integer I
I= find([M:ACLA6]FLDCUR,[M:ACLA8]WFLDCLA(0..[M:ACLA8]WNBRPARALL-1))
While I>0
 Dela I-1,1 [M:ACLA8]WNBRPARALL
 [M:ACLA8]WNBRPARALL-= 1
 I= find([M:ACLA6]FLDCUR,[M:ACLA8]WFLDCLA(0..[M:ACLA8]WNBRPARALL-1))
Wend
Raz   [M:ACLA6]FLDCUR
Gosub AFFZO_ACLA6
Gosub AFFZO_ACLA8
Return

Subprog C_FLDCLA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FLDCLA(0..[M]NBRFLD-1)) From OBJDIV
If mkstat : End : Endif

Local Char    LIST_NAM(GLONAVB)(0..)
Call RESERVED_NAME_LIST(LIST_NAM) From ACLACONTROL
For I=0 To maxtab(LIST_NAM)
 If toupper(VALEUR)=toupper(LIST_NAM(I))
  GMESSAGE = VALEUR+" : "+mess(129,133,1)
  mkstat = 2 : Break
 Endif
Next
End

Subprog AM_FLDCLA(VALEUR)
Variable Char    VALEUR()

Local Integer I, J,K
Gosub SEL_FLDCLA

[M:ACLA6]FLDCUR = VALEUR
Call L_LOAD_FLD_FROM_TB(VALEUR)
If [M:ACLA6]LOBTAB(nolign-1) <> ""
 Call L_AM_LOBTAB([M:ACLA6]LOBTAB(nolign-1),[M:ACLA6]LOBFLD(nolign-1), VALEUR)
Else
 Call L_AM_CODTYP([M:ACLA6]CODTYP(nolign-1), VALEUR)
 #94793
 GMODIFPAR=0
 For I=0 To [M:ACLA8]WNBRPARALL-1
  If [M:ACLA8]WFLDCLA(I)=VALEUR & [M:ACLA8]WTYPKEY(I)=2  & [M:ACLA8]WCODTYP(I)=[M:ACLA6]CODTYP(nolign-1)
   J+=1
   K=I
  Endif
 Next
 If J=1
  [M:ACLA8]WVALEUR(K)= [M:ACLA6]FLDGRP(nolign-1)+string$([M:ACLA6]FLDGRP(nolign-1)<>"",".")+[M:ACLA6]FLDCUR
  [M:ACLA6]VALCLE(0)=[M:ACLA8]WVALEUR(K)
  Affzo [M:ACLA6]VALCLE(0)
 Endif
 #
Endif
GMODIFPAR=0
If [M]TYPCLA=2
 For I=0  To [M:ACLA3]NBRLNK-1
  If [M:ACLA3]REFLNK(I)=VALEUR
   [M:ACLA3]REFLNK(I) = VALEUR
   Affzo [M:ACLA3]REFLNK(I)
   Break
  Endif
 Next
 If [M:ACLA6]FLDSEARCH(nolign-1)<>2
  Local Char CHAINE(250)
  CHAINE = [M:ACLA1]KEYINT
  Gosub L_DEFCLE From SUBACLA
  If find([M:ACLA6]FLDCUR,CLE)>0
   [M]FLDSEARCH(nolign-1)  = 2
  Endif
 Endif
Endif
End

$SEL_FLDCLA
Local Integer NBFLD, CHOI,I,OK
Local Char    TEX(GLONDES)(1..3000,1..5) , TIT(GLONDES)(0..4)

NBFLD = 0
For [ACLAF]ACLAF0 Where FLDCLA=VALEUR & LNKCLA=""
 NBFLD += 1
 TEX(NBFLD,1) =[F:ACLAF]CODCLA
 TEX(NBFLD,2) = [ACLAF]FLDCLA
 Call TEXTE([ACLAF]INTFLD,TEX(NBFLD,3)) From OBJDIV
 TEX(NBFLD,4) = [F:ACLAF]CODTYP
 TEX(NBFLD,5) = format$("Nz:5F",[F:ACLAF]LONG)
 If NBFLD>=dim(TEX)-1 : Break : Endif
Next ACLAF

 CHOI = 0
 TIT(0)=mess(8,31,1) # Sélection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ACLA0", "CODCLA")  # Classe
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "FLDCLA")  # Propriété
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
 TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "CODTYP")  # Type

If NBFLD>0
 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  Read [F:ACLAF]ACLAF0 = TEX(CHOI,1);TEX(CHOI,2)
  If !fstat
   Gosub LOAD_FLDCLA
  Endif
 Endif
Endif
Return

$LOAD_FLDCLA
Local Integer NOL
NOL = nolign-1

[M:ACLA6]FLDCLA(NOL) = [F:ACLAF]FLDCLA
[M:ACLA6]INTFLD(NOL) = [F:ACLAF]INTFLD
Call TEXTE([M:ACLA6]INTFLD(NOL),[M:ACLA6]ZINTFLD(NOL)) From OBJDIV
[M:ACLA6]INTSHTFLD(NOL) = [F:ACLAF]INTSHTFLD
Call TEXTE([M:ACLA6]INTSHTFLD(NOL),[M:ACLA6]ZINTSHTFLD(NOL)) From OBJDIV
[M:ACLA6]CODTYP(NOL) = [F:ACLAF]CODTYP
[M:ACLA6]NOLIB(NOL) = [F:ACLAF]NOLIB
[M:ACLA6]LONG(NOL) = [F:ACLAF]LONG
[M:ACLA6]ACTFLD(NOL) = [F:ACLAF]ACTFLD
[M:ACLA6]LNKCLA(NOL) = [F:ACLAF]LNKCLA
[M:ACLA6]FLDGRP(NOL) = ""
[M:ACLA6]LOBTAB(NOL) = [F:ACLAF]LOBTAB

[M:ACLA6]LOBFLD(NOL) = [F:ACLAF]LOBFLD
[M:ACLA6]LOBCNT(NOL) = [F:ACLAF]LOBCNT
[M:ACLA6]OBLIG(NOL) = [F:ACLAF]OBLIG
[M:ACLA6]CODCTL(NOL) = [F:ACLAF]CODCTL
[M:ACLA6]TABCONT(NOL) = [F:ACLAF]TABCONT
[M:ACLA6]ACS(NOL) = [F:ACLAF]ACS
[M:ACLA6]FLGACCGET(NOL) = [F:ACLAF]FLGACCGET
Return

