If nolign=1
 VALEUR="A"
Else
 VALEUR=chr$(ascii([M]OPTCOD(nolign-2))+1)
Endif
End

Subprog C_OPTCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]OPTCOD) From OBJDIV
If mkstat : End : Endif
End

Subprog AM_OPTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If GADONIX=2 & (VALEUR<"A" | VALEUR>"Z")
 Call AVERTIR(mess(230,133,1),OK) From GESECRAN : # Code réservé spécifique
 If OK<>2 : mkstat = 1 : Endif
Endif
# name covention
Call PLAGE(VALEUR,1) From CONTOBJ
If mkstat : End : Endif
End

Subprog C_LEGSTR(VALEUR)
Variable Char    VALEUR()
Local Integer I,K,OK
If VALEUR="" : End : Endif
K= find(VALEUR, [M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
If K=0
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
If [M:ACLA6]CODTYP(K-1) <> "ADI"
 GMESSAGE = mess(113,127,1) : # Type de donnée incompatible
 mkstat = 2 : End
Else
 For I = 0 To [M:ACLA8]WNBRPARALL-1
  If [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WFLDCLA(I) = VALEUR and [M:ACLA8]WCODPAR(I) = "NUMTAB" and [M:ACLA8]WVALEUR(I) = '909'
   OK=1: Break
  Endif
 Next
 If OK <> 1
  GMESSAGE = mess(113,127,1) : # Type de donnée incompatible
  mkstat = 2 :  End
 Endif
Endif
End


