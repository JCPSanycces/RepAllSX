 ## Action TRTADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTADC"
 PARMSK(1) = ""
 Call S_AFF_CHAR([M:ACLA1]CODTRT(nolign-1),PARMSK,"EDITION","SUBADC","") From GACTION
 GACTION = SAVACT
