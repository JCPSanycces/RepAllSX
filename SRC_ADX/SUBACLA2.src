Funprog TRT_ISRESERVED(MODULE,TYPTRT,CODTRT,ACTTRT)
Value Integer MODULE,TYPTRT
Value Char CODTRT,ACTTRT
Local File ACTIV [ACV]
If [L]CODTRT<>"" & GPRODUIT<>-1 & [L]TYPTRT=1
 If GADONIX<>2
  End 1
 Endif
 If [L]MODULE=1 | left$([L]CODTRT,1)="A" : #Superviseur
  If [L]ACTTRT<>""
   Read [ACV]CODACT = [L]ACTTRT
   If !fstat & [F:ACV]MODULE<>1
     End 0
   Endif
   End 1
  Endif
 Endif
Endif
End 0

