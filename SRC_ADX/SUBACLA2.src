Subprog C_FLGBUFFER(VALEUR)
Variable Integer VALEUR
If find([M]TYPCLA,1,3,4)>0
 GMESSAGE= mess(60,140,1) : # "Type de classe incompatible avec une classe tampon"
 mkstat = 1 : End
Endif
End

Subprog AM_FLGBUFFER(VALEUR)
Variable Integer VALEUR
If [M:ACLA1]FLGBUFFER<>2 & find(VALEUR,2)>0
 Local Integer OK
 Call AVERTIR(mess(61,140,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
[M]FLGBUFFER = VALEUR
If [M]FLGBUFFER=2
 Effzo [M:ACLA1]15
 Grizo [M:ACLA1]15
 Gosub L_CLEAN_METHOD
 Grizo [M:ACLA2]
 If [M:ACLA1]FLGBUFFER=2
  For I=0 To [M:ACLA5]NBMETSTD-1
   If [M:ACLA5]CODMETSTD(I)<>"R"
    [M:ACLA5]ACSMETSTD(I)= ""
    [M:ACLA5]ACTMETSTD(I) =""
    [M:ACLA5]ENAMETSTD(I) = 1
   Else
    [M:ACLA5]ENAMETSTD(I) = 2
   Endif
   Affzo [M:ACLA5]ENAMETSTD(I)
  Next
 Endif
 Effzo [M:ACLA3]20
 Grizo [M:ACLA3]20
 If dim([M:ACLA1]FLGACTX)>0
  Actzo [M:ACLA1]FLGACTX : [M:ACLA1]FLGACTX = 2 : Affzo [M:ACLA1]FLGACTX
 Endif
 Effzo [M:ACLA4]
 Grizo [M:ACLA4]
Else
 Actzo  [M:ACLA1]15
 Actzo  [M:ACLA2]
 Actzo  [M:ACLA3]20
 If dim([M:ACLA1]FLGACTX)>0
  Actzo [M:ACLA1]FLGACTX : [M:ACLA1]FLGACTX = 1 : Affzo [M:ACLA1]FLGACTX
 Endif
 Actzo  [M:ACLA4]
Endif



End

