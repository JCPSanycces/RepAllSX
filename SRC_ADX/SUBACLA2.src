Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Char L_ERR_MSG(250), L_PARCOL(30)
Local Integer I

If [L]VALEUR="" & [M:ACLA6]CODPAR(nolign-1)<>"AFILTER"
 GMESSAGE = mess(10,123,1) : #ZONE OBLIGATOIRE
 mkstat= 2 : End
Elsif  [L]VALEUR="" & [M:ACLA6]CODPAR(nolign-1)="AFILTER"
 End
Elsif  [M:ACLA6]CODPAR(nolign-1)="AENABLE" & find([L]VALEUR,"1","2")=0
 GMESSAGE = mess(126,143,1) # Valeur invalide.
 mkstat= 2 : End
Endif

I = find([M:ACLA6]FLDCUR, [M:ACLA6]FLDCLA)
If I>0
 L_PARCOL = [M:ACLA6]FLDGRP(I-1)
 If !func L_CHECK_PARAMETER([M:ACLA6]FLDCLA(I-1),[M:ACLA6]CODTYP(I-1),[M:ACLA6]CODPAR(nolign-1),[M:ACLA6]ACTFLD(I-1),VALEUR, [M:ACLA6]TYPINTPAR(nolign-1), [M:ACLA6]ADRVAL(nolign-1), L_PARCOL,
&  [M:ACLA0]CODCLA, 1, L_ERR_MSG)
  GMESSAGE = L_ERR_MSG
  mkstat = 2
 Endif
Endif
End


Subprog AM_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Integer TYP_KEY : TYP_KEY = 1
Local Char COD_PAR(80) : [L]COD_PAR = [M]CODPAR(nolign-1)
Gosub AM_WVALEUR
End

$AM_WVALEUR
Local Integer I
For I=0 To [M]WNBRPARALL
 If [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WFLDCLA(I)=[M:ACLA6]FLDCUR & [M:ACLA8]WCODPAR(I)=[L]COD_PAR & [M:ACLA8]WTYPKEY(I)=TYP_KEY
  [M:ACLA8]WVALEUR(I) = [L]VALEUR
  Affzo [M:ACLA8]WVALEUR(I)
  Break
 Endif
Next
Return

Subprog S_VALEUR(VALEUR)
Variable Char    VALEUR()

If zoncou="VALEUR"
 If [M:ACLA6]CODPAR(nolign-1) ="AFILTER"
  Gosub SEL_OPTION
  End
 Endif
 If [M:ACLA6]CODPAR(nolign-1) ="AENABLE"
  Gosub SEL_AENABLE
  End
 Endif
Endif
Local Integer NBCHOI, CHOI
Local Char    TEX(GLONDES)(1..[M:ACLA6]NBRFLD,1..4) , TIT(GLONDES)(0..4)
For  I=0 To [M:ACLA6]NBRFLD-1
 If [M]CODTYP(I)<>"ARF" & [M]LNKCLA(I)=""
  NBCHOI += 1
  TEX(NBCHOI,1) = [M]FLDCLA(I)
  TEX(NBCHOI,2) = [M]CODTYP(I)
  TEX(NBCHOI,3) = [M]ZINTFLD(I)
  TEX(NBCHOI,4) = [M:ACLA6]FLDGRP(I)
 Endif
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(199,123,1) : #PROPRIÉTÉS
TIT(2) = mess(5,42,1) : # type DE DONNÉES
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
TIT(4) = ""
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = ""
 If TEX(CHOI,4)<>""
  VALEUR = TEX(CHOI,4)+"."
 Endif
 VALEUR += TEX(CHOI,1)
Endif
End

