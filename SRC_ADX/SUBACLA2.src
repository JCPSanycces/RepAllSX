$SEL_OPTION
Gosub DEFSEL3 From SUBASW2
I = find([M:ACLA6]FLDCUR, [M:ACLA6]FLDCLA)
If I>0
 Read [ATY]CODTYP = [M]CODTYP(I-1)
 If !fstat
  For [ACLAO] Where CODCLA=[ATY]CODCLA
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ACLAO]OPTCOD
    TEX(NBTEX,2) = func AFNC.TEXTE([F:ACLAO]OPTLIB)
    TEX(NBTEX,3) = [F:ACLAO]OPTACT
  Next
  CHOI = 0
  TIT(0) = mess(22,123,1) # Sélection
  TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTCOD")
  TIT(2) = mess(30,109,1) : # INTITULé
  TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTACT")
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = '"'+TEX(CHOI,1)+'"'
  Endif
 Endif
Endif
Return

$SEL_AENABLE
Gosub DEFSEL2 From SUBASW2
NBTEX+= 1
TEX(NBTEX,1) = "1"
TEX(NBTEX,2) = mess(1,1,1)
NBTEX+= 1
TEX(NBTEX,1) = "2"
TEX(NBTEX,2) = mess(2,1,1)
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = mess(2,8,1)
TIT(2) = mess(30,109,1) : # INTITULé
Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
Return

