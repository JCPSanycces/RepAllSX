Subprog SEL_PROFROMCLASSE(VALEUR,CLASSE)
Variable Char    VALEUR()
Value Char CLASSE
Local Integer NBCHOI, CHOI,J
Local Char    TEX(GLONDES)(1..500,1..4) , TIT(GLONDES)(0..4)
J=find([M:ACLA3]REFLNKCUR,[M:ACLA3]REFLNK)
For [ACLAF]ACLAF0 Where CODCLA=CLASSE& LNKCLA=""
 NBCHOI += 1
 TEX(NBCHOI,1) = [F:ACLAF]FLDCLA
 TEX(NBCHOI,2) = [F:ACLAF]CODTYP
 TEX(NBCHOI,3) = func AFNC.TEXTE([F:ACLAF]INTFLD)
 TEX(NBCHOI,4) = [F:ACLAF]FLDGRP
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(199,123,1) : #PROPRIÉTÉS
TIT(2) = mess(5,42,1) : # type DE DONNÉES
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
TIT(4) = ""
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = ""
 If TEX(CHOI,4)<>""
  VALEUR = TEX(CHOI,4)+"."
 Endif
 VALEUR += TEX(CHOI,1)
Endif
End

