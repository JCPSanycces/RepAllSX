Subprog C_TYPCLA(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR <> [M:ACLA1]TYPCLA
 If find([M:ACLA1]TYPCLA,1,2,5) and VALEUR <> 4
  I = find(2,[M:ACLA2]FLGOPE)
  If I>0
   Local Integer OK
   Call AVERTIR(mess(178,143,1)+". "+mess(177,143,1)+". "+mess(205,100,1),OK) From GESECRAN
   If OK=1 : mkstat=2 : End : Endif
  Endif
 Endif
Endif
End

Subprog AM_TYPCLA(VALEUR)
Variable Integer VALEUR

# check if the operations need to be cleaned.
If find([M:ACLA1]TYPCLA,1,2,5) and VALEUR <> 4
 Gosub L_CLEAN_OPE
Endif

# If buffer before
If [M:ACLA1]FLGBUFFER=2 & find(VALEUR,1,3,5)>0
 Actzo  [M:ACLA1]15
 Actzo  [M:ACLA2]
 Actzo  [M:ACLA3]20
 Actzo  [M:ACLA5]
 [M:ACLA1]FLGBUFFER = 1
 Affzo [M:ACLA1]FLGBUFFER
Endif

[M]TYPCLA=VALEUR
Gosub GRISE_ACLA From SUBACLA
Gosub GRISE_ACLAM  From SUBACLA
Gosub GRISE_ACLAT  From SUBACLA
Gosub GRISE_ACLAK  From SUBACLA
Gosub GRISE_ACLAO  From SUBACLA
If [M]TYPCLA=5 : [M]ISTABLE=3 : Endif
End

