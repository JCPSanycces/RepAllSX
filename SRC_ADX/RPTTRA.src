#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char PARAM(10)(1..10)
Call GCONSULT( "TRA", "", PARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################


#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher. (Does nothing at the moment.)
#* 
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#** #############################################################################################################

$ACTION
Return



#** #############################################################################################################
#*
#*Procedure:   IMPRIME
#*
#* Purpose:    Handler for the report preprocess.
#* 
#*
#* Parameters:
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#** #############################################################################################################
#*!

Subprog IMPRIME( NBPAR, PARAMETRE )
Variable Integer NBPAR
Variable Char PARAMETRE()(1..)
    Local Char     PARAM(30), PARAMR    # Parameter variables for GET/SETPARAM
    Local Char     REPCODE              # Report code
    Local Integer  NUMREQ               # Report data ID (for AREPORTM)
    Local Integer  DOTPOS               # Position of the dot in the report name.
    Local Integer I    

    # Leave if the CONSRSG/DCLVATGER2 function is not active for we need a lot of
    # data from masks [M:RSGx]. 
    If !clalev([M:TRG0]) or !clalev([M:TRAP])
        GOK = 0 # Cancel printing.
        End
    Endif
        
    # Get the report code from report name.
    Call GETPARAM( "__REPORT", NBPAR, PARAMETRE, PARAMR ) From ETAT  
    DOTPOS = instr( 1, PARAMR, "." )
    If DOTPOS : REPCODE = left$( PARAMR, DOTPOS - 1 )  : Endif
    
    # Get the report ID for the selection using AREPORTM.NUMREQ.
    Call GETPARAM( "__REQUETE", NBPAR, PARAMETRE, PARAMR ) From ETAT
    NUMREQ = val(PARAMR)
    
    # Fill the numedt parameter.
    PARAMR = num$(NUMREQ)
    Call SETPARAM( "numedt", NBPAR, PARAMETRE, PARAMR ) From ETAT
    
    # Fill the company parameter.
    PARAMR = [M:TRAP]CPY
    Call SETPARAM( "societe", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the start date parameter.
    PARAMR = [M:TRAP]DATDEB
    Call SETPARAM( "datdeb", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the end date parameter.
    PARAMR = [M:TRAP]DATFIN
    Call SETPARAM( "datfin", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill BOX 003 addendum.
    PARAMR = [M:TRAP]BOX020 
    Call SETPARAM( "box020", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Correction flag.
    PARAMR = num$( [M:TRAP]FLGCOR - 1 )
    Call SETPARAM( "flgcor", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # U31 attachment flag.
    PARAMR = num$( [M:TRAP]FLGU31 - 1 )
    Call SETPARAM( "flgu31", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Invoice attachment flag.
    PARAMR = num$( [M:TRAP]FLGINV - 1 )
    Call SETPARAM( "flginv", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Tax ID and tax center.
    Read [F:CPY]CPY0 = [M:TRAP]CPY
    If !fstat
         For I = 0 To dim([F:CPY]GERTAXIDT) - 1
             If [F:CPY]GERTAXIDT(I) = [M:TRG0]CRN
                 # Tax ID          
                 PARAMR = [F:CPY]GERTAXIDT(I)
                 Call SETPARAM( "gertaxidt", NBPAR, PARAMETRE, PARAMR ) From ETAT

                 # Tax center            
                 PARAMR = [F:CPY]GERTAXCEN(I)
                 Call SETPARAM( "gertaxcen", NBPAR, PARAMETRE, PARAMR ) From ETAT
                 Break
             Endif
         Next
    Endif

    # We transfer the data box by box into AREPORTM table.
    If !clalev([F:ARM])  : Local File AREPORTM [ARM]  :  Endif

    Call DEBTRANS From GLOCK 
    Trbegin [ARM]

    For I = 0 To [M:TRG1]NBLIG-1
        Raz [F:ARM]
        [F:ARM]RPTCOD = REPCODE 
        [F:ARM]USR    = GUSER
        [F:ARM]CREDAT = date$
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = I + 1
        [F:ARM]CLEA1  = [M:TRAP]CPY
        [F:ARM]CLEA2  = [M:TRG1]REPLINE(I)
        [F:ARM]CLEMD1 = [M:TRG1]AMTVATBASE(I)
        [F:ARM]CLEMD2 = [M:TRG1]AMTVAT(I)
        Write [ARM]
        If fstat
            GOK = 0
            Break 
        Endif    
    Next
                
    If GOK < 1 
        Rollback
    Else
        Commit
    Endif 
End

