#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
# SUBPTHD : Gestion des réceptions (valorisations)         MBT 22/06/05 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "PTH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPTH       #
# Les actions "Gosub" de l'objet "PTH" se trouvent dans le SUBPTHA      #
# Les traitements complémentaires -1-  se trouvent dans le SUBPTHB      #
# Les traitements concernant la sous-traitance     dans le SUBPTHC      #
# --------------------------------------------------------------------- #
#   Subprog MAJ_CUMULS_LIG(NOL,SENS)                                    #
#     S/P de mise à jour des cumuls, bases et montants éléments à       #
#         partir des valeurs de la ligne de réception                   #
#   Subprog MAJ_BASTAX_LIG(NOL,SENS)                                    #
#     S/P de mise à jour des cumuls bases et montants de taxe à partir  #
#         des valeurs de la ligne de réception                          #
#   Subprog MAJ_CPR_LIG(NOL)                                            #
#     S/P de calcul prix unitaire de revient                            #
#   Subprog REAJUST_BASTAXLIN1 (NOL,MT)                                 #
#     S/P de réajustement de la base de TVA si modif d'un montant       #
#         de taxe parafiscale ou spéciale soumise à TVA                 #
#   Subprog REAJUST_CLCAMT (NOL,MT,CLCAMTFLG)                           #
#     S/P de réajustement des bases spéciales 1 et 2 si TVA incluse     #
#         dans ces bases (Canada)                                       #
#   Subprog MAJ_TAXE (NOL)                                              #
#     S/P de mise à jour des montants de taxe au prorata des bases sur  #
#         les éléments de facturation et sur les lignes de réception    #
#   Subprog MAJ_ELEMENT (NOL,AFF,SENS)                                  #
#     S/P de mise à jour des bases et calcul des taxes et répartition   #
#         si besoin des montants sur les lignes au prorata des qtés     #
#         ou montants                                                   #
#   Subprog MAJ_REPART_LIG                                              #
#     S/P de répartition des montants sur les lignes au prorata des     #
#         quantités ou montants, calcul taxes et prix unitaires revient #
#   Subprog INIT_COMPTES_INVDTA (NOL)                                   #
#     S/P d'initialisation des comptes d'un élément de facturation      #
#   Gosub PREP_INIT_PFICCE                                              #
#     S/P de préparation des sections d'un élément de facturation       #
#########################################################################

#########################################################################
# MAJ_CUMULS_LIG : S/P de mise à jour des cumuls           MBT 22/06/05 #
#         à partir des valeurs de la ligne de réception :               #
#    - Total Mts HT des lignes de réception                             #
#    - Total Qtés des lignes de réception                               #
#    - Màj des montants éléments venant des pieds de commande           #
#    - Màj des montants éléments venant du tarif                        #
# --------------------------------------------------------------------- #
# Subprog MAJ_CUMULS_LIG(NOL,SENS)                                      #
#   NOL    : indice de la ligne de réception (nolign-1)                 #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
#       (+2=Cumul sans màj éléments, -2=Soustraction sans màj éléments) #
#########################################################################
Subprog MAJ_CUMULS_LIG(NOL,SENS)
Value   Shortint NOL
Value   Integer  SENS
#---- Test si ligne existe bien (Avant ligne d'une nouvelle ligne) ----#
If [M:PTH1]ITMREF(NOL)=""  End : Endif
#----- Variables locales -----#
Local   Shortint SVGNOLIGN : SVGNOLIGN=nolign
Local   Shortint SVGNOL    : SVGNOL   =NOL
Local   Shortint I, J, K
Local   Integer  STAT
Local   Decimal  MT, MT1, MT2, WRND
Local   Decimal  WMNTMAX, WQTEMAX, WQTYSTU, WQTYSTUMAX
Local   Shortint SAV_LINFLG
Local   Libelle  WFLAG, WVCRTYP
#----- SENS = +2 ou -2, pas de màj des éléments -----#
WFLAG=0
If SENS=-2  SENS=-1 : WFLAG=1 : Endif
If SENS=+2  SENS=+1 : WFLAG=1 : Endif
#----- Chargement arrondi devise réception -----#
If [F:TCU]CUR<>[M:PTH0]CUR
  Read [TCU] TCU0=[M:PTH0]CUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#----- Mise à jour total HT lignes et total qtés lignes -----#
SAV_LINFLG=[M:PTH1]LINFLG(NOL)
If SENS=1
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:PTH1]LINTYP(NOL)<>2
    [M:PTH2]TOTLINAMT+=[M:PTH1]LINAMT(NOL)
  Endif
  #----- Cumuls qtés si ce n'est pas un composant service -----#
  If [M:PTH1]LINTYP(NOL)<>3
    [M:PTH2]TOTLINQTY+=[M:PTH1]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:PTH1]LINTYP(NOL)<3
      [M:PTH2]TOTLINWEU+=[M:PTH1]QTYWEU(NOL)
      [M:PTH2]TOTLINVOU+=[M:PTH1]QTYVOU(NOL)
    Endif
  Endif
  #-----
  Gosub TRT_CUMULS_LIG : # Màj des éléments venant des commandes et du tarif
Else
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:PTH1]LINTYP(NOL)<>2
    [M:PTH2]TOTLINAMT-=[M:PTH1]LINAMT(NOL)
  Endif
  #----- Cumuls qtés si ce n'est pas un composant service -----#
  If [M:PTH1]LINTYP(NOL)<>3
    [M:PTH2]TOTLINQTY-=[M:PTH1]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:PTH1]LINTYP(NOL)<3
      [M:PTH2]TOTLINWEU-=[M:PTH1]QTYWEU(NOL)
      [M:PTH2]TOTLINVOU-=[M:PTH1]QTYVOU(NOL)
    Endif
  Endif
  #-----
  [M:PTH1]LINFLG(NOL)=9
  Gosub TRT_CUMULS_LIG : # Màj des éléments venant des commandes et du tarif
Endif
[M:PTH1]LINFLG(NOL)=SAV_LINFLG
End
#------------------------------------------------------------------#
# Traitement des éléments venant des pieds de commande et du tarif #
#------------------------------------------------------------------#
$TRT_CUMULS_LIG
If !WFLAG
  #----- Variables locales -----#
  Local Char    WCUR(GLONCUR)
  Local Decimal WINIQTYSTU
  Local Decimal WTOTLINAMT
  Local Decimal WTOTLINQTY
  Local Decimal WTOTLINWEU
  Local Decimal WTOTLINVOU
  Local Char    WDSPWEU(GLONUOM)
  Local Char    WDSPVOU(GLONUOM)
  Local Char    WABR(3)
  Local Libelle WAMTCOD
  Local Decimal WINVDTAAMT
  Local Decimal WINVORDAMT
  Local Integer WINVDTA
  Local Char    WINVDTAVAT(GLONVAT)
  #-----
  If [M:PTH1]POHNUM(NOL)=""
    Raz [F:POH] : # Réception sans commande
  Else
    Read [POH] POH0=[M:PTH1]POHNUM(NOL) : If fstat  Raz [F:POH] : Endif
  Endif
  #-----
  # Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
  If GMODU(5)=2
  # fin Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
    If [M:PTH1]SDHNUM(NOL)=""
      Raz [F:SDH] : # Réception sans livraison
    Else
      Read [SDH] SDH0=[M:PTH1]SDHNUM(NOL) : If fstat  Raz [F:SDH] : Endif
    Endif
  # Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
  Endif
  # fin Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
  #----- Mise à jour montants éléments venant des pieds de livraison -----#
  # Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
  #If [F:SDH]SDHNUM<>""
  If GMODU(5)=2 & [F:SDH]SDHNUM<>""
  # fin Issue 77909 - 2011-11-18 by MUARN : erreur sur réception achat si pas de module vente
    #----- Ouverture des tables si nécessaire -----#
    If !clalev([F:TVC])   Local File TABVAC     [TVC]  : Endif
    If !clalev([F:BCH])   Local File BETCPY     [BCH]  : Endif
    If !clalev([F:SFI])   Local File SFOOTINV   [SFI]  : Endif
    If !clalev([F:SVF])   Local File SVCRFOOT   [SVF]  : Endif
    #----- Lecture des paramètres inter-société si nécessaire -----#
    If [F:BCH]CLE<>"STD"
      Read [BCH] BCH0="STD" : If fstat  Raz [F:BCH] : Endif
    Endif
    #-----
    WTOTLINAMT=[F:SDH]DLVNOT
    WTOTLINQTY=[F:SDH]DSPTOTQTY
    WTOTLINWEU=[F:SDH]DSPTOTWEI
    WTOTLINVOU=[F:SDH]DSPTOTVOL
    WDSPWEU   =[F:SDH]DSPWEU
    WDSPVOU   =[F:SDH]DSPVOU
    WCUR      =[F:SDH]CUR
    WABR      ="SVF"
    For [SVF] SVF2 Where VCRTYP=2 & VCRNUM=[F:SDH]SDHNUM
      J=find([F:SVF]DTA,[F:BCH]SFINUM)
      If J
        WAMTCOD   =[F:SVF]AMTCOD
        If [F:SVF]AMTCOD=2
          WINVDTAAMT=[F:SVF]DTANOT
        Else
          WINVDTAAMT=[F:SVF]DTAAMT
        Endif
        WINVORDAMT=[F:SVF]DTANOT
        WINVDTA   =[F:BCH]PFINUM(J-1)
        Call RECHVATFOOT(2,[M:PTH0]BPSNUM,WINVDTA,"PTH2",WINVDTAVAT) From TRTX3
        Gosub TRT_ELEMENT
      Else
        #----- Correspondance non trouvée mais est-ce un élément regroupé ? -----#
        Read [SFI] SFI0=[F:SVF]DTA : If fstat  Raz [F:SFI] : Endif
        If [F:SFI]INVFOOBRD<>0
          J=find([F:SFI]INVFOOBRD,[F:BCH]SFINUM)
          If J
            WAMTCOD   =[F:SVF]AMTCOD
            If [F:SVF]AMTCOD=2
              WINVDTAAMT=[F:SVF]DTANOT
            Else
              WINVDTAAMT=[F:SVF]DTAAMT
            Endif
            WINVORDAMT=[F:SVF]DTANOT
            WINVDTA   =[F:BCH]PFINUM(J-1)
            Call RECHVATFOOT(2,[M:PTH0]BPSNUM,WINVDTA,"PTH2",WINVDTAVAT) From TRTX3
            Gosub TRT_ELEMENT
          Else
            # Elément de vente sans correspondance dans les achats !
          Endif
        Else
          # Elément de vente sans correspondance dans les achats !
        Endif
      Endif
    Next
  #----- Mise à jour montants éléments venant des pieds de commande -----#
  Elsif [F:POH]POHNUM<>""
    If [F:POH]POHTYP=1  WVCRTYP=3  Else  WVCRTYP=5 : Endif
    WTOTLINAMT=[F:POH]TOTLINAMT
    WTOTLINQTY=[F:POH]TOTLINQTY
    WTOTLINWEU=[F:POH]TOTLINWEU
    WTOTLINVOU=[F:POH]TOTLINVOU
    WDSPWEU   =[F:POH]DSPWEU
    WDSPVOU   =[F:POH]DSPVOU
    WCUR      =[F:POH]CUR
    WABR      ="PVF"
    For [PVF] PVF1 Where VCRTYP=WVCRTYP & VCRNUM=[F:POH]POHNUM & INVLINFLG<>6 & DISVATFLG<>2
      WAMTCOD   =[F:PVF]AMTCOD
      WINVDTAAMT=[F:PVF]INVDTAAMT
      WINVORDAMT=[F:PVF]INVORDAMT
      WINVDTA   =[F:PVF]INVDTA
      WINVDTAVAT=[F:PVF]INVDTAVAT
      Gosub TRT_ELEMENT
    Next
  Endif
Endif
#----- Mise à jour montants éléments venant du tarif -----#
For I=1 To 9
  If evalue("dim([M:PTH1]DISCRGVAL"+num$(I)+"(NOL))")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      J=find(GINVDTALIN(I-1),[M:PTH2]INVDTA(0..[M:PTH2]NBFAC-1))
      If J<>0
        #----- C'est un montant -----#
        If GDISCRGTYP(I-1)=1
          If GCLCRUL(I-1)=1 : # Par unité
            MT=arr(evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")*[M:PTH1]QTYUOM(NOL),WRND)
          Else              : # Par ligne
            MT=evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")
          Endif
        #----- C'est un pourcentage -----#
        Else
          MT=arr([M:PTH1]LINAMT(NOL)*evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
        Endif
        #----- Inversion du montant si minoration -----#
        If GINCDCR(I-1)=2  MT=-MT : Endif
        #-----
        If !WFLAG  Call MAJ_ELEMENT(J-1,0,-2) From SUBPTHD : Endif
        If SENS=1
          If !WFLAG  [M:PTH2]INVDTAAMT(J-1)+=MT : Endif
          [M:PTH2]INVLINAMT(J-1)+=MT
        Else
          If !WFLAG  [M:PTH2]INVDTAAMT(J-1)-=MT : Endif
          [M:PTH2]INVLINAMT(J-1)-=MT
        Endif
        If !WFLAG  Call MAJ_ELEMENT(J-1,0,+2) From SUBPTHD : Endif
      Endif
    Endif
  Endif
Next I
Return
#-----------------------------------------------------------------------------------------#
# Traitement d'un élément de facturation venant du pied de la commande ou de la livraison #
#-----------------------------------------------------------------------------------------#
$TRT_ELEMENT
#----- Lecture élément facturation si nécessaire -----#
If [F:PFI]PFINUM<>WINVDTA
  Read [PFI] PFI0=WINVDTA : If fstat  Raz [F:PFI] : Endif
Endif
#----- Recherche si élément présent dans le tableau -----#
J=find(WINVDTA,[M:PTH2]INVDTA(0..[M:PTH2]NBFAC-1))
#----- Si pas de montant, on peut récupérer le code taxe de l'élément cde -----#
If J<>0 & [M:PTH2]INVDTAAMT(J-1)=0 & [M:PTH2]INVORDAMT(J-1)=0
  [M:PTH2]INVDTAVAT(J-1)=WINVDTAVAT
#----- Autrement il faut que le code taxe corresponde -----#
Elsif J<>0 & [M:PTH2]INVDTAVAT(J-1)<>WINVDTAVAT
  K=find(WINVDTA,[M:PTH2]INVDTA(J..[M:PTH2]NBFAC-1))
  If K<>0
    J+=K
    If [M:PTH2]INVDTAVAT(J-1)<>WINVDTAVAT
      K=find([F:PVF]INVDTA,[M:PTH2]INVDTA(J..[M:PTH2]NBFAC-1))
      If K<>0
        J+=K
        If [M:PTH2]INVDTAVAT(J-1)<>WINVDTAVAT
          K=find(WINVDTA,[M:PTH2]INVDTA(J..[M:PTH2]NBFAC-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
  Else
    J=0
  Endif
Endif
#-----
If J=0 & [M:PTH2]NBFAC<dim([M:PTH2]INVDTA)
  #----- Elément non présent dans le tableau, on l'ajoute -----#
  J=[M:PTH2]NBFAC+1
  [M:PTH2]INVDTA(J-1)=WINVDTA
  Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$(WINVDTA),"") From ATEXTRA
  [M:PTH2]INVDTALIB(J-1)=GBIDC3
  If [F:PFI]VATRUL=2
    [M:PTH2]INVDTAVAT(J-1)=WINVDTAVAT : # Récupération code taxe saisi sur cde
  Endif
  [M:PTH2]INVDTAFLG(J-1)=1
  [M:PTH2]INVLINFLG(J-1)=[F:PFI]DSPLIN
  [M:PTH2]INVORDFLG(J-1)=[F:PFI]DACORD
  [M:PTH2]DEBCDT(J-1)   =[F:PFI]INCDCR
  [M:PTH2]CLCORD(J-1)   =[F:PFI]CLCORD
  [M:PTH2]CLCBAS(J-1)   =[F:PFI]CLCBAS
  If dim([M:PTH2]DISVATFLG)>0  [M:PTH2]DISVATFLG(J-1)=[F:PFI]DISVATFLG : Endif
  If dim([M:PTH2]DSP)>0
    [M:PTH2]DSP(J-1)    =[F:PFI]DSP
  Endif
  #----- Chargement comptes et sections analytiques -----#
  nolign=J : NOL=J-1
  If WABR="PVF"
    Call CHARG_ACCCCE(NOL,"[M:PTH2]ACC","[M:PTH2]DSP","[M:PTH2]PFICCE",
&                    "PVF",[F:PVF]VCRTYP,[F:PVF]VCRNUM,0,[F:PVF]IND,"") From TRTX3CPT
  Else
    Call INIT_COMPTES_INVDTA(NOL)   From SUBPTHD
  Endif
  GBIDI2=0 : Gosub PREP_INIT_PFICCE From SUBPTHD
  nolign=SVGNOLIGN : NOL=SVGNOL
  #-----
  [M:PTH2]NBFAC+=1
  #-----
Elsif [M:PTH2]INVORDAMT(J-1)=0 & NOL=0 & SENS=1 & [M:PTH1]LINFLG(NOL)=0
  #----- chargement comptes et sections analytiques si 1ère commande -----#
  If WABR="PVF"
    nolign=J : NOL=J-1
    Call CHARG_ACCCCE(NOL,"[M:PTH2]ACC","[M:PTH2]DSP","[M:PTH2]PFICCE",
&                    "PVF",[F:PVF]VCRTYP,[F:PVF]VCRNUM,0,[F:PVF]IND,"") From TRTX3CPT
    GBIDI2=0 : Gosub PREP_INIT_PFICCE From SUBPTHD
    nolign=SVGNOLIGN : NOL=SVGNOL
  Endif
  #-----
Endif
#----- C'est une remise sur taxe (Settlement discount) -----#
If J<>0 & dim([M:PTH2]DISVATFLG)>0 & [M:PTH2]DISVATFLG(J-1)=2
  [M:PTH2]INVORDAMT(J-1)=[F:PVF]INVDTAAMT
  [M:PTH1]CLCFLG=2 : # Positionnement de l'indicateur de calcul
Elsif J<>0
  Raz MT
  #----- Calcul des valeurs maxi (qté et montant) -----#
  If WABR="PVF"
    If [F:POQ]POHNUM<>[M:PTH1]POHNUM(NOL) |
&      [F:POQ]POPLIN<>[M:PTH1]POPLIN(NOL) |
&      [F:POQ]POQSEQ<>[M:PTH1]POQSEQ(NOL)
      Read [POQ] POQ0=[M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
    Endif
    Raz WQTEMAX, WMNTMAX
    If [M:PTH1]CREFLG(NOL)<>0
      WQTEMAX=min(max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU+[M:PTH1]INIQTYPUU(NOL),0),[F:POH]TOTLINQTY)
    Else
      WQTEMAX=min(max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0),[F:POH]TOTLINQTY)
    Endif
    # Issue 104735 - 2014-12-12 by SR :en import , on peut passer ici avant d'avoir
    # récupéré toute la ligne article. exemple : en AM_VACBPR
    If GIMPORT & [M:PTH1]UOMPUUCOE(NOL) = 0
        GBIDD1=[M:PTH1]NETPRI(NOL)*WQTEMAX/[F:POQ]UOMPUUCOE
    Else
        GBIDD1=[M:PTH1]NETPRI(NOL)*WQTEMAX/[M:PTH1]UOMPUUCOE(NOL)
    Endif
    # End issue 104735
    If WCUR<>[M:PTH0]CUR
      Call CONVERT([M:PTH0]CUR,WCUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                  [M:PTH0]RCPDAT,GBIDD1,WMNTMAX,STAT) From TRTDEV
    Else
       WMNTMAX=arr(GBIDD1,WRND)
    Endif
    WMNTMAX=min(WMNTMAX,[F:POH]TOTLINAMT)
  Else
    If [F:SDD]SDHNUM<>[M:PTH1]SDHNUM(NOL) |
&      [F:SDD]SDDLIN<>[M:PTH1]SDDLIN(NOL)
      Read [SDD] SDD0=[M:PTH1]SDHNUM(NOL);[M:PTH1]SDDLIN(NOL)
    Endif
    Raz WQTEMAX, WMNTMAX
    If [M:PTH1]CREFLG(NOL)<>0
      Call PCAL_QTY([M:PTH1]INIQTYPUU(NOL),[M:PTH1]PUU(NOL),WINIQTYSTU,[M:PTH1]STU(NOL),
&                   [M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,1,GBIDD1)  From TRTACHQTE1
      WQTEMAX=min(max([F:SDD]QTYSTU-[F:SDD]RCPQTYSTU+WINIQTYSTU,0),[F:SDH]DSPTOTQTY)
    Else
      WQTEMAX=min(max([F:SDD]QTYSTU-[F:SDD]RCPQTYSTU,0),[F:SDH]DSPTOTQTY)
    Endif
    # Issue 104735 - 2014-12-12 by SR :en import , on peut passer ici avant d'avoir
    # récupéré toute la ligne article. exemple : en AM_VACBPR
    If GIMPORT & [M:PTH1]UOMPUUCOE(NOL) = 0
       GBIDD1=[M:PTH1]NETPRI(NOL)*WQTEMAX/[F:SDD]SAUSTUCOE
    Else
       GBIDD1=[M:PTH1]NETPRI(NOL)*WQTEMAX/[M:PTH1]UOMSTUCOE(NOL)
    Endif
    # End issue 104735
    If WCUR<>[M:PTH0]CUR
      Call CONVERT([M:PTH0]CUR,WCUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                  [M:PTH0]RCPDAT,GBIDD1,WMNTMAX,STAT) From TRTDEV
    Else
       WMNTMAX=arr(GBIDD1,WRND)
    Endif
    WMNTMAX=min(WMNTMAX,[F:SDH]DLVNOT)
  Endif
  #----- C'est un montant -----#
  If WAMTCOD=2
    #----- Calcul du montant par une règle de trois -----#
    If find([F:PFI]TRFINV,1,2,3,4)
      If [F:PFI]TRFINV=1
        #----- Calcul au prorata des montants -----#
        MT2=[M:PTH1]LINAMT(NOL)
        If WCUR<>[M:PTH0]CUR : # Si devise différente, conversion
          Call CONVERT([M:PTH0]CUR,WCUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                      [M:PTH0]RCPDAT,MT2,GBIDD1,STAT) From TRTDEV
        Else
          GBIDD1=MT2
        Endif
        If WTOTLINAMT>min(GBIDD1,WMNTMAX) & WTOTLINAMT<>0
          If WMNTMAX>GBIDD1
            MT=WINVDTAAMT*GBIDD1/WTOTLINAMT
          Else
            MT=WINVDTAAMT*WMNTMAX/WTOTLINAMT
          Endif
        Else
          MT=WINVDTAAMT
        Endif
      Elsif [F:PFI]TRFINV=2
        #----- Calcul au prorata des quantités -----#
        If WABR="PVF"
          GBIDD1=[M:PTH1]QTYPUU(NOL)
        Else
          GBIDD1=[M:PTH1]QTYSTU(NOL)
        Endif
        If WTOTLINQTY>min(GBIDD1,WQTEMAX) & WTOTLINQTY<>0
          If WQTEMAX>GBIDD1
            MT=WINVDTAAMT*GBIDD1/WTOTLINQTY
          Else
            MT=WINVDTAAMT*WQTEMAX/WTOTLINQTY
          Endif
        Else
          MT=WINVDTAAMT
        Endif
      Else
        #----- Calcul au prorata des poids ou des volumes -----#
        If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
          Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
        Endif
        #----- Calcul des quantités en US -----#
        WQTYSTU   =[M:PTH1]QTYSTU(NOL)
        If WABR="PVF"
          WQTYSTUMAX=max([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU,0)
        Else
          WQTYSTUMAX=max([F:SDD]QTYSTU-[F:SDD]RCPQTYSTU,0)
        Endif
        If [F:PFI]TRFINV=3
          #----- Calcul au prorata des poids -----#
          GBIDD1=[F:ITM]ITMWEI*WQTYSTU
          Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD1) From TRTX3
          GBIDD2=[F:ITM]ITMWEI*WQTYSTUMAX
          Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD2) From TRTX3
          If WTOTLINWEU>min(GBIDD1,GBIDD2) & WTOTLINWEU<>0
            If GBIDD2>GBIDD1
              MT=WINVDTAAMT*GBIDD1/WTOTLINWEU
            Else
              MT=WINVDTAAMT*GBIDD2/WTOTLINWEU
            Endif
          Else
            MT=WINVDTAAMT
          Endif
        Else
          #----- Calcul au prorata des volumes -----#
          GBIDD1=[F:ITM]ITMVOU*WQTYSTU
          Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD1) From TRTX3
          GBIDD2=[F:ITM]ITMVOU*WQTYSTUMAX
          Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD2) From TRTX3
          If WTOTLINVOU>min(GBIDD1,GBIDD2) & WTOTLINVOU<>0
            If GBIDD2>GBIDD1
              MT=WINVDTAAMT*GBIDD1/WTOTLINVOU
            Else
              MT=WINVDTAAMT*GBIDD2/WTOTLINVOU
            Endif
          Else
            MT=WINVDTAAMT
          Endif
        Endif
      Endif
    #----- Prise en compte intégrale du montant sur 1ère réception ou toutes -----#
    Else
      If WABR="PVF"
        [M:PTH1]POHNUM(NOL)=""
        If !find([F:POH]POHNUM,[M:PTH1]POHNUM(0..max([M:PTH1]NBLIG,NOL+1)-1))
          If [F:PFI]TRFINV=6 | ([F:PFI]TRFINV=5 & [F:POH]RCPNBR=0)
            MT=WINVDTAAMT
          Endif
        Endif
        [M:PTH1]POHNUM(NOL)=[F:POH]POHNUM
      Else
        [M:PTH1]SDHNUM(NOL)=""
        If !find([F:SDH]SDHNUM,[M:PTH1]SDHNUM(0..max([M:PTH1]NBLIG,NOL+1)-1))
          If [F:PFI]TRFINV=6
            MT=WINVDTAAMT
          Elsif [F:PFI]TRFINV=5
            Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & RCPFLG<>0
            Look [SDD] SDD0 First
            If fstat  MT=WINVDTAAMT : Endif
            Filter [SDD]
          Endif
        Endif
        [M:PTH1]SDHNUM(NOL)=[F:SDH]SDHNUM
      Endif
    Endif
    #----- Conversion du montant calculé en devise réception si nécessaire -----#
    If WCUR<>[M:PTH0]CUR : # Si devise différente, conversion
      Call CONVERT(WCUR,[M:PTH0]CUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                  [M:PTH0]RCPDAT,MT,GBIDD1,STAT) From TRTDEV
      MT=GBIDD1
    Endif
    #----- Mt pied de commande = Mt élément -----#
    MT1=MT
  #----- C'est un pourcentage ou une action -----#
  Else
    #----- Calcul au prorata des montants du pied de commande -----#
    MT2=[M:PTH1]LINAMT(NOL)
    If WCUR<>[M:PTH0]CUR : # Si devise différente, conversion
      Call CONVERT([M:PTH0]CUR,WCUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                  [M:PTH0]RCPDAT,MT2,GBIDD1,STAT) From TRTDEV
    Else
      GBIDD1=MT2
    Endif
    If WTOTLINAMT>min(GBIDD1,WMNTMAX) & WTOTLINAMT<>0
      If WMNTMAX>GBIDD1
        MT1=abs(WINVORDAMT)*GBIDD1/WTOTLINAMT
      Else
        MT1=abs(WINVORDAMT)*WMNTMAX/WTOTLINAMT
      Endif
    Else
      MT1=abs(WINVORDAMT)
    Endif
    #-----
    If [F:PFI]CLCBAS=2
      MT=[M:PTH1]LINAMT(NOL)*WINVDTAAMT/100
    Elsif [F:PFI]CLCBAS=3
      MT=[M:PTH1]LINATIAMT(NOL)*WINVDTAAMT/100
    Elsif [F:PFI]CLCBAS=4
      #----- Si action, calcul au prorata des montants (récupération du MT1) -----#
      MT=MT1
      #-----
    Endif
  Endif
  #----- Récupération du montant facturé (une seule fois par commande) -----#
  Raz MT2
  If WABR="PVF"
    [M:PTH1]POHNUM(NOL)=""
    If !find([F:POH]POHNUM,[M:PTH1]POHNUM(0..max([M:PTH1]NBLIG,NOL+1)-1))
      #----- Conversion du montant facturé en devise réception si nécessaire -----#
      If [F:POH]CUR<>[M:PTH0]CUR : # Si devise différente, conversion
        Call CONVERT([F:POH]CUR,[M:PTH0]CUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                    [M:PTH0]RCPDAT,[F:PVF]INVCPLAMT,MT2,STAT) From TRTDEV
      Else
        MT2=[F:PVF]INVCPLAMT
      Endif
    Endif
    [M:PTH1]POHNUM(NOL)=[F:POH]POHNUM
  Endif
  #-----
  MT =arr(MT ,WRND)
  MT1=arr(MT1,WRND)
  If ([M:PTH2]DEBCDT(J-1)=2)  MT=-MT : Endif : # Si minoration
  Call MAJ_ELEMENT(J-1,0,-2) From SUBPTHD
  # Issue X3-73377 - 2018-01-29 by MUARN : ne pas faire sur le service
  If ([M:PTH1]LINTYP(NOL)<>3 & [M:PTH2]INVLINFLG(J-1)=2) | ([M:PTH1]LINTYP(NOL)<>2 & [M:PTH2]INVLINFLG(J-1)=3) |
&    ([M:PTH1]LINTYP(NOL)<3 & [M:PTH2]INVLINFLG(J-1)=4)  | ([M:PTH1]LINTYP(NOL)<3 & [M:PTH2]INVLINFLG(J-1)=5)
    If SENS=1
      [M:PTH2]INVDTAAMT(J-1)+=MT
      [M:PTH2]INVORDAMT(J-1)+=MT1
      [M:PTH2]INVCPLAMT(J-1)+=MT2*(3-2*[M:PTH2]DEBCDT(J-1))
    Else
      [M:PTH2]INVDTAAMT(J-1)-=MT
      [M:PTH2]INVORDAMT(J-1)-=MT1
      [M:PTH2]INVCPLAMT(J-1)-=MT2*(3-2*[M:PTH2]DEBCDT(J-1))
    Endif
  Endif
  Call MAJ_ELEMENT(J-1,0,+2) From SUBPTHD
  #-----
Endif
Return

#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 22/06/05 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de réception                  #
# --------------------------------------------------------------------- #
# Subprog MAJ_BASTAX_LIG(NOL,SENS)                                      #
#   NOL    : indice de la ligne de réception (nolign-1)                 #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
#########################################################################
Subprog MAJ_BASTAX_LIG(NOL,SENS)
Value   Shortint NOL
Value   Integer  SENS
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#---- Test si ligne existe bien (Avant ligne d'une nouvelle ligne) ----#
If [M:PTH1]ITMREF(NOL)=""  End : Endif
#----- Si c'est le composé (produit fini), pas de chiffrage -----#
If [M:PTH1]LINTYP(NOL)=2   End : Endif
# Issue 105460 - 2015-01-15 by SR : En import, il se peut que tout ne soit pas encore chargé
If GIMPORT & [M:PTH1]LINPURTYP(NOL)=0  End : Endif
# End issue 105460

#----- Variables locales -----#
Local   Shortint I, J, K, I2, J2, K2
Local   Integer  STAT
Local   Decimal  MT, WBASE, WDISBASE, WAMTTAX, WDEDTAX, MT2
Local   Char     WTAX(GLONVAT)
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PTH1]TAXRCP)>0)
  Raz WDISBASE
  Case I
    When 1 : WTAX   =[M:PTH1]VAT1(NOL)       : WBASE  =[M:PTH1]BASTAXLIN1(NOL)
             WAMTTAX=[M:PTH1]AMTTAXLIN1(NOL) : WDEDTAX=[M:PTH1]DEDTAXLIN1(NOL)
             If dim([M:PTH1]DISBASLIN1)>0
               WDISBASE=[M:PTH1]DISBASLIN1(NOL)
             Endif
    When 2 : WTAX   =[M:PTH1]VAT2(NOL)       : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXLIN2(NOL) : WDEDTAX=[M:PTH1]DEDTAXLIN2(NOL)
    When 3 : WTAX   =[M:PTH1]VAT3(NOL)       : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXLIN3(NOL) : WDEDTAX=[M:PTH1]DEDTAXLIN3(NOL)
    When 4 : WTAX   =[M:PTH1]TAXRCP(NOL)     : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXRCP(NOL)  : WDEDTAX=[M:PTH1]DEDTAXRCP(NOL)
    When 5 : WTAX   =[M:PTH1]TAXISS(NOL)     : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXISS(NOL)  : WDEDTAX=[M:PTH1]DEDTAXISS(NOL)
    When 6 : WTAX   =[M:PTH1]TAXOTH1(NOL)    : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXOTH1(NOL) : WDEDTAX=[M:PTH1]DEDTAXOTH1(NOL)
    When 7 : WTAX   =[M:PTH1]TAXOTH2(NOL)    : WBASE  =[M:PTH1]LINAMT(NOL)
             WAMTTAX=[M:PTH1]AMTTAXOTH2(NOL) : WDEDTAX=[M:PTH1]DEDTAXOTH2(NOL)
  Endcase
  If WTAX<>""
    #If [F:TVT]VAT<>WTAX :#--CPO 71937 test fait dans le sous-pro, sinon tester aussi la leg
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,WTAX,WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
#      Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
    #Endif
    If I>1 & [F:TVT]VATBAS>1
      WBASE=evalue("[M:PTH1]CLCAMT"+num$(I)+"(NOL)") : # Bases spéciales 2-7
    Endif
    #----- Recherche si taxe déja existante -----#
    J=find(WTAX,[M:PTH2]TAX(0..[M:PTH2]NBTAX-1))
    If J<>0 & [M:PTH2]PURTYP(J-1)<>[M:PTH1]LINPURTYP(NOL)
      K=find(WTAX,[M:PTH2]TAX(J..[M:PTH2]NBTAX-1))
      If K<>0
        J+=K
        If [M:PTH2]PURTYP(J-1)<>[M:PTH1]LINPURTYP(NOL)
          K=find(WTAX,[M:PTH2]TAX(J..[M:PTH2]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----#
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! ------#
      If [M:PTH2]NBTAX>=dim([M:PTH2]TAX)
        Call ERREUR (WTAX-mess(300,194,1)) From GESECRAN
        Goto MAJ_SUIT1
      Endif
      #-----
      J=[M:PTH2]NBTAX
      [M:PTH2]NBTAX+=1
      [M:PTH2]TAX(J)=WTAX
      Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PTH2]LIBTAX(J)) From TRTX3TEX
      [M:PTH2]PURTYP(J)=[M:PTH1]LINPURTYP(NOL)
      [M:PTH2]VATTYP(J)=[F:TVT]VATTYP
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    If SENS=1
      If dim([M:PTH2]DISBAS)>0  [M:PTH2]DISBAS(J)+=WDISBASE : Endif
      [M:PTH2]BASTAX(J)+=WBASE
      [M:PTH2]AMTTAX(J)+=WAMTTAX
      [M:PTH2]DEDTAX(J)+=WDEDTAX
    Else
      If dim([M:PTH2]DISBAS)>0  [M:PTH2]DISBAS(J)-=WDISBASE : Endif
      [M:PTH2]BASTAX(J)-=WBASE
      [M:PTH2]AMTTAX(J)-=WAMTTAX
      [M:PTH2]DEDTAX(J)-=WDEDTAX
      #----- Suppression ligne taxe si aucun montant -----#
      If [M:PTH2]BASTAX(J)=0 & [M:PTH2]AMTTAX(J)=0 & [M:PTH2]DEDTAX(J)=0
        If !GIMPORT
          Dela J,1,[M:PTH2]NBTAX-1 [M:PTH2]NBTAX : [M:PTH2]NBTAX-=1
        Endif
      Endif
    Endif
  Endif
$MAJ_SUIT1
Next I
End


########################################################################
# MAJ_CPR_LIG : S/P de calcul prix unitaire de revient    MBT 29/06/05 #
# -------------------------------------------------------------------- #
# Subprog MAJ_CPR_LIG(NOL)                                             #
#   NOL    : indice de la ligne de réception (nolign-1)                #
########################################################################
Subprog MAJ_CPR_LIG (NOL)
Value Shortint NOL
Local Decimal  WCPRAMT, WUOMSTUCOE # Issue 70985 - 2012-04-10 by MUARN : landedcost
Local Date     WDATE # Issue 84129 - 2012-10-03 by MUARN : cout achat besoin date devise
Local Char     WCUR # Issue 84129 - 2012-10-03 by MUARN : cout achat besoin date devise
Local Integer  WCHGTYP # Issue 84129 - 2012-10-03 by MUARN : cout achat besoin date devise

# Issue 105027 - 2015-02-13 by MUARN : gestion inter site
If [M:PTH0]BETFCY=1 | [M:PTH0]BETCPY =2
  #----- Si composant, pas de calcul prix de revient -----#
  If [M:PTH1]LINTYP(NOL)>2
    Raz [M:PTH1]CPR(NOL), [M:PTH1]CPRPRI(NOL) : End
  Endif
  #-----
  Local   Decimal  WPRIPUR
  Local   Decimal  WBASE, WMT, WNEWCPR, WRND, WTAXE
  Local   Integer  STAT, I, J, WCPRFLG
  #----- Chargement arrondi devise facture -----#
  If [F:TCU]CUR<>[M:PTH0]CUR
    Read [TCU] TCU0=[M:PTH0]CUR
    If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
  Else
    WRND=[F:TCU]CURRND
  Endif
  #-----
  If [M:PTH1]LINTYP(NOL)=2
    J=NOL+1
    While [M:PTH1]LINTYP(J)>2 & J<[M:PTH1]NBLIG
      If [M:PTH1]QTYUOM(J)<>0
        WBASE+=[M:PTH1]NETPRI(J)*[M:PTH1]QTYUOM(J)  : # Mt ligne avec précision maxi
      Else
        WBASE+=[M:PTH1]LINAMT(J)                    : # Mt ligne arrondi suivant devise
      Endif
      J+=1
    Wend
  Else
    If [M:PTH1]QTYUOM(NOL)<>0
      WBASE=[M:PTH1]NETPRI(NOL)*[M:PTH1]QTYUOM(NOL) : # Mt ligne avec précision maxi
    Else
      WBASE=[M:PTH1]LINAMT(NOL)                     : # Mt ligne arrondi suivant devise
    Endif
  Endif
  #----- Eléments provenant du tarif -----#
  For I=1 To 9
    If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
      Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PTH1]LINTYP(NOL)=2
          J=NOL+1 : Raz WMT
          While [M:PTH1]LINTYP(J)>2 & J<[M:PTH1]NBLIG
            #----- C'est un montant -----#
            If GDISCRGTYP(I-1)=1
              If GCLCRUL(I-1)=1 : # Par unité
                WMT+=evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(J)")*[M:PTH1]QTYUOM(J)
              Else              : # Par ligne
                WMT+=evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(J)")
              Endif
            #----- C'est un pourcentage -----#
            Else
              WMT+=arr([M:PTH1]LINAMT(J)*evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(J)")/100,WRND)
            Endif
            J+=1
          Wend
        Else
          #----- C'est un montant -----#
          If GDISCRGTYP(I-1)=1
            If GCLCRUL(I-1)=1 : # Par unité
              WMT=evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")*[M:PTH1]QTYUOM(NOL)
            Else              : # Par ligne
              WMT=evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")
            Endif
          #----- C'est un pourcentage -----#
          Else
            WMT=arr([M:PTH1]LINAMT(NOL)*evalue("[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
          Endif
        Endif
        If GINCDCR(I-1)=2  WBASE-=WMT  Else WBASE+=WMT : Endif
      Endif
    Endif
  Next I

  #----- Eléments provenant du pied de réception -----#
  For I=1 To 9
    If [M:PTH1]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[M:PTH1]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PTH1]LINTYP(NOL)=2
          J=NOL+1
          While [M:PTH1]LINTYP(J)>2 & J<[M:PTH1]NBLIG
            WBASE+=evalue("[M:PTH1]DISCRGAMT"+num$(I)+"(J)")
            J+=1
          Wend
        Endif
        WBASE+=evalue("[M:PTH1]DISCRGAMT"+num$(I)+"(NOL)")
      Endif
    Endif
  Next I

  #----- Conversion si nécessaire du montant en devise société -----#
  # Issue 84129 - 2012-10-03 by MUARN : landedcost cout achat besoin date pour devise
  WDATE = [M:PTH0]RCPDAT
  WCUR = [M:PTH0]CUR
  WCHGTYP = [M:PTH0]CHGTYP
  If [M:PTH0]CUR<>GLOCALDEV
    WMT=WBASE
    If GPTHCURDAT<>2 & [M:PTH1]POHNUM(NOL)<>""
      If [F:POH]POHNUM<>[M:PTH1]POHNUM(NOL)
        Read [POH] POH0=[M:PTH1]POHNUM(NOL)
        If fstat
          Raz [F:POH] : [F:POH]ORDDAT=[M:PTH0]RCPDAT : [F:POH]CHGTYP=[M:PTH0]CHGTYP
        Endif
      Endif
      Call CONVERT2([M:PTH0]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                  WMT,WBASE,STAT) From TRTDEV
      WBASE=arr(WBASE,10^-GDECPRI)
      # Issue 84129 - 2012-10-03 by MUARN : landedcost cout achat besoin date pour devise
      WDATE = [F:POH]ORDDAT
      WCHGTYP = [F:POH]CHGTYP
    Else
      If [M:PTH0]CHGCOE=0
        Call CONVERT2([M:PTH0]CUR,GLOCALDEV,GLOCALDEV,[M:PTH0]CHGTYP,[M:PTH0]RCPDAT,
&                    WMT,WBASE,STAT) From TRTDEV
        WBASE=arr(WBASE,10^-GDECPRI)
      Else
        WBASE=arr(WMT*[M:PTH0]CHGCOE,10^-GDECPRI)
      Endif
    Endif
  Endif
  #----- Calcul prix unitaire d'achat en devise société et par unité de stock -----#
  Call CALCUL_PRIPUR(NOL,WPRIPUR) From SUBPTHB

  # Issue 70985 - 2012-02-20 by MUARN : landed cost ajour coût achat forfaitaire
  # Issue 93835 - 2013-10-24 by MUARN : utilisation GBIDD1 ne pas écraser QTYSTU
  Call PCAL_QTY([M:PTH1]QTYPUU(NOL),[M:PTH1]PUU(NOL),GBIDD1,[M:PTH1]STU(NOL),
&             [M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
  WCPRAMT = arr([M:PTH1]CPRAMT(NOL)/WUOMSTUCOE,10^-GDECPRI)

  #----- Le prix de revient (prix ordre) a t-il été modifié manuellement ? -----#
  # Issue 84130 - 2012-12-20 by MAE : landed cost
  If [M:PTH1]CPR(NOL)=[M:PTH1]CPRCLC(NOL)
    WCPRFLG=1 : # Non
  Else
    WCPRFLG=2 : # Oui
  Endif

  #----- Calcul du prix unitaire de revient théorique en US -----#
  If [M:PTH1]QTYSTU(NOL)<>0
    [M:PTH1]CPRPRI(NOL)=arr(WBASE/[M:PTH1]QTYSTU(NOL),10^-GDECPRI)
  Else
    [M:PTH1]CPRPRI(NOL)=WBASE
  Endif

  #------------- Point d'entrée CPRCAL --------------#
  # WCPRFLG : Indicateur recalcul du prix de revient #
  #           1 = Recalcul du CPR                    #
  #           2 = Pas de recalcul du CPR             #
  #                                                  #
  # WNEWCPR : Nouveau prix de revient si recalcul    #
  #                                                  #
  # [M:PTH1]CPR(NOL) : Ancien prix de revient        #
  #           Peut être modifié si WRCPFLG=2         #
  #--------------------------------------------------#
  # Issue 70985 - 2012-02-20 by MUARN : landed cost ajour coût achat forfaitaire
  # Issue 93835 - 2013-10-24 by MUARN : utilisation GBIDD1 ne pas écraser QTYSTU
  Call PCAL_QTY([M:PTH1]QTYPUU(NOL),[M:PTH1]PUU(NOL),GBIDD1,[M:PTH1]STU(NOL),
&             [M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
  WCPRAMT = arr([M:PTH1]CPRAMT(NOL)/WUOMSTUCOE,10^-GDECPRI)
  WNEWCPR=arr([M:PTH1]CPRPRI(NOL)-WPRIPUR+(WPRIPUR*[M:PTH1]CPRCOE(NOL))+WCPRAMT,10^-GDECPRI)
  Gosub POINT_CPRCAL From SUBPTHA
  #----- Calcul prix de revient (prix ordre) si pas de facture et non modifié -----#
  # Issue 84130 - 2013-02-06 by MUARN : Landed cost
  If [M:PTH1]INVQTYSTU(NOL)=0
    # Issue 84130 - 2013-02-06 by MUARN : landed cost - ajout gestion flag WCPRFGL et champ CPRCLC
    If WCPRFLG=1
      [M:PTH1]CPR(NOL)=[M:PTH1]CPRPRI(NOL)-WPRIPUR+(WPRIPUR*[M:PTH1]CPRCOE(NOL)+WCPRAMT)
    Endif
    [M:PTH1]CPRCLC(NOL)=[M:PTH1]CPRPRI(NOL)-WPRIPUR+(WPRIPUR*[M:PTH1]CPRCOE(NOL)+WCPRAMT)

    If GNODVATSTO = 2
      WTAXE = 0
      #----- Taxes non déductible -----#
      WTAXE+=[M:PTH1]AMTTAXLIN1(NOL)-[M:PTH1]DEDTAXLIN1(NOL)
      WTAXE+=[M:PTH1]AMTTAXLIN2(NOL)-[M:PTH1]DEDTAXLIN2(NOL)
      WTAXE+=[M:PTH1]AMTTAXLIN3(NOL)-[M:PTH1]DEDTAXLIN3(NOL)
      If dim([M:PTH1]AMTTAXRCP(NOL))>0
        WTAXE+=[M:PTH1]AMTTAXRCP(NOL) -[M:PTH1]DEDTAXRCP(NOL)
        WTAXE+=[M:PTH1]AMTTAXISS(NOL) -[M:PTH1]DEDTAXISS(NOL)
        WTAXE+=[M:PTH1]AMTTAXOTH1(NOL)-[M:PTH1]DEDTAXOTH1(NOL)
        WTAXE+=[M:PTH1]AMTTAXOTH2(NOL)-[M:PTH1]DEDTAXOTH2(NOL)
      Endif

      If [M:PTH0]CUR<>GLOCALDEV
        WMT=WTAXE
        Call CONVERT2([M:PTH0]CUR, GLOCALDEV, GLOCALDEV,[M:PTH0]CHGTYP,[M:PTH0]RCPDAT,
&                    WMT,WTAXE,STAT) From TRTDEV
      Endif

      If [M:PTH1]QTYSTU(NOL)<>0
        # Issue 84130 - 2013-02-06 by MUARN : landed cost - ajout gestion flag WCPRFGL et champ CPRCLC
        If WCPRFLG=1
          [M:PTH1]CPR(NOL) += (WTAXE/[M:PTH1]QTYSTU(NOL))
        Endif
        [M:PTH1]CPRCLC(NOL) += (WTAXE/[M:PTH1]QTYSTU(NOL))
      Endif
    Endif

    # Issue 100325 - 2014-11-04 by MUARN : ne faire l'arrondi qu'à la fin
    # Issue 84130 - 2013-02-06 by MUARN : landed cost - ajout gestion flag WCPRFGL et champ CPRCLC
    #If WCPRFLG=1
    #  [M:PTH1]CPR(NOL)=arr([M:PTH1]CPR(NOL),10^-GDECPRI)
    #Endif
    #[M:PTH1]CPRCLC(NOL)=arr([M:PTH1]CPRCLC(NOL),10^-GDECPRI)

    [M:PTH1]LINAMTCPR(NOL)=[M:PTH1]CPR(NOL)*[M:PTH1]QTYSTU(NOL)
    # Issue 84130 - 2012-12-17 by SR : Si structure de cout
     If [M:PTH1]STCNUM(NOL) <> ""
         [M:PTH1]LINAMTCPR(NOL) += [M:PTH1]FCSCPR(NOL)
         [M:PTH1]CPR(NOL)        = [M:PTH1]LINAMTCPR(NOL) / [M:PTH1]QTYSTU(NOL)
         [M:PTH1]CPR(NOL)        = arr([M:PTH1]CPR(NOL),10^-GDECPRI)
         [M:PTH1]CPRCLC(NOL)     = [M:PTH1]LINAMTCPR(NOL) / [M:PTH1]QTYSTU(NOL)
         [M:PTH1]CPRCLC(NOL)     = arr([M:PTH1]CPRCLC(NOL),10^-GDECPRI)
    Endif
    # Issue 100325 - 2014-11-04 by MUARN : ne faire l'arrondi qu'à la fin
    If WCPRFLG=1
      [M:PTH1]CPR(NOL)=arr([M:PTH1]CPR(NOL),10^-GDECPRI)
    Endif
    [M:PTH1]CPRCLC(NOL)=arr([M:PTH1]CPRCLC(NOL),10^-GDECPRI)

    [M:PTH1]LINAMTCPR(NOL)= arr([M:PTH1]LINAMTCPR(NOL),10^-GDECPRI)

    If !GIMPORT & !GPTH_PICK  Affzo [PTH1]CPR(NOL), LINAMTCPR(NOL) : Endif
  #--- Issue 84130 - 2013-06-14 by TS
  Else
    [M:PTH1]LINAMTCPR(NOL)=[M:PTH1]CPR(NOL)*[M:PTH1]QTYSTU(NOL)
  #---
  Endif
Endif

[M:PTH1]UPDFLG(NOL)=1

# Issue 84129 - 2012-10-03 by MUARN : calcul cout achat et cout achat unitaire
Call MAJ_CSTPUR_LIG("PTH1",NOL,WDATE,WCUR, WCHGTYP) From STCCLC
If !GIMPORT & !GPTH_PICK
    Affzo [PTH1]CSTPUR(NOL) ,LINCSTPUR(NOL)
Endif

End


########################################################################
# REAJUST_BASTAXLIN1 : S/P de réajustement de la base     MBT 29/06/05 #
#            de TVA si modif d'un montant de taxe parafiscale          #
#            ou spéciale soumise à TVA                                 #
# -------------------------------------------------------------------- #
# Subprog REAJUST_BASTAXLIN1 (NOL,MT)                                  #
#   NOL    : Indice de la ligne de réception concernée                 #
#   MT     : Montant de l'écart pour mise à jour                       #
########################################################################
Subprog REAJUST_BASTAXLIN1 (NOL,MT)
Value   Shortint   NOL
Value   Decimal    MT
#----- Variables locales -----#
Local   Shortint   I, J
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#----- Mise à jour base taxe de la ligne de réception -----#
[M:PTH1]BASTAXLIN1(NOL)+=MT
#----- Recherche si taxe déja existante -----#
I=find([M:PTH1]VAT1(NOL),[M:PTH2]TAX(0..[M:PTH2]NBTAX-1))
If I<>0 & [M:PTH2]PURTYP(I-1)<>[M:PTH1]LINPURTYP(NOL)
   J=find([M:PTH1]VAT1(NOL),[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
  #If J<>0 I+=J Else I=0 : Endif
   If J<>0
     I+=J
     If [M:PTH2]PURTYP(I-1)<>[M:PTH1]LINPURTYP(NOL)
       J=find([M:PTH1]VAT1(NOL),[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
       If J<>0 I+=J Else I=0 : Endif
     Endif
   Else
     I=0
   Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PTH2]NBTAX>=dim([M:PTH2]TAX)
    Call ERREUR ([M:PTH1]VAT1(NOL)-mess(300,194,1)) From GESECRAN
    End
  Endif
  #-----
  I=[M:PTH2]NBTAX
  [M:PTH2]NBTAX+=1
  [M:PTH2]TAX(I)=[M:PTH1]VAT1(NOL)
  # Issue 71937 - 2012-03-27 by SR : comment
  #--CPO 71937 pas le wtax [M:PTH1]VAT1(NOL)
  #Call LEC_TVT_LEG(GCURLEG,WTAX,WRET) From TRTLECLEG
  Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT1(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #--/CPO
  #Read [TVT] TVT0=[M:PTH1]VAT1(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PTH2]LIBTAX(I)) From TRTX3TEX
  [M:PTH2]PURTYP(I)=[M:PTH1]LINPURTYP(NOL)
  [M:PTH2]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:PTH2]BASTAX(I)+=MT : GPTH_INDBASTAX(I)=1
End


########################################################################
# REAJUST_CLCAMT : S/P de réajustement des bases          MBT 29/06/05 #
#            spéciales si modif du montant de taxe principale          #
#            et base spéciale incluant la taxe (Canada)                #
# -------------------------------------------------------------------- #
# Subprog REAJUST_CLCAMT (NOL,MT)                                      #
#   NOL       : Indice de la ligne de réception concernée              #
#   MT        : Montant de l'écart pour mise à jour                    #
#   CLCAMTFLG : Indicateur màj                                         #
#               1=Base 1                                               #
#               2=Base 2   3=Bases 1+2                                 #
#               4=Base 3   5=Bases 1+3   6=Bases 2+3   7=Bases 1+2+3   #
#               8=Base 4   9=Bases 1+8  10=Bases 2+8  11=Bases 1+2+8   #
#               ... etc                                                #
########################################################################
Subprog REAJUST_CLCAMT (NOL,MT,CLCAMTFLG)
Value   Shortint   NOL
Value   Decimal    MT
Value   Shortint   CLCAMTFLG
#----- Variables locales -----#
Local   Shortint   I, J, L
Local   Char       VATSPE(GLONVAT)
#-----
For L=3+4*(func AFNC.ACTIV("PTX") & dim([M:PTH1]TAXRCP)>0) To 2 Step -1
  If CLCAMTFLG>=2^L-1
    Case L
      When 2 : VATSPE=[M:PTH1]VAT2(NOL)
      When 3 : VATSPE=[M:PTH1]VAT3(NOL)
      When 4 : VATSPE=[M:PTH1]TAXRCP(NOL)
      When 5 : VATSPE=[M:PTH1]TAXISS(NOL)
      When 6 : VATSPE=[M:PTH1]TAXOTH1(NOL)
      When 7 : VATSPE=[M:PTH1]TAXOTH2(NOL)
    Endcase
    Gosub MAJ_BASTAX_CLCAMT
    CLCAMTFLG-=2^L-1
  Endif
Next L
End
#-----------------------------------------------------#
# Mise à jour de la base de taxe du tableau des taxes #
#-----------------------------------------------------#
$MAJ_BASTAX_CLCAMT
#If [F:TVT]VAT<>VATSPE :#--CPO 71937 le test est fait dans le sous-pro sinon il faut tester aussi la leg
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,VATSPE,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#  Read [TVT] TVT0=VATSPE : If fstat  Raz [F:TVT] : Endif
#Endif
#----- Si pas montant 1 ou 2 alors pas de mise à jour -----#
If [F:TVT]VATBAS<2  Return : Endif
#----- Mise à jour bases spéciales 2-7 de la ligne -----#
Case L
  When 2 : [M:PTH1]CLCAMT2(NOL)+=MT
  When 3 : [M:PTH1]CLCAMT3(NOL)+=MT
  When 4 : [M:PTH1]CLCAMT4(NOL)+=MT
  When 5 : [M:PTH1]CLCAMT5(NOL)+=MT
  When 6 : [M:PTH1]CLCAMT6(NOL)+=MT
  When 7 : [M:PTH1]CLCAMT7(NOL)+=MT
Endcase
#----- Recherche si taxe déja existante -----#
I=find(VATSPE,[M:PTH2]TAX(0..[M:PTH2]NBTAX-1))
If I<>0 & [M:PTH2]PURTYP(I-1)<>[M:PTH1]LINPURTYP(NOL)
  J=find(VATSPE,[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
  If J<>0
    I+=J
    If [M:PTH2]PURTYP(I-1)<>[M:PTH1]LINPURTYP(NOL)
      J=find(VATSPE,[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
      If J<>0  I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PTH2]NBTAX>=dim([M:PTH2]TAX)
    Call ERREUR (VATSPE-mess(300,194,1)) From GESECRAN : End
  Endif
  #-----
  I=[M:PTH2]NBTAX
  [M:PTH2]NBTAX+=1
  [M:PTH2]TAX(I)=VATSPE
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,VATSPE,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=VATSPE : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PTH2]LIBTAX(I)) From TRTX3TEX
  [M:PTH2]PURTYP(I)=[M:PTH1]LINPURTYP(NOL)
  [M:PTH2]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:PTH2]BASTAX(I)+=MT
Return


####################################################################
# Recalcul de la taxe globalement à partir de la base taxe cumulée #
# ---------------------------------------------------------------- #
#      GPTH_INDTAX  = Numéro de la ligne de taxe à traiter         #
#                I  = Indice de la ligne de taxe à traiter         #
# [M:PTH2]TAX   (I) = Code taxe à traiter                          #
# [M:PTH2]BASTAX(I) = Base taxe cumulée à traiter                  #
####################################################################
$CAL_TAXE_GLOB
If GPTH_INDTAX=0 | GPTH_INDTAX>[M:PTH2]NBTAX  Return : Endif
If dim(I)<0 Local Shortint I : Endif
I=GPTH_INDTAX-1
Local Integer  TYPREG,  STAT, NUMLIG_DISVAT
Local Decimal  MONTANT, MONTDED, SEUIL
Local Char     TAXE(GLONVAT)
#----- Si taxe classique, recherche présence remise sur taxe (Settlement discount) -----#
If [M:PTH2]VATTYP(I)=1
  If dim([M:PTH2]DISVATFLG)>0
    J=0
    NUMLIG_DISVAT=find(2,[M:PTH2]DISVATFLG(J..[M:PTH2]NBFAC-1))
    If NUMLIG_DISVAT
      If [M:PTH2]INVORDAMT(NUMLIG_DISVAT-1)=0
        J=NUMLIG_DISVAT
        NUMLIG_DISVAT=find(2,[M:PTH2]DISVATFLG(J..[M:PTH2]NBFAC-1))
        If NUMLIG_DISVAT & [M:PTH2]INVORDAMT(NUMLIG_DISVAT-1)=0
          Raz NUMLIG_DISVAT
        Endif
      Endif
    Endif
  Endif
  If NUMLIG_DISVAT | (dim([M:PTH2]DISBAS)>0 & [M:PTH2]DISBAS(I)<>0)
    Gosub SETTLEMENT_DISCOUNT
  Endif
Endif
#-----
TAXE=[M:PTH2]TAX(I)
Call CALTAXE(GSOCIETE,[M:PTH0]RCPDAT,[M:PTH0]VACBPR,GCUR,1,TAXE,1,
&         [M:PTH2]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
  Call CONVERT(GCURSHR,[M:PTH0]CUR,GLOCALDEV,[M:PTH0]CHGTYP,
&               [M:PTH0]RCPDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
  If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
Endif
If MONTANT<>[M:PTH2]AMTTAX(I)
  [M:PTH2]AMTTAX(I)=MONTANT
  [M:PTH2]DEDTAX(I)=MONTDED
  [M:PTH2]TOTTAXAMT=sum([M:PTH2]AMTTAX)
  #----- Réajustement mts taxe sur éléments et lignes facture -----#
  Raz GPTH_INDBASTAX
  Call MAJ_TAXE(I) From SUBPTHD
  #----- Si les bases ont été réajustées, il faut recalculer la taxe -----#
  If sum(GPTH_INDBASTAX)>0
    For I=0 To [M:PTH2]NBTAX-1
      If GPTH_INDBASTAX(I)=1
        #----- Si taxe classique, recherche présence remise sur taxe (Settlement discount) -----#
        If [M:PTH2]VATTYP(I)=1
           If dim([M:PTH2]DISVATFLG)>0
            J=0
            NUMLIG_DISVAT=find(2,[M:PTH2]DISVATFLG(J..[M:PTH2]NBFAC-1))
            If NUMLIG_DISVAT
              If [M:PTH2]INVORDAMT(NUMLIG_DISVAT-1)=0
                J=NUMLIG_DISVAT
                NUMLIG_DISVAT=find(2,[M:PTH2]DISVATFLG(J..[M:PTH2]NBFAC-1))
                If NUMLIG_DISVAT & [M:PTH2]INVORDAMT(NUMLIG_DISVAT-1)=0
                  Raz NUMLIG_DISVAT
                Endif
              Endif
            Endif
          Endif
          If NUMLIG_DISVAT | (dim([M:PTH2]DISBAS)>0 & [M:PTH2]DISBAS(I)<>0)
            Gosub SETTLEMENT_DISCOUNT
          Endif
        Endif
        #-----
        TAXE=[M:PTH2]TAX(I)
        Call CALTAXE(GSOCIETE,[M:PTH0]RCPDAT,[M:PTH0]VACBPR,GCUR,1,TAXE,1,
&                 [M:PTH2]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
        If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
          Call CONVERT(GCURSHR,[M:PTH0]CUR,GLOCALDEV,[M:PTH0]CHGTYP,
&                       [M:PTH0]RCPDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
          If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
        Endif
        If MONTANT<>[M:PTH2]AMTTAX(I)
          [M:PTH2]AMTTAX(I)=MONTANT
          [M:PTH2]DEDTAX(I)=MONTDED
          [M:PTH2]TOTTAXAMT=sum([M:PTH2]AMTTAX)
          #----- Réajustement mts taxe sur éléments et lignes facture -----#
          Call MAJ_TAXE(I) From SUBPTHD
        Endif
      Endif
    Next I
  Endif
  #-----
Endif
Return


###################################################################
# Traitement de la remise sur taxe (code activité KUK)            #
#                                   et paramètre GBRDSC)          #
# --------------------------------------------------------------- #
#                   I  = Indice de la ligne de taxe à traiter     #
#    [M:PTH2]TAX   (I) = Code taxe                                #
#    [M:PTH2]BASTAX(I) = Base taxe net (remise déduite            #
#    [M:PTH2]DISBAS(I) = Montant de la remise base (en négatif)   #
#        NUMLIG_DISVAT = Numéro ligne élément settlement discount #
#                   K  = Indice de la plus grosse base TVA        #
#             WBASFLG  = 0  Base sur ligne commande               #
#                        1  Base sur ligne élément de facturation #
#             WDIFBAS  = Calcul du delta bases Mises mis à jour   #
#             WMAXBAS  = Montant de la plus grosse bases TVA      #
#          WMT_DISVAT  = Montant de la remise sur taxe            #
#          WTX_DISVAT  = Pourcentage de la remise sur taxe        #
###################################################################
$SETTLEMENT_DISCOUNT
If dim(K)<0  Local Integer K : Endif
Local Libelle WBASFLG
Local Decimal WDIFBAS, WMAXBAS
Local Decimal WMT_DISVAT, WTX_DISVAT
Local Integer WSIGN
#-----
If NUMLIG_DISVAT
  WSIGN=1-2*([M:PTH2]DEBCDT(NUMLIG_DISVAT-1)-1)
  WTX_DISVAT=[M:PTH2]INVORDAMT(NUMLIG_DISVAT-1)
Else
  WSIGN=0
  WTX_DISVAT=0
Endif
#-----
WMT_DISVAT=arr(([M:PTH2]BASTAX(I)-[M:PTH2]DISBAS(I))*WTX_DISVAT/100,GPTH_RND)*WSIGN
[M:PTH2]BASTAX(I)=[M:PTH2]BASTAX(I)-[M:PTH2]DISBAS(I)+WMT_DISVAT
[M:PTH2]DISBAS(I)=WMT_DISVAT
#-----
Raz WMAXBAS, WBASFLG, K
WDIFBAS=WMT_DISVAT
#----- Boucle sur les lignes de réception -----#
For J=0 To [M:PTH1]NBLIG-1
  If [M:PTH1]VAT1(J)=[M:PTH2]TAX(I)
    WMT_DISVAT=arr(([M:PTH1]BASTAXLIN1(J)-[M:PTH1]DISBASLIN1(J))*WTX_DISVAT/100,GPTH_RND)*WSIGN
    [M:PTH1]BASTAXLIN1(J)=[M:PTH1]BASTAXLIN1(J)-[M:PTH1]DISBASLIN1(J)+WMT_DISVAT
    [M:PTH1]DISBASLIN1(J)=WMT_DISVAT
    [M:PTH1]UPDFLG(J)=1
    If abs([M:PTH1]BASTAXLIN1(J))>WMAXBAS
      WMAXBAS=abs([M:PTH1]BASTAXLIN1(J)) : K=J : WBASFLG=0
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J
#----- Boucle sur les éléments de facturation -----#
For J=0 To [M:PTH2]NBFAC-1
  If [M:PTH2]INVDTAVAT(J)=[M:PTH2]TAX(I) & [M:PTH2]INVDTAAMT(J)<>0
    WMT_DISVAT=arr([M:PTH2]INVDTAAMT(J)*WTX_DISVAT/100,GPTH_RND)*WSIGN
    [M:PTH2]DTADISBAS(J)=WMT_DISVAT
    If abs([M:PTH2]INVDTAAMT(J)+WMT_DISVAT)>WMAXBAS
      WMAXBAS=abs([M:PTH2]INVDTAAMT(J)+WMT_DISVAT) : K=J : WBASFLG=1
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J
#----- Imputation de l'écart éventuel sur la base la plus importante -----#
If WDIFBAS<>0
  Case WBASFLG
    When 1       : [M:PTH2]DTADISBAS (K)+=WDIFBAS
    When Default : [M:PTH1]DISBASLIN1(K)+=WDIFBAS
                   [M:PTH1]BASTAXLIN1(K)+=WDIFBAS
  Endcase
Endif
#-----
Return


########################################################################
# MAJ_TAXE : S/P de mise à jour des montants de taxe au prorata        #
#                des bases sur les éléments de facturation et          #
#                          sur les lignes de réception                 #
# -------------------------------------------------------------------- #
# Subprog MAJ_TAXE (NOL)                                               #
#    NOL  : Numéro de ligne de la taxe (nolign-1)                      #
########################################################################
Subprog MAJ_TAXE (NOL)
Value Shortint NOL
Local Shortint I, J, K, L, CLCAMTFLG
Local Decimal  CUMTAX, CUMDED, DIFTAX, DIFDED, MAXBAS, DIFBAS1
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
If [M:PTH2]BASTAX(NOL)=0  End : Endif : # Si le diviseur est zéro on ne fait rien !
#----- Màj des montants de taxe sur les éléments de facturation -----#
For I=0 To [M:PTH2]NBFAC-1
  If [M:PTH2]INVDTAVAT(I)=[M:PTH2]TAX(NOL) & [M:PTH2]PURTYP(NOL)=1
    [M:PTH2]DTAAMTTAX(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH2]INVDTAAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
    CUMTAX+=[M:PTH2]DTAAMTTAX(I)
    [M:PTH2]DTADEDTAX(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH2]INVDTAAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
    CUMDED+=[M:PTH2]DTADEDTAX(I)
    If abs([M:PTH2]INVDTAAMT(I))>MAXBAS MAXBAS=abs([M:PTH2]INVDTAAMT(I)) : J=1 : K=I : Endif
  Endif
Next I
#----- Màj des montants de taxe sur les lignes de réception -----#
For I=0 To [M:PTH1]NBLIG-1
  If [M:PTH1]LINPURTYP(I)=[M:PTH2]PURTYP(NOL)
    If [M:PTH1]VAT1(I)=[M:PTH2]TAX(NOL)
      #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
      Raz CLCAMTFLG
      For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PTH1]CLCAMT4)>0)
        GBIDD2=evalue("[M:PTH1]CLCAMT"+num$(L)+"(I)")
        If GBIDD2<>0 & (GBIDD2=[M:PTH1]LINAMT(I)+[M:PTH1]AMTTAXLIN1(I) |
&                       GBIDD2=[M:PTH1]AMTTAXLIN1(I))
          CLCAMTFLG+=2^L-1
        Endif
      Next L
      If CLCAMTFLG>0  DIFBAS1=-[M:PTH1]AMTTAXLIN1(I) : Endif
      #-----
      [M:PTH1]AMTTAXLIN1(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]BASTAXLIN1(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      CUMTAX+=[M:PTH1]AMTTAXLIN1(I)
      #----- Réajustement bases spéciales 1 et 2 si TVA incluse dans ces bases (Canada) -----#
      If CLCAMTFLG>0
        DIFBAS1+=[M:PTH1]AMTTAXLIN1(I)
        Call REAJUST_CLCAMT(I,DIFBAS1,CLCAMTFLG) From SUBPTHD
      Endif
      #-----
      [M:PTH1]DEDTAXLIN1(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]BASTAXLIN1(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      [M:PTH1]UPDFLG(I)=1
      CUMDED+=[M:PTH1]DEDTAXLIN1(I)
      If abs([M:PTH1]BASTAXLIN1(I))>MAXBAS MAXBAS=abs([M:PTH1]BASTAXLIN1(I)) : J=2 : K=I : Endif
    Elsif [M:PTH1]VAT2(I)=[M:PTH2]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT2(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
      #Read [TVT] TVT0=[M:PTH1]VAT2(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXLIN2(I) : Endif
      #-----
      [M:PTH1]AMTTAXLIN2(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      CUMTAX+=[M:PTH1]AMTTAXLIN2(I)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:PTH1]AMTTAXLIN2(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
      Endif
      #-----
      [M:PTH1]DEDTAXLIN2(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      CUMDED+=[M:PTH1]DEDTAXLIN2(I)
      If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=3 : K=I : Endif
    Elsif [M:PTH1]VAT3(I)=[M:PTH2]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      # Issue 71937 - 2012-03-27 by SR : comment
      Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT3(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
      #Read [TVT] TVT0=[M:PTH1]VAT3(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXLIN3(I) : Endif
      #-----
      [M:PTH1]AMTTAXLIN3(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      CUMTAX+=[M:PTH1]AMTTAXLIN3(I)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:PTH1]AMTTAXLIN3(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
      Endif
      #-----
      [M:PTH1]DEDTAXLIN3(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
      [M:PTH1]UPDFLG(I)=1
      CUMDED+=[M:PTH1]DEDTAXLIN3(I)
      If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=4 : K=I : Endif
    Elsif func AFNC.ACTIV("PTX") & dim([M:PTH1]TAXRCP)>0
      If [M:PTH1]TAXRCP(I)=[M:PTH2]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXRCP(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PTH1]TAXRCP(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXRCP(I) : Endif
        #-----
        [M:PTH1]AMTTAXRCP(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMTAX+=[M:PTH1]AMTTAXRCP(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PTH1]AMTTAXRCP(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
        Endif
        #-----
        [M:PTH1]DEDTAXRCP(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        [M:PTH1]UPDFLG(I)=1
        CUMDED+=[M:PTH1]DEDTAXRCP(I)
        If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=5 : K=I : Endif
      Elsif [M:PTH1]TAXISS(I)=[M:PTH2]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe sortie soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXISS(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PTH1]TAXISS(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXISS(I) : Endif
        #-----
        [M:PTH1]AMTTAXISS(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMTAX+=[M:PTH1]AMTTAXISS(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PTH1]AMTTAXISS(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
        Endif
        #-----
        [M:PTH1]DEDTAXISS(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        [M:PTH1]UPDFLG(I)=1
        CUMDED+=[M:PTH1]DEDTAXISS(I)
        If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=6 : K=I : Endif
      Elsif [M:PTH1]TAXOTH1(I)=[M:PTH2]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXOTH1(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PTH1]TAXOTH1(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXOTH1(I) : Endif
        #-----
        [M:PTH1]AMTTAXOTH1(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMTAX+=[M:PTH1]AMTTAXOTH1(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PTH1]AMTTAXOTH1(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
        Endif
        #-----
        [M:PTH1]DEDTAXOTH1(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMDED+=[M:PTH1]DEDTAXOTH1(I)
        If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=7 : K=I : Endif
      Elsif [M:PTH1]TAXOTH2(I)=[M:PTH2]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 2 soumise -----#
        # Issue 71937 - 2012-03-27 by SR : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXOTH2(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PTH1]TAXOTH2(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PTH1]AMTTAXOTH2(I) : Endif
        #-----
        [M:PTH1]AMTTAXOTH2(I)=arr([M:PTH2]AMTTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMTAX+=[M:PTH1]AMTTAXOTH2(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PTH1]AMTTAXOTH2(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPTHD
        Endif
        #-----
        [M:PTH1]DEDTAXOTH2(I)=arr([M:PTH2]DEDTAX(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]BASTAX(NOL),GPTH_RND)
        CUMDED+=[M:PTH1]DEDTAXOTH2(I)
        If abs([M:PTH1]LINAMT(I))>MAXBAS MAXBAS=abs([M:PTH1]LINAMT(I)) : J=8 : K=I : Endif
      Endif
    Endif
    #----- Mise à jour du TTC ligne si facture non CEE -----#
    If [M:PTH0]VACTYP<>4
      [M:PTH1]LINATIAMT(I)=[M:PTH1]LINAMT(I)+[M:PTH1]AMTTAXLIN1(I)
&                           +[M:PTH1]AMTTAXLIN2(I)+[M:PTH1]AMTTAXLIN3(I)
      If func AFNC.ACTIV("PTX") & dim([M:PTH1]TAXRCP)>0
        [M:PTH1]LINATIAMT(I)+=[M:PTH1]AMTTAXRCP(I)
        [M:PTH1]LINATIAMT(I)+=[M:PTH1]AMTTAXISS(I)
        [M:PTH1]LINATIAMT(I)+=[M:PTH1]AMTTAXOTH1(I)
        [M:PTH1]LINATIAMT(I)+=[M:PTH1]AMTTAXOTH2(I)
      Endif
    Endif
  Endif
Next I
#----- Imputation des écarts éventuels sur les montants les plus gros -----#
DIFTAX=[M:PTH2]AMTTAX(NOL)-CUMTAX
DIFDED=[M:PTH2]DEDTAX(NOL)-CUMDED
If DIFTAX<>0 | DIFDED<>0
  Case J
    When 1 : [M:PTH2]DTAAMTTAX (K)+=DIFTAX : [M:PTH2]DTADEDTAX (K)+=DIFDED
    When 2 : Raz CLCAMTFLG
             #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
             For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PTH1]CLCAMT4)>0)
               GBIDD2=evalue("[M:PTH1]CLCAMT"+num$(L)+"(I)")
               If GBIDD2<>0 & (GBIDD2=[M:PTH1]LINAMT(I)+[M:PTH1]AMTTAXLIN1(I) |
&                              GBIDD2=[M:PTH1]AMTTAXLIN1(I))
                 CLCAMTFLG+=2^L-1
               Endif
             Next L
             #-----
             [M:PTH1]AMTTAXLIN1(K)+=DIFTAX : [M:PTH1]DEDTAXLIN1(K)+=DIFDED
             If CLCAMTFLG>0  Call REAJUST_CLCAMT(K,DIFTAX,CLCAMTFLG) From SUBPTHD : Endif
    When 3 : [M:PTH1]AMTTAXLIN2(K)+=DIFTAX : [M:PTH1]DEDTAXLIN2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]VAT2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
    When 4 : [M:PTH1]AMTTAXLIN3(K)+=DIFTAX : [M:PTH1]DEDTAXLIN3(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT3(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]VAT3(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
    When 5 : [M:PTH1]AMTTAXRCP(K)+=DIFTAX  : [M:PTH1]DEDTAXRCP(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXRCP(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]TAXRCP(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
    When 6 : [M:PTH1]AMTTAXISS(K)+=DIFTAX  : [M:PTH1]DEDTAXISS(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXISS(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]TAXISS(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
    When 7 : [M:PTH1]AMTTAXOTH1(K)+=DIFTAX : [M:PTH1]DEDTAXOTH1(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXOTH1(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]TAXOTH1(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
    When 8 : [M:PTH1]AMTTAXOTH2(K)+=DIFTAX : [M:PTH1]DEDTAXOTH2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PTH1]TAXOTH2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PTH1]TAXOTH2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPTHD : Endif
  Endcase
Endif
End


########################################################################
# MAJ_ELEMENT : S/P de mise à jour des bases et calcul des taxes       #
#                   et répartition si besoin des montants sur          #
#                   les lignes au prorata des qtés ou montant          #
# -------------------------------------------------------------------- #
# Subprog MAJ_ELEMENT (NOL,AFF,SENS)                                   #
#    NOL  : Numéro de ligne de l'élément de facturation (nolign-1)     #
#    AFF  : Indicateur d'affichage (0=Non, 1-2=Oui)                    #
#    SENS : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
########################################################################
Subprog MAJ_ELEMENT (NOL,AFF,SENS)
Value Shortint NOL
Value Integer  AFF
Value Integer  SENS
#-----
Local Libelle  WFLAG
Local Shortint I, J, K, L, M
Local Integer  TYPREG,  STAT
Local Decimal  MONTANT, MONTDED, MTLIG, CUMLIG, CUMLINQTY, CUMLINWEU, CUMLINVOU
Local Decimal  CUMLINMT # Issue 121453 - 2017-02-09 by MUARN : répartition montant en SST
Local Decimal  CUMORIMT, CUMORIQTE, CUMQTYPUU, WMT
Local Char     TAXE(GLONVAT)
Local Integer  MAXLIG : MAXLIG=max([M:PTH1]NBLIG,find("",[M:PTH1]ITMREF)-1)
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
Raz GPTH_INDTAX
#----- SENS = +2 ou -2, pas de répartition tarif -----#
WFLAG=0
If SENS=-2  SENS=-1 : WFLAG=1 : Endif
If SENS=+2  SENS=+1 : WFLAG=1 : Endif
#---- Si élément fait partie de la ligne tarif et taxe produit ----#
If [M:PTH2]INVLINFLG(NOL)=6 & [M:PTH2]INVDTAVAT(NOL)=""
  If !WFLAG  Gosub REPART_TARIF : Endif
  Goto AFF_TAXES
Endif
#----- Si l'élément est une remise sur taxe (settlement discount) -----#
If dim([M:PTH2]DISVATFLG)>0 & [M:PTH2]DISVATFLG(NOL)=2
  Goto AFF_TAXES
Endif
#------ Si montant de l'élément égal à zéro ni calcul, ni màj ------#
If [M:PTH2]INVDTAAMT(NOL)=0  Goto AFF_TAXES : Endif
#----- Calcul suivant le type de répartition -----#
Case [M:PTH2]INVLINFLG(NOL)
  When 1  : Gosub CAL_TAXE_PIED : # Pas de répartition sur les lignes
  When 2  : Gosub CAL_PRORATA   : # Prorata des quantités
  When 3  : Gosub CAL_PRORATA   : # Prorata des montants
  When 4  : Gosub CAL_PRORATA   : # Prorata des poids
  When 5  : Gosub CAL_PRORATA   : # Prorata des volumes
  When 6  : Gosub CAL_TAXE_PIED : # Provient des lignes (tarif)
Endcase
#----- Affichage du tableau des taxes -----#
$AFF_TAXES
If AFF>0 & !GIMPORT & !GPTH_PICK  Affzo [PTH2]10,15 : Endif
End
#------------------------------------------------------------#
# Répartition sur les lignes au prorata des qtés ou montants #
#------------------------------------------------------------#
$CAL_PRORATA
#----- Taxe à taux fixe -----#
If [M:PTH2]INVDTAVAT(NOL)<>""  Gosub CAL_TAXE_PIED : Endif
#----- Recherche si élément nouveau et màj soustraction alors c'est fini -----#
#If !find([M:PTH2]INVDTA(NOL),[M:PTH1]INVDTALIN2(0..8)) & SENS=-1  Return : Endif
#---- C'est un élément nouveau : Stockage du no d'élément et du code taxe ----#
If !find([M:PTH2]INVDTA(NOL),[M:PTH1]INVDTALIN2(0..8))
   I=find(0,[M:PTH1]INVDTALIN2(0..8))
   If I<>0
     [M:PTH1]INVDTALIN2(I-1)=[M:PTH2]INVDTA(NOL)
     [M:PTH1]INVDTAVAT2(I-1)=[M:PTH2]INVDTAVAT(NOL)
   Else
     Return : # Une 10ème répartition est impossible !
   Endif
Endif
#----- Répartition sur les lignes -----#
J=find([M:PTH2]INVDTA(NOL),[M:PTH1]INVDTALIN2(0..8))
Raz CUMLIG, CUMLINQTY, CUMLINWEU, CUMLINVOU, CUMLINMT # Issue 121453 - 2017-02-09 by MUARN : répartition montant en SST CUMLINMT
If MAXLIG>0
  For I=0 To MAXLIG-1
    If [M:PTH1]LINTYP(I)<2
&   | ([M:PTH1]LINTYP(I)=2 & [M:PTH2]INVLINFLG(NOL)<>3)
&   | ([M:PTH1]LINTYP(I)=3 & [M:PTH2]INVLINFLG(NOL)=3)
&   | ([M:PTH1]LINTYP(I)=4 & [M:PTH2]INVLINFLG(NOL)<4)
      #----- Le prorata du produit fini s'affecte au service -----#
      If [M:PTH1]LINTYP(I)=2
        M=I+1
      #----- Le prorata des autres s'affecte sur eux-mêmes -----#
      Else
        M=I
      Endif
      #-----
      If SENS=1
        If [M:PTH1]LINFLG(I)<>9
          # Issue X3-91854 - 2018-05-29 by MUARN : répartition poids/volume
          # Issue 121453 - 2017-02-08 by MUARN : tenir compte du type de répartition
          #If I<MAXLIG-1 & CUMLINQTY+[M:PTH1]QTYPUU(I)<[M:PTH2]TOTLINQTY
          If ( I<MAXLIG-1 & [M:PTH2]INVLINFLG(NOL)=2 & (CUMLINQTY+[M:PTH1]QTYPUU(I)<[M:PTH2]TOTLINQTY) ) |
&            ( I<MAXLIG-1 & [M:PTH2]INVLINFLG(NOL)=3 & (CUMLINMT +[M:PTH1]LINAMT(I)<[M:PTH2]TOTLINAMT ) ) |
&            ( I<MAXLIG-1 & [M:PTH2]INVLINFLG(NOL)=4 & (CUMLINWEU +[M:PTH1]QTYWEU(I)<[M:PTH2]TOTLINWEU ) ) |
&            ( I<MAXLIG-1 & [M:PTH2]INVLINFLG(NOL)=5 & (CUMLINVOU +[M:PTH1]QTYVOU(I)<[M:PTH2]TOTLINVOU ) )

            Raz MTLIG
            Case [M:PTH2]INVLINFLG(NOL)
              When 2 : #----- Prorata par quantités -----#
                If [M:PTH2]TOTLINQTY<>0 & [M:PTH1]LINTYP(I)<>3
                  MTLIG=[M:PTH2]INVDTAAMT(NOL)*[M:PTH1]QTYPUU(I)/[M:PTH2]TOTLINQTY
                Endif
              When 3 : #----- Prorata par montants -----#
                If [M:PTH2]TOTLINAMT<>0 & [M:PTH1]LINTYP(I)<>2
                  MTLIG=[M:PTH2]INVDTAAMT(NOL)*[M:PTH1]LINAMT(I)/[M:PTH2]TOTLINAMT
                Endif
              When 4 : #----- Prorata par poids -----#
                If [M:PTH2]TOTLINWEU<>0 & [M:PTH1]LINTYP(I)<3
                  MTLIG=[M:PTH2]INVDTAAMT(NOL)*[M:PTH1]QTYWEU(I)/[M:PTH2]TOTLINWEU
                Endif
              When 5 : #----- Prorata par volume -----#
                If [M:PTH2]TOTLINVOU<>0 & [M:PTH1]LINTYP(I)<3
                  MTLIG=[M:PTH2]INVDTAAMT(NOL)*[M:PTH1]QTYVOU(I)/[M:PTH2]TOTLINVOU
                Endif
            Endcase
            MTLIG=arr(MTLIG,GPTH_RND)
          Else
            MTLIG=[M:PTH2]INVDTAAMT(NOL)-CUMLIG
          Endif
          Assign "[M:PTH1]DISCRGAMT"+num$(J)+"(M)" With MTLIG
          CUMLIG+=MTLIG
          CUMLINQTY+=[M:PTH1]QTYPUU(I)
          CUMLINWEU+=[M:PTH1]QTYWEU(I)
          CUMLINVOU+=[M:PTH1]QTYVOU(I)
          CUMLINMT+=[M:PTH1]LINAMT(I) # Issue 121453 - 2017-02-08 by MUARN : tenir compte du type de répartition
        Else
          MTLIG=0
          Assign "[M:PTH1]DISCRGAMT"+num$(J)+"(M)" With MTLIG
        Endif
      Else
        MTLIG=evalue("[M:PTH1]DISCRGAMT"+num$(J)+"(M)")
        Assign "[M:PTH1]DISCRGAMT"+num$(J)+"(M)" With 0
      Endif
      If [M:PTH1]INVDTAVAT2(J-1)="" & [M:PTH1]VAT1(M)<>"" Gosub CAL_TAXE_LIGNE : Endif
      [M:PTH1]UPDFLG(M)=1
    Endif
  Next I
Endif
If SENS=-1  [M:PTH1]INVDTALIN2(J-1)=0 : [M:PTH1]INVDTAVAT2(J-1)="" : Endif
Return
#-------------------------------------------------------------#
# Màj bases taxables et calcul des taxes en pied de réception #
#-------------------------------------------------------------#
$CAL_TAXE_PIED
#----- Recherche si taxe déja existante -----#
I=find([M:PTH2]INVDTAVAT(NOL),[M:PTH2]TAX(0..[M:PTH2]NBTAX-1))
If I<>0 & [M:PTH2]PURTYP(I-1)<>1
  J=find([M:PTH2]INVDTAVAT(NOL),[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
  If J<>0
    I+=J
    If [M:PTH2]PURTYP(I-1)<>1
      J=find([M:PTH2]INVDTAVAT(NOL),[M:PTH2]TAX(I..[M:PTH2]NBTAX-1))
      If J<>0 I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PTH2]NBTAX>=dim([M:PTH2]TAX)
    Call ERREUR ([M:PTH2]INVDTAVAT(NOL)-mess(300,194,1)) From GESECRAN
    GPTH_INDTAX=I+1
    Return
  Endif
  #-----
  I=[M:PTH2]NBTAX
  [M:PTH2]NBTAX+=1
  [M:PTH2]TAX(I)=[M:PTH2]INVDTAVAT(NOL)
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,[M:PTH2]INVDTAVAT(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:PTH2]INVDTAVAT(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PTH2]LIBTAX(I)) From TRTX3TEX
  [M:PTH2]PURTYP(I)=1
  [M:PTH2]VATTYP(I)=[F:TVT]VATTYP
Else
  I-=1
Endif
#----- Mise à jour base taxable et montants de taxe -----#
If SENS=-1
  [M:PTH2]BASTAX(I)-=[M:PTH2]INVDTAAMT(NOL)
  If dim([M:PTH2]DTADISBAS)>0
    [M:PTH2]BASTAX(I)-=[M:PTH2]DTADISBAS(NOL)
    [M:PTH2]DISBAS(I)-=[M:PTH2]DTADISBAS(NOL)
  Endif
  [M:PTH2]AMTTAX(I)-=[M:PTH2]DTAAMTTAX(NOL)
  [M:PTH2]DEDTAX(I)-=[M:PTH2]DTADEDTAX(NOL)
  #----- Suppression ligne taxe si aucun montant et affichage -----#
  If [M:PTH2]BASTAX(I)=0 & [M:PTH2]AMTTAX(I)=0 & [M:PTH2]DEDTAX(I)=0 : # & AFF>0
    If !GIMPORT
      Dela I,1,[M:PTH2]NBTAX-1 [M:PTH2]NBTAX : [M:PTH2]NBTAX-=1
    Endif
  Endif
Else
  [M:PTH2]BASTAX(I)+=[M:PTH2]INVDTAAMT(NOL)
  If dim([M:PTH2]DTADISBAS)>0
    Raz [M:PTH2]DTADISBAS(NOL)
  Endif
  #----- Calcul du montant de taxe avec sa partie déductible -----#
  #If [M:PTH2]DTAAMTTAX(NOL)=0 & [M:PTH2]DTADEDTAX(NOL)=0
    TAXE=[M:PTH2]INVDTAVAT(NOL)
    Call CALTAXE(GSOCIETE,[M:PTH0]RCPDAT,[M:PTH0]VACBPR,GCUR,1,TAXE,1,
&                [M:PTH2]INVDTAAMT(NOL),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
    [M:PTH2]DTAAMTTAX(NOL)=MONTANT
    [M:PTH2]DTADEDTAX(NOL)=MONTDED
  #Endif
  [M:PTH2]AMTTAX(I)+=[M:PTH2]DTAAMTTAX(NOL)
  [M:PTH2]DEDTAX(I)+=[M:PTH2]DTADEDTAX(NOL)
Endif
GPTH_INDTAX=I+1
Return
#----------------------------------------------------------------#
# Màj bases taxables et calcul des taxes à la ligne de réception #
#----------------------------------------------------------------#
$CAL_TAXE_LIGNE
#----- Recherche si taxe déja existante -----#
K=find([M:PTH1]VAT1(M),[M:PTH2]TAX(0..[M:PTH2]NBTAX-1))
If K<>0 & [M:PTH2]PURTYP(K-1)<>[M:PTH1]LINPURTYP(M)
   L=find([M:PTH1]VAT1(M),[M:PTH2]TAX(K..[M:PTH2]NBTAX-1))
   If L<>0
     K+=L
     If [M:PTH2]PURTYP(K-1)<>[M:PTH1]LINPURTYP(M)
       L=find([M:PTH1]VAT1(M),[M:PTH2]TAX(K..[M:PTH2]NBTAX-1))
       If L<>0 K+=L Else K=0 : Endif
     Endif
   Else
     K=0
   Endif
Endif
#----- Nouvelle taxe -----#
If K=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PTH2]NBTAX>=dim([M:PTH2]TAX)
    Call ERREUR ([M:PTH1]VAT1(M)-mess(300,194,1)) From GESECRAN
    GPTH_INDTAX=K+1
    Return
  Endif
  #-----
  K=[M:PTH2]NBTAX
  [M:PTH2]NBTAX+=1
  [M:PTH2]TAX(K)=[M:PTH1]VAT1(M)
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,[M:PTH1]VAT1(M),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:PTH1]VAT1(M) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PTH2]LIBTAX(K)) From TRTX3TEX
  [M:PTH2]PURTYP(K)=[M:PTH1]LINPURTYP(M)
  [M:PTH2]VATTYP(K)=[F:TVT]VATTYP
Else
  K-=1
Endif
#----- Calcul du montant de taxe avec sa partie déductible -----#
TAXE=[M:PTH1]VAT1(M)
Call CALTAXE(GSOCIETE,[M:PTH0]RCPDAT,[M:PTH0]VACBPR,GCUR,1,TAXE,1,
&            MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#----- Mise à jour base taxable et montants de taxe-----#
If SENS=-1
  [M:PTH1]BASTAXLIN1(M)-=MTLIG
  [M:PTH1]AMTTAXLIN1(M)-=MONTANT
  [M:PTH1]DEDTAXLIN1(M)-=MONTDED
  If [M:PTH0]VACTYP<>4  [M:PTH1]LINATIAMT(M) -=MONTANT : Endif
  [M:PTH2]BASTAX(K)-=MTLIG
  [M:PTH2]AMTTAX(K)-=MONTANT
  [M:PTH2]DEDTAX(K)-=MONTDED
  #----- Suppression ligne taxe si aucun montant -----#
  If [M:PTH2]BASTAX(K)=0 & [M:PTH2]AMTTAX(K)=0 & [M:PTH2]DEDTAX(K)=0
    If !GIMPORT
      Dela K,1,[M:PTH2]NBTAX-1 [M:PTH2]NBTAX : [M:PTH2]NBTAX-=1
    Endif
  Endif
Else
  [M:PTH1]BASTAXLIN1(M)+=MTLIG
  [M:PTH1]AMTTAXLIN1(M)+=MONTANT
  [M:PTH1]DEDTAXLIN1(M)+=MONTDED
  If [M:PTH0]VACTYP<>4  [M:PTH1]LINATIAMT(M) +=MONTANT : Endif
  # Issue 70985 - 2012-05-09 by MUARN : landedcost (taxe avec taux produit)
  If [M:PTH2]INVDTAVAT(NOL) <>"" | [M:PTH2]BASTAX(K)<>0
  # fin Issue 70985 - 2012-05-09 by MUARN : landedcost (taxe avec taux produit)
    [M:PTH2]BASTAX(K)+=MTLIG
    [M:PTH2]AMTTAX(K)+=MONTANT
    [M:PTH2]DEDTAX(K)+=MONTDED
  Endif
Endif
GPTH_INDTAX=K+1
Return
#-----------------------------------------------#
# Répartition du montant tarif sur chaque ligne #
#-----------------------------------------------#
$REPART_TARIF
#If SENS=-1  Return : Endif
If MAXLIG>0 & find([M:PTH2]INVDTA(NOL),GINVDTALIN(0..8))
  #-----
  J=find([M:PTH2]INVDTA(NOL),GINVDTALIN(0..8))
  Raz CUMLIG
  For I=0 To MAXLIG-1
    Call MAJ_BASTAX_LIG(I,-1) From SUBPTHD
    #----- C'est un montant -----#
    If GDISCRGTYP(J-1)=1
      If GCLCRUL(J-1)=1 : # Par unité
        WMT=arr(evalue("[M:PTH1]DISCRGVAL"+num$(J)+"(I)")*[M:PTH1]QTYUOM(I),GPTH_RND)
      Else              : # Par ligne
        WMT=evalue("[M:PTH1]DISCRGVAL"+num$(J)+"(I)")
      Endif
    #----- C'est un pourcentage -----#
    Else
      WMT=arr([M:PTH1]LINAMT(I)*evalue("[M:PTH1]DISCRGVAL"+num$(J)+"(I)")/100,GPTH_RND)
    Endif
    #-----
    If I<MAXLIG-1 & [M:PTH2]INVLINAMT(NOL)<>0
      MTLIG=arr([M:PTH2]INVDTAAMT(NOL)*WMT/[M:PTH2]INVLINAMT(NOL),GPTH_RND)
    Else
      If GDISCRGTYP(J-1)=1
        If GCLCRUL(J-1)=1 & [M:PTH1]QTYUOM(I)<>0
          MTLIG=arr(([M:PTH2]INVDTAAMT(NOL)-CUMLIG)/[M:PTH1]QTYUOM(I),10^-GDECPRI)
        Else
          MTLIG=[M:PTH2]INVDTAAMT(NOL)-CUMLIG
        Endif
      Else
       # Issue 75544 - 2011-06-27 by SR
       If [M:PTH1]LINAMT(I)<>0
          MTLIG=arr(([M:PTH2]INVDTAAMT(NOL)-CUMLIG)*100/[M:PTH1]LINAMT(I),GPTH_RND)
       Endif
      Endif
    Endif
    Assign "[M:PTH1]DISCRGVAL"+num$(J)+"(I)" With MTLIG
    CUMLIG+=MTLIG
    Call MAJ_CALTAX_LIG("PTH1",I) From TRTACHDIV1
    Call MAJ_BASTAX_LIG(I,+1) From SUBPTHD
  Next I
  [M:PTH2]INVLINAMT(NOL)=[M:PTH2]INVDTAAMT(NOL) : Affzo [PTH2]INVLINAMT(NOL)
  Affzo [PTH1]10
Endif
Return


#########################################################################
# MAJ_REPART_LIG : S/P de répartition des éléments de facturation sur   #
#         les lignes de réception au prorata des qantités ou montants,  #
#         calcul taxes et prix unitaires de revient                     #
# --------------------------------------------------------------------- #
# Subprog MAJ_REPART_LIG                                                #
#########################################################################
Subprog MAJ_REPART_LIG
#----- Variables locales -----#
Local Shortint I, J, K
Local Decimal  MTLIG, CUMLIG
# Issue 84130 - 2012-12-07 by SR
Local Integer  WRET
#-----
For I=0 To [M:PTH2]NBFAC-1
  Call MAJ_ELEMENT (I,0,-2) From SUBPTHD
  Call MAJ_ELEMENT (I,0,+2) From SUBPTHD
Next I
#-----
For I=0 To [M:PTH1]NBLIG-1
  #VPO 23/02/11 : ne pas faire si on est sur une ligne vide
  If [M:PTH1]ITMREF(I)<>""
    Call MAJ_CPR_LIG(I) From SUBPTHD
  Endif
Next I
End


########################################################################
# CONVERT_MONTANT : S/P de conversion des éléments de facturation      #
#                   et des montants HT, TVA                            #
#                   après un changement de devise réception ou de      #
#                   type de cours réception                            #
# -------------------------------------------------------------------- #
# Subprog CONVERT_MONTANT (DEV,TYP)                                    #
#    DEV  : Nouveau code devise                                        #
#    TYP  : Nouveau type de cours                                      #
########################################################################
Subprog CONVERT_MONTANT (DEV,TYP)
Value Char     DEV
Value Integer  TYP
Local Integer  I, STAT
If [M:PTH2]NBFAC>0
   For I=0 To [M:PTH2]NBFAC-1
       Call MAJ_ELEMENT (I,0,-2) From SUBPTHD
       Call CONVERT([M:PTH0]CUR,DEV,GLOCALDEV,TYP,[M:PTH0]RCPDAT,
&                   [M:PTH2]INVDTAAMT(I),GBIDD2,STAT) From TRTDEV
       If STAT  Raz GBIDD2 : Endif
       # Issue 85145 - 2012-10-16 by MUARN : Tunuel sur éléments de facturation et devise
       [M:PTH2]AMTCODLIB(I)=DEV
       [M:PTH2]INVDTAAMT(I)=GBIDD2
       Call CONVERT([M:PTH0]CUR,DEV,GLOCALDEV,TYP,[M:PTH0]RCPDAT,
&                   [M:PTH2]INVORDAMT(I),GBIDD2,STAT) From TRTDEV
       If STAT  Raz GBIDD2 : Endif
       [M:PTH2]INVORDAMT(I)=GBIDD2
       Call CONVERT([M:PTH0]CUR,DEV,GLOCALDEV,TYP,[M:PTH0]RCPDAT,
&                   [M:PTH2]INVCPLAMT(I),GBIDD2,STAT) From TRTDEV
       If STAT  Raz GBIDD2 : Endif
       [M:PTH2]INVCPLAMT(I)=GBIDD2
       Call MAJ_ELEMENT (I,0,+2) From SUBPTHD
   Next I
Endif
End


########################################################################
# INIT_COMPTES_INVDTA : S/P d'initialisation              MBT 29/03/06 #
#                des comptes d'un élément de facturation               #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_INVDTA (NOL)                                    #
#   NOL    : Indice de la ligne de l'élément à traiter (nolign-1)      #
########################################################################
Subprog INIT_COMPTES_INVDTA (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:PTH2]ACC"+num$(I)+")")>0
    Assign "[M:PTH2]ACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:PTH2]INVDTA(NOL)=0  End : Endif
#-----
Local    Libelle  WCDTFLG
Local    Char     ID1(20)(1..1), ID2(20)(1..3), CODPIECE(GLONGAU)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If [M:PTH2]DEBCDT(NOL)=2 & [M:PTH2]INVDTAAMT(NOL)=0
  [M:PTH2]INVDTAAMT(NOL)=-1 : WCDTFLG=1
Else
  Raz WCDTFLG
Endif
#-----
Local File PORDER [TB0], PVCRFOOT [TB1], CPTANALIN [TB2]
nolign=NOL+1
#----- Chargement pseudo fichier entête PORDER [TB0] -----#
[F:TB0]=[M:PTH0] : [F:TB0]=[M:PTH1] : [F:TB0]=[M:PTH2]
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
#----- Prendre le site financier de la société comme site de facturation -----#
[F:TB0]INVFCY=GFINRSP
#----- Chargement pseudo fichier ligne éléments facturation PVCRFOOT [TB1] -----#
[F:TB1]=[M:PTH0] : [F:TB1]=[M:PTH1] : [F:TB1]=[M:PTH2]
[F:TB1]VCRNUM=[M:PTH0]PTHNUM
[F:TB1]VCRTYP=3 : # 3 au lieu de 6 à cause de la pièce auto PORD
[F:TB1]IND   =NOL+1
#----- Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
If [F:TB1]INVLINFLG=2 | [F:TB1]INVLINFLG=3 | [F:TB1]INVLINFLG=4 | [F:TB1]INVLINFLG=5
  [F:TB1]INVLINFLG=0
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PVF"
[F:TB2]VCRTYP=3 : # 3 au lieu de 6 à cause de la pièce auto PORD
[F:TB2]VCRNUM=[M:PTH0]PTHNUM
[F:TB2]VCRSEQ=NOL+1
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:PTH2]ACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:PTH2]PFICCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:PTH2]PFICCE"+num$(I)+"(NOL)")
  Endif
Next I
#-----
Raz ID1, ID2
#-----
CODPIECE="POPV"
#----- Lecture de la pièce automatique -----#
If clalev([F:GAU])<=0 Local File GAUTACE   [GAU] : Endif
Read [GAU] GAU0=CODPIECE : If fstat Raz [F:GAU] : CODPIECE="PORD" : Endif
#----- Recherche du numéro de ligne de la pièce auto -----#
If clalev([F:GAD])<=0 Local File GAUTACED  [GAD] : Endif
Filter [GAD] Where COD=CODPIECE & LINNUM>0
For [GAD]
  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"INVDTA")
    LIG=[F:GAD]LINNUM : Break
  Endif
Next
Filter [GAD]
If LIG=0
  Look [GAD] GAD0=CODPIECE;9
  If !fstat  LIG=9  Else  LIG=120 : Endif
Endif
#----- Recherche des comptes à l'aide de la pièce auto -----#
Call COMPTE(CODPIECE,LIG,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA
  Raz TPLAN, TCOMPTE, GMESSAGE
Else
  If [F:GAD]COD<>CODPIECE | [F:GAD]LINNUM<>LIG
    Read [GAD] GAD0=CODPIECE;LIG : If fstat  Raz [F:GAD] : Endif
  Endif
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:PTH2]ACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
If WCDTFLG=1  [M:PTH2]INVDTAAMT(NOL)=0 : Endif
nolign=SAVNOLIGN
#-----
End


###############################################################################
# Préparation des sections analytiques d'une ligne d'élément de facturation   #
# --------------------------------------------------------------------------- #
# Si la clé de répartion est renseignée                                       #
#    il faut "mettre à blanc" toutes les sections                             #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# nolign contient le numéro de la ligne en cours                              #
# NOL contient l'indice de la ligne en cours                                  #
# [M:PTH2]ACC1-10(NOL) contient les comptes                                   #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
###############################################################################
$PREP_INIT_PFICCE
#-----
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Si clé de répartition renseignée, pas de sections analytiques -----#
If !varinit([M:PTH2]DSP,NOL)  [M:PTH2]DSP(NOL)=[F:GAC]DSP : Endif
If [M:PTH2]DSP(NOL)<>""
  For I=1 To GNBDIE
    If evalue("dim([M:PTH2]PFICCE"+num$(I)+")")>0
      Assign"[M:PTH2]PFICCE"+num$(I)+"(NOL)" With ""
    Endif
  Next I
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
Else
  For I=1 To GNBDIE
    WCCE=evalue("[M:PTH2]PFICCE"+num$(I)+"(NOL)")
    Raz mkstat
    Call SAIS_CCE(WCCE,I,"[M:PTH2]ACC","[M:PTH2]DSP") From TRTX3CPT
    If mkstat
      Assign "[M:PTH2]PFICCE"+num$(I)+"(NOL)" With ""
      Raz mkstat
    Elsif evalue("[M:PTH2]PFICCE"+num$(I)+"(NOL)")=""
      #----- Raz pour forcer l'initialisation -----#
      Case I
        When  1 : Raz [M:PTH2]PFICCE1 (NOL)
        When  2 : Raz [M:PTH2]PFICCE2 (NOL)
        When  3 : Raz [M:PTH2]PFICCE3 (NOL)
        When  4 : Raz [M:PTH2]PFICCE4 (NOL)
        When  5 : Raz [M:PTH2]PFICCE5 (NOL)
        When  6 : Raz [M:PTH2]PFICCE6 (NOL)
        When  7 : Raz [M:PTH2]PFICCE7 (NOL)
        When  8 : Raz [M:PTH2]PFICCE8 (NOL)
        When  9 : Raz [M:PTH2]PFICCE9 (NOL)
        When 10 : Raz [M:PTH2]PFICCE10(NOL)
        When 11 : Raz [M:PTH2]PFICCE11(NOL)
        When 12 : Raz [M:PTH2]PFICCE12(NOL)
        When 13 : Raz [M:PTH2]PFICCE13(NOL)
        When 14 : Raz [M:PTH2]PFICCE14(NOL)
        When 15 : Raz [M:PTH2]PFICCE15(NOL)
        When 16 : Raz [M:PTH2]PFICCE16(NOL)
        When 17 : Raz [M:PTH2]PFICCE17(NOL)
        When 18 : Raz [M:PTH2]PFICCE18(NOL)
        When 19 : Raz [M:PTH2]PFICCE19(NOL)
        When 20 : Raz [M:PTH2]PFICCE20(NOL)
      Endcase
    Endif
  Next I
Endif
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Affzo [PTH2]DSP(NOL)
  Gosub AFFICH_PFICCE From SUBPTH
Endif
Return


################################################################
# Si modif quantité du composé, répercution sur les composants #
# ------------------------------------------------------------ #
# NOL = Indice de la ligne de réception en cours de traitement #
################################################################
Subprog CALCUL_COMPOSANTS (NOL)
Value Shortint NOL
#-----
# Issue 71069 - 2015-12-24 by MUARN : PJT
If [M:PTH1]PREQTYPUU(NOL)<>[M:PTH1]QTYPUU(NOL) | [M:PTH1]PJT(NOL+1) <> [M:PTH1]PJT(NOL)
  Local Decimal WQTE
  Local Integer I : I=NOL+1
  # Issue 109590 - 2015-11-03 by SR :Si ouverture automatique du moteur de stock, NBLIG n'est pas encore correct
  #While [M:PTH1]LINTYP(I)>2 & I<[M:PTH1]NBLIG
  While [M:PTH1]LINTYP(I)>2 & [M:PTH1]ITMREF(I) <> ""
  # End issue 109590
    #If [M:PTH1]LIKQTYCOE(I)<>0
      #WQTE=[M:PTH1]QTYSTU(NOL)*[M:PTH1]LIKQTYCOE(I)
      #If [M:PTH1]UOMSTUCOE(I)<>0
      #  WQTE=WQTE/[M:PTH1]UOMSTUCOE(I)
      #Endif
      # Issue 71069 - 2015-12-24 by MUARN : PJT, contrôle si modif quantité
      If [M:PTH1]PREQTYPUU(NOL)<>[M:PTH1]QTYPUU(NOL)
        If [M:PTH1]LIKQTYCOE(I)=0 & find([M:PTH1]VCRTYPORI(I),10,36)   # Issue 85916 GA 11/2012 qté forfaitaire: pas de maj
           WQTE=[M:PTH1]QTYUOM(I)
        Elsif [M:PTH1]PREQTYPUU(NOL)<>0
          WQTE=[M:PTH1]QTYUOM(I)*[M:PTH1]QTYPUU(NOL)/[M:PTH1]PREQTYPUU(NOL)
        Elsif [M:PTH1]LIKQTYCOE(I)<>0
          WQTE=[M:PTH1]QTYSTU(NOL)*[M:PTH1]LIKQTYCOE(I)
          If [M:PTH1]UOMSTUCOE(I)<>0
            WQTE=WQTE/[M:PTH1]UOMSTUCOE(I)
          Endif
        Else
          WQTE=[M:PTH1]QTYUOM(I)
        Endif
        #-----
        #Call QTEARR(WQTE,[M:PTH1]UOM(I)) From TRTDIV
        If [F:TUN]UOM<>[M:PTH1]UOM(I)
          Read [TUN] TUN0=[M:PTH1]UOM(I)
          If fstat  Raz [F:TCU] : Endif
        Endif
        WQTE=arr(WQTE,10^-max([F:TUN]UOMDEC,1))
        #-----
      Endif
      nolign=I+1
      # Issue 71069 - 2015-12-24 by MUARN : PJT, contrôle si modif quantité
      If [M:PTH1]PREQTYPUU(NOL)<>[M:PTH1]QTYPUU(NOL) : status=75 : Endif
      Call AVANT_NBLIG     From SUBPTH
      # Issue 71069 - 2015-12-24 by MUARN : PJT, contrôle si modif quantité
      If [M:PTH1]PREQTYPUU(NOL)<>[M:PTH1]QTYPUU(NOL)
        Call AM_QTYUOM(WQTE) From SUBPTH
        [M:PTH1]QTYUOM(I)=WQTE
      Endif
      # Issue 71069 - 2015-12-24 by MUARN : PJT
      If [M:PTH1]PJT(I) <> [M:PTH1]PJT(NOL)
        [M:PTH1]PJT(I)=[M:PTH1]PJT(NOL)
      Endif
      [M:PTH1]LINFLG(I)=2
      Call APRES_NBLIG     From SUBPTH
      [M:PTH1]UPDFLG(I)=1
    #Endif
    I+=1
  Wend
  nolign=NOL+1
  [M:PTH1]PREQTYPUU(NOL)=[M:PTH1]QTYPUU(NOL)
Endif
End


#---------------------------------------------------------------------#
# Chargement lignes service et matières fournies par le sous-traitant #
#---------------------------------------------------------------------#
$CHARG_LIG_SUPPLEMENT
Local  Char     WNUM(GLONVCR), WVCRNUMORI(GLONVCR), WPOQLNK(16)
Local  Integer  WVCRTYPORI, SAVNOLIGN, SAVNBLIG
Local  Decimal  WQTE
#-----
SAVNBLIG =[M:PTH1]NBLIG
SAVNOLIGN=nolign
#-----
If [F:POQ]POHNUM<>[M:PTH1]POHNUM(NOL) |
&  [F:POQ]POPLIN<>[M:PTH1]POPLIN(NOL) |
&  [F:POQ]POQSEQ<>[M:PTH1]POQSEQ(NOL)
  Read [POQ] POQ0=[M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
  If fstat  Call ERREUR(mess(384,194,1)) From GESECRAN : Return : Endif
Endif
#-----
WNUM      =[F:POQ]POHNUM
WPOQLNK   =[F:POQ]POQLNK
WVCRTYPORI=[F:POQ]VCRTYPORI
WVCRNUMORI=[F:POQ]VCRNUMORI
#-----
Raz [M:PTH1]NBCRELIG
For [POQ] POQ3 Where POHNUM   =WNUM
&                  & POQLNK   >WPOQLNK
&                  & VCRTYPORI=WVCRTYPORI
&                  & VCRNUMORI=WVCRNUMORI
  If [F:POQ]LINTYP<2  Break : Endif
  nolign+=1 : NOL+=1
  status=73 : Call INSERE("PTDLIN") From TABLEAUX  : If mkstat  Break : Endif
  If dim([M:PTH1]ITMREF)<[M:PTH1]NBLIG+2  mkstat=1 : Break : Endif
  Insa NOL,1,[M:PTH1]NBLIG [M:PTH1]NBLIG : [M:PTH1]NBLIG+=1
  [M:PTH1]NBCRELIG+=1
  [M:PTH1]POHNUM(NOL)=[F:POQ]POHNUM
  [M:PTH1]POPLIN(NOL)=[F:POQ]POPLIN
  [M:PTH1]POQSEQ(NOL)=[F:POQ]POQSEQ
  [M:PTH1]ITMREF(NOL)=[F:POQ]ITMREF
  Gosub LECFIC_PICKE_CDE From TRTACHPIC1
  #If [F:POQ]LIKQTYCOE<>0
    #----- Calcul de la quantité restante à réceptionner -----#
    WQTE=[F:POQ]QTYSTU-[F:POQ]RCPQTYSTU
    WQTE-=sigma(I=0,[M:PTH1]NBLIG-1-[M:PTH1]NBCRELIG,
&               [M:PTH1]QTYSTU(I)*([M:PTH1]POHNUM(I)=[F:POQ]POHNUM &
&                                  [M:PTH1]POPLIN(I)=[F:POQ]POPLIN &
&                                  [M:PTH1]POQSEQ(I)=[F:POQ]POQSEQ &
&                                  [M:PTH1]CREFLG(I)=0))
    If WQTE<0  Raz WQTE : Endif
    #If abs(WQTE-([M:PTH1]QTYSTU(SAVNOLIGN-1)*[F:POQ]LIKQTYCOE))>0.1
    #  WQTE=[M:PTH1]QTYSTU(SAVNOLIGN-1)*[F:POQ]LIKQTYCOE
    #  Call QTEARR(WQTE,[F:POQ]STU) From TRTDIV
    #Endif
  #Else
  #  WQTE=[F:POQ]QTYSTU
  #Endif
  [F:POQ]PTHNUM=[M:PTH0]PTHNUM : # Pour éviter un écrasement par le transclasse
  Gosub CHARG_LIG_PTH From SUBPTHB
  If !mkstat
    status=0 : Call LINNUM("PTDLIN") From TABLEAUX
    Call APRES_NBLIG From SUBPTH
  Else
    Break
  Endif
Next
#-----
[M:PTH1]PCLFLG=9 : # Pour marquage ligne cde "pickée" !
[M:PTH1]NBLIG=SAVNBLIG
nolign=SAVNOLIGN
NOL=nolign-1
GMODIF=1
#----- Relecture de la ligne de commande du composé (produit fini) -----#
Read [POQ] POQ0=[M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
If fstat  Raz [F:POQ] : Endif
#-----
Return


######################################################### à supprimer !!!!!
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes #
#                     de la ligne de réception          # créé temporairement
# ----------------------------------------------------- # pour éviter les
# Subprog MAJ_CALTAX_LIG(NOL)                           # conflits lot D04 avec lot P01
#   NOL    : indice de la ligne (nolign-1)              #
#########################################################
Subprog MAJ_CALTAX_LIG(NOL)
Value  Shortint NOL
#-----
Local Char ABREV(5) : ABREV="PTH1"
#-----
Call MAJ_CALTAX_LIG(ABREV,NOL) From TRTACHDIV1
#-----
End

# Issue 71069 - 2016-09-06 by MUARN : PJT
$AM_PJTH

If [M:PTH1]NBLIG = 0

  [M:PTH0]PJTH=VALEUR

  If dim([M:PTH0]NBAXE)>0
    If [M:PTH0]NBAXE>0
        If dim([M:PTH0]CCE)>0 : Raz [M:PTH0]CCE : Endif
    Endif
    Call INIT_CCEH("PTH0","NBAXE","PTH") From TRTX3CPT
  Endif

  If dim([M:PTH2]NBFAC) > 0
    For I=0 To [M:PTH2]NBFAC-1
      If [M:PTH2]DSP(I) = ""
        For J=1 To GNBDIE
          Case J
            When  1 :
              Raz [M:PTH2]PFICCE1 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE1(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When  2 :
              Raz [M:PTH2]PFICCE2 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE2(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When  3 :
              Raz [M:PTH2]PFICCE3 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE3(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When  4 :
              Raz [M:PTH2]PFICCE4 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE4(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When  5
