              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE10(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When 11 :
