            When 12 :
              Raz [M:PTH2]PFICCE12(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE12(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When 13 :
              Raz [M:PTH2]PFICCE13(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE13(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When 14 :
              Raz [M:PTH2]PFICCE14(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PTH2]PFICCE14(I),J,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
            When 15 :
