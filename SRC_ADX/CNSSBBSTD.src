##        [M]ALLFCY=1
##        [M]FCYPLF=[F:PLF]FCYPLF
##        [M]FLGCLO=[F:PLF]FLGCLO
##        Affzo [M]ALLFCY,FCYPLF,FLGCLO
##      Endif
##    Else
##      Filter [F:PLF] Where YEAPLF=[M]YEAPLF & FCYPLF=[M]FCYPLF & VERPLF=VALEUR & LEGPLF=[M]LEGPLF
##      If rowcount([F:PLF])>0 Then
##        Read [F:PLF] Last
##        If !fstat Then
##          [M]ALLCPY=1
##          [M]CPYPLF=[F:PLF]CPYPLF
##          [M]FLGCLO=[F:PLF]FLGCLO
##          Affzo [M]ALLCPY,CPYPLF,FLGCLO
##        Endif
##      Else
##      Filter [F:PLF] Where YEAPLF=[M]YEAPLF & VERPLF=VALEUR & LEGPLF=[M]LEGPLF
##        If rowcount([F:PLF])>0 Then
##          Read [F:PLF] Last
##          If !fstat Then
##            [M]ALLCPY=1
##            [M]ALLFCY=1
##            [M]CPYPLF=[F:PLF]CPYPLF
##            [M]FCYPLF=[F:PLF]FCYPLF
##            [M]FLGCLO=[F:PLF]FLGCLO
##            Affzo [M]ALLCPY,ALLFCY,CPYPLF,FCYPLF,FLGCLO
##          Endif
##        Endif
##      Endif
##    Endif
##  Endif
##  Filter [F:PLF]
  #ADNGO - 2017-07-03 - X3-29553 - START
  Gosub VERIF_YEACPYFCY From CNSSBFSTD
  If ENR_OK<>2
    GMESSAGE=mess(168,10717,1) : # Il n'y a pas de plan définitif .#US3924 106549
    mkstat=2 : End
  Endif
  [M]SELFLG=1
  #ADNGO - 2017-07-03 - X3-29553 - END
End

