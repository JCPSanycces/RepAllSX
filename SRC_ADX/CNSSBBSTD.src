# FQ75419 - MABON 28/07/11 - Case "Plan définitif" cochée ou non selon valeurs sélectionnées
Subprog AM_VERPLF(VALEUR)
Variable Char    VALEUR()

  If clalev([F:PLF])=0 : Local File PLNFORM [PLF] : Endif
  Filter [F:PLF] Where YEAPLF=[M]YEAPLF & CPYPLF=[M]CPYPLF & FCYPLF=[M]FCYPLF & VERPLF=VALEUR & LEGPLF=[M]LEGPLF
  If rowcount([F:PLF])>0 Then
    Read [F:PLF] Last
    If !fstat Then
      [M]FLGCLO=[F:PLF]FLGCLO
      Affzo [M]FLGCLO
    Endif
  Endif
##  Else
##    Filter [F:PLF] Where YEAPLF=[M]YEAPLF & CPYPLF=[M]CPYPLF & VERPLF=VALEUR & LEGPLF=[M]LEGPLF
##    If rowcount([F:PLF])>0 Then
