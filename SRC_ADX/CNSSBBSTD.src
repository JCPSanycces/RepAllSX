#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry SBB
$ACTION

  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT

    When "DEB_CRIT"   : Gosub DEB_CRIT
    When "FIN_CRIT"   : Gosub FIN_CRIT

    #ADNGO - 2017-07-03 - X3-29553 - START
    When "APRES_CHOI" : Gosub APRES_CHOI
    #ADNGO - 2017-07-03 - X3-29553 - END

    When "AV_MAGNETO" : Gosub AV_MAGNETO
    When "AP_MAGNETO" : Gosub AP_MAGNETO

    When Default
  Endcase
Return

$OUVRE

  Gosub OUVRE From CNSSBFSTD
  GCHOIX = "SBB"
Return

$FERME

  Gosub FERME From CNSSBFSTD
Return

$LECTURE

  Gosub LECTURE From CNSSBFSTD
Return

$SETBOUT

  Gosub SETBOUT From CNSSBFSTD
Return

$DEB_CRIT

  Gosub DEB_CRIT From CNSSBFSTD
Return

$FIN_CRIT

  Gosub FIN_CRIT From CNSSBFSTD
Return

$AV_MAGNETO

  Gosub AV_MAGNETO From CNSSBFSTD
Return

$AP_MAGNETO

  Gosub AP_MAGNETO From CNSSBFSTD
Return
#ADNGO - 2017-07-03 - X3-29553 - START
# FQ85953 - Ajout état sur CONSSBB
$APRES_CHOI

  Case REPONSE
    When GSTAEDI :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      Local Char    SAVACT(GLONACT)
      Local Integer FLGEXE
      PARBOUT(1) = "REPCOST"
      PARBOUT(2) = GFONCTION
      PARBOUT(3) = num$(0)
      FLGEXE = 1
      SAVACT = GACTION
      GACTION = "AIMP1"
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AIMP1","AIMP1",4,"XYAIMP1") From GTRAITE
      GACTION = SAVACT
      REPONSE=0
  Endcase
Return
#ADNGO - 2017-07-03 - X3-29553 - END
# Gestion du masque CONSSBB1

$EVAL_YEA_ERROR

  GMESSAGE=mess(83,123,1) : # Valeur incorrecte
  mkstat=2
Resume

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSBB1) 24/03/2011 12:07:57 (MABON)
######################################################################################
Subprog AM_YEAPLF(VALEUR)
Variable Char    VALEUR()

  Onerrgo EVAL_YEA_ERROR
  If val(VALEUR)=0 Then
    GMESSAGE=mess(83,123,1) : # Valeur incorrecte
    mkstat=2 : End
  Endif
  Onerrgo

  # FQ85365 US903 - MABON 06/11/12 - Si pas de plan sur l'année, on ne laisse plus la possibilité de poursuivre, on bloque,
  Filter [F:PLF] Where YEAPLF=VALEUR and CLCFLG=2
  If rowcount([F:PLF])=0 Then
    GMESSAGE=mess(293,10717,1)-VALEUR : # Il n'y a pas de plan pour l'année yyyy.
    mkstat=2 : End
  Endif
  # Fin MABON
  #[M]LEGPLF=[F:PLF]LEGPLF
  # FQ71758 - MABON 03/03/11 - Réinit de la société/site
  If [M]CPYPLF<>"" | [M]FCYPLF<>"" Then
    If [M]CPYPLF<>"" Then
      Filter [F:PLF] Where YEAPLF=VALEUR and CLCFLG=2 & CPYPLF=[M]CPYPLF
    Endif
    If [M]FCYPLF<>"" Then
      Filter [F:PLF] Where YEAPLF=VALEUR and CLCFLG=2 & FCYPLF=[M]FCYPLF
    Endif
    If rowcount([F:PLF])=0 Then
      [M]SELFLG=1
    Endif
  Endif
  Filter [F:PLF]

  #ADNGO - 2017-07-03 - X3-29553 - START
  Gosub VERIF_YEACPYFCY From CNSSBFSTD
  Affzo [M]STRDAT
  Affzo [M]ENDDAT
  If ENR_OK<>2
    GMESSAGE=mess(293,10717,1) : # Il n'y a pas de plan  .#US3924 106549
    mkstat=2 : End
  Endif
  #ADNGO - 2017-07-03 - X3-29553 - END
  If [M]SELFLG=1 Then
    #[M]ALLCPY=2 : [M]CPYPLF=""
    #[M]ALLFCY=2 : [M]FCYPLF=""
    # FQ71758 - MABON 28/02/11 - Si on est dans la fenêtre de critères
    If dim(GCRIT)>0 & GCRIT=2 Then
      Affzo [M:CSBF]
    Endif
    If (dim(GCRIT)>0 & GCRIT=1) | dim(GCRIT)<0 Then
      Affzo [M:SBF1]
    Endif
  Endif
  [M]SELFLG=1

  # FQ75419 - MABON 28/07/11 - Case "Plan définitif" cochée ou non selon valeurs sélectionnées
  Filter [F:PLF] Where YEAPLF=VALEUR & CPYPLF=[M]CPYPLF & FCYPLF=[M]FCYPLF & VERPLF=[M]VERPLF & LEGPLF=[M]LEGPLF
  If rowcount([F:PLF])>0 Then
    Read [F:PLF] Last
    If !fstat Then
      [M]FLGCLO=[F:PLF]FLGCLO
      Affzo [M]FLGCLO
    Endif
  Endif
  #Filter [F:PLF] Where YEAPLF=VALEUR & CPYPLF=[M]CPYPLF & FCYPLF=[M]FCYPLF & VERPLF=[M]VERPLF & LEGPLF=[M]LEGPLF

End

