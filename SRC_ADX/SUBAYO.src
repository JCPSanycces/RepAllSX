Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYO",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Objet : AYO
## Ecran : AYO1
## Action de sélection : AYOSELPOOL, géré dans SUBAYOACT
## ACL_ZSELPOOL et BCL_ZSELPOOL pour alimenter champ POOX3 et vider le champ sur lequel est l'icône
## Contrôle manuel du remplissage des champs par sélection
######################################################################################

######################################################################################
## Table             :        AYTPOOWEB
## Ecran             :        AYO1
## Traitement        :        SUBAYO,SUBAYOACT,SUBAYOGEN
## Fenêtre           :        OAYO
## objet             :        AYO
## Type de données   :        AYO
## Action            :        AYOSELPOOL
## Fonction          :        GESAYO 
##
######################################################################################


$ACTION
Case ACTION
 When "LIENS"          : Gosub LIENS
 When "VERIF_CRE"      : Gosub VERIF_CRE
 When "VERIF_MOD"      : Gosub VERIF_MOD
 When "EXEACT"         : Gosub EXEACT
 When "SETBOUT"        : Gosub SETBOUT
 When "ACL_ZSELPOOL"    # Gestion particuliere click icone
        Local Char SAVPOOLX3(200) : SAVPOOLX3=[M:AYO1]POOX3
        Local Char SAVICO(4) : SAVICO=[M:AYO1]ZSELPOOL
        VALEUR=[M:AYO1]POOX3
 When "BCL_ZSELPOOL"   
        VALEUR=SAVICO    # Restauration icone
        If SAVPOOLX3<>[M:AYO1]POOX3
            Call AFFINFOPOOL()
            mkstat=4
        Endif
 When default
Endcase
Return


######################################################################################

$LIENS
# Call TEXTE([M:AYO1]POODES,[M:AYO1]ZPOODES) From OBJDIV
Call AFFINFOPOOL()

Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET : # Validation, copie
Endif
Return

$VERIF_CRE
$VERIF_MOD
# On vérifie qu'un pool X3 est saisi et qu'il existe
Call VERINFOPOOL()
Return

$EXEACT
Case BOUT
When "S"
Local Integer WI
    # A étendre sur tout le dossier...
     Call USG_SUPP("", GABREV, [M:AYO1]POOCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return





######################################################################################

Subprog AFFINFOPOOL()
If clalev([F:APW])=0  : Local File APOOLWS    [APW]  : Endif
If [M:AYO1]POOX3 <>"" Then
    Read [APW]APW1=[M:AYO1]POOX3
    If fstat Then
         GMESSAGE=mess(216,7900,1)-[M:AYO1]POOCOD
    Else
      [M:AYO1]SOLUTION=[F:APW]SOLUTION
      [M:AYO1]DOSSIER=[F:APW]DOSSIER
      [M:AYO1]INTITPOOL=[F:APW]INTITPOOL
      [M:AYO1]POOLALIAS=[F:APW]POOLALIAS
      [M:AYO1]SWEBALIAS=[F:APW]SWEBALIAS
      Affzo 10
    Endif
Endif

End

Subprog VERINFOPOOL()
Read [APW]APW1=[M:AYO1]POOX3
If [M:AYO1]POOX3 <>"" Then
    If fstat Then
         GMESSAGE=mess(216,7900,1)-[M:AYO1]POOCOD
    Endif
Else
        GMESSAGE=mess(215,7900,1)-[M:AYO1]POOCOD
Endif
End



