###########################
# Product name define in licences instead using aml 2902
# x3 if we have not a name in licence only here....
###########################
Funprog _AGETPRODUCTNAME
Local Char PRODUCT_NAME (40)
If dim(GACTX)>0
    PRODUCT_NAME = fmet GACTX.AGETLIC_PRODUCTNAME(func ASYRLIC.GET_CHPRODUCTSTDCODE)
    If PRODUCT_NAME = ""
         PRODUCT_NAME = "X3"
    Endif
Else
    PRODUCT_NAME = "X3"
Endif
End PRODUCT_NAME

