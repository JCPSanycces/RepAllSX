# 106969 Version management
###########################
# SCRIPT APRODUCT
###########################

###########################
# Release
###########################
Funprog AGETRELEASESUP ()
End "R090.002"

#**
#* Return the release number as a formated string (3 decimals)
#*
#* @param RELEASE : release number (ex: 80.010 will return "80.010" not "80.01")
#* use only this function to write PARAM in ADOVAL correctly.
#*!
Funprog FORMAT_RELEASE(RELEASE)
Value Decimal RELEASE

Local Char    STR_RELEASE(20)   # result
Local Integer NB0               # Number of 0 to add

STR_RELEASE = num$(RELEASE)
If instr(1,STR_RELEASE,".")
    NB0 = len(STR_RELEASE)-instr(1,STR_RELEASE,".")
    If NB0<3
        STR_RELEASE += string$(3-NB0,"0")
    Endif
Endif
End STR_RELEASE

###########################
#
###########################
Funprog AGETRELEASE (APPLI)
Value Char APPLI
Local Char RELEASE(20)

Local Integer ER
Onerrgo ERAPPLI
#107271
If func DOSSUB.ISHISTFOLD(APPLI)
 Local File =APPLI+".ADOVALHIS" [AHW]
 Read [AHW]AHW0 = "";"";"RELEASE"
 RELEASE = [F:AHW]VALEUR
Else
  # X3-79276
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)>0
      Local File =APPLI+".ADOVAL" [ADW]
      Read [ADW]ADW0 = "";"";"RELEASE"
      If fstat = 0
          RELEASE = [F:ADW]VALEUR
      Else
          RELEASE = ""
      Endif
  Else
      RELEASE = ""
  Endif
Endif
# X3-79276 and use logicclose
#Close Local File
LogicClose File
Onerrgo
If ER
 RELEASE = ""
Endif
End RELEASE

