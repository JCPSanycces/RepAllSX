Funprog _AGETINSTRELEASE ()
Local Integer OKTRT
Local Decimal RELEASE :#X3-15226 Manage sub-revision number
Local Integer PRODREL
RELEASE=0
Call EXISTE_ADX("","","AGESW33",OKTRT) From ORDSYS
If OKTRT
 PRODREL = func _PRODREL()
 Gosub _INSTRELEASE From AGESW33
Endif
End RELEASE
