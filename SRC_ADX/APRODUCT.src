Funprog AGETVERSLIC ()
Local Char CHECK(20)
Local Char VERSLIC (20)
Local Integer OKTRT
Local Integer PRODREL
VERSLIC=""
Call EXISTE_ADX("","","AGESW33",OKTRT) From ORDSYS
If OKTRT
 PRODREL = func _PRODREL()
 Gosub CHECK From AGESW33
 If CHECK=func APRODUCT.AGETRELEASEROOT(nomap)
  Gosub VERSLIC From AGESW33
 Endif
Else
 #old VERCOM
 Gosub VERCOM From GLOBVAR
 VERSLIC=left$(VERSION,1)
Endif
End VERSLIC
