###########################
#
###########################
Funprog AGETRELEASEROOT (APPLI)
Value Char APPLI
Local Char RELEASEPAR(20)

Local Integer ER
Onerrgo ERAPPLI
Local Char MACHINE(250) , NOMAPPLI(250) , APPRAC(250)
RELEASEPAR = ""
If APPLI=nomap
 Local File ADOVAL [ADW]
Else
 Local File =APPLI+".ADOVAL" [ADW]
Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 APPRAC = toupper([F:ADW]VALEUR)
 Call MACHINE(APPLI,MACHINE,NOMAPPLI) From ORDSYS
 If MACHINE=adxmac(0)
  If filinfo(filpath("FIL","ADOVAL","fde",APPRAC),0)>0
   Local File =APPRAC+".ADOVAL" [ADW2]
   Read [ADW2]ADW0 = "";"";"RELEASE"
   RELEASEPAR = [F:ADW2]VALEUR
  Endif
 Else
  If filinfo(filpath("FIL","ADOVAL","fde",APPRAC,"",MACHINE),0)>0
   Local File =MACHINE+"@"+APPRAC+".ADOVAL" [ADW2]
   Read [ADW2]ADW0 = "";"";"RELEASE"
   RELEASEPAR = [F:ADW2]VALEUR
  Endif
 Endif
Endif
Close Local File
Onerrgo
If ER
 RELEASEPAR = ""
Endif
End RELEASEPAR

$ERAPPLI
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
ER = errn
Resume

###########################
# Product version
###########################
Funprog AGETVERSION ()
Local Char CHECK(20)
Local Char VERSION (20)
Local Integer OKTRT
Local Integer PRODREL
VERSION="0.0.0"
Call EXISTE_ADX("","","AGESW33",OKTRT) From ORDSYS
If OKTRT
 PRODREL = func _PRODREL()
 Gosub CHECK From AGESW33
 If CHECK=func APRODUCT.AGETRELEASEROOT(nomap)
  Gosub VERSION From AGESW33
 Endif
Else
 #old GVERSION
 If dim(GVERSION)>0
 VERSION=GVERSION
 Endif
Endif
End VERSION
