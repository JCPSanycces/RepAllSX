#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets.
#########################################################################################
Subprog AOBJLST_TRC(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(10)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

Call ECR_TIME(mess(81,125,1)-": AOBJLST") From DOSSUB : # maj table

Trbegin [AOL]

 For WOBJET = "GTE"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File [AOL] , [AOL2]
End

#########################################################################################
# Mise à jour des textes => Récupération des textes en Textes Traduisibles.
#   MIGDOSMAJ => le dossier à migrer.
#
# MAJTEXTRA est appelé pour toutes les tables contenant des DES/DESSHO en V5 qui deviennent des DESTRA/SHOTRA en V6
#
#########################################################################################
Subprog MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Value    Char     VALEUR, TABLE, CHAMP, CLE1, CLE2

Local File =MIGDOSMAJ+".ATEXTRA" [MAXX]

Read [MAXX]AXX0 = TABLE;CHAMP;MIGGLANMAJ;CLE1;CLE2
If !fstat
 [F:MAXX]TEXTE = VALEUR
 If dim([F:MAXX]UPDDAT)>0 : [F:MAXX]UPDDAT = date$ : Endif
 If dim([F:MAXX]UPDUSR)>0 : [F:MAXX]UPDUSR = GUSER : Endif
 Rewrite [MAXX]
 If fstat
  Call ERREUR("ATEXTRA"-[L]TABLE-[L]CHAMP-[L]CLE1-[L]CLE2,2) From DOSDIC
 Endif
Else
 Raz [F:MAXX]
 [F:MAXX]CODFIC = TABLE
 [F:MAXX]ZONE   = CHAMP
 [F:MAXX]LANGUE = MIGGLANMAJ
 [F:MAXX]TEXTE  = VALEUR
 [F:MAXX]IDENT1 = CLE1
 [F:MAXX]IDENT2 = CLE2
 If dim([F:MAXX]CREDAT)>0 : [F:MAXX]CREDAT = date$ : Endif
 If dim([F:MAXX]CREUSR)>0 : [F:MAXX]CREUSR = GUSER : Endif
 Write [MAXX]
 If fstat
  Call ERREUR("ATEXTRA"-[L]TABLE-[L]CHAMP-[L]CLE1-[L]CLE2,2) From DOSDIC
 Endif
Endif

Close File [MAXX]
End

#########################################################################################
# Lecture des textes en Textes Traduisibles sur le dossier de COPIE
#########################################################################################
Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2

Local File =MIGDOSMAJ+".ATEXTRA" [CAXX]

Read [CAXX]AXX0 = TABLE;CHAMP;MIGGLANMAJ;CLE1;CLE2
If fstat=0
 VALEUR = [F:CAXX]TEXTE
Else
 Read [CAXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
 If fstat=0
  VALEUR = [F:CAXX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
Close File [CAXX]
End


#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets.
#########################################################################################
Subprog AOBJLST_CPTTRS(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(10)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

Call ECR_TIME(mess(81,125,1)-": AOBJLST") From DOSSUB : # maj table

Trbegin [AOL]

 For WOBJET = "JOU", "TPY", "CDA"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File [AOL] , [AOL2]
End

$INIVAR

Local Char W1_COD(6), W2_COD(6), W3_COD(6)
Local Char DESIG1(250) , DESIG2(250)

Local Integer DOLEG
Local Char PARAMETER(GLONADP)
Local Integer NBLEG : NBLEG = 5
Local Char LEGTAB(GLONADI)(1..NBLEG)

# Ouverture des tables du dossier à migrer
Local File =[F:ADS]DOSSIER+".ADOPAR"   [MADP]   # Paramètres
Local File =[F:ADS]DOSSIER+".ADOVAL"   [MADW]   # Valeurs paramétres
Local File =[F:ADS]DOSSIER+".ACTIV"    [MACV]   # Codes activités

# Déclaration des variables communes de travail
Local Integer I,J
Local Char TABLE(30), TABAOB(30), CODE(30), CODE_C(30), CODE_P(30)

# Gestion des textes trasuisibles
Global Char MIGGLANMAJ(10)
Global Char MIGDOSMAJ(10)

MIGGLANMAJ = [F:ADS]LANDEF
MIGDOSMAJ  = [F:ADS]DOSSIER

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3

# Législation de référence
Local Char LEGREF(30)
LEGREF = [F:ADS]DOSLEG(0)

# Release du dossier
Local Integer WVERSION
Local File =[F:ADS]DOSSIER+".ADOVAL" [TADW]
Read [TADW]ADW0 = "";"";"RELEASE"
If fstat=0
 WVERSION  = val( [F:TADW]VALEUR )
Endif
Close Local File [TADW]
Return

$FINVAR
Kill MIGGLANMAJ
Kill MIGDOSMAJ
Return
