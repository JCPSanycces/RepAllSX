##########################################################################################################
## Partie Comptabilité - Module TRONC COMMUN
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog ATRCMAJ40
##-------------------------------------------------------------------------------------------------------#
#** Appelé depuis DOSMAJ40
Gosub INIVAR

##-------------------------------------------------------------------------------------------------------#
# Données législation
##-------------------------------------------------------------------------------------------------------#
#-- MAJ Textes traduisibles
Gosub MAJTXTGTE From CPTMAJ40A
#-- MAJ des enregistrement ACLOB, ABLOB, AOBJTXT, AOBJTXTA pour GTE
Gosub MAJAOBGTE From CPTMAJ40A
#-- MAJ de la table TABPAM via ATABDIV 3
Gosub MAJTAM From CPTMAJ40A

#-- Initialisation des Législations actives dans les pièces automatiques
Gosub INILEGGAUGAD From CPTMAJ40A

#-- MAJ forcée de de l'onglet sélection des objets.
Call AOBJLST_TRC([F:ADS]DOSSIER,[F:ADS]DOSREF)

#-- MAJ lignes de codes comptables
Gosub GACCCODLIG From CPTMAJ40A

#-- MAJ ADI97 + GRP AREPORT
Gosub AREPORT_97 From CPTMAJ40A

Gosub FINVAR
End

##########################################################################################################
## Partie Comptabilité - Module COMPTABILITE
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog ACPTMAJ40
##-------------------------------------------------------------------------------------------------------#
#** Appelé depuis DOSMAJ40
Gosub INIVAR

##-------------------------------------------------------------------------------------------------------#
# Données législation
##-------------------------------------------------------------------------------------------------------#
#-- MAJ Textes traduisibles
Gosub MAJTXTJOU From CPTMAJ40A
#-- MAJ des enregistrement ACLOB, ABLOB, AOBJTXT, AOBJTXTA pour JOU
Gosub MAJAOBJOU From CPTMAJ40A
#-- Initialisation LEG sous GJOUCOA
Gosub GJOUCOA From CPTMAJ40A
#-- Initialisation LEG sous GAJOUSTA
Gosub GAJOUSTA From CPTMAJ40A

##-------------------------------------------------------------------------------------------------------#
# Autres Données
##-------------------------------------------------------------------------------------------------------#
#-- MAJ tableaux de bord
Gosub TXSAC From CPTMAJ40A
#-- MAJ Textes traduisibles
Gosub MAJTXTTBU From CPTMAJ40A
#-- MAJ CACCEDEF
Gosub CACCEDEF From CPTMAJ40A


#-- MAJ forcée de de l'onglet sélection des objets.
Call AOBJLST_CPTTRS([F:ADS]DOSSIER,[F:ADS]DOSREF)

Gosub FINVAR
End

##########################################################################################################
## Apres validation
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog CPTMAJ40
#** Appelé depuis DOSMAJ40
Gosub INIVAR

# Initialisation valeurs des nouveaux paramètres [LEG]VAT  - BRI/GER/POR/SPA/SWI
Gosub PARAMLEGVAT From CPTMAJ40A

Gosub FINVAR
End

##########################################################################################################
## Module tiers : avant validation
##########################################################################################################
##  Dans les AXXMAJ, on a les anciens + les nouveaux champs dans les tables...

##-------------------------------------------------------------------------------------------------------#
Subprog ATRSMAJ40
#** Appelé depuis DOSMAJ40
Gosub INIVAR

##-------------------------------------------------------------------------------------------------------#
# Données législation
##-------------------------------------------------------------------------------------------------------#
#-- MAJ Textes traduisibles TPY
Gosub MAJTXTTPY From CPTMAJ40A
#-- MAJ des enregistrement ACLOB, ABLOB, AOBJTXT, AOBJTXTA pour TPY
Gosub MAJAOBTPY From CPTMAJ40A
#-- Supression des écrans générés obsolètes des Transactions de règlements
Gosub MAJAMKTPY From CPTMAJ40A

#-- MAJ Textes traduisibles CDA
Gosub MAJTXTCDA From CPTMAJ40A
#-- MAJ des enregistrement ACLOB, ABLOB, AOBJTXT, AOBJTXTA pour CDA
Gosub MAJAOBCDA From CPTMAJ40A

#-- création des Textes traduisibles TFB
Gosub TABFILBAN From CPTMAJ40A
#-- MAJ des enregistrement ACLOB, ABLOB, AOBJTXT, AOBJTXTA pour CDA
Gosub MAJAOBTFB From CPTMAJ40A

##-------------------------------------------------------------------------------------------------------#
# Autres Données
##-------------------------------------------------------------------------------------------------------#
#-- MAJ de la table TABPAM via ATABDIV 304
Gosub MAJTED From CPTMAJ40A

Gosub FINVAR
End

##########################################################################################################
