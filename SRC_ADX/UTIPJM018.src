#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM018 Remove "SPE" action on PJMACOPY2
#
# Issue X3-33100 - 2017-04-12 by FGR : Sage internal usage only.
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM018(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM018(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Integer STAT

  Call ECR_TRACE("UTIPJM018: Process Start on : "+DOSSIER,0) From GESECRAN
  IERR = 0
  #----- Ouverture des fichiers -----#
  Local File ADOSSIER [ADS]
  Local File =DOSSIER + ".AMSKACT"  [AMA]
  Local File =DOSSIER + ".ADICTRT"  [ADC]
  # -----------------
  Raz COMPTEUR
  Read [ADS]DOSSIER=DOSSIER
  # -----------------
  Trbegin [AMA]
  Filter [AMA] Where [F:AMA]TYPAFF = 1 and [F:AMA]CODAFF = "PJMACOPY2" and [F:AMA]CODZON = "OPEART" and [F:AMA]ACTION = "SPE"
  For [AMA]
    # Delete the wrong action
    Delete [AMA]Curr
    If fstat Then
      Call ECR_TRACE("File AMSKACT" - num$([F:AMA]TYPAFF) - num$(CODAFF) - num$(CODZON) - num$(TYPACT) - num$(NOACT) + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Else
      # -----------------
      COMPTEUR += 1
      Read [ADC]ADC0="SPEPJMACOPY"
      If !fstat Then
        Delete [AMA]Curr
        If fstat Then
          Call ECR_TRACE("File ADICTRT" - num$([F:ADC]CODTRT) + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
      If IERR = 0 Then
        Call VALID([F:AMA]CODAFF, DOSSIER, [F:ADS]NBRLAN, [F:ADS]LAN, 1, STAT) From VALMSK
        # -----------------
        If filinfo(filpath("TRT", [F:ADC]CODTRT,"src", DOSSIER),0) > 0 Then
         Call EFFACE(filpath("TRT", [F:ADC]CODTRT, "src", DOSSIER), STAT) From ORDSYS
        Endif
        If filinfo(filpath("TRT", [F:ADC]CODTRT, "xrc", DOSSIER),0) > 0 Then
         Call EFFACE(filpath("TRT", [F:ADC]CODTRT, "xrc", DOSSIER), STAT) From ORDSYS
        Endif
        Call EFFACE_ADX("", DOSSIER, [F:ADC]CODTRT, STAT) From ORDSYS
        If filinfo(filpath("TRT", [F:ADC]CODTRT, "adx", DOSSIER),0) > 0 Then
          Call EFFACE(filpath("TRT", [F:ADC]CODTRT, "adx", DOSSIER), STAT) From ORDSYS
        Endif
        # -----------------
      Endif
    Endif
  Next
  Filter [AMA]
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM018 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM018 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [ADS]
  Close Local File [AMA]
  Close Local File [ADC]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  #If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTIPJM018(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  Call MAJ_UTIPJM018(APPLI)
End

