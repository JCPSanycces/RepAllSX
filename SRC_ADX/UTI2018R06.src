##########################################################################
# UTI2018RXX UTI process for 2018RX of X3
# THIS is a TEMPLATE... This process must not be modified
# UTI2018RXX is a template : so you must never complete it,
# because these modifications won't be never applied in any release.
#
# THE UTI For THE Next RELEASE, For Instance UTI2018R06, MUST BE DONE ONLY By DEVOPS TEAM;
# If A NEW ONE EXISTS IT WILL BE REPLACED.
#
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017RX - passage de RX-1 vers RX
#
#      correction utility to be done at the end of the patch - move from RX-1 to RX
#
##########################################################################

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R06 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC


End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R06 (APPLI)

End

###################################################
Subprog EXE_UTI2018R06(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R06-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#
#-------------------------------------------------------------#

#  Call PATCH  (LDOSSIER) From UTIXXX

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM201806001    # Issue X3-87228 - 2018-06-26 by FGR/ALMON
  Endif

#MIPEA - 2018-06-20-  X3-94669- START
Call PATCH(LDOSSIER) From UTIHRM011
#MIPEA - 2018-06-20-  X3-94669- END

# Issue X3-98320 - 2018-06-28 by FHA : Reset of VEF and VFE tables
Call PATCH(LDOSSIER) From UTICPT99

#MWA - 2018-06-28-  X3-74614- START
Call PATCH(LDOSSIER) From SUBGBS
#MWA - 2018-06-28-  X3-74614- END


# Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIEDI201806001
  Endif

# Issue X3-98872 - 2018-07-03 by JUSYN : deletion of table CCMNCSDOC (replaced by table NCSDOCHDR)
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTINCS201806001
  Endif
# End issue X3-98872

Call ECR_TRACE("END : UTI2018R06-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R06
End

