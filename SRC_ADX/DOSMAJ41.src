#<AdxTL>@(#)10.0.0.0 $Revision$
##################################################################################
# DOSMAJ41 : Mises à jour à effectuer lors du passage à la version 170 (Release 41)
# moulinette avant la version V7.1
#################################################################################
# moulinette avant la Release 41 si necessaire
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

###########################################
# MOULINETTE EN AVANT maj
############################################


#----- Superviseur en premier
#-----
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs V7
# Les index sont préservés
#-----
 Call MAJDIC From SUPMAJ41
#
 Call ECR_TRACE("************** DOSMAJ41 (Subprog AMAJ) ***************",-1) From GESECRAN
 Call AMAJ      From SUPMAJ41     : # Moulinettes Superviseur
 Call ECR_TRACE("************** DOSMAJ41 (Subprog AMAJ) ***************",-1) From GESECRAN
#----- Superviseur en premier

# tronc commun
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.7"
      If WPATCH < 4
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC44
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC55
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC56
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC57
      Endif
  Endif
Endif

Onerrgo
End

###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH, ZOK
WPATCH = 0
ZOK=0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.6"
    WPATCH =0
Endif


#----- Superviseur en premier
 Call ECR_TRACE("************** DOSMAJ41 (Subprog MAJ) ***************",-1) From GESECRAN
 Call MAJ      From SUPMAJ41     : # Moulinettes Superviseur
 Call ECR_TRACE("************** DOSMAJ41 (Subprog MAJ) ***************",-1) From GESECRAN


###########################################
# module tronc commun
# pas de test du module
###########################################
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.7"
      If WPATCH < 3
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC52
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC53
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC54
      Endif
      If WPATCH < 4
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC60
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC61
      Endif
      If WPATCH < 6
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITC62     # FGR 29/07/2014 : X3SUIVI100229
      Endif
  Endif
Endif

###########################################
# module compta
# pas de test du module
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  If left$(WVERSION,3) = "1.7"
    If WPATCH < 1
      Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT64
    Endif
    If WPATCH < 3
      Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT66
    Endif
  Endif
Endif
###########################################
# module tiers
# pas de test du module
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  If left$(WVERSION,3) = "1.7"
    If WPATCH < 3
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITRS25
    Endif
   Endif
Endif


###########################################
# module immos -
############################################
If left$(WVERSION,3) = "1.7"
    If [F:ADS]MODULE(13) = 2
        If WPATCH < 3
 #     Call UTI_MOUL([F:ADS]DOSSIER) From UTIxxxx
        Endif
    Endif
Endif

###########################################
# module ventes
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.7"
      If WPATCH < 3
   #     Call UTI_MOUL([F:ADS]DOSSIER) From UTIxxxx
      Endif
  Endif
Endif

###########################################
# MODUL Manufacturing
############################################
#Gbn-108091
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  If left$(WVERSION,3) = "1.7"
    If WPATCH < 1
          Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA42
    Endif
    If WPATCH < 12
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA47  # Issue 107012 - 2015-09-17 by BEB : Initialize ROUOPENUM = 0 for unexpected tracked OPs
    Endif
  Endif
Endif

###########################################
# MODULE CRM
############################################
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.7"
    If WPATCH < 6
      Call UTI_MOUL([F:ADS]DOSSIER) From UTICRM012     # FGR 25/07/2014 : X3SUIVI101618
      Call UTI_MOUL([F:ADS]DOSSIER) From UTICRM013     # FGR 31/07/2014 : X3SUIVI100463
    Endif
  Endif
Endif

###########################################
# module Stock
############################################
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.7"
      If WPATCH < 9
         Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO23  # Issue 100246 - 2015-03-05 by CCC : Valuation report with accounting date
      Endif
  Endif
Endif


Onerrgo
End
###################################################################################
###################################################################################
###################################################################################
$ERREUR
Call ECR_TRACE(errp-"("+num$(errl)+")"-mess(6,123,1)-":"-num$(errn)-errmes$(errn)-errm,1) From GESECRAN
# Erreur
Resume

