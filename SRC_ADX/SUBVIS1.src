#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
# Gestion du masque MAUTVISU1
######################################################################################

Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
#Variable Char    VALEUR()  # Ctrl des sources

Local Integer NOL, J
NOL=nolign-1

If GACTION = "VISUMAUTR"
    Read [MFG]MFG0=[M:VIS1]VCRNUM(NOL)
    If !fstat
        # OF matières seules
        If [F:MFG]MFGMOD = 2
            If [M:VIS1]ROUNUM(NOL)="" & [M:VIS1]ROUALT(NOL)= 0
                # Lcmt matière seule autorisée par trs
                If [F:MTS]MFGMODM = 2
                   J=1
                Endif
            Endif
        Endif
    Endif
Elsif GACTION =  "VISUMAUTF"
    If [M:VIS1]ROUNUM(NOL)="" & [M:VIS1]ROUALT(NOL)= 0
        # Lcmt matière seule autorisée par trs
        If [F:MTS]MFGMODM = 2
           J=1
        Endif
    Endif
Endif
pcolor = GCOUL(0)
If J
  If [M:VIS1]STRDAT(NOL) < date$ | ([M:VIS1]BOMALT(NOL) = 0 & [F:MTS]MFGMODO <> 2) | [M:VIS1]EXTQTY(NOL) = 0
     pcolor = GCOUL(1) : End
  Endif
Elsif [M:VIS1]STRDAT(NOL) < date$ | [M:VIS1]ROUNUM(NOL) = "" | [M:VIS1]EXTQTY(NOL) = 0
&  | ([M:VIS1]ROUALT(NOL) = 0 & [F:MTS]MFGMODM <> 2)
&  | ([M:VIS1]BOMALT(NOL) = 0 & [F:MTS]MFGMODO <> 2)
    pcolor = GCOUL(1) : End    # Issue 84916 GA 10/2012
Endif

# Issue 111414 - 2016-01 by GH - Implementation of versioning
J=0
If dim([M:VIS1]ECCVALMAJ)>0 & func ECCLIB.NBRCPN([M:VIS1]ITMREF(NOL))
   Call CTRECC([M:VIS1]ITMREF(NOL),"VIS1","STRDAT",[M:VIS1]ECCVALMAJ(NOL),[M:VIS1]ECCVALMIN(NOL),
&              [M:VIS1]STRDAT(NOL),GERR,GMESSAGE) From ECCLIB
   If find(GERR,1,4)
      pcolor = GCOUL(1) : J=1
   Endif
   Raz GERR, GMESSAGE
Endif
If !J & [M:VIS1]ROUNUM(NOL)<>"" & dim([M:VIS1]ROUECCMAJ)>0 & func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(NOL))
   Call CTRROUECC([M:VIS1]ROUNUM(NOL),[M:VIS1]MFGFCY,"VIS1","STRDAT",[M:VIS1]ROUECCMAJ(NOL),[M:VIS1]ROUECCMIN(NOL),
&                 [M:VIS1]STRDAT(NOL),GERR,GMESSAGE) From RVMLIB
   If find(GERR,1,4)
      pcolor = GCOUL(1) : J=1
   Endif
   Raz GERR, GMESSAGE
Endif
End

######################################################################################

$RAF_ITMREF
Call AV_ITMREF([M:VIS1]ITMREF(nolign-1))
zonsui =[M:VIS1]ITMREF(nolign-1)
Affzo [M:VIS1]ITMREF(nolign-1)
Return

######################################################################################
Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR

# pour réafficher l'article
[M:VIS1]EXTQTY(nolign-1) = VALEUR
Gosub RAF_ITMREF
End

######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M]MFGFCY) From MFGLIB

# Issue 111414 - 2016-01 by GH - Implementation of versioning
If !mkstat & dim([M:VIS1]ECCVALMAJ)>0
   Local Integer LRET
   Call CTRECC([M:VIS1]ITMREF(nolign-1),"VIS1","STRDAT",[M:VIS1]ECCVALMAJ(nolign-1),[M:VIS1]ECCVALMIN(nolign-1),
&              VALEUR,LRET,GMESSAGE) From ECCLIB
   If find(LRET,1,4)
      GMESSAGE=mess(344,193,1)-[M:VIS1]ECCVALMAJ(nolign-1)-[M:VIS1]ECCVALMIN(nolign-1)+"\"+GMESSAGE
      mkstat=2 : End
   Endif
Endif

End

######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY


# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# Issue 48879 - 2017-08-21 by STLIG : If backward scheduling then don't recalculate end date
If ([F:MTS]SCDMODSAI<>2)
  End
Endif

# recalcul date fin
Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT=VALEUR
WORIFCY=[M]MFGFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif

WQTY = [M]EXTQTY(nolign-1)
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M]ENDDAT(nolign-1)) From MFGLIB

Call TEMPOFF From GESECRAN
Affzo [M]ENDDAT(nolign-1)
#
# pour réafficher l'article
[M:VIS1]STRDAT(nolign-1) = WORIDAT
Gosub RAF_ITMREF
End

######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M]MFGFCY) From MFGLIB

# Issue 48879 - 2017-09-01 by STLIG : Validate end date > start date
If (!mkstat & ([F:MTS]SCDMODSAI=2 | VALEUR=[M:VIS1]ENDDAT(nolign-1)))
  Call DATDEBFIN(VALEUR,[M:VIS1]STRDAT(nolign-1)) From EXEFNC
Endif

End

######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

Call CHECK_PAST(VALEUR, 2) From MFGLIB

# Issue 48879 - 2017-08-21 by STLIG : If forward scheduling then don't recalculate start date
If ([F:MTS]SCDMODSAI=2)
  End
Endif

Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT=VALEUR
WORIFCY=[M]MFGFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M]ITMREF(nolign-1);[M]MFGFCY
If fstat : End : Endif


WQTY = [M]EXTQTY(nolign-1)
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M]STRDAT(nolign-1)) From MFGLIB

Call TEMPOFF From GESECRAN

Affzo [M]STRDAT(nolign-1)

# Issue 48879 - 2017-09-01 by STLIG : Validate end date > start date
Call DATDEBFIN(VALEUR,[M:VIS1]STRDAT(nolign-1)) From EXEFNC
If (mkstat) : End : Endif

Call CHECK_PAST([M]STRDAT(nolign-1), 2) From MFGLIB

# Issue 111414 - 2016-01 by GH - Implementation of versioning
If !mkstat & dim([M:VIS1]ECCVALMAJ)>0
   Local Integer LRET
   Call CTRECC([M:VIS1]ITMREF(nolign-1),"VIS1","STRDAT",[M:VIS1]ECCVALMAJ(nolign-1),[M:VIS1]ECCVALMIN(nolign-1),
&              [M]STRDAT(nolign-1),LRET,GMESSAGE) From ECCLIB
   If find(LRET,1,4)
      GMESSAGE=mess(344,193,1)-[M:VIS1]ECCVALMAJ(nolign-1)-[M:VIS1]ECCVALMIN(nolign-1)+"\"+GMESSAGE
      mkstat=2 : End
   Endif
Endif

# pour réafficher l'article
Gosub RAF_ITMREF
End

######################################################################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : mkstat = 2 : Endif
End

######################################################################################
Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR

# on ne permet pas de modifier l'alternative de nomenclature d'un OF alloué
If GACTION = "VISUMAUTR" & [F:MFG]ALLSTA > 1 : mkstat = 2 : End : Endif

## Issue 111414 - 2016-01 by GH - Implementation of versioning
If VALEUR = 0 & ([F:MTS]MFGMODO<>2 | (dim([M:VIS1]ECCVALMAJ)>0 & func ECCLIB.NBRCPN([M:VIS1]ITMREF(nolign-1))))
   Call RECH_NOM([M]MFGFCY, [M]STRDAT(nolign-1), VALEUR, 2) From BENCHLIB
   If VALEUR<>0
     # pour réafficher l'article
     [M:VIS1]BOMALT(nolign-1) = VALEUR
     Gosub RAF_ITMREF
   Endif
Endif

## Issue 111414 - 2016-01 by GH - Implementation of versioning
If VALEUR<>0 & dim([M:VIS1]ECCVALMAJ)>0 & func ECCLIB.NBRCPN([M:VIS1]ITMREF(nolign-1))
   mkstat=2
Endif
End

######################################################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer    WALT

If VALEUR = 0
    # Issue 84916 GA 10/2012 suite Issue 82499 GA 06/2012
    # autoriser BOMALT=0 dès lors que la transaction accepte "Opérations seules"
    If [F:MTS]MFGMODO<>2 : GMESSAGE=mess(10,123,1) : mkstat = 2 : Endif
Else
    # contrôle nomenclature
    WALT = VALEUR
    Call CONT_BOMALT([M]MFGFCY, WALT,2,[M]ITMREF(nolign-1), [M]STRDAT(nolign-1)) From BENCHLIB
    If GMESSAGE <> "" : mkstat = 2 : Endif
Endif
End

######################################################################################
Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY(GLONFCY)
Local    Integer WALT

If VALEUR<>0
  If [M]STRDAT(nolign-1)=[0/0/0]
      WDAT=date$
  Else
      WDAT=[M]STRDAT(nolign-1)
  Endif

  # contrôle nomenclature
  WFCY=[M]MFGFCY
  # Lecture BOM
  Read [TBO]TBO0=2;VALEUR
  If fstat : mkstat=2 : End : Endif
  Read [BOH]BOH0=[M]ITMREF(nolign-1);VALEUR;2
  If fstat :  Call ERREUR(mess(95,193,1)) From GESECRAN : mkstat=2 :End : Endif
  Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
  If WALT=0  : mkstat=2 : End : Endif
Endif

# pour réafficher l'article
[M:VIS1]BOMALT(nolign-1) = VALEUR
Gosub RAF_ITMREF
End

######################################################################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()

If GACTION="VISUMAUTR"
    # on ne peut pas compléter un OF partiel si la transaction ne permet pas de lancer des OF complets
    If [F:MFG]MFGMOD = 2 & [F:MTS]MFGMODC = 1
       mkstat=1 : End
    Endif
Elsif GACTION="VISUMAUTF"
    # si la transaction ne permet pas de lancer des OF complets
    If [F:MTS]MFGMODM = 2 & [F:MTS]MFGMODC = 1
      mkstat=1 : End
    Endif
Endif

If VALEUR=""
    Call C_ROUNUM(VALEUR)
    If mkstat
       GMESSAGE=""
       If [F:ITF]ITMREF <> [F:ORD]ITMREF | [F:ITF]STOFCY<>[M:VIS1]MFGFCY
          Read [ITF]ITF0=[F:ORD]ITMREF;[M:VIS1]MFGFCY
       Else fstat=0
       Endif
       If fstat | [F:ITF]MFGROU = ""
          [M:VIS1]ROUNUM(nolign-1) = [M:VIS1]ITMREF(nolign-1)
       Else
          [M:VIS1]ROUNUM(nolign-1) = [F:ITF]MFGROU
      Endif
   Endif
Endif
End

######################################################################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()

If GACTION="VISUMAUTR"
    Read [MFG]MFG0=[M:VIS1]VCRNUM(nolign-1)
    If !fstat & VALEUR = "" & [F:MFG]MFGMOD<>2
        Case [F:MFG]MFGMOD
            When 1 : # OF  complet
                If [F:MTS]MFGMODC = 2
                    GMESSAGE = mess(31,190,1)
                    mkstat = 2
                Endif
            When 3 : # OF opérations seules
                If [F:MTS]MFGMODO = 2
                    GMESSAGE = mess(31,190,1)
                    mkstat = 2
                Endif
        Endcase
    Endif
Elsif GACTION="VISUMAUTF"
    If [F:MTS]MFGMODM = 1  & VALEUR = ""
        GMESSAGE = mess(31,190,1)
        mkstat = 2
    Endif
Endif
End

######################################################################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()

If GACTION = "VISUMAUTR"
    If find([F:MFG]MFGMOD,1,3) & VALEUR = ""
        GMESSAGE = mess(31,190,1)
        mkstat = 2
        End
    Endif
Endif

# pour réafficher l'article
[M:VIS1]ROUNUM(nolign-1) = VALEUR
Gosub RAF_ITMREF
End

######################################################################################
## Issue 111414 - 2016-01 by GH - Implementation of versioning

Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR

If [M:VIS1]ROUNUM(nolign-1)="" : mkstat=1 : End : Endif

If dim([M:VIS1]ROUECCMAJ)<0 : End : Endif

Local Integer WALT
WALT = func RVMLIB.GETRVMALT([M:VIS1]ROUNUM(nolign-1),[M:VIS1]MFGFCY,[0/0/0])
If WALT
  Call CONT_ROUALT([M:VIS1]MFGFCY, WALT, [M:VIS1]ROUNUM(nolign-1), [M:VIS1]STRDAT(nolign-1), [M:VIS1]EXTQTY(nolign-1),
&                  [F:ITM]STU, [M:VIS1]BOMALT(nolign-1)) From BENCHLIB
  If WALT=0
     GMESSAGE="" : End
  Elsif WALT<>VALEUR
     VALEUR = WALT
     Call INIECCROU([M:VIS1]ROUNUM(nolign-1),[M:VIS1]MFGFCY,[M:VIS1]STRDAT(nolign-1),VALEUR
&                  ,[M:VIS1]ROUECCMAJ(nolign-1),[M:VIS1]ROUECCMIN(nolign-1)) From RVMLIB
     Affzo [M:VIS1] ROUECCMAJ(nolign-1), ROUECCMIN(nolign-1)
     # pour réafficher l'article
     [M:VIS1]ROUALT(nolign-1) = WALT
     Gosub RAF_ITMREF
  Endif
  mkstat=2
Endif

End

######################################################################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY(GLONFCY)
Local Integer    WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)

If GACTION ="VISUMAUTR"
    # on ne peut pas compléter un OF partiel si la transaction ne permet pas de lancer des OF complets
    If [F:MFG]MFGMOD = 2 & [F:MTS]MFGMODC = 1
        Raz VALEUR, [M]ROUALT(nolign-1)
        Affzo [M]ROUALT(nolign-1) : End
    Endif
Elsif GACTION ="VISUMAUTF"
    If [F:MTS]MFGMODM= 2 & [F:MTS]MFGMODC = 1
       Raz VALEUR, [M]ROUALT(nolign-1)
       Affzo [M]ROUALT(nolign-1) : End
    Endif
Endif

If VALEUR = 0
    If [F:MTS]MFGMODM = 2 & [M:VIS1]ROUNUM(nolign-1) = ""
        End
    Else
        GMESSAGE=mess(10,123,1)
        mkstat = 2
        End
    Endif
Endif
# contrôle gamme
WDAT=[M]STRDAT(nolign-1)
WFCY=[M]MFGFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=WFCY;[M]ROUNUM(nolign-1);VALEUR
If fstat : mkstat=2 : End : Endif

Call CONTMFGGAM(WFCY,WALT,WDAT,[M]EXTQTY(nolign-1), [M]STU(nolign-1), 1) From MFGLIB
If WALT=0 :  mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M]BOMALT(nolign-1), TABTBO)
   GMESSAGE=mess(53,193,1)
   mkstat=2
   End
Endif
End

######################################################################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY(GLONFCY)
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)

WDAT=[M]STRDAT(nolign-1)
WFCY=[M]MFGFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=WFCY;[M]ROUNUM(nolign-1);VALEUR
If fstat : mkstat=2 : End : Endif

Call CONTMFGGAM(WFCY,WALT,WDAT,[M]EXTQTY(nolign-1), [M]STU(nolign-1), 1) From MFGLIB
If WALT=0 :  mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M]BOMALT(nolign-1), TABTBO)
   GMESSAGE=mess(53,193,1)
   mkstat=2
   End
Endif

# pour réafficher l'article
[M:VIS1]ROUALT(nolign-1) = VALEUR
Gosub RAF_ITMREF
End

######################################################################################

Subprog AM_PECFLG(VALEUR)
Variable Integer VALEUR

[M:VIS1]PECFLG(nolign-1) = VALEUR

End

######################################################################################
## Issue 111414 - 2016-01 by GH - Implementation of versioning
######################################################################################

Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M:VIS1]ITMREF(nolign-1))<1
   mkstat=1
Endif
End

######################################################################################

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
If VALEUR=""
   GMESSAGE=mess(10,123,1) : LRET=1
Else
   Call CTRECC([M:VIS1]ITMREF(nolign-1),"VIS1","ECCVALMAJ",VALEUR,[M:VIS1]ECCVALMIN(nolign-1),
&             [0/0/0],LRET,GMESSAGE) From ECCLIB
Endif
If find(LRET,1,4)
   Gosub ERR_TIT
   If TIT<>""
      Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(153,198,1)-'-'-TIT+'"') From GESECRAN : # Erreur zone...
      GMESSAGE=""
   Endif
   mkstat=2 : End
Endif

If VALEUR<>[M:VIS1]ECCVALMAJ(nolign-1)
   # pour réafficher l'article
   [M:VIS1]ECCVALMAJ(nolign-1) = VALEUR
   Gosub RAF_ITMREF
Endif
End

