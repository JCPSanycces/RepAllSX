#<AdxTL>@(#)0.0.0.0 $Revision$ 
#FRLAA X3-91918 2018-05-29 - START
#**
#* Check the status and each property of the class to see if a change occured
#* @param STRUCTURE , Class - no internal declaration
#* @param VSYSPROP Value Char, An array indicating properties to exclude - -system properties will be excluded in this function
#* @param VWRK Variable Char, Indicate the change on the class C/D/M
#* @return RETVAL Local Integer - [V]AYES/[V]ANO
#*!
Funprog CHECK_CLASS_STAT(STRUCTURE,VSYSPROP,VWRK,VLINSTAT)
Value Char VSYSPROP,VLINSTAT
Variable Char VWRK
Local Integer RETVAL
Raz VWRK


#Assign variables
[L]RETVAL = [V]CST_ANO
#Test the status of the class and set WRK variable
#This test must include the manual status added on class transfer
If VLINSTAT= "T" #Basic classes will always show records as new when transferred
  If STRUCTURE.ASTALIN = [V]CST_ADEL #Record deleted
    VWRK = "D"
    [L]RETVAL = [V]CST_AYES
  Else
    #Check if a property in the record has been modified
    Gosub CHECK_MODIFY
  Endif
Else
  If STRUCTURE.ASTALIN <> [V]CST_ANEWDEL
    If STRUCTURE.ASTALIN = [V]CST_ANEW
      VWRK = "C"
      [L]RETVAL = [V]CST_AYES
   Endif
  Endif
Endif

End [L]RETVAL


$CHECK_MODIFY
Local Integer K
Local Clbfile OLDVAL,NEWVAL
Local Char FUNC_OBJVAR(100),FUNC_OBJVAR_SNAP(100)
Local Char PROG(100), PROGTYP(100)

Gosub SET_PROG_SYS

K = STRUCTURE.ObjectNbs
For I = 1 To K
  If find(STRUCTURE.ObjectVar(I),VSYSPROP)=0
    FUNC_OBJVAR = "(STRUCTURE."+STRUCTURE.ObjectVar(I)+")"
    FUNC_OBJVAR_SNAP = "(STRUCTURE.snapshot."+STRUCTURE.ObjectVar(I)+")"
    OLDVAL = evalue(PROG+FUNC_OBJVAR_SNAP)
    NEWVAL = evalue(PROG+FUNC_OBJVAR)
    If (NEWVAL<>OLDVAL)
      VWRK = "M"
      [L]RETVAL = [V]CST_AYES
      Break
    Endif
  Endif
Next I
Return

#**
#* Evaluate a property in a class - used to compare values for any class
#* @param EVAL_VAL, contains the property MYCLASS.PRO - No type can be assigned
#* @return RETVAL Local Integer
#*!
Funprog PARSE_CLASS_VAL(EVAL_VAL)
Local Clbfile S_VAL
VRETVALTYP =  type(EVAL_VAL)
If VRETVALTYP < 200
  S_VAL+=num$(EVAL_VAL)
Endif
End S_VAL

$SET_PROG_SYS
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".PARSE_CLASS_VAL"
PROGTYP="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".GETFIELD_TYP"
#Set system properties
RETVAL = func ESS_WRKFLOW_FUNC.SET_SYPROP(VSYSPROP)
Return

$HANDLE_CLASS_WRKFLOW
If RETVAL >= [V]CST_AERROR
  #If TRANSACTION_PENDING=0 : Rollback : Endif #FRLAA X3-91919 2018-09-18
Endif
If RETVAL = [V]CST_AOK
  #If TRANSACTION_PENDING=0 : Commit : Endif #FRLAA X3-91919 2018-09-18
  STAT = func EMPLOYEE_WORKFLOW(STRUCTURE,VCLEOBJ)
Endif

Return

Funprog EMPLOYEE_WORKFLOW(STRUCTURE,CLEOBJ)
Value Char CLEOBJ
Local Integer I
Local Integer STAT
Local Char    OPERAT(30)
OPERAT="M"
#Variable Instance STRUCTURE Using C_EMPESS

Gosub WORKFLOW_UPDATE_STAT

STAT = func ASYRWRKCLASSIC.WORKFLOW(STRUCTURE.ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQNUM,MSG)

End STAT


$WORKFLOW_UPDATE_STAT
#
Local Integer REQNUM,TYPEVT,STAT
Local Char    CODEVT(30)
Local Char    MSG(250)

TYPEVT=2         : # Object based event
CODEVT="ESWD"     : # The object is EXS

# Current key
#CLEOBJ must be set by the calling program - multiple programs

Return

Subprog RECOVERS_ERROR_IN_CLASSIC(STRUCTURE)
Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE
GERR=0

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(STRUCTURE, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


## To help debug process : write a classic log file with all errors in class.
#If GERR <> 0 Then
#  If GTRACE = AVOID.ACHAR Then
#    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
#    IOPEN_TRACE = [V]CST_AYES
#  Endif
#  Call ECR_TRACE("->", 0) From GESECRAN
#  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(STRUCTURE) From SYRSTACKTOOLS
#  If IOPEN_TRACE = [V]CST_AYES Then
#    Call FERME_TRACE From LECFIC
#  Endif
#Endif
# ----------------------------------------------------------


[L]MY_STATUS = fmet STRUCTURE.ADELETERRORALL()
End

$CHECK_MODIFY_WRLFLOW
#These properties will be additional to the manual properties before the call
Gosub SET_PROG_SYS From ESS_WRKFLOW_FUNC

K = STRUCTURE.ObjectNbs
For I = 1 To K
  If find(STRUCTURE.ObjectVar(I),VSYSPROP)=0
    FUNC_OBJVAR = "(STRUCTURE."+STRUCTURE.ObjectVar(I)+")"
    FUNC_OBJVAR_SNAP = "(STRUCTURE.snapshot."+STRUCTURE.ObjectVar(I)+")"
    OLDVAL = evalue(PROG+FUNC_OBJVAR_SNAP)
    NEWVAL = evalue(PROG+FUNC_OBJVAR)
    If (NEWVAL<>OLDVAL)
      If CHANGEFOUND = [V]CST_AYES
        CHANGEFOUND = [V]CST_ANO
      Elsif CHANGEFOUND = [V]CST_ANO
        #Keep value
      Else
        CHANGEFOUND = [V]CST_AYES
      Endif

      MAINRECORD  = [V]CST_ANO
      RETVALTYP = evalue(PROGTYP+FUNC_OBJVAR)
      #Change found - Create record in EMPLORIB Workflow table
      Gosub ADDLINE_ESSWRKFLWDET From ESS_WRKFLOW_FUNC
      If (RETVAL >= [V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next I
Return


#**
#* Check all the properties in the class - write any changes to worklow staging class
#* @param V_WRK Value Char, Workflow code C/M/D
#* @param V_THISUSR , Current context user
#* @param STRUCTURE , Class
#* @param VCLASSCOD Value Char, The ESS Class where the change occurred
#* @param VTABLE Value Char, Main table linked to the class
#* @param VABR Value Char, Main table abbr. linked to the class
#* @param VCLASS_ERROR Value Char, Returns the error on the class
#* @param VSYSPROP Value Char, An array indicating properties to exclude  -system properties will be excluded in this function
#* @param VALPKEY Value Char, Char array containing fields in the key of the main table
#* @param VINTKEY Value Integer, Integer array containing fields in the key of the main table
#* @param VDATKEY Value Date, Date array containing fields in the key of the main table
#* @return RETVAL Local Integer
#*!

#ESSWRKEMP
Funprog GENESSWRKFLOW_ESSWRKEMP(V_WRK, V_THISUSR,STRUCTURE,VCLASSCOD,VTABLE,VABR,VCLASS_ERROR,VSYSPROP,VALPKEY,VINTKEY,VDATKEY,VCLEOBJ)
Value Char VALPKEY,V_WRK
Value Date VDATKEY
Value Integer VINTKEY
Value Char VTABLE,VABR,VSYSPROP,VCLASSCOD,V_THISUSR
Variable Char VCLASS_ERROR,VCLEOBJ
Local Char TEXTABLE(GLONATB) :  TEXTABLE = VTABLE

#Set return value - All functions
RETVAL = [V]CST_AOK

#Declare variables - All functions
Gosub DECLARE_LOCAL_GENESSWRKFLOW From ESS_WRKFLOW_FUNC

#Open file and begin transaction
#Gosub OPEN_FILE_EMPLOID From ESS_WRKFLOW_FUNC  #Open own file #FRLAA X3-91919 2018-09-18

#Check the workflow code and manage
If V_WRK = "C" | V_WRK = "D"
  Gosub CREATION_ESSWRKFLWDET From ESS_WRKFLOW_FUNC
  If RETVAL = [V]CST_AOK
    Gosub ADDLINE_ESSWRKEMP From ESS_WRKFLOW_FUNC #Add own sub for class
    If RETVAL = [V]CST_AOK
      Gosub HANDLE_CLASS_WRKFLOW
      End RETVAL #Always return
    Endif
  Endif
  End RETVAL
Endif

#-----------------The following procedure will be used for modified records only------------------------------#
If V_WRK <> "M" : End RETVAL : Endif
#Set the calling function to parse values and setting system properties - Generic for all functions
Gosub CHECK_MODIFY_WRLFLOW

If (CHANGEFOUND = [V]CST_AYES or CHANGEFOUND = [V]CST_ANO)  and RETVAL = [V]CST_AOK
  MAINRECORD  = [V]CST_AYES
  CHANGEFOUND = [V]CST_ANO

  Gosub ADDLINE_ESSWRKFLWDET From ESS_WRKFLOW_FUNC
  #Change found - Create record in worklfow
  Gosub ADDLINE_ESSWRKEMP From ESS_WRKFLOW_FUNC #Add own sub for class
  Gosub HANDLE_CLASS_WRKFLOW
Endif
End RETVAL

