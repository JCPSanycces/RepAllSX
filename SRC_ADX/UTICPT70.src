#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################
# UTICPT70 : Initialization With EECVT Sequence Number          #
#           Module =  Financials  (2)                           #
#################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=[L]DOSSIER
 If fstat : Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Initialization with EECVT Sequence Number") From LECFIC
 Call MAJ_UTICPT70(DOSSIER)

 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


#####################################################################################
Subprog MAJ_UTICPT70(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT70: Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:TCA])=0 : Local File =DOSSIER+".TABCOUAFF" [TCA] : Endif

Local Integer N

Call DEBTRANS From GLOCK

Trbegin [TCA]

For [TCA] Where MODULE=2  #-- Module Financials
 Gosub UPDATE_TCA
Next

Commit

Close Local File [TCA]

Call ECR_TRACE("UTICPT70: "+num$(N)+" records processed",0) From GESECRAN

End

$UPDATE_TCA
Readlock [TCA] Curr
If fstat = 0 &  [F:TCA]CODNUM(17)=""
 [F:TCA]CODNUM(17)  = "EECVT"
 [F:TCA]MANCOU(17)  = 1
 [F:TCA]UPDDAT      = date$
 [F:TCA]UPDUSR      = GUSER
 If dim([F:TCA]UPDTIM)>0
  [F:TCA]UPDTIM    = time
 Elsif dim([F:TCA]UPDDATTIM)>0
  [F:TCA]UPDDATTIM = time
 Endif
 Rewrite [TCA]
 If !fstat : N +=1 : Endif
Endif
Return

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
# To update all the akira folders
#If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
# No check of module.
If filinfo(filpath("FIL","TABCOUAFF","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTICPT70(APPLI)

End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
# To update all the akira folders
#If APPLI=GDOSX3 End : Endif

If filinfo(filpath("FIL","TABCOUAFF","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT70(APPLI)
End
