#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-100056 - 2018-07-10 by CBO : Enhancements of VAT form

#*********************************************************************
#
#             Display the result of VAT submit from GESVFE
#
#*********************************************************************

$ACTION

  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When Default
  Endcase
Return

$DEBUT

  [M:VFE9]VATENTNUM = [M:VFE0]VATENTNUM
  [M:VFE9]VATFRM    = [M:VFE0]VATFRM
  [M:VFE9]DESTRA    = [M:VFE0]DESTRA
  [M:VFE9]STA       = [M:VFE0]STA

  [M:VFE9]RESULT    = [M:VFE1]RESULT

Return

