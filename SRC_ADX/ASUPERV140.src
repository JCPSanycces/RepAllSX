#<AdxTL>@(#)1.0.0.0 $Revision$
##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits 
#  utilise par INDUS si poste 0 vide : plus de mise a jour en 140
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_140
# test connexion avec la v140
# plus de mise a jour
If GFOLDER_PRODUIT (0) = ""
    Return
Endif

Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE

# mise a jour ATEXTE de superv140

# lecture dans le fichier XXS code langue FRA
# recherche du texte correspond 
# dans superv140 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 

Raz WTAB_NUM
W_INDICE  =0

Filter [XXS] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XXS]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XXS]NUMERO
Next
Filter [XXS]

If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv140 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XXS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XXS]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV140_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XXS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XXS]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV140_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif



