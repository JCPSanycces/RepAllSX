#<AdxTL>@(#)0.0.0.0 $Revision$

#FRLAA X3-82396 2018-03-14 - START
$MAJTIP_GLM
Filter [DCG] Where evalue([L]CRITERE2(0))
Read [DCG] First
Filter [DCG]
If !fstat
  Gosub WRKSIG_GLM
Endif
Return


$WRKSIG_GLM
Local Integer RET_GOK
Local Integer UIDS_TO_INCLUDE(20)(1..)
Local Integer UIDS_COUNT : UIDS_COUNT=1
Local Char ERRMSG(250)
Local Integer VTSA : VSTA = [F:DCG]STA
Local Char VREFNUM(GLONEML) : VREFNUM = [F:DCG]REFNUM
Local Integer ORG_UID : ORG_UID = [F:DCG]UID
Global Date CHECKD
Local Char GLOBFUNCTION(GLONAFC)

GLOBFUNCTION=GFONCTION

GFONCTION="GESDCG"

#Split the current transaction
#Assign the split filter(s)
Gosub ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION From SUBDCGGLM

#Delete future accruals
Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]ENDDAT, [F:DCG]TIM, 0, GCURLEG) From SUBDCGGLM

If [F:DCG]UID<>99999999
  Call RESET_FUTURE_SPLITS_PROG(RET_GOK,GCURLEG,0,UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
Endif

[L]CRITERE2(0)="UID="+num$([L]ORG_UID)
[L]CRITERE2(1)="1=1"

Gosub MAJTIP From SUBDCG

Update [DCG] Where REFNUM=VREFNUM & UID<0 & WRK>"" With WRK=""
If fstat
  [V]GOK=0
  Call RSTA("DCG",num$(VREFNUM)-'WRK=""') From GLOCK
  GFONCTION=GLOBFUNCTION
  Return
Endif


#Resplit any possible future transactions - transaction already cleared
Call RESPLIT_TRANSACTIONS_PROG(RET_GOK,GCURLEG,0,VREFNUM,ERRMSG,[0/0/0]) From SUBDCGGLM


[L]CRITERE2(0) ="REFNUM="+"'"+num$(VREFNUM)+"'" +" & find(UID,[L]UIDS_TO_INCLUDE)"
[L]CRITERE2(1)="1=1"

If [L]UIDS_TO_INCLUDE(1)<>0
  Gosub MAJTIP From SUBDCG
  If [V]GOK<1 :  GFONCTION=GLOBFUNCTION :Return : Endif
Endif
GFONCTION=GLOBFUNCTION
Return


$DECLARE_GLM_VARIABLES
Local Integer IS_SOA
Local Integer SOA_GOK
Local Char SOALEG (GLONADI)
Local Integer VGOK # Variable set for GOK that will be used for both V6 and SOA code
Local Char CLASS_REFNUM(GLONEML)
Local Char RET_ERRMESSAGE(250)
Local Integer UIDS_TO_INCLUDE(20)(1..)
Local Integer UIDS_COUNT : UIDS_COUNT=1
Local Char VSYSMSG(250)
Local Integer ORG_UID, L_AMLMSG, L_AML

L_AML = 11691 # Local menu used for all GLM messages
L_AMLMSG = 32 # Local menu number to be saved as standard for all transactions #Request validated

IS_SOA = 0
CLASS_REFNUM  = [F:DCG]REFNUM
ORG_UID       = [F:DCG]UID
Local File EMPLOCTR [HRCTR]

#Get legislation from contract
Local File EMPLOCTR [HRCTR3]

Filter [F:HRCTR3] Where REFNUM = [F:DCG]REFNUM and CTRNUM = [F:DCG]CTRNUM #GESDCG does not save CTRDAT yet, only need LEG here
Read [F:HRCTR3] First
Filter [F:HRCTR3]
If fstat = [V]CST_AOK
  GCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:DCG]REFNUM,[F:DCG]CTRNUM,[F:DCG]CTRDAT,1)
Else
  #AERROR
  #TODO:
Endif
Return

$SET_RETURN_MSG
If SOA_GOK = 1
  #Handle error - stop transaction
  ASTATUS = fmet this.ASETERROR("",RET_ERRMESSAGE,[V]CST_AERROR)
Else
  If SOA_GOK <> 0
   #Test the SOA_GOK number and set the local menu variables
   L_AML = 11691 # Local menu used for all GLM messages - This can be extended in the future to pass the LM back from the function
   L_AMLMSG = SOA_GOK # Local menu number to be saved as standard for all transactions #Request validated
   #Reset SOA_GOK to 0
   SOA_GOK = 0
  Endif
Endif
Return


#FRLAA X3-91927 2018-08-08 - START
$HANDLE_DCGSTA
If clalev([F:DCG6])    = 0 : Local File DEMCONGE     [DCG6]     : Endif
Local Integer NEGUID

#Create negative UID's when a transaction STA = 4 Rejected or 6 Cancellation accepted
If [F:DCG]STA = 4 or [F:DCG]STA = 6
  [L]NEGUID = [F:DCG]UID*-1
  Read [DCG6]DCG3 = [F:DCG]REFNUM;[L]NEGUID
  If fstat #Already managed
    Raz [F:DCG6]
    [F:DCG6] = [F:DCG]
    If [F:DCG6]UID>0
      [F:DCG6]UID*=-1
      [F:DCG6]WRK = "X"
      [F:DCG6]CHRONO =num$(-adxuid(2))
      Write [F:DCG6]
      If fstat
        [V]GOK=0
        Call FSTA("DCG6") From GLOCK
        Return
      Endif
    Endif
  Endif
Endif



Return
#FRLAA X3-91927 2018-08-08 - END

#FRLAA X3-82396 2018-03-14 - END

