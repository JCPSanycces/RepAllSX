# Gestão da máscara KCO
$ACTION

Case ACTION
 When "LIENS" : Gosub LIENS
 When "HINT" : Gosub HINTA
 When Default
Endcase
Return

$HINTA
HINTLIS(0)="KCO0"
Return
#########################################################
$LIENS
[M]NBLIG=0
For I=0 To 98
 [M]PANO(I)=[F:KCO]PANO(I)
 [M]COEF(I)=[F:KCO]COEF(I)
 NBLIG+=1
Next I
Return
################################################################3

######################################################################################
## Etiqueta acrescentada p/supervisor (ecrã KCO) 05-04-2006 16:36:44 (ADMIN)
######################################################################################
Subprog AM_DECRETO(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1

If GREP<>"C" : End : Endif
For I=0 To 98
 If I=0
   [M]PANO(I)=[M]ANO-1
 Else
    [M]PANO(I)=[M]PANO(I-1)-1
 Endif

 #If [M]KANO(I)=1900 : Break : Endif
 [M]NBLIG+=1
Next I

Affzo [M]3-99

End


