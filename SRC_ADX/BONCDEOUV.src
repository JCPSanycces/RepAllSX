#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# BONCDEOUV : Impression du bon de commande ouverte achats              #
# --------------------------------------------------------------------- #
# Chargement des paramètres et mise à jour de l'indicateur d'impression #
#########################################################################

$ACTION
Case ACTION
  When "CONTPRT" : Gosub CONTPRT
Endcase
Return

#########################################################################

#-----------------------------------------#
# Contrôle destination (choix imprimante) #
# --------------------------------------- #
#  Préchargement du nombre de copies      #
#  Par défaut provient des destinations   #
#-----------------------------------------#
$CONTPRT
#------ Préchargement si contexte gestion de contrats d'achat -----#
If GFONCTION="GESPOC" & clalev([M:POC0])
  If !find([M:RPT]IMPRIME,1,3,4)
  #sr 08.11 Demande 74804-uniquement s'il y a un modèle d'impression sur le tiers
    If [F:BPS]TPMCOD<>""
     [M:RPT]NBRCPY=max([M:POC0]COPNBR,1) : # Nombre de copies
    Endif
  Else
    [M:RPT]NBRCPY=0 : # pas de copie pour prévisu, message, fichier
    Grizo [M:RPT]NBRCPY : Affzo [M:RPT]NBRCPY #Fq73266
  Endif
Endif
#-----
Return

#########################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
#-----
Call EXEC(NBPAR,PARAMETRE)
#-----
End

#########################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
# -- BONCDEOUV2
Local Date    DATREF
#-----
Gosub OUVRE   : # Ouverture des tables
If GERREUR  GERREUR=0 : End : Endif
#-----
Gosub DECLARE : # Déclaration des varibales globales
#-----
[L]CRITERE = "1=1"
# -- BONCDEOUV2
[L]CRITERE2 = "1=1"


For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"           : [L]ETAT     = [L]VALEUR
      When "__REQUETE"       : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"         : [L]CRITERE -= "& POHFCY>='"+[L]VALEUR+"'"
      When "sitefin"         : [L]CRITERE -= "& POHFCY<='"+[L]VALEUR+"'"
      When "signedeb"        : [L]CRITERE -= "& APPFLG>="+num$([L]VALEUR)
      When "signefin"        : [L]CRITERE -= "& APPFLG<="+num$([L]VALEUR)
      When "fournisseurdeb"  : [L]CRITERE -= "& BPSNUM>='"+[L]VALEUR+"'"
      When "fournisseurfin"  : [L]CRITERE -= "& BPSNUM<='"+[L]VALEUR+"'"
      When "commandedeb"     : [L]CRITERE -= "& POHNUM>='"+[L]VALEUR+"'"
      When "commandefin"     : [L]CRITERE -= "& POHNUM<='"+[L]VALEUR+"'"
      When "codimp"          : [L]CRITERE -= "& PRNFLG="+num$([L]VALEUR)
                               [L]IMPR     = val([L]VALEUR)

# -- BONCDEOUV2
      When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                             val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                               [L]CRITERE2 -= "& ORDDAT >=["+format$(GFMD,[L]DATREF)+']'
      When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                             val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                               [L]CRITERE2 -= "& ORDDAT <=["+format$(GFMD,[L]DATREF)+']'
      When "devdeb"          : [L]CRITERE2 -= "& CUR>='"+[L]VALEUR+"'"
      When "devfin"          : [L]CRITERE2 -= "& CUR<='"+[L]VALEUR+"'"
      When "avenantdeb"      : [L]CRITERE2 -= "& REVNUM>="+num$([L]VALEUR)
      When "avenantfin"      : [L]CRITERE2 -= "& REVNUM<="+num$([L]VALEUR)

      When "comsolddeb"      : [L]CRITERE2 -= "& CLEFLG >="+num$(val([L]VALEUR)+1)
      When "comsoldfin"      : [L]CRITERE2 -= "& CLEFLG <="+num$(val([L]VALEUR)+1)
      When "etatlivdeb"      : [L]CRITERE2 -= "& RCPFLG >="+num$([L]VALEUR)
      When "etatlivfin"      : [L]CRITERE2 -= "& RCPFLG <="+num$([L]VALEUR)
      When "etatfacdeb"      : [L]CRITERE2 -= "& INVFLG >="+num$([L]VALEUR)
      When "etatfacfin"      : [L]CRITERE2 -= "& INVFLG <="+num$([L]VALEUR)

      When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
      When "euro"            : [L]PARAMETRE(I) = "euro="+GEURO
      When "_PrinterCopies" : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"
    Endcase
  Endif
Next
#-----
[L]CRITERE -= "& POHTYP=2"
# Issue 89114 - 2013-04-04 by SR : etat enchaine
Look [ARM]ARM0 = [L]NUMREQ;GUSER;[F:ARP]RPTCOD;1
If !fstat
  # Enreg trouvé, car lancement enchainé
  # On bloque la boucle
  End
  #On laisse GOK=1 sinon l'état ne sort pas
Endif

Filter [POH] Where evalue([L]CRITERE) & evalue([L]CRITERE2)
Gosub TRT_POH
End

#########################################################################

$TRT_POH
Raz WNUMLIG, WNUMCOP
Default File [POH]
For [POH] POH0
   Call DEBTRANS From GLOCK
  If [L]IMPR=1
    Gosub TR1
  Else
    Gosub TR2
  Endif
Next
Return

#########################################################################

$TR1
Trbegin [POH] , [ARM], [TPRPT]
#----- Mise à jour table entête commande si demande d'impression -----#
If [L]IMPR = 1
 Readlock [POH] POH0 Curr
 If fstat = 1 : GOK = -1 : GLOCK = "$PORDER" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("POH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:POH]PRNFLG = 2
 Rewrite [POH]
 If fstat=1
  GOK=-1 : GLOCK="$PORDER"-[F:POH]POHNUM
  Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("PORDER",[F:POH]POHNUM) From GLOCK : Goto AB_TR1
 Endif
Endif
#----- Création de l'enregistrement dans la table AREPORTM -----#
WNUMLIG += 1
Raz WNUMCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
Raz [F:ARM]
 WNUMCOP      += 1
 [F:ARM]USR    = GUSER
 [F:ARM]RPTCOD = [F:ARP]RPTCOD
 [F:ARM]NUMREQ = [L]NUMREQ
 [F:ARM]NUMLIG = WNUMLIG
 [F:ARM]NUMCOP = WNUMCOP
 [F:ARM]CLEA1  = [F:POH]POHNUM
 [F:ARM]CREDAT = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
Next INBCOP
If !GOK : Goto AB_TR1 : Endif

#Raz [F:ARM]
#[F:ARM]USR    = GUSER
#[F:ARM]RPTCOD = [F:ARP]RPTCOD
#[F:ARM]NUMREQ = [L]NUMREQ
#[F:ARM]NUMLIG = WNUMLIG
#[F:ARM]CLEA1  = [F:POH]POHNUM
#[F:ARM]CREDAT = date$
#Write [F:ARM]
#If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
#-----

# Issue 110704
# Issue 110704 - 2015-12-22 by RICAR : Updating the parameters
If [L]CKPO = 1
 Gosub ALIM_TMPPRPT
 If GOK = 0 : Goto AB_TR1 : Endif
Endif
# End issue 110704

Commit
Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#########################################################################

$TR2
Trbegin [ARM], [TPRPT]
#----- Création d'un enregistrement dans la table AREPORTM -----#
WNUMLIG += 1
Raz [F:ARM]
Raz WNUMCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
Raz [F:ARM]
 WNUMCOP      += 1
 [F:ARM]USR    = GUSER
 [F:ARM]RPTCOD = [F:ARP]RPTCOD
 [F:ARM]NUMREQ = [L]NUMREQ
 [F:ARM]NUMLIG = WNUMLIG
 [F:ARM]NUMCOP = WNUMCOP
 [F:ARM]CLEA1  = [F:POH]POHNUM
 [F:ARM]CREDAT = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
Next INBCOP
If !GOK : Goto AB_TR2 : Endif

#[F:ARM]USR    = GUSER
#[F:ARM]RPTCOD = [F:ARP]RPTCOD
#[F:ARM]NUMREQ = [L]NUMREQ
#[F:ARM]NUMLIG = WNUMLIG
#[F:ARM]CLEA1  = [F:POH]POHNUM
#[F:ARM]CREDAT = date$
#Write [F:ARM]
#If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
#-----

# Issue 110704
# Issue 110704 - 2015-12-22 by RICAR : Updating the parameters
If [L]CKPO = 1
 Gosub ALIM_TMPPRPT
 If GOK = 0 : Goto AB_TR2 : Endif
Endif
# End issue 110704

Commit
Return

$ROLL_TR2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

#########################################################################

$OUVRE
Local File PORDER [POH], AREPORTM [ARM]
# Issue 110704 - 2015-12-22 by RICAR : Opening table
Local File TMPPRPT    [TPRPT]

Local Integer CKPO : [L]CKPO = 0

Return

$DECLARE
Local Char    CRITERE(255), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local Integer WNUMLIG, WNUMCOP, NUMREQ, IMPR, I, J

If func AFNC.ACTIV("KPO")
  [L]CKPO = 1
Endif

Return
#########################################################################
$ALIM_TMPPRPT

Raz [F:TPRPT]

[F:TPRPT] = [F:ARM]
[F:TPRPT]VCRNUM = [F:POH]POHNUM

Write [F:TPRPT]
If fstat : GOK=0 : Call FSTA("TPRPT") From GLOCK : Endif

Return

