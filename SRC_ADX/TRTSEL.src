#<AdxTL>@(#)0.0.0.0 $Revision$
#
# CBO   05.07.2017 X3-43918 No list of CCE/GAC in GESCCE/GESGAC when partial data is written on the key and tabulate
#
#########################################################################
#                                                                       #
#      TRAITEMENTS de SELECTIONS                                        #
#                                                                       #
#########################################################################
# ACTIONS :                                                             #
#                                                                       #
# ITMCHOICE : Sélection auto article (Référence, Désignation, EAN Code) #
# ITPCHOICE : Sélection auto article (Référence, Désignation, EAN Code) #
#             avec prise ne compte article fournisseur                  #
# ITVCHOICE : Sél auto article vente (Référence, Désignation, EAN Code) #
#             avec prise ne compte article client                       #
# BPCCHOICE : Sélection auto client  (Code, Raison sociale)             #
# BPSCHOICE : Sélection auto fournisseur  (Code, Raison sociale)        #
# BPRCHOICE : Selection automatique tiers ( Code, Raison sociale)       #
# CCECHOICE : Selection automatique section ana ( Code, Intitulé)       #
#########################################################################
$ACTION
Case ACTION
 When "CHX_TABLE"     : Gosub CHX_TABLE
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return

#########################################################################
$CHX_TABLE
Case TABLE
  When "ITMCHOICE", "ITVCHOICE", "ITPCHOICE", "BPCCHOICE", "BPSCHOICE", "BPRCHOICE", "CCECHOICE", "GACCHOICE"  ##YYFIN_X3_6922
    If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")="2"
      CRITCAR = "1=1"  # to clear from set in GACTION
    Endif
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES                                              #
#########################################################################
$SEL_TABLE
Case TABLE
    When "ITMCHOICE" : Gosub S_ITM
    When "ITVCHOICE" : Gosub S_ITV
    When "ITPCHOICE" : Gosub S_ITP
    When "BPCCHOICE" : Gosub S_BPC
    When "BPSCHOICE" : Gosub S_BPS
    When "BPRCHOICE" : Gosub S_BPR
    When "CCECHOICE" : Gosub S_CCE
    When "GACCHOICE" : Gosub S_GAC ##YYFIN_X3_6922
Endcase
Return

#########################################################################
# $S_ITM : Sélection automatique article
#########################################################################
$S_ITM

If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif
If VALEUR="" : OK=0 : Return : Endif

If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif

#Local Char    UPVAL : UPVAL = toupper(VALEUR)                       # FGR 19/08/2015 : X3SUIVI108427
Local Char    UPVAL(type(VALEUR)-10) : UPVAL = toupper(VALEUR)       # FGR 19/08/2015 : X3SUIVI108427
Local Integer NBREC

Read [ITM]ITM0=UPVAL
If !fstat
  OK=0 : Return
Else
  Filter [ITM] Where EANCOD=UPVAL
  Read [ITM] First
  If !fstat
    VALEUR=[F:ITM]ITMREF
    OK=0 : Filter [ITM] : Return
  Endif
  Filter [ITM]
Endif

ORDRE   = 'ITMREF'
START   = 'ITMREF'
OBJET   = 'ITM'

#--- X3-38621 : ajout de '<>0' dans le 'pat'
CRITERE  = '((left$([F:ITM]ITMREF,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
CRITERE -= '| (pat(toupper([F:ITM]ITMDES1),"*'+UPVAL+'*")<>0)'
CRITERE -= '| (toupper([F:ITM]EANCOD)="'+UPVAL+'"))'

#--- Issue X3-38279
#                                    # hcb X3-109862   déplacement du PE
#GPOINT = "ITM_CRIT"
#Gosub ENTREE From EXEFNC
#---

Local Clbfile SQL_REQ(1)
SQL_REQ  = "select count(*) From ITMMASTER ITM"
Append SQL_REQ," Where ("+func FUZZIFY("ITM.ITMREF_0",VALEUR,2)
Append SQL_REQ," or"-func FUZZIFY("upper(ITM.ITMDES1_0)",VALEUR,3)
Append SQL_REQ," or"-func FUZZIFY("ITM.EANCOD_0",VALEUR,0)+")"

#                                    # hcb X3-109862   déplacement du PE
GPOINT = "ITM_CRIT"
Gosub ENTREE From EXEFNC
#---

For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
  NBREC = RES
Next

If NBREC<2            # Either 0 or 1 matches
  If NBREC=1          # If only 1 match, autoselect it
    Filter [ITM] Where evalue(CRITERE)
    Read [ITM] First
    If fstat>0 : Raz [ITM] : Endif # Issue X3-48042 - 2017-10-10 by CPO : Dysfonctionnement saisie article non renouvelé en gestion commande de vente
    VALEUR = [F:ITM]ITMREF
    Filter [ITM]
  Endif
  OK=0 : Return
Endif

Return

#########################################################################
# $S_ITV : Sélection automatique article vente
#########################################################################
$S_ITV

If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif
If VALEUR="" : OK=0 : Return : Endif

If clalev([F:ITS])=0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITU])=0 : Local File ITMBPC    [ITU] : Endif

#Local Char    UPVAL : UPVAL = toupper(VALEUR)                       # FGR 19/08/2015 : X3SUIVI108427
Local Char    UPVAL(type(VALEUR)-10) : UPVAL = toupper(VALEUR)       # FGR 19/08/2015 : X3SUIVI108427
Local Integer NBREC

If PARAM(2)<>""
   Read [ITU]ITU1 = PARAM(2);UPVAL
   If !fstat
      VALEUR=[F:ITU]ITMREF : OK=0 : Return
   Endif
Endif

Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]
Default File [KITS]

Read [KITS]ITS0=UPVAL
If !fstat
  OK=0 : Return
Else
  Filter [KITS] Where [F:ITM]EANCOD=UPVAL
  Read [KITS] First
  If !fstat
    VALEUR=[F:ITM]ITMREF
    OK=0 : Filter [KITS] : Return
  Endif
  Filter [KITS]
Endif

ORDRE   = 'ITMREF'
START   = 'ITMREF'
OBJET   = 'ITS'

#--- X3-38621 : ajout de '<>0' dans le 'pat'
CRITERE  = '((left$([F:ITM]ITMREF,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
CRITERE -= '| (pat(toupper([F:ITM]ITMDES1),"*'+UPVAL+'*")<>0)'
CRITERE -= '| (toupper([F:ITM]EANCOD)="'+UPVAL+'"))'
CRITERE -='& [F:ITM]ITMSTA=1'                                        # FGR 19/08/2015 : X3SUIVI108427

Local Clbfile SQL_REQ(1)
SQL_REQ  = "select count(*) From ITMMASTER ITM, ITMSALES ITS"
Append SQL_REQ," Where ITM.ITMREF_0=ITS.ITMREF_0"
Append SQL_REQ," and ("+func FUZZIFY("ITM.ITMREF_0",VALEUR,2)
Append SQL_REQ," or"-func FUZZIFY("upper(ITM.ITMDES1_0)",VALEUR,3)
Append SQL_REQ," or"-func FUZZIFY("ITM.EANCOD_0",VALEUR,0)+")"

## X3-98913 entry point TRTSEL - Automatic selection (LCC 03/07/18)
GPOINT = "ITV_CRIT": Gosub ENTREE From EXEFNC
## X3-98913 entry point TRTSEL - Automatic selection (LCC 03/07/18)

For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
  NBREC = RES
Next

If NBREC<2            # Either 0 or 1 matches
  If NBREC=1          # If only 1 match, autoselect it
    Filter [KITS] Where evalue(CRITERE)
    Read [KITS] First
    If fstat>0 : Raz [KITS] : Endif # Issue X3-48042 - 2017-10-10 by CPO : Dysfonctionnement saisie article non renouvelé en gestion commande de vente
    VALEUR = [KITS]ITMREF
    Filter [KITS]
  Endif
  OK=0 : Return
Endif

Return

#########################################################################
# $S_ITP : Sélection automatique article (pour achats)
#########################################################################
$S_ITP

If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif
If VALEUR="" : OK=0 : Return : Endif

If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS    [ITP] : Endif

#Local Char    UPVAL : UPVAL = toupper(VALEUR)                       # FGR 19/08/2015 : X3SUIVI108427
Local Char    UPVAL(type(VALEUR)-10) : UPVAL = toupper(VALEUR)       # FGR 19/08/2015 : X3SUIVI108427
Local Integer NBREC

If PARAM(2)<>""
  Read [ITP]ITP2 = PARAM(2);UPVAL
  If !fstat
    VALEUR=[F:ITP]ITMREF : OK=0 : Return
  Else
    Filter [ITP] Where BPSNUM=PARAM(2) & EANCODBPS=UPVAL Order By Key ITP2
    Read [ITP] First
    If !fstat
      VALEUR=[F:ITP]ITMREF
      OK=0 : Filter [ITP] : Return
    Endif
    Filter [ITP]
  Endif
Endif

Read [ITM]ITM0=UPVAL
If !fstat
  OK=0 : Return
Else
  Filter [ITM] Where EANCOD=UPVAL
  Read [ITM] First
  If !fstat
    VALEUR=[F:ITM]ITMREF
    OK=0 : Filter [ITM] : Return
  Endif
  Filter [ITM]
Endif

ORDRE   = 'ITMREF'
START   = 'ITMREF'
OBJET   = 'ITM'

#--- X3-38621 : ajout de '<>0' dans le 'pat'
CRITERE  = '((left$([F:ITM]ITMREF,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
CRITERE -= '| (pat(toupper([F:ITM]ITMDES1),"*'+UPVAL+'*")<>0)'
CRITERE -= '| (toupper([F:ITM]EANCOD)="'+UPVAL+'"))'

Local Clbfile SQL_REQ(1)
SQL_REQ  = "select count(*) From ITMMASTER ITM"
Append SQL_REQ," Where ("+func FUZZIFY("ITM.ITMREF_0",VALEUR,2)
Append SQL_REQ," or"-func FUZZIFY("upper(ITM.ITMDES1_0)",VALEUR,3)
Append SQL_REQ," or"-func FUZZIFY("ITM.EANCOD_0",VALEUR,0)+")"
#
GPOINT = "ITP_CRIT": Gosub ENTREE From EXEFNC                  # hcb X3-109862

For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
  NBREC = RES
Next

If NBREC<2            # Either 0 or 1 matches
  If NBREC=1          # If only 1 match, autoselect it
    Filter [ITM] Where evalue(CRITERE)
    Read [ITM] First
    If fstat>0 : Raz [ITM] : Endif # Issue X3-48042 - 2017-10-10 by CPO : Dysfonctionnement saisie article non renouvelé en gestion commande de vente
    VALEUR = [F:ITM]ITMREF
    Filter [ITM]
  Endif
  OK=0 : Return
Endif

Return

