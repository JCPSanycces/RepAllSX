#########################################################################
# $S_CCE : Automatic selection for dimensions
#########################################################################
$S_CCE

If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif

# Issue X3-43918
# No list in creation or dupli. in GESCCE function
If GFONCTION = "GESCCE"
  Return
Endif
## End Issue X3-43918

# Issue X3-43918
# No list in creation
#If dim(GREP) >= 0
#  If GREP = "C"
#    OK = 0
#    Return
#  Endif
#Endif
## End Issue X3-43918
#Return # Issue X3-43918 test 2

If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif

Local Char    DIEAZC(GLONDIE)        # Current Dimension type
Local Char    UPVAL(type(VALEUR)-10) : UPVAL = toupper(VALEUR)
Local Integer NBREC
#
If UPVAL= "" : Return : Endif
[L]DIEAZC = PARAM(1)

Read [CCE]CCE0 =[L]DIEAZC;UPVAL
If !fstat : OK=0 : Return : Endif

START  = "[F:CCE]CCE"
ORDRE  = "[F:CCE]DIE;[F:CCE]CCE"
OBJET   = "CCE"
#
# The criteria are :
# Dimension active
# Dimension type = current dimension type
# Dimension records contains the characters that have been entered in the fields CCE or DES
#
#--- X3-38621 : ajout de '<>0' dans le 'pat'
CRITERE  = "[F:CCE]ENAFLG=2"
CRITERE -= "& [F:CCE]DIE='"+[L]DIEAZC+"'"
CRITERE -= '&((left$([F:CCE]CCE,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
CRITERE -= '| (pat(toupper([F:CCE]DES),"*'+UPVAL+'*")<>0))'

Local Clbfile SQL_REQ(1)
SQL_REQ  = "select count(*) From CACCE CCE"
Append SQL_REQ," Where (CCE.DIE_0='"+[L]DIEAZC+"'"+")"
Append SQL_REQ,"  and ("+func FUZZIFY("CCE.CCE_0",VALEUR,2)
Append SQL_REQ,"     or"-func FUZZIFY("upper(CCE.DES_0)",VALEUR,3)+")"

For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
  NBREC = RES
Next

If NBREC<2            # Either 0 or 1 matches
  If NBREC=1          # If only 1 match, autoselect it
    Filter [CCE] Where evalue(CRITERE)
    Read [CCE] First
    VALEUR = [F:CCE]CCE
    Filter [CCE]
  Endif
  OK=0 : Return
Endif

Return


##YYFIN_X3_6922
#########################################################################
# $S_GAC : Sélection automatique compte
#########################################################################
$S_GAC

If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif
If VALEUR="" : OK=0 : Return : Endif

# Issue X3-43918
# No list in creation or dupli. in GESGAC function
If GFONCTION = "GESGAC"
  Return
Endif
## End Issue X3-43918

If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    UPVAL(type(VALEUR)-10)
Local Char    COAVAL(GLONCOA)
Local Integer NBREC

UPVAL  = ctrans(toupper(VALEUR))
COAVAL = PARAM(1)

Read [GAC]GAC0=COAVAL;UPVAL
If !fstat : OK=0 : Return : Endif

Read [GAC]GAC1=COAVAL;UPVAL
If !fstat : OK=0 : Return : Endif

ORDRE   = 'COA;ACC'
START   = 'ACC'
OBJET   = 'GAC'

#--- X3-38621 : ajout de '<>0' dans le 'pat'
CRITERE  = '[F:GAC]COA="'+COAVAL+'"'
CRITERE -= '& ((left$([F:GAC]ACC,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
CRITERE -= '| (pat(vireblc(ctrans(toupper([F:AXX]TEXTE)),4),"*'+UPVAL+'*")<>0))'
CRITERE -='& [F:GAC]ENAFLG=2'

Link [GAC] With [AXX]AXX0 ="GACCOUNT";"DESTRA";GLANGUE;[F:GAC]COA;[F:GAC]ACC
& As [LNC]
& Where evalue(CRITERE)

For [LNC]
 NBREC +=1
 If NBREC>=2 : Break : Endif
Next

If NBREC<2           # Either 0 or 1 matches
 If NBREC=1          # If only 1 match, autoselect it
  Read [LNC] First
  VALEUR = [F:GAC]ACC
 Endif
 OK=0 : Return
Endif

Return

## End YYFIN_X3_6922

########################################################
####################################################################################
# COLUMN = column name
# COLVAL = input value
# FUZZY  = whether or not to do a fuzzy search
#   0 - no fuzzy search (Customer #)
#   1 - fuzzy left only (not currently used)
#   2 - fuzzy right only (State and ZIP)
#   3 - fuzzy on both sides
######################################################################################
Funprog FUZZIFY(COLUMN,COLVAL,FUZZY)
Value    Char    COLUMN
Value    Char    COLVAL
Value    Integer FUZZY

Local Char STR(250)
STR = COLUMN - "like upper('"
If find(FUZZY,1,3) : STR += "%" : Endif
STR += func ENCODE_STR(COLVAL)
If find(FUZZY,2,3) : STR += "%" : Endif
STR += "')"

End STR

####################################################################################
# Replaces quote characters (') with two quote characters so that the
# string may be used in a query as a literal
####################################################################################
Funprog ENCODE_STR(STR)
Value Char STR

Local Char RES(250)

STR = vireblc(STR,5)         # remove consecutive spaces

For J=1 To len(STR)
    If mid$(STR,J,1)="'"
        RES += "''"
    Elsif mid$(STR,J,1)=" "  # replace space
        RES += "%"           # with wildcard
    Else
        RES += mid$(STR,J,1)
    Endif
Next

End RES


