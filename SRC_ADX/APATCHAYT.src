#<AdxTL>@(#)7.0.0.0 $Revision$
Call OUINON("Veux tu integrer une element Xtend, t'es sur ?",GBIDI1) From GESECRAN
If GBIDI1=2
 Local Char PARAM(30)(1..1) , VALEUR(250)
 Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
 End
Else
 Local Char PARAM(30)(1..1) , VALEUR(10)
 Raz GNBMASKOUV
 Call TRAITE_CHAR(VALEUR,PARAM,"","APATCH","APATCH",4,"") From GTRAITE
 End
Endif
End


######################################################################################
## Xtend: Gestion patch dictionnaire Xtendcopie d'un objet Xtend
#
#    Pour la mise à jour APATCH: voir PDF Comparaison APATCH (Xtend_Superv).pdf
#
#    Type spécifiques à XTend:
#        ELX: Gestion tar Xtend
#        AY : Patch complet paramétrage d'un site Xtend
#
######################################################################################
$ACTION
Case ACTION
 When "TRT_DIV"        : Gosub TRT_DIV
 When "CREINI"         : Gosub CREINI
 When "CREEXE"         : Gosub CREEXE
 When "CRELST"         : Gosub CRELST
 When "C_TYPOBJ"       : Gosub C_TYPOBJ
 When "AS_NOMOBJ"      : Gosub AS_NOMOBJ
 When "INTINI"         : Gosub INTINI
 When "INTEXE"         : Gosub INTEXE
 When "INTEND"         : Gosub INTEND
 When "C_NOMOBJ"       : Gosub C_NOMOBJ
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
##     AYTPATCHS     PATCHSEL   Sélection fiche de paramétrage Xtend
#         Ecran APATCH - bouton 6 (paramètre: OBJET=[M]TYPOBJ(nolign-1))
######################################################################################
#------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "PATCHSEL"
   #
   Local Char XTDCOD(GDIMFIC), FCYCOD(GLONAYS)
   XTDCOD=VALEUR
   WI = instr(1,VALEUR,"~")
   If WI : XTDCOD=right$(VALEUR,WI+1) : GAYTFCYWRK=left$(VALEUR,WI-1) : Endif

   # PARAM(1) = code "AYA", "AYS", "ELX"....
   Case PARAM(1)
   When "AYS","AY"
       # Site Xtend
       Call SELFCYCOD() :  If dim(GAYTFCYWRK)<0 | GAYTFCYWRK="" : OK=0 : Endif
       VALEUR=GAYTFCYWRK : mkstat=99

   When Default
       # Site Xtend
       Call SELFCYCOD()
       If dim(GAYTFCYWRK)<0 | GAYTFCYWRK=""
             OK=0
       Else
           Call SELXTDCOD(GAYTFCYWRK,PARAM(1),XTDCOD)
           If XTDCOD<>""
                VALEUR=XTDCOD : mkstat=99
           Else
                VALEUR=""
           Endif
       Endif
   Endcase
Endcase
Return

######################################################################################
##  Gosub pour création de patch (Pour traitement APATCH Ecran APATCH)
#              -----------------
#    CRELST          Ajout entrée dans la liste pour création de patch
#    C_NOMOBJ        Ctl du champ NOMOBJ
#    C_TYPOBJ        Ctl du champ TYPOBJ
#    CREINI          Initialisation pour ajout au patch
#    CREEXE          Ajout au patch d'un élément du dictionnaire Xtend
#
##  Gosub pour intégration de patch (Pour traitement PATCH)
#              --------------------
#    INTINI          Intégration patch:  Initialisation
#    INTEXE          Intégration patch:  Intégration d'un élément au dictionnaire Xtend
#    INTEND          Intégration patch:  Fin
#
##  Subprog
#    SELFCYCOD       Sélection site
#    SELXTDCOD       Sélection élément de paramétrage d'un site
#
######################################################################################

#    Ecran APATCH - Controle TYPOBJ
# $$$
######################################################################################
$C_TYPOBJ
If !func CODACT_OK([M]DOSSIER,"AYT")
      GMESSAGE = mess(42,115,1) : mkstat = 2 : End : # Type d'objet incorrect
Endif

If VALEUR="ELX"
    # Site Xtend
    Call SELFCYCOD() :
    If dim(GAYTFCYWRK)<0 | GAYTFCYWRK=""
        GMESSAGE=mess(6,7900,1)
        mkstat=2
    Else
        Local Char REPERT(GDIMFIC),REPERTPUB(GDIMFIC), EXT1(10)
        Local Integer W_I
        REPERT = nomap+"/X_TEND/X_TAR/" : EXT1 = "tar"
        #FIC = ctrans(NOMOBJ,"/\",SEP+SEP)  # filpath fait la conversion /\
        REPERTPUB=filpath("","","","X3_PUB")
        [M]NOMOBJ(nolign-1) = right$(filpath(REPERT ,GAYTFCYWRK,EXT1,"X3_PUB"), len(REPERTPUB)+2)
    Endif
Endif
Return

#    Ecran APATCH - Avant saisie du champ NOMOBJ
# $$$
######################################################################################
$AS_NOMOBJ
If TYPOBJ(nolign-1)="ELX"
        mkstat=2
Endif
Return

#    Ecran APATCH - Ctl du champ NOMOBJ
# $$$
######################################################################################
$C_NOMOBJ
VALEUR = vireblc(VALEUR,2)
Local Char     WX_RUBDES(20)
Local Integer  WX_NUMDES
Local Integer  WX_I, WX_J
Local Char     WX_FCYCOD(GLONAYS), WX_OBJCOD(GLONAY9)
Local Char     WX_OBJTYP(GLONAOB)
Case OBJTYP
 When "AYA"
  Local File =[M]DOSSIER+".AYTACT"  [AYA]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYB"
  Local File =[M]DOSSIER+".AYTELTBLC"  [AYB]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYC"
  Local File =[M]DOSSIER+".AYTMEN"     [AYC]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYW"
  Local File =[M]DOSSIER+".AYTELTBLCW"  [AYW]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYL"
  Local File =[M]DOSSIER+".AYTELTDLK"  [AYL]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYF"
  Local File =[M]DOSSIER+".AYTELTFLD"  [AYF]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYE"
  Local File =[M]DOSSIER+".AYTENT"  [AYE]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYS","AY"
  Local File =[M]DOSSIER+".AYTFCY"  [AYS]
  Call CONTROLE("AYS","",VALEUR,"",mkstat) From CONTOBJ
  If !fstat : Call LECTEXTRA(INTIT,"AYTFCY","INTIT",[F:AYS]FCYCOD,"") From ATEXTRA : Endif
 When "AYI"
  Local File =[M]DOSSIER+".AYTINT"  [AYI]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYM"
  Local File =[M]DOSSIER+".AYTMES"  [AYM]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYG"
  Local File =[M]DOSSIER+".AYTPAG"  [AYG]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYD"
  Local File =[M]DOSSIER+".AYTPRF"  [AYD]
  WX_RUBDES="" : Gosub C_NOMOBJTILD
 When "AYU"
  Local File =[M]DOSSIER+".AYTADVPAR"  [AYU]     # Clé site~codetyp~code
  WX_I = instr(1,VALEUR,"~")
  WX_J = instr(WX_I+1,VALEUR,"~")
  If (WX_I=0 or WX_J=0)
    GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1
  Else
      WX_FCYCOD= left$(VALEUR,WX_I-1)
      WX_OBJTYP=  seg$(VALEUR,WX_I+1,WX_J-1)
      WX_OBJCOD=right$(VALEUR,WX_J+1)
      mkstat=0
      Read [F:AYU]AYU0(3)=WX_FCYCOD;val(WX_OBJTYP);WX_OBJCOD
      If fstat : GMESSAGE=mess(177,7900,1) : mkstat=1 : Endif
  Endif
 When "ELX"
Endcase
Return

$C_NOMOBJTILD
  WX_I = instr(1,VALEUR,"~") # Clé site~code
  If WX_I = 0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : Return : Endif :# Valeur
  Call CONTROLE(OBJTYP,"",right$(VALEUR,WX_I+1),left$(VALEUR,WX_I-1),mkstat) From CONTOBJ
  Case OBJTYP
   When "AYC" :
    Call LECTEXTRA(INTIT,"AYTMEN","INTIT",[F:AYC]FCYCOD,[F:AYC]MENCOD) From ATEXTRA
   When "AYM" :
    Call LECTEXTRA(INTIT,"AYTMES","INTIT",[F:AYM]FCYCOD,[F:AYM]MESCOD) From ATEXTRA
   When "AYA" :
    Call LECTEXTRA(INTIT,"AYTACT","INTIT",[F:AYA]FCYCOD,[F:AYA]ACTCOD) From ATEXTRA
   When "AYE" :
    Call LECTEXTRA(INTIT,"AYTENT","INTIT",[F:AYE]FCYCOD,[F:AYE]ENTCOD) From ATEXTRA
   When "AYI" :
    Call LECTEXTRA(INTIT,"AYTINT","INTIT",[F:AYI]FCYCOD,[F:AYI]INTCOD) From ATEXTRA
   When "AYL" :
    Call LECTEXTRA(INTIT,"AYTELTDLK","INTIT",[F:AYL]FCYCOD,[F:AYL]DLKCOD) From ATEXTRA
   When "AYW" :
    Call LECTEXTRA(INTIT,"AYTELTBLCW","INTIT",[F:AYW]FCYCOD,[F:AYW]BLCWHNCOD) From ATEXTRA
   When "AYB" :
    Call LECTEXTRA(INTIT,"AYTELTBLC","INTIT",[F:AYB]FCYCOD,[F:AYB]BLCCOD) From ATEXTRA
   When "AYD" :
    Call LECTEXTRA(INTIT,"AYTPRF","INTIT",[F:AYD]FCYCOD,[F:AYD]PRFCOD) From ATEXTRA
   When "AYG" :
    Call LECTEXTRA(INTIT,"AYTELTFLD","INTIT",[F:AYG]FCYCOD,[F:AYG]PAGCOD) From ATEXTRA
   When "AYF" :
    Call LECTEXTRA(INTIT,"AYTELTFLD","INTIT",[F:AYF]FCYCOD,[F:AYF]FIECOD) From ATEXTRA
   When "AYG" :
    Call LECTEXTRA(INTIT,"AYTFCY","INTIT",[F:AYS]FCYCOD,"") From ATEXTRA
   When Default :
    If WX_RUBDES<>""
     WX_NUMDES = evalue(WX_RUBDES)
     If !fstat : Call TEXTE(WX_NUMDES,INTIT) From OBJDIV : Endif
    Endif
  Endcase
Return

#    Ajout entrée dans la liste pour création de patch
# $$$
######################################################################################
$CRELST
If !func CODACT_OK([M]DOSSIER,"AYT") : Return : Endif
#
Local Integer WX_AYT
Local Char    WX_X3OBJ(GLONAOB)
For WX_X3OBJ="AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYI","AYM","AYU","AYC"
   NBTEX += 1 : TEX(NBTEX) = WX_X3OBJ : TEXTE(NBTEX,2) = mess(func AYTUTIA.GETMNL7910(WX_X3OBJ), 7910, 1)
Next
#
NBTEX += 1 : TEX(NBTEX) = "ELX" : TEXTE(NBTEX,2) = mess(8, 7901, 1)
NBTEX += 1 : TEX(NBTEX) = "AY"  : TEXTE(NBTEX,2) = mess(10, 7901, 1)
Return

# Initialisation pour ajout au patch
# $$$
######################################################################################
$CREINI
If !func CODACT_OK(APPLI,"AYT") : Return : Endif
#
Local Char WX_FCYCOD(GLONAYS), WX_OBJCLE(40)  # Site xtend, cle d'un paramètre (ex: 'aSession')
Local Char WX_OBJTYP                          # Clé AYU: information OBJTYP (menu 7910)
Local Char WX_STR(200)
Local Integer WX_I, WX_J, WX_NBREC
Local Integer WX_TYP  # LINCODTYP de AYTLINES
Return

# Ajout au patch d'un élément du dictionnaire Xtend
# Remarques:
#  - Ce traitement prend en charge les objets standard Xtend
#  - L'ajout du tar d'un site Xtend est fait par la procédure standard en indiquant:
#     ELT XTEND/X_TEND/X_TAR/AREF.tar   dans ce cas: XTEND=Code dossier et AREF=Code site Xtend
# $$$
######################################################################################
$CREEXE
#
If !find(TYPOBJ(I),"AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYI","AYM","ELX","AYU","AY","AYC")
    Call ERREUR(APPLI-":"-mess(1,7901,1)-TYPOBJ(WI)) From GESECRAN
    Return
Endif
#

Raz WX_FCYCOD, WX_OBJCLE, WX_OBJTYP, WX_I, WX_J
Case TYPOBJ(I)
When "AYS","AY"
    WX_FCYCOD=NOMOBJ(I)
When "ELX"
When "AYU"
    WX_I = instr(1,NOMOBJ(I),"~")
    WX_J = instr(WX_I+1,NOMOBJ(I),"~")
    If (WX_I=0 or WX_J=0)
        WX_STR=mess(func AYTUTIA.GETMNL7910(TYPOBJ(I)), 7910, 1) -"-"-mess(2,7901,1)-":"-NOMOBJ(I)
        Call ERREUR(WX_STR) From GESECRAN
        Return
    Else
        WX_FCYCOD= left$(NOMOBJ(I),WX_I-1)
        WX_OBJTYP=  seg$(NOMOBJ(I),WX_I+1,WX_J-1)
        WX_OBJCLE=right$(NOMOBJ(I),WX_J+1)
    Endif
When Default
    WX_I=instr(1,NOMOBJ(I),"~")
    If WX_I
        WX_FCYCOD = left$(NOMOBJ(I),WX_I-1) : WX_OBJCLE = right$(NOMOBJ(I),WX_I+1)
    Else
        WX_STR=mess(func AYTUTIA.GETMNL7910(TYPOBJ(I)), 7910, 1) -"-"-mess(2,7901,1)-":"-NOMOBJ(I)
        Call ERREUR(WX_STR) From GESECRAN
        Return
    Endif
Endcase
#
Case TYPOBJ(I)
When "AYA" :  Gosub CREAYA
When "AYB" :  Gosub CREAYB
When "AYC" :  Gosub CREAYC
When "AYW" :  Gosub CREAYW
When "AYL" :  Gosub CREAYL
When "AYF" :  Gosub CREAYF
When "AYL" :  Gosub CREAYL
When "AYE" :  Gosub CREAYE
When "AYS" :  Gosub CREAYS
When "AYI" :  Gosub CREAYI
When "AYM" :  Gosub CREAYM
When "AYG" :  Gosub CREAYG
When "AYD" :  Gosub CREAYD
When "AYU" :  Gosub CREAYU
When "AY"  :  Gosub CREAYSALL
When "ELX" :  Gosub WEB From APATCH2    # Idem ELT
When Default
    Call ERREUR("Type unknown"-TYPOBJ(I)-"APATCHAYT/CREEXE") From GESECRAN
Endcase
Return


#-- Paramétrage de tout un site
# - - - - - - - - - - - - - - - - - - - - - - - - - -
$CREAYSALL
Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet fictif

INTITOBJ(I)=mess(11,7901,1)
#-- Site
TYPOBJ(I)="AYS" : NOMOBJ(I)=WX_FCYCOD :
Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
Gosub CREAYS
Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet

#-- Page
Local File =[L]APPLI+".AYTPAG"  [AYG_]
For [F:AYG_]AYG0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYG_]PAGCOD :  TYPOBJ(I)="AYG"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYG
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYG_]) : Close Local File [AYG_] : Endif

#-- Profil
Local File =APPLI+".AYTPRF" [AYD_]
For [F:AYD_]AYD0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYD_]PRFCOD :  TYPOBJ(I)="AYD"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYD
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYD_]) : Close Local File [AYD_] : Endif

#-- Champs
Local File =[L]APPLI+".AYTELTFLD"  [AYF_]
For [F:AYF_]AYF0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYF_]FIECOD :  TYPOBJ(I)="AYF"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYF
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYF_]) : Close Local File [AYF_] : Endif

#-- Entité
Local File =APPLI+".AYTENT" [AYE_]
For [F:AYE_]AYE0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYE_]ENTCOD :  TYPOBJ(I)="AYE"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYE
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYE_]) : Close Local File [AYE_] : Endif

#-- Bloc
Local File =APPLI+".AYTELTBLC" [AYB_]
For [F:AYB_]AYB0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYB_]BLCCOD :  TYPOBJ(I)="AYB"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYB
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYB_]) : Close Local File [AYB_] : Endif

#-- Bloc conditionné
Local File =APPLI+".AYTELTBLCW" [AYW_]
For [F:AYW_]AYW0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYW_]BLCWHNCOD :  TYPOBJ(I)="AYW"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYW
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYW_]) : Close Local File [AYW_] : Endif

#-- Action
Local File =APPLI+".AYTACT" [AYA_]
For [F:AYA_]AYA0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYA_]ACTCOD :  TYPOBJ(I)="AYA"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYA
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYA_]) : Close Local File [AYA_] : Endif

#-- Lien dynamique
Local File =APPLI+".AYTELTDLK" [AYL_]
For [F:AYL_]AYL0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYL_]DLKCOD :  TYPOBJ(I)="AYL"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYL
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYL_]) : Close Local File [AYL_] : Endif

#-- Menu
Local File =APPLI+".AYTMEN" [AYC_]
For [F:AYC_]AYC0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYC_]MENCOD :  TYPOBJ(I)="AYC"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYC
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYA_]) : Close Local File [AYA_] : Endif

#-- Interface
Local File =APPLI+".AYTINT" [AYI_]
For [F:AYI_]AYI0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYI_]INTCOD :  TYPOBJ(I)="AYI"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYI
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYI_]) : Close Local File [AYI_] : Endif

#-- Message
Local File =APPLI+".AYTMES" [AYM_]
For [F:AYM_]AYM0 Where FCYCOD=WX_FCYCOD
    WX_OBJCLE = [F:AYM_]MESCOD :  TYPOBJ(I)="AYM"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYM
    Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
Next
If clalev([F:AYM_]) : Close Local File [AYM_] : Endif

#-- Paramètre avancé
Local File =APPLI+".AYTADVPAR" [AYU_] Where FCYCOD=WX_FCYCOD
WX_NBREC = rowcount([AYU_])        # Gestion du dernier pour fermer corectement le patch
For [F:AYU_]AYU0(3)
    WX_NBREC-=1
    WX_OBJCLE = [F:AYU_]OBJCOD : WX_OBJTYP = num$([F:AYU_]OBJTYP)  :  TYPOBJ(I)="AYU"
    NOMOBJ(I)=WX_FCYCOD+"~"+WX_OBJTYP+"~"+WX_OBJCLE
    Wrseq '2';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Ouverture objet
    Gosub CREAYU
    #If WX_NBREC>0
        Wrseq '7';'"'+TYPOBJ(I)+'"';'"'+NOMOBJ(I)+'"';'"'+INTITOBJ(I)+'"'  # Fermeture objet
    #Endif
Next
If clalev([F:AYU_]) : Close Local File [AYU_] : Endif


Return
#-- Fin Paramétrage de tout un site
# - - - - - - - - - - - - - - - - - - - - - - - - - -

#-- Site
$CREAYS
Local File =APPLI+".AYTFCY" [AYS]
Read [AYS]AYS0 = WX_FCYCOD
If fstat : Gosub CRE_ERR : Goto CREAYS_F : Endif
FICHIER = "AYTFCY" : ABR = "AYS" : IDENT = [F:AYS]FCYCOD : Gosub FICHIER From APATCH2
$CREAYS_F
Close Local File [AYS]
Return

#-- Page
$CREAYG
Local File =APPLI+".AYTPAG" [AYG]
Read [AYG]AYG0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYG_F : Endif
FICHIER = "AYTPAG" : ABR = "AYG" : IDENT = [F:AYG]FCYCOD +"~"+ [AYG]PAGCOD  : Gosub FICHIER From APATCH2
$CREAYG_F
Close Local File [AYG]
Return

#-- Profil
$CREAYD
Local File =APPLI+".AYTPRF" [AYD]
Read [AYD]AYD0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYD_F : Endif
FICHIER = "AYTPRF" : ABR = "AYD" : IDENT = [F:AYD]FCYCOD +"~"+ [AYD]PRFCOD  : Gosub FICHIER From APATCH2
$CREAYD_F
Close Local File [AYD]
Return

#-- Champs
$CREAYF
Local File =APPLI+".AYTELTFLD" [AYF]
Read [AYF]AYF0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYF_F : Endif
FICHIER = "AYTELTFLD" : ABR = "AYF" : IDENT = [F:AYF]FCYCOD +"~"+ [AYF]FIECOD  : Gosub FICHIER From APATCH2
$CREAYF_F
Close Local File [AYF]
Return

#-- Entité
$CREAYE
Local File =APPLI+".AYTENT" [AYE]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYE]AYE0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYE_F : Endif
FICHIER = "AYTENT" : ABR = "AYE" : IDENT = [F:AYE]FCYCOD +"~"+ [AYE]ENTCOD  : Gosub FICHIER From APATCH2
WX_TYP=1 : Gosub CRE_AYN
$CREAYE_F
Close Local File [AYE], [AYN]
Return

#-- Bloc
$CREAYB
Local File =APPLI+".AYTELTBLC" [AYB]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYB]AYB0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYB_F : Endif
FICHIER = "AYTELTBLC" : ABR = "AYB" : IDENT = [F:AYB]FCYCOD +"~"+ [AYB]BLCCOD  : Gosub FICHIER From APATCH2
WX_TYP=2 : Gosub CRE_AYN
$CREAYB_F
Close Local File [AYB],[AYN]
Return

#-- Bloc conditionné
$CREAYW
Local File =APPLI+".AYTELTBLCW" [AYW]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYW]AYW0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYW_F : Endif
FICHIER = "AYTELTBLCW" : ABR = "AYW" : IDENT = [F:AYW]FCYCOD +"~"+ [AYW]BLCWHNCOD  : Gosub FICHIER From APATCH2
WX_TYP=5 : Gosub CRE_AYN
$CREAYW_F
Close Local File [AYW],[AYN]
Return

#-- Action
$CREAYA
Local File =APPLI+".AYTACT" [AYA]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYA]AYA0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYA_F : Endif
FICHIER = "AYTACT" : ABR = "AYA" : IDENT = [F:AYA]FCYCOD +"~"+ [AYA]ACTCOD  : Gosub FICHIER From APATCH2
WX_TYP=3 : Gosub CRE_AYN
$CREAYA_F
Close Local File [AYA],[AYN]
Return

#-- Lien dynamique
$CREAYL
Local File =APPLI+".AYTELTDLK" [AYL]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYL]AYL0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYL_F : Endif
FICHIER = "AYTELTDLK" : ABR = "AYL" : IDENT = [F:AYL]FCYCOD +"~"+ [AYL]DLKCOD  : Gosub FICHIER From APATCH2
WX_TYP=4 : Gosub CRE_AYN
$CREAYL_F
Close Local File [AYL],[AYN]
Return

#-- Menu
$CREAYC
Local File =APPLI+".AYTMEN" [AYC]
Local File =APPLI+".AYTLINES"  [AYN]
Read [AYC]AYC0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYC_F : Endif
FICHIER = "AYTMEN" : ABR = "AYC" : IDENT = [F:AYC]FCYCOD +"~"+ [AYC]MENCOD  : Gosub FICHIER From APATCH2
WX_TYP=7 : Gosub CRE_AYN
$CREAYC_F
Close Local File [AYC],[AYN]
Return

#-- Interface
$CREAYI
If !clalev([AYI]) : Local File =APPLI+".AYTINT"       [AYI] : Endif
If !clalev([ASU]) : Local File =APPLI+".ASUBPROG"     [ASU] : Endif
If !clalev([ASP]) : Local File =APPLI+".ASUBPROGD"    [ASP] : Endif
If !clalev([AWE]) : Local File =APPLI+".AWEBSERVIC"   [AWE] : Endif
If !clalev([AWY]) : Local File =APPLI+".AWEBSERDES"   [AWY] : Endif
Read [AYI]AYI0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYI_F : Endif
FICHIER = "AYTINT" : ABR = "AYI" : IDENT = [F:AYI]FCYCOD +"~"+ [AYI]INTCOD : Gosub FICHIER From APATCH2
If [F:AYI]PRG<>"" & [F:AYI]SUBPRG<>""
 Read [F:ASU]ASU0 = [F:AYI]PRG;[F:AYI]SUBPRG
 If !fstat
  FICHIER = "ASUBPROG" : ABR = "ASU" : IDENT = [F:AYI]PRG+"~"+[F:AYI]SUBPRG : Gosub FICHIER From APATCH2
 Endif
 For [ASP]ASP0 Where PRG=[F:AYI]PRG & SUBPRG=[F:AYI]SUBPRG
  FICHIER = "ASUBPROGD" : ABR = "ASP" : IDENT = [F:AYI]PRG+"~"+[F:AYI]SUBPRG+"~"+num$([F:ASP]LIGNE) : Gosub FICHIER From APATCH2
 Next
Endif
If  [F:AYI]WEBSRCCOD <>""
 Read [AWE]AWE1 = [F:AYI]WEBSRCCOD
 If !fstat
  FICHIER = "AWEBSERVIC" : ABR = "AWE" : IDENT = [F:AWE]PUBLI : Gosub FICHIER From APATCH2
  For [AWY]AWY1 Where PUBLI = [F:AWE]PUBLI
   FICHIER = "AWEBSERDES" : ABR = "AWY" : IDENT = [F:AWY]PUBLI+[F:AWY]GRP+[F:AWY]CHP : Gosub FICHIER From APATCH2
  Next
 Endif
Endif
$CREAYI_F
Close Local File [AYI],[ASU],[AWE],[AWY],[ASP]
Return

#-- Message
$CREAYM
Local File =APPLI+".AYTMES" [AYM]
Read [AYM]AYM0 = WX_FCYCOD;WX_OBJCLE
If fstat : Gosub CRE_ERR : Goto CREAYM_F : Endif
FICHIER = "AYTMES" : ABR = "AYM" : IDENT = [F:AYM]FCYCOD +"~"+ [AYM]MESCOD  : Gosub FICHIER From APATCH2
$CREAYM_F
Close Local File [AYM]
Return

#-- Paramètre avancé
$CREAYU
Local File =APPLI+".AYTADVPAR" [AYU]
For [AYU]AYU0 Where FCYCOD=WX_FCYCOD and OBJTYP=val(WX_OBJTYP) and OBJCOD=WX_OBJCLE
 FICHIER = "$" : ABR = "AYU"
 IDENT = [F:AYU]FCYCOD +"~"+ num$([AYU]OBJTYP) +"~"+ [AYU]OBJCOD +"~"+ num$([AYU]LIN)
 Gosub FICHIER From APATCH2
Next
$CREAYU_F
Close Local File [AYU]
Return

#-- $
#$CREAY$
#Local File =APPLI+".AYT$" [AY$]
#Read [AY$]AY$0 = WX_FCYCOD;WX_OBJCLE
#If fstat : Gosub CRE_ERR : Goto CREAY$_F : Endif
#FICHIER = "$" : ABR = "AY$" : IDENT = [F:AY$]FCYCOD +"~"+ [AY$]$COD  : Gosub FICHIER From APATCH2
#$CREAY$_F
#Close Local File [AY$]
#Return

# Erreur accès
$CRE_ERR
WX_STR=mess(func AYTUTIA.GETMNL7910(TYPOBJ(I)), 7910, 1)-"-"-mess(2,7901,1)-":"-WX_FCYCOD+"~"+WX_OBJCLE
Call ERREUR(WX_STR) From GESECRAN
Return

# Routine AYN
$CRE_AYN
For [AYN]AYN0 Where FCYCOD=WX_FCYCOD & LINCODTYP=WX_TYP & LINCOD=WX_OBJCLE
 FICHIER = "AYTLINES" : ABR = "AYN"
 IDENT = [AYN]FCYCOD+"~"+num$([AYN]LINCODTYP)+"~"+[AYN]LINCOD+"~"+num$([AYN]LINTYP)+"~"+num$([AYN]LINNUM)
 Gosub FICHIER From APATCH2
Next
Return

# $CREEXE - Fin Ajout au patch d'un élément du dictionnaire Xtend
######################################################################################



#    SELFCYCOD       Sélection site
######################################################################################
Subprog SELFCYCOD()
Local Char VALEUR
Local Char SAVACT (GLONACT)
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
GACTION = "AYSCHGFCYW"
Call S_TAB_CHAR(VALEUR,PARBOUT,"CHGFCYW","SUBAYSACT","") From GACTION
GACTION=SAVACT
End

#    SELXTDCOD       Sélection élément de paramétrage d'un site
######################################################################################
Subprog SELXTDCOD(FCYCOD,OBJCOD,XTDCOD)
Value Char FCYCOD
Value Char OBJCOD        # AYA, AYB...
Variable Char    XTDCOD()
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Case OBJCOD
When "AYU"
    PARMSK(1) = FCYCOD
    SAVACT = GACTION : GACTION = "AYUSEL"
    Call S_TAB_CHAR(XTDCOD,PARMSK,"ADVSEL","SUBAYUACT","") From GACTION
    GACTION = SAVACT
When Default
    PARMSK(1) = OBJCOD
    PARMSK(2) = ""
    PARMSK(3) = FCYCOD
    Call S_TAB_CHAR(XTDCOD,PARMSK,"SELOBJ","SELOBJ","") From GACTION
    If XTDCOD<>"" : XTDCOD=FCYCOD+"~"+XTDCOD : Endif
Endcase
End

######################################################################################
#    INTINI          Intégration patch:  Initialisation
######################################################################################
$INTINI
If !func CODACT_OK(APPLI,"AYT") : Return : Endif
If filinfo(filpath("FIL","AYTFCY","fde",APPLI),0)<0  or filinfo(filpath("FIL","AYTLINES","fde",APPLI),0)<0
 Return
Endif
#
Local Char WX_STR(200)
Local Integer WX_I, WX_J, WX_K, WX_TYP, WX_NEWFCY , WOK , VERIF_REP
# Site xtend, cle d'un paramètre (ex: 'aSession')
Local Integer DIMGLONAYS :DIMGLONAYS=10
If dim(GLONAYS)<>-1 Then DIMGLONAYS=GLONAYS Endif
Local Char WX_FCYCOD(DIMGLONAYS), WX_OBJCLE(40), WX_OBJTYP, WX_OBJLIN
Local Char WX_ABR(5), WX_FICHIER(20), WX_KEYCOD(10)
# Flags pour validation
Local Integer WX_FCYNBMAX : WX_FCYNBMAX=20
Local Char    WX_LSTFCY(DIMGLONAYS)(1..WX_FCYNBMAX)
Local Integer WX_LSTFCYIND                    # Indice du site Xtend encours
Local Integer WX_LSTAYS(1..WX_FCYNBMAX), WX_LSTAYA(1..WX_FCYNBMAX), WX_LSTAYB(1..WX_FCYNBMAX)
Local Integer WX_LSTAYD(1..WX_FCYNBMAX), WX_LSTAYE(1..WX_FCYNBMAX), WX_LSTAYF(1..WX_FCYNBMAX)
Local Integer WX_LSTAYG(1..WX_FCYNBMAX), WX_LSTAYI(1..WX_FCYNBMAX), WX_LSTAYL(1..WX_FCYNBMAX)
Local Integer WX_LSTAYM(1..WX_FCYNBMAX), WX_LSTAYW(1..WX_FCYNBMAX), WX_LSTAYC(1..WX_FCYNBMAX)
Local Integer WX_LSTAYU(1..WX_FCYNBMAX), WX_LSTELT(1..WX_FCYNBMAX)

Local Char    WX_LAN(GLONLAN)(1..10)
# Accès AYN
Local Integer WX_LINCODTYP
Local Integer DIMGLONAYN :DIMGLONAYN=20
If dim(GLONAYN)<>-1 Then DIMGLONAYN=GLONAYN Endif
Local Char    WX_LINCOD(DIMGLONAYN)
# Validation site
Local Char WX_OPTION(10)(1..10)     : Local Integer WX_OPTIND
Local Char WX_LSTOBJCOD(GLONAOB)(1..20)   : Local Integer WX_LSTIND
Local Integer WX_RET
#
Local File =APPLI+".AYTFCY"    [AYS] Order By Key AYS0
Local File =APPLI+".AYTLINES"  [AYN] Order By Key AYN0

Return

#########################################################################################
#    INTEXE          Intégration patch:  Intégration d'un élément au dictionnaire Xtend
#########################################################################################
$INTEXE
#
If !func CODACT_OK(APPLI,"AYT")
 Gosub FIN_OBJ From PATCH
 Return
Endif
If filinfo(filpath("FIL","AYTFCY","fde",APPLI),0)<0  or filinfo(filpath("FIL","AYTLINES","fde",APPLI),0)<0
 Gosub FIN_OBJ From PATCH
 Return
Endif
# Vérification racine Xtend: arborescence et mise à jour destination (utile validation et html)
If !VERIF_REP
 VERIF_REP= 1
 Call DIRXTUPD("", APPLI,  WX_RET) From AYTGESFILE
 If WX_RET=1
  Call DIRXTUNIX("", APPLI, WX_RET) From AYTGESFILE
 Endif
Endif
ER=0 # Non raz par boucle
### Décodage clés
Raz WX_FCYCOD, WX_OBJCLE, WX_OBJTYP, WX_I, WX_J, WX_K
Case TYPOBJ
 When "AYS","AY"
  WX_FCYCOD=NOMOBJ
 When "AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYI","AYM","AYC"
  WX_I=instr(1,NOMOBJ,"~")
  If WX_I
   WX_FCYCOD = left$(NOMOBJ,WX_I-1) : WX_OBJCLE = right$(NOMOBJ,WX_I+1)
  Else
   WX_STR=mess(func AYTUTIA.GETMNL7910(TYPOBJ), 7910, 1) -"-"-mess(2,7901,1)-":"-NOMOBJ
   Call ECR_TRACE(WX_STR,1) From GESECRAN
   Gosub FIN_OBJ From PATCH
   Return
  Endif
 When "AYU"
  WX_I=instr(1,NOMOBJ,"~")
  WX_J=instr(WX_I+1,NOMOBJ,"~")
  If (WX_I=0 or WX_J=0)
   WX_STR=mess(func AYTUTIA.GETMNL7910(TYPOBJ), 7910, 1) -"-"-mess(2,7901,1)-":"-NOMOBJ
   Call ERREUR(WX_STR) From GESECRAN
   Gosub FIN_OBJ From PATCH
   Return
 Else
  WX_FCYCOD= left$(NOMOBJ,WX_I-1)
  WX_OBJTYP=  seg$(NOMOBJ,WX_I+1,WX_J-1)
  WX_OBJCLE=right$(NOMOBJ,WX_J+1)
 Endif

 When "ELX"
  # NOMOBJ contient une chaine de la forme "XTEND/X_TEND/X_TAR/ZZ.tar"
  #   "[dossier]/X_TEND/X_TAR/[code site Xtend].tar"
  Local Char WWX_FCYCOD(GLONAYS+4)
  WX_I=instr(1,NOMOBJ,"/X_TEND/X_TAR/") + instr(1,NOMOBJ,"\X_TEND\X_TAR\")
  If WX_I
   WWX_FCYCOD = right$(NOMOBJ,WX_I+len("/X_TEND/X_TAR/"))
   WX_I=instr(1,WWX_FCYCOD,".tar")
   If !WX_I
    WX_STR=mess(4,7901,1)-":"-NOMOBJ
    Call ECR_TRACE(WX_STR,1) From GESECRAN
    Gosub FIN_OBJ From PATCH
    Return
   Endif
   WX_FCYCOD = left$(WWX_FCYCOD,WX_I-1)
  Else
   WX_STR=mess(4,7901,1)-":"-NOMOBJ
   Call ECR_TRACE(WX_STR,1) From GESECRAN
   Gosub FIN_OBJ From PATCH
   Return
  Endif

 When Default
  Call ECR_TRACE(mess(1,7901,1)-TYPOBJ,1) From GESECRAN
  Gosub FIN_OBJ From PATCH
  Return
Endcase

### Accès site Xtend
Read [AYS]AYS0 = WX_FCYCOD
If fstat
 WX_NEWFCY = 1
 If APPLI=GDOSX3 & WX_FCYCOD="AHRPORTAL"
  # integration du portail dans le dossier mere
 Elsif left$(WX_FCYCOD,1) = "A"
  Call ECR_TRACE("---"-mess(7,123,1)-":"-mess(223,7900,1),0) From GESECRAN
  # Création impossible : Code site commençant par A résevé à SAGE"
  Gosub FIN_OBJ From PATCH
  Return
 Endif
Elsif [F:AYS]CODACT>="X" & !find([F:AYS]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Return
Else
 WX_NEWFCY = 0
Endif
#
If WX_NEWFCY and !find(TYPOBJ,"AYS","AY")
 Call ECR_TRACE(NOMOBJ-mess(5,7901,1)-WX_FCYCOD-"("-APPLI-")",0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Return
Endif
# Indice Site courant
WX_LSTFCYIND=find(WX_FCYCOD,WX_LSTFCY)
If !WX_LSTFCYIND : WX_LSTFCYIND=find("",WX_LSTFCY) : WX_LSTFCY(WX_LSTFCYIND)=WX_FCYCOD : Endif

### Trt
Case TYPOBJ
When "AYA"
    If WX_ABR <> "AYA"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTACT" : WX_ABR="AYA" : WX_KEYCOD="ACTCOD"    : WX_LINCODTYP=3
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYA0
    Endif
    Gosub INTXTD
When "AYB"
    If WX_ABR <> "AYB"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTELTBLC" : WX_ABR="AYB" : WX_KEYCOD="BLCCOD" : WX_LINCODTYP=2
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYB0
    Endif
    Gosub INTXTD
When "AYC"
    If WX_ABR <> "AYC"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTMEN" : WX_ABR="AYC" : WX_KEYCOD="MENCOD"    : WX_LINCODTYP=7
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYC0
    Endif
    Gosub INTXTD
When "AYW"
    If WX_ABR <> "AYW"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTELTBLCW" : WX_ABR="AYW" : WX_KEYCOD="BLCWHNCOD" : WX_LINCODTYP=5
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYW0
    Endif
    Gosub INTXTD
When "AYL"
    If WX_ABR <> "AYL"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTELTDLK" : WX_ABR="AYL" : WX_KEYCOD="DLKCOD" : WX_LINCODTYP=4
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYL0
    Endif
    Gosub INTXTD
When "AYF"
    If WX_ABR <> "AYF"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTELTFLD" : WX_ABR="AYF" : WX_KEYCOD="FIECOD" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYF0
    Endif
    Gosub INTXTD
When "AYE"
    If WX_ABR <> "AYE"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTENT" : WX_ABR="AYE" : WX_KEYCOD="ENTCOD" : WX_LINCODTYP=1
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYE0
    Endif
    Gosub INTXTD
When "AYS"
    If !WX_NEWFCY
     Call ECR_TRACE("---"-mess(3,7901,1),0) From GESECRAN
     #Gosub FIN_OBJ From PATCH
     #Return
    Endif
    If WX_ABR <> "AYS"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTFCY" : WX_ABR="AYS" : WX_KEYCOD="" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER    [AY_] Order By Key AYS0
    Endif
    Gosub INTXTD
When "AYI"
    If WX_ABR <> "AYI"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTINT" : WX_ABR="AYI" : WX_KEYCOD="INTCOD" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYI0
    Endif
    If !clalev([F:ASU]) : Local File =APPLI+".ASUBPROG"     [ASU] : Endif
    If !clalev([F:ASP]) : Local File =APPLI+".ASUBPROGD"    [ASP] : Endif
    If !clalev([F:AWE])   : Local File =APPLI+".AWEBSERVIC"   [AWE] : Endif
    If !clalev([F:AWY])   : Local File =APPLI+".AWEBSERDES"   [AWY] : Endif
    Gosub INTXTD
    Local File [ASU],[AWE],[AWY],[ASP]
When "AYM"
    If WX_ABR <> "AYM"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTMES" : WX_ABR="AYM" : WX_KEYCOD="MESCOD" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYM0
    Endif
    Gosub INTXTD
When "AYG"
    If WX_ABR <> "AYG"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTPAG" : WX_ABR="AYG" : WX_KEYCOD="PAGCOD" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYG0
    Endif
    Gosub INTXTD
When "AYD"
    If WX_ABR <> "AYD"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTPRF" : WX_ABR="AYD" : WX_KEYCOD="PRFCOD" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYD0
    Endif
    Gosub INTXTD
When "AYU"
    If WX_ABR <> "AYU"
        If clalev([AY_]) : Close Local File [AY_] Endif
        WX_FICHIER="AYTADVPAR" : WX_ABR="AYU" : WX_KEYCOD="" : WX_LINCODTYP=0
        Local File =APPLI+"."+WX_FICHIER [AY_] Order By Key AYU0
    Endif
    Gosub INTXTD
When "ELX" :  Gosub INTELT
When "AY"    # Site auto (<=>RAF)
    Gosub FIN_OBJ From PATCH
    Return
When Default
    Call ECR_TRACE(mess(1,7901,1)-TYPOBJ,1) From GESECRAN
    Gosub FIN_OBJ From PATCH
    Return
Endcase

If ER or !OKOBJ : Gosub FIN_OBJ From PATCH :Endif

Return

#####     Integ d'un paramétrage Xtend   ########
$INTXTD
If WX_ABR="AYS"
    # Clé simple
    Read [F:AY_]=WX_FCYCOD
Elsif WX_ABR="AYU"
    # Clé en 4 parties - Lecture sur 1er enreg. pour test existence
    Read [F:AY_]=WX_FCYCOD;val(WX_OBJTYP);WX_OBJCLE;1
Else
    # Clé en 2 parties
    Read [F:AY_]=WX_FCYCOD;WX_OBJCLE
#    # Clé secondaire sans homonyme (non sensible maj/min.)
#    Read [F:AY_]=WX_FCYCOD+"_"+toupper(WX_OBJCLE)
#    If !fstat
#        WX_STR=evalue("[F:AY_]"+WX_KEYCOD)
#        If WX_STR<>WX_OBJCLE  # Pas de remplacement - les chainages sont faux
#            Call ECR_TRACE("---"-mess(163,7900,1)-WX_STR,1) From GESECRAN : # Objet spécifique
#            Gosub FIN_OBJ From PATCH  : Return
#        Endif
#    Endif
Endif
If fstat
 NEWOBJ = 1
 Raz [F:AY_]
Else
 NEWOBJ = 0
 # Savaugardes des valeur des parametres libres du site
 If !NEWOBJ & WX_ABR="AYS"
  Local Char XPAR(GLONAYR)(0..10) , XPARVAL(GLONAYV)(0..10)
  Local Integer XPARNBR
  For I=0 To [F:AY_]PARNBR-1
   XPAR(I)    = [F:AY_]PAR(I)
   XPARVAL(I) = [F:AY_]PARVAL(I)
  Next I
  XPARNBR = [F:AY_]PARNBR
 Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR_XTD

$INTXTD_FIN
Return

$TR_XTD
Trbegin [AY_]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7,13 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    If CHAMP(1)=WX_ABR
        Gosub XTD1
    Elsif CHAMP(1)="AYN"
        If WX_LINCODTYP  : Gosub AYN : Endif
    Elsif CHAMP(1)="ASU"
     K = instr(1,IDENT,"~")
     Read [ASU]ASU0 = left$(IDENT,K-1); right$(IDENT,K+1)
     If fstat
      NEWOBJ = 1
      Raz [F:ASU]
     Else
      NEWOBJ = 0
     Endif
     Gosub ASU1  From PATCHDIV
     Gosub FIN_OBJDIV : # a dcause du code activité
    Elsif CHAMP(1)="ASP"
     Gosub ASU2 From PATCHDIV
    Elsif CHAMP(1)="AWE"
     Read [AWE]AWE1  = IDENT
     If fstat
      NEWOBJ = 1
      Raz [F:AWE]
     Else
      NEWOBJ = 0
     Endif
     Gosub AWE1 From PATCHDIV
     Delete [AWY] Where PUBLI=IDENT
     If fstat : GOK = 0 : ER = 99 : ERFIC = "AWEBSERVIC"-IDENT: Return : Endif
    Elsif CHAMP(1)="AWY"
     Gosub AWE2 From PATCHDIV
    Else
        ER = 31
    Endif
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit

## Flag Validation
If WX_LSTFCYIND : Assign "WX_LST"+WX_ABR+"(WX_LSTFCYIND)" With 1 : Endif
Return

$FIN_OBJDIV
If OKOBJ=0
 If [F:ADS]MODULE(max(1,MODOBJ)-1)<>2
  Call ECR_TRACE("---"-mess(max(1,MODOBJ),14,1)-":"-mess(58,125,1),0) From GESECRAN
  # Module non implanté dans le dossier
 Else
  Call ECR_TRACE("---"-ACVOBJ-":"-mess(24,176,1),0) From GESECRAN
  # Code activité inactif
 Endif
 OKOBJ = 1
Endif
Return

$XTD1            # Recopie des chps
# Suppression AYN liés
If !NEWOBJ and WX_LINCODTYP
    Delete [AYN] Where FCYCOD=WX_FCYCOD and LINCODTYP=WX_LINCODTYP and LINCOD=toupper(WX_OBJCLE)
    If fstat : GOK = 0 : ER = 99 : ERFIC = "AYTLINES" -WX_FCYCOD+"~"+WX_LINCODTYP+"~"+toupper(WX_OBJCLE): Return : Endif
Endif
# Suppression objet AYU (par. avancé) car remplacement
If !NEWOBJ and WX_ABR="AYU"
    Delete [AY_] Where FCYCOD=WX_FCYCOD and OBJTYP=val(WX_OBJTYP) and OBJCOD=WX_OBJCLE
    If fstat : GOK = 0 : ER = 99 : ERFIC = "AYTADCPAR" -WX_FCYCOD+"~"+WX_OBJTYP+"~"+WX_OBJCLE: Return : Endif
    NEWOBJ=1
    Raz [F:AY_]
Endif
#
ABR="AY_" : FICHIER=WX_FICHIER
Repeat
 Gosub LIRE_ZONE From PATCH
 #
 # Informations non reprise sur un site déjà existant
 If !(WX_ABR="AYS" and !NEWOBJ
&     and find(CHAMP(1),"MAICOD","BRWDEG","LOGMOD","TOOLMOD","LNKNBR","LNKADS","LNKADSDEF"
&                      ,"BRWDEG","LOGMOD","TOOLMOD","LOCHTM","LOCFIL","LOCFLA","HCEDEF","HCEHTM"
&                      ,"HCEFIL","HCEXTD","HCEAPP","HCEFLA","CTSDEF","CTSHTM","CTSDIC"))
   If  !(WX_ABR="AYG" and !NEWOBJ and find(CHAMP(1),"WEBPRO"))
     If ER : Break : Endif
     If DIME>0 & IND+1<=DIME
      Gosub AFF_ZONE From PATCH
      If GOK<1 : ER = 99 : Break : Endif
     Endif
   Endif
 Endif
Until TYPENR=6
If WX_ABR="AYS"
 If  NEWOBJ
  [F]LNKNBR       = 1
  [F]LNKADS(0)    = "ADEFAULT"
  [F]LNKADSDEF(1) = 2
 Else
  For I=0 To [F]PARNBR
   J=find([F]PAR(I),XPAR(0..XPARNBR-1))
   If J
    [F]PARVAL(I) = XPARVAL(J-1)
   Endif
  Next I
 Endif
Endif
If NEWOBJ
 [F]CREDAT = date$
 [F]CREUSR = GUSER
 If dim([F]CRETIM)>0 : [F]CRETIM = time : Endif
 Write [F]
Else
 [F]UPDDAT = date$
 If dim([F]UPDTIM)>0 : [F]UPDTIM = time : Endif
 [F]UPDUSR = GUSER
 Rewrite [F]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = FICHIER  : Return
Endif
Return
#####     XTD (fin)

#####     AYN    Séquence commune pour mise à jour des lignes de détail
$AYN            # Recopie des chps
FICHIER = "AYTLINES" : ABR = "AYN"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
Write [AYN]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AYTLINES" : Return
Endif
Return
#####     AYN    (fin)


#####
$ABORT
Rollback
Return



#####     ELX - pach design   ######## (voir modèle PATCHDIV)
$INTELT
# Déposer l'archive avec sauvegarde éventuelle
Rdseq NOCT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
#   "[dossier]/X_TEND/X_TAR/[code site Xtend].tar"
REPERT = APPLI+"/X_TEND/X_TAR/" : EXT1 = "tar"
Case GOS(1)
When "unix"  : SEP = "/"
When Default : SEP = "\"
Endcase
#FIC = ctrans(NOMOBJ,"/\",SEP+SEP)  # filpath fait la conversion /\
FICSRC = filpath(REPERT ,WX_FCYCOD,EXT1,"X3_PUB")
If filinfo(FICSRC,0)>=0
  FICOLD = filpath(REPERT ,WX_FCYCOD,"old","X3_PUB")
  Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
Endif
Openi FICPATCH , SAVPOS
Openo FICSRC , 0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   Putseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   Putseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Openo
SAVPOS = adxseek(0)
Openi
Openi FICPATCH , SAVPOS

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif

## Flag Validation
If WX_LSTFCYIND : WX_LSTELT(WX_LSTFCYIND)=1 : Endif
Return
#####     ELT (fin)

#    INTEND          Intégration patch:  Fin
# $$$
######################################################################################
$INTEND
#
If (dim(INTEGRE)>0 & INTEGRE<>2) | (dim(INTEG)>0 & INTEG<>2)  : Return : Endif
If !func CODACT_OK(APPLI,"AYT") : Return : Endif
If filinfo(filpath("FIL","AYTFCY","fde",APPLI),0)<0  or filinfo(filpath("FIL","AYTLINES","fde",APPLI),0)<0
 Return
Endif
If dim(WX_LSTFCYIND)<=0 : Return : Endif
#
#SAM 120292 (fails if GOK set to 0 by another maintenance): If GOK<1 : Return : Endif

# Close Local File [AYA], [AYS] car fait par appelant avec ordre générique CLOSE LOCAL FILE
For WX_I=1 To WX_LSTFCYIND

    ## Gestion Design
    If WX_RET and WX_LSTELT(WX_I)=1
        Call DIRFCYDETAR("",APPLI,WX_LSTFCY(WX_I),WX_LSTFCY(WX_I),WX_RET) From AYTGESFILE
        If WX_RET<>1
            Call ECR_TRACE(mess(7,7901,1)-WX_LSTFCY(WX_I)-"("+APPLI+")",1) From GESECRAN
        Endif
    Endif

    # Verif arborecsence du site (sans langue)
    Raz WX_LAN
    Call DIRFCYUPD("" ,APPLI,WX_LSTFCY(WX_I), WX_LAN,0, WX_RET) From AYTGESFILE
    Call DIRFCYUNIX("",APPLI,WX_LSTFCY(WX_I), WX_RET) From AYTGESFILE


    ## Validation XML
    WX_LSTIND=0 : Raz WX_LSTIND, WX_LSTOBJCOD, WX_OPTION
    #WX_OPTION(1)="TRADET"         # Trace détaillée
    #WX_OPTION(1)="CHK"            # Vérification

    If WX_LSTAYA(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYA" : Endif        # Action
    If WX_LSTAYB(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYB" : Endif        # Bloc
    If WX_LSTAYC(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYC" : Endif        # Menu
    If WX_LSTAYD(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYD" : Endif        # Profil
    If WX_LSTAYE(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYE" : Endif        # Entité
    If WX_LSTAYF(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYF" : Endif        # Elt Champ
    If WX_LSTAYG(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYG" : Endif        # Page
    If WX_LSTAYI(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYI"                # Interface
     # pas dans ce cadre   If [M]INTGM1=2 : OPTIND+=1 : OPTION(OPTIND)="AYI_ACCWS" : Endif
                                                         : Endif
    If WX_LSTAYL(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYL" : Endif        # Lien dynamique
    If WX_LSTAYM(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYM" : Endif        # Message
    If WX_LSTAYS(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYS" : Endif        # Fiche site
    If WX_LSTAYW(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYW" : Endif        # Bloc conditionné
    If WX_LSTAYU(WX_I)=1 : WX_LSTIND+=1 : WX_LSTOBJCOD(WX_LSTIND)="AYU" : Endif        # Paramétrage avancé
    If WX_LSTIND
        Call XMLGENPRG(APPLI, WX_LSTFCY(WX_I), WX_LSTOBJCOD, WX_OPTION, WX_RET) From AYTGEN
        If WX_RET<>1
            Call ECR_TRACE(mess(6,7901,1)-WX_LSTFCY(WX_I)-"("+APPLI+")",1) From GESECRAN
        Endif
    Endif
Next
Return

# Code activité actif dans dossier  (repris Patchabi/Ok_Codact)
#------------------------------------------------------------#
Funprog CODACT_OK(DOS, CODACT)
Value Char    DOS()
Value Char    CODACT()
Value Char       APPLI
Value Char       COD
Local Integer WOK
If CODACT="" : End 0 : Endif
If DOS="" : DOS=nomap : Endif
Local File ADOSACT [ADA3]
Read [ADA3]ADA0=DOS;CODACT
WOK=(!fstat & [F:ADA3]FLACT=2)
Close Local File [ADA3]
End WOK

