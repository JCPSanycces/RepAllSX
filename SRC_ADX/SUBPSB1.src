#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# SUBPSB1 : Sélection des fournisseurs en AOF              HN  27/09/02 #
# --------------------------------------------------------------------- #
# Actions sur champs de l'écran                                         #
#########################################################################
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                  #
#   - SELBPSPQH  : Fenêtre sélection des fournisseurs d'un AOF          #
#########################################################################

$ACTION
###################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                      #
# --------------------------------------------------------------- #
# SELBPSPQH  : Fenêtre sélection des fournisseurs d'un AOF        #
###################################################################
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SELBPSPQH"  : Gosub OUV_SELBPSPQH
  Endcase
 When "TITRE"
  #---------------------#
  # Titre de la fenêtre #
  #---------------------#
  Case GACTION
   When "SELBPSPQH"  : TIT=mess(05,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "SELBPSPQH"  : Gosub DEB_SELBPSPQH
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SELBPSPQH"  : Gosub OK_SELBPSPQH
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SELBPSPQH"  : REP="M"
  Endcase
 When "SETBOUT"
  #-------------------------------#
  # Grisage/dégrisage des boutons #
  #-------------------------------#
  Case GACTION
   When "SELBPSPQH"  : Gosub SETB_SELBPSPQH
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SELBPSPQH"   : Gosub ABA_SELBPSPQH
  Endcase
 When "BOUTON"
  #-------------------------------#
  # Après l'exécution d'un bouton #
  #-------------------------------#
  Case GACTION
   When "SELBPSPQH"   : Gosub BOUT_SELBPSPQH
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "SELBPSPQH"  : Gosub FINSAI_SELBPSPQH
  Endcase
Endcase
Return

##########################################################################
# Action sur champ                                                       #
##########################################################################
Subprog AM_PICFLG(VALEUR)
Variable Integer  VALEUR
[M:PSB1]PICFLG(nolign-1)= VALEUR
End
##########################################################################
# Sélection des fournisseurs ayant un lien ITP avec l'article            #
# de la ligne d'appel d'offre si appel depuis tableau des articles       #
#                                                                        #
# Sélection des fournisseurs ayant un lien ITP tous les articles         #
# de l'appel d'offre si appel depuis tableau des fournisseur             #
#                                                                        #
# ---------------------------------------------------------------------- #
# Action SELBPSPQH avec paramètre                 :          HN 26/09/02 #
#             "ITM" = Appel depuis ligne article                         #
#             "BPS" = Appel depuis ligne fournisseur                     #
##########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SELBPSPQH
Local Integer SAVNOLIGN      : [L]SAVNOLIGN=nolign
Local Char    WTYP(3)        : [L]WTYP = PARAM(1)
Local Char    WBPSNUM(GLONBPS)
Local Char    WCRIT(150)
Local Integer I, J, K, SAI_OK, STOP
If [L]WTYP="ITM" Local Char WITMREF(GLONITM) : [L]WITMREF=[M:PQH1]ITMREF(nolign-1) : Endif
If clalev([M:PSB2])=0 : Local Mask PSELBPS1 [PSB2] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SELBPSPQH
Raz [M:PSB1]
nolign=1
Case WTYP
  When "ITM"
   For [ITP]ITP0 Where ITMREF=[L]WITMREF
     If [F:BPS]BPSNUM <> [F:ITP]BPSNUM
       Read [BPS]BPS0=[F:ITP]BPSNUM
       If fstat : Raz [F:BPS] : Endif
     Endif
     If !find([F:BPS]BPSNUM,[M:PSB1]BPSNUM(0..[M:PSB1]NBLIG-1))
       [M:PSB1]=[F:BPS]
       If find([F:BPS]BPSNUM,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
         [M:PSB1]PICFLG(nolign-1)=2
       Endif
       nolign+=1
       If nolign>=dim([M:PSB1]BPSNUM) : GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
     Endif
   Next
  When "BPS"
   If clalev([F:ITP1])=0 : Local File ITMBPS     [ITP1] : Endif
   Raz [F:ITP1]
   $BOUCLE_BPS
   WCRIT ='BPSNUM>"'+[F:ITP1]BPSNUM+'"'
   WCRIT-='& ITMREF>=min([M:PQH1]ITMREF(0..[M:PQH1]NBLIG-1))'
   WCRIT-='& ITMREF<=max([M:PQH1]ITMREF(0..[M:PQH1]NBLIG-1))'
   Raz STOP
   For [ITP1]ITP2 Where evalue(WCRIT)
     STOP=1
     For I=0 To [M:PQH1]NBLIG-1
       Look [ITP]ITP0=[M:PQH1]ITMREF(I);[F:ITP1]BPSNUM
       If fstat  Break 2 : Endif
     Next
     Read [BPS]BPS0=[F:ITP1]BPSNUM
     If fstat
       Raz [F:BPS]
     Else
       If !find([F:BPS]BPSNUM,[M:PSB1]BPSNUM(0..[M:PSB1]NBLIG-1))
         [M:PSB1]=[F:BPS]
         If find([F:BPS]BPSNUM,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
           [M:PSB1]PICFLG(nolign-1)=2
         Endif
         nolign+=1
         If nolign>=dim([M:PSB1]BPSNUM)
           GMESSAGE=mess(26,100,1) : GERR=2 : STOP=0 : Break
         Endif
       Endif
     Endif
     Break
   Next
   If STOP : Goto BOUCLE_BPS : Endif
  When Default
Endcase
[M:PSB1]NBLIG=nolign-1
If [M:PSB1]NBLIG=0
  GMESSAGE=mess(69,197,1) : GERR=1 : FIN=1 : Return
Endif
Sorta [M:PSB1]NBLIG [M:PSB1]NBLIG Order By [M:PSB1]BPSNUM(indice)
Affzo [PSB1]
# X3-26914 by RBA 20-04-2017
#[M:PSB2]=[M:PSB1]
Raz [M:PSB2] : Transmask [M:PSB1] To [M:PSB2]
#/ X3-26914 by RBA 20-04-2017
If GPQH_VERROU=0 & GREP<>"C" Diszo [PSB1]1-99 : Endif
Return
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
$SETB_SELBPSPQH
If varmode ([M:PSB1]PICFLG,0)>0
  Call VIREBOUT(CHMEN,"AB")  From GOBJET
  Call VIREBOUT(CHBOU,"OA")  From GOBJET
Elsif REP<>"M"
  Call VIREBOUT(CHBOU,"OA")  From GOBJET
Endif
Return
#-------------------------------#
# Après l'exécution d'un bouton #
#-------------------------------#
$BOUT_SELBPSPQH
Case BOUT
  When "A" : REP="M" : # Bouton "Inclure"
  When "B" : REP="M" : # Bouton "Exclure"
Endcase
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SELBPSPQH
SAI_OK=1
For I=0 To [M:PSB1]NBLIG-1
  If [M:PSB1]PICFLG(I)=2
    WBPSNUM=[M:PSB1]BPSNUM(I)
    Raz mkstat
    If find(WBPSNUM,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
      mkstat=1
    Endif
    If !mkstat
      Call CTLBPRCPY(WBPSNUM,num$([M:PQH1]PQHFCY)) From CONTX3
      If !mkstat
        Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
      Endif
    Endif
    If mkstat=0
      If [M:PQH1]NBFOU>=dim([M:PQH1]BPSNUM)-1 : GERR=2 : GMESSAGE =mess(26,100,1) : Break : Endif
      J=[M:PQH1]NBFOU
      nolign=J+1
      [M:PQH1]BPSNUM(J)=WBPSNUM
      Gosub CHARG_LIG_BPS From SUBPQHA
      nolign=J+1 : [M:PQH1]NBFOU+=1
      Call AM_NBFOU From SUBPQH
      status=73  : Call APRES_NBFOU From SUBPQH
     Else
      Raz GMESSAGE
    Endif
  Elsif [M:PSB1]PICFLG(I)=1
    WBPSNUM=[M:PSB1]BPSNUM(I)
    #----- Lecture du fournisseur -----#
    Read [BPS] BPS0=WBPSNUM
    If fstat Raz [F:BPS] : Endif
    Raz K
    K=find([F:BPS]BPSNUM,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
    If K<>0 & [M:PQH1]BPSNUM(K-1)=[F:BPS]BPSNUM
      J=K-1
      nolign=J+1 : status=65
      Call C_NBFOU From SUBPQH
      Call AVANT_NBFOU From SUBPQH
      If !mkstat
        Dela J,1,[M:PQH1]NBFOU-1 [M:PQH1]NBFOU : [M:PQH1]NBFOU-=1
      Endif
    Endif
  Endif
Next I
Return
#---------#
# Abandon #
#---------#
$ABA_SELBPSPQH
# X3-26914 by RBA 20-04-2017
#[M:PSB1]=[M:PSB2]
Raz [M:PSB1] : Transmask [M:PSB2] To [M:PSB1]
#/ X3-26914 by RBA 20-04-2017
Affzo [PSB1]
REP=""
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SELBPSPQH
If SAI_OK=1
  Affzo [PQH1]15,20
  mkstat=4
Endif
nolign=SAVNOLIGN
Return


Subprog INC_PQH
#--------------------------------------------#
# Inclus tous les fournisseurs               #
#--------------------------------------------#
For I=0 To [M:PSB1]NBLIG-1
  [M:PSB1]PICFLG(I)=2
Next I
Affzo [PSB1]1-99
End

Subprog EXC_PQH
#------------------------------------#
# Exclus tous les fournisseurs       #
#------------------------------------#
For I=0 To [M:PSB1]NBLIG-1
  [M:PSB1]PICFLG(I)=1
Next I
Affzo [PSB1]1-99
End

