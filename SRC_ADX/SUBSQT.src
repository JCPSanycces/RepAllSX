#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet SQT
#######################################################################
# SUBSQT : Transactions de saisie des contrôles qualité               #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWP]AWINBRO  Table des browser fenêtres    #
#                       [F:AWP]AWINBOUT Table des boutons fenêtres    #
#                                                                     #
# Génération de 2 écrans de saisie à partir des écrans de base SQT    #
# et STOETR*                                                          #
# Nom des écrans générés : WT8yyy                                     #
#                          yyy = nom de la transaction (SRTNUM)       #
#######################################################################
# Mail PARBUS du 10/05/2004 : Pas gestion affaire                     #
#######################################################################
Call OBJET("SQT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SQT0]SRTTYP = 8
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR      From ATRTX3
 When Default
Endcase
Return

$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE

    FILTSUP = "SRTTYP=8"

Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
    If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:SQT0]ENAFLG=0     [M:SQT0]ENAFLG=2     : Endif
#** Onglet général
If [M:SQT1]DOCFLG=0     [M:SQT1]DOCFLG=1     : Endif : # Impression auto (non)
#If [M:SQT1]PJTCOD=0     [M:SQT1]PJTCOD=1     : Endif : # Affaire (invisible)
#If [M:SQT1]PJTSCR=0     [M:SQT1]PJTSCR=1     : Endif : # Affaire (invisible)
If [M:SQT1]STQDATCOD=0  [M:SQT1]STQDATCOD=1  : Endif : # Date fin controle
If [M:SQT1]TRSFAMCOD=0  [M:SQT1]TRSFAMCOD=1  : Endif : # Famille mouvement
If [M:SQT1]QLYCRDCOD=0  [M:SQT1]QLYCRDCOD=2  : Endif : # Fiche techn.(affichée)

#-- Grisage des zones si besoin
#** Onglet Général
WMODU +=format$("N0:2",[M:SQT0]SRTTYP)

If [M:SQT1]IDECOD1=2    Grizo [SQT1]IDESCR1    Else Actzo [SQT1]IDESCR1   : Endif
If [M:SQT1]IDECOD2=2    Grizo [SQT1]IDESCR2    Else Actzo [SQT1]IDESCR2   : Endif
If [M:SQT1]IDECOD2=2    Grizo [SQT1]IDESCR2    Else Actzo [SQT1]IDESCR2   : Endif
If [M:SQT1]QLYCRDCOD=2  Grizo [SQT1]QLYCRDSCR  Else Actzo [SQT1]QLYCRDSCR : Endif    # HCB v6cq
If [M:SQT1]PRNCOD1=1
    Grizo [SQT1]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Else
    Actzo [SQT1]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Endif
If [M:SQT1]PRNNBFLG1=1  Grizo [SQT1]PRNNBSCR1  Else Actzo [SQT1]PRNNBSCR1 : Endif
Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
#** Onglet général
Actzo [SQT0]
Actzo [SQT1]
[M:SQT0]ENAFLG=2
[M:SQT1]DOCFLG=1
[M:SQT1]STQDATCOD=3    : # Date fin contrôle qualité
[M:SQT1]TRSFAMCOD=3    : # Famille mvt (invisible)
[M:SQT1]QLYCRDCOD=2    : # Fiche technique(affichée)
WMODU += format$("N0:2",[M:SQT0]SRTTYP)
If dim([M:SQT1]CHGWRHCOD) > 0      : # Saisie depot destination
   [M:SQT1]CHGWRHCOD=2
Endif
[M:SQT1]CHGEMPCOD=2      : # Saisie emplacement destination
[M:SQT1]CHGPCUCOD=2      : # Saisie UC
[M:SQT1]IDECOD1=1        : # Identifiant 1
[M:SQT1]IDESCR1=1
[M:SQT1]IDECOD2=1        : # Identifiant 2
[M:SQT1]IDESCR2=1
[M:SQT1]PRNCOD1=1        : # Impression
[M:SQT1]PRNSCR1=1
[M:SQT1]PRNNBFLG1=1      : # Nombre de document
[M:SQT1]PRNNBSCR1=1
Actzo [SQT1]
#- Grisage des zones
If [M:SQT1]IDECOD1=3    Grizo [SQT1]IDESCR1    Else Actzo [SQT1]IDESCR1   : Endif
If [M:SQT1]IDECOD2=3    Grizo [SQT1]IDESCR2    Else Actzo [SQT1]IDESCR2   : Endif
If [M:SQT1]QLYCRDCOD=2  Grizo [SQT1]QLYCRDSCR  Else Actzo [SQT1]QLYCRDSCR : Endif    # HCB v6cq
If [M:SQT1]PRNCOD1=1
    Grizo [SQT1]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Else
    Actzo [SQT1]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Endif
If [M:SQT1]PRNNBFLG1=1  Grizo [SQT1]PRNNBSCR1  Else Actzo [SQT1]PRNNBSCR1 : Endif

Gosub PE_STKTRS
Affzo [SQT0]1-99
Affzo [SQT1]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "QLYCRDCOD"                                   : # FICHE TECHNIQUE
       If val(CZ)=3
         [M:SQT1]QLYCRDSCR=1
         If !GIMPORT Affzo [SQT1]QLYCRDSCR : Grizo [SQT1]QLYCRDSCR : Endif
       Elsif !GIMPORT
         Actzo [SQT1]QLYCRDSCR
       Endif

  When "IDECOD1"                                  : # Identifiant 1
       If val(CZ)=2
         [M:SQT1]IDESCR1=1
         If !GIMPORT Affzo [SQT1]IDESCR1: Grizo [SQT1]IDESCR1 : Endif
       Elsif !GIMPORT
         Actzo [SQT1]IDESCR1
       Endif
  When "IDECOD2"                                  : # Identifiant 2
       If val(CZ)=2
         [M:SQT1]IDESCR2=1
         If !GIMPORT Affzo [SQT1]IDESCR2: Grizo [SQT1]IDESCR2 : Endif
       Elsif !GIMPORT
         Actzo [SQT1]IDESCR2
       Endif
  When "PRNCOD1"                                  : # Type Impression
       If val(CZ)=1
         [M:SQT1]PRNSCR1=1
         [M:SQT1]PRNNBFLG1=1
         [M:SQT1]PRNNBSCR1=1
         If !GIMPORT Affzo [SQT1]PRNSCR1    : Grizo [SQT1]PRNSCR1
                     Affzo [SQT1]PRNNBFLG1  : Grizo [SQT1]PRNNBFLG1
                     Affzo [SQT1]PRNNBSCR1  : Grizo [SQT1]PRNNBSCR1
         Endif
       Elsif !GIMPORT
         Actzo [SQT1]PRNSCR1
         Actzo [SQT1]PRNNBFLG1
         Actzo [SQT1]PRNNBSCR1
       Endif
  When "PRNNBFLG1"                                : # Nbre impression
       If val(CZ)=1
         [M:SQT1]PRNNBSCR1=1
         If !GIMPORT Affzo [SQT1]PRNNBSCR1: Grizo [SQT1]PRNNBSCR1 : Endif
       Elsif !GIMPORT
         Actzo [SQT1]PRNNBSCR1
       Endif
  When Default
       Gosub PE_STKTRS
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SQT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SQT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU : Endif
If APPLI=""    APPLI=nomap      : Endif
If dim(OK)<0  : Local Integer OK : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

If WMODU=""
    WMODU = "T"+format$("N0:2",[M:SQT0]SRTTYP)
Endif

#---------------- Noms fenêtres et traitement entrées diverses ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="OSTQ"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOSTQ"+[M:SQT0]SRTNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
MFROM="STQ1"
MTO="W"+WMODU+[M:SQT0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SQT1]STQDATCOD>1  TZONE(IZON)="ENDCTLDAT"             : # Date de fin
                           TMOD(IZON) =[M:SQT1]STQDATCOD
                           IZON+=1
   Endif

   If [M:SQT1]TRSFAMCOD>1  TZONE(IZON)="TRSFAM"                : # Famille mouvement
                           TMOD(IZON) =[M:SQT1]TRSFAMCOD
                           IZON+=1
   Endif

   If [M:SQT1]QLYCRDCOD>1  TZONE(IZON)="QLYCRD"                : # Fiche technique
                           TMOD(IZON) =[M:SQT1]QLYCRDCOD
                           IZON+=1
   Endif
   If [M:SQT1]QLYCRDSCR>1  TZONE(IZON)="QLYCRD"                : # Fiche technique
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]QLYCRDSCR)
                           IZON+=1
   Endif
   If [M:SQT1]CHGEMPCOD<>2 TZONE(IZON)="LOCTYPDES"   : # Type d'emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LOCDES"      : # Emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LPNNUMDES"   : # Contenant                # hcb X3-77043
                           TMOD(IZON) =3                                          # hcb X3-77043
                           IZON+=1                                                # hcb X3-77043


   Endif
   If dim([M:SQT1]CHGWRHCOD) > 0
      If [M:SQT1]CHGWRHCOD<>2 TZONE(IZON)="WRHDES"   : # dépot destination
                              TMOD(IZON) =3
                              IZON+=1
      Endif
   Endif
   If [M:SQT1]CHGPCUCOD<>2 TZONE(IZON)="PCUDES"      : # Unité destination
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="COEDES"      : # Coefficient destination
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDECOD1>1    TZONE(IZON)="PALNUM"               : # Id 1
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDESCR1>1    TZONE(IZON)="PALNUM"                : # Id 1
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]IDESCR1)
                           IZON+=1
   Endif

   If [M:SQT1]IDECOD2>1    TZONE(IZON)="CTRNUM"                : # Id 2
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDESCR2>1    TZONE(IZON)="CTRNUM"                : # Id 2
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]IDESCR1)
                           IZON+=1
   Endif

   OPT1=2
# C'est à partir d'ici qu'il faut tenir compte du paramétrage saisi
# pour les champs
   Gosub PE_STKTRS
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#--- Génération des écrans et fenêtres de stock
WNOMTRS = [M:SQT0]SRTNUM
WNOMOBJ = "STQ"
ACSCOD  = [M:SQT0]ACSCOD
WLIBEL  = [M:SQT0]DESAXX
WENAFLG = [M:SQT0]ENAFLG

#----------------------------------------------#
# Fenêtre de détail                            #
#----------------------------------------------#
WINREF1="ISTOQUA"
NOMWIN1="WQSQD"+[M:SQT0]SRTNUM+"S"
Raz NOMMSKENT    # Nom du masque d'entête de la fenêtre
MFROM="STOQUA"
MTO="W"+WMODU+[M:SQT0]SRTNUM+"S"

Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SQT1]IDECOD1>1    TZONE(IZON)="PALNUM"               : # Id 1
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDECOD2>1    TZONE(IZON)="CTRNUM"                : # Id 2
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:SQT1]CHGWRHCOD) > 0
      If [M:SQT1]CHGWRHCOD<>2 TZONE(IZON)="WRHDES"   : # Depot
                              TMOD(IZON) =3
                              IZON+=1
      Endif
   Endif
   If [M:SQT1]CHGEMPCOD<>2 TZONE(IZON)="LOCTYPDES"   : # Type d'emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LOCDES"      : # Emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LPNNUMDES"    : # Contenant        # hcb x3-77043
                           TMOD(IZON) =3                                   # hcb x3-77043
                           IZON+=1                                         # hcb x3-77043
   Endif
   If [M:SQT1]CHGPCUCOD<>2 TZONE(IZON)="PCUDES"      : # Unité destination
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="COEDES"      : # Coefficient destination
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNCOD1=1    TZONE(IZON)="LBEFMT"      : # Format étiquette
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNSCR1>1    TZONE(IZON)="LBEFMT"      : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNSCR1)
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBFLG1=1  TZONE(IZON)="LBENBR"      : # Nombre d'étiquettes
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBSCR1>1  TZONE(IZON)="LBENBR"      : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNNBSCR1)
                           IZON+=1
   Endif

Else
    OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#                                                            hcb V6CQ deb

#--- Génération des écrans et fenêtres de stock
WNOMTRS = [M:SQT0]SRTNUM
WNOMOBJ = "STQ"
ACSCOD  = [M:SQT0]ACSCOD
WLIBEL  = [M:SQT0]DESAXX
WENAFLG = [M:SQT0]ENAFLG

#----------------------------------------------#
# Fenêtre de saisie echantillonnage            #
#----------------------------------------------#
WINREF1="ISTOSMP"
NOMWIN1="WQSMP"+[M:SQT0]SRTNUM+"E"
Raz NOMMSKENT    # Nom du masque d'entête de la fenêtre
MFROM="STOSMP"
MTO="W"+WMODU+[M:SQT0]SRTNUM+"E"


Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SQT1]IDECOD1>1    TZONE(IZON)="PALNUM"               : # Id 1
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDECOD2>1    TZONE(IZON)="CTRNUM"                : # Id 2
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:SQT1]CHGWRHCOD) > 0
      If [M:SQT1]CHGWRHCOD<>2 TZONE(IZON)="WRHDES"   : # depot
                              TMOD(IZON) =3
                              IZON+=1
      Endif
   Endif
   If [M:SQT1]CHGEMPCOD<>2 TZONE(IZON)="LOCTYPDES"   : # Type d'emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LOCDES"      : # Emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LPNNUMDES"   : # Contenant                   # hcb x3-77043
                           TMOD(IZON) =3                                             # hcb x3-77043
                           IZON+=1                                                   # hcb x3-77043
   Endif

#   If [M:SQT1]PRNCOD1=1    TZONE(IZON)="LBEFMT"      : # Format étiquette             # hcb 50343 deb
#                           TMOD(IZON) =3
#                           IZON+=1
#   Endif
#   If [M:SQT1]PRNSCR1>1    TZONE(IZON)="LBEFMT"      : # Présentation tableau
#                           TMOD(IZON) =9
#                           TINT(IZON) =num$([M:SQT1]PRNSCR1)
#                           IZON+=1
#   Endif
#   If [M:SQT1]PRNNBFLG1=1  TZONE(IZON)="LBENBR"      : # Nombre d'étiquettes
#                           TMOD(IZON) =3
#                           IZON+=1
#   Endif
#   If [M:SQT1]PRNNBSCR1>1  TZONE(IZON)="LBENBR"      : # Présentation tableau
#                           TMOD(IZON) =9
#                           TINT(IZON) =num$([M:SQT1]PRNNBSCR1)
#                           IZON+=1
#   Endif                                                                         # hcb 50343 fin

   If [M:SQT1]PRNCOD1=1    TZONE(IZON)="LBEFMTNEW"   : # Format étiquette
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNSCR1>1    TZONE(IZON)="LBEFMTNEW"   : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNSCR1)
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBFLG1=1  TZONE(IZON)="LBENBRNEW"   : # Nombre d'étiquettes
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBSCR1>1  TZONE(IZON)="LBENBRNEW"   : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNNBSCR1)
                           IZON+=1
   Endif

Else
    OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#                                                            hcb V6CQ fin

#                                                            hcb 50343 deb

#--- Génération des écrans et fenêtres de stock
WNOMTRS = [M:SQT0]SRTNUM
WNOMOBJ = "STQ"
ACSCOD  = [M:SQT0]ACSCOD
WLIBEL  = [M:SQT0]DESAXX
WENAFLG = [M:SQT0]ENAFLG

#----------------------------------------------#
# Fenêtre de saisie echantillonnage détail           #
#----------------------------------------------#
WINREF1="ISTOSMP1"
NOMWIN1="WQSMP"+[M:SQT0]SRTNUM+"D"
Raz NOMMSKENT    # Nom du masque d'entête de la fenêtre
MFROM="STOSMP1"
MTO="W"+WMODU+[M:SQT0]SRTNUM+"D"


Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:SQT1]IDECOD1>1    TZONE(IZON)="PALNUM"               : # Id 1
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]IDECOD2>1    TZONE(IZON)="CTRNUM"                : # Id 2
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If dim([M:SQT1]CHGWRHCOD) > 0
      If [M:SQT1]CHGWRHCOD<>2 TZONE(IZON)="WRHDES"   : # Depot
                              TMOD(IZON) =3
                              IZON+=1
      Endif
   Endif
   If [M:SQT1]CHGEMPCOD<>2 TZONE(IZON)="LOCTYPDES"   : # Type d'emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LOCDES"      : # Emplacement
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="LPNNUMDES"   : # Contenant                   # hcb x3-77043
                           TMOD(IZON) =3                                             # hcb x3-77043
                           IZON+=1                                                   # hcb x3-77043
   Endif
   If [M:SQT1]CHGPCUCOD<>2 TZONE(IZON)="PCUDES"      : # Unité destination
                           TMOD(IZON) =3
                           IZON+=1
                           TZONE(IZON)="COEDES"      : # Coefficient destination
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNCOD1=1    TZONE(IZON)="LBEFMT"      : # Format étiquette
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNSCR1>1    TZONE(IZON)="LBEFMT"      : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNSCR1)
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBFLG1=1  TZONE(IZON)="LBENBR"      : # Nombre d'étiquettes
                           TMOD(IZON) =3
                           IZON+=1
   Endif
   If [M:SQT1]PRNNBSCR1>1  TZONE(IZON)="LBENBR"      : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:SQT1]PRNNBSCR1)
                           IZON+=1
   Endif

Else
    OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#                                                            hcb 50343 fin

Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:SQT0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour contrôle qualité si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  If WINREF1="ISTOQUA"
      WNOMMSK="W"+WMODU+[M:SQT0]SRTNUM+"S": Gosub ONGLET_INVISIBLE
      I=find("SQD",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
      [F:AWI]NOMMSK(I) = WNOMMSK
      [F:AWI]FLGMSK(I) = WFLGMSK
  Elsif WINREF1="ISTOSMP"                                             # V6CQ
      WNOMMSK="W"+WMODU+[M:SQT0]SRTNUM+"E": Gosub ONGLET_INVISIBLE    # V6CQ
      I=find("SMP",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif        # V6CQ
      [F:AWI]NOMMSK(I) = WNOMMSK                                      # V6CQ
      [F:AWI]FLGMSK(I) = WFLGMSK                                      # V6CQ
  Elsif WINREF1="ISTOSMP1"                                            # hcb 50343
      WNOMMSK="W"+WMODU+[M:SQT0]SRTNUM+"D": Gosub ONGLET_INVISIBLE    # hcb 50343
      I=find("SMP",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif        # hcb 50343
      [F:AWI]NOMMSK(I) = WNOMMSK                                      # hcb 50343
      [F:AWI]FLGMSK(I) = WFLGMSK                                      # hcb 50343
  Else
      WNOMMSK="W"+WMODU+[M:SQT0]SRTNUM+"1": Gosub ONGLET_INVISIBLE
      I=find("STQ1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
      [F:AWI]NOMMSK(I) = WNOMMSK
      [F:AWI]FLGMSK(I) = WFLGMSK
  Endif
  [F:AWI]ACS       = [M:SQT0]ACSCOD
  [F:AWI]LIBEL     = [M:SQT0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SQT0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
GOK = !!OK
Return


#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0
    Local File =APPLI+".AMSK"    [AMK]
Endif
Read [AMK] CODMSK=WNOMMSK
If fstat
    Raz [F:AMK]
    WFLGMSK=2
    Return
Endif

WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
    If [F:AMK]TYPBLOC(I)<>5
        WFLGMSK=2
        Break
    Endif
Next I

Return


#########################################################################
#                   Actions sur champs écran [M:SQT1]                   #
#########################################################################

Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
    [M:SQT0]SRTTYP = 8
End

Subprog AS_PRNCOD1(VALEUR)
Variable Integer VALEUR
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
    GMENLOC(6) = 1                     # hcb X3-92342
    GMENLOC(7) = 1                     # hcb X3-92342
End

Subprog AS_QLYCRDCOD(VALEUR)
Variable Integer  VALEUR
    GMENLOC(3) = 1
End

Subprog AM_CHGEMPCOD(VALEUR)
Variable Integer VALEUR
If dim([M:SQT1]CHGWRHCOD)>0 & VALEUR=1
   [M:SQT1]CHGWRHCOD=1
   Affzo [M:SQT1]CHGWRHCOD
Endif
End

Subprog AM_CHGWRHCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
   [M:SQT1]CHGEMPCOD=2
   Affzo [M:SQT1]CHGEMPCOD
Endif
End

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(8,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(8,APPLI) From FUNSTKTRS

End


#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 8;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 8 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=8;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################

