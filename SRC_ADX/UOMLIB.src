#      TRAITEMENT LIE au process dans le module GPAO                                 #
#                                                                      03.03    MM   #
######################################################################################
#                                                                                    #
# Subprog BOMCOE(LFROMUOM, LTOUOM, ITMREF, ABREV)                                    #
#    S/P de calcul du coefficient de conversion UOM-US                               #
#                                                                                    #
# Subprog LIKQTY(LQTY, LCOE, LSTU, ABREV)                                            #
#    S/P de calcul de la quantite de lien en US                                      #
#                                                                                    #
# Subprog BOMQTY(LQTY, LCOE, ABREV)                                                  #
#    S/P de calcul de la quantite de lien en UOM                       03.04    MM   #
######################################################################################


#------------------------------------------------------------------------------------#
# BOMCOE: ss-prog de calcul du coefficient de conversion UOM-US en fonction de       #
#         la densité                                                                 #
#------------------------------------------------------------------------------------#
# Entrée  LFROMUOM   : UOM                                                           #
#         LTOUOM     : US                                                            #
#         ITMREF     : article                                                       #
#         ABREV      : abreviation de l'ecran appelant                               #
#------------------------------------------------------------------------------------#

Subprog BOMCOE(LFROMUOM, LTOUOM, LITMREF, ABREV)
Value Char     LFROMUOM
Value Char     LTOUOM
Value Char     LITMREF     # FQ 59915 GA 11/2009 avant ITMREF
Value Char     ABREV

Local Decimal  BOMCOE
Local Decimal  DUOMCOE
Local Integer  LFTYP, LTTYP

If clalev ([F:TCO])=0  Local File TABCOEFF  [TCO] Endif
If clalev ([F:ITM])=0  Local File ITMMASTER  [ITM] Endif
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif

# FQ 59046 GA 11/2009 vérifier si coef de conversion sur l'article
If [F:ITM]ITMREF<>LITMREF
    Read [ITM]ITM0=LITMREF
    If fstat : mkstat=2  : GMESSAGE = LITMREF-":"-mess(212,199,1): End : Endif
Endif

# Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
## Cas de la sous-traitance
#Local Integer  WLIKQTYCOD
## mm 01.08
#Case ABREV
#    When "BOD1","BOR1","BOS2" :
#        If dim([M]LIKQTYCOD(nolign-1))>0
#            WLIKQTYCOD = [M]LIKQTYCOD(nolign-1)
#        Else
#            WLIKQTYCOD = 1 : # Proportionnel
#        Endif
#    When "BOM1","MFMW","SCO3" :
#        If dim([M]LIKQTYCOD)>0
#           WLIKQTYCOD = [M]LIKQTYCOD
#        Else
#           WLIKQTYCOD = 1 : # Proportionnel
#        Endif
#Endcase

#If LFROMUOM = LTOUOM | WLIKQTYCOD = 2 : # Qté forfaitaire
If LFROMUOM = LTOUOM
    DUOMCOE =1
Else
  # Issue 99006 GH 13/08/2018 - Remove correction of ticket 59046 to get back to previous behaviour
  # FQ 59046 GA 11/2009 vérifier si coef de conversion sur l'article, avant action BOMCOE
#    If LTOUOM=[F:ITM]STU # Conversion vers STU
#        Case LFROMUOM
#            When [F:ITM]PUU: DUOMCOE = [F:ITM]PUUSTUCOE
#            When [F:ITM]SAU: DUOMCOE = [F:ITM]SAUSTUCOE
#            When Default:    For I = 0 To dim([F:ITM]PCU)-1
#                                 If LFROMUOM= [F:ITM]PCU(I)
#                                    DUOMCOE = [F:ITM]PCUSTUCOE(I)
#                                 Endif
#                             Next I
#        Endcase
#    Endif  # Fin - FQ 59046 GA 11/2009
    If DUOMCOE =0   # Issue 87105 GA 01/2013 except when a value already found
      Read [TCO]TCO0 = LFROMUOM;LTOUOM
      If !fstat
          If [F:TCO]COEUOM <> 0 : DUOMCOE = [F:TCO]COEUOM : Endif
      Else
          Read [TCO]TCO0 = LTOUOM;LFROMUOM
          If !fstat
              If [F:TCO]COEUOM <> 0 : DUOMCOE = 1/[F:TCO]COEUOM : Endif
          Endif
      Endif
      If DUOMCOE =0
          mkstat= 2  : GERR = 1
          GMESSAGE = mess(182,190,1) : End
      Endif
    Endif
Endif

# cas des conversions Masse/Volume
Read [TUN]TUN0=LFROMUOM
If !fstat
    LFTYP = [F:TUN]UOMTYP
Endif

Read [TUN]TUN0=LTOUOM
If !fstat
    LTTYP = [F:TUN]UOMTYP
Endif

# FQ 59046 GA 11/2009 lecture article faite + haut
###Read [ITM]ITM0 = LITMREF
###If fstat : mkstat  =2  : GMESSAGE = LITMREF-":"-mess(212,199,1): End
###Else
  # FQ 59046 GA 11/2009 ssi [F:ITM]DTY est renseigné
  ###If LFTYP =3 & LTTYP =4
    If LFTYP =3 & LTTYP =4 & [F:ITM]DTY<>0
        BOMCOE = DUOMCOE*[F:ITM]DTY    # Conversion Volume/Masse
    Elsif   LFTYP =4 & LTTYP =3 & [F:ITM]DTY<>0
        BOMCOE = DUOMCOE/[F:ITM]DTY    # Conversion Masse/Volume
    Else
        BOMCOE = DUOMCOE
    Endif
###Endif


If BOMCOE = 0
    BOMCOE = 1
    GERR=2 : GMESSAGE = mess(43,187,1)- mess(183,190,1)- mess(184,190,1)
Endif

Case ABREV
    When "BOD1"    : [M]BOMSTUCOE(nolign-1) = BOMCOE
    When "BOM1"    : [M]BOMSTUCOE = BOMCOE
    When "MFMW"    : [M]BOMSTUCOE = BOMCOE
    When "BOR1"    : [M]BOMSTUCOE(nolign-1) = BOMCOE
    When "BOS2"    : [M:BOS2]BOMSTUCOE(nolign-1) = BOMCOE : Affzo [M:BOS2]BOMSTUCOE(nolign-1) # FQ 75917 GA 10/2011 avant [M]
    When "BOS3"    : [M:BOS3]BOMSTUCOE = BOMCOE : Affzo [M:BOS3]BOMSTUCOE # FQ 75917 avant [M]xxx(nolign-1) # FQ 61093 GA 12/2009
    When "SCO3"    : [M:SCO3]OPESTRCOE = BOMCOE : Affzo [M:SCO3]OPESTRCOE # Ctrl des sources avant [M]BOMSTUCOE
Endcase

End

#------------------------------------------------------------------------------------#
# LIKQTY : ss-prog de calcul de la quantite de lien en US                            #
#------------------------------------------------------------------------------------#
# Entrée  LQTY       : quantite de lien UOM                                          #
#         LCOE       : coef UOM-US                                                   #
#         LSTU       : US                                                            #
#         ABREV      : abreviation de l'ecran appelant                               #
#------------------------------------------------------------------------------------#
Subprog LIKQTY(LQTY,LCOE,LSTU, ABREV)
Value    Decimal LQTY
Value    Decimal LCOE
Value    Char    LSTU
Value    Char    ABREV
Local    Decimal LDEC

LDEC = arr(LCOE*LQTY,0.000001)
# Issue 84759 GA 10/2012
#If LSTU<>""   # FQ 77611 GA 11/2011 arrondir
#    Call QTEARR(LDEC,LSTU) From TRTDIV
#Endif

Case ABREV
    When "BOD1"    : [M]LIKQTY(nolign-1) = LDEC
    When "BOM1"    : [M]LIKQTY =  LDEC
    When "MFMW"    : [M]LIKQTY =  LDEC
    When "BOR1"    : [M]LIKQTY(nolign-1) = LDEC
    When "BOS2"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If [M:BOS2]LIKQTYCOD(nolign-1)<>2 :
                     [M:BOS2]LIKQTY(nolign-1) = LDEC    # FQ 75917 GA 10/2011 avant [M]
                     #Endif
    When "BOS3"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If [M:BOS3]LIKQTYCOD<>2 :
                     [M:BOS3]LIKQTY = LDEC
                     #Endif # Issue 77611 # FQ 75917 GA 10/2011 ajout
    When "SCO3"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If 0 & [M:SCO3]STRQTYCOD<>2 :
                     [M:SCO3]EXTQTY = LDEC  # Ctrl des sources [M]LIKQTYCOD
                     #Endif
Endcase

End

#------------------------------------------------------------------------------------#
# BOMQTY : ss-prog de calcul de la quantite de lien en UOM                           #
#------------------------------------------------------------------------------------#
# Entrée  LQTY       : quantite de lien US                                           #
#         LCOE       : coef UOM-US                                                   #
#         ABREV      : abreviation de l'ecran appelant                               #
#------------------------------------------------------------------------------------#
Subprog BOMQTY(LQTY,LCOE,ABREV)

Value    Decimal LQTY
Value    Decimal LCOE
Value    Char    ABREV
Local    Decimal LDEC

If LCOE = 0 : End : Endif
LDEC = arr(LQTY/LCOE,0.000001)
Case ABREV
    When "BOD1"    : [M]BOMQTY(nolign-1) = LDEC : Affzo [M]BOMQTY(nolign-1)
    When "BOM1"    : [M]BOMQTY =  LDEC : Affzo [M]BOMQTY
    When "MFMW"    : [M]BOMQTY =  LDEC : Affzo [M]BOMQTY
    When "BOR1"    : [M]BOMQTY(nolign-1) = LDEC : Affzo [M]BOMQTY(nolign-1)
    When "BOS2"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If [M:BOS2]LIKQTYCOD(nolign-1)<>2 # FQ 75917 GA 10/2011
                        Call QTEARR(LDEC,[M:BOS2]BOMUOM(nolign-1)) From TRTDIV  # FQ 77611
                        [M:BOS2]BOMQTY(nolign-1) = LDEC : Affzo [M:BOS2]BOMQTY(nolign-1)
                     #Endif
    When "BOS3"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If [M:BOS3]LIKQTYCOD<>2           # FQ 75917 GA 10/2011
                        Call QTEARR(LDEC,[M:BOS3]BOMUOM) From TRTDIV            # FQ 77611
                        [M:BOS3]BOMQTY = LDEC : Affzo [M:BOS3]BOMQTY            # FQ 77611 avant EXTSTRQTY
                     #Endif
    When "SCO3"    : # Issue 89700 - 2013-08-19 by CCC : Consistency Qus = Coef * Quo must be maintained even in "fixed quantity"
                     #If [M:SCO3]STRQTYCOD<>2           # FQ 77611 avant LIKQTYCOD # FQ 75917 GA 10/2011
                        [M:SCO3]EXTSTRQTY = LDEC : Affzo [M:SCO3]EXTSTRQTY(nolign-1)
                     #Endif
Endcase


End

