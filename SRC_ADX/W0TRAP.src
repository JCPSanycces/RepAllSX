#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRAP 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SUBMITTER
mkstat = 0
zoncou = "SUBMITTER"
indice = 0
IMPENT = [M]SUBMITTER
If varinit([M]SUBMITTER,indice)=0
 IMPENT = 1
Endif
If varmode([M]SUBMITTER,indice)=0
 [M]SUBMITTER(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SUBMITTER" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SUBMITTER(indice)
 Endif
Endif
[M]SUBMITTER = IMPENT

## Zone CRN
mkstat = 0
zoncou = "CRN"
indice = 0
If varmode([M]CRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRN" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone FLGCOR
mkstat = 0
zoncou = "FLGCOR"
indice = 0
IMPENT = [M]FLGCOR
If varinit([M]FLGCOR,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCOR,indice)=0
 [M]FLGCOR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGCOR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGCOR(indice)
 Endif
Endif
[M]FLGCOR = IMPENT

## Zone FLGU31
mkstat = 0
zoncou = "FLGU31"
indice = 0
IMPENT = [M]FLGU31
If varinit([M]FLGU31,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGU31,indice)=0
 [M]FLGU31(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGU31" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGU31(indice)
 Endif
Endif
[M]FLGU31 = IMPENT

## Zone FLGREI
mkstat = 0
zoncou = "FLGREI"
indice = 0
IMPENT = [M]FLGREI
If varinit([M]FLGREI,indice)=0
 IMPENT = 1
Endif
[M]FLGREI = IMPENT

## Zone FLGINV
mkstat = 0
zoncou = "FLGINV"
indice = 0
IMPENT = [M]FLGINV
If varinit([M]FLGINV,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGINV,indice)=0
 [M]FLGINV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGINV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGINV(indice)
 Endif
Endif
[M]FLGINV = IMPENT

## Zone BOX020
mkstat = 0
zoncou = "BOX020"
indice = 0
If varmode([M]BOX020,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BOX020" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]BOX020,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "BOX020" : GZNUM = 49891 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone NOTECUST
mkstat = 0
zoncou = "NOTECUST"
indice = 0
If varmode([M]NOTECUST,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOTECUST" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TYPEXP
mkstat = 0
zoncou = "TYPEXP"
indice = 0
IMPENT = [M]TYPEXP
WNUM = IMPENT
If varinit([M]TYPEXP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPEXP,indice)=0
 [M]TYPEXP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPEXP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPEXP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYPEXP(IMPENT) From TRAP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPEXP" : GZNUM = 32516 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPEXP = IMPENT

## Zone NOPKG
mkstat = 0
zoncou = "NOPKG"
indice = 0
If varinit([M]NOPKG,indice)=0
 [M]NOPKG = "1"
Endif
If varmode([M]NOPKG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOPKG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NOPKG,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NOPKG([M]NOPKG) From TRAP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone VOLFIL
mkstat = 0
zoncou = "VOLFIL"
indice = 0
If varmode([M]VOLFIL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VOLFIL" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_VOLFIL([M]VOLFIL) From TRAP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "VOLFIL" : GZNUM = 49607 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NOREC
mkstat = 0
zoncou = "NOREC"
indice = 0
If varinit([M]NOREC,indice)=0
 [M]NOREC = "1"
Endif
If varmode([M]NOREC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOREC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NOREC,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NOREC([M]NOREC) From TRAP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRAP"
Return

