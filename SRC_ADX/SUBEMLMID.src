$VERIF_CRE
$VERIF_MOD
Local Integer ADDCNT
Local Integer K : K = 0
Local Integer I : I = 0
Local Integer ISOK : ISOK = 0
Local Integer DATYY
Local Integer ADT : ADT = 0
Local Integer CHD : CHD = 0


 #MAPAD - 2016-05-03 - Req 114309 - START
Local Char  LISTLEG(1)(1..99)
Local Integer COUNTER
Local Integer KMIEA_IND

  KMIEA_IND = 0
  Call GET_LEG_CONTRACT(LISTLEG) From SUBEML

  If LISTLEG <> ""
    For COUNTER=1 To dim([L]LISTLEG)
     If [L]LISTLEG(COUNTER) <> ""
       If func DIVPAYE.IS_MIDDLEEAST_LEG([L]LISTLEG(COUNTER))
         KMIEA_IND=1
       Endif
     Endif
    Next
  Endif

  If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
    KMIEA_IND=1
  Endif

  If KMIEA_IND=0
    Return
  Endif
#MAPAD - 2016-05-03 - Req 114309 - END



  If func DIVPAYE.EXISTE_KXX("SAFUNCTIONS")
    DATYY = func SAFUNCTIONS.CALDATYY(date$,[M:EMP2]DATBRN)
    If DATYY < 18
      If [M:EMP2]NBRGUA = 0 : ERR = 2  : GMESSAGE = mess(00015,11738,1) :    mkstat = 2 : Return : Endif
      #ADNGO - 2017-12-05 - X3-60299 - START
      #If [M:EMP3]NBRHAB = 0 : ERR = 2  : GMESSAGE = mess(00016,11738,1) :    mkstat = 2 : Return : Endif
      If [M:EMP4]NBRHAB = 0 : ERR = 2  : GMESSAGE = mess(00016,11738,1) :    mkstat = 2 : Return : Endif
      #ADNGO - 2017-12-05 - X3-60299 - END
      For [L]ADDCNT=0 To dim([M:EMP2]GUANAM)-1
        If [M:EMP2]GUANAM([L]ADDCNT) <> "" : ISOK = 1 : Endif
      Next
      If ISOK = 0 : ERR = 2  : GMESSAGE = mess(00015,11738,1) : mkstat = 2 : Return : Endif

      #For [L]ADDCNT=0 To dim([M:EMP3]PMTTYP)-1
      For [L]ADDCNT=0 To dim([M:EMP4]PMTTYP)-1
        #If [M:EMP3]PMTTYP([L]ADDCNT) = 1 : ISOK = 1 : Endif
        If [M:EMP4]PMTTYP([L]ADDCNT) = 1 : ISOK = 1 : Endif
      Next
      If ISOK = 0 : ERR = 2  : GMESSAGE = mess(00016,11738,1)-mess(00001,11734,1) : mkstat = 2 : Return : Endif
    Endif
  Endif

  For [L]ADDCNT=0 To dim([M]PMTTYP)-1
    #If [M:EMP3]PMTTYP([L]ADDCNT) > 0
    If [M:EMP4]PMTTYP([L]ADDCNT) > 0
      #If ([M:EMP3]HABEND([L]ADDCNT) = [00/00/00])
      If ([M:EMP4]HABEND([L]ADDCNT) = [00/00/00])
        GMESSAGE = mess(00008,11738,1)
        mkstat = 2
        Return
      Endif
    Endif
  Next

  If [M:EMP3]STG = 2  & (dim([M:EMP3]PASNUMMID) = 0 | [M:EMP3]PASNUMMID(0) = "")
        GERR = 2 : GMESSAGE = mess(00010,11738,1) : mkstat=2 :GOK = 0 : Return
  Endif

#  If [M:EMP0]PSD = "" Then
#    GMESSAGE = mess(00003,11738,1) - mess(00001,00751,1)
#    mkstat = 2
#    Return
#  Endif


  #FRLAA 2015-06-02 - Requirement 105483 US 3675 START
  For [L]ADDCNT=0 To NBRCHD
  If [M:EMP2]DPDTYPMID([L]ADDCNT) <> 0
    If [M:EMP2]DPDTYPMID([L]ADDCNT) = 2
      CHD += 1
    Else
     ADT += 1
    Endif
  Endif
  Next

  [M:EMP2]ADT = ADT : Affzo [M:EMP2]ADT
  [M:EMP2]CHD = CHD : Affzo [M:EMP2]CHD
  #FRLAA 2015-06-17 - Requirement 105483 US 3675 - END

Return


$MOD_CRE

Return


Subprog C_SPOTYPEMP(VALEUR)
Variable Integer VALEUR
Local Integer PERMVISA
Local Integer EMPCOUNTVIS
#Guardian/Sposnor control
#FRLAA 2015-06-17 - Requirement 105483 US 3675 - START
If VALEUR = 5 | VALEUR = 4  Then
  Diszo [M:EMP2]70
Else
  Actzo [M:EMP2]70
Endif
#FRLAA 2015-06-17 - Requirement 105483 US 3675 - END

#Checking that the number of employees sponsored through the company does not exceed the permitted visas the company may have
If VALEUR <> 5 Then : End : Endif # Not a company sponsor - no further checks needed
EMPCOUNTVIS +=1 # Counting the current employee
If clalev([F:ID])=0       : Local File EMPLOID          [ID]             : Endif
If clalev([F:CPYMID])=0   : Local File HRCOMPANYMID     [CPYMID]         : Endif

Read [CPYMID]CPYMID0=[M:EMP0]CPY
If !fstat
  PERMVISA = [F:CPYMID]NUMPRMVIS
  If PERMVISA > 0 Then
    Filter [F:ID] Where ENAFLG =2
    For [ID]ID0
      Read [EMID]EMID0=[F:ID]REFNUM
      If !fstat
        If [F:EMID]SPOTYPEMP = 5
          EMPCOUNTVIS +=1
          If EMPCOUNTVIS > PERMVISA
            GERR = 2  : GMESSAGE = mess(00007,11738,1) :    mkstat = 2
          Endif
        Endif
      Endif
    Next
  Else
    GERR = 2  : GMESSAGE = mess(00007,11738,1) :    mkstat = 2
  Endif
Else
  GERR = 2  : GMESSAGE = mess(00007,11738,1) :    mkstat = 2
Endif

End

Subprog C_EXPDATMID(VALEUR)
Variable Date    VALEUR
If dim([M:EMP3]PASDTEMID)>0
  If [M:EMP3]PASDTEMID <> [00/00/00]
    If VALEUR < [M:EMP3]PASDTEMID
      GERR = 2  : GMESSAGE = mess(00009,11738,1) :    mkstat = 2
    Endif
  Endif
Endif

End

#FRLAA 2015-06-03 - Requirement 105483 US 3675 - START
Subprog C_DATBRN(VALEUR)
Variable Date    VALEUR
Local Integer DATYY
If !func SUBEML.IS_LEG('ARE'): End : Endif
If func DIVPAYE.EXISTE_KXX("SAFUNCTIONS")
  DATYY = func SAFUNCTIONS.CALDATYY(date$,VALEUR)
  If DATYY < 15
    ERR = 2  : GMESSAGE = mess(00013,11738,1) :    mkstat = 2
  Elsif DATYY > 64
    ERR = 2  : GMESSAGE = mess(00014,11738,1) :    mkstat = 2
  Endif
Endif
End
#FRLAA 2015-06-03 - Requirement 105483 US 3675 - END

#FRLAA 2015-06-03 - Requirement 105483 US 3675 - START
Subprog C_PASDTEMID(VALEUR)
Variable Date    VALEUR
If VALEUR > date$
  GERR = 2  : GMESSAGE = mess(00181,00717,1)
  mkstat = 2
 Endif
End
#FRLAA 2015-06-03 - Requirement 105483 US 3675 - END

#FRLAA 2015-07-10 - Requirement 109427 US 3712 - START
Subprog AM_DATSTY(VALEUR)
Variable Date    VALEUR
If VALEUR < date$ : GERR = 2 : GMESSAGE = mess(00327,00139,1) : Endif
End

Subprog AM_DATWRK(VALEUR)
Variable Date    VALEUR
If VALEUR < date$ : GERR = 2 : GMESSAGE = mess(00327,00139,1) : Endif
End
#FRLAA 2015-07-10 - Requirement 109427 US 3712 - END


#FRLAA 2015-07-22 - Requirement 109427 US 3712 - START
Subprog AM_CAT(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  #Diszo [M:EMP3]PMTTYP(nolign-1)
  Diszo [M:EMP4]PMTTYP(nolign-1)
Else
  #Actzo [M:EMP3]PMTTYP(nolign-1)
  Actzo [M:EMP4]PMTTYP(nolign-1)
Endif
End
#FRLAA 2015-07-22 - Requirement 109427 US 3712 - END

#FRLAA 2015-08-06 - Requirement 110223 US 3848 - START
Subprog B3_NBRHAB
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal BASPAG
If !GWEBSERV
    SAVACT = GACTION : GACTION = "AOBJTXT"
    PARMSK(1) = "EML"
    PARMSK(2) = num$([M:EMP0]REFNUM)
    PARMSK(3) = num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))#+"~"+num$([M]PMTNUM(nolign-1))
    PARMSK(4) = "M"
    Call SAISIE_NUM(BASPAG,PARMSK,"AOBJTXT","GOBJTXT","XWAOBJTXT") From GSAISIE
    GACTION = SAVACT
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  If mkstat=2 Then
    Filter [F:AOX] Where ABREV='EML' and IDENT1=num$([M:EMP0]REFNUM) and IDENT2=num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))#+"~"+num$([M]PMTNUM(nolign-1))
    If rowcount([F:AOX])>0 Then
      [M]PJ(nolign-1)="175"
    Else
      [M]PJ(nolign-1)=""
    Endif
    Affzo [M]PJ(nolign-1)
    Filter [F:AOX]
    mkstat=4
  Endif
End



Subprog AS_PJ(VALEUR)
Variable Char    VALEUR()
#If [M]CAT(nolign-1)="" Then
#  mkstat=2
#Endif
End

Subprog CL_PJ(VALEUR)
Variable Char    VALEUR()
Call B3_NBLIG
Filter [F:AOX] Where ABREV='EML' and IDENT1=num$([M:EMP0]REFNUM) and IDENT2=num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))#+"~"+num$([M]PMTNUM(nolign-1))
If rowcount([F:AOX])>0 Then
  VALEUR="175"
Else
  VALEUR=""
Endif
Filter [F:AOX]
End


Subprog B3_NBLIG
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal BASPAG
 If !GWEBSERV
    SAVACT = GACTION : GACTION = "AOBJTXT"
    PARMSK(1) = "EML"
    PARMSK(2) = num$([M:EMP0]REFNUM)
    PARMSK(3) = num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))#+"~"+num$([M]PMTNUM(nolign-1))
    #PARMSK(3) = num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))+"~"+num$([M]PMTNUM(nolign-1))
    PARMSK(4) = "M"
    Call SAISIE_NUM(BASPAG,PARMSK,"AOBJTXT","GOBJTXT","XWAOBJTXT") From GSAISIE
    GACTION = SAVACT
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  If mkstat=2 Then
    Filter [F:AOX] Where ABREV='EML' and IDENT1=num$([M:EMP0]REFNUM) and IDENT2=num$([M]CAT(nolign-1))+"~"+num$([M]HAB(nolign-1))+"~"+num$([M]PMTTYP(nolign-1))#+"~"+num$([M]PMTNUM(nolign-1))
    If rowcount([F:AOX])>0 Then
      [M]PJ(nolign-1)="175"
    Else
      [M]PJ(nolign-1)=""
    Endif
    Affzo [M]PJ(nolign-1)
    Filter [F:AOX]
    mkstat=4
  Endif
End

#FRLAA 2015-10-30 - Requirement 105483 US 4077 - START
Subprog C_BIDNUM(VALEUR)
Variable Char VALEUR()
If !func AFNC.ACTIV("KFR")  & !func AFNC.ACTIV("KPO") Then
 PAYS = [M]BIDCRY(nolign-1)
 Call IBAN(PAYS,VALEUR,[M]IBAN(nolign-1)) From TRTBPA
 Affzo IBAN(0)
Endif
End
#FRLAA 2015-10-30 - Requirement 105483 US 4077 - END


