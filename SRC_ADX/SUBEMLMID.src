Local Integer KMIEA_IND

  KMIEA_IND = 0

  Call GET_LEG_CONTRACT(LISTLEG) From SUBEML

  If LISTLEG <> ""
    For COUNTER=1 To dim([L]LISTLEG)
    If [L]LISTLEG(COUNTER) <> ""
       If func DIVPAYE.IS_MIDDLEEAST_LEG([L]LISTLEG(COUNTER))
         KMIEA_IND=1
       Endif
    Endif
    Next
  Endif

  If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
    KMIEA_IND=1
  Endif

  If KMIEA_IND=0
    Return
  Endif
