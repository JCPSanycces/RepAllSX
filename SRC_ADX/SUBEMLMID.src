Endcase
Return


$OUVRE
  Read [ACV]CODACT="KMIEA"
  If !fstat & [F:ACV]FLACT=2
    NBTBL += 1  : TBTABLE(NBTBL) = "EMPLOIDMID"  : TYPTABLE(NBTBL) = 1
    MSKTAB(NBTBL) = "5" : TBABREV(NBTBL) = "EMID" :
    If clalev([F:EMID])=0 : Local File EMPLOIDMID    [EMID]         : Endif

    NBTBL += 1  : TBTABLE(NBTBL) = "EMPLOCTRMID" : TYPTABLE(NBTBL) = 0
    MSKTAB(NBTBL) = "5" : BASTAB(NBTBL) = "NBRCTRMID"
    If clalev([F:CTRMID])=0 : Local File EMPLOCTRMID    [CTRMID]         : Endif

  Endif
Return

