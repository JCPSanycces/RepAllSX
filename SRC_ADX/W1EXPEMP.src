#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EXPEMP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:13"
A_USER  = "DOC"
A_STAMP = "20181109230413"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EXPEMP [EX1]
Gosub HORODAT
Local Inpbox "EXPEMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [EX1] As [SIM_]
Grizo [EX1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EX1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=37 : X2(0)=76 : Y1(0)=12 : Y2(0)=17
Return

$ON_EXC
Onevent INIT_AREA Call D_EXC(zc) From W1EXPEMP
Onevent BEFORE_INPUT Call AS_EXC(zc) From W1EXPEMP
Return

Subprog D_EXC(VALEUR)
Variable Integer VALEUR
If varinit([M]EXC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EXC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ADR
Onevent BEFORE_INPUT Call AS_ADR(zc) From W1EXPEMP
Onevent INIT_AREA Call D_ADR(zc) From W1EXPEMP
Return

Subprog D_ADR(VALEUR)
Variable Integer VALEUR
If varinit([M]ADR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ADR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_ADR(VALEUR) From TRTEMP1
If mkstat=2
 [M]ADR(INDIC) = VALEUR
 Affzo ADR(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_FLGCTR
Onevent BEFORE_INPUT Call AS_FLGCTR(zc) From W1EXPEMP
Onevent INIT_AREA Call D_FLGCTR(zc) From W1EXPEMP
Return

Subprog D_FLGCTR(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGCTR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGCTR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_FLGCTR(VALEUR) From TRTEMP1
If mkstat=2
 [M]FLGCTR(INDIC) = VALEUR
 Affzo FLGCTR(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


