#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MATCLC 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:20"
A_USER  = "DOC"
A_STAMP = "20181109230520"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBCLC"
  If [M]NBCLC=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MATCLC [MCL]
Gosub HORODAT
Local Inpbox "MATCLC" From GFONCTION At A_STAMP With A_WINDPREV Mask [MCL] As [SIM_]
Grizo [MCL]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MCL]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(1)=32 : X2(1)=81 : Y1(1)=9 : Y2(1)=20
Return

$ON_DOCCLA
Onevent INIT_AREA Call D_DOCCLA(zc) From W1MATCLC
Return

Subprog D_DOCCLA(VALEUR)
Variable Integer VALEUR
If varinit([M]DOCCLA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CLASPE
Onevent CONTROL Call C_CLASPE(zc) From W1MATCLC
Onevent BEFORE_INPUT Call AS_CLASPE(zc) From W1MATCLC
Onevent AFTER_CHANGE Gosub AMM_CLASPE From W1MATCLC
Return

Subprog AS_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45815,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CLASPE(VALEUR) From MATCLC
If mkstat=2
 [M]CLASPE(INDIC) = VALEUR
 Affzo CLASPE(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CLASPE(zc) From W1MATCLC
Onkey   2 Titled GBOUTS Call S_CLASPE(zc) From W1MATCLC
Onkey 144 Titled GBOUTP Call P_CLASPE(zc) From W1MATCLC
Onkey 146 Titled GBOUTA Call SA_CLASPE(zc) From W1MATCLC
Gosub _AFF
End

Subprog C_CLASPE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
If !mkstat
 ## Action CONTHRCLC
 Call CONTHRCLC(VALEUR,[M]LEG(nolign-1),GSOCIETE) From SUBHRCLC
 If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
 If !mkstat
  ## Action STD
  Call C_CLASPE(VALEUR) From MATCLC
  If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
  If !mkstat
   ## Action CONTOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARMSK(1) = "HRCLC"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CLASPE
Call AM_CLASPE(zc)
If !mkstat & GOBJET
 zoncou = "CLASPE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CLASPE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CLASPE(VALEUR) From MATCLC
If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
Gosub _AFF
End

Subprog S_CLASPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCLC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCLC"
 PARMSK(1) = [M]LEG(nolign-1)
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCLC","SUBHRCLC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CLASPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCLC
 Call TUNHRCLC(VALEUR,[M]LEG(nolign-1),GSOCIETE) From SUBHRCLC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCLC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCLC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DESCLA
Onevent INIT_AREA Call D_DESCLA(zc) From W1MATCLC
Return

Subprog D_DESCLA(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESCLA,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLACTR","DESCLA",[M]CLASPE(nolign-1),[M]LEG(nolign-1)) From ATEXTRA
Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1MATCLC
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_ACTSELECT
Onevent INIT_AREA Call D_ACTSELECT(zc) From W1MATCLC
Return

Subprog D_ACTSELECT(VALEUR)
Variable Integer VALEUR
If varinit([M]ACTSELECT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


