#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------------
#--The "black box" method for the price search
Funprog SEARCHPRICE(MYPARAM,PLINEDOC, MYRESULT)
Variable Instance MYPARAM  Using C_SFINDPRICE
Value    Integer  PLINEDOC
Variable Instance MYRESULT Using C_RESULTPRICE

    If MYPARAM.C_LINE(PLINEDOC) = null : End [V]CST_AERROR : Endif

    Local File  ITMMASTER [ITM]
    Local File  ITMSALES  [ITS]

    Local Integer WRET

    Local Decimal WTEMPDEC
    Local Integer WTEMPINT

    Local    Decimal  WRATRPT, WCOEFDEVISE  : Raz WRATRPT
    Local    Integer  WI

    Local Integer CTX_UPDPRISAL
    Local Char WMESS(250)

    CTX_UPDPRISAL = fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"UPDPRISAL")

    If MYPARAM.PLITYP = 0 : MYPARAM.PLITYP = 1 : Endif

    If MYPARAM.GTYPGEN>0 and MYPARAM.C_LED(MYPARAM.GTYPGEN)<>null and MYPARAM.C_LED(MYPARAM.GTYPGEN).RATDIV<>0
      If MYPARAM.C_LED(MYPARAM.GTYPGEN).RATMLT<>0
        MYPARAM.MLTDIVCOE=arr((1/(MYPARAM.C_LED(MYPARAM.GTYPGEN).RATMLT/MYPARAM.C_LED(MYPARAM.GTYPGEN).RATDIV)), 10^-MYPARAM.GDECRCU)
      Endif
    Endif

    If maxtab(MYPARAM.C_LED)>0
      WI=find(MYPARAM.GSYSCUR,MYPARAM.C_LED(1..maxtab(MYPARAM.C_LED)).CURLED)
      If WI and MYPARAM.C_LED(WI)<>null and  MYPARAM.C_LED(WI).RATDIV<>0
        If MYPARAM.C_LED(WI).RATMLT<>0
          WRATRPT=arr((1/(MYPARAM.C_LED(WI).RATMLT/MYPARAM.C_LED(WI).RATDIV)), 10^-MYPARAM.GDECRCU)
        Endif
      Endif
    Endif

    #--Syracusation of the TRTPRICE.TARIFRECH subroutine
    Call TARIFRECH(MYPARAM,PLINEDOC, MYRESULT, WMESS,[L]WRET) From TRTPRICE_SYRA
    If WRET>=[V]CST_AERROR : End [L]WRET : Endif

    #====================================================================================
    #-------------------------------------------------------------------------------#
    # Prix brut à 0 : Application du prix de base sf pour composants                #
    #                                             sf pour les articles non vendus   #
    #                                             sf pour les articles sous-traités #
    #                 --> Conversion prix de base dans unité  cde                   #
    #                 --> Conversion prix de base dans devise cde                   #
    #-------------------------------------------------------------------------------#


    Read [F:ITM]ITM0 = MYPARAM.C_LINE(PLINEDOC).ITMREF
    If fstat : Raz [F:ITM] : Endif

    Read [F:ITS]ITS0 = MYPARAM.C_LINE(PLINEDOC).ITMREF
    If fstat : Raz [F:ITS] : Endif

    If MYRESULT.C_PRICE(1).MONTANT = 0 & MYRESULT.C_PRICE(1).MOTIF = 0 & MYPARAM.TYPRECH = 1 & [F:ITM]SALFLG=2 & !find(MYPARAM.C_LINE(PLINEDOC).C_SPKD(1).LINTYP, 10)
       If MYPARAM.C_LINE(PLINEDOC).SAU <> [F:ITM]SAU

          WTEMPDEC= MYPARAM.C_LINE(PLINEDOC).SAUSTUCOE #val(MYPARAM_T(0)) : # indice 0 = coef. conversion UV --> US

          If WTEMPDEC=0
              Call SREC_COE(MYPARAM.C_LINE(PLINEDOC).ITMREF,MYPARAM.BPCNUM,[F:ITM]SAU, MYPARAM.C_LINE(PLINEDOC).SAU,WTEMPDEC) From TRTVENQTE_SYRA
          Else
              # calcul coef. conversion UV cde --> UV article  car le prix de base est exprimé ds l'UV article
              # coef. conversion UV --> US / coef. conversion UV --> US de la fiche article
              WTEMPDEC = WTEMPDEC/[F:ITM]SAUSTUCOE
              WTEMPDEC = arr(WTEMPDEC,0.000001)
              If WTEMPDEC=0 : WTEMPDEC = 1 : Endif
          Endif

          If WTEMPDEC <> 0
             GROPRI = [F:ITS]BASPRI * WTEMPDEC
          Else
             GROPRI = 0
          Endif

       Else

          GROPRI = [F:ITS]BASPRI

       Endif

       If MYPARAM.CUR <> MYPARAM.GSYSCUR & GROPRI <> 0

         If WRATRPT<>0
             WCOEFDEVISE=WRATRPT
         Else
             Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR,MYPARAM.CUR,MYPARAM.GLOCALDEV,MYPARAM.CHGTYP,MYPARAM.DOCDAT,1000000000000.00,WCOEFDEVISE,WTEMPINT) From TRTDEV_SYRA
             If WTEMPINT=0 & WCOEFDEVISE<>0 WCOEFDEVISE=WCOEFDEVISE/1000000000000.00 Else WCOEFDEVISE=1 Endif
         Endif
         GROPRI = GROPRI*WCOEFDEVISE

       Endif

       # Si document avec type prix en TTC, il faut passer le prix de base (HT) en TTC
       If MYPARAM.PRITYP=2
          # Bug 84596 : Date pour conversion prix HT/TTC
          Local Date WDATCONVPRI

          If MYPARAM.VATCLCDAT<>[0/0/0] WDATCONVPRI=MYPARAM.VATCLCDAT Else WDATCONVPRI=MYPARAM.DOCDAT Endif

          Call CLCTAXEPRIV_ADAPTER(MYPARAM.ACTX, GROPRI,MYPARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(MYPARAM.C_LINE(PLINEDOC).C_VAT)),
&          1,MYPARAM.CPY,WDATCONVPRI,MYPARAM.C_LINE(PLINEDOC).QTY,MYPARAM.VACBPR, MYPARAM.VACBPR_LEG ,MYPARAM.C_LINE(PLINEDOC).CLCAMT1,MYPARAM.C_LINE(PLINEDOC).CLCAMT2,WTEMPDEC) From TRTX3_SYRA
          GROPRI = WTEMPDEC
       Endif

       GROPRI  = arr(GROPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())

       WPRIREN = CTX_UPDPRISAL

       MYRESULT.C_PRICE(1).MONTANT = GROPRI
       MYRESULT.C_PRICE(1).MOTIF   = WPRIREN

    Endif


    Gosub PE_RECHTARIF1 From TRTVENTAR_SYRA : # GPOINT="RECHTARIF1"

    #----------------------------------------------------------------#
    # Gestion des gratuits                                           #
    #----------------------------------------------------------------#

    If MYPARAM.TYPRECH = 4 End : Endif

    If MYRESULT.C_FOC(1)<>null and MYRESULT.C_FOC(1).FOCQTY <> 0 & MYRESULT.C_FOC(1).FOCITMREF = ""
      If MYPARAM.C_LINE(PLINEDOC)<>null
        MYRESULT.C_FOC(1).FOCITMREF = MYPARAM.C_LINE(PLINEDOC).ITMREF
        MYRESULT.C_FOC(1).FOCUOM    = MYPARAM.C_LINE(PLINEDOC).SAU
      Endif
    Endif

End [L]WRET
#--------------------------------------------------------------------------------------------------
$RECHGROUP1

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHGROUP1" : Gosub ENTREE From EXEFNC

Return
#--------------------------------------------------------------------------------------------------
$PE_RECHTARIF1

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHTARIF1" : Gosub ENTREE From EXEFNC

Return
#----------------------------------------------------------------#
# Recherche interdit                                             #
#----------------------------------------------------------------#
# Entrée  ITMREF   : Article                                     #
#         BPAADD   : Client livré                                #
#         REP      : Representant                                #
#         FUNCTION : 1 devis / 2 commande / 3 livraison / 4 fact #
#----------------------------------------------------------------#
Funprog SEARCHPRICE_RESTRICTED(MYPARAM, PLINEDOC, VMESSAGE)
Value    Instance MYPARAM Using C_SFINDPRICE
Value    Integer  PLINEDOC
Variable Char     VMESSAGE

  If MYPARAM                  = null     : End [V]CST_AERROR : Endif
  If MYPARAM.C_LINE(PLINEDOC) = null     : End [V]CST_AERROR : Endif
  If MYPARAM.C_LINE(PLINEDOC).ITMREF= "" : End [V]CST_AOK    : Endif :#--On considère qu'il n'y a pas d'interdit

  Local Integer WRET
  Local Integer WSAVE_PLITYP : [L]WSAVE_PLITYP = MYPARAM.PLITYP

  Local File BPCUSTOMER [BPC]
  Local File BPARTNER   [BPR]
  Local File BPDLVCUST  [BPD]
  Local File ITMMASTER  [ITM]
  Local File ITMSALES   [ITS]
  Local File SALESREP   [REP]

  Read [ITM]ITM0=MYPARAM.C_LINE(PLINEDOC).ITMREF
  If fstat
    VMESSAGE = MYPARAM.C_LINE(PLINEDOC).ITMREF-":"-mess(23,100,1)
    End [V]CST_AERROR
  Endif
  Read [ITS]ITS0=MYPARAM.C_LINE(PLINEDOC).ITMREF
  If fstat
    VMESSAGE = MYPARAM.C_LINE(PLINEDOC).ITMREF-":"-mess(23,100,1)
    End [V]CST_AERROR
  Endif

  If dim(MYPARAM.C_REP(1).REP)>0
    Read [REP]REP0=MYPARAM.C_REP(1).REP
    If fstat : Raz [F:REP] : Endif
  Endif

  If MYPARAM.BPCNUM<>""
    Read [BPR]BPR0=MYPARAM.BPCNUM
    If fstat
      VMESSAGE = MYPARAM.BPCNUM-":"-mess(23,100,1)
      End [V]CST_AERROR
    Endif
    Read [BPC]BPC0=MYPARAM.BPCNUM
    If fstat
      VMESSAGE = MYPARAM.BPCNUM-":"-mess(23,100,1)
      End [V]CST_AERROR
    Endif
    Read [BPD]BPD0=MYPARAM.BPCNUM;MYPARAM.BPAADD
    If fstat
      VMESSAGE = MYPARAM.BPCNUM+";"+MYPARAM.BPAADD-":"-mess(23,100,1)
      End [V]CST_AERROR
    Endif
  Endif

  Local Instance MYRESULT Using C_RESULTPRICE
  Local Char WMESS(250)

  MYRESULT = NewInstance C_RESULTPRICE AllocGroup null

  MYPARAM.PLITYP = 3

  #--Syracusation of the TRTPRICE.TARIFRECH subroutine
  Call TARIFRECH(MYPARAM,PLINEDOC, MYRESULT, WMESS, [L]WRET) From TRTPRICE_SYRA
  If WRET>=[V]CST_AERROR : Goto $END_RECH_INTERDIT : Endif

  If MYRESULT.INTERDIT = 1 : VMESSAGE = MYPARAM.C_LINE(PLINEDOC).ITMREF-":"-mess(27,192,1) : [L]WRET = [V]CST_AWARNING : Endif

  $END_RECH_INTERDIT
  MYPARAM.PLITYP = [L]WSAVE_PLITYP

  FreeGroup MYRESULT

End [L]WRET
