#<AdxTL>@(#)12.0.0.0 $Revision$

#########################################################################
#                                         Module Ventes - Octobre 2003  #
#     FACTURES AUTO. DES TRANSFERTS STOCKS INTER-SOCIETES               #
#                                                                       #
#     - Traitement        : FUNAUTINVT                                  #
#     - Action e_commerce : TRTAUTINVT  (Traitement standard)           #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT_TRTAUTINVT
 When "INIT"        : Gosub INIT_TRTAUTINVT
 When "DEBUT"       : Affzo [DIA]1-99
 When "OK"          : GOK=1
 When "END"         : GOK=0 : FIN=1
 When "CONTROLE"    : Gosub CONTROLE_TRTAUTINVT
 When "EXEC"        : Gosub EXEC_TRTAUTINVT
 When "TERMINE"     : Gosub TERMINE_TRTAUTINVT
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTAUTINVT
  # FGR 04/08/2014 : X3SUIVI98833 (début)
  Gosub CHECK_INVCNO_MSK From FUNAUTINVC
  If FIN = 1 Then
    Return
  Endif
  # FGR 04/08/2014 : X3SUIVI98833 (fin)
Global Shortint GINVTYP  : GINVTYP = 1  : # Type document        = Facture

#----- Ouverture des tables et déclaration des variables pour les états -----#
Gosub INIT_ETAT From TRTX3ETA
#-----

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SAUTINVT [DIA]

Raz [M:DIA]

[M:DIA]SALFCY=GFCYDEF(5)
[M:DIA]INVDAT=date$
[M:DIA]SIVTYP=GSIVTYP
[M:DIA]IPTDAT=date$

Call LECMEMO ("STD","[M:DIA]","vf7") From GMEMO

Return

#########################################################################
$CONTROLE_TRTAUTINVT
If GOK < 1  FIN=1 Else TMP=1  Endif

# --> Suppression enreg. fichier travail si interruption
Gosub DEL_SWI
If GOK < 1 : FIN=1 : Endif

Return

#########################################################################
$EXEC_TRTAUTINVT
Local Char    WPARAM(10)
#Local Decimal WAMTNOTLIN

#-- pour appel GENSIH
Local Integer LCOD   : LCOD=1
Local Char    LMAJ   : LMAJ="C"
Local Integer LECH   : LECH=2
Local Integer LTEST  : LTEST=1
Local Char    LTRT   : LTRT="FUNAUTINVT"
Local Char    LORINUM
Local Char    LSIVNUM
Local Integer LERR   : LERR=0


## --> Réalimentation GSOCIETE,GFINRSP,GLOCALDEV
#Call GETDEV([M]SALFCY) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
#If GFCY<>[M:DIA]SALFCY : GFCY=[M:DIA]SALFCY : Gosub CHARG_PARAM Endif    : # Bug 69105
GFCY=[M:DIA]SALFCY : Gosub CHARG_PARAM                                    : # Bug 69105

# --> Récupération des paramêtres de vente
Call GLOBVAR([M]SALFCY,"VEN") From TRTX3
# --> Vérification Type de facture utilisateur
Gosub VERF_SIVTYP

If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SAUTINVT","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func AFNC.ACTIV("KPO") & GCURLEG = "POR"

  If [F:TSV]SAFTINVTYP = 2
    GMESSAGE = mess(78,7711,1)
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Goto EXEC_FIN
  Endif

  If [F:TSV]AUTINV = 2
    GMESSAGE = mess(146,7711,1)
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Goto EXEC_FIN
  Endif

Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

If [M:DIA]INVDAT = [0/0/0]
    [M:DIA]INVDAT = date$
    Local Date WINVDAT
    WINVDAT=[M:DIA]INVDAT
    Gosub CTL_INVDAT
    If mkstat <> 0
        Call ECR_TRACE(mess(468,197,1)-format$(GFMDAT,[M:DIA]INVDAT)-GMESSAGE,1) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
        Goto EXEC_FIN
    Endif
Endif

# Bornage de la date de prise en compte des pièces transfert si la requête est abonnée
# Si date non renseignée, on force la date du jour
If [M:DIA]IPTDAT = [0/0/0] & [M:DIA]ABT=2 [M:DIA]IPTDAT = date$ : Endif

# --> Sélection des pièces à traiter
Gosub SEL_SGH
If GOK < 1 Goto EXEC_FIN : Endif

# --> Traitement à partir du fichier de travail
Gosub TRT_SWI
If GOK < 1 Goto EXEC_FIN : Endif

# --> Fin du traitement
$EXEC_FIN
# --> déverrouillage de toutes les pièces de transfert
For [SWI]SWI0
    SYMBOLE = "SGH"+[F:SWI]NUM
    Unlock = SYMBOLE
Next
Filter [SWI]

# --> Suppression enreg. fichier travail
Gosub DEL_SWI

Return

#########################################################################
$TERMINE_TRTAUTINVT

If NBINV
  If [M:DIA]PRNFLG=2 & [M:DIA]PRNNAM<>"" & [M:DIA]PRNDEN<>""
    Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]PRNDEN) From TRTX3ETA
  Endif
Endif

If !GSERVEUR
    If !NBINV
      Call ECR_TRACE(mess(270,192,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
    # --> Aucune facture effectuee
    If !NBINV
         GERR=2 : GMESSAGE=mess(270,192,1)
    Endif
    TRA=1
Endif

Return

#-----------------------------------------------------------------------#
#     Ouverture des fichiers et masques                                 #
#-----------------------------------------------------------------------#
$OUVRE

Local Integer  OK, NBINV
Local Char     TIT(50), CRITERE(250)
Local Char     WMESS(80)
Local Char     WKEY(20), WKEY1(66), WNUM(GLONVCR), WDATA(250)

Local Char     WRUPTFAC0 (50), WRUPTFAC1 (50)
Local Integer  INVRANG   : # les lignes de valeur identique sont sur la meme facture
#                            pour être repere dans table SWRKINV
Local Integer  LINE1_INV : # flag de 1ere ligne de facture
Local Integer  LINE1_VCR : # flag de 1ere ligne de la pièce

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:TCA])  = 0 : Local File TABCOUAFF   [TCA]  : Endif
If clalev([F:TSV])  = 0 : Local File TABSIVTYP   [TSV]  : Endif

#--- Utilisation de SWI : SWIH=Entête (1ere ligne facture)
#                         SWID=Detail (1er enr. article : support cumul des qtés)
If clalev([F:SWI])  = 0 : Local File SWRKINV     [SWI]  : Endif
If clalev([F:SWIH]) = 0 : Local File SWRKINV     [SWIH] : Endif
If clalev([F:SWID]) = 0 : Local File SWRKINV     [SWID] : Endif

If clalev([F:SIH])  = 0 : Local File SINVOICE    [SIH]  : Endif
If clalev([F:SIV])  = 0 : Local File SINVOICEV   [SIV]  : Endif
If clalev([F:SID])  = 0 : Local File SINVOICED   [SID]  : Endif
If clalev([F:SVF])  = 0 : Local File SVCRFOOT    [SVF]  : Endif
If clalev([F:SVV])  = 0 : Local File SVCRVAT     [SVV]  : Endif

If clalev([F:SGH])  = 0 : Local File SCHGH       [SGH]  : Endif
If clalev([F:SGD])  = 0 : Local File SCHGD       [SGD]  : Endif

If clalev([F:BPR])  = 0 : Local File BPARTNER    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File BPCUSTOMER  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File BPDLVCUST   [BPD]  : Endif
If clalev([F:MVC])  = 0 : Local File BPCUSTMVT   [MVC]  : Endif
If clalev([F:LCM])  = 0 : Local File LASTCUSMVT  [LCM]  : Endif
If clalev([F:CAL])  = 0 : Local File CPTANALIN   [CAL]  : Endif

If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITS])  = 0 : Local File ITMSALES    [ITS]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif

If clalev([F:GTE])  = 0 : Local File GTYPACCENT  [GTE]  : Endif
If clalev([F:CAC])  = 0 : Local File GACCCODE    [CAC]  : Endif
If clalev([F:GAC])  = 0 : Local File GACCOUNT    [GAC]  : Endif
If clalev([F:GAU])  = 0 : Local File GAUTACE     [GAU]  : Endif
If clalev([F:GAG])  = 0 : Local File GAUTACEF    [GAG]  : Endif
If clalev([F:ANM])  = 0 : Local File ACODNUM     [ANM]  : Endif
If GMODU(2)=2                :  # 105566 : Ajout test présence module compta
    If clalev([F:JOU]) = 0 Local File GJOURNAL   [JOU]  : Endif
Endif                        :  # 105566

If clalev([F:GCM])  = 0 : Local File GACM        [GCM]  : Endif
If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif   # 106867.n

If clalev([M:SCS1]) = 0 : Local Mask SCS1        [SCS1] : Endif
If clalev([M:SIH0]) = 0 : Local Mask SIH0        [SIH0] : Endif
If clalev([M:SIH1]) = 0 : Local Mask SIH1        [SIH1] : Endif
If clalev([M:SIH2]) = 0 : Local Mask SIH2        [SIH2] : Endif
If clalev([M:SIH4]) = 0 : Local Mask SIH4        [SIH4] : Endif
If clalev([M:SIHV]) = 0 : Local Mask SIHV        [SIHV] : Endif

TIT = mess(528,197,1)

#Call GETDEV(GFCYDEF(5)) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
Raz GSOC_ACTIVE : GFCY=GFCYDEF(5) : Gosub CHARG_PARAM

# ------------------------------------------- #
# Récupération des paramêtres de vente        #
# ------------------------------------------- #
Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3
# --> Vérification Type de facture utilisateur
Gosub VERF_SIVTYP

Return

#-----------------------------------------------------------------------#
#     Effacement fichier de travail si interruption auparavant          #
#-----------------------------------------------------------------------#
$DEL_SWI
Call DEBTRANS From GLOCK
Trbegin [SWI]
  Delete [SWI] Where PRONUM=adxuid(1)
  If fstat=1  GOK=-1 : GLOCK="$SWRKINV"-num$(adxuid(1))            : Goto AB_TRT
  Elsif fstat GOK= 0 : Call RSTA("SWI",num$(adxuid(1))) From GLOCK : Goto AB_TRT
  Endif
Commit
Return

#-----------------------------------------------------------------------#
#    Sélection des pièces transfert à traiter                           #
#-----------------------------------------------------------------------#
$SEL_SGH
#--> critères de saisie
CRITERE = 'SALFCY ="'+[M:DIA]SALFCY+'"'
If [M:DIA]VCRNUMDEB <> ""
   CRITERE -= '& VCRNUM >="'+[M:DIA]VCRNUMDEB+'"'
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE -= '& VCRNUM <="'+[M:DIA]VCRNUMFIN+'"'
Endif
If [M:DIA]FCYDESDEB <> ""
   CRITERE -= '& FCYDES >="'+[M:DIA]FCYDESDEB+'"'
Endif
If [M:DIA]FCYDESFIN <> ""
   CRITERE -= '& FCYDES <="'+[M:DIA]FCYDESFIN+'"'
Endif
If [M:DIA]IPTDAT <> [0/0/0]
   CRITERE -= '& IPTDAT <= [' +format$(GFMD,[M:DIA]IPTDAT)+ ']'
Endif

#--> Critères standards
CRITERE -= "& BETCPY=2"          :# Intra-société     = oui
CRITERE -= "& INVSGH=2"          :# A facturer        = oui
CRITERE -= "& INVFLG<2"          :# Etat facture      = non facturée


# V6.2 : Certification
# Si ctrl date documents : La pièce de transfert doit avoir une date <= à la date de la facture
If GCTLDATORI=2  CRITERE -='& [F:SGH]IPTDAT<=[M:DIA]INVDAT' : Endif

#--> Critères supplémentaires (par point d'entrée)
Local Char FILSUP (250)
FILSUP="1=1"
GPOINT="AUTINVTFIL" : Gosub ENTREE From EXEFNC

Raz WRUPTFAC0, WRUPTFAC1
Raz [M:SIH4]

#--- Ordre de lecture des pièces différent si factures par affaire
If [M:DIA]PJTFLG=2
   Filter [SGH] Where (evalue(CRITERE) & evalue (FILSUP)) Order By PJT
Else
   Filter [SGH] Where (evalue(CRITERE) & evalue (FILSUP))
Endif

For  [SGH]
     Gosub SEL_SGHCOMPL
     # --- écriture dans SWRKINV
     If OK = 2
        # --> lock fichier entête pièce de transfert
        SYMBOLE = "SGH"+[F:SGH]VCRNUM
        Lock = SYMBOLE
        If fstat
           # modification en cours sur un autre poste
           Call ECR_TRACE("$SCHGH :"-[F:SGH]VCRNUM-mess(10,100,1),1) From GESECRAN
           OK=1
        Endif
        If OK=2
           WRUPTFAC1 = [F:SGH]SALFCY+[F:SGH]STOFCY+[F:SGH]FCYDES
           If [M:DIA]VCRNUMFLG=2 : WRUPTFAC1 += [F:SGH]VCRNUM : Endif
           If [M:DIA]PJTFLG=2    : WRUPTFAC1 += [F:SGH]PJT    : Endif
           If WRUPTFAC0<>WRUPTFAC1             : # on change de facture
              INVRANG +=1 : LINE1_INV=1 : Raz [M:SIH4] : WRUPTFAC0=WRUPTFAC1
           Endif
           Gosub CHARGESWI
        Endif
     Endif
Next
Filter [SGH]
Return

#-----------------------------------------------------------------------#
#     Sélection complémentaires pour les entêtes transfert              #
#-----------------------------------------------------------------------#
$SEL_SGHCOMPL
OK = 2
# Pour rajouter des filtres sur les enregistrements à traiter
GPOINT="AUTINVTSEL" : Gosub ENTREE From EXEFNC

Return

#-----------------------------------------------------------------------#
#     chargement dans le fichier de travail                             #
#-----------------------------------------------------------------------#
# Remarques :                                                           #
# - un enregistrement par ligne de pièce transfert                      #
# - les lignes de même article doivent être regroupées sur la facture   #
# - indicateurs dans les enr. pour permettre les regroupements et m.a.j.#
#   SWIINT(0)=INVRANG et SWIINT(1)=0  un enr. par facture               #
#   SWIINT(0)=INVRANG et SWIINT(1)=99 autre enr. de la facture          #
#   SWICHR(0)=No pièce un enr. par pièce                                #
#   SWICHR(1)=No affaire (stocké
#-----------------------------------------------------------------------#
$CHARGESWI
Local Integer IJ0, IR0, IR1, IBK

Call DEBTRANS From GLOCK
$CHGFIC

GOK=1
Trbegin [SWI]

# -------------------> lecture entête transfert
Readlock [SGH] Curr
If    fstat=1 : GOK=-1 : GLOCK="$SCHGH"+[F:SGH]VCRNUM : Goto ROL_CHGFIC
Elsif fstat   : GOK=0  : Call RSTA("SGH",[F:SGH]VCRNUM) From GLOCK : Goto AB_TRT
Endif

# -------------------> chargement pièce dans écran SCS1
#                      pour regroupement des lignes par reference article
Raz [M:SCS1]
Raz nolign
[M:SCS1]=[F:SGH]
For [SGD] SGD0 Where VCRNUM=[F:SGH]VCRNUM
    nolign +=1
    [M:SCS1]=[F:SGD]
    [M:SCS1]NBLIG +=1
Next
$DEB_PIECE
IBK=0
For IJ0=0 To [M:SCS1]NBLIG-1
    [M:SCS1]WSTOSEQ(IJ0)=0
    IR0=find([M:SCS1]ITMREF(IJ0),[M:SIH4]ITMREF)  : # deja une ligne facture de créée
    If !IR0                                       : # il faut creer une ligne
       IR1=find("",[M:SIH4]ITMREF)                : # recherche ligne suivante libre
       If !IR1                                    : # tableau plein
          IBK=1 : Raz [M:SIH4] : INVRANG +=1 : LINE1_INV=1 : Break
         Else
          [M:SIH4]ITMREF(IR1-1)=[M:SCS1]ITMREF(IJ0)
          [M:SCS1]WSTOSEQ(IJ0)=1                  : # c'est 1ere ligne pour cet article
       Endif
    Endif
Next IJ0
If IBK : Goto DEB_PIECE : Endif
LINE1_VCR=1

For IJ0=0 To [M:SCS1]NBLIG-1
    Raz [F:SWI]
    [F:SWI]PRONUM  = adxuid(1)
    [F:SWI]SWIKEY  = [F:SGH]SALFCY
    [F:SWI]SWIKEY += [F:SGH]STOFCY
    [F:SWI]SWIKEY += [F:SGH]FCYDES

    [F:SWI]SWIKEY1 = format$("N0:6",INVRANG)+"~"
    If [M:DIA]VCRNUMFLG=2
       [F:SWI]SWIKEY1 += [F:SGH]VCRNUM     : # 1 fac/pièce
    Endif
    If [M:DIA]PJTFLG=2
       [F:SWI]SWIKEY1 += [F:SGH]PJT        : # 1 fac/affaire
    Endif
    [F:SWI]SWIKEY1 += [M:SCS1]ITMREF(IJ0)

    [F:SWI]NUM = [F:SGH]VCRNUM
    [F:SWI]LIN = [M:SCS1]VCRLIN(IJ0)
    [F:SWI]SEQ = 0

    If [M:SCS1]WSTOSEQ(IJ0)=1  [F:SWI]SWIINT(2)=0  Else  [F:SWI]SWIINT(2)=99  Endif

    If LINE1_INV=1
       [F:SWI]SWIINT(0)=INVRANG : [F:SWI]SWIINT(1)=0 : LINE1_INV=0
     Else
       [F:SWI]SWIINT(0)=INVRANG : [F:SWI]SWIINT(1)=99
    Endif

    If LINE1_VCR=1 : [F:SWI]SWICHR(0)=[F:SGH]VCRNUM : LINE1_VCR=0 : Endif


    Write [SWI]
    If fstat
       GOK=0 : Call FSTA("SWI") From GLOCK : Goto AB_TRT
    Endif
Next IJ0

Commit
Return

#-----------------------------------------------------------------------#
#     traitement : lecture du fichier de travail                        #
#-----------------------------------------------------------------------#
$TRT_SWI
Local Char FCYFIN (GLONFCY)
For [SWIH]SWI0 Where PRONUM=adxuid(1) & SWIINT(0)<>0 & SWIINT(1)=0
  Read [SGH]SGH0=[F:SWIH]NUM
  If fstat
    If    [M:DIA]VCRNUMFLG=2  GMESSAGE=mess(532,197,1)-[F:SWIH]NUM-mess(1,418,1)
                              # piece de transfert ..... non facturee
    Elsif [M:DIA]PJTFLG=2     GMESSAGE=mess(274,197,1)-mid$([F:SWIH]SWIKEY1,7,GLONPJT)-mess(1,418,1)
                              # affaire ..... non facturee
    Else                      GMESSAGE=mess(270,192,1)
                              # aucune piece de transfert traitee
    Endif
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
    Call GETFIN([F:SGH]FCYDES,FCYFIN) From DEVSUB
    Read [BPR]BPR2(2)=2;FCYFIN
    Read [BPC]BPC0=[F:BPR]BPRNUM

    Filter [SWID] Where PRONUM=adxuid(1) & SWIINT(0)=[F:SWIH]SWIINT(0) & SWIINT(2)=0

    # Appel du composant de création facture.
    Call GENSIH(LCOD, LMAJ, LECH, LTEST, LTRT, LORINUM, LSIVNUM, LERR) From TRTVENFACG

    If LERR=0
       NBINV +=1
       #--CPO 87923 Gestion des prélèvements SDD
       Gosub INIT_CTL_UMRNUM
       #--/
       If [M:DIA]PRNFLG=2 & [M:DIA]PRNNAM<>"" & [M:DIA]PRNDEN<>""
         #----- Recherche du nouveau code état à partir du modèle -----#
         If [F:BPC]BPCNUM<>[F:SIH]BPR
           Read [BPC] BPC0=[F:SIH]BPR : If fstat  Raz [F:BPC] : Endif
         Endif
         If [F:BPC]TPMCOD<>""
           If [F:TPM]TPMCOD<>[F:BPC]TPMCOD
             Read [TPM] TPM0=[F:BPC]TPMCOD : If fstat  Raz [F:TPM] : Endif
           Endif
           If [F:TPM]SALINV<>""
             WARP_RPTCOD(0)=[F:TPM]SALINV
           Else
             WARP_RPTCOD(0)=[M:DIA]PRNNAM
           Endif
         Else
           WARP_RPTCOD(0)=[M:DIA]PRNNAM
         Endif
         #----- Nombre de copies -----#
         WARP_NBRCPY=[F:SIV]COPNBR
         #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
         Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
         #-----
       Endif
    Endif

    Filter [SWID]
  Endif
Next

Return

# -------------------------------------- #
#         Traitement des erreurs         #
# -------------------------------------- #
$ROL_CHGFIC
Rollback
Call ROLL From GLOCK
If   GROLL
     Goto ERR_TRT
Else Goto CHGFIC
Endif
Return

$AB_TRT
Rollback
Raz WKEY, WKEY1, WNUM, WDATA

$ERR_TRT
WMESS =mess(17,107,1)
Call ECR_TRACE("         "+WMESS,0)From GESECRAN
Raz WMESS
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SAUTINVT) 18/04/2006 14:28:16 (JL)
######################################################################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()
Call GETSOC (GFCYDEF(5)) From DEVSUB   : # init avec societe du site ventes par defaut
VALEUR=GSOCIETE
[M]SALFCY=GFCYDEF(5)
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
GSOCIETE=VALEUR
Raz [M]SALFCY
End

########################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
#Call GETDEV(VALEUR) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
If GFCY<>VALEUR : GFCY=VALEUR : Gosub CHARG_PARAM Endif
# --> Recherche Type de facture utilisateur
Call PARAML(GFCY,"SIVTYP",GSIVTYP) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
# --> Vérif.Type de facture utilisateur : Législation identique à la législation du site
Gosub VERF_SIVTYP
[M]SIVTYP=GSIVTYP : Affzo [M]SIVTYP
End

########################################
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WINVDAT

#--CPO 75310 Before doing the control...
If GSOCIETE<>[M]CPY or GFCY<>[M]SALFCY
  # --> Chargement globales référenciels, comptes et sections de la société
  GFCY=[M]SALFCY : Gosub CHARG_PARAM
  # --> Recherche Type de facture utilisateur
  Call PARAML(GFCY,"SIVTYP",GSIVTYP) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Endif
#--CPO

WINVDAT=VALEUR
If VALEUR <> [0/0/0] Gosub CTL_INVDAT Endif
End

$CTL_INVDAT
Local Decimal    EXERCICE , PERIODE

If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif

For [PER]PER0 Where CPY=GSOCIETE & PERSTR<=WINVDAT & PEREND>=WINVDAT & LEDTYP=GTYPGEN
  EXERCICE = [F:PER]FIYNUM
  PERIODE  = [F:PER]PERNUM
Next
If EXERCICE=0 | PERIODE=0
  GMESSAGE = mess(1,104,1) : # MSG=Date incorrecte
  mkstat = 2 : Return
Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Read [FIY]FIY0 = GSOCIETE;GTYPGEN;EXERCICE
If fstat | [F:FIY]FIYSTA<>2
  GMESSAGE = mess(20,101,1) : # MSG=Exercice non ouvert
  mkstat = 2 : Return
Endif
If [F:PER]PERSTA<2
  GMESSAGE = mess(35,101,1) : # MSG=Periode non ouverte
  mkstat = 2 : Return
Endif
If [F:PER]PERSTA>2
  GMESSAGE = mess(36,101,1) : # MSG=Période fermee
  mkstat = 2 : Return
Endif
#Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
#If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : Return : Endif

# V6.2 : Certification
#----- Contrôle date pour certification NF -----#
Call CTLDAT_CNF(5,[M:DIA]SALFCY,[0/0/0],WINVDAT,"","") From CONTX3
If mkstat  Return : Endif

Return

########################################
Subprog AM_VCRNUMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]PJTFLG=1 : Grizo [M]PJTFLG Else Actzo [M]PJTFLG : Endif
End

########################################
Subprog AS_PJTFLG(VALEUR)
Variable Integer VALEUR
If [M]VCRNUMFLG=2 : mkstat=2 : Endif
End

########################################
Subprog AM_FCYDESDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]FCYDESFIN = VALEUR : Endif
End

########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AP_PRNFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Raz [M]PRNNAM, [M]PRNDEN, [M]PRNIMP, [M]PRNSRV
   Diszo [M]PRNNAM, PRNDEN
Else
   If vireblc([M]PRNNAM,2)=""
#      Call INIT_IMP("SIH", [M]PRNNAM, [M]PRNIMP) From TRTVENIMP
      Call INIT_ARP("SIH", [M]PRNNAM) From TRTVENIMP
      Actzo [M]PRNNAM, PRNDEN
   Endif
Endif
Affzo [M]PRNNAM, PRNDEN, PRNIMP, PRNSRV
End

########################################
Subprog C_PRNNAM(VALEUR)
Variable Char    VALEUR()
Local    Char    AUTSIT(10)
Local    Integer OK
# Document obligatoire si impression facture
If [M:DIA]PRNFLG = 2 & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
   End
Endif
End
########################################
Subprog C_PRNSRV(VALEUR)
Variable Char    VALEUR()
Gosub CTL_SRV From TRTVENIMP
End
########################################
Subprog C_PRNIMP(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M:DIA]PRNNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

########################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
##########################################################################

##########################################################################
#    pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIH4
#    Actions appelées dans le TRTVENFACG
##########################################################################
$ACTION_GS

Case GWACTION_GS
     When "READ_DETAIL"     Gosub READ_DETAIL
     When "MSK_ENTETE"      Gosub MSK_ENTETE
     When "MSK_DETAIL"      Gosub MSK_DETAIL
     When "ERREUR"          Gosub ERREUR
     When "CREATION"        Gosub CREATION
Endcase

Return

#-----------------------------------------------------------------------
# Chargement des ecrans entete de facture
#-----------------------------------------------------------------------
$MSK_ENTETE
Case IMPZON
     When "SALFCY"     :  IMPMOD=1 : [M]SALFCY=[F:SGH]SALFCY
     When "SIVTYP"     :  IMPMOD=1 : [M]SIVTYP=[M:DIA]SIVTYP : # Bug 62532
     When "INVDAT"     :  IMPMOD=1 : [M]INVDAT=[M:DIA]INVDAT
     When "BPCINV"     :  IMPMOD=1 : [M]BPCINV=[F:BPR]BPRNUM
                                     [M]SIHORI=9
                                     If [M:DIA]VCRNUMFLG=2
                                        [M]SIHORINUM=[F:SGH]VCRNUM
                                     Endif
                          # On ne passe pas en saisie du site d'expé : Actzo [M]STOFCY en AM_BPCINV inopérant
                          [M]STOFCY=[F:SGH]STOFCY
     When "BPAADD"     :  IMPMOD=1 : [M]BPAADD=[F:SGH]FCYADD : # Bug 61680
                          # Bug 66519 : Init du client cde avec le client associé au site d'achat
                          Read [BPR]BPR2(2)=2;[F:SGH]PURFCY
                          If fstat=0
                              [M]BPCORD=[F:BPR]BPRNUM : GBPCNUM=[F:BPR]BPRNUM
                          Endif
     When "PJT"        :  IMPMOD=1 : [M]PJT=[F:SGH]PJT
                          # On ne passe pas en saisie du site d'expé : Actzo [M]STOFCY en AM_BPCINV inopérant
     When "STOFCY"     :  IMPMOD=1 : [M]STOFCY=[F:SGH]STOFCY
     When "CCE"
                          #FQ68364 Axes lignes Contrat de service vers facture
                          #Chargement des sections analytiques entête facture à partir du contrat
                          Call CHARG_CCEH("SIH2","NBAXE","SGH") From TRTX3CPT
                          #Initialisation sections analytiques vides
                          If dim([M:SIH2]NBAXE)>0
                              Local Char SECTION
                              For I=1 To GNBDIE
                                  #If [F:SIH]CCE(I-1)=""
                                  If [M:SIH2]CCE(I-1)=""
                                      [F:SIH]DIE(I-1)=GDIE(I)
                                      [M:SIH2]DIE(I-1)=GDIE(I)
                                      Call INISEC(SECTION,"SIH",GDIE(I)) From SUBCDE
                                      [F:SIH]CCE(I-1) = SECTION
                                      [M:SIH2]CCE(I-1) = SECTION
                                  Endif
                              Next I
                          Endif
                          #fin FQ68364
Endcase

Return

#-----------------------------------------------------------------------
# Lecture des enregistrements details
# - le filter des lignes doit être actif
# - on ne fait que de la création de lignes
#-----------------------------------------------------------------------
$READ_DETAIL
nolign=0 : LIG_DETAIL="C"     : # uniquement de la creation
Local Decimal CUMQTY

If LEC_DETAIL=0
    Read [SWID] First
Else
    Read [SWID] Next
Endif
If    !fstat        : # lecture ok
   LEC_DETAIL=1
   For [SWI] Where SWIKEY1=[F:SWID]SWIKEY1
       Read [SGD]SGD0=[F:SWI]NUM;[F:SWI]LIN
       If fstat : Raz [F:SGD] : Endif
       CUMQTY += [F:SGD]QTYSTUDES
   Next
   Read [SGD]SGD0=[F:SWID]NUM;[F:SWID]LIN
   If fstat : Raz [F:SGD] : Endif
   [F:SGD]QTYSTUDES=CUMQTY
Elsif fstat=4       : # fin lecture
   LEC_DETAIL=2
Elsif fstat         : # erreur
   LEC_DETAIL=3   : GBIDC3="SWRKINV [SWID]"
Endif

Return

#-----------------------------------------------------------------------
# Chargement d'une ligne dans l'ecran SIH4 des factures
#-----------------------------------------------------------------------
$MSK_DETAIL

Case IMPZON
     When "ITMREF"     :  IMPMOD=1 : [M]ITMREF(nolign-1)= [F:SGD]ITMREF
     When "SAU"        :  IMPMOD=1 : [M]SAU(nolign-1)= [F:SGD]STU
     When "QTY"        :  IMPMOD=1 : [M]QTY(nolign-1)=[F:SGD]QTYSTUDES
     When "GROPRI"        # --- ligne issue d une piece de transfert (sur champ declencheur)
                          If [M:SIH1]SIHORINUM=""
                             [M]SGHNUM(nolign-1)="$"                : # plusieurs pieces sur la facture
                          Else
                             [M]SGHNUM(nolign-1)=[M:SIH1]SIHORINUM  : # une seule piece sur la facture
                          Endif
     When "CCE1"
                         #FQ68364
                         # Chargement sections analytiques
                         Call CHARG_ACCCCE(nolign-1,"","","[M:SIH4]CCE",
&                                          "SGD",29,[F:SGD]VCRNUM,[F:SGD]VCRLIN,0,"") From TRTX3CPT
                         # Initialisation des sections analytiques vides
                         Local Integer I
                         Local Char    SECTION
                         For I=1 To GNBDIE
                            If evalue("dim([M]CCE"+num$(I)+"(nolign-1))") >0 & evalue("[M]CCE"+num$(I)+"(nolign-1)")=""
                                Call INISEC(SECTION, "SID", I) From TRTX3CPT
                                Assign "[M]CCE"+num$(I)+"(nolign-1)" With SECTION
                            Endif
                         Next
                         #fin FQ68364
Endcase
# pour avoir le no. de la ligne et la reference article dans l'erreur
GCLE=mess(3,40,1)-num$(nolign)-mess(18,7,1)-[M]ITMREF(nolign-1)
Return

#-----------------------------------------------------------------------
# Erreur lors du garnissage des ecrans facture
#-----------------------------------------------------------------------
$ERREUR
If LERR=4
   GBIDC3=GBIDC3-mess(532,197,1)-[F:SGD]VCRNUM+"   "+mess(18,7,1)-[M:SIH4]ITMREF(nolign-1)
Endif
Return

#-----------------------------------------------------------------------
# Tables mises a jour lors de la creation de facture
# ( on est dans une transaction : en cas d'erreur positionner GOK )
#-----------------------------------------------------------------------
$CREATION
For [SWI] Where PRONUM=adxuid(1) & SWIINT(0)=[F:SWIH]SWIINT(0) & SWICHR(0)<>""
    Readlock [SGH] SGH0=[F:SWI]SWICHR(0)
    If fstat=1  GOK = -1
                GLOCK = "$SCHGH"-[F:SGH]VCRNUM
                Break
    Elsif fstat GOK =  0
                Call RSTA ("SGH",[F:SGH]VCRNUM) From GLOCK
                Break
    Endif
    [F:SGH]SIHNUM=[M:SIH0]NUM : [F:SGH]INVFLG=2
    Rewrite [SGH]
Next
Return


###########################################################################################
# Appelé dans SUBSIHA
# Reinitialisation des enr. transfert si suppression de facture
# ( on est dans une transaction : en cas d'erreur positionner GOK )
###########################################################################################
$ANNULESCS
If clalev([F:SGH])=0 : Local File SCHGH [SGH] : Endif
For [SGH]SGH1 Where SIHNUM=[M:SIH0]NUM
    Readlock [SGH] Curr
    If fstat=1  GOK = -1
                GLOCK = "$SCHGH"-[F:SGH]VCRNUM
                Break
    Elsif fstat GOK =  0
                Call RSTA ("SGH",[F:SGH]VCRNUM) From GLOCK
                Break
    Endif
    Raz [F:SGH]SIHNUM : [F:SGH]INVFLG=1
    Rewrite [SGH]
Next
Return

##########################################################################
Subprog C_PRNDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M:DIA]PRNNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

##########################################################################
Subprog AP_PRNDEN(VALEUR)
Variable Char    VALEUR()
Call INIT_SRV(VALEUR, [M]PRNSRV,[M]PRNIMP) From TRTVENIMP
Affzo [M]PRNSRV, PRNIMP
[M:DIA]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)#Fq73266-Gbn
End

######################################################################################
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)

# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# --- Si changement société -----#
If GSOC_UPDFLG
    # --- Chargement des paramètres de localisation
    # --- Numérotation Argentine -----#
    If func AFNC.ACTIV("KAG")
        Call PARAML(GFCY,"ARGNUM",PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
        GLOCARGNUM=val(PARAM2)
        If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
    Else
        Raz GLOCARGNUM
    Endif
    # --- Utilisation systeme de taxe
    Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
#    If func AFNC.ACTIV("KUS")  # 106867.so
#        Call PARAM(GFCY,"USATAX",PARAM2) From ADOVAL
#        GLOCUSATAX=val(PARAM2)
#        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#    Else
#      Raz GLOCUSATAX
#    Endif  # 106867.eo
    # --- Contrôle date documents
    Call PARAML(GFCY,"CTLDATORI",PARAM2)    From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GCTLDATORI=val(PARAM2)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
Endif

Return

#-----------------------------------------------#
# Contrôle de la législation du type de facture #
#-----------------------------------------------#
$VERF_SIVTYP
If [F:TSV]SIVTYP<>GSIVTYP & GSIVTYP<>""
    #- X3Suivi 71937 Multi-législation -#
    #Read [TSV]TSV0 = GSIVTYP
    Local Integer WRET
    Call LEC_TSV_LEG(GCURLEG,GSIVTYP,WRET) From TRTLECLEG
    If WRET Raz [F:TSV] : Endif
Endif
If [F:TSV]LEG<>GCURLEG & GCURLEG<>"" & [F:TSV]LEG<>""
    Raz GSIVTYP
Endif
Return
#--CPO 87923 Gestion des prélèvements SDD
#-----------------------------------------------#
#--On initialise et on contrôle le mandat       #
#-----------------------------------------------#
$INIT_CTL_UMRNUM
Local Char WMESS_UMRNUM(250)

Read [F:SIH]SIH0= LSIVNUM
If !fstat
  Raz WMESS_UMRNUM
  Call INIT_CTL_UMRNUM([F:SIH]CPY,[F:SIH]BPRPAY,[F:SIH]PTE,[F:SIH]UMRNUM,WMESS_UMRNUM) From TRTVENSDD
  If WMESS_UMRNUM<>""
	  Call ECR_TRACE(mess(55,198,1)-[F:SIH]NUM-":"-WMESS_UMRNUM,-1) From GESECRAN
  Endif
Endif

Return
#--/
######################################################################################
## Section automatically added (screen SAUTINVT) 11/25/2014 11:46:23 (RICAR)
######################################################################################
Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func AFNC.ACTIV("KPO") & GCURLEG = "POR"
  Call VAL_SIVTYP(VALEUR) From PORLEGLIB
  Call VAL_AUTINV(VALEUR) From PORLEGLIB
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End


