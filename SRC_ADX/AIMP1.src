Subprog IB_VALEUR1
If DEBFIN(nolign-1) <> 3
 GBOUT3 = ""
Else
 Local Integer I,J
 For I=0 To [M:RPT]NBPLAG-1
  If [M:RPT]PARCOD(nolign-1) = [M:RPT]PARPLAG(I)
   J+=1
  Endif
 Next I
 If J>1
  GBOUTS = ""
  GBOUT1 = ""
  GBOUT2 = ""
 Elsif J=1
  I=find([M:RPT]PARCOD(nolign-1) ,[M:RPT]PARPLAG(0..[M:RPT]NBPLAG-1))
  If I
   If [M:RPT]BORPLAG(I-1) = 1
    GBOUT2= ""
   Endif
  Endif
 Endif
Endif
End

######################################################################################
#                    SUBPROG de controle
######################################################################################

Subprog CONTPAD(PARTYP,VALINT,VALEUR)
Value Char     PARTYP
Variable Char  VALINT
Variable Char  VALEUR
Local Integer I
If GPRODUIT=1 : ## GEODE
 #CHECK UNUSED_BEGIN
 Call LECTURE("ATY",[L]PARTYP,"") From CONTOBJ
 I=0
 #--- JDE X3Suivi:32616   14/11/2006  ---#
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM7  ---#
 If I=0
  I=find("PADNUM7",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM7(VALEUR) From LOGDIV
   [L]VALINT = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM8  ---#
 If I=0
  I=find("PADNUM8",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM8(VALEUR) From LOGDIV
   [L]VALINT = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM9  ---#
 If I=0
  I=find("PADNUM9",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM9(VALEUR) From LOGDIV
   [L]VALINT = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM10  ---#
 If I=0
  I=find("PADNUM10",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM10(VALEUR) From LOGDIV
   [L]VALINT = VALEUR
  Endif
 Endif
 #-- Fin formatage --#
 #CHECK UNUSED_END
Endif
End

Subprog CONTGEN(VALINT1,OBJET,DEBFIN,NOLIB,PAROBJ,TYP,CONTROLE,PAROPT)
Value Char    VALINT1
Value Char    OBJET
Value Integer DEBFIN
Value Integer NOLIB
Value Char    PAROBJ
Value Integer TYP
Value Char    CONTROLE
Value Char    PAROPT
If GPRODUIT=1 : ## GEODE
 Call CONTEVAL([L]TYP,[L]VALINT1,[L]CONTROLE)
 If mkstat : End : Endif
Endif
If [L]OBJET<>"" & [L]DEBFIN<2
 If dim([M]PARTYP(nolign-1))>0 & [M]PARTYP(nolign-1)<>""
  Local Integer K
  Call LECTURE("ATY",[M]PARTYP(nolign-1),"") From CONTOBJ
  K = find("CONTOBJN",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If K
   End : #115690  no control becasue CONTOBJN in the datatyp
  Endif
 Endif
 Local Char SUPP(10)
 If [L]OBJET="ADI"
  SUPP = num$([L]NOLIB)
 Elsif [L]PAROBJ<>""
  SUPP = num$(evalue([L]PAROBJ)) : # mb 7.5.2 bug 14220
 Endif
 Call CONTROLE([L]OBJET,"!$"+[L]PAROPT,VALINT1,SUPP,mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog CONTEVAL(TYP,VALCONT,CONTROLE)
Value Integer TYP
Value Char    VALCONT
Value Char    CONTROLE
Local Integer OK
Case [L]TYP
 When 1         : Local Integer VALPAR      : VALPAR = val(VALCONT)
 When 2,3,4,5,6 : Local Decimal VALPAR      : VALPAR = val(VALCONT)
 When 7         : Local Char    VALPAR(250) : VALPAR = VALCONT
 When 8         : Local Date    VALPAR      : VALPAR = gdat$(VALCONT)
Endcase
If [L]CONTROLE<>""
 Call EVALCONT(OK,[L]CONTROLE,VALPAR)
 If !OK
  GMESSAGE = mess(7,135,1) : # Valeur incorrecte
  mkstat = 2
 Endif
Endif
End

Subprog CONTADI(NOLIB,OBJET,DEBFIN,VALCONT)
Value Integer NOLIB
Value Char    OBJET
Value Integer DEBFIN
Value Char    VALCONT
If [L]NOLIB<>0 & [L]OBJET="ADI" & [L]DEBFIN<>2 & VALCONT<>""
 Read [ADI]CODE = [L]NOLIB;VALCONT
 If fstat
  GMESSAGE = mess(7,135,1) : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

Subprog CONTFIN(TYP,VALINT1,VALINT2,OK)
Value Integer    TYP
Value Char       VALINT1
Value Char       VALINT2
Variable Integer OK
Case [L]TYP
 When 1,2,3,4,5,6 :
  If val([L]VALINT2)<>0 & val([L]VALINT2)<val([L]VALINT1)
   OK = 0
  Endif
 When 7
  If [L]VALINT2<>"" & [L]VALINT2<[L]VALINT1 : OK = 0 : Endif
 When 8
  If gdat$([L]VALINT2)<>[0/0/0] & gdat$([L]VALINT2)<gdat$([L]VALINT1)
   OK = 0
  Endif
Endcase
If !OK
 GMESSAGE = mess(8,135,1) : # Valeur trop petite
 mkstat = 2 : End
Endif
End

$CONTPAR1
Local Integer NOL
#------------------------------- Pour les impressions
#[M:APG]VALEUR4  = PARAM(13)   : # [M:RPT]PARTYP(nolign-1)
#[M:APG]VALEUR5  = PARAM(14)   : # [M:RPT]PAROBJ(nolign-1)
#[M:APG]VALEUR6  = PARAM(15)   : # num$([M:RPT]TYP(nolign-1))
#[M:APG]VALEUR7  = PARAM(16)   : # [M:RPT]CONTROLE(nolign-1)
#[M:APG]VALEUR8  = PARAM(17)   : # [M:RPT]OBJET(nolign-1)
#[M:APG]VALEUR9  = PARAM(18)   : # ""
#-----------------------------------------------------------
NOL = nolign-1
Call CONTPAD([M:APG]VALEUR4,[M:APG]VALINT1(NOL),VALEUR)
Call CONTGEN([M:APG]VALINT1(NOL),[M:APG]VALEUR8,[M:APG]BORNE(NOL),[M:APG]NOLIB,[M:APG]VALEUR5
&   ,val([M:APG]VALEUR6),[M:APG]VALEUR7,[M:APG]OPTION)
If mkstat : Return : Endif
If GPRODUIT<>1 : ## GEODE
 Call CONTEVAL(val([M:APG]VALEUR6),[M:APG]VALINT1(NOL),[M:APG]VALEUR7)
 If mkstat : Return : Endif
Endif
Call CONTADI([M:APG]NOLIB,[M:APG]VALEUR8,[M:APG]BORNE(NOL),[M:APG]VALINT1(NOL))
Return

$CONTPAR2
Local Integer OK,NOL
NOL = nolign-1
Call CONTPAD([M:APG]VALEUR4,[M:APG]VALINT2(NOL),VALEUR)
OK = 1
Call CONTFIN(val([M:APG]VALEUR6),[M:APG]VALINT1(NOL),[M:APG]VALINT2(NOL),OK)
If !OK : mkstat = 1 : Return : Endif
Call CONTEVAL(val([M:APG]VALEUR6),[M:APG]VALINT2(NOL),[M:APG]VALEUR7)
Return

Subprog IB_PRTORIENT
End

