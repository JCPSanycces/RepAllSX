#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(20)(1..3) , VALEUR(20)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

####################################################################################
## AIMP0    Sélection de l'état
## AIMP1    Saisie paramètres
## AIMP2    Impressions différées, segmentation
## AIMP3    Exécution état
## AIMP4    Gestion des mémos
####################################################################################

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "TIR"         : Gosub TIR
 When "GAU"         : Gosub GAU
 When "SVG","PRG"   : Gosub SVG
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "PRE"         : Gosub PRECEDENT
 When "SUI"         : Gosub SUIVANT
 When "HLP"         : Gosub HLP
 When "RAF"         : Gosub RAF
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "BOUTON"      : Gosub BOUTON
 When "CONTPAR1"    : Gosub CONTPAR1
 When "CONTPAR2"    : Gosub CONTPAR2
 When "FIN"         : Gosub FIN
Endcase
Return

#############
$FIN
Local Char IACTION(20)
Onerrgo RIEN
IACTION = "FINAIMP1" : Gosub ACTINI
Onerrgo
Return

########################################
$INIT
If val(PARAM(3))>0 : # Impression par groupe
 If PARAM(1)=""
  FIN = 1 : Return
 Else
  PARAM(2) = GFONCTION
 Endif
Endif
TMP = 1
Gosub DECLARE
Return

$DECLARE
Local Integer ER , STAT
Local Char    RETOUR(10) , ETAT(GLONARP)
GIMPETAT = 0
Gosub OUVFIC
If clalev([M:AIP])=0 : Local Mask AIMP0    [AIP] : Raz [M:AIP] : Endif
If clalev([M:RPT])=0 : Local Mask AIMP1    [RPT] : Raz [M:RPT] : Endif
Return

########################################
$CONTROLE
If GSERVEUR
 Call LEC_REQUETE From AIMP3
Endif
Return

########################################
$CONT_BATCH
If [M]IMPRIME=3
 If dim([M]NBDEST)>0
  Gosub SET_MEL
  If !MELWRK
   Gosub SAIDEST From AIMP3
  Endif
 Endif
Endif
Return

########################################
$EXEC
If GSTATUT<>GSTAESC
 RETOUR = ""
If adxusr="" : GTEST = 1 : Endif

Call IMPRIME([M]RPTCOD,[M]LANGUE,[M]NBRPAR,[M]PARCOD,[M]TYP,[M]PARTYP,[M]NOLIB
&            ,[M]DEBFIN,[M]VALINT1,[M]VALINT2,[M]DIFFERE
&            ,[M]IMPRIME,[M]SERVEUR,[M]IMPRIMANTE,[M]PRTPOR,[M]PRTDRV
&            ,[M]PRTDES,[M]NBRCPY,[M]ASSCPY,[M]PAGDEB,[M]PAGFIN,[M]FICHIER,[M]FMTFIC
&            ,[M]NBSEG,[M]VALSEG,[M]DIFDAT,[M]DIFTIM,[M]DIFSRVC,[M]FORPAP
&            ,[M:AIP]TBPAR,[M:AIP]TBVAL,[M]MESSAGE,[M]NBPLAG,[M]PARPLAG,[M]BORPLAG,[M]VALPLAG1,[M]VALPLAG2,RETOUR,ER)
& From AIMP3
If adxusr="" : GTEST = 0 : Endif
 GERR = ER
 GOLDETAT = [M]RPTCOD
 GIMPETAT = [M]IMPRIME
 ETAT = [M]RPTCOD
 OK = 1
 IACTION = "FIN" : Gosub ACTINI
 If !OK : SAI = 1 : Return : Endif
 GPE = 0
 GPOINT = "FIN" : Gosub ENTREE From EXEFNC
 If GPE : PARAM(1) = ETAT : SAI = 1 : Return : Endif
 If PARAM(1)="" or val(PARAM(3))>0 : SAI = 1 : Return : Endif
Endif
Return

########################################
$OUVRE_BATCH
Gosub OUVFIC
If clalev([M:AIP])=0 : Local Mask AIMP0 [AIP]    : Raz [M:AIP] : Endif
TYPPRG = 4
Return

########################################
$OUVFIC
If clalev([F:ARP])=0  : Local File AREPORT   [ARP]  : Endif
If clalev([F:ARD])=0  : Local File AREPORTD  [ARD]  : Endif
If clalev([F:ARO])=0  : Local File AREPORTS  [ARO]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE     [ATY]  : Endif
If clalev([F:ADP])=0  : Local File ADOPAR    [ADP]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif
If clalev([F:AUS])=0  : Local File AUTILIS   [AUS]  : Endif
If clalev([F:AFT])=0  : Local File AFCTFCT   [AFT]  : Endif
If clalev([F:ARV])=0  : Local File AREPORTV  [ARV]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL    [ADW]  : Endif
If clalev([F:ACT])=0  : Local File ACTION    [ACT]  : Endif
If clalev([F:AIM])=0  : Local File APRINTER  [AIM]  : Endif
If clalev([F:AID])=0  : Local File APRINTDES [AID]  : Endif
If clalev([F:AIA])=0  : Local File APRTAUS   [AIA]  : Endif
If clalev([F:ACC])=0  : Local File ACCES     [ACC]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ABH])=0  : Local File ABATHOR   [ABH]  : Endif
If clalev([F:ABC])=0  : Local File ABATCAL   [ABC]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV     [ACV]  : Endif
Return

########################################
$OUVRE
Local Integer OK , I , J , K , L , NOL , ER , STAT , OKTRT
Local Char    CRITERE(250) , CRIRAP(250) , CRITRAP(250)
Local Char    ZONE(20) , CHAMP(30)
Local Char    AUTSIT(10)
Local Char    SERVEUR(30)
Local Date    DIFDAT
Local Char    DIFTIM(10) , DIFSRVC(10)
Local Char    SAVACT(20) , IACTION(20)
Local Integer OBLIG
Local Char    ETAT(GLONARP) , FONCTION(GLONAFC)
Local Char    BROW1(10) , BROW2(10)
Local Integer DIFIMP , ONBRCPY , OASSCPY
Local Char    MESSAGE(250)

CRITRAP = "1=1"
Return

########################################
$DEBUT
K = find("AR0",OBJLIS) : # Liste simple
If K : BROW1 = "GAU_CHE"+num$(K-1) : Endif
K = find("ARP",OBJLIS) : # Liste par groupe
If K : BROW2 = "GAU_CHE"+num$(K-1) : Endif

ETAT     = PARAM(1)
FONCTION = PARAM(2)

If GBATCH & [M]RPTCOD<>""
 ETAT = [M]RPTCOD
 Call EXE_RPTCOD(ETAT,MESSAGE,STAT)
 If STAT
  Call ERREUR(ETAT-":"-MESSAGE) From GESECRAN
  GSTATUT = GSTAESC : FIN = 1
 Else
  If find([M]IMPRIME,2)
   ONBRCPY = [M]NBRCPY
   OASSCPY = [M]ASSCPY
  Elsif find([M]IMPRIME,6)
   ONBRCPY = [M]NBRCPY
  Endif
  Call CONT_PRT([M]PRT)
  If find([M]IMPRIME,2)
   [M]NBRCPY = ONBRCPY
   [M]ASSCPY = OASSCPY
  Elsif find([M]IMPRIME,6)
   [M]NBRCPY = ONBRCPY
  Endif
  If mkstat
   Call MESSAGE(ETAT-":"-GMESSAGE) From GESECRAN
  Endif
  [M]BATCH = GBATCH
  Affzo
  If [F:ARP]PARSEG<>""
   For I=0 To [M]NBRPAR-1
    If PARCOD(I)=tolower([F:ARP]PARSEG)
     Chgstl [M]PARDES(I) With "AMKACT"
    Endif
   Next I
  Endif
  If GFONCTION1="GESABA"
   IACTION = "OUVRE" : Gosub ACTINI
   Gosub REMPLIT_TIR
  Else
   Diszo RPTCOD
  Endif
 Endif
 Return
Endif

# Pour garder les paramètres saisis après une impression
If [M]RPTCOD<>"" & [M]RPTCOD=GOLDETAT & ETAT=[M]ETAT  : # bug 51547  suppp de la conditon GSTATUT=GSTABOU+1
 Call CONT_PRT([M]PRT)
 Gosub REMPLIT_PLAG
 Affzo
 If PARAM(1)=""
  Gosub REMPLIT_TIR
  Actzo RPTCOD
 Else
  Diszo RPTCOD
 Endif
 ETAT = [M]RPTCOD
 Call LECTURE("ARP",ETAT,"") From CONTOBJ
 If [F:ARP]PARSEG<>""
  For I=0 To [M]NBRPAR-1
   If PARCOD(I)=tolower([F:ARP]PARSEG)
    Chgstl [M]PARDES(I) With "AMKACT"
   Endif
  Next I
 Endif
 IACTION = "OUVRE" : Gosub ACTINI
 Return
Endif

If !GBATCH or [M]RPTCOD=""
 Raz [M]
Else
 Affzo
Endif

[M]ETAT  = ETAT
[M]BATCH = GBATCH
If GBATCH
 [M]IMPDIF = 2
Endif
If ETAT="" & GOLDETAT<>""
 Call EXE_RPTCOD(GOLDETAT,MESSAGE,STAT)
 If !STAT
  ETAT = GOLDETAT
 Endif
Endif
If ETAT<>""
 Gosub CHARGE
 If STAT
  GSTATUT = GSTAESC : FIN = 1 : Return
 Endif
Endif
If [M]ETAT=""
 Gosub REMPLIT_TIR
 Actzo RPTCOD
Else
 Diszo RPTCOD
Endif
Call LECTURE("ARP",ETAT,"") From CONTOBJ
Return

########################################
$REMPLIT_PLAG
Local Integer I,J,K
For K=1 To [M:RPT]NBRPAR
 J=0
 If [M:RPT]DEBFIN(K-1)= 3
  For I=0 To [M:RPT]NBPLAG-1
   If [M:RPT]PARCOD(K-1) = [M:RPT]PARPLAG(I)
    J+=1
   Endif
  Next I
 Endif
 If J>1
  Chgstl [M:RPT]VALEUR1(K-1) With "APARPLAG"
  Chgstl [M:RPT]VALEUR2(K-1) With "APARPLAG"
  Affzo
 Endif
Next K
Return

########################################
$TIR
If currbox<>BOXCURR & [M]ETAT=""
 Gosub REMPLIT_TIR
Endif
Return

########################################
$RAF
If [M]ETAT=""
 Raz SAIRAP , FILSUITE , IFILSUITE
 Gosub REMPLIT_TIR
Endif
Return

########################################
$REMPLIT_TIR
If find(currbox,BROW1,BROW2)
 Gosub REMPLIT From GSAISIE
 Raz [F:ARP]
Endif
Return

########################################
$FILGAUCHE
If find(currbox,BROW1,BROW2)
 FILGAUSUP = '([F:ARP]LAN=GLANGUE or [F:ARP]MULLAN=2) & [F:ARP]EXEFLG<>2 & [F:ARP]ENAFLG=2'
 FILGAUSUP -= '& [F:ACC]EXEC=2'
Endif
Return

########################################
$SVG
If [M]ETAT<>""
 FOK = 0
Endif
Return

########################################
$GAU
ETAT = [F:ARP]RPTCOD
Gosub CHARGE
Return

########################################
$HLP
Hlpbox "ARP_"+[M]RPTCOD
Return

########################################
$APRES_MODIF
Case zoncou
 When "RPTCOD"
  Raz [M:RPT]NBPLAG , [M:RPT]PARPLAG, [M:RPT]VALPLAG1 , [M:RPT]VALPLAG1 , [M:RPT]BORPLAG
  Call CHANGE_RPTCOD(zc,FONCTION)
  IACTION = "OUVRE" : Gosub ACTINI
  Gosub SETBOX From =WINPROG
Endcase
Return

########################################
$CHARGE
Call EXE_RPTCOD(ETAT,MESSAGE,STAT)
If STAT
 Call ERREUR(ETAT-":"-MESSAGE) From GESECRAN
 Return
Endif
Raz [M:RPT]NBPLAG , [M:RPT]PARPLAG, [M:RPT]VALPLAG1 , [M:RPT]VALPLAG1 , [M:RPT]BORPLAG
Call CHANGE_RPTCOD(ETAT,FONCTION)
IACTION = "OUVRE" : Gosub ACTINI
Affzo
Gosub SETBOX From =WINPROG
Return

########################################
$SETBOUT
Raz CHBOU,CHMEN
If [M]ETAT=""
 CHBOU += "09="
Endif
Call VERF_DIFF(GUSER,DIFIMP)
If [M]RPTCOD<>""
 If [M]ETAT=""
  CHBOU += "<>"
 Endif
 CHMEN += "0123"
 If [M]BATCH=0 & DIFIMP
  CHMEN += "4"
 Endif
 STADEF = GSTABOU+1
Endif
Return

########################################
$BOUTON
Case BOUT
 When "0" : Gosub IMPRIMER : Call SET_DERLU("ARP",[M]RPTCOD+'~') From GOBJACT
 When "4" : SUIZON = "PRT"
Endcase
Return

########################################
$PREMIER
If find(currbox,BROW1,BROW2)
 Gosub FILGAUCHE
 Gosub DEFAUT_BRO From =WINPROG
 Filter [F] Where evalue(FILGAUSUP)
 Case currbox
  When BROW1 : Read [F]ARP0 First
  When BROW2 : Read [F]ARP1 First
 Endcase
 Filter [F]
 If fstat<=2 : ETAT = [F:ARP]RPTCOD : Gosub CHARGE : Endif
Endif
Return

########################################
$DERNIER
If find(currbox,BROW1,BROW2)
 Gosub FILGAUCHE
 Gosub DEFAUT_BRO From =WINPROG
 Filter [F] Where evalue(FILGAUSUP)
 Case currbox
  When BROW1 : Read [F]ARP0 Last
  When BROW2 : Read [F]ARP1 Last
 Endcase
 Filter [F]
 If fstat<=2 : ETAT = [F:ARP]RPTCOD : Gosub CHARGE : Endif
Endif
Return

########################################
$SUIVANT
If find(currbox,BROW1,BROW2)
 Read [ARP]ARP0 = [M]RPTCOD
 Gosub FILGAUCHE
 Gosub DEFAUT_BRO From =WINPROG
 Filter [F] Where evalue(FILGAUSUP)
 Case currbox
  When BROW1 : Read [F]ARP0 > [M]RPTCOD
  When BROW2 : Read [F]ARP1 > [F:ARP]GRP;[M]RPTCOD
 Endcase
 Filter [F]
 If fstat<=2 : ETAT = [F:ARP]RPTCOD : Gosub CHARGE : Endif
Endif
Return

########################################
$PRECEDENT
If find(currbox,BROW1,BROW2)
 Read [ARP]ARP0 = [M]RPTCOD
 Gosub FILGAUCHE
 Gosub DEFAUT_BRO From =WINPROG
 Filter [F] Where evalue(FILGAUSUP)
 Case currbox
  When BROW1 : Read [F]ARP0 < [M]RPTCOD
  When BROW2 : Read [F]ARP1 < [F:ARP]GRP;[M]RPTCOD
 Endcase
 Filter [F]
 If fstat<=2 : ETAT = [F:ARP]RPTCOD : Gosub CHARGE : Endif
Endif
Return

########################################
$IMPRIMER
# Contrôles de saisie
Call LECTURE("ARP",[M]RPTCOD,"") From CONTOBJ
Local Char    VALCONT(30)
Local Integer OKFIN
ER = 0 : OKFIN =1
For nolign=1 To [M]NBRPAR
 mkstat = 0
 If [M]DEBFIN(nolign-1)= 3
  For I=0 To [M:RPT]NBPLAG-1
   If [M:RPT]PARCOD(nolign-1) = [M:RPT]PARPLAG(I)
    Call CONTPAD([M:RPT]PARTYP(nolign-1),[M:RPT]VALPLAG1(I),[M:RPT]VALPLAG1(I))
    Call CONTGEN([M:RPT]VALPLAG1(I),[M:RPT]OBJET(nolign-1),[M:RPT]BORPLAG(I),[M:RPT]NOLIB(nolign-1)
&   ,[M:RPT]PAROBJ(nolign-1),[M:RPT]TYP(nolign-1),[M:RPT]CONTROLE(nolign-1),[M:RPT]PAROPT(nolign-1))
    If !mkstat
     If GPRODUIT<>1 : ## GEODE
      Call CONTEVAL([M:RPT]TYP(nolign-1),[M:RPT]VALPLAG1(I),[M:RPT]CONTROLE(nolign-1))
      If ! mkstat
       Call CONTADI([M:RPT]NOLIB(nolign-1),[M:RPT]OBJET(nolign-1),[M:RPT]BORPLAG(I),[M:RPT]VALPLAG1(I))
       If !mkstat
        If [M:RPT]BORPLAG(I) = 2
         Call CONTPAD([M:RPT]PARTYP(nolign-1),[M:RPT]VALPLAG2(I),[M:RPT]VALPLAG2(I))
         Call CONTFIN([M:RPT]TYP(nolign-1),[M:RPT]VALPLAG1(I),[M:RPT]VALPLAG2(I),OKFIN)
         If OKFIN
          Call CONTEVAL([M:RPT]TYP(nolign-1),[M:RPT]VALPLAG2(I),[M:RPT]CONTROLE(nolign-1))
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
   If mkstat | !OKFIN
    Call ERREUR([M]PARDES(nolign-1)-":"-GMESSAGE) From GESECRAN
    SUIZON = "VALEUR1("+num$(nolign-1)+")"
    ER = 1 : Break 2
   Endif
  Next I
 Else
  Call CONTROLE([M]VALINT1(nolign-1),[M]PARTYP(nolign-1),[M:RPT]NOLIB(nolign-1),[M:RPT]LONG(nolign-1),[M]VALINT1(nolign-1)) From FMTVAR
  If !mkstat
   Call CONTACL([M]VALINT1(nolign-1),[M]PARTYP(nolign-1),[M:RPT]TABCONT(nolign-1),"") From SUBACL
   If !mkstat
    Call C_VALEUR1([M]VALINT1(nolign-1)) From AIMP1
   Endif
  Endif
  If mkstat
   Call ERREUR([M]PARDES(nolign-1)-":"-GMESSAGE) From GESECRAN
   SUIZON = "VALEUR1("+num$(nolign-1)+")"
   ER = 1 : Break
  Endif
  If [M]DEBFIN(nolign-1)=2
   Call CONTROLE([M]VALINT2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR
   If !mkstat
    Call CONTACL([M]VALINT2(nolign-1),[M]PARTYP(nolign-1),[M]TABCONT(nolign-1),"") From SUBACL
    If !mkstat
     Call C_VALEUR2([M]VALINT2(nolign-1)) From AIMP1
    Endif
   Endif
   If mkstat
    SUIZON = "VALEUR2("+num$(nolign-1)+")"
    Call ERREUR([M]PARDES(nolign-1)-":"-GMESSAGE) From GESECRAN
    ER = 1 : Break
   Endif
  Endif
 Endif
Next nolign
If ER : GMESSAGE = "" : FIN = 0 : Return : Endif
If [F:ARP]EXEBAT=2 & ![M]BATCH & [M]DIFFERE<>2
 GERR = 1 : GMESSAGE = mess(95,133,1) : # Impression différée obligatoire
 FIN = 0 : Return
Endif
If [M]BATCH or [M]DIFFERE=2
 If find([M]IMPRIME,1)
  GERR = 1 : GMESSAGE = mess(12,135,1) : # Pas de prévisualisation en batch
  FIN = 0 : Return
 Endif
 If [M]SERVEUR=""
  GERR = 1 : GMESSAGE = mess(13,135,1) : # Serveur non défini
  FIN = 0 : Return
 Endif
Endif
# Contraintes horaires
If ![M]BATCH & [M]DIFFERE<>2 & [F:ARP]HOR<>""
 Call CTLDAT([F:ARP]HOR,"","",date$,OK) From ARQTSUB
 If !OK
  GERR = 1 : GMESSAGE = mess(31,135,1)+"\"+[F:ARP]HOR-[F:ABH]DES : # Jour interdit par la contrainte
  FIN = 0 : Return
 Endif
 Call CTLHOR([F:ARP]HOR,"","",date$,left$(time$,2)+mid$(time$,4,2),OK) From ARQTSUB
 If !OK
  GERR = 1 : GMESSAGE = mess(32,135,1)+"\"+[F:ARP]HOR-[F:ABH]DES : # Heure interdite par la contrainte
  FIN = 0 : Return
 Endif
Endif
# Destination obligatoire
If [M]PRT=""
 Call PARAMUTIL("WINIMP",VALCONT,"","") From SUBAUS
 If val(VALCONT)<>2
  GERR = 1 : GMESSAGE = mess(35,135,1) : # Destination d'impression obligatoire
  FIN = 0 : SUIZON = "PRT" : Return
 Endif
Endif
# Serveur d'impression en prévisu
Gosub SET_CRPE
If [M]IMPRIME=1 & !CRPE & [M]SERVEUR=""
 GERR = 1 : GMESSAGE = mess(13,135,1) : # Serveur non défini
 FIN = 0 : Return
Endif
FIN = 1
IACTION = "CONTSAI" : Gosub ACTINI
Return

########################################
$SET_CRPE
Local Integer CRPE
Local Char CHAINE(255)
If GRELCLI<"15c.011"
 CRPE = -1 : # Non supporté : on considère que le "Crystal Print Engine" est installé sur le poste client
Elsif GSERVEUR
 CRPE = 0
Else
 Call PARCLI("PEAvailable",CHAINE) From GLOBVAR
 Case CHAINE
  When "0"     : CRPE = 0  : # Non installé
  When "1"     : CRPE = 1  : # Installé
  When Default : CRPE = -1 : # Non supporté
 Endcase
Endif
Return

########################################
$SET_MEL
Local Integer MELWRK
# Envoi état en pièce jointe par le workflow
# ASAIDEST = 2 indique que le mail est envoyé directement par Crystal (ancienne méthode)
MELWRK = (func AFNC.PARAM("ASAIDEST","")<>"2" & func AFNC.PARTSEP(ver$(0),2," ")>="16r.113")
Return

###########################################################################
Subprog VERF_DIFF(USER,OK)
Value    Char    USER
Variable Integer OK
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If filinfo(filpath("FIL","AMETUTI","fde"),0)>0
 If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
Endif
If clalev([F:AFT])=0 : Local File AFCTFCT [AFT] : Endif
Call LECTURE("AUS",USER,"") From CONTOBJ
If [F:AUS]PRFFCT="" & clalev([F:AME])>0
 Read [AME]AME0 = [F:AUS]CODMET
 Call LECTURE("AFT",[F:AME]PRFFCT,"") From CONTOBJ
Else
 Call LECTURE("AFT",[F:AUS]PRFFCT,"") From CONTOBJ
Endif
OK = ([F:AFT]DIFIMP=2)
End

###########################################################################
Subprog VERF_DROIT(ETAT,USER,OK,AUTSIT)
Value    Char    ETAT
Value    Char    USER
Variable Integer OK
Variable Char    AUTSIT()
Local    Integer I , USRACC(1..2)
Local    Char    FONCIMP(GLONAFC)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If filinfo(filpath("FIL","AMETUTI","fde"),0)>0
 If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
Endif
If clalev([F:AFT])=0 : Local File AFCTFCT [AFT] : Endif
Call LECTURE("AUS",USER,"") From CONTOBJ
If [F:AUS]PRFFCT="" & clalev([F:AME])>0
 Read [AME]AME0 = [F:AUS]CODMET
 Call LECTURE("AFT",[F:AME]PRFFCT,"") From CONTOBJ
Else
 Call LECTURE("AFT",[F:AUS]PRFFCT,"") From CONTOBJ
Endif
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif

Read [ARP]ARP0 = ETAT : # mb 9.8.2 bug 15449 La classe [F:ARP] n'était pas chargée par le Call LECTURE
If fstat : OK = 0 : End : Endif

# Code d'accès
mkstat = 0
Call CONTEXE([F:ARP]ACS) From SUBACS
If mkstat : GMESSAGE = "" : OK = 0 : End : Endif

# Accès à toutes les fonctions (AUTSIT ne sert plus à rien à 140)
If [F:AFT]ALLFCT=2 : AUTSIT = "*" : OK = 1 : End : Endif

# Verif par rapport au filtre
If GFILTETAT<>""
 If !pat(ETAT,GFILTETAT) : OK = 0 : End : Endif
Endif

# Vérif par rapport au groupe
If [F:AFT]AUTETA([F:ARP]GRP-1)<>2 : OK = 0 : End : Endif

# Vérif par rapport à la fonction
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If dim([F:ARP]FNC)>0 & [F:ARP]FNC<>""
 FONCIMP = [F:ARP]FNC
Else
 FONCIMP = "" : # mb 13.5.8 fait double emploi avec la vérif par rapport au groupe
Endif
If FONCIMP<>""
 Call LECTURE("AFC",FONCIMP,"") From CONTOBJ
 If !fstat
  If [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
   Read [AFP]AFP0 = GPROFIL ; FONCIMP ; ""
   If fstat | [F:AFP]ACS<>2
    OK = 0 : End
   Endif
  Elsif GNBSITE<>0 : # mb 7.1.3 Pour les dossiers de référence sans sites
   Read [AFF]AFF1 = GPROFIL;FONCIMP : # mb 22.5.2 bug 14360
   If fstat
    OK = 0 : End
   Endif
  Endif
 Endif
Endif
OK = 1
End

#################################################################################
$REMPLIT
Local Char    TYPFMT(20) , OPTFMT(20) , CHFMT(50) , NUMFMT(10) , IACTION(20)
Local Integer LNGFMT , I , ERR , OKACS
Read [ARP]ARP0 = ETAT
Call TEXTE([F:ARP]RPTDES,[M]RPTDES) From OBJDIV
[M]NBRPAR = 0
Raz [M]VALEUR1, [M]VALEUR2

# Sources de données
Read [ARO]ARO0 = ETAT
If !fstat
 For I=0 To [F:ARO]NBRSRC-1
  NOL = [M]NBRPAR
  [M]PARCOD(NOL)   = "%SRC"+num$(I+1)
  Call TEXTE([F:ARO]SRC(I),[M]PARDES(NOL)) From OBJDIV
  [M]DEBFIN(NOL)   = 1
  [M]PARTYP(NOL)   = "A"
  Call LECTURE("ATY",[M]PARTYP(NOL),"") From CONTOBJ
  [M]TYP(NOL)      = [F:ATY]TYPTYP
  [M]OBJET(NOL)    = [F:ATY]OBJLIEN
  LNGFMT = [F:ATY]LNGTYP
  Call FORMA(20,[F:ATY]TYPTYP,LNGFMT,0,[F:ATY]OPTION,[F:ATY]FORTYP,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
  [M]FMT(NOL) = TYPFMT+OPTFMT+"z:"+CHFMT
  If [F:ARO]DOSSIER(I)<>""
   Onerrgo RIEN
   [M]VALEUR1(NOL) = evalue([F:ARO]DOSSIER(I))
   Onerrgo
  Endif
  If [M]VALEUR1(NOL)=""
   If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
   If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
   Call LECTURE("ADS",nomap,"") From CONTOBJ
   K = 0
   For [ADD] Where DOSSIER=[F:ADS]DOSSIER
    K = 1 : Break
   Next ADD
   If K
    [M]VALEUR1(NOL) = [F:ADD]LSOL+";"+[F:ADD]LDOSTARG
   Else
    Call LECTURE("ADS",GDOSX3,"") From CONTOBJ
    K = find(nomap(0),[F:ADS]SOLDOS)
    If K & [F:ADS]SOLAUZ(K-1)>=2
     [M]VALEUR1(NOL) = GINSTID+";"+GDOSX3
    Else
     [M]VALEUR1(NOL) = GINSTID+";"+nomap
    Endif
   Endif
  Endif
  [M]NBRPAR += 1
 Next I
Endif

# Paramètres

For [ARD]ARD0 Where RPTCOD=ETAT & PARSAI=2
 If [F:ARD]PARACS<>""
  Call LECACC([F:ARD]PARACS,OKACS) From SUBACS
 Else
  OKACS = 1
 Endif
 If OKACS
  NOL = [M]NBRPAR
  Call TEXTE([F:ARD]PARNAM,[M]PARDES(NOL)) From OBJDIV
  [M]PARCOD(NOL)   = tolower([F:ARD]PARCOD)
  [M]DEBFIN(NOL)   = [F:ARD]PARSTREND
  [M]CONTROLE(NOL) = [F:ARD]PARCTL
  [M]TABCONT(NOL)  = [F:ARD]PARCTLTAB
  [M]NOLIB(NOL)    = [F:ARD]PARNOLIB
  [M]PARTYP(NOL)   = [F:ARD]PARTYP
  [M]LONG(NOL)     = [F:ARD]PARLNG
  Call LECTURE("ATY",[F:ARD]PARTYP,"") From CONTOBJ
  [M]TYP(NOL)      = [F:ATY]TYPTYP
  [M]OBJET(NOL)    = [F:ATY]OBJLIEN
  [M]PAROBJ(NOL)   = [F:ARD]PARPAR
  [M]PAROPT(NOL)   = [F:ARD]PAROPT
  If [F:ATY]TYPTYP=1 : [F:ARD]PARLNG = 20 : Endif
  LNGFMT = [M]LONG(NOL)
  If LNGFMT=0
   LNGFMT = [F:ATY]LNGTYP
  Endif
  Call FORMA(20,[F:ATY]TYPTYP,LNGFMT,[F:ARD]PARNOLIB,[F:ATY]OPTION,[F:ATY]FORTYP
&           ,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
  If [F:ATY]TYPTYP=1
   [M]FMT(NOL) = "Nzf:3#"
  Elsif [F:ATY]TYPTYP=8
   [M]FMT(NOL) = TYPFMT+OPTFMT+"Zz:"+CHFMT
  Else
   [M]FMT(NOL) = TYPFMT+OPTFMT+"z:"+CHFMT
  Endif
  If left$([M]FMT(NOL),1)="="
   If mid$([M]FMT(NOL),2,2)='"K' or mid$([M]FMT(NOL),2,2)="'K"
    [M]FMT(NOL)    = "K:30X"
    [M]LONG(NOL)   = 30
   Else
    Onerrgo RIEN
    ERR = 0
    [M]FMT(NOL) = evalue(right$([M]FMT(NOL),2))
    Onerrgo
    If ERR
     [M]FMT(NOL)    = "K:30X"
     [M]LONG(NOL)   = 30
    Endif
   Endif
  Endif
  If [F:ARD]PARDEF1<>""
   Call EVALE([F:ARD]PARDEF1,[M]VALEUR1(NOL),[F:ATY]TYPTYP)
  Elsif [F:ATY]TYPTYP=1
   [M]VALEUR1(NOL) = "1"
  Endif
  If [F:ARD]PARDEF2<>""
   Call EVALE([F:ARD]PARDEF2,[M]VALEUR2(NOL),[F:ATY]TYPTYP)
  Elsif [F:ATY]TYPTYP=1 & [F:ARD]PARSTREND=2
   [M]VALEUR2(NOL) = "1"
  Endif
  If [M]DEBFIN(NOL) = 3  : # Si valeur multiple alors on recupere les valeurs 1 et 2 ds le tab invicible et on raz [m]valeur1 et 2
   If [M]VALEUR1(NOL) <> ""
    [M]PARPLAG([M]NBPLAG)  = [M]PARCOD(NOL)
    [M]BORPLAG([M]NBPLAG)  = 2
    Call CHARGE([M]VALEUR1(NOL),[M]PARTYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALPLAG1([M]NBPLAG)) From FMTVAR
    [M:RPT]VALINT1(NOL) = [M]VALPLAG1([M]NBPLAG)
   Endif
   If [M]VALEUR2(NOL) <> ""
    [M]PARPLAG([M]NBPLAG) = [M]PARCOD(NOL)
    [M]BORPLAG([M]NBPLAG) = 2
    Call CHARGE([M]VALEUR2(NOL),[M]PARTYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALPLAG2([M]NBPLAG)) From FMTVAR
    [M:RPT]VALINT2(NOL) = [M]VALPLAG2([M]NBPLAG)
   Endif
   If [F:ARD]PARDEF1 <> "" | [F:ARD]PARDEF2 <> ""
    [M]NBPLAG +=1
   Endif
  Endif
  [M]NBRPAR += 1
 Endif
Next

# Mémos

Call LECMEMO(ETAT,"rpt","STD") From AIMP4

# Si Menu/Impression on charge les valeurs par defauts (GESARV)

# cas ou on arrive de AIMPCRYS
Local Integer LEVEL,ISAIMPSYRCRY
While adxpno(LEVEL) <> ""
 If instr(1,adxpno(LEVEL),"AIMPCRYS") : ISAIMPSYRCRY=[V]CST_AYES : Break : Endif
 LEVEL += 1
Wend

If FONCTION <> "" and ISAIMPSYRCRY<[V]CST_AYES
 For [ARV]ARV0 Where FONCTION=[L]FONCTION & TYPCOD=1 & ETAT=[L]ETAT
  I = find(tolower([F:ARV]PARAM),[M]PARCOD(0..[M]NBRPAR))
  If I
   NOL = I-1
   [M]VALEUR1(NOL) = ""
   [M]VALEUR2(NOL) = ""
   If [F:ARV]VALDEF1<>""
    Call EVALE([F:ARV]VALDEF1,[M]VALEUR1(NOL),[M]TYP(NOL))
   Endif
   If [F:ARV]VALDEF2<>""
    Call EVALE([F:ARV]VALDEF2,[M]VALEUR2(NOL),[M]TYP(NOL))
   Endif
   If [M]DEBFIN(NOL) = 3
    I = find(tolower([F:ARV]PARAM),[M]PARPLAG(0..[M]NBPLAG))
    If !I
     I=[M]NBPLAG+1
     If [F:ARV]VALDEF1<>"" | [F:ARV]VALDEF2<>""
      [M]NBPLAG +=1
     Endif
    Endif
    [M]PARPLAG(I-1)  = [M]PARCOD(NOL)
    [M]BORPLAG(I-1) = 2

    [M]VALPLAG1(I-1) = [F:ARV]VALDEF1 : # [M]VALEUR1(NOL)
    Call CHARGE([M]VALEUR1(NOL),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALPLAG1(I-1)) From FMTVAR : # [M]VALPLAG1(i-1) = [M]VALEUR1(I-1)
    [M:RPT]VALINT1(NOL) = [M]VALPLAG1(I-1)

    [M]VALPLAG2(I-1) = [F:ARV]VALDEF2 : # [M]VALEUR2(NOL)
    Call CHARGE([M]VALEUR2(NOL),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALPLAG2(I-1)) From FMTVAR : # [M]VALPLAG2(I-1) = [M]VALEUR2(I-1)
    [M:RPT]VALINT2(NOL) = [M]VALPLAG2(I-1)

   Endif
  Endif
 Next
Endif

## Dates par défaut

For I=1 To [M]NBRPAR
 If ([M]DEBFIN(I-1)=2 |[M]DEBFIN(I-1)=3) & [M]TYP(I-1)=8
  If [M]VALEUR1(I-1)=""
   If GDATEDEB<>[0/0/0]
    [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,GDATEDEB)
   Else
    [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,gdat$(1,1,year(datesyst)))
   Endif
  Endif
  If [M]VALEUR2(I-1)=""
   If GDATEFIN<>[0/0/0]
    [M]VALEUR2(I-1) = format$("D:"+GFMDAT4,GDATEFIN)
   Else
    [M]VALEUR2(I-1) = format$("D:"+GFMDAT4,gdat$(31,12,year(datesyst)))
   Endif
  Endif
  If [M]DEBFIN(I-1)=3
   NOL = find([M]PARCOD(I-1),[M]PARPLAG(0..[M]NBPLAG))
   If !NOL
    NOL = [M]NBPLAG
    Call CHARGE([M]VALEUR1(I-1),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALPLAG1(NOL)) From FMTVAR : # [M]VALPLAG1(NOL) = [M]VALEUR1(I-1)
    Call CHARGE([M]VALEUR2(I-1),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALPLAG2(NOL)) From FMTVAR : # [M]VALPLAG2(NOL) = [M]VALEUR2(I-1)
    [M]PARPLAG(NOL)  = [M]PARCOD(I-1)
    [M]BORPLAG(NOL)  = 2
    [M]NBPLAG +=1
   Endif
  Endif
 Endif
Next I

## Particularités de chaque produit

Case GPRODUIT
 When 0 : ## Pour la compta
  I = find("datedeb",[M]PARCOD(0..[M]NBRPAR-1))
  If I & [M]VALEUR1(I-1)="000000"    # GB 18/07/00 bug 5788
   J = find("societe",[M]PARCOD(0..[M]NBRPAR-1))
   If J & [M]VALEUR1(J-1)<>""
    If filinfo(filpath("FIL","FISCALYEAR","fde",0),0)>=0
     If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
     Filter [FIY] Where CPY=[M]VALEUR1(J-1) & FIYEND>=datesyst
     Read [FIY]FIY0 First
     If !fstat
      [M]VALEUR1(I-1) = [F:FIY]FIYSTR
      [M]VALEUR2(I-1) = [F:FIY]FIYEND
     Endif
    Endif
   Endif
  Endif
 When 1 : ## GEODE
  I = find("FCY",[M]PARTYP(0..[M]NBRPAR-1))
  If I
   [M]FCY = [M]VALEUR1(I-1)
  Else
   [M]FCY = ""
  Endif
  I = find("DEP",[M]PARTYP(0..[M]NBRPAR-1))
  If I
   [M]DEP = [M]VALEUR1(I-1)
  Else
   [M]DEP = ""
  Endif
Endcase

For I=0 To [M]NBRPAR-1
 If [M]DEBFIN(I) <> 3
  Call CHARGE([M]VALEUR1(I),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALINT1(I)) From FMTVAR
  If [M]DEBFIN(I)=2
   Call CHARGE([M]VALEUR2(I),[M]PARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALINT2(I)) From FMTVAR
  Endif
 Endif
Next I
Return

########################################
$SETPAR
Local Char WPARAM(250)
For I=0 To dim([M:AIP]TBPAR)-1
 If [M:AIP]TBPAR(I)<>""
  WPARAM = tolower([M:AIP]TBPAR(I))
  If right$(WPARAM,len(WPARAM)-2)="fin"
   WPARAM = left$(WPARAM,len(WPARAM)-3)+"deb" : J = 2
  Elsif right$(WPARAM,len(WPARAM)-2)="end"
   WPARAM = left$(WPARAM,len(WPARAM)-3)+"str" : J = 2
  Else
   J = 1
  Endif
  K = find(WPARAM,[M]PARCOD(0..[M]NBRPAR-1))
  If K
   Case J
    When 1
     [M]VALEUR1(K-1) = [M:AIP]TBVAL(I)
     Call CHARGE([M]VALEUR1(K-1),[M]PARTYP(K-1),[M]NOLIB(K-1),[M]LONG(K-1),[M]VALINT1(K-1)) From FMTVAR
     If GERR<>0 : [M]VALEUR1(K-1) = "" : Raz GMESSAGE, GERR : Endif
    When 2
     [M]VALEUR2(K-1) = [M:AIP]TBVAL(I)
     Call CHARGE([M]VALEUR2(K-1),[M]PARTYP(K-1),[M]NOLIB(K-1),[M]LONG(K-1),[M]VALINT2(K-1)) From FMTVAR
     If GERR<>0 : [M]VALEUR2(K-1) = "" : Raz GMESSAGE, GERR : Endif
   Endcase
  Endif
 Endif
Next I
Return

########################################
Subprog EVALE(EXPRESSION,RESULTAT,TYP)
Value    Char    EXPRESSION
Variable Char    RESULTAT()
Value    Integer TYP
If left$(EXPRESSION,6)="PARAM("
 Local Char PARAM(10)
 PARAM = vireblc(toupper(seg$(EXPRESSION,7,len(EXPRESSION)-1)),2)
 Call PARAM("",PARAM,RESULTAT) From ADOVAL
Else
 Onerrgo RIEN
 If TYP=8
  RESULTAT = evalue(EXPRESSION)
 Else
  RESULTAT = num$(evalue(EXPRESSION))
 Endif
 Onerrgo
Endif
End

$RIEN
ERR = errn
Resume

########################################
$ACTINI
GPE = 0
Local Integer OKTRT
If dim([F:ARP]TRTSPE)>0 & [F:ARP]TRTSPE<>""
 If dim([L]ACTION)<=0 : Local Char ACTION(20) : Endif
 If dim([L]SAVACT)<=0 : Local Char SAVACT(20) : Endif
 SAVACT = ACTION
 ACTION = IACTION
 Call EXISTE_ADX("","",[F:ARP]TRTSPE,OKTRT) From ORDSYS
 If OKTRT
  Onerrgo RIEN
  Gosub ACTION From =[F:ARP]TRTSPE
  Onerrgo
 Endif
 ACTION = SAVACT
Endif
If !GPE & dim([F:ARP]TRTINI)>0 & [F:ARP]TRTINI<>""
 If dim([L]ACTION)<=0 : Local Char ACTION(20) : Endif
 If dim([L]SAVACT)<=0 : Local Char SAVACT(20) : Endif
 SAVACT = ACTION
 ACTION = IACTION
 Call EXISTE_ADX("","",[F:ARP]TRTINI,OKTRT) From ORDSYS
 If OKTRT
  Onerrgo RIEN
  Gosub ACTION From =[F:ARP]TRTINI
  Onerrgo
 Endif
 ACTION = SAVACT
Endif
Return

###########################################################################
## Ecran AIMP1
###########################################################################
Subprog APRES_NBRPAR
End

Subprog AS_RPTCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call GET_DERLU(VALEUR,"ARP","ENAFLG=2 & EXEFLG<>2") From GOBJACT
Endif
End

Subprog C_RPTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Call CONT_RPTCOD(VALEUR,GMESSAGE,STAT)
mkstat = STAT
If !mkstat & dim([F:ARP]EXEFLG)>0 & [F:ARP]EXEFLG=2 & [M]ETAT=""
 GMESSAGE = mess(20,135,1) : # Etat non exécutable directement
 mkstat = 2 : End
Endif
End

Subprog EXE_RPTCOD(VALEUR,MESSAGE,STAT)
Variable Char    VALEUR , MESSAGE
Variable Integer STAT
Call CONT_RPTCOD(VALEUR,MESSAGE,STAT)
If !STAT & dim([F:ARP]EXEFLG)>0 & [F:ARP]EXEFLG=2 & [M]ETAT=""
 MESSAGE = mess(20,135,1) : # Etat non exécutable directement
 STAT = 2 : End
Endif
End

Subprog CONT_RPTCOD(VALEUR,MESSAGE,STAT)
Value    Char    VALEUR
Variable Char    MESSAGE
Variable Integer STAT
Raz STAT , MESSAGE
Read [ARP]ARP0 = VALEUR
If fstat
 MESSAGE = mess(6,135,1) : # Etat inexistant
 STAT = 2 : End
Elsif [F:ARP]ENAFLG<>2
 MESSAGE = mess(17,135,1)-VALEUR+"\"+mess(2,126,1) : # Etat x\Fiche inactive
 STAT = 2 : End
Else
 Local Integer OK
 OK = 1
 If [F:ARP]CODACT<>""
  Read [ACV]CODACT=[F:ARP]CODACT
  If fstat or [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK
  Call VERF_DROIT(VALEUR,GUSER,OK,[M]AUTSIT)
 Endif
 If !OK
  MESSAGE = mess(3,135,1) : # Vous n'avez pas accès à cet état
  STAT = 2 : End
 Endif
Endif
End

Subprog AM_RPTCOD(VALEUR)
Variable Char    VALEUR()
End

Subprog CHANGE_RPTCOD(VALEUR,FONCTION)
Variable Char    VALEUR()
Value    Char    FONCTION
Raz [M]VALEUR1,[M]VALEUR2
Local Char     ETAT(GLONARP) , COMPLEMENT(10), REPLI(GLONLAN)
Local Integer OBLIG,LANSTD
ETAT     = VALEUR
If FONCTION="" : FONCTION = GFONCTION : Endif
Effzo NBRPAR
Gosub REMPLIT
Gosub SETPAR
[M]RPTCOD = VALEUR
[M]AUTSIT = AUTSIT
Call COMPLEMENT(COMPLEMENT)
Call DEFIMP([M]RPTCOD,GUSER,COMPLEMENT,[M]PRT,OBLIG) From IMPRIME
If OBLIG
 Diszo PRT
Else
 Actzo PRT
Endif
Call CONT_PRT([M]PRT)
If [F:ARP]MULLAN=2
 Call STDREPLI(GLANGUE,LANSTD,REPLI) From SUBTLA
 If LANSTD = 2 or GLANGUE=[F:ARP]LAN
  [M]LANGUE = GLANGUE
 Elsif REPLI<>""
  [M]LANGUE = REPLI
 Endif
 If [M]LANGUE ="" : [M]LANGUE = GLANGUE : Endif
 Actzo LANGUE
Else
 [M]LANGUE = [F:ARP]LAN
 Diszo LANGUE
Endif
If [M]LANGUE="" : [M]LANGUE = GLANGUE : Endif
Affzo
If [F:ARP]PARSEG<>""
 For I=0 To [M]NBRPAR-1
  If PARCOD(I)=tolower([F:ARP]PARSEG)
   Chgstl [M]PARDES(I) With "AMKACT"
  Endif
 Next I
Endif
End

Subprog AS_VALEUR1(VALEUR)
Variable Char VALEUR()
If tolower([F:ARP]PARSEG)<>tolower([M]PARCOD(nolign-1))
 GBOUT2 = ""
Endif
Local Char IACTION(20)
Onerrgo RIEN
IACTION = "INIPAR" : Gosub ACTINI
Onerrgo
End

Subprog C_VALEUR1(VALEUR)
Variable Char VALEUR()
Local Char IACTION(20)

Call CONTPAD([M]PARTYP(nolign-1),[M]VALINT1(nolign-1),VALEUR)
IACTION = "CONT1" : Gosub ACTINI
If mkstat : End : Endif
Gosub CONT1
If !mkstat & GPRODUIT=1 : ## GEODE
 Case [M]PARTYP(nolign-1)
  When "FCY"
   If [L]VALCONT=""
    [M]FCY = GFCY
   Else
    [M]FCY = VALEUR
   Endif
  When "DEP"
   [M]DEP = VALEUR
 Endcase
Endif
End

Subprog AM_VALEUR1(VALEUR)
Variable Char VALEUR()
Local Integer INF , J  , I
Case [M]TYP(nolign-1)
 When 1,2,3,4,5,6
  Local Decimal VAL1 : VAL1 = val([M]VALINT1(nolign-1))
  Local Decimal VAL2 : VAL2 = val([M]VALINT2(nolign-1))
  If find([M]DEBFIN(nolign-1),2,3)  & VAL2<VAL1 : INF = 1 : Endif
 When 7
  Local Char VAL1(250) : VAL1 = [M]VALINT1(nolign-1)
  Local Char VAL2(250) : VAL2 = [M]VALINT2(nolign-1)
  If find([M]DEBFIN(nolign-1),2,3)  & VAL2<VAL1 : INF = 1 : Endif
 When 8
  Local Date VAL1
  If [M]VALINT1(nolign-1)<>"" : VAL1 = gdat$([M]VALINT1(nolign-1)) : Else : VAL1 = [0/0/0] : Endif
  Local Date VAL2
  If [M]VALINT2(nolign-1)<>"" : VAL2 = gdat$([M]VALINT2(nolign-1)) : Else : VAL2 = [0/0/0] : Endif
  If find([M]DEBFIN(nolign-1),2,3)  & VAL2<VAL1 : INF = 1 : Endif
Endcase
If INF
 [M]VALEUR2(nolign-1) = num$(VALEUR)
 Call CONTROLE([M]VALEUR2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1)
&              ,[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR
 Affzo [M]VALEUR2(nolign-1)
Endif
If [M]DEBFIN(nolign-1)=3
 Local Integer OK
 For I=0 To [M:RPT]NBPLAG-1
  If [M]PARCOD(nolign-1) = evalue("[M:RPT]PARPLAG"+"("+num$(I)+")")
   OK += 1
  Endif
 Next I
 If OK=1
  I=find([M]PARCOD(nolign-1),[M]PARPLAG(0..[M]NBPLAG))
  If I : [M]VALPLAG1(I-1) = [M]VALINT1(nolign-1) : Endif : #--- VALEUR : Endif
 Elsif OK>1
  Raz VALEUR
 Endif
Endif

End

$CONT1
Local Char VALCONT(250)
VALCONT = [M]VALINT1(nolign-1)
Call CONTGEN([L]VALCONT,[M]OBJET(nolign-1),[M]DEBFIN(nolign-1),[M]NOLIB(nolign-1),[M]PAROBJ(nolign-1)
&   ,[M]TYP(nolign-1),[M]CONTROLE(nolign-1),[M]PAROPT(nolign-1))
If mkstat : Return : Endif
If tolower(left$([M]PARCOD(nolign-1),4))="%src"
 Local Integer K
 Local Char    SOLUCE(20) , SOLDOS(20)
 Local Char VALCONT(250)
 VALCONT = toupper(VALINT1(nolign-1))
 K = instr(1,VALCONT,";")
 If K
  SOLUCE = left$(VALCONT,K-1)
  SOLDOS = right$(VALCONT,K+1)
 Else
  SOLUCE = GINSTID
  SOLDOS = VALCONT
 Endif
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 If clalev([F:ADD])=0 : Local File ADOSSOL  [ADD] : Endif
 OK = 0
 If SOLUCE=GINSTID & SOLDOS=nomap
  OK = 1
 Elsif SOLUCE=GINSTID
  Read [ADS]DOSSIER = SOLDOS
  K = find(nomap(0),[F:ADS]SOLDOS)
  If K
   If [F:ADS]SOLAUZ(K-1)>=2
    OK = 1
   Else
    GMESSAGE = mess(149,125,1) : # Droit d'accès à ce dossier insuffisant
   Endif
  Else
   GMESSAGE = mess(219,139,1) : # Lien vers le dossier non défini
  Endif
 Else
  Read [ADS]DOSSIER = nomap
  For [ADD] Where DOSSIER=[F:ADS]DOSSIER
   If [F:ADD]LDOSTARG=SOLDOS
    If SOLUCE = [F:ADD]LSOL
     OK = 1 : Break
    Elsif SOLUCE=""
     SOLUCE = [F:ADD]LSOL
     OK = 1 : Break
    Endif
   Endif
  Next ADD
 Endif
 If !OK
  mkstat = 2
  Return
 Else
  #VALEUR = SOLUCE+";"+SOLDOS
 Endif
Endif
If GPRODUIT<>1 : ## GEODE
 Call CONTEVAL([M]TYP(nolign-1),[L]VALCONT,[M]CONTROLE(nolign-1))
 If mkstat : Return : Endif
Endif
Call CONTADI([M]NOLIB(nolign-1),[M]OBJET(nolign-1),[M]DEBFIN(nolign-1),[L]VALCONT)
Return

Subprog EVALCONT(OK,EXPRESSION,VALEUR)
Variable Integer OK
Value    Char    EXPRESSION
Onerrgo RIEN
OK = evalue(EXPRESSION)
Onerrgo
End

Subprog AS_VALEUR2(VALEUR)
Variable Char VALEUR()
Local Integer OK
If [M]DEBFIN(nolign-1)<2
 mkstat = 1 : End
Endif
If [M]DEBFIN(nolign-1)=3
 For I=0 To [M:RPT]NBPLAG-1
  If [M]PARCOD(nolign-1) = evalue("[M:RPT]PARPLAG"+"("+num$(I)+")")
   OK += 1
  Endif
 Next I
 If OK>1
  Chgstl [M]VALEUR1(nolign-1) With "APARPLAG"
  Chgstl [M]VALEUR2(nolign-1) With "APARPLAG"
  VALEUR = ""
  Diszo [M]VALEUR1(nolign-1)
  mkstat = 1
  End
 Else
  Actzo  [M]VALEUR1(nolign-1)
  If OK=1
   I= find([M]PARCOD(nolign-1),[M]PARPLAG(0..[M]NBPLAG))
   If I
    [M]VALINT1(nolign-1) = [M]VALPLAG1(I-1)
    If [M]TYP(nolign-1)=1
     Call CHARGE([M]VALEUR1(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1), [M]VALPLAG1(I-1)) From FMTVAR
    Else
     [M]VALEUR1(nolign-1) = [M]VALPLAG1(I-1)
    Endif
   Endif
  Endif
  Chgstl [M]VALEUR1(nolign-1) With ""
  Chgstl [M]VALEUR2(nolign-1) With ""
 Endif
Endif
Local Char IACTION(20)
Onerrgo RIEN
IACTION = "INIPAR2" : Gosub ACTINI
Onerrgo
End

Subprog C_VALEUR2(VALEUR)
Variable Char VALEUR()
Local Integer OK
Local Char IACTION(20)
Call CONTPAD([M]PARTYP(nolign-1),[M]VALINT2(nolign-1),VALEUR)
OK = 1
IACTION = "CONT2" : Gosub ACTINI
If !OK or mkstat : End : Endif
Call CONTFIN([M]TYP(nolign-1),[M]VALINT1(nolign-1),[M]VALINT2(nolign-1),OK)
If !OK : mkstat = 1 : End : Endif
Call CONTEVAL([M]TYP(nolign-1),[M]VALINT2(nolign-1),[M]CONTROLE(nolign-1))
Local Integer K , I
If [M]DEBFIN(nolign-1) = 3
 If [M]VALEUR1(nolign-1) <> "" | VALEUR <> ""
  For I=0 To [M:RPT]NBPLAG-1
   If [M]PARCOD(nolign-1) = evalue("[M:RPT]PARPLAG"+"("+num$(I)+")")
    K += 1
   Endif
  Next I
  If K<2
   If K=0 : K=[M]NBPLAG : [M]NBPLAG += 1
   Elsif K=1 : K =find([M:RPT]PARCOD(nolign-1),[M:RPT]PARPLAG(0..[M:RPT]NBPLAG))-1
   Endif
   [M]BORPLAG(K)  = 2
   [M]PARPLAG(K)  = [M]PARCOD(nolign-1)
   [M]VALPLAG1(K) = [M]VALINT1(nolign-1) : # [m]valeur1(nolign-1)
   [M]VALPLAG2(K) = [M]VALINT2(nolign-1) : # VALEUR
  Endif
 Elsif [M]VALEUR1(nolign-1) = "" & VALEUR = ""
  J= find([M:RPT]PARCOD(nolign-1),[M:RPT]PARPLAG(0..[M:RPT]NBPLAG))
  While J
   Dela J-1 , 1 [M:RPT]PARPLAG, [M:RPT]VALPLAG1 , [M:RPT]VALPLAG2 , [M:RPT]BORPLAG
   If [M:RPT]NBPLAG> 0 : [M:RPT]NBPLAG-= 1 : Endif
   J= find([M:RPT]PARCOD(nolign-1),[M:RPT]PARPLAG(0.. [M:RPT]NBPLAG))
  Wend
  [M:RPT]PARPLAG([M:RPT]NBPLAG) = [M:RPT]PARCOD(nolign-1)
  [M:RPT]VALPLAG1([M:RPT]NBPLAG) = ""
  [M:RPT]VALPLAG2([M:RPT]NBPLAG) = ""
  [M:RPT]BORPLAG([M:RPT]NBPLAG)  = 2
  [M:RPT]NBPLAG +=1
 Endif
Endif
End

Subprog AM_VALEUR2(VALEUR)
Variable Char    VALEUR()
End

Subprog S_VALEUR(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_INIIMP(VALEUR)
Variable Char    VALEUR()
Local Char    IMPRIMANTE(GLONAIM)
Local Integer OBLIG
Local Char    COMPLEMENT(10)
If !GCONSDIA
 Call COMPLEMENT(COMPLEMENT)
 Call DEFIMP([M]RPTCOD,GUSER,COMPLEMENT,IMPRIMANTE,OBLIG) From IMPRIME
 If VALEUR="" or OBLIG or varmode([M]PRT)<>0
  If OBLIG
   Diszo PRT
  Else
   Actzo PRT
  Endif
  VALEUR = IMPRIMANTE
  [M]PRT = IMPRIMANTE
  Call CONT_PRT([M]PRT)
  Affzo 40,50
 Endif
Endif
End

Subprog COMPLEMENT(VALEUR)
Variable Char VALEUR()
Local Integer I , J , K , L
Local Char    EXPRESSION(250) , VALPAR(250) , PARAM(30)
Local Integer TYPPAR , FIN
VALEUR = ""
If [F:ARP]PRTFRM="" : End : Endif
EXPRESSION = vireblc(format$("KT:250X",[F:ARP]PRTFRM),2)
Repeat
 J = instr(1,EXPRESSION,"PARAM(")
 If J
  K = instr(J+1,EXPRESSION,")")
  If K
   PARAM = toupper(seg$(EXPRESSION,J+6,K-1))
   L = len(PARAM)
   FIN = 0
   If right$(PARAM,L-2)="FIN"
    PARAM = left$(PARAM,L-3)+"DEB" : FIN = 1
   Elsif right$(PARAM,L-2)="END"
    PARAM = left$(PARAM,L-3)+"STR" : FIN = 1
   Endif
   TYPPAR = 0
   For I=0 To [M]NBRPAR-1
    If toupper([M]PARCOD(I))=PARAM
     If FIN
      VALPAR = [M]VALINT2(I)
     Else
      VALPAR = [M]VALINT1(I)
     Endif
     TYPPAR = [M]TYP(I)
     Break
    Endif
   Next I
   If TYPPAR
    Case TYPPAR
     When 7,10 : VALPAR = '"'+VALPAR+'"'
     When 8    : VALPAR = '['+format$("D:"+GFMD,gdat$(VALPAR))+']'
    Endcase
    EXPRESSION = left$(EXPRESSION,J-1)+VALPAR+right$(EXPRESSION,K+1)
   Else
    EXPRESSION = left$(EXPRESSION,J-1)+right$(EXPRESSION,K+1)
   Endif
  Else
   J = 0
  Endif
 Endif
Until J=0
Onerrgo RIEN
VALEUR = evalue(EXPRESSION)
Onerrgo
End

Subprog C_PRT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Local Char PARAM(10)
 Call PARAMUTIL("WINIMP",PARAM,"","") From SUBAUS
 If val(PARAM)<>2
  GMESSAGE = mess(35,135,1) : # Destination d'impression obligatoire
  mkstat = 2 : End
 Endif
Endif
Call CONT_PRT(VALEUR)
End

Subprog CONT_PRT(VALEUR)
Variable Char    VALEUR()
Local Integer I , ORIDEF , SERMOD
Gosub SET_CRPE
Gosub SET_MEL
If VALEUR<>""
 Call AIMCONT(VALEUR,[M]RPTCOD,([M]BATCH<>0) or ([M]DIFFERE=2)) From IMPRIME
 If mkstat : End : Endif
 [M]IMPRIME    = [F:AIM]PRT
 If CRPE=-1 & [M]IMPRIME=1 & !GBROWS : # Impression avec serveur d'impression non supportée
  [M]SERVEUR   = "" : SERMOD = 1
 Elsif [F:AIM]PRTSRV<>[M]SERVEUR
  [M]SERVEUR    = [F:AIM]PRTSRV : SERMOD=1
 Endif
 [M]IMPRIMANTE = [F:AIM]PRTNAM
 [M]PRTPOR     = [F:AIM]PRTPOR
 [M]PRTDRV     = [F:AIM]PRTDRV
 Raz [M]PRTDES,[M]PRTDESEX
 For [AID]AID0 Where COD=[F:AIM]COD
  [M]PRTDES([F:AID]NUM-1) = [F:AID]PRTDES
  [M]PRTDESEX([F:AID]NUM-1) = [F:AID]PRTDESEX
 Next
 If find([M]IMPRIME,2) : # Imprimante
  [M]NBRCPY     = [F:AIM]NBRCPY
  [M]ASSCPY     = [F:AIM]ASSCPY
 Elsif find([M]IMPRIME,6) : # Imprimante ZPL
  [M]NBRCPY     = [F:AIM]NBRCPY
  If left$([F:AIM]PRTZPL,1)="="
   Onerrgo RIEN
   [M]FICHIER = evalue(right$([F:AIM]PRTZPL,2))
   Onerrgo
  Else
   [M]FICHIER    = [F:AIM]PRTZPL
  Endif
 Endif
 If find([M]IMPRIME,3,4,6,7) : # Message/Fichier/Archive
  [M]FMTFIC     = [F:AIM]PRTFMT
 Elsif [M]IMPRIME=2
  [M]FMTFIC     = 1 : # rpt
 Elsif [M]IMPRIME=1 : # Prévisu
  If GBROWS
   If [F:AIM]PRTFMT<=1 : # rpt
    [M]FMTFIC   = 29 : # pdf
   Else
    [M]FMTFIC   = [F:AIM]PRTFMT
   Endif
  Elsif [M]SERVEUR<>"" : # Pré-visu
   GPE = 1
   GPOINT = "PRTFMT" : Gosub ENTREE From EXEFNC
   If GPE=1 & CRPE>=0 & [F:AIM]PRTFMT=1 : # rpt
    [M]FMTFIC   = 29 : # pdf
   Else
    [M]FMTFIC   = [F:AIM]PRTFMT
   Endif
  Elsif [M]SERVEUR="" & CRPE
   [M]FMTFIC    = 1 : # rpt
  Endif
 Endif
 [M]PRTORIENT = [F:AIM]PRTORIENT
 Affzo IMPRIME,IMPRIMANTE,FICHIER,PRTORIENT,NBRCPY,ASSCPY,FMTFIC,PAGDEB,PAGFIN
 If SERMOD=1 : Affzo SERVEUR : Endif
 Diszo IMPRIME,SERVEUR,IMPRIMANTE,FICHIER,NBRCPY,ASSCPY,FMTFIC,PAGDEB,PAGFIN,FORPAP
 If find([F:AIM]PRT,4)
  Actzo FICHIER
 Elsif [F:AIM]PRT=6 & [M]IMPRIMANTE=""
  Actzo FICHIER
 Else
  Effzo FICHIER
 Endif
 If find([F:AIM]PRT,2): # Imprimante
  Actzo NBRCPY,ASSCPY,PAGDEB,PAGFIN
  [M]FORPAP = 3 : # Préférence imprimante
  Affzo FORPAP
 Elsif find([F:AIM]PRT,6) : # Imprimante ZPL
  Actzo NBRCPY
  [M]FORPAP = 3 : # Préférence imprimante
  Affzo FORPAP
 Else
  Effzo NBRCPY,ASSCPY,PAGDEB,PAGFIN
  If [F:AIM]PRT=7
   [M]FORPAP = 3 : # Préférence imprimante
   Diszo FORPAP
  Else
   Gosub SET_PAPDEF
   [M]FORPAP = PAPDEF
   If NBRETA=1
    Actzo FORPAP
   Endif
  Endif
 Endif
 If GBROWS
  Actzo SERVEUR
 Endif
 If  ([M]SERVEUR="" & (([M]IMPRIME=3 & MELWRK) or ([M]IMPRIME=1 & !GBROWS & !CRPE)))
  GMESSAGE = mess(13,135,1) : # Serveur d'impression non défini
  mkstat = 1 : End
 Endif
Else
 Actzo IMPRIME,SERVEUR,IMPRIMANTE,FICHIER,NBRCPY,ASSCPY,FMTFIC,PAGDEB,PAGFIN,FORPAP
 If find([M]IMPRIME,2,6) : # Imprimante/Zpl
  [M]FORPAP = 3 : # Préférence imprimante
  Diszo FORPAP
 Elsif find([M]IMPRIME,7) : # Archive
  [M]FORPAP = 3 : # Préférence imprimante
  Diszo FORPAP
 Else
  Gosub SET_PAPDEF
  [M]FORPAP = PAPDEF
  If NBRETA>1
   Diszo FORPAP
  Endif
 Endif
 Gosub SET_ORIDEF
 [M]PRTORIENT = ORIDEF
 Affzo PRTORIENT
Endif
Local Char IACTION(20)
IACTION = "CONTPRT" : Gosub ACTINI
End

$SET_ORIDEF
ORIDEF = 0
For I=1 To dim([F:ARP]CRYCOD)
 If [F:ARP]CRYCOD(I-1)<>""
  If ORIDEF=0
   ORIDEF = max(1,[F:ARP]ORIENT(I-1))
  Elsif max(1,[F:ARP]ORIENT(I-1))<>ORIDEF
   ORIDEF = 0 : Break
  Endif
 Endif
Next I
Return

$SET_PAPDEF
Local Integer PAPDEF , NBRETA
Raz PAPDEF , NBRETA
For I=1 To dim([F:ARP]CRYCOD)
 If [F:ARP]CRYCOD(I-1)<>""
  NBRETA += 1
  If PAPDEF=0
   PAPDEF = max(1,[F:ARP]FORETA(I-1))
  Elsif max(1,[F:ARP]FORETA(I-1))<>PAPDEF
   PAPDEF = 0 : Break
  Endif
 Endif
Next I
Return

Subprog AS_IMPRIME(VALEUR)
Variable Integer VALEUR
If [M]PRT<>"" : mkstat = 2 : End : Endif
If [M]BATCH or [M]DIFFERE=2
 If VALEUR=1 : VALEUR = 2 : Endif
 GMENLOC(1) = 1
Endif
GMENLOC(5) = 1 : # Imprimante/Fichier ne fonctionne + avec le dernier Crystal Report
Call LECTURE("ARP",[M]RPTCOD,"") From CONTOBJ
If [F:ARP]GESZPL<>2 or !func AFNC.ACTIV("AZPL") : # Imprimante ZEBRA
 GMENLOC(6) = 1
Endif
GMENLOC(7) = !func AFNC.ACTIV("ARCH") : # Archivage
End

Subprog AM_IMPRIME(VALEUR)
Variable Integer VALEUR
Gosub SET_CRPE
Case VALEUR
 When 1 : # Prévisu
  If !GBROWS or !CRPE : [M]SERVEUR = "" : Affzo SERVEUR : Endif
  [M]IMPRIMANTE = ""
  Affzo IMPRIMANTE
 When 3,4,6,7 : # Message, Fichier, Imprimante ZPL
  [M]IMPRIMANTE = ""
  Affzo IMPRIMANTE
Endcase
[M]IMPRIME = VALEUR
Call D_FMTFIC([M]FMTFIC)
Affzo FMTFIC
End

Subprog C_IMPRIME(VALEUR)
Variable Integer VALEUR
If GVTMOD & VALEUR=1
 GMESSAGE = mess(231,133,1) : # Prévisu impossible sur un écran VT
 mkstat = 2 : End
Endif
End

Subprog AP_IMPRIME(VALEUR)
Variable Integer VALEUR
Gosub SET_CRPE
Gosub SET_PAPDEF
Case VALEUR
 When 1 : # Pré-visu
  If CRPE=-1 & !GBROWS
   Diszo SERVEUR
  Else
   Actzo SERVEUR
  Endif
  If !GBROWS and !CRPE
   Effzo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER,FMTFIC,PAGDEB,PAGFIN
   Diszo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER,FMTFIC,PAGDEB,PAGFIN
  Else
   Actzo FMTFIC,PAGDEB,PAGFIN
   Effzo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER
   Diszo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER
  Endif
  [M]FORPAP = PAPDEF
  Affzo FORPAP
  If NBRETA=1
   Actzo FORPAP
  Endif
 When 2 : # Imprimante
  Actzo SERVEUR,IMPRIMANTE,NBRCPY,ASSCPY,PAGDEB,PAGFIN
  If [M]NBRCPY=0 : [M]NBRCPY = 1 : Endif
  If [M]ASSCPY=0 : [M]ASSCPY = 1 : Endif
  Affzo NBRCPY,ASSCPY
  Effzo FICHIER,FMTFIC
  Diszo FICHIER,FMTFIC
  [M]FORPAP = 3
  Affzo FORPAP
  Diszo FORPAP
 When 3 : # Message
  Actzo FMTFIC,SERVEUR
  Effzo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER,PAGDEB,PAGFIN
  Diszo IMPRIMANTE,NBRCPY,ASSCPY,FICHIER,PAGDEB,PAGFIN
  [M]FORPAP = PAPDEF
  Affzo FORPAP
  If NBRETA=1
   Actzo FORPAP
  Endif
 When 4 : # Fichier
  Actzo SERVEUR,FICHIER,FMTFIC
  Effzo IMPRIMANTE,NBRCPY,ASSCPY,PAGDEB,PAGFIN
  Diszo IMPRIMANTE,NBRCPY,ASSCPY,PAGDEB,PAGFIN
  [M]FORPAP = PAPDEF
  Affzo FORPAP
  If NBRETA=1
   Actzo FORPAP
  Endif
 When 6 : # Imprimante ZPL
  Actzo SERVEUR,IMPRIMANTE,FICHIER,NBRCPY
  If [M]NBRCPY=0 : [M]NBRCPY = 1 : Endif
  Affzo NBRCPY
  [M]ASSCPY = 1
  Affzo ASSCPY
  [M]FMTFIC = 9 : # Ascii
  Affzo FMTFIC
  Effzo PAGDEB,PAGFIN
  Diszo FMTFIC,ASSCPY,PAGDEB,PAGFIN
  [M]FORPAP = 3
  Affzo FORPAP
  Diszo FORPAP
 When 7 : # Archive
  Actzo SERVEUR,FMTFIC
  Effzo IMPRIMANTE,FICHIER,NBRCPY,ASSCPY,PAGDEB,PAGFIN
  Diszo IMPRIMANTE,FICHIER,NBRCPY,ASSCPY,PAGDEB,PAGFIN
  [M]FORPAP = 3
  Affzo FORPAP
  Diszo FORPAP
Endcase
End

Subprog AS_SERVEUR(VALEUR)
Variable Char    VALEUR()
If GBROWS : End : Endif
If [M]PRT<>"" : mkstat = 2 : End : Endif
End

Subprog AM_SERVEUR(VALEUR)
Variable Char    VALEUR()
[M]IMPRIMANTE = ""
Affzo IMPRIMANTE
End

Subprog C_SERVEUR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If GBROWS : End : Endif
Gosub SET_CRPE
Gosub SET_MEL
If VALEUR=""
 OK = 1
 If [M]IMPRIME=1 & !CRPE
  OK = 0
 Elsif find([M]IMPRIME,2,3) & ([M]BATCH or [M]DIFFERE=2)
  OK = 0
 Elsif [M]IMPRIME=3 & MELWRK
  OK = 0
 Elsif [M]IMPRIME=7
  OK = 0
 Endif
 If !OK
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 1 : End
 Endif
Endif
If [M]IMPRIME=1
 Call D_FMTFIC([M]FMTFIC)
 If VALEUR=""
  Affzo FMTFIC
  Grizo FMTFIC
 Else
  Actzo FMTFIC
 Endif
Endif
End

Subprog AS_IMPRIMANTE(VALEUR)
Variable Char    VALEUR()

If !find([M]IMPRIME,2,6) : mkstat = 1 : End : Endif
If VALEUR="" & [M]IMPRIME<>6
 Local Integer I , J , K , NBPAR , ASSEMB
 Local Char    PARAMETRE(250)(1..200) , NOMIMP(80)
 If [M]SERVEUR<>"" & right$([M]SERVEUR,len([M]SERVEUR))<>"@"
  Listimp PARAMETRE = [M]SERVEUR+"@"
 Else
  Listimp PARAMETRE = [M]SERVEUR
 Endif
 NBPAR = stat1
 K = instr(1,PARAMETRE(2),"=")
 If K=0 : End : Endif
 NOMIMP = right$(PARAMETRE(2),K+2)
 If NOMIMP="" : End : Endif
 Raz NBPAR,PARAMETRE
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterName="+chr$(1)+NOMIMP
 NBPAR += 1
 PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
 If GFUSION
  NBPAR += 1
  PARAMETRE(NBPAR) = "_PrtDescDiscrete="+chr$(1)+"1"
 Endif
 If [M]SERVEUR<>"" & right$([M]SERVEUR,len([M]SERVEUR))<>"@"
  If adxusr="" : Call SELIMP_TRACE("Call AS_IMPRIMANTE.1",[M]SERVEUR+"@",PARAMETRE,"") From ASELSIMP: Endif
  Selimp PARAMETRE = [M]SERVEUR+"@" With PARAMETRE
 Else
  If adxusr="" : Call SELIMP_TRACE("Call AS_IMPRIMANTE.1",[M]SERVEUR,PARAMETRE,"")From ASELSIMP : Endif
  Selimp PARAMETRE = [M]SERVEUR With PARAMETRE
 Endif
 NBPAR = stat1
 If adxusr="" : Call SELIMP_TRACE("AS_IMPRIMANTE return","",PARAMETRE,"") From ASELSIMP: Endif
 Raz [M]PRTDES
 ASSEMB = 0
 For I=1 To min(NBPAR,dim(PARAMETRE))
  K = instr(1,PARAMETRE(I),"=")
  If K
   Case left$(PARAMETRE(I),K-1)
    When "_PrinterName"        : VALEUR    = right$(PARAMETRE(I),K+2)
    When "_PrinterPort"        : [M]PRTPOR = right$(PARAMETRE(I),K+2)
    When "_PrinterDriver"      : [M]PRTDRV = right$(PARAMETRE(I),K+2)
    When "_PrinterCopies"      : [M]NBRCPY = val(right$(PARAMETRE(I),K+2))
    When "_PrinterCollate"     : ASSEMB = 1+val(right$(PARAMETRE(I),K+2))
    When "_PrinterStartPage"   : [M]PAGDEB = val(right$(PARAMETRE(I),K+2))
    When "_PrinterStopPage"    : [M]PAGFIN = val(right$(PARAMETRE(I),K+2))
    When "_Orientation"    :         [M]PRTORIENT = val(right$(PARAMETRE(I),K+2))+1
    When "_PrinterDescription":
     J = ascii(mid$(PARAMETRE(I),K+1,1))
     If J<=dim([M]PRTDES)
      [M]PRTDES(J-1) = right$(PARAMETRE(I),K+2)
     Endif
    When "_PrinterDescriptionEx"
     J = ascii(mid$(PARAMETRE(I),K+1,1))
     If J<=dim([M]PRTDESEX)
      [M]PRTDESEX(J-1) = right$(PARAMETRE(I),K+2)
     Endif
   Endcase
  Endif
 Next I
 If ASSEMB
  [M]ASSCPY = ASSEMB
 Else
  [M]ASSCPY = 2
 Endif
Endif
End

Subprog C_IMPRIMANTE(VALEUR)
Variable Char    VALEUR()
If find([M]IMPRIME,2) & VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Elsif [M]IMPRIME=6
 If VALEUR<>""
  [M]FICHIER = ""
  Affzo FICHIER
  Diszo FICHIER
 Else
  Actzo FICHIER
 Endif
Endif
Affzo [M]ASSCPY,NBRCPY,PRTDES,PRTDESEX,PRTDRV,PAGDEB,PAGFIN,PRTPOR,SERVEUR,PRTORIENT
End

Subprog IB_FICHIER
Raz GBOUT2
If [M]SERVEUR=""
 GBOUT2 = mess(37,135,1) : # Emplacement par défaut
Endif
End

