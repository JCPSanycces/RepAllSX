Variable Char    VALEUR()
End

Subprog B2_FICHIER(VALEUR)
Variable Char    VALEUR()
Local Char FICHIER(GDIMFIC)
FICHIER = ""
Call DEFAULT_FILECLI(FICHIER,"UserTemp","","") From ORDSYS
Call MESSAGE("|"+FICHIER) From GESECRAN
End

Subprog AS_FICHIER(VALEUR)
Variable Char    VALEUR()
If [M]PRT<>""
 Call LECTURE("AIM",[M]PRT,"") From CONTOBJ
 If !find([F:AIM]PRT,4,6) : mkstat = 1 : End : Endif
 If VALEUR="" & [F:AIM]PRT<>6
  VALEUR = [M]RPTCOD
 Endif
Else
 If !find([M]IMPRIME,4,6,7) : mkstat = 1 : End : Endif
 If VALEUR="" & [M]IMPRIME<>6 : VALEUR = [M]RPTCOD : Endif
Endif
End

Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
If [M]IMPRIME=6 & VALEUR="" & [M]SERVEUR="" & [M]IMPRIMANTE=""
 GMESSAGE = mess(35,143,1) : # Pour ce type de sortie, il faut au moins renseigner un fichier ou une imprimante
 mkstat = 1 : End
Elsif left$(VALEUR,1)="#" or (instr(1,VALEUR,"@") & [M]IMPRIME<>6)
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat = 1 : End
Elsif [M]SERVEUR<>"" & !GFUSION & !instr(1,VALEUR,"/") & !instr(1,VALEUR,"\") : #SAM109412
 GMESSAGE = mess(160,100,1) : # Le chemin doit être indiqué en absolu
 mkstat = 1 : End
Endif
End

Subprog AS_NBRCPY(VALEUR)
Variable Decimal VALEUR
If !find([M]IMPRIME,2,6) : mkstat = 1 : End : Endif
End

Subprog C_NBRCPY(VALEUR)
Variable Decimal  VALEUR
If [M]NBRCPY<=1 & VALEUR>1 : [M]ASSCPY = 2 : Endif
[M]NBRCPY = VALEUR
If [M]NBRCPY>1 & [M]IMPRIME<>6
 Actzo ASSCPY
Else
 Effzo ASSCPY
 Grizo ASSCPY
Endif
End

Subprog AS_LANGUE(VALEUR)
Variable Char    VALEUR()
If [F:ARP]MULLAN<>2
 If VALEUR="" : VALEUR = GLANGUE    : Endif
 mkstat = 2
 End
Else
 If VALEUR<>""
  Local Integer STD
  Local Char REPLI(GLONLAN)
  Call STDREPLI(VALEUR,STD,REPLI) From SUBTLA
  If STD=2 or (VALEUR=[F:ARP]LAN)
   VALEUR = VALEUR
  Else
   VALEUR = REPLI
  Endif
 Endif
Endif
If VALEUR=""
 VALEUR = [F:ARP]LAN
 If VALEUR="" : VALEUR = GLANGUE : Endif
Endif
End

Subprog AS_FMTFIC(VALEUR)
Variable Integer VALEUR
Local Integer I
Gosub SET_CRPE
If [M]PRT<>"" : mkstat = 2 : End : Endif
If [M]IMPRIME=1 : # Pré-visu
 If [M]SERVEUR=""
  # Historiquement, la notion de pré-visu en C/S affiche le rapport dans une fenêtre standard CR
  # Mais depuis que l'installation de print-engine est optionnel, on doit passer par un serveur d'impression (comme en WEB)
  # Dans ce cas, la valeur par défaut de la pré-visu est "pdf"
  # Conclusion, serveur<>""->prévisu="pdf", serveur=""->"rpt"
  mkstat = 2 : End
 Endif
Elsif !find([M]IMPRIME,3,4,7) and !GBROWS
 mkstat = 2 : End
Endif
Raz GMENLOC
If GBROWS or ([M]IMPRIME=1 & !CRPE) : # Format non autorisé en Web
 GMENLOC(1) = 1 : # rpt
Endif
For I=1 To len(mess(0,91,1)) : # Formats supprimés en V136
 If left$(mess(I,91,1),1)="?"
  GMENLOC(I) = 1
 Endif
Next I
If [M]IMPRIME=1 : # mb 19.12.13 bug 91623
 # mb 22.12.14 demande 104958
 #GMENLOC(28) = 1 : # XLS données uniquement
Endif
If !func SUBAIM.OKXLS([M]SERVEUR)
 GMENLOC(31) = 1 : # Microsoft Excel Workbook
Endif
End

Subprog D_FMTFIC(VALEUR)
Variable Integer VALEUR
Gosub SET_CRPE
If GBROWS or [M]IMPRIME=3 or IMPRIME=7 : # Message/Archive
 VALEUR = 29 : # pdf
Elsif [M]IMPRIME=6 : # Zebra
 VALEUR = 9 : # Ascii
Elsif [M]IMPRIME=1
 If CRPE
  VALEUR = 1 : # rpt
 Else
  VALEUR = 29 : # pdf
 Endif
Elsif VALEUR=0
 VALEUR = 29
Endif
End

