#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL08   Pre-migration factures                      Module Ventes #
############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête facture : SINVOICEV                                               #
# --------------------------                                               #
# Gestion des adresses                                                     #
#                                                                          #
# Migration en V11 :                    : # Issue X3-90233                 #
# ---------------                                                          #
# Détail facture : SINVOICED                                               #
# --------------------------                                               #
# Alim. PJT à partir du champ PJT de l'entête facture                      #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail facture  : SINVOICED                                              #
# ---------------------------                                              #
# Alim. PJT à partir de l'entête si différence                             #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL08") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL08(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

###################################################################################
Subprog MAJ_UUMGPRESAL08(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL08",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL08",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL08 Sales Invoice Process : Update SINVOICE") From DOSSUB
Call ECR_TRACE("UUMGPRESAL08 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
EXE_SQL = 1

If EXE_SQL
  # Mise à jour des champs directement par requête SQL

  # Passage en V6
  If VERSION<GMIGX3VER60
    #1- ajouter la colonne dans la table SIH
    #--------------- Field ADDITION  ----------#
    Call MIGINDCRE (DOSSIER,"SINVOICE","","BPAPAY","A",5,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_SQL1_60
  Endif

Else
  # Mise à jour des champs par boucle de lecture de la table et maj

  # Passage en V6
  If VERSION<GMIGX3VER60
    #1- ajouter la colonne dans la table SIH
    #2- ajouter un index unique
    #--------------- Field ADDITION  ----------#
    Call MIGINDCRE (DOSSIER,"SINVOICE","BPAPAY+BPR+NUM","BPAPAY","A",5,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_X3_60

    #--------------- Suppression index ----------#
    Call MIGINDDEL (DOSSIER,"SINVOICE",ERR) From TRTMIG
    If ERR : Goto FIN : Endif
  Endif

Endif

# Mise à jour des champs directement par une requête SQL
Gosub TRT_SQL2

$FIN
Call ECR_TIME("UUMGPRESAL08 : Sales Invoice Process END.")  From DOSSUB
End

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête facture   : SINVOICE                                              #
# ---------------------                                                    #
# Gestion des adresses                                                     #
############################################################################
$TRT_SQL1_60
#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SIH]) : Close File [SIH] : Endif
If clalev([F:SIH])  = 0 : Local File =DOSSIER+".SINVOICE"    [SIH]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SIH]
GOK = 1

Gosub TRT_SQL1_60_1
Gosub TRT_SQL1_60_2

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SIH]
Return
############################################################################
$TRT_SQL1_60_1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SINVOICE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR,"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCPYR_0=BPR.BPRNUM_0 AND BPC.BPCNUM_0=SINVOICE.BPR_0),' ')"
REQSQL(2)=" WHERE EXISTS (SELECT 'X' FROM"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCNUM_0=SINVOICE.BPR_0 AND SINVOICE.BPRPAY_0=BPC.BPCPYR_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

############################################################################
$TRT_SQL1_60_2
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SINVOICE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR WHERE BPR.BPRNUM_0=SINVOICE.BPRPAY_0),' ')"
REQSQL(2)=" WHERE NOT EXISTS (SELECT 'X' FROM"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCNUM_0=SINVOICE.BPR_0 AND SINVOICE.BPRPAY_0=BPC.BPCPYR_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête facture   : SINVOICE                                              #
# ---------------------                                                    #
# Gestion des adresses                                                     #
############################################################################
$TRT_X3_60
Local Integer COMPTEUR


#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SIH]) : Close File [SIH] : Endif
If clalev([F:SIH])  = 0 : Local File =DOSSIER+".SINVOICE"    [SIH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Filter [SIH] Order By Key CLE=[F:SIH]BPAPAY;[F:SIH]BPR;[F:SIH]NUM

$LOOP_SAL00
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:SIH]BPAPAY='' & [F:SIH]BPR=ACLE1 & [F:SIH]NUM>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:SIH]BPAPAY='' & [F:SIH]BPR>ACLE1"
Else
 CRITERE = "[F:SIH]BPAPAY='' & 1=1"
Endif

Trbegin [SIH]
GOK = 1

For [SIH]CLE Where evalue(CRITERE)

  # --- alimentation des champs et écriture enreg
  Gosub RECUP_BPR

  Rewrite [F:SIH]
  If fstat
    Call ECR_TRACE("File SINVOICE(NUM)"-[F:SIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SIH]BPR
    ACLE2 = [F:SIH]NUM
    STOP=1
    Break
  Endif
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_SAL00
  Endif
Endif

$FIN_1
Gosub UNSET_FIRST From TRTFIRST
Close Local File [SIH]

Call ECR_TIME("UUMGPRESAL08 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return
##############################################################################################
$RECUP_BPR
   If [F:SIH]BPAPAY=""
      If [F:BPC]BPCNUM<>[F:SIH]BPR
        Read [BPC]BPC0=[F:SIH]BPR
        If fstat Raz [F:BPC] Endif
      Endif
      If [F:SIH]BPRPAY=[F:BPC]BPCPYR
          If dim([F:BPC]BPAPYR)>0 & [F:BPC]BPAPYR<>""
              [F:SIH]BPAPAY=[F:BPC]BPAPYR
          Else
              If [F:BPC]BPCPYR<>""
                  If [F:BPR]BPRNUM<>[F:BPC]BPCPYR
                      Read [BPR]BPR0=[F:BPC]BPCPYR : If fstat Raz [F:BPR] Endif
                  Endif
                  [F:SIH]BPAPAY=[F:BPR]BPAADD
              Endif
          Endif
      Else
          ##VVV lecture ssi besoin
          If [BPR]BPRNUM<>[F:SIH]BPRPAY
            Read [BPR]BPR0=[F:SIH]BPRPAY
            If fstat Raz [F:BPR] Endif
          Endif
          [F:SIH]BPAPAY=[F:BPR]BPAADD
      Endif
   Endif
Return
########################################################################
$TRT_SQL2

#----- Ouverture des fichiers -----#
If clalev([F:SIV]) : Close File [SIV] : Endif
If clalev([F:SID]) : Close File [SID] : Endif
If clalev([F:SIV])  = 0 : Local File =DOSSIER+".SINVOICEV"     [SIV]  : Endif
If clalev([F:SID])  = 0 : Local File =DOSSIER+".SINVOICED"     [SID]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SID]
GOK = 1

# Suppression des incohérences entre tables avant migration
# A faire pour toutes les versions
## Passage en V6
#If val(VERSION)<30
  Gosub TRT_SQL2_30 : # Mise à jour SALFCY SINVOICED à partir de SALFCY SINVOICEV
#Endif

# Issue X3-90233
# Passage en V11
If VERSION<GMIGX3VER110
  # Champs à alimenter à partir de la V11
  Gosub TRT_SQL2_110
Endif
# End issue X3-90233

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SIV],[SID]
Return
########################################################################
# Mise à jour SALFCY SINVOICED à partir de SALFCY SINVOICEV
########################################################################
$TRT_SQL2_30
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SINVOICED SET SALFCY_0="
REQSQL(1)="(SELECT SIV.SALFCY_0 FROM"-DOSSIER+".SINVOICEV SIV WHERE SIV.NUM_0=SINVOICED.NUM_0)"
REQSQL(2)=" WHERE SINVOICED.SALFCY_0<>(SELECT SIV.SALFCY_0 FROM"-DOSSIER+".SINVOICEV SIV WHERE SIV.NUM_0=SINVOICED.NUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

############################################################################
# Migration en V11 :                           : # Issue X3-90233          #
# ---------------                                                          #
# Détail facture : SINVOICED                                               #
# --------------------------                                               #
# Alim. PJT à partir du champ PJT de l'entête facture                      #
############################################################################
$TRT_SQL2_110                                  : # Issue X3-90233

Gosub TRT_SQL2_110_1 : # Mise à jour PJT SINVOICED à partir de PJT SINVOICEV    : # Issue X3-90233

Return
############################################################################
# Migration en V11 :                           : # Issue X3-90233          #
# ---------------                                                          #
# Détail facture : SINVOICED                                               #
# --------------------------                                               #
# Alim. PJT à partir du champ PJT de l'entête facture                      #
############################################################################
$TRT_SQL2_110_1                                : # Issue X3-90233
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SINVOICED SET PJT_0="
REQSQL(1)="(SELECT SIV.PJT_0 FROM"-DOSSIER+".SINVOICEV SIV WHERE SIV.NUM_0=SINVOICED.NUM_0)"
REQSQL(2)=" WHERE SINVOICED.PJT_0=' '"

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

