#<AdxTL>@(#)5.0.0.0 $Revision$
#################################################################################
#   Traitement de remise à zéro du champs CCNCRM de la table CONTACT
#   Sylvain DENIS                                      16 JUIN 2000
#################################################################################

$ACTION
Case ACTION
 When "EXEC" Gosub EXEC
 When Default
Endcase
Return

$EXEC
Case GACTION
 When "RAZCNT" Gosub TRTRAZCNT
 When Default
Endcase
Return

$TRTRAZCNT
If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif

Lock [CNT]
    For [CNT]
        If [F:CNT]CCNCRM <> ""
            [F:CNT]CCNCRM = ""
            Rewrite [CNT]
        Endif
    Next
Unlock [CNT]
End
