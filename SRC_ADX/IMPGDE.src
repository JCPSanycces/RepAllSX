#<AdxTL>@(#)12.0.0.0 $Revision$

# Import de transaction de saisie.
# L'objet GDE déclare la table GDIAENTRY qui remplit automatiquement les masque GDIAENTRY0 & GDIAENTRY1
# L'action IMPORT gère via la table GDIAENTRYD, le remplissage des masques GDIAENTRY2, GDIAENTRY3 & GDIAENTRY4 



$ACTION
Case ACTION
 When "IMPORT" : Gosub IMPORT
Endcase
Return


$IMPORT
Case IMPFIC

 When "GDD" : 
  # Selon l'enregistrement
  If [F:GDD]FLD<>""
   If left$( [F:GDD]FLD,4)="CCE."
    K= find( [F:GDD]FLD, [M:GDE4]FLD)
    If K
     nolign = K
     [M:GDE4] = [F:GDD]
    Else    
     [M:GDE4]DIE([M:GDE4]NBRFLD)    = right$([F:GDD]FLD,5)
     [M:GDE4]FLD([M:GDE4]NBRFLD)    = "CCE."+right$([F:GDD]FLD,5)
     [M:GDE4]NBRFLD+=1
     nolign = [M:GDE4]NBRFLD
     [M:GDE4] = [F:GDD]
    Endif
   Else
    K= find( [F:GDD]FLD, [M:GDE3]FLD)
    If K
     nolign = K
     [M:GDE3] = [F:GDD]
    Else
     K= find( [F:GDD]FLD, [M:GDE2]FLD)
     If K
      nolign = K
     [M:GDE2] = [F:GDD]
     Endif    
    Endif
   Endif
  Endif

 Endcase
Return
