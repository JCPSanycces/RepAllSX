#<AdxTL>@(#)2.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Génération des triggers des tables auditées sous SQL
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update audited file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFIL
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFIL
End

#-------------------#
$MAJFIL
If GTYPDBA<>2 or filinfo(filpath("FIL","AUDITH","fde",DOSSIER),0)<=0 : Return : Endif
Local Integer K
Local File =DOSSIER+".ATABLE"  [ATBZ]
For [ATBZ]
 K = (dim([F:ATBZ]AUDBI)>0 & [F:ATBZ]AUDBI=2)
 K += (dim([F:ATBZ]AUDCRE)>0 & ([F:ATBZ]AUDCRE=2 or [F:ATBZ]AUDUPD=2 or [F:ATBZ]AUDDEL=2))
 If K
  Call ECR_TRACE("Update trigger"-[F:ATBZ]CODFIC-"file",0) From GESECRAN
  Call MAJTRIG([F:ATBZ]CODFIC,DOSSIER) From VALDIC
 Endif
Next ATBZ
Return
