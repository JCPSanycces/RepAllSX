#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Suppresion des tables Contarts dans les dossiers suite passage type dossier à système
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Control view file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Table AJSCONT - Deleted in folder:"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Table AJSCONT - Deleted in folder:"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER<>GDOSX3
    Call ECR_TRACE("Table AJSCONT - Deleted in folder:"-DOSSIER,0) From GESECRAN
    Gosub DELCNT
Else
    Call ECR_TRACE("Table AJSCONT - No delete in mother folder:"-DOSSIER,0) From GESECRAN
Endif
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
#Gosub DELCNT    # A ne pas faire sur le dossier de référence
End

#-------------------#
$DELCNT                    # Repris de $ANNULE de SUBATB
Local Integer STAT
Local Char    SUF(10) , FICTRT(GDIMFIC) 
Local Char    MACHINE(GDIMFIC), APPLI(GLONADS)
Local Integer I , OK , STAT , ER
Local Char  CODE(10) : CODE="AJSCONT"

#Call MACHINE(DOS,MACHINE,APPLI) From ORDSYS
APPLI=DOSSIER

Call SYSTEME(adxmac(0),"valfil -n"-APPLI-[L]CODE,"",STAT) From ORDSYS
Call SYSTEME(adxmac(0),"valfil -d"-APPLI-[L]CODE,"",STAT) From ORDSYS
For SUF = "srf", "fde", "dat", "idx" , "cfg"
 FICTRT = filpath("FIL",[L]CODE,SUF,APPLI)
 If filinfo(FICTRT,0)>=0
  Call EFFACE(FICTRT,STAT) From ORDSYS
 Endif
Next SUF



Return
