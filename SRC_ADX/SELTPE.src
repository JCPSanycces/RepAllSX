#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################################
# Modifications :
# -------------
#
# XXX   JJ.MM.AAAA Fq nnnnn_nn Commentaire
# MDJ   24.12.2015 Fq 113247   Adding ENAFLG criteria
# GLE   10.12.2014 Fq104366    Désignation vide si la législation du type d'écriture n'est pas vide
# MDJ   14.11.2012 Fq 85066    NEW : Simplified setup for FA posting types (new table TYPACELEG)
########################################################################################################################
Local Char PARAM(30)(1..5) , VALEUR(10)

PARAM(1) = "FRA"
PARAM(2) = "064"
Call S_LIS_CHAR(VALEUR,PARAM,"SELTPE","SELTPE","") From GACTION

End
#######################################################################
# Actions SELTPE et SELTPELIS
#######################################################################
$ACTION

Case ACTION
  When "SEL_TABLE"
    Case TABLE
      When "SELTPE"    : Gosub SELTPETAB
    Endcase
  When "SEL_LISTE"
    Case LISTE
      When "SELTPELIS"    : Gosub SELTPELIS
    Endcase
  Endcase

Return
#######################################################################
$SELTPETAB

  # Issue 113247 - 2015-12-24 by MDJ : Adding ENAFLG criteria
  OBJET = "TPE"
  CRITERE =    'LEG = '+PARAM(1)+'"'
  CRITERE += '& CPY = '+PARAM(2)+'"'
  CRITERE += '& ENAFLG = G_OUI'
  ORDRE = "[F:TPE]ACETYP"
  START = "[F:TPA]ACETYP"

Return
#======================================================================================================================
# Restreindre la sélection des Types d'écriture en fonction de la législation et éventuellement de la société traitée
#======================================================================================================================
$SELTPELIS
If clalev([F:AXX])=0  :  Local File ATEXTRA    [AXX] : Endif
If clalev([F:TPE])=0  :  Local File TYPACE     [TPE] : Endif

# FQ104366
#Link [TPE] With [AXX]AXX0="TYPACE";"DESTRA";GLANGUE;[F:TPE]ACETYP;[F:TPE]LEG
#& As [LTPE]
Link [TPE] With [AXX]AXX0="TYPACE";"DESTRA";GLANGUE;[F:TPE]ACETYP;""
& As [LTPE]

Local Char TEX(50)(1..rowcount([LTPE]))
Local Char TEXTE(30)(1..rowcount([LTPE]),1..4) , TIT(30)(0..4)
NBTEX = 0
 # Issue 113247 - 2015-12-24 by MDJ : Adding ENAFLG criteria
 For [LTPE]TPE0(1) Where ((LEG=PARAM(1)| LEG ="") and (CPY=PARAM(2)| CPY ="")  and (ENAFLG=G_OUI)  )
  NBTEX += 1
  TEX(NBTEX)     = [F:TPE]ACETYP
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [AXX]TEXTE
  If [F:TPE]LEG <> ""
     TEXTE(NBTEX,3) = [F:TPE]LEG
  Else
     TEXTE(NBTEX,3) = mess(91,187,1)
  Endif
  If [F:TPE]CPY <>  ""
     TEXTE(NBTEX,4) = [F:TPE]CPY
  Else
     TEXTE(NBTEX,4) = mess(444,7773,1)
  Endif
 Next


TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TPE","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
# Type d'écriture
TIT(1) = mess(48,7778,1)
# Intitulé
TIT(2) = mess(3,113,1)
# législation
TIT(3) = mess(218,107,1)
# société
TIT(4) = mess(26,113,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif
Return

