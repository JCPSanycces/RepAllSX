#<AdxTL>@(#)6.0.0.0 $Revision$
Call SYRACUSE_TEST
End

Subprog SYRACUSE_TEST
## Test
GTEST = 1
FreeInstance
FreeInstance [REP]
adxmpr = adxmpr
Call SYRACUSE
GTEST = 0
End

#----------------------------------------------------------------#
Subprog SYRACUSE
#----------------------------------------------------------------#

#Call TRACE_OPEN("D") From ASYRCOM : # Dump /tmp/syracuse.tra with send to Syracuse
#Call TRACE("adxusr:"+adxusr) From ASYRCOM : # Dump /tmp/syracuse.tra with send to Syracuse

If find(adxusr,"EBOYARD","DOM")=0
 Call MAIN From ASYRMEN
Else
 Call MAIN From ASYRMAIN
Endif
End

#----------------------------------------------------------------#
Subprog MAIN
#----------------------------------------------------------------#

# ASYRMEN     Main program
# ASYRDET     Manage "details" requests
# ASYRQRY     Manage "query" requests
# ASYRPRO     Manage requets for prototype description
# ASYRJSO     JSON subprograms (temporary)
# ASYRCOM     Communication program (for tests)

#----------------------------------------------------------------#
# Connection procedure & initializations
#----------------------------------------------------------------#

Local Char     APPLI(10) , OGUSER(10)
Local Integer  OK , STAT
Local Libelle  BIT(1..96)
Local Integer  LOOP , MAXLOOP
Local Integer  STATERROR , ERRNUM

If dim(GUSER)>0 : OGUSER = GUSER : Endif

# Define globals

Call DEFGLOBVAR1 From GLOBVAR
Call INIGLOBVAR1 From GLOBVAR

# Initialize globals

GSERVEUR = 11
GUSER = "ADMIN"
GLOGNAME = "ADMIN"
Call INIGLOBVAR(STAT) From GLOBVAR
If !STAT
 ERRNUM = 9001
 Goto ERR_SESSION
Endif

# Define environnement

Call DEFVAR From ASYRGLOB

Local Instance ACTX Using C_ACONTEXT
ACTX = NewInstance With C_ACONTEXT
# nouvelle façon d'initialisation du contexte
STATERROR = fmet ACTX.ACTX_INIT_LAN(nomap, "FRA", adxusr)
#ACTX.USER = GUSER
#ACTX.LAN = "FRA"
GACTX = ACTX

# Logon

GPROCED = "SYRACUSE"
Call CONNECTSIL From GESUSER
If GPROCED=""
 ERRNUM = 9002
 Goto ERR_SESSION
Endif

# For tests

If OGUSER<>"" : GUSER = OGUSER : Endif
Call TRACE_OPEN("D") From ASYRCOM : # Dump /tmp/syracuse.tra with send to Syracuse
If GTEST
 MAXLOOP = 1
 Call TRACE_OPEN("F") From ASYRCOM : # Log without send to Syracuse
Endif
Call TRACE("adxusr="+adxusr-"GUSER="+GUSER) From ASYRCOM

#If adxusr="ERB"
# Call TRACE_OPEN("F") From ASYRCOM : # Log without send to Syracuse
#Endif


Call TRACE(" *********  adxusr:"+adxusr) From ASYRCOM
# License verification

Call SERIAL(BIT) From ENTREPRISE
If GPROCED=""
 ERRNUM = 9003
 Goto ERR_SESSION
Endif

#----------------------------------------------------------------#
# Main program
#----------------------------------------------------------------#

## Communication Instance with Syracuse server

Local Instance ARCV Using C_ASYRRCV       : # Receive communication instance
Local Instance ASND Using C_ASYRSND       : # Send communication instance

## Main variables

Local Char    REQUEST(30)             : # Type of request
Local Char    SERVICE(64)             : # service

Local Char    MODEL(30)               : # Data model
Local Char    TIMESTAMP(20)           : # Timestamp (prototype)
Local Char    TYPE_REPRES(20)         : # Representation type
Local Char    REPRESENTATION(30)      : # Representation
Local Char    REPRESENTATION_DEF(30)  : # Representation issue first POST
Local Char    REQUEST_DEF(10)         : # Operation issue first POST
Local Char    RES_KEYS(250)               : # Key (string with "~")
Local Char    REPNAM(20)              : # Group of instance
Local Integer RES_NBKEYS                   : # Number of key components
Local Char    KEYVAL(250)(1..16)      : # Values of key components
Local Char    PRGREP(30)              : # Presentation program (generated)
Local Char    PRGEXE(30)              : # Classe program (CRUD)
Local Uuident UIDINS                  : # uuid instance
Local Integer NUMLIN                  : # Line number (array)
Local Char    INSFAT(250)             : # Original instance

## Miscelleanous

Local Integer I , J , K , AI
Local Date    WDATE
Local Char    WCHAINE(250)
Local Char    WLANGUE(GLONLAN)
Local Clbfile WCLOB(8)

## Opening tables and initializations

If clalev([F:ASW])=0 : Local File ASHW    [ASW] : Endif : # Presentation
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif

# Internal parameters

Gosub SET_INTERNAL_PARAMETERS

#----------------------------------------------------------------#
# Response connect to serveur
#----------------------------------------------------------------#

ASND = NewInstance With C_ASYRSND
ASND.STAT = 201
ASND.CONTTYPE = "application/json"
ASND.URL = "/$sessions('"+num$(adxuid(1))+"')"
ASND.DATA = '{"'+'id'+'":"'+num$(adxuid(1))+'"}'
Call SYRSND(ASND) From ASYRCOM
FreeInstance ASND

ARCV = NewInstance With C_ASYRRCV
ASND = NewInstance With C_ASYRSND

#----------------------------------------------------------------#
# Main loop
#----------------------------------------------------------------#

While !MAXLOOP or LOOP<MAXLOOP

 LOOP += 1

 ## Reception

 # For tests
 #-----------------------------
 # 1 Prototype detail (TABCOUNTRY)
 # 2 Prototype query
 # 3 Detail data
 # 4 Query data
 # 5 Prototype detail (ATYPE)
 # 6 Prototype child (ATABAUD)
 # 7 Prototype detail (ACTIV)
 # 8 Query data (ACTIV)
 # 9 Detail data (AJSAUDIT)
 # 12 Cube prototype
 # 16 Image

 Case GUSER
  When "MB"      : Call SYRRCV(11,ARCV) From ASYRCOM
  When "SD"      : Call SYRRCV(11,ARCV) From ASYRCOM
  When "CCL"     : Call SYRRCV(18,ARCV) From ASYRCOM
  When "ERB"     : Call SYRRCV(5,ARCV) From ASYRCOM
  When "LSE"     : Call SYRRCV(6,ARCV) From ASYRCOM
# When "DOM"     : Call SYRRCV(12,ARCV) From ASYRCOM
  When Default   : Call SYRRCV(2,ARCV) From ASYRCOM
 Endcase

 ## Common treatment

 PSYR.PREFIX = ARCV.PREFIX
 If right$(PSYR.PREFIX,len(PSYR.PREFIX))="/"
  PSYR.PREFIX = left$(PSYR.PREFIX,len(PSYR.PREFIX)-1)
 Endif
 PSYR.URL = ARCV.PREFIX+"/"+"originalURL"   : # ??
 Call TRACE("PSYR.PREFIX="+PSYR.PREFIX) From ASYRCOM
 Call TRACE("PSYR.URL="+PSYR.URL) From ASYRCOM

 ## Language

 WLANGUE = func HDRVAL(ARCV,"accept-language")
 #TODO: retirer 0 & lorsque la fonction SEARCH_LANX3 sera de nouveau disponible
 # nouvelle façon d'initialisation du contexte
 STATERROR = fmet ACTX.ACTX_INIT_LAN(nomap, "FRA", adxusr)
 #ACTX.LAN="FRA"
 If WLANGUE<>"" & 1=0
  # Search language X3 in ISO code
  WLANGUE = func ADS_TOOL.SEARCH_LANX3(nomap,WLANGUE)
  # nouvelle façon d'initialisation du contexte
  STATERROR = fmet ACTX.ACTX_INIT_LAN(nomap, WLANGUE, adxusr)
  #ACTX.LAN = WLANGUE
 Endif
 messname(0) = ACTX.LAN
 adxmbm = adxmbm
 If ACTX.LAN=""
  ERRNUM = 9020
  Gosub ERROR From ASYRERR
  Break
 Endif
 Call TRACE("language="+ACTX.LAN) From ASYRCOM

 ## Verb analysis
 ERRNUM = 0
 Case toupper(ARCV.VERB)
  When "GET"        : Gosub TRT_GET
  When "POST","PUT" : Gosub TRT_POST
  When Default      : Gosub TRT_METHOD
 Endcase

 ## Errors

 If ERRNUM
  Gosub ERROR From ASYRERR
  Call SYRSND(ASND) From ASYRCOM
  ERRNUM = 0

 Else

  ## Response

  Call SYRSND(ASND) From ASYRCOM

 Endif

 If GTEST : Break : Endif

Wend

#----------------------------------------------------------------#
# Exit program
#----------------------------------------------------------------#

$END_SESSION
Call TRACE("C'est fini") From ASYRCOM
Call TRACE_END From ASYRCOM
GTEST = 0
FreeInstance
End

$ERR_SESSION
Gosub ERROR From ASYRERR
Call SYRSND(ASND) From ASYRCOM
Goto END_SESSION

#----------------------------------------------------------------#
# URL Parameters
#----------------------------------------------------------------#

$SET_INTERNAL_PARAMETERS
Local Instance  PSYR   Using C_ASYR
PSYR = NewInstance With C_ASYR
PSYR.PRELNK = "application/json;vnd.sage=syracuse"
PSYR.URLPRO = "$prototype"
PSYR.URLNEW = "$template/$workingCopies"
PSYR.URLREP = "?representation="
PSYR.URLUPD = "$workingCopies"
PSYR.CNTPRE = "application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp"
Return

#----------------------------------------------------------------#
# GET verb treatment
#----------------------------------------------------------------#

$TRT_GET

## Reading entities

If func HDRVAL(ARCV,"accept")<>""

 # First row with (or not) key

 K = instr(1,ARCV.ENTITIES(1),"(")
 If K
  REQUEST = toupper(left$(ARCV.ENTITIES(1),K-1))
  KEYS    = seg$(ARCV.ENTITIES(1),K+2,len(ARCV.ENTITIES(1))-2)
 Else
  REQUEST = ARCV.ENTITIES(1)
  KEYS    = ""
 Endif

 # Then, there can be keywords starting with "$"

 If left$(REQUEST,1)="$"

  Case REQUEST

   When "$PROTOTYPES"

    REQUEST = "PROTOTYPE"
    K = instr(1,KEYS,".")
    If K
     REPRESENTATION = left$(KEYS,K-1)
     TYPE_REPRES = right$(KEYS,K+1)
     Case TYPE_REPRES
      When "$query","$details","$edit","$child","$cube","$lookup"
      When Default  : ERRNUM = 9011 : # Break: # Modified by Dom
     Endcase
    Elsif KEYS="{representation}"
     # Representation init by last POST
     TYPE_REPRES = "$edit"
     REPRESENTATION = REPRESENTATION_DEF
    Else
     ERRNUM = 9004
    Endif
   When "$TEMPLATE"

  Endcase

 Else

  TYPE_REPRES = func PARVAL(ARCV,"representation")
  If TYPE_REPRES<>""
   K = instr(1,TYPE_REPRES,".$")
   If K
    REPRESENTATION = toupper(left$(TYPE_REPRES,K-1))
    TYPE_REPRES = right$(TYPE_REPRES,K+1)
   Else
    TYPE_REPRES = ""
   Endif
  Endif

  If TYPE_REPRES<>""
   REQUEST = toupper(right$(TYPE_REPRES,2))
  Else
   # Is there a key (detail) or not (query)
   If KEYS<>""
    REPRESENTATION = REQUEST
    REQUEST = "DETAILS"
   Else
    REPRESENTATION = REQUEST
    REQUEST = "QUERY"
   Endif
  Endif

 Endif

 # Images
 If REPRESENTATION="AIMAGE"
  REQUEST = "IMAGES"
 Elsif (pat(REPRESENTATION,"STATS~*")=0 or TYPE_REPRES<>'$cube') and (REPRESENTATION<>"STATS")
  # Search the representation except if the representation code starts with STATS and type is $cube (Dom)
  Read [ASW]ASW0 = REPRESENTATION
  If fstat
   ERRNUM = 9006 : #   Break: # Modified by Dom
  Endif
 Endif

Else

 # Others rows

Endif

Call TRACE("*** representation="+REPRESENTATION-"type="+TYPE_REPRES-"request="+REQUEST) From ASYRCOM
Call TRACE_STR("ASYRRCV",ARCV) From ASYRCOM

If ERRNUM<>0 : Return : Endif

# Decode ~ separator key

Call DECODE_KEY(RES_KEYS,RES_NBKEYS,KEYVAL)

# Call the appropriate program depending of request

Case REQUEST
 When "IMAGES"    : Gosub GET From ASYRIMG
 When "DETAILS"   : Gosub GET From ASYRDET
 When "QUERY"     : Gosub GET From ASYRQRY
 When "LOOKUP"    : Gosub GET From ASYRQRY
 When "CUBE"      : Gosub GET From SUBPS2
 When "PROTOTYPE" : Gosub GET From ASYRPRO
 When Default     : STATERROR = 2 : ERRNUM = 9015
Endcase

Return

#-----------------------------------------------------#
# Returns the value of a property PARAMCOD in a clob
#-----------------------------------------------------#

Funprog PARVAL(ARCV,PARCOD)
Variable Instance ARCV Using C_ASYRRCV
Value Char PARCOD
Local Clbfile PARVAL(2)
Local Integer I
PARVAL = ""
For I=1 To maxtab(ARCV.PARAMCOD)
 If toupper(ARCV.PARAMCOD(I))=toupper(PARCOD)
  Append PARVAL,ARCV.PARAMVAL(I)
  Break : # For resolve bug browser
 Endif
Next I
End PARVAL

#-----------------------------------------------------#
# Returns the value of a property HEADERCOD in a clob
#-----------------------------------------------------#

Funprog HDRVAL(ARCV,HDRCOD)
Variable Instance ARCV Using C_ASYRRCV
Value Char HDRCOD
Local Clbfile HDRVAL(2)
Local Integer I
HDRVAL = ""
For I=1 To maxtab(ARCV.HEADERCOD)
 If toupper(ARCV.HEADERCOD(I))=toupper(HDRCOD)
  Append HDRVAL,ARCV.HEADERVAL(I)
 Endif
Next I
End HDRVAL

#-----------------------------------------------------#
# Decode ~ separator key
#-----------------------------------------------------#

Subprog DECODE_KEY(KEYS,NBKEY,KEYVAL)
Value Char KEYS
Variable Integer NBKEY
Variable Char KEYVAL()(1..)
Local Char CHAINE(250)
Local Integer K
NBKEY = 0
CHAINE = KEYS
While CHAINE<>"" & NBKEY<dim(KEYVAL)
 NBKEY += 1
 K = instr(1,CHAINE,"~")
 If K
  KEYVAL(NBKEY) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  KEYVAL(NBKEY) = CHAINE
  CHAINE = ""
 Endif
Wend
End

#----------------------------------------------------------------#
# POST verb treatment
#----------------------------------------------------------------#

$TRT_POST
Gosub ERBOU

TYPE_REPRES = ""
REQUEST = ""
If find("$template",ARCV.ENTITIES(1..dim(ARCV.ENTITIES)-1)) & find("$workingCopies",ARCV.ENTITIES(1..dim(ARCV.ENTITIES)-1))
 REPRESENTATION = ARCV.ENTITIES(1)
 REQUEST = "CREATE"

 # Default representation
 REPRESENTATION_DEF = REPRESENTATION
 REQUEST_DEF = REQUEST

Elsif find("$workingCopies",ARCV.ENTITIES(1..dim(ARCV.ENTITIES)-1))

 K = instr(1,ARCV.ENTITIES(1),"(")
 If K
  REPRESENTATION = toupper(left$(ARCV.ENTITIES(1),K-1))
  KEYS    = seg$(ARCV.ENTITIES(1),K+2,len(ARCV.ENTITIES(1))-2)
 Else
  REPRESENTATION = ARCV.ENTITIES(1)
  KEYS    = ""
 Endif

 TYPE_REPRES = func PARVAL(ARCV,"representation")
 If TYPE_REPRES<>""
  K = instr(1,TYPE_REPRES,".$")
  If K
   REPRESENTATION = toupper(left$(TYPE_REPRES,K-1))
   TYPE_REPRES = right$(TYPE_REPRES,K+1)
   Case TYPE_REPRES
    When "$edit" : REQUEST = "UPDATE"
   Endcase
  Else
   TYPE_REPRES = ""
  Endif
 Endif

 # Default representation
 REPRESENTATION_DEF = REPRESENTATION
 REQUEST_DEF        = REQUEST

 # Track Id
 If func ASYRMEN.PARVAL(ARCV,"trackingId")<>""
  Assign "PSYR.WRKUID" With toUuid(func ASYRMEN.PARVAL(ARCV,"trackingId"))
 Endif

Else

 For I=1 To dim(ARCV.ENTITIES)-1
  K = instr(1,ARCV.ENTITIES(I),"(")
  If K & left$(ARCV.ENTITIES(I),K-1)="$workingCopies"
   REQUEST = "EDIT"
   # Track Id
   Assign "PSYR.WRKUID" With toUuid(seg$(ARCV.ENTITIES(I),K+2,len(ARCV.ENTITIES(I))-2))
   Break
  Endif
 Next I
 If REQUEST<>""
  TYPE_REPRES = func PARVAL(ARCV,"representation")
  If TYPE_REPRES<>""
   K = instr(1,TYPE_REPRES,".$")
   If K
    REPRESENTATION = toupper(left$(TYPE_REPRES,K-1))
    TYPE_REPRES = right$(TYPE_REPRES,K+1)
   Else
    TYPE_REPRES = ""
   Endif
  Endif
 Endif
Endif

Case REQUEST
 When "CREATE" : Gosub POST From ASYRCRE
 When "UPDATE" : Gosub POST From ASYRUPD
 When "EDIT"   : Gosub POST From ASYREDT
 When Default  : STATERROR = 2 : ERRNUM = 9016
Endcase

Return

#-------------------------------------------#
# Methods
#-------------------------------------------#

$TRT_METHOD
Case ARCV.VERB
 When "DELETE"
  K = instr(1,ARCV.ENTITIES(1),"(")
  If K
   REPRESENTATION = toupper(left$(ARCV.ENTITIES(1),K-1))
   KEYS    = seg$(ARCV.ENTITIES(1),K+2,len(ARCV.ENTITIES(1))-2)
  Else
   REPRESENTATION = ARCV.ENTITIES(1)
   KEYS    = ""
  Endif
  TYPE_REPRES = func PARVAL(ARCV,"representation")
  If TYPE_REPRES<>""
   K = instr(1,TYPE_REPRES,".$")
   If K
    REPRESENTATION = toupper(left$(TYPE_REPRES,K-1))
    TYPE_REPRES = right$(TYPE_REPRES,K+1)
   Else
    TYPE_REPRES = ""
   Endif
  Endif
  REQUEST = ARCV.VERB
  Gosub DEL From ASYRKIL
 When Default
  REQUEST = ARCV.VERB : STATERROR = 2 : ERRNUM = 9014
Endcase
Return

#----------------------------------#
# I do not know what for
#----------------------------------#

$ERBOU
  If GUSER = "ERBOU"
    Call TRACE("TRT_POST") From WMAXDDBG
  Endif
  If maxtab(ARCV.ENTITIES) > 0 & tolower(ARCV.ENTITIES(1))="$service"
    If I > 1
      SERVICE = ARCV.ENTITIES(2)
    Endif
    If GUSER = "ERBOU"
      Call TRACE("SERVICE=" + SERVICE) From WMAXDDBG
    Endif
    If tolower(SERVICE)="func"
      # just a test
      RES = func ZEBTEST1.ADD(1, 2)
      ASND.STAT     = 200
      ASND.URL      = PSYR.PREFIX + '/$service/func'
      ASND.CONTTYPE = "application/json"
      ASND.DATA = '{"result":'
#      Append ASND.DATA, {"type":"'
#      Append ASND.DATA, func WMAXDDBG.GET_TYPE_NAME(type(RES))
#      Append ASND.DATA, '","value":'
      Append ASND.DATA, num$(RES)
#      Append ASND.DATA, '}'
      Append ASND.DATA, '}'
#      ASND.DATA = '{"result":3}'
      If GUSER = "ERBOU"
        Call TRACE("ASND.DATA=" + ASND.DATA) From WMAXDDBG
        Call TRACE("len(ASND.DATA)=" + num$(len(ASND.DATA))) From WMAXDDBG
      Endif
    Endif
  Endif
Return

Subprog DUMP_RCV(ARCV)
  Const Instance ARCV Using C_ASYRRCV

  Call TRACE("ARCV.VERB=" + ARCV.VERB) From WMAXDDBG
  Call TRACE("ARCV.PREFIX=" + ARCV.PREFIX) From WMAXDDBG
  For I=1 To maxtab(ARCV.HEADERCOD)
    Call TRACE("ARCV.HEADERCOD(" + num$(I) + ")=" + ARCV.HEADERCOD(I)) From WMAXDDBG
  Next I

  For I=1 To maxtab(ARCV.ENTITIES)
    Call TRACE("ARCV.ENTITIES(" + num$(I) + ")=" + ARCV.ENTITIES(I)) From WMAXDDBG
  Next I

  For I=1 To maxtab(ARCV.PARAMCOD)
    Call TRACE("ARCV.PARAMCOD(" + num$(I) + ")=" + ARCV.PARAMCOD(I)) From WMAXDDBG
  Next I

  For I=1 To maxtab(ARCV.PARAMVAL)
    Call TRACE("ARCV.PARAMVAL(" + num$(I) + ")=" + ARCV.PARAMVAL(I)) From WMAXDDBG
  Next I

  Call TRACE("ARCV.JSON=" + ARCV.JSON) From WMAXDDBG
End
