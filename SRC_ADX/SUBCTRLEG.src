$DISPLAY_HIDE
#Subprog DISPLAY_HIDE()
#auto show/hide based on activity codes and GCURLEG
  #Call HIDE_ACTIVITYFIELDS From WOCTRHIDE

#If GUSER="SBA"
# Call DISPLAY_HIDE() From ZSBASUBCTRLEG
# End
#Endif
  Call HIDE_ACTIVITYFIELDS From WOCTRHIDE
  Call SHOW_LEGACTCALLS From WOCTRSHOW

#reshow all fields not protected by localization activity codes
  Local Char WSIGN(1)
  WSIGN=""
  Gosub RESHOW_UNPROTECTED_FIELDS

#reset all block titles that are set below
  Gosub RESET_BLOCK_TITLES

#hide fields specifically for certain localizations
#SAVAN test
  WSIGN="-"
  Gosub SPECIFIC_SOUTH_AFRICA
  Gosub SPECIFIC_AFRICA
  Gosub SPECIFIC_ZAMBIA
  Gosub SPECIFIC_FRANCE
  #JOJAC - 2016-10-25 - REQ114309 - START
  Gosub SPESIFIC_KMIEA
  #JOJAC - 2016-10-25 - REQ114309 - END
  #DEKEE - 2016-11-03 - JIRA X3PEOP-3823 - START
  Gosub SPECIFIC_UK
  #DEKEE - 2016-11-03 - JIRA X3PEOP-3823 - END
  #Gosub ADDRESSES
  #ADNGO - 2018-04-03 - X3-77587 - START
  Gosub SPECIFIC_KPO
  #ADNGO - 2018-04-03 - X3-77587 - END
  #DEKEE - 2016-11-15 - JIRA X3PEOP-3783 - START
  #Affzo [M:CTR4]
  #DEKEE - 2016-11-15 - JIRA X3PEOP-3783 - END
Return
#End

$RESET_BLOCK_TITLES
  If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
  Local Integer WNUMLIBEL

#CTR2
  Read [F:AMKW]CODMSK = "CTR2"
  WNUMLIBEL=[F:AMKW]TITBLOC(1)
  Chgtbk [M:CTR2]5  With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(2)
  Chgtbk [M:CTR2]10 With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(3)
  Chgtbk [M:CTR2]15 With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(7)
  Chgtbk [M:CTR2]35 With func AFNC.TEXTE(WNUMLIBEL)

#CTR4
  Read [F:AMKW]CODMSK = "CTR4"
  WNUMLIBEL=[F:AMKW]TITBLOC(8)
 Chgtbk [M:CTR4]18  With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(5)
  Chgtbk [M:CTR4]19  With func AFNC.TEXTE(WNUMLIBEL)

#CTR5
  Read [F:AMKW]CODMSK = "CTR5"
  WNUMLIBEL=[F:AMKW]TITBLOC(2)
  Chgtbk [M:CTR5]10  With func AFNC.TEXTE(WNUMLIBEL)
  WNUMLIBEL=[F:AMKW]TITBLOC(7)
  Chgtbk [M:CTR5]35  With func AFNC.TEXTE(WNUMLIBEL)
  #WNUMLIBEL=[F:AMKW]TITBLOC(2)
  #Chgtbk [M:CTR5]5  With func AFNC.TEXTE(WNUMLIBEL)
  Chgtbk [M:CTR5]5  With 'Payslip'

  If !func DIVPAYE.IS_KZA(GCURLEG) |  !func DIVPAYE.IS_KZM_LEG(GCURLEG)
    Read [F:AMKW]CODMSK = "CTR4"
    WNUMLIBEL=[F:AMKW]TITBLOC(3)
    Chgtbk [M:CTR4]19  With func AFNC.TEXTE(WNUMLIBEL)
    #Chgtbk [M:CTR4]19  With 'TEST'
  Endif

Return

$RESHOW_UNPROTECTED_FIELDS
#CTR1
  If dim([M:CTR1]DATLIB)>0 : Chgfmt [M:CTR1]DATLIB With WSIGN+"D:"+GFMDAT4 : Endif
