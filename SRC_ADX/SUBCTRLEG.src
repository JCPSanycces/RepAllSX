    If dim([M:CTR5]CARMAK) > 0      : Chgfmt [M:CTR5]CARMAK     With WSIGN+"K:20X"     : Raz [M:CTR5]CARMAK      :   Endif
    If dim([M:CTR5]DIRNUM)>0        : Chgfmt [M:CTR5]DIRNUM     With WSIGN+"K:15X"     : Raz [M:CTR5]DIRNUM      :   Endif
    If dim([M:CTR5]DIRPRC)>0        : Chgfmt [M:CTR5]DIRPRC     With WSIGN+"Nz:0.4"    : Raz [M:CTR5]DIRPRC      :   Endif
