$SPECIFIC_ZAMBIA
#ZAMBIA
  If func DIVPAYE.IS_KZM_LEG(GCURLEG)
  #CTR1
    If dim([M:CTR1]OCPSTA)>0  : Chgfmt [M:CTR1]OCPSTA With WSIGN+"K:20X"  : Endif
    If dim([M:CTR1]OCPSTA)>0  : Raz [M:CTR1]OCPSTA  : Endif

  #CTR2
    If dim([M:CTR2]CATCSP)>0    : Chgfmt [M:CTR2]CATCSP  With WSIGN+"K:20X" : Endif
    If dim([M:CTR2]STACAT)>0    : Chgfmt [M:CTR2]STACAT  With WSIGN+"K:20X" : Endif
    If dim([M:CTR2]STACAT2 )>0  : Chgfmt [M:CTR2]STACAT2 With WSIGN+"K:20X" : Endif
    If dim([M:CTR2]CATJOB)>0    : Chgfmt [M:CTR2]CATJOB  With WSIGN+"K:20X" : Endif

    If dim([M:CTR2]CATCSP)>0    : Raz [M:CTR2]CATCSP  : Endif
    If dim([M:CTR2]STACAT)>0    : Raz [M:CTR2]STACAT  : Endif
    If dim([M:CTR2]STACAT2 )>0  : Raz [M:CTR2]STACAT2 : Endif
    If dim([M:CTR2]CATJOB)>0    : Raz [M:CTR2]CATJOB  : Endif

  #CTR4
    If dim([M:CTR4]SOCCTBTYP)>0 : Chgfmt [M:CTR4]SOCCTBTYP  With WSIGN+"K:15X"      : Endif
    If dim([M:CTR4]SOCSTA)>0    : Chgfmt [M:CTR4]SOCSTA     With WSIGN+"K:10X"      : Endif
    If dim([M:CTR4]SOCCTBREA)>0 : Chgfmt [M:CTR4]SOCCTBREA  With WSIGN+"K:50X"      : Endif
    If dim([M:CTR4]HOUFUNNUM)>0 : Chgfmt [M:CTR4]HOUFUNNUM  With WSIGN+"K:15X"      : Endif
    If dim([M:CTR4]HLTNSSNUM)>0 : Chgfmt [M:CTR4]HLTNSSNUM  With WSIGN+"K:20X"      : Endif
    If dim([M:CTR4]HOUTYP)>0    : Chgfmt [M:CTR4]HOUTYP     With WSIGN+"K:20X"      : Endif
    If dim([M:CTR4]SATCAI)>0    : Chgfmt [M:CTR4]SATCAI     With WSIGN+"K:15X"      : Endif
    If dim([M:CTR4]HOUREGDAT)>0 : Chgfmt [M:CTR4]HOUREGDAT  With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTR4]HOUOCCDAT)>0 : Chgfmt [M:CTR4]HOUOCCDAT  With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTR4]FLRARE)>0    : Chgfmt [M:CTR4]FLRARE     With WSIGN+"LA:11716"   : Endif #DEHEN - 2016-03-03 - Requirement 114867 -  US 1

    If dim([M:CTR4]AFRSUB)>0    : Chgfmt [M:CTR4]AFRSUB     With WSIGN+"K:50X"      : Endif
    If dim([M:CTR4]AFRVIG)>0    : Chgfmt [M:CTR4]AFRVIG     With WSIGN+"K:50X"      : Endif
    If dim([M:CTR4]AFRTRDAUZ)>0 : Chgfmt [M:CTR4]AFRTRDAUZ  With WSIGN+"K:50X"      : Endif
    #If dim([M:CTR4]AFRPRV)>0     : Chgfmt [M:CTR4]AFRPRV      With WSIGN+"K:35X"      : Endif

    #ADNGO - 2017-08-29 - X3-53125 - START
    #If dim([M:CTR4]CARRGSNUM)>0 : Chgfmt [M:CTR4]CARRGSNUM  With WSIGN+"K:50X"      : Endif
    #If dim([M:CTR4]CARMAK)>0    : Chgfmt [M:CTR4]CARMAK     With WSIGN+"K:50X"      : Endif
    If dim([M:CTR5]CARRGSNUM)>0 : Chgfmt [M:CTR5]CARRGSNUM  With WSIGN+"K:50X"      : Endif
    If dim([M:CTR5]CARMAK)>0    : Chgfmt [M:CTR5]CARMAK     With WSIGN+"K:50X"      : Endif
    #ADNGO - 2017-08-29 - X3-53125 - END
    #JOJAC - 2016-07-12 - REQ114309 - START
    If dim([M:CTR4]MRGDAT)>0    : Chgfmt [M:CTR4]MRGDAT     With WSIGN+"D:"+GFMDAT4 : Endif
    #JOJAC - 2016-07-12 - REQ114309 - END

    If dim([M:CTR4]SOCCTBTYP)>0  : Raz [M:CTR4]SOCCTBTYP  : Endif
    If dim([M:CTR4]SOCSTA)>0     : Raz [M:CTR4]SOCSTA     : Endif
    If dim([M:CTR4]SOCCTBREA)>0  : Raz [M:CTR4]SOCCTBREA  : Endif
    If dim([M:CTR4]HOUFUNNUM)>0  : Raz [M:CTR4]HOUFUNNUM  : Endif
    If dim([M:CTR4]HLTNSSNUM)>0  : Raz [M:CTR4]HLTNSSNUM  : Endif
    If dim([M:CTR4]HOUTYP)>0     : Raz [M:CTR4]HOUTYP     : Endif
    If dim([M:CTR4]SATCAI)>0     : Raz [M:CTR4]SATCAI     : Endif
    If dim([M:CTR4]HOUREGDAT)>0  : Raz [M:CTR4]HOUREGDAT  : Endif
    If dim([M:CTR4]HOUOCCDAT)>0  : Raz [M:CTR4]HOUOCCDAT  : Endif
    If dim([M:CTR4]FLRARE)>0     : Raz [M:CTR4]FLRARE     : Endif #DEHEN - 2016-03-03 - Requirement 114867 -  US 1
    If dim([M:CTR4]AFRSUB)>0     : Raz [M:CTR4]AFRSUB     : Endif
    If dim([M:CTR4]AFRVIG)>0     : Raz [M:CTR4]AFRVIG     : Endif
    If dim([M:CTR4]AFRTRDAUZ)>0  : Raz [M:CTR4]AFRTRDAUZ  : Endif
    #ADNGO - 2017-08-29 - X3-53125 - START
    #If dim([M:CTR4]CARRGSNUM)>0  : Raz [M:CTR4]CARRGSNUM  : Endif
    #If dim([M:CTR4]CARMAK)>0     : Raz [M:CTR4]CARMAK     : Endif
    If dim([M:CTR5]CARRGSNUM)>0  : Raz [M:CTR5]CARRGSNUM  : Endif
    If dim([M:CTR5]CARMAK)>0     : Raz [M:CTR5]CARMAK     : Endif
    #ADNGO - 2017-08-29 - X3-53125 - END
    #JOJAC - 2016-07-12 - REQ114309 - START
    If dim([M:CTR4]MRGDAT)>0     : Raz [M:CTR4]MRGDAT     : Endif
    #JOJAC - 2016-07-12 - REQ114309 - END

  #CTR5
    If dim([M:CTR5]DIRAMT)>0     : Chgfmt [M:CTR5]DIRAMT      With WSIGN+"Nz:11.2"    : Endif
    If dim([M:CTR5]DIRNUM)>0     : Chgfmt [M:CTR5]DIRNUM      With WSIGN+"K:15X"      : Endif
    If dim([M:CTR5]DIRPRC)>0     : Chgfmt [M:CTR5]DIRPRC      With WSIGN+"Nz:0.4"     : Endif
    If dim([M:CTR5]PARTIMDIR)>0  : Chgfmt [M:CTR5]PARTIMDIR   With WSIGN+"LA:1"       : Endif
    If dim([M:CTR5]VEHRAT)>0     : Chgfmt [M:CTR5]VEHRAT      With WSIGN+"K:10X"      : Endif
    If dim([M:CTR5]EXOCERNUM)>0  : Chgfmt [M:CTR5]EXOCERNUM   With WSIGN+"K:20X" : Endif
    If dim([M:CTR5]TAXDEP )>0    : Chgfmt [M:CTR5]TAXDEP      With WSIGN+"NZ:2"       : Endif #FRLAA KMZ 2015/09/21
    If dim([M:CTR5]BULDEMAFF)>0   : Chgfmt [M:CTR5]BULDEMAFF  With WSIGN+"LA:10994" : Endif
    #JOJAC - 2016-07-12 - REQ114309 - START
    If dim([M:CTR5]MLTTAXCLS)>0   : Chgfmt [M:CTR5]MLTTAXCLS  With WSIGN+"LA:1" : Endif
    #JOJAC - 2016-07-12 - REQ114309 - END

    If dim([M:CTR5]DIRAMT)>0     : Raz [M:CTR5]DIRAMT     : Endif
    If dim([M:CTR5]DIRNUM)>0     : Raz [M:CTR5]DIRNUM     : Endif
    If dim([M:CTR5]DIRPRC)>0     : Raz [M:CTR5]DIRPRC     : Endif
    If dim([M:CTR5]PARTIMDIR)>0  : Raz [M:CTR5]PARTIMDIR  : Endif
    If dim([M:CTR5]VEHRAT)>0     : Raz [M:CTR5]VEHRAT     : Endif
    If dim([M:CTR5]EXOCERNUM)>0  : Raz [M:CTR5]EXOCERNUM  : Endif
    If dim([M:CTR5]TAXDEP )>0    : Raz [M:CTR5]TAXDEP     : Endif #FRLAA KMZ 2015/09/21
    If dim([M:CTR5]BULDEMAFF)>0   : Raz [M:CTR5]BULDEMAFF : Endif
    #JOJAC - 2016-07-12 - REQ114309 - START
    If dim([M:CTR5]MLTTAXCLS)>0   : Raz [M:CTR5]MLTTAXCLS : Endif
    #JOJAC - 2016-07-12 - REQ114309 - END


    #CTR8
    If dim([M:CTR8]NTCPAY)>0        : Chgfmt [M:CTR8]NTCPAY         With WSIGN+"LA:1"            : Endif
    If dim([M:CTR8]NUMASS)>0        : Chgfmt [M:CTR8]NUMASS         With WSIGN+"K:20X"           : Endif

    If dim([M:CTR8]NTCPAY)>0        : Raz [M:CTR8]NTCPAY               : Endif
    If dim([M:CTR8]NUMASS)>0        : Raz [M:CTR8]NUMASS               : Endif

  #CTR2
    #Chgtbk [M:CTR2]5         With "Yearly Declaration"
    Read [F:AMKW]CODMSK = "CTR2"
    WNUMLIBEL=[F:AMKW]TITBLOC(1)
    Chgtbk [M:CTR2]5  With func AFNC.TEXTE(WNUMLIBEL)
    #Chgtbk [M:CTR2]15         With "Multi-employer"
    WNUMLIBEL=[F:AMKW]TITBLOC(2)
    Chgtbk [M:CTR2]15  With func AFNC.TEXTE(WNUMLIBEL)
   #CTR5
    Chgtbk [M:CTR5]10         With "Prepayments"
    #Read [F:AMKW]CODMSK = "CTR5"
    #WNUMLIBEL=[F:AMKW]TITBLOC(2)
    #Chgtbk [M:CTR5]10  With func AFNC.TEXTE(WNUMLIBEL)

 Endif
Return

$SPECIFIC_FRANCE
#FRANCE
  If func DIVPAYE.IS_KFR_LEG(GCURLEG)
    If dim([M:CTRB]WENDDATPEN) > 0 : Diszo [M:CTRB]WENDDATPEN : Endif
    If dim([M:CTRB]WSTRDATPEN) > 0 : Diszo [M:CTRB]WSTRDATPEN : Endif
  Else
    If dim([M:CTRB]WENDDATPEN) > 0 : Actzo [M:CTRB]WENDDATPEN : Endif
    If dim([M:CTRB]WSTRDATPEN) > 0 : Actzo [M:CTRB]WSTRDATPEN : Endif
  Endif
Return

