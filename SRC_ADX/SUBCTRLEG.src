#ADNGO - 2017-02-07 - X3-76210 - END
#PEVAN - 2018-06-19 - X3-82107 - END

#CTR2
  If dim([M:CTR2]CATCSP)>0      : Chgfmt [M:CTR2]CATCSP     With WSIGN+"K:20X"      : Endif
  If dim([M:CTR2]PSNJOB)>0      : Chgfmt [M:CTR2]PSNJOB     With WSIGN+"K:20X"      : Endif
  If dim([M:CTR2]STACAT2 )>0    : Chgfmt [M:CTR2]STACAT2    With WSIGN+"K:20X"      : Endif
#JASMI - 2018-01-09 - X3-70568 - START
  If dim([M:CTR2]RSKWRK)>0      : Chgfmt [M:CTR2]RSKWRK     With WSIGN+"K:20"         Endif
  If dim([M:CTR2]WAGPAYPER)>0   : Chgfmt [M:CTR2]WAGPAYPER  With WSIGN+"L:801"        Endif
#JASMI - 2018-01-09 - X3-70568 - END

#CTR4
  If dim([M:CTR4]CIVCTRA) > 0   : Chgfmt [M:CTR4]CIVCTRA    With WSIGN+"K:15X"      : Endif

  If func AFNC.ACTIV("HRPAY")
  #CTR2
    If dim([M:CTR2]STACAT)>0    : Chgfmt [M:CTR2]STACAT     With WSIGN+"K:20X" : Endif
    If dim([M:CTR2]CATJOB)>0    : Chgfmt [M:CTR2]CATJOB     With WSIGN+"K:20X" : Endif
    If dim([M:CTR2]OPEDED)>0    : Chgfmt [M:CTR2]OPEDED     With WSIGN+"LA:5"  : Endif
    If dim([M:CTR2]SYSMAL)>0    : Chgfmt [M:CTR2]SYSMAL     With WSIGN+"K:20X" : Endif
  Endif

  If func AFNC.ACTIV("FRT")
  #CTR2
    If dim([M:CTR2]CATFRT )>0   : Chgfmt [M:CTR2]CATFRT     With WSIGN+"K:20X" : Endif
  Endif

