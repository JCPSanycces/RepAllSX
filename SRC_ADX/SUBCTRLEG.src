$SPECIFIC_KPO

If func DIVPAYE.IS_KPO_LEG(GCURLEG) #| func DIVPAYE.IS_KAO_LEG(GCURLEG)  : for now i only need to run this for KPO
  #CTR2
  If dim([M:CTR2]OPEDED)>0        : Chgfmt [M:CTR2]OPEDED       With WSIGN+"LA:10320"        : Raz [M:CTR2]OPEDED   :   Endif
  If dim([M:CTR2]CATFRT)>0        : Chgfmt [M:CTR2]CATFRT       With WSIGN+"K:20X"           : Raz [M:CTR2]CATFRT   :   Endif
  Chgtbk [M:CTR2]5 With "Legal declarations"
  Chgtbk [M:CTR2]10 With "DADSU Social Security scheme"
  Chgtbk [M:CTR2]15 With "Multi-employer"

  #CTR4
  If dim([M:CTR4]CIVCTRA)>0       : Chgfmt [M:CTR4]CIVCTRA        With WSIGN+"K:15X"        : Raz [M:CTR4]CIVCTRA  :  Endif
  If dim([M:CTR4]WRKNATLEG)>0     : Chgfmt [M:CTR4]WRKNATLEG      With WSIGN+"LA:10996"     : Raz [M:CTR4]WRKNATLEG:  Endif
