    If dim([M:CTR4]SOCSTA) > 0      : Chgfmt [M:CTR4]SOCSTA     With WSIGN+"LA:117070"   : Raz [M:CTR4]SOCSTA      :   Endif
    If dim([M:CTR4]SSCNUM) > 0      : Chgfmt [M:CTR4]SSCNUM     With WSIGN+"K:15X"       : Raz [M:CTR4]SSCNUM      :   Endif
