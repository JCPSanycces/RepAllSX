##Change block titles
#  If func DIVPAYE.IS_BRI_LEG(GCURLEG)
#    Chgtbk [M:EMP0]6           With mess(2,11800,1)
#    Chgtbk [M:EMP0]11          With mess(1,11800,1)
#    Chgtbk [M:EMP2]10          With mess(4,11800,1)
#    Chgtbk [M:EMP2]50          With mess(3,11800,1)
#  Endif

#Rename fields / tabs
#  #HRMAT2
#  If GCURLEG = 'BRI'
#    Chgtfd [M:EMP3]           With mess(6,11800,1)
#    Chgtzn [M:EMP2]DATBRN     With mess(5,11800,1)
#  Endif

#Hide fields
If GCURLEG = 'BRI'

    #CTR2 - DEHEN
    #Change block title
    Chgtbk [M:CTR2]5       With "General"
    If dim([M:CTR5]RTIABS)>0    : Chgfmt [M:CTR5]RTIABS     With WSIGN+"LA:4"      : Endif #HEGES - X3-45742 - 2017-06-22
    If dim([M:CTR2]CATCSP)>0    : Chgfmt [M:CTR2]CATCSP     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]PSNJOB)>0    : Chgfmt [M:CTR2]PSNJOB     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]STACAT)>0    : Chgfmt [M:CTR2]STACAT     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]STACAT2 )>0  : Chgfmt [M:CTR2]STACAT2    With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]CATJOB)>0    : Chgfmt [M:CTR2]CATJOB     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]OPEDED)>0    : Chgfmt [M:CTR2]OPEDED     With WSIGN+"LA:5"      : Endif
    If dim([M:CTR2]MAIFCY)>0    : Chgfmt [M:CTR2]MAIFCY     With WSIGN+"LA:1"      : Endif
    #If dim([M:CTR2]WAGPAYPER)>0 : Chgfmt [M:CTR2]WAGPAYPER  With WSIGN+"LA:10801"  : Endif
    If dim([M:CTR2]SEVEMP)>0    : Chgfmt [M:CTR2]SEVEMP     With WSIGN+"LA:10944" : Endif
    #If dim([M:CTR2]SEVCTR)>0    : Chgfmt [M:CTR2]SEVCTR     With WSIGN+"LA:10944" : Endif
    If dim([M:CTR2]CTRCODSEE)>0 : Chgfmt [M:CTR2]CTRCODSEE  With WSIGN+"K:4X"      : Endif
    If dim([M:CTR2]SYSMAL)>0    : Chgfmt [M:CTR2]SYSMAL     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]CATFRT)>0    : Chgfmt [M:CTR2]CATFRT     With WSIGN+"K:20X"     : Endif
    If dim([M:CTR2]STRDATSEV)>0 : Chgfmt [M:CTR2]STRDATSEV  With WSIGN+"D:"+GFMDAT4  : Raz [M:CTR2]STRDATSEV  : Endif #TODO Enter code in SUBCTR
    If dim([M:CTR2]ENDDATSEV)>0 : Chgfmt [M:CTR2]ENDDATSEV  With WSIGN+"D:"+GFMDAT4  : Raz [M:CTR2]ENDDATSEV  : Endif #TODO Enter code in SUBCTR
    If dim([M:CTR2]FINYEASTR)>0 : Chgfmt [M:CTR2]FINYEASTR  With WSIGN+"D:"+GFMDAT4  : Raz [M:CTR2]FINYEASTR  : Endif
    If dim([M:CTR2]FINYEAEND)>0 : Chgfmt [M:CTR2]FINYEAEND  With WSIGN+"D:"+GFMDAT4  : Raz [M:CTR2]FINYEAEND  : Endif
    #CTR5
    #DEHEN - X3-36476/X3-36478/X3-36607// - 2017-05-10 - START
    Chgtbk [M:CTR5]10       With mess(36, 11800, 1)
    Chgtzn [M:CTR5]EXOSTR1  With mess(37, 11800, 1)
    Chgtzn [M:CTR5]EXOSTR2  With mess(37, 11800, 1)
    Chgtzn [M:CTR5]EXOSTR3  With mess(37, 11800, 1)
    Chgtzn [M:CTR5]EXOSTR4  With mess(37, 11800, 1)
    Chgtzn [M:CTR5]EXOEND1  With mess(38, 11800, 1)
    Chgtzn [M:CTR5]EXOEND2  With mess(38, 11800, 1)
    Chgtzn [M:CTR5]EXOEND3  With mess(38, 11800, 1)
    Chgtzn [M:CTR5]EXOEND4  With mess(38, 11800, 1)
    Chgtbk [M:CTR5]35       With "Totals"
    #DEHEN - X3-36476//// - 2017-05-10 - End
    #Hide blocks
    #If dim([M:CTR5]NBRSAL)>0 Chgfmt [M:CTR5]NBRSAL           With WSIGN-"N:4"   : Raz [M:CTR5]NBRSAL     : Endif
    #Hide fields
    #If dim([M:CTR5]TWDPAY)>0    Chgfmt [M:CTR5]TWDPAY        With WSIGN-"LA:1"   : Raz [M:CTR5]TWDPAY     : Endif
    #If dim([M:CTR5]OBJRUB)>0    Chgfmt [M:CTR5]OBJRUB        With WSIGN-"K:10X"   : Raz [M:CTR5]OBJRUB     : Endif
    #If dim([M:CTR5]OBJVAR)>0    Chgfmt [M:CTR5]OBJVAR        With WSIGN-"K:10X"   : Raz [M:CTR5]OBJVAR     : Endif
    #If dim([M:CTR5]INCVAR)>0    Chgfmt [M:CTR5]INCVAR        With WSIGN-"K:10X"   : Raz [M:CTR5]INCVAR     : Endif
    #If dim([M:CTR5]INSAMT)>0    Chgfmt [M:CTR5]INSAMT        With WSIGN-"N:9.2"  : Raz [M:CTR5]INSAMT     : Endif
    #If dim([M:CTR5]INSDAY)>0    Chgfmt [M:CTR5]INSDAY        With WSIGN-"C:2"    : Raz [M:CTR5]INSDAY     : Endif
    #DEKEE - 2016-11-03 - JIRA X3PEOP-4117 - START
    #If dim([M:CTR5]RPTBUL)>0    Chgfmt [M:CTR5]RPTBUL        With WSIGN-"ARP"   : Raz [M:CTR5]RPTBUL     : Endif
