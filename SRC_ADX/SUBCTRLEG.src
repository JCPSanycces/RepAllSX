    If dim([M:CTR2]RSKWRK)>0          : Chgfmt [M:CTR2]RSKWRK           With WSIGN+"K:20"        : Raz [M:CTR2]RSKWRK     :   Endif
    If dim([M:CTR2]WAGPAYPER)>0       : Chgfmt [M:CTR2]WAGPAYPER        With WSIGN+"L:801"       : Raz [M:CTR2]WAGPAYPER  :   Endif
    If dim([M:CTR2]OPEDED )>0         : Chgfmt [M:CTR2]OPEDED           With WSIGN+"L:10320"     : Raz [M:CTR2]OPEDED     :   Endif

  #CTR4

    If dim([M:CTR4]CARTIKRES)>0       :   Chgfmt [M:CTR4]CARTIKRES      With WSIGN+"LA:1"         : Raz [M:CTR4]CARTIKRES  :  Endif
    If dim([M:CTR4]ORGMAL)>0          :   Chgfmt [M:CTR4]ORGMAL         With WSIGN+"K:20"         : Raz [M:CTR4]ORGMAL     :  Endif
    If dim([M:CTR4]WRKADD3)>0         :   Chgfmt [M:CTR4]WRKADD3        With WSIGN+"K:20X"        : Raz [M:CTR4]WRKADD3    :  Endif
    If dim([M:CTR4]WRKCODSEE)>0       :   Chgfmt [M:CTR4]WRKCODSEE      With WSIGN+"K:5X"         : Raz [M:CTR4]WRKCODSEE  :  Endif
    If dim([M:CTR4]WRKNATLEG)>0       :   Chgfmt [M:CTR4]WRKNATLEG      With WSIGN+"LA:10996"     : Raz [M:CTR4]WRKNATLEG  :  Endif
    If dim([M:CTR4]NUMSSCCTR)>0       :   Chgfmt [M:CTR4]NUMSSCCTR      With WSIGN+"K:30X"        : Raz [M:CTR4]NUMSSCCTR  :  Endif
    If dim([M:CTR4]NUMSSCCTR2)>0      :   Chgfmt [M:CTR4]NUMSSCCTR2     With WSIGN+"K:30X"        : Raz [M:CTR4]NUMSSCCTR2 :  Endif

  #CTR5
    If dim([M:CTR5]ZON1)>0            :   Chgfmt [M:CTR5]ZON1         With WSIGN+"N:9.2"          : Raz [M:CTR5]ZON1      :  Endif
    If dim([M:CTR5]ZON2)>0            :   Chgfmt [M:CTR5]ZON2         With WSIGN+"N:9.2"          : Raz [M:CTR5]ZON2       :  Endif

  #CTR8
    If dim([M:CTR8]FLGPRV)>0          :   Chgfmt [M:CTR8]FLGPRV         With WSIGN+"LA:1"         : Raz [M:CTR8]FLGPRV     :  Endif
    If dim([M:CTR8]STRTIMNTC)>0       :   Chgfmt [M:CTR8]STRTIMNTC      With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]STRTIMNTC  :  Endif
    If dim([M:CTR8]ENDTIMNTC)>0       :   Chgfmt [M:CTR8]ENDTIMNTC      With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]ENDTIMNTC  :  Endif
    If dim([M:CTR8]FLGPRV2)>0         :   Chgfmt [M:CTR8]FLGPRV2        With WSIGN+"LA:1"         : Raz [M:CTR8]FLGPRV2    :  Endif
    If dim([M:CTR8]STRNTC2)>0         :   Chgfmt [M:CTR8]STRNTC2        With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]STRNTC2    :  Endif
    If dim([M:CTR8]ENDNTC2)>0         :   Chgfmt [M:CTR8]ENDNTC2        With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]ENDNTC2    :  Endif
    If dim([M:CTR8]STRNTC3)>0         :   Chgfmt [M:CTR8]STRNTC3        With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]STRNTC3    :  Endif
    If dim([M:CTR8]ENDNTC3)>0         :   Chgfmt [M:CTR8]ENDNTC3        With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]ENDNTC3    :  Endif
    If dim([M:CTR8]FLGXITPRV)>0       :   Chgfmt [M:CTR8]FLGXITPRV      With WSIGN+"LA:1"         : Raz [M:CTR8]FLGXITPRV  :  Endif
    If dim([M:CTR8]STRXITPRV)>0       :   Chgfmt [M:CTR8]STRXITPRV      With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]STRXITPRV  :  Endif
    If dim([M:CTR8]ENDXITPRV)>0       :   Chgfmt [M:CTR8]ENDXITPRV      With WSIGN+"D:"+GFMDAT4   : Raz [M:CTR8]ENDXITPRV  :  Endif
    If dim([M:CTR8]FLGPRV3)>0         :   Chgfmt [M:CTR8]FLGPRV3        With WSIGN+"LA:1"         : Raz [M:CTR8]FLGPRV3    :  Endif
  #ADNGO - 2017-12-06 - X3-60300 - END
Endif
Return
#JOJAC - 2016-10-25 - REQ114309 - END

#JOJAC - 2016-07-07 - REQ114309 - START
Subprog AS_MRGDAT(VALEUR)
Variable Date    VALEUR

  If (func DIVPAYE.IS_KAO_LEG(GCURLEG) or func DIVPAYE.IS_KSZ_LEG(GCURLEG) or func DIVPAYE.IS_KLS_LEG(GCURLEG))
    If dim([M:CTR4]MRGDAT)>0 :  Chgfmt [M:CTR4]MRGDAT  With "D:"+GFMDAT4 :Endif
  Else
     If dim([M:CTR4]MRGDAT)>0 :  Chgfmt [M:CTR4]MRGDAT  With "-D:"+GFMDAT4 :Endif
  Endif
  #JOJAC - 2016-07-07 - REQ114309 - END
End

#JOJAC - 2016-07-13 - REQ114309 - START
Subprog BEFORE_ENTRY(VALEUR)
Variable Date VALEUR
Local Char WSIGN(1)
WSIGN="-"

  If func DIVPAYE.IS_KZM_LEG(GCURLEG)
    If dim([M:CTR4]MRGDAT)>0 : Chgfmt [M:CTR4]MRGDAT With WSIGN+"D:"+GFMDAT4 : Endif

    If dim([M:CTR4]MRGDAT)>0 : Raz [M:CTR4]MRGDAT : Endif
  Endif

  #Subprog SHOW_FINTM()
  If !func DIVPAYE.IS_KFR_LEG(GCURLEG)
    If dim([M:CTR3]PSNENDDAT)>0  : Chgfmt [M:CTR3]PSNENDDAT  With WSIGN+"D:"+GFMDAT4   : Endif
    If dim([M:CTR3]PSNSTRDAT)>0  : Chgfmt [M:CTR3]PSNSTRDAT  With WSIGN+"D:"+GFMDAT4   : Endif
    If dim([M:CTR3]PYRDAT)>0     : Chgfmt [M:CTR3]PYRDAT     With WSIGN+"D:"+GFMDAT4   : Endif
    #Subprog SHOW_KFR()
    If dim([M:CTR1]STRCAE)>0     : Chgfmt [M:CTR1]STRCAE     With   WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTRB]ENDDATPEN)>0  : Chgfmt [M:CTRB]ENDDATPEN  With   WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTRB]STRDATPEN)>0  : Chgfmt [M:CTRB]STRDATPEN  With   WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTRB]WENDDATPEN)>0 : Chgfmt [M:CTRB]WENDDATPEN With   WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTRB]WSTRDATPEN)>0 : Chgfmt [M:CTRB]WSTRDATPEN With   WSIGN+"D:"+GFMDAT4 : Endif

    If dim([M:CTR3]PSNENDDAT)>0  : Raz [M:CTR3]PSNENDDAT  : Endif
    If dim([M:CTR3]PSNSTRDAT)>0  : Raz [M:CTR3]PSNSTRDAT  : Endif
    If dim([M:CTR3]PYRDAT)>0     : Raz [M:CTR3]PYRDAT     : Endif
    #Subprog SHOW_KFR()
    If dim([M:CTR1]STRCAE)>0     : Raz [M:CTR1]STRCAE     : Endif
    If dim([M:CTRB]ENDDATPEN)>0  : Raz [M:CTRB]ENDDATPEN  : Endif
    If dim([M:CTRB]STRDATPEN)>0  : Raz [M:CTRB]STRDATPEN  : Endif
    If dim([M:CTRB]WENDDATPEN)>0 : Raz [M:CTRB]WENDDATPEN : Endif
    If dim([M:CTRB]WSTRDATPEN)>0 : Raz [M:CTRB]WSTRDATPEN : Endif
  Endif

  #Subprog SHOW_KAFR()
  If !func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
    #If dim([M:CTR4]HOUOCCDAT)>0 : Chgfmt [M:CTR4]HOUOCCDAT With WSIGN+"D:"+GFMDAT4 : Endif
    #If dim([M:CTR4]HOUREGDAT)>0 : Chgfmt [M:CTR4]HOUREGDAT With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTR4]MRGDAT)>0    : Chgfmt [M:CTR4]MRGDAT    With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTR5]TAXENDDAT)>0 : Chgfmt [M:CTR5]TAXENDDAT With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTR5]TAXSTRDAT)>0 : Chgfmt [M:CTR5]TAXSTRDAT With WSIGN+"D:"+GFMDAT4 : Endif

    #If dim([M:CTR4]HOUOCCDAT)>0 : Raz [M:CTR4]HOUOCCDAT : Endif
    #If dim([M:CTR4]HOUREGDAT)>0 : Raz [M:CTR4]HOUREGDAT : Endif
    If dim([M:CTR4]MRGDAT)>0    : Raz [M:CTR4]MRGDAT    : Endif
    If dim([M:CTR5]TAXENDDAT)>0 : Raz [M:CTR5]TAXENDDAT : Endif
    If dim([M:CTR5]TAXSTRDAT)>0 : Raz [M:CTR5]TAXSTRDAT : Endif
  Endif

  #Subprog SHOW_KMIEA()
  If !func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
    If dim([M:CTRA]LEARSMDAT)>0 : Chgfmt [M:CTRA]LEARSMDAT With WSIGN+"D:"+GFMDAT4 : Endif
    If dim([M:CTRA]LEARSMDAT)>0 : Raz [M:CTRA]LEARSMDAT : Endif
  Endif

  #Subprog SHOW_KZA()
  If !func DIVPAYE.IS_KZA(GCURLEG)
    If dim([M:CTR5]IRPSTRDAT)>0 : Chgfmt [M:CTR5]IRPENDDAT With WSIGN+'D:MM[/]DD[/]YYYY' : Endif
#    Grizo [M:CTR5]IRPSTRDAT
    If dim([M:CTR5]IRPENDDAT)>0 : Chgfmt [M:CTR5]IRPSTRDAT With WSIGN+'D:MM[/]DD[/]YYYY' : Endif

    If dim([M:CTR5]IRPSTRDAT)>0 : Raz [M:CTR5]IRPENDDAT : Endif
    If dim([M:CTR5]IRPENDDAT)>0 : Raz [M:CTR5]IRPSTRDAT : Endif
  Endif
End

