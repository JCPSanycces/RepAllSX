#<AdxTL>@(#)0.0.0.0 $Revision$
#Segay declaration ACTION
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "LIENS"     : Gosub LIENS
Endcase
Return

$OUVRE
#Segay declaration of table EMPLOIDPOR
#TYPTABLE=1 Table enreg 1=1 with EMPLOID
# Write, Update and delete are managed in SUBEML
NBTBL += 1 : TBTABLE(NBTBL) = "EMPLOIDPOR" : TYPTABLE(NBTBL) = 1
MSKTAB(NBTBL) = "2" : TBABREV(NBTBL) = "IDPOR"
If clalev([F:IDPOR])=0 : Local File EMPLOIDPOR [IDPOR] : Endif


Return
######################################################################################
#Segay DISPLAY fields xxxDIS
$RAZCRE
# Issue 110164 - 2016-01-15 by BRBAN : not needed for ANG
If func AFNC.ACTIV("KAO")>0 : Return : Endif
Gosub AFF_DISFLD
Return
######################################################################################
$LIENS

#MAPAD - 2016-05-03 - Req 114309 - START
If !func SUBEML.IS_LEG('ANG')
  Return
Endif
#MAPAD - 2016-05-03 - Req 114309 - END


Gosub AFF_DISFLD
Return

#Segay DISPLAY fields xxxDIS
$AFF_DISFLD
 ZONE = "CHD" : Gosub SET_ZONE From SUBEML2
 If MA Then
    If [M]CHD>0
      Actzo [M]CHDDIS
    Else
      Diszo [M]CHDDIS
    Endif
 Endif
 ZONE = "NBRHLD" : Gosub SET_ZONE From SUBEML2
 If MA Then
   If [M]NBRHLD=2
      Actzo [M]JNTDIS
    Else
      Diszo [M]JNTDIS
    Endif
 Endif

Return
######################################################################################
######################################################################################
$VERIF
#BRBAN Alterar isto nos restantes ambientes.
#MAPAD - 2016-05-03 - Req 114309 - START
If !func SUBEML.IS_LEG('ANG')
  Return
Endif
#MAPAD - 2016-05-03 - Req 114309 - END

# Default value = Yes (2)
Local Integer AWNSR    : AWNSR = 2 :# Yes
Read [F:FCY]FCY0 = [M:EMP0]FCY
If !fstat
  If [F:FCY]CRY = 'PT' & [M:EMP3]SRCRET = ''
    Call OUINON(mess(1,11553,1), [L]AWNSR) From GESECRAN
    If [L]AWNSR <> 2 : OK = 0 : Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
Subprog AS_SRCRET(VALEUR)
Variable Char    VALEUR()

If VALEUR<>'' & [M:EMP1]CRY='PT'  : End : Endif
If [M:EMP1]CRY<>'PT' : VALEUR=''  : End : Endif

Call AFF_SRCRET([M:EMP2]SITFAM,[M:EMP0]FCY,[M:EMP2]NBRHLD,VALEUR,[M:EMP3]FLGHDC,[M:EMP2]COIPLN)
Affzo [M]SRCRET

End
######################################################################################
######################################################################################
Subprog REGION(FCY,REGION)
Value     Char FCY
Variable  Integer REGION

# Variable Region
# 1 - Continent
# 2 - Azores
# 3 - Madeira

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif

Read [F:FCY]FCY0=[L]FCY
If !fstat
  Read [F:BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
  If !fstat
    If left$([F:BPA]POSCOD,2)>="90" & left$([F:BPA]POSCOD,2)<="94"
      [L]REGION= 3
    Elsif left$([F:BPA]POSCOD,2)>"94"
      [L]REGION= 2
    Else
      [L]REGION= 1
    Endif
  Endif
Endif
End
######################################################################################
######################################################################################
Subprog AM_CHD(VALEUR)
Variable Decimal VALEUR


If VALEUR>0
  If dim([M:EMP2]CHDDIS) > 0 : Actzo [M:EMP2]CHDDIS : Endif
Else
  If dim([M:EMP2]CHDDIS) > 0 : Raz   [M:EMP2]CHDDIS : Endif
  If dim([M:EMP2]CHDDIS) > 0 : Diszo [M:EMP2]CHDDIS : Endif
Endif
If dim([M:EMP2]CHDDIS) > 0 : Affzo [M:EMP2]CHDDIS : Endif

End
######################################################################################
######################################################################################
Subprog AM_NBRHLD(VALEUR)
Variable Decimal VALEUR

If VALEUR=2
  Actzo [M:EMP2]JNTDIS
Else
  Raz   [M:EMP2]JNTDIS
  Diszo [M:EMP2]JNTDIS
Endif
Affzo [M:EMP2]JNTDIS

Call AFF_SRCRET([M:EMP2]SITFAM,[M:EMP0]FCY,VALEUR,[M:EMP3]SRCRET,[M:EMP3]FLGHDC,[M:EMP2]COIPLN)
Affzo [M:EMP3]SRCRET


End
######################################################################################
######################################################################################
Subprog AM_SITFAMA(VALEUR)
Variable Char    VALEUR()

If find([M:EMP2]SITFAM,2,6)
  [M:EMP2]NBRHLD=2
Else
  [M:EMP2]NBRHLD=1
Endif
Affzo [M:EMP2]NBRHLD

Call AFF_SRCRET([M:EMP2]SITFAM,[M:EMP0]FCY,[M:EMP2]NBRHLD,[M:EMP3]SRCRET,[M:EMP3]FLGHDC,[M:EMP2]COIPLN)
Affzo [M:EMP3]SRCRET


End
######################################################################################
######################################################################################
Subprog AM_FLGHDC(VALEUR)
Variable Integer VALEUR
Call AFF_SRCRET([M:EMP2]SITFAM,[M:EMP0]FCY,[M:EMP2]NBRHLD,[M:EMP3]SRCRET,VALEUR,[M:EMP2]COIPLN)
Affzo [M:EMP3]SRCRET


End
######################################################################################
######################################################################################
Subprog AM_COIPLN(VALEUR)
Variable Integer VALEUR

Call AFF_SRCRET([M:EMP2]SITFAM,[M:EMP0]FCY,[M:EMP2]NBRHLD,[M:EMP3]SRCRET,[M:EMP3]FLGHDC,VALEUR)
Affzo [M:EMP3]SRCRET


End
######################################################################################
######################################################################################
Subprog AFF_SRCRET(STFAM,FACIL,HLD,RET,HDC,COI)
Value Integer    STFAM
Value Char    FACIL
Value Shortint   HLD
Variable Char    RET
Value Integer    HDC
Value Integer    COI

Local Char    INDRET(30) : [L]INDRET  = ''
Local Integer REG        : [L]REG     = 0
Local Integer AWNSR      : [L]AWNSR   = 2 :# Yes

If [L]RET<> ''
  Call OUINON(mess(14,11553,1), [L]AWNSR) From GESECRAN
  If [L]AWNSR <> 2 : End: Endif
Endif

If clalev([M:EMP1])<>0
  If [M:EMP1]CRY<>'PT'
    [L]RET=''
    End
  Endif
Endif

[L]RET=''
[L]RET='IRS_'

If [L]COI<>2
  If [L]HDC=1
    If [L]STFAM<>2 & [L]STFAM<>6
     [L]INDRET='1'
    Else
      If [L]HLD<2
        [L]INDRET='2'
      Else
        [L]INDRET='3'
      Endif
    Endif
    Call REGION([L]FACIL,[L]REG)
    Case [L]REG
      When 1  : [L]RET += 'CO'+[L]INDRET
      When 2  : [L]RET += 'AC'+[L]INDRET
      When 3  : [L]RET += 'MA'+[L]INDRET
    Endcase
  Else
    If [L]STFAM<>2 & [L]STFAM<>6
     [L]INDRET='4'
    Else
      If [L]HLD<2
        [L]INDRET='5'
      Else
        [L]INDRET='6'
      Endif
    Endif
    # Issue 111268 - 2015-10-12 by BRBAN : Missing call
    Call REGION([L]FACIL,[L]REG)
    Case [L]REG
      When 1  : [L]RET += 'CO'+[L]INDRET
      When 2  : [L]RET += 'AC'+[L]INDRET
      When 3  : [L]RET += 'MA'+[L]INDRET
    Endcase
  Endif
Else
  If [L]HDC=1
    If [L]STFAM<>2 & [L]STFAM<>6
     [L]INDRET='1'
    Else
      If [L]HLD<2
        [L]INDRET='2'
      Else
        [L]INDRET='3'
      Endif
    Endif
    Call REGION([L]FACIL,[L]REG)
    Case [L]REG
      When 1  : [L]RET += 'CP'+[L]INDRET
      When 2  : [L]RET += 'AP'+[L]INDRET
      When 3  : [L]RET += 'MP'+[L]INDRET
    Endcase
  Else
    If [L]STFAM<>2 & [L]STFAM<>6
     [L]INDRET='4'
    Else
      If [L]HLD<2
        [L]INDRET='5'
      Else
        [L]INDRET='6'
      Endif
    Endif
    # Issue 111268 - 2015-10-12 by BRBAN : Missing call
    Call REGION([L]FACIL,[L]REG)
    Case [L]REG
      When 1  : [L]RET += 'CP'+[L]INDRET
      When 2  : [L]RET += 'AP'+[L]INDRET
      When 3  : [L]RET += 'MP'+[L]INDRET
    Endcase
  Endif
Endif

If [L]RET='IRS_' : [L]RET='' : Endif
End
######################################################################################
######################################################################################
Subprog C_NBRHLD(VALEUR)
Variable Decimal VALEUR

If VALEUR<=0 | VALEUR>2
  Call ERREUR(mess(83,123,1)) From GESECRAN
  mkstat=2
Endif

End

Subprog AS_WMEDTYP(VALEUR)
Variable Char    VALEUR()
Local Integer AGE

[L]AGE = int((date$-[M]DATBRN)/365)

If [L]AGE<18 | [L]AGE>50
 VALEUR = "VM1"
Else
 VALEUR = "VM2"
Endif

End

Subprog C_WMEDTYP(VALEUR)
Variable Char    VALEUR()
Local Integer CTRNXTDAT : [L]CTRNXTDAT = 0

If year([M:EMPA]WMEDDAT)- year([M:EMP2]DATBRN)>50
  [L]CTRNXTDAT = 1
Elsif year([M:EMPA]WMEDDAT)- year([M:EMP2]DATBRN)=50
  If gdat$(day([M:EMPA]WMEDDAT),month([M:EMPA]WMEDDAT),year(date$))>=gdat$(day([M:EMP2]DATBRN),month([M:EMP2]DATBRN),year(date$))
    [L]CTRNXTDAT = 1
  Endif
Endif

If [L]CTRNXTDAT

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

  If [F:ADI]NUMTAB<>395 | [F:ADI]CODE <> VALEUR
    Read [F:ADI]CODE = 395;VALEUR
    If fstat : Raz [F:ADI] : Endif
  Endif

  If [F:ADI]N1>12
    GMESSAGE = mess(21,11553,1)
    mkstat   = 2
  Endif

Endif

End

