#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("COUTDIFF","") From ETAT
End

######################################################################################
# Améliorations de plan prévisionnel (SYMEU - Septembre 2010 - V6.1)
# -> EXI 66191 LOT 10
# - Ajout de la société et du site dans la clé du plan prévisionnel : on les fait
#   saisir en critère
# - Ne prendre que les stages de PLNFORM dont le flag calcul est à Oui
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    STGDEB(GLONSTG) , STGFIN(GLONSTG), ETAT(GLONARP), PARAM(20), CODCOL (3) (0..3), ANNEE(4)
Local Char    SOCDEB(GLONCPY) , SOCFIN(GLONCPY)
Local Char    SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    POPUL (GLONPOP)
Local Char    GROUPE (3) (0..3), CRITSTG(250),  CRITPLF(250), CRITINS(250)
Local Integer WNUMLIG, NUMREQ, NBGRP, NBPART, OK
Local Decimal TOTPREV(0..3), TOTREEL(0..3), IPTPREV(0..3), IPTREEL(0..3)
Local Date    DATDEB, DATFIN, DATMAT
Local Char    SOCIETE (GLONCPY), SITE (GLONFCY), MATRI (GLONEML), CTR(GLONHRCTR)
# SYMEU : EXI 66191 LOT 10 - V6.1 : société et site du plan
Local Char    SOCPLF(GLONCPY), SITPLF(GLONFCY)

[L]ETAT=[M]RPTCOD
If clalev([F:ARM])=0    : Local File AREPORTM   [ARM]   : Endif
If clalev([F:INS])=0    : Local File INSCRIPT   [INS]   : Endif
If clalev([F:INJ])=0    : Local File INSJOU     [INJ]   : Endif
If clalev([F:STG])=0    : Local File STAGE      [STG]   : Endif
If clalev([F:HRSES])=0  : Local File SESSIONS   [HRSES] : Endif
If clalev([F:PLF])=0    : Local File PLNFORM    [PLF]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
If clalev([F:HRCOR])=0  : Local File COUTREEL   [HRCOR] : Endif
If clalev([F:COR2])=0   : Local File COUTREEL   [COR2]  : Endif
If clalev([F:PLC])=0    : Local File PLNCOUT    [PLC]   : Endif

Gosub  OUVRE From WPDEFTABLE

Call GETPARAM("yea",NBPAR,PARAMETRE,ANNEE)
# SYMEU : EXI 66191 LOT 10 - V6.1 : société et site du plan
Call GETPARAM("cpyplf",NBPAR,PARAMETRE,SOCPLF)
Call GETPARAM("fcyplf",NBPAR,PARAMETRE,SITPLF)

Call GETPARAM("stgdeb",NBPAR,PARAMETRE,STGDEB)
Call GETPARAM("stgfin",NBPAR,PARAMETRE,STGFIN)
Call GETPARAM("cpydeb",NBPAR,PARAMETRE,SOCDEB)
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,SOCFIN)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,SITDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,SITFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPUL)
Call GETPARAM("col1",NBPAR,PARAMETRE,CODCOL(0))
Call GETPARAM("col2",NBPAR,PARAMETRE,CODCOL(1))
Call GETPARAM("col3",NBPAR,PARAMETRE,CODCOL(2))
Call GETPARAM("col4",NBPAR,PARAMETRE,CODCOL(3))
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

# SYMEU : EXI 66191 LOT 10 - V6.1 : prendre en compte le flag Calcul O/N
#CRITPLF="1=1"
CRITPLF="CLCFLG=2"
CRITINS="1=1"
If SOCDEB<>""
 CRITPLF-='& [F:PLF]CPY>="'+SOCDEB+'"'
 CRITINS-='& [F:FCY]LEGCPY>="'+SOCDEB+'"'
Endif
If SOCFIN<>""
 CRITPLF-='& [F:PLF]CPY<="'+SOCFIN+'"'
 CRITINS-='& [F:FCY]LEGCPY<="'+SOCFIN+'"'
Endif
If SITDEB<>""
 CRITPLF-='& [F:PLF]FCY>="'+SITDEB+'"'
 CRITINS-='& [F:FCY]FCY>="'+SITDEB+'"'
Endif
If SITFIN<>""
 CRITPLF-='& [F:PLF]FCY<="'+SITFIN+'"'
 CRITINS-='& [F:FCY]FCY<="'+SITFIN+'"'
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71708 : DEBUT
# tenir compte de la société ou du site du plan
If SOCPLF <> "" Then
  CRITINS-='& [F:FCY]LEGCPY="'+SOCPLF+'"'
Elsif SITPLF <> "" Then
  CRITINS-='& [F:FCY]FCY="'+SITPLF+'"'
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71708 : FIN

CRITSTG="1=1"
If STGDEB<>""
 CRITSTG-='& STG>="'+STGDEB+'"'
Endif
If STGFIN<>""
 CRITSTG-='& STG<="'+STGFIN+'"'
Endif

Call DEBTRANS From GLOCK
Gosub RAZ_ARM
Gosub TR1
Call TEMPOFF From GESECRAN
End

##########################
$RAZ_ARM
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

#######################
$TR1
Trbegin [ARM]
 NBGRP=0 : WNUMLIG=0
 Gosub COUTPREV
 NBGRP=0
 Gosub COUTREEL
Commit
Return

#######################
$COUTPREV
#Couts prévisionnels
Local Char CRIT(250)

# FQ71683 - MABON 18/02/11 - Les critères sut société et site ne doivent être appliqués que s'ils sont saisis
CRIT="1=1"
If SOCPLF<>"" Then CRIT -= "& CPYPLF='"+SOCPLF+"'" : Endif
If SITPLF<>"" Then CRIT -= "& CPYPLF='"+SITPLF+"'" : Endif
# Fin MABON

# SYMEU : EXI 66191 LOT 10 - V6.1 : ajout de la société et du site du plan
# FQ71683 - MABON 18/02/11 - Les critères sut société et site ne doivent être appliqués que s'ils sont saisis
# Donc, ce filtre est remplacé par evalue(CRIT)
#&                & CPYPLF=SOCPLF & FCYPLF=SITPLF
Filter [PLF] Where YEAPLF=ANNEE & FLGCLO=2 & evalue(CRITSTG) & evalue (CRITPLF)
&                & evalue(CRIT)
&     Order By Key CLE=STG Asc
For [PLF]CLE
 OK = 1
 Call CTRL_POP([PLF]EMP,POPUL,OK)
 If OK=1
  SOCIETE = [F:PLF]CPY
  SITE    = [F:PLF]FCY
  # SYMEU : EXI 66191 LOT 10 - V6.1 : ajout de la société et du site du plan
  # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
  For [PLC]PLC0 Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
&                   & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
&                   & LEGPLF=[F:PLF]LEGPLF
   Read[F:ADI]CODE=10451;[F:PLC]TYPCRG
   If !fstat & find([F:ADI]A2, CODCOL(0..3)) : Gosub TABPREV : Endif
  Next
  Gosub ECRIT_PREV
   # FQ75963 - MABON 08/09/11 - Ajout du nombre de participants réel
   Filter [F:ARM] Where NUMREQ=[L]NUMREQ & USR=GUSER & RPTCOD=[L]ETAT & [F:ARM]CLEA1=[F:PLF]STG
&                     &  CLEA3=SOCIETE & CLEA4=SITE
   Read [F:ARM]ARM0 First
   Filter [F:ARM]
   If !fstat
     # FQ75963 - MABON 08/09/11 - Ajout du nombre de participants prévisionnel
     [F:ARM]CLEN1   = [F:PLF]NBREMP     :#Participant Previsionnel
     # Fin MABON
     Rewrite [F:ARM]
     If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break
     Endif
   Endif
   # Fin MABON
 Endif
Next
Filter [PLF]
Return

#######################
$COUTREEL
#Couts reels
DATDEB = gdat$(01,01,val(ANNEE))
DATFIN = gdat$(31,12,val(ANNEE))
Filter [HRSES] Where STRDAT>=DATDEB & ENDDAT<=DATFIN & evalue(CRITSTG) Order By Key CLE=STG Asc
For [HRSES]CLE
 NBPART=0
 # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
# For [INS]INS0 Where SES=[F:HRSES]COD
 For [INS]INS0 Where SES=[F:HRSES]COD & STA<>3
 # Fin MABON
  NBPART+=1
 Next
 # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
# For [INS]INS0 Where SES=[F:HRSES]COD
 For [INS]INS0 Where SES=[F:HRSES]COD & STA<>3
 # Fin MABON
  OK = 1
  Gosub VERIF_EMP
  If OK=1
   For [HRCOR]COR0 Where TYPCOU=3 & SES=[F:HRSES]COD & REFNUM=[F:ID]REFNUM
    #Coûts réels participants
    Read[F:ADI]CODE=10451;[F:HRCOR]TYPCRG2
    If !fstat & find([F:ADI]A2, CODCOL(0..3)) : Gosub  REELPAR : Endif
    Gosub ECRIT_REEL
   Next
   #Couts réels formateur interne
   For [COR2]COR0 Where TYPCOU=2 & SES=[F:HRSES]COD
    Read[F:ADI]CODE=10451;[F:COR2]TYPCRG2
    If !fstat & find([F:ADI]A2, CODCOL(0..3)) : Gosub REELFOR : Endif
    Gosub ECRIT_REEL
   Next
   # FQ75963 - MABON 08/09/11 - Ajout du nombre de participants réel
   Filter [F:ARM] Where NUMREQ=[L]NUMREQ & USR=GUSER & RPTCOD=[L]ETAT & [F:ARM]CLEA1=[F:HRSES]STG
&                     &  CLEA3=SOCIETE & CLEA4=SITE
   Read [F:ARM]ARM0 First
   Filter [F:ARM]
   If !fstat
     [F:ARM]CLEN2   += 1             :#Participant Réel
     Rewrite [F:ARM]
     If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break
     Endif
   Endif
   # Fin MABON
  Endif
 Next
Next
Filter [HRSES]
Return

#######################
Subprog CTRL_POP(EMP,POPUL,OK)
Value    Char    EMP
Value    Char    POPUL
Variable Integer OK
If EMP="" | POPUL="" : End : Endif
If clalev([F:HRPOA])=0 : Local File POPULA [HRPOA] : Endif
Filter [F:HRPOA] Where REFNUM=EMP & COD>=POPUL & COD<=POPUL
Read [F:HRPOA]POA1 First
Filter [F:HRPOA]
If fstat : OK=0 : Endif
End

#######################
$TABPREV
J = find([F:ADI]A2,GROUPE(0..3))
If J
 TOTPREV(J-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
 IPTPREV(J-1) += [F:PLC]CSTIPTIDV*[F:PLF]NBREMP
Else
 GROUPE(NBGRP)  = [F:ADI]A2
 TOTPREV(NBGRP) = [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
 IPTPREV(NBGRP) = [F:PLC]CSTIPTIDV*[F:PLF]NBREMP
 NBGRP +=1
Endif
Return

#######################
$ECRIT_PREV
For K=0 To 3
 If GROUPE(K)="" : Break : Endif
 Filter [F:ARM] Where NUMREQ=[L]NUMREQ & USR=GUSER & RPTCOD=[L]ETAT & [F:ARM]CLEA1=[F:PLF]STG & [F:ARM]CLEA2=GROUPE(K)
&                     &  CLEA3=SOCIETE & CLEA4=SITE
 Read [F:ARM]ARM0 First
 Filter [F:ARM]
 If !fstat
  [F:ARM]CLEMD1  += TOTPREV(K) :#Total Previsionnel
  [F:ARM]CLEMD2  += IPTPREV(K) :#Imputable Previsionnel
  Rewrite [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Else
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:PLF]STG :#Code Stage
  [F:ARM]CLEA2   = GROUPE(K)  :#Code regroupement
  [F:ARM]CLEA3   = SOCIETE    :#Code Société
  [F:ARM]CLEA4   = SITE       :#Code Site
  # SYMEU : EXI 66191 LOT 10 - V6.1 : société et site du plan, pour éditer leur nom
  [F:ARM]CLEA5   = SOCPLF
  [F:ARM]CLEA6   = SITPLF
  [F:ARM]CLEMD1  = TOTPREV(K) :#Total Previsionnel
  [F:ARM]CLEMD2  = IPTPREV(K) :#Imputable Previsionnel
  [F:ARM]CREDAT  = date$
  Write [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
  WNUMLIG +=1
 Endif
Next
If !GOK : Return : Endif
Raz GROUPE : Raz TOTPREV : Raz IPTPREV : NBGRP=0
Return

#######################
$VERIF_EMP
OK = 1
Raz SOCIETE, SITE
Call CTRL_POP([F:INS]REFNUM,POPUL,OK)
If OK=0 : Return : Endif
MATRI  = [F:INS]REFNUM
DATMAT = [F:HRSES]STRDAT
CTR    = [F:INS]CTRNUM
Gosub LECEMP From WPDEFTABLE
If [F:HRCTR]ETRFCY <>""
 Call LECTURE ("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 If evalue(CRITINS)=0
  OK=0 : Return
 Elsif !fstat
  SITE    = [F:HRCTR]ETRFCY
  SOCIETE = [F:FCY]LEGCPY
 Endif
Endif
# FQ75963 - MABON 15/09/11 - On ne comptabilise que si l'inscription a des jours de présence
Filter [F:INJ] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
If rowcount([F:INJ])=0 Then
  OK=0
Endif
Filter [F:INJ]
# Fin MABON
Return

#######################
$REELPAR
J = find([F:ADI]A2,GROUPE(0..3))
If J
 TOTREEL(J-1) += [F:HRCOR]CSTTOTIDV2
 IPTREEL(J-1) += [F:HRCOR]CSTIPTIDV2
Else
 GROUPE(NBGRP)  = [F:ADI]A2
 TOTREEL(NBGRP) = [F:HRCOR]CSTTOTIDV2
 IPTREEL(NBGRP) = [F:HRCOR]CSTIPTIDV2
 NBGRP+=1
Endif
Return

#######################
$REELFOR
J = find([F:ADI]A2,GROUPE(0..3))
If J
 TOTREEL(J-1) += [F:COR2]CSTTOTIDV2/NBPART
 IPTREEL(J-1) += [F:COR2]CSTIPTIDV2/NBPART
Else
 GROUPE(NBGRP)  = [F:ADI]A2
 TOTREEL(NBGRP) = [F:COR2]CSTTOTIDV2/NBPART
 IPTREEL(NBGRP) = [F:COR2]CSTIPTIDV2/NBPART
 NBGRP+=1
Endif
Return

#######################
$ECRIT_REEL
For K=0 To 3
 If GROUPE(K)="" : Break : Endif
 Filter [F:ARM] Where NUMREQ=[L]NUMREQ & USR=GUSER & RPTCOD=[L]ETAT & [F:ARM]CLEA1=[F:HRSES]STG & [F:ARM]CLEA2=GROUPE(K)
&                     &  CLEA3=SOCIETE & CLEA4=SITE
 Read [F:ARM]ARM0 First
 Filter [F:ARM]
 If !fstat
  [F:ARM]CLEMD3 += TOTREEL(K)    :#Total Réel
  [F:ARM]CLEMD4 += IPTREEL(K)    :#Imputable Réel
  Rewrite [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Else
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:INS]STG
  [F:ARM]CLEA2   = GROUPE(K)
  [F:ARM]CLEA3   = SOCIETE    :#Code Société
  [F:ARM]CLEA4   = SITE       :#Code Site
  # SYMEU : EXI 66191 LOT 10 - V6.1 : société et site du plan, pour éditer leur nom
  [F:ARM]CLEA5   = SOCPLF
  [F:ARM]CLEA6   = SITPLF
  [F:ARM]CLEMD3  = TOTREEL(K) :#Total Previsionnel
  [F:ARM]CLEMD4  = IPTREEL(K) :#Imputable Previsionnel
  [F:ARM]CREDAT  = date$
  Write [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
  WNUMLIG +=1
 Endif
Next
If !GOK : Return : Endif
Raz GROUPE : Raz TOTREEL: Raz IPTREEL : NBGRP=0
Return

#######################
$AB_TR1
Rollback
Return

#######################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return # -> EXI 66191 LOT 10 : ligne manquante

#######################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

