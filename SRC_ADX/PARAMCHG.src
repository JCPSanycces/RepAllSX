#<AdxTL>@(#)3.0.0.0 $Revision$
Call IMPRIME("PARAMCHG","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVFIC
Gosub DECLARATION

#Recup no de requete
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
[L]ETAT="PARAMCHG"

CRITDCH="1=1"
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "etat" : If [L]VALEUR<>""
                    [L]CRITDCH -= '& [F:DCH]EDTDCC="'+[L]VALEUR+'"'
                   Endif
   When "decdeb" : If [L]VALEUR<>""
                    [L]CRITDCH -= '& [F:DCH]CODDCC>="'+[L]VALEUR+'"'
                   Endif
   When "decfin" : If [L]VALEUR<>""
                    [L]CRITDCH -= '& [F:DCH]CODDCC<="'+[L]VALEUR+'"'
                   Endif
   When "caideb" : If [L]VALEUR<>""
                    [L]CRITDCH -= '& [F:DCH]CAI>='+[L]VALEUR
                   Endif
   When "caifin" : If [L]VALEUR<>""
                    [L]CRITDCH -= '& [F:DCH]CAI<='+[L]VALEUR
                   Endif

  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call DEBTRANS From GLOCK
GOK = 1
Gosub TR1
End

########################################
$OUVFIC
If clalev([F:DCH])=0 : Local File DECCHARGE  [DCH] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
Return

########################################
$DECLARATION
Local Integer NUMREQ
Local Char ETAT (10)
Local Char CRITDCH(250)
Local Char PARAM(30)
Local Char VALEUR(30)
Return

########################################
$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR1
 Endif
 LIG=0
 For [F:DCH]DCH1 Where evalue (CRITDCH)
   For I=0 To [F:DCH]NUMRUB-1
    LIG += 1
    Raz [F:ARM]
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]NUMLIG = LIG
    [F:ARM]CLEA1  = [F:DCH]CODDCC
    [F:ARM]CLEA2  = [F:DCH]CODRUB(I)
    Read[F:RUB]RUB0=[F:DCH]LEG;[F:DCH]CODRUB(I)
    If !fstat
     [F:ARM]CLEA3  = num$([F:RUB]ROW)
     Call LECTEXTRA([F:ARM]CLEA4,"RUBRIQUE","DES",[F:DCH]LEG,[F:DCH]CODRUB(I)) From ATEXTRA
    Endif
    [F:ARM]CLEN1  = [F:DCH]ACCWRK(I)
    [F:ARM]CLEN2  = [F:DCH]TYPCAL(I)
    [F:ARM]CREDAT = date$
    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
  Next
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
