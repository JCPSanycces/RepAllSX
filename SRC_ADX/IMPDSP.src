#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
Endcase
Return

$IMPORT
Case IMPFIC
 When "DSP"
  ## Recherche du numéro de ligne en modif
  If GREP="M" & [F:DSP]NBRDSP>=1 & [F:DSP]NBRDSP<=[M]NBRDSP : # Modif ligne existante
   nolign = [F:DSP]NBRDSP
  Else                                               : # Ajout d'une ligne
   [M]NBRDSP += 1
   nolign = [M]NBRDSP
  Endif
Endcase
Return

