#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DSELFLDVUE","SELFLDVUE","") From GSAISIE
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "FINSAI"      : Gosub FINSAI
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABANDON
 When Default
Endcase
Return

#------------------------------------------------------------#
$FINSAI
If clalev([M:AVW2])>0
 Affzo [M:AVW2]
 mkstat = 4
 nolign = NOL
Endif
Return

#------------------------------------------------------------#
$OUVRE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Local Integer NOL
NOL = nolign
If clalev([M:AVW2])=0
 FIN = 1 : Return
Endif
Return

#------------------------------------------------------------#
$DEBUT
If [M]FICHIER<>"" : Gosub CHARGE_ZON : Endif
Actzo FICHIER
Return

#-----------------------------#
$CHARGE_ZON
nolign = 0
For [ATZ]NUMLIG Where CODFIC=[M]FICHIER
 nolign += 1
 [M] = [F:ATZ]
 Call TEXTE([F:ATZ]NOCOURT,[M]INTITCOURT(nolign-1)) From OBJDIV
 If find([F:ATZ]CODZONE,[M:AVW2]FLDVUE)
  [M]SELECT(nolign-1) = 1
 Else
  [M]SELECT(nolign-1) = 2
 Endif
Next
[M]NBLIG = nolign
REP = ""
Affzo
Return

#------------------------------------------------------------#
$ABANDON
Actzo FICHIER
Gosub CHARGE_ZON
Return

#------------------------------------------------------------#
$APRES_MODIF
Case zoncou
 When "NBLIG"
  Diszo FICHIER
  REP = "M"
 When "FICHIER"
  Gosub CHARGE_ZON
Endcase
Return

#------------------------------------------------------------#
$OK
K = 0
If NOL<1 : NOL = 1 : Endif
Read [ATB]CODFIC = [M]FICHIER
For I=0 To [M]NBLIG-1
 If [M]SELECT(I)=2 & !find([M]CODZONE(I),[M:AVW2]FLDVUE)
  Read [ATZ]CODZONE = [M]FICHIER ; [M]CODZONE(I)
  Insa NOL-1,1,[M:AVW2]NBFLD [M:AVW2]NBFLD
  [M:AVW2]FLDVUE(NOL-1) = [F:ATZ]CODZONE
  [M:AVW2]CODTYP(NOL-1) = [F:ATZ]CODTYP
  [M:AVW2]NOLIB(NOL-1)  = [F:ATZ]NOLIB
  [M:AVW2]LNG(NOL-1)    = [F:ATZ]LONG
  [M:AVW2]FLDACT(NOL-1) = [F:ATZ]CODACT
  [M:AVW2]DIME(NOL-1)   = [F:ATZ]DIME
  [M:AVW2]OPTION(NOL-1) = [F:ATZ]OPTION
  [M:AVW2]FLDINT(NOL-1) = [F:ATZ]NOCOURT
  Call TEXTE([F:ATZ]NOCOURT,[M:AVW2]FLDINTSAI(NOL-1)) From OBJDIV
  NOL += 1
  K += 1
 [M:AVW2]NBFLD += 1
 Endif
Next I
If K : mkstat = 4 : Endif
Return

#------------------------------------------------------------#
Subprog C_FICHIER(VALEUR)
Variable Char VALEUR()
[M]FICHIER = VALEUR
Gosub CHARGE_ZON
End

Subprog B2_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 10
mkstat = 4
End

Subprog B3_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 10
mkstat = 4
End


