#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet APH
Raz GPILOBJ , GNBMASKOUV
Call OBJET("APH",GBIDC1,GBIDC2) From GOBJET
End

#-------------------------------------#
$ACTION
Case ACTION
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "INIMOD"      : Gosub INIMOD
 When "INICRE"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
Endcase
Return

#-------------------------------------#
$INICRE
$INIMOD
[F]NUMLIG = nolign
Return

#-------------------------------------#
$CREATION
$MODIF
Call MAJTEXTRA([M]INTPAT,"APATCHMOD","INTPAT",[M]MODPAT,"") From ATEXTRA
Return

#-------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="APATCHMOD" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#-------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="APATCHMOD" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APATCHMOD"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#-------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File APATCHMOD [APH1] 
 Local File ATEXTRA   [AXX1] 
Else 
 Local File =[M]DOSORG+".APATCHMOD" [APH1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File APATCHMOD [APH2] 
 Local File ATEXTRA   [AXX2] 
Else 
 Local File =[M]DOSDES+".APATCHMOD" [APH2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif 
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [APH2]APH0(1) = TABLE 
 If !fstat
  Call AVERTIR(mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [APH1] , [APH2] , [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [APH2]
 Delete [APH2] Where MODPAT=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APATCHMOD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("APH2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [APH1]APH0 Where MODPAT=TABLE
  [F:APH2] = [F:APH1]
  Call COPTEXTRA("APATCHMOD","INTPAT",[F:APH2]MODPAT,"") From ATEXTRA
  If dim([F:APH2]UPDUSR)>0 : [F:APH2]UPDUSR = GUSER : Endif
  If dim([F:APH2]UPDDAT)>0 : [F:APH2]UPDDAT = date$ : Endif
  Write [APH2]
  If fstat
   GOK=0 : Call FSTA("APH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
ROLLBACK
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-------------------------------------#
Subprog C_TRANSAC(VALEUR)
Variable Char    VALEUR()
Local Integer ER
Local Char MESSAGE(250)
If VALEUR="" : End : Endif
Read [ATN]ATN0=VALEUR
If [F:ATN]CODTRT<>"" & GADONIX=2
 Call CHERCHE("Subprog PATCHMOD",[F:ATN]CODTRT,ER,GMESSAGE) From SUBATN
 If ER=1 : mkstat = 1 : End : Endif
 If ER=2
  Call CHERCHE("Subprog PATCH",[F:ATN]CODTRT,ER,MESSAGE) From SUBATN
  If !ER : Raz GMESSAGE : End : Endif
  mkstat = 1 : End
 Endif
Endif
End
