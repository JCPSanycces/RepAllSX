#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet PLM
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "CREATION"  : Gosub TR_CRE
    When "MODIF"     : Gosub TR_MOD
    When "LIENS"     : Gosub LIENS
    When "SEL_LISTE" : Gosub SEL_LISTE
    When Default
  Endcase
Return


######################################################################################
$OUVRE
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Return

$RAZCRE
  If [M:PLM1]NBVAL=0
    nolign = 0
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOM" : [M:PLM1]CODZONE(nolign-1)="BASQTY" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOM" : [M:PLM1]CODZONE(nolign-1)="BOMALTTYP" : [M:PLM1]VALDEF(nolign-1)="2" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOM" : [M:PLM1]CODZONE(nolign-1)="QTYCOD" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOM" : [M:PLM1]CODZONE(nolign-1)="USESTA" : [M:PLM1]VALDEF(nolign-1)="2" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOMD" : [M:PLM1]CODZONE(nolign-1)="CPNTYP" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOMD" : [M:PLM1]CODZONE(nolign-1)="LIKQTYCOD" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOMD" : [M:PLM1]CODZONE(nolign-1)="PKC" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="BOMD" : [M:PLM1]CODZONE(nolign-1)="QTYRND" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    If pat(GVERSION,"1.5.*")
      nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMMASTER" : [M:PLM1]CODZONE(nolign-1)="QUAFLG" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    Else
     nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMBPS" : [M:PLM1]CODZONE(nolign-1)="QUAFLG" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    Endif
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMMASTER" : [M:PLM1]CODZONE(nolign-1)="EXYMGTCOD" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMMASTER" : [M:PLM1]CODZONE(nolign-1)="ITMSTA" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    If !pat(GVERSION,"1.5.*")
      nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMMASTER" : [M:PLM1]CODZONE(nolign-1)="SHLLTIUOM" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
      nolign += 1 : [M:PLM1]CODFIC(nolign-1)="ITMMASTER" : [M:PLM1]CODZONE(nolign-1)="SHLUOM" : [M:PLM1]VALDEF(nolign-1)="1" : Call AP_CODZONE([M:PLM1]CODZONE(nolign-1))
    Endif
    [M:PLM1]NBVAL  = nolign
    Affzo [M:PLM1]
  Endif
Return
######################################################################################
$LIENS
  # Chargement ecran PLMDEFVAL (tableau)
  If dim([M:PLM1]NBVAL) > 0
    Raz [M:PLM1]CODFIC,[M:PLM1]CODZONE,[M:PLM1]VALDEF,[M:PLM1]NBVAL
    nolign = 0
    For [PDV] Where ID=[M:PLM1]ID
      nolign += 1
      [M:PLM1]=[F:PDV]
      Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);[M:PLM1]CODZONE(nolign-1)
      If !fstat
      Call TEXTE([F:ATZ]NOCOURT,[M:PLM1]COM(nolign-1)) From OBJDIV
      Endif
    Next
    [M:PLM1]NBVAL  = nolign
  Endif
Return

######################################################################################
$TR_CRE
Goto SUBCREMOD

$TR_MOD
  # Mise à jour table PLMDEFVAL
  If dim([M:PLM1]NBVAL) > 0
    For [PDV]PDV0 Where ID = [M:PLM1]ID
      Delete [PDV]
      #  Vérifier si un enregistrement est locké : si oui : Fin
      If fstat = 1
        GOK = -1
        Call RSTA("PDV",[M:PLM1]ID) From GLOCK : Break
      Endif
    Next
  Endif
  If GOK < 0 Goto FINCREMOD Endif

$SUBCREMOD
  For  nolign = 1 To [M:PLM1]NBVAL
    Raz [F:PDV]
    [F:PDV] = [M:PLM1]
    [F:PDV]ID    = [M:PLM1]ID
    If [F:PDV]CREUSR  = ""
      [F:PDV]CREUSR    = GUSER
      [F:PDV]CREDAT    = date$
      Raz [F:PDV]UPDUSR
      Raz [F:PDV]UPDDAT
    Endif
    Write [PDV]
    If fstat
      GOK = 0 : Call FSTA("PDV") From GLOCK : Break
    Endif
  Next nolign

$FINCREMOD
# Retour de la CREATION et de la MODIF
Return


######################################################################################
Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
  If [M:PLM1]ABRFIL=""
    Local Integer NB
    Raz [M:PLM1]ABRFIL , [M:PLM1]TABFIL , NB
    For [ATB] Where find(CODFIC,"ITMMASTER","ITMBPS","ITMFACILIT","BOM","BOMD")<>0
      [M:PLM1]TABFIL(NB) = [F:ATB]CODFIC
      [M:PLM1]ABRFIL(NB) = [F:ATB]ABRFIC
      NB += 1
    Next
  Endif
End

######################################################################################
Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
  If find(VALEUR,[M:PLM1]TABFIL)=0
    GMESSAGE = mess(83,123,1)
    mkstat = 2
    End
  Endif
End


######################################################################################
Subprog C_CODZONE(VALEUR)
Variable Char    VALEUR()
  If [M:PLM1]CODFIC(nolign-1)<>"" & VALEUR=""
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
  Endif
  Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);VALEUR
  If fstat
    GMESSAGE = mess(23,100,1)
    mkstat = 2
    End
  Endif
  For I=0 To NBVAL
    If [M:PLM1]CODFIC(nolign-1)+"/"+VALEUR=[M:PLM1]CODFIC(I)+"/"+[M:PLM1]CODZONE(I) & I<>nolign-1
      GMESSAGE = mess(29,100,1)-num$(I+1)
      mkstat = 2
      End
    Endif
  Next I
End

######################################################################################
Subprog AP_CODZONE(VALEUR)
Variable Char    VALEUR()
  Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);VALEUR
  If !fstat
    Call TEXTE([F:ATZ]NOCOURT,[M:PLM1]COM(nolign-1)) From OBJDIV
  Endif
End

######################################################################################
Subprog AV_VALDEF(VALEUR)
Variable Char    VALEUR()
  Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);[M:PLM1]CODZONE(nolign-1)
  If [F:ATZ]CODTYP="D"
    Chgfmt [M:PLM1]VALDEF(nolign-1) With "D:DD[/]MM[/]YYYY"
  Else
    Chgfmt [M:PLM1]VALDEF(nolign-1) With "K:80X"
  Endif
End

######################################################################################
Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()
  If [M:PLM1]CODFIC(nolign-1)<>"" & [M:PLM1]CODZONE(nolign-1)<>"" & VALEUR=""
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
  Endif
End

######################################################################################
$SEL_LISTE
  If COUZON="VALDEF"
    NBTEX = 0
    TIT(0)=[M:PLM1]COM(nolign-1)
    TIT(1)=""
    TIT(2)=""
    Local Char TEXTE(80)(1..200,1..2)
    If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif
    For [AST] Where LANCHP=[F:ATZ]NOLIB & LAN=GLANGUE & LANNUM>0
      NBTEX += 1
      TEX(NBTEX)   = num$([F:AST]LANNUM)
      TEXTE(NBTEX,1) = num$([F:AST]LANNUM)
      TEXTE(NBTEX,2) = [F:AST]LANMES
    Next
  Endif
Return

######################################################################################
Subprog S_VALDEF(VALEUR)
Variable Char    VALEUR()
  Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);[M:PLM1]CODZONE(nolign-1)

  Local Char    PARMSK(250)(1..20)
  Case [F:ATZ]CODTYP
  When "ADI":
    PARMSK(1) = left$([F:ATZ]EXPLIEN,instr(1,[F:ATZ]EXPLIEN,";")-1)
    PARMSK(2) = ""
    Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION

  When "M":
    SAVACT = GACTION : GACTION = "GSELLIS"
    PARMSK(1) = "VALDEF"
    PARMSK(2) = "SUBPLM"
    Call S_LIS_CHAR(VALEUR,PARMSK,"GSELECT","ASELGEN","") From GACTION
    GACTION = SAVACT

  When Default:
    If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat | [F:ATY]OBJLIEN=""
      #pas de liste/selection
      PARMSK(1) = [F:ATZ]CODTYP
    Else
      PARMSK(1) = [F:ATY]OBJLIEN
      PARMSK(2) = "!"
      Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
      Endif
  Endcase
End

######################################################################################
Subprog IB_VALDEF
  Read [ATZ]CODZONE=[M:PLM1]CODFIC(nolign-1);[M:PLM1]CODZONE(nolign-1)
  Case [F:ATZ]CODTYP
  When "ADI":
  When "M":
  When Default:
    If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat | [F:ATY]OBJLIEN=""
      #pas de liste/selection
      Raz GBOUTS
    Endif
  Endcase
End

# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
# + affichage du champ BOMALTTYP et passage en MM dans l'ecran PLM1
# + sur Champ BOMALT, type TBO, parametre TBO = BOMALTYP au lieu de "2"
# + table PLMPAR ajout du champ BOMALTTYP / prevoir une moulineet ed MAJ ou une procedure
######################################################################################
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(1)=1
End

Subprog AM_BOMALTTYP(VALEUR)
Variable Integer VALEUR
  Raz [M:PLM1]BOMALT

  Local Integer I
  For I=0 To NBVAL
    If [M:PLM1]CODFIC(I)="BOM" and [M:PLM1]CODZONE(I)="BOMALTTYP"
      [M:PLM1]VALDEF(I)=num$(VALEUR)
      Affzo [M:PLM1]
      Break
    Endif
  Next I
End
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance

# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
  If GBATCH & VALEUR=1
    GMESSAGE = mess(163,141,1)
    mkstat = 2 : End
  Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
  If VALEUR=1
    Raz [M]VOLFILISS
    Grizo [M]VOLFILISS
    Raz [M]VOLFILRCP
    Grizo [M]VOLFILRCP
    Raz [M]VOLFILSTO
    Grizo [M]VOLFILSTO
  Else
    Actzo [M]VOLFILISS
    Actzo [M]VOLFILRCP
    Actzo [M]VOLFILSTO
  Endif
    Affzo [M]VOLFILISS
    Affzo [M]VOLFILRCP
    Affzo [M]VOLFILSTO
End

Subprog C_VOLFILRCP(VALEUR)
Variable Char    VALEUR()
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTRCP,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILSTO(VALEUR)
Variable Char    VALEUR()
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTSTO,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILISS(VALEUR)
Variable Char    VALEUR()
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTISS,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
