###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_DEST"    : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.DEST"     : TBFIL(NBPRO) = "[LNK_]DEST"
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_CHRONO"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.CHRONO"   : TBFIL(NBPRO) = "[LNK_]CHRONO"
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_CLEDEC"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.CLEDEC"   : TBFIL(NBPRO) = "[LNK_]CLEDEC"
  #US X3-27346 by RBA 03-08-2017 SAM 121897
  Case WREP
    When "HIS"   :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_ACTSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.ACTSIG"     : TBFIL(NBPRO) = "[LNK_]ACTSIG"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_FLGSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.FLGSIG"     : TBFIL(NBPRO) = "[LNK_]FLGSIG"
    When "TOSIG" :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
    When "SIG"   :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
    When ""   : #PXX
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_ACTSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.ACTSIG"     : TBFIL(NBPRO) = "[LNK_]ACTSIG"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_FLGSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.FLGSIG"     : TBFIL(NBPRO) = "[LNK_]FLGSIG"
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  Case WREP
    When "HIS" :
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO desc;"
    When "" : #PXX History
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO desc;"
    When Default :
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO asc;"
  Endcase
Return

###############################################################################

$AQUERY_OPEN_AFTER
  Local Char TAB_DEST(100)(1..)
  Local Char TAB_CHRONO(100)(1..)
  Local Char TAB_CLEDEC(100)(1..)

  #US X3-27346 by RBA 03-08-2017 SAM 121897
  Case WREP
    When "HIS"   :
      Local Char TAB_EMETTEUR(100)(1..)
      Local Char TAB_ACTSIG(100)(1..)
      Local Integer TAB_FLGSIG(1..)
    When "TOSIG" :
      Local Char TAB_EMETTEUR(100)(1..)
    When "SIG"   :
      Local Char TAB_EMETTEUR(100)(1..)
    When ""   : #PXX
      Local Char TAB_EMETTEUR(100)(1..)
      Local Char TAB_ACTSIG(100)(1..)
      Local Integer TAB_FLGSIG(1..)
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897

  Local Integer I, J
  Local Char WKEYNUM(50)
  Local Integer WKEYLIN

  Local Char WUSER(5) : WUSER = GACTX.USER #user to be used into filters #If WUSER = "RBA" : WUSER = "CJ" : Endif
#If GACTX.USER = 'RBA' : WUSER = 'CH' : Endif
  Local File AWRKHISSUI [AWS]

  Case WCODOBJ
    When "PSH"
      Case WREP
        When "HIS"   : Gosub FILTER_PSH_HIS   #historique
        When "TOSIG" : Gosub FILTER_PSH_TOSIG #a signer
        When "SIG"   : Gosub FILTER_PSH_SIG   #Signé
      Endcase
    When "POH"
      Case WREP
        When "HIS"   : Gosub FILTER_POH_HIS   #historique
        When "TOSIG" : Gosub FILTER_POH_TOSIG #a signer
        When "SIG"   : Gosub FILTER_POH_SIG   #Signé
      Endcase
    When "POC"
      Case WREP
        When "HIS"   : Gosub FILTER_POC_HIS   #historique
        When "TOSIG" : Gosub FILTER_POC_TOSIG #a signer
        When "SIG"   : Gosub FILTER_POC_SIG   #Signé
      Endcase
    When "PXX"       : Gosub FILTER_PXX       #Historique tout achats
  Endcase

  J = 0
  For [AWS]
    I = instr(1,[AWS]CLEDEC,"~")
    If I > 0
      WKEYNUM = left$([AWS]CLEDEC, I-1)
      WKEYLIN = val(right$([AWS]CLEDEC, I+1))
      Case func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)
        When "PSH" : Gosub SET_TAB_VAL_PSH_LINE
        When "POH" : #n'arrive jamais - il n'y a pas de signature au niveau ligne pour ce document
        When "POC" : #n'arrive jamais - il n'y a pas de signature au niveau ligne pour ce document
      Endcase
    Else
      WKEYNUM = [AWS]CLEDEC
      WKEYLIN = 0
      Case func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)
        When "PSH" : Gosub SET_TAB_VAL_PSH_HEAD
        When "POH" : Gosub SET_TAB_VAL_POH_HEAD
        When "POC" : Gosub SET_TAB_VAL_POC_HEAD
      Endcase
    Endif
  Next
  LogicClose File [AWS]

  #US X3-27346 by RBA 03-08-2017 SAM 121897
#  Local File    (
#&               Char    DEST(100),
#&               Char    CHRONO(100),
#&               Char    CLEDEC(100)
#&             ) From Variable
#&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC As [LNK_]
  Case WREP
    When "HIS"   : Gosub SET_QUERY_DATA_HIS
    When "TOSIG" : Gosub SET_QUERY_DATA_TOSIG
    When "SIG"   : Gosub SET_QUERY_DATA_SIG
    When ""      : Gosub SET_QUERY_DATA_HIS #PXX
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

$SET_QUERY_DATA_HIS
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100),
&               Char    ACTSIG(100),
&               Integer FLGSIG
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR, TAB_ACTSIG, TAB_FLGSIG As [LNK_]
Return

$SET_QUERY_DATA_TOSIG
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100)
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR As [LNK_]
Return

$SET_QUERY_DATA_SIG
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100)
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR As [LNK_]
Return


###############################################################################

$FILTER_PSH_HIS #historique
  Filter [AWS] Where
&       (
&       (find('PSHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSHSIGNCR')
&       |
&       (find('PSDSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSDSIGNCR')
&       )
&       &
&       find ([F:AWS]FLGSIG, 1, 5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_PSH_TOSIG #a signer
  Filter [AWS] Where
&       (
&       (find('PSHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSHSIGNCR')
&       |
&       (find('PSDSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSDSIGNCR')
&       )
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_PSH_SIG #Signé
  Filter [AWS] Where
&       (
&       ([F:AWS]CODEVT='PSHSIG')  & (find([F:AWS]CODWRK,'PSHSIGNOT','PSHSIGREJ')<>0)
&       |
&       ([F:AWS]CODEVT='PSDSIG')  & (find([F:AWS]CODWRK,'PSDSIGNOT','PSDSIGREJ')<>0)
&       )
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_POH_HIS #historique
  Filter [AWS] Where
&       find('POHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POHSIGNCR')
&       &
&       find([F:AWS]FLGSIG, 1, 5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_POH_TOSIG #a signer
  Filter [AWS] Where
&       find ('POHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POHSIGNCR')
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_POH_SIG #Signé
  Filter [AWS] Where
&       [F:AWS]CODEVT='POHSIG' & find([F:AWS]CODWRK,'POHSIGNOT','POHSIGREJ')<>0
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_POC_HIS #historique
  Filter [AWS] Where
&       find('POCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POCSIGNCR')
&       &
&       find([F:AWS]FLGSIG,1,5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_POC_TOSIG #a signer
  Filter [AWS] Where
&       find('POCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POCSIGNCR')
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER

Return

###############################################################################

$FILTER_POC_SIG #Signé
  Filter [AWS] Where
&       ([F:AWS]CODEVT='POCSIG') & find([F:AWS]CODWRK,'POCSIGNOT','POCSIGREJ')<>0
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_PXX #Historique tout achats
  Filter [AWS] Where
&     (
&      (
&       (find('PSHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSHSIGNCR')
&       |
&       (find('PSDSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSDSIGNCR')
&      )
&      |
&      find('POHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POHSIGNCR')
&      |
&      find('POCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POCSIGNCR')
&     )
&     &
&     [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&     &
&     find([F:AWS]FLGSIG,1,5)
&     &
&     [F:AWS]DEST=WUSER
Return

###############################################################################

$SET_TAB_VAL_PSH_HEAD
  Local File PREQUIS [PSH]
  Read [PSH]PSH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [PSH]
Return

###############################################################################

$SET_TAB_VAL_PSH_LINE
  Local File PREQUISD [PSD]
  Read [PSD]PSD0 = WKEYNUM;WKEYLIN
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [PSD]
Return

###############################################################################

$SET_TAB_VAL_POH_HEAD
  Local File PORDER [POH]
  Read [POH]POH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [POH]
Return

###############################################################################

$SET_TAB_VAL_POC_HEAD
  Local File PORDER [POH]
  Read [POH]POH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [POH]
Return

###############################################################################

$SET_TAB_VAL
  J = J + 1
  TAB_DEST(J)   = [AWS]DEST
  TAB_CHRONO(J) = [AWS]CHRONO
  TAB_CLEDEC(J) = [AWS]CLEDEC

  #US X3-27346 by RBA 03-08-2017 SAM 121897
  If dim(TAB_EMETTEUR)>0 : TAB_EMETTEUR(J) = [AWS]EMETTEUR : Endif
  If dim(TAB_ACTSIG)>0   : TAB_ACTSIG(J)   = [AWS]ACTSIG   : Endif
  If dim(TAB_FLGSIG)>0   : TAB_FLGSIG(J)   = [AWS]FLGSIG   : Endif
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

###############################################################################

$AQUERY_TRANS_AFTER
  Local Char WQRY_AMT(50) #US X3-21771 by RBA 01-25-2017 SAM 121176
  Local Char WQRY_CUR(10) #US X3-21771 by RBA 01-25-2017 SAM 121176

  Gosub SET_QUERY_PROPERTIES_AWS

  Local Integer I
  I = instr(1,this.AWS.CLEDEC,"~")
  Gosub GET_KEYS
  If WREP = "TOSIG" or WREP = "SIG" or WREP = "HIS"
    Case this.AWS.CODDOC
      When "PSH" : Gosub SET_QUERY_PROPERTIES_PSH
      When "POH" : Gosub SET_QUERY_PROPERTIES_POH
      When "POC" : Gosub SET_QUERY_PROPERTIES_POC
    Endcase
  Else #WREP is empty means PXX
    Case this.AWS.CODDOC
      When "PSH" : Gosub SET_QUERY_PROPERTIES_PSH_PXX
      When "POH" : Gosub SET_QUERY_PROPERTIES_POH_PXX
      When "POC" : Gosub SET_QUERY_PROPERTIES_POC_PXX
    Endcase

    Gosub SET_QUERY_URLDOC
  Endif
Return

###############################################################################

$GET_KEYS
  If I > 0
    this.AWS.KEYNUM = left$(this.AWS.CLEDEC, I-1)
    this.AWS.KEYLIN = val(right$(this.AWS.CLEDEC, I+1))
  Else
    this.AWS.KEYNUM = this.AWS.CLEDEC
    this.AWS.KEYLIN = 0
  Endif
Return

###############################################################################

$SET_QUERY_PROPERTIES_AWS
  this.AWS.DEST       = [LNK_]DEST
  this.AWS.CHRONO     = [LNK_]CHRONO
  this.AWS.CLEDEC     = [LNK_]CLEDEC

  Local File AWRKHISSUI [AWS]
  Read [AWS]AWS0 = this.AWS.CHRONO;this.AWS.DEST
  If !fstat
    SetInstance this.AWS With [F:AWS]
    this.AWS.EMAIL    = func GET_EMAIL([LNK_]DEST, [AWS]EMAIL)  #    this.AWS.EMAIL    = [AWS]EMAIL
    this.AWS.CODDOC   = func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)

    Case this.AWS.CODDOC  #US X3-21771 by RBA 01-25-2017 SAM 121176
      When "PSH" :   WQRY_AMT = [F:AWS]VALCTX2
                     WQRY_CUR = [F:AWS]VALCTX3
      When "POH" :   WQRY_AMT = [F:AWS]VALCTX4
                     WQRY_CUR = [F:AWS]VALCTX6
      When "POC" :   WQRY_AMT = [F:AWS]VALCTX4
                     WQRY_CUR = [F:AWS]VALCTX5
    Endcase #/US X3-21771 by RBA 01-25-2017 SAM 121176

  Endif
  LogicClose File [AWS]
Return

###############################################################################

$SET_QUERY_PROPERTIES_PSH
  Local File PREQUIS [PSH]
  Read [PSH]PSH0 = this.AWS.KEYNUM
  If !fstat
    this.QRY_CPY    = [PSH]CPY
    this.QRY_PSHFCY = [PSH]PSHFCY
    this.QRY_PRQDAT = [PSH]PRQDAT
    this.QRY_REQUSR = [PSH]REQUSR
    this.QRY_AMT    = val(WQRY_AMT) #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_CUR    = WQRY_CUR      #US X3-21771 by RBA 01-25-2017 SAM 121176
    If dim(this.QRY_REPONSE) > 0 and dim(this.AWS.OPERATION) > 0 : this.QRY_REPONSE = this.AWS.OPERATION : Endif #US X3-23534 by RBA 02-17-2017 SAM 121219
  Endif
  LogicClose File [PSH]
Return

###############################################################################

$SET_QUERY_PROPERTIES_PSH_PXX
  Local File PREQUIS [PSH]
  Read [PSH]PSH0 = this.AWS.KEYNUM
  If !fstat
    this.QRY_CPY    = [PSH]CPY
    this.QRY_FCY    = [PSH]PSHFCY
    this.QRY_DAT    = [PSH]PRQDAT
    this.QRY_REQUSR = [PSH]REQUSR
    this.QRY_AMT    = val(WQRY_AMT) #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_CUR    = WQRY_CUR      #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_TYPVCR = 31 #purchase requests
  Endif
  LogicClose File [PSH]
Return

###############################################################################

$SET_QUERY_PROPERTIES_POH
  Local File PORDER [POH]
  Read [POH]POH0 = this.AWS.KEYNUM
