###############################################################################

$SET_QUERY_PROPERTIES_POC_PXX
  Local File PORDER [POH]
  Read [POH]POH0 = this.AWS.KEYNUM
  If !fstat
    this.QRY_CPY    = [POH]CPY
    this.QRY_FCY    = [POH]POHFCY
    this.QRY_DAT    = [POH]ORDDAT
    this.QRY_REQUSR = [POH]BUY
    this.QRY_AMT    = val(WQRY_AMT) #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_CUR    = WQRY_CUR      #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_TYPVCR = 28 #purchase open request
  Endif
  LogicClose File [POH]
Return

###############################################################################

$SET_QUERY_URLDOC
  #url to generate
  Local Clbfile WURL
  #representation to use for Document URLDOC
  Local Char WREPRES(30)    :   WREPRES = func GET_REPRES(this.AWS.CODDOC)
  #Set keys for url
  Local Char WTABKEY(50)(1..10)
  Local Char WTABKEYVAL(50)(1..10)
  WTABKEY(1) = "DEST"   : WTABKEYVAL(1) = this.AWS.DEST
  WTABKEY(2) = "CHRONO" : WTABKEYVAL(2) = this.AWS.CHRONO
  #Set parameters for url
  Local Char WTABPAR(50)(1..10)     #no more parameters
  Local Char WTABPARVAL(250)(1..10) #no more parameters
  #generate url
  ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE, WREPRES,  [V]CST_AFAC_DETAILS, WTABKEY,WTABKEYVAL,WTABPAR,WTABPARVAL,WURL)
  this.QRY_URLDOC = WURL
Return

###############################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

###############################################################################

$AREAD_AFTER
  Gosub GET_SIG_CIRCUIT
  If dim(this.QRY_REPONSE) > 0 and dim(this.AWS.OPERATION) > 0 : this.QRY_REPONSE = this.AWS.OPERATION : Endif #US X3-23534 by RBA 02-17-2017 SAM 121219
  Gosub GET_REASON #US X3-23534 by RBA 02-22-2017 SAM 121643
Return

$GET_REASON
  Local Integer WOK
  Local Char WCLEDEC(100) : WCLEDEC = ""

  WCLEDEC = this.AWS.CLEDEC
  If WCLEDEC <> ""
    If WREP = "SIG" and dim(this.AWS.OPERATION) > 0
      If this.AWS.OPERATION = "REJ"
        WOK = fmet this.AWS.ASETATTRIBUTE('REASON', "$isHidden", 'false')
        Local Integer I : I = 0
        Local File AWRKHISSUI [AWS]
        Filter [AWS] Where CLEDEC = WCLEDEC Order By CHRONO Desc
        For [AWS]
          If [AWS]CHRONO = this.AWS.CHRONO
            I = 0
          Endif
          I = I + 1
          If I = 2 #c'est donc le suivant
            this.AWS.REASON = [AWS]REASON
            Break
          Endif
        Next
        Filter [AWS]
        LogicClose File [AWS]
      Else
        WOK = fmet this.AWS.ASETATTRIBUTE('REASON', "$isHidden", 'true')
      Endif
    Elsif (WREP = "HIS" or WREP = "") #US X3-27015 by RBA 03-10-2017 SAM 121940
      If this.AWS.ACTSIG = "VAL"
        WOK = fmet this.AWS.ASETATTRIBUTE('REASON', "$isHidden", 'true')
      Else
        WOK = fmet this.AWS.ASETATTRIBUTE('REASON', "$isHidden", 'false')
      Endif #/US X3-27015 by RBA 03-10-2017 SAM 121940
    Endif
  Endif
Return


$GET_SIG_CIRCUIT
  Local Integer WOK
  Local Char WCLEDEC(100) : WCLEDEC = ""

  WCLEDEC = this.AWS.CLEDEC
  If WCLEDEC <> ""
    Local File AWRKHISSUI [AWS]
    Case WCODOBJ
      When "PSH"
        Case WREP
          When "HIS"   : Gosub SIG_FILTER_PSH_HIS #historique
          When "TOSIG" : Gosub SIG_NO_FILTER      #a signer
          When "SIG"   : Gosub SIG_NO_FILTER      #Signé
        Endcase
      When "POH"
        Case WREP
          When "HIS"   : Gosub SIG_FILTER_POH_HIS #historique
          When "TOSIG" : Gosub SIG_NO_FILTER      #a signer
          When "SIG"   : Gosub SIG_NO_FILTER      #Signé
        Endcase
      When "POC"
        Case WREP
          When "HIS"   : Gosub SIG_FILTER_POC_HIS #historique
          When "TOSIG" : Gosub SIG_NO_FILTER      #a signer
          When "SIG"   : Gosub SIG_NO_FILTER      #Signé
        Endcase
      When "PXX"       : Gosub SIG_FILTER_PXX     #Historique tout achats
    Endcase
    For [AWS]
      #circuit de signature
      Local Integer I
      Local Integer WPOS
      For I = 1 To [AWS]NBRUSR
        WPOS = fmet this.ADDLINE("SIG",[V]CST_ALASTPOS)
        If WPOS >= 0
          this.SIG(WPOS).SIG_POS = I
          this.SIG(WPOS).SIG_NAM = evalue("[AWS]USRSIG"+num$(I))
          If [AWS]FLGSIG = 5
            If I <= [AWS]LEVSIG + 1
              this.SIG(WPOS).SIG_LEV = "X"
            Endif
          Else # [AWS]FLGSIG = 3, en tout cas <> 5
            If I < [AWS]LEVSIG + 1
              this.SIG(WPOS).SIG_LEV = "X"
            Endif
          Endif
        Endif
      Next
      #fin circuit de signature
      Break #on ne va chercher que le 1er trouvé
    Next
    LogicClose File [AWS]
  Endif
Return

$SIG_FILTER_PSH_HIS
    Filter [AWS] Where
&       (
&       (find('PSHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSHSIGNCR')
&       |
&       (find('PSDSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSDSIGNCR')
&       )
&       &
&       find ([F:AWS]FLGSIG, 2, 4, 5)
&       &
&       [F:AWS]CLEDEC = WCLEDEC
&       Order By CHRONO Desc
Return

$SIG_FILTER_POH_HIS
    Filter [AWS] Where
&       (
&       find('POHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POHSIGNCR')
&       )
&       &
&       find ([F:AWS]FLGSIG, 2, 4, 5)
&       &
&       [F:AWS]CLEDEC = WCLEDEC
&       Order By CHRONO Desc
Return

$SIG_FILTER_POC_HIS
    Filter [AWS] Where
&       (
&       find('POCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POCSIGNCR')
&       )
&       &
&       find ([F:AWS]FLGSIG, 2, 4, 5)
&       &
&       [F:AWS]CLEDEC = WCLEDEC
&       Order By CHRONO Desc
Return

$SIG_FILTER_PXX
    Filter [AWS] Where
&     (
&      (
&       (find('PSHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSHSIGNCR')
&       |
&       (find('PSDSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'PSDSIGNCR')
&      )
&      |
&      find('POHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POHSIGNCR')
&      |
&      find('POCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'POCSIGNCR')
&     )
&     &
&     find ([F:AWS]FLGSIG, 2, 4, 5)
&     &
&     [F:AWS]CLEDEC = WCLEDEC
&     Order By CHRONO Desc
Return

$SIG_NO_FILTER
  Filter [AWS] Where [AWS]CHRONO = this.AWS.CHRONO and [AWS]DEST = this.AWS.DEST
Return
#---------------------------------------------------

###############################################################################

Funprog GET_EMAIL(USER, EMAIL)
Value Char USER
Value Char EMAIL
  Local Char WEMAIL(250) : WEMAIL = ""
  If EMAIL = ""
    Local File AUTILIS [AUS]
    Read [AUS]CODUSR = USER
    If !fstat
      WEMAIL = [AUS]ADDEML
    Endif
    LogicClose File [AUS]
  Else
    WEMAIL = EMAIL
  Endif
End WEMAIL

###############################################################################

Funprog GET_CODDOC(WCODEVT, WCODWRK)
Value Char WCODEVT
Value Char WCODWRK
  Local Char WCODDOC(3)
  If left$(WCODEVT,3) = "PSH" | left$(WCODWRK,3) = "PSH" : WCODDOC = "PSH" : Endif #purchase requests
  If left$(WCODEVT,3) = "PSD" | left$(WCODWRK,3) = "PSD" : WCODDOC = "PSH" : Endif #purchase requests
  If left$(WCODEVT,3) = "POH" | left$(WCODWRK,3) = "POH" : WCODDOC = "POH" : Endif #purchase orders
  If left$(WCODEVT,3) = "POC" | left$(WCODWRK,3) = "POC" : WCODDOC = "POC" : Endif #purchase open orders
End WCODDOC

###############################################################################

Funprog GET_REPRES(WCODDOC)
Value Char WCODDOC
  Local Char WREPRES(100)
  Case WCODDOC
    When "PSH" : WREPRES   = "TCWPSHSIGHIS"
    When "POH" : WREPRES   = "TCWPOHSIGHIS"
    When "POC" : WREPRES   = "TCWPOCSIGHIS"
    When Default : WREPRES   = ""
  Endcase
End WREPRES

