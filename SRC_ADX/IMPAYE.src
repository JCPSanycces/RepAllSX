Variable Char    VALEUR()
AXE=20 : Goto CONTCCE


$CONTCCE
Gosub SETNOL
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
For NLED=1 To GNBTYPLED
 COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
 If COMPTE<>""
  [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
  Call LECLED([M:IPY0]CPY,[L]TLED,LED,DEV) From CPTDIV
  Call CONTCCE(VALEUR,[L]LED,GAXE(AXE),[M]FCYLIN(NOL),[M]ACCDAT,COMPTE,[M]DIE,"[M]CCE#",NOL) From CPTCNT
 Endif
Next
End

Subprog D_DUDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] & [M:IPY0]NBLIG<>0
 If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif
 Call LEC_PYH([M:IPY0]NUM(0)) From CPTLEC
 VALEUR = [F:PYH]DUDDAT
Endif
End

Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
If [M:IPY0]NBLIG = 0
 mkstat = 1
Endif
End

Subprog IB_NUM
GBOUT2 = mess(18,100,1)     # Sélection
GBOUT3 = mess(173,124,1)    # Sélection avancée
End

Subprog C_PAYTYP(VALEUR)
Variable Char    VALEUR()
If dim([F:TPY]ACS)>0
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif

#ISSUE 39260 - 2017-08-01 By MANOW
If func AFNC.ACTIV("REGBC")
  Filter [F:TPY2] Where [F:TPY2]PAYTYP = VALEUR and [F:TPY2]DACREGNUM = 2
  Look [F:TPY2] First
  If !fstat
   Call ERRTIT(mess(32,126,1)-'"'+mess(198,117,1)+'"', mess(198,117,1)-mess(368,177,1)) From GESECRAN
   mkstat=2
  Endif
  Filter [F:TPY2]
Endif
#ISSUE END

End

$SEL_TABLE
Case COUZON
 When "NUM"
  OBJET = "PAY"
  OPTIONS = "#"
  Gosub CRE_CRIT
Endcase
Return

$CRE_CRIT
If dim([M:IPY0]BAN)>0
    #Réglement est proposé si étape 8 ou 9 réalisée et pas étape impayé
    CRITERE = '(BAN=[M]BAN2 | BAN="") & PAYTYP=[M]PAYTYP'
    CRITERE += '& STAFLG(10) <> 2 & (STAFLG(7)=2 | STAFLG(8)=2)'
Else
    CRITERE = 'PAYTYP=[M]PAYTYP & [F:PYH]BPRTYP=GBIDI1'
    CRITERE += '& STAFLG(4)<>2 & STAFLG(5)<>2 & STAFLG(6)<>2 & STAFLG(7)<>2 & STAFLG(8)<>2 & STAFLG(10)<>2'
Endif
If [M]BPR2<>"" : CRITERE += ' & BPR=[M]BPR2' : Endif
If [M]FCY2<>"" : CRITERE += ' & FCY=[M]FCY2' : Endif
If [M]CUR2<>""         : CRITERE += ' & CUR=[M]CUR2'       : Endif
If [M]DUDDAT2<>[0/0/0] : CRITERE += ' & DUDDAT=[M]DUDDAT2' : Endif
If [M]REF2<>""         : CRITERE += ' & pat(REF,[M]REF2)'  : Endif
If [M]AMTCUR2<>0
 B1 = [M]AMTCUR2*(1+[M:IPY1]PRCTOL/100)
 B2 = [M]AMTCUR2*(1-[M:IPY1]PRCTOL/100)
 CRITERE += ' & AMTCUR<=B1'
 CRITERE += ' & AMTCUR>=B2'
Endif
Return


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

