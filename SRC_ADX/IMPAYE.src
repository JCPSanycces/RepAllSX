Variable Char    VALEUR()
AXE = 17 : Goto SAICCE
Subprog AS_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto SAICCE
Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto SAICCE
Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto SAICCE


$SAICCE
If [M:IPY0]AMTCRG(nolign-1)=0
 mkstat = 1 : End
Else
 Local Char    COMPTE(GLONGAC)
 Local Integer NLED, TLED
 Local Integer AXI, IND
 Gosub SETNOL
 mkstat = 1
 For NLED=1 To GNBTYPLED
  [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
  Call INDLED([L]LED,[M:IPY0]DIE(AXE-1),IND,AXI) From CPTDIV
  If AXI
   COMPTE = evalue("[M:IPY0]ACC"+num$(NLED)+"("+num$(NOL)+")")
   If COMPTE<>""
    Call LEC_GAC(COMPTE, [M:IPY0]COA(ILED-1)) From CPTLEC
    If find([M:IPY0]DIE(AXE-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
   Else
    Raz mkstat : Break
   Endif
  Endif
 Next
Endif
End

