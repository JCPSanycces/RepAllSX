#<AdxTL>@(#)12.0.0.0 $Revision$  Impayés
#
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"IMPAYE"
 GFONCTION="IMPAYE" : Call AUTORIS From EXEFNC
Endif
GACTION = "IMPAYE"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"FIMPAYE","IMPAYE","",1,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End
#
$ACTION
Case ACTION
 When "DEBUT"
  Case PROG
   When "SELOBJAW"  : Gosub DSELPAY
   When Default     :
    Case GBOITE
     When "FIMPSEL" : Gosub DEBUT_FSEL
     When Default   : Gosub DEBUT
    Endcase
  Endcase
 When "APRES_MODIF" : REP="M"
 When "FIN"
  Case PROG
   When "SELOBJAW"  : Gosub FSELPAY
   When Default     : Gosub FIN
  Endcase
 When "ENR"         : Gosub ENR
 When "EXEC"        : Gosub EXEC
 When "AP_CHOIX"    :
  Case BOITE
   When "FIMPSEL" : Gosub AP_CHOIX
   When Default   :
  Endcase
 When "OK"          : Gosub OK_SEL
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

######
$DEBUT
######
Onerrgo CHUT From CONTROLE
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY] : Endif
#ISSUE 39260 - 2017-08-01 By MANOW
If !clalev([F:TPY2]) : Local File TABPAYTYP  [TPY2] : Endif
#END ISSUE
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:PYD])  : Local File PAYMENTD   [PYD] : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN] : Endif
If !clalev([F:CCE])  : Local File CACCE      [CCE] : Endif
If !clalev([F:ADI])  : Local File ATABDIV    [ADI] : Endif
If !clalev([F:GAG])  : Local File GAUTACEF   [GAG] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif : # Modèles comptables
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif : # Référentiels
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif : # Code plans
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif : # Axes analytiques
Onerrgo
If GERREUR : GERREUR=0 : Endif

Global Integer GNBPLAN                                       : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                        : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..max(len(mess(0,2644,1)),10)): # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))            : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))                   : # Obligatoire (O/N)
Global Integer GNBTYPLED                                     : # Nb référentiels (pour init sections)
Global Integer GTYPLED(1..max(len(mess(0,2644,1)),10))       : # Types référentiels

Raz [M:IPY0]
Return

$DEBUT_FSEL
If dim([M:IPY0]BAN)>0 : [M]BAN2 = [M:IPY0]BAN  Else Raz [M]BAN2 : Endif
Raz [M]AMTCUR2, FCY2
Local Char OPT(30)
Call PARAM("","PRCTOL",[L]OPT) From ADOVAL
[M:IPY1]PRCTOL = val([L]OPT)
Return

$AP_CHOIX
REP=""  :# Bouton Fin : pour ne pas confirmer l'abandon
Return

$OK_SEL
If status=0
  FIN=0
 Else
  VALEUR=VALBOUT
 Endif
Return

#####
$EXEC
#####
If GSTATUT<>GSTAENR : FIN=1 : Return : Endif
TRA=1
Return

####
$ENR
####
If [M:IPY0]NBLIG=0 : FIN=1 : Return : Endif

Onerrgo ERREUR From CONTROLE
If !clalev([F:UNP])  : Local File UNPAID     [UNP]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:PAN])  : Local File PAYACCNUM  [PAN]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
If !clalev([F:DAE2]) : Local File GACCENTRYD [DAE2] : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DAT])  : Local File GACCTMPD   [DAT]  : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:CAC])  : Local File GACCCODE   [CAC]  : Endif
If !clalev([F:MVC])  : Local File BPCUSTMVT  [MVC]  : Endif
If !clalev([F:FRM])  : Local File PAYFRM     [FRM]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]  : Endif
If !clalev([F:GAU])  : Local File GAUTACE    [GAU]  : Endif
If !clalev([F:GAD])  : Local File GAUTACED   [GAD]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
If !clalev([F:TSV])  : Local File TABSIVTYP  [TSV]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:SIH])  : Local File SINVOICE   [SIH]  : Endif
If !clalev([F:SIL])  : Local File BPCINVLIG  [SIL]  : Endif
If !clalev([F:SIA])  : Local File BPCINVLIGA [SIA]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char    PLAN(GLONCOA)
Local Char    TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    CPTDEV(GLONGAC)(1..len(mess(0,2644,1))), ACCB(GLONGAC)(1..len(mess(0,2644,1)))
Local Char    ACCT(GLONGAC)(1..len(mess(0,2644,1))), BPRB(GLONBPR), DEV(GLONCUR), DEVT(GLONCUR)
Local Char    LETTRE(3)
Local Char    IDPCE(30)
Local Decimal AMTDEV, MT
Local Libelle BORTYP
Local Char    BORNUM(GLONFRM), MESSA(100), IDENT(20)(1..2)
Local Integer STAT, I, J, K, FLGDEVAL, REECR, NBIMP, MAXPAY
Local Integer FLGSTA
Local Mask    PAY3 [PAY3]
MAXPAY = max(50,dim([M:PAY3]VCRNUM))
Close Local Mask [PAY3]

Local Integer LACCNUM(1..MAXPAY), LDUDLIG(1..MAXPAY)
Local Decimal LAMTIPT(1..MAXPAY)
Local Char    PCEAUTO(GLONGAU), PCEFRAIS(GLONGAU), NOTEDEB(GLONTSV)
Local Char    TEMP (1)
Local Integer NBRPCE, FLGANA
Local Decimal MONTSOC
Local Integer OD_TIERS
Local Char    XPARAM(1)
 #*X3-39795 Local Char     TZONE(10)(1)       : # Table des zones à forcer
 #*X3-39795 Local Char     TVAL(30)(1)        : # Table des valeurs des zones à forcer
Local Char   TZONE(10)(1..10)     : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char   TVAL(30)(1..10)      : # Table of values for zones to be forced         #*X3-39795

Call TEMPON("V") From GESECRAN
Call OUVRE_TRACE(mess(151,117,1)) From LECFIC : # Génération des écritures d'impayé

Call PARAM("","GAUUNPAI",[L]PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="UNPAI" : Endif
Call PARAM("","GAUUNPAY",[L]PCEFRAIS) From ADOVAL
If [L]PCEFRAIS="" : [L]PCEFRAIS="UNPAY" : Endif
Call PARAM([M:IPY0]CPY,"TAXUNPAY",[L]TEMP) From ADOVAL
[L]NBRPCE=val([L]TEMP)
If [L]NBRPCE=0 : [L]NBRPCE=1 : Endif
Call PARAM([M:IPY0]CPY,"TYPINVNDT",[L]NOTEDEB) From ADOVAL
If [L]NOTEDEB="" : [L]NOTEDEB="DEB" : Endif

If dim(GSDDMGT)>0
 Call PARAML([M:IPY0]CPY,"SDDMGT",XPARAM) From ADOVAL
 GSDDMGT=val(XPARAM)
 If GSDDMGT=2
  If clalev([F:HMDT])=0 : Local File HISTOMDT [HMDT] : Endif
  If clalev([F:MDT])=0  : Local File MANDATE [MDT]   : Endif
 Endif
Endif

#Pour la création de la note de débit
Local Char INTERM (GLONGAC)
Local Char GTECOD(GLONGTE)
Local Char JOUCOD(GLONJOU)
Local Char NUMFAC(GLONVCR)

#Pour le lettrage du compte inter_devise (DdM38083)
Local Integer LETACC

# Effacement du fichier PROROGPCE
Call DEBTRANS From GLOCK
Gosub TR_ANNUL

If GOK>0
 # Maj fichier UNPAID
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK>0 # Génération écritures + lettrage + Maj PAYMENTH,BPCUSTMVT
  If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
  If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
  If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
  If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
  If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif
  If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
  If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
  If clalev([M:SCL])=0  : Local Mask SAICURLED  [SCL]  : Endif
  Default Mask [M:IPY0]
  NBIMP = 0

  # Sauvegarde de valeurs (essentielle lors d'extourne d'une pièce de lettrage automatique)
  MAXLIG = dim([M:HAE2]BPR)
  Local Integer SVG_NBLIG, II
  Local Integer SVG_LEDTYP(MAXLIG)
  Local Char    SVG_ACC(GLONGAC)(MAXLIG)
  Local Decimal SVG_DEB(MAXLIG), SVG_CDT(MAXLIG), SVG_AMTLED(MAXLIG)
  Local Integer SVG_ACCNUM(MAXLIG)
  Local Integer PAN_ACCNUM

  For [UNP]UNP0(1)
   Call DEBTRANS From GLOCK
   Gosub TR2
  Next : # [UNP]
  Close Local Mask [HAE0], [HAE1], [HAE2], [VTL], [VT2], [HAEF], [HAEW], [SCL]
  If NBIMP>0
   Call ECR_TRACE(" \"+num$(NBIMP)-mess(28,117,1),0) From GESECRAN
   # NBIMP règlement(s) traité(s)
  Endif
 Endif
Endif

Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN

If NBIMP=0
 GERR=2 : GMESSAGE=mess(2,117,1)
 # Aucun règlement traité
Endif
FIN=1
Return

$OUVRE
Local File TABCUR[TCU],BPARTNER[BPR]
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Return

######################## Effacement du fichier UNPAID #############################

$TR_ANNUL
GOK=1
Trbegin [UNP]
 Delete [UNP] Where 1=1
 If fstat=1
  GLOCK = "UNPAID"-"" : Goto ROLL_TR_ANNUL
 Elsif fstat>5
  Call RSTA("UNP","") From GLOCK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif
Return

######################## Maj fichier UNPAID #############################

$TR1
GOK=1
Trbegin [UNP], [TPY]
 For I=0 To [M:IPY0]NBLIG-1
  Raz [F:UNP]
  Raz CPTDEV, TPLAN, ACCB, DEV, MT, BPRB, ACCT, DEVT
  Readlock [PYH]PYH0=[M:IPY0]NUM(I)
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[M:IPY0]NUM(I) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("PYH",[M:IPY0]NUM(I)) From GLOCK : Break
  Endif
  If [F:PYH]STAFLG(10) = 2
   Call ECR_TRACE([M:IPY0]NUM(I)-":"-mess(125,117,1),1) From GESECRAN : # Règlement déjà impayé
  Else
   Call LEC_CPY([F:PYH]CPY) From CPTLEC
   Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
   Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
   Call LECPLAN([F:PYH]CPY,GTYPGEN,PLAN) From CPTDIV
   Call SETCUR(1,[F:PYH]CPY,GLOCALDEV) From CPTDIV
   # Recherche code journal+compte tresorerie+montant+devise+bpr du compte trésorerie
   Call JOUCPT([F:PYH]NUM,TPLAN,ACCB,[F:UNP]JOU,[F:UNP]ACCNUM,[F:UNP]AMTACCNUM,DEV,
&              BPRB,[F:UNP]GRP,[F:UNP]ACCSTA) From IMPAYE
   If GOK<1 : Break : Endif
   If [M:IPY0]BPCTYP(I) <> 2
    ACCT(GTYPGEN) = [F:PYH]ACC
    MT   = [F:PYH]AMTCUR
    DEVT = [F:PYH]CUR
   Else  : # Client douteux="Oui"
    Call DOUTEUX([F:PYH]BPR,ACCT) From IMPAYE
    Call LEC_GAC(ACCT, PLAN) From CPTLEC
    DEVT = [F:GAC]CUR
    If DEVT<>[F:PYH]CUR & DEVT<>""
     Call CONVERT([F:PYH]CUR,DEVT,GLOCALDEV,0,[M:IPY0]ACCDAT,[F:PYH]AMTCUR,MT,STAT) From TRTDEV
     If STAT
      # Règlement XXXXX : Pas de cours de devises CUR -> DEVT (ACCDAT)
      Call ECR_TRACE(mess(27,117,1)-[M:IPY0]NUM(I)-":"-mess(16,114,1)-[F:PYH]CUR-"->"-DEVT-"("+format$("D:"+GFMDAT,[M:IPY0]ACCDAT)-")",1) From GESECRAN
      GOK=0 : Break
     Endif
    Else
     MT = [F:PYH]AMTCUR
    Endif
   Endif

   #Issue X3-75462 by MRDAB
   If (func AFNC.ACTIV("FIFRC"))
    If (func AFNC.PARAM("FIFRC", [F:PYH]FCY) = "2")
      If func FIFOCONVAR_CSTD.FLDFIFCP_CTL([F:PYH]BAN, [F:PYH]ACCDAT)
       If func FIFOCONVAR_CSTD.IS_FIFO_EXIST([F:PYH]BAN,[F:PYH]ACCDAT) = 1
        Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(29,7708,1),1) From GESECRAN
        GOK=0 : Break
       Endif
      Endif
    Endif
   Endif
   #Issue end

   # Passage par compte de liaison inter-devise ?
   If DEV<>DEVT & DEV<>"" & DEVT<>""
    Call RECH_ACCMIS([F:PYH]CPY,GTYPGEN,16,CPTDEV) From CPTDIV
    If CPTDEV=""
     # On contrôle que le compte d'attente pour OD devise trésorerie a été défini au moins
     # pour le plan de compte correspondant au référentiel général principal
     Call ECR_TRACE(mess(18,2649,1)-tolower(mess(176,105,1))-PLAN,1) From GESECRAN
     GOK=0 : Break
    Endif
    Call LEC_GAC(CPTDEV, PLAN) From CPTLEC
    If fstat=0 & [F:GAC]SAC=2
     # Compte : Type de compte incorrect "(WAICURACC1)"
     Call ECR_TRACE(CPTDEV-"("+PLAN+")"-":"-mess(59,106,1),1) From GESECRAN
     GOK=0 : Break
    Endif
   Endif
   If CPTDEV=""


#DdM38083
# Si CPTDEV n'est pas renseigné, pas de compte inter-devise donc une seule pièce (cas des frais à part)
# Si client douteux, le compte du client peut être suivi dans une devise... dans ce cas de figure, la conversion du montant est effectuée
#        Montant règlement en devise de règlement est converti en devise du compte Tiers (ligne 273).
#    Par contre, si le compte client n'est pas associé à une devise...
#    La variable MT contient le montant du règlement et la devise DEV contient la devise du compte de banque.
#    Différence de devise possible donc cAjout de l'appel du CONVERT
    Call CONVERT([F:PYH]CUR,DEV,GLOCALDEV,0,[M:IPY0]ACCDAT,MT,AMTDEV,STAT) From TRTDEV
    If STAT
     # Pas de cours de devises DEV -> DEVT (ACCDAT)
     Call ECR_TRACE(mess(27,117,1)-[M:IPY0]NUM(I)-":"-mess(16,114,1)-DEV-"->"-[F:PYH]CUR-"("+format$("D:"+GFMDAT,[M:IPY0]ACCDAT)-")",1) From GESECRAN
     GOK=0 : Break
    Endif
    Call GENE_PCE(TPLAN,ACCB,BPRB,ACCT,[F:PYH]BPR,DEV,AMTDEV,I,'L',NBRPCE) From IMPAYE

    If GOK<0 : Break : Endif
    # Frais s/pièce séparée
    If [M:IPY0]AMTCRG(I)<>0 & [M:IPY0]IPTBPR(I)=1 & [M:IPY0]CUR<>DEV
     Call GENE_PCE(TPLAN,ACCB,BPRB,"","",[M:IPY0]CUR,[M:IPY0]AMTCRG(I),I,'O',NBRPCE) From IMPAYE
     If GOK<0 : Break : Endif
    Endif
   Else
    Call CONVERT(DEVT,DEV,GLOCALDEV,0,[M:IPY0]ACCDAT,MT,AMTDEV,STAT) From TRTDEV
    If STAT
     # Pas de cours de devises DEV -> DEVT (ACCDAT)
     Call ECR_TRACE(mess(27,117,1)-[M:IPY0]NUM(I)-":"-mess(16,114,1)-DEV-"->"-DEVT-"("+format$("D:"+GFMDAT,[M:IPY0]ACCDAT)-")",1) From GESECRAN
     GOK=0 : Break
    Endif
    # Compte banque -> compte inter-devise
    Call GENE_PCE(TPLAN,ACCB,BPRB,CPTDEV,"",DEV,AMTDEV,I,'N',NBRPCE) From IMPAYE
    If GOK<0 : Break : Endif
    # Compte inter-devise -> compte tiers
    Call GENE_PCE(TPLAN,CPTDEV,"",ACCT,[F:PYH]BPR,DEVT,MT,I,'M',NBRPCE) From IMPAYE
    If GOK<0 : Break : Endif
   Endif
  Endif
 Next I
 If GOK <0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

###########################################################################
Subprog JOUCPT(PNUM,PCOA,PACC,PJOU,PACCNUM,PAMTACCNUM,PCUR,PBPRBAN,PGRP,PACCSTA)
###########################################################################
Value    Char     PNUM()            : # N° règlement
Variable Char     PCOA()(1..)       : # Tableau des plans de compte par type référentiel
Variable Char     PACC()(1..)       : # Tableau des comptes de trésorerie à solder par type référentiel
Variable Char     PJOU()
Variable Integer  PACCNUM(0..)      : # Tableau des n°écritures générées (sur le réf. général principal)
Variable Decimal  PAMTACCNUM(0..)   : # Tableau des montants en dev. transaction  (des écritures du réf. gén. princ)
Variable Char     PCUR()            : # Devise
Variable Char     PBPRBAN()         : # Tiers (cas où le compte de trésio est auxiliarisé)
Variable Char     PGRP()            : # Groupe : B+Num_bordereau ou R+Num_règlement ou D+Date_échéance
Variable Shortint PACCSTA           : # Dernière étape de comptabilisation réalisé sur le règlement PNUM

If !clalev([F:DAE3])  : Local File GACCENTRYD    [DAE3]  : Endif

Local Integer I, STAT, FLGAUT
Local Libelle TYPEFF
Local Char    PARAM2(10), COMPTE(10)

For [PAN] Where TYPNUM=3 & NUM=PNUM & RVSACCNUM=0 & CPTBAN=2 & find(ACCSTA,8,9)
 If [F:PAN]ACCSTA > [L]PACCSTA
  PACCSTA = [F:PAN]ACCSTA
 Endif
Next : # [PAN]
If PACCSTA=0
 # Règlement XXX : Ecriture du réglement introuvable ou règlement annulé
 Call ECR_TRACE(mess(27,117,1)-PNUM-":"-mess(140,117,1),1) From GESECRAN
 GOK = 0 : End
Endif

#La remise en banque ou sur compte peut générer plusieurs pièces comptables pour un règlement
#Les remises d'un règlement à une étape donnée se font sur le même compte/devise/journal
I = 0
For [PAN]PAN0 Where TYPNUM=3 & NUM=PNUM & RVSACCNUM=0 & CPTBAN=2 & ACCSTA=PACCSTA
 PGRP = [F:PAN]GRP
 Read [DAE]DAE2=[F:PAN]ACCNUM
 If fstat
  Read [DAT]DAT1=[F:PAN]ACCNUM
  If fstat=0 : # Règlement XXXXX : TYP NUM En cours de validation
   Call ECR_TRACE(mess(27,117,1)-PNUM-":"-[F:DAT]TYP-[F:DAT]NUM-mess(128,117,1),1) From GESECRAN
  Else       : # Règlement XXXXX : Pièce inexistante (ACCNUM)
   Call ECR_TRACE(mess(27,117,1)-PNUM-":"-mess(28,107,1)-"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
  Endif
  GOK = 0 : Break
 Endif
 Call LEC_HAE([F:DAE]TYP, [F:DAE]NUM) From CPTLEC
 PACCNUM(I)    = [F:DAE]ACCNUM
 PAMTACCNUM(I) = [F:DAE]AMTCUR
 I+= 1
Next : # [PAN]
PCUR      = [F:DAE]CUR
PCOA(GTYPGEN) = [F:DAE]COA
PACC(GTYPGEN) = [F:DAE]ACC
For [DAE3]DAE7(4) Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & IDTLIN=[F:DAE]IDTLIN & LEDTYP<>GTYPGEN
 Call LEDTYPAUT([F:DAE3]CPY,[F:DAE3]LEDTYP,[L]FLGAUT) From CPTDIV
 If [L]FLGAUT<>2
  PCOA([F:DAE3]LEDTYP) = [F:DAE3]COA
  PACC([F:DAE3]LEDTYP) = [F:DAE3]ACC
 Endif
Next

PBPRBAN   = [F:DAE]BPR
PJOU      = [F:HAE]JOU
End

##############################################################
Subprog GENE_PCE(PLAN,A1,B1,A2,B2,DEVISE,MONT,IND,TYPVCR,PCENBR)
##############################################################
Value Char    PLAN()(1..) : # Tableau des plan de comptes
Value Char    A1()(1..)   : # Tableau des comptes de trésorerie à solder par type référentiel
Value Char    B1()        : # Tiers (cas où le compte de tréso est auxiliarisé)
Value Char    A2()(1..)   : # Compte tiers payeur
Value Char    B2()        : # Tiers payeur
Value Char    DEVISE()    : # Devise
Value Decimal MONT        : # Montant
Value Integer IND
Value Char    TYPVCR()
Value Integer PCENBR

Local Integer STAT,JJ
Local Char SITE(GLONFCY)
If !clalev([F:PYD2]) : Local File PAYMENTD   [PYD2] : Endif
Filter [PYD2] Where NUM = [M:IPY0]NUM(IND) & DUDNUM<>0 & DUDLIG<>0
Read [PYD2]PYD0 First
Filter [PYD2]
If !fstat
 SITE = [F:PYD2]FCYLIN
Else
 SITE = [F:PYH]FCY
Endif
[F:UNP]FCY = [L]SITE
For I=1 To len(mess(0,2644,1))
 [F:UNP]COA(I-1) = PLAN(I)
 [F:UNP]ACC(I-1) = A1(I)
Next
For I=1 To GNBAXE
 [F:UNP]DIE(I-1) = evalue("[M:IPY0]DIE("+num$(I-1)+")")
Next I
[F:UNP]BPRBAN    = B1
[F:UNP]CUR       = DEVISE
[F:UNP]BAN       = [M:IPY0]BAN
[F:UNP]ACCDAT    = [M:IPY0]ACCDAT
[F:UNP]DUDDAT    = [M:IPY0]DUDDAT
[F:UNP]NUM       = [M:IPY0]NUM(IND)
[F:UNP]DES       = [M:IPY0]DES(IND)
[F:UNP]DESVCR    = [M:IPY0]DESVCR
[F:UNP]IPT       = [M:IPY0]IPTBPR(IND)
[F:UNP]BPR       = B2
For I=1 To len(mess(0,2644,1))
 [F:UNP]ACCBPR(I-1) = A2(I)
Next
[F:UNP]RENNOTPAY = [M:IPY0]RENNOTPAY(IND)
[F:UNP]AMTBPR    = MONT
[F:UNP]TYPVCR    = TYPVCR
[F:UNP]FLGCRG    = PCENBR
If TYPVCR = 'O'
 [F:UNP]FLGCRG    = 2
Endif
# Frais saisis si règlement remis en banque. Ils sont saisis dans la devise de la banque [M]CUR
If [M:IPY0]AMTCRG(IND)<>0
 # Devise banque <> devise pièce (cas où le collectif a une devise <> devise banque)
 If [M:IPY0]CUR<>DEVISE
  If [M:IPY0]IPTBPR(IND)=2 : # Les frais s'imputent sur le client
   Call CONVERT([M:IPY0]CUR,DEVISE,GLOCALDEV,0,[M:IPY0]ACCDAT,[M:IPY0]AMTVAT(IND),[F:UNP]AMTVAT,STAT) From TRTDEV
   If STAT
    # Règlement XXXXXX : Pas de cours de devises CUR -> DEVISE (ACCDAT)
    Call ECR_TRACE(mess(27,117,1)-[M:IPY0]NUM(IND)-":"-mess(16,114,1)-[M:IPY0]CUR-"->"-DEVISE-"("+format$("D:"+GFMDAT,[M:IPY0]ACCDAT)-")",1) From GESECRAN
    GOK=0 : End
   Endif

   Call CONVERT([M:IPY0]CUR,DEVISE,GLOCALDEV,0,[M:IPY0]ACCDAT,[M:IPY0]AMTCRG(IND),[F:UNP]AMTCRG,STAT) From TRTDEV
   If STAT
    # Règlement XXXXXX : Pas de cours de devises CUR -> DEVISE (ACCDAT)
    Call ECR_TRACE(mess(27,117,1)-[M:IPY0]NUM(IND)-":"-mess(16,114,1)-[M:IPY0]CUR-"->"-DEVISE-"("+format$("D:"+GFMDAT,[M:IPY0]ACCDAT)-")",1) From GESECRAN
    GOK=0 : End
   Endif
  Else
   [F:UNP]AMTCRG = 0
   [F:UNP]AMTVAT = 0
  Endif
 Else
  [F:UNP]AMTVAT  = [M:IPY0]AMTVAT(IND)
  [F:UNP]AMTCRG  = [M:IPY0]AMTCRG(IND)
 Endif
 [F:UNP]TAX      = [M:IPY0]TAX(IND)
 For JJ=1 To GOPTCANA
  [F:UNP]CCE(JJ-1)   = evalue("[M:IPY0]CCE"+num$(JJ)+"("+num$(IND)+")")
 Next JJ
Else
 [F:UNP]AMTVAT   = 0
 [F:UNP]AMTCRG   = 0
 [F:UNP]TAX      = ""
 [F:UNP]CCE(0)   = ""
 [F:UNP]CCE(1)   = ""
 [F:UNP]CCE(2)   = ""
 [F:UNP]CCE(3)   = ""
 [F:UNP]CCE(4)   = ""
 [F:UNP]CCE(5)   = ""
 [F:UNP]CCE(6)   = ""
 [F:UNP]CCE(7)   = ""
 [F:UNP]CCE(8)   = ""
Endif

If PCENBR=1
 [F:UNP]AMTACC    = MONT+[F:UNP]AMTVAT+[F:UNP]AMTCRG
Else
 [F:UNP]AMTACC    = MONT
Endif

#Si les frais sont à la charge du tiers -> Note de débit
If[F:UNP]AMTCRG<>0 & [F:UNP]IPT=2 & ([F:UNP]TYPVCR='L'|[F:UNP]TYPVCR='N')
 [F:UNP]FLGACT=2
Endif

GPOINT = "AV_ECRUNP" : Gosub ENTREE From EXEFNC

Write [UNP]
If fstat
 GOK= 0 : Call FSTA("UNP") From GLOCK
 End
Endif
End

###########################
Subprog DOUTEUX(CLECPT,CPT)
###########################
Value Char CLECPT()
Variable Char CPT()(1..)
Local Char    PLAN(GLONCOA), CODCPT(GLONCAC)
Local Integer TYPLED
Call LEC_BPC(CLECPT) From CPTLEC
For TYPLED=1 To len(mess(0,2644,1))
 Call INIT_COMPTE(CLECPT,[F:PYH]CPY,"C",CODCPT) From CPTSUB
 Call LECPLAN([F:PYH]CPY,TYPLED,PLAN) From CPTDIV
 Call LEC_CAC(2, [L]CODCPT, PLAN) From CPTLEC
 CPT(TYPLED) = [F:CAC]ACC(2)
Next
End

########## Génération écritures + lettrage + Maj PAYMENTH,BPCUSTMVT  ###############

$TR2
GOK=1
Trbegin [UNP], [PAN], [PYH], [MVC], [BAN], [FRM]
 Readlock [PYH]PYH0=[F:UNP]NUM
 If fstat = 1
  GOK = -1 : GLOCK = "$PAYMENTH"-[F:UNP]NUM : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("PYH",[F:UNP]NUM) From GLOCK : Goto AB_TR2
 Endif
 BORTYP=[F:PYH]FRMFLG : BORNUM=[F:PYH]FRMNUM
 Raz LETACC
 Raz OD_TIERS
 For [UNP]UNP0
  Raz LACCNUM, LDUDLIG, LAMTIPT
  IDENT(1) = [F:UNP]NUM
  IDENT(2) = [F:UNP]CUR
  If [F:UNP]TYPVCR<>'O'

   GPOINT = "BEFGNRVCR" : Gosub ENTREE From EXEFNC
   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:PYH]UMRNUM<>""
    # X3-39795 MWA
    #TZONE(0)= "TYPDUD" : TVAL(0)= "2"
    TZONE(1)= "TYPDUD" : TVAL(1)= "2"
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
    TZONE(6)= "ORICOD" : TVAL(6)= [L]PCEAUTO                      #*X3-39795
    Call VALPCE3([L]PCEAUTO,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
   Else
    # X3-39795 MWA
    #Call VALPCE([L]PCEAUTO,IDENT,STAT,MESSA) From CPTAUTO
    Raz TZONE, TVAL
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading
    TZONE(6)= "ORICOD" : TVAL(6)= [L]PCEAUTO
    Call VALPCE3([L]PCEAUTO,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
   Endif

   If STAT
    # Règlement xxxxxxxxxx : MESSA
    Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-MESSA,1) From GESECRAN
    GOK = 0 : Break
   Else
    # Réglement xxxxxx : Création pièce TYP NUM
    Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
   Endif

   SVG_NBLIG = [M:HAEW]NB-1
   For NOL=0 To SVG_NBLIG
    SVG_LEDTYP(NOL) = [M:HAEW]LEDTYP(NOL)
    SVG_ACC(NOL)    = [M:HAEW]ACC(NOL)
    SVG_DEB(NOL)    = [M:HAEW]DEB(NOL)
    SVG_CDT(NOL)    = [M:HAEW]CDT(NOL)
    SVG_ACCNUM(NOL) = [M:HAEW]ACCNUM(NOL)
    SVG_AMTLED(NOL) = [M:HAEW]AMTLED(NOL)
   Next

   Case [F:UNP]TYPVCR

    When 'L','N'

     K=0
     For II=0 To SVG_NBLIG
      If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACC(GTYPGEN-1)=SVG_ACC(II)
       K=II+1 : Break
      Endif
     Next
     If K = 0
      # Règlement NUM : ACC non généré dans écran
      Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACC(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
      GOK = 0 : Break
     Endif
     PAN_ACCNUM = SVG_ACCNUM(K-1)
     Call LEC_GAC(SVG_ACC(K-1), GPLAN(1)) From CPTLEC
     If [F:GAC]MTC = 2 : # Compte lettrable
      LACCNUM(1) = SVG_ACCNUM(K-1) : # N°Ecriture de l'impayé (compte banque) générée
      LAMTIPT(1) = SVG_CDT(K-1)
      LDUDLIG(1) = 1
      I = 0
      While [F:UNP]ACCNUM(I)<>0
       LACCNUM(I+2) = [F:UNP]ACCNUM(I) : # N°Ecritures du réglement
       LAMTIPT(I+2) = [F:UNP]AMTACCNUM(I)
       LDUDLIG(I+2) = 1
       I+=1
       If I+2 > MAXPAY
        Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
        GOK = 0 : Break 2
       Endif
      Wend
      Call LETDIF2(I+1,LACCNUM,LDUDLIG,LAMTIPT,2) From CPTLET
      If GOK<1 : Break : Endif
     Endif

     # Si Raz TVA = Non et Client douteux= non  et DCLVATPAY=Non :
     #    - Délettre le couple "facture/règlement"
     #    - Lettre le couple "reglement/impayé"
     Call LEC_BAN([F:UNP]BAN) From CPTLEC
     Call PARAM([F:BAN]CPY,"DCLVATPAY",PARAM) From ADOVAL
     If val(PARAM)=1
      K = find([F:UNP]NUM,[M]NUM(0..[M]NBLIG-1))
      If [M]AMTVATDCL(K-1)=1 & [M]BPCTYP(K-1)=1
       Gosub DELETTRE
       Gosub OD_TIERS
       Gosub LETTRE
       If GOK<1 : Break : Endif
      Endif
     Endif

     #DdM38083 : Lettrage inter_devise
     # Pour un meme règlement, la table UNPAID contient soit une seule écriture (A) soit deux écritures (B) (hors frais)
     # Cas A : Pièce 512<=>411 Compte Banque       <=>     Compte Tiers         => TYPVCR="L"
     # Cas B : Pièce 512<=>473 Compte Banque       <=>     Compte Inter-Devise  => TYPVCR="N"
     #       : Pièce 473<=>411 Compte Inter-Devise <=>     Compte Tiers         => TYPVCR="M"

     K=0
     For II=0 To SVG_NBLIG
      If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACCBPR(GTYPGEN-1)=SVG_ACC(II)
       K=II+1 : Break
      Endif
     Next
     If K = 0
      # Règlement NUM : ACC non généré dans écran
      Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACCBPR(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
      GOK = 0 : Break
     Endif
     Call LEC_GAC(SVG_ACC(K-1), GPLAN(1)) From CPTLEC
     If [F:GAC]MTC = 2 : # Compte lettrable
      If LETACC<>0
       LACCNUM(1) = SVG_ACCNUM(K-1) : # N°Ecriture de l'impayé (compte inter_devise) générée
       LAMTIPT(1) = SVG_DEB(K-1)
       LDUDLIG(1) = 1
       LACCNUM(2) = [L]LETACC
       LAMTIPT(2) = LAMTIPT(1)
       LDUDLIG(2) = 1
       Call LETDIF2(2,LACCNUM,LDUDLIG,LAMTIPT,-1) From CPTLET
      Else
       If [F:UNP]TYPVCR="N" : LETACC = SVG_ACCNUM(K-1) : Endif
      Endif
     Endif

    When 'M'
     K=0
     For II=0 To SVG_NBLIG
      If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACCBPR(GTYPGEN-1)=SVG_ACC(II)
       K=II+1 : Break
      Endif
     Next
     If K = 0
      # Règlement NUM : ACC non généré dans écran
      Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACCBPR(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
      GOK = 0 : Break
     Endif
     PAN_ACCNUM = SVG_ACCNUM(K-1)
     Call LEC_BAN([F:UNP]BAN) From CPTLEC
     Call PARAM([F:BAN]CPY,"DCLVATPAY",PARAM) From ADOVAL
     If val(PARAM)=1
      K = find([F:UNP]NUM,[M]NUM(0..[M]NBLIG-1))
      If [M]AMTVATDCL(K-1)=1 & [M]BPCTYP(K-1)=1
       Gosub DELETTRE
       Gosub OD_TIERS
       Gosub LETTRE
       If GOK<1 : Break : Endif
      Endif
     Endif

     #DdM38083 : Lettrage inter_devise
     # Pour un meme règlement, la table UNPAID contient soit une seule écriture (A) soit deux écritures (B)
     # Cas A : Pièce 512<=>411 Compte Banque       <=>     Compte Tiers         => TYPVCR="L"
     # Cas B : Pièce 512<=>473 Compte Banque       <=>     Compte Inter-Devise  => TYPVCR="N"
     #       : Pièce 473<=>411 Compte Inter-Devise <=>     Compte Tiers         => TYPVCR="M"

     K=0
     For II=0 To SVG_NBLIG
      If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACC(GTYPGEN-1)=SVG_ACC(II)
       K=II+1 : Break
      Endif
     Next
     If K = 0
      # Règlement NUM : ACC non généré dans écran
      Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACC(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
      GOK = 0 : Break
     Endif
     Call LEC_GAC(SVG_ACC(K-1), GPLAN(1)) From CPTLEC
     If [F:GAC]MTC = 2 : # Compte lettrable
      If LETACC<>0
       LACCNUM(1) = SVG_ACCNUM(K-1) : # N°Ecriture de l'impayé (compte inter_devise) générée
       LAMTIPT(1) = SVG_DEB(K-1)
       LDUDLIG(1) = 1
       LACCNUM(2) = [L]LETACC
       LAMTIPT(2) = LAMTIPT(1)
       LDUDLIG(2) = 1
       Call LETDIF2(2,LACCNUM,LDUDLIG,LAMTIPT,-1) From CPTLET
      Else
       LETACC = SVG_ACCNUM(K-1)
      Endif
     Endif

   Endcase

   K = find([F:UNP]NUM,[M]NUM(0..[M]NBLIG-1))
   If [M]AMTVATDCL(K-1)=2
    ## si on décide de remettre en cause la TVA initialement déclarée
    ##               on lettre le compte de tiers de l'impayé avec le règlement initial
    ##               et la (ou les) facture(s) de manière à pouvoir déclarer en sens inverse
    ##               lors de la prochaine déclaration de TVA
    Case TYPVCR
     When "L", "M" : # Ecriture 4111 -> 512

      K=0
      For II=0 To SVG_NBLIG
       If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACCBPR(GTYPGEN-1)=SVG_ACC(II)
        K=II+1 : Break
       Endif
      Next
      If K = 0
       # Règlement NUM : ACC non généré dans écran
       Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACCBPR(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
       GOK = 0 : Break
      Endif
      LACCNUM(1) = SVG_ACCNUM(K-1) : # No écriture impayée générée (compte de tiers)
      LAMTIPT(1) = SVG_AMTLED(K-1)
      LDUDLIG(1) = 1
      I = 0
      Filter [PAN] Where TYPNUM=3 & NUM=[F:PYH]NUM & STA=3
      Read [PAN]PAN0 First
      If !fstat
       Read [DAE]DAE2 = [F:PAN]ACCNUM
       If fstat
        Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)
&                   -"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
       Elsif !fstat
        ## On est sur la ligne d'écriture du règlement imputé à l'impayé contenant le compte de banque
        For [DAE2]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=GTYPGEN & ACC=[F:UNP]ACCBPR(GTYPGEN-1) & BPR=[F:UNP]BPR
         LACCNUM(I+2) = [F:DAE2]ACCNUM
         LAMTIPT(I+2) = [F:DAE2]AMTLED
         LDUDLIG(I+2) = 1
         I+=1
         If I+2 > MAXPAY
          Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
          GOK = 0 : Break 2
         Endif
        Next
        For [PYD]PYD0 Where NUM=[F:UNP]NUM & DUDNUM<>0 & DUDLIG<>0 & BPRINV=[F:UNP]BPR & BPRSACINV=[F:UNP]ACCBPR(GTYPGEN-1)
         LACCNUM(I+2) = [F:PYD]DUDNUM
         LAMTIPT(I+2) = -[F:PYD]PAYLOCLIN
         LDUDLIG(I+2) = [F:PYD]DUDLIG
         I+=1
         If I+2 > MAXPAY
          Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
          GOK = 0 : Break 2
         Endif
        Next
        Call LETDIF2(I+1,LACCNUM,LDUDLIG,LAMTIPT,-1) From CPTLET
       Endif
      Endif
      Filter [PAN]
      Gosub OD_TIERS
    Endcase
   Endif
   [L]FLGSTA=1
   Gosub CRE_PAN
   If GOK<1 : Break : Endif
  Endif
  ## Gestion des impayés avec frais sur pièce séparée
  If(NBRPCE=2 & [F:UNP]AMTCRG<>0 & ([F:UNP]TYPVCR='L'|[F:UNP]TYPVCR='N') |[F:UNP]TYPVCR='O')

   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:PYH]UMRNUM<>""
    # X3-39795 MWA
    # TZONE(0)= "TYPDUD" : TVAL(0)= "2"
    TZONE(1)= "TYPDUD" : TVAL(1)= "2"
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
    TZONE(6)= "ORICOD" : TVAL(6)= [L]PCEFRAIS                     #*X3-39795
    Call VALPCE3([L]PCEFRAIS,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
   Else
    # X3-39795 MWA
    #Call VALPCE([L]PCEFRAIS,IDENT,STAT,MESSA) From CPTAUTO
    Raz TZONE, TVAL
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading
    TZONE(6)= "ORICOD" : TVAL(6)= [L]PCEAUTO
    Call VALPCE3([L]PCEFRAIS,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
   Endif

   If STAT
    # Règlement xxxxxxxxxx : MESSA
    Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-MESSA,1) From GESECRAN
    GOK = 0 : Break
   Else
    # Réglement xxxxxx : Création pièce TYP NUM
    Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
   Endif
   [L]FLGSTA=2
   K=0
   For II=0 To [M:HAEW]NB-1
    If [M:HAEW]LEDTYP(II)=GTYPGEN & [F:UNP]ACC(GTYPGEN-1)=[M:HAEW]ACC(II)
     K=II+1 : Break
    Endif
   Next
   PAN_ACCNUM = [M:HAEW]ACCNUM(K-1)
   Gosub CRE_PAN
   If GOK<1 : Break : Endif
  Endif

  If[F:UNP]FLGACT=2 & ([F:UNP]TYPVCR='N' |[F:UNP]TYPVCR='L')
   Gosub CREFAC From TRTCREFAC    :#Création note de débit Tiers
   If GOK<1 : Break : Endif
   # Création facture client
   Call ECR_TRACE(mess(59,123,1)-tolower(mess(43,109,1))-NUMFAC,0) From GESECRAN
  Endif

 Next : # [UNP]

 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub MAJ_MVC
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub MAJ_BAN
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub MAJ_PYH
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub MAJ_HMDT
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub MAJ_FRM
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 #94635 RICAR 2014/04/23 - CASH VAT - BEGIN
 Gosub MAJ_PYHV
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 #94635 RICAR 2014/04/23 - CASH VAT - END
 GPOINT = "BEFCOMMIT" : Gosub ENTREE From EXEFNC
Commit
NBIMP+=1

# Point d'entrée Italie pour flag échéances impayées (bug 14047)
GPOINT = "REGLEMENT" : Gosub ENTREE From EXEFNC
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$CRE_PAN
Raz [F:PAN]
[F:PAN]TYPNUM    = 3
[F:PAN]NUM       = [F:UNP]NUM
[F:PAN]STA       = 11
If [L]FLGSTA=1
 [F:PAN]ACCSTA    = 11
Else
 [F:PAN]ACCSTA    = 99
Endif
[F:PAN]TYPVCR    = [F:UNP]TYPVCR
[F:PAN]ACCNUM    = [L]PAN_ACCNUM
[F:PAN]RVSACCNUM = 0
[F:PAN]GRP       = [F:UNP]GRP
If [F:UNP]TYPVCR<>'M'
 [F:PAN]CPTBAN = 2
Else
 [F:PAN]CPTBAN = 1
Endif
Write [PAN]
If fstat
 GOK=0 : Call FSTA("PAN") From GLOCK : Return
Endif

# Règlement impayé sur bordereau
If BORNUM<>""
 Raz [F:PAN]
 [F:PAN]TYPNUM    = BORTYP
 [F:PAN]NUM       = BORNUM
 [F:PAN]STA       = 11
 [F:PAN]TYPVCR    = [F:UNP]TYPVCR
 [F:PAN]ACCNUM    = [L]PAN_ACCNUM
 [F:PAN]RVSACCNUM = 0
 [F:PAN]GRP       = [F:UNP]GRP
 [F:PAN]RENCOD    = "I"+[F:UNP]NUM : # Impayé
 [F:PAN]ACCSTA    = [F:UNP]ACCSTA
 If [F:UNP]TYPVCR<>'M'
  [F:PAN]CPTBAN    = 2
 Else
  [F:PAN]CPTBAN    = 1
 Endif
 Write [PAN]
 If fstat
  GOK=0 : Call FSTA("PAN") From GLOCK : Return
 Endif
Endif
Return

$MAJ_MVC
# Même s'il n'y a pas de dévaloration du portefeuille (pas de cumuls misent à jour).
#  l'appel s'effectue pour la mise à jour des documents (LASTCUSMVT)
Local Decimal WAMT
Local Char DEVLED(GLONCUR)
Raz WAMT
FLGDEVAL = 0
Raz WAMT

# Etape Mise en portefeuille & Pas d'étape Dévalorisation & Tiers client
If [F:PYH]STAFLG(2)=2 & [F:PYH]STAFLG(9)<>2 & [F:PYH]AMTNYTBIL<>0 &
&  [F:PYH]BPRTYP=1 & [F:PYH]SNS<>1  & [F:TPY]UPDBIL>1

 # Le champ AMTNYTBIL est en devise de référentiel
 Call SETCUR(1,[F:PYH]CPY,DEVLED) From CPTDIV
 Call GETDEV([F:PYH]FCY) From DEVSUB
 Call COURMNT(DEVLED,[F:PYH]CUR,DEVLED,0,[F:PYH]ACCDAT,1,[F:PYH]AMTNYTBIL,WAMT,0,STAT) From TRTDEV
 If STAT
  # Pas de cours
  Call ECR_TRACE(mess(4,109,1)-DEVLED-"=>"-[F:PYH]CUR,1) From GESECRAN
 Else
  FLGDEVAL = 1
 Endif
Endif

Call MAJMVC([F:PYH]BPR,[F:PYH]CUR,0,0,[F:UNP]ACCDAT,[F:UNP]NUM,[F:PYH]FCY,WAMT,[F:PYH]AMTCUR,"-","M","C",[F:TPY]UPDBIL) From TRTBPMVT
Return


$MAJ_BAN
If [F:PYH]BANPAYTPY<>0 & [F:PYH]STAFLG(8)<>2
 Readlock [BAN]BAN0=[F:PYH]BAN
 If fstat = 1
  GOK = -1 : GLOCK = "$BANK"-[F:PYH]BAN : Return
 Elsif fstat
  GOK = 0 : Call RSTA("BAN",[F:PYH]BAN) From GLOCK : Return
 Endif
 [F:BAN]PAYTPY -= [F:PYH]BANPAYTPY
 Rewrite [BAN]
 If fstat
  GOK = 0 : Call FSTA("BAN") From GLOCK : Return
 Endif
Endif
Return

$MAJ_PYH
#Maj fichier PAYMENTH
[F:PYH]RENNOTPAY  = [F:UNP]RENNOTPAY
[F:PYH]STA        = 11 : # Dernière étape = impayé
[F:PYH]STAFLG(10) = 2  : # Etape impayé à Oui
[F:PYH]PST        = 3
# Etape de dévalorisation a eu lieu
If FLGDEVAL = 1
 [F:PYH]STAFLG(9)=2
Endif
#Pas de Maj AMTNYTBIL dans PAYMENTH car on a pas à valoriser le portefeuille dans impayé
#On le valorise lors de la mise en portefeuille
If BORNUM<>""
 [F:PYH]FRMFLG = 0
 [F:PYH]FRMNUM = ""
 [F:PYH]FRMLIN = 0
 [F:PYH]FRMREF = ""
Endif
#94635 RICAR 2014/04/23 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[F:PYH]CPY) = "2"
  If [F:PYH]CSHVATRGM = 2
    [F:PYH]UPDDAT = date$
    [F:PYH]VATSTA = 1
    [F:PYH]COMDAT = [0/0/0]
  Endif
Endif
#94635 RICAR 2014/04/23 - CASH VAT - END
Rewrite [PYH]
If fstat
 GOK = 0 : Call FSTA("PYH") From GLOCK : Return
Endif
Return

$MAJ_FRM
If BORNUM="" : Return : Endif
#Maj fichier PAYFRM
Read [PYH]PYH1(2) = BORTYP;BORNUM
If fstat>2
 Delete [FRM]FRM0 = BORTYP;BORNUM
 If fstat = 1
  GOK = -1 : GLOCK = "$PAYFRM"-num$(BORTYP)-BORNUM : Return
 Elsif fstat>5
  GOK = 0 : Call RSTA("FRM",num$(BORTYP)-BORNUM) From GLOCK : Return
 Endif
Endif
Return

$MAJ_HMDT
If [F:PYH]UMRNUM="" : Return : Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 and [F:PYH]STAFLG(5)=2
 Update [HMDT] Where PAYNUM=[F:PYH]NUM With DPT=3, FRMNUM=""
 If fstat = 1
  GOK = -1 : GLOCK = "$HISTOMDT"-[F:PYH]NUM : Return
 Elsif fstat
  GOK = 0 : Call RSTA("HMDT", [F:PYH]NUM) From GLOCK : Return
 Endif

 Update [MDT] Where CPY=[F:PYH]CPY and UMRNUM=[F:PYH]UMRNUM With TOTSDDPAY -= [F:PYH]AMTCUR
 If fstat = 1
  GOK = -1 : GLOCK = "$MANDATE"-[F:PYH]CPY-[F:PYH]UMRNUM : Return
 Elsif fstat
  GOK = 0 : Call RSTA("MDT", [F:PYH]CPY-[F:PYH]UMRNUM) From GLOCK : Return
 Endif

 Local Char UMRNUM(GLONMDT)
 Call INIT_UMRNUM([F:PYH]CPY, [F:PYH]BPR, 2, 2, [L]UMRNUM) From INVSDDLIB
 If [L]UMRNUM="" : Call ECR_TRACE(mess(270,117,1), -1) From GESECRAN : Endif
Endif
Return

$MAJ_PYHV
#94635 RICAR 2014/04/23 - CASH VAT - BEGIN
Local Integer STA : [L]STA=0
If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[F:PYH]CPY) = "2"
  If [F:PYH]CSHVATRGM=2
    Call UPD_PYHV([F:PYH]NUM,2,[L]STA) From SUBPAY3
    If [L]STA <> 1 : GOK = 0 : Endif
  Endif
Endif
#94635 RICAR 2014/04/23 - CASH VAT - END
Return

#Delettrage sur compte tiers de la facture et du règlement
$DELETTRE
Local Char REFLIG(GLONGTE+GLONVCR+1)
REFLIG="PYH"-[F:PYH]NUM
GTRANS=1
For [DAE] Where REFINTLIN=[L]REFLIG & LEDTYP=GTYPGEN & ACC=[F:UNP]ACCBPR(GTYPGEN-1) & BPR=[F:UNP]BPR & MTC<>""
 Gosub RELETTRE1
 If GOK<1 : Break : Endif
 Call DELETTRE ([F:DAE]CPY,[F:DAE]FCYLIN,[F:DAE]LEDTYP,[F:DAE]ACC,[F:DAE]BPR,[F:DAE]MTC) From DELETTRAGE
 Gosub RELETTRE2
Next
GTRANS=0
Return

#Re-lettrage
$RELETTRE1
Raz LACCNUM, LDUDLIG, LAMTIPT
I=1
For [DAE2]DAE1 Where CPY=[F:DAE]CPY & FCYLIN=[F:DAE]FCYLIN & LEDTYP=GTYPGEN & ACC=[F:DAE]ACC & BPR=[F:DAE]BPR & MTC=[F:DAE]MTC
 If [F:DAE2]REFINTLIN<>[L]REFLIG
  Filter [DUD]
  For [DUD] Where ACCNUM=[F:DAE2]ACCNUM
   Filter [PYD] Where NUM=[F:UNP]NUM & DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
   Read [PYD]PYD0 First
   Filter [PYD]
   If fstat
    LACCNUM(I) = [F:DAE2]ACCNUM
    LAMTIPT(I) = [F:DUD]PAYLOC
    LDUDLIG(I) = [F:DUD]DUDLIG
    I+=1
    If I+2 > MAXPAY
     # dim() : Valeur trop petite
     Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
     GOK = 0 : Break 2
    Endif
   Endif
  Next
  If I=1
   LACCNUM(I) = [F:DAE2]ACCNUM
   LAMTIPT(I) = [F:DAE2]AMTLED
   LDUDLIG(I) = 1
   I+=1
   If I+2 > MAXPAY
    # dim() : Valeur trop petite
    Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Endif
 Endif
Next
Return

#Re-lettrage (DdM38368)
$RELETTRE2
If I>2
 Call LETDIF2(I-1,LACCNUM,LDUDLIG,LAMTIPT,-1) From CPTLET
Endif
Return

#Lettrage sur compte tiers de l'impayé et du règlement
$LETTRE
Local Char REFLIG(GLONGTE+GLONVCR+1)
REFLIG="PYH"-[F:PYH]NUM
K=0
For II=0 To SVG_NBLIG
 If SVG_LEDTYP(II)=GTYPGEN & [F:UNP]ACCBPR(GTYPGEN-1)=SVG_ACC(II)
  K=II+1 : Break
 Endif
Next
If K = 0
 # Règlement NUM : ACC non généré dans écran
 Call ECR_TRACE(mess(27,117,1)-[F:UNP]NUM-":"-[F:UNP]ACCBPR(GTYPGEN-1)-mess(8,121,1),1) From GESECRAN
 GOK = 0 : Return
Endif
LACCNUM(1) = SVG_ACCNUM(K-1) : # N°Ecriture de l'impayé (compte client) générée
LAMTIPT(1) = SVG_CDT(K-1)
If OD_TIERS=1 & LAMTIPT(1)=0
 LAMTIPT(1) = SVG_DEB(K-1)
Endif
LDUDLIG(1) = 1
I = 0
For [DAE2]DAE0 Where REFINTLIN=[L]REFLIG & LEDTYP=GTYPGEN & ACC=[F:UNP]ACCBPR(GTYPGEN-1) & BPR=[F:UNP]BPR
 LACCNUM(I+2) = [F:DAE2]ACCNUM
 LAMTIPT(I+2) = [F:DAE2]AMTLED
 LDUDLIG(I+2) = 1
 I+=1
 If I+2 > MAXPAY
  # dim() : Valeur trop petite
  Call ECR_TRACE("dim([M:PAY3]VCRNUM):"-mess(8,135,1),1) From GESECRAN
  GOK = 0 : Break
 Endif
Next
If GOK=0 : Return : Endif
If I>0 #DdM38083
 Call LETDIF2(I+1,LACCNUM,LDUDLIG,LAMTIPT,-1) From CPTLET
Endif
Return

$OD_TIERS
If rowcount([F:PAN])>1
 Filter [PAN] Where TYPNUM=3 & NUM=[F:PYH]NUM & STA=3 & TYPVCR="D"
 For [PAN]
  Read [DAE]DAE2 = [F:PAN]ACCNUM
  If fstat
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)
&            -"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
  Elsif !fstat
   ## On est sur la ligne d'OD-Tiers contenant le tiers payeur, on parcours le tiers facturé pour le délettrer
   For [DAE2]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=GTYPGEN & ACCNUM<>[F:DAE]ACCNUM & MTC<>""
    Call DELETTRE ([F:DAE2]CPY,[F:DAE2]FCYLIN,[F:DAE2]LEDTYP,[F:DAE2]ACC,[F:DAE2]BPR,[F:DAE2]MTC) From DELETTRAGE
    OD_TIERS=1
   Next
  Endif
 Next
 Filter [PAN]
Endif
Return

$FIN
Return

##################################
## Etiquettes de l'écran IMPAYE ##
##################################

Subprog D_BAN(VALEUR)
Variable Char    VALEUR()
Call BANDEF(VALEUR) From SUBCHK
End

Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Local Char    MODELE(GLONGCM)
Local Integer OK
If !clalev([F:BAN]) : Local File BANK    [BAN] : Endif
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Call ACCES_POINTAGE(OK,VALEUR) From SUBCHK
If !OK
 GMESSAGE=mess(25,120,1)-VALEUR : # Vous n'avez pas accés à la banque
 mkstat = 2 : End
Endif
If VALEUR<>[M]BAN or [M]NBLIG=0
 Call LEC_BAN(VALEUR) From CPTLEC
 [M:IPY0]CPY    = [F:BAN]CPY
 [M:IPY0]CUR    = [F:BAN]CUR
 [M:IPY0]BANACC = [F:BAN]BANACC
 Affzo [IPY0]CUR
 Call LEC_CPY([M]CPY) From CPTLEC
 GCURLEG=[F:CPY]LEG
 GSOCIETE=[M]CPY
 If GCURFCY=""
  I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
  GCURFCY = GSITE(I)
 Endif
 Call SETGCM([M]CPY,MODELE) From CPTDIV
 Call SETPLAN2(MODELE,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
 [M]COA = GPLAN(1)
 For AXE=1 To GNBAXE
  [M]DIE(AXE-1) = GAXE(AXE)
 Next
 GNBTYPLED = GNBPLAN
 Call AFFCOL From SUBPAY3
Endif
End

Subprog D_DESVCR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = mess(7,121,1)-[M:IPY0]BAN-mess(40,101,1)-format$("D:"+GFMDAT,[M:IPY0]ACCDAT)
 # Impayés BANQUE du ..-..-..
Endif
End

Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
Call LEC_PYH(VALEUR) From CPTLEC
If fstat
 GMESSAGE = mess(137,117,1) : # Règlement inexistant
 mkstat = 2
 End
Elsif find(VALEUR,[M:IPY0]NUM(0..indice-1),"$$$$$$$$$$$",[M:IPY0]NUM(indice+1..[M:IPY0]NBLIG-1))
 GMESSAGE = mess(107,117,1) : #Numéro de règlement déjà saisi
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(10) = 2
 GMESSAGE = mess(125,117,1) : # Règlement déjà impayé
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(7)<>2 & [F:PYH]STAFLG(8)<>2
 #Impayé impossible : Réglement ni remis sur compte, ni remis en banque
 GMESSAGE = mess(139,117,1)
 mkstat = 2
 End
Elsif [F:PYH]BAN<>[M:IPY0]BAN and [F:PYH]BAN<>""
 GMESSAGE = mess(117,117,1)-":"-[F:PYH]BAN : # Banque affectée au règlement
 mkstat = 2
 End
Else
 Local Libelle TYPGEN,TYPANA
 Call SETMAINREF([F:PYH]FCY,TYPGEN,TYPANA) From CPTDIV
 Call CONTPER([M:IPY0]ACCDAT,TYPGEN,[F:PYH]FCY) From CPTSUB
 If [F:PYH]BPRTYP<>1
  GMESSAGE = mess(67,117,1) : # Ce n'est pas un client
  mkstat = 2
  End
 Endif
 Call LEC_CPY([F:PYH]CPY) From CPTLEC
 Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
 If [F:TPY]ENAFLG<>2
  Gosub TIT From WOTPY
  GMESSAGE = TIT-"\"+[F:PYH]PAYTYP-":"-mess(2,126,1) : # Fiche inactive
  mkstat=2
  End
 Elsif dim([F:TPY]ACS)>0
  Call CONTEXE([F:TPY]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 #Issue X3-75462 by MRDAB
 If (func AFNC.ACTIV("FIFRC"))
  If (func AFNC.PARAM("FIFRC", [F:PYH]FCY) = "2")
    If func FIFOCONVAR_CSTD.FLDFIFCP_CTL([F:PYH]BAN, [F:PYH]ACCDAT)
     If func FIFOCONVAR_CSTD.IS_FIFO_EXIST([F:PYH]BAN,[F:PYH]ACCDAT) = 1
      GMESSAGE = mess(27,117,1)-[F:PYH]NUM-":"-mess(29,7708,1)
      mkstat=2 : End
     Endif
    Endif
  Endif
 Endif
 #Issue end
Endif
## <Bug 45813> Suite du bug 45813 : On contrôle qu'il n'y a pas plusieurs échéances associées à des sites
## différents.
If !clalev([F:PYD2]) : Local File PAYMENTD   [PYD2] : Endif
Local Char SITE(GLONFCY)
Filter [PYD2] Where NUM = VALEUR & DUDNUM<>0 & DUDLIG<>0
Read [PYD2]PYD0 First
Filter [PYD2]
If !fstat
 SITE = [F:PYD2]FCYLIN
Endif
Filter [PYD2] Where NUM = VALEUR & DUDNUM<>0 & DUDLIG<>0 & FCYLIN<>[L]SITE
Read [PYD2]PYD0 First
Filter [PYD2]
If !fstat
 ## Plusieurs échéances associées à des sites différents : traitement d'impayé impossible
 GMESSAGE = mess(223,117,1)
 mkstat = 2 : End
Endif
## <Fin Bug 45813>
[M:IPY0]FCY(nolign-1) = [F:PYH]FCY
Call GETSOC([F:PYH]FCY) From DEVSUB
End

########
$DSELPAY
########
[L]MEMO="" : # Pas de mémo

## Préchargement du tableau de sélection avancée
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

NBSEL = 0 : NBTRI = 0

# Type de règlement
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]PAYTYP" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]PAYTYP"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Tiers
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]BPR" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]BPR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Banque
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]BAN" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]BAN"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Site
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]FCY" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Devise
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]CUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]CUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Montant
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]AMTCUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "Nf:15F"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]AMTCUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Date d'échéance
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]DUDDAT" : Gosub TEX_PAY
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "Df:"+GFMDAT
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]DUDDAT"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Référence
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]REF" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]REF"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Lot de saisie
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]PAYLOT" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]PAYLOT"
TRILIB(NBTRI) = SELLIB(NBSEL)

If dim([L]SELEXP)>0 : Raz [L]SELEXP : Endif

## Filtre supplémentaire obligatoire sur le fichier PAYMENTH

Local Char FILTPYH(255)
[L]FILTPYH = "BPRTYP=1 & (BAN='"+[M:IPY0]BAN+"' | BAN='')"
[L]FILTPYH -= "& STAFLG(10)<>2 & find(2,STAFLG(7..8))"
Filter [PYH] Where evalue([L]FILTPYH)
Return

$TEX_PAY
J=instr(1,SELZON(NBSEL),"]")
If !J : SELLIB(NBSEL)=SELZON(NBSEL) : Else SELLIB(NBSEL)=right$(SELZON(NBSEL),J+1) : Endif
For I=0 To 2
 Read [AMZ]CODE="PAY"+num$(I);SELLIB(NBSEL)
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,SELLIB(NBSEL)) From OBJDIV
  Break
 Endif
Next I
Return

########
$FSELPAY
########
Filter [PYH]
Return

Subprog D_DES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M:IPY0]DESVCR
Endif
End

# Si la société ne gère pas la TVA s/encaissement, il est inutile de remettre en cause la TVA initialement déclarée.
# On force donc la zone "RAZ TVA" à "Non".
Subprog AS_AMTVATDCL(VALEUR)
Variable Integer VALEUR
Local Char PARAM (1)
Call LEC_BAN([M:IPY0]BAN) From CPTLEC
Call PARAM([F:BAN]CPY,"DCLVATPAY",PARAM) From ADOVAL
If val(PARAM)=1
 VALEUR=1 : mkstat=2 : End
Endif
End

Subprog AS_BPCTYP(VALEUR)
Variable Integer VALEUR
If [M]AMTVATDCL(nolign-1) = 2
 # On remet en cause la TVA initialement déclarée. On force donc la zone
 # 'Douteux' à 'Non' pour que l'écriture d'impayé soit comptabilisée
 # au débit du compte client
 VALEUR = 1
 mkstat = 2 : End
Endif
End

Subprog AS_AMTCRG(VALEUR)
Variable Decimal VALEUR
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif
Call LEC_PYH([M:IPY0]NUM(nolign-1)) From CPTLEC
If [F:PYH]STAFLG(8)<>2 : # Si pas d'étape de remise en banque, pas de saisie de frais
 mkstat = 1
Endif
End

Subprog AS_TAX(VALEUR)
Variable Char    VALEUR()
If [M:IPY0]AMTCRG(nolign-1)=0
 mkstat = 1
Endif
End

Subprog C_TAX(VALEUR)
Variable Char    VALEUR()
Local Decimal MT, MTVAT
Local Integer TY, ST
If VALEUR="" & [M:IPY0]AMTCRG(nolign-1)<>0
 GMESSAGE = mess(138,117,1) : #Code TVA obligatoire
 mkstat = 2
 End
Endif
Call CALTAXE([M:IPY0]CPY,date$,"",[M:IPY0]CUR,1,VALEUR,1,[M:IPY0]AMTCRG(nolign-1),
&            MTVAT,MT,TY,ST) From SUBTVT
[M:IPY0]AMTVAT(nolign-1) = MTVAT
Affzo [M:IPY0]AMTVAT(nolign-1)
End

Subprog AS_AMTVAT(VALEUR)
Variable Decimal VALEUR
If [M:IPY0]AMTCRG(nolign-1)=0
 mkstat = 1
Endif
End

Subprog AS_IPTBPR(VALEUR)
Variable Integer VALEUR
If [M:IPY0]AMTCRG(nolign-1)=0
 mkstat = 1
Endif
End

Subprog C_IPTBPR(VALEUR)
Variable Integer VALEUR
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif
If !clalev([F:GAU]) : Local File GAUTACE  [GAU] : Endif
If !clalev([F:GAD]) : Local File GAUTACED [GAD] : Endif
If !clalev([F:GAG]) : Local File GAUTACEF [GAG] : Endif
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1)))
Local Char    TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    ID1(30)(1..10), ID2(30)(1..10), PCEAUTO(10)
Local Char    MESSA(100)
Local Integer STAT, I, ILED
Gosub SETNOL
Call PARAM("","GAUUNPAI",[L]PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="UNPAI" : Endif
Read [GAU]GAU0=[L]PCEAUTO
If fstat=0 : End : Endif
Local File =[F:GAU]TBL [TB0]
[F:TB0]BAN    = [M:IPY0]BAN
[F:TB0]CUR    = [M:IPY0]CUR
[F:TB0]ACC    = [M:IPY0]BANACC
[F:TB0]ACCDAT = [M:IPY0]ACCDAT
[F:TB0]DUDDAT = [M:IPY0]DUDDAT
[F:TB0]NUM    = [M:IPY0]NUM(NOL)
[F:TB0]IPT    = VALEUR
[F:TB0]AMTCRG = [M:IPY0]AMTCRG(NOL)
Filter [GAG] Where COD=[L]PCEAUTO & FLD="AMT" & instr(1,FORCLC,"AMTCRG")
Read [GAG] First
Filter [GAG]
Read [GAD]GAD0 = [L]PCEAUTO;[F:GAG]LINNUM
Raz GNBTYPLED, GTYPLED
For ILED=1 To [F:GAD]NBRLED
 GNBTYPLED+= 1
 GTYPLED(GNBTYPLED) = [F:GAD]LEDTYP(ILED-1)
Next
Call SETPLANAXE([M:IPY0]CPY,GNBTYPLED,GTYPLED,GNBPLAN,GPLAN,GNBAXE,GAXE,GOBLIG) From CPTDIV
Call COMPTE([L]PCEAUTO,[F:GAG]LINNUM,ID1,ID2,TPLAN,TCOMPTE,STAT,MESSA) From CPTCOD
For ILED=1 To GNBTYPLED
 [M:IPY0]COA(ILED-1) = TPLAN(ILED)
 Assign "[M:IPY0]ACC"+num$(ILED)+"("+num$(NOL)+")" With TCOMPTE(ILED)
Next
For I=1 To GNBAXE
 [F:TB0]DIE(I-1) = evalue("[M:IPY0]DIE("+num$(I-1)+")")
 [F:TB0]CCE(I-1) = evalue("[M:IPY0]CCE"+num$(I)+"("+num$(NOL)+")")
Next I
End

