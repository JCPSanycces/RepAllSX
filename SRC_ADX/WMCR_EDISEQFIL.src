#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential file
# Supervisor
## CRUD-CLASSE ## EDISEQFIL
# 2018-11-06 07:05:06 459


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EDISEQFIL [ESF_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EDISEQFIL") From ASYRCOM : Endif
Local Instance EDISEQFIL Using C_EDISEQFIL

If !SILENCE : Call TRACE("3 --> New Instance C_EDISEQFIL") From ASYRCOM : Endif
EDISEQFIL = NewInstance C_EDISEQFIL AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [ESF_]ESF0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EDISEQFIL") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.AREAD([ESF_]MSGCOD,[ESF_]MSGREL,[ESF_]MSGFILNOR))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EDISEQFIL.MSGCOD ="-num$(EDISEQFIL.MSGCOD)) From ASYRCOM
 Call TRACE("EDISEQFIL.MSGREL ="-num$(EDISEQFIL.MSGREL)) From ASYRCOM
 Call TRACE("EDISEQFIL.MSGFILNOR ="-num$(EDISEQFIL.MSGFILNOR)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EDISEQFIL.AKEYS)
  Call TRACE("-"-num$(I)-":"-EDISEQFIL.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [ESF_]
FreeGroup EDISEQFIL
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EDISEQFIL,ACLE,ASTATUS,_ETAG)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _MSGCOD(20)
Local Char _MSGREL(5)
Local Char _MSGFILNOR(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_MSGCOD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_MSGREL = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_MSGFILNOR = num$([L]CLE(3)) : Endif
Raz [L]_ETAG
Local File EDISEQFIL [ESF]
Default File [F:ESF]
Read [F:ESF]ESF0 = [L]_MSGCOD;[L]_MSGREL;[L]_MSGFILNOR
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:ESF]UPDTICK)>0
 [L]_ETAG = num$([F:ESF]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EDISEQFIL,ACLE,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Value Char ACLE
Variable Integer ASTATUS
Local Char _MSGCOD(20)
Local Char _MSGREL(5)
Local Char _MSGFILNOR(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_MSGCOD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_MSGREL = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_MSGFILNOR = num$([L]CLE(3)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.AREAD([L]_MSGCOD,[L]_MSGREL,[L]_MSGFILNOR))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EDISEQFIL,_MSGCOD,_MSGREL,_MSGFILNOR,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Value Char _MSGCOD
Value Char _MSGREL
Value Char _MSGFILNOR
Variable Integer ASTATUS

If EDISEQFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDISEQFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EDISEQFIL.APARENT=null
 [L]A_I = EDISEQFIL.freeSnapshot
 EDISEQFIL.snapshotEnabled = 0
 EDISEQFIL.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EDISEQFIL.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EDISEQFIL.APARENT=null
 EDISEQFIL.snapshotEnabled = 1
 EDISEQFIL.setAccessorEnabled = 1
Endif
LogicClose File [ESF] ,[ESFD] ,[ESFF]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL._ACTION_PARAM("AREAD_BEFORE",[L]_MSGCOD,[L]_MSGREL,[L]_MSGFILNOR))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:ESF]
Read [F:ESF]ESF0 = [L]_MSGCOD;[L]_MSGREL;[L]_MSGFILNOR
If fstat
[L]A_ERROR = [L]_MSGCOD+"~"+[L]_MSGREL+"~"+[L]_MSGFILNOR
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EDISEQFIL,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:ESF]AUUID)>0 & [F:ESF]AUUID=NullUuid
 [F:ESF]AUUID = getUuid
Endif
SetInstance EDISEQFIL With [F:ESF]
EDISEQFIL.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:ESFD]
 [L]A_N2=0
 For [F:ESFD]ESFD1 Where MSGCOD=[F:ESF]MSGCOD & MSGREL=[F:ESF]MSGREL & MSGFILNOR=[F:ESF]MSGFILNOR
  [L]A_N2 +=1
  EDISEQFIL.ESFD(A_N2) = NewInstance  C_EDISEQFILD(EDISEQFIL.ACTX,NullUuid,[L]A_N2,EDISEQFIL,"ESFD") AllocGroup EDISEQFIL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ADDINSTANCE_BOUND)
  If dim([F:ESFD]AUUID)>0 & [F:ESFD]AUUID=NullUuid
   [F:ESFD]AUUID = getUuid
  Endif
  SetInstance EDISEQFIL.ESFD(A_N2) With [F:ESFD]
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ASETATTRIBUTE("MSGREL","$namProParent","MSGREL"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR"))
 Next ESFD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:ESFF]
 [L]A_N2=0
 For [F:ESFF]ESFF1 Where MSGCOD=[F:ESF]MSGCOD & MSGREL=[F:ESF]MSGREL & MSGFILNOR=[F:ESF]MSGFILNOR
  [L]A_N2 +=1
  EDISEQFIL.ESFF(A_N2) = NewInstance  C_EDISEQFILF(EDISEQFIL.ACTX,NullUuid,[L]A_N2,EDISEQFIL,"ESFF") AllocGroup EDISEQFIL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ADDINSTANCE_BOUND)
  If dim([F:ESFF]AUUID)>0 & [F:ESFF]AUUID=NullUuid
   [F:ESFF]AUUID = getUuid
  Endif
  SetInstance EDISEQFIL.ESFF(A_N2) With [F:ESFF]
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ASETATTRIBUTE("MSGREL","$namProParent","MSGREL"))
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR"))
 Next ESFF
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]A_NEWCOL = 0
For [L]A_I=1 To 20
 If ([F:ESF]COMTYP([L]A_I-1)<>0 or [F:ESF]COMVAL([L]A_I-1)<>"")
  [L]A_NEWCOL += 1
  EDISEQFIL.ESFN(A_NEWCOL) = NewInstance  C_EDISEQFIL_ESFN(EDISEQFIL.ACTX,NullUuid,[L]A_I,EDISEQFIL,"ESFN") AllocGroup EDISEQFIL
  EDISEQFIL.ESFN(A_NEWCOL).COMTYP = [F:ESF]COMTYP([L]A_I-1)
  EDISEQFIL.ESFN(A_NEWCOL).COMVAL = [F:ESF]COMVAL([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFN(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



