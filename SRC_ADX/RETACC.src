#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"RETACC"
 GFONCTION="RETACC" : Call AUTORIS From EXEFNC
Endif
GACTION = "RETACC"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"FRETACC","RETACC","DRETACC",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return


#####
$INIT
#####
Onerrgo CHUT From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY]    : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM]    : Endif
If clalev([F:LED])=0 : Local File GLED       [LED]    : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]    : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY]    : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC]    : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR]    : Endif
If clalev([F:GCU])=0 : Local File GRPCUR     [GCU]    : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU]    : Endif
If clalev([F:PYL])=0 : Local File PAYLOT     [PYL]    : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM]    : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC]    : Endif
If clalev([F:TPY2])=0: Local File TABPAYTYP  [TPY2]   : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
Local Integer STAT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return


######
$DEBUT
######
Onerrgo ERREUR From CONTROLE
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY]    : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU]    : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY]    : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC]    : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY]    : Endif
If clalev([F:GCU])=0 : Local File GRPCUR     [GCU]    : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR]    : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH]    : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI]    : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC]    : Endif
If clalev([F:TPY2])=0: Local File TABPAYTYP  [TPY2]   : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Integer OK , STAT , PLEIN , MAXLIG
Local Decimal MONTANT
Local Char    CRITERE(250), CRITSPE(250)

MAXLIG = dim([M:RTC]BPR)

# Constitution du critère de sélection
CRITERE = "STAFLG(1)=0 & STA<2"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLSAC<>2
 CRITERE -= '& BPRSAC="'+[M:DIA]SAC+'"'
Endif
If [M:DIA]ALLBPR<>2
 CRITERE -= '& BPR="'+[M:DIA]BPR+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITERE -= '& PAYTYP="'+[M:DIA]TYP+'"'
Endif
If [M:DIA]ALLLOT<>2
 CRITERE -= '& PAYLOT="'+[M:DIA]LOT+'"'
Endif
If [M:DIA]ALLCUR<>2
 If [M:DIA]CUR<>""
  CRITERE -= '& CUR="'+[M:DIA]CUR+'"'
 Elsif [M:DIA]GRPCUR<>""
  Call LECTURE("GCU",[M:DIA]GRPCUR,"") From CONTOBJ
 Endif
Endif

If [M:DIA]DUDDAT<>[0/0/0]
 CRITERE -= '& DUDDAT<=['+format$(GFMD,[M:DIA]DUDDAT)+']'
Endif

#################### Point d'entrée FILTRE ####################
Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE="1=1" : Endif

# Chargement du tableau
Call TEMPON("L") From GESECRAN
[F:TCY]BIDFMT="30X"
[F:TCU]CURFMT1="11.2#"
Raz [M:RTC]
nolign = 0
PLEIN = 0
If [M:DIA]ALLTYP=2
 Filter [TPY2] Where (LEG=GCURLEG | LEG="") Order By Key CLE = PAYTYP Asc; LEG Desc
 For [TPY2]CLE(1)
  If [F:TPY2]ENAFLG=2 & [F:TPY2]STA2=2
   Call CONTEXE([F:TPY2]ACS) From CPTSUB
   If !mkstat : OK=1 : Else mkstat=0 : OK=0 : GMESSAGE="" : Endif
  Else
   OK=0
  Endif
  If OK
   Filter [PYH] Where PAYTYP=[F:TPY2]PAYTYP & evalue(CRITERE) & evalue(CRITSPE)
   If [F:TPY]PAYTYP<>[F:TPY2]PAYTYP | [F:TPY]LEG<>[F:TPY2]LEG
    Read [TPY]TPY0 = [F:TPY2]PAYTYP;[F:TPY2]LEG
   Endif
   Gosub CHARGE
   If PLEIN : Break : Endif
   Filter [PYH]
  Endif
 Next
 Filter [TPY2]
Else
 Call LEC_TPY_LEG(GCURLEG,[M:DIA]TYP) From CPTLEC
 If fstat=0
  Gosub ACCES
  If OK
   Filter [PYH] Where evalue(CRITERE) & evalue(CRITSPE)
   Gosub CHARGE
  Endif
 Endif
Endif
Filter [PYH]
[M:RTC]NBLIG = nolign
Affzo [RTC]
Call TEMPOFF From GESECRAN

If [M:RTC]NBLIG=0
 GERR=2 : GMESSAGE=mess(99,100,1) : # Pas de fiche sélectionnée
Elsif PLEIN
 GERR=2 : GMESSAGE=mess(26,100,1) : # Tableau plein
Endif
Return


$ACCES
If [M:DIA]TYP<>""      : OK=1
Elsif [F:TPY]ENAFLG<>2 : OK=0
Elsif [F:TPY]STA2<>2   : OK=0
Else Call CONTEXE([F:TPY]ACS) From CPTSUB
     If !mkstat : OK=1 : Else mkstat=0 : OK=0 : GMESSAGE="" : Endif
Endif
Return

$CHARGE
For [PYH]PYH0
 OK = 1

 If [M:DIA]GRPCUR<>""
  If !find([F:PYH]CUR,[F:GCU]CUR(0..[F:GCU]NBRCUR-1))
   OK = 0
  Endif
 Endif

 # If all cpy then only take PYH where the LEG of CPY = screen LEG
 If [M:DIA]ALLCPY=2
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  If [F:CPY]LEG <> GCURLEG : OK=0 : Endif
 Endif

 If OK & [M:DIA]MAXAMT<>0
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  Call CONVERT([F:PYH]CUR,GCURSHR,[F:CPY]ACCCUR,[F:TPY]RATTYP,datesyst
&  ,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
  If STAT=0 & MONTANT>[M:DIA]MAXAMT
   OK = 0
  Endif
 Endif

 If OK
  If nolign>=MAXLIG
   PLEIN = 1 : Break
  Else
   nolign += 1
   [M:RTC] = [F:PYH]
   If [F:PYH]BPR<>""
    Call LEC_BPR([F:PYH]BPR) From CPTLEC
    [M:RTC]BPRNAM(nolign-1) = [F:BPR]BPRNAM
   Elsif [F:PYH]ACC<>""
    Call LECTEXTRA([M:RTC]BPRNAM(nolign-1),"GACCOUNT","DESTRA",[F:PYH]COA,[F:PYH]ACC) From ATEXTRA
   Endif
   Call LEC_TAM(GCURLEG,[F:PYH]PAM) From CPTLEC
   If !fstat : [M:RTC]ACCEPT(nolign-1) = [F:TAM]ACCEPT : Endif
  Endif
 Endif
Next : # [PYH]
Return

########
$SETBOUT
########
If REP="" : REP="M" : ETABOU(GENRE) = 1 : STADEF = GSTAENR : Endif
Return

####
$ENR
####
If [M:RTC]NBLIG
 Call TEMPON("V") From GESECRAN
 Call DEBTRANS From GLOCK
 Gosub TR1
 Call TEMPOFF From GESECRAN
Endif
FIN=1
Return

$TR1
GOK = 1
Trbegin [PYH]
 For nolign=1 To [M:RTC]NBLIG
  Readlock [PYH]PYH0 = [M:RTC]NUM(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-[M:RTC]NUM(nolign-1) : Break
  Elsif !fstat
   [F:PYH]PAM = [M:RTC]PAM(nolign-1)
   [F:PYH]STAFLG(1) = 2
   [F:PYH]STA       = 2
   GPOINT = "MAJPYH" : Gosub ENTREE From EXEFNC
   Rewrite [PYH]
   If fstat
    GOK = 0 : Call FSTA("PYH") From GLOCK : Break
   Endif
  Endif
 Next nolign
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


##################################
## Etiquettes de l'écran RETACC ##
##################################
$SEL_TABLE
Case COUZON

 When "NUM" : # Numéro de règlement
  Local Integer NBTPY : NBTPY=0
  Local Integer ACS
  Local Char    TABTPY(GLONTPY)(1..99)
  OBJET="PAY"
  OPTIONS="#"

  CRITERE="[F:PYH]STAFLG(1)=0 & [F:PYH]STA<2"
  CRITERE+="& [F:CPY]LEG='"+GCURLEG+"'"

  If !clalev([F:TPY2]) : Local File TABPAYTYP [TPY2] : Endif
  Filter [TPY2] Where (LEG=GCURLEG | LEG="") Order By Key CLE=PAYTYP Asc; LEG Desc
  For [TPY2]CLE(1)
   If [F:TPY2]STA2=2 & [F:TPY2]ENAFLG=2
    Call CONTEXE([F:TPY2]ACS) From CPTSUB
    If !mkstat : ACS=1 : Else : mkstat=0 : ACS=0 : GMESSAGE="" : Endif
   Else
    ACS=0
   Endif
   If ACS
    NBTPY += 1
    TABTPY(NBTPY) = [F:TPY2]PAYTYP
     If NBTPY>=dim(TABTPY) : Break : Endif
   Endif
  Next
  If NBTPY = 0
   CRITERE="1<>1"
  Else
   CRITERE+=" & find([F:PYH]PAYTYP,TABTPY(1..NBTPY))"
  Endif
  Filter [TPY2]

 When "LOT" : # Lot de saisie
  OBJET="PYL"
  If [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
   CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTYP<>2
   CRITERE-="& PAYTYP='"+[M]TYP+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif

Endcase
Return


Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Local Integer STAT
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Affzo ALLSAC : Effzo SAC
  Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
  If dim([M]LEG)>0 : Actzo LEG : Endif
 Endif
 GSOCIETE =""
 GCURFCY=""
Else
 Actzo CPY, ALLFCY, ALLSAC
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY = 2
 mkstat = 1 : End
Endif
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR
Call LECMAINPLAN(1,VALEUR,[M]COA) From CPTDIV
Call C_CPY(VALEUR) From CPTTRT
End


Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2
 mkstat = 1 : End
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2
 mkstat = 1 : End
Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If [F:TPY]STA2<>2
 # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2 : End
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]ALLCPY<>2 & [F:PYL]CPY<>[M]CPY
 # Lot de saisie de société
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY : mkstat=2 : End
Elsif [M]ALLTYP<>2 & [F:PYL]PAYTYP<>[M]TYP
 # Lot de saisie de transaction
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP  : mkstat=2 : End
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYL]PAYTYP) From CPTLEC
If fstat | [F:TPY]STA2<>2
 # Transaction de règlement non paramétrée pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2 : End
Endif
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CUR,GRPCUR : Grizo CUR, GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char VALEUR
If [M]ALLCUR=2
 mkstat = 1 : End
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char    VALEUR()
If [M]ALLCUR=2 | [M]CUR<>""
 mkstat = 1 : End
Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog C_ALLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End

Subprog AS_ALLSAC(VALEUR)
Variable Integer VALEUR
Local Integer STAT
If [M]ALLCPY = 2
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
 Endif
Endif
End

Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SAC : Grizo SAC
Else
 Actzo SAC
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char    VALEUR()
If [M]ALLSAC=2
 mkstat = 1 : End
Endif
End

Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAC]GAC1 = [M]COA;VALEUR
 If !fstat : [M]SACACC=[F:GAC]ACC : Else : Raz [M]SACACC : Endif
Else
 Raz [M]SACACC
Endif
End

Subprog C_ALLBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BPR : Grizo BPR
Else
 Actzo BPR
Endif
End

Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPR=2
 mkstat = 1 : End
Endif
End

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
Local Integer STAT
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Affzo ALLSAC : Effzo SAC
  Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
 Endif
Else
 Actzo CPY, ALLFCY, ALLSAC
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
 If [M]CPY<>""
  Call LECMAINPLAN(1,[M]CPY,[M]COA) From CPTDIV
 Endif
Endif
If [M]ALLLOT=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
If [M]ALLSAC=2
 Effzo SAC : Grizo SAC
Else
 Actzo SAC
Endif
If [M]ALLBPR=2
 Effzo BPR : Grizo BPR
Else
 Actzo BPR
Endif
If [M]ALLCUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
If GBIDC1<>""
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP
 If dim(ZTYP)>0 : Affzo ZTYP : Endif
 Grizo ALLTYP, TYP
Else
 Actzo ALLTYP
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
End


########################################
## Etiquettes de l'écran RETACC2      ##
########################################
Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Char    TIT(30)
Call UNICITE(VALEUR,[M]NUM(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
Read [PYH]PYH0 = VALEUR
If fstat
 GMESSAGE = mess(6,117,1) : mkstat = 2 : End
# Numéro incorrect
Endif
Call LEC_CPY([F:PYH]CPY) From CPTLEC
If [F:CPY]LEG<>GCURLEG
 # Règlement ...  de législation différente de celle saisie.
 GMESSAGE = mess(27,117,1)- mess(221,107,1)
 mkstat=2 : End
Endif
Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
If [F:TPY]STA2<>2
 # Type de règlement incompatible
 GMESSAGE = mess(29,117,1)
 mkstat = 2 : End
Elsif [F:PYH]STAFLG(1)<>0 | [F:PYH]STA>1
 # Règlement déjà accepté
 GMESSAGE = mess(96,117,1)
 mkstat = 2 : End
Elsif [F:TPY]ENAFLG<>2
 Call TITOBJ("TPY","!",TIT) From CONTOBJ
 # Fiche inactive
 GMESSAGE = TIT-"\"+[F:PYH]PAYTYP-":"-mess(2,126,1)
 mkstat=2 : End
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
 If mkstat : End : Endif
Endif
If [M]NUM(nolign-1)<>VALEUR
 [M:RTC] = [F:PYH]
 If [F:PYH]BPR<>""
  Call LEC_BPR([F:PYH]BPR) From CPTLEC
  [M:RTC]BPRNAM(nolign-1) = [F:BPR]BPRNAM
 Elsif [F:PYH]ACC<>""
  Call LECTEXTRA([M:RTC]BPRNAM(nolign-1),"GACCOUNT","DESTRA",[F:PYH]COA,[F:PYH]ACC) From ATEXTRA
 Else
  [M:RTC]BPRNAM(nolign-1)=""
 Endif
Endif
End

Subprog AS_PAM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,[M]PAYTYP(nolign-1)) From CPTLEC
End

Subprog C_PAM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,[M]PAYTYP(nolign-1)) From CPTLEC
If VALEUR="" & [F:TPY]DACPAM=1
 # Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat=2 : End
Elsif !find(VALEUR,[F:TPY]PAM(0..[F:TPY]NBRPAM-1))
 # Mode de règlement incompatible
 GMESSAGE = mess(1,117,1)
 mkstat = 2 : End
Endif
End

Subprog AM_PAM(VALEUR)
Variable Char    VALEUR()
Call LEC_TAM(GCURLEG, VALEUR) From CPTLEC
[M]ACCEPT(nolign-1) = [F:TAM]ACCEPT
Affzo ACCEPT(nolign-1)
End
