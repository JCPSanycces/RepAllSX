Subprog AS_SELDATEND(VALEUR)
Variable Date VALEUR
Gosub SETMSK
[L]NOMVAR = [L]MSK + "SELDATSTR"
If [L]VALEUR = [0/0/0] : [L]VALEUR = evalue([L]NOMVAR) : Endif
End

Subprog C_SELDATEND(VALEUR)
Variable Date    VALEUR
Gosub SETMSK
[L]NOMVAR = [L]MSK + "SELDATSTR"
If [L]VALEUR <> [0/0/0] & [L]VALEUR < evalue([L]NOMVAR)
#JOJAC - 2016-09-08 - X3PEOP-1328 - START
  GMESSAGE = mess(200,126,1)-'"'+mess(192,10701,1)+'"'
#JOJAC - 2016-09-08 - X3PEOP-1328 - END
  mkstat = 2 : End
Endif
End

