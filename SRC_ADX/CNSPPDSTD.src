#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

#---------------------------------------------------------------------
# CNSPPDSTD : Consultation des éléments (demande) de préparation paie
#---------------------------------------------------------------------
#---------------------------------------------------------------------------------------------------------
# Tableau des paramètres admis
#---------------------------------------------------------------------------------------------------------
# 01 : Origine - vide si appel du menu, servi si appel avec passage de parametre, contenu non exploité
# 02 : Société
# 03 : Site
# 04 : Date d'application début
# 05 : Date d'application fin
# 06 : Manager de début
# 07 : Manager de fin
# 08 : Service
# 09 : Profil
# 10 : Matricule de début
# 11 : Matricule de fin
# 12 : Code population
# 13 : Etat de la ligne - début ( menu local 640, 1 = brouillon, 6 = prise en compte )
# 14 : Etat de la ligne - fin   ( menu local 640, 1 = brouillon, 6 = prise en compte )
# 15 : Code variable - jokers autorisés
# 16 : Numéro de bordereau
#---------------------------------------------------------------------------------------------------------

Local Char PARAM(250)(1..20)

Gosub GET_PPDSTA From TRTPREPAY

[L]PARAM(1) = ""
[L]PARAM(2) = ""
[L]PARAM(3) = ""
[L]PARAM(4) = "20101201"
[L]PARAM(5) = "20101231"
[L]PARAM(6) = ""
[L]PARAM(7) = ""
[L]PARAM(8) = ""
[L]PARAM(9) = ""
[L]PARAM(10) = ""
[L]PARAM(11) = ""
[L]PARAM(12) = ""
[L]PARAM(13) = num$([L]PPDSTA_BROUILLON)
[L]PARAM(14) = num$([L]PPDSTA_PRISENCOMPTE)
[L]PARAM(15) = ""
[L]PARAM(16) = ""

Call GCONSULT("PPD", "", [L]PARAM) From GCONSULT
End

#--------
# ACTION
#--------
$ACTION
Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "LECTURE"   : Gosub LECTURE
    When "FERME"     : Gosub FERME
    When Default
Endcase
Return

#------------------------------------------------------------------------------------------------
# OUVRE : Ouverture de la consultation - Déclaration des variables & récupération des paramètres
#------------------------------------------------------------------------------------------------
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG=GLEGFIL
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

# Variables génériques à conserver
Local Integer OK, I, SORTIE, SORTIE_ANTICIPEE, SENS, TRICUR, FLGTRI, OK_ENREG
Local Char FORMULE_FLGTRI(250)

# Variables de filtre
Local Char CRILNK(250)(3), CRISUP(250)(3), ORDLNK(250)
Local Integer OK_CRILNK, I, NBCRILNK, NBCRISUP

# Variables de sauvegarde des clés début et fin
Local Char DEB_REQNUM([V]GLONHRPPH), FIN_REQNUM([V]GLONHRPPH), DEB_MGR([V]GLONEML), FIN_MGR([V]GLONEML)
Local Char DEB_SRV([V]GLONSRV), FIN_SRV([V]GLONSRV)
Local Integer DEB_NUMLIG, FIN_NUMLIG, DEB_IDPPD, FIN_IDPPD
Local Date DEB_APLDAT, FIN_APLDAT

# Variables diverses
Local Char SELPOP([V]GLONPOP), ORIGINE(30), VOIDCAR(250), NOMVAR(250)
Local Date WDAT
Local Integer TPPDSTA(len(mess(0,10640,1))), NBPPDSTA

# Les tris possibles
Local Integer TRI_REQNUM, TRI_MGR, TRI_SRV, TRI_APLDAT
[L]TRI_REQNUM = 1
[L]TRI_MGR = 2
[L]TRI_SRV = 3
[L]TRI_APLDAT = 4

[L]FORMULE_FLGTRI = "[HRPPD]IDPPD <> [L]DEB_IDPPD"
[L]TRICUR = [L]TRI_REQNUM
[M:PPD1]TRI = [L]TRICUR

Gosub GET_PPDSTA From TRTPREPAY

# Récupération des paramètres de l'environnement
[L]ORIGINE = [L]PARAM(1)

If [L]ORIGINE <> ""
    # Si présence de paramètres - Récupération des valeurs
    [L]I = 1

    [L]I += 1 : [M:PPD1]SELCPY = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELFCY = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELDATSTR = [L]PARAM([L]I)
    [L]I += 1 : [M:PPD1]SELDATEND = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELMGRSTR = [L]PARAM([L]I)
    [L]I += 1 : [M:PPD1]SELMGREND = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELSRV = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELPRF = [L]PARAM([L]I)

    [L]I += 1 : If [L]PARAM([L]I) <> "" : [M:PPD1]SELMATSTR = [L]PARAM([L]I) : Endif
    [L]I += 1 : If [L]PARAM([L]I) <> "" : [M:PPD1]SELMATEND = [L]PARAM([L]I) : Endif

    [L]I += 1 : [M:PPD1]SELPOP = [L]PARAM([L]I)

    [L]I += 1 : [M:PPD1]SELSTASTR = val([L]PARAM([L]I))
    [L]I += 1 : [M:PPD1]SELSTAEND = val([L]PARAM([L]I))

    For [L]J = 1 To len(mess(0,10640,1))
        [L]NOMVAR = "[M:PPD1]SELSTA" + num$([L]J)
        If [L]J < [M:PPD1]SELSTASTR or [L]J > [M:PPD1]SELSTAEND
            Assign [L]NOMVAR With 1
        Else
            Assign [L]NOMVAR With 2
        Endif

        If [L]J = [L]PPDSTA_INACTIF
            Assign [L]NOMVAR With 1
        Endif

    Next

    [L]I += 1 : [M:PPD1]SELVRAPAT = [L]PARAM([L]I)
    [L]I += 1 : [M:PPD1]SELPPHNUM = [L]PARAM([L]I)

Else
    # Arrivée depuis le menu, un zoom sans passage de paramètre, etc.

    If GPAYE=1
       ##**82073
       #[L]WDAT = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
       [M:PPD1]SELDATSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
       [M:PPD1]SELDATEND = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
    Endif

    #Security
#    If [L]WDAT=[0/0/0]
#     #Pas de date de paie définie sur cette période
#     Call ERREUR (mess(79,10701,1)) From GESECRAN
#     [L]WDAT = eomonth(date$)
#    Endif
    #ADNGO - 2017-05-20 - START
    #** V7 : Waiting Time Mangement **#
    #**Read [HRPEO]PEO0 = "";[L]WDAT
    #**[M:PPD1]SELDATSTR = [F:HRPEO]PERSTR(0)
    #**[M:PPD1]SELDATEND = max([F:HRPEO]PEREND(0), [F:HRPEO]PEREND(1))
    #**
    #Read [HRPEOD]HRPEOD0 = "";[L]WDAT
    #[M:PPD1]SELDATSTR = [F:HRPEOD]PERSTR(0)
    #[M:PPD1]SELDATEND = max([F:HRPEOD]PEREND(0), [F:HRPEOD]PEREND(1))
    #ADNGO - 2017-05-20 - END
#    [M:PPD1]SELDATSTR = addmonth(eomonth([L]WDAT),-1)+1
#    [M:PPD1]SELDATEND = eomonth([L]WDAT)

    For [L]J = 1 To len(mess(0,10640,1))
        [L]NOMVAR = "[M:PPD1]SELSTA" + num$([L]J)
        If find([L]J, [L]PPDSTA_INACTIF)
            Assign [L]NOMVAR With 1
        Else
            Assign [L]NOMVAR With 2
        Endif
    Next
Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$LECTURE

Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
If [L]CHGPAG < 0 : [L]NOL = [L]MAXLIG : Endif

Gosub SET_CRITERE

If [L]OK_CRILNK = 1 : Return : Endif

Gosub SET_CHANGEMENT

[L]FLGTRI = 0

Repeat

    [L]SORTIE = 2

    For [F:WLNK] Where evalue([L]ORDLNK)
        ##**82073
        # Lecture du dernier contrat. Pour être en cohérence avec EMPCTR on ne filtre pas sur APLDAT ...
#        Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:HRPPD]REFNUM
#&                    & [F:HRCTR]CTRNUM = [F:HRPPD]CTRNUM
#        Read [F:HRCTR]CTR0 Last
#        Filter [F:HRCTR]
#        If fstat <= 2
            If evalue([L]CRISUP(0)) & evalue([L]CRISUP(1)) & evalue([L]CRISUP(2))

                # Ajouter le contrôle d'accès au salarié

                #  Filtre sur les variables d'un groupe de variable.
                #  => Techniquement très "lourd" car cela consiste à prendre
                # la variable en question, à retrouver la liste de variable
                # utilisée dans le bordereau où elle à été saisie, puis à
                # regarder si pour cette liste notre variable apparaît dans
                # le groupe concerné : et oui, rien ne nous interdit de mettre
                # la variable X dans le groupe PRIME sur la liste 1 et dans
                # le groupe DIVERS sur la liste 2 ....

                [L]OK_ENREG = 1

                If dim([M:PPD1]SELVRAGRP) > 0 & [M:PPD1]SELVRAGRP <> ""
                    Gosub GROUPE_VARIABLE
                Else
                    [L]OK_ENREG = 2
                Endif

                If [L]OK_ENREG = 2
                    Gosub SET_POSITION
                    If [L]SORTIE_ANTICIPEE = 2 : Break : Endif
                    nolign = [L]NOL + 1
                    [M:PPD2] = [F:HRPPH]
                    [M:PPD2] = [F:HRCTR]
                    [M]SRN (nolign-1) = [F:ID]NAM-[F:ID]SRN
                    [M:PPD2] = [F:HRPPD]
                Endif

             Endif
#        Endif
    Next

    # => SI changement de tri , SORTIE = 1 , retour sur la boucle
    If [L]TRICUR <> [M:PPD1]TRI
        If [L]CHGPAG = 3 & ![L]FLGTRI
            [L]FLGTRI = 1
            [L]CHGPAG = 1
            Gosub SET_CRITERE
            [L]CHGPAG = 3
            [L]RETOUR = 1
            [L]SORTIE = 1
        Else
            [L]TRICUR = [M:PPD1]TRI
        Endif
     Endif
Until [L]SORTIE = 2

Return

#------------------------------ A adapter pour chaque consultation ---------------------

#-------------------------------------------------------------
# EFFACE_MASQUE : MASQUE(s) à effacer entre chaque chargement
#-------------------------------------------------------------
$EFFACE_MASQUE
Raz [M:PPD2]
Return

#---------------------------------------------------------------------------------
# MEMO_CLEDEB : Mémoriser toutes les zones clé sur la "première" ligne du tableau
#---------------------------------------------------------------------------------
$MEMO_CLEDEB
[L]DEB_IDPPD = [F:HRPPD]IDPPD
[L]DEB_REQNUM = [F:HRPPD]REQNUM
[L]DEB_NUMLIG = [F:HRPPD]NUMLIG
[L]DEB_MGR = [F:HRPPH]MGR
##**82073
#[L]DEB_SRV = [F:ECT]SRV
[L]DEB_SRV = [F:HRCTR]ETRSRV
#[L]DEB_APLDAT = [F:HRPPD]APLDAT
[L]DEB_APLDAT = [F:HRPPD]APLSTR
Return

#---------------------------------------------------------------------------------
# MEMO_CLEDEB : Mémoriser toutes les zones clé sur la "dernière" ligne du tableau
#---------------------------------------------------------------------------------
$MEMO_CLEFIN
[L]FIN_IDPPD = [F:HRPPD]IDPPD
[L]FIN_REQNUM = [F:HRPPD]REQNUM
[L]FIN_NUMLIG = [F:HRPPD]NUMLIG
[L]FIN_MGR = [F:HRPPH]MGR
##**82073
#[L]FIN_SRV = [F:ECT]SRV
[L]DEB_SRV = [F:HRCTR]ETRSRV
[L]FIN_APLDAT = [F:HRPPD]APLDAT
Return

#----------------------------------------------------
# SET_ECRAN : Consultation avec écrans paramétrables
#----------------------------------------------------
$SET_ECRAN
Return

#----------------------------------------------------
# LIAISONS : Link ou filtre général sur la table lue
#----------------------------------------------------
##**82073: Remplace link sur ECT par HRCTR
$LIAISONS
If [L]SELPOP <> ""
    Link [F:HRPPD] With
&        [F:HRPPH]PPH0 = [F:HRPPD]REQNUM,
&        [F:HRCTR]CTR0 = [F:HRPPD]REFNUM ; [F:HRPPD]CTRNUM ; [F:HRPPD]CTRDAT,
&        [F:ID]ID0 = [F:HRPPD]REFNUM,
&        [F:FCY]FCY0 = [F:HRCTR]ETRFCY,
&        [F:CPY]CPY0 = [F:FCY]LEGCPY,
&        [F:HRPOA]POA0 = [L]SELPOP ; [F:HRPPD]REFNUM
&        As [WLNK]
&        Where evalue([L]CRILNK(0)) & evalue([L]CRILNK(1)) & evalue([L]CRILNK(2))
&        & [F:HRPOA]REFNUM <> ""
Else
    Link [F:HRPPD] With
&        [F:HRPPH]PPH0 = [F:HRPPD]REQNUM,
&        [F:HRCTR]CTR0 = [F:HRPPD]REFNUM ; [F:HRPPD]CTRNUM ; [F:HRPPD]CTRDAT,
&        [F:ID]ID0 = [F:HRPPD]REFNUM,
&        [F:FCY]FCY0 = [F:HRCTR]ETRFCY,
&        [F:CPY]CPY0 = [F:FCY]LEGCPY
&        As [WLNK]
&        Where evalue([L]CRILNK(0)) & evalue([L]CRILNK(1)) & evalue([L]CRILNK(2))
Endif
Gosub TRI
Return

#------------------------------------------------------------------------------
# TRI : Détermine l'ordre de tri y compris les tris inversés sur bouton retour
#------------------------------------------------------------------------------
$TRI
Case [M:PPD1]TRI
    When [L]TRI_REQNUM
        If [L]SENS = 1
            Filter [WLNK] Order By Key CLE = [F:HRPPD]REQNUM ; [F:HRPPD]NUMLIG ; [F:HRPPD]IDPPD
        Else
            Filter [WLNK] Order By Key CLE = [F:HRPPD]REQNUM Desc ; [F:HRPPD]NUMLIG Desc ; [F:HRPPD]IDPPD Desc
        Endif
    When [L]TRI_MGR
        If [L]SENS = 1
            Filter [WLNK] Order By Key CLE = [F:HRPPH]MGR ; [F:HRPPD]REQNUM ; [F:HRPPD]NUMLIG ; [F:HRPPD]IDPPD
        Else
            Filter [WLNK] Order By Key CLE = [F:HRPPH]MGR Desc ; [F:HRPPD]REQNUM Desc ; [F:HRPPD]NUMLIG Desc ;
&                                                [F:HRPPD]IDPPD
        Endif
    When [L]TRI_SRV
        If [L]SENS = 1
            Filter [WLNK] Order By Key CLE = [F:ECT]SRV ; [F:HRPPD]REQNUM ; [F:HRPPD]NUMLIG ; [F:HRPPD]IDPPD
        Else
            Filter [WLNK] Order By Key CLE = [F:ECT]SRV Desc ; [F:HRPPD]REQNUM Desc ; [F:HRPPD]NUMLIG Desc ;
&                                                [F:HRPPD]IDPPD
        Endif
    When [L]TRI_APLDAT
        If [L]SENS = 1
            ##**82073
            Filter [WLNK] Order By Key CLE = [F:HRPPD]APLSTR ; [F:HRPPD]APLDAT ; [F:HRPPD]REQNUM ; [F:HRPPD]NUMLIG ; [F:HRPPD]IDPPD
        Else
            Filter [WLNK] Order By Key CLE = [F:HRPPD]APLSTR Desc ; [F:HRPPD]APLDAT Desc ; [F:HRPPD]REQNUM Desc ; [F:HRPPD]NUMLIG Desc ;
&                                                [F:HRPPD]IDPPD
        Endif
Endcase
Return

#--------------------------------------------------------------------------------------
# SET_CRITERE : Définition des criteres y compris placement sur boutons suite / retour
#--------------------------------------------------------------------------------------
$SET_CRITERE

Raz [L]CRILNK, [L]NBCRILNK, [L]CRISUP, [L]NBCRISUP, [L]SELPOP, [L]ORDLNK

# Première série : CRILNK(0)

If [M:PPD1]SELCPY <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[CPY]CPY='"+[M:PPD1]SELCPY+"'"
Endif

If [M:PPD1]SELFCY <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[FCY]FCY='"+[M:PPD1]SELFCY+"'"
Endif

If [M:PPD1]SELDATSTR <> [0/0/0]
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]APLDAT>=["+format$("D:DD[/]MM[/]YYYY", [M:PPD1]SELDATSTR)+"]"
Endif

If [M:PPD1]SELDATEND <> [0/0/0]
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    ##**82073
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]APLSTR<=["+format$("D:DD[/]MM[/]YYYY", [M:PPD1]SELDATEND)+"]"
Endif

If [M:PPD1]SELMGRSTR <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPH]MGR>='"+[M:PPD1]SELMGRSTR+"'"
Endif

If [M:PPD1]SELMGREND <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPH]MGR<='"+[M:PPD1]SELMGREND+"'"
Endif

If [M:PPD1]SELMATSTR <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]REFNUM>='"+[M:PPD1]SELMATSTR+"'"
Endif

If [M:PPD1]SELMATEND <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]REFNUM<='"+[M:PPD1]SELMATEND+"'"
Endif

[L]NBCRILNK += 1

# Seconde série : CRILNK(1)

If [M:PPD1]SELVRAPAT <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif

    # Petit luxe, pouvoir utiliser un pattern de vérification

    If instr(1, [M:PPD1]SELVRAPAT, "?") or instr(1, [M:PPD1]SELVRAPAT, "*")
        [L]CRILNK([L]NBCRILNK) -= "pat([HRPPD]VRACOD, '"+[M:PPD1]SELVRAPAT+"')"
    Else
        [L]CRILNK([L]NBCRILNK) -= "[HRPPD]VRACOD='"+[M:PPD1]SELVRAPAT+"'"
    Endif
Endif

# Le cas tordu du "brouillon" à 0 dont l'état est brouillon mais qu'on ne veut pas voir en temps
# normal ... Si on coche les inactifs, alors , permettons de le voir
# => En fait si on ne coche pas les inactifs (PPDSTA_INACTIF<>2) , on ne voit pas les lignes à 0
If evalue("[M:PPD1]SELSTA"+num$([L]PPDSTA_INACTIF)) <> 2
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]DEMAMT <> 0"
Endif

# Le dernier truc à la mode , pouvoir choisir les états qu'on veut !
Raz [L]TPPDSTA, [L]NBPPDSTA

For [L]I = 1 To len(mess(0,10640,1))
    [L]NOMVAR = "[M:PPD1]SELSTA" + num$([L]I)
    If evalue([L]NOMVAR) = 2
        [L]TPPDSTA([L]NBPPDSTA) = [L]I
        NBPPDSTA += 1
    Endif
Next

If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
[L]CRILNK([L]NBCRILNK) -= "find([HRPPD]STA,[L]TPPDSTA)"

If [M:PPD1]SELSRV <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRCTR]ETRSRV='"+[M:PPD1]SELSRV+"'" :##**82073
Endif

If [M:PPD1]SELPRF <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRCTR]PROPRF='"+[M:PPD1]SELPRF+"'" :##**82073
Endif

If [M:PPD1]SELPPHNUM <> ""
    If [L]CRILNK([L]NBCRILNK) <> "" : [L]CRILNK([L]NBCRILNK) -= "&" : Endif
    [L]CRILNK([L]NBCRILNK) -= "[HRPPD]REQNUM='"+[M:PPD1]SELPPHNUM+"'"
Endif

[L]NBCRILNK += 1

# Troisième série - Réservée pour les distris : CRILNK(2)

[L]NBCRILNK += 1 : # +=1 Technique => on a NB éléments (3) de 0 à NB-1

# Critères supplémentaires appliqués après lecture d'un enregistrement HRPPD

# => But du jeu proposer des filtres liés au contrat et qu'on ne peut pas mettre dans la jointure
# pour cause de lien du type CTR0 <= refnum ; ctrnum ; apldat ....
# On privilégie la performance en considèrant ETRSRV / PROPRF dans ECT même si cela peut avoir quelques
# effets de bords.

# Première serie : CRISUP(0)

[L]NBCRISUP += 1

# Seconde série : CRISUP(1)

[L]NBCRISUP += 1

# Troisieme série - Réservée distris : CRISUP(2)

[L]NBCRISUP += 1    : # +=1 Technique => on a NB éléments (3) de 0 à NB-1

# Critères permettant le déplacement suite / retour / etc. en appliquant un filtre sur le premier
# ou le dernier élément mémorisé.
# Principe général en clé multi composée : on veut un enregistrement qui remplit les conditions suivantes :
# (CLE1 > MEMOCLE1) ou
# ou (CLE1 >= MEMOCLE1 & CLE2 > MEMOCLE2)
# ou (CLE1 >= MEMOCLE1 & CLE2>=MEMOCLE2 & CLE3>MEMOCLE3)
# etc ^^

Case [L]CHGPAG
    When -2
        # Retour
        Case [M:PPD1]TRI
            When [L]TRI_REQNUM
                [L]ORDLNK = "([HRPPD]REQNUM<='"+[L]DEB_REQNUM+"' & [HRPPD]NUMLIG<"+num$([L]DEB_NUMLIG)+")"
                [L]ORDLNK -= "or ([HRPPD]REQNUM<'"+[L]DEB_REQNUM+"')"
            When [L]TRI_MGR
                [L]ORDLNK = "([HRPPH]MGR<'"+[L]DEB_MGR+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPH]MGR<='"+[L]DEB_MGR+"' & [HRPPD]REQNUM<'"+[L]DEB_REQNUM+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPH]MGR<='"+[L]DEB_MGR+"' & [HRPPD]REQNUM<='"+[L]DEB_REQNUM+"'"
                [L]ORDLNK -= "& [HRPPD]NUMLIG<"+num$([L]DEB_NUMLIG)+")"
            When [L]TRI_SRV
                [L]ORDLNK = "([HRCTR]ETRSRV<'"+[L]DEB_SRV+"')" :##**82073
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRCTR]ETRSRV<='"+[L]DEB_SRV+"' & [HRPPD]REQNUM<'"+[L]DEB_REQNUM+"')"  :##**82073
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRCTR]ETRSRV<='"+[L]DEB_SRV+"' & [HRPPD]REQNUM<='"+[L]DEB_REQNUM+"'" :##**82073
                [L]ORDLNK -= "& [HRPPD]NUMLIG<"+num$([L]DEB_NUMLIG)+")"
            When [L]TRI_APLDAT
                [L]VOIDCAR = "["+format$(GFMDAT4, [L]DEB_APLDAT)+"]"
                [L]ORDLNK = "([HRPPD]APLDAT<"+[L]VOIDCAR+")"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPD]APLDAT<="+[L]VOIDCAR+" & [HRPPD]REQNUM<'"+[L]DEB_REQNUM+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPD]APLDAT<="+[L]VOIDCAR+" & [HRPPD]REQNUM<='"+[L]DEB_REQNUM+"'"
                [L]ORDLNK -= "& [HRPPD]NUMLIG<"+num$([L]DEB_NUMLIG)+")"
        Endcase
    When 2
        # Suite
        Case [M:PPD1]TRI
            When [L]TRI_REQNUM
                [L]ORDLNK = "([HRPPD]REQNUM>='"+[L]FIN_REQNUM+"' & [HRPPD]NUMLIG>"+num$([L]FIN_NUMLIG)+")"
                [L]ORDLNK -= "or ([HRPPD]REQNUM>'"+[L]FIN_REQNUM+"')"
            When [L]TRI_MGR
                [L]ORDLNK = "([HRPPH]MGR>'"+[L]FIN_MGR+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPH]MGR>='"+[L]FIN_MGR+"' & [HRPPD]REQNUM>'"+[L]FIN_REQNUM+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPH]MGR>='"+[L]FIN_MGR+"' & [HRPPD]REQNUM >='"+[L]FIN_REQNUM+"'"
                [L]ORDLNK -= "& [HRPPD]NUMLIG>"+num$([L]FIN_NUMLIG)+")"
            When [L]TRI_SRV
                [L]ORDLNK = "([HRCTR]ETRSRV>'"+[L]FIN_SRV+"')" :##**82073
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRCTR]ETRSRV>='"+[L]FIN_SRV+"' & [HRPPD]REQNUM>'"+[L]FIN_REQNUM+"')" :##**82073
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRCTR]ETRSRV>='"+[L]FIN_SRV+"' & [HRPPD]REQNUM >='"+[L]FIN_REQNUM+"'" :##**82073
                [L]ORDLNK -= "& [HRPPD]NUMLIG>"+num$([L]FIN_NUMLIG)+")"
            When [L]TRI_APLDAT
                [L]VOIDCAR = "["+format$(GFMDAT4, [L]FIN_APLDAT)+"]"
                [L]ORDLNK = "([HRPPD]APLDAT>"+[L]VOIDCAR+")"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPD]APLDAT>="+[L]VOIDCAR+" & [HRPPD]REQNUM<'"+[L]FIN_REQNUM+"')"
                [L]ORDLNK -= "or"
                [L]ORDLNK -= "([HRPPD]APLDAT>="+[L]VOIDCAR+" & [HRPPD]REQNUM<='"+[L]FIN_REQNUM+"'"
                [L]ORDLNK -= "& [HRPPD]NUMLIG<"+num$([L]FIN_NUMLIG)+")"
        Endcase
    When 3
        # Rafraichir
        Case [M:PPD1]TRI
            When [L]TRI_REQNUM
                [L]ORDLNK = "([HRPPD]REQNUM>='"+[L]DEB_REQNUM+"' & [HRPPD]NUMLIG>="+num$([L]DEB_NUMLIG)+")"
            When [L]TRI_MGR
                [L]ORDLNK = "([HRPPH]MGR>='"+[L]DEB_MGR+"'"
                [L]ORDLNK -= "& [HRPPD]REQNUM>='"+[L]DEB_REQNUM+"' & [HRPPD]NUMLIG>="+num$([L]DEB_NUMLIG)+")"
            When [L]TRI_SRV
                [L]ORDLNK = "([HRCTR]ETRSRV>='"+[L]DEB_SRV+"'" :##**82073
                [L]ORDLNK -= "& [HRPPD]REQNUM>='"+[L]DEB_REQNUM+"' & [HRPPD]NUMLIG>="+num$([L]DEB_NUMLIG)+")"
            When [L]TRI_APLDAT
                [L]VOIDCAR = "["+format$(GFMDAT4, [L]DEB_APLDAT)+"]"
                [L]ORDLNK = "([HRPPD]APLDAT>="+[L]VOIDCAR
                [L]ORDLNK -= "& [HRPPD]REQNUM>='"+[L]DEB_REQNUM+"' & [HRPPD]NUMLIG>="+num$([L]DEB_NUMLIG)+")"
        Endcase
Endcase

# ----------- Toujours penser aux distributeurs qui veulent ajouter des filtres ...

If [L]PROGSPE <> ""
    [L]ACTION = "FILTRE" : Gosub ACTION From =[L]PROGSPE
Endif

[L]OK_CRILNK = 1

For [L]I = 0 To [L]NBCRILNK - 1
    If [L]CRILNK([L]I) = "" or [L]CRILNK([L]I) = "1"
        [L]CRILNK([L]I) = "1"
    Else
        [L]OK_CRILNK = 2
    Endif
Next

If [M:PPD1]SELPOP <> ""
    [L]SELPOP = [M:PPD1]SELPOP
    [L]OK_CRILNK = 2
Endif

For [L]I = 0 To [L]NBCRISUP - 1
    If [L]CRISUP([L]I) = "" : [L]CRISUP([L]I) = "1" : Endif
Next

If [L]ORDLNK = "" : [L]ORDLNK = "1" : Endif

Return

#-------------------------------------------------------------------------------------------
# GROUPE_VARIABLE : Regarde si la variable, pour la liste concernée, fait partie du groupe
#                   de variable demandé
#-------------------------------------------------------------------------------------------
$GROUPE_VARIABLE
# On dispose de HRPPH et de HRPPD sous les pieds ( le link )
For [F:HRPVD]PVD1 Where [F:HRPVD]PVHCOD = [F:HRPPH]PVHCOD
&                    & [F:HRPVD]VRACOD = [F:HRPPD]VRACOD
&                    & [F:HRPVD]LEG = GCURLEG
    If [F:HRPVD]VRAGRP = [M:PPD1]SELVRAGRP
        [L]OK_ENREG = 2
        Break
    Endif
Next
Return

#-----------------------------------------------------------------------------------------
#------------------------------ Etiquettes génériques - ne pas toucher -------------------
#-----------------------------------------------------------------------------------------
$SET_POSITION
[L]SORTIE_ANTICIPEE = 1

If [L]FLGTRI
    If evalue([L]FORMULE_FLGTRI)
        [L]RETOUR = 2
    Endif
    [L]FLGTRI = 2
    [L]SORTIE_ANTICIPEE = 2
    Return
Endif

If [L]NBLU = 1
    If find([L]CHGPAG, 2, -2)
        Gosub EFFACE_MASQUE
    Endif
    [L]NBLU = 2
Endif
If [L]CHGPAG > 0
    If [L]NOL >= MAXLIG-1
        [L]SUITE = 2 : [L]SORTIE_ANTICIPEE = 2
        Return
    Endif
    [L]NOL += 1
    If [L]NOL = 0
        Gosub MEMO_CLEDEB
    Endif
    Gosub MEMO_CLEFIN
Else
    If [L]NOL <= 0
        [L]RETOUR = 2 : [L]SORTIE_ANTICIPEE = 2
        Return
    Endif
    [L]NOL -= 1
    If [L]NOL = [L]MAXLIG-1
        Gosub MEMO_CLEFIN
    Endif
    Gosub MEMO_CLEDEB
Endif
Return

$SET_CHANGEMENT
If [L]CHGPAG > 0
    [L]SUITE = 1
    If [L]CHGPAG = 1
        [L]RETOUR = 1
    Elsif [L]CHGPAG = 2
        [L]RETOUR = 2
    Endif
    [L]SENS = 1
    Gosub LIAISONS
Else
    [L]RETOUR = 1
    If [L]CHGPAG = -1
        [L]SUITE = 1
    Elsif [L]CHGPAG = -2
        [L]SUITE = 2
    Endif
    [L]SENS = -1
    Gosub LIAISONS
Endif
If [L]CHGPAG <> 2 & [L]CHGPAG <> -2
    Gosub EFFACE_MASQUE
Endif
Return

#--------------------------------------------------------------------------------------
# Réaffichage d'une seule ligne (optimisation perf. en retour d'une modif sur tableau)
#--------------------------------------------------------------------------------------
Subprog REAFFICHE_PPD(NOL)
Value Integer NOL
Local File PPREQUESTD [WPPD]
Read [F:WPPD]PPD9 = [M:PPD2]IDPPD([L]NOL)
If fstat = 0
    [M:PPD2]STA([L]NOL) = [F:WPPD]STA
    Affzo [M:PPD2]STA([L]NOL)
Endif
Close Local File [WPPD]
End

$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

$SETMSK
Local Char MSK(15), NOMVAR(250)
[L]MSK = "[M:" + maskcou + "]"
# On a un souci avec maskcou qui renvoie le nom complet et pas l'abrev !
Case maskcou
    When "CONSPPD1"
        [L]MSK = "[M:PPD1]"
    When "CRITPPD"
        [L]MSK = "[M:CPPD]"
    When Default
        [L]MSK = "[M:" + maskcou + "]"
Endcase

Return

