Subprog IB_NBLIG
Gosub SETNOL
Gosub GET_PPDSTA From TRTPREPAY
Raz [V]GBOUT2, [V]GBOUT3
Case [M:PPD2]STA([L]NOL)
    When [L]PPDSTA_DEMANDE
        # mess(170,10702,1) : Accepter
        # mess(171,10702,1) : Refuser
        [V]GBOUT2 = mess(170, 10702, 1)
        [V]GBOUT3 = mess(171, 10702, 1)
    When [L]PPDSTA_ACCEPTE
        # mess(171,10702,1) : Refuser
        [V]GBOUT3 = mess(171, 10702, 1)
    When [L]PPDSTA_REFUSE
        # mess(170,10702,1) : Accepter
        [V]GBOUT2 = mess(170, 10702, 1)
Endcase
End

Subprog B2_NBLIG
# Accepter
Gosub SETNOL
#64648 : Add CHRONO
Call WRKSIG("VIS", "D", [M:PPD2]REQNUM([L]NOL), num$([M:PPD2]NUMLIG([L]NOL)),
&                num$([M:PPD2]IDPPD([L]NOL)), [M:PPD2]REFNUM([L]NOL), [M:PPD2]VRACOD([L]NOL),[M:PPD2]CHRONO([L]NOL) ) From SUBHRPPH
Call REAFFICHE_PPD([L]NOL)        : # Récupération du "nouveau" statut
Call AS_NBLIG From ="W1"+maskcou  : # Forcage de réaffectation des GBOUTx sur les onkey du menu contextuel
End

Subprog B3_NBLIG
# Refuser
Gosub SETNOL
#64648 : Add CHRONO
Call WRKSIG("REF", "D", [M:PPD2]REQNUM([L]NOL), num$([M:PPD2]NUMLIG([L]NOL)),
&                num$([M:PPD2]IDPPD([L]NOL)), [M:PPD2]REFNUM([L]NOL), [M:PPD2]VRACOD([L]NOL),[M:PPD2]CHRONO([L]NOL) ) From SUBHRPPH
Call REAFFICHE_PPD([L]NOL)
Call AS_NBLIG From ="W1"+maskcou
End

Subprog AV_ZOOMVEP(VALEUR)
Variable Char     VALEUR
If [M:PPD2]BUL(nolign-1) = ""
    Diszo [M:PPD2]ZOOMVEP(nolign-1)
Else
    Actzo [M:PPD2]ZOOMVEP(nolign-1)
Endif
End

Subprog CL_ZOOMVEP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PPD2]BUL([L]NOL) <> ""
    # Utilisation du sous programme de la nouvelle action BULTUN - On passe par une indirection car on
    # souhaite le zoom depuis une zone icone et non pas une zone "numéro de bulletin" contenant le
    # numéro.
    Local Char WBUL(250)
    [L]WBUL = [M:PPD2]BUL([L]NOL)
    Call BULTUN([L]WBUL) From SUBVEP
Endif
End

