#<AdxTL>@(#)1.0.0.0 $Revision$
#
# TEST:  1 oui
Call OUVRE_TRACE(mess(171,115,1)) From LECFIC 
Call BLOB_PHOTO_UTIL("GX3APP",0)
Call LEC_TRACE From LECFIC
End
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
#    Sous-prgrm de récupération des images du configurateur 130 -> 140
#        - sur les symboles
#        - sur les formes et modèles
#    Nota:    En 130, les images sont dans PIC et on a le nom
#             En 140, les images sont stockées dans les fichiers
#
#    E:    APPLI code application
#          TEST  0: mise à jour base    1: test 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
Subprog BLOB_PHOTO_UTIL(APPLI,TEST)
Value Char    APPLI
Value Integer TEST

Local Integer I, J, K, T, OK, INTE, WRET, WINSTR
Local Char    PHOTO(50), FICHIER(GDIMFIC),SUF(10), TEXTE(250), NAME(40), BLBRUB(15), CURKEY(15)
Local Char    CTXMES(50), MESSAGE(200)
Local Blbfile WBLB(9)  
Local Integer SAVIUM
Local Char    SAVIRS(5), SAVIFS(5)
Local Char    BID(10)

SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

#
If GTRACE="" : Call OUVRE_TRACE(mess(171,115,1)) From LECFIC : Endif

# Recupération Photos des symboles
Gosub TRT_SYM

# Recupération Photos des formes/modèles
Gosub TRT_FM

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS

End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
# Recupération Photos des symboles
$TRT_SYM
Local File =APPLI+".CFGQST" [WFI]                       
#
TEXTE = mess(173,115,1)-mess(174,115,1)-mess(0,188,1)-":"-mess(77,188,1)
MESSAGE="****"-TEXTE-num$(nbrecord([F:WFI]))-"****"
If TEST : MESSAGE -= "("-mess(223,188,1)-")" : Endif
Call ECR_TRACE(MESSAGE,0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:WFI])) From GESECRAN
T = 0
CURKEY=""
BLBRUB="[F:WFI]CQUPIC"
For [WFI]
 CURKEY=[F:WFI]QSTNUM   
 T += 1
 Call AFF_BOITE("",T,INTE) From GESECRAN
 CTXMES=mess(77,188,1)-":"-CURKEY-":"
 PHOTO = [F:WFI]QSTPIC
 #
 Gosub HAS_BLBPHOTO
 If OK=0    # pas de blob chargé
    Gosub HAS_FILEPHOTO
    If OK=1
        Gosub LEC_FILEPHOTO
        If OK
            #maj 
            GOK=1
            Trbegin [WFI]
                Readlock [WFI] Curr
                If fstat
                    GOK=0  
                    Call RSTACTX("WFI",CURKEY,CTXMES,"") From CFGLIBD
                Else
                   Assign BLBRUB With WBLB
                   If TEST=0    
                        Rewrite [WFI]
                        If fstat
                            Call ECR_TRACE(CTXMES,1) From GESECRAN
                            Call FSTACTX("WFI",CTXMES,"") From CFGLIBD
                            GOK=0 
                        Else
                            MESSAGE = mess(229,188,1)-PHOTO-"->"-BLBRUB
                            Call ECR_TRACE(CTXMES-MESSAGE,0) From GESECRAN
                        Endif
                   Else
                        MESSAGE = mess(223,188,1)-":"-mess(229,188,1)-PHOTO-"->"-BLBRUB
                        Call ECR_TRACE(CTXMES-MESSAGE,0) From GESECRAN
                        GOK=0
                   Endif
                Endif
            If GOK=1 : Commit : Else : Rollback : Endif
        Else
           Call ECR_TRACE(CTXMES-MESSAGE,1) From GESECRAN
        Endif
    Elsif OK=-1    # rien à faire
#      Call ECR_TRACE(CTXMES, 0) From GESECRAN   (pas de message)
    Else    # pb
       Call ECR_TRACE(CTXMES-MESSAGE,1) From GESECRAN
    Endif
 Else
    Call ECR_TRACE(CTXMES-MESSAGE, 0) From GESECRAN 
 Endif
    
Next CQU

Close Local File [WFI]
Call FERME_BOITE From GESECRAN
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
# Recupération Photos des formes et modèles
$TRT_FM
Local File =APPLI+".CFGSHA" [WFI]                       
#
TEXTE = mess(173,115,1)-mess(174,115,1)-mess(0,188,1)-":"-mess(9,752,1)
MESSAGE="****"-TEXTE-num$(nbrecord([F:WFI]))-"****"
If TEST : MESSAGE -= "("-mess(223,188,1)-")" : Endif
Call ECR_TRACE(MESSAGE,0) From GESECRAN
Call OUVRE_BOITE(TEXTE,100) From GESECRAN
Call SET_BOITE(TEXTE,nbrecord([F:WFI])) From GESECRAN
T = 0
CURKEY=""
BLBRUB="[F:WFI]CSHPIC"
For [WFI]
 CURKEY=[F:WFI]SHACAT-"/"-[F:WFI]SHANUM
 T += 1
 Call AFF_BOITE("",T,INTE) From GESECRAN
 CTXMES=mess(9,752,1)-":"-CURKEY-":"
 PHOTO = [F:WFI]SHAPCT
 #
 Gosub HAS_BLBPHOTO
 If OK=0    # pas de blob chargé
    Gosub HAS_FILEPHOTO
    If OK=1
        Gosub LEC_FILEPHOTO
        If OK
            #maj 
            GOK=1
            Trbegin [WFI]
                Readlock [WFI] Curr
                If fstat
                    GOK=0  
                    Call RSTACTX("WFI",CURKEY,CTXMES,"") From CFGLIBD
                Else
                   Assign BLBRUB With WBLB
                   If TEST=0    
#                        [F:WFI]DISPIC=2    # flag affichage photo
                        Rewrite [WFI]
                        If fstat
                            Call ECR_TRACE(CTXMES,1) From GESECRAN
                            Call FSTACTX("WFI",CTXMES,"") From CFGLIBD
                            GOK=0 
                        Else
                            MESSAGE = mess(229,188,1)-PHOTO-"->"-BLBRUB
                            Call ECR_TRACE(CTXMES-MESSAGE,0) From GESECRAN
                        Endif
                   Else
                        MESSAGE = mess(223,188,1)-":"-mess(229,188,1)-PHOTO-"->"-BLBRUB
                        Call ECR_TRACE(CTXMES-MESSAGE,0) From GESECRAN
                        GOK=0
                   Endif
                Endif
            If GOK=1 : Commit : Else : Rollback : Endif
        Else
           Call ECR_TRACE(CTXMES-MESSAGE,1) From GESECRAN
        Endif
    Elsif OK=-1    # rien à faire
#      Call ECR_TRACE(CTXMES, 0) From GESECRAN   (pas de message)
    Else    # pb
       Call ECR_TRACE(CTXMES-MESSAGE,1) From GESECRAN
    Endif
 Else
    Call ECR_TRACE(CTXMES-MESSAGE, 0) From GESECRAN 
 Endif
Next CQU

Close Local File [WFI]
Call FERME_BOITE From GESECRAN
Return


#--------------------#
$HAS_BLBPHOTO
# Renvoit OK=0 pas de photo
#            1 photo avec message
OK=1 : MESSAGE=""
If evalue("len("+BLBRUB+")")=0    # protection     
    OK=0    
Else
    OK=1
    MESSAGE=mess(226,188,1)-"("-BLBRUB-")" 
Endif
Return

#--------------------#
$HAS_FILEPHOTO
# Renvoit OK=1 fichier existe
#            0 pb
#           -1 pas de photo à traiter
OK=1 : MESSAGE=""
PHOTO=vireblc(PHOTO,2)
If len(PHOTO)>0
    WINSTR=instr(1,PHOTO,".")
    If WINSTR<>0
        NAME=left$(PHOTO, WINSTR-1)
        SUF=right$(PHOTO,WINSTR+1)
        FICHIER = filpath("PIC",NAME,SUF,APPLI)
        If filinfo(FICHIER,0)>0
            OK=1
        Else
            OK=0
            MESSAGE=mess(227,188,1)-FICHIER
        Endif
    Else
        OK=0
        MESSAGE=mess(230,188,1)-PHOTO
    Endif
Else
    OK=-1
    MESSAGE=mess(231,188,1)-PHOTO
Endif
Return

#-----------------------------#
$LEC_FILEPHOTO
# Renvoit OK=1 si tvb
#         OK=0 pb
#
OK=0 : MESSAGE=""
Openi FICHIER Using [FIC]
Getseq 1,WBLB Using [FIC]
If fstat
 MESSAGE=FICHIER-":"-mess(232,188,1)    # Taille du fichier trop grande
 OK = 0
Else
 Getseq 1,BID Using [FIC]
 If fstat
  OK = 1 : # On a tout lu
 Else
  MESSAGE=FICHIER-":"-mess(175,115,1)    # Taille du fichier trop grande
  OK = 0
 Endif
Endif 
Openi Using [FIC]
#  If !TEST    pas d'effacement dans le cadre du configurateur (une image pour plusieurs fiches)
#   Call EFFACE(FICHIER,OK) From ORDSYS  
#  Endif
Return

