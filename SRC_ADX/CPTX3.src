#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTX3","DCPTX3",3,"") From GTRAITE
End

#----------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

#----------------------------------------------------------------------#
$INIT
Local Char    SUPER(GLONADS) , FICPAR(250) , FICRES(250), LIGNE(250)
Local Libelle CRYPT(1..12)
Local Char    DESCRL(30),NOMFL(20),LIENCPT(1)
Local Integer LIENCOU,OK
Call PARAM("","SUPDOS",SUPER) From ADOVAL
FICPAR = filpath("","compta","par",SUPER)
FICRES = filpath("","liens","par",SUPER)
Return

#----------------------------------------------------------------------#
$INIT_DIA
Raz [M:DIA]
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = nomap

# Pour assurer la compatibilité si liens.par n'existe pas on regarde si compta.par existe
# et on initiliase liens.par avec cette description

If filinfo(FICRES,0)<0 and filinfo(FICPAR,0)>=0
 Openo FICRES,0
 adxifs = ";"
 adxirs = chr$(10)
 adxium = GUTF8
 Wrseq "compta",mess(217,133,1),"2"
 Openo
Endif

# liens.par     Nom fichier; Description; Lien compta (2 Oui 1 Non)
Effzo [M]5
If filinfo(FICRES,0)>=0
 Openi FICRES
 adxifs = ";"
 adxirs = chr$(10)
 adxium=GUTF8
 While fstat=0
  Rdseq NOMFL,DESCRL,LIENCPT
  If fstat=0
    [M]NBLIG+=1
    [M]DESCR(NBLIG-1)=DESCRL
    [M]ANOMF(NBLIG-1)=NOMFL
    [M]ALIENCPT(NBLIG-1)=val(LIENCPT)
  Endif
 Wend
 Openi
Endif
Affzo [M]5
For LIENCOU=0 To [M]NBLIG-1
  Gosub CHARGELIEN
Next LIENCOU
Return

$CHARGELIEN
FICPAR=filpath("",[M]ANOMF(LIENCOU),"par",SUPER)
Effzo [M]10
If filinfo(FICPAR,0)>=0
 Openi FICPAR
 adxifs = ""
 adxirs = chr$(10)
 adxium=GASCII
 Rdseq LIGNE
 While fstat=0
  Case left$(LIGNE,4)
   When "MAC=" : [M]AMAC(LIENCOU) = right$(LIGNE,5)
   When "SRV=" : [M]ASRV(LIENCOU) = val(right$(LIGNE,5))
   When "REP=" : [M]AREP(LIENCOU) = right$(LIGNE,5)
   When "DBA=" : [M]ADBA(LIENCOU) = right$(LIGNE,5)
   When "SRC=" : [M]ASRC(LIENCOU) = right$(LIGNE,5)
   When "USR=" : [M]AUSR(LIENCOU) = right$(LIGNE,5)
   When "TOS=" : [M]AOS(LIENCOU)  = val(right$(LIGNE,5))
   When "BAS=" : [M]ABAS(LIENCOU) = val(right$(LIGNE,5))
   When "PWD="
    Seek Curr - (len(LIGNE)-3)
    Getseq 12,CRYPT
    Call CRI(CRYPT) From VISULIC
    [M]APWD(LIENCOU) = vireblc(sigma(1,12,chr$(CRYPT(indcum))),2)
  Endcase
  Rdseq LIGNE
 Wend
 Openi
Endif
Return

$AFFLIEN
Effzo [M]10
[M]MAC  = [M]AMAC(nolign-1)
[M]NOMF = [M]ANOMF(nolign-1)
[M]SRV  = [M]ASRV(nolign-1)
[M]REP  = [M]AREP(nolign-1)
[M]DBA  = [M]ADBA(nolign-1)
[M]SRC  = [M]ASRC(nolign-1)
[M]USR  = [M]AUSR(nolign-1)
[M]OS   = [M]AOS(nolign-1)
[M]BAS  = [M]ABAS(nolign-1)
[M]PWD  = [M]APWD(nolign-1)
[M]LIENCPT=[M]ALIENCPT(nolign-1)
If [M]LIENCPT=2
  [M]NOMF = "compta"
  Diszo NOMF
Else
  Actzo NOMF
Endif
Affzo [M]10
Return

#----------------------------------------------------------------------#
$EXEC
Local Integer ID
For ID=0 To [M]NBLIG-1
  Gosub EXEC1
#  If OK & [M]LIENCPT(ID)=2
#    Call MAJPAR("CPTFDR",dossier comptabilité) From DOSDIV
#    Call MAJPAR("CPTMAC",[M]AMAC(ID)) From DOSDIV
#    Call MAJPAR("CPTPORT",num$([M]ASRV(ID))) From DOSDIV
#  Endif
Next ID

#  Réecriture de liens.par
Openo FICRES,0
adxifs = ";"
adxirs = chr$(10)
adxium=GUTF8
For ID=0 To [M]NBLIG-1
  Wrseq [M]ANOMF(ID),[M]DESCR(ID),num$([M]ALIENCPT(ID))
Next ID
Openo
Return

$EXEC1
FICPAR=filpath("",[M]ANOMF(ID),"par",SUPER)

#Call CREDOS([M]AMAC(ID),[M]AOS(ID),[M]ABAS(ID),[M]ASRV(ID),[M]AREP(ID)
#&          ,[M]ADBA(ID),[M]ASRC(ID),[M]AUSR(ID),[M]APWD(ID),SUPER,OK)

#    Bug 27315  : CC 21/12/2004   Il faut créer le user et le répertoire par dossier
Call CREDOS([M]AMAC(ID),[M]AOS(ID),[M]ABAS(ID),[M]ASRV(ID),[M]AREP(ID)
&          ,[M]ADBA(ID),[M]ASRC(ID),[M]AUSR(ID),[M]APWD(ID),nomap,0,OK)

Openo FICPAR,0
adxifs = ""
adxirs = chr$(10)
adxium=GASCII
Wrseq "MAC=";[M]AMAC(ID)
Wrseq "SRV=";[M]ASRV(ID)
Wrseq "REP=";[M]AREP(ID)
Wrseq "DBA=";[M]ADBA(ID)
Wrseq "SRC=";[M]ASRC(ID)
Wrseq "USR=";[M]AUSR(ID)
Wrseq "TOS=";[M]AOS(ID)
Wrseq "BAS=";[M]ABAS(ID)
For I=1 To len([M]APWD(ID))
 CRYPT(I) = ascii(mid$([M]APWD(ID),I,1))
Next I
For I=len([M]APWD(ID))+1 To 12
 CRYPT(I) = 32
Next I
Call CRI(CRYPT) From VISULIC
Wrseq "PWD=";
Putseq 12,CRYPT
Wrseq
Openo
Return

#--------------------------------------------------------------------------------------#
Subprog CREDOS(MACHINE,OS,TYPDBA,SERVICE,REPERT,BASE,SOURCE,USER,PASSE,APPLI,FORCE,OK)
Value    Char    MACHINE
Value    Integer OS
Value    Integer TYPDBA
Value    Integer SERVICE
Value    Char    REPERT
Value    Char    BASE
Value    Char    SOURCE
Value    Char    USER
Value    Char    PASSE
Value    Char    APPLI
Value    Integer FORCE
Variable Integer OK

Local Integer ERR

# On ne fait rien si les paramètres ne sont pas complets
If MACHINE="" or SERVICE=0 or REPERT="" or BASE="" or USER=""
   End
Elsif PASSE=""
   #PASSE = "tiger"
   #recuperation du password pour X3 tiger par example X3_PWD
   # si on trouve rien tiger par defaut......
   Call PASSWD("database.software.sqlfolderpwd",PASSE,ERR) From DOSBASE
Endif

Local Integer EXISTE , STAT, ECRASE
Local Char    CHEMIN(250) , ORDSYS(250)
Local Char    SEP(1) , FIC(20) , FICORA(20)
Local Char    SAVIFS(5) , SAVIRS(5)

SAVIFS = adxifs
SAVIRS = adxirs
Case OS
 When 2       : SEP = "\"
 When Default : SEP = "/"
Endcase

CHEMIN = MACHINE+":"+num$(SERVICE)+"@"+REPERT+SEP+APPLI
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If EXISTE>=1
 CHEMIN = MACHINE+":"+num$(SERVICE)+"@"+REPERT+SEP+APPLI+SEP+"TRT"
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE>=1
  # APPLI est un dossier dans la solution distante. Activation impossible
  Call ECR_TRACE("|"+CHEMIN+"|\"+APPLI-mess(141,125,1),1) From GESECRAN
  OK = 0 : End
 Elsif FORCE
  ECRASE = 2
 Else
  # Le répertoire distant existe déjà voulez vous l'écraser ?
  Call OUINON(mess(142,125,1),ECRASE) From GESECRAN
  If ECRASE<>2
   OK = 2 : End
  Endif
 Endif
Elsif !EXISTE
 Call SYSTEME(MACHINE+":"+num$(SERVICE),"ae_mkdir"-REPERT+SEP+APPLI,"",STAT) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If !EXISTE
  # Le répertoire n'a pas pu être crée
  Call ECR_TRACE(mess(221,133,1),1) From GESECRAN
  OK = 0 : End
 Endif
Endif
For FIC=".users",".passwd"
 CHEMIN = MACHINE+":"+num$(SERVICE)+"@"+REPERT+SEP+APPLI+SEP+FIC
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0 or ECRASE=2
  Openo CHEMIN,0
  Openo
 Endif
Next FIC
CHEMIN = MACHINE+":"+num$(SERVICE)+"@"+REPERT+SEP+APPLI+SEP+"APL.ini"
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If EXISTE=0 or ECRASE=2
 Openo CHEMIN,0
 adxifs = ""
 adxirs = chr$(10)
 adxium = GUTF8
 Wrseq 'adxmother(0) = "X3"'
 Wrseq 'adxmso       = 15'
 Wrseq 'adxmto       = 90'
 Wrseq 'maxmem       = 8192'
 Wrseq 'adxtct       = "APLCOM"'
 Wrseq 'adxtlk       = "APLLCK"'
 Wrseq 'adxtms       = "APLSTD"'
 Openo
Endif
Case TYPDBA
 When 1
  ORDSYS = "adxora -b"+BASE-"-u"-USER-"-p"-PASSE-APPLI
 When 2
#  ORDSYS = "adxodbc -b"-BASE-"-d"-SOURCE-"-u"-USER-"-p"-PASSE-APPLI
#   Bug 47847 : Détermination de la source de données ODBC si SQL serveur        - CC  21/01/2010
  ORDSYS = "adxodbc -d"-SOURCE-"-u"-USER-"-p"-PASSE-APPLI
Endcase
Call SYSTEME(MACHINE+":"+num$(SERVICE),ORDSYS,"",STAT) From ORDSYS
OK = 1
adxifs = SAVIFS
adxirs = SAVIRS
End

#----------------------------------------------------------------------#
Subprog EFFACFIC(NOMFIC)
Value Char NOMFIC

Local Char    SUPER(GLONADS) , FICPAR(250)
Local Integer STAT

Call PARAM("","SUPDOS",SUPER) From ADOVAL
FICPAR = filpath("",NOMFIC,"par",SUPER)
Call EFFACE(FICPAR,STAT) From ORDSYS
End

#----------------------------------------------------------------------#
Subprog RECHPAR(MACHINE,PORT,REP,VERSION,PLATFORM,TBAS,NOMBAS,SQLINST)
#
# Recherche des informations dans le fichier solution

Value Char MACHINE,REP
Value Integer PORT
Variable Char NOMBAS,SQLINST
Variable Integer VERSION,PLATFORM,TBAS

Local Char NOMFIC(200),VALL1(200),VALL2(20)
Local Integer I1,I2,TYPD
Local Char SEP,SOLUTION(20),AVERSION,SQLODBC(100),FORCEDBLINK,DBLINK(100),NAMEMAIN(100)
Local Integer TBAS
SEP="/"
If instr(1,REP,"\")<>0 : SEP="\" : Endif
NOMFIC=MACHINE+":"+num$(PORT)+"@"+REP+SEP+"solution.xml"
If filinfo(NOMFIC,7)<0 : VERSION=130 : End : Endif
VERSION=140
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"<solution")<>0
    I1=instr(1,VALL1,"name")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Elsif instr(1,VALL1,"<module") and instr(1,VALL1,'family="RUNTIME"')<>0  and instr(1,VALL1,'type="MAIN"')<>0
    I1=instr(1,VALL1,"name=")
    I2=instr(I1+7,VALL1,'" ')
    If I2-I1-1>0
      NAMEMAIN=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Elsif instr(1,VALL1,"component.application.version")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      AVERSION=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
      If left$(AVERSION,1)="V"
        VERSION=val(right$(AVERSION,2))
      Else
        VERSION=val(AVERSION)
      Endif
    Endif
  Elsif instr(1,VALL1,"runtime.odbc.forcedblink")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      FORCEDBLINK=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"runtime.odbc.dblink")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      DBLINK=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"component.application.platform")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      VALL2=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
    Case toupper(VALL2)
      When "UNIX"  : PLATFORM=1
      When "WIN32" : PLATFORM=2
      When "LINUX" : PLATFORM=3
      When Default : PLATFORM=1
    Endcase
  Elsif instr(1,VALL1,'family="DATABASE"')<>0
    I1=instr(1,VALL1,"type")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      VALL2=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
    Case VALL2
      When "ORACLE"    : TBAS=1
      When "SQLSERVER" : TBAS=2
    Endcase
  Elsif TBAS=1 and instr(1,VALL1,"database.adonix.orasid")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlbase")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlodbc")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      SQLINST=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Endif
Wend

Openi Using [CST_]

#   Bug 47847 : Détermination de la source de données ODBC si SQL serveur        - CC  21/01/2010
If TBAS=2 and SQLINST=""
  If (toupper(FORCEDBLINK)="ON" or toupper(FORCEDBLINK)="TRUE") and DBLINK<>""
    SQLINST=DBLINK
  Else
    SQLINST=NAMEMAIN
  Endif
Endif

End

$ERRLEC
Resume

#----------------------------------------------------------------------#
Subprog C_BAS(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Effzo SRC : Grizo SRC
Else
 Actzo SRC
Endif
End

Subprog AS_NBLIG
Gosub AFFLIEN
End

Subprog C_LIENCPT(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=2
  For I=1 To [M]NBLIG
    If [M]ALIENCPT(I-1)=2 and nolign<>I
      GMESSAGE = mess(218,133,1) : # Type de lien déjà défini pour ce dossier
      mkstat = 2 : End
    Endif
  Next I
  [M]NOMF="compta"
  Affzo NOMF
  Diszo NOMF
Else
  Actzo NOMF
Endif
End

Subprog C_NOMF(VALEUR)
Variable Char    VALEUR()

Local Integer I,DEB
VALEUR=vireblc(VALEUR,4)
If [M]LIENCPT<>2 and VALEUR="compta"
  GMESSAGE = mess(219,133,1) : # Nom réservé pour le lien comptabilité
  mkstat = 2 :  End
Endif
If VALEUR="liens"
  GMESSAGE = mess(220,133,1) : # Répertoire déjà existant
  mkstat = 2 :  End
Endif
For I=1 To [M]NBLIG
  If [M]ANOMF(I-1)=VALEUR and nolign<>I
    GMESSAGE = mess(221,133,1)-num$(I) : # Le répertoire distant n'a pas pu être crée
    mkstat = 2 : End
  Endif
Next I
End

Subprog AP_LIENCPT(VALEUR)
Variable Integer VALEUR
[M]ALIENCPT(nolign-1)=VALEUR
End

Subprog AP_NOMF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]ANOMF(nolign-1) and [M]ANOMF(nolign-1)<>""
  Call EFFACFIC(ANOMF(nolign-1))
Endif
[M]ANOMF(nolign-1)=VALEUR
End

Subprog AP_MAC(VALEUR)
Variable Char    VALEUR()
[M]AMAC(nolign-1)=VALEUR
End

Subprog AP_SRV(VALEUR)
Variable Decimal VALEUR
[M]ASRV(nolign-1)=VALEUR
End

Subprog AP_REP(VALEUR)
Variable Char    VALEUR()
[M]AREP(nolign-1)=VALEUR
End

Subprog AP_OS(VALEUR)
Variable Integer VALEUR
[M]AOS(nolign-1)=VALEUR
End

Subprog AP_BAS(VALEUR)
Variable Integer VALEUR
[M]ABAS(nolign-1)=VALEUR
End

Subprog AP_DBA(VALEUR)
Variable Char    VALEUR()
[M]ADBA(nolign-1)=VALEUR
End

Subprog AP_SRC(VALEUR)
Variable Char    VALEUR()
[M]ASRC(nolign-1)=VALEUR
End

Subprog AP_USR(VALEUR)
Variable Char    VALEUR()
[M]AUSR(nolign-1)=VALEUR
End

Subprog AP_PWD(VALEUR)
Variable Char    VALEUR()
[M]APWD(nolign-1)=VALEUR
End

Subprog C_NBLIG
# Suppression d'une ligne
If status=65 or status=83
  Call EFFACFIC(ANOMF(nolign-1))
Endif
End

Subprog AM_REP(VALEUR)
Variable Char    VALEUR()
# On recherche les paramètres si il n'ont pas été saisis
If [M]DBA=""
  Local Char TBAS,NOMBAS,SQLINST
  Local Integer VERSION,PLATFORM,TBAS
  Call RECHPAR([M]MAC,[M]SRV,VALEUR,VERSION,PLATFORM,TBAS,NOMBAS,SQLINST)
  If VERSION >=140
    [M]OS=PLATFORM
    [M]BAS=TBAS
    [M]DBA=NOMBAS
    [M]SRC=SQLINST
    Affzo OS,BAS,DBA,SRC
  Endif
Endif
End

