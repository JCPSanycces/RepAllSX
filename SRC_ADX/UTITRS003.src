#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
# UTITRS003   Modification du champ ACCNONREI, positionné initialement    #
#             dans la table BPARTNER, et maintenant dans la table BID     #
#             La moulinette consiste à récupérer le contenu initial de    #
#             BPARTNER vers BID                                           #
# Moulinette exécutée depuis le dossier applicatif                        #
###########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  
    Call TEMPON("O") From GESECRAN
    If !GSERVEUR
      Call OUVRE_TRACE("Moulinette UTITRS003") From LECFIC
    Endif
  
    If nomap<>GDOSX3 Then
      Call MAJ_ACCNONREI(nomap)
    Else
      Local Integer OK
      Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
      If OK<>2 : End : Endif
      If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
      For [ADS]
        If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
          Call MAJ_ACCNONREI([F:ADS]DOSSIER)
        Endif
      Next
    Endif

    Call TEMPOFF From GESECRAN
    If !GSERVEUR
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
    Endif
  Endif
End

Subprog MAJ_ACCNONREI(DOSSIER)
Value Char    DOSSIER
Local Integer GOK, COMPTEUR, I, NBPA

  Call ECR_TRACE("UTITRS003 : Process Start on : "+DOSSIER,0) From GESECRAN

  If clalev([F:BPR])>0 Close Local File [BPR] : Endif
  Local File =DOSSIER+".BPARTNER" [BPR]
  If clalev([F:BID])>0 Close Local File [BID] : Endif
  Local File =DOSSIER+".BID" [BID]
  If clalev([F:ATZ])>0 Close Local File [ATZ] : Endif
  Local File =DOSSIER+".ATABZON" [ATZ]
  If clalev([F:ADA])>0 Close Local File [ADA] : Endif
  Local File =GDOSX3+".ADOSACT" [ADA]

  Read [F:ADA]ADA0=DOSSIER;"BPA"
  If !fstat Then
    NBPA=[F:ADA]DIME
  Endif
  Trbegin [F:BID] : GOK=1 : COMPTEUR=0
  If dim([F:BPR]ACCNONREI)>0 and dim([F:BID]ACCNONREI)>0 Then
    # FQ73686 - MABON 06/05/11 - Vérif dimension champ BPARTNER.ACCNONREI
    Read [F:ATZ]CODZONE="BPARTNER";"ACCNONREI"
    If !fstat Then
      If [F:ATZ]CODACT<>"" Then
      # Fin MABON
        For [F:BPR] Where ACCNONREI(0)<>""
          For I=0 To NBPA-1
            If [F:BPR]ACCNONREI(I)<>"" Then
              Filter [F:BID] Where BPATYP=1 and BPANUM=[F:BPR]BPRNUM and BPAADD=[F:BPR]ACCNONREI(I)
              For [F:BID]
                [F:BID]ACCNONREI=2
                Rewrite [F:BID] 
                If fstat Then 
                  GOK=0 : Break
                Else
                  COMPTEUR += 1         
                Endif
              Next
            Else
              Break
            Endif
          Next
        Next
      Endif
    Endif
  Endif
  
$FIN
  If GOK=1
    Commit
  Else
    Rollback
  Endif
 
  #----- Fin du traitement -----#
  Call ECR_TRACE("UTITRS003 : "+num$(COMPTEUR)+" records processed on " + DOSSIER,0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
#  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","BID","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPARTNER","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_ACCNONREI(APPLI)        
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
#  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","BID","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPARTNER","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_ACCNONREI(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

#  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","BID","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPARTNER","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_ACCNONREI(APPLI)
End
