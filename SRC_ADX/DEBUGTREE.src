Subprog GENTREE()

Local File ASHW [ASHW]

Local Integer I : I = 1
Local Clbfile OUTPUT(3)


For [ASHW]

OUTPUT = OUTPUT + ";" + num$([ASHW]CODREP) + "," + num$([ASHW]INTREP) + "," + num$(CODACT) + "," + num$(MODULE)

If I = 5
Break
Endif

I = I + 1

Next


Call DEBUG_TRACE(1, "TREE", OUTPUT) From DEBUGTRACE


End

