############################################################################
# Test de la saisie du code paramètre AUSCRMI
#
# Module CRM                                                24 Novembre 2003
############################################################################

Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value Char PARAM
Value Char TSTVALEUR
Variable Integer OK
OK= 1

If PARAM <> "AUSCRMI"
    #Erreur dans le code paramètre
    GMESSAGE = mess(204, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If TSTVALEUR = "" : End : Endif

If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif

Read [ADI] CODE = 452;TSTVALEUR
If fstat
    #La valeur saisie pour ce paramètre n'est pas définie dans la table diverse 452.
    GMESSAGE = mess(718, 182, 2)
    GERR = 1
    OK = 0
    End
Endif

End







