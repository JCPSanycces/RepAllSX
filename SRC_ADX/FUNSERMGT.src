#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","FUNSERMGT","ISERMGT",3,"") From GTRAITE
End

#########################################################################
# Utilitaire de modification du mode de gestion des numéros de séries   #
#                                                                       #
#     - Traitement : FUNSERMGT                                          #
#     - Action     : SAISERMGT (Traitement standard)                    #
#                                                                       #
#########################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "TERMINE" : Gosub TERMINE
 When Default
Endcase
Return

$INIT
Local Char WCRIT(150)

If clalev([F:ITM])=0  : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])=0  : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:STO1])=0 : Local File STOCK      [STO1] : Endif
If clalev([F:STO]) =0 : Local File STOCK      [STO]  : Endif
If clalev([F:STS]) =0 : Local File STOSER     [STS]  : Endif
If clalev([F:STJ]) =0 : Local File STOJOU     [STJ]  : Endif
If clalev([F:STA]) =0 : Local File STOALL     [STA]  : Endif
If clalev([F:SRG]) =0 : Local File STOSRG     [SRG]  : Endif
Return

$EXEC
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(mess(487,184,1),0) From GESECRAN
Else
  Call OUVRE_TRACE(mess(487,184,1)) From LECFIC
Endif

Call ECR_TRACE(mess(487,184,1),0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("SERMGT","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

WCRIT  = "[F:ITM]ITMREF>=[M]ITMREFSTR&[F:ITM]ITMREF<=[M]ITMREFEND"
WCRIT += "&[F:ITM]SERMGTCOD=[M]OLDSERMGT"

For [ITM]ITM0 Where evalue(WCRIT)
  Gosub CHG_SERMGTCOD
Next

Return

$TERMINE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3
Endif
Return

#------------------------------------------------
# Traitement du changement de gestion des séries
#------------------------------------------------
$CHG_SERMGTCOD
Local Decimal  LSTOCOU
Local Char     WPARAM
Local Integer  WRET

WRET=0

If [F:ITM]NEGSTO=2
  Call ECR_TRACE ([F:ITM]ITMREF-mess(665,199,1)-":"-mess(666,199,1),1) From GESECRAN
  Return
Endif

# Il ne doit pas y avoir d'inventaire en  cours
Filter [ITF] Where ITMREF=[F:ITM]ITMREF & CUNLISNUM<>"" Order By Key ITF0
If rowcount([ITF])>0
  Call ECR_TRACE ([F:ITM]ITMREF-mess(185,199,1),1) From GESECRAN
  Filter [ITF]
  Return
Endif
Filter [ITF]

# Il ne doit pas y avoir de contrôle qualité en cours
Filter [STO] Where ITMREF=[F:ITM]ITMREF & QLYCTLDEM<>""
If rowcount([STO])>0
  Call ECR_TRACE ([F:ITM]ITMREF-mess(218,187,1)+"\"+mess(460,199,1),1) From GESECRAN
  Filter [STO]
  Return
Endif
Filter [STO]

# Il ne doit pas y avoir de quantité en cours de traitement
Filter [STO] Where ITMREF=[F:ITM]ITMREF & CUMWIPQTA<>0
If rowcount([STO])>0
  Call ECR_TRACE ([F:ITM]ITMREF-mess(218,187,1)+"\"+mess(488,199,1),1) From GESECRAN
  Filter [STO]
  Return
Endif
Filter [STO]

# Il ne doit pas y avoir d'allocations en  cours
Filter [STA] Where ITMREF=[F:ITM]ITMREF & (ALLTYP=2 | ALLTYP=4) Order By Key STA2
If rowcount([STA])>0
  Call ECR_TRACE ([F:ITM]ITMREF-mess(90,192,1),1) From GESECRAN
  Filter [STA]
  Return
Endif
Filter [STA]

# Il ne doit pas y avoir de stock en attente de rangement
Filter [SRG] Where ITMREF=[F:ITM]ITMREF
If rowcount([SRG])>0
  Call ECR_TRACE ([F:ITM]ITMREF-mess(218,187,1)+"\"+mess(378,199,1),1) From GESECRAN
  Filter [SRG]
  Return
Endif
Filter [SRG]

Trbegin [STS]
#--- Passage gestion E/S à gestion E/S globale
If [M]OLDSERMGT=3 & [M]NEWSERMGT=4

  # Boucle de traitement des no séries
  For [STS] Where ITMREF=[F:ITM]ITMREF
    # Si no série en stock
    If [F:STS]ISSDAT=[0/0/0]
      # Lecture stock correspondant au no série
      Read [STO1]STO5=[F:STS]ITMREF;[F:STS]SERNUM
      If !fstat
        #--- Issue X3-53322 : ajout LPN
        Call CLESTO([F:STO1]STOFCY,[F:STO1]ITMREF,[F:STO1]LOT,[F:STO1]SLO,[F:STO1]BPSLOT,
&                   [F:STO1]PALNUM,[F:STO1]CTRNUM,[F:STO1]STA,[F:STO1]LOC,
&                   [F:STO1]PCU,[F:STO1]PCUSTUCOE,"",[F:STO1]QLYCTLDEM,[F:STO1]OWNER,
&                   [F:STO1]STOFLD1,[F:STO1]STOFLD2,[F:STO1]LPNNUM,LSTOCOU) From STKLIB
        # Pas de stock correspond au stock du no série
        If [L]LSTOCOU=0
          # Attribution du chrono stock
          Call NUMERO(GSTKCPT(0),[F:STO1]STOFCY,date$,"",[L]WPARAM,[L]WRET) From SUBANM
          If [L]WRET<>0
            Call ECR_TRACE([F:ITM]ITMREF-":"-GSTKCPT(0)-mess(60,199,1),1) From GESECRAN : Break
          Endif
          [L]LSTOCOU = val(WPARAM)
          # Chargement et écriture nouvelle ligne de stock
          Raz [F:STO]
          [F:STO] = [F:STO1]
          [F:STO]STOCOU = [L]LSTOCOU
          [F:STO]SERNUM = ""
          Call ECRSTO("",[L]WRET) From STKLIB
          If [L]WRET<>0
            Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
            Break
          Endif
        # Il y a déjà du stock correspond au stock du no série
        Else
          Readlock [STO] STO0=[F:STO1]STOFCY;[L]LSTOCOU With lockwait=3
          If fstat
            Call ECR_TRACE([F:ITM]ITMREF-":"-mess(12,100,1)-"STOCK",1) From GESECRAN
            [L]WRET=1 : Break
          Else
            # Cumul du stock du no série sur ce stock
            [F:STO]QTYPCU   +=[F:STO1]QTYPCU
            [F:STO]QTYSTU   +=[F:STO1]QTYSTU
            [F:STO]QTYSTUACT+=[F:STO1]QTYSTUACT
            [F:STO]CUMALLQTY+=[F:STO1]CUMALLQTY
            [F:STO]CUMALLQTA+=[F:STO1]CUMALLQTA
            [F:STO]QTYPCUORI+=[F:STO1]QTYPCUORI
            [F:STO]QTYSTUORI+=[F:STO1]QTYSTUORI
            Call REWSTO("",[L]WRET) From STKLIB
            If [L]WRET<>0
              Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
              Break
            Endif
          Endif
        Endif
        # Maj allocation sur ce no série si nécessaire
        #Read [STA]STA0(3)=[F:STO1]STOFCY;[F:STO1]ITMREF;[F:STO1]STOCOU
        #If !fstat
        #  [F:STA]STOCOU = [L]LSTOCOU
        #  [F:STA]SERNUM = [F:STS]SERNUM
        #  Rewrite [STA]
        #  If fstat
        #    Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOALL",1) From GESECRAN
        #    [L]WRET=1 :  Break
        #  Endif
        #Endif
        # Suppression de la ligne de stock du no série
        Delete [STO1]
        If fstat
          Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
          [L]WRET=1 : Break
        Endif
        # Mise à jour du no série avec le chrono stock
        [F:STS]STOCOU = [L]LSTOCOU
        Rewrite [STS]
        If fstat
          Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOSER",1) From GESECRAN
          [L]WRET=1 : Break
        Endif
      Else
        Call ECR_TRACE([F:ITM]ITMREF-[F:STS]SERNUM-":"-mess(12,100,1)-"STOCK",1) From GESECRAN
        [L]WRET=1 : Break
      Endif
    Endif

    # Maj des mouvements de stock de ce no série
    Filter [STJ] Where ITMREF=[F:ITM]ITMREF & SERNUM=[F:STS]SERNUM
&                Order By Key STJ4
    For [STJ]
      [F:STJ]SERNUM=""
      [F:STJ]SERDEB=[F:STS]SERNUM
      [F:STJ]SERFIN=[F:STS]SERNUM
      Rewrite [STJ]
    Next
    Filter [STJ]

  Next

#--- Passage gestion E/S globale à gestion E/S
Elsif [M]OLDSERMGT=4 & [M]NEWSERMGT=3

  # Boucle de traitement des no séries
  For [STS] Where ITMREF=[F:ITM]ITMREF & ISSDAT=[0/0/0]
    # Lecture stock correspondant au no série
    Readlock [STO1]STO0=[F:STS]STOFCY;[F:STS]STOCOU With lockwait=3
    If !fstat
      # Attribution du chrono stock
      Call NUMERO(GSTKCPT(0),[F:STO1]STOFCY,date$,"",[L]WPARAM,[L]WRET) From SUBANM
      If [L]WRET<>0
        Call ECR_TRACE([F:ITM]ITMREF-":"-GSTKCPT(0)-mess(60,199,1),1) From GESECRAN : Break
      Endif
      [L]LSTOCOU = val(WPARAM)
      # Chargement et écriture nouvelle ligne de stock
      Raz [F:STO]
      [F:STO] = [F:STO1]
      [F:STO]STOCOU = [L]LSTOCOU
      [F:STO]SERNUM = [F:STS]SERNUM
      [F:STO]QTYPCU = 1
      [F:STO]QTYSTU = 1
      [F:STO]QTYSTUACT = 1
      [F:STO]QTYPCUORI = 1
      [F:STO]QTYSTUORI = 1
      # Le no série est alloué
      #If find([F:STS]SDHTYP,2,3,4,5,8,10,36,40)
      #  [F:STO]CUMALLQTY = 1
      #  [F:STO]CUMALLQTA = 1
      #Else
        [F:STO]CUMALLQTY = 0
        [F:STO]CUMALLQTA = 0
      #Endif
      Call ECRSTO("",[L]WRET) From STKLIB
      If [L]WRET<>0
        Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
        Break
      Endif

      # Maj du stock origine du no série
      If [F:STO1]QTYSTU>1
        # Réécriture de la ligne de stock origine
        [F:STO1]QTYPCU    -= 1
        [F:STO1]QTYSTU    -= 1
        [F:STO1]QTYSTUACT -= 1
        [F:STO1]CUMALLQTY -= [F:STO]CUMALLQTY
        [F:STO1]CUMALLQTA -= [F:STO]CUMALLQTA
        [F:STO]QTYPCUORI  -= 1
        [F:STO]QTYSTUORI  -= 1
        [F:STO1]EXPNUM = [C]EXPORT
        [F:STO1]UPDUSR = GUSER
        [F:STO1]UPDDAT = date$
        Rewrite [STO1]
        If fstat
          Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
          [L]WRET=1 : Break
        Endif
      Else
        # Suppression de la ligne de stock origine
        Delete [STO1]
        If fstat
          Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOCK",1) From GESECRAN
          [L]WRET=1 : Break
        Endif
      Endif

      # Mise à jour du no série avec raz du chrono stock
      [F:STS]STOCOU = 0
      Rewrite [STS]
      If fstat
        Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"STOSER",1) From GESECRAN
        [L]WRET=1 : Break
      Endif

      #---
      # Voir ce qu'il faut faire pour la maj des mouvements de stock de ce no série
      # --> à priori rien, on conserve les mouvements tels quels
      # --> il faut interdire leur accés dans les moteurs de modifications de stock
      #     et modifier les consultations pour les visualiser correctement
      #---

    Else
      Call ECR_TRACE([F:ITM]ITMREF-":"-mess(12,100,1)-"STOCK",1) From GESECRAN
      [L]WRET=1 : Break
    Endif
  Next

Endif

If [L]WRET=0
  [F:ITM]SERMGTCOD = [M]NEWSERMGT
  Rewrite [ITM]
  If fstat
    Call ECR_TRACE([F:ITM]ITMREF-":"-mess(13,100,1)-"ITMMASTER",1) From GESECRAN
    [L]WRET=1
  Endif
Endif

If [L]WRET=0
  Call ECR_TRACE([F:ITM]ITMREF-":"-mess(488,184,1)-"="-mess([M]NEWSERMGT,210,1),0) From GESECRAN
  Commit
Else
  Rollback
Endif

Return


###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#########################################################################
# Gestion du masque SERMGT                                              #
#########################################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND=[M]ITMREFSTR | [M]ITMREFEND<VALEUR
  [M]ITMREFEND = VALEUR
  Affzo [M]ITMREFEND
Endif
End

Subprog AS_OLDSERMGT(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(4)=1
End

Subprog AM_OLDSERMGT(VALEUR)
Variable Integer VALEUR
If VALEUR=3
  [M]NEWSERMGT=4
Elsif VALEUR=4
  [M]NEWSERMGT=3
Endif
End

Subprog AS_NEWSERMGT(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
End

Subprog AM_NEWSERMGT(VALEUR)
Variable Integer VALEUR
If VALEUR=3
  [M]OLDSERMGT=4
Elsif VALEUR=4
  [M]OLDSERMGT=3
Endif
End

