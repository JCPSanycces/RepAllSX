#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################################
#
# -- Interface V5 --
#
#     Sage X3 Entreprise
#
#     Gestion de la trÃĐsorerie des flux financiers
#

#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)
##################################################################################################
#
#  Code ActivitÃĐ CAS
#
#    ParamÃĻtre EXPCASDUD  : Export trÃĐso Sage - EchÃĐances
#    ParamÃĻtre EXPCASPAY  : Export trÃĐso Sage - RÃĻglements
#    ParamÃĻtre CASTREGDUD : Code statut  - EchÃĐances
#
#  Ecran, Fenetre, Action : EXPCASPAY
#
##################################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Local Integer TST
Call TRAITE_CHAR(VALEUR,PARAM,"","EXPCASPAY","EXPCASPAY",4,"") From GTRAITE
End

######################################################################
$ACTION
Case ACTION

 When "INIT"        : Gosub INIT

 When "DEBUT"       : Gosub DEBUT
 When "BOUTON"      : Gosub BOUTON

 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE


 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0

 When "OUVRE_BATCH" : Gosub OUVRE_BATCH

 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE

Endcase
Return

######################################################################
$INIT
$OUVRE_BATCH
If !clalev([M:PAD]) : Local Mask EXPCASPAY [PAD] : Endif
Return

$DEBUT
If GCONSDIA : Return : Endif
Raz [M:PAD]
Call LECMEMO("STD","[M:PAD]","ca1") From GMEMO

#-- Recherche du rÃĐpertoire
Local Char REPFIC(GDIMFIC)
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 Local Integer LCASIN : # X3-104535
 LCASIN = func AFNC.ACTIV("CASIN")
 If LCASIN = G_OUI
  Call PARAMUTIL("EXPCASPAY",[L]REPFIC,"","") From SUBAUS
 Endif : # X3-104535

 If [L]REPFIC<>"" & left$(REPFIC,1)="["
  [M]VOLFIL = [L]REPFIC
 Else
  [M]VOLFIL = "["+GDIRCASH+"]"
 Endif
Endif
Actzo [M]VOLFIL
Affzo [PAD] : Gosub GRISE
Return

######################################################################
$BOUTON
Case BOUT
 When "R" : # Rappel
  Gosub GRISE :  Affzo [M:PAD]
Endcase
Return

######################################################################
$CONTROLE
If GOK=0 : FIN=1 : Return : Endif
If !GSERVEUR & [M]TRC=2 : TRA=1 : Endif
TMP = 0
Return

######################################################################
$EXEC
Local Integer NUMREQ, NUMOPE, NBRFIC
Local Char    EXPSNS(1),EXT(5), OS(10)
Local Char    NOMFIC(GDIMFIC), FICHIER(GDIMFIC) , CHEMIN(GDIMFIC) , MACHINE(GDIMFIC), FIC(GDIMFIC), REPERT(GDIMFIC)
Local Decimal AMT1,AMT2
Local Char    EXPAMT1(16), EXPAMT2(16)

If !clalev([PCH]) : Local File PYHCAS     [PCH] : Endif
If !clalev([TPY]) : Local File TABPAYTYP  [TPY] : Endif
If !clalev([TFC]) : Local File TABFILCASH [TFC] : Endif
If !clalev([PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([TCU]) : Local File TABCUR     [TCU] : Endif

# Initialisation des varaible de fichiers
adxifs = ""                    : # adxifs, sÃĐparateur de champ
adxirs = chr$(13)+chr$(10)     : # adxirs, sÃĐparateur d'enregistrement
adxium = GUTF8                 : # adxium, mode de codage. (50=Fichier ASCII)
EXT    = "txt"                 : # Extension du fichier

# Variables pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT
Call MACHINE([M]FIC,MACHINE,CHEMIN) From ORDSYS
Gosub FILTRE
Case num$([M]SIM)
 When "1" : Gosub TRTREL
 When "2" : Gosub TRTSIM
 When "3" : Gosub TRTREG
Endcase

If !NBRFIC
 If !GSERVEUR
  # Aucune rÃĻglement Ã  proposer
  Call ERREUR(mess(4,173,1)) From GESECRAN
 Endif
 If GTRACE<>""
  # Aucune rÃĻglement Ã  proposer
  Call ECR_TRACE(mess(4,173,1),0) From GESECRAN
 Endif
 SAI = 1
Endif
Return

######################################################################
$TRTREL

Link [PCH] With [TPY]TPY0=[F:PCH]PAYTYP
&     As [LNK]
&     Order By Key CLE = [F:TPY]FICCAS;[F:PCH]TRECOD;[F:PCH]CUR;[F:PCH]ACCNUM;[F:PCH]REGNUM

Filter [LNK] Where evalue(FILTRE)

GOK = 1 : GTRANS=1
Trbegin [PCH]
NUMREQ = uniqid([PCH])

Raz NBRFIC
For [LNK]CLE(1)

 NBRFIC +=1

 NOMFIC  = [TPY]FICCAS+format$("N0:8",NUMREQ)
 If [M]TYPEXP=1 : # Client
  FICHIER = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
  Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
 Else
  FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
 Endif

 Openo FICDON,0

 For [LNK]CLE(4)
  Raz NUMOPE,AMT1,AMT2
  For [LNK]CLE(5)
   NUMOPE+=1
   AMT2+=[F:PCH]AMTCUR
   For [LNK]CLE
    AMT1+=[F:PCH]AMTBAN
    Gosub MAJ
   Next
  Next

  If func AFNC.ACTIV("SFRPT")

   # Recherche du sens de l'ÃĐchÃĐance
   If [F:PCH]SNS>0
    If AMT2>0 : EXPSNS = "C" : Else EXPSNS = "D" : Endif
   Else
    If AMT2>0 : EXPSNS = "D" : Else EXPSNS = "C" : Endif
   Endif

   # Arrondi
   Call EXP_AMT(AMT1,[F:PCH]CURBAN,EXPAMT1)
   If [F:PCH]CUR=[F:PCH]CURBAN & AMT1=AMT2
    EXPAMT2=EXPAMT1
   Else
    Call EXP_AMT(AMT2,[F:PCH]CUR,EXPAMT2)
   Endif


   # Lignes
   Wrseq format$("K:12X",[F:PCH]TRECOD);        : # 1) SOCIETA   : SociÃĐtÃĐ
                                                : # 2) BANCA     : Banque(vide)
                                                : # 3) CONTO     : Compte (vide)

   Wrseq EXPSNS+format$("K:5X",[F:PCH]PAYTYP);  : # 4) CAUSALE   : Code support
   Wrseq format$("N:16F",EXPAMT1);              : # 5) IMPORTO   : Montant devise compte (vide)
   Wrseq format$("N:16F",EXPAMT2);              : # 6) IMPDIVIA  : Montant devise opÃĐration


  Else
   # Recherche du sens de l'ÃĐchÃĐance
   If [F:PCH]SNS>0
    If AMT2>0 : EXPSNS = "R" : Else EXPSNS = "D" : Endif
   Else
    If AMT2>0 : EXPSNS = "D" : Else EXPSNS = "R" : Endif
   Endif


   # Lignes
   Wrseq format$("K:16X",[F:PCH]TRECOD);        : # 1) SOCIETA   : SociÃĐtÃĐ
                                                : # 2) BANCA     : Banque(vide)
                                                : # 3) CONTO     : Compte (vide)

   Wrseq EXPSNS+format$("K:5X",[F:PCH]PAYTYP);  : # 4) CAUSALE   : Code support
   Wrseq format$("N:16F",abs(AMT1));            : # 5) IMPORTO   : Montant devise compte (vide)
   Wrseq format$("N:16F",abs(AMT2));            : # 6) IMPDIVIA  : Montant devise opÃĐration

  Endif


  Wrseq format$("K:3X",[F:PCH]ISOCOD);         : # 7) DIVISA    : Devise opÃĐration
  Wrseq format$("D:DDMMYYYY",[F:PCH]DOPE);     : # 8) DOPE      : Date d'opÃĐration

  If !func AFNC.ACTIV("SFRPT")
   Wrseq format$("D:DDMMYYYY",[F:PCH]VALDAT);   : # 9) DVAL      : Date de valeur
  Endif

  Wrseq format$("N0:4",[L]NUMOPE);             : # 10) NUMOPE   : Nombre d'opÃĐrations

  # Formules...
  # DiffÃĐrence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
  If func AFNC.ACTIV("SFRPT")
   Wrseq format$("K:32X",[F:PCH]DESCR);         : # 11) DESCR    : Commentaire
   Wrseq format$("K:16X",[F:PCH]REFXRT);        : # 12) REFXRT   : Code rÃĐfÃĐrence
   Wrseq
  Elsif func AFNC.ACTIV("T1000")
   Wrseq format$("K:128X",[F:PCH]TRANS);        : # 11) TRANS    : Transfert
   Wrseq format$("K:128X",[F:PCH]DESCR);        : # 12) DESCR    : Commentaire
   Read [F:TFC]TFC1=9;"REF";[F:PCH]PAYTYP
   If !fstat
    Wrseq format$("K:128X",[F:PCH]REF);         : # 13) REF      : NumÃĐro de chÃĻque
   Else
    Read [PYH]PYH0 = [F:PCH]REGNUM
    If !fstat
     Wrseq format$("K:128X",[F:PYH]CHQNUM);
    Else
     Wrseq format$("K:128X",[F:PCH]REF);
    Endif
   Endif
   Wrseq format$("K:128X",[F:PCH]LCR);          : # 14) LCR      : Type LCR
   Wrseq format$("K:128X",[F:PCH]BUDG);         : # 15) BUDG     : Code budget
   Wrseq
  Else
   # RÃĐ-ÃĐvaluation du numÃĐro de chÃĻque si non paramÃĐtrÃĐ
   Read [F:TFC]TFC1=9;"NASS";[F:PCH]PAYTYP
   If !fstat
    Wrseq format$("K:8X",[F:PCH]NASS);          : # 11) NASS     : NumÃĐro de chÃĻque
   Else
    Read [PYH]PYH0 = [F:PCH]REGNUM
    If !fstat
     Wrseq format$("K:8X",[F:PYH]CHQNUM);
    Else
     Wrseq format$("K:8X",[F:PCH]NASS);
    Endif
   Endif
   Wrseq format$("K:16X",[F:PCH]CPTA);          : # 12) CPTA     : Code nature
   Wrseq format$("K:16X",[F:PCH]CDC);           : # 13) CDC      : Code annexe
   Wrseq format$("K:32X",[F:PCH]DESCR);         : # 14) DESCR    : Commentaire
   Wrseq format$("K:8X",[F:PCH]CODRIF);         : # 15) CODRIF   : Code rÃĐfÃĐrence
   Wrseq
  Endif

  # Mise Ã  jour de la ligne
  #Gosub MAJ
 Next
 Openo
 If [M]TYPEXP=1
  Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
  If STAT=1
   # Fichier non copiÃĐ sur le poste client
   Call ERREUR(mess(164,141,1)) From GESECRAN
   FIN=1 : Goto AB_TRTREL
  Elsif STAT>1
   # Fichier inexistant
   Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
   FIN=1 : Goto AB_TRTREL
  Endif
 Endif
Next

Commit
GTRANS=0
Return

$MAJ
[F:PCH]NUMPCH = [L]NUMREQ
[F:PCH]DATPCH = date$
[F:PCH]FIC    = [L]NOMFIC
[F:PCH]FLG    = 2
Rewrite [PCH]
If fstat
 GOK = 0 : Call FSTA("PCA") From GLOCK : Goto ROLL_TRTREL
Endif
Return

$ROLL_TRTREL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else Goto TRTREL : Endif

$AB_TRTREL
Rollback : Return


######################################################################
$TRTSIM
Local Decimal AMTR,AMTD
Call OUVRE_TRACE("") From LECFIC
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

If [M]GRPCPY<>""
 Call LECTURE("AGF",[M]GRPCPY,"") From  CONTOBJ
 Call ECR_TRACE(mess(3,173,1)-[M]GRPCPY-[F:AGF]DES,0) From GESECRAN : # PÃĐrimÃĻtre
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

Link [PCH] With [TPY]TPY0=[F:PCH]PAYTYP
&     As [LNK]
&     Order By Key CLE = [F:TPY]FICCAS;[F:PCH]TRECOD;[F:PCH]PAYTYP;[F:PCH]DOPE;[F:PCH]CURBAN;[F:PCH]REGNUM

Filter [LNK] Where evalue(FILTRE)


# DiffÃĐrence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SFRPT")
 # IntitulÃĐ des colonnes : SociÃĐtÃĐ/banque/compte     Flux       Nombre rÃĻglts     Date opÃĐ     Montant devise compte
 LNG =format$("K:25X",mess(7,173,1))+format$("K:15X",mess(20,173,1))+format$("K:20X",mess(9,173,1))+format$("K:20X",mess(10,173,1))+format$("K:15X",mess(11,173,1))
Elsif func AFNC.ACTIV("T1000")
 # IntitulÃĐ des colonnes : SociÃĐtÃĐ/banque/compte     Nature      Nombre rÃĻglts     Date opÃĐ     Montant devise compte
 LNG =format$("K:25X",mess(7,173,1))+format$("K:15X",mess(17,173,1))+format$("K:20X",mess(9,173,1))+format$("K:20X",mess(10,173,1))+format$("K:15X",mess(11,173,1))
Else
 # IntitulÃĐ des colonnes : SociÃĐtÃĐ/banque/compte     Support     Nombre rÃĻglts     Date opÃĐ     Montant devise compte
 LNG =format$("K:25X",mess(7,173,1))+format$("K:15X",mess(8,173,1))+format$("K:20X",mess(9,173,1))+format$("K:20X",mess(10,173,1))+format$("K:15X",mess(11,173,1))
Endif
Call ECR_TRACE(LNG,0) From GESECRAN


Raz NBRFIC
For [LNK]CLE(1)
 NBRFIC+=1
 For [LNK]CLE(5)
  Raz NUMOPE,AMTR,AMTD
  For [LNK]CLE(6)
   NUMOPE+=1
   For [LNK]CLE
    If [F:PCH]SNS>0
     If [F:PCH]AMTBAN>0 : AMTR += abs([F:PCH]AMTBAN) : Else AMTD += abs([F:PCH]AMTBAN) : Endif
    Else
     If [F:PCH]AMTBAN>0 : AMTD += abs([F:PCH]AMTBAN) : Else AMTR += abs([F:PCH]AMTBAN) : Endif
    Endif
   Next
  Next

  # Lignes
  If AMTR>0
    LNG=format$("K:25X",[F:PCH]TRECOD)+
&     format$("K:20X","R"+[F:PCH]PAYTYP)+
&     format$("N0:4",[L]NUMOPE)+
&     format$("K:12X","")+
&     format$("DD2",[F:PCH]DOPE)+
&     format$("N:16F",abs(AMTR))-[F:PCH]CURBAN
     Call ECR_TRACE(LNG,0) From GESECRAN
  Endif
  If AMTD>0
    LNG=format$("K:25X",[F:PCH]TRECOD)+
&     format$("K:20X","D"+[F:PCH]PAYTYP)+
&     format$("N0:4",[L]NUMOPE)+
&     format$("K:12X","")+
&     format$("DD2",[F:PCH]DOPE)+
&     format$("N:16F",abs(AMTD))-[F:PCH]CURBAN
     Call ECR_TRACE(LNG,0) From GESECRAN
  Endif
 Next
Next
Return

######################################################################################
$TRTREG
NUMREQ = [M]REQ

Filter [PCH] Where NUMPCH=[M]REQ
&     Order By Key CLE = [F:PCH]FIC;[F:PCH]TRECOD;[F:PCH]CUR;[F:PCH]ACCNUM;[F:PCH]REGNUM

For [PCH]CLE(1)

 NBRFIC +=1

 If [M]TYPEXP=1 : # Client
  FICHIER = filpath(CHEMIN,[F:PCH]FIC,EXT,"","",MACHINE)
  Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
 Else
  FICDON = filpath(CHEMIN,[F:PCH]FIC,EXT,"","",MACHINE)
 Endif

 Openo FICDON,0

 For [PCH]CLE(4)
  Raz NUMOPE,AMT1,AMT2
  For [PCH]CLE(5)
   NUMOPE+=1
   AMT2+=[F:PCH]AMTCUR
   For [PCH]CLE
    AMT1+=[F:PCH]AMTBAN
   Next
  Next

  If func AFNC.ACTIV("SFRPT")
   # Recherche du sens de l'ÃĐchÃĐance
   If [F:PCH]SNS>0
    If AMT2>0 : EXPSNS = "C" : Else EXPSNS = "D" : Endif
   Else
    If AMT2>0 : EXPSNS = "D" : Else EXPSNS = "C" : Endif
   Endif

   # Arrondi
   Call EXP_AMT(AMT1,[F:PCH]CURBAN,EXPAMT1)
   If [F:PCH]CUR=[F:PCH]CURBAN & AMT1=AMT2
    EXPAMT2=EXPAMT1
   Else
    Call EXP_AMT(AMT2,[F:PCH]CUR,EXPAMT2)
   Endif


   # Lignes
   Wrseq format$("K:12X",[F:PCH]TRECOD);        : # 1) SOCIETA   : SociÃĐtÃĐ
                                                : # 2) BANCA     : Banque(vide)
                                                : # 3) CONTO     : Compte (vide)

   Wrseq EXPSNS+format$("K:5X",[F:PCH]PAYTYP);  : # 4) CAUSALE   : Code support

   Wrseq format$("N:16F",EXPAMT1);              : # 5) IMPORTO   : Montant devise compte (vide)
   Wrseq format$("N:16F",EXPAMT2);              : # 6) IMPDIVIA  : Montant devise opÃĐration

  Else

   # Recherche du sens de l'ÃĐchÃĐance
   If [F:PCH]SNS>0
    If AMT2>0 : EXPSNS = "R" : Else EXPSNS = "D" : Endif
   Else
    If AMT2>0 : EXPSNS = "D" : Else EXPSNS = "R" : Endif
   Endif

   # Lignes
   Wrseq format$("K:16X",[F:PCH]TRECOD);        : # 1) SOCIETA   : SociÃĐtÃĐ
                                                : # 2) BANCA     : Banque(vide)
                                                : # 3) CONTO     : Compte (vide)
   Wrseq EXPSNS+format$("K:5X",[F:PCH]PAYTYP);  : # 4) CAUSALE   : Code support

   Wrseq format$("N:16F",abs(AMT1));            : # 5) IMPORTO   : Montant devise compte (vide)
   Wrseq format$("N:16F",abs(AMT2));            : # 6) IMPDIVIA  : Montant devise opÃĐration

  Endif

  Wrseq format$("K:3X",[F:PCH]ISOCOD);         : # 7) DIVISA    : Devise opÃĐration
  Wrseq format$("D:DDMMYYYY",[F:PCH]DOPE);     : # 8) DOPE      : Date d'opÃĐration

  If !func AFNC.ACTIV("SFRPT")
   Wrseq format$("D:DDMMYYYY",[F:PCH]VALDAT);   : # 9) DVAL      : Date de valeur
  Endif

  Wrseq format$("N0:4",[L]NUMOPE);             : # 10) NUMOPE   : Nombre d'opÃĐrations

  # Formules...
  # DiffÃĐrence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
  If func AFNC.ACTIV("SFRPT")
   Wrseq format$("K:32X",[F:PCH]DESCR);        : # 11) DESCR    : Commentaire
   Wrseq format$("K:16X",[F:PCH]REFXRT);       : # 12) REFXRT   : RÃĐfÃĐrence
   Wrseq
  Elsif func AFNC.ACTIV("T1000")
   Wrseq format$("K:128X",[F:PCH]TRANS);        : # 11) TRANS    : Transfert
   Wrseq format$("K:128X",[F:PCH]DESCR);        : # 12) DESCR    : Commentaire
   Read [F:TFC]TFC1=9;"REF";[F:PCH]PAYTYP
   If !fstat
    Wrseq format$("K:128X",[F:PCH]REF);         : # 13) REF      : NumÃĐro de chÃĻque
   Else
    Read [PYH]PYH0 = [F:PCH]REGNUM
    If !fstat
     Wrseq format$("K:128X",[F:PYH]CHQNUM);
    Else
     Wrseq format$("K:1288X",[F:PCH]REF);
    Endif
   Endif
   Wrseq format$("K:128X",[F:PCH]LCR);          : # 14) LCR      : Type LCR
   Wrseq format$("K:128X",[F:PCH]BUDG);         : # 15) BUDG     : Code budget
   Wrseq
  Else
   # RÃĐ-ÃĐvaluation du numÃĐro de chÃĻque si non paramÃĐtrÃĐ
   Read [F:TFC]TFC1=9;"NASS";[F:PCH]PAYTYP
   If !fstat
    Wrseq format$("K:8X",[F:PCH]NASS);          : # 11) NASS     : NumÃĐro de chÃĻque
   Else
    Read [PYH]PYH0 = [F:PCH]REGNUM
    If !fstat
     Wrseq format$("K:8X",[F:PYH]CHQNUM);
    Else
     Wrseq format$("K:8X",[F:PCH]NASS);
    Endif
   Endif
   Wrseq format$("K:16X",[F:PCH]CPTA);          : # 12) CPTA     : Code nature
   Wrseq format$("K:16X",[F:PCH]CDC);           : # 13) CDC      : Code annexe
   Wrseq format$("K:32X",[F:PCH]DESCR);         : # 14) DESCR    : Commentaire
   Wrseq format$("K:8X",[F:PCH]CODRIF);         : # 15) CODRIF   : Code rÃĐfÃĐrence
   Wrseq
  Endif
 Next
 Openo
 If [M]TYPEXP=1
  Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
  If STAT=1
   # Fichier non copiÃĐ sur le poste client
   Call ERREUR(mess(164,141,1)) From GESECRAN
   FIN=1 : Break
  Elsif STAT>1
   # Fichier inexistant
   Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
   FIN=1 : Break
  Endif
 Endif
Next

Return

######################################################################################
$SEL_TABLE
Case COUZON
 When "TPY"
  OBJET="TPY"
  CRITERE = "[F:TPY]FLGCAS>1"
 When "REQ"
  Local Integer REQMAX, NBREQ
  REQMAX = 200
  Local Char TBNUM(50)(1..REQMAX)
  If !clalev([PCH]) : Local File PYHCAS [PCH] : Endif

  Raz TBNUM, NBREQ
  Filter [PCH] Where [F:PCH]FLG=2 Order By Key CLE=[F:PCH]FIC
  For [PCH]CLE(1)
   If NBREQ<REQMAX
    NBREQ+=1 : TBNUM(NBREQ)=[F:PCH]FIC
   Else
    Break
   Endif
  Next
  Filter [PCH] Where find([F:PCH]FIC,TBNUM(1..NBREQ))

  NBCOL=2
  COL(1) = "NUMPCH"   : TIT(1) = "Numero de requÃŠte"
  COL(2) = "DATPCH"   : TIT(2) = "Date de gÃĐnÃĐration"
  Raz OBJET
  ORDRE = "NUMPCH desc"
Endcase
Return

######################################################################################
$SEL_LISTE
Case COUZON
 When "REQ"
  Local Char TEXTE(GLONDES)(1..200,1..2)

  If !clalev([PCH]) : Local File PYHCAS [PCH] : Endif
  Filter [PCH] Where [F:PCH]FLG=2 Order By Key CLE=[F:PCH]NUMPCH Desc
  For [PCH]CLE(1)
   NBTEX +=1
   TEX(NBTEX)     = num$([F:PCH]NUMPCH)
   TEXTE(NBTEX,1) = num$([F:PCH]NUMPCH)
   TEXTE(NBTEX,2) = format$("D:",[F:PCH]DATPCH)
  Next
  Filter [PCH]
  TIT(0) = mess(6,173,1)    # Liste requÃŠte export rÃĻglements
  TIT(1) = mess(18,134,1)   # RequÃŠte
  TIT(2) = mess(19,151,1)   # Date
Endcase
Return

######################################################################################
$TERMINE

If [M]TRC<>2 or [M]SIM=2 : Return : Endif

If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
Local Integer NBCUR : NBCUR=max(1,nbrecord([TCU]))
Local Decimal TOTCUR(NBCUR)
Local Char    LIBCUR(GLONCUR)(1..NBCUR)
Local Char    SVGTRE(50)(1..NBCUR)
Local Integer LIGNE
Local Char SVGFIC(GDIMFIC)

# Trace
If !GSERVEUR
  Call OUVRE_TRACE("") From LECFIC :  TRA=1
Endif

If GTRACE<>""

 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 If [M]GRPCPY<>""
  Call LECTURE("AGF",[M]GRPCPY,"") From  CONTOBJ
  # PÃĐrimÃĻtre
  Call ECR_TRACE(mess(3,173,1)-[M]GRPCPY-[F:AGF]DES,0) From GESECRAN
 Endif
 Call ECR_TRACE(num$(NBRFIC)-" fichier(s) gÃĐnÃĐrÃĐ(s) ",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

 Filter [PCH] Where NUMPCH = [L]NUMREQ Order By Key CLE=FIC;TRECOD;CURBAN;ACCNUM
 Raz TOTCUR,LIGNE,NBCUR
 For [PCH]CLE(1)
   SVGFIC = [F:PCH]FIC
   Raz NBCUR, TOTCUR,LIGNE
   For [PCH]CLE(3)
     NBCUR +=1
     SVGTRE(NBCUR) = [F:PCH]TRECOD
     LIBCUR(NBCUR) = [F:PCH]CURBAN
     For [PCH]CLE(4)
      LIGNE+=1
      For [PCH]CLE
       TOTCUR(NBCUR) +=  [F:PCH]AMTBAN
      Next
     Next
   Next
   FICHIER = filpath(CHEMIN,SVGFIC,"","","",MACHINE)
   If [M]TYPEXP=1
    Call ECR_TRACE(mess(178,115,1)+"     "+num$(LIGNE)-mess(82,141,1),0) From GESECRAN
   Else
    # fichier....lignes exportÃĐes
    Call ECR_TRACE("|"+mess(14,9003,1)-[M]VOLFIL+SVGFIC+"     "+num$(LIGNE)-mess(82,141,1),0) From GESECRAN #<YYFIN_93938_US351>
   Endif
   For I=1 To NBCUR
    # SociÃĐtÃĐ/banque/compte... Total
    Call ECR_TRACE(mess(7,173,1)-"= "+format$("K:15X",SVGTRE(I))+mess(142,124,1)-":"-num$(TOTCUR(I))-LIBCUR(I),0) From GESECRAN
   Next
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Next
 Filter [PCH]

Endif

Call WORKFLOW(1,"CSP","","") From AWRK
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


######################################################################################
$FILTRE
# Variable pour le filtre standard
Local Char   FILTRE(250)(0..8)
Local Integer IFILT

If !clalev([F:AGC]) : Local File AGRPCPY    [AGC] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY    [AGF] : Endif

Raz FILTRE, IFILT

# CritÃĻres FigÃĐs
Call ADDCRIT(FILTRE,IFILT,"FLG",'FLG<>2'," & ") From GOBJSUB    # Flux non encore envoyÃĐ

# PÃĐrimÃĻtre
Filter [AGC] Where GRP = [M]GRPCPY
If rowcount([AGC])=1
 For [AGC]AGC0
  Call ADDCRIT(FILTRE,IFILT,"CPY",'CPY="'+[F:AGC]CPY+'"'," & ") From GOBJSUB
 Next
Else
 Call ADDCRIT(FILTRE, IFILT,"CPY",'find(CPY'," & ") From GOBJSUB
 For [AGC]AGC0
  Call ADDCRIT(FILTRE,IFILT,"CPY",'"'+[F:AGC]CPY+'"',",") From GOBJSUB
 Next
 Call ADDCRIT(FILTRE,IFILT,"CPY",')',"") From GOBJSUB
Endif
Filter [AGC]

# Transaction de rÃĻglement
If [M]ALLTPY<>2
 Call ADDCRIT(FILTRE,IFILT,"TPY",'PAYTYP="'+[M]TPY+'"'," & ") From GOBJSUB
Endif
Return

######################################################################################

Subprog EXP_AMT(AMT,CUR,EXPAMT)
Value Decimal AMT
Value Char CUR()
Variable Char EXPAMT()

Local Decimal WAMT
Local Char    BEF_SEP(16),AFT_SEP(16)

If !clalev([TCU]) : Local File TABCUR     [TCU] : Endif
Call LEC_TCU(CUR) From CPTLEC
WAMT = abs(AMT)

If fix(WAMT)=WAMT
 # Integer  => add decimal
 EXPAMT=sum(num$(abs(WAMT)),string$([F:TCU]DECNBR,"0"))
Else
 # BEF_SEP number before . &  AFT_SEP number after .
 BEF_SEP = left$(num$(WAMT),len(num$(fix(WAMT))))
 AFT_SEP = right$(num$(WAMT),len(BEF_SEP)+2)
 # AFT_SEP => add decimal if necessary (example : 10.1 => 10.10)
 If len(AFT_SEP)<[F:TCU]DECNBR
  AFT_SEP = sum(num$(AFT_SEP),string$([F:TCU]DECNBR-len(AFT_SEP),"0"))
 Endif
 If BEF_SEP<>"0"
  EXPAMT = BEF_SEP+AFT_SEP
 Else
  # AFT_SEP => delete decimal if necessary (example : 0.01 => 1 or 0.1 => 10)
  While left$(AFT_SEP,1)="0"
   AFT_SEP=right$(AFT_SEP,2)
  Wend
  EXPAMT = AFT_SEP
 Endif
Endif
End

######################################################################################
# Gestion du masque EXPCASPAY
######################################################################################
######################################################################################
Subprog C_SIM(VALEUR)
Variable Integer VALEUR
Case num$(VALEUR)
 When "1"
    # GÃĐnÃĐration rÃĐel
    Actzo [M:PAD]6, FIC
    Grizo [M:PAD]REQ
 When "2"
    # GÃĐnÃĐration simulÃĐ
    Actzo [M:PAD]6
    Grizo [M:PAD]REQ, FIC
 When "3"
    # Re-GÃĐnÃĐration
    Grizo [M:PAD]6
    Actzo [M:PAD]REQ, FIC
Endcase
Gosub GRISE
End

######################################################################################
Subprog AS_REQ(VALEUR)
Variable Decimal VALEUR
If [M]SIM<>3 : mkstat=2 : End : Endif
End

#######################
Subprog C_REQ(VALEUR)
Variable Decimal VALEUR
If !clalev([PCH]) : Local File PYHCAS [PCH] : Endif
Filter [PCH] Where [F:PCH]FLG=2 & [F:PCH]NUMPCH=VALEUR
Read [PCH] First
If fstat : mkstat=2 : Endif
Filter [PCH]
End

######################################################################################
Subprog C_ALLTPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TPY : Grizo TPY
Else
 Actzo TPY
Endif
End

Subprog AS_TPY(VALEUR)
Variable Char    VALEUR()
If [M]ALLTPY=2 : mkstat=1 : Endif
End

Subprog C_TPY(VALEUR)
Variable Char    VALEUR()
If !clalev([TPY]) : Local File TABPAYTYP  [TPY] : Endif
Read [F:TPY]TPY0 = VALEUR
If fstat or [F:TPY]FLGCAS<2
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat=2 : End
Endif
End

############################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
 [M]VOLFIL = "["+GDIRCASH+"]"
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

######################################################################################
Subprog AS_TRC(VALEUR)
Variable Integer VALEUR
If [M]SIM=2 : VALEUR=2 : mkstat=2 : End : Endif
End

######################################################################################
$GRISE
If [M]ALLTPY=2 : Effzo [M]TPY : Grizo [M]TPY : Else :  Actzo [M]TPY : Endif
If [M]TYPEXP=1 :                Grizo [M]FIC : Else :  Actzo [M]FIC : Endif
Return

###############################################################################
##  ContrÃīle en saisie du paramÃĻtre EXPCASPAY
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char FIL(GDIMFIC)
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL(2,VALEUR,[L]FIL,E_TYPE_FOLDER,GMESSAGE)
If mkstat=2 : OK=0 : Else OK=1 : Endif
End

###############################################################################
##  Actions liÃĐes au paramÃĻtrage des transaction de rÃĻglements
##
##  TPY_OUVRE    : Ouverture de la table
##  TPY_LIENS    : Charges les zones paramÃĐtrÃĐes.
##  TPY_CREATION : Mise Ã  jour de la table.
###############################################################################
$TPY_OUVRE
If !clalev([F:TFC]) : Local File TABFILCASH [TFC] : Endif
Return

$TPY_LIENS
Filter [TFC] Where MODULE=9 and CODPAR=[M:TPY0]PAYTYP
Raz [M:TPY4]NBCLC
For [TFC]
 [M:TPY4]CODCAS([M:TPY4]NBCLC) = [F:TFC]CODCAS
 [M:TPY4]CLCFOR([M:TPY4]NBCLC) = [F:TFC]CLCFOR
 [M:TPY4]NBCLC+=1
Next
Filter [TFC]
Return


$TPY_CREATION
Delete [TFC] Where MODULE=9 and CODPAR=[M:TPY0]PAYTYP
If fstat=1
 GOK = -1 : GLOCK = "$TABFILCASH"-[M:TPY0]PAYTYP: Return
Endif
For I=0 To [M:TPY4]NBCLC-1
 [F:TFC]MODULE=9
 [F:TFC]CODPAR=[M:TPY0]PAYTYP
 [F:TFC]CODCAS=[M:TPY4]CODCAS(I)
 [F:TFC]CLCFOR=[M:TPY4]CLCFOR(I)
 Write [TFC]
 If fstat
  GOK = 0 : Call FSTA("TFC") From GLOCK
 Endif
Next I
Return


######################################################################################
##  Annulation comtptable
######################################################################################
$EXTOURNE
# Annulation comptable est prise en compte SI
#     le fait gÃĐnÃĐrateur (=Etape de trÃĐsorerie) correspond Ã  l'ÃĐtape d'annulation.
Case [F:PAN]ACCSTA
 When 3 : # Mise en portefeuille
  If [F:TPY]FLGCAS<>2 : Return : Endif
 When 8 : # Comptabilisation intermÃĐdiaire
  If [F:TPY]FLGCAS<>3 :  Return : Endif
 When 9 : # Remise en banque
  If [F:TPY]FLGCAS<>4 :  Return : Endif
 When Default
   Return
Endcase

# Recherche de l'ensemble des lignes du rÃĻglement liÃĐ au flux des rÃĻglement.
#  (attention, un rÃĻglement peut ÃŠtre plusieurs fois annulÃĐ)
#
Filter [PC2] Where REGNUM=NPYH & RVSACCNUM=0
For  [PC2]
 Read [PCH]PCH3 = [PC2]REGNUM;[F:PC2]ACCNUM;[F:PC2]REGLIN
 If fstat
  Raz [F:PCH]
  [F:PCH] = [F:PC2]

  # RAZ des informations liÃĐes Ã  l'export du flux
  Raz [F:PCH]FIC
  Raz [F:PCH]FLG
  Raz [F:PCH]NUMPCH
  Raz [F:PCH]DATPCH

  # Inversement du sens.
  If [F:PC2]SNS>0 : [F:PCH]SNS = -1 : Else [F:PCH]SNS =  1 : Endif

  # Mise Ã  jour des dates
  If [F:TPY]FLGCAS=4 or [M]DUDDAT<[M]ACCDAT
   [F:PCH]DAT = [M]ACCDAT
  Else
   [F:PCH]DAT = [M]DUDDAT
  Endif
  [F:PCH]VALDAT = [M]VALDAT
  [F:PCH]ACCDAT = [M]ACCDAT
  [F:PCH]DUDDAT = [M]DUDDAT

  # Suivi...
  [F:PCH]RVSACCNUM = [F:PC2]ACCNUM
  [F:PCH]ACCNUM    = SVG_NUM2

  [F:PCH]CREUSR = GUSER
  [F:PCH]CREDAT = date$

  Write [PCH]
  If fstat
   GOK = 0 : Call FSTA("PCH") From GLOCK
   If GTRACE<>"" : MESSA="PCH\"+[F:PCH]NUMPCH : Endif
   Break
  Endif
 Endif
Next
Return

$ERR
If GTRACE<>""
 # Erreur en ÃĐvaluation de zone
 Call ECR_TRACE(mess(65,106,1)-[F:TFC]CODCAS-":"-errmes$(errn)-"("+num$(errn)+")",1) From GESECRAN
 GOK=0
Endif
Resume

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End

