#<AdxTL>@(#)4.0.0.0 $Revision$ Consultation SAD
Local Char PARAM(20)(1..15)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "A-HNSERIE"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = "0"
PARAM(7) = ""
PARAM(8) = ""
PARAM(9) = ""
PARAM(10)= "0"
PARAM(11)= "0"
PARAM(12)= ""
PARAM(13)= ""
PARAM(14)= "0"
PARAM(15)= ""
Call GCONSULT("SSE","",PARAM) From GCONSULT
End

############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSSE] : Transmask [M:SSE1] To [M:CSSE]# Issue 25606[M:CSSE] = [M:SSE1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO] : Endif
If clalev([F:STS])=0 : Local File STOSER     [STS] : Endif
If clalev([F:STS1])=0 : Local File STOSER     [STS1] : Endif  # Issue 110327
If clalev([F:STO2])=0 : Local File STOCK      [STO2] : Endif  # Issue 110327
#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILP(250)
Local Char    WFILL(250)
Local Char    WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG, WTYPSEL
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSSE"
SUITE  = 1
RETOUR = 1
nolign = 1
Return
############################################################
$FIN_CRIT
[M:SSE1]FLG = 0
[M:SSE1]    = [M:CSSE]
Return
############################################################
$AP_MAGNETO
[M:SSE1]FLG = 0
Return
############################################################
$CLECUR
If CLECUR=1
   #[M:SSE1]ITMDES1 = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SSE1]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Affzo [M:SSE1]ITMDES1
Endif
Return
############################################################
$SETBOUT
If [M:SSE1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(13)  = [M:SSE2]SERNUM(nolign-1)
      REPONSE = GSTAFIN
    Endif
Endcase
Return
############################################################
$FERME
If clalev([F:STS]) <> 0 : Filter [STS] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SSE1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SSE1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SSE1]LOTSEL = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:SSE1]SERNUMSEL = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:SSE1]VCRTYPSEL = val(PARAM(I))
      Endif
    When 7 :
      If PARAM(I) <> ""
        [M:SSE1]VCRNUMSEL = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) <> ""
        [M:SSE1]BPCNUMSEL = PARAM(I)
      Endif
    When 9 :
      If PARAM(I) <> ""
        [M:SSE1]BPAADDSEL = PARAM(I)
      Endif
    When 10 : #--- Issue 110327 suppression des # pour les lignes qui suivent
      If PARAM(I) <> ""
        [M:SSE1]STOCOUSEL = val(PARAM(I))
      Endif
    When 11 :
      If PARAM(I) <> ""
        [M:SSE1]SELFLG = val(PARAM(I))
      Else
        [M:SSE1]SELFLG = 0
      Endif
    When 12 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
    When 14:
        If PARAM(I) <> ""
         [M:SSE1]VCRLINSEL = val(PARAM(I))
        Endif
  Endcase
Next I
[M:SSE1]ITMFIL = "[F:ITM]STOMGTCOD>1&[F:ITM]SERMGTCOD>1"
If clalev([M:CSSE]) <> 0 & [M:CSSE]MEMO = "STD"
  [M:SSE1] = [M:CSSE]
Endif
[M:SSE1]NONFLG = 2
[M:SSE1]ALLFLG = 2

#--- Issue 110327
If dim([M:SSE1]STOCOUSEL)>0 & [M:SSE1]STOCOUSEL<>0
  [M:SSE1]ALLFLG = 1
Endif
#---
Return
############################################################
$LECTURE
If [M:SSE1]ITMREF = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER

SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
     # Issue 118523 - 2016-10-03 by MAE
    #For [STS]  With Nohint
    For [LNK]  With Nohint
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    # Issue 118523 - 2016-10-03 by MAE
    #For [STS]  With Nohint
    For [LNK]  With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SSE2]
    WLIG = 0
      # Issue 118523 - 2016-10-03 by MAE
    #For [STS] With Nohint
    For [LNK] With Nohint
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
     # Issue 118523 - 2016-10-03 by MAE
    #For [STS] With Nohint
    For [LNK] With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
       # Issue 118523 - 2016-10-03 by MAE
    #For [STS] With Nohint
    For [LNK] With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
Return
############################################################
$TRT_FILTER
If [M:SSE1]FLG = 0
  [M:SSE1]FLG = 1
  Raz [M:SSE2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # Issue 118523  - 2016-10-03 by MAE : préparation du lien entre STOCK et STOSER
  If [M:SSE1]SERMGTCOD = 4
    Link [STS] With [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
&             As [LNK]
  Else
    Link [STS] With [STO]STO5=[F:STS]ITMREF;[F:STS]SERNUM
&             As [LNK] Where [F:STO]QTYPCU <> 0
  Endif
  # End issue 118523
  If [M:SSE1]VCRTYPSEL = 0
    #--- Issue 110327
    If [M:SSE1]STOCOUSEL<>0 & [M:SSE1]SERMGTCOD=4
      # Issue 118523 - 2016-10-03 by MAE
      #Filter [STS] Where evalue(WFIL)  &
      Filter [LNK] Where evalue(WFIL)  &
&                        evalue(WFILL) &
&                        evalue(WFILS) &
&                        evalue(WFILSPE)
&                  Order By Key STS3
    Else
    #---
       # Issue 118523 - 2016-10-03 by MAE
      #Filter [STS] Where evalue(WFIL)  &
      Filter [LNK] Where evalue(WFIL)  &
&                        evalue(WFILL) &
&                        evalue(WFILS) &
&                        evalue(WFILSPE)
&                  Order By Key STS0
    #--- Issue 110327
    Endif
    #---
  Else
     # Issue 118523 - 2016-10-03 by MAE
    #Filter [STS] Where evalue(WFIL)  &
    Filter [LNK] Where evalue(WFIL)  &
&                      evalue(WFILL) &
&                      evalue(WFILS) &
&                      evalue(WFILSPE)
&                Order By Key STS2
  Endif
  Raz [F:STS]
Endif
#--- Issue 110327
If dim([M:SSE1]STOCOUSEL)>0 & [M:SSE1]STOCOUSEL<>0
  Diszo [M:SSE1]ALLFLG
  Diszo [M:SSE1]NONFLG
Else
  Actzo [M:SSE1]ALLFLG
  Actzo [M:SSE1]NONFLG
Endif
Affzo [M:SSE1]ALLFLG, NONFLG
#---

Return
############################################################
$LOAD_FILTER
# Filtre article
WFIL = "[F:STS]ITMREF=[M:SSE1]ITMREF"
WFILP = "1=1"
WFILL = "1=1"

#--- Issue 110327
If [M:SSE1]SERMGTCOD=4 & [M:SSE1]STOCOUSEL<>0
  WFIL += "&[F:STS]STOCOU=[M:SSE1]STOCOUSEL"
Endif
#---
# Filtre site
If [M:SSE1]FCY <> ""
  WFIL += "&[F:STS]STOFCY=[M:SSE1]FCY"
Endif
# Filtre numeros série début
If [M:SSE1]SERNUMSEL <> ""
  WFIL += "&[F:STS]SERNUM>=[M:SSE1]SERNUMSEL"
Endif
# Filtre numéro de tiers
If [M:SSE1]BPCNUMSEL <> ""
  WFIL += "&pat([F:STS]BPCNUM,[M:SSE1]BPCNUMSEL)"
Endif
# Filtre code adresse
  If [M:SSE1]BPAADDSEL <> ""
    WFIL += "&[F:STS]BPAADD=[M:SSE1]BPAADDSEL"
  Endif
# Filtre type pièce
WTYPSEL=0
If [M:SSE1]VCRTYPSEL > 1
WTYPSEL=1
  WFILL += "&([F:STS]SDHTYP=[M:SSE1]VCRTYPSEL-1 | [F:STS]RCPVCRTYP=[M:SSE1]VCRTYPSEL-1)"
Endif
# Filtre numéro pièce
If [M]VCRNUMSEL <> "" & WTYPSEL=0
  WFILL += "&([F:STS]SDHNUM=[M:SSE1]VCRNUMSEL | [F:STS]RCPVCRNUM=[M:SSE1]VCRNUMSEL)"
Endif
# Filtre date de sortie
   If [M:SSE1]ALLFLG = 2 & [M:SSE1]NONFLG = 1
      WFIL += "&[F:STS]ISSDAT<>[0/0/0]"
   Elsif [M:SSE1]ALLFLG = 1 & [M:SSE1]NONFLG = 2
      WFIL += "&[F:STS]ISSDAT=[0/0/0]"
   Endif
# Issue 118523
# Filtre lot
If [M:SSE1]LOTSEL <> ""
  WFIL += "&[F:STO]LOT=[M:SSE1]LOTSEL"
Endif
Return
############################################################
$LOA_LIGNE
# hcb                                                           # hcb 110327 deb
If [F:ITM]SERMGTCOD = 4
#   Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
Else
   Read [STO]STO5=[F:STS]ITMREF;[F:STS]SERNUM
Endif
# hcb                                                           # hcb 110327 end
If fstat
  Raz [F:STO]
Endif
If ([M:SSE1]LOTSEL <> "" & !pat([F:STO]LOT,[M:SSE1]LOTSEL)) |
&  ([M:SSE1]SELFLG   = 1 &  [F:STO]CUNLOKFLG = 2)
  nolign -= 1
  NOL    -= 1
  Goto LOA_LIGNE_FIN
Endif
#--- sélection sur pièce en sortie puis en entrée
If [M:SSE1]VCRTYPSEL > 1 & [M:SSE1]VCRNUMSEL <> ""
   If [F:STS]SDHTYP=[M:SSE1]VCRTYPSEL-1 & [F:STS]SDHNUM=[M:SSE1]VCRNUMSEL
      Goto FIN_PIE
   Elsif [F:STS]RCPVCRTYP=[M:SSE1]VCRTYPSEL-1 & [F:STS]RCPVCRNUM=[M:SSE1]VCRNUMSEL
      Goto FIN_PIE
   Else
      nolign -= 1
      NOL    -= 1
      Goto LOA_LIGNE_FIN
   Endif
Endif
$FIN_PIE
#
#--- sélection sur ligne pièce en sortie puis en entrée
If [M:SSE1]VCRNUMSEL <> "" & [M:SSE1]VCRLINSEL <> 0
   If [F:STS]SDHNUM=[M:SSE1]VCRNUMSEL & [F:STS]SDDLIN=[M:SSE1]VCRLINSEL
      Goto FIN_LIN
   Elsif [F:STS]RCPVCRNUM=[M:SSE1]VCRNUMSEL-1 & [F:STS]RCPVCRLIN=[M:SSE1]VCRLINSEL
      Goto FIN_LIN
   Else
      nolign -= 1
      NOL    -= 1
      Goto LOA_LIGNE_FIN
   Endif
Endif
$FIN_LIN
#
#--- alimentation ligne
[M:SSE2] = [F:STS]
If dim([M:SSE2]LOC) > 0
  [M:SSE2]LOC(nolign-1) = [F:STO]LOC
Endif
If dim([M:SSE2]LOT) >0
  [M:SSE2]LOT(nolign-1) = [F:STO]LOT
Endif
If dim([M:SSE2]SLO) >0
  [M:SSE2]SLO(nolign-1) = [F:STO]SLO
Endif
If dim([M:SSE2]STA) >0
  [M:SSE2]STA(nolign-1) = [F:STO]STA
Endif
If dim([M:SSE2]WRH) >0
  [M:SSE2]WRH(nolign-1) = [F:STO]WRH
Endif
#                                                               # hcb X3-69570  deb
If dim([M:SSE2]LPNNUM) >0
  [M:SSE2]LPNNUM(nolign-1) = [F:STO]LPNNUM
Endif
#                                                               # hcb X3-69570  fin






$LOA_LIGNE_FIN
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SSE1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SSE1] = [F:ITM]
Affzo [M:SSE1]STU
Affzo [M:SSE1]SERMGTCOD
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SSE1]STU       = [F:ITM]STU
[M:SSE1]SERMGTCOD = [F:ITM]SERMGTCOD
Affzo [M:SSE1]STU
Affzo [M:SSE1]SERMGTCOD
[M:SSE1]FLG = 0
End
############################################################
Subprog AS_BPCNUMSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_BPCNUMSEL(VALEUR)
Variable Char    VALEUR()
[M:SSE1]FLG = 0
End
############################################################
Subprog AS_BPAADDSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_BPAADDSEL(VALEUR)
Variable Char    VALEUR()
[M:SSE1]FLG = 0
End
############################################################
Subprog AS_SDHNUMSEL(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_SDHNUMSEL(VALEUR)
Variable Char    VALEUR()
[M:SSE1]FLG = 0
End
############################################################
Subprog AM_ALLFLG(VALEUR)
Variable Integer VALEUR
[M:SSE1]FLG = 0
End

##########################################################################
Subprog AM_NONFLG(VALEUR)
Variable Integer VALEUR
[M:SSE1]FLG = 0
End
##########################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,5,6,9,13,21,30,34,37)
        GMENLOC(I) = 1
    Endif
Next
End
##########################################################################
Subprog AM_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
[M:SSE1]FLG = 0
End
##########################################################################
Subprog AM_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()
[M:SSE1]FLG = 0
End

##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SSE") From SUBGTC

End



######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSSE2) 20/02/2017 14:25:38 (MAE)
######################################################################################
Subprog AV_SERNUM(VALEUR)
Variable Char    VALEUR()
# Issue 110327 - 2016-11-24 by MAE : affichage des lignes désynchronisées
If [F:ITM]SERMGTCOD = 4 & [M:SSE2]ISSDAT(nolign-1) = [0/0/0]
  Read [STO2]STO0 =[M:SSE2]STOFCY(nolign-1);[M:SSE2]STOCOU(nolign-1)
  If [F:STO2]LOCCAT <> 2
     Local Integer WIND
     Raz WIND
     Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[M:SSE2]STOCOU(nolign-1),[F:STO2]QTYSTUACT,WIND) From STKLIB
     If WIND = 2
        Chgstl [M:SSE2]NBLIG(nolign-1)  With "STKSERDSY"
     Else
        Chgstl [M:SSE2]NBLIG(nolign-1)  With "EMPTY"
     Endif
  Endif
Else
  Chgstl [M:SSE2]NBLIG(nolign-1)  With "EMPTY"
Endif
End


######################################################################################

