#<AdxTL>@(#)5.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Mise à jour des champs timestamp dans les tables
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Update supervisor field on file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2] Where DOSSIER=GDOSX3
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLD2
End

#-------------------#
$MAJFLD2

Local Integer  I , ARRET , CD , CT , UD , UT , CS , US , ERR, NBTRT
Local Integer  MAXFIL , NBTAB
Local Char     TABTAB(GLONATB)(1..3000) , DAT(30)
Local Char     OTRP(GLONADC) , OTRL(GLONASU)
Local Char REQSQL (250) (100)
Local Integer NBREQ , NOREQ
Local Char    APPLI(GDIMFIC), MACHINE(GDIMFIC), NOMDOS(GDIMFIC)

Call ECR_TRACE("UTIMAJFLDTAB2 : Update new fields on folder"-DOSSIER,0) From GESECRAN
APPLI=DOSSIER
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS

If DOSSIER=nomap
 Local File ATABLE [ATB] , ATABZON [ATZ] , ATYPE [ATY]
 Local File ADOVAL [ADW]
Else
 Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABZON" [ATZ] , =DOSSIER+".ATYPE"  [ATY]
 Local File =DOSSIER+".ADOVAL" [ADW]
Endif

Read [ADW]ADW0 = "";"";"TYPDBA"
TYPDBA = val([F:ADW]VALEUR)

# New fields

Gosub SET_FLDSYS

# Repérage des tables avec les nouveaux champs

NBTAB = 0

#For [ATB]CODFIC Where MODULE<>1
#& or find(CODFIC,"ADOCUMENT","ADOCFNC","ADOCFLD","ADOCCLB","ADOCBLB",
#&          "ABATRQT","ABATRQTL","ACCES","ADOVALAUS",
#&          "AELT","AELTLINK","AESPION","AFCTFCY",
#&          "ALINK",
#&          "ALISTEC","ALISTED","ALISTEH","ALISTEL","ALISTER","ALISTET",
#&          "ALOGIN","ALSTRD",
#&          "AMENUSER","AMSKACT","AMSKPAR","AMSKZON",
#&          "AOBJEXTD","APLSTD","AREPORTM",
#&          "ATABZON","ATEXTE","ATEXTRA","ATMPTRA",
#&          "AUDITH","AUDITL","AUSRSTA",
#&          "AWINBOUT","AWINPAR",
#&          "AWRKHISDES","AWRKHISMES","AWRKHISSUI",
#&          "POSCOD")<>0
For [ATB]CODFIC
Call AFF_BOITE([F:ATB]CODFIC,NBTAB,ARRET) From GESECRAN
 For I=1 To dim(FLDSYS)
  If FLDSYS(I)<>""
   Read [ATZ]CODZONE=[F:ATB]CODFIC;FLDSYS(I)
   If !fstat
    If [F:ATB]TYPFIC<>3 or DOSSIER=GDOSX3
     If !find([F:ATB]CODFIC,TABTAB) & filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",DOSSIER),0)>0 & func AFNC.ACTIVDOS(DOSSIER, [F:ATB]CODACT)
      #107271
      If func DOSVUE.ISVIEW(DOSSIER,[F:ATB]CODFIC)=0
       NBTAB += 1
       TABTAB(NBTAB) = [F:ATB]CODFIC
      Endif
      Break 1
     Endif
    Endif
   Endif
  Endif
 Next I
Next ATB

MAXFIL = NBTAB

Close Local File

# Mise à jour des champs time stamp à partir des CREDAT/UPDDAT

Call OUVRE_BOITE("Update new fields"-DOSSIER,0) From GESECRAN
Call SET_BOITE("",MAXFIL) From GESECRAN

NBTAB = 0

# Désactivation de la mise à jour automatique des champs "timestamp" par le moteur

If dim([S]adxtrp)>0 & [S]adxtrp<>""
 OTRP = [S]adxtrp
 OTRL = [S]adxtrl
 [S]adxtrp = ""
 [S]adxtrl = ""
Endif

If DOSSIER=nomap
 Local File ATABZON [ATZ]
Else
 Local File =DOSSIER+".ATABZON" [ATZ]
Endif

For I=1 To MAXFIL
 TABLE = TABTAB(I)
 NBTAB += 1
 Raz CS , US , CD , CT , UD , UT, ERR, NBTRT
 Read [ATZ]CODZONE=TABLE;"CREDATTIM"
 If !fstat
  CS = 1
  Read [ATZ]CODZONE=TABLE;"UPDDATTIM"
  If !fstat
   US = 1
   Read [ATZ]CODZONE=TABLE;"CREDAT"
   If !fstat
    CD = 1
    Read [ATZ]CODZONE=TABLE;"CRETIM"
    If !fstat & [F:ATZ]CODTYP="L" : CT = 1 : Endif
   Endif
   Read [ATZ]CODZONE=TABLE;"UPDDAT"
   If !fstat
    UD = 1
    Read [ATZ]CODZONE=TABLE;"UPDTIM"
    If !fstat & [F:ATZ]CODTYP="L" : UT = 1 : Endif
   Endif
  Endif
 Endif
 If (CS or US) & (CD or UD)
  If DOSSIER=nomap
   Local File =TABLE [AAA_]
  Else
   Local File =DOSSIER+"."+TABLE [AAA_]
  Endif
  If type([F:AAA_]CREDATTIM)=526
    Call AFF_BOITE(TABLE,NBTAB,ARRET) From GESECRAN
    Call ECR_TRACE("Working on table"-TABLE-"...",0) From GESECRAN
    Gosub FILL_REQ
    If pat(DOSSIER,"*@*")
      If TYPDBA=1 : #Oracle
        Gosub TRT_ORA
      Else
        Gosub TRT_SQL
      Endif
      If ERR
        Call ECR_TRACE(TABLE-": Error on fields updated.",1) From GESECRAN
      Endif
    Else
      Gosub EXE_REQ
      If ERR
        Call ECR_TRACE(TABLE-": Error on fields updated.",1) From GESECRAN
      Else
        Call ECR_TRACE(TABLE-":"-num$(NBTRT)+" records processed.",0) From GESECRAN
      Endif
    Endif
  Endif
  Close Local File [AAA_]
 Endif
Next I

If dim([S]adxtrp)>0 & OTRP<>""
 [S]adxtrp = OTRP
 [S]adxtrl = OTRL
Endif

Call FERME_BOITE From GESECRAN

Close Local File

Return

#----------------#
$SET_FLDSYS
Local Integer NBFLD , MAXFLD
MAXFLD = 2
Local Char    FLDSYS(GLONAVA)(1..MAXFLD) , TYPFLD(GLONATY)(1..MAXFLD)
Local Char    LNKFLD(GLONATB)(1..MAXFLD)
Local Integer INTFLD(1..MAXFLD) , NBFLD , ANUFLD(1..MAXFLD)
NBFLD = 0
While NBFLD<dim(FLDSYS)
 NBFLD += 1
 Case NBFLD
  When 1 : FLDSYS(NBFLD) = "CREDATTIM" : TYPFLD(NBFLD) = "ADATIM"
  When 2 : FLDSYS(NBFLD) = "UPDDATTIM" : TYPFLD(NBFLD) = "ADATIM"
 Endcase
 If clalev([F:ATY])>0
  Call LECTURE("ATY",TYPFLD(NBFLD),"") From CONTOBJ
  INTFLD(NBFLD) = [F:ATY]INTITTYP
 Endif
Wend
Return


###################################################################################################
###################################################################################################
$TRT_SQL
#############################################################
## Pour SQL-server
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    IRS(2)
Local Char    MACBID(GDIMFIC)
Local Char    TEXT(250)(3)
Local Char    XINSTANCE(200)
Local Char    XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
     SQLDBA = "sqlcmd"
     # instance ?
     Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
     If OK
        Return
     Endif
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
     SQLDBA = "osql"
Endif

IRS = chr$(13)+chr$(10)
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII

Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""

 FICCMD = filpath("tmp","sqltrt"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqltrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqltrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 Openo FICSQL , 0

 For NOREQ=0 To NBREQ
  Wrseq REQSQL(NOREQ)
 Next NOREQ

 Wrseq "GO"
 Wrseq "COMMIT"
 Wrseq "EXIT"
 Openo
 CTRL=2
 Gosub EXEC_FIC_SQL
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'

Endif
$FIN_VERIF_SQL
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return


###################################################################################################
###################################################################################################
$EXEC_FIC_SQL
Local Char WORDRE(250)
Local Char    LIGNE(250)
 ##
 ## On ecrit le fichier de commande pour le déclenchement
 ## car bug sur probleme de PATH
 ##WORDRE = SQLDBA-"-D"-BASE-"-U sa -P"-VPWD-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"
 ##
 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049 replace osql by sqlcmd
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
           Wrseq "SET SQLCMD_EXE="+SQLDBA
           WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
           Wrseq WORDRE
           WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
           Wrseq WORDRE
Else
           Wrseq "SET OSQL_EXE="+SQLDBA
           WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
           Wrseq WORDRE
           WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
           Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If ERR=1
        TEXT(1)=LIGNE
        Call ECR_TRACE(TEXT(0..1),1) From GESECRAN
      Break
   Elsif toupper(left$(LIGNE,3))="MSG"
      TEXT(0)=LIGNE
      ERR=1
   Elsif pat(LIGNE,"*rows affected*") & GADONIX=2
      Call ECR_TRACE("|"+TABLE-":"-LIGNE,0) From GESECRAN
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,1) From GESECRAN
      ERR=1
 Endif
Return
###################################################################################################
###################################################################################################
$TRT_ORA


#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    IRS(2), OS(10)
Local Char    MACBID(GDIMFIC)
Local Char TEXT(250)(3)


Call GET_OS(MACHINE,OS) From ORDSYS
If toupper(OS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 Wrseq "connect "+USER+"/"+PASSE


 For NOREQ=0 To NBREQ
  Wrseq REQSQL(NOREQ)
 Next NOREQ

 Wrseq ";"
 Wrseq "commit;"
 Wrseq "exit"
 Openo
 CTRL=2
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'

Endif
$FIN_VERIF_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

###################################################################################################
###################################################################################################
$EXEC_FIC_ORA
Local Char WORDRE(250)
Local Char    LIGNE(250)

 SQLDBA = "sqlplus" : # Ca existe dans les 2 versions
 WORDRE = SQLDBA-'/NOLOG @'+SQLFIC
 Call SYSTEME(MACHINE,WORDRE,"",ERR) From ORDSYS
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If left$(LIGNE,4) = "ORA-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Elsif left$(LIGNE,4) = "SP2-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Elsif left$(LIGNE,4) = "PLS-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Elsif pat(LIGNE,"*rows updated*") & GADONIX=2
      Call ECR_TRACE("|"+TABLE-":"-LIGNE,0) From GESECRAN
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,1) From GESECRAN
      ERR=1
 Endif
Return

##############################################################################
$REQ_SQL
  REQSQL(NBREQ)= "UPDATE"-NOMDOS+"."+TABLE-"SET "
  If CS & CD
      If CT
        # il faut la chaine sous la forme aaaammjj hh:mi:ss
        NBREQ+=1 : REQSQL(NBREQ)= "CREDATTIM_0=CONVERT(datetime,"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,CREDAT_0,112)+' '+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0/3600)<24 THEN (CRETIM_0/3600) ELSE 0 END))+':'+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN ((CRETIM_0%3600)/60)<60 THEN ((CRETIM_0%3600)/60) ELSE 0 END))+':'+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0%60)<60 THEN (CRETIM_0%60) ELSE 0 END))"
        NBREQ+=1 : REQSQL(NBREQ)= ")"
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "CREDATTIM_0=CREDAT_0"
      Endif
  Endif

  If US & UD
      If CS & CD
        NBREQ+=1 : REQSQL(NBREQ)= ","
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0=(CASE WHEN CREDAT_0>UPDDAT_0 THEN "
        #prendre CREDATTIM_0 si CREDAT_0>UPDDAT_0
        If CT
          # il faut la chaine sous la forme aaaammjj hh:mi:ss
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(datetime,"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,CREDAT_0,112)+' '+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0/3600)<24 THEN (CRETIM_0/3600) ELSE 0 END))+':'+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN ((CRETIM_0%3600)/60)<60 THEN ((CRETIM_0%3600)/60) ELSE 0 END))+':'+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0%60)<60 THEN (CRETIM_0%60) ELSE 0 END))"
          NBREQ+=1 : REQSQL(NBREQ)= ")"
        Else
          NBREQ+=1 : REQSQL(NBREQ)= "CREDAT_0"
        Endif
        NBREQ+=1 : REQSQL(NBREQ)= " ELSE "
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0="
      Endif
      If UT
        # il faut la chaine sous la forme aaaammjj hh:mi:ss
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(datetime,"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,UPDDAT_0,112)+' '+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (UPDTIM_0/3600)<24 THEN (UPDTIM_0/3600) ELSE 0 END))+':'+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN ((UPDTIM_0%3600)/60)<60 THEN ((UPDTIM_0%3600)/60) ELSE 0 END))+':'+"
        NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (UPDTIM_0%60)<60 THEN (UPDTIM_0%60) ELSE 0 END))"
        NBREQ+=1 : REQSQL(NBREQ)= ")"
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDAT_0"
      Endif
      If CS & CD
        NBREQ+=1 : REQSQL(NBREQ)= " END)"
      Endif
  Elsif US
      If CD
        NBREQ+=1 : REQSQL(NBREQ)= ","
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0="
        #prendre CREDATTIM_0 car pas de UPDDAT_0
        If CT
          # il faut la chaine sous la forme aaaammjj hh:mi:ss
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(datetime,"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,CREDAT_0,112)+' '+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0/3600)<24 THEN (CRETIM_0/3600) ELSE 0 END))+':'+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN ((CRETIM_0%3600)/60)<60 THEN ((CRETIM_0%3600)/60) ELSE 0 END))+':'+"
          NBREQ+=1 : REQSQL(NBREQ)= "CONVERT(varchar,(CASE WHEN (CRETIM_0%60)<60 THEN (CRETIM_0%60) ELSE 0 END))"
          NBREQ+=1 : REQSQL(NBREQ)= ")"
        Else
          NBREQ+=1 : REQSQL(NBREQ)= "CREDAT_0"
        Endif
      Endif
  Endif

  If CS & CD
      #si CREDAT_0 renseignée
      # il faut la chaine sous la forme aaaammjj hh:mi:ss
      NBREQ+=1 : REQSQL(NBREQ)= " WHERE CREDAT_0>CONVERT(datetime,'"+format$("D:YYYYMMDD",[01/01/1901])+"')"
      #si CREDATTIM_0 non renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " AND CREDATTIM_0<CONVERT(datetime,'"+format$("D:YYYYMMDD",[01/01/1901])+"')"
  Elsif US & UD
      #si UPDDAT_0 renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " WHERE UPDDAT_0>CONVERT(datetime,'"+format$("D:YYYYMMDD",[01/01/1901])+"')"
      #si UPDDATTIM_0 non renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " AND UPDDATTIM_0<CONVERT(datetime,'"+format$("D:YYYYMMDD",[01/01/1901])+"')"
  Endif

Return
##############################################################################
$REQ_ORA
  REQSQL(NBREQ)= "UPDATE"-NOMDOS+"."+TABLE-"SET "
  If CS & CD
      If CT
        NBREQ+=1 : REQSQL(NBREQ)= "CREDATTIM_0=CAST(to_date("
        NBREQ+=1 : REQSQL(NBREQ)= "to_char(CREDAT_0,'YYYYMMDD')||' '||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(CRETIM_0/3600)<24 THEN trunc(CRETIM_0/3600) ELSE 0 END),'09'))||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,3600)/60)<60 THEN trunc(mod(CRETIM_0,3600)/60) ELSE 0 END),'09'))||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,60))<60 THEN trunc(mod(CRETIM_0,60)) ELSE 0 END),'09'))"
        NBREQ+=1 : REQSQL(NBREQ)= ",'YYYYMMDD HH24MISS') AS TIMESTAMP)"
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "CREDATTIM_0=CAST(CREDAT_0 AS TIMESTAMP)"
      Endif
  Endif

  If US & UD
      If CS & CD
        NBREQ+=1 : REQSQL(NBREQ)= ","
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0=NVL((select "
        #prendre CREDATTIM_0 si CREDAT_0>UPDDAT_0
        If CT
          NBREQ+=1 : REQSQL(NBREQ)= "CAST(to_date("
          NBREQ+=1 : REQSQL(NBREQ)= "to_char(CREDAT_0,'YYYYMMDD')||' '||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(CRETIM_0/3600)<24 THEN trunc(CRETIM_0/3600) ELSE 0 END),'09'))||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,3600)/60)<60 THEN trunc(mod(CRETIM_0,3600)/60) ELSE 0 END),'09'))||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,60))<60 THEN trunc(mod(CRETIM_0,60)) ELSE 0 END),'09'))"
          NBREQ+=1 : REQSQL(NBREQ)= ",'YYYYMMDD HH24MISS') AS TIMESTAMP)"
        Else
          NBREQ+=1 : REQSQL(NBREQ)= "CAST(CREDAT_0 AS TIMESTAMP)"
        Endif
        NBREQ+=1 : REQSQL(NBREQ)= " from DUAL where CREDAT_0>UPDDAT_0),"
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0="
      Endif
      If UT
        NBREQ+=1 : REQSQL(NBREQ)= "CAST(to_date("
        NBREQ+=1 : REQSQL(NBREQ)= "to_char(UPDDAT_0,'YYYYMMDD')||' '||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(UPDTIM_0/3600)<24 THEN trunc(UPDTIM_0/3600) ELSE 0 END),'09'))||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(UPDTIM_0,3600)/60)<60 THEN trunc(mod(UPDTIM_0,3600)/60) ELSE 0 END),'09'))||"
        NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(UPDTIM_0,60))<60 THEN trunc(mod(UPDTIM_0,60)) ELSE 0 END),'09'))"
        NBREQ+=1 : REQSQL(NBREQ)= ",'YYYYMMDD HH24MISS') AS TIMESTAMP)"
      Else
        NBREQ+=1 : REQSQL(NBREQ)= "CAST(UPDDAT_0 AS TIMESTAMP)"
      Endif
      If CS & CD
        NBREQ+=1 : REQSQL(NBREQ)= ")"
      Endif
  Elsif US
      If CD
        NBREQ+=1 : REQSQL(NBREQ)= ","
        NBREQ+=1 : REQSQL(NBREQ)= "UPDDATTIM_0="
        #prendre CREDATTIM_0 car pas de UPDDAT_0
        If CT
          NBREQ+=1 : REQSQL(NBREQ)= "CAST(to_date("
          NBREQ+=1 : REQSQL(NBREQ)= "to_char(CREDAT_0,'YYYYMMDD')||' '||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(CRETIM_0/3600)<24 THEN trunc(CRETIM_0/3600) ELSE 0 END),'09'))||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,3600)/60)<60 THEN trunc(mod(CRETIM_0,3600)/60) ELSE 0 END),'09'))||"
          NBREQ+=1 : REQSQL(NBREQ)= "trim(to_char((case WHEN trunc(mod(CRETIM_0,60))<60 THEN trunc(mod(CRETIM_0,60)) ELSE 0 END),'09'))"
          NBREQ+=1 : REQSQL(NBREQ)= ",'YYYYMMDD HH24MISS') AS TIMESTAMP)"
        Else
          NBREQ+=1 : REQSQL(NBREQ)= "CAST(CREDAT_0 AS TIMESTAMP)"
        Endif
      Endif
  Endif

  If CS & CD
      #si CREDAT_0 renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " WHERE CREDAT_0>to_date('"+format$("D:YYYYMMDD",[01/01/1901])+"','YYYYMMDD')"
      #si CREDATTIM_0 non renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " AND CREDATTIM_0<CAST(to_date('"+format$("D:YYYYMMDD",[01/01/1901])+"','YYYYMMDD') AS TIMESTAMP)"
  Elsif US & UD
      #si UPDDAT_0 renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " WHERE UPDDAT_0>to_date('"+format$("D:YYYYMMDD",[01/01/1901])+"','YYYYMMDD')"
      #si UPDDATTIM_0 non renseignée
      NBREQ+=1 : REQSQL(NBREQ)= " AND UPDDATTIM_0<CAST(to_date('"+format$("D:YYYYMMDD",[01/01/1901])+"','YYYYMMDD') AS TIMESTAMP)"
  Endif
Return
##############################################################################
$FILL_REQ
Raz REQSQL
Raz NBREQ

If TYPDBA=1 : #Oracle
    Gosub REQ_ORA
Else : #SqlServer
    Gosub REQ_SQL
Endif

Return

##############################################################################
$EXE_REQ
  Trbegin [AAA_]

    Onerrgo ERR_SQL
    Execsql From num$(TYPDBA*2+1) Sql REQSQL
    NBTRT=adxSqlRec
    Onerrgo

  Commit
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL(0..NBREQ),1) From GESECRAN
ERR=1
Resume

