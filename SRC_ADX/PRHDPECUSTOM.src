#----------------------------------------------------------------
# WEB SERVICES - BEGIN
#----------------------------------------------------------------
# Return information about hidden/additional fields
#**
#* Restitution de la liste des champs à  désactiver (code activité inactif) et à  activer (personnalisation du
#* paramétrage) selon le flux et le site Web
#*
#* @param REFNUM    : matricule demandeur 
#* @param FNC       : type de flux : 5 (état civil), 11 (situation familiale), 6 (coord.perso) et 4 (coord.pro) 
#* @param FCY       : site Web 
#* @param CPY       : société 
#* @param HIDEFLD   : champs à  désactiver
#* @param ADDFLD    : champs à  activer
#* @param ADDTYPE   : types des champs à  activer
#* @param ADDSIZE   : longueurs des champs à activer (exprimées en nombre de caractères) - La taille d'affichage est déduite
#* @param ADDX3FMT  : formats X3 des champs à  activer
#* @param ADDLBL    : libellés des champs à  activer
#* @param ADDLIST   : liste de variables des champs à  activer
#* @param ADDACT    : actions des champs à  activer
#*!
# Non utilisés mais fonctionnent dans le portail
# ADDAUTOINT  Aucompletion - Safe X3 WAS interface (FCT GESAYI)  that will process autocompletion requests  
# ADDAUTOFLD  Aucompletion - List of fields that will be dispalyed (text) into drop down list - '~' as field separator 
#
# Sort fields
#
# SORTFLD        X3 fiels code -  Custom display field order if any
#----------------------------------------------------------------

Subprog PRHDPEFIELDINFO (AXPARCOD,AXPARVAL,REFNUM,FNC,CPY,HIDEFLD,ADDFLD,ADDTYPE,ADDSIZE,ADDX3FMT,ADDLBL,ADDLIST,ADDACT,ADDMANDATORY, ADDAUTOINT,ADDAUTOFLD,SORTFLD)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     REFNUM()
    Value    Integer  FNC
    Value    Char     CPY()
    Variable Char     HIDEFLD()()
    Variable Char     ADDFLD()()
    Variable Integer  ADDTYPE()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Char     ADDLBL()()
    Variable Char     ADDLIST()()
    Variable Char     ADDACT()()    
    Variable Integer  ADDMANDATORY()
    Variable Char     ADDAUTOINT  ()
    Variable Char     ADDAUTOFLD  ()()
    Variable Char     SORTFLD ()()
    Local Char LANG(3),FCY(50)
    LANG= func PRHUTIFILES.PARAMXTD_GET (AXPARCOD, AXPARVAL, "USRLANG")    
    FCY= func PRHUTIFILES.PARAMXTD_GET (AXPARCOD, AXPARVAL, "SITCOD") 
    Call GETPERSODATA(REFNUM,FNC,FCY,CPY,HIDEFLD,ADDFLD,ADDTYPE,ADDSIZE,ADDX3FMT,ADDLBL,ADDLIST,ADDACT,ADDMANDATORY) From PORDPI
End
#----------------------------------------------------------------
# WEB SERVICES - END
#----------------------------------------------------------------

