#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Structure TABLAN

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "LAN"    : Gosub LAN
  When "LANSTD" : Gosub LANSTD
  When "LANRPL" : Gosub LANRPL
  When "LANISO" : Gosub LANISO
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



################################################################################################
$AINSERT_CONTROL_BEFORE
Gosub LANSTD_DEPENDENCIES
Return

################################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub LANSTD_DEPENDENCIES
Return

###############################################################################################
$LAN
Case [L]ARULE
   When "CONTROL"   : Gosub LAN_CONTROL
Endcase
Return

$LAN_CONTROL
If this.LAN="ALL"
  # Reserved code
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(129,133,1),[V]CST_AERROR)
Endif
Return

###############################################################################################
$LANISO
Case [L]ARULE
   When "CONTROL"   : Gosub LANISO_CONTROL
Endcase
Return

$LANISO_CONTROL
Local Char VARMIN(2),VARMAJ(2)
Local Integer I

If this.LANISO=AVOID.ACHAR
  If pat(this.LANISO,"!!-!!")=[V]CST_AFALSE
    # incorrect format
    [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(149,100,1),[V]CST_AERROR)
  Else
    I = instr(1,this.LANISO,"-")
    If I >0
      VARMIN = left$(this.LANISO,I-1)
      VARMAJ = right$(this.LANISO,I+1)
      If VARMIN<>tolower(VARMIN) or (VARMAJ<> toupper(VARMAJ) )
        [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(149,100,1),[V]CST_AERROR) : Return
      Endif
    Else
      [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(149,100,1),[V]CST_AERROR) : Return
    Endif
  Endif
Endif
Return

################################################################################################
$LANSTD
Case [L]ARULE
   When "PROPAGATE"   : Gosub LANSTD_PROPAGATE
Endcase
Return

$LANSTD_PROPAGATE
Gosub LANSTD_DEPENDENCIES
Return

################################################################################################
$LANRPL
Case [L]ARULE
   When "CONTROL"                 : Gosub LANRPL_CONTROL
Endcase
Return

$LANRPL_CONTROL
If this.LANRPL<>""
  Local Instance MY_TABLAN Using C_TABLAN
  MY_TABLAN=NewInstance C_TABLAN AllocGroup null
  [L]ASTATUS = fmet MY_TABLAN.AREAD(this.LANRPL)
  If [L]ASTATUS=[V]CST_AOK and MY_TABLAN.LANSTD<>[V]CST_AYES
    # This is not a standard language
    [L]ASTATUS = fmet this.ASETERROR("LANRPL",this.LANRPL+":"-mess(235,100,1),[V]CST_AERROR)
  Endif
  FreeGroup MY_TABLAN
Endif
Return

################################################################################################
$LANSTD_DEPENDENCIES
If this.LANSTD=[V]CST_AYES
  this.LANCON=[V]CST_AYES
  this.LANRPL=AVOID.ACHAR
Endif
Return

