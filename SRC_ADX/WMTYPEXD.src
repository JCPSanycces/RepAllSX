#<AdxTL>@(#)0.0.0.0 $Revision$Class XSD files
# Supervisor
## ATY-ATYPE ## EXD
# 2018-11-09 07:14:17 218

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CODE,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CODE
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIXSDUPL [EXU]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIXSDUPL" [EXU]
Endif

Default File [F:EXU]
Read [F:EXU]EXU0 = [L]CODE
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODE)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODE)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


