#-------------------------------------
# TRTDSPAYY : Affichage document HTML
#-------------------------------------
# (C) PROSPER 28/10/10
#-------------------------------------

## Action TRTDSPAYY
Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR(250) 
SAVACT = GACTION : GACTION = "TRTDSPAYY"

 PARMSK(1) = "ADMINCONFIG"    
# PARMSK(1) = "VRAPREXCEPT"
# PARMSK(1) = "TEST"
# PARMSK(1) = "SAIRAPSYN"
# PARMSK(1) = "TESTFL"

PARMSK(2) = "FRA"
Call SAISIE_CHAR(VALEUR,PARMSK,"TRTDSPAYY","TRTDSPAYY","") From GSAISIE
GACTION = SAVACT
End

$ACTION
# Infbox [L]ACTION
Case [L]ACTION
    When "OUVRE"
        Gosub OUVRE
    When "DEBUT"
        Gosub DEBUT
    When Default
Endcase

Return

$OUVRE
If not clalev([F:AYY]) : Local File AYTDOC : Endif
# Global Clbfile TRTDSPAYY(9)
Return

$FIN
# Kill [V]TRTDSPAYY
Return

$DEBUT
[M:DIA]DOCCOD = [L]PARAM(1)
[M:DIA]LAN = [L]PARAM(2)
Gosub LECTURE
Return

$LECTURE
Read [F:AYY]AYY0 = [M:DIA]DOCCOD ; [M:DIA]LAN
If fstat = 0
    # On balance le clob dans une variable clob 
    # [V]TRTDSPAYY = [F:AYY]TEXTE
    # On appelle une librairie qui formate le clob affiché (document) 
    # Call INITURL([M:DIA]DOCUMENT,"TRTDSPAYY","","") From INTRUTILA

    # => En fait ce que l'on faisait à la main était strictement identique !!!!
    [M:DIA]DOCUMENT = "<DESC><URL><TIT>Titre de la page</TIT>"+"<TAD>LOC</TAD>"+"<PAG>"
    [M:DIA]DOCUMENT += "<![CDATA["
    [M:DIA]DOCUMENT += [F:AYY]TEXTE
    [M:DIA]DOCUMENT += "]]>"
    [M:DIA]DOCUMENT += "</PAG></URL></DESC>"
    Affzo [M:DIA]DOCUMENT

Endif

Return

