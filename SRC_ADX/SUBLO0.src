Subprog AM_BPRDATVCR(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
#--- Itialisation des cours devise (Suggestion V140)
Local Date SVG_RATDAT
SVG_RATDAT = [M]RATDAT(NOL)
Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
If [F:GTE]RATDAT=2 & VALEUR<>[0/0/0]
 [M]RATDAT(NOL) = VALEUR
Else
 [M]RATDAT(NOL) = [M]ACCDAT(NOL)
Endif
Call CONTDEV([M]CUR(NOL),[M]RATDAT(NOL)) From TRTDEV
If mkstat : End : Endif
If SVG_RATDAT<>[M]RATDAT(NOL)
 #-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
 Call INIT([M:HAE1]CUR(NOL),[M:HAE1]CPY,[F:GTE]TYPRAT,[M:HAE1]RATDAT(NOL),0) From SUBSCL
 Gosub CHARG_ZONES_DEV From SUBSCL
 Gosub INIT_COURS From SUBLO0
Endif
End

