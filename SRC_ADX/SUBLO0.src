$APZACC
Gosub SETNOL
Local Char WCOA(GLONCOA),WSAC(GLONSAC)
WSAC = evalue("[M]SAC"+num$(TYD)+"(NOL)")
WCOA = [M:HAEF]COA(TYD-1)
Affzo ="[M]SAC"+num$(TYD)+"(NOL)"
Gosub AFF_ACC
End

## ----------------------------------------------------------------- BPR
Subprog AS_BPR(VALEUR)
Variable Char     VALEUR
Local Integer OK
Gosub SETNOL
Local Char WCOA(GLONCOA),WACC(GLONGAC),WSAC(GLONSAC)

Raz OK
For I=1 To [M:HAEF]NBRLED
 WCOA = [M:HAEF]COA(I-1)
 WACC = evalue("[M]ACC"+num$(I)+"(NOL)")
 WSAC = evalue("[M]SAC"+num$(I)+"(NOL)")
 If WACC<>""
  Call LECTURE("GAC",WACC,WCOA) From CONTOBJ
  If [F:GAC]SAC=2 : OK=-1 : Break : Endif
 Else
  OK+=1
 Endif
Next

# Le tiers est accessible si aucun compte saisi ou si un des comptes saisi est collectif.
If OK<>[M:HAEF]NBRLED and OK>-1 : mkstat=1 : Endif

Gosub AFF_BPR

# Sauvegarde de la structure
Local Integer TYD
TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC From SUBGA0
End

$AFF_BPR
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LECTURE("BPR",VALEUR,"") From CONTOBJ
 [M]AFFICHE = VALEUR-":"-[F:BPR]BPRNAM : Affzo AFFICHE
Endif
Return

Subprog C_BPR(VALEUR)
Variable Char     VALEUR

#Gosub SETNOL
#Gosub CONTBPR From SUBGA1
#If mkstat : End : Endif

Call C_BPR(VALEUR) From SUBGA0
# PB de ACCDAT dans CONTACC, c'est la prorogation ?!?!
End

Subprog AP_BPR(VALEUR)
Variable Char     VALEUR
Call AP_BPR(VALEUR) From SUBGA0
End

#################################################################
Subprog AS_NUM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If [M]NEW(NOL)=1
 VALEUR = [M]NUM(NOL-1) : mkstat = 2 : End
Elsif [F:GTE]MANNUM<>2
 mkstat = 1 : End
Endif
End

Subprog C_NUM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If VALEUR<>"" | [F:GTE]COU=""
 Look [HAE]HAE0 = [M]TYP(NOL) ; VALEUR
 If !fstat
  GMESSAGE = mess(22,100,1) : # Fiche déjà existante
  mkstat = 2
 Endif
Endif
End

#################################################################
Subprog AS_DEB(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M]CDT(NOL)<>0
 mkstat = 1 : End
Elsif VALEUR=0 & !varinit([M]CDT,NOL)
 Case [F:GAC]SNSDEF
  When 2 : mkstat = 2 : End : # Crédit
  When 3 : Gosub EQUIPCE From SUBLO1
           If [L]SOLDE>0 : mkstat=2 : End : Endif : # Indéterminé
 Endcase
Endif
End

Subprog B2_DEB(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub EQUIPCE From SUBLO1
If [L]SOLDE>0
 [M]CDT(NOL) = [L]SOLDE
 VALEUR = 0 : mkstat = 99
Else
 VALEUR = -[L]SOLDE
Endif
End

Subprog B3_DEB(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub SETSOL From SUBLO1
If [L]SOLDE>0
 [M]CDT(NOL) = [L]SOLDE
 VALEUR = 0 : mkstat = 99
Else
 VALEUR = -[L]SOLDE
Endif
End

#################################################################
Subprog AS_CDT(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M]DEB(NOL)<>0
 mkstat = 1
Else
Endif
End

Subprog B2_CDT(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub EQUIPCE From SUBLO1
If [L]SOLDE>0
 VALEUR = [L]SOLDE
Else
 [M]DEB(NOL) = -[L]SOLDE
 Affzo [M]DEB(NOL)
 VALEUR = 0 : mkstat = 99
 zonsui="DEB("+num$(NOL)+")"
Endif
End

Subprog B3_CDT(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub SETSOL From SUBLO1
If [L]SOLDE>0
 VALEUR = [L]SOLDE
Else
 [M]DEB(NOL) = -[L]SOLDE
 Affzo [M]DEB(NOL)
 VALEUR = 0 : mkstat = 99
 zonsui="DEB("+num$(NOL)+")"
Endif
End

