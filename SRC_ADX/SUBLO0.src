#<AdxTL>@(#)12.0.0.0 $Revision$
# Issue X3-85420 - 2018-06-04 by FHA : GESLOT does not create records for other ledgers

GSCHEMA = ""
Call OBJET("LOT",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "TRT_DIV" Gosub TRT_DIV
Endcase
Return

$TRT_DIV
Local Integer IND,AXI,TYD
Local Decimal FIY
Local Char WACC(GLONGAC), WLED(GLONLED), WCUR(GLONCUR)

Case TRAIT
 When "GENT1" :
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
   If WACC<>""
    TYD=[M:HAEF]LEDTYP(I-1)
    Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
    If GLEDFLGGEN(IND)=2 : Gosub LECTURE : Break : Endif
   Endif
  Next

 When "GENT2" :
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
   If WACC<>""
    TYD=[M:HAEF]LEDTYP(I-1)
    Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
    If GLEDFLGANA(IND)=2 : Gosub LECTURE : Break : Endif
   Endif
  Next
Endcase
Return

$LECTURE
Call LECTURE("GAC",WACC,GLEDCOA(IND)) From CONTOBJ
Call GETEXE([M]CPY,TYD,[M]ACCDAT(nolign-1),[L]FIY) From CPTSUB
Call LECTURE("FIY",num$(TYD),[M]CPY+'~'+num$([L]FIY)) From CONTOBJ
Return


$SETNOL
Local Integer NOL
NOL = nolign-1
Return


#################################################################
# Etiquettes masque HAE1
#################################################################
Subprog AS_LOT(VALEUR)
Variable Char     VALEUR
If find(GREP,"C","D") : mkstat=2 : Endif
End

Subprog AP_LOT(VALEUR)
Variable Char     VALEUR
If VALEUR="" : mkstat=4 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 Call LECTURE("LOT",VALEUR,"") From CONTOBJ
 If fstat : Raz VALEUR : Endif
Endif
End

#################################################################
Subprog C_DACDIAGAS(VALEUR)
Variable Char    VALEUR()
Read [F:GDE]DIA = [M]DACDIA
GGRPFCY = [F:GDE]GFY
Call LECTURE("GDE",VALEUR,"") From CONTOBJ
If [F:GDE]FLGLOT = 2
 ## Transaction de type 'Saisie par lot'
 GMESSAGE = mess(120,106,1)
 mkstat = 2  : End
Elsif [F:GDE]TYPENT=3
 ## La transaction de saisie doit être de type 'Ligne' ou 'Colonne'
 GMESSAGE = mess(119,106,1)
 mkstat = 2  : End
Endif
# Si la transaction de saisie lot n'est pas associée à un groupe de sites mais que la transaction de saisie
# dans laquelle sera généné le lot est associé à un groupe de site, il faut initialiser GGRPFCY
If GGRPFCY = "" : GGRPFCY = [F:GDE]GFY : Endif
Read [F:GDE]DIA = [M]DACDIA
End

#################################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If [M]NBLIG<>0 : mkstat = 2 : Endif
End

Subprog C_FCY(VALEUR)
Variable Char     VALEUR
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call GETSOC(VALEUR) From DEVSUB
Call SETCUR(1,[M]CPY,[M]CURAFF) From CPTDIV
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# <JFL>
Local Integer OK, STAT
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call UNLOCKCPY() From AX3MONO # déverrouillage ancienne société
Call LOCKCPY([F:FCY]LEGCPY, OK) From AX3MONO # verrouillage nouvelle société
If !OK : mkstat=2 : End : Endif
# </JFL>

#--- Initialisation et contrôle des masques
[M]FCY = VALEUR
 Call INIMSKFMT(VALEUR,[F:GDE]DIA,[M]TYP(nolign-1),[M]ACCDAT(nolign-1),STAT)  From SUBGASA
 If [M:HAEF]NBRLED=0 or [M:HAEF]NBRAXI=99 or GERR=1
  GMESSAGE=""
  Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
  GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1) : # Paramétrage à revoir
  mkstat=2 : End
 Endif
End

Subprog D_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
VALEUR = [F:FCY]LEGCPY
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
End

#################################################################
Subprog C_JOU(VALEUR)
Variable Char     VALEUR
[M]JOU=VALEUR
Gosub CONTJOU From SUBLO1
End

#################################################################
#### Tableaux...    #############################################
#################################################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6

If nolign-1 < NBLIG
 Local Char WACC(GLONGAC), WSAC(GLONSAC)
 Local Integer IND,AXI

 For I=1 To [M:HAEF]NBRLED
  WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
  If WACC<>""
   Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
   If GLEDFLGGEN(IND)=2 & GBOUT1="" :  GBOUT1 = mess(1,109,1) : Endif
   # Consultation de compte
   If GLEDFLGANA(IND)=2 : GBOUT2="" :  GBOUT2 = mess(59,109,1) : Endif
   # Consultation de compte analytique
  Endif
 Next
 GBOUT3 = mess(29,106,1)          : # Codes statistiques

 If [M]DSP(nolign-1)<>""
  Gosub AVT_SAIDSP From SUBGA0
  GBOUT5 = mess(53,109,1)      : # Consultation des répartitions
 Endif
Endif
End

Subprog AS_NBLIG
Gosub AFF_NBLIG From SUBGA0
End

Subprog AVANT_NBLIG
Local Integer L
Gosub SETNOL
L=NOL
Gosub CONVCPY
[M]TOTDEB -= DEBIT
[M]TOTCDT -= CREDIT

If [M]NEW(NOL)=2
 For L=NOL+1 To [M]NBLIG-1
  If [M]NEW(L)=2 : Break : Endif
  Gosub CONVCPY
  [M]TOTDEB -= DEBIT
  [M]TOTCDT -= CREDIT
 Next
Endif
Gosub AFF_NBLIG From SUBGA0
End

$CONVCPY
Local Decimal DEBIT, CREDIT, COURS
Local Integer STAT : STAT=0
If [M]CUR(L)="" or [M]CURAFF="" : Return : Endif
If [M]CUR(L)<>[M]CURAFF
 Call LEC_GTE_LEG(GCURLEG,[M]TYP(L)) From CPTLEC
 If evalue("[M]RATDIV"+num$(GTYPGEN))>0 : COURS =  evalue("[M]RATMLT"+num$(GTYPGEN))/evalue("[M]RATDIV"+num$(GTYPGEN)) : Endif
 Call CONVERT3([M]CUR(L),[M]CURAFF,[M]CURAFF,[F:GTE]TYPRAT,[M]RATDAT(L),
&              [M]DEB(L),DEBIT,COURS,STAT) From CPTSUB
 If STAT : # Pas de cours de devises [M]CUR -> [M]CURAFF (RATDAT)
    #GMESSAGE=mess(16,114,1)-[M]CUR(L)-"->"-[M]CURAFF-"("+format$("D:"+GFMDAT,[M]RATDAT(L))+")"
    Raz DEBIT,CREDIT
 Else
    Call CONVERT3([M]CUR(L),[M]CURAFF,[M]CURAFF,[F:GTE]TYPRAT,[M]RATDAT(L),
&                 [M]CDT(L),CREDIT,COURS,STAT) From CPTSUB
 Endif
Else
 DEBIT = [M]DEB(L)
 CREDIT = [M]CDT(L)
Endif
Return

Subprog APRES_NBLIG
Local Integer L
Local Char WACC(GLONGAC)
Gosub SETNOL
L=NOL
Gosub CONVCPY
[M]TOTDEB += DEBIT
[M]TOTCDT += CREDIT

If !find(status,65,68,83)
 For I=1 To [M:HAEF]NBRLED
  WACC = evalue("[M:HAE1]ACC"+num$(I)+"(NOL)")
  If WACC<>""
   Gosub MODZON From SUBLO1
   Break
  Endif
 Next
Endif
If [M]NEW(NOL)=2
 For L=NOL+1 To [M]NBLIG-1
  If [M]NEW(L)=2 : Break : Endif
  Gosub CONVCPY
  [M]TOTDEB += DEBIT
  [M]TOTCDT += CREDIT
 Next
Endif
Affzo TOTDEB, TOTCDT, SOLDE, CURAFF, CURAFF2
End

#################################################################
Subprog AS_NEW(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If NOL=0 : VALEUR = 2 : mkstat = 2 : End : Endif
End

Subprog D_NEW(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Gosub EQUIPCE From SUBLO1
If [L]SOLDE=0
 VALEUR = 2 : # Nouvelle pièce si la précédente est équilibrée
Else
 VALEUR = 1
Endif
End

Subprog AP_NEW(VALEUR)
Variable Integer VALEUR
Local Integer OK
Gosub SETNOL
If inpmode<>2 | [M]NEW(NOL)=VALEUR | VALEUR=1 : End : Endif
Gosub EQUIPCE From SUBLO1
If [L]SOLDE
 OK=1 : Call AVERTIR(mess(52,106,1),OK) From GESECRAN
 # Pièce précédente déséquilibrée
 If OK<>2 : mkstat = 2 : VALEUR = 1 : Endif
Endif
End

#################################################################
Subprog AS_TYP(VALEUR)
Variable Char    VALEUR
Gosub SETNOL
If [M]NEW(NOL)=1
 VALEUR = [M]TYP(NOL-1) : mkstat = 2 : End
Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR
Gosub CONTTYP From SUBLO1
End

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR
Gosub SETNOL
Raz [M]ACCDAT(NOL), [M]FIY(NOL), [M]PER(NOL)
End

#################################################################
Subprog AS_ACCDAT(VALEUR)
Variable Date     VALEUR
Local Integer I
Gosub SETNOL
If [M]NEW(NOL)=1
 VALEUR = [M]ACCDAT(NOL-1)
 [M]FIY(NOL) = [M]FIY(NOL-1)
 [M]PER(NOL) = [M]PER(NOL-1)
 mkstat = 2 : End
Endif
If VALEUR=[0/0/0] | [F:GTE]PER>1
 Gosub SETDAT From SUBGA0
 VALEUR = DAT
Endif
If [F:GTE]PER>1 : mkstat = 2 : End : Endif
For I=0 To len(mess(0,2644,1))-1
 Call GETPERSOC([M]CPY,I+1,[M]ACCDAT(NOL),[M:HAEF]FIY(I),[M:HAEF]PER(I)) From CPTSUB
Next
End

Subprog C_ACCDAT(VALEUR)
Variable Date     VALEUR

Gosub SETNOL
Call CONTDAT(VALEUR,[M]ACCDAT(NOL)) From SUBLO1
If mkstat : End : Endif

#->KC : dates par modules
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,[M]CPY) From CPTSUB
 If mkstat : End : Endif
Endif
#<-KC

#--- Itialisation des cours devise
Gosub SETNOL
If [M]ACCDAT(NOL)<>VALEUR & [M]CUR<>''
  Local Date SVG_RATDAT
  SVG_RATDAT = [M]RATDAT(NOL)
  Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
  If [F:GTE]RATDAT=2 & [M]BPRDATVCR<>[0/0/0]
   [M]RATDAT(NOL) = [M]BPRDATVCR
  Else
   [M]RATDAT(NOL) = VALEUR
  Endif
  Call CONTDEV([M]CUR,[M]RATDAT(NOL)) From TRTDEV
  If mkstat : End : Endif
  If SVG_RATDAT<>[M]RATDAT(NOL)
   #-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
   Call INIT([M:HAE1]CUR(NOL),[M:HAE1]CPY,[F:GTE]TYPRAT,[M:HAE1]RATDAT(NOL),0) From SUBSCL
   Gosub CHARG_ZONES_DEV From SUBSCL
   Gosub INIT_COURS From SUBLO0
  Endif
 Endif
End

Subprog AP_ACCDAT(VALEUR)
Variable Date     VALEUR
For I=1 To 10
 Call GETPERSOC([M]CPY,I,VALEUR,[M:HAEF]FIY(I-1),[M:HAEF]PER(I-1)) From CPTSUB
Next
End

#################################################################
Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If [M]NEW(NOL)=1
 VALEUR = [M]CUR(NOL-1) : mkstat = 2 : End
Endif
If VALEUR=""
 VALEUR = [M]CURAFF
 Local Date SVG_RATDAT
 SVG_RATDAT = [M]RATDAT(NOL)
 Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
 If [F:GTE]RATDAT=2 & [M]BPRDATVCR(NOL)<>[0/0/0]
  [M]RATDAT(NOL) = [M]BPRDATVCR(NOL)
 Else
  [M]RATDAT(NOL) = [M]ACCDAT(NOL)
 Endif
 #-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
 Call INIT([M:HAE1]CUR(NOL),[M:HAE1]CPY,[F:GTE]TYPRAT,[M:HAE1]RATDAT(NOL),0) From SUBSCL
 Gosub CHARG_ZONES_DEV From SUBSCL
 Gosub INIT_COURS From SUBLO0
Endif
End

Subprog C_CUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Local Date SVG_RATDAT
SVG_RATDAT = [M]RATDAT(NOL)
Call LEC_GTE_LEG(GCURLEG,[M]TYP(NOL)) From CPTLEC
If [F:GTE]RATDAT=2 & [M]BPRDATVCR(NOL)<>[0/0/0]
 [M]RATDAT(NOL) = [M]BPRDATVCR(NOL)
Else
 [M]RATDAT(NOL) = [M]ACCDAT(NOL)
Endif
Call CONTDEV(VALEUR,[M]ACCDAT(NOL)) From TRTDEV
If mkstat : End : Endif
If SVG_RATDAT<>[M]RATDAT(NOL) : Call AM_CUR(VALEUR) : Endif
End

Subprog AM_CUR(VALEUR)
Variable Char     VALEUR
Local Integer STAT
Gosub SETNOL
[M]CUR(NOL) = VALEUR : Affzo [M]CUR(NOL)
#-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
Call INIT([M:HAE1]CUR(NOL),[M:HAE1]CPY,[F:GTE]TYPRAT,[M:HAE1]RATDAT(NOL),0) From SUBSCL
Gosub CHARG_ZONES_DEV From SUBSCL
Gosub INIT_COURS From SUBLO0
End

#################################################################
Subprog D_FCYLIN(VALEUR)
Variable Char     VALEUR
VALEUR = [M]FCY
End

Subprog C_FCYLIN(VALEUR)
Variable Char     VALEUR
If [F:FCY]LEGCPY<>[M]CPY
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
 mkstat = 2 : End
Endif
End

Subprog AS_FCYLIN(VALEUR)
Variable Char     VALEUR
If !find(VALEUR,GUSRFCY(1..GNBAUZ)) : mkstat = 2 : End : Endif
End

#################################################################

## ----------------------------------------------------------------- SAC
Subprog AS_SAC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAISAC
Subprog AS_SAC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAISAC
Subprog AS_SAC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAISAC
Subprog AS_SAC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAISAC
Subprog AS_SAC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAISAC
Subprog AS_SAC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAISAC
Subprog AS_SAC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAISAC
Subprog AS_SAC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAISAC
Subprog AS_SAC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAISAC
Subprog AS_SAC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAISAC

$SAISAC
Gosub SETNOL
If VALEUR="" & !find(status,5,31,75) : mkstat=2 : End : Endif

# Contrôle exercice/période
Call CONTPER([M]ACCDAT(NOL),[M:HAEF]LEDTYP(TYD-1),[M]FCYLIN(nolign-1)) From CPTSUB
If mkstat=2 : End : Endif

# Sauvegarde de la structure
Gosub AVT_SAIACC From SUBGA0
End

#########################
Subprog C_SAC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTSAC
Subprog C_SAC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto CONTSAC
Subprog C_SAC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto CONTSAC
Subprog C_SAC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto CONTSAC
Subprog C_SAC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto CONTSAC
Subprog C_SAC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto CONTSAC
Subprog C_SAC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto CONTSAC
Subprog C_SAC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto CONTSAC
Subprog C_SAC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto CONTSAC
Subprog C_SAC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto CONTSAC

$CONTSAC
If VALEUR="" : End : Endif
Gosub SETNOL
Local Char WCOA(GLONCOA)

WCOA = [M:HAEF]COA(TYD-1)
Read [GAC]GAC1 = WCOA;VALEUR
If fstat | [F:GAC]SAC<>2
 GMESSAGE = WCOA-VALEUR-mess(9,106,1) : # Collectif inexistant
 mkstat = 2 : End
Endif

Call CONTACC([F:GAC]ACC,[M:HAEF]LEDTYP(TYD-1),[M:HAEF]LED(TYD-1),[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT(NOL)) From SUBGA1
If mkstat : End : Endif

Assign "[M]ACC"+num$(TYD)+"(NOL)" With [F:GAC]ACC
End

## ----------------------------------------------------------------- ACC
Subprog IB_ACC1
TYD = 1 : Goto BOUTACC
Subprog IB_ACC2
TYD = 2 : Goto BOUTACC
Subprog IB_ACC3
TYD = 3 : Goto BOUTACC
Subprog IB_ACC4
TYD = 4 : Goto BOUTACC
Subprog IB_ACC5
TYD = 5 : Goto BOUTACC
Subprog IB_ACC6
TYD = 6 : Goto BOUTACC
Subprog IB_ACC7
TYD = 7 : Goto BOUTACC
Subprog IB_ACC8
TYD = 8 : Goto BOUTACC
Subprog IB_ACC9
TYD = 9 : Goto BOUTACC
Subprog IB_ACC10
TYD = 10 : Goto BOUTACC

$BOUTACC
Raz GBOUT3, GBOUT4

GBOUT1 = mess(45,102,1)      :    # Comptes
GBOUT2 = mess(46,102,1)      :    # Codes d'appel

Local Char WCOA(GLONCOA),WACC(GLONGAC)
Gosub SETNOL
WACC = evalue("[M]ACC"+num$(TYD)+"(NOL)")
WCOA = [M:HAEF]COA(TYD-1)
Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[F:JOU]JOU)From CPTLEC
If !fstat and [F:JCO]FRQNBR<>0
 GBOUT3 = mess(50,106,1) :    # Comptes fréquents
Endif
If WACC<>""
 Call LECTURE("GAC",WACC,WCOA) From CONTOBJ
 If !fstat
  GBOUT4 = mess(1,109,1)  :    # Consultation de comptes
 Endif
Endif
End

##########################
Subprog AS_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAIACC
Subprog AS_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAIACC
Subprog AS_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAIACC
Subprog AS_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAIACC
Subprog AS_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAIACC
Subprog AS_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAIACC
Subprog AS_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAIACC
Subprog AS_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAIACC
Subprog AS_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAIACC
Subprog AS_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAIACC

$SAIACC
Gosub SETNOL
Local Integer I,IND, WTYP
Local Char WLED(GLONLED),WCOA(GLONCOA),WSAC(GLONSAC)
WSAC = evalue("[M]SAC"+num$(TYD)+"(NOL)")
If WSAC<>"" & !find(status,5,31,75) : mkstat = 2 : End : Endif

# Contrôle exercice/période
Call CONTPER([M]ACCDAT(NOL),[M:HAEF]LEDTYP(TYD-1),[M]FCYLIN(nolign-1)) From CPTSUB
If mkstat=2 : End : Endif

# Règles de progation
If GNBSTR>=1
 Case [M:HAEF]TYPENT
  When 1 :
   # Saisie en colonne
   WCOA = [M:HAEF]COA(TYD-1)
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   For I=1 To TYD-1
    WACC = evalue("[M]ACC"+num$(I)+"(NOL)")
    If WACC<>""
     Call LECTURE("GAC",WACC,evalue("[M:HAEF]COA("+num$(I-1)+")")) From CONTOBJ
     If WCOA<>[F:GAC]COA  # Issue X3-85420
      If !find(WCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1)) & [F:GTE]AUZLED(WTYP-1)<>3 : mkstat = 1 : Break :  Endif
     Endif                # Issue X3-85420
    Endif
   Next
  When 2
   J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   WCOA = [M:HAEF]COA(J-1)
 Endcase
 If mkstat=1 : End : Endif
 If VALEUR=""
  # Sauvegarde de la structure
  Gosub AVT_SAIACC From SUBGA0
  Call INIPRO(WCOA,VALEUR) From SUBGA1
 Endif
Endif

If VALEUR<>"" : Gosub AFF_ACC : Endif
End

##########################
Subprog C_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTACC
Subprog C_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto CONTACC
Subprog C_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto CONTACC
Subprog C_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto CONTACC
Subprog C_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto CONTACC
Subprog C_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto CONTACC
Subprog C_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto CONTACC
Subprog C_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto CONTACC
Subprog C_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto CONTACC
Subprog C_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto CONTACC

$CONTACC
Call ="C_ACC"+num$(TYD) With VALEUR From SUBGA0
End

$AFF_ACC
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Local Char DESACC(GLONAX3)
 Call LECTURE("GAC",VALEUR,WCOA) From CONTOBJ
 Call LECTEXTRA([L]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 [M]AFFICHE = VALEUR-":"-[L]DESACC : Affzo AFFICHE
Endif
Return

