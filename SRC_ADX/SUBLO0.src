#################################################################
#################################################################
#CHECK IGNORE_BEGIN

$CURAFF
Local Integer I
For I=0 To 2
 If evalue("dim([M:HAE"+num$(I)+"]CURAFF)>0")
  Case I
   When 0 : [M:HAE0]CURAFF = VALEUR : Affzo [HAE0]CURAFF
   When 1 : [M:HAE1]CURAFF = VALEUR : Affzo [HAE1]CURAFF
   When 2 : [M:HAE2]CURAFF = VALEUR : Affzo [HAE2]CURAFF
  Endcase
 Endif
 If evalue("dim([M:HAE"+num$(I)+"]CURAFF2)>0")
  Case I
   When 0 : [M:HAE0]CURAFF2 = VALEUR : Affzo [HAE0]CURAFF2
   When 1 : [M:HAE1]CURAFF2 = VALEUR : Affzo [HAE1]CURAFF2
   When 2 : [M:HAE2]CURAFF2 = VALEUR : Affzo [HAE2]CURAFF2
  Endcase
 Endif
Next I
#zoncou = "CUR"
Return
#CHECK IGNORE_END



$INIT_COURS
Gosub INIT_COURS From SUBSCL
# Remplissage du masque HAE1
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(I)<>""
  # Devise de pièce = Devise de référentiel
  If [F:GCM]CUR(I)=[M:SCL]CURENT
   Assign "[M:HAE1]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")"  With 1
   Assign "[M:HAE1]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")"  With 1
  Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
   Assign "[M:HAE1]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")"  With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
   Assign "[M:HAE1]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")"  With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
  Endif
 Endif
Next
Return

