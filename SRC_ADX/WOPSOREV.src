$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Shortint A_BUF2(0..GNBDERNIER)
Local Char     A_BUF3(30)(0..GNBDERNIER)
Local Char     A_BUF4(40)(0..GNBDERNIER)
Local Char     A_BUF5(15)(0..GNBDERNIER)
Local Char     A_BUF6(20)(0..GNBDERNIER)
Local Date     A_BUF7(0..GNBDERNIER)
Local Char     A_BUF8(5)(0..GNBDERNIER)
If clalev([F:VPSOH9])>0 : Close Local File [VPSOH9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Shortint A_TAB2,
& Char     A_TAB3(30),
& Char     A_TAB4(40),
& Char     A_TAB5(15),
& Char     A_TAB6(20),
& Date     A_TAB7,
& Char     A_TAB8(5)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8
& As [VPSOH9]
Return

$LEC_DERLU
Read [PSOH]PSOH0=[F:VPSOH]PSONUM
If fstat : Raz [F:PSOH] : Endif
Return

$CHARGE_DERLU
If clalev([F:VPSOH9])>0
 Read [VPSOH9] = [F:VPSOH9]A_TABI
 [L]CLE = [F:VPSOH9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:VPSOH9])>0
 Filter [VPSOH9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [REVPSO1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:VPSOH9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = num$([F:VPSOH]REVNUM)+"~"
 A_CLEDERLU += [F:VPSOH]PSONUM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:VPSOH9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:VPSOH9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:VPSOH]PSONUM"
Call TEXTE(56316,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:VPSOH]PSONUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:VPSOH]REVNUM"
Call TEXTE(4861,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 2
SELFMT(NBSEL) = "N:4F"
SELFOR(NBSEL) = "N:4#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:VPSOH]REVNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(3)"
SELEXP(NBSEL) = "string$(num$([F:VPSOH]CURREVFLG)<>'2',mess([F:VPSOH]DOCTYP,7718,1))+string$(num$([F:VPSOH]CURREVFLG)='2',mess([F:PSOH]DOCTYP,7718,1))"
Call TEXTE(865,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(4)"
SELEXP(NBSEL) = "string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]OPPNUM)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]OPPNUM)"
Call TEXTE(18260,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(5)"
SELEXP(NBSEL) = "string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]BPCORD)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]BPCORD)"
Call TEXTE(2951,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(6)"
SELEXP(NBSEL) = "string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]HDOCNUM)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]HDOCNUM)"
Call TEXTE(171,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(7)"
SELEXP(NBSEL) = "string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]DOCDAT)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]DOCDAT)"
Call TEXTE(13676,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:VPSOH]SALFCY"
Call TEXTE(5060,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:VPSOH]SALFCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:VPSOH_])=0
 Gosub OUVFIC_LISTE
Endif
Return

