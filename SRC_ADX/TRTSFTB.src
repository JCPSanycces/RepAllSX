#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Shop floor tracking Break and indirect reference entry
#
# Local menu 2417 holds the values for break and indirect types
# 1 - Time off (not handled by this screen)
# 2 - Break (always exclusive)
# 3 - Non-exclusive labor (indirect task that does not stop others)
# 4 - Exclusive labor (indirect task that stops others - acts like a break)
# 5 - Auto breaks (can't be selected manually)
#
######################################################################################
$ACTION

  Case [L]ACTION
    When "TITRE"    : Gosub TIT
    When "OUVRE"    : Gosub OUVRE
    When "DEBUT"    : Gosub DEBUT
    When "OK"       : Gosub OK
    When "FERME"    : Gosub FERME
  Endcase

Return

######################################################################################
$TIT
  # Set the correct title based on what action is calling the window
  Case PARAM(3)
    When "IND", "EIR" : TIT = mess(8,2422,1) # Indirect references
    When "BRK", "EBK" : TIT = mess(9,2422,1) # Breaks
  Endcase
Return

######################################################################################
$OUVRE
  Local Integer EMPLOYEETYPE
  Local Instance SFTTXN Using C_SFTTXN
  Global Char ACTTYPE(3)  : ACTTYPE = PARAM(3)
  If !clalev([F:TMA]) : Local File TABMAT     [TMA]   : Endif
Return

######################################################################################
$DEBUT
  Local Integer I
  Local Char SFILTER(25), BRKTYP(3)
  Local Integer WMAX
  If !clalev([SFTIR]) : Local File SFTINDREF [SFTIR]  : Endif

  BRKTYP = PARAM(3)

  Case BRKTYP
    When "BRK", "EBK"  : SFILTER = "INDTYP=2"
    When "IND", "EIR"  : SFILTER = "INDTYP=3 or INDTYP=4"
  Endcase

  Raz [M:SFTB]

  WMAX = dim([M:SFTB]COD)  # Max lines to be displayed

  Filter [SFTIR] Where evalue(SFILTER)
  For [SFTIR]
    If I >= WMAX
        Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
        Break
    Endif

    [M:SFTB]SELLIN(I)     = AVOID.AINT
    [M:SFTB]COD(I)        = [F:SFTIR]INDCOD
    Call  LECTEXTRA([M:SFTB]DES(I), "SFTINDREF", "INDESAXX", num$([M:SFTB]COD(I)), "" ) From ATEXTRA
    [M:SFTB]INDTYP(I)     = [F:SFTIR]INDTYP
    [M:SFTB]TIMUOMCOD(I)  = 2
    I += 1
  Next

  Filter [SFTIR]
  [M:SFTB]NBLIG = I

  Case BRKTYP
    When "EBK"
      Chgfmt [M:SFTB]NUMJOBS  With "-K:"  + num$(type([M:SFTB]NUMJOBS)-10)  + "B"    # Hide
    When "BRK", "IND"
      Chgfmt [M:SFTB]NUMJOBS  With "-K:"  + num$(type([M:SFTB]NUMJOBS)-10)  + "B"    # Hide
      Chgfmt [M:SFTB]DURTIM   With "-K:"  + num$(type([M:SFTB]DURTIM)-10)   + "B"    # Hide
      Chgfmt [M:SFTB]TIMUOMCOD  With "-K:"  + num$(type([M:SFTB]DURTIM)-10)   + "B"    # Hide
  Endcase

  Affzo [M:SFTB]

Return

######################################################################################
$OK
  Local Integer   EMPNUM, I, SELECTED, EXCL, SFTTYP
  Local Char      FCY(5)
  Local Datetime  STARTDATE
  Local Integer   INDTYP(0..), NUMJOBS(0..)
  Local Char      BRKCOD(3)(0..), ACTTYP(3)(0..)
  Local Decimal   DURATION(0..)
  Local Integer   EMPTEAMNUM
  Local Integer   YESNO : YESNO = [V]CST_AYES
  Local Char      ERRMSG(125)
  Local Integer   ERRNUM

#  Local Integer   INDTYP([M:SFTB]NBLIG), NUMJOBS([M:SFTB]NBLIG)
#  Local Char      BRKCOD(3)([M:SFTB]NBLIG), ACTTYP(3)([M:SFTB]NBLIG)
#  Local Decimal   DURATION([M:SFTB]NBLIG)

  # Arrays to pass to class methods
  Local Char      CHARBLANK(20)(0..[M:SFTB]NBLIG) # Using this for all that we don't need to pass
  Local Integer   INTBLANK(0..[M:SFTB]NBLIG)      # Using this for all that we don't need
  Local Decimal   DECBLANK(0..[M:SFTB]NBLIG)      # Using this for all that we don't need

  EMPNUM  = val(PARAM(1))
  FCY     = PARAM(2)

  # Get Employee type
  [L]EMPLOYEETYPE = func SFTLIB.EMPTYP(EMPNUM)

  Case PARAM(3)
    When "BRK", "EBK"
      SFTTYP=3
    When "IND", "EIR"
      SFTTYP=2
  Endcase

  #  Action not allowed if employee active on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPNUM) = [V]CST_AYES
    #Call ERREUR(mess(18,2422,1)) From GESECRAN

    #CT-1797.sn
    Case [L]EMPLOYEETYPE
      When 1  # Employee
        Call ERREUR(mess(18,2422,1)) From GESECRAN
      When 2  # Detailed Team
        Call ERREUR(mess(122,2422,1)) From GESECRAN
      When 3  # Summary team
        Call ERREUR(mess(121,2422,1)) From GESECRAN
    Endcase
    #CT-1797.en

    Return
  Endif

  # Default Exclusive to No
  EXCL = [V]CST_ANO

  For I=0 To [M:SFTB]NBLIG-1
    If [M:SFTB]SELLIN(I)    = [V]CST_AYES
      [L]BRKCOD(SELECTED)   = [M:SFTB]COD(I)
      [L]INDTYP(SELECTED)   = [M:SFTB]INDTYP(I)
      [L]NUMJOBS(SELECTED)  = [M:SFTB]NUMJOBS(I)
      [L]DURATION(SELECTED) = [M:SFTB]DURATION(I)
      [L]ACTTYP(SELECTED)    = ACTTYPE
      SELECTED+=1
      If PARAM(3) <> "EIR" & PARAM(3) <> "EBK"
        # If Break or Exclusive labor, only allow one - so break if found
        If find([M:SFTB]INDTYP(I),2,4) : [L]EXCL=[V]CST_AYES : Break : Endif
      Endif
    Endif
  Next I

  # If nothing selected - end
  If SELECTED=0
    GERR = 1 : GMESSAGE = mess(187,7900,1)
    FIN = 0 : Return
  Endif

  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  If PARAM(3) = "EIR" | PARAM(3) = "EBK"   # Elapsed labor indirect and Elapsed
    If fmet SFTTXN.TIME_TRACKING([L]EMPNUM, [L]FCY, BRKCOD, INDTYP,
&                                INTBLANK, NUMJOBS, CHARBLANK, CHARBLANK,
&                                DURATION, DECBLANK, DECBLANK, ACTTYP,
&                                DECBLANK, INTBLANK, INTBLANK, SELECTED)

      Call ERREUR(func AFNC.MES1(mess(10,2422,1),mess([L]SFTTYP,2416,1))) From GESECRAN
      Return
    Endif
  Else
    If [L]EXCL=[V]CST_AYES
      # Only one allowed, so no loop and will always in position 0 of array
      If fmet SFTTXN.BREAK_START([L]EMPNUM, [L]FCY, [L]SFTTYP, [L]BRKCOD(0), [L]INDTYP(0)) <> [V]CST_AOK
        Call ERREUR(func AFNC.MES1(mess(10,2422,1),mess([L]SFTTYP,2416,1))) From GESECRAN
        Return
      Endif
    Else
      # Start the operations
      If SELECTED > 0

        # Check if employee is in a team and if he has any team activities running
        Call EMP_TEAM_NUM ([L]EMPNUM, EMPTEAMNUM) From SFTLIB
        If EMPTEAMNUM <> 0   # Employee is part of the team
          If !clalev([SFTXNS]) : Local File SFTTXN [SFTXNS] : Endif
          Filter [F:SFTXNS] Where (EMPNUM = [L]EMPNUM & TEAMNUM = EMPTEAMNUM) &
&                            SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM
          Look [F:SFTXNS] First
          If fstat = 0    # Found open team activities...
            Call OUINON(mess(107,2422,1), YESNO) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
            If YESNO <> [V]CST_AYES    # No
              mkstat = 2
              Return
            Endif

            # Stop open activities...
            Call STOP_OPEN_ACTIVITIES(EMPTEAMNUM, [L]EMPNUM, ERRNUM, ERRMSG) From SFTLIB
            If ERRNUM
              GERR=1 : GMESSAGE = ERRMSG
              LogicClose File [SFTXNS]
              mkstat = 2
              Return
            Endif
            LogicClose File [SFTXNS]
          Endif
        Endif

        STARTDATE = datetime$

        Local Instance SFTTXN Using C_SFTTXN
        SFTTXN = NewInstance C_SFTTXN AllocGroup null

        If fmet SFTTXN.OPERATION_START([L]EMPNUM, [L]FCY, [L]EMPLOYEETYPE, 2, STARTDATE, BRKCOD, INDTYP, INTBLANK, CHARBLANK, CHARBLANK, CHARBLANK, 1, SELECTED, SELECTED) <> [V]CST_AOK
          Call ERREUR(func AFNC.MES1(mess(10,2422,1),mess([L]SFTTYP,2416,1))) From GESECRAN
          Return
        Endif
      Endif
    Endif
  Endif

  FreeGroup SFTTXN

Return

######################################################################################
$FERME
  If (SFTTXN <> null) : FreeGroup SFTTXN : Endif
  Kill SFTTXN
Return

######################################################################################
Subprog C_SELLIN(VALEUR)
Variable Integer VALEUR

  Local Integer I, CURLIN, FOUND
  CURLIN=nolign-1
  FOUND=[V]CST_ANO

  # If we are unchecking - no need to verify
  If VALEUR<>[V]CST_AYES : End : Endif
  If ACTTYPE = "EBK" | ACTTYPE = "EIR" : End : Endif

  # Breaks (type 2) and Exclusive Indirect (type 4) must be only line
  If find([M:SFTB]INDTYP(CURLIN),2,4)
    If find([V]CST_AYES,[M:SFTB]SELLIN) : FOUND=[V]CST_AYES : Endif
  Else
    For I=0 To [M:SFTB]NBLIG-1
      If I<>CURLIN & [M:SFTB]SELLIN(I)=[V]CST_AYES & [M:SFTB]INDTYP(I)=4
        FOUND=[V]CST_AYES
      Endif
    Next I
  Endif

  If FOUND=[V]CST_AYES
    VALEUR=[V]CST_ANO
    mkstat=2
    Call ERREUR (mess(11,2422,1)) From GESECRAN
  Endif

End

######################################################################################
Subprog AVANT_NBLIG

  Case ACTTYPE
    When "EBK"    # Elapsed labor break
      Grizo [M:SFTB]NUMJOBS(nolign-1)
      Actzo [M:SFTB]DURTIM(nolign-1)
    When "EIR"    # Elapsed labor indirect
      If [M:SFTB]INDTYP(nolign-1) <> 4
        Actzo [M:SFTB]NUMJOBS(nolign-1)
      Else
        Grizo [M:SFTB]NUMJOBS(nolign-1)
      Endif
      Actzo [M:SFTB]DURTIM(nolign-1)
    When Default
      Grizo [M:SFTB]NUMJOBS(nolign-1)
      Grizo [M:SFTB]DURTIM(nolign-1)
  Endcase

End

######################################################################################
Subprog AM_NUMJOBS(VALEUR)
Variable Decimal VALEUR
    Call NUMJOBSLINE()
    Call SELECTLINE(VALEUR)
End

######################################################################################
Subprog AM_DURTIM(VALEUR)
Variable Decimal VALEUR

  # Check Time unit, convert to minutes if needed.
  If [M:SFTB]TIMUOMCOD(nolign-1) = 1
    [M:SFTB]DURATION(nolign-1) = VALEUR * 60
  Else
    [M:SFTB]DURATION(nolign-1) = VALEUR
  Endif

  Call SELECTLINE([M:SFTB]DURATION(nolign-1))
End

######################################################################################
Subprog C_DURTIM(VALEUR)
Variable Decimal    VALEUR()

  Call NUMJOBSLINE()

End

######################################################################################
Subprog C_NUMJOBS(VALEUR)
Variable Decimal VALEUR

  Call NUMJOBSLINE()

End
######################################################################################
Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR

  Call NUMJOBSLINE()

End
######################################################################################
Subprog NUMJOBSLINE()

  If [M:SFTB]INDTYP(nolign-1) = 4
    Grizo  [M:SFTB]NUMJOBS(nolign-1)
    Affzo  [M:SFTB]NUMJOBS(nolign-1)
  Endif

End

#####################################################################################
Subprog SELECTLINE(I)
Value Decimal I
  If I<>0
    [M:SFTB]SELLIN(nolign-1)=[V]CST_AYES
    Affzo [M:SFTB]SELLIN(nolign-1)
  Endif
End

