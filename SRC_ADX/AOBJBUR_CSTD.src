#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AOBJBUR

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"         : Gosub CTRANS1_IDENT
      When "AUPDATE_AFTER"     : Gosub CTRANS1_IDENT
      When "AINSERT_AFTER"       : Gosub CTRANS1_IDENT
      When "ADELETE_AFTER"      : Gosub CTRANS1_IDENT
      When "AUPDATE_CONTROL_BEFORE"     : Gosub CTRANS2_IDENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub CTRANS2_IDENT
      When "ADELETE_CONTROL_BEFORE"      : Gosub CTRANS2_IDENT
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]ARULE
  When "GET" : Gosub GET
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return







$CTRANS1_IDENT
this.IDENT1 = ctrans(this.IDENT1,CST_TILDE,CST_ESCTILDE)
this.IDENT2 = ctrans(this.IDENT2,CST_TILDE,CST_ESCTILDE)
Return

$CTRANS2_IDENT
this.IDENT1 = ctrans(this.IDENT1,CST_ESCTILDE,CST_TILDE)
this.IDENT2 = ctrans(this.IDENT2,CST_ESCTILDE,CST_TILDE)
Return

$GET
Case CURPRO
 When "IDENT1BLB"    : this.IDENT1BLB=ctrans(this.IDENT1 ,[V]CST_ESCTILDE ,[V]CST_TILDE)
 When "IDENT2BLB"    : this.IDENT2BLB=ctrans(this.IDENT2 ,[V]CST_ESCTILDE ,[V]CST_TILDE)
Endcase
Return

