#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Désactivation du flag "Mise au point" dans la règle workflow APRINT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update debuging field in APRINT rule") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub INIFLD
End

#-------------------#
$INIFLD

Local Integer UPD

Local File =DOSSIER+".AWRKPAR"   [AWA] 

# Mise à jour de la table AWRKPAR
Call ECR_TRACE(mess(81,125,1)-"APRINT:"-time$,0) From GESECRAN
Trbegin [AWA]
 Read [AWA]AWA0="APRINT"
 If !fstat
  UPD = 0 
  If [F:AWA]DEBUG=2
   [F:AWA]DEBUG = 1
   UPD = 1
  Endif
  If instr(1,[F:AWA]TEXTE,'string$(PCEJOI(2)<>""')
   [F:AWA]TEXTE = '|mess(167,154,1)-func GOBJTXT.SETFIC(PCEJOI(1))|'+chr$(10)
   [F:AWA]TEXTE += '|string$(PCEJOI(2)<>"",mess(168,154,1)-func GOBJTXT.SETFIC(PCEJOI(2)))|'+chr$(10)+chr$(10)
   [F:AWA]TEXTE += '|mess(169,154,1)|'
   UPD = 1
  Endif
  If UPD
   Rewrite [AWA]
   If fstat
    Call ERREUR("AWRKPAR"-[F:AWA]CODE,2) From DOSDIC
   Endif
  Endif 
 Endif
Commit

Close Local File [AWA]

Return
