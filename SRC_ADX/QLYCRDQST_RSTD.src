#<AdxTL>@(#)2.0.0.0 $Revision$
# Classe QLYCRDQST
# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_BEFORE" : Gosub AREAD_BEFORE
      When "AREAD_AFTER"  : Gosub AREAD_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Case CURPRO
  #Endcase
Return


#$ACTION
#Case CURPRO
#    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
#    When Default    : Gosub PROPERTIES : # Otherwise it is an event called on properties
#Endcase
#Return
#
################
## METHODS
################
#$METHODS
#Case CURPTH
#   When ""
#     # Current classe : QLYCRDQST
#     Case ACTION
#      When "AREAD_BEFORE" : Gosub AREAD_BEFORE
#      When "AREAD_AFTER"  : Gosub AREAD_AFTER
#     Endcase
#Endcase
#Return



$AREAD_AFTER
  Case CURPRO
     When "QLQ.DEMASWTYP"       : Gosub DEMASWTYP
  Endcase
Return
$AREAD_BEFORE
  Case CURPRO
  Endcase
Return


$DEMASWTYP
  If this.DEMASWTYP = 2
     OK = fmet this.ASETATTRIBUTE('ALPSTRVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('ALPENDVAL', '$isHidden', 'true')
  Endif
  If this.DEMASWTYP = 1
     OK = fmet this.ASETATTRIBUTE('NUMSTRVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
     OK = fmet this.ASETATTRIBUTE('NUMENDVAL', '$isHidden', 'true')
  Endif

Return

