#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
#                            UPDVEPLOCK
#              Vérrou / Déverrouillage des bulletins
#
#   MABOS - 08/10/2013
####################################################################################

Local Char     PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = ""        : #
#
### GPROG    = Traitement
### GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
### GWINDOW  = Ecran de saisie
### GWINCRIT = Ecran de critères
### Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,GPROGSPE)
#
Call TRAITE_CHAR(VALEUR,PARAM,"UPDVEPLOCK","UPDVEPLOCK","GENUPDVEPLOC",4,"") From GTRAITE
End

#########################################
## Traitement des actions : UPDVEPLOCK
#########################################
$ACTION
#Infbox(ACTION)
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "BOUTON"      : Gosub BOUTON
    When "OK"          : Gosub OK
    When "END"         : FIN = 1
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXECFIN
Endcase
Return

$INIT
  Local Mask   GENUPDVEPLOC [DIA]
  Raz [M:DIA]

  Gosub OUVFIC

  [M:DIA]FLGLOCK=len(mess(0,10872,1))
  [M:DIA]ALLSTA=2
  [M:DIA]ALLGEN =2
  [M:DIA]ALLSYN =2
  [M:DIA]ALLVRA=2
  [M:DIA]ALLANA =2

  Call INI_LEG From DIVPAYE
  Call LECMEMO("STD","[M:DIA]","loc") From GMEMO

Return

$OUVRE

Return

$DEBUT
  If BOITE="UPDVEPLOCK"
    Gosub CHARGE_CRIT
    Gosub CHARGE_MSK
  Else
    Affzo [M:DIA]: Setmok [M:DIA] With 0
    Call AFF_MEMO2(1)  From DIVPAYE
    Call D_INI([M:DIA]INI)
  Endif
Return

$OK
  If BOITE="GENUPDVEPLOC"
    BOX = 0 : # To keep [M:DIA] open
  Elsif BOITE="UPDVEPLOCK"
    Gosub EXEC
  Endif
Return

$CONTROLE
  If GSTATUT<>GSTAOK
    # To exit If End button is activated on criteria window
    FIN = 1
  Endif
Return


#  - On retourne en saisie en fin de traitement
$EXECFIN
  If BOITE="UPDVEPLOCK"
     SAI=1
  Endif
Return
######################################################
## Ouverture des tables
######################################################
$OUVFIC

  If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
  If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
  If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
  If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE     [ATX] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
  If clalev([F:DIC])=0 : Local File DICOEMP    [DIC] : Endif
  If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
  If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
  If clalev([F:SMH])=0 : Local File SCREMPH    [SMH] : Endif
  If clalev([F:SMD])=0 : Local File SCREMPD    [SMD] : Endif
  If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
  If clalev([F:VEP])=0  : Local File VALEMP    [VEP] : Endif
  If clalev([F:VEP2])=0 : Local File VALEMP    [VEP2] : Endif
  If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif


  Gosub OUVRE From WPDEFTABLE
Return

#########################################################################################################################
$CHARGE_CRIT
Local Char CRITERE_CPY(GDIMFIC), CRITERE_FCY(GDIMFIC), CRITERE_SRV(GDIMFIC), CRITERE_PRF(GDIMFIC)
Local Char CRITERE_DEB(GDIMFIC), CRITERE_FIN(GDIMFIC), CRITERE_LIBRE(GDIMFIC), CRITERE_POP(GDIMFIC)
Local Char CRITERE_LOCK(GDIMFIC), CRITERE_STA(GDIMFIC)
Local Char CRITERE_GEN(GDIMFIC), CRITERE_SYN(GDIMFIC), CRITERE_VRA(GDIMFIC), CRITERE_ANA(GDIMFIC)
Local Char CRITERE_LEG(GDIMFIC)
Local Char LIS_CPY(GLONCPY)(0..100)
Local Integer I, K

  [L]CRITERE_CPY = "1=1"  : If [M:DIA]CPY<>""    Then  [L]CRITERE_CPY += "& [F:FCY]LEGCPY='"+[M:DIA]CPY+"'"     : Endif
  [L]CRITERE_FCY = "1=1"  : If [M:DIA]FCY<>""    Then [L]CRITERE_FCY += "& [F:HRCTR]ETRFCY='"+[M:DIA]FCY+"'"     : Endif
  [L]CRITERE_SRV = "1=1"  : If [M:DIA]SRV<>""    Then [L]CRITERE_SRV += "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"     : Endif
  [L]CRITERE_PRF = "1=1"  : If [M:DIA]PRF<>""    Then [L]CRITERE_PRF += "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"     : Endif
  [L]CRITERE_DEB = "1=1"  : If [M:DIA]MATDEB<>"" Then [L]CRITERE_DEB += "& [F:HRCTR]REFNUM>='"+[M:DIA]MATDEB+"'" : Endif
  [L]CRITERE_FIN = "1=1"  : If [M:DIA]MATFIN<>"" Then [L]CRITERE_FIN += "& [F:HRCTR]REFNUM<='"+[M:DIA]MATFIN+"'" : Endif
  [L]CRITERE_POP = "1=1"  : If [M:DIA]POP<>""    Then [L]CRITERE_POP += "& [F:HRPOA]REFNUM<>'' & [F:HRPOA]CTRNUM<>''" : Endif
  [L]CRITERE_LOCK = "1=1"  : If [M:DIA]FLGLOCK<>len(mess(0,10872,1)) Then [L]CRITERE_LOCK += "& [F:VEP]FLGLOCK"+func VALCRIT([M:DIA]FLGLOCK)  : Endif
  [L]CRITERE_STA = "1=1"   : If [M:DIA]ALLSTA<>2  Then [L]CRITERE_STA += "& [F:VEP]STA="+num$([M:DIA]STA)  : Endif
  [L]CRITERE_GEN = "1=1"   : If [M:DIA]ALLGEN<>2  Then [L]CRITERE_GEN += "& [F:VEP]FLGGEN"+func VALCRIT([M:DIA]FLGGEN) : Endif
  [L]CRITERE_SYN = "1=1"   : If [M:DIA]ALLSYN<>2  Then [L]CRITERE_SYN += "& [F:VEP]FLGSYN"+func VALCRIT([M:DIA]FLGSYN) : Endif
  [L]CRITERE_VRA = "1=1"   : If [M:DIA]ALLVRA<>2  Then [L]CRITERE_VRA += "& [F:VEP]FLGVRA"+func VALCRIT([M:DIA]FLGVRA) : Endif
  [L]CRITERE_ANA = "1=1"   : If [M:DIA]ALLANA<>2  Then [L]CRITERE_ANA += "& [F:VEP]FLGANA"+func VALCRIT([M:DIA]FLGANA) : Endif

 If [M:DIA]CRITERE<>"" Then
    [L]CRITERE_LIBRE = [M:DIA]CRITERE
  Else
    [L]CRITERE_LIBRE = "1=1"
  Endif

  [L]CRITERE_LEG= "1=1"
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
    [L]CRITERE_LEG += "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)"
  Endif

Return

#########################################################################################################################
$CHARGE_MSK
  Local Integer   L_OK, IJ

  If [L]CRITERE_POP<>"1=1" Then
   Link [HRCTR] With  [F:ID]ID0   = [F:HRCTR]REFNUM
&                 , [FCY]FCY0   = [F:HRCTR]ETRFCY
&                 , [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&              As [LCTR]
&              Where evalue([L]CRITERE_POP) & evalue([L]CRITERE_LEG)
&                    & evalue([L]CRITERE_CPY) & evalue([L]CRITERE_FCY)
&                    & evalue([L]CRITERE_SRV) & evalue([L]CRITERE_PRF)
&                    & evalue([L]CRITERE_DEB) & evalue([L]CRITERE_FIN)
&                    & [F:ID]ENAFLG=2
  Else
   Link [HRCTR] With  [F:ID]ID0   = [F:HRCTR]REFNUM
&                 , [FCY]FCY0   = [F:HRCTR]ETRFCY
&              As [LCTR]
&              Where evalue([L]CRITERE_LEG)
&                    & evalue([L]CRITERE_CPY) & evalue([L]CRITERE_FCY)
&                    & evalue([L]CRITERE_SRV) & evalue([L]CRITERE_PRF)
&                    & evalue([L]CRITERE_DEB) & evalue([L]CRITERE_FIN)
&                    & [F:ID]ENAFLG=2

  Endif



  Raz [M:UPVL]

  If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> "" : GCURLEG=[M:DIA]LEG : Endif

  GERR   = 0
  nolign = 0

   For [LCTR]CTR0
    [L]L_OK = 1
    Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[L]CRITERE_LIBRE,[L]L_OK,1) From DIVPAYE
    If  [L]L_OK
      Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
      Read [VEP]VEP0 Last
      Filter [VEP]
      If fstat<2
        If !(evalue([L]CRITERE_LOCK) & evalue([L]CRITERE_STA))
          [L]L_OK = 0
        Endif
        Gosub IS_VEP_MODIFIABLE
        If [L]L_OK & !(evalue([L]CRITERE_GEN) & evalue([L]CRITERE_SYN) & evalue([L]CRITERE_VRA) & evalue([L]CRITERE_ANA))
          [L]L_OK = 0
        Endif
        If [L]L_OK
          nolign += 1
          [M:UPVL] = [F:ID]
          [M:UPVL]DES(nolign-1) = [F:ID]NAM-[F:ID]SRN
          [M:UPVL] = [F:HRCTR]
          [M:UPVL] = [F:VEP]
          If [F:VEP]LOCKUSR <> ""
            Read [F:AUS]CODUSR=[F:VEP]LOCKUSR
            Call LECTEXTRA([M:UPVL]LOCKNAM(nolign-1),"AUTILIS","INTUSR",[F:VEP]LOCKUSR,"") From ATEXTRA
            [M:UPVL]LOCKNAM(nolign-1) -= "("+[F:VEP]LOCKUSR +")"
          Else
            [M:UPVL]LOCKNAM(nolign-1) = ""
          Endif
          [M:UPVL]OLDLOCK(nolign-1) = [F:VEP]FLGLOCK
        Endif : # If [L]L_OK
        If nolign > dim([M:UPVL]FLGLOCK)-1
          # Tableau plein
          Call ERREUR(func AFNC.MES1(mess(131,10720,1),num$(dim([M:UPVL]FLGLOCK)))) From GESECRAN
          #'Le nombre de lignes du tableau dépasse la limite autorisée ($1$). Veuillez modifier vos critères de sélection  # Tableau plein
          Break
        Endif
      Endif
    Endif
  Next : # [LCTR]CTR0
  If GERR : Return : Endif
  Onerrgo
  [M:UPVL]NBLIG = nolign
  Affzo [M:UPVL]
Return

######################################################
$ERREUR
Resume

######################################################
## It begins here...
######################################################
$EXEC
  TIT = mess(223,10703,1) : # Verrouillage/déverrouillage des bulletins
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  For [L]IJ=0 To [M:UPVL]NBLIG-1
    If  [M:UPVL]FLGLOCK([L]IJ)<>[M:UPVL]OLDLOCK([L]IJ)
      Gosub TR1
      If GOK<1 : Break : Endif
    Endif
  Next [L]IJ

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

##############
$TR1
  GOK = 1
  Call DEBTRANS From GLOCK
  Trbegin [F:HRCTR], [F:VEP]
  # Maj contrat
  Read [F:VEP]VEP0=[M:UPVL]REFNUM([L]IJ);[M:UPVL]PYRDAT([L]IJ);[M:UPVL]BUL([L]IJ)
# VEP0=EMP+PYRDAT+BUL

  If !fstat Then
    [F:VEP]FLGLOCK = [M:UPVL]FLGLOCK([L]IJ)
    [F:VEP]LOCKUSR=GUSER
    [F:VEP]LOCKDAT=date$
    Rewrite [VEP]
    If fstat
      GOK = 0 : Call FSTA("VEP") From GLOCK
    Else
      Local Char WMESS(250)
      If  [F:VEP]FLGLOCK =2 Then [L]WMESS=mess(221,10703,1) Else  [L]WMESS=mess(222,10703,1) :Endif
      #'Bulletin verrouillé' / 'Bulletin déverrouillé'
      [L]WMESS+=":"-[F:VEP]BUL-"du"-format$("D:"+GFMDAT,[F:VEP]PYRDAT)  :# No bulletin + date bulletin
      [L]WMESS+=";"-mess(5,10506,1)-[M:UPVL]REFNUM([L]IJ)-[M:UPVL]DES([L]IJ) :# Salarié
      [L]WMESS+=";"-mess(6,10506,1)-[M:UPVL]CTRNUM([L]IJ)-format$("D:"+GFMDAT,[M:UPVL]CTRDAT([L]IJ))# Contrat
      Call ECR_TRACE("   "-[L]WMESS,0) From GESECRAN :

    Endif
  Endif

  If GOK=-1 : Goto ROLL_TR1
  Elsif GOK<1 : Goto AB_TR1
  Endif
  Commit
Return

$AB_TR1

  Rollback
Return

$ROLL_TR1

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
Return

$BOUTON
  Case BOITE
   When "GENUPDVEPLOC"
    Case BOUT
      When "R"
      # Button "Rappel MEMO"
        Call AFF_MEMO2(1) From DIVPAYE
    Endcase

   When "UPDVEPLOCK"
    Case BOUT
      When "C" : For I=0 To [M:UPVL]NBLIG-1 : [M:UPVL]FLGLOCK(I)=2 : Next : Affzo [M:UPVL]
      When "D" : For I=0 To [M:UPVL]NBLIG-1 : [M:UPVL]FLGLOCK(I)=1 : Next : Affzo [M:UPVL]
    Endcase

  Endcase

Return

Funprog VALCRIT(VALEUR)
Value Integer VALEUR
Local Char CRIT(10)
If [L]VALEUR < 2 Then
 [L]CRIT="<2"
Else
 [L]CRIT="=2"
Endif
End [L]CRIT

$IS_VEP_MODIFIABLE

  If [L]L_OK & ([F:VEP]PST>1 or [F:VEP]RVS=2)
    # pas comptabilisée ni extourne
    [L]L_OK = 0
  Endif
  If [L]L_OK
    #Lecture du bul#Lecture du bulletin suivant (même chrono contrat, autre période activité )letin suivant (même chrono contrat, autre période activité )
    #MAPAD - 2018-08-20 - X3-105326 - START
    # Filter [VEP2] Where EMP=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & BUL>[F:VEP]BUL
    Local Date LSTDATE,ENDDAT
    Local Date LSTPRYDAT

    ENDDAT= [F:VEP]ENDDAT
    LSTPRYDAT = ENDDAT  #EQUEL TO CURRENT PRYDAT
    LSTPRYDAT = LSTPRYDAT + 1

    Filter [VEP2] Where EMP=[F:VEP]EMP & ENDDAT >= LSTPRYDAT & CTRNUM=[F:VEP]CTRNUM
    Read [VEP2]VEP0 First
    #MAPAD - 2018-08-20 - X3-105326 - END
    Filter [VEP2]
    If fstat<=2 & [F:VEP2]STA>1
     [L]L_OK = 0
    Endif
  Endif
Return

#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
#   SCREEN GENUPDVEPLOC
#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-08-05 - X3PEOP-950 - START
Gosub GRISE From DIVPAYE
#JOJAC - 2016-08-05 - X3PEOP-950 - END
  If dim([M]ALLSTA)>0
   If [M]ALLSTA=2 : Diszo [M]STA : Else : Actzo [M]STA : Endif
  Endif
  If dim([M]ALLGEN)>0
   If [M]ALLGEN=2 : Diszo [M]FLGGEN : Else : Actzo [M]FLGGEN : Endif
  Endif
  If dim([M]ALLSYN)>0
   If [M]ALLSYN=2 : Diszo [M]FLGSYN : Else : Actzo [M]FLGSYN : Endif
  Endif
  If dim([M]ALLVRA)>0
   If [M]ALLVRA=2 : Diszo [M]FLGVRA : Else : Actzo [M]FLGVRA : Endif
  Endif
  If dim([M]ALLANA)>0
   If [M]ALLANA=2 : Diszo [M]FLGANA : Else : Actzo [M]FLGANA : Endif
  Endif

End

Subprog C_ALLSTA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Effzo [M]STA : Diszo [M]STA
  Else
   Actzo [M]STA
  Endif
End

Subprog C_ALLGEN(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Effzo [M]FLGGEN : Diszo [M]FLGGEN
  Else
   Actzo [M]FLGGEN
  Endif
End

Subprog C_ALLSYN(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Effzo [M]FLGSYN : Diszo [M]FLGSYN
  Else
   Actzo [M]FLGSYN
  Endif
End

Subprog C_ALLVRA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Effzo [M]FLGVRA : Diszo [M]FLGVRA
  Else
   Actzo [M]FLGVRA
  Endif
End

Subprog C_ALLANA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Effzo [M]FLGANA : Diszo [M]FLGANA
  Else
   Actzo [M]FLGANA
  Endif
End

#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
#   END SCREEN GENUPDVEPLOC
#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #

#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
#   SCREEN UPDVEPLOCK
#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #

Subprog B1_NBLIG
Local Integer VALEUR
Local Integer I , NOL
[L]NOL = nolign-1
[L]VALEUR =[M:UPVL]FLGLOCK(NOL)
For [L]I=[L]NOL+1 To [M]NBLIG-1
  If [M:UPVL]FLGLOCK(I) <> [L]VALEUR
   [M:UPVL]FLGLOCK(I) = [L]VALEUR
  Endif
Next
Affzo [M:UPVL]
End



#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
#   END SCREEN UPDVEPLOCK
#- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #

