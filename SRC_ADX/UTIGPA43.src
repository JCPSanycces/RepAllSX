#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA43: Lien POF <=> WOF rÃĐajustÃĐ                   Module GPAO      #
##########################################################################
# GA 28/11/13                                           Bug 94870        #
##########################################################################


Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Local Integer WOUV_TRACE
    If GTRACE = ""
        Call OUVRE_TRACE("UTIGPA43 : Process link between subcontracted WO operation and PO") From LECFIC
        WOUV_TRACE=1
    Endif
    Call MAJ_UTIGPA43(DOSSIER)
    Call TEMPOFF     From GESECRAN
    If WOUV_TRACE=1
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE   From LECFIC
    Endif
  Endif
End



Subprog MAJ_UTIGPA43(LDOS)
Value Char LDOS

If LDOS<>nomap
    Local Mask =LDOS+".SBCK"       [SBCK]
    Local Mask =LDOS+".JALK"       [JALK]
    Local Mask =LDOS+".OPSK"       [OPSK]

    Local File =LDOS+".FACILITY"   [FCY]
    Local File =LDOS+".ITMMASTER"  [ITM]
    Local File =LDOS+".ITMFACILIT" [ITF]
    Local File =LDOS+".PORDERQ"    [POQ]
    Local File =LDOS+".PORDER"     [POH]

    Local File =LDOS+".MFGHEAD"    [MFG]
    Local File =LDOS+".MFGITM"     [MFI]
    Local File =LDOS+".MFGOPE"     [MFO]
    Local File =LDOS+".MFGMAT"     [MFM]
    Local File =LDOS+".ORDERS"     [ORD]
    Local File =LDOS+".OPERATIONS" [OPS]
    Local File =LDOS+".CPTANALIN"  [CAL]
    Local File =LDOS+".MFGTRS"     [MTS]
    Local File =LDOS+".SCHEDULING" [SCH]
    Local File =LDOS+".PARJAL"     [PJA]
    Local File =LDOS+".WORKSTATIO" [MWS]
Else
    Local Mask SBCK       [SBCK]
    Local Mask JALK       [JALK]
    Local Mask OPSK       [OPSK]

    Local File FACILITY   [FCY]
    Local File ITMMASTER  [ITM]
    Local File ITMFACILIT [ITF]
    Local File PORDERQ    [POQ]
    Local File PORDER     [POH]

    Local File MFGHEAD    [MFG]
    Local File MFGITM     [MFI]
    Local File MFGOPE     [MFO]
    Local File MFGMAT     [MFM]
    Local File ORDERS     [ORD]
    Local File OPERATIONS [OPS]
    Local File CPTANALIN  [CAL]
    Local File MFGTRS     [MTS]
    Local File SCHEDULING [SCH]
    Local File PARJAL     [PJA]
    Local File WORKSTATIO [MWS]
Endif

#
Local Date WRCPDAT,WORDDAT
Local Char WFCY(GLONFCY)
Local Integer WMFO,WPOQ,ISPL,INUM
Raz WMFO,WPOQ,ISPL,INUM

Local Integer WSIMFLG : WSIMFLG=2
Call OUINON(mess(6,115,1),WSIMFLG) From GESECRAN

Call ECR_TRACE("Start trace : MFGOPE" ,0) From GESECRAN

Trbegin [MFO]


# SÃĐlection des encours POF liÃĐs Ã  SCF
Filter [ORD] Where WIPTYP=2 & VCRTYP=14 & VCRTYPORI=10 Order By STOFCY
For [F:ORD]

     Call ECR_TRACE("\-------------- Order:"
&                  -"PO="-[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)
&                  -"OF="-[F:ORD]VCRNUMORI-num$([F:ORD]VCRLINORI)-num$([F:ORD]VCRSEQORI),-1) From GESECRAN

    Read [POH]POH0=[F:ORD]VCRNUM
    If fstat : Raz [F:POH] : Endif

    If [F:POH]POHFCY<>WFCY
       Gosub CHARG_PARAM
       WFCY=[F:POH]POHFCY
    Endif

    Read [POQ]POQ0(2)=[F:ORD]VCRNUM;[F:ORD]VCRLIN
    If fstat : Raz [F:POQ] : Goto NEXT_ORD : Endif

    Read [F:MFG]MFG0=[F:ORD]VCRNUMORI
    If !fstat & [F:MFG]MFGSTA=1 & [F:MFG]MFGTRKFLG<5
       Gosub TRT_MFO
    Else
       Call ECR_TRACE("=> WOF not found or already closed"-[F:ORD]VCRNUMORI,-1) From GESECRAN
       Goto NEXT_ORD
    Endif

$NEXT_ORD
Next
Filter [ORD]

If WSIMFLG=2
   Rollback
   Call ECR_TRACE("-MFO-"-mess(104,141,1)-" : "-num$(WMFO)-"Rollbacked",0) From GESECRAN
   Call ECR_TRACE("-POQ-"-mess(104,141,1)-" : "-num$(WPOQ)-"Rollbacked",0) From GESECRAN
Else
   Commit
   Call ECR_TRACE("-MFO-"-mess(104,141,1)-" : "-num$(WMFO)-"Commited",0) From GESECRAN
   Call ECR_TRACE("-POQ-"-mess(104,141,1)-" : "-num$(WPOQ)-"Commited",0) From GESECRAN
Endif


End

$TRT_MFO
# relire MFO, et voir si maj necessaire dates selon SBCLIB,
# pour les opÃĐrations de sous-traitance commandÃĐes
#
WORDDAT    = [F:POQ]EXTRCPDAT-[F:POQ]OFS
WRCPDAT    = [F:POQ]EXTRCPDAT
Read [F:MFO]MFO1(2)=[F:POQ]POHNUM;[F:POQ]POPLIN
If !fstat
   If [F:MFO]OPEEND <> WRCPDAT & WRCPDAT>=date$
     Call ECR_TRACE("Subcontracted Operation 1a:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                  -"will be modified to"-num$(WORDDAT)-num$(WRCPDAT),0) From GESECRAN
     Gosub MAJ_SBC
   Elsif [F:MFO]OPEEND <> WRCPDAT
     Call ECR_TRACE("Subcontracted Operation 1b:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                  -"will be NOT modified to"-num$(WORDDAT)-num$(WRCPDAT),-1) From GESECRAN
   Else
     Call ECR_TRACE("Subcontracted Operation 1c:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                  -"are ok"-num$(WORDDAT)-num$(WRCPDAT),-1) From GESECRAN
   Endif
Elsif [F:ORD]VCRTYPORI=10
# Issue XYZ GA 11/2013
   Raz [F:MFO]
   Filter [MFO] Where MFGNUM=[F:ORD]VCRNUMORI & (OPENUM=[F:ORD]VCRLINORI | [F:ORD]VCRLINORI=0) & SCOITMREF<>""
   For [MFO]
       If [F:MFO]SCOITMREF=[F:ORD]ITMREF & [F:MFO]EXTSTRQTY=[F:ORD]EXTQTY Break Endif
   Next
   Filter [MFO]
   If [F:MFO]MFGNUM=[F:ORD]VCRNUMORI # MFO Found ?
     If WRCPDAT>=date$
       Call ECR_TRACE("Subcontracted Operation 2a:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                    -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                    -"will be modified to"-num$(WORDDAT)-num$(WRCPDAT),0) From GESECRAN
       Gosub MAJ_SBC
     Else
       Call ECR_TRACE("Subcontracted Operation 2b:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                    -"Dates="-num$([F:MFO]OPESTR)-num$([F:MFO]OPEEND)
&                    -"will be NOT modified to"-num$(WORDDAT)-num$(WRCPDAT),-1) From GESECRAN
     Endif
   Endif
Endif
If [F:MFO]MFGNUM=[F:ORD]VCRNUMORI
    # Maj de POQ ?
    If [F:POQ]VCRNUMORI<>[F:MFO]MFGNUM & [F:POQ]VCRNUMORI=""
     Call ECR_TRACE("Subcontract Operation order POQ:"
&                  -"PO="-[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)
&                  -"OF="-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI)-num$([F:POQ]VCRSEQORI)
&                  -"will be linked to OF"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM),0) From GESECRAN
       [F:POQ]VCRNUMORI=[F:MFO]MFGNUM
       [F:POQ]VCRLINORI=[F:MFO]OPENUM
       [F:POQ]VCRSEQORI=[F:MFO]OPESPLNUM
       WPOQ+=1
       Rewrite [F:POQ]
    Elsif [F:POQ]VCRNUMORI=[F:MFO]MFGNUM & [F:POQ]VCRLINORI=[F:MFO]OPENUM & [F:POQ]VCRSEQORI<>[F:MFO]OPESPLNUM
     Call ECR_TRACE("Subcontract Operation order POQ:"-[F:MFO]MFGNUM-num$(-[F:MFO]OPENUM)-num$(-[F:MFO]OPESPLNUM)
&                  -"OF="-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI)-num$([F:POQ]VCRSEQORI)
&                  -"will be modified to operation step"-num$([F:MFO]OPESPLNUM),0) From GESECRAN
       [F:POQ]VCRSEQORI=[F:MFO]OPESPLNUM
       WPOQ+=1
       Rewrite [F:POQ]
    Endif
    # Maj de MFO ?
    If [F:POQ]POHNUM<>[F:MFO]POHNUM & [F:MFO]POHNUM=""
     Call ECR_TRACE("Subcontract Operation order MFO:"
&                  -"PO="-[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)
&                  -"OF="-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI)-num$([F:POQ]VCRSEQORI)
&                  -"will be linked to OF"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM),0) From GESECRAN
       [F:MFO]POHNUM = [F:POQ]POHNUM
       [F:MFO]POPLIN = [F:POQ]POPLIN
       WMFO+=1
       Rewrite [F:MFO]
    Endif
Endif
Return

$MAJ_SBC
Local Integer STAT
#-----
# Extrait de SUPBPOHA: maj de l'opÃĐ de sous-traitance selon maj de la commande d'achat
#-----
   Raz [M:SBCK]
  [M:SBCK]MAJCOD    = "M"
  [M:SBCK]VCRNUM    = [F:POQ]POHNUM
  [M:SBCK]VCRLIN    = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ    = [F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
  [M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
  [M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
  [M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI
  [M:SBCK]BPSNUM    = [F:POQ]BPSNUM
  [M:SBCK]BPAADD    = [F:POQ]SCOADD
  If [F:POQ]LINCLEFLG<>2
     [M:SBCK]ORDQTY=[F:POQ]QTYSTU
  Elsif [F:POQ]RCPQTYSTU<>0
     [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU : # ligne cde soldÃĐe donc qtÃĐ commandÃĐe = qtÃĐ rÃĐceptionnÃĐe
  Else
     [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD="A"
  Endif
  [M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,STAT) From TRTDEV
  [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  [M:SBCK]OFS    = [F:POQ]OFS
  [M:SBCK]MSGFLG = 1
  [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    If [M:SBCK]VCRTYPORI=10
      GMESSAGE=mess(96,193,1)
    Elsif [M:SBCK]VCRTYPORI=36
      GMESSAGE=mess(913,196,1)
    Endif
    GERR=1 : GOK=0 : Return
  Endif
Return

$CHARG_PARAM
If GFCY<>[F:POH]POHFCY GFCY=[F:POH]POHFCY : Raz GMESSAGE : Endif
GCUR=[F:POH]CUR
Call GET_SOC(GFCY) From GLOFCYCPY
Call GET_DEV(GFCY) From GLOFCYCPY
Call GLOBVAR(GFCY) From WWGLOBACH

Return

########################################################################
# Pour exÃĐcution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  ##### A lancer ssi nÃĐcessaire
  ##### Call MAJ_UTIGPA43(APPLI)
End

#######################################################################
# Pour exÃĐcution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  ##### A lancer ssi nÃĐcessaire
  ##### Call MAJ_UTIGPA43(APPLI)
End
