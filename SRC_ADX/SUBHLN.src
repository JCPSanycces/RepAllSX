#<AdxTL>@(#)6.0.0.0 $Revision$
# LS 29/12/98
# Lignes d'honoraires

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FHONLIN","SUBHLN","DHONLIN",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub DEVERROU

 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF 
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "ENR"         : Gosub VALID
 When "ABA"         : Gosub DEBUT
 When "OK"          : FIN = 0
 When "SORTIE"      : Gosub SORTIE

 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return

$INIT
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HLN])=0 : Local File HONLIN     [HLN] : Endif
Return 

$INIT_DIA
Raz [M:DIA]
[M:DIA]ALLFCY    = 2
[M:DIA]ALLHON    = 2
If VALEUR=""
 [M:DIA]ALLPRVNUM = 2
Else
 [M:DIA]ALLPRVNUM = 1
 [M:DIA]PRVNUM    = VALEUR
Endif
Return

$CONTROLE
Lock ="HONLIN"+"\"+[M:DIA]CPY : # Nom entier du fichier car typges=2
If fstat=1
 GERR = 1 : GMESSAGE = mess(10,100,1) : # Modif en cours sur autre poste
 SAI = 1
Endif
Return

$SORTIE
Return

$DEVERROU
Unlock ="HONLIN"+"\"+[M:DIA]CPY
Return

$OUVRE
Local Integer MODIF, NOLIN, LG, STAT, ISOC
Local Char    CRITTAB(250)
Local Integer MAXLIGHLN
Return

$DEBUT
Raz [M:HLN1]
MAXLIGHLN = dim([M]PRVNUM)
[M:HLN1]CPY = [M:DIA]CPY
ISOC = find([M:DIA]CPY,GSOC(1..GNBSOC))
If ISOC 
 [M]CUR2 = GDEVSOC(ISOC)
Endif
STADEF = 0
CRITTAB = 'CPY = "'+[M:DIA]CPY+'"'
If [M:DIA]ALLFCY<>2
 CRITTAB -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITTAB -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
If [M:DIA]ALLHON<>2
 CRITTAB -= '& HON = '+num$([M:DIA]HON)
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITTAB -= '& DAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITTAB -= '& DAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
nolign = 0
For [HLN]HLN0 Where evalue(CRITTAB)
 nolign += 1
 [M] = [F:HLN]
 If [M]ACCNUM(nolign-1)<>0
  Read [DAE]DAE2=[M]ACCNUM(nolign-1)
  If !fstat
   [M]TYP(nolign-1) = [F:DAE]TYP
   [M]NUM(nolign-1) = [F:DAE]NUM
  Endif
 Endif
# Bug 9953 : CP (30/07/01)
# Call CONVERT([M]CUR(nolign-1),[M]CUR2,[M]CUR2,0,[M]DAT(nolign-1),[M]AMTCUR(nolign-1),
#&             [M]AMTLOC(nolign-1),STAT) From TRTDEV
# If STAT : [M]AMTLOC(nolign-1) = 0 : Endif
 If nolign>=MAXLIGHLN
  # Tableau plein 
  Call MESSAGE(mess(26,100,1)) From GESECRAN 
  Break
 Endif 
Next
[M]NBLIG = nolign
[M]TOTAMTLOC = sum([M]AMTLOC(0..[M]NBLIG-1))
MODIF = 0
Affzo
Return

$SETBOUT
Raz ETABOU, REP
If MODIF
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Endif
ETABOU(GBFIN) = 1
Return

$APRES_MODIF
MODIF = 1
Return

$AP_CHOIX
Case REPONSE
 When GSTARET          : Gosub VALID
 When GSTAEND, GSTAESC : Gosub CONFIRME
 When Default
Endcase
Return

$CONFIRME
If MODIF 
 REP = "M"
Endif
Return

$VALID
If MODIF & [M:HLN1]NBLIG>0
 Sorta [M:HLN1]NBLIG [M:HLN1]NBLIG Order By [M:HLN1]FCY(indice),[M:HLN1]PRVNUM(indice),
&     [M:HLN1]DAT(indice),[M:HLN1]HON(indice),[M:HLN1]NUM(indice),[M:HLN1]LIN(indice)
 Affzo [M] : # Car après Enregistrer on revient en saisie
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
MODIF = 0
Return

$TR1
GOK = 1
Trbegin [HLN]
 Delete [HLN] Where evalue(CRITTAB)
 If fstat=1
  GOK = -1 : GLOCK = "$HONLIN" : Goto ROLL_TR1
 Endif
 For nolign=1 To [M:HLN1]NBLIG
  Raz [F:HLN]
  [F:HLN] = [M:HLN1]
  LG = nolign-1
  If LG=0
   NOLIN = 1 
  Elsif [M]FCY(LG)<>[M]FCY(LG-1) | [M]DAT(LG)<>[M]DAT(LG-1) | [M]HON(LG)<>[M]HON(LG-1) |
&       [M]PRVNUM(LG)<>[M]PRVNUM(LG-1)
   NOLIN = 1
  Else
   NOLIN +=1
  Endif
  [F:HLN]LINNUM = NOLIN
  Write [HLN]
  If fstat
   GOK = 0 : Call FSTA("HLN") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


$TRT_DIV
# Bug 5570 : ajout de zoom (CP : 13/07/01)
Case TRAIT
 When "CONSFACT" : Gosub B1_NBLIG From SUBHLN1
 When "CONSREGL" : Gosub B2_NBLIG From SUBHLN1
Endcase
Return


