#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : unites
#                             cf AML 2240 : 32
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables TUNWPIV devient WK
######################################################################
$OUVTAB_TUN
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:TUN]) Local File TABUNIT [TUN] Endif
Return

######################################################################
Subprog TRT_TUN(ID,CLETRT,PITTUN,P_CRITERE,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITTUN () 
Value Char P_CRITERE() 
Variable Integer OK

If PITTUN ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_TUN
Gosub OUVREPIVOT From CONNECTFCT


Local Integer WNBTUN  : Raz WNBTUN 
Local Integer WPRETUN : Raz WPRETUN
Local Char    OPTTUN(GDIMFIC)
OPTTUN = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pittun")
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES 
Local Integer WKHEATYP       : Raz WKHEATYP 
Local Char    WKHEADMES (250): Raz WKHEADMES 

Call READPIT(PITTUN,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Call LOADPIVZON(PITTUN,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(PITTUN,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRETUN,OPTTUN) From CONNECTFCT

#######
For [TUN] Where evalue(P_CRITERE)
    Gosub WR_TUN
Next
#######

Call WRPIVOT_END(PITTUN ,WNBTUN ,WKNORECMES ,WPRETUN ,OPTTUN) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_TUN
    ################################
    # fichiers TUN
    ################################
    #     Ouverture du fichier OPTTUN en écriture
    If WPRETUN = 0
      Openo OPTTUN,0 Using [FPIV]
      WPRETUN = 1
    Else
      Openo OPTTUN Using [FPIV]
    Endif
    
    WNBTUN += 1
    Call RAZVALPIVOT(PITTUN,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITTUN,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Return

######################################################################
######################################################################
#############################################################################
Funprog TUN_GETDES
Local Char LDES(GLONDES)
Raz LDES
If [F:TUN]UOM<>""
     Call LECTEXTRA(LDES,"TABUNIT","DES",[F:TUN]UOM,"") From ATEXTRA
Endif
End LDES
