#<AdxTL>@(#)0.0.0.0 $Revision$ PropriÃĐtÃĐs Oracle
Close Local Mask
Call ORAPROP(nomap)
End

########################################################################
Subprog ORAPROP(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ORAPROP","ORAPROP","") From GSAISIE
End

######################################################################################
# Gestion des masques ORAPROP
####################
$ACTION
#Infbox GACTION-"ACTION="+ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "RAF"          : Gosub RAF
 When "BOUTON"       : Gosub BOUTON
 When "FIN"          : Gosub FIN
 When "EDI"          : Gosub EDIT
 When Default
Endcase
Return

####################
$EDIT
Local Char WLIBEL(250) : Raz WLIBEL
Local Integer WNOLIBEL : Raz WNOLIBEL
Local Integer OUVREAFC,OUVREATX
If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
      WNOLIBEL= 0
      Read [F:AFCW]CODINT = "TRTPROP"
      If [S]fstat = 0
        WNOLIBEL = [F:AFCW]LIBMENU
        Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
        If [S]fstat = 0
           WLIBEL= [F:ATXW]TEXTE
        Endif
      Endif
      If WLIBEL="" : WLIBEL="TRTPROP" : Endif
If OUVREAFC : Close File [AFCW] :  Endif
If OUVREATX : Close File [ATXW] :  Endif

Local Char TABMSK(10)(4)
Local Char TABABR(5)(4)
#on les mets dans ce sens pour avoir les info regroupÃĐes
TABMSK(0)="ORAPROP0" : TABABR(0)="PRO0"
TABMSK(1)="ORAPROP3" : TABABR(1)="PRO3"
TABMSK(2)="ORAPROP1" : TABABR(2)="PRO1"
TABMSK(3)="ORAPROP2" : TABABR(3)="PRO2"
Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
Call IMPSCR From ATRTX3
Return


####################
$OUVRE
If GTYPDBA<>1
    FIN=1
    Return
Endif
If GTYPDBA<>1
    Call ERREUR(mess(108,115,1)) From GESECRAN : # La base de donnÃĐes n'est pas oracle
    FIN=1
    Return
Endif
Return

####################
$DEBUT
If GTYPDBA<>1
    Call ERREUR(mess(108,115,1)) From GESECRAN : # La base de donnÃĐes n'est pas oracle
    FIN=1
    Return
Endif

Raz [M:PRO0]
Raz [M:PRO1]
Raz [M:PRO2]
Call VERS_ORA([M:PRO0]BDDNAM,[M:PRO0]VER,[M:PRO0]VERDES,FIN)
If FIN : Return : Endif
Gosub ACTUALISER
Return

####################
$FIN
Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"A") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A"
CHBOU += "=" : # RaffraÃŪchir
CHBOU += "I" : # Impression

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
Call TEMPON("L") From GESECRAN
Call CHARGE_PRO1(FIN)
Call CHARGE_PRO3(FIN)
Call CHARGE_PRO2(FIN)
Affzo [M:PRO3]
Affzo [M:PRO2]
Affzo [M:PRO1]
Call TEMPOFF From GESECRAN
Return

###################################################################################################
###################################################################################################
Subprog VERS_ORA(BDDNAM,VER,VERDES,ERR)
Variable Char BDDNAM
Variable Char VER
Variable Char VERDES
Variable Integer ERR

Onerrgo ERR_SQL_VERS

For (Char VBDDNAM(200)) From '3' Sql
&        "select NAME from V$DATABASE"
&        As [BDD]
 BDDNAM=[BDD]VBDDNAM
 Break
Next

For (Char VERSION(200)) From '3' Sql
&        "Select VERSION from PRODUCT_COMPONENT_VERSION"
&       +" Where PRODUCT like 'Oracle%'"
&        As [VER]
 VER=[VER]VERSION
 Break
Next

For (Char VERDES(200)) From '3' Sql
&        "Select BANNER from V$VERSION WHERE BANNER like '%Oracle%'"
&        As [DES]
 VERDES=[DES]VERDES
 Break
Next

Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL_VERS
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
 GMESSAGE += "\"+"V$DATABASE, PRODUCT_COMPONENT_VERSION, V$VERSION"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
###################################################################################################
$ERR_SQL_PRO1
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
    If left$([M:PRO0]VER,1)="8"
        GMESSAGE += "\"+"V$PARAMETER, V$SGASTAT"
    Elsif left$([M:PRO0]VER,1)="9"
        GMESSAGE += "\"+"V$PARAMETER, V$SGASTAT, V$PGASTAT"
    Else :#10
        GMESSAGE += "\"+"V$PARAMETER, V$SGAINFO, V$PGASTAT"
    Endif
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
#**
#* ORACLE_MAJOR_VERSION **** function return the Major version of oracle version (ie: 12.1.0.2.0 will return 12)
#*
#* @param INPUT_ORAVER     : INPUT Oracle version retreived from Oracle SQL request
#*
#* @return integer         : The major version
#*!
Funprog ORACLE_MAJOR_VERSION (INPUT_ORAVER)
Value Char  INPUT_ORAVER
 # INPUT_ORAVER : Oracle Version is like "12.1.0.2.0" and comes from SQL request :
 #                Select VERSION from PRODUCT_COMPONENT_VERSION Where PRODUCT like 'Oracle%'
End fix(val(INPUT_ORAVER))

###################################################################################################
Subprog CHARGE_PRO1(ERR)
Variable Integer ERR

Local Char SQLREQ (250)
# JPGA 11/05/2009 BUG-54911 : Lorsque les valeurs retournÃĐes par INFVALEUR sont > 2e31, le dÃĐclarer en Integer ne suffit plus (limite atteinte!)
Local Decimal INFVALEUR,MAXSGA,TOTSHARE

Raz INFVALEUR,MAXSGA,TOTSHARE
Raz [M:PRO1]
nolign = 0

Onerrgo ERR_SQL_PRO1

### gestion auto
[M:PRO1]TXTAUT=mess(1001,153,1) : #"Gestion automatique de la mÃĐmoire partagÃĐe"
INFVALEUR = 0
# JPGA - 2017/11/24 : From oracle 11 and after : memory_target is used for ORACLE AMM
If func ORACLE_MAJOR_VERSION([M:PRO0]VER)>=10
  Case left$([M:PRO0]VER,2)
    When "10"
      SQLREQ = "select to_char(value) from V$PARAMETER where name='sga_target'"
      For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
        INFVALEUR=val([REQ]VVAL)
        Break
      Next
    When Default
      SQLREQ = "select to_char(value) from V$PARAMETER where name='memory_target'"
      For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
        INFVALEUR=val([REQ]VVAL)
        Break
      Next
  Endcase
Endif

If INFVALEUR > 0
    [M:PRO1]FLGAUT=2
Else
    [M:PRO1]FLGAUT=1
Endif

##################
# 1 - POOL PARTAGE - Shared Pool Size

If left$([M:PRO0]VER,1)="8" or left$([M:PRO0]VER,1)="9"
   SQLREQ = "select to_char(value) from V$PARAMETER where name='shared_pool_size'"
Else :#10
   SQLREQ = "select to_char(BYTES) from V$SGAINFO where name='Shared Pool Size'"
Endif
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    nolign +=1
    [M:PRO1]PARAM(nolign-1)=mess(1021,153,1) :#"Pool partagÃĐ"
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/(1024*1024)),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Mo"
        [M:PRO1]UNITE(nolign-1)=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/1024),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Ko"
        [M:PRO1]UNITE(nolign-1)=mess(1027,153,1)
    Else
        [M:PRO1]VALEUR(nolign-1)=arr(INFVALEUR,0.01)
        If INFVALEUR <> 0
            #VPO 04/09/08 48789
            #[M:PRO1]UNITE(nolign-1)="O"
            [M:PRO1]UNITE(nolign-1)=mess(1026,153,1)
        Endif
    Endif
    ###
    [M:PRO1]VALINF(nolign-1)=INFVALEUR
    ###
    TOTSHARE=INFVALEUR
 Break
Next


##################
# 2 - Cache de tampon -  DB Block Buffer Size

If left$([M:PRO0]VER,1)="8"
   SQLREQ = "select to_char(sum(BYTES)) From V$SGASTAT Where POOL is NULL and name='db_block_buffers'"
Elsif left$([M:PRO0]VER,1)="9"
   SQLREQ = "select to_char(sum(BYTES)) From V$SGASTAT Where POOL is NULL and name='buffer_cache'"
Else : # 10
   SQLREQ = "select to_char(BYTES) from V$SGAINFO where name='Buffer Cache Size'"
Endif
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    nolign +=1
    [M:PRO1]PARAM(nolign-1)=mess(1022,153,1) :#"Cache de tampon"
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/(1024*1024)),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Mo"
        [M:PRO1]UNITE(nolign-1)=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/1024),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Ko"
        [M:PRO1]UNITE(nolign-1)=mess(1027,153,1)
    Else
        [M:PRO1]VALEUR(nolign-1)=arr(INFVALEUR,0.01)
        If INFVALEUR <> 0
            #VPO 04/09/08 48789
            #[M:PRO1]UNITE(nolign-1)="O"
            [M:PRO1]UNITE(nolign-1)=mess(1026,153,1)
        Endif
    Endif
    ###
    [M:PRO1]VALINF(nolign-1)=INFVALEUR
    ###
    MAXSGA+=INFVALEUR
 Break
Next

##################
# 3 - Zone de mÃĐmoire LARGE POOL -

If left$([M:PRO0]VER,1)="8" or left$([M:PRO0]VER,1)="9"
   SQLREQ = "select to_char(sum(BYTES)) From V$SGASTAT where POOL='large pool'"
Else : # 10
   SQLREQ = "select to_char(BYTES) from V$SGAINFO where name='Large Pool Size'"
Endif
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    nolign +=1
    [M:PRO1]PARAM(nolign-1)=mess(1023,153,1) :#"Zone de mÃĐmoire LARGE POOL"
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/(1024*1024)),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Mo"
        [M:PRO1]UNITE(nolign-1)=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/1024),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Ko"
        [M:PRO1]UNITE(nolign-1)=mess(1027,153,1)
    Else
        [M:PRO1]VALEUR(nolign-1)=arr(INFVALEUR,0.01)
        If INFVALEUR <> 0
            #VPO 04/09/08 48789
            #[M:PRO1]UNITE(nolign-1)="O"
            [M:PRO1]UNITE(nolign-1)=mess(1026,153,1)
        Endif
    Endif
    ###
    [M:PRO1]VALINF(nolign-1)=INFVALEUR
    ###
    MAXSGA+=INFVALEUR
 Break
Next

##################
# 4 - POOL JAVA -

If left$([M:PRO0]VER,1)="8" or left$([M:PRO0]VER,1)="9"
   SQLREQ = "select to_char(sum(BYTES)) From V$SGASTAT Where POOL='java pool'"
Else : # 10
   SQLREQ = "select to_char(BYTES) from V$SGAINFO where name='Java Pool Size'"
Endif
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    nolign +=1
    [M:PRO1]PARAM(nolign-1)=mess(1024,153,1) :#"Pool Java"
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/(1024*1024)),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Mo"
        [M:PRO1]UNITE(nolign-1)=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/1024),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Ko"
        [M:PRO1]UNITE(nolign-1)=mess(1027,153,1)
    Else
        [M:PRO1]VALEUR(nolign-1)=arr(INFVALEUR,0.01)
        If INFVALEUR <> 0
            #VPO 04/09/08 48789
            #[M:PRO1]UNITE(nolign-1)="O"
            [M:PRO1]UNITE(nolign-1)=mess(1026,153,1)
        Endif
    Endif
    ###
    [M:PRO1]VALINF(nolign-1)=INFVALEUR
    ###
    MAXSGA+=INFVALEUR
 Break
Next

##################
# 5 - AUTRES pour 10g
If left$([M:PRO0]VER,1)<>"8" and left$([M:PRO0]VER,1)<>"9"
    SQLREQ = "select to_char(sum(bytes)) from V$SGAINFO"
    SQLREQ-= "where name not in ('Maximum SGA Size','Buffer Cache Size','Shared Pool Size','Large Pool Size',"
    SQLREQ-= "'Java Pool Size','Startup overhead in Shared Pool','Free SGA Memory Available','Granule Size')"
Else
    #Goto SUITE_PRO1
    SQLREQ = "select to_char(0) from DUAL"
Endif

For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    nolign +=1
    [M:PRO1]PARAM(nolign-1)=mess(1025,153,1) :#"Autres"
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/(1024*1024)),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Mo"
        [M:PRO1]UNITE(nolign-1)=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALEUR(nolign-1)=arr((INFVALEUR/1024),0.01)
        #VPO 04/09/08 48789
        #[M:PRO1]UNITE(nolign-1)="Ko"
        [M:PRO1]UNITE(nolign-1)=mess(1027,153,1)
    Else
        [M:PRO1]VALEUR(nolign-1)=arr(INFVALEUR,0.01)
        If INFVALEUR <> 0
            #VPO 04/09/08 48789
            #[M:PRO1]UNITE(nolign-1)="O"
            [M:PRO1]UNITE(nolign-1)=mess(1026,153,1)
        Endif
    Endif
    ###
    [M:PRO1]VALINF(nolign-1)=INFVALEUR
    ###
 Break
Next

$SUITE_PRO1
[M:PRO1]NBLIG = nolign
#I=[M:PRO1]NBLIG
For J=1 To [M:PRO1]NBLIG
    I=J
    If [M:PRO1]UNITE(I-1)<>""
        [M:PRO1]INFPAR(J-1)=[M:PRO1]PARAM(I-1)-"("+num$([M:PRO1]VALEUR(I-1))-[M:PRO1]UNITE(I-1)+")"
    Else
        [M:PRO1]INFPAR(J-1)=[M:PRO1]PARAM(I-1)-"("+num$([M:PRO1]VALEUR(I-1))+")"
    Endif
    [M:PRO1]INFVAL(J-1)=[M:PRO1]VALINF(I-1)
    #I-=1
Next J
[M:PRO1]NBINF = nolign


##################
# 6 - Calcul SGA TOTALE

[M:PRO1]TXTTOT=mess(1002,153,1) :#"Taille totale de la mÃĐmoire SGA"
INFVALEUR=MAXSGA+TOTSHARE
If (INFVALEUR/(1024*1024)) >= 1
    [M:PRO1]VALTOT=(INFVALEUR/(1024*1024))
    #VPO 04/09/08 48789
    #[M:PRO1]UNITOT="Mo"
    [M:PRO1]UNITOT=mess(1028,153,1)
Elsif (INFVALEUR/1024) >= 1
    [M:PRO1]VALTOT=(INFVALEUR/1024)
    #VPO 04/09/08 48789
    #[M:PRO1]UNITOT="Ko"
    [M:PRO1]UNITOT=mess(1027,153,1)
Else
    [M:PRO1]VALTOT=INFVALEUR
    #VPO 04/09/08 48789
    #[M:PRO1]UNITOT="O"
    [M:PRO1]UNITOT=mess(1026,153,1)
Endif
###

##################
# 7 - Calcul SGA MAX

If left$([M:PRO0]VER,1)="8" or left$([M:PRO0]VER,1)="9"
   SQLREQ = "select to_char(sum(BYTES)) From V$SGASTAT Where POOL='shared pool'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    INFVALEUR=val([REQ]VVAL)
    MAXSGA+=INFVALEUR
 Break
Next
Else :#10
   SQLREQ = "select to_char(BYTES) from V$SGAINFO where name='Maximum SGA Size'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    INFVALEUR=val([REQ]VVAL)
    MAXSGA=INFVALEUR
 Break
Next
Endif

[M:PRO1]TXTMAX=mess(1003,153,1) :#"Taille maximale de la mÃĐmoire SGA"
INFVALEUR=MAXSGA
If (INFVALEUR/(1024*1024)) >= 1
    [M:PRO1]VALMAX=(INFVALEUR/(1024*1024))
    #VPO 04/09/08 48789
    #[M:PRO1]UNIMAX="Mo"
    [M:PRO1]UNIMAX=mess(1028,153,1)
Elsif (INFVALEUR/1024) >= 1
    [M:PRO1]VALMAX=(INFVALEUR/1024)
    #VPO 04/09/08 48789
    #[M:PRO1]UNIMAX="Ko"
    [M:PRO1]UNIMAX=mess(1027,153,1)
Else
    [M:PRO1]VALMAX=INFVALEUR
    #VPO 04/09/08 48789
    #[M:PRO1]UNIMAX="O"
    [M:PRO1]UNIMAX=mess(1026,153,1)
Endif
###

TXTPGACUM=mess(1011,153,1) :#"Cible d'agrÃĐgation de la mÃĐmoire PGA"
TXTPGA=mess(1012,153,1) :#"QuantitÃĐ de mÃĐmoire PGA actuellement allouÃĐe"
UNIPGA="Ko"
TXTPGAMAX=mess(1013,153,1) :#"QuantitÃĐ maximale de mÃĐmoire PGA allouÃĐe"
UNIPGAMAX="Ko"-mess(1014,153,1) :#(depuis le dÃĐmarrage)
TXTPGARAT=mess(1015,153,1) :#"Pourcentage de succÃĻs en mÃĐmoire cache"

If left$([M:PRO0]VER,1)="8" : Goto FIN_CHARGE : Endif

#############
# 1 total PGA
SQLREQ = "select to_char(value) from V$PGASTAT where name='aggregate PGA target parameter'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    INFVALEUR=val([REQ]VVAL)
    If (INFVALEUR/(1024*1024)) >= 1
        [M:PRO1]VALPGACUM=(INFVALEUR/(1024*1024))
        #VPO 04/09/08 48789
        #[M:PRO1]UNIPGACUM="Mo"
        [M:PRO1]UNIPGACUM=mess(1028,153,1)
    Elsif (INFVALEUR/1024) >= 1
        [M:PRO1]VALPGACUM=(INFVALEUR/1024)
        #VPO 04/09/08 48789
        #[M:PRO1]UNIPGACUM="Ko"
        [M:PRO1]UNIPGACUM=mess(1027,153,1)
    Else
        [M:PRO1]VALPGACUM=INFVALEUR
        #VPO 04/09/08 48789
        #[M:PRO1]UNIPGACUM="O"
        [M:PRO1]UNIPGACUM=mess(1026,153,1)
    Endif
 Break
Next

#############
# 2 PGA allouÃĐe
SQLREQ = "select to_char(value) from V$PGASTAT where name='total PGA allocated'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    INFVALEUR=val([REQ]VVAL)
    [M:PRO1]VALPGA=(INFVALEUR/1024)
 Break
Next

#############
# 3 PGA Max
SQLREQ = "select to_char(value) from V$PGASTAT where name='maximum PGA allocated'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    INFVALEUR=val([REQ]VVAL)
    [M:PRO1]VALPGAMAX=(INFVALEUR/1024)
 Break
Next

#############
# 4 PGA ratio
SQLREQ = "select to_char(value) from V$PGASTAT where name='cache hit percentage'"
For (Char VVAL(200)) From '3' Sql SQLREQ As [REQ]
    [M:PRO1]PGARAT=[REQ]VVAL - "%"
 Break
Next

$FIN_CHARGE
Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL_PRO2
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
        GMESSAGE += "\"+"V$PARAMETER"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



###################################################################################################
###################################################################################################
Subprog CHARGE_PRO2(ERR)
Variable Integer ERR

Raz [M:PRO2]
nolign = 0

Onerrgo ERR_SQL_PRO2

For (Char VNAM(100),Char VVAL(255),Char VDEF(50),Char VDES(255)) From '3' Sql
&  "SELECT name, substr(value,1,250) vval,"
& -"DECODE(isDefault,'TRUE','YES','FALSE','NO'),description"
& -"From V$PARAMETER"
& -"Order BY 1"
&   As [BZZ]
    nolign +=1
    [M:PRO2]PAR(nolign-1)=[BZZ]VNAM
    [M:PRO2]PARVAL(nolign-1)=[BZZ]VVAL
    If [BZZ]VDEF="YES"
       [M:PRO2]DEFVAL(nolign-1)=2
    Else
       [M:PRO2]DEFVAL(nolign-1)=1
    Endif
    [M:PRO2]DES(nolign-1)=[BZZ]VDES
Next
[M:PRO2]NBPAR = nolign
Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL_PRO3_1
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
        GMESSAGE += "\"+"V$INSTANCE, V$DATABASE, ALL_USERS, V$SESSION"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End

###################################################################################################
###################################################################################################
$ERR_SQL_PRO3_2
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
        GMESSAGE += "\"+"NLS_DATABASE_PARAMETERS, NLS_INSTANCE_PARAMETERS, NLS_SESSION_PARAMETERS"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



###################################################################################################
###################################################################################################
Subprog CHARGE_PRO3(ERR)
Variable Integer ERR

Raz [M:PRO3]
Onerrgo ERR_SQL_PRO3_1

For (Char VSRVINS(50),Char VSRVMAC(64),Char VCREDAT(10),Char VCREHOU(10)) From '3' Sql
&  "SELECT INSTANCE_NAME,HOST_NAME,TO_CHAR(STARTUP_TIME,'YYYYMMDD'),TO_CHAR(STARTUP_TIME,'HH24:MI:SS')"
& -"From V$INSTANCE"
& -"where instance_number=1 "
&   As [BZZ]

    [M:PRO3]SRVMAC=[BZZ]VSRVMAC
    [M:PRO3]SRVINS=[BZZ]VSRVINS

    [M:PRO3]STRDAT=format$("DZ<:YYYYMMDD",[BZZ]VCREDAT)
    [M:PRO3]STRHOU=[BZZ]VCREHOU
    Break
Next

For (Char VCREDAT(10),Char VCREHOU(10),Char VLOGMODE(50)) From '3' Sql
&  "SELECT TO_CHAR(created,'YYYYMMDD'),TO_CHAR(created,'HH24:MI:SS'),"
& -"LOG_MODE"
& -"From V$DATABASE "
&   As [BZZ]
    [M:PRO3]CREDAT=format$("DZ<:YYYYMMDD",[BZZ]VCREDAT)
    [M:PRO3]CREHOU=[BZZ]VCREHOU
    [M:PRO3]LOGMOD=[BZZ]VLOGMODE
    Break
Next

For (Integer VNBRUSR) From '3' Sql
&  "SELECT count(*) from ALL_USERS"
&   As [BZZ]
    [M:PRO3]NBRUSR=[BZZ]VNBRUSR
    Break
Next

For (Integer VNBRPRO) From '3' Sql
&  "SELECT count(*) from V$SESSION"
&   As [BZZ]
    [M:PRO3]NBRPRO=[BZZ]VNBRPRO
    Break
Next

Onerrgo ERR_SQL_PRO3_2
nolign = 0
For (Char VNAM(250),Char VBDDVAL(250),Char VINSVAL(250),Char VSESVAL(250)) From '3' Sql
&  "select d.parameter,d.value,i.value ,s.value"
& -"FROM NLS_DATABASE_PARAMETERS d, NLS_INSTANCE_PARAMETERS i, NLS_SESSION_PARAMETERS s"
& -"where d.parameter=i.parameter(+) and d.parameter=s.parameter(+)"
& -"Order BY 1"
&   As [BZZ]
    nolign +=1
    [M:PRO3]PAR(nolign-1)=[BZZ]VNAM
    [M:PRO3]BDDVAL(nolign-1)=[BZZ]VBDDVAL
    [M:PRO3]INSVAL(nolign-1)=[BZZ]VINSVAL
    [M:PRO3]SESVAL(nolign-1)=[BZZ]VSESVAL
Next
[M:PRO3]NBNLS = nolign

Onerrgo
End




