#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EXEFNC 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FFO
mkstat = 0
zoncou = "FFO"
indice = 0
If varinit([M]FFO,indice)=0
 [M]FFO = 12
Endif
If varmode([M]FFO,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FFO([M]FFO) From EXEFNC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FFO : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "FFO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FONCTION
mkstat = 0
zoncou = "FONCTION"
indice = 0
If varmode([M]FONCTION,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FONCTION" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AFC","!",[M]FONCTION,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "FONCTION" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_FONCTION([M]FONCTION) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FONCTION" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone FFR
mkstat = 0
zoncou = "FFR"
indice = 0
If varinit([M]FFR,indice)=0
 [M]FFR = 12
Endif
If varmode([M]FFR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FFR([M]FFR) From EXEFNC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FFR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "FFR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RECHFCT
mkstat = 0
zoncou = "RECHFCT"
indice = 0
If varmode([M]RECHFCT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RECHFCT" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"
indice = 0
status = 1
zoncou = "NBLIG2"
If varmode([M]NBLIG2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG2 = nolign
   status = 75
   Call SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone F1
mkstat = 0
zoncou = "F1"
If varinit([M]F1,indice)=0
 [M]F1(indice) = 12
Endif
If varmode([M]F1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "F1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"

## Zone F2
mkstat = 0
zoncou = "F2"
If varinit([M]F2,indice)=0
 [M]F2(indice) = 12
Endif
If varmode([M]F2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "F2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EXEFNC"
Return

