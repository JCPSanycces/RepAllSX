##################################################
## DOSSUB  Sous-programmes divers
##################################################

##################################################
## Mise du dossier en mono-utilisateur          ##
##################################################
Subprog MONO(DOSSIER,OK)
Value    Char    DOSSIER
Variable Integer OK
Local Integer NBUSR , I , J , K
If !GHYPER
#   CC 12/12/2002     Pour mieux controler si connexiosn de type ADAPI
 Call USER_CONADAPI(DOSSIER,NBUSR) From PSADX
 If NBUSR>0
  Call ECR_TRACE(num$(NBUSR)-mess(48,125,1),1) From GESECRAN
  #  utilisateurs sur ce dossier
  OK = 0 : End
 Endif
Endif
#107271
If func DOSSUB.ISHISTFOLD(DOSSIER)
  Local File =DOSSIER+".ADOVALHIS" [AHW]
  Read [AHW]AHW0 = "";"";"MONO"
  MONO = val([F:AHW]VALEUR)
  If fstat
   Call ECR_TRACE(mess(49,125,1)-"ADOVALHIS"-"MONO",1) From GESECRAN
   # Erreur de lecture
   OK = 0 : End
  Elsif MONO
   Case MONO
    When 2
     Call ECR_TRACE(mess(46,125,1),1) From GESECRAN
     # Dossier en cours de génération
    When Default
     Call ECR_TRACE(mess(47,125,1),1) From GESECRAN
     # Dossier en cours d'utilisation
   Endcase
   OK = 0 : End
  Endif
  Trbegin [AHW]
   [F:AHW]VALEUR = "2"
   Rewrite [AHW]
   If fstat
    Call ECR_TRACE(mess(26,125,1)-"ADOVALHIS"-"MONO",1) From GESECRAN
    # Erreur d'écriture
    OK = 0
   Else
    OK = 1
   Endif
  Commit
Else
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW]ADW0 = "";"";"MONO"
  MONO = val([F:ADW]VALEUR)
  If fstat
   Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
   # Erreur de lecture
   OK = 0 : End
  Elsif MONO
   Case MONO
    When 2
     Call ECR_TRACE(mess(46,125,1),1) From GESECRAN
     # Dossier en cours de génération
    When Default
     Call ECR_TRACE(mess(47,125,1),1) From GESECRAN
     # Dossier en cours d'utilisation
   Endcase
   OK = 0 : End
  Endif
  Trbegin [ADW]
   [F:ADW]VALEUR = "2"
   Rewrite [ADW]
   If fstat
    Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    # Erreur d'écriture
    OK = 0
   Else
    OK = 1
   Endif
  Commit
Endif
End

##################################################
## Remise en multi-utilisateur                  ##
##################################################
Subprog MULTI(DOSSIER)
Value Char DOSSIER
#107271
If func DOSSUB.ISHISTFOLD(DOSSIER)
  Local File =DOSSIER+".ADOVALHIS" [AHW]
  Trbegin [AHW]
   Read [AHW]AHW0 = "";"";"MONO"
   If fstat
    # Erreur de lecture
    Call ECR_TRACE(mess(49,125,1)-"ADOVALHIS"-"MONO",1) From GESECRAN
   Else
    [F:AHW]VALEUR = "0"
    Rewrite [AHW]
    If fstat
     # Erreur d'écriture
     Call ECR_TRACE(mess(26,125,1)-"ADOVALHIS"-"MONO",1) From GESECRAN
    Endif
   Endif
  Commit
Else
  Local File =DOSSIER+".ADOVAL" [ADW]
  Trbegin [ADW]
   Read [ADW]ADW0 = "";"";"MONO"
   If fstat
    # Erreur de lecture
    Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
   Else
    [F:ADW]VALEUR = "0"
    Rewrite [ADW]
    If fstat
     # Erreur d'écriture
     Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    Endif
   Endif
  Commit
Endif
End

###############################################################
## Lecture numéro de patch d'une appli                       ##
###############################################################
Funprog PATNUM(DOSSIER)
Value Char DOSSIER
Local Char NOPATCH(10)
Call NOPATCH(DOSSIER,NOPATCH)
End NOPATCH

Subprog NOPATCH(DOSSIER,NOPATCH)
Value    Char DOSSIER
Variable Char NOPATCH
Local File =DOSSIER+".APATCH" [APT]
Filter [APT] Where TYP="P"
Read [APT]APT0 Last
If fstat=0
 NOPATCH=num$([F:APT]PATNUM)
Endif
Filter [APT]
Close Local File [APT]
End

Funprog PATNUMSUP(DOSSIER)
Value Char DOSSIER
Local Char NOPATCH(10)
Call NOPATCHSUP(DOSSIER,NOPATCH)
End NOPATCH

Subprog NOPATCHSUP(DOSSIER,NOPATCH)
Value Char DOSSIER
Variable Char NOPATCH
Local Char MACHINE(250) , APPLI(250) , APPRAC(250)
Onerrgo RIEN
If DOSSIER=nomap
 Local File ADOVAL [ADW]
Else
 Local File =DOSSIER+".ADOVAL" [ADW]
Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 APPRAC = toupper([F:ADW]VALEUR )
 If APPRAC=nomap
  Call NOPATCH(nomap,NOPATCH)
 Else
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
  If MACHINE=adxmac(0)
   If filinfo(filpath("FIL","APATCH","fde",APPRAC),0)>0
    Call NOPATCH(APPRAC,NOPATCH)
   Endif
  Else
   If filinfo(filpath("FIL","APATCH","fde",APPRAC,"",MACHINE),0)>0
    Local File =MACHINE+"@"+APPRAC+".APATCH" [APT]
    Filter [APT] Where TYP="P"
    Read [APT]APT0 Last
    If fstat=0
     NOPATCH=num$([F:APT]PATNUM)
    Endif
    Filter [APT]
    Close Local File [APT]
   Endif
  Endif
 Endif
Endif
Close Local File [ADW]
Onerrgo
End

###############################################################
## Appli test ?                                              ##
###############################################################
Funprog TEST(DOSSIER)
Value    Char DOSSIER
Local Integer TEST
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0 = "";"";"TEST"
If fstat or val([F:ADW]VALEUR )<>2
 TEST = 0
Else
 TEST = 1
Endif
Close Local File
End TEST

###############################################################
## Lecture numéro de version (paramètre RELEASE) d'une appli ##
###############################################################
Funprog RELEASE(DOSSIER)
Value Char DOSSIER
End func APRODUCT.AGETRELEASE(DOSSIER)

Subprog VERSION(DOSSIER,VERSION)
Value    Char DOSSIER
Variable Char VERSION()
VERSION=func APRODUCT.AGETRELEASE(DOSSIER)
End

##########################################################################
## Lecture numéro de version (paramètre RELEASE) de l'appli superviseur ##
##########################################################################
Funprog RELSUP(DOSSIER)
Value Char DOSSIER
End func APRODUCT.AGETRELEASEROOT(DOSSIER)

$RIEN
Resume

#############################################################################
## Lecture numéro de version superviseur (paramètre VERSUP) d'une appli    ##
#############################################################################
Subprog VERSUP(DOSSIER,VERSION)
Value    Char DOSSIER
Variable Char VERSION()
Local Char MACHINE(250) , APPLI(250) , APPRAC(250)
VERSION = ""
Onerrgo RIEN
If DOSSIER=nomap
 Local File ADOVAL [ADW]
Else
 Local File =DOSSIER+".ADOVAL" [ADW]
Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 APPRAC = toupper([F:ADW]VALEUR )
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
 If MACHINE=adxmac(0)
  If filinfo(filpath("FIL","ADOVAL","fde",APPRAC),0)>0
   Local File =APPRAC+".ADOVAL" [ADW2]
   Read [ADW2]ADW0 = "";"";"VERSUP"
   VERSION = [F:ADW2]VALEUR
   Close Local File [ADW2]
  Endif
 Else
  If filinfo(filpath("FIL","ADOVAL","fde",APPRAC,"",MACHINE),0)>0
   Local File =MACHINE+"@"+APPRAC+".ADOVAL" [ADW2]
   Read [ADW2]ADW0 = "";"";"VERSUP"
   VERSION = [F:ADW2]VALEUR
   Close Local File [ADW2]
  Endif
 Endif
Endif
Close Local File [ADW]
Onerrgo
End

##################################################
## Détermine si un code activité est spécifique ##
##################################################
Subprog SPEC(CODACT,SPEC)
Value    Char    CODACT
Variable Integer SPEC
If CODACT>="X" & find(CODACT,GSPE(1..GNBSPE))
 SPEC = 1
Else
 SPEC = 0
Endif
End

##################################################
## Détermine si un code activité a changé       ##
##################################################
Subprog DIFFACT(DOSSIER,CODACT,DIFF)
Value    Char    DOSSIER
Value    Char    CODACT
Variable Integer DIFF
If CODACT<>""
 If dim(DOSVERS)>0 & dim(SUPVERS)>0 & DOSVERS<>SUPVERS : # Cas d'une migration
  If clalev([F:DACV])=0 : Local File =DOSSIER+".ACTIV" [DACV] : Endif
  Read [DACV]CODACT = CODACT
  If fstat : DIFF = 92 : End : Endif
  If dim([F:DACV]UPDFLG)>0 & [F:DACV]UPDFLG>0 : DIFF = 95 : Endif
 Endif
# Nouvelle valeur dans le fichier dossier
 If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
 Read [ADA]ADA0 = DOSSIER;CODACT
 If fstat : DIFF = 91 : End : Endif
# Ancienne valeur dans le fichier ACTIV avant mise à jour
 If clalev([F:DACV])=0 : Local File =DOSSIER+".ACTIV" [DACV] : Endif
 Read [DACV]CODACT = CODACT
 If fstat : DIFF = 92 : End : Endif
 If [F:DACV]FLACT<>[F:ADA]FLACT : DIFF = 93 : End : Endif
 If [F:DACV]DIME <>[F:ADA]DIME  : DIFF = 94 : End : Endif
Endif
End

##############################################################
## Détermine si un texte a changé                           ##
##############################################################
Subprog TXT(NUMERO,DIFF)
Value    Integer NUMERO
Variable Integer DIFF
Local Integer ERR
ERR = 0
If NUMERO<=0
 End
#115210/6
Elsif NUMERO<GMAXTXTSTD | NUMERO>GNEWTXTSTD
 If GDERTXTSTD<>0 & NUMERO>GDERTXTSTD
  ERR = NUMERO
  DIFF = 99
 Elsif find(NUMERO,GMAJTXTSTD(1..GNBRTXTSTD))
  DIFF = 99
 Endif
Else
 If GDERTXTSPE<>0 & NUMERO>GDERTXTSPE
  ERR = NUMERO
  DIFF = 99
 Elsif find(NUMERO,GMAJTXTSPE(1..GNBRTXTSPE))
  DIFF = 99
 Endif
Endif
If ERR
 Call ERREUR("("+num$(ERR)+")"-mess(135,141,1),0) From DOSDIC : # Valeur hors limite
Endif
End

##############################################################
## Détermine si un objet doit être généré                   ##
##############################################################
Subprog NEWREC(DOSSIER,CODACT,MODULE,NEWREC)
Value    Char    DOSSIER
Value    Char    CODACT
Value    Integer MODULE
Variable Integer NEWREC
If MODULE=0
 NEWREC = 1
Elsif [F:ADS]MODULE(MODULE-1)=2
 NEWREC = 1
Else
 NEWREC = 0
Endif
If NEWREC & CODACT<>""
 If CODACT=GCODACTX3(1)
  NEWREC = 1
 Elsif CODACT=GCODACTX3(2)
  NEWREC = 0
 Else
  Read [ADA]ADA0 = DOSSIER;CODACT
  If fstat or [F:ADA]FLACT<>2
   NEWREC = 0
  Endif
 Endif
Endif
End

######################################################
# Détermine si un code activité est activ
######################################################
Funprog ACTIV(DOSSIER,CODACT)
Value Char CODACT
Local Integer OK
OK = 1
If CODACT<>""
 If CODACT=GCODACTX3(1)
  OK = 1
 Elsif CODACT=GCODACTX3(2)
  OK = 0
 Else
  Read [ADA]ADA0 = DOSSIER;CODACT
  If fstat or [F:ADA]FLACT<>2
   OK = 0
  Endif
 Endif
Endif
End OK

##############################################################
## Dimension d'une zone de table                            ##
##############################################################
Subprog REPTAB(CODACT,REPET)
Value    Char    CODACT
Variable Integer REPET
If CODACT<>""
 Read [ACV]CODACT = CODACT
 If !fstat
  If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
   REPET = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
  Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
   REPET = max([F:ACV]DIMFIL,[F:ACV]DIME)
  Endif
  If [F:ACV]FLACT<>2
   REPET = -max(REPET,1) : End
  Endif
 Else
  Call ECR_TRACE(CODACT-":"-mess(22,150,1),1) From GESECRAN : # Code activité inexistant
 Endif
Endif
REPET = max(REPET,1)
End

#######################################################
## Existence d'un index                              ##
#######################################################
Subprog INDEX(DOSSIER,CODACT,NEWREC)
Value    Char    DOSSIER
Value    Char    CODACT
Variable Integer NEWREC
NEWREC = 1
If CODACT<>""
 If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
 Read [ADA]ADA0 = DOSSIER;CODACT
 If fstat or [F:ADA]FLACT<>2
  NEWREC = 0
 Endif
Endif
End

#######################################################
## Ecriture trace hordatée                           ##
#######################################################
Subprog ECR_TIME(MESSA)
Value Char MESSA
Call ECR_TRACE(format$("D:"+GFMDAT4,date$)-time$-":"-MESSA,0) From GESECRAN
End

#######################################################
## Changement de langue                              ##
#######################################################
Subprog SETLANGUE(DOSSIER,LANGUE)
Value Char DOSSIER
Value Char LANGUE
GLANGUE     = LANGUE            : # Variable globale pour le superviseur
adxrob(0)   = "ECR"
adxrob(1)   = "M"+LANGUE        : # Répertoire des menus
messname(0) = LANGUE            : # Nom du fichier pour messages adonix
If DOSSIER=nomap
 adxtms     = "APLSTD"          : # Nom du fichier pour messages mess()
Else
 adxtms     = DOSSIER+".APLSTD" : # Nom du fichier pour messages mess()
Endif
adxmbm      = adxmbm            : # Flush des buffers de messages
End

#######################################################
## Suppression d'un traitement auto                  ##
#######################################################
Subprog SUPP_TRT(TRAITE)
Value Char TRAITE
Local Char    TRAITEMENT(250)
Local Integer STAT , OKTRT
Call EXISTE_ADX("",[F:ADS]DOSSIER,TRAITE,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX("",[F:ADS]DOSSIER,TRAITE,OKTRT) From ORDSYS
Endif
TRAITEMENT = filpath("TRT",TRAITE,"src",[F:ADS]DOSSIER)
If filinfo(TRAITEMENT,0)>=0
 Call EFFACE(TRAITEMENT,STAT) From ORDSYS
Endif
End

#######################################################
## Suppression d'une structure auto
#######################################################
Subprog SUPP_STC(TRAITE)
Value Char TRAITE
Local Char    TRAITEMENT(250)
Local Integer STAT , OKTRT
Call EXISTE_ADX("",[F:ADS]DOSSIER,TRAITE,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX("",[F:ADS]DOSSIER,TRAITE,OKTRT) From ORDSYS
Endif
TRAITEMENT = filpath("STC",TRAITE,"stc",[F:ADS]DOSSIER)
If filinfo(TRAITEMENT,0)>=0
 Call EFFACE(TRAITEMENT,STAT) From ORDSYS
Endif
End

#-----------------------------------------------#
# Type de base en fonction de GTYPDBA
#-----------------------------------------------#

Funprog CODDBA(TYPDBA)
Value Integer TYPDBA
Local Char CODDBA(1)
Case TYPDBA
 When 1 : CODDBA = "3" : # Oracle
 When 2 : CODDBA = "5" : # Sql
 When 3 : CODDBA = "2" : # Cisam
 When 4 : CODDBA = "4" : # DB2
Endcase
End CODDBA

#--------------------------------
# Functions on historical folders
#107271
#--------------------------------
Funprog PARENTHISTFOLD(DOSCUR)
Value    Char    DOSCUR
Local Char DOSPARENT(GLONADS)
Local File ADOSSIER         [ADS_]
Filter [ADS_] Where DOSHIS=DOSCUR
Read First
Filter [ADS_]
If !fstat
 End [F:ADS_]DOSSIER
Endif
End ""

Funprog ISHISTFOLD(DOSCUR)
Value    Char    DOSCUR
If func PARENTHISTFOLD(DOSCUR)<>""
 End 1
Endif
End 0

Funprog FILL_ADS(DOSCUR)
Value    Char    DOSCUR
Local Char DOSPARENT(GLONADS)
Raz [F:ADS]
DOSPARENT=func PARENTHISTFOLD(DOSCUR)
If DOSPARENT<>""
 Read [ADS]DOSSIER = DOSPARENT
 If !fstat
  If clalev([F:ADSH])=0  : Local File ADOSSIER        [ADSH]  : Endif
  [F:ADSH]=[F:ADS]
  [F:ADSH]DOSHIS=""
  [F:ADSH]DOSREF=[F:ADS]DOSSIER
  [F:ADSH]DOSCOP=[F:ADS]DOSSIER
  [F:ADSH]DOSSIER=DOSCUR
  [F:ADS]=[F:ADSH]
  End 1
 Endif
Else
 Read [ADS]DOSSIER = DOSCUR
 If fstat
  Raz [F:ADS]
 Else
  End 1
 Endif
Endif
End 0

