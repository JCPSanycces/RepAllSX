##############################################
##   Contrôle du no Carte Bleue           ####
##############################################
Subprog CONTCB(TYPCB,NOCB)
Value Char TYPCB()
Value Char NOCB()
Local Integer I, J, K
Case TYPCB
 When "VIS" : # Visa
  If not func AFNC.ACTIV("SEPP") : # X3-76511
    If len(NOCB)<>16 | num$(val(NOCB))<>NOCB
     GMESSAGE = mess(8,127,1) : mkstat=2 : End : # Numéro de carte incorrect
    Endif
    K=0
    For I=1 To 15
     J=val(mid$(NOCB,I,1))
     If mod(I,2)
      J=2*J : If J>9 : J=1+mod(J,10) : Endif
     Endif
     K+=J
    Next I
    I=mod(K,10)
    If !I : K=0 : Else K=10-I : Endif
    If val(mid$(NOCB,16,1))<>K
     GMESSAGE = mess(8,127,1) : mkstat=2 : # Numéro de carte incorrect
    Endif
  Endif
Endcase
End
##################################################
Subprog CONTPIVA(PIVA,PAYS)
Value Char PIVA()
Value    Char PAYS()          # FGR 06/04/2012 : X3SUIVI81399 (Value pas Const)

Gosub OUVRE
Local Integer SPSTAT,OK , OKTRT
If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call PIVA(PIVA,SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 1
    GMESSAGE = mess(6,127,1) : # Code IVA incorrect
    #mkstat=2
    Call AVERTIR(GMESSAGE,OK) From GESECRAN
    If OK<>2 : mkstat=2 : Endif
  Endcase
 Endif
Endif
End

#######################################################################
##   Mise à jour de l'enregistrement DEB : echanges CEE              ##
##     traitement standard des arrondis ( idem CONTFRANCE )          ##
##-------------------------------------------------------------------##
##  Flux :  11 Introduction Achats     12 Introduction Ventes        ##
##          21 Expedition   Achats     22 Expedition   Ventes        ##
#######################################################################
Subprog DEB (FLUX,SPSTAT)
Value    Integer FLUX
Variable Integer SPSTAT

If [F:DEB]STAAMT    : # valeur statistique
   If mod([F:DEB]STAAMT,int([F:DEB]STAAMT)) = 0.5
      [F:DEB]STAAMT = arr([F:DEB]STAAMT,1)-1
   Else
      [F:DEB]STAAMT = arr([F:DEB]STAAMT,1)
   Endif
Endif

If [F:DEB]FISAMT    : # valeur fiscale
   If mod([F:DEB]FISAMT,int([F:DEB]FISAMT)) = 0.5
      [F:DEB]FISAMT = arr([F:DEB]FISAMT,1)-1
   Else
      [F:DEB]FISAMT = arr([F:DEB]FISAMT,1)
   Endif
Endif

If [F:DEB]EECUNT    : # unites CEE
   [F:DEB]EECUNT=arr([F:DEB]EECUNT,1)
   If [F:DEB]EECUNT=0 [F:DEB]EECUNT=1 Endif
Endif

If [F:DEB]NETMAS    : # masse nette
   If [F:DEB]NETMAS < 0.5
      [F:DEB]NETMAS = 0
   Elsif [F:DEB]NETMAS < 1.5
     [F:DEB]NETMAS = 1
   Else
     [F:DEB]NETMAS=arr([F:DEB]NETMAS,1)
   Endif
Endif

End

#-------------------------------------------------------------#
Subprog CONTTEL(TEL,PAYS)
Value    Char    TEL
Value    Char    PAYS
Local Integer MODIF
MODIF = 0
Goto CONTTELTRT

#-------------------------------------------------------------#
Subprog CONTTELMOD(TEL,PAYS)
Value    Char    TEL
Value    Char    PAYS
Local Integer MODIF
MODIF = 1

$CONTTELTRT
Local Integer OPT
Local Char    MESSA(250)

Gosub OUVRE

OPT = val(func AFNC.PARAM("CTLTEL",""))
Case OPT
 When 2       : If !MODIF : End : Endif : # Uniquement en modif
 When 3       : If MODIF : End : Endif  : # Toujours
 When Default : End                     : # Jamais
Endcase

Call CNTTEL(TEL,MESSA)
If MESSA<>""
 GMESSAGE = MESSA : mkstat =2 : End
Endif

End

#---------------------------------------------#
Subprog CNTTEL(TEL,MESSA)
Value    Char TEL
Variable Char MESSA

Local Char    IDTPAY(10) , IDTREG(10) , NUMTEL(30)
Local Integer OKTRT , STAT , I

If dim([F:TCY]CTLPRG)>0 & [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Onerrgo RIEN
  Call CNTTEL(TEL,MESSA,STAT) From =[F:TCY]CTLPRG
  Onerrgo
  If STAT : End : Endif
 Endif
Endif

If len(TEL)=0 : End : Endif

Gosub SET_IDT

If len(TEL)<>LNG & LNG>0
 MESSA = mess(111,123,1)-'('+num$(LNG)+')' : # Longueur incorrecte
 End
Endif

If CTLTCY
 If IDTPAY=""
  MESSA = mess(115,127,1) : # Indicatif pays impossible à déterminer
  End
 Elsif IDTPAY<>""
  STAT = 0
  For I=1 To len(IDTPAY)
   If mid$(IDTPAY,I,1)<"0" or mid$(IDTPAY,I,1)>"9"
    STAT = 1 : Break
   Endif
  Next I
  If STAT
   MESSA = mess(120,127,1) : # Indicatif pays non numérique
   End
  Endif
 Endif
Endif

If CTLREG
 If IDTREG=""
  MESSA = mess(116,127,1) : # Indicatif région impossible à déterminer
  End
 Elsif IDTREG<>""
  STAT = 0
  For I=1 To len(IDTREG)
   If mid$(IDTREG,I,1)<"0" or mid$(IDTREG,I,1)>"9"
    STAT = 1 : Break
   Endif
  Next I
  If STAT
   MESSA = mess(119,127,1) : # Indicatif régional non numérique
   End
  Endif
 Endif
Endif

End

#----------------------------#
$RIEN
Resume

#--------------------------------------#
$SET_IDT
Local Integer K , D , F , M , LNG
Local Integer CTLTCY , CTLREG
Local Char    CHAINE(250) , TELEP(30)
If dim([F:TCY]TELFMT)>0 & [F:TCY]TELFMT<>"" & TEL<>""
 Call LNGFMT([F:TCY]TELFMT,LNG) From FMTVAR
 TELEP = format$("K:"+[F:TCY]TELFMT,TEL)
 If dim([F:TCY]TELTCY)>0 and dim([F:TCY]TELREG)>0 & LNG=len(TEL)
  For CHAINE=[F:TCY]TELTCY,[F:TCY]TELREG
   If CHAINE<>""
    Case CHAINE
     When [F:TCY]TELTCY : CTLTCY = 1
     When [F:TCY]TELREG : CTLREG = 1
    Endcase
    K = instr(1,CHAINE,"-")
    If K<>0
     D = val(left$(CHAINE,K-1))
     F = val(right$(CHAINE,K+1))
     M = max(M,F)
     Case CHAINE
      When [F:TCY]TELTCY : IDTPAY = seg$(TELEP,D,F)
      When [F:TCY]TELREG : IDTREG = seg$(TELEP,D,F)
     Endcase
    Endif
   Endif
  Next CHAINE
 Endif
 NUMTEL = right$(TELEP,M+1)
Endif
Return

#--------------------------------------------------#
Subprog DECOUPE(PAYS,TEL,IDTPAY,IDTREG,NUMTEL)
Value Char PAYS , TEL
Variable Char IDTPAY , IDTREG , NUMTEL
Gosub OUVRE
Gosub SET_IDT
End

