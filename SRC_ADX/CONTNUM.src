##############################################
##   Contrôle du RIB                      ####
##############################################
Subprog CONTRIB(RIB,PAYS)
Value Char RIB()          # FGR 06/04/2012 : X3SUIVI81399 (Value pas Const)
Value Char PAYS()         # FGR 06/04/2012 : X3SUIVI81399 (Value pas Const)

If RIB="" : End : Endif # CP (05/04/03) : Suite au nouveau superviseur

Gosub OUVRE
Local Integer SPSTAT , OKTRT

If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call RIB(RIB,SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 1
    GMESSAGE = mess(1,127,1) : # Clé incorrecte
    mkstat=2
   When 2
    GMESSAGE = mess(2,127,1) : # Le RIB doit être complet
    mkstat=2
  Endcase
 Endif
Endif
End

#####################################
$OUVRE
If clalev([F:TCY])=0
 Local File TABCOUNTRY [TCY]
Endif
If [F:TCY]CRY<>PAYS
 Read [TCY]TCY0 = PAYS
 If fstat : Raz [F:TCY] : Return : Endif
Endif
Return

##############################################
##   Contrôle du SIRET                    ####
##############################################
Subprog CONTSIRET(SIRET,PAYS,SITE)
Variable Char SIRET()
Value    Char PAYS()
Value    Char SITE

SIRET = vireblc(SIRET,2) : # MBT 12/10/09 Bug 58708

If SIRET="" : End : Endif # CP (05/04/03) : Suite au nouveau superviseur

Gosub OUVRE
Local Integer I , SPSTAT , OKTRT

If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call SIRET(SIRET,SITE,SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 1
    GMESSAGE = mess(3,127,1) : # Code SIRET incorrect
    mkstat=2
   When 2
    GMESSAGE = mess(4,127,1) : # Le code SIRET doit être complet
    mkstat=2
   When 3
    I = find(SITE,GSITE(1..GNBSITE))
    GMESSAGE = mess(32,127,1)-GSOCSITE(I) : # Le code SIRET ne correspond pas au SIREN de la Société
    mkstat=2
  Endcase
 Endif
Endif
End

##############################################
##   Contrôle du SIREN                    ####
##############################################
Subprog CONTSIREN(SIREN,PAYS)
Variable Char SIREN()
Value    Char PAYS()
If SIREN="" : End : Endif

Gosub OUVRE
Local Integer SPSTAT , OKTRT

If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call SIRET(SIREN,"",SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 1
    GMESSAGE = mess(30,127,1) : # Code SIREN incorrect
    mkstat=2
   When 2
    GMESSAGE = mess(31,127,1) : # Le code SIREN doit être complet
    mkstat=2
  Endcase
 Endif
Endif
End

##############################################
##   Contrôle du Numéro de TVA            ####
##############################################
Subprog CONTTVA(NUMTVA,PAYS)
Variable Char NUMTVA()
Value    Char PAYS()          # FGR 06/04/2012 : X3SUIVI81399 (Value pas Const)

If NUMTVA="" : End : Endif

Gosub OUVRE
Local Integer SPSTAT , OK , OKTRT

If [F:TCY]EECFLG<>2 : End : Endif
If left$(NUMTVA,len([F:TCY]CRYVATNUM))<>[F:TCY]CRYVATNUM
 OK = 1 : Call AVERTIR(mess(5,127,1)-[F:TCY]CRYVATNUM,OK) From GESECRAN
          #### Radical de no de TVA différent de
 If OK=1 : mkstat=2 : End : Endif
Endif
If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call TVA(NUMTVA,SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 0
    End
   When Default
    GMESSAGE = mess(6,127,1) : # Numéro de TVA incorrect
    mkstat=2
  Endcase
 Endif
Endif
End

###############################
## Init No TVA               ##
###############################
Subprog D_NUMTVA(PAYS,NUMTVA)
Value    Char PAYS()
Variable Char NUMTVA()

Gosub OUVRE
NUMTVA = [F:TCY]CRYVATNUM
End

######################################################
##   Contrôle du no d'immatriculation sociale     ####
######################################################
Subprog CONTSS(NOSS,PAYS,PAYSN,P1,P2,P3,P4)
Value Char NOSS(), PAYS(), P3(), PAYSN(), P4()
Value Integer P1
Value Date P2

Gosub OUVRE

Local Integer SPSTAT , OKTRT

If [F:TCY]CTLPRG<>""
 Call EXISTE_ADX("","",[F:TCY]CTLPRG,OKTRT) From ORDSYS
 If OKTRT>0
  Call SS(NOSS,PAYS=PAYSN,P1,P2,P3,P4,SPSTAT) From =[F:TCY]CTLPRG
  Case SPSTAT
   When 1
    GMESSAGE = mess(1,127,1) : # Clé incorrecte
    mkstat=2
   When 2
    GMESSAGE = mess(7,127,1) : # Plusieurs personnes ont le même no
    mkstat=2
   When 3 : # pb de cohérence avec les autres paramètres saisis confirmé
    mkstat=2
  Endcase
 Endif
Endif
End

