Gosub TEST From ASHWVAL
End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB2
Append CLOB2,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement WMQRY
#---------------------------------------------------------------------------------------------------#
Subprog VALTRT_QRY(DOSSIER,CODREP,ASHW,AERR)
Value Char DOSSIER , CODREP
Variable  Instance  ASHW  Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR

Gosub DEFVAR From ASHWVALTRT

Gosub DEFVAR

NOMTRTQRY = func SUBASW.PREFIX_QRYTRT+CODREP

I = find(3,ASHW.CODFAC(1..maxtab(ASHW.CODFAC)))
If ASHW.ENAFAC(I)<>2 : End : Endif

Call STC_VERF(NOMTRTQRY,ASHW.ACLAV.IDENTQRY,APPLI,MACHINE,"TRT",OK,AERR) From ACLASUB
If OK : # creation du fichiet Trt (WMQRY)
 Raz CLOB
 Gosub LOAD_TABLE_FOR_QUERY
 Gosub TRT_AQUERY_OPEN
 Gosub TRT_AQUERY_CLOSE
 Gosub TRT_AQUERY_JOIN
 Gosub TRT_AQUERY_FILTER_DEF
 Gosub TRT_AQUERY_TRANS
 Gosub TRT_AQUERY_CREATEINSTANCE
 Gosub TRT_AQUERY_SETINSTANCE
 Gosub TRT_AQUERY_CRITERIA
 Gosub TRT_AQUERY_LNKPRO
 Gosub TRT_AQUERY_DECODE_CRITERIA
 Gosub TRT_AQUERY_PRIMARYKEYS
 Gosub TRT_AQUERY_ACTION
 Call STC_DEB([L]APPLI,[L]MACHINE,NOMTRTQRY,ASHW.ACLAV.IDENTQRY,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
 Call TRT_FIN([L]CLOB,NOMTRTQRY,0,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB
 If maxtab(AERR)>0 : End : Endif
Endif

End

#---------------------------------------------------------------------------------------------------#
$DEFVAR
Local Char    WCLA(GLONACLA)
Local Integer WPTH,NBRAXX,NBRATX
Local Integer NB_WFLDCLB
Local Schar ATYBLBCLB(GLONATY)(1..250)
Local Integer NB_ATYBLBCLB
Local Char CHAINE(250),WABR(GLONABR), CHAINE2(80)
Local Char   VALEUR(GLONAVC)
Local Char   WCLE1(250),WCLE2(250),WCHAMP(250),WTABLE(250),WLANGUE(80)
Local Clbfile CLOB2(3)
Return

#---------------------------------------------------------------------------------------------------#
$LOAD_TABLE_FOR_QUERY

If ASHW.ACLA.TYPCLA<>2 : Return : Endif

For [ATY]CODTYP Where [F:ATY]TYPTYP=9 or [F:ATY]TYPTYP=10
 NB_ATYBLBCLB += 1
 ATYBLBCLB(NB_ATYBLBCLB) = [ATY]CODTYP
Next

NBABRUSED = 1
WABRUSED(NBABRUSED) = ASHW.ACLA.ACLAK(1).ABRLNK
WTBLUSED(NBABRUSED) = ASHW.ACLA.ACLAK(1).TABLNK
Gosub LIST_BLBCLB
For EXPPRO=1 To maxtab(ASHW.ASWR)
 If ASHW.ASWR(EXPPRO).CODPRO<>""
  [L]VALEUR = ASHW.ASWR(EXPPRO).CODPRO
  Gosub RECH_PRO From SUBASW2
  If NBCLA>1
   Read [ACLAF]ACLAF0 = ASHW.CODCLA;TABCLA(2)
   WCLA = [F:ACLAF]LNKCLA
   If NBCLA=2  : WPTH = 2 : Else : WPTH = 1 : Endif
   If ASHW.ASWR(EXPPRO).QRYPRO=2 or ASHW.ASWR(EXPPRO).LOKPRO=2 : I = 2 :  Gosub ADDTBLUSED : Endif
   For I=2 To NBCLA
    Read [ACLAF]ACLAF0 = WCLA;TABCLA(I)
    WCLA = [F:ACLAF]LNKCLA
    If I=NBCLA : WPTH = 2 : Else : WPTH = 1 : Endif
    If ASHW.ASWR(EXPPRO).QRYPRO=2 or ASHW.ASWR(EXPPRO).LOKPRO=2 : Gosub ADDTBLUSED : Endif
   Next
   If ASHW.ASWR(EXPPRO).QRYPRO=2 or ASHW.ASWR(EXPPRO).LOKPRO=2
    If maxtab(ASHW.ACLA.ACLAK)>=K
     ASHW.ASWR(EXPPRO).ABRTAB = ASHW.ACLA.ACLAK(K).ABRLNK
     ASHW.ASWR(EXPPRO).TABTAB = ASHW.ACLA.ACLAK(K).TABLNK
    Endif
   Endif
  Else
   ASHW.ASWR(EXPPRO).ABRTAB = ASHW.ACLA.ACLAK(1).ABRLNK
   ASHW.ASWR(EXPPRO).TABTAB = ASHW.ACLA.ACLAK(1).TABLNK
  Endif
 Endif
Next
Raz NBRAXX,NBRATX
For J=1 To maxtab(ASHW.ASWR)
 If  ASHW.ASWR(J).QRYPRO=2 or ASHW.ASWR(J).LOKPRO=2
  Case ASHW.ASWR(J).ACLAF.ATY.CODTYP
   When "AXX","AX1","AX2","AX3"
     NBABRUSED += 1 : NBRAXX +=1
     WABRUSED(NBABRUSED) = "WAXX"+num$(NBRAXX)
     WTBLUSED(NBABRUSED) = "ATEXTRA"
     WPTHUSED(NBABRUSED) = ""
     ASHW.ASWR(J).ABRTXT = WABRUSED(NBABRUSED)
   When "ATX"
     NBABRUSED += 1 : NBRATX +=1
     WABRUSED(NBABRUSED) = "WATX"+num$(NBRATX)
     WTBLUSED(NBABRUSED) = "ATEXTE"
     WPTHUSED(NBABRUSED) = ""
     ASHW.ASWR(J).ABRTXT = WABRUSED(NBABRUSED)
  Endcase
 Endif
Next
# On ajoute les tables qu'on trouve dans les criteres
Raz CHAINE,WABR, CHAINE2
For K=1 To maxtab(ASHW.ASWOPT)
 CHAINE = ASHW.ASWOPT(K).OPTCND
 I = instr(1,CHAINE,"[")
 While I>0
  J= instr(I+1,CHAINE,"]")
  If I>0 & J>0
   CHAINE2 = mid$(CHAINE,I+1,J-I-1)
   If instr(1,toupper(CHAINE2),"F:")
    CHAINE2 = right$(CHAINE2,3)
   Endif
   M = find(CHAINE2,ASHW.ACLA.ACLAK(1..maxtab(ASHW.ACLA.ACLAK)).ABRLNK)
   If M
    OK = find(ASHW.ACLA.ACLAK(M).ABRLNK,WABRUSED(1..NBABRUSED))
    If !OK
     NBABRUSED += 1
     WABRUSED(NBABRUSED) = ASHW.ACLA.ACLAK(M).ABRLNK
     WTBLUSED(NBABRUSED) = ASHW.ACLA.ACLAK(M).TABLNK
    Endif
   Endif
   I = instr(J+1,CHAINE,"[")
  Else
   I=0
  Endif
 Wend
Next
# Si aucune table n'a été rajouté on rajoute la table principale avec un abrev dif pour le link
If NBABRUSED = 1 : # If
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = "A_"
 WTBLUSED(NBABRUSED) = ASHW.ACLA.ACLAK(1).TABLNK
 WPTHUSED(NBABRUSED) = ""
Endif
# Si champ site , on rajoute AFCTFCY
If ASHW.ACLA.FCYSTR<>"" & ASHW.AFCRIGHT<>""
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = "AFF"
 WTBLUSED(NBABRUSED) = "AFCTFCY"
 WPTHUSED(NBABRUSED) = ""
Endif
If ASHW.ACLA.ACCSTR<>""
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = "ACC"
 WTBLUSED(NBABRUSED) = "ACCES"
 WPTHUSED(NBABRUSED) = ""
Endif
Return

#---------------------------------------------------------------------------------------------------#
# case action
#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_ACTION
LIGNE = "#-------------------------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "# ACTIONS"  : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$AQUERY_ACTION" : Gosub ADDCLB
LIGNE = "Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)" : Gosub ADDCLB
LIGNE = "[L]AEVENT = [L]ACTION" : Gosub ADDCLB
For I=1 To ASHW.NBRTRT
 LIGNE = "Gosub METHODS From "+ASHW.ASWTRT(I).CODTRT : Gosub ADDCLB
 LIGNE = "Gosub EVENTS From "+ASHW.ASWTRT(I).CODTRT : Gosub ADDCLB
Next
LIGNE = "Return" : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement WMQRY
#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_OPEN
LIGNE = "#-------------------------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "# Tables list to open"  : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$AQUERY_OPEN" : Gosub ADDCLB
For I=1 To NBABRUSED
 LIGNE =  "If clalev([F:"+WABRUSED(I)+"])=0 : Local File"-WTBLUSED(I)-"["+WABRUSED(I)+"] : Endif" : Gosub ADDCLB
Next
LIGNE = 'ACTION = "AQUERY_OPEN_AFTER" : Gosub AQUERY_ACTION' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_CLOSE
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Tables list to close" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_CLOSE" : Gosub ADDCLB
For I=1 To NBABRUSED
 LIGNE = "LogicClose File ["+WABRUSED(I)+"]" : Gosub ADDCLB
Next I
LIGNE = 'ACTION = "AQUERY_CLOSE_AFTER" : Gosub AQUERY_ACTION'  : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_JOIN
Local Integer WITHACC
Local Integer WITHRIGHT
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Link for the query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_JOIN" : Gosub ADDCLB
If ASHW.ACLA.ACCSTR<>""
 LIGNE ="If GACTX.ALLACS=[V]CST_AYES" : Gosub ADDCLB
 DIF +=1
 LIGNE ="Gosub AQUERY_JOIN_ALL " : Gosub ADDCLB
 DIF -= 1
 LIGNE ="Else" : Gosub ADDCLB
 DIF +=1
 WITHACC = [V]CST_ATRUE : WITHRIGHT = [V]CST_ATRUE : Gosub TRT_LINK
 DIF -=1
 LIGNE = "Endif" : Gosub ADDCLB
Else
  WITHACC =  [V]CST_ATRUE : WITHRIGHT = [V]CST_ATRUE  : Gosub TRT_LINK
Endif
LIGNE = 'ACTION = "AQUERY_JOIN_AFTER" : Gosub AQUERY_ACTION' : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
If ASHW.ACLA.ACCSTR<>""
 LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
 LIGNE = "# Link for the query" : Gosub ADDCLB
 LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
 LIGNE = "$AQUERY_JOIN_ALL" : Gosub ADDCLB
 WITHACC = [V]CST_AFALSE : WITHRIGHT = [V]CST_ATRUE : Gosub TRT_LINK
 LIGNE = 'Return' : Gosub ADDCLB
 LIGNE = " " : Gosub ADDCLB
Endif
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Link for the lookup" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_JOIN_LOOKUP" : Gosub ADDCLB
WITHACC =  [V]CST_ATRUE : WITHRIGHT = [V]CST_ATRUE  : Gosub TRT_LINK : # 101630  acces restriction on the lookup
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_FILTER_DEF
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Default filter for the query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_FILTER_DEF" : Gosub ADDCLB
Gosub TRT_FILTER_DEF
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return


#---------------------------------------------------------------------------------------------------#
$TRT_LINK
If ASHW.ACLA.TYPCLA<>2 : Return : Endif
#If ASHW.ACLA.ACCSTR<>""
# LIGNE ="Local Char _ACCFILTER(250)" : Gosub ADDCLB
# LIGNE ="If GACTX.ALLACS<>2" : Gosub ADDCLB
# DIF += 1
# LIGNE = "[L]_ACCFILTER = '([F:"+ASHW.ACLA.ACLAK(1).ABRLNK+"]"+ASHW.ACLA.ACCSTR+'="" or [F:ACC]CONSUL=2)'+"'" :  Gosub ADDCLB
# DIF -= 1
# LIGNE = 'Else' : Gosub ADDCLB
# DIF += 1
# LIGNE = '[L]_ACCFILTER = "1=1"' : Gosub ADDCLB
# DIF -= 1
# LIGNE = 'Endif' : Gosub ADDCLB
#Endif
If ASHW.AOBRIGHT<>"" & WITHRIGHT=[V]CST_ATRUE
 LIGNE = 'Local Char ACRITROLE(250)(1..)' : Gosub ADDCLB
 LIGNE = '[L]ASTATUS = fmet GACTX.AGETCRITROLE(GACTX,"'+ASHW.AOBRIGHT+'","'+ASHW.ACLA.ACLAK(1).ABRLNK+'",ACRITROLE,[V]CST_AFALSE)' : Gosub ADDCLB
Endif
B = 0
LIGNE = "Link ["+ASHW.ACLA.ACLAK(1).ABRLNK+"] With" : Gosub ADDCLB
For J=2 To maxtab(ASHW.ACLA.ACLAK)
 OK = find(ASHW.ACLA.ACLAK(J).ABRLNK,WABRUSED(1..NBABRUSED))
 If OK
  If B>0 : LIGNE += "," : Gosub ADDCLB : Endif
  B +=1
  LIGNE = "& ["+ASHW.ACLA.ACLAK(J).ABRLNK+"]"+ASHW.ACLA.ACLAK(J).CLELNK
  If find(ASHW.ACLA.ACLAK(J).TYPLNK,3,4)
   LIGNE += " ~= "
  Else
   LIGNE += " = "
  Endif
  LIGNE += ASHW.ACLA.ACLAK(J).EXPLNK
 Endif
Next
If ASHW.ACLA.FCYSTR<>"" & ASHW.AFCRIGHT<>""  & WITHRIGHT=[V]CST_ATRUE
 If B>0 : LIGNE += "," : Gosub ADDCLB0 : Endif
 B +=1
 LIGNE = "& [AFF]AFF0~= [F:"+ASHW.ACLA.ACLAK(1).ABRLNK+"]"+ASHW.ACLA.FCYSTR+";GACTX.APRFCOD;[L]_AFCRIGHT"
Endif
If ASHW.ACLA.ACCSTR<>"" & WITHACC=[V]CST_ATRUE
 If B>0 : LIGNE += "," : Gosub ADDCLB0 : Endif
 B +=1
 LIGNE = "& [ACC]CODACC~= GACTX.USER;[F:"+ASHW.ACLA.ACLAK(1).ABRLNK+"]"+ASHW.ACLA.ACCSTR
Endif
If !B :# Aucune JOINure on fait une auto jointure
 LIGNE = "& [A_]"+ASHW.ACLA.ACLAK(1).CLELNK+"~="
 For I=1 To ASHW.ACLA.ACLAK(1).NBRIND
  If I>1 : LIGNE += ";" : Endif
  LIGNE += "["+ASHW.ACLA.ACLAK(1).ABRLNK+"]"+ASHW.ACLA.ACLAK(1).INDEX(I)
 Next I
Endif
# Gestion AXX and ATX
For K=1 To maxtab(ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF)
 WCODPRO = ASHW.ABRCLA+"."+ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF(K).FLDCLA
 Gosub ADDLNKTXT
Next
For I=2 To NBABRUSED
 If WPTHUSED(I)<>""
  J = find(WABRUSED(I),ASHW.ACLA.ACLAK(1..maxtab(ASHW.ACLA.ACLAK)).ABRLNK)
  If J & WTRANSUSED(I)>0
   For K=1 To maxtab(ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF)
    OK =0
    WCODPRO = WPTHUSED(I)+"."+ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF(K).FLDCLA
    Gosub ADDLNKTXT
   Next
  Endif
 Endif
Next
If LIGNE<>"" : Gosub ADDCLB0 : Endif
LIGNE = '& As [LNK_]' : Gosub ADDCLB0
Gosub SET_WHERE
If len(CLOB2)>0 : Append CLOB,CLOB2 : Endif
Return


$SET_WHERE
Raz CLOB2
LIGNE = "& Where ( (1=1)" : Gosub ADDCLB2
K=0
If ASHW.ACLA.FLTREF<>""
 LIGNE = "& and ("+ASHW.ACLA.FLTREF+")"  : Gosub ADDCLB2
 K =1
Endif
If ASHW.ACLA.ACCSTR<>"" & WITHACC=[V]CST_ATRUE
 LIGNE = "& and ([F:ACC]CONSUL=2)"  : Gosub ADDCLB2
 K =1
Endif
#If ASHW.ACLA.ACCSTR<>""
# LIGNE = "& and (evalue([L]_ACCFILTER))" : Gosub ADDCLB2
# K=1
#Endif
If ASHW.AOBRIGHT<>"" & WITHRIGHT=[V]CST_ATRUE
 LIGNE = "& and (evalue([L]ACRITROLE))" : Gosub ADDCLB2
 K=1
Endif
For J=2 To maxtab(ASHW.ACLA.ACLAK)
 OK = find(ASHW.ACLA.ACLAK(J).ABRLNK,WABRUSED(1..NBABRUSED))
 If OK & ASHW.ACLA.ACLAK(J).EXPSEL<>""
  LIGNE = "& and ("+ASHW.ACLA.ACLAK(J).EXPSEL+")" : Gosub ADDCLB2
  K=1
 Endif
Next
For I=1 To ASHW.NBROPT
 If ASHW.ASWOPT(I)<>null & ASHW.ASWOPT(I).OPTOBY=2
  LIGNE = "& and "
  LIGNE += "("+ASHW.ASWOPT(I).OPTCND+")" : Gosub ADDCLB2
  Raz LIGNE
  K+=1
  Break
 Endif
Next
LIGNE = "&  )" : Gosub ADDCLB2
Return

#---------------------------------------------------------------------------------------------------#
$TRT_FILTER_DEF
If ASHW.ACLA.TYPCLA<>2 : Return : Endif
For I=1 To ASHW.NBROPT
 If ASHW.ASWOPT(I)<>null & ASHW.ASWOPT(I).OPTDEF=2
  LIGNE = "QFILTER='"+ASHW.ASWOPT(I).OPTCOD+"'" : Gosub ADDCLB
  Break
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
$ADDLNKTXT
For M=1 To maxtab(ASHW.ASWR)
 If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2) & ASHW.ASWR(M).CODPRO=WCODPRO
  Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
   When "AXX","AX1","AX2","AX3"
    For KK=1 To maxtab(ASHW.ASWR(M).ACLAF.ATBKEY)
     Case ASHW.ASWR(M).ACLAF.ATBKEY(KK).CODPAR
      When "CODFIC"  : WTABLE = ASHW.ASWR(M).ACLAF.ATBKEY(KK).VALEUR
      When "ZONE"    : WCHAMP = ASHW.ASWR(M).ACLAF.ATBKEY(KK).VALEUR
      When "IDENT1"  : WCLE1 = ASHW.ASWR(M).ACLAF.ATBKEY(KK).VALEUR : Call EVAL_CLE(ASHW,ASHW.ASWR(M).TABTAB,ASHW.ASWR(M).ABRTAB,WCLE1)
      When "IDENT2"  : WCLE2 = ASHW.ASWR(M).ACLAF.ATBKEY(KK).VALEUR : Call EVAL_CLE(ASHW,ASHW.ASWR(M).TABTAB,ASHW.ASWR(M).ABRTAB,WCLE2)
     Endcase
    Next
    If B>0 : LIGNE += "," : Gosub ADDCLB0 : Endif
    B +=1
    LIGNE = '& [F:'+ASHW.ASWR(M).ABRTXT+']AXX0 = '+WTABLE+';'+WCHAMP+';GACTX.LAN;'+WCLE1+';'+WCLE2
   When "ATX"
    If B>0 : LIGNE += "," : Gosub ADDCLB0 : Endif
    B +=1
    LIGNE = "& [F:"+ASHW.ASWR(M).ABRTXT+"]NUMERO = GACTX.LAN;[F:"+ASHW.ASWR(M).ABRTAB+"]"+ASHW.ASWR(M).FLDCLA
  Endcase
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
Subprog EVAL_CLE(ASHW,TAB,ABR,CHP)
Value Instance ASHW Using OBJECT
Variable Char TAB
Variable Char ABR
Variable Char CHP


Local Char    PTR(250),CHAMP(250),TABLE(GLONATB),ABREV(GLONABR),CHAINE(250)
Local Integer I,J
CHAMP= CHP
TABLE = TAB
ABREV = ABR
CHAINE= CHP

I = instr(1,toupper(CHAINE),"=NUM$(")
If I
 J =  instr(6,CHAINE,")")
 CHAMP = seg$(CHAINE,I+6,instr(7,CHAINE,")")-1)
Else
 CHAINE = ""
Endif

If instr(1,CHAMP,".")>0 & instr(1,CHAMP,'"')=0  & instr(1,CHAMP,'"')=0 & instr(1,CHAMP,"ACTX")=0 & instr(1,CHAMP,"AVOID")=0
 I = instr(1,CHAMP,".")
 While I>0
  PTR = left$(CHAMP,I-1)
  CHAMP = right$(CHAMP,I+1)
  I = instr(1,CHAMP,".")
 Wend
Endif

If PTR<>""
 For I=1 To maxtab(ASHW.ACLA.ACLAK)
  If ASHW.ACLA.ACLAK(I).REFLNK=PTR
   TABLE = ASHW.ACLA.ACLAK(I).TABLNK
   ABREV = ASHW.ACLA.ACLAK(I).ABRLNK
   Break
  Endif
 Next
Endif

Read [ATZ]CODZONE = TABLE;CHAMP
If !fstat
 CHP = "[F:"+ABREV +"]"+CHAMP
Endif

If CHAINE<>""
 CHP = "num$("+CHP+")"
Endif

End

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_CREATEINSTANCE
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Create instance" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_CREATEINSTANCE" : Gosub ADDCLB
If find(ASHW.ACLA.TYPCLA,2,5)=0
 LIGNE = 'Return' : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 Return
Endif
LIGNE = "# "+ASHW.ABRCLA-"---"-WTBLUSED(1)+"("+WABRUSED(1)+")" : Gosub ADDCLB
LIGNE = "QRY = NewInstance "+ASHW.ACLAV.NOMSTC+' AllocGroup PQRY' : Gosub ADDCLB
Local Integer INSTXT
If ASHW.ACLA.TYPCLA=2
 For K=1 To maxtab(ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF)
  WCODPRO = ASHW.ABRCLA+"."+ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF(K).FLDCLA
  For M=1 To maxtab(ASHW.ASWR)
   If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2) & ASHW.ASWR(M).CODPRO=WCODPRO
    Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
     When "AXX","AX1","AX2","AX3"
      INSTXT +=1 : LIGNE = "QRY."+ASHW.ABRCLA+'.AXX('+num$(INSTXT)+') = NewInstance C_ATXTTRA AllocGroup QRY' : Gosub ADDCLB
     When "ATX"
      INSTXT +=1 : LIGNE = "QRY."+ASHW.ABRCLA+'.ATX('+num$(INSTXT)+') = NewInstance C_ATXTSUP AllocGroup QRY' : Gosub ADDCLB
    Endcase
   Endif
  Next
 Next
Endif
Raz INSTXT
For I=2 To NBABRUSED
  If WPTHUSED(I)<>""
   J = find(WABRUSED(I),ASHW.ACLA.ACLAK(1..maxtab(ASHW.ACLA.ACLAK)).ABRLNK)
   If J
    LIGNE = "# "+WPTHUSED(I)-"---"-WTBLUSED(I)+"("+WABRUSED(I)+")"-WINSUSED(I) : Gosub ADDCLB
    LIGNE = "QRY."+WPTHUSED(I)+" = NewInstance C_"+WCLAUSED(I)+'(QRY.ACTX,UIDINS,NUMLIN,QRY,"'+WINSUSED(I)+'") AllocGroup QRY' : Gosub ADDCLB
    If WTRANSUSED(I)>0
     For K=1 To maxtab(ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF)
      WCODPRO = WPTHUSED(I)+"."+ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF(K).FLDCLA
      For M=1 To maxtab(ASHW.ASWR)
       If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2or ASHW.ASWR(M).LOKPRO=2)  & ASHW.ASWR(M).CODPRO=WCODPRO
        Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
         When "AXX","AX1","AX2","AX3"
          INSTXT +=1 : LIGNE = "QRY."+WPTHUSED(I)+'.AXX('+num$(INSTXT)+') = NewInstance C_ATXTTRA AllocGroup QRY' : Gosub ADDCLB
         When "ATX"
          INSTXT +=1 : LIGNE = "QRY."+WPTHUSED(I)+'.ATX('+num$(INSTXT)+') = NewInstance C_ATXTSUP AllocGroup QRY' : Gosub ADDCLB
        Endcase
       Endif
      Next
     Next
    Endif
    LIGNE = "" : Gosub ADDCLB
   Endif
  Endif
 Next
LIGNE = "QRY.setAccessorEnabled = 0" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_SETINSTANCE
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Create instance" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_SETINSTANCE" : Gosub ADDCLB
If find(ASHW.ACLA.TYPCLA,2,5)=0
 LIGNE = 'Return' : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 Return
Endif
If ASHW.ACLA.TYPCLA=2
 LIGNE = "If dim([F:"+WABRUSED(1)+"]AUUID)>0 & [F:"+WABRUSED(1)+"]AUUID=NullUuid" : Gosub ADDCLB
 DIF +=1
 LIGNE = "[F:"+WABRUSED(1)+"]AUUID = getUuid" : Gosub ADDCLB
 DIF -=1
 LIGNE = "Endif" : Gosub ADDCLB
 LIGNE = "SetInstance QRY."+ASHW.ABRCLA+" With [F:"+WABRUSED(1)+"]" : Gosub ADDCLB
 Raz INSTXT
 For K=1 To maxtab(ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF)
  WCODPRO = ASHW.ABRCLA+"."+ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF(K).FLDCLA
  For M=1 To maxtab(ASHW.ASWR)
   If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2) & ASHW.ASWR(M).CODPRO=WCODPRO
    If find(ASHW.ASWR(M).ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3","ATX")>0
     If ASHW.ASWR(M).ACLAF.ACS<>""
      LIGNE =  'If fmet QRY.'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY.'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)<[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
     Endif
     Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
      When "AXX","AX1","AX2","AX3"
      INSTXT +=1 :
      LIGNE = "QRY."+ASHW.ABRCLA+'.AXX('+num$(INSTXT)+').PRO = "'+ASHW.ASWR(M).FLDCLA+'"' : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.AXX('+num$(INSTXT)+').LAN = [F:'+ASHW.ASWR(M).ABRTXT+']LANGUE' : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.AXX('+num$(INSTXT)+').TEX = [F:'+ASHW.ASWR(M).ABRTXT+']TEXTE' : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.AXX('+num$(INSTXT)+').FLG = 1' : Gosub ADDCLB
     When "ATX"
      INSTXT +=1 :
      LIGNE = "QRY."+ASHW.ABRCLA+'.ATX('+num$(INSTXT)+').PRO = "'+ASHW.ASWR(M).FLDCLA+'"'  : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.ATX('+num$(INSTXT)+').LAN = [F:'+ASHW.ASWR(M).ABRTXT+']LAN'  : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.ATX('+num$(INSTXT)+').NUM = [F:'+ASHW.ASWR(M).ABRTXT+']NUMERO'  : Gosub ADDCLB
      LIGNE = "QRY."+ASHW.ABRCLA+'.ATX('+num$(INSTXT)+').TEX = [F:'+ASHW.ASWR(M).ABRTXT+']TEXTE'  : Gosub ADDCLB
     Endcase
     If ASHW.ASWR(M).ACLAF.ACS<>""
      DIF -= 1
      LIGNE = "Endif" : Gosub ADDCLB
     Endif
    Elsif find(ASHW.ASWR(M).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
     If ASHW.ASWR(M).ACLAF.ACS<>""
      LIGNE = 'If fmet QRY.'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY.'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
      LIGNE = '[L]ASTATUS = fmet QRY.'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isHidden","true")' : Gosub ADDCLB
      LIGNE = '[L]ASTATUS = fmet QRY.'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'",[V]CST_ARIGHTACCESS,"false")' : Gosub ADDCLB
      DIF -=1
      LIGNE = 'Elsif fmet QRY.'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTM(QRY.'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
      LIGNE = '[L]ASTATUS = fmet QRY.'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isReadOnly","true")' : Gosub ADDCLB
      DIF -=1
      LIGNE ="Endif" : Gosub ADDCLB
     Endif
    Else
     If ASHW.ASWR(M).ACLAF.ACS<>""
      LIGNE =  'If fmet QRY.'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY.'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR : Raz QRY.'+ASHW.ABRCLA+'.'+ASHW.ASWR(M).ACLAF.FLDCLA+
& ' : Endif' : Gosub ADDCLB
     Endif
    Endif
   Endif
  Next
 Next
Endif
Raz INSTXT
For I=2 To NBABRUSED
 If WPTHUSED(I)<>""
  J = find(WABRUSED(I),ASHW.ACLA.ACLAK(1..maxtab(ASHW.ACLA.ACLAK)).ABRLNK)
  If J
   If WTRANSUSED(I)>0
    LIGNE = "SetInstance QRY."+WPTHUSED(I)+" With [F:"+WABRUSED(I)+"]" : Gosub ADDCLB
    For K=1 To maxtab(ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF)
     WCODPRO = WPTHUSED(I)+"."+ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF(K).FLDCLA
     For M=1 To maxtab(ASHW.ASWR)
      If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2) & ASHW.ASWR(M).CODPRO=WCODPRO
       If ASHW.ASWR(M).ACLAF.ACS<>""
        LIGNE =  'If fmet QRY.'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY.'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)<[V]CST_AERROR' : Gosub ADDCLB
        DIF += 1
       Endif
       Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
        When "AXX","AX1","AX2","AX3"
         INSTXT +=1 :
         LIGNE = "QRY."+WPTHUSED(I)+'.AXX('+num$(INSTXT)+').PRO = "'+ASHW.ASWR(M).FLDCLA+'"' : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.AXX('+num$(INSTXT)+').LAN = [F:'+ASHW.ASWR(M).ABRTXT+']LANGUE' : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.AXX('+num$(INSTXT)+').TEX = [F:'+ASHW.ASWR(M).ABRTXT+']TEXTE' : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.AXX('+num$(INSTXT)+').FLG = 1' : Gosub ADDCLB
        When "ATX"
         INSTXT +=1 :
         LIGNE = "QRY."+WPTHUSED(I)+'.ATX('+num$(INSTXT)+').PRO = "'+ASHW.ASWR(M).FLDCLA+'"'  : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.ATX('+num$(INSTXT)+').LAN = [F:'+ASHW.ASWR(M).ABRTXT+']LAN'  : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.ATX('+num$(INSTXT)+').NUM = [F:'+ASHW.ASWR(M).ABRTXT+']NUMERO'  : Gosub ADDCLB
         LIGNE = "QRY."+WPTHUSED(I)+'.ATX('+num$(INSTXT)+').TEX = [F:'+ASHW.ASWR(M).ABRTXT+']TEXTE'  : Gosub ADDCLB
       Endcase
       If ASHW.ASWR(M).ACLAF.ACS<>""
        DIF -= 1
        LIGNE = "Endif" : Gosub ADDCLB
       Endif
      Elsif find(ASHW.ASWR(M).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
       If ASHW.ASWR(M).ACLAF.ACS<>""
        LIGNE = 'If fmet QRY.'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTC(QRY.'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
        DIF += 1
        LIGNE = '[L]ASTATUS = fmet QRY.'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isHidden","true")' : Gosub ADDCLB
        LIGNE = '[L]ASTATUS = fmet QRY.'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'",[V]CST_ARIGHTACCESS,"false")' : Gosub ADDCLB
        DIF -=1
        LIGNE = 'Elsif fmet QRY.'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTM(QRY.'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
        DIF += 1
        LIGNE = '[L]ASTATUS = fmet QRY.'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isReadOnly","true")' : Gosub ADDCLB
        DIF -=1
        LIGNE ="Endif" : Gosub ADDCLB
       Endif
      Else
       If ASHW.ASWR(M).ACLAF.ACS<>""
        LIGNE =  'If fmet QRY.'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTC(QRY.'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR : Raz QRY.'+WPTHUSED(I)+'.'+ASHW.ASWR(M).ACLAF.FLDCLA+
& ' : Endif' : Gosub ADDCLB
       Endif
      Endif
     Next
    Next
   Endif
   LIGNE = "" : Gosub ADDCLB
  Endif
 Endif
Next
LIGNE = '[L]ASTATUS = fmet QRY.ACTION("AQUERY_TRANS_AFTER")' : Gosub ADDCLB
LIGNE = "Gosub AQUERY_LNKPRO_INSTANCE"
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_TRANS
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Transclass of fields of query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_TRANS" : Gosub ADDCLB
If find(ASHW.ACLA.TYPCLA,2,5)=0
 LIGNE = 'Return' : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 Return
Endif

LIGNE = "# "+ASHW.ABRCLA-"---"-WTBLUSED(1)+"("+WABRUSED(1)+")" : Gosub ADDCLB
LIGNE = "QRY(NBREP) = NewInstance "+ASHW.ACLAV.NOMSTC+' AllocGroup PQRY' : Gosub ADDCLB
LIGNE = "QRY(NBREP).setAccessorEnabled = 0" : Gosub ADDCLB

If ASHW.ACLA.TYPCLA=2
 NB_WFLDCLB = 1
 While WFLDCLB(1,NB_WFLDCLB)<>""
  LIGNE = "if dim([F:"+WABRUSED(1)+"]"+WFLDCLB(1,NB_WFLDCLB)+")>0 : Raz [F:"+WABRUSED(1)+"]"+WFLDCLB(1,NB_WFLDCLB)+" : Endif" : Gosub ADDCLB
  NB_WFLDCLB += 1
 Wend

 LIGNE = "If dim([F:"+WABRUSED(1)+"]AUUID)>0 & [F:"+WABRUSED(1)+"]AUUID=NullUuid" : Gosub ADDCLB
 DIF +=1
 LIGNE = "[F:"+WABRUSED(1)+"]AUUID = getUuid" : Gosub ADDCLB
 DIF -=1
 LIGNE = "Endif" : Gosub ADDCLB

 LIGNE = "SetInstance QRY(NBREP)."+ASHW.ABRCLA+" With [F:"+WABRUSED(1)+"]" : Gosub ADDCLB
 LIGNE = '[L]ASTATUS = fmet QRY(NBREP).ACTION("AQUERY_TRANS_AFTER")' : Gosub ADDCLB
 For K=1 To maxtab(ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF)
  OK = 0
  WCODPRO = ASHW.ABRCLA+"."+ASHW.ACLA.ACLAK(1).ACLALNK.ACLAF(K).FLDCLA
  For M=1 To maxtab(ASHW.ASWR)
   If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2)  & ASHW.ASWR(M).CODPRO=WCODPRO
    If find(ASHW.ASWR(M).ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3","ATX")>0
     If ASHW.ASWR(M).ACLAF.ACS<>""
      LIGNE =  'If fmet QRY(NBREP).'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)<[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
     Endif
     Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
      When "AXX","AX1","AX2","AX3"
       LIGNE = 'Call ASETTEXTRA('+"QRY(NBREP)."+ASHW.ABRCLA+'.AXX,"QRY","'+ASHW.ASWR(M).FLDCLA+'",[F:'+ASHW.ASWR(M).ABRTXT+']TEXTE,[F:'+ASHW.ASWR(M).ABRTXT+']LANGUE) From ASYRSUB' : Gosub ADDCLB
      When "ATX"
       LIGNE = 'Call ASETTEXT('+"QRY(NBREP)."+ASHW.ABRCLA+'.ATX,"QRY","'+ASHW.ASWR(M).FLDCLA+'",[F:'+ASHW.ASWR(M).ABRTXT+']TEXTE,[F:'+ASHW.ASWR(M).ABRTXT+']LAN,[F:'+ASHW.ASWR(M).ABRTXT+
& ']NUMERO) From ASYRSUB'
       Gosub ADDCLB
     Endcase
     If ASHW.ASWR(M).ACLAF.ACS<>""
      DIF -= 1
      LIGNE = "Endif" : Gosub ADDCLB
     Endif
    Elsif find(ASHW.ASWR(M).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
     If ASHW.ASWR(M).ACLAF.ACS<>""
      LIGNE = 'If fmet QRY(NBREP).'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
      LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isHidden","true")' : Gosub ADDCLB
      LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'",[V]CST_ARIGHTACCESS,"false")' : Gosub ADDCLB
      DIF -=1
      LIGNE = 'Elsif fmet QRY(NBREP).'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTM(QRY(NBREP).'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
      DIF += 1
      LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+ASHW.ABRCLA+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isReadOnly","true")' : Gosub ADDCLB
      DIF -=1
      LIGNE ="Endif" : Gosub ADDCLB
     Endif
    Else
      If ASHW.ASWR(M).ACLAF.ACS<>""
       LIGNE =  'If fmet QRY(NBREP).'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+ASHW.ABRCLA+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR :'
       LIGNE +=  'Raz QRY(NBREP).'+ASHW.ABRCLA+'.'+ASHW.ASWR(M).ACLAF.FLDCLA+' : Endif' : Gosub ADDCLB
     Endif
    Endif
   Endif
  Next
 Next
 LIGNE = " " : Gosub ADDCLB

 For I=2 To NBABRUSED
  If WPTHUSED(I)<>""
   J = find(WABRUSED(I),ASHW.ACLA.ACLAK(1..maxtab(ASHW.ACLA.ACLAK)).ABRLNK)
   If J
    LIGNE = "# "+WPTHUSED(I)-"---"-WTBLUSED(I)+"("+WABRUSED(I)+")"-WINSUSED(I) : Gosub ADDCLB
    LIGNE = "QRY(NBREP)."+WPTHUSED(I)+" = NewInstance C_"+WCLAUSED(I)+'(QRY.ACTX,UIDINS,NUMLIN,QRY(NBREP),"'+WINSUSED(I)+'") AllocGroup QRY(NBREP)' : Gosub ADDCLB
    If WTRANSUSED(I)>0
     NB_WFLDCLB = 1
     While WFLDCLB(I,NB_WFLDCLB)<>""
     LIGNE = "if dim([F:"+WABRUSED(I)+"]"+WFLDCLB(I,NB_WFLDCLB)+")>0 : Raz [F:"+WABRUSED(I)+"]"+WFLDCLB(I,NB_WFLDCLB)+" : Endif" : Gosub ADDCLB
      NB_WFLDCLB += 1
     Wend
     LIGNE = "SetInstance QRY(NBREP)."+WPTHUSED(I)+" With [F:"+WABRUSED(I)+"]" : Gosub ADDCLB
     For K=1 To maxtab(ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF)
      OK =0
      WCODPRO = WPTHUSED(I)+"."+ASHW.ACLA.ACLAK(J).ACLALNK.ACLAF(K).FLDCLA
      For M=1 To maxtab(ASHW.ASWR)
       If ASHW.ASWR(M).CODPRO<>"" &  (ASHW.ASWR(M).QRYPRO=2 or ASHW.ASWR(M).LOKPRO=2) & ASHW.ASWR(M).CODPRO=WCODPRO
        If find(ASHW.ASWR(M).ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3","ATX")>0
         If ASHW.ASWR(M).ACLAF.ACS<>""
          LIGNE =  'If fmet QRY(NBREP).'+ASHW.ABRCLA+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)<[V]CST_AERROR' : Gosub ADDCLB
          DIF += 1
         Endif
         Case ASHW.ASWR(M).ACLAF.ATY.CODTYP
          When "AXX","AX1","AX2","AX3"
           LIGNE = 'Call ASETTEXTRA('+"QRY(NBREP)."+WPTHUSED(I)+'.AXX,"QRY","'+ASHW.ASWR(M).FLDCLA+'",[F:'+ASHW.ASWR(M).ABRTXT+']TEXTE,[F:'+ASHW.ASWR(M).ABRTXT+']LANGUE ) From ASYRSUB' : Gosub ADDCLB
          When "ATX"
           LIGNE = 'Call ASETTEXT('+"QRY(NBREP)."+WPTHUSED(I)+'.ATX,"QRY","'+ASHW.ASWR(M).FLDCLA+'",[F:'+ASHW.ASWR(M).ABRTXT+']TEXTE,[F:'+ASHW.ASWR(M).ABRTXT+']LAN,[F:'+ASHW.
& ASWR(M).ABRTXT+']NUMERO) From ASYRSUB' : Gosub ADDCLB
         Endcase
         If ASHW.ASWR(M).ACLAF.ACS<>""
          DIF -= 1
          LIGNE = "Endif" : Gosub ADDCLB
         Endif
        Elsif find(ASHW.ASWR(M).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
         If ASHW.ASWR(M).ACLAF.ACS<>""
          LIGNE = 'If fmet QRY(NBREP).'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
          DIF += 1
          LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isHidden","true")' : Gosub ADDCLB
          LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'",[V]CST_ARIGHTACCESS,"false")' : Gosub ADDCLB
          DIF -=1
          LIGNE = 'Elsif fmet QRY(NBREP).'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTM(QRY(NBREP).'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
          DIF += 1
          LIGNE = '[L]ASTATUS = fmet QRY(NBREP).'+WPTHUSED(I)+'.ASETATTRIBUTE("'+ASHW.ASWR(M).ACLAF.FLDCLA+'","$isReadOnly","true")' : Gosub ADDCLB
          DIF -=1
          LIGNE ="Endif" : Gosub ADDCLB
         Endif
        Else
         If ASHW.ASWR(M).ACLAF.ACS<>""
          LIGNE =  'If fmet QRY(NBREP).'+WPTHUSED(I)+'.ACTX.AGETACSRIGHTC(QRY(NBREP).'+WPTHUSED(I)+',"'+ASHW.ASWR(M).ACLAF.ACS+'",[V]CST_AFALSE)>=[V]CST_AERROR : Raz QRY(NBREP).'+WPTHUSED(I)+'.'+ASHW.
& ASWR(M).ACLAF.FLDCLA+' : Endif' : Gosub ADDCLB
         Endif
        Endif
       Endif
      Next
     Next
    Endif
    LIGNE = "" : Gosub ADDCLB
   Endif
  Endif
 Next
Else
 LIGNE = '[L]ASTATUS = fmet QRY(NBREP).ACTION("AQUERY_TRANS_AFTER")' : Gosub ADDCLB
Endif
LIGNE = "QRY(NBREP).setAccessorEnabled = 1" : Gosub ADDCLB
LIGNE = "Gosub AQUERY_LNKPRO" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_CRITERIA
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Additionnal criteria of query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_CRITERIA" : Gosub ADDCLB
LIGNE = "Gosub DECLARE_VAR From "+func APREFIXTRT.GET_PREFIX_CLA+"0"+ASHW.CODCLA  : Gosub ADDCLB
LIGNE = 'CURQRY = "'+ASHW.ACLAV.NOMSTC+'"' : : Gosub ADDCLB
LIGNE = 'ACTION = "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_ACTION'  : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_LNKPRO
Local Char CAS(10)
For CAS="","INSTANCE"
 LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
 LIGNE = "# LNKPRO of query"-CAS : Gosub ADDCLB
 LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
 LIGNE = "$AQUERY_LNKPRO"+string$(CAS<>"","_"+CAS) : Gosub ADDCLB
 For J=1 To maxtab(ASHW.ASWR)
  #If ASHW.ASWR(J).ACLAF.ATY<>null & !find(ASHW.ASWR(J).ACLAF.ATY.TYPTYP,9,10)
  If  ASHW.ASWR(J).QRYPRO=2 or ASHW.ASWR(J).LOKPRO=2
   If ASHW.ASWR(J).ACLAF.ATY<>null
    If ASHW.ASWR(J).ACLAF.ACHPSHO<>null or ASHW.ASWR(J).ACLAF.ACHPLNG<>null or ASHW.ASWR(J).ACLAF.ACHPSYM<>null
&  or find(ASHW.ASWR(J).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)>0
&  or find(5,ASHW.ASWR(J).ACLAF.ATY.ARUL(1..maxtab(ASHW.ASWR(J).ACLAF.ATY.ARUL)).TYPRUL)>0 : #rule FORMAT
     If CAS=""
      LIGNE = "Callmet QRY(NBREP)."
     Else
      LIGNE = "Callmet QRY."
     Endif
     LIGNE += ASHW.ASWR(J).CODPRO+"."+ASHW.ACLAV.TBMET(10)
     Gosub ADDCLB
    Endif
   Endif
  Endif
 Next
 LIGNE = 'Return' : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Next
Return

#---------------------------------------------------------------------------------------------------#
$TRT_AQUERY_DECODE_CRITERIA
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# LOAD_PROPERTIES of query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_DECODE_CRITERIA" : Gosub ADDCLB
LIGNE = "NBPRO = 0" : Gosub ADDCLB

If ASHW.ACLA.TYPCLA=2
 For K=1 To maxtab(ASHW.ACLA.ACLAK)
  OK = find(ASHW.ACLA.ACLAK(K).ABRLNK,WABRUSED(1..NBABRUSED))
  If OK
   For J=1 To maxtab(ASHW.ASWR)
    If   ASHW.ASWR(J).QRYPRO<>2 and  ASHW.ASWR(J).LOKPRO<>2
&   & ASHW.ACLA.ACLAK(K).ABRLNK=ASHW.ASWR(J).ABRTAB
&   & find(ASHW.ASWR(J).FLDCLA,ASHW.ACLA.ACLAK(K).INDEX)>0
     Gosub ADD_LOAD_PROPERTIES
    Endif
   Next
  Endif
 Next
 For J=1 To maxtab(ASHW.ASWR)
  If !find(ASHW.ASWR(J).ACLAF.ATY.TYPTYP,9,10)
   If  ASHW.ASWR(J).QRYPRO=2 or ASHW.ASWR(J).LOKPRO=2
    Gosub ADD_LOAD_PROPERTIES
   Endif
  Endif
 Next
Endif
LIGNE = 'ACTION = "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_ACTION' : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$ADD_LOAD_PROPERTIES
LIGNE = 'NBPRO += 1 : TBPRO(NBPRO) = "'+ASHW.ASWR(J).ALIAS
#If maxtab(ASHW.ASWR(J).ASWK)>0 & ASHW.ASWR(J).ACLAF.ATY.CODCLA<>ASHW.ASWR(J).ACLAF.CODCLA
# LIGNE += '_REF'
#Endif
LIGNE += '" : TBFIL(NBPRO) = "[F:'
Case ASHW.ASWR(J).ACLAF.ATY.CODTYP
 When "AXX","AX1","AX2","AX3","ATX"
  LIGNE += ASHW.ASWR(J).ABRTXT+']TEXTE"'
 When Default :
  LIGNE += ASHW.ASWR(J).ABRTAB+']'+ASHW.ASWR(J).FLDCLA+'"'
Endcase
Gosub ADDCLB
LIGNE = space$(11)+": TBTYP(NBPRO) = "
If ASHW.ASWR(J).ACLAF.ATY.CODTYP="ATX" : LIGNE += "25"
Elsif find(ASHW.ASWR(J).ACLAF.ATY.CODTYP,"AXX","AX1","AX2","AX3")>0 : LIGNE += "26"
Else                                   : LIGNE += num$(ASHW.ASWR(J).ACLAF.ATY.TYPTYP)
Endif
LIGNE += ' : TBPTH(NBPRO) = "'+ASHW.ASWR(J).CODPRO+'"'
Gosub ADDCLB
Return

#----------------------------------------------------------#
$TRT_AQUERY_PRIMARYKEYS
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Standard key of query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$AQUERY_PRIMARYKEYS" : Gosub ADDCLB
LIGNE = "Local Char ASTDKEY(250)" : Gosub ADDCLB
LIGNE = 'ASTDKEY = ""' : Gosub ADDCLB
If ASHW.ACLA.TYPCLA=2 and ASHW.DESCRIPT=""
 For I=1 To ASHW.ACLA.ACLAK(1).NBRIND
  LIGNE = 'ASTDKEY += '
  If I>1
   LIGNE += '";"+'
  Endif
  LIGNE += '"[F:'+ASHW.ACLA.ACLAK(1).ABRLNK+']'+ASHW.ACLA.ACLAK(1).INDEX(I)+'"'
  Gosub ADDCLB
 Next I
Elsif ASHW.DESCRIPT<>""
 Local Integer NBKEYS
 Local Char    KEYS(GLONAVB)(1..16),ORDS(5)(1..16)
 Call SETCLEORDER([L]NBKEYS,[L]KEYS,[L]ORDS,ASHW.DESCRIPT) From LNKSUB
 For I=1 To [L]NBKEYS
  LIGNE = 'ASTDKEY += '
  If I>1
   LIGNE += '";"+'
  Endif
  LIGNE += '"[F:'+ASHW.ACLA.ACLAK(1).ABRLNK+']'+KEYS(I)+[L]ORDS(I)+'"'
  Gosub ADDCLB
 Next
Endif
LIGNE = 'ACTION = "AQUERY_PRIMARYKEYS_AFTER" : Gosub AQUERY_ACTION' : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#---------------------------------------------------------------------------------------------------#
$LIST_BLBCLB
For [ATZ]CODZONE  Where CODFIC = WTBLUSED(NBABRUSED) & find(CODTYP,ATYBLBCLB(1..NB_ATYBLBCLB))>0
 NB_WFLDCLB += 1
 WFLDCLB(NBABRUSED,NB_WFLDCLB) = [F:ATZ]CODZONE
Next
Return

#---------------------------------------------------------------------------------------------------#
$ADDTBLUSED
For K=1 To maxtab(ASHW.ACLA.ACLAK)
 If WCLA=ASHW.ACLA.ACLAK(K).CLALNK
  If !find(ASHW.ACLA.ACLAK(K).ABRLNK,WABRUSED(1..NBABRUSED))
   NBABRUSED += 1
   WABRUSED(NBABRUSED) = ASHW.ACLA.ACLAK(K).ABRLNK
   WTBLUSED(NBABRUSED) = ASHW.ACLA.ACLAK(K).TABLNK
   For M=1 To  I
    WPTHUSED(NBABRUSED) += string$(M>1,".")+TABCLA(M)
   Next
   WINSUSED(NBABRUSED) = TABCLA(I)
   WCLAUSED(NBABRUSED) = WCLA
   WTRANSUSED(NBABRUSED) = (WPTH=2)
   Break
  Else
   If WPTH=2
    WTRANSUSED(find(ASHW.ACLA.ACLAK(K).ABRLNK,WABRUSED(1..NBABRUSED))) = (WPTH=2)
   Endif
   Break
  Endif
 Endif
Next
Return

