#<AdxTL>@(#)12.0.0.0 $Revision$
################################################################################
# SQUELETTE D'UNE MOULINETTE POUR POUVOIR LA LANCER EN INTEGRATION DE PATCH    #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("APCC200501") From LECFIC
 Call APCC200501(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de APCC200501                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcèment activé    #
#      tous les modules dans ses dossiers
#                                              
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog APCC200501(APPLI)
Value Char APPLI
Local Integer OK

#Call ECR_TRACE("APCC200501: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début
Local Integer TRCOU
Local File =APPLI+".AFONCTION"  [AFC] 
If adxlog=0 : TRCOU=1 : Trbegin [AFC] : Endif
Delete [AFC] Where CODINT="CPTX3"
If TRCOU=1 : Commit : Endif
Call ECR_TRACE("APCC200501: Suppress CPTX3 function on folder : "+APPLI,0) From GESECRAN

# Regénère les profils
If clalev([F:ADS])<=0 : Local File ADOSSIER [ADS]:  Endif
Read [ADS]DOSSIER = APPLI
# on ne génère pas les menus sur le dossier mère
If [ADS]DOSREF=APPLI : End : Endif
Call GENMEN From DOSMEN

#Call PATCH(APPLI) From VALMENU


End

###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=adxmother(0) : End : Endif
Call APCC200501(APPLI)
End


