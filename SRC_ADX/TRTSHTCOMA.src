#<AdxTL>@(#)1.0.0.0 $Revision$
##########################
# Ce traitement contient le code propre à chaque document
# tous appelés de TRTSHTCOM
##########################


###############################################################################
# CHARGE_PARAM_SO : Effectue le chargement de certains paramètres
#                   avant le lancement de la régularisation automatique
#                   sur une alloc commande de vente
###############################################################################
$CHARGE_PARAM_SO
    If !clalev([SOH]) : Local File SORDER [SOH] : Endif
    If [F:SOH]SOHNUM<>[M:ALP]VCRNUM
        Read [SOH]SOH0=[M:ALP]VCRNUM
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    If !clalev([SOQ]) : Local File SORDERQ [SOQ] : Endif
    If [F:SOQ]SOHNUM<>[M:ALP]VCRNUM | [F:SOQ]SOPLIN<>[M:ALP]VCRLIN | [F:SOQ]SOQSEQ<>[M:ALP]VCRSEQ
        Read [SOQ]SOQ0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    LMODALL = [F:SOQ]ALLTYP
    If [F:SOH]SOHCAT=4
        If !clalev([SOC]) : Local File SORDERC [SOC] : Endif
        If [F:SOC]SOHNUM<>[M:ALP]VCRNUM | [F:SOC]SOPLIN<>[M:ALP]VCRLIN
            Read [SOC]SOC0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
            #--- Bug 72943
            If fstat : LRET=1 : Return : Endif
        Endif
        [M:ALP]PCU       = [F:SOC]SAU
        [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
    Else
        If !clalev([SOP]) : Local File SORDERP [SOP] : Endif
        If [F:SOP]SOHNUM<>[M:ALP]VCRNUM | [F:SOP]SOPLIN<>[M:ALP]VCRLIN | [F:SOP]SOPSEQ<>[M:ALP]VCRSEQ
            Read [SOP]SOP0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ
            #--- Bug 72943
            If fstat : LRET=1 : Return : Endif
        Endif
        [M:ALP]PCU       = [F:SOP]SAU
        [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
    Endif
    # Si commande de prêt
    If [F:SOH]SOHCAT=2
       [M:ALP]TRSTYP = 17
    Else
       [M:ALP]TRSTYP = 4
    Endif
Return

###############################################################################
# CHARGE_PARAM_SD : Effectue le chargement de certains paramètres
#                   avant le lancement de la régularisation automatique
#                   sur une alloc livraison
###############################################################################
$CHARGE_PARAM_SD

    If !clalev([SDH]) : Local File SDELIVERY [SDH] : Endif
    If [F:SDH]SDHNUM<>[M:ALP]VCRNUM
        Read [SDH]SDH0=[M:ALP]VCRNUM
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    If !clalev([SDD]) : Local File SDELIVERYD [SDD] : Endif
    If [F:SDD]SDHNUM<>[M:ALP]VCRNUM | [F:SDD]SDDLIN<>[M:ALP]VCRLIN
        Read [SDD]SDD0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    [M:ALP]PCU       = [F:SDD]SAU
    [M:ALP]PCUSTUCOE = [F:SDD]SAUSTUCOE
    [M:ALP]DLVDAT    = [F:SDH]DLVDAT
    If [M:ALP]TRSTYP=0
       If [F:SDH]LND=2
          [M:ALP]TRSTYP=17
       Elsif [F:SDH]SCO=2
          [M:ALP]TRSTYP=20
       Else
          [M:ALP]TRSTYP=4
       Endif
    Endif
    #--- Bug 63305
    [M:ALP]BPRNUM = [F:SDD]BPCORD

Return

###############################################################################
# CHARGE_PARAM_PR : Effectue le chargement de certains paramètres
#                   avant le lancement de la régularisation automatique
#                   sur une alloc préparation
###############################################################################
$CHARGE_PARAM_PR

    If !clalev([PRH]) : Local File STOPREH [PRH] : Endif
    If [F:PRH]PRHNUM<>[M:ALP]VCRNUM
        Read [PRH]PRH0=[M:ALP]VCRNUM
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    If !clalev([PRE]) : Local File STOPRED [PRE] : Endif
    If [F:PRE]PRHNUM<>[M:ALP]VCRNUM | [F:PRE]PRELIN<>[M:ALP]VCRLIN
        Read [PRE]PRE0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    #--- Issue 117181
    LMODALL = [F:PRE]ALLTYP
		#---
    If [F:PRE]ORITYP=1
       If !clalev([SOH]) : Local File SORDER [SOH] : Endif
       If [F:SOH]SOHNUM<>[F:PRE]ORINUM
           Read [SOH]SOH0=[F:PRE]ORINUM
           #--- Bug 72943
           If fstat : LRET=1 : Return : Endif
       Endif
       If [F:SOH]SOHCAT=4
           If !clalev([SOC]) : Local File SORDERC [SOC] : Endif
           Read [SOC]SOC0=[F:PRE]ORINUM;[F:PRE]ORILIN
           #--- Bug 72943
           If fstat : LRET=1 : Return : Endif
           [M:ALP]PCU       = [F:SOC]SAU
           [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
       Else
           If !clalev([SOP]) : Local File SORDERP [SOP] : Endif
           Read [SOP]SOP0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
           #--- Bug 72943
           If fstat : LRET=1 : Return : Endif
           [M:ALP]PCU       = [F:SOP]SAU
           [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
       Endif
    Elsif [F:PRE]ORITYP=2
       If !clalev([SOP]) : Local File SORDERP [SOP] : Endif
       Read [SOP]SOP0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
       [M:ALP]PCU       = [F:SOP]SAU
       [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
    Endif
    [M:ALP]DLVDAT = [F:PRH]DLVDAT

Return

###############################################################################
# CHARGE_PARAM_SI : Effectue le chargement de certains paramètres
#                   avant le lancement de la régularisation automatique
#                   sur une alloc facture
###############################################################################
$CHARGE_PARAM_SI

    If !clalev([SID]) : Local File SINVOICED [SID] : Endif
    If [F:SID]NUM<>[M:ALP]VCRNUM | [F:SID]SIDLIN<>[M:ALP]VCRLIN
        Read [SID]SID0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
        #--- Bug 72943
        If fstat : LRET=1 : Return : Endif
    Endif
    [M:ALP]PCU       = [F:SID]SAU
    [M:ALP]PCUSTUCOE = [F:SID]SAUSTUCOE
    [M:ALP]DLVDAT    = [F:SID]INVDAT
    #--- Bug 63305
    [M:ALP]BPRNUM    = [F:SID]BPCINV
    If [M:ALP]TRSTYP=0 [M:ALP]TRSTYP=4 Endif
Return

###############################################################################
# CHARGE_PARAM_GP : Effectue le chargement de certains paramètres
#                  avant le lancement de la régularisation automatique
#                  sur une alloc GP
###############################################################################
$CHARGE_PARAM_GP
If !clalev([MFM]) : Local File MFGMAT [MFM] : Endif
If [F:MFM]MFGNUM<>[M:ALP]VCRNUM | [F:MFM]MFGLIN<>[M:ALP]VCRLIN | [F:MFM]BOMSEQ<>[M:ALP]VCRSEQ | [F:MFM]ITMREF <> [M:ALP]ITMREF
    Read [MFM]MFM0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ;[M:ALP]ITMREF
    #--- Bug 72943
    If fstat : LRET=1 : Return : Endif
Endif
Case [F:MFM]ALLSTA
    When 2:    LMODALL = 1
    When 4:    LMODALL = 2
Endcase
If [F:MFM]SCOFLG = 2 & [F:MFM]CPNTYP<5   # Prise en compte emplacements sous-traitants
    [M:ALP]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [F:MFM]BOMOPE <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM & OPENUM=[F:MFM]BOMOPE
&                    Order By Key MFO0
        For [MFO]
            [M:ALP]BPRNUM = [F:MFO]BPRNUM
            [M:ALP]BPAADD = [F:MFO]BPAADD
            If [M:ALP]BPRNUM <> "" : Break : Endif
        Next
        Filter [MFO]
    Endif
Else
    [M:ALP]PECSCOLOC = 1
Endif
[M:ALP]STOLOC    = [F:MFM]LOC
Return

###############################################################################
# CHARGE_PARAM_EO : Effectue le chargement de certains paramètres
#                  avant le lancement de la régularisation automatique
#                  sur une alloc ordre de sous-traitance
###############################################################################
$CHARGE_PARAM_EO
Gosub OPEN_FILES_SCO From SCOLIB
If [F:SCM]SCONUM<>[M:ALP]VCRNUM | [F:SCM]SCILIN<>[M:ALP]VCRLIN | [F:SCM]SCMLIN<>[M:ALP]VCRSEQ | [F:SCM]CPNITMREF <> [M:ALP]ITMREF
   Read [SCM]SCM0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ
   #--- Bug 72943
   If fstat : LRET=1 : Return : Endif
Endif
If [F:SCO]SCONUM<>[M:ALP]VCRNUM
   Read [SCO]SCO0=[M:ALP]VCRNUM
   #--- Bug 72943
   If fstat : LRET=1 : Return : Endif
Endif
If [F:SCI]SCONUM<>[M:ALP]VCRNUM | [F:SCI]SCILIN<>[M:ALP]VCRLIN
   Read [SCI]SCI0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
   #--- Bug 72943
   If fstat : LRET=1 : Return : Endif
Endif
Case [F:SCM]ALLSTA
    When 2:    LMODALL = 1
    When 4:    LMODALL = 2
Endcase
If [F:SCM]SCOFLG = 2 & [F:SCM]CPNTYP<5
   [M:ALP]PECSCOLOC = 2
Endif
[M:ALP]TRSTYP    = 29
[M:ALP]STOLOC    = [F:SCM]LOC
[M:ALP]BPRNUM    = [F:SCO]BPRNUM    : # Mail TS du 11/04/06
[M:ALP]BPAADD    = [F:SCI]BPAADD    : # Mail TS du 11/04/06
Return


###############################################################################
# sr 08.05 demande 31597
# CHARGE_PARAM_TK : Effectue le chargement de certains paramètres
#                  avant le lancement de la régularisation automatique
#                  d'un mouvement en attente sortie OF
###############################################################################
$CHARGE_PARAM_TK
If !clalev([F:MKM]) : Local File MFGMATTRK [MKM] : Endif
If !clalev([F:MFM]) : Local File MFGMAT [MFM]    : Endif
If [F:MKM]MFGTRKNUM<>[M:ALP]VCRNUM | [F:MKM]MATTRKLIN<>[M:ALP]VCRLIN
   Read [MKM]MKM0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
   If fstat : Raz [F:MKM] : LRET=1 : Return : Endif
   Raz [F:MFM]               # hcb 76420
   #--- Bug 83975
   #If [F:MKM]MFGNUM <> ""    # hcb 76420
   If [F:MKM]MFGNUM<>"" & [F:MKM]BOMSEQ<>0
   #---
      # Issue 88931 - 2014-06-06 by CCC : use of [M:ALP] because [F:MKM]MFGLIN can be null
      #Read [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
      Read [F:MFM]MFM0 = [M:ALP]VCRNUMORI;[M:ALP]VCRLINORI;[M:ALP]VCRSEQORI;[F:MKM]ITMREF

      # Issue 88270 - 2018-06-19 by STLIG : Material accumulation - line number = 0 ..
      If (fstat)
        Read [F:MFM]MFM0 = [M:ALP]VCRNUMORI;0;[M:ALP]VCRSEQORI;[F:MKM]ITMREF
        If (fstat)
          Raz [F:MFM]
          LRET = 1
          Return
        Endif
      Endif

      #--- Bug 83975
      [M:ALP]PECSCOLOC=[F:MFM]SCOFLG
   Endif                     # hcb 76420
Endif
#--- Bug 83975
#[M:ALP]PECSCOLOC = [F:MFM]SCOFLG
Return

###############################################################################
# CHARGE_PARAM_SCM : Effectue le chargement de certains paramètres
#                    avant le lancement de la régularisation automatique
#                    sur une sortie matière d'ordre de sous-traitance
###############################################################################
$CHARGE_PARAM_SCM
If !clalev([F:PTH]) : Local File PRECEIPT  [PTH] : Endif
If !clalev([F:PTD]) : Local File PRECEIPTD [PTD] : Endif
If !clalev([F:SCM]) : Local File SCOMAT    [SCM] : Endif

#--- Bug 82751
[M:ALP]PECSCOLOC = 2

If [F:PTH]PTHNUM<>[M:ALP]VCRNUM
    Read [PTH]PTH0=[M:ALP]VCRNUM
    If fstat : Raz [F:PTH] : LRET=1 : Return : Endif
Endif
If [F:PTD]PTHNUM<>[M:ALP]VCRNUM | [F:PTD]PTDLIN<>[M:ALP]VCRLIN
    Read [PTD]PTD0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
    If fstat : Raz [F:PTD] : LRET=1 : Return : Endif
Endif
Return

###############################################################################
# CHARGE_PARAM_SMO : Effectue le chargement de certains paramètres
#                  avant le lancement de la régularisation automatique
#                  sur une sortie diverse
###############################################################################
$CHARGE_PARAM_SMO
If !clalev([F:SMD]) : Local File SMVTD [SMD] : Endif
Read [SMD]SMD0=20;[M:ALP]VCRNUM;[M:ALP]VCRLIN
#--- Bug 72943
If fstat : LRET=1 : Return : Endif
[M:ALP]PCU       = [F:SMD]PCU
[M:ALP]PCUSTUCOE = [F:SMD]PCUSTUCOE
Return

###############################################################################
# CHARGE_PARAM_PRT : Effectue le chargement de certains paramètres
#                    avant le lancement de la régularisation automatique
#                    sur un retour fournisseur
###############################################################################
$CHARGE_PARAM_PRT
If !clalev([PND]) : Local File PRETURND [PND] : Endif
If [F:PND]PNHNUM<>[M:ALP]VCRNUM | [F:PND]PNDLIN<>[M:ALP]VCRLIN
   Read [PND]PND0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
   If fstat : Raz [F:PND] : LRET=1 : Return : Endif
   If [F:PND]LINCAT=2
      [M:ALP]TRSTYP=16
   Else
      [M:ALP]TRSTYP=11
   Endif
Endif

Return

#--- Issue X3-4501
###############################################################################
# CHARGE_PARAM_PJM : Effectue le chargement de certains paramètres
#                    avant le lancement de la régularisation automatique
#                    sur une tache affaire
###############################################################################
$CHARGE_PARAM_PJM

Return
