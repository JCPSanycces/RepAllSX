#<AdxTL>@(#)2.0.0.0 $Revision$
#Infbox "on est dans menu"
# Lignes prĂŠliminaires Ă  toute entrĂŠe dans le debugger
Default Local
[S]adxdpg = "DEBUGGER"   : # Adieu application sys !
[S]adxkpg = "CALCULETTE" : # Adieu application sys !
[S]adxrob(0) = "E"+messname(0) : # On n'a pas encore de langue!!
[S]adxrob(1) = "M"+messname(0)
If dim([S]adxtrp)>0 & dim([S]adxtrl)>0
 If func EXISTE("ATRIFIL")
  [S]adxtrp = "ATRIFIL" : # Traitement appelĂŠ par les Write/Rewrite/Update
  [S]adxtrl = "ATRIOPE" : # Etiquette appelĂŠe par les Write/Rewrite/Update
 Endif
Endif

If adxusr="jc" & 1=0
 [S]dbgstr(132) = "/u/jc/jctra"
 [S]adxmpr = 64
Endif
If find(adxusr,"rvett") & 1=0
 Call _ACTIVE(filpath("!tmp",adxusr,"tra","","",""),1) From ASYRTIMING
Endif
If find(adxusr,"") & 1=0
 Call START(filpath("!tmp",adxusr ,"","","",""),1) From ASYRTIMING
 Infbox  "Start : " + time$
Endif
If find(adxusr,"") & 1=0
 Call _ACTIVE(filpath("!tmp",adxusr,"tra","","",""),1) From ASYRTIMING
Endif
If adxusr="mbeinat" & 1=0
 Openo "/u/mbeinat/menu.log"
 Wrseq "adxtyp="+num$(adxtyp)-"date$="+num$(datetime$)
 Openo
Endif

#-------------------------------------------------------------------------------------------------------------------#
# Pour dĂŠbugger une connexion
#-------------------------------------------------------------------------------------------------------------------#
# Ce nâest pas vraiment un mode âdebugâ moteur mais une trace dâexĂŠcution des traitements.
# Ce mode produit un fichier dans $ADXDIR/tmp/adotra_XXXXX_0.tra ou XXXXX est le no de processus. Elle est produite
# sur le serveur dâapplication. Ce mode trace le dĂŠroulement dâexĂŠcution des traitements ligne Ă  ligne.
# Pour dĂŠmarrer une trace des suivants les cas :
# -Avec un client X3 :
# Lâoption â-w 0TRAITEMENT :SOUS-PROâ
# -Avec un moteur adonix (tache ou un serveur batch)
# Lâoption â-t 0TRAITEMENT :SOUS-PROâ
#
# 0 : symbolise le type de trace. (Pour lâinstant, il nây en a quâun)
# TRAITEMENT et SOUS-PRO peuvent recevoir la valeur â*â
# exemple :
# avec â-w 0GLOBVAR :*â, on trace tous les sous-pro de GLOBVAR
# avec â-w 0* :TOTO on trace les sous-pro TOTO de tout les traitements
# avec â-w 0*.*â ou â-w 0*â, on trace tout !
#
# Exemple de trace :
# 100,Subprog ; @SUPERV.TRT/ZZDS$adx(5)
# 36,Integer ; @SUPERV.TRT/ZZDS$adx(6)
# 255,Assign ; @SUPERV.TRT/ZZDS$adx(8)
# 255,Assign ; @SUPERV.TRT/ZZDS$adx(9)
# 13,End ; @SUPERV.TRT/ZZDS$adx(10)
#-------------------------------------------------------------------------------------------------------------------#

# Trace de dĂŠmarrage requĂŞte
If getenv$("RQT_ENTREP")<>"" & getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG("MENU"-mess(15,134,1),val(getenv$("RQT_ENTREP")),1) From SERVEUR : # Activation requĂŞte
Endif

Call DEFGLOBVAR1 From GLOBVAR
Call INIGLOBVAR1 From GLOBVAR

##############################################
##  DĂŠmarrage en mode "Debugging" (Sophia)  ##
##############################################
Global Integer GTEST
GTEST = val(getenv$("GTEST"))

If GTEST : dbgmode(1) = 1 : Endif

############################################
### Programme de dĂŠmarrage               ###
############################################
Local Char     APPLI(10)
Local Integer  OK , STAT
Local Libelle  BIT(1..96)

If find(adxusr,"cmi")
 #Call MESSAGE("Message affichĂŠ au tout dĂŠbut de la connexion") From GESECRAN
 adxrob(0) = "ECR"
 adxrob(1) = "M"+messname(0)
 #Call TEMPON("test TEMPON cmi - Sleep 2") From GESECRAN : # Installation superviseur
 #Sleep 15
 #Call TEMPOFF From GESECRAN
 #Sleep 4
Endif

## Installation ??
GOK = 1
Call INSTALL From INSTALL
If GOK<1 : Goto RATE : Endif

#### Traitement des tĂ˘ches batch
GPROCED = getenv$("EXEC_ENTREP")
If GPROCED<>""
 GTRACE = GPROCED
 If GPROCED="ACCENTRY" : # TĂ˘che de validation des piĂ¨ces
  GSERVEUR = 11
  GUSER = "ADMIN" : GLOGNAME = "ADMIN"
  Call INIGLOBVAR(STAT) From GLOBVAR
  If !STAT : Goto RATE : Endif
  Call CONNECTSIL From GESUSER
  If GPROCED="" : Goto RATE : Endif
  Call SERIAL(BIT) From ENTREPRISE
  If GPROCED="" : Goto RATE : Endif
  #107269
  If func ASYRSYS.VERSRUN(GACTX,"")>= "19r.101"
   actihgup(0) = "TIMOUT" : # Traitement de dĂŠconnexion sur time out
   actihgup(1) = "FIN"    : # Traitement de dĂŠconnexion volontaire
   actihgup(2) = "FINERR"    : # Traitement des erreurs involontaires
  Else
   Call FLUSH_TRACE From GESECRAN
   Global Char     GTRALIG(250)(1) : # MĂŠmoire trace
  Endif
  ## Pour psadx
  Call SET_CURFCT(GPROCED,1,GLOGIN) From PSADX
  Run ="BATCHCPT"
  Call AUDIT_DECONNECT From GESUSER
  End
 Elsif GPROCED="BATCH" : # Serveur batch
  GSERVEUR = 1
  Local  Integer NUMREQ
  Global Integer GBATCHCPT
  NUMREQ = val(getenv$("RQT_ENTREP"))
  GBATCHRQT = num$([L]NUMREQ) : #109897
  Local File ABATPAR [ABP]
  Read [ABP]SPOOL First
  APPLI = [F:ABP]APPLI
  Close Local File [ABP]
  GTRACE = func SERVSYS.GET_FILE_RQT(format$("N0:8#",NUMREQ),"")  # Issue X3-70499 - 2018-03-05 by CCC : no extension file
  Call RQT_PID("RQT"+format$("N0:8#",NUMREQ)) From SERVSYS
  Openo filpath("TRA",GTRACE,"tra") , -1
  Call INIGLOBVAR(STAT) From GLOBVAR
  If !STAT : Goto RATE : Endif
  Call CONNECTSIL From GESUSER
  If GPROCED="" : Goto RATE : Endif
  #107269
  If func ASYRSYS.VERSRUN(GACTX,"")>= "19r.101"
   actihgup(0) = "TIMOUT" : # Traitement de dĂŠconnexion sur time out
   actihgup(1) = "FIN"    : # Traitement de dĂŠconnexion volontaire
   actihgup(2) = "FINERR"    : # Traitement des erreurs involontaires
  Endif
  Call INIREQ From REQUETES
  If GOK=1 & GTRT<>""
   #107269
   If func ASYRSYS.VERSRUN(GACTX,"")< "19r.101"
    Call FLUSH_TRACE From GESECRAN
    Global Char     GTRALIG(250)(1) : # MĂŠmoire trace
   Endif
   Run =GTRT : # mb 22.10.03 Onerrgo impossible
  Endif
  Call FINREQ From REQUETES
  Call AUDIT_DECONNECT From GESUSER
  End
 Else
  GSERVEUR = 1
  Call INIGLOBVAR(STAT) From GLOBVAR
  If !STAT : Goto RATE : Endif
  Call CONNECTSIL From GESUSER
  If GPROCED="" : Goto RATE : Endif
  Call SERIAL(BIT) From ENTREPRISE
  If GPROCED="" : Goto RATE : Endif
  #107269
  If func ASYRSYS.VERSRUN(GACTX,"")>= "19r.101"
   actihgup(0) = "TIMOUT" : # Traitement de dĂŠconnexion sur time out
   actihgup(1) = "FIN"    : # Traitement de dĂŠconnexion volontaire
   actihgup(2) = "FINERR"    : # Traitement des erreurs involontaires
  Else
   Call FLUSH_TRACE From GESECRAN
   Global Char     GTRALIG(250)(1) : # MĂŠmoire trace
  Endif
  ## Pour psadx
  Call SET_CURFCT(GPROCED,1,GLOGIN) From PSADX
  Run =GPROCED
  #109897
  Call FLUSH_TRACE From GESECRAN
  Call AUDIT_DECONNECT From GESUSER
  End
 Endif
Endif
## A partir d'ici on est en conversationnel (ouf!!)
Call SERIAL(BIT) From ENTREPRISE
Call INIGLOBVAR(STAT) From GLOBVAR
If !STAT : Goto RATE : Endif
If GMENDEP="" : Goto RATE : Endif
If STAT<0 & filinfo(filpath("","nologin","",0),0)>=0
 Call ECR_TRACE(mess(153,100,1)+"\"+mess(153,124,1),1) From GESECRAN
 Goto RATE
Endif

# On continue l'installation du superviseur mĂŞme si l'utilisateur n'est pas habilitĂŠ (mb 21.1.15)

If dim(GFUSION)>0 & GFUSION & filinfo(filpath("","X3","new",0),0)>=0 : # On a chargĂŠ une mise Ă  jour
 GOK = 1
 Call MAJ From MAJX3
 If GOK<1 : Goto RATE : Endif
Endif

GUSER = "ADMIN" : GLOGNAME = "ADMIN"
Call CONNECT From GESUSER
If GMENDEP=""
  If GVTMOD=1 : Infbox(mess(55,127,1)) : Endif : # Menu de connexion VT non renseignĂŠ
  Goto RATE
Endif

#  Initialisation paramĂ¨tres du portail - CC 25/05/2004 (dĂŠplacĂŠ)
If !GSERVEUR
 Call INIPORTAL From INTRUTILA
Endif

Local Integer ETABOU(1..GNBBOU)
Raz ETABOU
For I=1 To GNBBOU
 GETABOU(I) = 2
Next I
Call SETBOUT(ETABOU) From GESECRAN

##################
$REUSSI
Local Char PARAM(GLONAFC)
# mb 21.1.15 La MAJ est dĂŠjĂ  faite en convergence
If (dim(GFUSION)<=0 or !GFUSION) & filinfo(filpath("","X3","new",0),0)>=0 : # On a chargĂŠ une mise Ă  jour
#If filinfo(filpath("","X3","new",0),0)>=0 : # On a chargĂŠ une mise Ă  jour
 Call MAJ From MAJX3
 If GOK<1 : Goto RATE : Endif
Endif
If filinfo(filpath("","histo","",0),0)>=0 : # On est dans le dossier historique
 Call PARAM("","HISMEN",PARAM) From ADOVAL
 If PARAM<>""
  GMENDEP = PARAM
 Else
  GMENDEP = "HISTO"
 Endif
Endif
If GVTMOD
 Call PARAMUTIL("VTMEN",PARAM,GUSER,"") From SUBAUS
 If PARAM<>""
  GMENDEP = PARAM
 Else
  Local File APROFIL [APF]
  Read [APF]APF1(1)="VT" : # Pour ne pas forcer systĂŠmatiquement ce menu
  If !fstat
   GMENDEP = "VT"
  Else
   GMENDEP = ""
  Endif
  Close Local File [APF]
  If GMENDEP="" : Goto RATE : Endif
 Endif
Endif

Global Onevent ITM_MENU Call MENU From EXEFNC

actihgup(0) = "TIMOUT" : # Traitement de dĂŠconnexion sur time out
actihgup(1) = "FIN"    : # Traitement de dĂŠconnexion volontaire
#107269
If func ASYRSYS.VERSRUN(GACTX,"")>= "19r.101"
 actihgup(2) = "FINERR"    : # Traitement des erreurs involontaires
Else
 Call FLUSH_TRACE From GESECRAN
 Global Char     GTRALIG(250)(1) : # MĂŠmoire trace
Endif

# Epuration des rendez-vous Eclipse
If func EXISTE("AECLIRDV") :#AECLIRDV is created by Eclipse
 GBIDC1 = num$(func AECLIRDV.EPURDV(GBIDC2))
Endif

# Pour GĂŠode
Call AFF_ENV

Local Char FONCTION(GLONAFC)
Call UNE_FONCTION(FONCTION) : # Renvoie la seule fonction dont l'utilisateur a le droit
If FONCTION<>""
 Disable GSTAFNC : # DĂŠsactivation du menu Fichier/ExĂŠcuter
 Call EXEFNC(FONCTION,"") From EXEFNC
Elsif GVTMOD
 # Terminaux VT - CC 22/11/2006
 Local Char TIMESP(14)
 Call GETIMSP(GMENDEP,GLANGUE,TIMESP) From INTRUTILA
 If TIMESP="no profil"
  GMENDEP = "" : Goto RATE
 Endif
 Men =GMENDEP+"^"+TIMESP
Else
 Men =GMENDEP
Endif
Goto FIN

###################
$RATE
Goto FIN

###################
$FIN
End

###################
Subprog AFF_ENV
Case GPRODUIT
 When 1
  # GUSER : Site GFCY - DĂŠposant GDEP
  Local Char MESSAGE(80)
  If GFCY<>""
   MESSAGE=mess(101,133,1)-GFCY
  Endif
  If GDEP<>""
   If MESSAGE<>"" : MESSAGE+=" - " : Endif
   MESSAGE+=mess(102,133,1)-GDEP
  Endif
  If GUSER<>""
   If MESSAGE<>"" : MESSAGE=GUSER-":"-MESSAGE
   Else           : MESSAGE=GUSER
   Endif
  Endif
  Inftxt MESSAGE At 1
 When 4
  # GUSER : Budget GBUD - Exercice GEXO
  Local Char MESSAGE(80)
  If GBUD<>""
   MESSAGE=mess(22,114,1)-GBUD
  Endif
  If GEXO<>0
   If MESSAGE<>"" : MESSAGE+=" - " : Endif
   MESSAGE+=mess(23,114,1)-num$(GEXO)
  Endif
  If GUSER<>""
   If MESSAGE<>"" : MESSAGE=GUSER-":"-MESSAGE
   Else           : MESSAGE=GUSER
   Endif
  Endif
  Inftxt MESSAGE At 1
Endcase
End

################################################################
Subprog UNE_FONCTION(FONCTION)
Variable Char FONCTION
Local Integer I
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
FONCTION = ""
Read [AFT]AFT0 = GPROFIL
If [F:AFT]ALLFCT<>2
 Link [AFC] With
& [AFF]AFF0 ~= "";GPROFIL;[F:AFC]CODINT,
& [AFP]AFP0 = GPROFIL;[F:AFC]CODINT;""
& As [AFC_]
& Where [F:AFC]FCYAUZ=2 or [F:AFP]ACS=2
 I = 0
 For [AFC_]
  FONCTION = [F:AFC]CODINT
  I += 1
  If I>1
   FONCTION = "" : Break
  Endif
 Next AFC_
Endif
End

#####################################################
Funprog EXISTE(TRT)
Value Char TRT
Local Integer OKTRT
Call EXISTE_ADX("","",TRT,OKTRT) From ORDSYS
End OKTRT

