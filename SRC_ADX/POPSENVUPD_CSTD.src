#<AdxTL>@(#)0.0.0.0 $Revision$
# Class POPSENVUPD
# This is an interface between Ortems Planner One that is being OEM'd as
# Production Scheduler. It uses a javascript bundle to handle the requests
# from the Planner One service. The Planner One service issues a http get
# request to retrieve data uses the site code and a timestamp. If the
# timestamp is not blank then only those records that have changed since
# the timestamp are read, this is handled in POPSENVUPD_CSTD. The Planner One service also issues a http PUT
# to send updated data which is then used to update the X3 tables which is handled by this
# script as we don't want to read any records as part of the update process because this
# could take a long time and the supervisor can't matcht the records read with the updated
# information. Therefore we have two classes, one for reading and one for updating.
#
# The structure of the data being exchanged uses interface classes in
# collections to represent the JSON required by Planner One. The javascript
# bundle performs a transformation from JSON to the X3 classes and vice
# versa.

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
 Case [L]CURPTH
   When ""
#     Local Instance POPSEVLOG Using C_ALOG
#     POPSEVLOG = NewInstance C_ALOG AllocGroup null
#     Local Integer TRACE
#     Local Integer OK
#     TRACE = 1
#     [L]OK = func STARTLOG(TRACE, POPSEVLOG, "Start_Event", "POPSUPD_"+[L]AEVENT+"_BEGIN")
#     [L]OK = func OUTPUTLOGMSG(TRACE, POPSEVLOG, "Start of processing"-[L]CURPTH-[L]AEVENT)
#     [L]OK = func ENDLOG(TRACE, POPSEVLOG)
#     FreeGroup POPSEVLOG
#     POPSEVLOG=null
     Case [L]AEVENT
       When "AREAD" : Gosub AREAD
       When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_BEFORE
       When "AUPDATE" : Gosub AUPDATE
       When Default
     Endcase
#     POPSEVLOG = NewInstance C_ALOG AllocGroup null
#     [L]OK = func STARTLOG(TRACE, POPSEVLOG, "End_Event", "POPSUPD_"+[L]AEVENT+"_END")
#     [L]OK = func OUTPUTLOGMSG(TRACE, POPSEVLOG, "End of processing")
#     [L]OK = func ENDLOG(TRACE, POPSEVLOG)
#     FreeGroup POPSEVLOG
#     POPSEVLOG = null
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$AREAD
    Local Integer LIN

    this.FCY = [L]FCY

    [L]LIN = fmet this.ADDLINE("RESREP", [V]CST_ALASTPOS)
    If [L]LIN = [V]CST_ANOTDEFINED
    Endif

    [L]LIN = fmet this.ADDLINE("WOREP", [V]CST_ALASTPOS)
    If [L]LIN = [V]CST_ANOTDEFINED
    Endif
Return

$AUPDATE_BEFORE
    Local Integer RESREPCNT
    Local Integer RESCNT
    Local Integer I
    Local Integer R
    Local Integer W
    Local Integer O
    Local Integer OK

    Local Instance POPSLOG Using C_ALOG
    POPSLOG = NewInstance C_ALOG AllocGroup null
    Local Integer LOGINUSE
    Local Integer OK
    Local Integer  ILINE_ER
    Local Integer  ERRLIN
    Local Char ERRMESS(250)
    Local Char ERRCOD(6)

    Local File FACILITY   [FCY]

    # Set logging off, switch to 1 if needed using the parameter
    [L]LOGINUSE = 0
    If func ADP_TOOL.GET_PARAM(this.ACTX.AFOLDER, 3, this.FCY, "PSLOGTRACE") = "YES"
        [L]LOGINUSE = 1
    Endif
    [L]OK = func POPSENV_CSTD.STARTLOG([L]LOGINUSE, POPSLOG, mess(887,197,1), "POPSUPD_UPD_BEF")
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of function")
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "FCY="-this.FCY-"TIMESTAMP="+this.TIMESTAMP)

    # Need to validate the site passed.
    Read [FCY]FCY0 = this.FCY
    If fstat = 0
        this.FCYNAM = [F:FCY]FCYNAM
    Else
        [L]ERRMESS = mess(349,193,1)
        [L]ASTATUS = fmet this.ASETERROR("",mess(349,193,1), [V]CST_AERROR)
        [L]ERRCOD = num$([L]ASTATUS)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Issue with site")

        # Add an error repository
        Gosub ADD_ERROR

        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Stop processing")
        [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

        FreeGroup POPSLOG

        Return
    Endif

    If this.RESREP <> null
        # Update calendar exceptions if there are any
        [L]RESREPCNT = maxtab(this.RESREP)
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Number of resources=" + num$([L]RESREPCNT))
        If ([L]RESREPCNT > 0)
            For [L]I = 1 To [L]RESREPCNT
                # Update resources if any
                [L]RESCNT = maxtab(this.RESREP([L]I).RESOURCES)
                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Number of resources=" + num$([L]RESCNT))
                For [L]R = 1 To [L]RESCNT
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Resources=" + this.RESREP([L]I).RESOURCES([L]R).WST)
                    this.RESREP([L]I).RESOURCES([L]R).WSTFCY = this.FCY
                Next
            Next
        Endif
    Endif

    Local Char MFGNUM(GLONVCR)
    Local Char ITMREF(GLONITM)
    Local Integer WOREPCNT
    Local Integer WOCNT
    Local Integer OPCNT
    [L]WOREPCNT = maxtab(this.WOREP)
    If ([L]WOREPCNT > 0)
         [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Work order")
         [L]I = 1
         If this.WOREP([L]I).WRKORDS <> null
            # Update work orders if any
            [L]WOCNT = maxtab(this.WOREP([L]I).WRKORDS)
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Number of WOs=" + num$([L]WOCNT))
            For [L]W = 1 To [L]WOCNT
                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "WO=" + this.WOREP([L]I).WRKORDS([L]W).MFGNUM)
                [L]OPCNT = maxtab(this.WOREP([L]I).WRKORDS([L]W).OPERS)
                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Number of Operations=" + num$([L]OPCNT))
                For [L]O = 1 To [L]OPCNT
                    # Update operation
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "OP=" + this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM)
                    # X3-22333 - STWIL - Now need to split the work order number from itmref
                    [L]OK = func SPLIT_WO_KEY(this.WOREP([L]I).WRKORDS([L]W).MFGNUM, [L]MFGNUM, [L]ITMREF)
                    this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).MFGNUM = [L]MFGNUM
                    this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).WSTFCY = this.FCY
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Forced placement="+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FORPLA))
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Fixed="+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FIXED))
                Next
            Next
         Endif
    Endif

    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "End of processing")
    [L]OK = func POPSENV_CSTD.ENDLOG([L]LOGINUSE, POPSLOG)
    FreeGroup POPSLOG

Return

$AUPDATE
    Local Instance POPSLOG Using C_ALOG
    POPSLOG = NewInstance C_ALOG AllocGroup null
    Local Integer LOGINUSE
    Local Integer OK
    Local Integer ASTATUS
    Local Char SITE(GLONFCY)
    Local Integer I
    Local Integer R
    Local Integer E
    Local Integer W
    Local Integer O
    Local Integer M
    Local Integer T
    Local Integer LIN
    Local Integer UPDATED
    Local Integer ERROR
    Local Integer IFTRANSOPEN
    Local Integer RESREPCNT
    Local Integer RESCNT
    Local Integer EXCPCNT
    Local Integer MRKCNT
    Local Integer ILINE_ER
    Local Char MESSAGE(100)
    Local Integer  ILINE_ER
    Local Integer  ERRLIN
    Local Char ERRMESS(250)
    Local Char ERRCOD(6)
    Local Char LOGNAME(30)
    Local Char LOGTIME(30)

    # Set logging off, switch to 1 if needed using the parameter
    [L]LOGINUSE = 0
    If func ADP_TOOL.GET_PARAM(this.ACTX.AFOLDER, 3, this.FCY, "PSLOGTRACE") = "YES"
        [L]LOGINUSE = 1
    Endif

    [L]LOGTIME = time$
    [L]LOGNAME = "POPSUPD"+this.FCY+left$([L]LOGTIME, 2)+mid$([L]LOGTIME, 4, 2)+right$([L]LOGTIME, 7)
    [L]OK = func STARTLOG([L]LOGINUSE, POPSLOG, mess(887,197,1) + " - AUPD", [L]LOGNAME)
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of function")
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "FCY="-this.FCY-"TIMESTAMP="+this.TIMESTAMP)

    If this.snapshot = null
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Snapshot null")
    Else
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Snapshot not null")
    Endif

    Local File MFGHEAD [MFG]
    Local File POPSCALEXP [CEP]
    Local File POPSTAG [TAG]
    Local File POPSMRK [MRK]
    Local File POPSPIN [PIN]
    Local File MFGITM [MFI]
    Local File MFGOPE [MFO]
    Local File OPERATIONS [OPS]
    Local File SCHEDULING [SCH]
    Local File ORDERS [ORD]
    Local File STOALL [STA]
    Local File MFGMAT [MFM]
    Local File WORKSTATIO [MWS]

    [L]IFTRANSOPEN = adxlog

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "adxlog="-num$(adxlog))

    If [L]IFTRANSOPEN = 0
        Trbegin MFGHEAD, POPSCALEXP, POPSTAG, POPSMRK, POPSPIN, MFGITM, MFGOPE, OPERATIONS, SCHEDULING
    Endif

    If this.RESREP <> null #& this.RESREP.modified = 1
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Resrep modified")
    # Update calendar exceptions if there are any
    [L]RESREPCNT = maxtab(this.RESREP)
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of calendar exceptions num="+num$([L]RESREPCNT))
    If ([L]RESREPCNT > 0)
        For [L]I = 1 To [L]RESREPCNT
            # Update resources if any
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Count resources")
            [L]RESCNT = maxtab(this.RESREP([L]I).RESOURCES)
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of calendar exceptions res="+num$([L]RESCNT))
            For [L]R = 1 To [L]RESCNT
                [L]EXCPCNT = maxtab(this.RESREP([L]I).RESOURCES([L]R).CALEXPS)
                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of calendar exceptions exp="+num$([L]EXCPCNT))
                For [L]E = 1 To [L]EXCPCNT
                    # Update calendar exception
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "calendar exceptions start="+num$(this.RESREP([L]I).RESOURCES([L]R).CALEXPS([L]E).STRDAT))
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "calendar exceptions end="+num$(this.RESREP([L]I).RESOURCES([L]R).CALEXPS([L]E).ENDDAT))
                    [L]ASTATUS = func POPSENVUPD_CSTD.UPDATEEXP(this.RESREP([L]I).RESOURCES([L]R).CALEXPS([L]E), this.RESREP([L]I).RESOURCES([L]R).WST, this.FCY, [L]MESSAGE, this.ACTX.USER)
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "After Call update calendar exceptions res=" + this.RESREP([L]I).RESOURCES([L]R).WST)
                    If ([L]ASTATUS <> [V]CST_AOK)
                        # There has been an error. Rollback and break.
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Update exceptions failed err="+num$([L]ASTATUS))
                        [L]ERRMESS = mess(358,193,1) - this.RESREP([L]I).RESOURCES([L]R).WST - [L]MESSAGE
                        [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                        [L]ERRCOD = num$([L]ASTATUS)
                        If [L]IFTRANSOPEN = 0
                            Rollback
                        Endif
                        [L]UPDATED = 0
                        [L]ERROR = 1
                        Break 3
                    Endif
                    [L]UPDATED = 1
                Next
            Next
        Next
    Endif
    # There has been an error, might as well end.
    If ([L]ERROR = 1)
        Gosub ADD_ERROR
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "There has been an issue")
        [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)
        FreeGroup POPSLOG
        Return
    Endif
    Else
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Resrep not modified")
    Endif

    Local Date STRDAT
    Local Date ENDDAT
    Local Date OPSTRDAT
    Local Date OPENDDAT
    Local Date PRPSTRDAT
    Local Date WAIENDDAT
    Local Datetime OPSTRDATTIM
    Local Datetime OPENDDATTIM
    Local Datetime PRPSTRDATTIM
    Local Datetime WAIENDDATTIM
    Local Integer OPUPDATED
    Local Integer WOREPCNT
    Local Integer WOCNT
    Local Integer OPCNT
    Local Integer TAGCNT
    Local Char MFGNUM(GLONVCR)
    Local Char ITMREF(GLONITM)
    Local Char DEFDIH(GLONDIH)
    Local Integer OPENUM
    Local Integer OPESPLNUM
    Local Integer WO
    Local Integer UNPUBLISHED

    # X3-29632 - STWIL - Timezone class to convert UTC times to local
    Local Instance TIMEZONE Using C_TIMEZONE
    TIMEZONE = NewInstance C_TIMEZONE AllocGroup null

    Local Datetime LOCFIXDATTIM
    Local Datetime LOCSTRDATTIM
    Local Datetime LOCENDDATTIM
    Local Datetime LOCOPESTRDATTIM
    Local Datetime LOCOPEENDDATTIM

    ASTATUS = fmet TIMEZONE.INITIALIZE(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.FCY, "PSTIMEZONE"), "")
    If ASTATUS <> [V]CST_AOK
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Issue with timezone")
    Endif

    # X3-29634 - STWIL - Get the default time schema, used to calculate the fraction of a day
    [L]DEFDIH = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.FCY, "DEFDIH")
    [L]OPSTRDAT = AVOID.ADATE
    [L]OPENDDAT = AVOID.ADATE
    [L]PRPSTRDAT = AVOID.ADATE
    [L]WAIENDDAT = AVOID.ADATE
    [L]OPSTRDATTIM = AVOID.ADATTIM
    [L]OPENDDATTIM = AVOID.ADATTIM
    [L]PRPSTRDATTIM = AVOID.ADATTIM
    [L]WAIENDDATTIM = AVOID.ADATTIM
    [L]OPUPDATED = 0
    [L]WOREPCNT = maxtab(this.WOREP)
    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations update woreps="+num$([L]WOREPCNT))
    If ([L]WOREPCNT > 0)
         [L]I = 1
#        For I = 1 To WOREPCNT
         [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "WRKORDS test")
#         If this.WOREP([L]I).WRKORDS <> null
            # Update work orders if any
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "WOCNT setting")
            [L]WOCNT = maxtab(this.WOREP([L]I).WRKORDS)
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations update wos="+num$([L]WOCNT))
            For [L]W = 1 To [L]WOCNT
                # Update operations if any
                [L]OPUPDATED = 0
                [L]UNPUBLISHED = 0
                # X3-22333 - STWIL - Now need to split the work order number from itmref
                [L]OK = func SPLIT_WO_KEY(this.WOREP([L]I).WRKORDS([L]W).MFGNUM, [L]MFGNUM, [L]ITMREF)

                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Check Work order or suggestion mfgnum="+[L]MFGNUM)
                [L]WO = func POPSENVUPD_CSTD.WO_OR_SUGGESTION([L]MFGNUM, [L]ITMREF)
                # If not a WO or Suggestion the throw an error
                If [L]WO = 0
                    # There has been an error. Rollback and break.
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Work order error mfgnum="+this.WOREP([L]I).WRKORDS([L]W).MFGNUM)
                    [L]ERRMESS = mess(151,193,1) - this.WOREP([L]I).WRKORDS([L]W).MFGNUM
                    [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                    [L]ERRCOD = num$([V]CST_AERROR)
                    If [L]IFTRANSOPEN = 0
                        Rollback
                    Endif
                    [L]UPDATED = 0
                    [L]ERROR = 1
                    Break
                Endif
                this.WOREP([L]I).WRKORDS([L]W).ITMREF = [L]ITMREF
                [L]OPCNT = maxtab(this.WOREP([L]I).WRKORDS([L]W).OPERS)
                [L]STRDAT = [31/12/9999]
                [L]ENDDAT = AVOID.ADATE
                [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations update ops="+num$([L]OPCNT))
                For [L]O = 1 To [L]OPCNT
                    # Update operation
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations update wo="+[L]MFGNUM)
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations update res="+this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).CPLWST)
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation wo+op="+[L]MFGNUM+";"+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).
& OPENUM))

                    # X3-22333 - STWIL - Now need to split the work order operation number from itmref
                    [L]OK = func SPLIT_OP_KEY(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM, [L]OPENUM, [L]OPESPLNUM)
#                    [L]OK = func SPLIT_OP_KEY_ALL(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM, [L]MFGNUM, [L]ITMREF, [L]OPENUM, [L]OPESPLNUM)

                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start of operations openum opesplnum="+num$([L]OPENUM) - num$([L]OPESPLNUM))
                    If (this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).STRDATTIM <> AVOID.ADATTIM)
                        # X3-29632 - STWIL - Use timezone class to convert UTC times to local
                        ASTATUS = fmet TIMEZONE.TO_LOCAL_TIME(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).STRDATTIM, [L]LOCSTRDATTIM)
                        #[L]LOCSTRDATTIM = this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).STRDATTIM

                        [L]PRPSTRDAT = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_DATE([L]LOCSTRDATTIM)
                        [L]PRPSTRDATTIM = [L]LOCSTRDATTIM
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Preperation start date="+num$([L]PRPSTRDAT))
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Preperation start datetime="+num$([L]PRPSTRDATTIM))
                    Else
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "no preperation start date="+num$([L]PRPSTRDATTIM))
                    Endif
                    If (this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).ENDDATTIM <> AVOID.ADATTIM)
                        # X3-29632 - STWIL - Use timezone class to convert UTC times to local
                        ASTATUS = fmet TIMEZONE.TO_LOCAL_TIME(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).ENDDATTIM, [L]LOCENDDATTIM)
                        #[L]LOCENDDATTIM = this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).ENDDATTIM
                        [L]WAIENDDAT = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_DATE([L]LOCENDDATTIM)
                        [L]WAIENDDATTIM = [L]LOCENDDATTIM
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Post-op end date="+num$([L]WAIENDDAT))
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Post-op end datetime="+num$([L]WAIENDDATTIM))
                    Endif

                    # X3-56795 - STWIL - Use new operation start and end times from Production Scheduler
                    If (this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).STROPEDT <> AVOID.ADATTIM)
                        # X3-29632 - STWIL - Use timezone class to convert UTC times to local
                        ASTATUS = fmet TIMEZONE.TO_LOCAL_TIME(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).STROPEDT, [L]LOCOPESTRDATTIM)
                        [L]OPSTRDAT = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_DATE([L]LOCOPESTRDATTIM)
                        [L]OPSTRDATTIM = [L]LOCOPESTRDATTIM

                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation start datetime="+num$([L]LOCOPESTRDATTIM))
                    Else
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "no operation start date="+num$([L]LOCOPESTRDATTIM))
                    Endif
                    If (this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).ENDOPEDT <> AVOID.ADATTIM)
                        # X3-29632 - STWIL - Use timezone class to convert UTC times to local
                        ASTATUS = fmet TIMEZONE.TO_LOCAL_TIME(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).ENDOPEDT, [L]LOCOPEENDDATTIM)
                        [L]OPENDDAT = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_DATE([L]LOCOPEENDDATTIM)
                        [L]OPENDDATTIM = [L]LOCOPEENDDATTIM

                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation end datetime="+num$([L]LOCOPEENDDATTIM))
                    Else
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "no operation end date="+num$([L]LOCOPEENDDATTIM))
                    Endif
                    # Issue x3-29698 - 2017-04-04 by CCC : Record fixed date only if a pin exists
                    #    except if PINTYP=4 because in this case it corresponds to subcontracting order and there is no forced date
                    If (this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FIXDAT <> AVOID.ADATTIM)
&                    & find(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).PINTYP,1,2,3)>0
                        # X3-29632 - STWIL - Use timezone class to convert UTC times to local
                        ASTATUS = fmet TIMEZONE.TO_LOCAL_TIME(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FIXDAT, [L]LOCFIXDATTIM)
                        #[L]LOCFIXDATTIM = this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FIXDAT
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation fixed datetime="+num$([L]LOCFIXDATTIM))
                    Else
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "PINTYP="+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).PINTYP)-"fixdat="+num$(this.WOREP([L]I).WRKORDS([L]W).
& OPERS([L]O).FIXDAT))
                        Raz this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FIXDAT
                    Endif

                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation sequence order="+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).SEQORD))
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation forced placement="+num$(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).FORPLA))
                    # If the resource is blank don't update status
                    If  this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).CPLWST = ""
                        [L]UNPUBLISHED = 1
                    Endif
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation update MFGNUM="+[L]MFGNUM)
                    [L]ASTATUS = func POPSENVUPD_CSTD.UPDATEOP(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O), this.FCY, [L]OPENUM, [L]OPESPLNUM, [L]MFGNUM, [L]PRPSTRDAT, [L]PRPSTRDATTIM,
&                   [L]OPSTRDAT, [L]OPSTRDATTIM, [L]OPENDDAT, [L]OPENDDATTIM, [L]WAIENDDAT, [L]WAIENDDATTIM, [L]WO, [L]MESSAGE, this.ACTX.USER, [L]DEFDIH, [L]LOCFIXDATTIM, [L]LOGINUSE)
                    If ([L]ASTATUS <> [V]CST_AOK)
                        # There has been an error. Rollback and break.
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operations update failed opnum="+this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM - num$(fstat))
                        [L]ERRMESS = mess(359,193,1) - this.WOREP([L]I).WRKORDS([L]W).MFGNUM - this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM - [L]MESSAGE
                        [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                        [L]ERRCOD = num$([L]ASTATUS)
                        If [L]IFTRANSOPEN = 0
                            Rollback
                        Endif
                        [L]UPDATED = 0
                        [L]ERROR = 1
                        Break 2
                    Endif
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation update finished MFGNUM="+[L]MFGNUM)
                    [L]ASTATUS = func POPSENVUPD_CSTD.UPDATEPIN(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O), [L]OPENUM, [L]OPESPLNUM, [L]MFGNUM, [L]MESSAGE, this.ACTX.USER)
                    If ([L]ASTATUS <> [V]CST_AOK)
                        # There has been an error. Rollback and break.
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operations pin type update failed opnum="+this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM - num$(
& fstat))
                        [L]ERRMESS = mess(360,193,1) - this.WOREP([L]I).WRKORDS([L]W).MFGNUM - this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM - [L]MESSAGE
                        [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                        [L]ERRCOD = num$([L]ASTATUS)
                        If [L]IFTRANSOPEN = 0
                            Rollback
                        Endif
                        [L]UPDATED = 0
                        [L]ERROR = 1
                        Break 2
                    Endif
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation pin update finished MFGNUM="+[L]MFGNUM)
                    If ([L]PRPSTRDAT < [L]STRDAT)
                        [L]STRDAT = [L]PRPSTRDAT
                    Endif
                    If ([L]WAIENDDAT > [L]ENDDAT)
                        [L]ENDDAT = [L]WAIENDDAT
                    Endif
                    [L]UPDATED = 1
                    [L]OPUPDATED = 1

                    # Update any markers added to the operation
                    [L]MRKCNT = maxtab(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).MARKERS)
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operations markers update mrks="+num$([L]MRKCNT))
                    For [L]M = 1 To [L]MRKCNT
                        [L]ASTATUS = func POPSENVUPD_CSTD.UPDATEMRK(this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).MARKERS([L]M), [L]MFGNUM, [L]OPENUM, [L]MESSAGE, this.ACTX.USER)
                        If ([L]ASTATUS <> [V]CST_AOK)
                            # There has been an error. Rollback and break.
                            If [L]IFTRANSOPEN = 0
                                Rollback
                            Endif
                            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Update markers failed err="+num$([L]ASTATUS))
                            [L]ERRMESS = mess(361,193,1) - this.WOREP([L]I).WRKORDS([L]W).MFGNUM - this.WOREP([L]I).WRKORDS([L]W).OPERS([L]O).OPENUM - [L]MESSAGE
                            [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                            [L]ERRCOD = num$([L]ASTATUS)
                            [L]UPDATED = 0
                            [L]ERROR = 1
                            Break 3
                        Endif
                        [L]UPDATED = 1
                    Next
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Operation markers update finished MFGNUM="+[L]MFGNUM)
                Next
                # Update work order if any operations have been updated
                If ([L]OPUPDATED)
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Update WO header")
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "start date="+num$([L]STRDAT)-"End date="+num$([L]ENDDAT))
                    [L]ASTATUS = func POPSENVUPD_CSTD.UPDATEWO([L]MFGNUM, [L]ITMREF, [L]STRDAT, [L]ENDDAT, [L]WO, [L]UNPUBLISHED, [L]MESSAGE, this.ACTX.USER, [L]LOGINUSE)
                    If ([L]ASTATUS <> [V]CST_AOK)
                        # There has been an error. Rollback and break.
                        If [L]IFTRANSOPEN = 0
                            Rollback
                        Endif
                        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Update work orders failed err="+num$([L]ASTATUS))
                        [L]ERRMESS = mess(362,193,1) - this.WOREP([L]I).WRKORDS([L]W).MFGNUM - [L]MESSAGE
                        [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                        [L]ERRCOD = num$([L]ASTATUS)
                        [L]UPDATED = 0
                        [L]ERROR = 1
                        Break 1
                    Endif
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "After Update WO header")
                    [L]UPDATED = 1
                Endif
            Next
#        Endif
        # Don't try and update tags if there has been an error.
        If [L]ERROR = 0
            [L]TAGCNT = maxtab(this.WOREP([L]I).TAGS)
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Tags update tags="+num$([L]TAGCNT))
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Tags modified")
            # Update any tags that have been created.
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Tags update tags="+num$([L]TAGCNT))
            For [L]T = 1 To [L]TAGCNT
                [L]ASTATUS = func POPSENVUPD_CSTD.UPDATETAG(this.WOREP([L]I).TAGS([L]T), [L]MESSAGE, this.ACTX.USER)
                If ([L]ASTATUS <> [V]CST_AOK)
                    # There has been an error. Rollback and break.
                    If [L]IFTRANSOPEN = 0
                        Rollback
                    Endif
                    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Update tags failed err="+[L]MESSAGE+num$([L]ASTATUS))
                    [L]ERRMESS = mess(362,193,1) - this.WOREP([L]I).TAGS([L]T).TAGID - [L]MESSAGE
                    [L]ASTATUS = fmet this.ASETERROR ("", [L]ERRMESS, [V]CST_AERROR)
                    [L]ERRCOD = num$([L]ASTATUS)
                    [L]UPDATED = 0
                    [L]ERROR = 1
                    Break 1
                Endif
                [L]UPDATED = 1
            Next
        Endif
#        Next
    Endif

    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Set error or commit")
    # If we have updated a record and there hasn't been an error commit the transaction
    If [L]UPDATED = 0 & [L]ERROR = 0
        If [L]IFTRANSOPEN = 0
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Nothing updated transaction committed")
            Commit
        Endif
    Elsif [L]ASTATUS = [V]CST_AOK
        [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Records updated OK")
        If [L]IFTRANSOPEN = 0
            [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
            Commit
        Endif
    Elsif ([L]ASTATUS <> [V]CST_AOK)
        # There has been an error we need to send an error repository
        # We have already done a rollback so need to do it again
        Gosub ADD_ERROR
    Endif

    [L]OK = func POPSENV_CSTD.OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "End of processing")
    [L]OK = func POPSENV_CSTD.ENDLOG([L]LOGINUSE, POPSLOG)

    FreeGroup TIMEZONE
    FreeGroup POPSLOG

Return

$ADD_ERROR
    # Add an error repository if this is the first error.
    If this.ERRREP = null
        [L]ERRLIN = fmet this.ADDLINE("ERRREP", [V]CST_ALASTPOS)
    Endif
    If [L]ERRLIN <> [V]CST_ANOTDEFINED
        [L]ILINE_ER = fmet this.ERRREP([L]ERRLIN).ADDLINE("ERRORS", [V]CST_ALASTPOS)
        If [L]ILINE_ER <> [V]CST_ANOTDEFINED
            this.ERRREP([L]ERRLIN).ERRORS([L]ILINE_ER).ERRCOD = [L]ERRCOD
            this.ERRREP([L]ERRLIN).ERRORS([L]ILINE_ER).ERRMES = [L]ERRMESS
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Error message -" - [L]ERRMESS)
        Endif
    Endif
Return

#**----------------------------------------------------------------<br/>
#* UPDATEEXP : Update calendar exceptions entered in Production Scheduler to table POPSCALEXP
#**<br/>----------------------------------------------------------------<br/>
#* @param CALEXP - C_POPSCALEXP = Calender exception class
#* @param WST - Char = Code of the parameter
#* @param FCY - Char = Site
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEEXP(CALEXP, WST, FCY, MESSAGE, USER)
    Variable Instance CALEXP Using C_POPSCALEXP
    Variable Char WST
    Variable Char FCY
    Variable Char MESSAGE()
    Value Char USER()

    Local Integer ASTATUS
    Local Integer STAT
    Local Char MESSAGE(100)

    Readlock [F:CEP]CEP0 = FCY;WST;CALEXP.STRDAT;CALEXP.ENDDAT
    If fstat = [V]CST_AOK | fstat = [V]CST_ANOREC
        [F:CEP]OPENED = CALEXP.OPENED
        [F:CEP]COMMENT = CALEXP.COMMENT
        [F:CEP]EDITABLE = CALEXP.EDITABLE
        If fstat = [V]CST_AOK
            [F:CEP]UPDDATTIM = datetime$
            [F:CEP]UPDUSR = USER
            Rewrite [F:CEP]
        Else
            [F:CEP]WSTFCY = FCY
            [F:CEP]WST = WST
            [F:CEP]STRDAT = CALEXP.STRDAT
            [F:CEP]ENDDAT = CALEXP.ENDDAT
            [F:CEP]CREDATTIM = datetime$
            [F:CEP]CREUSR = USER
            [F:CEP]AUUID = getUuid
            Write [F:CEP]
        Endif
    Endif

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* UPDATETAG : Update tag entered in Production Scheduler to table POPSTAG
#**<br/>----------------------------------------------------------------<br/>
#* @param TAG - C_POPSTAG = Production Scheduler Tag class
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATETAG(TAG, MESSAGE, USER)
    Variable Instance TAG Using C_POPSTAG
    Variable Char MESSAGE()
    Value Char USER()

    Local Integer ASTATUS
    Local Integer STAT

    Read [TAG]TAG0 = TAG.TAGID
    If fstat = [V]CST_AOK | fstat = [V]CST_ANOREC
        [F:TAG]TAGICON = TAG.TAGICON
        [F:TAG]TAGORD = TAG.TAGORD
        [F:TAG]DELETED = TAG.DELETED
        If fstat = [V]CST_AOK
            Readlock [TAG]TAG0 = TAG.TAGID
            If fstat = [V]CST_AOK
                [F:TAG]UPDDATTIM = datetime$
                [F:TAG]UPDUSR = USER
                Rewrite [F:TAG]
            Endif
            Unlock [TAG]
        Else
            [F:TAG]TAGID = TAG.TAGID
            [F:TAG]CREDATTIM = datetime$
            [F:TAG]CREUSR = USER
            [F:TAG]AUUID = getUuid
            Write [F:TAG]
        Endif
    Endif

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* UPDATEMRK : Update markers entered in Production Scheduler to table POPSMRK
#**<br/>----------------------------------------------------------------<br/>
#* @param MARKER - C_POPSMARKER = Production Scheduler marker class
#* @param MFGNUM - Char = Work order / Suggestion number
#* @param OPENUM - Char = Operation number
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEMRK(MARKER, MFGNUM, OPENUM, MESSAGE, USER)
    Variable Instance MARKER Using C_POPSMARKER
    Variable Char MFGNUM
    Variable Integer OPENUM
    Variable Char MESSAGE()
    Value Char USER()

    Local Integer ASTATUS
    Local Integer STAT

    Readlock [MRK]MRK0 = MFGNUM;OPENUM;MARKER.MRKID
    If fstat = [V]CST_AOK | fstat = [V]CST_ANOREC
        [F:MRK]MRKID = MARKER.MRKID
        [F:MRK]COMMENT = MARKER.COMMENT
        If fstat = [V]CST_AOK
            [F:MRK]UPDDATTIM = datetime$
            [F:MRK]UPDUSR = USER
            Rewrite [F:MRK]
        Else
            [F:MRK]MFGNUM = MFGNUM
            [F:MRK]OPENUM = OPENUM
            [F:MRK]MRKID = MARKER.MRKID
            [F:MRK]CREDATTIM = datetime$
            [F:MRK]CREUSR = USER
            [F:MRK]AUUID = getUuid
            Write [F:MRK]
        Endif
    Endif
    Unlock [MRK]

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* UPDATEPIN : Update pinned status entered in Production Scheduler to table POPSPIN
#**<br/>----------------------------------------------------------------<br/>
#* @param OPER - C_POPSOPER = Operation class
#* @param OPENUM - Integer = Operation number
#* @param OPESPLNUM - Integer = Operation split number
#* @param MFGNUM - Char = Work order / Suggestion number
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEPIN(OPER, OPENUM, OPESPLNUM, MFGNUM, MESSAGE, USER)
    Variable Instance OPER Using C_POPSOPER
    Variable Integer OPENUM
    Variable Integer OPESPLNUM
    Variable Char MFGNUM
    Variable Char MESSAGE()
    Value Char USER()

    Local Integer ASTATUS
    Local Integer STAT

    # Decode the openum and opesplnum
    # X3-22333 - STWIL - Don't need to do this anymore
    #OPENUM = val(left$(OPER.OPENUM, 5))
    #OPESPLNUM = val(right$(OPER.OPENUM, 7))

    Readlock [PIN]PIN0 = MFGNUM;OPENUM;OPESPLNUM
    If fstat = [V]CST_AOK | fstat = [V]CST_ANOREC
        [F:PIN]PINTYP = OPER.PINTYP
        If fstat = [V]CST_AOK
            [F:PIN]UPDDATTIM = datetime$
            [F:PIN]UPDUSR = USER
            Rewrite [F:PIN]
        Else
            [F:PIN]MFGNUM = MFGNUM
            [F:PIN]OPENUM = OPENUM
            [F:PIN]OPESPLNUM = OPESPLNUM
            [F:PIN]CREDATTIM = datetime$
            [F:PIN]CREUSR = USER
            [F:PIN]AUUID = getUuid
            Write [F:PIN]
        Endif
    Endif

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* UPDATEWO : Update work order table or suggestions table
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order / Suggestion number
#* @param ITMREF - Char = Item code
#* @param STRDAT - Date = Start date of the work order / suggestion
#* @param ENDDAT - Date = End date of the work order / suggestion
#* @param WO - Integer = 1 if work order, 2 if suggestion
#* @param UNPUBLISHED - Integer = 1 if any operations have not been scheduled
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEWO(MFGNUM, ITMREF, STRDAT, ENDDAT, WO, UNPUBLISHED, MESSAGE, USER, LOGINUSE)
    Variable Char MFGNUM()
    Variable Char ITMREF()
    Variable Date STRDAT
    Variable Date ENDDAT
    Variable Integer WO
    Variable Integer UNPUBLISHED
    Variable Char MESSAGE()
    Value Char USER()
    Value Integer LOGINUSE

    Local Integer ASTATUS
    Local Integer STAT
    Local Integer OK
    Local Date LSTRDAT
    Local Date LENDDAT
    Local Char LITMREF(GLONITM)

    Local Char LOGNAME(20)
    Local Instance UPDWOLOG Using C_ALOG
    UPDWOLOG = NewInstance C_ALOG AllocGroup null

    [L]LOGNAME = left$(MFGNUM,20)
#    [L]LOGNAME = "POPSENVUPD_UPDATEWO"
    [L]OK = func STARTLOG ([L]LOGINUSE, UPDWOLOG, mess(887,197,1)+" - UPDWO", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWOLOG, "Start update WO (POPSENVUPD_CSTD.UPDATEWO)")

    [L]LSTRDAT = STRDAT
    [L]LENDDAT = ENDDAT
    [L]LITMREF = ITMREF

    # Issue X3-22304 - 2017-08-09 by ALSHE : update fields after publish
    # update work orders plan or firm
    If WO = 1
        # Update MFGHEAD, MFGITM
        Readlock [MFG]MFG0 = MFGNUM
        If fstat = [V]CST_AOK
            [F:MFG]UPDDAT = date$
            [F:MFG]UPDDATTIM = datetime$
            [F:MFG]UPDUSR = USER
            [F:MFG]STRDAT = STRDAT
            [F:MFG]ENDDAT = ENDDAT
            [F:MFG]CLCSCDLTI = ENDDAT - STRDAT
            # Only update the status if all operations have resources
            If UNPUBLISHED = 0
                [F:MFG]SCDFLG = 4
                [F:MFG]OPTFLG = 1
            Endif
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update MFGHEAD: MFGNUM ="-[F:MFG]MFGNUM-"STRDAT: "-[F:MFG]STRDAT-"ENDDAT: "-[F:MFG]ENDDAT)
            Rewrite [F:MFG]
        Endif
        Unlock [F:MFG]

        If fstat = [V]CST_AOK
            For [MFM] Where MFGNUM = [F:MFG]MFGNUM With Lock
                If [F:MFM]BOMOPE <> 0
                    Read [MFO]MFO0 = MFGNUM;[F:MFM]BOMOPE;0
                    [F:MFM]RETDAT = [F:MFO]OPESTR
                Else
                    [F:MFM]RETDAT = STRDAT + [F:MFM]BOMOFS
                Endif
                [F:MFM]UPDDAT = date$
                [F:MFM]UPDDATTIM = datetime$
                [F:MFM]UPDUSR = USER
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update MFGMAT: "-[F:MFM]MFGNUM-[F:MFM]ITMREF-"RETDAT ="-[F:MFM]RETDAT)
                Rewrite [MFM]

                # update MFGMAT and ORDERS
                If fstat = [V]CST_AOK
                    Update [ORD] Where WIPNUM = [F:MFM]WIPNUM & WIPTYP = 6 & ITMREF = [F:MFM]ITMREF
&                                With  STRDAT = [F:MFM]RETDAT,
&                                      ENDDAT = [F:MFM]RETDAT,
&                                      UPDDAT = date$,
&                                      UPDDATTIM = datetime$,
&                                      UPDUSR = USER
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update ORDDERS-MFM: "-[F:MFM]MFGNUM-[F:MFM]WIPNUM-[F:MFM]ITMREF)
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "STRDAT: "-[F:MFM]RETDAT-"ENDDAT: "-[F:MFM]RETDAT)

                    Update [STA] Where VCRTYP = 10 & VCRNUM = [F:MFM]MFGNUM &
&                                      VCRLIN = [F:MFM]MFGLIN & VCRSEQ = [F:MFM]BOMSEQ &
&                                      ITMREF = [F:MFM]ITMREF
&                                With  BESDAT = [F:MFM]RETDAT,
&                                      UPDDAT = date$,
&                                      UPDDATTIM = datetime$,
&                                      UPDUSR = USER
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update STOALL: "-[F:STA]VCRNUM-"BESDAT ="-[F:MFM]RETDAT)
                Endif
                If fstat : Break : Endif
            Next

            # update MFGITM and ORDERS
            If fstat = [V]CST_AOK
                For [MFI] Where MFGNUM = [F:MFG]MFGNUM & ITMSTA<3 With Lock
                    If [F:MFI]ITMSTA = 1 : [F:MFI]STRDAT = STRDAT : Endif
                    [F:MFI]ENDDAT = ENDDAT
                    [F:MFI]UPDDAT = date$
                    [F:MFI]UPDDATTIM = datetime$
                    [F:MFI]UPDUSR = USER
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update MGITM: "-[F:MFI]MFGNUM)
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "STRDAT: "-[F:MFI]STRDAT-"ENDDAT: "-[F:MFI]ENDDAT)
                    Rewrite [MFI]

                    If fstat = [V]CST_AOK
                        Update [ORD] Where WIPNUM=[F:MFI]WIPNUM & WIPTYP = 5 & ITMREF = [F:MFI]ITMREF
&                                    With  STRDAT = [L]LSTRDAT,
&                                          ENDDAT = [L]LENDDAT,
&                                          UPDDAT = date$,
&                                          UPDDATTIM = datetime$,
&                                          UPDUSR = USER
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update ORDERS-MFI: "-[F:MFI]MFGNUM-[F:MFI]WIPNUM-[F:MFI]ITMREF)
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "STRDAT: "-[L]LSTRDAT-"ENDDAT: "-[L]LENDDAT)
                    Endif
                    If fstat : Break : Endif
                Next
            Endif
        Endif

    # update work order suggestions
    Elsif WO = 2
        # update product
        Update [ORD] Where WIPNUM=MFGNUM & WIPTYP = 5 & ITMREF = [L]LITMREF
&                    With  STRDAT = [L]LSTRDAT,
&                          ENDDAT = [L]LENDDAT,
&                          UPDDAT = date$,
&                          UPDDATTIM = datetime$,
&                          UPDUSR = USER
        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update ORDERS-SUG-Prod: "-MFGNUM-[L]LITMREF)
        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "STRDAT: "-[L]LSTRDAT-"ENDDAT: "-[L]LENDDAT)
        If fstat = [V]CST_AOK
            # update material requirements
            For [ORD] Where VCRNUM=MFGNUM & WIPTYP=6 & WIPSTA=3 With Lock
                If [F:ORD]BOMOPE <> 0
                    Read [F:OPS]OPS1 = MFGNUM;[F:ORD]BOMOPE;0
                    [F:ORD]STRDAT = [F:OPS]OPESTR
                    [F:ORD]ENDDAT = [F:OPS]OPESTR
                Else
                    [F:ORD]STRDAT = [L]STRDAT + [F:ORD]BOMOFS
                    [F:ORD]ENDDAT = [L]STRDAT + [F:ORD]BOMOFS
                Endif
#                [F:ORD]STRDAT = [L]LSTRDAT
#                [F:ORD]ENDDAT = [L]LSTRDAT
                [F:ORD]UPDDAT = date$
                [F:ORD]UPDDATTIM = datetime$
                [F:ORD]UPDUSR = USER
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "Update ORDERS-SUG- Comp: "-MFGNUM-[F:ORD]ITMREF)
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "STRDAT: "-[F:ORD]STRDAT-"ENDDAT: "-[F:ORD]ENDDAT)
                Rewrite [ORD]
            Next
        Endif
    Endif

    # Use the new function to set ASTATUS and output a message if necessary.
    [L]STAT = fstat
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)

    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, UPDWOLOG, "End of processing")
    [L]OK = func ENDLOG([L]LOGINUSE, UPDWOLOG)
    FreeGroup UPDWOLOG

#    # This is a work order
#    If WO = 1
#        # Update MFGHEAD, MFGITM
#        Readlock [MFG]MFG0 = MFGNUM
#        If fstat = [V]CST_AOK
#            [F:MFG]UPDDATTIM = datetime$
#            [F:MFG]UPDUSR = USER
#            [F:MFG]STRDAT = STRDAT
#            [F:MFG]ENDDAT = ENDDAT
#            # Only update the status if all operations have resources
#            If UNPUBLISHED = 0
#                [F:MFG]SCDFLG = 4
#                [F:MFG]OPTFLG = 1
#            Endif
#            Rewrite [F:MFG]
#        Endif
#        Unlock [MFG]
##        If (fstat = [V]CST_AOK)
##            For [MFI] Where MFGNUM = MFGNUM & ITMREF = ITMREF
##                Readlock [MFI]MFI0 = MFGNUM;[F:MFI]MFGLIN
##                If fstat = [V]CST_AOK
##                    # We can assume that the start and end dates are valid within
##                    # the constraints of version validity dates as we have sent the
##                    # earliest start and latest end dates.
##                    [F:MFI]UPDDATTIM = datetime$
##                    [F:MFI]UPDUSR = USER
##                    [F:MFI]STRDAT = STRDAT
##                    [F:MFI]ENDDAT = ENDDAT
##                    Rewrite [F:MFI]
##                Endif
##            Next
##        Endif
#    # This is a suggestion
#    Elsif WO = 2
#        # Update ORDERS
#        Readlock [ORD]ORD0 = 5;MFGNUM;ITMREF
#        If fstat = [V]CST_AOK
#            [F:ORD]UPDDATTIM = datetime$
#            [F:ORD]UPDUSR = USER
#            [F:ORD]STRDAT = STRDAT
#            [F:ORD]ENDDAT = ENDDAT
#            # X3-27347 - STWIL - Don't update status of suggestions they can only be removed
#            # using the appropriate function. Or re-running MRP.
#            # Only update the status if all operations have resources
##            If UNPUBLISHED = 0
##                # Need to check if this is valid
##                [F:ORD]OPTFLG = 1
##            Endif
#            Rewrite [F:ORD]
#        Endif
#        Unlock [F:ORD]
#    Endif


End [L]ASTATUS

#########################################################################

#**----------------------------------------------------------------<br/>
#* UPDATEOP : Update operations and scheduling tables, and if a WO mfgope.
#**<br/>----------------------------------------------------------------<br/>
#* @param OPER - C_POPSOPER = Operation class
#* @param FCY - Char = Site
#* @param OPENUM - Integer = Operation number
#* @param OPESPLNUM - Integer = Operation split number
#* @param MFGNUM - Char = Work order / Suggestion number
#* @param PRPSTRDAT - Date = Start date of the preperation time
#* @param PRPSTRDATTIM - DateTime = Start time of the preperation time
#* @param OPSTRDAT - Date = Start date of the operation
#* @param OPSTRDATTIM - DateTime = Start time of the operation
#* @param OPENDDAT - Date = End date of the operation
#* @param OPENDDATTIM - DateTime = End time of the operation
#* @param WAIENDDAT - Date = End date of the post-op/waiting time
#* @param WAIENDDATTIM - DateTime = End time of the post-op/waiting time
#* @param WO - Integer = 1 if work order, 2 if suggestion
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @param DEFDIH - Char = Default time schema
#* @param LOCFIXDATTIM - DateTime = Fixed date in local time
#* @param LOGINUSE - Integer = Is logging being used?
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEOP(OPER, FCY, OPENUM, OPESPLNUM, MFGNUM, PRPSTRDAT, PRPSTRDATTIM, OPSTRDAT, OPSTRDATTIM, OPENDDAT, OPENDDATTIM, WAIENDDAT, WAIENDDATTIM, WO, MESSAGE, USER, DEFDIH, LOCFIXDATTIM, LOGINUSE
& )
    Variable Instance OPER Using C_POPSOPER
    Variable Char FCY()
    Variable Integer OPENUM
    Variable Integer OPESPLNUM
    Variable Char MFGNUM
    Variable Date PRPSTRDAT
    Variable Datetime PRPSTRDATTIM
    Variable Date OPSTRDAT
    Variable Datetime OPSTRDATTIM
    Variable Date OPENDDAT
    Variable Datetime OPENDDATTIM
    Variable Date WAIENDDAT
    Variable Datetime WAIENDDATTIM
    Variable Integer WO
    Variable Char MESSAGE()
    Value Char USER()
    Value Char DEFDIH()
    Variable Datetime LOCFIXDATTIM
    Value Integer LOGINUSE

    #Local Integer TIMUOMCOD
    Local Integer ASTATUS
    Local Integer STAT
    Local Integer OK
    Local Integer WSTCHANGE
    Local Decimal STRTIM
    Local Decimal ENDTIM
    Local Decimal STRMIN
    Local Decimal ENDMIN

    #Local Date PRPSTRDAT
    Local Date OPESTRDAT
    Local Date OPEENDDAT
    #Local Date WAIENDDAT
    Local Date PRVOPESTR
    Local Date PRVOPEEND

    Local Decimal OPEDUR # Duration in hours
    Local Decimal OPEDURFR # Duration in fraction of days
    Local Decimal PRPSTF
    Local Decimal OPESTF
    Local Decimal OPEENF
    Local Decimal WAIENF
    Local Decimal SETTIM
    Local Decimal PRPTIM
    Local Decimal WAITIM

    # Variable to save existing data when changing resource
    Local Char PRVWST(GLONWST)
    Local Decimal PRVOPETIM
    Local Decimal PRVOPESTF
    Local Decimal PRVOPEENF

    Local Char LOGNAME(20)

    Local Instance UPDOPLOG Using C_ALOG
    UPDOPLOG = NewInstance C_ALOG AllocGroup null

    [L]LOGNAME = "UPDATE_OP1"+num$(OPENUM)
    [L]OK = func STARTLOG ([L]LOGINUSE, UPDOPLOG, "UPDOP", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op ="+OPER.OPENUM)

    [L]OPESTRDAT = OPSTRDAT
    [L]OPEENDDAT = OPENDDAT

    # Decode the openum and opesplnum
    # X3-22333 - STWIL - Don't need to do this anymore
    #OPENUM = val(left$(OPER.OPENUM, 5))
    #OPESPLNUM = val(right$(OPER.OPENUM, 7))

    WSTCHANGE = 0

    # X3-61099 - STWIL - Need to read the MFGOPE table to check the status
    If (WO = 1)
        Read [MFO]MFO0 = MFGNUM;OPENUM;OPESPLNUM
    Endif
    # Only update the operation if not closed (5) otherwise it will not exist
    If WO = 2 | (fstat = [V]CST_AOK & [F:MFO]OPESTA <> 5)
        Readlock [OPS]OPS1 = MFGNUM;OPENUM;OPESPLNUM
        If fstat = [V]CST_AOK
            # X3-64283 - STWIL - Make sure that we convert setup time to hours.
            If [F:OPS]TIMUOMCOD = 1
                [L]SETTIM = [F:OPS]EXTSETTIM
            Else
                [L]SETTIM = [F:OPS]EXTSETTIM / 60
            Endif
            [L]PRPTIM = [F:OPS]PRPTIM
            [L]WAITIM = [F:OPS]PSPTIM+[F:OPS]WAITIM

            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters SETTIM="+num$([L]SETTIM))
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters PRPTIM="+num$([L]PRPTIM))
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters WAITIM="+num$([L]WAITIM))

            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters PRPSTRDATTIM="+num$(PRPSTRDATTIM))
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters OPSTRDATTIM="+num$(OPSTRDATTIM))
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters OPENDDATTIM="+num$(OPENDDATTIM))
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters WAIENDDATTIM="+num$(WAIENDDATTIM))
            # Only update the resource if it is not blank.
            If OPER.CPLWST <> ""
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a1-1")
                Read [MWS]WST0 = OPER.CPLWST;FCY
                If fstat
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Problem reading MWS")
                    Raz [F:MWS]
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a1-2")
                # If new work station is sub-contract reset any setup or off-load times
                If [F:MWS]WSTTYP = 3
                    [L]SETTIM = 0
                    [L]PRPTIM = 0
                    [L]WAITIM = 0
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a1")
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a2")
                [F:OPS]EXTWSTNBR = [F:MWS]WSTNBR
                [F:OPS]EXTWSTTYP = [F:MWS]WSTTYP
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1a")
                # X3-56795 - STWIL - Don't need this function now as we are given all of the times needed
                # Need to determine all the start and end times and durations based on start and end time from Production Scheduler
#                [L]OPEDUR = func POPSENV_CSTD.CONVERT_START_END_TO_DURATION(STRDATTIM, ENDDATTIM, [L]SETTIM, [L]PRPTIM, [L]WAITIM, OPER.CPLWST, FCY, DEFDIH,
#&                                                               [L]PRPSTRDAT, [L]PRPSTF, [L]OPESTRDAT, [L]OPESTF, [L]OPEENDDAT, [L]OPEENF, [L]WAIENDDAT, [L]WAIENF, LOGINUSE)
                # X3-56795 - STWIL - Call existing function to determine the fraction of days from the times sent by Production Scheduler
                [L]OPESTF = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(OPSTRDATTIM, OPER.CPLWST, FCY, DEFDIH, 1, 2)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1b")
                [L]OPEENF = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(OPENDDATTIM, OPER.CPLWST, FCY, DEFDIH, 1, 2)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1c")
                If [L]PRPTIM > 0
                    [L]PRPSTF = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(PRPSTRDATTIM, OPER.CPLWST, FCY, DEFDIH, 1, 1)
                Else
                    [L]PRPSTF = [L]OPESTF
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1d")
                If [L]WAITIM > 0
                    [L]WAIENF = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(WAIENDDATTIM, OPER.CPLWST, FCY, DEFDIH, 0, 3)
                Else
                    [L]WAIENF = [L]OPEENF
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1e")
                [L]OPEDURFR = func CALC_DUR_FROM_START_END([L]OPESTRDAT, [L]OPESTF, [L]OPEENDDAT, [L]OPEENF)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 1f")
                [L]OPEDUR = func CONVERT_FRDAY_TO_DURATION([L]OPESTRDAT, [L]OPESTF, [L]OPEENDDAT, [L]OPEENF, [L]SETTIM, OPER.CPLWST, FCY, DEFDIH)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters PRPSTF="+num$([L]PRPSTF))
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters OPESTF="+num$([L]OPESTF))
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters OPEENF="+num$([L]OPEENF))
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters WAIENF="+num$([L]WAIENF))
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Op parameters OPEDUR="+num$([L]OPEDUR))

                # If the resource or operation dates have changed, we need to update the workload
                If OPER.CPLWST <> [F:OPS]EXTWST | [L]OPESTRDAT <> [F:OPS]OPESTR | [L]OPEENDDAT <> [F:OPS]OPEEND
                    [L]WSTCHANGE = 1
                    [L]PRVWST = [F:OPS]EXTWST
                Endif
            Endif
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2")
            [F:OPS]UPDDATTIM = datetime$
            [F:OPS]UPDDAT = date$
            [F:OPS]UPDUSR = USER
            # Only update the resource if it is not blank.
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a")
            If  OPER.CPLWST <> ""
                If [L]WSTCHANGE
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a1")
                    If [F:OPS]TIMUOMCOD = 1
                        [L]PRVOPETIM = [F:OPS]EXTOPETIM
                        [F:OPS]EXTOPETIM = [L]OPEDUR
                    Else
                        [L]PRVOPETIM = [F:OPS]EXTOPETIM / 60
                        [F:OPS]EXTOPETIM = [L]OPEDUR * 60
                    Endif
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a2")
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a3")
                [F:OPS]EXTWST = OPER.CPLWST
                # X3-31913 - STWIL - Update more fields
                #[F:OPS]CPLWST = OPER.CPLWST
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2a4")
                [F:OPS]FITCAPSTR = [L]OPESTRDAT
                [F:OPS]FITCAPEND = [L]OPEENDDAT
            Endif
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 2b")
            [F:OPS]SEQORD = OPER.SEQORD
            [F:OPS]FORPLA = OPER.FORPLA
            [F:OPS]OPESTR = PRPSTRDAT
            [F:OPS]OPEEND = WAIENDDAT
            Rewrite [F:OPS]
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 3")
        Endif
        # Update MFGOPE, OPERATIONS, SCHEDULING
        If (WO = 1)
            Readlock [MFO]MFO0 = MFGNUM;OPENUM;OPESPLNUM
            If fstat = [V]CST_AOK
                [F:MFO]UPDDATTIM = datetime$
                [F:MFO]UPDDAT = date$
                [F:MFO]UPDUSR = USER
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 4")
                # Only update the resource if it is not blank.
                If  OPER.CPLWST <> ""
                    [F:MFO]EXTWST = OPER.CPLWST
                    If [F:MFO]TIMUOMCOD = 1
                        [F:MFO]EXTOPETIM = [L]OPEDUR
                    Else
                        [F:MFO]EXTOPETIM = [L]OPEDUR * 60
                    Endif
                    If OPER.CPLWST <> [L]PRVWST
                        [F:MFO]EFF = [F:MWS]EFF
                        [F:MFO]WSTEFF = [F:MWS]EFF
                        If [F:MWS]WSTTYP = 3
                            [F:MFO]SCOCOD = 3
                            [F:MFO]SCOWST = OPER.CPLWST
                            [F:MFO]ROOTIMCOD = 3
                            [F:MFO]TIMCOD = 0
                            [F:MFO]BASQTY = 0
                            [F:MFO]CAD = 3
                            [F:MFO]TECCRD = ""
                            [F:MFO]OPEPLNNUM = ""
                            [F:MFO]OPEROUPCT = ""
                            [F:MFO]EQUNUM = ""
                            [F:MFO]FXGNUM = ""
                            [F:MFO]PRGNUM = ""
                        Endif
                    Endif
                    # Issue X3-22304 - 2017-08-10 by ALSHE : update subcontract item in table ORDERS
                    If [F:MFO]OPESTA <> 7 & [F:MWS]WSTTYP = 3
                        Update [ORD] Where WIPNUM=[F:MFO]WIPNUM & WIPTYP = 4 & ITMREF = [F:MFO]SCOITMREF
&                                    With  STRDAT = PRPSTRDAT,
&                                          ENDDAT = WAIENDDAT,
&                                          UPDDATTIM = datetime$,
&                                          UPDDAT = date$,
&                                          UPDUSR = USER
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update ORDERS")
                    Endif
                    # End issue X3-22304
                Endif

                If OPER.FIXDAT <> AVOID.ADATTIM
                    [F:MFO]FRCSTRDAT = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_DATE(LOCFIXDATTIM)
                    [F:MFO]FRCSTRHOU = func POPSENVUPD_CSTD.CONVERT_DATETIME_TO_HHMM(LOCFIXDATTIM)
                Else
                    # Issue X3-29698 - 2017-04-04 by CCC : Remove forced date
                    Raz [F:MFO]FRCSTRDAT, [F:MFO]FRCSTRHOU
                Endif
                # X3-61617 - STWIL - Use the prep start and post-op end dates
                [F:MFO]OPESTR = PRPSTRDAT
                [F:MFO]OPEEND = WAIENDDAT
                #TIMUOMCOD = [F:MFO]TIMUOMCOD
                #STRMIN = func POPSENV_CSTD.CONVERT_DATETIME_TO_MINS(STRDATTIM)
                #ENDMIN = func POPSENV_CSTD.CONVERT_DATETIME_TO_MINS(ENDDATTIM)
                Rewrite [F:MFO]
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 5")
            Endif
        Endif
        If (fstat = [V]CST_AOK)
            Readlock [SCH]SCH0 = MFGNUM;OPENUM;OPESPLNUM
            If fstat = [V]CST_AOK
                [F:SCH]UPDDATTIM = datetime$
                [F:SCH]UPDDAT = date$
                [F:SCH]UPDUSR = USER
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6")
                # Only update the resource if it is not blank.
                If  OPER.CPLWST <> ""
                    [F:SCH]CLCWST = OPER.CPLWST
                    # X3-31913 - STWIL - If the work centre has changed reset values
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6a")
                    # X3-57824 - STWIL - we need to use the resource start and end
                    [L]PRVOPESTR = [F:SCH]INFCAPSTR
                    [L]PRVOPESTF = [F:SCH]INFCAPSTF
                    [L]PRVOPEEND = [F:SCH]INFCAPEND
                    [L]PRVOPEENF = [F:SCH]INFCAPENF
                    If [F:OPS]TIMUOMCOD = 1
                        [F:SCH]CLCEXTTIM = [L]OPEDUR
                    Else
                        [F:SCH]CLCEXTTIM = [L]OPEDUR * 60
                    Endif
                    [F:SCH]OPEFITSTD = PRPSTRDAT
                    [F:SCH]OPEFITSTF = [L]PRPSTF
                    [F:SCH]FITCAPSTR = [L]OPESTRDAT
                    [F:SCH]FITCAPSTF = [L]OPESTF
                    [F:SCH]FITCAPEND = [L]OPEENDDAT
                    [F:SCH]FITCAPENF = [L]OPEENF
                    [F:SCH]FITOPEEND = WAIENDDAT
                    [F:SCH]FITOPEENF = [L]WAIENF

                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6c")
                    # not right needs to be in fraction of day[F:SCH]FITPRPDUR = [L]PRPTIM
                    If [L]PRPTIM > 0
                        [F:SCH]FITPRPDUR = func CALC_DUR_FROM_START_END([L]PRPSTRDAT, [L]PRPSTF, [L]OPESTRDAT, [L]OPESTF)
                    Else
                        [F:SCH]FITPRPDUR = 0
                    Endif
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6d")
                    # not right needs to be total duration in fractions of day[F:SCH]FITWORDUR = [L]OPEDUR
                    If [L]OPEDUR > 0
                        [F:SCH]FITWORDUR = func CALC_DUR_FROM_START_END([L]OPESTRDAT, [L]OPESTF, [L]OPEENDDAT, [L]OPEENF)
                    Else
                        [F:SCH]FITWORDUR = 0
                    Endif
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6e")
                    # not right needs to be in fraction of day[F:SCH]FITPSTDUR = [L]WAITIM
                    If [L]WAITIM > 0
                        [F:SCH]FITPSTDUR = func CALC_DUR_FROM_START_END([L]OPESTRDAT, [L]OPESTF, [L]WAIENDDAT, [L]WAIENF)
                    Else
                        [F:SCH]FITPSTDUR = 0
                    Endif
                    # X3-57824 - STWIL - We need to set the infinite capacity fields with the new values
                    # in case this work order is removed from Production Scheduler.
                    If [L]WSTCHANGE
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6b")
                        [F:SCH]CLCPRPDUR = [F:SCH]FITPRPDUR
                        [F:SCH]CLCWORDUR = [F:SCH]FITWORDUR
                        [F:SCH]CLCAFTDUR = [F:SCH]FITPSTDUR
                        [F:SCH]INFCAPSTR = [F:SCH]FITCAPSTR
                        [F:SCH]INFCAPSTF = [F:SCH]FITCAPSTF
                        [F:SCH]SETENDDAT = [F:SCH]FITCAPSTR
                        [F:SCH]SETENDFRD = [F:SCH]FITCAPSTF
                        [F:SCH]INFCAPEND = [F:SCH]FITCAPEND
                        [F:SCH]INFCAPENF = [F:SCH]FITCAPENF
                        [F:SCH]OPESTRFRD = [F:SCH]OPEFITSTF
                        [F:SCH]OPEENDFRD = [F:SCH]FITOPEENF
                    Endif
                Endif
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6f")
                [F:SCH]OPESTRDAT = PRPSTRDAT
                [F:SCH]OPEENDDAT = WAIENDDAT
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6g")
                # X3-29634 - STWIL - Change function to calculate fraction of day based on time schemas.
                #[F:SCH]OPESTRFRD = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(STRDATTIM, [F:SCH]CLCWST, [F:MFO]PLNFCY, DEFDIH)
                [F:SCH]OPESTRFRD = [L]PRPSTF
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 6h")
                #[F:SCH]OPEENDFRD = func POPSENV_CSTD.CONVERT_DATETIME_TO_FRDAY(ENDDATTIM, [F:SCH]CLCWST, [F:MFO]PLNFCY, DEFDIH)
                [F:SCH]OPEENDFRD = [L]WAIENF
                Rewrite [F:SCH]
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 7")
            Endif
        Endif
        # The work station has changed update the work loads
        If fstat = [V]CST_AOK & [L]WSTCHANGE
            # Reduce the previous work station load
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 7a params=" - FCY - num$([L]PRVOPESTR) - num$([L]PRVOPESTF) - num$([L]PRVOPEEND) - num$([L]PRVOPEENF) - [F:OPS]MFGNUM - [
& L]PRVWST - num$([L]PRVOPETIM))
            [L]OK = func UPDATE_WST('-', FCY, [L]PRVOPESTR, [L]PRVOPESTF, [L]PRVOPEEND, [L]PRVOPEENF, [F:OPS]MFGNUM, [L]PRVWST, USER, [L]PRVOPETIM, LOGINUSE)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 7b params=" - FCY - num$([L]OPESTRDAT) - num$([L]OPESTF) - num$([L]OPEENDDAT) - num$([L]OPEENF) - [F:OPS]MFGNUM - [F:OPS]
& EXTWST - num$([L]OPEDUR))

            # Update THE NEW WORK STATION
            [L]OK = func UPDATE_WST('+', FCY, [L]OPESTRDAT, [L]OPESTF, [L]OPEENDDAT, [L]OPEENF, [F:OPS]MFGNUM, [F:OPS]EXTWST, USER, [L]OPEDUR, LOGINUSE)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 7c")
        Endif
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 8")

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]ASTATUS = func MANAGE_FSTAT(STAT, MESSAGE)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDOPLOG, "Start update op 9")

    [L]OK = func ENDLOG ([L]LOGINUSE, UPDOPLOG)

    FreeGroup UPDOPLOG

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* UPDATE_WST : Update work load of workstation up or down
#**<br/>----------------------------------------------------------------<br/>
#* @param LSIG - Char = + or -
#* @param LSTRDAT - Date = Start date of the operation
#* @param LSTF - Decimal = Start time of the operation as a fraction of day
#* @param LENDDAT - Date = End date of the operation
#* @param LENF - Decimal = End time of the operation as a fraction of day
#* @param LVCRNUM - Char = Work order number
#* @param LWST - Char = Work centre being updated
#* @param LUSER - Char = User who is doing update
#* @param LOPETIM - Decimal = Operation duration
#* @param LOGINUSE - Integer = Is logging being used?
#* @return whether the update was successful
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATE_WST(LSIG, LFCY, LSTRDAT, LSTF, LENDDAT, LENF, LVCRNUM, LWST, LUSER, LOPETIM, LOGINUSE)
Value Char LSIG()
Value Char LFCY()
Value Date LSTRDAT
Value Decimal LSTF
Value Date LENDDAT
Value Decimal LENF
Value Char LVCRNUM()
Value Char LWST()
Value Char LUSER()
Value Decimal LOPETIM
Value Integer LOGINUSE

    Local Integer ORITYP
    Local Integer LRET
    Local Integer LNBR(2000)
    Local Decimal CURCAP(2000)
    Local Decimal LABCOE
    Local Integer WSTNBR
    Local Integer WIPSTA
    Local Integer OK
    Local Char CAL(3)
    Local Char WCR(20)

    # Open the files needed by the function
    Local File WORKSTATIO [MWS]
    Local File ORDERS [ORD]
    Local File TABUNAVAIL [TUV]
    Local File CAPVAR [CPV]
    Local File TABWEEDIA [TWD]

    Local Char LOGNAME(20)

    Local Instance UPDWSTLOG Using C_ALOG
    UPDWSTLOG = NewInstance C_ALOG AllocGroup null

    [L]LOGNAME = "UPDATE_WST1"+LSIG+LWST
    [L]OK = func STARTLOG ([L]LOGINUSE, UPDWSTLOG, "UPD_WST", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst ="+LWST)

    [L]LABCOE = 1 # Don't have labour coefficient on Production Scheduler

    Readlock [MWS]WST0 = LWST;LFCY
    If fstat = [V]CST_AOK
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 1")
        For [ORD] Where VCRNUM = LVCRNUM
            If [F:ORD]ORI = 5
                [L]ORITYP = 3
            Elsif [F:ORD]ORI = 6
                [L]ORITYP = 2
            Endif
            [L]WSTNBR = [F:MWS]WSTNBR
            [L]WIPSTA = [F:ORD]WIPSTA
            [L]WCR = [F:MWS]WCR
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 2")
            If LSIG = '+'
                [F:MWS]EXTHOUTIM += LOPETIM
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 3")
                Call LOACAPN (LSTRDAT, LENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 4")
                Call WSTLOAD (LFCY,[L]WCR,LWST,[L]WIPSTA, [L]ORITYP, [L]CAL, [L]CURCAP, LSTRDAT, LSTF, LENDDAT, LENF, [L]LNBR, [L]WSTNBR, [L]LABCOE, 0, [L]WSTNBR, LUSER, [L]LRET) From JALLIBB_SYRA
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 5")
            Else
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 3a")
                [F:MWS]EXTHOUTIM -= LOPETIM
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 4a")
                Call LOACAPN (LSTRDAT, LENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 5a")
                Call WSTUNLD (LFCY,LWST,[L]WIPSTA, [L]ORITYP, [L]CAL, [L]CURCAP, LSTRDAT, LSTF, LENDDAT, LENF, [L]LNBR, [L]WSTNBR, [L]LABCOE, 0, [L]WSTNBR, LUSER, [L]LRET) From JALLIBB_SYRA
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 6a")
            Endif
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 7")
            Rewrite [MWS]
            Break
        Next
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 8")
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, UPDWSTLOG, "Start update wst 9")

    [L]OK = func ENDLOG ([L]LOGINUSE, UPDWSTLOG)

    FreeGroup UPDWSTLOG
End OK

#**----------------------------------------------------------------<br/>
#* CALC_DUR_FROM_START_END : Calculate the time as a fraction of a day ( > 1 is more than 1 day)
#**<br/>----------------------------------------------------------------<br/>
#* @param LSTRDAT - Date = Start date
#* @param LSTF - Decimal = Start time as a fraction
#* @param LENDDAT - Date = End date
#* @param LENF - Decimal = End time as a fraction
#* @return Duration - Decimal = Duration of elapsed time in fractions of day
#**<br/>----------------------------------------------------------------
#*!
Funprog CALC_DUR_FROM_START_END (LSTRDAT, LSTF, LENDDAT, LENF)
Value Date LSTRDAT
Value Decimal LSTF
Value Date LENDDAT
Value Decimal LENF

    Local Decimal DURATION

    If LENDDAT = LSTRDAT
        [L]DURATION = LENF - LSTF
    Elsif LENDDAT - LSTRDAT = 1
        [L]DURATION = (1 - LSTF) + LENF
    Else
        [L]DURATION = (LENDDAT - LSTRDAT - 1) + (1 - LSTF) + LENF
    Endif
End DURATION

#**----------------------------------------------------------------<br/>
#* CONVERT_FRDAY_TO_DURATION : Convert the operation start and end into a duration
#**<br/>----------------------------------------------------------------<br/>
#* @param LSTRDAT - Date = Start date
#* @param LSTF - Decimal = Start time as a fraction
#* @param LENDDAT - Date = End date
#* @param LENF - Decimal = End time as a fraction
#* @param LSETTIM - Decimal = Amount of setup time
#* @param EXTWST - Char = Work centre being updated
#* @param FCY - Char = Site
#* @param DEFDIH - Char = Default time schema
#* @return Duration - Decimal = Duration of elapsed time in hours
#*!
Funprog CONVERT_FRDAY_TO_DURATION(LSTRDAT, LSTF, LENDDAT, LENF, LSETTIM, EXTWST, FCY, DEFDIH)
    Value Date LSTRDAT
    Value Decimal LSTF
    Value Date LENDDAT
    Value Decimal LENF
    Value Decimal LSETTIM
    Value Char EXTWST()
    Value Char FCY()
    Value Char DEFDIH()

    Local Char DATTIM(20)
    Local Char HHMM(6)
    Local Date OPEDAT
    Local Integer OK
    Local Decimal OPEDUR
    Local Decimal CURCAP(200)
    Local Decimal FRDAY
    Local File WORKSTATIO [MWS]
    Local File TABWEEDIA [TWD]
    Local File CAPVAR [CPV]
    Local File TABUNAVAIL [TUV]
    Local File FACILITY [FCY]
    Local Char LOGNAME(20)
    Local Integer LOGINUSE
    Local Integer LNBR(200)
    Local Integer LRET
    Local Decimal STADUR
    Local Decimal ENDDUR
    Local Decimal STACURCAP
    Local Decimal ENDCURCAP
    Local Decimal DUR
    Local Decimal DAYSDUR
    Local Integer STALNBR
    Local Integer ENDLNBR
    Local Integer DAYS
    Local Date STADURDAT
    Local Date ENDDURDAT

    Local Instance FRDAYLOG Using C_ALOG
    FRDAYLOG = NewInstance C_ALOG AllocGroup null

    [L]FRDAY = 0

    [L]LOGINUSE = 1
    [L]LOGNAME = "CONVFRDUR1"
    [L]OK = func STARTLOG ([L]LOGINUSE, FRDAYLOG, "CONV_FRD_DUR", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start test")
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "FCY="+FCY+"WST="+EXTWST)

    # Make sure we have something in all the variables
    If EXTWST <> "" & LSTRDAT <> AVOID.ADATE & LENDDAT <> AVOID.ADATE & FCY <> "" & DEFDIH <> ""

        If [F:FCY]FCY <> FCY
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read FCY")
            Read [FCY]FCY0 = FCY
            If fstat <> [V]CST_AOK
                [L]FRDAY = 0
                [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                FreeGroup FRDAYLOG
            Endif
        Endif

        If [F:FCY]UVYCOD = ""
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "UVYCOD = ''")
            Raz [F:TUV]
        Else
            If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read TUV")
                Read [TUV]UVY0 = [F:FCY]UVYCOD
                If fstat <> [V]CST_AOK
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "TUV failed")
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "TUV failed - " + [F:FCY]UVYCOD + num$(fstat))
                    [L]FRDAY = 0
                    [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                    FreeGroup FRDAYLOG
                Endif
            Endif
        Endif

        If [F:MWS]WST <> EXTWST | [F:MWS]WCRFCY <> FCY
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read WST-" + EXTWST)
            Read [MWS]WST0 = EXTWST;FCY
            If fstat <> [V]CST_AOK
                [L]FRDAY = 0
                [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                FreeGroup FRDAYLOG
            Endif
        Endif

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "LOACAPN")

        # Get the capacity for the start day
        Call LOACAPN (LSTRDAT, LSTRDAT, [L]STACURCAP, [L]STALNBR, [L]LRET) From JALLIBB_SYRA

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "LOACAPN 2")
        # Get the capacity for the end day
        Call LOACAPN (LENDDAT, LENDDAT, [L]ENDCURCAP, [L]ENDLNBR, [L]LRET) From JALLIBB_SYRA

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "LOACAPN 3")
        # Calculate the duration between the two dates
        If LENDDAT - LSTRDAT > 1
            [L]DAYS = LENDDAT - LSTRDAT - 1
            [L]STADURDAT = LSTRDAT + 1
            [L]ENDDURDAT = LENDDAT - 1
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "LOACAPN 4")

            # Get the capacity for the full days in question only if there are any
            Call LOACAPN ([L]STADURDAT, [L]ENDDURDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
            [L]DAYSDUR = sigma(0, [L]DAYS, [L]CURCAP(indcum))
        Endif
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "In between days =" + num$([L]STADURDAT)+ num$([L]ENDDURDAT))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "In between days capacity=" + num$([L]DAYSDUR))

        # Calculate the number of hours runtime, this currently includes setup time.
        # runtime = capacity of full days - setup time + (start day capacity * start day fraction) + (end day capacity * end day fraction)
        # Unless the start and end are on the same day when we only need (end day capacity * end day fraction) - setup time
        If LSTRDAT = LENDDAT
            # Calculate the number of work hours between start and end time
            [L]STADUR = LSTF * [L]STACURCAP
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc start day duration=" + num$([L]STADUR))
            [L]ENDDUR = LENF * [L]ENDCURCAP
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc end day duration=" + num$([L]ENDDUR))
            [L]DUR = [L]ENDDUR - [L]STADUR - LSETTIM
        Else
            # Calculate the number of work hours between start and end time
            [L]STADUR = [L]STACURCAP - (LSTF * [L]STACURCAP)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc start day duration=" + num$([L]STADUR))
            [L]ENDDUR = LENF * [L]ENDCURCAP
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc end day duration=" + num$([L]ENDDUR))
            [L]DUR = [L]DAYSDUR + [L]STADUR + [L]ENDDUR - LSETTIM
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc duration=" + num$([L]DUR))
        Endif
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "ROUND")
        [L]FRDAY = arr([L]FRDAY, 0.0001)
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc frday=" + num$([L]FRDAY))
    [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

    FreeGroup FRDAYLOG

End [L]DUR

#**----------------------------------------------------------------<br/>
#* WO_OR_SUGGESTION : Check if the WO number is a WO or a WO Suggestion or neither
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order / Suggestion number
#* @param ITMREF - Char = Product code
#* @return 1 if a work order, 2 if a suggestion, 0 if neither
#**<br/>----------------------------------------------------------------
#*!
Funprog WO_OR_SUGGESTION(MFGNUM, ITMREF)
    Variable Char MFGNUM()
    Variable Char ITMREF()

    Local Integer WO

    # Set the flag to either WO or Suggestion
    [L]WO = 0
    ITMREF = ""

    # Read MFGHEAD
    Read [MFG]MFG0 = MFGNUM
    If fstat = [V]CST_AOK
        # This is a WO
        [L]WO = 1
        #ITMREF = [F:MFG]ITMREF
    Else
        # Not a WO check ORDERS for a suggestion
        Filter [F:ORD] Where WIPNUM=MFGNUM & WIPTYP=5
        For [ORD]
            If [F:ORD]WIPSTA = 3
                # This is a suggestion
                [L]WO = 2
                ITMREF = [F:ORD]ITMREF
            Endif
            # There should only be one record.
            Break
        Next
        Filter [F:ORD]
    Endif

End [L]WO

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_DATE : Convert datetime type to date type
#**<br/>----------------------------------------------------------------<br/>
#* @param DATETIMETOCONV - DateTime = Date time to convert
#* @return Date portion of the datetime
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_DATETIME_TO_DATE (DATETIMETOCONV)
    Value Datetime DATETIMETOCONV
    Local Date NEWDATE
    Local Char STRINGDT(20)

    STRINGDT = num$(DATETIMETOCONV)
    NEWDATE = gdat$(val(mid$(STRINGDT, 9, 2)), val(mid$(STRINGDT,6,2)), val(left$(STRINGDT, 4)))

End NEWDATE

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_HHMM : Convert datetime type to char type in the format HHMM
#**<br/>----------------------------------------------------------------<br/>
#* @param DATETIMETOCONV - DateTime = Date time to convert
#* @return Time portion of the datetime formatted to HHMM
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_DATETIME_TO_HHMM (DATETIMETOCONV)
    Value Datetime DATETIMETOCONV
    Local Char NEWTIME(4)
    Local Char STRINGDT(20)

    STRINGDT = num$(DATETIMETOCONV)
    NEWTIME = mid$(STRINGDT, 12, 2) + mid$(STRINGDT,15,2)

End NEWTIME

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_TIME : Convert datetime type to char type in the format HH:MM:SS
#**<br/>----------------------------------------------------------------<br/>
#* @param DATETIMETOCONV - DateTime = Date time to convert
#* @return Time portion of the datetime formatted to HH:MM:SS
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_DATETIME_TO_TIME (DATETIMETOCONV)
    Value Datetime DATETIMETOCONV
    Local Char NEWTIME(8)
    Local Char STRINGDT(20)

    STRINGDT = num$(DATETIMETOCONV)
    NEWTIME = mid$(STRINGDT, 12, 8)

End NEWTIME

#**----------------------------------------------------------------<br/>
#* SPLIT_WO_KEY : Split the concatenated work order key into it's parts
#**<br/>----------------------------------------------------------------<br/>
#* @param WOKEY - Integer = Concatenated work order key
#* @param MFGNUM - Char = Work order number
#* @param ITMREF - Char = Work order product code
#* @return ASTATUS value based on fstat value if fstat <> 0 = CST_AERROR
#**<br/>----------------------------------------------------------------
#*!
Funprog SPLIT_WO_KEY(WOKEY, MFGNUM, ITMREF)
    Value Char WOKEY()
    Variable Char MFGNUM()
    Variable Char ITMREF()

    Local Integer SUCCESS
    Local Integer KEYSPLIT

    [L]KEYSPLIT = instr(1, WOKEY, "|")
    MFGNUM = left$(WOKEY, [L]KEYSPLIT - 1)
    ITMREF = right$(WOKEY, [L]KEYSPLIT)

End SUCCESS

#**----------------------------------------------------------------<br/>
#* SPLIT_OP_KEY : Split the concatenated operation key into it's parts
#**<br/>----------------------------------------------------------------<br/>
#* @param OPKEY - Integer = Concatenated work order operation key
#* @param OPENUM - Integer = Work order operation number
#* @param OPESPLNUM - Integer = Work order operation split number
#* @return SUCCESS - Integer - 0 = SUCCESS otherwise failure
#**<br/>----------------------------------------------------------------
#*!
Funprog SPLIT_OP_KEY(OPKEY, OPENUM, OPESPLNUM)
    Value Char OPKEY()
    Variable Integer OPENUM
    Variable Integer OPESPLNUM

    Local Integer SUCCESS
    Local Integer KEYSPLIT
    Local Integer KEYSPLIT2

    [L]KEYSPLIT = instr(1, OPKEY, "|")
    [L]KEYSPLIT = instr(1 + [L]KEYSPLIT, OPKEY, "|")
    [L]KEYSPLIT2 = instr(1 + [L]KEYSPLIT, OPKEY, "|")
    [L]OPENUM = val(mid$(OPKEY, [L]KEYSPLIT + 1, 5))
    # Issue X3-65203 - 2017-11-21 by ALSHE : fix start character to determine OPSPLNUM (KEYSPLIT2 + 1)
    [L]OPESPLNUM = val(right$(OPKEY, [L]KEYSPLIT2 + 1))

End SUCCESS

# Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
#**----------------------------------------------------------------<br/>
#* SPLIT_OP_KEY_ALL : Split the concatenated operation key into it's parts
#**<br/>-----------------------------------------------------------<br/>
#* @param OPKEY - Integer = Concatenated work order operation key
#* @param MFGNUM - Char = Work order number
#* @param ITMREF - Char = Work order product code
#* @param OPENUM - Integer = Work order operation number
#* @param OPESPLNUM - Integer = Work order operation split number
#* @return SUCCESS - Integer - 0 = SUCCESS otherwise failure
#**<br/>----------------------------------------------------------------
#*!
Funprog SPLIT_OP_KEY_ALL(OPKEY, MFGNUM, ITMREF, OPENUM, OPESPLNUM)
    Value Char OPKEY()
    Variable Char MFGNUM()
    Variable Char ITMREF()
    Variable Integer OPENUM
    Variable Integer OPESPLNUM

    Local Integer SUCCESS
    Local Integer KEYSPLIT
    Local Integer KEYSPLIT1
    Local Integer KEYSPLIT2

    [L]KEYSPLIT  = instr(1, OPKEY, "|")
    [L]MFGNUM    = mid$( OPKEY, 1,[L]KEYSPLIT-1)
    [L]KEYSPLIT1 = instr([L]KEYSPLIT + 1, OPKEY, "|")
    [L]ITMREF    = mid$( OPKEY, [L]KEYSPLIT + 1, [L]KEYSPLIT1 - [L]KEYSPLIT -1)
    [L]KEYSPLIT2 = instr([L]KEYSPLIT1 + 1, OPKEY, "|")
    [L]OPENUM    = val(mid$(OPKEY, [L]KEYSPLIT1 + 1, 5))
    [L]OPESPLNUM = val(right$(OPKEY, [L]KEYSPLIT2 + 1))

End SUCCESS

# Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
#**-----------------------------------------------------------------------<br/>
#* SPLIT_MTOLINK_KEY: Split the concatenated MTO link key into it's parts <br/>
#**-----------------------------------------------------------------------<br/>
#* @param MTOLINKKEY       - Char = Concatenated key
#* @param NUM              - Char = order number
#* @param LIN              - Integer = line number
#* @param SEQ              - Integer = sequence number
#* @return SUCCESS - Integer - 0 = SUCCESS otherwise failure
#**<br/>---------------------------------------------------------------------
#*!
Funprog SPLIT_MTOLINK_KEY(MTOLINKKEY, NUM, LIN, SEQ)
    Value Char       MTOLINKKEY()
    Variable Char    NUM()
    Variable Integer LIN
    Variable Integer SEQ

    Local Integer SUCCESS
    Local Integer KEYSPLIT
    Local Integer KEYSPLIT1
    Local Integer KEYSPLIT2

Infbox MTOLINKKEY
    [L]KEYSPLIT  = instr(1, MTOLINKKEY, "|")
    [L]NUM    = mid$(MTOLINKKEY, 1,[L]KEYSPLIT-1)
    [L]KEYSPLIT1 = instr([L]KEYSPLIT + 1, MTOLINKKEY, "|")
    [L]LIN    = val(mid$(MTOLINKKEY, [L]KEYSPLIT + 1,[L]KEYSPLIT1 - [L]KEYSPLIT - 1))
    [L]KEYSPLIT2 = instr([L]KEYSPLIT1 + 1, MTOLINKKEY, "|")
    [L]SEQ    = val(mid$(MTOLINKKEY, [L]KEYSPLIT1 + 1, 10))

End SUCCESS

#**----------------------------------------------------------------<br/>
#* MANAGE_FSTAT : Convert the fstat value into a ASTATUS value and message.
#**<br/>----------------------------------------------------------------<br/>
#* @param FSTATVAL - Integer = fstat value returned from file operation
#* @param MESSAGE - Char = Error message determined by fstat value
#* @return ASTATUS value based on fstat value if fstat <> 0 = CST_AERROR
#**<br/>----------------------------------------------------------------
#*!
Funprog MANAGE_FSTAT(FSTATVAL, MESSAGE)
    Variable Integer FSTATVAL
    Variable Char MESSAGE()

    Local Integer ASTATUS

    Case FSTATVAL
        When [V]CST_AOK
            MESSAGE = "No error"
        When [V]CST_ALOCK
            MESSAGE = mess(364,193,1)
        When [V]CST_AOUTSEARCH
            MESSAGE = mess(365,193,1)
        When [V]CST_ADUPKEY
            MESSAGE = mess(366,193,1)
        When [V]CST_AOUTKEYS
            MESSAGE = mess(367,193,1)
        When [V]CST_ANOREC
            MESSAGE = mess(368,193,1)
        When [V]CST_ARECTICKUPD
            MESSAGE = mess(369,193,1)
        When [V]CST_ARECTICKDEL
            MESSAGE = mess(370,193,1)
        When Default
            MESSAGE = "Default error="+num$(FSTATVAL)
    Endcase

    If (FSTATVAL = [V]CST_AOK)
        [L]ASTATUS = [V]CST_AOK
    Else
        [L]ASTATUS = [V]CST_AERROR
    Endif

End [L]ASTATUS

#**----------------------------------------------------------------<br/>
#* OUTPUTLOGMSG : Write a message to the current log
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @param MESSAGE   = Message to be written to the log
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog OUTPUTLOGMSG(LOGINUSE, POPSLOG, MESSAGE)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG
    Value Char MESSAGE()

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.APUTLINE(num$(datetime$)+": "+MESSAGE,0)
        [L]SUCCESS = fmet POPSLOG.AFLUSHLOG()
    Endif

End [L]SUCCESS

#**----------------------------------------------------------------<br/>
#* STARTLOG : Open a log file
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @param TITLE     = Title of the log
#* @param LOGNAME   = Name of the log
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog STARTLOG(LOGINUSE, POPSLOG, TITLE, LOGNAME)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG
    Value Char TITLE()
    Value Char LOGNAME()

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.ABEGINLOG(TITLE)
        [L]SUCCESS = fmet POPSLOG.ASETNAME(LOGNAME)
    Endif

End [L]SUCCESS

#**----------------------------------------------------------------<br/>
#* ENDLOG : Close the currently open log
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog ENDLOG(LOGINUSE, POPSLOG)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.AENDLOG()
    Endif

End [L]SUCCESS

