#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# - Fenêtre d'affichage des modifications en attente de traitement (contextes)
# - Traitements déclenchés en cas de modification de paramètrage.
#        o Mise à jour directe de DEPSTA pour les biens concernés si nb biens < à LSEUIL (paramètre DIRUPDTSD)
#        o Enregistrement de la modification de paramètrage dans le ou les contextes concernés
#
# @ver        1.0.0
# @date       07/05/2007
# @user       GBO
# @modif      07/05/2007
#
# Liste des sous-programmes :
# -------------------------
#
# RAZ_UPD_WAI_CNX(PCPY, PCNX, RCOD)
# ADD_UPD_WAI_CNX(PCPY, PCNX, PUPDTYP, PUPDPAR, PUPDVAL, PCLASSE, RCOD)
#
# Liste des fonctions :
# -------------------
# 
# 
# UPD_WAI_CNX(PCPY, PCNX)
#
# Liste des routines :
# ------------------
#
# $DEBUT
# $LOAD_INFO_CNX
# $DETER_PAR_INT
# $ADP_INT
# $DPM_INT
# $ADI_INT
# $CNX_INT
# $CAL_NB_BCO
# $LST_UPD_CNX
#
########################################################################################################################
# Modifications :
# -------------
# 
# - XXX - JJ.MM.AAAA - Fq nnnnn - Commentaire
#   MDJ   08.08.2012 - Fq 81074 - Optimisation suite SPIKE Performances contextes
# - GLE - 14.02.2011 - Fq 70465 - Nouveau paramètre DESYNC pour le type CNX - certification NC-25
# - GLE - 15.11.2010 - Fq 67765 - Application des mêmes critères que dans GLOBB pour sélectionner les biens à mettre "A calculer"
# - GLE - 15.11.2010 - Fq 66894 - Optimisation des flux
########################################################################################################################
 Local Integer CHOIX : CHOIX = 2
 Case CHOIX
  When 1         : Goto  TEST_CTRL_CLOTURE
  When 2         : Goto  TEST_AFFICHAGE
  When 3         : Goto  TEST_VIDE_LISTE
  When 4         : Goto  TEST_VIDE_LISTE_TOUT_CNX
  When 5         : Gosub LST_UPD_CNX
  When Default
 Endcase
End

$TEST_CTRL_CLOTURE
 If !func UPDWAICNX.UPD_WAI_CNX("CN1",G300CPFI)
  Infbox "No change in backlog"
 Else
  Infbox "Changes in backlog"
 Endif
End

$TEST_AFFICHAGE
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1)= "GBA"
PARAM(2)= "1"
Call SAISIE_CHAR(VALEUR,PARAM,"UPDWAICNX","UPDWAICNX","") From GSAISIE
End

$TEST_VIDE_LISTE
Local Integer RCOD
Call RAZ_UPD_WAI_CNX("CN1", G300CPFI, RCOD)
If RCOD=0
 Infbox "Dump list OK"
Else
 Infbox num$(RCOD)
Endif
End

$TEST_VIDE_LISTE_TOUT_CNX
Local Integer RCOD
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
Call OUVRE_TRACE(mess(141,7774,1)) From LECFIC 
For [CPY]
 Filter [CNX] Where CPY=[F:CPY]CPY
 For [CNX]
  Call RAZ_UPD_WAI_CNX([F:CPY]CPY, [F:CNX]CNX, RCOD)  
  If RCOD
   Call ECR_TRACE("Erreur"-[F:CPY]CPY-"/"-mess([F:CNX]CNX,3100,1)-num$(RCOD),1) From GESECRAN
  Else
   Call ECR_TRACE("Mise à jour"-[F:CPY]CPY-"/"-mess([F:CNX]CNX,3100,1),0) From GESECRAN
  Endif
 Next
Next 
Filter [CNX]
Call LEC_TRACE() From LECFIC
End

End

#################################################################################
$ACTION
 Case ACTION
  When "DEBUT" : Gosub DEBUT
  When Default
 Endcase
Return

#========================================================================
$DEBUT
 Local Char    LCPY : LCPY=PARAM(1)
 Local Integer LCNX : LCNX=val(PARAM(2))

 Local Integer I_UPD

 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
 If [F:CNX]CPY<>LCPY | [F:CNX]CNX<>LCNX
  Read [F:CNX]CNX0=LCPY;LCNX
  If fstat
   Call FSTA("CNX") From GLOCK
   GOK=0
  Endif
 Endif
 
 Gosub LOAD_INFO_CNX

Return

#========================================================================
$LOAD_INFO_CNX
 For I_UPD=1 To [F:CNX]UPDWAINBR
  [M]UPDWAITYP(I_UPD-1)=[F:CNX]UPDWAITYP(I_UPD-1)
  [M]UPDWAIPAR(I_UPD-1)=[F:CNX]UPDWAIPAR(I_UPD-1)
  Gosub DETER_PAR_INT
  [M]UPDWAIBCO(I_UPD-1)=[F:CNX]UPDWAIBCO(I_UPD-1)
 Next I_UPD
 [M]NBUPD=I_UPD-1
 Affzo [M:UWC]
Return

#========================================================================
# Détermination des intitulés des paramètres en fonction de leur
# type.
#========================================================================
$DETER_PAR_INT

 Local Char LINT(30)
 Local Char LTYP
 Local Char LPAR

 LTYP = [M]UPDWAITYP(I_UPD-1)
 LPAR = [M]UPDWAIPAR(I_UPD-1)

 Case LTYP
  When "ADP" : Gosub ADP_INT 
  When "DPM" : Gosub DPM_INT 
  When "CNX" : Gosub CNX_INT  
 Endcase

 If pat(LTYP,"ADI-*")
  Gosub ADI_INT
 Endif

 [M]UPDWAIINT(I_UPD-1)=LINT

Return

#========================================================================
# Intitulé d'un paramètre de type "Paramètre général"
#========================================================================
$ADP_INT
 If !clalev([F:ADP]) : Local File ADOPAR [ADP] : Endif
 Read [ADP]ADP0="AAS";LPAR
 If !fstat
  Call TEXTE([F:ADP]NAM, LINT) From OBJDIV
 Endif
Return

#========================================================================
# Intitulé d'un paramètre de type "Mode d'amortissement"
#========================================================================
$DPM_INT
 If !clalev([F:DPM]) : Local File DPRMOD [DPM] : Endif 
 Filter [DPM] Where DPM=LPAR
 Read [DPM] First
 If !fstat
  LINT=[F:DPM]DES
 Endif
 Filter [DPM]
Return

#========================================================================
# Intitulé d'un paramètre de type "Table diverse"
#========================================================================
$ADI_INT
 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif 
 Local Char LNUMTAB : LNUMTAB=right$(LTYP,instr(0,LTYP,"-")+1)
 If !fstat
  Call LECTEXTRA(LINT,"ATABDIV","LNGDES",LNUMTAB,LPAR) From ATEXTRA
 Endif
Return

#========================================================================
# Intitulé d'un paramètre de type "Contexte"
#========================================================================
$CNX_INT
 Case LPAR
  When "RATPIOCAA" : LINT=mess(187,200,1)
  When "PROWEK"    : Call TEXTE(21329,LINT) From OBJDIV
  When "ISSSIMPL"  : Call TEXTE(21260,LINT) From OBJDIV
  When "CALCNX"    : LINT=mess(133,7774,1)
  When "FLUX"      : LINT=mess(2,3189,1)
  When Default
 Endcase
Return

######################################################################################
## Sous-pro / fonctions / routines
######################################################################################

#========================================================================
# Raz de la liste des modifications en attente pour un contexte.
#========================================================================
Subprog RAZ_UPD_WAI_CNX(PCPY, PCNX, RCOD)
Value    Char    PCPY          # Société
Value    Integer PCNX          # Contexte
Variable Integer RCOD          # Code retour du sous-programme

#> Constantes

Local Integer LDBG   : LDBG   = 0
Local Integer LSEUIL : LSEUIL = 0

#> Tables

If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

#> Variables

# Lecture du contexte

Read [CNX]CNX0=PCPY;PCNX
If fstat
 RCOD = fstat
 End
Endif

# Raz de la liste des modifications en attente

If !adxlog
 Trbegin [CNX]
 Local Integer LTRS
Endif

Local Integer I_UPD, OK

For I_UPD=1 To 10
 [F:CNX]UPDWAITYP(I_UPD-1)=""
 [F:CNX]UPDWAIPAR(I_UPD-1)=""
 [F:CNX]UPDWAIBCO(I_UPD-1)=0
Next I_UPD
[F:CNX]UPDWAINBR=0

OK=1
Rewrite [F:CNX]
If fstat
 RCOD = fstat+10
 OK=0
Endif

If dim(LTRS)>0
 If OK
  Commit
 Else  
  Rollback
 Endif
Endif


End

#========================================================================
# Indique s'il y a au moins une modification en attente.
#========================================================================
Funprog UPD_WAI_CNX(PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX 

Local Integer  RCOD : RCOD=0

If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

Read [F:CNX]CNX0=PCPY;PCNX
If !fstat
 If [F:CNX]UPDWAINBR>0
  RCOD = 1
 Endif
Endif

End RCOD

#======================================================================== FQ70465
# Indique s'il y a au moins une modification en attente du type demandé
# et du paramètre demandé
#========================================================================
Funprog IS_WAI_CNX(PCPY, PCNX, PUPDTYP, PUPDPAR)
Value    Char    PCPY          # Société
Value    Integer PCNX          # Contexte
Value    Char    PUPDTYP       # Type de paramètre modifié
Value    Char    PUPDPAR       # Nom du paramètre modifié

Local Integer  RCOD : RCOD=0
Local Shortint N_CNX

If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif

For N_CNX = 0 To [F:CNX]UPDWAINBR-1
  If [F:CNX]UPDWAITYP(N_CNX)=PUPDTYP and [F:CNX]UPDWAIPAR(N_CNX)=PUPDPAR
    RCOD = 1
    Break
  Endif
Next

End RCOD

#========================================================================
# Ajout d'une modification en attente.
#
# LSEUIL : nombre de modifications au delà duquel on stocke la modif
#          de paramètrage dans les contextes.
#
#========================================================================
Subprog ADD_UPD_WAI_CNX(PCPY, PCNX, PUPDTYP, PUPDPAR, PUPDVAL, PCLASSE, RCOD)
Value    Char    PCPY          # Société
Value    Integer PCNX          # Contexte
Value    Char    PUPDTYP       # Type de paramètre modifié
Value    Char    PUPDPAR       # Nom du paramètre modifié
Value    Char    PUPDVAL       # Valeur de paramètre
Value    Char    PCLASSE       # Classe [F] ou [M] ouverte à mettre à jour ou blanc pour mise à jour directe
Variable Integer RCOD          # Code retour du sous-programme

#> Constantes

Local Integer LDBG   : LDBG   = 0
Local Integer LSEUIL : LSEUIL = GDIRUPDTSD

#> Tables

If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
If !clalev([F:FAS])  : Local File FXDASSETS [FAS]  : Endif

#> Variables

Local Char    L_CRIT(255)(2)
Local Char    L_CRIT1(255)
Local Char    L_CRIT2(255)
Local Char    L_CRIT3(255)
Local Char    L_CRITFAS(255) : # FQ67765
Local Char    L_CPY
Local Integer L_CNX          : # FQ67765
Local Date    L_EXEDEB
Local Date    L_FINEXE
Local Date    L_DEBPER
Local Date    L_FINPER
Local Integer L_PLN(1..G301MAX-1)
Local Integer I
Local Integer L_NBBCO
Local Integer L_NBENR
Local Integer OK
Local Char    L_SAASREF

# Contrôle de la validité des types et des noms de paramètres reçus

If PUPDTYP<>"ADP"         &  
&  !pat(PUPDTYP,"ADI-*")  & 
&  PUPDTYP<>"DPM"         &
&  PUPDTYP<>"CNX"
 RCOD = 1                  # Type de paramètre incorrect
 End
Endif

Case PUPDTYP
 When "ADP"
  If PUPDPAR<>"DEROENCOUR" & 
&    PUPDPAR<>"IMLRVEISS"  & 
&    PUPDPAR<>"NBEXESTO"   &  
&    PUPDPAR<>"PRVSITUPD"  &
&    PUPDPAR<>"PCOTVAPMV" 
   RCOD = 2
   End
  Endif
 When "DPM"
 When "CNX"
  # FQ66894 : ajout de "FLUX"
  # FQ70465 : ajout de "DESYNC"
  If PUPDPAR<>"RATPIOCAA" & 
&    PUPDPAR<>"PROWEK"    & 
&    PUPDPAR<>"RAT39BIS"  & 
&    PUPDPAR<>"DFDTYP"    & 
&    PUPDPAR<>"DFDCOD"    & 
&    PUPDPAR<>"DFDRAT"    & 
&    PUPDPAR<>"ISSSIPML"  &
&    PUPDPAR<>"CALCNX"    &  
&    PUPDPAR<>"FLUX"      &
&    PUPDPAR<>"DESYNC" 
   RCOD = 2
   End
  Endif
Endcase

# Lecture du contexte

OK=1

If PCLASSE=""
 If !adxlog
  Trbegin [WCNX] : Local Integer LTRS
 Endif

 Read [WCNX]CNX0=PCPY;PCNX
 If fstat
  RCOD = 10+fstat
  End
 Endif
Endif

# Calcul du nombre de biens concernés
Gosub CAL_NB_BCO

# FQ70465 Si c'est un redécoupage, peu importe le nombre de biens concernés, c'est toujours à faire et c'est toujours batch
If PUPDPAR<>"DESYNC"
  # Aucun bien à mettre à jour, on sort
  
  If !L_NBBCO
   Goto FIN_TRS
  Endif
  
  # Si le nombre de biens à modifier est inférieur au seuil, on fait la mise à jour directement
  If L_NBBCO<=LSEUIL
   Call MAJ_DEPSTA(PCPY,PCNX,PUPDTYP,PUPDPAR,PUPDVAL,0,"",RCOD) From UPDWAITRT
   Goto FIN_TRS
  Endif
Endif

# Nombre de bien à mettre à jour >= seuil : on stocke la modif dans les contextes.

If find(PUPDTYP,[F:WCNX]UPDWAITYP) & find(PUPDPAR,[F:WCNX]UPDWAIPAR)
 Goto FIN_TRS
Endif

# DEBUT FQ66894
#If PUPDTYP="CNX" & PUPDPAR="CALCNX"
# For I_UPD = 1 To 10
#  [F:WCNX]UPDWAITYP(I_UPD-1)=""
#  [F:WCNX]UPDWAIPAR(I_UPD-1)=""
#  [F:WCNX]UPDWAIBCO(I_UPD-1)=0
# Next I_UPD 
# [F:WCNX]UPDWAINBR=0
#Endif
If PUPDTYP="CNX" & PUPDPAR="CALCNX"
 For I_UPD = 1 To [F:WCNX]UPDWAINBR
  #If [F:WCNX]UPDWAIPAR(I_UPD-1)="FLUX" and I_UPD > 1 : # FQ70465
  If find([F:WCNX]UPDWAIPAR(I_UPD-1),"FLUX","DESYNC") and I_UPD > 1
    [F:WCNX]UPDWAITYP(0)=[F:WCNX]UPDWAITYP(I_UPD-1)
    [F:WCNX]UPDWAIPAR(0)=[F:WCNX]UPDWAIPAR(I_UPD-1)
    [F:WCNX]UPDWAIBCO(0)=[F:WCNX]UPDWAIBCO(I_UPD-1)
    [F:WCNX]UPDWAINBR+=1
  Endif
  #If [F:WCNX]UPDWAIPAR(I_UPD-1)<>"FLUX" or ([F:WCNX]UPDWAIPAR(I_UPD-1)="FLUX" and I_UPD > 1)  : # FQ70465
  If !find([F:WCNX]UPDWAIPAR(I_UPD-1),"FLUX","DESYNC") or (find([F:WCNX]UPDWAIPAR(I_UPD-1),"FLUX","DESYNC") and I_UPD > 1)
    [F:WCNX]UPDWAITYP(I_UPD-1)=""
    [F:WCNX]UPDWAIPAR(I_UPD-1)=""
    [F:WCNX]UPDWAIBCO(I_UPD-1)=0
    [F:WCNX]UPDWAINBR-=1
  Endif
 Next I_UPD 
Endif
# FIN FQ66894

[F:WCNX]UPDWAITYP([F:WCNX]UPDWAINBR)=PUPDTYP
[F:WCNX]UPDWAIPAR([F:WCNX]UPDWAINBR)=PUPDPAR
[F:WCNX]UPDWAIBCO([F:WCNX]UPDWAINBR)=L_NBBCO
[F:WCNX]UPDWAINBR+=1

If PCLASSE="" Then
 Rewrite [F:WCNX]
 If !fstat
  OK=1 
 Else
  RCOD= 20+fstat
  OK=0
 Endif
Else
 For I_UPD = 1 To 10
  Assign PCLASSE+"UPDWAITYP(I_UPD-1)" With [F:WCNX]UPDWAITYP(I_UPD-1)
  Assign PCLASSE+"UPDWAIPAR(I_UPD-1)" With [F:WCNX]UPDWAIPAR(I_UPD-1)
  Assign PCLASSE+"UPDWAIBCO(I_UPD-1)" With [F:WCNX]UPDWAIBCO(I_UPD-1)
 Next I_UPD 
 Assign PCLASSE+"UPDWAINBR" With [F:WCNX]UPDWAINBR
Endif

$FIN_TRS

If PCLASSE="" Then
 If dim(LTRS)>0
  If OK
   Commit
  Else
   Rollback
  Endif
 Endif
Endif
End

#========================================================================
$CAL_NB_BCO

 #Local Char LLSTPLN : # FQ67765

 #> Société
 
 L_CPY = PCPY

 #> Contexte
 
 L_CNX = PCNX : # FQ67765

 #> Recherche des dates
 Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA

 L_DEBEXE=[F:WFIS]DATSTRFIY
 L_FINEXE=[F:WFIS]DATENDFIY
 L_DEBPER=[F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
 L_FINPER=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)

 # FQ67765 : on utilise le nouveau champs CNX de DEPREC plutôt que de passer par une liste de plans
 #> Plans à inclure dans la recherche
 # For I=1 To [F:CNX]NBPLC
 #  If [F:CNX]PLNCAA(I-1)
 #   L_PLN(I)=[F:CNX]PLNCAA(I-1)
 #    FQ67765
 #   If LLSTPLN=""
 #    LLSTPLN =num$([F:CNX]PLNCAA(I-1))
 #   Else
 #    LLSTPLN+=","+num$([F:CNX]PLNCAA(I-1))
 #   Endif
 #  Else
 #   L_PLN(I)=0
 #  Endif
 #Next I

 #> Calcul du nombre de biens concernés par la modif
 Gosub INIT_CRITERES From UPDWAICNX

 Local File DEPREC    [DEP]
 L_NBBCO=0 : L_NBENR=0
 Case PUPDTYP

  When "ADP"
   Case PUPDPAR
    When "DEROENCOUR" : Gosub NBR_DEROENCOUR From UPDWAICOM
    When "IMLRVEISS"  : Gosub NBR_IMLRVEISS  From UPDWAICOM
    When "NBEXESTO"   : Gosub NBR_NBEXESTO   From UPDWAICOM
    When "PRVSITUPD"  : Gosub NBR_PRVSITUPD  From UPDWAICOM
    When "PCOTVAPMV"  : Gosub NBR_PCOAMTPMV  From UPDWAICOM   : # FQ64478
   Endcase

  When "DPM"
   Gosub NBR_DPM From UPDWAICOM

  When "CNX"
   Case PUPDPAR
    When "CALCNX"    : Gosub NBR_CALCNX    From UPDWAICOM
    When "PROWEK"    : Gosub NBR_PROWEK    From UPDWAICOM
    When "RAT39BIS"  : Gosub NBR_RAT39BIS  From UPDWAICOM
    When "DFDTYP"    : Gosub NBR_DFDTYP    From UPDWAICOM
    When "DFDCOD"    : Gosub NBR_DFDCOD    From UPDWAICOM
    When "DFDRAT"    : Gosub NBR_DFDRAT    From UPDWAICOM
    When "FLUX"      : Gosub NBR_FLUX      From UPDWAICOM   : # FQ66894
    When "DESYNC"    : Gosub NBR_DESYNC    From UPDWAICOM   : # FQ70465
   Endcase

  When Default

   If pat(PUPDTYP,"ADI-*")
    Case right$(PUPDTYP,instr(0,PUPDTYP,"-")+1)
     When "512"
      L_CRIT2="PROSHFTYP=PUPDPAR"
     When "531"
      L_CRIT2="CRBVEHCOD=PUPDPAR"      
    Endcase
   Endif

 Endcase
 Close Local File [DEP]
 
Return

#========================================================================
$NBR_BCO
 If L_CRIT1="" : L_CRIT1="1=1" : Endif
 If L_CRIT2="" : L_CRIT2="1=1" : Endif
 If L_CRIT3="" : L_CRIT3="1=1" : Endif
 Filter [F:DEP] Where evalue(L_CRIT1) & evalue(L_CRIT2) & evalue(L_CRIT3)
 For [F:DEP]DEP0
  If L_SAASREF<>[F:DEP]AASREF
   L_NBBCO+=1
   L_SAASREF=[F:DEP]AASREF
  Endif  
  L_NBENR+=1
 Next
 Filter [F:DEP]
Return

#========================================================================
$LST_UPD_CNX
 If GTRACE=""
  Call OUVRE_TRACE(mess(141,7774,1)) From LECFIC
  Local Integer L_TRACE
 Endif

 Local Char    S_CPY, LIGNE(100)
 Local Integer I_UPD
 If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif
 If !clalev([F:WCPY]) : Local File COMPANY [WCPY] : Endif

 For [WCPY]
  Filter [WCNX] Where (UPDWAINBR>0 & CPY=[F:WCPY]CPY)
   #Fq-81074 If rowcount([F:WCNX])>0
   Look[WCNX]
   If fstat=0
   Call ECR_TRACE("O "+mess(2,45,1)-[F:WCPY]CPY-[F:WCPY]CPYNAM,0) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
    For [WCNX]
     Call ECR_TRACE(" #> "+mess(521,7773,1)-mess([F:WCNX]CNX,3100,1),0) From GESECRAN
     For I_UPD=0 To [F:WCNX]UPDWAINBR-1
      LIGNE=space$(5)+
&           [F:WCNX]UPDWAITYP(I_UPD)+space$(10-len([F:WCNX]UPDWAITYP(I_UPD)))+
&           [F:WCNX]UPDWAIPAR(I_UPD)+space$(20-len([F:WCNX]UPDWAITYP(I_UPD)))+
&           num$([F:WCNX]UPDWAIBCO(I_UPD))+space$(20-len(num$([F:WCNX]UPDWAITYP(I_UPD))))
      Call ECR_TRACE(LIGNE,0) From GESECRAN
     Next I_UPD
    Next
   Call ECR_TRACE("",0) From GESECRAN
  Endif
 Next

 If dim(L_TRACE)>0
  Call LEC_TRACE() From LECFIC
 Endif

Return

#======================================================================== FQ67765
$INIT_CRITERES
 L_CRIT1   ="CPY=L_CPY & FIYSTRDAT=L_DEBEXE & PERSTRDAT=L_DEBPER & CNX=L_CNX" 
 L_CRITFAS ="CPY=L_CPY & ENAFAS=G_OUI & ISSFIYPRE <> G_OUI & OWNTYP <> GVML_TDMODEL & OWNTYP <> GVML_TDANNUL"  : # FQ67765
 L_CRITFAS-="& (GACACN=GVML_NIENSER | GACACN=GVML_NIENCOU | IASACN=GVML_NIENSER | IASACN=GVML_NIENCOU)"        : # FQ67765
Return

######################################################################################
## ACTIONS / CHAMP du masque UPDWAICNX
######################################################################################


