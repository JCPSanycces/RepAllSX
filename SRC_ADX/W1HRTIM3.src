#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:48"
A_USER  = "DOC"
A_STAMP = "20181109230448"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRTIM3 [HRTIM3]
Gosub HORODAT
Local Inpbox "HRTIM3" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRTIM3] As [SIM_]
Grizo [HRTIM3]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRTIM3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=18
Return

$ON_AUZPRH
Onevent INIT_AREA Call D_AUZPRH(zc) From W1HRTIM3
Onevent BEFORE_INPUT Call AS_AUZPRH(zc) From W1HRTIM3
Return

Subprog D_AUZPRH(VALEUR)
Variable Integer VALEUR
If varinit([M]AUZPRH,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_AUZPRH(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DESIGN
Onevent INIT_AREA Call D_DESIGN(zc) From W1HRTIM3
Onevent CONTROL Call C_DESIGN(zc) From W1HRTIM3
Onevent BEFORE_INPUT Call AS_DESIGN(zc) From W1HRTIM3
Onevent AFTER_CHANGE Gosub AMM_DESIGN From W1HRTIM3
Return

Subprog D_DESIGN(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESIGN,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10701","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10701") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DESIGN(zc) From W1HRTIM3
Onkey   2 Titled GBOUTS Call S_DESIGN(zc) From W1HRTIM3
Onkey 144 Titled GBOUTP Call P_DESIGN(zc) From W1HRTIM3
Onkey 146 Titled GBOUTA Call SA_DESIGN(zc) From W1HRTIM3
Gosub _AFF
End

Subprog C_DESIGN(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10701","") From SUBADI
If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10701",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
Endif
Gosub _AFF
End

$AMM_DESIGN
Call AM_DESIGN(zc)
If !mkstat & GOBJET
 zoncou = "DESIGN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DESIGN(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZDESIGN)")>indice
 [M]DESIGN(indice) = VALEUR
 Affzo ZDESIGN(indice)
Endif
Gosub _AFF
End

Subprog S_DESIGN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10701"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DESIGN(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10701") From GOBJET
Gosub _AFF
End

Subprog SA_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10701"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DESIGN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10701"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZDESIGN
Onevent BEFORE_AREA Gosub AV_ZDESIGN From W1HRTIM3
Return

$AV_ZDESIGN
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10701",num$([M]DESIGN(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_AUZCAL
Onevent AFTER_CHANGE Gosub AMM_AUZCAL From W1HRTIM3
Onevent INIT_AREA Call D_AUZCAL(zc) From W1HRTIM3
Onevent BEFORE_INPUT Call AS_AUZCAL(zc) From W1HRTIM3
Return

Subprog D_AUZCAL(VALEUR)
