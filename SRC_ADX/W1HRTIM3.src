Endif
Gosub _AFF
End

$AMM_AUZCAL
Call AM_AUZCAL(zc)
If !mkstat & GOBJET
 zoncou = "AUZCAL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AUZCAL(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_AUZCAL(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "AUZCAL" : GZNUM = 55898 : Endif
Gosub _AFF
End

