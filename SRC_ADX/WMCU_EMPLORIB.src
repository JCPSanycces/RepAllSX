#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank ID statement
# Supervisor
## CRUD-CLASSE ## EMPLORIB
# 2018-11-06 07:06:27 265


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLORIB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLORIB

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub AVARIABLES From WMC00EMPLORIB
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLORIB.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLORIB
Else
 Gosub AUPDATE_EMPLORIB
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLORIB.freeSnapshot
EMPLORIB.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLORIB.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLORIB.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLORIB.ASTALIN)<>""
 [L]A_ASTALIN = EMPLORIB.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLORIB.ASTALIN)<>""
 [L]A_ASTALIN = EMPLORIB.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLORIB
Trbegin [F:RIB]
 Gosub AUPDATE_EMPLORIB
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLORIB
[L]A_ASTALIN = EMPLORIB.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLORIB._MAJSQL_EMPLORIB(EMPLORIB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLORIB.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLORIB.snapshotEnabled=1
 [L]A_RETIK = EMPLORIB.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLORIB.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLORIB.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLORIB.ASTALIN = [V]CST_ALL
Endif
Return



