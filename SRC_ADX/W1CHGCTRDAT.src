#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CHGCTRDAT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:06"
A_USER  = "DOC"
A_STAMP = "20181109230306"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CHGCTRDAT [CHG]
Gosub HORODAT
Local Inpbox "CHGCTRDAT" From GFONCTION At A_STAMP With A_WINDPREV Mask [CHG] As [SIM_]
Grizo [CHG]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CHG]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=39 : X2(0)=73 : Y1(0)=13 : Y2(0)=15
Return

$ON_CTRDAT
Onevent CONTROL Call C_CTRDAT(zc) From W1CHGCTRDAT
Onevent INIT_AREA Call D_CTRDAT(zc) From W1CHGCTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1CHGCTRDAT
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "D:"+GFMDAT4
Gosub _AFF
Return

Subprog D_CTRDAT(VALEUR)
Variable Date    VALEUR
If varinit([M]CTRDAT,indice)=0
 VALEUR = [M:CTR0]CTRDAT
Endif
Gosub _AFF
End

Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRDAT" : GZNUM = 47200 : Endif
If !mkstat
 ## Action STD
 Call C_CTRDAT(VALEUR) From CHGCTRDAT
 If mkstat : GERR = 1 : GZONE = "CTRDAT" : GZNUM = 47200 : Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


