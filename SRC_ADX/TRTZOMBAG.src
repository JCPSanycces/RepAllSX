#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "TRT_DIV"    : Gosub TRT_DIV
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
Endcase
Return

$TRT_DIV
Case TRAIT
 When "ZOOMFACT"  : Gosub ZOOMFACT
 When "ZOOMPIECE" : Gosub ZOOMPIECE
Endcase
Return

$SEL_LISTE
Case LISTE
 When "ZOOMREGL" : Gosub L_ZOOMREGL
Endcase
Return

$VERF_LISTE
Case LISTE
 When "ZOOMREGL" : Gosub V_ZOOMREGL
Endcase
Return

###################################################################
$ZOOMFACT
Gosub SETNOL
Raz [M]BIDOBJ, [M]BIDCLE1, [M]BIDCLE2
Case GBOUT2
    When mess(43,109,1) : # Facture tiers client
        If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
        Call LECTURE("BIC",[M]NUM(NOL),"") From CONTOBJ
        If !fstat : [M]BIDOBJ = "BIC" :  Endif
    When mess(44,109,1) : # Facture tiers fournisseur
        If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
        Call LECTURE("BIS",[M]NUM(NOL),"") From CONTOBJ
        If !fstat : [M]BIDOBJ = "BIS" : Endif
    When mess(45,109,1) : # Facture vente
        If clalev([F:SIV])=0 : Local File SINVOICEV [SIV] : Endif 
        Call LECTURE("SIH",[M]NUM(NOL),"") From CONTOBJ
        If !fstat : [M]BIDOBJ = "SIH" : Endif
    When mess(46,109,1) : # Facture achat
        If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif 
        Call LECTURE("PIH",[M]NUM(NOL),"") From CONTOBJ
        If !fstat : [M]BIDOBJ = "PIH" : Endif
Endcase
[M]BIDCLE1  = [M]NUM(NOL)
Return

###################################################################
$ZOOMPIECE
Gosub SETNOL
Raz [M]BIDOBJ, [M]BIDCLE1, [M]BIDCLE2
Read [HAE]HAE0 = [M]TYP(NOL);[M]NUM(NOL)
If !fstat
    [M]BIDOBJ = "GAS" 
    [M]BIDCLE1  = [M]NUM(NOL)
    [M]BIDCLE2  = [M]TYP(NOL)
Endif
Return

###################################################################
$L_ZOOMREGL
Gosub SETNOL
Raz [M]BIDOBJ, [M]BIDCLE1, [M]BIDCLE2

If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
If !clalev([F:PYD]) : Local File PAYMENTD  [PYD] : Endif

Link [PYD] With [PYH]PYH0=NUM 
& As [LNK] 

For [LNK]PYD0(1) Where VCRTYP=[M]TYP(NOL) and VCRNUM=[M]NUM(NOL)
 NBTEX +=1
 TEXTE(NBTEX) = [F:PYD]NUM
 TEX(NBTEX)   = [F:PYD]NUM
Next

Return

$V_ZOOMREGL
[M]BIDOBJ   = "PAY" 
[M]BIDCLE1  = TEX(CHOIX)
Return


###################################################################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

