#<AdxTL>@(#)6.0.0.0 $Revision$
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# FPE     27.03.2018 X3-71603 : Update [DUD]BPAPAY if [DUD]BPRPAY      #
#                               is updated.                            #
########################################################################

Local Char PARAM(10)(1..10) , VALEUR(10)
# Fusion des Comptes
#PARAM(1) = "1"
#Call TRAITE_CHAR(VALEUR,PARAM,"","GACMERGE","UTIGACMER",3,"") From GTRAITE
# Fusion des Tiers
PARAM(1) = "2"
Call TRAITE_CHAR(VALEUR,PARAM,"","GACMERGE","UTIBPRMER",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

###################################

$OUVRE
If clalev([F:CPY])=0  : Local File COMPANY [CPY]     : Endif
If clalev([F:CPY2])=0 : Local File COMPANY [CPY2]    : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY]    : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD [PER]      : Endif
If clalev([F:CMM])=0  : Local File GCOMMIT [CMM]     : Endif
If clalev([F:CMD])=0  : Local File GCOMMITD [CMD]    : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY [HAE]   : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAA])=0  : Local File GACCENTRYA [DAA]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE [BAL]     : Endif
If clalev([F:BLA])=0  : Local File BALANA [BLA]      : Endif
If clalev([F:BLM])=0  : Local File BLACMM [BLM]      : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY [BLQ]      : Endif
If clalev([F:JST])=0  : Local File GAJOUSTA [JST]    : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT [GAC]    : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER [BPR]    : Endif
If clalev([F:MTC])=0  : Local File MATCHCODE   [MTC] : Endif
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
# Issue X3-71603
If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
# End issue number
## Historisation des échéances
If func AFNC.ACTIV("HDU")
 If clalev ([F:HDU])=0  : Local File HISTODUD   [HDU]  : Endif
Endif
# Preconsolidation
If func AFNC.ACTIV("PRCSL")
 If clalev ([F:BLP])=0  : Local File BALPRECSL   [BLP]  : Endif
Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Return

$INIT
Gosub OUVRE
TMP = 1
Return

$CONTROLE
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Return : Endif
Case val(PARAM(1))
 When 1 : Call VERIF(1,[M:DIA]COA,[M:DIA]CPTORG,[M:DIA]CPTDES,GSERVEUR)
 When 2 : Call VERIF(2,"",[M:DIA]BPRORG,[M:DIA]BPRDES,GSERVEUR)
Endcase
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

$EXEC
Case val(PARAM(1))
 When 1 : TIT = mess(59,107,1)  :# Fusion de comptes
 When 2 : TIT = mess(65,107,1)  :# Fusion de tiers
Endcase
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 If [M]CPY<>"" :  Call ECR_TRACE(mess(2,45,1)-" : "-[M]CPY,0) From GESECRAN : Endif
 If [M]FCY<>"" :  Call ECR_TRACE(mess(3,45,1)-" : "-[M]FCY,0) From GESECRAN : Endif
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

Case val(PARAM(1))
 When 1 : Call MERGE(1,[M:DIA]COA,[M:DIA]CPTORG,[M:DIA]CPTDES,GSERVEUR)
 When 2 : Call MERGE(2,"",[M:DIA]BPRORG,[M:DIA]BPRDES,GSERVEUR)
Endcase

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return

####################################################################

Subprog VERIF(TYPCPT,PLAN,CPTORG,CPTDES,BATCH)
Value Integer TYPCPT
Value Char    PLAN
Value Char    CPTORG
Value Char    CPTDES
Value Integer BATCH

Local Integer NBRLEDTYP
Local Integer LEDTYPLIST(0..len(mess(0,2644,1))-1)

Gosub CRITSOC

# Vérifs
Local Integer LET1 , LET2
# Pas d'écriture sur un exercice clôturé

For [CPY2]CPY0 Where CPYLEGFLG=2 & LEG=GCURLEG & evalue(CRIT_SOC)
 #types de référentiel utilisés
 Call SETLEDTYPLIST([F:CPY2]CPY,PLAN,NBRLEDTYP,LEDTYPLIST) From CPTDIV
 For J=0 To NBRLEDTYP-1
  Gosub CRITERE

  Filter [FIY] Where CPY=[F:CPY2]CPY & LEDTYP=LEDTYPLIST(J) & FIYSTA>2
  Read [FIY] Last
  Filter [FIY]
  If fstat=0
   Case TYPCPT
    When 1
     Filter [DAE] Where CPY=[F:CPY2]CPY & LEDTYP=LEDTYPLIST(J) & ACC=CPTORG & ACCDAT<=[F:FIY]FIYEND
    When 2
     Filter [DAE] Where CPY=[F:CPY2]CPY & BPR=CPTORG & ACCDAT<=[F:FIY]FIYEND
   Endcase
   Read [DAE]DAE1 First
   Filter [DAE]
   If fstat=0
    # Société ... Ecritures sur exercice clôturé
    GMESSAGE = mess(2,116,1)-[F:CPY2]CPY-"\"+mess(60,107,1)+"\"+format$("D:"+GFMDAT,[F:DAE]ACCDAT)
    GERR = 1 : Break 2
   Endif
  Endif

  Filter [PER] Where CPY=[F:CPY2]CPY & LEDTYP=LEDTYPLIST(J) & PERSTA=3 : # Fermée
  Read [PER] Last
  Filter [PER]
  If fstat=0
   Case TYPCPT
    When 1
     Filter [DAE] Where CPY=[F:CPY2]CPY & LEDTYP=LEDTYPLIST(J) & ACC=CPTORG & ACCDAT<=[F:PER]PEREND
    When 2
     Filter [DAE] Where CPY=[F:CPY2]CPY & BPR=CPTORG & ACCDAT<=[F:PER]PEREND
   Endcase
   Read [DAE]DAE1 First
   Filter [DAE]
   If fstat=0
    # Société ... Ecritures sur période clôturée
    GMESSAGE = mess(2,116,1)-[F:CPY2]CPY-"\"+mess(162,107,1)+"\"+format$("D:"+GFMDAT,[F:DAE]ACCDAT)
    GERR = 1 : Break 2
   Endif
  Endif

 Next J
Next

If GERR : End : Endif

# Compatibilité du lettrage
If TYPCPT=1
 Read [GAC]GAC0 = [L]PLAN;[L]CPTORG
 LET1 = [F:GAC]MTC
 Read [GAC]GAC0 = [L]PLAN;[L]CPTDES
 LET2 = [F:GAC]MTC
 If LET1<>LET2
  GMESSAGE = [L]CPTORG-":"
  If LET1=2 : GMESSAGE -= mess(46,110,1) : Else : GMESSAGE -= mess(36,110,1) : Endif
  GMESSAGE += "\"+[L]CPTDES-":"
  If LET2=2 : GMESSAGE -= mess(46,110,1) : Else : GMESSAGE -= mess(36,110,1) : Endif
  GERR = 3
 Endif
Endif
End

############################

Subprog MERGE(TYPCPT,PLAN,CPTORG,CPTDES,BATCH)
Value Integer TYPCPT
Value Char    PLAN
Value Char    CPTORG
Value Char    CPTDES
Value Integer BATCH

Local Integer OK , LET1 , LET2
Local Char    TIT(30)
Local Date    DATMIN , DATMAX
Local Decimal EXERCICE , PERIODE
Local Integer NONAT
Local Integer J

Local Char    TBCCE(GLONCCE)(1..9)
Local Integer AX

Local Integer NBRLEDTYP
Local Integer LEDTYPLIST(0..len(mess(0,2644,1))-1)

Local Integer FLGMTC
Local Char    MTCORG(10), MTCDES(10)

Case TYPCPT
 When 1 : TIT = mess(59,107,1) : # Fusion de comptes
 When 2 : TIT = mess(65,107,1) : # Fusion de tiers
Endcase

If GSERVEUR
 Call ECR_TRACE(TIT,0) From GESECRAN
Endif

# Traitement
Gosub CRITSOC
DATMAX = [31/12/2999]
For [CPY2]CPY0 Where CPYLEGFLG=2 & LEG=GCURLEG & evalue(CRIT_SOC)
 Call SETLEDTYPLIST([F:CPY2]CPY,PLAN,NBRLEDTYP,LEDTYPLIST) From CPTDIV
 Call DEBTRANS From GLOCK
 GSOCIETE =  [F:CPY2]CPY
 Gosub TR1
 If GOK<1 : Break : Endif
Next
If GOK=1
 Call ECR_TRACE(CPTORG-"=>"-CPTDES,0) From GESECRAN
Endif
End

$TR1
GOK=1
Trbegin [DAE] , [CMD] , [BAL] , [JST] , [DUD]

 For J=0 To NBRLEDTYP-1
  Gosub CRITERE

  # Ecritures
  Case TYPCPT
   When 1 : Filter [DAE] Where CPY=[F:CPY2]CPY & ACC=CPTORG & evalue(CRIT_FCY_B)
   When 2 : Filter [DAE] Where CPY=[F:CPY2]CPY & BPR=CPTORG & evalue(CRIT_FCY_B)
  Endcase

  DATMIN = DATMAX

  For [DAE]DAE1
   DATMIN = min(DATMIN,[F:DAE]ACCDAT)
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   If fstat
    GOK = 0 : Call RSTA("HAE",[F:DAE]TYP-[F:DAE]NUM) From GLOCK : Break
   Endif
   Call BALANCE(-1) From CPTBAL
   If GOK<1 : Break : Endif
   Call VALSTA("GAS",-1) From SUBPS2
   If GOK<1 : Break : Endif

   # Gestion de la nature à l'américaine
   If TYPCPT=1
    Read [GAC]GAC0 = [M:DIA]COA;CPTDES
    For [DAA]DAA0 Where TYP=[F:DAE]TYP & LEDTYP=LEDTYPLIST(J) & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN
     If [F:DAA]ACC<>""
      Call BALANA(-1) From CPTBAL
      If GOK<1 : Break 2 : Endif
     Endif
     [F:DAA]ACC = [F:GAC]ACC
     If [F:DAA]ACC<>""
      Call BALANA(+1) From CPTBAL
      If GOK<1 : Break 2 : Endif
     Endif
     Rewrite [DAA]
     If fstat
      GOK=0 : Call FSTA("DAA") From GLOCK : Break 2
     Endif
    Next
    [F:DAE]ACC = [F:GAC]ACC
   Endif

   If TYPCPT=2
    For [DAA]DAA0 Where TYP=[F:DAE]TYP & LEDTYP=LEDTYPLIST(J) & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN
     If [F:DAA]BPR=CPTORG
      Call BALANA(-1) From CPTBAL
      If GOK<1 : Break 2 : Endif
      [F:DAA]BPR = CPTDES
      Call BALANA(+1) From CPTBAL
      If GOK<1 : Break 2 : Endif
      Rewrite [DAA]
      If fstat
       GOK=0 : Call FSTA("DAA") From GLOCK : Break 2
      Endif
     Endif
    Next
   Endif

   Case TYPCPT
    When 1 : [F:DAE]ACC = CPTDES
    When 2 : [F:DAE]BPR = CPTDES
   Endcase
   Rewrite [DAE]
   If fstat
    GOK=0 : Call FSTA("DAE") From GLOCK : Break
   Endif

   Call BALANCE(+1) From CPTBAL
   If GOK<1 : Break : Endif

   Call VALSTA("GAS",+1) From SUBPS2
   If GOK<1 : Break : Endif

   # contrepartie
   For [DAE2]DAE0 Where TYP=[F:DAE]TYP & LEDTYP=LEDTYPLIST(J) & NUM=[F:DAE]NUM & OFFACC=CPTORG
    [F:DAE2]OFFACC = CPTDES
    Rewrite [DAE2]
    If fstat
     GOK=0 : Call FSTA("DAE2") From GLOCK : Break 2
    Endif
   Next :#[DAE2]

  Next :#[DAE1]
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  # Echéances
  If TYPCPT=2
    # Issue X3-71603
    Local Tinyint WTIMEC, WTIMES  # To know whether we need
    WTIMEC = 0 : WTIMES = 0       # to read BPC/BPS or not.
    Local Char WADDREC(5), WADDRESS(5)  # Customer & Supplier addresses
    WADDREC = "" : WADDRESS = ""
    # End issue X3-71603
   Filter [DUD] Where evalue(CRITERE) and (BPR=CPTORG or BPRPAY=CPTORG)
   For [DUD]
    If [F:DUD]BPR=CPTORG    : [F:DUD]BPR    = CPTDES : Endif
    If [F:DUD]BPRPAY=CPTORG
      [F:DUD]BPRPAY = CPTDES
# Issue X3-71603
      Case [F:DUD]BPRTYP
        When 1  # Customer
          If WTIMEC = 0
            WTIMEC = 1
            Read [BPC]BPC0 = CPTDES
            If !fstat
              WADDRESC = [F:BPC]BPAADD
            Else
              GOK = 0 : Call FSTA("BPC") From GLOCK : Break
            Endif
          Endif
          [F:DUD]BPAPAY = WADDRESC
        When 2  # Supplier
          If WTIMES = 0
            WTIMES = 1
            Read [BPS]BPS0 = CPTDES
            If !fstat
              WADDRESS = [F:BPS]BPAADD
            Else
              GOK = 0 : Call FSTA("BPS") From GLOCK : Break
            Endif
          Endif
          [F:DUD]BPAPAY = WADDRESS
      Endcase
# End issue X3-71603
    Endif
    Rewrite [DUD]
    If fstat
     GOK = 0 : Call FSTA("DUD") From GLOCK : Break
    Endif
   Next :#[DUD]
   Filter [DUD]
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
   ## Historisation des échéances
   If func AFNC.ACTIV("HDU")
    Filter [HDU] Where evalue(CRITERE) and (BPR=CPTORG or BPRPAY=CPTORG)
    For [HDU]
     If [F:HDU]BPR=CPTORG    : [F:HDU]BPR    = CPTDES : Endif
     If [F:HDU]BPRPAY=CPTORG : [F:HDU]BPRPAY = CPTDES : Endif
     Rewrite [HDU]
     If fstat
      GOK = 0 : Call FSTA("HDU") From GLOCK : Break
     Endif
    Next
    Filter [HDU]
    If   GOK<0 : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif
   Endif
  Endif

  # Engagements
  Case TYPCPT
   When 1 : # Les comptes sont dans les lignes
    Filter [CMD] Where evalue(CRIT_CMD) & ACC=CPTORG
    For [CMD]
     Read [CMM]CMM0 = [F:CMD]NUM
     Call CORBLACMM(-1) From CPTENG
     If GOK<1 : Break : Endif
     #
     [F:CMD]ACC(LEDTYPLIST(J)-1) = CPTDES
     Rewrite [CMD]
     If fstat
      GOK = 0 : Call FSTA("CMD") From GLOCK : Break
     Endif
     #
     Call CORBLACMM(+1) From CPTENG
     If GOK<1 : Break : Endif
    Next

   When 2 : # Les tiers sont dans l'entête #68150 & dans les lignes !
    Filter [CMM] Where evalue(CRITERE) and BPR=CPTORG
    For [CMM]
     [F:CMM]BPR = CPTDES
     Rewrite [CMM]
     If fstat
      GOK = 0 : Call FSTA("CMM") From GLOCK : Break
     Endif
     #Dmd 68150 : il manquait ici la maj des lignes d'engagement
     Filter [CMD] Where NUM=[F:CMM]NUM & BPRACC=CPTORG
     For [CMD]CMD0
      Call CORBLACMM(-1) From CPTENG
      If GOK<1 : Break 2 : Endif
      #
      [F:CMD]BPRACC = CPTDES
      Rewrite [CMD]
      If fstat
       GOK=0 : Call FSTA("CMD") From GLOCK : Break 2
      Endif
      #
      Call CORBLACMM(+1) From CPTENG
      If GOK<1 : Break 2 : Endif
     Next
    Next
  Endcase

  Filter [CMD]
  Filter [CMM]

  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  # Balance
  Case TYPCPT
   When 1 : Delete [BAL] Where evalue(CRITERE_B) & ACC=CPTORG & CPY=[F:CPY2]CPY
            If func AFNC.ACTIV("PRCSL")
             Delete [BLP] Where evalue(CRITERE_B) & ACC=CPTORG & CPY=[F:CPY2]CPY
            Endif
   When 2 : Delete [BAL] Where evalue(CRITERE) & BPR=CPTORG & CPY=[F:CPY2]CPY
  Endcase
  If fstat=1
   GOK=-1 : GLOCK="$BALANCE"-CPTORG : Goto ROLL_TR1
  Endif
  If TYPCPT=1
   Delete [BLA] Where ACC=CPTORG & evalue(CRIT_CNA)
   If fstat=1
    GOK=-1 : GLOCK="$BALANA"-CPTORG : Goto ROLL_TR1
   Endif
  Else # WHEN TYPCPT=2
   #X3-35394 - previous BP recor not deletd in BALANA
   Delete [BLA] Where BPR=CPTORG & evalue(CRITERE)
   If fstat=1
    GOK=-1 : GLOCK="$BALANA"-CPTORG : Goto ROLL_TR1 # RollBack si erreur
   Endif
   # Check also in BLAQTY
   Delete [BLQ] Where BPR=CPTORG & evalue(CRITERE)
   If fstat=1
    GOK=-1 : GLOCK="$BLAQTY"-CPTORG : Goto ROLL_TR1 # RollBack si erreur
   Endif
   # FIN -- X3-35394
   #68150
   Delete [BLM] Where BPR=CPTORG & evalue(CRITERE)
   If fstat=1
    GOK=-1 : GLOCK="$BLACMM"-CPTORG : Goto ROLL_TR1
   Endif
  Endif

  # MATCHCODE : Table des lettre à utiliser
  If !FLGMTC : Gosub TR2 : Endif

  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

 Next
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
[L]FLGMTC = 1  # A faire un seule fois pour le couple COA+ACC+BPR

# Table MATCHCODE
# MTCORG = lettre d'origine
# MTCDES = lettre destination

Case TYPCPT
 When 1 :

   Raz MTCORG
   Read [GAC]GAC0 = PLAN;CPTORG
   If !fstat
    Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;""
    If !fstat
     [L]MTCORG = [F:MTC]MTC
    Endif
   Endif

   Raz MTCDES
   Read [GAC]GAC0 = PLAN;CPTDES
   If !fstat
    Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;""
    If !fstat
     [L]MTCDES = [F:MTC]MTC
     If [L]MTCORG<>"" & len([L]MTCDES)<len([L]MTCORG) or (len([L]MTCDES)=len([L]MTCORG) & [L]MTCDES<[L]MTCORG)
      [F:MTC]MTC = [L]MTCORG
      Rewrite [MTC]
      If fstat
       GOK = 0 : Call FSTA("MTC") From GLOCK
      Endif
     Endif
    Elsif [L]MTCORG<>""
     Raz [F:MTC]
     [F:MTC]COA = [F:GAC]COA
     [F:MTC]ACC = [F:GAC]ACC
     [F:MTC]BPR = ""
     [F:MTC]MTC = [L]MTCORG
     Write [MTC]
     If fstat
      GOK = 0 : Call FSTA("MTC") From GLOCK
     Endif
    Endif
   Endif

 When 2 :

   Filter [DAE3] Where CPY=[F:CPY2]CPY & BPR=CPTDES & evalue(CRIT_FCY) Order By Key CLE=COA;ACC;ACCNUM
   For [F:DAE3]CLE(2)

    Raz MTCORG, MTCDES
    Read [GAC]GAC0 = [F:DAE3]COA;[F:DAE3]ACC
    If !fstat
     Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;CPTORG
     If !fstat
      [L]MTCORG = [F:MTC]MTC
     Endif
     Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;CPTDES
     If !fstat
      [L]MTCDES = [F:MTC]MTC
      If [L]MTCORG<>"" & len([L]MTCDES)<len([L]MTCORG) or (len([L]MTCDES)=len([L]MTCORG) & [L]MTCDES<[L]MTCORG)
       [F:MTC]MTC = [L]MTCORG
       Rewrite [MTC]
       If fstat
        GOK = 0 : Call FSTA("MTC") From GLOCK : Break
       Endif
      Endif
     Elsif [L]MTCORG<>""
      Raz [F:MTC]
      [F:MTC]COA = [F:GAC]COA
      [F:MTC]ACC = [F:GAC]ACC
      [F:MTC]BPR = CPTDES
      [F:MTC]MTC = [L]MTCORG
      Write [MTC]
      If fstat
       GOK = 0 : Call FSTA("MTC") From GLOCK : Break
      Endif
     Endif
    Endif
   Next
Endcase
Filter [DAE3]
Return

###########################################
##   définition critère sur la société   ##
###########################################
$CRITSOC
Local Char    CRIT_SOC(250)
CRIT_SOC = "1=1"
If [M:DIA]ALLCPY<>2
 CRIT_SOC -= "& CPY='"+[M:DIA]CPY+"'"
Endif
Return

###########################################################################################
# Filtre sur la société et le site pour la fusion de compte
# Idem pour la fusion de tiers
###########################################################################################
$CRITERE
Local Char CRITERE(250), CRITERE_B(250),CRIT_FCY(250), CRIT_FCY_B(250),  CRIT_CMD(250)

CRITERE   = "1=1"
CRIT_FCY  = "1=1"
CRIT_CMD  = "1=1"

# Company
# If all cpy the should take care of Legislation : leg cpy = screen leg
If [M:DIA]ALLCPY<>2
 CRITERE  -= "& CPY='"+[M:DIA]CPY+"'"
 CRIT_CMD -= "& CPY='"+[M:DIA]CPY+"'"
Endif

# Site
If [M:DIA]ALLFCY<>2
 CRITERE  -= "& FCY='"+[M:DIA]FCY+"'"
 CRIT_FCY -= "& FCYLIN='"+[M:DIA]FCY+"'"
 CRIT_CMD -= "& FCYLIN='"+[M:DIA]FCY+"'"
Elsif GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 CRITERE  -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
 CRIT_FCY -= "& find(FCYLIN,GUSRFCY(1..GNBAUZ))"
 CRIT_CMD -= "& find(FCYLIN,GUSRFCY(1..GNBAUZ))"
Endif

CRITERE_B  = CRITERE
CRIT_FCY_B = CRIT_FCY

# Plan et type de référentiel
If LEDTYPLIST(J)
 CRITERE_B   -= "& LEDTYP="+num$(LEDTYPLIST(J))
 CRIT_FCY_B  -= "& LEDTYP="+num$(LEDTYPLIST(J))
 CRIT_CMD    -= "& LEDTYP("+num$(LEDTYPLIST(J)-1)+")="+num$(LEDTYPLIST(J))
 If TYPCPT=1 & [M:DIA]COA<>""
  CRITERE_B   -= "& COA='"+[M:DIA]COA+"'"
  CRIT_FCY_B  -= "& COA='"+[M:DIA]COA+"'"
  CRIT_CMD    -= "& COA("+num$(LEDTYPLIST(J)-1)+")='"+[M:DIA]COA+"'"
 Endif
Endif

# FIltre CRIT_CNA
If [L]TYPCPT=1
 Local Char CRIT_CNA(250)
 If [M:DIA]ALLCPY=2 and [M:DIA]ALLFCY=2
  CRIT_CNA = "1=1"
 Elsif [M:DIA]ALLFCY<>2
  CRIT_CNA = "FCY='"+[M:DIA]FCY+"'"
 Else
  Local Integer K, L  : Raz K,L
  CRIT_CNA = "find(FCY"
  For I = 1 To GNBSITE
   If [M:DIA]CPY=GSOCSITE(I)
    CRIT_CNA += ",'"+GSITE(I)+"'"
    K+=1 : If K=1 : L=I : Endif
   Endif
  Next
  If [L]CRIT_CNA = "find(FCY"
   CRIT_CNA = "0"
  Else CRIT_CNA += ")"
  Endif
  If K=1 : [L]CRIT_CNA="FCY='"+GSITE(L)+"'" : Endif
 Endif
 If CRIT_CNA  = "" : CRIT_CNA  = "1=1" : Endif
Endif
Return

