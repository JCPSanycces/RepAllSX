End

######################################
###   Etiquettes masque GACMERGE   ###
######################################
Subprog AS_CPTORG(VALEUR)
Variable Char VALEUR()
Raz GBOUT1
End

Subprog AS_CPTDES(VALEUR)
Variable Char VALEUR()
Raz GBOUT1
End

Subprog C_CPTDES(VALEUR)
Variable Char VALEUR()
If VALEUR=[M]CPTORG : mkstat = 1 : End : Endif

Local Char    NAT1(GLONCNA) , NAT2(GLONCNA) , CRNAT1(10) , CRNAT2(10) , SIT1(GLONFCY) , SIT2(GLONFCY), MESSA(255)
Local Integer OK, CTRL1,CTRL2
Local Integer FLGVAT1, FLGVAT2    # Bug 16007 (CP : 04/10/02) : Ajout du contrôle sur la gestion TVA
Local Integer NLED, CSLOK
Local Integer CSLFLGORG, CSLFLGDES
Local Integer CSLBPRORG, CSLBPRDES
Local Char    MESSA(255)
Local Integer ICSL
Local Char    LEDCSLLST(GLONLED) (1..)

###########################################################################################################
# Quelques contrôles pour garantir que les sociétés/sites de sélection
# sont cohérents et compatibles avec ceux auxquels sont associés le compte origine et le compte destination.
#  - CTRL 1 : Vérification de la compatibilité entre le site saisi et celui du compte destination.
#  - CTRL 2 : Vérification de la cohérence entre le site saisi et celui du compte origine.
#
#  Le controle 1 est un contrôle bloquant et le controle 2 est un message d'avertissement.
#############################################################################################################

mkstat = 0 : CTRL1=1
Call COMPAT(SIT2,[M]FCY,[M]CPY)
If mkstat
 # Critères société/site incompatibles avec le paramétrage du compte destination
 MESSA=mess(127,116,1)-"("-SIT2-")"
 CTRL1=0
Endif

mkstat = 0  :CTRL2=1
Call COMPAT(SIT1,[M]FCY,[M]CPY)
If mkstat
 # Attention : critères société/site incohérents avec le paramétrage du compte origine
 MESSA-="\"-mess(126,116,1)-"("-SIT1-")"
 CTRL2=0
Endif

If CTRL1
 If !CTRL2
  OK=0
  Call AVERTIR(mess(126,116,1)-"("-SIT1-")",OK) From GESECRAN
  If OK<>2 :  mkstat=2 : End : Else mkstat=0 : Endif
 Endif
Else
 GMESSAGE=MESSA : mkstat=2 : End
Endif

# Ajout du contrôle sur la gestion TVA
If (FLGVAT1=1 & FLGVAT2<>1) or (FLGVAT1<>1 & FLGVAT2=1)
 OK = 0   :  Call AVERTIR(mess(105,107,1),OK) From GESECRAN # Gestion de TVA différente.
 If OK<>2 :  mkstat = 2 : End : Endif
Endif

# Flow/Partner control management between source account and target account
# if the chart plan belongs to a Consolidation ledger
If func AFNC.ACTIV("PRCSL")
 If clalev([F:GCM])=0 : Local File GACM  [GCM] : Endif
 If clalev([F:LED])=0 : Local File GLED  [LED] : Endif

 If [M:DIA]CPTORG <> ""
  # Read the source account and its management parameter for Flow and Partner
  Call LEC_GAC([M:DIA]CPTORG,[M:DIA]COA) From CPTLEC
  If  dim([F:GAC]CSLFLGFLW)>0
   CSLFLGORG = [F:GAC]CSLFLGFLW
  Endif
  If  dim([F:GAC]CSLFLGBPR)>0
   CSLBPRORG = [F:GAC]CSLFLGBPR
  Endif
 Endif

 If VALEUR <> ""
  #  Read the target account and its management parameter for Flow and Partner
  Call LEC_GAC(VALEUR,[M:DIA]COA) From CPTLEC
  If  dim([F:GAC]CSLFLGFLW)>0
   CSLFLGDES = [F:GAC]CSLFLGFLW
  Endif
  If  dim([F:GAC]CSLFLGBPR)>0
   CSLBPRDES = [F:GAC]CSLFLGBPR
  Endif
 Endif

 If (CSLFLGDES = CSLFLGORG) and (CSLBPRDES=CSLBPRORG) :   End :  Endif

 mkstat = 0 : CSLOK=0 :  ICSL=0

 If [M]CPY<>""
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If !fstat
   For NLED = 1 To len(mess(0,2644,1))
    If [F:GCM]LED(NLED-1)<>"" and [F:GCM]CFMAUT(NLED-1)<>2
     Call LEC_LED([F:GCM]LED(NLED-1)) From CPTLEC
     If [F:LED]CSL=2 and [F:LED]COA=[M:DIA]COA
      CSLOK=1
      Break
     Endif
    Endif
   Next #<NLED>
  Endif
 Else  #  All CPY
  # List with consolidated Ledgers for the legislation
  Raz LEDCSLLST
  For [LED]LED0 Where COA=[M:DIA]COA and CSL=2
   ICSL=+1
   LEDCSLLST(ICSL)=[F:LED]LED
  Next
  If ICSL>0
    Link [CPY] With [GCM]GCM0~=[F:CPY]ACM
&             As [LNK]
&             Where [F:CPY]CPYLEGFLG=2 & [F:CPY]LEG=[M:DIA]LEG
    For [LNK]
     For J=1 To len(mess(0,2644,1))
      If [F:GCM]LED(J-1)="" : Break : Endif
      If find ([F:GCM]LED(J-1),LEDCSLLST(1..ICSL))
       CSLOK=1
       Break 2
      Endif
     Next #<LNK>
    Next #<J>
   Endif
 Endif

 If CSLOK
  Call COMPAT_CSLFLG([M:DIA]CPTORG,CSLFLGORG, CSLBPRORG, VALEUR, CSLFLGDES, CSLBPRDES)
  If mkstat
   GERR=1 :  mkstat = 2 : End
  Endif
 Endif

Endif


End

##########################################################################
## Vérif de compatibilité Compte
##########################################################################
Subprog COMPAT(FCY,FILT_FCY,FILT_CPY)
Value Char FCY
Value Char FILT_FCY
Value Char FILT_CPY

If FCY="" : End : Endif

If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

If find(FCY,GSITE(1..GNBSITE))
 If FILT_FCY<>FCY :  mkstat=2 :  Endif
Else
 Call LECTURE("CPY",FCY,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2
  If FILT_CPY<>FCY :  mkstat=2  : Endif
 Else
  Read [FGR]FGR0 = FCY;FILT_FCY
  If fstat : mkstat=2 : Endif
 Endif
Endif
End
#**
#*
################################################################################
## - Checking compatibility of the flow management between source account and target account
## - Checking compatibility of the Partner management between source account and target account
################################################################################
Subprog COMPAT_CSLFLG(PCPTORG, PCSLFLGO, PCSLBPRO, PCPTDES, PCSLFLGD, PCSLBPRD)
Value Char    PCPTORG          # Source control account
Value Integer PCSLFLGO        # Flow management source control account
Value Integer PCSLBPRO        # Partner management source control account
Value Char    PCPTDES         # Target control account
Value Integer PCSLFLGD        # Flow management target control account
Value Integer PCSLBPRD        # Partner management target control account


If (PCSLFLGD <> 2) and (PCSLFLGO <> PCSLFLGD)
 # Comparison Flow management if Flow management target not optional
 # XXX => YYY - Flow management: Not entered,Optional,Mandatory/XXX ==> Not entered,Optional,Mandatory/YYY
 GMESSAGE = num$(PCPTORG)-"=> "-num$(PCPTDES)-"-"-mess(204,104,1)-":"-mess(PCSLFLGO,2637,1)-"/"-num$(PCPTORG)-"=>"-mess(PCSLFLGD,2637,1)-"/"-num$(PCPTDES)
 mkstat=2 : End
Endif

If (PCSLBPRD <> 2) and (PCSLBPRO <> PCSLBPRD)
 # Comparison Partner management if Partner management target not optional
 # XXX => YYY - Partner management: Not entered,Optional,Mandatory/XXX ==> Not entered,Optional,Mandatory/YYY
 GMESSAGE = num$(PCPTORG)-"=> "-num$(PCPTDES)-"-"-mess(205,104,1)-":"-mess(PCSLBPRO,2637,1)-"/"-num$(PCPTORG)-"=>"-mess(PCSLBPRD,2637,1)-"/"-num$(PCPTDES)
 mkstat=2 : End
Endif

End
#################################################################
# Etiquette masque BPRMERGE
#################################################################
########################################
Subprog AS_BPRORG(VALEUR)
Variable Char    VALEUR()
Raz GBOUT1
End

########################################
Subprog AS_BPRDES(VALEUR)
Variable Char    VALEUR()
Raz GBOUT1
End

########################################
Subprog C_BPRDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]BPRORG : mkstat = 1 : End : Endif
Local Integer CLI , FOU , DIV, OK, CTRL1,CTRL2
Local Char    MESSA(255)

Call LECTURE("BPR",[M]BPRORG,"") From CONTOBJ
CLI = [F:BPR]BPCFLG
FOU = [F:BPR]BPSFLG
DIV = [F:BPR]BPRFLG
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
If CLI=2 & [F:BPR]BPCFLG<>2
 GMESSAGE = VALEUR-mess(106,116,1) : mkstat = 2 : End : # n'est pas un client
Elsif FOU=2 & [F:BPR]BPSFLG<>2
 GMESSAGE = VALEUR-mess(107,116,1) : mkstat = 2 : End : # n'est pas un fournisseur
Elsif DIV=2 & [F:BPR]BPRFLG<>2
 GMESSAGE = VALEUR-mess(108,116,1) : mkstat = 2 : End : # n'est pas un tiers divers
Endif

###########################################################################################################
# Quelques contrôles pour garantir que les sociétés/sites de sélection
# sont cohérents et compatibles avec ceux auxquels sont autorisés le tiers origine et le tiers destination.
#  - CTRL 1 : Vérification de la compatibilité entre le site saisi et celui du tiers destination.
#  - CTRL 2 : Vérification de la cohérence entre le site saisi et celui du tiers origine.
#
#  Le controle 1 est un contrôle bloquant et le controle 2 est un message d'avertissement.
#############################################################################################################

mkstat = 0 : CTRL1=1
Call COMPAT2(VALEUR,[M]CPY)
# Critères société/site incompatibles avec le paramétrage du tiers destination
If mkstat : MESSA=mess(129,116,1) : CTRL1=0 : Endif

mkstat = 0 : CTRL2 = 1
Call COMPAT2([M]BPRORG,[M]CPY)
# Attention : critères société/site incohérents avec le paramétrage du tiers origine
If mkstat : MESSA-="\"-mess(128,116,1) : CTRL2=0 : Endif

If CTRL1
 If !CTRL2
  OK=0
  Call AVERTIR(mess(128,116,1),OK) From GESECRAN
  If OK<>2 :  mkstat=2 : End : Else mkstat=0 : Endif
 Endif
Else
 GMESSAGE=MESSA : mkstat=2 : End
Endif
End

##########################################################################
## Vérif de compatibilité TIERS
##########################################################################
Subprog COMPAT2(BPR,FILT_CPY)
Value Char BPR
Value Char FILT_CPY

If !clalev([F:ACV]) Local File ACTIV      [ACV] : Endif

# Contrôle uniquement si on est en multi-site
Read [ACV]CODACT="MUL"
If !fstat & [F:ACV]FLACT = 2

 If clalev([F:BPE]) =0 : Local File BPEXCEPT [BPE]  : Endif

 # Par défaut, le vide représente des autorisations positives...
 # donc je filtre sur les autorisations négatives.
 # Si aucun --> Tous les droits.

 If FILT_CPY<>""
  Filter [BPE] Where BPRNUM=BPR and CPY=FILT_CPY and ACEAUZ<>2
  Read [BPE]First
  If !fstat : mkstat=2 : Endif
 Else
  Filter [BPE] Where BPRNUM=BPR and ACEAUZ<>2
  Read [BPE]First
  If !fstat : mkstat=2 : Endif
 Endif
 Filter [BPE]
Endif
End

