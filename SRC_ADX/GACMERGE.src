Variable Char VALEUR
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char VALEUR()
If [F:CPY]CPYLEGFLG<>2
 # Société non juridique
 mkstat=2 : GMESSAGE=mess(130,121,1)
Endif
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call AM_CPY(VALEUR) From CPTTRT
 If dim([M:DIA]CPTDES)>0 & [M:DIA]CPTDES<>""
  Raz [M:DIA]CPTDES
  Affzo [M:DIA]CPTDES
 Endif
End

