Call C_LEG(VALEUR) From CPTTRT
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
 If dim([M:DIA]CPTDES)>0 & [M:DIA]CPTDES<>""
  Raz [M:DIA]CPTDES
  Affzo [M:DIA]CPTDES
 Endif
End

