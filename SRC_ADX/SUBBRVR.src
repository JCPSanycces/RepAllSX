#<AdxTL>@(#)10.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Fonction : REQREV - Demandes de révisions
#   Action   : REQREV
#   Fenêtre  : REQREV
#   Ecran concerné : BRVR
#   Description : Fonction de demandes de révisions. Selection des objets
#                 concernés par société/site.
#
#--------------------------------------------------------------------------

Local Char PARAM(10)(1..5) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"REQREV","SUBBRVR","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_OK"     : Gosub AVANT_OK
 When "OK"           : Gosub OK
 When Default
Endcase
Return

$OUVRE
#Recup du parametrage du niveau d'approbation
Global Char GAPPNIV(3)
#Entité de l'utilisateur courant (GUSER)
Global Char GENTUSR
Call PARAMUTIL("GDDENTUSR",GENTUSR,"","") From SUBAUS
#Tables utiles
If !clalev([AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([LED]) : Local File GLED       [LED] : Endif
If !clalev([GCM]) : Local File GACM       [GCM] : Endif
If !clalev([CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([ACC]) : Local File ACCES      [ACC] : Endif
If !clalev([BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([BVD]) : Local File BUDREVDET  [BVD] : Endif
If !clalev([FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([TCA]) : Local File TABCOUAFF  [TCA] : Endif
#Masque
Local Mask BRVR
#Variables locales
Local Integer STAT
Local Char NUMREV
Local Char REVCPT(GLONANM)
Return

$SETBOUT
If [M]NBLIG<=0
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return

$DEBUT
Raz [M:BRVR]
Return

$AVANT_OK
Local Integer OK,COCHE : COCHE=0
For I=0 To [M]NBLIG-1
 If [M]ASK(I)=2
  COCHE=1 : Break
 Endif
Next
If !COCHE
 #Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Endif
Return

$OK
If [M]NBLIG<=0 : End : Endif
Local Char LISTENVAPP(GLONENV)(1..[M]NBLIG)
Local Char LISTAPPMUL(GLONENV)(1..[M]NBLIG)
Local Char ENVCUR(GLONENV)
#Etablissement de la liste des enveloppes dont au moins un objet et soumis à révision
K=1 : P=1
For J=0 To [M]NBLIG-1
 If [M]ASK(J)=2
  If !find([M]ENV(J),LISTENVAPP(1..[M]NBLIG))
   LISTENVAPP(K)=[M]ENV(J)
   ENVCUR=[M]ENV(J)
   K+=1
  Endif
 Endif
Next

Local Integer X, NB
X=1
While X<=dim(LISTENVAPP) & LISTENVAPP(X)<>""
 NB=0
 For I=0 To [M]NBLIG-1
  If [M]ASK(I)=2 & [M]ENV(I)=LISTENVAPP(X) : NB+=1 : Endif
 Next
 If NB>1
  LISTAPPMUL(P)=LISTENVAPP(X)
  P+=1
 Endif
 X+=1
Wend

Local Char ALREADY_DONE(GLONENV)(1..[M]NBLIG)
Local Integer Q : Q=1
Local Integer NIVEAU

For I=0 To [M]NBLIG-1
 If [M]ASK(I)=2
  If !find([M]ENV(I),LISTAPPMUL(1..[M]NBLIG))
   NIVEAU=[M]NIV(I)
   Gosub CRE_REVISION
  Elsif !find([M]ENV(I),ALREADY_DONE(1..[M]NBLIG))
   ALREADY_DONE(Q)=[M]ENV(I)
   Q+=1
   NIVEAU=4
   Gosub CRE_REVISION
  Endif
 Endif
Next
Return

$ABANDON
Rollback
Return

$CRE_REVISION
#Lecture affectation compteur
Read [TCA]TCA0 = 2;[M]CPY
If !fstat
 REVCPT = [F:TCA]CODNUM(10)
Endif
If REVCPT=""
 Read [TCA]TCA0 = 2;""
 If !fstat
  REVCPT = [F:TCA]CODNUM(10)
 Endif
Endif
Call NUMERO(REVCPT,[M:BRVR]FCY,date$,"",[L]NUMREV,STAT) From SUBANM
If [L]NUMREV=""
 #Anomalie au niveau du compteur, vérifiez l'affectation.
 GMESSAGE=mess(236,108,1)
 mkstat=2
 GOK=0
 Return
Endif

Call DEBTRANS From GLOCK

Trbegin [BRV],[BVD]
 Raz [F:BRV]
 [F:BRV]NUM    = [L]NUMREV
 [F:BRV]TYP    = NIVEAU
 [F:BRV]STA    = 2
 [F:BRV]RENTAB = [M]RENTAB(I)
 [F:BRV]RENTXT = [M]RENTXT(I)
 [F:BRV]CUR    = [M]CUR(I)
 [F:BRV]ENV    = [M]ENV(I)
 If NIVEAU=4
  #New Way -> création des éléments dans BUDREVDET
  L=0
  For J=0 To [M]NBLIG
   If [M]ENV(J)=[M]ENV(I) & [M]ASK(J)=2
    L+=1
     [F:BVD]NUMERO = L
     [F:BVD]NUMREV = [L]NUMREV
     [F:BVD]TYP    = [M]NIV(J)
     [F:BVD]ENV    = [M]ENV(J)
     [F:BVD]FIY    = [M]FIY(J)
     [F:BVD]ACCNUM = [M]ACCNUM(J)
     [F:BVD]ACC    = [M]ACC(J)
     [F:BVD]COA    = [M]COA(J)
     [F:BVD]ENT    = [M]ENTDEN(J)
     [F:BVD]AMT    = [M]AMT(J)
     [F:BVD]AMTASK = [M]AMTASK(J)
     [F:BVD]AMTPRS = [M]AMTPRS(J)
     [F:BVD]AMTPNV = [M]AMTPNV(J)
     [F:BVD]AMTRAL = [M]AMTRAL(J)
     [F:BVD]CUR    = [M]CUR(J)
     Write [BVD]
     If fstat
      GOK=0 : Call FSTA("BVD") From GLOCK : Break
     Endif
   Endif
  Next
  If   GOK<0 : Goto ABANDON
  Elsif !GOK : Goto ABANDON
  Endif
 Else
  [F:BRV]FIY    = [M]FIY(I)
  [F:BRV]ACCNUM = [M]ACCNUM(I)
  [F:BRV]ACC    = [M]ACC(I)
  [F:BRV]COA    = [M]COA(I)
  [F:BRV]ENT    = [M]ENTDEN(I)
  [F:BRV]AMT    = [M]AMT(I)
  [F:BRV]AMTASK = [M]AMTASK(I)
  [F:BRV]AMTPRS = [M]AMTPRS(I)
  [F:BRV]AMTPNV = [M]AMTPNV(I)
  [F:BRV]AMTRAL = [M]AMTRAL(I)
 Endif
 [F:BRV]DMDDAT = date$
 [F:BRV]CREDAT = date$
 [F:BRV]CREUSR = GUSER
 Write [BRV]
 If fstat
  GOK=0 : Call FSTA("BRV") From GLOCK
 Endif
 If   GOK<0 : Goto ABANDON
 Elsif !GOK : Goto ABANDON
 Endif
Commit
Call WORKFLOW(1,"REV","","") From AWRK
Return

################################
## Etiquettes de l'écran BRVR ##
################################

Subprog C_CFY(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC, ISITE
Raz [M]FCY
ISOC   = find(VALEUR,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 [M]FCY=VALEUR
 #06/10/09-Dmd54223:Autorisation site
 Call CONTFCY(VALEUR) From CPTSUB
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Else
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
Endif
[M]CPY=GSOC(ISOC)
Call SETGLBAPP(GSOC(ISOC),GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
Affzo [M]
End

Subprog AM_CFY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CFY=VALEUR
 Raz [M]CRIPRJ
 Raz [M]ENTMSTR,ENTMEND
 Raz [M]ENTASTR,ENTAEND
 Raz [M]ENVSTR,ENVEND
 Raz [M]NBLIG
 Affzo [M]
Endif
End

Subprog AS_CRIDATSTR(VALEUR)
Variable Date    VALEUR
If [M]CFY<>""
 Call DATDEFSOC([M]CPY,VALEUR,[M]CRIDATEND) From CONSSUB
Endif
End

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CFY<>""
 Gosub CHARGEMENT
Endif
End

Subprog C_CRIPRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call LECACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End


Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
Endif
End


Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif
Endif
End


#--------------------------------------------------------------------#

$CHARGEMENT
#Intitulé enveloppe
Local Char INTENV(30)
Local Decimal REALISE
Local Libelle LEDTYPGEN, LEDTYPANA
Local Integer I,B,OK,OKBRV
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3
CTLACS = 1

I=0
Raz [M]NBLIG

Local Integer SOC,J
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
SOC=find([M]CFY,GSOC(1..GNBSOC))
J=1
If SOC
 For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
  LISTFCY(J)=[F:FCY]FCY
  J+=1
 Next
Endif

Local Char CRITENV(250)
CRITENV="1=1"
CRITENV -= '& (FCY="'+[M]CFY+'" | find(FCY,LISTFCY(1..J)))'

If [M]CRIPRJ<>""
 CRITENV -='& PRJ="'+[M]CRIPRJ+'"'
Endif
If [M]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M]ENTMSTR+'" & ENTMNA<="'+[M]ENTMEND+'"'
Endif
If [M]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M]ENTASTR+'" & ENTAPP<="'+[M]ENTAEND+'"'
Endif
If [M]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif
If [M]CRIDATSTR<>[0/0/0] & [M]CRIDATEND<>[0/0/0]
 CRITENV -='& REASTR<=['+format$(GFMD,[M]CRIDATEND)+'] & REAEND>=['+format$(GFMD,[M]CRIDATSTR)+']'
Endif

#Les enveloppes à réviser
For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif

 If OKACS
  #Pour intitulé exercice
  Call SETMAINREF([F:ENV]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  If [F:ENV]STA=3
   OKBRV=1
   For [BRV]BRV0 Where STA=2
    If [F:BRV]TYP=1 & [F:BRV]ENV=[F:ENV]ENV & [F:BRV]FIY=0 & [F:BRV]ACCNUM=0 : OKBRV=0 : Break : Endif
    If [F:BRV]TYP=2 & [F:BRV]ENV=[F:ENV]ENV : OKBRV=0 : Break : Endif
    If [F:BRV]TYP=3 & [F:BRV]ENV=[F:ENV]ENV : OKBRV=0 : Break : Endif
    If [F:BRV]TYP=4 & [F:BRV]ENV=[F:ENV]ENV
     Filter [BVD] Where NUMREV=[F:BRV]NUM & TYP=1
     Look [BVD]BVD0 First
     If !fstat : OKBRV=0 : Break : Endif
     Filter [BVD]
    Endif
   Next

   If OKBRV
    [M]NIV(I)    = 1
    [M]ENV(I)    = [F:ENV]ENV
    [M]CUR(I)    = [F:ENV]CURENV
    [M]AMT(I)    = [F:ENV]AMTENV
    [M]AMTRES(I) = [F:ENV]AMTRES
    [M]ENVINT(I) = INTENV
    [M]PRJ(I)    = [F:ENV]PRJ
    [M]ENTMNA(I) = [F:ENV]ENTMNA
    Call CAL_REALISE(1,[F:ENV]ENV,0,INDENV,"",REALISE)
    [M]TOTREA(I) = REALISE
    [M]SOLDE(I)  = [F:ENV]AMTENV-REALISE
    #---Reste a ventiler------
    Local Decimal VE_BUD : VE_BUD=0
    For [ENF]ENF0 Where ENV=[F:ENV]ENV
     VE_BUD +=[F:ENF]AMTBUDFIY
    Next
    [M]RAVE(I)=[F:ENV]AMTENV-[F:ENV]AMTRES-VE_BUD
    #-------------------------
    Raz [M]ACCNUM(I), [M]FIY(I), [M]ACC(I), [M]ENTDEN(I), [M]LOT(I), [M]AMTASK(I), [M]AMTPRS(I), [M]COA(I)
    Raz [M]AMTPNV(I), [M]AMTRAL(I), [M]RENTAB(I), [M]RENTXT(I)
    [M]ASK(I)=1
    I+=1
    #----TB protection----
    If I>dim([M]NIV)-1
     #Tableau Plein
     Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
    Endif
    #--------------------
   Endif
  Endif

  #Les budgets exercices
  For [ENF]ENF0 Where ENV=[F:ENV]ENV
   If [F:ENV]STA=3 & [F:ENF]STAFIY=3
    OKBRV=1
    For [BRV]BRV0 Where STA=2
     If [F:BRV]TYP=1 & [F:BRV]ENV=[F:ENF]ENV & [F:BRV]FIY=0 & [F:BRV]ACCNUM=0 : OKBRV=0 : Break : Endif
     If [F:BRV]TYP=2 & [F:BRV]ENV=[F:ENF]ENV & [F:BRV]FIY=[F:ENF]FIYNUM & [F:BRV]ACCNUM=0 : OKBRV=0 : Break : Endif
     If [F:BRV]TYP=3 & [F:BRV]ENV=[F:ENF]ENV & [F:BRV]FIY=[F:ENF]FIYNUM : OKBRV=0 : Break : Endif
     If [F:BRV]TYP=4 & [F:BRV]ENV=[F:ENF]ENV
      Filter [BVD] Where NUMREV=[F:BRV]NUM & TYP=2 & FIY=[F:ENF]FIYNUM
      Look [BVD]BVD0 First
      If !fstat : OKBRV=0 : Break : Endif
      Filter [BVD]
     Endif
    Next
    If OKBRV
     [M]NIV(I) = 2
     [M]ENV(I)    = [F:ENF]ENV
     [M]FIY(I)    = [F:ENF]FIYNUM
     [M]INTFIY(I) = num$([F:ENF]FIYNUM)
     Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
     If !fstat
      [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
     Endif
     [M]AMT(I)    = [F:ENF]AMTBUDFIY
     [M]AMTRES(I) = [F:ENF]AMTRESFIY
     [M]ENVINT(I) = INTENV
     [M]CUR(I)    = [F:ENV]CURENV
     [M]PRJ(I)    = [F:ENV]PRJ
     [M]ENTMNA(I) = [F:ENV]ENTMNA
     Call CAL_REALISE(2,[F:ENF]ENV,[F:ENF]FIYNUM,INDENV,"",REALISE)
     [M]TOTREA(I) = REALISE
     [M]SOLDE(I)  = [F:ENF]AMTBUDFIY-REALISE
     #---Reste a ventiler-------
     Local Decimal VE_LIG : VE_LIG=0
     For [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM
       VE_LIG +=[F:BUD]AMT(0)
     Next
     [M]RAVE(I)=[F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY-VE_LIG
     #--------------------------
     Raz [M]ACCNUM(I), [M]ACC(I), [M]ENTDEN(I), [M]LOT(I), [M]AMTASK(I), [M]AMTPRS(I),[M]COA(I)
     Raz [M]AMTPNV(I), [M]AMTRAL(I), [M]RENTAB(I), [M]RENTXT(I)
     [M]ASK(I)=1
     I+=1
     #----TB protection----
     If I>dim([M]NIV)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
     Endif
     #--------------------
    Endif
   Endif
   #Les Lignes Budgétaires
   For [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM
    If [F:ENF]STAFIY=3 & [F:BUD]STA=3
     OKBRV=1
     For [BRV]BRV0 Where STA=2
      If [F:BRV]TYP=1 & [F:BRV]ENV=evalue('[F:BUD]CCE'+num$(INDENV)) & [F:BRV]FIY=0 & [F:BRV]ACCNUM=0
       OKBRV=0 : Break
      Endif
      If [F:BRV]TYP=2 & [F:BRV]ENV=evalue('[F:BUD]CCE'+num$(INDENV)) & [F:BRV]FIY=[F:BUD]FIY & [F:BRV]ACCNUM=0
       OKBRV=0 : Break
      Endif
      If [F:BRV]TYP=3 & [F:BRV]ENV=evalue('[F:BUD]CCE'+num$(INDENV)) & [F:BRV]FIY=[F:BUD]FIY & [F:BRV]ACCNUM=[F:BUD]ACCNUM
       OKBRV=0 : Break
      Endif
      If [F:BRV]TYP=4 & [F:BRV]ENV=evalue('[F:BUD]CCE'+num$(INDENV))
       Filter [BVD] Where NUMREV=[F:BRV]NUM & TYP=3 & ACCNUM=[F:BUD]ACCNUM
       Look [BVD]BVD0 First
       If !fstat : OKBRV=0 : Break  : Endif
       Filter [BVD]
      Endif
     Next
     If OKBRV
      [M]NIV(I)    = 3
      [M]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
      [M]FIY(I)    = [F:BUD]FIY
      [M]INTFIY(I) = num$([F:BUD]FIY)
      Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BUD]FIY
      If !fstat
       [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
      Endif
      [M]ACCNUM(I) = [F:BUD]ACCNUM
      [M]AMT(I)    = [F:BUD]AMT(0)
      [M]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
      [M]ACC(I)    = [F:BUD]ACC
      [M]COA(I)    = [F:BUD]COA
      [M]LOT(I)    = [F:BUD]LOT
      [M]ENVINT(I) = INTENV
      [M]CUR(I)    = [F:ENV]CURENV
      [M]PRJ(I)    = [F:ENV]PRJ
      [M]ENTMNA(I) = [F:ENV]ENTMNA
      Call CAL_REALISE(3,evalue('[F:BUD]CCE'+num$(INDENV)),[F:BUD]FIY,INDENV,[F:BUD]ACCNUM,REALISE)
      [M]TOTREA(I) = REALISE
      [M]SOLDE(I)  = [F:BUD]AMT(0)-REALISE
      [M]RAVE(I)   = [F:BUD]AMT(0)-[F:BUD]AMTREA-[F:BUD]AMTCMMPRP-[F:BUD]AMTCMM
      Raz [M]AMTASK(I), [M]AMTPRS(I), [M]AMTPNV(I), [M]AMTRAL(I), [M]RENTAB(I), [M]RENTXT(I)
      [M]ASK(I)=1
      I+=1
      #----TB protection----
      If I>dim([M]NIV)-1
       #Tableau Plein
       Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 3
      Endif
      #--------------------
     Endif
    Endif
   Next
  Next
 Endif :#OKACS
Next

If I=0
 #Aucun objet ne satisfait ces critères de sélection
 Call MESSAGE(mess(218,108,1)) From GESECRAN
 Return
Endif

[M]NBLIG=I
Affzo [M]
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Gosub COLORIZE
Return

$COLORIZE
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For I=0 To [M]NBLIG-1
 If [M]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
  Chgstl [M]AMT(I)    With "GDD"+num$(K)+"G"
  Chgstl [M]AMTASK(I) With "GDD"+num$(K)+"G"
 Else
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
  Chgstl [M]AMT(I)    With "GDD"+num$(K)+"G"
  Chgstl [M]AMTASK(I) With "GDD"+num$(K)+"G"
 Endif
 If [M]NIV(I)=1
  Grizo [M]AMTPRS(I),AMTPNV(I),AMTRAL(I)
 Endif
 ENVCUR=[M]ENV(I)
Next
Affzo [M]
Return

Subprog CAL_REALISE(TYP,ENVELOPPE,EXERCICE,I_ENV,ACCNUM,REALISE)
Value Integer    TYP
Value Char       ENVELOPPE
Value Integer    EXERCICE
Value Integer    I_ENV
Variable Decimal REALISE
Raz REALISE
If !clalev([ENFX]) : Local File ENVFIY [ENFX] : Endif
If !clalev([BUDX]) : Local File BUD    [BUDX] : Endif
Case TYP
 When 1 :#Enveloppe
  For [ENFX]ENF0 Where ENV=ENVELOPPE
   For [BUDX] Where evalue('CCE'+num$(I_ENV))=[F:ENFX]ENV & FIY=[F:ENFX]FIYNUM
    REALISE += [F:BUDX]AMTREA+[F:BUDX]AMTCMMPRP+[F:BUDX]AMTCMM
   Next
  Next
 When 2 # Budget exercice
  For [BUDX] Where evalue('CCE'+num$(I_ENV))=ENVELOPPE & FIY=EXERCICE
   REALISE += [F:BUDX]AMTREA+[F:BUDX]AMTCMMPRP+[F:BUDX]AMTCMM
  Next
 When 3 # Ligne budgétaire
  Read [BUDX]BUD1=ACCNUM
  If !fstat
   REALISE = [F:BUDX]AMTREA+[F:BUDX]AMTCMMPRP+[F:BUDX]AMTCMM
  Endif
Endcase
End

#--------------------------------------------------------------------#

Subprog IB_NBLIG
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
End

Subprog AS_RENTAB(VALEUR)
Variable Char    VALEUR()
For I=0 To [M]NBLIG-1
 If I<>(nolign-1) & [M]ENV(nolign-1)=[M]ENV(I) & [M]NIV(I)<=[M]NIV(nolign-1) & [M]ASK(I)=2 & [M]ASK(nolign-1)=2
  VALEUR=[M]RENTAB(I) : Break
 Endif
Next
End

Subprog C_RENTAB(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ASK(nolign-1)=2
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2
Endif
End


$LIST_OBJ_ASK
Local Integer J,K,L : J=0 : K=0 : L=0
Local Integer LISTENVN(1..200)
Local Integer LISTBUDN(1..500)
Local Integer LISTLIGN(1..1000)

Local Char LISTENV(GLONENV)(1..200)
Local Char LISTBUD(GLONENV+1+2)(1..500)
Local Char LISTLIG(GLONENV+1+2+1+8)(1..1000)

For I=0 To [M]NBLIG-1
 If dim([M]ASK(I))<0 | [M]ASK(I)=2
  Case [M]NIV(I)
   When 1 : J+=1 : LISTENVN(J)=I : LISTENV(J)=[M]ENV(I)
   When 2 : K+=1 : LISTBUDN(K)=I : LISTBUD(K)=[M]ENV(I)+"~"+num$([M]FIY(I))
   When 3 : L+=1 : LISTLIGN(L)=I : LISTLIG(L)=[M]ENV(I)+"~"+num$([M]FIY(I))+"~"+num$([M]ACCNUM(I))
  Endcase
 Endif
Next
Return

Subprog C_AMTASK(VALEUR)
Variable Decimal VALEUR

Local Integer INDENV, INDENT, INDCCE3

If VALEUR<>0 & VALEUR<>[M]AMT(nolign-1)
 [M]AMTASK(nolign-1)=VALEUR
 Local Char    ENVELOPPE(GLONENV) : ENVELOPPE = [M]ENV(nolign-1)
 Local Integer EXERCICE           : EXERCICE  = [M]FIY(nolign-1)
 Local Integer NUM                : NUM       = [M]ACCNUM(nolign-1)
 Gosub LIST_OBJ_ASK
 Local Integer D,V

 If VALEUR>[M]AMT(nolign-1)
  Case [M]NIV(nolign-1)
   When 1   : Actzo AMTRAL(nolign-1)
   When 2,3 : Actzo [M]AMTPRS(nolign-1),AMTPNV(nolign-1),AMTRAL(nolign-1)
  Endcase
  Affzo [M]
  #------------------------
  #Contrôle en augmentation
  #------------------------
  #Contrôle du dépassement du montant possible par rapport au niveau supérieur
  Local Decimal SOM_AMT
  Case [M]NIV(nolign-1)
   When 2
    #---------------------------------------------------------------------
    #Ctrl que pas supérieur au montant disponible de l'enveloppe
    #---------------------------------------------------------------------
    Local Decimal DISPO_ENV,OTHERS_BUD,OTHERS_PRS,OTHERS_PNV
    DISPO_ENV = 0 : OTHERS_BUD = 0 : OTHERS_PRS=0 : OTHERS_PNV=0

    #Montant disponible de l'enveloppe
    Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
    D=find(ENVELOPPE,LISTENV(1..J))
    If D
     DISPO_ENV=[M]AMTASK(LISTENVN(D))
    Else
     DISPO_ENV=[F:ENV]AMTENV
    Endif

    #Montant ventilé par les autres budgets de la même enveloppe
    Filter [ENF] Where ENV=ENVELOPPE & FIYNUM<>EXERCICE
    For [ENF]ENF0
     V=0
     V=find([F:ENF]ENV+"~"+num$([F:ENF]FIYNUM),LISTBUD(1..K))
     If V
      OTHERS_BUD += [M]AMTASK(LISTBUDN(V))
      OTHERS_PRS += [M]AMTPRS(LISTBUDN(V))
      OTHERS_PNV += [M]AMTPNV(LISTBUDN(V))
     Else
      OTHERS_BUD += [F:ENF]AMTBUDFIY
     Endif
    Next
    Filter [ENF]

    #Contrôle
    If VALEUR>DISPO_ENV-OTHERS_BUD
     #Vous ne pouvez pas dépasser le montant autorisé de l'enveloppe. Veuillez d'abord réviser l'enveloppe
     GMESSAGE = mess(134,108,1)
     VALEUR=DISPO_ENV-OTHERS_BUD-OTHERS_PNV
     mkstat=2 : End
    Endif
    If [F:ENV]STA=3
     Grizo [M]AMTRAL(nolign-1)
    Endif

    #---------------------------------------------------------------------
   When 3
    #---------------------------------------------------------------------
    #Ctrl que pas supérieur au montant disponible du budget exe
    #---------------------------------------------------------------------
    Local Decimal DISPO_BUD,OTHERS_LIG,OTHERS_PRS,OTHERS_PNV
    DISPO_BUD = 0 : OTHERS_LIG = 0 : OTHERS_PRS=0 : OTHERS_PNV=0

    #Montant disponible du budget
    Read [ENF]ENF0 = ENVELOPPE;EXERCICE
    If !fstat
     D=find(ENVELOPPE+"~"+num$(EXERCICE),LISTBUD(1..K))
     If D
      DISPO_BUD=[M]AMTASK(LISTBUDN(D))
     Else
      DISPO_BUD=[F:ENF]AMTBUDFIY
     Endif
    Endif

    #Montant ventilé dans les autres lignes du même budget
    Call LEC_ENV(ENVELOPPE)From CPTLEC
    Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
    Filter [BUD] Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=EXERCICE & ACCNUM<>NUM
    For [BUD]BUD0
     V=0
     V=find(ENVELOPPE+"~"+num$(EXERCICE)+"~"+num$([F:BUD]ACCNUM),LISTLIG(1..L))
     If V
      OTHERS_LIG += [M]AMTASK(LISTLIGN(V))
      OTHERS_PRS += [M]AMTPRS(LISTLIGN(V))
      OTHERS_PNV += [M]AMTPNV(LISTLIGN(V))
     Else
      OTHERS_LIG += [F:BUD]AMT(0)
     Endif
    Next
    Filter [BUD]

    If VALEUR>DISPO_BUD-OTHERS_LIG
      #Vous ne pouvez pas dépasser le montant autorisé du budget exercice. Veuillez d'abord réviser ce dernier
      GMESSAGE = mess(135,108,1)
      VALEUR=DISPO_BUD-OTHERS_LIG-OTHERS_PRS-OTHERS_PNV
     mkstat=2 : End
    Endif
    If [F:ENF]STAFIY=3
     Grizo [M]AMTRAL(nolign-1)
     Affzo [M]
    Endif

    #---------------------------------------------------------------------
  Endcase
 Elsif VALEUR<[M]AMT(nolign-1)
  Raz [M]AMTPRS(nolign-1),AMTPNV(nolign-1),AMTRAL(nolign-1)
  Grizo [M]AMTPRS(nolign-1),AMTPNV(nolign-1),AMTRAL(nolign-1)
  Affzo [M]
  #------------------------
  #Contrôle en diminution
  #------------------------
  Case [M]NIV(nolign-1)
   When 1:#Sur les enveloppes : Dans la limite du reste à ventiler de l’enveloppe. Mise à jour du montant de l’enveloppe
    #---------------------------------------------------------------------
    # Ctrl que pas inférieur au montant ventilé dans les budgets
    #---------------------------------------------------------------------
    Local Decimal VE_BUD : VE_BUD =0
    Filter [ENF] Where ENV=ENVELOPPE
    For [ENF]ENF0
     V=0
     V=find([F:ENF]ENV+"~"+num$([F:ENF]FIYNUM),LISTBUD(1..K))
     If V
      VE_BUD += [M]AMTASK(LISTBUDN(V))
     Else
      VE_BUD += [F:ENF]AMTBUDFIY
     Endif
    Next
    Filter [ENF]
    Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
    If VE_BUD<>0 & (VALEUR-[F:ENV]AMTRES)<VE_BUD
     VALEUR=(VE_BUD+[F:ENV]AMTRES)
     #Le montant disponible de l'enveloppe ne peut être inférieur au montant ventilé dans le ou les budget(s) exercice(s)
     GMESSAGE=mess(166,108,1)
     mkstat=2 : End
    Endif
    #---------------------------------------------------------------------
   When 2:#Sur les budgets : Dans la limite du reste à ventiler du budget. Mise à jour du montant du budget
    #---------------------------------------------------------------------
    #Ctrl que pas inférieur au montant ventilé dans les lignes
    #---------------------------------------------------------------------
    Local Decimal VE_LIG :  VE_LIG =0
    Call LEC_ENV(ENVELOPPE)From CPTLEC
    Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
    Filter [BUD] Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=EXERCICE

    For [BUD]BUD0
     V=0
     V=find(evalue('[F:BUD]CCE'+num$(INDENV))+"~"+num$([F:BUD]FIY)+"~"+num$([F:BUD]ACCNUM),LISTLIG(1..L))
     If V
      VE_LIG += [M]AMTASK(LISTLIGN(V))
     Else
      VE_LIG += [F:BUD]AMT(0)
     Endif
    Next
    Filter [BUD]
    Read [ENF]ENF0 = ENVELOPPE;EXERCICE
    If VE_LIG<>0 & (VALEUR-[F:ENF]AMTRESFIY)<VE_LIG
     VALEUR=(VE_LIG+[F:ENF]AMTRESFIY)
     #La somme des montants des lignes budgétaire ne doit pas dépasser le montant disponible du budget exercice
     GMESSAGE=mess(133,108,1)
     mkstat=2 : End
    Endif
    #---------------------------------------------------------------------
   When 3:#Sur les lignes budgétaires : Dans la limite du reste à ventiler de la ligne budgétaire Mise à jour du montant de la ligne budgétaire
    #---------------------------------------------------------------------
    #Ctrl que pas inférieur au montant réalisé
    #---------------------------------------------------------------------
    Local Decimal REA_LIG :  REA_LIG =0
    Read [BUD]BUD1 = [M]ACCNUM(nolign-1)
    If !fstat
     REA_LIG = [F:BUD]AMTREA+[F:BUD]AMTCMMPRP+[F:BUD]AMTCMM
    Endif
    If REA_LIG<>0 & VALEUR<REA_LIG
     VALEUR=REA_LIG
     #Le montant de la ligne ne peut pas être inférieur au montant réalisé
     GMESSAGE=mess(173,108,1)
     mkstat=2 : End
    Endif
    #---------------------------------------------------------------------
  Endcase
 Endif
 [M]ASK(nolign-1)=2
 Affzo[M]
Elsif VALEUR=[M]AMT(nolign-1)
 #La montant demandé doit être différent du montant initial
 GMESSAGE=mess(136,108,1)
 mkstat=2 : End
Elsif [M]ASK(nolign-1)=2 & VALEUR=0
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
End

Subprog AS_AMTPRS(VALEUR)
Variable Decimal VALEUR
If [M]AMTASK(nolign-1)=0
 mkstat=1 : End
Endif
End

Subprog C_AMTPRS(VALEUR)
Variable Decimal VALEUR
#Variables locales utiles
Local Decimal DIFFERENCE                 : DIFFERENCE = [M]AMTASK(nolign-1)-[M]AMT(nolign-1)
Local Decimal AMT_DISPO                  : Raz AMT_DISPO
Local Decimal AMT_RSV_DISPO              : Raz AMT_RSV_DISPO
Local Decimal AMT_NV_DISPO,AMT_VENTILE   : Raz AMT_NV_DISPO,AMT_VENTILE

Local Char    ENVELOPPE(GLONENV) : ENVELOPPE = [M]ENV(nolign-1)
Local Integer EXERCICE          : EXERCICE  = [M]FIY(nolign-1)
Local Integer NUM               : NUM       = [M]ACCNUM(nolign-1)

Gosub LIST_OBJ_ASK
Local Integer D,V
Local Integer INDENV, INDENT, INDCCE3

# Verif par rapport à la réserve disponible
Case [M]NIV(nolign-1)
 When 2 : # budget exercice / prélevement dans la réserve de l'enveloppe

  #---------------------------------------------------------------------
  #Calcul du montant disponible de l'enveloppe
  #---------------------------------------------------------------------
  Local Decimal DISPO_ENV,OTHERS_BUD,OTHERS_PRS,OTHERS_PNV
  DISPO_ENV = 0 : OTHERS_BUD = 0 : OTHERS_PRS=0 : OTHERS_PNV=0

  #Montant disponible de l'enveloppe
  Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
  D=find(ENVELOPPE,LISTENV(1..J))
  If D
   DISPO_ENV=[M]AMTASK(LISTENVN(D))
  Else
   DISPO_ENV=[F:ENV]AMTENV
  Endif

  #Montant ventilé par les autres budgets de la même enveloppe
  Filter [ENF] Where ENV=ENVELOPPE & FIYNUM<>EXERCICE
  For [ENF]ENF0
   V=0
   V=find([F:ENF]ENV+"~"+num$([F:ENF]FIYNUM),LISTBUD(1..K))
   If V
    OTHERS_BUD += [M]AMTASK(LISTBUDN(V))
    OTHERS_PRS += [M]AMTPRS(LISTBUDN(V))
    OTHERS_PNV += [M]AMTPNV(LISTBUDN(V))
   Else
    OTHERS_BUD += [F:ENF]AMTBUDFIY
   Endif
  Next
  Filter [ENF]

  #---------------------------------------------------------------------
  #Calcul du montant disponible de l'enveloppe
  #---------------------------------------------------------------------
  AMT_DISPO=DISPO_ENV-OTHERS_BUD

  #---------------------------------------------------------------------
  #Calcul du montant disponible de la réserve de l'enveloppe
  #---------------------------------------------------------------------
  AMT_RSV_DISPO=[F:ENV]AMTRES-OTHERS_PRS

  #---------------------------------------------------------------------
  #Calcul du montant non ventilé disponible de l'enveloppe
  #---------------------------------------------------------------------
  AMT_NV_DISPO=AMT_DISPO-[M]AMT(nolign-1)-AMT_RSV_DISPO
  If AMT_NV_DISPO<0 : AMT_NV_DISPO=0 : Endif
  #---------------------------------------------------------------------

  #---> Vérification dépassement de réserve disponible
  If AMT_RSV_DISPO<VALEUR
   #Dépassement du montant disponible de la réserve de l'enveloppe
   GMESSAGE = mess(139,108,1)
   VALEUR=AMT_RSV_DISPO-OTHERS_PRS
   mkstat=2 : End
  Endif

  #---> Vérification cas "pas de rallonge" montant renseigné suffisant
  #pas de rallonge donc vérif de cohérence simplement sur les 2 montants prs et pnv
  If VALEUR<DIFFERENCE-AMT_NV_DISPO
   #Part prélevée dans la réserve du niveau supérieur insuffisante. Montant minimum :
   GMESSAGE=mess(175,108,1)-num$(DIFFERENCE-AMT_NV_DISPO)
   VALEUR=DIFFERENCE-AMT_NV_DISPO
   mkstat=2 : End
  Endif

  #---> Cas de demande supérieure au besoin
  If VALEUR>DIFFERENCE
   #Montant supérieur au besoin
   GMESSAGE=mess(274,108,1)-"("+num$(DIFFERENCE)+")"
   VALEUR=DIFFERENCE
   mkstat=2 : End
  Endif

 When 3 : # ligne budgetaire / prélèvement dans la réserve du budget exercice
  #---------------------------------------------------------------------
  #Calcul du montant disponible du budget
  #---------------------------------------------------------------------
  Local Decimal DISPO_BUD,OTHERS_LIG,OTHERS_PRS,OTHERS_PNV
  DISPO_BUD = 0 : OTHERS_LIG = 0 : OTHERS_PRS=0 : OTHERS_PNV=0

  #Montant disponible du budget
  Read [ENF]ENF0 = ENVELOPPE;EXERCICE
  If !fstat
   D=find(ENVELOPPE+"~"+num$(EXERCICE),LISTBUD(1..K))
   If D
    DISPO_BUD=[M]AMTASK(LISTBUDN(D))
   Else
    DISPO_BUD=[F:ENF]AMTBUDFIY
   Endif
  Endif

  #Montant ventilé dans les autres lignes du même budget
  Call LEC_ENV(ENVELOPPE)From CPTLEC
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  Filter [BUD] Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=EXERCICE & ACCNUM<>NUM
  For [BUD]BUD0
   V=0
   V=find(ENVELOPPE+"~"+num$(EXERCICE)+"~"+num$([F:BUD]ACCNUM),LISTLIG(1..L))
   If V
    OTHERS_LIG += [M]AMTASK(LISTLIGN(V))
    OTHERS_PRS += [M]AMTPRS(LISTLIGN(V))
    OTHERS_PNV += [M]AMTPNV(LISTLIGN(V))
   Else
    OTHERS_LIG += [F:BUD]AMT(0)
   Endif
  Next
  Filter [BUD]

  #---------------------------------------------------------------------
  #Calcul du montant disponible du budget exercice
  #---------------------------------------------------------------------
  AMT_DISPO=DISPO_BUD-OTHERS_LIG

  #---------------------------------------------------------------------
  #Calcul du montant disponible de la réserve du budget
  #---------------------------------------------------------------------
  Read [ENF]ENF0 =[M]ENV(nolign-1);[M]FIY(nolign-1)
  If !fstat
   AMT_RSV_DISPO = [F:ENF]AMTRESFIY-OTHERS_PRS
  Else
   End
  Endif

  #---------------------------------------------------------------------
  #Calcul du montant non ventilé disponible du budget
  #---------------------------------------------------------------------
  AMT_NV_DISPO=AMT_DISPO-[M]AMT(nolign-1)-AMT_RSV_DISPO
  If AMT_NV_DISPO<0 : AMT_NV_DISPO=0 : Endif :#85080
  #--------------------------------------------------------------------

  #---> Vérification dépassement de réserve disponible
  If AMT_RSV_DISPO-OTHERS_PRS<VALEUR
   #Dépassement du montant disponible de la réserve du budget exercice
   GMESSAGE = mess(140,108,1)
   VALEUR=AMT_RSV_DISPO-OTHERS_PRS
   mkstat=2 : End
  Endif

  #---> Vérification cas "pas de rallonge" montant renseigné suffisant
  If VALEUR+AMT_NV_DISPO<DIFFERENCE
   #Part prélevée dans la réserve du niveau supérieur insuffisante. Montant minimum :
   GMESSAGE=mess(175,108,1)-num$(DIFFERENCE-AMT_NV_DISPO)
   VALEUR=DIFFERENCE-AMT_NV_DISPO
   mkstat=2 : End
  Endif

  #---> Cas de demande supérieure au besoin
  If VALEUR>DIFFERENCE
   #Montant supérieur au besoin
   GMESSAGE=mess(274,108,1)-"("+num$(DIFFERENCE)+")"
   VALEUR=DIFFERENCE
   mkstat=2 : End
  Endif
Endcase
End

Subprog AS_AMTPNV(VALEUR)
Variable Decimal VALEUR
If [M]AMTASK(nolign-1)=0
 mkstat=1 : End
Endif
#Alim auto cas ou pas de rallonge
Local Decimal DIFFERENCE
DIFFERENCE = [M]AMTASK(nolign-1)-[M]AMT(nolign-1)
If DIFFERENCE>0
  Case [M]NIV(nolign-1)
   When 2,3 :  VALEUR=DIFFERENCE-[M]AMTPRS(nolign-1)
  Endcase
Endif
End

Subprog C_AMTPNV(VALEUR)
Variable Decimal VALEUR
#Variables locales utiles
Local Decimal DIFFERENCE                 : DIFFERENCE = [M]AMTASK(nolign-1)-[M]AMT(nolign-1)
Local Decimal AMT_DISPO                  : Raz AMT_DISPO
Local Decimal AMT_RSV_DISPO              : Raz AMT_RSV_DISPO
Local Decimal AMT_NV_DISPO,AMT_VENTILE   : Raz AMT_NV_DISPO,AMT_VENTILE

Local Char    ENVELOPPE(GLONENV) : ENVELOPPE = [M]ENV(nolign-1)
Local Integer EXERCICE           : EXERCICE  = [M]FIY(nolign-1)
Local Integer NUM                : NUM       = [M]ACCNUM(nolign-1)

Gosub LIST_OBJ_ASK
Local Integer D,V

Case [M]NIV(nolign-1)
 When 2 : # budget exercice / prélevement dans le non ventilé de l'enveloppe
  #Vérification cas "pas de rallonge" montant renseigné suffisant / Cas ou les budget dépendent d'une enveloppe approuvée
  Call LECTURE("ENV",[M]ENV(nolign-1),"") From CONTOBJ
  If VALEUR<>DIFFERENCE-[M]AMTPRS(nolign-1)
   #Le total des montants "pris sur réserve" + "pris sur non ventilé" doit être égal à l'écart de révision demandé
   GMESSAGE=mess(174,108,1)
   VALEUR=DIFFERENCE-[M]AMTPRS(nolign-1)
   mkstat=2 : End
  Endif
 When 3 : # ligne budgetaire / prélèvement dans la réserve du budget exercice
  #Vérification cas "pas de rallonge" montant renseigné suffisant / Cas ou les lignes bud dépendent d'un budget approuvée
  Read [ENF]ENF0 = [M]ENV(nolign-1);[M]FIY(nolign-1)
  If !fstat
   If VALEUR<>DIFFERENCE-[M]AMTPRS(nolign-1)
    #Le total des montants "pris sur réserve" + "pris sur non ventilé" doit être égal à l'écart de révision demandé
    GMESSAGE=mess(174,108,1)
    VALEUR=DIFFERENCE-[M]AMTPRS(nolign-1)
    mkstat=2 : End
   Endif
  Endif
Endcase
End


Subprog AS_AMTRAL(VALEUR)
Variable Decimal VALEUR
#il ne peut y avoir de rallonge que pour l'enveloppe
If [M]NIV(nolign-1)<>1
 mkstat=1 : End
Endif
If [M]AMTASK(nolign-1)=0
 #Vous devez d'abord saisir le nouveau montant demandé
 GMESSAGE = mess(141,108,1)
 Raz VALEUR
 zonsui="AMTASK("+num$(nolign-1)+")"
Endif
Local Decimal AMT_RESTANT
AMT_RESTANT=([M]AMTASK(nolign-1)-[M]AMT(nolign-1))-([M]AMTPRS(nolign-1)+[M]AMTPNV(nolign-1))
If AMT_RESTANT>=0
 VALEUR=AMT_RESTANT
Endif
End

Subprog C_AMTRAL(VALEUR)
Variable Decimal VALEUR
# Vérification cohérence ligne
If ([M]AMTPRS(nolign-1)+[M]AMTPNV(nolign-1)+VALEUR)<>([M]AMTASK(nolign-1)-[M]AMT(nolign-1))
 #Le montant est incohérent avec le montant demandé
 GMESSAGE = mess(138,108,1)
 VALEUR = ([M]AMTASK(nolign-1)-[M]AMT(nolign-1)) - ([M]AMTPRS(nolign-1)+[M]AMTPNV(nolign-1))
 mkstat=2
Endif
End

Subprog C_ASK(VALEUR)
Variable Integer VALEUR
If [M]AMTASK(nolign-1)=0 & VALEUR=2
 zonsui="[M]AMTASK("+num$(nolign-1)+")"
Endif
End

Subprog AM_ASK(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Gosub SETNOL
 [M]ASK(NOL)=VALEUR
 Raz [M]AMTASK(NOL),AMTPRS(NOL),AMTPNV(NOL),AMTRAL(NOL)
 #Si un niveau inférieur était coché il faut le décocher obligatoirement=>Problème des contrôles des montants
 For J=0 To [M]NBLIG-1
  If [M]NIV(J)>[M]NIV(NOL) & [M]ENV(J)=[M]ENV(NOL) & J<>(NOL) & [M]ASK(J)=2
   [M]ASK(J)=1
   Raz [M]AMTASK(J),AMTPRS(J),AMTPNV(J),AMTRAL(J)
  Endif
 Next J
 Affzo [M]
Endif
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

