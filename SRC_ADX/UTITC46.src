#<AdxTL>@(#)6.0.0.0 $Revision$ CQU data type modification
###############################################################################
# UTIGPA46 : Revalidation tables/screens with data type CQU    Module TC      #
###############################################################################
# GH 24/01/13                                                  Bug 85714      #
###############################################################################

Call MAJ_UTIGPA46
End

##################################
Subprog MAJ_UTIGPA46
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA46: Revalidation tables/screens with data type CQU") From LECFIC
Call EXE_UTIGPA46(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA46(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ATYPE","fde",DOSSIER),0)    <= 0  : End : Endif
Local File =[L]DOSSIER+".ATYPE"    [ATY]

Local Integer OLDLNG, NEWLNG
Local Integer MAJ, OK

Read [ATY]CODTYP = "CQU"
If !fstat : NEWLNG=[F:ATY]LNGTYP : Endif
If NEWLNG=0 : End : Endif

Call ECR_TRACE("UTIGPA46 : Process Start on : "+DOSSIER,0) From GESECRAN

#
# Revalidation (optimisée) des tables
#

Gosub VALID_TAB

#
# Revalidation (non optimisée) des écrans
#

Gosub VALID_ECR

Call ECR_TRACE("UTIGPA46 : Process End on : "+[L]DOSSIER,0) From GESECRAN
End

###########################################

$VALID_TAB
If filinfo(filpath("FIL","ATABZON","fde",DOSSIER),0)  <= 0  : Return : Endif
Local File =[L]DOSSIER+".ATABZON"  [ATZ]

Local Char    TABCUR(GLONATB)
MAJ=0

$BOUCLE_TAB
OK=0
For [ATZ]CODTYP(2) Where CODTYP="CQU" & CODFIC>TABCUR
     TABCUR=[F:ATZ]CODFIC
     If filinfo(filpath("FIL",[L]TABCUR,"fde",[L]DOSSIER),0)>0
        Local File =[L]DOSSIER+"."+[L]TABCUR [XXX]
        For [ATZ]CODTYP
            OLDLNG = evalue("type([F:XXX]"+[F:ATZ]CODZONE+")-10")
            If OLDLNG>0 & OLDLNG<>NEWLNG
               OK=1 : Break 2
            Endif
        Next
        Close Local File [XXX]
     Endif
Next
If OK
   Close Local File [XXX]
   If !MAJ
        Local File =[L]DOSSIER+".ATABLE"   [ATB]
        # Local File =[L]DOSSIER+".ATABZON"  [ATZ]
        Local File =[L]DOSSIER+".ATABIND"  [ATI]
        Local File =[L]DOSSIER+".AMSKPAR"  [AMP]
        Local File =[L]DOSSIER+".AINDEX"   [ANX]
        # Local File =[L]DOSSIER+".ATYPE"    [ATY]
        Local File =[L]DOSSIER+".ATEXTE"   [ATX]
        Local File =[L]DOSSIER+".ACTIV"    [ACV]

        If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
        If [F:ADS]DOSSIER<>[L]DOSSIER
           Read [ADS] DOSSIER=[L]DOSSIER
           If fstat : Raz [F:ADS] : Endif
        Endif

        If dim(GCOEFTAB)<0
            Global Decimal GCOEFTAB
            GCOEFTAB = 0.5
        Endif
   Endif
   Call MAJTABDOS([L]DOSSIER,[F:ATZ]CODFIC,1) From DOSTAB # Validation forcée
   MAJ+=1
   Goto BOUCLE_TAB
Endif

Close Local File [ATZ]
If MAJ
   Close Local File [ATB], [ATI], [AMP], [ANX], [ATX], [ACV]
Endif
Return

###########################################

$VALID_ECR
If filinfo(filpath("FIL","AMSKZON","fde",DOSSIER),0)  <= 0  : Return : Endif
Local File =[L]DOSSIER+".AMSKZON"  [AMZ]

Local Char    MSKCUR(GLONAMK)
MAJ=0

$BOUCLE_ECR
OK=0
For [AMZ]CODTYP(2) Where CODTYP="CQU" & CODMSK>MSKCUR
     MSKCUR = [F:AMZ]CODMSK
     If filinfo(filpath("ECR",[L]MSKCUR,"msk",[L]DOSSIER),7)>0
        Local Mask =[L]DOSSIER+"."+[L]MSKCUR [XXX]
        For [AMZ]CODTYP
            OLDLNG = evalue("type([M:XXX]"+[F:AMZ]CODZON+")-10")
            If OLDLNG>0 & OLDLNG<>NEWLNG
               OK=1 : Break 2
            Endif
        Next
        Close Local Mask [XXX]
     Endif
Next
If OK
   Close Local Mask [XXX]
   If !MAJ
      Local File =[L]DOSSIER+".AMSK"     [AMK]
      # Local File =[L]DOSSIER+".AMSKZON"  [AMZ]
      Local File =[L]DOSSIER+".AMSKACT"  [AMA]
      Local File =[L]DOSSIER+".AMSKPAR"  [AMP]
      # Local File =[L]DOSSIER+".ATYPE"    [ATY]
      Local File =[L]DOSSIER+".ATEXTE"   [ATX]
      Local File =[L]DOSSIER+".ACTIV"    [ACV]
      Local File =[L]DOSSIER+".ACTION"   [ACT]
      Local File =[L]DOSSIER+".ACTPAR"   [ATR]
      Local File =[L]DOSSIER+".AOBJET"   [AOB]
      Local File =[L]DOSSIER+".ATABLE"   [ATB]
      Local File =[L]DOSSIER+".ATABZON"  [ATZ]
      Local File =[L]DOSSIER+".ACTL"     [ACL]
      Local File =[L]DOSSIER+".AURL"     [AUR]

      If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
      If [F:ADS]DOSSIER<>[L]DOSSIER
         Read [ADS] DOSSIER=[L]DOSSIER
         If fstat : Raz [F:ADS] : Endif
      Endif
   Endif
   Call VALID([L]MSKCUR,[L]DOSSIER,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
   MAJ+=1
   Goto BOUCLE_ECR
Endif

Close Local File [AMZ]
If MAJ
   Close Local File [AMK], [AMA], [AMP], [ATX], [ACV], [ACT], [ATR], [AOB], [ATB], [ATZ], [ACL], [AUR]
Endif
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA46(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIGPA46(APPLI)
End
