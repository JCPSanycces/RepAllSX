#############################################################################
# Traitement SOHBPCM_CSTD : Liste commandes --> 3 onglets sur mobile        #
#   Classe représentation SOHBPCM : Liste des cdes (3 onglets sur mobile)   #
#   Classe données        SOHBPCM : Liste des cdes (3 onglets sur mobile)   #
#############################################################################


##################################
## $METHODS                     ##
##################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""             : #-- On est au niveau de SOQ --#
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER
      Endcase
   When "C_SORDERH1"
      Case [L]AEVENT
        When "--"

        #-- Action pour le Détail --#
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SORDERH1
      Endcase
Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
$PROPERTIES
#Case [L]CURPRO
#Endcase
Return

##################################
## $AREAD_AFTER                 ##
##################################
$AREAD_AFTER

  #-- Chargement de la LEG et de la devise société du document--#
  #If this.CPY<>""
  #  Local File COMPANY [CPY]
  #  Read [F:CPY]CPY0=this.CPY
  #  If fstat Raz [F:CPY] : Endif
  #  this.LEG    = [F:CPY]LEG
  #Endif

  #Gbn-97875
  If this.SOHCAT<>4
    Local File SORDERP [SOP]
    Filter [F:SOP] Where SOHNUM=this.SOHNUM & SOPLIN=this.SOPLIN
    Read [F:SOP] Last
    If !fstat
     this.TOTLINNOT = this.QTY * [F:SOP]NETPRINOT
     this.TOTLINATI = this.QTY * [F:SOP]NETPRIATI
    Else
     this.TOTLINNOT = 0
     this.TOTLINATI = 0
    Endif
    Filter [F:SOP]
  Endif

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

##################################
## $AREAD_AFTER_SORDERH1        ##
##################################
$AREAD_AFTER_SORDERH1

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SOHTYP_LEG(this, this.SOHTYP, this.CPY, this.SALFCY, this.APARENT.LEG, this.SOHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

