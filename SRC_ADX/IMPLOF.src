#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#    TRAITEMENT D'IMPORT DES DEPENSES
#    GBN
#    Création le : 05/08/2003
#
################################################################################
#    Modification
#    GLE - 22.09.2014  FQ102782 : Erreur "Le contexte "fiscal & comptable" de la société doit avoir été défini au préalable." à tort
#    GLE - 11.09.2014  FQ102224 : Initialisation de CPMCREORI à 5 si pas renseigné
#    CBO - 29.04.2014  FQ 69690 : Objet FAM
#    GLE - 27.01.2014  FQ 95955 : Détermination de la société et chargement de ses paramètres (FPC)
#    GLE - 01.06.2011  FQ 55725 : Import des dépenses validées par défaut
#    GLE - 27.04.2010  FQ 64491 : Import Abel Entreprise (voir également le traitement IMPPHYAE)
#    GLE - 23.09.2005  FQ 32253 : Correction pb montant de TVA récupéré
#    GLE - 01.08.2005  FQ 31543 : Adaptation pour import des dépenses X3 130
################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"            : Gosub IMP_OUVRE
 When "IMPORT"               : Gosub IMPORT
 When "IMP_VERIF_CRE"        : Gosub IMP_VERIF_CRE
 When "IMP_ZONE"             : Gosub IMP_ZONE      #--> Exécuté pour chaque zone de l'enr
 When Default
Endcase
Return

$IMP_OUVRE
Local Integer L_I                          : # Indice pour boucle
Local Integer ADI_TAB                      : # Numéro de table diverse
Local Char    ADI_COD(GLONADI)             : # Code de table diverse
Local Char    ADI_DES(GLONDES)             : # Intitulé code de table diverse
Local Char    LPARM                        : # Valeur d'1 paramètre
Local Char    TEXTE(80)                    : # Texte de ATEXTRA
Local Integer TRANS                        : # Indicateur de transaction
Local Integer CREBPR                       : # Indicateur de création auto des fournisseurs
Local Integer CREITMREF                    : # Indicateur de création auto des articles
Local Integer CREACGGRP                    : # Indicateur de création auto des familles
Local Integer CRECCE(GOPTCANA)             : # Indicateur de création auto des sections analytiques
Local Integer CREPLNINV                    : # Indicateur de création auto des références projets
Local Integer CREBUDINV                    : # Indicateur de création auto des budgets d'investissement
Local Integer CREDEMINV                    : # Indicateur de création auto des demandes d'investissement
Local Integer CRECONNUM                    : # Indicateur de création auto des marchés
Local Integer CREUSRFLDA(10)               : # Indicateur de création auto des codes zones libres
Local Integer RERROR                       : # Code retour FQ95955

If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif  : # Table des tiers
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif  : # Table des articles
If !clalev([F:CCE]) : Local File CACCE     [CCE] : Endif  : # Table des sections analytiques
If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif  : # Tables diverses

# Lecture des paramètres autorisant la création auto de données de base
Call PARAM("","CREBPR",LPARM) From ADOVAL                         : # Fournisseur
CREBPR = val(LPARM)
Call PARAM("","CREITMREF",LPARM) From ADOVAL                      : # Article
CREITMREF = val(LPARM)
Call PARAM("","CREACGGRP",LPARM) From ADOVAL                      : # Famille
CREACGGRP = val(LPARM)
Call PARAM("","CREPLNINV",LPARM) From ADOVAL                      : # Référence projet
CREPLNINV = val(LPARM)
Call PARAM("","CREBUDINV",LPARM) From ADOVAL                      : # Budget d'investissement
CREBUDINV = val(LPARM)
Call PARAM("","CREDEMINV",LPARM) From ADOVAL                      : # Demande d'investissement
CREDEMINV = val(LPARM)
Call PARAM("","CRECONNUM",LPARM) From ADOVAL                      : # Marché
CRECONNUM = val(LPARM)
For L_I=0 To GOPTCANA-1
  Call PARAM("","CRECCE"+num$(L_I+1),LPARM) From ADOVAL           : # Sections analytiques
  CRECCE(L_I) = val(LPARM)
Next L_I
For L_I=0 To 9
  Call PARAM("","CREUSRFL"+num$(L_I+1),LPARM) From ADOVAL         : # Codes zones libres
  CREUSRFLDA(L_I) = val(LPARM)
Next L_I

GCOUSIT = "" : # Pour forcer le rechargement FQ95955
Return

$IMPORT
# Initialisation de la société à partir du site financier FQ95955
If [F:LOF]FCY <> GCOUSIT
  Call LECTURE("FCY",[F:LOF]FCY,"") From CONTOBJ
  [F:LOF]CPY = [F:FCY]LEGCPY
  #GCOUSOC    = [F:FCY]LEGCPY : # FQ102782
  Call LOAD_FASPARCPY([F:LOF]CPY,"",G_OUI,RERROR) From GLOFCYCPY
Else
  [F:LOF]CPY = GCOUSOC
Endif

Gosub CREREF_AUTO
If TRANS & !GOK : OK=0 : Endif

# FQ102224 : déplacement de l'alimentation de CPMCREORI, LIGORI et ANALIGORI en fin d'import

# GLE FQ32253 - DEBUT
If [F:LOF]RATVATREC <> 0 Then : [M:LOF1]RATVATREC = [F:LOF]RATVATREC : Endif

If [F:LOF]AMTVATRCUR<>0 Then
  [M:LOF1]FLGRECFVR  = G_OUI
  [M:LOF1]AMTVATRCUR = [F:LOF]AMTVATRCUR
Else
  [M:LOF1]FLGRECFVR = G_NON
Endif
# GLE FQ32253 - FIN

If GCNXPROIAS = G_NON Then
  [M:LOF1]IASACN = 0
Endif

Return

$IMP_VERIF_CRE

# FQ31543 Alimentation manuelle des champs non modifiables si origine X3
If ([F:LOF]CPMCREORI = 0) : # FQ102224
  [M:LOF2]CPMCREORI = 5                : # Complément origine saisie initialisé à "Import"
Else
  [M:LOF2]CPMCREORI = [F:LOF]CPMCREORI : # Complément origine saisie
Endif
[M:LOF2]LIGORI    = [F:LOF]LIGORI    : # Ligne d'origine
[M:LOF2]ANALIGORI = [F:LOF]ANALIGORI : # Analytique d'origine

Call CALCUL_MONTANTS() From SUBLOF : # GLE FQ32253

Case GLOFAUTNUM
  When 1 : Gosub CTL_PRESENCE_REF : # Pas de numérotation automatique
  When 2 : Gosub CTL_ABSENCE_REF  : # Numérotation automatique obligatoire
  When 3 : Gosub CTL_REF          : # Numérotation automatique facultative
Endcase

# FQ55725 : par défaut, une dépense importée est validée
# Attention : à partir du moment où le champ FLGVAL est ajouté au modèle d'import, la non valorisation ou la
# valorisation à 0 du champ de le fichier sera transformé en "1" par le Superviseur. La validation automatique
# de la dépense à l'import ne fonctionne donc QUE SI le champ FLGVAL ne fait pas partie des champs du modèle, sinon
# par défaut la dépense sera créé non validée.
If [F:LOF]FLGVAL = 0
  [M:LOF1]FLGVAL = G_OUI
Endif
Return

$CTL_PRESENCE_REF
# L'identification de la dépense doit être complète
If [M:LOF0]CODLOF = "" | [M:LOF0]LINLOF = 0
  Call ECR_TRACE(mess(43,7772,1)-"("+num$([M:LOF0]LINLOF)+"/"+[M:LOF0]CODLOF+")",1) From GESECRAN
  OK=0
Endif
Return

$CTL_ABSENCE_REF
# L'identification de la dépense doit être absente
If [M:LOF0]CODLOF <> "" | [M:LOF0]LINLOF <> 0
  Call ECR_TRACE(mess(44,7772,1)-"("+num$([M:LOF0]LINLOF)+"/"+[M:LOF0]CODLOF+")",1) From GESECRAN
  OK=0
Endif
Return

$CTL_REF
# L'identification de la dépense ne peut être partielle
If ([M:LOF0]CODLOF <> "" & [M:LOF0]LINLOF = 0) | ([M:LOF0]CODLOF = "" & [M:LOF0]LINLOF <> 0)
  Call ECR_TRACE(mess(45,7772,1)-"("+num$([M:LOF0]LINLOF)+"/"+[M:LOF0]CODLOF+")",1) From GESECRAN
  OK=0
Endif
Return

$IMP_ZONE
Case IMPZON
  When "FLGVATFCR"
    If [F:LOF]AMTVATCUR<>0                     : # Gestion de l'indicateur de montant forcé (Mt TVA)
      [M:LOF1]FLGVATFCR = G_OUI
    Else
      [M:LOF1]FLGVATFCR = G_NON
    Endif
  When "FLGAMTGRA"
    If [F:LOF]AMTGRA<>0                        : # Gestion de l'indicateur de montant forcé (Mt subvention)
      [M:LOF2]FLGAMTGRA = G_OUI
    Else
      [M:LOF2]FLGAMTGRA = G_NON
    Endif
  When Default
Endcase
Return

$CREREF_AUTO
# Création automatique des éléments nécessaires au contrôle de la dépense dans le référentiel
TRANS = 0
If GTABCPT <> "" : Return : Endif                       : # Pas de création auto si on est installé avec X3
If CREBPR=G_OUI & [F:LOF]BPR <> "" : Gosub CREBPR_AUTO : Endif                 : # Fournisseur
If TRANS & !GOK : Return : Endif
If CREITMREF=G_OUI & [F:LOF]ITMREF <> "" : Gosub CREITMREF_AUTO : Endif        : # Article
If TRANS & !GOK : Return : Endif
If CREACGGRP=G_OUI : Gosub CREACGGRP_AUTO : Endif        : # Famille
If TRANS & !GOK : Return : Endif
For L_I=0 To GOPTCANA-1                                                        : # Sections analytiques
  If CRECCE(L_I)=G_OUI & [F:LOF]CCE(L_I) <> "" : Gosub CRECCE_AUTO : Endif
  If TRANS & !GOK : Break : Endif
Next L_I
If TRANS & !GOK : Return : Endif
If CREPLNINV=G_OUI & [F:LOF]PLNINV <> "" : Gosub CREPLNINV_AUTO : Endif        : # Référence projet
If TRANS & !GOK : Return : Endif
If CREBUDINV=G_OUI & [F:LOF]BUDINV <> "" : Gosub CREBUDINV_AUTO : Endif        : # Budget d'investissement
If TRANS & !GOK : Return : Endif
If CREDEMINV=G_OUI & [F:LOF]DEMINV <> "" : Gosub CREDEMINV_AUTO : Endif        : # Demande d'investissement
If TRANS & !GOK : Return : Endif
If CRECONNUM=G_OUI & [F:LOF]CONNUM <> "" : Gosub CRECONNUM_AUTO : Endif        : # Marché
If TRANS & !GOK : Return : Endif
For L_I=0 To 9                                                                 : # Codes zones libres
  If CREUSRFLDA(L_I)=G_OUI & evalue("[F:LOF]USRFLDA"+num$(L_I+1)) <> "" : Gosub CREUSRFLDA_AUTO : Endif
  If TRANS & !GOK : Break : Endif
Next L_I
If TRANS & !GOK : Return : Endif
If TRANS & GOK : Commit : Endif
Return

$CREBPR_AUTO
  Call CRE_BPR([F:LOF]BPR,GIMP(1)) From GLOFUNCIMP : # FQ64491
Return

$CREITMREF_AUTO
  Call CRE_ITM([F:LOF]ITMREF,GIMP(2)) From GLOFUNCIMP : # FQ64491
Return

$CRECCE_AUTO
  Call CRE_CCE([M:FPC]DIE(L_I),[F:LOF]CCE(L_I),GIMP(3+L_I)) From GLOFUNCIMP : # FQ64491
Return

$CREACGGRP_AUTO
  # Création automatique famille FQ69690
  Call CRT_FAM([F:LOF]ACGGRP, GIMP(7)) From SUBFAM
#  Call TRT_TABDIV(611, [F:LOF]ACGGRP, GIMP(7), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

$CREPLNINV_AUTO
  # Création automatique référence projet
  Call TRT_TABDIV(614, [F:LOF]PLNINV, GIMP(12), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

$CREBUDINV_AUTO
  # Création automatique budget d'investissement
  Call TRT_TABDIV(615, [F:LOF]BUDINV, GIMP(13), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

$CREDEMINV_AUTO
  # Création automatique demande d'investissement
  Call TRT_TABDIV(616, [F:LOF]DEMINV, GIMP(14), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

$CRECONNUM_AUTO
  # Création automatique marché
  Call TRT_TABDIV(620, [F:LOF]CONNUM, GIMP(15), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return

$CREUSRFLDA_AUTO
  # Création automatique codes zones libres
  Call TRT_TABDIV(evalue("GABLIADI"+num$(L_I+1)), evalue("[F:LOF]USRFLDA"+num$(L_I+1)), GIMP(16+L_I), "", "", 0, 0) From GLOFUNCIMP : # FQ64491
Return
