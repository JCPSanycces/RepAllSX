#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque USAPRDSEA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PRDDES
mkstat = 0
zoncou = "PRDDES"
indice = 0
If varmode([M]PRDDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRDDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SEAKEY
mkstat = 0
zoncou = "SEAKEY"
indice = 0
If varmode([M]SEAKEY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEAKEY" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SLDFLG
mkstat = 0
zoncou = "SLDFLG"
indice = 0
IMPENT = [M]SLDFLG
If varinit([M]SLDFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]SLDFLG,indice)=0
 [M]SLDFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SLDFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SLDFLG(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SLDFLG" : GZNUM = 20387 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]SLDFLG = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "USAPRDSEA"
Return

