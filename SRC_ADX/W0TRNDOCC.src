#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRNDOCC 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "PORDIGSIG"
    Call PORDIGSIG([M]CPY,"") From PORLEGLIB
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
indice = 0
If varmode([M]STRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
indice = 0
If varmode([M]ENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CTLDATVALW"
 PARAM(1) = [M]STRDAT
 Local Date    VALEUR
 VALEUR = [M]ENDDAT
 Call S_AFF_DAT(VALEUR,PARAM,"CTLDATVAL","CONTX3","") From GACTION
 [M]ENDDAT = VALEUR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone STAT
mkstat = 0
zoncou = "STAT"
indice = 0
IMPENT = [M]STAT
If varinit([M]STAT,indice)=0
 IMPENT = 1
Endif
[M]STAT = IMPENT

## Zone FLGSTA
mkstat = 0
zoncou = "FLGSTA"
indice = 0
IMPENT = [M]FLGSTA
If varinit([M]FLGSTA,indice)=0
 IMPENT = 1
Endif
[M]FLGSTA = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DOCTYP
mkstat = 0
zoncou = "DOCTYP"
indice = 0
IMPENT = [M]DOCTYP
WNUM = IMPENT
If varinit([M]DOCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DOCTYP,indice)=0
 Call INICOMBO(2047) From COMBOS
 [M]DOCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DOCTYP(indice)
 Endif
 If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
  mkstat = 1 : GMESSAGE = mess(99,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DOCTYP(IMPENT) From CNSTDCSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]DOCTYP = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone DOCNUMSTR
mkstat = 0
zoncou = "DOCNUMSTR"
indice = 0
WCHAR = [M]DOCNUMSTR
If varmode([M]DOCNUMSTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DOCNUMSTR([M]DOCNUMSTR) From CNSTDCSTD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DOCNUMSTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCNUMSTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]DOCNUMSTR or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DOCNUMSTR([M]DOCNUMSTR) From CNSTDCSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DOCNUMSTR" : GZNUM = 5169 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DOCNUMEND
mkstat = 0
zoncou = "DOCNUMEND"
indice = 0
If varmode([M]DOCNUMEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DOCNUMEND([M]DOCNUMEND) From CNSTDCSTD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DOCNUMEND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCNUMEND" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BPRNUMSTR
mkstat = 0
zoncou = "BPRNUMSTR"
indice = 0
WCHAR = [M]BPRNUMSTR
If varmode([M]BPRNUMSTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPRNUMSTR" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPR","!",[M]BPRNUMSTR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPRNUMSTR" : GZNUM = 19569 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]BPRNUMSTR or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_BPRNUMSTR([M]BPRNUMSTR) From CNSTDCSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "BPRNUMSTR" : GZNUM = 19569 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone BPRNUMEND
mkstat = 0
zoncou = "BPRNUMEND"
indice = 0
If varmode([M]BPRNUMEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPRNUMEND" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPR","!",[M]BPRNUMEND,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPRNUMEND" : GZNUM = 978 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRNDOCC"
Return

