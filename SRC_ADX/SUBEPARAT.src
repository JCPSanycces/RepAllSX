#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "LIENS"         : Gosub LIENS
  When "MODIF"         : Gosub MODIF
  When "CREATION"      : Gosub CREATION
  When "RAZCRE"       : Gosub LIENS
  When "FERME"        : Gosub FERME
  When "RAZCRE"       : Gosub RAZCRE
  When "FILTRE"       : Gosub FILTRE
Endcase
Return

$OUVRE
If clalev([F:EPARAT])=0       : Local File EPARAT     [EPARAT]    : Endif
If clalev([F:EPARATD])=0      : Local File EPARATD    [EPARATD]    : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#Filter [F:EPARAT] Where LEG = GLEGFIL

Affzo [M:EPARAT0]


Return

$FILTRE

   If GLEGFIL <> ''
      FILTSUP = 'LEG=GLEGFIL'
   Endif

Return


$LIENS

If dim([M:EPARAT0]LEG)>0 : GCURLEG=[M:EPARAT0]LEG : Endif

Local Integer I,K
#populate screens on startup

nolign = 0
#Populating the latest rates
 For I=1 To 2
  If I = 1 : K = 5 : Endif
  If I = 2 : K = 7 : Endif
  nolign += 1
  [M:EPARAT1]EPARATTYP(nolign-1)  = K
  Read [EPARATD]EPARATD0 = [F:EPARAT]EFFDAT;[F:EPARAT]LEG;[F:EPARAT]CPY;[F:EPARAT]FCY;K
  If !fstat
    [M:EPARAT1]EPARATVAL(nolign-1)  = [F:EPARATD]EPARATVAL
  Endif
Next
Assign "[M:EPARAT1]EPARATNBR" With nolign


Affzo [M:EPARAT1]
Return


#LIMAS - 2018-01-22 - X3-57798 - START
$FERME

  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

Return
#LIMAS - 2018-01-22 - X3-57798 - START


#LIMAS - 2018-01-22 - X3-57798 - START
$RAZCRE

Raz GCURLEG

Return
#LIMAS - 2018-01-22 - X3-57798 - END
$MODIF
$CREATION
#Creating/Updating records
Delete [F:EPARATD] Where EFFDAT=[M:EPARAT0]EFFDAT and LEG=[M:EPARAT0]LEG and CPY = [M:EPARAT0]CPY and FCY = [M:EPARAT0]FCY
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("EPARATD",[M:EPARAT0]EFFDAT) From GLOCK : Return
Endif

nolign = 0
For nolign = 0 To [M:EPARAT1]EPARATNBR-1
  Raz [F:EPARATD]
  [F:EPARATD]LEG       = [M:EPARAT0]LEG
  [F:EPARATD]CPY       = [M:EPARAT0]CPY
  [F:EPARATD]FCY       = [M:EPARAT0]FCY
  [F:EPARATD]EFFDAT    = [M:EPARAT0]EFFDAT
  [F:EPARATD]EPARATTYP = [M:EPARAT1]EPARATTYP(nolign)
  [F:EPARATD]EPARATVAL = [M:EPARAT1]EPARATVAL(nolign)
  Write [F:EPARATD]
  If fstat
    GOK=0 : Call FSTA("EPARATD") From GLOCK : Break
  Endif
Next
Return

Subprog C_EPARATVAL(VALEUR)
Variable Decimal VALEUR
If nolign = 4 or nolign = 5 : End : Endif
  VALEUR = func GPLAN.FMTNUM("N0:3.2#",VALEUR)
End

######################################################################################
## Section automatically added (screen EPARAT0) 09/13/2017 16:29:10 (PHVEN)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  Raz [M:EPARAT0]FCY
  Raz [M:EPARAT0]CPY
  GCURLEG=VALEUR
End


######################################################################################

######################################################################################
## Section automatically added (screen EPARAT0) 02/02/2018 11:13:15 (PHVEN)
######################################################################################
Subprog IB_CPY
End


######################################################################################

######################################################################################
## Section automatically added (screen EPARAT0) 02/02/2018 12:15:30 (PHVEN)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> ''
    If clalev([F:CPY])=0       : Local File COMPANY     [CPY]    : Endif

    Filter [F:CPY] Where LEG = GCURLEG and CPY = VALEUR
    Read [F:CPY] First

    If fstat > 0
      Filter [F:CPY] Where CPY = VALEUR
      Read [F:CPY] First

      GMESSAGE = VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
      Filter [F:CPY]
      mkstat = 2
    Endif

    Raz [M:EPARAT0]FCY

  Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()


  If VALEUR <> ''
    If clalev([F:FCY])=0       : Local File FACILITY     [FCY]    : Endif

    If [M:EPARAT0]CPY <> ''
      Filter [F:FCY] Where LEG = GCURLEG and LEGCPY = [M:EPARAT0]CPY and FCY = VALEUR
      Read [F:FCY] First

      If fstat > 0
        Filter [F:FCY] Where FCY = VALEUR
        Read [F:FCY] First

        GMESSAGE = VALEUR-func AFNC.MES1(mess(171,104,1),[M:EPARAT0]CPY)
        Raz [M:EPARAT0]FCY
        Filter [F:FCY]
        mkstat = 2 : End
      Endif
    Else
      Filter [F:FCY] Where LEG = GCURLEG and FCY = VALEUR
      Read [F:FCY] First

      If fstat > 0
        Filter [F:FCY] Where FCY = VALEUR
        Read [F:FCY] First

        GMESSAGE = VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
        Raz [M:EPARAT0]FCY
        Filter [F:FCY]
        mkstat = 2 : End
      Endif

    Endif



  Endif

End


