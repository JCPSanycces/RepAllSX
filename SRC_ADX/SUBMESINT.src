###############################################################
$ERR_IMPORT
NBERR+=1
Call ERR_IMPORT(IMPSTA,MESSAGE) From GIMPOBJ
Call ECR_TRACE(mess(6,123,1)-" : "-MESSAGE,1) From GESECRAN
Return
###############################################################
$IMPORT
 #On construit le nom du fichier
#Issue 96702 - 2014-04-16 by RBA - import/export directory
 Local Integer WTYPEXP
 Local Char WREPFIN(250)
 Local File AOBJEXT [WAOE]
 Trbegin [WAOE]
 Readlock [WAOE]AOE0 = [L]MODELE
 If fstat = 0
   WTYPEXP = [WAOE]TYPEXP
   WREPFIN = [WAOE]REPFIN
   [F:WAOE]TYPEXP = 2
#   [F:WAOE]REPFIN = [M:DIA]DRTWRK
   [F:WAOE]REPFIN = [M:DIA]VOLFILWRK
   Rewrite [WAOE]
   Commit
 Else
   Rollback
 Endif
 Close File [WAOE]
#/Issue 96702 - 2014-04-16 by RBA - import/export directory
 Gosub GETNOMFIC
 Raz [M:IMP2]
 Raz [M:AOE0], [M:AOE1], [M:AOE2]
 Call CHARGE_MODELE([L]MODELE,IMPSTA) From GIMPOBJ
 If IMPSTA : Return : Endif
 If [F:AOE]OBJ<>""
    Read [AOB_]ABREV = [F:AOE]OBJ
    If fstat : IMPSTA = 18 : Return : Endif
 Endif
 [M:IMP2]MODIMP = [L]MODELE
 [M:IMP2]NOMIMP = NOMFIC
 [M:IMP2]TYPEXP = [M:DIA]TYPEXP
 Call IMPORTSIL([L]MODELE,[M:IMP2]NOMIMP) From GIMPOBJ
#Issue 96702 - 2014-04-16 by RBA - import/export directory
 Local File AOBJEXT [WAOE]
 Trbegin [WAOE]
 Readlock [WAOE]AOE0 = [L]MODELE
 If fstat = 0
   [F:WAOE]TYPEXP = WTYPEXP
   [F:WAOE]REPFIN = WREPFIN
   Rewrite [WAOE]
   Commit
 Else
   Rollback
 Endif
 Close File [WAOE]
#/Issue 96702 - 2014-04-16 by RBA - import/export directory
 IMPSTA = [M:IMP2]STAT
# Issue 88807 - 2012-08-29 by RBA - Eviter le message d'erreur si IMPSTA = 2 Fichier inexistant
# If IMPSTA : Gosub ERR_IMPORT : Endif
  If IMPSTA <> 0 and IMPSTA <> 2 : Gosub ERR_IMPORT : Endif
#/ Issue 88807
 If GOK<1 : IMPSTA = 11 : Gosub ERR_IMPORT : Endif
 Raz mkstat
 Raz IMPSTA
 GOK=1
 OK=1
 Raz GERR
 Raz GMESSAGE
Return

