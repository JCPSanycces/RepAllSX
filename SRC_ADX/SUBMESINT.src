######################################################################################
Subprog AM_FLGMKOTPL(VALEUR)
Variable Integer VALEUR
If [M:DIA]MKOPARAM<>"" & VALEUR=2
    Read [F:BTS]BTS0 = 60;[M:DIA]MKOPARAM
    If fstat
       GMESSAGE=mess(45,7710,1)
       mkstat=2
       GERR=1
       End
    Endif
    If find([F:BTS]MATFLG,3,4)
        [M:DIA]FLGMKMTPL=1
    ###Else
    ###    [M:DIA]FLGMKMTPL=2
    Endif
    Affzo [M:DIA]FLGMKMTPL
    If find([F:BTS]ITMFLG,3,4)
        [M:DIA]FLGMKITPL=1
    ###Else
    ###    [M:DIA]FLGMKITPL=2
    Endif
    Affzo [M:DIA]FLGMKITPL
Endif
[M:DIA]FLGMKOTPL=VALEUR
OK=1
WCOUZON="FLGMKOTPL"
Gosub CTRLTRS
If OK=0
    GERR=1
    mkstat=2
    End
Endif
End



######################################################################################

Subprog AM_FLGMKMTPL(VALEUR)
