 # X3-26914 by RBA 20-04-2017
 #[M:EXP2]=[M:EXP1]
 Transmask [M:EXP1] To [M:EXP2]
 #/ X3-26914 by RBA 20-04-2017
 [M:EXP2]MODELE = [L]MODELE
 [M:EXP2]NOMEXP = NOMFIC
 [M:EXP2]TYPEXP = [M:DIA]TYPEXP
 Gosub ANALYSE_FORMULE
 [M:EXP2]CRITERE(0)=CRITERE
 [M:EXP2]CRITERE(1)=CRITERE1
 # FQ 64414 GA 04/2010 ajout de trace
 Call ECR_TRACE("Selection 0:"-CRITERE,0) From GESECRAN
 Call ECR_TRACE("Selection 1:"-CRITERE1,0) From GESECRAN
 Call EXPORTSIL From GEXPOBJ
 IMPSTA = [M:EXP2]STAT
 If IMPSTA : Gosub ERR_EXPORT : Endif
 If GOK<1 : IMPSTA = 11 : Gosub ERR_EXPORT : Endif
 Raz mkstat
 Raz IMPSTA
 GOK=1
 OK=1
 Raz GERR
 Raz GMESSAGE
Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If FORMULE  <> ""
    Read [F:TFO]TFO0=TYPFOR;FORMULE
    If !fstat
        If pat([F:TFO]FORFOR,"*MFI]*") | pat([F:TFO]FORFOR,"*MFM]*")
            If CRITERE1 = ""
                CRITERE1 = [F:TFO]FORFOR
            Else
                CRITERE1 += "&"
                CRITERE1 += [F:TFO]FORFOR
            Endif
        Else
            If CRITERE = ""
                CRITERE = [F:TFO]FORFOR
            Else
                CRITERE += "&"
                CRITERE += [F:TFO]FORFOR
            Endif
        Endif
    Endif
Endif
Return


