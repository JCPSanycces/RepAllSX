##BASENOMFIC="MFM#.TXT"
##Else
BASENOMFIC="MFM.TXT"
##Endif
CRITERE="MFGSTA=1"
If pat(GVERSION,"1.5.*")
TYPFOR=26
Else
TYPFOR=44
Endif
FORMULE=[M:DIA]MFGFOR
Gosub ANALYSE_FORMULE
Raz CRITERE1
If pat(GVERSION,"1.5.*")
TYPFOR=25
Else
TYPFOR=40
Endif
