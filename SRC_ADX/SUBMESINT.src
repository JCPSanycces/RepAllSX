#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBMESINT","MESINT",4,"SPEMESINT") From GTRAITE
End

# Gestion du masque MESINT

######################################################################################
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
 When "INIT"         : Gosub OUVRE : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

$INI_STO
If clalev([F:MTS])=0 Local File MFGTRS     [MTS]  Endif
If clalev([F:SWL])=0 Local File STOLOCRES  [SWL]  Endif
If clalev([F:STL])=0 Local File STOLOT     [STL]  Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  Endif  # FQ 64414 GA 04/2010 erreur dans STKLOC
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITV])=0 Local File ITMMVT     [ITV]  Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP]  Endif
If clalev([F:TUN])=0 Local File TABUNIT    [TUN]  Endif
If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO])=0 Local File STOCK      [STO]  Endif
If clalev([F:STS])=0 Local File STOSER     [STS]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:SRU])=0 Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST])=0 Local File TABSTASTO  [TST]  Endif
If clalev([F:TLO])=0 Local File TABLOCTYP  [TLO]  Endif
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
If clalev([F:SRT])=0 Local File STKTRS     [SRT]  Endif
# Ne semblent pas utiles
##If clalev([F:STA])=0 Local File STOALL     [STA]  Endif
##If clalev([F:STC])=0 Local File STOLOC     [STC]  Endif
If clalev([M:ENTL])=0 Local Mask STOENTLOT [ENTL] Endif  #  ecran saisie complement lot

# Important : l écran STOENTW doit etre ouvert par le document appelant
If clalev([M:ENTW])=0 Local Mask STOENTW   [ENTW] Endif  #  ecran stockage mvt du document

If clalev([M:ENT])=0 Local Mask STOENT    [ENT] Endif  #  ecran stockage
If clalev([M:MTK2])=0 : Local Mask MTK2 [MTK2] : Endif

#########
If !pat(GVERSION,"1.5.*")
    ######### n'existe pas en V5
    If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
Endif

Return
######################################################################################
$OUVRE
Local Integer NBERR : NBERR=0
Local Integer OK , STAT, IMPSTA
Local Char    MESSAGE(250)
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    FORMULE (GLONFOR)
Local Integer TYPFOR
Local Char    NOMFIC(GDIMFIC), FICBAS(GDIMFIC)
Local Char    REPERT(GDIMFIC), NOMREP(GDIMFIC)
Local Char    MACHINE(GDIMFIC)
Local Char    MODELE(GLONAOE)
# Issue 84156 - 2012-08-29 by RBA - Enregistrement fichier trace
Local Char FICBASTRA(GDIMFIC)
Local Char NOMFICTRA(GDIMFIC)

###Local Char   FICREF(GDIMFIC),FICREJ(GDIMFIC), WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(10)
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:BTS]) = 0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif

Gosub INI_STO

Local Mask MESINT [DIA] : # Saisie paramètres
Raz [M:DIA]
If clalev ([F:MPA]) = 0 : Local File MESPAR [MPA] : Endif
Call GET_DERLU([M:DIA]ID,"MES","")
If [M:DIA]ID<>""
    Call AP_ID([M:DIA]ID)
Endif

Local Char    MKOPARAM(10)
# Transaction suivi temps import
Call PARAM(GFCY,"MKOTRSNUM",MKOPARAM) From ADOVAL
[M:DIA]MKOPARAM=MKOPARAM

Local Char    MKIPARAM(10)
# Transaction suivi production
Call PARAM(GFCY,"MKITRSNUM",MKIPARAM) From ADOVAL
[M:DIA]MKIPARAM=MKIPARAM

Gosub OUVRE From GEXPOBJ
Gosub OUVRE From GIMPOBJ
[M:DIA]TRACE=2
Return

$DEBUT
# Issue 98931 - 2014-07-04 by RBA : Volumes managment evolution
If [M:DIA]ID<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
Endif
#/ Issue 98931 - 2014-07-04 by RBA : Volumes managment evolution
Diszo [M:DIA]MKOPARAM
Diszo [M:DIA]MKIPARAM
Affzo [M:DIA]
Return

$CTRLTRS
If [M:DIA]MKOPARAM<>"" & [M:DIA]FLGMKOTPL=2
    Read [F:BTS]BTS0 = 60;[M:DIA]MKOPARAM
    If fstat
       GMESSAGE=mess(45,7710,1)
       OK=0
       Return
    Endif
    If find([F:BTS]MATFLG,3,4) & [M:DIA]FLGMKMTPL=2 & (WCOUZON="FLGMKMTPL" | WCOUZON="")
       GMESSAGE=mess(46,7710,1)-mess(47,7710,1)-mess(49,7710,1)
       OK=0
       Return
    Endif
    ###If [F:BTS]MATFLG<>3 & [M:DIA]FLGMKMTPL=1 & (WCOUZON="FLGMKMTPL" | WCOUZON="")
    ###   GMESSAGE=mess(50,7710,1)
    ###   OK=0
    ###   Return
    ###Endif
    If find([F:BTS]ITMFLG,3,4) & [M:DIA]FLGMKITPL=2 & (WCOUZON="FLGMKITPL" | WCOUZON="")
       GMESSAGE=mess(48,7710,1)-mess(47,7710,1)-mess(49,7710,1)
       OK=0
       Return
    Endif
    ###If [F:BTS]ITMFLG<>3 & [M:DIA]FLGMKITPL=1 & (WCOUZON="FLGMKITPL" | WCOUZON="")
    ###   GMESSAGE=mess(51,7710,1)
    ###   OK=0
    ###   Return
    ###Endif
Endif
If [M:DIA]MKIPARAM<>"" & [M:DIA]FLGMKITPL=2
    Read [F:BTS]BTS0 = 62;[M:DIA]MKIPARAM
    If fstat
       GMESSAGE=mess(58,7710,1)
       OK=0
       Return
    Endif
    If find([F:BTS]MATFLG,3,4) & [M:DIA]FLGMKMTPL=2 & (WCOUZON="FLGMKMTPL" | WCOUZON="")
       GMESSAGE=mess(46,7710,1)-mess(59,7710,1)-mess(49,7710,1)
       OK=0
       Return
    Endif
    ###If [F:BTS]MATFLG<>3 & [M:DIA]FLGMKMTPL=1 & (WCOUZON="FLGMKMTPL" | WCOUZON="")
    ###   GMESSAGE=mess(50,7710,1)
    ###   OK=0
    ###   Return
    ###Endif
Endif
Return
#######################################################
$CONTROLE
If !GSERVEUR
    TMP = 1
Endif
If GSTATUT=7
    FIN = 1 : # Sortie du GSAISIE par la touche FIN
    Return
Endif

If [M:DIA]TYPEXP=2 & [M:DIA]DRTWRK=[M:DIA]DRTSTO
    ##Les répertoires indiqués doivent être différents
    GERR=1
    SAI=1
    GMESSAGE=mess(44,7710,1)
    Return
Endif

If [M:DIA]FLGTMATPL=1 &
&     [M:DIA]FLGTSRTPL=1 &
&     [M:DIA]FLGMWSTPL=1 &
&     [M:DIA]FLGMFITPL=1 &
&     [M:DIA]FLGMFOTPL=1 &
&     [M:DIA]FLGMFMTPL=1 &
&     [M:DIA]FLGMKOTPL=1 &
&     [M:DIA]FLGMKMTPL=1 &
&     [M:DIA]FLGMKITPL=1
    ##Il faut demander au moins le traitement d'un fichier
    GERR=1
    SAI=1
    GMESSAGE=mess(36,7710,1)
    Return
Endif
OK=1
WCOUZON=""
Gosub CTRLTRS
If OK=0
    GERR=1
    SAI=1
    Return
Endif
Return

###############################################################
$TERMINE
  If !GSERVEUR & ( [M:DIA]TRACE=2 | NBERR>0)
    TRA = 1
  Else
    TRA = 0
  Endif
  Gosub SUP_VAR
Return

###############################################################
######################################################################################
$EXEC
Local Char WCLIGNE (100)
WCLIGNE="======================================================================"

TIT  = mess(25,7710,1)

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Gosub INI_VAR
Gosub DEB_CPTRENDU

WDATBAS=format$("D:YYYYMMDDhhmmss",date$)

#exports
Gosub TRAIT_TMA
Gosub TRAIT_TSR
Gosub TRAIT_MWS
Gosub TRAIT_MFI
Gosub TRAIT_MFO
Gosub TRAIT_MFM
#imports
Gosub TRAIT_MKO
Gosub TRAIT_MKM
Gosub TRAIT_MKI

Gosub FIN_CPTRENDU

# Issue 84156 - 2012-08-29 by RBA - Enregistrement fichier trace
If GERRTRACE>0
  If [M:DIA]TYPEXP=2
    FICBASTRA= filpath("TRA",GTRACE,"tra",nomap,"",adxmac(0))
    NOMFICTRA= filpath([M:DIA]DRTSTO,"TRA"+WDATBAS+'_'+GTRACE,"tra","","",MACHINE)
    Call COPIE(FICBASTRA,NOMFICTRA,STAT) From ORDSYS
   Endif
Endif

##If NBERR>0
###on doit envoyer un mail
##    Gosub SEND_MAIL
##Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

###############################################################
$TRAIT_MKI
If [M:DIA]FLGMKITPL<>2 | [M:DIA]MKITPL="" : Return : Endif
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
############
# Import Suivis de fabrication
Call ECR_TRACE("=========="-mess(29,7710,1),0) From GESECRAN
#ON VA LIRE LE MODELE
[L]MODELE=[M:DIA]MKITPL
#On donne la base du nom du fichier
# Issue 107371 - 2015-04-03 by RBA : Volumes managment
#NOMREP=[M:DIA]DRTWRK
NOMREP=[M:DIA]VOLFILWRK
#/ Issue 107371 - 2015-04-03 by RBA : Volumes managment
##If [M:DIA]TYPEXP = 2
##BASENOMFIC="MKI#.TXT"
##Else
BASENOMFIC="MKI.TXT"
##Endif
Gosub IMPORT
#on doit basculer le fichier dans le repertoire des fichiers traites ssi sur serveur
# Issue 88807 - 2012-08-29 by RBA - Eviter le message d'erreur si IMPSTA = 2 Fichier inexistant
  If IMPSTA <> 2
    If [M:DIA]TYPEXP=2
        FICBAS= filpath([M:DIA]DRTWRK,"MKI","TXT","","",MACHINE)
        NOMFIC= filpath([M:DIA]DRTSTO,"MKI"+WDATBAS,"TXT","","",MACHINE)
        Call MOVE_EMPTY(FICBAS,NOMFIC,STAT) From ORDSYS
    Endif
  Endif
#If [M:DIA]TYPEXP=2
#    FICBAS= filpath([M:DIA]DRTWRK,"MKI","TXT","","",MACHINE)
#    NOMFIC= filpath([M:DIA]DRTSTO,"MKI"+WDATBAS,"TXT","","",MACHINE)
#    Call MOVE_EMPTY(FICBAS,NOMFIC,STAT) From ORDSYS
#Endif
#/ Issue 88807
Return


