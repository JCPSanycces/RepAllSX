#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
Endcase
Return


$IMPORT

Local Integer NOL
Gosub IMP_DECLARE From TRTX3IMP

Case IMPFIC
    When "BRL" : # BUDREQL : Détail de demnde de budget
        ICLEPRIM (0) = "[F:BRL]REQNUM"
        TPRIM (0) = "REQNUM"
        NBASTAB = "NBLIG"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
        # C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBLIG 
            nolign=NOL+1
            [M]NBLIG+=1
        Endif
Endcase

Return

