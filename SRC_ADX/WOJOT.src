$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(10)(0..GNBDERNIER)
Local Char     A_BUF2(10)(0..GNBDERNIER)
Local Char     A_BUF3(20)(0..GNBDERNIER)
Local Char     A_BUF4(10)(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
Local Char     A_BUF6(10)(0..GNBDERNIER)
Local Date     A_BUF7(0..GNBDERNIER)
Local Date     A_BUF8(0..GNBDERNIER)
Local Char     A_BUF9(30)(0..GNBDERNIER)
If clalev([F:JOT9])>0 : Close Local File [JOT9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(10),
& Char     A_TAB2(10),
& Char     A_TAB3(20),
& Char     A_TAB4(10),
& Char     A_TAB5(20),
& Char     A_TAB6(10),
& Date     A_TAB7,
& Date     A_TAB8,
& Char     A_TAB9(30)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9
& As [JOT9]
Return

$LEC_DERLU
Read [AXL]AXX0="ATABDIV";"SHODES";GLANGUE;"10459";[F:JOT]UOMGRP
If fstat : Raz [F:AXL] : Endif
Read [AXK]AXX0="ATABDIV";"SHODES";GLANGUE;"10460";[F:JOT]JOBGRP
If fstat : Raz [F:AXK] : Endif
Read [AXJ]AXX0="JOBTYP";"DES";GLANGUE;[F:JOT]COD;""
If fstat : Raz [F:AXJ] : Endif
Return

$CHARGE_DERLU
If clalev([F:JOT9])>0
 Read [JOT9] = [F:JOT9]A_TABI
 [L]CLE = [F:JOT9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:JOT9])>0
 Filter [JOT9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [JOT1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:JOT9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:JOT]COD+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:JOT9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:JOT9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:JOT]COD"
Call TEXTE(45853,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:JOT]COD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "[F:AXJ]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:JOT]UOMGRP"
Call TEXTE(13912,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:JOT]UOMGRP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(4)"
SELEXP(NBSEL) = "[F:AXL]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:JOT]JOBGRP"
Call TEXTE(46541,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:JOT]JOBGRP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(6)"
SELEXP(NBSEL) = "[F:AXK]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:JOT]DATSTRVLY"
Call TEXTE(1805,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:JOT]DATSTRVLY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:JOT]DATENDVLY"
Call TEXTE(1806,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:JOT]DATENDVLY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(9)"
SELEXP(NBSEL) = "string$([F:JOT]LEG<>'',[F:JOT]LEG)+string$([F:JOT]LEG='',mess(91,187,1))"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
If clalev([F:JOT_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AXL])=0 : Local file ATEXTRA [AXL] : Endif
If clalev([F:AXK])=0 : Local file ATEXTRA [AXK] : Endif
If clalev([F:AXJ])=0 : Local file ATEXTRA [AXJ] : Endif
Link [JOT] With
& [AXL]AXX0="ATABDIV";"SHODES";GLANGUE;"10459";[F:JOT]UOMGRP,
& [AXK]AXX0="ATABDIV";"SHODES";GLANGUE;"10460";[F:JOT]JOBGRP,
& [AXJ]AXX0="JOBTYP";"DES";GLANGUE;[F:JOT]COD;""
& As [JOT_]
Return

$DEFAUT_LISTE
Default file [JOT_]
Return

