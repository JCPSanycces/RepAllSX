## CRUD-CLASSE ## EMPLOTRY
# 2018-11-06 07:06:18 424


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOTRY

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOTRY

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOTRY
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOTRY
Else
 Gosub AINSERT_EMPLOTRY
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOTRY.freeSnapshot
EMPLOTRY.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOTRY.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOTRY.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOTRY
Trbegin [F:TRY]
 Gosub AINSERT_EMPLOTRY
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOTRY
Raz [F:TRY]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOTRY._MAJSQL_EMPLOTRY(EMPLOTRY))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOTRY.snapshotEnabled=1
 [L]A_RETIK = EMPLOTRY.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOTRY.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOTRY.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOTRY.ASTALIN = [V]CST_ALL
Endif
Return



