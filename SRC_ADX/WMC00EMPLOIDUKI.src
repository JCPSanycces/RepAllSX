#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:58 090

Gosub TEST From WMCR_EMPLOIDUKI : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOIDUKI : EMPLOIDUKI
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOIDUKI._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOIDUKI.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOIDUKI.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOIDUKI [IDUKI]
 Local File EMPLOIDUKI [AAA_]
Else
 Local File =EMPLOIDUKI.ACTX.AFOLDER+".EMPLOIDUKI" [IDUKI]
 Local File =EMPLOIDUKI.ACTX.AFOLDER+".EMPLOIDUKI" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [IDUKI] With
& [AAA_]IDUKI0 = REFNUM
& As [LNK_]
Return

############################################################################################
### EMPLOIDUKI(WIDUKI)
############################################################################################
Funprog  _MAJSQL_EMPLOIDUKI(WIDUKI)
Variable Instance WIDUKI Using C_EMPLOIDUKI
Local Integer ASTATUS,A_I,A_J
Default File [F:IDUKI]
If WIDUKI.ASTALIN=[V]CST_ANEW
 Call INICRE(WIDUKI) From ASYRSUB
 SetInstance [F:IDUKI] With WIDUKI
 Write [F:IDUKI]
 If fstat
  Call FSTA("IDUKI",WIDUKI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WIDUKI.updTick = [F:IDUKI]updTick
Elsif WIDUKI.ASTALIN=[V]CST_ALL or WIDUKI.ASTALIN=[V]CST_AUPD
 Call INIUPD(WIDUKI) From ASYRSUB
 SetInstance [F:IDUKI] With WIDUKI
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WIDUKI,"EMPLOIDUKI")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:IDUKI]IDUKI0 = [F:IDUKI]REFNUM
 If fstat
  Call FSTA("IDUKI",WIDUKI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WIDUKI.updTick = [F:IDUKI]updTick
Elsif WIDUKI.ASTALIN=[V]CST_ADEL
 SetInstance [F:IDUKI] With WIDUKI
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WIDUKI,"EMPLOIDUKI")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:IDUKI]IDUKI0 = [F:IDUKI]REFNUM
 If fstat
  Call FSTA("IDUKI",WIDUKI,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



