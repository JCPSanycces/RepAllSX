########################################
Subprog AV_ITMTYP(VALEUR)
Variable Integer VALEUR
Local Integer L : L = nolign - 1

If [M:MFS2]ITMTYP(L) = 2
  pcolor = GCOUL(3)
Else
  pcolor = GCOUL(0)
Endif
End

########################################
Subprog AV_REJCPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer L : L = nolign - 1

If [M:MFS2]REJCPLQTY(L) <> 0
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(0)
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS2) 10/09/2010 09:07:58 (CCC)
######################################################################################
Subprog B2_NBCPS
Local Integer LIND

[M:MFS2]AFFFLG([M:MFS2]NUMLIGCPS(nolign-1)-1) = 1
Affzo [M:MFS2]AFFFLG([M:MFS2]NUMLIGCPS(nolign-1)-1)

For I=[M:MFS2]NUMLIGCPS(nolign-1) To [M:MFS2]NBLIG-1
    [M:MFS2]NUMLIG(I)-=1
Next
Affzo [M:MFS2]NUMLIG

Dela nolign-1, 1 [M:MFS2]NBCPS
[M:MFS2]NBCPS -=1
Affzo [M:MFS2]10

End

######################################################################################
Subprog AM_AFFFLG(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
    Dela [M:MFS2]NUMLIG(nolign-1)-1, 1 [M:MFS2]NBCPS
    [M:MFS2]NBCPS -=1
    Affzo [M:MFS2]10
    For I=nolign To [M:MFS2]NBLIG-1
        [M:MFS2]NUMLIG(I)-=1
    Next
Else
    Insa [M:MFS2]NUMLIG(nolign-1)-1, 1 [M:MFS2]NBCPS
    [M:MFS2]CPSREF([M:MFS2]NUMLIG(nolign-1)-1)      = [M:MFS2]ITMREF(nolign-1)
    [M:MFS2]STUG([M:MFS2]NUMLIG(nolign-1)-1)        = [M:MFS2]STU(nolign-1)
    [M:MFS2]EXTQTYG([M:MFS2]NUMLIG(nolign-1)-1)     = [M:MFS2]EXTQTY(nolign-1)
    [M:MFS2]CPLQTYG([M:MFS2]NUMLIG(nolign-1)-1)     = [M:MFS2]CPLQTY(nolign-1)
    [M:MFS2]NUMLIGCPS([M:MFS2]NUMLIG(nolign-1)-1)   = nolign
    [M:MFS2]NBCPS +=1
    Affzo [M:MFS2]10
    For I=nolign To [M:MFS2]NBLIG-1
        [M:MFS2]NUMLIG(I)+=1
    Next
Endif
Affzo [M:MFS2]NUMLIG
End
