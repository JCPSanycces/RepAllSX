######################################################################################################
# Module        : Finance
# Description   : Manages duplicate class for camt element mapping (Class BSIELTMAP)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CODNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub CODNEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################

$CODNEW_CONTROL
  If this.CODNEW <> ""
    If func CTRL_EXIST_ELTMAP(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("CODNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CODNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_ELTMAP(this.CODNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSIELTNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_ELTMAP(this.COD, this.CODNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CODNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CODNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_ELTMAP(WCOD)
Value Char WCOD

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCOD <> ""
    Local File BSIELTMAP [BSIELT]
    Read [BSIELT]BSIELT0 = WCOD
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSIELT]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_ELTMAP(WCOD, WCOD_NEW, WERR)
Value Char WCOD
Value Char WCOD_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSIELTMAP [BSIELT]
  Local File BSIELTMAP [BSIELT2]
  Local File BSIELTMAPD [BSIELTD]
  Local File BSIELTMAPD [BSIELTD2]
  WERR = ""

  Trbegin [BSIELT2], [BSIELTD2]

  Read [BSIELT]BSIELT0 = WCOD
  If !fstat
    [BSIELT2]       = [BSIELT]
    [BSIELT2]COD    = WCOD_NEW
    Write [BSIELT2]
    If fstat
      WOK = [V]CST_AERROR
      WERR = "BSIELTMAP ("+mess(1,7983,1)+")"
    Endif
  Else
    WOK = [V]CST_AERROR
    WERR = "BSIELTMAP ("+mess(7,7983,1)+")"
  Endif

  If WOK = [V]CST_AOK
    Filter [BSIELTD] Where COD = WCOD
    For [BSIELTD]
      [BSIELTD2]       = [BSIELTD]
      [BSIELTD2]COD    = WCOD_NEW
      Write [BSIELTD2]
      If fstat
          WOK = [V]CST_AERROR
          Break
      Endif
    Next
    Filter [BSIELTD]
  Endif

  If WOK = [V]CST_AERROR
    If WERR = "" : WERR = "BSIELTMAPD ("+mess(3,40,1)-num$([BSIELTD2]LIN)+")" : Endif
    Rollback
  Else
    Commit
  Endif

  LogicClose File [BSIELTD2]
  LogicClose File [BSIELTD]
  LogicClose File [BSIELT2]
  LogicClose File [BSIELT]
End WOK

