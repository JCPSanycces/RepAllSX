#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
#Call OUVRE_TRACE( "STKSHTSEL" ) From LECFIC
## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères

GPROG    = "TRTSHTS"
GTYPPROG = 3
GWINDOW  = "ISHTS"
GWINCRIT = "ISHTCRIT"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG) From GTRAITE
#Call LEC_TRACE From LECFIC
#Call FERME_TRACE From LECFIC
End
#CHECK UNUSED_END

##################################################################################
##################################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH"    : Gosub OUVRE                # hcb 38033
 When "OUVRE"          : Gosub OUVRE
 When "INIT"           : Gosub INIT
 When "INIT_DIA"       : Gosub INIT_DIA      From TRTSHTCRIT
 When "DEBUT"          : Gosub DEBUT
 When "SETBOUT"        : Gosub SETBOUT
 When "EXEC"           : Gosub EXEC                 # hcb 38033
 When "AB1_NBLIG"      : Gosub AB1_NBLIG
 When "BB1_NBLIG"      : Gosub BB1_NBLIG
 When "FIR"            : Call ALIM_SHTS(0,1) From TRTSHTA
 When "LAS"            : Call ALIM_SHTS(0,2) From TRTSHTA
 When "PRE"            : Call ALIM_SHTS(0,3) From TRTSHTA
 When "SUI"            : Call ALIM_SHTS(0,4) From TRTSHTA
 When "BOUTON"   :
    Case BOUT
        When "R" :
                Call TEMPON("C") From GESECRAN
                If [M:SSC]MONOITMFLG=2
                    [M:SHTS]ITMREFEND = [M:SHTS]ITMREFSTR
                    Call ALIM_SHTS(0, 5) From TRTSHTA
                Else
                    Call ALIM_SHTS(0, 0) From TRTSHTA
                Endif
                Call TEMPOFF From GESECRAN
        When "I" : Call SELECT_ALL(2) From TRTSHTA
        When "E" : Call SELECT_ALL(1) From TRTSHTA
        When "A" : Call REGUL From TRTSHTA
    Endcase
 When Default :
Endcase

Return


#########################################   # hcb 38033 deb
$EXEC
If GSERVEUR
   If clalev([F:ITM]) =0 Local File ITMMASTER  [ITM]  Endif
   If clalev([F:STE]) =0 Local File STOPAR     [STE]  Endif
   If clalev([F:ITF]) =0 Local File ITMFACILIT [ITF]  Endif
   If clalev([F:STJ]) =0 Local File STOJOU     [STJ]  Endif
   If clalev([F:STA]) =0 Local File STOALL     [STA]  Endif
   If clalev([F:ITV]) =0 Local File ITMMVT     [ITV]  Endif
   If clalev([F:ITG]) =0 Local File ITMCATEG   [ITG]  Endif
   If clalev([F:STO]) =0 Local File STOCK      [STO]  Endif
   If clalev([F:STL]) =0 Local File STOLOT     [STL]  Endif
   If clalev([F:SRU]) =0 Local File TABSTORUL  [SRU]  Endif
   If clalev([F:TRU]) =0 Local File TABALLRUL  [TRU]  Endif
   If clalev([F:ACV]) =0 Local File ACTIV      [ACV]  Endif
   If clalev([M:SHTS])=0 Local Mask STKSHTSEL  [SHTS] Endif
   If GWRHACT = 2                                             # hcb 58361
      If clalev([F:ITW])=0  Local File ITMWRH    [ITW] Endif
      If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
   Endif
   If dim(GCOD_SLS)<1
      Global Integer GCOD_SLS
   Endif
   If dim(GSUITE)  <1
      Global Integer GSUITE
   Endif
   Raz GSUITE
   Read [ACV] CODACT="SLS"
   If !fstat
      GCOD_SLS=[F:ACV]DIME
   Endif

   Call LOADSHTS(0)            From TRTSHTA
   Call SELECT_ALL(2)          From TRTSHTA
   Call GETSOC([M:SHTS]STOFCY) From DEVSUB
   Call REGUL                  From TRTSHTA

Endif


Return

########################################## hcb 38033 fin
#########################################
# Ouverture des fichiers nécessaires
#########################################
$INIT
    Global Integer GOUVSHTREG    # Indique si on ouvre la fenêtre de régul manuelle (<>1) ou non (=1)
    Raz GOUVSHTREG

    Gosub INIT_SHT From TRTSHTCOM
Return

#########################################
$DEBUT
    Call LOADSHTS(0) From TRTSHTA
Return
#########################################
$OUVRE

If clalev([F:ITM]) =0 Local File ITMMASTER  [ITM]  Endif   # hcb 38033
If clalev([F:STE]) =0 Local File STOPAR     [STE]  Endif   # hcb 38033
If clalev([F:ITF]) =0 Local File ITMFACILIT [ITF]  Endif   # hcb 38033
If clalev([F:ACV]) =0 Local File ACTIV      [ACV]  Endif
If GWRHACT = 2                                             # hcb 58361
   If clalev([F:ITW])=0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
Endif
#lecture code activite nombre de lignes

If dim(GCOD_SLS)<1  Global Integer GCOD_SLS : Endif
If dim(GSUITE)  <1  Global Integer GSUITE   : Endif
Read [ACV] CODACT="SLS" : If !fstat GCOD_SLS=[F:ACV]DIME  : Endif

Raz GSUITE
Return

#########################################
$SETBOUT
    If [M:SSC]MONOITMFLG<>2
        Call VIREBOUT(CHBOU,"09<>") From GOBJET
    Endif
Return

#-----------------------------------------------------------------------------#
#                           ACTIONS CHAMPS                                    #
#-----------------------------------------------------------------------------#

###############################################################################
# Si la ligne correspond à une allocation globale, on évite l'ouverture
# de SAISHTREG
###############################################################################
Subprog IB_NBLIG
    If [M:SHTS]ALLTYP(nolign-1)=5    # manquant global
        GBOUT1 = mess(21,180,1)
    Endif
End

$AB1_NBLIG
Local Integer AB1_RET
    If [M:SHTS]ALLTYP(nolign-1)=5    # manquant global
        Call REGAUTO( nolign-1, AB1_RET ) From TRTSHTAUTO
        If AB1_RET
            Call ERREUR( mess(11,180,1) ) From GESECRAN
        Endif
        GOUVSHTREG = 1
    Endif
Return

###############################################################################
$BB1_NBLIG
    Raz GOUVSHTREG
Return


###############################################################################
# Contrôle que la ligne peut être régularisée en automatique
###############################################################################
Subprog C_FLG(VALEUR)
Variable Integer VALEUR
Local Integer LRET
Local Char MES(250)
#Inter 1
    If VALEUR=2
        Call CTRSELFLG(nolign-1, LRET) From TRTSHTA
        If LRET
            VALEUR = 1
            If LRET = 1                        # hcb 72894
               MES=mess(24,180,1)              # hcb 72894
            Else                               # hcb 72894
            # Régularisation automatique impossible, il manque ces informations:
               MES=mess(10,180,1)
            Endif                              # hcb 72894
            If mod(LRET ,4)>=2
                MES += "\"+mess(25,197,1)    # Lot
            Endif
            If mod(LRET ,8)>=4
                MES += "\"+mess(456,197,1)   # Sous lot
            Endif
            If mod(LRET ,16)>=8
                MES += "\"+mess(47,197,1)    # N° de série
            Endif
            If mod(LRET ,32)>=16
                MES += "\"+mess(24,197,1)    # Statut
            Endif
            If mod(LRET ,64)>=32
                MES += "\"+mess(44,197,1)    # Emplacement
            Endif
# En mettant mkstat=2 => ça boucle
#            mkstat = 2
#            GMESSAGE = MES
            Call ERREUR(MES) From GESECRAN
        Endif
    Endif
End

Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
#--- Issue 48800
#If [M]AVAFLG(nolign-1) = 2
#  pcolor = GCOUL(3)
#Else
#  pcolor = GCOUL(0)
#Endif
If [M]QTYSTUDIS(nolign-1)>=[M]QTYSTUACT(nolign-1)
  pcolor = GCOUL(3)
Elsif [M]QTYSTUDIS(nolign-1)<=0
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(2)
Endif
#---
End


