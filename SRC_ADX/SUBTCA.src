#####################################################################
# SUBTCA : Affectation des compteurs aux documents     MBT 27/11/97 #
#<ch 26 SEP 2013
#####################################################################

Call OBJET("TCA",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBTCAB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "RAZCRE"      : Gosub RAZCRE
 When "AFFMASK"     : Gosub AFFMASK
Endcase
If PSUBB
 Gosub ACTION From SUBTCAB
Endif
Return

#-------------------------#
$RAZCRE
If dim([M:TCA1]LEG)>0 & !func AFNC.ACTIV("LEG")
 [M:TCA1]LEG = GDOSLEG
Endif
Return

#-----------------------#
$AFFMASK
If dim([M:TCA1]LEG)>0
 If !func AFNC.ACTIV("LEG")
  Chgfmt [M:TCA1]LEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:TCA1]ZLEG)>0
   Chgfmt [M:TCA1]ZLEG With "-K:"+num$(type([M:TCA1]ZLEG)-10)+"X"
  Endif
 Endif
Endif
Return

#-----------------------------#
$OUVRE
Local Char    OACTION(20)
Local Integer NOLIB
Return

#--------------------------------#
$INICRE
If [F:TCA]CPY=""
 If !func AFNC.ACTIV("LEG")
  [F:TCA]LEG = GDOSLEG
 Endif
Elsif [F:TCA]LEG<>""
 [F:TCA]LEG = ""
Endif
Return

#--------------------------------#
$INIMOD
If [F:TCA]CPY=""
 If !func AFNC.ACTIV("LEG")
  Look [TCA]TCA0=[F]MODULE;[F]LEG;""
  If fstat
   Look [TCA]TCA0=[F]MODULE;GDOSLEG;[F]CPY
   If !fstat
    [F:TCA]LEG = GDOSLEG
   Endif
  Endif
# Elsif [F:TCA]LEG<>""
#  [F:TCA]LEG = ""
 Endif
Endif
Return

#-----------------------------#
$APRES_MODIF
Case zoncou
 When "MODULE"
  [M]MODULE = zc
  Gosub CHARGE_DOC
Endcase
Return

#-----------------------------------------#
# Suppression des boutons # Code et X Sél #
#-----------------------------------------#

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
# Since the index of table TABCOUAFF include 3 fields(MODULE+LEGISLATION+SOCIETE),
# button "Supprimer" is not activated by default, need to be activated here
If instr(1,CHAINE,"A")=0 : CHAINE += "A" : Endif
Return

#------------------------------------------------------------#
# Chargement du nombre de type de document suivant le module #
#------------------------------------------------------------#

$LIENS
Gosub CHARGE_DOC
# LEG and CPY can not be both filled
Gosub SET_CPY
Gosub SET_LEG
Return

#-----------------------------#
$CHARGE_DOC
If [M]MODULE=1
 NOLIB = 907
 [M]NBDOC = len(mess(0,NOLIB,1))
 For I=1 To [M]NBDOC
  [M]DOCINT(I-1) = mess(I,NOLIB,1)
 Next I
Endif
Gosub GRISE_MAN
Gosub GRISE_XTD
OACTION = ACTION
ACTION = "CHARGE_DOC" : Gosub ACTION
ACTION = OACTION
If NOLIB=0 & [M]MODULE<>1
 [M]NBDOC  = 1
 [M]DOCINT = "????????????????????"
Endif
Return
#-----------------------------#
$GRISE_MAN
If [M]MODULE=1
 For I=1 To [M]NBDOC
  [M]MANCOU(I-1) = 1
  Affzo MANCOU(I-1)
  Grizo MANCOU(I-1)
 Next I
Else
 Actzo MANCOU
Endif
Return

#-----------------------------#
$GRISE_XTD
If [M]MODULE=1 & !func AFNC.ACTIV("AYT") : # Xtend
 Grizo CODNUM(3)
Else
 Actzo CODNUM(3)
Endif
Return

#--------------------------------------------------------------------------------#
Funprog NAMCPT(MODULE,TYPDOC)
Value Integer MODULE , TYPDOC
Local Integer OK , ER
Local Char    TCA(max(GLONANM,20))
Onerrgo ERFIC
Local File TABCOUAFF [TCA]
Call LECTCA(MODULE,OK)
If !OK or TYPDOC<1 or TYPDOC>dim([F:TCA]CODNUM)
 TCA = ""
Else
 TCA = [F:TCA]CODNUM(TYPDOC-1)
Endif
Onerrgo
End TCA

$ERFIC
ER = errn
Resume

#--------------------------------------------------------------------------------#
#**
#* Calculer le compteur à retourner avec la logique suivante:
#* - si la variable GSOCIETE est renseignée, et qu'il existe un enregistrement pour la société en question, on le prend
#* - si la variable GSOCIETE est renseignée et qu'il n'existe pas d'enregistrement pour la société, mais qu'il en existe
#    un pour sa législation on prend ce dernier enregistrement.
#* - si la variable GSOCIETE est vide mais la variable GCURLEG est renseignée et qu'il en existe un pour ce dernier, on le prend.
#* - sinon, on regarde s'il existe un enregistrement avec code société et législation VIDES;
#*
#* Valeurs retournées du paramètre « OK »:
#* - 1   si un compteur trouvé
#* - 0   si aucun compteur trouvé
#*
#* @param MODULE
#* @param OK
#* @public
#*!
Subprog LECTCA(MODULE,OK)
Value Integer MODULE
Variable Integer OK
Local Integer ER
Local Integer INDEX_LEG
OK = 0
ER = 0
INDEX_LEG = -1
Onerrgo ERFIC
If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif

### in case GSOCIETE is given
If GSOCIETE<>""
 # look for the counter for the given company
 Read [TCA]TCA0=MODULE;"";GSOCIETE
 If !fstat
  OK = 1
 Else
  # look for the legislation of the given company in GLECSOC
  INDEX_LEG = find(GSOCIETE, GSOC)
  If INDEX_LEG >0
   # look for the counter for the legislation of the given company
   Read [TCA]TCA0=MODULE;GLEGSOC(INDEX_LEG);""
   If !fstat
    OK = 1
   Endif
  Endif
  If !OK
   # if still not found, look for the counter of the whole module
   Read [TCA]TCA0=MODULE;"";""
   If !fstat
    OK = 1
   Endif
  Endif
 Endif
### in case GSOCIETE is empty
Else
  If GCURLEG<>""
   # look for the counter with the legislation given in GCURLEG
   Read [TCA]TCA0=MODULE;GCURLEG;""
   If !fstat
    OK = 1
   Endif
  Elsif func AFNC.ACVDOSACT(nomap,"LEG")=0
   #case where we are in a monolegislation folder
   Read [TCA]TCA0=MODULE;GDOSLEG(1);""
   If !fstat
    OK = 1
   Endif
  Endif
  If !OK
   # if still not found, look for the counter of the whole module
   Read [TCA]TCA0=MODULE;"";""
   If !fstat
    OK = 1
   Endif
  Endif
Endif

Onerrgo
End

#------------------------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File TABCOUAFF   [TCA1]
Else
 Local File =[M]DOSORG+".TABCOUAFF"   [TCA1]
Endif
If [M]DOSDES=nomap
 Local File TABCOUAFF   [TCA2]
Else
 Local File =[M]DOSDES+".TABCOUAFF"   [TCA2]
Endif
Local Char    DOSLEG(30)(1..30)
Local Integer NBLEG , OK , MONOLEG
Call SETLEG([M]DOSDES,DOSLEG,NBLEG) From DOSCONT
MONOLEG = !func AFNC.ACVDOSACT([M]DOSDES,"LEG")
OK = 1
If GTRACE=""
 If MONOLEG
  If (TABLE2="" or TABLE2=DOSLEG)
   Read [TCA2]TCA0 = val(TABLE);DOSLEG;TABLE3
   If !fstat
    # Fiche déjà existante
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-DOSLEG-TABLE3-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Else
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Endif
 Else
  If TABLE2<>"" & !find(TABLE2,DOSLEG(1..NBLEG))
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Else
   Read [TCA2]TCA0 = val(TABLE);TABLE2;TABLE3
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-TABLE2-TABLE3-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [TCA1] , [TCA2]
Return

$TR_COP
GOK = 1
Trbegin [TCA2]
 Read [TCA1]TCA0 = val(TABLE);TABLE2;TABLE3
 If !fstat
  If [F:TCA1]LEG="" or find([F:TCA1]LEG,DOSLEG(1..NBLEG))
   Readlock [TCA2]TCA0 = val(TABLE);TABLE2;TABLE3
   If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABCOUAFF" : Goto ROLL_TR_COP
   Else
    If MONOLEG & [F:TCA1]LEG=""
     Readlock [TCA2]TCA0=val(TABLE);DOSLEG(1);TABLE3
     If fstat=1
      GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABCOUAFF" : Goto ROLL_TR_COP
     Elsif fstat
      [F:TCA2] = [F:TCA1]
      [F:TCA2]LEG = DOSLEG(1)
      If dim([F:TCA2]CREUSR)>0 : [F:TCA2]CREUSR = GUSER : Endif
      If dim([F:TCA2]CREDAT)>0 : [F:TCA2]CREDAT = date$ : Endif
      If dim([F:TCA2]CRETIM)>0 : [F:TCA2]CRETIM = time  : Endif
      Write [TCA2]
      If fstat
       GOK=0 : Call FSTA("TCA2") From GLOCK : Goto AB_TR_COP
      Endif
     Else
      [F:TCA2] = [F:TCA1]
      [F:TCA2]LEG = DOSLEG(1)
      If dim([F:TCA2]UPDUSR)>0 : [F:TCA2]UPDUSR = GUSER : Endif
      If dim([F:TCA2]UPDDAT)>0 : [F:TCA2]UPDDAT = date$ : Endif
      If dim([F:TCA2]UPDTIM)>0 : [F:TCA2]UPDTIM = time  : Endif
      Rewrite [TCA2]
      If fstat
       GOK=0 : Call FSTA("TCA2") From GLOCK : Goto AB_TR_COP
      Endif
     Endif
    Elsif fstat
     [F:TCA2] = [F:TCA1]
     If dim([F:TCA2]CREUSR)>0 : [F:TCA2]CREUSR = GUSER : Endif
     If dim([F:TCA2]CREDAT)>0 : [F:TCA2]CREDAT = date$ : Endif
     If dim([F:TCA2]CRETIM)>0 : [F:TCA2]CRETIM = time  : Endif
     Write [TCA2]
     If fstat
      GOK=0 : Call FSTA("TCA2") From GLOCK : Goto AB_TR_COP
     Endif
    Else
     [F:TCA2] = [F:TCA1]
     If dim([F:TCA2]UPDUSR)>0 : [F:TCA2]UPDUSR = GUSER : Endif
     If dim([F:TCA2]UPDDAT)>0 : [F:TCA2]UPDDAT = date$ : Endif
     If dim([F:TCA2]UPDTIM)>0 : [F:TCA2]UPDTIM = time  : Endif
     Rewrite [TCA2]
     If fstat
      GOK=0 : Call FSTA("TCA2") From GLOCK : Goto AB_TR_COP
     Endif
    Endif
   Endif
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#--------------------------------------------------------------------------------#
Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
Local Char ACTION(20)
ACTION = "AS_MODULE" : Gosub ACTION
Local Integer I
If GPRODUIT=-1
 For I=2 To len(mess(0,14,1))
  GMENLOC(I) = 1
 Next I
Endif
End

Subprog C_MODULE(VALEUR)
Local Char ACTION(20)
ACTION = "C_MODULE" : Gosub ACTION
End

Subprog AM_MODULE(VALEUR)
Local Char ACTION(20)
ACTION = "AM_MODULE" : Gosub ACTION
End

Subprog AS_NBDOC
Local Char ACTION(20) , OACTION(20)
Local Integer NOLIB
If [M]NBDOC=0
 Gosub CHARGE_DOC
 Affzo 10
Endif
End

Subprog C_NBDOC
Local Char ACTION(20)
ACTION = "C_NBDOC" : Gosub ACTION
End

Subprog AS_CODNUM(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "AS_CODNUM" : Gosub ACTION
End

Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
Local File ACODNUM [ANM]
Local File COMPANY [CPY]
Local Char WLEG(10)
If [M:TCA1]LEG<>""
 WLEG = [M:TCA1]LEG
Elsif [M:TCA1]CPY<>""
 Read [F:CPY]CPY0=[M:TCA1]CPY
 If !fstat & [F:CPY]LEG<>""
  WLEG = [F:CPY]LEG
 Endif
Endif
If WLEG<>""
 Read [ANM]ANM0 = VALEUR
 If !fstat & [F:ANM]LEG<>"" & [F:ANM]LEG<>WLEG
  GMESSAGE = func AFNC.MES1(mess(265,133,1), WLEG) : #Législation $1$ obligatoire avec le compteur
  mkstat = 2 :End
 Endif
Endif
Local Char ACTION(20)
ACTION = "C_CODNUM" : Gosub ACTION
End

Subprog S_CODNUM(VALEUR)
Variable Char    VALEUR()
Local Integer NBCHOI, CHOI,J
Local Char    TEX(GLONDES)(1..,1..3) , TIT(GLONDES)(0..3) , CRITERE(60)
Local File ACODNUM [ANM]
Local File COMPANY [CPY]
Local Char WLEG(10)
If [M:TCA1]LEG<>""
 WLEG = [M:TCA1]LEG
Elsif [M:TCA1]CPY<>""
 Read [F:CPY]CPY0=[M:TCA1]CPY
 If !fstat & [F:CPY]LEG<>""
  WLEG = [F:CPY]LEG
 Endif
Endif
CRITERE = "1=1"
If WLEG<>""
 CRITERE ='(LEG="'+WLEG+'" or LEG="")'
Endif
For [ANM] Where evalue(CRITERE)
 NBCHOI += 1
 TEX(NBCHOI,1) = [F:ANM]CODNUM
 TEX(NBCHOI,2) = func AFNC.TEXTRA("ACODNUM","DES",[F:ANM]CODNUM,"")
 TEX(NBCHOI,3) = string$([F:ANM]LEG<>'',[F:ANM]LEG)+string$([F:ANM]LEG='',mess(236,143,1))
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(6,83,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
TIT(3) = mess(238,133,1) : # legislation
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR =  TEX(CHOI,1)
Endif
End


Subprog AS_MANCOU(VALEUR)
Variable Integer  VALEUR
Local Char ACTION(20)
ACTION = "AS_MANCOU" : Gosub ACTION
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran TCA1) 10/11/2011 16:21:51 (KUYAN)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
[M]LEG = [L]VALEUR
# LEG and CPY can not be both filled
Gosub SET_CPY
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
[M]CPY = [L]VALEUR
# LEG and CPY can not be both filled
Gosub SET_LEG
End

# LEG is activated only when CPY is empty
$SET_LEG
If func AFNC.ACTIV("LEG")
 If [M]CPY <> ""
  Diszo [M]LEG
 Else
  Actzo [M]LEG
 Endif
Endif
Return

# CPY is activated only when LEG is empty
$SET_CPY
If [M]LEG<>"" & func AFNC.ACTIV("LEG")
 Diszo [M]CPY
Else
 Actzo [M]CPY
Endif
Return


