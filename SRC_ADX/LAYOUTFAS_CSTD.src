# Classe LAYOUTFAS

###################
# CLASS LAYOUTFAS
###################
$ACTION
#  If (dim(TRACEUR_D) < 0) Then
#    Global Integer TRACEUR_D
#    Global Integer B_TRACE_D : B_TRACE_D = 0
#    GUSER = adxusr
#    TRACEUR_D = 0
#    Call TRACE_CLEAR From AXUNIT
#    Call TRACE_LINE( "D_____" - "Trace reinitialisee______" - CURPRO ) From AXUNIT
#  Endif
#  If (B_TRACE_D) Then
#    Call TRACE_LINE( "D_____" - ACTION - time$ - "_____________________________") From AXUNIT
#  Endif

  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"       : Gosub AREAD_AFTER       : # Get method attached to NBMVT
    Endcase
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


###############
###############
# METHOD
###############
###############
$METHODS
Return


###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################
$AREAD_AFTER
#  If (B_TRACE_D) Then
#    Call TRACE_LINE("DDDD" - "AREAD_AFTER" - "Curpro"-CURPRO - "Curpth"-CURPTH   ) From AXUNIT
#  Endif
Return


###############
###############
# PROPERTY
###############
###############
$PROPERTIES
#  If (B_TRACE_D) Then
#    Call TRACE_LINE("Property :"- CURPRO - "Action" - ACTION) From AXUNIT
#  Endif
  Case CURPRO
    When "CUR"    : Gosub CUR
    When Default
    Endcase
  Return


###################################################################
#            METHODES SUR LA PROPRIETE  -  CUR
###################################################################
$CUR
  Case ARULE
    When "INIT"       : Gosub INIT_CUR      : # Init method attached to CUR
    When "CONTROL"    : Gosub CONTROL_CUR   : # Control method attached to CUR
    When "PROPAGATE"  : Gosub PROPAGATE_CUR : # Propagate method attached to CUR
    When "GET"        : Gosub GET_CUR       : # Get method attached to CUR
    When Default
  Endcase
Return
#------------
$INIT_CUR
Return
#------------
$CONTROL_CUR
Return
#------------
$PROPAGATE_CUR
Return
#------------
GET_CUR
Return

