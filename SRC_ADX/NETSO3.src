#<AdxTL>@(#)4.0.0.0 $Revision$
#############################################
$ACTION
Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################


# Sous-programme de description du web service de liste
$DESC_LISTE
Return


# Sous-programme de description du web service de lecture
$DESC_LEC
#-----
CODE_CHAMPS(6) ="NBMSOH"
CODE_CHAMPS(7) ="NBASOH"
CODE_CHAMPS(8) ="CAMBPC"
CODE_CHAMPS(9) ="CAABPC"
CODE_CHAMPS(10)="OSTBPC"

INTIT_CHAMPS(6) =mess(236,191,1)
INTIT_CHAMPS(7) =mess(237,191,1)
INTIT_CHAMPS(8) =mess(238,191,1)
INTIT_CHAMPS(9) =mess(239,191,1)
INTIT_CHAMPS(10)=mess(240,191,1)

TYPE_CHAMPS(6) =3 
TYPE_CHAMPS(7) =3
TYPE_CHAMPS(8) =4
TYPE_CHAMPS(9) =4
TYPE_CHAMPS(10)=4

LEN_CHAMPS(6) =8 
LEN_CHAMPS(7) =8
LEN_CHAMPS(8) =9.2
LEN_CHAMPS(9) =9.2
LEN_CHAMPS(10)=9.2
#-----
Return


# Sous-programme de liste
$LISTE
Return


# Sous-programme de lecture détail
$LECTURE
#-----
Local Date DATMIN, DATMAX
#-----
If month(date$)=1
  DATMIN=gdat$( 1,12,year(date$)-1)
  DATMAX=gdat$(31,12,year(date$)-1)
Elsif month(date$)-1=2
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(28,month(date$)-1,year(date$))
Elsif find(month(date$)-1,4,6,9,11)
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(30,month(date$)-1,year(date$))
Else
  DATMIN=gdat$( 1,month(date$)-1,year(date$))
  DATMAX=gdat$(31,month(date$)-1,year(date$))
Endif
CHAMPS_LUS(6) =num$(func TRTX3FNC.GETNBRSOH([SOH]BPCORD,DATMIN,DATMAX)) 
CHAMPS_LUS(8) =num$(func TRTX3FNC.GETCABPC([SOH]BPCINV,DATMIN,DATMAX))
DATMIN=gdat$( 1, 1,year(date$)-1)
DATMAX=gdat$(31,12,year(date$)-1)
CHAMPS_LUS(7) =num$(func TRTX3FNC.GETNBRSOH([SOH]BPCORD,DATMIN,DATMAX))
CHAMPS_LUS(9) =num$(func TRTX3FNC.GETCABPC([SOH]BPCINV,DATMIN,DATMAX))
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If [F:BPC]BPCNUM<>[F:SOH]BPCORD
  Read [BPC]BPC0=[F:SOH]BPCORD
Endif
CHAMPS_LUS(10)=num$(func TRTBPMVT.CALOST([BPC]BPCRSK,[BPC]CHGTYP,date$))
#-----
Return


# Sous-programme de rafraichissement favoris
$RAFRAICHIR
Return



