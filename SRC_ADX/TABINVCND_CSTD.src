#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TABINVCND
# Issue 113097 - 2016-01-05 by CPO : Classes & representations updates for new labels
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case CURPTH
      When ""          :
                        Case [L]AEVENT
                            When "AREAD_AFTER"            : Gosub AREAD_AFTER              From TABINVCND_EVENTS
                            When "ACONTROL"               : Gosub ACONTROL                 From TABINVCND_EVENTS
                            When "AINSERT_BEFORE"         : Gosub AINSERT_BEFORE           From TABINVCND_EVENTS
                            When "AUPDATE_BEFORE"         : Gosub AUPDATE_BEFORE           From TABINVCND_EVENTS
                        Endcase
      When "INVCNDLIN" :
                        Case [L]AEVENT
                            When "ACONTROL"               : Gosub INVCNDLIN_ACONTROL       From TABINVCND_EVENTS
                            When "AREAD_AFTER"            : Gosub INVCNDLIN_AREAD_AFTER    From TABINVCND_EVENTS
                            When "ADDLINE_BEFORE"         : Gosub INVCNDLIN_ADDLINE_BEFORE From TABINVCND_EVENTS
                            When "ADDLINE_AFTER"          : Gosub INVCNDLIN_ADDLINE_AFTER  From TABINVCND_EVENTS
                        Endcase
  Endcase
Return
#---------------------------------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#---------------------------------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#---------------------------------------------------------------
$PROPERTIES
  Case [L]ARULE
    When "INIT"      :
                        Case CURPRO
                          When "LEG"                      : Gosub INIT_LEG                 From TABINVCND_PROPERTIES
                        Endcase
    When "CONTROL"   :
                        Case CURPRO
                          When "INVCNDTYP"                : Gosub CONTROL_INVCNDTYP        From TABINVCND_PROPERTIES
                          When "GRP"                      : Gosub CONTROL_GRP              From TABINVCND_PROPERTIES
                        Endcase
    When 'PROPAGATE' :
                        Case CURPRO
                          When "INVCNDTYP"                : Gosub PROPAGATE_INVCNDTYP      From TABINVCND_PROPERTIES
                        Endcase
  Endcase
Return
#---------------------------------------------------------------

