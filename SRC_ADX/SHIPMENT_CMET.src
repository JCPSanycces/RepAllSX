#**
#* Warning: Use of APARENT property
#*!
$SHIPD_AINSERT_BEFORE
  If this.VCRNUM = AVOID.ACHAR
    this.VCRNUM = this.APARENT.SHIPNUM
  Endif
Return

$SHIPD_AUPD_AINS_CONTROL_AFTER
Local Char WTEXTE (100)
  If this.SDTYPE = AVOID.ACHAR
    Call TEXTE(865, WTEXTE) From OBJDIV
    [L]ASTATUS = fmet this.ASETERROR(WTEXTE, mess(10,123,1), [V]CST_AERROR)
  Endif
Return

#**
#* capacity control :
#* 1 - number of container filled : TCTRNUM msut be filled
#* TCTRNUM <> ""
#* 2 - unities control : weignth and volume
#* 3 - total weight = number of container * current weight
#*     total volume = number of container * volume
#*!
$CTR_CAPACITY
#1 - number of container filled : TCTRNUM msut be filled
If this.SHIPNBCTR <> 0 & this.TCTRNUM = AVOID.ACHAR
  Call TEXTE(52437, WTEXTE) From OBJDIV
  [L]ASTATUS = fmet this.ASETERROR(WTEXTE, mess(10,123,1), [V]CST_AERROR)
  Return
Endif
If this.TCTRNUM <> AVOID.ACHAR
  #read TABCONTAINER class
  Local Instance WTABCONTAINER Using C_TABCONTAINER
  WTABCONTAINER = NewInstance C_TABCONTAINER AllocGroup null

  If fmet WTABCONTAINER.AREAD(this.TCTRNUM) = [V]CST_AOK
    #2 - unities control : weignth and volume
    If this.DSPWEU <> WTABCONTAINER.WEU | this.DSPVOU <> WTABCONTAINER.VOU
      [L]ASTATUS = fmet this.ASETERROR("", mess(551,194,1), [V]CST_AERROR)
      FreeGroup WTABCONTAINER
      Return
    Endif
    #3 - TOTAL WEIGHT = NUMBER OF CONTAINER * CURRENT WEIGHT/ total volume = number of container * volume
    If this.MAXWEI <> this.SHIPNBCTR * (WTABCONTAINER.TARWEI + WTABCONTAINER.MAXWEI)
&      | this.MAXVOL <> this.SHIPNBCTR * WTABCONTAINER.TCTRVOL
      [L]ASTATUS = fmet this.ASETERROR("", mess(552,194,1), [V]CST_AERROR)
      FreeGroup WTABCONTAINER
      Return
    Endif
  Endif
FreeGroup WTABCONTAINER
Endif
Return
#######################################################################################
# Issue 111257 US 42
$SHIPT_ADELLINE_AFTER
If func SYRCOLLECTION.SORTDEL(this, "TRKSORT", this.TRKSORT, "SHIPT", 10) <> CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("",func ASYRFNC.MES2(mess(273,133,1), 'SHIPT', 'SHIPMENT'), [V]CST_AERROR)
Endif
Return
#######################################################################################
$SHIPT_GET_INDEX
  [L]ARET_VALUE = find(LIGNE,this.SHIPT(1..maxtab(this.SHIPT)).STLIN)
Return
#######################################################################################
# Issue 15350 - 2016-12-06 by MAE : Update quantities and status
$_UPD_QTY_STAT

Local Instance WSHIPMENTD Using C_SHIPMENTD
WSHIPMENTD = NewInstance C_SHIPMENTD AllocGroup null
Local Instance WSHIPMENT Using C_SHIPMENT
WSHIPMENT = NewInstance C_SHIPMENT AllocGroup null

#update the quantities on the line
If fmet WSHIPMENTD.AREAD(SHIPNUM,NUMLINE) < [V]CST_AERROR
  # Char QTYTYPE Quantity type (CST_RCP:receipt, CST_PRCP:pre-receipt, CST_SHP:shipped)
  If fmet WSHIPMENTD._UPDQTYLIN(QTYTYPE,QTY,QTYPUU,QTYSTU,CLEFLG) < [V]CST_AERROR
     If fmet WSHIPMENTD.AUPDATE() >= [V]CST_AERROR
      WRET = fmet WSHIPMENTD.ASETERROR("SHIPMENTD", mess(581,194,1), [V]CST_AERROR)
     Else
      #Update the status on the header
      If fmet WSHIPMENT.AREAD(SHIPNUM) < [V]CST_AERROR
        If fmet WSHIPMENT._UPD_STATUS() < [V]CST_AERROR
          If fmet WSHIPMENT.AUPDATE() >= [V]CST_AERROR
            WRET = fmet WSHIPMENT.ASETERROR("SHIPMENT", mess(581,194,1), [V]CST_AERROR)
          Endif
        Endif
      Endif
    Endif
  Endif
Endif

LMESS = func LCCLIB.MAXMSG(WSHIPMENT)
If LMESS = AVOID.ACHAR | fmet WSHIPMENT.AGETMAXERROR("") < [V]CST_AERROR
  LMESS = func LCCLIB.MAXMSG(WSHIPMENTD)
Endif

FreeGroup WSHIPMENT
FreeGroup WSHIPMENTD

Return

#######################################################################################
#**
#* update the status in the header
#*!
$_UPD_STATUS
Local Integer WNBRECEPT,WNBPRECEPT,WNBCREE, LVCRTYP,WNBSOLDE

WNBRECEPT=0:WNBPRECEPT=0:WNBCREE=0:WNBSOLDE=0
For I=1 To maxtab(this.SHD)
# Issue 15176 - 2016-12-01 by MAE : calcul du statut de l'expé
    If (this.SHD(I).CLEFLG = 2)
      WNBSOLDE += 1
    Elsif (this.SHD(I).RCPQTYPUU=this.SHD(I).SHIQTYPUU) #receptionné
      WNBRECEPT += 1
    Elsif (this.SHD(I).PRCPFLG=2)  #pre receptionné
      WNBPRECEPT += 1
    Else
      WNBCREE += 1
    Endif
Next
# Issue 6079 - 2016-12-13 by MAE : ajout du statut expédié
If WNBCREE > 0 & this.SHIPFLG<>2 : this.SHIPSTAT = 1
Elsif WNBCREE > 0 & this.SHIPFLG=2 : this.SHIPSTAT = 2
Elsif WNBPRECEPT > 0 : this.SHIPSTAT = 3
Elsif WNBRECEPT > 0 : this.SHIPSTAT = 4
Elsif WNBSOLDE >0 : this.SHIPSTAT = 5
Endif
Return

#######################################################################################
#**
#* Update the receipt quantity in the line and the sold if necessary. Update also the status in the header
#*
#* @param SHIPNUM shipment number
#* @param NUMLINE shipment line
#* @param QTYPUU quantity in UA
#* @param QTYSTU quantity in STU
#* @param CLEFLG sold
#* @param LMESS message
#*!
Funprog MAJQTYRCP(SHIPNUM,NUMLINE,QTYPUU,QTYSTU,CLEFLG,LMESS)
Value Char SHIPNUM()
Value Integer NUMLINE
Value Decimal QTYPUU
Value Decimal QTYSTU
Value Shortint CLEFLG
Variable Char LMESS()

Local Char QTYTYPE(10)
Local Decimal QTY
Local Integer WRET

QTYTYPE = "CST_RCP"
Gosub _UPD_QTY_STAT

End WRET

# End issue 15350

