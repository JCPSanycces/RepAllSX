#<AdxTL>@(#)5.0.0.0 $Revision$
##############################################################################
## Suppresion tunnel a tort
##############################################################################
Call OUVRE_TRACE("Update table : AMSK-AMSKZON") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer I ,K , OK ,DIFTUN , DIFLIEN , DIFAMK , NBAMK
Local Char    TABAMK(GLONAMK)(0..10000)
Local File =DOSSIER+".AMSKZON" [AMZ]
Local File =DOSSIER+".AMSK"    [AMK] 
Local File =DOSSIER+".ATYPE"   [ATY] 
Local File =DOSSIER+".AOBJET"  [AOB]
Local File =DOSSIER+".ATABLE"  [ATB]
Local File ADOSSIER [ADS2]

Read [ADS2]DOSSIER = [L]DOSSIER
If fstat : End : Endif

Trbegin [AMZ]
For [AMK] Where CODMSK<"W"
 DIFAMK = 0
 For [AMZ]CODE Where CODMSK = [F:AMK]CODMSK
  ### TUNNEL 
  Raz DIFTUN,DIFLIEN
  If [F:AMZ]SAIAFF<>1 & find([F:AMZ]TUNNEL,1,2)  
   [F:AMZ]TUNNEL = 0 
   DIFTUN = 1
  Elsif [F:AMZ]CODTYP=""  & find([F:AMZ]TUNNEL,1,2)
   [F:AMZ]TUNNEL = 0 
   DIFTUN =2
  Endif
  If !DIFTUN
   Call LECTURE("ATY",[F:AMZ]CODTYP,"") From CONTOBJ
   If [F:ATY]OBJLIEN="" & find([F:AMZ]TUNNEL,2)
    [F:AMZ]TUNNEL = 0
    DIFTUN = 3
   Elsif find([F:AMZ]TUNNEL,2)
    Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
    If [F:AOB]NOMFIC <> ""
     If find([F:AOB]NOMFIC,[F:AMK]FICREF(0))
      [F:AMZ]TUNNEL = 1
      DIFTUN = 4
     Endif
    Endif
   Endif
  Endif
  If DIFTUN 
   #Call ECR_TRACE([F:AMZ]CODMSK-[F:AMZ]CODZON-num$([F:AMZ]TUNNEL)-"---"-num$(DIFTUN),0) From GESECRAN
  Endif
  If [F:AMZ]SAIAFF>2  & find([F:AMZ]LIEN,2)
   [F:AMZ]LIEN = 1
   DIFLIEN = 1
  Elsif [F:AMZ]CODTYP=""  & find([F:AMZ]LIEN,1,2)
   [F:AMZ]LIEN = 0 
   DIFLIEN = 2 
  Endif
  If !DIFLIEN
   Call LECTURE("ATY",[F:AMZ]CODTYP,"") From CONTOBJ
   If [F:ATY]OBJLIEN="" & find([F:AMZ]LIEN,2)
    [F:AMZ]LIEN = 0
    DIFLIEN = 3 
   Elsif find([F:AMZ]LIEN,2) 
    Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
    If [F:AOB]NOMFIC="" 
     [F:AMZ]LIEN = 1
     DIFLIEN = 4
    Else
     Call LECTURE("ATB",[F:AOB]NOMFIC,"") From CONTOBJ
     If [F:ATB]INTIT="" & [F:ATB]INTITC="" 
     [F:AMZ]LIEN = 1
      DIFLIEN = 4 
     Endif
    Endif
   Endif
  Endif
  If DIFLIEN
   #Call ECR_TRACE("***"-[F:AMZ]CODMSK-[F:AMZ]CODZON-num$([F:AMZ]LIEN)-"---"-num$(DIFLIEN),0) From GESECRAN
  Endif
  If DIFLIEN or DIFTUN
   Rewrite [F:AMZ]
   If fstat
    Call ERREUR("AMSKZON"-[F:AMZ]CODMSK-[F:AMZ]CODZON,2) From DOSDIC
   Endif
   DIFAMK = 1
  Endif
 Next AMZ
 If DIFAMK
  TABAMK(NBAMK) = [F:AMK]CODMSK
  NBAMK +=1
 Endif
Next
Commit

If NBAMK
 Call ECR_TRACE("Update table : AMSK-AMSKZON",0) From GESECRAN
 For I=0 To NBAMK-1
  Call VALID(TABAMK(I),[L]DOSSIER,[F:ADS2]NBRLAN,[F:ADS2]LAN,1,GBIDI1) From VALMSK
 Next I
Endif

Close Local File
Return
