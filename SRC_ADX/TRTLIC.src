################################################################################
# Subprog INFMSG : Affiche le taux de gestion des immobilisations et les messages de dépassement
################################################################################

Funprog INFMSG()

Local Integer FASMAX                    : # Nombre de biens accordés par la licence
Local Integer FASCNT                    : # Nombre de biens gérés
Local Decimal NIVDEP                    : # Niveau de dépassement

  #Call NOMBRE(1,FASMAX) From GLOCK : # FQ97426
  FASMAX = func GET_FASMAX()        : # FQ97426

  Local Integer RERR
  FASCNT = func TRTLIC.LEC_NOMBCO()

  # Message dans la barre d'état du client
  # Nombre de biens maxi = xxxxxx    Nombre de biens gérés = nnnnnnn
  #Call ECR_TRACE( mess(105,7770,1)-"="-num$(FASMAX)+space$(5)+mess(106,7770,1)-"="-num$(FASCNT) , 1) From GESECRAN
  #Inftxt mess(105,7770,1)-"="-num$(FASMAX)+space$(5)+mess(106,7770,1)-"="-num$(FASCNT) At 1

  NIVDEP = func FASRAT(FASMAX,FASCNT)
  Case NIVDEP
    When 2
      # Le nombre d'immobilisations accordé par votre licence est largement dépassé, l'extension de cette licence
      # est indispensable pour poursuivre l'exploitation du progiciel, veuillez contacter votre fournisseur
      Call MESSAGE (mess(111,7770,1)-mess(112,7770,1)) From GESECRAN
    When 1
      # Le nombre d'immobilisations accordé par votre licence est atteint,
      # veuillez contacter votre fournisseur pour étendre cette limite
      Call MESSAGE (mess(109,7770,1)-mess(110,7770,1)) From GESECRAN
    When Default
  Endcase
End NIVDEP


################################################################################
# Funprog FASRAT : Détermine le taux de gestion des immobilisations et rend le niveau de
#                  dépassement en fonction de 2 taux plafonds
#                  => 0 : taux inférieur à la limite de licence
#                  => 1 : la limite de licence est atteinte
#                  => 2 : la limite de licence est largement dépassée
################################################################################
Funprog FASRAT (FASMAX,FASCNT)
Value Integer FASMAX                    : # Nombre de biens accordés par la licence
Value Integer FASCNT                    : # Nombre de biens gérés

Local Decimal TAUX                      : # Taux de gestion des immobilisations
Local Decimal ATTEIN                    : # Taux plafond => licence atteinte
Local Decimal DEPASS                    : # Taux plafond => licence largement dépassée
Local Integer RETOUR                    : # Variable de retour

ATTEIN = 100                            : # licence atteinte = 100 %
DEPASS = 105                            : # licence largement dépassée = 105 %

TAUX = FASCNT / max(FASMAX,1) * 100 : # FQ73896

If TAUX >= DEPASS
  RETOUR = 2
Elsif TAUX >= ATTEIN
  RETOUR = 1
Else
  RETOUR = 0
Endif

End RETOUR

