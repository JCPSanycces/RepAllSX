Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
###################################################################################################
$EXEC_FIC_SQL
#Value Integer CTRL
Local Char SQLDBA(50)
Local Char WORDREECR(250)
Local Char WORDRE(250)(1..2)
Local Char LIGNE(250)
Local Char TEXT(250)(3)
# Issue X3-106024
Local Char XINSTANCE(200) : # SQL Server instance
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

Case GOS(1) # Issue X3-42308 - 2017-07-21 by BEFOU : GOS : Unix ou Dos
 When "unix"
  # Issue X3-42308
  WORDRE(1) = 'sqlcmd'
  WORDRE(1) -= '-S "'+left$(getenv$("CONNECTSTR"),instr(0,getenv$("CONNECTSTR"),"#")-1)+'"'  # Serveur
  WORDRE(1) -= '-d "'+right$(getenv$("CONNECTSTR"),instr(0,getenv$("CONNECTSTR"),"#")+1)+'"'  # Base
  WORDRE(1) -= '-U "'+USER+'"'   # User
  WORDRE(1) -= '-P "'+PASSE+'"'  # PWD
  #WORDRE -= '-q "'+REQUETE+'"' # Requete
  WORDRE(1)-= '-i "'+FICSQL+'"' # Requete
  WORDRE(1) -= '-e ' # Echo Input
  WORDRE(1) -= '-t 60' # Timeout 60s
  WORDRE(2) = FICTRA
  Call SYSTEME(MACHINE,WORDRE,"",ERR) From ORDSYS
  # End issue X3-42308

 When "dos"
   ##
   ## On ecrit le fichier de commande pour le déclenchement
   ## car bug sur probleme de PATH
   ##
   Openo FICCMD , 0
   Wrseq "@ECHO OFF"
   Wrseq "BREAK OFF"

   # Issue X3-106024 : use 'sqlcmd' instead of 'osql' since runtime R091
   If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
     SQLDBA = "sqlcmd"
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
       XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
       XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,ERR) From DOSBASE
     If ERR
       Return
     Endif
     Wrseq "SET SQLCMD_EXE="+SQLDBA
     WORDREECR = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
     Wrseq WORDREECR
     WORDREECR = '%SQLCMD_EXE%'-'-S'-XHOSTNAME+'\'+XINSTANCE-'-d'-XBASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w250'
     Wrseq WORDREECR
   Else
     SQLDBA = "osql"
     Wrseq "SET OSQL_EXE="+SQLDBA
     WORDREECR = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
     Wrseq WORDREECR
     WORDREECR = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
     Wrseq WORDREECR
   Endif

   Wrseq "BREAK ON"
   Openo
   System COMMANDE = MACHINE+'@'+CMDFIC
 Endcase

 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If ERR=1
      TEXT(1)=LIGNE
      Call ECR_TRACE("|"+TEXT(0..1),ERR) From GESECRAN
      Break
   Elsif toupper(left$(LIGNE,3))="MSG"
      TEXT(0)=LIGNE
      ERR=1
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      ERR=1
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,ERR) From GESECRAN
 Endif

Return


###################################################################################################
###################################################################################################
$EXEC_FIC_ORA
#Value Integer CTRL
Local Char SQLDBA(50)
Local Char WORDRE(250)
Local Char LIGNE(250)

 SQLDBA = "sqlplus" : # Ca existe dans les 2 versions
 WORDRE = SQLDBA-'/NOLOG @'+SQLFIC
 Call SYSTEME(MACHINE,WORDRE,"",ERR) From ORDSYS
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If left$(LIGNE,4) = "ORA-"
      ERR=1
      Call ECR_TRACE("|"+LIGNE,ERR) From GESECRAN
      Break
   Elsif left$(LIGNE,4) = "SP2-"
      ERR=1
      Call ECR_TRACE("|"+LIGNE,ERR) From GESECRAN
      Break
   Elsif left$(LIGNE,4) = "PLS-"
      ERR=1
      Call ECR_TRACE("|"+LIGNE,ERR) From GESECRAN
      Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      ERR=1
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,ERR) From GESECRAN
 Endif
Return

###################################################################################################
###################################################################################################
$RECUP_COUNT
Local Char    LIGNE(250)
Local Char    LIGNUM(250)
Local Integer TROUVE : TROUVE=0

adxifs = "" : adxirs = IRS : adxium = GASCII
If filinfo(FICTRA,0)>0
    Openi FICTRA
    Rdseq LIGNE
    While fstat=0
        LIGNE=vireblc(LIGNE,2)
        If left$(LIGNE,6) = "TOTAL="
            LIGNUM = right$(LIGNE,7)
            LIGNUM =vireblc(LIGNUM ,2)
            NOMBRE=val(LIGNUM)
            TROUVE=1
            Break
        Endif
        Rdseq LIGNE
    Wend
    Openi
    If TROUVE=0
        ERR=1 : # FQ66905
        Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,ERR) From GESECRAN
    Endif
Else
    ERR=1
    Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,ERR) From GESECRAN
Endif
Return



###################################################################################################
###################################################################################################
$WRITE_PROC_COUNT
Local Char VIEWNAME(50)
Local Integer OUVADSFLG : OUVADSFLG=0    : # Indicateur d'ouverture de la table des dossiers
Local Integer OUVADAFLG : OUVADAFLG=0    : # Indicateur d'ouverture de la table des codes activités dossiers FQ64390
Local Char NOMDOSS(50)

If !clalev([F:WADS]) : Local File ADOSSIER [F:WADS] : OUVADSFLG=1 : Endif
If !clalev([F:WADA]) : Local File ADOSACT  [F:WADA] : OUVADAFLG=1 : Endif : # FQ64390

If GTYPDBA=1 : # oracle
   Wrseq ""
Elsif GTYPDBA=2 and XBASE<>"": # sqlserver
# Issue X3-42308 - 2017-07-21 by BEFOU : A priori XBASE non chargé sous linux !
   Wrseq "use"-XBASE
   Wrseq "GO"
Endif

If GTYPDBA=1 : # oracle
    SAVUSER=USER
    For [WADS]DOSSIER
        NOMDOSS= [F:WADS]DOSSIER
        Read [F:WADA]ADA0=NOMDOSS;"FAS" : # FQ64390
        If fstat : Raz [F:WADA] : Endif : # FQ64390
        #If filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0 & APPLI<>NOMDOSS : # FQ64390
        #If APPLI<>NOMDOSS & [F:ADA]FLACT=2 & filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0 : # FQ69281
        # Issue 109669 If !(func ARECAUO.APPDEM(NOMDOSS)) & (APPLI<>NOMDOSS) & ([F:WADA]FLACT=2) & (filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0)
        If !(func ARECAUO.APPDEM(NOMDOSS)) & (APPLI<>NOMDOSS) & ([F:WADA]FLACT=2)
          If (filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0)
            Call PASSE(NOMDOSS,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
            Wrseq "connect"-USER+"/"+PASSE
            Wrseq "grant select on "+NOMDOSS+".FXDASSETS"-"to"-SAVUSER-";"
          Endif # Issue 109669
        Endif
    Next

    Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
    Wrseq "connect"-USER+"/"+PASSE
Endif

VIEWNAME=APPLI+"."+"TMPVFASCNT"+num$(adxuid(2))
Wrseq "CREATE VIEW"-VIEWNAME-"(DOSSIER,AASREF) AS"
# ### ATTENTION : il ne faudrait totaliser les biens en ne prenant que les dossiers de production !
For [WADS]DOSSIER
    NOMDOSS= [F:WADS]DOSSIER
    Read [F:WADA]ADA0=NOMDOSS;"FAS" : # FQ64390
    If fstat : Raz [F:WADA] : Endif : # FQ64390
    #If filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0 : # FQ64390
    #If [F:ADA]FLACT=2 & filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0 : # FQ69281
    # Issue 109669  If !(func ARECAUO.APPDEM(NOMDOSS)) & ([F:WADA]FLACT=2) & (filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0)
    If !(func ARECAUO.APPDEM(NOMDOSS)) & ([F:WADA]FLACT=2)
      If  (filinfo(filpath("FIL","FXDASSETS","fde",NOMDOSS),0)>=0)
        NBDOSS+=1
        If NBDOSS>1
            Wrseq "UNION"
        Endif
        # On calcul le nombre de biens présents ou sortis pour une CIG (Cession Intra Groupe)
        ###Filter [FAS] Where ISSTYP<>GVML_TSCIG &ISSTYP<>GVML_TSAPPOR &ISSTYP<>GVML_TSFUSIO &ISSTYP<>GVML_TSSCISS
        Wrseq "SELECT '"+NOMDOSS+"',AASREF_0 FROM "+NOMDOSS+".FXDASSETS"
        Wrseq "WHERE ISSTYP_0<>"+num$(GVML_TSCIG)-"AND ISSTYP_0<>"+num$(GVML_TSAPPOR)
        Wrseq "AND   ISSTYP_0<>"+num$(GVML_TSFUSIO)-"AND ISSTYP_0<>"+num$(GVML_TSSCISS)
        Wrseq "AND   ENAFAS_0="+num$([V]CST_AYES) # Issue 116395
      Endif # Issue 109669
    Endif
Next
If GTYPDBA=1 : # oracle
   Wrseq ";"
Elsif GTYPDBA=2 : # sqlserver
   Wrseq "GO"
Endif

Wrseq "SELECT 'TOTAL=' lib,count(distinct AASREF) FROM"-VIEWNAME
If GTYPDBA=1 : # oracle
   Wrseq ";"
Elsif GTYPDBA=2 : # sqlserver
   Wrseq "GO"
Endif

Wrseq "DROP VIEW"-VIEWNAME+";"
If GTYPDBA=1 : # oracle
   Wrseq ";"
Elsif GTYPDBA=2 : # sqlserver
   Wrseq "GO"
Endif
If OUVADSFLG : Close Local File [WADS] : Endif
If OUVADAFLG : Close Local File [WADA] : Endif : # FQ64390
Return

