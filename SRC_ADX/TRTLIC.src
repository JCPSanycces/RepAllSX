################################################################################
# Subprog LICACV : Fourni la liste des options et leur disponibilité / licence
################################################################################
Subprog LICACV(LICACV,LICACT,ACVNBR)
Variable Char    LICACV
Variable Integer LICACT
Variable Integer ACVNBR

Local    Char    ACT

# Module Financement
  [L]LICACV(0)="GRT"                : # Option Gestion des subventions
  #Call NOMBRE(2,[L]LICACT(0)) From GLOCK         : # FQ97426
  [L]LICACT(0) = fmet GACTX.AGETLICACV("GRT") + 1 : # FQ97426

  [L]LICACV(1)="LEA"                : # Option Gestion des Contrats de location-financement
  [L]LICACT(1) = fmet GACTX.AGETLICACV("LEA") + 1 : # FQ97426

# Module IAS/IFRS
  [L]LICACV(2)="IAS"                : # Option IAS
  #Call NOMBRE(3,[L]LICACT(2)) From GLOCK         : # FQ97426
  [L]LICACT(1) = fmet GACTX.AGETLICACV("IAS") + 1 : # FQ97426

  [L]ACVNBR=3

# Options Superviseur non modifiables dans ABELX3 => forcées à Non
  If GADONIX<>G_OUI
    For [L]ACT = "CSL","DAS","EUR","USA","VAT","VII"
      [L]LICACV([L]ACVNBR)=[L]ACT
      [L]LICACT([L]ACVNBR)=G_NON
      [L]ACVNBR += 1
    Next
  Endif
End

#########################################################################################
# Subprog LIMOBJ : Limite le menu local 341 aux objets gérés / licence et codes activités
#########################################################################################
Subprog LIMOBJ

  If G_ACTGRT = G_NON : GMENLOC(GVML_OMSUBV)=1 : Endif
  If G_ACTLEA = G_NON : GMENLOC(GVML_OMLOCFI)=1 : Endif

End

###################################################################################################
# Compte le nombre de biens distincts dans l'application
###################################################################################################
Subprog FASCNT (NOMBRE,ERR)
Variable Integer NOMBRE : # Nombre de biens distincts dans la solution
Variable Integer ERR    : # 0 : OK
ERR=0                   : # 1 : Erreur

  # S'il n'y a pas de dossier applicatif, on n'a pas de table FXDASSETS (sauf dossier de développement)
  If !clalev([F:WADS]) : Local File ADOSSIER [WADS] : Endif
  # Issue 109669 If rowcount([F:WADS])=1 and !(filinfo(filpath("FIL","FXDASSETS","fde",GDOSX3),0)>0)
  If rowcount([F:WADS])=1
    If !(filinfo(filpath("FIL","FXDASSETS","fde",GDOSX3),0)>0)
      End
    Endif # Issue 10966
  Endif

  # Génération et exécution d'un script sous le user du dossier racine pour faire le comptage
  If GTYPDBA=1 : # oracle
     Gosub TRT_FASCNT_ORA
  Elsif GTYPDBA=2 : # sqlserver
     Gosub TRT_FASCNT_SQL
  Endif

  If ERR=0
    # Mise à jour du compteur centralisé. Ce compteur se trouve dans la table des paramètres ADOVAL
    # du dossier racine sous le nom de NOMBCO
    Call MAJ_PARAM("NOMBCO",NOMBRE,ERR)
  Else
    Call ECR_TRACE(mess(136,7770,1),1) From GESECRAN
  Endif
End

#############################################################
## Mise à jour des compteurs communs NOMBCO et FASMAX (paramètre dans le dossier racine)
##
## Entrée
##   PARAM  : nom du paramètre
##   VALEUR : valeur à mettre à jour
## Sortie
##   ERR    : 0 : OK, 1 : Erreur
#############################################################
Subprog MAJ_PARAM(PARAM,VALEUR,ERR)
Value Char    PARAM  : # Paramètre à mettre à jour
Value Integer VALEUR : # Valeur à mettre à jour
Variable Integer ERR : # 0 : OK
  ERR=0              : # 1 : Erreur

  Local File =GDOSX3+".ADOVAL" [ZADW]

  Trbegin [ZADW]

  Readlock [ZADW]ADW1=PARAM;"";"" With lockwait=10
  If fstat=1 Then
    # Erreur de verrouillage de l'enregistrement
    ERR=1
  Elsif fstat
    # Le compteur n'existe pas, on le crée
    Raz [F:ZADW]
    [F:ZADW]CMP = ""
    [F:ZADW]FCY = ""
    [F:ZADW]PARAM  = PARAM
    [F:ZADW]VALEUR = num$(VALEUR)
    If dim([F:ZADW]CREDAT)>0 : [F:ZADW]CREDAT = date$ : Endif
    If dim([F:ZADW]CREUSR)>0 : [F:ZADW]CREUSR = GUSER : Endif
    If dim([F:ZADW]CRETIM)>0 : [F:ZADW]CRETIM = time  : Endif
    If dim([F:ZADW]UPDDAT)>0 : [F:ZADW]UPDDAT = date$ : Endif
    If dim([F:ZADW]UPDUSR)>0 : [F:ZADW]UPDUSR = GUSER : Endif
    If dim([F:ZADW]UPDTIM)>0 : [F:ZADW]UPDTIM = time  : Endif
    Write [ZADW]
    If fstat Then : ERR=1 : Endif
    Unlock [ZADW]
  Else
    # Le compteur existe, on le met à jour
    [F:ZADW]VALEUR = num$(VALEUR)
    If dim([F:ZADW]UPDDAT)>0 : [F:ZADW]UPDDAT = date$ : Endif
    If dim([F:ZADW]UPDUSR)>0 : [F:ZADW]UPDUSR = GUSER : Endif
    If dim([F:ZADW]UPDTIM)>0 : [F:ZADW]UPDTIM = time  : Endif
    Rewrite [ZADW] Curr
    If fstat Then : ERR=1 : Endif
    Unlock [ZADW]
  Endif

  If ERR : Rollback : Else : Commit : Endif

  If clalev([ZADW]) : Close File [ZADW] : Endif
End

#############################################################
## Lecture du compteur commun NOMBCO (paramètre dans le dossier racine)
#############################################################
Funprog LEC_NOMBCO()
Local Integer NOMBRE : # Nombre de bien
Local Integer ERR

Local File =GDOSX3+".ADOVAL" [ZADW]

  Read [ZADW]ADW1="NOMBCO";"";""


  If fstat Then
    # Erreur de lecture du paramètre, peut se produire la première fois ; dans ce cas on crée le paramètre
    Call FASCNT(NOMBRE,ERR)
    If ERR Then
      # Si on est sur le dossier racine, on continue ; sinon on stoppe
      #Call ECR_TRACE(mess(136,7770,1),1) From GESECRAN : # FQ66905 : inutile, on l'a déjà fait dans le CALL FASCNT()
      If GDOSX3<>nomap
       Reb
      Endif
    Endif
  Else
    NOMBRE=val([ZADW]VALEUR)
    # Si la mise à jour du compteur ne date pas de ce jour, on recalcule le nombre de biens
    If (dim([F:ZADW]UPDDAT)>0) and ([ZADW]UPDDAT<date$) Then
      Call FASCNT(NOMBRE,ERR)
      If ERR Then
        # Si on est sur le dossier racine, on continue ; sinon on stoppe
        #Call ECR_TRACE(mess(136,7770,1),1) From GESECRAN : # FQ66905 : inutile, on l'a déjà fait dans le CALL FASCNT()
        If GDOSX3<>nomap
          Reb
        Endif
      Endif
    Endif
  Endif

  If clalev([ZADW]) : Close File [ZADW] : Endif
End NOMBRE

############################################################# FQ97426
## Récupération du nombre de biens accordés par la licence
## - soit via la méthode AGETLICPAR si GACTX est chargé
## - soit via le paramètre FASMAX qui sert de cache
##
## En cas d'erreur renvoie 9999999 pour ne pas bloquer l'application
#############################################################
Funprog GET_FASMAX()
Local Integer RFASMAX
Local Char VALMAX(30)
Local Integer ERR

  If dim(GACTX) > -1
    # Le contexte est en ligne, on peut lire le nombre de biens accordé par la licence et on en profite
    # pour mettre à jour la valeur du paramètre caché FASMAX qui permettra de connaitre ce qui est accordé
    # par la licence lorsqu'on est déconnecté de Syracuse
    If fmet GACTX.AGETLICPAR("MAXFIXEDASSETS",VALMAX)=[V]CST_ATRUE
      RFASMAX=val(VALMAX)

      # Mise à jour du paramètre caché
      Call MAJ_PARAM("FASMAX",RFASMAX,ERR)
    Else
      # Il se peut que les informations ne soient pas disponibles. On lit le paramètre caché FASMAX
      Gosub LEC_FASMAX
    Endif
  Else
    # Le contexte n'est pas en ligne, on récupère le nombre de biens accordé par la licence
    # dans le paramètre caché FASMAX
    Gosub LEC_FASMAX
  Endif
End RFASMAX

# Lecture du paramètre FASMAX dans ADOVAL
$LEC_FASMAX
  Local File =GDOSX3+".ADOVAL" [ZADW]
  Read [F:ZADW]ADW1="FASMAX";"";""
  If fstat
    # On ne peut pas se permettre de planter l'appli, on retourne une grande valeur
    RFASMAX = 9999999
  Else
    RFASMAX = val([ZADW]VALEUR)
  Endif
  If clalev([ZADW]) : Close File [ZADW] : Endif
Return

$TRT_FASCNT_SQL
#############################################################
## Pour SQL-server
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) , IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Integer NBDOSS : NBDOSS=0

APPLI=GDOSX3
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS="unix"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE

If BASE<>""

 FICCMD = filpath("tmp","sqltrt"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqltrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqltrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 Openo FICSQL , 0
 Gosub WRITE_PROC_COUNT
 Wrseq "EXIT"
 Openo

 If NBDOSS=0 Then
   NOMBRE=0
 Else
   #on veut le controle
   CTRL=2
   Gosub EXEC_FIC_SQL
   If ERR=0 : Gosub RECUP_COUNT : Endif
 Endif

 # FQ66905
 If ERR=0
   # Suppression des fichiers
   System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
   System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
   System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 Else
   Call ECR_TRACE(mess(261,7770,1)-":\|"+SQLFIC+"|\|"+TRAFIC+"|\|"+CMDFIC,1) From GESECRAN
   Goto FIN_PROC_SQL
 Endif
Endif
$FIN_PROC_SQL
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

$TRT_FASCNT_ORA
#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50), IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Integer NBDOSS : NBDOSS=0

APPLI=GDOSX3
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS="unix"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 ###Wrseq "connect"-USER+"/"+PASSE
 Gosub WRITE_PROC_COUNT
 Wrseq "exit"
 Openo

 If NBDOSS=0 Then
   NOMBRE=0
 Else
   #on veut le controle
   CTRL=2
   Gosub EXEC_FIC_ORA
   If ERR=0 : Gosub RECUP_COUNT : Endif
 Endif

 # FQ66905
 If ERR=0
   # Suppression des fichiers
   System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
   System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 Else
   Call ECR_TRACE(mess(261,7770,1)-":\|"+SQLFIC+"|\|"+TRAFIC,1) From GESECRAN
   Goto FIN_PROC_ORA
 Endif
Endif
$FIN_PROC_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

