#######################################################################################
$AUPDATE_CONTROL_BEFORE
  # Issue X3-6415/119493 - 2016-10-28 by SINGC
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer IRET

  # Issue X3-17075/120484 - 2016-12-19 by FGR : BEGIN Not to do here
  ## Issue X3-6415/119493 - 2016-10-28 by SINGC
  #[L]ASTATUS = fmet this.CALCULATE_LOAD(this.POASTDQTY, this.POACSMQTY, this.POARMNQTY)
  # Issue X3-17075/120484 - 2016-12-19 by FGR : END
  # ----------------------------
  # Issue X3-17556/120812 - 2017-01-10 by FGR : BEGIN
  IRET = fmet this.LOAD_POACST_POACSTLAB()
  [L]ASTATUS = max([L]ASTATUS, IRET)
  # Issue X3-17556/120812 - 2017-01-10 by FGR : END
  # ----------------------------
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL)
    Return
  Endif
Return

#######################################################################################
$AINSERT_AFTER
Return

#######################################################################################
$AUPDATE_AFTER
Return

