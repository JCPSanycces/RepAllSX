#######################################################################################
# Classe PJMOPEAFF
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
$ACONTROL
Local Integer IRET           # Issue X3-30028/122466 - 2017-04-10 by FGR

  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL)
    Return
  Endif
  # ----------------------------
  # Issue X3-30028/122466 - 2017-04-10 by FGR : BEGIN
  If this.POASTR <> [0/0/0] and this.POAEND <> [0/0/0] Then
    If this.POASTR > this.POAEND Then
      IRET = fmet this.SETERROR("POASTR", mess(289,2260,1), [V]CST_AERROR)                               # Issue X3-23847/121267 - 2017-01-31 by FGR
      [L]ASTATUS = max([L]ASTATUS, IRET)                                                                 # Issue X3-23847/121267 - 2017-01-31 by FGR
    Endif
  Endif
  # ----------------------------
  IRET = func OPPORPJM_CSTD_PROGS.CONTROL_HOURS_BEGIN_END(this, this.POASTR, "POASTRHM", this.POASTRHM, this.POAEND, "POAENDHM", this.POAENDHM)
  [L]ASTATUS = max([L]ASTATUS,IRET)
  # Issue X3-30028/122466 - 2017-04-10 by FGR : END
  # ----------------------------
  # Issue X3-17377/120529 - 2016-12-21 by FGR : BEGIN
  ## Issue X3-6319/119461 - 2016-10-28 by SINGC : START
  #If this.POASTDQTY < this.POARMNQTY Then
  #  [L]ASTATUS = fmet this.SETERROR("POARMNQTY", mess(444,2260,1), [V]CST_AERROR)
  #Endif
  ## Issue X3-6319/119461 - 2016-10-28 by SINGC : END
  # Issue X3-17377/120529 - 2016-12-21 by FGR : END
Return

#######################################################################################
