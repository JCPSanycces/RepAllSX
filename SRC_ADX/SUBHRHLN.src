#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FHRHONLIN","SUBHRHLN","DHRHONLIN",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub DEVERROU

 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF 
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "ENR"         : Gosub VALID
 When "ABA"         : Gosub DEBUT
 When "OK"          : FIN = 0
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$INIT
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:HLN])=0 : Local File HONLIN     [HLN] : Endif

Call LECMEMO("STD","[M:DIA]","hon") From GMEMO
Return 

$INIT_DIA
Local Char VALPAR (10)
Raz [M:DIA]
Call PARAM("","DADYEA",VALPAR) From ADOVAL
[M:DIA]YEA=VALPAR
[M:DIA]ALLFCY    = 2
[M:DIA]ALLHON    = 2
If VALEUR=""
 [M:DIA]ALLPRVNUM = 2
Else
 [M:DIA]ALLPRVNUM = 1
 [M:DIA]PRVNUM    = VALEUR
Endif
Return

$CONTROLE
Lock ="HONLIN"+"\"+[M:DIA]CPY : # Nom entier du fichier car typges=2
If fstat=1
 GERR = 1 : GMESSAGE = mess(10,100,1) : # Modif en cours sur autre poste
 SAI = 1
Endif
Return

$SORTIE
Return

$DEVERROU
Unlock ="HONLIN"+"\"+[M:DIA]CPY
Return

$OUVRE
Local Integer MODIF, NOLIN, LG, STAT, ISOC
Local Char    CRITTAB(250)
Local Integer MAXLIGHLN
Return

$DEBUT
Raz [M:HLN1]
MAXLIGHLN = dim([M]PRVNUM)
[M:HLN1]YEA = [M:DIA]YEA
[M:HLN1]CPY = [M:DIA]CPY
STADEF = 0
CRITTAB = 'CPY = "'+[M:DIA]CPY+'"'
If [M:DIA]ALLFCY<>2
 CRITTAB -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITTAB -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
If [M:DIA]ALLHON<>2
 CRITTAB -= '& HON = '+num$([M:DIA]HON)
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITTAB -= '& DAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITTAB -= '& DAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
nolign = 0
For [HLN]HLN0 Where evalue(CRITTAB)
 nolign += 1
 [M] = [F:HLN]
 If nolign>=MAXLIGHLN
  # Tableau plein 
  Call MESSAGE(mess(26,100,1)) From GESECRAN 
  Break
 Endif 
Next
[M]NBLIG = nolign
[M]TOTAMT = sum([M]AMT(0..[M]NBLIG-1))
MODIF = 0
Affzo
Return

$SETBOUT
Raz ETABOU, REP
If MODIF
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Endif
ETABOU(GBFIN) = 1
Return

$APRES_MODIF
MODIF = 1
Return

$AP_CHOIX
Case REPONSE
 When GSTARET          : Gosub VALID
 When GSTAEND, GSTAESC : Gosub CONFIRME
 When Default
Endcase
Return

$CONFIRME
If MODIF 
 REP = "M"
Endif
Return

$VALID
If MODIF & [M:HLN1]NBLIG>0
 Sorta [M:HLN1]NBLIG [M:HLN1]NBLIG Order By [M:HLN1]FCY(indice),[M:HLN1]PRVNUM(indice),
&     [M:HLN1]DAT(indice),[M:HLN1]HON(indice)
 Affzo [M] : # Car après Enregistrer on revient en saisie
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
MODIF = 0
Return

$TR1
GOK = 1
Trbegin [HLN]
 Delete [HLN] Where evalue(CRITTAB)
 If fstat=1
  GOK = -1 : GLOCK = "$HONLIN" : Goto ROLL_TR1
 Endif
 For nolign=1 To [M:HLN1]NBLIG
  Raz [F:HLN]
  [F:HLN] = [M:HLN1]
  LG = nolign-1
  If LG=0
   NOLIN = 1 
  Elsif [M]FCY(LG)<>[M]FCY(LG-1) | [M]DAT(LG)<>[M]DAT(LG-1) | [M]HON(LG)<>[M]HON(LG-1) |
&       [M]PRVNUM(LG)<>[M]PRVNUM(LG-1)
   NOLIN = 1
  Else
   NOLIN +=1
  Endif
  [F:HLN]LINNUM = NOLIN
  Write [HLN]
  If fstat
   GOK = 0 : Call FSTA("HLN") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################
## Etiquette ajoutée par le superviseur (écran HONLIN1) 06/08/2009 12:50:01 (DBA)
######################################################################################

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]FCY<>""
 VALEUR = [M:DIA]FCY
 Call AM_FCY (VALEUR)
 mkstat = 2 : End
Else
 If VALEUR="" & indice>0
  VALEUR = [M]FCY(indice-1)
  Call AM_FCY (VALEUR)
  End
 Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[FCY]FCY0=VALEUR
 If !fstat & [F:FCY]DADFCY<>""
  [M]DADFCY(nolign-1)=[F:FCY]DADFCY
 Else
  Read [F:FCY]FCY0=VALEUR
  If !fstat & [F:FCY]DADFCY<>""
   [M]DADFCY(nolign-1)=[F:FCY]DADFCY
  Else
   [M]DADFCY(nolign-1)=VALEUR
  Endif
 Endif
Endif
End


Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M:DIA]PRVNUM<>""
 VALEUR = [M:DIA]PRVNUM
 mkstat = 2 : End
Else
 If VALEUR="" & indice>0
  VALEUR = [M]PRVNUM(indice-1)
 Endif
Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]STRDAT | (VALEUR>[M:DIA]ENDDAT & [M:DIA]ENDDAT<>[00/00/00])
 GMESSAGE = mess(12,122,1)-format$(GFMD,[M:DIA]STRDAT)-"-"-format$(GFMD,[M:DIA]ENDDAT)
 # Date en dehors de la période
 mkstat = 2
 End
Endif
End

Subprog AS_HON(VALEUR)
Variable Integer    VALEUR()
If [M:DIA]HON<>0
 VALEUR = [M:DIA]HON
 mkstat = 2 : End
Endif
End

Subprog C_HON(VALEUR)
Variable Integer   VALEUR()
If clalev([F:PRV])=0 : Local File HONPRV[PRV] : Endif
Read[PRV]PRV0=[M]PRVNUM(nolign-1)
If fstat : End : Endif
Case VALEUR
 When 9  
  ##Indemnités & Remboursements
  If [F:PRV]CODMOD=""
   #Type de rémunération non paramétrée pour ce prestataire
   GMESSAGE=mess(75,122,1)
   mkstat=2 : End 
  Endif
 When 10
  #Avantages en nature
  If [F:PRV]CODAVN=""
   #Type de rémunération non paramétrée pour ce prestataire
   GMESSAGE=mess(75,122,1)
   mkstat=2 : End 
  Endif
 When 11
  #Retenues impôt s/revenu
  If [F:PRV]CODRAT=""
   #Type de rémunération non paramétrée pour ce prestataire
   GMESSAGE=mess(75,122,1)
   mkstat=2 : End 
  Endif
Endcase
End

Subprog AS_VALHON(VALEUR)
Variable Char    VALEUR()
If !find([M]HON(nolign-1),9,10,11)
 mkstat = 1 : End
Endif
End

Subprog C_VALHON(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRV])=0 : Local File HONPRV[PRV] : Endif
Read[PRV]PRV0=[M]PRVNUM(nolign-1)
If fstat : End : Endif
Local Char CODES (5)
Local Char VALCODE (1)

# N4DS - On doit faire le détail des avantages / indemnités, du coup on impose une saisie "unique" par ligne
#        On ne change pas la longueur de la zone pour ne pas perdre d'infos sur l'existant 

If len([L]VALEUR) > 1
    # mess(92,705,1) : N4DS - Les informations doivent être saisies de manière détaillées\Une ligne par type d'élément à saisir
    [V]GMESSAGE = mess(92, 705, 1)
    mkstat = 2 : End
Endif

Case[M]HON(nolign-1)
 When 9  
  ##Indemnités & Remboursements
  CODES=[F:PRV]CODMOD
 When 10
  #Avantages en nature
  CODES=[F:PRV]CODAVN
 When 11
  #Retenues impôt s/revenu
  CODES=[F:PRV]CODRAT
Endcase
For I=1 To len(VALEUR)
 If !instr(1,CODES,mid$(VALEUR,I,1))
  #Type de rémunération non paramétrée pour ce prestataire : 
   GMESSAGE=mess(75,122,1)-":"-mid$(VALEUR,I,1)
   mkstat=2 : End 
 Endif
Next I
End

Subprog AVANT_NBLIG
[M]TOTAMT -= [M]AMT(nolign-1)
End

Subprog APRES_NBLIG
Local Integer STAT
[M]TOTAMT += [M]AMT(nolign-1)
Affzo [M]AMT(nolign-1), TOTAMT
End



