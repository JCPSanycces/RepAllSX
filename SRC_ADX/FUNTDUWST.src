#<AdxTL>@(#)2.0.0.0 $Revision$
#################################################################################
#                                                                               #
#    MODELISATION E-COMMERCE                                                    #
#                                                                               #
# ACTION  : TRTTDUWST  : Action traitement remplacement postes                  #
#                                                                               #
#################################################################################

########################################################################
#    Détail des actions                                                #
########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Case GACTION
                           When "SAITDUWST" : Gosub OUVRE
                       Endcase
 When "SETBOUT"      : Gosub SETBOUT
 When "DEBUT"        : Case GACTION
                           When "SAITDUWST" : Gosub S_DEBUT
                           When "TRTTDUWST" : Gosub T_DEBUT
                       Endcase
 When "APRES_MODIF"  : Gosub APRES_MODIF
 #When "AVANT_OK"     : Gosub AVANT_OK
 When "AVANT_ENR"    : Gosub AVANT_ENR
 When "ENR"          : Case GACTION
                           When "TRTTDUWST" : Gosub ENREGISTRE
                       Endcase
 When "ABA"          : Gosub ABORT
 When "TERMINE"      : Gosub TERMINE
 When "FIN"          : Gosub FIN
Endcase
Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################

$OUVRE
If clalev([F:MWS]) =0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:ROH]) =0 : Local File ROUTING    [ROH] : Endif
If clalev([F:ROO]) =0 : Local File ROUOPE     [ROO] : Endif
If clalev([F:TRO]) =0 : Local File TABROUALT  [TRO] : Endif
If clalev([F:FCY]) =0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TFO]) =0 : Local File TABFOR     [TFO] : Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Return

########################################################################
$SETBOUT
Raz ETABOU
ETABOU(GVALI) = 1
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
Return

########################################################################
$S_DEBUT
Raz [M:TUT0]
Raz [M:TUT1]
Raz [M:TUT2]

[M:TUT0]MFGFCY = GFCY
[M:TUT0]REPLACEFLG = 1

Grizo [TUT2]WSTV
Grizo [TUT2]LABWSTV
Grizo [TUT2]SCOWSTV
Grizo [TUT2]SCOITMREFV : # Grizo [TUT2]FSCOITMREF : # GH 23/01/2014
Grizo [TUT2]BPSNUMV    : # Grizo [TUT2]FBPSNUM    : # GH 23/01/2014
Grizo [TUT2]BPAADDV
Grizo [TUT2]REFPRIV    : # Grizo [TUT2]FREFPRI    : # GH 23/01/2014

Grizo [TUT0]APPDAT
Affzo [TUT1]1-99
Affzo [TUT2]1-99

Return

########################################################################
$AVANT_OK

# GH 23/01/2014 une opération peut déjà avoir un article SST qu'on veut conserver
#sous-traitance sans saisie  d'article
#If [M:TUT2]SCOITMREFV="" & [M:TUT2]WSSTRAI = 1
#   [M:TUT2]FSCOITMREF=2 : Affzo [TUT2]FSCOITMREF
#   Actzo [TUT2]SCOITMREFV : SUIZON ="[M:TUT2]SCOITMREFV"
#   GERR = 1 : GMESSAGE = mess(152,190,1) : FIN=0
#Endif


# GH 23/01/2014 On doit pouvoir modifier un poste m-o sans modifier le poste pricnipal d'une opération
# Saisie d'un poste m-o sans saisie préalable d'un poste de charge principal
#If [M:TUT2]WSTV= "" & [M:TUT2]LABWSTV <>""
#   [M:TUT2]FLABWST = 1  : [M:TUT2]LABWSTV = "" : [M:TUT2]LABWSTDES =""
#   Affzo [TUT2]FLABWST, LABWSTV, LABWSTDES : Grizo [TUT2]LABWSTV, LABWSTDES
#   GERR = 1 : GMESSAGE = mess(189,193,1) : FIN=0
#Endif

Return

########################################################################
$T_DEBUT
Local  Char        CRITERE(250), CRITERE1(250)
Local  Integer     OK, NBOPE, MAJOPE, I  #
Local  Date        XAPPDAT
Local  Char        FORMULE1(255), FORMULE2(255)
Local  Integer     WOPENUM, WROUALT
Local  Char        WITMREF(GLONITM)
Local  Integer     WMAX
Global Integer     WWORKFLG       : WWORKFLG = 0  : # Issue X3-60368 - 2017-10-19 by JUSYN Trace versioned Route log file -
                                                    # work flag to see whether modifications made

Default Mask [TUT3]
WMAX = dim([M:TUT3]WST) :      # llc 04.03 17909

Gosub LIRE
If [M:TUT3]NBLIG=0
    GERR= 2: GMESSAGE=mess(358,197,1) : # Aucun poste de charge à traiter
    FIN =1
Endif

# Issue X3-57041 - 2017-10-16 by JUSYN : Info message about not deleted components in versioned BOMs / Grey out versioned fields as well
If func AFNC.ACTIV("RVM")
    If [M:TUT3]NBLIG > 0
        Call MESSAGE(mess(413,193,1)) From GESECRAN
        # Version managed Routes included in the selection criteria are not processed. Please update these manually.
    Endif
Endif
# End issue X3-57041

Return

#######################################################################
$AVANT_ENR
For I=0 To [M:TUT3]NBLIG-1
 If [M:TUT3]SCOITMREF(I)="" & [M:TUT3]SCOWSTTYP(I)=3
     # Saisie d'un article obligatoire
     GERR= 1 : mkstat = 2 : GMESSAGE = mess(152,190,1) : SUIZON = "[M:TUT3]SCOITMREF("+num$(I)+")" : Break
 Endif
Next I
Return

#######################################################################
$ENREGISTRE
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN : # Validation de la saisie
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif

Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1) : # Fin de la modification série
Return

#######################################################################
$ABORT
Raz [M:TUT3]
Affzo [TUT3]
Gosub LIRE
Return

#######################################################################
$TERMINE
Call FERME_TRACE From LECFIC
# Issue X3-60368 - 2017-10-19 by JUSYN Trace versioned Route log file -
#                                      Delete log file if not needed (e.g. without any processing and only listed versioned routes).
If WWORKFLG
    Call LEC_TRACE From LECFIC
Endif
# End issue X3-60368
Return

#######################################################################
$FIN
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3
Return

##########################################################################
# Sélection de gammes
$SEL_ROUTING

CRITERE =""

If [M:TUT0]MFGFCY <> ""
   CRITERE -= '&FCY="'+[M:TUT0]MFGFCY+'"'
Endif

If [M:TUT1]ROUALTDEB <> 0
   CRITERE -= "&ROUALT>="+num$([M:TUT1]ROUALTDEB)
Endif
If [M:TUT1]ROUALTFIN <> 0
   CRITERE -= "&ROUALT<="+num$([M:TUT1]ROUALTFIN)
Endif

If [M:TUT1]ROUNUMDEB <> ""
   CRITERE -= '&ITMREF>="'+[M:TUT1]ROUNUMDEB+'"'
Endif
If [M:TUT1]ROUNUMFIN <> ""
   CRITERE -= '&ITMREF<="'+[M:TUT1]ROUNUMFIN+'"'
Endif

If [M:TUT1]OPENUMDEB <> 0
   CRITERE -= "&OPENUM>="+num$([M:TUT1]OPENUMDEB)
Endif
If [M:TUT1]OPENUMFIN <> 0
   CRITERE -= "&OPENUM<="+num$([M:TUT1]OPENUMFIN)
Endif

If CRITERE="" : CRITERE="1=1" : Else CRITERE=right$(CRITERE,3) : Endif

CRITERE1 = ""

If [M:TUT1]WSTDEB <> ""
   CRITERE1 -= '&WST>="'+[M:TUT1]WSTDEB+'"'
Endif
If [M:TUT1]WSTFIN <> ""
   CRITERE1 -= '&WST<="'+[M:TUT1]WSTFIN+'"'
Endif

If [M:TUT1]LABWSTDEB <> ""
   CRITERE1 -= '&LABWST>="'+[M:TUT1]LABWSTDEB+'"'
Endif
If [M:TUT1]LABWSTFIN <> ""
   CRITERE1 -= '&LABWST<="'+[M:TUT1]LABWSTFIN+'"'
Endif

If [M:TUT1]SCOCODDEB <> 0
   CRITERE -= "&SCOCOD>="+num$([M:TUT1]SCOCODDEB)
Endif
If [M:TUT1]SCOCODFIN <> 0
   CRITERE -= "&SCOCOD<="+num$([M:TUT1]SCOCODFIN)
Endif

If [M:TUT1]SCOWSTDEB <> ""
   CRITERE1 -= '&SCOWST>="'+[M:TUT1]SCOWSTDEB+'"'
Endif
If [M:TUT1]SCOWSTFIN <> ""
   CRITERE1 -= '&SCOWST<="'+[M:TUT1]SCOWSTFIN+'"'
Endif

If [M:TUT1]SCOITMDEB <> ""
   CRITERE1 -= '&SCOITMREF>="'+[M:TUT1]SCOITMDEB+'"'
Endif
If [M:TUT1]SCOITMFIN <> ""
   CRITERE1 -= '&SCOITMREF<="'+[M:TUT1]SCOITMFIN+'"'
Endif

If CRITERE1="" : CRITERE1="1=1" : Else CRITERE1=right$(CRITERE1,3) : Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

##################################################
# analyse présence formule de sélection

$ANALYSE_FORMULE
Local Integer WITM, WTRO, WITF, WROT, WMWS

If [M:TUT1]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [TFO]TFO0=9;[M:TUT1]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

FORMULE2 = vireblc(FORMULE1,4)
Gosub TABLE_FORMULE
Return

$TABLE_FORMULE
If !WITM & (instr(1,FORMULE2,"[ITM]") | instr(1,FORMULE2,"[F:ITM]"))
   WITM=1
   If !clalev([F:ITM]) : Local File ITMMASTER [ITM]  : Endif
Endif

If !WTRO & (instr(1,FORMULE2,"[TRO]") | instr(1,FORMULE2,"[F:TRO]"))
   WTRO=1
   If !clalev([F:TRO]) : Local File TABROUALT [TRO]  : Endif
Endif

If !WITF & (instr(1,FORMULE2,"[ITF]") | instr(1,FORMULE2,"[F:ITF]"))
   WITF=1
   If !clalev([F:ITF]) : Local File ITMFACILIT [ITF]  : Endif
Endif

If !WROT & (instr(1,FORMULE2,"[ROT]") | instr(1,FORMULE2,"[F:ROT]"))
   WROT=1
   If !clalev([F:ROT]) : Local File ROUOPESTD [ROT]  : Endif
Endif

If !WMWS & (instr(1,FORMULE2,"[MWS]") | instr(1,FORMULE2,"[F:MWS]"))
   WMWS=1
   If !clalev([F:MWS]) : Local File WORKSTATIO [MWS]  : Endif
Endif
Return

########################################################################
$CONTEXTE_FORMULE
If FORMULE1="1=1" : Return : Endif

If WITM & [F:ITM]ITMREF<>[F:ROO]ITMREF
   Read [ITM]ITM0 = [F:ROO]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

If WITF & ([F:ITF]STOFCY<>[F:ROO]FCY | [F:ITF]ITMREF<>[F:ROO]ITMREF)
   Read [ITF]ITF0 = [F:ROO]ITMREF;[F:ROO]FCY
   If fstat : Raz [F:ITF] : Endif
Endif

If WTRO & [F:TRO]ROUALT<>[F:ROO]ROUALT
   Read [TRO]TBO0 = [F:ROO]ROUALT
   If fstat : Raz [F:TRO] : Endif
Endif

If WROT & ([F:ROT]STDOPENUM<>[F:ROO]STDOPENUM | [F:ROT]FCY<>[F:ROO]FCY)
   Read [ROT]ROT0 = [F:ROO]STDOPENUM;[F:ROO]FCY
   If fstat : Raz [F:ROT] : Endif
Endif

If WMWS & ([F:MWS]WST<>[F:ROO]WST | [F:MWS]WCRFCY<>[F:ROO]FCY)
   Read [MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
   If fstat : Raz [F:MWS] : Endif
Endif
Return

##########################################################################
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return

##########################################################################
# Lecture
$LIRE
# Issue X3-57041 - 2017-10-16 by JUSYN : Check for activity code RVM
Local Integer WACTRVM : WACTRVM = func AFNC.ACTIV("RVM")
# Issue X3-57041 - end

REP=""
Raz [M:TUT3]
nolign= 0

If GTRACE = ""
    Call OUVRE_TRACE(mess(148,190,1)) From LECFIC : # Modification en série des opérations
Endif

# Issue X3-60368 - 2017-10-19 by JUSYN Trace versioned Route log file - info message
If WACTRVM
    Call ECR_TRACE(mess(413,193,1),0) From GESECRAN
Endif
# End issue X3-60368

[M:TUT3]MFGFCY = [M:TUT0]MFGFCY
Call LECTURE("FCY",[M:TUT3]MFGFCY,"") From CONTOBJ
[M:TUT3]FCYNAM = [F:FCY]FCYNAM

Gosub SEL_ROUTING
If [M:TUT0]REPLACEFLG = 2
   XAPPDAT = [M:TUT0]APPDAT
   Raz WITMREF, WROUALT, WOPENUM
Else
   XAPPDAT = date$
Endif

# --- Positionnement du filtre : # Beryl Site en fin de clé primaire
Link [ROO] With [ROH]ROH0=[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]FCY As [ROX]
&                Where evalue(CRITERE) & evalue(CRITERE1) &
&               (([F:ROH]ROUENDDAT  >= XAPPDAT & [F:ROH]ROUENDDAT<>[0/0/0]) |[F:ROH]ROUENDDAT=[0/0/0])
&          Order By Key ROO0

nolign=1
For [ROX]
    If nolign = WMAX : WMAX=-1 : Break : Endif    # llc 04.03 17909

    # Issue X3-57041 - 2017-10-16 by JUSYN : Exclude versioned routes from selection
    If WACTRVM
        If func RVMLIB.NBRCPNROU([F:ROH]ITMREF) > 0
            # Issue X3-60368 - 2017-10-19 by JUSYN Trace versioned Route log file - Writing
            Gosub CHARG_LOG
            # End issue X3-60368
            Goto NXTOPE
        Endif
    Endif
    # End ISSUE X3-57041

    # test si opération issue d'une opération std
    If [F:ROO]STDOPENUM<>0 & [M:TUT1]EFFUPD=1
       Goto NXTOPE
    Endif

    # Test si date de remplacement encore valable
    If !(([F:ROO]VALENDDAT >= XAPPDAT & [F:ROO]VALENDDAT<>[0/0/0])| [F:ROO]VALENDDAT=[0/0/0])
       Goto NXTOPE
    Endif

    ## Analyse de la formule de sélection
    Gosub CONTEXTE_FORMULE
    If !evalue(FORMULE1) : Goto NXTOPE : Endif

    [M:TUT3] = [F:ROH]
    [M:TUT3] = [F:ROO]
    If [M:TUT0]REPLACEFLG <> 2
       Gosub MAJ_AFFICH
    Elsif WITMREF<>[M:TUT3]ITMREF(nolign-1)
&       | WROUALT<>[M:TUT3]ROUALT(nolign-1)
&       | WOPENUM<>[M:TUT3]OPENUM(nolign-1)
       # Issue 84175 - 2012-10-16 by CCC
       WITMREF = [M:TUT3]ITMREF(nolign-1)
       WROUALT = [M:TUT3]ROUALT(nolign-1)
       WOPENUM = [M:TUT3]OPENUM(nolign-1)
       Gosub VARIANTE
    Elsif MAJOPE
       Gosub MAJ_AFFICH
    Endif
    If OK : nolign+=1 : Endif

$NXTOPE
Next

[M:TUT3]NBLIG = nolign-1
Affzo [TUT3]

# Attention, d'autres enregistrements existent pour ces sélections
If WMAX<0 : Call MESSAGE(mess(168,190,1)) From GESECRAN : WMAX = dim([M:TUT3]WST) : Endif   # llc 04.03 17909
Return

#######################################################################
$VARIANTE
# si l'opération d'indice R est avec DD <= XAPPDAT-1 et DF = vide ou >= XAPPDAT
# on splitte l'opération en 2
# - opération initiale  d'indice R   de DD à XAPPDAT-1 SANS application des modifs
# - nouvelle  opération d'indice R+1 de XAPPDAT à DF   AVEC application des modifs

If [M:TUT3]VALSTRDAT(nolign-1) < XAPPDAT
   Look [ROO]ROO0 = [M:TUT3]MFGFCY;[M:TUT3]ITMREF(nolign-1);[M:TUT3]ROUALT(nolign-1);[M:TUT3]OPENUM(nolign-1);[M:TUT3]RPLIND(nolign-1)+1
   If !fstat
     # Une opération de remplacement existe déjà
     # => On ne peut pas splitter
     # => On affiche les opérations de même no et gamme sans appliquer les modifs
     Call ECR_TRACE(mess(209,197,1)-num$([M:TUT3]OPENUM(nolign-1))+"/"+num$([M:TUT3]RPLIND(nolign-1))+ "/"+
&                  [M:TUT3]ITMREF(nolign-1)-":"-mess(154,190,1), 0) From GESECRAN
     MAJOPE=0
     Return
   Endif
   Gosub MAJ_AFFICH
   [M:TUT3]RPLIND(nolign-1) = [F:ROO]RPLIND+1
   [M:TUT3]VALSTRDAT(nolign-1)= XAPPDAT
   [M:TUT3]CREFLG(nolign-1) = 2
   MAJOPE=1
Else
   Gosub MAJ_AFFICH
   MAJOPE=1
Endif

Return

############################################################################
# affichage mis à jour en fonction des modifs à faire en série
$MAJ_AFFICH

# affichage des zones liées au poste de charge principal
If [M:TUT3]WST(nolign-1) <> "" & [M:TUT2]FWST <> 2
  Read [MWS]WST0=[M:TUT3]WST(nolign-1);[F:ROO]FCY
  If !fstat
      [M:TUT3]WCR(nolign-1)=[F:MWS]WCR : [M:TUT3]WSTTYP(nolign-1)=[F:MWS]WSTTYP
# GH 10/01/2014 bug 95776
#     [M:TUT3]WSTNBR(nolign-1) = [F:MWS]WSTNBR
#     [M:TUT3]SHR(nolign-1)    = [F:MWS]SHR
#      If GWSTEFFINH<>1
#         [M:TUT3]EFF(nolign-1) = [F:MWS]EFF
#      Endif
   Endif
Endif

# modif en masse du poste de charge principal
If [M:TUT2]FWST = 2
    [M:TUT3]WST(nolign-1) = [M:TUT2]WSTV

    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[M:TUT3]WST(nolign-1);[F:ROO]FCY
    If !fstat
        [M:TUT3]WCR(nolign-1)    = [F:MWS]WCR
        [M:TUT3]WSTTYP(nolign-1) = [F:MWS]WSTTYP
        [M:TUT3]WSTNBR(nolign-1) = [F:MWS]WSTNBR
        [M:TUT3]SHR(nolign-1)    = [F:MWS]SHR
        If GWSTEFFINH<>1
           [M:TUT3]EFF(nolign-1) = [F:MWS]EFF
        Endif

        # si type poste principal<> MA
        If [M:TUT3]WSTTYP(nolign-1)<>1
            [M:TUT3]LABWST(nolign-1)="" : [M:TUT3]LABWCR(nolign-1)=""
            [M:TUT3]LABNBR(nolign-1) = 0 : [M:TUT3]LABWSTTYP(nolign-1)=0
        Endif
        # la sous-traitance devient structurelle
        If [M:TUT3]WSTTYP(nolign-1) = 3
           [M:TUT3]WSTNBR(nolign-1) = 1
           [M:TUT3]SCOCOD(nolign-1) = 2 : [M:TUT3]SCOWST(nolign-1) = [M:TUT2]WSTV
        # la sous-traitance devient conjoncturelle
        Elsif [M:TUT3]SCOCOD(nolign-1) = 2
           [M:TUT3]SCOCOD(nolign-1) = 3
        Endif
    Endif
Endif


# affichage des zones liées au poste main-d'oeuvre
If [M:TUT3]LABWST(nolign-1) <> "" & [M:TUT2]FLABWST<>2
    Read [MWS]WST0=[M:TUT3]LABWST(nolign-1);[F:ROO]FCY
    If !fstat
        [M:TUT3]LABWCR(nolign-1)=[F:MWS]WCR : [M:TUT3]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
# GH 10/01/2014 bug 95776
#       [M:TUT3]LABNBR(nolign-1)=[F:MWS]WSTNBR
    Endif
Endif

# modif en masse du poste MO
If [M:TUT2]FLABWST = 2 & [M:TUT3]WSTTYP(nolign-1)<>3  & [M:TUT2]LABWSTV<>""
# GH 23/01/2014 On peut avoir une opération avec un poste m-o en poste de charge principal et secondaire
#If [M:TUT2]FLABWST = 2 & [M:TUT3]WSTTYP(nolign-1) = 1  & [M:TUT2]LABWSTV<>""
    [M:TUT3]LABWST(nolign-1) = [M:TUT2]LABWSTV
    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[M:TUT3]LABWST(nolign-1);[F:ROO]FCY
    If !fstat
        [M:TUT3]LABWCR(nolign-1)   = [F:MWS]WCR :  [M:TUT3]LABWSTTYP(nolign-1)= [F:MWS]WSTTYP
        [M:TUT3]LABNBR(nolign-1)   = [F:MWS]WSTNBR
        If [M:TUT3]OPELABCOE(nolign-1) =0 :[M:TUT3]OPELABCOE(nolign-1)=1 : Endif
        If [M:TUT3]SETLABCOE(nolign-1) =0 :[M:TUT3]SETLABCOE(nolign-1)=1 : Endif
    Endif
Endif

# suppression des éléments relatifs au poste M-O
If [F:ROO]LABWST<>"" & [M:TUT2]FLABWST=2  & [M:TUT2]LABWSTV=""
     [M:TUT3]LABWST(nolign-1)= ""
     [M:TUT3]LABWCR(nolign-1) ="" : [M:TUT3]LABWSTTYP(nolign-1)=0
     [M:TUT3]LABNBR(nolign-1) =0
Endif


# affichage des zones liées au poste de sous-traitance
If [M:TUT3]SCOWST(nolign-1) <> ""
    Read [MWS]WST0=[M:TUT3]SCOWST(nolign-1);[F:ROO]FCY
    If !fstat
        [M:TUT3]SCOWCR(nolign-1) = [F:MWS]WCR : [M:TUT3]SCOWSTTYP(nolign-1) = [F:MWS]WSTTYP
    Endif
Endif

# Modif en masse du poste de sous-traitance
If  [M:TUT3]SCOCOD(nolign-1)<>2 & [M:TUT2]FSCOWST=2 & [M:TUT2]SCOWSTV<>""
    [M:TUT3]SCOWST(nolign-1) = [M:TUT2]SCOWSTV
    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[M:TUT3]SCOWST(nolign-1);[F:ROO]FCY
    If !fstat
        [M:TUT3]SCOWCR(nolign-1) = [F:MWS]WCR
        [M:TUT3]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
        [M:TUT3]SCOCOD(nolign-1) = 3
    Endif
Endif

# suppression des éléments relatifs au poste de sous-traitance
If [F:ROO]SCOWST <> "" & [M:TUT2]FSCOWST=2 & [M:TUT2]SCOWSTV= "" & [M:TUT3]SCOCOD(nolign-1) = 3
        [M:TUT3]SCOWST(nolign-1)= ""
        [M:TUT3]SCOWCR(nolign-1) = ""
        [M:TUT3]SCOCOD(nolign-1) = 1
        [M:TUT3]SCOWSTTYP(nolign-1) = 0
        [M:TUT3]SCOITMREF(nolign-1) = ""
        [M:TUT3]BPRNUM(nolign-1) = ""
        [M:TUT3]BPAADD(nolign-1) = ""
        [M:TUT3]REFPRI(nolign-1) = 0
Endif

# article sous-traitance
# 39639 mm 02.07
If [M:TUT2]FSCOITMREF = 2 & [M:TUT3]SCOCOD(nolign-1) <> 1
    [M:TUT3]SCOITMREF(nolign-1) = [M:TUT2]SCOITMREFV
Endif

# fournisseur
If [M:TUT2]FBPSNUM = 2 & [M:TUT3]SCOCOD(nolign-1) <> 1
    [M:TUT3]BPRNUM(nolign-1) = [M:TUT2]BPSNUMV
Endif

# GH 10/01/2014 bug 95776
# adresse
If [M:TUT2]FBPAADD = 2 & [M:TUT3]SCOCOD(nolign-1) <> 1
    [M:TUT3]BPAADD(nolign-1) = [M:TUT2]BPAADDV
Endif

# prix
If [M:TUT2]FREFPRI = 2 & [M:TUT3]SCOCOD(nolign-1) <> 1
    [M:TUT3]REFPRI(nolign-1) = [M:TUT2]REFPRIV
Endif

If [M:TUT1]EFFUPD2 = 2 &
& [F:ROO]WST       = [M:TUT3]WST(nolign-1)       &
& [F:ROO]LABWST    = [M:TUT3]LABWST(nolign-1)    &
& [F:ROO]SCOWST    = [M:TUT3]SCOWST(nolign-1)    &
& [F:ROO]SCOITMREF = [M:TUT3]SCOITMREF(nolign-1) &
& [F:ROO]BPRNUM    = [M:TUT3]BPRNUM(nolign-1)    &
& [F:ROO]BPAADD    = [M:TUT3]BPAADD(nolign-1)    &
& [F:ROO]REFPRI    = [M:TUT3]REFPRI(nolign-1)
  OK=0 : # Aucune modification ne s'applique sur l'opération => on ne la charge pas dans le tableau
Else
  OK=1
Endif
Return

#######################################################################
# Mise à jour/ création opérations
$MODIF
Call TEMPON ("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (mess(148,190,1)) From LECFIC : # Modification en série des opérations
Endif

NBOPE = 0
Call DEBTRANS From GLOCK
Call ECR_TRACE('',0) From GESECRAN

# Issue X3-60368 - 2017-10-19 by JUSYN Trace versioned Route log file - Moved to first opening of log file; Setting work/process flag
WWORKFLG = 1
# Issue X3-57041 - 2017-10-12 by JUSYN : Info message about not processed versioned routes
#If func AFNC.ACTIV("RVM")
#    Call ECR_TRACE(mess(413,193,1),0) From GESECRAN
#Endif
# End issue X3-57041
# End issue X3-60368

Trbegin [ROO]
    For nolign = 1 To [M:TUT3]NBLIG
     If [M:TUT3]CREFLG(nolign-1) = 2
        # création de l'opération
        Call ECR_TRACE(mess(155,190,1)-num$([M:TUT3]OPENUM(nolign-1) )+"/"+num$([M:TUT3]RPLIND(nolign-1))+"/"+[M:TUT3]ITMREF(nolign-1),0) From GESECRAN

        # ajout de la ligne dupliquée dans la base
        # Issue 84175 - 2012-10-16 by CCC
        Read [ROO]ROO0 = [M:TUT3]MFGFCY;[M:TUT3]ITMREF(nolign-1);[M:TUT3]ROUALT(nolign-1);[M:TUT3]OPENUM(nolign-1);[M:TUT3]RPLIND(nolign-1)-1
        If fstat : # Issue 115901 - 2016-05-31 by GH : test added
            GCLE = [M:TUT3]ITMREF(nolign-1)-num$([M:TUT3]ROUALT(nolign-1))-num$([M:TUT3]OPENUM(nolign-1))-num$([M:TUT3]RPLIND(nolign-1)-1)
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif
        [F:ROO]=[M:TUT3]
        Raz [F:ROO]RSTMAC,[F:ROO]SCHGRP,[F:ROO]SCHGRPFOR,[F:ROO]SCHSBB,[F:ROO]SCHSBBFOR

        # Issue 115901 - 2016-05-31 by GH : entry point added
        GPOINT = "UPDROO" : Gosub ENTREE From EXEFNC
        If GOK<1 : Break : Endif

        Write [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif

        # modif de la ligne initiale
        Readlock [ROO]ROO0 = [M:TUT3]MFGFCY;[M:TUT3]ITMREF(nolign-1);[M:TUT3]ROUALT(nolign-1);[M:TUT3]OPENUM(nolign-1);[M:TUT3]RPLIND(nolign-1)-1
        If fstat
            GCLE = [M:TUT3]ITMREF(nolign-1)-num$([M:TUT3]ROUALT(nolign-1))-num$([M:TUT3]OPENUM(nolign-1))-num$([M:TUT3]RPLIND(nolign-1)-1)
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif
        [F:ROO]VALENDDAT = XAPPDAT-1
        Rewrite [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif

     Else
         Read [ROO]ROO0 = [M:TUT0]MFGFCY;[M:TUT3]ITMREF(nolign-1);[M:TUT3]ROUALT(nolign-1);[M:TUT3]OPENUM(nolign-1);[M:TUT3]RPLIND(nolign-1)
         If fstat : Goto NXTLIG : Endif

         If  [F:ROO]WST       = [M:TUT3]WST(nolign-1)       &
&            [F:ROO]LABWST    = [M:TUT3]LABWST(nolign-1)    &
&            [F:ROO]SCOWST    = [M:TUT3]SCOWST(nolign-1)    &
&            [F:ROO]SCOITMREF = [M:TUT3]SCOITMREF(nolign-1) &
&            [F:ROO]BPRNUM    = [M:TUT3]BPRNUM(nolign-1)    &
&            [F:ROO]BPAADD    = [M:TUT3]BPAADD(nolign-1)    &
&            [F:ROO]REFPRI    = [M:TUT3]REFPRI(nolign-1)
             Goto NXTLIG
        Endif

        # Issue X3-60368 - 2017-10-19 by JUSYN - Put ITMREF (routing id) first for better overview
        # Modification de l'opération
        Call ECR_TRACE(mess(63,198,1)-[M:TUT3]ITMREF(nolign-1)+"/"+num$([M:TUT3]OPENUM(nolign-1) )+"/"+num$([M:TUT3]RPLIND(nolign-1)),0) From GESECRAN
        # End issue X3-60368

        Readlock [ROO]ROO0 = [M:TUT3]MFGFCY;[M:TUT3]ITMREF(nolign-1);[M:TUT3]ROUALT(nolign-1);[M:TUT3]OPENUM(nolign-1);[M:TUT3]RPLIND(nolign-1)
        If fstat
            GCLE = [M:TUT3]ITMREF(nolign-1)-num$([M:TUT3]ROUALT(nolign-1))-num$([M:TUT3]OPENUM(nolign-1))-num$([M:TUT3]RPLIND(nolign-1))
            GOK = 0 : Call RSTA("ROO",GCLE) From GLOCK : Break
        Endif

        [F:ROO]=[M:TUT3]

        # Issue 115901 - 2016-05-31 by GH : entry point added
        GPOINT = "UPDROO" : Gosub ENTREE From EXEFNC
        If GOK<1 : Break : Endif

        Rewrite [ROO]
        If fstat
            GOK = 0 : Call FSTA("ROO") From GLOCK : Break
        Endif
    Endif

    NBOPE += 1

$NXTLIG
Next nolign

If GOK<1
  Rollback
  # Abandon suite à erreur de transaction
  Call ECR_TRACE(mess(17,107,1), 1)From GESECRAN
Else
  Commit
Endif

If NBOPE
    Call ECR_TRACE(" ",0) From GESECRAN
    # Modification(s) en série effectuée(s)
    Call ECR_TRACE(num$(NBOPE)-mess(362,197,1),0) From GESECRAN
Elsif GOK=1
    # Aucune modification à traiter
    Call ECR_TRACE(mess(371,197,1), 0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN
Return


########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog AM_REPLACEFLG(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1:    [M:TUT0]APPDAT = [0/0/0]
               Grizo [TUT0]APPDAT
    When 2:    [M:TUT0]APPDAT = date$
               Actzo [TUT0]APPDAT
Endcase
End

########################################
Subprog C_APPDAT(VALEUR)
Variable Date    VALEUR
If VALEUR< date$ : VALEUR = date$ : Endif
End

########################################
Subprog C_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : End : Endif

Read [TRO]TRO0=VALEUR
If fstat : mkstat=2
Elsif [F:TRO]FCY <> "" & [F:TRO]FCY <> [M:TUT0]MFGFCY : mkstat = 2
Endif

End

########################################
Subprog AM_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ROUALTFIN = VALEUR : Endif
End

########################################
Subprog C_ROUALTFIN(VALEUR)
Variable Decimal VALEUR

If VALEUR < [M]ROUALTDEB : mkstat = 2 : GMESSAGE = mess(44,199,1) : End : Endif
If VALEUR = 0 : End : Endif

Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : Endif
If [F:TRO]FCY <> "" & [F:TRO]FCY <> [M:TUT0]MFGFCY : mkstat = 2 : Endif

End

########################################
Subprog AM_ROUNUMDEB(VALEUR)
Variable Char    VALEUR()

If [M]ROUNUMDEB = ""     : [M]ROUNUMFIN = VALEUR : Endif
If [M]ROUNUMFIN < VALEUR : [M]ROUNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_OPENUMDEB(VALEUR)
Variable Decimal VALEUR
If [M]OPENUMDEB = 0      : [M]OPENUMFIN = VALEUR : Endif
If [M]OPENUMFIN < VALEUR : [M]OPENUMFIN = VALEUR : Endif
End

########################################
Subprog C_OPENUMFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]OPENUMDEB : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]WSTDEB = ""     : [M]WSTFIN = VALEUR : Endif
If [M]WSTFIN < VALEUR : [M]WSTFIN = VALEUR : Endif
End

########################################
Subprog AM_LABWSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]LABWSTDEB = ""     : [M]LABWSTFIN = VALEUR : Endif
If [M]LABWSTFIN < VALEUR : [M]LABWSTFIN = VALEUR : Endif
End

########################################
Subprog AM_SCOCODDEB(VALEUR)
Variable Integer VALEUR
If [M]SCOCODDEB = 0      : [M]SCOCODFIN = VALEUR : Endif
If [M]SCOCODFIN < VALEUR : [M]SCOCODFIN = VALEUR : Endif
End

########################################
Subprog C_SCOCODFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]SCOCODDEB : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_SCOWSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]SCOWSTDEB = ""     : [M]SCOWSTFIN = VALEUR : Endif
If [M]SCOWSTFIN < VALEUR : [M]SCOWSTFIN = VALEUR : Endif
End

########################################
Subprog AM_SCOITMDEB(VALEUR)
Variable Char    VALEUR()
If [M]SCOITMDEB = ""     : [M]SCOITMFIN = VALEUR : Endif
If [M]SCOITMFIN < VALEUR : [M]SCOITMFIN = VALEUR : Endif
End

########################################
Subprog AM_FWST(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : [M:TUT2]WSTV="" : [M:TUT2]WSTDES ="" : Affzo [TUT2]WSTV, WSTDES : Grizo [TUT2]WSTV
             Actzo [TUT2]FSCOWST , FLABWST
             #If [M:TUT2]SCOWSTV = "" : Gosub GRISE_SST : Endif # GH 23/01/2014
             [M:TUT2]WTYPMO  = 0
    When 2 : Actzo [TUT2]WSTV
Endcase
End

$GRISE_SST
[M:TUT2]WSSTRAI = 0
Grizo [TUT2] 14 : Effzo [TUT2] 14
Return

########################################
Subprog C_WSTV(VALEUR)
Variable Char    VALEUR()

# contrôle existence
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
   If fstat
      # FGR 13/01/2010 : X3SUIVI60986 WOMWS
      #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
      Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
   Endif
Elsif [M:TUT2]FWST = 2
   # saisir un poste si case cochée
   mkstat= 2 : GMESSAGE = mess(1, 9009,1)
Endif
End

########################################
Subprog AM_WSTV(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
    If !fstat
#        [M:TUT2]WSTDES=[F:MWS]WSTDES
        #LECTURE du libellé traduisible
        Call LECTEXTRA([M:TUT2]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        Affzo [TUT2]WSTDES
    Endif
Else
    [M:TUT2]WSTDES=""
    Affzo [TUT2]WSTDES
Endif

If [F:MWS]WSTTYP <> 3
   Actzo [TUT2]FLABWST, FSCOWST
   #  main d'oeuvre
   [M:TUT2]WTYPMO = ([F:MWS]WSTTYP=2)

   #If [M:TUT2]SCOWSTV ="" : Gosub GRISE_SST : Endif : # GH 23/01/2014

Else
    # si poste principal de type = sous-traitance et qu'il existe déjà un poste ss-traitance,
    # le poste principal devient le poste de ss-traitance
    If [M:TUT2]FSCOWST<>1
        [M:TUT2]FSCOWST= 1 : [M:TUT2]SCOWSTV = "" : [M:TUT2]SCOWSTDES = "" : Grizo [TUT2]SCOWSTV
    Endif
    If  [M:TUT2]FLABWST<>1
        [M:TUT2]FLABWST= 1 : [M:TUT2]LABWSTV = "" : [M:TUT2]LABWSTDES = "" : Grizo [TUT2]LABWSTV
    Endif
    Grizo [TUT2]FLABWST, FSCOWST
    Actzo [TUT2]FSCOITMREF, FBPSNUM, FREFPRI
    [M:TUT2]WSSTRAI = 1
Endif
End

########################################
Subprog C_FLABWST(VALEUR)
Variable Integer VALEUR

# GH 23/01/2014 On peut avoir une opération avec un poste m-o en poste de charge principal et secondaire
# si type poste de charge principal= MO
#If [M:TUT2]WTYPMO=1 & VALEUR=2
#    VALEUR = 1
#    [M:TUT2]FLABWST = VALEUR : Affzo FLABWST
#    mkstat = 2 : GMESSAGE = mess(190,193,1) : End
#Endif

# GH 23/01/2014 On doit pouvoir modifier un poste m-o sans modifier le poste pricnipal d'une opération
# Saisie d'un poste m-o sans saisie préalable d'un poste de charge principal
#If [M:TUT2]WSTV="" & VALEUR=2
#   VALEUR =1
#   [M:TUT2]FLABWST = VALEUR : Affzo FLABWST
#   mkstat=2 : GMESSAGE = mess(189,193,1) : End
#Endif
End

########################################
Subprog AM_FLABWST(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : [M:TUT2]LABWSTV = "": [M:TUT2]LABWSTDES= ""
             Affzo [TUT2]LABWSTV , LABWSTDES :  Grizo [TUT2]LABWSTV
    When 2 : Actzo [TUT2]LABWSTV
Endcase
End

########################################
Subprog C_LABWSTV(VALEUR)
Variable Char    VALEUR()

# contrôle existence
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
If fstat
   # FGR 13/01/2010 : X3SUIVI60986 WOMWS
   #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
   Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
Elsif [F:MWS]WSTTYP <> 2
   GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2
Endif
End

########################################
Subprog AM_LABWSTV(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
    If !fstat
#        [M:TUT2]LABWSTDES=[F:MWS]WSTDES
        Call LECTEXTRA([M:TUT2]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        Affzo [TUT2]LABWSTDES
    Endif
Else
    [M:TUT2]LABWSTDES=""
    Affzo [TUT2]LABWSTDES
Endif
End

########################################
Subprog AM_FSCOWST(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : [M:TUT2]SCOWSTV="" : [M:TUT2]SCOWSTDES="" : Affzo  [TUT2]SCOWSTV, SCOWSTDES
             Grizo [TUT2]SCOWSTV
             #Gosub GRISE_SST : # GH 23/01/2014
    When 2 : Actzo [TUT2]SCOWSTV
Endcase
End

########################################
Subprog C_SCOWSTV(VALEUR)
Variable Char    VALEUR()
# contrôle existence
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
If fstat
   # FGR 13/01/2010 : X3SUIVI60986 WOMWS
   #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
   Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
Elsif [F:MWS]WSTTYP <> 3
   GMESSAGE=VALEUR - mess(3,193,1) : mkstat=2
Endif
End

########################################
Subprog AM_SCOWSTV(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
    If !fstat
#        [M:TUT2]SCOWSTDES=[F:MWS]WSTDES
        Call LECTEXTRA([M:TUT2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        Affzo [TUT2]SCOWSTDES
    Endif
    Actzo [TUT2]FSCOITMREF : Actzo [TUT2]FBPSNUM : Actzo [TUT2]FREFPRI
    [M:TUT2]WSSTRAI = 1
Else
    [M:TUT2]SCOWSTDES="" : Affzo [TUT2]SCOWSTDES
    #Gosub GRISE_SST : # GH 23/01/2014
Endif
End

########################################
Subprog AM_FSCOITMREF(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Grizo [TUT2]SCOITMREFV
             If [M:TUT2]SCOITMREFV<>""
                VALEUR =1 : [M:TUT2]FSCOITMREF=VALEUR  :[M:TUT2]SCOITMREFV=""
                Affzo SCOITMREFV
             Endif
    When 2 : Actzo [TUT2]SCOITMREFV
Endcase
End

########################################
Subprog AV_SCOITMREFV(VALEUR)
Variable Char    VALEUR()

## GH 23/10/2014 On doit pouvoir modifier l'article SST sans modifier le poste principal ou le poste SST
# réinitialisation dans la cas où on supprime le poste de sous-traitance
#If [M:TUT2]WSSTRAI=0
#    Grizo SCOITMREFV : [M]FSCOITMREF = 1 : Affzo FSCOITMREF
#    If VALEUR  <>""
#        VALEUR = "" : [M]SCOITMREFV = VALEUR
#    Endif
#Endif
End

########################################
Subprog C_SCOITMREFV(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:TUT2]FSCOITMREF=2
   mkstat= 2 : GMESSAGE = mess(1,9009,1)
Endif
End

########################################
Subprog AM_FBPSNUM(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Grizo [TUT2]BPSNUMV : Grizo [TUT2]BPAADDV
             If [M:TUT2]BPSNUMV<>""
                VALEUR = 1 : [M:TUT2]FBPSNUM = VALEUR : [M:TUT2]BPSNUMV ="" : [M:TUT2]BPAADDV =""
                Affzo BPSNUMV : Affzo BPAADDV
             Endif
    When 2 : Actzo [TUT2]BPSNUMV
             Actzo [TUT2]BPAADDV
Endcase
[M:TUT2]FBPAADD=VALEUR : Affzo [TUT2]FBPAADD
End

########################################
Subprog AV_BPSNUMV(VALEUR)
Variable Char    VALEUR()

## GH 23/10/2014 On doit pouvoir modifier le fournisseur sans modifier le poste principal ou le poste SST
# réinitialisation dans la cas où on supprime le poste de sous-traitance
#If [M:TUT2]WSSTRAI=0
#    Grizo BPSNUMV : [M]FBPSNUM = 1 : Affzo FBPSNUM
#    If VALEUR  <>""
#        VALEUR = "" : [M]BPSNUMV = VALEUR
#    Endif
#Endif
End

########################################
Subprog C_BPSNUMV(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:TUT2]FBPSNUM=2
    mkstat= 2 : GMESSAGE = mess(1, 9009,1) : End
Endif
GBPCNUM = VALEUR
End

########################################
Subprog AV_BPAADDV(VALEUR)
Variable Char    VALEUR()

## GH 23/10/2014
# réinitialisation dans la cas où on supprime le poste de sous-traitance
#If [M:TUT2]WSSTRAI=0
#    Grizo BPAADDV : [M]FBPAADD = 1 : Affzo FBPAADD
#    If VALEUR  <>""
#        VALEUR = "" : [M]BPAADDV = VALEUR
#    Endif
#Endif
End

########################################
Subprog AM_FREFPRI(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Grizo [TUT2]REFPRIV
             If [M:TUT2]REFPRIV<>0
                 VALEUR = 1 : [M:TUT2]FREFPRI=VALEUR : [M:TUT2]REFPRIV=0
                 Affzo REFPRIV
             Endif
    When 2 : Actzo [TUT2]REFPRIV
Endcase
End

########################################
Subprog AV_REFPRIV(VALEUR)
Variable Decimal VALEUR

## GH 23/10/2014 On doit pouvoir modifier le prix réference sans modifier le poste principal ou le poste SST
# réinitialisation dans la cas où on supprime le poste de sous-traitance
#If [M:TUT2]WSSTRAI=0
#    Grizo REFPRIV : [M]FREFPRI = 1 : Affzo FREFPRI
#    If VALEUR  <>0
#        VALEUR = 0 : [M]REFPRIV = VALEUR
#    Endif
#Endif
End

########################################
Subprog C_REFPRIV(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M:TUT2]FREFPRI=2
    mkstat= 2 : GMESSAGE = mess(1,9009,1) : # Variable à saisir
Endif
End

########################################
Subprog AV_WST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste de charge principal
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
   [M]WCR(nolign-1)=[F:MWS]WCR : [M]WSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

########################################
Subprog C_WST(VALEUR)
Variable Char    VALEUR()
# contrôle existence
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
   If fstat
      # FGR 13/01/2010 : X3SUIVI60986 WOMWS
      #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
      Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
   Endif
Else
   # poste de charge obligatoire
   GERR = 1 : GMESSAGE = mess(10,123,1)
   mkstat = 2
Endif
End

########################################
Subprog AP_WST(VALEUR)
Variable Char    VALEUR()
# affichage du centre choisi en retour de la consultation des postes
If VALEUR ="" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
   [M]WCR(nolign-1)=[F:MWS]WCR
Endif
End

########################################
Subprog AM_WST(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif

Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
        [M]WCR(nolign-1)=[F:MWS]WCR : [M]WSTTYP(nolign-1)=[F:MWS]WSTTYP
        [M]WSTNBR(nolign-1) = [F:MWS]WSTNBR
        If GWSTEFFINH<>1
           [M]EFF(nolign-1) = [F:MWS]EFF
        Endif
        [M]SHR(nolign-1) = [F:MWS]SHR
        Affzo WCR(nolign-1)
        Affzo WSTTYP(nolign-1)
        Affzo EFF(nolign-1)
        Affzo SHR(nolign-1)
        Affzo WSTNBR(nolign-1)
        If [F:MWS]WSTTYP <> 1
            [M]LABWCR(nolign-1)="" : [M]LABWST(nolign-1)="" : [M]LABNBR(nolign-1)=0
            [M]LABWSTTYP(nolign-1)=0
            Affzo [TUT3] LABWCR(nolign-1), LABWST(nolign-1), LABNBR(nolign-1), LABWSTTYP(nolign-1)
        Endif
    # ss-trait. structurelle
        If [F:MWS]WSTTYP=3
            [M]WSTNBR(nolign-1) = 1
            [M]SCOWST(nolign-1) = VALEUR
            [M]SCOCOD(nolign-1) = 2
            Affzo [TUT3] WSTNBR(nolign-1),SCOWST(nolign-1),SCOCOD(nolign-1)
    # ss-trait. conjoncturelle
        Elsif [M]SCOCOD(nolign-1)=2
            [M]SCOCOD(nolign-1)=3 :  Affzo [TUT3]SCOCOD(nolign-1)
        Endif
Endif
End

########################################
Subprog IB_WST
GBOUT1=mess(29,198,1) : # nom bouton tunnel sur postes de charge
End

########################################
Subprog B1_WST(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY)
WFCY = [M]MFGFCY
Call OBJET("MWS",WFCY,VALEUR) From GOBJET
If [F:MWS]WST <> "" & [F:MWS]WCRFCY = [M]MFGFCY
    VALEUR = [F:MWS]WST
Endif
End

########################################
Subprog AV_LABWST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste main-d'oeuvre
If [M]WSTTYP(nolign-1)=3
    VALEUR="" : [M]LABWCR(nolign-1)="" : [M]LABWSTTYP(nolign-1)=0
Endif
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
    [M]LABWCR(nolign-1)=[F:MWS]WCR : [M]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

########################################
Subprog AS_LABWST(VALEUR)
Variable Char    VALEUR()

If [M]WSTTYP(nolign-1)=3
   mkstat = 2
Endif
End

########################################
Subprog C_LABWST(VALEUR)
Variable Char    VALEUR()

# contrôle existence
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
If fstat
  # FGR 13/01/2010 : X3SUIVI60986 WOMWS
  #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
  Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
Elsif [F:MWS]WSTTYP <> 2
  GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2
Endif
End

########################################
Subprog AP_LABWST(VALEUR)
Variable Char    VALEUR()

# affichage du centre choisi en retour de la consultation des postes
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
   If !fstat
       [M:TUT3]LABWCR(nolign-1)=[F:MWS]WCR
       Affzo [TUT3]LABWCR(nolign-1)
   Endif
Else
   [M:TUT3]SETLABCOE(nolign-1)=0 : [M:TUT3]OPELABCOE(nolign-1)=0
   Affzo [TUT3]SETLABCOE(nolign-1), OPELABCOE(nolign-1)
Endif

End

########################################
Subprog AM_LABWST(VALEUR)
Variable Char    VALEUR()

# GH 23/01/2014 On peut avoir une opération avec un poste m-o en poste de charge principal et secondaire
# Pas de poste m-o en cas de ss-traitance structurelle ou de poste de charge de type m-o
#If [M]WSTTYP(nolign-1)<>1
#    VALEUR="" : [M]LABWCR(nolign-1)=""
#    Affzo LABWCR(nolign-1)
#    End
#Endif

# affichage des zones liées au poste main-d'oeuvre
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
    If !fstat
        [M]LABWST(nolign-1)= VALEUR  : [M]LABWCR(nolign-1)=[F:MWS]WCR
        [M]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP : [M]LABNBR(nolign-1)=[F:MWS]WSTNBR
        If [M]SETLABCOE(nolign-1)=0 : [M]SETLABCOE(nolign-1)=1 : Endif
        If [M]OPELABCOE(nolign-1)=0 : [M]OPELABCOE(nolign-1)=1 : Endif
        Affzo [TUT3]LABWCR(nolign-1), LABNBR(nolign-1), SETLABCOE(nolign-1), OPELABCOE(nolign-1)
    Endif
Else
    # suppression du poste m-o
    [M]LABWST(nolign-1)= VALEUR
    [M]LABWCR(nolign-1)="" : [M]LABWSTTYP(nolign-1)=0 : [M]LABNBR(nolign-1)=0
    Affzo [TUT3]LABWCR(nolign-1), LABNBR(nolign-1)
Endif
End

########################################
Subprog IB_LABWST
GBOUT1=mess(29,198,1) : # nom bouton tunnel sur postes de charge
End

########################################
Subprog B1_LABWST(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY)
WFCY = [M]MFGFCY
Call OBJET("MWS",WFCY,VALEUR) From GOBJET
If [F:MWS]WST <> "" & [F:MWS]WCRFCY = [M]MFGFCY
    VALEUR = [F:MWS]WST
Endif
End

########################################
Subprog AV_SETLABCOE(VALEUR)
Variable Decimal VALEUR
If [M]LABWST(nolign-1)="" : VALEUR=0 : Endif
End

########################################
Subprog AV_OPELABCOE(VALEUR)
Variable Decimal VALEUR
If [M]LABWST(nolign-1)="" : VALEUR=0 : Endif
End

########################################
Subprog AV_SCOWST(VALEUR)
Variable Char    VALEUR()

# affichage des zones liées au poste de sous-traitance
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M]MFGFCY
If !fstat
    [M]SCOWCR(nolign-1)=[F:MWS]WCR : [M]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
Endif
End

########################################
Subprog AS_SCOWST(VALEUR)
Variable Char    VALEUR()
# code sous-traitance non saisissable si type poste principal=sous-traitance
If [M]WSTTYP(nolign-1)=3 : mkstat=2 : Endif
End

#####################################
Subprog C_SCOWST(VALEUR)
Variable Char     VALEUR
# contrôle existence et type poste sous-traitance
If VALEUR = "" : End : Endif
Read [MWS]WST0=VALEUR;[M:TUT0]MFGFCY
If fstat
  # FGR 13/01/2010 : X3SUIVI60986 WOMWS
  #Gosub TIT From GESMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
  Gosub TIT From WOMWS : GMESSAGE=TIT-":"-VALEUR+"\"+mess(133,193,1) : mkstat=2
Elsif [F:MWS]WSTTYP <> 3
  GMESSAGE=VALEUR - mess(3,193,1) : mkstat=2
Endif
End

########################################
Subprog AM_SCOWST(VALEUR)
Variable Char    VALEUR()

# affichage des zones liées au poste de sous-traitance
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M]MFGFCY
    If !fstat
        [M:TUT3]SCOWCR(nolign-1)= [F:MWS]WCR : [M:TUT3]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
        [M:TUT3]SCOCOD(nolign-1)=3
        Affzo [TUT3]SCOCOD(nolign-1), SCOWCR(nolign-1)
    Endif
Else
# suppression des zones liées au poste de sous-traitance
   [M]SCOWCR(nolign-1)=""
   [M]SCOWSTTYP(nolign-1) = 0
   [M]SCOCOD(nolign-1) = 1
   [M]SCOITMREF(nolign-1) = ""
   [M]BPRNUM(nolign-1) =""
   [M]BPAADD(nolign-1) =""
   [M]REFPRI(nolign-1) =0
   Affzo SCOWCR(nolign-1), SCOCOD(nolign-1), SCOITMREF(nolign-1), BPRNUM(nolign-1), BPAADD(nolign-1), REFPRI(nolign-1)
Endif
End

########################################
Subprog C_SCOITMREF(VALEUR)
Variable Char    VALEUR()

If [M]SCOWSTTYP(nolign-1)=3 & VALEUR =""
   mkstat=2 : GMESSAGE = mess(152,190,1) : # Saisie d'un article obligatoire
Endif
End

########################################
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()
If [M]BPRNUM(nolign-1)="" : mkstat=1
Else GBPCNUM = [M]BPRNUM(nolign-1)
Endif
End

# Issue X3-60368 - 2017-10-19 by JUSYN : Trace versioned route log file - Log file writing; put ITMREF first for better overview
########################################
$CHARG_LOG

Call ECR_TRACE(mess(63,198,1)-[F:ROO]ITMREF+"/"+num$([F:ROO]OPENUM)+"/"+num$([F:ROO]RPLIND)-mess(421,193,1),0) From GESECRAN

Return
# End issue X3-60368

