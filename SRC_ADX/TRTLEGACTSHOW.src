#<AdxTL>@(#)0.0.0.0 $Revision$

Call MANAGE_LOCALISATION_SHOW("OHRENT")

End

Subprog MANAGE_LOCALISATION_SHOW(THIS_WINDOW)
Value Char THIS_WINDOW()

Call DISPLAY_FIELDS_AUTO(THIS_WINDOW)

End



Funprog GENERATE_FILES(FEN)
Value Char FEN


If !clalev([F:WAELT]) : Local File AELT [WAELT] : Endif
If !clalev([F:AWIZZ]) : Local File AWINDOW [AWIZZ]     : Endif
Local Integer RES : RES=1

Local Char NAMFIL(250),NAMFILADX(250)
Local Char WLIN(250)
Local Integer W_POS,WI
Local Char W_MSK(30)
Local Char W_TIMSTP_SH(30),W_TIMSTP(30)


NAMFIL=filpath("TRT","W"+FEN+"SHOW","src",nomap)
NAMFILADX=filpath("TRT","W"+FEN+"SHOW","adx",nomap)

If filinfo(NAMFIL,0)>0 & filinfo(NAMFILADX,0)>0
  fstat=0
  Openi NAMFIL Using [XML_]
  If ! fstat
    Iomode adxifs ""  Using [XML_]
    Iomode adxirs chr$(10)  Using [XML_]
    Iomode adxium GUTF8  Using [XML_]
    Rdseq WLIN Using [XML_]
    While fstat=0
      Rdseq WLIN Using [XML_]
      W_POS=instr(1,WLIN,'timestamp')
      If W_POS
         W_TIMSTP_SH=vireblc(right$(WLIN,instr(1,WLIN,":")+1),4)
        Break 1
      Endif
    Wend
    Openi Using [XML_]
    If  W_TIMSTP_SH<>""
      For [F:WAELT]ELT0(3) Where  ELTTYP="FENW" and ELT=[L]FEN
        If W_TIMSTP_SH< [F:WAELT]ELTSTP
          W_TIMSTP=[F:WAELT]ELTSTP
          Break
        Endif
      Next
      If W_TIMSTP_SH>=W_TIMSTP
        # need to check screen..
        Read [F:AWIZZ]AWI0 = [L]FEN
        If!fstat
          If [F:AWIZZ]MSKENT<>""
            [L]W_MSK=[F:AWIZZ]MSKENT
            Gosub CHECK_MSK
          Endif
          If W_TIMSTP_SH>=W_TIMSTP
            For WI=0 To dim([F:AWIZZ]MSKNOM)-1
              If [F:AWIZZ]MSKNOM(WI)<>""
                [L]W_MSK=[F:AWIZZ]MSKNOM(WI)
                Gosub CHECK_MSK
              Endif
              If W_TIMSTP_SH<W_TIMSTP : Break : Endif
            Next
          Endif
        Endif
      Endif
      If W_TIMSTP_SH>=W_TIMSTP
        RES=0
      Endif
    Endif
  Endif
Endif

End RES

$CHECK_MSK
  Read [F:WAELT]ELT0="SCRN";[L]W_MSK;"ALL"
  If !fstat
   If  W_TIMSTP_SH< [F:WAELT]ELTSTP
    W_TIMSTP=[F:WAELT]ELTSTP
   Endif
  Endif
Return

#########################################################################################

Subprog DISPLAY_FIELDS_AUTO(THIS_WINDOW)
Value Char THIS_WINDOW()
Local Char THIS_SCREEN(12)
Local Char THIS_ACT(GLONACV)
Local Char DATA_TYPE(GLONATY)
Local Decimal TYP_LEN()
Local Integer INT_TYP()
Local Decimal SCR_LEN()
Local Char ADO_TYP(50)
Local Shortint LOM_NUM()
Local Char THIS_SCREENABR(GLONABR)
Local Integer FIRSTCHAR
Local Integer LOOPNUMBER
Local Integer CALLCOUNTER
Local Char BLOCACTARRAY(GLONACV)(1..)
Local Integer BLOC_NUM()
Local Char THIS_FIELD(GLONAVA+4)
Local Char THIS_SCREENACTCOD(GLONACV)
#MIPEA - 2016-11-02 - REQ 114309 - START
Local Integer BLOCTYPARRAY(1..)
Local Integer BLOC_TYPE
Local Integer FIELD_DIM
#MIPEA - 2016-11-02 - REQ 114309 - END

# SBA specific format
Local Char SCR_OPT(30)
Local Char SCR_FMT(30)
Local Char OPT_TYP(50)

If !clalev([F:ACVZZ])  : Local File ACTIV [ACVZZ]      : Endif     #First Instance
If !clalev([F:ACVZZ3]) : Local File ACTIV [ACVZZ3]     : Endif     #Third Instance
#JASMI - 2016-06-06 - REQ 114309 - START
#If !clalev([F:ACVZZ4]) : Local File ACTIV [ACVZZ4]     : Endif     #Fourth Instance
#JASMI - 2016-06-06 - REQ 114309 - END
If !clalev([F:ADIZZ])  : Local File ATABDIV [ADIZZ]    : Endif
If !clalev([F:AMZZZ])  : Local File AMSKZON [AMZZZ]    : Endif
If !clalev([F:AMKZZ])  : Local File AMSK [AMKZZ]       : Endif
If !clalev([F:ADATYP]) : Local File ATYPE [ADATYP]     : Endif
#JASMI - 2016-06-06 - REQ 114309 - START
#If !clalev([F:ADIZZ])  : Local File ATABDIV [ADIZZ]    : Endif
If !clalev([F:AWIZZ]) : Local File AWINDOW [AWIZZ]     : Endif
If !clalev([F:ACVZZ2]) : Local File ACTIV [ACVZZ2]    : Endif     #Second Instance
#JASMI - 2018-02-23 - X3-78230 - START
If !clalev([F:ACVZZ3]) : Local File ACTIV [ACVZZ3]    : Endif     #Second Instance
If !clalev([F:ACVZZ4]) : Local File ACTIV [ACVZZ4]    : Endif     #Second Instance
If !clalev([F:ACVZZ5]) : Local File ACTIV [ACVZZ5]    : Endif     #Second Instance
#JASMI - 2018-02-23 - X3-78230 - END

Filter [F:ADIZZ]
Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB  = 10302

Filter [F:ACVZZ2]
Filter [F:ACVZZ2] Where [F:ACVZZ2]FLACT=2 & [F:ACVZZ2]DEP=4

Read [F:AWIZZ]AWI0 = THIS_WINDOW
If fstat : Return : Endif
#JASMI - 2016-06-06 - REQ 114309 - END

#POPULATE SUBPROGS FOR ALL LOCALISATION ACTIVITY CODES
#write call subprog with activity code calls per Legislation
LOOPNUMBER=1
Gosub CREATE_SHOW_SCRIPT
Wrseq ''
Wrseq "End"

#JASMI - 2016-06-06 - REQ 114309 - START
#For [F:ACVZZ] Where [F:ACVZZ]FLACT=2
Filter [F:ACVZZ]
Filter [F:ACVZZ] Where [F:ACVZZ]FLACT=2 &
&                   ((left$([F:ACVZZ]CODACT,1)="K"|left$([F:ACVZZ]CODACT,2)="FK") | [F:ACVZZ]DEP=4)
For [F:ACVZZ]
#JASMI - 2016-06-06 - REQ 114309 - END
LOOPNUMBER=2
#JASMI - 2016-06-06 - REQ 114309 - START
#  If (left$([F:ACVZZ]CODACT,1)="K"|left$([F:ACVZZ]CODACT,2)="FK") | [F:ACVZZ]DEP=4
  If 1=1
#JASMI - 2016-06-06 - REQ 114309 - END
    #write heading for call subprog for activity codes that are active
    Gosub CREATE_SHOW_SCRIPT

#JASMI - 2016-06-06 - REQ 114309 - START
#    Read [F:AWIZZ]AWI0 = THIS_WINDOW
#
#    If !fstat
#JASMI - 2016-06-06 - REQ 114309 - END
      #Checking header screens
      If [F:AWIZZ]MSKENT<>""
        #fields
        THIS_SCREEN=[F:AWIZZ]MSKENT
        Gosub CHECK_FIELDS_FOR_SCREEN
      Endif

      #Checking tab screens
      For I = 0 To [F:AWIZZ]NBMSK-1
        #fields
        THIS_SCREEN=[F:AWIZZ]NOMMSK(I)
        Gosub CHECK_FIELDS_FOR_SCREEN
      Next
      Endif
    Wrseq ''
    Wrseq "End"
#JASMI - 2016-06-06 - REQ 114309 - START
#  Endif
#JASMI - 2016-06-06 - REQ 114309 - END
Next

#close file
Openo
If GOK<>0
  Gosub COMPILE_SHOW_SCRIPT
Endif

End

#########################################################################################

$CHECK_FIELDS_FOR_SCREEN

GOK=1
#JASMI - 2016-06-06 - REQ 114309 - START
#Filter [F:AMZZZ]
#Filter [F:AMKZZ]
#Filter [F:AMKZZ] Where [F:AMKZZ]CODMSK  = THIS_SCREEN
#Filter [F:ADIZZ]
#Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB  = 10302
#Read [F:AMKZZ]First
If [F:AMKZZ]CODMSK <> THIS_SCREEN
  Filter [F:AMKZZ]
  Filter [F:AMKZZ] Where [F:AMKZZ]CODMSK  = THIS_SCREEN
  Read [F:AMKZZ]First
Endif
#JASMI - 2016-06-06 - REQ 114309 - END
THIS_SCREENABR=[F:AMKZZ]ABRMSK
THIS_SCREENACTCOD=[F:AMKZZ]CODACT

Raz BLOCACTARRAY

#CREATING BLOCK ACTIVITY CODE ARRAY
For X = 0 To [F:AMKZZ]NBBLOC-1
  BLOCACTARRAY(X+1)=[F:AMKZZ]ACTBLOC(X)
#MIPEA - 2016-11-02 - REQ 114309 - START
  BLOCTYPARRAY(X+1)=[F:AMKZZ]TYPBLOC(X)
  #MIPEA - 2016-11-02 - REQ 114309 - END
Next

#########################################################################################

#write call subprog with activity code instructions
#JASMI - 2016-06-06 - REQ 114309 - START
#For [AMZZZ] Where CODMSK = THIS_SCREEN
If [AMZZZ]CODMSK <> THIS_SCREEN
  Filter [AMZZZ]
  Filter [AMZZZ] Where [AMZZZ]CODMSK = THIS_SCREEN
Endif
 For [AMZZZ]
#JASMI - 2016-06-06 - REQ 114309 - END

  LOOPNUMBER=3
  DATA_TYPE =[F:AMZZZ]CODTYP
  SCR_LEN =[F:AMZZZ]LONG
  LOM_NUM =[F:AMZZZ]NOLIB
  BLOC_NUM =[F:AMZZZ]NUMBLOC
#MIPEA - 2016-11-02 - REQ 114309 - START
  #THIS_FIELD=[F:AMZZZ]CODZON
  FIELD_DIM=[F:AMZZZ]DIME
#MIPEA - 2016-11-02 - REQ 114309 - END
  # SBA specific format or option if $ take SCR_FMT
  SCR_OPT = [F:AMZZZ]OPTSAI
  SCR_FMT = [F:AMZZZ]OPTFOR


  If [F:AMZZZ]CODACT<>"" THIS_ACT=[F:AMZZZ]CODACT : Endif
  If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM)<>"" THIS_ACT=BLOCACTARRAY(BLOC_NUM) : Endif
  If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM) ="" THIS_ACT=THIS_SCREENACTCOD      : Endif
#MIPEA - 2016-11-02 - REQ 114309 - START
  BLOC_TYPE = BLOCTYPARRAY(BLOC_NUM)
#MIPEA - 2016-11-02 - REQ 114309 - END
  If THIS_ACT<>""
    Read [F:ACVZZ3]CODACT = THIS_ACT
    If [F:ACVZZ3]FLACT=2
      If THIS_ACT=[F:ACVZZ]CODACT
        Read [F:ADATYP]CODTYP = DATA_TYPE
        INT_TYP=[F:ADATYP]TYPTYP
        TYP_LEN =[F:ADATYP]LNGTYP
        ADO_TYP =[F:ADATYP]FORTYP
        OPT_TYP= [F:ADATYP]OPTION

#MIPEA - 2016-11-02 - REQ 114309 - START
        If BLOC_TYPE <> 1 & FIELD_DIM > 1
          For BT = 0 To FIELD_DIM-1
            THIS_FIELD = [F:AMZZZ]CODZON+"("+num$(BT)+")"
            Gosub CREATE_SHOW_SCRIPT
          Next
        Else
          THIS_FIELD=[F:AMZZZ]CODZON
          Gosub CREATE_SHOW_SCRIPT
        Endif
          #Gosub CREATE_SHOW_SCRIPT
#MIPEA - 2016-11-02 - REQ 114309 - END
      Else
      Endif
     Endif
  Endif

Next

Return

#########################################################################################

$CREATE_SHOW_SCRIPT
Local Char RET_ACTCODE(GLONACV)(1..)
Local Char SEND_ACTCODE(GLONACV)(1..)
Local Char COMBINED_ACTCODE(GLONACV)(1..)
Local Integer ISFOUND()
Local Char MISCACT(5)
Local Char MISCLEG(GLONADI)
Local Char W_TIMESTAMP(20)

# calculate time stamp to compare later with win json
Call ENVVAR(W_TIMESTAMP)From INTRUTILA


CALLCOUNTER+=1
If CALLCOUNTER=1 & LOOPNUMBER=1
#get filename
  SCRISRC = filpath("TRT","W"+THIS_WINDOW+"SHOW","src",nomap)

#open source file
  Openo SCRISRC,0
  adxifs = ""
  adxirs = chr$(10)

#write creation details
# SBA : need to do
# $generationDate we have the same name in the json description folder X3_PUB\CUR_FOLDER\GEN\ALL\WINDJ on the serveur.
If GUSER="SBA1"
 Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# Date :'-format$("DD4",date$)
  Wrseq '# $timestamp :'-W_TIMESTAMP
  Wrseq ''
  Wrseq "Subprog HIDE_ACTIVITYFIELDS()"
  Wrseq ''
  Wrseq 'Local Char W_SIGN(1) :  W_SIGN="-"'
  Wrseq 'Local Char SAV_LEG(GLONADI) :  SAV_LEG=GCURLEG'
  Wrseq 'GCURLEG=""'
  Wrseq ''
  Wrseq 'Call SHOW_LEGACTCALLS(W_SIGN)'
   Wrseq 'GCURLEG=SAV_LEG'
  Wrseq 'End'
  Wrseq ''
  Wrseq ''
  Wrseq "Subprog SHOW_LEGACTCALLS(SIGN)"
  Wrseq 'Value Char SIGN()'
  Wrseq 'Local Char W_SIGN(1)   : W_SIGN=SIGN '
  Wrseq ''

Else

  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# timestamp :'-W_TIMESTAMP
  Wrseq ''
  Wrseq "Subprog SHOW_LEGACTCALLS"
  Wrseq ''

Endif
#Writing the call instructions per legislation
#JASMI - 2016-06-06 - REQ 114309 - START
#If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif
#Filter [F:ADIZZ]
#Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB  = 10302
#JASMI - 2016-06-06 - REQ 114309 - END

For [F:ADIZZ]

  ISFOUND=1
  MISCLEG=[F:ADIZZ]CODE
  MISCACT=[F:ADIZZ]A1

  Raz COMBINED_ACTCODE

  SEND_ACTCODE(1)=MISCACT
#JASMI - 2018-02-23 - X3-78230 - START
#  COMBINED_ACTCODE(1)=MISCACT
  Z=0
#JASMI - 2018-02-23 - X3-78230 - END

  While ISFOUND=1
#JASMI - 2018-02-23 - X3-78230 - START
#    Z=1
#JASMI - 2018-02-23 - X3-78230 - END
    Gosub FINDALL_ACTCODES

      If ISFOUND=1
        For Y =1 To maxtab(RET_ACTCODE)

          Z+=1
          COMBINED_ACTCODE(Z)=RET_ACTCODE(Y)
          Raz SEND_ACTCODE
          SEND_ACTCODE=RET_ACTCODE
        Next
      Endif
  Wend

#JASMI - 2018-02-23 - X3-78230 - START
  Z+=1
  COMBINED_ACTCODE(Z)=MISCACT
#JASMI - 2018-02-23 - X3-78230 - END

  Wrseq "If GCURLEG ='"+MISCLEG+"' | GCURLEG=''"

  For X = 1 To maxtab(COMBINED_ACTCODE)

#JASMI - 2016-06-06 - REQ 114309 - START
#    Read [F:ACVZZ4]CODACT=COMBINED_ACTCODE(X)
#    If [F:ACVZZ4]FLACT=2
    Read [F:ACVZZ3]CODACT=COMBINED_ACTCODE(X)
    If [F:ACVZZ3]FLACT=2
#JASMI - 2016-06-06 - REQ 114309 - END
        If GUSER="SBA1"
           Wrseq " Call Show_"+COMBINED_ACTCODE(X)+"(W_SIGN)"
        Else
          Wrseq " Call Show_"+COMBINED_ACTCODE(X)
        Endif
      Else

    Endif

  Next

  Wrseq "Endif"
  Wrseq ''
Next
Endif

#########################################################################################

If LOOPNUMBER=2
#write heading for each subprog per activity code
  If GUSER="SBA1"
    Wrseq ''
    Wrseq "Subprog Show_"+[F:ACVZZ]CODACT+"(SIGN)"
    Wrseq "Value Char SIGN()"
    Wrseq ''
  Else
    Wrseq ''
    Wrseq "Subprog Show_"+[F:ACVZZ]CODACT+"()"
    Wrseq ''

Endif
Endif

If LOOPNUMBER=3
#write write change formats to show fields for each activity code
If GUSER="SBA1"
Case INT_TYP
  When 1
   #"LA" (Local MENU)
   LAVAL = "LA:"+num$(LOM_NUM)
   Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+ "+"'"+LAVAL+"'"
  When 2,3,4,5,6
   #"NZ" (Number)
   If SCR_LEN<>0
   NZVAL="Nz:"+num$(SCR_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+NZVAL+"'"
   Endif
   If SCR_LEN=0 & TYP_LEN<>0
   NZVAL="Nz:"+num$(TYP_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+NZVAL+"'"
   Endif
   If SCR_LEN=0 & TYP_LEN=0
   NZVAL="Nz:"+ADO_TYP
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+NZVAL+"'"
   Endif
  When 7
   #"K" (ALPHA)
   If SCR_LEN<>0
   KVAL="K:"+num$(SCR_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+KVAL+"'"
     Else
   KVAL="K:"+num$(TYP_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+KVAL+"'"
   Endif
  When 8, 12
   #"D" (Date)
   DVAL="D:"+GFMDAT4
    Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+DVAL+"'"
#JASMI - 2016-11-02 - START
  When 10
    #CLOB
    Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With SIGN+"+"'"+DATA_TYPE+"'"
#JASMI - 2016-11-02 - END
Endcase

Else
Case INT_TYP
  When 1
   #"LA" (Local MENU)
   LAVAL = "LA:"+num$(LOM_NUM)
   Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+LAVAL+"'"
  When 2,3,4,5,6
   #"NZ" (Number)
   If SCR_LEN<>0
   NZVAL="Nz:"+num$(SCR_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+NZVAL+"'"
   Endif
   If SCR_LEN=0 & TYP_LEN<>0
   NZVAL="Nz:"+num$(TYP_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+NZVAL+"'"
   Endif
   If SCR_LEN=0 & TYP_LEN=0
   NZVAL="Nz:"+ADO_TYP
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+NZVAL+"'"
   Endif
  When 7
   #"K" (ALPHA)
   If SCR_LEN<>0
   KVAL="K:"+num$(SCR_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+KVAL+"'"
     Else
   KVAL="K:"+num$(TYP_LEN)
     Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+KVAL+"'"
   Endif
  When 8, 12
   #"D" (Date)
   DVAL="D:"+GFMDAT4
    Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+DVAL+"'"
#JASMI - 2016-11-02 - START
  When 10
    #CLOB
    Wrseq "Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+" With "+"'"+DATA_TYPE+"'"
#JASMI - 2016-11-02 - END
Endcase
Endif
 #LIPET - 2017-05-29 - X3-41741 - START
 Wrseq "Affzo [M:"+THIS_SCREENABR+"]"+THIS_FIELD
 #LIPET - 2017-05-29 - X3-41741 - END
Endif

Return

#SBA :  see VALMSKSUB for format
Funprog GETFMT_DAT(SCR_OPT,SCR_FMT,TYP_OPT)
Value  Char SCR_OPT(),SCR_FMT(),TYP_OPT()

Local Char RES(30)
Local Char WOPT(30),WRES_OPT(30)
Local Integer WOPT_NUM

If SCR_OPT <>"" and SCR_OPT="$"
  If !instr(0,SCR_FMT,":")
    RES='D:'+SCR_FMT
  Else
    RES=SCR_FMT
  Endif
Else
  WOPT=vireblc(SCR_OPT+TYP_OPT,4)
  For WI=0 To len(WOPT)-1
    If val(mid$(WOPT,WI,1))<>0
      WOPT_NUM=val(mid$(WOPT,WI,1))
      Break
    Endif
  Next
  If instr(1,WOPT,"z") : WRES_OPT += "z" : Endif       : # Commentaires non affichés
  If instr(1,WOPT,"Z") : WRES_OPT += "Z" : Endif       : # Date nulle autorisée
  If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
  If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé
  RES='"D'+WRES_OPT+':"+'+func GET_NAMEDAT(WOPT_NUM)

Endif
#OPT=vireblc(OPT,4)
#If TYP=8
# If OPT<>""
#  If OPT <>"$"
#    For WI=0 To len(OPT)
#      If val(mid$(OPT,WI,1))<>0
#       WOPT_NUM=val(mid$(OPT,WI,1))
#      Else
#       WOPT+=mid$(OPT,WI,1)
#      Endif
#    Next
#    RES='"D'+WOPT+':"+'+func GET_NAMEDAT(WOPT_NUM)
#  Else
#    If !instr(0,FMT,":")
#      RES='D:'+FMT
#    Else
#      RES=FMT
#  Endif
# Endif
#Endif
#
#Endif

End RES


Funprog GETFMT_NUM(SCR_OPT,SCR_FMT,TYP_OPT,TYP_FMT,SCR_LEN,TYP_LEN)
Value  Decimal SCR_LEN,TYP_LEN
Value  Char SCR_OPT(),SCR_FMT(),TYP_OPT(),TYP_FMT()
Local Char RES(30)


Local Char WOPT(30),WRES_OPT(30)
Local Char WFMT(30),WRES_FMT(30)
Local Integer WOPT_NUM
If SCR_OPT <>"" and SCR_OPT="$"
  If !instr(0,SCR_FMT,":")
    RES='N:'+SCR_FMT
  Else
    RES=SCR_FMT
  Endif
Else
   WOPT=vireblc(SCR_OPT+TYP_OPT,4)
   If TYP_FMT<>""
    WRES_FMT=TYP_FMT
   Else
    If SCR_LEN<>0
      WRES_FMT=num$(SCR_LEN)
    Else
      WRES_FMT=num$(TYP_LEN)
    Endif
    If instr(1,WOPT,"F") & val(WRES_FMT)=int(WRES_FMT)                    : # Flottant si pas de décimales
      WRES_FMT+ = "F"
    Else
      WRES_FMT+ ="#"
    Endif
   Endif
    If instr(1,WOPT,"+") : WRES_OPT += "+" : Endif       : # Nb > 0
    If instr(1,WOPT,"z") : WRES_OPT += "z" : Endif       : # Zéro non affiché
    If instr(1,WOPT,"0") : WRES_OPT += "0" : Endif       : # Paddé avec des 0
    If instr(1,WOPT,"3") : WRES_OPT += "3" : Endif       : # Séparateur de 3 chiffres
    If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
    If instr(1,WOPT,"-") : WRES_OPT += "-" : Endif       : # Signe forcé
    If instr(1,WOPT,"D") : WRES_OPT += "D" : Endif       : # Signe après
    If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé
    RES="N"+WRES_OPT+":"+WRES_FMT
Endif

End RES

