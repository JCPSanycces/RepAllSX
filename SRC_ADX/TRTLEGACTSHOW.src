Funprog GET_NAMEDAT(TYP)
Value Integer TYP
Local Char RES(30)
Case TYP
  When 1 : RES="GFMDAT"
  When 2 : RES="GFMDAT4"
  When 3 : RES="GFMDAT3"
  When 4 : RES="GFMDAT9"
  When 5 : RES="GFMJOU"
  When 6 : RES="GFMMOI"
  When 7 : RES="GFMMOI4"
  When Default : RES="GFMDAT"
Endcase

End RES
