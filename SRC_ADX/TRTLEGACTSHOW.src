#########################################################################################

$FINDALL_ACTCODES
#JASMI - 2016-06-06 - REQ 114309 - START
#If !clalev([F:ACVZZ2]) : Local File ACTIV [ACVZZ2]    : Endif     #Second Instance
#JASMI - 2016-06-06 - REQ 114309 - END

ISFOUND=0
Y=0
Raz RET_ACTCODE

 For X = 1 To maxtab(SEND_ACTCODE)

#MIPEA - 2016-06-07 - REQ 114309 - START
#JASMI - 2016-06-06 - REQ 114309 - START
#  Filter [F:ACVZZ2]
#    For [F:ACVZZ2] Where [F:ACVZZ2]FLACT=2
    For [F:ACVZZ2] Where [F:ACVZZ2]DEP=4 & [F:ACVZZ2]FLACT=2
#JASMI - 2016-06-06 - REQ 114309 - END
#MIPEA - 2016-06-07 - REQ 114309 - END
      #If (left$([F:ACVZZ2]CODACT,1)="K"|left$([F:ACVZZ2]CODACT,2)="FK") and [F:ACVZZ2]DEP=4#([F:ACVZZ2]TYP=1 & [F:ACVZZ2]DEP=4)
#JASMI - 2016-06-06 - REQ 114309 - START
#      If [F:ACVZZ2]DEP=4 & [F:ACVZZ2]FLACT=2 #([F:ACVZZ2]TYP=1 & [F:ACVZZ2]DEP=4)
      If 1=1
#JASMI - 2016-06-06 - REQ 114309 - END
        #Storing the formula into array
#JASMI - 2018-02-23 - X3-78230 - START
#        Gosub LOOP_FORMULAARRAY
#          If find(SEND_ACTCODE(dim(X)),FORMULAARRAY(1..maxtab(FORMULAARRAY)))
        [F:ACVZZ2]ACTFOR=ctrans([F:ACVZZ2]ACTFOR,"abcdefghijklmnopqrstuvxyz |&()","~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
        #Check if the legislation activity code was found in the array
          If instr(1,[F:ACVZZ2]ACTFOR,SEND_ACTCODE(dim(X)))>0
          #level 1
            For [F:ACVZZ3] Where [F:ACVZZ3]DEP=4 & [F:ACVZZ3]FLACT=2 & [F:ACVZZ3]CODACT<>[F:ACVZZ2]CODACT
              [F:ACVZZ3]ACTFOR=ctrans([F:ACVZZ3]ACTFOR,"abcdefghijklmnopqrstuvxyz |&()","~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
              #Check if the legislation activity code was found in the array
              If instr(1,[F:ACVZZ3]ACTFOR,[F:ACVZZ2]CODACT)>0
              #level 2
                For [F:ACVZZ4] Where [F:ACVZZ4]DEP=4 & [F:ACVZZ4]FLACT=2 & [F:ACVZZ4]CODACT<>[F:ACVZZ3]CODACT
                  [F:ACVZZ4]ACTFOR=ctrans([F:ACVZZ4]ACTFOR,"abcdefghijklmnopqrstuvxyz |&()","~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
                  #Check if the legislation activity code was found in the array
                  If instr(1,[F:ACVZZ4]ACTFOR,[F:ACVZZ3]CODACT)>0
                  #level 3
                    For [F:ACVZZ5] Where [F:ACVZZ5]DEP=4 & [F:ACVZZ5]FLACT=2 & [F:ACVZZ5]CODACT<>[F:ACVZZ4]CODACT
                      [F:ACVZZ5]ACTFOR=ctrans([F:ACVZZ5]ACTFOR,"abcdefghijklmnopqrstuvxyz |&()","~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")
                      #Check if the legislation activity code was found in the array
                      If instr(1,[F:ACVZZ5]ACTFOR,[F:ACVZZ4]CODACT)>0
                        Y+=1 : RET_ACTCODE(Y)=[F:ACVZZ5]CODACT
                      Endif
                    Next
                    Y+=1 : RET_ACTCODE(Y)=[F:ACVZZ4]CODACT
                  Endif
                Next
                Y+=1 : RET_ACTCODE(Y)=[F:ACVZZ3]CODACT
              Endif
            Next
#JASMI - 2018-02-23 - X3-78230 - END
            FNDACTCODE=[F:ACVZZ2]CODACT
            ISFOUND=1 : Y+=1
            RET_ACTCODE(Y)=FNDACTCODE
          Endif
     Endif
    Next
 Next

Return

#########################################################################################

$LOOP_FORMULAARRAY
Local Char FORMULAARRAY(GLONACV)(1..)

Raz FORMULAARRAY
TMPSTR=vireblc([F:ACVZZ2]ACTFOR,4)
ACTFORLEN=len(TMPSTR)
FIRSTCHAR=1
X=0

For AF = 1 To ACTFORLEN
  CHKPIPESTR=mid$(ACTFOR,1,AF)
  CHKPIPE=mid$(CHKPIPESTR,AF,1)
    If CHKPIPE="|"  | CHKPIPE="Or" | AF=ACTFORLEN  | CHKPIPE=" " | CHKPIPE="&" | CHKPIPE="And" | CHKPIPE="(" | CHKPIPE=")"
      If AF = ACTFORLEN FACTCODE=mid$(ACTFOR,FIRSTCHAR,AF-FIRSTCHAR+1) Else FACTCODE=mid$(ACTFOR,FIRSTCHAR,(AF-1)-FIRSTCHAR+1) : Endif
      X+=1
      FORMULAARRAY(X)=FACTCODE
      FIRSTCHAR=AF+1
    Endif
Next

Return

