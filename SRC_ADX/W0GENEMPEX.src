 Endif
Endif
[M]PRDANN = IMPENT

## Zone PRDFRM
mkstat = 0
zoncou = "PRDFRM"
indice = 0
WDATE = [M]PRDFRM
SAVACT = GACTION : GACTION = "ADATRELI"
Call INIDAT([M]PRDFRM,[M]RELDATFRM) From ADATREL
GACTION = SAVACT
If mkstat=1 : Raz [M]PRDFRM : Endif
If !mkstat
 If varmode([M]PRDFRM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PRDFRM" : Gosub ACTION From =IMPTRT
  Endif
  If WDATE<>[M]PRDFRM or IMPMOD
   SAVACT = GACTION : GACTION = "ADATRELM"
   Call MODIFDAT([M]PRDFRM,[M]RELDATFRM) From ADATREL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PRDFRM" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PRDUTL
mkstat = 0
zoncou = "PRDUTL"
indice = 0
WDATE = [M]PRDUTL
SAVACT = GACTION : GACTION = "ADATRELI"
Call INIDAT([M]PRDUTL,[M]RELDATUTL) From ADATREL
GACTION = SAVACT
If mkstat=1 : Raz [M]PRDUTL : Endif
If !mkstat
 If varmode([M]PRDUTL,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PRDUTL" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CTLDATV"
  Call CTLDATV([M]PRDUTL,[M]PRDFRM) From CONTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRDUTL" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WDATE<>[M]PRDUTL or IMPMOD
    SAVACT = GACTION : GACTION = "ADATRELM"
    Call MODIFDAT([M]PRDUTL,[M]RELDATUTL) From ADATREL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PRDUTL" : GZNUM = 0 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

