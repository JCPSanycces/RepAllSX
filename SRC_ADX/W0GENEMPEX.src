# Superviseur
# Gestion du masque GENEMPEX 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone INIT
mkstat = 0
zoncou = "INIT"
indice = 0
SAVACT = GACTION : GACTION = "STD"
Call AV_INIT([M]INIT) From SUBSMH
GACTION = SAVACT
If mkstat=1 : Raz [M]INIT : Endif

## Zone TYPFRM
mkstat = 0
zoncou = "TYPFRM"
indice = 0
IMPENT = [M]TYPFRM
If varinit([M]TYPFRM,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPFRM,indice)=0
 [M]TYPFRM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPFRM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPFRM(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TYPFRM(IMPENT) From SUBSMH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TYPFRM" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TYPFRM = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone FLGFRM
mkstat = 0
zoncou = "FLGFRM"
indice = 0
