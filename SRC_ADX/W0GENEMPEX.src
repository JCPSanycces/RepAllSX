  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ATY","",[M]TYP,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 15 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

