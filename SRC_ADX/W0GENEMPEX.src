  IMPENT = [M]FLGFRM(indice)
 Endif
Endif
[M]FLGFRM = IMPENT

## Zone TOTTYP
mkstat = 0
zoncou = "TOTTYP"
indice = 0
IMPENT = [M]TOTTYP
If varinit([M]TOTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TOTTYP,indice)=0
 Call INICOMBO(10344) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TOTTYP(IMPENT) From SUBSMH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10344,1))))
 Endif
 [M]TOTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TOTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TOTTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TOTTYP" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_TOTTYP(IMPENT) From SUBSMH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TOTTYP" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TOTTYP = IMPENT

