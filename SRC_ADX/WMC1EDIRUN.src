[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PARTYP
Gosub DECLARE_VAR From WMC0EDIRUN
[L]CURPRO = "PARTYP"
$_LNKPRO_PARTYP
Return

$_ALOADATTRIBUTE_PARTYP
[L]ASTATUS = fmet this.ASETATTRIBUTE("PARTYP","$isMandatory","true")
Return


