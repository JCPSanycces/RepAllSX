[L]CURPRO = "FLOCOD"
If vireblc(this.FLOCOD,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPEFC.ACTRLREF(this,"FLOCOD",this.FLOCOD,this.FLOCOD,this.FLOREL,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.FLOCOD<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
