Gosub DECLARE_VAR From WMC0EDIRUN
[L]CURPRO = "FLOCOD"
$_LNKPRO_FLOCOD
If vireblc(this.FLOCOD,2)<>""
 # Link EDIFLO
 Local File EDIFLO [WEFL]
 Read [F:WEFL]EFL0 = this.FLOCOD;this.FLOREL
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FLOCOD","$title",[F:WEFL]FLODES)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FLOCOD","$description",[F:WEFL]FLODES)
 Endif
 LogicClose File [WEFL]
Endif
Return


