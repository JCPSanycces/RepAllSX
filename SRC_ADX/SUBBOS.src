#<AdxTL>@(#)254.0.0.0 $Revision$
# Sélection pour Suppression composant
# seul le masque numero 0 est différent, les masques de
# validation sont les mêmes que pour le remplacement (BOMRPL1, BOMRPL2, BOMRPL3)
# GA 24/11/2005 supression d'un composant nomenclature de sous-traitance
################################################################################
## Programme inspiré de SUBXXT pour gestion en
## tableaux des nomenclatures détails          Thierry B
## Modif GA 21/06/2005 ajout BOMS
########################################################
# FQ 55649 GA 01/2010 utilisé aussi par l'objet BOS
#-------------------------------------------------------
# Ce traitement nécessite d'avoir
# GFONBOD : positionné avant son appel
#           ("BOMC":commerciale, "BOMP":production, "BOMS":sous-traitance)
########################################################
# Ce traitement nécessite d'avoir
# GFONBOD : positionné avant son appel
#           ("BOMC":commerciale, "BOMP":production, "BOMS":sous-traitance)
# GBOMALT : Tableau des alternatives acceptées (en tunnel)
# GDATEREF: déclarée et initialisée si besoin
########################################################
#Call OBJET("BOD",GBIDC1,GBIDC2) From GOBJET
#End
########################################################
$ACTION
If dim(GFONBOD)>0 & GFONBOD="BOMS" # FQ 55649 GA 01/2010 pour l'objet BOS nomenclatures de sous-traitance
    Case ACTION
     When "VARIANTE"         : Gosub VARIANTE From SUBBODA
     When "AVANT_OUVRE"      : Gosub AVANT_OUVRE From SUBBODA
     When "OUVRE"            : Gosub OUVRE From SUBBODA
     When "OUVRE_BATCH"      : Gosub OUVRE From SUBBODA          : # GA 10/2008
     When "OUVRE_BOITE"      : Gosub OUVRE_BOITE  From SUBBODA
     When "HINTCLE"          : Gosub HINTCLE      From SUBBODA
     When "STATUT"           : Gosub STATUT From SUBBODA
     When "FERME"            : Gosub FERME From SUBBODA
     When "VERIF_CRE"        : Gosub VERIF_CRE From SUBBODA
     When "VERIF_MOD"        : Gosub VERIF_MOD From SUBBODA
     When "INICRE"           : Gosub INICRE From SUBBODA
     When "INIMOD"           : Gosub INICRE From SUBBODA
     When "CREATION"         : Gosub CREATION From SUBBODA
     When "APRES_CRE"        : Gosub APRES_CRE From SUBBODA
     When "AVANT_MODFIC"     : Gosub AVANT_MODFIC From SUBBODA
     When "APRES_MOD"        : Gosub APRES_MOD From SUBBODA
     When "APRES_MODIF"      : Gosub APRES_MODIF From SUBBODA
     When "MODIF"            : Gosub MODIF From SUBBODA
     When "FILTRE"           : Gosub FILTRE From SUBBODA
     When "LIENS"            : Gosub LIENS From SUBBODA
     When "SETBOUT"          : Gosub SETBOUT From SUBBODA
     When "AVANTBOUT"        : Gosub AVANTBOUT From SUBBODA
     When "EXEBOUT"          : Gosub EXEBOUT From SUBBODA
     When "EXEACT"           : Gosub EXEACT From SUBBODA     # 27172 12.04 MM
     When "VERF_ANU"         : Gosub VERF_ANU From SUBBODA
     When "ANNULE"           : Gosub ANNULE From SUBBODA
     When "RAZCRE"           : Gosub RAZCRE From SUBBODA
     When "RAZDUP"           : Gosub RAZDUP From SUBBODA
     When "ABANDON"          : Gosub SUPPRESS_TEX From SUBBODA
     When "AB_CREATION"      : Gosub SUPPRESS_TEX From SUBBODA
     When "FILGAUCHE"        : Gosub FILGAUCHE From SUBBODA
     When "TIROIR"           : Gosub TIROIR    From SUBBODA
     When "FIN_ACTION"       : Gosub FIN_ACTION  From SUBBODA   # 12.06 demande 38646
     When "SEL_TABLE"        : Gosub SEL_TABLE From SUBBODA
     When "EFFMASK"          : Gosub EFFMASK From SUBBODA
    Endcase
Else
    Case ACTION
        When "INIT"     : Gosub INIT
        When "CONTROLE" : Gosub CONTROLE
        When "EXEC"     : Gosub EXEC
        When "TERMINE"  : Gosub TERMINE
        When "SORTIE"   : Gosub SORTIE
        When "DEBUT"    : If BOITE = "FBOMSUP" : Gosub DEBUTSUP : Else : Gosub DEBUT : Endif
        When "END"      : PARAM(1) = "END"

        # GH 06/06/2016 bug 113255 - File updates are managed through the action OK (instead of EXEC)
        When "OK"       : If BOITE = "FBOMSUP" : Gosub VALID  : Endif
    Endcase
Endif
Return

################################################################################
$INIT
Local    Integer OK
Local    Char    TEX(15)(30) : #, ERR_TRA(132)

If clalev([F:ACC]) = 0 : Local File ACCES     [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD      [BOD] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO] : Endif

Local Mask BOMSUP0 [BOS0]

[M:BOS0]APPDAT = date$  #par défaut

Return

################################################################################
$CONTROLE
# paramètre en retour de la fenêtre initiale
If PARAM(1) = "END"
  FIN = 1
  Return
Endif

# ouverture préalable des masques pour le chargement
If clalev([M:BOSH]) = 0 : Local Mask BOMSUPH [BOSH] : Endif : # pour entête d'écran résultat
If clalev([M:BOR1]) = 0 : Local Mask BOMRPL1 [BOR1] : Endif : # pour alternatives de prod
If clalev([M:BOR2]) = 0 : Local Mask BOMRPL2 [BOR2] : Endif : # pour alternatives commerc
If clalev([M:BOR3]) = 0 : Local Mask BOMRPL3 [BOR3] : Endif : # pour alternatives sous-traitance
Raz [BOR1], [BOR2], [BOR3]

Default Mask [BOS0]

OK = 1
Call EXTRACT(OK)

# erreur d'accès sur fichier entête de nomenclature ...
If OK = 0
    GMESSAGE=mess(12,100,1)-"BOM:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)
    GERR = 1
    Return
Endif

If [M:BOR1]NBLIG = 0 & [M:BOR2]NBLIG = 0 & [M:BOR3]NBLIG = 0
   GMESSAGE = mess(113,199,1)
   GERR = 1
Endif

If GERR <> 1  TMP = 1  Endif

Return

################################################################################
$EXEC
# si on a cliqué 'Fin' dans la fenêtre principale, on ne fait rien  :
If PARAM(1) = "END"
    SAI = 1
    Raz PARAM(1)
    Raz [M:BOS0]
#Else
#  Gosub VALID # GH 06/06/2016 bug 113255 - File update are managed through the action OK (instead of EXEC)

# Issue X3-60359 - 2017-10-18 by JUSYN : Trace versioned BOM log file - Close page and delete trace file if not needed
    If func AFNC.ACTIV("ECC")
        Call FERME_TRACE From LECFIC
    Endif
Endif
# End issue X3-60359
Return

################################################################################
$TERMINE
Close Local Mask [BOSH], [BOR1], [BOR2], [BOR3]
Raz [M:BOS0]
[M:BOS0]APPDAT = date$
#TRA = 1 : # GH 06/06/2016 bug 113255 - log trace is displayed through action OK (instead of EXEC)
SAI = 1
Return

################################################################################
$SORTIE
Raz GFONBOD
Raz [M:BOS0]
Return

#######################################################################
$DEBUT
[M:BOS0]APPDAT = date$
Affzo [M:BOS0]
Return

################################################################################
$DEBUTSUP
# Affichage des ecrans de validation  "Résultat remplacement"
[M:BOSH] = [M:BOS0]
Affzo [BOSH]
Affzo [BOR1]
Affzo [BOR2]
Affzo [BOR3]

Diszo [BOSH]SUPCPN

# End issue X3-58228
If [M:BOR1]NBLIG = 0 : Grizo [M:BOR1] : Endif
If [M:BOR2]NBLIG = 0 : Grizo [M:BOR2] : Endif
If [M:BOR3]NBLIG = 0 : Grizo [M:BOR3] : Endif
# Issue X3-58228 - 2017-10-12 by JUSYN : Info message about not deleted components in versioned BOMs / Grey out versioned fields as well
If func AFNC.ACTIV("ECC")
    Call MESSAGE(mess(414,193,1)) From GESECRAN
Endif
# End issue X3-58228
Return

###################################################################################
$FILTRE

Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2

XCRITERE1 = "1=1"

If [M]ITMREFDEB <> ""
    XCRITERE = "[F:BOH]ITMREF >= [M]ITMREFDEB"
    Gosub LOAD_CRITERE
Endif

If [M]ITMREFFIN <> ""
    XCRITERE = "[F:BOH]ITMREF <= [M]ITMREFFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTTYPDEB <> 1 | [M]ALTTYPFIN <> 3)
    XCRITERE = "[F:BOH]BOMALTTYP >= [M]ALTTYPDEB & [F:BOH]BOMALTTYP <= [M]ALTTYPFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTDEB <> 0 | [M]ALTFIN <> 0)
    XCRITERE = "[F:BOH]BOMALT >= [M]ALTDEB & [F:BOH]BOMALT <= [M]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return

############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif
Return

################################################################################
Subprog EXTRACT(OK)
Variable Integer OK
Local Integer    ILIG, JLIG, KLIG, NBTEX
Local    Char    XCRITERE(255)
Local    Char    XCRITERE1(255)
Local    Char    XCRITERE2(255)
Local    Char    FORMULE1(255)
# Issue X3-60359 - 2017-10-18 by JUSYN Trace versioned BOM log file
Local    Integer WACTECC : WACTECC = func AFNC.ACTIV("ECC")
# End issue X3-60359

Gosub FILTRE
If XCRITERE2 = "" : XCRITERE2 = "1=1" : Endif

# analyse présence formule de sélection
If [M]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=31;[M]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

ILIG=0 : JLIG=0 : KLIG=0

Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP, [ITM]ITM0=[F:BOD]ITMREF,
&               [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT As [BODX]
&          Where CPNITMREF = [M:BOS0]SUPCPN &
&                BOMSTRDAT < [M:BOS0]APPDAT &
&               (BOMENDDAT > [M:BOS0]APPDAT-1 | BOMENDDAT=[0/0/0]) &
&               evalue(XCRITERE1) & evalue(XCRITERE2) & evalue(FORMULE1)

For [BODX]
   # Issue X3-60359 - 2017-10-24 by JUSYN Trace versioned BOM log file - earlier trace of versioned BOMs because of process exclusion
   If WACTECC
       If GTRACE = ""
           Call OUVRE_TRACE(mess(117,199,1)) From LECFIC
           Call PRTSCR("BOMSUP0","BOS0","",0,1) From ATRTX3
           Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
           Call ECR_TRACE(" ",0) From GESECRAN
           Call ECR_TRACE(mess(414,193,1),0) From GESECRAN
       Endif
   Endif
   # End issue X3-60359
   # Issue X3-58228 - 2017-10-12 by JUSYN : Exclude versioned BOMs from selection
   If func ECCLIB.NBRCPN([F:BOH]ITMREF) = 0
       Gosub CHARG_ECR
   Else
       # Issue X3-60359 - 2017-10-18 by JUSYN Trace versioned BOM log file - Writing
       Gosub CHARG_LOG
       # End issue X3-60359
   Endif
   # End issue X3-58228
   If OK = 0 : Break : Endif
Next

[M:BOR1]NBLIG = ILIG
[M:BOR2]NBLIG = JLIG
[M:BOR3]NBLIG = KLIG
End

################################################################################
$CHARG_ECR

Raz mkstat

# vérifier droit de modif sur alternative
Call CTLMODALT([F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM
Raz GMESSAGE
If mkstat : Return : Endif

Case [F:BOH]BOMALTTYP
    When 1:    # nomenclature commerciale
               JLIG += 1
               nolign = JLIG
               If JLIG > dim([M:BOR2]VALID)
                  JLIG -= 1
                  GMESSAGE = mess(188,199,1)
                  GERR = 2
               Else
                  [M:BOR2] = [F:BOD]
                  [M:BOR2]VALID(nolign-1)  = 2
#                  [M:BOR2]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                  [M:BOR2]BOHSTU(nolign-1) = [F:ITM]SAU
                  [M:BOR2]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                  [M:BOR2]BASQTY(nolign-1) = [F:BOH]BASQTY
               Endif
    When 2:    # nomenclature de production
               ILIG += 1
               nolign = ILIG
               If ILIG > dim([M:BOR1]VALID)
                  ILIG -= 1
                  GMESSAGE = mess(187,199,1)
                  GERR = 2
               Else
                  [M:BOR1] = [F:BOD]
                  [M:BOR1]VALID(nolign-1)  = 2
#                  [M:BOR1]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                  [M:BOR1]BOHSTU(nolign-1) = [F:ITM]STU
                  [M:BOR1]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                  [M:BOR1]BASQTY(nolign-1) = [F:BOH]BASQTY
                  #  process 03.03 MM
                  If dim([M:BOR1]BOMQTY(nolign-1))>0
                    If [M:BOR1]BOMQTY(nolign-1)=0
                     [M:BOR1]BOMQTY(nolign-1) = [M:BOR1]LIKQTY(nolign-1)
                    Endif
                  Endif
                  # Fin process 03.03 MM
               Endif
    When 3:    # nomenclature sous-traitance
               KLIG += 1
               nolign = KLIG
               If KLIG > dim([M:BOR3]VALID)
                  KLIG -= 1
                  GMESSAGE = mess(512,199,1)
                  GERR = 2
               Else
                  [M:BOR3] = [F:BOD]
                  [M:BOR3]VALID(nolign-1)  = 2
#                  [M:BOR3]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                  [M:BOR3]BOHSTU(nolign-1) = [F:ITM]SAU
                  [M:BOR3]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                  [M:BOR3]BASQTY(nolign-1) = [F:BOH]BASQTY
               Endif
Endcase
Return

################################################################################
$VALID

# Issue X3-60359 - 2017-10-24 by JUSYN Trace versioned BOM log file - Usual start to create log file if not ECC no BOM versions.
If GTRACE = ""
    Call OUVRE_TRACE(mess(117,199,1)) From LECFIC
    Call PRTSCR("BOMSUP0","BOS0","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif
# moved this part to into subprogramme "Extract"
  # Issue X3-58228 - 2017-10-12 by JUSYN : Info message about not deleted components in versioned BOMs
  #If func AFNC.ACTIV("ECC")
  #    Call ECR_TRACE(mess(414,193,1),0) From GESECRAN
  #Endif
  # End issue X3-58228
# End issue X3-60359

# GH 06/06/2016 bug 113255 - information already given by copying of criteria screen in the log
#ERR_TRA = mess(35,197,1) - [M:BOS0]SUPCPN
#ERR_TRA -= mess(38,197,1) - format$("D:DD[/]MM[/]YY",[M:BOS0]APPDAT)
#Call ECR_TRACE(ERR_TRA,0) From GESECRAN

# maj du lien existant en changeant la fin de validité
# pas de mise à jour de code de plus bas niveau car le lien n'est pas oté physiquement

Call DEBTRANS From GLOCK
Trbegin [BOD]

If GOK>0
  # Alternatives de production
  For nolign = 1 To [M:BOR1]NBLIG
      If [M:BOR1]VALID(nolign-1) = 2
          Default Mask [BOR1]
          Gosub MODI
          If GOK<1 : Break : Endif
      Endif
  Next
Endif

If GOK>0
  # Alternatives commerciales
  For nolign = 1 To [M:BOR2]NBLIG
      If [M:BOR2]VALID(nolign-1) = 2
          Default Mask [BOR2]
          Gosub MODI
          If GOK<1 : Break : Endif
      Endif
  Next
Endif

If GOK>0
  # Alternatives de sous-traitance
  For nolign = 1 To [M:BOR3]NBLIG
      If [M:BOR3]VALID(nolign-1) = 2
          Default Mask [BOR3]
          Gosub MODI
          If GOK<1 : Break : Endif
      Endif
  Next
Endif

# GH 06/06/2016 bug 113255 - if transaction is rollbacked, we go back to the screen entry
If GOK>0 : Commit : Else Rollback : FIN=0 : Endif
Call FERME_TRACE From LECFIC
# GH 06/06/2016 bug 113255 - log trace is displayed through action OK (instead of EXEC)
Call LEC_TRACE From LECFIC
Return

################################################################################
$MODI
# GH 06/06/2016 bug 113255 : rollback management in the transaction
Raz GMESSAGE
Readlock [BOD]BOD0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMSEQ(nolign-1);[M:BOS0]SUPCPN
If fstat = 1  # the record is locked
    GMESSAGE = mess(60,100,1)-"BOMD"
    GOK=-1
Elsif fstat   # the record not exists anymore => nothing to do
    Return
Elsif [F:BOD]BOMENDDAT > [M:BOS0]APPDAT - 1 | [F:BOD]BOMENDDAT = [0/0/0]
    [F:BOD]BOMENDDAT = [M:BOS0]APPDAT - 1
    [F:BOD]UPDDAT    = date$
    [F:BOD]UPDUSR    = GUSER
    [F:BOD]EXPNUM    = [C]EXPORT

    # entry point for additional updates or warnings of usage by WO for example
    GPOINT = "BODMAJ" : Gosub ENTREE From EXEFNC
    If GOK<1 : Return : Endif

    Rewrite [BOD]
    If fstat # an error occurs during the update of the record
       GMESSAGE = mess(13,100,1)-"BOMD"
       GOK=0
    Endif
Endif

################################################################################
$ERR
Call ECR_TRACE(mess(153,198,1)-mess([M]BOMALTTYP(nolign-1),224,1)-[M]ITMREF(nolign-1)+"/"+num$([M]BOMALT(nolign-1))+"/"+num$([M]BOMSEQ(nolign-1))
&             -string$(GMESSAGE<>"",":"-GMESSAGE),GOK<1) From GESECRAN
Raz GMESSAGE
Return

################################################################################
# ETIQUETTES SUR ZONES
################################################################################
Subprog AV_STU(VALEUR)
Variable Char     VALEUR
Call LECTURE("ITM",[M]SUPCPN,"") From CONTOBJ
VALEUR = [F:ITM]STU
End

################################################################################
Subprog C_APPDAT(VALEUR)
Variable Date     VALEUR
If VALEUR < date$
   mkstat = 2 : GMESSAGE = mess(114,199,1)
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BOMSUP0) 07/04/2006 12:03:46 (LLCX)
######################################################################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]ITMREFFIN = VALEUR : Endif
End

Subprog AM_ALTTYPDEB(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0 : [M]ALTTYPFIN = VALEUR : Endif
End

Subprog C_ALTTYPFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]ALTTYPDEB : mkstat = 2 : Endif
End

Subprog AM_ALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ALTFIN = VALEUR : Endif
End

Subprog C_ALTFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]ALTDEB : mkstat = 2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BOMSUP0) 07/04/2006 12:05:25 (LLCX)
######################################################################################
Subprog AV_ALTDEB(VALEUR)
Variable Decimal VALEUR
Local Integer WALTTYP

If [M]ALTTYPDEB <= 1 & [M]ALTTYPFIN >= 1  : WALTTYP += 1 : Endif
If [M]ALTTYPDEB <= 2 & [M]ALTTYPFIN >= 2  : WALTTYP += 2 : Endif
If [M]ALTTYPDEB <= 3 & [M]ALTTYPFIN >= 3  : WALTTYP += 4 : Endif

[M]ALTTYPS = WALTTYP
End

######################################################################################
# Issue X3-58228 - 2017-10-12 by JUSYN : No versioned components allowed - control and message
######################################################################################
## Section automatically added (screen BOMSUP0) 10/12/2017 11:45:16 (JUSYN)
######################################################################################
Subprog C_SUPCPN(VALEUR)
Variable Char    VALEUR()

If func ECCLIB.NBRCPN(VALEUR) > 0
    GERR = 1
    GMESSAGE = mess(417,193,1)
    mkstat = 2
Endif

End
# End issue X3-58228

######################################################################################
# Issue X3-60359 - 2017-10-18 by JUSYN : Trace versioned BOM log file - Log file writing
$CHARG_LOG
    Call ECR_TRACE(mess(153,198,1)-mess([F:BOH]BOMALTTYP,224,1)-[F:BOH]ITMREF+"/"+num$([F:BOH]BOMALT)+"/"+num$([F:BOD]BOMSEQ)-
&            mess(419,193,1),0) From GESECRAN
Return
# End issue X3-60359

