#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("GH-DT-0107","") From ETAT
End

####################################################
## Compétences par salarié
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250), CRITERE1(250)
Local Char    CPY(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    PRF(GLONPRF), SRV(GLONSRV)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML),POP(GLONPOP)
Local Char TAXYEAR(4), TAXMON(2)

Local Decimal NUMREQ

If clalev([F:ARM])=0    : Local File AREPORTM  [ARM]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]: Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpy",NBPAR,PARAMETRE,CPY)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("srv",NBPAR,PARAMETRE,SRV)
Call GETPARAM("taxyear",NBPAR,PARAMETRE,TAXYEAR)
Call GETPARAM("taxmon",NBPAR,PARAMETRE,TAXMON)


Call GETPARAM("prf",NBPAR,PARAMETRE,PRF)
Call GETPARAM("pop",NBPAR,PARAMETRE,POP)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = "1=1"


If CPY<>"" : CRITERE1 -= "& [F:FGR]CPY='"+CPY+"'"    : Endif
If FCYDEB<>"" : CRITERE1 -= "& [F:HRCTR]ETRFCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE1 -= "& [F:HRCTR]ETRFCY<='"+FCYFIN+"'"    : Endif
If PRF<>"" : CRITERE1 -= "& [F:HRCTR]PROPRF='"+PRF+"'"    : Endif
If MATDEB<>"" : CRITERE1 -= "& [F:HRCTR]REFNUM>='"+MATDEB+"'" : Endif
If MATFIN<>"" : CRITERE1 -= "& [F:HRCTR]REFNUM<='"+MATFIN+"'" : Endif
If SRV<>"" : CRITERE1 -= "& [F:HRCTR]ETRSRV='"+SRV+"'"    : Endif


Gosub TR1
Gosub TR2

End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]

  Local Integer CNTACTIVE,CNTNEW,CNTTERM
  Local Date STRDAT, ENDDAT
  Local Char RESULT_VALUE(2)
  Local Integer ITAXYEAR
  Local Integer ITAXMON
  Local Char CTRNUM(30)
  Local Char CTRNUMTMP(30)
#initialize
  RESULT_VALUE=''
  CNTACTIVE = 0
  CNTNEW = 0
  CNTTERM = 0
  ITAXYEAR = val(TAXYEAR)
  ITAXMON = val(TAXMON)
  STRDAT = gdat$(1,ITAXMON,ITAXYEAR)

  If ITAXMON = 12
    ENDDAT = gdat$(1,1,ITAXYEAR-1)
  Else
    ENDDAT = gdat$(1,ITAXMON+1,ITAXYEAR)
  Endif

If [L]POP<>""
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNKAC]
& Where evalue(CRITERE1) & [F:HRCTR]DATCRE < STRDAT & ([F:HRCTR]DATXITFNL >=STRDAT | [F:HRCTR]DATXITFNL = [0/0/0]) & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& As [LNKAC]
& Where evalue(CRITERE1) & [F:HRCTR]DATCRE < STRDAT & ([F:HRCTR]DATXITFNL >=STRDAT | [F:HRCTR]DATXITFNL = [0/0/0])
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif
  For [LNKAC]
    If [F:HRCTR]XITDAT < STRDAT & ([F:HRCTR]DATXITFNL = [0/0/0] & [F:HRCTR]XITDAT <> [0/0/0])
      #Infbox "Out Act: " + [F:HRCTR]REFNUM + " " + [F:HRCTR]CTRNUM + " C: " + num$([F:HRCTR]DATCRE)  + " X: " + num$([F:HRCTR]XITDAT) + " F: " + num$([F:HRCTR]DATXITFNL)
      CTRNUMTMP = [F:HRCTR]CTRNUM
    Else
      If CTRNUM <> [F:HRCTR]CTRNUM
      #Infbox "In Act: " + [F:HRCTR]REFNUM + " " + [F:HRCTR]CTRNUM + " C: " + num$([F:HRCTR]DATCRE)  + " X: " + num$([F:HRCTR]XITDAT) + " F: " + num$([F:HRCTR]DATXITFNL)
        CNTACTIVE+=1
      Endif
      CTRNUM = [F:HRCTR]CTRNUM
    Endif
  Next

If [L]POP<>""
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNKNEW]
& Where evalue(CRITERE1) & ([F:HRCTR]DATCRE >= STRDAT & [F:HRCTR]DATCRE < ENDDAT) & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& As [LNKNEW]
& Where evalue(CRITERE1) & ([F:HRCTR]DATCRE >= STRDAT & [F:HRCTR]DATCRE < ENDDAT)
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif
CTRNUM = ""


  For [LNKNEW]
    If CTRNUM <> [F:HRCTR]CTRNUM
      CNTNEW+=1
    Endif
    CTRNUM = [F:HRCTR]CTRNUM
  Next

If [L]POP<>""
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& , [HRPOA]POA0=[L]POP;[F:HRCTR]REFNUM
& As [LNKTERM]
& Where evalue(CRITERE1) & ([F:HRCTR]DATXITFNL >= STRDAT & [F:HRCTR]DATXITFNL < ENDDAT) & [F:HRPOA]REFNUM<>""
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Else
 Link [HRCTR] With
&  [FGR]FGR1(1)=[F:HRCTR]ETRFCY
& As [LNKTERM]
& Where evalue(CRITERE1) & ([F:HRCTR]DATXITFNL >= STRDAT & [F:HRCTR]DATXITFNL < ENDDAT)
& Order By [F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
Endif
CTRNUM = ""


  For [LNKTERM]
    If CTRNUM <> [F:HRCTR]CTRNUM
      CNTTERM+=1
    Endif
    CTRNUM = [F:HRCTR]CTRNUM
  Next

    Raz [F:ARM]
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]CLEA1  = [L]CPY
    [F:ARM]CLEN1  = CNTACTIVE
    [F:ARM]CLEN2  = CNTNEW
    [F:ARM]CLEN3  = CNTTERM


    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif

 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

