#<AdxTL>@(#)8.0.0.0 $Revision$
# Gestion du masque SNLL
# L'ouverture de la fenêtre ne se fera que si:
#  - GOUVINVLL <> 1  


$ACTION
Case ACTION
  When "INIT"     : Gosub INIT_SNLL
  When "OUVRE"    : Gosub OUVRE_SNLL
  When "DEBUT"    : Gosub DEBUT_SNLL
  When "OK"       : Gosub OK_SNLL
  When "ABA"      : Gosub ABA_SNLL
  When "END"      : Gosub END_SNLL 
  When "FIN"      : Gosub FIN_SNLL
  When "FINSAI"   : Gosub FINSAI
Endcase
Return
############################################################
$INIT_SNLL
#si variable globale GOUVINVL <= 1 on sort
# gouvinvl = 1 : automatique
# gouvinvl = 2 : clic droit 
If GOUVINVL < 1 
  FIN = 1 
  Return
Endif
Return 
############################################################
$OUVRE_SNLL


If clalev([M:SNLL])= 0 Local Mask SNLL       [SNLL] Endif  #  ecran saisie  lot
If clalev([F:STO]) = 0 Local File STOCK      [STO]  Endif
If !clalev([ECS]) : Local File ECCSTA [ECS] : Endif   # hcb 71276
If GFEALOTLEV = 2                                          # hcb unicite
   If clalev([F:STL1]) = 0 Local File STOLOT [STL1] Endif  # hcb unicite
Endif                                                      # hcb unicite
If clalev([F:SLF]) = 0 Local File STOLOTFCY  [SLF]  Endif

Raz [M:SNLL]
#recuperation numero de ligne 
Local Integer    LLIG  : LLIG    =  val(PARAM(1))
Return 
############################################################
$DEBUT_SNLL
Local  Char    LSLO(GLONSLO)                 # hcb 34064
Local  Integer I
Global Integer GMODLOT                       # hcb unicite
Raz    GMODLOT                               # hcb unicite
#----- Relecture transaction de saisie  -----#                     
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

[M:SNLL]ITMREF      = [M:SNL1]ITMREF


If dim([M:SNL1]LOT) > 0                        # hcb 103036 
   [M:SNLL]LOT        = [M:SNL1]LOT(LLIG)
Else                                           # hcb 103036 
   Raz [M:SNLL]LOT                             # hcb 103036 
Endif                                          # hcb 103036 
If dim([M:SNL1]SLO) > 0 & [F:ITM]LOTMGTCOD = 4
   [M:SNLL]SLO       = [M:SNL1]SLO(LLIG)
   LSLO              = [M:SNL1]SLO(LLIG)    # hcb 34064
Endif

#                                                           # Hcb 71276 deb
If dim([M:SNL1]ECCVALMAJ) > 0 & [F:ITM]ECCSTO > 1
   [M:SNLL]ECCVALMAJ       = [M:SNL1]ECCVALMAJ(LLIG)
   [M:SNLL]ECCVALMIN       = [M:SNL1]ECCVALMIN(LLIG)
   If [M:SNLL]ECCVALMAJ <> ""
      Read [ECS]ECS0=[M:SNLL]ITMREF;[M:SNLL]ECCVALMAJ
      If fstat
         Raz [F:ECS]
      Endif
      [M:SNLL]ECCSTA = [F:ECS]ECCSTA
   Endif
#                                                           # Hcb 71276 fin
Endif


[M:SNLL]LOTEXI   = 2

If GOUVINVL = 1
   [M:SNLL]LOTEXI   = 1
# si automatique et gestion slo on recherche si lot "maitre" existe
   If [F:ITM]LOTMGTCOD = 4 
      Filter [F:STL] Where ITMREF = [M:SNL1]ITMREF & LOT = [M:SNLL]LOT 
&                    Order By Key STL0
      Read [STL] First  
      If fstat
         Gosub INIT_STL
      Else                                      # hcb unicite
         If GFEALOTLEV = 2                      # hcb unicite
            GMODLOT    = 1                      # hcb unicite 
         Endif                                  # hcb unicite
      Endif
      Filter [F:STL]
   Else
      Gosub INIT_STL
   Endif
Else
   Read [STL]STL0= [M:SNLL]ITMREF;[M:SNLL]LOT ;LSLO            # hcb 34064
   If fstat
      Gosub INIT_STL
      [M:SNLL]LOTEXI   = 1
#                                                                            hcb unicite deb
   Else                                                                                          
      If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2                                                   
         Filter [F:STL1] Where ITMREF = [M:SNL1]ITMREF & LOT = [M:SNLL]LOT  & SLO <> LSLO   
&               Order By Key STL0                                                                
         Read [STL1] First                                                                      
         If !fstat                                                                              
            GMODLOT    = 1                                                                        
         Endif                                                                                  
         Filter [F:STL1]                                                                         
      Endif                                                                                     
#                                                                            hcb unicite fin
                                                                                       
   Endif 
Endif

[M:SNLL]POT        = [F:STL]POT
[M:SNLL]ACT        = [F:STL]ACT
[M:SNLL]REFPER     = [F:STL]REFPER
[M:SNLL]SHL        = [F:STL]SHL
[M:SNLL]SHLDAT     = [F:STL]SHLDAT
[M:SNLL]USRFLD1    = [F:STL]USRFLD1
[M:SNLL]USRFLD2    = [F:STL]USRFLD2
[M:SNLL]USRFLD3    = [F:STL]USRFLD3
[M:SNLL]USRFLD4    = [F:STL]USRFLD4
[M:SNLL]BPSLOT     = [F:STL]BPSLOT
[M:SNLL]SHLUOM     = [F:STL]SHLUOM          # V6per
[M:SNLL]DLU        = [F:STL]DLU             # V6per
[M:SNLL]DLUDAT     = [F:STL]DLUDAT          # V6per
[M:SNLL]SHLLTI     = [F:STL]SHLLTI          # V6per
[M:SNLL]SHLLTIUOM  = [F:STL]SHLLTIUOM       # V6per
[M:SNLL]NEWLTIDAT  = [F:STL]NEWLTIDAT       # V6per
If [M:SNLL]DLUDAT <> [0/0/0] 
#                                                                           # hcb dlu deb  
    If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4 
        Raz [M:SNLL]DLULTI

    Else
        [M:SNLL]DLULTI     =  nday([M:SNLL]DLUDAT) -nday([M:SNLL]REFPER)
    Endif
#                                                                           # hcb dlu fin  
Endif

# hcb unicite
If GMODLOT          = 0                  &
&  [F:STL]VCRTYP    = 9                  &
&  [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM  &
&  [F:STL]VCRLIN    = 0
    I = 0
    Filter [STO] Where ITMREF = [M:SNLL]ITMREF &
&                      STOFCY = [M:SNL1]STOFCY &
&                      LOT    = [M:SNLL]LOT &
&                      SLO    = LSLO 
&                Order By Key STO3
    For [STO]
      I = 1
      Break
    Next 
    Filter [STO]
    If I = 0
       If [F:SRT]SRUB1FLG=2
          Actzo [M:SNLL]USRFLD1
       Else  
          Grizo [M:SNLL]USRFLD1
       Endif
       If [F:SRT]SRUB2FLG=2
          Actzo [M:SNLL]USRFLD2
       Else  
          Grizo [M:SNLL]USRFLD2
       Endif
       If [F:SRT]SRUB3FLG=2
          Actzo [M:SNLL]USRFLD3
       Else  
          Grizo [M:SNLL]USRFLD3
       Endif
       If [F:SRT]SRUB4FLG=2
          Actzo [M:SNLL]USRFLD4
       Else  
          Grizo [M:SNLL]USRFLD4
       Endif
       If [F:ITF]STOMGTCOD<3
          Grizo [M:SNLL]POT
          Grizo [M:SNLL]ACT
       Endif
       If [F:ITF]STOMGTCOD=3
          Actzo [M:SNLL]POT
       Endif
       If [F:ITF]STOMGTCOD=4
          Actzo [M:SNLL]ACT
       Endif
       If [F:ITM]EXYMGTCOD > 1
          Actzo [M:SNLL]SHLDAT
          Actzo [M:SNLL]REFPER
          Actzo [M:SNLL]SHL
          Actzo [M:SNLL]SHLUOM       # V6per
          Actzo [M:SNLL]DLU          # V6per
          Actzo [M:SNLL]DLUDAT       # V6per
          Actzo [M:SNLL]SHLLTI       # V6per
          Actzo [M:SNLL]SHLLTIUOM    # V6per
          Actzo [M:SNLL]NEWLTIDAT    # V6per
       Else  
          Grizo [M:SNLL]SHLDAT 
          Grizo [M:SNLL]REFPER
          Grizo [M:SNLL]SHL
          Grizo [M:SNLL]SHLUOM       # V6per
          Grizo [M:SNLL]DLU          # V6per
          Grizo [M:SNLL]DLUDAT       # V6per
          Grizo [M:SNLL]SHLLTI       # V6per
          Grizo [M:SNLL]SHLLTIUOM    # V6per
          Grizo [M:SNLL]NEWLTIDAT    # V6per

       Endif
#                                                                          # hcb dlu deb
       If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4 
           Diszo [M:SNLL]DLU
           Diszo [M:SNLL]DLUDAT
       Else
           Actzo [M:SNLL]DLU
           Actzo [M:SNLL]DLUDAT
       Endif
#                                                                          # hcb dlu fin

# si la ligne est validée ou abandonnée modif interdire
       If [M:SNL1]CUNLISSTA(LLIG) > 2
          Diszo [M:SNLL]
       Endif
    Else
       Diszo [M:SNLL]
    Endif
Else
    Diszo [M:SNLL]
Endif
If [F:ITM]EXYMGTCOD = 6               # hcb typ6 
      Grizo [M:SNLL]REFPER
Endif
#                                                           # Hcb 71276 deb
If dim([M:SNLL]ECCVALMAJ)>0
   If dim([M:SNL1]ECCSAIFLG) > 0 & [M:SNL1]ECCSAIFLG(LLIG) = 1
      Grizo [M:SNLL]ECCVALMAJ
      Grizo [M:SNLL]ECCVALMIN
   Else
      If [F:ITM]ECCSTO >1
         Actzo [M:SNLL]ECCVALMAJ
      Else                 
         Grizo [M:SNLL]ECCVALMAJ
         Grizo [M:SNLL]ECCVALMIN
      Endif
      If [F:ITM]ECCSTO = 3
         Actzo [M:SNLL]ECCVALMIN
      Endif
   Endif
Endif
#                                                           # Hcb 71276 fin




Raz [M:SNLL]WFEALOTLEV                                                   # hcb unicite
If [F:ITM]LOTMGTCOD=4                                                    # hcb unicite
   [M:SNLL]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1) # hcb unicite
Endif                                                                    # hcb unicite

Affzo [M:SNLL]
If dim([M:SNLL]SLO)>0                                                    # hcb unicite
   If GFEALOTLEV = 2 | [F:ITM]LOTMGTCOD <> 4                             # hcb unicite
      Local Char WINVSLO                                                 # hcb unicite
      WINVSLO="-K:"+num$(GLONSLO)+"X"                                    # hcb unicite
      Chgfmt [M:SNLL]SLO  With WINVSLO                                   # hcb unicite 
   Endif                                                                 # hcb unicite 
Endif                                                                    # hcb unicite 

#                                                           # Hcb 71276 deb
If dim([M:SNLL]ECCVALMAJ)>0                        
   Local Char WINVECC                        
   WINVECC="-K:"+num$(glonecs)+"X"           
   If [F:ITM]ECCSTO = 1
      Chgfmt [M:SNLL]ECCVALMAJ  With WINVECC          
      Chgfmt [M:SNLL]ECCVALMIN  With WINVECC   
   Endif                                       
   If [F:ITM]ECCSTO = 2
      Chgfmt [M:SNLL]ECCVALMIN  With WINVECC          
   Endif                                       
Endif                                           
#                                                           # Hcb 71276 fin

#
Return

############################################################
# Validation
$OK_SNLL
FIN = 1
Local Integer I
Local Char    LSLO(GLONSLO)                 # hcb 34064
If dim([M:SNLL]SLO) > 0                     # hcb 34064
   LSLO              = [M:SNLL]SLO          # hcb 34064
Endif                                       # hcb 34064



Readlock [STL]STL0=[M:SNLL]ITMREF;[M:SNLL]LOT;LSLO        # hcb 34064
If fstat = 0
  If [F:STL]VCRTYP    = 9                 &
&    [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM &
&    [F:STL]VCRLIN    = 0
     I = 0
     Filter [STO] Where ITMREF = [M:SNLL]ITMREF &
&                       STOFCY = [M:SNL1]STOFCY &
&                       LOT    = [M:SNLL]LOT    &
&                       SLO    = LSLO 
&                 Order By Key STO3
     For [STO]
         I = 1
         Break
     Next 
     Filter [STO]
     If I = 0
        Call DEBTRANS From GLOCK
        Trbegin [STL]   
        [F:STL]       = [M:SNLL]
        Case [F:ITF]STOMGTCOD
          When 3 :
             [F:STL]ACT = 1
          When 4 :
            [F:STL]POT = 100
          When Default :
            [F:STL]POT = 100
            [F:STL]ACT = 1
        Endcase
        If [F:ITM]EXYMGTCOD<2
           Raz [F:STL]REFPER, [F:STL]SHL, [F:STL]SHLDAT
           Raz [F:STL]DLU   , [F:STL]DLUDAT            # V6per
        Endif
#                                                             # hcb 71276 deb
        If [F:ITM]ECCSTO<2 & dim([F:STL]ECCVALMAJ) > 0 
           Raz [F:STL]ECCVALMAJ, [F:STL]ECCVALMIN 
        Endif
#                                                             # hcb 71276 fin

        Call REWSTL From STKLIB
        If fstat
           Call FSTA("STL") From GLOCK
           GERR = 1
           FIN  = 1
        Endif
        Commit
     Else
#   un dizso est fait predemment ...  # 51056  
#        GERR     = 2
#   Le numéro de lot existe déjà pour cet article
#        GMESSAGE = mess(19,196,1)
#        FIN = 0
     Endif
  Endif
Else
  Call DEBTRANS From GLOCK
  Trbegin [STL]   
  Raz [F:STL]
  [F:STL]          = [M:SNLL]
  [F:STL]VCRTYP    = 9
  [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
  [F:STL]VCRLIN    = 0
  If [F:ITM]EXYMGTCOD<2
     Raz [F:STL]REFPER, [F:STL]SHL, [F:STL]SHLDAT
     Raz [F:STL]DLU   , [F:STL]DLUDAT            # V6per
  Endif
#                                                             # hcb 71276 deb
  If [F:ITM]ECCSTO<2 & dim([F:STL]ECCVALMAJ) > 0 
     Raz [F:STL]ECCVALMAJ, [F:STL]ECCVALMIN 
  Endif
#                                                             # hcb 71276 fin


  Case [F:ITF]STOMGTCOD
    When 3 :
       If[F:STL]ACT = 0
         [F:STL]ACT = 1
       Endif
    When 4 :
       If [F:STL]POT = 0
          [F:STL]POT = 100
       Endif
    When Default :
       If [F:STL]POT = 0
          [F:STL]POT = 100
       Endif
       If [F:STL]ACT = 0
          [F:STL]ACT = 1
       Endif
  Endcase  
# [F:STL]REFPER    = date$ 
  [F:STL]LOTCREDAT = date$
  Call ECRSTL From STKLIB
  If fstat
    Call FSTA("STL") From GLOCK
    GERR = 1
    FIN  = 1
  Endif
  Raz [F:SLF]                    # hcb 93726
  [F:SLF]       = [F:STL]
  [F:SLF]STOFCY = [M:SNL1]STOFCY
  Call ECRSLF From STKLIB
  If fstat
     Call FSTA("SLF") From GLOCK
     GERR = 1
     FIN  = 1
  Endif
#flag creation STOLOT à oui
  [M:SNL1]STLFLG(LLIG) = 2
  Commit 
Endif
#                                                             # hcb 71276 deb
If dim([M:SNLL]ECCVALMAJ)>0                        
   If [M:SNL1]ECCVALMAJ(LLIG) <> [M:SNLL]ECCVALMAJ
      [M:SNL1]ECCVALMAJ(LLIG) =  [M:SNLL]ECCVALMAJ
      Affzo [M:SNL1]ECCVALMAJ (LLIG)
   Endif
Endif
If dim([M:SNLL]ECCVALMIN)>0                        
   If [M:SNL1]ECCVALMIN(LLIG) <> [M:SNLL]ECCVALMIN
      [M:SNL1]ECCVALMIN(LLIG) =  [M:SNLL]ECCVALMIN
      Affzo [M:SNL1]ECCVALMIN (LLIG)
   Endif
Endif
#                                                             # hcb 71276 fin

Return
############################################################
$ABA_SNLL
Return
############################################################
$END_SNLL
If GOUVINVL=1
   Call MESSAGE(mess(17,184,1)) From GESECRAN
   FIN = 0
Endif
Return
############################################################

############################################################
# hcb 31134   deb
$FINSAI                                 
mkstat = 4

Return
# hcb 31134   fin


$FIN_SNLL

Return

$INIT_STL
Local    Integer  WCOD 
Local    Date     WREF 
Local    Integer  WSHL 
Local    Date     WPER
Local    Date     WEXY
Local    Decimal  WDLU
Local    Integer  WLTI

Raz [F:STL]
[F:STL]VCRTYP    = 9                 
[F:STL]VCRNUM    = [M:SNL1]CUNLISNUM  
[F:STL]VCRLIN    = 0
[F:STL]SHLUOM    = [F:ITM]SHLUOM     # V6per
[F:STL]DLU       = [F:ITF]DLU        # V6per
[F:STL]SHLLTIUOM = [F:ITF]SHLLTIUOM  # V6per
[F:STL]SHL       = [F:ITM]SHL        # V6per
[F:STL]SHLLTI    = [F:ITF]SHLLTI     # V6per

If [F:STL]REFPER  = [0/0/0] 
   [F:STL]REFPER  = [M:SNL0]IPTDAT 
Endif
If dim([F:ITM]EXYMGTCOD) > 0
    If [F:ITM]EXYMGTCOD < 2
        [F:STL]SHLDAT         = [31/12/2999]
        [F:STL]NEWLTIDAT      = [31/12/2999]
        [F:STL]DLUDAT         = [31/12/2999]
    Else
        WCOD = [F:ITM]EXYMGTCOD
        WREF = [F:STL]REFPER 
        WEXY = [F:STL]SHLDAT 
        WSHL = [F:STL]SHL    
        WUOM = [F:STL]SHLUOM 
        WDLU = [F:STL]DLU    

        Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
        [F:STL]SHLDAT         = WPER
        WEXY = [F:STL]SHLDAT 
        Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
        [F:STL]DLUDAT         = WPER

        WSHL = [F:STL]SHLLTI 
        WUOM = [F:STL]SHLLTIUOM
        Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
        [F:STL]NEWLTIDAT      = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
        If [F:STL]NEWLTIDAT <> [31/12/2999]
           If [F:STL]NEWLTIDAT  > [F:STL]DLUDAT  
              [F:STL]NEWLTIDAT  = [F:STL]DLUDAT
           Endif
        Endif
    Endif
Else
    [F:STL]SHLDAT       = [31/12/2999]
    [F:STL]NEWLTIDAT    = [31/12/2999]
    [F:STL]DLUDAT       = [31/12/2999]
Endif

Return

################################################# Action champ ###


Subprog C_ACT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   mkstat = 2
Endif   

End

Subprog AS_POT(VALEUR)
Variable Decimal VALEUR
If [M:SNLL]LOTEXI <> 2 
   If [F:ITF]STOMGTCOD = 3 
       VALEUR = [F:ITM]DEFPOT
   Endif
Endif

End

Subprog C_POT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   mkstat = 2
Endif   

End

Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999]
  mkstat = 2
Endif
If [F:ITM]EXYMGTCOD > 1 & VALEUR = [0/0/0]   # hcb typ6 
   mkstat = 2
Endif

End


Subprog C_REFPER(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999]
  mkstat = 2
Endif

End




Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = VALEUR
Local    Integer  WSHL : WSHL = [M:SNLL]SHL
Local    Integer  WUOM : WUOM = [M:SNLL]SHLUOM
Local    Decimal  WDLU : WDLU = [M:SNLL]DLU 
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]SHLDAT = WPER
Affzo [M:SNLL]SHLDAT
WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SNLL]DLUDAT = WPER
Affzo [M:SNLL]DLUDAT
[M:SNLL]DLULTI = WLTI
Affzo [M:SNLL]DLULTI


WSHL = [M:SNLL]SHLLTI
WUOM = [M:SNLL]SHLLTIUOM
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
      [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT  
   Endif
Endif
Affzo [M:SNLL]NEWLTIDAT


End

Subprog AM_SHL(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Integer  WSHL : WSHL = VALEUR
Local    Integer  WUOM : WUOM = [M:SNLL]SHLUOM
Local    Decimal  WDLU : WDLU = [M:SNLL]DLU 
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]SHLDAT = WPER
Affzo [M:SNLL]SHLDAT

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SNLL]DLUDAT = WPER
Affzo [M:SNLL]DLUDAT
[M:SNLL]DLULTI = WLTI
Affzo [M:SNLL]DLULTI

End

Subprog AM_SHLUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Integer  WSHL : WSHL = [M:SNLL]SHL
Local    Decimal  WDLU : WDLU = [M:SNLL]DLU 
Local    Integer  WUOM : WUOM = VALEUR
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]SHLDAT = WPER
Affzo [M:SNLL]SHLDAT

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SNLL]DLUDAT = WPER
Affzo [M:SNLL]DLUDAT
[M:SNLL]DLULTI = WLTI
Affzo [M:SNLL]DLULTI


WSHL = [M:SNLL]SHLLTI
WUOM = [M:SNLL]SHLLTIUOM
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
      [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT  
   Endif
Endif
Affzo [M:SNLL]NEWLTIDAT


End

Subprog AM_DLU(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Integer  WSHL : WSHL = [M:SNLL]SHL
Local    Integer  WUOM : WUOM = [M:SNLL]SHLUOM
Local    Decimal  WDLU : WDLU = VALEUR 
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


WEXY = [M:SNLL]SHLDAT
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SNLL]DLUDAT = WPER
Affzo [M:SNLL]DLUDAT
[M:SNLL]DLULTI = WLTI
Affzo [M:SNLL]DLULTI
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
      [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT 
      Affzo [M:SNLL]NEWLTIDAT
   Endif
Endif
End

Subprog AM_DLUDAT(VALEUR)
Variable Date    VALEUR
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > VALEUR 
      [M:SNLL]NEWLTIDAT  = VALEUR   
      Affzo [M:SNLL]NEWLTIDAT
   Endif
Endif
[M:SNLL]DLULTI     =  nday(VALEUR) -nday([M:SNLL]REFPER)
Affzo [M:SNLL]DLULTI

End

Subprog AM_SHLLTI(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Integer  WSHL : WSHL = VALEUR
Local    Date     WPER
Local    Integer  WUOM : WUOM = [M:SNLL]SHLLTIUOM
Local    Integer OK
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
      Call AVERTIR(mess(309,184,1),OK) From GESECRAN  # Date re-contrôle  > date limite utilisation ! 
      [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT  
   Endif
Endif
Affzo [M:SNLL]NEWLTIDAT

End

Subprog AM_SHLLTIUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Integer  WSHL : WSHL = [M:SNLL]SHLLTI
Local    Date     WPER
Local    Integer  WUOM : WUOM = VALEUR
Local    Integer OK
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SNLL]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
If [M:SNLL]NEWLTIDAT <> [31/12/2999]
   If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
      Call AVERTIR(mess(309,184,1),OK) From GESECRAN  # Date re-contrôle  > date limite utilisation ! 
      [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT  
   Endif
Endif
Affzo [M:SNLL]NEWLTIDAT
End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [31/12/2999]
   If VALEUR > [M:SNLL]DLUDAT
      GMESSAGE=mess(309,184,1)  # Date re-contrôle  > date limite utilisation ! 
      mkstat = 2
   Endif
Endif
End

Subprog C_DLU(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0 | VALEUR = 0
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
Endif
End

Subprog C_DLUDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:SNLL]SHLDAT
   GMESSAGE=mess(313,184,1)  # Date re-contrôle  > date limite peremption ! 
   mkstat = 2
Endif

End


Subprog AM_SHLDAT(VALEUR)
Variable Date    VALEUR

Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Decimal  WDLU : WDLU = [M:SNLL]DLU 
Local    Date     WREF : WREF = [M:SNLL]REFPER
Local    Date     WPER
Local    Date     WEXY : WEXY = VALEUR  
Local    Integer  WSHL : WSHL = [M:SNLL]SHL
Local    Integer  WUOM : WUOM = [M:SNLL]SHLUOM
Local    Integer  WLTI 

If [F:ITM]EXYMGTCOD = 6
   # recalcul reference date peremption 
   Call CALREF(WCOD,WEXY,WSHL,WUOM,"",WPER) From STKLIB
   [M:SNLL]REFPER = WPER
   WREF           = [M:SNLL]REFPER
   Affzo [M:SNLL]REFPER
Endif

Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SNLL]DLUDAT = WPER
Affzo [M:SNLL]DLUDAT
[M:SNLL]DLULTI = WLTI
Affzo [M:SNLL]DLULTI


If [F:ITM]EXYMGTCOD = 6
   # recalcul date limite utilisation
   WUOM = [M:SNLL]SHLLTIUOM 
   WSHL = [M:SNLL]SHLLTI
   Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
   [M:SNLL]NEWLTIDAT = WPER
   # si date recontrole > date limite utilisation : date recontrole = date limite utilisation 
   If [M:SNLL]NEWLTIDAT <> [31/12/2999]     # date recontrole
      If [M:SNLL]NEWLTIDAT  > [M:SNLL]DLUDAT 
         [M:SNLL]NEWLTIDAT  = [M:SNLL]DLUDAT  
      Endif
   Endif
   Affzo [M:SNLL]NEWLTIDAT
Endif

End


