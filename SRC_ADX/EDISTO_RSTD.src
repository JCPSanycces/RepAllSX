#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
         When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
         When "AREAD_AFTER"           : Gosub AREAD_AFTER
      Endcase
    When "EST"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EST_AREAD_AFTER
      Endcase
    When "EST.ESTE"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EST_ESTE_AREAD_AFTER
      Endcase
    When "EST.ESTF"
      Case [L]AEVENT
         When "AREAD_AFTER"           : Gosub EST_ESTF_AREAD_AFTER
      Endcase
    When "EST.ESTU"
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub EST_ESTU_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "EST.PTCCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EST_PTCCOD_PROPAGATE
      Endcase
    When "EST.PARCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EST_PARCOD_PROPAGATE
      Endcase
    When "EST.FLOCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EST_FLOCOD_PROPAGATE
      Endcase
    When "EST.FLOREL" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EST_FLOREL_PROPAGATE
      Endcase
    When "EST.CATCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EST_CATCOD_PROPAGATE
      Endcase
  Endcase
Return

####################################################################
$EST_PTCCOD_PROPAGATE
  this.APARENT.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
Return

####################################################################
$EST_PARCOD_PROPAGATE
  this.APARENT.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
Return

####################################################################
$EST_FLOCOD_PROPAGATE
  this.APARENT.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
Return

####################################################################
$EST_FLOREL_PROPAGATE
  this.APARENT.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
Return

####################################################################
$EST_CATCOD_PROPAGATE
  this.APARENT.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
Return

####################################################################



#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#
#********************************************************************
$AQUERY_TRANS_AFTER
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.EST.PTCCOD,"PTCDES")
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EST.PARCOD,"PARDES")
  this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.EST.FLOCOD,this.EST.FLOREL,"FLODES")
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EST.CATCOD,"CATDES")
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#
#********************************************************************
$AREAD_AFTER
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.EST.PTCCOD,"PTCDES")
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EST.PARCOD,"PARDES")
  this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.EST.FLOCOD,this.EST.FLOREL,"FLODES")
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EST.CATCOD,"CATDES")

  If this.EST.TESTFLG = [V]CST_AYES
    [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)
    [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3URL",[V]CST_AFFLNKPAG)
  Else
    #link managment
    #test : CRUD or IMPORT
    Local Integer I
    Local Integer WFLG_QRY  : WFLG_QRY = [V]CST_AFALSE
    Local Integer WFLG_CRUD : WFLG_CRUD = [V]CST_AFALSE
    #by default
    this.VIEWX3URL = "http://"
    #rechercher s'il y a une ligne query dans le detail flux
    For I = 1 To maxtab(this.EST.ESTF)
      If this.EST.ESTF(I).MSGTYP = 1 #Query
        WFLG_QRY  = [V]CST_ATRUE
        Break
      Endif
    Next I
    If WFLG_QRY = [V]CST_ATRUE #Query
      If this.EST.STA <> 3 #M2003 Terminé
        [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)
        [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3URL",[V]CST_AFFLNKPAG)
      Else #terminé
        For I = 1 To maxtab(this.EST.ESTU)
          If this.EST.ESTU(I).CODE = "CRUDFILE1"
            WFLG_CRUD = [V]CST_ATRUE
            Break
          Endif
        Next I
        If WFLG_CRUD = [V]CST_AFALSE
          [L]ASTATUS = fmet this.ASETLINKENABLE("VIEWX3",[V]CST_AFFLNKPAG)
          [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3URL",[V]CST_AFFLNKPAG)
        Else # WFLG_CRUD = [V]CST_ATRUE # CRUDFILE1
          Gosub GENERATE_LINK_VIEWX3URL
          [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)
          #[L]ASTATUS = fmet this.ASETLINKENABLE("VIEWX3URL",[V]CST_AFFLNKPAG) #Issue US X3-112584 - 2018-10-12 by RBA : Representation link in SAS
          #Issue US X3-112584 - 2018-10-12 by RBA : Representation link in SAS
          If func DOCEXIST(WCATTRGTAB, WDESCRIPT, WTABKEY, WTABKEYVAL) = [V]CST_ATRUE
            #link can be displayed
            [L]ASTATUS = fmet this.ASETLINKENABLE("VIEWX3",[V]CST_AFFLNKPAG)
          Else
            #link cannot be displayed
            [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)
          Endif
          #/Issue US X3-112584
        Endif
      Endif
    Else # pas query
      [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)
      [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3URL",[V]CST_AFFLNKPAG)
      #not query
      # 2 = attachment
      # 3 = sdata A SUPPRIMER
    Endif
  Endif
Return

#********************************************************************
# Method EST_AREAD_AFTER
#********************************************************************
#
#********************************************************************
$EST_AREAD_AFTER
  Call EST_DISPLAY(this)
Return




#********************************************************************
# Method EST_ESTE_AREAD_AFTER
#********************************************************************
#
#********************************************************************
$EST_ESTE_AREAD_AFTER
  Local Integer I
  Local Integer WOK : WOK = [V]CST_AOK

  this.DES = mess(this.MSGNUM,2017,1)
Return

#********************************************************************
# Method EST_ESTF_AREAD_AFTER
#********************************************************************
#
#********************************************************************
$EST_ESTF_AREAD_AFTER
  If this.MSGTYP = 1 #Query
    Gosub GENERATE_LINK_QUERY
  Else
    #not query
    # 2 = attachment
    # 3 = sdata A SUPPRIMER
  Endif
#      [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKPAG)    #[V]CST_AFFLNKREC and [V]CST_AFFLNKPAG
#      [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3",[V]CST_AFFLNKREC)    #[V]CST_AFFLNKREC and [V]CST_AFFLNKPAG
#      [L]ASTATUS = fmet this.ASETLINKDISABLE("VIEWX3REP",[V]CST_AFFLNKREC)
Return


$GENERATE_LINK_QUERY
  Local Char WUUID(36)
  If this.APARENT.CATACT = 1 #send
    WUUID = ""
  Else #receive
    Local Integer WPOS_MES
    WPOS_MES = this.AORDER
    Local File EDISTOU [ESTU]
    Filter [ESTU] Where [ESTU]NUMBATCH = this.NUMBATCH and [ESTU]KEYDOC = this.KEYDOC and [ESTU]CODE = "INSFILE"+num$(WPOS_MES)
    For [ESTU]
      WUUID = num$([ESTU]DOCUUID)
      Break
    Next
    LogicClose File [ESTU]
  Endif

  #url to generate
  Local Clbfile WURL
  #key to use
  Local Char WKEYVALUE(100) : WKEYVALUE = this.APARENT.KEYDOC

  #recuperer les infos de la categorie
  Local Integer WCATTYP
  Local Char WCATTRGTAB(12)
  Local Char WDESCRIPT(120)

  Local File EDICAT [ECA]
  Read [ECA]ECA0 = this.APARENT.CATCOD
  If !fstat
    WCATTYP    = [ECA]CATTYP #M2012
    WCATTRGTAB = [ECA]CATTRGTAB
    WDESCRIPT  = [ECA]DESCRIPT
  Else
    #error
    Return
  Endif
  LogicClose File [ECA]

  Local Char WTABKEY(50)(1..10) #V9
  Local Char WTABKEYVAL(50)(1..10) #V9
  #keys
  Local Integer WPOS, I, J
  #Get keys from index descriptor
  J = 1
  For I = 1 To len(WDESCRIPT)
    WPOS = instr(I, WDESCRIPT, "+")
    If WPOS > 0
      WTABKEY(J) = left$(WDESCRIPT, WPOS-1)
      J = J +1
      WDESCRIPT = right$(WDESCRIPT, WPOS+1)
    Endif
  Next I
  If WPOS <= 0
    WTABKEY(J) = WDESCRIPT
  Endif
  WPOS = 0
  #Get key values from key value field
  J = 1
  For I = 1 To len(WKEYVALUE)
#    WPOS = instr(I, WKEYVALUE, "~") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    WPOS = instr(I, WKEYVALUE, "!") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    If WPOS > 0
      WTABKEYVAL(J) = left$(WKEYVALUE, WPOS-1)
      J = J +1
      WKEYVALUE = right$(WKEYVALUE, WPOS+1)
    Endif
  Next I
  If WPOS <= 0
    WTABKEYVAL(J) = WKEYVALUE
  Endif


  ############################################
  #Set parameters for url
  Local Char WTABPAR(50)(1..10)
  Local Char WTABPARVAL(250)(1..10)
  Local Char WPARAM(250)

  ############################################
  #representation to use for X3 Document URLDOCX3
  Local Integer WFLG_URL : WFLG_URL = [V]CST_ATRUE #RBA
  Local Char WREPRESX3(30)  #for X3 document
  Case WCATTYP #M2012
    When 1 : WREPRESX3 = "SDELIVERY" #1 Purchase invoice
    When 2 : WREPRESX3 = "SINVOICEV" #2 Sales invoice
    When 3 : WREPRESX3 = "PORDER"    #3 Purchase order
    When 4 : WREPRESX3 = "SORDER"    #4 Sales order
    When 5 : WREPRESX3 = "SDELIVERY" #5 Sales delivery
    When 6 : WREPRESX3 = "EDIDEB"    #6 Intrasat #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat
    When 7 : WREPRESX3 = "SDELIVERYNO"  #7 Sales delivery notification
    When Default : WFLG_URL = [V]CST_AFALSE #RBA
  Endcase
#        When 7 : WREPRESX3 = "SDELIVERYNO" #5 Sales delivery RBA
  #Set parameters -> no parameters for the URLDOCX3
  Raz WTABPAR
  Raz WTABPARVAL
  Raz WPARAM
  #generate X3 url
  If WFLG_URL = [V]CST_ATRUE #RBA
    ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE,WREPRESX3,[V]CST_AFAC_DETAILS,WTABKEY,WTABKEYVAL,WTABPAR,WTABPARVAL,WURL)
    this.URLDOCX3 = WURL
  Else #RBA
    this.URLDOCX3 = "http://" #RBA
  Endif #RBA
  ############################################
Return

$GENERATE_LINK_VIEWX3URL
  #url to generate
  Local Clbfile WURL
  #key to use
  Local Char WKEYVALUE(100) : WKEYVALUE = this.EST.KEYDOC

  #recuperer les infos de la categorie
  Local Integer WCATTYP
  Local Char WCATTRGTAB(12)
  Local Char WDESCRIPT(120)

  Local File EDICAT [ECA]
  Read [ECA]ECA0 = this.EST.CATCOD
  If !fstat
    WCATTYP    = [ECA]CATTYP #M2012
    WCATTRGTAB = [ECA]CATTRGTAB
    WDESCRIPT  = [ECA]DESCRIPT
  Else
    #error
    Return
  Endif
  LogicClose File [ECA]

  Local Char WTABKEY(50)(1..10) #V9
  Local Char WTABKEYVAL(50)(1..10) #V9
  #keys
  Local Integer WPOS, I, J
  #Get keys from index descriptor
  J = 1
  For I = 1 To len(WDESCRIPT)
    WPOS = instr(I, WDESCRIPT, "+")
    If WPOS > 0
      WTABKEY(J) = left$(WDESCRIPT, WPOS-1)
      J = J +1
      WDESCRIPT = right$(WDESCRIPT, WPOS+1)
    Endif
  Next I
  If WPOS <= 0
    WTABKEY(J) = WDESCRIPT
  Endif
  WPOS = 0
  #Get key values from key value field
  J = 1
  For I = 1 To len(WKEYVALUE)
#    WPOS = instr(I, WKEYVALUE, "~") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    WPOS = instr(I, WKEYVALUE, "!") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    If WPOS > 0
      WTABKEYVAL(J) = left$(WKEYVALUE, WPOS-1)
      J = J +1
      WKEYVALUE = right$(WKEYVALUE, WPOS+1)
    Endif
  Next I
  If WPOS <= 0
    WTABKEYVAL(J) = WKEYVALUE
  Endif

  ############################################
  #Set parameters for url
  Local Char WTABPAR(50)(1..10)
  Local Char WTABPARVAL(250)(1..10)
  Local Char WPARAM(250)

  ############################################
  #representation to use for X3 Document VIEWX3URL
  Local Integer WFLG_URL : WFLG_URL = [V]CST_ATRUE #RBA
  Local Char WREPRESX3(30)  #for X3 document
  Case WCATTYP #M2012
    When 1 : WREPRESX3 = "SDELIVERY" #1 Purchase invoice
    When 2 : WREPRESX3 = "SINVOICEV" #2 Sales invoice
    When 3 : WREPRESX3 = "PORDER"    #3 Purchase order
    When 4 : WREPRESX3 = "SORDER"    #4 Sales order
    When 5 : WREPRESX3 = "SDELIVERY" #5 Sales delivery
    When 6 : WREPRESX3 = "EDIDEB"    #6 Intrasat #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat
    When 7 : WREPRESX3 = "SDELIVERYNO" #7 Sales delivery notification
    When Default : WFLG_URL = [V]CST_AFALSE #RBA
  Endcase
#        When 7 : WREPRESX3 = "SDELIVERYNO" #5 Sales delivery RBA
  #Set parameters -> no parameters for the VIEWX3URL
  Raz WTABPAR
  Raz WTABPARVAL
  Raz WPARAM
  #generate X3 url
  If WFLG_URL = [V]CST_ATRUE #RBA
    ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE,WREPRESX3,[V]CST_AFAC_DETAILS,WTABKEY,WTABKEYVAL,WTABPAR,WTABPARVAL,WURL)
    this.VIEWX3URL = WURL
  Else #RBA
    this.VIEWX3URL = "http://" #RBA
  Endif #RBA
  ############################################
Return


Funprog DOCEXIST(WCATTRGTAB, WDESCRIPT, WTABKEY, WTABKEYVAL)
Variable Char WCATTRGTAB
Variable Char WDESCRIPT
Variable Char WTABKEY()
Variable Char WTABKEYVAL()

  Local Integer WFLG_DOCEXIST : WFLG_DOCEXIST = [V]CST_AFALSE
#  Local Char WCATTRGTAB(30)      : WCATTRGTAB    = "SINVOICE"
#  Local Char WDESCRIPT(30)       : WDESCRIPT     = "SIH0"
#  Local Char WTABKEY(30)(1..)    : WTABKEY(1)    = "NUM"
#  Local Char WTABKEYVAL(30)(1..) : WTABKEYVAL(1) = "FAC-SP10115-000004"

  Local File =WCATTRGTAB [MYTAB]
  If WTABKEY(4) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WTABKEY(1)) = WTABKEYVAL(1) and
&       evalue("[MYTAB]"+WTABKEY(2)) = WTABKEYVAL(2) and
&       evalue("[MYTAB]"+WTABKEY(3)) = WTABKEYVAL(3) and
&       evalue("[MYTAB]"+WTABKEY(4)) = WTABKEYVAL(4)
  Elsif WTABKEY(3) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WTABKEY(1)) = WTABKEYVAL(1) and
&       evalue("[MYTAB]"+WTABKEY(2)) = WTABKEYVAL(2) and
&       evalue("[MYTAB]"+WTABKEY(3)) = WTABKEYVAL(3)
  Elsif WTABKEY(2) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WTABKEY(1)) = WTABKEYVAL(1) and
&       evalue("[MYTAB]"+WTABKEY(2)) = WTABKEYVAL(2)
  Elsif WTABKEY(1) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WTABKEY(1)) = WTABKEYVAL(1)
  Endif

  For [MYTAB]
    WFLG_DOCEXIST = [V]CST_ATRUE
    Break
  Next
  LogicClose File [MYTAB]

End WFLG_DOCEXIST

#********************************************************************
# Subprog EST_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT --> OBJECT
#*!
Subprog EST_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(20)
  WPROP = "$isHidden"

  If WOBJECT.CATACT = 2 # Receipt
    WOK = fmet WOBJECT.ASETATTRIBUTE('EXTKEYDOC', WPROP, 'false')
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE('EXTKEYDOC', WPROP, 'true')
  Endif
End
