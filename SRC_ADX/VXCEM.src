#<AdxTL>@(#)3.0.0.0 $Revision$
#consultation des emplacements par terminaux VT
########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "BOUTON"        : Gosub BOUTON
 When "SETBOUT"       : Gosub SETBOUT
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

Local Char WFIL(250)
Local Char WFILS(250)
Local Char WFILE(250)
Local Char SVGLOT(GLONLOT)
Local Char SVGSLO(GLONSLO)
Local Char SVGLOC(GLONLOC)
Local Char SVGLOC1(GLONLOC)   # hcb 65909
Local Integer SVGCAT          # hcb 65909



If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif
If clalev([F:STC]) = 0 : Local File STOLOC [STC] : Endif
GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Return

########################################################
$DEBUT

Local Integer WOK, WCPT, LRET
Local Decimal WSVGQTY

If GXAFCY="" 
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN=1 : Return
Endif

Raz [M:XCEM]

Return
########################################################
$APRES_MODIF
WFILS = "1=1"

Gosub REMP_TAB

Return
########################################################
$BOUTON

# page suivante

If BOUT="1" Gosub PAGESUIV Endif

If BOUT="2" Gosub EMPSUIV Endif

Return

########################################################
$REMP_TAB
SVGLOC1 = [M:XCEM]LOC      # hcb 65909
SVGCAT  = [M:XCEM]LOCCAT   # hcb 65909
Raz [M:XCEM]               # hcb 65909
[M:XCEM]LOC    = SVGLOC1   # hcb 65909
[M:XCEM]LOCCAT = SVGCAT    # hcb 65909

WFIL= "1=1"
If [M:XCEM]LOC <> "" 
         WFIL += "& [F:STO1]LOC=[M:XCEM]LOC"
Endif

If GXAFCY <> ""
    WFIL += "& [F:STO1]STOFCY = GXAFCY & QTYSTU <> 0"
Endif 



Filter [STO1] Where evalue(WFIL) & evalue(WFILS)
&                            Order By Key STO3 Asc

nolign = 0
Raz [M:XCEM]NBLIG
For [STO1] 
    If nolign < dim([M:XCEM]STA)
        nolign += 1
        [M:XCEM]ITMREF(nolign-1)=[F:STO1]ITMREF
        [M:XCEM]LOT(nolign-1)=[F:STO1]LOT
        [M:XCEM]SLO(nolign-1)=[F:STO1]SLO
        [M:XCEM]SERNUM(nolign-1)=[F:STO1]SERNUM
        [M:XCEM]QTYPCU(nolign-1)=[F:STO1]QTYPCU
        [M:XCEM]PCU(nolign-1)=[F:STO1]PCU
        [M:XCEM]QTYSTU(nolign-1)=[F:STO1]QTYSTU
        [M:XCEM]CUMALLQTY(nolign-1)=[F:STO1]CUMALLQTY
        [M:XCEM]STA(nolign-1)=[F:STO1]STA
        [M:XCEM]PALNUM(nolign-1)=[F:STO1]PALNUM
        [M:XCEM]CTRNUM(nolign-1)=[F:STO1]CTRNUM
        [M:XCEM]QLYCTLDEM(nolign-1)=[F:STO1]QLYCTLDEM
        [M:XCEM]OWNER(nolign-1)=[F:STO1]OWNER
        [M:XCEM]NBLIG+=1
        #sauvegarde des infos de la derniere ligne du tableau
        SVGITM = [M:XCEM]ITMREF(nolign-1)
        SVGLOT = [M:XCEM]LOT(nolign-1)
        SVGSLO = [M:XCEM]SLO(nolign-1)
    Endif
Next

#--- Bug 59424
Affzo[M]1-99
#---

Return

########################################################
$PAGESUIV
WFILS="(([F:STO1]ITMREF= SVGITM & [F:STO1]LOT = SVGLOT  & [F:STO1]SLO > SVGSLO )"
WFILS += "|([F:STO1]ITMREF= SVGITM & [F:STO1]LOT > SVGLOT  )"
WFILS += "|([F:STO1]ITMREF>SVGITM  ))"

Gosub REMP_TAB
Return
########################################################
$EMPSUIV

WFILS = "1=1"
If [M:XCEM]LOC <> ""

    WFILE = "[F:STC]STOFCY=GXAFCY & [F:STC]LOC >[M:XCEM]LOC "
        Filter [STC] Where evalue(WFILE) 
&                            Order By Key STC0 Asc

    Read[STC]First 
    If fstat = 4
       Call VIREBOUT(CHMEN, '2') From GOBJET
    Elsif fstat = 0
        [M:XCEM]LOC = [F:STC]LOC
        [M:XCEM]LOCCAT = [F:STC]LOCCAT
        Gosub REMP_TAB
    Endif
    
    Filter[STC]
Endif
   
Return

########################################################
$SETBOUT

If [M:XCEM]NBLIG < dim([M:XCEM]STA)
   Call VIREBOUT(CHMEN, '1') From GOBJET
Else
   CHMEN += '1'
Endif


Return
########################################################
$FIN
GVTMOD=0

Return


########################################################
# Actions champs
########################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXCEM) 09/07/2008 13:31:47 (MAE)
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:XCEM]ITMREF = VALEUR
End

######################################################################################





######################################################################################
## Etiquette ajoutée par le superviseur (écran VXCEM) 11/07/2008 10:04:42 (MAE)
######################################################################################
Subprog AP_LOC(VALEUR)
Variable Char    VALEUR()
[M:XCEM]LOC=VALEUR
Read[STC]STC0 = GXAFCY;[M:XCEM]LOC
[M:XCEM]LOCCAT = [F:STC]LOCCAT
End


######################################################################################

