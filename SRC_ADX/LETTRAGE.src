#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "1"
Call SAISIE_CHAR(VALEUR,PARAM,"FMTC","LETTRAGE","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "OK"           : Gosub ENTREE
 When "RAF"          : Gosub RAFFRAICHIR
 When "END"          : Gosub FIN
 When "BOUTON"       : Gosub EXEBOUT
 When "MEN"          : Gosub EXEBOUT
 When "AVANT_BOUT"   : Gosub AVANT_BOUT
 When "AVANT_MEN"    : Gosub AVANT_BOUT
 When "FINSAI"       : Gosub FINSAI
 When Default
Endcase
Return

$OUVRE
Local Integer CLECUR, OK
Local Char    CRITERE(250) , SOCIETE(GLONCPY) , SITE(GLONFCY) , SITCUR(GLONFCY)
Local Char    COMPTE(GLONGAC) , TIERS(GLONBPR) , SYMBCPT(50)
Local Char    CPTCUR(GLONGAC) , BPRCUR(GLONBPR)
Local Date    DATDEBCUR, DATFINCUR
Local Char    MESSAGE(250) , PCETYP(GLONGTE)(1..10) , PCENUM(GLONVCR)(1..10)
Local Char    MESSAGE(250) , XPCETYP(GLONGTE)(1..10) , XPCENUM(GLONVCR)(1..10)
Local Integer MAXECT
Local Integer XNBPCE
Local Integer CAS , FLDEV , PLEIN , STA
Local Integer I , J , K
Local Integer W, X, Y, Z
Local Integer ECRLET
Local Integer MINECT
Local Date    SAVD1 , SAVD2 , SAVC1 , SAVC2
Local Integer SUITE , RETOUR, NBACC
Local Char    VALPAR(30)
Local Date DATEVT
Local Char    FILT(250)
Local Mask LETTRECH [LTE] , LETTCRIT [LTC] , LETTMONT [LTM] , LETTPT [LTP]

If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0  : Local File GLED       [LED] : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE] : Endif
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2]: Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD] : Endif
If clalev([F:MTC])=0  : Local File MATCHCODE  [MTC] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE] : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB] : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATY])=0  : Local File ATYPE      [ATY] : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW] : Endif

# Suggestion liée au TRI
 Local Mask TRILETTR [TLT] : # Critères de tri
 Raz [M:TLT]

 # Variable de critères de tri
    Local Char CRITERE1(250), CRITERE2(250)
    Local Integer TRIOK

 # Définition de l'ordre de tri
    Local Char ORDRE(250)
    Gosub INIT_TRI From SUBTLT
    Call LECMEMO("STD","[M:TLT]","trl") From GMEMO
Return

$DEBUT
Default Mask [LTR]

Raz [M:LTR] : Raz [M:LTP]
MAXECT = dim([M:LTR]ACCNUM)

pcolor = GCOUL(0)
GMODIF = 0
If val(PARAM(1))<1 : PARAM(1) = "1" : Endif
[M:LTR]LEDTYP = val(PARAM(1))
# Variables pour propagation du lettrage
Local Integer R , XNBECH
Local Integer XACCNUM(1..MAXECT)
Local Integer XDUDLIG(1..MAXECT)
Local Decimal XAMTIPT(1..MAXECT)
Return

$SETBOUT
Raz CHMEN , CHBOU
CHMEN += "V"    :#Recherche
###
If CLECUR
 If ECRLET=0
  If [M:LTR]VERROU
   If [M:LTP]NBLET>=2 or ([M:LTP]NBLET=1 & [M:LTR]SOLDE=0)
    CHMEN += "G" : # Lettrage
   Endif
   CHMEN += "1"  : # Auto
   CHMEN += "4"  : # Inversion
  Endif
  CHMEN += "O" : # Non lettrées
  If [M:LTR]NBLIG>0 : CHMEN +="U"  : Endif   # Tri
 Else
  CHMEN += "N" : # Lettrées
 Endif
 CHMEN += "3" : # Recherche
 CHBOU += ">" : # Suivant
 CHBOU += "<" : # Précédent
Endif
CHMEN += "2" : # Critères
If SUITE  : CHMEN += "S" : Endif : # Suite
If RETOUR : CHMEN += "Q" : Endif : # Retour
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
ETABOU(GRAFF) = 1 : # Raffraîchir
Return

$AVANT_BOUT
Case BOUT
 When "2" : # sauvegarde des critères
  SAVD1 = [M:LTC]DEBDATDEB
  SAVD2 = [M:LTC]DEBDATFIN
  SAVC1 = [M:LTC]CREDATDEB
  SAVC2 = [M:LTC]CREDATFIN
 When "1"
  Gosub ABORT
  If !OK : FOK = 0 : Endif
Endcase
Return

$EXEBOUT
Case BOUT
 When "O" : Gosub ECRLET
 When "N" : Gosub ECRNLET
 When "S" : Gosub PSUIV
 When "Q" : Gosub PPREC
 When "2" : Gosub CRITERES
 When "G" : Gosub VAL_LETTRAGE
 When "1" : CLECUR = 0 : Gosub LECTURE
 When "3" : Gosub RECHERCHE
 When "4" : Gosub INVERSE
 When "U" : If TRIOK=2 : Gosub RAFFRAICHIR : Endif
 When "V" : Gosub RAFFRAICHIR
###
Endcase
Return

$RAFFRAICHIR
CLECUR = 0 : Gosub LECTURE
Return

$ENTREE
FIN = 0 : # On a fait return
SUIZON = "NBLIG(0)"
Return

$APRES_MODIF
If find(COUZON,"FCY","LEDTYP","ACC","BPR","DATDEB","DATFIN")
 Gosub ABORT
 If !OK
  GERR = 2 : GMESSAGE = "#"
  Return
 Endif
 [M:LTP]NBLET = 0
 Effzo 15,20
 [M:LTR]ECRLET = [L]ECRLET
 If COUZON="LEDTYP"
  Assign "[M:LTR]"+COUZON With val(CZ) : # Une variante de zc
 Else
  Assign "[M:LTR]"+COUZON With CZ : # Une variante de zc
 Endif
Elsif COUZON="NBLIG"
 If [M:LTR]VERROU  & GMODIF=9
  Call SEL_DESEL From SUBLTR
 Endif
 GMODIF = 0
Endif
Return

#############################################
## On se tire, il faut déverrouiller
#############################################
$FIN
Gosub ABORT
If !OK
 FIN = 0
Else
 Gosub DEVERROU
Endif
Return

$FINSAI
Call UNLOCKCPY() From AX3MONO
Return

#############################################
## Abandon en cours de lettrage
#############################################
$ABORT
OK = 2
If [M:LTP]NBLET>=2 or ([M:LTP]NBLET=1 & [M:LTR]SOLDE=0)
 Call ABANDON(OK) From GESECRAN
 If OK<>2 : OK = 0 : Endif
Endif
Return

#############################################
## Rechargement si les critères ont changé
#############################################
$CRITERES
If  SAVD1<>[M:LTC]DEBDATDEB | SAVD2<>[M:LTC]DEBDATFIN
& | SAVC1<>[M:LTC]CREDATDEB | SAVC2<>[M:LTC]CREDATFIN
 CLECUR = 0 : Gosub LECTURE
Endif
Return

#############################################
## Compte suivant
#############################################
$SUIVANT
Gosub ABORT : If !OK : Return : Endif
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
COMPTE = [M:LTR]ACC
TIERS  = [M:LTR]BPR
If TIERS<>"" : COLL = 1 : Else : COLL = 0 : Endif
Gosub SETBAL

$SUIV1
If COLL
 Filter [BAL] Where LEDTYP=[M:LTR]LEDTYP & CPY=SOCIETE & FCY=SITE & ACC=COMPTE & BPR>TIERS
& Order By Key CLE=BPR
Else
 Filter [BAL] Where LEDTYP=[M:LTR]LEDTYP & CPY=SOCIETE & FCY=SITE & ACC>COMPTE
& Order By Key CLE=ACC
Endif
Read [BAL]CLE First
Filter [BAL]
If fstat>2 | (COLL=1 & [F:BAL]BPR="")
 Call ERREUR(mess(11,100,1)) From GESECRAN : Return
Endif
COMPTE = [F:BAL]ACC
TIERS  = [F:BAL]BPR
Call LECTURE("GAC",[F:BAL]ACC,[F:BAL]COA) From CONTOBJ
If fstat | [F:GAC]MTC<>2 : Goto SUIV1 : Endif
If [F:GAC]SAC=2 & COLL=0 : TIERS = "" : Goto SUIV1 : Endif
Gosub SUIVPREC
If [M:LTR]NBLIG=0 : Goto SUIVANT : Endif
Return

$SETBAL
If clalev([F:BAL])<>0 : Close Local File [BAL] : Endif
If [M:LTR]GENE=2
 Local File BALANCE [BAL]
Else
 Local File BALANA  [BAL]
Endif
Return

#############################################
## Compte précédent
#############################################
$PRECEDENT
Gosub ABORT : If !OK : Return : Endif
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
COMPTE = [M:LTR]ACC
TIERS  = [M:LTR]BPR
If TIERS<>"" : COLL = 1 : Else : COLL = 0 : Endif
Gosub SETBAL

$PREC1
If COLL
 Filter [BAL] Where LEDTYP=[M:LTR]LEDTYP & CPY=SOCIETE & FCY=SITE & ACC=COMPTE & BPR<TIERS
& Order By Key CLE=BPR
 Read [BAL]CLE Last
Else
 Filter [BAL] Where LEDTYP=[M:LTR]LEDTYP & CPY=SOCIETE & FCY=SITE & ACC<COMPTE
& Order By Key CLE=ACC
 Read [BAL]CLE Last
Endif
Filter [BAL]
If fstat>2 | (COLL=1 & [F:BAL]BPR="")
 Call ERREUR(mess(11,100,1)) From GESECRAN : Return
Endif
COMPTE = [F:BAL]ACC
TIERS  = [F:BAL]BPR
Call LECTURE("GAC",[F:BAL]ACC,[F:BAL]COA) From CONTOBJ
If fstat | [F:GAC]MTC<>2 : Goto PREC1 : Endif
If [F:GAC]SAC=2 & COLL=0 : TIERS = "" : Goto PREC1 : Endif
Gosub SUIVPREC
If [M:LTR]NBLIG=0 : Goto PRECEDENT : Endif
Return

$SUIVPREC
Effzo 10,15
[M:LTR]ECRLET = [L]ECRLET
[M:LTR]ACC = COMPTE
[M:LTR]BPR = TIERS
Gosub LECTURE
Return

#######################################
## Ecritures lettrées
#######################################
$ECRLET
Gosub ABORT : If !OK : Return : Endif
Effzo 10,15
Chgfmt [M]FLGMTC  With "-LA1:4X"
ECRLET = 1
Gosub LECTURE
Return

#######################################
## Ecritures non lettrées
#######################################
$ECRNLET
Chgfmt [M]FLGMTC  With "LA1:4X"
ECRLET = 0
Gosub LECTURE
Return

########################################
## Chargement initial
########################################
$LECTURE
SITE = [M:LTR]FCY
If SITE="" : Return : Endif
Call LECTURE("FCY",SITE,"") From CONTOBJ
SOCIETE = [F:FCY]LEGCPY
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
[M:LTR]CURCPY = [F:GCM]CUR([M:LTR]LEDTYP-1)
COMPTE = [M:LTR]ACC
If COMPTE="" : Return : Endif
TIERS = [M:LTR]BPR
Call LECTURE("GAC",COMPTE,[M:LTR]COA) From CONTOBJ
If fstat | ([F:GAC]SAC=2 & TIERS="") : Return
Elsif [F:GAC]SAC<>2 : TIERS = ""
Endif
Call PARAM(SITE,"MTCRND",VALPAR) From ADOVAL
[M:LTR]SEUIL = val(VALPAR)
If CLECUR=1 & SITE=SITCUR & COMPTE=CPTCUR & TIERS=BPRCUR & ECRLET=ECRCUR & DATDEBCUR=[M:LTR]DATDEB & DATFINCUR=[M:LTR]DATFIN
 Return
Endif
Call LECTEXTRA([M]ACCDES,"GACCOUNT","DESTRA",[M]COA,COMPTE) From ATEXTRA
[M:LTR]BPR = TIERS
Gosub DEVERROU
Gosub VERROU
Effzo [LTR]20 : [M:LTP]NBLET = 0

PLEIN = 0
J = 0
SUITE  = 0
RETOUR = 0

If ECRLET=0
 Gosub FILTRE
 Call TRI([L]ORDRE,0)
 Gosub FILTRER_DAE
 For [DAE]
  If [F:DAE]MTC=""
   Gosub OKECR
   If OK
    If J>=MAXECT
     PLEIN = 1
     Break
    Else
     J += 1
     nolign = J : Gosub CHARGE
    Endif
   Endif
  Else
# un groupe lettré minuscule doit être chargé en entier ou pas du tout
   If !find([F:DAE]MTC,[M:LTR]MTC(0..J-1))
    I = J
    Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT) Order With [L]ORDRE
    For [DAE2]
     If J>=MAXECT
      J = I
      PLEIN = 1
      Break
     Else
      J += 1
      [F:DAE] = [F:DAE2]
      Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
      nolign = J : Gosub CHARGE
     Endif
    Next
    Filter [DAE2]
    If PLEIN : Break : Endif
   Endif
  Endif
 Next
 Filter [DAE]
 [M:LTR]NBLIG = J
Else
 Gosub FILTRE
 Filter [DAE] Where evalue(CRITERE) & evalue(CRITERE1) & evalue(FILT)
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Desc; ACCNUM Asc
 For I=5 To 1 Step -1
  For [DAE] Where len(MTC)=I
   # Un groupe lettré majuscule doit être chargé en entier ou pas du tout
   If !find([F:DAE]MTC,[M:LTR]MTC(0..J-1))
    K = J
    Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT)
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Desc; ACCNUM Asc
    For [DAE2]
     If J>=MAXECT
      J = K
      PLEIN = 1
      Break
     Else
      J += 1
      [F:DAE] = [F:DAE2]
      Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
      nolign = J : Gosub CHARGE
     Endif
    Next
    Filter [DAE2]
    If PLEIN : Break 2 : Endif
   Endif
  Next
 Next I
 Filter [DAE]
 [M:LTR]NBLIG = J
Endif
If PLEIN
 SUITE = 1
Endif
[M:LTR]FCY   = SITE
[M:LTR]SOLCPT = sum([M:LTR]DEBIT(0..[M:LTR]NBLIG-1))
&              -sum([M:LTR]CREDIT(0..[M:LTR]NBLIG-1))
If [M:LTR]SOLCPT=0
 [M:LTR]SOLSNS = ""
Elsif [M:LTR]SOLCPT>0
 [M:LTR]SOLSNS = mess(1,626,1)
Else
 [M:LTR]SOLSNS = mess(2,626,1)
 [M:LTR]SOLCPT = -[M:LTR]SOLCPT
Endif
[M:LTR]SOLDEV = [M:LTR]CURCPY
If SITE<>SITCUR
 Gosub INIPAR
 SITCUR = SITE
Endif
If dim([F:GAC]DIFFLG)>0 & [F:GAC]DIFFLG=2
 [M:LTR]CURFLG = 1
Else
 [M:LTR]CURFLG = 0
Endif
[M:LTR]SOLDE   = 0
[M:LTR]SOLDLET = 0
[M:LTR]CURLET  = ""

Gosub AFFLTR From SUBLTR

If PLEIN
 # Toutes les écritures n'ont pas être chargées dans le tableau
 Call MESSAGE(mess(43,110,1)) From GESECRAN
Endif
If ![M:LTR]VERROU
 Call MESSAGE(mess(10,100,1)) From GESECRAN
 # Modification en cours sur un autre poste
Endif
CLECUR = 1
SITCUR = SITE
CPTCUR = COMPTE
BPRCUR = TIERS
ECRCUR = [L]ECRLET
DATDEBCUR = [M:LTR]DATDEB
DATFINCUR = [M:LTR]DATFIN
[M:LTR]ECRLET = [L]ECRLET
Return

############################################################
## Lecture page suivante
############################################################
$PSUIV

If ECRLET : Goto SUIV_LET : Endif
# Si ça se termine par un groupe lettré, on recommence au premier du groupe

K = [M:LTR]NBLIG-1
While K>0 & [M:LTR]MTC(K)<>"" & [M:LTR]MTC(K)=[M:LTR]MTC(K-1) : K -= 1 : Wend

Call FILTRE_TRI(CRITERE2,">",K)

# Sauvegarde de la sélection
Gosub SAUVE_LEC

Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LECTURE("GAC",COMPTE,[M:LTR]COA) From CONTOBJ

PLEIN = 0
J = MINECT
SUITE  = 0
RETOUR = 1

Call TRI([L]ORDRE,0)
Gosub FILTRER_DAE

For [DAE]
 OK = !find([F:DAE]ACCNUM,[M:LTR]ACCNUM(0..J-1))
 If OK
  If [F:DAE]MTC=""
   Gosub OKECR
   If OK
    If J>=MAXECT
     PLEIN = 1
     Break
    Else
     J += 1
     nolign = J : Gosub CHARGE
    Endif
   Endif
  Else
# un groupe lettré minuscule doit être chargé en entier ou pas du tout
# on ne prend le groupe que si on rencontre la première écriture du groupe
   If !find([F:DAE]MTC,[M:LTR]MTC(0..J-1))
    I = J
    Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT) Order With [L]ORDRE
    For [DAE2]
     If J=I & [F:DAE2]ACCNUM<>[F:DAE]ACCNUM
      Break : # Raté, c'était pas la première
     Endif
     If J>=MAXECT
      J = I
      PLEIN = 1
      Break
     Else
      J += 1
      [F:DAE] = [F:DAE2]
      Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
      nolign = J : Gosub CHARGE
     Endif
    Next
    Filter [DAE2]
    If PLEIN : Break : Endif
   Endif
  Endif
 Endif
Next
Filter [DAE]
If PLEIN
 SUITE = 1
Endif
[M:LTR]FCY   = SITE
[M:LTR]NBLIG = J

[M:LTR]SOLCPT = sum([M:LTR]DEBIT(0..[M:LTR]NBLIG-1))
&              -sum([M:LTR]CREDIT(0..[M:LTR]NBLIG-1))
If [M:LTR]SOLCPT=0
 [M:LTR]SOLSNS = ""
Elsif [M:LTR]SOLCPT>0
 [M:LTR]SOLSNS = mess(1,626,1)
Else
 [M:LTR]SOLSNS = mess(2,626,1)
 [M:LTR]SOLCPT = -[M:LTR]SOLCPT
Endif
[M:LTR]SOLDEV = [M:LTR]CURCPY

Gosub AFFLTR From SUBLTR
For NOL1=0 To NBACC-1
 Gosub AFFLIG From SUBLTR
Next NOL1
zonsui = "NBLIG(0)"
Return

$SUIV_LET
J = 0
PLEIN  = 0
SUITE  = 0
RETOUR = 1

Gosub FILTRE

# dans le cas ou le nbre de ligne groupe en cours est > MAXECT , le num de lignes en cours est 0 donc le remettre à 1
If [M:LTR]NBLIG=0 : [M:LTR]NBLIG = 1 : Endif

Filter [DAE] Where evalue(CRITERE) & evalue(CRITERE1) & evalue(FILT) &
&  (   (len(MTC)=len([M:LTR]MTC([M:LTR]NBLIG-1)) & MTC=[M:LTR]MTC([M:LTR]NBLIG-1) & ACCNUM>[M:LTR]ACCNUM([M:LTR]NBLIG-1) )
&   | (len(MTC)=len([M:LTR]MTC([M:LTR]NBLIG-1)) & MTC<[M:LTR]MTC([M:LTR]NBLIG-1))
&   | (len(MTC)<len([M:LTR]MTC([M:LTR]NBLIG-1))) )
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Desc; ACCNUM Asc

Effzo [LTR]20
For I=5 To 1 Step -1
 For [DAE] Where len(MTC)=I
  # Un groupe lettré majuscule doit être chargé en entier ou pas du tout
  # on ne prend le groupe que si on rencontre la première écriture du groupe
  If !find([F:DAE]MTC,[M:LTR]MTC(0..J-1))
   K = J
   Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT)
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Desc; ACCNUM Asc
   For [DAE2]
    If J=K & [F:DAE2]ACCNUM<>[F:DAE]ACCNUM
     Break : # Raté, c'était pas la première
    Endif
    If J>=MAXECT
     J = K
     PLEIN = 1
     Break
    Else
     J += 1
     [F:DAE] = [F:DAE2]
     Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
     nolign = J : Gosub CHARGE
    Endif
   Next
   Filter [DAE2]
   If PLEIN : Break 2 : Endif
  Endif
 Next
Next I
Filter [DAE]
[M:LTR]NBLIG = J
If PLEIN : SUITE = 1 : Endif
Gosub AFFLTR From SUBLTR
For NOL1=0 To NBACC-1
 Gosub AFFLIG From SUBLTR
Next NOL1
zonsui = "NBLIG(0)"
Return

####################################################################
## Lecture page précédente
####################################################################
$PPREC

If ECRLET : Goto PREC_LET : Endif

# On commence à la première écriture non sélectionnée
K = 0
While K<[M:LTR]NBLIG-1 & [M:LTR]FLG(K)<>"" : K += 1 : Wend

Call FILTRE_TRI(CRITERE2,"<",K)

# Sauvegarde sélection
Gosub SAUVE_LEC

Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LECTURE("GAC",COMPTE,[M:LTR]COA) From CONTOBJ

PLEIN = 0
J = MAXECT+1
SUITE  = 1
RETOUR = 0

Call TRI([L]ORDRE,1)
Gosub FILTRER_DAE

For [DAE]
 OK = !find([F:DAE]ACCNUM,[M:LTR]ACCNUM(J-1,MAXECT-1)) & !find([F:DAE]ACCNUM,[M:LTR]ACCNUM(0..MINECT-1))
 If OK
  If [F:DAE]MTC=""
   Gosub OKECR
   If OK
    If J<=MINECT+1
     PLEIN = 1
     Break
    Else
     J -= 1
     nolign = J : Gosub CHARGE
    Endif
   Endif
  Else
# un groupe lettré minuscule doit être chargé en entier ou pas du tout
   If !find([F:DAE]MTC,[M:LTR]MTC(J-1..MAXECT-1))
    I = J
    K = 0
    L = [F:DAE]ACCNUM
    Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT) Order With [L]ORDRE
    For [DAE2]
     K = [F:DAE2]ACCNUM
     If J<=MINECT+1
      J = I
      PLEIN = 1
      Break
     Else
      J -= 1
      [F:DAE] = [F:DAE2]
      Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
      nolign = J : Gosub CHARGE
     Endif
    Next
    Filter [DAE2]
    If K<>L & J<>I
     J = I : PLEIN = 0 : # Raté c'était pas la première
    Endif
    If PLEIN : Break : Endif
   Endif
  Endif
 Endif
Next
Filter [DAE]
If PLEIN
 RETOUR = 1
Endif
[M:LTR]FCY   = SITE
[M:LTR]NBLIG = MAXECT

# On n'a peut être pas tout rempli...
If J>MINECT+1
 Dela MINECT,J-1-MINECT,[M:LTR]NBLIG-1 [M:LTR]NBLIG
 [M:LTR]NBLIG -= J-1-MINECT
Endif

[M:LTR]SOLCPT = sum([M:LTR]DEBIT(0..[M:LTR]NBLIG-1))
&              -sum([M:LTR]CREDIT(0..[M:LTR]NBLIG-1))
If [M:LTR]SOLCPT=0
 [M:LTR]SOLSNS = ""
Elsif [M:LTR]SOLCPT>0
 [M:LTR]SOLSNS = mess(1,626,1)
Else
 [M:LTR]SOLSNS = mess(2,626,1)
 [M:LTR]SOLCPT = -[M:LTR]SOLCPT
Endif
[M:LTR]SOLDEV = [M:LTR]CURCPY

Gosub AFFLTR From SUBLTR
For NOL1=0 To NBACC-1
 Gosub AFFLIG From SUBLTR
Next NOL1
zonsui = "NBLIG(0)"
Return

$PREC_LET

J = MAXECT+1
PLEIN  = 0
SUITE  = 1
RETOUR = 0
Gosub FILTRE

K=len([M:LTR]MTC(0))

Filter [DAE] Where evalue(CRITERE) & evalue(CRITERE1) & evalue(FILT) &
&  (  (len(MTC)=len([M:LTR]MTC(0)) & MTC=[M:LTR]MTC(0) & ACCNUM<[M:LTR]ACCNUM(0))
&   | (len(MTC)=len([M:LTR]MTC(0)) & MTC>[M:LTR]MTC(0))
&   | (len(MTC)>len([M:LTR]MTC(0)) ))
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Asc ; ACCNUM Desc

Effzo [LTR]20
For I=K To 5
 For [DAE] Where len(MTC)=I
  # Un groupe lettré majuscule doit être chargé en entier ou pas du tout
  W = J
  Y = 0
  Z = [F:DAE]ACCNUM
  Filter [DAE2] Where evalue(CRITERE) & MTC=[F:DAE]MTC & evalue(FILT)
& Order By CPY Asc; FCYLIN Asc; ACC Asc; BPR Asc; MTC Desc; ACCNUM Asc
  For [DAE2]
   Y = [F:DAE2]ACCNUM
   If J<=MINECT+1
    J = W
    PLEIN = 1
    Break
   Else
    J -= 1
    [F:DAE] = [F:DAE2]
    Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
    nolign = J : Gosub CHARGE
   Endif
  Next
  Filter [DAE2]
  If Y<>Z & J<>W
   J = W : PLEIN = 0 : # Raté c'était pas la première
  Endif
  If PLEIN : Break : Endif
 Next
Next I
Filter [DAE]
[M:LTR]NBLIG = MAXECT
If PLEIN : RETOUR = 1 : Endif

If J>1
 Dela 0,J-1,[M:LTR]NBLIG-1 [M:LTR]NBLIG
 [M:LTR]NBLIG -= J-1
Endif
Gosub AFFLTR From SUBLTR
For NOL1=0 To NBACC=0
 Gosub AFFLIG From SUBLTR
Next NOL1
zonsui = "NBLIG(0)"
Return

############################################################
## Sauvegarde et relecture des écritures sélectionnées
############################################################
$SAUVE_LEC
Local Integer NUMACC(1..MAXECT) , NBACC
Local Char    FLG(1)
NBACC = [M:LTP]NBLET
FLG   = [M:LTR]FLG([M:LTP]TBLET(1))
For K=1 To NBACC
 NUMACC(K) = [M:LTR]ACCNUM([M:LTP]TBLET(K))
Next K
Effzo [LTR]20
[M:LTP]NBLET = NBACC
For K=1 To NBACC
 Read [DAE]DAE2 = NUMACC(K)
 Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
 nolign = K : Gosub CHARGE
 [M:LTR]FLG(nolign-1) = FLG
 If FLG<>"" : [M:LTR]FLGMTC(nolign-1) = 2 : Endif
 [M:LTP]TBLET(K) = K-1
Next K
MINECT = NBACC
Return

############################################################
## Recherche montant
############################################################
$RECHERCHE
Local Integer LIGDEB
LIGDEB = nolign-1
If [M:LTM]AMT=0 & [M:LTM]VCR="" : Return : Endif
K = -1
For I=LIGDEB+1 To [M:LTR]NBLIG-1
 Gosub CHERCHE
 If K>=0 : Break : Endif
Next I
If K<0
 For I=0 To LIGDEB
  Gosub CHERCHE
  If K>=0 : Break : Endif
 Next I
Endif
If K>=0
 SUIZON = "NBLIG("+num$(K)+")"
Else
 GERR = 2 : GMESSAGE = mess(22,110,1) : #  Aucune ligne trouvée
Endif
Return

$CHERCHE
If [M:LTM]VCR<>"" & pat([M:LTR]NUM(I),[M:LTM]VCR)
 K = I
Elsif [M:LTM]AMT<>0
 Case [M:LTM]CUR
  When [M:LTR]CURCPY,""
    If ([M:LTM]SNS<>2 & [M:LTR]DEBIT(I)=[M:LTM]AMT)
&    | ([M:LTM]SNS<>1 & [M:LTR]CREDIT(I)=[M:LTM]AMT)
    K = I
   Endif
  When Default
   If ([M:LTM]CUR="" | [M:LTR]CUR(I)=[M:LTM]CUR) & (([M:LTM]SNS<>2 & [M:LTR]DEBCUR(I)=[M:LTM]AMT)
&                                                 | ([M:LTM]SNS<>1 & [M:LTR]CRECUR(I)=[M:LTM]AMT))
    K = I
   Endif
 Endcase
Endif
Return

#####################################################
## Inversion de la sélection
#####################################################
$INVERSE
Raz [M:LTP]NBLET, [M:LTR]CURLET, [M:LTR]SOLDE , [M:LTR]SOLDLET
For I=0 To [M:LTR]NBLIG-1
 If [M:LTR]FLG(I)="" & !([M:LTR]MTC(I)>="A" & [M:LTR]MTC(I)<"ZZZZZ")
  [M:LTR]FLG(I) = "*"
  [M:LTR]FLGMTC(I) = 2
  [M:LTP]NBLET += 1
  [M:LTP]TBLET([M:LTP]NBLET)  = I
  If [M:LTP]NBLET=1 & [M:LTR]CURFLG=1
   If [M:LTR]CUR([M:LTP]TBLET(1))<>[M:LTR]CURCPY
    [M:LTR]CURLET = [M:LTR]CUR([M:LTP]TBLET(1))
   Elsif !find([M:LTR]CURORG([M:LTP]TBLET(1)),"",[M:LTR]CURCPY)
    [M:LTR]CURLET = [M:LTR]CURORG([M:LTP]TBLET(1))
   Endif
  Endif
  [M:LTR]SOLDE += [M:LTR]DEBIT(I)-[M:LTR]CREDIT(I)
  If [M:LTR]CURFLG=1 & [M:LTR]CUR(I)=[M:LTR]CURLET
   [M:LTR]SOLDLET += [M:LTR]DEBCUR(I)-[M:LTR]CRECUR(I)
  Elsif [M:LTR]CURLET<>"" & !([M:LTR]CURFLG=1
&  &     [M:LTR]CUR(I)=[M:LTR]CURCPY
&  &     [M:LTR]CURORG(I)=[M:LTR]CURLET)
   [M:LTR]CURLET = ""
   [M:LTR]SOLDLET = 0
  Endif
 Else
  [M:LTR]FLG(I) = ""
  [M:LTR]FLGMTC(I) = 1
 Endif
Next I
If [M:LTR]SOLDE=0 |
&  ([M:LTR]CURLET<>"" & [M:LTR]SOLDLET=0)
 For I=1 To [M:LTP]NBLET
  [M:LTR]FLG([M:LTP]TBLET(I)) = "="
  [M:LTR]FLGMTC([M:LTP]TBLET(I)) = 2
 Next I
Endif
For NOL1=0 To [M:LTR]NBLIG-1
 Gosub AFFLIG From SUBLTR
Next NOL1
SUIZON = "NBLIG(0)"
Return

#####################################################
## Lecture des paramètres lettrage auto
#####################################################
$INIPAR
Gosub INIPAR From LETTCRIT
Return

#############################################
## Test chargement écriture
#############################################
$OKECR
OK = 1
If [F:DAE]SNS>0
 If [M:LTC]DEBDATDEB<>[0/0/0]
  OK *= [F:DAE]ACCDAT>=[M:LTC]DEBDATDEB
 Endif
 If [M:LTC]DEBDATFIN<>[0/0/0]
  OK *= [F:DAE]ACCDAT<=[M:LTC]DEBDATFIN
 Endif
Else
 If [M:LTC]CREDATDEB<>[0/0/0]
  OK *= [F:DAE]ACCDAT>=[M:LTC]CREDATDEB
 Endif
 If [M:LTC]CREDATFIN<>[0/0/0]
  OK *= [F:DAE]ACCDAT<=[M:LTC]CREDATFIN
 Endif
Endif
If OK
 Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
 OK *= ([F:HAE]CAT=1)
 OK *= ([F:HAE]FLGREP<>2)
Endif
GPOINT = "BEFLOADDAE" : Gosub ENTREE From EXEFNC
Return

#############################################
## Chargement écriture
#############################################
$CHARGE
[M:LTR] = [F:HAE]
[M:LTR] = [F:DAE]
If [F:DAE]SNS>0
 [M:LTR]DEBIT(nolign-1)  = [F:DAE]AMTLED
 [M:LTR]DEBCUR(nolign-1) = [F:DAE]AMTCUR
 Raz [M:LTR]CREDIT(nolign-1),[M:LTR]CRECUR(nolign-1)
Else
 [M:LTR]CREDIT(nolign-1) = [F:DAE]AMTLED
 [M:LTR]CRECUR(nolign-1) = [F:DAE]AMTCUR
 Raz [M:LTR]DEBIT(nolign-1),[M:LTR]DEBCUR(nolign-1)
Endif
Return

#############################################
## Critère de lecture écritures
#############################################
$FILTRE
CRITERE  = 'LEDTYP='+num$([M:LTR]LEDTYP)+'& ACC="'+[M:LTR]ACC+'" & BPR="'+[M:LTR]BPR+'"'
CRITERE -= '& CPY="'+SOCIETE+'" & FCYLIN="'+[M:LTR]FCY+'"'

If [M:LTR]DATDEB<>[0/0/0]
 CRITERE -= '& ACCDAT>=['+format$(GFMD,[M:LTR]DATDEB)+']'
Endif
If [M:LTR]DATFIN<>[0/0/0]
 CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:LTR]DATFIN)+']'
Endif
###

# Suggestion TRI
If !ECRLET  # Ecritures non lettrées ou lettrées en minuscule
   CRITERE1 ='(MTC<"A" or MTC>"ZZZZZ")'
Else        # Ecritures lettrées en majuscule
   CRITERE1 ='(MTC>="A" & MTC<="ZZZZZ") & FLGMTC=0'
Endif

Raz CRITERE2

Gosub FILTRE_SPE
Return

$FILTRE_SPE
Raz FILT
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If FILT="" : FILT = "1=1" : Endif
Return

#############################################
## Lettrage proprement dit
#############################################
$VALIDATION
Global Integer GPASSE_FEN : GPASSE_FEN = 0
Local Integer ECHNEG : Raz ECHNEG
OK = 1
If [M:LTP]NBLET>=1
 Raz [M:LTE]
 If [M:LTR]CURLET=""
  [M:LTE]CUR = [M:LTR]CURCPY
  FLDEV = 1
 Else
  [M:LTE]CUR = [M:LTR]CURLET
  FLDEV = 2
 Endif
 Call LECTURE("GAC",[M:LTR]ACC,[M:LTR]COA) From CONTOBJ
 [M:LTE]FRWCUR = [F:GAC]FRWCUR
 Call CHARGECH([M:LTP]NBLET,[M:LTP]TBLET(1..[M:LTP]NBLET),FLDEV,[M:LTR]BPR,ECHNEG)
 If ([M:LTR]BPR<>"" & !([M:LTR]SOLDE=0 |
&                      ([M:LTR]CURLET<>"" & [M:LTR]SOLDLET=0))
&                   &   [M:LTE]NBLIG>2)
&   or ([M:LTR]BPR<>"" & ECHNEG)
               # On va saisir la fenêtre
  GPASSE_FEN = 1
 Else
  BOITE = "" : # C'est pas la peine
 Endif
Else
 FIN = 1
Endif
Return

$VAL_LETTRAGE
Local Integer OK3
OK3 = 0
If dim(GPASSE_FEN)<=0
 OK3 = 1
Elsif dim(GPASSE_FEN)>0
 If !GPASSE_FEN
  OK3 = 1
 Elsif GPASSE_FEN & GSTATUT=GSTAOK
  OK3 = 1
 Endif
Endif
If OK3
 Call DEBTRANS From GLOCK
 Gosub TR1
 Local Integer SAV_TITCOL
 If GOK=1
  # Nombre de lignes à afficher
  For I=1 To [M:LTP]NBLET
   NOL1 = [M:LTP]TBLET(I)
   Read [DAE]DAE2 = [M:LTR]ACCNUM(NOL1)
   [M:LTR]MTC(NOL1) = [F:DAE]MTC
   [M:LTR]FLG(NOL1) = ""
   [M:LTR]FLGMTC(NOL1) = 1
   Affzo [LTR]FLG(NOL1),MTCAFF(NOL1),FLGMTC(NOL1)
   Gosub AFFLIG From SUBLTR
  Next I
  [M:LTP]NBLET = 0
  SUIZON = "NBLIG("+num$(NOL1)+")"
 Elsif STA & MESSAGE<>""
  GERR = 1 : GMESSAGE = MESSAGE
 Endif
Endif
Return

$TR1
GOK = 1 : Raz PCENUM, PCETYP, XPCENUM, XPCETYP, XNBPCE, STA
Trbegin [DAE], [DUD], [MTC]
 CAS = 1+([M:LTR]CURLET<>"")
 Gosub EPUR_MTCBATCH
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ## If we match open items attached to different currencies, the matching will be done in ledger currency
 ## An error message is displayed if the account to be matched is selected "Carry-forward amounts in currency"
 If [M:LTE]FRWCUR=2 or CAS<>2
  Local Char    XDEVISE(GLONCUR)
  Local Integer NOLI, OK
  Local Integer OKDEV : OKDEV=1
  XDEVISE = [M:LTE]DEVPCE(0)
  For NOLI=1 To [M:LTE]NBLIG-1
   If [M:LTE]DEVPCE(NOLI)<>XDEVISE
    OKDEV=0
    If [M:LTE]FRWCUR=2
     If [M:LTR]BPR<>"" : # Collective Account => Blocking message
      # The account has the flag "Carry-forward amounts in currency" checked
      GOK = 0 : STA = 99 : MESSAGE = [M:LTR]COA-[M:LTR]ACC-":"-mess(172,107,1) : Break
     Else : # Non Collective Account => Warning message
      # The account has the flag "Carry-forward amounts in currency" checked
      Call AVERTIR([M:LTR]COA-[M:LTR]ACC-":"-mess(172,107,1),OK) From GESECRAN
      If OK<>2 : Raz OK : GOK = 0 : Break : Endif
     Endif
    Endif
   Endif
  Next
  If OKDEV : CAS=2 : Endif
 Endif
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Call LETTRAGE([M:LTE]NBLIG,[M:LTE]ACCNUM,[M:LTE]DUDLIG,[M:LTE]NIPT,CAS,0,STA,MESSAGE,PCETYP,PCENUM) From CPTLET
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 XNBPCE = 0
 For I=1 To dim(PCENUM)
  If PCENUM(I)<>""
   XNBPCE += 1
   XPCETYP(XNBPCE) = PCETYP(I)
   XPCENUM(XNBPCE) = PCENUM(I)
  Endif
 Next
 ## Propagation du lettrage sur les autres référentiels
 For R=1 To len(mess(0,2644,1))
  Call PROPAGE([M:LTR]FCY,[M:LTR]LEDTYP,[M:LTE]NBLIG,[M:LTE]ACCNUM,R,XNBECH,XACCNUM) From CPTLET
  If XNBECH>=2
   Call LETTRAGE(XNBECH,XACCNUM,XDUDLIG,XAMTIPT,CAS,0,STA,MESSAGE,PCETYP,PCENUM) From CPTLET
   If GOK<1 : Break : Endif
   For I=1 To dim(PCENUM)
    If PCENUM(I)<>""
     XNBPCE += 1
     XPCETYP(XNBPCE) = PCETYP(I)
     XPCENUM(XNBPCE) = PCENUM(I)
    Endif
   Next
   #
  Endif
 Next R
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
For I=1 To XNBPCE
 If XPCENUM(I)<>""
  GERR = 2 : GMESSAGE = mess(40,107,1)-XPCETYP(I)-XPCENUM(I)
  Call AJOUTLIG(XPCETYP(I),XPCENUM(I)) From SUBLTR
 Endif
Next I
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR1 : Else Return : Endif

$VERF_LTE
Local Decimal IPTDEB, IPTCRE
Raz IPTDEB , IPTCRE
For I=0 To [M:LTE]NBLIG-1
 Case [M:LTE]SNS(I)
  When 1 : IPTDEB += [M:LTE]IPT(I)
  When 2 : IPTCRE += [M:LTE]IPT(I)
 Endcase
Next I
If IPTDEB<>IPTCRE & IPTDEB+IPTCRE<>0
 GERR = 1 : GMESSAGE = mess(8,110,1) : #  Imputations déséquilibrées
 FIN  = 0
Endif
Return


$EPUR_MTCBATCH
## On épure les lettrages en attente lorsqu'on cherche à lettrer le groupe qui était en attente de lettrage dans MTCBATCH
Local Integer T, OKK, NBACCNUM
Local Integer NUML
Local Integer MAXLET
Local Char    PARAMMTC(10)
Call PARAM("","MTCNBR",PARAMMTC) From ADOVAL
MAXLET = max(1000,val(PARAMMTC))
Local Integer TABACCNUM(1..MAXLET)
Filter [MTB] Where ACCNUM=[M:LTE]ACCNUM(0) & DUDLIG=[M:LTE]DUDLIG(0)
Read [MTB]MTB0 First : # Juste pour prendre le n° de lettrage en attente...
Filter [MTB]
If !fstat
 [L]NUML = [F:MTB]MTCNUM : NBACCNUM = 0
 For [MTB]MTB0 Where MTCNUM = [L]NUML
  T = find([F:MTB]ACCNUM,[M:LTE]ACCNUM(0..[M:LTE]NBLIG-1))
  If T & [F:MTB]DUDLIG = [M:LTE]DUDLIG(T-1)
  If NBACCNUM >= MAXLET
   GOK = 0 : STA=1 : MESSAGE = mess(42,114,1)  :# Paramètre MTCNBR (Nb lignes lettrage) trop petit
   Break
  Endif
   OKK = 1 : TABACCNUM(T) = [F:MTB]ACCNUM : NBACCNUM += 1
  Else
   OKK = 0 : Break
  Endif
 Next
 If !GOK : Return : Endif
 If OKK
  # On regarde quand même si on a bien le même nombre d'"accnum" à lettrer...
  If [M:LTE]NBLIG = NBACCNUM
   Delete [MTB] Where MTCNUM = [L]NUML
   If fstat=1
    GOK=-1 : GLOCK="$MTCBATCH"-num$([L]NUML)
   Endif
  Endif
 Endif
Endif
Return

#############################################
## Verrou symbole
#############################################
$VERROU
SYMBCPT = "MTC"-SITE-COMPTE-TIERS
Lock =SYMBCPT With lockwait=0
If fstat=1
 [M:LTR]VERROU = 0
Else
 [M:LTR]VERROU = 1
Endif
Return

$DEVERROU
If [M:LTR]VERROU
 Unlock = SYMBCPT
Endif
Return

#####################################################
## Chargement du masque LETTRECH                   ##
#####################################################
Subprog CHARGECH(NBECR,TBIND,FLDEV,TIERS,NEG)
Value Integer NBECR
Value Integer TBIND(1..)
Value Integer FLDEV
Value Char       TIERS
Variable Integer NEG
Local Integer I, TBECR(1..NBECR)

For I=1 To NBECR
 TBECR(I) = [M:LTR]ACCNUM(TBIND(I))
Next I
Call CHARGECH2(NBECR,TBECR,FLDEV,TIERS,NEG)
End

Subprog CHARGECH2(NBECR,TBECR,FLDEV,TIERS,NEG)
Value    Integer NBECR
Value    Integer TBECR(1..)
Value    Integer FLDEV
Value    Char    TIERS
Variable Integer NEG
Local Decimal TOTDEB , TOTCRE , IPTDEB , IPTCRE , MTIPT
Local Integer I , NOL
# Local File [DUD], [DAE], [HAE]

For I=1 To NBECR
 Read [DAE]DAE2 = TBECR(I)
 If fstat=0
  Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
  If fstat : Raz [F:HAE] : Endif
  If left$([F:HAE]REFINT,3)<>"MTC"
   Call SETMAINREF([F:DAE]CPY,GTYPGEN,GTYPANA) From CPTDIV
   If TIERS<>"" &  GTYPGEN = [F:DAE]LEDTYP
    For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
     nolign  = NOL+1
     [M:LTE] = [F:DAE]
     [M:LTE] = [F:HAE]
     [M:LTE] = [F:DUD]
     [M:LTE]DEVPCE(NOL) = [F:HAE]CUR
     Case FLDEV
      When 1
       [M:LTE]AMT(NOL) = [F:DUD]AMTLOC
       [M:LTE]IPT(NOL) = [F:DUD]PAYLOC
       [M:LTE]TMP(NOL) = [F:DUD]TMPLOC
      When 2
       [M:LTE]AMT(NOL) = [F:DUD]AMTCUR
       [M:LTE]IPT(NOL) = [F:DUD]PAYCUR
       [M:LTE]TMP(NOL) = [F:DUD]TMPCUR
     Endcase
     [M:LTE]OIPT(NOL) = [M:LTE]IPT(NOL)
     If [M:LTE]AMT(NOL)<0 : NEG=1 : Endif
     If [F:DAE]SNS>0
      [M:LTE]SNS(NOL) = 1
      TOTDEB += [M:LTE]AMT(NOL)-[M:LTE]TMP(NOL)
      IPTDEB += [M:LTE]IPT(NOL)
     Else
      [M:LTE]SNS(NOL) = 2
      TOTCRE += [M:LTE]AMT(NOL)-[M:LTE]TMP(NOL)
      IPTCRE += [M:LTE]IPT(NOL)
     Endif
     NOL += 1
    Next
   Else
    NOL += 1
    nolign  = NOL
    [M:LTE] = [F:HAE]
    [M:LTE] = [F:DAE]
    [M:LTE]DEVPCE(NOL-1) = [F:HAE]CUR
   Endif : # TIERS
  Endif : # REFINT
 Endif : # fstat
Next I
[M:LTE]NBLIG = NOL
# Init des imputations
If TIERS<>""
 For I=0 To [M:LTE]NBLIG-1
  Case [M:LTE]SNS(I)
   When 1
    If IPTDEB<TOTCRE
     MTIPT = min(TOTCRE-IPTDEB,[M:LTE]AMT(I)-[M:LTE]IPT(I)-[M:LTE]TMP(I))
     [M:LTE]IPT(I)  += MTIPT
     [M:LTE]NIPT(I) += MTIPT
     IPTDEB         += MTIPT
    Else
     If [M:LTE]IPT(I)>0
      MTIPT = min(IPTDEB-TOTCRE,[M:LTE]IPT(I)+[M:LTE]TMP(I))
     Else
      MTIPT = max(IPTDEB-TOTCRE,[M:LTE]IPT(I)+[M:LTE]TMP(I))
     Endif
     [M:LTE]IPT(I)  -= MTIPT
     [M:LTE]NIPT(I) -= MTIPT
     IPTDEB         -= MTIPT
    Endif
   When 2
    If IPTCRE<TOTDEB
     MTIPT = min(TOTDEB-IPTCRE,[M:LTE]AMT(I)-[M:LTE]IPT(I)-[M:LTE]TMP(I))
     [M:LTE]IPT(I)  += MTIPT
     [M:LTE]NIPT(I) += MTIPT
     IPTCRE         += MTIPT
    Else
     If [M:LTE]IPT(I)<0
      MTIPT = max(IPTCRE-TOTDEB,[M:LTE]IPT(I)+[M:LTE]TMP(I))
     Else
      MTIPT = min(IPTCRE-TOTDEB,[M:LTE]IPT(I)+[M:LTE]TMP(I))
     Endif
     [M:LTE]IPT(I)  -= MTIPT
     [M:LTE]NIPT(I) -= MTIPT
     IPTCRE         -= MTIPT
    Endif
  Endcase
 Next I
Endif
End

###############################################################
## Lettrage automatique
###############################################################
Subprog LETAUTO(NBECR,NUMECR,CAS,TRACE)
Value Integer NBECR
Value Integer NUMECR(1..)
Value Integer CAS
Value Integer TRACE

Local Integer STA , NEG
Local Char    MESSA(250) , PCETYP(GLONGTE)(1..5) , PCENUM(GLONVCR)(1..5)
# Variables pour propagation du lettrage
Local Integer R , XNBECH
Local Integer XACCNUM(1..dim([M:LTE]ACCNUM))
Local Integer XDUDLIG(1..dim([M:LTE]ACCNUM))
Local Decimal XAMTIPT(1..dim([M:LTE]ACCNUM))

If NBECR<2 : End : Endif
If NBECR>=dim([M:LTE]ACCNUM)
 Call ECR_TRACE(mess(54,110,1)-"("+num$(dim([M:LTE]ACCNUM))+")",1) From GESECRAN : End
Endif

Read [DAE]DAE2 = NUMECR(1)
Raz [M:LTE]
Call LECTURE("CPY",[F:DAE]CPY,"") From CONTOBJ
[M:LTE]CUR = [F:DAE]CURLED
Call LEC_GAC([F:DAE]ACC,[F:DAE]COA) From CPTLEC
[M:LTE]FRWCUR = [F:GAC]FRWCUR

Call CHARGECH2(NBECR,NUMECR,CAS,[F:DAE]BPR,NEG)

## If we match open items attached to different currencies, the matching will be done in ledger currency
## An error message is displayed if the account to be matched is selected "Carry-forward amounts in currency"
If [M:LTE]FRWCUR=2
 Local Char    XDEVISE(GLONCUR)
 Local Integer NOLI, OK
 XDEVISE = [M:LTE]DEVPCE(0)
 For NOLI=1 To [M:LTE]NBLIG-1
  If [M:LTE]DEVPCE(NOLI)<>XDEVISE
   If [M:LTE]FRWCUR=2
    If [F:DAE]BPR<>"" : # Collective Account => Blocking message
     # The account has the flag "Carry-forward amounts in currency" checked
     GOK = 0 : Call ECR_TRACE([F:GAC]COA-[F:GAC]ACC-":"-mess(172,107,1),1) From GESECRAN : Break
    Else : # Non Collective Account => Warning message
     # The account has the flag "Carry-forward amounts in currency" checked
     Call AVERTIR([F:GAC]COA-[F:GAC]ACC-":"-mess(172,107,1),OK) From GESECRAN
     If OK<>2 : Raz OK : GOK = 0 : Break : Endif
    Endif
   Endif
  Endif
 Next
Endif
If GOK<1 : End : Endif

Call LETTRAGE([M:LTE]NBLIG,[M:LTE]ACCNUM,[M:LTE]DUDLIG,[M:LTE]NIPT
& ,CAS,TRACE,STA,MESSA,PCETYP,PCENUM) From CPTLET
If GOK<1 : End : Endif
## Propagation du lettrage sur les autres référentiels
For R=1 To len(mess(0,2644,1))
 Call PROPAGE([F:DAE]FCYLIN,[F:DAE]LEDTYP,[M:LTE]NBLIG,[M:LTE]ACCNUM,R,XNBECH,XACCNUM) From CPTLET
 If XNBECH>=2
  Call LETTRAGE(XNBECH,XACCNUM,XDUDLIG,XAMTIPT,CAS,TRACE,STA,MESSA,PCETYP,PCENUM) From CPTLET
  If GOK<1 : Break : Endif
 Endif
Next R
If GOK<1 : End : Endif
End

###############################################################
## Suggestion sur le tri (Demande 20632)
###############################################################
# Etablissement d'un ordre de lecture
Subprog TRI(ORD,SNS)
Variable Char ORD()
Value Integer SNS            #  SNS=0 -> ">"  et SNS=1 -> "<"
                             #  [M]TRI=1 -> Asc & [M]TRI=2 -> Desc


Local Char CRIT(50)(1..dim([M:TLT]CRI))

# Pas de tri... on impose un tri par défaut 1er choix (Standard, c'est la date comptable)
# ajout de deux chps CHPCP et CODTYPCP pour gérer le Tri
# Si mémo existant avant l'ajout des chp CODTYPCP et CHPCP , alors pb d'initialisation des var
# lors de la 1ere utilisation donc on impose le RAZ du mémo et le tri par défaut

If([M:TLT]NBCRI<>0 & [M:TLT]CODTYPCP(0)= "")
For J=1 To [M:TLT]NBCRI
 NOL = [M:TLT]CRICUR-1
 If NOL>=0
  [M:TLT]CRITERE([M:TLT]NBLIG)  = [M:TLT]CRI(NOL)
  [M:TLT]NUMLIG([M:TLT]NBLIG)   = [M:TLT]NUMTRI(NOL)
  [M:TLT]CHP([M:TLT]NBLIG)      = [M:TLT]CHPCP(NOL)
  [M:TLT]CODTYP([M:TLT]NBLIG)   = [M:TLT]CODTYPCP(NOL)
  [M:TLT]NBLIG += 1
  Dela NOL [M:TLT]NBCRI
  [M:TLT]NBCRI -= 1
  If [M:TLT]NBCRI>0
   [M:TLT]CRICUR = min(NOL+1,[M:TLT]NBCRI)
  Endif
 Endif
Next J
Endif


If ([M:TLT]NBCRI=0 )
 K = find(1,[M:TLT]NUMLIG(0..[M:TLT]NBLIG-1))
 If K
  [M:TLT]NBCRI       = 1
  [M:TLT]CRI(0)      = [M:TLT]CRITERE(K-1)
  [M:TLT]TRI(0)      = 1
  [M:TLT]NUMTRI(0)   = 1
  [M:TLT]CHPCP(0)    = [M:TLT]CHP(0)
  [M:TLT]CODTYPCP(0) = [M:TLT]CODTYP(0)
  Dela K-1 [M:TLT]NBLIG
  [M:TLT]NBLIG -= 1
 Endif
Endif

# Il faut RAZ les critères
For J=1 To [M:TLT]NBLIG
 Assign "CRIT("+num$(J)+")" With ""
Next

# Initialisation des CRITx
# Changer CHP par CHPCP
For J=1 To [M:TLT]NBCRI
 If (!SNS & [M:TLT]TRI(J-1)=2) | (SNS & [M:TLT]TRI(J-1)<>2)
  Assign "CRIT("+num$(J)+")" With [M:TLT]CHPCP(J-1)-"Desc"
 Else
  Assign "CRIT("+num$(J)+")" With [M:TLT]CHPCP(J-1)-"Asc"
 Endif
Next J

# Mise à jour d'ORDRE
Raz ORD
For J=1 To [M:TLT]NBCRI
 If evalue("CRIT("+num$(J)+")")<>""
  If ORD<>""
   ORD += ";"
  Endif
  ORD = ORD + evalue("CRIT("+num$(J)+")")
 Endif
Next
If !SNS
 ORD+=";ACCNUM Asc"
Else
 ORD+=";ACCNUM Desc"
Endif
End

###############################################################
# génération des critères pour éxécuter "Page précédente" et "Page suivante"
Subprog FILTRE_TRI(WFILTRE,SIGNE,BORNE)
Variable Char WFILTRE()
Value Char SIGNE()
Value Integer BORNE

Raz WFILTRE

Local Char RES(250)(0..[M:TLT]NBLIG)
Local Char VALCHAMP(50)
Local Integer IND,NB,I,J,K

NB=[M:TLT]NBCRI
NB+=1

# Initialisation des RES
IND=0
For J=NB To 1 Step -1

   RES(IND)=""
   For K=1 To J

       # cas clé unique
       If J=NB and NB=K
           RES(IND) += "&ACCNUM"+SIGNE+num$(evalue("[M:LTR]ACCNUM("+num$(BORNE)+")"))

       Else
           # CHP devient CHPCP , CODTYP devient CODTYPCP
              I=K

              Case [M:TLT]CODTYPCP(I-1)
                When "D"
                  VALCHAMP = "["+format$(GFMD,evalue("[M:LTR]"+[M:TLT]CHPCP(I-1)+"("+num$(BORNE)+")"))+"]"
                When "A"
                  VALCHAMP = "'"+evalue("[M:LTR]"+[M:TLT]CHPCP(I-1)+"("+num$(BORNE)+")")+"'"
                When Default
                  VALCHAMP = num$(evalue("[M:LTR]"+[M:TLT]CHPCP(I-1)+"("+num$(BORNE)+")"))
                  If int(val(VALCHAMP))=val(VALCHAMP)
                      VALCHAMP = num$(evalue("[M:LTR]"+[M:TLT]CHPCP(I-1)+"("+num$(BORNE)+")"))+".0"
                  Endif
              Endcase

              If len(RES(IND))<>0 : RES(IND) += "&" : Endif

              If K<>J
                 RES(IND) += [M:TLT]CHPCP(I-1)+"="+VALCHAMP
              Else

                  If (SIGNE=">" & [M:TLT]TRI(I-1)=2) | (SIGNE="<" & [M:TLT]TRI(I-1)<>2)
                     RES(IND) += [M:TLT]CHPCP(I-1)+"<"+VALCHAMP
                  Else
                     RES(IND) += [M:TLT]CHPCP(I-1)+">"+VALCHAMP
                  Endif
              Endif
           #Endif
        Endif
   Next
   IND=IND+1
Next

# Création du filtre
WFILTRE += "("
For I=0 To NB-1
    WFILTRE += "("+RES(I)
    If I<NB-1
        WFILTRE +=")|"
    Else
        WFILTRE +=")"
    Endif
Next
WFILTRE += ")"
End

###############################################################
# Filtre sur les écritures
$FILTRER_DAE
If CRITERE2="" : CRITERE2="1=1" : Endif
Filter [DAE] Where evalue(CRITERE) and evalue(CRITERE1) and evalue(CRITERE2) and evalue(FILT) Order With [L]ORDRE
Return

