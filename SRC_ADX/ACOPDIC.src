#<AdxTL>@(#)6.0.0.0 $Revision$
Call COPIE
End

Subprog COPIE
Local Char PARAM(30)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPDIC","ACOPDIC",3,"XYACOPDIC") From GTRAITE
End

#######################################################
## Traitement des actions                             #
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

$INIT
Local Integer  OK , I , STAT , COP, STAT , ILAN , COPSRC
Local Char     TABLE(30) , TABLE2(30) , TABLE3(30) , TABLE4(30)
Local Char     FICORG(GDIMFIC) , FICDES(GDIMFIC)
Local Char     TRAIT(GLONADC) , EXT(3)
Local Char     SAVLAN(GLONLAN)
Local Integer  OGSERVEUR
Global Decimal GCOEFTAB : GCOEFTAB = 0.5
Local Char     SUPERVIS(GDIMFIC) , MACHINE(GDIMFIC) , DOS(GDIMFIC)
Local Char     MACO(GDIMFIC) , DOSO(GDIMFIC) , MACD(GDIMFIC) , DOSD(GDIMFIC)
Return

$INIT_DIA
Raz [M:DIA]
[M]NBMOD = len(mess(0,14,1))
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  [M]NBMOD = I-1
  Break
 Endif
 [M]COPMOD(I-1) = 2
Next I
Return

$CONTROLE
Gosub  INIT_AV
GSERVEUR = 0
Return

$EXEC
Call TEMPON("O") From GESECRAN
GSERVEUR = 1 : # Pour éviter l'affichage des messages
Call OUVRE_TRACE(mess(108,124,1)-[M:DIA]DOSORG-"=>"-[M:DIA]DOSDES) From LECFIC
# Copie dictionnaire
# Il faut copier tout avant de valider
If [M]ACTION=2   : Gosub COPACT : Endif
If [M]TYPDON=2   : Gosub COPTYP : Endif
If [M]TABDIV=2   : Gosub COPDIV : Endif
If [M]TABLE=2    : Gosub COPTAB : Endif
If [M]VUE=2      : Gosub COPVUE : Endif
If [M]ECRAN=2    : Gosub COPECR : Endif
If [M]FENETRE=2  : Gosub COPFEN : Endif
If [M]FONCTION=2 : Gosub COPFCT : Endif
If [M]OBJET=2    : Gosub COPOBJ : Endif
If [M]CONSULT=2  : Gosub COPCNS : Endif
If [M]MESSAGE=2  : Gosub COPMES : Endif
If [M]TRAIT=2    : Gosub COPPRG : Endif
If [M]ETAT=2     : Gosub COPETA : Endif
If [M]ACLA=2     : Gosub COPACLA : Endif
If [M]ASW=2     : Gosub COPASW : Endif

If [M:DIA]VALDIC=2
 Call MACHINE([M]DOSDES,MACHINE,DOS) From ORDSYS
 If MACHINE<>"" & MACHINE<>adxmac(0)
  Call ECR_TRACE(mess(97,115,1),1) From GESECRAN
 Else
  If [M]TABLE=2    : Gosub VALTAB  : Endif
  If [M]VUE=2      : Gosub VALVUE  : Endif
  If [M]ECRAN=2    : Gosub VALMSK  : Endif
  If [M]FENETRE=2  : Gosub VALFEN  : Endif
  If [M]OBJET=2    : Gosub VALOBJ  : Endif
  If [M]CONSULT=2  : Gosub VALCONS : Endif
  If [M]FONCTION=2 : Gosub VALMEN  : Endif
  If [M]ACLA=2    : Gosub VALACLA  : Endif
  If [M]ASW=2    : Gosub VALASW  : Endif
 Endif
Endif
GSERVEUR = 0
Return

$TERMINE
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC
Return

$INIT_AV
If [M:DIA]TABFIN="" : [M:DIA]TABFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]VUEFIN="" : [M:DIA]VUEFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]MSKFIN="" : [M:DIA]MSKFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]TYPFIN="" : [M:DIA]TYPFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]ACTFIN="" : [M:DIA]ACTFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]FCTFIN="" : [M:DIA]FCTFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]OBJFIN="" : [M:DIA]OBJFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]DIVFIN=0  : [M:DIA]DIVFIN = 32767        : Endif
If [M:DIA]FENFIN="" : [M:DIA]FENFIN = "ZZZZZZZZ"   : Endif
If [M:DIA]CNSFIN="" : [M:DIA]CNSFIN = "ZZZ"        : Endif
If [M:DIA]MESFIN=0  : [M:DIA]MESFIN = 32767        : Endif
If [M:DIA]TRTFIN="" : [M:DIA]TRTFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]ETAFIN="" : [M:DIA]ETAFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]ACLAFIN="" : [M:DIA]ACLAFIN = "ZZZZZZZZZZ" : Endif
If [M:DIA]ASWFIN="" : [M:DIA]ASWFIN = "ZZZZZZZZZZ" : Endif
Return


###########################################################
$COPACLA

Gosub OUVRE_COP From SUBACLA

If [M]DOSORG=nomap
 Local File ACLASSE  [ACLA]
Else
 Local File =[M]DOSORG+".ACLASSE"  [ACLA]
Endif

For [ACLA]ACLA0 Where CODCLA>=[M:DIA]ACLADEB & CODCLA<=[M:DIA]ACLAFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ACLA]UPDDATTIM<>gdatetime$("") & func SUBADC.DAT_DATETIME([F:ACLA]UPDDATTIM)>=[M:DIA]DATDEB
  OK += [F:ACLA]UPDDATTIM= gdatetime$("") & func SUBADC.DAT_DATETIME([F:ACLA]CREDATTIM)>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ACLA]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ACLA]CODACT)
 If OK
  TABLE = [F:ACLA]CODCLA
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBACLA
  If GOK=1
   Call ECR_TRACE(mess(90,140,1)-TABLE,0) From GESECRAN :#  Copie table
   If [M:DIA]COPTRT=2
    For ITRT=0 To [F:ACLA]NBRTRT-1
     TRAIT = [ACLA]CODTRT(ITRT) : Gosub COPTRT
    Next
   Endif
  Endif
 Endif
Next
Close Local File


Return

$COPASW
Gosub OUVRE_COP From SUBASW

If [M]DOSORG=nomap
 Local File ASHW  [ASW]
Else
 Local File =[M]DOSORG+".ASHW"  [ASW]
Endif

For [ASW]ASW0 Where CODREP>=[M:DIA]ASWDEB & CODREP<=[M:DIA]ASWFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ASW]UPDDATTIM<>gdatetime$("") & func SUBADC.DAT_DATETIME([F:ASW]UPDDATTIM)>=[M:DIA]DATDEB
  OK += [F:ASW]UPDDATTIM= gdatetime$("") & func SUBADC.DAT_DATETIME([F:ASW]CREDATTIM)>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ASW]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ASW]CODACT)
 If OK
  TABLE = [F:ASW]CODREP
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBASW
  If GOK=1
   Call ECR_TRACE(mess(91,140,1)-TABLE,0) From GESECRAN :#  Copie table
   If [M:DIA]COPTRT=2
    For ITRT=0 To [F:ASW]NBRTRT-1
     TRAIT = [F:ASW]CODTRT(ITRT) : Gosub COPTRT
    Next
   Endif
  Endif
 Endif
Next
Close Local File
Return

###########################################################

$COPTAB
If [M]DOSORG=nomap
 Local File ATABLE  [ATB]
 Local File ATABLE  [ATB1]
 Local File ATABZON [ATZ1]
 Local File ATABIND [ATI1]
 If filinfo(filpath("FIL","ATABAUD","fde"),0)>0
  Local File ATABAUD [ATA1]
 Endif
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".ATABLE"  [ATB]
 Local File =[M]DOSORG+".ATABLE"  [ATB1]
 Local File =[M]DOSORG+".ATABZON" [ATZ1]
 Local File =[M]DOSORG+".ATABIND" [ATI1]
 If filinfo(filpath("FIL","ATABAUD","fde",[M]DOSORG),0)>0
  Local File =[M]DOSORG+".ATABAUD" [ATA1]
 Endif
 Local File =[M]DOSORG+".AMSKPAR" [AMP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ATABLE  [ATB2]
 Local File ATABZON [ATZ2]
 Local File ATABIND [ATI2]
 If filinfo(filpath("FIL","ATABAUD","fde"),0)>0
  Local File ATABAUD [ATA2]
 Endif
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
 If filinfo(filpath("FIL","AVIEW","fde"),0)>0
  Local File AVIEW [AVW2]
 Endif
Else
 Local File =[M]DOSDES+".ATABLE"  [ATB2]
 Local File =[M]DOSDES+".ATABZON" [ATZ2]
 Local File =[M]DOSDES+".ATABIND" [ATI2]
 If filinfo(filpath("FIL","ATABAUD","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".ATABAUD" [ATA2]
 Endif
 Local File =[M]DOSDES+".AMSKPAR" [AMP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
 If filinfo(filpath("FIL","AVIEW","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".AVIEW" [AVW2]
 Endif
Endif
Local Integer NBENR , AUD1 , AUD2 , AUD3 , AUD4 , AUD5 , AUDIT , ABI , ASD
Local Char    AUDC(GLONANX) , AUDCLE(GLONANX)
AUDIT = func AFNC.ACTIVDOS([M]DOSDES,"AUDIT")
ABI   = func AFNC.ACTIVDOS([M]DOSDES,"ABI")
ASD   = func AFNC.ACTIVDOS([M]DOSDES,"ASD")
For [ATB]CODFIC Where CODFIC>=[M:DIA]TABDEB & CODFIC<=[M:DIA]TABFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ATB]UPDDAT<>[0/0/0] & [F:ATB]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ATB]UPDDAT= [0/0/0] & [F:ATB]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ATB]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ATB]CODACT)
 If OK
  TABLE = [F:ATB]CODFIC
  Read [ATB1]CODFIC = TABLE
  Read [ATB2]ABRFIC = [F:ATB1]ABRFIC
  If !fstat & [F:ATB2]CODFIC<>TABLE
   Call ECR_TRACE(mess(17,176,1)-"("+[F:ATB2]CODFIC+")",1) From GESECRAN : # Abréviation déjà existante
   OK = 0
  Endif
 Endif
 If OK & clalev([F:AVW2])>0
  Read [AVW2]AVW0 = TABLE
  If !fstat
   Call ECR_TRACE(TABLE-":"-mess(75,139,1),1) From GESECRAN : # Il existe déjà une vue du même nom
   OK = 0
  Endif
 Endif
 If OK
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBATB
  If GOK=1
   Call ECR_TRACE(mess(106,123,1)-TABLE,0) From GESECRAN
#  Copie table
  Endif
 Endif
Next
Close Local File
Return

$COPVUE
If [M]DOSORG=nomap
 Local File AVIEW   [AVW]
 Local File AVIEW   [AVW1]
 Local File AVIEWD  [AVD1]
 Local File AVIEWC  [AVC1]
 Local File AVIEWB  [AVB1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AVIEW"   [AVW]
 Local File =[M]DOSORG+".AVIEW"   [AVW1]
 Local File =[M]DOSORG+".AVIEWD"  [AVD1]
 Local File =[M]DOSORG+".AVIEWC"  [AVC1]
 Local File =[M]DOSORG+".AVIEWB"  [AVB1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AVIEW   [AVW2]
 Local File AVIEWD  [AVD2]
 Local File AVIEWC  [AVC2]
 Local File AVIEWB  [AVB2]
 Local File ATEXTE  [ATX2]
 Local File ATABLE  [ATB2]
Else
 Local File =[M]DOSDES+".AVIEW"   [AVW2]
 Local File =[M]DOSDES+".AVIEWD"  [AVD2]
 Local File =[M]DOSDES+".AVIEWC"  [AVC2]
 Local File =[M]DOSDES+".AVIEWB"  [AVB2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
 Local File =[M]DOSDES+".ATABLE"  [ATB2]
Endif
For [AVW]AVW0 Where CODVUE>=[M:DIA]VUEDEB & CODVUE<=[M:DIA]VUEFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AVW]UPDDAT<>[0/0/0] & [F:AVW]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AVW]UPDDAT= [0/0/0] & [F:AVW]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AVW]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AVW]CODACT)
 If OK
  TABLE = [F:AVW]CODVUE
  Read [ATB2]CODFIC = TABLE
  If !fstat
   Call ECR_TRACE(TABLE-":"-mess(74,139,1),1) From GESECRAN : # Il existe déjà une table du même nom
   OK = 0
  Endif
 Endif
 If OK
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBAVW
 Endif
Next
Close Local File
Return

$COPECR
If [M]DOSORG=nomap
 Local File AMSK    [AMK]
 Local File AMSK    [AMK1]
 Local File AMSKZON [AMZ1]
 Local File AMSKACT [AMA1]
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AMSK"    [AMK]
 Local File =[M]DOSORG+".AMSK"    [AMK1]
 Local File =[M]DOSORG+".AMSKZON" [AMZ1]
 Local File =[M]DOSORG+".AMSKACT" [AMA1]
 Local File =[M]DOSORG+".AMSKPAR" [AMP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AMSK    [AMK2]
 Local File AMSKZON [AMZ2]
 Local File AMSKACT [AMA2]
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".AMSK"    [AMK2]
 Local File =[M]DOSDES+".AMSKZON" [AMZ2]
 Local File =[M]DOSDES+".AMSKACT" [AMA2]
 Local File =[M]DOSDES+".AMSKPAR" [AMP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
For [AMK]CODMSK Where CODMSK>=[M:DIA]MSKDEB & CODMSK<=[M:DIA]MSKFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AMK]UPDDAT<>[0/0/0] & [F:AMK]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AMK]UPDDAT= [0/0/0] & [F:AMK]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AMK]CODACT)
 OK *= [M:DIA]COPMOD([F:AMK]MODULE-1)=2
 If OK
  TABLE = [F:AMK]CODMSK
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBAMK
  If GOK=1
   Call ECR_TRACE(mess(129,123,1)-TABLE,0) From GESECRAN : #  Copie écran
   If [M:DIA]COPTRT=2
    TRAIT = [F:AMK]TRTSTD : Gosub COPTRT
    TRAIT = [F:AMK]TRTSPE : Gosub COPTRT
    TRAIT = [F:AMK]TRTSPV : Gosub COPTRT
   Endif
  Endif
 Endif
Next
Close Local File
Return

$COPTYP
Gosub OUVRE_COP From SUBATY
If [M]DOSORG=nomap
 Local File ATYPE   [ATY]
Else
 Local File =[M]DOSORG+".ATYPE"   [ATY]
Endif
For [ATY]CODTYP Where CODTYP>=[M:DIA]TYPDEB & CODTYP<=[M:DIA]TYPFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ATY]UPDDAT<>[0/0/0] & [F:ATY]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ATY]UPDDAT= [0/0/0] & [F:ATY]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ATY]CODACT)
 If OK
  TABLE = [F:ATY]CODTYP
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBATY
  If GOK=1
   Call ECR_TRACE(mess(114,123,1)-TABLE,0) From GESECRAN
#  Copie type de données
  Endif
 Endif
Next
Close Local File
Return

$COPACT
If [M]DOSORG=nomap
 Local File ACTION    [ACT]
 Local File ACTION    [ACT1]
 Local File ACTPAR    [ATR1]
 Local File ACTCODPAR [AAR1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ACTION"    [ACT]
 Local File =[M]DOSORG+".ACTION"    [ACT1]
 Local File =[M]DOSORG+".ACTPAR"    [ATR1]
 Local File =[M]DOSORG+".ACTCODPAR" [AAR1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ACTION    [ACT2]
 Local File ACTPAR    [ATR2]
 Local File ACTCODPAR [AAR2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ACTION"    [ACT2]
 Local File =[M]DOSDES+".ACTPAR"    [ATR2]
 Local File =[M]DOSDES+".ACTCODPAR" [AAR2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
For [ACT]ACTION Where ACTION>=[M:DIA]ACTDEB & ACTION<=[M:DIA]ACTFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ACT]UPDDAT<>[0/0/0] & [F:ACT]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ACT]UPDDAT= [0/0/0] & [F:ACT]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ACT]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ACT]CODACT)
 If OK
  TABLE = [F:ACT]ACTION
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBACT
  If GOK=1
   Call ECR_TRACE(mess(29,124,1)-TABLE,0) From GESECRAN
#  Copie action
   If [M:DIA]COPTRT=2
    TRAIT = [F:ACT]CODTRT : Gosub COPTRT
   Endif
  Endif
 Endif
Next
Close Local File
Return

$COPOBJ
If [M]DOSORG=nomap
 Local File AOBJET  [AOB]
 Local File AOBJET  [AOB1]
 Local File AOBJTAB [AOT1]
 Local File AOBJLST [AOL1]
 Local File AOBJLNK [AOK1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AOBJET"  [AOB]
 Local File =[M]DOSORG+".AOBJET"  [AOB1]
 Local File =[M]DOSORG+".AOBJTAB" [AOT1]
 Local File =[M]DOSORG+".AOBJLST" [AOL1]
 Local File =[M]DOSORG+".AOBJLNK" [AOK1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AOBJET  [AOB2]
 Local File AOBJTAB [AOT2]
 Local File AOBJLST [AOL2]
 Local File AOBJLNK [AOK2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".AOBJET"  [AOB2]
 Local File =[M]DOSDES+".AOBJTAB" [AOT2]
 Local File =[M]DOSDES+".AOBJLST" [AOL2]
 Local File =[M]DOSDES+".AOBJLNK" [AOK2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
For [AOB]ABREV Where ABREV>=[M:DIA]OBJDEB & ABREV<=[M:DIA]OBJFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AOB]UPDDAT<>[0/0/0] & [F:AOB]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AOB]UPDDAT= [0/0/0] & [F:AOB]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AOB]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AOB]CODACT)
 If OK
  TABLE = [F:AOB]ABREV
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBAOB
  If GOK=1
   Call ECR_TRACE(mess(14,124,1)-TABLE,0) From GESECRAN : # Copie objet
   If [M:DIA]COPTRT=2
    TRAIT = "SUB"+[F:AOB]ABREV : Gosub COPTRT
    TRAIT = "SPE"+[F:AOB]ABREV : Gosub COPTRT
    TRAIT = "SPV"+[F:AOB]ABREV : Gosub COPTRT
   Endif
  Endif
 Endif
Next
Close Local File
Return

$COPFEN
If [M]DOSORG=nomap
 Local File AWINDOW  [AWI]
 Local File AWINDOW  [AWI1]
 Local File AWINPAR  [AWP1]
 Local File AWINBRO  [AWB1]
 Local File AWINBOUT [AWT1]
 Local File ATEXTE   [ATX1]
Else
 Local File =[M]DOSORG+".AWINDOW"  [AWI]
 Local File =[M]DOSORG+".AWINDOW"  [AWI1]
 Local File =[M]DOSORG+".AWINPAR"  [AWP1]
 Local File =[M]DOSORG+".AWINBRO"  [AWB1]
 Local File =[M]DOSORG+".AWINBOUT" [AWT1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AWINDOW  [AWI2]
 Local File AWINPAR  [AWP2]
 Local File AWINBRO  [AWB2]
 Local File AWINBOUT [AWT2]
 Local File ATEXTE   [ATX2]
Else
 Local File =[M]DOSDES+".AWINDOW"  [AWI2]
 Local File =[M]DOSDES+".AWINPAR"  [AWP2]
 Local File =[M]DOSDES+".AWINBRO"  [AWB2]
 Local File =[M]DOSDES+".AWINBOUT" [AWT2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif
For [AWI]AWI0 Where WIN>=[M:DIA]FENDEB & WIN<=[M:DIA]FENFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AWI]UPDDAT<>[0/0/0] & [F:AWI]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AWI]UPDDAT= [0/0/0] & [F:AWI]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AWI]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AWI]CODACT)
 If OK
  TABLE = [F:AWI]WIN
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBAWI
  If GOK=1
   Call ECR_TRACE(mess(14,126,1)-TABLE,0) From GESECRAN
#  Copie
  Endif
 Endif
Next
Close Local File
Return

$COPCNS
If [M]DOSORG=nomap
 Local File ACONSULT  [ACN]
 Local File ACONSULT  [ACN1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".ACONSULT"  [ACN]
 Local File =[M]DOSORG+".ACONSULT"  [ACN1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ACONSULT  [ACN2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".ACONSULT"  [ACN2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
For [ACN]ACN0 Where COD>=[M:DIA]CNSDEB & COD<=[M:DIA]CNSFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ACN]UPDDAT<>[0/0/0] & [F:ACN]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ACN]UPDDAT= [0/0/0] & [F:ACN]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ACN]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ACN]CODACT)
 If OK
  TABLE = [F:ACN]COD
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBACN
  If GOK=1
   Call ECR_TRACE(mess(15,126,1)-TABLE,0) From GESECRAN
#  Copie consultation
   If [M:DIA]COPTRT=2
    TRAIT = [F:ACN]PRGSTD : Gosub COPTRT
    TRAIT = [F:ACN]PRGSPE : Gosub COPTRT
   Endif
  Endif
 Endif
Next
Close Local File
Return

$COPFCT
If [M]DOSORG=nomap
 Local File AFONCTION [AFC]
 Local File AFONCTION [AFC1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".AFONCTION" [AFC]
 Local File =[M]DOSORG+".AFONCTION" [AFC1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AFONCTION [AFC2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".AFONCTION" [AFC2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
For [AFC]CODINT Where CODINT>=[M:DIA]FCTDEB & CODINT<=[M:DIA]FCTFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AFC]UPDDAT<>[0/0/0] & [F:AFC]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AFC]UPDDAT= [0/0/0] & [F:AFC]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AFC]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AFC]CODACT)
 If OK
  TABLE = [F:AFC]CODINT
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBAFC
  If GOK=1
   Call ECR_TRACE(mess(32,124,1)-TABLE,0) From GESECRAN
#  Copie fonction
   If [F:AFC]TYPTRAIT=1 & [M:DIA]COPTRT=2
    TRAIT = [F:AFC]TRAIT : Gosub COPTRT
   Endif
  Endif
 Endif
Next
Close Local File
Return

$COPDIV
If [M]DOSORG=nomap
 Local File ATABTAB [ADV]
 Local File ATABTAB [ADV1]
 Local File ATABDIV [ADI1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".ATABTAB" [ADV]
 Local File =[M]DOSORG+".ATABTAB" [ADV1]
 Local File =[M]DOSORG+".ATABDIV" [ADI1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ATABTAB [ADV2]
 Local File ATABDIV [ADI2]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".ATABTAB" [ADV2]
 Local File =[M]DOSDES+".ATABDIV" [ADI2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
Local Char    DOSDESLEG(GLONADI)(1..dim(GDOSLEG)) , DOSORGLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer NBDESLEG , NBORGLEG
Call SETLEG([M]DOSDES,DOSDESLEG,NBDESLEG) From DOSCONT
Call SETLEG([M]DOSORG,DOSORGLEG,NBORGLEG) From DOSCONT

For [ADV]CODE Where NUMTAB>=[M:DIA]DIVDEB & NUMTAB<=[M:DIA]DIVFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ADV]UPDDAT<>[0/0/0] & [F:ADV]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ADV]UPDDAT= [0/0/0] & [F:ADV]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ADV]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ADV]CODACT)
 If OK
  TABLE = num$([F:ADV]NUMTAB)
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBADI
  If GOK=1
   Call ECR_TRACE(mess(109,123,1)-TABLE,0) From GESECRAN
#  Copie table diverse
  Endif
 Endif
Next
Close Local File
Return

$COPETA
Local File ADOSSIER [ADS]
Call LECTURE("ADS",[M]DOSDES,"") From CONTOBJ
If [M]DOSORG=nomap
 Local File AREPORT  [ARP]
 Local File AREPORT  [ARP1]
 Local File AREPORTD [ARD1]
 Local File AREPORTS [ARO1]
 Local File ATEXTE   [ATX1]
Else
 Local File =[M]DOSORG+".AREPORT"  [ARP]
 Local File =[M]DOSORG+".AREPORT"  [ARP1]
 Local File =[M]DOSORG+".AREPORTD" [ARD1]
 Local File =[M]DOSORG+".AREPORTS" [ARO1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AREPORT  [ARP2]
 Local File AREPORTD [ARD2]
 Local File AREPORTS [ARO2]
 Local File ATEXTE   [ATX2]
Else
 Local File =[M]DOSDES+".AREPORT"  [ARP2]
 Local File =[M]DOSDES+".AREPORTD" [ARD2]
 Local File =[M]DOSDES+".AREPORTS" [ARO2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif
For [ARP]ARP0 Where RPTCOD>=[M:DIA]ETADEB & RPTCOD<=[M:DIA]ETAFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ARP]UPDDAT<>[0/0/0] & [F:ARP]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ARP]UPDDAT= [0/0/0] & [F:ARP]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ARP]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ARP]CODACT)
 If OK
  TABLE = [F:ARP]RPTCOD
  Call DEBTRANS From GLOCK
  Gosub TR_COP From SUBARP
  If GOK=1
   Call ECR_TRACE(mess(194,123,1)-TABLE,0) From GESECRAN
#  Copie état
  Endif
 Endif
Next
If [M:DIA]COPTRT=2
 For ILAN=0 To [F:ADS]NBRLAN-1
  FICORG = filpath(filpath("REPORT",[F:ADS]LAN(ILAN),"",[M]DOSORG),[F:ARP]CRYCOD,"rpt",[M]DOSORG)
  If filinfo(FICORG,0)>=0
   FICDES = filpath(filpath("REPORT",[F:ADS]LAN(ILAN),"",[M]DOSDES),[F:ARP]CRYCOD,"rpt",[M]DOSDES)
   Call COPIE(FICORG,FICDES,STAT) From ORDSYS
  Endif
 Next ILAN
Endif
Close Local File
Return

$COPMES
If [M]DOSORG=nomap
 Local File APLSTD  [AST]
 Local File AMENLOC [AML]
 Local File APLSTD  [AST1]
 Local File AMENLOC [AML1]
Else
 Local File =[M]DOSORG+".APLSTD"  [AST]
 Local File =[M]DOSORG+".AMENLOC" [AML]
 Local File =[M]DOSORG+".APLSTD"  [AST1]
 Local File =[M]DOSORG+".AMENLOC" [AML1]
Endif
If [M]DOSDES=nomap
 Local File APLSTD  [AST2]
 Local File AMENLOC [AML2]
Else
 Local File =[M]DOSDES+".APLSTD"  [AST2]
 Local File =[M]DOSDES+".AMENLOC" [AML2]
Endif
For [AST]CLE(1) Where LAN=GLANGUE & LANCHP>=[M:DIA]MESDEB & LANCHP<=[M:DIA]MESFIN
 Read [AML]MENLOC = [F:AST]LANCHP
 If fstat
  OK =0
 Elsif [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AML]UPDDAT<>[0/0/0] & [F:AML]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AML]UPDDAT= [0/0/0] & [F:AML]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [F:AML]MODULE<>0 & [M:DIA]COPMOD([F:AML]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AML]CODACT)
 If OK
  TABLE = num$([F:AML]MENLOC)
  Call DEBTRANS From GLOCK
  Gosub TR_COP From APLSTD
  If GOK=1
   Call ECR_TRACE(mess(34,124,1)-TABLE,0) From GESECRAN : # Copie chapitre
  Endif
 Endif
Next
Close Local File
Return

$COPPRG
Gosub SETMAC
If DOSORG=SUPORG & DOSDES=SUPDES
 If [M]DOSORG=nomap
  Local File ADICTRT [ADC1]
 Else
  Local File =[M]DOSORG+".ADICTRT" [ADC1]
 Endif
 If [M]DOSDES=nomap
  Local File ADICTRT [ADC2]
 Else
  Local File =[M]DOSDES+".ADICTRT" [ADC2]
 Endif
Endif
Local Integer I , J , K , NBPRG , TOUS , MAXPRG
Local Char    BID(10) , VERMOT(30)
VERMOT = func AFNC.PARTSEP(ver$(0),2," ")
TOUS = (sum([M:DIA]COPMOD(0..[M:DIA]NBMOD-1))=[M:DIA]NBMOD*2)
TOUS *= ([M:DIA]CODACT="")
# Calcul nb de trt sans les "W"
For I=65 To 86 : # A -> V
 If VERMOT>="17r.106"
  # 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
  GBIDC1 = "archive -d"-[M]DOSORG-'-t'-'-l "'+chr$(I)+'*"'
 Else
  GBIDC1 = "archive -d"-[M]DOSORG-'-t "adx"'-'-l "'+chr$(I)+'*" -v'
 Endif
 Call SYSTEME2("",GBIDC1,"",K,BID) From ORDSYS
 MAXPRG = max(K,MAXPRG)
 NBPRG += K
Next I
For I=88 To 90 : # X -> Z
 If VERMOT>="17r.106"
  # 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
  GBIDC1 = "archive -d"-[M]DOSORG-'-t'-'-l "'+chr$(I)+'*"'
 Else
  GBIDC1 = "archive -d"-[M]DOSORG-'-t "adx"'-'-l "'+chr$(I)+'*" -v'
 Endif
 Call SYSTEME2("",GBIDC1,"",K,BID) From ORDSYS
 MAXPRG = max(K,MAXPRG)
 NBPRG += K
Next I
# On prend des précautions et une marge
NBPRG = max(1,min(32767,NBPRG+100))
MAXPRG = max(1,min(32767,MAXPRG+100))
Local Char    PRG(GLONADC)(NBPRG)
Local Char    TMP(GLONADC)(MAXPRG)
NBPRG = 0
For I=65 To 86
 If VERMOT>="17r.106"
  # 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
  GBIDC1 = "archive -d"-[M]DOSORG-'-t'-'-l "'+chr$(I)+'*"'
 Else
  GBIDC1 = "archive -d"-[M]DOSORG-'-t "adx"'-'-l "'+chr$(I)+'*" -v'
 Endif
 Call SYSTEME2("",GBIDC1,"",K,TMP) From ORDSYS
 For J=1 To min(32767,K)
  NBPRG += 1
  PRG(NBPRG) = TMP(J)
 Next J
Next I
For I=88 To 90
 If VERMOT>="17r.106"
  # 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
  GBIDC1 = "archive -d"-[M]DOSORG-'-t'-'-l "'+chr$(I)+'*"'
 Else
  GBIDC1 = "archive -d"-[M]DOSORG-'-t "adx"'-'-l "'+chr$(I)+'*" -v'
 Endif
 Call SYSTEME2("",GBIDC1,"",K,TMP) From ORDSYS
 For J=1 To min(32767,K)
  NBPRG += 1
  PRG(NBPRG) = TMP(J)
 Next J
Next I
For I=1 To NBPRG
 If PRG(I)>=[M]TRTDEB & PRG(I)<=[M]TRTFIN & left$(PRG(I),1)<>"W"
  If clalev([F:ADC1])<=0
   OK = 0
  Else
   Read [ADC1]ADC0 = PRG(I)
   If fstat
    OK = 0
   Else
    OK = 1
    OK *= [M:DIA]COPMOD([F:ADC1]MODULE-1)=2
    OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ADC1]CODACT)
   Endif
  Endif
  If OK & [M:DIA]DATDEB<>[0/0/0]
   Call INFO_ADX("",[M]DOSORG,PROG(I),9,BID) From ORDSYS
   DATFIC = [01/01/1970]+int(val(BID)/(24*3600))
   If DATFIC<[M:DIA]DATDEB
    OK = 0
   Endif
  Endif
  If OK
   TABLE = PRG(I)
   Call DEBTRANS From GLOCK
   If clalev([F:ADC1])>0
    Gosub TR_COP From SUBADC
   Endif
   If GOK=1
    TRAIT = PRG(I)
    Gosub COPTRT
   Endif
  Endif
 Endif
Next I
Close Local File
Return

########################################
$COPTRT
If TRAIT="" : Return : Endif
Raz COP , COPSRC
FICORG = filpath("TRT",TRAIT,"src",[M]DOSORG)
If filinfo(FICORG,0)>=0
 FICDES = filpath("TRT",TRAIT,"src",[M]DOSDES)
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 COP = 1
 COPSRC = 1
Endif
FICORG = filpath("TRT",TRAIT,"xrc",[M]DOSORG)
If filinfo(FICORG,0)>=0
 FICDES = filpath("TRT",TRAIT,"xrc",[M]DOSDES)
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 COP = 1
Endif
Call MACHINE([M]DOSORG,MACO,DOSO) From ORDSYS
Call EXISTE_ADX(MACO,DOSO,TRAIT,STAT) From ORDSYS
If STAT>0
 If COPSRC & MACD<>"" : # mb 31.1.8 pour éviter des pb de versions d'archive
  Call VALID("TRT",TRAIT,MACD+"@"+DOSD,STAT) From VALMSKSUB
 Else
  Call MACHINE([M]DOSDES,MACD,DOSD) From ORDSYS
  Call COPIE_ADX(MACO,DOSO,TRAIT,MACD,DOSD,TRAIT,STAT) From ORDSYS
 Endif
 COP = 1
Endif
If COP
 Call ECR_TRACE(mess(130,123,1)-TRAIT,0) From GESECRAN : # Copie traitement
Endif
Return

########################################
$VALTAB
Local File ADOSSIER [ADS], ADOSACT [ADA]
Local File =[M]DOSDES+".ATABLE"  [ATB]
&         ,=[M]DOSDES+".ATABIND" [ATI]
&         ,=[M]DOSDES+".ATABZON" [ATZ]
&         ,=[M]DOSDES+".ATEXTE"  [ATX]
&         ,=[M]DOSDES+".ATYPE"   [ATY]
&         ,=[M]DOSDES+".ACTIV"   [ACV]
&         ,=[M]DOSDES+".AINDEX"  [ANX]
Local File =[M]DOSDES+".ATABLE"  [ATB2]

Call LECTURE("ADS",DOS,"") From CONTOBJ

## BY 22/11/00 Il ne faut pas valider les tables "système X3"
For [ATB2]CODFIC Where CODFIC>=[M:DIA]TABDEB & CODFIC<=[M:DIA]TABFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ATB2]UPDDAT<>[0/0/0] & [F:ATB2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ATB2]UPDDAT= [0/0/0] & [F:ATB2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ATB2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ATB2]CODACT)
 OK *= [F:ATB2]TYPFIC<>3
 If OK
  [F:ATB] = [F:ATB2]
  Call MAJTAB([F:ATB2]CODFIC,0) From DOSTAB
  Call ECR_TRACE("---"-mess(110,124,1)-[F:ATB2]CODFIC,0) From GESECRAN : # Validation table
 Endif
Next
Close Local File

# Mise à jour des triggers

Local File ADOSSIER [ADS], ADOSACT [ADA]
Local File =[M]DOSDES+".ATABLE"  [ATB]
&         ,=[M]DOSDES+".ATABIND" [ATI]
&         ,=[M]DOSDES+".ATABZON" [ATZ]
&         ,=[M]DOSDES+".ATEXTE"  [ATX]
&         ,=[M]DOSDES+".ATYPE"   [ATY]
&         ,=[M]DOSDES+".ACTIV"   [ACV]
&         ,=[M]DOSDES+".AINDEX"  [ANX]
Local File =[M]DOSDES+".ATABLE"  [ATB2]

Call LECTURE("ADS",DOS,"") From CONTOBJ

For [ATB2]CODFIC Where CODFIC>=[M:DIA]TABDEB & CODFIC<=[M:DIA]TABFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ATB2]UPDDAT<>[0/0/0] & [F:ATB2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ATB2]UPDDAT= [0/0/0] & [F:ATB2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ATB2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ATB2]CODACT)
 OK *= [F:ATB2]TYPFIC<>3
 If OK
  [F:ATB] = [F:ATB2]
  Call MAJTRIGDOS([M]DOSDES,[F:ATB2]CODFIC) From DOSTAB
 Endif
Next
Close Local File
Return

########################################
$VALVUE
Local File ADOSSIER [ADS]
Local File =[M]DOSDES+".AVIEW"   [AVW]
&         ,=[M]DOSDES+".AVIEWD"  [AVD]
&         ,=[M]DOSDES+".ATEXTE"  [ATX]
&         ,=[M]DOSDES+".ATYPE"   [ATY]
&         ,=[M]DOSDES+".ACTIV"   [ACV]
Local File =[M]DOSDES+".AVIEW"   [AVW2]

Call LECTURE("ADS",DOS,"") From CONTOBJ

For [AVW2]AVW0 Where CODVUE>=[M:DIA]VUEDEB & CODVUE<=[M:DIA]VUEFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AVW2]UPDDAT<>[0/0/0] & [F:AVW2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AVW2]UPDDAT= [0/0/0] & [F:AVW2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AVW2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AVW2]CODACT)
 If OK
  Call MAJVUE([F:AVW2]CODVUE,DOS) From DOSVUE
  Call ECR_TRACE("---"-mess(84,139,1)-[F:AVW2]CODVUE,0) From GESECRAN : # Validation de la vue
 Endif
Next
Close Local File
Return

########################################
$VALMSK
Local Char APPLI(80)
APPLI = [M]DOSDES
Gosub OUVFIC From VALMSKLEC
Local File =[M]DOSDES+".AMSK"   [AMK2]

Call LECTURE("ADS",DOS,"") From CONTOBJ
SAVLAN = GLANGUE

For [AMK2]CODMSK Where CODMSK>=[M:DIA]MSKDEB & CODMSK<=[M:DIA]MSKFIN & MDL<>2
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AMK2]UPDDAT<>[0/0/0] & [F:AMK2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AMK2]UPDDAT= [0/0/0] & [F:AMK2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AMK2]CODACT)
 OK *= [M:DIA]COPMOD([F:AMK2]MODULE-1)=2
 If OK
  Call VALID([F:AMK2]CODMSK,[M]DOSDES,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  Call ECR_TRACE("---"-mess(139,123,1)-[F:AMK2]CODMSK,0) From GESECRAN
  # Validation écran
 Endif
Next
Close Local File
Return

########################################
$VALOBJ
Local File =[M]DOSDES+".AOBJET"    [AOB]
Local File =[M]DOSDES+".AOBJTAB"   [AOT]
Local File =[M]DOSDES+".AOBJLST"   [AOL]
Local File =[M]DOSDES+".AOBJLNK"   [AOK]
Local File =[M]DOSDES+".AWINDOW"   [AWI]
Local File =[M]DOSDES+".AWINBRO"   [AWB]
Local File =[M]DOSDES+".ATABLE"    [ATB]
Local File =[M]DOSDES+".ATABZON"   [ATZ]
Local File =[M]DOSDES+".ATABIND"   [ATI]
Local File =[M]DOSDES+".AINDEX"    [ANX]
Local File =[M]DOSDES+".ATYPE"     [ATY]
Local File =[M]DOSDES+".AMENLOC"   [AML]
Local File =[M]DOSDES+".ATEXTE"    [ATX]
Local File =[M]DOSDES+".AMSK"      [AMK]
Local File =[M]DOSDES+".AMSKZON"   [AMZ]
Local File =[M]DOSDES+".ACTIV"     [ACV]
Local File =[M]DOSDES+".AELT"      [AEL]
Local File =[M]DOSDES+".AELTLINK"  [AEK]
Local File =[M]DOSDES+".AFONCTION" [AFC]
Local File =[M]DOSDES+"."+adxtms   [STD]
Local File =[M]DOSDES+".AOBJET"    [AOB2]

For [AOB2]ABREV Where ABREV>=[M:DIA]OBJDEB & ABREV<=[M:DIA]OBJFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AOB2]UPDDAT<>[0/0/0] & [F:AOB2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AOB2]UPDDAT= [0/0/0] & [F:AOB2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AOB2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AOB2]CODACT)
 If OK
  Call VALID([F:AOB2]ABREV,[M]DOSDES,1,OK) From VALOBJ
  Call GENFONC2([M]DOSDES,[F:AOB2]ABREV)  From OBJFNC
  Call ECR_TRACE("---"-mess(13,124,1)-[F:AOB2]ABREV,0) From GESECRAN : # Validation objet
 Endif
Next
Close Local File
Return

########################################
$VALFEN
Local File =[M]DOSDES+".AWINDOW"  [AWI]
Local File =[M]DOSDES+".AWINPAR"  [AWP]
Local File =[M]DOSDES+".AWINBRO"  [AWB]
Local File =[M]DOSDES+".AWINBOUT" [AWT]
Local File =[M]DOSDES+".AOBJET"   [AOB]
Local File =[M]DOSDES+".ATABLE"   [ATB]
Local File =[M]DOSDES+".ATABIND"  [ATI]
Local File =[M]DOSDES+".ATABZON"  [ATZ]
Local File =[M]DOSDES+".ATYPE"    [ATY]
Local File =[M]DOSDES+".ATEXTE"   [ATX]
Local File =[M]DOSDES+".AMSK"     [AMK]
Local File =[M]DOSDES+".AMSKZON"  [AMZ]
Local File =[M]DOSDES+".ATABLE"   [AT2]
Local File =[M]DOSDES+".ACTIV"    [ACV]
Local File =[M]DOSDES+".ACTION"   [ACT]
Local File =[M]DOSDES+".ACTPAR"   [ATR]
Local File =[M]DOSDES+".AWINDOW"  [AWI2]

For [AWI2]AWI0 Where WIN>=[M:DIA]FENDEB & WIN<=[M:DIA]FENFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:AWI2]UPDDAT<>[0/0/0] & [F:AWI2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:AWI2]UPDDAT= [0/0/0] & [F:AWI2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:AWI2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:AWI2]CODACT)
 If OK
  Call VALID([F:AWI2]WIN,[M]DOSDES,0,OK) From VALWIN
  Call ECR_TRACE("---"-mess(28,126,1)-[F:AWI2]WIN,0) From GESECRAN : # Validation fenêtre
  If [F:AWI2]OBJ<>""
   Call VALID([F:AWI2]OBJ,[M]DOSDES,0,OK) From VALOBJ
   Call ECR_TRACE("---"-mess(13,124,1)-[F:AWI2]WIN,0) From GESECRAN : # Validation objet
  Endif
 Endif
Next
Close Local File
Return

$VALCONS
Local File =[M]DOSDES+".ACONSULT"  [ACN]
Local File =[M]DOSDES+".AMSK"      [AMK]
Local File =[M]DOSDES+".ATABLE"    [ATB]
Local File =[M]DOSDES+".AWINDOW"   [AWI]
Local File =[M]DOSDES+".ACONSULT"  [ACN2]

For [ACN2]ACN0 Where COD>=[M:DIA]CNSDEB & COD<=[M:DIA]CNSFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ACN2]UPDDAT<>[0/0/0] & [F:ACN2]UPDDAT>=[M:DIA]DATDEB
  OK += [F:ACN2]UPDDAT= [0/0/0] & [F:ACN2]CREDAT>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ACN2]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ACN2]CODACT)
 If OK
  Call GENTRT([M]DOSDES,[F:ACN2]COD) From ACNTRT
  Call ECR_TRACE("---"-mess(23,126,1)-[F:ACN2]COD,0) From GESECRAN : # Validation consultation
 Endif
Next
Close Local File
Return

$VALMEN
Local File ADOSSIER [ADS]
Call LECTURE("ADS",[M]DOSDES,"") From CONTOBJ
Call GENMEN From DOSMEN
Close Local File
Return

$SETMAC
Local Char    DOSORG(20) , DOSDES(20)
Local Char    MACORG(40) , MACDES(40)
Call MACHINE([M]DOSORG,[L]MACORG,[L]DOSORG) From ORDSYS
Call MACHINE([M]DOSDES,[L]MACDES,[L]DOSDES) From ORDSYS
If [M]DOSORG=nomap
 Local File ADOVAL  [ADW1]
Else
 Local File =[M]DOSORG+".ADOVAL"   [ADW1]
Endif
If [M]DOSDES=nomap
 Local File ADOVAL  [ADW2]
Else
 Local File =[M]DOSDES+".ADOVAL"   [ADW2]
Endif
Read [ADW1]ADW0 = "";"";"SUPDOS"
If !fstat : SUPORG = [F:ADW1]VALEUR : Endif
Read [ADW2]ADW0 = "";"";"SUPDOS"
If !fstat : SUPDES = [F:ADW2]VALEUR : Endif
Close Local File [ADW1] , [ADW2]
Return

########################################

$VALACLA
Local File =[M]DOSDES+".ACLASSE"  [ACLA]
For [ACLA]ACLA0 Where CODCLA>=[M:DIA]ACLADEB & CODCLA<=[M:DIA]ACLAFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ACLA]UPDDATTIM<>gdatetime$("") & func SUBADC.DAT_DATETIME([F:ACLA]UPDDATTIM)>=[M:DIA]DATDEB
  OK += [F:ACLA]UPDDATTIM= gdatetime$("") & func SUBADC.DAT_DATETIME([F:ACLA]CREDATTIM)>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ACLA]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ACLA]CODACT)
 If OK
  Call VALIDATION(0,[M]DOSDES,[ACLA]CODCLA) From SUBACLA
 Endif
Next
Close Local File
Return

########################################

$VALASW
Local File =[M]DOSDES+".ASHW"  [ASW]
For [ASW]ASW0 Where CODREP>=[M:DIA]ASWDEB & CODREP<=[M:DIA]ASWFIN
 If [M:DIA]DATDEB<>[0/0/0]
  OK  = 0
  OK += [F:ASW]UPDDATTIM<>gdatetime$("") & func SUBADC.DAT_DATETIME([F:ASW]UPDDATTIM)>=[M:DIA]DATDEB
  OK += [F:ASW]UPDDATTIM= gdatetime$("") & func SUBADC.DAT_DATETIME([F:ASW]CREDATTIM)>=[M:DIA]DATDEB
 Else
  OK = 1
 Endif
 OK *= [M:DIA]COPMOD([F:ASW]MODULE-1)=2
 OK *= ([M:DIA]CODACT="" or [M:DIA]CODACT=[F:ASW]CODACT)
 If OK
  Call VALIDATION(0,[M]DOSDES,[ASW]CODREP) From SUBASW
 Endif
Next
Close Local File
Return

########################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Gosub GRISE_TAB
Gosub GRISE_VUE
Gosub GRISE_MSK
Gosub GRISE_TYP
Gosub GRISE_ACT
Gosub GRISE_FCT
Gosub GRISE_OBJ
Gosub GRISE_FEN
Gosub GRISE_CNS
Gosub GRISE_DIV
Gosub GRISE_MES
Gosub GRISE_TRT
Gosub GRISE_ETA
Setmok [M] With 0
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_DOSDES(VALEUR)
Variable Char     VALEUR
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
If mkstat : End : Endif
GDOSPATH = VALEUR
Local Char MACHINE(GDIMFIC) , DOS(GDIMFIC)
Call MACHINE(VALEUR,MACHINE,DOS) From ORDSYS
If MACHINE<>"" & MACHINE<>adxmac(0)
 [M]VALDIC = 1 : Affzo VALDIC : Grizo VALDIC
Else
 Actzo VALDIC
Endif
[M]DOSDES = VALEUR
Gosub SETMAC
If DOSORG<>SUPORG | DOSDES<>SUPDES
 [M]TRAIT = 1 : [M]TRTDEB = "" : [M]TRTFIN = ""
 Affzo TRAIT , TRTDEB , TRTFIN
 Grizo TRAIT , TRTDEB , TRTFIN
Else
 Actzo TRAIT , TRTDEB , TRTFIN
Endif
End

Subprog AS_NBMOD
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
End

Subprog B2_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]COPMOD(I-1) = 2
Next I
Affzo 30
End

Subprog B3_NBMOD
Local Integer I
For I=nolign To [M]NBMOD
 [M]COPMOD(I-1) = 1
Next I
Affzo 30
End

