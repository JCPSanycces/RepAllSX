Subprog AM_TABLE(VALEUR)
Variable Integer VALEUR
[M]TABLE = VALEUR
Effzo TABDEB , TABFIN
Gosub GRISE_TAB
End

$GRISE_TAB
If [M]TABLE=1
 [M]TABDEB = ""
 [M]TABFIN = ""
 Diszo TABDEB , TABFIN
Else
 Actzo TABDEB , TABFIN
Endif
Return

