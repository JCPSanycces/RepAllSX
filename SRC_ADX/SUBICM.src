#<AdxTL>@(#)0.0.0.0 $Revision$
# Traitement spécial de comparaison des coûts
# permet de comparer des coûts standards entre eux ou avec des PRF
# Aucune mise à jour
# (Attention par analogie d'abréviation le titre de ce trt est erroné !
# Ce programme n'a rien à voir avec le fichier ITMCOMP)

# Webification en GSAISIE Action  SAIITCCOMP (09/05/03)

$ACTION
# actions pour GSAISIE
Case ACTION
 When "OUVRE"        Gosub OUVRE
 When "SETBOUT"      Gosub SETBOUT
 When "ABA"          Gosub ABA
 When "APRES_MODIF"  Gosub APRES_MODIF
 When "OK"           Gosub OK
 When "FIN"          Gosub FIN
 When "DEBUT"        Gosub DEBUT
 When "AVANT_EDI"    Gosub AVANT_EDI
Endcase
Return


$OUVRE
#Local Integer COUT1_OK, COUT2_OK
Local Integer MODIF_SEL    # modifcation des éléments de sélection
Local Integer I
Local Char    NO_COUT(1) : # ATTENTION: alpha "1" ou "2" pour assigner les zones écrans

Local File ITMCOST [ITC]
If GMODU(8) = 2            :# Test module Prod rajouté le 22/06/99
   Local File MFGCOST [MFC]
Endif
If clalev([F:TCU]) = 0 : Local File TABCUR [TCU] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

Return



$DEBUT
Call RAZPRONUM From SUBICMCOM
Raz [M:ICM0]
[M:ICM0]NIV = 1
Affzo [M:ICM0]NIV

  [M:ICM1]NBLIG = 8
  Call TEXTE(11249,[M:ICM1]LINE(0)) From OBJDIV
  Call TEXTE(1071, [M:ICM1]LINE(1)) From OBJDIV
  Call TEXTE(8757, [M:ICM1]LINE(2)) From OBJDIV
  Call TEXTE(23447,[M:ICM1]LINE(3)) From OBJDIV
  Call TEXTE(1888, [M:ICM1]LINE(4)) From OBJDIV
  Call TEXTE(6567, [M:ICM1]LINE(5)) From OBJDIV
  Call TEXTE(8789, [M:ICM1]LINE(6)) From OBJDIV
  Call TEXTE(11205,[M:ICM1]LINE(7)) From OBJDIV
  Affzo [M:ICM1]

  [M:ICM4]NBLIG = 5
  Call TEXTE(11249,[M:ICM4]LINE(0)) From OBJDIV
  Call TEXTE(1071, [M:ICM4]LINE(1)) From OBJDIV
  Call TEXTE(8757, [M:ICM4]LINE(2)) From OBJDIV
  Call TEXTE(1904, [M:ICM4]LINE(3)) From OBJDIV
  Call TEXTE(4245, [M:ICM4]LINE(4)) From OBJDIV
  Affzo [M:ICM4]
Return

$SETBOUT
If MODIF_SEL
  ETABOU(GABAN) = 1
Endif
If [M:ICM1]CSTTOT1=0 |[M:ICM1]CSTTOT2=0
    Call VIREBOUT(CHBOU,"I") From GOBJET
Endif

Return

$AVANT_EDI
    Call RAZIMC From SUBICMCOM
    Call WRIIMC From SUBICMCOM
Return

$ABA
# effacement des champs de sélection et des onglets
Raz [M:ICM0]: Raz[M:ICM1]: Raz[M:ICM2]: Raz[M:ICM3]: Raz[M:ICM4]
[M:ICM0]NIV = 1
Affzo [M:ICM0]
Affzo [M:ICM1]
Affzo [M:ICM2]
Affzo [M:ICM3]
Affzo [M:ICM4]
MODIF_SEL = 0
Gosub SETBOUT
Return

$OK
# relecture à partir des éléments affichés
Gosub LIRE1
Gosub LIRE2
FIN = 0     # SINON ON SORT DE GSAISIE !!!

#  [M:ICM1]NBLIG = 8
#  Call TEXTE(11249,[M:ICM1]LINE(0)) From OBJDIV
#  Call TEXTE(1071, [M:ICM1]LINE(1)) From OBJDIV
#  Call TEXTE(8757, [M:ICM1]LINE(2)) From OBJDIV
#  Call TEXTE(23447,[M:ICM1]LINE(3)) From OBJDIV
#  Call TEXTE(1888, [M:ICM1]LINE(4)) From OBJDIV
#  Call TEXTE(6567, [M:ICM1]LINE(5)) From OBJDIV
#  Call TEXTE(8789, [M:ICM1]LINE(6)) From OBJDIV
#  Call TEXTE(11205,[M:ICM1]LINE(7)) From OBJDIV
#
#  [M:ICM4]NBLIG = 5
#  Call TEXTE(11249,[M:ICM4]LINE(0)) From OBJDIV
#  Call TEXTE(1071, [M:ICM4]LINE(1)) From OBJDIV
#  Call TEXTE(8757, [M:ICM4]LINE(2)) From OBJDIV
#  Call TEXTE(1904, [M:ICM4]LINE(3)) From OBJDIV
#  Call TEXTE(4245, [M:ICM4]LINE(4)) From OBJDIV
#
#  Affzo [M:ICM1]
#  Affzo [M:ICM4]

Return

$FIN

Return


$APRES_MODIF
MODIF_SEL = 1 # pour activer le btn Abandon
Case COUZON
 When "ITMREF"
    Call LECTURE("ITM",CZ,"") From CONTOBJ
    [M]STU = [F:ITM]STU
    [M:ICM1]STU1 = [F:ITM]STU
    [M]ITMREF = CZ
    Gosub LIRE1
    Gosub LIRE2
 When "DEVTYP"
    [M]DEVTYP = val(CZ)
    If [M:ICM0]CSTFLG1 & [M:ICM0]CSTFLG2
        Gosub CAL_ECA
        Call AFFZOICM("E") # blocs écart
    Endif
 When "UNTFLG"
    [M]UNTFLG = val(CZ)
    If [M:ICM0]CSTFLG1 & [M:ICM0]CSTFLG2
      Gosub LIRE1
      Gosub LIRE2
    Endif
 When "CSTTYP1"
    [M]CSTTYP1 = val(CZ)
    Gosub LIRE1
 When "STOFCY1" :
    [M]STOFCY1 = CZ
    Gosub LIRE1
 When "ITCDAT1" :
    [M]ITCDAT1 = CZ
    Gosub LIRE1
 When "VCRNUM1" :
    [M]VCRNUM1 = CZ
    Gosub LIRE1
 When "CSTTYP2"
    [M]CSTTYP2= val(CZ)
    Gosub LIRE2
 When "STOFCY2" :
    [M]STOFCY2= CZ
    Gosub LIRE2
 When "ITCDAT2" :
    [M]ITCDAT2 = CZ
    Gosub LIRE2
 When "VCRNUM2" :
    [M]VCRNUM2 = CZ
    Gosub LIRE2
 When "NIV" :
    [M]NIV = val(CZ)
    Gosub LIRE1
    Gosub LIRE2
 When "AFFZER" :
    [M]AFFZER = val(CZ)
    Gosub CHARGE_GRAPHE From SUBICMG
 When Default
Endcase
Return

# Lecture du premier coût
#########################
$LIRE1
Call INITMSK
If [M:ICM0]CSTTYP1 < 5
  Default File [ITC]
Else
  Default File [MFC]
Endif
[M:ICM0]CSTFLG1 = 0
If [M:ICM0]CSTTYP1 < 5  & [M:ICM0]ITCDAT1>[0/0/0]
    Read [ITC]ITC0(4)=[M:ICM0]STOFCY1;[M:ICM0]ITMREF;[M:ICM0]CSTTYP1;[M:ICM0]ITCSEQ1
    [G:ITC]currlen = 0
    If fstat
    # Quand on a déjà une date chargée mais pas de coût, la modif du site peut suffir à trouver un coût
        Filter [ITC] Where STOFCY=[M:ICM0]STOFCY1 & ITMREF=[M:ICM0]ITMREF & CSTTYP=[M:ICM0]CSTTYP1 & ITCDAT>=[M:ICM0]ITCDAT1
&                    Order By Key DAT1=ITCDAT;ITCSEQ Desc
        Read [ITC]DAT1 First
        Filter [ITC]
    Endif
    If !fstat
      [M:ICM0]ITCSEQ1 = [F:ITC]ITCSEQ
      [M:ICM0]ITCDAT1 = [F:ITC]ITCDAT
      [M:ICM0]ITCSTRDAT1 = [F:ITC]ITCSTRDAT
      [M:ICM0]ITCENDDAT1 = [F:ITC]ITCENDDAT
    Endif
Elsif [M:ICM0]CSTTYP1 >= 5
  Read [MFC]MFC0=[M:ICM0]STOFCY1;[M:ICM0]ITMREF;[M:ICM0]VCRTYP1;[M:ICM0]VCRNUM1;[M:ICM0]VCRLIN1;[M:ICM0]CSTTYP1-4;0
Endif
If !fstat
  NO_COUT = "1"
  If [M:ICM0]CSTTYP1 < 5 & [M:ICM0]NIV=1
      Gosub CHARGE_COUT2
  Elsif [M:ICM0]CSTTYP1 > 4 & ([M:ICM0]CSTTYP1 < 8 | [M:ICM0]CSTTYP1=8) & [M:ICM0]NIV=2
      Gosub CHARGE_COUT3
  Else
      Gosub CHARGE_COUT
  Endif
  [M:ICM0]CSTFLG1 = 1
  If [M:ICM0]CSTFLG2 = 1 Gosub CAL_ECA Endif
  Call AFFZOICM("1E")  # bloc premier cout et écart
Else
  Call EFFZOICM("1E")
  [M:ICM1]STU1 = [M:ICM0]STU : Affzo [M:ICM1]STU1 : # réafficher après effzo !!
Endif
Gosub CHARGE_GRAPHE From SUBICMG
Return

$LIRE2
# Lecture et chargement du 2ème coût
# Lecture de ITC ou de MFC selon le type
Call INITMSK
If [M:ICM0]CSTTYP2 < 5
  Default File [ITC]
Else
  Default File [MFC]
Endif
[M:ICM0]CSTFLG2 = 0
If [M:ICM0]CSTTYP2 < 5
    Read [ITC]ITC0(4)=[M:ICM0]STOFCY2;[M:ICM0]ITMREF;[M:ICM0]CSTTYP2;[M:ICM0]ITCSEQ2
    [G:ITC]currlen = 0
    If fstat
        Filter [ITC] Where STOFCY=[M:ICM0]STOFCY2 & ITMREF=[M:ICM0]ITMREF & CSTTYP=[M:ICM0]CSTTYP2 & ITCDAT>=[M:ICM0]ITCDAT2
&                    Order By Key DAT1=ITCDAT;ITCSEQ Desc
        Read [ITC]DAT1 First
        Filter [ITC]
    Endif
    If !fstat
      [M:ICM0]ITCSEQ2 = [F:ITC]ITCSEQ
      [M:ICM0]ITCDAT2 = [F:ITC]ITCDAT
      [M:ICM0]ITCSTRDAT2 = [F:ITC]ITCSTRDAT
      [M:ICM0]ITCENDDAT2 = [F:ITC]ITCENDDAT
    Endif
Elsif [M:ICM0]CSTTYP2 >= 5
  Read [MFC]MFC0=[M:ICM0]STOFCY2;[M:ICM0]ITMREF;[M:ICM0]VCRTYP2;[M:ICM0]VCRNUM2;[M:ICM0]VCRLIN2;[M:ICM0]CSTTYP2-4;0
Endif
If !fstat
  NO_COUT = "2"
  If [M:ICM0]CSTTYP2 < 5 & [M:ICM0]NIV=1
      Gosub CHARGE_COUT2
  Elsif [M:ICM0]CSTTYP2 > 4 & ([M:ICM0]CSTTYP2 < 8 | [M:ICM0]CSTTYP2=8) & [M:ICM0]NIV=2
      Gosub CHARGE_COUT3
  Else
      Gosub CHARGE_COUT
  Endif
  [M:ICM0]CSTFLG2 = 1
  If [M:ICM0]CSTFLG1 = 1 Gosub CAL_ECA Endif
  Call AFFZOICM("2E")
Else
  Call EFFZOICM("2E")
Endif

Gosub CHARGE_GRAPHE From SUBICMG
Return

##################################################################
# CHARGE_COUT : Charge le prix standard en multi-niveau ou le PRF en mono-niveau
##################################################################
$CHARGE_COUT
# chargement du 1er ou du 2è coût avec le ficher ITC OU MFC (qui est positionné par défaut)
Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With [F]MATTOT
Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With [F]MACTOT
Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With [F]LABTOT
Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With [F]SCOTOT
If dim([F]INVDTATOT)>0
    Assign "[M:ICM1]INVDTA"+ NO_COUT With [F]INVDTATOT
Endif
Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With [F]OVETOT
# 15441, le coût doit inclure les FG
If evalue("[M:ICM0]CSTTYP"+NO_COUT) < 5
    Assign "[M:ICM1]CSTTOT"+ NO_COUT With [F]CSTTOT
    Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With [F]VLTTOT
Else
    Assign "[M:ICM1]CSTTOT"+ NO_COUT With [F]CSTTOT
    Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With [F]CSTTOT + [F]OVETOT
Endif
# La zone écran CLCQTYx reprend la qté calculée des couts std ou la qté prévue/réal des PRF
If evalue("[M:ICM0]CSTTYP"+NO_COUT) < 5
  Assign "[M:ICM1]COST"+ NO_COUT +"(6)" With [F]CLCQTY
Else
  Assign "[M:ICM1]COST"+ NO_COUT +"(6)" With [F]QTYSTU
Endif
# 15441, le coût doit inclure les FG
If evalue("[M:ICM0]CSTTYP"+NO_COUT) < 5
    Assign "[M:ICM1]COST"+ NO_COUT +"(7)" With [F]VLTTOT
Else
    Assign "[M:ICM1]COST"+ NO_COUT +"(7)" With [F]CSTTOT + [F]OVETOT
Endif
# chargement des autres onglets ...
For I = 0 To GACTMAT-1
  Assign "[M:ICM2]MATCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MATCST(I)
Next
Assign "[M:ICM2]MATCST"+ NO_COUT+"(GACTMAT)" With [F]MATTOT
Assign "[M:ICM2]SCOTOT"+ NO_COUT With [F]SCOTOT

For I = 0 To GACTMAC-1
  Assign "[M:ICM3]MACCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MACCST(I)
Next
Assign "[M:ICM3]MACCST"+ NO_COUT +"(GACTMAC)" With [F]MACTOT

For I = 0 To GACTLAB-1
  Assign "[M:ICM3]LABCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]LABCST(I)
Next
Assign "[M:ICM3]LABCST"+ NO_COUT +"(GACTLAB)" With [F]LABTOT

Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With [F]OVEMATCST
Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With [F]OVEMACCST
Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With [F]OVELABCST
Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With [F]OVESCOCST
Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With [F]OVETOT

# Affichage des totaux au lieu des coûts unitaires de la table
If [M:ICM0]UNTFLG = 1
  Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With evalue("[M:ICM1]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With evalue("[M:ICM1]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With evalue("[M:ICM1]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With evalue("[M:ICM1]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With evalue("[M:ICM1]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With evalue("[M:ICM1]COST"+ NO_COUT +"(5)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]CSTTOT"+ NO_COUT With evalue("[M:ICM1]CSTTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")


# chargement des autres onglets ...
  For I = 0 To GACTMAT-1
   Assign "[M:ICM2]MATCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM2]MATCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM2]MATCST"+ NO_COUT +"(GACTMAT)" With evalue("[M:ICM2]MATCST"+NO_COUT+"(GACTMAT)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM2]SCOTOT"+ NO_COUT With evalue("[M:ICM2]SCOTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTMAC-1
   Assign "[M:ICM3]MACCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]MACCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]MACCST"+ NO_COUT+"(GACTMAC)" With evalue("[M:ICM3]MACCST"+NO_COUT+"(GACTMAC)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTLAB-1
   Assign "[M:ICM3]LABCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]LABCST"+ NO_COUT+"(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]LABCST"+ NO_COUT+"(GACTLAB)" With evalue("[M:ICM3]LABCST"+NO_COUT+"(GACTLAB)"+"*[M:ICM1]COST"+ NO_COUT +"(6)")

  Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With evalue("[M:ICM4]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With evalue("[M:ICM4]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With evalue("[M:ICM4]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With evalue("[M:ICM4]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With evalue("[M:ICM4]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

Endif
Return


##################################################################
# CHARGE_COUT2 : Charge le prix standard en mono-niveau
##################################################################
$CHARGE_COUT2
# chargement du 1er ou du 2è coût avec le ficher ITC OU MFC (qui est positionné par défaut)
Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With sum([F]MATLEVCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With sum([F]MACLEVCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With sum([F]LABLEVCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With [F]SCOLEVCST
Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With [F]OVELEVCST
Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With [F]VLTTOT
Assign "[M:ICM1]COST"+ NO_COUT +"(6)" With [F]CLCQTY
Assign "[M:ICM1]COST"+ NO_COUT +"(7)" With [F]VLTTOT

Assign "[M:ICM1]CSTTOT"+ NO_COUT With [F]CSTTOT


# chargement des autres onglets ...
For I = 0 To GACTMAT-1
  Assign "[M:ICM2]MATCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MATLEVCST(I)
Next
Assign "[M:ICM2]MATCST"+ NO_COUT+"(GACTMAT)" With sum([F]MATLEVCST(0..GACTMAT-1))
Assign "[M:ICM2]SCOTOT"+ NO_COUT With [F]SCOLEVCST

For I = 0 To GACTMAC-1
  Assign "[M:ICM3]MACCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MACLEVCST(I)
Next
Assign "[M:ICM3]MACCST"+ NO_COUT+"(GACTMAC)" With sum([F]MACLEVCST(0..GACTMAC-1))

For I = 0 To GACTLAB-1
  Assign "[M:ICM3]LABCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]LABLEVCST(I)
Next
Assign "[M:ICM3]LABCST"+ NO_COUT+"(GACTLAB)" With sum([F]LABLEVCST(0..GACTLAB-1))

Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With [F]OVEMATLEV
Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With [F]OVEMACLEV
Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With [F]OVELABLEV
Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With [F]OVESCOLEV
Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With [F]OVELEVCST

# Affichage des totaux au lieu des coûts unitaires de la table
If [M:ICM0]UNTFLG = 1
  Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With evalue("[M:ICM1]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With evalue("[M:ICM1]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With evalue("[M:ICM1]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With evalue("[M:ICM1]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With evalue("[M:ICM1]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With evalue("[M:ICM1]COST"+ NO_COUT +"(5)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  Assign "[M:ICM1]INVDTA"+ NO_COUT With evalue("[M:ICM1]invdta"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]CSTTOT"+ NO_COUT With evalue("[M:ICM1]CSTTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")


# chargement des autres onglets ...
  For I = 0 To GACTMAT-1
      Assign "[M:ICM2]MATCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM2]MATCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM2]MATCST"+ NO_COUT With evalue("[M:ICM2]MATCST"+NO_COUT+"(GACTMAT)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM2]SCOTOT"+ NO_COUT With evalue("[M:ICM2]SCOTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTMAC-1
      Assign "[M:ICM3]MACCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]MACCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]MACCST"+ NO_COUT With evalue("[M:ICM3]MACCST"+NO_COUT+"(GACTMAC)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTLAB-1
      Assign "[M:ICM3]LABCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]LABCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]LABCST"+ NO_COUT With evalue("[M:ICM3]LABCST"+NO_COUT+"(GACTLAB)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With evalue("[M:ICM4]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With evalue("[M:ICM4]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With evalue("[M:ICM4]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With evalue("[M:ICM4]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With evalue("[M:ICM4]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

Endif
Return

##################################################################
# CHARGE_COUT3 : Charge le prix previ ou PRF en multi-niveau
##################################################################
$CHARGE_COUT3
# chargement du 1er ou du 2è coût avec le ficher ITC OU MFC (qui est positionné par défaut)
Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With                  sum([F]MATCPNCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With sum([F]MACCST) + sum([F]MACCPNCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With sum([F]LABCST) + sum([F]LABCPNCST)
Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With     [F]SCOCST  +     [F]SCOCPNCST
Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With     [F]OVETOT  +     [F]OVECPNCST
Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With [F]CSTTOT + [F]OVETOT

Assign "[M:ICM1]INVDTA"+ NO_COUT With     [F]INVDTACST +   [F]INVDTACPN
Assign "[M:ICM1]CSTTOT"+ NO_COUT With [F]CSTTOT


# La zone écran CLCQTYx reprend la qté calculée des couts std ou la qté prévue/réal des PRF
Assign "[M:ICM1]COST"+ NO_COUT +"(6)" With [F]QTYSTU
Assign "[M:ICM1]COST"+ NO_COUT +"(7)" With [F]CSTTOT + [F]OVETOT

# chargement des autres onglets ...
For I = 0 To GACTMAT-1
  Assign "[M:ICM2]MATCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MATCPNCST(I)
Next
Assign "[M:ICM2]MATCST"+ NO_COUT+"(GACTMAT)" With sum([F]MATCPNCST)
Assign "[M:ICM2]SCOTOT"+ NO_COUT With [F]SCOTOT + [F]SCOCPNCST

For I = 0 To GACTMAC-1
  Assign "[M:ICM3]MACCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]MACCST(I)+[F]MACCPNCST(I)
Next
Assign "[M:ICM3]MACCST"+ NO_COUT+"(GACTMAC)" With [F]MACTOT+sum([F]MACCPNCST)

For I = 0 To GACTLAB-1
  Assign "[M:ICM3]LABCST"+ NO_COUT+ "(" +num$(I)+ ")" With [F]LABCST(I)+[F]LABCPNCST(I)
Next
Assign "[M:ICM3]LABCST"+ NO_COUT+"(GACTLAB)" With [F]LABTOT+sum([F]LABCPNCST)

Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With [F]OVEMATCST + [F]OVEMATCPN
Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With [F]OVEMACCST + [F]OVEMACCPN
Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With [F]OVELABCST + [F]OVELABCPN
Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With [F]OVESCOCST + [F]OVESCOCPN
Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With [F]OVETOT + [F]OVECPNCST

# Affichage des totaux au lieu des coûts unitaires de la table
If [M:ICM0]UNTFLG = 1
  Assign "[M:ICM1]COST"+ NO_COUT +"(0)" With evalue("[M:ICM1]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(1)" With evalue("[M:ICM1]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(2)" With evalue("[M:ICM1]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(3)" With evalue("[M:ICM1]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(4)" With evalue("[M:ICM1]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]COST"+ NO_COUT +"(5)" With evalue("[M:ICM1]COST"+ NO_COUT +"(5)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  Assign "[M:ICM1]INVDTA"+ NO_COUT With evalue("[M:ICM1]invdta"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM1]CSTTOT"+ NO_COUT With evalue("[M:ICM1]CSTTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")

# chargement des autres onglets ...
  For I = 0 To GACTMAT-1
    Assign "[M:ICM2]MATCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM2]MATCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM2]MATCST"+ NO_COUT+"(GACTMAT)" With evalue("[M:ICM2]MATCST"+NO_COUT+"(GACTMAT)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM2]SCOTOT"+ NO_COUT With evalue("[M:ICM2]SCOTOT"+NO_COUT +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTMAC-1
    Assign "[M:ICM3]MACCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]MACCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]MACCST"+ NO_COUT+"(GACTMAC)" With evalue("[M:ICM3]MACCST"+NO_COUT+"(GACTMAC)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  For I = 0 To GACTLAB-1
    Assign "[M:ICM3]LABCST"+ NO_COUT+ "("+num$(I)+")" With evalue("[M:ICM3]LABCST"+ NO_COUT+ "(I)*[M:ICM1]COST"+ NO_COUT +"(6)")
  Next
  Assign "[M:ICM3]LABCST"+ NO_COUT+"(GACTLAB)" With evalue("[M:ICM3]LABCST"+NO_COUT+"(GACTLAB)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

  Assign "[M:ICM4]COST"+ NO_COUT +"(0)" With evalue("[M:ICM4]COST"+ NO_COUT +"(0)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(1)" With evalue("[M:ICM4]COST"+ NO_COUT +"(1)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(2)" With evalue("[M:ICM4]COST"+ NO_COUT +"(2)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(3)" With evalue("[M:ICM4]COST"+ NO_COUT +"(3)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")
  Assign "[M:ICM4]COST"+ NO_COUT +"(4)" With evalue("[M:ICM4]COST"+ NO_COUT +"(4)" +"*[M:ICM1]COST"+ NO_COUT +"(6)")

Endif
Return

$CAL_ECA
# calcul et réaffichage de l'écart (selon le type)

If [M:ICM0]DEVTYP = 1
# ... [M:ICM1]VARCST(7) = 100 * ([M:ICM1]CPLQTY2 - [M:ICM1]CPLQTY1) / [M:ICM1]CPLQTY1
# ou Solution avec sous-prog :
   Call POURCENT([M:ICM1]VARCST(0), [M:ICM1]COST1(0), [M:ICM1]COST2(0))
   Call POURCENT([M:ICM1]VARCST(1), [M:ICM1]COST1(1), [M:ICM1]COST2(1))
   Call POURCENT([M:ICM1]VARCST(2), [M:ICM1]COST1(2), [M:ICM1]COST2(2))
   Call POURCENT([M:ICM1]VARCST(3), [M:ICM1]COST1(3), [M:ICM1]COST2(3))
   Call POURCENT([M:ICM1]VARCST(4), [M:ICM1]INVDTA1, [M:ICM1]INVDTA2)
   Call POURCENT([M:ICM1]VARCST(4), [M:ICM1]COST1(4), [M:ICM1]COST2(4))
   Call POURCENT([M:ICM1]VARCST(5), [M:ICM1]COST1(5), [M:ICM1]COST2(5))
   Call POURCENT([M:ICM1]VARCST(6), [M:ICM1]COST1(6), [M:ICM1]COST2(6))
   Call POURCENT([M:ICM1]VARCST(7), [M:ICM1]COST1(7), [M:ICM1]COST2(7))

# calcul de l'écart dans les écrans détails
   For I = 0 To GACTMAT    # ...avec le total
     Call POURCENT([M:ICM2]DEVMAT(I), [M:ICM2]MATCST1(I), [M:ICM2]MATCST2(I))
   Next
   Call POURCENT([M:ICM2]DEVSCO, [M:ICM2]SCOTOT1, [M:ICM2]SCOTOT2)
   For I = 0 To GACTMAC    # ...avec le total
     Call POURCENT([M:ICM3]DEVMAC(I), [M:ICM3]MACCST1(I), [M:ICM3]MACCST2(I))
   Next
   For I = 0 To GACTLAB    # ...avec le total
     Call POURCENT([M:ICM3]DEVLAB(I), [M:ICM3]LABCST1(I), [M:ICM3]LABCST2(I))
   Next

   Call POURCENT([M:ICM4]VARCST(0), [M:ICM4]COST1(0), [M:ICM4]COST2(0))
   Call POURCENT([M:ICM4]VARCST(1), [M:ICM4]COST1(1), [M:ICM4]COST2(1))
   Call POURCENT([M:ICM4]VARCST(2), [M:ICM4]COST1(2), [M:ICM4]COST2(2))
   Call POURCENT([M:ICM4]VARCST(3), [M:ICM4]COST1(3), [M:ICM4]COST2(3))
   Call POURCENT([M:ICM4]VARCST(4), [M:ICM4]COST1(4), [M:ICM4]COST2(4))

Else
   [M:ICM1]VARCST(0) = [M:ICM1]COST2(0) - [M:ICM1]COST1(0)
   [M:ICM1]VARCST(1) = [M:ICM1]COST2(1) - [M:ICM1]COST1(1)
   [M:ICM1]VARCST(2) = [M:ICM1]COST2(2) - [M:ICM1]COST1(2)
   [M:ICM1]VARCST(3) = [M:ICM1]COST2(3) - [M:ICM1]COST1(3)
   [M:ICM1]VARCST(4) = [M:ICM1]INVDTA2  - [M:ICM1]INVDTA1
   [M:ICM1]VARCST(4) = [M:ICM1]COST2(4) - [M:ICM1]COST1(4)
   [M:ICM1]VARCST(5) = [M:ICM1]COST2(5) - [M:ICM1]COST1(5)
   [M:ICM1]VARCST(6) = [M:ICM1]COST2(6) - [M:ICM1]COST1(6)
   [M:ICM1]VARCST(7) = [M:ICM1]COST2(7) - [M:ICM1]COST1(7)

   For I = 0 To GACTMAT
     [M:ICM2]DEVMAT(I) = [M:ICM2]MATCST2(I) - [M:ICM2]MATCST1(I)
   Next
   [M:ICM2]DEVSCO = [M:ICM2]SCOTOT2 - [M:ICM2]SCOTOT1
   For I = 0 To GACTMAC
     [M:ICM3]DEVMAC(I) = [M:ICM3]MACCST2(I) - [M:ICM3]MACCST1(I)
   Next
   For I = 0 To GACTLAB
     [M:ICM3]DEVLAB(I) = [M:ICM3]LABCST2(I) - [M:ICM3]LABCST1(I)
   Next

   [M:ICM4]VARCST(0) = [M:ICM4]COST2(0) - [M:ICM4]COST1(0)
   [M:ICM4]VARCST(1) = [M:ICM4]COST2(1) - [M:ICM4]COST1(1)
   [M:ICM4]VARCST(2) = [M:ICM4]COST2(2) - [M:ICM4]COST1(2)
   [M:ICM4]VARCST(3) = [M:ICM4]COST2(3) - [M:ICM4]COST1(3)
   [M:ICM4]VARCST(4) = [M:ICM4]COST2(4) - [M:ICM4]COST1(4)
Endif

Return

Subprog POURCENT(RESULT,MNT1,MNT2)
Variable Decimal RESULT
Value Decimal MNT1
Value Decimal MNT2
# calcul de l'écart en pourcentage arrondi à 2 décimales
If MNT1 <> 0
  RESULT = ar2(100 * (MNT2 - MNT1) / MNT1)
Else
  RESULT = 0
Endif
End

##############################
# Sous-pro d'actions sur zones
##############################

##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char     VALEUR
If !clalev([ITF]) : Local File ITMFACILIT [ITF] : Endif
If [M:ICM0]STOFCY1=""
    Look [ITF]ITF0=VALEUR;GFCYDEF(0)
Endif
If [M:ICM0]STOFCY1="" & !fstat
    [M:ICM0]STOFCY1 = GFCYDEF(0)
Else
    If [M:ICM0]STOFCY1<>""
        Look [ITF]ITF0=VALEUR;[M:ICM0]STOFCY1
    Endif
    If fstat
        Filter [ITF] Where ITMREF=VALEUR
        Read [ITF]First
        [M:ICM0]STOFCY1 = [F:ITF]STOFCY
        Affzo [M:ICM0]STOFCY1
    Endif
Endif

[M:ICM1]STU1 = [F:ITM]STU
Affzo [M:ICM1]STU1

End

##########################################################################
Subprog C_STOFCY1(VALEUR)
Variable Char    VALEUR()

If !clalev([ITF]) : Local File ITMFACILIT [ITF] : Endif
Read [ITF]ITF0 = [M:ICM0]ITMREF;VALEUR
If fstat
    GMESSAGE=[M:ICM0]ITMREF-VALEUR-":"-mess(139,197,1)
    mkstat=2
    End
Endif

Call GETDEV(VALEUR) From DEVSUB
[M:ICM0]CUR = GLOCALDEV : Affzo [M:ICM0]CUR

End

##########################################################################
Subprog AS_CSTTYP1(VALEUR)
Variable Integer VALEUR
# si le module Production n'est pas installé : pas de PRF
If GMODU(8) <> 2
  GMENLOC(5) = 1
  GMENLOC(6) = 1
  GMENLOC(7) = 1
  GMENLOC(8) = 1
Endif
End

##########################################################################
Subprog AM_CSTTYP1(VALEUR)
Variable Integer VALEUR
If VALEUR<5
    Effzo [M:ICM0]VCRTYP1
    Grizo [M:ICM0]VCRTYP1
    Grizo [M:ICM0]VCRNUM1
Else
    Actzo [M:ICM0]VCRTYP1
    Actzo [M:ICM0]VCRNUM1
Endif
If GMODU(8) = 2              # rajouté le 26/06/01
    If [M:ICM0]VCRNUM1 <> "" & VALEUR < 5
        Effzo [M:ICM0]VCRNUM1
    Elsif [M:ICM0]VCRNUM2<>""
        Read [MFC]MFC0=[M:ICM0]STOFCY1;[M:ICM0]ITMREF;[M:ICM0]VCRTYP1;[M:ICM0]VCRNUM1;[M:ICM0]VCRLIN1;VALEUR-4;0
        If fstat
            Effzo [M:ICM0]VCRNUM1
            Effzo [M:ICM0]VCRLIN1
        Endif
    Endif
Endif
End

##########################################################################
Subprog D_ITCDAT1(VALEUR)
Variable Date    VALEUR
VALEUR = date$
End

##########################################################################
Subprog AS_ITCDAT1(VALEUR)
Variable Date     VALEUR
Raz [M:ICM0]ITCSEQ1        # 21/05/02   (14126)
End

##########################################################################
Subprog C_ITCDAT1(VALEUR)
Variable Date     VALEUR

If VALEUR=[0/0/0] & [M:ICM0]CSTTYP1<5
    GMESSAGE = mess(10,123,1)    # Zone obligatoire
    mkstat=2
    End
Endif

# Correction bug 14126 ; détecter qu'on a fait une sélection (actual. ou simul.)
If [M:ICM0]ITCSEQ1 > 0
    Gosub LIRE1
    Affzo [M:ICM0]10
    End
Endif                      # 21/05/02   (14126)
      ## filtrer pour les types de coûts (bug 6069)
If [M]CSTTYP1 <5
    Filter [ITC] Where STOFCY=[M]STOFCY1 & ITMREF=[M]ITMREF & CSTTYP=[M]CSTTYP1 & ITCDAT>=VALEUR
&           Order By Key DAT1=ITCDAT;ITCSEQ Desc
    Read [ITC]DAT1 First
    If fstat
       Call MESSAGE(mess(23,100,1)) From GESECRAN
       mkstat = 2
    Else
      [M:ICM0]ITCSEQ1    = [F:ITC]ITCSEQ
      VALEUR             = [F:ITC]ITCDAT : # plus convivial ! (17/01/00)
      [M:ICM0]ITCSTRDAT1 = [F:ITC]ITCSTRDAT
      [M:ICM0]ITCENDDAT1 = [F:ITC]ITCENDDAT
    Endif
    Filter [ITC]
Else
    Effzo [M:ICM0]ITCSEQ1
Endif
End

##########################################################################
Subprog AS_VCRNUM1(VALEUR)
Variable Char     VALEUR
If [M]CSTTYP1 < 5 : mkstat = 2 : Endif
End

##########################################################################
Subprog C_VCRNUM1(VALEUR)
Variable Char VALEUR
# si année chargée par la sélection, l'afficher à ce moment   # si on l'a saisi, lire pour récupérer la date !
# faire un filter pour pouvoir saisir directement un n°d'OF (l'année n'est pas forcément renseignée ni fiable)
#Look [MFC]MFC0(4)=[M]STOFCY1;[M]ITMREF;[M]YEA1;VALEUR
Filter [MFC] Where STOFCY=[M]STOFCY1 & ITMREF=[M]ITMREF & VCRTYP=[M]VCRTYP1 & VCRNUM=VALEUR & MFCTYP=[M]CSTTYP1-4
Read [MFC] First
If fstat
   Call MESSAGE(mess(23,100,1)) From GESECRAN
   mkstat = 2
Else
  [M]ITCDAT1 = [F:MFC]MFCDAT
  [M]VCRLIN1 = [F:MFC]VCRLIN
  Affzo ITCDAT1,VCRLIN1
Endif
Filter [MFC]
End

##########################################################################
Subprog C_STOFCY2(VALEUR)
Variable Char     VALEUR
Local Char SAV_DEV(GLONCUR)

If !clalev([ITF]) : Local File ITMFACILIT [ITF] : Endif
Read [ITF]ITF0 = [M:ICM0]ITMREF;VALEUR
If fstat
    GMESSAGE=[M:ICM0]ITMREF-VALEUR-":"-mess(139,197,1)
    mkstat=2
    End
Endif

# Controler que le site a la même devise que le site 1
# Attention ce sous-pro change temporairement GLOCALDEV
SAV_DEV = GLOCALDEV
Call GETDEV(VALEUR) From DEVSUB
If GLOCALDEV <> SAV_DEV
  mkstat = 2 : GMESSAGE = mess(208,199,1)
Endif
GLOCALDEV = SAV_DEV  :# (19/01/00) au cas où l'on revienne en arrière !
End

##########################################################################
Subprog AS_CSTTYP2(VALEUR)
Variable Integer VALEUR
If GMODU(8) <> 2
  GMENLOC(5) = 1
  GMENLOC(6) = 1
  GMENLOC(7) = 1
  GMENLOC(8) = 1
Endif
End

##########################################################################
Subprog AM_CSTTYP2(VALEUR)
Variable Integer VALEUR
If GMODU(8) = 2              # rajouté le 26/06/01
    If VALEUR<5
        Effzo [M:ICM0]VCRTYP2
        Grizo [M:ICM0]VCRTYP2
        Grizo [M:ICM0]VCRNUM2
    Else
        Actzo [M:ICM0]VCRTYP2
        Actzo [M:ICM0]VCRNUM2
    Endif

    If [M:ICM0]VCRNUM2 <> "" & VALEUR < 5
        Effzo [M:ICM0]VCRNUM2
    Elsif [M:ICM0]VCRNUM2<>""
        Read [MFC]MFC0=[M:ICM0]STOFCY2;[M:ICM0]ITMREF;[M:ICM0]VCRTYP2;[M:ICM0]VCRNUM2;[M:ICM0]VCRLIN2;VALEUR-4;0
        If fstat
            Effzo [M:ICM0]VCRNUM2
            Effzo [M:ICM0]VCRLIN2
        Endif
    Endif
    If VALEUR<8 & ([M:ICM0]CSTTYP1<8 | [M:ICM0]CSTTYP1=8) | VALEUR=8
        Actzo [M:ICM0]NIV
    Else
        [M:ICM0]NIV = 1
        Diszo [M:ICM0]NIV
        Affzo [M:ICM0]NIV
    Endif
Endif
End

##########################################################################
Subprog D_ITCDAT2(VALEUR)
Variable Date    VALEUR
VALEUR = date$
End

##########################################################################
Subprog AS_ITCDAT2(VALEUR)
Variable Date    VALEUR
Raz [M:ICM0]ITCSEQ2        # 21/05/02   (14126)
End

##########################################################################
Subprog C_ITCDAT2(VALEUR)
Variable Date     VALEUR
Local Integer I

If VALEUR=[0/0/0] & [M:ICM0]CSTTYP1<5
    GMESSAGE = mess(10,123,1)    # Zone obligatoire
    mkstat=2
    End
Endif

# pour correction du 14126 ; détecter qu'on a fait une sélection (pour actual. ou simul.)
If [M:ICM0]ITCSEQ2 > 0
    Gosub LIRE2
    Affzo [M:ICM0]15
   End
Endif                      # 21/05/02   (14126)
If [M]CSTTYP2 < 5
    Filter [ITC] Where STOFCY=[M]STOFCY2 & ITMREF=[M]ITMREF & CSTTYP=[M]CSTTYP2 & ITCDAT>=VALEUR
&           Order By Key DAT1=ITCDAT;ITCSEQ Desc
    Read [ITC]DAT1 First
    If fstat
       Call MESSAGE(mess(23,100,1)) From GESECRAN
       mkstat = 2
    Else
      [M:ICM0]ITCSEQ2 = [F:ITC]ITCSEQ
      VALEUR          = [F:ITC]ITCDAT : # plus convivial ! (17/01/00)
      [M:ICM0]ITCSTRDAT2 = [F:ITC]ITCSTRDAT
      [M:ICM0]ITCENDDAT2 = [F:ITC]ITCENDDAT
    Endif
    Filter [ITC]
Else
    Effzo [M:ICM0]ITCSEQ2
Endif
End


##########################################################################
Subprog AS_VCRNUM2(VALEUR)
Variable Char     VALEUR
If [M]CSTTYP2 < 5 : mkstat = 2 : Endif
End

##########################################################################
Subprog C_VCRNUM2(VALEUR)
Variable Char VALEUR
Filter [MFC] Where STOFCY=[M]STOFCY2 & ITMREF=[M]ITMREF & VCRTYP=[M]VCRTYP2 & VCRNUM=VALEUR & MFCTYP=[M]CSTTYP2-4
Read [MFC] First
If fstat
   Call MESSAGE(mess(23,100,1)) From GESECRAN
   mkstat = 2
Else
  [M]ITCDAT2 = [F:MFC]MFCDAT
  [M]VCRLIN2 = [F:MFC]VCRLIN
  Affzo ITCDAT2,VCRLIN2
Endif
Filter [MFC]
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITCMATCH0) 07/11/2006 16:32:14 (CCC)
######################################################################################
Subprog AS_VCRTYP1(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    Case I
        When 10 :
            If GMODU(8)<>2
                GMENLOC(I)=1
            Endif
        When 36 :
            If GMODU(6)<>2
                GMENLOC(I)=1
            Endif
        When Default :
            GMENLOC(I)=1
    Endcase
Next
End

Subprog AS_VCRTYP2(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    Case I
        When 10 :
            If GMODU(8)<>2
                GMENLOC(I)=1
            Endif
        When 36 :
            If GMODU(6)<>2
                GMENLOC(I)=1
            Endif
        When Default :
            GMENLOC(I)=1
    Endcase
Next
End


######################################################################################

Subprog INITMSK
Local Integer I

#Call TEXTE(30428,[M:ICM2]INTSCO1) From OBJDIV    # Coût 2
#Call TEXTE(30429,[M:ICM2]INTSCO2) From OBJDIV    # Coût 1
#Call TEXTE(4308,[M:ICM2]INTDEV) From OBJDIV      # Ecart

For I=0 To GACTMAT-1
    [M:ICM2]FAMMAT(I) = mess(I+1,325,1)
Next
[M:ICM2]FAMMAT(I) = mess(1,379,1)
[M:ICM2]NBMAT = GACTMAT+1

For I=0 To GACTMAC-1
    [M:ICM3]FAMMAC(I) = mess(I+1,316,1)
Next
[M:ICM3]FAMMAC(I) = mess(3,379,1)
[M:ICM3]NBMAC = GACTMAC+1

For I=0 To GACTLAB-1
    [M:ICM3]FAMLAB(I) = mess(I+1,316,1)
Next
[M:ICM3]FAMLAB(I) = mess(5,379,1)
[M:ICM3]NBLAB = GACTLAB+1

End

################################################################
# AFFZOICM : Affiche les zones indiquées par le paramètre
################################################################
# Paramètre E : PTYP += "1": Coût n°1
#                       "2": Coût n°2
#                       "E": Ecarts
################################################################
Subprog AFFZOICM(PTYP)
Value Char PTYP
Local Integer I

#---- Cout 1 ----#
If instr(1,PTYP,"1")>0
    #---- ICM1 ----#
#    Affzo [M:ICM1]5
    Affzo [M:ICM1]COST1

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Affzo [M:ICM2]MATCST1(I)
    Next
    Affzo [M:ICM2]SCOTOT1

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Affzo [M:ICM3]MACCST1(I)
    Next
    For I=0 To GACTLAB
        Affzo [M:ICM3]LABCST1(I)
    Next

    #---- ICM4 ----#
#    Affzo [M:ICM4]5
    Affzo [M:ICM4]COST1
Endif

#---- Cout 2 ----#
If instr(1,PTYP,"2")>0
    #---- ICM1 ----#
#    Affzo [M:ICM1]10
    Affzo [M:ICM1]COST2

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Affzo [M:ICM2]MATCST2(I)
    Next
    Affzo [M:ICM2]SCOTOT2

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Affzo [M:ICM3]MACCST2(I)
    Next
    For I=0 To GACTLAB
        Affzo [M:ICM3]LABCST2(I)
    Next

    #---- ICM4 ----#
#    Affzo [M:ICM4]10
    Affzo [M:ICM4]COST2
Endif

#---- Ecarts ----#
If instr(1,PTYP,"E")>0
    #---- ICM1 ----#
#    Affzo [M:ICM1]15
    Affzo [M:ICM1]VARCST

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Affzo [M:ICM2]DEVMAT(I)
    Next
    Affzo [M:ICM2]DEVSCO

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Affzo [M:ICM3]DEVMAC(I)
    Next
    For I=0 To GACTLAB
        Affzo [M:ICM3]DEVLAB(I)
    Next

    #---- ICM4 ----#
#    Affzo [M:ICM4]15
    Affzo [M:ICM4]VARCST
Endif
End

################################################################
# EFFZOICM : Efface les zones indiquées par le paramètre
################################################################
# Paramètre E : PTYP += "1": Coût n°1
#                       "2": Coût n°2
#                       "E": Ecarts
################################################################
Subprog EFFZOICM(PTYP)
Value Char PTYP
Local Integer I
#---- Cout 1 ----#
If instr(1,PTYP,"1")>0
    #---- ICM1 ----#
    Effzo [M:ICM1]5

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Effzo [M:ICM2]MATCST1(I)
    Next
    Effzo [M:ICM2]SCOTOT1

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Effzo [M:ICM3]MACCST1(I)
    Next
    For I=0 To GACTLAB
        Effzo [M:ICM3]LABCST1(I)
    Next

    #---- ICM4 ----#
    Effzo [M:ICM4]5
Endif

#---- Cout 2 ----#
If instr(1,PTYP,"2")>0
    #---- ICM1 ----#
    Effzo [M:ICM1]10

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Effzo [M:ICM2]MATCST2(I)
    Next
    Effzo [M:ICM2]SCOTOT2

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Effzo [M:ICM3]MACCST2(I)
    Next
    For I=0 To GACTLAB
        Effzo [M:ICM3]LABCST2(I)
    Next

    #---- ICM4 ----#
    Effzo [M:ICM4]10
Endif

#---- Ecarts ----#
If instr(1,PTYP,"E")>0
    #---- ICM1 ----#
    Effzo [M:ICM1]15

    #---- ICM2 ----#
    For I=0 To GACTMAT
        Effzo [M:ICM2]DEVMAT(I)
    Next
    Effzo [M:ICM2]DEVSCO

    #---- ICM3 ----#
    For I=0 To GACTMAC
        Effzo [M:ICM3]DEVMAC(I)
    Next
    For I=0 To GACTLAB
        Effzo [M:ICM3]DEVLAB(I)
    Next

    #---- ICM4 ----#
    Effzo [M:ICM4]15
Endif
End

