######################################################################################
$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MKM","",0) From TRTX3CPT
Return


$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date d'imputation
Local Date WDATE : WDATE = [M:MBR]IPTDAT(nolign-1)
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHR) 13/10/2009 11:43:18 (CCC)
######################################################################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

######################################################################################
# Actzo ou Grizo des dépôts selon le site
######################################################################################
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]FCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES=2
  If GWRHOBY=2
    If [M:MBR]WRHE<>"" & [M:MBR]NBLIG<>0
      Diszo [MBR]WRHE
    Else
      Actzo [MBR]WRHE
    Endif
    Diszo [MBR]WRH
  Else
    Actzo [MBR]WRHE
    Actzo [MBR]WRH
  Endif
Else
  Grizo [MBR]WRHE
  Grizo [MBR]WRH
Endif
Return

########################################
# Dépôt à la ligne
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:MBR]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:MBR]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:MBR]WRH(nolign-1)<>""
   Raz [M:MBR]LOC(nolign-1)
Endif
End
######################################################################################
# Issue 107513/8 - 2015-07-13 by JUSYN : Versioning
$GREY_ECC
If dim([M:MBR]ECCVALMAJ(I)) < 0
    Return
Endif

# Reintegration - so no need to change versions at all versions have to be kept
Affzo [M:MBR]ECCVALMAJ(I)
Affzo [M:MBR]ECCVALMIN(I)
Grizo [M:MBR]ECCVALMAJ(I)
Grizo [M:MBR]ECCVALMIN(I)

Return

