#CHECK UNUSED_BEGIN
Subprog AS_MATTYP(VALEUR)
Variable Integer VALEUR
If [F:BTS]OFFLG = 1  : GMENLOC(3) = 1 : Endif
If [F:BTS]BOMFLG = 1 : GMENLOC(4) = 1 : Endif
If GMENLOC(3) = 1 : VALEUR = 4 : mkstat = 2 : End : Endif
If GMENLOC(4) = 1 : VALEUR = 3 : mkstat = 2 : End : Endif
GMENLOC(1)=  1
GMENLOC(2)=  1
End

##########################################################################
Subprog AM_MATTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
Raz [M:MBR]MFGNUM(NOL),[M:MBR]BOMNUM(NOL),[M:MBR]BOMALT(NOL),[M:MBR]ITMREF(NOL),[M:MBR]OPENUM(NOL),
&   [M:MBR]STU(NOL),[M:MBR]USEQTY(NOL),[M:MBR]REIQTY(NOL),[M:MBR]WINDIC(NOL),[M:MBR]CLEFLG(NOL),
&   [M:MBR]REIQTYPCU(NOL)
End
#CHECK UNUSED_END

##########################################################################
## Etiquette ajoutée par le superviseur 28/10/2003 09:49:37 (SR)
##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
If VALEUR = "" : End : Endif
Case [M:MBR]MATTYP(nolign-1)
    When 3 : Call STKCTRSER(VALEUR, [M:MBR]ITMREF(NOL), NOL, [M:MBR]NBLIG, [M:MBR]WSTOSEQ(NOL), 19, 12, "",
&            [M:MBR]WLINUM(NOL), 10, [M:MBR]MFGNUM(NOL), [M:MBR]MFGLIN(NOL),[M:MBR]BOMSEQ(NOL) , 0, "" ) From STKACT
    When 4 : Call STKCTRSER(VALEUR, [M:MBR]ITMREF(NOL),[M:MBR]REIQTY(NOL),[M:MBR]BOMNUM(NOL), [M:MBR]BOMALT(NOL),
&                         [M:MBR]WENDDATD, [M:MBR]WENDDATF, [M:MBR]FCY,NOL,[M:MBR]SERNUMF(NOL))
             If mkstat : End : Endif
             Affzo [MBR]SERNUMF(NOL)
Endcase
End


############################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
# Issue 73500 - 2015-01-21 by CCC : Import -> Control not needed here
If !GIMPORT
    Case [M:MBR]MATTYP(nolign-1)
        When 3 :Call STKCTRLOT(VALEUR, "MBR",NOL ,[M:MBR]ITMREF(NOL), "", 12, "", [M:MBR]WLINUM(NOL), [M:MBR]MFGNUM(NOL),
&               10, [M:MBR]MFGLIN(NOL), [M:MBR]BOMSEQ(NOL), [M:MBR]FCY, "LOCTYP", [M:MBR]GESLOT(NOL)) From STKACT
        When 4 :Call STKCTRLOT(VALEUR, [M:MBR]ITMREF(NOL),[M:MBR]BOMNUM(NOL), [M:MBR]BOMALT(NOL), [M:MBR]WENDDATD,
&               [M:MBR]WENDDATF, [M:MBR]FCY)
    Endcase
Endif
End

############################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

Local    Char    WBPSLOT

If VALEUR<>""
    Case [M:MBR]MATTYP(nolign-1)
        When 3 :
               Call STKCTRSLO(VALEUR, [M:MBR]NBSLO(nolign-1), [M:MBR]LOT(nolign-1),
&              [M:MBR]ITMREF(nolign-1), WBPSLOT, [M:MBR]GESLOT(nolign-1),[M:MBR]MFGNUM(nolign-1), 10, [M:MBR]MFGLIN(nolign-1),
&              [M:MBR]BOMSEQ(nolign-1),[M:MBR]FCY, [M:MBR]SLOF(nolign-1)) From STKACT
        When 4 :
               Call STKCTRSLO(VALEUR, [M:MBR]LOT(nolign-1),
&              [M:MBR]ITMREF(nolign-1),[MBR]BOMNUM(nolign-1), [M:MBR]BOMALT(nolign-1),
&              [M:MBR]WENDDATD,[M:MBR]WENDDATF,[M:MBR]FCY)
    Endcase
    If !mkstat
       Affzo [MBR]SLOF(nolign-1)
    Endif
Endif
End


########################################################################
Subprog STKCTRLOT(PLOT, PITM, PBOMNUM, PBOMALT ,PDATDEB, PDATFIN, PSTOFCY)
Value    Char    PLOT
Value    Char    PITM
Value    Char    PBOMNUM
Value    Integer PBOMALT
Value    Date    PDATDEB
Value    Date    PDATFIN
Value    Char    PSTOFCY

Local Integer LSTJOK

If !clalev([F:STL]) : Local File STOLOT    [STL] : Endif
If !clalev([F:MKM1]): Local File MFGMATTRK [MKM1] : Endif

If PDATFIN <> [0/0/0]
    Filter [F:STJ] Where STOFCY = PSTOFCY       & ITMREF = PITM
&                         & LOT = PLOT          & REGFLG<>2
&                         & IPTDAT >= PDATDEB   & IPTDAT <= PDATFIN
&                         & UPDCOD = 2
Else
    Filter [F:STJ] Where STOFCY = PSTOFCY       & ITMREF = PITM
&                         & LOT = PLOT          & REGFLG<>2
&                         & UPDCOD = 2
Endif

For  [STJ]STJ0
     Read [F:MKM1]MKM0 = [F:STJ]VCRNUM;[F:STJ]VCRLIN
     If [F:MKM1]BOMNUM = PBOMNUM & [F:MKM]BOMALT = PBOMALT
        LSTJOK = 1
        Break
     Endif
Next
If LSTJOK = 0
   mkstat = 2
   GMESSAGE = mess(360, 199, 1)    # Lot inexistant dans la ligne du document origine
Else
   # vérifier la quantité !!!
Endif
Filter [F:STJ]
End

########################################################################
Subprog STKCTRSLO(PSLO, PLOT, PITM, PBOMNUM, PBOMALT ,PDATDEB, PDATFIN, PSTOFCY)
Value    Char    PSLO
Value    Char    PLOT
Value    Char    PITM
Value    Char    PBOMNUM
Value    Integer PBOMALT
Value    Date    PDATDEB
Value    Date    PDATFIN
Value    Char    PSTOFCY

Local Integer LSTJOK

If !clalev([F:MKM1]) : Local File MFGMATTRK [MKM1] : Endif

If PDATFIN <> [0/0/0]
    Filter [F:STJ] Where STOFCY = PSTOFCY       & ITMREF = PITM
&                         & LOT = PLOT          & REGFLG<>2
&                         & IPTDAT >= PDATDEB   & IPTDAT <= PDATFIN
&                         & UPDCOD = 2          & SLO = PSLO
Else
    Filter [F:STJ] Where STOFCY = PSTOFCY       & ITMREF = PITM
&                         & LOT = PLOT          & REGFLG<>2
&                         & UPDCOD = 2          & SLO = PSLO
Endif

For  [STJ]STJ0
     Read [F:MKM1]MKM0 = [F:STJ]VCRNUM;[F:STJ]VCRLIN
     If [F:MKM1]BOMNUM = PBOMNUM & [F:MKM1]BOMALT = PBOMALT
        LSTJOK = 1
        Break
     Endif
Next
If LSTJOK = 0
   mkstat = 2
   GMESSAGE = mess(360, 199, 1)    # Lot inexistant dans la ligne du document origine
Endif
Filter [F:STJ]
End

########################################################################
Subprog STKCTRSER(PSER, PITM, PQTY,PBOMNUM, PBOMALT ,PDATDEB, PDATFIN, PSTOFCY,PLIG,PSERF)
Value    Char    PSER
Value    Char    PITM
Value    Decimal PQTY
Value    Char    PBOMNUM
Value    Integer PBOMALT
Value    Date    PDATDEB
Value    Date    PDATFIN
Value    Char    PSTOFCY
Value    Integer PLIG
Variable Char    PSERF

Local Integer  PRET    # -1=pas d'erreur
Local Integer  LSTSOK, LRET
Local Char     LSERD(GLONSER) : LSERD = PSER
Local Char     LSERF(GLONSER) : LSERF = PSER

PRET = -1
If !clalev([F:MKM1]) : Local File MFGMATTRK [MKM1] : Endif

Call LECSER (PITM,PSER,"",PRET) From STKLIB
If PRET = 1
    If PDATFIN = [0/0/0]  |  ([F:STS]ISSDAT >= PDATDEB & [F:STS]ISSDAT <= PDATFIN)
            Read [F:MKM1]MKM0 = [F:STS]SDHNUM;[F:STS]SDDLIN
            If !fstat
                If [F:MKM1]BOMNUM = PBOMNUM & [F:MKM1]BOMALT = PBOMALT & [F:MKM1]MATTYP = 2
                    LSTSOK = 1
                Endif
           Endif
    Endif
Endif
If LSTSOK = 0
   mkstat = 2
   GMESSAGE = mess(37,184,1)  # N° de série sorti par une autre pièce
   End
Endif
#si quantité réintégrée > 1 , calculer le numéro série de fin et contrôler tous les numéros entre les deux
# Recherche du numéro fin
If PQTY = 1
   PSERF = PSER
   End
Else
   I = PQTY
   While I > 0 & PRET=-1
      #lecture STOSER
       Raz LSTSOK
       Call LECSER (PITM,LSERF,"",PRET) From STKLIB
       If PRET = 1
          If PDATFIN = [0/0/0]  |  ([F:STS]ISSDAT >= PDATDEB & [F:STS]ISSDAT <= PDATFIN)
             Read [F:MKM1]MKM0 = [F:STS]SDHNUM;[F:STS]SDDLIN
             If !fstat
                If [F:MKM1]BOMNUM = PBOMNUM & [F:MKM1]BOMALT = PBOMALT
                    LSTSOK = 1
                Endif
             Endif
          Endif
          I -= 1
          If I>0 & LSTSOK = 1
                Call PLUS_UN(LSERD,LSERF,LRET) From STKLIB
                If LRET <> 0
                    PRET = 7
                Else
                    LSERD = LSERF
                Endif
          Endif
        Endif
    Wend
    If LSERF <> ""
        # If [M:ENT] is opened we have to use it
        If clalev([M:ENT])>0
            Call RECSER_M(PSER, [M:ENT]WSTOSEQ, [M:ENT]WSTOSEQ, [M:ENT]QTYSTU(PLIG), "QTYSTU",
&                         PITM, [M:ENT]NBLIG, LSERF) From STKACT
        Else
            Call RECSER_M(PSER, [M:MBR]WSTOSEQ(PLIG), [M:MBR]WSTOSEQ(PLIG), [M:MBR]REIQTY(PLIG), "REIQTY",
&                         PITM, [M:MBR]NBLIG, LSERF) From STKACT
        Endif
        If !mkstat
            PSERF  = LSERF
            [M]SERNUMF(PLIG) = LSERF

        Else
            PSERF  = ""
            [M]SERNUMF(PLIG) = LSERF
        Endif
        Affzo [M]SERNUMF(PLIG)
    Endif
Endif

End

##########################################################################
