#<AdxTL>@(#)12.0.0.0 $Revision$
###############################################################################
# Fonction Réintégration de stock    GPAO        v140                        #
#                                                                            #
# traitement FUNBENCHR                                                       #
#                                                                            #
# ACTION = SAIBENCHR                                                         #
##############################################################################

$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "BOUTON"        : Gosub BOUTON
    When "SETBOUT"       : Gosub SETBOUT
    When "ABA"           : Gosub ABA
    When "FIN"           : Gosub FIN
    When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG

    When "AB4_NBLIG"     : Gosub AB4_NBLIG
Endcase
Return


$AAPRES_NBLIG
#-------------------------------------------------#
# Appelé avant l'action SAISTOENT                 #
#-------------------------------------------------#
Local Shortint WRET
Local Integer  LRET
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1

If [M:MBR]REIQTYPCU(NOL) = 0 : Raz GOUVENT : Raz GOUVLOT : Return : Endif

If [F:ITM]ITMREF<>[M:MBR]ITMREF(NOL)
  Read [ITM]ITM0=[M:MBR]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If !find(status,65,68,83)
    Diszo [MBR]ITMREF(NOL)
Endif

# CCC (11/03/09) Bug 53214 : Chargement de ENTW à partir des mouvements afin que la sélection de ce qui est à réintégrer se fasse dans le détail stock
If ([M:MBR]WSTOSEQ(NOL)=0 | !find([M:MBR]WSTOSEQ(NOL),[M:ENTW]WSTOSEQ))
& & !GIMPORT    # Issue 73500 - 2015-01-21 by CCC
    Local Decimal LQTYSAV : LQTYSAV=[M:MBR]REIQTY(NOL)
    Local Decimal LQTYPCUSAV : LQTYPCUSAV=[M:MBR]REIQTYPCU(NOL)
    Local Integer LTYPORI
    # Issue 116259 - 2016-08-25 by YARAM : Used temp variable to restore lost changes to field LOC
    Local Char LLOC : LLOC = [M:MBR]LOC(NOL)
    [M:MBR]REIQTY(NOL) = [M:MBR]USEQTY(NOL)
    Call STJSTOENTW("MBR",19,12,[M:MBR]IPTDAT(NOL),NOL,[M:MBR]NBLIG,"BTS",3,LRET) From STKENT
    [M:MBR]REIQTY(NOL) = LQTYSAV
    [M:MBR]REIQTYPCU(NOL) = LQTYPCUSAV
    Affzo [MBR]REIQTYPCU(NOL), REIQTY(NOL)
    ## GH 03/12/2014 bug 102753
    If GMTK<>""
       LTYPORI = 12 # Suivi matière
    Elsif [M:MBR]MFGNUM(NOL) <> ""
       LTYPORI = 10 # Ordre de fabrication
    Endif
    Call LOAD_FROM_ENTW("MBR",NOL,[M:MBR]FCY,[M:MBR]WSTOSEQ(NOL),[M:MBR]ITMREF(NOL),LTYPORI)  From STKENT
    # Issue 116259 - 2016-08-25 by YARAM : Used temp variable to restore lost changes to field LOC
    [M]LOC(NOL) = LLOC
    Affzo [M]LOC(NOL)
    ##
Endif
Call OUVENT([M:MBR]FCY,"MBR",19,[M:MBR]TRSCODS,"",12,[M:MBR]IPTDAT(NOL),nolign-1,[M:MBR]NBLIG,"BTS","",WRET) From STKENT

Affzo [MBR]ITMREF(NOL)

Return

###########################################################################
$INIT
Local Char     LFCY(GLONFCY)    :    LFCY    = PARAM(1)
Local Char     LVCR(GLONVCR)    :    LVCR    = PARAM(2)
Global Char    GMTK(GLONVCR)    :    GMTK    = PARAM(3)
Local Char     LORI(10)         :    LORI    = PARAM(4)
Local Char     LUSR(GLONAUS)    :    LUSR    = PARAM(5)
Local Integer  LRETOK           :    LRETOK  = val(PARAM(6))
Global Char    GMRENUM(GLONTRS)

Raz GSTATUT
Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du pilotage, on vérifie si un code transaction est passé
If GFONCTION = "FUNBENPLT"
    If [M:MBP]MOLTRS <> ""
        Read [BTS]BTS0=63;[M:MBP]MRETRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
        GMRENUM = [F:BTS]BTSNUM
        OK = 0
        Return
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=63&ENAFLG=2"
# 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=63;GFLAG
    Filter [BTS]
    If !fstat
        If dim(GMRENUM)<=0
            Global Char    GMRENUM(GLONTRS)
        Endif
        GMRENUM= [F:BTS]BTSNUM
        OK=0
    Endif
Endif
If GMRENUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMRENUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=63;GMRENUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:BTS]WRHOBY
Else
  GWRHOBY = 1
Endif
Return

###########################################################################
$OUVRE
#01.10 mm 61503 - Si on vient par tunnel il faut sauvegarder les variables globales
Gosub SAUV_GLOB From TRTX3GLOB
#
Local Char     LFCY(GLONFCY)
Local Char     LVCR(GLONVCR)
Global Char    GMTK(GLONVCR) : Raz GMTK
Local Char     LORI(10)
Local Char     LUSR(GLONAUS)
Local Integer  VALOK
Local Integer  LRETOK
If !GIMPORT     # Issue 73500 - 2015-01-21 by CCC
    LFCY    = PARAM(1)
    LVCR    = PARAM(2)
    GMTK    = PARAM(3)
    LORI    = PARAM(4)
    LUSR    = PARAM(5)
    LRETOK  = val(PARAM(6))
Endif
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE11(50)
Local Char     CRITERE2(255)
Local Char     CRITEREA(255)
Local Char     CRITEREB(255)
Local Char     CUSFLT(255)
Local Char     FORMULE1(255)
Local Integer  WGG

Global Integer GMFMLIN  : GMFMLIN = 1
Global Integer GCONSLCT : GCONSLCT = GCONSULT
Global Char    GGFONC1  : GGFONC1 = GFONC1
# 81942
Global Integer  GMODMAT


GFONC1 = "FUNBENCHR"
Raz GCONSULT
Raz GSOC_ACTIVE
If LFCY <> ""
   GFCY = LFCY
Else
   Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Endif

Gosub OPEN_FILE
WGG=(clalev([F:WGG])<>0)

[M:ENTW]WZONPCU = "PCU"
[M:ENTW]WZONQUC = "REIQTYPCU"
[M:ENTW]WZONCCS = "PCUSTUCOE"
[M:ENTW]WZONSTU = "STU"
[M:ENTW]WZONQUS = "REIQTY"
[M:ENTW]WZONSTOUPD = ""
Raz [M:VALW]

Gosub STK_INILOC From STKLOC

Gosub CHARG_PARAM
Gosub LECTURE_BTS
#

Call DELSTOENTW(-1,-1,"MBR",1,1,"",0,"") From STKENT

# Issue 73500 - 2015-01-21 by CCC
If GIMPORT : Return : Endif

# substitution fenêtre
BOITE     = "WIMBR"+GMRENUM
WMASQUE   = "WT63"+GMRENUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY

Gosub CHANGE_AWI From BENCHLIB
GORITITCOL = 1

Return

########################################################################
$OPEN_FILE
If clalev([M:ORDK])=0  : Local Mask ORDK      [ORDK] : Endif       # pour générer encours
If clalev([M:MTMK])=0  : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev ([M:ENTW])=0 : Local Mask STOENTW   [ENTW] : Endif
If clalev ([M:STW])=0  : Local Mask STOWORK    [STW] : Endif
If clalev([M:MTB2])=0  : Local Mask MTKBCRIT2 [MTB2] : Endif       # 15806 MM 05.05 : gestion memo STD
If clalev([M:VALW])=0  : Local Mask STOVALW   [VALW] : Endif
If clalev([M:SVW])=0   : Local Mask STOVALWORK [SVW] : Endif

If clalev ([M:MKL])=0  : Local Mask MTKLOT     [MKL] : Endif
If clalev ([F:BTS])=0  : Local File BENCHTRS   [BTS] : Endif
If clalev ([F:MFG])=0  : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFM])=0  : Local File MFGMAT     [MFM] : Endif
If clalev ([F:MFO])=0  : Local File MFGOPE     [MFO] : Endif
If clalev ([F:MFI])=0  : Local File MFGITM     [MFI] : Endif
If clalev ([F:BOH])=0  : Local File BOM        [BOH] : Endif
If clalev ([F:BOD])=0  : Local File BOMD       [BOD] : Endif
If clalev ([F:TFO])=0  : Local File TABFOR     [TFO] : Endif
If clalev ([F:ITM])=0  : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF])=0  : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITG])=0  : Local File ITMCATEG   [ITG] : Endif
If clalev ([F:ITV])=0  : Local File ITMMVT     [ITV] : Endif
If clalev ([F:TLO])=0  : Local File TABLOCTYP  [TLO] : Endif
If clalev ([F:STC])=0  : Local File STOLOC     [STC] : Endif
If clalev ([F:STL])=0  : Local File STOLOT     [STL] : Endif
If clalev ([F:STS])=0  : Local File STOSER     [STS] : Endif
If clalev ([F:SRU])=0  : Local File TABSTORUL  [SRU] : Endif
If clalev ([F:MTK])=0  : Local File MFGHEADTRK [MTK] : Endif
If clalev ([F:MKM])=0  : Local File MFGMATTRK  [MKM] : Endif
If clalev ([F:STJ])=0  : Local File STOJOU     [STJ] : Endif
If clalev ([F:STO])=0  : Local File STOCK      [STO] : Endif
If clalev ([F:SRU])=0  : Local File TABSTORUL  [SRU] : Endif
If clalev ([F:TCA])=0  : Local File TABCOUAFF  [TCA] : Endif
If clalev ([F:ORD])=0  : Local File ORDERS     [ORD] : Endif
If clalev ([F:MWS])=0  : Local File WORKSTATIO [MWS] : Endif
If clalev([F:CAL])<=0  : Local File CPTANALIN  [CAL] : Endif
If clalev([F:DTR])<=0  : Local File DIETRS     [DTR] : Endif
If clalev([F:FCY])<=0  : Local File FACILITY   [FCY] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
If filinfo(filpath("FIL","WEIGHING","fde",0),0)>=0                      # 52340 mm 02.09
    If clalev([F:WGG])<=0  : Local File WEIGHING   [WGG] : Endif        # 50058 mm 01.09
Endif

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

########################################################################
$DEBUT

Raz [M:MBR]
[M:MBR]FCY = GFCY
Gosub WRH_ETAT
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

# CCC (2009-09-23) Bug 57792 : alimenter le code transaction systématiquement
Gosub LECTURE_BTS
[M:MBR]TRSCODS = [F:BTS]TRSCODS

[M:MBR]FILTMAT  = [F:BTS]FILTDEF
[M:MBR]LORI     = LORI
If LORI = "PILOT"
    Gosub CHARG_MASKB
Elsif LVCR <> ""  | GMTK <> ""
        [M:MBR]WMFGNUMD = LVCR
        [M:MBR]WMFGNUMF = LVCR
        Gosub CHARG_MASK
        Grizo [MBR]5,7,10
Endif

Case [F:BTS]CRIT1
     When 1 : [M:MBR]WSRT += 1
     When 2 : [M:MBR]WSRT += 2
     When 3 : [M:MBR]WSRT += 4
     When 5 : [M:MBR]WSRT += 8
Endcase
Case [F:BTS]CRIT2
     When 1 : [M:MBR]WSRT += 16
     When 2 : [M:MBR]WSRT += 32
     When 3 : [M:MBR]WSRT += 64
     When 5 : [M:MBR]WSRT += 128
Endcase

If [F:BTS]FILTFLG < 3 : [M:MBR]FILTMAT = [F:BTS]FILTDEF : Endif

# 15806 MM 05.05 : application memo STD
If LORI =""
    If filinfo(filpath("ETM",GUSER+"_"+GMRENUM+"_"+"STD","mbr",0),0)>=0
        Call LECMEMO("STD","[M:MTB2]",GMRENUM+"~mbr") From GMEMO
        [M:MBR] = [M:MTB2]
        Affzo [MBR]10
    Endif
Endif

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables ( sections analytiques)           #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD
  Local Char BASPAG(10)
  If (dim([M:MBR]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT63"+GMRENUM+"1"
      If [M:MBR]NBLIG = 0 : [M:MBR]NBLIG = 1 : Affzo [MBR]15 : Effzo [MBR]15 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return

########################################################################
$SETBOUT
# Pour interdire la navigation
GREP="M"

ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = 1                                     # validation

ETABOU(GABAN) = 1
If LORI = "PILOT"
    ETABOU(GSPE1) = 0                                     # recherche
    ETABOU(GSPE2) = 0                                     # critères
Endif

Return
########################################################################
$BOUTON

Case BOUT
    When "1"      : Gosub CHARG_MASK    # Recherche
    When "2"      : If [M:MBR]REACT = 2 : Gosub CHARG_MASK : [M:MBR]REACT = 1 : Endif    # Criteres
    When "3"      : Gosub VALIDATION
Endcase
Return

########################################################################
$CHARG_MASK
Local Integer WMAX, WRETOUR
Local Integer I,J
Local Char    WCCE(15)
Local Char    WGESLOT
Local Char    WWRH(GLONWRH)

WMAX = dim([M:MBR]IPTDAT)     # mémorisation nombre de ligne maxi
GMFMLIN = 1
Effzo [MBR]15
Effzo [MKL]1-99
[M:MKL]NBLIG = 0

Call STKCTRIPT(date$,[M:MBR]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

[M:MBR]TRSCODS = [F:BTS]TRSCODS

Call DELSTOENTW(-1,-1,"MBR",1,1,[M:MBR]FCY,1,"") From STKENT

# Issue 73500 - 2015-01-21 by CCC
If GIMPORT
    Raz I
    Raz CRITERE, CRITERE1, CRITERE11, CRITERE2, CUSFLT, FORMULE1
    CRITERE1 = "MFGTRKNUM=[F:MKMR]MFGTRKNUM & MATTRKLIN=[F:MKMR]MATTRKLIN"
    If [F:MKMR]ITMREF<>""
        Call ADDCRIT(CRITERE2,I,"","ITMREF=[F:MKMR]ITMREF","&") From GOBJSUB
    Endif
    If [F:MKMR]MFGFCY<>""
        Call ADDCRIT(CRITERE2,I,"","MFGFCY=[F:MKMR]MFGFCY","&") From GOBJSUB
    Endif
Else
    Gosub LOAD_FILTER
Endif

If CRITERE11= "" : CRITERE11= "1=1" : Endif
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT   = "" : CUSFLT   = "1=1" : Endif
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

nolign=1

#If CRITERE11 = "MFMTRKFLG <"+num$(5) & [F:BTS]OFFLG = 2  : Goto RESEARCH_MFM : Endif

If [M:MBR]WBOMNUMF <> "" : [M:MBR]WMATTYP = 4
Else                     : [M:MBR]WMATTYP = 3
Endif
# Premiere passe : recherche de suivis liés à des composants non prévus
# de même si réintégration sur nomenclature
# on passe ici aussi si on vient de l'annulation de pesée
If GMTK <> ""
    Filter [F:MKM] Where MFGTRKNUM = GMTK
Elsif ([F:BTS]BOMFLG = 2 & [F:BTS]OFFLG = 1)
    Filter [F:MKM] Where evalue (CRITERE1) & evalue(CRITERE2)&
&                    evalue(CUSFLT)   & evalue(FORMULE1) & [F:MKM]MFGNUM = ""
Elsif ([F:BTS]BOMFLG = 1 & [F:BTS]OFFLG = 2)
    Filter [F:MKM] Where evalue (CRITERE1) & evalue(CRITERE2)&
&                        evalue(CUSFLT)   & evalue(FORMULE1) & [F:MKM]MFMITMREF="" & [F:MKM]MFGNUM <> ""
Else
    Filter [F:MKM] Where evalue (CRITERE1) & evalue(CRITERE2)&
&                        evalue(CUSFLT)   & evalue(FORMULE1) & ([F:MKM]MFGNUM = "" | ([F:MKM]MFMITMREF="" & [F:MKM]MFGNUM <> ""))
Endif

For [F:MKM]
    If nolign = WMAX : Break : Endif

   # FQ 66499  GA 09/2010 pas de réintégration sur OF Clos
    If [F:MKM]MFGNUM<>"" & [F:MFG]MFGNUM <> [F:MKM]MFGNUM
        Read [F:MFG]MFG0 = [F:MKM]MFGNUM
        If fstat : Raz [F:MFG] : Endif
    Endif
    #L'OF doit être ferme
    If [F:MFG]MFGNUM<>"" & [F:MFG]MFGSTA <> 1   : Goto NEXTR : Endif

    # date
    If [M:MBR]WENDDATD <> [0/0/0] & GMTK = ""
        If [F:MKM]IPTDAT < [M:MBR]WENDDATD
            Goto NEXTR
        Endif
    Endif
    If [M:MBR]WENDDATF <> [0/0/0] & GMTK = ""
        If [F:MKM]IPTDAT>[M:MBR]WENDDATF
            Goto NEXTR
        Endif
    Endif

    If [F:ITM]ITMREF <> [F:MKM]ITMREF
        Read [F:ITM]ITM0 = [F:MKM]ITMREF
        If fstat : Goto NEXTR : Endif
    Endif

    If [F:ITF]ITMREF <> [F:MKM]ITMREF | [F:ITF]STOFCY <> [F:MKM]MFGFCY
           Read [F:ITF]ITF0 = [F:MKM]ITMREF;[F:MKM]MFGFCY
           If fstat : Raz [F:ITF] : Goto NEXTR : Endif
     Endif

    #On prend la ligne selon mode de destockage paramétré dans la transaction
    If ([F:BTS]STOCODDEF=3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)

        [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
        [M:MBR]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
        [M:MBR]LOTMGTCOD(nolign-1) = [F:ITM]LOTMGTCOD
        [M:MBR]QUAFLG(nolign-1)    = [F:ITF]QUAFLG    # 50060 mm 01.09

        [M:MBR]=[F:MKM]
 # hcb V6CQ
        Case [F:ITF]QUAFLG
             When 1       : [M:MBR]STA(nolign-1) = "A"
             When Default : [M:MBR]STA(nolign-1) = "Q"
        Endcase

        Raz [M:MBR]GESLOT(nolign-1)
        Gosub REAJUST_QTY_MKM
        [M:MBR]WIPTDAT(nolign-1)    = [F:MKM]IPTDAT

        If     [F:MKM]MATTYP = 1 : [M:MBR]MATTYP(nolign-1) = 3
        Elsif  [F:MKM]MATTYP = 2 : [M:MBR]MATTYP(nolign-1) = 4
               Read [F:BOD]BOD0 = [F:MKM]BOMNUM;[F:MKM]BOMALT;[F:MKM]BOMSEQ;[F:MKM]ITMREF;2
               If !fstat :[M:MBR]MKMTEX(nolign-1) = [F:BOD]BOMTEXNUM : Endif

        Endif

        If find([F:MKM]MATTYP,3,4)
            [M:MBR]USEQTY(nolign-1) *= -1
        Endif

        [M:MBR]BOMALT(nolign-1)  = [F:MKM]BOMALT

        Raz [M:MBR]MFMITMREF(nolign-1)
        If dim([M:MBR]TYPQTY(nolign-1)) > 0
           If [F:ITF]STOMGTCOD = 3  : [M:MBR]TYPQTY(nolign-1) = 1
           Else [M:MBR]TYPQTY(nolign-1) = 2
           Endif
        Endif

        [M:MBR]WLINUM(nolign-1)     = GMFMLIN
        [M:MBR]IPTDAT(nolign-1)     = date$
        If [M:MBR]BOMSEQ(nolign-1) <> 0
            [M:MBR]ITMTYP(nolign-1)     = 1
        Else
            [M:MBR]ITMTYP(nolign-1)     = 2
        Endif
        [M:MBR]CLEFLG(nolign-1)     = 2
        [M:MBR]STU(nolign-1)        = [F:ITM]STU
        [M:MBR]PCU(nolign-1)        = [M:MBR]STU(nolign-1)
        [M:MBR]PCUSTUCOE(nolign-1)  = 1

        #[M:MBR]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBR]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M:MBR]STOCODL(nolign-1)    = [F:ITF]STOCOD
        [M:MBR]WCLEFLG(nolign-1)    = [M:MBR]CLEFLG(nolign-1)
        [M:MBR]WINDIC(nolign-1)     = 1

        If GMTK <> ""
            [M:MBR]REIQTYPCU(nolign-1)  = [M:MBR]USEQTY(nolign-1)
            [M:MBR]REIQTY(nolign-1)     = [M:MBR]USEQTY(nolign-1)
            [M:MBR]PECFLG(nolign-1)     = 2
            [M:MBR]ITMTYP(nolign-1)     = 1
            Read [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]ITMREF
            If fstat : Raz [F:MFM] : Endif
            [M:MBR]MFMITMREF(nolign-1) = [F:MFM]ITMREF
            [M:MBR]CLEFLG(nolign-1)    = 1
            # CCC (26/09/08) Bug 48655 : Utilisation de la règle de gestion avant l'emplacement d'origine
            If dim([M:MBR]LOC) > 0 & [F:ITF]LOCMGTCOD=2
                If dim([M:MBR]WRH)>0
                  WWRH=[M:MBR]WRH(nolign-1)
                Else
                  WWRH=""
                Endif
                Call LECSRU([M:MBR]FCY,[F:ITM]TCLCOD,19,[F:BTS]TRSCOD,"",WRETOUR) From STKLIB
                Call STKWLOCSEQ("MBR", nolign-1, WRETOUR) From STKECR
                Call STKSUGEMP([M:MBR]WLOCSEQ(nolign-1),19,[F:BTS]TRSCOD,[M:MBR]FCY,[M:MBR]MFMITMREF(nolign-1),
&                              [M:MBR]PCU(nolign-1),[M:MBR]REIQTYPCU(nolign-1),[M:MBR]STA(nolign-1),
&                              [M:MBR]LOCTYP(nolign-1),[M:MBR]LOC(nolign-1),"","","",WWRH) From STKLOC
            Endif
            Filter [F:STJ] Where STOFCY = [M:MBR]FCY & VCRNUM = GMTK & VCRTYP = 12 & VCRLIN = [F:MKM]MATTRKLIN & ITMREF = [F:MKM]ITMREF
            Read [F:STJ]STJ1 First
            Filter [STJ]
            If !fstat
                If dim([M:MBR]LOT) > 0 : [M:MBR]LOT(nolign-1) = [F:STJ]LOT : Endif
                If dim([M:MBR]SLO) > 0 : [M:MBR]SLO(nolign-1) = [F:STJ]SLO : Endif
                If dim([M:MBR]LOC) > 0
                    If [M:MBR]LOC(nolign-1)=""
                        [M:MBR]LOC(nolign-1) = [F:STJ]LOC
                    Endif
                Endif
            Endif
        Endif
        #Chargement des section ana
        For J = 1 To GNBDIE
               Call INISEC(WCCE,"MKM", J) From TRTX3CPT
               Assign "[M:MBR]CCE"+num$(J)+"(nolign-1)" With WCCE
        Next
        nolign+=1
        GMFMLIN += 1
    Endif
$NEXTR
Next
Filter [F:MKM]

[M:MBR]NBLIG = nolign-1
#If [M:MBR]NBLIG = 0 : nolign = 1 : Goto RESEARCH_MFM : Endif

# 50060 mm 01.09
If [M:MBR]NBLIG = 0
    If GMTK<>"" : Return : Endif
    nolign = 1 : Goto RESEARCH_MFM
Endif

Gosub INCREMENT_QUANTITE

For I = [M:MBR]NBLIG - 1 To 0 Step -1
   If [M:MBR]USEQTY(I) <= 0
      Dela I,1 [M:MBR]NBLIG
      [M:MBR]NBLIG -=1
   Endif
Next I

For I = 0 To [M:MBR]NBLIG-1
#       Default Mask [MBR]
        If [M:MBR]LOTMGTCOD(I) > 1
                Gosub LOAD_MKL
        Endif
#        WGESLOT = [M:MBR]GESLOT(I)
#        Case [M:MBR]MATTYP(I)
#            When 3 :
#                Call INIZONENT([M:MBR]ITMREF(I),"MBR",[M:MBR]FCY,"",0,"",I,19,[M:MBR]TRSCODS,[M:MBR]MFGNUM(I),3,1) From STKECR
#            When 4 :
#                Call INIZONENT([M:MBR]ITMREF(I),"MBR",[M:MBR]FCY,"",0,"",I,19,[M:MBR]TRSCODS,"",3,1) From STKECR
#        Endcase

#        # car RAZ dans INIZONENT
#        [M:MBR]LOT(I)    = [M:MBR]XLOT(I)
#        [M:MBR]SLO(I)    = [M:MBR]XSLO(I)
#        [M:MBR]GESLOT(I) = WGESLOT


#        status=0

#        If [M:MBR]REIQTYPCU(I) <> 0
#           Call STJSTOENTW("MBR",19,12,[M:MBR]IPTDAT(I),I,NBLIG,"BTS",3,WRETOUR) From STKENT
#        Endif

Next

# si réintégration sur nomenclature  ou annulation de pesée on arrête là
If [F:BTS]OFFLG = 1 | [M:MBR]WBOMNUMF <> ""  | GMTK <> ""
    Affzo [MBR]5,7,10
    Gosub AFF_TABLEAU
    Return
Endif
# FQ 55323
#If [M:MBR]NBLIG > 0
    nolign=[M:MBR]NBLIG+1    # FQ 55323 avant [M:MBR]NBLIG
#Else
#   nolign = 1
#Endif


$RESEARCH_MFM
# Issue 73500 - 2015-01-21 by CCC
If GIMPORT
    CRITEREA = "MFGNUM=[F:MKMR]MFGNUM & MFGLIN=[F:MKMR]MFGLIN & BOMSEQ=[F:MKMR]BOMSEQ & ITMREF=[F:MKMR]ITMREF"
    CRITEREB = "[F:MFM]USEQTY > 0 & [F:MFM]CPNTYP <> 5"
Else
    Gosub LOAD_FILTERMFM
    If CRITEREB = "" : CRITEREB = "1=1" : Endif
Endif

# Seconde passe : recherche de suivis liés à des composants OF
Link [MFM] With [MFI]MFI0=[F:MFM]MFGNUM;[F:MFM]MFGLIN As [MFX]
&          Where evalue(CRITEREA) & evalue(CRITERE11) & evalue(CRITEREB)&
&                evalue(CUSFLT)   & evalue(FORMULE1)
 For [MFX]
    If nolign = WMAX : Break : Endif

   # FQ 66499  GA 09/2010 pas de réintégration sur OF Clos
    If [F:MFM]MFGNUM<>"" & [F:MFG]MFGNUM <> [F:MFM]MFGNUM
        Read [F:MFG]MFG0 = [F:MFM]MFGNUM
        If fstat : Raz [F:MFG] : Endif
    Endif
    #L'OF doit être ferme
    If [F:MFG]MFGNUM<>"" & [F:MFG]MFGSTA <> 1   : Goto NEXTS : Endif

    # date
    If [M:MBR]WENDDATD <> [0/0/0]
        If [F:MFM]TRKFIRST<[M:MBR]WENDDATD
            Goto NEXTS
        Endif
    Endif
    If [M:MBR]WENDDATF <> [0/0/0]
        If [F:MFM]TRKFIRST>[M:MBR]WENDDATF
            Goto NEXTS
        Endif
    Endif

    # On ne propose pas les matières si le prix de revient est calculé
    If [F:MFM]MFMTRKFLG = 6 : Goto NEXTS : Endif

     If [F:MFM]MFGLIN <> 0
          Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
          If fstat : Raz [F:MFI] : Endif
     Else
          Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
          Read [F:MFI]MFI0 First
          If fstat : Raz [F:MFI] : Endif
          Filter [F:MFI]
     Endif

      If [M:MBR]WITMRELF <> ""
         If [F:MFI]ITMREF < [M:MBR]WITMRELD | [F:MFI]ITMREF > [M:MBR]WITMRELF
            Goto NEXTS
         Endif
     Endif
     If [M:MBR]WCDEF <> ""
          If [F:MFI]VCRNUMORI < [M:MBR]WCDED | [F:MFI]VCRNUMORI > [M:MBR]WCDEF
             Goto NEXTS
          Endif
      Endif
      If [M:MBR]WPJTF <> ""
         If [F:MFI]PJT < [M:MBR]WPJTD | [F:MFI]PJT > [M:MBR]WPJTF
            Goto NEXTS
         Endif
      Endif
    If [F:ITM]ITMREF <> [F:MFM]ITMREF
        Read [F:ITM]ITM0 = [F:MFM]ITMREF
        If fstat : Goto NEXTS : Endif
    Endif

    If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
           Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
           If fstat : Raz [F:ITF] : Goto NEXTS : Endif
    Endif

    # If filinfo(filpath("FIL","WEIGHING","fde",0),0)>=0                      # 52340 mm 02.09
        # 50058 mm 01.09 - Interdiction de réintégrer une matière pesée depuis la fonction Plan de réintégration std
        If WGG & find("FUNBENCHR", GNAVIG(1..GPILNAV))
            Read [WGG]WGG0 = [F:MFM]MFGNUM;[F:MFM]BOMOPE;[F:MFM]ITMREF;[F:MFM]MFGLIN;[F:MFM]BOMSEQ
            If !fstat :  Goto NEXTS : Endif
        Endif
    # Endif

    #On prend la ligne selon mode de destockage paramétré dans la transaction
    If ([F:BTS]STOCODDEF=3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)
        [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
        If dim([M:MBR]TYPQTY(nolign-1)) > 0
           If [F:ITF]STOMGTCOD = 3  : [M:MBR]TYPQTY(nolign-1) = 1
           Else [M:MBR]TYPQTY(nolign-1) = 2
           Endif
        Endif

        [M:MBR]=[F:MFM]
        # 56958
        If dim([M:MBR]LOC) > 0
            [M:MBR]LOC(nolign-1) = ""     # 54136 mm 03.09
        Endif
        [M:MBR]MKMTEX(nolign-1)    = [F:MFM]MFMTEX

        Gosub REAJUST_QTY_MFM

        [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
        [M:MBR]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
        [M:MBR]LOTMGTCOD(nolign-1) = [F:ITM]LOTMGTCOD
        [M:MBR]QUAFLG(nolign-1)    = [F:ITF]QUAFLG    # 50060 mm 01.09

        [M:MBR]MFMITMREF(nolign-1) = [F:MFM]ITMREF
        If [M:MBR]USEQTY(nolign-1) <=0 : Raz [M:MBR]ITMREF(nolign-1) : Goto NEXTS : Endif

        [M:MBR]WLINUM(nolign-1)     = GMFMLIN
        [M:MBR]IPTDAT(nolign-1)     = date$
        [M:MBR]ITMTYP(nolign-1)     = 1
        [M:MBR]MATTYP(nolign-1)     = 3
        [M:MBR]WIPTDAT(nolign-1)    = [F:MFM]TRKFIRST
        [M:MBR]MFMEXTQTY(nolign-1)  = [F:MFM]RETQTY
        [M:MBR]MFMUSEQTY(nolign-1)  = [F:MFM]USEQTY
        [M:MBR]MFMALLQTY(nolign-1)  = [F:MFM]ALLQTY
        [M:MBR]MFMSHTQTY(nolign-1)  = [F:MFM]SHTQTY
        [M:MBR]MFMTRKFLG(nolign-1)  = [F:MFM]MFMTRKFLG

        [M:MBR]STU(nolign-1)            = [F:ITM]STU
        [M:MBR]PCU(nolign-1)            = [M:MBR]STU(nolign-1)
        [M:MBR]PCUSTUCOE(nolign-1)      = 1

        #[M:MBR]ITMDES1(nolign-1)        = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBR]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M:MBR]STOCODL(nolign-1)        = [F:ITF]STOCOD
        If [F:MFM]MFMTRKFLG < 5
             [M:MBR]CLEFLG(nolign-1)    = 1
        Else
             [M:MBR]CLEFLG(nolign-1)    = 2
        Endif
        [M:MBR]WCLEFLG(nolign-1)        = [M:MBR]CLEFLG(nolign-1)
        [M:MBR]WINDIC(nolign-1)         = 1


        If [F:ITM]LOTMGTCOD > 1
            I = nolign-1
            Gosub LOAD_MKL
        Endif

#        Default Mask [MBR]
#        Call INIZONENT([M:MBR]ITMREF(nolign-1),"MBR",[M:MBR]FCY,"",0,"",nolign-1,19,[M:MBR]TRSCODS,[M:MBR]MFGNUM(nolign-1),3,1) From STKECR

        # car RAZ dan INIZONENT
#        [M:MBR]LOT(nolign-1) = [M:MBR]XLOT(nolign-1)
#        [M:MBR]SLO(nolign-1) =  [M:MBR]XSLO(nolign-1)

#        status=0
#        If [M:MBR]REIQTYPCU(nolign-1) <> 0
#            Call STJSTOENTW("MBR",19,12,[M:MBR]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRETOUR) From STKENT
#        Endif

        #Chargement des section ana
         Call CHARG_ACCCCE(nolign-1 ,"","","[M:MBR]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
         For J = 1 To GNBDIE
            If evalue ("[M:MBR]CCE"+num$(J)+"(nolign-1)") =""
                Call INISEC(WCCE,"MKM", J) From TRTX3CPT
                Assign  "[M:MBR]CCE"+num$(J)+"(nolign-1)" With WCCE
            Endif
         Next
         nolign+=1
         GMFMLIN += 1
    Endif
$NEXTS
Next

[M:MBR]NBLIG = nolign-1

# 11.04 demande 26502 chargement spécifique du masque MBR
GPOINT = "LOAMSKMBR" : Gosub ENTREE From EXEFNC

Affzo [MBR]5,7,10
Gosub AFF_TABLEAU
Affzo [MBR]15
Return


########################################################################
$CHARG_MASKB
Local Integer WMAX, WRETOUR
Local Integer I,J, WI
Local Char    WCCE(15)
Local Char WGESLOT
Local Integer LIG  : LIG = nolign -1

WMAX = dim([M:MBR]IPTDAT)     # mémorisation nombre de ligne maxi
GMFMLIN = 1
Effzo [MBR]15
Effzo [MKL]1-99
[M:MKL]NBLIG = 0

Call STKCTRIPT(date$,[M:MBR]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

[M:MBR]TRSCODS = [F:BTS]TRSCODS
nolign = 0
For WI = 0 To [M:MTPK]NBLIG-1
   Read [F:MFG]MFG0 = [M:MTPK]MFGNUM(WI)
   # première passe sur les suivis des matières rajoutées au suivi
   For [F:MKM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MFMITMREF = ""
        If nolign = WMAX : BREAK2 : Endif
        If [F:ITM]ITMREF <> [F:MKM]ITMREF
            Read [F:ITM]ITM0 = [F:MKM]ITMREF
            If fstat : Goto NEXTR2 : Endif
        Endif

        If [F:ITF]ITMREF <> [F:MKM]ITMREF | [F:ITF]STOFCY <> [F:MKM]MFGFCY
               Read [F:ITF]ITF0 = [F:MKM]ITMREF;[F:MKM]MFGFCY
               If fstat : Raz [F:ITF] : Goto NEXTR2 : Endif
         Endif

        #On prend la ligne selon mode de destockage paramétré dans la transaction
        If ([F:BTS]STOCODDEF=3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)

            [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
            [M:MBR]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
            [M:MBR]LOTMGTCOD(nolign-1) = [F:ITM]LOTMGTCOD
            [M:MBR]=[F:MKM]
# hcb V6CQ
            Case [F:ITF]QUAFLG
                 When 1       : [M:MBR]STA(nolign-1) = "A"
                 When Default : [M:MBR]STA(nolign-1) = "Q"
            Endcase

            Raz [M:MBR]GESLOT(nolign-1)
            Gosub REAJUST_QTY_MKM
            [M:MBR]WIPTDAT(nolign-1)    = [F:MKM]IPTDAT
            If     [F:MKM]MATTYP = 1 : [M:MBR]MATTYP(nolign-1) = 3 : Endif
            If [F:MKM]MATTYP = 3
                [M:MBR]USEQTY(nolign-1) *= -1
            Endif

            Raz [M:MBR]MFMITMREF(nolign-1)
            If dim([M:MBR]TYPQTY(nolign-1)) > 0
               If [F:ITF]STOMGTCOD = 3  : [M:MBR]TYPQTY(nolign-1) = 1
               Else [M:MBR]TYPQTY(nolign-1) = 2
               Endif
            Endif

            [M:MBR]WLINUM(nolign-1)     = GMFMLIN
            [M:MBR]IPTDAT(nolign-1)     = date$
            If [M:MBR]BOMSEQ(nolign-1) <> 0
                [M:MBR]ITMTYP(nolign-1)     = 1
            Else
                [M:MBR]ITMTYP(nolign-1)     = 2
            Endif
            [M:MBR]CLEFLG(nolign-1)     = 2
            [M:MBR]STU(nolign-1)        = [F:ITM]STU
            [M:MBR]PCU(nolign-1)        = [M:MBR]STU(nolign-1)
            [M:MBR]PCUSTUCOE(nolign-1)  = 1

            #[M:MBR]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBR]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:MBR]STOCODL(nolign-1)    = [F:ITF]STOCOD
            [M:MBR]WCLEFLG(nolign-1)    = [M:MBR]CLEFLG(nolign-1)
            [M:MBR]WINDIC(nolign-1)     = 1

            #Chargement des section ana
            For J = 1 To GNBDIE
                   Call INISEC(WCCE,"MKM", J) From TRTX3CPT
                   Assign "[M:MBR]CCE"+num$(J)+"(nolign-1)" With WCCE
            Next
            nolign+=1
            GMFMLIN += 1
        Endif
   $NEXTR2
   Next
   #If [M:MBR]NBLIG > 0
        nolign=[M:MBR]NBLIG+1    # FQ 55323 avant [M:MBR]NBLIG
   #Else
   #    nolign = 1
   #Endif

   $RESEARCH_MFM2
    Case [F:BTS]FILTDEF
        When 1 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4 & MFMTRKFLG <5
        When 2 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4 & MFMTRKFLG =5
        When 3 :    Filter [F:MFM] Where MFGNUM = [M:MTPK]MFGNUM(WI) & MATSTA <>4
    Endcase
    For [F:MFM]
        If [F:MFM]MFMTRKFLG = 6 : Goto NEXTS2 : Endif

        If [F:ITM]ITMREF <> [F:MFM]ITMREF
            Read [F:ITM]ITM0 = [F:MFM]ITMREF
            If fstat : Goto NEXTS2 : Endif
        Endif

        If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
               Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
               If fstat : Raz [F:ITF] : Goto NEXTS2 : Endif
         Endif

        #On prend la ligne selon mode de destockage paramétré dans la transaction
        If ([F:BTS]STOCODDEF=3 | [F:ITF]STOCOD = [F:BTS]STOCODDEF)
            [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
            If dim([M:MBR]TYPQTY(nolign-1)) > 0
               If [F:ITF]STOMGTCOD = 3  : [M:MBR]TYPQTY(nolign-1) = 1
               Else [M:MBR]TYPQTY(nolign-1) = 2
               Endif
            Endif

            [M:MBR]=[F:MFM]
            [M:MBR]MKMTEX(nolign-1)    = [F:MFM]MFMTEX

            Gosub REAJUST_QTY_MFM

            [M:MBR]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD
            [M:MBR]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
            [M:MBR]LOTMGTCOD(nolign-1) = [F:ITM]LOTMGTCOD

            [M:MBR]MFMITMREF(nolign-1) = [F:MFM]ITMREF
            If [M:MBR]USEQTY(nolign-1) <=0 : Raz [M:MBR]ITMREF(nolign-1) : Goto NEXTS2 : Endif

            [M:MBR]WLINUM(nolign-1)     = GMFMLIN
            [M:MBR]IPTDAT(nolign-1)     = date$
            [M:MBR]ITMTYP(nolign-1)     = 1
            [M:MBR]MATTYP(nolign-1)     = 3
            [M:MBR]WIPTDAT(nolign-1)    = [F:MFM]TRKFIRST
            [M:MBR]MFMEXTQTY(nolign-1)  = [F:MFM]RETQTY
            [M:MBR]MFMUSEQTY(nolign-1)  = [F:MFM]USEQTY
            [M:MBR]MFMALLQTY(nolign-1)  = [F:MFM]ALLQTY
            [M:MBR]MFMSHTQTY(nolign-1)  = [F:MFM]SHTQTY
            [M:MBR]MFMTRKFLG(nolign-1)  = [F:MFM]MFMTRKFLG

            [M:MBR]STU(nolign-1)            = [F:ITM]STU
            [M:MBR]PCU(nolign-1)            = [M:MBR]STU(nolign-1)
            [M:MBR]PCUSTUCOE(nolign-1)      = 1

            #[M:MBR]ITMDES1(nolign-1)        = [F:ITM]ITMDES1
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MBR]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:MBR]STOCODL(nolign-1)        = [F:ITF]STOCOD
            If [F:MFM]MFMTRKFLG < 5
                 [M:MBR]CLEFLG(nolign-1)    = 1
            Else
                 [M:MBR]CLEFLG(nolign-1)    = 2
            Endif
            [M:MBR]WCLEFLG(nolign-1)        = [M:MBR]CLEFLG(nolign-1)
            [M:MBR]WINDIC(nolign-1)         = 1

            If [F:ITM]LOTMGTCOD > 1
                I = nolign-1
                Gosub LOAD_MKL
            Endif

#            Default Mask [MBR]
#            Call INIZONENT([M:MBR]ITMREF(nolign-1),"MBR",[M:MBR]FCY,"",0,"",nolign-1,19,[M:MBR]TRSCODS,[M:MBR]MFGNUM(nolign-1),3,1) From STKECR

            # car RAZ dan INIZONENT
#            [M:MBR]LOT(nolign-1) = [M:MBR]XLOT(nolign-1)
#            [M:MBR]SLO(nolign-1) =  [M:MBR]XSLO(nolign-1)

#            status=0
#            If [M:MBR]REIQTYPCU(nolign-1) <> 0
#                Call STJSTOENTW("MBR",19,12,[M:MBR]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRETOUR) From STKENT
#            Endif

            #Chargement des section ana
            Call CHARG_ACCCCE (nolign-1,"","","[M:MBR]CCE","MFM",0 , [F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
            For J = 1 To GNBDIE
                If evalue("[M:MBR]CCE"+num$(J)+"(nolign-1)") =""
                    Call INISEC(WCCE,"MKM", J) From TRTX3CPT
                    Assign "[M:MBR]CCE"+num$(J)+"(nolign-1)" With WCCE
                Endif
            Next
            nolign+=1
            GMFMLIN += 1
        Endif
   $NEXTS2
   Next
   Filter [F:MFM]
Next
[M:MBR]NBLIG = nolign-1

# 11.04 demande 26502 chargement spécifique du masque MBR
GPOINT = "LOAMSKMBR" : Gosub ENTREE From EXEFNC

Grizo [MBR]5,7,10
Gosub AFF_TABLEAU
Return

########################################################################
$INCREMENT_QUANTITE
Local Integer I,J

# Issue 69637 - 2010-12-03 by CCC : Le test MATTYP doit être fait par ligne
#     car il est possible d'avoir de la réintégration sur OF ou sur nomenclature en même temps
For I=0 To [M:MBR]NBLIG-2
    Case [M:MBR]MATTYP(I)
        When 3 :
            For J=I+1 To [M:MBR]NBLIG-1
                If [M:MBR]MATTYP(J)  = 3
&                & [M:MBR]MFGNUM(I)  = [M:MBR]MFGNUM(J)
&                & [M:MBR]ITMREF(I)  = [M:MBR]ITMREF(J)
&                & [M:MBR]BOMOPE(I)  = [M:MBR]BOMOPE(J)
&                & [M:MBR]BOMSEQ(I)  = [M:MBR]BOMSEQ(J)
                    [M:MBR]USEQTY(I) += [M:MBR]USEQTY(J)
                    [M:MBR]USEQTY(J) = 0
                    If dim([M:MBR]LOT)>0 & [M:MBR]LOT(I) <> [M:MBR]LOT(J) : Raz [M:MBR]LOT(I) : Endif
                Endif
            Next J
        When 4 :
            For J=I+1 To [M:MBR]NBLIG-1
                If [M:MBR]MATTYP(J)  = 4
&                & [M:MBR]BOMNUM(I)  = [M:MBR]BOMNUM(J)
&                & [M:MBR]BOMALT(I)  = [M:MBR]BOMALT(J)
&                & [M:MBR]ITMREF(I)  = [M:MBR]ITMREF(J)
&                & [M:MBR]BOMOPE(I)  = [M:MBR]BOMOPE(J)
&                & [M:MBR]BOMSEQ(I)  = [M:MBR]BOMSEQ(J)
                    [M:MBR]USEQTY(I) += [M:MBR]USEQTY(J)
                    [M:MBR]USEQTY(J) = 0
                    If dim([M:MBR]LOT)>0 & [M:MBR]LOT(I) <> [M:MBR]LOT(J) : Raz [M:MBR]LOT(I) : Endif
                Endif
            Next J
    Endcase
Next I
# Tri pour le DELA
Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]USEQTY(indice) Desc
Return

########################################################################
# il faut réajuster la quantité selon les mouvements en attente
# attention : dans STOJOU la quantité est en nagatif : donc pour l'enlever on fait + !!!
$REAJUST_QTY_MKM
Columns [STJ] (ACTQTY)
For [STJ] Where STOFCY = [M:MBR]FCY & VCRNUM = [F:MKM]MFGTRKNUM & VCRLIN = [F:MKM]MATTRKLIN
&             & UPDCOD = 1 & REGFLG <> 2
    [M:MBR]USEQTY(nolign-1) += [F:STJ]ACTQTY
Next
Columns [STJ]
Raz [F:STJ]
Return

########################################################################
# il faut réajuster la quantité selon les mouvements en attente
# attention : dans STOJOU la quantité est en nagatif : donc pour l'enlever on fait + !!!
$REAJUST_QTY_MFM
Columns [STJ] (ACTQTY)
# CCC (29/10/07) Bug 43601 : Ajout de ITMREF dans le filtre
For [STJ] Where STOFCY = [M:MBR]FCY & VCRNUMORI = [F:MFM]MFGNUM & VCRLINORI = [F:MFM]MFGLIN
&             & VCRSEQORI = [F:MFM]BOMSEQ & ITMREF=[F:MFM]ITMREF & UPDCOD = 1 & REGFLG <> 2
    [M:MBR]USEQTY(nolign-1) += [F:STJ]ACTQTY
Next
Columns [STJ]
Raz [F:STJ]
Return

########################################################################
# chargement dans un buffer invisible de tous les lots/slo sortis pour cette ligne avec la qté totale
# Si les sorties pour cette ligne se sont faites sur un lot unique on
# le pré alimente et il sera non saisissable
# de même avec le sous-lot
# de même avec le numéro de série ?
$LOAD_MKL
Local Char    WLOT,WSLO
Local Integer UNIQ_LOT,J, WCUMUL, UNIQ_SLO

If !clalev([F:MKM1]) : Local File MFGMATTRK [MKM1] : Endif

Case [M:MBR]MATTYP(I)
  When 3 :
# CCC (29/10/07) Bug 43601 : Ajout de ITMREF dans le filtre
    For [F:STJ] Where STOFCY = [M:MBR]FCY & VCRNUMORI = [M:MBR]MFGNUM(I) & VCRLINORI = [M:MBR]MFGLIN(I)
&                   & VCRSEQORI = [M:MBR]BOMSEQ(I) & ITMREF=[M:MBR]ITMREF(I) & UPDCOD = 2 & REGFLG <> 2
        If WLOT = "" & [F:STJ]LOT <> "" : WLOT = [F:STJ]LOT : Endif
        If WSLO = "" & [F:STJ]SLO <> "" : WSLO = [F:STJ]SLO : Endif
        If WLOT <> "" & [F:STJ]LOT <> WLOT : UNIQ_LOT = 1 : Endif
        If WSLO <> "" & [F:STJ]SLO <> WSLO : UNIQ_SLO = 1 : Endif
        Raz WCUMUL
        If [M:MKL]NBLIG > 0
            For J = 0 To [M:MKL]NBLIG-1
                If [M:MKL]VCRNUMORI(J)    = [F:STJ]VCRNUMORI &
&                  [M:MKL]VCRLINORI(J)    = [F:STJ]VCRLINORI &
&                  [M:MKL]VCRSEQORI(J)    = [F:STJ]VCRSEQORI &
&                  [M:MKL]LOT(J)          = [F:STJ]LOT       &
&                  [M:MKL]SLO(J)          = [F:STJ]SLO
                   [M:MKL]QTYSTUACT(J)   += [F:STJ]ACTQTY * -1
                   WCUMUL = 1
                Endif
            Next
        Endif
        If WCUMUL = 0
            J= [M:MKL]NBLIG
            [M:MKL]VCRNUMORI(J)    = [F:STJ]VCRNUMORI
            [M:MKL]VCRLINORI(J)    = [F:STJ]VCRLINORI
            [M:MKL]VCRSEQORI(J)    = [F:STJ]VCRSEQORI
            [M:MKL]LOT(J)          = [F:STJ]LOT
            [M:MKL]SLO(J)          = [F:STJ]SLO
            [M:MKL]STU(J)          = [F:STJ]STU
            [M:MKL]QTYSTUACT(J)    = [F:STJ]ACTQTY * -1
            [M:MKL]WLINUM(J)       = [M:MBR]WLINUM(I)
            [M:MKL]WLINLOT(J)      = J
            [M:MKL]NBLIG += 1
        Endif
    Next
  When 4:

    If [M:MBR]WENDDATF <> [0/0/0]
        Filter [STJ] Where STOFCY = [M:MBR]FCY   & ITMREF = [M:MBR]ITMREF(I)
&          & UPDCOD = 2  & REGFLG<>2 & VCRTYPORI = 0 & VCRTYP = 12
&          & IPTDAT >= [M:MBR]WENDDATD    & IPTDAT <= [M:MBR]WENDDATF
    Else
        Filter [STJ] Where STOFCY = [M:MBR]FCY   & ITMREF = [M:MBR]ITMREF(I)
&          & UPDCOD = 2  & REGFLG<>2 & VCRTYPORI = 0 & VCRTYP = 12
    Endif
    # 03.05 Performances
    For  [STJ]STJ0
            Read [F:MKM1]MKM0 = [F:STJ]VCRNUM;[F:STJ]VCRLIN
            If !fstat & [F:MKM1]BOMNUM = [M:MBR]BOMNUM(I) & [F:MKM1]BOMALT = [M:MBR]BOMALT(I)
                If WLOT = "" & [F:STJ]LOT <> "" : WLOT = [F:STJ]LOT : Endif
                If WSLO = "" & [F:STJ]SLO <> "" : WSLO = [F:STJ]SLO : Endif
                If WLOT <> "" & [F:STJ]LOT <> WLOT : UNIQ_LOT = 1 : Endif
                If WSLO <> "" & [F:STJ]SLO <> WSLO : UNIQ_SLO = 1 : Endif
                Raz WCUMUL
                If [M:MKL]NBLIG > 0
                    For J = 0 To [M:MKL]NBLIG-1
                        If [M:MKL]LOT(J)          = [F:STJ]LOT       &
&                          [M:MKL]SLO(J)          = [F:STJ]SLO
                           [M:MKL]QTYSTUACT(J)   += [F:STJ]ACTQTY * -1
                           WCUMUL = 1
                        Endif
                    Next
                Endif
                If WCUMUL = 0
                    J= [M:MKL]NBLIG
                    [M:MKL]LOT(J)          = [F:STJ]LOT
                    [M:MKL]SLO(J)          = [F:STJ]SLO
                    [M:MKL]STU(J)          = [F:STJ]STU
                    [M:MKL]QTYSTUACT(J)    = [F:STJ]ACTQTY * -1
                    [M:MKL]WLINUM(J)       = [M:MBR]WLINUM(I)
                    [M:MKL]WLINLOT(J)      = J
                    [M:MKL]NBLIG += 1
                Endif
            Endif
    Next
Endcase
Filter [F:STJ]
If UNIQ_LOT = 0
    [M:MBR]LOT(I) = WLOT
    #si lot unique et lot = "" alors lot blanc
    If [M:MBR]LOT(I) = "" : [M:MBR]GESLOT(I) = "B" : Endif
Endif
If UNIQ_SLO = 0
    [M:MBR]SLO(I) = WSLO
Endif

If [M:MBR]LOT(I) <> "" : [M:MBR]XLOT(I) = [M:MBR]LOT(I) : Endif
If [M:MBR]SLO(I) <> "" : [M:MBR]XSLO(I) = [M:MBR]SLO(I) : Endif
Return

########################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE11
Raz CRITERE2
Raz CUSFLT
Raz FORMULE1

# site
If [M:MBR]FCY <> ""
   CRITERE = "MFGFCY=[M:MBR]FCY"                # filtre site
   Gosub LOAD_CRITERE
Endif

# composant
If [M:MBR]WITMREFD <> ""
    CRITERE = "ITMREF>=[M:MBR]WITMREFD"      # borne début article
    Gosub LOAD_CRITERE
Endif
If [M:MBR]WITMREFF <>""
    CRITERE = "ITMREF<=[M:MBR]WITMREFF"      # borne fin   article
    Gosub LOAD_CRITERE
Endif

# OF
If [M:MBR]WMFGNUMD <> ""
   CRITERE = "MFGNUM>=[M:MBR]WMFGNUMD"         # borne début n°OF
   Gosub LOAD_CRITERE
Endif
If [M:MBR]WMFGNUMF <> ""
   CRITERE = "MFGNUM<=[M:MBR]WMFGNUMF"         # borne fin  n°OF
   Gosub LOAD_CRITERE
Endif

# Article produit
If [M:MBR]WITMRELD <> ""
    CRITERE = "BOMNUM>=[M:MBR]WITMRELD"      # borne début article
    Gosub LOAD_CRITERE
Endif
If [M:MBR]WITMRELF <>""
    CRITERE = "BOMNUM<=[M:MBR]WITMRELF"      # borne fin   article
    Gosub LOAD_CRITERE
Endif

# OPE
If [M:MBR]WOPENUMD <> 0
   CRITERE = "OPENUM>=[M:MBR]WOPENUMD"         # borne début opé
   Gosub LOAD_CRITERE
Endif
If [M:MBR]WOPENUMF <> 0
   CRITERE = "OPENUM<=[M:MBR]WOPENUMF"         # borne fin  opé
   Gosub LOAD_CRITERE
Endif

# Nomenclature
If [M:MBR]WBOMNUMD <> ""
   CRITERE = "BOMNUM>=[M:MBR]WBOMNUMD"         # borne début nomenclature
   Gosub LOAD_CRITERE
Endif
If [M:MBR]WBOMNUMF <> ""
   CRITERE = "BOMNUM<=[M:MBR]WBOMNUMF"         # borne fin  nomenclature
   Gosub LOAD_CRITERE
Endif

# alternative
If [M:MBR]WBOMALTD <> 0
   CRITERE = "BOMALT>=[M:MBR]WBOMALTD"         # borne début alternative
   Gosub LOAD_CRITERE
Endif
If [M:MBR]WBOMALTF <> 0
   CRITERE = "BOMALT<=[M:MBR]WBOMALTF"         # borne fin  alternative
   Gosub LOAD_CRITERE
Endif

CRITERE = "CPNTYP <> 5"
Gosub LOAD_CRITERE


# Filtre
CRITERE11 = "1=1"
If [F:BTS]FILTFLG < 3
    Case [M:MBR]FILTMAT
        When 1 : CRITERE11 = "MFMTRKFLG<5"
        When 2 : CRITERE11 = "MFMTRKFLG=5"
    Endcase
Else
    Case [F:BTS]FILTDEF
        When 1 : CRITERE11 = "MFMTRKFLG<5"
        When 2 : CRITERE11 = "MFMTRKFLG=5"
    Endcase
Endif

# analyse présence formule de sélection
If [M:MBR]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=13;[M:MBR]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

############################################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 < 250
  If CRITERE1 <> ""
      CRITERE1 += "&"
  Endif
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

########################################################################
$LOAD_FILTERMFM
Raz CRITERE
Raz CRITEREA
Raz CRITEREB

# quantite
CRITERE = "[F:MFM]USEQTY > 0"
Gosub LOAD_CRITEREMFM

# site
If [M:MBR]FCY <> ""
   CRITERE = "[F:MFM]MFGFCY=[M:MBR]FCY"                # filtre site
   Gosub LOAD_CRITEREMFM
Endif

# article
If [M:MBR]WITMREFD <> ""
    CRITERE = "[F:MFM]ITMREF>=[M:MBR]WITMREFD"      # borne début article
    Gosub LOAD_CRITEREMFM
Endif
If [M:MBR]WITMREFF <>""
    CRITERE = "[F:MFM]ITMREF<=[M:MBR]WITMREFF"      # borne fin   article
    Gosub LOAD_CRITEREMFM
Endif

# OF
If [M:MBR]WMFGNUMD <> ""
   CRITERE = "[F:MFM]MFGNUM>=[M:MBR]WMFGNUMD"         # borne début n°OF
   Gosub LOAD_CRITEREMFM
Endif
If [M:MBR]WMFGNUMF <> ""
   CRITERE = "[F:MFM]MFGNUM<=[M:MBR]WMFGNUMF"         # borne fin  n°OF
   Gosub LOAD_CRITEREMFM
Endif

# OPE
If [M:MBR]WOPENUMD <> 0
   CRITERE = "[F:MFM]BOMOPE>=[M:MBR]WOPENUMD"         # borne début opé
   Gosub LOAD_CRITEREMFM
Endif
If [M:MBR]WOPENUMF <> 0
   CRITERE = "[F:MFM]BOMOPE<=[M:MBR]WOPENUMF"         # borne fin  opé
   Gosub LOAD_CRITEREMFM
Endif

# Nomenclature
If [M:MBR]WBOMNUMD <> ""
   CRITERE = "[F:MFI]ITMREF>=[M:MBR]WBOMNUMD"         # borne début nomenclature
   Gosub LOAD_CRITEREMFM
Endif
If [M:MBR]WBOMNUMF <> ""
   CRITERE = "[F:MFI]ITMREF<=[M:MBR]WBOMNUMF"         # borne fin  nomenclature
   Gosub LOAD_CRITEREMFM
Endif

# alternative
If [M:MBR]WBOMALTD <> 0
   CRITERE = "[F:MFI]BOMALT>=[M:MBR]WBOMALTD"         # borne début alternative
   Gosub LOAD_CRITEREMFM
Endif
If [M:MBR]WBOMALTF <> 0
   CRITERE = "[F:MFI]BOMALT<=[M:MBR]WBOMALTF"         # borne fin  alternative
   Gosub LOAD_CRITEREMFM
Endif
CRITERE = "[F:MFM]CPNTYP <> 5"
Gosub LOAD_CRITEREMFM
Return

############################################################
$LOAD_CRITEREMFM
If len(CRITERE)+len(CRITEREA)+1 < 250
  If CRITEREA <> ""
      CRITEREA += "&"
  Endif
  CRITEREA += CRITERE
Else
  If CRITEREB <> ""
     CRITEREB += "&"
  Endif
  CRITEREB += CRITERE
Endif
Return

###########################################
$AFF_TABLEAU
Local Integer I, WRETOUR
Local Char    WGESLOT
#---------------------------------------#
#Les différentes valeurs de [M:MBR]WSRT:#
#    33 : Par Date/Composant            #
#    65 : Par Date/Of                   #
#   129 : Par Date/lot                  #
#    18 : Par Composant/Date            #
#    66 : Par Composant/OF              #
#   130 : Par Composant/lot             #
#    2O : Par Of/Date                   #
#    36 : Par Of/Composant              #
#   132 : Par Of/lot                    #
#    24 : Par lot/Date                  #
#    40 : Par lot/Composant             #
#    72 : Par lot/Of                    #
#---------------------------------------#
#
Case [M:MBR]WSRT
     When 33  : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]WIPTDAT(indice),
&                                                        [M:MBR]ITMREF(indice)
     When 65  : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]WIPTDAT(indice),
&                                                        [M:MBR]MFGNUM(indice)
     When 129 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]WIPTDAT(indice),
&                                                        [M:MBR]LOT(indice)
     When 18  : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]ITMREF(indice),
&                                                        [M:MBR]WIPTDAT(indice)
     When 66  : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]ITMREF(indice),
&                                                        [M:MBR]MFGNUM(indice)
     When 130 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]ITMREF(indice),
&                                                        [M:MBR]LOT(indice)
     When  20 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]MFGNUM(indice),
&                                                        [M:MBR]WIPTDAT(indice)
     When  36 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]MFGNUM(indice),
&                                                        [M:MBR]ITMREF(indice)
     When 132 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]MFGNUM(indice),
&                                                        [M:MBR]LOT(indice)
     When  24 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]LOT(indice),
&                                                        [M:MBR]WIPTDAT(indice)
     When  40 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]LOT(indice),
&                                                        [M:MBR]ITMREF(indice)
     When  72 : Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]LOT(indice),
&                                                        [M:MBR]MFGNUM(indice)
Endcase

Default Mask [MBR]
For I = 0 To [M:MBR]NBLIG-1
        WGESLOT = [M:MBR]GESLOT(I)
        Case [M:MBR]MATTYP(I)
            When 3 :
                Call INIZONENT([M:MBR]ITMREF(I),"MBR",[M:MBR]FCY,"",0,"",I,19,[M:MBR]TRSCODS,[M:MBR]MFGNUM(I),3,0) From STKECR
            When 4 :
                Call INIZONENT([M:MBR]ITMREF(I),"MBR",[M:MBR]FCY,"",0,"",I,19,[M:MBR]TRSCODS,"",3,0) From STKECR
        Endcase
        # car RAZ dans INIZONENT
        [M:MBR]LOT(I)    = [M:MBR]XLOT(I)
        [M:MBR]SLO(I)    = [M:MBR]XSLO(I)
        [M:MBR]GESLOT(I) = WGESLOT

        status=0

        If [M:MBR]REIQTYPCU(I) <> 0
           Call STJSTOENTW("MBR",19,12,[M:MBR]IPTDAT(I),I,NBLIG,"BTS",3,WRETOUR) From STKENT
        Endif
        # CCC (2010-01-26) Bug 61961 : S'il y a plusieurs mouvements d'origine, on ne permet pas la saisie
        Case [M:MBR]MATTYP(I)
            When 3 :
                Filter [STJ] Where STOFCY = [M:MBR]FCY
&                                & ITMREF = [M:MBR]ITMREF(I)
&                                & VCRTYP = 12
&                                & VCRNUMORI = [M:MBR]MFGNUM(I)
&                                & VCRLINORI = [M:MBR]MFGLIN(I)
&                                & REGFLG = 1
            When 4 :
                Filter [STJ] Where STOFCY = [M:MBR]FCY
&                                & ITMREF = [M:MBR]ITMREF(I)
&                                & VCRTYP = 12
&                                & VCRNUM = [M:MBR]MFGTRKNUM(I)
&                                & VCRLIN = [M:MBR]MATTRKLIN(I)
&                                & REGFLG = 1
        Endcase
        If rowcount([STJ])>1
            If dim([M:MBR]PALNUM)>0    Diszo PALNUM(I) : Endif
            If dim([M:MBR]CTRNUM)>0    Diszo CTRNUM(I) : Endif
            If dim([M:MBR]MVTDES)>0    Diszo MVTDES(I) : Endif
            If dim([M:MBR]STA)>0       Diszo STA(I)    : Endif
            If dim([M:MBR]LOC)>0       Diszo LOCTYP(I)
                                       Diszo LOC(I)    : Endif
            If dim([M:MBR]WRH)>0       Diszo WRH(I)    : Endif
            If dim([M:MBR]BPSLOT)>0    Diszo BPSLOT(I) : Endif
            If dim([M:MBR]LOT)>0       Diszo LOT(I)    : Endif
            If dim([M:MBR]SLO)>0       Diszo NBSLO(I)
                                       Diszo SLO(I)    : Endif
            If dim([M:MBR]SERNUM)>0    Diszo SERNUM(I) : Endif
        Endif
        # Issue 107513/8 - 2015-07-13 by JUSYN : ECC - Major and minor version after RAZ in INIZONENT
        If dim([M:MBR]ECCVALMAJ(I)) > 0
            If rowcount([STJ])>=1
                Read [STJ] First
                If !fstat
                    [M:MBR]ECCVALMAJ(I)       = [F:STJ]ECCVALMAJ
                    [M:MBR]ECCVALMIN(I)       = [F:STJ]ECCVALMIN
                Endif
            Endif
            # Issue 107513/8 - 2015-07-13 by JUSYN : EEC setting ECCSAIFLG default
            If dim([M:MBR]ECCSAIFLG(I)) > 0
                [M:MBR]ECCSAIFLG(I) = 9 # version number is not modifiable
            Endif
            Gosub GREY_ECC
        Endif
        Filter [STJ]
Next

Affzo [MBR]15
Return

########################################################################
$CHARG_PARAM

Call GETCPY(GFCY,"BTS",63,GMRENUM) From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 63 | [F:BTS]BTSNUM <> GMRENUM
    Read [BTS]BTS0=63;GMRENUM : If fstat Raz [F:BTS] : Endif
Endif
GFLAG   = [F:BTS]BTSNUM
Return


################################################################################################
$VALIDATION
# Issue 73286 - GA 01/2012
GPE=0 : GPOINT = "BEFVALID" : Gosub  ENTREE From EXEFNC
If GPE <> 0 : Return : Endif

Gosub CRE_SUIVI
If VALOK <> 2 : Return : Endif

If LORI <> "PILOT"
   Call FERME_TRACE From LECFIC
   If TRA = 1
      Call LEC_TRACE From LECFIC
   Endif
   TRA = 0
Endif

# GH 02/2016 bug 108954 don't lose entries if the validation didn't totally succeed
# Effzo [MBR]15
J=0
For I=0 To [M:MBR]NBLIG-1
  If WMTKNUM(I)="" & ([M:MBR]REIQTY(I) <> 0 | [M:MBR]CLEFLG(I) <> [M:MBR]WCLEFLG(I))
     J=1 : Break
  Endif
Next
If !J
   # all what should be validated was => clear the grid
   Effzo [MBR]15
   [M:MBR]NBLIG=0
Else
   # all what should be validated was not => remove validated lines of the grid to make a new try of validation
   I=0
   While I<[M:MBR]NBLIG
     If WMTKNUM(I)<>""
        Dela I, 1 [M:MBR]NBLIG : [M:MBR]NBLIG-=1 : I-=1
     Endif
     I+=1
   Wend
   Affzo [MBR]15
Endif
Return

################################################################################################
$FIN
GCONSULT = GCONSLCT
Call DELSTOENTW(-1,-1,"MBR",1,1,[M:MBR]FCY,1,"") From STKENT
Kill  GMRENUM, GMFMLIN
Raz GORITITCOL
Call IMPSCR From ATRTX3
PARAM(6) = num$(LRETOK)
GFONC1 = GGFONC1

# 01.10 mm 61503
Gosub REST_GLOB From TRTX3GLOB

Return

################################################################################################
$ABA
Call DELSTOENTW(-1,-1,"MBR",1,1,[M:MBR]FCY,1,"") From STKENT
Effzo [MBR]
Effzo [MKL]
Gosub LECTURE_BTS            # 08.05 31621
Gosub DEBUT                    # 08.05 31621
Return

######################################################################
$CRE_SUIVI
Local Integer I,OK,WOK, WLIN, WMATCLENBR, WNBMAT, STAT, LRET, WRETOUR, WRETN, WNOSUIVI, WNOLIGN
Local Date    WDAT
Local Char    WMFGNUM(GLONVCR),WWMFGNUM(GLONVCR),WMFGTRKNUM(GLONVCR),TIT(80)
Local Char    WNUMTEX (12)
Local Decimal WWQTY, WALLQTY,WSHTQTY,WWALLQTY,WWSHTQTY
Local Char    WMTKNUMSTR(GLONVCR), WMTKNUMEND(GLONVCR)        # llc étiquettes (9727)
Local Char    WMTKNUM(GLONVCR)(max(1,[M:MBR]NBLIG))
Local Integer WMFGMKM                                         # GH 17/09/2015 bug 110557

Raz WMTKNUMSTR, WMTKNUMEND                  # llc étiquettes (9727)
Raz WMTKNUM
#
VALOK=1
#1ere chose y a-t-il quelque chose à suivre ?
If [M:MBR]NBLIG = 0 : Return : Endif
WOK = 0
For I = 0 To [M:MBR]NBLIG-1
    If [M:MBR]REIQTY(I) <> 0 | [M:MBR]CLEFLG(I) <> [M:MBR]WCLEFLG(I)
        WOK = 1
        Break
    Endif
Next I
If WOK = 0 : Call ERREUR(mess(219,193,1)) From GESECRAN   : Return : Endif

Call CTLSTOENT( "MBR", "REIQTY", [M:MBR]NBLIG, WOK ) From STKECR
If !WOK : Return : Endif

#Un petit message de confirmation...
Call OUINON(mess(20,196,1),VALOK) From GESECRAN
If VALOK <> 2 : Return : Endif
#
# FQ 73634 GA 05/2011 ctrl ajouté après la Question ...
For I=0 To [M:MBR]NBLIG-1
    #If func MFGLIB.CHKMFGLOCK([M:MBR]MFGNUM(I),0) : # GH 21/02/2014 bug 94986
    If ([M:MBR]REIQTY(I) <> 0 | [M:MBR]CLEFLG(I) <> [M:MBR]WCLEFLG(I))
&      & !sigma(0,I-1,[M:MBR]MFGNUM(indcum)=[M:MBR]MFGNUM(I)
&                     & ([M:MBR]REIQTY(indcum) <> 0 | [M:MBR]CLEFLG(indcum) <> [M:MBR]WCLEFLG(indcum)))
&      & func MFGLIB.CHKMFGLOCK([M:MBR]MFGNUM(I),0)
        Call ERREUR([M:MBR]MFGNUM(I)-":"-mess(280,193,1)) From GESECRAN
        VALOK=1 : Break
    Endif
Next
If VALOK = 1 : Return : Endif

#On y va ...

If LORI <> "PILOT"
    TIT = mess(230,195,1)
    TRA=0
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Sorta [M:MBR]NBLIG [M:MBR]NBLIG Order By [M:MBR]IPTDAT(indice),
&                                        [M:MBR]MFGNUM(indice)
#Récupération du compteur
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
#
Raz [L]WLIN
For nolign = 1 To [M:MBR]NBLIG
  Raz WNOSUIVI
  If [M:MBR]REIQTY(nolign-1) <> 0 | [M:MBR]CLEFLG(nolign-1) <> [M:MBR]WCLEFLG(nolign-1)
        If WLIN = 0
           WDAT     = [M:MBR]IPTDAT(nolign-1)
           WMFGNUM  = [M:MBR]MFGNUM(nolign-1)
           WWMFGNUM = [M:MBR]MFGNUM(nolign-1)
           Call DEBTRANS From GLOCK
           Trbegin [MKM]
           Call NUMERO(GCODNUM,[M:MBR]FCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
           If STAT
              Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
              GOK = 0
              Break
           Endif
           WMTKNUM(nolign-1) = WMFGTRKNUM
        Else
           If [M:MBR]IPTDAT(nolign-1) <> WDAT
              If WNBMAT<>0 : # GH 17/09/2015 bug 110557 if WLIN<>0
                If WWMFGNUM <> ""
                   Gosub MAJ_ENTOF
                   Raz WWMFGNUM
                Endif
                Gosub CRE_ENTETE
                If GOK<1 : Break : Endif
              Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
              Endif
              Call DEBTRANS From GLOCK
              Trbegin [MKM]
              WDAT     = [M:MBR]IPTDAT(nolign-1)
              WMFGNUM  = [M:MBR]MFGNUM(nolign-1)
              WWMFGNUM = [M:MBR]MFGNUM(nolign-1)
              Call NUMERO(GCODNUM,[M:MBR]FCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
              If STAT
                  Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
                  GOK = 0
                  Break
              Endif
              WMTKNUM(nolign-1) = WMFGTRKNUM
           Else
              If [M:MBR]MFGNUM(nolign-1) <> WMFGNUM : Raz WMFGNUM : Endif
              If [M:MBR]MFGNUM(nolign-1) <> WWMFGNUM & WWMFGNUM <> ""
                 Gosub MAJ_ENTOF
                 Raz WWMFGNUM
                 If GOK<1 : Break : Endif
                 WWMFGNUM = [M:MBR]MFGNUM(nolign-1)
              Endif
           Endif
        Endif
        Raz [M:MTMK]
        [M:MTMK]           = [M:MBR]
        [M:MTMK]MFGFCY     = [M:MBR]FCY
        [M:MTMK]MFGTRKNUM  = WMFGTRKNUM
        [M:MTMK]MATTRKLIN  = [M:MBR]WLINUM(nolign-1)
        [M:MTMK]ENTCOD     = [F:BTS]ENTCODS
        [M:MTMK]TRSFAM     = [F:BTS]TRSFAMS
        [M:MTMK]TRSCODS    = [F:BTS]TRSCODS

       [M:MTMK]USEQTY = [M:MBR]REIQTY(nolign-1)
        #Lecture matière OF
       Case [M:MBR]MATTYP(nolign-1)
         When 3 :
         #Lecture matière OF
            WNOLIGN = nolign
            If [M:MBR]MFMITMREF(nolign-1) <> ""
               Read [F:MFM]MFM0 = [M:MBR]MFGNUM(nolign-1);[M:MBR]MFGLIN(nolign-1);[M:MBR]BOMSEQ(nolign-1);[M:MBR]ITMREF(nolign-1)
                If fstat
                     GOK = 0 : Call RSTA("MFM",[M:MBR]MFGNUM(nolign1)+num$([M:MBR]MFGLIN(nolign-1))) From GLOCK
                     Break
                 Endif
                [M:MTMK]TYPTRT = 14
            Else
                [M:MTMK]TYPTRT = 15
            Endif
            # Issue 86369 - 2014-01-21 by CCC
            If [M:MTMK]MVTDES=""
                [M:MTMK]MVTDES     =  mess(145,190,1)
            Endif
            Call CRE_MKM("",0) From MTKAUTLIB
            If GOK < 1 : TRA = 1 : Break : Endif
            nolign = WNOLIGN
            [L]WLIN   += 1
            WMATCLENBR = [M:MTMK]WMATCLENBR
            WNBMAT += [M:MTMK]WNBMAT : # WNBMAT += 1 # GH 17/09/2015 bug 1105557
            WMFGMKM += [M:MTMK]WNBMAT : # GH 17/09/2015 bug 110557
         When 4 :
            WNOLIGN = nolign
        #Lecture de l'article de nomenclature
            If [M:MBR]MFMITMREF(nolign-1) <> ""
               Read [F:BOD]BOD0 = [M:MBR]BOMNUM(nolign-1);[M:MBR]BOMALT(nolign-1);[M:MBR]BOMSEQ(nolign-1);[M:MBR]ITMREF(nolign-1);2
                If fstat
                     GOK = 0 : Call RSTA("BOD",[M:MBR]BOMNUM(nolign1)+num$([M:MBR]BOMALT(nolign-1))) From GLOCK
                     Break
                Endif
                [M:MTMK]TYPTRT = 16
            Else
                [M:MTMK]TYPTRT = 17
            Endif
            # Issue 86369 - 2014-01-21 by CCC
            If [M:MTMK]MVTDES=""
                [M:MTMK]MVTDES     =  mess(198,190,1)
            Endif
            Call CRE_MKM([M:MTMK]BOMNUM,0) From MTKAUTLIB
            If GOK < 1 : TRA = 1 : Break : Endif
            nolign = WNOLIGN
            [L]WLIN   += 1
            WMATCLENBR = [M:MTMK]WMATCLENBR
            WNBMAT += [M:MTMK]WNBMAT : # WNBMAT += 1 # GH 17/09/2015 bug 1105557
        Endcase
  Endif
Next
If GOK > 0 & WWMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
If GOK < 1
   If adxlog : Gosub AB_TR : Endif
Else
   If WNBMAT <> 0 : Gosub CRE_ENTETE
   Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
   Endif
Endif

If GOK < 1
   # GH 02/2016 bug 108954  cancel the tracking number set on the associated lines
   If WMFGTRKNUM<>""
      Look [MTK]MTK0 = WMFGTRKNUM
      If fstat
        For I=0 To [M:MBR]NBLIG-1
            If WMTKNUM(I) = WMFGTRKNUM : WMTKNUM(I)="" : Endif
        Next I
      Endif
   Endif
   Return
Endif

Gosub LBE

# 11.02 point d'entrée permettant d'effectuer un traitement supplémentaire
# en fin de plan, exemple, lancer une impression
GPOINT = "CUSTRTSUP" : Gosub  ENTREE From EXEFNC
Return

############################################

$MAJ_ENTOF
If WMFGMKM<>0  : # GH 17/09/2015 bug 110557 test WMFGMKM
    #Maj entête d'OF
    Readlock [F:MFG]MFG0 = WWMFGNUM
    If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(WWMFGNUM) : Return
    Elsif fstat GOK=0  : Call RSTA("MFG",num$(WWMFGNUM)) From GLOCK : Return
    Endif
    [F:MFG]MATCLENBR += WMATCLENBR
    If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&      [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&      [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
       [F:MFG]MFGTRKFLG = 5
        # CCC (10/01/08) DM 44021
    #   [F:MFG]TRKLAST   = WDAT
    Else
       [F:MFG]MFGTRKFLG = 4
        # CCC (10/01/08) DM 44021
    #   Raz [F:MFG]TRKLAST
    Endif
    # CCC (10/01/08) DM 44021
    If [F:MFG]TRKLAST<WDAT
       [F:MFG]TRKLAST   = WDAT
    Endif
    If [F:MFG]TRKLASTC<date$
       [F:MFG]TRKLASTC  = date$
    Endif
    If [F:MFG]TRKFIRST>WDAT | [F:MFG]TRKFIRST = "00/00/00"
        [F:MFG]TRKFIRST = WDAT
    Endif
    If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
        [F:MFG]TRKFIRSTC = date$
    Endif

    Rewrite [F:MFG]
    If fstat
       GOK = 0 : Call FSTA("MFG") From GLOCK : Return
    Endif
    #----- MISE à jour statistiques entête OF -----#
    Call VALSTA("MFG",1) From SUBPS2
    If GOK < 1 : Return : Endif
Endif

Raz WMATCLENBR, WMFGMKM : # GH 17/09/2015 bug 110557 raz WWMFGMKM
Return

############################################################
#Création entête de suivi
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    If WMFGNUM <> ""
       Read [F:MFG] = WMFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = [M:MBR]FCY
    [F:MTK]TRSCODS   = [M:MTMK]TRSCODS
    [F:MTK]MFGTRKNUM = WMFGTRKNUM
    [F:MTK]MFGTRKDAT = WDAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 2
    [F:MTK]NBRMAT    = WNBMAT

#---52014 mm 01.09 - PE pour gérer des zones spécifiques
    GPOINT = "CRE_ENTETE" : Gosub ENTREE From EXEFNC

    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1
   Gosub AB_TR
Else
   Commit
   LRETOK = 2
   TRA = 1
   Call ECR_TRACE(mess(79,190,1)-[F:MTK]MFGTRKNUM,0) From GESECRAN

   If WMTKNUMSTR = ""       # llc étiquettes 9727
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
       # Les n° de documents ne sont pas nécessairement créés de façon croissante
   Elsif WMTKNUMEND < [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
   Elsif WMTKNUMSTR > [F:MTK]MFGTRKNUM
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
   Endif

   Raz WMFGTRKNUM
Endif

Raz WNBMAT, WLIN, WMFGNUM
Return

$AB_TR
Rollback
LRETOK = 0
If GOK<0 & GLOCK<>"" :  # GH 02/2016 bug 108954 put an error in the log in case of lock
   Call ECR_LOCK("") From GLOCK : GLOCK=""
   TRA=1
Endif
If !GVTMOD
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(mess(254,193,1)+"\"+mess(255,193,1),1) From GESECRAN
   TRA=1
Endif
Return

##############################################
# impression étiquettes 9727
$LBE
If WMTKNUMSTR <> "" & WMTKNUMEND <> "" & [F:BTS]PRNCOD1 > 1
   Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
   WPARAM(1) = [M:MBR]FCY
   WPARAM(2) = "12"
   WPARAM(3) = WMTKNUMSTR
   WPARAM(4) = WMTKNUMEND
   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif
Return

##############################################
$AB4_NBLIG
Local Char WBOMNUM(GLONVCR)

Case [M:MBR]MATTYP(nolign-1)
    When 3
        [M:MBR]WMFGNUM = [M:MBR]MFGNUM(nolign-1)
        [M:MBR]WMFGLIN = [M:MBR]MFGLIN(nolign-1)
        [M:MBR]WBOMSEQ = [M:MBR]BOMSEQ(nolign-1)
        If [M:MBR]NBLIG > 0
           [M:MBR]FLT  = "[F:STJ]VCRNUMORI  = [M:MBR]WMFGNUM"
           [M:MBR]FLT += "&[F:STJ]VCRLINORI = [M:MBR]WMFGLIN"
           [M:MBR]FLT += "&[F:STJ]VCRSEQORI = [M:MBR]WBOMSEQ"
           [M:MBR]FLT += "&[F:STJ]REGFLG  <> 2"
        Endif
    When 4:
        Raz WBOMNUM
        WBOMNUM        = [M:MBR]BOMNUM(nolign-1)
        [M:MBR]WMFGNUM = WBOMNUM
        [M:MBR]WMFGLIN = [M:MBR]BOMALT(nolign-1)
        If [M:MBR]NBLIG > 0
           [M:MBR]FLT  = "[F:STJ]VCRNUMORI  = [M:MBR]WMFGNUM"
           [M:MBR]FLT += "&[F:STJ]VCRLINORI = [M:MBR]WMFGLIN"
           [M:MBR]FLT += "&[F:STJ]REGFLG  <> 2"
        Endif
Endcase
Return


############################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
[M]FCY = VALEUR
If dim([M:MBR]WRHE)>0
    Effzo [MBR]WRHE,WRH
Endif
Gosub WRH_ETAT
# Issue 73720 - 2011-05-18 by CCC
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
End

############################################
Subprog AM_WITMREFD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]WITMREFF = VALEUR
                  Affzo [M]WITMREFF
Endif
End

############################################
Subprog C_WITMREFF(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WITMREFD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

############################################
Subprog AM_WENDDATD(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]WENDDATF = VALEUR : Affzo [M]WENDDATF : Endif
End

############################################
Subprog C_WENDDATF(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]WENDDATD : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

############################################
Subprog IB_NBLIG
#GBOUT3 = "Ordre de fabrication"
#GBOUT4 = "Mouvenents"
#GBOUT5 = "Saisie détail quantité"
#GBOUT6 = "Infos lots"
#GBOUT7 = "Complément lot"
#GBOUT8 = "Tout inclure"
#GBOUT9 = "Tout exclure"
If [M:MBR]ITMREF(nolign-1) <> ""
    #  Bouton saisie détail quantités
    Call STKINIBTN( 5, 0, 6, 7, "MBR", "BTS", [M:MBR]ITMREF(nolign-1) , [M:MBR]FCY) From STKENT
Else
    Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10, GBOUT11, GBOUT12
    End
Endif


If [M:MBR]MFMITMREF(nolign-1) = ""
    Raz GBOUT1,GBOUT2,GBOUT3
Endif

Raz GBOUT8, GBOUT9
If [M:MBR]REIQTY(nolign-1) <> 0
        GBOUT9=  mess(289,198,1)
        If [M:MBR]REIQTY(nolign-1) <> [M:MBR]USEQTY(nolign-1)
            GBOUT8 = mess(288,198,1)
        Endif
Else
        GBOUT8 = mess(288,198,1)
Endif


End

############################################
Subprog C_NBLIG
Local Integer NOL
#
# pour bug moteur
If [M:MBR]NBLIG > 0
  If [M:MBR]ITMREF([M:MBR]NBLIG-1) = ""
    status=65 : nolign=[M:MBR]NBLIG
    Dela [M:MBR]NBLIG-1,1,[M:MBR]NBLIG-1 [M:MBR]NBLIG : [M:MBR]NBLIG-=1
  Endif
Endif
GMODIF=2    # pour bug moteur
Case status
    When 82:          NOL=nolign-1                    # Reprise
                      GMODIF=1    # pour bug moteur
                      mkstat=2
Endcase
End

############################################
Subprog AVANT_NBLIG
If [M:MBR]REIQTYPCU(nolign-1)=0
    GMODIF = 1
Endif
End


############################################
Subprog B8_NBLIG
# tout inclure
[M:MBR]REIQTYPCU(nolign-1) = [M:MBR]USEQTY(nolign-1) / [M:MBR]PCUSTUCOE(nolign-1)
Call QTEARR([M:MBR]REIQTYPCU(nolign-1),[M:MBR]PCU(nolign-1)) From TRTDIV
Call AM_REIQTYPCU([M:MBR]REIQTYPCU(nolign-1))
mkstat = 99
End

############################################
Subprog B9_NBLIG

# tout exclure
[M:MBR]REIQTYPCU(nolign-1) = 0
Call AM_REIQTYPCU([M:MBR]REIQTYPCU(nolign-1))
mkstat = 99
End

############################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
#On ne peut pas saisir une date > date du jour
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
#On ne peut pas saisir une date < au mouvement initial
If VALEUR < [M:MBR]WIPTDAT(nolign-1) : GMESSAGE = mess(187,193,1)- format$(GFMD,[M:MBR]WIPTDAT(nolign-1))
           mkstat = 1
           End
Endif
End

############################################
Subprog AS_PECFLG(VALEUR)
Variable Integer VALEUR
If [M:MBR]WCLEFLG(nolign-1) = 2 : mkstat = 2 : End : Endif
End

############################################
Subprog AM_PECFLG(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M:MBR]CLEFLG(nolign-1)  = [M:MBR]WCLEFLG(nolign-1)
               [M:MBR]REIQTYPCU(nolign-1)  = 0
    When 2:    If [M:MBR]WCLEFLG(nolign-1) = 1 : [M:MBR]CLEFLG(nolign-1) = 2 : Endif
Endcase
Call AM_CLEFLG(VALEUR)
[M:MBR]PECFLG(nolign-1) = VALEUR
Affzo [MBR]15
End

############################################
Subprog AS_REIQTYPCU(VALEUR)
Variable Decimal VALEUR

If GMTK <> "" : mkstat = 2 : End : Endif
If [M:MBR]USEQTY(nolign-1) = 0 : mkstat = 2 : End : Endif
End


############################################
Subprog C_REIQTYPCU(VALEUR)
Variable Decimal VALEUR
Local Decimal WREIQTY

#calcul de la quantité en US
WREIQTY = VALEUR  * [M:MBR]PCUSTUCOE(nolign-1)
Call QTEARR(WREIQTY,[M:MBR]STU(nolign-1)) From TRTDIV

If WREIQTY > [M:MBR]USEQTY(nolign-1)
   GMESSAGE = mess(38,190,1) - num$([M:MBR]USEQTY(nolign-1))
   mkstat = 1
   End
Endif
End

############################################
Subprog AM_REIQTYPCU(VALEUR)
Variable Decimal VALEUR
#calcul de la quantité en US

[M:MBR]REIQTYPCU(nolign-1) = VALEUR
[M:MBR]REIQTY(nolign-1) = VALEUR  * [M:MBR]PCUSTUCOE(nolign-1)
Call QTEARR([M:MBR]REIQTY(nolign-1),[M:MBR]STU(nolign-1)) From TRTDIV

If [M:MBR]REIQTY(nolign-1)=0
    If [M:MBR]CLEFLG(nolign-1)  = [M:MBR]WCLEFLG(nolign-1)
       [M:MBR]PECFLG(nolign-1)  = 1
    Endif
Else
       [M:MBR]PECFLG(nolign-1)  = 2
Endif
Affzo [MBR]PECFLG(nolign-1)
Affzo [MBR]REIQTY(nolign-1)
Affzo [MBR]REIQTYPCU(nolign-1)
If VALEUR <> 0
    GMODIF = 2
Else
    GMODIF = 1
Endif

End


############################################
Subprog AV_CLEFLG(VALEUR)
Variable Integer VALEUR
If    VALEUR <> [M:MBR]WCLEFLG(nolign-1)
      pcolor = GCOUL(1)
Else
      pcolor = GCOUL(0)
Endif
End

############################################
Subprog AS_CLEFLG(VALEUR)
Variable Integer VALEUR
# Issue 47625 - 2011-01-17 by CCC : En réintégration "normale", il faut laisser accès à la zone "Solde"
#                                   En annulation de pesée, on laisse aussi accès à ce flag pour éviter un changement de comportement
#If GMTK = ""
#    If [M:MBR]WCLEFLG(nolign-1) = 2 : mkstat = 2 : End : Endif
#Endif
If [M:MBR]ITMTYP(nolign-1) = 2 : mkstat = 2 : End : Endif
End

############################################
Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:MBR]REIQTYPCU(nolign-1) = 0 : [M:MBR]PECFLG(nolign-1)  = 1
Elsif VALEUR = 2                               : [M:MBR]PECFLG(nolign-1)  = 2
Endif

[M:MBR]CLEFLG(nolign-1) = VALEUR
Affzo [MBR]PECFLG(nolign-1),CLEFLG(nolign-1)

End

############################################
Subprog AS_LOCTYP(VALEUR)
Variable Char    VALEUR()
If [F:ITF]ITMREF <> [M:MBR]ITMREF(nolign-1) | [F:ITF]STOFCY <> [M:MBR]FCY
    Read [F:ITF]ITF0 = [M:MBR]ITMREF(nolign-1);[M:MBR]FCY
    If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]LOCMGTCOD = 1 : mkstat = 2 : End : Endif
End

############################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,1)
VALEUR = toupper(VALEUR)
#
If len(VALEUR) <> 0
  If mid$(VALEUR,len(VALEUR),1) <> "*"
    Read [TLO]TLO0=[M:MBR]FCY;VALEUR
    If fstat
      mkstat = 2
    Endif
  Else
    VALEUR = toupper(left$(VALEUR,len(VALEUR)-1))+"*"
  Endif
Endif
If [M:MBR]LOCTYP(nolign-1)<>VALEUR                                             # hcb 89061
   Call RAZLOC([M:MBR]LOC(nolign-1),[M:MBR]WLOCSEQ(nolign-1)) From STKACT
Endif
End

############################################
Subprog AS_LOC(VALEUR)
Variable Char    VALEUR()

If [F:ITF]ITMREF <> [M:MBR]ITMREF(nolign-1) | [F:ITF]STOFCY <> [M:MBR]FCY
    Read [F:ITF]ITF0 = [M:MBR]ITMREF(nolign-1);[M:MBR]FCY
    If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]LOCMGTCOD = 1 : mkstat = 2 : End : Endif
End

############################################
Subprog AM_LOC(VALEUR)
Variable Char    VALEUR()
Read [F:STC]STC0 = [M:MBR]FCY;VALEUR
If fstat : Raz [F:STC] : Endif
[M:MBR]LOCTYP(nolign-1) = [F:STC]LOCTYP
Affzo [MBR]LOCTYP(nolign-1)
End

############################################
Subprog AS_CRIT1(VALEUR)
Variable Integer VALEUR
GMENLOC(4) = 1
End

############################################
Subprog AS_CRIT2(VALEUR)
Variable Integer VALEUR
GMENLOC(4) = 1
End

############################################
Subprog C_CRIT2(VALEUR)
Variable Integer VALEUR
If VALEUR = [M]CRIT1 : GMESSAGE = mess(144,193,1) : mkstat = 1 : End : Endif
End

############################################
Subprog APRES_NBLIG

# si l'UC ou le coeff. ont été modifiés et que REIQTYPCU=0, on réinitialise l'UC et le coeff.
If [M:MBR]PCU(nolign-1)<>[M:MBR]STU(nolign-1) | [M:MBR]PCUSTUCOE(nolign-1)<>1
    If [M:MBR]REIQTYPCU(nolign-1)=0
        [M:MBR]PCU(nolign-1)=[M:MBR]STU(nolign-1) : [M:MBR]PCUSTUCOE(nolign-1)=1
        Affzo [MBR]PCU(nolign-1), PCUSTUCOE(nolign-1)
    Endif
Endif
End

############################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Local Char    WUOM
Local Decimal WCOEFF

WUOM = VALEUR
Gosub DIS_COEFF
If mkstat : End : Endif

[M:MBR]PCUSTUCOE(nolign-1)=WCOEFF
Raz [M:MBR]REIQTYPCU(nolign-1)
Call AM_REIQTYPCU([M:MBR]REIQTYPCU(nolign-1))
End

$DIS_COEFF
#---------------------------------------------------------------#
# Alimentation du coeff dans WCOEFF et positionnement flag saisi#
# WUOM doit contenir l'unité                                    #
#---------------------------------------------------------------#
If dim(NOL)<0 Local Shortint NOL : Endif
NOL=nolign-1
Local Char     LUSCAV(2), LLBEFMT(GLONARP)
Local Integer LDACCOE

Call CTLUOM([M:MBR]ITMREF(NOL),1,"", WUOM, WCOEFF,
&           LUSCAV, LLBEFMT, LDACCOE) From STKACT
If mkstat : Return : Endif
If LDACCOE=1
  Affzo [MBR]PCUSTUCOE(NOL) : # pb diszo
  Diszo [MBR]PCUSTUCOE(NOL)
  Affzo [MBR]PCUSTUCOE(NOL) : # pb diszo
  [M:MBR]WSTOSAI(NOL)=left$([M:MBR]WSTOSAI(NOL),2)+"2"+right$([M:MBR]WSTOSAI(NOL),4)
Else
  Affzo [MBR]PCUSTUCOE(NOL) : # pb diszo
  Actzo [MBR]PCUSTUCOE(NOL)
  Affzo [MBR]PCUSTUCOE(NOL) : # pb diszo
  [M:MBR]WSTOSAI(NOL)=left$([M:MBR]WSTOSAI(NOL),2)+"0"+right$([M:MBR]WSTOSAI(NOL),4)
Endif
Return

############################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
Raz [M:MBR]REIQTYPCU(nolign-1)
Call AM_REIQTYPCU([M:MBR]REIQTYPCU(nolign-1))
End

############################################
Subprog C_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
If VALEUR =0
    mkstat=2
Endif
End

############################################
Subprog AS_PCUSTUCOE(VALEUR)
