#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_DATANC
Onevent BEFORE_INPUT Call AS_DATANC(zc) From W3CTR1
Onevent AFTER_CHANGE Gosub AMM_DATANC From W3CTR1
Onevent BEFORE_AREA Gosub AV_DATANC From W3CTR1
Return

$AV_DATANC
Chgfmt [M]DATANC(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_DATANC(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_DATANC(VALEUR) From SUBCTR
If mkstat=2
 [M]DATANC(INDIC) = VALEUR
 Affzo DATANC(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_DATANC
Call AM_DATANC(zc)
If !mkstat & GOBJET
 zoncou = "DATANC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DATANC(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_DATANC(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "DATANC" : GZNUM = 47186 : Endif
Gosub _AFF
End

