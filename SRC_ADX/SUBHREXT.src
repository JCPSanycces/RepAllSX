#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management HREXT
######################################################################################
## Section automatically added (Object HREXT) 02/26/2015 14:10:29 (JASMI)
######################################################################################
$ACTION
Case ACTION
  When "LIENS"    : Gosub LIENS
  When "CREATION" : Gosub CREATION
  When "MODIF"    : Gosub MODIF
  When "EXEBOUT"  : Gosub EXEBOUT
Endcase
Return

$LIENS
  nolign = 0
  For [F:HREXD]HREXD0 Where [F:HREXD]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT1] = [F:HREXD]
  Next
  nolign = 0
  For [F:HREXF]HREXF0 Where [F:HREXF]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT1] = [F:HREXF]
  Next
  nolign = 0
  For [F:HREXP]HREXP0 Where [F:HREXP]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT2] = [F:HREXP]
  Next
  nolign = 0
  For [F:HREXG]HREXG0 Where [F:HREXG]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT3] = [F:HREXG]
  Next
  nolign = 0
  For [F:HREXL]HREXL0 Where [F:HREXL]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT3] = [F:HREXL]
  Next
  nolign = 0
  For [F:HREXV]HREXV0 Where [F:HREXV]EXRTEP=[M:HREXT0]EXRTEP
    nolign += 1
    [M:HREXT4] = [F:HREXV]
  Next

Return

$CREATION
$MODIF
  Delete [F:HREXD] Where [F:HREXD]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXD",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif
  Delete [F:HREXF] Where [F:HREXF]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXF",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif
  Delete [F:HREXP] Where [F:HREXP]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXP",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif
  Delete [F:HREXG] Where [F:HREXG]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXG",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif
  Delete [F:HREXL] Where [F:HREXL]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXL",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif
  Delete [F:HREXV] Where [F:HREXV]EXRTEP=[M:HREXT0]EXRTEP
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREXV",[M:HREXT0]EXRTEP) From GLOCK : Return
  Endif

  For nolign=1 To [M:HREXT1]DTANBR
    Raz [F:HREXD]
    [F:HREXD] = [M:HREXT0]
    [F:HREXD] = [M:HREXT1]
    [F:HREXD]DTANBR = nolign
    Write [F:HREXD]
    If fstat
      GOK=0 : Call FSTA("HREXD") From GLOCK : Break
    Endif
  Next nolign
  For nolign=1 To [M:HREXT1]FLTNBR
    Raz [F:HREXF]
    [F:HREXF] = [M:HREXT0]
    [F:HREXF] = [M:HREXT1]
    [F:HREXF]FLTNBR = nolign
    Write [F:HREXF]
    If fstat
      GOK=0 : Call FSTA("HREXF") From GLOCK : Break
    Endif
  Next nolign
  For nolign=1 To [M:HREXT2]PARNBR
    Raz [F:HREXP]
    [F:HREXP] = [M:HREXT0]
    [F:HREXP] = [M:HREXT2]
    [F:HREXP]PARNBR = nolign
    Write [F:HREXP]
    If fstat
      GOK=0 : Call FSTA("HREXP") From GLOCK : Break
    Endif
  Next nolign
  For nolign=1 To [M:HREXT3]GRPNBR
    Raz [F:HREXG]
    [F:HREXG] = [M:HREXT0]
    [F:HREXG] = [M:HREXT3]
    [F:HREXG]GRPNBR = nolign
    Write [F:HREXG]
    If fstat
      GOK=0 : Call FSTA("HREXG") From GLOCK : Break
    Endif
  Next nolign
  For nolign=1 To [M:HREXT3]DFNNBR
    Raz [F:HREXL]
    [F:HREXL] = [M:HREXT0]
    [F:HREXL] = [M:HREXT3]
    [F:HREXL]DFNNBR = nolign
    Write [F:HREXL]
    If fstat
      GOK=0 : Call FSTA("HREXL") From GLOCK : Break
    Endif
  Next nolign
  For nolign=1 To [M:HREXT4]VLYNBR
    Raz [F:HREXV]
    [F:HREXV] = [M:HREXT0]
    [F:HREXV] = [M:HREXT4]
    [F:HREXV]VLYNBR = nolign
    Write [F:HREXV]
    If fstat
      GOK=0 : Call FSTA("HREXV") From GLOCK : Break
    Endif
  Next nolign

  GOK=1
  Gosub DELETE_TRT
  Gosub CREATE_TRT
  If GOK<>0
    Gosub COMPILE_TRT
  Endif

Return

$EXEBOUT
Case REP
  When "V"
    GOK=1
    Gosub DELETE_TRT
    Gosub CREATE_TRT
    If GOK<>0
      Gosub COMPILE_TRT
    Endif
Endcase
Return

#=============================================================================
$DELETE_TRT
  Call DELTRT("W"+[M:HREXT0]EXRSRCNAM,nomap) From SUBADC

Return

#=============================================================================
$CREATE_TRT
Local Char    TABLE_COUNT(1), FICSRC(250)
Local Integer TABLE_COUNTER, DATA_LEVEL, TABLE_IDX

#populate table abbreviations
#JASMI - 2017-02-07 - SA TYE 2017 - START
#  If clalev([F:ATB])=0        : Local File ATABLE           [ATB]    : Endif
  If clalev([F:AVWT])=0        : Local File AVIEWTAB           [AVWT]    : Endif
#JASMI - 2017-02-07 - SA TYE 2017 - END
  For nolign=1 To [M:HREXT1]DTANBR
    Read [F:AVWT]CODFIC = [M:HREXT1]DTATBL(nolign-1)
    If !fstat
      [L]TABLE_COUNT="" : [L]TABLE_COUNTER=0
      If nolign>1
        For [L]TABLE_IDX=0 To (nolign-1-1)
          If [M:HREXT1]DTATBL(nolign-1)=[M:HREXT1]DTATBL([L]TABLE_IDX)
            [L]TABLE_COUNT=num$(val([L]TABLE_COUNT)+1)
            [L]TABLE_COUNTER+=1
          Endif
        Next
      Endif
      [M:HREXT1]DTATBLABR(nolign-1)=[F:AVWT]ABRFIC+[L]TABLE_COUNT
      [M:HREXT1]DTAORGABR(nolign-1)=""
      If [L]TABLE_COUNT<>""
        [M:HREXT1]DTAORGABR(nolign-1)=[F:AVWT]ABRFIC
      Endif
    Else
      GOK=0 : Call FSTA("AVWT") From GLOCK : Return
    Endif
  Next nolign

#get filename
  FICSRC = filpath("TRT","W"+[M:HREXT0]EXRSRCNAM,"src",nomap)

#open source file
  Openo FICSRC,0
  adxifs = ""
  adxirs = chr$(10)

#write creation details
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# Date :'-format$("DD4",date$)

#write action for open statements for data sources specified
  Wrseq ''
  Wrseq '$OPEN_TEMPLATE_TABLES'

  For nolign=1 To [M:HREXT1]DTANBR
    Wrseq '  If clalev([F:'+[M:HREXT1]DTATBLABR(nolign-1)+'])=0 : Local File '+[M:HREXT1]DTATBL(nolign-1)+' ['+[M:HREXT1]DTATBLABR(nolign-1)+'] : Endif'
  Next nolign

  Wrseq ''
  Wrseq 'Return'

#write action for header link statements for data sources specified
  Wrseq ''
  Wrseq '$LINK_HEADER'

  [L]DATA_LEVEL=1
  Gosub WRITE_LINK_ACTIONS

  Wrseq ''
  Wrseq 'Return'

#write action for detail link statements for data sources specified
  Wrseq ''
  Wrseq '$LINK_DETAIL'

  [L]DATA_LEVEL=2
  Gosub WRITE_LINK_ACTIONS

  Wrseq ''
  Wrseq 'Return'

#close file
  Openo

Return

$WRITE_LINK_ACTIONS
Local Char    TEMP_VAL(250), TRAILING_CHAR(1)
Local Integer TABLE_COUNTER, TABLE_COUNTER2, FIELD_SPEC_START, FIELD_SPEC_END

#get table count for level
  [L]TABLE_COUNTER2=0
  For nolign=1 To [M:HREXT1]DTANBR
    If [M:HREXT1]DTALVL(nolign-1)=[L]DATA_LEVEL
      [L]TABLE_COUNTER2+=1
    Endif
  Next nolign

  If [L]TABLE_COUNTER2<2
    GOK=0
    GMESSAGE = mess(44, 11662, 1)
    Return
  Endif

#write link statement
  [L]TABLE_COUNTER=0
  For nolign=1 To [M:HREXT1]DTANBR
    If [M:HREXT1]DTALVL(nolign-1)=[L]DATA_LEVEL
      [L]TABLE_COUNTER+=1
      If [L]TABLE_COUNTER=[L]TABLE_COUNTER2
        [L]TRAILING_CHAR=''
      Else
        [L]TRAILING_CHAR=','
      Endif
      If [L]TABLE_COUNTER=1
        If [L]TABLE_COUNTER2=1
          Wrseq '  Filter ['+[M:HREXT1]DTATBLABR(nolign-1)+']'
        Else
          Wrseq '  Link ['+[M:HREXT1]DTATBLABR(nolign-1)+']'
        Endif
      Else
        If [L]TABLE_COUNTER=2
          If [M:HREXT1]DTAORGABR(nolign-1)=""
            Wrseq '&   With '+[M:HREXT1]DTALNKCLC(nolign-1)+[L]TRAILING_CHAR
          Else
            [L]FIELD_SPEC_START=instr(1,[M:HREXT1]DTALNKCLC(nolign-1),[M:HREXT1]DTAORGABR(nolign-1)+"]")
            [L]FIELD_SPEC_END=len([M:HREXT1]DTALNKCLC(nolign-1))-[L]FIELD_SPEC_START+len([M:HREXT1]DTAORGABR(nolign-1))
            [L]TEMP_VAL=left$([M:HREXT1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START-1)+
&                       [M:HREXT1]DTATBLABR(nolign-1)+"]"+
&                       mid$([M:HREXT1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START+len([M:HREXT1]DTAORGABR(nolign-1))+1,[L]FIELD_SPEC_END)
            Wrseq '&   With '+[L]TEMP_VAL+[L]TRAILING_CHAR
          Endif
        Else
          If [M:HREXT1]DTAORGABR(nolign-1)=""
            Wrseq '&        '+[M:HREXT1]DTALNKCLC(nolign-1)+[L]TRAILING_CHAR
          Else
            [L]FIELD_SPEC_START=instr(1,[M:HREXT1]DTALNKCLC(nolign-1),[M:HREXT1]DTAORGABR(nolign-1)+"]")
            [L]FIELD_SPEC_END=len([M:HREXT1]DTALNKCLC(nolign-1))-[L]FIELD_SPEC_START+len([M:HREXT1]DTAORGABR(nolign-1))
            [L]TEMP_VAL=left$([M:HREXT1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START-1)+
&                       [M:HREXT1]DTATBLABR(nolign-1)+"]"+
&                       mid$([M:HREXT1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START+len([M:HREXT1]DTAORGABR(nolign-1))+1,[L]FIELD_SPEC_END)
            Wrseq '&        '+[L]TEMP_VAL+[L]TRAILING_CHAR
          Endif
        Endif
      Endif
    Endif
  Next nolign
  If [L]DATA_LEVEL=1
    Wrseq '&   As    [LNKH]'
  Else
    Wrseq '&   As    [LNKD]'
  Endif
  Wrseq '&   Where evalue([L]CRITERIA(1)+[L]CRITERIA(2)+[L]CRITERIA(3)+[L]CRITERIA(4))'
  For nolign=1 To [M:HREXT3]GRPNBR
    If [M:HREXT3]GRPDTALVL(nolign-1)=[L]DATA_LEVEL
      Wrseq '&   Order By '+[M:HREXT3]GRPORD(nolign-1)
    Endif
  Next nolign

Return

#=============================================================================
$COMPILE_TRT
  If dim(OK)<0 : Local Integer OK : Endif

  Call VALID("TRT","W"+[M:HREXT0]EXRSRCNAM,nomap,OK) From VALMSKSUB
  If OK=0
    GOK=0
    GMESSAGE = mess(35, 11662, 1)
  Endif

Return

$TRTCOP
If [M]DOSORG=nomap
  Local File HREXTRACT    [HREXT1]
  Local File HREXTRACTDAT [HREXD1]
  Local File HREXTRACTDEF [HREXL1]
  Local File HREXTRACTFIL [HREXF1]
  Local File HREXTRACTGRP [HREXG1]
  Local File HREXTRACTPAR [HREXP1]
  Local File HREXTRACTVAL [HREXV1]
Else
  Local File =[M]DOSORG+".HREXTRACT"    [HREXT1]
  Local File =[M]DOSORG+".HREXTRACTDAT" [HREXD1]
  Local File =[M]DOSORG+".HREXTRACTDEF" [HREXL1]
  Local File =[M]DOSORG+".HREXTRACTFIL" [HREXF1]
  Local File =[M]DOSORG+".HREXTRACTGRP" [HREXG1]
  Local File =[M]DOSORG+".HREXTRACTPAR" [HREXP1]
  Local File =[M]DOSORG+".HREXTRACTVAL" [HREXV1]
Endif
If [M]DOSDES=nomap
  Local File HREXTRACT    [HREXT2]
  Local File HREXTRACTDAT [HREXD2]
  Local File HREXTRACTDEF [HREXL2]
  Local File HREXTRACTFIL [HREXF2]
  Local File HREXTRACTGRP [HREXG2]
  Local File HREXTRACTPAR [HREXP2]
  Local File HREXTRACTVAL [HREXV2]
Else
  Local File =[M]DOSDES+".HREXTRACT"    [HREXT2]
  Local File =[M]DOSDES+".HREXTRACTDAT" [HREXD2]
  Local File =[M]DOSDES+".HREXTRACTDEF" [HREXL2]
  Local File =[M]DOSDES+".HREXTRACTFIL" [HREXF2]
  Local File =[M]DOSDES+".HREXTRACTGRP" [HREXG2]
  Local File =[M]DOSDES+".HREXTRACTPAR" [HREXP2]
  Local File =[M]DOSDES+".HREXTRACTVAL" [HREXV2]
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [HREXT1], [HREXD1], [HREXL1], [HREXF1], [HREXG1], [HREXP1], [HREXV1]
Close Local File [HREXT2], [HREXD2], [HREXL2], [HREXF2], [HREXG2], [HREXP2], [HREXV2]

Return

$TR_COP
GOK = 1
Trbegin [HREXT2], [HREXD2], [HREXL2], [HREXF2], [HREXG2], [HREXP2], [HREXV2]

  Delete [HREXT2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACT" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXT2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXD2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTDAT" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXD2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXL2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTDEF" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXL2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXF2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTFIL" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXF2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXG2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTGRP" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXG2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXP2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTPAR" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXP2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [HREXV2] Where EXRTEP=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".HREXTRACTVAL" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("HREXV2","") From GLOCK : Goto AB_TR_COP
  Endif

  For [HREXT1] Where EXRTEP=TABLE
    [F:HREXT2] = [F:HREXT1]
    Write [HREXT2]
    If fstat
      GOK = 0 : Call FSTA("HREXT2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXD1] Where EXRTEP=TABLE
    [F:HREXD2] = [F:HREXD1]
    Write [HREXD2]
    If fstat
      GOK = 0 : Call FSTA("HREXD2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXL1] Where EXRTEP=TABLE
    [F:HREXL2] = [F:HREXL1]
    Write [HREXL2]
    If fstat
      GOK = 0 : Call FSTA("HREXL2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXF1] Where EXRTEP=TABLE
    [F:HREXF2] = [F:HREXF1]
    Write [HREXF2]
    If fstat
      GOK = 0 : Call FSTA("HREXF2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXG1] Where EXRTEP=TABLE
    [F:HREXG2] = [F:HREXG1]
    Write [HREXG2]
    If fstat
      GOK = 0 : Call FSTA("HREXG2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXP1] Where EXRTEP=TABLE
    [F:HREXP2] = [F:HREXP1]
    Write [HREXP2]
    If fstat
      GOK = 0 : Call FSTA("HREXP2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
  For [HREXV1] Where EXRTEP=TABLE
    [F:HREXV2] = [F:HREXV1]
    Write [HREXV2]
    If fstat
      GOK = 0 : Call FSTA("HREXV2") From GLOCK : Break
    Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif

Commit

Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

