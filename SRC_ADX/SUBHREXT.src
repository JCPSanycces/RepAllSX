######################################################################################
Subprog AM_DFNTYP(VALEUR)
Variable Char    VALEUR()

  VALEUR=toupper(VALEUR)
  Case VALEUR
  When "A","N"
  When Default
    VALEUR="A"
  Endcase

End


######################################################################################
#JASMI - 2016-05-26 - REQ 116689 - END

######################################################################################
## Section automatically added (screen HREXT1) 02/07/2017 13:56:51 (JASMI)
######################################################################################
Subprog C_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
If clalev([F:ATB])=0        : Local File AVIEWTAB           [ATB]    : Endif
Local Integer OK , K ,KO
Local Char    ABR(GLONABR) , MESSA(80) , CHP(50)
If VALEUR="" : End : Endif
Gosub OUVFIC_VUE
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
VALEUR = toupper(VALEUR)
OK = 1

Gosub DECODE_LNK From LNKSUB
If ABREV="" or TABLE="" or CLE=""
 If TABLE="" & ABREV<>""
  MESSA = ABREV-":"-mess(124,124,1) : # Table inexistante
 Endif
 Gosub CODE_LNK From LNKSUB
 OK = 0
Elsif STRICT & NBLEC
 OK = 0
Else
 Gosub CODE_LNK From LNKSUB
 For I=1 To NBCHP
  If CHAMP(I)=""
   OK = 0 : Break
  Else
   If left$(CHAMP(I),1)="["
    K = instr(1,CHAMP(I),"]")
    If K
     CHAINE = seg$(CHAMP(I),2,K-1)
     If instr(1,CHAINE,"/")
      ABR = ""
     Else
      If left$(CHAINE,2)="F:"
       ABR = right$(CHAINE,3)
      Else
       ABR = CHAINE
      Endif
      CHP = right$(CHAMP(I),K+1)
#JASMI - START
#      If GFONCTION="GESALH" & dim([M:ALH1]NBLIG)>0
#JASMI - END
       KO = 1
       For II=0 To [M:HREXT1]DTANBR-1
        Read [AVWT]CODFIC = [M:HREXT1]DTATBL(II)
        If [F:AVWT]ABRFIC = ABR
         KO = 0
         Break
        Endif
       Next II
       If KO = 1
        Read [AVWT]ABRFIC = ABR
       Endif
#JASMI - START
#      Else
#       Read [ATB]ABRFIC = ABR
#      Endif
#JASMI - END
      If fstat
       MESSA = ABR-":"-mess(124,124,1) : OK = 0 : Break : # Table inexistante
      Endif
      K = instr(1,CHP,"(")
      If K : CHP = left$(CHP,K-1) : Endif
      Read [AVWF]CODZONE = [F:AVWT]CODFIC;CHP
      If fstat
       MESSA = CHP-":"-mess(41,100,1) : OK = 0 : Break : # Champ inexistant
      Else
       K = 1
       If [F:AVWF]CODACT<>""
        Read [ACV]CODACT=[F:AVWF]CODACT
        If fstat | [F:ACV]FLACT<>2
         K = 0
        Endif
       Endif
       If !K
        MESSA = CHP-":"-[F:AVWF]CODACT-mess(24,176,1) : OK = 0 : Break : # Code activité inactif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Next I
Endif
If !OK
 GMESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 If MESSA<>"" : GMESSAGE += "\"+MESSA : Endif
 mkstat = 2 : End
Endif

End

######################################################################################

$OUVFIC_VUE
 If   filinfo(filpath("FIL","AVIEWTAB","fde"),0)>0
& and filinfo(filpath("FIL","AVIEWFLD","fde"),0)>0
& and filinfo(filpath("FIL","AVIEWIND","fde"),0)>0
  If clalev([F:AVWT])=0 : Local File AVIEWTAB  [AVWT]  : Endif
  If clalev([F:AVWF])=0 : Local File AVIEWFLD [AVWF] : Endif
  If clalev([F:ATI])=0 : Local File AVIEWIND  [ATI]  : Endif
 Endif
Return

