#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXPBAL","EXPBAL",3,"") From GTRAITE
End

############################################################################
## Export balance V150 pour Sage ECF
############################################################################
## AMK    EXPBAL
## AWI    EXPBAL
## ACT    EXPBAL
## TRT    EXPBAL
## AFC    EXPBAL
## ADP    EXPBAL
## AML    877,878
## AST    107
############################################################################

$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return

$INIT
############################################################################
adxium = GASCII
############################################################################
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY    [AGC] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif


Local Mask =[V]GFONCTION [DIA]

Local Integer MAXEXE
MAXEXE = 100

Local Char    SOCIETE(GLONCPY) , DEVISE(GLONCUR) , EXT(5)
Local Char    FILBAL(250) , NAM(250) , FICHIER(GDIMFIC) , CHEMIN(GDIMFIC) , MACHINE(GDIMFIC) , CRITSPE(250)
Local Char    SAVIFS(5) , SAVIRS(5) , SEPENR(5) , SEPCHP(5)
Local Integer MAXPER(1..MAXEXE) , NBREC
Local Decimal EXEDEB , EXEFIN
Local Decimal PERDEB , PERFIN
Local Decimal DEBIT , CREDIT , ANOUV
Local Decimal CPTDEB , CPTCRE , CPTANO
Local Decimal CUMDEB , CUMCRE , CUMANO , CUMANOD , CUMANOC
Local Decimal TOTDEB , TOTCRE , TOTANO
Local Decimal MULTI , MONT
Local Char    TRANS1(250) , TRANS2(250)
Local Char    COMPTE(GLONGAC) , DESIG(GLONAX3)
Local Char    MNT(50) , POINT(1)
Local Integer P
Local Integer K , ER
Local Integer NBSOC , NBPER
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer TBEDEB(1..GNBSOC) , TBEFIN(1..GNBSOC) , TBPDEB(1..GNBSOC) , TBPFIN(1..GNBSOC)
Local Integer TBMPER(1..GNBSOC,1..MAXEXE)
Local Date    TBPER(1..MAXEXE)

# Variables pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT

############################################################################
## Options d'export
############################################################################
SEPCHP = chr$(9)                                : # Séparateur de champ (tab)
SEPENR = chr$(13)+chr$(10)                      : # Séparateur de ligne (CR+LF)
NAM    = "[F:CPY]CPY+num$(year([M:DIA]DATDEB))" : # Nom du fichier
EXT    = "txt"                                  : # Extension du fichier
POINT  = "."                                    : # Point décimal
############################################################################

############################################################################
If GFONCTION <> "EXPBAL" : Gosub INIT From =[V]GFONCTION : Endif
############################################################################

############################################################################
GPOINT = "INIT" : Gosub ENTREE From EXEFNC
############################################################################

TRA = 1
TMP = 1
SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)
[M:DIA]CPY = GDEFSOC
Return

$EXEC
#----------------------  18/03/09 Bug n°53577 ----------------------------
#Vérifications de cohérence entre société renseigné et type de référentiel
#-------------------------------------------------------------------------
Local Char VERFDEV(GLONCUR),DEVLED(GLONCUR),CODLED(GLONLED)
Local Char VERFPLAN(GLONCOA),PLAN
Local Integer REPONSE,OK
VERFDEV=""
VERFPLAN=""
If [M]ALLCPY=2
 For [CPY]CPY0 Where CPYLEGFLG=2
  #Vérif de cohérence devise
  Call LECLED([F:CPY]CPY,[M]LEDTYP,CODLED,DEVLED) From CPTDIV
  If VERFDEV=""
   VERFDEV=DEVLED
  Else
   If VERFDEV<>DEVLED
     GERR=1
     #Toutes les sociétés n'ont pas la même devise pour ce référentiel
     GMESSAGE=mess(179,107,1)
     SAI=1
     Break
   Endif
  Endif
  #Vérif de cohérence plan
  Call LECPLAN([F:CPY]CPY,[M]LEDTYP,PLAN) From CPTDIV
  If VERFPLAN=""
   VERFPLAN=PLAN
  Else
   If VERFPLAN<>PLAN
     GERR=1
     #Toutes les sociétés n'utilisent pas le même plan de compte pour ce type de référentiel
     GMESSAGE=mess(180,107,1)
     SAI=1
     Break
   Endif
  Endif
 Next
Else
 Call GETTYPSOCSITGRP([M]CPY,REPONSE) From CPTDIV
 Case REPONSE
  When 3 :#Groupe de sites
   Filter [FGR] Where CPY=[M]CPY
   For [FGR]FGR0
    Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    #Vérif de cohérence devise
    Call LECLED([F:FCY]LEGCPY,[M]LEDTYP,CODLED,DEVLED) From CPTDIV
    If VERFDEV=""
     VERFDEV=DEVLED
    Else
     If VERFDEV<>DEVLED
       GERR=1
       #Toutes les sociétés n'ont pas la même devise pour ce référentiel
       GMESSAGE=mess(179,107,1)
       SAI=1
       Break
     Endif
    Endif
    #Vérif de cohérence plan
    Call LECPLAN([F:FCY]LEGCPY,[M]LEDTYP,PLAN) From CPTDIV
    If VERFPLAN=""
     VERFPLAN=PLAN
    Else
     If VERFPLAN<>PLAN
      GERR=1
      #Toutes les sociétés n'utilise pas le même plan de compte pour ce type de référentiel
      GMESSAGE=mess(180,107,1)
      SAI=1
      Break
     Endif
    Endif
   Next
   Filter [FGR]
  When 4 :#Groupe de sociétés
    Filter [AGC] Where GRP=[M]CPY
    For [AGC]AGC0
     #Vérif de cohérence devise
     Call LECLED([F:AGC]CPY,[M]LEDTYP,CODLED,DEVLED) From CPTDIV
     If VERFDEV=""
      VERFDEV=DEVLED
     Else
      If VERFDEV<>DEVLED
        GERR=1
        #Toutes les sociétés n'ont pas la même devise pour ce référentiel
        GMESSAGE=mess(179,107,1)
        SAI=1
        Break
      Endif
     Endif
     #Vérif de cohérence plan
     Call LECPLAN([F:AGC]CPY,[M]LEDTYP,PLAN) From CPTDIV
     If VERFPLAN=""
      VERFPLAN=PLAN
     Else
      If VERFPLAN<>PLAN
        GERR=1
        #Toutes les sociétés n'utilise pas le même plan de compte pour ce type de référentiel
        GMESSAGE=mess(180,107,1)
        SAI=1
        Break
      Endif
     Endif
    Next
    Filter [AGC]
 Endcase
Endif
If SAI : Return : Endif
#----- Fin Vérif cohérence -----

Call OUVRE_TRACE(mess(106,107,1)) From LECFIC : # Exportation balance
Call INITRANS(TRANS1,TRANS2,[M:DIA]CNV) From SUBEXPOBJ
If [M:DIA]ALLCPY=2
 For [CPY]CPY0 Where CPYLEGFLG=2
  SOCIETE = [F:CPY]CPY : Gosub SOCIETE
  If FIN : Break : Endif
 Next
Else
 SOCIETE = [M:DIA]CPY
 Read [CPY]CPY0 = SOCIETE
 Gosub SOCIETE
Endif
Call FERME_TRACE From LECFIC
adxifs = SAVIFS
adxirs = SAVIRS
Return

$SOCIETE
Call ECR_TRACE(mess(2,116,1)-SOCIETE-[F:CPY]CPYNAM,0) From GESECRAN : # Société
Gosub VERIF
If ER : Goto FINSOC : Endif
FICHIER = [M:DIA]FIC
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = evalue(NAM)
If [M]TYPEXP=1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
Endif
Read [GCM]GCM0 = [F:CPY]ACM
DEVISE = [F:GCM]CUR([M:DIA]LEDTYP-1)
Read [TCU]TCU0 = DEVISE
If [M:DIA]CTS=2
 MULTI = 10^[F:TCU]DECNBR
Else
 MULTI = 1
Endif
Openo FICDON,0
If GFONCTION <> "EXPBAL" :  Gosub EXPORT_HEADER From =[V]GFONCTION : Endif
Openo
If [F:CPY]CPYLEGFLG=2
 Gosub JURIDIQUE
Else
 Gosub GROUPE
Endif
If [M:DIA]TYPEXP=1
 Call ECR_TRACE(mess(178,115,1)+"     "+num$(NBREC)-mess(82,141,1),0) From GESECRAN
Else
 Call ECR_TRACE("|"+mess(14,9003,1)-[M:DIA]VOLFIL+"     "+num$(NBREC)-mess(82,141,1),0) From GESECRAN #<YYFIN_93938_US351>
Endif
# fichier....lignes exportées
If TOTDEB<>TOTCRE or (TOTANO<>0 & [M:DIA]ANO=2)
 Call ECR_TRACE(mess(64,116,1)-num$(TOTDEB)-num$(TOTCRE)-DEVISE-"("+num$(TOTANO)+")",1) From GESECRAN
# Balance déséquilibrée
Else
 Call ECR_TRACE(mess(65,116,1)-num$(TOTDEB)-DEVISE,0) From GESECRAN : # Total balance
Endif

$FINSOC
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Openo
If !ER & [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : TRA = 0 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : TRA = 0 : Return
 Endif
Endif
Return

$VERIF
ER = 0
If [F:CPY]CPYLEGFLG=2
 Raz EXEDEB,EXEFIN,PERDEB,PERFIN
 Call GETPERSOC(SOCIETE,[M:DIA]LEDTYP,[M:DIA]DATDEB,EXEDEB,PERDEB) From CPTSUB
 Call GETPERSOC(SOCIETE,[M:DIA]LEDTYP,[M:DIA]DATFIN,EXEFIN,PERFIN) From CPTSUB
 If EXEDEB=0 or EXEFIN=0 or PERDEB=0 or PERFIN=0
  Call ECR_TRACE(mess(107,107,1),1) From GESECRAN : # Exercices non définis sur cette période
  ER = 1 : Return
 Endif
 If EXEDEB>1 & [M:DIA]ANO=2
  Read [FIY]FIY0 = SOCIETE;[M:DIA]LEDTYP;EXEDEB-1
  If fstat or [F:FIY]FIYSTA<3
   Call ECR_TRACE(mess(108,107,1)-":"-format$("D:"+GFMDAT4,[F:FIY]FIYSTR)-"-"-format$("D:"+GFMDAT4,[F:FIY]FIYEND)
&   +"\"+mess(109,107,1),1) From GESECRAN
 # Exercice non clôturé
 # Les à-nouveaux risquent d'être erronés
  Endif
 Endif
 Raz MAXPER
 For [PER]PER0 Where CPY=SOCIETE & LEDTYP=[M:DIA]LEDTYP & FIYNUM>=EXEDEB & FIYNUM<=EXEFIN
  MAXPER([F:PER]FIYNUM) += 1
 Next
 If [M:DIA]CLO=2 & PERFIN=MAXPER(EXEFIN)
  PERFIN = dim([F:BAL]DEB)-1
 Endif
Else
 NBSOC = 0
 Raz TBMPER
 For [FGR]FGR0 Where CPY=SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
   Read [CPY]CPY0 = [F:FCY]LEGCPY
   Raz EXEDEB,EXEFIN,PERDEB,PERFIN
   Call GETPERSOC([F:CPY]CPY,[M:DIA]LEDTYP,[M:DIA]DATDEB,EXEDEB,PERDEB) From CPTSUB
   Call GETPERSOC([F:CPY]CPY,[M:DIA]LEDTYP,[M:DIA]DATFIN,EXEFIN,PERFIN) From CPTSUB
   If EXEDEB=0 or EXEFIN=0 or PERDEB=0 or PERFIN=0
    Call ECR_TRACE([F:CPY]CPY-":"-mess(107,107,1),1) From GESECRAN : # Exercices non définis sur cette période
    ER = 1 : Break
   Endif
   NBSOC += 1
   TBSOC(NBSOC)  = [F:CPY]CPY
   TBEDEB(NBSOC) = EXEDEB
   TBEFIN(NBSOC) = EXEFIN
   TBPDEB(NBSOC) = PERDEB
   TBPFIN(NBSOC) = PERFIN
   If NBSOC=1
    NBPER = 0
    For [PER]PER0 Where CPY=[F:CPY]CPY & LEDTYP=[M:DIA]LEDTYP & FIYNUM>=EXEDEB & FIYNUM<=EXEFIN
     NBPER += 1
     TBPER(NBPER) = [F:PER]PERSTR
     TBMPER(NBSOC,[F:PER]FIYNUM) += 1
    Next
   Else
    K = 0
    For [PER]PER0 Where CPY=[F:CPY]CPY & LEDTYP=[M:DIA]LEDTYP & PERSTR>=TBPER(1) & PERSTR<=TBPER(NBPER)
     K += 1
     If [F:PER]PERSTR<>TBPER(K) : ER = 1 : Break : Endif
     TBMPER(NBSOC,[F:PER]FIYNUM) += 1
    Next
    If ER or K<>NBPER
     Call ECR_TRACE(mess(11,101,1)-[F:CPY]CPY,1) From GESECRAN : # Périodes incompatibles sur la société
     ER = 1 : Break
    Endif
   Endif
  Endif
 Next
 If ER : Return : Endif
 If [M:DIA]CLO=2
  For ISOC=1 To NBSOC
   If TBPFIN(ISOC)=TBMPER(ISOC,TBEFIN(ISOC))
    TBPFIN(ISOC) = dim([F:BAL]DEB)-1
   Endif
  Next ISOC
 Endif
Endif
Read [CPY]CPY0 = SOCIETE
Return

########################################################################
## Société juridique
########################################################################
$JURIDIQUE
FILBAL  = 'LEDTYP='+num$([M:DIA]LEDTYP)
FILBAL -= '& CPY="'+SOCIETE+'"'
FILBAL -= '& FCY=""'
If EXEDEB=EXEFIN
 FILBAL -= '& FIY='+num$(EXEDEB)
Else
 FILBAL -= '& FIY>='+num$(EXEDEB)+' & FIY<='+num$(EXEFIN)
Endif
If [M:DIA]OPT=1 : # Solde des collectifs
 FILBAL -= '& BPR=""'
Endif

Gosub POINT_ENTREE

Read [LED]LED0 = [F:GCM]LED([M:DIA]LEDTYP-1)
Read [COA]COA0 = [F:LED]COA

Raz TOTDEB,TOTCRE,TOTANO,NBREC

Link [BAL] With [LED]LED0=[F:BAL]LED As [LBAL]
& Where evalue(FILBAL) & evalue([L]CRITSPE)
& Order By Key CLE=ACC;BPR

For [LBAL]CLE(1)
 Raz DEBIT,CREDIT,ANOUV
 Read [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC
 Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
 If ([F:GAC]CLSCOD<>"" & [F:CLS]TYP<>2) or [M:DIA]HBI=2
  If [F:GAC]SAC<>2 or [M:DIA]OPT=1
   For [LBAL]CLE
    Gosub CUMUL
   Next
   CPTDEB = DEBIT
   CPTCRE = CREDIT
   CPTANO = ANOUV
   COMPTE = [F:BAL]ACC
   Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   Gosub EXPORT
   TOTDEB += CPTDEB
   TOTCRE += CPTCRE
   TOTANO += CPTANO
  Else
   Raz CUMDEB,CUMCRE,CUMANOD,CUMANOC
   For [LBAL]CLE(2)
    Raz DEBIT,CREDIT,ANOUV
    For [LBAL]CLE
     If [F:BAL]BPR<>""
      Gosub CUMUL
     Endif
    Next
    If ANOUV+DEBIT-CREDIT>0
     CUMDEB  += DEBIT-CREDIT
     CUMANOD += ANOUV
    Else
     CUMCRE  += CREDIT-DEBIT
     CUMANOC += ANOUV
    Endif
   Next
   If CUMDEB<>0 or CUMANOD<>0
    COMPTE = [F:BAL]ACC+"D"
    Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    CPTDEB = CUMDEB
    CPTCRE = 0
    CPTANO = CUMANOD
    Gosub EXPORT
   Endif
   If CUMCRE<>0 or CUMANOC<>0
    COMPTE = [F:BAL]ACC+"C"
    Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    CPTDEB = 0
    CPTCRE = CUMCRE
    CPTANO = CUMANOC
    Gosub EXPORT
   Endif
   TOTDEB += CUMDEB
   TOTCRE += CUMCRE
   TOTANO += CUMANOD+CUMANOC
  Endif
 Endif
Next
Return

$POINT_ENTREE
## Demande PE 21634
Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif
Return

########################################################################
## Société non juridique
########################################################################
$GROUPE
FILBAL  = 'LEDTYP='+num$([M:DIA]LEDTYP)
FILBAL -= '& [F:FGR]CPY="'+SOCIETE+'"'
FILBAL -= '& [F:BAL]FCY<>""'
FILBAL -= '& [F:FIY]FIYSTR<['+format$(GFMD,[M:DIA]DATFIN)+"]"
FILBAL -= '& [F:FIY]FIYEND>['+format$(GFMD,[M:DIA]DATDEB)+"]"
If [M:DIA]OPT=1 : # Solde des collectifs
 FILBAL -= '& [F:BAL]BPR=""'
Endif

Gosub POINT_ENTREE

Link [BAL] With [FGR]FGR0=SOCIETE;[F:BAL]FCY , [FIY]FIY0=[F:BAL]CPY;[F:BAL]LEDTYP;[F:BAL]FIY As [LBAL]
& Where evalue(FILBAL) & evalue([L]CRITSPE)
& Order By Key CLE=ACC;BPR;FCY;FIY
Raz TOTDEB,TOTCRE,TOTANO,NBREC
For [LBAL]CLE(1)
 Raz DEBIT,CREDIT,ANOUV
 Read [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC
 Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
 Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
 If ([F:GAC]CLSCOD<>"" & [F:CLS]TYP<>2) or [M:DIA]HBI=2
  If [F:GAC]SAC<>2 or [M:DIA]OPT=1
   For [LBAL]CLE
    Gosub CUMGRP
   Next
   CPTDEB = DEBIT
   CPTCRE = CREDIT
   CPTANO = ANOUV
   COMPTE = [F:BAL]ACC
   Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   Gosub EXPORT
   TOTDEB += CPTDEB
   TOTCRE += CPTCRE
   TOTANO += CPTANO
  Else
   Raz CUMDEB,CUMCRE,CUMANOD,CUMANOC
   For [LBAL]CLE(2)
    Raz DEBIT,CREDIT,ANOUV
    For [LBAL]CLE
     If [F:BAL]BPR<>""
      Gosub CUMGRP
     Endif
    Next
    If ANOUV+DEBIT-CREDIT>0
     CUMDEB  += DEBIT-CREDIT
     CUMANOD += ANOUV
    Else
     CUMCRE  += CREDIT-DEBIT
     CUMANOC += ANOUV
    Endif
   Next
   If CUMDEB<>0 or CUMANOD<>0
    COMPTE = [F:BAL]ACC+"D"
    Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    CPTDEB = CUMDEB
    CPTCRE = 0
    CPTANO = CUMANOD
    Gosub EXPORT
   Endif
   If CUMCRE<>0 or CUMANOC<>0
    COMPTE = [F:BAL]ACC+"C"
    Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    CPTDEB = 0
    CPTCRE = CUMCRE
    CPTANO = CUMANOC
    Gosub EXPORT
   Endif
   TOTDEB += CUMDEB
   TOTCRE += CUMCRE
   TOTANO += CUMANOD+CUMANOC
  Endif
 Endif
Next
Return

########################################################################
## Export d'un compte
########################################################################
$EXPORT
If CPTDEB<>0 or CPTCRE<>0 or (CPTANO<>0 & [M:DIA]ANO=2)
 NBREC += 1
 adxifs = SEPCHP
 adxirs = SEPENR
 Openo FICDON,-1
 If GFONCTION <> "EXPBAL"
  Gosub EXPORT From =[V]GFONCTION
 Else
  Wrseq ctrans(COMPTE,TRANS1,TRANS2);
  Wrseq ctrans(DESIG,TRANS1,TRANS2);
  MONT = CPTDEB : Gosub MONTANT
  MONT = CPTCRE : Gosub MONTANT
  If [M:DIA]ANO=2
   MONT = CPTANO : Gosub MONTANT
  Else
   MONT = 0      : Gosub MONTANT
  Endif
  Wrseq
 Endif
Openo
 adxifs = ""
 adxirs = chr$(10)
Endif
Return

$MONTANT
MNT = num$(MULTI*MONT)
If POINT<>"."
 P = instr(1,MNT,".")
 If P
  MNT = left$(MNT,P-1)+POINT+right$(MNT,P+1)
 Endif
Endif
Wrseq MNT;
Return

########################################################################
## Cumul balance
########################################################################
$CUMUL
If EXEDEB=EXEFIN
 DEBIT  += sum([F:BAL]DEBLED(PERDEB..PERFIN))
 CREDIT += sum([F:BAL]CDTLED(PERDEB..PERFIN))
 ANOUV  += sum([F:BAL]DEBLED(0..PERDEB-1))-sum([F:BAL]CDTLED(0..PERDEB-1))
Elsif [F:BAL]FIY=EXEDEB
 DEBIT  += sum([F:BAL]DEBLED(PERDEB..MAXPER([F:BAL]FIY)))
 CREDIT += sum([F:BAL]CDTLED(PERDEB..MAXPER([F:BAL]FIY)))
 ANOUV  += sum([F:BAL]DEBLED(0..PERDEB-1))-sum([F:BAL]CDTLED(0..PERDEB-1))
Elsif [F:BAL]FIY=EXEFIN
 DEBIT  += sum([F:BAL]DEBLED(1..PERFIN))
 CREDIT += sum([F:BAL]CDTLED(1..PERFIN))
Else
 DEBIT  += sum([F:BAL]DEBLED(1..MAXPER([F:BAL]FIY)))
 CREDIT += sum([F:BAL]CDTLED(1..MAXPER([F:BAL]FIY)))
Endif
Return

$CUMGRP
ISOC = find([F:BAL]CPY,TBSOC(1..NBSOC))
If !ISOC : Return : Endif
If TBEDEB(ISOC)=TBEFIN(ISOC)
 DEBIT  += sum([F:BAL]DEBLED(TBPDEB(ISOC)..TBPFIN(ISOC)))
 CREDIT += sum([F:BAL]CDTLED(TBPDEB(ISOC)..TBPFIN(ISOC)))
 ANOUV  += sum([F:BAL]DEBLED(0..TBPDEB(ISOC)-1))-sum([F:BAL]CDTLED(0..TBPDEB(ISOC)-1))
Elsif [F:BAL]FIY=TBEDEB(ISOC)
 DEBIT  += sum([F:BAL]DEBLED(TBPDEB(ISOC)..TBMPER(ISOC,[F:BAL]FIY)))
 CREDIT += sum([F:BAL]CDTLED(TBPDEB(ISOC)..TBMPER(ISOC,[F:BAL]FIY)))
 ANOUV  += sum([F:BAL]DEBLED(0..TBPDEB(ISOC)-1))-sum([F:BAL]CDTLED(0..TBPDEB(ISOC)-1))
Elsif [F:BAL]FIY=TBEFIN(ISOC)
 DEBIT  += sum([F:BAL]DEBLED(1..TBPFIN(ISOC)))
 CREDIT += sum([F:BAL]CDTLED(1..TBPFIN(ISOC)))
Else
 DEBIT  += sum([F:BAL]DEBLED(1..TBMPER(ISOC,[F:BAL]FIY)))
 CREDIT += sum([F:BAL]CDTLED(1..TBMPER(ISOC,[F:BAL]FIY)))
Endif
Return

################################################
## Ecran EXPBAL
################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo ALLCPY
 Actzo CPY
 mkstat = 1 : End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY
 Grizo CPY
Else
 Actzo CPY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=1 : # # Référentiels flagués 'Général'
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
If [M]ALLCPY<>2
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2
  Local Decimal EXERCICE , PERIODE
  Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EXERCICE,PERIODE) From CPTSUB
  If EXERCICE=0 or PERIODE=0
   GMESSAGE = mess(1,104,1) : # Date incorrecte
   mkstat = 2 : End
  Else
   VALEUR = [F:PER]PERSTR
  Endif
 Endif
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If [M]ALLCPY<>2
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2
  Local Decimal EXERCICE , PERIODE
  Call GETPERSOC([M]CPY,[M]LEDTYP,VALEUR,EXERCICE,PERIODE) From CPTSUB
  If EXERCICE=0 or PERIODE=0
   GMESSAGE = mess(1,104,1) : # Date incorrecte
   mkstat = 2 : End
  Else
   VALEUR = [F:PER]PEREND
  Endif
 Else
  #Groupe de soc ou sit
  Local Integer STAT
  Local Char MESSA(250)
  #Vérif cohérence période
  Call CNTCOHPER([M]CPY,[M]LEDTYP,[M]DATDEB,VALEUR,STAT,MESSA) From CPTCNT
  If !STAT
   # Périodes incompatibles entre les sociétés du groupe
   Call MESSAGE(MESSA) From GESECRAN
   zonsui = "[M]CPY"
   mkstat = 0 : End
  Endif
 Endif
Else
 #Tte soc
 #----------------------
 #Vérif cohérence période
 Local Integer OKPER
 Local Integer NBSOC, NBPER
 # GH 02/02/00 bug 4189
 NBSOC = max(1,GNBSOC)
 Local Char TSOC(GLONCPY)(1..NBSOC) : # Table des sociétés juridiques des sites du groupement
 NBSOC = 0
 Local Date TDATDEB(1..999)
 Local Decimal EXERCICE, PERIODE, EDEB, EFIN
 OKPER = 1
 If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
 If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
 If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
 If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
 For [CPY]CPY0 Where CPYLEGFLG=2
  NBPER=0
  NBSOC += 1 : TSOC(NBSOC)=[F:CPY]CPY
  Call GETPERSOC(TSOC(NBSOC),[M]LEDTYP,[M]DATDEB,EXERCICE,PERIODE) From CPTSUB
  EDEB = EXERCICE
  Call GETPERSOC(TSOC(NBSOC),[M]LEDTYP,VALEUR,EXERCICE,PERIODE) From CPTSUB
  EFIN = EXERCICE
  If EFIN=0
   Filter [FIY] Where CPY=TSOC(NBSOC)
   Read [FIY]FIY0 Last
   Filter [FIY]
   If fstat<=2 & DATFIN>[F:FIY]FIYEND : EFIN=[F:FIY]FIYNUM : Endif
  Endif
  For EXERCICE=EDEB To EFIN
   For [PER]PER0 Where CPY=TSOC(NBSOC) & FIYNUM=EXERCICE
    NBPER += 1
    If NBSOC=1
     TDATDEB(NBPER) = [F:PER]PERSTR
    Elsif TDATDEB(NBPER)<>[F:PER]PERSTR
     # Les périodes ne sont pas les mêmes
     OKPER = 0 : Break 3
    Endif
   Next
  Next
 Next : # [FGR]
 If !OKPER
  # Périodes incompatibles
  Call MESSAGE(mess(61,101,1)) From GESECRAN
  zonsui = "[M]ALLCPY"
  mkstat = 0 : End
 Endif
 #----------------------
Endif
End

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
Local Char NOMFIC(GDIMFIC)
Raz [M]
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 Call PARAM("",GFONCTION,NOMFIC) From ADOVAL
 If NOMFIC<>"" & left$(NOMFIC,1)="["
  [M]VOLFIL = NOMFIC
 Else
  [M]VOLFIL = "[TMP]"
 Endif
Endif
Actzo [M]VOLFIL
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else Raz [M]VOLFIL : Grizo [M]VOLFIL : Affzo [M]VOLFIL
 Endif
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

###############################################################################
##  Contrôle en saisie du paramètre EXPBAL
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End

