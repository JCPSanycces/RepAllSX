#<AdxTL>@(#)0.0.0.0 $Revision$
# Class AQCU1011

$EVENTS
Local Char TMP_ACTION: TMP_ACTION="EVENTS"
Gosub AEVENT_ACTION
Case [L]CURPTH
   When ""
    Case [L]AEVENT
    Endcase
Endcase
Return

$METHODS
Local Char TMP_ACTION: TMP_ACTION="METHODS"
Gosub AMETHOD_ACTION
If [L]AMETHOD<>AVOID.ACHAR           # Temporary until U11 - where only class methods are called due to "When Default" on Case statement
  Case [L]AMETHOD
  Endcase
Endif
Return

$OPERATIONS
Local Char TMP_ACTION: TMP_ACTION="OPERATIONS"
Gosub AOPERATION_ACTION
Case [L]AOPERATION
Endcase
Return


$PROPERTIES
#Gosub PROPERTY_ACTION
Case [L]CURPRO
Endcase
Return

$AEVENT_ACTION
If dim([L]AMETHOD)<=0 Local Char AMETHOD : Endif
If dim([L]ARULE)<=0 Local Char ARULE : Endif
If dim([L]AOPERATION)<=0 Local Char AOPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]ACTION)<=0 Local Char ACTION : Endif
[L]ASTATUS = fmet this.ASETERROR(ACTION, "U10 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] AEVENT=["
& +AEVENT+"] AMETHOD=["+[L]AMETHOD+"] AOPERATION=["+[L]AOPERATION+"]",[V]CST_AINFO)
  #[L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [EVENTS] Action "+"CURPTH=["+CURPTH+"] ACTION=["+ACTION+"]",[V]CST_AINFO)
Return

$AMETHOD_ACTION
If dim([L]AMETHOD)<=0 Local Char AMETHOD : Endif
If dim([L]ARULE)<=0 Local Char ARULE : Endif
If dim([L]AOPERATION)<=0 Local Char AOPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]AEVENT)<=0 Local Char AEVENT : Endif
If [L]AMETHOD=AVOID.ACHAR
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "U9 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
&     +ACTION+"] AMETHOD=["+[L]AMETHOD+"] AOPERATION=[]",[V]CST_AINFO)
Else
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "U9 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
&     +ACTION+"] AMETHOD=[] AOPERATION=[]",[V]CST_AINFO)
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "U10 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] AEVENT=["
&     +AEVENT+"] AMETHOD=["+[L]AMETHOD+"] AOPERATION=["+[L]AOPERATION+"]",[V]CST_AINFO)
Endif
#  [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [METHODS] Action "+"METH=["+[L]METH+"]",[V]CST_AINFO)
 # [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [METHODS] Action "+"CURPTH=["+CURPTH+"] ACTION=["+ACTION+"]",[V]CST_AINFO)
Return

$AOPERATION_ACTION
If dim([L]AMETHOD)<=0 Local Char AMETHOD : Endif
If dim([L]ARULE)<=0 Local Char ARULE : Endif
If dim([L]AOPERATION)<=0 Local Char AOPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]ACTION)<=0 Local Char ACTION : Endif
[L]ASTATUS = fmet this.ASETERROR(ACTION, "U10 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] AEVENT=["
& +AEVENT+"] AMETHOD=["+[L]AMETHOD+"] AOPERATION=["+[L]AOPERATION+"]",[V]CST_AINFO)
#  [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [OPERATION] Action "+"OPERATION=["+[L]OPERATION+"]",[V]CST_AINFO)
Return

$PROPERTY_ACTION
Local Integer MY_STATUS
If ! (ACTION ="PROPAGATE" and find(CURPRO,"UPDDATTIM","UPDUSR"))
 MY_STATUS = fmet this.ASETERROR("PROPERTY_ACTION", "Property Action Execute "+"CURPRO=["+CURPRO+"] ACTION=["+ACTION+"]",[V]CST_AINFO)
Endif
Return

