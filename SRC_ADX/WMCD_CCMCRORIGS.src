# Superviseur
## CRUD-CLASSE ## CCMCRORIGS
# 2018-10-19 07:50:19 581


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGS

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_CCMCRORIGS

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGS
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_CCMCRORIGS
Else
 Gosub ADELETE_CCMCRORIGS
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(CCMCRORIGS,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If CCMCRORIGS.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGS.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_CCMCRORIGS
Trbegin [F:CCMCROS]
 Gosub ADELETE_CCMCRORIGS
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_CCMCRORIGS
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(CCMCRORIGS,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGS._MAJSQL_CCMCRORIGS(CCMCRORIGS))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If CCMCRORIGS.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGS.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGS.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



