$ON_SPAOPE340
Onevent INIT_AREA Call D_SPAOPE340(zc) From W1TVBLEGSPA
Onevent CONTROL Call C_SPAOPE340(zc) From W1TVBLEGSPA
Onevent BEFORE_INPUT Call AS_SPAOPE340(zc) From W1TVBLEGSPA
Onevent AFTER_CHANGE Gosub AMM_SPAOPE340 From W1TVBLEGSPA
Return

Subprog D_SPAOPE340(VALEUR)
Variable Char    VALEUR()
If varinit([M]SPAOPE340,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"393","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SPAOPE340(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"393") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SPAOPE340(zc) From W1TVBLEGSPA
Onkey   2 Titled GBOUTS Call S_SPAOPE340(zc) From W1TVBLEGSPA
Onkey 144 Titled GBOUTP Call P_SPAOPE340(zc) From W1TVBLEGSPA
Onkey 146 Titled GBOUTA Call SA_SPAOPE340(zc) From W1TVBLEGSPA
Gosub _AFF
End

Subprog C_SPAOPE340(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"393","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SPAOPE340" : GZNUM = 48685 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"393",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SPAOPE340" : GZNUM = 48685 : Endif
Endif
Gosub _AFF
End

$AMM_SPAOPE340
Call AM_SPAOPE340(zc)
If !mkstat & GOBJET
 zoncou = "SPAOPE340" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SPAOPE340(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSPAOPE340)")>indice
 [M]SPAOPE340(indice) = VALEUR
 Affzo ZSPAOPE340(indice)
Endif
Gosub _AFF
End

Subprog S_SPAOPE340(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "393"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SPAOPE340(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"393") From GOBJET
Gosub _AFF
End

Subprog SA_SPAOPE340(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "393"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SPAOPE340(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "393"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSPAOPE340
Onevent BEFORE_AREA Gosub AV_ZSPAOPE340 From W1TVBLEGSPA
Return

$AV_ZSPAOPE340
Call LECTEXTRA(zc,"ATABDIV","LNGDES","393",num$([M]SPAOPE340(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


