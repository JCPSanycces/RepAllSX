#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TVBLEGSPA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:56"
A_USER  = "DOC"
A_STAMP = "20181109230656"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TVBLEGSPA [TVBSPA]
Gosub HORODAT
Local Inpbox "TVBLEGSPA" From GFONCTION At A_STAMP With A_WINDPREV Mask [TVBSPA] As [SIM_]
Grizo [TVBSPA]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TVBSPA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=37 : X2(0)=76 : Y1(0)=9 : Y2(0)=20
Return

$ON_SPAJOUDCL
Onevent INIT_AREA Call D_SPAJOUDCL(zc) From W1TVBLEGSPA
Onevent BEFORE_INPUT Call AS_SPAJOUDCL(zc) From W1TVBLEGSPA
Return

Subprog D_SPAJOUDCL(VALEUR)
Variable Integer VALEUR
If varinit([M]SPAJOUDCL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SPAJOUDCL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

