#<AdxTL>@(#)0.0.0.0 $Revision$ 
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"                      : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$AREAD_AFTER
Local Integer READSTATUS
Local Integer NI

If this.PASDET <> null
  For NI = 1 To maxtab(this.PASDET)
    If this.PASDET(NI) <> null and find(this.PASDET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      this.PASDET(NI).TCH_NUMLIG = NI
      this.PASDET(NI).TCH_PASSTA = "T"
    Endif
  Next
Endif

If func ESSPASDET_CSTD_EVT.ASSIGNESSUIDPAS(this) = [V]CST_AERROR
  ASTATUS=fmet this.ASETERROR("","UID Assignment error",[V]CST_AERROR)
Endif

Return


#**
#* Check and assign unique ESS ID to the record for passport details - EMPLOID
#* @param ESSPASDET Variable class instance (ESSPASDET)
#* @return ESS_UPDATE Local Integer - Default [V]CST_AOK
#*!
Funprog ASSIGNESSUIDPAS(V_ESSPASDET)
Variable Instance V_ESSPASDET Using C_ESSPASDET
Local Integer ESS_UPDATE_NEWREC,ESS_UPDATE
Local Integer K, NEW_ESSUID

Local File EMPLOID      [ID4]
Local File EMPLOID      [ID5]
Local File EMPLOIDSA    [ESA6] #FRLAA X3-96827 2018-08-02

ESS_UPDATE_NEWREC = [V]CST_AOK
ESS_UPDATE        = [V]CST_AOK

If V_ESSPASDET.PASDET <> null
  For K = 1 To maxtab(V_ESSPASDET.PASDET)
    If V_ESSPASDET.PASDET(K) <> null
      If V_ESSPASDET.PASDET(K).ESSUIDPAS = 0
        ESS_UPDATE_NEWREC = [V]CST_ANEW
        NEW_ESSUID = uniqid([F:ID5])
        V_ESSPASDET.PASDET(K).ESSUIDPAS = NEW_ESSUID

        #Update existing records only - New records will be updated after approval
        If V_ESSPASDET.PASDET(K).TCH_PASSTA = "T"
          Update [F:ID5] Where REFNUM = V_ESSPASDET.REFNUM  With ESSUIDPAS(K-1) = NEW_ESSUID
          Update [F:ESA6] Where REFNUM = V_ESSPASDET.REFNUM  With ESSUIDPAS(K-1) = NEW_ESSUID #FRLAA X3-96827 2018-08-02
        Endif
        If fstat <> [V]CST_AOK
          ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
          Break
        Endif
      Endif
    Endif
  Next K
Endif
End ESS_UPDATE




