#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque SRE6
##########################################################################################################
Subprog AS_NBADR
If nolign >= dim([M:SRE6]CODADR)
    End
Endif

If nolign > 0
    If GPRESRE6NOL <> nolign - 1
        Gosub AS_C_NBADR
    Endif
Endif

Affzo [M:SRE6]1-99
End

##########################################################################################################
Subprog C_NBADR
If nolign >= dim([M:SRE6]CODADR)
    End
Endif

If nolign > 0
    If GPRESRE6NOL <> nolign - 1
        Gosub AS_C_NBADR
    Endif
Endif

Affzo [M:SRE6]1-99
End

##########################################################################################################
$AS_C_NBADR
[M:SRE6]NBADRSEL(GPRESRE6NOL) = ""
[M:SRE6]NBADRSEL(nolign - 1) = "->"
[M:SRE6]CURBPAADD = [M:SRE6]CODADR(nolign - 1)

Call SETCURADD(1, GSZSRE6BPC, [M:SRE6]CURBPAADD) From TRTSRE6

GPRESRE6NOL = nolign - 1
Return

##########################################################################################################
Subprog IB_NBADR

Raz GBOUT1
Raz GBOUT2
If type(GSZMST9POPUP) > 0
    GBOUT1 = GSZMST9POPUP
Endif
If type(GSZMACAPOPUP) > 0
    GBOUT2 = GSZMACAPOPUP
Endif

End



