#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# UUMGINISAL06   Moulinette de Migration des livraisons      Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Validation des masques SDH et ouverture                                  #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail devis : SDELIVERYD                                                #
# --------------------------                                               #
# Alim. STOFCY à partir de l'entête si différence                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGINISAL06") From LECFIC
  Endif
  #Call RAZ_UUMGINISAL06(DOSSIER)
  Call MAJ_UUMGINISAL06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


##########################################################################
Subprog MAJ_UUMGINISAL06(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer TOTNBR
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION

Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSDHM,WNAMSDDM
Call MIGTABNAME (DOSSIER,"SDELIVERY",WNAMSDHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SDELIVERYD",WNAMSDDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

If filinfo(filpath("FIL",WNAMSDHM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSDDM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGINISAL06 Sales Delivery Process : Update SDELIVERYD") From DOSSUB
Call ECR_TRACE("UUMGINISAL06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG

#----- SDELIVERY => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"SDELIVERY",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGINISAL06",TOTNBR,ERR) From TRTMIG
Commit

#----- Ouverture des fichiers -----#
If clalev([F:SDHM]) = 0 : Local File =DOSSIER+"."+WNAMSDHM   [SDHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SDDM]) = 0 : Local File =DOSSIER+"."+WNAMSDDM   [SDDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NBLUS, NBCOMMIT
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBCOMMIT

# Issue 106947 - 20150811 by LD : Migration of historic folder
# Passage en V6
If VERSION<GMIGX3VER60
    Gosub OUVRE_SAL06
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
Endif
# Issue 106947 - 20150811 by LD

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGINISAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG

If NBCOMMIT=0
  #----- Suppression des incohérences entre tables avant migration -----#
  Gosub TRT_SQL
  If GOK<1 : Goto FIN : Endif
  Trbegin [AMY]
  NBLUS=TOTNBR
  NBCOMMIT=TOTNBR
  Call MIGSTKKEY (DOSSIER,"UUMGINISAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
  Commit
Endif

$FIN
Close Local File [SDDM], [SDHM]

Call ECR_TIME("UUMGINISAL06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

Call MIGTRTEND (DOSSIER,"UUMGINISAL06") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGINISAL06(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Local Char WNAMSDHM,WNAMSDDM
Call MIGTABNAME (DOSSIER,"SDELIVERY",WNAMSDHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SDELIVERYD",WNAMSDDM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSDHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSDDM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGINISAL06",ERR) From TRTMIG

End
##############################################################################################
$OUVRE_SAL06

# Validation des écrans

# Issue 106947 - 20150811 by LD : Migration of historic folder
Local Char WHISTFOLD(GLONADS)
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    WHISTFOLD=[F:ADS]DOSSIER
Else
    WHISTFOLD=[F:ADS]DOSREF
Endif

#Call VALIDDIRECT ("SDH0",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH1",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH2",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH3",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SFITRF",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Local Mask =DOSSIER+".SDH0"    [SDH0]
#Local Mask =DOSSIER+".SDH1"    [SDH1]
#Local Mask =DOSSIER+".SDH2"    [SDH2]
#Local Mask =DOSSIER+".SDH3"    [SDH3]
#Local Mask =DOSSIER+".SFITRF"  [SFIT]
#Local Mask =DOSSIER+".SFITRF"  [SFI2]

Call VALIDDIRECT ("SDH0",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
If GOK<>1
  Return
Endif
Call VALIDDIRECT ("SDH1",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
If GOK<>1
  Return
Endif
Call VALIDDIRECT ("SDH2",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
If GOK<>1
  Return
Endif
Call VALIDDIRECT ("SDH3",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
If GOK<>1
  Return
Endif
Call VALIDDIRECT ("SFITRF",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
If GOK<>1
  Return
Endif
Local Mask =WHISTFOLD+".SDH0"    [SDH0]
Local Mask =WHISTFOLD+".SDH1"    [SDH1]
Local Mask =WHISTFOLD+".SDH2"    [SDH2]
Local Mask =WHISTFOLD+".SDH3"    [SDH3]
Local Mask =WHISTFOLD+".SFITRF"  [SFIT]
Local Mask =WHISTFOLD+".SFITRF"  [SFI2]
# Issue 106947 - 20150811 by LD

Return
########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SDDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour STOFCY SDELIVERYD à partir de STOFCY SDELIVERY
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSDDM+" SET STOFCY_0="
REQSQL(1)="(SELECT SDH.STOFCY_0 FROM"-DOSSIER+"."+WNAMSDHM+" SDH Where SDH.SDHNUM_0="+WNAMSDDM+".SDHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSDDM+".STOFCY_0<>(SELECT SDH.STOFCY_0 From"-DOSSIER+"."+WNAMSDHM+" SDH Where SDH.SDHNUM_0="+WNAMSDDM+".SDHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGINISAL06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGINISAL06(APPLI)
End

