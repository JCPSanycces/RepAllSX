#<AdxTL>@(#)6.0.0.0 $Revision$


Call MAJ150(nomap)
End

#################################################################################
## Moulinette tableaux de bord 140 => 150
#################################################################################
Subprog MAJ150(APPLI)
Value Char APPLI
Local File =APPLI+".TXSA" [TXS]
Local File =APPLI+".TXSM" [TXM]

Trbegin [TXS]
 For [TXS]
  For I=0 To [F:TXS]NBRCOL-1
   If [F:TXS]SAICOL(I)=0
    [F:TXS]SAICOL(I) = 1                               : # Ttes colonnes saisies
   Endif
  Next I
  If [F:TXS]GENLEDTYP=0 : [F:TXS]GENLEDTYP = 1 : Endif : # Réf géné par défaut
  If [F:TXS]ANALEDTYP=0 : [F:TXS]ANALEDTYP = 1 : Endif : # Réf ana par défaut
  Rewrite [TXS]
  If fstat
   Call ERREUR("TXSA"-[F:TXS]TXSNAM,2) From DOSDIC
  Endif
 Next
 Delete [TXM] Where 1=1 : # Effacement de tous les montants
Commit
End




