#<AdxTL>@(#)0.0.0.0 $Revision$
# LS 08/10/1998 
# EDITION DES DOUBLONS (RAPPROCHEMENT BANCAIRE)

Subprog IMPRIME(NBPAR,PARAMETRE)
Value Integer NBPAR
Value Char    PARAMETRE()(1..)
Local Char LPTG1(4)
Local Integer I, J, K, L

If dim([M:SAI1]NBLIG)<=0 or dim([M:SAI1]CHK)<=0 : # GH 15/12/99 bug 3864
 Call ERREUR(mess(20,135,1)) From GESECRAN : # Etat non exécutable directement
 GOK=0 : [M:RPT]NBRPAR=0 : End
Endif

Local File EDITRBK [EBK]
Default Mask [M:SAI1]

Call DEBTRANS From GLOCK
LPTG1 = ""
Trbegin [EBK]
 Delete [EBK] Where BAN=[M]BAN
 If fstat=1 | fstat>5
  GOK=-1 : Call RSTA("EBK","") From GLOCK : Goto ABANDON
 Endif
 For I=0 To [M]NBLIG-1
  If [M]ACCNUM(I)=0 & ([M]CHK(I)=""| [M]CHK(I)>"_") &
&              VALEUR1(0)=mess(2,1,1)     : # Bug 12271
#&VALEUR1(0)="2"      : # Ecriture bancaire
   J = I : K = 1 : L = 0
   While K<>0
    K = find([M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
    If K<>0 & [M]SNS(I)=[M]SNS(J+K) & [M]ACCNUM(J+K)=0 & ([M]CHK(J+K)="" | [M]CHK(J+K)>"_")
     Gosub DOUBLON
     If !GOK : Break 2 : Endif
    Endif
    J +=K
   Wend
  Elsif [M]ACCNUM(I)<>0 & ([M]CHK(I)="" | [M]CHK(I)>"_") &
&                         VALEUR1(1)=mess(2,1,1)     : # Bug 12271
#&        VALEUR1(1)="2"  : #Ecriture
   J = I : K = 1 : L = 0
   While K<>0
    K = find([M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
    If K<>0 & [M]SNS(I)=[M]SNS(J+K) & [M]ACCNUM(J+K)<>0 & ([M]CHK(J+K)="" |[M]CHK(J+K)>"_")
     Gosub DOUBLON
     If !GOK : Break 2 : Endif
    Endif
    J +=K
   Wend
   J = I : K = 1
   While K<>0
    K = find(-[M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
    If K<>0 & [M]SNS(I)<>[M]SNS(J+K) & [M]ACCNUM(J+K)=0 & ([M]CHK(J+K)=""|[M]CHK(J+K)>"_")
     Gosub DOUBLON
     If !GOK : Break 2 : Endif
    Endif
    J +=K
   Wend
  Endif
 Next I
 If !GOK : Goto ABANDON : Endif
Commit
End

$DOUBLON
If L=0
 Look [EBK]EBK1=[M]BAN;I+1
 If fstat
  L = 1
  Call CHK_LETTRE(LPTG1) From SUBRAB
  IND = I
  Gosub MAJ_EBK
  If !GOK : Return : Endif
  Endif
Endif
Look [EBK]EBK1=[M]BAN;J+K+1
If fstat
 IND = J+K
 Gosub MAJ_EBK
 If !GOK : Return : Endif
Endif
Return

$MAJ_EBK
Raz [F:EBK]
[F:EBK]BAN    = [M]BAN
[F:EBK]CHK    = "_"+LPTG1
[F:EBK]NUMLIN = IND+1
[F:EBK]ACCDAT = [M]ACCDAT(IND)
[F:EBK]SNS    = [M]SNS(IND)
[F:EBK]AMTCUR = [M]AMTBNQ(IND)
[F:EBK]CUR    = [M]CUR
[F:EBK]DES    = [M]DES(IND)
[F:EBK]CIB    = [M]BANCIB(IND)
If [M]ACCNUM(IND) = 0    : # Ecriture de relevé bancaire
 [F:EBK]RBK    = "BANQUE"
 [F:EBK]REF    = [M]REFB(IND)
 [F:EBK]ENTNUM = [M]REFC(IND)
Else
 [F:EBK]RBK    = "COMPTE"
 [F:EBK]REF    = [M]REFC(IND)
 [F:EBK]ENTNUM = [M]REFB(IND)
Endif
Write [EBK]
If fstat
 GOK = 0 : Call FSTA("EBK") From GLOCK
Endif
Return

$ABANDON
Rollback
End

