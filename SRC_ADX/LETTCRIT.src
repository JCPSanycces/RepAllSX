#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque LETTCRIT
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
GACTION = "MTCCRIT"
Local Mask LETTCRIT [LTC]
Local File ADOVAL [ADW]
SITE = "PAR" : Gosub INIPAR
Call TRAITE_CHAR(VALEUR,PARAM,"","LETTCRIT","DMTCCRIT",4,"") From GTRAITE
End

########################################
## Critères de lettrage
########################################
$ACTION
Case GACTION
 When "MTCCRIT"
  Case ACTION
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
   When "SETBOUT"     : Gosub SETBOUT
   When Default
  Endcase
 When "MTCCRIT2"
  Case ACTION
   When "DEBUT"        : Gosub DEB_ENR
   When "OK"           : Gosub ENR
  Endcase
Endcase
Return

########################################
## Style de sélection
########################################
$STYLE
Local Char STYLE(GLONASY)
STYLE = "MTC3"
Return

########################################
## Action MTCCRIT
########################################
$SETBOUT
CHBOU += "E"
Gosub SET_BOUT_STD From GSAISIE
Return

$DEBUT
If  dim([M:LTA]LEDTYP)>0
 [M:LTC] = [M:LTA]
 If [M:LTC]MTCAMT<2  : [M:LTC]MTCAMT  = 0 : [M:LTC]PIO(0) = 0 : Endif
 If [M:LTC]MTCCUR<2  : [M:LTC]MTCCUR  = 0 : [M:LTC]PIO(1) = 0 : Endif
 If [M:LTC]MTCSOL2<2 : [M:LTC]PIO(2)  = 0 : Endif
 If [M:LTC]MTCSOL1<1 : [M:LTC]MTCSOL1 = 0 : [M:LTC]PIO(3) = 0 : Endif
 If [M:LTC]MTCREF<3  : [M:LTC]MTCREF  = 0 : [M:LTC]PIO(4) = 0 : Endif
 If [M:LTC]MTCDES<3  : [M:LTC]MTCDES  = 0 : [M:LTC]PIO(5) = 0 : Endif
 [M:LTC]NBMET = 0
 [M:LTC]NBPIO = 0
 NPRI = dim([M:LTC]PIO)
 Local Integer PRI1(1..NPRI) , PRI2(1..NPRI)
 For J=1 To NPRI
  PRI1(J) = [M:LTC]PIO(J-1)
  PRI2(J) = J
 Next J
 Sorta NPRI PRI1,PRI2
 For J=1 To NPRI
  If PRI1(J)=0
   [M:LTC]MET([M:LTC]NBMET) = PRI2(J)
   [M:LTC]NBMET += 1
  Else
   [M:LTC]METHODE([M:LTC]NBPIO) = PRI2(J)
   Case PRI2(J)
    When 1 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCAMT
    When 2 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCCUR
    When 4 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCSOL1
    When 5 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCREF
    When 6 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCDES
    When 7 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCFREREF
   Endcase
   [M:LTC]NBPIO += 1
  Endif
 Next J
Endif
[M:DIA] = [M:LTC]
Call LECMEMO("STD","[M:DIA]","cpl") From GMEMO
Affzo
Return

$OK
Raz [M:DIA]PIO
Raz [M:DIA]MTCAMT,[M:DIA]MTCCUR,[M:DIA]MTCSOL1,[M:DIA]MTCSOL2,[M:DIA]MTCREF,[M:DIA]MTCDES,[M:DIA]MTCFREREF
For I=0 To [M:DIA]NBPIO-1
 [M:DIA]PIO([M:DIA]METHODE(I)-1) = I+1
 Case [M:DIA]METHODE(I)
  When 1 : [M:DIA]MTCAMT    = [M:DIA]PARAM(I)
  When 2 : [M:DIA]MTCCUR    = [M:DIA]PARAM(I)
  When 3 : [M:DIA]MTCSOL2   = 2
  When 4 : [M:DIA]MTCSOL1   = [M:DIA]PARAM(I)
  When 5 : [M:DIA]MTCREF    = [M:DIA]PARAM(I)
  When 6 : [M:DIA]MTCDES    = [M:DIA]PARAM(I)
  When 7 : [M:DIA]MTCFREREF = [M:DIA]PARAM(I)
 Endcase
Next I
[M:DIA]SAVCRIT = 1
[M:LTC] = [M:DIA]
If dim([M:LTA]LEDTYP)>0 : [M:LTA] = [M:LTC]  : Endif
Return

$INIPAR
Local Char    VALPAR(10)
Call PARAM(SITE,"MTCAMT",VALPAR) From ADOVAL
[M:LTC]MTCAMT = val(VALPAR)
Call PARAM(SITE,"MTCCUR",VALPAR) From ADOVAL
[M:LTC]MTCCUR = val(VALPAR)
Call PARAM(SITE,"MTCSOL1",VALPAR) From ADOVAL
[M:LTC]MTCSOL1 = val(VALPAR)
Call PARAM(SITE,"MTCSOL2",VALPAR) From ADOVAL
[M:LTC]MTCSOL2 = val(VALPAR)
Call PARAM(SITE,"MTCREF",VALPAR) From ADOVAL
[M:LTC]MTCREF = val(VALPAR)
Call PARAM(SITE,"MTCFREREF",VALPAR) From ADOVAL # bug 25771
[M:LTC]MTCFREREF = val(VALPAR)                  # bug 25771
Call PARAM(SITE,"MTCDES",VALPAR) From ADOVAL
[M:LTC]MTCDES = val(VALPAR)
Call PARAM(SITE,"MTCLOW",VALPAR) From ADOVAL
[M:LTC]MTCLOW = val(VALPAR)
Call PARAM(SITE,"MTCTRA",VALPAR) From ADOVAL
[M:LTC]MTCTRA = val(VALPAR)
Call PARAM(SITE,"MTCRND",VALPAR) From ADOVAL
[M:LTC]MTCRND = val(VALPAR)
Call PARAM(SITE,"MTCPIO",VALPAR) From ADOVAL
For I=1 To dim([M:LTC]PIO)
 [M:LTC]PIO(I-1) = val(mid$(VALPAR,I,1))
Next I
If [M:LTC]MTCAMT<2
 [M:LTC]MTCAMT = 0 : [M:LTC]PIO(0) = 0
Endif
If [M:LTC]MTCCUR<2
 [M:LTC]MTCCUR = 0 : [M:LTC]PIO(1) = 0
Endif
If [M:LTC]MTCSOL2<2
 [M:LTC]PIO(2) = 0
Endif
If [M:LTC]MTCSOL1<1
 [M:LTC]MTCSOL1 = 0 : [M:LTC]PIO(3) = 0
Endif
If [M:LTC]MTCREF<3
 [M:LTC]MTCREF = 0 : [M:LTC]PIO(4) = 0
Endif
If [M:LTC]MTCDES<3
 [M:LTC]MTCDES = 0 : [M:LTC]PIO(5) = 0
Endif
[M:LTC]NBMET = 0
[M:LTC]NBPIO = 0
For I=1 To len(mess(0,2667,1))
 If [M:LTC]PIO(I-1)=0
  [M:LTC]MET([M:LTC]NBMET) = I
  [M:LTC]NBMET += 1
 Else
  [M:LTC]METHODE([M:LTC]NBPIO) = I
  Case I
   When 1 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCAMT
   When 2 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCCUR
   When 4 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCSOL1
   When 5 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCREF
   When 6 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCDES
   When 7 : [M:LTC]PARAM([M:LTC]NBPIO) = [M:LTC]MTCFREREF
  Endcase
  [M:LTC]NBPIO += 1
 Endif
Next I
[M:LTC]DRO = "154"
[M:LTC]GAU = "153"
[M:LTC]HAU = "030"
[M:LTC]BAS = "029"
[M:LTC]SITCUR = SITE
Return

########################################
## Action MTCCRIT2
########################################
$DEB_ENR
Raz [M]
If [M:LTC]SITCUR<>""
 [M]FCY = [M:LTC]SITCUR
 If clalev ([F:FCY])=0 : Local File FACILITY [FCY] : Endif
 Look [FCY]FCY0=[M]FCY
 If fstat
  Raz [M]FCY
  [M]CPY = [M:LTC]SITCUR
 Endif
Endif
Affzo
Return

$ENR
Local Char LEGCUR(GLONADI) : # Législation
If dim([M]LEG)>0
 LEGCUR = [M]LEG
Else
 LEGCUR = GDOSLEG(1)
Endif
Gosub OK
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ADW]
 Call MAJPAR("MTCAMT",num$([M:LTC]MTCAMT),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCCUR",num$([M:LTC]MTCCUR),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCSOL1",num$([M:LTC]MTCSOL1),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCSOL2",num$([M:LTC]MTCSOL2),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCREF",num$([M:LTC]MTCREF),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCDES",num$([M:LTC]MTCDES),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCFREREF",num$([M:LTC]MTCFREREF),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCLOW",num$([M:LTC]MTCLOW),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCTRA",num$([M:LTC]MTCTRA),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCRND",num$([M:LTC]MTCRND),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJPAR("MTCPIO",sigma(0,6,num$([M:LTC]PIO(indcum))),[M]FLD,[L]LEGCUR,[M]CPY,[M]FCY)
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

Subprog MAJPAR(PARAM,VALEUR,DOSSIER,LEGIS,SOCIETE,SITE)
Value Char    PARAM
Value Char    VALEUR
Value Integer DOSSIER
Value Char    LEGIS
Value Char    SOCIETE
Value Char    SITE
Local Char WSOC(30) , WSIT(30)
If DOSSIER=2
 WSOC = ""
 WSIT = ""
Elsif LEGIS<>""
 WSOC = "*"
 WSIT = LEGIS
Else
 WSOC = SOCIETE
 WSIT = SITE
Endif
Readlock [ADW]ADW0 = WSOC;WSIT;PARAM
If fstat=1
 GOK = -1 : GLOCK = "$ADOVAL"-WSOC-WSIT-PARAM : End
Elsif fstat
 [F:ADW]CMP    = WSOC
 [F:ADW]FCY    = WSIT
 [F:ADW]PARAM  = PARAM
 [F:ADW]VALEUR = VALEUR
 Write [ADW]
Else
 [F:ADW]VALEUR = VALEUR
 Rewrite [ADW]
Endif
If fstat
 GOK = 0 : Call FSTA("ADW") From GLOCK : End
Endif
End

########################################
## Ecran LETTCRIT                     ##
########################################
Subprog CL_DRO(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]LIGCUR-1
If NOL>=0
 Gosub DESELECT
 [M]METHODE([M]NBPIO) = [M]MET(NOL)
 Case [M]METHODE([M]NBPIO)
  When 1,2   : [M]PARAM([M]NBPIO) = 3
  When 3     : [M]PARAM([M]NBPIO) = 0
  When 4     : [M]PARAM([M]NBPIO) = 1
  When 5,6,7 : [M]PARAM([M]NBPIO) = 8
 Endcase
 [M]NBPIO += 1
 Dela NOL [M]NBMET
 [M]NBMET -= 1
 Affzo
 If [M]NBMET>0
  [M]LIGCUR = min(NOL+1,[M]NBMET)
  Chgstl [M]NBMET([M]LIGCUR-1) With STYLE
 Endif
Endif
End

Subprog CL_GAU(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=0
 Gosub DESELECT
 [M]MET([M]NBMET) = [M]METHODE(NOL)
 [M]NBMET += 1
 Dela NOL [M]NBPIO
 [M]NBPIO -= 1
 Affzo
 If [M]NBPIO>0
  [M]CRICUR = min(NOL+1,[M]NBPIO)
  Chgstl [M]NBPIO([M]CRICUR-1) With STYLE
 Endif
Endif
End

Subprog CL_HAU(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=1
 Local Integer SAVMET , SAVPAR
 SAVMET            = [M]METHODE(NOL)
 SAVPAR            = [M]PARAM(NOL)
 [M]METHODE(NOL)   = [M]METHODE(NOL-1)
 [M]PARAM(NOL)     = [M]PARAM(NOL-1)
 [M]METHODE(NOL-1) = SAVMET
 [M]PARAM(NOL-1)   = SAVPAR
 Affzo METHODE,PARAM
 Chgstl [M]NBPIO([M]CRICUR-1) With ""
 [M]CRICUR -= 1
 Chgstl [M]NBPIO([M]CRICUR-1) With STYLE
Endif
End

Subprog CL_BAS(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=0 & NOL<[M]NBPIO-1
 Local Integer SAVMET , SAVPAR
 SAVMET            = [M]METHODE(NOL)
 SAVPAR            = [M]PARAM(NOL)
 [M]METHODE(NOL)   = [M]METHODE(NOL+1)
 [M]PARAM(NOL)     = [M]PARAM(NOL+1)
 [M]METHODE(NOL+1) = SAVMET
 [M]PARAM(NOL+1)   = SAVPAR
 Affzo METHODE,PARAM
 Chgstl [M]NBPIO([M]CRICUR-1) With ""
 [M]CRICUR += 1
 Chgstl [M]NBPIO([M]CRICUR-1) With STYLE
Endif
End

Subprog AS_NBMET
If nolign>0 & nolign<=[M]NBMET
 Gosub STYLE
 Gosub DESELECT
 Chgstl [M]NBMET(nolign-1) With STYLE
 [M]LIGCUR = nolign
Endif
End

Subprog AS_NBPIO
If nolign>0 & nolign<=[M]NBPIO
 Gosub STYLE
 Gosub DESELECT
 Chgstl [M]NBPIO(nolign-1) With STYLE
 [M]CRICUR = nolign
Endif
End

$DESELECT
If [M]LIGCUR<>0
 Chgstl [M]NBMET([M]LIGCUR-1) With ""
 [M]LIGCUR = 0
Endif
If [M]CRICUR<>0
 Chgstl [M]NBPIO([M]CRICUR-1) With ""
 [M]CRICUR = 0
Endif
Return

Subprog AS_PARAM(VALEUR)
Variable Decimal VALEUR
If [M]METHODE(nolign-1)=3
 mkstat = 1 : End
Endif
End

Subprog C_PARAM(VALEUR)
Variable Decimal VALEUR
Case [M]METHODE(nolign-1)
 When 1,2
  If VALEUR<2 : VALEUR = 2 : Endif
  If VALEUR>9 : VALEUR = 9 : Endif
 When 4
  If VALEUR<1 : VALEUR = 1 : Endif
  If VALEUR>9 : VALEUR = 9 : Endif
 When 5,6,7
  If VALEUR<3  : VALEUR = 3  : Endif
  If VALEUR>30 : VALEUR = 30 : Endif
Endcase
End

Subprog AS_MTCLOW(VALEUR)
Variable Integer VALEUR
If !find(5,[M]METHODE(0..[M]NBPIO-1)) & !find(6,[M]METHODE(0..[M]NBPIO-1)) & !find(7,[M]METHODE(0..[M]NBPIO-1))
 mkstat = 1 : End
Endif
End

######################################################################################
## Ecran LETTCRIT2
######################################################################################
Subprog C_FLD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY, FCY
 Grizo CPY, FCY
 If dim([M]LEG)>0
  Effzo LEG
  Grizo LEG
 Endif
Else
 Actzo CPY, FCY
 If dim([M]LEG)>0
  Actzo LEG
 Endif
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo CPY, FCY
 Grizo CPY, FCY
Else
 Actzo CPY, FCY
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo FCY
 Grizo FCY
Else
 Actzo FCY
Endif
End

