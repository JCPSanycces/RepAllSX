######################################################################################
## Etiquette ajoutée par le superviseur (écran ILOGIMG) 21/01/2011 09:30:10 (GBE)
######################################################################################
Subprog AP_IMG
# on met à jour le timestamp
Local Integer TIMESTAMP
Call CALCTIMESTAMP(TIMESTAMP)
[M:ILI0]TIMESTAMP = num$(TIMESTAMP)

End

######################################################################################
# Fonction qui calcule le nombre de secondes écoulée depuis le 01/01/1970
# pas besoin d'être précis par rapport au GMT on veux simplement donner un timestamp
# permettant de signaler un changement
######################################################################################
Subprog CALCTIMESTAMP(TIMESTAMP)
Variable Integer TIMESTAMP

Local Integer NBDAY   #nombre de jours depuis 1970
Local Date DATE1970   #date  01/01/1970
Local Date DATENOW    #date actuelle
Local Integer TIMESEC #nombre de secondes depuis minuit

DATE1970=gdat$(1,1,1970)
DATENOW=date$()
TIMESEC=time

NBDAY=DATENOW-DATE1970
TIMESTAMP=(NBDAY*3600*24)+TIMESEC
End

######################################################################################

