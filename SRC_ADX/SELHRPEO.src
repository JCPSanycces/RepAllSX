#<AdxTL>@(#)0.0.0.0 $Revision$


$ACTION
Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
Endcase

Return

$OUVRE
  If clalev([F:HRPER])=0  :  Local File HRPERIOD [HRPER]  :  Endif
Return

$DEBUT
Local Date STR2
Local Date END2
Local Integer TAXMONTH
Local Integer TAXYEA
Global Integer GPERYEA
Global Integer GPERNUM
Global Integer GTAXMON
Global Char GPERMON1(10)
Global Date GPYRDAT
Global Date GSTR1
Global Date GEND1
Global Date GSTR2
Global Date GEND2
Global Date GSTR3
Global Date GEND3

[L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))


Local Mask SELHRPEO

nolign=0
Filter [F:HRPER] Where [F:HRPER]PERCOD = [V]GFRQCOD and [F:HRPER]PERSTR(0) >= [L]STR2 and [F:HRPER]PEREND(0) <= [L]END2
Read [F:HRPER] Last
If fstat
  Return
Endif
Filter [F:HRPER]
TAXMONTH = [F:HRPER]TAXMON
TAXYEA=[F:HRPER]PERYEA

For [F:HRPER] Where [F:HRPER]PERCOD = [V]GFRQCOD and [F:HRPER]PERYEA = [L]TAXYEA and [F:HRPER]TAXMON=[L]TAXMONTH

nolign+=1
[M:SELHRPEO]PERYEA(nolign-1) = [F:HRPER]PERYEA(0)
[M:SELHRPEO]PERNUM(nolign-1) = [F:HRPER]PERNUM(0)
[M:SELHRPEO]TAXMON(nolign-1) = [F:HRPER]TAXMON(0)
[M:SELHRPEO]PERMON1(nolign-1) = [F:HRPER]PERMON1(0)
[M:SELHRPEO]PYRDAT(nolign-1) = [F:HRPER]PYRDAT(0)
[M:SELHRPEO]STR1(nolign-1)  =  [F:HRPER]PERSTR(0)
[M:SELHRPEO]END1(nolign-1)  =  [F:HRPER]PEREND(0)
[M:SELHRPEO]STR2(nolign-1)  =  [F:HRPER]PERSTR(1)
[M:SELHRPEO]END2(nolign-1)  =  [F:HRPER]PEREND(1)
[M:SELHRPEO]STR3(nolign-1)  =  [F:HRPER]PERSTR(2)
[M:SELHRPEO]END3(nolign-1)  =  [F:HRPER]PEREND(2)
Next

[M:SELHRPEO]NBRLIG=nolign

Affzo [M:SELHRPEO]
Return

######################################################################################
## Section automatically added (screen HRPER0) 10/04/2016 17:00:32 (JOJAC)
######################################################################################
Subprog AM_OPNPER(VALEUR)
Variable Integer VALEUR
Local Integer CURLIGN
#Global Integer GPERNUM
#Global Integer GTAXMON
#Global Char GPERMON1(10)
#Global Date GSTR1
#Global Date GEND1
#Global Date GSTR2
#Global Date GEND2
#Global Date GSTR3
#Global Date GEND3

CURLIGN=nolign-1
Raz [M:SELHRPEO]OPNPER
[M:SELHRPEO]OPNPER(CURLIGN)=2
Affzo [M:SELHRPEO]

GPERYEA  = [M:SELHRPEO]PERYEA(CURLIGN)
GPERNUM  = [M:SELHRPEO]PERNUM(CURLIGN)
GTAXMON  = [M:SELHRPEO]TAXMON(CURLIGN)
GPERMON1 = [M:SELHRPEO]PERMON1(CURLIGN)
GPYRDAT  = [M:SELHRPEO]PYRDAT(CURLIGN)
GSTR1    = [M:SELHRPEO]STR1(CURLIGN)
GEND1    = [M:SELHRPEO]END1(CURLIGN)
GSTR2    = [M:SELHRPEO]STR2(CURLIGN)
GEND2    = [M:SELHRPEO]END2(CURLIGN)
GSTR3    = [M:SELHRPEO]STR3(CURLIGN)
GEND3    = [M:SELHRPEO]END3(CURLIGN)

End


######################################################################################

