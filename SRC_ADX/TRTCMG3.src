#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Retours marketing                                              Module CRM          12 janvier 2004
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When "RAF"          : Gosub REFRESH
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
  Gosub LOADCMG3
Return

##########################################################################################################
$OUVRE
  If PARAM(1) = "" Then
    #Aucune campagne marketing n'est précisée. L'ananlyse des retours marketing est impossible.
    GMESSAGE = mess(964,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  If PARAM(4) = "" Then
    #Aucune devise n'est précisée. La valorisation des retours marketing est impossible.
    GMESSAGE = mess(965,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
  If !clalev([F:SIV]) : Local File SINVOICEV [SIV] : Endif
  If !clalev([F:SID]) : Local File SINVOICED [SID] : Endif
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNCMG3"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Définition du titre
  If PARAM(2) = "" Then
    #Analyse des retours de la campagne marketing n°XXXXXXX
    [M:CMG3]TIT = mess(966,182,1) + PARAM(1)
  Else
    Case PARAM(3)
      When "OMM"
        #Analyse des retours du publipostage n°XXXXXXX
        [M:CMG3]TIT = mess(967,182,1) + PARAM(2)
      When "OMP"
        #Analyse des retours de la campagne d'appels n°XXXXXXX
        [M:CMG3]TIT = mess(968,182,1) + PARAM(2)
      When "OMT"
        #Analyse des retours du salon professionnel n°XXXXXXX
        [M:CMG3]TIT = mess(969,182,1) + PARAM(2)
      When "OMN"
        #Analyse des retours de la campagne presse n°XXXXXXX
        [M:CMG3]TIT = mess(970,182,1) + PARAM(2)
      When Default
        #Analyse des retours de l'opération marketing n°XXXXXXX
        [M:CMG3]TIT = mess(971,182,1) + PARAM(2)
    Endcase
  Endif
  [M:CMG3]CMGNUM = PARAM(1)
  [M:CMG3]OPGNUM = PARAM(2)
  [M:CMG3]OPGTYP = PARAM(3)
  If PARAM(2) = "" Then
    [M:CMG3]NVGCOD = "1"
  Else
    [M:CMG3]NVGCOD = "2"
  Endif
  #Chargement du tableau
  Gosub LOADCMG3
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:CMG3]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
Return

##########################################################################################################
$LOADCMG3
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Char CODDEVSOC
Local Char SZSALFCY
Local Char SZRECCUR
Local Char SZCMGOPGCUR
Local Decimal ISRCAMT
Local Decimal IDESAMT

  Call TEMPON("L") From GESECRAN
  SZCMGOPGCUR = PARAM(4)
  Gosub RAZCMG3

  #Tâches
  If PARAM(2) = "" Then
    Filter [TSK] Where [F:TSK]TSKCMGNUM = PARAM(1) Order By [F:TSK]CREDAT Asc
  Else
    Filter [TSK] Where [F:TSK]TSKCMGNUM = PARAM(1) and [F:TSK]TSKOPGNUM = PARAM(2) and [F:TSK]TSKOPGTYP = PARAM(3) Order By [F:TSK]CREDAT Asc
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 1  #Tâches
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  For [TSK]
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:TSK]CREDAT
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:TSK]CREDAT
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
  Next
  Filter [TSK]
  [M:CMG3]NBRTN += 1

  #Appels
  If PARAM(2) = "" Then
    Filter [CLL] Where [F:CLL]CLLCMGNUM = PARAM(1) and [F:CLL]CLLCMGFLG = 0
  Else
    Filter [CLL] Where [F:CLL]CLLCMGNUM = PARAM(1) and [F:CLL]CLLCMGFLG = 0 and [F:CLL]CLLOPGNUM = PARAM(2) and [F:CLL]CLLOPGTYP = PARAM(3)
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 2 #Appels
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  For [CLL]CLL1 Hint Key CLL5
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:CLL]CLLDATX
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:CLL]CLLDATX
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
  Next
  Filter [CLL]
  [M:CMG3]NBRTN += 1

  #Rendez-vous
  If PARAM(2) = "" Then
    Filter [BAP] Where [F:BAP]APTCMGNUM = PARAM(1)
  Else
    Filter [BAP] Where [F:BAP]APTCMGNUM = PARAM(1) and [F:BAP]APTOPGNUM = PARAM(2) and [F:BAP]APTOPGTYP = PARAM(3)
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 3  #Rendez-vous
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  For [BAP]APP4
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:BAP]APTDATX
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:BAP]APTDATX
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
  Next
  Filter [BAP]
  [M:CMG3]NBRTN += 1

  #Affaires
  If PARAM(2) = "" Then
    Filter [OPP] Where [F:OPP]OPPCMGNUM = PARAM(1) Order By [F:OPP]CREDAT Asc
  Else
    Filter [OPP] Where [F:OPP]OPPCMGNUM = PARAM(1) and [F:OPP]OPPOPGNUM = PARAM(2) and [F:OPP]OPPOPGTYP = PARAM(3) Order By [F:OPP]CREDAT Asc
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 4 #Affaires
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  [M:CMG3]RTNCUR([M:CMG3]NBRTN) = PARAM(4)
  For [OPP] Hint Key OPP2
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:OPP]CREDAT
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:OPP]CREDAT
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
    SZRECCUR = [F:OPP]CUR
    SZSALFCY = [F:OPP]SALFCY
    ISRCAMT = [F:OPP]OPPAMT
    Gosub MNGCUR
    [M:CMG3]RTNAMT([M:CMG3]NBRTN) += IDESAMT
  Next
  Filter [OPP]
  [M:CMG3]NBRTN += 1

  #Commandes de ventes
  If PARAM(2) = "" Then
    Filter [SOH] Where [F:SOH]CMGNUM = PARAM(1) Order By [F:SOH]ORDDAT Asc
  Else
    Filter [SOH] Where [F:SOH]CMGNUM = PARAM(1) and [F:SOH]OPGNUM = PARAM(2) and [F:SOH]OPGTYP = PARAM(3) Order By [F:SOH]ORDDAT Asc
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 5  #Commandes de ventes
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  [M:CMG3]RTNCUR([M:CMG3]NBRTN) = PARAM(4)
  For [SOH]
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:SOH]ORDDAT
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:SOH]ORDDAT
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
    SZRECCUR = [F:SOH]CUR
    SZSALFCY = [F:SOH]SALFCY
    ISRCAMT = [F:SOH]ORDNOT
    Gosub MNGCUR
    [M:CMG3]RTNAMT([M:CMG3]NBRTN) += IDESAMT
  Next
  Filter [SOH]
  [M:CMG3]NBRTN += 1

  #Factures directes
  If PARAM(2) = ""
    Filter [SIV] Where [F:SIV]CMGNUM = PARAM(1) Order By [F:SIV]INVDAT Asc
  Else
    Filter [SIV] Where [F:SIV]CMGNUM = PARAM(1) and [F:SIV]OPGNUM = PARAM(2) and [F:SIV]OPGTYP = PARAM(3) Order By [F:SIV]INVDAT Asc
  Endif
  [M:CMG3]RTNTYP([M:CMG3]NBRTN) = 6  #Factures directes
  #LSE 07/12/2006 pour affichage graphe
  [M:CMG3]LIBTYP([M:CMG3]NBRTN) = mess([M:CMG3]RTNTYP([M:CMG3]NBRTN),3031,1)
  [M:CMG3]RTNCUR([M:CMG3]NBRTN) = PARAM(4)
  For [SIV]
    If [M:CMG3]RTNNBR([M:CMG3]NBRTN) = 0 Then
      [M:CMG3]RTNDATSTR([M:CMG3]NBRTN) = [F:SIV]INVDAT
    Endif
    [M:CMG3]RTNDATEND([M:CMG3]NBRTN) = [F:SIV]INVDAT
    [M:CMG3]RTNNBR([M:CMG3]NBRTN) += 1
    SZRECCUR = [F:SIV]CUR
    SZSALFCY = [F:SIV]SALFCY
    Filter [SID] Where [F:SID]NUM = [F:SIV]NUM
    For [SID]
      ISRCAMT = [F:SID]AMTNOTLIN
      Gosub MNGCUR
      [M:CMG3]RTNAMT([M:CMG3]NBRTN) += IDESAMT
    Next
    Filter [SID]
  Next
  Filter [SIV]
  [M:CMG3]NBRTN += 1
  #
  Call TEMPOFF From GESECRAN
  Affzo [M:CMG3]1-99
Return

#########################################################
$RAZCMG3
  Raz [M:CMG3]NBRTN
  Raz [M:CMG3]RTNTYP
  Raz [M:CMG3]RTNDATSTR
  Raz [M:CMG3]RTNDATEND
  Raz [M:CMG3]RTNNBR
  Raz [M:CMG3]RTNAMT
  Raz [M:CMG3]RTNCUR
Return

##########################################################################################################
$MNGCUR
  #Conversion des montants dans la devise de l'état
  IT_IS_OK = 1
  IT_IS_NOT_OK = 0
  If SZRECCUR = SZCMGOPGCUR Then
    IDESAMT = ISRCAMT
  Else
    Call GETDEVCPY("", SZSALFCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
    # Devise d'origine
    # Devise destination
    # Devise de la société
    # Type de cours
    # Date du cours
    # Montant origine
    # Montant destination
    # Status de retour (0 = OK)
    #Montant brut
    Call CONVERT(SZRECCUR,SZCMGOPGCUR,CODDEVSOC,2,date$,ISRCAMT,IDESAMT,IT_IS_NOT_OK) From TRTDEV
    If IT_IS_NOT_OK Then
      #Certains montants n'ont pas pus être calculés correctement en raison
      # d'une mauvaise qualification de la table des devises.
      GMESSAGE = mess(278,196,1)
      GERR = 3
    Endif
  Endif
Return
