#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTMODACO    : Action modification des acomptes            #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return
#########################################################################
$INIT
Case GACTION
 When "TRTMODACO"    : Gosub INIT_MODACO
Endcase
Return
Return
#########################################################################
$INIT_DIA
Case GACTION
 When "TRTMODACO"    : Gosub INITD_MODACO
Endcase
Return
#########################################################################
$EXEC
Case GACTION
 When "TRTMODACO"    : Gosub EXEC_MODACO
Endcase
Return
#########################################################################
$TERMINE
Case GACTION
 When "TRTMODACO"    : Gosub TERM_MODACO
 Local Shortint I
  For I=0 To [M:DIA]NBLIG-1
    If [M:DIA]PAM(0) <> ""
      GBIDI1 = I
      Call WORKFLOW("F_FUNPNS","","") From SUBAMSC
    Endif
  Next I
Endcase
Return
#########################################################################
#    Actions liés à l'action MODACOMPTE                                 #
#########################################################################
$INIT_MODACO
Local    Integer MODULE    :    MODULE = val(PARAM(1))
Local    Char    NUMCDE    :    NUMCDE = PARAM(2)
Local    Integer IMPR      :    IMPR   = val(PARAM(3))
Local    Char    DOCNAM    :    DOCNAM = PARAM(4)

If dim([V]GTYP)<1  Global Char GTYP(3) : Endif : # Car Kill dans catégories article ?

## Historisation des échéances supprimées
Local Char CRITSUPPR (250)

GNUMCDE = "" : GSNSNAM = "" : GTYP    = ""
GMODULE = 0  : GSNSFLG = 0  : GACCNUM = 0

Local Integer WDUDLIG, OK, NBTEX, STAT
Local Decimal WMONTANT
Global Integer TYPCOURS
Global Char  TFACT(GLONBPR), TPAYE(GLONBPR), ADRPAY(GLONADR)
Global Date    DEPECHE
Local Char TEXTE(15)(10),CHAINE(10), REP(1)
If !clalev([F:ADP]) Local File ADOPAR [ADP] Endif
If !clalev([F:ADW]) Local File ADOVAL [ADW] Endif
#Local Char    PARAM(10)
Local Integer WDRAPEAU
Raz WDRAPEAU

GSNSFLG = 1

GMODULE = MODULE
If NUMCDE <> "" : GNUMCDE = NUMCDE
                  GSNSNAM = DOCNAM
                  GSNSFLG = IMPR
Else              GORDCAT = 4
Endif
Gosub SAUV_GLOB From TRTX3GLOB

# Globale initialisée dans la fonction FUNSNS ou FUNPNS
Raz GFONEMI
If NUMCDE = "" & MODULE = 5
    GFONEMI = "VEN"
Elsif NUMCDE = "" & MODULE = 6
    GFONEMI = "ACH"
Endif
#Ouverture des fichier nécessaires
If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif
If clalev([F:CAC])<=0 : Local File GACCCODE [CAC] : Endif
If clalev([F:GAC])<=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:TPT])<=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:ADI])<=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:TAM])<=0 : Local File TABPAM  [TAM] Endif      : # 71937 : Multilégislation

Case MODULE
     When 5 : If clalev ([F:SOH]) <= 0 : Local File SORDER [SOH] : Endif
              If clalev ([F:BPC]) <= 0 : Local File BPCUSTOMER [BPC] : Endif
              GTYP = "*SO"
     When 6 : If clalev ([F:POH]) <= 0 : Local File PORDER [POH] : Endif
              If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
              GTYP = "*PO"
     When Default
Endcase
Default File [DUD]

TIT = mess(40,195,1)

Return
#########################################################################
$INITD_MODACO
Local Char WPARAM(10)

Default File [DUD]
Raz [M:DIA]

Gosub ALIM_DIA

Return

#########################################################################
$EXEC_MODACO

Call DEBTRANS From GLOCK
Gosub ECRIRETOUT
If GOK < 1 : Goto SAI : Endif
Return
#########################################################################
$TERM_MODACO

If MODULE = 5 & WDRAPEAU = 1 & IMPR =2
     Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
#    Si on vient de la gestion des acomptes, il faut positionner GNUMCDE pour imprimer
     If GFONEMI="VEN" GNUMCDE=[M]NUM : Endif
     If [M]SNSNAM <> ""
         Call ETAT([M]SNSNAM,"GESSOH",TBPAR,TBVAL) From ETAT
     Endif
Endif
#Si on vient de la gestion des commande, il ne faut SURTOUT PAS "killer"
#le paramètre GDAYNBR puisque ce n'est pas nous qui l'avons créé.
#-- cg le 27 novembre 98 on ne doit plus killer les var
If GMODULE = 5 & GFONEMI="VEN" GDAYNBR = 0 : Endif
Gosub REST_GLOB From TRTX3GLOB

Raz TFACT,TPAYE,ADRPAY,TYPCOURS,DEPECHE
Return
# --------------------------------------------- #
#    Alimentation du  masque                    #
#    Initialement an AV_NUM                     #
# --------------------------------------------- #
$ALIM_DIA
Local Char WCUR
Local Char CODCPT(GLONCAC)

If GNUMCDE <> ""
   [M:DIA]NUM = GNUMCDE

   Case GMODULE
       When 5 : Call LECTURE("SOH",[M:DIA]NUM,"") From CONTOBJ
                [M:DIA]NUM = [F:SOH]SOHNUM
                [M:DIA]CUR = [F:SOH]CUR
                WCUR = [F:SOH]CUR
                [M:DIA]TTVORD = [F:SOH]ORDINVATI
                [M:DIA]TOTORD = [F:SOH]ORDINVNOT
                TFACT     = [F:SOH]BPCINV
                TPAYE     = [F:SOH]BPCPYR
                ADRPAY    = [F:SOH]BPAPYR        : # Bug 69487
                TYPCOURS  = [F:SOH]CHGTYP
                DEPECHE   = [F:SOH]ORDDAT
       When 6 : Call LECTURE ("POH",[M:DIA]NUM,"") From CONTOBJ
                [M:DIA]NUM = [F:POH]POHNUM
                [M:DIA]CUR = [F:POH]CUR
                WCUR = [F:POH]CUR
                [M:DIA]TTVORD = [F:POH]TTVORD
                [M:DIA]TOTORD = [F:POH]TOTORD
                TFACT     = [F:POH]BPSINV
                TPAYE     = [F:POH]BPRPAY
                ADRPAY    = [F:POH]BPAPAY
                TYPCOURS  = [F:POH]CHGTYP
                DEPECHE   = [F:POH]ORDDAT
       When Default
   Endcase
   #----- Chargement du code comptable par société -----#
   Case GMODULE
       When 5 : Read [F:BPC]BPC0 = TFACT
                Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",[L]CODCPT) From CPTSUB
                Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(1))             From CONTOBJ
                Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
       When 6 : Read [F:BPS]BPS0 = TFACT
                Call INIT_COMPTE([F:BPS]BPSNUM,GSOCIETE,"F",[L]CODCPT) From CPTSUB
                Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
                Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
       When Default
   Endcase

#    Lecture de la devise
    Call LECDEV([M:DIA]CUR) From TRTDIV
#    Quel que soit le module : Si traitement par entrée séparée
#    Il faut lire les paramètres généraux SOCIETE,SITE FINANCIER, DEVISES
#    SOCIETE ET DOSSIER
#    Si on vient de la fonction indépendante de gestion des acomptes
#    et Module = vente, il faut aller lire le paramètre disant le nombre
#    de jour à enlever à la date d'échéance pour obtenir la date prévue
#    d'émission
#    Si on vient de la gestion des commandes, ce paramètre est déjà chargé
#    Si on vient des achats on n'en a pas besoin
    If GMODULE = 5 & GNUMCDE = ""
       Call GETDEV([F:SOH]SALFCY) From DEVSUB
       Global Decimal GDAYNBR : # nbre pour calcul dte émission
       Call PARAM([F:SOH]SALFCY,"DAYNBR",WPARAM) From ADOVAL
       GDAYNBR = val(WPARAM)
    Endif

    If GMODULE = 6 & GNUMCDE = ""
       Call GETDEV([F:POH]POHFCY) From DEVSUB
    Endif

    Gosub LIRE From TRTTPT
    [M:DIA]CUR=WCUR
Endif

[M:DIA]SNSNAM=GSNSNAM
[M:DIA]SNSFLG=GSNSFLG
Return

#########################################################################
#                            TRTTPT                                     #
#Traitement de création automatique des acomptes et de gestion des      #
#acomptes                                                               #
#                                                     sr Mars 1998      #
# Revu en Avril pour travailler directement dans la table des échéances #
# De règlement GACCDUDATE                                               #
#########################################################################
# Subprog ACOMPTES (MODULE,TRAIT,NUMCDE,NBLIN,CODECHE,DEPECHE,MONTHT,   #
#                 MONTTTC,CURECH,TYPCOURS,TFACT,TPAYE,ADRPAY,NOLIN,OK)  #
#-----------------------------------------------------------------------#
# DEFINI les acomptes et retenues garantie en saisie cde achats ventes  #
#  MODULE    : Achat/Vente                                              #
#  TRAIT     : Code traitement :                                        #
#                1 = Création                                           #
#                2 = Annulation                                         #
#                3 = Contrôle acomptes versés                           #
#  NUMCDE    : Numéro de commande                                       #
#  NBLIN     : Nbre de ligne CDE                                        #
#  CODECHE   : code réglement                                           #
#  DEPECHE   : date origine des calculs d'échéances                     #
#  MONTHT    : HT à répartir                                            #
#  MONTTTC   : TTC à répartir                                           #
#  CURECH    : code devise                                              #
#  TYPCOURS  : Type de cours                                            #
#  TFACT     : Tiers Facturé/Facturant                                  #
#  TPAYE     : Tiers Payé/Payeur                                        #
#  ADRPAY    ; Adresse Tiers Payé/Payeur                                #
#  NOLIN     : Numéro de la ligne de départ(sert pour cdes par articles)#
#  OK        : Code retour en CONT_ACOMPTES                             #
#########################################################################
Subprog ACOMPTES(MODULE,TRAIT,NUMCDE,NBLIN,CODECHE,DEPECHE,MONTHT,MONTTTC,CURECH,TYPCOURS,TFACT,TPAYE,ADRPAY,NOLIN,OK)
Value    Integer MODULE
Value    Integer TRAIT
Value    Char    NUMCDE
Value    Integer NBLIN
Value    Char    CODECHE
Value    Date    DEPECHE
Value    Decimal MONTHT
Value    Decimal MONTTTC  # FGR 01/02/2010 : X3SUIVI60986 : Pas MONTTC
Value    Char    CURECH
Value    Integer TYPCOURS
Value    Char    TFACT
Value    Char    TPAYE
Value    Char    ADRPAY
Value    Integer NOLIN
Variable Integer OK

Local    Integer WTYPTAXE  : # (Bug 49881) 1=Acompte en HT, 2=Acompte en TTC
Local    Decimal WTAUXTAXE : # (Bug 49881) Taux de taxe pour calcul des taxes sur les lignes si acompte en TTC
Local    Decimal WTAXE     : # (Bug 49881) Montant de taxe pour calcul des taxes sur les lignes si acompte en TTC
Local    Char    LEGIS   (GLONADI)

If clalev([F:TPT])<=0 : Local File TABPAYTERM [TPT] : Endif
# Bug 42853 : Pouvoir calculer un acompte sur le montant HT ou TTC
# Si    Code activité TPT activé et %TVA de la 1ère ligne de la condition paiement à 0 : Acompte calculé sur HT
# Sinon Acompte calculé sur TTC
Local    Decimal MONTANT
MONTANT = MONTTTC
WTYPTAXE=2

#- X3Suivi 71937 Multi-législation -#
Call GETLEG(GSOCIETE,"G",LEGIS) From DEVSUB
If LEGIS='' : Call GETLEG(GSOCIETE,"T",LEGIS) From DEVSUB : Endif

If GTPTTVA
    #-- X3suivi 71937 - T249 : Multi-Leg--#
    #Filter [TPT] Where PTE=CODECHE & PAMTYP=2 & LEG=LEGIS
    #Read [TPT]TPT0 First
    Filter [TPT] Where PTE=CODECHE & PAMTYP=2 & (LEG=LEGIS or LEG ="")
&     Order By Key CLE=[F:TPT]PTE Asc; [F:TPT]LEG Desc

    Read [TPT]CLE First
    #
    If fstat = 0 & [F:TPT]VATPRC=0 MONTANT=MONTHT : WTYPTAXE=1 Endif
    Filter [TPT]
Endif
Gosub TRT_ACOMPTE
End

$TRT_ACOMPTE
## Historisation des échéances supprimées
Local Char CRITSUPPR (250)

Local Integer NBVAT : NBVAT=20
Case MODULE
    When 5 : If clalev([F:SVV])<=0 : Local File SVCRVAT [SVV] : Endif
             NBVAT=func AFNC.ACTIV("SVA")
    When 6 : If clalev([F:PVV])<=0 : Local File PVCRVAT [PVV] : Endif
             NBVAT=func AFNC.ACTIV("PVA")
    When Default
Endcase
Local Char    TABTAXE(GLONVAT) (0..NBVAT)
Local Decimal TABMNT   (0..NBVAT)
Local Decimal TABMNTTAXE (0..NBVAT)   : # Bug 78172

Local Integer WRET, WDUDLIG, WLIG, STAT, WACCNUM, WIND_TAB
Local Char CODCPT(GLONCAC)

#Ouverture des fichiers nécessaires
If clalev([F:TPT])<=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif
If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:CAC])<=0 : Local File GACCCODE [CAC] : Endif
If clalev([F:GAC])<=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:ADI])<=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:TAM])<=0 : Local File TABPAM  [TAM] : Endif      : # 71937 : Multilégislation

#----------------------------------------------------------------------#
# Point d'entrée pour intervenir avant la génération des acomptes      #
#----------------------------------------------------------------------#
GPOINT="AVTGENACPT" : Gosub ENTREE From EXEFNC
If GOK<1 & TRAIT<>3  End : Endif

If TRAIT = 2 : Gosub SUPP_ACOMPTES : End : Endif
If TRAIT = 3 : Gosub CONT_ACOMPTES : End : Endif

#----- Chargement du code comptable par société -----#
Case MODULE
     When 5 : Read [F:BPC]BPC0 = TFACT
              Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",[L]CODCPT) From CPTSUB
              Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(1))             From CONTOBJ
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
     When 6 : Read [F:BPS]BPS0 = TFACT
              Call INIT_COMPTE([F:BPS]BPSNUM,GSOCIETE,"F",[L]CODCPT) From CPTSUB
              Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1))             From CONTOBJ
              Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))              From CONTOBJ
     When Default
Endcase

#chargement du tableau des taxes si plusieurs
#Garnissage des montants
J=0
Gosub CHARG_TABTAXE

#For I = NOLIN To (NOLIN+NBLIN)-1
#If evalue(COLVAT+"("+num$(I-1)+")") = "" : Goto SUITVAT : Endif
#  If !find(evalue(COLVAT+"("+num$(I-1)+")"),TABTAXE(0..NBLIN))
#     J+=1
#     TABTAXE(J-1) = evalue(COLVAT+"("+num$(I-1)+")")
#  Endif
#  TABMNT(J-1) += evalue(COLMNT+"("+num$(I-1)+")")
#$SUITVAT
#Next I

#On trie les tableaux par ordre des montants
Sorta J TABMNT,TABTAXE

#Lecture de la devise
#Read [F:TCU]TCU0 = CURECH
Call LECDEV(CURECH) From TRTDIV

#Filtre sur code condition de paiement et récupération du nombre maxi d'échéances
#- X3Suivi 71937 Multi-législation -#
Filter [TPT] Where PTE=CODECHE & (LEG=LEGIS | LEG="")
&     Order By Key CLE=[F:TPT]PTE Asc; [F:TPT]LEG Desc; [F:TPT]PTELIN Asc
Read [TPT]CLE Last
NBECH = [F:TPT]PTELIN
Filter [TPT]

# X3-87219 Alternative payment terms and prepayment calculation (LCC-19/06/18)
#  It's not calculated a max. of due dates as there could be a alternative payment term
#  with a upper number of due dates (30 is is the max numer of due dates)
#Local Char     MODECHE(15) (0..NBECH)
#Local Integer  TYPECHE (0..NBECH)
#Local Decimal  MNTECHE (0..NBECH)
#Local Date     DATECHE (0..NBECH)
#Local Integer  RELEVE  (0..NBECH)
Local Char     MODECHE(15) (0..29)
Local Integer  TYPECHE (0..29)
Local Decimal  MNTECHE (0..29)
Local Date     DATECHE (0..29)
Local Integer  RELEVE  (0..29)
# end X3-87219 Alternative payment terms and prepayment calculation (LCC-19/06/18)
Local Shortint NECHE

#Appel au sous-pro de remplissage du tableau précédemment défini
Call DATECHE(CODECHE,DEPECHE,MONTANT,[F:TCU]CURRND,MODECHE,TYPECHE,
&            MNTECHE,DATECHE,RELEVE,NECHE,"") From SUBTPT

#Si rien dans le tableau on sort
If NECHE = 0 : End : Endif

#Création des acomptes et retenues de garantie
Gosub CREA_ACOMPTE

Return

#---------------------------------#
#Chargement du tableau des taxes  #
#---------------------------------#
$CHARG_TABTAXE

Case MODULE
    When 5 : Gosub CHARG_TABTAXE_SVV
             Gosub CHARG_TABTAXE_SVF    : # 102841 : Lecture SVCRFOOT pour connaître le total HT des élt de facturation
    When 6 : Gosub CHARG_TABTAXE_PVV
Endcase

Return

# ----------------------------------------------------------------- #
# Constitution du tableau des taxes par lecture de la table SVCRVAT #
# ----------------------------------------------------------------- #
$CHARG_TABTAXE_SVV
J=0
For [SVV]SVV1 Where VCRTYP=20 & VCRNUM=NUMCDE
    # 102841 : Pb ventilation acomptes par code taxe : Prendre le Montant HT et non le montant soumis
    #If [F:SVV]VATTYP=1
    If [F:SVV]VATTYP=1 & [F:SVV]VATGRO<>0
    # 102841
        # Taxe principale
        J+=1
        # 102841 : Pb ventilation acomptes par code taxe : Prendre le Montant HT et non le montant soumis
        #TABMNT(J-1) = [F:SVV]BASTAX                    : # On prend le Montant HT
        TABMNT(J-1) = [F:SVV]VATGRO                     : # On prend le Montant HT
        #If WTYPTAXE=2 TABMNT(J-1)+=[F:SVV]AMTTAX Endif  : # Si Acompte en TTC, on ajoute le montant de taxe
        If WTYPTAXE=2 TABMNT(J-1)+=[F:SVV]VATAMT Endif  : # Si Acompte en TTC, on ajoute le montant de taxe
        # 102841
        TABTAXE(J-1)= [F:SVV]VAT
        TABMNTTAXE(J-1)= TABMNT(J-1)                    : # Bug 78172
    Endif
Next
Return

# 102841 : Pb ventilation acomptes par code taxe
# --> Il faut prendre le montant HT et non le mnt soumis (pb en cas de remise sur taxe qui diminue le mnt soumis)
# --> le montant HT ds SVCRVAT ne concerne que le montant HT produit, il faut en plus lire SVCRFOOT pour tenir compte du montant HT des élt facturation
# ------------------------------------------------------------------ #
# Constitution du tableau des taxes par lecture de la table SVCRFOOT #
# ------------------------------------------------------------------ #
$CHARG_TABTAXE_SVF
Local  Integer WI, WK

For [SVF] Where VCRTYP=20 & VCRNUM=NUMCDE
  If [F:SVF]DTA<>0
     For WI=0 To dim([F:SVF]DTANET)-1
       WK = find([F:SVF]DTAVAT(WI),TABTAXE(0..NBVAT))
       If WK
        TABMNT(WK-1) += [F:SVF]DTAVATNOT(WI)                    : # On prend le Montant HT
        If WTYPTAXE=2 TABMNT(WK-1)+=[F:SVF]DTAVATAMT(WI) Endif  : # Si Acompte en TTC, on ajoute le montant de taxe
        TABMNTTAXE(WK-1)= TABMNT(WK-1)
       Else
        J+=1
        TABMNT(J-1) = [F:SVF]DTAVATNOT(WI)                     : # On prend le Montant HT
        If WTYPTAXE=2 TABMNT(J-1)+=[F:SVF]DTAVATAMT(WI) Endif  : # Si Acompte en TTC, on ajoute le montant de taxe
        TABTAXE(J-1)= [F:SVF]DTAVAT(WI)
        TABMNTTAXE(J-1)= TABMNT(J-1)
       Endif
     Next
  Endif
Next

Return
# 102841

# ----------------------------------------------------------------- #
# Constitution du tableau des taxes par lecture de la table PVCRVAT #
# ----------------------------------------------------------------- #
$CHARG_TABTAXE_PVV
J=0
For [PVV]PVV1 Where VCRTYP=3 & VCRNUM=NUMCDE
    If [F:PVV]VATTYP=1
        # Taxe principale
        J+=1
        TABMNT(J-1) = [F:PVV]BASTAX                     : # On prend le Montant HT
        If WTYPTAXE=2 TABMNT(J-1)+=[F:PVV]AMTTAX Endif  : # Si Acompte en TTC, on ajoute le montant de taxe
        TABTAXE(J-1)= [F:PVV]TAX
        TABMNTTAXE(J-1)= TABMNT(J-1)                    : # Bug 78172
    Endif
Next
Return

#---------------------#
#Création des acomptes #
#---------------------#
$CREA_ACOMPTE
Call ACCNUM(WACCNUM) From SUBGAS
WDUDLIG = 0
For WLIG = 1 To NECHE
# On ne traite que les acomptes et retenues de garantie
    If TYPECHE(WLIG-1) = 2 | TYPECHE(WLIG-1) = 3
       #Traitement des acomptes et retenues de garantie
       Gosub CREA_LIG
       If GOK < 1 : Break : Endif
    Endif
Next WLIG
Return

#-----------------------------
#Création de la ligne fichier#
#-----------------------------
$CREA_LIG

WRET = 0
Raz [F:DUD]

Case MODULE
     When 5 : [F:DUD]TYP = "*SO"
     When 6 : [F:DUD]TYP = "*PO"
     When Default
Endcase

[F:DUD]NUM = NUMCDE
[F:DUD]LIG = 1
WDUDLIG += 1
[F:DUD]DUDLIG = WDUDLIG
[F:DUD]ACCNUM = WACCNUM
[F:DUD]CPY    = GSOCIETE
[F:DUD]FCY    = GFINRSP
[F:DUD]CUR    = CURECH
[F:DUD]SAC    = [F:GAC]ACCSHO
[F:DUD]BPR    = TFACT
[F:DUD]BPRPAY = TPAYE
[F:DUD]BPAPAY = ADRPAY
Case MODULE
     When 5 : [F:DUD]BPRTYP = 1
     When 6 : [F:DUD]BPRTYP = 2
     When Default
Endcase
[F:DUD]DUDDAT = DATECHE(WLIG-1)
[F:DUD]PAMTYP = TYPECHE(WLIG-1)
[F:DUD]PAM    = MODECHE(WLIG-1)
[F:DUD]FLGPAZ = len(mess(0,510,1))
[F:DUD]SOI    = 1
# 71937 : Multilégislation
#Read [F:ADI]CODE = 3;[F:DUD]PAM
#If !fstat & [F:ADI]A1 <> "" : [F:DUD]SOI = 2 : Endif
#If [F:DUD]PAM <> "" : [F:DUD]SOI = 2 : Endif
Local Integer WRET
Call LEC_TAM_LEG(GCURLEG,[F:DUD]PAM,WRET) From TRTLECLEG
If WRET Raz [F:TAM] : Endif
If [F:TAM]SOI<>"" [F:DUD]SOI=2 Endif
# 71937 : Multilégislation
[F:DUD]SENINS = 1
[F:DUD]FLGFUP = 1
[F:DUD]AMTCUR = MNTECHE(WLIG-1)
Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTLOC,STAT) From TRTDEV
# à revoir V150 ????
#Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTRPT,STAT) From TRTDEV
#Pour les ventes calcule de la date d'émission prévue par soustraction
#de la valeur du paramètre à la date d'échéance
#Pour les achats la date d'émission est la date de création
[F:DUD]IBDAMT = [F:DUD]AMTCUR
If MODULE = 5
   [F:DUD]EXPSENDAT = [F:DUD]DUDDAT - GDAYNBR
   If [F:DUD]EXPSENDAT < DEPECHE
      [F:DUD]EXPSENDAT = DEPECHE
   Endif
   [F:DUD]SNS = 1
   If [F:BPC]FUPTYP > 1 : [F:DUD]FLGFUP = 2 : Endif
Else
   [F:DUD]EXPSENDAT = DEPECHE
   [F:DUD]SENDAT    = DEPECHE
   [F:DUD]SENINS    = 2
   [F:DUD]SNS       = -1
Endif
[F:DUD]DUDSTA = 0
#Récupération de la taxe à utiliser
#si aucun rang du tableau renseigné la taxe sera à espace
#Si que premier rang du tableau renseigné c'est qu'il n'y a qu'une seule taxe
WIND_TAB=J
If    TABTAXE(0) = "" :  [F:DUD]VAT = ""
Elsif TABTAXE(1) = "" :  [F:DUD]VAT = TABTAXE(0)
Else Gosub REC_TAXE
     If WRET = 1 : Gosub ECLATE_LIG : Return
     Endif
Endif

Gosub ECRIRE
Return

#-----------------------------------#
#Recherche du code taxe à appliquer #
#-----------------------------------#
$REC_TAXE
Local Integer IND
#Recherche de la taxe dont le montant cumulé couvre la totalité de l'acompte
#If sum(TABMNT)=0 [F:DUD]VAT = TABTAXE(0) Endif     : # Bug 78172
If sum(TABMNTTAXE)=0                                : # Bug 78172
    [F:DUD]VAT = TABTAXE(0)                         : # Bug 78172
Elsif sum(TABMNT)=0                                 : # Bug 78172 : La totalité des mnts de taxe a été utilisée : Acompte créé avec le code taxe EXO
    [F:DUD]VAT=GEXETAX                              : # Bug 78172
Endif                                               : # Bug 78172

#For IND = 1 To J                                   : # Bug 78172 : Partir du montant le plus élevé
For IND = J To 1 Step -1                            : # Bug 78172
    If TABMNT(IND-1) >= [F:DUD]AMTCUR & IND<=WIND_TAB
       [F:DUD]VAT = TABTAXE(IND-1)
       TABMNT(IND-1) -= [F:DUD]AMTCUR               : # Bug 78172
       Break
       Endif
Next IND

If [F:DUD]VAT = "" : WRET = 1 : Endif
Return

#------------------------------------------------------#
#aucun montant par taxe ne permet de couvrir l'acompte #
#Il faut donc éclater la ligne                         #
#------------------------------------------------------#
$ECLATE_LIG
Local Decimal WREST
$DEB
WRET = 0
WREST = [F:DUD]AMTCUR-TABMNT(WIND_TAB-1)
[F:DUD]AMTCUR = TABMNT(WIND_TAB-1)
TABMNT(WIND_TAB-1)=0                    : # Bug 78172
Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTLOC,STAT) From TRTDEV
# à revoir V150 ????
#Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTRPT,STAT) From TRTDEV
[F:DUD]IBDAMT = [F:DUD]AMTCUR
[F:DUD]VAT    = TABTAXE(WIND_TAB-1)

# On remonte le tableau des montants de taxe du plus grand au plus petit
WIND_TAB-=1
J-=1                                      : # Bug 78172
Gosub ECRIRE

WDUDLIG += 1
[F:DUD]DUDLIG = WDUDLIG
[F:DUD]AMTCUR = WREST
Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTLOC,STAT) From TRTDEV
# à revoir V150 ????
#Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTRPT,STAT) From TRTDEV
[F:DUD]IBDAMT = [F:DUD]AMTCUR
Raz [F:DUD]VAT

# Bug 49881 : Si tous les acomptes ont été créés pour chaque taxe et qu'il reste un résidu
# --> On créé un dernier acompte avec la taxe EXO
If WIND_TAB>0
    Gosub REC_TAXE
Else
    [F:DUD]VAT=GEXETAX
Endif
If WRET = 1 : Goto DEB
Else        : Gosub ECRIRE
Endif
Return

#-----------
$ECRIRE
[F:DUD]TYPDUD = 1  : #Commande
Call KEYDUD("DUD") From MODECHE
Call SLDECH("DUD")From MODECHE
Local Decimal EXERCICE, PERIODE
Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
[F:DUD]FIY = EXERCICE
[F:DUD]PER = PERIODE
If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
GPE=0 : GPOINT="BEFDUDCRE" : Gosub ENTREE From EXEFNC
If !GPE
 Write [DUD]
 If fstat : GOK = 0 : Call FSTA("DUD") From GLOCK : Endif
Endif
Call HISTOECH("DUD",1,DEPECHE)From MODECHE
Return

#---------------------------------------------#
#Suppression des acomptes liés à une commande #
#---------------------------------------------#
$SUPP_ACOMPTES
Case MODULE
     When 5 : ## Historisation des échéances supprimées
              CRITSUPPR="TYP='*SO' & NUM='"+NUMCDE+"'"
              Call HISTOSUPPR (CRITSUPPR) From MODECHE
              Delete [F:DUD] Where TYP = "*SO" & NUM = NUMCDE
     When 6 : ## Historisation des échéances supprimées
              CRITSUPPR="TYP='*PO' & NUM='"+NUMCDE+"'"
              Call HISTOSUPPR (CRITSUPPR) From MODECHE
              Delete [F:DUD] Where TYP = "*PO" & NUM = NUMCDE
     When Default
Endcase
If fstat = 1 : GOK = 0 : Return : Endif
Return

#-------------------------------------------------------------#
# Controle des acomptes                                       #
# Module vente : 0 : Acomptes versés pour la cde              #
#                1 : Acomptes pour la cde                     #
#                2 : Acomptes émis pour la cde                #
#                3 : Pas d'acomptes pour la cde               #
# Module achat : 0 : Acomptes versés pour la cde              #
#                1 : Acomptes pour la cde                     #
#                3 : Pas d'acomptes pour la cde               #
#-------------------------------------------------------------#
$CONT_ACOMPTES
OK=1
Case MODULE
     When 5 : Filter [F:DUD] Where TYP="*SO" & NUM=NUMCDE
              Read [DUD] First
              If fstat  OK=3 : Goto CA_FIN   Endif
              Filter [F:DUD] Where TYP="*SO" & NUM=NUMCDE & SENINS=2 & SENDAT<>[0/0/0] & PAYCUR=0 & TMPCUR=0
              Read [DUD] First
              If !fstat  OK=2 : Goto CA_FIN  Endif
              Filter [F:DUD] Where TYP="*SO" & NUM=NUMCDE & (PAYCUR <> 0 | TMPCUR <> 0)
     When 6 : Filter [F:DUD] Where TYP="*PO" & NUM=NUMCDE
              Read [DUD] First
              If fstat  OK=3 : Goto CA_FIN   Endif
              Filter [F:DUD] Where TYP="*PO" & NUM=NUMCDE & (PAYCUR <> 0 | TMPCUR <> 0)
     When Default
Endcase
Read [DUD] First
If !fstat GERR=1 : GMESSAGE = mess(70,196,1) : OK=0 : Endif
$CA_FIN
Filter [DUD]
Return


####################################################
# Subprog VERF_ACOMPTE_ACTIF (MODULE,NUMCDE,OK)    #
# ------------------------------------------------ #
# Controle si acomptes actifs en solde de commande #
#   MODULE : 5 = Ventes,  6 = Achats               #
#   NUMCDE : Numéro de la commande soldée          #
#                                                  #
#   OK     : Code retour                           #
#            1 = Pas d'acomptes actifs             #
#            0 = Il reste des acomptes actifs      #
####################################################
Subprog VERF_ACOMPTE_ACTIF (MODULE,NUMCDE,OK)
Value    Integer MODULE
Value    Char    NUMCDE
Variable Integer OK
#-----
If !clalev([F:DUD])  Local File GACCDUDATE [DUD] : Endif
OK=1
Case MODULE
  When 5 : Filter [F:DUD] Where TYP="*SO" & NUM=NUMCDE & AMTCUR>PAYCUR+TMPCUR
  When 6 : Filter [F:DUD] Where TYP="*PO" & NUM=NUMCDE & AMTCUR>PAYCUR+TMPCUR
Endcase
Read [DUD] DUD0 First
#----- Commande soldée, il reste des acomptes actifs -----#
If !fstat  OK=0 : Endif
Filter [DUD]
End


############################################################################
# Subprog MODACOMPTES (MODULE,NUMCDE)                                   #
#-----------------------------------------------------------------------#
#  Permet de modifier les acomptes liés à une commande achat ou vente   #
#  MODULE    : Achat/Vente                                              #
#  NUMCDE    : Numéro de commande                                       #
#  IMPR      : Impression des acomptes OUI/NON                          #
#  DOCNAM    : Nom du document                                          #
#########################################################################
Subprog MODACOMPTES (MODULE,NUMCDE,IMPR,DOCNAM)
Value    Integer MODULE
Value    Char    NUMCDE
Value    Integer IMPR
Value    Char    DOCNAM

GNUMCDE = "" : GSNSNAM = "" : GTYP    = ""
GMODULE = 0  : GSNSFLG = 0  : GACCNUM = 0

Local Integer WDUDLIG, OK, NBTEX, STAT
Local Decimal WMONTANT
Global Integer TYPCOURS
Global Char  TFACT(GLONBPR), TPAYE(GLONBPR), ADRPAY(GLONADR)
Global Date    DEPECHE
Local Char TEXTE(15)(10),CHAINE(10), REP(1)
If !clalev([F:ADP]) Local File ADOPAR [ADP] Endif
If !clalev([F:ADW]) Local File ADOVAL [ADW] Endif
Local Char    PARAM(10)
Local Integer WDRAPEAU
Raz WDRAPEAU

## Historisation des échéances supprimées
Local Char CRITSUPPR (250)

GSNSFLG = 1

Raz GFONEMI
GMODULE = MODULE
If NUMCDE <> "" : GNUMCDE = NUMCDE
                  GSNSNAM = DOCNAM
                  GSNSFLG = IMPR
                  Gosub SAUV_GLOB From TRTX3GLOB
Else              GORDCAT = 4
Endif

#Ouverture des fichier nécessaires
If clalev ([F:DUD]) <= 0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif
If clalev([F:CAC])<=0 : Local File GACCCODE [CAC] : Endif
If clalev([F:GAC])<=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:TPT])<=0 : Local File TABPAYTERM [TPT] : Endif
If clalev([F:ADI])<=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:TAM])<=0 : Local File TABPAM  [TAM] : Endif      : # 71937 : Multilégislation

Case MODULE
     When 5 : If clalev ([F:SOH]) <= 0 : Local File SORDER [SOH] : Endif
              If clalev ([F:BPC]) <= 0 : Local File BPCUSTOMER [BPC] : Endif
              GTYP = "*SO"
     When 6 : If clalev ([F:POH]) <= 0 : Local File PORDER [POH] : Endif
              If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
              GTYP = "*PO"
     When Default
Endcase
Local Mask DUDX [DIA]
Default File [DUD]

#--------------------------------------------------------#
#Proposition en tableau des lignes à traiter             #
#--------------------------------------------------------#
Raz [M:DIA]

Gosub ALIM_DIA
Affzo [M:DIA]10

$SAI
Local Char WIN (GLONFEN)
WIN="DDUDX"
OK=2 : Call DIALWIN(OK,mess(40,195,1),WIN) From GESECRAN

If OK <> 2 : End : Endif
Call DEBTRANS From GLOCK
Gosub ECRIRETOUT
If GOK < 1 : Goto SAI : Endif

$FIN
If MODULE = 5 & WDRAPEAU = 1 & IMPR =2
     Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

#    Si on vient de la gestion des acomptes, il faut positionner GNUMCDE pour imprimer
     If GFONEMI="VEN" GNUMCDE=[M]NUM : Endif
     DOCNAM=[M]SNSNAM
     Call ETAT(DOCNAM,"GESSOH",TBPAR,TBVAL) From ETAT
Endif
Close Mask [DIA]
#Si on vient de la gestion des commande, il ne faut SURTOUT PAS "killer"
#le paramètre GDAYNBR puisque ce n'est pas nous qui l'avons créé.
#-- cg le 27 novembre 98 on ne doit plus killer les var
#If GMODULE = 5 & GNUMCDE = "" : GDAYNBR = 0 : Endif
#If GNUMCDE <> "" : Gosub REST_GLOB From TRTX3GLOB : Endif

If GMODULE = 5 & GFONEMI= "VEN" : GDAYNBR = 0 : Endif
If GFONEMI = "VEN" Gosub REST_GLOB From TRTX3GLOB : Endif

Raz TFACT,TPAYE,ADRPAY,TYPCOURS,DEPECHE

End

#----------------------------------------#
#Lecture des acomptes liés à la commande #
#et chargement en tableau                #
#----------------------------------------#
$LIRE
nolign = 0
#Proposition en tableau des acomptes liés à la commande
Filter [F:DUD] Where TYP = GTYP & NUM = [M:DIA]NUM

For [F:DUD]
       nolign += 1
       [M:DIA] = [F]
       [M:DIA]DCUR(nolign-1) = [F]CUR
       [M:DIA]AEMETTRE(nolign-1) = 1
       If GACCNUM = 0 : GACCNUM = [M:DIA]ACCNUM(nolign-1) : Endif
Next
Filter [DUD]
[M:DIA]NBLIG = nolign

#Affzo [M:DIA]10
Return

#------------------------------------------------------#
#En validation du tableau suppression puis recréation  #
#de tous les acomptes liés à la commande               #
#------------------------------------------------------#
$ECRIRETOUT
GOK = 1
Trbegin [DUD]
WDUDLIG = 0
## Historisation des échéances supprimées
CRITSUPPR="TYP='"+GTYP+"' & NUM='"+[M]NUM+"'"
Call HISTOSUPPR (CRITSUPPR) From MODECHE
##
Delete [F:DUD] Where TYP = GTYP & NUM = [M]NUM
For nolign = 1 To [M]NBLIG
 [F] = [M]
 [F:DUD]TYP = GTYP
 [F:DUD]LIG = 1
 WDUDLIG += 1
 [F:DUD]DUDLIG = WDUDLIG
 [F:DUD]CPY    = GSOCIETE
 [F:DUD]FCY    = GFINRSP
 [F:DUD]FLGFUP = 1
 [F:DUD]FLGPAZ = len(mess(0,510,1))
 [F:DUD]SOI    = 1
 # 71937 : Multilégislation
 #Read [F:ADI]CODE = 3;[F:DUD]PAM
 #If !fstat & [F:ADI]A1 <> "" : [F:DUD]SOI = 2 : Endif
 Local Integer WRET
 Call LEC_TAM_LEG(GCURLEG,[F:DUD]PAM,WRET) From TRTLECLEG
 If WRET Raz [F:TAM] : Endif
 If [F:TAM]SOI<>"" [F:DUD]SOI=2 Endif
 # 71937 : Multilégislation
 If GACCNUM <> 0
    [F:DUD]ACCNUM = GACCNUM
 Else
    Call ACCNUM([F:DUD]ACCNUM) From SUBGAS
    GACCNUM = [F:DUD]ACCNUM
 Endif
 [F:DUD]BPR = TFACT
 [F:DUD]BPRPAY = TPAYE
 [F:DUD]BPAPAY = ADRPAY
 [F:DUD]SAC = [F:GAC]ACCSHO
 Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTLOC,STAT) From TRTDEV
 # à revoir V150 ????
 #Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,TYPCOURS,DEPECHE,[F:DUD]AMTCUR,[F:DUD]AMTRPT,STAT) From TRTDEV
 If GMODULE = 6
    [F:DUD]SENINS = 2
    If [F:DUD]EXPSENDAT = [0/0/0]
      [F:DUD]EXPSENDAT = date$
    Endif
    [F:DUD]SENDAT = date$
    [F:DUD]CUR    = [F:POH]CUR
    [F:DUD]SNS    = -1
    [F:DUD]BPRTYP =  2   # Fournisseur
 Else
# ld : 20/02/01 dde 8049
    If [F:DUD]EXPSENDAT = [0/0/0]
        [F:DUD]EXPSENDAT = [F:DUD]DUDDAT - GDAYNBR
        If [F:DUD]EXPSENDAT < date$ : [F:DUD]EXPSENDAT = date$ : Endif
    Endif
    [F:DUD]CUR       = [F:SOH]CUR
    [F:DUD]SNS       = 1
    If [F:BPC]FUPTYP > 1 : [F:DUD]FLGFUP = 2 : Endif
    [F:DUD]BPRTYP =  1   # Client
 Endif
    #Appui sur bouton émission
 If [M]AEMETTRE(nolign-1) = 2
    [F:DUD]SENINS = 2
    [F:DUD]SENDAT = date$
    WDRAPEAU = 1
 Endif
 [F:DUD]TYPDUD = 1  : #Commande
 Call KEYDUD("DUD") From MODECHE
 Call SLDECH("DUD")From MODECHE
 Local Decimal EXERCICE, PERIODE
 Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
 [F:DUD]FIY = EXERCICE
 [F:DUD]PER = PERIODE
 If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
 If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
 GPE=0 : GPOINT="BEFDUDUPD" : Gosub ENTREE From EXEFNC
 If !GPE
  Write [DUD]
  If fstat : GOK = 0 : Call FSTA("DUD") From GLOCK : Break : Endif
 Endif

 Call HISTOECH("DUD",1,DEPECHE)From MODECHE
Next nolign

$TRT_ERR
If    GOK < 0 : Goto TR_ROLL
Elsif GOK = 0 : Goto AB_CREAT
Endif
Commit

$FIN_CREAT
Return

$TR_ROLL
Rollback
Call ROLL From GLOCK
Goto FIN_CREAT

$AB_CREAT
Rollback
Goto FIN_CREAT

