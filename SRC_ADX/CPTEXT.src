#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTEXT","CPTEXT",4,"") From GTRAITE
End
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

########################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif

If FIN : Return : Endif
Local Integer OK
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return

#######################################################
$OUVRE
Gosub OUVFIC
Local Mask CPTEXT [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp2") From GMEMO

Local Mask GACCENTFMT  [SVGF]        # To save the HAEF mask in the netting context before the unmatching
Local Mask GACCENTW    [SVGW]        # To save the HAEW mask in the netting context before the unmatching

Local Mask GACCENTFMT  [HAEF]        # Ouverture du masque pour diverses informations
Local Mask GACCENTW    [HAEW]        # Ouverture du masque pour la gérer les lignes de pièces comtpables.
Local Mask SAICURLED   [SCL]         # Ouverture du masque pour la gestion des devises

# Pour les avoir par défaut
Local Mask GACCENT0 [HAE0],  GACCENT1 [HAE1],   GACCENT2 [HAE2]
&        , VENTILE  [VTL] ,  VENTILE2 [VT2] , GACCDUD [DUDD]

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Integer I, J, K, OK, NOL,NOLI, GENEURO
Local Char    CRITERE(250), CRITEREJ(250)
Local Integer NBPCE
Local Integer STAT
Local Char    TIT(50)
Local Char    MESSA(250)
Local Char    SYMBOLE(50)
Local Char    TYP(GLONGTE) , NUM(GLONVCR)
Local Char    SOCIETE(GLONCPY)

Local Integer MAXLIG , MAXVTL , NBR_ECH , OKPCE
MAXLIG = dim([M:HAEW]ACC)
MAXVTL = dim([M:VTL]AMT)
NBR_ECH = dim([M:DUDD]DUDDAT)+1
Local Decimal AROLOC , ARORPT
Local Integer INDREF, NBLET , TBLET(1..NBR_ECH) , DUDLIG(1..NBR_ECH)
Local Decimal AMTIPT(1..NBR_ECH)
Local Char TYPORG(GLONGTE)
Local Char PCEORG(GLONVCR)
Local Char VLEG(GLONADI)
## For the netting
Local Decimal AMTIPT2(1..NBR_ECH)
Local Integer NET , FLGCURCPY
Local Char    CHKCUR(GLONCUR), SVGTYPPCE(GLONGTE), SVGNUMPCE(GLONVCR)

Local Integer CALL_PT : Raz CALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CPTEXT",GENTSTD(1..GNBENTREE)) : CALL_PT=1 : Endif

TIT = mess(9,107,1) : # Extournes automatiques
Return

$OUVFIC
Local File GACCOUNT   [GAC],  GAJOUSTA   [JST]
&        , COMPANY    [CPY],  COMPANY    [CPY2]
&        , FACILITY   [FCY],  FACGROUP   [FGR]
&        , TABCUR     [TCU],  TABCHANGE  [TCH]
&        , GDIAENTRY  [GDE],  GDIAENTRYD [GDD]
&        , TABACCLIK  [TCK]
&        , GTYPACCENT [GTE],  CADSP      [DSP]
&        , GACCENTRY  [HAE]
&        , GACCENTRYD [DAE],  GACCENTRYA [DAA]
&        , AVALNUM    [AVN],  ACODNUM    [ANM]
&        , FISCALYEAR [FIY],  PERIOD     [PER]
&        , GJOURNAL   [JOU],  TABUNIT    [TUN]
&        , GACCENTRY  [HA2],  MTCBATCH   [MTB]
&        , GACCDUDATE [DUD],  GACM       [GCM]
&        , GJOURNAL   [JOU2]
Return

#######################################################
$EXEC
If GSERVEUR
 [M:DIA]TRC = 2
Endif
If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Reinit de GCURLEG car qd on lance la validation on passe de GSAISE à GTRAITE et
# on perd le GCURLEG initialisé par CPTTRT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

CRITERE = "RVS=2"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITERE -= '& TYP = "'+[M:DIA]TYP+'"'
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR = "'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR = "" & CREUSR = "'+[M:DIA]USR+'"))'
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE -= '& RVSDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE -= '& RVSDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif
Filter [HA2] Where evalue(CRITERE)

CRITEREJ = "1=1"
If [M:DIA]ALLTYPJOU<>2
 CRITEREJ -= "& TYP ="-num$([M:DIA]TYPJOU)
Endif
If [M:DIA]ALLJOU<>2
 CRITEREJ -= '& JOU = "'+[M:DIA]JOU+'"'
Endif
Filter [JOU] Where evalue(CRITEREJ)

# Boucle sur les sociétés
If [M:DIA]ALLCPY=2
 For [CPY2] Where CPYLEGFLG=2 & LEG=GCURLEG
  SOCIETE = [F:CPY2]CPY
  Gosub TRTSOC
 Next
Else
 SOCIETE = [M:DIA]CPY
 If [F:CPY2]CPY<>SOCIETE
  Read [CPY2]CPY0 = SOCIETE
 Endif
 Gosub TRTSOC
Endif

Filter [JOU]
Filter [HA2]

If !NBPCE
 Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

#######################################################
$TRTSOC
For [JOU]JOU0(1)
 VLEG = [F:CPY2]LEG
 Look [JOU2]JOU0=[F:JOU]JOU;VLEG
 If fstat
  Raz VLEG
 Endif
 For [JOU]JOU0(2)
  If [F:JOU]LEG=VLEG
   GOK=1
   Gosub TRTEXT
   If GOK<1 & GTRACE<>""
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Rollback
   Endif
  Endif
 Next
Next
Return

#######################################################
$TRTEXT
Call CONTEXE([F:JOU]ACS) From CPTSUB

If mkstat
 If GTRACE<>""
  Call ECR_TRACE([F:JOU]JOU-GMESSAGE,1) From GESECRAN
 Endif
 Return
Endif

For [HA2]HAE1 Where CPY=[L]SOCIETE & JOU=[F:JOU]JOU
 OK = 1
 Call CONTFCY([F:HA2]FCY) From CPTSUB
 If mkstat : OK = 0 : Endif
 If OK=1 & [M:DIA]ALLTYP=2
  Call LEC_GTE_LEG(GCURLEG,[F:HA2]TYP) From CPTLEC
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If mkstat : OK = 0 : Endif
 Endif

#ISSUE 75463 - MNO
 If func AFNC.ACTIV("FIFRC")
   If func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_HAE([F:HA2]NUM, [F:HA2]CPY) = 0
    Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM,0) From GESECRAN
    Call ECR_TRACE(mess(14,7708,1),1) From GESECRAN
    OK=0
   Endif
 Endif
#ISSUE END 75463 - MNO
 If dim(CALL_PT)>0 & CALL_PT & OK=1 : GPOINT = "FLTHAE" : Gosub ENTREE From EXEFNC : Endif
 If OK
  OKPCE = 0
  NBPCE += 1
  SYMBOLE = "HAE"+[F:HA2]NUM+"\"+[F:HA2]TYP
  Lock =SYMBOLE With lockwait=0
  If fstat=1
   If GTRACE<>""
    Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,100,1),1) From GESECRAN
   Endif
  Else
   Call DEBTRANS From GLOCK
   Gosub TR1
   If GOK=1 & !STAT & OKPCE
    If GTRACE<>""
     If NET=1
      # In the case of a reversal of a netting journal that has also reversed an exchange rate variance journal
      # we want first to display in the log file, the reversal journal
      # Dans le cas d'une extourne de pièce de netting qui a aussi généré une extourne de pièce d'écart de change
      # On veut d'abord afficher dans la trace la pièce d'extourne
      # Pièce extournée
      Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,107,1)-SVGTYPPCE-SVGNUMPCE,0) From GESECRAN
      If (SVGTYPPCE<>GTYPPCE | SVGNUMPCE<>GNUMPCE)
       # The reversal operation has posted another journal
       # Création pièce
       Call ECR_TRACE(mess(40,107,1)-GTYPPCE-GNUMPCE,0) From GESECRAN
      Endif
     Else
      # Pièce extournée
      Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,107,1)-GTYPPCE-GNUMPCE,0) From GESECRAN
     Endif
    Endif
    Call ESPION("GACCENTRY",1,[F:HAE]TYP,[F:HAE]NUM) From ESPION
   Endif
   Unlock =SYMBOLE
  Endif
 Endif
Next

Return

$TR1
GOK=1
Trbegin  [HAE], [HA2], [DAE], [DAA], [AVN]
 Readlock [HAE]HAE0 = [F:HA2]TYP ; [F:HA2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRY"+[F:HA2]TYP-[F:HA2]NUM : Goto ROL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("HAE",[F:HA2]TYP-[F:HA2]NUM) From GLOCK : Goto AB_TR1
 Endif
 If [F:HAE]RVS=2
  Gosub GENECR
  OKPCE=1
 Endif
 If    GOK<0 : Goto ROL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
Commit

#YYFIN_117536 déplacé depuis GENECR
### CREATION DE LA DEPENSE DANS FRP FA
If GMODU(14)=2 : # Présence du module Immobilisation
  #-----------------------#
  # Dépense immobilisable #
  #-----------------------#
  Local Char MESSA(250)
  Call CREDEP("HAE", MESSA) From SUBLOF2
  If !GOK
   GMESSAGE = MESSA
  Endif
Endif

Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$GENECR
# Chargement écrans
Raz [M:HAE0], [M:HAE1], [M:HAE2]

[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]

TYP = [F:HAE]TYP
NUM = [F:HAE]NUM

Gosub LIENS From SUBGAS

#119323
Local Decimal  SAVACCNUM(1..dim([M:HAEW]ACCNUM))
Local Decimal  SAVLINREF(1..dim([M:HAEW]ACCNUM))
# For the line to reverse with IDTLIN=LIAIS, storage of [M:HAEW]accnum and [M:HAEW]linref
I = 0
Raz SAVACCNUM, SAVLINREF
For NOL=0 To [M:HAEW]NB-1
 If [M:HAEW]IDTLIN(NOL)="LIAIS"
  I +=1
  SAVACCNUM(I) = [M:HAEW]ACCNUM(NOL)
  SAVLINREF(I) = [M:HAEW]LINREF(NOL)
 Endif
Next

[M:HAE0]NUM = ""
[M:HAE0]ACCDAT = [M:HAE1]RVSDAT

[M:HAE1]RVSORITYP=TYP
[M:HAE1]RVSORINUM=NUM
[M:HAE1]ENTDAT = [M:HAE0]ACCDAT
[M:HAE1]DUDDAT = [M:HAE0]ACCDAT
[M:HAE1]VALDAT = [M:HAE0]ACCDAT
[M:HAE1]RVS = 1
[M:HAE1]RVSDAT = [0/0/0]
[M:HAE1]ORIMOD = 2


#--- Libellé par défaut de la pièce d'extourne : on remplace le car. '*' par TYP-NUM
K = instr(1,mess(92,106,1),"*")
If K
 #--- TYP NUM extournée
 [M:HAE1]DESVCR = left$(mess(92,106,1),K-1) + TYP-NUM + right$(mess(92,106,1),K+1)
Endif


## La gestion des pièces en devise IN /OUT
Raz GENEURO
If [M:HAE1]CUR<>GEURO
 Call LEC_TCU([M:HAE1]CUR) From CPTLEC
 # Date de validité
 If [F:TCU]EURFLG=2 & [M:HAE0]ACCDAT>=[F:TCU]CURENDDAT
  Call LECLED([F:HA2]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
  If DEVLED = GEURO
   GENEURO = 1
   [M:HAE1]CUR = GEURO
  Else
   # La société n'est pas passée à l'Euro
   MESSA = "("+[M:HAE0]CPY+")"-mess(99,106,1)
   If GTRACE<>""
     Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-MESSA,1) From GESECRAN
   Endif
  Endif
 Endif
Endif

Default Mask [M:HAE2]
For NOL=0 To [M:HAE2]NBLIG-1
 Case [M:DIA]EXTSNS
  When 1 : # Débit <=> crédit
   If [M]DEB(NOL)<>0
    [M]CDT(NOL) = [M]DEB(NOL)
    [M]DEB(NOL) = 0
    If GENEURO : [M]CDT(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
   Elsif [M]CDT(NOL)<>0
    [M]DEB(NOL) = [M]CDT(NOL)
    [M]CDT(NOL) = 0
    If GENEURO : [M]DEB(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
   Endif
  When 2 : # Montant <=> montant <0
   [M]DEB(NOL) = -[M]DEB(NOL)
   [M]CDT(NOL) = -[M]CDT(NOL)

   If GENEURO
     [M]DEB(NOL) = -[M]AMTLED(NOL)
     [M]CDT(NOL) = -[M]AMTLED(NOL)
     Assign "[M]DEB("+num$(NOL)+")" With - evalue("[M]AMT"+num$([M]LEDTYP)+"("+num$(NOL)+")")
   Endif

   If dim([M]QTY)>0
    [M]QTY(NOL) = -[M]QTY(NOL)
   Endif
   If [M]DSP(NOL)="$"
    For I=[M]PTV(NOL) To [M]PTF(NOL)
     [M:VT2]TBAMT(I) = -[M:VT2]TBAMT(I)
     [M:VT2]TBQTY(I) = -[M:VT2]TBQTY(I)
    Next I
   Endif
 Endcase

 If ([M]DEB(NOL)=0 & [M]CDT(NOL)=0) or [M:DIA]EXTSNS=2

  For I=1 To len(mess(0,2644,1))
   Assign "[M]AMT"+num$(I)+"("+num$(NOL)+")" With - evalue("[M]AMT"+num$(I)+"("+num$(NOL)+")")
   Assign "[M]AMTFRC"+num$(I)+"("+num$(NOL)+")" With - evalue("[M]AMTFRC"+num$(I)+"("+num$(NOL)+")")
  Next

 Endif

Next NOL
Raz [M:HAE2]ACCNUM, [M:HAE2]CHRNUM, [M:HAE2]CHK, [M:HAE2]CHKDAT
Raz [M:HAE2]MTC, [M:HAE2]MTCDAT, [M:HAE2]MTCDATMAX, [M:HAE2]MTCDATMIN
Raz [M:HAE2]AMTVAT

# Contrôles écran
Local Mask [M:HAE0],[M:HAE1],[M:HAE2]
Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
 Gosub MESSAGE From CPTAUTO
 If GTRACE<>""
  Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-MESSA,1) From GESECRAN
 Endif
 Return
Endif

# Mise à jour pièce d'origine
[F:HAE]RVS = 3   : # Extournée
TYPORG = [F:HAE]TYP : PCEORG = [F:HAE]NUM
Rewrite [HAE]
If fstat
 GOK=0 : Call FSTA("HAE") From GLOCK : Return
Endif

# Reversal of a netting journal entry
NET = 0
If left$([F:HAE]REFINT,5)="NETLI" : NET = 1 : Endif

# Ecriture de la pièce
Call VALPIECE

# BP Netting
If NET=1
 # In the case of a reversal of a netting journal that also reverses an exchange rate variance journal
 # GTYPPCE et GNUMPCE will be erased. We want to store the references of the reversal journal
 # Dans le cas d'une extourne de pièce de netting qui génèré une extourne de pièce d'écart de change
 # GTYPPCE et GNUMPCE seront écrasées. On veut conserver les références de la pièce d'extourne
 SVGTYPPCE = GTYPPCE
 SVGNUMPCE = GNUMPCE
Endif

If clalev([F:DAEX])=0 : Local File GACCENTRYD [DAEX] : Endif
If clalev([F:DATX])=0 : Local File GACCTMPD   [DATX] : Endif

# BP Netting
If NET=1
 If clalev([F:DUDY])=0 : Local File GACCDUDATE [DUDY] : Endif
 If clalev([F:DAEY])=0 : Local File GACCENTRYD [DAEY] : Endif
 If clalev([F:HAEY])=0 : Local File GACCENTRY  [HAEY] : Endif
 If clalev([F:NTO])=0  : Local File NETAUTO    [NTO]  : Endif

 Raz NBLET, TBLET, DUDLIG, AMTIPT, AMTIPT2, FLGCURCPY
 For NOL=0 To [M:HAEW]NB-1
  INDREF = [M:HAEW]LEDTYP(NOL)
  If [M:HAEF]GENC(INDREF-1) = 2 & [M:HAEF]MTC(INDREF-1) = 2
   Call LEC_GAC([M:HAEW]ACC(NOL),[M:HAEW]COA(NOL)) From CPTLEC
   If !fstat & [F:GAC]MTC=2
    # Search the netting journal entry and save the data for the unmatching
    Read [DAEX]DAE0 = TYPORG;PCEORG;[M:HAEW]LIN(NOL);INDREF
    If !fstat
     # Is the netting open item being matching?
     # It's the case when we reverse 2 netting journal that net two different open items of the same BP invoice
     # L'échéance de compensation est-elle en cours de lettrage ?
     # Cas où on extourne 2 pièces de compensation qui chacune compensait une echéance d'une même facture
     Filter [MTB] Where ACCNUM=[F:DAEX]ACCNUM & DUDLIG=1
     Look [MTB]MTB0 First
     Filter [MTB]
     If !fstat
      If GTRACE<>""
       Call ECR_TRACE(mess(70,119,1)-[F:DAEX]TYP-[F:DAEX]NUM-num$([F:DAEX]LIN),1) From GESECRAN :# Echéance en cours de lettrage
      Endif
      GOK = 0 : Break
     Endif

     If [F:DAEX]MTC<>""

      # Open items are created on the general ledger
      If INDREF=GTYPGEN
       # Search the open item netted with the netting journal entry ([F:NTO]ACCNUM-[F:NTO]DUDLIG)
       Read [NTO]NTO2=[F:DAEX]ACCNUM
       If !fstat
        # Save in TBLET the open items that belong to the same matching group than the netting journal entry
        # except the open item netted with the netting journal entry and the open item of the netting journal entry
        # and the "MTC" journal entry
        # TBLET allows the matching (LETDIF2) after the unmatching

        Link [DAEY] With [DUD]DUD1(1)=[F:DAEY]ACCNUM,[HAEY]HAE0=[F:DAEY]TYP;[F:DAEY]NUM
&       As [LNK]
&       Where [F:DAEY]LEDTYP=[F:DAEX]LEDTYP & [F:DAEY]ACC=[F:DAEX]ACC & [F:DAEY]BPR=[F:DAEX]BPR &
&             [F:DAEY]MTC=[F:DAEX]MTC & [F:DAEY]FCYLIN=[F:DAEX]FCYLIN & [F:DAEY]ACCNUM<>[F:DAEX]ACCNUM &
&             [F:DUD]FLGCLE<>1 & left$([F:HAEY]REFINT,3)<>"MTC"

        Raz NBLET, TBLET, DUDLIG, AMTIPT, AMTIPT2, CHKCUR, FLGCURCPY

        For [LNK]
          # Pour le lettrage - For the matching
         If [F:DUD]ACCNUM=[F:NTO]ACCNUM & [F:DUD]DUDLIG=[F:NTO]DUDLIG :# Echéance de la facture compensée
          Read [DUDY]DUD1=[F:DAEX]ACCNUM;1 :# L échéance de l'écriture de compensation- open item of the netting journal entry
          If !fstat & [F:DUD]PAYCUR-[F:DUDY]AMTCUR<>0
           Gosub MAJTBLET
           AMTIPT(NBLET)  = [F:DUD]PAYLOC-[F:DUDY]AMTLOC
           AMTIPT2(NBLET) = [F:DUD]PAYCUR-[F:DUDY]AMTCUR
          Endif
         Else
          Gosub MAJTBLET
          AMTIPT(NBLET)  = [F:DUD]PAYLOC
          AMTIPT2(NBLET) = [F:DUD]PAYCUR
         Endif
        Next
       Endif
      Endif

      # Unmatching the netting matching group
      Raz [M:SVGF]
      Raz [M:SVGW]
      [M:SVGF] = [M:HAEF]
      [M:SVGW] = [M:HAEW]
      Call DELETTRE([F:DAEX]CPY,[F:DAEX]FCYLIN,[F:DAEX]LEDTYP,[F:DAEX]ACC,[F:DAEX]BPR,[F:DAEX]MTC) From DELETTRAGE
      [M:HAEF] = [M:SVGF]
      [M:HAEW] = [M:SVGW]
      If GOK<=0 : Break : Endif

      If INDREF=GTYPGEN & NBLET>0
       # Match the group
       # TBLET stores the accnums of the general ledger. LETDIF2 matches all the ledgers
       Case FLGCURCPY
        When 1 : Call LETDIF2(NBLET,TBLET,DUDLIG,AMTIPT,-1) From CPTLET
        When 2 : Call LETDIF2(NBLET,TBLET,DUDLIG,AMTIPT2,-2) From CPTLET
       Endcase
       Raz NBLET, TBLET, DUDLIG, AMTIPT, AMTIPT2
       If GOK<=0 : Break :  Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Next NOL
 If GOK<=0 : Return :  Endif

Endif

# Lettrage avec écriture d'origine
For NOL=0 To [M:HAEW]NB-1
 INDREF = [M:HAEW]LEDTYP(NOL)
 If [M:HAEF]GENC(INDREF-1) = 2 & [M:HAEF]MTC(INDREF-1) = 2
  Call LEC_GAC([M:HAEW]ACC(NOL),[M:HAEW]COA(NOL)) From CPTLEC
  If !fstat & [F:GAC]MTC=2
   NBLET = 2
   #119323
   If [M:HAEW]IDTLIN(NOL)="LIAIS"
    I = find([M:HAEW]LINREF(NOL),SAVLINREF)
    If I>0
     Read [DAEX]DAE2=SAVACCNUM(I)
    Endif
   Else
    Read [DAEX]DAE0 = [L]TYP;[L]NUM;[M:HAEW]LIN(NOL);INDREF
   Endif
   If !fstat
    TBLET(1)  = [F:DAEX]ACCNUM
    DUDLIG(1) = 1
    AMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
   Else
    #119323
    If [M:HAEW]IDTLIN(NOL)="LIAIS"
     If I>0
      Read [DATX]DAT1 = SAVACCNUM(I)
     Endif
    Else
     Read [DATX]DAT0 = [L]TYP;[L]NUM;[M:HAEW]LIN(NOL);INDREF
    Endif
    If !fstat
     TBLET(1)  = [F:DATX]ACCNUM
     DUDLIG(1) = 1
     AMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
    Endif
   Endif
   TBLET(2)  = [M:HAEW]ACCNUM(NOL)
   DUDLIG(2) = 1
   AMTIPT(2) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
   Call LETDIF(NBLET,TBLET,DUDLIG,AMTIPT,2) From CPTLET
   If GOK<1 : Break : Endif
  Endif
 Endif
Next NOL
If GOK<=0 : Return : Endif

#YYFIN_117536 déplacé après le commit en TR1
### CREATION DE LA DEPENSE DANS FRP FA
#If GMODU(14)=2 : # Présence du module Immobilisation
#  #-----------------------#
#  # Dépense immobilisable #
#  #-----------------------#
#  Local Char MESSA(250)
#  Call CREDEP("HAE", MESSA) From SUBLOF2
#  If !GOK
#   GMESSAGE = MESSA
#  Endif
#Endif

Return

$MAJTBLET
NBLET +=1
TBLET(NBLET)   = [F:DUD]ACCNUM
DUDLIG(NBLET)  = [F:DUD]DUDLIG
If CHKCUR=""
 CHKCUR = [F:DUD]CUR
 FLGCURCPY = 2 : # Matching with the currency of the transaction
Elsif CHKCUR <> [F:DUD]CUR
 FLGCURCPY= 1  : # Matching with the company currency
Endif
Return

Subprog VALPIECE
Local Integer STAT
Local Char    MESSA(80)
Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795

TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
TZONE(6)= "ORICOD" : TVAL(6)= "CPTEXT"                        #*X3-39795

Local File GACCTMP [HAE] , GACCTMPD [DAE] , GACCTMPA [DAA]

#*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
If STAT
 If GTRACE<>""
  Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-MESSA,1) From GESECRAN
 Endif
Endif
End

