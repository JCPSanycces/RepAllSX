#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet PAC
Raz GPILOBJ
Call OBJET("PAC",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "ANNULE"      : Gosub ANNULE
 When "FERME"       : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
If clalev([F:HRREP])=0  : Local File REPART   [HRREP] : Endif
If clalev([F:FDS])=0    : Local File FONDS    [FDS]   : Endif
If clalev([F:TCA])=0    : Local File TABCOUAFF[TCA]   : Endif
If clalev([F:PAC])=0    : Local File PARCOL   [PAC]   : Endif
If clalev([F:PAI])=0    : Local File PARIND   [PAI]   : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$APRES_MODIF
If [M]STA=3 & COUZON<>"NUMPAR" & REP<>"D" : # Répartition Validée
 GMESSAGE = mess(9,123,1) : # Modification impossible
 OK =0
Endif
Return

########################################
$INICRE
If [F:PAC]NUMPAR=""
 Local Char    COMPTEUR(5)
 Local Integer STAT

 Read[F:CPY]CPY0=[F:PAC]CPY
 GSOCIETE=[F:CPY]CPY
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Else
  If dim([F:CPY]LEG)>0
    GCURLEG =[F:CPY]LEG
  Endif
 Endif

 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(1,10704,1) : # Compteur non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(3)
 Endif

 Call NUMERO(COMPTEUR,[F:CPY]MAIFCY,date$,"",[F:PAC]NUMPAR,STAT) From SUBANM
 If STAT
  GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
  GOK = 0 : Return
 Endif
 [M]NUMPAR=[F:PAC]NUMPAR
 Affzo[M]NUMPAR
Endif
[F:PAC]STA=1 :#saisie
[M]STA=[F:PAC]STA
Affzo[M]STA
Return

$LIENS
Call AM_CODREP([F:PAC]CODREP)
Return

$SETBOUT
#39925
# If REP<>"" | !CLECUR
If REP<>"" | CLECUR=0 | !VERROU
 Call VIREBOUT (CHAINE,"BO") From GOBJET  : # Bouton Calcul et Validation
Endif
# Pas de bouton Calculer Valider Supprimer si fiche de participation collective validée
If [M]STA=3 : # Répartition validée
 Call VIREBOUT(CHAINE,"BOA") From GOBJET
Endif
# Pas de bouton Validation si la répartition n'a pas encore été calculée
If [M]STA=1
 Call VIREBOUT(CHAINE,"O") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
 When "O"
  Call DEBTRANS From GLOCK
  Gosub TR_VALID : # Bouton Validation
  Gosub RELIT From GOBJSUB
Endcase
Return


$TR_VALID
GOK=1
Trbegin [PAC], [PAI]
 Readlock [PAC]PAC0=[M:PAC0]NUMPAR
 If fstat=1
  GOK=-1 : GLOCK="$PARCOL"-num$([M:PAC0]NUMPAR)
 Elsif fstat
  GOK=0 : Call RSTA("PAC",num$([M:PAC0]NUMPAR)) From GLOCK
 Else
  [F:PAC]STA    = 3 : # Validé
  If dim([F:PAC]UPDDAT)>0 : [F:PAC]UPDDAT = date$ : Endif
  If dim([F:PAC]UPDUSR)>0 : [F:PAC]UPDUSR = GUSER : Endif
  If dim([F:PAC]UPDTIM)>0 : [F:PAC]UPDTIM = time  : Endif
  Rewrite [PAC]
  If fstat
   GOK=0 : Call FSTA("PAC") From GLOCK
  Endif
 Endif
 If GOK=1
  For [PAI] Where NUMPAR=[M:PAC0]NUMPAR
   [F:PAI]STA    = 2 : # Validé
   If dim([F:PAI]UPDDAT)>0 : [F:PAI]UPDDAT = date$ : Endif
   If dim([F:PAI]UPDUSR)>0 : [F:PAI]UPDUSR = GUSER : Endif
   If dim([F:PAI]UPDTIM)>0 : [F:PAI]UPDTIM = time  : Endif
   Rewrite [PAI]
   If fstat=1
    GOK=-1 : GLOCK="$PARIND"-[F:PAI]CPY-[F:PAI]REFNUM-num$([F:PAI]NUMPAR) : Break
   Elsif fstat
    GOK=0 : Call FSTA("PAI") From GLOCK : Break
   Endif
  Next
 Endif
 If GOK<0
  Goto ROLL_TR_VALID
 Elsif !GOK
  Goto AB_TR_VALID
 Endif
Commit
Return

$ROLL_TR_VALID
 Rollback
 Call ROLL From GLOCK
 If GROLL : Return : Else : Goto TR_VALID : Endif
Return

$AB_TR_VALID
Rollback
Return

$ANNULE
If clalev([F:PAI])=0 : Local File PARIND [PAI] : Endif
Delete [PAI] Where NUMPAR=[F:PAC]NUMPAR
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$PARIND"-num$([F:PAC]NUMPAR) : Return
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran PAC0) 17/09/2004 10:43:25 (DBA)
######################################################################################
Subprog AM_CODREP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("HRREP",VALEUR,"") From CONTOBJ
 [M]TYPREP=[F:HRREP]TYPREP
 Affzo[M]TYPREP
Endif

End


######################################################################################
