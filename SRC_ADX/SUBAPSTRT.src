#<AdxTL>@(#)6.0.0.0 $Revision$
# ------------------------------------------------------------
# SUBAPSTRT
# Version: 0001      
#    Exemple de traitement dialoguant avec les composants visuels
#            * TB1 "Tableau standard"
#            * FCA "Flash calendrier"
#
#    Cet exemple extrait les interventions dont la date de création est supèrieure au paramètre P1 
#        Paramètres sources de données:
#            P1:    Date début
#
#    Contexte
#        U_VIEWCODE        Code de la vue portail
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
#        M_ACTION          Code de l'action à traiter soumis par le provider Htc 
#        M_HTCTYPE         Type de provider Htc  (ex: PORTALREQ, PORTALSTA...)
#
#    Infos: (Ixx) Se reporter au traitement SUBAPSTRTI
#
# ------------------------------------------------------------

# Personnamisation des lignes sources de données des vues du portail
# ------------------------------------------------------------
$T_SRCTITLES
[APV1]SRCPARNBR=2
[APV1]SRCPARDES(0)="Date début"
[APV1]SRCPARDES(1)="Exemple Oui/Non" : [M:APV1]PARNOLIB(1)=1
Return


# Traitement d'extraction (I1)
# ------------------------------------------------------------
$T_EXECUTE     
    Onerrgo    # Suppression gestion d'erreur du prgrm appelant 
  
    U_TRAMES="--> Debut: " + "Exemple traitement": Gosub U_TRAPUT From SUBAPSUTI     # Trace (I9)

    Gosub T_INIT    # Initialisation
       
    #-- XML
    U_SEQPUT=' <Data>' : Gosub U_PUT From SUBAPSUTI         # Ecriture balise Data  (I2)

    ### Gestion Action
    Case M_ACTION
        When TQ_ACTINIT , TQ_ACTREFRESH    
            Gosub $T_ACTINIT : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif    # (I3)
        When Default                                                        
            U_MESCODE="TRTACTUNKNOWN" : U_MESP1=M_ACTION : U_MESP2= [F:APV]SRCCODTYP : U_ERR=UC_ERRG     # (I3)
            Gosub U_MESPUT From SUBAPSUTI : Goto ERRXMLCLOSE
    Endcase    


    $ERRXMLCLOSE    # fermeture XML listes
    #-- XML 
    U_SEQPUT=' </Data>' : Gosub U_PUT From SUBAPSUTI
    # Trace
    U_TRAMES="--> Fin: " + "Serveur statistique du portail": Gosub U_TRAPUT From SUBAPSUTI 
Return

  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# Gestion de la demande INIT
#
$T_ACTINIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Paramètre date: P1  (I4)
U_PARCODE=TC_P1 : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR=UC_ERRG : Return : Endif 
# 
If U_PARVALTYP = 7        # type date
    T_P1DAT=U_PARVALDAT        
Else
    T_P1DAT=date$-10    # defaut: date du jour - 10
Endif

# Section lignes de données
Gosub $SEC_LINES : If U_ERR=UC_ERRG : Return: Endif

# Section titres        Après les données car codage en dur flash
Gosub $SEC_TITLES : If U_ERR=UC_ERRG : Return: Endif

Return

# gestion des messages 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#  info: Valoriser U_MES
#        Utiliser une section de message propre à vos traitements (pas la 137!)
$T_GETMESBYCODE        # (I3)
Case U_MESCODE
When "TRTACTUNKNOWN"    # "Source de données: " + U_MESP2 + " - Action inconnue: " + U_MESP1 
    U_MES=mess(45,137,1) - U_MESP2 + " - " + mess(5,137,1) + " " + U_MESP1 
When "TRTP1DATERR"    # Pb date
    U_MES=mess(41,137,1)-"P1"-mess(46,137,1)-U_MESP1
Endcase
Return


# * * * * * * * * * * * * * *
#   G O S U B
# * * * * * * * * * * * * * *
# Section titres
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEC_TITLES
#
U_SEQPUT='<Titles>' : Gosub T_SEQPUT
  # Titre
  U_SEQPUT=' <Title>'+mess(8,138,1)-num$(T_P1DAT)+'</Title>' : Gosub T_SEQPUT    # Dates, heures...
  # Colonnes
  For TW_I=1 To 7
    U_HEXTOTXT=mess(TW_I,138,1) : Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
    U_SEQPUT=' <ColTitle Num="'+num$(TW_I)+'" X3Type="7">'+U_TXTTOHEX+'</ColTitle>' : Gosub T_SEQPUT    # Dates, heures...
  Next
U_SEQPUT='</Titles>' : Gosub T_SEQPUT
Return 



# Section des données
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEC_LINES
U_SEQPUT=' <Lines>' : Gosub T_SEQPUT
Filter [ITN] Where DAT >= T_P1DAT Order By Key ITN6

For [ITN]
  U_SEQPUT='  <Line>' : Gosub T_SEQPUT

  # Date deb        (I6)
    U_SEQPUT='    <Col Num="1" X3Type="7">' : Gosub T_SEQPUT
     U_SEQPUT='     <X3IntVal>' + [F:ITN]DAT + '</X3IntVal>' : Gosub T_SEQPUT
     U_SEQPUT='     <X3Value>' + num$([F:ITN]DAT) + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Heure deb
    U_SEQPUT='    <Col Num="2" X3Type="7">' : Gosub T_SEQPUT
     U_SEQPUT='     <X3IntVal>' + [F:ITN]HOU + '</X3IntVal>' : Gosub T_SEQPUT
     U_SEQPUT='     <X3Value>' + format$("K:##[:]##",[F:ITN]HOU) + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Date fin
    U_SEQPUT='    <Col Num="3" X3Type="7">' : Gosub T_SEQPUT
     U_SEQPUT='     <X3IntVal>' + [F:ITN]DATEND + '</X3IntVal>' : Gosub T_SEQPUT
     U_SEQPUT='     <X3Value>' + num$([F:ITN]DATEND) + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Heure fin
    U_SEQPUT='    <Col Num="4" X3Type="7">' : Gosub T_SEQPUT
     U_SEQPUT='     <X3IntVal>' + [F:ITN]HOUEND + '</X3IntVal>' : Gosub T_SEQPUT
     U_SEQPUT='     <X3Value>' + format$("K:##[:]##",[F:ITN]HOUEND) + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Titre
    U_SEQPUT='    <Col Num="5" X3Type="7" ' 
    #   ajout du lien sur l'intervention        (I8)
     Call GETURLCLEPRIM("ITN", num$([F:ITN]NUM), M_MODE, TW_URL) From SUBAPSOBJ
     If TW_URL<>""
         U_HEXTOTXT=TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
         U_SEQPUT+=' X3Link="' + U_TXTTOHEX + '" '
     Endif
    U_SEQPUT +=  ' >': Gosub T_SEQPUT
        # Chrono Client Contact
        PW_STR1=num$([F:ITN]NUM)-"/"-[F:ITN]BPC
        If [F:ITN]CCN<>"" : PW_STR1-="/"-[F:ITN]CCN : Endif
        U_SEQPUT='     <X3IntVal>' + PW_STR1 + '</X3IntVal>' : Gosub T_SEQPUT
        U_SEQPUT='     <X3Value>' + format$("K:25X",PW_STR1) + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Information
    U_SEQPUT='    <Col Num="6" X3Type="7">' : Gosub T_SEQPUT
    U_HEXTOTXT=[F:ITN]OBJ 
    If len(U_HEXTOTXT)>200 : U_HEXTOTXT=left$(U_HEXTOTXT,200)+"..." : Endif
    Gosub U_TXTTOHEX From SUBAPSUTI        # (I7)
        U_SEQPUT='     <X3IntVal>' + U_TXTTOHEX + '</X3IntVal>' : Gosub T_SEQPUT
        U_SEQPUT='     <X3Value>' + U_TXTTOHEX + '</X3Value>' : Gosub T_SEQPUT
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # Date et heure de fin (informations 2)
    U_SEQPUT='    <Col Num="7" X3Type="7">' : Gosub T_SEQPUT
    PW_STR1 = ""
    If [F:ITN]DATEND<>[00/00/00]
         U_SEQPUT+="<B>"+mess(3,138,1)+":"-num$([F:ITN]DATEND)
&        -mess(3,138,1)+":"-format$("K:##[:]##",[F:ITN]HOUEND) +"</B>"
    
        U_SEQPUT='     <X3IntVal>' + PW_STR1 + '</X3IntVal>' : Gosub T_SEQPUT
        U_SEQPUT='     <X3Value>' + PW_STR1 + '</X3Value>' : Gosub T_SEQPUT
    Endif    
    U_SEQPUT='    </Col>' : Gosub T_SEQPUT

  # fin de ligne
  U_SEQPUT='  </Line>' : Gosub T_SEQPUT
Next
Filter [ITN]

U_SEQPUT='  </Lines>' : Gosub T_SEQPUT

Return


# Initialisations
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#    info: Pour ne pas interferer avec les autres programmes, les variables commencent par 'T'
$T_INIT
# Table Interventions
If clalev([F:ITN]) = 0 : Local File INTERVEN : Endif

# Actions    
#    info: TQ pour T:prefixe traitement, Q:donnée issue de la Query string
Local Char TQ_ACTINIT(10) : TQ_ACTINIT='INIT'            # En 1er appel
Local Char TQ_ACTREFRESH(10) : TQ_ACTREFRESH='REFRESH'            # En 1er appel

# Paramètres sources de données
#    info: TC pour T:prefixe traitement, C: constante
Local Char TC_P1(2),T_P1VAL(10) : TC_P1="P1"       # code et valeur 1er paramètre - Date de debut d'extraction
Local Date T_P1DAT                                 # en format interne date

# Travail
#    info: TC pour T:prefixe traitement, W: travail
Local Integer TW_I
Local Char TW_STR1(100), TW_URL(100)
Return

# Ecriture XML 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$T_SEQPUT
Gosub U_PUT From SUBAPSUTI
Return

