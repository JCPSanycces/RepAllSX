#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","AYTGEN","AYTFCYGEN",3,"XYAYTGEN") From GTRAITE
End

Call AYT_DEBUG From AYTUTIA   # Activation debug java
DOSORG = "XTEND"
FCYORG = "ZSITE2"
Integer RET
Local Char TIM(14)
TIM = func AYTGEN.TIMESTAMP
End

######################################################################################
## Xtend: Gestion des validations Xtend
#  Version 0001
#
######################################################################################
##  Actions
#    AYTFCYGEN    Procédure générale de génération (validation d'un site Xtend)
#    AYTGEN       Procédure génération d'un élément Xtend
#
######################################################################################
##  Utilitaires pour gestion des générations
######################################################################################
#    Subprog XMLGENPRG        # Génération des Xmls pour un site Xtend  
#    Funprog TIMESTAMP        # Horodatage ex: 20061012091432
#    Subprog SETTIMSTP        # Mise à jour des times stamps de génération (base et fichier)
#------------------------------------------------------------#
#  Gosub
#    $XML_INI        # Initialisation variables (clob)
#    $XMLF_INI       # Initialisation variables (file)
#    $XMLF_INI2      # Initialisation variables (file)
#    $XML_ADD        # Ajout d'une ligne
#    $XMLF_ADD       # Ajout d'une ligne
#    $XML_CL         # Close XML
#    $XMLF_CL        # Close XML
#    $TEXTE          # Remplace TEXTE de OBJDIV (rapidité)
#------------------------------------------------------------#
######################################################################################

$ACTION
Case GACTION 
 When "AYTFCYGEN"    
  If dim([L]PTRTB)<=0        # Perso par produit
    Local Integer PTRTB
    Call EXISTE_ADX("","","AYTGENB",PTRTB) From ORDSYS
  Endif
  Case ACTION
   When "INIT"         : Gosub FCYGEN_INI
   When "INIT_DIA"     : Gosub FCYGEN_DIA
   When "EXEC"         : Gosub FCYGEN_EXEC
  Endcase
  If PTRTB: Gosub ACTION From AYTGENB: Endif           # Perso par produit
 When "AYTGEN"       
  Case ACTION
   When "INIT"         : Gosub GEN_INI
   When "EXEC"         : Gosub GEN_EXEC
  Endcase
Endcase
Return

######################################################################################
#    AYTFCYGEN        Procédure générale de génération (validation d'un site Xtend)
#                     Type Gtraite - Ecran et fenêtre AYTFCYGEN
#                     
#        Param(1)      Dossier 
#        Param(2)      Site Xtend 
######################################################################################
$FCYGEN_INI
#-----------------------------
Local Char FCYORG(GLONAYS)
Local Char DOSORG(GDIMFIC), MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000@XTEND ; sodaix01:5000 ; XTEND
Local Char WSTR1(200), WDES(50), WTIT(100)
Local Char TIMSTP(14)
Local Char OPTION(10)(1..10)     : Local Integer OPTIND
Local Char LSTOBJCOD(3)(1..20)   : Local Integer LSTIND
Local Integer RET, WI
Local Mask AWE2 [AWE2]
Local Mask AWE1 [AWE1]
Local Mask AWE0 [AWE0]
DOSORG = PARAM(1)
FCYORG = PARAM(2)
Return

$FCYGEN_DIA
#-----------------------------
If DOSORG <> "" : [M:DIA]DOSORG=DOSORG : Endif
If FCYORG <> "" : [M:DIA]FCYORG=FCYORG  : Endif
Return

$FCYGEN_EXEC   # Nota: [M:DIA] ecran de la demande
#-----------------------------
Call TITOBJ("AYS","", WTIT) From CONTOBJ : WTIT=mess(42,7900,1)-WSTR1-[M]FCYORG
If !GSERVEUR
    TRA=1
    Call TEMPON(WTIT) From GESECRAN 
    Call OUVRE_TRACE(WTIT) From LECFIC
Endif
OK=1

# Elts à générer
Raz LSTIND, OPTIND
If [M:DIA]TRAOPT=2: OPTIND+=1 : OPTION(OPTIND)="TRADET" : Endif        # Trace détaillée
If [M:DIA]CHK=2   : OPTIND+=1 : OPTION(OPTIND)="CHK"    : Endif        # Vérification

If [M:DIA]FCYM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYS" : Endif        # Fiche site
If [M:DIA]PAGM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYG" : Endif        # Page
If [M:DIA]PRFM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYD" : Endif        # Profil
If [M:DIA]FIEM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYF" : Endif        # Elt Champ
If [M:DIA]SPXM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYX" : Endif        # Elt spécial
If [M:DIA]MESM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYM" : Endif        # Message
If [M:DIA]INTM1=2                                                      # Interface
     LSTIND+=1 : LSTOBJCOD(LSTIND)="AYI" 
     If [M]INTGM1=2 : OPTIND+=1 : OPTION(OPTIND)="AYI_ACCWS" : Endif 
Endif
If [M:DIA]ENTM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYE" : Endif        # Entité
If [M:DIA]BLCM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYB" : Endif        # Bloc
If [M:DIA]ACTM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYA" : Endif        # Action
If [M:DIA]DLKM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYL" : Endif        # Lien dynamique
If [M:DIA]BLWM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYW" : Endif        # Bloc conditionné
If [M:DIA]ADVM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYU" : Endif        # Paramétrage avancé
If [M:DIA]MENM1=2 : LSTIND+=1 : LSTOBJCOD(LSTIND)="AYC" : Endif        # Paramétrage avancé
Call XMLGENPRG([M]DOSORG, [M]FCYORG, LSTOBJCOD, OPTION, RET)

$FCYGEN_FIN
If !GSERVEUR
 Call TEMPOFF() From GESECRAN 
Endif
Return


######################################################################################
#    AYTGEN         Procédure génération d'un élément Xtend
#                   Type Gtraite sans saisie
# $$$$
#        Param(1)      Dossier 
#        Param(2)      Site Xtend 
#        Param(3)      Code Objet Xtend
#        Param(4)      Code elt Xtend
#        Param(5)      Option Verif Interface
######################################################################################
$GEN_INI
#----------------------------
Local Char DOSORG(GDIMFIC)                # sodaix01:5000@XTEND
Local Char FCYCOD(GLONAYS), ELTCOD(40), OBJCOD(GLONAOB)
Local Integer WINDOPT, CHK 
Local Char WSTR(200), WTRT
Local Char TIMSTP(14)
Local Char OPTION(10)(1..10) : WINDOPT=1
Local Integer RET, WXMLGEN_RET, WTIMSTP_RET
DOSORG=PARAM(1)
FCYCOD=PARAM(2)
OBJCOD=PARAM(3)
ELTCOD=PARAM(4)
CHK=(PARAM(5)="1")

Return

$GEN_EXEC   
#-----------------------------
RET=1
Call TITOBJ(OBJCOD,"", WSTR) From CONTOBJ
WSTR=mess(38,7900,1)-WSTR

If !GSERVEUR
  Call TEMPON(WSTR) From GESECRAN 
  Call OUVRE_TRACE(WSTR) From LECFIC
  TRA=1
Else
  OPTION(WINDOPT)="NOTEMPON" : WINDOPT+=1
Endif

TIMSTP = func AYTGEN.TIMESTAMP
WTRT="SUB"+OBJCOD+"GEN"
OPTION(WINDOPT)="TRADET" : WINDOPT+=1
If OBJCOD="AYI"
    OPTION(WINDOPT)="AYI_ACCWS_Q" : WINDOPT+=1       # 2: poser la question génération Web services sur interface de type 'Accès'
Endif 
If CHK : OPTION(WINDOPT)="CHK" : WINDOPT+=1 : Endif

Call XMLGEN(DOSORG,FCYCOD,TIMSTP,OPTION,ELTCOD, WXMLGEN_RET) From =WTRT
If WXMLGEN_RET=0 : RET=0 : Goto GEN_FIN : Elsif WXMLGEN_RET=2 : RET=2 : Endif

Call SETTIMSTP(DOSORG, FCYCOD, OBJCOD, TIMSTP, WTIMSTP_RET) 
If WXMLGEN_RET=0 : RET=0 : Goto GEN_FIN : Elsif WXMLGEN_RET=2 : RET=2 : Endif

$GEN_FIN
If !GSERVEUR
    Call TEMPOFF() From GESECRAN 
    Call FERME_TRACE From LECFIC
    If RET=0 | RET=2    # erreur ou warning 
        Call LEC_TRACE  From LECFIC
    Else
        WSTR = filpath("TRA",GTRACE,"tra",0)
        Call EFFACE(WSTR, RET) From ORDSYS
        TRA=0
    Endif
Endif
Return



######################################################################################
## Xtend - Utilitaires pour gestion des générations
######################################################################################

######################################################################################
#  Utilitaires - Gestion File XML
# $$$$
######################################################################################

$XMLF_INI        # Initialisation 
# en entré
Local Char XT_ID, XT_VAL(250), XT_TY, XT_LAB(100), XT_XMLID
Local Char XT_DOSSIER(GDIMFIC),XT_MAC(GDIMFIC), XT_DOSNAM(GDIMFIC)   # sodaix01:5000@XTEND ; sodaix01:5000 et XTEN
Local Char XT_FCYCOD(GLONAYS)
Local Char XT_TIMSTP(14)
#Travail
Local Char XT_TABEND(50)(1..10)      # Tableau des balise de fermetures
Local Char XT_XMLID, XT_STR(250), XT_STR1(250)
Local Integer XT_I, XT_J, XT_K
Local Integer XT_RET : XT_RET=1        # Ok=1; Ko=0 
Local Integer XT_LVL
Local Char     XT_TXTVAL(250)  #Textes
Local Integer  XT_TXTNUM
Local Integer  TIMLOCK : TIMLOCK=20
Return

$XMLF_INI2        # Suite Initialisation
If XT_DOSSIER<>nomap    
    Lock AYTGENXML From = XT_DOSSIER With lockwait=TIMLOCK    #[S]lockwait
Else
    Lock AYTGENXML With lockwait=TIMLOCK        #[S]lockwait
Endif
If fstat
    XT_RET=0
    Local Char MACHINE(GDIMFIC), USER
    Call  QUILOCKE("AYTGENXML",MACHINE,USER) From OBJDIV
    Call ECR_TRACE(mess(37,7900,1)-"AYTGENXML"-GUSER+"/"+MACHINE,1) From GESECRAN
    Return
Endif
#
XT_STR=func AYTGESFILE.GETPATH(XT_MAC,XT_DOSNAM,"FIL"+XT_XMLID,"",XT_FCYCOD,"")
If 1=2 and GUSER="JPJ"
   XT_I=1
   Qstbox "AYTGEN/XMLF_INI Chemin PC ?" Using XT_I Sleep 3
   If XT_I=1 : XT_STR="#@E:\X3 Xtend V2 (voir ecjullien)\XmlX3\"+"FIL"+XT_XMLID+".xml" : Endif
Endif
Onerrgo XML_ERR
Openo XT_STR,0 Using [XTS]
Onerrgo
If XT_RET=0 : Return : Endif
Iomode adxifs ""  Using [XTS]
Iomode adxirs chr$(13)+chr$(10)  Using [XTS]
Iomode adxium GUTF8  Using [XTS]

Wrseq '<?xml version="1.0" encoding="utf-8" standalone="yes" ?> ' Using [XTS]
Return

#------------------------------------------------------------#
$XMLF_ADD        # Ajout d'une ligne
Case XT_TY
When "ELMTS"
    If adxmac(0)=""            # formule récuperer de globvar 
     XT_STR = nomap-adxmac(-1)
    Else
     XT_STR = nomap-adxmac(0)
    Endif

    XT_LVL=1
    Wrseq         '<ELMTS ID="' +XT_XMLID+ '" FCY="' +XT_FCYCOD+ '" DOS="' +XT_STR+ '" TIM="' +XT_TIMSTP+ '">'  Using [XTS]
    XT_TABEND(XT_LVL)='</ELMTS>'

When "ELMT"
    XT_LVL=2 : Gosub XMLF_TAG_CL
    Wrseq         ' <ELMT ID="' +XT_ID+ '" DES="' +XT_VAL+ '">'  Using [XTS]
    XT_TABEND(XT_LVL)=' </ELMT>'

When "FLD"
    XT_LVL=3 : Gosub XMLF_TAG_CL
    XT_STR=        '  <FLD ID="' +XT_ID
    If XT_LAB<>""
        XT_STR+=                 '" LAB="' +XT_LAB
    Endif
    If len(XT_VAL)<150
       XT_STR+=                     '">' +XT_VAL+ '</FLD>'
       Wrseq XT_STR       Using [XTS]
    Else
       XT_STR+=                     '">'
       Wrseq XT_STR       Using [XTS]
       Wrseq XT_VAL       Using [XTS]
       Wrseq '</FLD>'     Using [XTS]
    Endif

When "TAB"
    XT_LVL=3 : Gosub XMLF_TAG_CL
    If XT_VAL=""
        Wrseq         '  <TAB ID="' +XT_ID+ '">'                       Using [XTS]
    Else
        Wrseq         '  <TAB ID="' +XT_ID+ '" DES="' +XT_VAL+ '">'    Using [XTS]
    Endif
    XT_TABEND(XT_LVL)='  </TAB>'

When "LIN"
    XT_LVL=4 : Gosub XMLF_TAG_CL
    Wrseq         '   <LIN>'              Using [XTS]
    XT_TABEND(XT_LVL)='   </LIN>'

When "COL"
    XT_LVL=5 
    XT_STR=        '    <COL ID="' +XT_ID
    If XT_LAB<>""
        XT_STR+=                 '" LAB="' +XT_LAB
    Endif
    If len(XT_VAL)<150
       XT_STR+=                     '">' +XT_VAL+ '</COL>'
       Wrseq XT_STR       Using [XTS]
    Else
       XT_STR+=                     '">'
       Wrseq XT_STR       Using [XTS]
       Wrseq XT_VAL       Using [XTS]
       Wrseq '</COL>'     Using [XTS]
    Endif

When "LST"
    XT_LVL=3 : Gosub XMLF_TAG_CL
    Wrseq         '  <LST ID="' +XT_ID+ '">'          Using [XTS]
    XT_TABEND(XT_LVL)='  </LST>'

When "ITM"
    XT_LVL=4 
    XT_STR=        '    <ITM '
    If XT_LAB<>""
        XT_STR+=                 'LAB="' +XT_LAB +'"'
    Endif
    XT_STR+=                     '>' +XT_VAL+ '</ITM>'
    Wrseq XT_STR   Using [XTS]

When Default
    XT_RET=0 : Call ECR_TRACE("Unknown XML type:"-XT_TY,1) From GESECRAN
Endcase
Raz XT_TY, XT_ID, XT_VAL, XT_LAB
Return

#------------------------------------------------------------#
$XMLF_TAG_CL         # Close TAG
XT_J=0
For XT_I=XT_LVL To 10 # dim(XT_TABEND,1)
    If XT_TABEND(XT_I)="" : Break : Endif
    XT_J=XT_I
Next
#XT_J=find("",XT_TABEND(XT_LVL..10)) # pas même résultat
If XT_J
 For XT_I=XT_J To XT_LVL Step -1
    Wrseq XT_TABEND(XT_I)  Using [XTS]
    XT_TABEND(XT_I)=""
 Next
Endif

Return

#------------------------------------------------------------#
$XMLF_CL         # Close XML
XT_LVL=1 : Gosub XMLF_TAG_CL
#
Openo Using [XTS]
If XT_DOSSIER<>nomap    
    Unlock AYTGENXML From = XT_DOSSIER
Else
    Unlock AYTGENXML
Endif
Return


#------------------------------------------------------------#
$TEXTE        # Remplace TEXTE de OBJDIV (rapidité)
If XT_TXTNUM=0 : XT_TXTVAL = "" : Return : Endif
Read [ATX]NUMERO = GLANGUE;XT_TXTNUM
If fstat=0
 XT_TXTVAL = [F:ATX]TEXTE
Else 
 Read [ATX]NUMERO = GLANDEF;XT_TXTNUM 
 If fstat=0 
  XT_TXTVAL = [F:ATX]TEXTE 
 Else
  XT_TXTVAL = "" 
 endif
Endif
Return

######################################################################################
#  Gestion Clob du XML (non utilisé - à vérifier si chgt)
# $$$$
######################################################################################

$XML_INI        # Initialisation variables
# en entré
Local Char XT_ID, XT_VAL(250), XT_TY, XT_LAB(100), XT_XMLID
Local Char XT_DOSSIER(GDIMFIC), XT_MAC(GDIMFIC), XT_DOSNAM(GDIMFIC)  # sodaix01:5000@XTEND ; sodaix01:5000 et XTEND
Local Char XT_FCYCOD(GLONAYS)
Local Char XT_TIMSTP(14)
#Travail
Local Clbfile XT_XML(11)             # 1Mo  500000 carc.
Local Char XT_TABEND(50)(1..10)      # Tableau des balisise de fermetures
Local Char XT_XMLID, XT_CR, XT_STR(250)
Local Integer XT_I, XT_J, XT_K
Local Integer XT_RET : XT_RET=1        # Ok=1; Ko=0 
Local Integer XT_LVL
Local Char     XT_TXTVAL(250)  #Textes
Local Integer  XT_TXTNUM
XT_CR=chr$(13)+chr$(10)
XT_XML='<?xml version="1.0" encoding="utf-8" standalone="yes" ?> '
Return

#------------------------------------------------------------#
$XML_ADD        # Ajout d'une ligne
Case XT_TY
When "ELMTS"
    XT_LVL=1
    XT_XMLID=XT_ID
    XT_XML+=XT_CR +        '<ELMTS ID="' +XT_XMLID+ '" TIM="' +XT_TIMSTP+ '">'
    XT_TABEND(XT_LVL)=XT_CR + '</ELMTS>'

When "ELMT"
    XT_LVL=2 : Gosub XML_TAG_CL
    XT_XML+=XT_CR +        ' <ELMT ID="' +XT_ID+ '" DES="' +XT_VAL+ '">'
    XT_TABEND(XT_LVL)=XT_CR + ' </ELMT>'

When "FLD"
    XT_LVL=3 : Gosub XML_TAG_CL
    XT_XML+=XT_CR +        '  <FLD ID="' +XT_ID
    If XT_LAB<>""
        XT_XML+=                 '" LAB="' +XT_LAB
    Endif
    XT_XML+=                     '">' +XT_VAL+ '</FLD>'

When "TAB"
    XT_LVL=3 : Gosub XML_TAG_CL
    XT_XML+=XT_CR +        '  <TAB ID="' +XT_ID+ '">'
    XT_TABEND(XT_LVL)=XT_CR + '  </TAB>'

When "LIN"
    XT_LVL=4 : Gosub XML_TAG_CL
    XT_XML+=XT_CR +        '   <LIN>'
    XT_TABEND(XT_LVL)=XT_CR + '   </LIN>'

When "COL"
    XT_LVL=5 
    XT_XML+=XT_CR +        '    <COL ID="' +XT_ID
    If XT_LAB<>""
        XT_XML+=                 '" LAB="' +XT_LAB
    Endif
    XT_XML+=                     '">' +XT_VAL+ '</COL>'

When "LST"
    XT_LVL=3 : Gosub XML_TAG_CL
    XT_XML+=XT_CR +        '  <LST ID="' +XT_ID+ '">'

When "ITM"
    XT_LVL=4 
    XT_XML+=XT_CR +        '    <ITM '
    If XT_LAB<>""
        XT_XML+=                 'LAB="' +XT_LAB +'"'
    Endif
    XT_XML+=                     '>' +XT_VAL+ '</ITM>'

When Default
    XT_RET=0 : Call ECR_TRACE("Unknown XML type:"-XT_TY,1) From GESECRAN
Endcase
Raz XT_TY, XT_ID, XT_VAL, XT_LAB
Return

#------------------------------------------------------------#
$XML_TAG_CL         # Close TAG
#XT_J=0
#For XT_I=XT_LVL To dim(XT_TABEND,1)
#    If XT_TABEND(XT_I)="" : Break : Endif
#    XT_J=XT_I
#Next
XT_J=find("",XT_TABEND(XT_LVL..10))
If XT_J
 For XT_I=XT_J To XT_LVL Step -1
    XT_XML+=XT_TABEND(XT_I)
    XT_TABEND(XT_I)=""
 Next
Endif
Return

#------------------------------------------------------------#
$XML_CL         # Close XML
XT_LVL=1 : Gosub XML_TAG_CL
#
Lock AYTGENXML
If fstat
    XT_RET=0
    Local Char MACHINE(GDIMFIC), USER
    Call  QUILOCKE("AYTGENXML",MACHINE,USER) From OBJDIV
    Call ECR_TRACE(mess(37,7900,1)-"AYTGENXML"-GUSER+"/"+MACHINE,1) From GESECRAN
    Return
Endif
#
XT_STR=func AYTGESFILE.GETPATH(XT_MAC,XT_DOSNAM,"FIL"+XT_XMLID,"",XT_FCYCOD,"")
Onerrgo XML_ERR
Openo XT_STR,0 Using [XTS]
Onerrgo
If XT_RET=0 : Return : Endif
Iomode adxifs ""  Using [XTS]
Iomode adxirs XT_CR  Using [XTS]
Iomode adxium GUTF8  Using [XTS]
Wrseq XT_XML Using [XTS]
$TEMPEND
Openo Using [XTS]
#If GUSER="JPJ" : Gosub DBGJPJ : Endif
Unlock AYTGENXML
Return

$DBGJPJ
Infbox "Avant ecriture local dans E:temp"
Onerrgo XML_ERR
Openo "#@E:\TEMP\"+"FIL"+XT_XMLID+".xml",0 Using [XTS]
Onerrgo
If XT_RET=0 : Return : Endif
Iomode adxifs ""  Using [XTS]
Iomode adxirs XT_CR  Using [XTS]
Iomode adxium GUTF8  Using [XTS]
Wrseq XT_XML Using [XTS]
Openo Using [XTS]
Return

$XML_ERR
Unlock AYTGENXML
XT_RET=0
Call ECR_TRACE(mess(13,100,1)-XT_STR, 1) From GESECRAN
Resume



######################################################################################
###     Utilitaires générations subprog et funprog 
######################################################################################
#------------------------------------------------------------#
# Génération des Xmls pour un site Xtend
# $$$$
#------------------------------------------------------------#
Subprog XMLGENPRG(DOSORG, FCYORG, LSTOBJCOD, OPTION, RET)       
Value Char DOSORG              # sodaix01:5000@XTEND
Value Char FCYORG              # Site Xtend
Value Char LSTOBJCOD()(1..)    # Liste des objets Xtend à regénérer AYG, AYS... ou "***" pour tous
Value Char OPTION()(1..)       # Options 
                               #   'AYI_ACCWS' =Regénération des Web Services des interfaces de type Accès générés
                               #   'TRADET'    =Trace détaillée
                               #   'NOTEMPON'  =Pas de popup avancement

Variable Integer RET : RET=1   # 1: Ok
#
Local Char WSTR1(200), WTIT(100) 
Local Char TIMSTP(14)
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        #  sodaix01:5000 ; XTEND
Local Integer FLGALL   : FLGALL=find("***",LSTOBJCOD)
Local Integer TMPONFLG : TMPONFLG=(find("NOTEMPON",OPTION)=0)

# Perso par produit
Local Integer PTRTB
Call EXISTE_ADX("","","AYTGENB",PTRTB) From ORDSYS

#
Call TITOBJ("AYS","", WTIT) From CONTOBJ : WTIT=mess(42,7900,1)-WSTR1-FCYORG-"-"-mess(3,23,1)-DOSORG
Call ECR_TRACE(WTIT,0) From GESECRAN

TIMSTP = func AYTGEN.TIMESTAMP
#
Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
#
# Table site
If DOSORG<>nomap          
    Local File =DOSORG+".AYTFCY"  [AYS1] 
Else
    Local File AYTFCY [AYS1] 
Endif
Read [AYS1]AYS0 = FCYORG
If fstat
    Call ECR_TRACE(mess(19,7900,1)-FCYORG,1) From GESECRAN
    RET=0
    Goto XMLGEN_FIN
Endif

# Fiche site
If FLGALL or find("AYS",LSTOBJCOD)
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYSGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Page
If FLGALL or find("AYG",LSTOBJCOD)
    Call TITOBJ("AYG","", WSTR1) From CONTOBJ
    Gosub TEMPON    # Call TEMPON(WTIT-WSTR1) From GESECRAN
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYGGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Profil
If FLGALL or find("AYD",LSTOBJCOD)
    Call TITOBJ("AYD","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYDGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Elt Champ
If FLGALL or find("AYF",LSTOBJCOD)
    Call TITOBJ("AYF","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYFGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Elt spécial
If FLGALL or find("AYX",LSTOBJCOD)
    WSTR1 =mess(11,7910,1) : # TOKENS champs spéciaux 
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYXGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Message
If FLGALL or find("AYM",LSTOBJCOD)
    Call TITOBJ("AYM","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYMGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Interface
If FLGALL or find("AYI",LSTOBJCOD)
    Call TITOBJ("AYI","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYIGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Entité
If FLGALL or find("AYE",LSTOBJCOD)
    Call TITOBJ("AYE","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYEGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Bloc
If FLGALL or find("AYB",LSTOBJCOD)
    Call TITOBJ("AYB","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYBGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Action
If FLGALL or find("AYA",LSTOBJCOD)
    Call TITOBJ("AYA","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYAGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Lien dynamique
If FLGALL or find("AYL",LSTOBJCOD)
    Call TITOBJ("AYL","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYLGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Bloc conditionné
If FLGALL or find("AYW",LSTOBJCOD)
    Call TITOBJ("AYW","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYWGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Menu
If FLGALL or find("AYC",LSTOBJCOD)
    Call TITOBJ("AYC","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYCGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif
# Paramétrage avancé
If FLGALL or find("AYU",LSTOBJCOD)
    Call TITOBJ("AYU","", WSTR1) From CONTOBJ
    Gosub TEMPON 
    Call XMLGEN(DOSORG, FCYORG, TIMSTP,OPTION,"", RET) From SUBAYUGEN
    If RET=0 : Goto XMLGEN_FIN: Endif
Endif

If FLGALL
  For I=0 To [F:AYS1]LNKNBR-1
   ###
   Call ECR_TRACE(mess(14,123,1)-mess(79,7900,1)-":"-[F:AYS1]LNKADS(I)-"-"-mess(85,115,1)-DOSORG,0) From GESECRAN
   Call XMLGEN(DOSORG,FCYORG,func AYTGEN.TIMESTAMP,OPTION,[F:AYS1]LNKADS(I),RET) From SUBAYOGEN
   If RET=0 :  Goto FCYGEN_FIN: Endif
   ###
   Call SETTIMSTP(DOSORG,FCYORG, "AYO", func AYTGEN.TIMESTAMP,RET) 
   If RET=0 :  Goto FCYGEN_FIN: Endif
  Next
Endif

# Perso par produit
If PTRTB: Gosub XMLGENFIN From AYTGENB: Endif           # Perso par produit

# Maj time stamp
Call SETTIMSTP(DOSORG, FCYORG, "", TIMSTP, RET) 
If RET=0 : Goto XMLGEN_FIN: Endif

$XMLGEN_FIN
If TMPONFLG : Call TEMPOFF() From GESECRAN : Endif
End

# Gestion popup
#------------------------------------------------------------#
$TEMPON
If TMPONFLG : Call TEMPON(WTIT-WSTR1) From GESECRAN : Endif
Return

#------------------------------------------------------------#
# $$$$
Funprog TIMESTAMP()      # Horodatage ex: 20061012091432
End date$+left$(time$,2)+mid$(time$,4,2)+right$(time$,7)


#------------------------------------------------------------#
# Mise à jour des times stamps de génération (base et fichier)
# $$$$
#------------------------------------------------------------#
Subprog SETTIMSTP(DOSORG, FCYCOD, OBJCOD, TIMSTP, RET)    
Value Char DOSORG          # sodaix01:5000@XTEND
Value Char FCYCOD
Value Char OBJCOD          # AYG, AYS... ou "" pour mise à jour de tous
Value Char TIMSTP          # Horodatage ex: 20061012091432
Variable Integer RET
RET=1
Value Decimal WD_TIMSTP    # TimeStamp voulu
WD_TIMSTP=val( TIMSTP )
Value Decimal WDF_TIMSTP   # TimeStamp du fichier
If OBJCOD="AYO"
    End
Endif
# Table site
If DOSORG<>nomap          
    Local File =DOSORG+".AYTFCY"  [AYS] 
Else
    Local File AYTFCY [AYS] 
Endif

# Perso par produit
Local Integer PTRTB
Call EXISTE_ADX("","","AYTGENB",PTRTB) From ORDSYS

# Maj
Gosub UPDFIC_CF
If GOK<1 : RET=0 : Endif
# Fichier généré
Gosub UPDFIL_CF
End

# - - - - - - - - - - - - - - - - - - - -
$UPDFIC_CF
GOK=1
Trbegin [AYS]
Readlock [AYS]AYS0 = FCYCOD
If fstat=1
    GOK=-1 : GLOCK = "$AYTFCY"-GUSER -FCYCOD : Goto ROLL_CF
Elsif (fstat=0)
    If [F]TIMALL < WD_TIMSTP : [F]TIMALL = WD_TIMSTP : Endif
    Case OBJCOD
    When "AYA" : Gosub ASSIGN_TIM
    When "AYS" : Gosub ASSIGN_TIM
    When "AYF" : Gosub ASSIGN_TIM
    When "AYM" : Gosub ASSIGN_TIM
    When "AYC" : Gosub ASSIGN_TIM
    When "AYX" : Gosub ASSIGN_TIM
    When "AYI" : Gosub ASSIGN_TIM
    When "AYG" : Gosub ASSIGN_TIM
    When "AYE" : Gosub ASSIGN_TIM
    When "AYB" : Gosub ASSIGN_TIM
    When "AYL" : Gosub ASSIGN_TIM
    When "AYW" : Gosub ASSIGN_TIM
    When "AYD" : Gosub ASSIGN_TIM
    When "AYU" : Gosub ASSIGN_TIM
       When ""
        OBJCOD = "AYA" : Gosub ASSIGN_TIM
        OBJCOD = "AYS" : Gosub ASSIGN_TIM
        OBJCOD = "AYF" : Gosub ASSIGN_TIM
        OBJCOD = "AYM" : Gosub ASSIGN_TIM
        OBJCOD = "AYC" : Gosub ASSIGN_TIM
        OBJCOD = "AYX" : Gosub ASSIGN_TIM
        OBJCOD = "AYI" : Gosub ASSIGN_TIM
        OBJCOD = "AYG" : Gosub ASSIGN_TIM
        OBJCOD = "AYE" : Gosub ASSIGN_TIM
        OBJCOD = "AYB" : Gosub ASSIGN_TIM
        OBJCOD = "AYL" : Gosub ASSIGN_TIM
        OBJCOD = "AYW" : Gosub ASSIGN_TIM
        OBJCOD = "AYD" : Gosub ASSIGN_TIM
        OBJCOD = "AYU" : Gosub ASSIGN_TIM
    Endcase

    If PTRTB: Gosub TIMSTP_FILE From AYTGENB: Endif           # Perso par produit

    Rewrite [AYS]
    If fstat
        GOK = 0 : Call FSTA("AYS") From GLOCK : Goto AB_CF
    Endif
Else
    Call ECR_TRACE(mess(19,7900,1)-FCYCOD,1) From GESECRAN
    RET=0
Endif
Commit
Return

$ROLL_CF
Rollback
Call ROLL From GLOCK
If !GROLL : Goto UPDFIC_CF : Endif
Return

$AB_CF
Rollback
Return

# - - - - - - - - - - - - - - - - - - - -
$UPDFIL_CF
Gosub XMLF_INI
XT_DOSSIER=DOSORG
Call MACHINE(XT_DOSSIER,XT_MAC,XT_DOSNAM) From ORDSYS
XT_FCYCOD=FCYCOD : XT_TIMSTP=TIMSTP
XT_XMLID="TIM"
Gosub XMLF_INI2
Wrseq '<ELMTS ID="TIM" TIM="' +num$([F]TIMALL)+ '">'  Using [XTS]
Wrseq ' <ELMT ID="FCY" TIM="' +num$([F]TIMAYS)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="FLD" TIM="' +num$([F]TIMAYF)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="MES" TIM="' +num$([F]TIMAYM)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="MEN" TIM="' +num$([F]TIMAYC)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="SPE" TIM="' +num$([F]TIMAYX)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="INT" TIM="' +num$([F]TIMAYI)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="PAG" TIM="' +num$([F]TIMAYG)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="ENT" TIM="' +num$([F]TIMAYE)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="BLC" TIM="' +num$([F]TIMAYB)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="DLK" TIM="' +num$([F]TIMAYL)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="ACT" TIM="' +num$([F]TIMAYA)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="CND" TIM="' +num$([F]TIMAYW)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="PRF" TIM="' +num$([F]TIMAYD)+ '"/>'  Using [XTS]
Wrseq ' <ELMT ID="ADV" TIM="' +num$([F]TIMAYU)+ '"/>'  Using [XTS]

If PTRTB: Gosub TIMSTP_FILE From AYTGENB: Endif           # Perso par produit

Wrseq '</ELMTS>'  Using [XTS]
#
Gosub XMLF_CL

Return

# - - - - - - - - - - - - - - - - - - - -
$ASSIGN_TIM
WDF_TIMSTP = evalue("[F]TIM" + OBJCOD)
If (WDF_TIMSTP < WD_TIMSTP or WDF_TIMSTP < 20070101000000 )    # protection sur données fichiers fausses
    Assign ("[F:AYS]TIM" + OBJCOD) With [L]WD_TIMSTP
Endif
Return

