#<AdxTL>@(#)7.0.0.0 $Revision$

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 When "IMP_CREATION"  : Gosub IMP_CREATION
 When "IMP_MODIF"     : Gosub IMP_MODIF
 When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

$IMP_OUVRE
If clalev([DIE]) = 0 : Local File GDIE       [DIE]  : Endif
If clalev([CCE]) = 0 : Local File CACCE      [CCE]  : Endif
If clalev([CYM]) = 0 : Local File GCCEPYM    [CYM]  : Endif
If clalev([CLS]) = 0 : Local File GACCCLS    [CLS]  : Endif
If clalev([CRY0])= 0 : Local File GCCEGRUPYM [CRY0] : Endif
If clalev([CRY2])= 0 : Local File GCCEGRUPYM [CRY2] : Endif
If clalev([CRY3])= 0 : Local File GCCEGRUPYM [CRY3] : Endif

Local Decimal LIVELLO
Local Char IMPDIE(GLONDIE)

Local Integer NBRDIE
NBRDIE = nbrecord([DIE])
Local Char DIEIMP(GLONDIE)(1..NBRDIE)
Raz NBRDIE
Return

$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
If OK
 I = find([F:CYM]DIE,DIEIMP(1..NBRDIE))
 If !I
  NBRDIE+=1
  DIEIMP(NBRDIE)= [F:CYM]DIE
 Endif
Endif
Return


$CONTROLE
# Issue 67598 - We do not allow to repeat a subgroup within the same pyramid and a dimension within the same group or pyramid.
  If clalev([CRY4])= 0 : Local File GCCEGRUPYM [CRY4] :  Endif
#-------- Avoiding duplicate CCE or SBBGRU
  Filter [F:CRY4] Where PYM = [F:CRY]PYM & GRU = [F:CRY]GRU & LEV = [F:CRY]LEV & SBBGRU = [F:CRY]SBBGRU & CCE = [F:CRY]CCE & LIN <> [F:CRY]LIN
  For [F:CRY4]CRY0 : GMESSAGE = mess(00069,00104,1)-[CRY4]GRU-[CRY4]CCE : OK = 0 : Break : Next
  Filter [CRY4]
  If OK = 0 : Return : Endif
# End issue 67598
#--------- The PYM field is mandatory and existing
If [F:CRY]PYM=""
 GMESSAGE ="PYM"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [CYM]CYM0=[F:CRY]PYM
 If fstat
  GMESSAGE = "PYM"-mess(83,123,1)-[F:CRY]PYM  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- The DIE field is to be recovered under the pyramid (<> import groups accounts, cf IMPGRY)
[L]IMPDIE = [F:CYM]DIE

#--------- The LEV field
LIVELLO = [F:CRY]LEV
Filter [CRY2] Where PYM=[F:CRY]PYM and SBBGRU=[F:CRY]GRU and LEV>=LIVELLO
Read [F:CRY2] First
If !fstat & [F:CRY2]GRU<>""
 GMESSAGE = (mess(32,113,1)-[F:CRY2]GRU-">"-num$([F:CRY2]LEV)) : # Regroupé dans
 OK=0 : Return
Endif
Filter [CRY2]
For [CRY2]CRY0 Where PYM=[F:CRY]PYM & GRU=[F:CRY]GRU & CCE=""
 Filter [CRY3] Where PYM=[F:CRY]PYM and GRU=[F:CRY2]SBBGRU
 Read   [CRY3]  First
 If !fstat
  If   LIVELLO>=[F:CRY3]LEV
   GMESSAGE = mess(40,113,1)-"(>"-num$([F:CRY3]LEV)-")" : # Niveau incompatible avec le groupe ...
  OK=0 : Break
  Endif
 Endif
 Filter [CRY3]
Next
If OK=0 : Return : Endif

#--------- The SBBGRU field
If [F:CRY]SBBGRU<>""
 Read [CRY0]CRY0(2) = [F:CRY]PYM;[F:CRY]SBBGRU
 If !fstat & [F:CRY0]LEV<=[F:CRY]LEV
  GMESSAGE = [F:CRY]SBBGRU-mess(31,113,1)-num$([F:CRY0]LEV) : # Groupe de niveau ...
  OK=0 : Return
 Endif
Endif

#--------- The CCE field
[F:CRY]CCE = toupper([F:CRY]CCE)
If [F:CRY]CCE<>""
 JOKER  = 0
 For I=1 To len([F:CRY]CCE)
  If instr(1,"!#?*",mid$([F:CRY]CCE,I,1))
   JOKER = 1 : Break
  Endif
 Next I
 If !JOKER
  Read [CCE]CCE0 = [L]IMPDIE;[F:CRY]CCE
  If fstat
   GMESSAGE = [F:CRY]CCE-mess(35,106,1)-"("+[L]IMPDIE+")"  # Nonexistent dimension value
   OK=0 : Return
  Endif
 Endif
Endif

Return

$IMP_MODIF
$IMP_CREATION

# Deleting records in "too much" - F54934
If [F:CRY]LIN=1
 Delete [CRY2] Where PYM=[F:CRY]PYM and GRU=[F:CRY]GRU and LIN>1
 If fstat=1
  GOK = -1 : GLOCK="$GCCEGRUPYM"-[F:CRY]PYM-[F:CRY]GRU : Return
 Endif
Endif

# Issue 67598 - We do not allow to repeat a dimension n the pyramid in different groups.
  If clalev([CRY4])= 0 : Local File GCCEGRUPYM [CRY4] :  Endif

  If [F:CRY]CCE <> ""
    Delete [F:CRY4] Where PYM = [F:CRY]PYM & CCE = [F:CRY]CCE & GRU <> [F:CRY]GRU
    If fstat = [V]CST_ALOCK
      GOK = -1 : GLOCK="$GCCEGRUPYM"-[F:CRY]PYM-[F:CRY]GRU : Return
    Endif
    # Warning : "Dimension XXXX grouped in new group XXXXX"
    Call ECR_TRACE([F:CRY]PYM-[F:CRY]GRU-[F:CRY]CCE - " : " -mess(17,103,1)-[F:CRY]CCE-tolower(mess(38,103,1))-tolower(mess(107,102,1))-[F:CRY]GRU,0) From GESECRAN
  Endif
# End issue 67598

Return


$IMP_FERME
Local Char WFOUNDED(1) : WFOUNDED = 'N'
If NBRDIE
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 # Resynchronization of pyramids sections
 Call ECR_TRACE(mess(152,116,1),0) From GESECRAN
 For I=1 To NBRDIE
  Call MAJ_AXE(DIEIMP(I),nomap) From LIENPYRCCE
 Next
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return

