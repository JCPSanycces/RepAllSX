#<AdxTL>@(#)0.0.0.0 $Revision$Class Spouses (>1)
# Supervisor
## CRUD-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:07 218


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOJNT

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLOJNT

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLOJNT,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOJNT
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLOJNT.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLOJNT
Else
 Gosub AUPDATE_EMPLOJNT
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLOJNT.freeSnapshot
EMPLOJNT.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOJNT._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLOJNT.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOJNT.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLOJNT.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOJNT.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLOJNT.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOJNT.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLOJNT
Trbegin [F:JNT]
 Gosub AUPDATE_EMPLOJNT
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLOJNT
[L]A_ASTALIN = EMPLOJNT.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOJNT._MAJSQL_EMPLOJNT(EMPLOJNT))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLOJNT.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLOJNT.snapshotEnabled=1
 [L]A_RETIK = EMPLOJNT.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLOJNT.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLOJNT.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOJNT.ASTALIN = [V]CST_ALL
Endif
Return



