Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EQUCOMP" : GZNUM = 55805 : Endif
Gosub _AFF
End

$ON_NBRTAXCER
Onevent BEFORE_INPUT Call AS_NBRTAXCER From W1CPYLEGKSA
Return

Subprog AS_NBRTAXCER
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
mkstat = 2 : GMESSAGE = ""
If !mkstat
Endif
Gosub _AFF
End

$ON_TAXEXRTEP
Return

$ON_ZTAXEXRTEP
Onevent BEFORE_AREA Gosub AV_ZTAXEXRTEP From W1CPYLEGKSA
Return

$AV_ZTAXEXRTEP
If clalev([F:HREXT])=0 : Local File HREXTRACT [HREXT] : Endif
Call LECTURE("HREXT",num$([M]TAXEXRTEP(indice)),"") From CONTOBJ
zc = [F:HREXT]EXRTIT
Gosub _AFF
Return

$ON_TAXRUNDAT
Onevent BEFORE_AREA Gosub AV_TAXRUNDAT From W1CPYLEGKSA
Return

$AV_TAXRUNDAT
Chgfmt [M]TAXRUNDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TAXLIVIND
Onevent INIT_AREA Call D_TAXLIVIND(zc) From W1CPYLEGKSA
Return

Subprog D_TAXLIVIND(VALEUR)
Variable Integer VALEUR
If varinit([M]TAXLIVIND,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


