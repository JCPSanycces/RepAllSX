Return

Subprog AS_HOLCPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_HOLCPY(zc) From W1CPYLEGKSA
Onkey   2 Titled GBOUTS Call S_HOLCPY(zc) From W1CPYLEGKSA
Onkey 144 Titled GBOUTP Call P_HOLCPY(zc) From W1CPYLEGKSA
Onkey 146 Titled GBOUTA Call SA_HOLCPY(zc) From W1CPYLEGKSA
Gosub _AFF
End

Subprog C_HOLCPY(VALEUR)
Variable Char    VALEUR()
## Action ACONTCPY
Call CONTSOC(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "HOLCPY" : GZNUM = 55812 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CPY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "HOLCPY" : GZNUM = 55812 : Endif
Endif
Gosub _AFF
End

$AMM_HOLCPY
Call AM_HOLCPY(zc)
If !mkstat & GOBJET
 zoncou = "HOLCPY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HOLCPY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZHOLCPY)")>indice
 [M]HOLCPY(indice) = VALEUR
 Affzo ZHOLCPY(indice)
Endif
Gosub _AFF
End

Subprog S_HOLCPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CPY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_HOLCPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_HOLCPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HOLCPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

