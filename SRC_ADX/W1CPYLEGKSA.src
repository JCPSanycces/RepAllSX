#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGKSA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:31"
A_USER  = "DOC"
A_STAMP = "20181109230331"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRTAXCER"
  If [M]NBRTAXCER=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGKSA [CLKSA]
Gosub HORODAT
Local Inpbox "CPYLEGKSA" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLKSA] As [SIM_]
Grizo [CLKSA]5
Grizo [CLKSA]10
Grizo [CLKSA]15
Grizo [CLKSA]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLKSA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=12 : X2(0)=100 : Y1(0)=8 : Y2(0)=14
X1(1)=12 : X2(1)=100 : Y1(1)=15 : Y2(1)=17
X1(2)=12 : X2(2)=100 : Y1(2)=18 : Y2(2)=20
X1(3)=12 : X2(3)=100 : Y1(3)=21 : Y2(3)=20
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1CPYLEGKSA
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_TCCCOD
Onevent CONTROL Call C_TCCCOD(zc) From W1CPYLEGKSA
Onevent BEFORE_INPUT Call AS_TCCCOD(zc) From W1CPYLEGKSA
Return

Subprog AS_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16749,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TCCCOD(zc) From W1CPYLEGKSA
Onkey   2 Titled GBOUTS Call S_TCCCOD(zc) From W1CPYLEGKSA
Onkey 144 Titled GBOUTP Call P_TCCCOD(zc) From W1CPYLEGKSA
Gosub _AFF
End

Subprog C_TCCCOD(VALEUR)
Variable Decimal VALEUR
## Action %CNTOBJ
Call CONTNUM("HRTCC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 55798 : Endif
Gosub _AFF
End

Subprog S_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "HRTCC"
PARMSK(2) = "!"
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("HRTCC",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRTCC",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

