################################################################################
$ACTION
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When Default
Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE

  #--------------------------------------------------------------------#
  # Chargement des paramètres zones libres dans des variables globales #
  #--------------------------------------------------------------------#
  Call INIT_INTIT () From GLOZLIBR
Return

################################################################################
Subprog AFFICHE_DEVISES()

  Local Integer I      : # indice pour boucle sur les zones libres

  # En attendant la disparition de FRZ9
  If !clalev([M:FRZ9])
    Default Mask "[M:"+GABREV+"9]"
  Else
    Default Mask [M:FRZ9]
  Endif

  For I=1 To 6
    If evalue("[M]DEVDM"+num$(I)) <> evalue("GABZLMNT"+num$(I))
      Assign "[M]DEVDM"+num$(I) With evalue("GABZLMNT"+num$(I))
      Affzo ="DEVDM"+num$(I)
    Endif
  Next
End

################################################################################
Subprog INIT_CREORI()

  # En attendant la disparition de FRZ9
  If !clalev([M:FRZ9])
    Default Mask "[M:"+GABREV+"9]"
  Else
    Default Mask [M:FRZ9]
  Endif

  [M]CREORI = GVML_COSAITR
  Affzo [M]CREORI
End

