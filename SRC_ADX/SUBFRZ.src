###########################################################################
# Mémorisation du n° de la table diverse de référence des champs USRFLDAn #
###########################################################################
####################################
Subprog GERE_REFTAB (PZONE, PVALEUR)
Value Char PZONE()
Value  Char PVALEUR()
# Affecte le numéro de la table diverse au "champ qui va bien", lorsque
# la valeur de la ZL ADI est renseignée.
# Vide la rubrique contenant le numéro de la table diverse, lorsque la
# valeur n'est pas renseignée
# Attention, ce SP est aussi appelé depuis FUNLOFLDAB

  If PVALEUR<>"" Then
    Assign ("[M]REFTAB"+right$(PZONE,8)) With evalue("GABLIADI"+right$(PZONE,8))
  Else
    Assign ("[M]REFTAB"+right$(PZONE,8)) With 0
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FREEZON9) 12/02/2008 15:42:07 (GBO)
######################################################################################
Subprog CL_EVTLIST(VALEUR)
Variable Char    VALEUR()
  Local Char    VALBOUT(250) , PARBOUT(250)(1..20)
  Local Integer CHGT_LEVEL

  # si tunnel depuis bien comptable (GESFAS) vers les Ã©lÃ©ments phy, il faut recharger les Ã©vts relatifs aux Ã©lts
  CHGT_LEVEL=G_NON
  If GPHY=G_OUI Then
    If GPILNAV > 1 Then
      If find(GNAVIG(GPILNAV),"GESPHY") & find(GNAVIG(GPILNAV-1),"GESFAS") Then
        CHGT_LEVEL=G_OUI
      Endif
    Endif
  Endif

  #Fq-76033 si tunnel depuis bien comptable (GESFAS) vers les dépenses, il faut recharger les Evts relatifs aux Dépenses
# CHGT_LEVEL=G_NON FQ99020
    If GPILNAV > 1 Then
      If find(GNAVIG(GPILNAV),"GESLOF") & find(GNAVIG(GPILNAV-1),"GESFAS") Then
        CHGT_LEVEL=G_OUI
      Endif
    Endif

  If dim([M:FAS0]AASREF)>0 and CHGT_LEVEL=G_NON
   PARBOUT(1) = [M:FAS0]AASREF
   PARBOUT(2) = num$(GVML_OMBIEN)
  Elsif dim([M:LOF0]CODLOF)>0
   PARBOUT(1) = [M:LOF0]CODLOF+"~"+num$([M:LOF0]LINLOF)
   PARBOUT(2) = num$(GVML_OMDEPEN)
  Elsif dim([M:LEA0]LEAREF)>0
   PARBOUT(1) = [M:LEA0]LEAREF
   PARBOUT(2) = num$(GVML_OMLOCFI)
  Elsif dim([M:GRT0]GRAREF)>0
   PARBOUT(1) = [M:GRT0]GRAREF
   PARBOUT(2) = num$(GVML_OMSUBV)
  Elsif dim([M:PHY0]PHYREF)>0
   PARBOUT(1) = [M:PHY0]PHYREF
   PARBOUT(2) = num$(GVMLOMPHY)
  Elsif dim([M:CCN0]CCNREF)>0
   PARBOUT(1) = [M:CCN0]CCNREF
   PARBOUT(2) = num$(GVML_OMCCN)
  Endif

  FLGEXE = 1
  GACTION = "EVTLIST"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTEVTLIST","EVTLIST",4,"XYEVTLIST") From GTRAITE

End

