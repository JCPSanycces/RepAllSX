########################################################################################################################

$TRCTEC_OUVRE
  If [F:TPE]DBGMOD=G_OUI
   GTECTRC = G_OUI
   Global Char GFICTECTRC(255)
   # X3-48258 FHA Log file created in the TRA directory with .tra extension - start
   #If GUSER="GBO"
   # GFICTECTRC="#@D:\tmpcpt\TRTCPT"+"_"+GUSER+"_"+num$(adxuid(2))+"_"+[F:FCY]FCY+"_"+[F:TPE]ACETYP+".log"
   #Else
    #GFICTECTRC=filpath("tmp","TRTCPT"+"_"+GUSER+"_"+num$(adxuid(2))+"_"+[F:FCY]FCY+"_"+[F:TPE]ACETYP,"log")
    GFICTECTRC=filpath("TRA","TRTCPT"+"_"+GUSER+"_"+num$(adxuid(2))+"_"+[F:FCY]FCY+"_"+[F:TPE]ACETYP,"tra")
   #Endif
   # X3-48258 FHA end
   Openo GFICTECTRC,0              Using [XLOG]
   Iomode adxirs chr$(13)+chr$(10) Using [XLOG]
   Iomode adxium 50                Using [XLOG]
  Else
   GTECTRC=G_NON
  Endif
Return

$TRCTEC_DEBTPE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "******************************************************************"      Using [XLOG]
 #Wrseq "Site"-[F:FCY]FCY-"Type d'ecriture"-[F:TPE]ACETYP                         Using [XLOG]  :# X3-48258 FHA translation
 Wrseq "Site"-[F:FCY]FCY-"Posting Type"-[F:TPE]ACETYP                            Using [XLOG]   :# X3-48258 FHA translation
 Wrseq date$-time$                                                               Using [XLOG]
 Wrseq "******************************************************************"      Using [XLOG]
Return

#=============================================================================
$TRCTEC_FINTPE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "******************************************************************"      Using [XLOG]
 Wrseq ""                                                                        Using [XLOG]
Return

#=============================================================================
$TRCTEC_PERIODE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq ""                                                            Using [XLOG]
 Wrseq "======================================================"      Using [XLOG]
 #Wrseq " Période du"-format$("D:" + GFMDAT4,PDATMIN)-"au"-format$("D:" + GFMDAT4,PDATMAX) Using [XLOG] :# X3-48258 FHA translation
 Wrseq " Period from"-format$("D:" + GFMDAT4,PDATMIN)-"to"-format$("D:" + GFMDAT4,PDATMAX) Using [XLOG] :# X3-48258 FHA translation
 Wrseq " "-date$-time$                                               Using [XLOG]
 Wrseq "======================================================"      Using [XLOG]
 Wrseq ""                                                            Using [XLOG]
Return

#=============================================================================
$TRCTEC_CAS
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "[$DEF_CAS]"-date$-time$                                                  Using [XLOG]
 LIGNE="LCAS ="-num$(LCAS)
 Case LCAS
  When GCAS_DEPREC
   LIGNE += "(DEPREC)"
   #LIGNE += " Comptabilisation"-mess(max(1,PTYPPST),GML_TYPPST,1)            :# X3-48258 FHA translation
   LIGNE += " Posting"-mess(max(1,PTYPPST),GML_TYPPST,1)                      :# X3-48258 FHA translation
  When GCAS_EVENT
   #LIGNE += "(EVENEMENTS)"                                                   :# X3-48258 FHA translation
   LIGNE += "(EVENTS)"                                                        :# X3-48258 FHA translation
  When GCAS_AUTRE
   #LIGNE += "(AUTRE)"                                                        :# X3-48258 FHA translation
   LIGNE += "(OTHER)"                                                         :# X3-48258 FHA translation
 Endcase
 Wrseq space$(5)+LIGNE                                                           Using [XLOG]
Return

#=============================================================================
$TRCTEC_CRITERE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "[$DEF_CRITERES]"-date$-time$                                                       Using [XLOG]
 #Wrseq space$(5)+"Criteres de selection utilises pour la comptabilisation"                 Using [XLOG]  :# X3-48258 FHA translation
 Wrseq space$(5)+"Selection criteria used for posting"                                     Using [XLOG]   :# X3-48258 FHA translation
 Wrseq ""                                                                                  Using [XLOG]
 Wrseq space$(10)+"LCRITSUP :"-LCRITSUP                                                    Using [XLOG]
 Wrseq space$(10)+"LCRITPLN :"-LCRITPLN                                                    Using [XLOG]
 Wrseq space$(10)+"LCRITDAT :"-LCRITDAT                                                    Using [XLOG]
 Wrseq space$(10)+"LCRITDIV :"-LCRITDIV                                                    Using [XLOG]
 Wrseq ""                                                                                  Using [XLOG]
 #Wrseq space$(5)+"Valeurs des variables utilisees pour la selection"                       Using [XLOG]  :# X3-48258 FHA translation
 Wrseq space$(5)+"Values of variables used for the selection"                              Using [XLOG]   :# X3-48258 FHA translation
 Wrseq ""                                                                                  Using [XLOG]
 If LCAS=GCAS_EVENT | LCAS=GCAS_DEPREC | LCAS=GCAS_AUTRE | LCAS=GCAS_CCNRPR
  Wrseq space$(10)+"LCPY     :"-LCPY                                                       Using [XLOG]
  Wrseq space$(10)+"LFCY     :"-LFCY                                                       Using [XLOG]
  Wrseq space$(10)+"LDPRPLN  :"-mess(LDPRPLN,GML_NPLAN,1)                                       Using [XLOG]
  Wrseq space$(10)+"LDATMIN  :"-format$(GFMDAT,LDATMIN)                                    Using [XLOG]
  Wrseq space$(10)+"LDATMAX  :"-format$(GFMDAT,LDATMAX)                                    Using [XLOG]
  Wrseq ""                                                                                 Using [XLOG]
 Endif
Return

#=============================================================================
$TRCTEC_VERS_TEMP
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "[$xxxxx_VERS_TEMP]"-date$-time$                                                    Using [XLOG]
 Wrseq space$(5)+"Order by                              ="-LREADKEY                        Using [XLOG]
 #Wrseq space$(5)+"Expression d'evaluation de rupture    ="-LRUPEVAL                        Using [XLOG]  :# X3-48258 FHA translation
 Wrseq space$(5)+"Expression of evaluation for break    ="-LRUPEVAL                        Using [XLOG]   :# X3-48258 FHA translation
 #Wrseq space$(5)+"Tri analytique en majeur              ="-mess(max(1,[M:TPE]SORTCCE),1,1) Using [XLOG]  :# X3-48258 FHA translation
 Wrseq space$(5)+"Major analytical sort              ="-mess(max(1,[M:TPE]SORTCCE),1,1)    Using [XLOG]   :# X3-48258 FHA translation
 #Wrseq space$(5)+"Nombre d'enregistrements selectionnes ="-num$(rowcount([F:RDEC]))        Using [XLOG]  :# X3-48258 FHA translation
 Wrseq space$(5)+"Number of selected records ="-num$(rowcount([F:RDEC]))                   Using [XLOG]   :# X3-48258 FHA translation
 Wrseq ""                                                                                  Using [XLOG]
Return

#=============================================================================
$TRCTEC_VERS_TEMP_VIDE_CPT
 If GTECTRC<>G_OUI : Return : Endif
 If [M:TPE]SRCTYP=GVML_SRCDEP : LIGNE = [F:OBJ]AASREF-num$([F:CPT]DPEDEV)    : Endif
 If [M:TPE]SRCTYP=GVML_SRCRPR : LIGNE = [F:OBJ]AASREF-num$([F:CPT]ACGRPRDEV)-num$([F:CPT]FISRPRDEV) : Endif
 Wrseq LIGNE                                                                               Using [XLOG]
Return

#=============================================================================
$TRCTEC_TMPTABDTA
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq ""                                                                                  Using [XLOG]
 #Wrseq "Vidage du contenu de la table TMPCPTDTA :"                                         Using [XLOG]  :# X3-48258 FHA translation
 Wrseq "Content of table TMPCPTDTA :"                                                      Using [XLOG]   :# X3-48258 FHA translation
 Wrseq "-------------------"                                                               Using [XLOG]
 # X3-48258 FHA Record description - start
 Wrseq "PCENUM"+";"+
&      "SEQNUM"+";"+
&      "REF"+";"+
&      "ACCCOD"+";"+
&      "CPTREF"+";"+
&      "SNS"+";"+
&      "AMT(0)"+";"+
&      "AMT(1)"+";"+
&      "AMT(2)"+";"+
&      "AMT(3)"+";"+
&      "AMT(4)"+";"+
&      "AMT(5)"+";"+
&      "AMT(6)"+";"+
&      "AMT(7)"+";"+
&      "AMT(8)"+";"+
&      "AMT(9)"+";"+
&      "DSP"+";"+
&      "DIE(0)"+";"+
&      "CCE(0)"+";"+
&      "DIE(1)"+";"+
&      "CCE(1)"+";"+
&      "DIE(2)"+";"+
&      "CCE(2)"+";"+
&      "DIE(3)"+";"+
&      "CCE(3)"+";"+
&      "DIE(4)"+";"+
&      "CCE(4)"+";"+
&      "DIE(5)"+";"+
&      "CCE(5)"+";"+
&      "DIE(6)"+";"+
&      "CCE(6)"+";"+
&      "DIE(7)"+";"+
&      "CCE(7)"+";"+
&      "DIE(8)"+";"+
&      "CCE(8)"+";"+
&      "AGRKEY"                                                                            Using [XLOG]
# X3-48258 FHA end

 For [F:TCD] Where TRTNUM=GNUMTRT
  LIGNE = num$([F:TCD]PCENUM)+";"+
&         num$([F:TCD]SEQNUM)+";"+
&         [F:TCD]REF+";"+
&         [F:TCD]ACCCOD+";"+
&         num$([F:TCD]CPTREF)+";"+
&         num$([F:TCD]SNS)+";"+
&         num$([F:TCD]AMT(0))+";"+
&         num$([F:TCD]AMT(1))+";"+
&         num$([F:TCD]AMT(2))+";"+
&         num$([F:TCD]AMT(3))+";"+
&         num$([F:TCD]AMT(4))+";"+
&         num$([F:TCD]AMT(5))+";"+
&         num$([F:TCD]AMT(6))+";"+
&         num$([F:TCD]AMT(7))+";"+
&         num$([F:TCD]AMT(8))+";"+
&         num$([F:TCD]AMT(9))+";"+
&         [F:TCD]DSP+";"+
&         [F:TCD]DIE(0)+";"+
&         [F:TCD]CCE(0)+";"+
&         [F:TCD]DIE(1)+";"+
&         [F:TCD]CCE(1)+";"+
&         [F:TCD]DIE(2)+";"+
&         [F:TCD]CCE(2)+";"+
&         [F:TCD]DIE(3)+";"+
&         [F:TCD]CCE(3)+";"+
&         [F:TCD]DIE(4)+";"+
&         [F:TCD]CCE(4)+";"+
&         [F:TCD]DIE(5)+";"+
&         [F:TCD]CCE(5)+";"+
&         [F:TCD]DIE(6)+";"+
&         [F:TCD]CCE(6)+";"+
&         [F:TCD]DIE(7)+";"+
&         [F:TCD]CCE(7)+";"+
&         [F:TCD]DIE(8)+";"+
&         [F:TCD]CCE(8)+";"+
&         [F:TCD]AGRKEY
  Wrseq LIGNE                                                                              Using [XLOG]
 Next
 Wrseq "-------------------"                                                               Using [XLOG]
Return

#=============================================================================
$TRCTEC_TMPTABLCK
Return

#=============================================================================
$TRCTECVIDETCD
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "[$VIDE_TABTEMP]"-date$-time$                                             Using [XLOG]
 #Wrseq "TCD"-num$(adxdlrec)-"enregistrements supprimes"                          Using [XLOG]  :# X3-48258 FHA translation
 Wrseq "TCD"-num$(adxdlrec)-"records deleted"                                    Using [XLOG]   :# X3-48258 FHA translation
Return

#=============================================================================
$TRCTEC_DEB_COMPTABILISE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq "[$COMPTABILISE]"                                                          Using [XLOG]
 #Wrseq space$(5)+"Debut : "+date$-time$                                           Using [XLOG] :# X3-48258 FHA translation
 Wrseq space$(5)+"Start : "+date$-time$                                           Using [XLOG]  :# X3-48258 FHA translation
Return

#=============================================================================
$TRCTEC_PARM_COMPTABILISE
 If GTECTRC<>G_OUI : Return : Endif
 #Wrseq space$(10)+"Valeurs imposées"                                              Using [XLOG] :# X3-48258 FHA translation
 Wrseq space$(10)+"Forced values"                                                 Using [XLOG]  :# X3-48258 FHA translation
 Local Integer I_ZONE
 For I_ZONE=1 To dim(TZONE)
  Wrseq space$(15)+TZONE(I_ZONE)+space$(10-len(TZONE(I_ZONE)))+TVAL(I_ZONE) Using [XLOG]
 Next I_ZONE
Return

#=============================================================================
$TRCTEC_FIN_COMPTABILISE
 If GTECTRC<>G_OUI : Return : Endif
 Wrseq space$(5)+"GOK/STAT/MESSA "-"="-num$(GOK)+"/"+num$(STAT)+"/"+MESSA          Using [XLOG]
 #Wrseq space$(5)+"Fin   : "+date$-time$                                           Using [XLOG] :# X3-48258 FHA translation
 Wrseq space$(5)+"End   : "+date$-time$                                            Using [XLOG] :# X3-48258 FHA translation
Return

