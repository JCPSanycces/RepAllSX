#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT82   UTI process                                    FIN Module
#            Migration To U11 - CHALLENGER version
#
#  ==> New field must be initialized :
#     [F:GAC]TYPVATCTL (ML3684) to 1 (Inactif)
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update GACCOUNT (TYPVATCTL field)") From LECFIC

  Call MAJ_UTICPT82(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT82(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","GACCOUNT","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"GACCOUNT")<>0 : End : Endif

Call ECR_TRACE("UTICPT82 : Start of process on : "+DOSSIER,0) From GESECRAN

If clalev([F:GAC])=0  Local File =DOSSIER+".GACCOUNT"   [GAC] : Endif

Call DEBTRANS From GLOCK
Trbegin [GAC]
Update [GAC] Where TYPVATCTL < 1 With TYPVATCTL = 1
Call ECR_TRACE("UTICPT82 / TYPVATCTL : " + num$(adxuprec) + "[GAC] records processed", 0) From GESECRAN
Commit
Close Local File [GAC]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT82 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT82(APPLI)
End

#######################################################################
# To execute during DOSMAJ80 process (validation of folder)
# call by DOSMAJ80
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT82(APPLI)
End

