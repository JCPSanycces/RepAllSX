#<AdxTL>@(#)0.0.0.0 $Revision$

Raz GPILOBJ,GNBMASKOUV
Local Char    VALEUR(30), PARAM(250)(1..20)
GABREV = "AUS"
PARAM(1) = GABREV
PARAM(2) = "MB"
PARAM(4) = "M"
Call SAISIE_CHAR(VALEUR,PARAM,"AOBJTXT","GOBJTXT","XWGOBJTXT") From GSAISIE
End

#-------------------------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
 When Default
Endcase
Return

$INIT_DIA
Local Integer OK
Call LEC_ABB(PARAM(1),PARAM(2),PARAM(3),[M]PICTURE,OK) From GOBJTXT
#SAM 120819
[M:AOXB]PARAM6= PARAM(6)
Affzo [M:AOXB]PICTURE
Return

$EXEC
#SAM 120819
If [M:AOXB]PARAM6= "0"
  Return
Endif
Call MAJ_ABB(PARAM(1),PARAM(2),PARAM(3),[M]PICTURE, val(PARAM(4)),OK) From GOBJTXT
[M:AOX]PHOTO = [M:AOXB]PICTURE
PARAM(5) = "1"
Return

#SAM 120819
Subprog AS_PICTURE
If [M:AOXB]PARAM6= "0"
  Diszo [M:AOXB]PICTURE
  Affzo [M:AOXB]PICTURE
Endif
End


######################################################################################

