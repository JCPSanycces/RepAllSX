#<AdxTL>@(#)1.0.0.0 $Revision$ Eléments physiques
#* ################################################################################################
#*                P H Y E L T    -     P h y s i c a l    a s s e t s
#* ################################################################################################
#*
#* PHYELT data class manages physical assets. User can create, update, delete a physical element.
#* The reference of a physical asset can be numbered automatically depending on parameter.
#* A physical asset belongs to a location. It can be transfered from one location to another.
#* It also can be disposed.
#* A physical element can be linked or not to a fixed asset.
#* When linked to a fixed asset, transfer or disposal must be validated by the asset manager.
#* Therefore a pending movement is generated, for the "to come" decision.
#* When it is not linked to a fixed asset, transfer or disposal takes places immediatly.
#*
#* Physical asset is created for inventory needs. For so, it has got a location and a barcode.
#*
#* ________________________________________________________________________________________________
#*
#TODO
# Issue on reference that is mandatory before automatic numbering
# Managing physical asset event when creating or deleting a physical asset
# Managing free fields
# Selection / Jump to (without data type depending on activity code)
#

$EVENTS

  Case CURPTH
    When ""
      Case [L]AEVENT

        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE
#        When "AINSERT"                 : Gosub AINSERT  : # To be used only if insert is not taken in charge by the crud
        When "AINSERT_AFTER"           : Gosub AINSERT_AFTER
#        When "AINSERT_ROLLBACK"        : Gosub AINSERT_ROLLBACK

        When "AREAD_BEFORE"            : Gosub AREAD_BEFORE
        When "AREAD_AFTER"             : Gosub AREAD_AFTER

        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER
        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE
#        When "AUPDATE"                 : Gosub AUPDATE  : # To be used only if update is not taken in charge by the crud
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER
#        When "AUPDATE_ROLLBACK"        : Gosub AUPDATE_ROLLBACK

        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE
#        When "ADELETE_CONTROL_AFTER"   : Gosub ADELETE_CONTROL_AFTER
#        When "ADELETE_BEFORE"          : Gosub ADELETE_BEFORE
#        When "ADELETE"                 : Gosub ADELETE   : # To be used only if delete is not taken in charge by the crud
        When "ADELETE_AFTER"           : Gosub ADELETE_AFTER
#        When "ADLETE_ROLLBACK"         : Gosub ADELETE_ROLLBACK

      Endcase
    When Default
  Endcase
Return

$METHODS
  Case CURPTH
    When ""
      Case [L]AMETHOD

        When Default  : Gosub METHODS From PHYELT_C_MPR

      Endcase
    When Default
  Endcase

Return

$OPERATIONS

  Case CURPTH
    When ""
      Case [L]AOPERATION

        When Default  : Gosub OPERATIONS From PHYELT_C_MPR

      Endcase
    When Default
  Endcase

Return

$PROPERTIES
  Case CURPTH
    When ""
      Gosub PROPERTIES  From PHYELT_C_PRO
    When Default
  Endcase
Return

# -------------------------------------
# PHYELT standard data class methods
# -------------------------------------

#**
#* ################################
#* Event: AINSERT_CONTROL_BEFORE
#*        Executes different controls before inserting a physical asset before control on properties is done
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AINSERT_CONTROL_BEFORE
Local Char    MSG(100)
Local Char    ERRMSG(140)
Local Integer RET

  #**
  #* ==> FCY > If the location is filled and the facility is empty, facility is inhereted from the location
  #*!
  If this.FCY = AVOID.ACHAR and this.LCTCOD <> AVOID.ACHAR
    Local Instance LCT Using C_PHYLCT
    LCT = NewInstance C_PHYLCT AllocGroup null
    If fmet LCT.AREAD(this.LCTCOD) = [V]CST_AOK
      this.FCY = LCT.FCY
    Endif
    FreeGroup LCT
  Endif

  #**
  #* ==> CPY > If the facility is filled and the company is empty, company is inhereted from the facility
  #*!
  If this.CPY = AVOID.ACHAR and this.FCY <> AVOID.ACHAR
    this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY")
  Endif

  #- PHYREF -----
  Local File PHYELT [PHY]
  Read [F:PHY]PHY0=this.PHYREF
  If fstat = [V]CST_AOK
    # Object already exists
    [L]ASTATUS = fmet this.ASETERROR("PHYREF", mess(54,[V]CST_MSGMIS, 1), [V]CST_AERROR)
  Endif
  LogicClose File [PHY]

  #**
  #* ==> ISSTYP > When creating a physical asset, the disposal reason must be blank
  #*!
  If this.ISSTYP <> [V]CST_PDNOTISS
    [L]ASTATUS = fmet this.ASETERROR("ISSTYP", mess(191,[V]CST_MSGPHY, 1), [V]CST_AERROR)
  Endif

  #**
  #* ==> ISSDAT > A disposed physical element cannot be created
  #*!
  If this.ISSDAT <> AVOID.ADATE
    #  A disposed physical element cannot be created
    [L]ASTATUS = fmet this.ASETERROR("ISSDAT", mess(184,[V]CST_MSGPHY, 1), [V]CST_AERROR)
  Endif

  #**
  #* ==> TRFDAT >  When creating a physical asset, the last transfer date must be blank
  #*!
  If this.TRFDAT <> AVOID.ADATE
    [L]ASTATUS = fmet this.ASETERROR("TRFDAT", mess(229,[V]CST_MSGPHY, 1), [V]CST_AERROR)
  Endif

  #- CREORI -----
  If (this.CREORI = AVOID.ALIB)
    this.CREORI = [V]CST_COSAITR
  Endif

  Gosub _INSERT_UPDATE_CONTROL_BEFORE
 Return

#**
#* ################################
#* Event: AINSERT_CONTROL_AFTER
#*        Executes different controls before inserting a physical asset after control on properties was done
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AINSERT_CONTROL_AFTER
  Local Char  ERRMSG(140)

  #**
  #*    >>>>>>>>>>>
  #*    Rules of INSERT_UPDATE_AFTER are checked here.
  #*    They are described a little further in this document
  #*    <<<<<<<<<<<
  #*!
  Gosub _INSERT_UPDATE_CONTROL_AFTER
#
  #**
  #* ==> CPY > If both company and facility are filled, facility must be one of this company
  #*!
  If this.CPY <> AVOID.ACHAR and this.FCY <> AVOID.ACHAR
    If  not (this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"))
      [L]ERRMSG = func ASYRFNC.MES2(mess(53,[V]CST_MSGMIS, 1),num$(this.CPY), "CPY")
      [L]ASTATUS = fmet this.ASETERROR("CPY", [L]ERRMSG, [V]CST_AERROR)
    Endif
  Endif

  #**
  #* ==> LCTCOD > If both location and facility are filled, location must be one of this facility
  #*!
  If this.LCTCOD <> AVOID.ACHAR and this.FCY <> AVOID.ACHAR
    Local Char    FACILITY(GLONFCY)
    Local Instance LCT Using C_PHYLCT
    LCT = NewInstance C_PHYLCT AllocGroup null
    If fmet LCT.AREAD(this.LCTCOD) = [V]CST_AOK
      [L]FACILITY = LCT.FCY
    Endif
    If not ([L]FACILITY = this.FCY)
      # La valeur $1$ de la propriété $2$  n'est pas défini pour le site financier $3.
      [L]ERRMSG = func ASYRFNC.MES3(mess(94,[V]CST_MSGMIS, 1), this.LCTCOD, "LCTCOD", this.FCY)
      [L]ASTATUS = fmet this.ASETERROR("LCTCOD", [L]ERRMSG, [V]CST_AERROR)
    Endif
    FreeGroup LCT
  Endif

Return

#**
#* ################################
#* Event: AINSERT_BEFORE
#*        Is called after controls are done and just before inserting a physical asset in the database.
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AINSERT_BEFORE
Local Char    ERRMSG(140)
Local Integer RET

  Local Integer PHYAUTNUM
  #  AGETVALCHAR, AGETVALNUM, AGETVALDAT (Def. Level, level value, Parameter name)
  # Definition level : folder ALEVFOLD,  Company ALEVCPY, Facility ALEVFCY, User ALEVUSR, legislation ALEVLEG, 0= not specified
  # Level value      : folder, company, facility, user or legislation (according to Definition Level)
  # Parameter name
  [L]PHYAUTNUM = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,this.CPY,"PHYAUTNUM")
  #  [L]RET = fmet this.ACTX.APARAM.AGETVALERR
  #  If [L]LRET
  #    # PHY000 Parameter is not defined
  #    [L]ASTATUS = fmet this.ASETERROR("PHYREF", mess(141,105, 1) - num$([L]LRET), [V]CST_AFATAL)
  #    Return
  #  Endif
  If find([L]PHYAUTNUM, [V]CST_NAAUCUNE, [V]CST_NAFACUL, [V]CST_NAOBLIG )= 0
    [L]PHYAUTNUM = [V]CST_NAAUCUNE
  Endif

  #**
  #* ==> PHYREF > If PHYAUTNUM parameter value is "None", physical asset reference must be filled : It is mandatory.
  #*!
  If [L]PHYAUTNUM = [V]CST_NAAUCUNE and not (this.PHYREF <> AVOID.ACHAR) Then
    [L]ASTATUS = fmet this.ASETERROR("PHYREF",mess(19,[V]CST_MSGPHY,1), [V]CST_AERROR)
    Return
  Endif

  #**
  #* ==> PHYREF > If PHYAUTNUM parameter value is "mandatory" or ("optional" and physical asset reference is empty)
  #*     the physical asset reference is determined according to automatic numbering mechanism
  #*!
  If [L]PHYAUTNUM = [V]CST_NAOBLIG or ( [L]PHYAUTNUM = [V]CST_NAFACUL and this.PHYREF = AVOID.ACHAR) Then
    # Automatic numbering fpr physical asset reference
    Call GET_NEW_REFERENCE("PHY",4,1,this.CPY,this.FCY,date$,this.PHYREF,[L]RET) From FXDFCT_SYRA
    If ([L]RET) Then
      # Error in the automatic numbering
      [L]ERRMSG = func ASYRFNC.MES1(mess(22,[V]CST_MSGPAR, 1), "PHYREF")
      [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
      Return
    Endif
  Endif

  If ([L]ASTATUS = [V]CST_AOK)
    #**
    #* ==> ENAFLG > Field evaluation.
    #      If the physical asset is not linked to a fixed asset then it is allways equal to Yes
    #      If it is linked, it inherates its value from the ENAFAS field value of the fixed asset
    #      Not to do when coming from fixed assets (pb if num auto)
    #*!
    # FQ110284
    If fmet this.IS_LINKED_ASSET() and
&     (this.CREORI <> [V]CST_COIMPOR and this.CREORI <> [V]CST_COAUTCR)  # Origine de saisie IMPORT ou CREATION AUTOMATIQUE  # FQ110245

      this.ENAFLG = func _IS_ASSET_ENABLED(this)
    Else
      this.ENAFLG = [V]CST_AYES
    Endif
  Endif

Return

##------------------------
#$AINSERT
#Local Char  ERRMSG(140)
# To be used if insert is not taken in charge by the crud
#
#Return

#**
#* ################################
#* Event: AINSERT_AFTER
#*        Is called after a succesful insertion of the physical asset in the database.
#*        Additionnal update operations can be done.
#*        At this step, if an error occurs, a rollback is automatically performed
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AINSERT_AFTER
Local Char    ERRMSG(140)
Local Integer RET

  #**
  #* ==> PHYREF > After each physical asset creation, a event of physical asset creation must be created.
  #*!
  # Event of creation of a physical asset
  Local Char EVT_ERRMSG(250)
  Local Instance EVT Using C_EVENT : EVT = NewInstance C_EVENT AllocGroup null
  EVT.EVTINT  = "PHYCRT"
  [L]RET = fmet EVT.INIT_EVENT()

  EVT.REF     = this.PHYREF
  # Common event data
  EVT.EFFDAT  = date$
  EVT.ACCDAT  = AVOID.ADATE

  If not fmet EVT.CRT_EVENT_PHY (this) = [V]CST_AOK
    # Error when creating physical asset event.
    [L]ASTATUS = func FXDFCT_SYRA.COPY_MSG(EVT, this)
    [L]ASTATUS = [V]CST_AERROR
    [L]RET =  [V]CST_AFALSE
  Endif
  FreeGroup EVT
Return

#------------------------
$AREAD_BEFORE
Return

$AREAD_AFTER

#  # Useful to test statement syntax through debug
Local Char    MSG(100)
Local Char    ERRMSG(140)
Local Integer RET
Local Integer STA

  # Action indicators
  this.ORIACT    = [V]CST_OANONE
  this.PHYTRF    = [V]CST_AFALSE
  this.PHYISS    = [V]CST_AFALSE
  this.PHYCNLISS = [V]CST_AFALSE

  # ENAFLG evaluation ( that field is not stored in PHYELT table)
  # If the physical asset is not linked to a fixed asset then it is allways equal to Yes
  # If it is linked, it inherates its value from the ENAFAS field value of the fixed asset
  If (fmet this.IS_LINKED_ASSET())
    this.ENAFLG = func _IS_ASSET_ENABLED(this)
  Else
    # Physical ENAFLG get the table value and not put to CST_AYES
  Endif

  # Physical element is disposed.
  If (this.ISSDAT <> AVOID.ADATE) Then
    [L]ASTATUS = fmet this.ASETERROR("", mess(179,[V]CST_MSGPHY,1), [V]CST_AINFO)
  Else
    If (fmet this.IS_LINKED_ASSET())
      # Physical asset linked to a fixed asset
      Local Integer B_ISSMVT
      [L]B_ISSMVT = func PHYELT_C_MPR._COLL_FIND_MVT(this, "PHYMVT", [V]CST_PMVISS) <> [V]CST_ANOTDEFINED
      If ([L]B_ISSMVT = [V]CST_ATRUE)
        [L]ASTATUS = fmet this.ASETERROR("", mess(180,[V]CST_MSGPHY,1), [V]CST_AINFO)
      Endif
    Endif
  Endif

  # Physical element as a pending transfer movement.
  If (fmet this.IS_LINKED_ASSET())
    Local Integer B_TRFMVT
    [L]B_TRFMVT = func PHYELT_C_MPR._COLL_FIND_MVT(this, "PHYMVT", [V]CST_PMVGEO) <> [V]CST_ANOTDEFINED
    If ([L]B_TRFMVT = [V]CST_ATRUE)
      [L]ASTATUS = fmet this.ASETERROR("", mess(227,[V]CST_MSGPHY,1), [V]CST_AINFO)
    Endif
  Endif

Return

#**
#* ################################
#* Event: AUPDATE_CONTROL_BEFORE
#*        Executes different controls before updating a physical asset before control on properties is done
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AUPDATE_CONTROL_BEFORE
Local Char  MSG(100)
Local Char  ERRMSG(140)

#
Local Integer NCHGPRO : # Number of changed properties
Local Char CHGPRO(12)(1..)
Local Char PRO(12)

#  # Get changed properties
#  [L]NCHGPRO=this.getModified([L]CHGPRO)
#
#  # Check if hereunder properties have been changed
#  For [L]PRO = "CPY", "FCY", "PHYREF", "LCTCOD"
#    If find([L]PRO, [L]CHGPRO) > 0
#      # Modification is impossible : $1$ property must not be modified
#      [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), [L]PRO)
#      [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
#    Endif
#  Next [L]PRO

  #**
  #* ==> CPY > Company cannot be modified.
  #*!
  If not (this.CPY = this.snapshot.CPY)
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "CPY")
    [L]ASTATUS = fmet this.ASETERROR("CPY", [L]ERRMSG, [V]CST_AERROR)
  Endif

  #**
  #* ==> FACILITY > Facility cannot be modified (Transfer the physical asset).
  #*!
    If not (this.FCY = this.snapshot.FCY) and this.PHYTRF = [V]CST_AFALSE
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "FCY")
    [L]ASTATUS = fmet this.ASETERROR("FCY", [L]ERRMSG, [V]CST_AERROR)
  Endif

  #**
  #* ==> PHYREF > Physical asset reference cannot be modified.
  #*!
  If not(this.PHYREF = this.snapshot.PHYREF)
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "PHYREF")
    [L]ASTATUS = fmet this.ASETERROR("PHYREF", [L]ERRMSG, [V]CST_AERROR)
  Endif
  #**
  #* ==> LCTCOD > Location cannot be modified (Transfer the physical asset).
  #*!
  If not (this.LCTCOD = this.snapshot.LCTCOD) and this.PHYTRF = [V]CST_AFALSE
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "LCTCOD")
    [L]ASTATUS = fmet this.ASETERROR("LCTCOD", [L]ERRMSG, [V]CST_AERROR)
  Endif

  #**
  #* ==> ENAFLG > When the physical asset is linked to a fixed asset, "Active" flag cannot be modified.
  #*!
  If fmet this.IS_LINKED_ASSET() and not(this.ENAFLG = this.snapshot.ENAFLG)
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "ENAFLG")
    [L]ASTATUS = fmet this.ASETERROR("ENAFLG", [L]ERRMSG, [V]CST_AERROR)
  Endif

#  #**
#  #* ==> AASREF > From the physical asset transaction, it is not possible to unlink the physical asset from its fixed asset
#  #*!
#  If this.AASREF = AVOID.ACHAR and not(this.AASREF = this.snapshot.AASREF)
#    [L]ERRMSG = func ASYRFNC.MES1(mess(167,[V]CST_MSGMIS, 1), "AASREF")
#    [L]ASTATUS = fmet this.ASETERROR("AASREF", [L]ERRMSG, [V]CST_AERROR)
#  Endif
  #**
  #* ==> AASREF > If the physical asset is disposed, fixed asset reference cannot be modified.
  #*!
  If this.ISSDAT <> AVOID.ADATE and not(this.AASREF = this.snapshot.AASREF)
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "AASREF")
    [L]ASTATUS = fmet this.ASETERROR("AASREF", [L]ERRMSG, [V]CST_AERROR)
  Endif

#  #**
#  #* ==> AASREF > If the physical asset has got at least one pending movement, fixed asset reference cannot be modified.
#  #*!
#  If this.AASREF <> AVOID.ACHAR and not(this.AASREF = this.snapshot.AASREF)
#    Local Integer LIN
#    For [L]LIN =1 To maxtab(this.PHYMVT)
#      If this.PHYMVT([L]LIN) <> null and find(this.PHYMVT([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
#        # Modification is impossible : $1$ property must not be modified
#        [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "AASREF")
#        [L]ASTATUS = fmet this.ASETERROR("AASREF", [L]ERRMSG, [V]CST_AERROR)
#        Break
#      Endif
#    Next [L]LIN
#  Endif

  #**
  #* ==> AASREF > If the physical asset is linked to a fixed asset, fixed asset reference cannot be modified.
  #*              except from the fixed asset itself (unlink).
  #*!
  If this.snapshot.AASREF <> AVOID.ACHAR and this.ORIACT <> [V]CST_OAFASULKPHY  and not(this.AASREF = this.snapshot.AASREF)
    # Modification is impossible : $1$ property must not be modified
    [L]ERRMSG = func ASYRFNC.MES1(mess(56,[V]CST_MSGMIS, 1), "AASREF")
    [L]ASTATUS = fmet this.ASETERROR("AASREF", [L]ERRMSG, [V]CST_AERROR)
  Endif

  #**
  #* ==> ISSDAT > The disposal date of a physical element can't be modified except through the disposal or cancelation disposal action
  #*!
  If this.snapshot.ISSDAT <> this.ISSDAT
    If not (this.PHYISS = [V]CST_ATRUE or this.PHYCNLISS = [V]CST_ATRUE)
      [L]ASTATUS = fmet this.ASETERROR("", mess(189,[V]CST_MSGPHY, 1), [V]CST_AERROR)
    Endif
  Endif

  #**
  #* ==> ISSTYP > The disposal type of a physical element can't be modified except through the disposal or cancelation disposal action
  #*!
  If this.snapshot.ISSTYP <> this.ISSTYP
    If not (this.PHYISS = [V]CST_ATRUE or this.PHYCNLISS = [V]CST_ATRUE)
      [L]ASTATUS = fmet this.ASETERROR("", mess(190,[V]CST_MSGPHY, 1), [V]CST_AERROR)
    Endif
  Endif

  #**
  #* ==> TRFDAT > The last transfer date of a physical element can't be modified except through the disposal or cancelation disposal action
  #*!
  If this.snapshot.TRFDAT <> this.TRFDAT
    If not (this.PHYTRF = [V]CST_ATRUE)
      [L]ASTATUS = fmet this.ASETERROR("", mess(228,[V]CST_MSGPHY, 1), [V]CST_AERROR)
    Endif
  Endif

  Gosub _INSERT_UPDATE_CONTROL_BEFORE

Return

#**
#* ################################
#* Event: AUPDATE_CONTROL_AFTER
#*        Executes different controls before updating a physical asset after control on properties was done
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AUPDATE_CONTROL_AFTER
  #**
  #*    >>>>>>>>>>>
  #*    Rules of INSERT_UPDATE_AFTER are checked here.
  #*    They are described a little further in this document
  #*    <<<<<<<<<<<
  #*!
  Gosub _INSERT_UPDATE_CONTROL_AFTER
Return

#**
#* ################################
#* Event: AUPDATE_BEFORE
#*        Is called after controls are done and just before updating a physical asset in the database.
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$AUPDATE_BEFORE
  #**
  #* ==> ENAFLG > Field evaluation.
  #      If the physical asset is not linked to a fixed asset then it is allways equal to Yes
  #      If it is linked, it inherates its value from the ENAFAS field value of the fixed asset
  #*!
  If fmet this.IS_LINKED_ASSET()
    this.ENAFLG = func _IS_ASSET_ENABLED(this)
  Else
    this.ENAFLG = [V]CST_AYES
  Endif
Return

#------------------------
$AUPDATE_AFTER
  this.ORIACT = [V]CST_OANONE
  this.PHYTRF = [V]CST_AFALSE
Return

#
##------------------------
#$AUPDATE
#Local Char  ERRMSG(140)
# To be used if update is not taken in charge by the crud
#Return

#**
#* ################################
#* Event: ADELETE_CONTROL_BEFORE
#*        Executes different controls before deleting a physical asset
#*        before control of the referential integrety is done
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$ADELETE_CONTROL_BEFORE
Local Char  ERRMSG(100)
Local Char  MSG(100)

  #**
  #* ==> AASREF > If the physical asset is linked to a fixed asset, the physical asset cannot be deleted.
  #*!
  If fmet this.IS_LINKED_ASSET()
    [L]ASTATUS = fmet this.ASETERROR("PHYREF", mess(1,[V]CST_MSGPHY, 1), [V]CST_AERROR)
  Endif
Return

#------------------------
#$ADELETE_CONTROL_AFTER
#Return

#------------------------
#$ADELETE
##Local Char  ERRMSG(140)
## To be used if delete is not taken in charge by the crud
#Return

#**
#* ################################
#* Event: ADELETE_AFTER
#*        Is called after a succesful deletion of the physical asset in the database.
#*        Additionnal update operations can be done.
#*        At this step, if an error occurs, a rollback is automatically performed
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$ADELETE_AFTER
Local Char  ERRMSG(100)
Local Char  MSG(100)

  #**
  #* ==>  PHOTO > if a picture is attached to the physical asset. It must be explicitly deleted
  #*!
  If this.ACTX.AFOLDER=nomap
    Local File FXBLOB [FBB]
  Else
   Local File =this.ACTX.AFOLDER+".FXBLOB" [FBB]
  Endif
  # Picture found in FXBLOB
  Delete [F:FBB]ABB0= "PHYELT";this.PHYREF;"";""
  LogicClose File [FBB]

  #**
  #* ==> PHYREF > After each physical asset deletion, all events related to a deleted physical asset must be deleted.
  #*!
  Local Char EVT_ERRMSG(250)
  Local Instance EVT Using C_EVENT : EVT = NewInstance C_EVENT AllocGroup null
  EVT.REF = this.PHYREF
  If not fmet EVT.DEL_ALL_PHYELT_EVENT() = [V]CST_AOK
    # Error when creating physical asset event.
    [L]ASTATUS = func FXDFCT_SYRA.COPY_MSG(EVT, this)
    [L]ASTATUS = [V]CST_AERROR
    [L]RET =  [V]CST_AFALSE
  Endif
  FreeGroup EVT
Return

#-----------------------------------------------------------------
$_INSERT_UPDATE_CONTROL_BEFORE

## At this level you can write control for insert or update.
#Local Char  MSG(100)
#Local Char  ERRMSG(140)
#Local Integer RET
#
#
## You can differenciate those two situations with the values
## [V]CST_ANEW, [V]CST_AUPD of this.ASTALIN class property
# If (this.ASTALIN = [V]CST_ANEW)
#   # Control only in creation
# Endif
# If (this.ASTALIN = [V]CST_AUPD)
#   # Control only in modification
# Endif

#- GEOLOC -----
  #**
  #* ==> GEOLOC > If geographical location is not entered, it heritates the geographical location
  #*              of the location to which the physical asset is linked.
  #*!
  # Issue 110304
  #If this.GEOLOC = AVOID.ACHAR
    # Get geographical position from location
#    If  this.LCTCOD <> AVOID.ACHAR
# Issue 114755 : issue 110304 must be fixed in _PHYELT_TRANSFER of PHYELT_C_MPR
#    If this.LCTCOD <> AVOID.ACHAR
    If this.GEOLOC = AVOID.ACHAR
# End Issue 114755
      Local Instance LCT Using C_PHYLCT
      LCT = NewInstance C_PHYLCT AllocGroup null
      Local Char PROPERTIES(GLONAVA)(1..1)
      Local Char VALUES(255)        (1..1)
      Local Integer RET
      [L]PROPERTIES(1) = "GEOLOC"
      [L]RET = fmet LCT.GET_PROPERTIES_VALUE(this.LCTCOD, [L]PROPERTIES, [L]VALUES)
      this.GEOLOC = VALUES(1)
      FreeGroup LCT
    Endif
  #Endif
  # End issue 110134

Return

#**
#* --------------------------------
#* Prodedure : INSERT_UPDATE_AFTER
#* --------------------------------
#* This procedure executes different controls after creating or modifying a physical asset
#* It is called from both AINSERT_CONTROL_AFTER and AUPDATE_CONTROL_BEFORE
#* --------------------------------
#* @param  this      : Physical Asset instance
#* @return ASTATUS   : [V]CST_AOK, [V]CST_AERROR, [V]CST_AWARNING, [V]CST_AINFO
#* @return           : Error message stack
#*!
$_INSERT_UPDATE_CONTROL_AFTER
Local Char  MSG(100)
Local Char  ERRMSG(140)
Local Integer RET
Local Integer STA

#- BPSUPPLIER -----
  #**
  #* ==> BPS > The supplier must be defined in the BPSUPPIER table for the company.
  #*!
#TODO: Create an method/operation on BPSUPPLIER class to know if supplier is defined or not
  If this.BPS <> AVOID.ACHAR
    Local File BPSUPPLIER [BPS]
    Read [F:BPS]BPS0=this.BPS
    If fstat
      [L]ASTATUS = fmet this.ASETERROR("BPS", this.BPS-":"-mess(23,100,1), [V]CST_AERROR)
    Endif
    LogicClose File [BPS]
  Endif

#- ORDBUY -----
  #**
  #* ==> ORDBUY > If "PUR" activity code is active, the order number must be defined in the PORDER table.
  #*!
#TODO: Create an method/operation on PORDER class to get the ORDDAT and CPY property
  Local Date DORDBUY : [L]DORDBUY = AVOID.ADATE
  If this.ORDBUY <> AVOID.ACHAR and func AFNC.ACTIV("PUR")
    Local File PORDER [POH]
    Read [F:POH]POH0=this.ORDBUY
    If fstat
      [L]ASTATUS = fmet this.ASETERROR("ORDBUY", this.ORDBUY-":"-mess(23,100,1), [V]CST_AERROR)
    Else
      [L]DORDBUY = [F:POH]ORDDAT
      #**
      #* ==> ORDBUY > The order number must be defined for the company if it is filled.
      #*!
      If  this.CPY <> AVOID.ACHAR and not (this.CPY = [F:POH]CPY)
        [L]ERRMSG = func ASYRFNC.MES3(mess(93,[V]CST_MSGMIS, 1), this.ORDBUY, "ORDBUY",this.CPY)
        [L]ASTATUS = fmet this.ASETERROR("ORDBUY", [L]ERRMSG, [V]CST_AERROR)
      Endif
    Endif
    LogicClose File [POH]
  Endif

#- DORDBUY -----
  #**
  #* ==> DORDBUY > If "PUR" activity code is active and order number was entered and order date is not entered
  #*     then order date inherates the order date of the entered order number.
  #*!
  If func AFNC.ACTIV("PUR") and this.ORDBUY <> AVOID.ACHAR and this.DORDBUY = AVOID.ADATE Then
    this.DORDBUY = [L]DORDBUY
  Endif
  #**
  #* ==> DORDBUY > If "PUR" activity code is active and order number was entered
  #*     then order date must be equal to the one of the order number if it exists.
  #*!
  If func AFNC.ACTIV("PUR") and this.ORDBUY <> AVOID.ACHAR and [L]DORDBUY <> AVOID.ADATE and
&    not (this.DORDBUY = [L]DORDBUY) Then
    [L]ASTATUS = fmet this.ASETERROR("DORDBUY",mess(174,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  #**
  #* ==> DORDBUY > If an order number was entered then an order date must also be entered: Order date is mandatory
  #*!
  If this.ORDBUY <> AVOID.ACHAR and not (this.DORDBUY <> AVOID.ADATE) Then
    [L]ASTATUS = fmet this.ASETERROR("DORDBUY",mess(21,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  #**
  #* ==> DORDBUY > If no order number was entered then order date must not be entered
  #*!
  If this.ORDBUY = AVOID.ACHAR and not (this.DORDBUY = AVOID.ADATE) Then
    [L]ASTATUS = fmet this.ASETERROR("DORDBUY",mess(146,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

#- NUMRECEP -----
  #**
  #* ==> NUMRECEP > If "PUR" activity code is active, the receipt number must be defined in the PRECEIPT table.
  #*!
#TODO: Create an method/operation on PRECEIPT class to get the RCPDAT and CPY property
  Local Date DNUMRECEP : [L]DNUMRECEP = AVOID.ADATE
  If func AFNC.ACTIV("PUR") and this.NUMRECEP <> AVOID.ACHAR
    Local File PRECEIPT [PTH]
    Read [PTH]PTH0=this.NUMRECEP
    If fstat
      [L]ASTATUS = fmet this.ASETERROR("NUMRECEP", this.NUMRECEP-":"-mess(23,100,1), [V]CST_AERROR)
    Else
      [L]DNUMRECEP = [F:PTH]RCPDAT
      #**
      #* ==> NUMRECEP > The order number must be defined for the company if it is filled.
      #*!
      If  this.CPY <> AVOID.ACHAR and not (this.CPY = [F:PTH]CPY)
        [L]ERRMSG = func ASYRFNC.MES3(mess(93,[V]CST_MSGMIS, 1), this.NUMRECEP, "NUMRECEP",this.CPY)
        [L]ASTATUS = fmet this.ASETERROR("NUMRECEP", [L]ERRMSG, [V]CST_AERROR)
      Endif
    Endif
    LogicClose File [PTH]
  Endif

#- DNUMRECEP -----
  #**
  #* ==> DNUMRECEP > If "PUR" activity code is active and receipt number was entered
  #*     then receipt date must be equal to the one of the receipt number if it exists.
  #*!
  If func AFNC.ACTIV("PUR") and this.NUMRECEP <> AVOID.ACHAR and [L]DNUMRECEP <> AVOID.ADATE and
&    not (this.DNUMRECEP = [L]DNUMRECEP) Then
    [L]ASTATUS = fmet this.ASETERROR("DNUMRECEP",mess(175,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  #**
  #* ==> DNUMRECEP > If "PUR" activity code is active and receipt number was entered and receipt date is not entered
  #*     then receipt date inherates the receipt date of the entered receipt number.
  #*!
  If func AFNC.ACTIV("PUR") and this.NUMRECEP <> AVOID.ACHAR and this.DNUMRECEP = AVOID.ADATE Then
    this.DNUMRECEP = [L]DNUMRECEP
  Endif
  #**
  #* ==> DNUMRECEP > If an receipt number was entered then an receipt date must also be entered.
  #*     Receipt date is mandatory.
  #*!
  If this.NUMRECEP <> AVOID.ACHAR and not (this.DNUMRECEP <> AVOID.ADATE) Then
    [L]ASTATUS = fmet this.ASETERROR("DNUMRECEP",mess(22,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  #**
  #* ==> DNUMRECEP > If no receipt number was entered then receipt date must not be entered.
  #*!
  If this.NUMRECEP = AVOID.ACHAR and not (this.DNUMRECEP = AVOID.ADATE) Then
    [L]ASTATUS = fmet this.ASETERROR("DNUMRECEP",mess(147,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  #**
  #* ==> DNUMRECEP > If receipt number is entered then receipt date must be
  #*     less or equal to last effective transfer date
  #*!
  If this.NUMRECEP <> AVOID.ACHAR and this.TRFDAT <> AVOID.ADATE and not (this.DNUMRECEP <= this.TRFDAT) Then
    [L]ASTATUS = fmet this.ASETERROR("DNUMRECEP",mess(36,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif
  If this.NUMRECEP <> AVOID.ACHAR
    #**
    #* ==> DNUMRECEP > If receipt number is entered then receipt date must be less or equal to any pending movement date
    #*!
#TODO: Perhaps write method to get the first movement who have MVTDAT less than DNUMRECEP property
    Local Integer LIN
    For [L]LIN =1 To maxtab(this.PHYMVT)
      If this.PHYMVT([L]LIN) <> null and find(this.PHYMVT([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
        If not (this.DNUMRECEP <= this.PHYMVT([L]LIN).MVTDAT)
          [L]ERRMSG  = mess(37,[V]CST_MSGPHY,1)-num$([L]LIN)-" : "-num$(this.PHYMVT([L]LIN).MVTDAT)
          [L]ASTATUS = fmet this.ASETERROR("DNUMRECEP", [L]ERRMSG, [V]CST_AERROR)
          Break
        Endif
      Endif
    Next [L]LIN
  Endif

#- BAC ----- MESS
  #**
  #* ==> BAC > If barcode is entered, it must be unique in the folder or
  #*     in the company according to CPYBACUNY parameter value
  #*!
  If not (this.BAC = AVOID.ACHAR)
    Local Tinyint B_BAC_UNIQUE
    Local Char OTHERPHY(GLONPHY)
    If not (fmet this._IS_BAC_UNIQUE([L]B_BAC_UNIQUE, [L]OTHERPHY) < [V]CST_AERROR)
      # Method/Operation IS_BAC_UNIQUE error
      [L]ASTATUS = fmet this.AGETMAXERROR("")
    Else
      If not ([L]B_BAC_UNIQUE = [V]CST_ATRUE)
        [L]ASTATUS = fmet this.ASETERROR("BAC", mess(54,[V]CST_MSGPHY,1)-"("+[L]OTHERPHY+")", [V]CST_AERROR)
      Endif
    Endif
  Endif

#- AASREF -----
  If this.FCY <> AVOID.ACHAR and fmet this.IS_LINKED_ASSET() and this.snapshot.AASREF <> this.AASREF
    If (find(this.ORIACT, [V]CST_OAFASTRFPHY, [V]CST_OAFASISSPHY, [V]CST_OAFASCTRFPHY, [V]CST_OAFASCISSPHY) = 0)
      #**
      #* ==> AASREF > if entered the fixed asset must be attachable to the physical asset.
      #* @include FXDASSETS_C_MPR $_IS_FAS_LINKABLE_TO_PHY
      #*!
      Local Instance FAS Using C_FXDASSETS : FAS = NewInstance C_FXDASSETS AllocGroup null
      [L]STA = fmet FAS._IS_FAS_LINKABLE_TO_PHY(this.AASREF, this.FCY)
      If not ([L]STA = [V]CST_AOK)
        # Moving error messages from FAS class error stack to PHY class's one
        [L]RET = func FXDFCT_SYRA.COPY_MSG(FAS, this)
        [L]ASTATUS = fmet this.AGETMAXERROR("")
      Endif
      FreeGroup FAS
    Endif
  Endif

#- MVT -----
  #**
  #* ==> PHYMVT > No pending movement can exist as long as physical asset is not linked to a fixed asset.
  #*!
  If not (fmet this.IS_LINKED_ASSET())
    If func PHYELT_C_MPR._COLL_GET_COUNTTAB(this, "PHYMVT") > 0
      [L]ASTATUS = fmet this.ASETERROR("MVT", mess(148,[V]CST_MSGPHY,1), [V]CST_AERROR)
    Endif
  Endif
Return

#**
#* Return the value of asset ENAFLG property (CST_AYES or CST_ANO), and add an error in the message stack if occur
#*
#* @private
#* @param PHY Class of physical element
#* @return CST_AYES or CST_ANO
#*!
Funprog _IS_ASSET_ENABLED(PHY)
Variable Instance PHY Using C_PHYELT
Local Integer RET

  Local Instance FAS Using C_FXDASSETS
  Local Integer RETMET, STA
  Local Shortint ENAFAS
  Local Char MESSAGE(255)

  FAS = NewInstance C_FXDASSETS AllocGroup null

  [L]RETMET = fmet FAS.GET_ENABLED_OPE(PHY.AASREF, [L]ENAFAS, [L]MESSAGE)
  If [L]RETMET = [V]CST_AOK
    [L]RET = [L]ENAFAS
  Else
    # Error on read FAS table. Set error in error stack and return CST_ANO
    [L]RET = [V]CST_ANO
    [L]STA = fmet PHY.ASETERROR("", [L]MESSAGE, [L]RETMET)
  Endif

  FreeGroup FAS

End [L]RET

