#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################################################
#   Recherche d'un champ                                             Module CRM         28 octobre 2002 #
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

#########################################################################################################
$PREMIER
  If [M:MGG3]NBFIELKP <= dim([M:MGG3]TABLKP) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADMGG3(1, GMGG3LKPFLG)
Return

#########################################################################################################
$PRECEDENT
  If [M:MGG3]NBFIELKP <= dim([M:MGG3]TABLKP) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADMGG3(2, GMGG3LKPFLG)
Return

#########################################################################################################
$SUIVANT
  If [M:MGG3]NBFIELKP <= dim([M:MGG3]TABLKP) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADMGG3(3, GMGG3LKPFLG)
Return

#########################################################################################################
$DERNIER
  If [M:MGG3]NBFIELKP <= dim([M:MGG3]TABLKP) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADMGG3(4, GMGG3LKPFLG)
Return

#########################################################################################################
$OUVRE
Global Integer GMGG3NOL
Global Char GMGG3PARAM1
Global Char GMGG3PARAM2
Global Integer GMGG3PARAM3
Global Integer GMGG3LKPFLG

  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  If !clalev([F:FDF]) : Local File FIEDICFIE [FDF] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  GMGG3NOL = 0
  GMGG3LKPFLG = 0
  GMGG3PARAM1 = PARAM(1)
  GMGG3PARAM2 = PARAM(2)
  GMGG3PARAM3 = val(PARAM(3))
Return

#########################################################################################################
$DEFBOUT
Return

#########################################################################################################
$SETBOUT
Return

#########################################################################################################
$OUVRE_BOITE
Return

#########################################################################################################
$DEBUT
  [M:MGG3]CRIENA = 2
  [M:MGG3]CRINOTENA = 2
  Call LOADMGG3(1, GMGG3LKPFLG)
Return

#########################################################################################################
$AV_CHOIX
Return

#########################################################################################################
AP_CHOIX
Return

#########################################################################################################
$AVANT_BOUTON
Return

#########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:MGG3]
  Kill GMGG3NOL
  Kill GMGG3PARAM1
  Kill GMGG3PARAM2
  Kill GMGG3PARAM3
  Kill GMGG3LKPFLG
Return

#########################################################################################################
$FIN
Return

#########################################################################################################
$ABANDON
Return

#########################################################################################################
$APRES_MODIF
Return

#########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      GMGG3LKPFLG = 1
      Call LOADMGG3(1, GMGG3LKPFLG)
      GMGG3NOL = 0
    When "B"
      [M:MGG3]CRIENA = 2
      [M:MGG3]CRINOTENA = 2
      GMGG3LKPFLG = 0
      Call RAZMGG3
      Call LOADMGG3(1, GMGG3LKPFLG)
      GMGG3NOL = 0
    When "C"
      If GMGG3PARAM1 = "TAB" Then
        VALEUR = [M:MGG3]TABLKP(GMGG3NOL)
        [M:MGG2]CRIFIE(GMGG3PARAM3-1) = [M:MGG3]FIELKP(GMGG3NOL)
        Affzo [M:MGG2]CRIFIE(GMGG3PARAM3-1)
        FIN = 1
      Elsif GMGG3PARAM1 = "FIE" Then
        VALEUR = [M:MGG3]FIELKP(GMGG3NOL)
        [M:MGG2]CRITAB(GMGG3PARAM3-1) = [M:MGG3]TABLKP(GMGG3NOL)
        Affzo [M:MGG2]CRITAB(GMGG3PARAM3-1)
        FIN = 1
      Endif
    When Default
  Endcase
Return

#########################################################################################################
$ONMENU
Return

#########################################################################
# Sous-programmes utilitaires
#########################################################################
#
# LOADMGG3 : Charge l'écran MGG3
# RAZMGG3  : Purge l'écran MGG3
# 
#########################################################################
#########################################################################
# Charge l'écran MGG3
#########################################################################
#########################################################################################################
Subprog LOADMGG3(IWHATTODO, ILOOKUPFLAG)
Value Integer IWHATTODO
Value Integer ILOOKUPFLAG

Local Integer ITER

  If [M:MGG3]CRIENA <> 2 Then
    If [M:MGG3]CRINOTENA <> 2 Then
      #Il n'est pas possible de rechercher des champs à la fois non actifs et non inactifs.
      GMESSAGE = mess(827,196,1)
      GERR = 1
      End
    Endif
  Endif
  ITER = 0
  #On met au moins la cible
  Read [SSP]SSP0=GMGG3PARAM2
  If fstat Then
    #Erreur lors du chargement du tableau des champs.
    GMESSAGE = mess(826,196,1)
    GERR = 1
    End
  Else
    If [F:SSP]SPTTGR <> "" Then
      Call FILLFIELDS([F:SSP]SPTTGR, "", ILOOKUPFLAG, ITER)
    Endif
  Endif
  If ITER < dim([M:MGG3]TABLKP) Then
    Filter [SSC] Where [F:SSC]SPTNUM = GMGG3PARAM2 Order By [F:SSC]SPTLEV Asc
    For [SSC]
      If ITER >= dim([M:MGG3]TABLKP) Then
        Break
      Endif
      Call FILLFIELDS([F:SSC]SPTTAB, "", ILOOKUPFLAG, ITER)
    Next
    Filter [SSC]
  Endif
  [M:MGG3]NBFIELKP = ITER
  Affzo [M:MGG3]
End

##########################################################################
# Charge les champs d'une table
##########################################################################
#########################################################################################################
Subprog FILLFIELDS(SZTABCOD, SZFIECOD, ILKPFLG, ITERLINE)
Value Char SZTABCOD
Value Char SZFIECOD
Value Integer ILKPFLG
Variable Integer ITERLINE

Local Integer ITER2
Local Integer IEXIST
Local Char SZFIEDES(GLONDCO)
Local Char SZTEXTE(GLONDCO)

  ITER2 = 0
  IEXIST = 0
  SZFIEDES = ""
  Read [FID]FID0=SZTABCOD;GAUSCRMI
  If fstat Then
    Read [FID]FID0=SZTABCOD;""
    If fstat Then
      #La table est exploité telle quelle.
      Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCOD and [F:ATZ]CODZONE > SZFIECOD
      For [ATZ]CODZONE
        If ITERLINE >= dim([M:MGG3]TABLKP) Then
          Break
        Endif
        If ILKPFLG Then
          Call TEXTE([F:ATZ]NOLONG, SZFIEDES) From OBJDIV
          For ITER2 = 0 To [M:MGG3]NBCRILKP-1
            If [M:MGG3]CRILKP(ITER2) <> "" Then
              If instr(1, toupper(ctrans(SZFIEDES)), toupper(ctrans([M:MGG3]CRILKP(ITER2)))) Then
                Call TESTEXIST(ITERLINE, SZTABCOD, [F:ATZ]CODZONE, IEXIST)
                If !IEXIST Then
                  [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
                  [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
                  Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
                  ITERLINE += 1
                Endif
              Endif
            Endif
          Next
        Else
          [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
          [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
          Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
          ITERLINE += 1
        Endif
      Next
      Filter [ATZ]
    Else
      #La table a fait l'objet d'un paramétrage dans le dictionnaire des critères
      If ILKPFLG Then
        If [M:MGG3]CRIENA = 2 and [M:MGG3]CRINOTENA = 2 Then
          Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]CAT = "" and [F:FDF]SELCRIFIE > SZFIECOD Order By [F:FDF]SELCRISRT Asc
        Elsif [M:MGG3]CRIENA = 2 and [M:MGG3]CRINOTENA <> 2 Then
          Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
        Elsif [M:MGG3]CRIENA <> 2 and [M:MGG3]CRINOTENA = 2 Then
          Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG <> 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
        Endif
      Else
        Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
      Endif
      For [FDF]
        If ITERLINE >= dim([M:MGG3]TABLKP) Then
          Break
        Endif
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        If ILKPFLG Then
          If SZTEXTE = "" Then
            Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
            If fstat Then
              SZFIEDES = [F:FDF]SELCRIFIE
            Else
              Call TEXTE([F:ATZ]NOLONG, SZFIEDES) From OBJDIV
            Endif
          Else
            SZFIEDES = SZTEXTE
          Endif
          For ITER2 = 0 To [M:MGG3]NBCRILKP-1
            If [M:MGG3]CRILKP(ITER2) <> "" Then
              If instr(1, toupper(ctrans(SZFIEDES)), toupper(ctrans([M:MGG3]CRILKP(ITER2)))) Then
                Call TESTEXIST(ITERLINE, SZTABCOD, [F:FDF]SELCRIFIE, IEXIST)
                If !IEXIST Then
                  [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
                  [M:MGG3]FIELKP(ITERLINE) = [F:FDF]SELCRIFIE
                  If SZTEXTE = "" Then
                    Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
                    If fstat Then
                      [M:MGG3]FIELKPDES(ITERLINE) = [F:FDF]SELCRIFIE
                    Else
                      Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
                    Endif
                  Else
                    [M:MGG3]FIELKPDES(ITERLINE) = SZTEXTE
                  Endif
                  ITERLINE += 1
                Endif
              Endif
            Endif
          Next
        Else
          [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
          [M:MGG3]FIELKP(ITERLINE) = [F:FDF]SELCRIFIE
          If SZTEXTE = "" Then
            Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
            If fstat Then
              [M:MGG3]FIELKPDES(ITERLINE) = [F:FDF]SELCRIFIE
            Else
              Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
            Endif
          Else
            [M:MGG3]FIELKPDES(ITERLINE) = SZTEXTE
          Endif
          ITERLINE += 1
        Endif
      Next
      Filter [FDF]
      If ITERLINE < dim([M:MGG3]TABLKP) Then
        #On recherche ensuite soit des nouveaux champs standards non maquillés soit des champs spécifiques
        Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCOD and [F:ATZ]CODZONE > SZFIECOD
        For [ATZ]CODZONE
          If ITERLINE >= dim([M:MGG3]TABLKP) Then
            Break
          Endif
          Read [FDF]FDF0=SZTABCOD;[F:ATZ]CODZONE
          If fstat Then
            If ILKPFLG Then
              Call TEXTE([F:ATZ]NOLONG, SZFIEDES) From OBJDIV
              For ITER2 = 0 To [M:MGG3]NBCRILKP-1
                If [M:MGG3]CRILKP(ITER2) <> "" Then
                  If instr(1, toupper(ctrans(SZFIEDES)), toupper(ctrans([M:MGG3]CRILKP(ITER2)))) Then
                    Call TESTEXIST(ITERLINE, SZTABCOD, [F:ATZ]CODZONE, IEXIST)
                    If !IEXIST Then
                      [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
                      [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
                      Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
                      ITERLINE += 1
                    Endif
                  Endif
                Endif
              Next
            Else
              [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
              [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
              Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
              ITERLINE += 1
            Endif
          Endif
        Next
        Filter [ATZ]
      Endif
    Endif
  Else
    #La table a fait l'objet d'un paramétrage dans le dictionnaire des critères
    If ILKPFLG Then
      If [M:MGG3]CRIENA = 2 and [M:MGG3]CRINOTENA = 2 Then
        Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]CAT = GAUSCRMI and [F:FDF]SELCRIFIE > SZFIECOD Order By [F:FDF]SELCRISRT Asc
      Elsif [M:MGG3]CRIENA = 2 and [M:MGG3]CRINOTENA <> 2 Then
        Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
      Elsif [M:MGG3]CRIENA <> 2 and [M:MGG3]CRINOTENA = 2 Then
        Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG <> 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
      Endif
    Else
      Filter [FDF] Where [F:FDF]CRITAB = SZTABCOD and [F:FDF]SELCRIFIE > SZFIECOD and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
    Endif
    For [FDF]
      If ITERLINE >= dim([M:MGG3]TABLKP) Then
        Break
      Endif
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      If ILKPFLG Then
        If SZTEXTE = "" Then
          Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
          If fstat Then
            SZFIEDES = [F:FDF]SELCRIFIE
          Else
            Call TEXTE([F:ATZ]NOLONG, SZFIEDES) From OBJDIV
          Endif
        Else
          SZFIEDES = SZTEXTE
        Endif
        For ITER2 = 0 To [M:MGG3]NBCRILKP-1
          If [M:MGG3]CRILKP(ITER2) <> "" Then
            If instr(1, toupper(ctrans(SZFIEDES)), toupper(ctrans([M:MGG3]CRILKP(ITER2)))) Then
              Call TESTEXIST(ITERLINE, SZTABCOD, [F:FDF]SELCRIFIE, IEXIST)
              If !IEXIST Then
                [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
                [M:MGG3]FIELKP(ITERLINE) = [F:FDF]SELCRIFIE
                If SZTEXTE = "" Then
                  Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
                  If fstat Then
                    [M:MGG3]FIELKPDES(ITERLINE) = [F:FDF]SELCRIFIE
                  Else
                    Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
                  Endif
                Else
                  [M:MGG3]FIELKPDES(ITERLINE) = SZTEXTE
                Endif
                ITERLINE += 1
              Endif
            Endif
          Endif
        Next
      Else
        [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
        [M:MGG3]FIELKP(ITERLINE) = [F:FDF]SELCRIFIE
        If SZTEXTE = "" Then
          Read [ATZ]CODZONE=SZTABCOD;[F:FDF]SELCRIFIE
          If fstat Then
            [M:MGG3]FIELKPDES(ITERLINE) = [F:FDF]SELCRIFIE
          Else
            Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
          Endif
        Else
          [M:MGG3]FIELKPDES(ITERLINE) = SZTEXTE
        Endif
        ITERLINE += 1
      Endif
    Next
    Filter [FDF]
    If ITERLINE < dim([M:MGG3]TABLKP) Then
      #On recherche ensuite soit des nouveaux champs standards non maquillés soit des champs spécifiques
      Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCOD and [F:ATZ]CODZONE > SZFIECOD
      For [ATZ]CODZONE
        If ITERLINE >= dim([M:MGG3]TABLKP) Then
          Break
        Endif
        Read [FDF]FDF0=SZTABCOD;[F:ATZ]CODZONE
        If fstat Then
          If ILKPFLG Then
            Call TEXTE([F:ATZ]NOLONG, SZFIEDES) From OBJDIV
            For ITER2 = 0 To [M:MGG3]NBCRILKP-1
              If [M:MGG3]CRILKP(ITER2) <> "" Then
                If instr(1, toupper(ctrans(SZFIEDES)), toupper(ctrans([M:MGG3]CRILKP(ITER2)))) Then
                  Call TESTEXIST(ITERLINE, SZTABCOD, [F:ATZ]CODZONE, IEXIST)
                  If !IEXIST Then
                    [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
                    [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
                    Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
                    ITERLINE += 1
                  Endif
                Endif
              Endif
            Next
          Else
            [M:MGG3]TABLKP(ITERLINE) = SZTABCOD
            [M:MGG3]FIELKP(ITERLINE) = [F:ATZ]CODZONE
            Call TEXTE([F:ATZ]NOLONG, [M:MGG3]FIELKPDES(ITERLINE)) From OBJDIV
            ITERLINE += 1
          Endif
        Endif
      Next
      Filter [ATZ]
    Endif
  Endif
End

##########################################################################
# Purge l'écran MGG3
##########################################################################
#########################################################################################################
Subprog RAZMGG3
  Raz [M:MGG3]NBFIELKP
  Raz [M:MGG3]TABLKP
  Raz [M:MGG3]FIELKP
  Raz [M:MGG3]FIELKPDES
  Raz [M:MGG3]NBCRILKP
  Raz [M:MGG3]CRILKP
End

#########################################################################
# Vérifie si un champs n'est pas déjà présent dans le tableau
#########################################################################
#########################################################################################################
Subprog TESTEXIST(INBLINE, SZTAB, SZFIE, IEXISTFLG)
Value Integer INBLINE
Value Char SZTAB
Value Char SZFIE
Variable Integer IEXISTFLG

Local Integer ITER3

  IEXISTFLG = 0
  For ITER3 = 0 To INBLINE-1
    If [M:MGG3]TABLKP(ITER3) = SZTAB Then
      If [M:MGG3]FIELKP(ITER3) = SZFIE Then
        IEXISTFLG = 1
        Break
      Endif
    Endif
  Next
End
