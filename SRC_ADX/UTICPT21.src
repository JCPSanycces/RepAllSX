#<AdxTL>@(#)5.0.0.0 $Revision$
##############################################################################
## Initialisation du flag ESDTRK de la table GTYPACCENT rajouté dans le cadre
## de la déclaration européenne de services (DES).
## On initialise ce flag à "Oui" pour les types de pièces flagués "Relances"
##############################################################################

Call MAJ_UTICPT21
End

Subprog MAJ_UTICPT21

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT21:"-"Initialisation field ESDTRK (GTYPACCENT Table)") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT21") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT21(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT21(APPLI)
Value Char APPLI

Local Integer OK
If filinfo(filpath("FIL","GTYPACCENT","fde",APPLI),0) < 0 : End : Endif

If clalev([F:GTE])=0 : Local File =APPLI+".GTYPACCENT" [GTE] : Endif


Call ECR_TRACE("UTICPT21: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT21
Call ECR_TRACE("UTICPT21: Process End on : "+APPLI,0) From GESECRAN
End


#### Corps de la moulinette - début
$TR_UTICPT21
Trbegin [GTE]
 For [GTE]GTE0 Where ESDTRK=0 & FUP=2
  [F:GTE]ESDTRK = 2
  Rewrite [GTE]
  If fstat
   GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"GTYPACCENT"-":"-[F:GTE]TYP,1) From GESECRAN
   Break
  Endif
 Next
 If !GOK : Goto AB_UTICPT21 : Endif
Commit
Return


$AB_UTICPT21
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT21(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTICPT21(APPLI)
End
