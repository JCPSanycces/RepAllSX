#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_SOURCE


Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()

Local Integer NUMREQ, WNUMLIG, SVG_NUMLIG
Local Char    FILTRE(250)
Local Char    NUMREG(15) , DEVISE(GLONCUR)
Local Char    SOCIETE(GLONCPY), SITE(GLONFCY),TRSDEB(GLONBPR), ETAT(10), PARAM(30), PVAL(30), TRSFIN(GLONBPR)
Local Integer I , J , K
Local Decimal MONTANT , MONTIMP , SOLDECH
Local Decimal MONTCUR , MONTREG , MONTLOC , MONTRPT
Local Decimal RSTECH, RSTREG
Local Integer CLIFOU

Local File AREPORTM   [ARM]
Local File AREPORTM   [ARM2]
Local File GACCDUDATE [DUD]  
Local File GACCDUDATE [DUD2] 
Local File GACCENTRY  [HAE]  
Local File GACCENTRYD [DAE]  
Local File PAYMENTD   [PYD]  
Local File COMPANY    [CPY]  
Local File PAYMENTH   [PYH]  
Local File FACILITY   [FCY]  

#DBA le 14/04/03
#Call GETPARAM("__REPORT",NBPAR,PARAMETRE,ETAT) From ETAT
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif

## Vérif de la société

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Read [CPY]CPY0 = SOCIETE
If fstat
 # Société incorrecte
 Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
 GOK = 0 : End
Endif

# Récupération des paramètres
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]PVAL = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE": [L]NUMREQ = val([L]PVAL)
   When "societe"  : [L]SOCIETE=[L]PVAL
   When "site"     : [L]SITE=[L]PVAL
   When "typbpr"   : [L]CLIFOU=val([L]PVAL)
   When "tiersdeb" : [L]TRSDEB=[L]PVAL
   When "tiersfin" : [L]TRSFIN=[L]PVAL
  Endcase
 Endif
Next

# Affectation du numéro de requête
[L]PVAL=num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,[L]PVAL) From ETAT

# Filtre sur les échéances d'acompte
[L]FILTRE  = "[F:DUD]CPY='"+[L]SOCIETE+"'"
If [L]SITE<>""
   [L]FILTRE -= "& [F:DUD]FCY='"+[L]SITE+"'"
Endif
[L]FILTRE -= "& [F:DUD]BPRTYP="+num$([L]CLIFOU)
Case [L]CLIFOU
    When 1 :  [L]FILTRE -= "& [F:DUD]SNS<0"
    When 2 :  [L]FILTRE -= "& [F:DUD]SNS>0"
Endcase   
If [L]TRSDEB<>""
   [L]FILTRE -= "& [F:DUD]BPRPAY>='"+[L]TRSDEB+"'"
Endif
If [L]TRSFIN<>""
   [L]FILTRE -= "& [F:DUD]BPRPAY<='"+[L]TRSFIN+"'"
Endif

FILTRE -= '& [F:DUD]FLGCLE=1'
FILTRE -= '& [F:DUD]DUDSTA=2'
FILTRE -= '& left$([F:DAE]REFINT,3)="PYH"'

Trbegin [ARM]
Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit

Read [CPY]CPY0 = [L]SOCIETE
Link [DUD] With [DAE]DAE2=[F:DUD]ACCNUM , [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
& As [LNK]
& Where evalue(FILTRE)
& Order By [F:DAE]REFINT;[F:HAE]TYP;[F:HAE]NUM

Trbegin [ARM], [ARM2]

Raz WNUMLIG
For [LNK]
 SOLDECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 NUMREG = vireblc(right$([F:DAE]REFINT,4),2)
 Read [PYH]PYH0 = NUMREG
 For [PYD]PYD0 Where NUM=NUMREG & (IPTTYP=0 or IPTTYP=CLIFOU)
  MONTIMP = 0
  If [F:PYD]IPTTYP=CLIFOU : # C'est une commande
   Read [DUD2]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
   If fstat=0 & [F:DUD2]DINAMT=0
    If [F:DUD2]CUR=[F:DUD]CUR
     DEVISE  = [F:DUD]CUR
     MONTANT = [F:DUD]AMTCUR
     MONTIMP = [F:PYD]AMTLIN
    Elsif [F:DUD2]CUR=[F:CPY]ACCCUR & [F:DUD]CUR=[F:PYH]CUR
     DEVISE  = [F:CPY]ACCCUR
     MONTANT = [F:DUD]AMTLOC
     MONTIMP = [F:PYD]AMTLIN
    Elsif [F:DUD2]CUR=GSYSCUR & [F:DUD]CUR=[F:PYH]CUR
     DEVISE  = GSYSCUR
     MONTANT = [F:DUD]AMTRPT
     MONTIMP = [F:PYD]AMTLIN
    Endif
   Endif
  Elsif [F:PYD]CURLIN=[F:DUD]CUR : # Le non imputé est dans la devise de règlement
   DEVISE   = [F:DUD]CUR
   MONTANT = [F:DUD]AMTCUR
   If SOLDECH>=[F:PYD]AMTLIN
       MONTIMP =[F:PYD]AMTLIN
   Else
       MONTIMP = SOLDECH
   Endif
  Endif

  SOLDECH -= MONTIMP
  If MONTIMP>0

    Raz [F:ARM]
    WNUMLIG +=1

    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = [L]WNUMLIG

    If [F:PYD]IPTTYP=CLIFOU
        [F:ARM]CLEN1 = 1
    Else
        [F:ARM]CLEN1 = 3
    Endif

    [F:ARM]CLEA1  = [F:PYD]VCRNUM         # Numero de commande
    [F:ARM]CLEA2  = DEVISE
    [F:ARM]CLEMD1 = MONTANT
    [F:ARM]CLEMD2 = MONTIMP
    [F:ARM]CLEA3  = NUMREG                # Numéro de règlement
    [F:ARM]CLEN2  = [F:PYD]DUDNUM         # Echéance de facture/commande
    [F:ARM]CLEN3  = [F:PYD]DUDLIG         # Echéance de facture/commande
    [F:ARM]CLEN4  = [F:DUD]ACCNUM         # Echéance d'acompte
    [F:ARM]CLEN5  = [F:DUD]DUDLIG         # Echéance d'acompte
    [F:ARM]CLEA6  = [F:DUD]BPRPAY         # TIERS
    [F:ARM]CLEA4  = [F:PYD]VATLIN

    [F:ARM]CREDAT  = date$
    
    Write [F:ARM]   
    If fstat 
        GOK = 0
        Call FSTA("ARM") From GLOCK
        Goto AB_IMP
    Endif 
  Endif 
 Next
Next

##
## PRE CHARGEMENT
##
If !WNUMLIG : Goto AB_IMP : Endif
Local Char FILFAC(255)

# Filtre les échéances liées aux factures
FILTRE = '[F:DUD]CPY="'+[L]SOCIETE+'"'
If [L]SITE<>""
   FILTRE -= '& [F:DUD]FCY="'+[L]SITE+'"'
Endif
FILTRE -= '& [F:DUD]BPRPAY>="'+[L]TRSDEB+'"'
FILTRE -= '& [F:DUD]BPRPAY<="'+[L]TRSFIN+'"'
FILTRE -= '& [F:DUD]FLGCLE=1'
Case CLIFOU
    When 1 : FILTRE -= '& [F:DUD]SNS>0'
    When 2 : FILTRE -= '& [F:DUD]SNS<0'
Endcase
FILTRE -= '& [F:HAE]FLGREP<>2'
FILTRE -= '& [F:DUD]BPRFCT=""'

Link [DUD] With [DAE]DAE2=[F:DUD]ACCNUM , [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
& As [LNK2]
& Where evalue(FILTRE)
& Order By [F:DUD]BPRPAY ; [F:DUD]CUR ; [F:DUD]DUDDAT 

# Sous LNK2, on liste les échéances de factures triées par Devise et Date d'échéance
# --> les echéances de factures les + anciennes en premier 
# (Possibilité de choix via un paramètre ?)

# On relie le fichier AREPORTM
#  On s'intéresse essentiellement aux échéances d'acompte (= "Non imputé")
# --> les echéances acomptes les + élévés en premier
Filter [ARM] Where USR=GUSER & RPTCOD=[L]ETAT & NUMREQ=[L]NUMREQ & CLEN1=3
& Order By Key CLE=CLEA6 Asc ; CLEA2 Asc ; CLEMD1 Desc ; NUMLIG Asc

# Lecture de l'échéanche facture
Read [LNK2]First
If fstat : Goto $AB_IMP : Endif
RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR

# Parcours des échéances d'acompte réelles // reliquat crée ultérieurement
SVG_NUMLIG=WNUMLIG

For [F:ARM]CLE(1)           # Tiers
  For [F:ARM]CLE(2)         # Devise
    For [F:ARM]CLE(3) 
     For [F:ARM]CLE(4)   
            If [F:ARM]NUMLIG>SVG_NUMLIG : Break 4 : Endif
            If [F:ARM]CLEA6<[DUD]BPRPAY : Break 3 : Endif
            #If [F:ARM]CLEA2<[DUD]CUR    : Break 2 : Endif

              
            ##########################################################################
            ## Mise à jour des variables pour l'imputation :                         #
            #  Montant déjà imputé sur le règlement de l'échance d'acompte           #
            #     CLEMD1 = Montant total du règlement                                #
            #     CLEMD2 = Acompte (initialisation faîte lors de la 1ere lecture)    #
            ##########################################################################
            RSTREG = [F:ARM]CLEMD1-[F:ARM]CLEMD2

            $AFF_IMP

            ##########################################################################
            # Affectation d'une facture ayant le même tiers & même devise...
            ##########################################################################
            If [F:ARM]CLEA6=[F:DUD]BPRPAY & [F:ARM]CLEA2 = [F:DUD]CUR
    
                [F:ARM]CLEN1  = 2
                [F:ARM]CLEA1  = [F:DUD]NUM
                [F:ARM]CLEN2  = [F:DUD]ACCNUM
                [F:ARM]CLEN3  = [F:DUD]DUDLIG

                If RSTECH>=[F:ARM]CLEMD1-RSTREG
                    MONTIMP = [F:ARM]CLEMD1-RSTREG
                Else
                    MONTIMP = RSTECH
                Endif
                [F:ARM]CLEMD2  = MONTIMP
    
                Rewrite [F:ARM]   
                If fstat 
                    GOK = 0
                    Call FSTA("ARM") From GLOCK
                    Goto AB_IMP
                Endif 

                # Soit le montant imputé solde l'échéance acompte & l'échéance facture
                If [F:ARM]CLEMD1=RSTREG+[F:ARM]CLEMD2 & RSTECH=[F:ARM]CLEMD2
    
                    # Lecture de l'échéanche facture
                    Read [LNK2] Next
                    If fstat : Break 3 : Endif
                    RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR

                # Soit le montant imputé ne solde pas l'échéance acompte... Reliquat
                Elsif [F:ARM]CLEMD1>RSTREG+[F:ARM]CLEMD2
               
                    # Création d'une nouvelle échéance d'acompte (reliquat)                
                    Raz [F:ARM2]
                    WNUMLIG +=1

                    [F:ARM2]USR    = GUSER
                    [F:ARM2]RPTCOD = [L]ETAT
                    [F:ARM2]NUMREQ = [L]NUMREQ
                    [F:ARM2]NUMLIG = [L]WNUMLIG
                    [F:ARM2]CLEN1  = 3
                    [F:ARM2]CLEA2  = [F:ARM]CLEA2
                    [F:ARM2]CLEMD1 = [F:ARM]CLEMD1
                    [F:ARM2]CLEMD2 = [F:ARM]CLEMD1
                    [F:ARM2]CLEA3  = [F:ARM]CLEA3
                    [F:ARM2]CLEN4  = [F:ARM]CLEN4
                    [F:ARM2]CLEN5  = [F:ARM]CLEN5
                    [F:ARM2]CLEA6  = [F:ARM]CLEA6
                    [F:ARM2]CLEA4  = [F:ARM]CLEA4
                    [F:ARM2]CREDAT = date$
                    RSTREG += [F:ARM]CLEMD2

                    Write [F:ARM2]
                    If fstat 
                        GOK = 0
                        Call FSTA("ARM") From GLOCK
                        Goto AB_IMP
                    Endif 

                    # Affectation de la nouvelle échéance d'acompte                
                    If [F:ARM]CLEMD2= RSTECH
                        # Lecture de l'échéanche facture
                        Read [LNK2] Next
                        If fstat : Break 3 : Endif
                        RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
                    Else
                        RSTECH -= [F:ARM]CLEMD2
                    Endif
         
                    Read [F:ARM]CLE =[F:ARM2]CLEA6;[F:ARM2]CLEA2;[F:ARM2]CLEMD1;[F:ARM2]NUMLIG           
                    Goto AFF_IMP

                # Soit le montant imputé ne solde pas l'échéance...
                Elsif RSTECH>[F:ARM]CLEMD2
                    # Pas de lecture, on réutilise l'échéance facture
                    RSTECH -= [F:ARM]CLEMD2
                Endif
        
            # Soit la devise de l'échéance acompte < devise de l'échéance facture
            Elsif [F:ARM]CLEA2 > [F:DUD]CUR | [F:ARM]CLEA6 > [F:DUD]BPRPAY
                # Lecture de l'échéance facture
                Read [LNK2] Next
                If fstat : Break 3 : Endif
                RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
                Goto AFF_IMP
            Endif
        Next
    Next
  Next
Next
Commit
End


$AB_IMP
GOK=0
Rollback
End


