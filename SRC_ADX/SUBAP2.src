#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier APRTBRW
Raz GPILOBJ
Call OBJET("AP2",GBIDC1,GBIDC2) From GOBJET
End

##################################################

$ACTION
Case ACTION
 When "CREATION" : Gosub MAJ_TEXTRA
 When "MODIF"    : Gosub MAJ_TEXTRA
 When "ANNULE"   : Gosub ANNULE
 When "CHANGE"   : Gosub CHANGE
 When default
Endcase
Return

######################################################################################
$MAJ_TEXTRA
Call MAJTEXTRA([M]AP2INTIT,"APRTBRW","AP2INTIT",[M]AP2BRW,"") From ATEXTRA
Return

$ANNULE
#suppresion texte traduisible
Delete [AXX] Where CODFIC="APRTBRW"  & IDENT1=[L]CODE & ZONE ="AP2INTIT"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[M]AP2BRW) From GLOCK 
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="APRTBRW"  & IDENT1=[L]OCODE & ZONE ="AP2INTIT" With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APRTBRW"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

######################################################################################
Subprog AS_OBJSEL(VALEUR)
Variable Char    VALEUR()

Local Integer MYNUM : MYNUM=nolign
If VALEUR = "" # choix par defaut
    Local Char    PROGOBJ(10) : PROGOBJ = "WO" + [M]OBJ(nolign-1) : Gosub OPTIONS From =PROGOBJ
    If OPTSEL<>""
        VALEUR=OPTSEL
    Elsif NBCOND>0    # 1er sélection
        VALEUR=OPT(1)
    Endif
Endif

End

########################################
Subprog C_OBJSEL(VALEUR)
Variable Char    VALEUR()

Local Char    PROGOBJ(10) : PROGOBJ = "WO" + [M]OBJ(nolign-1) : Gosub OPTIONS From =PROGOBJ
Local Integer I
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),OPT(1..NBCOND))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I


End

########################################
Subprog S_OBJSEL(VALEUR)
Variable Char    VALEUR()

Local Char    PROGOBJ(10) : PROGOBJ = "WO" + [M]OBJ(nolign-1) : Gosub OPTIONS From =PROGOBJ
Local Integer  VALINT, I
Local Char LIB (30) (0..NBCOND)
If NBCOND
 For I=1 To NBCOND
    LIB(I) = OPT(I) + " " + LIBOPT(I) # il faut un indice 0...
 Next
 Call SAITEX(NBCOND,LIB,VALINT,mess(100,123,1)) From GESECRAN
 If VALINT<>0 & status<>7 & !instr(1,VALEUR,OPT(VALINT))
    VALEUR += OPT(VALINT)
 Endif
Endif
End

########################################
Subprog C_NBREC(VALEUR)
Variable Decimal VALEUR
If VALEUR>GNBSEL | VALEUR<1
    GMESSAGE="Valeur entre 1 et " + num$(GNBSEL)
    mkstat=2
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 15/04/2003 17:09:10 (JPJ)
##########################################################################
Subprog AS_NBREC(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
    VALEUR=GNBSEL
Endif
End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 02/05/2003 11:15:16 (JPJ)
##########################################################################
Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()

Call LECTURE("AOB",VALEUR,"") From CONTOBJ
If [F:AOB]TYPGES<>1 and [F:AOB]TYPGES<>4
    GMESSAGE=mess(2,137,1)
    mkstat=1
Endif
End


##########################################################################

