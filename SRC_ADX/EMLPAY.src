#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2016-08-12 - X3PEOP-763 - START NEW FROM U9
# Issue 105399 - 2015-10-05 by BRBAN : Payslip by email
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "AVANT_OK"    : Gosub AVANT_OK
   When "OK"          : Gosub OK
   When "DEBUT"       : Gosub DEBUT
   When Default
Endcase

Return
######################################################################################
######################################################################################
$DEBUT
# Issue 112975 - 2016-05-02 by BRBAN : Improvements
If GFONCTION = 'GESVEP'
  [M]ALLCPY = 1
  [M]CPY    = [M:VEP1]CPY
  [M]ALLFCY = 1
  [M]FCY    = [M:VEP1]FCY
  [M]ALLSRV = 1
  [M]SRV    = [M:VEP1]SRV
  [M]ALLPRF = 1
  [M]PRF    = [M:VEP1]PRF
  [M]REFNUMDEB = [M:VEP0]EMP
  [M]REFNUMFIN = [M:VEP0]EMP
  [M]PAYDATDEB = [M:VEP1]PAYDAT
  [M]PAYDATFIN = [M:VEP1]PAYDAT
  [M]PYRDATDEB = [M:VEP0]PYRDAT
  [M]PYRDATFIN = [M:VEP0]PYRDAT
  #ADNGO - 2017-06-07 - X3-11585 - START
  [M]LEG = [F:FCY]LEG
  #ADNGO - 2017-06-07 - X3-11585 - END
  Affzo [M]
Endif
Return
######################################################################################
######################################################################################
$OUVRE
If !clalev([F:AIM])    : Local File APRINTER   [AIM]    : Endif
If !clalev([F:VEP2])   : Local File VALEMP     [VEP2]   : Endif
If !clalev([F:FCY])    : Local File FACILITY   [FCY]    : Endif
If !clalev([F:ID])     : Local File EMPLOID    [ID]     : Endif
If !clalev([F:AD])     : Local File EMPLOAD    [AD]     : Endif
# Issue 112975 - 2016-04-29 by BRBAN : Population filter
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA]  : Endif
#-
#MIPEA - 2016-08-12 - X3PEOP-763 - START
If clalev([F:HRCTR])=0 : Local File EMPLOCTR   [HRCTR]  : Endif
#MIPEA - 2016-08-12 - X3PEOP-763 - END
Local Char    IMPDES(10)  : [L]IMPDES = ''
Local Integer SND         : [L]SND    = 0
Local Integer WOK         : [L]WOK    = 0

#Link [F:VEP2] With [F:ID]ID0=[F:VEP2]EMP, [F:FCY]FCY0=[F:VEP2]FCY, [F:AD]AD0=[F:VEP2]EMP As [LVEP]

Local Mask EMLPAY [DIA]
Raz [M:DIA]

Call LECMEMO("STD","[M:DIA]","epay") From GMEMO

Return
######################################################################################
######################################################################################
$AVANT_OK
[L]IMPDES = func AFNC.PARAMDOS(nomap , "EMLIMPDES")
If [L]IMPDES=''
  #General parameter EMLIMPDES is not set.
  GMESSAGE = mess(1,2533,1)
  GERR=1
Endif

Return
######################################################################################
######################################################################################
$OK
#lock this function for the chosen company
If dim ([L]SYMBOLE)<0 : Local Char SYMBOLE : Endif
[L]SYMBOLE = GFONCTION
Lock = [L]SYMBOLE
If fstat
  OK       = 0
  GERR     = 1
  GMESSAGE = mess(8,2533,1)
  Return
Endif
[L]WOK=1 # No
#You about to send the payslips by email. Do you want to proceed?
Call OUINON(mess(2,2533,1), WOK) From GESECRAN

If [L]WOK=2
  Call TEMPON ("O") From GESECRAN
  #Payslips by e-mail
  If !GSERVEUR : Call OUVRE_TRACE(mess(3,2533,1)) From LECFIC : Endif

  Gosub SEND_MAIL

  Call TEMPOFF From GESECRAN
  Call LEC_TRACE From LECFIC
  If !GSERVEUR : Call FERME_TRACE() From LECFIC : Endif
Endif

If !GERR
  Unlock = [L]SYMBOLE
Endif
Return
######################################################################################
######################################################################################
$SEND_MAIL
Local Integer K
Local Date    PYRDATSTR, PYRDATEND
Local Char    CRITERE(255), CRITERE2(255)
Local Char    TBPAR(20)(1..50), TBVAL(20)(1..50), RPTBUL([V]GLONARP)

[L]CRITERE="1=1"
[L]CRITERE2="1=1"

If [M:DIA]ALLCPY<>2 & [M:DIA]CPY<>''
  [L]CRITERE-="& [F:FCY]LEGCPY='"+[M:DIA]CPY+"'"
Endif

If [M:DIA]ALLFCY<>2 & [M:DIA]FCY<>''
  [L]CRITERE-="& [F:VEP2]FCY='"+[M:DIA]FCY+"'"
Endif

If [M:DIA]PAYDATDEB<>[0/0/0]
  [L]CRITERE2-="& [F:VEP2]PAYDAT>=["+format$(GFMD,[M:DIA]PAYDATDEB)+"]"
Endif

If [M:DIA]PAYDATFIN<>[0/0/0]
  [L]CRITERE2-="& [F:VEP2]PAYDAT<=["+format$(GFMD,[M:DIA]PAYDATFIN)+"]"
Endif

If [M:DIA]PYRDATDEB<>[0/0/0]
  [L]CRITERE2-="& [F:VEP2]PYRDAT>=["+format$(GFMD,[M:DIA]PYRDATDEB)+"]"
Endif

If [M:DIA]PYRDATFIN<>[0/0/0]
  [L]CRITERE2-="& [F:VEP2]PYRDAT<=["+format$(GFMD,[M:DIA]PYRDATFIN)+"]"
Endif

If [M:DIA]ALLPRF<>2 & [M:DIA]PRF<>''
  [L]CRITERE-="& [F:VEP2]PRF='"+[M:DIA]PRF+"'"
Endif

If [M:DIA]ALLSRV<>2 & [M:DIA]SRV<>''
  [L]CRITERE-="& [F:VEP2]SRV='"+[M:DIA]SRV+"'"
Endif

If [M:DIA]REFNUMDEB<>''
  [L]CRITERE-="& [F:VEP2]EMP>='"+[M:DIA]REFNUMDEB+"'"
Endif

If [M:DIA]REFNUMFIN<>''
  [L]CRITERE-="& [F:VEP2]EMP<='"+[M:DIA]REFNUMFIN+"'"
Endif

# Issue 112975 - 2016-04-29 by BRBAN : Population filter
#MIPEA - 2016-08-15 - X3PEOP-763 - START
If [M:DIA]POP<>""
  Link [F:VEP2] With [F:ID]ID0=[F:VEP2]EMP, [F:FCY]FCY0=[F:VEP2]FCY, [F:AD]AD0=[F:VEP2]EMP, [F:HRPOA]POA0=[M:DIA]POP;[F:VEP2]EMP;[F:VEP2]CTRNUM;[F:VEP2]CTRDAT As [LVEP]
& Where evalue([L]CRITERE) & evalue([L]CRITERE2) & find([F:VEP2]STA,2,3)<>0 & [F:HRPOA]REFNUM<>""
& Order By Key CLE=[F:VEP2]EMP;[F:VEP2]PYRDAT Asc
Else
  Link [F:VEP2] With [F:ID]ID0=[F:VEP2]EMP, [F:FCY]FCY0=[F:VEP2]FCY, [F:AD]AD0=[F:VEP2]EMP As [LVEP]
& Where evalue([L]CRITERE) & evalue([L]CRITERE2) & find([F:VEP2]STA,2,3)<>0
& Order By Key CLE=[F:VEP2]EMP;[F:VEP2]PYRDAT Asc
Endif
#If [M:DIA]POP<>""
#  Link [F:VEP2] With [F:ID]ID0=[F:VEP2]EMP, [F:FCY]FCY0=[F:VEP2]FCY, [F:AD]AD0=[F:VEP2]EMP, [F:HRPOA]POA0=[M:DIA]POP;[F:VEP2]EMP As [LVEP]
#& Where evalue([L]CRITERE) & evalue([L]CRITERE2) & find([F:VEP2]STA,2,3)<>0 & [F:HRPOA]REFNUM<>""
#& Order By Key CLE=[F:VEP2]EMP;[F:VEP2]PYRDAT Asc
#Else
#  Link [F:VEP2] With [F:ID]ID0=[F:VEP2]EMP, [F:FCY]FCY0=[F:VEP2]FCY, [F:AD]AD0=[F:VEP2]EMP As [LVEP]
#& Where evalue([L]CRITERE) & evalue([L]CRITERE2) & find([F:VEP2]STA,2,3)<>0
#& Order By Key CLE=[F:VEP2]EMP;[F:VEP2]PYRDAT Asc
#Endif
# -
#Filter [F:LVEP] Where find([F:VEP2]STA,2,3)<>0 & evalue([L]CRITERE)& evalue([L]CRITERE2)
#& Order By Key CLE=[F:VEP2]EMP;[F:VEP2]PYRDAT Asc
For [F:LVEP]
  Gosub TRTCONT
  If OK
    [L]SND = 1
    Raz [L]TBVAL, [L]TBPAR, [L]K

    [L]K+=1 : [L]TBPAR([L]K) = "cpy"         : [L]TBVAL([L]K) = [F:FCY]LEGCPY
    [L]K+=1 : [L]TBPAR([L]K) = "matdeb"      : [L]TBVAL([L]K) = [F:VEP2]EMP
    [L]K+=1 : [L]TBPAR([L]K) = "matfin"      : [L]TBVAL([L]K) = [F:VEP2]EMP
    [L]K+=1 : [L]TBPAR([L]K) = "buldeb"      : [L]TBVAL([L]K) = [F:VEP2]BUL
    [L]K+=1 : [L]TBPAR([L]K) = "bulfin"      : [L]TBVAL([L]K) = [F:VEP2]BUL
    [L]K+=1 : [L]TBPAR([L]K) = "fcydeb"      : [L]TBVAL([L]K) = [F:VEP2]FCY
    [L]K+=1 : [L]TBPAR([L]K) = "fcyfin"      : [L]TBVAL([L]K) = [F:VEP2]FCY
    [L]K+=1 : [L]TBPAR([L]K) = "datdeb"      : [L]TBVAL([L]K) = num$([M:DIA]PAYDATDEB)
    [L]K+=1 : [L]TBPAR([L]K) = "datfin"      : [L]TBVAL([L]K) = num$([M:DIA]PAYDATFIN)
    [L]K+=1 : [L]TBPAR([L]K) = "srv"         : [L]TBVAL([L]K) = [F:VEP2]SRV
    [L]K+=1 : [L]TBPAR([L]K) = "prf"         : [L]TBVAL([L]K) = [F:VEP2]PRF
    [L]K+=1 : [L]TBPAR([L]K) = "tri"         : [L]TBVAL([L]K) = "1"
    [L]K+=1 : [L]TBPAR([L]K) = "flgprn"      : [L]TBVAL([L]K) = "1"
    [L]K+=1 : [L]TBPAR([L]K) = "txt"         : [L]TBVAL([L]K) = mess(182,10703,1) : # Duplicata
    [L]K+=1 : [L]TBPAR([L]K) = "impsim"      : [L]TBVAL([L]K) = "1"
    [L]K+=1 : [L]TBPAR([L]K) = "impsel"      : [L]TBVAL([L]K) = "1"
    [L]K+=1 : [L]TBPAR([L]K) = "archivage"   : [L]TBVAL([L]K) = "1"

    [L]RPTBUL=[F:VEP2]RPTBUL
    # Issue 114304 - 2016-02-08 by BRBAN : Error management
    If GFILPATH <> ""
      Call DELJOB(GFILPATH) From AIMP3
      GFILPATH=""
     Endif

    Call ETAT([L]RPTBUL,[L]IMPDES,[V]GLANGUE,0,"",[L]TBPAR,[L]TBVAL) From AIMP3
    #ADNGO - 2017-06-08 - X3-11585 - START
    #Call ECR_TRACE (mess(205,10703,1)+":"-[F:AD]PFLEML-mess(3,76,1)-[F:VEP2]EMP-[F:ID]SRN-[F:ID]NAM-":"-mess(104,10703,1)-month$([F:VEP2]PYRDAT)-num$(year([F:VEP2]PYRDAT)),0) From GESECRAN
    Call ECR_TRACE (mess(205,10703,1)+":"-[F:AD]PFLEML-mess(868,197,1)-[F:VEP2]EMP-[F:ID]SRN-[F:ID]NAM-":"-mess(104,10703,1)-month$([F:VEP2]PYRDAT)-num$(year([F:VEP2]PYRDAT)),0) From GESECRAN
    #ADNGO - 2017-06-08 - X3-11585 - END
  Endif
Next
#Filter [F:LVEP]

If [L]SND=0
  #There are no payslips for the selected filter.
  Call ECR_TRACE (mess(4,2533,1),2) From GESECRAN
Endif

Return
######################################################################################
######################################################################################
$TRTCONT
OK=1
Call CONTROLE([F:VEP2]EMP,[F:VEP2]PYRDAT,[F:VEP2]CTRNUM,[M:DIA]CRI,OK,0) From DIVPAYE
If !OK : Return : Endif
Return
######################################################################################
#MIPEA - 2016-08-12 - X3PEOP-763 - END

