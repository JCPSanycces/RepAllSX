#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRNDOCC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone FLG
mkstat = 0
zoncou = "FLG"
IMPENT = [M]FLG(indice)
SAVACT = GACTION : GACTION = "STD"
Call AV_FLG(IMPENT) From CNSTDCSTD
GACTION = SAVACT
If mkstat=1 : Raz IMPENT : Endif
If !mkstat
 If varinit([M]FLG,indice)=0
  IMPENT = 1
 Endif
Endif
If varmode([M]FLG,indice)=0
 [M]FLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLG(indice)
 Endif
Endif
[M]FLG(indice) = IMPENT

## Zone LINDOCTYP
mkstat = 0
zoncou = "LINDOCTYP"
IMPENT = [M]LINDOCTYP(indice)
If varinit([M]LINDOCTYP,indice)=0
 IMPENT = 1
Endif
[M]LINDOCTYP(indice) = IMPENT

## Zone ATDTINPTYP
mkstat = 0
zoncou = "ATDTINPTYP"
IMPENT = [M]ATDTINPTYP(indice)
If varinit([M]ATDTINPTYP,indice)=0
 IMPENT = 1
Endif
[M]ATDTINPTYP(indice) = IMPENT

## Zone ATDTCOD
mkstat = 0
zoncou = "ATDTCOD"
WCHAR = [M]ATDTCOD(indice)
If varmode([M]ATDTCOD,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ATDTCOD([M]ATDTCOD(indice)) From CNSTDCSTD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ATDTCOD(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ATDTCOD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WCHAR<>[M]ATDTCOD(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_ATDTCOD([M]ATDTCOD(indice)) From CNSTDCSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ATDTCOD" : GZNUM = 52730 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone UPDFLG
mkstat = 0
zoncou = "UPDFLG"
IMPENT = [M]UPDFLG(indice)
If varinit([M]UPDFLG,indice)=0
 IMPENT = 1
Endif
[M]UPDFLG(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRNDOCC1"
Return

