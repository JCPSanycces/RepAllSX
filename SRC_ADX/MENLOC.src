#<AdxTL>@(#)12.0.0.0 $Revision$
## Appel général
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "0"
Call SAISIE_CHAR(VALEUR,PARAM,"FMENLOC","MENLOC","") From GSAISIE
End

$ACTION
If dim([L]PSUBBB)<=0
 Local Integer  PSUBBB
 Call EXISTE_ADX("","","MENLOCB",PSUBBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FIN"         : Gosub FIN
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
If PSUBBB
 Gosub ACTION From MENLOCB
Endif
Return

$OUVRE
Local Integer NOMOD
Local Integer MODU , NOLIB , CLE , MODMEN , CHP
Local Char    CHAINE(80)
If clalev([F:AML])=0 : Local File AMENLOC [AML] : Endif
If clalev([F:AST])=0 : Local File APLSTD  [AST] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
NOMOD  =  val(PARAM(1))
MODMEN = 0
REP    = ""
Return

$DEBUT
Raz [M]
If NOMOD<>0
 [M]MODULE = NOMOD
 Affzo MODULE
 Grizo MODULE
Else
 OK = 0
 GBIDC1 = space$(50)
 For [AML] Where AUZMOD=2 & MENLOCAL=2
  K = 1
  If [F:AML]CODACT<>""
   Read [ACV]CODACT=[F:AML]CODACT
   If fstat | [F:ACV]FLACT<>2
    K = 0
   Endif
  Endif
  If K
   CHP = [F:AML]MENLOC
   If CHP>=1 & CHP<=99      : CHAINE = mess(CHP,0,1)
   Elsif CHP>200 & CHP<8900 : CHAINE = mess(CHP-200,200,1)
   Else                     : CHAINE = mess(0,CHP,1)
   Endif
   I = [F:AML]MODULE
   If mid$(GBIDC1,I,1)<>"X" : # bug 102569 : CHAINE<>"" &
    GBIDC1 = left$(GBIDC1,I-1)+"X"+right$(GBIDC1,I+1)
    OK = 1
   Endif
  Endif
 Next AML
Endif
Return

$APRES_MODIF
Case COUZON
 When "MODULE"
  Effzo 10-20
  Gosub DEGRISE
  REP = ""
 When "MENLOC"
  CLE = val(CZ)
  Gosub LECTURE
  REP = ""
  Gosub DEGRISE
  Affzo 20
 When Default
  REP = "M"
  Gosub GRISE
Endcase
Return

$FIN
If MODMEN
 Call MENULOC From GENMENULOC
Endif
Return

$LECTURE
Raz [M]
Read [AML]MENLOC = CLE
If fstat : Return : Endif
[M:AML] = [F:AML]
If CLE<100
 [M]TITCHP = mess(CLE,0,1)
Else
 [M]TITCHP = mess(CLE-200,200,1)
Endif
For I=1 To len(mess(0,CLE,1))
 [M]LANMES(I-1) = mess(I,CLE,1)
Next I
[M]NBLIG = len(mess(0,CLE,1))
Return

$ABANDON
Gosub LECTURE
REP = ""
Gosub DEGRISE
Return

$GRISE
Grizo MODULE, MENLOC
Return

$DEGRISE
Actzo MENLOC
If NOMOD=0 : Actzo MODULE : Endif
Return

$ENREGISTRE
Read [AML]MENLOC = CLE
If [M]NBLIG<[F:AML]MINI
 GERR = 1 : GMESSAGE = mess(133,124,1)-num$([F:AML]MINI)
# Nombre minimum de libellés
 Return
Endif
If [F:AML]MAXI<>0 & [M]NBLIG>[F:AML]MAXI
 GERR = 1 : GMESSAGE = mess(134,124,1)-num$([F:AML]MAXI)
# Nombre maximum de libellés
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 If GADONIX=2 : Call TRACE_COR("AML",num$(CLE),"","M") From GOBJET : Endif
 MODMEN = 1 : adxmbm = adxmbm
Endif
REP =""
Gosub DEGRISE
If CLE=655 & mess(0,656,1)<>"" & filinfo(filpath("FIL","TABFILBAN","fde"),0)>0 : # Type de remise
 Local File TABFILBAN [TFB]
 Filter [TFB] Where pat(FRM,"*PYH]FRMTYP*")
 Read [TFB]TFB0 First
 Filter [TFB]
 If fstat=0
  GERR = 2
  Call TITOBJ("TFB","",GMESSAGE) From CONTOBJ
  GMESSAGE -= [F:TFB]COD-[F:TFB]BAN-mess([F:TFB]RECTYP,656,1)
  If [F:TFB]RECTYP=2
   GMESSAGE -= num$([F:TFB]ORDNUM)
  Endif
  GMESSAGE += "\"+mess(86,105,1) : # Paramétrage à revoir
 Endif
 Close Local File [TFB]
Endif
Return

$TR1
GOK = 1
Trbegin APLSTD [AST]
 Delete [AST] Where LAN=GLANGUE & LANCHP=CLE
 If fstat=1
  GOK = -1 : GLOCK = "$APLSTD"-num$(CLE) : Goto ROLL_TR1
 Endif
 For I=0 To [M]NBLIG-1
  [F:AST]LAN    = GLANGUE
  [F:AST]LANCHP = CLE
  [F:AST]LANNUM = I+1
  [F:AST]LANMES = [M]LANMES(I)
  Write [AST]
  If fstat
   GOK = 0 : Call FSTA("AST") From GLOCK : Break
  Endif
 Next I
 If GOK<1 : Goto AB_TR1 : Endif
 [F:AST]LAN    = GLANGUE
 [F:AST]LANCHP = CLE
 [F:AST]LANNUM = 0
 [F:AST]LANMES = string$([M]NBLIG,"1")
 Write [AST]
 If fstat
  GOK = 0 : Call FSTA("AST") From GLOCK : Goto AB_TR1
 Endif
 If GOK
  Gosub MENLOC
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
Commit
Return

$MENLOC
 Readlock [AML]MENLOC = [M]MENLOC
 If fstat=1
  GOK = -1 : GLOCK = "$AMENLOC" : Return
 Elsif fstat
  [F:AML]MENLOC = CHAPITRE
  [F:AML]CREDAT = date$
  [F:AML]CREUSR = GUSER
  If dim([F:AML]CRETIM)>0 : [F:AML]CRETIM = time : Endif
  Write [AML]
 Else
  [F:AML]UPDDAT = date$
  [F:AML]UPDUSR = GUSER
  If dim([F:AML]UPDTIM)>0 : [F:AML]UPDTIM = time : Endif
  Rewrite [AML]
 Endif
 If fstat
  GOK = 0 : Call FSTA("AML") From GLOCK
 Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################

$SEL_LISTE
Case LISTE
 When "MENLOC"  : Gosub SEL
Endcase
Return

$SEL
Local Integer CHP
Local Char    CHAINE(80), TEX(10)(0..GNBSEL), TEXTE(50)(0..GNBSEL)
TIT = mess(23,125,1) : # Menus locaux
NBTEX = 0
For [AML] Where AUZMOD=2 & MENLOCAL=2 & MODULE=[M]MODULE & AUZMOD=2 & MENLOC>=VALEUR
 K = 1
 If [F:AML]CODACT<>""
  Read [ACV]CODACT=[F:AML]CODACT
  If fstat | [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  CHP = [F:AML]MENLOC
  If CHP>=1 & CHP<=99      : CHAINE = mess(CHP,0,1)
  Elsif CHP>200 & CHP<8900 : CHAINE = mess(CHP-200,200,1)
  Else                     : CHAINE = mess(0,CHP,1)
  Endif
  If CHAINE<>""
   NBTEX += 1
   TEX(NBTEX) = format$("N:4#",CHP)
   TEXTE(NBTEX) = TEX(NBTEX)+" "+CHAINE
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Endif
Next AML
Return

########################################

Subprog AS_MODULE(VALEUR)
Variable Integer MODULE
Local Integer J
For J=1 To len(GBIDC1)
 If mid$(GBIDC1,J,1)<>"X" or GMODU(J)<>2 : GMENLOC(J) = 1 : Endif
Next J
End

Subprog C_MENLOC(VALEUR)
Variable Decimal VALEUR
Local Integer OK
OK = 1
Read [AML]MENLOC = VALEUR
If fstat or [F:AML]MENLOCAL<>2 or [F:AML]AUZMOD<>2
 OK = 0
Elsif [F:AML]CODACT<>""
 Read [ACV]CODACT=[F:AML]CODACT
 If fstat | [F:ACV]FLACT<>2
  OK = 0
 Endif
Endif
If !OK
 GMESSAGE = mess(33,139,1) : mkstat = 2 : End : # Numéro incorrect
Endif
End
