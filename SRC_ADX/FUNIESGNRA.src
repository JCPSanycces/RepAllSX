Local Char R04AR211(15)(1..1)
Local Char R04AR212(15)(1..1)
Local Char R04AR213(15)(1..1)
Local Char R04AR214(15)(1..1)
Local Char R04AR215(15)(1..1)
Local Char R04ACAMPO(5)

Return
############################################################################################
############################################################################################
###
###                         INITIALIZE VARIABLES
###
############################################################################################
############################################################################################
$ALIM_AQVAR

CAMPO = ""
#Filter [F:TXM] Where TXSNAM = [M:DIA]TXSNAM(LINE) & VERSION = [M:DIA]VERSION(LINE) Order By LIG Asc; COL Asc; IND Asc
Filter [F:TXM] Where TXSNAM = [L]QUADRO & VERSION = [L]VERSION & !find([L]QUADRO,[L]IESCRIT) Order By LIG Asc; COL Asc; IND Asc
For [F:TXM]
  If    [F:TXM]LIG <> 0 & [F:TXM]COL = 0 & [F:TXM]IND = 0

    If ANEXO = "A"
      If vireblc([F:TXM]AMTVAL,2)="" | len([F:TXM]AMTVAL)<5
        CAMPO = ""
      Else
        CAMPO = left$([F:TXM]AMTVAL, 5)
      Endif
    Elsif ANEXO = "R"
      If vireblc([F:TXM]AMTVAL,2)="" | len([F:TXM]AMTVAL)<4
        CAMPO = ""
      Else
        CAMPO = left$([F:TXM]AMTVAL, 4)
      Endif
    Endif

  Elsif ([F:TXM]LIG <> 0 & [F:TXM]COL <> 0 & [F:TXM]IND = 0 & pat(CAMPO, "!####") & ANEXO = "A")|
&       ([F:TXM]LIG <> 0 & [F:TXM]COL <> 0 & [F:TXM]IND = 0 & pat(CAMPO, "!###") & ANEXO = "R")

    COL = [F:TXM]COL

    If find([M:DIA]TXSNAM(LINE), "05071A", "05081A", "05121A", "0516A", "05191A", "05192A", "0522A")
      If [F:TXM]COL = 1
        Goto NEXTTXM
      Else
        COL -= 1
      Endif
    Endif

    #exception for 0516 where it wasn't used column 6, moving from 5 to 7
    If find([M:DIA]TXSNAM(LINE), "0516A")
      If [F:TXM]COL = 7
        COL = 7
      Endif
    Endif

    #exception for 05192 where it wasn't used column 3, moving from 2 to 4
    If find([M:DIA]TXSNAM(LINE), "05192A")
      If [F:TXM]COL = 4
        COL = 4
      Endif
    Endif

    If ANEXO = "A"
      If vireblc([F:TXM]UPDVAL,2)<>""
        Assign "A" + [M:DIA]TXSNAM(LINE) + CAMPO + "(" + num$(COL) + ")" With ctrans(vireblc(format$("N:20.2",ar2(val([F:TXM]UPDVAL))),2), ",", ".")
      Else
        Assign "A" + [M:DIA]TXSNAM(LINE) + CAMPO + "(" + num$(COL) + ")" With ctrans(vireblc(format$("N:20.2",ar2(val([F:TXM]AMTVAL))),2), ",", ".")
      Endif


      #If empty (there are lines on the financial data extraction which don't contain formulas or any value
      #use 0.00
      If evalue("A" + [M:DIA]TXSNAM(LINE) + CAMPO + "(" + num$(COL) + ")") = ""
        Assign "A" + [M:DIA]TXSNAM(LINE) + CAMPO + "(" + num$(COL) + ")" With "0.00"
      Endif
    Elsif ANEXO = "R"
      If vireblc([F:TXM]UPDVAL,2)<>""
        Assign "R" + "04A" + CAMPO + "(" + num$(COL) + ")" With ctrans(vireblc(format$("N:20.2",ar2(val([F:TXM]UPDVAL))),2), ",", ".")
      Else
        Assign "R" + "04A" + CAMPO + "(" + num$(COL) + ")" With ctrans(vireblc(format$("N:20.2",ar2(val([F:TXM]AMTVAL))),2), ",", ".")
      Endif

      #If empty (there are lines on the financial data extraction which don't contain formulas or any value
      #use 0.00
      If evalue("R" + "04A" + CAMPO + "(" + num$(COL) + ")") = ""
        Assign "R" + "04A" + CAMPO + "(" + num$(COL) + ")" With "0.00"
      Endif
    Endif

  Endif

  $NEXTTXM
Next
Filter [F:TXM]

Return
############################################################################################
############################################################################################
###
###                                      WRITE
###
############################################################################################
############################################################################################
$WRIT_AQ03A
#-- Write. Q03A
For C = 5001 To 5026
  For C2 = 1 To 2
    TAGNAM = "Q03A-A" + num$(C) + "-" + num$(C2)
    If find(C, 5017, 5020, 5023, 5025) : TAGNAM += "-soma" : Endif
    TAGVAL = evalue("A03AA"+num$(C)+"("+num$(C2)+")")
    If TAGVAL = "" : TAGVAL = "0.00" : Endif
    Gosub WRITETAG From FUNIESGNR
  Next
Next

Return
