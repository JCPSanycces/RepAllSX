$WRIT_RQ04A

#-- Write RQ04A (Anexo R)
For C = 201 To 215

  TAGNAM = "Q04A-R" + num$(C)
  TAGVAL = evalue("R04AR"+num$(C))
  If C = 201
    TAGVAL = num$(int(val(TAGVAL)))
  Else
    If TAGVAL = "" : TAGVAL = "0.00" : Endif
  Endif
  Gosub WRITETAG From FUNIESGNR
Next

Return
############################################################################################
############################################################################################
$WRIT_FCY

If [F:FCY]CRY = 'PT'
  TAGNAM = 'Q04A-1'
  TAGVAL = '620'
  Gosub WRITETAG From FUNIESGNR
Endif

Read [F:BPA]BPA0 = 3;[F:FCY]FCY;[F:FCY]BPAADD
If !fstat

  TAGNAM = 'Q04A-2-1'
  TAGVAL = vireblc(vireblc([F:BPA]BPAADDLIG(0),2)-vireblc([F:BPA]BPAADDLIG(1),2)-vireblc([F:BPA]BPAADDLIG(2),2),2)
  If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

  If [F:BPA]POSCOD <> ""
    TAGNAM = 'Q04A-2-sede-cod-postal'
    TAGVAL = left$([F:BPA]POSCOD, 4)
    If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

    If len([F:BPA]POSCOD) = 7
      TAGNAM = 'Q04A-2-sede-uni-funcional'
      TAGVAL = right$([F:BPA]POSCOD, 5)
      If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif
    Endif
  Endif

  TAGNAM = 'Q04A-2-3'
  TAGVAL = vireblc([F:BPA]CTY, 4)
  If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

  If vireblc([F:BPA]FAX(0),4) <> ""
    TAGNAM = 'Q04A-2-7'
    TAGVAL = vireblc([F:BPA]FAX(0),4)
    If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif
  Endif

  If vireblc([F:BPA]TEL(0),4) <> ""
    TAGNAM = 'Q04A-2-8'
    TAGVAL = vireblc([F:BPA]TEL(0),4)
    If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif
  Endif

  If vireblc([F:BPA]WEB(0),4) <> ""
    TAGNAM = 'Q04A-2-9'
    TAGVAL = vireblc([F:BPA]WEB(0),4)
    If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif
  Endif

Endif

TAGNAM = 'Q04A-2-10'
TAGVAL = '02'
If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

TAGNAM = 'Q04A-2-12'
TAGVAL = num$([F:CPY]PORCPYACT)
If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

TAGNAM = 'Q04A-2-13'
TAGVAL = num$(I+1)
If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

TAGNAM = 'Q04A-2-14-15'
If [F:CPY]MAIFCY = [F:FCY]FCY
  TAGVAL = "1"
Else
  TAGVAL = "0"
Endif
If TAGVAL <> "" : Gosub WRITETAG From FUNIESGNR : Endif

Return
