#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGTRTCRM01   Opportunity migration script             CRM module       #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCRM01") From LECFIC
  Endif

  Call MAJ_UUMGTRTCRM01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End
##########################################################################
Subprog MAJ_UUMGTRTCRM01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(12)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMOPPM
Call MIGTABNAME (DOSSIER,"OPPOR", WNAMOPPM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMOPPM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Opening of the required tables for the migration process  -----#
If filinfo(filpath("FIL", "OPPORCRM", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".OPPORCRM" [OPPCRM]
Endif
#
If filinfo(filpath("FIL", "OPPORSTB", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".OPPORSTB" [OSB]
Endif
#
If filinfo(filpath("FIL", "OPPORSTA", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".OPPORSTA" [OSA]
Endif
#
If filinfo(filpath("FIL", "OPPORCPP", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".OPPORCPP" [OCP]
Endif
#
If filinfo(filpath("FIL", "OPPORSBB", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".OPPORSBB" [OBB]
Endif
#
If filinfo(filpath("FIL", "PIMPL", "fde", DOSSIER), 0) <= 0 Then
  End
Else
  Local File =DOSSIER + ".PIMPL" [PIM]
Endif
#


##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",2,ERR) From TRTMIG : #2=En cours

###################

Local Shortint WCPT_OPP

Call ECR_TIME("UUMGTRTCRM01 CRM Project       : Update OPPOR") From DOSSUB
Call ECR_TRACE("UUMGTRTCRM01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Local Char WTAB_OPP (30) (adxwrb)
Call MIGTABINIT (DOSSIER,"OPPOR",ERR) From TRTMIG

Call ECR_TIME("UUMGTRTCRM01 CRM Project : Update OPPOR ...") From DOSSUB

#----- Ouverture des fichiers -----#
If clalev([F:OPP])  = 0 : Local File =DOSSIER+".OPPOR"  [OPP]  : Endif      # Fichier X3 "Vide"

If clalev([F:OPPM]) = 0 : Local File =DOSSIER+"."+WNAMOPPM [OPPM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

#déclaration des variables locales de travail
Local Char     WSITE : Raz WSITE

Gosub OUVRE_HDK From UUMGTRTHDK00

If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
Call MIGGETKEY (DOSSIER,"UUMGTRTCRM01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

Filter [OPPM] Order By Key CLE=SALFCY;OPPNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTCRM01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CRM01
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:OPPM]SALFCY=TABMIGKEY(1) & [F:OPPM]OPPNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:OPPM]SALFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [OPP]
GOK = 1

#=> Migration toward V11 : update of the two ADI tables
If VERSION<GMIGX3VER110
  Gosub MAJ110_ADI
  If GOK<1 : Goto FIN_BOUCLE : Endif
Endif

For [OPPM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  #rupture par site,affaire
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
    FLUX="UUMGTRTCRM01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  Gosub RAZ_OPP
  [F:OPP] = [F:OPPM]

  If WSITE<>[F:OPPM]SALFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:OPPM]SALFCY) From TRTX3CPT
      Call GLOBVAR([F:OPPM]SALFCY) From WWGLOBVEN
      WSITE=[F:OPPM]SALFCY
  Endif

  If VERSION<GMIGX3VER110
    Gosub MAJ110_OPP
    If GOK<1 : Break : Endif
  Endif

  Gosub OPP_STK : # pour stocker ref
  WriteB [F:OPP]
  If fstat
    Call ECR_TRACE("File OPPOR, Error ="-num$(fstat),1) From GESECRAN
    Gosub OPP_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # End Issue 106947

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:OPPM]SALFCY
    TABMIGKEY(2) = [F:OPPM]OPPNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",7,ERR) From TRTMIG : #7=Erreur
Else
  Flush [F:OPP]
  If fstat
      Call ECR_TRACE("File OPPOR, Error ="-num$(fstat),1) From GESECRAN
      Gosub OPP_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif

  # Stocker les valeurs de ACLE1/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(3)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTCRM01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCRM01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_CRM01
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN

Filter [OPPM]

Close Local File [OPP]
Close Local File [OPPM]

Call ECR_TIME("UUMGTRTCRM01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"OPPOR",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTCRM01") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGTRTCRM01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(12)<>2 : # N= no module
  End
Endif

##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCRM01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMOPPM
Call MIGTABNAME (DOSSIER,"OPPOR", WNAMOPPM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMOPPM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"OPPOR",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTCRM01",ERR) From TRTMIG

End
##############################################################################################
$OPP_STK
Call STK (WTAB_OPP,WCPT_OPP,[F:OPP]OPPNUM) From TRTMIG
Return

##############################################################################################
$OPP_ERRTRA
Call ERRTRA (WTAB_OPP,WCPT_OPP,"File OPPOR(OPPNUM)=") From TRTMIG
Return

#========================================================================
$MAJ110_ADI

    Local Integer NCOUNT, NCOUNTERROR

    # -------------------------
    # ADI table 400 update
    # -------------------------
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UUMGTRTCRM01 : Updating ATABDIV(400)", 0) From GESECRAN
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N3 <> 1 and [F:ADI]N3 <> 2
    For [ADI]
      NCOUNT += 1
      If [F:ADI]N2 = 3 or [F:ADI]N2 = 5 Then
        [F:ADI]N3 = 2
      Else
        [F:ADI]N3 = 1
      Endif
      Rewrite [ADI]
      If fstat Then
        Call ECR_TRACE("File ATABDIV(400) " - [F:ADI]CODE - "/" - [F:ADI]N3 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [ADI]
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UUMGTRTCRM01 : ATABDIV(400)" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UUMGTRTCRM01 : ATABDIV(400)" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    If NCOUNTERROR : GOK=0 : Return : Endif
    # -------------------------

    # -------------------------
    # ADI table 421 update
    # -------------------------
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UUMGTRTCRM01 : Updating ATABDIV(421)", 0) From GESECRAN
    Filter [ADI] Where [F:ADI]NUMTAB = 421 and [F:ADI]N2 <> 1 and [F:ADI]N2 <> 2
    For [ADI]
      NCOUNT += 1
      [F:ADI]N2 = 1
      Rewrite [ADI]
      If fstat Then
        Call ECR_TRACE("File ATABDIV(421) " - [F:ADI]CODE - "/" - [F:ADI]N2 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [ADI]
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UUMGTRTCRM01 : ATABDIV(421)" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UUMGTRTCRM01 : ATABDIV(421)" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    If NCOUNTERROR : GOK=0 : Endif

Return

########################################################################
$RAZ_OPP
  Raz [F:OPP]
Return

########################################################################
# Initialization of the new fields for V11 [CHALLENGER]
########################################################################
$MAJ110_OPP

  Local Integer NI, IERR, NCOUNTERROR

  #---------------------------------
  # Transfer to OPPORCRM table
  #---------------------------------
  Raz [F:OPPCRM]
  [F:OPPCRM] = [F:OPPM]
  # -----------
  Write [OPPCRM]
  If fstat Then
    IERR = 1
    Call ECR_TRACE("File OPPORCRM " - [F:OPPM]OPPNUM + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif

  #---------------------------------
  # Transfer to OPPORSTB table
  #---------------------------------
  For NI = 0 To dim([F:OPPM]STE)-1
    # -----------
    If [F:OPPM]STE(NI) <> "" Then
      Raz [F:OSB]
      [F:OSB]OPPNUM = [F:OPPM]OPPNUM
      [F:OSB]STELIN = 1
      [F:OSB]STE    = [F:OPPM]STE(NI)
      [F:OSB]STRDAT = [F:OPPM]ENDDAT(NI)
      [F:OSB]ENDDAT = [F:OPPM]ENDDAT(NI)
      [F:OSB]DON    = [F:OPPM]DON(NI)
      [F:OSB]REN    = [F:OPPM]REN(NI)
      #----------
      $WRITE_OSB
      Write [OSB]
      If fstat = 3 Then
        [F:OSB]STELIN += 1
        Goto WRITE_OSB
      Elsif fstat Then
        Call ECR_TRACE("File OPPORSTB(400) " - [F:OPPM]OPPNUM - "/" - [F:OPPM]STE(NI) - "/" - num$(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      Break
    Endif
  Next NI
  # -----------

  #---------------------------------
  # Transfer to OPPORSTA table
  #---------------------------------
  For NI = 0 To dim([F:OPPM]STEX)-1
    If [F:OPPM]STEX(NI) <> "" Then
      Raz [F:OSA]
      [F:OSA]OPPNUM  = [F:OPPM]OPPNUM
      [F:OSA]STELINX = 1
      [F:OSA]STEX    = [F:OPPM]STEX(NI)
      [F:OSA]STRDATX = [F:OPPM]ENDDATX(NI)
      [F:OSA]ENDDATX = [F:OPPM]ENDDATX(NI)
      [F:OSA]DONX    = [F:OPPM]DONX(NI)
      [F:OSA]RENX    = [F:OPPM]RENX(NI)
      #----------
      $WRITE_OSA
      Write [OSA]
      If fstat = 3 Then
        [F:OSA]STELINX += 1  # Issue X3-75820 - 2018-03-28 by FGR : not [F:OSA]STELIN
        Goto WRITE_OSA
      Elsif fstat Then
        IERR = 1
        Call ECR_TRACE("File OPPORSTA(421) " - [F:OPP]OPPNUM - "/" - [F:OPP]STEX(NI) - "/" - num$(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      Break
    Endif
  Next NI
  # -----------

  #---------------------------------
  # Transfer to OPPORCPP table
  #---------------------------------
  For NI = 0 To dim([F:OPPM]CPP)-1
    If [F:OPPM]CPP(NI) <> "" Then
      Raz [F:OCP]
      [F:OCP]OPPNUM  = [F:OPPM]OPPNUM
      [F:OCP]CPP     = [F:OPPM]CPP(NI)
      [F:OCP]CPPAMT  = [F:OPPM]CPPAMT(NI)
      [F:OCP]ASE     = [F:OPPM]ASE(NI)
      [F:OCP]SHC     = [F:OPPM]SHC(NI)
      Write [OCP]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File OPPORCPP " - [F:OPPM]OPPNUM - "/" - [F:OPPM]CPP(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      Break
    Endif
  Next NI
  # -----------

  #---------------------------------
  # Transfer to OPPORSBB table
  #---------------------------------
  For NI = 0 To dim([F:OPPM]SBBPJT)-1
    If [F:OPPM]SBBPJT(NI) <> "" Then
      Raz [F:OBB]
      [F:OBB]OPPNUM  = [F:OPPM]OPPNUM
      [F:OBB]SBBPJT  = [F:OPPM]SBBPJT(NI)
      Write [OBB]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File OPPORSBB " - [F:OPPM]OPPNUM - "/" - [F:OPPM]SBBPJT(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      Break
    Endif
  Next NI
  # -----------

  #---------------------------------
  # Creation or update of the
  # PIMPL table
  #---------------------------------
  Read [PIM]PIM0=[F:OPPM]OPPNUM
  If fstat=5 Then
    Raz [F:PIM]
    [F:PIM]PIMNUM    = [F:OPPM]OPPNUM
    [F:PIM]OPPNUM    = [F:OPPM]OPPNUM
    [F:PIM]FCY       = [F:OPPM]SALFCY
    [F:PIM]PIMTYP = 1
    [F:PIM]PIMSTA = G_OUI
    #
    [F:PIM]CPY       = [F:FCY]LEGCPY
    [F:PIM]FINRSPFCY = [F:FCY]FINRSPFCY
    Write [PIM]
    If fstat Then
      IERR = 1
      Call ECR_TRACE("File(Write) PIMPL" - [F:PIM]PIMNUM + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Elsif !fstat
    [F:PIM]OPPNUM    = [F:OPPM]OPPNUM
    [F:PIM]FCY       = [F:OPPM]SALFCY
    [F:PIM]UPDUSR    = [F:OPPM]UPDUSR
    [F:PIM]UPDDAT    = [F:OPPM]UPDDAT
    #
    [F:PIM]CPY       = [F:FCY]LEGCPY
    [F:PIM]FINRSPFCY = [F:FCY]FINRSPFCY
    Rewrite [PIM]
    If fstat Then
      IERR = 1
      Call ECR_TRACE("File(Rewrite) PIMPL" - [F:PIM]PIMNUM + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Endif
  # -------------------------

  #---------------------------------
  # Creation or update of the
  # PIMPL table
  #---------------------------------
  If [F:OPPM]OPPDES <> "" Then
    Call MAJTEXTRA([F:OPPM]OPPDES, "PIMPL", "PIMDESAXX", [F:OPPM]OPPNUM, "") From ATEXTRA
    If GOK < 1 Then
      Call ECR_TRACE("File ATEXTRA PIMPL-PIMDESAXX" - [F:OPPM]OPPNUM + ",Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
    Endif
    IUPDATE = 1
    [F:OPPM]OPPDES = ""
  Else
    Local Char WCHAINE(250)  # Issue X3-112612 - 2018-10-16 by FGR

    Call LECTEXTRA(WCHAINE, "PIMPL", "PIMDESAXX", [F:OPPM]OPPNUM, "") From ATEXTRA
    If WCHAINE = "" Then
      Call MAJTEXTRA(WCHAINE, "PIMPL", "PIMDESAXX", [F:OPPM]OPPNUM, "") From ATEXTRA
    Endif
  Endif
  # -------------------------

  #---------------------------------
  # Currency management
  #---------------------------------
  If [F:OPP]CHGTYP < 1 Then
      [F:OPP]CHGTYP = 1
      IUPDATE = 1
  Endif
  # -------------------------

  If IERR : GOK=0 : Endif

Return

########################################################################
$TRT_SQL

#2- alimenter la nouvelle colonne si vide
#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [OPPM]
GOK = 1

Gosub TRT_SQL1

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMOPPM+" SET SALFCY_0="
REQSQL(1)="(SELECT OPP.SALFCY_0 FROM"-DOSSIER+"."+WNAMOPPM+" OPP Where OPP.OPPNUM_0="+WNAMOPPM+".OPPNUM_0)"
REQSQL(2)=" WHERE "+WNAMOPPM+".SALFCY_0<>(SELECT OPP.SALFCY_0 From"-DOSSIER+"."+WNAMOPPM+" OPP Where OPP.OPPNUM_0="+WNAMOPPM+".OPPNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCRM01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTCRM01(APPLI)
End

