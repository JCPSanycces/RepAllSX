#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SXXSIGHIS
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]AEVENT
    When "AQUERY_CRITERIA_AFTER"
      If PQRY.QWHERE<>""
        PQRY.QWHERE="("+PQRY.QWHERE+") and (FLGSIG eq 1 or FLGSIG eq 5) and DEST eq GACTX.USER"
      Else
        PQRY.QWHERE="(FLGSIG eq 1 or FLGSIG eq 5) and DEST eq GACTX.USER"
      Endif
    When "AQUERY_JOIN_AFTER"
      Local Char VARS(20)(1..3), COLS(20)(1..3)

      VARS(1)="FLGSIG"
      COLS(1)="[F:AWS]FLGSIG"
      VARS(2)="DEST"
      COLS(2)="[F:AWS]DEST"
      Link [AWS] With [A_]AWS2=[AWS]DEST;[AWS]CHRONO
&                As [LNK_]
&                Where evalueSData(PQRY.QWHERE,VARS,COLS)
&                  and (find('SQHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)&[F:AWS]CODWRK<>'SQHSIGNCR')|(find('SOHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)&[F:AWS]CODWRK<>'SOHSIGNCR')|
&                      (find('SOCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)&[F:AWS]CODWRK<>'SOCSIGNCR')
    When Default
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  Case [L]CURPRO
    When "RCHRONO"
      Case [L]ARULE
        When "GET"
          this.RCHRONO = this.AWS.CHRONO
        When Default
      Endcase
    When "TYPVCR"
      Case [L]ARULE
        When "GET"
          Case this.AWS.ABROBJ
            When "SQH"
              this.TYPVCR = 9  # Devis ML477
            When "SOH"
              this.TYPVCR = 8  # Commande ML477
            When Default
              this.TYPVCR = 7  # Commande ouverte ML477
          Endcase
      Endcase
    When "DEVTTC"
      Case [L]ARULE
        When "GET"
          this.DEVTTC = this.AWS.VALCTX6
      Endcase
    When "RCLEDEC"
      Case [L]ARULE
        When "GET"
          this.RCLEDEC = this.AWS.CLEDEC
        When Default
      Endcase
    When "RVALCTX7"
      Case [L]ARULE
        When "GET"
          Local Integer IDAY
          Local Integer IMONTH
          Local Integer IYEAR

          IDAY = val(left$(this.AWS.VALCTX7,2))
          IMONTH = val(mid$(this.AWS.VALCTX7,4,2))
          IYEAR = val(mid$(this.AWS.VALCTX7,7,4))
          this.RVALCTX7 = gdat$(IDAY, IMONTH, IYEAR)
        When Default
      Endcase
    When "RVALCTX2"
      Case [L]ARULE
        When "GET"
          this.RVALCTX2 = this.AWS.VALCTX2
        When Default
      Endcase
    When "RVALCTX3"
      Case [L]ARULE
        When "GET"
          this.RVALCTX3 = this.AWS.VALCTX3
        When Default
      Endcase
    When "RVALCTX1"
      Case [L]ARULE
        When "GET"
          this.RVALCTX1 = this.AWS.VALCTX1
        When Default
      Endcase
    When "RVALCTX4"
      Case [L]ARULE
        When "GET"
          this.RVALCTX4 = val(this.AWS.VALCTX4)
        When Default
      Endcase
    When "RVALCTX6"
      Case [L]ARULE
        When "GET"
          this.RVALCTX6 = this.AWS.VALCTX6
        When Default
      Endcase
    When "RVALCTX5"
      Case [L]ARULE
        When "GET"
          this.RVALCTX5 = val(this.AWS.VALCTX5)
        When Default
      Endcase
    When "RVALCTX8"
      Case [L]ARULE
        When "GET"
          If this.TYPVCR <> 7 Then
            # pas pour les commandes ouvertes
            this.RVALCTX8 = this.AWS.VALCTX8
          Endif
        When Default
      Endcase
    When "RVALCTX9"
      Case [L]ARULE
        When "GET"
          If this.TYPVCR <> 7 Then
            # pas pour les commandes ouvertes
            this.RVALCTX9 = this.AWS.VALCTX9
          Endif
        When Default
      Endcase
  Endcase
Return

