#<AdxTL>@(#)5.0.0.0 $Revision$
########################################################################################################
# UUTITRS07                                                  Module Tiers                              #
# Suppression des paramètres obsolètes FUPLEV6 à FUPLEV9                                               #                     
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITRS07: FUPLEV6 to FUPLEV9 parameters deletion") From LECFIC

 Call MAJ_UTITRS07(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS07(APPLI)
Value Char APPLI
Local Char PARNAM(250)
Local Integer STAT, N

# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

Call ECR_TRACE("UUTITRS07: Process Start on: "+APPLI,0) From GESECRAN

Local File =APPLI+".ADOPAR"    [ADP]
Local File =APPLI+".ADOVAL"    [ADW]

Trbegin [ADP]
For N=6 To 9
 [L]PARNAM = "FUPLEV"+num$(N)
 Readlock [ADP]ADP0 = "TRS";[L]PARNAM
 If !fstat
  Delete [ADP] Curr
  If fstat
   # Erreur d'effacement
   GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : "+[L]PARNAM,-1) From GESECRAN : Goto AB_UUTITRS07 
  Else
   # Suppression enregistrements
   Call ECR_TRACE(mess(499,196,1)-"ADOPAR : "+"TRS"-[L]PARNAM,0) From GESECRAN
   For [ADW] Where PARAM=[L]PARNAM
    Readlock [ADW] Curr
    If fstat
     # Erreur d'effacement
     GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOVAL : "+[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM,-1) From GESECRAN : Goto AB_UUTITRS07 
    Else
     Delete [ADW] Curr
     # Suppression
     Call ECR_TRACE(mess(53,123,1)-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM, 0) From GESECRAN
    Endif
   Next
  Endif
 Else
  
 Endif
Next
Commit
Call ECR_TRACE("UUTITRS07: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITRS07
Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS07(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS07(APPLI)
End
