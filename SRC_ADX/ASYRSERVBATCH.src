#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* This program is working on Syracuse Session Client
#* It permit to update ABATPAR table to pass in integrate update mode;
#*
#*!
Funprog HANDLER_PUT(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Gosub INIT_NODES

Gosub START_GLOBAL

Local Integer MODE : [L]MODE = (func ASYRMAIN.PARVAL(ARCV,"flgpatch")="true")+1
Raz GMESSAGE
Local File ABATPAR [ABP]
Gosub TR_MODEINTEGRATE

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDARRAY(NODES,ROOT,"diagnoses",DIAGS) From ASYRJSO
Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO
If  [L]MODE=2
 Call JSON_ADDSTRING(NODES,DIAG,"$message","Patch mode activated"-GMESSAGE)  From ASYRJSO
Else
 Call JSON_ADDSTRING(NODES,DIAG,"$message","Patch mode not activated :"-GMESSAGE)  From ASYRJSO
Endif
If GMESSAGE=""
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"info")  From ASYRJSO
Else
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
Endif

Gosub END_GLOBAL

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

$HANDLER_PUT_EXIT
ASND.URL      = PSYR.PREFIX+'/modesrvpatch'
End ERROR

$TR_MODEINTEGRATE
GOK=1
Raz GMESSAGE
Trbegin [ABP]
 Readlock [ABP]SPOOL First
 If fstat=1
  GOK=-1 : GMESSAGE = mess(60,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Endif
 [F:ABP]FLGPATCH = [L]MODE
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Endif
Commit
Return

$AB_TR_DEB
Rollback
Return


#**
#* This program is working on Syracuse Session Client
#* It permit to kill all tasks on  the batch server.
#*
#*!
Funprog HANDLER_KILL(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Gosub INIT_NODES

Gosub START_GLOBAL

Local Char    FICKILL(GDIMFIC)
FICKILL = filpath("FIL","kill","",0)
Openo FICKILL,0 Using [FIC]
Wrseq "" Using [FIC]
Openo Using [FIC]


Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDARRAY(NODES,ROOT,"diagnoses",DIAGS) From ASYRJSO
Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO
If filinfo(FICKILL,0)>0
 Call JSON_ADDSTRING(NODES,DIAG,"$message",FICKILL-"created")  From ASYRJSO
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"info")  From ASYRJSO
Else
 Call JSON_ADDSTRING(NODES,DIAG,"$message",FICKILL-"not created")  From ASYRJSO
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
Endif

Gosub END_GLOBAL

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

$HANDLER_KILL_EXIT
ASND.URL      = PSYR.PREFIX+'/killbatch'
End ERROR
#**
#* This program is working on Syracuse Session Client
#* It permit to stop the batch server.
#*
#*!
Funprog HANDLER_DELETE(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Gosub INIT_NODES

Gosub START_GLOBAL

Call DESACTIVE From SERVEUR

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
If GERR>0
 Call JSON_ADDARRAY(NODES,ROOT,"diagnoses",DIAGS) From ASYRJSO
 Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO
 Call JSON_ADDSTRING(NODES,DIAG,"$message",GMESSAGE)  From ASYRJSO
 If GERR=2
  Call JSON_ADDSTRING(NODES,DIAG,'$severity',"info")  From ASYRJSO
 Else
  Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
 Endif
Endif
Gosub END_GLOBAL

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

$HANDLER_DELETE_EXIT
ASND.URL      = PSYR.PREFIX+'/stopbatch'
End ERROR

#**
#* This program is working on Syracuse Session Client
#* It permit to start the batch server.
#*
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO
Gosub INIT_NODES

Gosub START_GLOBAL

Local Integer MODE : [L]MODE = (func ASYRMAIN.PARVAL(ARCV,"flgpatch")="true")+1

Local File ABATPAR [ABP]
Gosub TR_MODEINTEGRATE

Call ACTIVE From SERVEUR

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
If GERR>0
 Call JSON_ADDARRAY(NODES,ROOT,"diagnoses",DIAGS) From ASYRJSO
 Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO
 If  [L]MODE=2
  GMESSAGE -= ",patch mode activated"
 Else
  GMESSAGE -= ",patch mode notactivated"
 Endif
 Call JSON_ADDSTRING(NODES,DIAG,"$message",escJson(GMESSAGE))  From ASYRJSO
 If GERR=2
  Call JSON_ADDSTRING(NODES,DIAG,'$severity',"info")  From ASYRJSO
 Else
  Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
 Endif
Endif
Gosub END_GLOBAL

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

$HANDLER_POST_EXIT
ASND.URL      = PSYR.PREFIX+'/startbatch'
End ERROR



#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK
Local File ABATPAR [ABP]

Read [ABP]SPOOL First
If !fstat
 #---------------------------------#
 # [F:ABP]STOP
 #---------------------------------#
 # 0 Serveur arrêté
 # 1 Actif
 # 2 En cours d'arrêt
 # 3 En cours de démarrage (new)
 #---------------------------------#
 GMESSAGE = mess([F:ABP]STOP+1,8,1)
 Local Instance  JSO(1..) Using C_ASYRJSO

Gosub INIVAR From ASYRJSO
NIV = 1
NODEPRO = ''
Gosub ADDOBJECT From ASYRJSO

NODEPRO = '"APPLI"'
NODESVAL = '"'+[F:ABP]APPLI+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"FLGPATCH"'
NODENVAL = [F:ABP]FLGPATCH
Gosub ADDNUMBER From ASYRJSO
NODEPRO = '"STOP"'
NODENVAL = [F:ABP]STOP
Gosub ADDNUMBER From ASYRJSO

Gosub ENDNIV From ASYRJSO
Call GENERATE_JSON(TBNIV(1),ASND.DATA) From ASYRJSO

Endif

Close File [ABP]
$HANDLER_GET_EXIT
ASND.URL      = PSYR.PREFIX+'/startbatch'
End ERROR


$START_GLOBAL
Local Char PWD(250)

If dim([S]secmod)>0 & [S]secmod=2 : # Kerberos
 [S]adxcpw = XCRYPT([L]PWD)
Endif
Global Char     GOS(10)(0..3)       : # Type de machine (dos/unix)
Global Char     GOS2(10)(0..3)      : # Sous-type (AIX/ULTRIX)
Global Char     GREPTMP(250)(0..3)  : # Répertoires temporaires
Global Char     GMESSAGE(250)
Global Integer  GERR
Global Char     GLOGIN(30)
Global Char     GLANGUE(GLONLAN)
Global Char     GIRS(2)(0..3)

For I=1 To maxtab(ACTX.ASOL.OS)
 GOS(I-1) = ACTX.ASOL.OS(I)
 GOS2(I-1) = ACTX.ASOL.OS2(I)
 GREPTMP(I-1) = ACTX.ASOL.TMPDIR(I)
 GIRS(I-1) = ACTX.ASOL.IRS(I)
Next
GLOGIN = ACTX.LOGIN
GLANGUE = ACTX.LAN
Return

$END_GLOBAL
If dim([S]secmod)>0 & dim([S]adxcpw)>0
 If [S]secmod=2 : [S]adxcpw = "" : Endif : # Kerberos
Endif
Kill [V]GOS,[V]GOS2,[V]GREPTMP,[V]GMESSAGE,[V]GERR,[V]GLOGIN,[V]GLANGUE,[V]GIRS
Return


$INIT_NODES
Local Integer   ERROR : ERROR = [V]CST_AOK

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE          Using C_ASYRJSO  : NODE=null
Local Instance  DIAGS          Using C_ASYRJSO  : NODE=null
Local Instance  LINKS          Using C_ASYRJSO  : NODE=null
Local Instance  LNKTRA          Using C_ASYRJSO  : NODE=null
Local Instance  DIAG          Using C_ASYRJSO  : NODE=null
Local Instance  INFO          Using C_ASYRJSO  : NODE=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null
Return
