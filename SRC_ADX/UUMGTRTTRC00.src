#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC00   Migration sub-programs                      TRC Module  #
##########################################################################
# LOA_BOM: Load BOM for upgrade of BOMALTTYP 
##########################################################################

$LOA_BOM
Global Shortint WBOMALTTYP(1..99)

# Chargement des types d'alternatives dans un tableau
Local File =[F:ADS]DOSSIER+".TABBOMALT"   [TBO]
For [TBO]
    WBOMALTTYP([F:TBO]BOMALT)=[F:TBO]BOMALTTYP
Next
Return

#######################################################################
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
#######################################################################
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return
#######################################################################
