#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Return


#** #############################################################################################################
#*
#*Procedure:   IMPRIME
#*
#* Purpose:    Handler for the report preprocess.
#*
#*
#* Parameters:
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#** #############################################################################################################
#*!

Subprog IMPRIME( NBPAR, PARAMETRE )
Variable Integer NBPAR
Variable Char PARAMETRE()(1..)
    Local Char     PARAM(30), PARAMR(250)   # Parameter variables for GET/SETPARAM
    Local Char     REPCODE(250)             # Report code
    Local Integer  NUMREQ                   # Report data ID (for AREPORTM)
    Local Integer  DOTPOS                   # Position of the dot in the report name.
    Local Integer  I
    Local Char     PARAMC(250)
    Local Char     DATERANGE(250)
    Local Char     SHODES_ADI(250)
    Local Libelle  RETC                      # Return code of the warning box

    # Leave if the CONSRSG/DCLVATGER2 function is not active for we need a lot of
    # data from masks [M:RSGx].
    If !clalev([M:TRA5]) or !clalev([M:TRAP])
        GOK = 0 # Cancel printing.
        End
    Endif

    # Unfortunately there are only 5 entries possible so we have to warn and eventually cancel.
    If [M:TRA5]NBLIG > 5
        RETC = 1
        Qstbox mess(338,107,1) - mess(339,107,1) - mess(93,9139,1)
        If RETC = 2
            GOK = 0     # Cancel printing.
            End
        Endif
    Endif

    # Get the report code from report name.
    Call GETPARAM( "__REPORT", NBPAR, PARAMETRE, PARAMR ) From ETAT
    DOTPOS = instr( 1, PARAMR, "." )
    If DOTPOS : REPCODE = left$( PARAMR, DOTPOS - 1 )  : Endif

    # Get the report ID for the selection using AREPORTM.NUMREQ.
    Call GETPARAM( "__REQUETE", NBPAR, PARAMETRE, PARAMR ) From ETAT
    NUMREQ = val(PARAMR)

    # Fill the numedt parameter.
    PARAMR = num$(NUMREQ)
    Call SETPARAM( "numedt", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the company parameter.
    PARAMR = [M:TRAP]CPY
    Call SETPARAM( "cpy", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the start date parameter.
    PARAMR = [M:TRAP]DATDEB
    Call SETPARAM( "datdeb", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the end date parameter.
    PARAMR = [M:TRAP]DATFIN
    Call SETPARAM( "datfin", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Transfer
    PARAMR = num$( [M:TRA5]FLGTRN - 1 )
    Call SETPARAM( "flgtrn", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]AMTTRN)
    Call SETPARAM( "amttrn", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]CRN)
    Call SETPARAM( "crn", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]TAXCEN)
    Call SETPARAM( "taxcen1", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Transfer 2
    PARAMR = num$( [M:TRA5]FLGTRN2 - 1 )
    Call SETPARAM( "flgtrn2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]AMTTRN2)
    Call SETPARAM( "amttrn2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]CRN2)
    Call SETPARAM( "crn2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]TAXCEN2)
    Call SETPARAM( "taxcen2", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Reimbursement
    PARAMR = num$( [M:TRA5]FLGREI - 1 )
    Call SETPARAM( "flgrei", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]AMTREI)
    Call SETPARAM( "amtrei", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BAN
    Call SETPARAM( "ban", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BANDES
    Call SETPARAM( "bandes", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BICCOD
    Call SETPARAM( "biccod", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]IBACOD
    Call SETPARAM( "ibacod", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Reimbursement 2
    PARAMR = num$( [M:TRA5]FLGREI2 - 1 )
    Call SETPARAM( "flgrei2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = num$([M:TRA5]AMTREI2)
    Call SETPARAM( "amtrei2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BAN2
    Call SETPARAM( "ban2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BANDES2
    Call SETPARAM( "bandes2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]BICCOD2
    Call SETPARAM( "biccod2", NBPAR, PARAMETRE, PARAMR ) From ETAT
    PARAMR = [M:TRA5]IBACOD2
    Call SETPARAM( "ibacod2", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Total
    PARAMR = num$([M:TRA5]AMTTOT)
    Call SETPARAM( "amttot", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Tax ID and tax center.
    Read [F:CPY]CPY0 = [M:TRAP]CPY
    If !fstat
         For I = 0 To dim([F:CPY]GERTAXIDT) - 1
             If [F:CPY]GERTAXIDT(I) = [M:TRG0]CRN
                 # Tax ID
                 PARAMR = [F:CPY]GERTAXIDT(I)
                 Call SETPARAM( "taxid", NBPAR, PARAMETRE, PARAMR ) From ETAT

                 # Tax center
                 PARAMR = [F:CPY]GERTAXCEN(I)
                 Call SETPARAM( "taxcen", NBPAR, PARAMETRE, PARAMR ) From ETAT
                 Break
             Endif
         Next
    Endif

    # transfer the data box by box into AREPORTM table.
    If !clalev([F:ARM]) : Local File AREPORTM [ARM] :  Endif
    If !clalev([F:ADI]) : Local File ATABDIV [ADI]  : Endif

    Call DEBTRANS From GLOCK
    Trbegin [ARM]

    For I = 0 To [M:TRA5]NBLIG-1

        # MMJJJJ
        DATERANGE = num$(month([M:TRA5]DATDEB(I)))

        If len(DATERANGE) = 1 : DATERANGE = "0" + DATERANGE : Endif

        If month([M:TRA5]DATDEB(I)) <> month([M:TRA5]DATFIN(I))
          # MMMMJJJJ
          If len(num$(month([M:TRA5]DATFIN(I)))) = 1
            DATERANGE = DATERANGE + "0" + num$(month([M:TRA5]DATFIN(I)))
          Else
            DATERANGE = DATERANGE + num$(month([M:TRA5]DATFIN(I)))
          Endif
        Endif

        DATERANGE = DATERANGE + num$(year([M:TRA5]DATDEB(I)))

        Raz [F:ARM]
        [F:ARM]RPTCOD = REPCODE
        [F:ARM]USR    = GUSER
        [F:ARM]CREDAT = date$
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = I + 1

        # Levy short text
        Call LECTEXTRA(SHODES_ADI,"ATABDIV","SHODES","301",[M:TRA5]TYPLEV(I)) From ATEXTRA
        [F:ARM]CLEA2  = SHODES_ADI
        [F:ARM]CLEA1  = [M:TRAP]CPY
        [F:ARM]CLEA3  = DATERANGE
        [F:ARM]CLED1  = [M:TRA5]DATDEB(I)
        [F:ARM]CLED2  = [M:TRA5]DATFIN(I)
        [F:ARM]CLEMD1 = [M:TRA5]AMT(I)
        Write [ARM]
        If fstat
            GOK = 0
            Break
        Endif
    Next

    If GOK < 1
        Rollback
    Else
        Commit
    Endif
End
