#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYSDH

######################################################################################
# Affichage pièce Facture
Subprog IB_NBSIH

  GBOUT2 = mess(55,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSIH
Local Integer NOL

  If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
  Filter [F:SIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM(GLONSIH)       # FGR 13/08/2014 : X3SUIVI98821 un longueur c'est mieux
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDH2]NUM(NOL)
  Call OBJET("SIH",[M:PDH2]NUM(NOL),"1") From GOBJET
  [M:PDH2]NUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End


######################################################################################
# Affichage pièce Retour
Subprog IB_NBSRH
Local Integer NOL

  GBOUT2 = mess(192,198,1)
  If GPILNAV>1 Then
    NOL = nolign-1
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PDH2]LNDRTN(NOL)=G_OUI and find("GESSRL",GNAVIG(1..GPILNAV)) Then GBOUT2=""
    Elsif [M:PDH2]SCORTN(NOL)=G_OUI and find("GESSRS",GNAVIG(1..GPILNAV)) Then GBOUT2=""
    Elsif find("GESSRH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSRH
Local Integer NOL

  If clalev([F:SRH])=0 : Local File SRETURN [SRH] : Endif
  Filter [F:SRH]
  GCONSULT = 2
  Local Char SAV_VCRNUM(GLONSRH)       # FGR 13/08/2014 : X3SUIVI98821 un longueur c'est mieux
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDH2]SRHNUM(NOL)
  If [M:PDH2]LNDRTN(NOL)=G_OUI Then
    Call OBJET("SRL",[M:PDH2]SRHNUM(NOL),"") From GOBJET
  Elsif [M:PDH2]SCORTN(NOL)=G_OUI Then
    Call OBJET("SRS",[M:PDH2]SRHNUM(NOL),"") From GOBJET
  Else
    Call OBJET("SRH",[M:PDH2]SRHNUM(NOL),"") From GOBJET
  Endif
  [M:PDH2]SRHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End

######################################################################################
# Affichage Pièce Commande
Subprog IB_NBSOH

  GBOUT2 = mess(191,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PDH2]SOHCAT(nolign-1)<>4 Then
      If find("GESSOH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Else
      If find("GESSOQ",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Endif
  Endif
End

Subprog B2_NBSOH
Local Integer NOL

  If clalev([F:SOH])=0 : Local File SORDER [SOH] : Endif
  Filter [F:SOH]
  GCONSULT = 2
  Local Char SAV_VCRNUM(GLONSOH)       # FGR 13/08/2014 : X3SUIVI98821 un longueur c'est mieux
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PDH2]SOHNUM(NOL)
  If [M:PDH2]SOHCAT(NOL)<>4 Then
    Call OBJET("SOH",[M:PDH2]SOHNUM(NOL),"") From GOBJET
  Else
    Call OBJET("SOQ",[M:PDH2]SOHNUM(NOL),"") From GOBJET
  Endif
  [M:PDH2]SOHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End


######################################################################################
