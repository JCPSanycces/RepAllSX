   If [F:ACST]CATEG    <> [F:DACST]CATEG     : DIFF = 9  : Endif
   If !DIFF : Call TXT([F:ACST]INTIT,DIFF)  From DOSSUB : Endif
   If DIFF
    If GTSTDOS
     Call ECR_TRACE("Diff constant"-[F:ACST]CODVAR-num$(DIFF),0) From GESECRAN
    Endif
    [F:DACST] = [F:ACST]
    If dim([F:DACST]UPDDAT)>0 : [F:DACST]UPDDAT = date$ : Endif
    If dim([F:DACST]UPDUSR)>0 : [F:DACST]UPDUSR = GUSER : Endif
