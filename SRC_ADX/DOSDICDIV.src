#<AdxTL>@(#)11.0.0.0 $Revision$
#####################################################
## DOSDICDIV   Dictionnaires divers
#####################################################
# $DICACT  Actions
# $DICPAR  Paramètres actions
# $DICACV  Codes activités
# $DICGEN  Paramètres généraux
# $DICDIV  Tables diverses
# $DICTYP  Types de données
# $DICTYPACLA  Types de données (for ACLA,ASW)
# $DICCNS  Consultations
# $DICNAV  Navigations
# $DICEPU  Formules d'épuration/historisation
# $DICAMI  Transactions systèmes
# $DICTRN  Transactions applicatives
# $DICATYP Type prototype
# $DICAGB  Variables globales
# $DICASU  Sous programmes
# $DICAPE  Points d'entrée
# $DICADO  Documentation
# $DICADF  Liens documentation
# $DICAVR  Contexte assistant formule
# $DICAWM  Modèles de données Worflow
# $DICAUTIL  Utilitaires
#####################################################

#####################################################
#####################################################
Subprog CHANGE_CODTYP(TAB,TYPTYP,CODTYP,LONG)
Value Integer TAB,TYPTYP
Variable Char CODTYP
Variable Decimal LONG
  Case [L]TYPTYP
   When 1,2,3   : [L]CODTYP = "C"      : [L]LONG = 4
   When 4,5,6   : [L]CODTYP = "DCB"    : [L]LONG = 19.8
   When 8       : [L]CODTYP = "D"      : [L]LONG = 1
   When 11      : [L]CODTYP = "AUUID"  : [L]LONG = 1
   When 12      : [L]CODTYP = "ADATIM" : [L]LONG = 1
   When Default : [L]CODTYP = "A"
                  If TAB : [L]LONG = 10
                  Else : [L]LONG = 1
                  Endif
  Endcase
End


#####################################################
## Actions
#####################################################
$DICACT
# Remplissage du dico des actions
Call ECR_TIME(mess(15,125,1)-mess(20,125,1)) From DOSSUB
# MAJ dictionnaire - Actions
Local File =GDOSREF+".ACTION" [ACT] , =GDOSREF+".ACTPAR" [ATR]
Local File =[F:ADS]DOSSIER+".ACTION"    [DACT]
&         ,=[F:ADS]DOSSIER+".ACTION"    [DAC2]
&         ,=[F:ADS]DOSSIER+".ACTPAR"    [DATR]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(20,125,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DACT] , [DATR]
  For [DACT] Where ACTION<GXX
   Call SPEC([F:DACT]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ACT]ACTION = [F:DACT]ACTION
    If fstat
     Delete [DATR] Where ACTION=[F:DACT]ACTION
     If fstat=1 : Call ERREUR("ACTPAR"-[F:DACT]ACTION,3) From DOSDIC : Endif
     Delete [DACT]
     If fstat=1 : Call ERREUR("ACTION"-[F:DACT]ACTION,3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif

For [ACT] Where ACTION<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(20,125,1),[F:ACT]ACTION) From GESECRAN
 Endif
 Trbegin [DACT]
  OLD = 0
  SPEC = 0
  Read [DACT]ACTION = [F:ACT]ACTION
  If !fstat
   OLD = 1
   Call SPEC([F:DACT]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ACT]CODACT,[F:ACT]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Delete [DACT] Where ACTION=[F:ACT]ACTION
    If fstat=1 : Call ERREUR("ACTION"-[F:ACT]ACTION,3) From DOSDIC : Endif
    Delete [DATR] Where ACTION=[F:ACT]ACTION
    If fstat=1 : Call ERREUR("ACTPAR"-[F:ACT]ACTION,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    Raz [F:DACT]
    [F:DACT] = [F:ACT]
    [F:DACT]CREDAT = date$
    [F:DACT]CREUSR = GUSER
    If dim([F:DACT]CRETIM)>0 : [F:DACT]CRETIM = time : Endif
    Write [DACT]
    If fstat : Call ERREUR("ACTION"-[F:DACT]ACTION,1) From DOSDIC : Endif
    Gosub CREPAR
   Elsif NEWREC & OLD
    [F:DAC2] = [F:DACT]
    [F:DACT] = [F:ACT]
    [F:DACT]SPETRT = [F:DAC2]SPETRT
    [F:DACT]UPDDAT = date$
    [F:DACT]UPDUSR = GUSER
    If dim([F:DACT]UPDTIM)>0 : [F:DACT]UPDTIM = time : Endif
    Rewrite [DACT]
    If fstat : Call ERREUR("ACTION"-[F:DACT]ACTION,2) From DOSDIC : Endif
    Delete [DATR] Where ACTION=[F:ACT]ACTION
    Gosub CREPAR
   Endif
  Endif
 Commit
Next
Close Local File [ACT] , [ATR] , [DACT] , [DAC2] , [DATR]
Return

$CREPAR
For [ATR] Where ACTION=[F:ACT]ACTION
 [F:DATR] = [F:ATR]
 Write [DATR]
 If fstat : Call ERREUR("ACTPAR"-[F:DATR]ACTION-[F:DATR]CODPAR,1) From DOSDIC : Endif
Next
Return

############################################################
## Paramètres
############################################################
$DICPAR
Call ECR_TIME(mess(15,125,1)-mess(40,125,1)) From DOSSUB
# MAJ dictionnaire - Paramètres
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(40,125,1),"") From GESECRAN
Endif
Local File =GDOSREF+".ACTCODPAR" [AAR] , =GDOSREF+".ACTPAR" [ATR]
Local File =[F:ADS]DOSSIER+".ACTCODPAR" [DAAR]
&         ,=[F:ADS]DOSSIER+".ACTPAR" [DATR]
# On crée tout et on ne conserve que les paramètres référencés
Trbegin [DAAR]
 For [AAR]CODPAR
  Read [DAAR]CODPAR = [F:AAR]CODPAR
  If fstat
   [F:DAAR] = [F:AAR]
   Write [DAAR]
   If fstat : Call ERREUR("ACTCODPAR"-[F:DAAR]CODPAR,1) From DOSDIC : Endif
  Else
   [F:DAAR] = [F:AAR]
   Rewrite [DAAR]
   If fstat : Call ERREUR("ACTCODPAR"-[F:DAAR]CODPAR,2) From DOSDIC : Endif
  Endif
 Next
 For [DAAR]CODPAR
  Read [DATR]CODPAR = [F:DAAR]CODPAR
  If fstat
   Delete [DAAR]
   If fstat=1 : Call ERREUR("ACTCODPAR"-[F:DAAR]CODPAR,3) From DOSDIC : Endif
  Endif
 Next
Commit
Close Local File [AAR] , [ATR] , [DAAR] , [DATR]
Return

############################################################
## Codes activités
############################################################
$DICACV
Call ECR_TIME(mess(15,125,1)-mess(24,125,1)) From DOSSUB
# MAJ dictionnaire - Codes activités
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(24,125,1),"") From GESECRAN
Endif
Local File =GDOSX3+".ADOSACT" [ADA], =[F:ADS]DOSSIER+".ACTIV" [DACV], =[F:ADS]DOSREF+".ACTIV" [ACV3]
Trbegin [DACV]
 For [DACV]
  Read [ADA]ADA0=[F:ADS]DOSSIER;[F:DACV]CODACT
  If fstat
   Delete [DACV] Curr
  Endif
 Next DACV
 For [ACV3] Where CODACT<GXX
  If GINFO
   Call AFF_VLC(mess(15,125,1)-mess(24,125,1),[F:ACV3]CODACT) From GESECRAN
  Endif
  Read [DACV]CODACT=[F:ACV3]CODACT
  If fstat
   [F:DACV] = [F:ACV3]
   If [F:ACV3]CODACT=GCODACTX3(1)
    [F:DACV]FLACT = 2
   Elsif [F:ACV3]CODACT=GCODACTX3(2)
    [F:DACV]FLACT = 1
   Else
    Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:ACV3]CODACT
    If fstat
     [F:DACV]FLACT = 1
    Else
     [F:DACV]FLACT  = [F:ADA]FLACT
     [F:DACV]DIME   = [F:ADA]DIME
     [F:DACV]CREDAT = date$
     [F:DACV]CREUSR = GUSER
     If dim([F:DACV]CRETIM)>0 : [F:DACV]CRETIM = time : Endif
    Endif
   Endif
   Write [DACV]
   If fstat : Call ERREUR("ACTIV"-[F:DACV]CODACT,1) From DOSDIC : Endif
  Else
   [F:DACV] = [F:ACV3]
   If [F:ACV3]CODACT=GCODACTX3(1)
    [F:DACV]FLACT = 2
   Elsif [F:ACV3]CODACT=GCODACTX3(2)
    [F:DACV]FLACT = 1
   Else
    Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:ACV3]CODACT
    If fstat
     [F:DACV]FLACT = 1
    Else
     [F:DACV]FLACT  = [F:ADA]FLACT
     [F:DACV]DIME   = [F:ADA]DIME
     [F:DACV]UPDDAT = date$
     [F:DACV]UPDUSR = GUSER
     If dim([F:DACV]UPDTIM)>0 : [F:DACV]UPDTIM = time : Endif
    Endif
   Endif
   Rewrite [DACV]
   If fstat : Call ERREUR("ACTIV"-[F:DACV]CODACT,1) From DOSDIC : Endif
  Endif
 Next ACV
 For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X"
  Read [DACV]CODACT=[F:ADA]CODACT
  If fstat
   Raz [F:DACV]
   Read [ACV3]CODACT = [F:ADA]CODACT
   If fstat
    [F:DACV]DIMFIL = [F:ADA]DIME
   Else
    [F:DACV] = [F:ACV3]
   Endif
   [F:DACV] = [F:ADA]
   If [F:ADA]DIME<>0
    [F:DACV]TYP = 2
   Else
    [F:DACV]TYP = 1
   Endif
   [F:DACV]CREDAT = date$
   [F:DACV]CREUSR = GUSER
   If dim([F:DACV]CRETIM)>0 : [F:DACV]CRETIM = time : Endif
   Write [DACV]
   If fstat : Call ERREUR("ACTIV"-[F:DACV]CODACT,1) From DOSDIC : Endif
  Else
   Read [ACV3]CODACT = [F:ADA]CODACT
   If fstat
    [F:DACV]DIMFIL = [F:ADA]DIME
   Else
    [F:DACV] = [F:ACV3]
   Endif
   [F:DACV] = [F:ADA]
   If [F:ADA]DIME<>0
    [F:DACV]TYP = 2
   Else
    [F:DACV]TYP = 1
   Endif
   [F:DACV]UPDDAT = date$
   [F:DACV]UPDUSR = GUSER
   If dim([F:DACV]UPDTIM)>0 : [F:DACV]UPDTIM = time : Endif
   Rewrite [DACV]
   If fstat : Call ERREUR("ACTIV"-[F:DACV]CODACT,1) From DOSDIC : Endif
  Endif
 Next ADA
Commit
Close Local File [ADA] , [DACV] , [ACV3]
Return

############################################################
## Paramètres généraux
############################################################
$DICGEN

Call ECR_TIME(mess(15,125,1)-mess(25,125,1)) From DOSSUB
# MAJ dictionnaire - Paramètres généraux
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(25,125,1),"") From GESECRAN
Endif

Local File =GDOSREF+".ADOPAR"           [ADP]
Local File =[F:ADS]DOSCOP+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSCOP+".ADOVALAUS"  [ADU]
# Issue 86047 - 2012-11-20 by VPO : ADOVALGRP passe en TYPFIC=4 Dictionnaire
Local File =[F:ADS]DOSCOP+".ADOVALGRP"  [ADG]

Local File =[F:ADS]DOSSIER+".ADOPAR"    [DADP]
Local File =[F:ADS]DOSSIER+".ADOPAR"    [DAD2]
Local File =[F:ADS]DOSSIER+".ADOVAL"    [DADW]
Local File =[F:ADS]DOSSIER+".ADOVAL"    [DAW2]
Local File =[F:ADS]DOSSIER+".ADOVALAUS" [DADU]
# Issue 85493 - 2012-10-29 by VPO : supp ADOVALGRP si supp ADOVAL
Local File =[F:ADS]DOSSIER+".ADOVALGRP" [DADG]

# Paramètres

If !GCRE
 Trbegin [DADP] , [DADW] , [DADU], [DADG]
  For [DADP] Where PARAM<GXX
   Call SPEC([F:DADP]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ADP]ADP1 = [F:DADP]PARAM
    If fstat
     Delete [DADW] Where PARAM=[F:DADP]PARAM
     If fstat=1 : Call ERREUR("ADOVAL"-[F:DADP]PARAM,3) From DOSDIC : Endif
     Delete [DADU] Where PARAM=[F:DADP]PARAM
     If fstat=1 : Call ERREUR("ADOVALAUS"-[F:DADP]PARAM,3) From DOSDIC : Endif
     # Issue 85493 - 2012-10-29 by VPO : supp ADOVALGRP si supp ADOVAL
     Delete [DADG] Where PARAM=[F:DADP]PARAM
     If fstat=1 : Call ERREUR("ADOVALGRP"-[F:DADP]PARAM,3) From DOSDIC : Endif
     Delete [DADP]
     If fstat=1 : Call ERREUR("ADOPAR"-[F:DADP]PARAM,3) From DOSDIC : Endif
    Endif
   Endif
  Next DADP
 Commit
Endif

Trbegin [DADP]
 For [ADP]ADP0 Where PARAM<GXX
  If GINFO
   Call AFF_VLC(mess(15,125,1)-mess(25,125,1),[F:ADP]CHAPITRE) From GESECRAN
  Endif
  OLD = 0
  SPEC = 0
  Read [DADP]ADP1 = [F:ADP]PARAM
  If !fstat
   OLD = 1
   Call SPEC([F:DADP]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ADP]CODACT,0,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Delete [DADW] Where PARAM=[F:DADP]PARAM
    If fstat=1 : Call ERREUR("ADOVAL"-[F:DADP]PARAM,3) From DOSDIC : Endif
    Delete [DADU] Where PARAM=[F:DADP]PARAM
    If fstat=1 : Call ERREUR("ADOVALAUS"-[F:DADP]PARAM,3) From DOSDIC : Endif
    # Issue 85493 - 2012-10-29 by VPO : supp ADOVALGRP si supp ADOVAL
    Delete [DADG] Where PARAM=[F:DADP]PARAM
    If fstat=1 : Call ERREUR("ADOVALGRP"-[F:DADP]PARAM,3) From DOSDIC : Endif
    Delete [DADP]
    If fstat=1 : Call ERREUR("ADOPAR"-[F:DADP]PARAM,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    [F:DADP] = [F:ADP]
    Write [DADP]
    If fstat : Call ERREUR("ADOPAR"-[F:DADP]PARAM,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    [F:DAD2] = [F:DADP]
    [F:DADP] = [F:ADP]
    [F:DADP]ACS = [F:DAD2]ACS : # On préserve le code d'accès
    Rewrite [DADP]
    If fstat : Call ERREUR("ADOPAR"-[F:DADP]PARAM,2) From DOSDIC : Endif
   Endif
  Endif
 Next ADP
Commit

# Valeurs des paramètres

Trbegin [DADW]
 If GCRE & [F:ADS]OPTINI(3)=2
  # Création + Copie
  If [F:ADS]OPTINI(5)=2
   # mb 6.6.2 dem 9262 Copie des paramètres Société/Site
   For [ADW]ADW0 Where find(PARAM,"DOSLEG","ADEMO")=0
    Read [DADP]ADP1 = [F:ADW]PARAM
    If !fstat
     If OKLEG : # Multi-législation
      If ([F:ADW]CMP<>"*") or ([F:ADW]CMP="*" & find([F:ADW]FCY,[F:ADS]DOSLEG(0..[F:ADS]NBLEG)) & !find([F:ADW]FCY,TBLEG(1..NBLEG)))
       [F:DADW] = [F:ADW]
       Write [DADW]
       If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,1) From DOSDIC : Endif
      Endif
     Else : # Mono-législation
      If [F:ADW]CMP="*"
       If [F:ADW]FCY=[F:ADS]DOSLEG(0)
        Read [DADW]ADW0 = "";"";[F:ADW]PARAM
        If fstat
         [F:DADW] = [F:ADW]
         [F:DADW]CMP = ""
         [F:DADW]FCY = ""
         Write [DADW]
         If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
        Else
         [F:DADW] = [F:ADW]
         [F:DADW]CMP = ""
         [F:DADW]FCY = ""
         Rewrite [DADW]
         If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,2) From DOSDIC : Endif
        Endif
       Endif
      Else
       Read [DADW]ADW0 = [F:ADW]CMP;[F:ADW]FCY;[F:ADW]PARAM
       If fstat
        [F:DADW] = [F:ADW]
        Write [DADW]
        If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM-[F:DADW]CMP-[F:DADW]FCY,1) From DOSDIC : Endif
       Endif
      Endif
     Endif
    Endif
   Next ADW
  Else
   # Pas de copie des paramètres sociétés + sites
   For [ADW]ADW0 Where CMP="" & FCY="" & find(PARAM,"DOSLEG","ADEMO")=0
    Read [DADP]ADP1 = [F:ADW]PARAM
    If !fstat
     [F:DADW] = [F:ADW]
     Write [DADW]
     If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
    Endif
   Next ADW
   #X3-59961 - JOBRO - 9/21/2018
   If !OKLEG  #Single legislation
     #Copy from the copy folder the parameters for the single legislation
     For [ADW]ADW0 Where CMP="*" & FCY=[F:ADS]DOSLEG(0) & find(PARAM,"DOSLEG","ADEMO")=0
       Read [DADP]ADP1 = [F:ADW]PARAM
       If !fstat
         Read [F:DADW]ADW0="";"";[F:ADW]PARAM
         If fstat=0
            [F:DADW] = [F:ADW]
            Raz [F:DADW]FCY
            Raz [F:DADW]CMP
            Rewrite [F:DADW]
            If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,2) From DOSDIC : Endif
          Else
            [F:DADW] = [F:ADW]
            Raz [F:DADW]FCY
            Raz [F:DADW]CMP
            Write [F:DADW]
            If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
          Endif
        Endif
      Next
    Endif
    #X3-59961
  Endif
  # Copie des paramètres utilisateurs
  If [F:ADS]OPTINI(0)=2
   For [ADU]ADU0
    Read [DADP]ADP1 = [F:ADU]PARAM
    If !fstat
     [F:DADU] = [F:ADU]
     Write [DADU]
     If fstat : Call ERREUR("ADOVALAUS"-[F:DADU]PARAM-[F:DADU]CODUSR,1) From DOSDIC : Endif
    Endif
   Next ADU
  Endif
  # Issue 86047 - 2012-11-20 by VPO : ADOVALGRP passe en TYPFIC=4 Dictionnaire
  # il faut gérer la copie selon copie de données pour Paramètres [ADS]OPTINI(3)
  # Copie des paramètres
  If [F:ADS]OPTINI(3)=2
   For [ADG]ADG0
    Read [DADP]ADP1 = [F:ADG]PARAM
    If !fstat
     [F:DADG] = [F:ADG]
     Write [DADG]
     If fstat : Call ERREUR("ADOVALGRP"-[F:DADG]PARAM-[F:DADG]GRPPAR-[F:DADG]GRPDEF,1) From DOSDIC : Endif
    Endif
   Next ADG
  Endif
 Else
  # Mise à jour (GCRE=0)
  For [DADP]ADP0 Where PARAM<>"DOSLEG"
   Read [DADW]ADW0 = "";"";[F:DADP]PARAM
   If fstat
    If !OKLEG
     # Si le dossier validé est en mono-législation,
     # On copie la valeur de la législation du dossier validé dans la valeur dossier
     Read [ADW]ADW0 = "*";[F:ADS]DOSLEG(0);[F:DADP]PARAM
     If !fstat
      [F:DADW] = [F:ADW]
      [F:DADW]CMP = ""
      [F:DADW]FCY = ""
      Write [DADW]
      If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
     Else
      Read [ADW]ADW0 = "";"";[F:DADP]PARAM
      If !fstat
       [F:DADW] = [F:ADW]
       Write [DADW]
       If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
      Endif
     Endif
    Else
     # Sinon on copie les valeurs des nouvelles législations
     For I=0 To [F:ADS]NBLEG
      If !find([F:ADS]DOSLEG(I),TBLEG(1..NBLEG))
       Read [DADW]ADW0 = "*";[F:ADS]DOSLEG(I);[F:DADP]PARAM
       If fstat
        Read [ADW]ADW0 = "*";[F:ADS]DOSLEG(I);[F:DADP]PARAM
        If !fstat
         [F:DADW] = [F:ADW]
         Write [DADW]
         If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
        Endif
       Endif
      Endif
     Next I
     # Et la valeur dossier
     Read [ADW]ADW0 = "";"";[F:DADP]PARAM
     If !fstat
      [F:DADW] = [F:ADW]
      Write [DADW]
      If fstat : Call ERREUR("ADOVAL"-[F:DADW]PARAM,1) From DOSDIC : Endif
     Endif
    Endif
   Endif
  Next DADP
  # ccl bug 67755 Passage Mono lég à Multi lég avec ou pas l'ajout d'une lég
  If MODLEG : # On est passé en multi-législation ou on revient en mono
   If OKLEG : # On est passé en multi
    For [ADP] Where NIVDEF=5
     # Il faut copier les valeurs dossiers des paramètres niveau lég dans la lég courante
     Read [DADW]ADW0="";"";[F:ADP]PARAM
     If !fstat
      Read [DAW2]ADW0="*";TBLEG(1);[F:ADP]PARAM
      If !fstat
       [F:DAW2] = [F:DADW]
       [F:DAW2]CMP = "*"
       [F:DAW2]FCY = TBLEG(1)
       Rewrite [DAW2]
       If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
      Else
       [F:DAW2] = [F:DADW]
       [F:DAW2]CMP = "*"
       [F:DAW2]FCY = TBLEG(1)
       Write [DAW2]
       If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
      Endif
     Endif
     # Et recopier les valeurs dossiers du dossier de référence
     Read [ADW]ADW0="";"";[F:ADP]PARAM
     If !fstat
      Read [DAW2]ADW0="";"";[F:ADP]PARAM
      If !fstat
       [F:DAW2] = [F:ADW]
       [F:DAW2]CMP = ""
       [F:DAW2]FCY = ""
       Rewrite [DAW2]
       If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
      Else
       [F:DAW2] = [F:ADW]
       [F:DAW2]CMP = ""
       [F:DAW2]FCY = ""
       Write [DAW2]
       If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
      Endif
     Endif
    Next ADP
   Else : # On est passé en mono
    # Il faut copier toutes les valeurs législations dans la valeur dossier
    For [DADW] Where CMP="*"
     Read [DAW2]ADW0="";"";[F:DADW]PARAM
     If !fstat
      [F:DAW2] = [F:DADW]
      [F:DAW2]CMP = ""
      [F:DAW2]FCY = ""
      Rewrite [DAW2]
      If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
     Else
      [F:DAW2] = [F:DADW]
      [F:DAW2]CMP = ""
      [F:DAW2]FCY = ""
      Write [DAW2]
      If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
     Endif
     Delete [DAW2] Where CMP="*" & PARAM=[F:DADW]PARAM
     If fstat=1 : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,3) From DOSDIC : Endif
    Next DADW
   Endif
  Endif
  # Fin 67755
 Endif
 For [DADW]ADW0 Where PARAM<>"ADEMO"
  Read [DADP]ADP1 = [F:DADW]PARAM
  If fstat
   Delete [DADW]
   If fstat=1 : Call ERREUR("ADOVAL"-[F:DADW]PARAM,3) From DOSDIC : Endif
  Endif
 Next DADW
 For [DADU]ADU0
  Read [DADP]ADP1 = [F:DADU]PARAM
  If fstat
   Delete [DADU]
   If fstat=1 : Call ERREUR("ADOVALAUS"-[F:DADU]PARAM,3) From DOSDIC : Endif
  Endif
 Next DADU
 # Issue 85493 - 2012-10-29 by VPO : supp ADOVALGRP si supp ADOVAL
 For [DADG]ADG0
  Read [DADP]ADP1 = [F:DADG]PARAM
  If fstat
   Delete [DADG]
   If fstat=1 : Call ERREUR("ADOVALGRP"-[F:DADG]PARAM,3) From DOSDIC : Endif
  Endif
 Next DADG
 If !GCRE & !OKLEG
  Delete [DADW] Where CMP="*"
 Endif
 If GCRE
  Delete [DADW] Where PARAM="HISDOS"
 Endif
Commit
Close Local File [ADP], [ADW], [ADG], [DADP], [DAD2], [DADW], [ADU], [DADU] , [DAW2], [DADG]
Return

###############################################################
## Tables diverses
###############################################################
$DICDIV
If func APRODUCT.AGETRELEASESUP()>="17v.132" : Return : Endif

# Remplissage du dico des tables diverses
Call ECR_TIME(mess(15,125,1)-mess(75,125,1)) From DOSSUB
# MAJ dictionnaire - Tables diverses

Local File =[F:ADS]DOSREF +".ATABTAB" [ADV]
Local File =[F:ADS]DOSCOP +".ATABDIV" [ADI]

Local File =[F:ADS]DOSSIER+".ATABTAB" [DADV]
Local File =[F:ADS]DOSSIER+".ATABDIV" [DADI]
If !GCRE
 Local File =[F:ADS]DOSSIER+".ATEXTRA" [DAXX]
 Local File =[F:ADS]DOSCOP +".ATEXTRA" [CAXX]
 Local File =[F:ADS]DOSREF +".ATEXTRA" [RAXX]
Endif

Local Integer STA1 , STA2
Local Integer DIFFA(0..dim([F:ADV]COLALPTYP)-1)
Local Integer DIFFN(0..dim([F:ADV]COLNUMTYP)-1)

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(75,125,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DADV]
  For [DADV]
   Call SPEC([F:DADV]CODACT,SPEC) From DOSSUB
   If !SPEC and (GADONIX<>2 or pat([F:ADS]DOSSIER,"*REFSTD*")=0)
    Read [ADV]CODE = [F:DADV]NUMTAB
    If fstat
     Delete [DAXX] Where find(CODFIC,"ATABDIV","ATABTAB")<>0 & IDENT1=num$([F:DADV]NUMTAB)
     If fstat=1 : Call ERREUR("ATEXTRA"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
     Delete [DADI] Where NUMTAB=[F:DADV]NUMTAB
     If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
     Delete [DADV]
     If fstat=1 : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif

For [ADV] Where FLGLEG<>2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(75,125,1),num$([F:ADV]NUMTAB)) From GESECRAN
 Endif
 Trbegin [DADV]
  OLD = 0
  SPEC = 0
  Read [DADV]CODE = [F:ADV]NUMTAB
  If !fstat
   OLD = 1
   Call SPEC([F:DADV]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ADV]CODACT,[F:ADV]MODULE,NEWREC) From DOSSUB
  If !NEWREC and GADONIX=2 and pat([F:ADS]DOSSIER,"*REFSTD*")<>0 : NEWREC = 1 : Endif
  If !SPEC

   If OLD & !NEWREC : # On le vire

    If !GCRE
     Delete [DAXX] Where find(CODFIC,"ATABDIV","ATABTAB")<>0 & IDENT1=num$([F:ADV]NUMTAB)
     If fstat=1 : Call ERREUR("ATEXTRA"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
    Endif
    Delete [DADI] Where NUMTAB=[F:ADV]NUMTAB
    If fstat=1 : Call ERREUR("ATABDIV"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif
    Delete [DADV] Where NUMTAB=[F:ADV]NUMTAB
    If fstat=1 : Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif

   Elsif NEWREC & !OLD

    Raz [F:DADV]
    [F:DADV] = [F:ADV]
    If !GCRE
     Call COPTEXREF("ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"")
     Call COPTEXREF("ATABTAB","SHODES",num$([F:ADV]NUMTAB),"")

     #Exigence 53267
     For K=0 To dim([F:ADV]COLALPTYP)-1
      Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K))
     Next

     For K=0 To dim([F:ADV]COLNUMTYP)-1
      Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K))
     Next

    Endif
    Write [DADV]
    If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),1) From DOSDIC : Endif

    Delete [DADI] Where NUMTAB=[F:ADV]NUMTAB : # bug 75977 suite residu migration V5
    If fstat=1 : Call ERREUR("ATABDIV"-num$([F:ADV]NUMTAB),3) From DOSDIC : Endif

    For [ADI]CODE Where NUMTAB=[F:ADV]NUMTAB
     [F:DADI] = [F:ADI]
     If !GCRE
      Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADV]NUMTAB),[F:ADI]CODE)
      Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADV]NUMTAB),[F:ADI]CODE)
     Endif
     Write [DADI]
     If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB)-[F:ADI]CODE,1) From DOSDIC : Endif
    Next ADI

   Elsif NEWREC & OLD

    Raz DIFFA, DIFFN

    For K=0 To dim([F:ADV]COLALPTYP)-1
     Read [RAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:RAXX]TEXTE=""
      STA1 = 0
     Else
      STA1 = 1
     Endif
     Read [DAXX]AXX0 = "ATABTAB";"COLALPDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:DAXX]TEXTE=""
      STA2 = 0
     Else
      STA2 = 1
     Endif
     If STA1=0 & STA2<>0
      DIFFA(K) = -1
      Delete [DAXX]
      If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLALPDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
     Elsif STA1<>0 & STA2=0
      DIFFA(K) =  1
      Call COPTEXREF("ATABTAB","COLALPDES",num$([F:ADV]NUMTAB),num$(K))
     Endif
     [F:DADV]COLALPTYP(K)     = [F:ADV]COLALPTYP(K)
     [F:DADV]COLALPSUP(K)     = [F:ADV]COLALPSUP(K)
    Next K

    For K=0 To dim([F:ADV]COLNUMTYP)-1
     Read [RAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:RAXX]TEXTE=""
      STA1 = 0
     Else
      STA1 = 1
     Endif
     Read [DAXX]AXX0 = "ATABTAB";"COLNUMDES";GLANGUE;num$([F:ADV]NUMTAB);num$(K)
     If fstat or [F:DAXX]TEXTE=""
      STA2 = 0
     Else
      STA2 = 1
     Endif
     If STA1=0 & STA2<>0
      DIFFN(K) = -1
      Delete [DAXX]
      If fstat : Call ERREUR("ATEXTRA"-"ATABTAB"-"COLNUMDES"-num$([F:DADV]NUMTAB)-num$(K),3) From DOSDIC : Endif
     Elsif STA1<>0 & STA2=0
      DIFFN(K) =  1
      Call COPTEXREF("ATABTAB","COLNUMDES",num$([F:ADV]NUMTAB),num$(K))
     Endif
     [F:DADV]COLNUMTYP(K)     = [F:ADV]COLNUMTYP(K)
     [F:DADV]COLNUMSUP(K)     = [F:ADV]COLNUMSUP(K)
    Next K

    [F:DADV]CODACT  = [F:ADV]CODACT
    [F:DADV]UPDFLG  = [F:ADV]UPDFLG
    [F:DADV]LNGFLG  = [F:ADV]LNGFLG
    If [F:ADV]LNGFLG<>2 or [F:DADV]LNG=0
     [F:DADV]LNG = [F:ADV]LNG
    Endif
    [F:DADV]MODULE = [F:ADV]MODULE
    [F:DADV]FLGLEG = [F:ADV]FLGLEG
    [F:DADV]FLGSOC = [F:ADV]FLGSOC
    Rewrite [DADV]
    If fstat : Call ERREUR("ATABTAB"-num$([F:DADV]NUMTAB),2) From DOSDIC : Endif

    For [DADI]CODE Where NUMTAB=[F:ADV]NUMTAB
     Read [ADI]CODE = [F:DADI]NUMTAB ; [F:DADI]CODE

     For K=1 To dim([F:ADV]COLALPTYP)
      If    DIFFA(K-1)>0
       If !fstat
        Assign "[F:DADI]A"+num$(K) With evalue("[F:ADI]A"+num$(K))
       Else
        Assign "[F:DADI]A"+num$(K) With ""
       Endif
      Elsif DIFFA(K-1)<0
       Assign "[F:DADI]A"+num$(K) With ""
      Endif
     Next

     For K=1 To dim([F:ADV]COLNUMTYP)
      If    DIFFN(K-1)>0
       If !fstat
        Assign "[F:DADI]N"+num$(K) With evalue("[F:ADI]N"+num$(K))
       Else
        Assign "[F:DADI]N"+num$(K) With 0
       Endif
      Elsif DIFFN(K-1)<0
       Assign "[F:DADI]N"+num$(K) With 0
      Endif
     Next

     Rewrite [DADI]
     If fstat : Call ERREUR("ATABDIV"-num$([F:DADV]NUMTAB-[F:DADI]CODE),2) From DOSDIC : Endif
    Next
   Endif
  Endif
 Commit
Next

## Recopie du contenu des tables 901..999 (superviseur)

Trbegin [DADI]
 For [DADV] Where NUMTAB>900 & NUMTAB<1000
  For [DADI] Where NUMTAB=[F:DADV]NUMTAB & CODE<"X"
   Read [ADI]CODE = [F:DADI]NUMTAB ; [F:DADI]CODE
   If fstat
    If !GCRE
     Delete [DAXX] Where CODFIC="ATABDIV" & IDENT1=num$([F:DADI]NUMTAB) & IDENT2=[F:DADI]CODE
     If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,3) From DOSDIC : Endif
    Endif
    Delete [DADI]
    If fstat=1 : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,3) From DOSDIC : Endif
   Endif
  Next DADI
 Next DADV
 For [ADV] Where NUMTAB>900 & NUMTAB<1000 & FLGLEG<>2
  Call NEWREC([F:ADS]DOSSIER,[F:ADV]CODACT,[F:ADV]MODULE,NEWREC) From DOSSUB
  If NEWREC or (GADONIX=2 and pat([F:ADS]DOSSIER,"*REFSTD*")<>0)
   For [ADI] Where NUMTAB=[F:ADV]NUMTAB & CODE<GXX
    Read [DADI]CODE = [F:ADI]NUMTAB ; [F:ADI]CODE
    If fstat
     [F:DADI] = [F:ADI]
     If !GCRE
      Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE)
      Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADI]NUMTAB),[F:ADI]CODE)
     Endif
     Write [DADI]
     If fstat : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,1) From DOSDIC : Endif
    Else
     [F:DADI] = [F:ADI]
     If !GCRE
      Call COPTEXTRA("ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE)
      Call COPTEXTRA("ATABDIV","SHODES",num$([F:ADI]NUMTAB),[F:ADI]CODE)
     Endif
     Rewrite [DADI]
     If fstat : Call ERREUR("ATABDIV"-num$([F:DADI]NUMTAB)-[F:DADI]CODE,2) From DOSDIC : Endif
    Endif
   Next ADI
  Endif
 Next ADV
Commit
Close Local File [ADV] , [DADV]
Close Local File [ADI] , [DADI]
If !GCRE
 Close Local File [DAXX] , [CAXX] , [RAXX]
Endif

Return

Subprog COPTEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2
For [CAXX] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:DAXX]AXX0 = TABLE;CHAMP;[F:CAXX]LANGUE;CLE1;CLE2
 If !fstat
  [F:DAXX]TEXTE = [F:CAXX]TEXTE
  If dim([F:DAXX]UPDDAT)>0 : [F:DAXX]UPDDAT = date$  : Endif
  If dim([F:DAXX]UPDUSR)>0 : [F:DAXX]UPDUSR = GUSER  : Endif
  Rewrite [DAXX]
  If fstat
   GOK=0 : Call FSTA("DAXX") From GLOCK : Break
  Endif
 Else
  [F:DAXX] = [F:CAXX]
  If dim([F:DAXX]CREDAT)>0 : [F:DAXX]CREDAT = date$ : Endif
  If dim([F:DAXX]CREUSR)>0 : [F:DAXX]CREUSR = GUSER : Endif
  If dim([F:DAXX]UPDDAT)>0 : [F:DAXX]UPDDAT = [0/0/0] : Endif
  If dim([F:DAXX]UPDUSR)>0 : [F:DAXX]UPDUSR = "" : Endif
  Write [DAXX]
  If fstat
   GOK=0 : Call FSTA("DAXX") From GLOCK : Break
  Endif
 Endif
Next
End

Subprog COPTEXREF(TABLE,CHAMP, CLE1,CLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2
For [RAXX] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:DAXX]AXX0 = TABLE;CHAMP;[F:RAXX]LANGUE;CLE1;CLE2
 If !fstat
  [F:DAXX]TEXTE = [F:RAXX]TEXTE
  If dim([F:DAXX]UPDDAT)>0 : [F:DAXX]UPDDAT = date$  : Endif
  If dim([F:DAXX]UPDUSR)>0 : [F:DAXX]UPDUSR = GUSER  : Endif
  Rewrite [DAXX]
  If fstat
   GOK=0 : Call FSTA("DAXX") From GLOCK : Break
  Endif
 Else
  [F:DAXX] = [F:RAXX]
  If dim([F:DAXX]CREDAT)>0 : [F:DAXX]CREDAT = date$ : Endif
  If dim([F:DAXX]CREUSR)>0 : [F:DAXX]CREUSR = GUSER : Endif
  If dim([F:DAXX]UPDDAT)>0 : [F:DAXX]UPDDAT = [0/0/0] : Endif
  If dim([F:DAXX]UPDUSR)>0 : [F:DAXX]UPDUSR = "" : Endif
  Write [DAXX]
  If fstat
   GOK=0 : Call FSTA("DAXX") From GLOCK : Break
  Endif
 Endif
Next
End

#####################################################
## Types de données
#####################################################
$DICTYP
# Remplissage du dico des types
#Call COPIE_DIC("ATYPE","CODTYP",1,mess(19,125,1))
Gosub DICATY From DOSDICATY

# Vérifications
Call ECR_TIME(mess(57,123,1)-"1"-mess(19,125,1)) From DOSSUB
# Vérifications 1 - Types de données
Local File =GDOSREF+".ATYPE"          [ATY]
Local File =[F:ADS]DOSSIER+".ATYPE"   [DATY]
Local File =[F:ADS]DOSSIER+".AOBJET"  [DAOB]
Local File =[F:ADS]DOSSIER+".ATABZON" [DATZ]
Local File =[F:ADS]DOSSIER+".ATABLE"  [DATB]
Local File =[F:ADS]DOSSIER+".ACTION"  [DACT]
Local File =[F:ADS]DOSSIER+".AMSKZON" [DAMZ]
Local File =[F:ADS]DOSSIER+".AMSK"    [DAMK]
Local File =[F:ADS]DOSSIER+".ATYPERUL"    [DATYR]
Local File =[F:ADS]DOSSIER+".ATYPERPAR"    [DATYRP]
Trbegin [DATY]
 For [DATY]CODTYP
  RW = 0
  # On vire les liens si l'objet associé au type n'existe pas
  If [F:DATY]OBJLIEN<>""
   Read [DAOB]ABREV = [F:DATY]OBJLIEN
   If fstat
    [F:DATY]OBJLIEN = ""
    [F:DATY]FICLIEN = ""
    RW = 1
    For [DATZ]CODTYP Where CODTYP=[F:DATY]CODTYP
     Read [DATB]CODFIC=[F:DATZ]LIEN : # mb 16.6.8
     If fstat
      [F:DATZ]LIEN = ""
      [F:DATZ]EXPLIEN = ""
      Rewrite [DATZ]
      If fstat : Call ERREUR("ATABZON"-[F:DATZ]CODFIC,2) From DOSDIC : Endif
     Endif
    Next
   Endif
  Endif
  #
  # On vire les actions qui n'existent pas
  I = 0
  While I<=[F:DATY]NBTYP-1
   Read [DACT]ACTION = [F:DATY]ACTION(I)
   If fstat
    Dela I,1,[F:DATY]NBTYP [F:DATY]ACTION,[F:DATY]ACTTYP,[F:DATY]EXEACT
    [F:DATY]NBTYP -= 1
    RW = 1
   Else
    I += 1
   Endif
  Wend
  #
  If RW
   Rewrite [DATY]
   If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif
  Endif
 Next
# Blobs
 Read [DATY]CODTYP = "ABB"
 If !fstat & ([F:DATY]LNGTYP=0 or [F:DATY]LNGTYP<>[F:ADS]BLBLNG)
  [F:DATY]LNGTYP = [F:ADS]BLBLNG
  If [F:DATY]LNGTYP=0 : [F:DATY]LNGTYP = 9 : Endif
  Rewrite [DATY]
  If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif
  For [DAMZ]CODTYP Where CODTYP="ABB"
   Read [DAMK]CODMSK=[F:DAMZ]CODMSK
   If !fstat
    [F:DAMK]UPDFLG = 1
    [F:DAMK]UPDDAT = date$
    If dim([F:DAMK]UPDTIM)>0 : [F:DAMK]UPDTIM = time : Endif
    [F:DAMK]UPDUSR = GUSER
    If [F:DAMK]MDL<>2 : GNBMSK += 1 : Endif
    Rewrite [DAMK]
    If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,2) From DOSDIC : Endif
   Endif
  Next DAMZ
  For [DATZ]CODTYP Where CODTYP="ABB"
   Read [DATB]CODFIC=[F:DATZ]CODFIC
   If !fstat
    [F:DATB]UPDFLG = 1
    [F:DATB]UPDDAT = date$
    If dim([F:DATB]UPDTIM)>0 : [F:DATB]UPDTIM = time : Endif
    [F:DATB]UPDUSR = GUSER
    If [F:DATB]TYPFIC<3 : GNBTBL += 1 : Endif
    Rewrite [DATB]
    If fstat : Call ERREUR("ATABLE"-[F:DATB]CODFIC,2) From DOSDIC : Endif
   Endif
  Next DATZ
 Endif
# Clobs
 Read [DATY]CODTYP = "ACB"
 If !fstat & ([F:DATY]LNGTYP=0 or [F:DATY]LNGTYP<>[F:ADS]CLBLNG)
  [F:DATY]LNGTYP = [F:ADS]CLBLNG
  If [F:DATY]LNGTYP=0 : [F:DATY]LNGTYP = 6 : Endif
  Rewrite [DATY]
  If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif
  For [DAMZ]CODTYP Where CODTYP="ACB"
   Read [DAMK]CODMSK=[F:DAMZ]CODMSK
   If !fstat
    [F:DAMK]UPDFLG = 1
    [F:DAMK]UPDDAT = date$
    If dim([F:DAMK]UPDTIM)>0 : [F:DAMK]UPDTIM = time : Endif
    [F:DAMK]UPDUSR = GUSER
    If [F:DAMK]MDL<>2 : GNBMSK += 1 : Endif
    Rewrite [DAMK]
    If fstat : Call ERREUR("AMSK"-[F:DAMK]CODMSK,2) From DOSDIC : Endif
   Endif
  Next DAMZ
  For [DATZ]CODTYP Where CODTYP="ACB"
   Read [DATB]CODFIC=[F:DATZ]CODFIC
   If !fstat
    [F:DATB]UPDFLG = 1
    [F:DATB]UPDDAT = date$
    If dim([F:DATB]UPDTIM)>0 : [F:DATB]UPDTIM = time : Endif
    [F:DATB]UPDUSR = GUSER
    If [F:DATB]TYPFIC<3 : GNBTBL += 1 : Endif
    Rewrite [DATB]
    If fstat : Call ERREUR("ATABLE"-[F:DATB]CODFIC,2) From DOSDIC : Endif
   Endif
  Next DATZ
 Endif
 # Si le type de données sur un champ avec code activité inactif n'existe pas, on le remplace par un type de données générique
 For [DAMZ] Where CODTYP<>"" & CODACT<>""
  Call NEWREC([F:ADS]DOSSIER,[F:DAMZ]CODACT,0,K) From DOSSUB
  If !K
   Read [DATY]CODTYP=[F:DAMZ]CODTYP
   If fstat
    Read [ATY]CODTYP=[F:DAMZ]CODTYP
    If !fstat
     Call CHANGE_CODTYP(0,[F:ATY]TYPTYP,[F:DAMZ]CODTYP,[F:DAMZ]LONG) From DOSDICDIV
    Else
     [F:DAMZ]CODTYP  = "A"
    Endif
    [F:DAMZ]LONG = 1
    [F:DAMZ]DIME = 1
    Rewrite [DAMZ]
    If fstat : Call ERREUR("AMASKZON"-[F:DAMZ]CODMSK-[F:DAMZ]CODZON,2) From DOSDIC : Endif
   Endif
  Endif
 Next DAMZ

Commit
Close Local File [ATY] , [DATY] , [DAOB] , [DATZ] , [DATB] , [DACT] , [DAMZ] , [DAMK]  , [DATYR] , [DATYRP]
Return

#####################################################
## Types de données
#####################################################
$DICTYPACLA

Call ECR_TIME(mess(57,123,1)-"2"-mess(19,125,1)) From DOSSUB
# Vérifications 2 - Types de données
Local File =GDOSREF+".ATYPE"          [ATY]
Local File =[F:ADS]DOSSIER+".ATYPE"   [DATY]
Local File =[F:ADS]DOSSIER+".ACLASSE"   [DACLA]
Local File =[F:ADS]DOSSIER+".ATYPERUL"  [DATYR]

Local File =[F:ADS]DOSSIER+".ATYPERPAR" [DATYRP]
Local File =[F:ADS]DOSSIER+".ASHW"      [DASW]

Trbegin [DATY]
 For [DATY]CODTYP
  RW = 0
  # On vire la classe si cette derniere existe pas.
  If [F:DATY]CODCLA<>""
   Read [DACLA]ACLA0 = [F:DATY]CODCLA
   If fstat
    [F:DATY]CODCLA = ""
    [F:DATY]TYPSELSYR = 1
    RW = 1
    Delete [DATYR] Where CODTYP=[F:DATY]CODTYP & PRGRUL=[V]CST_ANAMCTLREF
    If fstat=1 : Call ERREUR("ATYPERUL"-[F:DATY]CODTYP-[V]CST_ANAMCTLREF,3) From DOSDIC : Endif
    Delete [DATYRP] Where CODTYP=[F:DATY]CODTYP & PRGRUL=[V]CST_ANAMCTLREF
    If fstat=1 : Call ERREUR("ATYPERPAR"-[F:DATY]CODTYP-[V]CST_ANAMCTLREF,3) From DOSDIC : Endif
   Endif
  Endif
  #
  # On vire la rep desktop si cette derniere existe pas.
  If [F:DATY]DEFREPDES<>""
   Read [DASW]ASW0 = [F:DATY]DEFREPDES
   If fstat
    [F:DATY]DEFREPDES = ""
    RW = 1
   Endif
  Endif
  #
  # On vire la rep desktop si cette derniere existe pas.
  If [F:DATY]DEFREPDES<>""
   Read [DASW]ASW0 = [F:DATY]DEFREPDES
   If fstat
    [F:DATY]DEFREPDES = ""
    RW = 1
   Endif
  Endif
  #
  # On vire la rep tablette si cette derniere existe pas.
  If [F:DATY]DEFREPTAB<>""
   Read [DASW]ASW0 = [F:DATY]DEFREPTAB
   If fstat
    [F:DATY]DEFREPTAB = ""
    RW = 1
   Endif
  Endif
  #
  # On vire la rep mobile si cette derniere existe pas.
  If [F:DATY]DEFREPMOB<>""
   Read [DASW]ASW0 = [F:DATY]DEFREPMOB
   If fstat
    [F:DATY]DEFREPMOB = ""
    RW = 1
   Endif
  Endif
  #
  If RW
   Rewrite [DATY]
   If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif
  Endif
 Next

Commit
Close Local File [ATY] , [DATY] , [DACLA] , [DATYR] , [DATYRP] , [DASW]
Return

#####################################################
## Consultations
#####################################################
$DICCNS
# Remplissage du dico des consultations
Call ECR_TIME(mess(15,125,1)-mess(88,125,1)) From DOSSUB
# MAJ dictionnaire - Consultations
Local File =GDOSREF+".ACONSULT" [ACN]
Local File =[F:ADS]DOSSIER+".ACONSULT"  [DACN]
Local File =[F:ADS]DOSSIER+".ACONSULT"  [DAC2]
Local File =[F:ADS]DOSSIER+".ACTIV"     [DACV]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(88,125,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DACN]
  For [DACN] Where COD<GXX
   Call SPEC([F:DACN]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ACN]ACN0 = [F:DACN]COD
    If fstat
     Call ECR_TRACE(mess(99,125,1)-[F:DACN]COD,0) From GESECRAN
     Call SUPP_TRT("WWCNS"+[F:DACN]COD) From DOSSUB
     Delete [DACN]
     If fstat=1 : Call ERREUR("ACONSULT"-[F:DACN]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif
GNBCNS = 0
For [ACN] Where COD<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(88,125,1),[F:ACN]COD) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DACN]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DACN]ACN0 = [F:ACN]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DACN]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ACN]CODACT,[F:ACN]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Call ECR_TRACE(mess(99,125,1)-[F:ACN]COD,0) From GESECRAN
    Call SUPP_TRT("WWCNS"+[F:DACN]COD) From DOSSUB
    Delete [DACN] Where COD=[F:ACN]COD
    If fstat=1 : Call ERREUR("ACONSULT"-[F:ACN]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    GNBCNS += 1
    RWO = 1
    Raz [F:DACN]
    [F:DACN] = [F:ACN]
    If dim([F:DACN]CREDAT)>0 : [F:DACN]CREDAT = date$ : Endif
    If dim([F:DACN]CREUSR)>0 : [F:DACN]CREUSR = GUSER : Endif
    If dim([F:DACN]CRETIM)>0 : [F:DACN]CRETIM = time : Endif
    If dim([F:DACN]UPDFLG)>0 : [F:DACN]UPDFLG = 1 : Endif
    Write [DACN]
    If fstat : Call ERREUR("ACONSULT"-[F:DACN]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    [F:DAC2] = [F:DACN]
    DIFF = 0
    If [F:ACN]CODACT    <> [F:DACN]CODACT     : DIFF = 1  : Endif
    If [F:ACN]LIBEL     <> [F:DACN]LIBEL      : DIFF = 2  : Endif
    If [F:ACN]MODULE    <> [F:DACN]MODULE     : DIFF = 3  : Endif
    If [F:ACN]WND0      <> [F:DACN]WND0       : DIFF = 4  : Endif
    If [F:ACN]WND1      <> [F:DACN]WND1       : DIFF = 5  : Endif
    If [F:ACN]SCRCOD    <> [F:DACN]SCRCOD     : DIFF = 6  : Endif
    If [F:ACN]PRGSTD    <> [F:DACN]PRGSTD     : DIFF = 7  : Endif
    If [F:ACN]OBJET     <> [F:DACN]OBJET      : DIFF = 8  : Endif
    If [F:ACN]FILNAM    <> [F:DACN]FILNAM     : DIFF = 9  : Endif
    If [F:ACN]FILABB    <> [F:DACN]FILABB     : DIFF = 10 : Endif
    If [F:ACN]FILKEY    <> [F:DACN]FILKEY     : DIFF = 11 : Endif
    If [F:ACN]NBRCRI    <> [F:DACN]NBRCRI     : DIFF = 12 : Endif
    If !DIFF
     For B=0 To [F:ACN]NBRCRI-1
      If [F:ACN]FLD0(B)    <> [F:DACN]FLD0(B)     : DIFF = 13  : Endif
      If [F:ACN]FLD1(B)    <> [F:DACN]FLD1(B)     : DIFF = 14  : Endif
      If [F:ACN]DSYCRI(B)  <> [F:DACN]DSYCRI(B)   : DIFF = 15  : Endif
     Next B
    Endif
    If [F:ACN]NBRFIL    <> [F:DACN]NBRFIL     : DIFF = 16  : Endif
    If !DIFF
     For B=0 To [F:ACN]NBRFIL-1
      If [F:ACN]FILOPN(B)    <> [F:DACN]FILOPN(B)   : DIFF = 17  : Endif
     Next B
    Endif
    If !DIFF
     For B=0 To dim([F:ACN]FLCND)-1
      If [F:ACN]FILCND(B)  <> [F:DACN]FILCND(B)  : DIFF = 18  : Endif
     Next B
    Endif
    If [F:ACN]NBRCPNKEY <> [F:DACN]NBRCPNKEY  : DIFF = 19  : Endif
    If !DIFF
     For B=0 To [F:ACN]NBRCPNKEY-1
      If [F:ACN]CPNKEY(B) <> [F:DACN]CPNKEY(B) : DIFF = 20  : Endif
      If [F:ACN]CPNSCR(B) <> [F:DACN]CPNSCR(B) : DIFF = 21  : Endif
     Next B
    Endif
    If !DIFF : Call TXT([F:ACN]LIBEL,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff consult"-[F:ACN]COD-num$(DIFF),0) From GESECRAN
     Endif
     GNBCNS += 1
     RWO = 1
     [F:DACN] = [F:ACN]
     [F:DACN]PRGSPE = [F:DAC2]PRGSPE
     If dim([F:DACN]UPDDAT)>0 : [F:DACN]UPDDAT = date$ : Endif
     If dim([F:DACN]UPDUSR)>0 : [F:DACN]UPDUSR = GUSER : Endif
     If dim([F:DACN]UPDTIM)>0 : [F:DACN]UPDTIM = time : Endif
     If dim([F:DACN]UPDFLG)>0 : [F:DACN]UPDFLG = 1 : Endif
     Rewrite [DACN]
    Endif
    If fstat : Call ERREUR("ACONSULT"-[F:DACN]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [ACN] , [DACN] , [DAC2] , [DACV]
Return

#####################################################
## Navigations
#####################################################
$DICNAV
# Remplissage du dico des navigations
Call ECR_TIME(mess(15,125,1)-mess(101,125,1)) From DOSSUB
# MAJ dictionnaire - Navigations
Local File =GDOSREF+".ANAVIG"  [ANG]
Local File =GDOSREF+".ANAVFIL" [ANH]
Local File =GDOSREF+".ANAVCRE" [ANI]
Local File =[F:ADS]DOSSIER+".ANAVIG"  [DANG]
Local File =[F:ADS]DOSSIER+".ANAVFIL" [DANH]
Local File =[F:ADS]DOSSIER+".ANAVCRE" [DANI]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(101,125,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DANG]
  For [DANG]ANG0 Where COD<GXX
   Call SPEC([F:DANG]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ANG]ANG0 = [F:DANG]COD
    If fstat
     Call ECR_TRACE(mess(102,125,1)-[F:DANG]COD,0) From GESECRAN
     Delete [DANH] Where COD=[F:DANG]COD
     If fstat=1 : Call ERREUR("ANAVFIL"-[F:DANG]COD,3) From DOSDIC : Endif
     Delete [DANI] Where COD=[F:DANG]COD
     If fstat=1 : Call ERREUR("ANAVCRE"-[F:DANG]COD,3) From DOSDIC : Endif
     Delete [DANG]
     If fstat=1 : Call ERREUR("ANAVIG"-[F:DANG]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif
For [ANG] Where COD<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(101,125,1),[F:ANG]COD) From GESECRAN
 Endif
 Trbegin [DANG]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DANG]ANG0 = [F:ANG]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DANG]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ANG]CODACT,[F:ANG]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Call ECR_TRACE(mess(101,125,1)-[F:ANG]COD,0) From GESECRAN
    Delete [DANH] Where COD=[F:ANG]COD
    If fstat=1 : Call ERREUR("ANAVFIL"-[F:ANG]COD,3) From DOSDIC : Endif
    Delete [DANI] Where COD=[F:ANG]COD
    If fstat=1 : Call ERREUR("ANAVCRE"-[F:ANG]COD,3) From DOSDIC : Endif
    Delete [DANG] Where COD=[F:ANG]COD
    If fstat=1 : Call ERREUR("ANAVIG"-[F:ANG]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DANG]
    [F:DANG] = [F:ANG]
    If dim([F:DANG]CREDAT)>0 : [F:DANG]CREDAT = date$ : Endif
    If dim([F:DANG]CREUSR)>0 : [F:DANG]CREUSR = GUSER : Endif
    If dim([F:DANG]CRETIM)>0 : [F:DANG]CRETIM = time : Endif
    If dim([F:DANG]UPDFLG)>0 : [F:DANG]UPDFLG = 1 : Endif
    Write [DANG]
    If fstat : Call ERREUR("ANAVIG"-[F:DANG]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    RWO = 1
    K = [F:DANG]ENAFLG
    [F:DANG] = [F:ANG]
    [F:DANG]ENAFLG = K
    If dim([F:DANG]UPDDAT)>0 : [F:DANG]UPDDAT = date$ : Endif
    If dim([F:DANG]UPDUSR)>0 : [F:DANG]UPDUSR = GUSER : Endif
    If dim([F:DANG]UPDTIM)>0 : [F:DANG]UPDTIM = time : Endif
    If dim([F:DANG]UPDFLG)>0 : [F:DANG]UPDFLG = 1 : Endif
    Rewrite [DANG]
    If fstat : Call ERREUR("ANAVIG"-[F:DANG]COD,2) From DOSDIC : Endif
   Endif
   If RWO
    Delete [DANH] Where COD=[F:ANG]COD
    If fstat=1 : Call ERREUR("ANAVFIL"-[F:ANG]COD,3) From DOSDIC : Endif
    Delete [DANI] Where COD=[F:ANG]COD
    If fstat=1 : Call ERREUR("ANAVCRE"-[F:ANG]COD,3) From DOSDIC : Endif
    For [ANH]ANH0 Where COD=[F:ANG]COD
     [F:DANH] = [F:ANH]
     Write [DANH]
     If fstat : Call ERREUR("ANAVFIL"-[F:DANH]COD,1) From DOSDIC : Endif
    Next
    For [ANI]ANI0 Where COD=[F:ANG]COD
     [F:DANI] = [F:ANI]
     Write [DANI]
     If fstat : Call ERREUR("ANAVCRE"-[F:DANI]COD,1) From DOSDIC : Endif
    Next
   Endif
  Endif
 Commit
Next

Close Local File [ANG] , [ANH] , [ANI] , [DANG] , [DANH] , [DANI]
Return

###############################################################
## Formules d'épurations/historisation
###############################################################
$DICEPU
# Remplissage du dico des formules d'épuration

Local File =GDOSREF+".AHISTO" [AHI] , =GDOSREF+".AHISTOD" [AHD]
Local File =[F:ADS]DOSSIER+".AHISTO"    [DAHI]
&         ,=[F:ADS]DOSSIER+".AHISTO"    [DAH2]
&         ,=[F:ADS]DOSSIER+".AHISTOD"   [DAHD]

Call ECR_TIME(mess(15,125,1)-mess(76,125,1)) From DOSSUB
# MAJ dictionnaire - Formules d'épuration
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(76,125,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DAHI] , [DAHD]
  For [DAHI] Where COD<GXX
   Call SPEC([F:DAHI]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [AHI]AHI0 = [F:DAHI]COD
    If fstat
     Delete [DAHD] Where COD=[F:DAHI]COD
     If fstat=1 : Call ERREUR("AHISTOD"-[F:DAHI]COD,3) From DOSDIC : Endif
     Delete [DAHI]
     If fstat=1 : Call ERREUR("AHISTO"-[F:DAHI]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif

For [AHI] Where COD<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(76,125,1),[F:AHI]COD) From GESECRAN
 Endif
 Trbegin [DAHI]
  OLD = 0
  SPEC = 0
  Read [DAHI]AHI0 = [F:AHI]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DAHI]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AHI]CODACT,[F:AHI]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    Delete [DAHD] Where COD=[F:AHI]COD
    If fstat=1 : Call ERREUR("AHISTOD"-[F:AHI]COD,3) From DOSDIC : Endif
    Delete [DAHI] Where COD=[F:AHI]COD
    If fstat=1 : Call ERREUR("AHISTO"-[F:AHI]COD,3) From DOSDIC : Endif

   Elsif NEWREC & !OLD

    Raz [F:DAHI]
    [F:DAHI] = [F:AHI]
    [F:DAHI]CREDAT = date$
    [F:DAHI]CREUSR = GUSER
    If dim([F:DAHI]CRETIM)>0 : [F:DAHI]CRETIM = time : Endif
    Write [DAHI]
    If fstat : Call ERREUR("AHISTO"-[F:DAHI]COD,1) From DOSDIC : Endif
    For [AHD] Where COD=[F:AHI]COD
     [F:DAHD] = [F:AHD]
     Write [DAHD]
     If fstat : Call ERREUR("AHISTOD"-[F:DAHI]COD,1) From DOSDIC : Endif
    Next

   Elsif NEWREC & OLD

    [F:DAH2] = [F:DAHI]
    [F:DAHI] = [F:AHI]

    ## Zones utilisateurs

    [F:DAHI]TIM1 = [F:DAH2]TIM1
    [F:DAHI]TIM2 = [F:DAH2]TIM2
    [F:DAHI]FLG1 = [F:DAH2]FLG1
    [F:DAHI]FLG2 = [F:DAH2]FLG2
    [F:DAHI]FRQ1 = [F:DAH2]FRQ1
    [F:DAHI]FRQ2 = [F:DAH2]FRQ2
    [F:DAHI]DAT1 = [F:DAH2]DAT1
    [F:DAHI]DAT2 = [F:DAH2]DAT2
    [F:DAHI]ENAFLG = [F:DAH2]ENAFLG
    [F:DAHI]SPETRT = [F:DAH2]SPETRT

    [F:DAHI]UPDDAT = date$
    [F:DAHI]UPDUSR = GUSER
    If dim([F:DAHI]UPDTIM)>0 : [F:DAHI]UPDTIM = time : Endif
    Rewrite [DAHI]
    If fstat : Call ERREUR("AHISTO"-[F:DAHI]COD,2) From DOSDIC : Endif
    Delete [DAHD] Where COD=[F:AHI]COD
    For [AHD] Where COD=[F:AHI]COD
     [F:DAHD] = [F:AHD]
     Write [DAHD]
     If fstat : Call ERREUR("AHISTOD"-[F:DAHI]COD,1) From DOSDIC : Endif
    Next
   Endif
  Endif
 Commit
Next
Close Local File [AHI] , [AHD] , [DAHI] , [DAH2] , [DAHD]
Return

###################################################
## Transactions systèmes
###################################################
$DICAMI
# Dico des transactions systèmes
Call COPIE_DIC("AMAINT","COD",1,mess(77,125,1))
Return

###################################################
## Transactions applicatives
###################################################
$DICTRN
# Transactions applicatives
Call COPIE_DIC("ATRANSAC","COD",1,mess(105,125,1))
Return

###################################################
## Codes mémos
###################################################
$DICMEM
# Codes mémos
Call COPIE_DIC("AMEMO","MEMO",1,mess(191,125,1))
Return

###################################################
## Copie standard d'une table dictionnaire      ###
###################################################
Subprog COPIE_DIC(FICHIER,CLE,MODU,MESSAGE)
Value Char    FICHIER
Value Char    CLE
Value Integer MODU
Value Char    MESSAGE

Local File =GDOSREF+"."+FICHIER        [ORG]
Local File =[F:ADS]DOSSIER+"."+FICHIER [DES]

Local Char    CRITERE(250)
Local Integer OLD , SPEC , NEWREC , OENAFLG

If FICHIER="AMEMO"
 CRITERE = '('+CLE+'>="A" & '+CLE+'<"'+GXX+'")'
 CRITERE += ' or ('+CLE+'>="a" & '+CLE+'<"'+tolower(GXX)+'")'
Else
 CRITERE = CLE+'<"'+GXX+'"'
Endif

[G:ORG]currind = 1
[G:ORG]currlen = 0
[G:DES]currind = 1
[G:DES]currlen = 0

Call ECR_TIME(mess(15,125,1)-MESSAGE) From DOSSUB
If GINFO
 Call AFF_VLC(mess(15,125,1)-MESSAGE,"") From GESECRAN
Endif
If !GCRE
 Trbegin [DES]
  For [DES] Where evalue(CRITERE)
   If dim([F:DES]CODACT)>0
    Call SPEC([F:DES]CODACT,SPEC) From DOSSUB
   Else
    SPEC = 0
   Endif
   If !SPEC
    [F:ORG] = [F:DES]
    Read [ORG] =
    If fstat
     Gosub VIRE_TRT
     Delete [DES]
     If fstat=1 : Call ERREUR(FICHIER-evalue("[F:DES]"+CLE),3) From DOSDIC : Endif
    Endif
   Endif
  Next
 Commit
Endif
For [ORG] Where evalue(CRITERE)
 If GINFO
  Call AFF_VLC(mess(15,125,1)-MESSAGE,evalue("[F:ORG]"+CLE)) From GESECRAN
 Endif
 Trbegin [DES]
  OLD = 0
  SPEC = 0
  [F:DES] = [F:ORG]
  Read [DES] =
  If !fstat
   OLD = 1
   If dim([F:DES]CODACT)>0
    Call SPEC([F:DES]CODACT,SPEC) From DOSSUB
   Endif
  Endif
  If MODU & dim([F:ORG]MODULE)>0
   If dim([F:ORG]CODACT)>0
    Call NEWREC([F:ADS]DOSSIER,[F:ORG]CODACT,[F:ORG]MODULE,NEWREC) From DOSSUB
   Else
    Call NEWREC([F:ADS]DOSSIER,"",[F:ORG]MODULE,NEWREC) From DOSSUB
   Endif
  Elsif dim([F:ORG]CODACT)>0
   Call NEWREC([F:ADS]DOSSIER,[F:ORG]CODACT,0,NEWREC) From DOSSUB
  Else
   NEWREC = 1
  Endif
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Gosub VIRE_TRT
    Delete [DES]
    If fstat=1 : Call ERREUR(FICHIER-evalue("[F:ORG]"+CLE),3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    Raz [F:DES]
    [F:DES] = [F:ORG]
    If dim([F:DES]CREDAT)>0
     [F:DES]CREDAT = date$
    Endif
    If dim([F:DES]CREUSR)>0
     [F:DES]CREUSR = GUSER
    Endif
    If dim([F:DES]CRETIM)>0 : [F:DES]CRETIM = time : Endif
    Write [DES]
    If fstat : Call ERREUR(FICHIER-evalue("[F:DES]"+CLE),1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    If dim([F:DES]ENAFLG)>0
     OENAFLG = [F:DES]ENAFLG
    Endif
    [F:DES] = [F:ORG]
    If dim([F:ORG]ENAFLG)>0 & dim([F:DES]ENAFLG)>0
     [F:ORG]ENAFLG = OENAFLG
    Endif
    If dim([F:DES]UPDDAT)>0
     [F:DES]UPDDAT = date$
    Endif
    If dim([F:DES]UPDUSR)>0
     [F:DES]UPDUSR = GUSER
    Endif
    If dim([F:DES]UPDTIM)>0 : [F:DES]UPDTIM = time : Endif
    Rewrite [DES]
    If fstat : Call ERREUR(FICHIER-evalue("[F:DES]"+CLE),2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [ORG] , [DES]
End

$VIRE_TRT
Case FICHIER
 When "AMAINT"
  Call SUPP_TRT("WMAMI"+[F:DES]COD) From DOSSUB
Endcase
Return

