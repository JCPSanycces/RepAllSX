   Endif
   Raz [F:DACST]
   [F:DACST] = [F:ACST]
   If dim([F:DACST]CREDAT)>0 : [F:DACST]CREDAT = date$ : Endif
   If dim([F:DACST]CREUSR)>0 : [F:DACST]CREUSR = GUSER : Endif
   If dim([F:DACST]CRETIM)>0 : [F:DACST]CRETIM = time : Endif
   Write [F:DACST]
   If fstat : Call ERREUR("ACONSTANT"-[F:DACST]CODVAR,1) From DOSDIC : Endif
  Elsif NEWREC & OLD
   DIFF = 0
   If [F:ACST]MODULE    <> [F:DACST]MODULE     : DIFF = 3  : Endif
