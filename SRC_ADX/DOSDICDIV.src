#####################################################
## URL
#####################################################
$DICURL
## MAJ Dictionnaire - Serveur HTTP
Call ECR_TIME(mess(15,125,1)-mess(146,151,1)) From DOSSUB

Local File =GDOSREF+".AURL"             [AUR]
Local File =[F:ADS]DOSSIER+".AURL"      [DAUR]
Local File =[F:ADS]DOSSIER+".ACTIV"     [DACV]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(146,151,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DAUR]
  For [DAUR] Where CODURL<GXX
   Call SPEC([F:DAUR]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [AUR]AUR0 = [F:DAUR]CODURL
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DAUR]CODURL,0) From GESECRAN
     Delete [DAUR] Curr
     If fstat=1 : Call ERREUR("AURL"-[F:DAUR]CODURL,3) From DOSDIC : Endif
    Endif
   Endif
  Next DAUR
 Commit
Endif
For [AUR] Where CODURL<GXX
 ACTIV = 0
 Trbegin [DAUR]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAUR]AUR0 = [F:AUR]CODURL
  If !fstat
   OLD = 1
   Call SPEC([F:DAUR]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AUR]CODACT,[F:AUR]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:AUR]CODURL,0) From GESECRAN
    Delete [DAUR] Where CODURL=[F:AUR]CODURL
    If fstat=1 : Call ERREUR("AURL"-[F:AUR]CODURL,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DAUR]
    [F:DAUR] = [F:AUR]
    If dim([F:DAUR]CREDAT)>0 : [F:DAUR]CREDAT = date$ : Endif
    If dim([F:DAUR]CREUSR)>0 : [F:DAUR]CREUSR = GUSER : Endif
    If dim([F:DAUR]CRETIM)>0 : [F:DAUR]CRETIM = time : Endif
    Write [DAUR]
    If fstat : Call ERREUR("AURL"-[F:DAUR]CODURL,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    DIFF = 0
    If [F:AUR]CODACT    <> [F:DAUR]CODACT     : DIFF = 1  : Endif
    If [F:AUR]MODULE    <> [F:DAUR]MODULE     : DIFF = 3  : Endif
    If [F:AUR]INTEVAL   <> [F:DAUR]INTEVAL    : DIFF = 6  : Endif
    If [F:AUR]URL       <> [F:DAUR]URL        : DIFF = 6  : Endif
    If [F:AUR]TYPURL    <> [F:DAUR]TYPURL     : DIFF = 4  : Endif
    If dim([F:AUR]SECLEV)>0 & dim([F:DAUR]SECLEV)>0
    If [F:AUR]SECLEV    <> [F:DAUR]SECLEV     : DIFF = 4  : Endif
    Endif
    If [F:AUR]XSLCLOB   <> [F:DAUR]XSLCLOB    : DIFF = 5  : Endif
    If [F:AUR]TYPXSL    <> [F:DAUR]TYPXSL     : DIFF = 7  : Endif
    For I=0 To min(dim([F:AUR]UCOD)-1,dim([F:DAUR]UCOD)-1)
     If [F:AUR]UCOD(I)    <> [F:DAUR]UCOD(I)     : DIFF = 7  : Break : Endif
     If [F:AUR]UMEN(I)    <> [F:DAUR]UMEN(I)     : DIFF = 7  : Break :  Endif
     If [F:AUR]UPARCOD(I) <> [F:DAUR]UPARCOD(I)  : DIFF = 7  : Break :  Endif
     If [F:AUR]UPARLIB(I) <> [F:DAUR]UPARLIB(I)  : DIFF = 7  : Break :  Endif
     If [F:AUR]UPARDEF(I) <> [F:DAUR]UPARDEF(I)  : DIFF = 7  : Break :  Endif
     If [F:AUR]UPARMEN(I) <> [F:DAUR]UPARMEN(I)  : DIFF = 7  : Break :  Endif
    Next I
    For I=0 To min(dim([F:AUR]UPRG)-1,dim([F:DAUR]UPRG)-1)
     If [F:AUR]UPRG(I)  <> [F:DAUR]UPRG(I)   : DIFF = 8  : Break :  Endif
     If [F:AUR]USPRG(I) <> [F:DAUR]USPRG(I)  : DIFF = 8  : Break :  Endif
    Next I
    If !DIFF : Call TXT([F:AUR]INTIT,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff url"-[F:AUR]CODURL-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DAUR] = [F:AUR]
     If dim([F:DAUR]UPDDAT)>0 : [F:DAUR]UPDDAT = date$ : Endif
     If dim([F:DAUR]UPDUSR)>0 : [F:DAUR]UPDUSR = GUSER : Endif
     If dim([F:DAUR]UPDTIM)>0 : [F:DAUR]UPDTIM = time : Endif
     Rewrite [DAUR]
    Endif
    If fstat : Call ERREUR("AURL"-[F:DAUR]CODURL,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [AUR] , [DAUR] , [DACV]
Return

#####################################################
## Sous programmes
#####################################################
$DICASU
Local Integer I
# MAJ dictionnaire - Sous-programmes
Call ECR_TIME(mess(15,125,1)-mess(207,124,1)) From DOSSUB

Local File =GDOSREF+".ASUBPROG"  [ASU]
Local File =GDOSREF+".ASUBPROGD" [ASP]
Local File =[F:ADS]DOSSIER+".ASUBPROG"   [DAS2]
Local File =[F:ADS]DOSSIER+".ASUBPROG"   [DASU]
Local File =[F:ADS]DOSSIER+".ASUBPROGD"  [DASP]
Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(207,124,1),"") From GESECRAN
Endif
If !GCRE
 # On regarde si les enreg du dossier2 existent dans le dossier de ref
 # Si pas de spec et inexsitant on les supprime du dossier2
 Trbegin [DASU]
  For [DAS2] Where PRG<GXX & left$(PRG,1)<>"W"
   Call SPEC([F:DAS2]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ASU]ASU0 = [F:DAS2]PRG;[F:DAS2]SUBPRG
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DAS2]PRG-"/"-[F:DAS2]SUBPRG,0) From GESECRAN
     Delete [DASU] Where PRG=[F:DAS2]PRG & SUBPRG=[F:DAS2]SUBPRG
     If fstat=1 : Call ERREUR("ASUBPROG"-[F:DAS2]PRG-"/"-[F:DAS2]SUBPRG,3) From DOSDIC : Endif
     Delete [DASP] Where PRG=[F:DAS2]PRG & SUBPRG=[F:DAS2]SUBPRG
     If fstat=1 : Call ERREUR("ASUBPROGD"-[F:DAS2]PRG-"/"-[F:DAS2]SUBPRG,3) From DOSDIC : Endif
    Endif
   Endif
  Next DASU
 Commit
Endif
For [ASU] Where PRG<GXX & left$(PRG,1)<>"W"
 ACTIV = 0
 Trbegin [DASU]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DASU]ASU0 = [F:ASU]PRG;[F:ASU]SUBPRG
  If !fstat
   OLD = 1
   Call SPEC([F:DASU]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ASU]CODACT,[F:ASU]MODULE,NEWREC) From DOSSUB
  If !SPEC
   Read [ASU]ASU0 = [F:ASU]PRG;[F:ASU]SUBPRG
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,0) From GESECRAN
    Delete [DASU] Where PRG=[F:ASU]PRG &  SUBPRG=[F:ASU]SUBPRG
    If fstat=1 : Call ERREUR("ASUBPROG"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,3) From DOSDIC : Endif
    Delete [DASP] Where PRG=[F:ASU]PRG &  SUBPRG=[F:ASU]SUBPRG
    If fstat=1 : Call ERREUR("ASUBPROGD"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DASU]
    [F:DASU] = [F:ASU]
    If dim([F:DASU]CREDAT)>0 : [F:DASU]CREDAT = date$ : Endif
    If dim([F:DASU]CREUSR)>0 : [F:DASU]CREUSR = GUSER : Endif
    If dim([F:DASU]CRETIM)>0 : [F:DASU]CRETIM = time : Endif
    Write [DASU]
    If fstat : Call ERREUR("ASUBPROG"-[F:DASU]PRG-"/"-[F:DASU]SUBPRG,1) From DOSDIC : Endif
    Delete [DASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    If fstat=1 : Call ERREUR("ASUBPROGD"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,3) From DOSDIC : Endif
    For [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
     [F:DASP] = [F:ASP]
     Write [DASP]
     If fstat : Call ERREUR("ASUBPROGD"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,1) From DOSDIC : Endif
    Next
   Elsif NEWREC & OLD
    DIFF = 0
    If [F:ASU]PRG      <> [F:DASU]PRG             : DIFF = 1  : Endif
    If [F:ASU]SUBPRG   <> [F:DASU]SUBPRG          : DIFF = 2  : Endif
    If [F:ASU]NBRCOM   <> [F:DASU]NBRCOM          : DIFF = 4  : Endif
    If [F:ASU]MODULE   <> [F:DASU]MODULE          : DIFF = 5  : Endif
    If [F:ASU]NBRPAR   <> [F:DASU]NBRPAR          : DIFF = 6  : Endif
    For [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
     Read [DASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:ASP]PARAM
     If fstat : DIFF = 7  : Break : Endif
     If [F:ASP]PARAM   <> [F:DASP]PARAM     : DIFF = 7  : Break : Endif
     If [F:ASP]TYPPAR  <> [F:DASP]TYPPAR    : DIFF = 8  : Break : Endif
     If [F:ASP]ADRVAL  <> [F:DASP]ADRVAL    : DIFF = 9  : Break : Endif
     If [F:ASP]DIME    <> [F:DASP]DIME      : DIFF = 11 : Break : Endif
     If [F:ASP]PUBLI   <> [F:DASP]PUBLI     : DIFF = 12 : Break : Endif
     If [F:ASP]LONG    <> [F:DASP]LONG      : DIFF = 13 : Break : Endif
     If [F:ASP]CODCLA  <> [F:DASP]CODCLA    : DIFF = 14 : Break : Endif
     Call TXT([F:ASP]INTITPAR,DIFF)  From DOSSUB : If DIFF : Break : Endif
    Next ASP
    If [F:ASU]FONCTION <> [F:DASU]FONCTION        : DIFF = 14 : Endif
    If [F:ASU]WEBS     <> [F:DASU]WEBS            : DIFF = 15 : Endif
    If [F:ASU]PUBLINAM <> [F:DASU]PUBLINAM        : DIFF = 16 : Endif
    If dim([F:DASU]TYPASU)>0
     If [F:ASU]TYPASU  <> [F:DASU]TYPASU          : DIFF = 17 : Endif
    Endif
    If [F:ASU]CODACT   <> [F:DASU]CODACT          : DIFF = 19 : Endif
    If !DIFF : Call TXT([F:ASU]INTIT,DIFF)  From DOSSUB       : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff Sous-programmes"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DASU] = [F:ASU]
     If dim([F:DASU]UPDDAT)>0 : [F:DASU]UPDDAT = date$ : Endif
     If dim([F:DASU]UPDUSR)>0 : [F:DASU]UPDUSR = GUSER : Endif
     If dim([F:DASU]UPDTIM)>0 : [F:DASU]UPDTIM = time : Endif
     Rewrite [DASU]
     If fstat : Call ERREUR("ASUBPROG"-[F:DASU]PRG-"/"-[F:DASU]SUBPRG,2) From DOSDIC : Endif
     Delete [DASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
     If fstat=1 : Call ERREUR("ASUBPROGD"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,3) From DOSDIC : Endif
     For [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
      [F:DASP] = [F:ASP]
      Write [DASP]
      If fstat : Call ERREUR("ASUBPROGD"-[F:ASU]PRG-"/"-[F:ASU]SUBPRG,1) From DOSDIC : Endif
     Next
    Endif
   Endif
  Endif
 Commit
Next
Close Local File [ASU] , [DASU] , [DACV] , [ASP] , [DASP]
Return

#####################################################################################
## Contexte assistant formule (uniquement les variables globales et fonctions)
## Les variables locales et systèmes sont considérées comme du paramètrage
#####################################################################################
$DICAVR
# MAJ dictionnaire - Contexte assistant formule
Call ECR_TIME(mess(15,125,1)-mess(141,139,1)) From DOSSUB

Local File =GDOSREF+".AVARLOC"  [AVR]
Local File =GDOSREF+".AGLOBVAR" [AGB]
Local File =GDOSREF+".ASUBPROG" [ASU]
Local File =[F:ADS]DOSSIER+".AVARLOC"  [DAVR]
Local File =[F:ADS]DOSSIER+".AGLOBVAR" [DAGB]
Local File =[F:ADS]DOSSIER+".ASUBPROG" [DASU]
Local File =[F:ADS]DOSSIER+".ACTIV"    [DACV]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(141,139,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DAVR]
  For [DAVR] Where COD<GXX & find(TYP,1,3)<>0 and COD<"a"
   Case [F:DAVR]TYP
    When 1 : # Variables globales
     Read [DAGB]AGB0=[F:DAVR]COD
     If !fstat : Raz [F:DAGB] : Endif
     Call SPEC([F:DAGB]CODACT,SPEC) From DOSSUB
    When 3 : # Fonctions
     K = instr(1,[F:DAVR]COD,"/")
     If K
      Read [DASU]ASU0=left$([F:DAVR]COD,K-1);right$([F:DAVR]COD,K+1)
      If !fstat : Raz [F:DASU] : Endif
     Else
      Raz [F:DASU]
     Endif
     Call SPEC([F:DASU]CODACT,SPEC) From DOSSUB
   Endcase
   If !SPEC
    Read [AVR]AVR0 = [F:DAVR]TYP;[F:DAVR]FCT;[F:DAVR]COD
    If fstat
     Call ECR_TRACE(mess(53,123,1)-mess([F:DAVR]TYP,2945,1)-[F:DAVR]FCT-[F:DAVR]COD,0) From GESECRAN
     Delete [DAVR] Where TYP=[F:DAVR]TYP & FCT=[F:DAVR]FCT & COD=[F:DAVR]COD
     If fstat=1 : Call ERREUR("AVARLOC"-num$([F:DAVR]TYP)-[F:DAVR]FCT-[F:DAVR]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next DAVR
 Commit
Endif
For [AVR] Where COD<GXX & find(TYP,1,3)<>0 and COD<"a"
 ACTIV = 0
 Trbegin [DAVR]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAVR]AVR0 = [F:AVR]TYP;[F:AVR]FCT;[F:AVR]COD
  If !fstat
   OLD = 1
  Endif
  Case [F:AVR]TYP
   When 1
    Read [DAGB]AGB0=[F:AVR]COD
    If !fstat : Raz [F:DAGB] : Endif
    Call SPEC([F:DAGB]CODACT,SPEC) From DOSSUB
    Read [AGB]AGB0=[F:AVR]COD
    If !fstat : Raz [F:AGB] : Endif
    Call NEWREC([F:ADS]DOSSIER,[F:AGB]CODACT,[F:AGB]MODULE,NEWREC) From DOSSUB
   When 3
    K = instr(1,[F:AVR]COD,"/")
    If K
     Read [DASU]ASU0=left$([F:AVR]COD,K-1);right$([F:AVR]COD,K+1)
     If !fstat : Raz [F:DASU] : Endif
    Else
     Raz [F:DASU]
    Endif
    Call SPEC([F:DASU]CODACT,SPEC) From DOSSUB
    K = instr(1,[F:AVR]COD,"/")
    If K
     Read [ASU]ASU0=left$([F:AVR]COD,K-1);right$([F:AVR]COD,K+1)
     If !fstat : Raz [F:ASU] : Endif
    Else
     Raz [F:ASU]
    Endif
    Call NEWREC([F:ADS]DOSSIER,[F:ASU]CODACT,[F:ASU]MODULE,NEWREC) From DOSSUB
  Endcase
  If !SPEC
   If OLD & !NEWREC
    Delete [DAVR] Where TYP=[F:AVR]TYP & FCT=[F:AVR]FCT & COD=[F:AVR]COD
    If fstat=1 : Call ERREUR("AVARLOC"-num$([F:AVR]TYP)-[F:AVR]FCT-[F:AVR]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DAVR]
    [F:DAVR] = [F:AVR]
    If dim([F:DAVR]CREDAT)>0 : [F:DAVR]CREDAT = date$ : Endif
    If dim([F:DAVR]CREUSR)>0 : [F:DAVR]CREUSR = GUSER : Endif
    If dim([F:DAVR]CRETIM)>0 : [F:DAVR]CRETIM = time : Endif
    Write [DAVR]
    If fstat : Call ERREUR("AVARLOC"-num$([F:AVR]TYP)-[F:AVR]FCT-[F:AVR]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    Call TXT([F:AVR]INTIT,DIFF)  From DOSSUB
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff varloc"-[F:AVR]COD-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DAVR] = [F:AVR]
     If dim([F:DAVR]UPDDAT)>0 : [F:DAVR]UPDDAT = date$ : Endif
     If dim([F:DAVR]UPDUSR)>0 : [F:DAVR]UPDUSR = GUSER : Endif
     If dim([F:DAVR]UPDTIM)>0 : [F:DAVR]UPDTIM = time : Endif
     Rewrite [DAVR]
    Endif
    If fstat : Call ERREUR("AVARLOC"-num$([F:AVR]TYP)-[F:AVR]FCT-[F:AVR]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [AVR] , [AGB] , [ASU] , [DAVR] , [DAGB] , [DASU] , [DACV]
Return

#####################################################
## Points d'entrée
#####################################################
$DICAPE
# MAJ dictionnaire - Point d'entrée
Call ECR_TIME(mess(15,125,1)-mess(134,125,1)) From DOSSUB

Local File =GDOSREF+".AENTREE" [APE]
Local File =[F:ADS]DOSSIER+".AENTREE"  [DAPE]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(134,125,1),"") From GESECRAN
Endif

Trbegin [DAPE]
 For [APE]
  #117248 Read [DAPE]APE0 = [F:APE]TRTSTD
  Read [DAPE]APE0 = [F:APE]TRTSTD;[F:APE]OBJ;[F:APE]TRTSPE
  If fstat
   Call ECR_TRACE(mess(59,123,1)-[F:APE]TRTSTD-[F:APE]OBJ-[F:APE]TRTSPE,0) From GESECRAN
   [F:DAPE] = [F:APE]
   Write [DAPE]
   If fstat : Call ERREUR("AENTREE"-[F:APE]TRTSTD-[F:APE]OBJ-[F:APE]TRTSPE,1) From DOSDIC : Endif
  Endif
 Next APE
Commit

Close Local File [APE] , [DAPE]
Return

#####################################################
## Documentation
#####################################################
$DICADO
# Remplissage du dico de la documentation
Call ECR_TIME(mess(15,125,1)-mess(108,139,1)) From DOSSUB
# MAJ dictionnaire - Documentation
Local File =GDOSREF+".ADOCUMENT" [ADO]
Local File =[F:ADS]DOSSIER+".ADOCUMENT"    [DADO]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(108,139,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DADO]
  For [DADO] Where COD<GXX
   If !find([F:DADO]LAN,[F:ADS]LAN) : # test si la langue est bien dans le dossier
    Delete [DADO]
    If fstat=1 : Call ERREUR("ADOCUMENT"-[F:DADO]LAN-[F:DADO]TYP-[F:DADO]COD,3) From DOSDIC : Endif
   Else
    Call SPEC([F:DADO]CODACT,SPEC) From DOSSUB
    If !SPEC
     Read [ADO]ADO0 = [F:DADO]LAN;[F:DADO]TYP;[F:DADO]COD;[F:DADO]LEV;[F:DADO]SUBLEV
     If fstat
      Delete [DADO]
      If fstat=1 : Call ERREUR("ADOCUMENT"-[F:DADO]LAN-[F:DADO]TYP-[F:DADO]COD,3) From DOSDIC : Endif
     Endif
    Endif
   Endif
  Next
 Commit
Endif

For I=1 To [F:ADS]NBRLAN
 For [ADO]ADO0 Where COD<GXX & LAN=[F:ADS]LAN(I-1)
  If GINFO
   Call AFF_VLC(mess(15,125,1)-mess(108,139,1),[F:ADO]LAN-[F:ADO]TYP-[F:ADO]COD) From GESECRAN
  Endif
  Trbegin [DADO]
   OLD = 0
   SPEC = 0
   Read [DADO]ADO0 = [F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    OLD = 1
    Call SPEC([F:DADO]CODACT,SPEC) From DOSSUB
   Endif
   If ([F:ADO]MODULE>0 & [F:ADS]MODULE([F:ADO]MODULE-1)=2) or GADONIX=2
    NEWREC = 1 : # Il faut transférer qq soit le code activité
   Else
    Call NEWREC([F:ADS]DOSSIER,[F:ADO]CODACT,[F:ADO]MODULE,NEWREC) From DOSSUB
   Endif
   If !SPEC
    If OLD & !NEWREC : # On le vire
     Delete [DADO] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD
&                      & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
     If fstat=1 : Call ERREUR("ADOCUMENT"-[F:ADO]LAN-[F:ADO]TYP-[F:ADO]COD,3) From DOSDIC : Endif
    Elsif NEWREC & !OLD
     Raz [F:DADO]
     [F:DADO] = [F:ADO]
     [F:DADO]CREDAT = date$
     [F:DADO]CREUSR = GUSER
     If dim([F:DADO]CRETIM)>0 : [F:DADO]CRETIM = time : Endif
     Write [DADO]
     If fstat : Call ERREUR("ADOCUMENT"-[F:ADO]LAN-[F:ADO]TYP-[F:ADO]COD,1) From DOSDIC : Endif
    Elsif NEWREC & OLD
     DIFF = 0
     If [F:DADO]MODULE <> [F:ADO]MODULE : DIFF = 1 : Endif
     If [F:DADO]MSK    <> [F:ADO]MSK    : DIFF = 1 : Endif
     If [F:DADO]PAR    <> [F:ADO]PAR    : DIFF = 1 : Endif
     If [F:DADO]TIT    <> [F:ADO]TIT    : DIFF = 1 : Endif
     If [F:DADO]CODACT <> [F:ADO]CODACT : DIFF = 1 : Endif
     If [F:DADO]STY    <> [F:ADO]STY    : DIFF = 1 : Endif
     If [F:DADO]PRIO   <> [F:ADO]PRIO   : DIFF = 1 : Endif
     If [F:DADO]VLDFLG <> [F:ADO]VLDFLG : DIFF = 1 : Endif
     If [F:DADO]VLDDAT <> [F:ADO]VLDDAT : DIFF = 1 : Endif
     If DIFF
      [F:DADO] = [F:ADO]
      [F:DADO]UPDDAT = date$
      [F:DADO]UPDUSR = GUSER
      If dim([F:DADO]UPDTIM)>0 : [F:DADO]UPDTIM = time : Endif
      Rewrite [DADO]
      If fstat : Call ERREUR("ADOCUMENT"-[F:ADO]LAN-[F:ADO]TYP-[F:ADO]COD,2) From DOSDIC : Endif
     Endif
    Endif
   Endif
  Commit
 Next ADO
Next I
Close Local File [ADO] , [DADO]
Return

#####################################################
## Liens de documentation
#####################################################
$DICADF
# Remplissage du dico des liens de documentation
Call ECR_TIME(mess(15,125,1)-mess(138,139,1)) From DOSSUB
# MAJ dictionnaire - Liens de documentation
Local File =GDOSREF+".ADOCFNC" [ADF]
Local File =[F:ADS]DOSSIER+".ADOCFNC"    [DADF]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(138,139,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DADF]
  For [DADF]ADF0(2) Where COD<GXX
   Call SPEC([F:DADF]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ADF]ADF0(2) = [F:DADF]TYP;[F:DADF]COD
    If fstat
     For [DADF]ADF0
      Delete [DADF]
      If fstat=1 : Call ERREUR("ADOCFNC"-[F:DADF]TYP-[F:DADF]COD,3) From DOSDIC : Endif
     Next DADF
    Endif
   Endif
  Next DADF(2)
 Commit
Endif

For [ADF]ADF0(2) Where COD<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(138,139,1),[F:ADF]TYP-[F:ADF]COD) From GESECRAN
 Endif
 Trbegin [DADF]
  OLD = 0
  SPEC = 0
  Read [DADF]ADF0(2) = [F:ADF]TYP;[F:ADF]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DADF]CODACT,SPEC) From DOSSUB
  Endif
  If ([F:ADF]MODULE>0 & [F:ADS]MODULE([F:ADF]MODULE-1)=2) or GADONIX=2
   NEWREC = 1 : # Il faut transférer qq soit le code activité
  Else
   Call NEWREC([F:ADS]DOSSIER,[F:ADF]CODACT,[F:ADF]MODULE,NEWREC) From DOSSUB
  Endif
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Delete [DADF] Where TYP=[F:ADF]TYP & COD=[F:ADF]COD
    If fstat=1 : Call ERREUR("ADOCFNC"-[F:ADF]TYP-[F:ADF]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    For [ADF]ADF0
     Raz [F:DADF]
     [F:DADF] = [F:ADF]
     [F:DADF]CREDAT = date$
     [F:DADF]CREUSR = GUSER
     If dim([F:DADF]CRETIM)>0 : [F:DADF]CRETIM = time : Endif
     Write [DADF]
     If fstat : Call ERREUR("ADOCFNC"-[F:ADF]TYP-[F:ADF]COD-num$([F:ADF]NUM),1) From DOSDIC : Endif
    Next ADF
   Elsif NEWREC & OLD
    Delete [DADF] Where TYP=[F:ADF]TYP & COD=[F:ADF]COD
    If fstat=1 : Call ERREUR("ADOCFNC"-[F:ADF]TYP-[F:ADF]COD,3) From DOSDIC : Endif
    For [ADF]ADF0
     [F:DADF] = [F:ADF]
     [F:DADF]UPDDAT = date$
     [F:DADF]UPDUSR = GUSER
     If dim([F:DADF]UPDTIM)>0 : [F:DADF]UPDTIM = time : Endif
     Write [DADF]
     If fstat : Call ERREUR("ADOCFNC"-[F:ADF]TYP-[F:ADF]COD-num$([F:ADF]NUM),2) From DOSDIC : Endif
    Next ADF
   Endif
  Endif
 Commit
Next ADF(2)
Close Local File [ADF] , [DADF]
Return

#####################################################
## Modèles de données
#####################################################
$DICAWM
# Remplissage du dico des Modèles de données Worflow
Call ECR_TIME(mess(15,125,1)-mess(152,75,1)) From DOSSUB
# MAJ dictionnaire - Modèles de données Worflow
Local File =GDOSREF+".AWRKLNK" [AWM]
Local File =GDOSREF+".AWRKTAB" [AWK]
Local File =[F:ADS]DOSSIER+".AWRKLNK"    [DAWM]
Local File =[F:ADS]DOSSIER+".AWRKTAB"    [DAWK]


If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(152,75,1),"") From GESECRAN
Endif

If !GCRE
 Trbegin [DAWM]
  For [DAWM]AWM0 Where MODELE<GXX
   Call SPEC([F:DAWM]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [AWM]AWM0 = [F:DAWM]MODELE
    If fstat
     Delete [DAWK] Where MODELE=[F:DAWM]MODELE
     If fstat=1 : Call ERREUR("AWRKTAB"-[F:DAWM]MODELE,3) From DOSDIC : Endif
     Delete [DAWM] Curr
     If fstat=1 : Call ERREUR("AWRKLNK"-[F:DAWM]MODELE,3) From DOSDIC : Endif
    Endif
   Endif
  Next DAWM
 Commit
Endif

For [AWM] Where MODELE<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(152,75,1),[F:AWM]MODELE) From GESECRAN
 Endif
 Trbegin [DAWM]
  OLD = 0
  SPEC = 0
  Read [DAWM]AWM0 = [F:AWM]MODELE
  If !fstat
   OLD = 1
   Call SPEC([F:DAWM]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AWM]CODACT,[F:AWM]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC : # On le vire
    Delete [DAWK] Where MODELE=[F:AWM]MODELE
    If fstat=1 : Call ERREUR("MODELE AWRKTAB"-[F:AWM]MODELE,3) From DOSDIC : Endif
    Delete [DAWM] Where MODELE=[F:AWM]MODELE
    If fstat=1 : Call ERREUR("MODELE AWRKLNK"-[F:AWM]MODELE,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    Raz [F:DAWM]
    [F:DAWM] = [F:AWM]
    [F:DAWM]CREDAT = date$
    [F:DAWM]CREUSR = GUSER
    If dim([F:DAWM]CRETIM)>0 : [F:DAWM]CRETIM = time : Endif
    Write [DAWM]
    If fstat : Call ERREUR("MODELE"-[F:DAWM]MODELE,1) From DOSDIC : Endif
    For [AWK] Where MODELE=[F:AWM]MODELE
     Raz [F:DAWK]
     [F:DAWK] = [F:AWK]
     Write [DAWK]
     If fstat : Call ERREUR("MODELE AWRKTAB"-[F:DAWK]MODELE,1) From DOSDIC : Endif
    Next
   Elsif NEWREC & OLD
    [F:DAWM] = [F:AWM]
    [F:DAWM]UPDDAT = date$
    [F:DAWM]UPDUSR = GUSER
    If dim([F:DAWM]UPDTIM)>0 : [F:DAWM]UPDTIM = time : Endif
    Rewrite [DAWM]
    If fstat : Call ERREUR("MODELE"-[F:DAWM]MODELE,2) From DOSDIC : Endif
    Delete [DAWK] Where MODELE=[F:AWM]MODELE
    If fstat=1 : Call ERREUR("MODELE AWRKTAB"-[F:AWM]MODELE,3) From DOSDIC : Endif
    For [AWK] Where MODELE=[F:AWM]MODELE
     Raz [F:DAWK]
     [F:DAWK] = [F:AWK]
     Write [DAWK]
     If fstat : Call ERREUR("MODELE AWRKTAB"-[F:DAWK]MODELE,1) From DOSDIC : Endif
    Next
   Endif
  Endif
 Commit
Next AWM

Close Local File [AWM] , [DAWM] , [AWK] , [DAWK]
Return

#####################################################
## utilitaires
#####################################################
$DICAUTIL
# Remplissage du dico
# CAS DE LA CREATION DE DOSSIER etiquete se fait à la fin car la structure de la table est fait apres sinon
# ne copier que les nouveaux ou ceux qui sont à lancer (dans le cas d une mise à jour)
# ne pas ecraser ceux deja lancer
# voir a utiliser même routine que patcheur
# en creation de dossier les copier mais mettre le status en non actif. à la fin fin
#
# voir comment on gérera le cas de la mise à jour de la structure de cette table.
# on ne met pas autility en systeme avec une notion de folder .. car ces infos sont stockés dans github
# et là on ne dispose pas de notion de folder.
# voir a couper la table en deux sinon une sans notion de folder et une liée a ADOSSIER.
#
Call ECR_TIME(mess(15,125,1)-" utilities") From DOSSUB
# MAJ dictionnaire dossier fille
# on part tjs du dossir root
Local File =GDOSX3+".AUTILITY" [AUTI]
Local File =[F:ADS]DOSSIER+".AUTILITY"    [DAUTI]


If GINFO
    Call AFF_VLC(mess(15,125,1)-" utilities","") From GESECRAN
Endif

Filter [AUTI]

Trbegin [DAUTI]
# boucle sur tous les uti de x3... pas le choix pour instant .. pas top mais....
# rien ne donne info comme quoi uti nouveau ou pas......
# voir a tester le GMAXUPDTRS......

For [AUTI]
  # verif code act ADOSACT + module ADOSSIER
  # test des modules et codes activités du dossier fille en fct de la ficher ADOSACT...
  Call NEWREC([F:ADS]DOSSIER,[F:AUTI]CODACT,[F:AUTI]MODULE,NEWREC) From DOSSUB
  Read [DAUTI]AUTI0 = [F:AUTI]UTICOD
  If fstat = 0
      If NEWREC = 0
          # ici uti n est pas à copier mais il existe deja dans le dossier
          # dans ce cas on le vire.
          Delete [F:DAUTI] Where UTICOD = [F:AUTI]UTICOD
          If fstat<> 0 : Call ERREUR("UTILITY "-[F:AUTI]UTICOD,3) From DOSDIC : Endif
      Else
          # si existe et que status est à lancer on ecrase sinon rien.
          If [F:DAUTI]LAUNCHSTATUS = 1
              [F:DAUTI]COMMENT   =  [F:AUTI]COMMENT
              [F:DAUTI]MODULE    =  [F:AUTI]MODULE
              [F:DAUTI]CODACT    =  [F:AUTI]CODACT
              [F:DAUTI]SCRIPT    =  [F:AUTI]SCRIPT
              [F:DAUTI]GROUPFLG  =  [F:AUTI]GROUPFLG
              [F:DAUTI]ROOTRUN   =  [F:AUTI]ROOTRUN
              [F:DAUTI]CHILDRUN  =  [F:AUTI]CHILDRUN
              [F:DAUTI]LAUNCHTYP =  [F:AUTI]LAUNCHTYP
              [F:DAUTI]GROUP     =  [F:AUTI]GROUP
              [F:DAUTI]GROUPSEQ  =  [F:AUTI]GROUPSEQ
              # always this flag set = NO (modification not authorized)
              [F:DAUTI]UPDATEFLG = 1
              # si le type lancement non actif en validation
              # on met a jour status en non actif ne pas lancer ensuite
              If [F:AUTI]LAUNCHTYPVAL  = 4
                    [F:DAUTI]LAUNCHSTATUS = 3
              Endif
              Call FLDUPD("DAUTI") From OBJDIV
              Rewrite [DAUTI]
              If fstat
                    Call ERREUR("UTILITY"-[F:AUTI]UTICOD,2) From DOSDIC
              Endif
          Endif
      Endif
  Else
     If NEWREC = 0
          # ici uti n est pas à copier mais pas present dans le dossier fille
          # donc on ne fait rien
     Else
         [F:DAUTI] = [F:AUTI]
         If GCRE
              # en creation on passe le statut à non actif
              # le dossier est forcement déjà à jour puisqu on part de rien.
              # on fait à la fin fin ....de valdos
              [F:DAUTI]LAUNCHSTATUS = 3
         Else
              # on copie car nouveau record avec status a lancer
              # si le type lancement non actif en validation
              # on met a jour status en non actif ne pas lancer ensuite
              If [F:AUTI]LAUNCHTYPVAL  = 4
                [F:DAUTI]LAUNCHSTATUS = 3
              Else
                [F:DAUTI]LAUNCHSTATUS = 1
              Endif
         Endif
         [F:DAUTI]LAUNCHNBR    = 0
         # always this flag set = NO (modification not authorized)
         [F:DAUTI]UPDATEFLG = 1
         Raz [F:DAUTI]LOGFIL
         Raz [F:DAUTI]LAUNCHDAT
         Raz [F:DAUTI]LAUNCHUSR
         Raz [F:DAUTI]LASLAUNCHDAT
         Raz [F:DAUTI]LASLAUNCHUSR
         Raz [F:DAUTI]RELEASE
         Call FLDCRE("DAUTI") From OBJDIV
         Write [DAUTI]
         If fstat
              Call ERREUR("UTILITY"-[F:AUTI]UTICOD,1) From DOSDIC
         Endif
     Endif
  Endif
Next
Commit
#Close Local File [AUTI] , [DAUTI]
LogicClose File [AUTI] , [DAUTI]
Return

