#<AdxTL>@(#)0.0.0.0 $Revision$
# Moulinette pour alimenter le champ CREMVTSEQ de STOJOU

  Call MAJ_UTISTO10(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTISTO10(APPLI)
End

########################################################################
Subprog MAJ_UTISTO10(DOSSIER)
Value Char DOSSIER

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Alimentation CREMVTSEQ") From DOSSUB
  #------------------------------------------------------
  Call MAJ_UTISTO10(DOSSIER) From UTISTO10
  Call ECR_TIME("FIN => Alimentation CREMVTSEQ") From DOSSUB
  #------------------------------------------------------
End
