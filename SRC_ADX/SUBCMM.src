###############

Subprog AV_NBLIG
Gosub AFF_NBLIG
End

$AFF_NBLIG
Local Char VALEUR(10)
If nolign>0 & evalue('dim([M]ACC'+num$(GENGNUMLEDAFF)+')>0') & evalue('[M]ACC'+num$(GENGNUMLEDAFF)+'('+num$(nolign-1)+')<>""')
 VALEUR = evalue("[M]ACC"+num$(GENGNUMLEDAFF)+"("+num$(nolign-1)+")")
 Gosub AFF_CPT
Elsif dim([M]AFFICHE)>0
 [M]AFFICHE = ""
 Affzo AFFICHE
Endif
End

$AFF_CPT
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Local Char INTIT(GLONAX3)
 Call LECTURE("GAC",VALEUR,[M]COA(GENGNUMLEDAFF-1)) From CONTOBJ
 Call LECTEXTRA([L]INTIT,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 [M]AFFICHE = VALEUR-":"-[L]INTIT : Affzo AFFICHE
Endif
Return

Subprog AVANT_NBLIG
Gosub SETNOL
[M]TOTAL -= [M]AMT(NOL)
Gosub AFF_NBLIG
End

Subprog APRES_NBLIG
Gosub SETNOL
[M]TOTAL += [M]AMT(NOL)
If status<>7
 Affzo TOTAL
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$LECLED
Local Char LED(GLONLED)
Local Char DEV(GLONCUR)
Call LECLED([M]CPY,[L]TLED,LED,DEV) From CPTDIV
Call LECTURE("LED",[L]LED,"") From CONTOBJ
Return

