Subprog CONTACC(NLED,VALEUR)
Value Integer NLED    : # Type référentiel
Variable Char VALEUR()
Local Char    CPT(GLONGAC), CRIBLE(30)
Local Integer I, OK
Local Integer TLED
Gosub SETNOL
[L]TLED = [M]LEDTYP(NLED-1)
Gosub LECLED
If NLED>1
 Assign "[M]ACC"+num$(NLED)+"("+num$(NOL)+")" With VALEUR
 Local Char    TPLAN(GLONCOA)(1..NLED),TCOMPTE(GLONGAC)(1..NLED), MESSA(250)
 Local Integer I, STAT : STAT = 0
 For I=1 To NLED
  TPLAN(I)   = evalue("[M]COA("+num$(I-1)+")")
  TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
 Next
 Call CNTIPTACC(NLED,TPLAN,TCOMPTE,MESSA,STAT) From CPTCNT
 If STAT : GMESSAGE = MESSA : mkstat = 2 : End : Endif
Endif

If VALEUR = "" : End : Endif
CPT = VALEUR

If GMODU(2)=2  : # Compta
 Read [GAC]GAC1 = [M]COA(NLED-1);CPT
 If !fstat
  CPT = [F:GAC]ACC     : # Code d'appel compte
 Endif
Endif

Read [GAC]GAC0 >= [M]COA(NLED-1);CPT
If fstat>2 | left$([F:GAC]ACC,len(CPT))<>CPT
 # Compte inexistant
 GMESSAGE = CPT-mess(44,102,1)
 mkstat = 2 : End
Endif
Call CONTACC([M]LEDTYP(NLED-1),[M]COA(NLED-1),[F:GAC]ACC,[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT(NOL)) From CPTCNT
If mkstat : End : Endif
VALEUR      = [F:GAC]ACC
If [M]UOM(NOL)=""
 [M]UOM(NOL) = [F:GAC]UOM
Endif

#Contrôle de compatibilité avec le tiers pour compte collectif
If [M]BPR<>""
 If [F:GAC]SAC=2
  Raz OK
  Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
  OK += [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
  OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
  OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
  OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
  OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
  OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
  If !OK
   # Compte incompatible avec le tiers
   GMESSAGE = mess(105,106,1)
   mkstat=2 : End
  Endif
  [M]BPRACC(NOL) = [M]BPR
 Else
  [M]BPRACC(NOL) = [M]BPR
 Endif
Endif
End

