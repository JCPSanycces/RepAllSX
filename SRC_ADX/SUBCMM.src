Gosub SETNOL
Call LECTURE("GAC",evalue("[M]ACC"+num$(GENGNUMLEDAFF)+"("+num$(NOL)+")"),[M]COA(GENGNUMLEDAFF-1)) From CONTOBJ
If [F:GAC]FLGUOM=2
 VALEUR = [F:GAC]UOM
Endif
End

Subprog D_QTY(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Decimal MONTANT, ARRO, COURS
Local Integer STAT
Call LECTURE("GAC",evalue("[M]ACC"+num$(GENGNUMLEDAFF)+"("+num$(NOL)+")"),[M]COA(GENGNUMLEDAFF-1)) From CONTOBJ
If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
 Call LECTURE("TUN",[F:GAC]UOM,"") From CONTOBJ
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call CONVERT([M]CUR,GSYSCUR,[F:CPY]ACCCUR,[M]TYPCUR,[M]ACCDAT(NOL),[M]AMTCUR(NOL),MONTANT,STAT) From TRTDEV
 If [F:TUN]UOMDEC=0
  ARRO = 1
 Else
  ARRO = val("0."+string$([F:TUN]UOMDEC-1,"0")+"1")
 Endif
 VALEUR = arr(MONTANT/[F:GAC]VALUOM,ARRO)
Endif
End

Subprog AS_QTY(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Call LECTURE("GAC",evalue("[M]ACC"+num$(GENGNUMLEDAFF)+"("+num$(NOL)+")"),[M]COA(GENGNUMLEDAFF-1)) From CONTOBJ
If [F:GAC]FLGUOM<>2 : mkstat = 1 : End : Endif
End

