Subprog C_CCE(AXE,VALEUR)
Value    Integer AXE      : # N° ordre axe
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
For I=1 To len(mess(0,2644,1))
 K=find(I,GENGTYPLED(1..10))
 If K
  COMPTE = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
  If COMPTE<>""
   [L]TLED = [M]LEDTYP(I-1) : Gosub LECLED
   Call CONTCCE(VALEUR,[L]LED,GENGAXE(AXE),[M]FCYLIN(NOL),[M]ACCDAT(NOL),COMPTE,[M]DIE,"[M]CCE#",NOL) From CPTCNT
  Endif
 Endif
Next
End

$AFF_CCE
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LECTURE("CCE",VALEUR,[M]DIE(AXE-1)) From CONTOBJ
 If !fstat
  [M]AFFICHE = VALEUR-":"-[F:CCE]DES : Affzo AFFICHE
 Endif
Endif
Return

Subprog TUNNEL(TYP)
Value Integer TYP
Local Char TEST
[M:BUD]CMMTYP = [L]TYP
Call OBJET_CHAR(TEST,"CMM","") From GOBJET
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()

# Issue X3-107417 by MRDAB - problem with BPR for modification and duplication
For nolign = 1 To [M]NBLIG
  [M]BPRACC(nolign - 1) = VALEUR
Next
# Issue X3-107417 end

End

