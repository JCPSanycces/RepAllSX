Variable Char    VALEUR()
Local Integer NLED
NLED = 4 : Goto SAIACC

Subprog AS_ACC5(VALEUR)
Variable Char    VALEUR()
Local Integer NLED
NLED = 5 : Goto SAIACC

Subprog AS_ACC6(VALEUR)
Variable Char    VALEUR()
Local Integer NLED
NLED = 6 : Goto SAIACC

