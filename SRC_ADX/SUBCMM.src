Variable Char    VALEUR()
Local Integer NLED
NLED = 7 : Goto SAIACC

Subprog AS_ACC8(VALEUR)
Variable Char    VALEUR()
Local Integer NLED
NLED = 8 : Goto SAIACC

Subprog AS_ACC9(VALEUR)
Variable Char    VALEUR()
Local Integer NLED
NLED = 9 : Goto SAIACC

Subprog AS_ACC10(VALEUR)
Variable Char    VALEUR()
Local Integer NLED
NLED = 10 : Goto SAIACC

$SAIACC
Gosub SETNOL
Local Integer TLED
## L'unique collectif et tiers se 'raccroche' au référentiel principal général
[L]TLED = NLED
If NLED = GTYPGEN
 Local Char COMPTE(GLONGAC), CODCPT(GLONCAC)
 If NOL=0 & VALEUR=""
  Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
  Call INIT_COMPTE([M]BPR,GSOCIETE,"C",CODCPT) From CPTSUB
  If !clalev([CAC]) : Local File GACCCODE [CAC] : Endif
  Read [CAC]CAC0 = 2;[L]CODCPT;[M]COA(NLED)
  If !fstat & [F:CAC]ACC(7)<>""
   COMPTE = vireblc(ctrans([F:CAC]ACC(7),"xX","00"),2)
   Read [GAC]GAC0 = [M]COA(NLED);COMPTE
   If !fstat
    VALEUR = COMPTE
   Endif
  Endif
 Endif
Endif
If NLED>1
 Gosub INI_OTHACC
Endif
Gosub AFF_ACC
End

$INI_OTHACC
If evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")<>"" : Return : Endif
If NLED>1
 Local Char    CRIBLE(20)
 Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
 Local Integer INDLED, INDREF
 For INDLED=1 To NLED-1
  [L]ACCORG = evalue("[M]ACC"+num$(INDLED)+"("+num$(NOL)+")")
  If [L]ACCORG<>""
   Call LECTURE("GAC",ACCORG,[M]COA(INDLED-1)) From CONTOBJ
   If find([M]COA(NLED-1),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
    Call INIACC([M]COA(INDLED-1),[L]ACCORG,[M]COA(NLED-1),ACCDES,[L]CRIBLE) From CPTINI
    If [L]ACCDES<>""
     ## Le compte du type référentiel NLED a été initialisé par le type référentiel INDLED -> On sort
     INDREF = INDLED : Break
    Endif
   Elsif [M]COA(NLED-1)=[M]COA(INDLED-1) : # Demande 55712. Plans de comptes identiques
    [L]ACCDES = [L]ACCORG
    INDREF = INDLED : Break
   Else
    mkstat = 1 : Break
   Endif
  Endif
 Next
 If mkstat : Return : Endif
 If ACCDES = ""
  Return
 Elsif [M]COA(INDREF-1)<>[M]COA(NLED-1)
  VALEUR = ACCDES
  If VALEUR<>""
   Call LECTURE("GAC",VALEUR,[M]COA(NLED-1)) From CONTOBJ
   [M]UOM(NOL) = [F:GAC]UOM
  Else
   [M]UOM(NOL) = ""
  Endif
  If [L]ACCDES = [L]CRIBLE
   mkstat=2 : Return
  Endif
 Elsif [M]COA(NLED-1)=[M]COA(INDLED-1) : # Demande 55712. Plans de comptes identiques
  VALEUR = ACCDES : mkstat = 2 : Return
 Endif
Endif
Return


$AFF_ACC
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Local Char INTIT(GLONAX3)
 Call LECTURE("GAC",VALEUR,[M]COA(NLED-1)) From CONTOBJ
 Call LECTEXTRA([L]INTIT,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 [M]AFFICHE = VALEUR-":"-[L]INTIT : Affzo AFFICHE
Endif
Return

