Subprog D_CCE(AXE,CODSEC,VALEUR)
Value    Integer AXE      : # N° ordre axe
Value    Char    CODSEC() : # Code section par défaut
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
Local Integer NLED, TLED
For I=1 To len(mess(0,2644,1))
 K=find(I,GENGTYPLED(1..10))
 If K
  [L]TLED = [M]LEDTYP(I-1) : Gosub LECLED
  Call INICCE(VALEUR,GENGAXE(AXE),[L]LED,evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")"),CODSEC) From CPTINI
  If VALEUR<>"" : Break : End : Endif
 Endif
Next
End

