#<AdxTL>@(#)8.0.0.0 $Revision$
# Issue X3-101787 - 2018-10-19 by FHA : RATDAT not initiated

Raz GPILOBJ
Call OBJET("CMM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "INICRE"     : Gosub INICRE
 When "RAZDUP"     : Gosub RAZDUP
 When "RAZCRE"     : Gosub RAZCRE
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "CREATION"   : Gosub CREATION
 When "APRES_CRE"  : Gosub APRES_CRE
 When "MODIF"      : Gosub MODIF
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "APRES_MOD"  : Gosub APRES_MOD
 When "SEL_LISTE"  : Gosub SEL_LISTE From SUBCMM2
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "EXEBOUT"    : Gosub EXEBOUT
 When "AVANT_MOD"  : Gosub AVANT_MOD

 When "FILTRE"     : Gosub FILTRE
Endcase
Return

$FILTRE
If clalev([M:BCR])>0 & clalev([M:BUD])>0
 nolign = max(1,SAVNOL2)
 # Si la transaction n'est pas de type période il faut tester dim
 If dim([M:BUD]PERSTR)>0
  FILTSUP += "CPY='"+[M:BCR]CPY+"' & ACCDAT>=[M:BUD]PERSTR("+num$(nolign-1)+") & ACCDAT<=[M:BUD]PEREND("+num$(nolign-1)+") & TYP="+num$([M:BUD]CMMTYP)
 Else
  FILTSUP += "CPY='"+[M:BCR]CPY+"' & TYP="+num$([M:BUD]CMMTYP)
 Endif
 If [F:BUP]LEV=2 # budget défini niveau site
  FILTSUP += " & FCY='"+[M:BCR]FCY+"'"
 Endif
Endif
Return

$SEL_TABLE
If PARAM(1)=""
 CRITERE -= "[F:GAC]SAC<>2"
 CRITERE -= "& [F:GAC]COA='"+PARAM(2)+"'"
Else
 CRITERE = "[F:GAC]COA='"+PARAM(2)+"'"
Endif
OBJET   = "GAC"
Return

$OUVRE
If clalev([CPY])=0 : Local File COMPANY   [CPY]  : Endif
If clalev([GCM])=0 : Local File GACM      [GCM]  : Endif
If clalev([LED])=0 : Local File GLED      [LED]  : Endif
If clalev([COA])=0 : Local File GCOA      [COA]  : Endif
If clalev([DIE])=0 : Local File GDIE      [DIE]  : Endif
If clalev([CCE])=0 : Local File CACCE     [CCE]  : Endif
If clalev([TCA])=0 : Local File TABCOUAFF [TCA]  : Endif

Local Char    INTIT(250)
Local Char    ENGCPT(GLONANM)  : # Compteur engagements
Local Integer I, N, STAT, AX, OKBUD, SIGN , TYPCMM, SNSCMM, LEDTYPCMM, OKTCA
Local Integer OLDTYP     : # Type dernier engagement
Local Integer OLDSNS     : # Sens dernier engagement (Dépense ou Recette)

Local Char    TBCCE(GLONCCE)(1..dim([F:LED]DIE)), CMESSAGE(250)
Local Char    TBDIE(GLONDIE)(1..dim([F:LED]DIE))
Local Char    VALPAR(10)
Local Integer CONTBUD    : # Contrôle budgétaire

#19/05/09 Dmd 55251
Local Integer NBCUR, CONSCUR
Local Char    TBCUR(GLONCUR)(1..4)

If clalev([M:CMM1])=0 : Local Mask CMM1 [CMM1] : Endif
Local Decimal AMT(0..dim([M:CMM1]AMTCUR))

#08/06/09 Dmd 56882
Local Char    MESSA(250)
Local Integer STAT
Gosub DECLARE_GLOBAL
Return

$LIENS
Actzo [M:CMM1]
Raz STAT
Default Mask [CMM1]
nolign = 0
[M:CMM1] = [F:CMM]
OLDTYP   = [F:CMM]TYP
OLDSNS   = [F:CMM]SNS
#Initialisation/Affectation des globales d'engagement en fonction du site
Call AM_FCY([M]FCY)
#JHA : Vu par CP 13/01/11
#If STAT : Return : Endif
If GENGNUMLEDAFF=0
 #Aucun référentiel flagué engagement pour cette société/site
 GMESSAGE = mess(209,107,1)
 GERR=1 : Return
Endif
Gosub AFFCOL
Filter [CMD] Where NUM=[F:CMM]NUM Order By [F:CMD]ACCDAT;LIN
#For [CMD] Where NUM=[F:CMM]NUM
For [CMD]
 nolign += 1
 [M:CMM1] = [F:CMD]
 For I=1 To GENGNBAXE
  Assign "[M:CMM1]DIE("+num$(I-1)+")" With GENGAXE(I)
 Next
 For I=0 To dim([F:CMD]DIE)-1
  If [M:CMM1]DIE(I)=[F:CMD]DIE(I)
   Assign "[M:CMM1]CCE"+num$(I+1)+"("+num$(nolign-1)+")" With [F:CMD]CCE(I)
  Endif
 Next
 For I=1 To GENGNBPLAN
  Assign "[M:CMM1]COA("+num$(GENGTYPLED(I)-1)+")" With GENGPLAN(I)
 Next
 For I=0 To dim([F:CMD]COA)-1
  If [M:CMM1]COA(I)=[F:CMD]COA(I)
   Assign "[M:CMM1]ACC"+num$(I+1)+"("+num$(nolign-1)+")" With [F:CMD]ACC(I)
  Endif
 Next
 [M]AMT(nolign-1) = [F:CMD]AMTCUR
 [M]AMTCUR(nolign-1) = [F:CMD]AMTCUR
Next
Filter [CMD]
[M]NBLIG = nolign
[M]TOTAL = sum([M]AMTCUR(0..[M]NBLIG-1))
#---- Affichage montants en devises
[M:CMM1]CURAFF=[M:CMM1]CUR
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
#Initialisation des cours d'affichages
Gosub AFFRAT
Gosub GRISE_COURS
Affzo [M:CMM1]
Return


$SETBOUT
If CLECUR1="" or REP<>""
 Call VIREBOUT(CHAINE,"O") From GOBJET
Endif
# Le TYPORG détermine la pièce d'origine : verrouillage des pièces généré par le module ACHAT (TYPORG<>4)
If !find(GREP,"C","D") & [F:CMM]TYPORG<>4
 Call VIREBOUT(CHAINE,"M") From GOBJET
Endif
Case [F:CMM]TYPORG
 When 1 : CHMEN += "1" : # Commande achat
 When 2 : CHMEN += "2" : # Commande ouverte
 When 3 : CHMEN += "3" : # Demande d'achat
Endcase
If [M]TYPREF<>"" & [M]NUMREF<>""
 CHMEN += "4"
Endif
Return

$EXEBOUT
Case REP
 When "O" : Gosub DEVISE
Endcase
Return

$AVANT_MOD
#Avant de modifier, il faut repasser en devise de saisie
[M]CURAFF=[M]CUR
For I=0 To [M]NBLIG-1
 [M]AMT(I)=[M]AMTCUR(I)
Next
[M]TOTAL = sum([M]AMT(0..[M]NBLIG-1))
Affzo [M]CURAFF, AMT, TOTAL
Return

$DEVISE
Local Char LISTCUR(GLONCUR)(1..11)
Local Decimal CDIV(1..11),CMLT(1..11)
Local Integer NBCUR, N, CNUM(1..11)
Raz CDIV,CMLT,LISTCUR
LISTCUR(1)=[M]CUR
CDIV(1)=1
CMLT(1)=1
NBCUR=1
For I=0 To len(mess(0,2644,1))-1
 If [M]CURLED(I)<>"" & !find([M]CURLED(I),LISTCUR(1..11))
  NBCUR+=1
  LISTCUR(NBCUR)=[M]CURLED(I)
  CDIV(NBCUR)=[M]RATDIV(I)
  CMLT(NBCUR)=[M]RATMLT(I)
  CNUM(NBCUR)=I
 Endif
Next
N=find([M]CURAFF,LISTCUR(1..NBCUR))
If N=NBCUR : N=0 : Endif
For I=0 To [M]NBLIG-1
 If N=0
  [M]AMT(I)=[M]AMTCUR(I)
 Else
   Read [CMD]CMD0=[M]NUM;I+1
   If !fstat & [F:CMD]AMTLED(CNUM(N+1))<>0
    [M]AMT(I)=[F:CMD]AMTLED(CNUM(N+1))
   Else
    [M]AMT(I)=[M]AMTCUR(I)*CMLT(N+1)/CDIV(N+1)
   Endif
 Endif
Next
[M]TOTAL = sum([M]AMT(0..[M]NBLIG-1))
[M]CURAFF=LISTCUR(N+1)
Affzo [M]CURAFF, AMT, TOTAL
Return

$RAZDUP
$RAZCRE
Raz [M:CMM1]NUM
Affzo [M:CMM1]NUM
Grizo [M:CMM1]NUM
Return

$VERIF_CRE
$VERIF_MOD
Local Integer NOACC, NOCCE
NOACC=1 : NOCCE=1
For I=0 To [M]NBLIG-1
 For J=1 To 9
  If evalue("[M:CMM1]ACC"+num$(J)+"("+num$(I)+")")<>""
   NOACC=0 : Break 2
  Endif
 Next
Next
If NOACC
 # Vous devez définir au moins un compte par ligne
 Call MESSAGE(mess(106,104,1)) From GESECRAN
 GOK=0
 Return
Endif
For I=0 To [M]NBLIG-1
 For J=1 To 20
  If evalue("[M:CMM1]CCE"+num$(J)+"("+num$(I)+")")<>""
   NOCCE=0 : Break 2
  Endif
 Next
Next
If NOCCE
 #Vous devez définir au moins une section par ligne
 Call MESSAGE(mess(88,104,1)) From GESECRAN
 GOK=0
 Return
Endif
Return

$INICRE
## Gestion du numéro/code d'engagement ([M]NUM)
ENGCPT = ""
GSOCIETE = [M]CPY
Call LECTCA(2,OKTCA) From SUBTCA
If OKTCA
 If [F:CMM]TYP=2
  ENGCPT = [F:TCA]CODNUM(1)
 Else
  ENGCPT = [F:TCA]CODNUM(5)
 Endif
Endif
If ENGCPT="" : ENGCPT = "CMM" : Endif
#JHA0610 : Changement date (now via ligne)
Call NUMERO(ENGCPT,[M]FCY,[M]ACCDAT(0),"",[F:CMM]NUM,STAT) From SUBANM
If STAT
 Gosub MESSAGE From SUBANM
 GMESSAGE=mess(104,117,1)-"("+ENGCPT+") : "-MESSA
 GOK = 0 : Return
Endif
# Pièce non générée, créée en direct
[F:CMM]TYPORG=4
Return

$LEC_PARAM
Case [M]TYP
 When 1 : Call PARAM([M]FCY,"BUDCNTPRP",VALPAR) From ADOVAL
 When 2 : Call PARAM([M]FCY,"BUDCNTCMM",VALPAR) From ADOVAL
Endcase
CONTBUD = val(VALPAR)
If CONTBUD=4 : # Par opérateur
 Local Char LCONTBUD(10)
 Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Call PARAMUTIL("CNTBUD",LCONTBUD,"","") From SUBAUS
 CONTBUD = val(LCONTBUD)
Endif
Return

$CREATION
[M:CMM1]NUM=[F:CMM]NUM
Gosub LEC_PARAM
If [M]SNS = 1
 SNSCMM = +1
Else
 SNSCMM = -1
Endif
#Gestion des ecritures dans :
# GCOMMIT   Engagemment
# GCOMMITD  Engagemment détails
For nolign=1 To [M]NBLIG
 Raz [F:CMD]
 [F:CMD]       = [M:CMM1]
 [F:CMD]BPRACC = [M:CMM1]BPRACC(nolign-1)
 [F:CMD]FIY = [M:CMM1]FIY(nolign-1)
 [F:CMD]PER = [M:CMM1]PER(nolign-1)
 [F:CMD]LIN = nolign
 For I=0 To dim([F:CMD]DIE)-1
  [F:CMD]CCE(I) = evalue("[M:CMM1]CCE"+num$(I+1)+"("+num$(nolign-1)+")")
 Next
 For I=0 To dim([F:CMD]COA)-1
  [F:CMD]ACC(I) = evalue("[M:CMM1]ACC"+num$(I+1)+"("+num$(nolign-1)+")")
 Next
 # Gestion des montants référentiels
 For I=1 To len(mess(0,2644,1))
  K=find(I,GENGTYPLED(1..10))
  If K & [M]RATDIV(I-1)<>0
   [F:CMD]AMTLED(I-1) = [M:CMM1]AMTCUR(nolign-1)*[M]RATMLT(I-1)/[M]RATDIV(I-1)
  Endif
 Next
 Write [CMD]
 If fstat
  GOK=0 : Call FSTA("CMD") From GLOCK : Break
 Endif
 SIGN = +1
 TYPCMM = [F:CMM]TYP
 Gosub MAJBUD
  If !OK & CONTBUD>0
  If MESSA<>""
   Call MESSAGE(MESSA) From GESECRAN
  Endif
  If CONTBUD=2
   #Call MESSAGE(mess(166,105,1)-mess([F:CMD]LEDTYP(),2644,1)+chr$(10)+MESSA) From GESECRAN
   #Call MESSAGE(MESSA) From GESECRAN
   GOK = 0
   If GREP="C" | GREP="D"
    Raz [M]NUM
   Endif
   Break
  Endif
 Endif
Next nolign
Return

$MAJBUD
#V6 multi-ref : On appelle le majbud pour chaque référentiel engagement flagué budget
Local Char TBDIELED(GLONDIE)(1..dim([F:CMD]DIE))
Local Char TBCCELED(GLONCCE)(1..dim([F:CMD]CCE))
Local Char TIERSBUD(GLONBPR)
For I=0 To dim([F:CMD]LED)-1
 Call LECTURE("LED",[F:CMD]LED(I),"") From CONTOBJ
 If [F:LED]CMM=2
  Raz TBDIELED, TBCCELED
  Call SETDIECCELED([F:CMD]DIE,[F:CMD]CCE,[F:CMD]LED(I),TBDIELED,TBCCELED) From CPTDIV
  Raz TIERSBUD
  Call LECTURE("GAC",[F:CMD]ACC(I),[F:CMD]COA(I)) From CONTOBJ
  If [F:GAC]SAC=2
   TIERSBUD=[F:CMD]BPRACC
  Endif
  Call MAJBUD([F:CMD]ACCDAT,[F:CMD]FCYLIN,[F:CMD]LEDTYP(I),[F:CMM]CUR,[F:CMD]AMTCUR
&          ,[F:CMD]AMTLED(I),[F:CMD]QTY,[F:CMD]ACC(I),TIERSBUD
&          ,TBDIELED,TBCCELED,SNSCMM,SIGN,TYPCMM,CONTBUD,OK,MESSA)
& From CPTBUD
 If !OK
  If CONTBUD>0 | GREP<>"M" : Break : Endif
 Endif
 Endif
Next
Return

$MODIF
Gosub LEC_PARAM
For [CMD] Where NUM=CLECUR1
 If OLDSNS=1
  SNSCMM = +1
 Else
  SNSCMM = -1
 Endif
 SIGN = -1
 TYPCMM = OLDTYP
 Gosub MAJBUD
Next
Delete [CMD] Where NUM=CLECUR1
If fstat=1
 GOK=-1 : GLOCK="$GCOMMITD"-CLECUR1 : Return
Endif
Gosub CREATION
Return

$APRES_CRE
[M:CMM1]NUM = [F:CMM]NUM
Actzo [CMM1]NUM
Affzo [CMM1]NUM
OLDTYP = [F:CMM]TYP
OLDSNS = [F:CMM]SNS
Return

$APRES_MOD
OLDTYP = [F:CMM]TYP
OLDSNS = [F:CMM]SNS
Return

$APRES_CHOI
If REPONSE=GSTAANU
 Gosub ANNULE
 REPONSE = 0
Endif
Return

$ANNULE
Gosub VERROU From GOBJET
If !OK : Return : Endif
## Confirmation d'annulation
OK=2 : Call OUINON(mess(28,100,1),OK) From GESECRAN
If OK<>2 : Goto FIN_ANNUL : Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 CLECUR1 = "" : CLECUR = 0 : Gosub RELIT From GOBJET
Endif

$FIN_ANNUL
Unlock =SYMBOLE
Gosub DEVERROU From GOBJET
Return

$TR1
GOK=1
Trbegin [CMM] , [CMD]
 For [CMD] Where NUM=CLECUR1
  SIGN = -1
  TYPCMM = OLDTYP
  If OLDSNS=1
   SNSCMM = +1
  Else
   SNSCMM = -1
  Endif
  Gosub MAJBUD
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Delete [CMD] Where NUM=CLECUR1
 If fstat=1
  GOK=-1 : GLOCK="$GCOMMITD"-CLECUR1 : Goto ROLL_TR1
 Endif
 Delete [CMM] Where NUM=CLECUR1
 If fstat=1
  GOK=-1 : GLOCK="$GCOMMIT"-CLECUR1 : Goto ROLL_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$FIN
Call UNLOCKCPY() From AX3MONO # <JFL>
Return

######################################################################
## 080609 : Passage en multi-référentiel
$DECLARE_GLOBAL
If dim([V]GENGNBPLAN)<=0
 Global Integer GENGNBPLAN                               : # Nb de plans comptables (max 10)
 Global Integer GENGNBAXE                                : # Nb d'axes à saisir (max 20)
 Global Char    GENGPLAN(GLONCOA)(1..10)                 : # Plans (COA)
 Global Char    GENGAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
 Global Integer GENGOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
 Global Integer GENGNBTYPLED                             : # Nb référentiels <> pour la société (pour init sections)
 Global Char    GENGLED(GLONLED)(1..10)                  : # référentiels
 Global Integer GENGTYPLED(1..10)                        : # Types référentiels
 Global Integer GENGNUMLEDAFF                            : # Numéro de référentiel utilisé pour l'affichage du cours
 Global Char    GENGCURLED(GLONCUR)(1..10)               : # Liste de devise par référentiel
Endif
Return

Subprog INI_GLOBAL(SOCIETE,STAT,MESSA)
Value    Char    SOCIETE() : # Société
Variable Integer STAT      : # Statut erreur
Variable Char    MESSA()   : # Message erreur
# Initialisation des globales en fonction de la société(site)
# permet de récupérer toute les données liés aux référentiels flagués engagements
# (types de référentiels, plans, axes )
GENGNUMLEDAFF=0
Call SETLED(SOCIETE,GENGNBTYPLED,GENGTYPLED,GENGLED,GENGCURLED,STAT,MESSA)
If STAT : End : Endif
Call SETPLANAXE2(SOCIETE,GENGNBTYPLED,GENGTYPLED,GENGNBPLAN,GENGPLAN,GENGNBAXE,GENGAXE,GENGOBLIG) From CPTDIV
GENGNBTYPLED = GENGNBPLAN
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
GSOCIETE = SOCIETE
If dim([M]DIE)>0
 For I=0 To GENGNBAXE-1
  [M]DIE(I)=GENGAXE(I+1)
 Next
 For I=1 To len(mess(0,2644,1))
  K=find(I,GENGTYPLED(1..10))
  If K
   [M]COA(I-1)=GENGPLAN(K)
  Endif
 Next
Endif
I=find(GTYPANA,GENGTYPLED(1..10))
If I
 GENGNUMLEDAFF=GTYPANA
Else
 GENGNUMLEDAFF=GENGTYPLED(1)
Endif
End

# Renvoie les types de référentiels à gérer pour une société (flagué engagement)
Subprog SETLED(SOCIETE,NBLED,LEDTYP,LED,CURLED,STAT,MESSA)
Value    Char    SOCIETE       : # Société ou site
Variable Integer NBLED         : # Nb de référentiels
Variable Integer LEDTYP(1..)   : # Liste types référentiels
Variable Char    LED()(1..)    : # Liste référentiels
Variable Char    CURLED()(1..) : # Liste devises
Variable Integer STAT          : # Statut retour
Variable Char    MESSA()       : # Message d'erreur
Local Integer I
STAT = 0
Raz NBLED, LEDTYP
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Read [GCM]GCM0 = [F:CPY]ACM
If !fstat
 For I=0 To dim([F:GCM]LED)-1
  If [F:GCM]CFMAUT(I)<>2
   Call LECTURE("LED",[F:GCM]LED(I),"") From CONTOBJ
   If [F:LED]CMM=2
    If dim([M:CMM1]LEDTYP)>0
     [M:CMM1]LEDTYP(I)=I+1
     [M:CMM1]LED(I)=[F:GCM]LED(I)
     [M:CMM1]CURLED(I)=[F:GCM]CUR(I)
    Endif
    NBLED +=1
    LEDTYP(NBLED) = I+1
    LED(NBLED)    = [F:GCM]LED(I)
    CURLED(NBLED) = [F:GCM]CUR(I)
   Else
    If dim([M:CMM1]LEDTYP)>0
     [M:CMM1]LEDTYP(I)=0
    Endif
   Endif
  Endif
 Next
Else
 STAT=1
Endif
If NBLED=0
 STAT=1
 #Aucun référentiel flagué engagement pour cette société/site
 MESSA=mess(209,107,1)
Endif
End

$AFFRAT
If [M]RATDAT=[0/0/0] : [M]RATDAT = datesyst : Endif    # Issue X3-101787
[M]RAT1   = [M]RATDIV(GENGNUMLEDAFF-1)
[M]LABEL  = [M]CUR-"="
[M]CURDIV = [M]CUR : # Zone invisible
[M]RAT2   = [M]RATMLT(GENGNUMLEDAFF-1)
[M]CURMLT = [M]CURLED(GENGNUMLEDAFF-1)
Return

$AFFCOL
Local Char FMT(10)
Local Integer I
#Gestion de l'affichage des colonnes de comptes
For I=1 To len(mess(0,2644,1))
 K=find(I,GENGTYPLED(1..10))
 If K
  Call LECTURE("COA",evalue("GENGPLAN("+num$(K)+")"),"") From CONTOBJ
  Call LECTEXTRA([M]INTCOA(I-1),"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
  Gosub INTIT_ACC
  Call INIACCFMT([F:COA]COA) From SETGLBCOA
  FMT = "K:"+GFMTACC
  Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
 Else
  FMT = "-K:10X"
  Assign "[M]FMTCOA("+num$(I-1)+")" With FMT
 Endif
Next
#Gestion de l'affichage des colonnes des sections
For I=1 To GENGNBAXE
 Call LECTURE("DIE",evalue("GENGAXE("+num$(I)+")"),"") From CONTOBJ
 Call LECTEXTRA([M]INTDIE(I-1),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
 Gosub INTIT_CCE
 Call INICCEFMT([F:DIE]DIE) From SETGLBDIE
 Call SAI_AMONT([M]CPY,GENGNBTYPLED,GENGTYPLED,evalue("GENGAXE("+num$(I)+")"),[M]SAIAXE(I-1)) From CPTDIV
 If [M]SAIAXE(I-1)=2
  FMT = "K:"+GCCEFMT
 Else
  FMT = "-K:"+GCCEFMT
 Endif
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
Next
For I=GENGNBAXE+1 To dim([M]FMTDIE)
 FMT = "-K:10X"
 Assign "[M]FMTDIE("+num$(I-1)+")" With FMT
Next
zoncou = "NBLIG"
Gosub CHG_FMT From W1CMM1
[M]NBLIG=1
Affzo ACC1, ACC2, ACC3, ACC4, ACC5, ACC6, ACC7, ACC8, ACC9, ACC10
Affzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
Affzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
[M]NBLIG=0
Effzo ACC1, ACC2, ACC3, ACC4, ACC5, ACC6, ACC7, ACC8, ACC9, ACC10
Effzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE10, CCE11, CCE12
Effzo CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
Return

$INTIT_ACC
Case I
 When 1  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC1
 When 2  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC2
 When 3  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC3
 When 4  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC4
 When 5  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC5
 When 6  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC6
 When 7  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC7
 When 8  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC8
 When 9  : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC9
 When 10 : Titcol [M]NBLIG [M]INTCOA(I-1) For ACC10
Endcase
Return

$INTIT_CCE
Case I
 When 1  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE1
 When 2  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE2
 When 3  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE3
 When 4  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE4
 When 5  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE5
 When 6  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE6
 When 7  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE7
 When 8  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE8
 When 9  : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE9
 When 10 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE10
 When 11 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE11
 When 12 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE12
 When 13 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE13
 When 14 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE14
 When 15 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE15
 When 16 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE16
 When 17 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE17
 When 18 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE18
 When 19 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE19
 When 20 : Titcol [M]NBLIG [M]INTDIE(I-1) For CCE20
Endcase
Return

