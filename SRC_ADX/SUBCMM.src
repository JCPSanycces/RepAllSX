Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
# En création ou duplication: automatisation du numéro d'engagemment
If (GREP="" or GREP="C" or GREP="D") & VALEUR<>""
 Look [CMM]CMM0 = VALEUR
 If fstat : VALEUR = "" : End : Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
If GREP="" & VALEUR=""
 mkstat = 4
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call INIFCY(VALEUR,"") From CPTSUB
 If VALEUR<>"" : Gosub SETSOC : Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Local Char    MESSA(100)
# Issue X3-107417 by MRDAB - problem with site on lines
Local Char    OLD_CPY(GLONCPY)
[L]OLD_CPY = [M:CMM1]CPY
# Issue X3-107417 end
Raz [M:CMM1]CPY, [M:CMM1]FIY, [M:CMM1]PER
Gosub SETSOC
# Multi-réf
Call INI_GLOBAL([M]CPY,STAT,MESSA)
Gosub AFFCOL
# Issue X3-107417 by MRDAB - problem with site on lines
If [L]OLD_CPY <> [M:CMM1]CPY
  Effzo [M:CMM1]20
  Effzo [M:CMM1]TOTAL
Endif
# Issue X3-107417 end
End

$SETSOC
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Return

Subprog D_ACCDAT(VALEUR)
Variable Date    VALEUR
VALEUR = datesyst
End

Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXERCICE, PERIODE
#-> KC Nouveau Ctrl Dates par Module
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
 If mkstat : End : Endif
Endif
#<-KC
Call GETEXE([M]CPY,[M]LEDTYP(GENGNUMLEDAFF-1),VALEUR,EXERCICE) From CPTSUB
If fstat | EXERCICE=0 | [F:FIY]FIYSTA<>2
 # Exercice non ouvert
 GMESSAGE = mess(20,101,1)
 mkstat = 2 : End
Endif
Call GETPER([M]FCY,[M]LEDTYP(GENGNUMLEDAFF-1),VALEUR,EXERCICE,PERIODE) From CPTSUB
If !find(GREP,"C","D") & [F:CMM]TYPORG<>4 & [M]NBLIG<>0
 Read [CMD]CMD0=[F:CMM]NUM;nolign
 If !fstat & [F:CMD]FIY<>EXERCICE
  # Changement d'exercice interdit
  GMESSAGE = mess(5,106,1)
  mkstat = 2 : End
 Endif
Endif
If fstat | PERIODE=0 | [F:PER]PERSTA<>2
 # Période non ouverte
 GMESSAGE = mess(35,101,1)
 mkstat = 2 : End
Endif
[M:CMM1]FIY(nolign-1)=EXERCICE
[M:CMM1]PER(nolign-1)=PERIODE
[M:CMM1]ACCDAT(nolign-1)=VALEUR
Affzo [M]
End

Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG : mkstat=2 : End : Endif
If dim(GENGCURLED)>0 & VALEUR=""
 VALEUR=[M]CURLED(GENGNUMLEDAFF-1)
 Call AM_CUR(VALEUR)
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Call CONTDEV(VALEUR,[M]ACCDAT) From TRTDEV
End

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CUR = VALEUR
 [M]CURAFF = VALEUR
 Gosub CHARG_ZONES_DEV
Endif
End

Subprog AM_TYPCUR(VALEUR)
Variable Integer VALEUR
[M]TYPCUR=VALEUR
If (GREP="C" | GREP="D") & [M]CUR<>""
 Gosub CHARG_ZONES_DEV
Endif
End

Subprog AM_RAT1(VALEUR)
Variable Decimal VALEUR
[M]RATDIV(GENGNUMLEDAFF-1) = VALEUR
For I=0 To dim([M]CURLED)-1
 If I<>GENGNUMLEDAFF-1 & [M]CURLED(I)=[M]CURLED(GENGNUMLEDAFF-1)
  [M]RATDIV(I) = VALEUR
 Endif
Next
End

Subprog AM_RAT2(VALEUR)
Variable Decimal VALEUR
[M]RATMLT(GENGNUMLEDAFF-1) = VALEUR
For I=0 To dim([M]CURLED)-1
 If I<>GENGNUMLEDAFF-1 & [M]CURLED(I)=[M]CURLED(GENGNUMLEDAFF-1)
  [M]RATMLT(I) = VALEUR
 Endif
Next
End

#####################################################################################################
#--------------------------------------------------#
# Saisie cours devises                             #
#--------------------------------------------------#
#--------------------------------------------------#
# [M]RATDIV  : Cours diviseur                      #
# [M]LABEL   : Libellé devise pièce Ex: USD =      #
# [M]CURDIV  : Devise pièce                        #
# [M]RATMLT  : Cours multiplicateur                #
# [M]CURMLT  : Devise référentiel général principal#
#--------------------------------------------------#
# Exemple : devise pièce = USD ; devise référentiel = EUR
# Cours diviseur...
#    On va saisir : 1 USD = 2 EUR
#    Standard (1) : le cours saisi est par rapport à la devise de pièce
#    Cas particulier (2) : Devise de pièce est IN et différent de EURO avec une devise de référentiels OUT
#                       => saisi des cours par rapport à l'euro
# Cours multiplicateur...
#    On va saisir : 0.5 USD = 1 EUR
#    Standard (3) : le cours saisi est par rapport à la devise de référentiel
#    Cas particulier (4) : Devise de référentiels est IN et différent de EURO avec une devise de pièce OUT
#                       => saisi des cours par rapport à l'euro
# Les deux...
#    On pourra alors saisir : 2 USD = 4 EUR
$CHARG_ZONES_DEV
Local Integer STAT

If [M]RATDAT=[0/0/0] : [M]RATDAT = datesyst : Endif    # Issue X3-101787

# Position des devises par rapport à l'Euro
Call SETFLGDEV([M]CUR,[M]CPY,[M]RATDAT) From CPTDIV

For J=0 To dim([M]CURLED)-1
 If [M]CURLED(J)<>""
  If [M]CURLED(J)=[M]CUR
   [M]RATDIV(J) = 1
   [M]RATMLT(J) = 1
  Elsif [M]CURLED(J)<>[M]CUR
   Gosub INIT_COURS
  Endif
 Endif
Next

[M]RAT1   = [M]RATDIV(GENGNUMLEDAFF-1)
[M]LABEL  = [M]CUR-"="
[M]CURDIV = [M]CUR : # Zone invisible
[M]RAT2   = [M]RATMLT(GENGNUMLEDAFF-1)
[M]CURMLT = [M]CURLED(GENGNUMLEDAFF-1)

Gosub GRISE_COURS
Affzo RATDIV, LABEL, CURDIV, RATMLT, CURMLT , RAT1, RAT2
Return

$INIT_COURS
Local Decimal COURS
If J>9 : Return : Endif
If [M]LEDTYP(J)<1 : Return : Endif
If [F:GCM]FLGVCRRAT([M]LEDTYP(J)-1)=2
 COURS = [M]TYPCUR
Else
 COURS = [F:GCM]TYPRAT([M]LEDTYP(J)-1)
Endif
Case [F:GCM]DACRAT([M]LEDTYP(J)-1)
 When 1,3 :
  # Multiplicateur
  If [M]RATDIV(J)=0
   [M]RATDIV(J)=1
  Endif
  # CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
  Call CONVERT([M]CUR,[M]CURLED(J),[F:CPY]ACCCUR,COURS,[M]RATDAT,10^GDECRCU,[M]RATMLT(J),STAT) From TRTDEV
  If !STAT
   [M]RATMLT(J)  = arr([M]RATMLT(J)/10^GDECRCU, 10^-GDECRCU)
  Endif
 When 2 :
  # Diviseur
  If [M]RATMLT(J)=0
   [M]RATMLT(J)=1
  Endif
  Call CONVERT([M]CURLED(J),[M]CUR,[F:CPY]ACCCUR,COURS,[M]RATDAT,10^GDECRCU,[M]RATDIV(J),STAT) From TRTDEV
  If !STAT
   [M]RATDIV(J)  = arr([M]RATDIV(J)/10^GDECRCU, 10^-GDECRCU)
  Endif
Endcase
Return

#--------------------------------------------------#
# Grisage des cours saisis                         #
#--------------------------------------------------#
# [M]RAT1, [M]RATDIV(10) : Cours diviseur          #
# [M]RAT2, [M]RATMLT(10) : Cours multiplicateur    #
#--------------------------------------------------#
## En gestion de facture, on n'affiche dans l'en-tête uniquement le cours entre la devise de transaction
## et la devise du référentiel général principal. Les cours des autres référentiels sont accessibles via
## le bouton 'Cours devises'
$GRISE_COURS
If [M]LEDTYP(GENGNUMLEDAFF-1)<1 : Return : Endif
Case [F:GCM]DACRAT([M]LEDTYP(GENGNUMLEDAFF-1)-1)
 When 1 :
  # Multiplicateur
  [M]RAT1 = 1 : Diszo [M]RAT1 : Actzo [M]RAT2
 When 2 :
  # Diviseur
  [M]RAT2 = 1 : Diszo [M]RAT2 : Actzo [M]RAT1
 When 3 :
  # Les deux
  Actzo [M]RAT1, RAT2
Endcase
# Devise IN
If GCURFLG=2 and GLEDFLG([M]LEDTYP(GENGNUMLEDAFF-1))=2
 Diszo [M]RAT1, RAT2
Endif
Return

