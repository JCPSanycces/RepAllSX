Subprog AS_CCE(AXE,VALEUR)
Value    Integer AXE      : # N° ordre axe
Variable Char    VALEUR() : # Section analytique
Gosub SETNOL
Local Char    COMPTE(GLONGAC)
Local Integer TLED
mkstat = 1
For I=1 To len(mess(0,2644,1))
 K=find(I,GENGTYPLED(1..10))
 If K
  COMPTE = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
  If COMPTE<>""
   Call LECTURE("GAC",COMPTE,[M]COA(I-1)) From CONTOBJ
   If find(GENGAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
  Endif
 Endif
Next
End

