#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone VLYNBR
mkstat = 0
zoncou = "VLYNBR"
indice = 0
status = 1
zoncou = "VLYNBR"
If varmode([M]VLYNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]VLYNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]VLYNBR = nolign
   status = 75
   Call SAI_VLYNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_VLYNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone VLYNBR
mkstat = 0
zoncou = "VLYNBR"

## Zone VLYDTALVL
mkstat = 0
zoncou = "VLYDTALVL"
IMPENT = [M]VLYDTALVL(indice)
If varinit([M]VLYDTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]VLYDTALVL,indice)=0
 [M]VLYDTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYDTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]VLYDTALVL(indice)
 Endif
Endif
[M]VLYDTALVL(indice) = IMPENT

## Zone VLYTYP
mkstat = 0
zoncou = "VLYTYP"
IMPENT = [M]VLYTYP(indice)
If varinit([M]VLYTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]VLYTYP,indice)=0
 [M]VLYTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]VLYTYP(indice)
 Endif
Endif
[M]VLYTYP(indice) = IMPENT

## Zone VLYOPT
mkstat = 0
zoncou = "VLYOPT"
IMPENT = [M]VLYOPT(indice)
If varinit([M]VLYOPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]VLYOPT,indice)=0
 [M]VLYOPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYOPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]VLYOPT(indice)
 Endif
Endif
[M]VLYOPT(indice) = IMPENT

## Zone VLYCDN1
mkstat = 0
zoncou = "VLYCDN1"
If varmode([M]VLYCDN1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYCDN1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone VLYSETFLD
mkstat = 0
zoncou = "VLYSETFLD"
If varmode([M]VLYSETFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYSETFLD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone VLYVALCLC
mkstat = 0
zoncou = "VLYVALCLC"
If varmode([M]VLYVALCLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYVALCLC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone VLYMSG
mkstat = 0
zoncou = "VLYMSG"
If varmode([M]VLYMSG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLYMSG" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone VLYNBR
mkstat = 0
zoncou = "VLYNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENHREXT4"
Return

