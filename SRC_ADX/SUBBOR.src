###########################################################################################################
# Issue 74332 - 2018-02-09 by NEHAR : Added functionality to allow the user to maintain the Setup Level &
#                                     Tolerance Levels during component Replacement

Subprog AV_VALID(VALEUR)
Variable Integer VALEUR

# If we aren't weighing (PKC = 1), disable the setup level and tolerance Fields
# If we are weighing but not with a BOM setup level(LEVSET <> 4), disable the tolerance fields
  If [M:BOR1]PKC(nolign-1) = 1
      Grizo [M:BOR1]LEVSET(nolign-1)
      Grizo [M:BOR1]ITMTOLPOS(nolign-1)
      Grizo [M:BOR1]ITMTOLNEG(nolign-1)
  Elsif [M:BOR1]LEVSET(nolign-1) <> 4
        Grizo [M:BOR1]ITMTOLPOS(nolign-1)
        Grizo [M:BOR1]ITMTOLNEG(nolign-1)
  Endif

  Call AM_PKC([M:BOR1]LEVSET(nolign-1))
End


######################################################################################

Subprog AM_PKC(VALEUR)
Variable Integer VALEUR

  #CATUA X3-91303.sn Blank out container code if not weighed at station
  If dim([M:BOR1]CTN(nolign-1))>0
    If !find(VALEUR,2,4,6)
      [M:BOR1]CTN(nolign-1) = ""
      Affzo[M:BOR1]CTN(nolign-1)
    Endif
  Endif
  #CATUA X3-91303.en

# If the component isn't being weighed (LEVSET = 1), clear the setup level & tolerances & disable the fields
# otherwise activate the fields, then go find and display the tolerances levels
   If VALEUR = 1
      [M:BOR1]LEVSET(nolign-1) = 1
      Effzo [M:BOR1]LEVSET(nolign-1)
      Effzo [M:BOR1]ITMTOLPOS(nolign-1)
      Effzo [M:BOR1]ITMTOLNEG(nolign-1)
      Grizo [M:BOR1]LEVSET(nolign-1)
      Grizo [M:BOR1]ITMTOLPOS(nolign-1)
      Grizo [M:BOR1]ITMTOLNEG(nolign-1)

    Else
      If [M:BOR1]PKC(nolign-1) <> VALEUR and [M:BOR1]LEVSET(nolign-1) = 1 Then
         [M:BOR1]LEVSET(nolign-1) = 2
         Affzo [M:BOR1]LEVSET(nolign-1)
      Endif

      Actzo [M:BOR1]LEVSET(nolign-1)
      Actzo [M:BOR1]ITMTOLPOS(nolign-1)
      Actzo [M:BOR1]ITMTOLNEG(nolign-1)

      Call AM_LEVSET([M:BOR1]LEVSET(nolign-1))
   Endif
End

######################################################################################

Subprog AS_LEVSET(VALEUR)
Variable Integer VALEUR

# If we aren't weighing anything (PKC = 1), don't allow access to the setup level; field
  If [M:BOR1]PKC(nolign-1) = 1 : mkstat = 1 : Endif

# If ther picking list code is a Material Correction, allow blank as a setup level option,
# otherwise remove the blank option from setup level choices
  If find ([M]PKC(nolign-1),8,9)
    GMENLOC(1) = 0
  Else
    GMENLOC(1) = 1
  Endif
End

######################################################################################

Subprog AM_LEVSET(VALEUR)
Variable Integer VALEUR

# If we're weighing and the setup level is a blank, show error and force user to choose
  If ! find ([M]PKC(nolign-1),1,8,9) & VALEUR = 1
    mkstat = 2 : GMESSAGE = mess(10,123,1)
  Endif

  If clalev ([F:HSH])=0  Local File HANDLING [HSH] Endif

# Based on the setup level, clear the tolerance levels or get them and display them
  Case VALEUR
    When 1: Effzo [M:BOR1]ITMTOLPOS(nolign-1)
            Effzo [M:BOR1]ITMTOLNEG(nolign-1)

    When 2: Raz [M:BOR1]ITMTOLPOS(nolign-1), [M:BOR1]ITMTOLNEG(nolign-1)
            Read [TBO]TBO0 = [M:BOR1]BOMALTTYP(nolign-1);[M:BOR1]BOMALT(nolign-1)
            If !fstat
              Read [ITF]ITF0= [M:BORH]UPDCPN;[TBO]FCY
              If !fstat
                Read [HSH]HSH0 = [F:ITF]ISM
                If !fstat
                  [M:BOR1]ITMTOLPOS(nolign-1) = [F:HSH]ITMTOL
                  [M:BOR1]ITMTOLNEG(nolign-1) = [F:HSH]ITMTOLNEG
                Endif
              Endif
            Endif

            Affzo [M:BOR1]ITMTOLPOS(nolign-1)
            Affzo [M:BOR1]ITMTOLNEG(nolign-1)
            Grizo [M:BOR1]ITMTOLPOS(nolign-1)
            Grizo [M:BOR1]ITMTOLNEG(nolign-1)

    When 3: Raz [M:BOR1]ITMTOLPOS(nolign-1), [M:BOR1]ITMTOLNEG(nolign-1)
            Read [TBO]TBO0 = [M:BOR1]BOMALTTYP(nolign-1);[M:BOR1]BOMALT(nolign-1)
            If !fstat
              Read [ITF]ITF0= [M:BORH]UPDCPN;[TBO]FCY
              If !fstat
                [M:BOR1]ITMTOLPOS(nolign-1) = [ITF]ITMTOLPOS
                [M:BOR1]ITMTOLNEG(nolign-1) = [ITF]ITMTOLNEG
              Endif
            Endif

            Affzo [M:BOR1]ITMTOLPOS(nolign-1)
            Affzo [M:BOR1]ITMTOLNEG(nolign-1)
            Grizo [M:BOR1]ITMTOLPOS(nolign-1)
            Grizo [M:BOR1]ITMTOLNEG(nolign-1)

    When 4: Actzo [M:BOR1]ITMTOLPOS(nolign-1)
            Actzo [M:BOR1]ITMTOLNEG(nolign-1)
  Endcase
End

#CATUA X3-91303.sn
#Manage container fields in BOM replacement screen
Subprog AV_CTN(VALEUR)
Variable Char VALEUR()
  If dim([M:BOR1]CTN(nolign-1))>0 & dim([M:BOR1]PKC(nolign-1))>0
    If find([M:BOR1]PKC(nolign-1),2,4,6)
      Actzo [M:BOR1]CTN(nolign-1)
    Else
      Grizo [M:BOR1]CTN(nolign-1)
    Endif
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

Subprog AM_CTN(VALEUR)
Variable Char VALEUR()
  If dim([M:BOR1]CTN(nolign-1))>0 & dim([M:BOR1]PKC(nolign-1))>0
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

#Show display only fields 'container weight unit' and 'container capacity'
Subprog DISP_CTN_FLDS(CTNCODE)
Value Char CTNCODE
  Local Integer ISEMPTY

  ISEMPTY=1
  If clalev ([F:CTN])=0  Local File CONTAINERS [CTN] Endif
  If CTNCODE<>""
    Read [CTN]CTN0=CTNCODE
    If !fstat
      ISEMPTY=0
      [M:BOR1]CTNWEU(nolign-1) = [CTN]CTNWEU
      [M:BOR1]CTNCAP(nolign-1) = [CTN]CTNCAP
    Endif
  Endif

  If ISEMPTY
    Raz [M:BOR1]CTNWEU(nolign-1)
    Raz [M:BOR1]CTNCAP(nolign-1)
  Endif

  Affzo [M:BOR1]CTNWEU(nolign-1)
  Affzo [M:BOR1]CTNCAP(nolign-1)
End
#CATUA X3-91303.en

