#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################
# remplacement composant
# La saisie initiale est une saisie de FENETRE sous "forme" de dialogue
#######################################################################
# Fenêtre principale :
# Affichage / modif / Validation des nouveaux liens de nomenclatures
# les masques de validation sont les mêmes que pour la suppression (BOMRPL1, BOMRPL2, BOMRPL3)
# GA 24/11/2005 remplacement d'un composant nomenclature de sous-traitance
#######################################################################
# Issue X3-58261 - 2017-10-06 by BAKHA : added entry/validation actions major/minor version for components
# Issue X3-60359 - 2017-10-19 by BAKHA : write not selected versioned BOMs to log

$ACTION
Case ACTION
    When "INIT"     : Gosub INIT
    When "CONTROLE" : Gosub CONTROLE
    When "EXEC"     : Gosub EXEC
    When "TERMINE"  : Gosub TERMINE
    When "SORTIE"   : Gosub SORTIE
    When "DEBUT"    : If BOITE = "FBOMRPL" : Gosub DEBUTRPL : Else : Gosub DEBUT : Endif
    When "END","ABA": PARAM(1) = "END"

    # GH 06/06/2016 bug 113255 - File updates are managed through the action OK (instead of EXEC)
    When "OK"       : If BOITE = "FBOMRPL" : Gosub VALID : Endif
Endcase
Return

#######################################################################
$INIT
Local    Integer OK
Local    Char    TEX(15)(30) : #,  ERR_TRA(132)

If clalev([F:ACC]) = 0 : Local File ACCES     [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM    [ITB] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ITS]) = 0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD      [BOD] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO] : Endif

# Issue 74332 - 2018-02-08 by NEHAR : Open Item facility table for validating tolerances
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif


Local Mask BOMRPL0 [BOR0]
Return

#######################################################################
$CONTROLE
# paramètre en retour de la fenêtre initiale
If PARAM(1) = "END"
  FIN = 1
  Return
Endif

# ouverture préalable des masques pour le chargement
If clalev([M:BORH]) = 0 : Local Mask BOMRPLH [BORH] : Endif : # pour entête d'écran résultat
If clalev([M:BOR1]) = 0 : Local Mask BOMRPL1 [BOR1] : Endif : # pour alternatives de prod
If clalev([M:BOR2]) = 0 : Local Mask BOMRPL2 [BOR2] : Endif : # pour alternatives commerc
If clalev([M:BOR3]) = 0 : Local Mask BOMRPL3 [BOR3] : Endif : # pour alternatives de sous-traitance
Raz [BOR1], [BOR2], [BOR3]

Default Mask [BOR0]
OK = 1

Call EXTRACT(OK)

# erreur d'accès sur fichier entête de nomenclature ...
If OK = 0
    GMESSAGE = mess(12,100,1)-"BOM:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)
    GERR = 1
    Return
Endif

If [M:BOR1]NBLIG = 0 & [M:BOR2]NBLIG = 0 & [M:BOR3]NBLIG = 0
    GMESSAGE = mess(113,199,1)
    GERR = 1
Endif

If GERR <> 1  : TMP = 1 : Endif

Return

#######################################################################
$EXEC
# si on a cliqué 'Fin' dans la fenêtre principale, on ne fait rien  :
If PARAM(1) = "END"
    SAI = 1
    Raz PARAM(1)
    Raz [M:BOR0]
#Else
#    Gosub VALID # GH 06/06/2016 bug 113255 - File update are managed through the action OK (instead of EXEC)
  # Issue X3-60359 - If using ECC and log opened, then delete log
  If func AFNC.ACTIV("ECC")
    If GTRACE <> ""
      Call FERME_TRACE From LECFIC
    Endif
  Endif
  # Issue X3-60359 end
Endif
Return

#######################################################################
$TERMINE
Close Local Mask [BORH], [BOR1], [BOR2], [BOR3]
Raz [M:BOR0]
[M:BOR0]APPDAT = date$
#TRA = 1 : # GH 06/06/2016 bug 113255 - log trace is displayed through action OK (instead of EXEC)
SAI = 1
Return

#######################################################################
$SORTIE
Raz GFONBOD
Raz [M:BOR0]
Return

#######################################################################
$DEBUT
[M:BOR0]APPDAT = date$
Affzo [M:BOR0]
Return

#######################################################################
$DEBUTRPL
# Affichage des ecrans de validation  "Résultat remplacement"
[M:BORH] = [M:BOR0]
Affzo [BORH]
Affzo [BOR1]
Affzo [BOR2]
Affzo [BOR3]

Diszo [BORH]RPLCPN, UPDCPN
If [M:BOR1]NBLIG = 0 : Grizo [M:BOR1] : Endif
If [M:BOR2]NBLIG = 0 : Grizo [M:BOR2] : Endif
If [M:BOR3]NBLIG = 0 : Grizo [M:BOR3] : Endif

# Issue X3-58261 - display info message if using versioning
If func AFNC.ACTIV("ECC")
  Call MESSAGE (mess(414,193,1)) From GESECRAN
Endif
# Issue X3-58261 - end

Return

#######################################################################
$FILTRE

Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2

XCRITERE1 = "1=1"

If [M]ITMREFDEB <> ""
    XCRITERE = "[F:BOH]ITMREF >= [M]ITMREFDEB"
    Gosub LOAD_CRITERE
Endif

If [M]ITMREFFIN <> ""
    XCRITERE = "[F:BOH]ITMREF <= [M]ITMREFFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTTYPDEB <> 1 | [M]ALTTYPFIN <> 3)
    XCRITERE = "[F:BOH]BOMALTTYP >= [M]ALTTYPDEB & [F:BOH]BOMALTTYP <= [M]ALTTYPFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTDEB <> 0 | [M]ALTFIN <> 0)
    XCRITERE = "[F:BOH]BOMALT >= [M]ALTDEB & [F:BOH]BOMALT <= [M]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return

############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif
Return

#######################################################################
# Ce sous-pro extrait les enreg selon les sélections et charge [M]
Subprog EXTRACT(OK)
Variable Integer OK
Local    Integer ILIG, JLIG, KLIG, NBTEX
Local    Char    XCRITERE(255)
Local    Char    XCRITERE1(255)
Local    Char    XCRITERE2(255)
Local    Char    FORMULE1(255)
# Issue X3-58261 - check ECC activity
Local Integer WACTECC : WACTECC = func AFNC.ACTIV("ECC")
# Issue X3-58261 - end

Gosub FILTRE
If XCRITERE2 = "" : XCRITERE2 = "1=1" : Endif

# analyse présence formule de sélection
If [M]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=31;[M]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

ILIG=0 : JLIG=0 : KLIG=0

Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP, [ITM]ITM0=[F:BOD]ITMREF,
&               [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT As [BODX]
&          Where CPNITMREF = [M:BOR0]RPLCPN &
&                BOMSTRDAT < [M:BOR0]APPDAT &
&               (BOMENDDAT > [M:BOR0]APPDAT | BOMENDDAT=[0/0/0]) &
&               evalue(XCRITERE1) & evalue(XCRITERE2) & evalue(FORMULE1)

For [BODX]
  # Issue X3-58261 - if using versioning then ignore any versioned BOMs
  If !WACTECC | func ECCLIB.NBRCPN([F:BOH]ITMREF) = 0
      Gosub CHARG_ECR
      If OK = 0 : Break : Endif
  Else
    # Issue X3-60359 - 2017-10-24 by JUSYN : if no trace file open to open it already here to log versioned BOMs
    If GTRACE = ""
      Call OUVRE_TRACE(mess(115,199,1)) From LECFIC
      Call PRTSCR("BOMRPL0","BOR0","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(mess(414,193,1),0) From GESECRAN
    Endif
    # Issue X3-60359 end
    # Issue X3-60359 - Write BOM to log
    Call ECR_TRACE(mess(153,198,1)-mess([F:BOD]BOMALTTYP,224,1)-[F:BOD]ITMREF+"/"+num$([F:BOD]BOMALT)+"/"+num$([F:BOD]BOMSEQ)
&               -mess(420,193,1),0) From GESECRAN
    # Issue X3-60359 end
  Endif
  # Issue X3-58261 - end
Next

[M:BOR1]NBLIG = ILIG
[M:BOR2]NBLIG = JLIG
[M:BOR3]NBLIG = KLIG

End

#######################################################################
$CHARG_ECR

Raz mkstat

# vérifier droit de modif sur alternative
Call CTLMODALT([F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM
Raz GMESSAGE
If mkstat : Return : Endif

Case [F:BOH]BOMALTTYP
    When 1:    # nomenclature commerciale
               JLIG += 1
               nolign = JLIG

               # trop de liens d'alternative commerciale
               If JLIG > dim([M:BOR2]VALID)
                   JLIG -= 1
                   GMESSAGE = mess(188,199,1)
                   GERR = 2
               Else
                   [M:BOR2] = [F:BOD]
                   [M:BOR2]VALID(nolign-1)  = 2
                   If [F:BOD]ITMREF = [M:BOR0]UPDCPN
                       [M:BOR2]VALID(nolign-1) = 1
                   Endif
#                   [M:BOR2]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                   [M:BOR2]BOHSTU(nolign-1) = [F:ITM]SAU
                   [M:BOR2]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                   [M:BOR2]BASQTY(nolign-1) = [F:BOH]BASQTY
                   [M:BOR2]LIKQTY(nolign-1) = [F:BOD]LIKQTY * [M:BOR0]QTYCOE
                   [M:BOR2]BOMSTRDAT(nolign-1) = [M:BOR0]APPDAT
               Endif
    When 2:    # nomenclature de production
               ILIG += 1
               nolign = ILIG

               # trop de liens d'alternative de production
               If ILIG > dim([M:BOR1]VALID)
                   ILIG -= 1
                   GMESSAGE =mess(187,199,1)
                   GERR = 2
               Else
                   [M:BOR1] = [F:BOD]
                   [M:BOR1]VALID(nolign-1)  = 2
                   If [F:BOD]ITMREF = [M:BOR0]UPDCPN
                       [M:BOR1]VALID(nolign-1) = 1
                   Endif
#                   [M:BOR1]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                   [M:BOR1]BOHSTU(nolign-1) = [F:ITM]STU
                   [M:BOR1]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                   [M:BOR1]BASQTY(nolign-1) = [F:BOH]BASQTY
                   [M:BOR1]LIKQTY(nolign-1) = [F:BOD]LIKQTY * [M:BOR0]QTYCOE
                   [M:BOR1]BOMSTRDAT(nolign-1) = [M:BOR0]APPDAT

                   #  process 03.03 MM
                   If dim([M:BOR1]BOMQTY(nolign-1))>0
                       [M:BOR1]BOMQTY(nolign-1) = [M:BOR1]LIKQTY(nolign-1)
                       Raz [M:BOR1]BOMUOM(nolign-1),[M:BOR1]BOMSTUCOE(nolign-1)
                   Endif
               Endif
    When 3:    # nomenclature sous-traitance
               KLIG += 1
               nolign = KLIG

               # trop de liens d'alternative commerciale
               If KLIG > dim([M:BOR3]VALID)
                   KLIG -= 1
                   GMESSAGE =mess(188,199,1)
                   GERR = 2
               Else
                   [M:BOR3] = [F:BOD]
                   [M:BOR3]VALID(nolign-1)  = 2
                   If [F:BOD]ITMREF = [M:BOR0]UPDCPN
                       [M:BOR3]VALID(nolign-1) = 1
                   Endif
#                   [M:BOR3]ITMDES1(nolign-1)= [F:ITM]ITMDES1
                   [M:BOR3]BOHSTU(nolign-1) = [F:ITM]SAU
                   [M:BOR3]QTYCOD(nolign-1) = [F:BOH]QTYCOD
                   [M:BOR3]BASQTY(nolign-1) = [F:BOH]BASQTY
                   [M:BOR3]LIKQTY(nolign-1) = [F:BOD]LIKQTY * [M:BOR0]QTYCOE
                   [M:BOR3]BOMSTRDAT(nolign-1) = [M:BOR0]APPDAT
               Endif
Endcase
Return

#######################################################################
$VALID
Global Integer GNIV, GBOHLLC
Local Char     ABLIG(3)
Local Integer  PROD_COMM                     # distinction de l'écran car MODI est utilisé dans les 2 cas
Local Integer  SYNCLLC, J
# Remplacement de 300 par func AFNC.ACTIV("BOW") pour récupérer la bonne dimension Bug 49149 12/09/08
#Local Char    BOHMAX(20)(1..func AFNC.ACTIV("BOW"))            # tableau des entetes par alternative
#Local Integer LLCMAX(1..func AFNC.ACTIV("BOW"))                # avec les LLC max
#Local Integer ALT(1..func AFNC.ACTIV("BOW")), NBALT, I, J, K   # et les numéros d'alternatives
#Local Integer ALTTYP(1..func AFNC.ACTIV("BOW"))
#Local Integer WLLCTYP

# Issue X3-60359 - 2017-10-24 by JUSYN : if trace file not open open it here
If GTRACE = ""
  Call OUVRE_TRACE(mess(115,199,1)) From LECFIC
  Call PRTSCR("BOMRPL0","BOR0","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif
# Issue X3-60359 end

# GH 06/06/2016 bug 113255 - information already given by copying of criteria screen in the log
#ERR_TRA  = mess(35,197,1) - [M:BOR0]RPLCPN - mess(37,197,1)-[M:BOR0]UPDCPN
#ERR_TRA -= mess(38,197,1) - format$("D:DD[/]MM[/]YY",[M:BOR0]APPDAT)
#Call ECR_TRACE(ERR_TRA,0) From GESECRAN

# maj du lien existant et création du nouveau lien
Call DEBTRANS From GLOCK
Trbegin [BOD], [BOH], [ITB]

If GOK>0
  # Alternatives de production
  PROD_COMM = 1
  For nolign = 1 To [M:BOR1]NBLIG
      If [M:BOR1]VALID(nolign-1) = 2
          Default Mask [BOR1]
          Gosub MODI
          If GOK<1 : Break : Endif
      Endif
  Next
Endif

If GOK>0
  # Alternatives commerciales
  PROD_COMM = 2
  For nolign = 1 To [M:BOR2]NBLIG
   If [M:BOR2]VALID(nolign-1) = 2
      Default Mask [BOR2]
      Gosub MODI
      If GOK<1 : Break : Endif
   Endif
  Next
Endif

If GOK>0
  # Alternatives sous-traitance
  PROD_COMM = 3
  For nolign = 1 To [M:BOR3]NBLIG
   If [M:BOR3]VALID(nolign-1) = 2
      Default Mask [BOR3]
      Gosub MODI
      If GOK<1 : Break : Endif
   Endif
  Next
Endif

# Issue 118021 GH 07/09/2016 - this part is now included in $MODI
#If GOK>0
#  # Mise à jour des LLC (par alternative)
## I est calculé dans l'étiquette MODI
#NBALT = I : J=0 : GMESSAGE=""
#For I = 1 To NBALT
#   WLLCTYP = func LLCLIB.LLCTYP(ALTTYP(I))
#   Readlock [ITB]ITB0=[M:BOR0]UPDCPN;ALT(I);WLLCTYP
#   If fstat = 5
#     [F:ITB]ITMREF = [M:BOR0]UPDCPN
#     [F:ITB]BOMALT = ALT(I)
#     [F:ITB]LLCTYP = WLLCTYP
#     [F:ITB]BOHITM = BOHMAX(I)
#     [F:ITB]BOMEXIFLG = 1
#     [F:ITB]WUSEXIFLG = 2
#     [F:ITB]LLC       = LLCMAX(I) + 1 : # corrigé le 18/06/99
# [F:ITB]CREDAT = date$
# [F:ITB]CREUSR = GUSER
# Write [ITB]
# If fstat
#    GOK=0 : GMESSAGE = mess(13,100,1)-"ITMBOM"
#   Endif
# Elsif fstat = 1  : # enreg déjà locké
# GOK=-1 : GMESSAGE = mess(60,100,1)-"ITMBOM"
# Elsif !fstat & ([F:ITB]LLC < (LLCMAX(I) + 1))
#   [F:ITB]WUSEXIFLG = 2
#   [F:ITB]LLC = LLCMAX(I) + 1
#   [F:ITB]BOHITM = BOHMAX(I)
#   Rewrite [ITB]
#   If fstat
#      GOK=0 : GMESSAGE = mess(13,100,1)-"ITMBOM"
# Else
#    GNIV = 1 : # car on part du composant en lançant le sous-pro de Màj
#GBOHLLC = LLCMAX(I)
#Call CALCLLC([M:BOR0]UPDCPN,ALT(I),ALTTYP(I),"+") From LLCLIB
#   Endif
# Elsif !fstat & ([F:ITB]LLC = (LLCMAX(I) + 1))
#   [F:ITB]BOHITM = "" : # plusieurs liens au même LLC
# Rewrite [ITB]
# If fstat
#    GOK=0 : GMESSAGE = mess(13,100,1)-"ITMBOM"
#   Endif
# Endif
#
# # cas d'erreur d'écriture ou de lock, on n'annule pas tout !
# If GOK<1
#    If GMESSAGE<>""
# Call ECR_TRACE([M:BOR0]UPDCPN-num$(ALT(I))-num$(WLLCTYP)-":"-GMESSAGE,1) From GESECRAN
# GMESSAGE=""
#      Endif
#      J=1 : GOK=1
#   Endif
#Next I
## Il est préférable de lancer une resynchronisation des codes de plus bas niveau !
#  If J : Call ECR_TRACE(mess(198,196,1),0) From GESECRAN : Endif
#Endif

# GH 06/06/2016 bug 113255 - if transaction is rollbacked, we go back to the screen entry
If GOK>0 : Commit : Else Rollback : FIN=0 : Endif
If GOK>0 & SYNCLLC
   #Il est préférable de lancer une resynchronisation des codes de plus bas niveau !
   Call ECR_TRACE(mess(198,196,1),1) From GESECRAN
   SYNCLLC=0
Endif
Call FERME_TRACE From LECFIC
# GH 06/06/2016 bug 113255 - log trace is displayed through action OK (instead of EXEC)
Call LEC_TRACE From LECFIC
Return

#######################################################################
$MODI
# GH 06/06/2016 bug 113255 : rollback management in the transaction

# Controler que le nouveau lien ne créé pas de boucle dans la nomencl
# Lecture récursive par la clé composant (Remontant la nomencl.)
OK = 1
Call MONTLIEN([M:BOR0]UPDCPN,[M]ITMREF(nolign-1),[M]BOMALT(nolign-1),[M]BOMALTTYP(nolign-1),OK) From LLCLIB
If OK = 0 | [M:BOR0]UPDCPN = [M]ITMREF(nolign-1)
  Call ECR_TRACE(mess(153,198,1)-mess([M]BOMALTTYP(nolign-1),224,1)-[M]ITMREF(nolign-1)+"/"+num$([M]BOMALT(nolign-1))+"/"+num$([M]BOMSEQ(nolign-1))
&               -mess(67,199,1),1) From GESECRAN
  GOK=0 : Return
Endif

Raz GMESSAGE
## GH 09/07/13 bug 91019 mettre à jour la table BOM
Readlock [BOH]BOH0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMALTTYP(nolign-1)
If fstat = 1  # the record is locked
   GMESSAGE = mess(60,100,1)-"BOM"
   GOK=-1
Elsif fstat=0
   ABLIG = "BOH" : # pour zones standard
   Gosub INIMOD_LIG From TABLEAUX
   Rewrite [BOH]
   If fstat
      GOK=0 : GMESSAGE = mess(13,100,1)-"BOM"
   Endif
Endif
If GOK<1
    Call ECR_TRACE(mess(153,198,1)-mess([M]BOMALTTYP(nolign-1),224,1)-[M]ITMREF(nolign-1)+"/"+num$([M]BOMALT(nolign-1))
&                -string$(GMESSAGE<>"",":"-GMESSAGE),1) From GESECRAN
    Raz GMESSAGE
    Return
Endif

# Réecriture de l'ancien lien
Readlock [BOD]BOD0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMSEQ(nolign-1);[M:BOR0]RPLCPN;[M]BOMALTTYP(nolign-1)
If fstat = 1  # the record is locked
   GMESSAGE = mess(60,100,1)-"BOMD"
   GOK=-1
Elsif fstat=0 & ([F:BOD]BOMENDDAT > [M:BOR0]APPDAT - 1 | [F:BOD]BOMENDDAT = [0/0/0])
   [F:BOD]BOMENDDAT = [M:BOR0]APPDAT - 1

   ## GH 09/07/13 bug 91019
   #[F:BOD]UPDDAT    = date$
   #[F:BOD]UPDUSR    = GUSER
   #[F:BOD]EXPNUM    = [C]EXPORT
   ABLIG = "BOD" : # pour zones standard
   Gosub INIMOD_LIG From TABLEAUX

   # sr 07.02 demande 15091
   # point d'entrée  pour mise à jour supplémentaires sur l'ancien lien
   GPOINT = "BODMAJ" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif

   Rewrite [BOD]
   If fstat
      GOK=0 : GMESSAGE = mess(13,100,1)-"BOMD"
   Endif
Endif
If GOK<1 : Goto ERR : Endif

# Création du nouveau lien
Raz [F:BOD]
[F:BOD] = [M]
# process 03.04 MM
If PROD_COMM = 1
  If dim([M:BOR1]BOMUOM(nolign-1))<0    # UML inactif
    [F:BOD]BOMUOM =[M:BOR0]STU
    [F:BOD]BOMSTUCOE=1
    [F:BOD]BOMQTY=[M:BOR1]LIKQTY(nolign-1)
  Endif
Endif
If PROD_COMM = 3
  If dim([M:BOR3]BOMUOM(nolign-1))<0    # UML inactif
    [F:BOD]BOMUOM =[M:BOR0]STU
    [F:BOD]BOMSTUCOE=1
    [F:BOD]BOMQTY=[M:BOR3]LIKQTY(nolign-1)
  Endif
Endif
# Fin process 03.04 MM
[F:BOD]CPNITMREF = [M:BOR0]UPDCPN

ABLIG = "BOD" : # pour zones standard
Gosub INICRE_LIG From TABLEAUX

#######################################################################
$ECRIT
Write [BOD]
# Si le cpn existe déjà on en créé un avec un n° de séquence +1
If fstat=3
   # Fiche déjà existante
   Call ECR_TRACE("BOMD"-[M]ITMREF(nolign-1)-num$([M]BOMALT(nolign-1))-num$([M]BOMSEQ(nolign-1))-[M:BOR0]UPDCPN-num$([M]BOMALTTYP(nolign-1))
&                -":"-mess(22,100,1),0) From GESECRAN
   # Signaler : "Création de nouveau lien avec séquence supérieure"
   Call ECR_TRACE(mess(115,197,1),0) From GESECRAN

   [F:BOD]BOMSEQ += 1
   Goto ECRIT  : # retente l'écriture avec seq + 1 (juste après et non pas BOMSTP plus loin)
Endif

# Issue 118021 GH 07/09/2016 - the standard routine is now used
#WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
#Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
#If fstat
#   Call ECR_TRACE(mess(12,100,1)-"ITMBOM"-":"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)-num$(WLLCTYP),1) From GESECRAN
#   Return
#Endif
## Chargement du tableau des LLC (des COMPOSES !!!) par alternative
## les composés/alternatives n'étant pas forcément dans l'ordre, il faut chercher
## dans le tableau et distinguer le cas de la création d'une occurence (21/06/99)
#If I = 0
#   J = 1
#Else
#   J = find([F:BOD]BOMALT,ALT)
#Endif
#If J = 0 | I = 0 : # soit on n'a pas trouvé,soit le tableau est vide
#   I += 1
#   ALT(I)    = [F:BOD]BOMALT
#   ALTTYP(I) = [F:BOD]BOMALTTYP
#   LLCMAX(I) = [F:ITB]LLC
#   BOHMAX(I) = [F:ITB]ITMREF
#Elsif [F:ITB]LLC > LLCMAX(J)
#   LLCMAX(J) = [F:ITB]LLC
#   BOHMAX(J) = [F:ITB]ITMREF
#Elsif [F:ITB]LLC = LLCMAX(J) & BOHMAX(J) <> [F:ITB]ITMREF
#   BOHMAX(J) = ""
#Endif
J=GOK : GOK=1
Call UPDLLC([F:BOD]BOMALTTYP, [F:BOD]BOMALT, [F:BOD]ITMREF, [F:BOD]CPNITMREF, [F:BOD]CPNTYP, +1) From SUBBODB
If GOK<1 : SYNCLLC=1 : Endif
GOK=J

# écriture trace de la modification
Call ECR_TRACE(mess(153,198,1)-mess([F:BOD]BOMALTTYP,224,1)-[F:BOD]ITMREF+"/"+num$([F:BOD]BOMALT)+"/"+num$([F:BOD]BOMSEQ),0) From GESECRAN
Return

