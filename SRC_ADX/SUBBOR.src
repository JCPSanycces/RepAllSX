Subprog C_BOMSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [F:BOH]BOHSTRDAT
   mkstat = 2 : GMESSAGE = mess(51,199,1)+"/"+mess(52,199,1)
Endif
End

#######################################################################
Subprog C_BOMENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [F:BOH]BOHENDDAT & [F:BOH]BOHENDDAT <> [0/0/0]
  mkstat = 2 : GMESSAGE = mess(51,199,1) +"/"+ mess(52,199,1)
Endif
End

#######################################################################
Subprog C_APPDAT(VALEUR)
Variable Date     VALEUR
If VALEUR < date$
   mkstat = 2 : GMESSAGE = mess(114,199,1)
Endif
End

#######################################################################
Subprog C_VALID(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 & GFONBOD="BOR" & [M]ITMREF(nolign-1)=[M:BOR0]UPDCPN
  mkstat = 2 : GMESSAGE = mess(116,199,1)
Endif
End

#######################################################################
Subprog AVANT_NBLIG
# lire BOH l'entete correspondant
Read [BOH]BOH0 = [M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMALTTYP(nolign-1)
End

#######################################################################
Subprog C_UPDCPN(VALEUR)
Variable Char VALEUR()
If VALEUR = [M]RPLCPN : mkstat=2 : End  Endif
# Issue X3-58261 - reject if component is versioned
If func AFNC.ACTIV("ECC")
  If func ECCLIB.NBRCPN(VALEUR) > 0
    Call MESSAGE (mess(417,193,1)) From GESECRAN
    mkstat = 2
    End
  Endif
Endif
# Issue X3-58261 - end

[M:BOR0]STU = [F:ITM]STU
Affzo [M:BOR0]STU
End

#######################################################################
Subprog B2_UPDCPN(VALEUR)
Variable Char    VALEUR()
Read [ITM]ITM0 = [M]RPLCPN
VALEUR = [F:ITM]RPLITM
End

#######################################################################
Subprog B3_UPDCPN(VALEUR)
Variable Char    VALEUR()
Read [ITS]ITS0 = [M]RPLCPN
VALEUR = [F:ITS]SBSITM
End

#######################################################################
Subprog IB_UPDCPN
# B2 mess(316,198,1): "ARTICLE remplacement";B3 mess(324,198,1): "ARTICLE substitution"
Read [ITM]ITM0 = [M]RPLCPN
If fstat | [F:ITM]RPLITM = ""
   GBOUT2 = ""
Endif

Read [ITS]ITS0 = [M]RPLCPN
If fstat | [F:ITS]SBSITM = ""
   GBOUT3 = ""
Endif
End

