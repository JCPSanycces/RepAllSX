#######################################################################
# process 03.03 MM
Subprog AV_BOMUOM(VALEUR)
Variable Char    VALEUR()

If instr(1,dbgstr(1),"BOR0")    # remplacement
 Read [ITM]ITM0 = [M]UPDCPN
 If !fstat
    VALEUR = [F:ITM]STU
    [M:BOR1]STU(nolign-1)= [F:ITM]STU
    If dim([M:BOR1]BOMSTUCOE(nolign-1))>0 : [M:BOR1]BOMSTUCOE(nolign-1) = 1 : Endif
 Endif
 [M:BOR1]RPLITMREF(nolign-1)= [M]UPDCPN
Elsif  instr(1,dbgstr(1),"BOS0") # suppression
  Read [ITM]ITM0 = [M]SUPCPN
  If !fstat
     If dim([M:BOR1]BOMUOM(nolign-1))>0
       If [M:BOR1]BOMUOM(nolign-1)=""
          VALEUR =  [F:ITM]STU
          [M:BOR1]BOMSTUCOE(nolign-1) = 1
        Endif
     Endif
     [M:BOR1]STU(nolign-1)= [F:ITM]STU
     [M:BOR1]RPLITMREF(nolign-1)=[M]SUPCPN
  Endif
Endif

End
#######################################################################
# process 03.03 MM
Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()

If [M:BOR1]BOMUOM(nolign-1)<>VALEUR
    [M:BOR1]BOMQTY(nolign-1)=0 : [M:BOR1]LIKQTY(nolign-1)=0
    Affzo [M:BOR1]BOMQTY(nolign-1),LIKQTY(nolign-1)
Endif

End

#######################################################################
# process 03.03 MM
Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP

TYP=0
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif
Read [TUN]TUN0=[M]STU(nolign-1)
If !fstat
    TYP = [F:TUN]UOMTYP
Endif
If (TYP <>3 & TYP <>4) : mkstat=2 : Endif

End

