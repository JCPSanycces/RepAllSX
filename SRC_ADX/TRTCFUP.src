#<AdxTL>@(#)9.0.0.0 $Revision$
#### Reminder campaign ####
#
# 07/06/2017 X3-38477 - BEFOU - Option S in functionnal Authorization
# 01/08/2017 X3-38477-A - BEFOU - Option C in functionnal Authorization
# 2018-05-15 DNE X3-78302 Error on CURSHRFLD not set
#

#########################################################################################################
# Handling of CRITFUP0 and CRITFUP1 masks : main criteria
#########################################################################################################

Local Char PARAM(30)(1..2) , VALEUR(20)
GERR = 0
GPROG    = "TRTCFUP"
GTYPPROG = 4
GWINDOW  = "DFUP"
GWINCRIT = "CRITFUP"
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE
End

######################################################################################

$ACTION
## Actions of GTRAITE
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE

 When "EXEC"        : If GSERVEUR : Gosub EXEC : Endif

 When "SEL_TABLE"   :
  If GACTION="SELFUP" : Gosub SELFUP
  Elsif dim(COUZON)>0 and COUZON="FCY" : Gosub S_FCY : Endif

# code not executed if GSERVEUR=1 (because there's no window!)
 When Default
  If dim([L]BOITE)=1
   Case BOITE
    When "CRITFUP"  : Gosub ACTION_CRIT
    When "DFUP"     : Gosub ACTION From TRTFUP
    When "DETFUP"   : Gosub ACTION From TRTDFUP
   Endcase
  Endif
Endcase
Return

######################################################################################

# code not executed if GSERVEUR=1 (because there's no window!)
$ACTION_CRIT
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub AFF
 When "END"     : Gosub FIN
 When "OK"      : Gosub EXEC
 When "SUP"     : Gosub SUP
 When "NEW"     : Gosub NOUVEAU
 When "ABA"     : Gosub ABANDON
 When "SETBOUT" : Gosub SETBOUT
 When "FIR"     : Gosub PREMIER
 When "LAS"     : Gosub DERNIER
 When "PRE"     : Gosub PRECEDENT
 When "SUI"     : Gosub SUIVANT
 When "BOUTON"  : Gosub BOUTON
 When "EXEC"    : Gosub EXEC
Endcase
Return

######################################################################################
$SELFUP
OBJET="FUP"
Return

$NOUVEAU
If NOUVEAU
 # The current record has not been created yet
 # Cancel the creation
 Call OUINON(mess(8,126,1)+"\"+mess(10,126,1), OK) From GESECRAN
 If OK=1 : Return : Endif
Endif

# erase the masks and disable some fields
NOUVEAU = 1
Actzo [M:CFP0]
Actzo [M:CFP1]
Actzo [M:CFP2]

Raz [M:CFP0]
Raz [M:CFP1]
Raz [M:CFP2]
Call LECMEMO("STD","[M:CFP0],[M:CFP1],[M:CFP2]","cpf") From GMEMO
# necessary to prevent the campaign from being validated immediately after creation
[M:CFP0]VALIDE=1
[M:CFP0]CREDAT = date$
[M:CFP0]CREUSR = GUSER
[M:CFP0]UPDDAT = date$
[M:CFP0]UPDUSR = GUSER

Raz   [M:CFP0]QURNUM
Grizo [M:CFP0]QURNUM
Call C_ALLFCY([M:CFP1]ALLFCY)
Call C_ALLSAC([M:CFP1]ALLSAC)
If varmode([M:CFP1]GRPSAC)=0
 Call C_GRPSAC([M:CFP1]GRPSAC)
Endif
If varmode([M:CFP1]GRPSAC)=0
 Call C_SAC([M:CFP1]SAC)
Endif

Call C_ALLBPC([M:CFP1]ALLBPC)
Call C_ALLPAM([M:CFP1]ALLPAM)
Call C_ALLFGP([M:CFP1]ALLFGP)
Call C_ALLUSR([M:CFP1]ALLUSR)

Call C_ALLBPCGRU([M:CFP2]ALLBPCGRU) From TRTCFUP2
Call C_ALLBPCRSK([M:CFP2]ALLBPCRSK) From TRTCFUP2
Call C_ALLREP1([M:CFP2]ALLREP1) From TRTCFUP2
Call C_ALLREP2([M:CFP2]ALLREP2) From TRTCFUP2
Call C_ALLCLS([M:CFP2]ALLCLS) From TRTCFUP2
Call C_ALLTSCCOD([M:CFP2]ALLTSCCOD) From TRTCFUP2
Affzo [M:CFP0]
Affzo [M:CFP1]
Affzo [M:CFP2]

# invalidate all masks to re-execute all field checks
Setmok [CFP0] With 0
Setmok [CFP1] With 0
Setmok [CFP2] With 0
Return

######################################################################################

$BOUTON
# "Recall" button to load a memo
If BOUT="R" and varmode([M:CFP0]QURNUM)<>0
 # it's a new campaign
 Raz [M:CFP0]QURNUM

 # necessary to prevent the campaign from being validated at the creation
 [M:CFP0]VALIDE=1
 [M:CFP0]CREDAT = date$
 [M:CFP0]CREUSR = GUSER
 [M:CFP0]UPDDAT = date$
 [M:CFP0]UPDUSR = GUSER
Endif
Return

######################################################################################

$ABANDON
Local Integer OK
If NOUVEAU
 # The current record has not been created yet
 # Cancel the creation
 Call OUINON(mess(8,126,1)+"\"+mess(10,126,1), OK) From GESECRAN
 If OK=1 : Return : Endif
Endif
NOUVEAU=0

Raz [M:CFP0]
Raz [M:CFP1]
Raz [M:CFP2]

Diszo [M:CFP0]
Diszo [M:CFP1]
Diszo [M:CFP2]

Actzo [M:CFP0]QURNUM
Return

######################################################################################

$PREMIER
Gosub ABORT
If !OK : Return : Endif
Read [TFP0]TFP0 First

[M:CFP0]QURNUM = [F:TFP0]QURNUM
Call AP_QURNUM([M:CFP0]QURNUM)
Return

######################################################################################

$DERNIER
Gosub ABORT
If !OK : Return : Endif
Read [TFP0]TFP0 Last
[M:CFP0]QURNUM = [F:TFP0]QURNUM
Call AP_QURNUM([M:CFP0]QURNUM)
Return

######################################################################################

$SUIVANT
Gosub ABORT
If !OK : Return : Endif
If [TFP0]QURNUM<>[M:CFP0]QURNUM
 Read [TFP0]TFP0 = [M:CFP0]QURNUM
Endif
Read [TFP0]TFP0 Next
If fstat
 Gosub ERR_DEFILE
Else
 [M:CFP0]QURNUM = [F:TFP0]QURNUM
 Call AP_QURNUM([M:CFP0]QURNUM)
Endif
Return

######################################################################################

$PRECEDENT
Gosub ABORT
If !OK : Return : Endif
If [TFP0]QURNUM<>[M:CFP0]QURNUM
 Read [TFP0]TFP0 = [M:CFP0]QURNUM
Endif
Read [TFP0]TFP0 Prev
If fstat
 Gosub ERR_DEFILE
Else
 [M:CFP0]QURNUM = [F:TFP0]QURNUM
 Call AP_QURNUM([M:CFP0]QURNUM)
Endif
Return

######################################################################################

$ABORT
OK = 2
If find(REP,"M")
 Call ABANDON(OK) From GESECRAN
 If OK<>2
  OK = 0
 Endif
Endif
Return

######################################################################################

$ERR_DEFILE
# Start/End of file
Call ERREUR(mess(11,100,1)) From GESECRAN
Return

######################################################################################

$ROLL_SUP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto SUP : Endif

$ROLL_EXEC2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto EXEC2 : Endif

$ROLL_TR3
Rollback
Call ROLL From GLOCK
# necessary to continue after a failed update of the CMT field
If GROLL : FIN = 0 : GERR = 0 : GNBROL = 0 : Return : Else : Goto TR3 : Endif

$SUP
If func GLOCK.LOKBYU("FUP"+[M:CFP0]QURNUM)
 Call ECR_TRACE([M:CFP0]QURNUM-mess(94,2006,1), 1) From GESECRAN
 Return
Endif
If [M:CFP0]QURNUM<>""
 # Records deletion
 Call TEMPON(mess(499,196,1)) From GESECRAN
 Trbegin [TFP0]
  Delete [TFP0] Where [TFP0]QURNUM=[M:CFP0]QURNUM
  If fstat=1
   GOK = -1 : GLOCK = "$TMPFUP0"-[M:CFP0]QURNUM : Goto SUP2
  Elsif fstat
   ABR = "TFP0" : GOK = 0 : Goto SUP2
  Endif

  Delete [TFP1] Where [TFP1]NUMREQ=[M:CFP0]QURNUM
  If fstat=1
   GOK = -1 : GLOCK = "$TMPFUP1"-[M:CFP0]QURNUM : Goto SUP2
  Elsif fstat
   ABR = "TFP1" : GOK = 0 : Goto SUP2
  Endif

  Delete [TFP2] Where [TFP2]NUMREQ=[M:CFP0]QURNUM
  If fstat=1
   GOK = -1 : GLOCK = "$TMPFUP2"-[M:CFP0]QURNUM : Goto SUP2
  Elsif fstat
   ABR = "TFP2" : GOK = 0 : Goto SUP2
  Endif

  Delete [FUP] Where [FUP]NUMEDT=[M:CFP0]QURNUM
  If fstat=1
   GOK = -1 : GLOCK = "$FUP"-[M:CFP0]QURNUM : Goto SUP2
  Elsif fstat
   ABR = "FUP" : GOK = 0 : Goto SUP2
  Endif
 Commit

 $SUP2
 Call TEMPOFF From GESECRAN
 If GOK=-1
  Goto ROLL_SUP
 Elsif GOK=0
  Call FSTA(ABR) From GLOCK : Rollback
 Endif

 If fstat=0
  Read [TFP0]TFP0=[M:CFP0]QURNUM
  Read [TFP0]TFP0 Prev
  # The records of the campaign have been deleted
  Call MESSAGE(mess(208,117,1)) From GESECRAN
  [M:CFP0]QURNUM=[TFP0]QURNUM
  Call AP_QURNUM([M:CFP0]QURNUM)
  Affzo [M:CFP0]QURNUM
 Endif
Endif
Return

######################################################################################

$SETBOUT

# 07/06/2017 X3-38477 BEFOU  - Option S in functionnal Authorization
  Local Integer  BTNDEL
  Local Char CPYFUP(10)
  CPYFUP=[M:CFP1]CPY
  If [M:CFP1]ALLFCY<>G_OUI
      CPYFUP=[M:CFP1]FCY
  Endif
  BTNDEL = [V]CST_ATRUE

  Local Char OPTAFP(23)
  If clalev([F:AFP])=0  : Local File "AFCTPRF" [AFP]  : Endif : # Habilitations fonctionnelles
  Read [AFP]AFP0 = GPROFIL ; GUSRFCT; CPYFUP
  If fstat <> [V]CST_AOK
    Read [AFP]AFP0 = GPROFIL ; GUSRFCT; ""
  Endif
  If fstat = [V]CST_AOK
    OPTAFP =[AFP]OPT
    # GUSRVID ne prends pas le site !
    If !pat (OPTAFP,"*S*")
      Call VIREBOUT(CHBOU,"S") From GOBJET # Delete
      BTNDEL = [V]CST_AFALSE
    Endif
  Endif
# End of  X3-38477

If NOUVEAU
 CHBOU+="A" # Cancel
 Call VIREBOUT(CHBOU,"S") From GOBJET # Delete
Else
 Call VIREBOUT(CHBOU,"A") From GOBJET
 If(BTNDEL) #X3-38477
   CHBOU+="S"
  Endif
Endif

Return

######################################################################################

$OUVRE
Gosub DECLARE

# arriving from a tunnel
If dim(PARAM)>0 and PARAM(1)<>""
 [M:CFP0]QURNUM = PARAM(1)

 # necessary to prevent an infinite loop
 PARAM(1) = ""
 zonsui = "CMT"
 # go directly to the list of BPs in the campaign
Else
 If !GSERVEUR and !GBATCH : Call LECMEMO("STD","[M:CFP0],[M:CFP1],[M:CFP2]","cpf") From GMEMO : Endif
 # necessary to prevent the campaign from being validated at the creation
 [M:CFP0]VALIDE=1
 [M:CFP0]CREDAT = date$
 [M:CFP0]CREUSR = GUSER
 [M:CFP0]UPDDAT = date$
 [M:CFP0]UPDUSR = GUSER
Endif
Raz fstat

COPIE = 0
Return

######################################################################################

$OUVRE_BATCH
Gosub INIT
Gosub OUVRE
Gosub OUVRE_TABLES From TRTFUP

Local Mask [CFP0], [CFP1], [CFP2]

Raz [M:CFP0], [M:CFP1], [M:CFP2]
Grizo [M:CFP0]QURNUM
Affzo [M:CFP0]
Return

$INIT
# necessary to keep access to [M:CFP*] from TRTFUP process
If clalev([M:CFP0])=0 : Local Mask CRITFUP0 [CFP0] : Raz [M:CFP0] : Endif
If clalev([M:CFP1])=0 : Local Mask CRITFUP1 [CFP1] : Raz [M:CFP1] : Endif
If clalev([M:CFP2])=0 : Local Mask CRITFUP2 [CFP2] : Raz [M:CFP2] : Endif
If clalev([M:FUP]) =0 : Local Mask FUP      [FUP]  : Raz [M:FUP]  : Endif

If dim([M:FUP]SEL)>0 & dim([L]SVG_ADXLIG)<0
 Local Integer SVG_ADXLIG
 [L]SVG_ADXLIG=adxlig
 adxlig=dim([M:FUP]SEL)
Endif
Return

$INIT_DIA
Raz [M:CFP0], [M:CFP1], [M:CFP2]
Return

$DECLARE
If clalev([F:AGC])=0     : Local File AGRPCPY    [AGC]   : Endif
If clalev([F:FCY])=0     : Local File FACILITY   [FCY]   : Endif
If clalev([F:CPY])=0     : Local File COMPANY    [CPY]   : Endif
If clalev([F:DUD])=0     : Local File GACCDUDATE [DUD]   : Endif
If clalev([F:BPC])=0     : Local File BPCUSTOMER [BPC]   : Endif # reminded business partner (charged or paying, according to the value of BPRFUP)
If clalev([F:BPCF])=0    : Local File BPCUSTOMER [BPCF]  : Endif # charged business partner
If clalev([F:BPR])=0     : Local File BPARTNER   [BPR]   : Endif
If clalev([F:ANM])=0     : Local File ACODNUM    [ANM]   : Endif
If clalev([F:TCU])=0     : Local File TABCUR     [TCU]   : Endif
If clalev([F:TFP0])=0    : Local File TMPFUP0    [TFP0]  : Endif
If clalev([F:TFP1])=0    : Local File TMPFUP1    [TFP1]  : Endif
If clalev([F:TFP2])=0    : Local File TMPFUP2    [TFP2]  : Endif
If clalev([F:TFP3])=0    : Local File TMPFUP1    [TFP3]  : Endif
If clalev([F:AMZ])=0     : Local File AMSKZON    [AMZ]   : Endif
If clalev([F:AMK])=0     : Local File AMSK       [AMK]   : Endif
If clalev([F:TCA])=0     : Local File TABCOUAFF  [TCA]   : Endif
If clalev([F:AUS])=0     : Local File AUTILIS    [AUS]   : Endif
If clalev([F:GTE])=0     : Local File GTYPACCENT [GTE]   : Endif
If clalev([F:FGP])=0     : Local File FUPGRP     [FGP]   : Endif
If clalev([F:BPA])=0     : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:REP])=0     : Local File SALESREP   [REP]   : Endif
If clalev([F:FUP])=0     : Local File FUP        [FUP]   : Endif
If clalev([F:GSC])=0     : Local File GRPSAC     [GSC]   : Endif
If clalev([F:TDA])=0     : Local File TABDEPAGIO [TDA]   : Endif
If clalev([F:AIM])=0     : Local File APRINTER   [AIM]   : Endif
If clalev([F:HAE])=0     : Local File GACCENTRY  [HAE]   : Endif

Local Char DATE1(12), DATE2(12), CRIT_DUD(250), CRIT_BPCF(250)(2), CRIT_BPC(250), VALPAR(200), Y(50), FUPADD(200), CMT(250)
Local Char CHRONO(GLONANM), CRI(250), BPRFUP(GLONBPR), DEVORG(GLONCUR), DEVDES(GLONCUR), DEVSOC(GLONCUR), RPTDST(250)(1..2)
Local Integer NN, FUPAMT, NBSAC, N, STAT, FUPFCY, FUPCUR, CREDIT, CONTCLI, NBSEUIL, NOUVEAU, COPIE, OK, TYPCOURS, NBSEL, NBDESEL
Local Integer NBFUP, NBTOTFUP, NBBPC, T, OKDUD, EP_CALL
Local Decimal MNT, MTORG, MTDES, TOTAL, MNTMIN
Local Date DATCOURS
Local Char ABR(4) # Used for FSTA() calls
Local Char CRIT_OTHER(250), CRITFCT(250), CRITDAT(250), CRITLEVFUP(250)
Local Integer OKTCA

NOUVEAU = 0

# Common field rate type
Call PARAML("","TYPCURSHR",VALPAR) From ADOVAL
TYPCOURS = val(VALPAR)

# parameter to define the address of the BP to be reminded
Call PARAML("","FUPADD",FUPADD) From ADOVAL

EP_CALL = find('TRTCFUP',GENTSTD(1..GNBENTREE))
Return

######################################################################################

$CONTROLE
If GOK<1
 FIN = 1 : Return
Endif
Return

######################################################################################

$AFF
# To avoid overwriting the parameter values when we choose "Parameter entry" from the "Request management" function,
# we test if the [F:ABR] class is set to know if we are currently creating a new request or just modifying the parameters
# of an existing request (right-click "Parameter entry")

If GBATCH=1
 If clalev([F:ABD])
  # we are coming from "Recurring task management" function

  # searching for parameters of the current recurring task
  Filter [ABD] Where CODABT=[M:ABA1]CODABT and CODTAC=[M:ABA1]TACHE
  If rowcount([F:ABD])=0
   # creation of a new recurring task
   Call LECMEMO("STD","[M:CFP0],[M:CFP1],[M:CFP2]","cpf") From GMEMO
  Else
   Trbegin [ABD]
    # deletion of QURNUM parameter value from recurring tasks parameters table
    Delete [ABD] Where CODABT=[M:ABA1]CODABT and CODTAC=[M:ABA1]TACHE and PARAM="QURNUM"
   Commit
  Endif
  Filter [ABD]
 Elsif clalev([F:ABL]) and clalev([F:ABR])
  # we are coming from "Request management" function
  If [F:ABR]NUMREQ=0
   # creation of a new batch request
   Call LECMEMO("STD","[M:CFP0],[M:CFP1],[M:CFP2]","cpf") From GMEMO
  Endif
 Endif

 # calls to controls to disable fields when needed
 Call C_ALLFCY([M:CFP1]ALLFCY)
 Call C_ALLSAC([M:CFP1]ALLSAC)
 If varmode([M:CFP1]GRPSAC)=0
  Call C_GRPSAC([M:CFP1]GRPSAC)
 Endif
 If varmode([M:CFP1]GRPSAC)=0
  Call C_SAC([M:CFP1]SAC)
 Endif

 Call C_ALLBPC([M:CFP1]ALLBPC)
 Call C_ALLPAM([M:CFP1]ALLPAM)
 Call C_ALLFGP([M:CFP1]ALLFGP)
 Call C_ALLUSR([M:CFP1]ALLUSR)

 Call C_ALLBPCGRU([M:CFP2]ALLBPCGRU) From TRTCFUP2
 Call C_ALLBPCRSK([M:CFP2]ALLBPCRSK) From TRTCFUP2
 Call C_ALLREP1([M:CFP2]ALLREP1) From TRTCFUP2
 Call C_ALLREP2([M:CFP2]ALLREP2) From TRTCFUP2
 Call C_ALLCLS([M:CFP2]ALLCLS) From TRTCFUP2
 Call C_ALLTSCCOD([M:CFP2]ALLTSCCOD) From TRTCFUP2

 Affzo [M:CFP0]
 Affzo [M:CFP1]
 Affzo [M:CFP2]
Endif
Return

######################################################################################
# click on OK button
# Saving values to TMPFUP0, TMPFUP1 and TMPFUP2 tables
######################################################################################
$EXEC
# We don't fill in TMPFUP* tables after input of batch criteria (GBATCH=1)
If GBATCH
 Raz [M:CFP0]QURNUM
 Return
Endif

If GSERVEUR : Gosub OUVRE : Endif

# We check that all facilities are allowed for the current reminder campaign
# and create a list of forbidden facilities of the chosen company
Local Char SITINT(250)
Local Char FCYS(GLONFCY)(250)
Local Integer NBFCY

If GUSRFCY(1)<>"\"
 If [M:CFP1]ALLFCY<>2
  If !find([M:CFP1]FCY, GUSRFCY(1..GNBAUZ)) : SITINT -= [M:CFP1]FCY : Endif
 Else
  For [AGC] Where GRP=[M:CFP1]CPY
   For [FCY] Where LEGCPY=[AGC]CPY
    If !find([F:FCY]FCY, GUSRFCY(1..GNBAUZ))
     SITINT -= [F:FCY]FCY
     FCYS(NBFCY) = [F:FCY]FCY
     NBFCY = NBFCY+1
    Endif
   Next
  Next
 Endif
Endif
If SITINT<>""
 Call AVERTIR(mess(27,135,1)+SITINT,OK) From GESECRAN
 If OK=1 : SAI=1 : FIN=1 : GOK=0 : Return : Endif
Endif

FIN = 1 : GOK = 1

##################################################
# CRIT_DUD criterion ---> table GACCDUDATE [DUD] #
##################################################

Raz CRIT_DUD, CRIT_OTHER

NN = 0
Call ADDCRIT(CRIT_DUD, NN, "[DUD]BPRTYP", "[DUD]BPRTYP=1", "&") From GOBJSUB
Call ADDCRIT(CRIT_DUD, NN, "[DUD]AMTLOC", "[DUD]AMTLOC<>0", "&") From GOBJSUB
Call ADDCRIT(CRIT_DUD, NN, "[DUD]FLGCLE", "[DUD]FLGCLE=1", "&") From GOBJSUB
Call ADDCRIT(CRIT_DUD, NN, "[DUD]DUDSTA", "[DUD]DUDSTA=2", "&") From GOBJSUB
Call ADDCRIT(CRIT_DUD, NN, "[DUD]TYP", "[DUD]TYP<>'*PO'", "&") From GOBJSUB

If NBFCY<>0
 Call ADDCRIT(CRIT_DUD, NN, "[DUD]FCY", "!find([DUD]FCY, [L]FCYS)<>0", "&") From GOBJSUB
Endif

# If campaign number is set, we use the values already stored in TMPFUP2 for that campaign
# In batch mode, ALWAYS create a new campaign
If varmode([M:CFP0]QURNUM)=1 or GSERVEUR
 # campaign creation
 # generating selection criteria

 Local Integer N
 Local Char NUM(250)

 # Facility
 If [M:CFP1]FCY<>"" : Call ADDCRIT(CRIT_DUD, NN, "[DUD]FCY", "[DUD]FCY='"+[M:CFP1]FCY+"'", "&") From GOBJSUB : Endif

 # All collective accounts / Collective groups / Collective
 If [M:CFP1]SAC<>"" : Call ADDCRIT(CRIT_DUD, NN, "[DUD]SAC", "[DUD]SAC='"+[M:CFP1]SAC+"'", "&") From GOBJSUB : Endif

 If [M:CFP1]BPRFUP=1
  [L]BPRFUP = "BPRPAY"
 Else
  [L]BPRFUP = "BPR"
 Endif

 # All payment modes / Payment mode
 If [M:CFP1]PAM<>"" : Call ADDCRIT(CRIT_DUD, NN, "[DUD]PAM", "[DUD]PAM='"+[M:CFP1]PAM+"'", "&") From GOBJSUB : Endif

 # Level of reminder start / end
 Call ADDCRIT(CRIT_DUD, NN, "[DUD]LEVFUP", "[DUD]LEVFUP>="+num$([M:CFP1]FUPLEVSTR), "&") From GOBJSUB
 Call ADDCRIT(CRIT_DUD, NN, "[DUD]LEVFUP", "[DUD]LEVFUP<="+num$([M:CFP1]FUPLEVEND), "&") From GOBJSUB

 If [M:CFP1]ACCLI=1
  # Exclude sale orders too
  Call ADDCRIT(CRIT_DUD, NN, "[DUD]TYP", "[DUD]TYP<>'*SO'", "&") From GOBJSUB
 Endif

 # if [M]FLGFUP=2 ---> Include due dates not for reminding -> No criterion to add
 # if [M]FLGFUP<>2 ---> Do not include due dates not for reminding --> FLGFUP=2
 If [M:CFP2]FLGFUP<>2
  Call ADDCRIT(CRIT_DUD, NN, "[DUD]FLGFUP", "[DUD]FLGFUP=2", "&") From GOBJSUB
 Endif

 # All users
 If [M:CFP1]ALLUSR<>2
  Call ADDCRIT(CRIT_DUD, NN, "[DUD]CREUSR", "[DUD]CREUSR='"+[M:CFP1]USR+"'", "&") From GOBJSUB
 Endif

 If [M:CFP1]CRI=""
  [L]CRI = "1=1"
 Else
  [L]CRI = [M:CFP1]CRI
 Endif

 # CRIT_BPC  : criterion on pay-by BP or bill-to BP according to the value of [M:CFP1]BPRFUP
 # CRIT_BPCF : criterion (always) on charged BP

 CRIT_BPC  = ""
 CRIT_BPCF = ""

 ##################################################
 # CRIT_PBC criterion ---> table BPCUSTOMER [BPC] #
 ##################################################

 NN = 0
 Call ADDCRIT(CRIT_BPC, NN, "[BPC]FUPTYP", "[BPC]FUPTYP<>1", "&") From GOBJSUB

 # All clients / Client start / Client end
 If [M:CFP1]ALLBPC<>2
  If [M:CFP1]BPCDEB<>""
   Call ADDCRIT(CRIT_BPC, NN, "[BPC]BPCNUM", "[BPC]BPCNUM>='"+[M:CFP1]BPCDEB+"'", "&") From GOBJSUB
  Endif
  If [M:CFP1]BPCFIN<>""
   Call ADDCRIT(CRIT_BPC, NN, "[BPC]BPCNUM", "[BPC]BPCNUM<='"+[M:CFP1]BPCFIN+"'", "&") From GOBJSUB
  Endif
 Endif

 ####################################################
 # CRIT_PBCF criterion ---> table BPCUSTOMER [BPCF] #
 ####################################################

 # Risk customer
 If [M:CFP2]ALLBPCRSK<>2
  If [M:CFP2]BPCRSKDEB<>""
   Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]BPCRSK", "[BPCF]BPCRSK>='"+[M:CFP2]BPCRSKDEB+"'", "&") From GOBJSUB
  Endif
  If [M:CFP2]BPCRSKFIN<>""
   Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]BPCRSK", "[BPCF]BPCRSK<='"+[M:CFP2]BPCRSKFIN+"'", "&") From GOBJSUB
  Endif
 Endif

 # customer group
 If [M:CFP2]BPCGRU<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]BPCGRU", "[BPCF]BPCGRU='"+[M:CFP2]BPCGRU+"'", "&") From GOBJSUB
 Endif

 # All reminder groups
 If [M:CFP1]FGP<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]GRP", "[BPCF]GRP='"+[M:CFP1]FGP+"'", "&") From GOBJSUB
 Else
  # 58737
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]GRP", "[BPCF]GRP<>''", "&") From GOBJSUB
 Endif

 # Commercial n°1 start / end
 If [M:CFP2]REPDEB1<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]REP(0)", "[BPCF]REP(0)>='"+[M:CFP2]REPDEB1+"'", "&") From GOBJSUB
 Endif
 If [M:CFP2]REPFIN1<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]REP(0)", "[BPCF]REP(0)<='"+[M:CFP2]REPFIN1+"'", "&") From GOBJSUB
 Endif

 # Commercial n°2 start / end
 If [M:CFP2]REPDEB2<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]REP(1)", "[BPCF]REP(1)>='"+[M:CFP2]REPDEB2+"'", "&") From GOBJSUB
 Endif
 If [M:CFP2]REPFIN2<>""
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]REP(1)", "[BPCF]REP(1)<='"+[M:CFP2]REPFIN2+"'", "&") From GOBJSUB
 Endif

 # ABC Class
 If [M:CFP2]ALLCLS=1
  Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]ABCCLS", "[BPCF]ABCCLS="+num$([M:CFP2]CLS), "&") From GOBJSUB
 Endif

 # Statistical group
 If [M:CFP2]ALLTSCCOD=1
  For N=0 To dim([M:CFP2]TSCCOD)-1
   If [M:CFP2]TSCCOD(N)<>""
    Call ADDCRIT(CRIT_BPCF, NN, "[BPCF]TSCCOD("+num$(N)+")", "[BPCF]TSCCOD("+num$(N)+")='"+evalue("[M:CFP2]TSCCOD("+num$(N)+")")+"'", "&") From GOBJSUB
   Endif
  Next
 Endif

 If CRIT_BPC=""
  CRIT_BPC = "1=1"
 Endif
 If CRIT_BPCF=""
  CRIT_BPCF = "1=1"
 Endif

 ####################################################
 # CRIT_OTHER criterion : related to various tables #
 ####################################################

 NN = 0
 Call ADDCRIT(CRIT_OTHER, NN, "[GTE]FUP", "[GTE]FUP=2", "&") From GOBJSUB
 Call ADDCRIT(CRIT_OTHER, NN, "[FGP]FUPCDT", "([FGP]FUPCDT=2 or [DUD]SNS=1)", "&") From GOBJSUB
 Call ADDCRIT(CRIT_OTHER, NN, "[AGC]GRP", "[AGC]GRP=[M:CFP1]CPY", "&") From GOBJSUB

 # retrieval of sequence counter name
 Filter [AGC] Where GRP=[M:CFP1]CPY
  # If only one company we could check the counter name else we take by default the "FUP" counter
  If rowcount([AGC])=1
   GSOCIETE = [M:CFP1]CPY
   Call LECTCA(3,OKTCA) From SUBTCA
   GSOCIETE = ""
  Endif
 Filter [AGC]

 If OKTCA and [F:TCA]CODNUM(11)<>"" : CHRONO = [F:TCA]CODNUM(11) Else CHRONO = "FUP" : Endif

 # counter value retrieval
 If [M:CFP1]CPY=""
  Call NUMERO(CHRONO,"",date$,GUSER,NUM,STAT) From SUBANM
 Else
  Call LEC_CPY([M:CFP1]CPY) From CPTLEC
  Call NUMERO(CHRONO,[F:CPY]MAIFCY,date$,GUSER,NUM,STAT) From SUBANM
 Endif

 If GOK<0 : Return
 Elsif GOK<1 | STAT
  GOK=0
  If STAT
   Gosub MESSAGE From SUBANM
   GMESSAGE=mess(104,117,1)-"("+[L]CHRONO+") : "+MESSA
  Endif
  FIN = 1 : Return
 Else
  [M:CFP0]QURNUM = NUM
 Endif

 ########################################################
 # Retrieval and copy of records to TMPFUP1 and TMPFUP2 #
 ########################################################

 $EXEC2
 NBBPC=0
 NBTOTFUP=0 # total number of open items
 T=1

 Trbegin [BPC], [TFP0], [TFP1], [TFP2]

 # Open items set with "No reminder" are excluded
 # On prend les échéances non soldées (FLGCLE=1), non affacturées (BPRFCT=''), validées en comptabilité (DUDSTA=2)
 # et échues par rapport à la date de référence
 # (sauf si la case "Echéances non échues exclusivement" est cochée)
 # et avec type de relance différent de "Pas de relance"
 # et uniquement les échéances "client" (BPRTYP=1)
 # et on ne sélectionne pas les échéances avec montants nuls (AMTLOC<>0)

 # Le critère "groupes de relance" ne doit porter que sur le tiers facturé des échéances, idem pour les représentants (REPDEB1...),
 # les classes (CLS) et les familles statistiques (TSCCOD).
 # Et quant au flag "tiers relancé=tiers payeur/tiers facturé" (BPRFUP), il ne doit impacter que la nature de ce qui sera précisé
 # dans les champs BPCDEB & BPCFIN.

 # 2.  Les autres critères dont il s'agit dans notre échange, à savoir "groupe", "classe", "représentant"...etc, là, on prend
 #     toujours ceux du tiers facturé, donc de BPR
 # Purchase orders are always excluded : TYP<>'*PO'

 # gestion GTE pour X3 V7
 Local Integer NBTYP
 Filter [GTE] Where FUP=2
 NBTYP = rowcount([F:GTE])
 Filter [GTE]
 Local Char TTYP(GLONGTE)(1..NBTYP)
# 2018-05-15 DNE X3-78302 BEGIN
 Local Char LCURSHRFLD(30)
# 2018-05-15 DNE X3-78302

 NBTYP = 0
 # loop on all companies belonging to the company group
 For [AGC] Where GRP=[M:CFP1]CPY
  Call LEC_CPY([AGC]CPY) From CPTLEC

# 2018-05-15 DNE X3-78302 BEGIN
  Call PARAML( [AGC]CPY, "CURSHRFLD", [L]LCURSHRFLD ) From ADOVAL
  If [L]LCURSHRFLD = ""
      # 'Company'
      # 'Parameter '$1$' not set.'
      Call ERREUR( mess(2,45,1) - [AGC]CPY - "-" - func AFNC.MES1( mess(332,123,1), "CURSHRFLD" ) ) From GESECRAN
      GOK = 0
      Break
  Endif
# 2018-05-15 DNE X3-78302

  # the "Order By" statement will first retrieve the record where LEG is set whenever several records exist for the same TYP
  Filter [GTE] Where (LEG=[F:CPY]LEG or LEG="") and FUP=2 Order By Key CLE=TYP Asc; LEG Desc
  # CLE(1) is mandatory to remove potential duplicate records
  For [GTE]CLE(1)
   If !find([F:GTE]TYP, TTYP(1..NBTYP))
    NBTYP+=1
    TTYP(NBTYP) = [F:GTE]TYP
   Endif
  Next
 Next
 Filter [GTE]
 If NBTYP<60
  Call ADDCRIT(CRIT_DUD, NN, "CRITERE", "find([F:DUD]TYP,TTYP(1..NBTYP))<>0", "&") From GOBJSUB
 Else
  Call ADDCRIT(CRIT_DUD, NN, "CRITERE", "find([F:DUD]TYP,TTYP(1..NBTYP))", "&") From GOBJSUB
 Endif
 # fin gestion GTE pour X3 V7

 If [M:CFP1]GRPSAC=""
  If [L]BPRFUP="BPRPAY"
   Link [DUD] With [BPC]BPC0~=[DUD]BPRPAY, [FGP]FGP0~=[BPC]GRP, [BPCF]BPC0~=[DUD]BPR, [AGC]AGC1(1)~=[DUD]CPY As [LNKC]
  Else # [L]BPRFUP=BPR
   Link [DUD] With [BPC]BPC0~=[DUD]BPR, [FGP]FGP0~=[BPC]GRP, [BPCF]BPC0~=[DUD]BPR, [AGC]AGC1(1)~=[DUD]CPY As [LNKC]
  Endif
 Else
  If [L]BPRFUP="BPRPAY"
   Link [DUD] With [BPC]BPC0~=[DUD]BPRPAY, [FGP]FGP0~=[BPC]GRP, [BPCF]BPC0~=[DUD]BPR, [GSC]GSC0~=[M:CFP1]COA;[M:CFP1]GRPSAC, [AGC]AGC1(1)~=[DUD]CPY As [LNKC]
&  Where [DUD]SAC=[GSC]SAC
  Else # [L]BPRFUP=BPR
   Link [DUD] With [BPC]BPC0~=[DUD]BPR, [FGP]FGP0~=[BPC]GRP, [BPCF]BPC0~=[DUD]BPR, [GSC]GSC0~=[M:CFP1]COA;[M:CFP1]GRPSAC, [AGC]AGC1(1)~=[DUD]CPY As [LNKC]
&  Where [DUD]SAC=[GSC]SAC
  Endif
 Endif

 Filter [LNKC]
&  Where evalue([L]CRIT_DUD) and evalue([L]CRIT_BPC) and evalue([L]CRIT_BPCF) & evalue([L]CRIT_OTHER)
&    and evalue([L]CRI)
&   Order By Key CLE=[BPC]BPCNUM;[DUD]CPY;[DUD]FCY;[DUD]DUDDAT;[DUD]ACCNUM;[DUD]DUDLIG

  For [LNKC]CLE(1) # Rupture par client

   Raz [L]MNT, [F:TFP1], TOTAL, OKDUD
   NBSEL = 0 : NBNSEL = 0

   # taking into account of credit
   If [F:FGP]FUPCDT=2 : [L]CREDIT=1 : Else : [L]CREDIT=0 : Endif
   # reminder amount considered
   If [F:FGP]FUPCTL=1 : [L]CONTCLI=1 : Else : [L]CONTCLI=0 : Endif
   # reminder by transaction currency
   If [F:FGP]FUPCUR=2 : [L]FUPCUR=1 : Else : [L]FUPCUR=0 : Endif
   # reminder by site
   If [F:FGP]FUPFCY=2 : [L]FUPFCY=1 : Else : [L]FUPFCY=0 : Endif

   # minimum amount to remind
   [L]MNTMIN = [F:BPC]FUPMINAMT

   [L]OK = 1

   [L]CRITFCT = "0=1"
   Local Char PARAMFUPMAX(2)
   # consider the parameter for activating the ignoration of the max. reminder level
   Call PARAM([M:CFP1]CPY, "FUPMAX", [L]PARAMFUPMAX) From ADOVAL
   If [L]PARAMFUPMAX = "2" Then
     [L]CRITLEVFUP = "1=1"
   Else
     [L]CRITLEVFUP = "0=1"
   Endif
   If EP_CALL : GPOINT="CRITFUPFCT" : Gosub ENTREE From EXEFNC : Endif

   #81318 - Point entrée TRTCFUP pour relancer non échus
   CRITDAT = "0=1"
   If EP_CALL : GPOINT="CRITFUPDAT" : Gosub ENTREE From EXEFNC : Endif

   # 82298- Entry point to modify the criteria used to create the campaign
   If EP_CALL : GPOINT="ALLCRIT" : Gosub ENTREE From EXEFNC : Endif

   For [LNKC]CLE(3) # Rupture client/société/site
    NBFUP = 0
    For [LNKC]CLE # loop on each open item to be reminded

     If([F:DUD]BPRFCT='' or evalue(CRITFCT)) and ([M:CFP1]REFDAT-[F:DUD]DUDDAT>0 or evalue(CRITDAT))
&        and ([F:FGP]FUPMAX=0 or [F:DUD]LEVFUP<[FGP]FUPMAX or evalue(CRITLEVFUP))
      OKDUD = 1

      # For all reminder types (by invoice, global, global by level, global by delay)
      # if the lateness of the open item is lower than the first threshold, then the open item is not selected
      If ([M:CFP1]REFDAT-[F:DUD]DUDDAT<[F:FGP]SEUILS(0)) and ([F:FGP]SEUILS(0)>0)
       OKDUD = 0
      Else
       # contrôle seuil montant à relancer pour chaque échéance
       If [L]MNTMIN
        Gosub CONT_SEUIL
        If [L]CONTCLI=0 & abs([L]MNT)<[L]MNTMIN : [L]OKDUD=0 : Endif
       Endif
      Endif
     Else
      OKDUD = 0
     Endif

     If OKDUD
      Raz [F:TFP2]
      Local Integer LNEW_LEVFUP
      [L]LNEW_LEVFUP = [F:DUD]LEVFUP + 1
      If [F:FGP]FUPFRY = 2 Then # Interval
          Gosub FUPSELDUD
      Else # Threshold
          # the reminder level must be equal to the open item threshold found
          # min() is used to ensure the number of thresholds used is never greater than the number of existing thresholds
          K = func TRTCFUP.GET_THRESHOLD([F:DUD]DUDDAT, [M:CFP1]REFDAT, [F:FGP]SEUILS(0..min(dim([F:FGP]SEUILS), max([F:FGP]FUPMAX, 1))-1))
          If [F:BPC]FUPTYP=2 or [F:BPC]FUPTYP=3 or [F:BPC]FUPTYP=4
           # reminder by invoice, global or by level
           # the open item is included in the campaign only if its LEVFUP is strictly lower than the threshold K
           If [F:DUD]LEVFUP>=K : OKDUD = 0 : Endif
          Endif
      Endif

      If EP_CALL : GPOINT="FUPSELDUD" : Gosub ENTREE From EXEFNC : Endif

      # si le montant de l'échéance est supérieur au montant minimum à relancer, l'échéance est incluse
      # si c'est un avoir et flag "prise en compte crédit", l'échéance est incluse
      If OKDUD
       Call LEC_CPY([F:DUD]CPY) From CPTLEC
       DEVORG = [F:DUD]CUR
       DEVDES = GCURSHR
       If DEVORG = DEVDES
        MTORG = ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
       Else
        MTORG = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
       Endif
       MTDES = MTORG
       If ([L]CONTCLI=1 or MTDES>[L]MNTMIN or ([L]CREDIT and [F:DUD]SNS=-1))
        # Si MNTMIN non nul et si la devise de l'échéance est différente de la devise zone commune
        # => convertir tous les montants en devise zone commune (GCURSHR)
        # MNTMIN est déjà exprimé en devise GCURSHR
        NBTOTFUP+=1
        NBFUP+=1
        TOTAL += MTDES

        If [F:DUD]FLGFUP<>2 # no reminder for this open item
         NBNSEL+=1
         [F:TFP2]SEL = 1 # not selected by default
        Else # relançable
         NBSEL+=1
         [F:TFP2]SEL = 2 # selected by default
        Endif
        If [F:FGP]FUPMAX>0
         [F:TFP2]LEVFUP = min([F:DUD]LEVFUP+1,[F:FGP]FUPMAX)
        Else
         [F:TFP2]LEVFUP = [F:DUD]LEVFUP+1
        Endif
        [F:TFP2]NUMDUD = [F:DUD]NUMDUD
        [F:TFP2]BPC = [F:BPC]BPCNUM
        [F:TFP2]CPY = [F:DUD]CPY
        [F:TFP2]FCY = [F:DUD]FCY

        # recherche de l'adresse [L]FUPADD du tiers facturé ou payeur (en fonction de la valeur de BPRFUP)
        If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:TFP2]BPC or [F:BPA]BPAADD<>[L]FUPADD
         Read [BPA]BPA0=1;[F:TFP2]BPC;[L]FUPADD
        Else
         Raz fstat
        Endif
        If fstat
         If [M:CFP1]BPRFUP=1
          # tiers relancé = tiers payeur
          # Cas 4 : FUPADD vide ou alimenté et n'existe pas parmi adresses du Tiers Payeur
          # --> Adresse de relance = adresse de paiement de l'échéance, champ BPAPAY sur DUD
          [F:TFP2]ADD = [F:DUD]BPAPAY
         Else
          # tiers relancé = tiers facturé
          # Cas 2 : FUPADD vide ou alimenté et n'existe pas parmi adresses du Tiers Facturé
          # --> Adresse de relance = adresse de facturation du Tiers Facturé, champ BPAINV sur onglet Financières (masque BPC3)
          [F:TFP2]ADD = [F:BPC]BPAINV
         Endif
        Else
         # Cas 1 : FUPADD alimenté et existe parmi adresses du  Tiers Facturé
         # Cas 3 : FUPADD alimenté et existe parmi adresses du Tiers Payeur
         # --> Adresse de relance = valeur de FUPADD
         [F:TFP2]ADD = [F:BPA]BPAADD
        Endif
        [F:TFP2]NUMREQ = [M:CFP0]QURNUM

        [F:TFP2]DEP = [F:DUD]DEP
        # lecture du taux d'escompte/agio
        Call LITTABDEP([F:TFP2]DEP,nday([M:CFP1]REFDAT)-nday([F:DUD]DUDDAT),[F:TFP2]DEPRAT) From TRTDIV

        [F:TFP2]FUPMOD = [F:FGP]FUPMOD

        # 59303
        # 71932 - calcul de AMTDEP seulement si "Calcul d'agios" coché
        If [M:CFP2]AGIO=2
         Call ESC_AGIO([F:TFP2]DEP,date$,[F:DUD]DUDDAT,nday([M:CFP1]REFDAT)-nday([F:DUD]DUDDAT),MTDES,[F:DUD]CUR,[F:TFP2]AMTDEP,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From MODECHE
         # on inverse le signe de l'agio pour stocker le montant en positif
         [F:TFP2]AMTDEP = -[F:TFP2]AMTDEP
         Local Integer STA
         Call CONVERT([F:CPY]ACCCUR, [F:DUD]CUR, [F:CPY]ACCCUR, [L]TYPCOURS, [M:CFP1]REFDAT, [F:TFP2]AMTDEP, [F:TFP2]AMTDEPCUR, [L]STA) From TRTDEV
         If [L]STA <> 0 Then
             Call ERREUR(mess(1017,196,1)) From GESECRAN
         Endif
        Endif
        Write [F:TFP2]
        If fstat : ABR = 'TFP2' : Break 3 : Endif
       Endif
      Endif
     Endif # OKDUD
    Next # rupture échéance

    Raz [F:TFP1]
    If NBFUP>0
     [F:TFP1]NUMREQ = [M:CFP0]QURNUM
     [F:TFP1]BPC = [F:BPC]BPCNUM
     [F:TFP1]CPY = [F:DUD]CPY
     [F:TFP1]FCY = [F:DUD]FCY
     If NBSEL=0
      [F:TFP1]SEL = 1 # no open item selected
     Elsif NBNSEL=0
      [F:TFP1]SEL = 3 # all open items selected
     Else
      [F:TFP1]SEL = 2 # some open items selected
     Endif
     [F:TFP1]CREUSR = GUSER
     [F:TFP1]CREDAT = date$
     [F:TFP1]UPDUSR = GUSER
     [F:TFP1]UPDDAT = date$
     Write [F:TFP1]
     If fstat
      GOK = 0 : ABR = 'TFP1' : Goto OK2
     Endif
    Endif
   Next # Rupture société/site

   If TOTAL>0 and (CONTCLI=0 or [L]TOTAL>[L]MNTMIN)
    NBBPC+=1
   Else
    Delete [TFP1] Where NUMREQ=[M:CFP0]QURNUM and BPC=[BPC]BPCNUM
    If fstat=1
     GOK = -1 : GLOCK = "$TMPFUP1"-[M:CFP0]QURNUM-[BPC]BPCNUM : Goto OK2
    Elsif fstat
     ABR = "TFP1" : GOK = 0 : Goto OK2
    Endif

    Delete [TFP2] Where NUMREQ=[M:CFP0]QURNUM and BPC=[BPC]BPCNUM
    If fstat=1
     GOK = -1 : GLOCK = "$TMPFUP2"-[M:CFP0]QURNUM-[BPC]BPCNUM : Goto OK2
    Elsif fstat
     ABR = "TFP2" : GOK = 0 : Goto OK2
    Endif
   Endif
  Next # End of [BPC] loop
 Filter [LNKC]

 If fstat
  GOK = 0 : ABR = 'TFP2' : Goto OK2
 Endif

 If NBBPC=0
  # No open item matches the chosen criteria, please check your criteria.
  Call ERREUR(mess(209,117,1)) From GESECRAN
  Raz [M:CFP0]QURNUM
  FIN=0
 Else
  # calcul de [F:TFP1]FUPTOTAMT
  Gosub UPD_FUPTOTAMT From TRTFUP

  If fstat=0
   # all CRITFUP fields are saved into TMPFUP0 table
   [F:TFP0] = [M:CFP0]
   [F:TFP0] = [M:CFP1]
   [F:TFP0] = [M:CFP2]
   Write [F:TFP0]
   If fstat
    GOK = 0 : ABR = 'TFP0' : Goto OK2
   Endif
  Endif
 Endif

 $OK2
 If GOK=-1
  Goto ROLL_EXEC2
 Elsif GOK=0
  Call FSTA(ABR) From GLOCK : Rollback
 Else
  Commit # campaign creation
 Endif
Else # [M:CFP0]QURNUM not empty -> the campaign already exists -> update its comment
 Call DEBTRANS From GLOCK

 $TR3
 GOK = 1
 Trbegin [TFP0]
  Update [TFP0] Where [F:TFP0]QURNUM=[M:CFP0]QURNUM With [F:TFP0]CMT=[M:CFP0]CMT, UPDUSR=GUSER, UPDDAT=date$
  If fstat
   GOK = -1 : GLOCK = "$TMPFUP0"-num$([M:CFP0]QURNUM) : Goto ROLL_TR3
  Else
   Commit # comment update
  Endif
Endif

If GOK<>0 and GSERVEUR : Gosub VALIDATION From TRTFUPVAL : Endif
Return

######################################################################################

$CONT_SEUIL
If [L]CONTCLI=0
 # contrôle par échéance
 Raz [L]MNT
Endif
Gosub CONT_SEUIL2
Return

$CONT_SEUIL2
If (find([F:BPC]FUPTYP,2,3,4) & [M:CFP1]REFDAT-[F:DUD]DUDDAT>[F:FGP]SEUILS(min([F:DUD]LEVFUP, dim([F:FGP]SEUILS)-1)))
&  or ([F:BPC]FUPTYP=5 & [M:CFP1]REFDAT-[F:DUD]DUDDAT>[F:FGP]SEUILS(0))
 If [F:HAE]TYP<>[F:DUD]TYP or [F:HAE]NUM<>[F:DUD]NUM
  Read [HAE]HAE0=[F:DUD]TYP;[F:DUD]NUM
 Else
  Raz fstat
 Endif
 If fstat | [F:HAE]FLGREP<>2

# convertir le montant dans la même devise que le montant mini relance : devise zone commune GCURSHR
  If [F:CPY]CPY<>[F:DUD]CPY : Read [CPY]CPY0=[F:DUD]CPY : Endif
  DEVORG = [F:DUD]CUR
  DEVDES = GCURSHR
  DEVSOC = [F:CPY]ACCCUR
  MTORG = ([F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR)*[F:DUD]SNS
  DATCOURS = [F:DUD]DUDDAT : # conversion par rapport à la date d'échéance : à voir....

  If DEVORG = DEVDES
   [L]MTDES = [L]MTORG
  Elsif DEVSOC = DEVDES
   [L]MTDES = ([F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC)*[F:DUD]SNS
  Else
   Call CONVERT(DEVORG, DEVDES, DEVSOC, TYPCOURS, DATCOURS, MTORG, MTDES, STAT) From TRTDEV
  Endif

  [L]MNT += [L]MTDES
 Endif
Endif
Return

######################################################################################

$FUPSELDUD
    If [L]LNEW_LEVFUP > [F:FGP]FUPMAX Then
        Return
    Endif
    Local Integer LNEW_INTERVAL
    [L]LNEW_INTERVAL = [F:FGP]FUPINTERVAL([L]LNEW_LEVFUP - 1)

    Local Date LTODAY
    # consider the reference date
    If [M:CFP1]REFDAT <> date$() and [M:CFP1]REFDAT <> [0/0/0] Then
        [L]LTODAY = [M:CFP1]REFDAT
    Else
        [L]LTODAY = date$()
    Endif

    Local Date DUEDATE
    If [F:DUD]DUDDAT > [F:DUD]DATFUP Then
        [L]DUEDATE = [F:DUD]DUDDAT
    Else
        [L]DUEDATE = [F:DUD]DATFUP
    Endif

    If [L]DUEDATE + [L]LNEW_INTERVAL > [L]LTODAY Then
        [L]OKDUD = 0 # no reminder
    Else
        [L]OKDUD = 1 # reminder
    Endif
Return

######################################################################################

$FIN
FIN = 1 : GOK = 0
Return

$SORTIE
If dim(SVG_ADXLIG)>0 : adxlig=SVG_ADXLIG : Endif
Return

######################################################################################
## Labels for CRITFUP0 and CRITFUP1 masks
######################################################################################

$CHARGE_CFP0
Read [TFP0]TFP0=NUM
[M:CFP0] = [F:TFP0]
[M:CFP1] = [F:TFP0]
[M:CFP2] = [F:TFP0]

If GBATCH : Raz [M:CFP0]QURNUM : Endif

Call C_ALLFCY([M:CFP1]ALLFCY)
Call C_ALLSAC([M:CFP1]ALLSAC)
If varmode([M:CFP1]GRPSAC)=0
 Call C_GRPSAC([M:CFP1]GRPSAC)
Endif
If varmode([M:CFP1]GRPSAC)=0
 Call C_SAC([M:CFP1]SAC)
Endif

Call C_ALLBPC([M:CFP1]ALLBPC)
Call C_ALLPAM([M:CFP1]ALLPAM)
Call C_ALLFGP([M:CFP1]ALLFGP)
Call C_ALLUSR([M:CFP1]ALLUSR)

Call C_ALLBPCGRU([M:CFP2]ALLBPCGRU) From TRTCFUP2
Call C_ALLBPCRSK([M:CFP2]ALLBPCRSK) From TRTCFUP2
Call C_ALLREP1([M:CFP2]ALLREP1) From TRTCFUP2
Call C_ALLREP2([M:CFP2]ALLREP2) From TRTCFUP2
Call C_ALLCLS([M:CFP2]ALLCLS) From TRTCFUP2
Call C_ALLTSCCOD([M:CFP2]ALLTSCCOD) From TRTCFUP2
Return

Subprog AP_QURNUM(VALEUR)
Variable Char VALEUR()
Local Char FLD(100), NUM(250)
Local Integer DIMFLD

If VALEUR<>""
 NUM = VALEUR
 Gosub CHARGE_CFP0
Endif

Affzo [M:CFP0]
Affzo [M:CFP1]
Affzo [M:CFP2]
If GBATCH=0
 Diszo [M:CFP1]
 Diszo [M:CFP2]
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# Issue X3-38477-A Option C // Create
  If clalev([F:AFP])=0  : Local File "AFCTPRF" [AFP]  : Endif : # Habilitations fonctionnelles
  Read [AFP]AFP0 = GPROFIL ; GUSRFCT; VALEUR
  If fstat <> [V]CST_AOK
    Read [AFP]AFP0 = GPROFIL ; GUSRFCT; ""
  Endif
  If (fstat = [V]CST_AOK and !instr(1,[F:AFP]OPT,"C")) or (fstat<>[V]CST_AOK and GNBAUZ<>GNBSITE)
    Call ERREUR(VALEUR - mess(00003,02303,1)) From GESECRAN
    VALEUR=""
  Endif
# End issue X3-38477-A

Local Char CUR(GLONCUR), MESSA(250), PLAN(GLONCOA)
Local Integer OKLEG

Raz mkstat, [M:CFP1]COA
Raz GCURLEG, OKLEG

For [AGC]AGC0 Where GRP=VALEUR
 Read [F:CPY]CPY0=[F:AGC]CPY
 If [F:CPY]CPYLEGFLG<>2
  # This company is not a legal company!
  GMESSAGE = [F:AGC]CPY-mess(12,199,1)
  mkstat = 2
  Break
 Endif
 # Initialization GCURLEG if all companies in the group have the same legislation
 If !OKLEG & GCURLEG=""
  GCURLEG=[F:CPY]LEG
 Elsif GCURLEG<>[F:CPY]LEG
  OKLEG=1
 Endif

 # we check that all companies in the group use the same currency
 If CUR<>""
  If CUR<>[F:CPY]ACCCUR
   # Not all companies have the same currency
   GMESSAGE = mess(134,116,1)
   mkstat = 2
   Break
  Endif
 Else
  CUR = [F:CPY]ACCCUR
 Endif
Next
If mkstat
 End
Endif
If OKLEG : Raz GCURLEG : Endif

Actzo [M:CFP1]ALLSAC, GRPSAC, SAC
Call C_ALLSAC([M:CFP1]ALLSAC)
For [AGC]AGC0 Where GRP=VALEUR
 Read [F:CPY]CPY0=[F:AGC]CPY
 # Returns the chart of accounts associated with the main general ledger
 Call LECMAINPLAN(1,[F:CPY]CPY,PLAN) From CPTDIV
 If [M:CFP1]COA=""
  [M:CFP1]COA=PLAN
 Elsif [M:CFP1]COA<>PLAN
  # Not all companies use the same chart of accounts for this ledger type ---> we delete and disable GRPSAC and SAC fields
  [M:CFP1]ALLSAC = 2 # "All collective accounts" checked
  # 69877
  Raz [M:CFP1]GRPSAC, [M:CFP1]SAC
  Grizo [M:CFP1]ALLSAC, GRPSAC, SAC
  Affzo [M:CFP1]ALLSAC, GRPSAC, SAC
  Break
 Endif
Next
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Actzo [M:CFP1]FCY
Else
 #Call C_CPY([M:CFP1]CPY)
 Raz [M:CFP1]FCY : Diszo [M:CFP1]FCY
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer OK

If [M:CFP1]CPY<>""
 Call LEC_FCY(VALEUR) From CPTLEC

 OK=0
 For [AGC]AGC0 Where GRP=[M]CPY
  If [F:FCY]LEGCPY=[F:AGC]CPY : OK=1 : Break : Endif
 Next
 If OK
  Call LECMAINPLAN(1,[F:AGC]CPY,[M:CFP1]COA) From CPTDIV
  Actzo [M:CFP1]ALLSAC, GRPSAC, SAC
  Affzo [M:CFP1]ALLSAC, GRPSAC, SAC
  Call C_ALLSAC([M:CFP1]ALLSAC)
  End
 Endif

 # This site is in the company
 GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
 mkstat = 2 : End
Endif
End

$S_FCY
OBJET="FCY"
If [M:CFP1]CPY<>""
 CRITERE="LEGCPY='"+[M:CFP1]CPY+"'"
Endif
Return

Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 If [M:CFP1]GRPSAC<>""
  Actzo [M:CFP1]GRPSAC : Diszo [M:CFP1]SAC
 Elsif [M:CFP1]SAC<>""
  Diszo [M:CFP1]GRPSAC : Actzo [M:CFP1]SAC
 Else
  Actzo [M:CFP1]GRPSAC, SAC
 Endif
Else
 # 69877
 Raz [M:CFP1]SAC, [M:CFP1]GRPSAC : Diszo [M:CFP1]SAC, GRPSAC
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char    VALEUR()
If [M:CFP1]ALLSAC = 2 | [M:CFP1]GRPSAC<>""
 mkstat=1 : End
Endif
End

Subprog C_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M:CFP1]GRPSAC : Diszo [M:CFP1]GRPSAC
Else
 Actzo [M:CFP1]GRPSAC
 If [M:CFP1]ALLSAC=1 and [M:CFP1]GRPSAC=""
  mkstat=1
 Endif
Endif
End

Subprog AS_GRPSAC(VALEUR)
Variable Char    VALEUR()
If [M:CFP1]ALLSAC=2
 mkstat = 1 : End
Endif
End

Subprog C_GRPSAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M:CFP1]SAC
 Diszo [M:CFP1]SAC
Else
 Actzo [M:CFP1]SAC
Endif
End

Subprog C_ALLBPC(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP1]BPCDEB, BPCFIN
Else
 Raz [M:CFP1]BPCDEB, [M:CFP1]BPCFIN : Diszo [M:CFP1]BPCDEB, BPCFIN
Endif
End

Subprog C_BPCFIN(VALEUR)
Variable Char    VALEUR()
If [M:CFP1]BPCDEB="" and VALEUR=""
 mkstat=2
Endif
End

Subprog C_ALLPAM(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP1]PAM
Else
 Raz [M:CFP1]PAM : Diszo [M:CFP1]PAM
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP1]USR
Else
 [M:CFP1]USR="" : Diszo [M:CFP1]USR
Endif
End

Subprog AS_FUPLEVEND(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 VALEUR=[M:CFP1]FUPLEVSTR
Endif
End

Subprog C_FUPLEVEND(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M:CFP1]FUPLEVSTR
 # End range is less than Start range
 GMESSAGE = mess(44,199,1)
 mkstat=2 : End
#69530
Elsif VALEUR>5
 # Incorrect value
 GMESSAGE = mess(6,199,1)
 mkstat=2 : End
Endif
End

Subprog AM_CMT(VALEUR)
Variable Char    VALEUR()
# In batch mode we do not modify the comment of the selected request (we want to duplicate the whole campaign)
If GBATCH=1 : End : Endif

# If we select an existing campaign, our only option is to modify its comment
If varmode([M:CFP0]QURNUM)=0
 Trbegin [TFP0]
 Update [TFP0] Where QURNUM=[M:CFP0]QURNUM With CMT=VALEUR, UPDUSR=GUSER, UPDDAT=date$
 If fstat : Call FSTA('TFP0') From GLOCK : Rollback Else Commit Endif
Endif
End

Subprog C_ALLFGP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP1]FGP
Else
 [M:CFP1]FGP="" : Diszo [M:CFP1]FGP
Endif
End

Subprog AS_BPCDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPC=2 : mkstat=1 : Endif
End

Subprog AS_BPCFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPC=2 : mkstat=1 : Endif
If VALEUR="" | VALEUR<[M]BPCDEB : VALEUR=[M]BPCDEB : Endif
End

# necessary to avoid error messages such as :
# "Réservé au groupe de société : RUS"
Subprog C_QURNUM(VALEUR)
Variable Char    VALEUR()
Raz GSOCIETE
If VALEUR=""
 If GBATCH
  # we accept an empty value only if we are setting batch parameters
  mkstat = 0
 Else
  mkstat = 1
 Endif
Endif
End

###############################################################################
# Input controls for RPTBATCH1, RPTBATCH2, RPTDST1, RPTDST2 parameters
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Local Integer FICDST
Local Char VALPAR(250)
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

Case PARAM
 When "RPTBATCH1", "RPTBATCH2" :
  If VALEUR="" : End : Endif
  Read [AIM]AIM0=VALEUR
  If [AIM]PRT=1
   # Destination set in '$1' parameter must not be of 'Preview' type.
   GMESSAGE = mess(253,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
  If [AIM]PRTSRV=""
   # Destination set in '$1' parameter must be associated with a printing server.
   GMESSAGE = mess(254,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
 When "FUPRPTDIR" :
  If VALEUR=""
   FICDST = 0
   For P='RPTBATCH1', 'RPTBATCH2', 'RPTDST1', 'RPTDST2'
    Call PARAML("", P, VALPAR) From ADOVAL
    Read [AIM]AIM0=VALPAR
    If fstat=0 and [AIM]PRT=4
     FICDST = 1 : Break
    Endif
   Next
   GMESSAGE = mess(559,199,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Else
   # 70168
   If(right$(VALEUR, len(VALEUR))<>"/" and right$(VALEUR, len(VALEUR))<>"\")
    # "The value must end with / or \"
    GMESSAGE = mess(256,117,1)
    OK = 0
    End
   Endif
  Endif
Endcase
End

# Returns the threshold to use for an open item date and a reference date
Funprog GET_THRESHOLD(OIDAT, REFDAT, THRESHOLDS)
Value Date OIDAT
Value Date REFDAT
Value Integer THRESHOLDS()
Local Integer T

# sort the reminder thresholds in ascending order (just to be sure)
Sorta THRESHOLDS Order By THRESHOLDS(indice)

For T=0 To dim(THRESHOLDS)-1
 # exit the loop as soon as the open item delay exceeds threshold K
 If REFDAT-OIDAT<THRESHOLDS(T) : Break : Endif
Next
T = min(T, dim(THRESHOLDS))
End T

