##########################################################################
# Saisie des règles de gestion par défaut des flux de sortie
# Alimentation de la table TABSTORUL
# Action SAISTORUL de type saisie de fenêtre
##########################################################################

########################################
# Actions sur champs                   #
########################################

#######################################
Subprog APRES_NBSRU2
[M:SRU2]UPDFLG(nolign-1) = 1
End

########################################
Subprog AS_TRSTYP(VALEUR)
Variable Integer VALEUR
mkstat = 2
End

########################################
Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()
# contrôle en cas de saisie directe
VALEUR = toupper(VALEUR)
Call CTR_LIST_SST(VALEUR,[M:SRU2]AUZSTA(nolign-1)) From TRTCATEG

# construction de la formule :
Call DECODE_STAT(VALEUR,[M:SRU2]FORSTA(nolign-1)) From TRTCATEG

End

