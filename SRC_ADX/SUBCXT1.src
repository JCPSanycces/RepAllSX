#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
Subprog AS_NBPBL

If nolign - 1 >= 0
    GSZCXT1SELPBL = [M:CXT1]PBL(nolign - 1)

    Call LOADREPSTAT(GSZCXT1SELPBL) From TRTCXT1
    Call LOADQUESTAT(GSZCXT1SELPBL) From TRTCXT1
Endif


[M:CXT1]NVGCOD = "1"
Affzo [M:CXT1]

End

##########################################################################
Subprog C_NBPBL

If nolign - 1 >= 0
    GSZCXT1SELPBL = [M:CXT1]PBL(nolign - 1)

    Call LOADREPSTAT(GSZCXT1SELPBL) From TRTCXT1
    Call LOADQUESTAT(GSZCXT1SELPBL) From TRTCXT1
Endif

[M:CXT1]NVGCOD = "1"
Affzo [M:CXT1]
End

##########################################################################
Subprog IB_NBPBL
#Gestion du Bouton : Familles parents
#Gestion du bouton : Revenir au sommet

#Familles filles
Call TEXTE(15600, GBOUT2) From OBJDIV

If GICXT1ATTOP
    Raz GBOUT1
    Raz GBOUT3
Else
    GBOUT1 = mess(265, 196, 2) #Familles parents.
    GBOUT3 = mess(264, 196, 2) #Revenir au sommet.
Endif

#Demandes de service
Call TEXTE(14508, GBOUT4) From OBJDIV

End

##########################################################################
Subprog B1_NBPBL

Gosub LOADPAEPBL From TRTCXT1
Affzo [CXT1]
End

##########################################################################
Subprog B2_NBPBL

Gosub LOADSUBPBL From TRTCXT1
Affzo [CXT1]
End

##########################################################################
Subprog B3_NBPBL

Gosub LOADCXT1 From TRTCXT1

End

##########################################################################
Subprog AS_NBAUS
If nolign - 1 >= 0
    [M:CXT1]SELAUS = [M:CXT1]AUS(nolign - 1)
Endif

[M:CXT1]NVGCOD = "2"
End

##########################################################################
Subprog C_NBAUS
If nolign - 1 >= 0
    [M:CXT1]SELAUS = [M:CXT1]AUS(nolign - 1)
Endif

[M:CXT1]NVGCOD = "2"
