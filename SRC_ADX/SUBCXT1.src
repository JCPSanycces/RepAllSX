##########################################################################
Subprog AS_NBQUE
If nolign - 1 >= 0
    [M:CXT1]SELQUE = [M:CXT1]QUE(nolign - 1)
Endif

[M:CXT1]NVGCOD = "3"
End

##########################################################################
Subprog C_NBQUE
If nolign - 1 >= 0
    [M:CXT1]SELQUE = [M:CXT1]QUE(nolign - 1)
Endif

[M:CXT1]NVGCOD = "3"
End

##########################################################################
Subprog IB_NBAUS
#Demandes de service
Call TEXTE(14508, GBOUT1) From OBJDIV
End

##########################################################################
Subprog IB_NBQUE
#Demandes de service
Call TEXTE(14508, GBOUT1) From OBJDIV
End



