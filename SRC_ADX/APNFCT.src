#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = ""
PARAM(2) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","APNFCT","APN9",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT_DIA
[M]PROFIL = PARAM(1)
[M]INTPRF = PARAM(2)
Return

$CONTROLE
If [M]NBSIT1=0 & [M]NBSIT2=0
 [M]NBSIT1 = 1
 [M]GRUCOD1(0) = 1
 [M]FCYGRU1(0) = ""
 Affzo
Endif
Return

$EXEC
Local Integer I , J , K
Local Integer OPTENA
Local Char    OPTION(50)
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AMU])=0 : Local File AMENUSER  [AMU] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Call MAJAFF([M]PROFIL) From SUBAFP1
Endif
Return

$TR1
GOK = 1
Trbegin [AFT]

 Delete [AFP] Where PRFCOD=[M]PROFIL
 Delete [AFF] Where PRFCOD=[M]PROFIL

# Création AFCTFCT

 Read [AFT]AFT0 = [M]PROFIL
 If fstat
  Raz [F:AFT]
  Call MAJTEXTRA([M]INTPRF,"AFCTFCT","INTPRF",[M]PROFIL,"") From ATEXTRA
  [F:AFT]PRFCOD = [M]PROFIL
  [F:AFT]ALLACS = 1
  [F:AFT]ALLFCT = 1
  [F:AFT]DIFIMP = 2
  [F:AFT]FILTRE = "*"
  [F:AFT]CREUSR = GUSER
  [F:AFT]CREDAT = date$
  If dim([F:AFT]CRETIM)>0 : [F:AFT]CRETIM = time : Endif
  For I=0 To dim([F:AFT]AUTETA)-1
   [F:AFT]AUTETA(I) = 2
  Next I
  For I=0 To dim([F:AFT]FCYDEF)-1
   [F:AFT]FCYDEF(I) = [M]FCYDEF
  Next I
  Write [AFT]
  If fstat
   GOK = 0 : Call FSTA("AFT") From GLOCK : Goto AB_TR1
  Endif
 Endif

# Habilitations fonctionnelles

 For [AMU]MENFCT(2) Where CODPRF=[M]PROFIL & FONCTION<>"" & FONCTION<>"MENU"
  Read [AFC]CODINT = [F:AMU]FONCTION
  If !fstat
   Raz [F:AFP]
   [F:AFP]PRFCOD = [M]PROFIL
   [F:AFP]FNC    = [F:AFC]CODINT
   [F:AFP]CREUSR = GUSER
   [F:AFP]CREDAT = date$
   If dim([F:AFP]CRETIM)>0 : [F:AFP]CRETIM = time : Endif
   If [F:AFC]FCYAUZ=2
    For I=0 To [M]NBSIT1-1
     [F:AFP]FCYGRUCOD = [M]GRUCOD1(I)
     [F:AFP]FCYGRU    = [M]FCYGRU1(I)
     [F:AFP]ACS       = 2
     Gosub OPTION
     [F:AFP]OPT       = OPTION
     Write [AFP]
     If fstat
      GOK = 0 : Call FSTA("AFP") From GLOCK : Break 2
     Endif
    Next I
    For I=0 To [M]NBSIT2-1
     [F:AFP]FCYGRUCOD = [M]GRUCOD2(I)
     [F:AFP]FCYGRU    = [M]FCYGRU2(I)
     [F:AFP]ACS       = 1
     [F:AFP]OPT       = ""
     Write [AFP]
     If fstat
      GOK = 0 : Call FSTA("AFP") From GLOCK : Break 2
     Endif
    Next I
   Else
    I = 0
    Gosub OPTION
    [F:AFP]FCYGRUCOD = 0
    [F:AFP]FCYGRU    = ""
    [F:AFP]ACS       = 2
    [F:AFP]OPT       = OPTION
    Write [AFP]
    If fstat
     GOK = 0 : Call FSTA("AFP") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif

 GPOINT = "UPDFCT" : Gosub ENTREE From EXEFNC
 If GOK<1 : Goto AB_TR1 : Endif

Commit
Return

$AB_TR1
Rollback
Return

$OPTION
OPTION = ""
If [F:AFC]TYP=2
 For OPT="C","M","S"
  If instr(1,[M]FCYOPT1(I),OPT)
   OPTION += OPT
  Endif
 Next OPT
 Call OPTENA([F:AFC]CODINT,OPTENA) From SUBAFP
 If OPTENA & instr(1,[M]FCYOPT1(I),"A")
  OPTION += "N"
 Endif
Endif
If instr(1,[M]FCYOPT1(I),"A")
 For J = 0 To ([F:AFC]NBOPT-1)
  OPTION += [F:AFC]FLAG(J)
 Next J
Endif
Return

######################################################################################
## Ecran APN9
######################################################################################
Subprog C_FCYGRU1(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call UNICITE(VALEUR,[M]FCYGRU1(0..[M]NBSIT1-1)) From OBJDIV
If mkstat : End : Endif
If [M]GRUCOD1(nolign-1)<>2
 If VALEUR<>"" : Call CONTROLE("AGF","",VALEUR,"",mkstat) From CONTOBJ : Endif
Else
 Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
Endif
If mkstat : End :Endif
End

Subprog S_FCYGRU1(VALEUR)
Variable Char    VALEUR()
If [M]GRUCOD1(nolign-1)=1
 Call SELECT("AGF","",VALEUR,"") From SELOBJ
Else
 Call SELECT("FCY","",VALEUR,"") From SELOBJ
Endif
End

Subprog C_FCYGRU2(VALEUR)
Variable Char    VALEUR()
Local Integer I
Call UNICITE(VALEUR,[M]FCYGRU2(0..[M]NBSIT2-1)) From OBJDIV
If mkstat : End : Endif
I = find(VALEUR,[M]FCYGRU1(0..[M]NBSIT1-1))
If I
 GMESSAGE = mess(43,130,1)-"("+num$(I)+")" : # Déjà autorisé
 mkstat = 2 : End
Endif
If [M]GRUCOD2(nolign-1)<>2
 If VALEUR<>"" : Call CONTROLE("AGF","",VALEUR,"",mkstat) From CONTOBJ : Endif
Else
 Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
Endif
If mkstat : End :Endif
End

Subprog S_FCYGRU2(VALEUR)
Variable Char    VALEUR()
If [M]GRUCOD2(nolign-1)=1
 Call SELECT("AGF","",VALEUR,"") From SELOBJ
Else
 Call SELECT("FCY","",VALEUR,"") From SELOBJ
Endif
End

Subprog D_FCYOPT1(VALEUR)
Variable Char    VALEUR
Gosub DEFOPT
VALEUR = OPTIONS
End

Subprog C_FCYOPT1(VALEUR)
Variable Char    VALEUR()
Gosub DEFOPT
Local Integer I
I = 1
While I<=len(VALEUR)
 If !instr(1,OPTIONS,mid$(VALEUR,I,1)) or instr(1,left$(VALEUR,I-1),mid$(VALEUR,I,1))
  VALEUR = left$(VALEUR,I-1)+right$(VALEUR,I+1)
 Else
  I += 1
 Endif
Wend
End

Subprog S_FCYOPT1(VALEUR)
Variable Char    VALEUR()
Gosub DEFOPT
Local Integer NUMOPT
Call SAITEX(NBOPT,LIBEL,NUMOPT,"Choix options") From GESECRAN
If NUMOPT & !instr(1,VALEUR,mid$(OPTIONS,NUMOPT,1))
 VALEUR += mid$(OPTIONS,NUMOPT,1)
Endif
End

$DEFOPT
Local Integer NBOPT
Local Char    OPTIONS(10) , LIBEL(50)(10)
NBOPT    = 4
OPTIONS  = "CMSA"
LIBEL(1) = mid$(OPTIONS,1,1)-mess(59,123,1) : # Création
LIBEL(2) = mid$(OPTIONS,2,1)-mess(3,85,1)   : # Modification
LIBEL(3) = mid$(OPTIONS,3,1)-mess(2,24,1)   : # Suppression
LIBEL(4) = mid$(OPTIONS,4,1)-mess(20,127,1) : # Autres
Return

