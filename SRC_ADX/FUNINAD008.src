#<AdxTL>@(#)8.0.0.0 $Revision$
########################################
Subprog AP_TOUS(VALEUR)
Variable Integer    VALEUR()
If (VALEUR=2) Then
  [M]ABTAB=""
  [M]CODFIC=""
  [M]INTITFIC=""
Endif
End
########################################
Subprog AP_ABTAB(VALEUR)
Variable Char    VALEUR()
Local Integer NUMT
Local Char VTEX

If (VALEUR = "") Then : End : Endif
If ([M]TOUS=2) : End : Endif

Read[ATB]ABRFIC=VALEUR
If fstat : GMESSAGE=mess(5,150,1) : mkstat=2 : End : Endif
NUMT=[F:ATB]INTITFIC
Call TEXTE(NUMT,VTEX) From OBJDIV
[M]INTITFIC=VTEX
[M]CODFIC=[F:ATB]CODFIC

End
########################################
Subprog AP_CODFIC(VALEUR)
Variable Char     VALEUR
Local Integer NUMT
Local Char VTEX

If ([M]TOUS=2) : End : Endif
Read[ATB]CODFIC=VALEUR
If fstat : GMESSAGE=mess(5,150,1) : mkstat=2 : End : Endif
NUMT=[F:ATB]INTITFIC
Call TEXTE(NUMT,VTEX) From OBJDIV
[M]INTITFIC=VTEX
[M]ABTAB=[F:ATB]ABRFIC
Affzo INTITFIC,ABTAB
End
########################################

