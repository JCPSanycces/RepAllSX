#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################################################
#   Préférences horodatage                                          Module CRM          30 janvier 2004 #
#########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return


$OUVRE
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Read [DVA] DVA0 = "HNA";GUSER
If fstat
    [M:HNA1]HNAFLG = 1
    [M:HNA1]HNAAFC = ""
    [M:HNA1]HNARET = 1
    Grizo [M:HNA1]HNAAFC
    Grizo [M:HNA1]HNARET
Else
    [M:HNA1]HNAFLG = 2
    [M:HNA1]HNAAFC = [F:DVA]ALHX(0)
    If [F:DVA]ALHX(1) = ""
        [M:HNA1]HNARET = 1
    Else
        [M:HNA1]HNARET = 2
    Endif
    Actzo [M:HNA1]HNAAFC
    Actzo [M:HNA1]HNARET
Endif

Affzo [M:HNA1]
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:HNA1]
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$ONMENU
Return

$ONOK

Trbegin [DVA]
Delete [DVA] Where [F:DVA]OBC = "HNA" and [F:DVA]PARAM = GUSER
If fstat
    Rollback
    #Erreur lors de l'enregistrement des préférences horodatage.
    GMESSAGE = mess(25, 177, 2)
    GERR = 1
    Return
Else
    Commit
Endif

If [M:HNA1]HNAFLG <> 2 : Return : Endif

Trbegin [DVA]
Raz [F:DVA]
[F:DVA]OBC = "HNA"
[F:DVA]PARAM = GUSER
[F:DVA]ALHX(0) = [M:HNA1]HNAAFC
If [M:HNA1]HNARET = 2
    [F:DVA]ALHX(1) = "RETURN"
Else
    [F:DVA]ALHX(1) = ""
Endif
Write [DVA]
If fstat
    Rollback
    #Erreur lors de l'enregistrement des préférences horodatage.
    GMESSAGE = mess(25, 177, 2)
    GERR = 1
    Return
Else
    Commit
Endif
Return

