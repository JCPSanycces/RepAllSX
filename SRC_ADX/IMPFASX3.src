#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#                IMPORT DES BIENS COMPTABLES X3
#
#*********************************************************************
#    Création
#    GLE - 24.02.2009
#
#*********************************************************************
#    Modification
#
#    Issue X3-63497 - 2017-11-23 by BEFOU : Commenting GREP for Error file
#    CBO - 23.06.2016  FQ116860 erreur "PHYIVY : masque inexistant"
#    MDJ - 09.02.2015  FQ100398 Suppression site géographique
#    GLE - 19.02.2014  FQ96987  Correction suite à la fiche FQ96134
#    GLE - 27.01.2014  FQ95955  Chargement de FASPARCPY pour la création automatique des sections analytiques
#    GLE - 24.01.2014  FQ96134  La société est déduite du site financier
#    GLE - 09.09.2013  FQ91573  Import du plan fiscal optionnel
#    GLE - 20.06.2012  FQ82227  Les actions champs des fenêtres complémentaires n'étaient pas jouées (erreur rubrique ISRCLCBAS obligatoire)
#    GLE - 30.05.2012  FQ82226  Erreur lors de l'import monoligne suite à la correction 79283
#                               Erreur si le plan fiscal n'est pas sur la deuxième ligne du tableau de [M:FAS3]
#    GLE - 17.01.2012  FQ79283  Les associations sont écrasées par des valeurs nulles si les champs sont dans le modèle d'import
#    GLE - 17.01.2012  FQ79242  Les actions champs du tableau des amortissements n'étaient pas jouées
#    GLE - 10.02.2011  FQ?????  Initialisation de [F:CCE]IPT à G_OUI
#    GLE - 03.01.2011  FQ70335  Erreur lors de la création des localisations, étiquette TRAITE_LOC inexistante
#    GLE - 30.06.2010  FQ65744  Erreur sur les éléments physique si le code activité PHY est à Non pour le dossier
#    GLE - 07.04.2010  FQ46184  Correction erreur sur [M:FAS3] lors de l'utilisation du bouton "TEST"
#    GLE - 26.02.2010  FQ62941  Suppression de l'alimentation manuelle des axes ; cette modification va avec la mise à jour de FAS2
#                               (action Init de NBRCCE passe de "Interactive" à "Toujours")
#    GLE - 26.02.2010  FQ62916  Forçage de la dotation exercice : fait à la suite de DPM au lieu de DPRCUM car DPRCUM n'est pas toujours saisissable
#    GLE - 23.02.2010  FQ62830  Biens sortis dans un exercice antérieur : initialisation des dates des exercices courants plus tôt
#    GLE - 01.02.2010  FQ61951  Si une répartition et des axes sont renseignés, seule la répartition est importée
#    GLE - 27.01.2010  FQ61340  Si le montant de TVA facturée n'est pas alimenté dans le fichier d'import, on le force à zéro -> KO
#    GLE - 10.11.2009  FQ59686  Lors de l'import de la base et du cumul d'mortissement, il pouvait y avoir l'erreur
#                               "Le cumul d'amortissement ne peut pas être supérieur à la base amortissable (valeur bilan - valeur résiduelle)."
#    GLE - 09.11.2009  FQ59783  Lorsqu'on importe un mode d'amortissement déjà alimenté par une association mais que celle-ci ne
#                               détermine pas la règle particulière, celle-ci est à 0. Initialisation à 1 dans ce cas.
#    GLE - 30.10.2009  FQ59450  Les biens non sortis suivants un bien sortis étaient sortis également
#    GLE - 22.10.2009  FQ59159  L'import de ENDDPE ne fonctionnait pas
#    GLE - 13.07.2009  FQ56478  Appel de l'action de sortie en mode silencieux
#  SYMEU - 04.05.2009  FQ49517  Numérotation des éléments physiques à partir du bien
#    GLE - 13.05.2009  FQ55143  Forçage TVA, TVA récupérée et cumul d'amortissement : pb dans la chronologie
#
#*********************************************************************

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

  Case ACTION
    When "IMP_OUVRE"     : Gosub IMP_OUVRE
    When "IMP_FERME"     : Gosub IMP_FERME
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMPORT"        : Gosub IMPORT

    When "SET_IMPMOD"    : IMPMOD = 1

    When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
    When "IMP_INICRE"    : Gosub IMP_INICRE
    When "IMP_CREATION"  : Gosub IMP_CREATION
    When "IMP_APRES_CRE" : Gosub IMP_APRES_CRE : # FQ56478

    When "AP_IMPORT"     : Gosub AP_IMPORT
    When Default
  Endcase
Return

####################################################################
# Au début de l'import
#
$IMP_OUVRE
  # Contrôle que la mise à jour est bien interdite
  If [M:AOE1]OPTUPD = G_OUI
    OK       = 0
    GERR     = 1
    GMESSAGE = mess(26,141,1)-[M:AOE0]EXT-":"-mess(686,7773,1)
    Return
  Endif

  # Chargement des masques des quatres fenetres complementaires de la fenêtre de gestion
  # des biens comptables
  Global Mask FASISR [FASI]       : # Assurance
  Global Mask FASVEH [FASV]       : # Véhicule
  Global Mask FASNSP [FASN]       : # Valeur marché
#FQ116860
#  If GPHY = G_OUI : # FQ65744
#    Global Mask PHYIVY [PHYY]     : # Inventaire
#  Endif
  Global Mask FASPARCPY [FPC]     : # Environnement comptable
  Local Integer RERROR            : # Code retour FQ95955

  Global Char TRTSTD_ISR (12)     : # Traitement standard de l'action du menu Assurance
  Global Char TRTSPE_ISR (12)     : # Traitement spécifique de l'action du menu Assurance
  Global Char TRTSTD_VEH (12)     : # Traitement standard de l'action du menu Véhicule
  Global Char TRTSPE_VEH (12)     : # Traitement spécifique de l'action du menu Véhicule
  Global Char TRTSTD_NSP (12)     : # Traitement standard de l'action du menu Valeur marché
  Global Char TRTSPE_NSP (12)     : # Traitement spécifique de l'action du menu Valeur marché
#FQ116860
#  Global Char TRTSTD_IVY (12)     : # Traitement standard de l'action du menu Inventaire
#  Global Char TRTSPE_IVY (12)     : # Traitement spécifique de l'action du menu Inventaire

  Global Char FORMAT_DATE (8)     : # Format des dates pour l'import
  Global Integer FASPLN (3..5)    : # Numéro des 3 plans supplémentaires
  Global Integer CRELOC           : # Indicateur de création auto de la localisation
  Global Integer CREACGGRP        : # Indicateur de création auto de la famille
  Global Integer CRECCE(GOPTCANA) : # Indicateur de création auto des sections analytiques
  Global Integer CREUSRFL(10)     : # Indicateur de création auto des zones libres alpha
  Global Integer REPENDDPE        : # Indicateur de reprise de la dotation exercice
  Global Char GSEPDEC             : # Séparateur décimal du modèle d'import
  Global Integer G_DERRVEISS      : # Reprise de dérogatoire sur sortie

  # FQ33442
  Global Date    L_STRFIYCOU(1..G300MAX)
  Global Date    L_ENDFIYCOU(1..G300MAX)
  Global Date    L_STRPERCOU(1..G300MAX)
  Global Date    L_ENDPERCOU(1..G300MAX)
  Global Integer L_FLGPER   (1..G300MAX)

  Global Integer N_I              : # FQ48941

  Global Char GCPY_CURR           : # Contient la société du dernier bien importé
  GCPY_CURR = ""

  Local Integer L_I

  # Ouverture de FASS pour la gestion de la sortie par action silencieuse
  If !clalev([F:FASS]) : Local File FXDASSETS  [FASS] : Endif : # FQ56478

  # Ouverture de la table COMPANY pour les associations
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

  # Ouverture de la table FACILITY pour déterminer la société FQ96134
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

  # Chargement des actions des menus OI, ON, OM et OP
  Local File AWINBOUT [AWT]

  For [F:AWT] Where WIN = "OFAS"
    Case [F:AWT]CODBOUT
      When "OI" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_ISR, TRTSPE_ISR)
      When "ON" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_VEH, TRTSPE_VEH)
      When "OM" : Call CHERCHE_TRT_ACTION([F:AWT]ACTBOUT, TRTSTD_NSP, TRTSPE_NSP)
    Endcase
  Next
  # Il n'y a plus d'action inventaire liée au bien
#  TRTSTD_IVY="SUBPHYY"
#  TRTSPE_IVY="SPEPHYY"

  Close Local File [AWT]

  # Format des dates pour l'import
  Case [M:AOE1]OPTDAT
    When 1 : FORMAT_DATE = "DDMMYY"
    When 2 : FORMAT_DATE = "DDMMYYYY"
    When 3 : FORMAT_DATE = "YYMMDD"
    When 4 : FORMAT_DATE = "YYYYMMDD"
  Endcase

  # Ouverture des tables pour la création du réferentiel
  #If !clalev([F:LOC]) : Local File LOCALIZAT [LOC] : Endif : # Localisation
  If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif : # Tables diverses
  If !clalev([F:CCE]) : Local File CACCE     [CCE] : Endif : # Table des sections analytiques

  # Chargement des paramètres d'autorisation de création du réferentiel
  Local Char LPARM
  Call PARAM("","CRELOC",LPARM) From ADOVAL                   : # Localisation
  CRELOC = val(LPARM)

  Call PARAM("","CREACGGRP",LPARM) From ADOVAL                : # Famille
  CREACGGRP = val(LPARM)

  For L_I=0 To GOPTCANA-1
    Call PARAM("","CRECCE"+num$(L_I+1),LPARM) From ADOVAL     : # Sections analytiques
    CRECCE(L_I) = val(LPARM)
  Next L_I

  For L_I=0 To 9
    Call PARAM("","CREUSRFL"+num$(L_I+1),LPARM) From ADOVAL     : # Zones libres
    CREUSRFL(L_I) = val(LPARM)
  Next L_I

  GSEPDEC = [M:AOE1]SEPDEC : If GSEPDEC="" : GSEPDEC="." : Endif

  # Mise à jour du paramètre d'import des biens en inactif
  Call PARAM("","DISAFAS",LPARM) From ADOVAL     : # Sections analytiques
  GDISAFAS = val(LPARM)

  GCOUSIT = "" : # Pour forcer le rechargement FQ96134
Return

####################################################################
# A la fin de l'import
#
$IMP_FERME
  # Fermeture des masques
  If clalev([M:FASI]) : Close Local Mask [M:FASI] : Endif
  If clalev([M:FASV]) : Close Local Mask [M:FASV] : Endif
  If clalev([M:PHYY]) : Close Local Mask [M:PHYY] : Endif
  If clalev([M:FASN]) : Close Local Mask [M:FASN] : Endif
  If clalev([M:FPC])  : Close Local Mask [M:FPC]  : Endif

  # Suppression des variables
  If dim(TRTSTD_ISR)>0 : Kill TRTSTD_ISR : Endif
  If dim(TRTSPE_ISR)>0 : Kill TRTSPE_ISR : Endif
  If dim(TRTSTD_VEH)>0 : Kill TRTSTD_VEH : Endif
  If dim(TRTSPE_VEH)>0 : Kill TRTSPE_VEH : Endif
  If dim(TRTSTD_NSP)>0 : Kill TRTSTD_NSP : Endif
  If dim(TRTSPE_NSP)>0 : Kill TRTSPE_NSP : Endif
  #FQ116860
#  If dim(TRTSTD_IVY)>0 : Kill TRTSTD_IVY : Endif
#  If dim(TRTSPE_IVY)>0 : Kill TRTSPE_IVY : Endif

  If dim(FORMAT_DATE)>0 : Kill FORMAT_DATE : Endif
  If dim(FASPLN)>0      : Kill FASPLN      : Endif
  If dim(CRELOC)>0      : Kill CRELOC      : Endif
  If dim(CREACGGRP)>0   : Kill CREACGGRP   : Endif
  If dim(CRECCE)>0      : Kill CRECCE      : Endif
  If dim(CREUSRFL)>0    : Kill CREUSRFL    : Endif
  If dim(REPENDDPE)>0   : Kill REPENDDPE   : Endif
  If dim(GSEPDEC)>0     : Kill GSEPDEC     : Endif
  If dim(L_STRFIYCOU)>0 : Kill L_STRFIYCOU : Endif
  If dim(L_ENDFIYCOU)>0 : Kill L_ENDFIYCOU : Endif
  If dim(L_STRPERCOU)>0 : Kill L_STRPERCOU : Endif
  If dim(L_ENDPERCOU)>0 : Kill L_ENDPERCOU : Endif
  If dim(L_FLGPER)>0    : Kill L_FLGPER    : Endif
  If dim(GCPY_CURR)>0   : Kill GCPY_CURR   : Endif
  If dim(N_I)>0         : Kill N_I         : Endif

  # Fermeture des tables pour l'alimentation du réferentiel
  If clalev([F:LOC]) : Close Local File [LOC]    : Endif
  If clalev([F:ADI]) : Close Local File [ADI]    : Endif
  If clalev([F:CCE]) : Close Local File [CCE]    : Endif
Return

####################################################################
# Verification avant l'enregistrement.
#
$IMP_VERIF_CRE
Return

####################################################################
# Alimentation de certaines zones de la classe [F] avant enregistrement.
#
$IMP_INICRE
  Gosub IMP_INICRE From IMPFAS
Return

####################################################################
# Après la création du bien.
#
$IMP_CREATION
  Gosub IMP_CREATION From IMPFAS
Return

#################################################################### FQ56478
# Après la création du bien, après le commit
#
$IMP_APRES_CRE
  Gosub IMP_APRES_CRE From IMPFAS : # FQ56478
Return

####################################################################
# Avant la simulation de la saisie
#
$IMPORT
  # Initialisation de la classe [F:FASS] des informations de sortie FQ59450
  Raz [F:FASS]

  # Initialisation de la société à partir du site financier FQ96134 FQ95955 FQ96987
  Call ACTION_FCY([F:FAS]FCY,[F:FAS]CPY) From GLOFCYCPY

  Local Char WPARAM

  # Lecture du paramètre de numérotation automatique
  Call PARAM([F:FAS]CPY,"AASAUTNUM",WPARAM) From ADOVAL
  GAASAUTNUM = val(WPARAM)
  If GPHY = G_OUI
    Call PARAM([F:FAS]CPY,"PHYAUTNUM",WPARAM) From ADOVAL
    GPHYAUTNUM = val(WPARAM)
  Endif

  # Lecture de paramètres d'import des plans supplémentaires
  Gosub LIRE_PLANS_PARAM

  # Lecture du paramètre Société REPENDDPE
  Local Char WPARAM
  Call PARAM([F:FAS]CPY,"REPENDDPE",WPARAM) From ADOVAL : # Chargement du paramètre de reprise de la dotation exercice
  If val(WPARAM) = 0
    REPENDDPE = G_NON
  Else
    REPENDDPE = val(WPARAM)
  Endif
Return

####################################################################
# Déclenchement de traitements spécifiques lors du passage
# sur certaines zones
#
$IMP_ZONE
  Case IMPZON
    When "AASREF"
        Gosub ALI_FXDASSETS
        Gosub ALI_FASY
    When "ENAFAS"
        If (GDISAFAS = G_OUI) and ([F:FAS]ISSDAT = [0/0/0])
          [M]ENAFAS = G_NON
        Else
          [M]ENAFAS = G_OUI
        Endif
        OK = 0
    When "AASQTY"
        If [F:FAS]AASQTY = 0 Then : [M]AASQTY = 1 : OK = 0 : Endif
    When "ACGETRNOT"
        If [F:FAS]ACGETRNOT = 0 Then : [M]ACGETRNOT = func GLOFUNC.VALSEP(GIMP(5), GSEPDEC) : OK = 0 : Endif
        IMPMOD = 1 : # Pour forcer l'execution de l'après-modif
    When "IVCVATRAT"
        If [F:FAS]IVCVATRAT <> 0 Then
          [M]IVCVATRAT = [F:FAS]IVCVATRAT * 100 : OK = 0
        Endif
    When "IVCVATAMT"
        # FQ55143 FQ61340
        #If [F:FAS]IVCVATAMT <> [M:FAS1]IVCVATAMT
        #  [M:FAS1]IVCVATAMT = [F:FAS]IVCVATAMT
        #  Call AM_IVCVATAMT([M:FAS1]IVCVATAMT) From SUBFAS
        If [F:FAS]IVCVATFLG <> G_OUI : OK = 0 : Endif
        #Endif
        # FQ49613
        If dim([M:FAS1]IVCVATAMTI)<0 or (!(dim([M:FAS1]IVCVATAMTI)<0) and varmode([M:FAS1]IVCVATAMTI))
          Gosub ALIMENTATIONS_COMPLEMENTAIRES
        Endif
    When "DEDVATRAT"
        If [F:FAS]DEDVATRAT <> 0 Then
          [M]DEDVATRAT = [F:FAS]DEDVATRAT * 100 : OK = 0
        Endif
    When "DEDVATAMT"
        If [F:FAS]DEDVATFLG = G_NON : OK = 0 : Endif
    When "IASRATCUR"
        # On estime que IASRATCUR à 0 n'est pas significatif
        If [F:FAS]IASRATCUR = 0 : OK = 0 : Endif
    When "IVCVATRATI"
        If [F:FAS]IVCVATRATI <> 0 Then
          [M]IVCVATRATI = [F:FAS]IVCVATRATI * 100 : OK = 0
        Endif
    When "IVCVATAMTI"
        # FQ55143 FQ61340
        #If [F:FAS]IVCVATAMTI <> [M:FAS1]IVCVATAMTI
        #  [M:FAS1]IVCVATAMTI = [F:FAS]IVCVATAMTI
        #  Call AM_IVCVATAMTI([M:FAS1]IVCVATAMTI) From SUBFAS
        If [F:FAS]IVCVATFLGI <> G_OUI : OK = 0 : Endif
        #Endif
        Gosub ALIMENTATIONS_COMPLEMENTAIRES
    When "DEDVATRATI"
        If [F:FAS]DEDVATRATI <> 0 Then
          [M]DEDVATRATI = [F:FAS]DEDVATRATI * 100 : OK = 0
        Endif
    When "DEDVATAMTI"
        If [F:FAS]DEDVATFLGI = G_NON : OK = 0 : Endif
   ##################
   # AMORTISSEMENTS #
   ##################
   # Les champs suivant sont alimentés par l'appel à SAI_NBLIG1 de W0FAS3 dans $ALI_FAS3
    When "DPM"
        # Mode d'amortissement
        If GIMP(N_I*10+1) <> "" Then
          [M:FAS3]DPM(indice) = GIMP(N_I*10+1)
        Endif
        OK = 0
        # FQ62916 + FQ59159 : le champ ENDDPE n'étant pas saisissable, on profite d'avoir la main sur
        # le champ DPM pour l'alimenter
        # Dotation exercice
        If GIMP(N_I*10+6) <> "" Then
          [M:FAS3]ENDDPE(indice)    = func GLOFUNC.VALSEP(GIMP(N_I*10+6), GSEPDEC)
        Endif
        # Flag de forçage de la dotation exercice
        [M:FAS3]ENDDPEFLG(indice) = REPENDDPE
    When "STRDPRDAT"
        # Date de début d'amortissement
        If GIMP(N_I*10) <> "" Then
          Call STRING_TO_DATE(GIMP(N_I*10), [M:FAS3]STRDPRDAT(indice))
        Endif
        OK = 0
    When "DPRDUR"
        # Durée d'amortissement
        If GIMP(N_I*10+2) <> "" Then
          [M:FAS3]DPRDUR(indice) = func GLOFUNC.VALSEP(GIMP(N_I*10+2), GSEPDEC)
        Endif
        OK = 0
    When "DPRBAS"
        # Base d'amortissement et base d'amortissement initiale
        If GIMP(N_I*10+4) <> "" Then
          [M:FAS3]DPRBAS(indice)    = func GLOFUNC.VALSEP(GIMP(N_I*10+4), GSEPDEC)
          [M:FAS3]BSEVAL(indice)    = func GLOFUNC.VALSEP(GIMP(N_I*10+4), GSEPDEC)
          [M:FAS3]DPRVAL(indice)    = func GLOFUNC.VALSEP(GIMP(N_I*10+4), GSEPDEC) : # FQ59686
        Endif
        OK = 0
    When "DPRRAT"
        # Taux d'amortissement
        If func GLOFUNC.VALSEP(GIMP(N_I*10+3), GSEPDEC) <> 0
          [M:FAS3]DPRRATFLG(indice) = G_OUI
          [M:FAS3]DPRRAT(indice)    = func GLOFUNC.VALSEP(GIMP(N_I*10+3), GSEPDEC)
        Else
          [M:FAS3]DPRRATFLG(indice) = G_NON
        Endif
        OK = 0
    When "DPRCUM"
        # Cumul d'amortissement
        If GIMP(N_I*10+5) <> "" Then
          [M:FAS3]DPRCUM(indice) = func GLOFUNC.VALSEP(GIMP(N_I*10+5), GSEPDEC)
        Endif
        OK = 0
    When "ALWCOD"
        # FQ59783
        # Règle particulière
        If [M:FAS3]ALWCOD(indice) = 0
          [M:FAS3]ALWCOD(indice) = 1
        Endif
    When Default
  Endcase

  Gosub IMP_ZONE_ASSOC From GLOFUNCIMP : # FQ79283
Return

#################################################################### FQ49613
$ALIMENTATIONS_COMPLEMENTAIRES
  Gosub ALI_FAS3  : # Alimentation des plans
  Gosub ALI_FAS8  : # Déclenchement de la simulation de saisie des fenêtres complémentaires
  If [F:FAS]ISSDAT <> [0/0/0]
    Gosub ALI_SORTIE : # Alimentation des zones relatives à la sortie
  Endif
Return

####################################################################
# Après l'import d'une ligne du fichier en entrée
#
$AP_IMPORT
  If [M:IMP2]TEST=2 : Return : Endif : # FQ46184

  If clalev([M:FASI]) : Raz [M:FASI] : Endif
  If clalev([M:FASV]) : Raz [M:FASV] : Endif
  # If clalev([M:FASY]) : Raz [M:FASY] : Endif
  If clalev([M:PHYY]) : Raz [M:PHYY] : Endif
  If clalev([M:FASN]) : Raz [M:FASN] : Endif

  G_DERRVEISS = 0

  # DEBUT FQ62830 : cette initialisation était faite trop tard dans IMP_INICRE de IMPFAS
  # Lecture des dates des différents contextes de la société (cache pour ne faire la lecture que si nécéssaire)
  If [F:FAS]CPY <> GCPY_CURR
    Local Integer CDRET
    Call GET_CPY_DAT([F:FAS]CPY,L_STRFIYCOU,L_ENDFIYCOU,L_STRPERCOU,L_ENDPERCOU,CDRET) From GLOBIENS
    GCPY_CURR = [F:FAS]CPY
  Endif
  # FIN FQ62830
Return

####################################################################
# Initialisations du début de l'import d'un bien
#
$ALI_FXDASSETS
  # création du réferentiel (la localisation est traitée plus tard)
  If CREACGGRP=G_OUI : Gosub CREACGGRP_AUTO : Endif            : # Famille

  For L_I=0 To GOPTCANA-1                                      : # Sections analytiques
    If CRECCE(L_I)=G_OUI & [F:FAS]CCE(L_I) <> "" : Gosub CRECCE_AUTO : Endif
  Next L_I

  Gosub CREUSRFL_AUTO

  [M:FAS0]FISLIG = 1 : # Affectation par défaut au comptable au cas où le fiscal n'existe pas
Return

####################################################################
#
# IMPORTS MANUELS
#
####################################################################

####################################################################
# Simulation de la saisie via les fenetres complementaires
# "Assurance", "Véhicule" et "Inventaire".
#
$ALI_FAS8

  [M:FAS8] = [F:FAS] : # Alimentation de l'onglet caché FAS8

  ###############################################
  # Alimentation de la fenetre "Assurance"
  Default Mask [M:FASI]

  Onerrgo ARRETE
  Gosub DEBUT_FASISR From =TRTSTD_ISR
  Onerrgo CONTINUE
  Gosub DEBUT_FASISR From =TRTSPE_ISR
  Onerrgo

  # On initialise le type d'assurance à "non assuré" si l'import ne donne pas cette information
  If [M]ISRTYP = 0 : [M]ISRTYP = 1 : Endif
  # Si un montant de valeur à neuf non nul est importé, la valeur a neuf forcée est a OUI
  If [M]RPLVAL > 0 : [M]RPLVALFLG = G_OUI : Else [M]RPLVALFLG = G_NON : Endif
  # Si un montant de valeur d'assurance non nul est importé, la valeur assurance forcée est a OUI
  If [M]ISRVAL > 0 : [M]ISRVALFLG = G_OUI : Else [M]ISRVALFLG = G_NON : Endif

  # Execution des actions liees aux champs de ce masque
  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227
  Call SAIMSK("FAS", "SET_IMPMOD", "SUBIMPOBJ") From W0FASISR
  Setmode                                                                            : # FQ82227
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASISR From =TRTSTD_ISR
  Onerrgo CONTINUE
  Gosub OK_FASISR From =TRTSPE_ISR
  Onerrgo

  ###############################################
  # Alimentation de la fenetre "Véhicule"

  # Pas d'info véhicule si le type VEHTYP n'est pas renseigné dans le fichier d'import
  If [M:FAS8]VEHTYP = "" Then
    Effzo [M:FAS8]2 : # Bloc "Véhicule" de l'écran FAS8
  Else
    Default Mask [M:FASV]

    Onerrgo ARRETE
    Gosub DEBUT_FASVEH From =TRTSTD_VEH
    Onerrgo CONTINUE
    Gosub DEBUT_FASVEH From =TRTSPE_VEH
    Onerrgo

    # Execution des actions liees aux champs de ce masque
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227
    Call SAIMSK("FAS", "SET_IMPMOD", "SUBIMPOBJ") From W0FASVEH
    Setmode                                                                            : # FQ82227
    If mkstat : GERR = 1 : End : Endif

    Default Mask [M:FAS8]

    Onerrgo ARRETE
    Gosub OK_FASVEH From =TRTSTD_VEH
    Onerrgo CONTINUE
    Gosub OK_FASVEH From =TRTSPE_VEH
    Onerrgo
  Endif

  Default Mask [M:FAS8]
Return

###############################################
# Alimentation de la fenetre "Valeur marché"
#
# Cette étiquette est appellée lors du contrôle
# "APRES_NBLIG1" de SUBFAS en import
#
$ALI_DEPREC
  Local Integer SAVE_NOLIGN

  SAVE_NOLIGN = nolign

  Default Mask [M:FASN]

  Onerrgo ARRETE
  Gosub DEBUT_FASNSP From =TRTSTD_NSP
  Onerrgo CONTINUE
  Gosub DEBUT_FASNSP From =TRTSPE_NSP
  Onerrgo

  # Execution des actions liees aux champs de ce masque
  Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227
  Call SAIMSK("FASN", "SET_IMPMOD", "SUBIMPOBJ") From W0FASNSP
  Setmode                                                                            : # FQ82227
  If mkstat : GERR = 1 : End : Endif

  Onerrgo ARRETE
  Gosub OK_FASNSP From =TRTSTD_NSP
  Onerrgo CONTINUE
  Gosub OK_FASNSP From =TRTSPE_NSP
  Onerrgo

  Default Mask [M:FAS3]

  nolign = SAVE_NOLIGN
Return

####################################################################
# Arrêt du traitement en cas de problème
#
$ARRETE
  mkstat = 2 : GERR = 1 : End
Return

####################################################################
# On continue le traitement en cas de problème
#
$CONTINUE
  Resume
Return

####################################################################
# Alimentation des informations de sortie
#
$ALI_SORTIE
  # DEBUT FQ56478
  Local Shortint N_I, ISSANT

  ISSANT = G_NON

  # On regarde si le bien est sorti dans un exercice antérieur pour un des contextes
  For N_I = 1 To [M:FAS3]NBLIG1
    If [F:FAS]ISSDAT < L_STRFIYCOU([M:FAS3]CNX(N_I-1))
      ISSANT = G_OUI : # Il y a au moins un contexte pour lequel la sortie est antérieure à l'exercice courant
      Break
    Endif
  Next

  If ISSANT = G_NON
    # Si la sortie est dans l'exercice courant, on effectuera une sortie silencieuse à l'issue
    # de la création du bien. On stocke dans [F:FASS] les paramètres de sortie
    [F:FASS] = [F:FAS]
    Return
  Else
    # Alimentation des informations de sortie avec ce qui est dans le fichier d'import
    Raz [F:FASS]
  Endif
  # FIN FQ56478

  [M:FAS4]ISSDAT = [F:FAS]ISSDAT

  For N_I=1 To [M:FAS4]NBLIG4
    If [F:FAS]ISSAMT([M:FAS4]DPRPLN(N_I-1)-1) <> 0
      [M:FAS4]ISSAMT(N_I-1) = [F:FAS]ISSAMT([M:FAS4]DPRPLN(N_I-1)-1)
    Else
      [M:FAS4]ISSAMT(N_I-1) = [F:FAS]ISSAMT(0)
    Endif
    # Alimentation des +/- values pour les sorties antérieures à l'exercice courant
    [M:FAS4]GAL(N_I-1)       = [F:FAS]GAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]SHOGAL(N_I-1)    = [F:FAS]SHOGAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]LNGGAL(N_I-1)    = [F:FAS]LNGGAL([M:FAS4]DPRPLN(N_I-1)-1)
    [M:FAS4]IMLRVEISS(N_I-1) = [F:FAS]IMLRVEISS([M:FAS4]DPRPLN(N_I-1)-1)
  Next

  # Type de sortie (vente ou rebut)
  If GIMP(3) = ""
    [M:FAS4]ISSTYP = GVML_TSVENTE
  Elsif val(GIMP(3)) > 0
    # Type numérique : on considère que c'est le menu local
    [M:FAS4]ISSTYP = [F:FAS]ISSTYP
  Else
    Case GIMP(3)
      When "C"     : [M:FAS4]ISSTYP = GVML_TSVENTE
      When "R"     : [M:FAS4]ISSTYP = GVML_TSREBUT
      When Default : # On a une construction du type <Motif de cession>_<Motif de mise au rebut>
        If instr(1,GIMP(3),"_") = 1
          # chaine de la forme _<Motif de mise au rebut> -> rebut
          [M:FAS4]ISSTYP = GVML_TSREBUT
        Else
          # chaine de la forme <Motif de cession>_ -> cession
          [M:FAS4]ISSTYP = GVML_TSVENTE
        Endif
    Endcase
  Endif

  If [F:FAS]PYBVATTYP = 0
    If [F:FAS]ISSVATAMT = 0
      [M:FAS4]PYBVATTYP = GVML_RVTVA00
    Else
      [M:FAS4]PYBVATTYP = GVML_RVTVAVT
    Endif
  Else
    [M:FAS4]PYBVATTYP = [F:FAS]PYBVATTYP
  Endif

  If [F:FAS]ISSDATRUL = 0
    [M:FAS4]ISSDATRUL = 1
  Else
    [M:FAS4]ISSDATRUL = [F:FAS]ISSDATRUL
  Endif

  [M:FAS4]ISSVATRAT = [F:FAS]ISSVATRAT
  [M:FAS4]ISSVATAMT = [F:FAS]ISSVATAMT
  [M:FAS4]BUY       = [F:FAS]BUY
  [M:FAS4]IVCSALISS = [F:FAS]IVCSALISS
  G_DERRVEISS       = [F:FAS]DERRVEISS

  # Alimentation du flag FLGUPDISS sur les DEPREC pour les biens sortis au-delà du début de l'exercice courant
  Local Integer N_I
  For N_I = 1 To [M:FAS3]NBLIG1
    If [M:FAS4]ISSDAT >= [M:FAS3]FIYSTRDAT(N_I-1)
      [M:FAS3]FLGUPDISS(N_I-1) = G_OUI
      [M:FAS4]FLGUPDISS        = G_OUI
    Endif
  Next N_I
Return

####################################################################
# Alimentation des informations de TVA
#
$ALI_TVA
  # FQ61340
  If [F:FAS]IVCVATFLG = G_OUI
    [M:FAS1]IVCVATFLG = [F:FAS]IVCVATFLG
    [M:FAS1]IVCVATRAT = [F:FAS]IVCVATRAT
    [M:FAS1]IVCVATAMT = [F:FAS]IVCVATAMT
    Call AM_IVCVATAMT([M:FAS1]IVCVATAMT) From SUBFAS
  Endif

  If G_ACTIAS = G_OUI and [F:FAS]IVCVATFLGI = G_OUI
    [M:FAS1]IVCVATFLGI = [F:FAS]IVCVATFLGI
    [M:FAS1]IVCVATRATI = [F:FAS]IVCVATRATI
    [M:FAS1]IVCVATAMTI = [F:FAS]IVCVATAMTI
    Call AM_IVCVATAMTI([M:FAS1]IVCVATAMTI) From SUBFAS
  Endif
  # FIN FQ61340

  If [F:FAS]DEDVATFLG = G_OUI
    [M:FAS1]DEDVATFLG = [F:FAS]DEDVATFLG
    [M:FAS1]DEDVATRAT = [F:FAS]DEDVATRAT
    [M:FAS1]DEDVATAMT = [F:FAS]DEDVATAMT
    Call AM_DEDVATAMT([M:FAS1]DEDVATAMT) From SUBFAS
  Endif

  If G_ACTIAS = G_OUI and [F:FAS]DEDVATFLGI = G_OUI
    [M:FAS1]DEDVATFLGI = [F:FAS]DEDVATFLGI
    [M:FAS1]DEDVATRATI = [F:FAS]DEDVATRATI
    [M:FAS1]DEDVATAMTI = [F:FAS]DEDVATAMTI
    Call AM_DEDVATAMTI([M:FAS1]DEDVATAMTI) From SUBFAS
  Endif
Return

####################################################################
# Création automatique de la famille comptable
#
$CREACGGRP_AUTO
  Call TRT_TABDIV(611,[F:FAS]ACGGRP,"")
  If GOK=0
    # Donnée de base créée automatiquement : Famille comptable <Code famille> Erreur xx
    Call ECR_TRACE(mess(46,7772,1)-mess(1,3235,1)-[F:FAS]ACGGRP-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Return
  Endif
Return

####################################################################
# Alimentation des différents plans
#
$ALI_FAS3
  Local Integer N_P : # numéro de ligne du plan dans FAS3

  Gosub ALI_TVA

  # L'initialisation se fait dans INIT_PLAN_AMT de SUBFAS

  # Boucle sur les divers plans :
  #             1- de GIMP(10) à GIMP(19) : plan comptable
  #             2- de GIMP(20) à GIMP(29) : plan fiscal
  #             3- de GIMP(30) à GIMP(39) : plan 3 optionnel (paramètre FASPLN3)
  #             4- de GIMP(40) à GIMP(49) : plan 4 optionnel (paramètre FASPLN4)
  #             5- de GIMP(50) à GIMP(59) : plan 5 optionnel (paramètre FASPLN5)

  For N_I = 1 To 5
    If ( N_I <= 2) or (( N_I > 2) and ( FASPLN(N_I) <> G301AUC )) Then
      # On contrôle l'existence du plan dans FAS3 et on récupère son rang dans N_P
      Case N_I
        When 1
            If [M:FAS3]DPRPLN(0) <> G301CPT
              GERR = 1 : mkstat = 2 : Call ECR_TRACE([M:FAS0]AASREF-":"-mess(164,7770,1)-[M:FAS0]CPY,1) From GESECRAN : End : # Les plans à importer ne correspondent pas à ceux de la société
            Endif
            N_P = 1
        When 2
            N_P = find(G301FIS,[M:FAS3]DPRPLN) : # FQ82226
            # FQ91573 : import du plan fiscal optionnel
            #If N_P = 0
            #  GERR = 1 : mkstat = 2 : Call ECR_TRACE([M:FAS0]AASREF-":"-mess(164,7770,1)-[M:FAS0]CPY,1) From GESECRAN : End : # Les plans à importer ne correspondent pas à ceux de la société
            #Endif
        When 3, 4, 5
            N_P = find(FASPLN(N_I),[M:FAS3]DPRPLN)
            If N_P = 0
              GERR = 1 : mkstat = 2 : Call ECR_TRACE([M:FAS0]AASREF-":"-mess(164,7770,1)-[M:FAS0]CPY,1) From GESECRAN : End : # Les plans à importer ne correspondent pas à ceux de la société
            Endif
      Endcase

      If N_P <> 0 : # FQ91573
        If ( [M:FAS3]DPRPLN(N_P-1) = G301FIS ) Then
          [M:FAS0]FISLIG = N_P
        Endif

        # FQ48941 : Exécution des contrôles et des actions pour la ligne d'amortissement
        nolign = N_P
        indice = nolign-1
        Default Mask [FAS3]
        Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ79242
        Call SAI_NBLIG1("DEP","IMP_ZONE","SUBIMPOBJ") From W0FAS3 : # FQ82226
        # DEBUT FQ79242
        Setmode
        If mkstat
         #GREP = "" # Issue X3-63497 - 2017-11-23 by BEFOU : For error file
         Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ
         Break
        Endif
        Raz GERREUR
        # FIN FQ79242

        # Alimentation de l'amortissement exceptionnel et de la valeur nette
        [M:FAS3]EXCDPR(nolign-1) = func GLOFUNC.VALSEP(GIMP(N_I*10+8), GSEPDEC)
        [M:FAS3]NBV(nolign-1)    = func GLOFUNC.VALSEP(GIMP(N_I*10+9), GSEPDEC)

        # Forçage des cumuls repris pour ne pas les écraser par le calcul
        [M:FAS3]DPRCUMFLG(nolign-1)  = G_OUI
      Endif
    Endif
  Next N_I
Return

####################################################################
# Alimentation des différents éléments physiques
#
$ALI_FASY
Local Integer STAT

  If GPHY=G_OUI Then
    [M:FAS8]NBPHY  = 0
    # If [F:FAS]BAC<>'' Then
    If GIMP(90)<>'' Then
      # GIMP(8) correspond à la localisation, voilà pourquoi on ne regarde pas [F:FAS]LOC, qui n'est pas encore renseigné
      # à ce niveau

      #  Numérotation des éléments physiques à partir du bien
      # test sur le code à barre qui doit être unique
      Local Integer UNIQUE
      Call VERIF_UNICITE_BAC(GIMP(90),[F:FAS]CPY,UNIQUE) From TRTPHYTOOL
      If UNIQUE = G_NON Then
        GOK = 0
        Call ECR_TRACE([F:PHY]PHYREF-'-'-'BAC'-GIMP(90)-'-'-mess(249,7773,1),1) From GESECRAN
        Return
      Endif

      Default Mask [M:PHYY]

      # Appel du compteur de document
      # Numérotation des éléments physiques à partir du bien
      Call GET_NUMERO_ELTPHY("PHY",GVMLNUMPHY-1,1,[F:FAS]FCY,date$,[F:FAS]CPY,[F:FAS]AASREF,[F:PHY]PHYREF,STAT) From GLOBIENS

      If ( STAT ) Then : GOK = 0 : Return : Endif

#FQ116860
#      Onerrgo ARRETE
#      Gosub DEBUT_PHYIVY From =TRTSTD_IVY
#      Onerrgo CONTINUE
#      Gosub DEBUT_PHYIVY From =TRTSPE_IVY
#      Onerrgo
#
#      # Execution des actions liees aux champs de ce masque
#      Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2 : # FQ82227
#      Call SAIMSK("PHY", "SET_IMPMOD", "SUBIMPOBJ") From W0PHYIVY
#      Setmode                                                                            : # FQ82227
#      If mkstat : GERR = 1 : End : Endif
#
#      Onerrgo ARRETE
#      Gosub OK_PHYIVY From =TRTSTD_IVY
#      Onerrgo CONTINUE
#      Gosub OK_PHYIVY From =TRTSPE_IVY
#      Onerrgo
#End FQ116860
      Default Mask [M:FAS8]

      nolign = [M:FAS8]NBPHY+1

      # Alimentation de la ligne du tableau des élts phy de FAS8 à partir du fichier d'import
      [M:FAS8]IMP(nolign-1)       = G_OUI
      [M:FAS8]PHYREF(nolign-1)    = [F:PHY]PHYREF
      [M:FAS8]PHYDES1(nolign-1)   = [F:FAS]AASDES1
      # [M:FAS8]BAC(nolign-1)       = [F:FAS]BAC
      # [M:FAS8]SRLNBR(nolign-1)    = [F:FAS]SRLNBR
      # [M:FAS8]IVYDAT(nolign-1)    = [F:FAS]IVYDAT
      # [M:FAS8]IVYTIM(nolign-1)    = [F:FAS]IVYTIM
      # [M:FAS8]CURCND(nolign-1)    = [F:FAS]CURCND
      # [M:FAS8]IVYRES(nolign-1)    = [F:FAS]IVYRES
      [M:FAS8]BAC(nolign-1)       = GIMP(90)
      [M:FAS8]SRLNBR(nolign-1)    = GIMP(91)
#      Call STRING_TO_DATE(GIMP(92), [M:FAS8]IVYDAT(nolign-1))#FQ116860
#      [M:FAS8]IVYTIM(nolign-1)    = GIMP(93)#FQ116860
      [M:FAS8]CURCND(nolign-1)    = GIMP(94)
#      [M:FAS8]IVYRES(nolign-1)    = val(GIMP(95))
      [M:FAS8]NBPHY +=1
    Else
      # On initialise quand même IMP, de façon à ce que dans SUFAS, on ne passe pas dans la boucle de MAJ_ELT_PHYSIQUE
      [M:FAS8]IMP(0) = G_OUI
    Endif
  Endif
Return

####################################################################
#
# CREATION AUTOMATIQUE DU REFERENTIEL
#
####################################################################

####################################################################
# Création automatique section analytique
#
$CRECCE_AUTO
  GOK=1

  Look [F:CCE]CCE0=[M:FPC]DIE(L_I);[F:FAS]CCE(L_I)
  If fstat
    Raz [F:CCE]
    [F:CCE]DIE=[M:FPC]DIE(L_I)
    [F:CCE]CCE=[F:FAS]CCE(L_I)
    If GIMP(70+L_I) = ""
      [F:CCE]DES=[F:FAS]CCE(L_I)
    Else
      [F:CCE]DES=GIMP(70+L_I)
    Endif
    [F:CCE]DESSHO=[F:CCE]CCE
    [F:CCE]EXPNUM=[C]EXPORT
    [F:CCE]BUDTRK=G_OUI
    [F:CCE]CREDAT=date$
    [F:CCE]CREUSR=GUSER
    [F:CCE]IPT=G_OUI : # FQ?????
    Write [CCE]
    If fstat
      GOK=0 : Return
    Endif
    # Donnée de base créée automatiquement : Axe n CCE DES
    Call ECR_TRACE(mess(46,7772,1)-mess(L_I+1,601,1)-[F:CCE]CCE-[F:CCE]DES,0) From GESECRAN
  Endif
Return

####################################################################
# Création des codes zones libres
#
$CREUSRFL_AUTO
  Local Integer N_I

  If !clalev([F:FRF]) : Local File FREFLD [FRF] : Endif

  # Lecture du paramétrage des zones libres pour avoir le numéro de la table diverse
  Read [FRF]FRF0=GVML_OMBIEN;[F:FAS]CPY

  If fstat
    Read [FRF]FRF0=GVML_OMBIEN;""
  Endif

  If fstat : Return : Endif

  For N_I = 1 To 10
    If CREUSRFL(N_I-1) = G_OUI and evalue("[F:FAS]USRFLDA"+num$(N_I)) <> ""
      Call TRT_TABDIV([F:FRF]ALPREF(N_I-1), evalue("[F:FAS]USRFLDA"+num$(N_I)), GIMP(59 + N_I))
    Endif
  Next
Return

##################################################
# Création automatique codes en tables diverses
#
Subprog TRT_TABDIV(ADI_TAB, ADI_COD, ADI_DES)
Value Integer ADI_TAB
Value Char ADI_COD
Value Char ADI_DES

Local Char TEXTE(80)

  GOK=1

  If ADI_COD = "" Then : End : Endif : # Pas de création si le code n'est pas renseigné

  Look [F:ADI]CODE=ADI_TAB;ADI_COD
  If fstat
    Raz [F:ADI]
    [F:ADI]NUMTAB=ADI_TAB
    [F:ADI]CODE=ADI_COD
    [F:ADI]CREDAT=date$
    [F:ADI]CREUSR=GUSER
    Write [ADI]
    If fstat
      GOK=0 : End
    Endif
    If ADI_DES = ""
      ADI_DES=ADI_COD
    Endif
    Call MAJTEXTRA(ADI_DES,"ATABDIV","LNGDES",num$(ADI_TAB),ADI_COD) From ATEXTRA
    Call MAJTEXTRA(ADI_COD,"ATABDIV","SHODES",num$(ADI_TAB),ADI_COD) From ATEXTRA
    Call LECTEXTRA(TEXTE,"ATABTAB","LNGDES",num$(ADI_TAB),"") From ATEXTRA
    # Donnée de base créée automatiquement : Table diverse n CODE LNGDES
    Call ECR_TRACE(mess(46,7772,1)-TEXTE-ADI_COD-ADI_DES,0) From GESECRAN
  Endif
End

####################################################################
#
# DIVERS
#
####################################################################

####################################################################
# Lecture des paramètres FASPLN(3), FASPLN(4) et FASPLN(5)
# dans le chapitre AAS. Ces paramètres indiquent pour la société
# courante à quoi correspondent les éventuels plans supplémentaires
# dans l'export de X3
#
$LIRE_PLANS_PARAM

  # Lecture des paramètres FASPLN3, FASPLN4, FASPLN5 pour les trois plans supplémentaires
  Local Char WPARAM
  Call PARAM([F:FAS]CPY,"FASPLN3",WPARAM) From ADOVAL
  FASPLN(3) = val(WPARAM)
  Call PARAM([F:FAS]CPY,"FASPLN4",WPARAM) From ADOVAL
  FASPLN(4) = val(WPARAM)
  Call PARAM([F:FAS]CPY,"FASPLN5",WPARAM) From ADOVAL
  FASPLN(5) = val(WPARAM)

  # On teste si les plans supplémentaires ne sont ni comptable ni fiscal et différents entre eux
  Local Integer N_I
  For N_I = 3 To 5
    If FASPLN(N_I) = G301CPT or FASPLN(N_I) = G301FIS
      GERR = 1 : mkstat = 2 : Call ECR_TRACE("FASPLN"+num$(N_I)-":"-mess(162,7770,1)-"("+[F:FAS]CPY+")",1) From GESECRAN : End : # redondance sur les plans comptable et fiscal
    Endif
  Next N_I

  If ((FASPLN(3) = FASPLN(4) and FASPLN(3)<>0) or (FASPLN(3) = FASPLN(5) and FASPLN(3)<>0)) and (FASPLN(3) <> G301AUC) Then
      GERR = 1 : mkstat = 2 : Call ECR_TRACE(mess(163,7770,1)-"("+[F:FAS]CPY+")",1) From GESECRAN : End : # Des plans supplémentaires sont égaux entre eux
  Else
    If (FASPLN(4) = FASPLN(5) and FASPLN(4)<>0) and (FASPLN(4) <> G301AUC) Then
      GERR = 1 : mkstat = 2 : Call ECR_TRACE(mess(163,7770,1)-"("+[F:FAS]CPY+")",1) From GESECRAN : End : # Des plans supplémentaires sont égaux entre eux
    Endif
  Endif
Return

##################################################
# Recherche des traitements standard et spécifique
# d'une action
#
Subprog CHERCHE_TRT_ACTION(P_ACTION, P_TRTSTD, P_TRTSPE)
Value Char P_ACTION ()
Variable Char P_TRTSTD ()
Variable Char P_TRTSPE ()

  Local File ACTION [ACT]

  Read [F:ACT]ACTION = P_ACTION

  If fstat = 0
    P_TRTSTD = [F:ACT]CODTRT
    P_TRTSPE = [F:ACT]SPETRT
  Endif

  Close Local File [F:ACT]
End

##################################################
# Transformation d'un chaine de caractères
# contenant une date de la forme JJMMAAAA en
# type date
#
Subprog STRING_TO_DATE(P_CHAINE, P_DATE)
Value Char    P_CHAINE : # chaine de caractères en entrée à convertir
Variable Date P_DATE   : # date en sortie

Local Date    VALDAT
Local Integer DD , MM , YY , JOUR , MOIS , ANNEE
Local Integer I , V1 , V2 , V3

  DD = instr(1,FORMAT_DATE,"DD")
  MM = instr(1,FORMAT_DATE,"MM")
  YY = instr(1,FORMAT_DATE,"YY")
  If DD=0 or MM=0 or YY=0
   GERR = 1 : mkstat = 2 : GMESSAGE = GFMDAT4-":"-mess(149,100,1) : End : # Format incorrect
  Endif
  I = 1
  While I<=len(P_CHAINE)
   If !instr(1,"0123456789",mid$(P_CHAINE,I,1))
    P_CHAINE = left$(P_CHAINE,I-1)+right$(P_CHAINE,I+1)
   Else
    I += 1
   Endif
  Wend
  Case len(P_CHAINE)
   When 0 : # Date nulle
    JOUR  = 0
    MOIS  = 0
    ANNEE = 0
   When 4 : # Jour + mois
    If DD<MM
     JOUR = val(left$(P_CHAINE,2))
     MOIS = val(right$(P_CHAINE,3))
    Else
     MOIS = val(left$(P_CHAINE,2))
     JOUR = val(right$(P_CHAINE,3))
    Endif
    If JOUR=0 & MOIS=0
     ANNEE = 0
    Else
     ANNEE = year(date$)
    Endif
   When 6 : # Jour + mois + année sur 2
    V1 = val(left$(P_CHAINE,2))
    V2 = val(mid$(P_CHAINE,3,2))
    V3 = val(right$(P_CHAINE,5))
    If DD<MM
     If    YY<DD : ANNEE = V1 : JOUR  = V2 : MOIS  = V3
     Elsif YY>MM : JOUR  = V1 : MOIS  = V2 : ANNEE = V3
     Else        : JOUR  = V1 : ANNEE = V2 : MOIS  = V3
     Endif
    Else
     If    YY<MM : ANNEE = V1 : MOIS  = V2 : JOUR  = V3
     Elsif YY>DD : MOIS  = V1 : JOUR  = V2 : ANNEE = V3
     Else        : MOIS  = V1 : ANNEE = V2 : JOUR  = V3
     Endif
    Endif
    If ANNEE>mod(adxdcs,100)
     ANNEE += 100*int(adxdcs/100)
    Else
     ANNEE += 100*int(adxdcs/100)+100
    Endif
   When 8 : # Date complète
    If DD<MM
     If    YY<DD : V1 = 1 : V3 = 5 : V2 = 7
     Elsif YY>MM : V3 = 1 : V2 = 3 : V1 = 5
     Else        : V3 = 1 : V1 = 3 : V2 = 7
     Endif
    Else
     If    YY<MM : V1 = 1 : V2 = 5 : V3 = 7
     Elsif YY>DD : V2 = 1 : V3 = 3 : V1 = 5
     Else        : V2 = 1 : V1 = 3 : V3 = 7
     Endif
    Endif
    ANNEE = val(mid$(P_CHAINE,V1,4))
    MOIS  = val(mid$(P_CHAINE,V2,2))
    JOUR  = val(mid$(P_CHAINE,V3,2))
   When Default
    GERR = 1 : mkstat = 2 : GMESSAGE = mess(1,104,1) : End : # Date incorrecte
  Endcase
  If ANNEE=0 & JOUR=0 & MOIS=0
   P_DATE = [0/0/0]
  Elsif ANNEE<1800 or MOIS<1 or MOIS>12 or JOUR<1 or JOUR>31
   ERR = 0
   Onerrgo RIEN
   P_DATE = gdat$(P_CHAINE)
   Onerrgo
   If ERR
    GERR = 1 : mkstat = 2 : GMESSAGE = mess(1,104,1) : End : # Date incorrecte
   Endif
  Else
   P_DATE = gdat$(JOUR,MOIS,ANNEE)
  Endif
End

$RIEN
ERR = 1
Resume

