#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPREPUR07   Pre-migration Retours                       Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPREPUR07") From LECFIC
  Endif

  Call MAJ_UUMGPREPUR07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPREPUR07(DOSSIER)
Value Char DOSSIER

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Call ECR_TIME("UUMGPREPUR07 Purchase Returns Process : Update PRETURN-D") From DOSSUB
Call ECR_TRACE("UUMGPREPUR07 : Process Start on : "+DOSSIER,0) From GESECRAN
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPREPUR07 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#fin MAE 386

Local Integer ERR

If val(VERSION)<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V6
    #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"PRETURN",ERR) From TRTMIG
  If ERR : Goto FIN : Endif


Endif
# Passage en V7
If val(VERSION)<GMIGX3VER70
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table POH
  # ----------------------------------------
  Gosub ADDCOLV7
  If ERR : Goto FIN : Endif

  Gosub TRT_X3_V7

  #--------------- Suppression index ----------#
  #Call MIGINDDEL (DOSSIER,"PORDER",ERR) From TRTMIG
  #If ERR : Goto FIN : Endif
Endif
#Fin MAE 386
$FIN
Call ECR_TIME("UUMGPREPUR07 : Purchase Orders Process END.")  From DOSSUB
End

############################################################
# Issue 386 - 2013-04-29 by MAE : prise en compte des versions
$ADDCOLV7
Return
############################################################
$TRT_X3_V7
Return
############################################################
$ADDCOLV6
  #1- ajouter la colonne dans la table POH
  Call MIGADDCOL (DOSSIER,"PRETURN","FFWADD","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRETURN","BPAINV","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRETURN","BPRPAY","BPR",0,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRETURN","BPAPAY","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  Call MIGADDCOL (DOSSIER,"PRETURN","EECNUM","A",20,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  #--------------- Field ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"PRETURND","","POHTYP","M",20,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  #2- ajouter un index unique
  #--------------- INDEX ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"PRETURN","BPSNUM+PNHNUM","","",0,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

Return

############################################################
$TRT_X3_V6
Local Integer COMPTEUR


#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:PNH]) : Close File [PNH] : Endif
Local File =DOSSIER+".PRETURN"   [PNH]
Local File =DOSSIER+".PRETURND"  [PND]
Local File =DOSSIER+".PORDER"    [POH]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPADDRESS"  [BPA]
Local File =DOSSIER+".ACTIV"      [ACV]

If dim(GACTDEB)<1  Global Libelle  GACTDEB : Endif
#----- Code activité "DEB" Déclaration échange de biens CEE -----#
Read [ACV] CODACT="DEB"
If !fstat
  GACTDEB=[F:ACV]FLACT
Else
  GACTDEB=2
Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Link [PNH] With [BPS]BPS0=[F:PNH]BPSNUM
&    As [LNK]
&    Order By Key CLE = [F:PNH]BPSNUM;[F:PNH]PNHNUM


$LOOP_PUR05
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:PNH]BPSNUM=ACLE1 & [F:PNH]PNHNUM>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PNH]BPSNUM>ACLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [PNH]
GOK = 1

For [LNK]CLE(2) Where evalue(CRITERE)

  # --- alimentation des champs et écriture enreg
  Gosub MAJ30_PNH
  If GOK<1 : Break : Endif

  For [PND] Where PNHNUM=[F:PNH]PNHNUM
    Gosub MAJ30_PND
    If GOK<1 : Break : Endif
    Rewrite [F:PND]
    If fstat
      Call ECR_TRACE("File PRETURND(PNHNUM/PNDLIN)"-[F:PND]PNHNUM-num$([F:PND]PNDLIN)+", Error ="-num$(fstat),1) From GESECRAN
      GOK=0 : Break
    Endif
  Next
  If GOK<1 : Break : Endif

  Rewrite [F:PNH]
  If fstat
    Call ECR_TRACE("File PRETURN(PNHNUM)"-[F:PNH]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:PNH]BPSNUM
    ACLE2 = [F:PNH]PNHNUM
    STOP=1
    Break
  Endif
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_PUR05
  Endif
Endif

$FIN_1
Gosub UNSET_FIRST From TRTFIRST
Close Local File [PNH],[PND],[ACV],[BPS],[BPR],[BPA]
Call ECR_TIME("UUMGPREPUR07 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
Return

###################################################################################
$MAJ30_PNH
    #----- Alimentation tiers payé et code adresse tiers payé -----#
    If [F:PNH]BPRPAY=""
      Gosub LECT_BPSPNH
      [F:PNH]BPRPAY=[F:BPS]BPRPAY
      If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
        Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PNH]BPAPAY=[F:BPR]BPAADD
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PNH]EECNUM=""
      Gosub LECT_BPRI
      [F:PNH]EECNUM=[F:BPR]EECNUM
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PNH]BPAINV=""
      Gosub LECT_BPSI
      If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
        Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PNH]BPAINV=[BPR]BPAADD
    Endif
    #----- Alimentation code adresse transitaire -----#
    If [F:PNH]FFWNUM<>"" & [F:PNH]FFWADD=""
      Gosub LECT_BPRFFW
      [F:PNH]FFWADD=[F:BPR]BPAADD
    Endif
Return

############################
$LECT_BPRFFW
  If [F:BPR]BPRNUM<>[F:PNH]FFWNUM
    WBPR=[F:PNH]FFWNUM
    Gosub LECT_BPR
  Endif
Return

$LECT_BPRI
  If [F:BPR]BPRNUM<>[F:PNH]BPSINV
    WBPR=[F:PNH]BPSINV
    Gosub LECT_BPR
  Endif
Return

$LECT_BPR
    Read [BPR] BPR0=WBPR : If fstat  Raz [F:BPR] : Endif
Return
############################
$LECT_BPSI
  If [F:BPS]BPSNUM<>[F:PNH]BPSINV
    WBPS=[F:PNH]BPSINV
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSPNH
  If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
    WBPS=[F:PNH]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSPND
  If [F:BPS]BPSNUM<>[F:PND]BPSNUM
    WBPS=[F:PND]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPS
    Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return

###################################################################################
$MAJ30_PND
      #----- Alimentation du type commande -----#
      If [F:PND]POHTYP=0 & [F:PND]POHNUM<>""
        Gosub LECT_POHPND
        [F:PND]POHTYP=[F:POH]POHTYP
      Endif
Return

##################################
$LECT_POHPND
  If [F:POH]POHNUM<>[F:PND]POHNUM
    WPOH=[F:PND]POHNUM
    Gosub LECT_POH
  Endif
Return

$LECT_POH
  Read [POH] POH0=WPOH : If fstat  Raz [F:POH] : Endif
Return

