#<AdxTL>@(#)6.0.0.0 $Revision$

# Issue 67488 - 2018-04-26 by MDJ : Report LETCHQEUR : check number jumps

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call IMPRIME(NBPAR,PARAMETRE) From TRSRPT : # Pour vérif de la banque
If GOK<1 : End : Endif

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

Raz FILTRE, IFILT
Call ADDCRIT(FILTRE,IFILT,"STD","STA<>9 & STAFLG(8)<>2 & AMTCUR>0 & EDTNUM=0 & CHQNUM='' & SNS=1"," & ") From GOBJSUB

# Chèque émis non remis en banque, d'un montant positif, non édité sans no de chèque
[L]FILT    = "1=1"
# Erreur d'affectation du numéro de chèque du aux lignes non imputés --> non édités
[L]FILT2 = "AMTLIN2<>0"

[L]ETATDEP = ETAT

For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE": [L]NUMREQ1 = val([L]VALEUR)
   When "etat"     : [L]ETAT = [L]VALEUR
   When "societe"  : If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"CPY","CPY='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Endif
   When "sitedeb"  : Call ADDCRIT(FILTRE,IFILT,"FCY","FCY>='"+[L]VALEUR+"'"," & ") From GOBJSUB
   When "sitefin"  : Call ADDCRIT(FILTRE,IFILT,"FCY","FCY<='"+[L]VALEUR+"'"," & ") From GOBJSUB
   When "bank"     : If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"BAN","BAN='"+[L]VALEUR+"'"," & ") From GOBJSUB
                      [L]BANK = [L]VALEUR
                     Endif
   When "datedeb"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    Call ADDCRIT(FILTRE,IFILT,"ACCDAT","ACCDAT>=["+format$(GFMD,[L]DTE)+"]"," & ") From GOBJSUB
   When "datefin"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    Call ADDCRIT(FILTRE,IFILT,"ACCDAT","ACCDAT<=["+format$(GFMD,[L]DTE)+"]"," & ") From GOBJSUB
   When "codedt"   : [L]EDIT = [L]VALEUR
   When "lotdeb"   : [L]VALEUR = vireblc([L]VALEUR,2)
                     If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"PAYLOT","PAYLOT>='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Endif
   When "lotfin"   : If [L]VALEUR<"zzzzzzzzzz"
                      Call ADDCRIT(FILTRE,IFILT,"PAYLOT","PAYLOT<='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Endif
   When "regdeb"   : Call ADDCRIT(FILTRE,IFILT,"NUM","NUM>='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     [L]FILT    -= "& CLEA1>='"+[L]VALEUR+"'"
   When "regfin"   : Call ADDCRIT(FILTRE,IFILT,"NUM","NUM<='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     [L]FILT    -= "& CLEA1<='"+[L]VALEUR+"'"
   When "numedt"   : If [L]VALEUR<>"0"
                      [L]NUMREQ2 = val([L]VALEUR)
                      [L]PARAMETRE(I) = "numedt="+[L]VALEUR
                     Else
                      [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ1)
                     Endif
   When "chedeb"   : [L]CHEDEB = [L]VALEUR
   When "chefin"   : [L]CHEFIN = [L]VALEUR
   When "chqnbr"   : [L]CHQNBR = val([L]VALEUR)
   When "bordeb"   : [L]VALEUR = vireblc([L]VALEUR,2)
                     If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"FRMNUM","FRMNUM>='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Endif
   When "borfin"   : If [L]VALEUR<"zzzzzzzzzz"
                      Call ADDCRIT(FILTRE,IFILT,"FRMNUM","FRMNUM<='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Endif
   When "lettre"   : [L]LETTRE = val([L]VALEUR)
   When "tri"      : [L]TRI = num$([L]VALEUR)
   When "X3FCT"    : [L]FONCTION = [L]VALEUR
   When "X3ETA"    : [L]CODRPT = [L]VALEUR
  Endcase
 Endif
Next

If [L]BANK=""
 # Code banque obligatoire
 Call ERREUR(mess(21,121,1)) From GESECRAN
 GOK=0
 End
Endif

If [L]CHEDEB="!" or [L]CHEFIN="zzzzzzzzzzzzzzz"
 # Pas de numéro de chèque saisi
 Call ERREUR(mess(17,121,1)) From GESECRAN
 GOK=0
 End
Endif

If [L]CHEFIN<[L]CHEDEB
 # Borne des numéros de chèques incorrecte
 Call ERREUR(mess(18,121,1)) From GESECRAN
 GOK=0
 End
Endif

Call OUVRE_TRACE (mess(7,7,1)) From LECFIC          # Impression
Raz NBT, NBE, OKCHQ

If [L]NUMREQ2=0 : # Pas de réédition
 If [L]TRI ="" : [L]TRI = "2" : Endif
 If [L]TRI = "1" : # Tri par code tiers
  Filter [PYH] Where evalue([L]FILTRE) Order By Key CLE = BPR   :# 16034
 Else
  Filter [PYH] Where evalue([L]FILTRE) Order By Key CLE = NUM
 Endif

GPOINT = "CHQSRT"  : Gosub ENTREE From EXEFNC

 Raz [L]WNUMLIG, OKSITE, OKDEV
 OLDCHE = [L]CHEDEB
 For [PYH]CLE

  # Vérif autorisation par site
  OKSITE = 1
  If FONCTION<>""
   Read [AFF]AFF0 = [F:PYH]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Endif
  Endif
  # Vérif cohérence devise
  Gosub CTRL_DEVISE

  If OKSITE and OKDEV
   Call DEBTRANS From GLOCK
   OK = 1
   Gosub TR1
   If OK=0 : Break : Endif
  Endif
 Next
 If OKSITE and OKDEV and OKCHQ
  Call MESSAGE(mess(38,114,1)-num$([L]NUMREQ1)) From GESECRAN # Requête numéro xxxxx
 Elsif !(OKSITE & OKCHQ)
  GOK=0
 Endif
 Filter [PYH]
Else             : # Réédition. On peut indiquer une borne de règlements
 Filter [ARM] Where  NUMREQ=[L]NUMREQ2 & evalue([L]FILT)
 Read [ARM] First
 If [F:ARM]RPTCOD <> [L]ETAT : # ou fstat<>0->aucun réglt sélectionnés n'appartient à la requête
  # Impossible de rééditer les règlements par la requête yyy
  Call ERREUR(mess(19,121,1)-num$([L]NUMREQ2)) From GESECRAN
  Filter [ARM]
  GOK=0
  End
 Endif
 OLDCHE = [L]CHEDEB
# For [ARM]ARM0
 For [ARM]ARM0 Where CLEA4<>'GACCDENCOD' & CLEA4<>'GTYPACCENT'
  Call DEBTRANS From GLOCK
  OK = 1
  Gosub TR2
  If OK=0 : Break : Endif
 Next
 Filter [ARM]
Endif

If OLDCHE>[L]CHEFIN & OK=0
 # gestion des saut de page par règlement
 If OKCHQ=0 | [L]NUMREQ2
     Call ERREUR(mess(18,121,1)) From GESECRAN :  # Borne des numéros de chèques incorrecte
     GOK=0
 Else
     Call ERREUR(mess(23,121,1)) From GESECRAN : # Dernier chèque édité. Il reste des règlements à imprimer
 Endif
Endif

If NBE=1 : Call MESSAGE(mess(84,116,1)-" :" -PYHCUR) From GESECRAN : Endif  # Devise incorrecte
If NBE>1
 Call SUPP_TRACE From LECFIC
 If NBT<=0 : GOK=0 : Endif
Else
 Call FERME_TRACE From LECFIC
Endif

# EMERAUDE - Feature MULTILEG- Requirement 71216
#------------------------------------------------------------------
Local Integer NBRLEG : NBRLEG = 1
Local Char TABLEG(GLONADI)(1..1) : TABLEG(NBRLEG) = GCURLEG
If [L]NUMREQ2<>0
 [L]NUMREQ=[L]NUMREQ2
Else
 [L]NUMREQ=[L]NUMREQ1
 Gosub ETA_LEG :#ML JHA
Endif
End

$ETA_LEG
If OKCHQ=0 : Return : Endif
# Multi-Leg (LETCHQEUR/LETTRECHE)
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
If SOCIETE<>"?????"
 Read [CPY]CPY0 = SOCIETE
 If fstat
  # Société incorrecte
  Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
  GOK = 0 : Return
 Endif
 If [F:CPY]CPYLEGFLG<>2
  NBSOC = 0
  For [FGR]FGR0 Where CPY=SOCIETE
   Read [FCY]FCY0 = [F:FGR]FCY
   If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
    NBSOC += 1
    TBSOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Next
 Else
  NBSOC = 1
  TBSOC(1) = SOCIETE
 Endif
Endif
K = WNUMLIG
Gosub TRT_CDA_GTE From RPTLEG
Return

$TR1
Trbegin [ARM], [PYH]
 Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
 Call LEC_TED([F:TPY]LEG,[F:TPY]CODEDT) From CPTLEC
 If [F:TED]TRT = [L]EDIT
  If OLDCHE>[L]CHEFIN
   OK = 0
   Commit
   Return
  Endif

  If [L]LETTRE=1

   NBR = 0
   Filter [PYD] Where NUM=[F:PYH]NUM & evalue([L]FILT2)
   NBPYD = rowcount([PYD])
   For [PYD]
    NBR +=1
    If NBR>CHQNBR or (NBPYD>7 & NBPYD<12 & [F:PYD]LIN=8)
     NBR = 1
     Call INCSERIE(NEWCHE,OLDCHE) From EDITCHE
     SAV_OLDCHE = OLDCHE #X3-67488
     OLDCHE     = NEWCHE

     #X3-67488
     If SAV_OLDCHE <> NEWCHE
       Gosub VOID_CHE
     Endif #X3-67488

     #X3-67488 If OLDCHE>[L]CHEFIN
     #*X3-67488  We compare OLDCHE with [L]CHEFIN only if the number of payment lines is not greater than chqnbr param value
     #*          Only in the case where one check can contains all payment lines
     If (NBPYD <= [L]CHQNBR) and (OLDCHE>[L]CHEFIN)
      Break
     Endif
    Endif
   Next
   Filter [PYD]

   #*X3-67488   If OLDCHE>[L]CHEFIN
   #*X3-67488  We compare OLDCHE with [L]CHEFIN only if the number of payment lines is not greater than  chqnbr param value
   #*          Only in the case where one check can contains all payment lines
   If (NBPYD <= [L]CHQNBR) and (OLDCHE>[L]CHEFIN)
     OK = 0
     Commit
     Return
   Endif

  Endif

  WNUMLIG += 1
  Raz [F:ARM]
  Gosub ADRESSE
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ1
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:PYH]NUM
  [F:ARM]CREDAT  = date$
  Write [F:ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
  Readlock [PYH2]PYH0 = [F:PYH]NUM
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[F:PYH]NUM : Goto ROLL_TR1
  Elsif fstat
   GOK = 0 : Call RSTA("PYH2",[F:PYH]NUM) From GLOCK : Goto AB_TR1
  Endif
  If func AFNC.PARAM("CHQCT",[F:PYH]CPY)="2"
   Gosub SET_CHECK From CHECKS
   If !GOK : Goto AB_TR1 : Endif
  Endif
  [F:PYH2]EDTNUM = [L]NUMREQ1
  [F:PYH2]CHQNUM = OLDCHE
  Rewrite [PYH2]
  If fstat
   GOK = 0 : Call FSTA("PYH2") From GLOCK : Goto AB_TR1
  Endif
  If func AFNC.PARAM("CHQCT",[F:PYH]CPY)="2"
   Gosub GET_NEW_CHECK From CHECKS
   If !GOK : Goto AB_TR1 : Endif
  Else
   Call INCSERIE(NEWCHE,OLDCHE) From EDITCHE
   OLDCHE = NEWCHE
  Endif
  OKCHQ+=1
 Endif
Commit
Return

$ADRESSE
# Recherche de l'adresse du fournisseur
# Sur le chèque l'info CLEA2 sur l'adresse est inutile
# Sur la lettre chèque l'adresse du fournisseur est obligatoire

# Bug 52310 le 3/03/09 Si l'adresse détail de PAYMENTH est vide on récupère le code adresse qui est obligatoire
###DBA le 04/07/03 : Sugg 12674 & 18621
###On prend l'adresse du règlement mais si elle est vide,
###on prend l'adresse par défaut du tiers ou du compte.

# Bug 52310 si l'adresse détail de PAYMENTH est vide on récupère le code adresse qui est obligatoire
#I=0
#For J=0 To dim([F:PYH]BPAADDLIG)-1
# If vireblc([F:PYH]BPAADDLIG(J),2)<>"" : I=1 : Break : Endif
#Next J
#If [F:PYH]POSCOD <> "" or [F:PYH]CTY <> "" : I=1 : Endif
#If I : Raz [F:ARM]CLEN1, [F:ARM]CLEA3
#Elsif [F:PYH]BPR<>""
# [F:ARM]CLEN1=1
# [F:ARM]CLEA3=[F:PYH]BPR
# Call LECTURE("BPS",[F:PYH]BPR,"") From CONTOBJ
# Read [BPA]BPA0=1;[F:PYH]BPR;[F:BPS]BPAADD
# If !fstat
#    [F:ARM]CLEA2 = [F:BPS]BPAADD : Return
# Else
#    Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
#    Read [BPA]BPA0=1;[F:PYH]BPR;[F:BPR]BPAADD
#    If !fstat
#        [F:ARM]CLEA2 = [F:BPR]BPAADD : Return
#    Endif
# Endif
#Else
# [F:ARM]CLEN1=5
# [F:ARM]CLEA3=[F:PYH]ACC
# Call LECTURE("GAC",[F:PYH]ACC,[F:PYH]COA) From CONTOBJ
# Read [BPA]BPA0=5;[F:PYH]ACC;[F:GAC]BPAADD
# If !fstat : [F:ARM]CLEA2 = [F:GAC]BPAADD : Return : Endif
#Endif
# Bug 52310 si l'adresse détail de PAYMENTH est vide on récupère le code adresse qui est obligatoire
I=0
For J=0 To dim([F:PYH]BPAADDLIG)-1
 If vireblc([F:PYH]BPAADDLIG(J),2)<>"" : I=1 : Break : Endif
Next J
If [F:PYH]POSCOD <> "" or [F:PYH]CTY <> "" or [F:PYH]CRYNAM <> "" : I=1 : Endif
If I : Raz [F:ARM]CLEN1, [F:ARM]CLEA3
Elsif [F:PYH]BPR<>""
 [F:ARM]CLEN1=1
 [F:ARM]CLEA3=[F:PYH]BPR
 [F:ARM]CLEA2 = [F:PYH]BPAINV : Return
Endif
Raz [F:ARM]CLEA2
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1
Endif

$AB_TR1
Rollback
Return

$TR2
Trbegin [PYH], [ARM]
 If OLDCHE>[L]CHEFIN
  OK = 0
  Commit
  Return
 Endif
 Readlock [PYH]PYH0=[F:ARM]CLEA1
 If [F:PYH]BAN=[L]BANK
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[F:ARM]CLEA1 : Goto ROLL_TR2
  Elsif fstat
   GOK = 0 : Call RSTA("PYH",[F:ARM]CLEA1) From GLOCK : Goto AB_TR2
  Endif
# Vérif autorisation par site
  OKSITE = 1
  If FONCTION<>""
   Read [AFF]AFF0 = [F:PYH]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Endif
  Endif
# vérif cohérence devise
  Gosub CTRL_DEVISE
  If OKSITE and OKDEV
   If [L]LETTRE=1
    NBR = 0
    Filter [PYD] Where NUM=[F:PYH]NUM & evalue([L]FILT2)
    NBPYD = rowcount([PYD])
    For [PYD]
     NBR +=1
     If NBR>CHQNBR or (NBPYD>7 & NBPYD<12 & [F:PYD]LIN=8)
      NBR = 1
      Call INCSERIE(NEWCHE,OLDCHE) From EDITCHE
      OLDCHE = NEWCHE
      If OLDCHE>[L]CHEFIN
       Break
      Endif
     Endif
    Next
    Filter [PYD]
    If OLDCHE>[L]CHEFIN
     OK = 0
     Commit
     Return
    Endif
   Endif
   Gosub ADRESSE
   Rewrite [ARM]
   If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
   [F:PYH]CHQNUM = OLDCHE
   Rewrite [PYH]
   If fstat
    GOK = 0 : Call FSTA("PYH") From GLOCK : Goto AB_TR2
   Endif
   Call INCSERIE(NEWCHE,OLDCHE) From EDITCHE
   OLDCHE = NEWCHE
   OKCHQ+=1
  Endif
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2
Endif

$AB_TR2
Rollback
Return

$OUVRE
Local File PAYMENTH [PYH], PAYMENTH [PYH2], PAYMENTD[PYD], AREPORTM [ARM], TABPAYTYP[TPY],
& BPADDRESS [BPA], BPARTNER [BPR], BPCUSTOMER [BPC], BPSUPPLIER [BPS], GACCOUNT [GAC], AFCTFCY [AFF], COMPANY [CPY], GTYPACCENT [GTE], BANK [BAN],
& FACGROUP [FGR], FACILITY [FCY], GACCDENCOD [CDA], TABCODEDT [TED]
Return

$DECLARE
Local Date DTE
Local Integer I, J, NUMREQ, NUMREQ1, NUMREQ2, WNUMLIG, NBR, CHQNBR, OK, LETTRE, OKSITE, NBT, NBE, OKDEV, OKCHQ, NBPYD
Local Char FILT(100), FILT2(100), ETAT(GLONARP), PARAM(30), VALEUR(30), EDIT(3), CODRPT(15)
Local Char CHEDEB(15), CHEFIN(15), OLDCHE(15), NEWCHE(15), BANK(5), FONCTION(10)
Local Char SAV_OLDCHE(15)
Local Char TRI(1), PYHCUR(GLONVCR)
# Variables pour effectur le filtre (Demande 41899)
Local Char FILTRE(250)(1..2)
Local Integer IFILT : IFILT = 1
#
#Multi-Leg (LETCHQEUR/LETTRECHE)
Local Char ETATDEP(GLONARP)
Local Char SOCIETE(GLONCPY)
Local Integer NBSOC
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer K
Return

##############################################################################
Subprog INCSERIE(NEWCHE,OLDCHE)
Variable Char NEWCHE()
Value    Char OLDCHE()
Local Integer I,J,LG
Local Char NUMERO(15),NEWNUM(15)

I=len(OLDCHE)
While I>0 & !instr(1,"0123456789",mid$(OLDCHE,I,1))
 I-=1
Wend
If I=0 : NEWCHE=OLDCHE : End : Endif
J=I
While J>0 & instr(1,"0123456789",mid$(OLDCHE,J,1))
 J-=1
Wend
J+=1
NUMERO=seg$(OLDCHE,J,I)
LG = len(NUMERO)
NEWNUM=format$("N0:"+num$(LG),val(NUMERO)+1)
NEWCHE=left$(OLDCHE,J-1)+NEWNUM+right$(OLDCHE,I+1)
End


$ACTION
Case ACTION
 When "OUVRE"
  Local Integer P2 : P2 = find("bank",[M]PARCOD(0..[M]NBRPAR-1))
  If P2 & [M]VALEUR1(P2-1)<>""
   Call DEF_CHQNUM([M]VALEUR1(P2-1),ACTION) From CHECKS
  Endif
 When "CONT1"
  If [M]PARCOD(nolign-1)="bank"
   Call DEF_CHQNUM([M]VALINT1(nolign-1),ACTION) From CHECKS
  Endif
 When "CONT2"
  If [M]PARCOD(nolign-1) = "chedeb"
   Local Integer L1 , L2
   L1 = len(VALPAR) : L2 = len([M]VALEUR1(nolign-1))
   If L1>L2
    [M]VALEUR1(nolign-1) = string$(L1-L2,"0")+[M]VALEUR1(nolign-1)
    [M]VALINT1(nolign-1) = [M]VALEUR1(nolign-1)
    Affzo VALEUR1(nolign-1)
   Elsif L2>L1
    VALPAR = string$(L2-L1,"0")+VALPAR
    [M]VALINT2(nolign-1) = VALPAR
   Endif
  Endif
 When "AP_IMPRIME"
  Local Integer P2 : P2 = find("bank",[M]PARCOD(0..[M]NBRPAR-1))
  If P2 & [M]VALEUR1(P2-1)<>""
     Call DEF_CHQNUM([M]VALEUR1(P2-1),ACTION) From CHECKS
  Endif
Endcase
Return


##############################################################################
$CTRL_DEVISE

OKDEV=1
NBT=+1
If find([L]CODRPT,"CHEQUE","LETTRECHE") & [PYH]CUR="EUR"
 NBT-=1 : NBE+=1 : OKDEV=0
 PYHCUR = [PYH]NUM
 Call ECR_TRACE(mess(84,116,1)-" :" -PYHCUR,0) From GESECRAN
Elsif find([L]CODRPT,"CHQEURO","LETCHQEUR") & [PYH]CUR<>"EUR"
 NBT-=1 : NBE+=1 : OKDEV=0
 PYHCUR = [PYH]NUM
 Call ECR_TRACE(mess(84,116,1)-" :" -PYHCUR,0) From GESECRAN
Endif

Return
### #X3-67488 ###########################################################################
$VOID_CHE

 # If number of payment lines > CHQNBR we set old check to void if payment is assigned to new check
 Readlock [CHN]CHN0=[L]BANK;SAV_OLDCHE
 If fstat = 0
   [F:CHN]CHQTYP = 0          #
   [F:CHN]STA    = 3          # Voided
   [F:CHN]PAYNUM = ""
   [F:CHN]PRNFLG = 1          # Not Printed
   [F:CHN]PRNDAT = [00/00/00]
   [F:CHN]UPDUSR = GUSER
   [F:CHN]UPDDAT = date$
   [F:CHN]CLODAT = [00/00/00]
   Rewrite [CHN]
   If fstat
     OK = 0 : Call RSTA("CHN",[L]BANK-SAV_OLDCHE) From GLOCK : Return
   Endif
 Endif

Return
##############################################################################

