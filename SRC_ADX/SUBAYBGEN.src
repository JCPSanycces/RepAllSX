#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Xtend: Gûˋnûˋration fiche Bloc
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Rûˋfûˋrence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace dûˋtaillûˋe
                         #       'CHK'   =Vûˋrification 
Value Char ELTCOD        #     Code ûˋlûˋment
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Integer CHKFLG      : CHKFLG      = find("CHK",OPTION) 

Local Char WSTR1(250)

RET=1

Call TITOBJ("AYB","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 
If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTELTBLC    [AYB1] 
 Local File ATEXTE       [ATX1] 
 Local File AYTLINES     [AYN1] 
 Local File ATEXTRA      [AXX1]
Else 
 Local File = [L]DOSORG+".AYTELTBLC"  [AYB1] 
 Local File = [L]DOSORG+".ATEXTE"     [ATX1] 
 Local File = [L]DOSORG+".AYTLINES"   [AYN1]  
 Local File = [L]DOSORG+".ATEXTRA"    [AXX1] 
Endif 

If CHKFLG   # Vûˋrification interface
 If DOSORG=nomap 
  Local File AYTINT    [AYI1]
  Local File AYTENT    [AYE1]
 Else
  Local File =[L]DOSORG+".AYTINT"     [AYI1] 
  Local File =[L]DOSORG+".AYTENT"     [AYE1] 
 Endif 
 Gosub GETWS_VAR From SUBAYIACT
Endif

Default File "[AYB1],[ATX1],[AYN1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="BLC"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYB1]AYB0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG or CHKFLG : Call ECR_TRACE(mess(7,7910,1)-":"-[F]BLCCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]BLCCOD    
 Call LECTEXTRA(XT_VAl,"AYTELTBLC","INTIT",[F]FCYCOD,[F]BLCCOD) From AYTUTIA : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="ENTCOD"     : XT_VAL=[F]ENTCOD                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="TYP"        : XT_VAL=num$([F]TYP)
                                      XT_LAB=mess([F]TYP,7914,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="OPTDSY"     : XT_VAL=num$([F]OPTDSY)
                                      XT_LAB=mess([F]OPTDSY,7915,1)        : Gosub XMLF_ADD From AYTGEN

 XT_TY="FLD"   : XT_ID="INTOPTIMI"     : XT_VAL=num$([F]INTOPTIMI)
                                         XT_LAB=mess([F]INTOPTIMI,7933,1)        : Gosub XMLF_ADD From AYTGEN
 
 If [F]TYP=2    # Multi
   XT_TY="FLD"   : XT_ID="BLCNBRLIN"  : XT_VAL=num$([F]BLCNBRLIN)            : Gosub XMLF_ADD From AYTGEN
   XT_TY="FLD"   : XT_ID="LINNBROBC"  : XT_VAL=num$([F]LINNBROBC)            : Gosub XMLF_ADD From AYTGEN
   XT_TY="TAB"   : XT_ID="LINSTYNBR"  : XT_VAL="Styles"                      : Gosub XMLF_ADD From AYTGEN
   For WI=0 To [F]LINSTYNBR-1
     XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
     XT_TY="COL"  : XT_ID="LINSTY"     : XT_VAL=[F]LINSTY(WI)                  : Gosub XMLF_ADD From AYTGEN
   Next
 Endif

 XT_TY="FLD"   : XT_ID="SELTYP"     : XT_VAL=num$([F]SELTYP)
                                      XT_LAB=mess([F]SELTYP,7916,1)        : Gosub XMLF_ADD From AYTGEN

 # Sûˋlection requete ou code
 If find([F]SELTYP,2,3)    
   XT_TY="FLD"   : XT_ID="SELDYNALT"  : XT_VAL=num$([F]SELDYNALT)
                                        XT_LAB=mess([F]SELDYNALT,1,1)         : Gosub XMLF_ADD From AYTGEN
   XT_TY="FLD"   : XT_ID="SRTTYP"     : XT_VAL=num$([F]SRTTYP)
                                        XT_LAB=mess([F]SRTTYP,7917,1)         : Gosub XMLF_ADD From AYTGEN

   # Chps sûˋlection
     XT_TY="TAB"   : XT_ID="NUM30"    :  XT_VAL="Selection"                   : Gosub XMLF_ADD From AYTGEN
     For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=2
&                       and LINCOD = toupper([F:AYB1]BLCCOD) and  LINTYP = 30
        Gosub SEL_DET
     Next
       
   # Tri
   If [F]SRTTYP=2  
     XT_TY="FLD"   : XT_ID="SRTDYNALT"  : XT_VAL=num$([F]SRTDYNALT)
                                          XT_LAB=mess([F]SRTDYNALT,1,1)       : Gosub XMLF_ADD From AYTGEN
     XT_TY="TAB"   : XT_ID="NUM31"      : XT_VAL="Tri"                        : Gosub XMLF_ADD From AYTGEN
     For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=2
&                       and LINCOD = toupper([F:AYB1]BLCCOD) and  LINTYP = 31
        Gosub SRT_DET
     Next
   Endif
 Endif

 # Valeur paramû´tres interface
 XT_TY="TAB"   : XT_ID="NUM41"      :  XT_VAL="InterfaceParameterValue"       : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=2
&                       and LINCOD = toupper([F:AYB1]BLCCOD) and  LINTYP = 41
       XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="PARCOD"     : XT_VAL=[F:AYN1]PARCOD                 : Gosub XMLF_ADD From AYTGEN
       # Type valeur
       XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F]VALTYP)
                                           XT_LAB=mess([F]VALTYP,7925,1)         : Gosub XMLF_ADD From AYTGEN
       Case [F]VALTYP
       When 1,3    
         XT_TY="COL"  : XT_ID="VALEUR"   : U_HEXTOTXT=[F:AYN1]VALEUR             : Gosub U_TXTTOHEX From SUBAPSUTI
                                           XT_VAL=U_TXTTOHEX                     : Gosub XMLF_ADD From AYTGEN
       When 2
         XT_TY="COL"  : XT_ID="VALBLCCOD" : XT_VAL=[F:AYN1]VALBLCCOD              : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIELNKE": XT_VAL=[F:AYN1]VALFIELNKE             : Gosub XMLF_ADD From AYTGEN
         XT_TY="COL"  : XT_ID="VALFIECOD" : XT_VAL=[F:AYN1]VALFIECOD              : Gosub XMLF_ADD From AYTGEN
       Endcase
 Next

 If CHKFLG   # Vûˋrification interface
    If [F:AYB1]ENTCOD="" : Goto INTCHKFLG_E : Endif
    Read [AYE1]AYE0=[F]FCYCOD;[F]ENTCOD
    Call ECR_TRACE(space$(5)+mess(6,7910,1)-":"-[F]ENTCOD,0) From GESECRAN
    If fstat
        Call ECR_TRACE(space$(5)+mess(173,7900,1)-":"-[F]ENTCOD,1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif
    
    If [F:AYE1]INTCOD="" : Goto INTCHKFLG_E : Endif
    Call ECR_TRACE(space$(5)+mess(13,7910,1)-":"-[F:AYE1]INTCOD,0) From GESECRAN
    Read [AYI1]AYI0=[F]FCYCOD;[F:AYE1]INTCOD
    If fstat
        Call ECR_TRACE(space$(5)+mess(172,7900,1)-":"-[F:AYE1]INTCOD,1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif

    If !find([F:AYI1]TYP,1,2,3,4)
        Call ECR_TRACE(space$(5)+mess(174,7900,1)-":"-mess([F:AYI1]TYP,7912,1),1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif

    Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
    WS_INTTYP=[F:AYI1]TYP : WS_WSRCOD=[F:AYI1]WEBSRCCOD 
    Gosub GETWS_INF From SUBAYIACT
    If WS_RET   # Anomalie
        Call ECR_TRACE(space$(5)+WS_MES,1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif
#modif sb On controle les lignes si multi-enregistrement
    If ([F:AYB1]BLCNBRLIN*[F:AYB1]LINNBROBC > RUBRESMAX & [F:AYB1]TYP=2 )
        Call ECR_TRACE(space$(5)+mess(178, 7900, 1)-"("-num$(RUBRESMAX)-")",1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif
#fin sb
 Endif
$INTCHKFLG_E

Next

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYB1],[ATX1],[AYN1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

# Dûˋtail ligne sûˋlection (repris par SUBAYLGEN) - AYN1 en ligne
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEL_DET
XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F:AYN1]FIECOD                 : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="FIELNKENT"  : XT_VAL=[F:AYN1]FIELNKENT              : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="ANDOR"      : XT_VAL=num$([F]ANDOR)
                                   XT_LAB=mess([F]ANDOR,56,1)             : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="BRKLFT"     : XT_VAL=num$([F:AYN1]BRKLFT)           : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="BRKRGT"     : XT_VAL=num$([F:AYN1]BRKRGT)           : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="OPE"        : XT_VAL=num$([F]OPE)
                                   U_HEXTOTXT=mess([F]OPE,7926,1)        : Gosub U_TXTTOHEX From SUBAPSUTI
                                   XT_LAB=U_TXTTOHEX                     : Gosub XMLF_ADD From AYTGEN
XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F]VALTYP)
                                   XT_LAB=mess([F]VALTYP,7925,1)         : Gosub XMLF_ADD From AYTGEN
# Type valeur
Case [F]VALTYP
When 1,3    
  XT_TY="COL"  : XT_ID="VALEUR"   : U_HEXTOTXT=[F:AYN1]VALEUR             : Gosub U_TXTTOHEX From SUBAPSUTI
                                    XT_VAL=U_TXTTOHEX                     : Gosub XMLF_ADD From AYTGEN
When 2
  XT_TY="COL"  : XT_ID="VALBLCCOD" : XT_VAL=[F:AYN1]VALBLCCOD              : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="VALFIELNKE": XT_VAL=[F:AYN1]VALFIELNKE             : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="VALFIECOD" : XT_VAL=[F:AYN1]VALFIECOD              : Gosub XMLF_ADD From AYTGEN
Endcase

# Par requûˆte
If [F]SELTYP=3
  XT_TY="COL"  : XT_ID="ALLSTAR"    : XT_VAL=num$([F]ALLSTAR)
                                      XT_LIB=mess([F]ALLSTAR,1,1)           : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="CRIOBY"     : XT_VAL=num$([F]CRIOBY)
                                      XT_LIB=mess([F]CRIOBY,1,1)            : Gosub XMLF_ADD From AYTGEN
Endif
Return

# Dûˋtail ligne tri (repris par SUBAYLGEN)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SRT_DET
       XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F:AYN1]FIECOD                 : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="FIELNKENT"  : XT_VAL=[F:AYN1]FIELNKENT              : Gosub XMLF_ADD From AYTGEN
       XT_TY="COL"  : XT_ID="SRTORD"     : XT_VAL=num$([F]SRTORD)
                                           XT_LAB=mess([F]SRTORD,90,1)           : Gosub XMLF_ADD From AYTGEN
Return
