#<AdxTL>@(#)0.0.0.0 $Revision$Class Representation
# Supervisor
## ATY-ATYPE ## ESH1
# 2018-11-09 07:14:15 829

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,MSGCOD,MSGREL,MSGFILNOR,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char MSGCOD
Value Char MSGREL
Value Char MSGFILNOR
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDISEQFIL [ESF]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDISEQFIL" [ESF]
Endif

Default File [F:ESF]
Read [F:ESF]ESF0 = [L]MSGCOD;[L]MSGREL;[L]MSGFILNOR
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)+"~"+num$([L]MSGFILNOR)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)+"~"+num$([L]MSGFILNOR)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


