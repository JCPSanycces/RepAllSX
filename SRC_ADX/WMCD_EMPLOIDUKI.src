#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:57 374


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOIDUKI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOIDUKI

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOIDUKI
Else
 Gosub ADELETE_EMPLOIDUKI
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOIDUKI,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOIDUKI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOIDUKI.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOIDUKI
Trbegin [F:IDUKI]
 Gosub ADELETE_EMPLOIDUKI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOIDUKI
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOIDUKI,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOIDUKI._MAJSQL_EMPLOIDUKI(EMPLOIDUKI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOIDUKI.snapshotEnabled=1
 [L]A_RETIK = EMPLOIDUKI.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOIDUKI.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



