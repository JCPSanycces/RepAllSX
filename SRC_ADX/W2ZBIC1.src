 PARMSK(1) = "1"
 PARMSK(2) = [M]BPRPAY
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELTBPA","TRTADR","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
