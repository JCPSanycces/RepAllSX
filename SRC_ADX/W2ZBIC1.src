Call CONTSEL("BAN","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PAYBAN" : GZNUM = 54386 : Endif
If !mkstat
 ## Action STD
 Call C_PAYBAN(VALEUR) From SUBBIC2
 If mkstat : GERR = 1 : GZONE = "PAYBAN" : GZNUM = 54386 : Endif
Endif
Gosub _AFF
End

Subprog S_PAYBAN(VALEUR)
