End

Subprog AS_DCLEECNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_DCLEECNUM(VALEUR) From SUBBIC2
If mkstat=2
 [M]DCLEECNUM(INDIC) = VALEUR
 Affzo DCLEECNUM(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$ON_UMRNUM
