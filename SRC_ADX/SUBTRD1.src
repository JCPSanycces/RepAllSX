#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################
##   ZZSUBTRD1
##############################################################

Call MESSAGE(GBIDI1)
End 
 
Subprog MESSAGE(NUMERO) 
Variable Integer NUMERO  : NUMERO = 0
Global Char SAVE_ZLAN(3)                 # valeur par défaut dans ecran donc Global
Local Integer ETABOU(1..GNBBOU) , REPONSE 
Local Integer SAVOBJET , CLECUR , OK, CHAPITRE, VERROU 
Local Char    SAVPROG(10), REP(1) , COUZON(10), FILTRE(250), ZDEB(1), SAVE_LAN(3) 
Local Integer NOCHP , NOLIB 
Local Char    TITLIB(250), OK_CHP 
ZDEB="0" 
Local Mask TRAD02 [TRA2] 
Local File APLSTD [AST]  , APLSTD [AST2]  , APLSTD [AST3] , APLSTD [AST4]
&         ,APLSTD [AST5] , APLSTD [AST6]
 
Call SAVBOUT From GESECRAN 

SAVOBJET = GOBJET 
SAVPROG  = GPROGRAMME 
If ZDEB="0"
    SAVE_LAN=GLANGUE
    [M:TRA2]LAN=GLANGUE
    [M:TRA2]LANCHP=1
    [M:TRA2]LANNUM=0
    SAVE_ZLAN=""
    ZDEB="1"
Endif


FILTRE = "1=1" 
Gosub FILTRE

### Gestion liste gauche
Local Inpbox Mask [TRA2] 
& Button mess(2,123,1) , mess(5,123,1) 
& With left$(mess(2,123,1),1) , left$(mess(5,123,1),1) 
& Coded GSTAENR  , GSTAFIN 
& Leftbox [LNK] GAU_CHE 
& [F:AST3]LANCHP Titled mess(78,100,1) 
& , string$([F:AST3]LANCHP<100,[F:AST5]LANMES)
&  -string$(([F:AST3]LANCHP>=100 & [F:AST3]LANCHP<200) or [F:AST3]LANCHP>8900,[F:AST4]LANMES)
&  -string$([F:AST3]LANCHP>200 & [F:AST3]LANCHP<8900,[F:AST6]LANMES)
&  Titled ""
& As [TRA2] 
# 
Boxact [TRA2] 
Gosub REMPLIT 

Onevent 
GOBJET = 1 
GPROGRAMME = "SUBTRD1" 
REP = "" 
If NUMERO<>0 : CHAPITRE = NUMERO : Gosub LECTURE : Endif  

$CHOI 
Gosub SETBOUT 
Boxinp [TRA2] Using REPONSE 
Onevent AFTER_CHANGE 
Case REPONSE 
 When GSTAENR : Gosub ENREGISTRE 
 When GSTACRE : Gosub ENREGISTRE 
 When GSTAFIN : Gosub ABANDON 
 When GSTAFIR : Gosub PREMIER 
 When GSTALAS : Gosub DERNIER 
 When GSTASUI : Gosub SUIVANT 
 When GSTAPRE : Gosub PRECEDENT 
 When GSTAESC : Gosub ABORT : If OK : Goto FIN : Endif 
 When GSTASEL : Gosub SELECTION 
 When GSTALFT , GSTALF2 : Gosub GAUCHE 
 When Default : Gosub ENREGISTRE 
Endcase 
Goto CHOI 
  
$REMPLIT 
adxmxl = GNBGAUCHE 
Fillbox [TRA2] 
Return 

$ABANDON 
Gosub RELIT 
REP = "" 
If not GIMPORT
    Effzo [M:TRA2]LANNUM
    Effzo [M:TRA2]LANMES
    Effzo [M:TRA2]ZTEXTE
Endif
Return 
 
$ABORT 
OK = 1 
If not GIMPORT
    Effzo [M:TRA2]LANNUM
    Effzo [M:TRA2]LANMES
    Effzo [M:TRA2]ZTEXTE
Endif
Return 
 
$SETBOUT 
Raz ETABOU 
ETABOU(GENRE) = 1 
ETABOU(GABAN) = 1 
ETABOU(GSELE) = 1
If CLECUR<>0 
    ETABOU(GPREM) = 1 
    ETABOU(GDERN) = 1
    ETABOU(GSUIV) = 1 
    ETABOU(GPREC) = 1 
Endif
Call SETBOUT(ETABOU) From GESECRAN 
Return 
 
$PREMIER 
If OK_CHP="0"
    Filter [AST] Where LANCHP<>0 & LANCHP<>200 
    Read [AST]CLE(1) First 
    Goto SUIVPREC 
Endif
[M:TRA2]LANNUM=0
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM ;[M:TRA2]LAN
CLECUR=1
Goto SUIVPREC_NUM
 
$DERNIER 
If OK_CHP="0"
    Filter [AST] Where LANCHP<>0 & LANCHP<>200  
    Read [AST]CLE(1) Last 
    Goto SUIVPREC 
Endif
[M:TRA2]LANNUM=NBLIG-1
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM ;[M:TRA2]LAN
CLECUR=[F:AST]LANNUM
Goto SUIVPREC_NUM
 
$SUIVANT 
If OK_CHP="0"
    Filter [AST] Where LANCHP<>0 & LANCHP<>200  
    Read [AST]CLE(1)>CHAPITRE 
    Goto SUIVPREC 
Endif
[M:TRA2]LANNUM=LANNUM+1
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM;[M:TRA2]LAN
CLECUR=[F:AST]LANNUM
Goto SUIVPREC_NUM
 
$PRECEDENT 
If OK_CHP="0"
    Filter [AST] Where LANCHP<>0 & LANCHP<>200  
    Read [AST]CLE(1)<CHAPITRE 
    Goto SUIVPREC 
Endif
[M:TRA2]LANNUM=LANNUM-1
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM;[M:TRA2]LAN
CLECUR=[F:AST]LANNUM
Goto SUIVPREC_NUM
 
$GAUCHE 
fstat = 0 
[F:AST]LANCHP = [F:AST3]LANCHP 
Goto SUIVPREC 
 
$SUIVPREC 
Filter [AST] 
Gosub ABORT 
If !ok : Return : Endif 
If fstat 
 call MESSAGE(mess(11,100,1)) From GESECRAN 
 Return 
Else 
    If not GIMPORT
        Gosub DEVERROU 
    Endif
 CHAPITRE = [F:AST]LANCHP 
 Gosub LECTURE 
 REP = "" 
Endif 
Return 

$SUIVPREC_NUM 
#If !ok : Return : Endif 
If fstat 
    Call MESSAGE(mess(11,100,1)) From GESECRAN 
    Return 
Else 
    If not GIMPORT
        [M:TRA2]LANNUM=[F:AST]LANNUM
        [M:TRA2]LANMES=[F:AST]LANMES
#        Affzo [M]LANNUM
#        Affzo [M]LANMES
        If SAVE_ZLAN <> ""
            Read[AST]CLE=[F:AST]LANCHP;[F:AST]LANNUM;SAVE_ZLAN
            If fstat = 0   
               [M:TRA2]ZTEXTE = [F:AST]LANMES
            Else
                [M:TRA2]ZTEXTE="?"
            Endif
        Endif
        Affzo [M:TRA2]1-99
        Gosub DEVERROU 
    Endif
Endif 
Return 

$APRES_MODIF
COUZON = zoncou 
If COUZON="LANCHP" 
 Read [AST]CLE(1) = zc 
 If !fstat 
  CHAPITRE = zc 
  Gosub LECTURE 
  Gosub SETBOUT 
  REP = "" 
 Else
    If not GIMPORT
      Gosub DEVERROU 
    Endif
      REP = "C" 
  gosub SETBOUT 
 Endif 
Elsif REP="" 
  If not GIMPORT
     If !VERROU 
          Gosub VERROU 
         If !VERROU 
           Call ERREUR(mess(10,100,1)) From GESECRAN : mkstat = 2 : Return 
         Else 
           CHAPITRE = [M:TRA2]LANCHP 
           Gosub LECTURE 
         Endif 
     Endif 
  Endif
 REP = "M" 
 Gosub SETBOUT 
Endif 
Return 
 
$VERROU 
SYMBOLE = "AST"+num$(CHAPITRE) 
Lock =symbole With lockwait=0 
If fstat 
 VERROU = 0 
Else 
 VERROU = 1 
Endif 
Return 
 
$DEVERROU 
If VERROU 
 Unlock = SYMBOLE 
 VERROU = 0 
Endif 
Return 
 
$LECTURE 
If GIMPORT : Return : Endif
Gosub DEVERROU 
Gosub VERROU 
nolign = 0 
Read [AST]CLE(1) = CHAPITRE
Setlbox [TRA2]
For [AST]CLE Where LANCHP=CHAPITRE & LAN=GLANGUE
    nolign += 1 
    [M] = [F:AST] 
Next 
[M]NBLIG = nolign 
CLECUR = 1 
    If [M]LANNUM(0)=0 & [M]NBLIG>=1 
    Dela 0,1 [M]NBLIG 
    [M]NBLIG -= 1 
    Endif 
    If SAVE_ZLAN <> ""
        Read[AST]CLE=[F:AST]LANCHP;[F:AST]LANNUM;SAVE_ZLAN
        If fstat = 0   
            [M:TRA2]ZTEXTE = [F:AST]LANMES
        Else
            [M:TRA2]ZTEXTE="?"
        Endif
    Endif
Affzo [M]1-99
Return 
 
$RELIT 
If CLECUR<>0 
    Gosub LECTURE 
Else
Endif 
Return 
 
##################################### 
##        Mise a jour fichier      ## 
##################################### 
$ENREGISTRE

If not GIMPORT
    Trbegin [AST]    
Endif
Readlock [AST]CLE =[M:TRA2]LANCHP;[M:TRA2]LANNUM;[M:TRA2]ZLAN
If fstat=1 
  GOK=-1 : GLOCK="$APLSTD"-num$([M:TRA2]LANNUM) : Goto ROLL_TR_MTEX 
Elsif fstat  
    If vireblc([M:TRA2]ZTEXTE,0) <>  ""  
        [F:AST]LAN     = [M:TRA2]ZLAN
        [F:AST]LANNUM  = [M:TRA2]LANNUM
        [F:AST]LANMES  = [M:TRA2]ZTEXTE
        [F:AST]UPDDAT  = date$   
        Write [AST]
    Endif  
Else  
    [F:AST]LANMES  = [M:TRA2]ZTEXTE
    [F:AST]UPDDAT  = date$   
    Rewrite [AST]     
Endif  
If fstat 
   GOK=0 : Call FSTA("AST") From GLOCK : Goto AB_TR_MTEX 
Endif 
If not GIMPORT
    Commit
Endif
Return

$AB_TR_MTEX    
Rollback    
Return    
    
$ROLL_TR_MTEX    
Call ROLL From GLOCK    
If GROLL : Return : Else : Goto ENREGISTRE : Endif     

########################################
$SELECTION 
FILTRE = "" 
Call SELECT("APLSTD",FILTRE,OK) From ASELECT 
If OK
 If FILTRE="" : FILTRE = "1=1" : Endif 
 Gosub FILTRE 
 Gosub REMPLIT 
Endif 
Return 

########################################
$FILTRE 
# AST4  100..199
# AST5  1..99
# AST6  201..
Link [AST3] With [AST4]CLE = [F:AST3]LANCHP;0;GLANGUE
&               ,[AST5]CLE = 0;[F:AST3]LANCHP;GLANGUE
&               ,[AST6]CLE = 200;([F:AST3]LANCHP-200);GLANGUE
& As [LNK] 
& Where LANCHP<>0 & LANCHP<>200 & LAN=GLANGUE & LANNUM=1 & evalue(FILTRE) 
& Order By Key CLE(1) 
Return 

$SELECT
NBTEX = 0 
For [AST]CLE Where LANNUM=1 and LAN=GLANGUE and LANCHP<>0 & LANCHP<>200 & evalue(FILTRE)
CHP = [F:AST]LANCHP 
If !VALEUR | (VALEUR & CHP>=VALEUR-10) 
  NBTEX += 1 
  If CHP>=1 & CHP<=99 
   TEX(NBTEX) = format$("N:4#[ ]",CHP)+mess(CHP,0,1) 
  Elsif CHP>200 & CHP<8900
   TEX(NBTEX) = format$("N:4#[ ]",CHP)+mess(CHP-200,200,1) 
  Else 
   TEX(NBTEX) = format$("N:4#[ ]",CHP)+mess(0,CHP,1) 
  Endif 
  If NBTEX>=dim(TEX)-1 : Break : Endif 
Endif 
Next 
NUM = 1 
Call SAITEX(NBTEX,TEX,NUM,mess(30,123,1)) From GESECRAN : # Choix message 
If NUM<>0 & status<>7 
   VALEUR = val(left$(TEX(NUM),4)) 
Endif 
mkstat = 2 
End

### Affichage en fenetre des Numeros de message
$SELECT_BOUT
#dbgmode(1)=1
NBMES = 0 
For [AST]CLE Where LAN=GLANGUE and LANCHP=[M:TRA2]LANCHP & evalue(FILTRE)
  NUMMES = [F:AST]LANNUM 
#  If !VALEUR  
    NBMES += 1 
    MES(NBMES) = format$("N:4#[ ]",NUMMES)+mess(NUMMES,[M:TRA2]LANCHP,1) 
   If NBMES>=dim(MES)-1 : Break : Endif 
#  Endif 
Next 
NUMMES = 1 
Call SAITEX(NBMES,MES,NUMMES,mess(30,123,1)) From GESECRAN : # Choix message 
If NUMMES<>0 & status<>7 
   VALEUR = val(left$(MES(NUMMES),4)) 
   [M:TRA2]LANMES=seg$(MES(NUMMES),6,len(MES(NUMMES)))
   Affzo [M:TRA2]LANMES
#Réaffichage du texte traduit si lan traduction deja saisie
   If [M:TRA2]ZLAN <> ""
      Call REAFFICHE_ZTEXTE (VALEUR)
   Endif
   Endif 
mkstat = 2 
End


$FIN 
If not GIMPORT
    Gosub DEVERROU
Endif
Boxclr [TRA2] 
GOBJET = SAVOBJET 
GPROGRAMME = SAVPROG 
GLANGUE = SAVE_LAN
Call RESTBOUT From GESECRAN 
NUMERO = CHAPITRE
adxmbm = adxmbm 

Kill SAVE_ZLAN
End 
 
########################################
Subprog REAFFICHE_ZTEXTE(VALEUR)
Variable Decimal VALEUR

 Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]ZLAN
   If fstat = 0   
       [M:TRA2]ZTEXTE = [F:AST]LANMES
   Else
       [M:TRA2]ZTEXTE="?"
   Endif
   Affzo [M:TRA2]ZTEXTE 
End
########################################
Subprog AP_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Local Integer ETABOU(1..GNBBOU), CHAPITRE 
Local Integer VERROU , CLECUR 
OK_CHP="0"
CLECUR=1
Gosub SETBOUT 
If [M:TRA2]LANNUM=0
    CHAPITRE=VALEUR
    Gosub LECTURE
Endif
Read[AST]CLE=VALEUR;[M:TRA2]LANNUM;[M:TRA2]LAN
If fstat = 0   
    [M:TRA2]LANMES = [F:AST]LANMES
    If not GIMPORT
          Affzo [M:TRA2]LANMES
          OK_CHP="1"
    Endif
Else
    mkstat=2
Endif
End 
########################################
Subprog AM_LANCHP(VALEUR)
Variable Decimal VALEUR

Read[AST]CLE=VALEUR;[M:TRA2]LANNUM;[M:TRA2]ZLAN
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
If not GIMPORT 
  Affzo [M:TRA2]ZTEXTE
Endif
End

########################################
Subprog AP_LANNUM(VALEUR)
Variable Decimal VALEUR


If GIMPORT : End : Endif 
Affzo [M:TRA2]LANCHP

Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]LAN
If fstat = 0   
    [M:TRA2]LANMES = [F:AST]LANMES
    If not GIMPORT
        Affzo [M:TRA2]LANMES
#        If SAVE_ZLAN <> "" 
#            Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;SAVE_ZLAN
#            If fstat = 0   
#            [M:TRA2]ZTEXTE = [F:AST]LANMES
#            Else
#            [M:TRA2]ZTEXTE="?"
#            Endif
#            Affzo [M:TRA2]ZTEXTE
#        Endif
    Endif
Else
    mkstat=2
Endif
End
########################################
Subprog AM_LANNUM(VALEUR)
Variable Decimal VALEUR

Read[AST]CLE=[M:TRA2]LANCHP;VALEUR;[M:TRA2]ZLAN
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
If not GIMPORT 
  Affzo [M:TRA2]ZTEXTE
Endif

End

########################################
Subprog AM_ZLAN(VALEUR)
Variable Char    VALEUR()
#If GIMPORT : End : Endif 
Read[AST]CLE=[M:TRA2]LANCHP;[M:TRA2]LANNUM;VALEUR
If fstat = 0   
    [M:TRA2]ZTEXTE = [F:AST]LANMES
Else
    [M:TRA2]ZTEXTE="?"
Endif
SAVE_ZLAN = VALEUR
End


########################################
Subprog B1_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Local Integer NBTEX , NUM, CHP , OK
Local Char    TEX(40)(0..GNBSEL) 
Local Char    FILTRE(250)
FILTRE = "" 
Call SELECT("APLSTD",FILTRE,OK) From ASELECT 
If !OK : End : Endif
If FILTRE="" : FILTRE = "1=1" : Endif 
Goto SELECT
End 

########################################
Subprog S_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Local Integer NBTEX , NUM, CHP 
Local Char    TEX(40)(0..GNBSEL) 
Local Char    FILTRE(250)
FILTRE = "1=1"
Goto SELECT
End

########################################
Subprog AS_LANCHP(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
GBOUT1 = mess(173,124,1) : # Sélection avancée
End

########################################
Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
If GIMPORT : End : Endif 
GLANGUE=VALEUR
FILTRE = "1=1"
Gosub FILTRE 
Close Local Mask
Gosub REMPLIT
End


########################################
Subprog B1_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Local Integer NBMES, NUMMES, NUM, OK
Local Char    MES(50)(0..GNBSEL) 
Local Char    FILTRE(250)
FILTRE = "" 
Call SELECT("APLSTD",FILTRE,OK) From ASELECT 
If !OK : End : Endif
If FILTRE="" : FILTRE = "1=1" : Endif 
Goto SELECT_BOUT
End

########################################
Subprog AS_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
GBOUT1 = mess(173,124,1) : # Sélection avancée
End

########################################
Subprog S_LANNUM(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif 
Local Integer NBMES , NUMMES, NUM 
Local Char    MES(50)(0..GNBSEL) 
Local Char    FILTRE(250)
FILTRE = "1=1"
Goto SELECT_BOUT
End

