# GBN   07.07.2009 FQ56402  : Manip LEAREF en AM_OWNTYP conditionné par le code activité LEA activé.
# MWA   02.02.2009 FQ55960  : Degressif marocain
# GLE   22.06.2009 FQ55485  : Un bien composant n'A PLUS OBLIGATOIREMENT LA MÊME LOCALISATION QUE SON BIEN PRINCIPAL
# GLE   25.06.2009 FQ55719  : Il pouvait apparaitre à tort un message indiquant que le bien allait devenir actif à l'issue d'actions métier
# SEGAY   26.05.2009 FQ55263  : V5 V6 Initaliser le site géographique aprés la saisie du site financier
# SEGAY   25.05.2009 FQ55352  : V5 V6 Empêcher la modification du site financier si on a des éléments rattachés
# STANT   29.04.2009 FQ49517  : Création élément physique sur BCO non immatriculable.
# SEGAY   11.05.2009 FQ55082  : Gestion du fournisseur dans les éléments physique
# SEGAY   30.04.2009 FQ49517  : Création d'un élément physique
# MABON   30.04.2009 FQ49517  : Création automatique d'un élément physique
# GLE   24.04.2009 FQ54754  : Déclaration des dates de sortie régularisées (réelle, théorique et initiale) pour l'import
# MDJ   22.04.2009 FQ54616  : Abandon de la suppression d'1 bien avec dépense : le bien était qd même supprimé
#********************************************************************
#
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
  Case ACTION
    When "SETTRANS"      : Local Integer LFASTRS : Gosub SET_TRS_PARM From SUBTSH
    When "BOITE"         : Gosub BOITE        # FQ119322
    When "OUVRE"         : Gosub OUVRE
    When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
    When "SETBOUT"       : Gosub SETBOUT
    When "STATUT"        : Gosub STATUT
    When "RAZCRE"        : Gosub RAZCRE
    When "VERROU"        : Gosub VERROU
    When "DEVERROU"      : Gosub DEVERROU
    When "LIENS"         : Gosub LIENS
    When "APRES_MODIF"   : Gosub APRES_MODIF
    When "VERIF_CRE"     : Gosub VERIF_CRE
    When "INICRE"        : Gosub INICRE
    When "CREATION"      : Gosub CREATION
    When "APRES_CRE"     : Gosub APRES_CRE
    When "AVANT_MOD"     : Gosub AVANT_MOD
    When "VERIF_MOD"     : Gosub VERIF_MOD
    When "AVANT_MODFIC"  : Gosub AVANT_MODFIC
    When "INIMOD"        : Gosub INIMOD
    When "MODIF"         : Gosub MODIF
    When "APRES_MOD"     : Gosub APRES_MOD
    When "AB_MODIF"      : Gosub AB_MODIF
    When "VERF_ANU"      : Gosub VERF_ANU
    When "AV_ANNULE"     : Gosub AV_ANNULE
    When "ANNULE"        : Gosub ANNULE
    When "AP_ANNULE"     : Gosub AP_ANNULE
    When "AVANT_DEVERROU": Gosub AVANT_DEVERROU
    When "FIN_ACTION"    : Gosub FIN_ACTION
    When "ABANDON"       : Gosub ABANDON
    When "FIN"           : Gosub FIN
    When "APRES_CHOI"    : Gosub APRES_CHOI
    When "FILGAUCHE"     : Gosub FILGAUCHE
    When "TIROIR"        : Gosub TIROIR
    When "GAUCHE"        : Gosub GAUCHE
    When "PICKE"         : Gosub PICKE
    When "DEPICKE"       : Gosub DEPICKE
    When "FIN_PICK"      : Gosub FIN_PICK
    When "AVANTBOUT"     : Gosub AVANTBOUT
    When "EXEBOUT"       : Gosub EXEBOUT
    When "FERME"         : Gosub FERME
    When Default
  Endcase
Return

#*********************************************************************
#=====================================================================

$OUVRE
  # Sauvegarde de la liste des masques par défaut
  Global Char FAS_DEF_MASK(255)
  FAS_DEF_MASK = dbgstr(1)

  # Sauvegarde du contexte - variables globales
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif
  If TUNNEL : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif
  # Appel à la fonction de gestion des variales globales
  Gosub OUVRE From SUBFRZ
  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

# --------------------------------

Global Char    G_CCNFMT          : # Pour masquer des champs
Global Integer G_STPDEPSTAO(0..G301MAX) # Valeur origine du statut Arrêt / redémarrage (par plan) FQ80825
Global Char    G_DEROUTE         : # Gestion code forçage
Global Integer G_PLNIAS          : # Plan IAS géré
Global Integer G_CNXIAS          : # Contexte du plan IAS si plan IAS géré

Global Integer G_NBAXE           : #Fq-79815 Nb d'axes à saisir (max 20)

Global Integer GLOFPREAD         : # Dépense principale lue
Global Char    GLDAPCRIT         : #
Global Integer GLDAPSTAR         : #
Global Integer GPARTYPPHY (100)  : # types physique des critères déterminants
Global Char    GLOFLDAB(100)     : #
Global Integer GLDABAPPL         : # Liste des dépenses appliquées
Global Integer GINDLOFPRI        : # Indice de la dépense principale dans le tableau destination
Global Integer GNBDEPLIEES       : # Nombre de dépenses déjà immobilisées sur le bien
Global Integer GDELDEPENSES      : # Utilisé lors de la suppression d'un bien avec GNBDEPLIEES>0 :
                                   #    =G_NON : Les dépenses liées seront détachées
                                   #    =G_OUI : Les dépenses liées seront supprimées
Global Integer GDDABOK           : # Utilisé lors de la suppression d'un bien avec GNBDEPLIEES>0 :
                                   #    =G_NON : on a cliqué sur FIN, donc pas de suppression du bien
                                   #    =G_OUI : on a cliqué sur OK, donc les dépenses sont détachées
                                   #             et on supprime le bien

Global Integer GSUPOK            : # Utilisé lors de la suppression pour traiter les lock en cas d'échec
                                   #    =0     : Pas de suppression
                                   #    =G_NON : Echec suppression
                                   #    =G_OUI : Suppression Ok
Global Integer GMODOK            : # Utilisé lors de la modification pour traiter les lock en cas d'échec
                                   #    =0     : Pas de suppression
                                   #    =G_NON : Echec suppression
                                   #    =G_OUI : Suppression Ok
Global Decimal GCPLDURPRC        : # Bien complémentaire % Durée d'amortissement
Global Decimal GCPLDURMIN        : # Bien complémentaire Durée d'amortissement minimum
Global Integer GACCCOD_ASSO      : # G_NON si le code comptable est déterminé par association, G_OUI sinon
Global Integer G_ARECALCULER     : # Indicateur bien à recalculer (1 ou 0)
Global Integer G_CHARGE_PCG      : # La nature du compte comptable change et passe à charge.
Global Integer G_CHARGE_IAS      : # La nature de l'imputation IAS change et passe à charge.
Global Integer GFLGASS           : # Indicateur association appliquée (G_NON ou G_OUI)

Global Integer G_AASBUS          :  # Indicateur appel AM_AASBUS par call

Global Integer G_DEFORCE         : # Indicateur zone déforcée (G_NON ou G_OUI)
Global Integer GIBIENCIG         : # Indicateur bien présent dans CIG
Global Integer GMODENAFAS        : # Indicateur modification du flag Actif  :
                                   # =0 : pas de modification
                                   # =1 : de "Inactif" en "Actif"
                                   # =2 : de "Actif" en "Inactif"
Global Integer G_TUNNEL_PHY      : # flag tunnel depuis les éléments physiques
Global Integer G_SAV_CONSULT     : # sauvegarde de la variable globale GCONSULT
If dim(G_MODIF_LOC) <= 0
  Global Integer G_MODIF_LOC       : # Variable globale pour savoir s'il n'y a que la localisation de modifiée pour générer l'évènement que sur les éléments physiques
Endif
# Variable indiquant si la date de transfert récupérée est :
# - la date du dernier transfert du bien ("B")
# - la date du dernier transfert d'un élément physique rattaché au bien ("T")
# - la date de réception d'un élément physique rattaché au bien ("R")
If dim(G_ORI_TRFDAT) <= 0
  Global Char    G_ORI_TRFDAT
Endif
#49517: Numérotation des éléments physiques à partir du bien
If GPHY = G_OUI Then
  Global Char G_ELEMENTS(GLONPHY)(1..999) # Va servir à stocker les éléments rattachés à un bien
Endif
Global Integer G_NOUVEAU_BIEN     # Mis à G_OUI quand on change de bien
Global Integer RATT_LEAREF #Fq-65312 - Rattachement d'un contrat
Global Integer DETA_LEAREF #Fq-65312 - Détachement  d'un contrat
Global Integer MOD_LEAREF  #Fq-65312 - Modification réf. contrat
# fin 49517



  # Par défaut AM_AASBUS pas appelé par call
  G_AASBUS = 0
  # Pas de contrôle méthode à priori
  GSUPOK = 0
  # Pas de déforçage en cours
  GSUPOK = 0
  # Pas de suppression par défaut
  GSUPOK = 0
  # Pas de modification par défaut
  GMODOK = 0
  # Pas de changement
  G_CHARGE_PCG    = G_NON
  G_CHARGE_IAS    = G_NON
  G_ARECALCULER   = 0
  RATT_LEAREF  = G_NON #Fq-65312
  DETA_LEAREF  = G_NON #Fq-65312
  MOD_LEAREF   = G_NON #Fq-65312
# Calcul
Local Char        ACALCULER(10)
Local Integer     ERROR

# Autres
Local Integer LERROR
Local Integer REPORT_LEAREF

Local Char    L_COMPTEUR(5), MESSA(80)


  # Gestion tables
  # FQ50972
  # FQ54343
  If ( G_ACTCCN = G_OUI ) Then
    If clalev([F:CCN]) =0    : Local File CONCESSION    [CCN]    : Endif
    If clalev([F:COE]) =0    : Local File CCNCOE        [COE]    : Endif
    If clalev([F:RPR]) =0    : Local File CCNRPR        [RPR]    : Endif
  Endif

  If clalev([F:FAS]) =0    : Local File FXDASSETS     [FAS]    : Endif
  If clalev([F:FASW])=0    : Local File FXDASSETS     [FASW]   : Endif
  If clalev([F:WFCY])=0    : Local File FACILITY      [WFCY]   : Endif
  If clalev([F:DEP]) =0    : Local File DEPREC        [DEP]    : Endif
  If clalev([F:DEPW])=0    : Local File DEPREC        [DEPW]   : Endif
  If clalev([F:CNX]) =0    : Local File CONTEXT       [CNX]    : Endif
  If clalev([F:SEA]) =0    : Local File SECACT        [SEA]    : Endif  : # secteurs d'activité
  If clalev([F:HFAS])=0    : Local File FXDASSETS     [HFAS]   : Endif
  If clalev([F:HIS]) =0    : Local File VATHIS        [HIS]    : Endif  : # historique Régul. TVA

  If clalev([F:FIS]) =0    : Local File FISCYEAR      [FIS]    : Endif
  If clalev([F:TCA]) =0    : Local File TABCOUAFF     [TCA]    : Endif
  If clalev([F:ADI]) =0    : Local File ATABDIV       [ADI]    : Endif
  If clalev([F:PPH]) =0    : Local File PROPLNH       [PPH]    : Endif
  If clalev([F:PPL]) =0    : Local File PROPLN        [PPL]    : Endif
  If clalev([F:FAS]) =0    : Local File FXDASSETS     [FAS]    : Endif
  If clalev([F:LDA]) =0    : Local File PARLDAP       [LDA]    : Endif : # Paramétrage liaison dépense à bien
  If clalev([F:TZL]) =0    : Local File PARTRZL       [TZL]    : Endif : # Paramétrage transite zones
  If clalev([F:TZD]) =0    : Local File PARTRZLDET    [TZD]    : Endif : # Paramétrage transit zones détail
  If clalev([F:LOF]) =0    : Local File LAYOUTFAS     [LOF]    : Endif : # Table des dépenses
  If clalev([F:LOFP])=0    : Local File LAYOUTFAS     [LOFP]   : Endif : # Table des dépenses pour la dépense principale
  If clalev([F:ATZ]) =0    : Local File ATABZON       [ATZ]    : Endif : # dictionnaire des champs de table
  If clalev([F:ATY]) =0    : Local File ATYPE         [ATY]    : Endif : # Types de données
  If clalev([F:ADW]) =0    : Local File ADOVAL        [ADW]    : Endif : # Valeur des paramètres
  If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

  If G_ACTCIG = G_OUI
    If clalev([F:CIB]) =0    : Local File CIGFXDSOR     [CIB]    : Endif : # Biens sortis CIG
    If clalev([F:CIG]) =0    : Local File CIGDEF        [CIG]    : Endif : # Définition CIG
  Endif
  If G_ACTLEA=G_OUI # FQ117828
    If clalev([F:LEA]) =0    : Local File LEASE     [LEA]    : Endif
  Endif

  # --------------------------------
  # Ouverture de l'écran d'immobilisation des dépenses
  Local Mask LOFLDAB [LOF6]
  FAS_DEF_MASK += ","+dbgstr(1)
  # --------------------------------
  # --------------------------------
  # Ouverture de l'écran pour contrôler la méthode
  Local Mask METH [METH]
  FAS_DEF_MASK += ","+dbgstr(1)
  # --------------------------------


  #******************************
  #=> Liste des actions métiers

  #> Suppression des globales si elles existaient déjà à cause d'un plantage par exemple.
  If dim(LIS_ACT)>0  : Kill LIS_ACT  : Endif
  If dim(LIS_NAM)>0  : Kill LIS_NAM  : Endif
  If dim(LIS_TYP)>0  : Kill LIS_TYP  : Endif
  If dim(G_TRSSAV)>0 : Kill G_TRSSAV : Endif

  Global Char LIS_ACT(1)(20)
  Global Char LIS_NAM(15)(20)
  Global Char LIS_TYP(1)(20)

  LIS_ACT(0) ="X"   : # Transfert géographique & analytique
  LIS_ACT(1) ="Z"   : # Sortie d'actif
  LIS_ACT(2) ="R"   : # Transfert comptable
  LIS_ACT(3) ="T"   : # Changement de méthode
  LIS_ACT(4) ="V"   : # Réévaluer
  LIS_ACT(5) ="G"   : # Eclater # F100927 W à G
  LIS_ACT(6) ="U"   : # Actualiser
  LIS_ACT(7) ="4"   : # Détacher
  LIS_ACT(8) ="L"   : # Déprecier
  LIS_ACT(9) ="Y"   : # Changer information biens en concession
  LIS_ACT(10)="S"   : # T.V.A.

  Local Integer RCOD
  Call GET_WIN_BOUT(GBOITE,LIS_ACT,LIS_NAM,LIS_TYP,RCOD) From TRUPROACT

  #=> Fin liste des actions métiers
  #********************************

  #=> Globale contenant le nom de la transaction en cours pour exploitation dans les actions métiers
  Global Char G_TRSSAV : G_TRSSAV=GBOITE


  # Pour suppression bien comptable
  Gosub OUVRE_TABLES From SUBFASCNL
  # Particularités polonaises
  If G_ACTKPL=G_OUI : Gosub OUVRE_TABLES From SUBFASKPL : Endif

Return

##########################################################################################################
$BOITE
  # FQ119322
  # Pas en webservice et en import
  If (GPHY = G_OUI and !GIMPORT & !(dim(GWEBSERV) = 1 & GWEBSERV = 1)) Then
    Assign "[G:"+ABFIC+"]currind" With INDCUR
    Assign "[G:"+ABFIC+"]currlen" With 0
    If MENFON<>"" : OGFONCTION=GFONCTION : GFONCTION=MENFON : Endif
    # -----------------------------------------
    Gosub INIT_BOITE From =WINPROG
    #
#    If !clalev([F:XPHY])  : Local File PHYELT     [XPHY]  : Endif
#    If !clalev([F:XMVT])  : Local File PHYMVT     [XMVT]  : Endif
#    Link [FAS] With
#&      [F_AS]FAS2 = [F:FAS]CPY;[F:FAS]FCY;[F:FAS]AASREF,
#&      [XPHY]PHY5(1)~=[F:FAS]AASREF,
#&      [XMVT]PMVT0~=[F:XPHY]PHYREF
#&   As [FA5]
    If !clalev([F:FASPMVT])  : Local File FASPHYMVT     [FASPMVT]  : Endif
    Link [FAS] With
&      [F_AS]FAS2 = [F:FAS]CPY;[F:FAS]FCY;[F:FAS]AASREF,
&      [FASPMVT]FASPMVT0~=[F:FAS]AASREF
&   As [FA5]
    #
    # -----------------------------------------
    Gosub DEF_BOITE From =WINPROG
    Gosub AFF_BOITE From =WINPROG
    # -----------------------------------------
    If MENFON<>"" : GFONCTION=OGFONCTION : Endif
    OK = 0
  Endif
Return

#-------------------------------------------------------------------------------
$OUVRE_BOITE
  Gosub DECLARE_TIROIRS
  Gosub RAZ_PICKING From FUNLOFLDAB
Return

#-------------------------------------------------------------------------------
$DECLARE_TIROIRS
  # Récupération des positions des tiroirs en fonction de leurs noms et
  # affectation dans des variables locales
  Local Char LTI_FASCMP  : LTI_FASCMP  = 'GAU_CHE'+num$(find('FA2',OBJLIS(1..10))) : # Biens composants
  Local Char LTI_FASSET  : LTI_FASSET  = 'GAU_CHE'+num$(find('FA1',OBJLIS(1..10))) : # Biens de l'ensemble
  Local Char LTI_DEPIMMO : LTI_DEPIMMO = 'GAU_CHE'+num$(find('LO2',OBJLIS(1..10))) : # Dépenses immobilisables
  Local Char LTI_DEPLIEE : LTI_DEPLIEE = 'GAU_CHE'+num$(find('LO1',OBJLIS(1..10))) : # Dépenses regroupées
  Local Char LTI_FASISS  : LTI_FASISS  = 'GAU_CHE'+num$(find('FA3',OBJLIS(1..10))) : # Biens sortis
  Local Char LTI_FASDIS  : LTI_FASDIS  = 'GAU_CHE'+num$(find('FA4',OBJLIS(1..10))) : # Biens inactifs
  If GPHY = G_OUI Then
     Local Char LTI_FASPHY  : LTI_FASPHY  = 'GAU_CHE'+num$(find('FA5',OBJLIS(1..10))) : # Biens avec élément physique en attente
  Endif
Return

#-------------------------------------------------------------------------------
$VERROU
Local Char LLOCK(200)

  # Pour interdire toute modification sur l'objet
  LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([M:FAS0]AASREF)
  If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:FAS0]CPY, LLOCK) = 0 ) Then
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    OK = 0
    Return
  Else
    # sinon on gère à la main le verrou identifiant+société pour permettre le contrôle
    # de tester si le lockage de la table pour la société est possible
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("FAS", [M:FAS0]CPY, LLOCK, 0) = 0 Then
      # on teste rien, normalement ça marche puisqu'on a pu locker l'enregistrement
      # et que la société n'est pas lockée
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$DEVERROU
Local Char LLOCK(200)

  LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([M:FAS0]AASREF)
  Call UNLOCK_SYMBOLE_CPY ("FAS", [M:FAS0]CPY, LLOCK) From GLOBIENS

  # La supression s'est passé correctement
  If ( GSUPOK = G_OUI ) Then
    # L'indicateur passe à "Pas de suppression"
    GSUPOK = 0
    # Suppression de tous les verrous posés lors de la suppression
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
  Endif

  # La modification s'est passé correctement
  If ( GMODOK = G_OUI ) Then
    # L'indicateur passe à "Pas de suppression"
    GMODOK = 0
    # Suppression de tous les verrous posés lors de la suppression
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
  Endif
Return

#-------------------------------------------------------------------------------
$AVANT_MOD

  # Un bien comptable sorti ne peut pas être modifié
  If ( [M:FAS0]ENAFAS = G_OUI ) Then
    If ( [M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]EXTISSFLG = G_NON ) Then
      # Test si le bien est sortie réellement (flag prévisionnel non positionné )
      GERR=1 : GMESSAGE = mess(50,GML_MSGFAS,1)
      OK=0
    Endif
  Endif

  # Un bien présent dans une cession intra-groupe ne peut pas être modifié
  If G_ACTCIG = G_OUI
    Gosub TEST_BIEN_DS_CIG
    If ( GIBIENCIG = G_OUI ) Then
      GERR= 1 : GMESSAGE= mess(536,GML_MSGFAS, 1) - [F:CIB]CIGCOD : OK = 0
    Endif
  Endif

  # FQ70465
  If func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY, 0) = G_OUI
    GERR=1 : GMESSAGE = func GLOFUNC.SUBSTIT1(mess(272,GML_MSGFASPR,1), [M:FAS0]CPY)
    OK=0
  Endif
Return

#=====================================================================
$APRES_MODIF

  #--------------------------
  If GREP = "C" Then
    If func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:FAS0]CPY, "?¤") = 0 Then
      # Test si la société est verrouillée sur cette table pour empêcher la création du bien
      # Obligé de mettre n'importe quoi("?¤") dans l'identifiant parce que sinon ça demande si c'est
      # la société qui est lockable, et si quelqu'un est dessus ça refuse.
      OK        = 0
      GMESSAGE  = G_MSGQUILOCK
      Return
    Endif
  Endif
  #--------------------------
  If (( COUZON = "SET" or COUZON = "CMP") and [M:FAS0]FLGDSP = "2") Then
    CLECUR1 = [M:CPY0]CPY
    Gosub RELIT From GOBJSUB
    [M:FAS0]FLGDSP = ""
    # Pour interdire la modification et courtcircuiter mkstat = 4
    OK = 0
  Endif
  #--------------------------
  If ( currbox = LTI_DEPIMMO ) Then
    Gosub REMPLIT
  Endif
  If zoncou = "FCY" : zonsui = "[M:FAS0]AASREF" : Endif

  If (G_DEROUTE <> "") Then : zonsui = G_DEROUTE : G_DEROUTE = "" : Endif

Return
#=====================================================================
$SETBOUT
# doc : BGOUVYZ0123456789 : à utiliser

# Activation menu Actions
# Menu B Actions
#        Option R Changer l'imputation comptable
#        Option T Changer de méthode
#        Option V Réévaluer
#        Option L Dépréciation
#        Option U Actualiser
#        Option G Eclater # FQ100927
#        Option S Changer la règle de TVA
#        Option Y Changer attributs concession
#        Option K Arrêter/redémarrer
# Menu G Mouvements
#        Option X Transférer analytique
#        Option Z Sortir
# Menu O Options
#        Option I Assurance
#        Option N Véhicule
#        Option M Valeur marché
#        option E Evénement
#        Option Q Eléments physiques
#        Option C Traçabilité pièces   # FGR 17/10/2012 :X3SUIVI81498
Local Char LKEY(200)
# Fiche 48468 : éléments physiques
Local Integer I, WBOPTION # FQ96303
Local Integer NBLOF
Local Integer COME_FROM_ELT
  # Désactivation des actions
  # -- Changer de clé
  Call VIREBOUT(CHAINE,"H") From GOBJET
  # -- Dupliquer
  Call VIREBOUT(CHAINE,"D") From GOBJET
  WBOPTION = 0 # FQ96303

  # FGR 17/10/2012 : X3SUIVI81498 (début)
  If GREP = "" Then
    CHMEN += "C"
  Endif
  # FGR 17/10/2012 : X3SUIVI81498 (fin)

  #Fq-81004
  If GNBDEPLIEES > 0
    CHMEN += "INMEU"
  Else
    CHMEN += "INME"
  Endif #Fq-81004

  #Fq-81004CHMEN += "INME"
  # FQ96303
  If mkstat = 4 and GREP = ""
    WBOPTION = 1
  Endif

  If GPHY = G_OUI Then
     CHMEN += "Q"
     Actzo [M:FAS0]FLGELT # on initialise le bouton élément physique
     # Grisage des éléments physiques si on vient d'une action métier
     # Sur un bien composant si le bien principal n'a pas d'élément rattaché : on supprime l'accés à la fenêtre élément physique
     # Sur un bien principal qui n'a pas d'élément rattaché et qui a des composants : on supprime l'accés à la fenêtre élément physique
# FQ100398/13 : suppression ctle/LOC
# FQ110211
     If ( (GREP="M" or GREP="C" ) and find(BOUT,"R","T","V","L","G","X","Z") <> 0 )
#&    or ([M:FAS1]CMP <> "" and func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:FAS1]CMP +"'") = 0)
#&    or ([M:FAS1]CMPSTA = GVML_SBPRINC and [M:FAS8]NBPHY = 0) Then
        Call VIREBOUT(CHMEN,"Q") From GOBJET
        Diszo [M:FAS0]FLGELT
     Endif
  Endif
  # Gestion actions objets métiers
  # Pour chaque action métier, ajouter une occurrence dans LIS_ACT
  # Ecrire la condition d'activation du bouton dans le traitement
  # TRT+nomAction dans l'étiquette CRITMEN de ACTMET en alimentant
  # la variable CRITMEN
  If ( dim(LIS_ACT1) < 0 ) Then
    Local Char LIS_ACT1(15)(20)
  Endif
  Gosub ACTION From TRTOBJACT                                      #=> Modèle action unitaire V1
  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2

  #FQ97872  If GREP="" and [M:FAS0]AASREF=""
  If ( GREP="" and [M:FAS0]AASREF="" ) or ( [M:FAS4]ISSDAT <> [0/0/0] )
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
    Call VIREBOUT (CHAINE, "4") From GOBJET   : # Détacher
  Endif

  If (GREP <> "C" ) and ( GLOFPREAD = G_NON ) Then
        # Si on n'est pas en création et que la dépense principale n'est pas lue on ne peut pas immobiliser
        # sauf si le bien n'est pas valorisé (valeur entrée PCG = 0 et valeur entrée IAS = 0 si l'IAS est géré)
        If (  [M:FAS1]ACGETRNOT <> 0 or ( G_PLNIAS and [M:FAS1]IASETRNOT <> 0 )  ) Then
           Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
        Endif
  Endif

  If (GREP <> "C" and (GKFR = G_OUI and [M:FAS5]VATYEAFLG = G_OUI)) Then : # FQ57624
    # Si on n'est pas en création et que le bien a subi une régularisation de TVA annuelle on ne peut pas immobiliser
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
  Endif

  # FQ 59177 - En création ou modification, une fois que des dépenses ont été appliquées on
  #            ne peut plus cliquer sur Immobiliser
  If GLDABAPPL = G_OUI
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
  Endif

  # FQ68568 - On ne peut pas cliquer sur Immobiliser si on n'a pas les droits de modification
  If GREP = "" and !func GLOBIENS.AUTORIS_OPT([M]FCY,"M")
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
  Endif

  If ((GREP = "M" and [M:LOF6]NBDEST > GNBDEPLIEES and GNBDEPLIEES > 0)
&    or (GREP = "C" and [M:LOF6]NBDEST > 0)) and GLDABAPPL = G_NON Then
    # SI on est en modif et qu'il y a plus d'une dépense sélectionnée (ds ce cas la 1ère est la principale)
    # OU si on est en création et qu'il y a au moins une dépense de sélectionnée
    # ET qu'on n'a pas déjà appliqué : on peut appliquer
  Else
    # Sinon on ne peut pas !
    Call VIREBOUT (CHAINE, "2") From GOBJET   : # Appliquer
  Endif

  If ( GREP <> "" or [M:FAS0]ENAFAS <> G_OUI ) Then
    # Le bouton "Calculer" lit et enregistre des informations dans la base.
    # Cela suppose donc que les informations soient stables. Il n'est donc accessible qu'en mode VISU
    Call VIREBOUT (CHAINE, "3") From GOBJET   : # Calculer
    Call VIREBOUT (CHAINE, "5") From GOBJET   : # Simulation
  Endif

  # FQ66599 le bouton "Calculer" n'est accessible que si le bien n'est pas sorti
  If ([M:FAS4]ISSDAT <> [0/0/0] and GUSER <> "MWA" and GUSER <> "CBO" and GUSER <> "CFF" ) Then
    Call VIREBOUT (CHAINE, "3") From GOBJET   : # Calculer
  Endif

  # Si on n'est pas en création et que le bien n'est pas sorti
  # L'option Arrêter/rémarrer amortissement est disponible
  If ( ([M:FPC]LEG = "RUS" or (G_ACTDRO = G_OUI and [M:FPC]LEG="RUM") )
&    and GREP <> "C" and GREP<>"M" and [M:FAS4]ISSDAT = [0/0/0]
&    and func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY, 0)<>G_OUI) Then : # FQ70465 FQ72093 FQ80825
      CHMEN+="K"
  Endif

  If ( [M:FAS0]AASREF <> "" ) Then
    # Pour désactiver les actions lorsque le bien est locké ailleurs
    LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([M:FAS0]AASREF)
    If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:FAS0]CPY, LKEY) = 0 ) Then
      # Il est verrouillé ailleurs : on ne peut pas le calculer, délier et immobiliser
      Call VIREBOUT (CHAINE, "3") From GOBJET   : # Calculer
      Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
      If GPHY = G_OUI Then
         # Grisage des éléments physiques si le bien est verrouillé ailleurs
         Call VIREBOUT(CHMEN,"Q") From GOBJET
         Diszo [M:FAS0]FLGELT
      Endif
      #Fq59941
      If G_ACTKRU=G_OUI
       Call VIREBOUT(CHMEN,"K") From GOBJET  : # Arrêter / Redémarrer
      Endif
      Call VIREBOUT(CHMEN,"INM") From GOBJET  : # Assurance / Véhicule / Valeur marché


    Endif
  Endif

  If ( GREP = "M" ) Then
    # Si on est en modif, et que le bouton "Détacher" n'est pas actif, c'est parce qu'on est
    # en détachement de dépenses. On ne peut donc que enregistrer ou abandonner.
    # Il faut donc griser le bouton "Immobiliser" aussi.
    Gosub CRITMEN From TRTFASDDE
    If AUTORISE = G_NON Then
      Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
    Endif
  Endif

  # Si le bien est sorti dans un exercice antérieur et ceci pour tous les contextes
  # le calcul et la simulation sont interdits.
  If ( [M:FAS4]ISSDAT <> [0/0/0] ) Then
    Local Integer L_ERROR : L_ERROR = 0
    If ( [M:FAS1]OWNTYP <> GVML_TDCONCE ) Then
      Call IS_SORTI_EX_ANTERIEUR( [M:FAS0]CPY, [M:FAS4]ISSDAT, 2, L_ERROR ) From TRTFAS
    Else
      If ( [M:FAS0]ISSFIYPRE = G_OUI ) Then
        L_ERROR = 1
      Endif
    Endif
    If ( L_ERROR ) Then
      Call VIREBOUT (CHAINE, "3") From GOBJET   : # Calculer
      Call VIREBOUT (CHAINE, "5") From GOBJET   : # Simulation
      Call VIREBOUT (CHMEN,"G")   From GOBJET   : # Eclater               #X3-98903
      Call VIREBOUT (CHMEN,"S")   From GOBJET   : # Changer la règle TVA  #X3-98903
      Call VIREBOUT (CHMEN,"X")   From GOBJET   : # Transférer analytique #X3-98903
      Call VIREBOUT (CHMEN,"Z")   From GOBJET   : # Sortir                #X3-98903
    Endif
  Endif

  # Le bouton Immobiliser n'est pas accessible si le bien a subi une sortie réelle.
  If ( [M:FAS4]ISSDAT<>[0/0/0] and [M:FAS4]EXTISSFLG = G_NON ) Then
    Call VIREBOUT (CHAINE, "1") From GOBJET   : # Immobiliser
  Endif

  # Si le bien est annulé le calcul et la simulation sont interdits pour tous les contextes de sa société.
  If ( [M:FAS1]OWNTYP = GVML_TDANNUL ) Then
    Call VIREBOUT (CHAINE, "3") From GOBJET   : # Calculer
    Call VIREBOUT (CHAINE, "5") From GOBJET   : # Simulation
  Endif

  # Si on a trouvé une nouvelle ligne d'élément physique ou une annulation d'attente ou un détachement, on désactive
  # le menu transfert et sortie
  Local Integer WINDICE
  WINDICE =0
  If GPHY = G_OUI Then
    WINDICE = find(G_OUI, [M:FAS8]FLGMODIF(0..[M:FAS8]NBPHY-1)) + find(G_OUI, [M:FAS8]SUPATTENTE(0..[M:FAS8]NBPHY-1))
&         + find(G_NON, [M:FAS8]RATTACHE(0..[M:FAS8]NBPHY-1))

    If WINDICE <> 0  Then
      Local Char WPHYREF(GLONPHY)
# Pour ne pas géner le zonsui aprés la validation "OK", on ne fait le affzo que si FLGELT change de valeur
      If func PHYELT_C_MPR._GET_SELECTED_MVT_PHY_NBR("[F:PHY]AASREF = '" + [M:FAS0]AASREF + "'") > 0
         If [M:FAS0]FLGELT <> GICOATTENTE Then
            [M:FAS0]FLGELT = GICOATTENTE
            Affzo [M:FAS0]FLGELT
         Endif
      Else
         If [M:FAS0]FLGELT <> GICOATTACHE Then
            [M:FAS0]FLGELT = GICOATTACHE
            Affzo [M:FAS0]FLGELT
         Endif
      Endif

# Fin FQ49517
      Call VIREBOUT(CHMEN,"X") From GOBJET  : # Transférer analytique
      Call VIREBOUT(CHMEN,"Z") From GOBJET  : # Sortir
    Endif
  # On grise le menu Eclater si on n'a qu'un seul élt physique rattaché, et moins de deux dépenses
  # On le grise également si on est en train de modifier les élts physiques rattachés

    I = func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:FAS0]AASREF + "'")
    If I=1 Then
    Elsif REP='M' Then
      If ([M:FAS8]NBPHY > 0) and ( clalev([M:FASP]) ) Then
        COME_FROM_ELT=G_NON
        For I=0 To [M:FAS8]NBPHY-1
          If [M:FASP]FLGLOCK(I) = G_OUI Then
            COME_FROM_ELT=G_OUI
            Break
          Endif
        Next
        If COME_FROM_ELT=G_OUI Then
          Call VIREBOUT(CHMEN,"G") From GOBJET  : # Eclater
        Endif
      Endif
    Endif
    # Si Bien comptable sorti à une date antérieure à la date de début d'exercice du contexte comptable & fiscal
    # On grise le menu transfert comme dans les éléments physiques (avant on mettait un message)
    If [M:FAS4]EXTISSFLG=G_NON & [M:FAS4]ISSDAT<>[0/0/0] # Bien sorti
      Call VIREBOUT(CHMEN,"X") From GOBJET  : # Transférer
    Endif

    If G_TUNNEL_PHY = G_OUI Then    #si l'on vient d'un tunnel des éléments physiques on désactive les boutons.
       Call VIREBOUT(CHAINE, "1") From GOBJET   : # Immobiliser
       Call VIREBOUT(CHAINE, "2") From GOBJET   : # Appliquer
       Call VIREBOUT(CHAINE, "3") From GOBJET   : # Calculer
       Call VIREBOUT(CHAINE, "5") From GOBJET   : # Simulation
       # Menu B Actions
       Call VIREBOUT(CHMEN,"R") From GOBJET   # Changer l'imputation comptable
       Call VIREBOUT(CHMEN,"T") From GOBJET   # Changer de méthode
       Call VIREBOUT(CHMEN,"V") From GOBJET   # Réévaluer
       Call VIREBOUT(CHMEN,"L") From GOBJET   # Dépréciation
       #Call VIREBOUT(CHMEN,"U") From GOBJET  # Actualiser
       Call VIREBOUT(CHMEN,"G") From GOBJET   # Eclater
       Call VIREBOUT(CHMEN,"S") From GOBJET   # Changer la règle TVA
       If ( G_ACTCCN = G_OUI ) Then
         Call VIREBOUT(CHMEN,"Y") From GOBJET   # Changer attributs concession
       Endif
       If ( G_ACTKRU = G_OUI) Then
         Call VIREBOUT(CHMEN,"K") From GOBJET   # Arrêter / Redémarrer
       Endif
       # Menu G Mouvements
       Call VIREBOUT(CHMEN,"X") From GOBJET   # Transfert géographique
       Call VIREBOUT(CHMEN,"Z") From GOBJET   # Sortie
       # Menu O Options
       Call VIREBOUT(CHMEN,"I") From GOBJET   # Assurance
       Call VIREBOUT(CHMEN,"N") From GOBJET   # Véhicule
       Call VIREBOUT(CHMEN,"M") From GOBJET   # Valeur marché
       Call VIREBOUT(CHMEN,"E") From GOBJET   # Evénement
       Call VIREBOUT(CHMEN,"Q") From GOBJET   # Eléments physiques
    Endif
  Endif

  #FQ54343-Gestion du bouton "annulation du renouvellement"
  #Gosub SETBOUTCAN From TRTCCNRNW


  #Fq-49627 Si on vient d'immobiliser des dépenses : on recalcule le coff de déduction
  If ( GREP = "C"  and  GNBDEPLIEES > 0 ) Then
    Local Decimal TXTVAREC
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
    [M:FAS1]DEDCOE = TXTVAREC : Affzo [M:FAS1]DEDCOE
    TXTVAREC = TXTVAREC * 100.
    If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
      [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
      If (GCNXPROIAS = G_OUI) Then
        [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
      Endif
      Gosub CALCUL_MONTANTS_TVA
    Endif
  Endif

  If func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY, 0) = G_OUI : # FQ70465
   Call VIREBOUT(CHAINE, "1") From GOBJET   : # Immobiliser
   Call VIREBOUT(CHAINE, "2") From GOBJET   : # Appliquer
   Call VIREBOUT(CHAINE, "3") From GOBJET   : # Calculer
   Call VIREBOUT(CHAINE, "4") From GOBJET   : # Détacher
   Call VIREBOUT(CHAINE, "5") From GOBJET   : # Simulation
   Call VIREBOUT(CHAINE, "A") From GOBJET   : # Supprimer
  Endif

  Gosub SET_BOUT_SPE From GSAISIE

  # FQ96303
  If WBOPTION
    GREP = "M"
  Endif
  #Fq61295-Rend le champ référence inacessible lorsque le bien est en modification.
  If GREP="M"
   Grizo [M:FAS0]AASREF
  Else
   Actzo [M:FAS0]AASREF
  Endif
  #Affzo [M:FAS0]AASREF : # FQ63459 : pas utile ici

Return

#=====================================================================
$AVANTBOUT
  Local Integer LOK
  # Fiche 48468 : éléments physiques
  Local Integer G_HAS_ELT_PHY
  # Ouverture des masques de la fenêtre d'une action métier
  Case BOUT
    When "1"        : # Immobiliser
      # FQ69636
      If ( GREP = "C") and (( ACGETRNOT <> 0 ) or (G_ACTIAS and IASETRNOT <> 0))
        # si le bien est valorisé en création et que l'utilisateur clique sur "Immobiliser" -> message d'erreur
        # "Il n'est pas possible d'immobiliser des dépenses sur un bien valorisé"
        GERR     = 1
        GMESSAGE = mess(817,GML_MSGFAS,1)
        Return
      Endif
      If ( GREP = "" ) Then
        REP = "M"
      Endif
    When "2"        : # Appliquer
      Gosub CTRL_LDAB From FUNLOFLDAB
    When "4"        : # Détacher
      If ( func GLOBIENS.GET_NB_LOF_ON_FAS([M:FAS0]AASREF) = 1 ) Then
        # s'il n'y a qu'une seule dépense on ne peut pas détacher
        GERR     = 1
        GMESSAGE = mess(279,GML_MSGFAS,1)
        Call VIREBOUT (CHAINE, "4") From GOBJET   : # Détacher
        Return
      Endif
    When Default
  Endcase

  # Gestion actions objets métiers
  If ( dim(LIS_ACT1) < 0 ) Then
    Local Char LIS_ACT1(15)(20)
    LIS_ACT1(0)="G"  : # Eclater
    LIS_ACT1(1)="4"  : # Détacher
    LIS_ACT1(2)="U"  : # Actualiser
  Endif

  # Gestion interaction des écrans options et des actions (voir fin_action)
  # --> sauvegarde contenu et fermeture sytèmatique des écrans
  # Menu O Options
  #        Option I Assurance
  #        Option N Véhicule
  #        Option M Valeur marché
  #        Option Q Eléments physiques
  #        Option K Arrêter / Redémarrer
  #-1 -----------------------------------

  If ( find(BOUT, "I","N","M","Q","K") ) Then # Fiche 48468 : "P" remplacé par "Q"
    If (clalev([M:FASC])) Then
      Local Mask FASTRFC  [XASC]
      [M:XASC]=[M:FASC]
    Endif
    If (clalev([M:FASM])) Then
      Local Mask FASMTC  [XASM]
      [M:XASM]=[M:FASM]
    Endif
    If (clalev([M:FASR])) Then
      Local Mask FASRVA  [XASR]
      [M:XASR]=[M:FASR]
    Endif
    If (G_ACTCCN = G_OUI and clalev([M:FASY])) Then
      Local Mask FASCCN  [XASY]
      [M:XASY]=[M:FASY]
    Endif
    If (clalev([M:IML1])) Then
      Local Mask FASIML1 [XASI]
      [M:XASI]=[M:IML1]
    Endif
    If (clalev([M:FASG])) Then
      Local Mask FASRGGP  [XASG]
      [M:XASG]=[M:FASG]
    Endif

# FQ92129 ce masque n'existe plus
# si plantage : ouvrir avec [FASY] le masque FASCCN ?
#    If ( clalev([M:FASY]) = 0 ) Then : Local Mask FASIVY [FASY] : Endif
    # Fenêtre des éléments physiques
    If GPHY = G_OUI Then
       If !clalev([M:FASP])Then : Local Mask FASPHY [FASP] : Endif
    Endif
  Endif
  #-1 -----------------------------------
  If (clalev([M:FASC])) Then : Close Mask [FASC] : Endif
  If (clalev([M:FASM])) Then : Close Mask [FASM] : Endif
  If (clalev([M:FASR])) Then : Close Mask [FASR] : Endif
  If (G_ACTCCN = G_OUI and clalev([M:FASY])) Then : Close Mask [FASY] : Endif
  If (clalev([M:FASI])) Then : Close Mask [FASI] : Endif

  # Ouverture selon boutons actions
  If (BOUT = "R") Then
    Local Mask FASTRFC [FASC]
  Endif
  If (BOUT = "T") Then
    Local Mask FASMTC  [FASM]
  Endif
  If (BOUT = "V") Then
    Local Mask FASRVA  [FASR]
  Endif
  If (G_ACTCCN = G_OUI and BOUT = "Y") Then
    Local Mask FASCCN  [FASY]
  Endif
  If (BOUT = "L") Then
    # Saisie parametrage dépréciation non affiché si calcul société non effectué
    Call TOUS_PLANS_CALCULES ( LOK )
    If ( LOK = 2 ) Then
      # Opération impossible : Aucun plan n'est normé IAS/IFRS ou CRC2002_10
      GMESSAGE = mess(628,GML_MSGFAS,1)
      FIN=1
      Return
    Endif
    If ( LOK = 1 ) Then
      # Dépréciation impossible car aucun calcul société réalisé pour les plans normés de la société
      GMESSAGE = mess(499,GML_MSGFAS,1)
      FIN=1
      Return
    Endif
    Local Mask FASIML1 [IML1]
   Endif

  If (BOUT = 'G') and GPHY = G_OUI  Then  # si l'on clic sur éclater et que l'on gére les éléments physiques F102319

    # FQ100398/13
    If func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [M:FAS0]AASREF + "'") > 0
      G_HAS_ELT_PHY = G_OUI
      ACTION='AVANTBOUT_E'
    Else
      G_HAS_ELT_PHY = G_NON
    Endif
  Endif

  Gosub ACTION From TRTOBJACT     # Modèle action unitaire V1
  Gosub SETMASK From GOBJET

Return
#***********************************************
Subprog TOUS_PLANS_CALCULES ( LRET )
#
#    Objet  : Ce sous-programme détermine si tous les plans normés gérés
#             par la société ont été calculés
#
#    Sortie : LRET = 0 (calculés)
#                  = 1 (au moins un plan non calculés)
#
Variable Integer LRET

Local Integer N_I             : # N° du plan
Local Integer LCONTEXT        : # Contexte du plan
Local Integer I_PLN           : # Indice du plan dans la table CONTEXT
Local Integer BNORME          : # Booleen au moins un plan normé


  BNORME = 0      : # Au moins un plan normé
  LRET   = 0      : # Par défaut tous les plans calculés

  #>>>>>>>>>>>>>>>>>>
  # Pour chaque plan potentiel
  For N_I=1 To G301MAX-1
    # Contexte du plan
    Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, N_I, LCONTEXT) From GLOBIENS
    If ( LCONTEXT > 0 ) Then
      # Lecture du contexte
      Read [CNX]CNX0=[M:FAS0]CPY;LCONTEXT
      # Indice du plan dans la table CONTEXT
      I_PLN = find(N_I,[F:CNX]PLNCAA)
      # Le plan est-il géré ?
      If ( I_PLN <> 0 ) Then
        # Si le plan est géré
        If ( [F:CNX]PLNSTD(I_PLN-1) = GVML_NPCRC or [F:CNX]PLNSTD(I_PLN-1) = GVML_NPIAS ) Then
          BNORME = 1 : # Au moins un plan normé
          # Récupération dates fin exercice courant & fin de la période courante
          Local Date    WDDATE(1..5)
          Local Integer LRETOUR
          Call GET_CNX_DAT([M:FAS0]CPY, LCONTEXT, WDDATE, LRETOUR) From GLOBIENS
          # Le plan a-t'il été calculé ?
          Read [DEP]DEP0=[M:FAS0]AASREF;N_I;WDDATE(2);WDDATE(4)
          If ( [F:DEP]DEPSTA <> GVML_SCCAL ) Then : LRET = 1 : End : Endif
        Endif
      Endif
    Endif
  Next N_I
  #<<<<<<<<<<<<<<<<<<<
  If !(BNORME) Then
    LRET = 2
  Endif

End


#-------------------------------------------------------------------------------
$EXEBOUT
  #-------------
  Case BOUT
    When "2"  : # Appliquer
      GREP = SAVREP
      Gosub APPLIQUER_LDAB From FUNLOFLDAB
      GREP = BOUT
      Setmok [M:FAS2] With 0

    When "3"  : # Calculer amortissement
      Call CALCULER_BIEN ([M:FAS0]CPY, [M:FAS0]AASREF, ERROR)  From =G_GLOB
      If ( ERROR = 0 and GIMPORT = 0 ) Then
        Gosub RELIT From GOBJSUB
        # FQ66894
        Call GEN_FLUX_BIEN ([M:FAS0]CPY, [M:FAS0]AASREF, GVML_TXSPRO, ERROR) From TRTFLUX
        If ERROR
          GERR = 1
          Call GERE_MSG_ERREUR_FLUX (ERROR, GMESSAGE) From TRTFLUX
        Endif
        Gosub RELIT From GOBJSUB
      Endif
    When Default
  Endcase
  #-------------
Return

#=====================================================================
$STATUT

  # Saisie sur fenêtre ne passe pas en mode modif si mkstat = 4
  # Il faut le passer manuellement
  Case BOUT
    When "I" : If mkstat=4 & GREP="" REP="M" Endif
    When "N" : If mkstat=4 & GREP="" REP="M" Endif
    When "M" : If mkstat=4 & GREP="" REP="M" Endif
    When "Z" : If mkstat=4 & GREP="" REP="M" Endif
    When "4" : If mkstat=4 & GREP="" REP="M" Endif
    # Eléments physiques ou transfert : Si on a fait OK dans la fenêtre SUBPHY ou de transfert
    When "Q", "X" : If GPHY = G_OUI & mkstat=4 & GREP="" Then
                       REP="M"
                    Endif
  Endcase
Return


#=====================================================================
$FIN_ACTION
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT
  #--------------------------

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2

  # Gestion interaction des écrans options et des actions (voir avantbout)
  # --> récupération contenu dans écran action et fermeture des écrans de sauvegarde
  If (clalev([M:XASC])) Then
    Local Mask FASTRFC  [FASC]
    [M:FASC]=[M:XASC]
    Close Mask [XASC]
  Endif
  If (clalev([M:XASM])) Then
    Local Mask FASMTC  [FASM]
    [M:FASM]=[M:XASM]
    Close Mask [XASM]
  Endif
  If (clalev([M:XASR])) Then
    Local Mask FASRVA  [FASR]
    [M:FASR]=[M:XASR]
    Close Mask [XASR]
  Endif
  If (G_ACTCCN = G_OUI and clalev([M:XASY])) Then
    Local Mask FASCCN  [FASY]
    [M:FASY]=[M:XASY]
    Close Mask [XASY]
  Endif
  If (clalev([M:XASI])) Then
    Local Mask FASIML1  [IML1]
    [M:IML1]=[M:XASI]
    Close Mask [XASI]
  Endif

  # --> restauration des masques dans la liste des masques par défaut
  Default Mask FAS_DEF_MASK

  #fq54343-Après annulation d'un renouvellement, on relit le bien comptable courant
  If G_ACTCCN=G_OUI & dim(GRNWCAN)>0
   Gosub RELIT From GOBJSUB
   Kill GRNWCAN
  Endif

  # FQ59941 Arrêter / Redémarrer
  If ( G_ACTKRU = G_OUI and BOUT = "K") Then
    If (mkstat = 4 and GREP = "") Then
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
  Endif

Return

#=====================================================================
$RAZCRE

  # Affichage champs masqués
  GDEVFMT = GDEVFMT1(max(find([M:FAS1]ACGCUR,GDEVISE(1..GNBDEV)),1))
  G_CCNFMT = "Nz3:"+GDEVFMT

  If (G_ACTCCN = G_OUI ) Then
    If ( G_CCNRPR = G_OUI) Then
      Affzo [M:FAS6]E_1ACGRPR
      Affzo [M:FAS6]STRRNWVAL
      Affzo [M:FAS6]E_1FISRPR
      Affzo [M:FAS6]E_1RVERPR
      Affzo [M:FAS6]TRFCADCUM
    Endif
  Endif

  # Le bien ne possède pas de composant
  [M:FAS0]LIKCMPFLG = G_NON
  # Le bien est "A calculer"
  [M:FAS0]FLGCLC    = G_OUI
  # FQ54343
  If ( G_ACTCCN=G_OUI ) Then
    If ( G_CCNRPR = G_OUI ) Then
      [M:FAS0]FLGRPRCLC = G_OUI
    Else
      [M:FAS0]FLGRPRCLC = G_NON
    Endif
  Endif

  # Effacement du masque FAS8
  Raz [M:FAS8]

  [M:FAS1]ASJCOE    = 1. : Affzo [M:FAS1]ASJCOE
  [M:FAS1]TAXCOE    = 1. : Affzo [M:FAS1]TAXCOE
  [M:FAS1]TAXCOEFLG = 1  : Affzo [M:FAS1]TAXCOEFLG
  [M:FAS1]ADMCOE    = 1. : Affzo [M:FAS1]ADMCOE
  [M:FAS1]DEDCOE    = 1. : Affzo [M:FAS1]DEDCOE

  # Initialisation des valeurs par défaut
  If ( GIMPORT ) Then
    # Taux de TVA et TVA récupérée PCG
    If dim([M:FAS1]IVCVATRAT)>0 : [M:FAS1]IVCVATRAT = GDEFVATRAT : Endif
    If dim([M:FAS1]IVCVATFLG)>0 : [M:FAS1]IVCVATFLG = G_NON      : Endif
    If dim([M:FAS1]DEDVATRAT)>0 : [M:FAS1]DEDVATRAT = 100.00     : Endif
    If dim([M:FAS1]DEDVATFLG)>0 : [M:FAS1]DEDVATFLG = G_NON      : Endif
  Endif

  # L'initialisation du tableau du plan est implicite
  # L'établissement est reinitialisé puis la rémanence déclenche un am_fcy

  Gosub RAZ_PICKING From FUNLOFLDAB
  GNBDEPLIEES = 0
  GMODENAFAS  = 0
  # Fiche 48468 : Initialisation du flag tunnel depuis les éléments physiques
  G_TUNNEL_PHY = G_NON
  # Affectation des champs si IAS non géré
  If !(G_PLNIAS) Then
    Call ACTION_BLOCK(ACB_EFFZO, "FAS1", "IASCUR") From GLOBIENS
    [M:FAS2]IASCGU     = "": # Unité génér tréso
  Endif

  # Fiche 48468
  # [M:FAS8]BAC = ""         :   # Code à barres

  If ( GDISAFAS = G_NON ) Then
    # La solution est paramétrée comme ne gérant pas les biens inactifs ( bien toujours actif)
    [M:FAS0]ENAFAS = G_OUI
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]ENAFAS", 0) = G_OUI Then : Diszo [M:FAS0]ENAFAS : Endif
  Else
    # La solution est paramétrée comme gérant les biens inactifs ( bien peut être actif ou inactif)
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]ENAFAS", 0) = G_NON Then : Actzo [M:FAS0]ENAFAS : Endif
  Endif
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]IASCGU", 0) = G_OUI Then : Diszo [M:FAS2]IASCGU : Endif

  Gosub MODIF_REDUITE From SUBFAS2
  If ( GREMAFCY = G_NON ) Then
    #zonsui = "[M:FAS0]FCY" : # FQ63459
    SUIZON = "[M:FAS0]FCY"
  Else
    #zonsui = "[M:FAS0]AASREF"  : # FQ63459
    SUIZON = "[M:FAS0]AASREF"
  Endif

  # En création, réinitialisation du style.
  Chgstl [M:FAS0]AASREF  With ""
  Chgstl [M:FAS0]AASDES1 With ""
  Chgstl [M:FAS0]AASDES2 With ""

  GLOFPREAD = G_NON # FQ98116 : pas de dépense principale lue quand on entre en création
Return

#=====================================================================
$LIENS

Local Shortint I
Local Char LIBZON(25)

  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:FAS]CPY,"",G_NON,ERR) From GLOFCYCPY

  GREP = ""

  # Masquage champs visibles
  G_CCNFMT = "-Nz3:13.2#"

  # La suppression a échoué dans le $ANNULE
  If ( GSUPOK = G_NON ) Then
    # L'indicateur passe à "Pas de suppression"
    GSUPOK = 0
    # Unlock des biens (Un par un pour éviter de déverrouiller le bien courant)
    # Unlock des biens de l'ensemble
    For [FASW]FAS0 Hint Key FAS3 Where SET=[M:FAS0]AASREF
      #------------------------------
      LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([F:FASW]AASREF)
      Call UNLOCK_SYMBOLE ("FAS", [F:FASW]CPY, LLOCK) From GLOBIENS
    Next
    # Unlock des biens composant
    Gosub UNLOCK_COMPOSANT
  Endif

  # La modification a échoué dans le $MODIF
  If ( GMODOK = G_NON ) Then
    # L'indicateur passe à "Pas de modification"
    GMODOK = 0
    # Unlock des biens composant
    Gosub UNLOCK_COMPOSANT
  Endif

  # Valeurs des variables globales en fonction du site
  # Le fait de faire l'affzo déclenche le Call ACTION_FCY en avant_zone du type de donnée BCP
  Affzo [M:FAS0]FCY

  # Récupération valeur des differents paramètres
  Call LECTURE_PARAMETRES ([M:FAS0]FCY)

  # Initialisation du tableau des plans d'amortissement
  Gosub INIT_PLAN_AMT

  # Alimentation du tableau des plans d'amortissement
  Gosub LOAD_PLAN_AMT
  If GERR=1 : Return : Endif

  # Affectation / Activation / désactivation de champs
  Gosub INIT_GENERALE

  # Chargement du tableau de +/- value sur l'onglet entrée / sortie
  Gosub LOAD_GAL

  # Alimentation des montants de TVA sur cession
  If ([F:FAS]ISSDAT <> [0/0/0]) and (([F:FAS]ACGREVVAT <> 0) or ([F:FAS]IASREVVAT <> 0))
    # Cas du reversement de TVA
    # Changement des libellés et des valeurs des champs de déduction complémentaire du masque FAS4
    [M:FAS4]ACGCPLDED = [F:FAS]ACGREVVAT
    [M:FAS4]IASCPLDED = [F:FAS]IASREVVAT
    Call TEXTE(34941, LIBZON) From OBJDIV : # "TVA reversement PCG"
    Chgtzn [M:FAS4]ACGCPLDED With LIBZON
    Call TEXTE(34942, LIBZON) From OBJDIV : # "TVA reversement IFRS"
    Chgtzn [M:FAS4]IASCPLDED With LIBZON
  Else
    Call TEXTE(34784, LIBZON) From OBJDIV  : # "Déduction complém PCG"
    Chgtzn [M:FAS4]ACGCPLDED With LIBZON
    Call TEXTE(34787, LIBZON) From OBJDIV  : # "Déduction complém IFRS"
    Chgtzn [M:FAS4]IASCPLDED With LIBZON
  Endif

  # Valeur bilan PCG = Valeur d'entrée HT PCG + TVA facturée PCG - TVA récupérée PCG
  [M:FAS1]ACGBSEVAL = [M:FAS1]ACGETRNOT + [M:FAS1]IVCVATAMT - [M:FAS1]DEDVATAMT

  # Valeur bilan PCG = Valeur d'entrée HT PCG + TVA facturée PCG - TVA récupérée PCG
  [M:FAS1]IASBSEVAL = [M:FAS1]IASETRNOT + [M:FAS1]IVCVATAMTI - [M:FAS1]DEDVATAMTI

  # Affectation / Activation / désactivation de champs
  Gosub INIT_LIENS

  # Réinitialisation des valeurs relatives à l'immobilisation des dépenses
  Gosub RAZ_PICKING From FUNLOFLDAB
  Gosub READ_DEP_PRINCIPALE From FUNLOFLDAB

  # Diszo de certains champs selon IAS, Immo avec dépenses,..
  Gosub MODIF_REDUITE From SUBFAS2

  GMODENAFAS = 0

  Diszo [M:FAS4]IVCSALISS  #Fq-67621 déclaré saisissable uniquement pour le Tunnel mais non modifiable

  # Le bien est annulé
  If ( [M:FAS1]OWNTYP = GVML_TDANNUL ) Then
     Diszo [M:FAS1]
     Diszo [M:FAS2]
     Diszo [M:FAS3]
     Diszo [M:FAS4]
     # FQ54343
     Diszo [M:FAS5] : Actzo [M:FAS5]HIS #Fq70353
     If ( G_ACTCCN =  G_OUI ) Then
       Diszo [M:FAS6]
       Chgtzn [M:FAS6]VISRPR With ""
     Endif
#     If (clalev([M:FRZ9])) : Diszo [M:FRZ9] : Actzo [M:FRZ9]EVTLIST  : Endif #Fq70353 # Issue X3-109499
#     If (clalev([M:FAS9])) : Diszo [M:FAS9] : Actzo [M:FAS9]EVTLIST  : Endif #Fq70353 # Issue X3-109499
     If (clalev([M:FRZ9])) : Diszo [M:FRZ9]  : Endif #Fq70353 # Issue X3-109499
     If (clalev([M:FAS9])) : Diszo [M:FAS9]  : Endif #Fq70353 # Issue X3-109499
     Actzo [M:FAS0]EVTLIST # Issue X3-109499
  Endif

  If GPHY=G_OUI Then
    If GPILNAV > 1 Then
      If find(GNAVIG(GPILNAV-1),"GESPHY") Then
          G_TUNNEL_PHY=G_OUI
          G_SAV_CONSULT = GCONSULT
          GCONSULT = 1
          Diszo [M:FAS0]
          Diszo [M:FAS1]
          Diszo [M:FAS2]
          Diszo [M:FAS3]
          Diszo [M:FAS4]
          # FQ54343
          Diszo [M:FAS5]
          If ( G_ACTCCN =  G_OUI ) Then
            Diszo  [M:FAS6]
            Chgtzn [M:FAS6]VISRPR With ""
          Endif
          Diszo [M:FAS9]
          Actzo [M:FAS0]FLGELT # on initialise le bouton élément physique
          Actzo [M:FAS0]EVTLIST # on ré active le bouton de vision des évenements # Issue X3-109499
      Endif
    Endif
  Endif

  # Chargement des éléments physiques dans l'écran FAS8
  If GPHY = G_OUI Then
     Gosub CHARGE_FAS8_ELT_PHY
  Endif

  If ( [M:FAS1]AASBUS <> "") Then
    Read [F:SEA]SEA0=[M:FAS0]CPY;[M:FAS1]AASBUS
    [M:FAS1]SACDES = [F:SEA]SACDES
  Endif
  # Ecran TVA
  Gosub CONDITIONNE_TVA_FAS5           From TRTFAS
  Gosub CONDITIONNE_TAXES_LOCALES_FAS2 From TRTFAS : # FQ57624

  If GKFR = G_OUI Then : # FQ57624
    [M:FAS5]ASJCOE2    = [F:FAS]ASJCOE
    [M:FAS5]TAXCOE2    = [F:FAS]TAXCOE
    [M:FAS5]TAXCOEFLG2 = [F:FAS]TAXCOEFLG
    [M:FAS5]ADMCOE2    = [F:FAS]ADMCOE
    [M:FAS5]DEDCOE2    = [F:FAS]DEDCOE
  Endif

  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:FAS]","[M:FPC]","[M:FAS2]",LNBRCCE) From GLOBIENSANA
  [M:FAS2]NBRCCE=LNBRCCE

  G_NBAXE = LNBRCCE  #Fq-79815

  #> Application du style ISSFIYPRE si le bien est sorti
  If [F:FAS]ISSFIYPRE<>G_OUI & [F:FAS]ISSDAT<>[0/0/0] & [F:FAS]EXTISSFLG<>G_OUI
    Chgstl [M:FAS0]AASREF  With "ISSFIYPRE"
    Chgstl [M:FAS0]AASDES1 With "ISSFIYPRE"
    Chgstl [M:FAS0]AASDES2 With "ISSFIYPRE"
  Else
    Chgstl [M:FAS0]AASREF  With ""
    Chgstl [M:FAS0]AASDES1 With ""
    Chgstl [M:FAS0]AASDES2 With ""
  Endif

  # FQ54343
  If ( [M:FAS1]OWNTYP = GVML_TDCONCE ) Then
    If ( G_CCNRPR = G_OUI ) Then
      # Chargement des éléments provisions dans l'écran FAS6
      Gosub CHARGE_FAS6_ELT_RPR From SUBFASCCN
    Else
      Chgtzn [M:FAS6]VISRPR With ""
      Call ACTION_BLOCK (ACB_DISZO, "FAS6", "CCNACTCOD") From GLOBIENS
    Endif
  Else
    If ( G_ACTCCN = G_OUI ) Then
      Chgtzn [M:FAS6]VISRPR With ""
      Diszo [M:FAS6]1-99
    Endif
  Endif

  If func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY, 0) = G_OUI : # FQ73739
    Call ECR_TRACE(func GLOFUNC.SUBSTIT1(mess(282,GML_MSGFASPR,1), [M:FAS0]CPY)-mess(283,GML_MSGFASPR,1),0) From GESECRAN
  Endif

  Default File [F:FAS] : # FQ56636 : Pour que l'application du style fonctionne sur le premier $LIEN
Return

