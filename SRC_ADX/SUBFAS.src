#*********************************************************************
#         *FAS2            E C R A N      F A S 2
#*********************************************************************

########################################
Subprog AM_INVPLN(VALEUR)
Variable Char    VALEUR()

Local Char LCODE

  If ( VALEUR <> "" ) Then
    LCODE=VALEUR
    If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif   # tables diverses
    Read[ADI]CODE=GTD_INVPLN;LCODE
    If ( fstat = 0 ) Then
      If ([F:ADI]A1 <> "") &  ([F:ADI]A1 <> [M:FAS0]CPY)
        GERR=1
        # Le projet doit porter sur la société du bien comptable ou n'être rattaché à aucune société
        GMESSAGE = mess(539,GML_MSGFAS,1) :
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

########################################
Subprog AM_ORDREF(VALEUR)
Variable Char    VALEUR()

  If (VALEUR <> "" and [M:FAS2]ORDLIG = 0) Then
   [M:FAS2]ORDLIG = 1
   Affzo [M:FAS2]ORDLIG
  Endif
  If (VALEUR  = "" and [M:FAS2]ORDLIG <> 0) Then
   Raz [M:FAS2]ORDLIG : Affzo [M:FAS2]ORDLIG
  Endif
End


########################################
Subprog AM_AASBUS(VALEUR)
Variable Char    VALEUR()

Local Decimal LDEDVATRAT

  # Gestion du code forçage
  [M:FAS1]DEDVATFLG  = G_NON : Affzo [M:FAS1]DEDVATFLG
  [M:FAS1]DEDVATFLGI = G_NON : Affzo [M:FAS1]DEDVATFLGI

  LDEDVATRAT = [M:FAS1]DEDVATRAT
  If ( VALEUR <> "" ) Then
    Read [F:SEA]SEA0=[M:FAS0]CPY;VALEUR
    If (fstat) Then
      # Secteur d'activité invalide
      GERR=1 : mkstat = 2 :  GMESSAGE = mess(636,GML_MSGFAS,1) :  End
    Endif
    If ( not G_AASBUS ) Then
      [M:FAS1]ASJCOE = [F:SEA]ASJCOE : Affzo [M:FAS1]ASJCOE
      Call AM_ASJCOE ([M:FAS1]ASJCOE)
    Endif
    If ([M:FAS1]TAXCOEFLG <> G_OUI) Then
      [M:FAS1]TAXCOE = [F:SEA]TAXCOEINI : Affzo [M:FAS1]TAXCOE
    Endif
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, LDEDVATRAT ) From TRTFAS
    [M:FAS1]DEDCOE = LDEDVATRAT : Affzo [M:FAS1]DEDCOE
    LDEDVATRAT = LDEDVATRAT * 100.
  Else
    If ( [M:FAS1]ASJCOE = 0. ) Then
      [M:FAS1]TAXCOEFLG = 2
      [M:FAS1]TAXCOE    = 0. : Affzo [M:FAS1]TAXCOE
      If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0) = G_OUI Then : Diszo [M:FAS1]TAXCOE : Endif
      Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, LDEDVATRAT ) From TRTFAS
      [M:FAS1]DEDCOE = LDEDVATRAT : Affzo [M:FAS1]DEDCOE
      LDEDVATRAT = LDEDVATRAT * 100.
    Endif
    If ( [M:FAS1]TAXCOEFLG <> G_OUI ) Then
      [M:FAS1]TAXCOE = 1. : Affzo [M:FAS1]TAXCOE
      Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, LDEDVATRAT ) From TRTFAS
      [M:FAS1]DEDCOE = LDEDVATRAT : Affzo [M:FAS1]DEDCOE
      LDEDVATRAT = LDEDVATRAT * 100.
    Endif
  Endif
  If ( [M:FAS1]DEDVATRAT <> LDEDVATRAT ) Then
    [M:FAS1]DEDVATRAT = LDEDVATRAT
    Affzo [M:FAS1]DEDVATRAT
    Actzo [M:FAS1]DEDVATAMT
    Affzo [M:FAS1]DEDVATAMT
    # Taux TVA récupérée IAS
    If ( G_PLNIAS ) Then
      [M:FAS1]DEDVATRATI = LDEDVATRAT
       Affzo [M:FAS1]DEDVATRATI
       Actzo [M:FAS1]DEDVATAMTI
       Affzo [M:FAS1]DEDVATAMTI
    Endif
  Endif

  Call AM_DEDVATRAT([M:FAS1]DEDVATRAT)
  If (G_PLNIAS) Then
    Call AM_DEDVATRATI([M:FAS1]DEDVATRATI)
  Endif

  If (VALEUR <> "") Then
    [M:FAS1]SACDES = [F:SEA]SACDES : Affzo [M:FAS1]SACDES
  Else
    Effzo [M:FAS1]SACDES
  Endif

End

########################################
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()

 If ( VALEUR <> "" ) Then
   # FQ95579 valorisation de PCLE_SUPP à 1
   Call CTRL_AUT_OBJ("DSP", VALEUR, "1", [M:FAS0]FCY, date$) From GLOBIENS
   If mkstat : End : Endif

 Endif
End

########################################
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
  Local Integer N_CCE

  For N_CCE = 0 To GOPTCANA-1
    If ( VALEUR = "" ) Then
      # Si une clé de répartition est remise à blanc, il faut dégriser les axes
      Actzo [M:FAS2]CCE(N_CCE)
    Else
      # Si une clé de répartition est saisie, il faut griser les axes
      [M:FAS2]CCE(N_CCE) = ""
      Diszo [M:FAS2]CCE(N_CCE)
    Endif
  Next N_CCE
End

######################################################################################
##Fq-79815 Activation et contrôle des sections analytiques
######################################################################################
#######################################
Subprog AS_NBRCCE

 # Pour récupèree les sections par défautce il faut être en  Création/Duplication de biens
 # .... et ne pas avoir renseigné de clé répartition
 # FQ93517
 If (GREP <> "C"  and GREP <> "D")  or GNBDEPLIEES > 0  or  [M:FAS2]DSP <> ""
    End
 Endif

  Local Integer AXE
  ##Fq-79815 Section analytiques par défaut
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  Local Char WACC
  If [M:FAS1]GAC <> ""
     WACC = [M:FAS1]GAC
  Else
     WACC = [M:FAS1]IASACC
  Endif

  For I_DIE = 1 To [M:FPC]NBDIE
    [M:FAS2]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
    #XXXX ne fonctionne pas avec le paramétrage section par défaut sur compte (Compta)
    If [M:FAS2]CCE(I_DIE-1)= ""
       # Call INICCE([M:FAS2]CCE(I_DIE-1),[M:FPC]DIE(I_DIE-1),LED(GLEDTYPANA),WACC,"FXDASSETS") From CPTINI
       Call INISEC([M:FAS2]CCE(I_DIE-1),"FXDASSETS",[M:FPC]DIE(I_DIE-1)) From SUBCDE
    Endif
    Affzo [M:FAS2]DIE(I_DIE-1) : Affzo [M:FAS2]ZDIE(I_DIE-1)
    Affzo [M:FAS2]CCE(I_DIE-1) : Affzo [M:FAS2]ZCCE(I_DIE-1)
  Next I_DIE
  Affzo [M:FAS2]NBRCCE
  #Fq-79815

   For AXE=1 To  [M]NBRCCE
     Actzo [M:FAS2]CCE(AXE-1)
     Affzo [M:FAS2]CCE(AXE-1)
   Next

End

#######################################
Subprog C_NBRCCE

# adxgtb= 0 = On est encore en saisie dans le tableau
# adxgtb= 1 = Sortie invalide du tableau ==> pas la peine de faire ces contrôles car il y a au préalable des anomalies à corriger
# adxgtb= 2 = Sortie valide du tableau ==>  on fait des contrôles complémentaires sur chaque ligne du tableau
If adxgtb=2
   If clalev([F:CAZ])=0  : Local File CAAUZ   [CAZ]  : Endif
   If clalev([F:CCE])=0  : Local File CACCE   [CCE]  : Endif  : # Sections
   If clalev([F:CCE2])=0 : Local File CACCE   [CCE2] : Endif  : # Sections

   For AXE=1 To G_NBAXE
      If [M]CCE(AXE-1)<>""
         nolign=AXE
         # Contrôle interdiction section/section
         Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
         For I=AXE+1 To G_NBAXE
            If [M]CCE(I-1)<>""
               Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
               Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
               If !fstat
                  # Interdit avec la section
                  GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
                  mkstat = 1 : Break 2
               Endif
            Endif
         Next
      Else    # [M]CCE(AXE-1)=""
      Endif
   Next
Endif

End
######################################################################################
Subprog AM_PROPLN(VALEUR)
Variable Char    VALEUR()

End

######################################################################################
Subprog AM_LEAREF(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Decimal SCUMRNT    #Fq-64312
Local Decimal SCUMIASBSE #Fq-64312

RATT_LEAREF = G_NON
MOD_LEAREF  = G_NON
DETA_LEAREF = G_NON

  If [M:FAS2]LEAREF = "" and VALEUR <> ""
    RATT_LEAREF = G_OUI
  Elsif   [M:FAS2]LEAREF <> "" and VALEUR <> ""
    MOD_LEAREF = G_OUI
  Elsif   [M:FAS2]LEAREF <> "" and VALEUR = ""
    DETA_LEAREF = G_OUI
  Endif

  If (VALEUR <> "") and DETA_LEAREF <> G_OUI
    Read[LEA]LEA0 = VALEUR
    If ( fstat or  ([M:FAS0]FCY   <> [F:LEA]FCY)
&              or  ([F:LEA]LEASTA <> GVML_STAVAL and [F:LEA]LEASTA <> GVML_STENCOU) )
      GERR= 1: GMESSAGE = mess(2,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif  #Fq-64312
    SCUMIASBSE =  [F:LEA]CUMIASBSE + [M:FAS1]IASETRNOT
    SCUMRNT    =  [F:LEA]CUMRNTAMT
    #Fq-76672 Ctrl uniquement si FRADGI = "OUI" ==> si LEG ="FRA"
    If func GLOBIENS.FRADGI([F:CNX]CPY)
       If SCUMRNT <  SCUMIASBSE
          #Le cumul des bases des biens rattachés au contrat de location dépasse le cumul des redevances du contrat.
          GERR= 1: GMESSAGE = mess(806,GML_MSGFAS,1)
          mkstat = 2 : End     #Fq-64312
       Endif
    Endif

    If [M:FAS1]PURDAT  <  [F:LEA]STRLEADAT   or  [M:FAS1]PURDAT   >  [F:LEA]ENDLEADAT
       Call OUINON(mess(420,GML_MSGFAS,1), OK) From GESECRAN
       If ( OK = 1)
         mkstat = 2 : End
       Endif
    Endif

    # FQ84262
    If ( [M:FAS1]OWNTYP = GVML_TDCBAIL and [F:LEA]LEATYP <> GVML_CREBAIL  ) Then
      # Il ne s'agit pas d'un contrat crédit bail
      GERR= 1: GMESSAGE = mess(42,7771,1)
      mkstat = 2 : End
    Endif
    # FQ84262 + X3-8349
    If ( [M:FAS1]OWNTYP = GVML_TDLOCAT and [F:LEA]LEATYP <> GVML_LOCLDUR  and [F:LEA]LEATYP <> GVML_LOCATION  ) Then
      # Il ne s'agit pas d'un contrat de location
      GERR= 1: GMESSAGE = mess(121,7771,1)
      mkstat = 2 : End
    Endif

  Endif

  [M:FAS2]LEAREFORI = [M:FAS2]LEAREF
  Affzo [M:FAS2]LEAREFORI


End
########################################
Subprog C_LEAREF(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Decimal SCUMRNT    #Fq-64312
Local Decimal SCUMIASBSE #Fq-64312


End
