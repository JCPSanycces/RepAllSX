#*********************************************************************
#          *FAS3           E C R A N      F A S 3
#*********************************************************************

########################################
Subprog AS_NBLIG1

  # Plan d'amortissement n'est accessible qu'en mode visualisation
  If (GREP <> "" ) Then
    GBOUT1=""
  Endif
  # Plan dérogatoire n'est accessible que pour les plans autres que Fiscal ou Comptable
  # si le plan fiscal ET le plan comptable sont défins et si l'on est en visualisation.
  If (( [M:FAS3]DPRPLN(nolign-1) <> G301FIS and [M:FAS3]DPRPLN(nolign-1) <> G301CPT ) or
&     find( G301FIS, [M:FAS3]DPRPLN ) = 0 or find(G301CPT, [M:FAS3]DPRPLN) = 0 or GREP <> "" ) Then
    GBOUT2=""
  Endif
  # Reporter les paramètres est accessible en création
  # Réévaluer et Déprécier n'est accessible qu'en mode visualisation
  If ( GREP <> "" ) Then
    GBOUT4=""
    GBOUT6=""
  Endif
  # Réévaluer n'est accessible que pour les plans autres que le plan Subvnetion
  If ( [M:FAS3]DPRPLN(nolign-1) = G301SUB ) Then
    GBOUT4=""
  Endif
  # Forcer dotation n'est pas accessible si la date de début d'amt > date de début de l'exercice courant
  If ( [M:FAS3]STRDPRDAT(nolign-1) > [M:FAS3]FIYENDDAT(nolign-1) ) Then
    GBOUT5=""
  Endif

  # Les actions métier ne sont pas disponibles si un contexte de la société est désynchronisé
  If func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY, 0) = G_OUI : # FQ73739
    GBOUT4=""
    GBOUT5=""
    GBOUT6=""
  Endif

  # FQ88613 : la demande de recalcul d'un contexte n'est possible que sur un dossier de développement
  If GADONIX <> 2
    GBOUT8=""
  Endif

  # FQ75616
  # Reprise avancée autorisée si la situation antérieure peut être remise en cause
  # en Création dans tous les cas ou en Modficiation si le bien est inactif
  If ( [M:FAS0]PRVSITUPD <> G_OUI ) Then
    GBOUT9=""
  Else
    If ( [M:FAS0]ENAFAS = G_OUI and GREP <> "C" ) Then
      GBOUT9=""
    Endif
  Endif

  # Application des habilitations aux menus contextuels "Réévaluer" et "Déprécier"
  # du tableau des plans d'amortissement
  Local Integer ACCFCY
  Local Char AUZFCY (15)
  # Accès selon droit à l'option
  Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
  If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'V') ) Then
    GBOUT4=""
    GBOUT6=""
  Endif

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Call AS_NBLIG1 From TRTFASMDR
  Endif

End

########################################
Subprog C_NBLIG1

 If ( status = 71 ) Then : # Escape
   Gosub MODIF_REDUITE From SUBFAS2
 Endif
End


########################################
Subprog B4_NBLIG1
# action de réévaluation à partir d'une ligne de plan d'amortissement

  # initialisation des paramètres de l'action FASRVA
  #----------
  Local Char VALBOUT(250) , PARAM(250)(1..20)
  GACTION    = "FASRVA"
  PARAM(1)   = GTAMUNI
  PARAM(2)   = "FASRVA"
  PARAM(3)   = num$(GVML_OMBIEN)
  PARAM(4)   = num$(G_OUI)
  PARAM(5)   = num$(G_NON)
  PARAM(6)   = num$([M:FAS3]DPRPLN(nolign-1))
  Call SAISIE_CHAR(VALBOUT,PARAM,"FASRVAU","TRTFASRVA","XWFASRVA") From GSAISIE
  # Gestion actions objets métiers : on passe en FIN_ACTION afin de vérifier le actmodif
  # et mettre GREP ="M" en retour de l'action métier de réévaluation
  ACTION = "FIN_ACTION"
  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
  Kill GPARMPLN
  If GREP = "M"  : mkstat = 4 : Endif

End

########################################
Subprog B6_NBLIG1
# action de dépréciation à partir d'une ligne de plan d'amortissement

Local Date    WDDATE(1..5)
Local Integer WICODERET
Local Integer LCONTEXT

  # Récupération Debut et Fin d'exercice du contexte correspondant au plan amort
  Call GET_CNX_DAT([M:FAS0]CPY,[M:FAS3]CNX(nolign-1),WDDATE,WICODERET) From GLOBIENS
  # Lecture DEPREC Début exercice courant
  Read [DEP]DEP5=[M:FAS0]AASREF;[M:FAS3]DPRPLN(nolign-1);WDDATE(2);WDDATE(3)

  If ( [F:DEP]DEPSTA <> GVML_SCCAL ) Then
    GMESSAGE = mess(500,GML_MSGFAS,1) : # Dépréciation impossible car aucun calcul société n'a été lancé pour ce plan  "
  Else
    # initialisation des paramètres de l'action FASIML
    #----------
    Local Char VALBOUT(250) , PARAM(250)(1..20)
    GACTION    = "FASIML"
    PARAM(1)   = GTAMUNI
    PARAM(2)   = "FASIML"
    PARAM(3)   = num$(GVML_OMBIEN)
    PARAM(4)   = num$(G_OUI)
    PARAM(5)   = num$(G_NON)
    PARAM(6)   = num$([M:FAS3]DPRPLN(nolign-1))

    Call SAISIE_CHAR(VALBOUT,PARAM,"FASIMLU","TRTFASIML","XWFASIML") From GSAISIE
    # Gestion actions objets métiers : on passe en FIN_ACTION afin de vérifier le actmodif
    # et mettre GREP ="M" en retour de l'action métier de réévaluation
    ACTION = "FIN_ACTION"
    Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
    Kill GPARMPLN
    If ( GREP = "M" ) Then  : mkstat = 4 : Endif
  Endif

End

#Fq67577
########################################
Subprog B7_NBLIG1
 Call B7_NBLIG1 From TRTFASMDR
End

######################################## FQ88613
Subprog B8_NBLIG1
  # Recalcul du contexte
  [M:FAS0]FLGCLC                             = G_OUI
  [M:FAS0]FLGCNXCLC([M:FAS3]CNX(nolign-1)-1) = G_OUI
  mkstat = 4
End

########################################
Subprog AM_DPM(VALEUR)
Variable Char    VALEUR()

Local Integer LERROR

  # FQ64291 FQ70467
  # En norme française, le plan de subvention hérite de la durée du plan fiscal
  If ([M:FAS3]DPRPLN(nolign-1) = G301SUB) and (func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA") Then
    Local Integer I_PLNFIS
    I_PLNFIS = find(G301FIS, [M:FAS3]DPRPLN)
    If (I_PLNFIS > 0) Then
      If ( [M:FAS3]DPM(I_PLNFIS-1) <> "SA" ) and ( VALEUR <> "SA" ) Then
        [M:FAS3]DPRDUR(nolign-1) = [M:FAS3]DPRDUR(I_PLNFIS-1)
      Endif
    Endif
  Endif

  #------------
  # Contrôles
  #------------
  Call CTRL_DPM ( VALEUR, [M:FAS0]CPY, [M:FAS3]CNX(nolign-1), [M:FAS3]DPRPLN(nolign-1),
&                 [M:FAS1]AASTYP, [M:FAS1]OWNTYP, [M:FAS2]PROPLN, G_OUI, LERROR) From TRTFAS
  If (LERROR) Then
    GMESSAGE = mess(LERROR,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
  Endif

  #---------------
  # Affectations
  #---------------

  # -- Début d'amort.
  Case func TRTFAS.GET_DPRSTRDAT_TYP(VALEUR, [M:FAS0]CPY)
    When GVML_TPURDAT : [M:FAS3]STRDPRDAT(nolign-1) = [M:FAS1]PURDAT
    When GVML_TITSDAT : [M:FAS3]STRDPRDAT(nolign-1) = [M:FAS1]ITSDAT
    When GVML_TACCDAT : [M:FAS3]STRDPRDAT(nolign-1) = [M:FAS1]AASIPTDAT
    When Default
  Endcase
  Affzo [M:FAS3]STRDPRDAT(nolign-1)

  # -- Durée d'amort. FQ84110
  If ( find(VALEUR, G_DPMSA, G_DPMLV, G_DPMIT, G_DPM1P) <> 0 ) Then
    # Pour ces modes la durée est toujours à 0
    [M:FAS3]DPRDUR(nolign-1)   = 0     : Affzo [M:FAS3]DPRDUR(nolign-1)
  Endif
  If ( VALEUR = G_DPMFM ) Then
    # Pour "Formes & Moules", la durée est de 3 ans
    [M:FAS3]DPRDUR(nolign-1)   = 3.    : Affzo [M:FAS3]DPRDUR(nolign-1)
  Endif
  If ( VALEUR = G_DPMLG ) Then
    # Pour "Linge", la durée est de 18 mois
    [M:FAS3]DPRDUR(nolign-1)   = 1.5   : Affzo [M:FAS3]DPRDUR(nolign-1)
  Endif
  If ( VALEUR = G_DPMLP and [M:FAS3]ALWCOD(nolign-1) = GVML_RPALOGI ) Then
    #-- Pour le logiciel, la durée est de 12 mois
    [M:FAS3]DPRDUR(nolign-1)   = 1.    : Affzo [M:FAS3]DPRDUR(nolign-1)
  Endif

  # -- Taux 1
  # FQ55960 FQ59941 FQ84110 FQ84283 FQ84281, FQ105809
  If ( func TRTFAS.GET_MODE_DPM ([M:FAS0]CPY, VALEUR) = GVML_TMLIBRE or
&      find( VALEUR,  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMAL, G_DPMAD,
&                     G_DPMDP, G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA,
&                     G_DPMSY, G_DPMUO, G_DPMDV, G_DPMRA, G_DPMDM, G_DPMLR, G_DPMDR,
&                     G_DPMSR, G_DPMUR, G_DPMCR, G_DPMRX, G_DPMRD, G_DPM1P, G_DPMHL ) <> 0 ) Then
    #-- Pour les modes libres, le taux est déterminé par le calcul.
    #-- Pour ces modes standards, le taux est déterminé par le calcul. FQ77877
    [M:FAS3]DPRRAT(nolign-1)   = 0     : Affzo [M:FAS3]DPRRAT(nolign-1)
    [M:FAS3]DPRRATFLG(nolign-1)= G_NON : Affzo [M:FAS3]DPRRATFLG(nolign-1)
  Endif
  If ( VALEUR = G_DPMLP and [M:FAS3]ALWCOD(nolign-1) = GVML_RPALOGI ) Then
    #-- Pour le logiciel, le taux est toujours à 100 %
    [M:FAS3]DPRRAT(nolign-1)   = 1.    : Affzo [M:FAS3]DPRRAT(nolign-1)
    [M:FAS3]DPRRATFLG(nolign-1)= G_NON : Affzo [M:FAS3]DPRRATFLG(nolign-1)
  Endif

  # -- Taux 2
  # FQ59941 FQ84283
  If (find( VALEUR, G_DPMIT, G_DPMLR, G_DPMCR, G_DPMAL, G_DPMAD) = 0 ) Then
    # Le taux d'amort. exceptionnel ne concerne que les modes ci-dessus
    # Utilisé égalemet pour la saisie du coefficient de bonus à appliquer pour les modes russes LR & CR
    [M:FAS3]DPRRAT2(nolign-1) = 0. : Affzo [M:FAS3]DPRRAT2(nolign-1)
  Endif

  # -- Coef accél.
  If ( find(VALEUR, G_DPMUD, G_DPMTD, G_DPMDB, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMML, G_DPMMD) = 0) Then
    # FQ59941 67577 FQ72372 FQ105809
    # Le coefficient d'accélération ne concerne que "Declining Balance", "Linéaire russe", " Dégressif russe"
    # "Constant russe" "Linéaire polonais" ou le "Dégressif belge"
    [M:FAS3]ACLCOE(nolign-1) = 0. : Affzo [M:FAS3]ACLCOE(nolign-1)
  Endif

  # -- Prorata
  If ( find( VALEUR, G_DPMUL, G_DPMUD, G_DPMTD, G_DPMRE, G_DPMHL, G_DPMHD, G_DPMTL) = 0 ) Then
    # Le type de prorata n'est significatif que pour les modes ci-dessus FQ84281, FQ105809
    [M:FAS3]PRATYP(nolign-1) = 0. : Affzo [M:FAS3]PRATYP(nolign-1)
  Endif

  # -- Fin d'amortissement
  # FQ59941
  # Issue 116168 - POR (PC/PD methods)
  # Issue 116168 If ( VALEUR <> G_DPMUO and VALEUR <> G_DPMUR ) Then
  If find(VALEUR, G_DPMUO, G_DPMUR, G_DPMPC, G_DPMPD) = 0
    # Le fin d'amortissement n'est saisissable que pour les modes ci-dessus
    [M:FAS3]ENDDPRDAT(nolign-1) = [0/0/0] : Affzo [M:FAS3]ENDDPRDAT(nolign-1)
  Endif

  # -- Règle paticulière
  # FQ82075 G_DPMSL
  If ( ( VALEUR = G_DPMLP or VALEUR = G_DPMDF or VALEUR = G_DPMSL ) and
&      ( find([M:FAS3]ALWCOD(nolign-1), GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) <> 0 ) ) Then
    # Règle inchangée si mode "LP" ou "DF" et règle correspond à une des règles ci-desssus (règles communes)
  Elsif( ( VALEUR = G_DPMLR or VALEUR = G_DPMCR ) and
&      ( find([M:FAS3]ALWCOD(nolign-1), GVML_RPBONUS) <> 0 ) ) Then
    # FQ59941 Règle inchangée si mode "LR" ou "CR" et règle correspond à Bonus
  Elsif ( ( VALEUR = G_DPMPC and [M:FAS3]DPM(nolign-1) <> G_DPMPD ) or
&         ( VALEUR = G_DPMPD and [M:FAS3]DPM(nolign-1) <> G_DPMPC )    ) Then
    # "Basé sur période" règle par défaut pour les modes "PC" et "PD"
    [M:FAS3]ALWCOD(nolign-1) = GVML_RPPERIO : Affzo [M:FAS3]ALWCOD(nolign-1)
  Else
    # Dans tous les autres cas, la règle passe à "Aucune"
    [M:FAS3]ALWCOD(nolign-1) = GVML_RPAUCUN : Affzo [M:FAS3]ALWCOD(nolign-1)
  Endif

  # FQ75616
  If not [M:FAS3]BREPRISE(nolign-1) Then
    If ( [M:FAS3]DPM(nolign-1) = [M:FAS3]DPMI(nolign-1) ) Then
      [M:FAS3]DPMI(nolign-1) = VALEUR
    Endif
    If ( [M:FAS3]DPM(nolign-1) = [M:FAS3]DPMT(nolign-1) ) Then
      [M:FAS3]DPMT(nolign-1) = VALEUR
    Endif
  Endif

  # Modif réduite
  [M:FAS3]DPM(nolign-1) = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2

End

########################################
Subprog C_DPRDUR(VALEUR)
Variable Decimal VALEUR

Local Integer LERROR
  # Contrôles de la durée par rapport au mode d'amortissement
  Call CTRL_DPRDUR (VALEUR, [M:FAS3]DPM(nolign-1), [M:FAS0]CPY, [M:FAS3]ALWCOD(nolign-1),[M:FAS3]ENDDPRFLG(nolign-1), LERROR ) From TRTFAS
  If (LERROR) Then
    GMESSAGE = mess(LERROR,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
  Endif

End

########################################
Subprog AV_DPRRAT(VALEUR)
Variable Decimal VALEUR

  If ([M:FAS3]DPRRATFLG(nolign-1) = G_OUI ) Then
    Chgstl [M:FAS3]DPRRAT(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:FAS3]DPRRAT(nolign-1) With ""
  Endif
End

########################################
Subprog AS_DPRRAT(VALEUR)
Variable Decimal VALEUR
  If ( [M:FAS3]DPRRATFLG(nolign-1) <> G_OUI or
&      func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRRAT", nolign-1) <> G_OUI  )  Then
    GBOUT1 = ""
  Endif

End

########################################
Subprog C_DPRRAT(VALEUR)
Variable Decimal VALEUR

Local Decimal WTXLIN     : WTXLIN      = 0.     : # Taux linéaire
Local Decimal WTXMAX     : WTXMAX      = 0.     : # Taux maximum


 If ( find([M:FAS3]DPM(nolign-1), G_DPMIT, G_DPMLV ) and  VALEUR = 0 ) Then
   # Pour ce mode, le Taux doit être renseigné.
   GERR= 1: GMESSAGE = mess(123,GML_MSGFAS,1)
   mkstat = 2 : End
 Endif

 # FQ55960 FQ59941 FQ84110 FQ84283 FQ84281 FQ105809
 If (find ([M:FAS3]DPM(nolign-1),  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMDP,
&                                  G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMSY, G_DPMUO,
&                                  G_DPMRX, G_DPMRD, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMHL,
&                                  G_DPMDV, G_DPMRA, G_DPMDM, G_DPMLR, G_DPMCR, G_DPMDR, G_DPMSR, G_DPMUR) <> 0
&                             and  VALEUR <> 0  ) Then
   # Pour ce mode, le Taux ne doit pas être renseigné. FQ77877
   VALEUR = 0
   [M:FAS3]DPRRATFLG(nolign-1) = G_NON    : Affzo [M:FAS3]DPRRATFLG(nolign-1)
   GERR= 1: GMESSAGE = mess(121,GML_MSGFAS,1)
   mkstat = 2 : End
 Endif

  # FQ82075 G_DPMSL
  If (  [M:FAS3]DPRDUR(nolign-1) = 0 and VALEUR = 0 and
&      find( [M:FAS3]DPM(nolign-1), G_DPMLE, G_DPMLP, G_DPMPC, G_DPMPD,
&                                   G_DPMLB, G_DPMML, G_DPMMD, G_DPMRL, G_DPMSL, G_DPMHD, G_DPMTL) <> 0 ) Then
   # Pour ce mode, la Durée et/ou le Taux doivent être renseignés. FQ67577 FQ72372 FQ77877 FQ84281, FQ105809
   GERR= 1: GMESSAGE = mess(440,GML_MSGFAS,1) : zonsui = "[M:FAS3]DPRDUR("+num$(nolign-1)+")"
   mkstat = 2 : End
 Endif

 If ( [M:FAS3]DPM(nolign-1) = G_DPMDB and VALEUR <> 0 ) Then
   WTXLIN = arr(1/[M:FAS3]DPRDUR(nolign-1), 0.01)
   WTXMAX = arr((1/[M:FAS3]DPRDUR(nolign-1) * 2.), 0.01)
   If ( VALEUR < WTXLIN or VALEUR > WTXMAX  ) Then
     # Pour ce mode d'amortissement, si le taux est renseigné, il doit être > au taux linéaire
     # <= au double du taux linéaire
     GERR= 1: GMESSAGE = mess(572,GML_MSGFAS,1)
     mkstat = 2 : End
   Endif
 Endif

End

########################################
Subprog AM_DPRRAT(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR > 1 or VALEUR < 0 ) Then
    GERR= 1: GMESSAGE = mess(83,123,1)
    mkstat = 2 : End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    If (VALEUR <> 0 ) Then
      [M:FAS3]DPRRATFLG(nolign-1) = G_OUI:  Affzo [M:FAS3]DPRRATFLG(nolign-1)
       Chgstl [M:FAS3]DPRRAT(nolign-1) With "TFORCAGE"
    Else
      [M:FAS3]DPRRATFLG(nolign-1) = G_NON:  Affzo [M:FAS3]DPRRATFLG(nolign-1)
      Chgstl [M:FAS3]DPRRAT(nolign-1) With ""
    Endif
  Endif

End

########################################
Subprog B1_DPRRAT(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  [M:FAS3]DPRRATFLG(nolign-1) = G_NON : Affzo [M:FAS3]DPRRATFLG(nolign-1)

  Raz [M:FAS3]DPRRAT(nolign-1)
  Raz VALEUR

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS3]DPRRAT(nolign-1)  With ""
  Affzo [M:FAS3]DPRRAT(nolign-1)
  mkstat = 99
End

########################################
Subprog AV_DPRRAT2(VALEUR)
Variable Decimal VALEUR

 # FQ84283
 Local Char PAYSIT(GLONCRY)
 Local Char PAYSLR(GLONCRY)
 Local Char PAYSDR(GLONCRY)
 Local Char PAYSCR(GLONCRY)
 Local Char PAYSAL(GLONCRY)
 Local Char PAYSAD(GLONCRY)
 PAYSIT = func TRTFAS.GET_MODE_PAYS( "", "IT" )
 PAYSLR = func TRTFAS.GET_MODE_PAYS( "", "LR" )
 PAYSDR = func TRTFAS.GET_MODE_PAYS( "", "DR" )
 PAYSCR = func TRTFAS.GET_MODE_PAYS( "", "CR" )
 PAYSAL = func TRTFAS.GET_MODE_PAYS( "", "AL" )
 PAYSAD = func TRTFAS.GET_MODE_PAYS( "", "AD" )

 Local Char LEGIT
 Local Char LEGLR
 Local Char LEGDR
 Local Char LEGCR
 Local Char LEGAL
 Local Char LEGAD
 LEGIT = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )
 LEGLR = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )
 LEGDR = func TRTFAS.GET_MODE_LEGISLATION( "", "DR" )
 LEGCR = func TRTFAS.GET_MODE_LEGISLATION( "", "CR" )
 LEGAL = func TRTFAS.GET_MODE_LEGISLATION( "", "AL" )
 LEGAD = func TRTFAS.GET_MODE_LEGISLATION( "", "AD" )

 # FQ62313
 If (
&     (  (PAYSIT = "" or ( PAYSIT <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSIT )) and
&        (LEGIT  = "" or ( LEGIT  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGIT  )) )
&  or (  (PAYSLR = "" or ( PAYSLR <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSLR )) and
&        (LEGLR  = "" or ( LEGLR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGLR  )) )
&  or (  (PAYSDR = "" or ( PAYSDR <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSDR )) and
&        (LEGDR  = "" or ( LEGDR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGDR  )) )
&  or (  (PAYSCR = "" or ( PAYSCR <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSCR )) and
&        (LEGCR  = "" or ( LEGCR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGCR  )) )
&  or (  (PAYSAL = "" or ( PAYSAL <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSAL )) and
&        (LEGAL  = "" or ( LEGAL  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGAL  )) )
&  or (  (PAYSAD = "" or ( PAYSAD <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = PAYSAD )) and
&        (LEGAD  = "" or ( LEGAD  <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:FAS0]CPY) = LEGAD  )) )
& ) Then
  Chgfmt [M:FAS3]DPRRAT2 With "N:3.6#"
 Else
  Chgfmt [M:FAS3]DPRRAT2 With "-N:3.6#"
 Endif

End

########################################
Subprog C_DPRRAT2(VALEUR)
Variable Decimal VALEUR

 If ( [M:FAS3]DPM(nolign-1) = G_DPMIT and VALEUR <> 0 and VALEUR > [M:FAS3]DPRRAT(nolign-1) )
   # "Le taux anticipato ne peut être supérieur au taux ordinario"
   GERR=1: GMESSAGE = mess(483,GML_MSGFAS,1)
   mkstat = 2 : End
 Endif

 # FQ59941
 If ( find([M:FAS3]DPM(nolign-1), G_DPMLR, G_DPMCR) <> 0 and ( VALEUR < 0 and VALEUR > 1 ) )
   # "La valeur doit être comprise en 0 et 1"
   GERR=1: GMESSAGE = mess(253,GML_MSGFAS,1)
   mkstat = 2 : End
 Endif
End


########################################
Subprog AV_ACLCOE(VALEUR)
Variable Decimal VALEUR

 Local Char PAYSS(GLONCRY)
 PAYSS  = func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY)
 Local Char PAYS1(GLONCRY)
 Local Char PAYS2(GLONCRY)
 Local Char PAYS3(GLONCRY)
 PAYS1 = func TRTFAS.GET_MODE_PAYS( "", "UD" )
 PAYS2 = func TRTFAS.GET_MODE_PAYS( "", "DB" )
 PAYS3 = func TRTFAS.GET_MODE_PAYS( "", "LR" )
 Local Char LEGIS
 LEGIS  = GLEGSOC(find([F:FASW]CPY,GSOC))
 Local Char LEGI1
 Local Char LEGI2
 Local Char LEGI3
 LEGI1 = func TRTFAS.GET_MODE_LEGISLATION( "", "UD" )
 LEGI2 = func TRTFAS.GET_MODE_LEGISLATION( "", "DB" )
 LEGI3 = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )

 If ( ( PAYS1 = "" and LEGI1 = "" ) or ( PAYS2 = "" and LEGI2 ="" ) or ( PAYS3 = "" and LEGI3 ="" ) or
&     ( PAYS1 <> "" and PAYSS = PAYS1 and LEGI1 <> "" and LEGIS = LEGI1 ) or
&     ( PAYS2 <> "" and PAYSS = PAYS2 and LEGI2 <> "" and LEGIS = LEGI2 ) or
&     ( PAYS3 <> "" and PAYSS = PAYS3 and LEGI3 <> "" and LEGIS = LEGI3 )     ) Then
  Chgfmt [M:FAS3]ACLCOE With "N:3.6#"
 Else
  Chgfmt [M:FAS3]ACLCOE With "-N:3.6#"
 Endif

End

########################################
Subprog C_ACLCOE(VALEUR)
Variable Decimal VALEUR
  If ( VALEUR <> 0 and
&      find([M:FAS3]DPM(nolign-1), G_DPMUD, G_DPMTD, G_DPMDB, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMML, G_DPMMD ) = 0 ) Then
    # FQ59941 FQ67577 FQ72372 FQ105809
    # Le coefficient d'accélération ne concerne pas ce mode.
    GERR= 1: GMESSAGE = mess(569,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
  If ( VALEUR <> 0  and [M:FAS3]DPM(nolign-1) = G_DPMDB and (VALEUR < 1. or VALEUR > 2.) ) Then
    # Le coefficient d'accélération doit être > à 1 et <= 2.
    GERR= 1: GMESSAGE = mess(575,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
  If ( VALEUR <> 0  and find([M:METH]DPM , G_DPMLR, G_DPMDR, G_DPMCR) and (VALEUR < 0. or VALEUR > 3.) ) Then
    # Le coefficient d'accélération pour les modes russes  doit être > à 0 et <= 3.
    GERR= 1: GMESSAGE = mess(809,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

########################################
Subprog AS_PRATYP(VALEUR)
Variable Integer VALEUR
  If ( find([M:FAS3]DPM(nolign-1), G_DPMUD,G_DPMUL,G_DPMTD) >0 ) Then
    # Si le type de prorata est "Declining Balance", "Straight line" ou "Dégressif turque"
    # le prorata ne peut pas être "Jour" ni "Semaine". FQ105809
    GMENLOC(GVML_TPJOUR) = 1
    GMENLOC(GVML_TPSEMA) = 1
  Endif
  If ( find ([M:FAS3]DPM(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL) > 0 ) Then
    # Si le type de prorata est "Linéaire suisse", "Dégressif suisse", "Linéaire Turque"
    # le prorata ne peut être que "Jour" ou "Mois". FQ84281, FQ105809
    GMENLOC(GVML_TPSEMA) = 1
    GMENLOC(GVML_TPONZE) = 1
    GMENLOC(GVML_TPHLFY) = 1
    GMENLOC(GVML_TPHLFM) = 1
    GMENLOC(GVML_TPHLFQ) = 1
  Endif
  # F101532
  If ( [M:FAS3]DPM(nolign-1) = G_DPMRE ) Then
    # Si le type de prorata est "Résiduel", le prorata ne peut être que "Jour", "Mois" ou "Semaine".
    GMENLOC(GVML_TPHLFY) = 1
    GMENLOC(GVML_TPHLFM) = 1
    GMENLOC(GVML_TPHLFQ) = 1
  Endif

End


########################################
Subprog C_PRATYP(VALEUR)
Variable Integer VALEUR
  If ( VALEUR = 0 and find([M:FAS3]DPM(nolign-1), G_DPMUD, G_DPMTD, G_DPMUL, G_DPMRE, G_DPMHL, G_DPMHD, G_DPMTL) <> 0 ) Then
    # Le type de prorata doit être saisi pour
    # le "Declining Balance", "Straight line", "Linéaire turque", "Dégressif turque ou "Residuel". FQ84281, FQ105809
    GERR= 1: GMESSAGE = mess(571 ,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

########################################
Subprog AM_PRATYP(VALEUR)
Variable Integer VALEUR
  #FQ54343
  # Modif réduite
  [M:FAS3]PRATYP(nolign-1) = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2
End

########################################
Subprog C_STRDPRDAT(VALEUR)
Variable Date    VALEUR

Local Integer    OK

  # Demande de confirmation lorsque la date de début d'amort est < à la date d'achat.
  If ( [M:FAS1]PURDAT > VALEUR ) Then
    Call OUINON(mess(16,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1) Then : mkstat = 2 : End : Endif
  Endif
  # Demande de confirmation lorsque la date de début d'amort est < à la date de comptabilisation.
  If ( [M:FAS1]AASIPTDAT > VALEUR ) Then
    Call OUINON(mess(35,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1) Then : mkstat = 2 : End : Endif
  Endif
End

########################################
Subprog AM_STRDPRDAT(VALEUR)
Variable Date    VALEUR
  # le cumul d'amt peut devenir saisissable en fonction de la date de début d'amortissement
  [M:FAS3]STRDPRDAT(nolign-1) = VALEUR
  Gosub MODIF_REDUITE  From SUBFAS2
End

###########################################
Subprog AM_DPRBAS(VALEUR)
Variable Decimal VALEUR
Local    Decimal MTDES
Local Integer OK #104164

  # La valeur amortissable doit avoir le même signe que le montant HT de son origine
  # (pas de contrôle si saisie manuelle ou subvention)
  If GIMPORT : # FQ96106
    # En import le champ est DPRBAS déjà affecté, contrairement à l'interactif où il contient encore son ancienne valeur
    # Pour déterminer DPRVAL on se base sur base amrtissement - valeur résiduelle
    MTDES = VALEUR - [M:FAS3]RSDVAL(nolign-1)
  Else
    MTDES = [M:FAS3]DPRVAL(nolign-1) - [M:FAS3]DPRBAS(nolign-1) + VALEUR
  Endif

  Case [M:FAS3]ORIBAS(nolign-1)
    When GVML_OBPCG
      If (MTDES<>0) and (sgn(MTDES)+sgn([M:FAS1]ACGETRNOT)=0) Then
        GERR= 1: GMESSAGE = mess(46,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    When GVML_OBIAS
      If (MTDES<>0) and (sgn(MTDES)+sgn([M:FAS1]IASETRNOT)=0) Then
        GERR= 1: GMESSAGE = mess(46,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    When Default
  Endcase

  # FQ104164
  If VALEUR <> [M:FAS3]DPRBAS(nolign-1) and GNBDEPLIEES

    Call AVERTIR(mess(934,GML_MSGFAS,1), OK) From GESECRAN
    If (OK = 1) Then
      GERR = 1 : OK = 0
      mkstat = 2 : End
    Endif
  Endif

  [M:FAS3]DPRVAL(nolign-1) = MTDES
  Affzo [M:FAS3]DPRVAL(nolign-1)

  # RI370
  #If ( [M:FAS3]ORIBAS(nolign-1) = GVML_OBSAI ) Then : # FQ59253
    [M:FAS3]BSEVAL(nolign-1) = VALEUR
  #Endif
End

########################################
Subprog AM_RSDVAL(VALEUR)
Variable Decimal VALEUR

Local Decimal MTDES
Local Integer STAT

  MNTDES = [M:FAS3]DPRBAS(nolign-1) - VALEUR

  # La valeur amortissable doit avoir le même signe que le montant HT de son origine
  # (pas de contrôle si saisie manuelle ou subvention)
  Case [M:FAS3]ORIBAS(nolign-1)
    When GVML_OBPCG
      If (MNTDES<>0) and (sgn(MNTDES)+sgn([M:FAS1]ACGETRNOT)=0) Then
        GERR= 1: GMESSAGE = mess(46,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    When GVML_OBIAS
      If (MNTDES<>0) and (sgn(MNTDES)+sgn([M:FAS1]IASETRNOT)=0) Then
        GERR= 1: GMESSAGE = mess(46,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    When Default
  Endcase

  [M:FAS3]DPRVAL(nolign-1) = MNTDES
  Affzo [M:FAS3]DPRVAL(nolign-1)

  # La valeur résiduelle pour le plan fiscal d'un bien d'une société française doit être nulle
  If (  VALEUR <> 0 and [M:FAS3]DPRPLN(nolign-1) = G301FIS and
&    ( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) ) Then
#&       ( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) ) Then # FQ57624
    GERR= 1: GMESSAGE = mess(586,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif

  # Si la valeur résiduelle est changée sur un plan normé
  # la valeur résiduelle doit être reportée sur tous les plans normés avec conversion éventuelle.
  #- 1 -------------------
  If ( VALEUR and find ([M:FAS3]PLNSTD(nolign-1), GVML_NPCRC, GVML_NPIAS) ) Then
    Local Integer I_PLN
    #> 2 >>>>>>>>>>>>>>>>>>>>>>>
    For I_PLN=1 To [M:FAS3]NBLIG1
      #- 3 -------------------
      If ( I_PLN <> nolign and find ([M:FAS3]PLNSTD(I_PLN-1), GVML_NPCRC, GVML_NPIAS) ) Then
      # Plan normé
        #- 4 -------------------
        If (  [M:FAS3]CUR(I_PLN-1) = [M:FAS3]CUR(nolign-1) ) Then
          # Mêmes devises alors report sans conversion
          MNTDES = [M:FAS3]DPRBAS(I_PLN-1) - VALEUR
          # La valeur amortissable doit avoir le même signe que le montant HT de son origine
          If  ([M:FAS3]ORIBAS(I_PLN-1)=GVML_OBPCG) and (sgn(MNTDES) + sgn([M:FAS1]ACGETRNOT) <> 0)
&         or  ([M:FAS3]ORIBAS(I_PLN-1)=GVML_OBIAS) and (sgn(MNTDES) + sgn([M:FAS1]IASETRNOT) <> 0)
&         or  (MNTDES = 0)
            [M:FAS3]DPRVAL(I_PLN-1)=MNTDES : Affzo [M:FAS3]DPRVAL(I_PLN-1)
            [M:FAS3]RSDVAL(I_PLN-1)=VALEUR : Affzo [M:FAS3]RSDVAL(I_PLN-1)
          Endif
        Endif
        #- 4 -------------------
      Endif
      #- 3 -------------------
    Next I_PLN
    #> 2 >>>>>>>>>>>>>>>>>>>>>>>
  Endif
  #- 1 -------------------

End

######################################################################################
Subprog AV_ENDDPRDAT(VALEUR)
Variable Date    VALEUR
  #FQ54343
  # Gestion du code forçage
  If ([M:FAS3]ENDDPRFLG(nolign-1) = G_OUI ) Then
    Chgstl [M:FAS3]ENDDPRDAT(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:FAS3]ENDDPRDAT(nolign-1) With ""
  Endif
End

###########################################
Subprog AS_ENDDPRDAT(VALEUR)
Variable Date    VALEUR
  # Gestion du code forçage
  If ( [M:FAS3]ENDDPRFLG(nolign-1) <> G_OUI  or
&      func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]ENDDPRDAT", nolign-1) <> G_OUI ) Then
    GBOUT1 = ""
  Endif
End

###########################################
Subprog C_ENDDPRDAT(VALEUR)
Variable Date    VALEUR
  #FQ54343
  # La date de fin d'amortissement saisie ne peut pas être antérieure à la date de début d'amortissement
  If ( VALEUR <> [0/0/0] and VALEUR < [M:FAS3]STRDPRDAT(nolign-1) ) Then
      GERR= 1: GMESSAGE = mess(694,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
  # La date de fin d'amortissement saisie ne peut pas être antérieure à la date de début d'exercice du contexte
  If ( VALEUR <> [0/0/0] and VALEUR < [M:FAS3]FIYSTRDAT(nolign-1) ) Then
      GERR= 1: GMESSAGE = mess(695,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

###########################################
Subprog AM_ENDDPRDAT(VALEUR)
Variable Date    VALEUR
  #FQ54343
  # La date de fin d'amortissement a été modifiée alors recalcul forcé
  G_ARECALCULER = 1

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR")  ) Then
    G_DEFORCE = 0
  Else
    # Issue 116168 If (VALEUR <> [0/0/0] and
    # Issue 116168 &       ( [M:FAS3]DPM(nolign-1) = G_DPMRA or ([M:FAS3]DPM(nolign-1) = G_DPMRE and [M:FAS3]PRATYP(nolign-1) = GVML_TPJOUR) )) Then
    If VALEUR <> [0/0/0] and
&      ( find ([M:FAS3]DPM(nolign-1), G_DPMPC, G_DPMPD, G_DPMRA) > 0 or
&             ([M:FAS3]DPM(nolign-1)= G_DPMRE and [M:FAS3]PRATYP(nolign-1)= GVML_TPJOUR) )
      # Issue 116168  [M:FAS3]DPRDUR(nolign-1)    = 0    :  Affzo [M:FAS3]DPRDUR(nolign-1)
      # Issue 116168 remise à zéro de la durée : uniquement si mode <> PC et PD
      If  find ([M:FAS3]DPM(nolign-1), G_DPMPC, G_DPMPD) = 0
        [M:FAS3]DPRDUR(nolign-1)    = 0    :  Affzo [M:FAS3]DPRDUR(nolign-1)
      Endif  # Issue 116168
      [M:FAS3]ENDDPRFLG(nolign-1) = G_OUI:  Affzo [M:FAS3]ENDDPRFLG(nolign-1)
      Chgstl [M:FAS3]ENDDPRDAT(nolign-1) With "TFORCAGE"
    Else
      [M:FAS3]ENDDPRFLG(nolign-1) = G_NON:  Affzo [M:FAS3]ENDDPRFLG(nolign-1)
      Chgstl [M:FAS3]ENDDPRDAT(nolign-1) With [0/0/0]
    Endif
  Endif
  # la durée peut devenir saisissable en fonction de la date de fin d'amortissement
  [M:FAS3]ENDDPRDAT(nolign-1) = VALEUR
  Gosub MODIF_REDUITE  From SUBFAS2
End

###########################################
Subprog B1_ENDDPRDAT(VALEUR)
Variable Date    VALEUR
  #FQ54343
  # Gestion du code forçage
  [M:FAS3]ENDDPRFLG(nolign-1) = G_NON
  Affzo [M:FAS3]ENDDPRFLG(nolign-1)

  Raz [M:FAS3]ENDDPRDAT(nolign-1)
  Raz VALEUR


  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS3]ENDDPRDAT(nolign-1)  With ""
  Affzo [M:FAS3]ENDDPRDAT(nolign-1)
  mkstat = 99

End


######################################################################################
Subprog AV_DPRCUM(VALEUR)
Variable Decimal VALEUR

  # FQ86558
  If (GREP = "C") and ([M:FAS0]PRVSITUPD <> G_OUI)
    [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI
  Endif

  # Gestion du code forçage
  If ([M:FAS3]DPRCUMFLG(nolign-1) = G_OUI ) Then
    Chgstl [M:FAS3]DPRCUM(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:FAS3]DPRCUM(nolign-1) With ""
  Endif

End

###########################################
Subprog AS_DPRCUM(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  # FQ86558
#  If ( [M:FAS3]DPRCUMFLG(nolign-1) <> G_OUI  or
#&      func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRCUM", nolign-1) <> G_OUI ) Then
  If ( [M:FAS3]DPRCUMFLG(nolign-1) <> G_OUI  or
&      func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS3]DPRCUM", nolign-1) <> G_OUI or
&      [M:FAS0]PRVSITUPD <> G_OUI) Then
    GBOUT1 = ""
  Endif
End

###########################################
Subprog AM_DPRCUM(VALEUR)
Variable Decimal VALEUR
  # Le cumul a été modifié alors recalcul forcé
  G_ARECALCULER = 1

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR")  ) Then
    G_DEFORCE = 0
  Else
    # FQ86558
    #If (VALEUR <> 0 ) Then
    If (VALEUR <> 0 ) or ([M:FAS0]PRVSITUPD <> G_OUI) Then
      [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI:  Affzo [M:FAS3]DPRCUMFLG(nolign-1)
      Chgstl [M:FAS3]DPRCUM(nolign-1) With "TFORCAGE"
    Else
      [M:FAS3]DPRCUMFLG(nolign-1) = G_NON:  Affzo [M:FAS3]DPRCUMFLG(nolign-1)
      Chgstl [M:FAS3]DPRCUM(nolign-1) With ""
    Endif
  Endif
End

###########################################
Subprog C_DPRCUM(VALEUR)
Variable Decimal VALEUR
  ## Le cumul d'amortissement ne doit pas être supérieure à la valeur amortissable (en valeur absolue)
  #If ( abs(VALEUR) > abs([M:FAS3]DPRVAL(nolign-1)) ) Then
  #    GERR= 1: GMESSAGE = mess(237,GML_MSGFAS,1)
  #  mkstat = 2 : End
  #Endif

  # FQ72796
  Local Integer OK
  Local Char    MESSAGE(255)
  Local Decimal L_ENDDPE

  If ( abs(VALEUR) > abs([M:FAS3]DPRVAL(nolign-1)) ) Then
    L_ENDDPE = [M:FAS3]DPRVAL(nolign-1) - VALEUR
    If GIMPORT
      Call ECR_TRACE(num$(nolign)-num$([M:FAS3]DPRVAL(nolign-1))-num$(VALEUR),0) From GESECRAN
      [M:FAS3]ENDDPE(nolign-1)    = L_ENDDPE
      [M:FAS3]ENDDPEFLG(nolign-1) = G_OUI
      Call ECR_TRACE(mess(237,GML_MSGFAS,1),-1) From GESECRAN : # FQ96106
      Call ECR_TRACE(func GLOFUNC.SUBSTIT2(mess(841,GML_MSGFAS,1),
&                                          num$([M:FAS3]ENDDPE(nolign-1)),
&                                          mess([M:FAS3]DPRPLN(nolign-1),GML_NPLAN,1)),-1) From GESECRAN
    Else
      MESSAGE = func GLOFUNC.SUBSTIT1(mess(840,GML_MSGFAS,1), num$(L_ENDDPE))
      Call OUINON(mess(237,GML_MSGFAS,1)-MESSAGE-"\"-mess(205,100,1), OK) From GESECRAN
      If ( OK = 1) Then
        mkstat = 2 : End
      Else
        [M:FAS3]ENDDPE(nolign-1)    = L_ENDDPE
        [M:FAS3]ENDDPEFLG(nolign-1) = G_OUI
      Endif
    Endif
    [M:FAS3]ENDDPEI(nolign-1) = [M:FAS3]ENDDPE(nolign-1)
    [M:FAS3]ENDDPET(nolign-1) = [M:FAS3]ENDDPE(nolign-1)
  Endif
End

###########################################
Subprog B1_DPRCUM(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  [M:FAS3]DPRCUMFLG(nolign-1) = G_NON
  Affzo [M:FAS3]DPRCUMFLG(nolign-1)

  Raz [M:FAS3]DPRCUM(nolign-1)
  Raz VALEUR

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS3]DPRCUM(nolign-1)  With ""
  Affzo [M:FAS3]DPRCUM(nolign-1)
  mkstat = 99
End

###########################################
Subprog AS_ALWCOD(VALEUR)
Variable Integer VALEUR

  # FQ54343
  Global Char  G_COURDPM, G_COURPLN
  Local  Char  PNOMVAR
  PCLASSE    =  "[M:FAS3]"
  PNOMVAR    =  "DPM(nolign-1)"
  G_COURDPM  =   PCLASSE+PNOMVAR
  PNOMVAR    =  "DPRPLN(nolign-1)"
  G_COURPLN  =   PCLASSE+PNOMVAR

  If ( [M:FAS3]DPM(nolign-1) <> "" )  or ( [M:FAS3]DPRPLN(nolign-1) <> G301FIS )
    Gosub COMMUN_AS_ALWCOD From TRTFAS
  Endif
  G_COURDPM = ""
  G_COURPLN = ""

End

###########################################
Subprog AM_ALWCOD(VALEUR)
Variable Integer VALEUR

  If ( VALEUR = GVML_RPALOGI and [M:FAS3]DPM(nolign-1) = G_DPMLP ) Then
    #-- Pour le logiciel, la durée est de 12 mois
    [M:FAS3]DPRDUR(nolign-1)   = 1.    : Affzo [M:FAS3]DPRDUR(nolign-1)
    [M:FAS3]DPRRAT(nolign-1)   = 1.    : Affzo [M:FAS3]DPRRAT(nolign-1)
    [M:FAS3]DPRRATFLG(nolign-1)= G_NON : Affzo [M:FAS3]DPRRATFLG(nolign-1)
    Chgstl [M:FAS3]DPRRAT(nolign-1) With ""
  Endif

  # FQ64491 : à ne pas faire en import car la classe [M:FAS3] est alors déjà alimentée
  If ( !GIMPORT and [M:FAS3]ALWCOD(nolign-1) = GVML_RPALOGI and [M:FAS3]DPM(nolign-1) = G_DPMLP ) Then
    [M:FAS3]DPRDUR(nolign-1)   = 0.    : Affzo [M:FAS3]DPRDUR(nolign-1)
    [M:FAS3]DPRRAT(nolign-1)   = 0.    : Affzo [M:FAS3]DPRRAT(nolign-1)
    G_DEROUTE = "[M:FAS3]DPRDUR("+num$(nolign-1)+")"
  Endif

  [M:FAS3]ALWCOD(nolign-1) = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2

  #FQ59941
  If ([M:FAS3]ALWCOD(nolign-1) = GVML_RPBONUS ) Then
    zonsui = "[M:FAS3]DPRRAT2("+num$(nolign-1)+")"
  Endif


End

###########################################
Subprog AV_CCNTYPPLN(VALEUR)
Variable Char VALEUR
 If G_ACTCCN=G_OUI
  If G_CCNFLG=G_OUI
   Chgfmt [M:FAS3]CCNTYPPLN With "K:15X"
  Else
   Chgfmt [M:FAS3]CCNTYPPLN With "-K:15X"
  Endif
 Endif
End

#*********************************************************************
#*********************************************************************
#         *FAS4            E C R A N      F A S 4
#*********************************************************************
#*********************************************************************
#
###########################################
Subprog AV_ISSVATAMT(VALEUR)
Variable Decimal VALEUR
  If ( [M:FAS4]ISSVATFLG = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS4]ISSVATAMT With "FORCAGE"
    Else
      Chgstl [M:FAS4]ISSVATAMT With "TFORCAGE"
    Endif

  Else
   Chgstl [M:FAS4]ISSVATAMT With ""
  Endif
End

###########################################
Subprog AV_SHOGAL(VALEUR)
Variable Decimal VALEUR
 #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
 If !( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
  Chgfmt [M:FAS4]SHOGAL With "-Nz3:13.2#"
 Else
  Chgfmt [M:FAS4]SHOGAL With "Nz3:13.2#"
  Diszo  [M:FAS4]SHOGAL
 Endif
End

###########################################
Subprog AV_LNGGAL(VALEUR)
Variable Decimal VALEUR
 #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
 If !( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
  Chgfmt [M:FAS4]LNGGAL With "-Nz3:13.2#"
 Else
  Chgfmt [M:FAS4]LNGGAL With "Nz3:13.2#"
  Diszo  [M:FAS4]LNGGAL
 Endif
End


#*********************************************************************
#         *FAS6            E C R A N      F A S 6
#*********************************************************************

#
#         *  -----  Voir   SUBFASCCN
#

#*********************************************************************
#                     S o u s - p r o g r a m m e s
#*********************************************************************


#*************************************
#*     INITIALISATION GENERALE       *
#*************************************

$INIT_GENERALE

Local Integer  TEMP

  # Initialisation devise PCG
  If ( GCNXCURCPF <> "" ) Then
    [M:FAS1]ACGCUR=GCNXCURCPF : Affzo [M:FAS1]ACGCUR
  Endif

  # Plan IAS géré
  If (G_PLNIAS) and (G_ACTIAS = G_OUI) Then : # FQ57624
    # ----- Lecture contexte IAS
    Read [CNX] CNX0=[M:FAS0]CPY;G_CNXIAS
    If ( fstat ) Then : Raz [F:CNX] : Endif
    [M:FAS1]IASCURTYP=[F:CNX]CURTYP : Affzo [M:FAS1]IASCURTYP
    # -----  Initialisation devise IAS
    [M:FAS1]IASCUR=GCNXCURIAS       : Affzo [M:FAS1]IASCUR
  Endif
Return

#
########################################
$INIT_LIENS
  # Ensemble
  If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]SET", 0) = G_NON ) Then : Actzo [M:FAS1]SET : Endif
  If ([M:FAS1]SET = [M:FAS0]AASREF ) Then
    Filter [FASW] Where SET = [M:FAS0]AASREF and AASREF <> [M:FAS1]SET
    Read[FASW] First Hint Key FAS3
    If ( fstat = 0 ) Then
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]SET", 0) = G_OUI ) Then : Diszo [M:FAS1]SET : Endif
    Endif
    Filter [FASW]
  Endif

  # Bien possède au moins un composant
  [M:FAS0]LIKCMPFLG = G_OUI
  Filter [FASW] Where CMP = [M:FAS0]AASREF
  Read[FASW] First Hint Key FAS5
  If ( fstat ) Then
    [M:FAS0]LIKCMPFLG = G_NON
  Endif
  Filter [FASW]

  # Statut du bien
  If ( [M:FAS1]CMPSTA = GVML_SBPRINC and [M:FAS0]LIKCMPFLG = G_OUI ) Then
    # Si le statut est "Principal", Statut non modifiable si des biens sont rattachés au bien principal
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]CMPSTA", 0) = G_OUI ) Then : Diszo [M:FAS1]CMPSTA : Endif
  Endif

  #- 1 ------------------------------
  If ( [M:FAS0]ENAFAS = G_NON ) Then
    # Si le bien est inactif, on doit toujours permettre de le passer en actif
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]ENAFAS", 0) = G_NON ) Then : Actzo [M:FAS0]ENAFAS : Endif
  #- 1 ------------------------------
  Else
    If ( GDISAFAS = G_OUI and func GLOBIENS.IS_FAS_MODIFIED ([M:FAS0]CPY, [M:FAS0]AASREF) = G_NON and
&        [M:FAS4]ISSDAT = [0/0/0] ) Then
      # Si on autorise la saisie des biens inactifs et que le bien n'a jamais subi de traitement
      # et qu'il n'est pas sorti, on peut le passer en "inactif"...
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]ENAFAS", 0) = G_NON ) Then : Actzo [M:FAS0]ENAFAS : Endif
    Else
      # ...sinon il ne peut pas passer en "inactif"
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]ENAFAS", 0) = G_OUI ) Then : Diszo [M:FAS0]ENAFAS : Endif
    Endif
  Endif
  #- 1 ------------------------------

  #- 1 ------------------------------
  If ( [M:FAS0]ENAFAS = G_OUI ) Then
    # Diszo de certains champs
    # -- FAS0
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS0]FCY"   , 0) = G_OUI ) Then : Diszo [M:FAS0]FCY    : Endif

    # -- FAS1
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]OWNTYP", 0) = G_OUI ) Then : Diszo [M:FAS1]OWNTYP : Endif
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACGGRP", 0) = G_OUI ) Then : Diszo [M:FAS1]ACGGRP : Endif
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ACCCOD", 0) = G_OUI ) Then : Diszo [M:FAS1]ACCCOD : Endif
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]ITSDAT", 0) = G_OUI ) Then : Diszo [M:FAS1]ITSDAT : Endif  : # FQ63917

    Call ACTION_BLOCK (ACB_DISZO, "FAS1", "ACGCUR") From GLOBIENS   # Rubriques Valorisation PCG
    Call ACTION_BLOCK (ACB_DISZO, "FAS1", "IASCUR") From GLOBIENS   # Rubriques Valorisation IAS
    If func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]AASBUS", 0) = G_OUI Then : Diszo [M:FAS1]AASBUS : Endif

    # -- FAS2

    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]DSP", 0) = G_OUI ) Then : Diszo [M:FAS2]DSP : Endif
    Diszo [M:FAS2]NBRCCE

    Call ACTION_BLOCK (ACB_DISZO, "FAS2", "IASCGU") From GLOBIENS   # Rubriques IAS (CGU, secteurs 1 & 2)
    If (G_ACTKRU = G_OUI and func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS2]KPSEPLN", 0) = G_OUI ) Then : Diszo [M:FAS2]KPSEPLN : Endif

    # -- FAS3
    # Réactivation de la ligne origine.
    Call ACTION_BLOCK (ACB_DISZO, "FAS3", "NBLIG1") From GLOBIENS   # Plans d'amortissement
    # FQ95196 : le code ci-dessous est faux (la valeur de nolign est aléatoire et ne correspond pas forcément au plan fiscal)
    #           il est mis en commentaire plutôt que corrigé car déjà traité correctement dans ACTIVE_TOUTES_RUBRIQUES de SUBFAS2
    #If [M:FAS3]DPRPLN(nolign-1) = G301FIS      #FQ-62386 activation Plafond véhicule si plan fiscal
    #   Actzo [M:FAS3]CRBVEHCOD
    #Endif
    # -- FAS6
    If ([M:FAS1]OWNTYP = GVML_TDCONCE) Then
      If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]RNWDONFLG", 0) = G_OUI ) Then : Diszo [M:FAS6]RNWDONFLG : Endif
      Call ACTION_BLOCK (ACB_DISZO, "FAS6", "TPAFLG") From GLOBIENS
      Call ACTION_BLOCK (ACB_DISZO, "FAS6", "CCNACTCOD") From GLOBIENS
      If ( G_CCNRPR = G_OUI ) Then
        # FQ66188 : Si le bien est "en cours", il est possible de modifier le type d'apport et l'origine d'apport
        If [M:FAS1]GACACN = GVML_NIENCOU
          If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]CCNETRNAT", 0) = G_NON ) Then : Actzo [M:FAS6]CCNETRNAT : Endif
          If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]CCNETRTYP", 0) = G_NON ) Then : Actzo [M:FAS6]CCNETRTYP : Endif
          If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]CCNETRTYP", 0) = G_OUI ) Then : Diszo [M:FAS6]CCNREF    : Endif
        Else
          Call ACTION_BLOCK (ACB_DISZO, "FAS6", "CCNREF" ) From GLOBIENS
        Endif
        # FIN FQ66188
        If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]VISRPR",    0) = G_NON ) Then : Actzo [M:FAS6]VISRPR    : Endif
        Local Char    LIBZON(100)
        Call TEXTE(41826, LIBZON) From OBJDIV
        Chgtzn [M:FAS6]VISRPR  With LIBZON
      Else
        If ( [M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]EXTISSFLG <> G_OUI ) Then
          Call ACTION_BLOCK (ACB_DISZO, "FAS6", "CCNREF" ) From GLOBIENS
        Endif
      Endif
    Endif

  Endif
  #- 1 ------------------------------
Return


#
#*****************************
#*   LECTURE_PARAMETRES      *
#*****************************

Subprog LECTURE_PARAMETRES(PFCY)
Variable Char PFCY

Local Char    LPARM(10)

  # Remise en cause de la situation après clôture autorisée
  Call PARAM(PFCY,"PRVSITUPD",LPARM) From ADOVAL
  [M:FAS0]PRVSITUPD = val(LPARM)

  # Bien complémentaire % Durée d'amortissement
  Call PARAM(PFCY,"CPLDURPRC",LPARM) From ADOVAL
  GCPLDURPRC= val(LPARM)

  # Bien complémentaire Durée d'amortissement minimum
  Call PARAM(PFCY,"CPLDURMIN",LPARM) From ADOVAL
  GCPLDURMIN = val(LPARM)
End

#
#*****************************
#*   CALCUL_MONTANTS_TVA     *
#*****************************

########################################
$CALCUL_MONTANTS_TVA

Local Decimal MTDES
Local Integer STAT

  # TVA facturée PCG = Montant achat HT * ( Taux TVA facturée / 100 )
  Gosub TVA_FAC_PCG
  # TVA récupérée PCG = TVA facturée PCG * ( Taux TVA récupérée / 100 )
  Gosub TVA_REC_PCG

  # Champs relatifs au plan IAS à ne traiter que si le plan IAS est géré

  # Conversion PCG -> IAS
  Gosub CONV_PCG_IAS
  # TVA facturée IAS = Valeur HT * ( Taux TVA facturée / 100 )
  Gosub TVA_FAC_IAS
  # TVA récupérée IAS = TVA facturée IAS * ( Taux TVA récupérée / 100 )
  Gosub TVA_REC_IAS

  #===========================
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
Return

########################################
$TVA_FAC_PCG
    # TVA facturée PCG = Montant achat HT * ( Taux TVA facturée / 100 )
  If ( [M:FAS1]IVCVATFLG <> G_OUI )  Then
    [M:FAS1]IVCVATAMT = [M:FAS1]ACGETRNOT * ([M:FAS1]IVCVATRAT / 100 )
    Call GET_MNT_ARRONDI ([M:FAS1]IVCVATAMT, [M:FAS1]ACGCUR, [M:FAS1]IVCVATAMT ) From GLOBIENS
    Affzo [M:FAS1]IVCVATAMT
  Else
    If (GNBDEPLIEES = 0) Then
      Diszo [M:FAS1]IVCVATAMT #*FQ98116
    Endif
  Endif

Return
########################################
$TVA_REC_PCG
    # TVA récupérée PCG = TVA facturée PCG * ( Taux TVA récupérée / 100 )
  If ( [M:FAS1]DEDVATFLG <> G_OUI)  Then
    [M:FAS1]DEDVATAMT = [M:FAS1]IVCVATAMT * ([M:FAS1]DEDVATRAT / 100 )
    Call GET_MNT_ARRONDI ([M:FAS1]DEDVATAMT, [M:FAS1]ACGCUR, [M:FAS1]DEDVATAMT ) From GLOBIENS
    Affzo [M:FAS1]DEDVATAMT
  Else
    If (GNBDEPLIEES = 0) Then
      Diszo [M:FAS1]DEDVATAMT #*FQ98116
    Endif
  Endif

  If ( [M:FAS1]DEDVATRAT = 100 ) Then
    Diszo [M:FAS1]DEDVATAMT
  Endif


Return
########################################
$CONV_PCG_IAS

Local Decimal MTDES
Local Integer STAT


  If (G_PLNIAS) Then
    # FQ93595 La valeur HT IAS vient des dépenses : elle ne doit pas être recalculée
    If GNBDEPLIEES = 0
      # ------------- Conversion en devise IAS
      Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
&                  [M:FAS1]ACGETRNOT, MTDES, [M:FAS1]IASRATCUR, STAT) From CPTSUB
      If STAT
        GMESSAGE = mess(18,GML_MSGFAS,1)
        GERR=1
        mkstat = 2
        Return #End
      Endif

      Call GET_MNT_ARRONDI (MTDES, [M:FAS1]IASCUR, MTDES) From GLOBIENS
      [M:FAS1]IASETRNOT = MTDES : Affzo [M:FAS1]IASETRNOT
      Affzo [M:FAS1]IASRATCUR
    Endif

    # ------------ Détermination du taux
    If ( [M:FAS1]IASRATCUR = 0 ) Then
      Call CDVCAL( [M:FAS1]IASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY,
&                  [M:FAS1]IASCURTYP, [M:FAS1]PURDAT ) From TRTDIV
      Affzo [M:FAS1]IASRATCUR
    Endif
  Endif

Return

########################################
$TVA_FAC_IAS

Local Decimal MTDES
Local Integer STAT

  If (G_PLNIAS) Then
    #*FQ98116 recalcul du montant TVA rec uniquement si pas forcé
    If ( [M:FAS1]IVCVATFLGI <> G_OUI ) Then
      # ----------- TVA facturée IAS = Valeur HT * ( Taux TVA facturée / 100 )
      [M:FAS1]IVCVATAMTI = [M:FAS1]IASETRNOT * ([M:FAS1]IVCVATRATI / 100 )
      Call GET_MNT_ARRONDI ([M:FAS1]IVCVATAMTI, [M:FAS1]IASCUR, [M:FAS1]IVCVATAMTI) From GLOBIENS
    Endif

    If ( [M:FAS1]IVCVATRATI = 100 ) Then
      Diszo [M:FAS1]IVCVATAMTI
    Endif

    Affzo [M:FAS1]IVCVATAMTI
  Endif

Return
########################################
$TVA_REC_IAS

Local Decimal MTDES
Local Integer STAT

  If (G_PLNIAS) Then
    #*FQ98116 recalcul du montant TVA rec uniquement si pas forcé
    If ([M:FAS1]DEDVATFLGI <> G_OUI )
      # ----------- TVA récupérée IAS = TVA facturée IAS * ( Taux TVA récupérée / 100 )
      [M:FAS1]DEDVATAMTI = [M:FAS1]IVCVATAMTI * ([M:FAS1]DEDVATRATI / 100 )
      Call GET_MNT_ARRONDI ([M:FAS1]DEDVATAMTI, [M:FAS1]IASCUR, [M:FAS1]DEDVATAMTI) From GLOBIENS
      Affzo [M:FAS1]DEDVATAMTI
    Endif

    If ( [M:FAS1]DEDVATRATI = 100 )
      Diszo [M:FAS1]DEDVATAMTI
    Endif

    Affzo [M:FAS1]DEDVATAMTI

  Endif

Return

#*****************************
#*   INIT_PLAN_AMT         *
#*****************************
#
########################################
$INIT_PLAN_AMT
Local Integer I_PLN
Local Date    FIYSTRDAT2,PERENDDAT2

  G_PLNIAS = 0
  G_CNXIAS = 0

  nolign = 1

  [M:FAS0]FISLIG = 1 # Affectation par défaut au comptable au cas où le fiscal n'existe pas

  #>1 >>>>>>>>>>>>>>>>>>
  For [CNX]CNX0 Where CPY =[M:FAS0]CPY

    # Suivant
    Filter [FIS] Where CPY=[M:FAS0]CPY and CNX = [F:CNX]CNX and STAFIY = GVML_TESUIV
    Read [FIS] First
    Filter [FIS]
    If ( fstat ) Then
      FIYSTRDAT2 = [0/0/0]
      FIYENDDAT2 = [0/0/0]
    Else
      FIYENDDAT2 = [F:FIS]DATENDFIY
      PERENDDAT2 = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif

    # Courant
    Filter [FIS] Where CPY=[M:FAS0]CPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
    Read [FIS]First
    Filter [FIS]
    If ( fstat ) Then
      Raz [F:FIS]
    Endif

    #>2 >>>>>>>>>>>>>>>>>>
    For I_PLN = 0 To [F:CNX]NBPLC-1
      If ( [F:CNX]PLNCAA(I_PLN) = G301FIS ) Then : [M:FAS0]FISLIG = nolign              : Endif
      If ( [F:CNX]PLNCAA(I_PLN) = G301IAS ) Then : G_PLNIAS = 1 : G_CNXIAS = [F:CNX]CNX : Endif
      [M:FAS3]DPRPLN(nolign-1)     = [F:CNX]PLNCAA(I_PLN)
      [M:FAS4]DPRPLN(nolign-1)     = [F:CNX]PLNCAA(I_PLN)
      [M:FAS3]PRATYP(nolign-1)     = 0
      If (G_ACTKRU = G_OUI) Then : [M:FAS3]SESFLG(nolign-1) = G_NON : Endif
      [M:FAS3]ORIBAS(nolign-1)     = [F:CNX]ORIBASDPR(I_PLN)
      [M:FAS3]CUR(nolign-1)        = [F:CNX]CUR
      [M:FAS3]CURTYP(nolign-1)     = [F:CNX]CURTYP
      [M:FAS3]CNX(nolign-1)        = [F:CNX]CNX
      [M:FAS3]UOM(nolign-1)        = GDEFUOM
      [M:FAS3]FIYSTRDAT(nolign-1)  = [F:FIS]DATSTRFIY
      [M:FAS3]FIYENDDAT(nolign-1)  = [F:FIS]DATENDFIY
      [M:FAS3]PERSTRDAT(nolign-1)  = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      [M:FAS3]PERENDDAT(nolign-1)  = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
      [M:FAS3]FIYENDDAT2(nolign-1) = FIYENDDAT2
      [M:FAS3]PERENDDAT2(nolign-1) = PERENDDAT2
      [M:FAS3]PLNSTD(nolign-1) = func GLOBIENS.GET_NORME_PLAN([M:FAS0]CPY, [M:FAS3]DPRPLN(nolign-1))
      # FQ75616
      [M:FAS3]BREPRISE(nolign-1)   = 0
      Gosub ALIM_CCNTYPPLN From SUBFASCCN
      nolign += 1
    Next I
    #<2 <<<<<<<<<<<<<<<<<<
    If (GREP = "C") Then
      [M:FAS0]FLGCNXCLC([F:CNX]CNX-1)    = G_OUI
    Endif
  Next
  #<1 <<<<<<<<<<<<<<<<<<
  [M:FAS3]NBLIG1 = nolign-1
  [M:FAS4]NBLIG4 = nolign-1
Return



#
#*****************************
#*   LOAD_PLAN_AMT           *
#*****************************
#
########################################
$LOAD_PLAN_AMT

Local Integer NOL


  For nolign = 1 To [M:FAS3]NBLIG1
    # Lecture DEPREC pour l'exercice et la période courante
    Read [DEP] DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(nolign-1);[M:FAS3]FIYENDDAT(nolign-1);
&              [M:FAS3]PERENDDAT(nolign-1)
    If ( fstat ) Then
      # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
      Filter [DEP] Where AASREF= [M:FAS0]AASREF and DPRPLN= [M:FAS3]DPRPLN(nolign-1)
      Read [DEP]DEP0 Last
      Filter [DEP]
      If ( fstat ) Then
        GMESSAGE = mess(193,7770,1)-":"-[M:FAS0]AASREF-mess(82,7770,1)-num$([M:FAS3]DPRPLN(nolign-1))
        GERR=1
        Return
      Endif
    Endif
    [M:FAS3] = [F:DEP]
    [M:FAS3]DPRVAL(nolign-1)  = [M:FAS3]DPRBAS (nolign-1) - [M:FAS3]RSDVAL(nolign-1)

    # FQ59941 FQ80825
    If (G_ACTKRU = G_OUI or (G_ACTDRO = G_OUI and [M:FPC]LEG="RUM") ) Then
      G_STPDEPSTAO([M:FAS3]DPRPLN(nolign-1)) =  [F:DEP]KSTPDEPSTA
    If (G_ACTKRU = G_OUI) Then
      If ( val(mid$([F:FAS]KSESFLG,[F:DEP]DPRPLN,1)) = G_OUI ) Then
        [M:FAS3]SESFLG(nolign-1) =  G_OUI
      Else
        [M:FAS3]SESFLG(nolign-1) =  G_NON
      Endif
    Endif
    Endif

    # FQ116251
    [M:FAS3]DPRBASORI(nolign-1) = [F:DEP]DPRBAS
    [M:FAS3]BSEVALORI(nolign-1) = [F:DEP]BSEVAL

    [M:FAS4] = [F:DEP]

    # FQ75616
    If ( [M:FAS1]OWNTYP = GVML_TDCONCE and G_CCNRPR = G_OUI and [M:FAS3]DPRPLN(nolign-1) = G_CCNPLNCAD ) Then
      # Si le bien est "En concession" et que le type de gestion est "Transmis par renouvellement" pour le plan de caducité
        [M:FAS6] = [F:DEP]
    Endif

    Gosub ALIM_CCNTYPPLN From SUBFASCCN
  Next nolign

Return


########################################
$REINIT_ETAB_DEPEND

Local Integer N_I

  Effzo [M:FAS1]SET                                        : # Ensemble
  [M:FAS1]CMPSTA = GVML_SBAUTON : Affzo [M:FAS1]CMPSTA     : # Statut Bien Autonome
  Effzo [M:FAS1]CMP                                        : # Bien principal
  [M:FAS1]OWNTYP = GVML_TDPROPR : Affzo [M:FAS1]OWNTYP     : # Type de détention

  # En cas de changement de site, on efface la famille et le code comptable
  # pour rejouer proprement les associations et refaire les controles sur les comptes.
  Effzo [M:FAS1]ACGGRP
  Effzo [M:FAS1]ACCCOD

  If ( G_ACTLEA = G_OUI ) Then
    Effzo [M:FAS2]LEAREF                                   : # Contrat de location
  Endif
  # FQ54343
  If ( G_ACTCCN = G_OUI ) Then
    Effzo [M:FAS6]                                         : # Contrat de concession
  Endif

  # Code Axes analytiques
  Effzo [M:FAS2]DIE
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
    [M:FAS2]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
  Next I_DIE
  Affzo [M:FAS2]DIE

  # >>>>>>
  Effzo [M:FAS2]DSP
  For N_I = 1 To GOPTCANA           : # Axes analytique
    If ([M:FAS2]CCE(N_I-1) <> "") Then
      Effzo [M:FAS2]CCE(N_I-1)
    Endif
  Next N_I
  # <<<<<<
Return

#######################################################################################
$MAJ_PLAN_SUBV
#
# Maj du plan de subvention avec le montant subventionné des dépenses rattachées
#

Local Integer I
Local Decimal WLAMTGRA
  WLAMTGRA=0
  # >>>>>>>>>>>>>>>>>>>
  For I = 1 To [M:LOF6]NBDEST
    Read [LOF]LOF0=[M:LOF6]CODLOF(I-1);[M:LOF6]LINLOF(I-1)
    If ( fstat = 0 and [F:LOF]FLGGRA = G_OUI ) Then
      WLAMTGRA+=[F:LOF]AMTGRA
    Endif
  Next I
  # >>>>>>>>>>>>>>>>>>>
  MTDES = WLAMTGRA

Return


#######################################################################################
$LOAD_GAL

  Local Integer I_PLN
  Local Decimal L_NBV

  If !clalev([F:WDEP]) : Local File DEPREC [WDEP] : Endif
  L_NBV    = 0.

  # >>>>>>>>>>>
  For I_PLN=1 To [M:FAS4]NBLIG4
    #-1 --------------
    If ( [F:FAS]ISSDAT <> [0/0/0] ) Then

      #-2 --------------
      If ([F:FAS]ISSDAT < [M:FAS3]PERSTRDAT(I_PLN-1)) Then
        # Sortie antérieure à la période courante
        If ( [F:FAS]ISSDAT >= [M:FAS3]FIYSTRDAT(I_PLN-1) ) Then
          # Dans l'exercice courant, on lit le DEPREC courant
          L_REQUETE  = "CPY=[M:FAS0]CPY and AASREF=[M:FAS0]AASREF and DPRPLN=[M:FAS4]DPRPLN(I_PLN-1) and "
          L_REQUETE += "FIYENDDAT=[M:FAS3]FIYENDDAT(I_PLN-1) and PERENDDAT=[M:FAS3]PERENDDAT(I_PLN-1)"
          Filter [F:WDEP] Where evalue(L_REQUETE)
          Read [F:WDEP] Last
          If (!fstat) Then :  L_NBV    = [F:WDEP]NBV  :  Endif
        Endif
        If ( [F:FAS]ISSDAT < [M:FAS3]FIYSTRDAT(I_PLN-1) ) Then
          # Dans un exercice antérieur, on lit le dernier DEPREC de l'exercice de sortie
          L_REQUETE  = "CPY=[M:FAS0]CPY and AASREF=[M:FAS0]AASREF and DPRPLN=[M:FAS4]DPRPLN(I_PLN-1) and "
          L_REQUETE += "FIYSTRDAT<=[F:FAS]ISSDAT and FIYENDDAT>=[F:FAS]ISSDAT"
          Filter [F:WDEP] Where evalue(L_REQUETE)
          Read [F:WDEP] Last
          If (!fstat) Then :  L_NBV    = [F:WDEP]NBV  :  Endif
        Endif
      #-2 --------------
      Elsif ([F:FAS]ISSDAT >= [M:FAS3]PERSTRDAT(I_PLN-1) and [F:FAS]ISSDAT <= [M:FAS3]PERENDDAT(I_PLN-1)) Then
        # Sortie dans la pér. courante, on prend le DEPREC courant
        L_REQUETE  = "CPY=[M:FAS0]CPY and AASREF=[M:FAS0]AASREF and DPRPLN=[M:FAS4]DPRPLN(I_PLN-1) and "
        L_REQUETE += "FIYENDDAT=[M:FAS3]FIYENDDAT(I_PLN-1) and PERENDDAT=[M:FAS3]PERENDDAT(I_PLN-1)"
        Filter [F:WDEP] Where evalue(L_REQUETE)
        Read [F:WDEP] Last
        If (!fstat) Then   :    L_NBV   = [F:WDEP]NBV  :  Endif
      #-2 --------------
      Elsif ([F:FAS]ISSDAT>=[M:FAS3]PERENDDAT(I_PLN-1)) Then
        # Sortie dans une pér. postérieure à la pér. courante, on lit le DEPREC contenant la date de sortie.
        L_REQUETE  = "CPY=[M:FAS0]CPY and AASREF=[M:FAS0]AASREF and DPRPLN=[M:FAS4]DPRPLN(I_PLN-1) and "
        L_REQUETE += "((PERSTRDAT= [0/0/0] and FIYSTRDAT<=[F:FAS]ISSDAT and FIYENDDAT>=[F:FAS]ISSDAT) or "
        L_REQUETE += " (PERSTRDAT<>[0/0/0] and PERSTRDAT<=[F:FAS]ISSDAT and PERENDDAT>=[F:FAS]ISSDAT))"
        Filter [F:WDEP] Where evalue(L_REQUETE)
        Read [F:WDEP] Last
        If (!fstat) Then   :    L_NBV   = [F:WDEP]NBV  :  Endif
      Endif
      #-2 --------------
    Endif
    #-1 --------------

    [M:FAS4]ISSAMT   (I_PLN-1) = [F:FAS]ISSAMT   ([M:FAS4]DPRPLN(I_PLN-1)-1)
    [M:FAS4]NBV      (I_PLN-1) = L_NBV
    [M:FAS4]GAL      (I_PLN-1) = [F:FAS]GAL      ([M:FAS4]DPRPLN(I_PLN-1)-1)
    [M:FAS4]SHOGAL   (I_PLN-1) = [F:FAS]SHOGAL   ([M:FAS4]DPRPLN(I_PLN-1)-1)
    [M:FAS4]LNGGAL   (I_PLN-1) = [F:FAS]LNGGAL   ([M:FAS4]DPRPLN(I_PLN-1)-1)

  Next I_PLN
  # >>>>>>>>>>>>

  Affzo [M:FAS4]15
  Filter [F:WDEP]


Return


Subprog CALCUL_DUREE_COMPL(PAASREF, RDUREE, RERR)

Value Char       PAASREF
Variable Decimal RDUREE
Value Integer    RERR

  RERR     = 0
  RDUREE   = 0.

  #-1 ----------------------------
  If ( GCPLDURPRC <> 0  ) Then
    Local Decimal L_DUREE
    Local Decimal DPRDUR1
    Local Decimal DURPLFD
    Local Decimal WDURANN
    Local Integer LOK
    # Calcul de la durée du plan fiscal pour un bien complémentaire (lecture du bien principal)
    Read [DEPW] DEP0=PAASREF;G301FIS;GFINEXECPF;GFINPERCPF
    If ( [F:DEPW]DEPSTA = GVML_SCNOCAL ) Then
      # Plan fiscal du bien principal non calculé
      RERR = 1
      End
    Endif
    # Durée plafond = ( Date déb amt fisc BC - Date de fin Amt BP )
    Call CALCUL_DUREE_EN_ANNEE
&   ([M:FAS3]STRDPRDAT([M:FAS0]FISLIG-1),[F:DEPW]ENDDPRDAT,WDURANN, LOK ) From GLOBIENS
    #-2 ----------------------------
    If ( LOK = G_OUI ) Then
      [L]DURPLFD = WDURANN
      [L]DPRDUR1 = 0
      #-----------------------------
      If (GCPLDURPRC <> 0 ) Then
        # Application d'un pourcentage sur la durée du bien principal
        [L]DPRDUR1 = arr([F:DEPW]DPRDUR * (GCPLDURPRC/100), 0.01)
        # La durée du bien complémentaire est égale au max ( Durée calculée , Durée minimum société)
        L_DUREE = max([L]DPRDUR1, GCPLDURMIN)
        # La durée ne dépassera jamais le plafond
        L_DUREE = min(L_DUREE, [L]DURPLFD)
        #-----------------------------
      Else
        L_DUREE = [M:FAS3]DPRDUR([M:FAS0]FISLIG-1)
        If ( [M:FAS3]STRDPRDAT([M:FAS0]FISLIG-1) <> [0/0/0] and [F:DEPW]ENDDPRDAT <> [0/0/0] ) Then
          # La durée saisie ne dépassera jamais le plafond
          L_DUREE = min([M:FAS3]DPRDUR([M:FAS0]FISLIG-1), [L]DURPLFD)
        Endif
      Endif
      #-----------------------------
    Endif
    #-2 ----------------------------

    RDUREE = L_DUREE

  Endif
  #-1 ----------------------------


End

# Fiche 48468
######################################################################################
$CHARGE_FAS8_ELT_PHY
######################################################################################
  Local Integer WINDICE
  WINDICE = 0

    # FQ100398/13
  # Ouverture de la table des éléments physiques
  If clalev([F:PHYT]) =0   : Local File PHYELT        [PHYT]   : Endif : # Eléments physiques
  If clalev([F:PMVT]) =0   : Local File PHYMVT        [PMVT]   : Endif : # Mouvements Eléments physiques

  # Ouverture de la table LEASE si le module Contrats location financement est actif
  If ( G_ACTLEA = G_OUI ) and  (clalev([F:LEA]) =0 ) Then
    Local File LEASE [LEA]
  Endif

  # Eléments physiques rattachés au bien comptable
  For [PHYT] Where AASREF=[M:FAS0]AASREF
    If WINDICE > GPHN-1 Then
        GMESSAGE = mess(9,7775,1)-":"-num$(GPHN)
        GERR = 2
        Break
    Endif
    [M:FAS8]PHYREF(WINDICE) = [F:PHYT]PHYREF
    [M:FAS8]BAC(WINDICE)    = [F:PHYT]BAC #FQ49517 - Création d'un élément physique

    # FQ100398/13
    [M:FAS8]LCTCOD(WINDICE) = [F:PHYT]LCTCOD
    [M:FAS8]PHYDES1(WINDICE) = [F:PHYT]PHYDES1
    [M:FAS8]PHYDES2(WINDICE) = [F:PHYT]PHYDES2

    Gosub RECUP_ELT_ATTENTE
    WINDICE += 1
  Next

  [M:FAS8]NBPHY = WINDICE
  If WINDICE > 0  Then
  Local Char WPHYREF(GLONPHY)
#     If func PHYELT_C_MPR._GET_PHY_WITH_MVT_FROM_FAS([M:FAS0]AASREF, WPHYREF) = [V]CST_ATRUE Then
     If func PHYELT_C_MPR._GET_SELECTED_MVT_PHY_NBR("[F:PHY]AASREF = '" + [M:FAS0]AASREF + "'") > 0
        [M:FAS0]FLGELT = GICOATTENTE
     Else
        [M:FAS0]FLGELT = GICOATTACHE
     Endif
  Else
     [M:FAS0]FLGELT = ""
  Endif
Return

#===========================================================================================================================
# Pour l'élément physique en cours, récupération de la localisation et du premier élément en attente
# Traitement presque équivalent dans SUBFASP pour écran FASPHY (FASP)
#===========================================================================================================================
$RECUP_ELT_ATTENTE
#===========================================================================================================================

   # FQ100398/13
   [M:FAS8]RATTACHE(WINDICE)= G_OUI
   [M:FAS8]SUPATTENTE(WINDICE)= G_NON
   [M:FAS8]FLGMODIF(WINDICE) = G_NON
   [M:FAS8]FLGLOCK(WINDICE) = G_NON
   #FQ49517 - Création d'un élément physique
   [M:FAS8]IMP(WINDICE)= G_NON
   [M:FAS8]BAC(WINDICE) = [F:PHYT]BAC
   # FQ!!!!!!!!
   [M:FAS8]PHYDES1(WINDICE) = [F:PHYT]PHYDES1
   [M:FAS8]PHYDES2(WINDICE) = [F:PHYT]PHYDES2
   [M:FAS8]SRLNBR(WINDICE) = [F:PHYT]SRLNBR
   [M:FAS8]BPRPHY(WINDICE) = [F:PHYT]BPS # FQ100398/13
   [M:FAS8]PHYCAT(WINDICE) = [F:PHYT]PHYCAT
   [M:FAS8]ORDBUY(WINDICE) = [F:PHYT]ORDBUY
   [M:FAS8]DORDBUY(WINDICE) = [F:PHYT]DORDBUY
   [M:FAS8]NUMRECEP(WINDICE) = [F:PHYT]NUMRECEP
   [M:FAS8]DNUMRECEP(WINDICE) = [F:PHYT]DNUMRECEP

  Read [PMVT]PMVT0(1) = [F:PHYT]PHYREF

  If fstat = [V]CST_AOK #and [F:PMVT]MVT > GVMLPMVNONE  Then
    [M:FAS8]MVT(WINDICE) = [F:PMVT]MVT
    [M:FAS8]MVTDATPHY(WINDICE) = [F:PMVT]MVTDAT
    [M:FAS8]LOCATT(WINDICE) = [F:PMVT]MVTLCTCOD
  # [M:FAS8]SUPATTENTE(WINDICE)= G_OUI
  Else
    [M:FAS8]MVT(WINDICE) = GVMLPMVNONE
  Endif

Return

###########################################
Subprog AV_ASJCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
    Chgfmt [M:FAS1]ASJCOE With "-N+:3.2#"
  Else
    Chgfmt [M:FAS1]ASJCOE With "N+:3.2#"
  Endif
End

###########################################
Subprog AM_ASJCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  If ( GREP <> "C" and VALEUR = 0. ) Then
    # Coefficient invalide.
    GERR= 1 : GMESSAGE= mess(173, GML_MSGFAS, 1)
    mkstat = 2 : End
  Endif

  If ( VALEUR = 0. and [M:FAS1]AASBUS = "" ) Then
    # Si le coefficient d'assujettissement est à 0
    # alors le coefficient de taxation est à 0
    [M:FAS1]TAXCOEFLG = 2
    [M:FAS1]TAXCOE    = 0.     : Affzo [M:FAS1]TAXCOE : Diszo [M:FAS1]TAXCOE
  Endif

  If ( GREP = "C" ) Then
    Call TVA_COE_DEDUCTION ( VALEUR, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
    TXTVAREC = TXTVAREC * 100.
    If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
      [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
      [M:FAS1]DEDVATFLG = G_NON : # FQ98116
      If (GCNXPROIAS = G_OUI) Then
        [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
        [M:FAS1]DEDVATFLGI = G_NON : # FQ98116
      Endif
      Gosub CALCUL_MONTANTS_TVA
    Endif
  Endif

  # Recalcul systématique du coefficient de déduction
  Call TVA_COE_DEDUCTION ( VALEUR, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, [M:FAS1]DEDCOE ) From TRTFAS

End

###########################################
Subprog AV_TAXCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
  If !(  func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
    Chgfmt [M:FAS1]TAXCOE With "-N+:3.2#"
  Else
    Chgfmt [M:FAS1]TAXCOE With "N+:3.2#"
  Endif

  If ([M:FAS1]TAXCOEFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]TAXCOE With "FORCAGE"
    Else
      Chgstl [M:FAS1]TAXCOE With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FAS1]TAXCOE With ""
  Endif
End

###########################################
Subprog AS_TAXCOE(VALEUR)
Variable Decimal VALEUR

  If ([M:FAS1]TAXCOEFLG <> G_OUI) or (func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]TAXCOE", 0) = G_NON )
& or ([M:FAS1]AASBUS="") Then : # FQ98116
    GBOUT1 = ""
  Endif
End

###########################################
Subprog AM_TAXCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    [M:FAS1]TAXCOEFLG = G_OUI:  Affzo [M:FAS1]TAXCOEFLG
    Affzo [M:FAS1]TAXCOE
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]TAXCOE With "FORCAGE"
    Else
      Chgstl [M:FAS1]TAXCOE With "TFORCAGE"
    Endif
  Endif

  If ( GREP = "C" ) Then
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, VALEUR, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
    TXTVAREC = TXTVAREC * 100.
    If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
      [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
      [M:FAS1]DEDVATFLG = G_NON : # FQ98116
      If (GCNXPROIAS = G_OUI) Then
        [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
        [M:FAS1]DEDVATFLGI = G_NON : # FQ98116
      Endif
      Gosub CALCUL_MONTANTS_TVA
    Endif
  Endif

  # Recalcul systématique du coefficient de déduction
  Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, VALEUR, [M:FAS1]ADMCOE, [M:FAS1]DEDCOE ) From TRTFAS
  Affzo [M:FAS1]DEDCOE
End

###########################################
Subprog B1_TAXCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC
  TXTVAREC = [M:FAS1]DEDVATRAT
  [M:FAS1]TAXCOE = VALEUR

  # Gestion du code forçage
  [M:FAS1]TAXCOEFLG = G_NON : Affzo [M:FAS1]TAXCOEFLG

  #-1 -----------------------
  If ( [M:FAS1]AASBUS <> "" ) Then
    Read [F:SEA]SEA0=[M:FAS0]CPY;[M:FAS1]AASBUS
    [M:FAS1]TAXCOE = [F:SEA]TAXCOEINI
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
    TXTVAREC = TXTVAREC * 100.
  #-1 -----------------------
  Else
    [M:FAS1]TAXCOE = 1.
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
    TXTVAREC = TXTVAREC * 100.
  Endif
  #-1 -----------------------

  If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
    # Gestion du code forçage
    [M:FAS1]TAXCOEFLG = G_NON : Affzo [M:FAS1]TAXCOEFLG

    If (GREP = "C" ) Then
      [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
      If (GCNXPROIAS = G_OUI) Then
        [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
      Endif
      Gosub  CALCUL_MONTANTS_TVA
    Endif
  Endif

  VALEUR = [M:FAS1]TAXCOE

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS1]TAXCOE With ""
  Affzo [M:FAS1]TAXCOE
  mkstat = 99
End

###########################################
Subprog AV_ADMCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
    Chgfmt [M:FAS1]ADMCOE With "-N+:3.2#"
  Else
    Chgfmt [M:FAS1]ADMCOE With "N+:3.2#"
  Endif
End

###########################################
Subprog AM_ADMCOE(VALEUR)
Variable Decimal VALEUR

Local Decimal TXTVAREC
  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif
  #*Fq-55504If ( VALEUR <> 0. and ( [M:FAS8]VEHTYP = "VP" or [M:FAS8]VEHTYP = "TCP") and
  #*Fq-55504&      func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY)= "FR"  ) Then
  #*Fq-55504# Pour un véhicule, le coefficient d'admission doit être égal à 0.
  #*Fq-55504GERR= 1 : GMESSAGE= mess(644, GML_MSGFAS, 1)
  #*Fq-55504mkstat = 2 : End
  #*Fq-55504Endif

  #FQ-60551 If ( GREP = "C"  ) Then
    Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, VALEUR, TXTVAREC ) From TRTFAS
    TXTVAREC = TXTVAREC * 100.
    If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
      [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
      [M:FAS1]DEDVATFLG = G_NON : # FQ98116
      If (GCNXPROIAS = G_OUI) Then
        [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
        [M:FAS1]DEDVATFLGI = G_NON : # FQ98116
      Endif
      Gosub CALCUL_MONTANTS_TVA
    Endif
  #FQ-60551 Endif
  # Recalcul systématique du coefficient de déduction
  Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, VALEUR, [M:FAS1]DEDCOE ) From TRTFAS
  Affzo [M:FAS1]DEDCOE
End


###########################################
Subprog AV_DEDCOE(VALEUR)
Variable Decimal VALEUR

  #If !( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) # FQ57624
  If !( func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )
    Chgfmt [M:FAS1]DEDCOE With "-N+:3.2#"
  Else
    Chgfmt [M:FAS1]DEDCOE With "N+:3.2#"
    Diszo [M:FAS1]DEDCOE
  Endif
End


###########################################
Subprog AV_TAXCOE2(VALEUR)
Variable Decimal VALEUR

  If GKFR = G_OUI Then : # FQ57624
    If ([M:FAS5]TAXCOEFLG2 = G_OUI ) Then
      If ( GBROWS = 0 ) Then
        Chgstl [M:FAS5]TAXCOE2 With "FORCAGE"
      Else
        Chgstl [M:FAS5]TAXCOE2 With "TFORCAGE"
      Endif
    Else
     Chgstl [M:FAS5]TAXCOE2 With ""
    Endif
  Endif
End

######################################################################################
# DEBUT MODES RUSSES - FQ59941
######################################################################################
Subprog C_KPSEPLN(VALEUR)
Variable Char    VALEUR()

  If (VALEUR <> "" ) Then
    If clalev([F:PSE]) =0    : Local File PSEPLN    [PSE]    : Endif
    Look[PSE]PSE0= [M:FAS0]CPY;VALEUR
    If (fstat) Then
      Look[PSE]PSE0= "";VALEUR
      If (fstat) Then
        GERR= 1: GMESSAGE = mess(801,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

Subprog AM_KPSEPLN(VALEUR)
Variable Char    VALEUR()

Local Char LLOCK (200)
Local Char LLOCK2(200)


  # FQ54343
  If (VALEUR <> "" and  VALEUR <> [M:FAS2]KPSEPLN ) Then
    LLOCK  = func GLOBIENS.GET_KEY_PSEPLN ([M:FAS0]CPY, VALEUR)
    LLOCK2 = func GLOBIENS.GET_KEY_PSEPLN ("", VALEUR)
    If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("PSE", [M:FAS0]CPY, LLOCK)  = 0 or
&        func GLOBIENS.IS_SYMBOLE_LOCKED ("PSE", [M:FAS0]CPY, LLOCK2) = 0      ) Then
      # Le plan de saisonnalité est verrouillée
      GERR= 1: GMESSAGE = mess(802,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

  Endif
End


Subprog AM_SESFLG(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_OUI and find([M:FAS3]DPM(nolign-1), G_DPMLR, G_DPMML, G_DPMMD )= 0 ) Then
    # La saisonnalité n'est pas prise en compte par ce mode  FQ72372
    GERR= 1: GMESSAGE = mess(804,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
  If (VALEUR = G_OUI and [M:FAS2]KPSEPLN = "") Then
    # Le plan de saisonnalité n'est pas renseigné
    GERR= 1: GMESSAGE = mess(803,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

