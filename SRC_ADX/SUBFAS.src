$LOCK_COMPOSANT
  # Lock des biens composant
  For [FASW]FAS0 Hint Key FAS5 Where CMP = [M:FAS0]AASREF
    LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([F:FASW]AASREF)
    If func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FASW]CPY, LLOCK, 0) = 0 Then
