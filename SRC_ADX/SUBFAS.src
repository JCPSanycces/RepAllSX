Subprog B1_DEDVATAMT(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:FAS1]DEDVATFLG = G_NON : Affzo [M:FAS1]DEDVATFLG

  Gosub TVA_REC_PCG
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
  VALEUR = [M:FAS1]DEDVATAMT

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS1]DEDVATAMT  With ""
  Affzo [M:FAS1]DEDVATAMT
  mkstat = 99

End

