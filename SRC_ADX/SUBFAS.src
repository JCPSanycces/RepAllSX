  GPOINT = "CPLCPTIMM" : Gosub ENTREE From EXEFNC
  If GOK<1 : Return : Endif
  #CHECK IGNORE_END
 Endif
Return

#=========================
$TEST_BIEN_DS_CIG

  # Test afin de savoir si le bien est présent dans une cession intra-groupe
  GIBIENCIG = G_NON
  Read [CIB]CIB4=[M:FAS0]AASREF
  If (fstat = 0) Then
    GIBIENCIG = G_OUI
  Endif

Return

#=====================================================================
$APRES_CHOI

  If currbox = LTI_DEPLIEE Then
    # Si on est sur le tiroir des dépenses liées
    # pour le moment je vais le mettre sur le click, mais le top serait sur le double-clic (GSTALF2),
    # mais il ça ne fonctionne pas sur ce type de liste !
    Case REPONSE
      When GSTALFT
        If dim([M:LOF0]CPY) < 0 Then
          # L'écran des dépenses n'est pas ouvert : on peut repartir dessus
          Local Char LFGRFGR
          Call OBJET_CHAR(LFGRFGR, "LOF", [F:LOF]CODLOF+"@"+num$([F:LOF]LINLOF)) From GOBJET
        Else
          # L'écran des dépenses est ouvert, on ne peut pas faire un tunnel dans ce cas,
          # y a un message d'erreur de X3
          GERR=1: GMESSAGE = mess(41,GML_MSGFAS, 1): OK= 0: Return
        Endif
    Endcase
  Endif
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2


Return

#=====================================================================
$TIROIR


  If currbox = LTI_DEPIMMO Then
    # Dépenses immobilisables
    Raz CRITERE
    Gosub FILGAUCHE
    If (dim(FILTREG) > 0) Then : FILTREG = 1 : Endif
    Gosub REMPLIT
    Gosub SET_PICKING_QVB From FUNLOFLDAB
  Elsif currbox = LTI_DEPLIEE Then
    # Dépenses liées
    Raz CRITERE
    Gosub FILGAUCHE
    If (dim(FILTREG) > 0) Then : FILTREG = 1 : Endif
    Gosub REMPLIT
  Endif
Return


$REMPLIT

  Case currbox
    When "GAU_CHE1" : Gosub REMPLIT_1 From WGOFAS
    When "GAU_CHE2" : Gosub REMPLIT_2 From WGOFAS
    When "GAU_CHE3" : Gosub REMPLIT_3 From WGOFAS
    When "GAU_CHE4" : Gosub REMPLIT_4 From WGOFAS
    When "GAU_CHE5" : Gosub REMPLIT_5 From WGOFAS
    When "GAU_CHE6" : Gosub REMPLIT_6 From WGOFAS
    When "GAU_CHE7" : Gosub REMPLIT_7 From WGOFAS
    When "GAU_CHE8" : Gosub REMPLIT_8 From WGOFAS
    When "GAU_CHE9" : Gosub REMPLIT_9 From WGOFAS
  Endcase
Return

#=====================================================================
$GAUCHE
  #GBO-FQ62567-Le clic sur un élément de la liste gauche n'a d'effet que si l'on est en consultation
  If GREP<>"" & dim(ACTMETNAM)>0 : Gosub OBJ_ABANDON From TRUPROACT : OK=0 : Return : Endif
  If ( currbox = LTI_FASSET ) Then
    If VERROU : Gosub DEVERROU From GOBJET : Endif
    CLECUR1 = [F:FAS]AASREF
    Gosub RELIT From GOBJSUB
  Elsif ( currbox = LTI_FASCMP ) Then
    If VERROU : Gosub DEVERROU From GOBJET : Endif
    CLECUR1 = [F:FAS]AASREF
    Gosub RELIT From GOBJSUB
  Endif
Return

#=====================================================================
$FILGAUCHE
# Pour indiquer avec quoi remplir la liste de gauche
# Les seules info prises sur l'écran des biens comptables sont la société et l'établissement
# Les autres valeurs, prises comme déterminantes, sont fixées par le choix de la première
# dépense dans la liste de picking
# Inconvénient : * si la dépense qu'on cherche est la dernière d'une longue
#                 liste, il faut tout balayer
# Avantage     : * Un seul paramétrage de critères déterminants
#                   - les noms de colonnes des dépenses et des biens comptables sont différents
#                   - les valeurs retenues comme déterminantes dans les dépenses ne sont pas
#                     forcéments présentes dans les biens comptables
#                * Il est possible de partager complètement le code entre la solution PICKING
#                  et la solution à partir de la fenêtre de sélection (qui permet des sélection
#                  plus complexes des dépenses).
# Question en suspend : comment traiter le cas où, en picking on souhaite faire un
#                       ajout à un bien comptable existant ?
#     Proposition 1 : Considérer la première dépense rattachée au bien comme principale,
#                     mais il est possible qu'en fonction du paramétrage, elle ne soit pas
#                     forcément la plus adaptée
#     Proposition 2 : On pourrait, en plus de la référence du bien comptable, et de marquer la
#                     dépense comme ayant été la dépense principale ou pas. Du coup, lors de
#                     l'éventuel ajout d'autres dépenses, on pourrait automatiquement repartir
#                     de la même dépense principale
#     Proposition 3 : j'en n'ai pas !
# Reste le problème d'un bien pas du tout lié à une dépense, et qu'on souhaite lier
# (cf le premier avantage) !
#
# Si on clique sur l'établissement ou la société de la liste de picking, il est possible
# de sélectionner toutes les dépenses compatibles avec la dépense principale.
# On peut paramétrer la liste de picking de deux façons :
#  1°) en chargement partiel, l'application fonctionne page par page, mais la sélection
#      par rapport à la remarque précédente se fera par rapport à la page en cours.
#      Par contre le chargement est plus rapide.
#  2°) en chargement total, l'application charge alors toutes les dépenses dans la liste de
#      picking. Dans ce cas, la sélection par rapport à la remarque précédente se fera sur
#      TOUTES les dépenses compatibles.
#      Par contre, les chargement est directement lié au volume,
#      et par conséquent peut être long.
#-------------------------------------------------------------------------------
Local Integer N_I, N_E
Local Char LCOND(250)

  # Fiche 48468 : Correction bug STANT le 19/08/2008
  If dim(LTI_FASCMP)> 0 and ( currbox = LTI_FASCMP ) Then
    # Biens composants
    #Raz FILGAUSUP : # FQ64353
    If 0=1 Then
      Raz FILSUITE
      If !GIMPORT Then
        Call MESSAGE ("dim(CRITERE)="-num$(dim(CRITERE)))     From GESECRAN
        Call MESSAGE ("dim(FILGAUSUP)="-num$(dim(FILGAUSUP))) From GESECRAN
        Call MESSAGE ("dim(FILSUITE)="-num$(dim(FILSUITE)))   From GESECRAN
      Endif
    Endif
    FILGAUSUP(0) = "CPY=[M:FAS0]CPY and CMP=[M:FAS0]AASREF"
    FILGAUSUP(1) = ""
    #FILGAUSUP(2) = "" : # FQ64353
    FILGAUSUP(3) = ""
  Elsif ( currbox = LTI_FASSET ) Then
    # Biens de l'ensemble
    #Raz FILGAUSUP : # FQ64353
    FILGAUSUP(0) = "CPY=[M:FAS0]CPY and SET=[M:FAS1]SET"
    FILGAUSUP(1) = ""
    #FILGAUSUP(2) = "" : # FQ64353
    FILGAUSUP(3) = ""
  Elsif currbox = LTI_DEPIMMO Then
    # Dépenses immobilisables
    #Raz FILGAUSUP : # FQ64353
    Gosub LIRE_PARLDAP_SOC From FUNLOFLDAB
    FILGAUSUP(0)    = 'FLGLIKAAS=G_NON &CPY=[M:FAS0]CPY &FCY=[M:FAS0]FCY'
    N_E             = 1
    FILGAUSUP(N_E)  = ""
    FILGAUSUP(3)    = "" : # FQ64353
    LCOND           = ""
    If [M:LOF6]NBDEST > 0 Then
      # -------------------------------------------
      # S'il y a une dépense principale
      # -------------------------------------------
      For N_I = 0 To [F:LDA]NBLDAP-1
        If GPARTYPPHY(N_E) <> -1 Then
          If [F:LDA]ORNUL = G_OUI and GPARTYPPHY(N_I) > 0 Then
            LCOND += "("
          Endif
          LCOND += [F:LDA]CODZON(N_I)+"=[F:LOFP]"+[F:LDA]CODZON(N_I)
          If [F:LDA]ORNUL = G_OUI and GPARTYPPHY(N_I) > 0 Then
            LCOND += "|"+[F:LDA]CODZON(N_I)+"="
            If GPARTYPPHY(N_I) = GNUMBER Then
              # Numérique
              LCOND += "0"
            Elsif GPARTYPPHY(N_I) = GALPHA Then
              # Alpha-numérique
              LCOND += "''"
            Elsif GPARTYPPHY(N_I) = GDATE Then
              # Date
              LCOND += "[0/0/0]"
            Endif
            #------------------------------
            LCOND += ")"
          Endif
          If LCOND <> "" Then
            FILGAUSUP(N_E) += "&"
            FILGAUSUP(N_E) += LCOND
            LCOND = ""
          Endif
        Endif
        #------------------------------
        # Suite de la boucle
      Next N_I
      # ----------------------------
      # FQ64353 : remplacement de FILGAUSUP(2) par FILGAUSUP(3)
      FILGAUSUP(3)    = '&('
      If !(G_PLNIAS) Then
        # Si on ne gère pas l'IAS la nature PCG est forcément "En cours" ou "En Service"
        FILGAUSUP(3)     += '(GACACN=GVML_NIENCOU|GACACN=GVML_NIENSER)'
      Else
        If [F:LOFP]GACACN = GVML_NIENCOU or [F:LOFP]GACACN = GVML_NIENSER Then
          If [F:LOFP]IASACN = GVML_NIENCOU or [F:LOFP]IASACN = GVML_NIENSER Then
            # Si les deux natures sont "En cours" ou "En Service", alors on n'a pas besoin de filtre "nature"
            FILGAUSUP(3)  = ''
          Else
            # Sinon l'IAS doit forcément être en charge (donc différent de...)
            FILGAUSUP(3) += '(GACACN=GVML_NIENCOU|GACACN=GVML_NIENSER)'
            FILGAUSUP(3) += '&(IASACN<>GVML_NIENCOU&IASACN<>GVML_NIENSER)'
          Endif
        Else
          # Comme un des deux doit être "En cours" ou "En Service", si nature PCG ne l'est pas
          # la nature IAS l'est forcément
          FILGAUSUP(3)   += '(GACACN<>GVML_NIENCOU&GACACN<>GVML_NIENSER)'
          FILGAUSUP(3)   += '&(IASACN=GVML_NIENCOU|IASACN=GVML_NIENSER)'
        Endif
      Endif
      If FILGAUSUP(3) <> '' Then
        FILGAUSUP(3)     += ')'
      Else
        FILGAUSUP(3)      = '&(1=1)'
      Endif
    Else
      # -------------------------------------------
      # S'il n'y a pas encore de dépense principale
      # -------------------------------------------
      FILGAUSUP(N_E) = '&(1=1)'
      If GLOFPREAD = G_NON and GREP <> "C" Then
        # Si la dépense principale n'est pas lue, c'est que le bien a été créé indépendemment de tout
        # On met une condition bidon pour présenter la liste de picking vide
        # Si on est en création on ne vient jamais ici : on présente toutes les dépenses immobilisables
        FILGAUSUP(N_E) = "&FLGLIKAAS=-1"
      Endif
      # ----------------------------
      FILGAUSUP(3)    = '&('
      FILGAUSUP(3)   += '(GACACN=GVML_NIENCOU|GACACN=GVML_NIENSER)'
      If (G_PLNIAS = G_OUI) Then
        FILGAUSUP(3) += '|(IASACN=GVML_NIENCOU|IASACN=GVML_NIENSER)'
      Endif
      FILGAUSUP(3)   += ')'
      # ----------------------------
    Endif
  Elsif currbox = LTI_DEPLIEE Then
    # Dépenses regroupées
    #Raz FILGAUSUP : # FQ64353
    FILGAUSUP(0) = "AASREF=[M:FAS0]AASREF and AASREF<>''"
    FILGAUSUP(1) = "&FLGLIKAAS=G_OUI"
    FILGAUSUP(3) = "" : # FQ64353
  Elsif currbox = LTI_FASISS Then
    # Bien sorti dans exercice antérieur
    #Raz FILGAUSUP : # FQ64353
    FILGAUSUP(0) = "ISSFIYPRE=G_OUI"
    FILGAUSUP(1) = "" : # FQ64353
    FILGAUSUP(3) = "" : # FQ64353
  Elsif currbox = LTI_FASDIS Then
    # Bien inactifs
    #Raz FILGAUSUP : # FQ64353
    FILGAUSUP(0) = "ENAFAS=G_NON"
    FILGAUSUP(1) = "" : # FQ64353
    FILGAUSUP(3) = "" : # FQ64353
  Elsif GPHY = G_OUI and currbox = LTI_FASPHY Then
    # Bien avec éléments physiques en attente de mouvement
    # FQ119322
    #FILGAUSUP(0) = "AASREF<>''"
    #FILGAUSUP(1) = "&MVT(0)>GVMLPMVNONE"
    #FILGAUSUP(3) = ""
    FILGAUSUP(0) = ""
    FILGAUSUP(1) = ""
    FILGAUSUP(3) = ""
    # Réactivation des rôles
    Local Char SZFILROLE(250)(0..5)
    Local Integer RI
    Call FILROLE("FAS", SZFILROLE) From SUBARL
    If SZFILROLE <> "" and SZFILROLE <> "1=1" Then
      For RI = 0 To dim(SZFILROLE)-1
        If SZFILROLE(RI) <> "" and SZFILROLE(RI) <> "1=1" Then
          Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", SZFILROLE(RI), "&") From GOBJSUB
        Endif
      Next RI
    Endif
  Endif

  # Biens non sortis dans un exercice antérieur et actif
  FILGAUCHE = "ISSFIYPRE<>G_OUI & ENAFAS<>G_NON"

Return

#=====================================================================
$PICKE
Local Integer LCOMPAT
Local Char LKEY(200)

  # ---------------------------------------
  # Pour chacun des éléments cliqués
  If ( currbox = LTI_DEPIMMO ) Then
    # Dépenses immobilisables
    If ( [M:FAS0]AASREF <> "" ) Then
      LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([M:FAS0]AASREF)
      If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:FAS0]CPY, LKEY) = 0 ) Then
        GMESSAGE = mess(52,7770,1)
        OK       = 0
        Return
      Endif
    Endif
    # ---------------------------------------
    If ( [M:LOF6]NBDEST = 0 ) Then
      # La première dépense de la liste est considérée comme principale
      Read [LOF]LOF0 =
      [LOFP] = [LOF] : # donc on la planque
      Call AJOUTE_UNE_DEPENSE () From FUNLOFLDAB
    Else
      If ( GLDABAPPL = G_OUI ) Then
        # Si on a déjà appliqué on ne peut plus sélectionner d'autres dépenses
        OK = 0
      Else
        Read [LOF]LOF0 =
        # Contrôler la compabilité des dépenses suivantes, avec la dépense principale
        # à l'aide des critères discriminants
        # Si elle est OK on la planquera dans le tableau RETENUS de l'écran LOFLDAB [LOF6]
        Call IS_DEPENSE_COMPATIBLE (LCOMPAT) From FUNLOFLDAB
        If ( LCOMPAT = G_OUI ) Then
          Call AJOUTE_UNE_DEPENSE () From FUNLOFLDAB
        Else
          OK = 0
        Endif
      Endif
    Endif
    # ---------------------------------------
  Endif
Return

#=====================================================================
$DEPICKE
  # Pour chacun des éléments décliqués
  # On ne peut pas DEPICKer la dépense qui aura été considérée comme déterminante
  # On verra plus tard si je sais le faire !
  # OK = 0
  If ( GLDABAPPL = G_OUI ) Then
    # si on a "Appliqué" on ne peut plus désélectionner une ligne
    OK = 1
  Endif
Return

#=====================================================================
$FIN_PICK
  # A la fin du picking
  If ( currbox = LTI_DEPIMMO ) Then
    # Dépenses immobilisables
    If ( [M:LOF6]NBDEST = 1 ) Then
      # utile de remplir une nouvelle fois la liste de picking que pour la sélection de la dépense
      # principale en création. Ensuite la liste est filtrée correctement
      Gosub TIROIR From SUBFAS
    Else
      Gosub SET_PICKING_QVB From FUNLOFLDAB
    Endif
  Endif
Return

#=====================================================================
$ABANDON
  Gosub RAZ_PICKING From FUNLOFLDAB
  If ( GMODOK = G_NON and REPORT_LEAREF = G_OUI ) Then
    # Unlock sur les biens "composant"
    Gosub UNLOCK_COMPOSANT
  Endif

  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
  If GPHY = G_OUI Then
     If [M:FAS8]NBPHY > 0
        For nolign = 1 To [M:FAS8]NBPHY
          [M:FAS8]FLGLOCK(nolign-1) = G_NON
        Next nolign
     Endif
  Endif
Return

#=====================================================================
$FIN
  Gosub DELOCK_TBL_DEST From FUNLOFLDAB

  Local Integer FROMSUBOBJ
  Gosub ACTION From TRTOBJACT
  Kill FROMSUBOBJ
Return

#=====================================================================
$FERME
  If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM : Endif

  If dim(G_STPDEPSTAO)>0  : Kill G_STPDEPSTAO  : Endif :# FQ59941
  If dim(G_ARECALCULER)>0 : Kill G_ARECALCULER : Endif
  If dim(G_CCNFMT)>0      : Kill G_CCNFMT      : Endif
  If dim(G_DEROUTE)>0     : Kill G_DEROUTE     : Endif
  If dim(G_PLNIAS)>0      : Kill G_PLNIAS      : Endif
  If dim(G_CNXIAS)>0      : Kill G_CNXIAS      : Endif
  If dim(G_AASBUS)>0      : Kill G_AASBUS      : Endif
#  If dim(G_NBAXE)>0       : Kill  G_NBAXE       : Endif FQ93595


  If dim(G_CHARGE_PCG)>0  : Kill G_CHARGE_PCG  : Endif
  If dim(G_CHARGE_IAS)>0  : Kill G_CHARGE_IAS  : Endif
  If dim(G_DEFORCE)>0     : Kill G_DEFORCE     : Endif

  If dim(GCPLDURMIN)>0    : Kill GCPLDURMIN    : Endif
  If dim(GCPLDURPRC)>0    : Kill GCPLDURPRC    : Endif
  If dim(GSUPOK)>0        : Kill GSUPOK        : Endif
  If dim(GMODOK)>0        : Kill GMODOK        : Endif
  If dim(GIBIENCIG)>0     : Kill GIBIENCIG     : Endif
  If dim(GFLGASS)>0       : Kill GFLGASS       : Endif
  # -----------------------
  If dim(GLOFPREAD)>0     : Kill GLOFPREAD     : Endif
  If dim(GLDAPCRIT)>0     : Kill GLDAPCRIT     : Endif
  If dim(GLDAPSTAR)>0     : Kill GLDAPSTAR     : Endif
  If dim(GPARTYPPHY)>0    : Kill GPARTYPPHY    : Endif
  If dim(GLOFLDAB)>0      : Kill GLOFLDAB      : Endif
  If dim(GLDABAPPL)>0     : Kill GLDABAPPL     : Endif
  If dim(GINDLOFPRI)>0    : Kill GINDLOFPRI    : Endif
  If dim(GNBDEPLIEES)>0   : Kill GNBDEPLIEES   : Endif
  If dim(GMODENAFAS)>0    : Kill GMODENAFAS    : Endif
  # -----------------------
  If dim(G_TRSSAV)>0      : Kill G_TRSSAV      : Endif
  If dim(LIS_ACT)>0       : Kill LIS_ACT       : Endif
  If dim(LIS_NAM)>0       : Kill LIS_NAM       : Endif
  If dim(LIS_TYP)>0       : Kill LIS_TYP       : Endif
  If dim(LIS_ACT1)>0      : Kill LIS_ACT1      : Endif
  # -----------------------
  # Fiche 48468
  # 49517: Numérotation des éléments physiques à partir du bien
  If GPILNAV <= 1 or !find(GNAVIG(GPILNAV-1),"GESPHY") Then #si l'on vient d'un tunnel des éléments physiques
    If dim(G_ELEMENTS)>0     : Kill G_ELEMENTS     : Endif
    If dim(G_NOUVEAU_BIEN)>0 : Kill G_NOUVEAU_BIEN : Endif
  Endif
  # fin 49517

  # flag tunnel depuis les éléments physiques
  If dim(G_TUNNEL_PHY)>0   : Kill G_TUNNEL_PHY   : Endif
  If dim(G_SAV_CONSULT)>0   : GCONSULT = G_SAV_CONSULT : Kill G_SAV_CONSULT : Endif

  If ( TUNNEL ) Then : Gosub RESTAURE_GLOB_TUNNEL From TRUPROACT : Endif
Return

#=====================================================================
$CALCUL_BIEN

  If ( ACALCULER <> num$(G_OUI) ) Then
    Call PARAM([M:FAS0]CPY,"CALAUTVAL", ACALCULER) From ADOVAL
  Endif

  If ([M:FAS0]ENAFAS = G_OUI ) Then
    # Le bien est actif
    If ( ACALCULER = num$(G_OUI) or G_CHARGE_PCG=G_OUI or G_CHARGE_IAS=G_OUI )  Then
      # Calcul si le bien est à calculer ou
      #        suite à un transfert comptable la nature PCG ou IAS passe à Charge
      Call CALCULER_BIEN ([M:FAS0]CPY, [M:FAS0]AASREF, ERROR)  From =G_GLOB
      If ( ERROR = 0 and GIMPORT = 0 ) Then
        # FQ66894
        #FQ91070
        If dim(GFXDNBERR) < 0
          Gosub RELIT From GOBJSUB
        Endif
        Call GEN_FLUX_BIEN ([M:FAS0]CPY, [M:FAS0]AASREF, GVML_TXSPRO, ERROR) From TRTFLUX
        If ERROR
          GERR = 1
          Call GERE_MSG_ERREUR_FLUX (ERROR, GMESSAGE) From TRTFLUX
        Endif
        #FQ91070
        If dim(GFXDNBERR) < 0
          Gosub RELIT From GOBJSUB
#         Return #FQ101398
        Endif
      Endif
    Endif
  Endif

  ACALCULER = ""

  If (!ERROR) & !GIMPORT Then
   # Génération des écritures comptables selon paramétrage
    #FQ91070 : en ITF, une fois la comptabilisation faite, on ne lit pas la trace donc Return
    If dim(GFXDNBERR) >= 0
      Call COMPTA_DIRECTE([M:FAS0]CPY, [M:FAS0]FCY, [M:FAS0]AASREF, 0, "", ERROR) From TRTCPTINT
      Return
    Endif

   Call TEMPON("Comptabilisation en cours ...") From GESECRAN
   Call COMPTA_DIRECTE([M:FAS0]CPY, [M:FAS0]FCY, [M:FAS0]AASREF, 0, "", ERROR) From TRTCPTINT
   Call TEMPOFF() From GESECRAN
   If GTRACE<>"" & dim(LTRCOPE)>0
    Call LEC_TRACE From LECFIC
    Kill LTRCOPE
   Endif
   #CHECK IGNORE_BEGIN
   #FQ51827-GBN-010909
   GPOINT = "CPLCPTIMM" : Gosub ENTREE From EXEFNC
   If GOK<1 : Return : Endif
   #CHECK IGNORE_END
  Endif

Return

#*********************************************************************
#        *FAS0             E C R A N      F A S 0
#*********************************************************************
##########################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()
  # Affichage "à priori" des valeurs par défaut en création
  If (GREP = 'C' ) Then
    Affzo [M:FAS1]PURNAT, OWNTYP, ETRNAT, AASUOM, AASQTY,
&                 GACACN, GAC, IVCVATRAT, DEDVATRAT
    If (G_PLNIAS) Then
      Affzo  [M:FAS1]IVCVATRATI, DEDVATRATI
    Endif
  Endif
End

########################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer ISITE, OK
  Local Char    SOCIETE (GLONCPY)
# FQ55352 - Empêcher la modification du site financier si on a des éléments rattachés
  If GPHY = G_OUI and [M:FAS0]ENAFAS = G_OUI Then
    If [M:FAS8]NBPHY > 0 and VALEUR <> [M:FAS0]FCY and find(G_OUI, [M:FAS8]RATTACHE(0..[M:FAS8]NBPHY-1))Then
      # Au moins un élément physique rattaché a un site géographique incompatible avec le site financier du bien
      [V]GMESSAGE=mess(125,7775,1)
      mkstat = 2 : End
    Endif
  Endif
# Fin FQ55352 -
  # Recherche de la société du site
  ISITE = find(VALEUR,GSITE(1..GNBSITE))
  If ISITE
    SOCIETE = GSOCSITE(ISITE)
  Else
    GMESSAGE = mess(15,104,1) : # Site inexistant
    mkstat = 2 : End
  Endif

  # Contrôle de l'existence du contexte Comptable et fiscal
  OK=1
  If ( SOCIETE <> GCOUSOC ) Then
    Look [CNX]CNX0=SOCIETE;G300CPFI
    If fstat : OK=0 : Endif
  Else
    If GCNXPROCPF = G_NON : OK=0 : Endif
  Endif
  If !OK Then
    # Opération impossible. Le contexte "fiscal & comptable" de la société doit avoir été défini au préalable.
    GMESSAGE = mess(115,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  # Affichage de l'intitulé société (non pris en compte par les actions associées au type de donnée BFC)
  If ( dim([M:FAS0]ZCPY) > 0 ) Then
    Affzo [M:FAS0]ZCPY
  Endif

#  If !clalev([M:FCP])# Issue 115510
     #> Chargement du masque de travail contenant le paramétrage comptable de la société
     Local Integer ERR
     Call LOAD_FASPARCPY([M:FAS0]CPY,"",G_NON,ERR) From GLOFCYCPY
#  Endif# Issue 115510

  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:FAS]","[M:FPC]","[M:FAS2]",LNBRCCE) From GLOBIENSANA
  [M:FAS2]NBRCCE=LNBRCCE
  G_NBAXE = LNBRCCE  #Fq-79815

  [M:FAS1]ASJCOE    = 1. : Affzo [M:FAS1]ASJCOE
  [M:FAS1]TAXCOE    = 1. : Affzo [M:FAS1]TAXCOE
  [M:FAS1]TAXCOEFLG = 1  : Affzo [M:FAS1]TAXCOEFLG
  [M:FAS1]ADMCOE    = 1. : Affzo [M:FAS1]ADMCOE
  [M:FAS1]DEDCOE    = 1. : Affzo [M:FAS1]DEDCOE
  Effzo [M:FAS1]AASBUS
  Effzo [M:FAS1]SACDES

  # Suppression des informations saisies sur le biens et sur les plans
  Effzo [M:FAS3]
  # Initialisation du tableau des plans d'amortissement
  Gosub INIT_PLAN_AMT
  # Initialisation générale
  Gosub INIT_GENERALE
  # Récupération des paramètres
  Call LECTURE_PARAMETRES (VALEUR)
  Affzo [M:FAS3]
  Affzo [M:FAS4]

  Effzo [M:FAS1]ACGETRNOT
  Effzo [M:FAS1]IVCVATAMT
  Effzo [M:FAS1]DEDVATAMT
  Effzo [M:FAS1]IASETRNOT
  Effzo [M:FAS1]IVCVATAMTI
  Effzo [M:FAS1]DEDVATAMTI
  Chgstl [M:FAS1]IVCVATAMT With "" : # FQ98116
  Chgstl [M:FAS1]DEDVATAMT With "" : # FQ98116

  #Fq72245-Pb alimentation taux TVA facturée par défaut si chgt site avec taux différents
  # Affichage des valeurs par defaut dépendant de l'établissement
  #If ( GREP = 'C' ) Then
  #  # si contexte IAS geré
  #  If (G_PLNIAS) Then
  #    Affzo [M:FAS1]IASCUR, IASACN, IASACC, IASCURTYP, IASRATCUR
  #    If ([M:FAS1]IVCVATRATI = 0 ) Then
  #      [M:FAS1]IVCVATRATI = GDEFVATRAT : Affzo [M:FAS1]IVCVATRATI
  #      [M:FAS1]DEDVATRATI = [M:FAS1]DEDVATRAT : Affzo [M:FAS1]DEDVATRATI
  #    Endif
  #  Else
  #    Call ACTION_BLOCK(ACB_EFFZO, "FAS1", "IASCUR") From GLOBIENS
  #    [M:FAS2]IASCGU     = "": # Unité génér tréso
  #    Affzo [M:FAS2]IASCGU
  #  Endif
  #Endif
  # Affichage des valeurs par defaut dépendant de l'établissement
  If ( GREP = 'C' ) Then
    [M:FAS1]IVCVATRAT=GDEFVATRAT : Affzo [M:FAS1]IVCVATRAT
    # si contexte IAS geré
    If (G_PLNIAS) Then
      Affzo [M:FAS1]IASCUR, IASACN, IASACC, IASCURTYP, IASRATCUR
      [M:FAS1]IVCVATRATI = GDEFVATRAT : Affzo [M:FAS1]IVCVATRATI
      [M:FAS1]DEDVATRATI = [M:FAS1]DEDVATRAT : Affzo [M:FAS1]DEDVATRATI
    Else
      Call ACTION_BLOCK(ACB_EFFZO, "FAS1", "IASCUR") From GLOBIENS
      [M:FAS2]IASCGU     = "": # Unité génér tréso
      Affzo [M:FAS2]IASCGU
      # FQ98116
      [M:FAS1]IVCVATRATI = 0
      [M:FAS1]DEDVATRATI = 0
      Affzo [M:FAS1]IVCVATRATI
      Affzo [M:FAS1]DEDVATRATI
    Endif
  Endif
  #Fq72245-Fin

  Gosub CONDITIONNE_TVA_FAS5           From TRTFAS
  Gosub CONDITIONNE_TAXES_LOCALES_FAS2 From TRTFAS : # FQ57624
  Gosub CONDITIONNE_IAS_FAS1           From TRTFAS : # FQ57624

  # Réinitialisation de champs en cas de changement d'établissement
  Gosub REINIT_ETAB_DEPEND

  # Réinitialisation de champs en cas de changement d'établissement
  [M:FAS0]FCY = VALEUR

  Gosub MODIF_REDUITE From SUBFAS2
End

########################################
Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()

Local Char LZVSOC(GLONCPY)

  # Dans les biens, un contrôle est réalisé sur l'existence du contexte Fiscal & comptable
  # sur la société du site. S'il n'existe pas, il faut refuser la création d'un bien sur cette société.
  # Mais la classe du site a déjà trouvé et affiché la société.
  # Si on remet le site d'origine, on ne passe plus en AM_FCY, et la société affichée
  # n'est pas celle du site. Il faut donc prendre en charge cette partie à la main pour repasser dans
  # ACTION_FCY.
  LZVSOC = [M:FAS0]CPY
  Call ACTION_FCY (VALEUR, [M:FAS0]CPY) From GLOFCYCPY
  If [M:FAS0]CPY <> LZVSOC Then
    Affzo [M:FAS0]CPY
  Endif

#  If !clalev([M:FCP])# Issue 115510
     #> Chargement du masque de travail contenant le paramétrage comptable de la société
     Local Integer ERR
     Call LOAD_FASPARCPY([M:FAS0]CPY,"",G_NON,ERR) From GLOFCYCPY
#  Endif# Issue 115510

  #> Chargement du tableau des axes et sections analytiques
  # FQ93517
  If (GNBDEPLIEES = 0 and GREP <> "C") Then     : # Issue X3-71038 - 2018-01-18 by FHA
    Local Integer LNBRCCE
    Call LOAD_TAB_CCE("[F:FAS]","[M:FPC]","[M:FAS2]",LNBRCCE) From GLOBIENSANA
    [M:FAS2]NBRCCE=LNBRCCE
    G_NBAXE = LNBRCCE  #Fq-79815
  Endif

End

########################################
Subprog C_AASREF(VALEUR)
Variable Char    VALEUR()

  If ( GAASAUTNUM = 1 and VALEUR= "" ) Then
    GERR= 1: GMESSAGE = mess(3,GML_MSGFAS, 1)
    mkstat = 2
  Elsif ( VALEUR = "" and !GIMPORT ) Then
    # Création forcée
    mkstat = 4
  Endif
End

######################################################################################
# Contrôle si on a le droit de passer le flag actif à non en testant si mouvements en
# attente sur les éléments physiques rattachés
# Contrôle si on a le droit de passer le flag actif à oui en testant si tous les éléments
# physiques rattachés ont le même site géographique que le bien
# Fiche 48468
######################################################################################
Subprog C_ENAFAS(VALEUR)
Variable Integer VALEUR
  # Contrôle si on a le droit de passer le flag actif à non en testant si mouvements en attente sur les éléments
  # physiques rattachés
  If GPHY = G_OUI and VALEUR = G_NON and VALEUR<>[M:FAS0]ENAFAS Then
    If func PHYELT_C_MPR._GET_SELECTED_MVT_PHY_NBR("[F:PHY]AASREF = '" + [M:FAS0]AASREF + "'") > 0
        GERR=1
        GMESSAGE = mess(59,7775,1) # "Au moins un mouvement en attente sur un élément physique rattaché : vous ne pouvez pas rendre le bien inactif"
        mkstat = 2
     Endif
  Endif


End

########################################
#FQ61803
Subprog AS_AASDES1(VALEUR)
Variable Char    VALEUR()
 If GDEBUG<>G_OUI : GBOUT1 = "" : Endif
End


#*********************************************************************
#*********************************************************************
#         *FAS1            E C R A N      F A S 1
#*********************************************************************
#*********************************************************************

######################################################################
Subprog C_PURDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR>=[01/01/2200]
  GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
  mkstat = 2 : End
 Endif
End

##############################
Subprog AM_PURDAT(VALEUR)
Variable Date    VALEUR

Local Integer REPORTER_DATE, LOK

  #FQ80672
  If [M:FAS0]PRVSITUPD = G_NON and (GREP = "" or GREP = "M")
    If func SUBFAS2.DATEMEMEEXE([M:FAS0]CPY, [M:FAS1]PURDAT, VALEUR) = 0
      GERR = 1
      # GMESSAGE = "Changement d'exercice interdit"
      GMESSAGE = mess(877, GML_MSGFAS, 1)
      mkstat = 2
      End
    Endif
  Endif

  #--------------
  If ( GREP = "C" and GNBDEPLIEES = 0 ) Then
    [M:FAS1]ITSDAT    =VALEUR : Affzo [M:FAS1]ITSDAT
    [M:FAS1]AASIPTDAT =VALEUR : Affzo [M:FAS1]AASIPTDAT
  Endif
  #--------------
  If ( GREP = "C" ) Then
    If GKFR = G_OUI : [M:FAS5]VATREGDAT =VALEUR : Affzo [M:FAS5]VATREGDAT : Endif : # FQ57624
    [M:FAS4]GALREFDAT =VALEUR : Affzo [M:FAS4]GALREFDAT
  Else
    If GKFR = G_OUI : If [M:FAS5]VATREGDAT = [M:FAS1]PURDAT Then : [M:FAS5]VATREGDAT =VALEUR : Affzo [M:FAS5]VATREGDAT : Endif : Endif : # FQ57624
    If [M:FAS4]GALREFDAT = [M:FAS1]PURDAT Then : [M:FAS4]GALREFDAT =VALEUR : Affzo [M:FAS4]GALREFDAT : Endif
  Endif
  #--------------
  For nolign = 1 To [M:FAS3]NBLIG1
    # Date de début d'amortissement
    Case func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(nolign-1), [M:FAS0]CPY)
      When GVML_TPURDAT : [M:FAS3]STRDPRDAT(nolign-1) = VALEUR
      When GVML_TITSDAT : [M:FAS3]STRDPRDAT(nolign-1) = [M:FAS1]ITSDAT
      When GVML_TACCDAT : [M:FAS3]STRDPRDAT(nolign-1) = [M:FAS1]AASIPTDAT
      When Default
    Endcase
    Affzo [M:FAS3]STRDPRDAT(nolign-1)
  Next nolign

  # le cumul d'amt peut devenir saisissable en fonction de la date de début d'amortissement
  Gosub MODIF_REDUITE From SUBFAS2

  #------------------------
  # Détermination de la durée pour régularisation TVA
  If GKFR = G_OUI Then : # FQ57624
    Call EVAL_PERIODE_REGUL_TVA([M:FAS2]TAXTYP,VALEUR,[M:FAS5]THESLI) From TRTFAS
    Affzo [M:FAS5]THESLI
  Endif
End


######################################################################
Subprog AS_OWNTYP(VALEUR)
Variable Integer VALEUR
  # Type de détention "Annulé" exclu de la liste des valeurs saisissables
  # Un bien "Annulé" est un bien de la société cédante dans une opération cession intra-groupe qui n'a
  # pas encore été amorti à la date de l'opération
  GMENLOC(GVML_TDANNUL)=1
  # FQ54343
  If ( G_ACTCCN <> G_OUI ) Then : GMENLOC(GVML_TDCONCE)=1 : Endif
  If ( G_ACTCCN =  G_OUI and G_CCNFLG <> G_OUI ) Then : GMENLOC(GVML_TDCONCE)=1 : Endif
End

###################################################################### FQ65623
Subprog C_OWNTYP(VALEUR)
Variable Integer VALEUR
  If [M:FPC]CREDIRFAS=G_NON and GNBDEPLIEES=0 and find(VALEUR,GVML_TDPROPR,GVML_TDCONCE)<>0
    GMESSAGE = mess(258,7770,1)-[M:FPC]CPY
    mkstat   = 2
    End
  Endif
End

##############################
Subprog AM_OWNTYP(VALEUR)
Variable Integer VALEUR

  #GBN-Fq56402-Manip LEAREF conditionné par le code activité LEA activé.
  If G_ACTLEA=G_OUI & ( VALEUR <> GVML_TDCBAIL and  VALEUR <> GVML_TDLOCAT ) Then
    [M:FAS2]LEAREF = "" :   Affzo  [M:FAS2]LEAREF
  Endif

  If ( [M:FAS1]OWNTYP = GVML_TDCONCE and VALEUR <> GVML_TDCONCE) Then
    # FQ54343
    Effzo [M:FAS6]1-99
  Endif
  # FQ50972
  # FQ54343
  If (G_ACTCCN = G_OUI) Then
    If ( VALEUR = GVML_TDCONCE ) Then
      # Recherche concession par défaut
      Filter [CCN] Where CPY= [M:FAS0]CPY and DFTCCNFLG = G_OUI
      Read [CCN]CCN0 First
      If (fstat) Then
        [M:FAS6]CCNREF   = ""            : Affzo  [M:FAS6]CCNREF
        [M:FAS6]ZCCNREF  = ""            : Affzo  [M:FAS6]ZCCNREF
      Else
        [M:FAS6]CCNREF   = [F:CCN]CCNREF : Affzo  [M:FAS6]CCNREF
        Affzo  [M:FAS6]ZCCNREF
      Endif
      Filter [CCN]
    Endif
    Setmok [M:FAS6] With 0
 Endif
  # modif réduite
  [M:FAS1]OWNTYP = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2
End

######################################################################
Subprog C_AASIPTDAT(VALEUR)
Variable Date    VALEUR

  # Date de début d'amortissement > 01/01/2200
  If ( VALEUR>=[01/01/2200] ) Then
   GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
   mkstat = 2 : End
  Endif

  # La date de comptabilisation doit être >= à la date d'achat
  # FQ82797
  # Ne pas faire ces tests si en import et date d'imput < exe courant
  If GIMPORT and
&     func TRTFAS.IS_INF_EXC ([M:FAS0]CPY, VALEUR, 0) = 1
  Else
    If ( VALEUR < [M:FAS1]PURDAT  ) Then
      GERR= 1: GMESSAGE = mess(13,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

    If  [M:FAS9]CREORI <> GVML_COREPRI   #FQ-64727
       If ( [M:FAS0]PRVSITUPD = G_NON ) and not ( func TRTFAS.IS_SUPEG_EXC ([M:FAS0]CPY, VALEUR, 0) ) Then
         GERR= 1: GMESSAGE = mess(494, GML_MSGFAS,1)
         mkstat = 2 : End
       Endif
      Endif #FQ-64727
    Endif

End

##############################
Subprog AM_AASIPTDAT(VALEUR)
Variable Date    VALEUR

  #FQ80672
  If [M:FAS0]PRVSITUPD = G_NON and (GREP = "" or GREP = "M")
    If func SUBFAS2.DATEMEMEEXE([M:FAS0]CPY, [M:FAS1]AASIPTDAT, VALEUR) = 0
      GERR = 1
      # GMESSAGE = "Changement d'exercice interdit"
      GMESSAGE = mess(877, GML_MSGFAS, 1)
      mkstat = 2
      End
    Endif
  Endif

  # Détermination de la date de début d'amortissement.
  For nolign=1 To [M:FAS3]NBLIG1
    If [M:FAS3]DPM(nolign-1)<>""
      If func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(nolign-1), [M:FAS0]CPY)=GVML_TACCDAT
        [M:FAS3]STRDPRDAT(nolign-1)=VALEUR : Affzo [M:FAS3]STRDPRDAT(nolign-1)
      Endif
    Endif
  Next
End

######################################################################
Subprog AS_ITSDAT(VALEUR)
Variable Date    VALEUR
End

##############################
Subprog C_ITSDAT(VALEUR)
Variable Date    VALEUR
  If ( VALEUR >= [01/01/2200] ) Then
    GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
    mkstat = 2 : End
  Endif
End

##############################
Subprog AM_ITSDAT(VALEUR)
Variable Date    VALEUR

Local Integer    OK

  #FQ80672
  If [M:FAS0]PRVSITUPD = G_NON and (GREP = "" or GREP = "M")
    If func SUBFAS2.DATEMEMEEXE([M:FAS0]CPY, [M:FAS1]ITSDAT, VALEUR) = 0
      GERR = 1
      # GMESSAGE = "Changement d'exercice interdit"
      GMESSAGE = mess(877, GML_MSGFAS, 1)
      mkstat = 2
      End
    Endif
  Endif

  # La date de mise en service doit être >= à la date d'achat
  If ( VALEUR < [M:FAS1]PURDAT and VALEUR <> [0/0/0] ) Then
    Call OUINON(mess(16,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1) Then : mkstat = 2 : End : Endif
  Endif

  # La date de mise en service doit être >= à la date de comptablisation
  If ( VALEUR < [M:FAS1]AASIPTDAT and VALEUR <> [0/0/0]) Then
    Call OUINON(mess(1,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1) Then : mkstat = 2 : End : Endif
  Endif

  # Détermination de la date de début d'amortissement.
  For nolign=1 To [M:FAS3]NBLIG1
   If [M:FAS3]DPM(nolign-1)<>""
    If func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(nolign-1), [M:FAS0]CPY)=GVML_TITSDAT
     [M:FAS3]STRDPRDAT(nolign-1)=VALEUR : Affzo [M:FAS3]STRDPRDAT(nolign-1)
    Endif
   Endif
  Next

End

######################################################################
Subprog AS_AASTYP(VALEUR)
Variable Integer VALEUR
  # FQ76979 : Suppression des valeurs "Immeubles de placement" et "Actifs biologiques" sauf pour le Portugal
  If [M:FPC]LEG <> "POR"
    GMENLOC(5) = 1
    GMENLOC(6) = 1
  Endif
End

######################################################################
Subprog C_AASQTY(VALEUR)
Variable Decimal VALEUR
  # La quantité doit être supérieure à 0.
  If (VALEUR <= 0) Then
    GERR= 1: GMESSAGE = mess(21,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

######################################################################
Subprog AM_ACGGRP(VALEUR)
Variable Char    VALEUR()

Local Integer RFLGASS
Local Integer LCLS


  # Activation de toutes les rubriques pouvant être déterminées par association
  # avant l'application de l'association
  If ( [M:FAS1]ACGGRP <> "" ) Then
    Call  RUBRIQUES_DETERMINEES(GVML_OMBIEN, [M:FAS0]CPY, G_NON) From TRTASSO
  Endif

  # On applique l'association si la famille est renseignée
  If ( VALEUR <> "" ) Then
    # Application de l'association si elle a été définie et activée pour le déterminant
    # famille
    #*Fq-59277 Call GERER_ASSOCIATION( VALEUR, "FAM","FAS",GBOITE,RFLGASS ) From TRTASSO
    Call GERER_ASSOCIATION( VALEUR, "FAM","FAS",[M:FAS1]OWNTYP,GBOITE,RFLGASS ) From TRTASSO
  Endif

  GFLGASS = RFLGASS

  # Gestion de l'association si elle a été définie et activée pour le déterminant
  # code comptable suite à l'application de l'association sur la famille
  If ( GFLGASS = G_OUI  and [M:FAS1]ACCCOD <> "" ) Then
    #*Fq-59277 Call GERER_ASSOCIATION([M:FAS1]ACCCOD, "COD","FAS", GBOITE,RFLGASS) From TRTASSO
    Call  GERER_ASSOCIATION([M:FAS1]ACCCOD, "COD","FAS",[M:FAS1]OWNTYP, GBOITE, RFLGASS) From  TRTASSO
  Endif

  GFLGASS = RFLGASS

  Local Decimal TXTVAREC
  Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
  TXTVAREC = TXTVAREC * 100.
  If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
    [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
    # FQ98116
    [M:FAS1]DEDVATFLG  = G_NON
    If (GCNXPROIAS = G_OUI) Then
      [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
      [M:FAS1]DEDVATFLGI = G_NON
    Endif
    # FQ98116
    Gosub CALCUL_MONTANTS_TVA
  Endif

  #- 1 -----------------------------
  If ([M:FAS1]ACCCOD <> "") Then
    # Récupération  Compte et Nature PCG/IAS à partir du code comptable
    Call EXPLOITE_CODE_COMPTABLE ([M:FAS1]ACCCOD)

    If ( mkstat = 2 ) Then
      # Remise à blanc du code comptable car problème détecté sur le compte PCG et/ou IAS du code comptable
      [M:FAS1]ACCCOD = "" : Affzo [M:FAS1]ACCCOD : Actzo [M:FAS1]ACCCOD
      mkstat = 2
      End
    Endif

    If (GNBDEPLIEES=0) : # FQ98116
      If [M:FAS1]GACACN=GVML_NICHARG
        Diszo [M:FAS1]ACGETRNOT
        Diszo [M:FAS1]IVCVATAMT  #Fq-65312 corr annexe
        Diszo [M:FAS1]IVCVATRAT  #Fq-65312 corr annexe
      Else
        Actzo [M:FAS1]ACGETRNOT
        Actzo [M:FAS1]IVCVATAMT  #Fq-65312 corr annexe
        Actzo [M:FAS1]IVCVATRAT  #Fq-65312 corr annexe
      Endif

      If (G_PLNIAS) Then
        If [M:FAS1]IASACN=GVML_NICHARG
          Diszo [M:FAS1]IASETRNOT
          Diszo [M:FAS1]IVCVATAMTI  #Fq-65312 corr annexe
          Diszo [M:FAS1]IVCVATRATI #Fq-65312 corr annexe
        Else
          Actzo [M:FAS1]IASETRNOT
          Actzo [M:FAS1]IVCVATAMTI  #Fq-65312 corr annexe
          Actzo [M:FAS1]IVCVATRATI #Fq-65312 corr annexe
        Endif
      Endif
    Endif
  Endif
  #- 1 -----------------------------

  #- 1 -----------------------------
  If   (GREP = "C") and (GFLGASS= G_OUI) and (VALEUR <> "") Then
    # >>>>>>>>>>>>>>>>>>
    For I = 1 To [M:FAS3]NBLIG1
      If ( [M:FAS3]DPM(I-1) <> "" and ([M:FAS3]DPRDUR(I-1) <> 0 or [M:FAS3]DPRRAT(I-1) <> 0) ) Then
        PLIGNE=I
        Call RUBRIQUES_DETERMINEES_P(GVML_OMBIEN,[M:FAS0]CPY,"FAM",[M:FAS3]DPRPLN(I-1),PLIGNE) From TRTASSO
        Call RUBRIQUES_DETERMINEES_P(GVML_OMBIEN,[M:FAS0]CPY,"COD",[M:FAS3]DPRPLN(I-1),PLIGNE) From TRTASSO
      Endif
      Case func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(I-1), [M:FAS0]CPY)
        When GVML_TPURDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]PURDAT
        When GVML_TITSDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]ITSDAT
        When GVML_TACCDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]AASIPTDAT
        When Default
      Endcase
      Affzo [M:FAS3]STRDPRDAT(I-1)
    Next I
    # <<<<<<<<<<<<<<<<<
  Endif
  #- 1 -----------------------------

End

######################################################################
Subprog C_ACGGRP(VALEUR)
Variable Char    VALEUR

  If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif   #FQ-71562 tables diverses
#  Read [ADI]CODE = GTD_FAMCPT;VALEUR
  Read [FAM]FAM0 = VALEUR
  If fstat=0
    If   !(func TRTFAS.IS_LEG_ACGGRP_OK([M:FPC]LEG, VALEUR)) Then
      GERR= 1: GMESSAGE = mess(683,GML_MSGFAS,1)-" "-[M:FPC]LEG
      mkstat = 2 : End
    Endif
  Endif
End

#============================================
Subprog EXPLOITE_CODE_COMPTABLE (PACCCOD)
Value Char PACCCOD
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
Local Integer I, PLIGNE

  GGACIMMO=0
  GIASIMMO=0

  Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, PACCCOD, GGACIMMO, GIASIMMO,
&                                LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
  # FQ60332 : amélioration des messages portant sur le contrôle des natures PCG et IAS à partir du code comptable
  #If ( LGACACN = 0 and LIASACN  = 0 ) Then
  #  # Code comptable invalide
  #  GMESSAGE = mess(39,GML_MSGFAS,1) : GERR=1 : mkstat = 2 : End
  #Endif
  If ( LGACACN = 0 ) Then
    ## Le compte d'immobilisation PCG est invalide pour le code comptable
    #GMESSAGE = mess(516,GML_MSGFAS,1)-PACCCOD
    # Le compte d'immobilisation PCG associé au code comptable est invalide ou sa nature est incorrecte.
    GMESSAGE = PACCCOD-mess(422,GML_MSGFAS,1) : # FQ60332
    GERR     = 1
    mkstat   = 2
    End
  Endif
  If ( G_PLNIAS and LIASACN = 0 ) Then
    ## Le compte d'immobilisation IFRS est invalide le code comptable
    #GMESSAGE = mess(517,GML_MSGFAS,1)-PACCCOD
    # Le compte d'immobilisation IFRS associé au code comptable est invalide ou sa nature est incorrecte.
    GMESSAGE = PACCCOD-mess(423,GML_MSGFAS,1) : # FQ60332
    GERR     = 1
    mkstat   = 2
    End
  Endif
  # FQ95579 + GFASLEDSOC et [M:FAS1]GAC remplacé par LGAC
  Call CTRL_AUT_OBJ("GAC", LGAC, GFASLEDSOC, [M:FAS0]FCY, date$) From GLOBIENS
  If ( mkstat) Then
    GMESSAGE = mess(243,GML_MSGFAS,1)-GMESSAGE
    GERR     = 1
    mkstat   = 2
    End
  Endif
  If (G_PLNIAS) Then
    # FQ95579 + GFASLEDIAS et [M:FAS1]IASACC remplacé par LIASACC
    Call CTRL_AUT_OBJ("GAC", LIASACC, GFASLEDIAS, [M:FAS0]FCY, date$) From GLOBIENS
    If mkstat Then
      GMESSAGE = mess(245,GML_MSGFAS,1)-GMESSAGE
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif

  Raz [M:FAS1]GACACN, GAC
  If ( LGACACN <> 0 ) Then
    [M:FAS1]GACACN = LGACACN
    [M:FAS1]GAC    = LGAC
  Endif
  Raz [M:FAS1]IASACN, IASACC
  If ( G_PLNIAS and LIASACN <> 0 ) Then
    [M:FAS1]IASACN = LIASACN
    [M:FAS1]IASACC = LIASACC
  Endif
  If (dim([M:FAS1]ZGACACN) > 0 ) Then : Affzo [M:FAS1]ZGACACN  : Endif
  If (dim([M:FAS1]ZGAC)    > 0 ) Then : Affzo [M:FAS1]ZGAC     : Endif
  Affzo [M:FAS1]GACACN, GAC #, ACCCOD
  If ( G_PLNIAS and LIASACN <> 0 ) Then
    If (dim([M:FAS1]ZIASACN) > 0 ) Then : Affzo [M:FAS1]ZIASACN  : Endif
    If (dim([M:FAS1]ZIASACC) > 0 ) Then : Affzo [M:FAS1]ZIASACC  : Endif
    Affzo [M:FAS1]IASACN, IASACC
  Endif

End
#============================================

########################################
Subprog AM_ACCCOD(VALEUR)
Variable Char    VALEUR()

Local Integer RFLGASS
Local Integer LCLS

  # Activation de toutes les rubriques pouvant être déterminées par association
  # avant l'application de l'association.
  If ( [M:FAS1]ACCCOD <> "" ) Then
    Call  RUBRIQUES_DETERMINEES(GVML_OMBIEN, [M:FAS0]CPY, G_NON) From TRTASSO
  Endif

  If ( VALEUR <> "" ) Then
    # Gestion de l'association si elle a été définie et activée pour le déterminant
    # code comptable
    #*Fq-59277 Call GERER_ASSOCIATION(VALEUR, "COD","FAS",GBOITE, RFLGASS)From TRTASSO
    Call GERER_ASSOCIATION(VALEUR, "COD","FAS",[M:FAS1]OWNTYP, GBOITE, RFLGASS)From TRTASSO
  Endif

  GFLGASS = RFLGASS

  Local Decimal TXTVAREC
  Call TVA_COE_DEDUCTION ( [M:FAS1]ASJCOE, [M:FAS1]TAXCOE, [M:FAS1]ADMCOE, TXTVAREC ) From TRTFAS
  TXTVAREC = TXTVAREC * 100.
  If ( [M:FAS1]DEDVATRAT <> TXTVAREC ) Then
    [M:FAS1]DEDVATRAT = TXTVAREC : Affzo [M:FAS1]DEDVATRAT
    # FQ98116
    [M:FAS1]DEDVATFLG  = G_NON
    If (GCNXPROIAS = G_OUI) Then
      [M:FAS1]DEDVATRATI = TXTVAREC : Affzo [M:FAS1]DEDVATRATI
      [M:FAS1]DEDVATFLGI = G_NON
    Endif
    # FQ98116
    Gosub CALCUL_MONTANTS_TVA
  Endif

  # Récupération  Compte et Nature PCG/IAS à partir du code comptable
  Call EXPLOITE_CODE_COMPTABLE (VALEUR)
  If mkstat = 2 : End : Endif

  If (GNBDEPLIEES=0) : # FQ98116
    If [M:FAS1]GACACN=GVML_NICHARG
      Diszo [M:FAS1]ACGETRNOT
      Diszo [M:FAS1]IVCVATAMT  #Fq-65312 corr annexe
      Diszo [M:FAS1]IVCVATRAT  #Fq-65312 corr annexe
    Else
      Actzo [M:FAS1]ACGETRNOT
      Actzo [M:FAS1]IVCVATAMT  #Fq-65312 corr annexe
      Actzo [M:FAS1]IVCVATRAT  #Fq-65312 corr annexe
    Endif

    If (G_PLNIAS) Then
      If [M:FAS1]IASACN=GVML_NICHARG
        Diszo [M:FAS1]IASETRNOT
        Diszo [M:FAS1]IVCVATAMTI  #Fq-65312 corr annexe
        Diszo [M:FAS1]IVCVATRATI  #Fq-65312 corr annexe
      Else
        Actzo [M:FAS1]IASETRNOT
        Actzo [M:FAS1]IVCVATAMTI  #Fq-65312 corr annexe
        Actzo [M:FAS1]IVCVATRATI  #Fq-65312 corr annexe
      Endif
    Endif
  Endif

  # FQ67615 Alimentation du statut selon la gestion paramétrée au niveau du compte immo. du code comptable
  Local Integer L_LVATYP
  Call GET_LVATYP_FROM_GACCODE (GVML_COGIMMO, VALEUR, GGACIMMO, L_LVATYP) From GLOBIENS
  If (L_LVATYP = GVML_GLVALVA)  Then : [M:FAS1]CMPSTA = GVML_SBLVA  : Affzo [M:FAS1]CMPSTA : Endif
  If (L_LVATYP = GVML_GLVAPOOL) Then : [M:FAS1]CMPSTA = GVML_SBPOOL : Affzo [M:FAS1]CMPSTA : Endif


  If   (GREP = "C") & (GFLGASS= G_OUI) and (VALEUR <> "") Then
    #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    For I = 1 To [M:FAS3]NBLIG1
      If  [M:FAS3]DPM(I-1) <> "" and ([M:FAS3]DPRDUR(I-1) <> 0 or [M:FAS3]DPRRAT(I-1) <> 0 ) Then
        PLIGNE=I
        Call RUBRIQUES_DETERMINEES_P(GVML_OMBIEN, [M:FAS0]CPY, "COD", [M:FAS3]DPRPLN(I-1), PLIGNE)
&            From TRTASSO
      Endif
      Case func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(I-1), [M:FAS0]CPY)
        When GVML_TPURDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]PURDAT
        When GVML_TITSDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]ITSDAT
        When GVML_TACCDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]AASIPTDAT
        When Default
      Endcase
      Affzo [M:FAS3]STRDPRDAT(I-1)
    Next I
    #<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  Endif

End

######################################################################
Subprog AS_SET(VALEUR)
Variable Char    VALEUR()

End

########################################
Subprog C_SET(VALEUR)
Variable Char    VALEUR()

  # La référence ensemble d'un bien peut être un ensemble quelconque ou la référence d'un bien.
  # Dans le premier cas tous les biens de l'ensemble doivent appartenir aux mêmes société et site financier.
  # Dans le second cas, la référence ne peut être que la référence du bien lui-même
  # ou la référence d'un bien ayant comme référence ensemble sa propre référence.
  # Il doit s'agir d'un bien appartenant à la même société et au même établissement que le bien rattaché
  #  De plus, son type de détention doit être différent de 'En prévision' et 'En modèle'.
  If ( ( VALEUR <> [M:FAS0]AASREF ) and  not (VALEUR = "" and GREP="C" )  ) Then
    Read[FASW]FAS0= VALEUR
    # Si l'ensemble n'est pas un bien comptable.
    If ( fstat ) Then
      Filter [FASW] Where SET = VALEUR and ( CPY <> [M:FAS0]CPY or FCY <> [M:FAS0]FCY )
      Read[FASW] First
      If ( fstat = 0 ) Then
        GERR= 1: GMESSAGE = mess(10,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
      Filter [FASW]
    # Si l'ensemble est un bien comptable.
    Else
      If ( [F:FASW]AASREF <> [F:FASW]SET or
&       [F:FASW]CPY <> [M:FAS0]CPY or [F:FASW]FCY <> [M:FAS0]FCY or
&       [F:FASW]OWNTYP = GVML_TDPREVU or [F:FASW]OWNTYP = GVML_TDMODEL ) Then
        GERR= 1: GMESSAGE = mess(10,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

######################################################################
Subprog AS_CMPSTA(VALEUR)
Variable Integer VALEUR
  # FQ67615 Statut LVA que pour AUT autriche ou GER allemagne
  #         Statut POol que pour GER
  If ( [M:FPC]LEG <> "GER" and [M:FPC]LEG <> "AUT" ) Then
    GMENLOC(GVML_SBPOOL) = 1
    GMENLOC(GVML_SBLVA ) = 1
  Elsif ([M:FPC]LEG = "AUT") Then
    GMENLOC(GVML_SBPOOL) = 1
  Endif
  If ( GREP <> "C"  and VALEUR <> GVML_SBPOOL and VALEUR <> GVML_SBLVA ) Then
    # FQ67615 En modification un bien ne peut pas devenir Pool ou LVA
    GMENLOC(GVML_SBPOOL) = 1
    GMENLOC(GVML_SBLVA ) = 1
  Endif
End

##########################################################################
Subprog AM_CMPSTA(VALEUR)
Variable Integer VALEUR

   If [M:FAS1]CMPSTA = GVML_SBPRINC and VALEUR <> GVML_SBPRINC
      If  [M:FAS0]LIKCMPFLG = G_OUI
         GERR= 1: GMESSAGE = mess(555,GML_MSGFAS,1)
         mkstat = 2 : End
      Endif
   Endif

   # FQ57863 : suppression du test interdisant le passage d'un bien autonome en bien
   #           principal ou composant lorsque ses éléments physiques portent des
   #           localisations différentes

   If ( VALEUR <> GVML_SBCOMPO ) Then
     [M:FAS1]CMP = "" : Affzo [M:FAS1]CMP
   Endif
   # modif réduite
   [M:FAS1]CMPSTA = VALEUR
   Gosub MODIF_REDUITE  From SUBFAS2
End

##########################################################################
Subprog AM_CMP(VALEUR)
Variable Char    VALEUR()

Local Integer N_I

  # FQ64491
  If GIMPORT : End : Endif

  # Bien principal et bien composant doivent appartenir
  # à la même société et au même site financier
  # Le bien principal doit avoir le statut à "Principal" ne pas être sorti et avoir
  # un type de détention différent de 'En prévision' et 'En modèle'
  # Le bien principal doit être calculé.

  # -1 ----------------------------------------------------
  If ( VALEUR <> "") Then
    Read[FASW]FAS0= VALEUR
    # FQ59451 : dans le test ci-dessous, le contrôle sur ISSDAT est fait hors import
    If ( fstat or [F:FASW]CPY    <> [M:FAS0]CPY  or [F:FASW]FCY    <> [M:FAS0]FCY or
&                 [F:FASW]CMPSTA <> GVML_SBPRINC or ([F:FASW]ISSDAT <> [0/0/0] and !GIMPORT) or
&                 [F:FASW]OWNTYP =  GVML_TDPREVU or [F:FASW]OWNTYP =  GVML_TDMODEL ) Then
      GERR= 1: GMESSAGE = mess(11,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

    If ( [F:FASW]FLGCLC = G_OUI) Then
      GERR= 1: GMESSAGE = mess(614,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

    # En création le bien composant hérite des affectations du bien principal
    # Le type de détention du composant hérite de celui du principal
    # Ces champs ne sont pas saisissables, sauf pour les informations analytiques
    # -2 -----------------------------------
    If (GREP = "C" ) Then
      # Type de détention
      [M:FAS1]OWNTYP  = [F:FASW]OWNTYP
      Affzo [M:FAS1]OWNTYP
      # Economiques
      If ([M:FAS1]AASBUS  <> [F:FASW]AASBUS ) Then
        [M:FAS1]AASBUS    = [F:FASW]AASBUS
        [M:FAS1]ASJCOE    = [F:FASW]ASJCOE
        [M:FAS1]TAXCOE    = [F:FASW]TAXCOE
        [M:FAS1]TAXCOEFLG = [F:FASW]TAXCOEFLG
        [M:FAS1]ADMCOE    = [F:FASW]ADMCOE
        G_AASBUS = 1
        Call AM_AASBUS([M:FAS1]AASBUS)
        G_AASBUS = 0
      Else
        [M:FAS1]AASBUS  = [F:FASW]AASBUS
      Endif
      Affzo [M:FAS1]AASBUS
      Affzo [M:FAS1]ASJCOE
      Affzo [M:FAS1]TAXCOE
      Affzo [M:FAS1]ADMCOE

      [M:FAS2]IASCGU  = [F:FASW]IASCGU
      Call ACTION_BLOCK (ACB_AFFZO, "FAS2", "IASCGU") From GLOBIENS
      # Analytiques
      [M:FAS2]DSP  = [F:FASW]DSP
      For N_I = 1 To GOPTCANA
        [M:FAS2]CCE(N_I-1) = [F:FASW]CCE(N_I-1)
        Affzo [M:FAS2]CCE(N_I-1)
      Next N_I

      # Calcul de la durée du plan fiscal pour un bien complémentaire (lecture du bien principal)
      # Vérification qu ele bien principal a bien été calculé
      Local Decimal L_DUREE
      Local Integer BERREUR
      Call CALCUL_DUREE_COMPL(VALEUR, L_DUREE, BERREUR)
      If (BERREUR) Then
        # Plan fiscal du bien principal non calculé
        GERR= 1: GMESSAGE = mess(623,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
      If ([M:FAS3]DPRDUR([M:FAS0]FISLIG-1) <> L_DUREE and L_DUREE <> 0 ) Then
        [M:FAS3]DPRDUR([M:FAS0]FISLIG-1) = L_DUREE
        Affzo [M:FAS3]DPRDUR([M:FAS0]FISLIG-1)
      Endif

    Endif
    # -2 -----------------------------------

    # En modification bien composant et bien principal
    # doivent avoir même imputations économiques, analytiques, géographiques
    #               même type de détention
    # -2 ----------------------------
    If (GREP = "M" ) Then
      If ( [F:FASW]AASBUS  <> [M:FAS1]AASBUS  or [F:FASW]IASCGU  <> [M:FAS2]IASCGU  or [F:FASW]OWNTYP  <> [M:FAS1]OWNTYP  ) Then
           GERR= 1: GMESSAGE = mess(11,GML_MSGFAS,1)
           mkstat = 2 : End
      Endif
      # Analytiques
      For N_I = 1 To GOPTCANA
        If ( [F:FASW]CCE(N_I-1) <>[M:FAS2]CCE(N_I-1) ) Then
          GERR= 1: GMESSAGE = mess(11,GML_MSGFAS,1)
          mkstat = 2 : End
        Endif
      Next N_I
    Endif
    # -2 ----------------------------
  Endif
  # -1 ----------------------------------------------------
  # modif réduite
  [M:FAS1]CMP = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2
End

########################################
Subprog C_CMP(VALEUR)
Variable Char    VALEUR()

  # Si le statut est 'Composant' la référence du bien principal
  # doit être précisée et ne doit pas être la même que celle du composant.
  If ( ( VALEUR = "" or VALEUR = [M:FAS0]AASREF ) and [M:FAS1]CMPSTA = GVML_SBCOMPO ) Then
    GERR= 1: GMESSAGE = mess(11,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif

End


######################################################################################
Subprog C_ACGETRNOT(VALEUR)
Variable Decimal VALEUR

  # Si le type de détention du bien est "En location" ou "En crédit bail"
  # la valeur d'entrée doit être égale à 0.
  #FQ-61084 If  ( VALEUR <> 0 and
  If  ( VALEUR <> 0 and GCNXPROIAS = G_OUI and
&     ( [M:FAS1]OWNTYP = GVML_TDLOCAT  or  [M:FAS1]OWNTYP = GVML_TDCBAIL ) and
&       func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" )    Then
#&       ( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) )    Then # FQ57624
    GERR= 1: GMESSAGE = mess(544,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif
End

