Variable Decimal VALEUR

  # Recalcul des montants de TVA
  [M:FAS1]IVCVATRAT = VALEUR
  Gosub TVA_FAC_PCG
  Gosub TVA_REC_PCG
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
End

######################################################################################
Subprog AV_IVCVATAMT(VALEUR)
Variable Decimal VALEUR
  If ([M:FAS1]IVCVATFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]IVCVATAMT With "FORCAGE"
    Else
      Chgstl [M:FAS1]IVCVATAMT With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FAS1]IVCVATAMT With ""
  Endif
End

########################################
Subprog AS_IVCVATAMT(VALEUR)
Variable Decimal VALEUR
  If ([M:FAS1]IVCVATFLG <> G_OUI or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]IVCVATAMT", 0) = G_NON ) Then
    GBOUT1 = ""
  Endif
End

########################################
Subprog AM_IVCVATAMT(VALEUR)
Variable Decimal VALEUR

  # Le montant TVA facturée doit être du même signe que la valeur d'entrée HT
  If ([M:FAS1]ACGETRNOT > 0 and VALEUR < 0) or ([M:FAS1]ACGETRNOT < 0 and VALEUR > 0) Then
    GERR= 1: GMESSAGE = mess(22,GML_MSGFAS,1)
    mkstat = 2
    End
  Endif

  # En valeur absolue, le montant TVA facturée doit être inférieur à la valeur d'entrée HT
  If abs(VALEUR) > abs([M:FAS1]ACGETRNOT) Then
    GERR= 1: GMESSAGE = mess(23,GML_MSGFAS,1)
    mkstat = 2
    End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    [M:FAS1]IVCVATFLG = G_OUI:  Affzo [M:FAS1]IVCVATFLG
    Affzo [M:FAS1]IVCVATAMT
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]IVCVATAMT With "FORCAGE"
    Else
      Chgstl [M:FAS1]IVCVATAMT With "TFORCAGE"
    Endif
  Endif

  # Recalcul des montants de TVA
  [M:FAS1]IVCVATAMT = VALEUR
  Gosub TVA_REC_PCG
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
End

########################################
Subprog B1_IVCVATAMT(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:FAS1]IVCVATFLG = G_NON : Affzo [M:FAS1]IVCVATFLG

  Gosub TVA_FAC_PCG
  Gosub TVA_REC_PCG
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
  VALEUR = [M:FAS1]IVCVATAMT

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS1]IVCVATAMT  With ""
  Affzo [M:FAS1]IVCVATAMT
  mkstat = 99

End

########################################
Subprog AM_DEDVATRAT(VALEUR)
Variable Decimal VALEUR

  # Recalcul des montants de TVA
  [M:FAS1]DEDVATRAT = VALEUR
  If (G_PLNIAS) Then
  [M:FAS1]DEDVATRATI = VALEUR : Affzo [M:FAS1]DEDVATRATI
  Endif
  Gosub TVA_REC_PCG
  Gosub TVA_REC_IAS
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
End

########################################
Subprog AV_DEDVATAMT(VALEUR)
Variable Decimal VALEUR
  If ([M:FAS1]DEDVATFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]DEDVATAMT With "FORCAGE"
    Else
      Chgstl [M:FAS1]DEDVATAMT With "TFORCAGE"
    Endif
    If (GNBDEPLIEES = 0) Then
      Diszo [M:FAS1]DEDVATAMT #*FQ98116
    Endif
  Else
    Chgstl [M:FAS1]DEDVATAMT With ""
  Endif

  If ( [M:FAS1]DEDVATRAT = 100 or [M:FAS1]DEDVATRAT = 0.) Then
    Diszo [M:FAS1]DEDVATAMT
  Endif

End

########################################
Subprog AS_DEDVATAMT(VALEUR)
Variable Decimal VALEUR
  If ([M:FAS1]DEDVATFLG <> G_OUI or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS1]DEDVATAMT", 0) = G_NON  ) Then
    GBOUT1 = ""
  Endif
End

########################################
Subprog AM_DEDVATAMT(VALEUR)
Variable Decimal VALEUR

  # Le montant TVA récupérée doit être du même signe que la valeur d'entrée HT
  If ([M:FAS1]ACGETRNOT > 0 and VALEUR < 0) or ([M:FAS1]ACGETRNOT < 0 and VALEUR > 0) Then
    GERR= 1: GMESSAGE = mess(24,GML_MSGFAS,1)
    mkstat = 2
    End
  Endif

  # En valeur absolue, la TVA récupérée doit être inférieure à la TVA facturée
  If abs(VALEUR) > abs([M:FAS1]IVCVATAMT) Then
    GERR= 1: GMESSAGE = mess(25,GML_MSGFAS,1)
    mkstat = 2
    End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    [M:FAS1]DEDVATFLG = G_OUI:  Affzo [M:FAS1]DEDVATFLG
    Affzo [M:FAS1]DEDVATAMT
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS1]DEDVATAMT With "FORCAGE"
    Else
      Chgstl [M:FAS1]DEDVATAMT With "TFORCAGE"
    Endif

  Endif

  # Recalcul des montants de TVA
  [M:FAS1]DEDVATAMT = VALEUR
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
End

