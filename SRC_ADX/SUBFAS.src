Subprog AM_IASCURTYP(VALEUR)
Variable Integer VALEUR

  # Recalcul des montants de TVA
  [M:FAS1]IASCURTYP= VALEUR
  # Détermination du taux en fonction du nouveau type de cours
  Call CDVCAL( [M:FAS1]IASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY, [M:FAS1]IASCURTYP,
&            [M:FAS1]PURDAT  ) From TRTDIV
  Affzo [M:FAS1]IASRATCUR
  Gosub CONV_PCG_IAS
  Gosub TVA_FAC_IAS
  Gosub TVA_REC_IAS
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
End


