$AVANT_DEVERROU

 If !GIMPORT & dim(GFASANNULE)>0
  Kill GFASANNULE
  Gosub AP_ANNULE_FASCNL From SUBFASCNL
  Local Integer ERROR
  Call TEMPON("Comptabilisation en cours ...") From GESECRAN
  Call COMPTA_DIRECTE([F:FAS]CPY, [F:FAS]FCY, [F:FAS]AASREF, 0, "", ERROR) From TRTCPTINT
  Call TEMPOFF() From GESECRAN
  If GTRACE<>"" & dim(LTRCOPE)>0
   Call LEC_TRACE From LECFIC
   Kill LTRCOPE
  Endif
  #FQ51827-GBN-010909
