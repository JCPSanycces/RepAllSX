#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UTIGPA01        Utilitaire de récupération du bug 9734    Module GPAO  #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Sur certaines matières soldées des allocations ont été générées à    #
#     tort. Il faut les supprimer et mettre à jour la qté allouée de la  #
#     matière si besoin.                                                 #
##########################################################################

Call MAJ_UTIGPA01
End


Subprog MAJ_UTIGPA01
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("Correction") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPA01(DOSSIER)
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA01(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA01 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MFM])  =0  Local File =DOSSIER+".MFGMAT"      [MFM]  : Endif
If clalev([F:MFM2]) =0  Local File =DOSSIER+".MFGMAT"      [MFM2] : Endif
If clalev([F:STA])  =0  Local File =DOSSIER+".STOALL"      [STA]  : Endif
If clalev([F:STA1]) =0  Local File =DOSSIER+".STOALL"      [STA1] : Endif
If clalev([F:STA2]) =0  Local File =DOSSIER+".STOALL"      [STA2] : Endif
If clalev([F:MFI])  =0  Local File =DOSSIER+".MFGITM"      [MFI]  : Endif
If clalev([F:ITM])  =0  Local File =DOSSIER+".ITMMASTER"   [ITM]  : Endif
If clalev([F:ITF])  =0  Local File =DOSSIER+".ITMFACILIT"  [ITF]  : Endif
If clalev([F:ORD])  =0  Local File =DOSSIER+".ORDERS"      [ORD]  : Endif
If clalev([F:ITV])  =0  Local File =DOSSIER+".ITMMVT"      [ITV] : Endif
If clalev([F:STO])  =0  Local File =DOSSIER+".STOCK"       [STO] : Endif
#----- masque encours
Local Mask =DOSSIER+".ORDK" [ORDK]
#----- masque STOCK
Local Mask =DOSSIER+".STOK" [STOK]
#----- Variables locales -----#
Local Char     WMESSAGE(80)
Local Integer  WALLOC
Local Char     WFCY
Local Integer  WTYP
Local Char     WNUM
Local Decimal  WLIN
Local Decimal  WSEQ
Local Char     WITM
Local Integer  WOPT
Local Decimal  WQTY
Local Decimal  WSHT
Local Integer  WRET

Local Integer COMPTEUR, STOP : # pour éviter erreur snapshot (TB 30/03/00)
Local Char     CLE1(20), CLE3(20), CRITERE(200)
Local Integer  CLE2, CLE4, CLE5

#----------------------------------------------------------------#
# Première boucle : on part des matières
#----------------------------------------------------------------#
Call ECR_TRACE("UTIGPA01 : début phase 1 ",0) From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFM_1
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+
&                                      ' & ITMREF >"'+CLE3+'"'
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ >'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN >'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
# Issue 75269 suite GA 05/2012
#CRITERE -="& (MFMTRKFLG = 5 | ([F:MFM2]RETQTY - [F:MFM2]USEQTY <= 0))"
CRITERE -="& (find(MFMTRKFLG,5,6) | ([F:MFM2]RETQTY - [F:MFM2]USEQTY <= 0))"

Raz COMPTEUR

Call DEBTRANS From GLOCK
Trbegin [MFM]

For [F:MFM2] Where evalue(CRITERE)
    Raz WALLOC
    Filter [F:STA2] Where VCRTYP = 10 & VCRNUM = [F:MFM2]MFGNUM & VCRLIN = [F:MFM2]MFGLIN &
&                        VCRSEQ = [F:MFM2]BOMSEQ & ITMREF = [F:MFM2]ITMREF
    Read [F:STA2]STA0 First
    If !fstat : WALLOC = 2 : Else WALLOC = 1: Endif
    Filter [F:STA2]
    If WALLOC = 2 | [F:MFM2]ALLQTY <> 0 | [F:MFM2]SHTQTY <> 0
       GOK=1
       Readlock [F:MFM]MFM0 =[F:MFM2]MFGNUM;[F:MFM2]MFGLIN;[F:MFM2]BOMSEQ;[F:MFM2]ITMREF
       If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MFM2]ITMREF : Break
       Elsif fstat GOK=0  : Call RSTA("MFM",[F:MFM2]ITMREF) From GLOCK : Break
       Endif
       If WALLOC = 2
           # FQ 75269 GA 10/2011
           #Gosub SUPALL_OF From SUBMTKC
           Call DELALL(12,[F:MFM2]MFGNUM,[F:MFM2]MFGLIN,[F:MFM2]BOMSEQ,[F:MFM2]ITMREF,0,[F:MFM2]ALLQTY,[F:MFM2]SHTQTY,WRET) From STKALL
           If GOK < 1
              Call ECR_TRACE("Erreur allocations du composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF,1) From GESECRAN
              GOK = 0
              Goto NXT1
           Endif
       Endif
       Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
       Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
       Read [F:MFI]MFI0 First
       If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK     # llc 05.02 cohérence
           Filter [F:MFI]
           Break
       Endif
       Filter [F:MFI]
       Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
       Rewrite [F:MFM]
       If fstat
          GOK = 0 : Call FSTA("MFM") From GLOCK
          Call ECR_TRACE("Erreur="+num$(fstat)+" sur composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF,1) From GESECRAN
          Break
       Endif
       Call ECR_TRACE("Composant "+[F:MFM]MFGNUM - [F:MFM]ITMREF +" traité ",0) From GESECRAN
    Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS
        CLE1 = [F:MFM2]MFGNUM
        CLE2 = [F:MFM2]MFGLIN
        CLE4 = [F:MFM2]BOMSEQ
        CLE3 = [F:MFM2]ITMREF
        STOP = 1
        Break
    Endif
$NXT1
Next
If GOK <= 0
   Rollback
Else
 Commit
Endif
If STOP : Goto BOUCLE_MFM_1 : Endif
Call ECR_TRACE("UTIGPA01 : fin phase 1 ",0) From GESECRAN

#----------------------------------------------------------------#
# Deuxième boucle : on part des allocation
# On supprime les allocations sans matière
#----------------------------------------------------------------#
Call ECR_TRACE("UTIGPA01 : début phase 2 ",0) From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFM_2
If STOP=1
  STOP=2 : CRITERE='STOFCY="'+CLE1+'"'+' & ITMREF ="'+(CLE3)+'"'+' & STOCOU='+num$(CLE2)+
&                                      ' & SEQ >'+num$(CLE4)
Elsif STOP=2
  STOP=3 : CRITERE='STOFCY="'+CLE1+'"'+' & ITMREF ="'+(CLE3)+'"'+' & STOCOU >'+num$(CLE2)
Elsif STOP=3
  STOP=4 : CRITERE='STOFCY="'+CLE1+'"'+' & ITMREF >"'+(CLE3)+'"'
Elsif STOP=4
  STOP=0 : CRITERE='STOFCY>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
CRITERE -="& VCRTYP = 10"
Raz COMPTEUR

Call DEBTRANS From GLOCK
Trbegin [MFM]


For [F:STA2] Where evalue(CRITERE)
    Read [F:MFM2]MFM0 = [F:STA2]VCRNUM;[F:STA2]VCRLIN;[F:STA2]VCRSEQ;[F:STA2]ITMREF
    If fstat
       GOK=1
       WFCY = [F:STA2]STOFCY
       WNUM = [F:STA2]VCRNUM
       WLIN = [F:STA2]VCRLIN
       WTYP = 10
       WSEQ = [F:STA2]VCRSEQ
       WITM = [F:STA2]ITMREF
       WOPT = 0
       WRET = 0
       # FQ 75269 GA 10/2011 ALLLIB n'existe plus depuis la V140
       #Case [F:STA2]ALLTYP :
       #     When 1,5 :
       #         Call DELGLO(WTYP,WNUM,WLIN,WSEQ,WITM,WOPT,WQTY,WSHT,WRET) From ALLLIB
       #
       #     When 2,4 :
       #         Call DELALL(WTYP,WNUM,WLIN,WSEQ,WITM,WOPT,WQTY,WSHT,WRET) From ALLLIB
       #Endcase
       Call SUPALL([F:STA2]STOFCY,[F:STA2]ITMREF,[F:STA2]STOCOU,[F:STA2]SEQ,WRET) From STKALL
       If WRET <> 0 : Break : Endif
       Call ECR_TRACE("Allocation sur Composant "+[F:STA2]VCRNUM - [F:STA2]ITMREF +" supprimée ",0) From GESECRAN
    Endif
     COMPTEUR += 1
     If COMPTEUR > GMAXUPDTRS
        CLE1 = [F:STA2]STOFCY
        CLE3 = [F:STA2]ITMREF
        CLE2 = [F:STA2]STOCOU
        CLE4 = [F:STA2]SEQ
        STOP = 1
        Break
     Endif
Next

If GOK <= 0
   Rollback
Else
 Commit
Endif
If STOP : Goto BOUCLE_MFM_2 : Endif
Call ECR_TRACE("UTIGPA01 : fin phase 2 ",0) From GESECRAN

#----- Fin du traitement -----#
$FIN_UTIGPA01
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPA01(APPLI)
End
