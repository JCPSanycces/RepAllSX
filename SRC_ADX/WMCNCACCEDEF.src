#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## ACLA-CLASSE ## CACCEDEF
# 2018-11-06 07:04:06 451

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0CACCEDEF
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_COD From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_CPY From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_DES From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_DESSHO From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_DESTRA From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_SHOTRA From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_MODULE From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_NBRDIE From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_NBLIG From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub AINIT From WMC0CACCEDEF : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0CACCEDEF
Gosub _ALOADATTRIBUTE_COD From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CPY From WMC1CACCEDEF : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0CACCEDEF
Gosub LNKPRO_COD From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub LNKPRO_CPY From WMC1CACCEDEF : Gosub TESTALLSTAT
For AINDCLA=1 To 25
 If this.IDENT(AINDCLA)<>null& find(this.IDENT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.IDENT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null& find(this.DIMCEN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null& find(this.LISCCE(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_CREUSR From WMC1CACCEDEF : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1CACCEDEF : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



