############################################################
# CALNBENR : Compte le nombre d'enregistrement déjà traité #
#            et le nombre d'enregistrement total à traiter #
# -------------------------------------------------------- #
# Appelé depuis le traitement SUBSIM                       #
# La clase [M:SIM2] doit être ouverte et chargée           #
# WNOL est l'indice de la ligne en cours de traitement     #
# -------------------------------------------------------- #
# En sortie :                                              #
#    [M:SIM2]NB2TRT chargé avec nbre total à traiter       #
#    LMES chargé avec "nbre traité / nbre total"           #
############################################################
Funprog CALNBENR(WNOL)
Value Integer WNOL
#-----
Local Char    LMES(30)
Local Integer WNBCDE
#----- Nombre total d'enregistrements reste à traiter -----#
Local File XIEPA [XEPA] Where TYPPIE="CF"
&                           & FLGMAJ=""
&                           & FLGREP<2
&                           & DATPIE>=[F:SPX]STRPER
WNBCDE=rowcount([XEPA])
Close Local File [XEPA]
#-----
LMES=num$(WNBCDE)-"/"
#----- Nombre total d'enregistrements à traiter -----#
Local File XIEPA [XEPA] Where TYPPIE="CF"
&                           & FLGMAJ=""
&                           & DATPIE>=[F:SPX]STRPER
WNBCDE=rowcount([XEPA])
Close Local File [XEPA]
#-----
LMES-=num$(WNBCDE)
[M:SIM4]NB2TRT(WNOL)=WNBCDE
#-----
End LMES


#-----------------------#
# Création des acomptes #
#-----------------------#
$CREATION_ACOMPTES
#----- Suppression des acomptes générés en standard -----#
Call ACOMPTES(6,2,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,
&             [F:POH]TTVORD,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]BPSINV,[F:POH]BPRPAY,
&             [F:POH]BPAPAY,1,OK) From TRTTPT
If GOK<1  Return : Endif
#----- Création des acomptes à partir de ceux de l'intégrale -----#
Gosub SIXRECUPTABI
If GNBEAA=0  Return : Endif
Call SIXACOMPTES(6,1,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,
&                [F:POH]TTVORD,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]BPSINV,[F:POH]BPRPAY,
&                [F:POH]BPAPAY,1,OK)
Return


#---------------------------------------------#
# Récupération des acomptes dans des tableaux #
#---------------------------------------------#
$SIXRECUPTABI
#-----
Local Char WCODTVA(GLONVAT)
#-----
If !clalev([F:XEAA])  Local File =SI_DOSSIER+".XIEAA"    [XEAA] : Endif
If !clalev([F:XLAA])  Local File =SI_DOSSIER+".XILAA"    [XLAA] : Endif
If !clalev([F:XOPT])  Local File =SI_DOSSIER+".XILAAOPT" [XOPT] : Endif
#-----
Raz GNBEAA, GMODRGL, GMNTECH, GDATECH, GCODTVA
FLGERRACP=0
If [F:XEPA]GENAPT="O"
  #----- Il y a eu génération d'acompte, on les récupère s'il n'y a pas eu liaison comptable
  For [XEAA] Where NUMORD=[F:XEPA]NUMORD
&                & LETRLQNUMORD=[F:XEPA]LETRLQNUMORD
&                & FLGMAJ<>"C"
    If GNBEAA>=dim(GMODRGL)
      FLGERRACP=1 : Break
    Endif
    #----- Lecture de l'entête de l'acompte
    WCODTVA=func SIXFONCTION.SI_COR2("XITVAACH",num$([F:XEAA]CODTVA),[F:XFOU]CODPAY,"#","")
    GMODRGL(GNBEAA)=[F:XEAA]MODRGL1    : # Mode de règlement
    GMNTECH(GNBEAA)=[F:XEAA]MNTECH1    : # Montant de l'échéance
    GDATECH(GNBEAA)=[F:XEAA]DATECH1    : # Date de l'échéance
    GCODTVA(GNBEAA)=WCODTVA            : # Code tva
    GNBEAA +=1
    #----- Pour chaque acompte, lecture lignes règlement si règlement a plusieurs échéances
    For [XOPT] Where NUMORD=[F:XEAA]NUMORD
&                  & LETRLQ=[F:XEAA]LETRLQNUMORD
&                  & NUMAPT=[F:XEAA]NUMAPT
&                  & TYPLIG="O"
      If GNBEAA>=dim(GMODRGL)
        FLGERRACP=1 : Break 2
      Endif
      GMODRGL(GNBEAA)=[F:XOPT]MODRGL   : # Mode de règlement
      GMNTECH(GNBEAA)=[F:XOPT]MNTECH   : # Montant de l'échéance
      GDATECH(GNBEAA)=[F:XOPT]DATECH   : # Date de l'échéance
      GCODTVA(GNBEAA)=WCODTVA          : # Code tva
      GNBEAA +=1
    Next
    #-----
  Next
Elsif [F:XEPA]MNTAPT<>0
  #----- Il n'y a pas eu génération d'acompte, on génère une ligne si le mt acompte<>0
  GMNTECH(GNBEAA)=[F:XEPA]MNTAPT  : # Montant de l'échéance
  GDATECH(GNBEAA)=[F:XEPA]DAT1ECH : # Date de l'échéance   # Non renseignée !!
  If GDATECH(GNBEAA)="000000"
    GDATECH(GNBEAA)=[F:XEPA]DATPIE
  Endif
  GNBEAA +=1
Endif
Return


#------------------------# 
# Création des acomptes  #
#------------------------#
Subprog SIXACOMPTES (MODULE,TRAIT,NUMCDE,NBLIN,CODECHE,DEPECHE,MONTANT,MONTTTC,
&                    CURECH,TYPCOURS,TFACT,TPAYE,ADRPAY,NOLIN,OK)
Value    Integer MODULE
Value    Integer TRAIT
Value    Char    NUMCDE
Value    Integer NBLIN
Value    Char    CODECHE
Value    Date    DEPECHE
Value    Decimal MONTANT
Value    Decimal MONTTTC
Value    Char    CURECH
Value    Integer TYPCOURS
Value    Char    TFACT
Value    Char    TPAYE
Value    Char    ADRPAY
Value    Integer NOLIN
Variable Integer OK
#----- Historisation des échéances supprimées -----#
Local Char    CRITSUPPR(250)
Local Char    TABTAXE(3)(0..NBLIN)
Local Decimal TABMNT    (0..NBLIN)
Local Integer WRET, WDUDLIG, WLIG, STAT, WACCNUM
#----- Ouverture des fichiers si nécessaire -----#
If !clalev([F:TPT])  Local File =SI_DOSSIER+".TABPAYTERM" [TPT] : Endif
If !clalev([F:TCU])  Local File =SI_DOSSIER+".TABCUR"     [TCU] : Endif
If !clalev([F:DUD])  Local File =SI_DOSSIER+".GACCDUDATE" [DUD] : Endif
If !clalev([F:CAC])  Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif
If !clalev([F:GAC])  Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif
If !clalev([F:ADI])  Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif
#----- Uniquement création d'acomptes -----#
If TRAIT<>1  Return : Endif
#-----
Local Integer WI, WJ, J
Local Char    WPTE, WMODECHE
#-----
Call LECDEV(CURECH) From TRTDIV
NBECH=GNBEAA-1
#-----
Local Char     MODECHE(15)(0..NBECH)
Local Integer  TYPECHE    (0..NBECH)
Local Decimal  MNTECHE    (0..NBECH)
Local Date     DATECHE    (0..NBECH)
Local Integer  RELEVE     (0..NBECH)
Local Char     TABTAXE(GLONVAT)(0..max(NBECH,1))
Local Shortint NECHE : NECHE=0
#-----
For WI=0 To GNBEAA-1
  If GMODRGL(WI)<>""
    If len(GMODRGL(WI))>2
      CLERGL=left$(GMODRGL (WI),2)
      NUMORD=right$(GMODRGL(WI),3)
    Else 
      CLERGL=GMODRGL(WI)
      # NUMORD="" ==> à voir pour ajout initialisation NUMORD dans ce cas
    Endif 
    WPTE=func SIXFONCTION.SI_COR2("XIMODRGL",CLERGL,NUMORD,"","")
  Else
    # Aucun mode règlement sur ligne d'acompte, on prend la condition paiement entête commande
    WPTE=CODECHE
  Endif
  #----- Init mode de règlement avec celui de la 1ère ligne de type acompte
  Filter [TPT] Where PTE=WPTE & PAMTYP=2
  Read [TPT] TPT0 First
  If !fstat
    WMODECHE=[F:TPT]PAM
  Else
    #----- Aucune ligne de type acompte, init mode règlement celui de la 1ère ligne 
    Filter [TPT] Where PTE=CODECHE
    Read [TPT] TPT0 First
    If !fstat  WMODECHE=[F:TPT]PAM : Endif
  Endif 
  Filter [TPT]
  #-----
  MODECHE(NECHE) = WMODECHE
  TYPECHE(NECHE) = 2
  MNTECHE(NECHE) = GMNTECH(WI)
  DATECHE(NECHE) = GDATECH(WI)
  RELEVE (NECHE) = 1    : # Inutilisé à la création de l'acompte
  #-----
  If GCODTVA(WI)<>"" & !find(GCODTVA(WI), TABTAXE(0..NBECH-1))
    TABTAXE(WJ) = GCODTVA(WI)
    WJ+=1
  Endif
  NECHE+=1
Next
#-----
J=WJ
Gosub CREA_ACOMPTE From TRTTPT
End
