 If !clalev([F:SOQ]) Local File =SI_DOSSIER+".SORDERQ"    [SOQ] : Endif
Endif
If filinfo(filpath("FIL","SVCRFOOT",  "fde",SI_DOSSIER),0)>=0
 If !clalev([F:SVF]) Local File =SI_DOSSIER+".SVCRFOOT"   [SVF] : Endif
