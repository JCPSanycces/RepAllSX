#<AdxTL>@(#)8.0.0.0 $Revision$
#    ACTION MODELISATION                                                #
#                                                                       #
# GACTION  : TRTSCA : Pesée                                             #
#                                                                       #
#########################################################################
# Paramètres
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "DEBUT"          : Gosub DEBUT
    When "SETBOUT"        : Gosub SETBOUT
    When "AP_CHOIX"       : Gosub AP_CHOIX
    When "OK"             : Gosub OK
    When "FIN"            : Gosub FIN
    When Default
Endcase
Return


##########################################################################
$OUVRE
#If GBROWS # désactivation en Web
If !(GBROWS=0 | (GBROWS=1 & GFUSION=1)) : # GH 24/11/2014 dm 103835
   GMESSAGE = mess(85,150,1) : GERR = 2 : FIN = 1
Endif

Local Char     WFCY
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Local Integer  OK

Gosub CHARG_PARAM

# Ouverture des fichiers utilisés
If clalev([F:SBX])  = 0 : Local File STATIONBOX  [SBX]  : Endif
If clalev([F:STX])  = 0 : Local File STATION     [STX]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:ITM]) <= 0 : Local File ITMMASTER   [ITM]  : Endif    # 42003 mm 07.07
If clalev([F:ITF]) <= 0 : Local File ITMFACILIT  [ITF]  : Endif

Return


##########################################################################
$DEBUT
Local Integer  I_SBX
Local Char     WCURBOX
Local Char     WCURSTI
Local Char     WCURFCY

Raz [M:SCA1]
[M:SCA1]MFGFCY = GFCY

# On filtre les box qui correspondent au poste de travail
Filter [SBX] Where DESKCNX=adxmac(-2)
I_SBX=0
For [SBX]
  I_SBX+=1
  WCURBOX = [SBX]BOX
  WCURSTI = [SBX]STI
  WCURFCY = [SBX]FCY
# A partie du moment où on en a deux pas la peine de continuer : pas de chargement du box par défaut
  If (I_SBX>1)
    Break
  Endif
Next
If I_SBX = 1
 [M:SCA1]MFGFCY = WCURFCY
 [M:SCA1]BOX = WCURBOX
 [M:SCA1]STI = WCURSTI
 Grizo [M:SCA1]MFGFCY
 Affzo [M:SCA1]MFGFCY
 Grizo [M:SCA1]BOX
 Affzo [M:SCA1]BOX
 Affzo [M:SCA1]STI
 #affichage des libellés
 Affzo [M:SCA1]ZMFGFCY
 # Lecture STATION
 Call LECTEXTRA ([M:SCA1]STXDES,"STATION","STXDESAXX",[M:SCA1]STI,"") From ATEXTRA
 # Lecture STATIONBOX
 Call LECTEXTRA ([M:SCA1]DES,"STATIONBOX","DESAXX",[M:SCA1]BOX,[M:SCA1]MFGFCY) From ATEXTRA

 Affzo [M:SCA1]STXDES
 Affzo [M:SCA1]DES
Endif
If I_SBX <= 1
  Filter [SBX]
Endif
Return


#########################################################################
$SETBOUT
ETABOU(GVALI) = 1 : # OK
ETABOU(GABAN) = 1 : # Fin
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub OK
    Raz REPONSE
Endif
Return

#########################################################################
$OK

Global Char       GSCA1MFGFCY (GLONFCY)
Global Char       GSCA1STI    (8)
Global Char       GSCA1BOX    (8)
Global Char       GSCA1DES    (30)
Global Char       GSCA1STXDES (30)
Global Date       GSCA1DATESTR
Global Date       GSCA1DATEEND
Global Char       GSCA1FORMULE (GLONFOR)
Global Char       GSCA1NUMSTR (GLONVCR)   # 57505 mm 08.09
Global Char       GSCA1NUMEND (GLONVCR)   # 57505 mm 08.09
Global Char       GSCA1ITMREF(GLONITM)    # 42003 mm 07.07
Global Decimal    GSTOCOU                 # 55296 mm 05.09
Global Integer    GSEQSTA                 # 55296 mm 05.09

GSCA1MFGFCY  = [M:SCA1]MFGFCY
GSCA1STI     = [M:SCA1]STI
GSCA1BOX     = [M:SCA1]BOX
GSCA1DES     = [M:SCA1]DES
GSCA1STXDES  = [M:SCA1]STXDES
GSCA1DATESTR = [M:SCA1]DEBDATESTR
GSCA1DATEEND = [M:SCA1]DEBDATEEND
GSCA1NUMSTR  = [M:SCA1]MFGNUMSTR
GSCA1NUMEND  = [M:SCA1]MFGNUMEND
GSCA1ITMREF  = [M:SCA1]CPNITMREF

GSCA1FORMULE = [M:SCA1]FORMULE

# mm 09.08
Call GETSOC(GSCA1MFGFCY) From DEVSUB

Boxclr [SCA1]
Call SCALEENGINE From SCALELIB
FIN=0 : # GH pour revenir toujours à l'écran de saisie
Return

#########################################################################
$FIN
Return

################################################################
# Chargement variables globales
$CHARG_PARAM
# Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO

# Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
# sr 05.02 si longueur de comparaison = 0, on compare sur la totalité de la zone LOT
If GLENLOT = 0 : GLENLOT = GLONLOT : Endif

Return

#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY
GFCY=VALEUR                     # mm 12.02
Gosub CHARG_PARAM
WFCY = VALEUR
End

########################################
Subprog C_BOX(VALEUR)
Variable Char    VALEUR()

# contrôle existence
If [F:SBX]FCY <> [M:SCA1]MFGFCY | [F:SBX]BOX <> VALEUR
    Read [SBX]SBX0=VALEUR;[M:SCA1]MFGFCY
    If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Endif
Endif

# Si le box est lié à un PC, on contrôle le PC courant si non erreur
If len([SBX]DESKCNX)>0
  If [SBX]DESKCNX <> adxmac(-2)
      # Le Box saisie est lié à un poste de travail, le lancement depuis se poste n'est pas autorisé
      GMESSAGE = mess(57,2324,1)
      mkstat = 1
  Endif
Endif
End

########################################
Subprog AM_BOX(VALEUR)
Variable Char    VALEUR()

[M:SCA1]STI       = [F:SBX]STI

# 03.09 mm - libellé traduisible
# Lecture STATION
Call LECTEXTRA ([M:SCA1]STXDES,"STATION","STXDESAXX",[M:SCA1]STI,"") From ATEXTRA
# Lecture STATIONBOX
Call LECTEXTRA ([M:SCA1]DES,"STATIONBOX","DESAXX",VALEUR,[M:SCA1]MFGFCY) From ATEXTRA

Affzo [M:SCA1]STI
Affzo [M:SCA1]DES
Affzo [M:SCA1]STXDES
End

########################################
Subprog AM_DEBDATESTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M:SCA1]DEBDATEEND = VALEUR : Affzo [M:SCA1]DEBDATEEND : Endif
End

########################################
Subprog C_DEBDATEEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:SCA1]DEBDATESTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:SCA1]MFGNUMEND = VALEUR : Affzo [M:SCA1]MFGNUMEND : Endif
End

########################################
Subprog C_MFGNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:SCA1]MFGNUMSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran SCA1) 30/07/2007 14:48:26 (MM)
######################################################################################
Subprog C_CPNITMREF(VALEUR)
Variable Char    VALEUR()
# 107513
#Local Char     WFCY
#
## 42003 mm 07.07
#If [F:ITM]ITMREF <> VALEUR
#    Read [ITM]ITM0=VALEUR
#Endif
#
## lecture article site
#If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>[M:SCA1]MFGFCY
#   Read [ITF] ITF0=VALEUR;[M:SCA1]MFGFCY
#   If fstat : GMESSAGE = mess(260,199,1) : End : Endif
#Endif
#
#WFCY = [F:ITF]STOFCY
#Call CONTMATITM(WFCY, 1) From MFGLIB
If VALEUR=""
    End
Endif
Call CONTMATITM(VALEUR, [M:SCA1]MFGFCY, "MKM", GERR, GMESSAGE) From MFGLIB
If find(GERR,1,4)
    GERR = 1
    mkstat=2
    End
Endif

End


######################################################################################
#-----------------------------------------------#
# mm 02.11 - magasin avancé
# Vérification saisie paramètre PRIALL & ALLAUT
#-----------------------------------------------#
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM
Variable Char VALEUR
Variable Integer OK

Local Integer I
If clalev([M:ADWP]) <= 0 : Local Mask ADWP  [ADWP]  : Endif

# priorité  aux allocations OF + allocations auto : en cas d'allocations partielles,
# pas d'allocations auto générées. Il faudra allouer la totalité de la matière manuellement
Case PARAM
 When "PRIALL"
  If VALEUR = "1"
    For I=0 To NBVAR-1
      If [M:ADWP]PARAM(I)= "ALLAUT" & [M:ADWP]VALEUR(I)= mess(2,1,1)
       Infbox mess(286,193,1)-mess(287,193,1)-mess(288,193,1)
       Break
      Endif
    Next I
  Endif
 When "ALLAUT"
    If VALEUR = "2"
     For I=0 To NBVAR-1
      If [M:ADWP]PARAM(I)= "PRIALL" & [M:ADWP]VALEUR(I)= mess(1,2397,1)
       Infbox  mess(286,193,1)-mess(287,193,1)-mess(288,193,1)
       Break
      Endif
     Next I
    Endif
Endcase

End

