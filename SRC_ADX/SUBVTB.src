#<AdxTL>@(#)0.0.0.0 $Revision$ Cases TVA
Raz GPILOBJ , GNBMASKOUV
Call OBJET("VTB",GBIDC1,GBIDC2) From GOBJET
End

####################################################################################################
# Tables
#   VATBOX  [VTB]   (Key : VATFNC+LEG+LIN)
#   VATBOXD [VTD]   (Key : VATFNC+LEG+LIN+FLGVAT+VATIPT)
###########################################################################################################
# Masks      Windows   Function    Programs    Object/action
# -----      --------   -------   --------     --------
# VATBOX0   |
# VATBOX1   |  OVTB     GESVTB      SUBVTB      VTB ( Objet simply)
# VATBOX2   |
###########################################################################################################
# Issue X3-63066 - 2018-04-23 by FHA : Activity code of this process in the dictionary (GASADC) is set from VATBX to DCL

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "CREATION"    : Gosub CREATION
 When "APRES_CRE"   : Gosub APRES_CRE
 When "INIMOD"      : Gosub INIMOD
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AV_ANNULE"   : Gosub AV_ANNULE
 When "ANNULE"      : Gosub ANNULE
 When "RAZDUP"      : Gosub RAZDUP
 When "FERME"       : Gosub FERME
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When Default
Endcase
Return

$OUVRE

If clalev([F:VTB])  = 0  : Local File VATBOX     [VTB]   : Endif
If clalev([F:VTB1]) = 0  : Local File VATBOX     [VTB1]  : Endif
If clalev([F:VTD])  = 0  : Local File VATBOXD    [VTD]   : Endif
If clalev([F:TVT])  = 0  : Local File TABVAT     [TVT]   : Endif
If clalev([F:GTE])  = 0  : Local File GTYPACCENT [GTE]   : Endif
If clalev([F:CPY])  = 0  : Local File COMPANY    [CPY]   : Endif
If clalev([F:DLVB]) = 0  : Local File DCLVATBOXH [DLVB]   : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Global Integer GMAXLINTXT # Manage the translatable titles while inserting a line(s)
Return

$AFFMASK
Call FMTLEG From TRTX3
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0
 Diszo [M:VTB0]LEG
 [M:VTB0]LEG=GDOSLEG(1)
 Affzo [M:VTB0]LEG
Endif
Return

$SETBOUT
If !find('A',CHAINE) Then CHAINE += 'A' : Endif
If CLECUR = 0 Then
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

$LIENS
# Simply object => Supervisor manage VATFNC+LEG+ LIN=0

If dim([M:VTB0]LEG)>0 : Affzo [M:VTB0]LEG : Endif
GCURLEG = [F:VTB]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M:VTB0]DESVATFNC,"VATBOX","DESVATFNC",[M:VTB0]VATFNC,GCURLEG) From ATEXTRA


## First TAB
nolign = 0
For [VTB1]VTB0 Where VATFNC=[F:VTB]VATFNC & LEG=[F:VTB]LEG & LIN>0
 If nolign >= dim ([M:VTB1]VATBOX) Break : Endif
 nolign += 1
 [M:VTB1] = [F:VTB1]
 [M:VTB1]VLYSTRHEA(nolign-1) = [F:VTB1]VLYSTR
 [M:VTB1]VLYENDHEA(nolign-1) = [F:VTB1]VLYEND

 Call LECTEXTRA([M:VTB1]DESTRA([F:VTB1]LIN-1),"VATBOX","DESTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$([F:VTB1]LIN)) From ATEXTRA
 Call LECTEXTRA([M:VTB1]SHOTRA([F:VTB1]LIN-1),"VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$([F:VTB1]LIN)) From ATEXTRA
 [M:VTB1]LIGTXT([F:VTB1]LIN-1) = [F:VTB1]LIN
Next
[M:VTB1]NBRVTB1 = nolign

Affzo [M:VTB1]
For I=1 To [M:VTB1]NBRVTB1
 If  [M:VTB1]TYPBOX(I-1) <> 3
  Raz [M:VTB1]CNDFOR(I-1)
  Diszo [M:VTB1]CNDFOR(I-1)
 Else
  Actzo [M:VTB1]CNDFOR(I-1)
 Endif
Next

# Second TAB
nolign = 0
For [VTD]VTD0 Where VATFNC=[F:VTB]VATFNC & LEG=[F:VTB]LEG
 If nolign >= dim ([M:VTB2]VATBOX2) Break : Endif
 nolign += 1
 [M:VTB2] = [F:VTD]

 [M:VTB2]VATBOX2(nolign-1)  = [F:VTD]VATBOX
 Call LECTEXTRA([M:VTB2]DES(nolign-1),"VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$([F:VTD]LIN)) From ATEXTRA
 [M:VTB2]LINVATBOX(nolign-1) = func LINVATBOX1([M:VTB2]VATBOX2(nolign-1))

 Call LEC_TVT_LEG(GCURLEG,[F:VTD]VAT) From CPTLEC
 [M:VTB2]VAC(nolign-1)  = [F:TVT]VATVAC
Next
[M:VTB2]NBRVTB2 = nolign

Local Char    STYLE1(10) : STYLE1 = "BACKYELLOW"
Local Char    STYLE2(10) : STYLE2 = "BACKGREY"
Local Char    WSTYLE(10)
Local Integer I

Affzo [M:VTB2]
If [M:VTB2]VATBOX2(0) <>""
WSTYLE = STYLE1
 Chgstl [M:VTB2]NBRVTB2(0) With WSTYLE
For I=2 To [M:VTB2]NBRVTB2
 If [M:VTB2]VATBOX2(I-1)<>[M:VTB2]VATBOX2(I-2)
  If WSTYLE = STYLE1
   WSTYLE = STYLE2
  Else
   WSTYLE = STYLE1
  Endif
  Chgstl [M:VTB2]NBRVTB2(I-1) With WSTYLE
 Else
  Chgstl [M:VTB2]NBRVTB2(I-1) With WSTYLE
 Endif
Next
Endif

GMAXLINTXT = max([M:VTB1]NBRVTB1)
Return


$FILGAUCHE
If CRITERE<>"" : CRITERE +="&" : Endif
CRITERE +="LIN=0"
Return

$FILTRE
If FILTSUP<>"" : FILTSUP +="&" : Endif
FILTSUP +="LIN=0"
Return


####################################################################################################
$RAZCRE
Gosub GRILEG
Return

$INICRE
$INIMOD
If func AFNC.ACTIV("LEG")=0 : [F:VTB]LEG = GDOSLEG(1) : Endif
[F:VTB]LIN  = 0  # First record

Raz [F:VTB]VATBOX  # If not empty, X3 display "Record already exists" (see keys on VATBOX Table)
Raz [F:VTB]CLCFOR  # To inhibit the Transclass of Supervisor
Raz [F:VTB]TYPBOX  # To inhibit the Transclass of Supervisor
# Not Raz [F:VTB] because we have to save the value of CRExxx field.

Return

$VERIF_CRE
$VERIF_MOD
# Sort without VATBOX !
Sorta [M:VTB2]NBRVTB2 [M:VTB2]NBRVTB2 Order By [M:VTB2]VATBOX2(indice),[M:VTB2]FLGVAT(indice),[M:VTB2]VATIPT(indice),
& [M:VTB2]VAT(indice),[M:VTB2]VCRTYP(indice),[M:VTB2]VLYSTR(indice),[M:VTB2]VLYEND(indice)

For I=1 To [M:VTB2]NBRVTB2-1
 If [M:VTB2]VATBOX2(I-1)=[M:VTB2]VATBOX2(I) &
&   [M:VTB2]FLGVAT(I-1)=[M:VTB2]FLGVAT(I) &
&   [M:VTB2]VATIPT(I-1)=[M:VTB2]VATIPT(I) &
&   [M:VTB2]VAT(I-1)=[M:VTB2]VAT(I) &
&   [M:VTB2]VCRTYP(I-1)=[M:VTB2]VCRTYP(I) &
&   [M:VTB2]VLYSTR(I-1)=[M:VTB2]VLYSTR(I) &
&   [M:VTB2]VLYEND(I-1)=[M:VTB2]VLYEND(I)

  GMESSAGE = mess(364,107,1)-[M:VTB2]VATBOX2(I-1)-mess(61,100,1)-num$([M:VTB2]LIN2(I-1)+1)-":"-mess(365,107,1)-
&            mess(364,107,1)-[M:VTB2]VATBOX2(I)-mess(61,100,1)-num$([M:VTB2]LIN2(I)+1)
  # Sort for displaying message with the true  line number
  Sorta [M:VTB2]NBRVTB2 [M:VTB2]NBRVTB2 Order By [M:VTB2]LIN2(indice)
  Affzo [M:VTB2]

  GERR = 1 : OK = 0 : Break
 Endif
Next
If !OK : Return : Endif
Return

$CREATION
# First Tab = VATBOX table
For NOL=0 To [M:VTB1]NBRVTB1-1
 nolign=NOL+1
 [F:VTB]    = [M:VTB1]
 [F:VTB]LIN = nolign

 [F:VTB]VLYSTR = [M:VTB1]VLYSTRHEA(NOL)
 [F:VTB]VLYEND = [M:VTB1]VLYENDHEA(NOL)
 Write [VTB]
 If fstat
  GOK = 0 : Call FSTA("VTB") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif

Gosub TEXTRA
If GOK<1 : Return : Endif

# Second Tab = VATBOXD Table
Sorta [M:VTB2]NBRVTB2 [M:VTB2]NBRVTB2 Order By [M:VTB2]LINVATBOX(indice),[M:VTB2]FLGVAT(indice),[M:VTB2]VATIPT(indice),
& [M:VTB2]VAT(indice),[M:VTB2]VCRTYP(indice),[M:VTB2]VLYSTR(indice),[M:VTB2]VLYEND(indice)

For NOL=0 To [M:VTB2]NBRVTB2-1
 nolign=NOL+1
 Raz [F:VTD]
 [F:VTD] = [M:VTB0]
 [F:VTD] = [M:VTB2]

 [F:VTD]LIN    = find([M:VTB2]VATBOX2(NOL),[M:VTB1]VATBOX)
 [F:VTD]VATBOX = [M:VTB2]VATBOX2(NOL)

 Write [VTD]
 If fstat
  GOK = 0 : Call FSTA("VTD") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return

$APRES_CRE
$APRES_MOD
CLECUR1    = GCURLEG
CLECUR2(0) = [M]VATFNC
CLECUR2(1) = "0"
Gosub RELIT From GOBJET
zoncou     = ""
Gosub RAFFRAICHIR From GOBJSUB
Return

$MODIF
Delete [VTB1] Where [F:VTB1]VATFNC=[F:VTB]VATFNC & [F:VTB1]LEG=[F:VTB]LEG & [F:VTB1]LIN>0
If fstat=1
 GOK = -1 : Call RSTA("VTB",[F:VTB]VATFNC-[F:VTB]LEG) From GLOCK : Return
Endif
If GOK<1 : Return : Endif
Delete [VTD] Where VATFNC=[F:VTB]VATFNC & LEG=[F:VTB]LEG
If fstat=1
 GOK = -1 : Call RSTA("VTD",[F:VTB]VATFNC-[F:VTB]LEG) From GLOCK : Return
Endif
Gosub CREATION
If GOK<1 : Return : Endif
Return

$TEXTRA
# 3 translates texts :
#  DESVATFNC  (key :  VATFNC + LEG)
#  DESTRA     (Key :  VATFNC + LEG~LIN)
#  SHOTRA     (key :  VATFNC + LEG~LIN)

If GREP="D"
  Call DUPTEXTRA("VATBOX","DESVATFNC",CLECUR2,CLECUR1,"VATBOX","DESVATFNC",[F:VTB]VATFNC,[F:VTB]LEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M:VTB0]DESVATFNC,"VATBOX","DESVATFNC",[F:VTB]VATFNC,[F:VTB]LEG) From ATEXTRA

If GREP="M"
 For I=0 To [M:VTB1]NBRVTB1-1
  If [M:VTB1]LIGTXT(I) <> 0
   Call DUPTEXTRA("VATBOX","DESTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$([M:VTB1]LIGTXT(I)),"VATBOX","DESTRA",[M:VTB0]VATFNC,chr$(255)+GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
   Call DUPTEXTRA("VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$([M:VTB1]LIGTXT(I)),"VATBOX","SHOTRA",[M:VTB0]VATFNC,chr$(255)+GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
  Endif
 Next I
 If GOK<1 : Return : Endif

 Delete [AXX] Where CODFIC = "VATBOX" & ZONE = "DESTRA" & IDENT1 = [M:VTB0]VATFNC & left$(IDENT2,len(GCURLEG)) = GCURLEG
 If fstat=1
  GOK=-1 : Call RSTA("AXX","VATBOX"-[M:VTB0]VATFNC-GCURLEG) From GLOCK : Return
 Endif
 Delete [AXX] Where CODFIC = "VATBOX" & ZONE = "SHOTRA" & IDENT1 = [M:VTB0]VATFNC & left$(IDENT2,len(GCURLEG)) = GCURLEG
 If fstat=1
  GOK=-1 : Call RSTA("AXX","VATBOX"-[M:VTB0]VATFNC-GCURLEG) From GLOCK : Return
 Endif
 Update [AXX] Where CODFIC = "VATBOX" & ZONE = "DESTRA" & IDENT1 = [M:VTB0]VATFNC & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","VATBOX"-[M:VTB0]VATFNC-GCURLEG) From GLOCK : Return
 Endif
 Update [AXX] Where CODFIC = "VATBOX" & ZONE = "SHOTRA" & IDENT1 = [M:VTB0]VATFNC & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","VATBOX"-[M:VTB0]VATFNC-GCURLEG) From GLOCK : Return
 Endif
 For I=0 To [M:VTB1]NBRVTB1-1
  Call MAJTEXTRA([M:VTB1]DESTRA(I),"VATBOX","DESTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
  If GOK<1 : Break : Endif
  Call MAJTEXTRA([M:VTB1]SHOTRA(I),"VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
  If GOK<1 : Break : Endif
  [M:VTB1]LIGTXT(I) = I+1
 Next
 If GOK<1 : Return : Endif

Else # GREP

 If GREP="D"
  For I=0 To [M:VTB1]NBRVTB1-1
   Call DUPTEXTRA("VATBOX","DESTRA",CLECUR2,CLECUR1+"~"+num$([M:VTB1]LIGTXT(I)),"VATBOX","DESTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
   Call DUPTEXTRA("VATBOX","SHOTRA",CLECUR2,CLECUR1+"~"+num$([M:VTB1]LIGTXT(I)),"VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
  Next
  If GOK<1 : Return : Endif
 Endif
 If GREP="C" | GREP="D"
  For I=0 To [M:VTB1]NBRVTB1-1
   Call MAJTEXTRA([M:VTB1]DESTRA(I),"VATBOX","DESTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
   Call MAJTEXTRA([M:VTB1]SHOTRA(I),"VATBOX","SHOTRA",[M:VTB0]VATFNC,GCURLEG+"~"+num$(I+1)) From ATEXTRA
   If GOK<1 : Break : Endif
  Next
  If GOK<1 : Return : Endif
 Endif
Endif  #GREP
Return

$AV_ANNULE
Local Integer I, LREP
Local Char LACTION(1), LVATBOX(5)
For I=1 To [M:VTB1]NBRVTB1
 LACTION="A" : # Delete all
 LVATBOX=[M:VTB1]VATBOX(I-1)
 Gosub CTL_DELBOX
 If mkstat : GERR=1 : GOK = 0 : Endif
Next I
Return

$ANNULE
Delete [VTB1] Where [F:VTB1]VATFNC=[F:VTB]VATFNC & [F:VTB1]LEG=[F:VTB]LEG & [F:VTB1]LIN>0
If fstat=1
 GOK = -1 : Call RSTA("VTB",[F:VTB]VATFNC-[F:VTB]LEG) From GLOCK : Return
Endif
Delete [VTD] Where [F:VTD]VATFNC=[F:VTB]VATFNC & LEG=[F:VTB]LEG
If fstat=1
 GOK = -1 : Call RSTA("VTD",[F:VTD]VATFNC-[F:VTD]LEG) From GLOCK : Return
Endif

Call SUPTEXTRA("VATBOX","DESVATFNC",[F:VTB]VATFNC,[F:VTB]LEG) From ATEXTRA
If GOK<1 : Return : Endif
For I=0 To [M:VTB1]NBRVTB1-1
 Call SUPTEXTRA("VATBOX","DESTRA",[F:VTB]VATFNC,[F:VTB]LEG+"~"+num$(I+1)) From ATEXTRA
 If GOK<1 : Break : Endif
 Call SUPTEXTRA("VATBOX","SHOTRA",[F:VTB]VATFNC,[F:VTB]LEG+"~"+num$(I+1)) From ATEXTRA
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif
Return

$RAZDUP
Effzo [M:VTB2]
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(GMAXLINTXT) : Kill GMAXLINTXT : Endif
Return

###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File VATBOX   [VTB1]
 Local File VATBOXD  [VTD1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".VATBOX"      [VTB1]
 Local File =[M]DOSORG+".VATBOXD"     [VTD1]
 Local File =[M]DOSORG+".ATEXTRA"     [AXX1]
Endif
If [M]DOSDES=nomap
 Local File VATBOX   [VTB2]
 Local File VATBOXD  [VTD2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".VATBOX"   [VTB2]
 Local File =[M]DOSDES+".VATBOXD"  [VTD2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA

If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE2-":"-mess(249,133,1) ) From GESECRAN
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [VTB1], [VTB2], [VTD1], [VTD2], [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [VTB2]
 Delete [VTB2] Where VATFNC=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".VATBOX" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("VTB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [VTD2] Where VATFNC=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".VATBOX" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("VTB2","") From GLOCK : Goto AB_TR_COP
 Endif

 For [VTB1] Where VATFNC=TABLE & LEG=TABLE2
  [F:VTB2] = [F:VTB1]
  Call COPTEXTRA("VATBOX","DESVATFNC",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("VATBOX","DESTRA",TABLE,TABLE2+"~"+num$([F:VTB1]LIN)) From ATEXTRA
  Call COPTEXTRA("VATBOX","SHOTRA",TABLE,TABLE2+"~"+num$([F:VTB1]LIN)) From ATEXTRA
  Call FLDUPD("VTB2") From OBJDIV
  Write [VTB2]
  If fstat
   GOK = 0 : Call FSTA("VTB2") From GLOCK : Break
  Endif
 Next
 For [VTD1] Where VATFNC=TABLE & LEG=TABLE2
  [F:VTD2] = [F:VTD1]
  Call FLDUPD("VTD2") From OBJDIV
  Write [VTD2]
  If fstat
   GOK = 0 : Call FSTA("VTD2") From GLOCK : Break
  Endif
 Next

 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return


######################################################################################
$SEL_LISTE
Case LISTE
 When "SELAFCVAT" : Gosub SELAFCVAT
 When "SELVATBOX" : Gosub SELVATBOX
 When Default
Endcase
Return

$SELAFCVAT
Local Char    TEXTE(80)(1..dim(TEX),1..2)

TIT(0) = mess(10, 16,1)-mess(20,110,1)
TIT(1) = mess(20,110,1)
TIT(2) = mess(38,100,1)

If clalev([F:WAFC])=0  : Local File AFONCTION   [WAFC]  : Endif

NBTEX = 0
For [WAFC] Where ACTION="DCLVATSTD"
 If NBTEX>=dim(TEXTE) : Break : Endif
 NBTEX += 1
 TEX(NBTEX)     = [F:WAFC]CODINT
 TEXTE(NBTEX,1) = [F:WAFC]CODINT
 Call TEXTE([F:WAFC]NOM,TEXTE(NBTEX,2)) From OBJDIV
Next

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 GERR=2 : mkstat=2  : Return
Endif
Return

$SELVATBOX
Local Char    TEXTE(80)(1..dim(TEX),1..3)
Local Char    DESTXTTRA(80)

TIT(0) = mess(10, 16,1)
TIT(1) = mess(38,100,1)
TIT(2) = mess(30,109,1)
TIT(3) = mess(59,100,1)


NBTEX = 0
For I=0 To [M:VTB1]NBRVTB1
 If [M:VTB1]TYPBOX(I)=2 | [M:VTB1]TYPBOX(I)=4
  If NBTEX>=dim(TEXTE) : Break : Endif
  NBTEX += 1
  TEX(NBTEX)     = [M:VTB1]VATBOX(I)
  TEXTE(NBTEX,1) = [M:VTB1]VATBOX(I)
  TEXTE(NBTEX,2) = [M:VTB1]DESTRA(I)
  TEXTE(NBTEX,3) = mess([M:VTB1]TYPBOX(I),3651,1)
 Endif
Next

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 GERR=2 : mkstat=2  : Return
Endif
Return


######################################################################################
## Labels of VATBOX0 screen
######################################################################################

Subprog C_VATFNC(VALEUR)
Variable Char    VALEUR()
If clalev([F:WAFC])=0  : Local File AFONCTION   [WAFC]  : Endif
fstat=0
If [F:WAFC]CODINT<>VALEUR
 Read [F:WAFC]CODINT = VALEUR
Endif
If fstat | [F:WAFC]ACTION<>"DCLVATSTD"
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End


######################################################################################
## Labels of VATBOX1 screen
######################################################################################
Subprog C_NBRVTB1
Local Integer I, J
Local Integer LREP
Local Char LACTION(1)
Local Char LVATBOX(5)

Case status
 When 65,68,83 : # Cancellation line
  Gosub SETNOL
  If status=65
   LACTION="D" : # Deletion
   LVATBOX=[M:VTB1]VATBOX(NOL)
   Gosub CTL_DELBOX
   If mkstat : End : Endif
   For J=0 To [M:VTB2]NBRVTB2-1
    If [M:VTB1]VATBOX(NOL)=[M:VTB2]VATBOX2(J)
     GMESSAGE = mess(364,107,1)-[M:VTB1]VATBOX(NOL)-":"-mess(368,107,1)
     mkstat = 2 : Break
    Endif
   Next J
   If mkstat : End : Endif
  Else
   For I=nolign To nolign1
    LACTION="D" : # Deletion
    LVATBOX=[M:VTB1]VATBOX(I-1)
    Gosub CTL_DELBOX
    If mkstat : Break : Endif
    For J=0 To [M:VTB2]NBRVTB2-1
     If [M:VTB1]VATBOX(I-1)=[M:VTB2]VATBOX2(J)
      GMESSAGE = mess(364,107,1)-[M:VTB1]VATBOX(I-1)-":"-mess(368,107,1)
      mkstat = 2 : Break 2
     Endif
    Next J
   Next I
   If mkstat : End : Endif
  Endif
Endcase
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$CTL_DELBOX
   Filter [DLVB] Where GRPCPY = "" and CPY <> "" and VATBOX=LVATBOX and VATFNC = [M:VTB0]VATFNC and SIM = 1
   For [DLVB]DLVB0(2)
    Call LEC_CPY([F:DLVB]CPY) From CPTLEC
    If [F:CPY]LEG = [M:VTB0]LEG
     If LACTION = "A"
      GMESSAGE = func AFNC.MES2(mess(405,107,1),[F:DLVB]VATFNC, [M:VTB0]LEG)-"\"
     Elsif (LACTION = "D" or LACTION = "U")
      GMESSAGE = func AFNC.MES3(mess(402,107,1),[F:DLVB]VATFNC, [M:VTB0]LEG, [F:DLVB]VATBOX)-"\"
     Endif
     GMESSAGE -= func AFNC.MES1(mess(403,107,1),[F:DLVB]CPY)-"\"
     If LACTION="D"
      GMESSAGE -= mess(1,115,1)
     Elsif LACTION="U"
      GMESSAGE -= mess(9,123,1)
     Endif
     mkstat = 2 : Break
    Endif
   Next
   Filter [DLVB]
   If mkstat : Return : Endif

   Filter [DLVB] Where GRPCPY <> "" and CPY = "" and VATBOX=LVATBOX and VATFNC = [M:VTB0]VATFNC and SIM = 1
   Read [DLVB]DLVB0 First
   Filter [DLVB]
   If !fstat
    Call OUINON(func AFNC.MES3(mess(402,107,1),[F:DLVB]VATFNC, [M:VTB0]LEG, [F:DLVB]VATBOX)-"\"-
&               func AFNC.MES1(mess(404,107,1),[F:DLVB]GRPCPY)-"\"-
&               mess(287,107,1),LREP) From GESECRAN
    If LREP=1
     mkstat = 2 : Return
    Endif
   Endif
Return


Subprog AS_VATBOX(VALEUR)
Variable Char    VALEUR()

If [M]LIGTXT(nolign-1)=0
 GMAXLINTXT +=1
 [M]LIGTXT(nolign-1) = GMAXLINTXT
Endif

Local Integer LINVATBOX
[L]LINVATBOX=-1
For I=0 To [M:VTB2]NBRVTB2-1
 If [M:VTB2]VATBOX2(I)=VALEUR
  [L]LINVATBOX=I : Break
 Endif
Next I
If [L]LINVATBOX<>-1 : mkstat=2 : End : Endif
End


Subprog AM_VATBOX(VALEUR)
Variable Char    VALEUR()

Local Integer LREP
Local Char LVATBOX(5)
If [M]TYPBOX <4
  LACTION="U" : # Update
  LVATBOX=[M:VTB1]VATBOX(nolign-1)
  Gosub CTL_DELBOX
  If mkstat : End : Endif
Endif
End

Subprog AS_TYPBOX(VALEUR)
Variable Integer VALEUR
If VALEUR<>2 & VALEUR<>4 : End : Endif
Local Integer LINVATBOX
[L]LINVATBOX=-1
For I=0 To [M:VTB2]NBRVTB2-1
 If [M:VTB2]VATBOX2(I)=[M:VTB1]VATBOX(nolign-1)
  [L]LINVATBOX=I : Break
 Endif
Next I
If [L]LINVATBOX<>-1 : mkstat=2 : End : Endif
End

Subprog AM_TYPBOX(VALEUR)
Variable Integer VALEUR
If VALEUR=3
 [M:VTB1]CNDFOR(nolign-1) = 1
 Actzo [M:VTB1]CNDFOR(nolign-1)
Else
 Raz[M:VTB1]CNDFOR(nolign-1)
 Diszo [M:VTB1]CNDFOR(nolign-1)
Endif
End

Subprog AS_VLYSTRHEA(VALEUR)
Variable Date    VALEUR
If [M:VTB1]TYPBOX(nolign-1)<>1 and [M:VTB1]TYPBOX(nolign-1)<>3
 mkstat = 1 : End
Endif
End

Subprog AS_VLYENDHEA(VALEUR)
Variable Date    VALEUR
If [M:VTB1]TYPBOX(nolign-1)<>1 and [M:VTB1]TYPBOX(nolign-1)<>3
 mkstat = 1 : End
Endif
End

Subprog C_VLYENDHEA(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<=[M:VTB1]VLYSTRHEA(nolign-1)
 GMESSAGE = mess(1,104,1)
 mkstat = 2 : End
Endif
End

######################################################################################
Subprog AS_CLCFOR(VALEUR)
Variable Char    VALEUR()
If [M:VTB1]TYPBOX(nolign-1)<>3 : mkstat=1 : Endif
End

Subprog C_CLCFOR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
LIGNE = VALEUR
While LIGNE<>""
 K = instr(1,LIGNE," ")
 If K
  ZONE = left$(LIGNE,K-1) : LIGNE = vireblc(right$(LIGNE,K+1),2)
 Else
  ZONE = LIGNE : LIGNE = ""
 Endif
 If left$(ZONE,1)="-" : ZONE=right$(ZONE,2) : Endif

 FORMU = 0
 For I=0 To nolign-2
  If [M:VTB1]VATBOX(I)=ZONE & ([M:VTB1]TYPBOX(I)=2 | [M:VTB1]TYPBOX(I)=3)
    FORMU=1 : Break
  Endif
 Next I
 If !FORMU :  Break : Endif
Wend
If !FORMU
 GMESSAGE = mess(83,123,1)-ZONE : mkstat = 2 : End
Endif
End

Subprog AS_CNDFOR(VALEUR)
Variable Integer VALEUR
If [M:VTB1]TYPBOX(nolign-1)<>3 : mkstat=1 : Endif
End

######################################################################################
## Labels of VATBOX2 screen
######################################################################################
Subprog C_NBRVTB2
# Sort as keys of VATBOXD (LIN field is linked to VATBOX)
# Sort different on VERIF_xxx label.
If adxgtb<>0
 Sorta [M:VTB2]NBRVTB2 [M:VTB2]NBRVTB2 Order By [M:VTB2]LINVATBOX(indice),[M:VTB2]FLGVAT(indice),[M:VTB2]VATIPT(indice),
& [M:VTB2]VAT(indice),[M:VTB2]VCRTYP(indice),[M:VTB2]SNS(indice),[M:VTB2]VLYSTR(indice),[M:VTB2]VLYEND(indice)

 # LIN2 field use  on VERIF_xxx label.
 For I=0 To [M:VTB2]NBRVTB2-1
  [M:VTB2]LIN2(I) = I
 Next
 Affzo [M:VTB2]

Endif
End

Subprog C_VATBOX2(VALEUR)
Variable Char    VALEUR()
Local Integer LINVATBOX
[L]LINVATBOX=-1
For I=0 To [M:VTB1]NBRVTB1-1
 If [M:VTB1]VATBOX(I)=VALEUR
  [L]LINVATBOX=I : Break
 Endif
Next I
If [L]LINVATBOX=-1 | ([M:VTB1]TYPBOX([L]LINVATBOX)<>2 & [M:VTB1]TYPBOX([L]LINVATBOX)<>4)
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
If VALEUR<>[M:VTB2]VATBOX2(nolign-1)
 [M:VTB2]DES(nolign-1)=[M:VTB1]SHOTRA([L]LINVATBOX)
Endif
[M:VTB2]LINVATBOX(nolign-1) = [L]LINVATBOX
End

Subprog AS_FLGVAT(VALEUR)
Variable Integer VALEUR
Gosub AS_ZONE
GMENLOC(1)=1
End

Subprog C_FLGVAT(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog AS_VATIPT(VALEUR)
Variable Integer VALEUR
Gosub AS_ZONE
End

Subprog C_VAT(VALEUR)
Variable Char    VALEUR()
Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
LIN = func LINVATBOX1([M:VTB2]VATBOX2(nolign-1))
If [M:VTB0]VATFNC="DCLVATBEL"
If [M:VTB1]TYPBOX(LIN)<>4 & [F:TVT]VATTYP<>1
 GMESSAGE=mess(11,119,1)
 mkstat=2 : End
Endif
If [M:VTB1]TYPBOX(LIN)=2  & [F:TVT]VATPAY<>1
  #"The tax code must be of the debit type"
  GMESSAGE=mess(398,107,1)
 mkstat=2 : End
Endif
Endif
If VALEUR<>[M:VTB2]VAT(nolign-1)
 [M:VTB2]VAC(nolign-1)=[F:TVT]VATVAC
Endif
End

Subprog AS_VCRTYP(VALEUR)
Variable Char    VALEUR()
Gosub AS_ZONE
End

Subprog C_VCRTYP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call LEC_TVT_LEG(GCURLEG,[M:VTB2]VAT(nolign-1)) From CPTLEC
If [F:TVT]VATPAY = 1
Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
If [F:GTE]VAT<>2
  # "The entry type must be checked to 'VAT on debit'"
  GMESSAGE=mess(399,107,1)
 mkstat=2 : End
Endif
Endif
End

Subprog AS_SNS(VALEUR)
Variable Decimal VALEUR
Gosub AS_ZONE
If mkstat : End : Endif
If VALEUR=0 : VALEUR=1 : Endif
End

Subprog C_SNS(VALEUR)
Variable Decimal VALEUR
If VALEUR<>1 & VALEUR<>-1
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog AS_VLYSTR(VALEUR)
Variable Date    VALEUR
Gosub AS_ZONE
End

Subprog AS_VLYEND(VALEUR)
Variable Date    VALEUR
Gosub AS_ZONE
End

Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<=[M:VTB2]VLYSTR(nolign-1)
 GMESSAGE = mess(1,104,1)
 mkstat = 2 : End
Endif
End

$AS_ZONE
Local Integer LIN
mkstat=0
LIN = [M:VTB2]LINVATBOX(nolign-1)
If [L]LIN<0 | [M:VTB1]TYPBOX([L]LIN)=4
 mkstat=1 : Return
Endif
Return

Funprog LINVATBOX1(VATBOX)
Value Char VATBOX
Local Integer LINVATBOX
[L]LINVATBOX=-1
For I=0 To [M:VTB1]NBRVTB1-1
 If [M:VTB1]VATBOX(I)=[L]VATBOX
  [L]LINVATBOX=I : Break
 Endif
Next I
End [L]LINVATBOX

