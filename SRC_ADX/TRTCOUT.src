#  If VALEUR>[M]CSTTOTIDV(nolign-1) Then
#    GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
#    mkstat=2 : End
#  Endif
#  # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
#  If VALEUR<0 Then
#    GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
#    mkstat=2 : End
#  Endif
#Endif
#If [M]CSTTOTIDV(nolign-1)<0 Then
#  If VALEUR<=0 Then
#    If abs(VALEUR)>abs([M]CSTTOTIDV(nolign-1)) Then
#      #Coût imputable supérieur au coût total
#      GMESSAGE=mess(7,10717,1)
#      mkstat=2 : End
#    Endif
#  Else
#    GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
#    mkstat=2 : End
#  Endif
#Endif
## Fin MABON
#If [M]TYPCRG(nolign-1)="HEB"
# Local Decimal VALMG
# Call RECUP_MG("", "", "",DATREF,VALMG)
# If VALEUR>arr(5*VALMG*[M]NBRDAY,0.01)
#   # FQ97638 - 21/03/14 - Mettre un message plus complet
##  GMESSAGE=mess(51,10717,1) :#Coût imputable supérieur au minimum garanti
#  #Incohérence de données : / - Coût imputable supérieur au minimum garanti / - Le nombre de jours n'est pas renseigné
#  GMESSAGE=mess(305,10717,1)-":"+chr$(10)+"- "+mess(51,10717,1)+chr$(10)+"- "+mess(306,10717,1)
#  # Fin FQ97638
#  mkstat=2 : End
# Endif
#Endif
#End

Subprog C_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR

# SEGAY X3PEOP-112635 230117
If dim([M]TCRCOD)<>-1 and dim([M]LNKREP)<>-1 and [M]TCRCOD<>"" and [M]LNKREP(nolign-1)=""
   [M]CSTIPTIDV(nolign-1)=VALEUR
   Gosub ADD_REP_COST From TRTCOUT
Endif

Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTTOTIDV

# FQ71546 - MABON 14/02/11 - Le coût total peut être négatif
If VALCUMULIDV>0 Then
  If VALEUR>VALCUMULIDV Then
    GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
    Gosub ERROR_RETORE_CSTIPTIDV
    mkstat=2 : End
  Endif
  # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
  If VALEUR<0 Then
    GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
    Gosub ERROR_RETORE_CSTIPTIDV
    mkstat=2 : End
  Endif
Endif
If VALCUMULIDV<0 Then
  If VALEUR<=0 Then
    If abs(VALEUR)>abs(VALCUMULIDV) Then
      #Coût imputable supérieur au coût total
      GMESSAGE=mess(7,10717,1)
      Gosub ERROR_RETORE_CSTIPTIDV
      mkstat=2 : End
    Endif
  Else
    GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
    Gosub ERROR_RETORE_CSTIPTIDV
    mkstat=2 : End
  Endif
Endif
# Fin MABON
If [M]TYPCRG(nolign-1)="HEB"
 Local Decimal VALMG
 Call RECUP_MG("", "", "",W_DATREF,VALMG) From TRTCOUT
 If VALEUR>arr(5*VALMG*W_NBRDAY,0.01)
   # FQ97638 - 21/03/14 - Mettre un message plus complet
#  GMESSAGE=mess(51,717,1) :#Coût imputable supérieur au minimum garanti
  #Incohérence de données : / - Coût imputable supérieur au minimum garanti / - Le nombre de jours n'est pas renseigné
  GMESSAGE=mess(305,10717,1)-":"+chr$(10)+"- "+mess(51,10717,1)+chr$(10)+"- "+mess(306,10717,1)
  Gosub ERROR_RETORE_CSTIPTIDV
  # Fin FQ97638
  mkstat=2 : End
 Endif
Endif
If IS_DISTRIB
  If func FORCE_AM(VALEUR)
    Call AM_CSTIPTIDV(VALEUR)
    Gosub SET_VALCTL
  Endif
Endif

End
#LIPET - 2017-06-22 - X3-34431 - END

#LIPET - 2017-06-22 - X3-34431 - START
$ERROR_RETORE_CSTIPTIDV
If IS_DISTRIB
  VALEUR=VALEUR-[M]CSTIPTIDV(LIN+1)
Endif
Return
#LIPET - 2017-06-22 - X3-34431 - END
##############################
#Calcul de la synthèse des coûts
Subprog CSTMOY (VALEUR)
Value Integer VALEUR
Local Integer I
Raz[M]CSTMOYTOT
Raz[M]CSTMOYIPT
# 97021 Nbr ligne -1
For I=0 To VALEUR-1
 [M]CSTMOYTOT+=[M]CSTTOTIDV(I)
 [M]CSTMOYIPT+=[M]CSTIPTIDV(I)
Next
Affzo[M]CSTMOYTOT,CSTMOYIPT

If dim([M]CSTMOYTOT2)>=0
 Raz[M]CSTMOYTOT2
 Raz[M]CSTMOYIPT2
 # FQ70982 - MABON 24/01/11 - Gestion des arrondis
# 97021 Nbr ligne -1
 For I=0 To VALEUR-1
  [M]CSTMOYTOT2+=[M]CSTTOTCLL(I)
  If [M]CSTTOTCLL(I)=0 Then
    [M]CSTMOYTOT2+=arr([M]CSTTOTIDV(I)*[M]NBRPRTSTD,0.01)
  Endif
  [M]CSTMOYIPT2+=[M]CSTIPTCLL(I)
  If [M]CSTIPTCLL(I)=0 Then
    [M]CSTMOYIPT2+=arr([M]CSTIPTIDV(I)*[M]NBRPRTSTD,0.01)
  Endif
 Next
# [M]CSTMOYTOT2=arr([M]CSTMOYTOT*[M]NBRPRTSTD,0.01)
# [M]CSTMOYIPT2=arr([M]CSTMOYIPT*[M]NBRPRTSTD,0.01)
 # Fin MABON
 Affzo[M]CSTMOYTOT2,CSTMOYIPT2
Endif
End

##############################
#Récup du minimum garanti dans les valeurs de variables de paie
Subprog RECUP_MG(SOCIETE, SITE, MATRI,DATMAT,VALEUR)
Value Char SOCIETE()
Value Char SITE()
Value Char MATRI()
Value Date DATMAT ()
Variable Decimal VALEUR

VALEUR=0
If DATMAT=[0/0/0] : DATMAT=date$ : Endif

If GPAYE Then
  If clalev([F:VLA])=0  : Local File VALEUR     [VLA] : Endif
  If clalev([F:VFD])=0  : Local File VALFDR     [VFD] : Endif
  If clalev([F:VCP])=0  : Local File VALCPY     [VCP] : Endif
  If clalev([F:VFC])=0  : Local File VALFCY     [VFC] : Endif
  If clalev([F:VEP])=0  : Local File VALEMP     [VEP] : Endif
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif

  Local Char CODMG (GLONVRA), CTR(GLONHRCTR)

  VALEUR=0
  If DATMAT=[0/0/0] : DATMAT=date$ : Endif

  Call PARAM(GCURLEG,"CODMG",CODMG) From ADOVAL
  If CODMG="" :  End : Endif

  ## Valeurs salarié
  If MATRI<>""
   Filter [VEP] Where EMP=MATRI & PYRDAT<=DATMAT
   Read [VEP]VEP0 Last
   Filter [VEP]
   If !fstat
    Read[VLA]VLA0=4;"";"";"";[F:VEP]EMP;[F:VEP]PYRDAT;CODMG
    If !fstat : VALEUR=[VLA]VARVAL : Endif
   Endif
   If VALEUR<>0 : End : Endif
   # Recup du site en fonction du matricule...
   Gosub OUVRE From WPDEFTABLE
   CTR = [F:VEP]CTRNUM
   Gosub LECEMP From WPDEFTABLE
   SITE =[F:HRCTR]ETRFCY
  Endif

   ## Valeurs site
  If SITE<>""
   Filter [VFC] Where FCY=SITE & DAT<=DATMAT
   Read [VFC]VFC0 Last
   Filter [VFC]
   If !fstat
    Read[VLA]VLA0=3;"";"";[F:VFC]FCY;"";[F:VFC]DAT;CODMG
    If !fstat : VALEUR=[VLA]VARVAL : Endif
   Endif
   If VALEUR<>0 : End : Endif
   # Recup du société en fonction du site...
   Call LECTURE("FCY",SITE,"") From CONTOBJ
   SOCIETE =[F:FCY]LEGCPY
  Endif

  If SOCIETE<>""
   ## Valeurs société
   Filter [VCP] Where CPY=SOCIETE & DAT<=DATMAT
   Read [VCP]VCP0 Last
   Filter [VCP]
   If !fstat
    Read[VLA]VLA0=2;"";[F:VCP]CPY;"";"";[F:VCP]DAT;CODMG
    If !fstat : VALEUR=[VLA]VARVAL : Endif
   Endif
   If VALEUR<>0 : End : Endif
  Endif

  ## Valeurs dossier
  Filter [VFD] Where DAT<=DATMAT
  Read [VFD]VFD0 Last
  Filter [VFD]
  If !fstat
   Read[VLA]VLA0=1;[F:VFD]LEG;"";"";"";[F:VFD]DAT;CODMG
   If !fstat : VALEUR=[VLA]VARVAL : Endif
  Endif
Endif
End
#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
####################################
# X3PEOP-3477
Subprog C_ORGFIN(VALEUR)
Variable Char    VALEUR()

# On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN
# X3PEOP-3477
# Idem SUBSTG

Gosub DECLARE_PROCESS_LINE
Local Integer I, OK
OK = 1
For I=0 To nolign-2
 If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
  OK = 0 : Break
 Endif
Next
If OK=1
 For I=nolign To VAL_NBLIG-1
  If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
   OK = 0 : Break
  Endif
 Next
Endif
If OK=0
 # Ligne de coût déjà existante en ligne xx
 GMESSAGE = mess(84,10717,1)-num$(I+1)
 mkstat = 2 : End
Endif

# SBA X3PEOP-3476
If [M]TCRCOD<>"" and (VALEUR<>[M]ORGFIN(nolign-1) or [M]FLGCHG(nolign-1)=1 )# test to see if ok or adpat
  Read [F:HRTCR]HRTCR1=[M]TCRCOD;[M]TYPCRG(nolign-1);[M]TYPFIN(nolign-1);VALEUR
  If !fstat
    For I=0 To VAL_NBLIG-1
      If !(I= nolign-1 or [M]LNKREP(nolign-1)+"D"=[M]LNKREP(I))
        If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=[F:HRTCR]ORGFIN2
          OK = 0 : Break
        Endif
      Endif
    Next
   Endif
Endif

If !OK
  GMESSAGE = [F:HRTCR]ORGFIN2-":"- mess(84,10717,1)-num$(I+1)
  mkstat = 2 : End
Elsif (VALEUR=[M]ORGFIN(nolign-1) and [M]FLGCHG(nolign-1)=1)
  # forced creation
  Call AM_ORGFIN(VALEUR)
  [M]FLGCHG(nolign-1)=0
Endif
End
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
#$TCR_ORGFIN
# X3PEOP-3477
# TODO Idem SUBSTG
# = Subprog AM_ORGFIN(VALEUR)
Subprog AM_ORGFIN(VALEUR)
Variable Char    VALEUR()
Local Char W_ACT(1)
Gosub DECLARE_PROCESS_LINE
If [M]LNKREP(LIN)<>""
  LINREF=LIN+1
  Gosub DELETE_LINEREP
   W_ACT="D"
   [M]LNKREP(LIN)=""
Endif

If [M]TCRCOD<>""
  Read [F:HRTCR]HRTCR1=[M]TCRCOD;[M]TYPCRG(LIN);[M]TYPFIN(LIN);VALEUR
  If!fstat
    W_ACT="C"
    LINREF=LIN+1
    Gosub CREATE_LINEREP
    Raz  [M]CSTIPTIDV(LIN),[M]CSTIPTCLL(LIN),[M]CSTTOTCLL(LIN),[M]CSTTOTIDV(LIN)
  Endif
Endif

[M]WLNKTYPACT=W_ACT
[M]ORGFIN(LIN)=VALEUR
# local car sur le masque
Gosub STYLE
Gosub AFFZO_BLOCCOUT From =W_NOMPRG
End
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# X3PEOP-3477
Subprog AM_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR

Gosub IS_DISTRIB

If IS_DISTRIB & ![M]WVALCTL
  Gosub CALC_DISTRIB
  [M]CSTIPTIDV(LIN+1)=VAL2
  Affzo [M]CSTIPTIDV(LIN+1)
  VALEUR=VAL1
Endif
End
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
