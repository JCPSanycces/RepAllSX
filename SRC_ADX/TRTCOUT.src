VAL_NBLIG=evalue(WMANBAS)

Return
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
$GET_NOLIGN
Local Integer LIN
LIN=nolign-1
Return
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
$GRISE_LINE
W_ACTLINE="GRIZO"
Gosub CHANGE_STYLE_LINE
Return
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
$PROCESS_LINE
For WNAME="TYPCRG","TYPFIN","ORGFIN","CSTTOTCLL","CSTTOTIDV","CSTIPTCLL","CSTIPTIDV","LNKREP"
  Case W_ACTLINE
    When "GRIZO"    : Diszo="[M]"+WNAME+'('+num$(LINREF)+')'
    When "ACTZO"    : Actzo="[M]"+WNAME+'('+num$(LINREF)+')'
    When "SAVE"     : Assign "[M]W"+WNAME With evalue("[M]"+WNAME+"("+num$(LINREF)+")")
    When "REST"     : Assign "[M]"+WNAME+"("+num$(LINREF)+")" With evalue("[M]W"+WNAME)
  Endcase
Next
Return
#LIPET - 2017-06-22 - X3-34429 - END
####################################
#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
$CHANGE_STYLE_LINE
 W_STYLE=""
If W_ACTLINE="GRIZO" : W_STYLE="PLAGE" : Endif
Gosub PROCESS_LINE

Chgstl =W_CIBLE With W_STYLE
Return
