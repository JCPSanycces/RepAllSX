#LIPET - 2017-06-22 - X3-34431 - START
Subprog AM_TCRCOD(VALEUR)
Variable Char    VALEUR()
#Only if code exist and change
If [M]TCRCOD<>""
  Local Integer OK
  Call OUINON(mess(318,10717,1),OK) From GESECRAN  :# "Les lignes liées à la répartition seront supprimées. Souhaitez-vous continuer?"
  If OK=2
    Gosub DECLARE_PROCESS_LINE
    For LINREF=VAL_NBLIG-1 To 0 Step -1
      If dim([M]LNKREP)<>-1 and [M]LNKREP(LINREF)<>""
        Gosub DELETE_LINEREP
      Endif
    Next
   Gosub AFFZO_BLOCCOUT From =W_NOMPRG
  Else
      VALEUR=[M]TCRCOD
  Endif
Endif
End
#LIPET - 2017-06-22 - X3-34431 - END

#LIPET - 2017-06-22 - X3-34431 - START
$SET_VALINI
If dim([M]WVALINI)<>-1
  [M]WVALINI=VALEUR
  [M]WVALCTL=0
Endif
Return
#LIPET - 2017-06-22 - X3-34431 - END

#LIPET - 2017-06-22 - X3-34431 - START
# SBA X3PEOP-3476
Subprog C_CSTTOTCLL(VALEUR)
Variable Decimal VALEUR

# SEGAY X3PEOP-112635 230117
If dim([M]TCRCOD)<>-1 and dim([M]LNKREP)<>-1 and [M]TCRCOD<>"" and [M]LNKREP(nolign-1)=""
   [M]CSTTOTCLL(nolign-1)=VALEUR
   Gosub ADD_REP_COST From TRTCOUT
Endif

Gosub IS_DISTRIB
If IS_DISTRIB
  If func FORCE_AM(VALEUR)
    Call AM_CSTTOTCLL(VALEUR)
    Gosub SET_VALCTL
  Endif
Endif
End
#LIPET - 2017-06-22 - X3-34431 - END

#LIPET - 2017-06-22 - X3-34431 - START
# SBA X3PEOP-3476
Subprog C_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR

# SEGAY X3PEOP-112635 230117
If dim([M]TCRCOD)<>-1 and dim([M]LNKREP)<>-1 and [M]TCRCOD<>"" and [M]LNKREP(nolign-1)=""
   [M]CSTTOTIDV(nolign-1)=VALEUR
   Gosub ADD_REP_COST From TRTCOUT
Endif

Gosub IS_DISTRIB
If IS_DISTRIB
  If func FORCE_AM(VALEUR)
    Call AM_CSTTOTIDV(VALEUR)
    Gosub SET_VALCTL
  Endif
Endif
End
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
# SBA X3PEOP-3476
Subprog AM_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR

Gosub IS_DISTRIB

If IS_DISTRIB & ![M]WVALCTL
  Gosub CALC_DISTRIB
  [M]CSTTOTIDV(LIN+1)=VAL2
  Affzo [M]CSTTOTIDV(LIN+1)
  VALEUR=VAL1
Endif
End
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
# SBA X3PEOP-3476
$SET_VALCTL
  [M]WVALCTL=1
Return
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
Subprog C_NBLIG()
Gosub DECLARE_PROCESS_LINE
If status=73 and right$([M]LNKREP(LIN),len([M]LNKREP(LIN)))="D"
  GMESSAGE=mess(321,10717,1)
  mkstat=2
Endif
If status=71
  Gosub STYLE         : # mandotory to rigth display
  Gosub AFFZO_BLOCCOUT From =W_NOMPRG
Endif

End
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
Subprog DELETE_MANUAL()
  Gosub DECLARE_PROCESS_LINE
  LINREF=LIN
  If([M]LNKREP(LIN))<>""
    If right$([M]LNKREP(LIN),len([M]LNKREP(LIN)))="D"
    # delete manual
    LINREF=LIN-1
    Endif
    Gosub DELETE_LINE
  Endif
  Gosub DELETE_LINE
  Gosub STYLE         : # mandotory to rigth display
  Gosub AFFZO_BLOCCOUT From =W_NOMPRG

End
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
$GET_RECORD_REP
If dim(IS_REP)<0 : Local Integer IS_REP : Endif
Raz [L]IS_REP
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
Read [F:HRTCR]HRTCR1(2)=[L]W_TCRCOD;[L]W_TYPCRG
If !fstat
  [L]IS_REP=1
Else
  Raz [F:HRTCR]
Endif

Return
#LIPET - 2017-06-22- X3-34431 - END

#LIPET - 2017-06-22- X3-34431 - START
# SEGAY X3PEOP-112635 230117
$ADD_REP_COST
Local Char W_ACT(1)
Gosub DECLARE_PROCESS_LINE From TRTCOUT
If [M]LNKREP(LIN)=""
  If [M]TCRCOD<>""
    Read [F:HRTCR]HRTCR1=[M]TCRCOD;[M]TYPCRG(LIN);[M]TYPFIN(LIN);[M]ORGFIN(LIN)
    If!fstat
      W_ACT="C"
      LINREF=LIN+1
      Gosub CREATE_LINEREP From TRTCOUT
      Raz  [M]CSTIPTIDV(LIN),[M]CSTIPTCLL(LIN),[M]CSTTOTCLL(LIN),[M]CSTTOTIDV(LIN)
    Endif
  Endif

  [M]WLNKTYPACT=W_ACT
#  [M]ORGFIN(LIN)=[M]ORGFIN(LIN)
  # local car sur le masque
  Gosub STYLE From TRTCOUT
  Gosub AFFZO_BLOCCOUT From =W_NOMPRG
 Endif
Return
#LIPET - 2017-06-22- X3-34431 - END

