#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################################################
#Recherche du taux horaire du formateur interne
#Si j'ai la paie, je prend la valeur de la rubrique
#Sinon, je prend le taux défini dans la catégorie 2483
#############################################################################################################
Subprog TAUX_HORAIRE (MATRI,CONTRAT,DATMAT,TAUX,TYPTX,TYPCOUT,COLONNE)
Value    Char    MATRI ()
Value    Date    DATMAT
Value    Char    CONTRAT
Variable Decimal TAUX
Value    Decimal TYPTX      :#1=Sal & 2=Pat
Value    Integer TYPCOUT    :#1=Prév  & 2=Réel
Value    Integer COLONNE    :#1=Total & 2= Imputable

If clalev([F:ADI3])=0 : Local File ATABDIV    [ADI3] : Endif

TAUX=0

If GPAYE & TYPCOUT=2
 Gosub TXPAYE
Else
 Gosub TXCAT
Endif
End

#Recherche du taux horaire dans l'historique de paye
###################################
$TXPAYE
If clalev([F:HSP])=0 : Local File HISTOPAYE    [HSP] : Endif
Local Char CODRUB (GLONRUB)
If TYPTX=2
 If COLONNE= 1
  Call PARAM(GCURLEG,"TXHRPAT2",CODRUB)From ADOVAL
 Else
  Call PARAM(GCURLEG,"TXHRPAT",CODRUB)From ADOVAL
 Endif
Else
 If COLONNE= 1
  Call PARAM(GCURLEG,"TXHRSAL2",CODRUB)From ADOVAL
 Else
  Call PARAM(GCURLEG,"TXHRSAL",CODRUB)From ADOVAL
 Endif
Endif
If CODRUB<>""
 If DATMAT=[0/0/0] : DATMAT=date$ : Endif
 # 50833
 #Filter [F:HSP] Where EMP=MATRI & DAT<=DATMAT & RUB=CODRUB & (TYP=TYPTX | TYP=TYPTX+6)
 Filter [F:HSP] Where EMP=MATRI & CTRNUM=CONTRAT & DAT<=DATMAT & RUB=CODRUB
 Read[F:HSP]HSP1 Last
 Filter [F:HSP]
 If !fstat :  TAUX=[F:HSP]AMT :  Endif
 #LIPET - 2017-06-22 - X3-34431 - START
 #104656-
 # Si pas de bulletin avant la fin de sesion - cas d'une arrivée dans le mois.
 # chercher 1er bulletin après fin de session
 If fstat
  Filter [F:HSP] Where EMP=MATRI & CTRNUM=CONTRAT & DAT>DATMAT & RUB=CODRUB
  Read[F:HSP]HSP1 First
  Filter [F:HSP]
  If !fstat :  TAUX=[F:HSP]AMT :  Endif
 Endif
 #LIPET - 2017-06-22 - X3-34431 - END
#46232
Else
 Gosub TXCAT
Endif
Return

#Recherche du taux horaire dans la catégorie 2483
###################################
$TXCAT
Local Char CATFRT(3)
Call CAT2483(MATRI,CONTRAT,CATFRT)From SUBDEM
If CATFRT<>""
 Read[F:ADI3]CODE=10453;CATFRT
 If !fstat
  If TYPTX=2 :#patronal
   If COLONNE= 1
    TAUX=val([F:ADI3]A2)
   Else
    TAUX=[F:ADI3]N2
   Endif
  Else     :#salarial
   If COLONNE= 1
    TAUX=val([F:ADI3]A1)
   Else
    TAUX=[F:ADI3]N1
   Endif
  Endif
 Endif
Endif
Return

#############################################################################################################
#############################################################################################################

##############################
#Type de frais
#On interdit la saisie des coûts de type "Participant"
Subprog C_TYPCRG(VALEUR)
Variable Char    VALEUR()
Local Integer K
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;VALEUR
If !fstat & [F:ADI]N1<3 & [F:ADI]N2=1
 If GFONCTION="GESHRSES" :  K=34 : Else :  K=33 : Endif
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(K,10717,1) :#Type de coût non autorisé au niveau stage / session
 mkstat=2 : End
Endif
End
##############################
#Cout total collectif
#Si c'est un coût calculable, pas de saisie collective
#Si un coût total individuel a été saisi, on ne saisit pas le coût total collectif
Subprog AS_CSTTOTCLL(VALEUR)
Variable Decimal VALEUR
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
If !fstat & [F:ADI]N1<3
 mkstat=2 : End
Endif

#LIPET - 2017-06-22 - X3-34431 - START
Gosub SET_VALINI
Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTTOTCLL
Gosub GET_CUMUL_CSTTOTIDV

#If VALEUR=0 & [M]CSTTOTIDV(nolign-1)<>0 : mkstat=2 : End : Endif
If VALCUMULCLL=0 & VALCUMULIDV<>0 : mkstat=2 : End : Endif

VALEUR=VALCUMULCLL
#LIPET - 2017-06-22 - X3-34431 - END
End

##############################
#Cout total collectif
#Calcul du coût total individuel en fonction du coût total collectif saisi
Subprog AM_CSTTOTCLL(VALEUR)
Variable Decimal VALEUR
#LIPET - 2017-05-10 - X3-34431 - START
Gosub IS_DISTRIB

If IS_DISTRIB & ![M]WVALCTL
  IS_COL=1
  Gosub CALC_DISTRIB
  If !(VAL1=VAL2 and VAL1=0)
    # on update l'indi
    [M]CSTTOTIDV(LIN)=VAL1
    [M]CSTTOTIDV(LIN+1)=VAL2
    Affzo [M]CSTTOTIDV(LIN+1)
    Affzo [M]CSTTOTIDV(LIN)
  Endif
  [M]CSTTOTCLL(LIN+1)=(VAL2*NB_COL)
  Affzo [M]CSTTOTCLL(LIN+1)
  VALEUR=(VAL1*NB_COL)
  # on update A
#LIPET - 2017-05-10 - X3-34431 - END
Else
  If VALEUR<>0
    [M]CSTTOTIDV(nolign-1)=arr((VALEUR/[M]NBRPRTSTD),0.01)
    Affzo [M]CSTTOTIDV(nolign-1)
  Endif
Endif
End
##############################
#Cout total individuel
#Si un coût total collectif a été saisi, on ne saisit pas le coût total individuel
#Si un formateur interne a été saisi, on valorise ses charges salariales et patronales
#en fonction de sa catégorie 2483
#LIPET - 2017-06-22 - X3-34431 - START
#Subprog AS_CSTTOTIDV(VALEUR, FORMATEUR, CONTRAT,DATREF)
#Variable Decimal VALEUR
#Value Char FORMATEUR ()
#Value Char CONTRAT
#Value Date DATREF
#If [M]CSTTOTCLL(nolign-1)<>0 : mkstat=2 : End : Endif
#If FORMATEUR<>"" & VALEUR=0
# Local Decimal TAUX
# If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
# Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
# If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2     :#cout calculable pour formateur interne
#  Call TAUX_HORAIRE (FORMATEUR,CONTRAT,DATREF,TAUX,[F:ADI]N1,2,1) From TRTCOUT
#  If !TAUX
#   #Taux horaire total non défini
#   Call ERREUR (FORMATEUR-":"-mess(78,10717,1))From GESECRAN
#  Else
#   VALEUR=arr(TAUX*[M]NBRHOUIPT,0.01) :# Nb d'heures imputables
#  Endif
# Endif
#Endif
#End

Subprog AS_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR

Gosub SET_VALINI
Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTTOTCLL
If VALCUMULCLL<>0 : mkstat=2 : End : Endif

Gosub GET_CUMUL_CSTTOTIDV

If W_FORMATEUR<>"" & VALCUMULIDV=0
 Local Decimal TAUX
 If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
 Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
 If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2     :#cout calculable pour formateur interne
  Call TAUX_HORAIRE (W_FORMATEUR,W_CONTRAT,W_DATREF,TAUX,[F:ADI]N1,2,1) From TRTCOUT
  If !TAUX
   #Taux horaire total non défini
   Call ERREUR (W_FORMATEUR-":"-mess(78,10717,1))From GESECRAN
  Else
   VALEUR=arr(TAUX*W_NBRHOUR,0.01) :# Nb d'heures imputables
  Endif
 Endif
Else
  VALEUR=VALCUMULIDV
Endif
End
#LIPET - 2017-06-22 - X3-34431 - END

##############################
#LIPET - 2017-06-22 - X3-34431 - START
#Cout imputable collectif
#Si c'est un coût calculable, pas de saisie collective
#Si un coût imputable individuel a été saisi, on ne saisit pas le coût imputable collectif
#Subprog AS_CSTIPTCLL(VALEUR)
#Variable Decimal VALEUR
#If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
#Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
#If !fstat & [F:ADI]N1<3
# mkstat=2 : End
#Endif
#If VALEUR=0  & [M]CSTIPTIDV(nolign-1)<>0 : mkstat=2 : End : Endif
## MABON 25/08/10 - Initialisation de CSTIPTCLL avec CSTTOTCLL si celui-ci est renseigné
#If VALEUR=0  & [M]CSTTOTCLL(nolign-1)<>0 : VALEUR=[M]CSTTOTCLL(nolign-1) : Endif
#End

Subprog AS_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
If !fstat & [F:ADI]N1<3
 mkstat=2 : End
Endif
Gosub SET_VALINI
Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTIPTCLL
Gosub GET_CUMUL_CSTIPTIDV
If VALCUMULCLL=0 & VALCUMULIDV<>0 : mkstat=2 : End : Endif
If VALCUMULCLL=0
  Gosub GET_CUMUL_CSTTOTCLL
Endif
VALEUR=VALCUMULCLL
End
#LIPET - 2017-06-22 - X3-34431 - END
##############################
#Cout imputable collectif
#On contrôle que le coût imputable collectif n'est pas > que le coût total collectif
#LIPET - 2017-06-22 - X3-34431 - START
#Subprog C_CSTIPTCLL(VALEUR)
#Variable Decimal VALEUR
## FQ71546 - MABON 14/02/11 - Le coût total peut être négatif
#If [M]CSTTOTCLL(nolign-1)>0 Then
#  If VALEUR>[M]CSTTOTCLL(nolign-1) Then
#    GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
#    mkstat=2 : End
#  Endif
#  # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
#  If VALEUR<0 Then
#    GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
#    mkstat=2 : End
#  Endif
#Endif
#If [M]CSTTOTCLL(nolign-1)<0 Then
#  If VALEUR<=0 Then
#    If abs(VALEUR)>abs([M]CSTTOTCLL(nolign-1)) Then
#      GMESSAGE=mess(7,10717,1) : #Coût imputable supérieur au coût total
#      mkstat=2 : End
#    Endif
#  Else
#    GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
#    mkstat=2 : End
#  Endif
#Endif
## Fin MABON
#End

Subprog C_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR

# SEGAY X3PEOP-112635 230117
If dim([M]TCRCOD)<>-1 and dim([M]LNKREP)<>-1 and [M]TCRCOD<>"" and [M]LNKREP(nolign-1)=""
   [M]CSTIPTCLL(nolign-1)=VALEUR
   Gosub ADD_REP_COST From TRTCOUT
Endif

Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTTOTCLL

If VALCUMULCLL>0 Then
  If VALEUR>VALCUMULCLL Then
    GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
    Gosub ERROR_RETORE_CSTIPTCLL
    mkstat=2 : End
  Endif
  # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
  If VALEUR<0 Then
    GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
    Gosub ERROR_RETORE_CSTIPTCLL
    mkstat=2 : End
  Endif
Endif
If VALCUMULCLL<0 Then
  If VALEUR<=0 Then
    If abs(VALEUR)>abs(VALCUMULCLL) Then
      GMESSAGE=mess(7,10717,1) : #Coût imputable supérieur au coût total
      Gosub ERROR_RETORE_CSTIPTCLL
      mkstat=2 : End
    Endif
  Else
    GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
    Gosub ERROR_RETORE_CSTIPTCLL
    mkstat=2 : End
  Endif
Endif
# Force recalculation
If IS_DISTRIB
  If func FORCE_AM(VALEUR)
    Call AM_CSTIPTCLL(VALEUR)
    Gosub SET_VALCTL
  Endif
Endif

End

#LIPET - 2017-06-22 - X3-34431 - END

#LIPET - 2017-06-22 - X3-34431 - START
$ERROR_RETORE_CSTIPTCLL
If IS_DISTRIB
  VALEUR=VALEUR-[M]CSTIPTCLL(LIN+1)
Endif
Return
#LIPET - 2017-06-22 - X3-34431 - END

##############################
#Cout imputable collectif
#Calcul du coût imputable individuel en fonction du coût individuel collectif saisi
Subprog AM_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR

Gosub IS_DISTRIB

If IS_DISTRIB & ![M]WVALCTL
  IS_COL=1
  Gosub CALC_DISTRIB
  If !(VAL1=VAL2 and VAL1=0)
    # on update l'indi
    [M]CSTIPTIDV (LIN)=VAL1
    [M]CSTIPTIDV (LIN+1)=VAL2
    Affzo [M]CSTIPTIDV (LIN+1)
    Affzo [M]CSTIPTIDV (LIN)
  Endif
  [M]CSTIPTCLL(LIN+1)=(VAL2*NB_COL)
  Affzo [M]CSTIPTCLL(LIN+1)
  VALEUR=(VAL1*NB_COL)
  # on update A
Else
  If VALEUR<>0
    [M]CSTIPTIDV(nolign-1)=arr((VALEUR/[M]NBRPRTSTD),0.01)
    Affzo [M]CSTTOTIDV(nolign-1)
  Endif
Endif
End

##############################
#Cout imputable total
#Si un coût imputable collectif a été saisi, on ne saisit pas le coût imputable individuel
#Si un formateur interne a été saisi, on valorise ses charges salariales et patronales
#en fonction de l'historique de paye ou de sa catégorie 2483
#Si un coût d'hebergement a été saisi, on valorise son coût en fonction du Minimum garanti
#Frais d'hebergement imputable individuel = 5*MG*Nb jours
#LIPET - 2017-06-22 - X3-34431 - START
#Subprog AS_CSTIPTIDV(VALEUR, FORMATEUR,CONTRAT, DATREF)
#Variable Decimal VALEUR
#Value Char FORMATEUR ()
#Value Char CONTRAT
#Value Date DATREF
#If [M]CSTIPTCLL(nolign-1)<>0 : mkstat=2 : End : Endif
#If FORMATEUR<>"" & VALEUR=0
# Local Decimal TAUX
# If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
# Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
# If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2
#  Call TAUX_HORAIRE (FORMATEUR,CONTRAT,DATREF,TAUX,[F:ADI]N1,2,2) From TRTCOUT
#  If !TAUX
#   #Taux horaire imputable non défini
#   Call ERREUR (FORMATEUR-":"-mess(79,10717,1))From GESECRAN
#  Else
#   VALEUR=arr(TAUX*[M]NBRHOUIPT,0.01)
#  Endif
# Endif
#Endif
#If [M]TYPCRG(nolign-1)="HEB" & VALEUR=0
# Local Decimal VALMG
# Call RECUP_MG("", "", "",DATREF,VALMG)
# If [M]CSTTOTIDV(nolign-1)<arr(5*VALMG*[M]NBRDAY,0.01)
#  VALEUR=[M]CSTTOTIDV(nolign-1)
# Else
#  VALEUR=arr(5*VALMG*[M]NBRDAY,0.01)
# Endif
#Endif
## MABON 25/08/10 - Initialisation de CSTIPTIDV avec CSTTOTIDV si celui-ci est renseigné
#If VALEUR=0  & [M]CSTTOTIDV(nolign-1)<>0 : VALEUR=[M]CSTTOTIDV(nolign-1) : Endif
#End

Subprog AS_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR

Gosub SET_VALINI

Gosub IS_DISTRIB
Gosub GET_CUMUL_CSTIPTCLL
Gosub GET_CUMUL_CSTIPTIDV

If VALCUMULCLL<>0 : mkstat=2 : End : Endif
If W_FORMATEUR<>"" & VALCUMULIDV=0
 Local Decimal TAUX
 If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
 Read[F:ADI]CODE=10451;[M]TYPCRG(LIN)
 If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2
  Call TAUX_HORAIRE (W_FORMATEUR,W_CONTRAT,W_DATREF,TAUX,[F:ADI]N1,2,2) From TRTCOUT
  If !TAUX
   #Taux horaire imputable non défini
   Call ERREUR (W_FORMATEUR-":"-mess(79,10717,1))From GESECRAN
  Else
   VALEUR=arr(TAUX*[L]W_NBRHOUR,0.01)
  Endif
 Endif
Endif

# warning line could be split


VALCUMUL=VALCUMULIDV
# /!\  VALCUMULIDV is now CSTTOTIDV : VALCUMUL=CSTIPTIDV
Gosub GET_CUMUL_CSTTOTIDV

If [M]TYPCRG(LIN)="HEB" & VALCUMUL=0
 Local Decimal VALMG
 Call RECUP_MG("", "", "",W_DATREF,VALMG) From TRTCOUT
 If VALCUMULIDV<arr(5*VALMG*[L]W_NBRDAY,0.01)
  VALEUR=VALCUMULIDV
 Else
  VALEUR=arr(5*VALMG*[L]W_NBRDAY,0.01)
 Endif
Endif
# SBA change  MABON 25/08/10 - Initialisation de CSTIPTIDV avec CSTTOTIDV si celui-ci est renseigné
#If VALEUR=0  & [M]CSTTOTIDV(nolign-1)<>0 : VALEUR=[M]CSTTOTIDV(nolign-1) : Endif

If VALEUR=0 & VALCUMUL=0  & VALCUMULIDV<>0
  VALEUR=VALCUMULIDV
Else
  VALEUR=VALCUMUL
Endif

End
#LIPET - 2017-06-22 - X3-34431 - END
##############################
#Cout imputable individuel
#On contrôle que le coût imputable individuel n'est pas > que le coût total individuel
#On contrôle que le coût imputable individuel n'est pas > au minimum garanti en cas de frais d'hebergement
