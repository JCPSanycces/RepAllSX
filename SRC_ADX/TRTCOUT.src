# Declaration variable
# W_NOMPRG = non du traitement appelant
$DECLARE_PROCESS_LINE
Local Char W_ACTLINE(10)
Local Char W_STYLE(10)
Local Integer LINREF
Local Char W_CIBLE(30)
Local Char W_NOMPRG(200)
Gosub GET_NOLIGN
###
### [M]WTRTCOU
###
If dim([M]WTRTCOU)<>-1
  W_NOMPRG=[M]WTRTCOU
  Gosub GET_NAMBAS From =W_NOMPRG
  Gosub GET_VALNBLIGN
  W_CIBLE=WMANBAS+"(LINREF)"
Endif
Return
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
$GET_VALNBLIGN
