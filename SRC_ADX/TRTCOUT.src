# SBA X3PEOP-3476
Subprog AVANT_LIGNETABLE()
Gosub DECLARE_PROCESS_LINE
Gosub EFFZO_BLOCTECH From =W_NOMPRG
[M]WLNKTYPACT=""
If([M]LNKREP(LIN))<>"" and [M]LNKREP(LIN)+"D"=[M]LNKREP(LIN+1)
  LINREF=LIN+1
  Gosub SAVE_LINE
  [M]WLNKTYPACT="C"
Endif
[M]FLGCHG(LIN)=0
Gosub AFFZO_BLOCTECH From =W_NOMPRG
End
#LIPET - 2017-06-22 - X3-34429 - END

#LIPET - 2017-06-22 - X3-34429 - START
# SBA X3PEOP-3476
Subprog APRES_LIGNETABLE()
Gosub DECLARE_PROCESS_LINE
If status=6
  If [M]WLNKTYPACT="C"
    LINREF=LIN+1
    Gosub DELETE_LINEREP
    # case add at the last line => [M]+2
    If VAL_NBLIG-1=LINREF
      Gosub DELETE_LINEREP
    Endif
  Endif
  If[M]WTYPCRG(0)<>""
    LINREF=LIN
    Gosub RESTORE_LINEREP
  Endif
  # Bonne place????
  Gosub EFFZO_BLOCTECH From =W_NOMPRG
  [M]WLNKTYPACT=""
  Gosub STYLE
  Gosub AFFZO_BLOCCOUT From =W_NOMPRG
Endif

# delete call CSTMOY. put in local file
End
#LIPET - 2017-06-22 - X3-34429 - END

