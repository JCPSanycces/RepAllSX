  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PLBAMTREM = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).snapshot.PLBAMTREM
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_BUDGET_LINE()
  Endif
End

