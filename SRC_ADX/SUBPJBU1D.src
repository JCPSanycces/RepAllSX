#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMBUD1D
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "FIN"                         : Gosub FIN
    When "APRES_MODIF"                 : Gosub APRES_MODIF
    When "ENR"                         : Gosub ENR
    When "ABA"                         : Gosub ABANDON
    When "AVANT_NEW"                   : Gosub AVANT_NEW   # Issue X3-52534 - 2017-08-18 by FGR
    When "NEW"                         : Gosub NEW
    When "SUI"                         : Gosub SUI
    When "PRE"                         : Gosub PRE
    When "LAS"                         : Gosub LAS
    When "FIR"                         : Gosub FIR
    When "SUP"                         : Gosub SUP         # Issue X3-52534 - 2017-08-18 by FGR
    When "SETBOUT"                     : Gosub SETBOUT     # Issue X3-52534 - 2017-08-18 by FGR
    When "AP_CHOIX"                    : Gosub AP_CHOIX    # Issue X3-52534 - 2017-08-18 by FGR
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Instance TECFINOVE Using C_TECFINOVE
Global Integer GIPBUIDX
Global Integer GIPLBIDX
#Global Integer GICREATE               # Issue X3-52534 - 2017-08-18 by FGR : Not necessary from now

Local Char SVBU1DREP(type(REP)-10)     # Issue X3-52534 - 2017-08-18 by FGR
Local Char SPBUCOD(GLONPBU)
Local Integer IPLBSEQ

  # -----------------------------
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  #GICREATE = [V]CST_ANO               # Issue X3-52534 - 2017-08-18 by FGR : Not necessary from now
  SPBUCOD = PARAM(1)
  IPLBSEQ = val(PARAM(2))
  GIPBUIDX = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(SPBUCOD)
  GIPLBIDX = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_GET_INDEX(IPLBSEQ)
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  Call EXTRACT_ALL()
  # -----------------------------
Return

##########################################################################################################
$DEBUT
  # -----------------------------
  #If !clalev([F:PJC]) : Local File PJMSC [PJC] : Endif    # Issue X3-52534 - 2017-08-18 by FGR : Not necessary from now
  # -----------------------------
  [M:PJBU1D]OPPNUM = GZINSPJM.OPPNUM
  [M:PJBU1D]CUR    = GZINSPJM.CUR
  [M:PJBU1D]PBUCOD = SPBUCOD
  [M:PJBU1D]PLBSEQ = IPLBSEQ
  # -----------------------------
  #GIPBUIDX = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(SPBUCOD)                      # Issue X3-52534 - 2017-08-18 by FGR
  #GIPLBIDX = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_GET_INDEX(IPLBSEQ)     # Issue X3-52534 - 2017-08-18 by FGR
  Call SHOW_BUDGET_LINE()
Return

##########################################################################################################
$FIN
Local Integer IRET
Local Char STUNBUD(GLONPBU)            # Issue X3-52534 - 2017-08-18 by FGR

  If TECFINOVE <> null Then
    IRET = fmet TECFINOVE.DELETE_ALL()
    FreeGroup TECFINOVE
    Raz TECFINOVE
  Endif
  Kill TECFINOVE
  Kill GIPBUIDX
  Kill GIPLBIDX
  #Kill GICREATE                       # Issue X3-52534 - 2017-08-18 by FGR : Not necessary from now
  STUNBUD = SPBUCOD                    # Issue X3-52534 - 2017-08-18 by FGR
  Gosub LOAD_PAGE From PJMACTBUD       # Issue X3-52534 - 2017-08-18 by FGR : reload budget on previous screen
Return

##########################################################################################################
$APRES_MODIF
  If REP = AVOID.ACHAR Then
    REP = "M"
  Endif
Return

##########################################################################################################
$ENR
Local Integer MY_STATUS                          # Hybrid part
#Local Char STUNBUD(GLONPBU)                     # Issue X3-52534 - 2017-08-18 by FGR
Local Integer ISVPLBSEQ                          # Issue X3-52534 - 2017-08-18 by FGR

  #STUNBUD = SPBUCOD                             # Issue X3-52534 - 2017-08-18 by FGR
  # Hybrid part (begin)
  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  ISVPLBSEQ =  GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PLBSEQ
  Gosub RELIT_GZINSPJM From SUBPJMA
  GIPLBIDX = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_GET_INDEX(ISVPLBSEQ)    # Issue X3-52534 - 2017-08-18 by FGR : moved on $FIN do to it once
  Call EXTRACT_ALL()                                                           # Refresh suivi financier
  #Gosub LOAD_PAGE From PJMACTBUD                                              # Issue X3-52534 - 2017-08-18 by FGR : moved on $FIN do to it once
  Call SHOW_BUDGET_LINE()
  # Hybrid part (end)
  Raz REP
  Raz SVBU1DREP                                                                # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$ABANDON
Local Integer IRET

  # --------------------------------
  # Issue X3-52534 - 2017-08-18 by FGR : BEGIN Not necessary from now
  #If GICREATE = [V]CST_AYES Then
  #  # The user did "Cancel" on a new created line
  #  GICREATE = [V]CST_ANO
  #  # I put the focus on the line where the SUBPJBU1D action was called.
  #  GIPLBIDX = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_GET_INDEX(IPLBSEQ)
  #Endif
  GIPLBIDX = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_GET_INDEX(IPLBSEQ)
  # Issue X3-52534 - 2017-08-18 by FGR : END Not necessary from now
  # --------------------------------
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call SHOW_BUDGET_LINE()
  Raz REP
  Raz SVBU1DREP    # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$AVANT_NEW
  # Issue X3-52534 - 2017-08-18 by FGR
  REP = SVBU1DREP
Return

##########################################################################################################
$NEW
Local Integer ILINE

  ILINE = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).ADDLINE("BUDLIG", [V]CST_ALASTPOS)
  If ILINE = [V]CST_ANOTDEFINED Then
    # Issue X3-52534 - 2017-08-18 by FGR
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    #GICREATE = [V]CST_AYES  # Issue X3-52534 - 2017-08-18 by FGR : Not necessary from now
    GIPLBIDX = ILINE
    Call SHOW_BUDGET_LINE()
    REP = "M"
  Endif
Return

##########################################################################################################
$SUI
Local Integer NI

  For NI = GIPLBIDX+1 To maxtab(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG)
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      GIPLBIDX = NI
      Call SHOW_BUDGET_LINE()
      Break
    Endif
  Next NI
  REP = SVBU1DREP  # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$PRE
Local Integer NI

  For NI = GIPLBIDX-1 To 1 Step -1
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      GIPLBIDX = NI
      Call SHOW_BUDGET_LINE()
      Break
    Endif
  Next NI
  REP = SVBU1DREP  # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$LAS
Local Integer NI

  For NI = maxtab(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG) To 1 Step -1
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      GIPLBIDX = NI
      Call SHOW_BUDGET_LINE()
      Break
    Endif
  Next NI
  REP = SVBU1DREP  # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$FIR
Local Integer NI

  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG)
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      GIPLBIDX = NI
      Call SHOW_BUDGET_LINE()
      Break
    Endif
  Next NI
  REP = SVBU1DREP  # Issue X3-52534 - 2017-08-18 by FGR
Return

##########################################################################################################
$SUP
Local Integer IRET

  # Issue X3-52534 - 2017-08-18 by FGR
  IRET = fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).ADELLINE("BUDLIG", GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    If REP = AVOID.ACHAR Then
      REP = "M"
    Endif
    SVBU1DREP = REP
    If fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_COUNT() > 0 Then
      Gosub FIR
    Else
      GIPLBIDX = 0
      Effzo [M:PJBU1D]
    Endif
  Endif
Return

##########################################################################################################
$SETBOUT
  # Issue X3-52534 - 2017-08-18 by FGR
  CHBOU += "N"     # To not deactive "New" button
  If fmet GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG_COUNT() > 0 Then
    CHBOU += "S"   # To not deactive "Delete" button
    CHBOU += "0"   # To not deactive "First" button
    CHBOU += "9"   # To not deactive "Last" button
    CHBOU += "<"   # To not deactive "Back" button
    CHBOU += ">"   # To not deactive "Next" button
  Endif
Return

##########################################################################################################
$AP_CHOIX
  # Issue X3-52534 - 2017-08-18 by FGR
  If find(REPONSE, GSTAEND) Then
    If REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      Return
    Endif
  Elsif find(REPONSE, GSTANEW) Then
    # To deactivate the question to lost current not updated information
    SVBU1DREP = REP
    Raz REP
  Elsif find(REPONSE, GSTASUI, GSTAPRE, GSTAFIR, GSTALAS) Then
    If REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      SVBU1DREP = REP
      Raz REP
      Return
    Endif
  Endif
Return

##########################################################################################################
# Subroutines and functions
##########################################################################################################
Subprog EXTRACT_ALL()
Local Integer IRET

  If GIPLBIDX > 0 Then       # Issue X3-52534 - 2017-08-18 by FGR
    If TECFINOVE <> null Then
      FreeGroup TECFINOVE
      Raz TECFINOVE
    Endif
    TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
    IRET = fmet TECFINOVE._GET_DEFAULT_GRP()
    #TECFINOVE.PROJECT  = GZINSPJM               # Issue X3-82778 - 2018-06-18 by FGR : not necessary # Note FGR : optimisation for financial overview loading.
    TECFINOVE.ISBUDUPD = [V]CST_AYES
    TECFINOVE.OPPNUM   = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).OPPNUM
    TECFINOVE.PBUCOD   = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PBUCOD
    TECFINOVE.CUR      = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).CUR
    TECFINOVE.UOM      = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PLBU
    IRET = fmet TECFINOVE.EXTRACT_ALL()
    If IRET <> [V]CST_AOK Then
      IRET = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(TECFINOVE, GMESSAGE)
      GERR = 1
      GOK = 0
      FIN = 1
    Endif
  Endif
End

##########################################################################################################
Subprog LOAD_PJMSC()
  If GIPLBIDX > 0 Then                                                                   # Issue X3-52534 - 2017-08-18 by FGR
    #If GICREATE = [V]CST_ANO Then                                                       # Issue X3-52534 - 2017-08-18 by FGR
    If GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).ASTALIN <> [V]CST_ANEW Then        # Issue X3-52534 - 2017-08-18 by FGR
      Local File PJMSC [PJC]                                                             # Issue X3-52534 - 2017-08-18 by FGR
      Filter [F:PJC] Where PSCSSS = TECFINOVE.SESSION
&                      and PBUCOD = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PBUCOD
&                      and PCCCOD = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PCCCOD
      For [F:PJC]
        [M:PJBU1D] = [F:PJC]
        Break
      Next
      Filter [F:PJC]
    Endif
  Endif
End

##########################################################################################################
Subprog SHOW_BUDGET_LINE
  If GIPLBIDX > 0 Then       # Issue X3-52534 - 2017-08-18 by FGR
    Raz [M:PJBU1D]
    Call LOAD_PJMSC()
    #Note FGR : mandatory after LOAD_PJMSC, because in PJMSC table there are fields with the same name than in the screen.
    SetInstance [M:PJBU1D] With GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX)
    [M:PJBU1D]PBUDESAXX = GZINSPJM.PJM(1).BUD(GIPBUIDX).PIMPL.PIMDESAXX
    Call SET_STYLES()
    Affzo [M:PJBU1D]1-99
    GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).TCHFINOVSESS = TECFINOVE.SESSION
  Endif
End

##########################################################################################################
Funprog COL_GET_TITLE(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.COL_GET_TITLE(TECFINOVE, INDEX)
End SARENDRE

##########################################################################################################
Funprog COLGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVE, INDEX, [V]CST_AYES, [M:PJBU1D]CUR, [V]CST_AYES, [M:PJBU1D]PLBU)
End SARENDRE

##########################################################################################################
Subprog SET_STYLES()
  # PJMEXPENSE (vert)
  Chgstl [M:PJBU1D]PSCBUDQTY   With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCBUDAMT   With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCQTY1     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCAMT1     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCQTY2     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCAMT2     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCQTY3     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCAMT3     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCQTY4     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCAMT4     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCQTY5     With "PJMEXPENSE"
  Chgstl [M:PJBU1D]PSCAMT5     With "PJMEXPENSE"
  # PJMREMAINS (jaune)
  Chgstl [M:PJBU1D]PSCREMQTY   With "PJMREMAINS"
  Chgstl [M:PJBU1D]PSCREMAMT   With "PJMREMAINS"
  Chgstl [M:PJBU1D]PSCWIPQTY   With "PJMREMAINS"
  Chgstl [M:PJBU1D]PSCWIPAMT   With "PJMREMAINS"
  # PJMTOTAL   (orange)
  Chgstl [M:PJBU1D]PSCTOTQTY   With "PJMTOTAL"
  Chgstl [M:PJBU1D]PSCTOTAMT   With "PJMTOTAL"
  Chgstl [M:PJBU1D]PSCMARGQTY  With "PJMTOTAL"
  Chgstl [M:PJBU1D]PSCMARGAMT  With "PJMTOTAL"
  Chgstl [M:PJBU1D]PSCPCTMQTY  With "PJMTOTAL"
  Chgstl [M:PJBU1D]PSCPCTMAMT  With "PJMTOTAL"
End

##########################################################################################################
##########################################################################################################
# Screens fields
##########################################################################################################
# PJBU1D
##########################################################################################################
Subprog AM_PLBDESAXX(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PLBDESAXX = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).PLBDESAXX = GZINSPJM.PJM(1).BUD(GIPBUIDX).BUDLIG(GIPLBIDX).snapshot.PLBDESAXX
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_BUDGET_LINE()
  Endif
End

