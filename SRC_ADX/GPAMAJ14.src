#<AdxTL>@(#)1.0.0.0 $Revision$
#################################################################################
# GPAMAJ14 : Mises à jour à effectuer lors du passage à la v140   Module GPAO   #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#    - ROUOPE, table des opérations de gamme                                    #
#      Initialisation du champs tiers (BPRNUM)                                  #
#      Initialisation des champs date de début(VALSTRDAT) et date de fin        #
#      d'une opération(VALENDDAT)                                               #
#                                                                               #
#    - MFGOPE, table des opérations OF                                          #
#      Initialisation du champs tiers (BPRNUM)                                  #
#                                                                               #
#    - RPLWST, table des postes de charge remplaçants                           #
#      Initialisation des champs de la nouvelle table RPLWST                    #
#                                                                               #
#    - WORKSTATIO, table des postes de charge                                   #
#      Initialisation des champs RCCP (RCCP), contraint (CONSTRAINT) et         #
#      regroupement (GRPFLG)                                                    #
#                                                                               #
#    - MFGITMTRK, table des suivis de production                                #
#      Initialisation des champs CSTFLG,ITMTYP,PJT,QUAFLG                       #
#                                                                               # 
#    - MFGTRS, table des transactions                                           #
#      Initialisation des champs MCCIMPMOD                                      #
#      Initialisation des champs STOCK 140                                      #
#                                                                               #
#    - MFGCOST, table des prix de revient de fabrication                        #
#      Initialisation du type de coût                                           #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#                                                                               #
#################################################################################

#################################################################################
# Moulinette Avant mise à jour concernant le module GPAO                        #
#################################################################################
Subprog AGPAMAJ14
Local Integer  COMPTEUR, INDIC, STOP
Local Char     CLE1(20),CLE3(20),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5
Local Integer  I

If filinfo (filpath ("FIL", "ROUOPE"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "MFGOPE"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "WORKSTATIO", "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "RPLWST"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "MFGHEAD"   , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "MFGTRS"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "MFGITMTRK" , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "MFGITM"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "ITMMASTER" , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif


Gosub SET_FIRST From TRTFIRST

#-------------------------------------------------------------------------------#
#  ROUOPE, table des opérations de gamme                                        #
#  Initialisation de BPRNUM(=BPSNUM)                                            #
#  Initialisation de VALENDDAT(=RLPDAT) et de VALSTRDAT(=RLPDAT+1),             #
#  uniquement quand il existe une opération remplaçante                         #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".ROUOPE" [ROO]
Local File =[F:ADS]DOSSIER+".ROUOPE" [ROOW]

Call ECR_TIME("DOSMAJ14 : Operations Process") From DOSSUB

Raz CLE1, CLE2 , CLE4, CLE5 , STOP
$BOUCLE_ROO
If STOP=1
   STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT='+ num$(CLE2)+' & OPENUM='+ num$(CLE4)+' & RPLIND>'+ num$(CLE5)
Elsif STOP=2
   STOP=3 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT='+ num$(CLE2)+' & OPENUM>'+ num$(CLE4)   
Elsif STOP=3
   STOP=4 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT>'+ num$(CLE2)       
Elsif STOP=4
   STOP =0 :CRITERE='ITMREF>"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ROO]

For [ROO]ROO0 Where evalue (CRITERE)
    #Readlock [ROO] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File ROUOPE, Error="-num$(fstat),1) From GESECRAN
    #Else
        If [F:ROO]BPSNUM <>"" & [F:ROO]BPRNUM ="" : [F:ROO]BPRNUM =[F:ROO]BPSNUM : Endif
        If [F:ROO]RPLDAT<>[0/0/0] & [F:ROO]VALENDDAT=[0/0/0]
            [F:ROO]VALENDDAT = [F:ROO]RPLDAT
            # si une opération remplaçante existe
            #Readlock [ROOW]ROO0=[ROO]ITMREF;[ROO]ROUALT;[ROO]OPENUM;[ROO]RPLIND+1  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
            Read [ROOW]ROO0=[ROO]ITMREF;[ROO]ROUALT;[ROO]OPENUM;[ROO]RPLIND+1  # FGR 12/03/2010 : X3SUIVI63191
            If fstat =0 
                [F:ROOW]VALSTRDAT =  [F:ROO]RPLDAT+1
                Rewrite [F:ROOW]
            Endif
        Endif
        Rewrite [F:ROO]
    #Endif
    COMPTEUR += 1
    If COMPTEUR >GMAXUPDTRS
        CLE1 = [F:ROO]ITMREF
        CLE2 = [F:ROO]ROUALT
        CLE4 = [F:ROO]OPENUM
        CLE5 = [F:ROO]RPLIND
        STOP =1
        Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_ROO : Endif
Close Local File [ROO]
Close Local File [ROOW]

#-------------------------------------------------------------------------------#
#  MFGOPE, table des opérations OF                                              #
#  Initialisation du champs tiers (BPRNUM)                                      #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGOPE" [MFO]

Call ECR_TIME("DOSMAJ14 : Manufacturing Operations Process") From DOSSUB

Raz CLE1,CLE2,CLE4,STOP
$BOUCLE_MFO
If STOP=1
    STOP= 2 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM='+num$(CLE2)+' & OPESPLNUM>'+num$(CLE4)
Elsif STOP= 2
    STOP= 3 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM>'+num$(CLE2)
Elsif STOP= 3
    STOP= 0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
    CRITERE ="1=1"
Endif

Raz COMPTEUR
Trbegin [MFO]

For [MFO]MFO0 Where evalue (CRITERE)
    #Readlock [MFO] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File MFGOPE, Error="-num$(fstat),1) From GESECRAN
    #Else
        If [F:MFO]BPSNUM<>"" &  [F:MFO]BPRNUM=""
            [F:MFO]BPRNUM=[F:MFO]BPSNUM
        Endif
        Rewrite [F:MFO]
    #Endif
    COMPTEUR += 1
    If COMPTEUR >GMAXUPDTRS
        CLE1 = [F:MFO]MFGNUM
        CLE2 = [F:MFO]OPENUM
        CLE4 = [F:MFO]OPESPLNUM
        STOP =1
        Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_MFO : Endif
Close Local File [MFO]

#-------------------------------------------------------------------------------#
#  Initialisation de la nouvelle table RPLWST grâce au contenu des              #
#  champs de WOKSTATIO                                                          #
#  + Initialisation de champs de la table WOKSTATIO                             #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".WORKSTATIO" [MWS]
Local File =[F:ADS]DOSSIER+".WORKSTATIO" [MWS2] # table de travail
Local File =[F:ADS]DOSSIER+".RPLWST" [RPW]

Call ECR_TIME("DOSMAJ14 : Workstations Process") From DOSSUB

Raz CLE1, CLE3, STOP
$BOUCLE_RPW
If STOP=1
    STOP= 2 : CRITERE='WST="'+CLE1+'"'+' & WCRFCY>"'+ CLE3 +'"'
Elsif STOP= 2
    STOP= 0 : CRITERE='WST>"'+CLE1 +'"'
Else
    CRITERE ="1=1"
Endif

Raz COMPTEUR
Trbegin [MWS]

For [MWS]WST0 Where evalue(CRITERE)
#Readlock [MWS] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat 
    #    Call ECR_TRACE("File WORKSTATIO, Error="-num$(fstat),1) From GESECRAN
    #Else
        Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY 
        If fstat<>0
            Raz [F:RPW]
            [F:RPW]WST       =[F:MWS]WST
            [F:RPW]WCRFCY    =[F:MWS]WCRFCY 
            If [F:MWS]RPLWST<>""
                #Readlock [MWS2]WST0=[F:MWS]RPLWST;[F:MWS]WCRFCY  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                Read [MWS2]WST0=[F:MWS]RPLWST;[F:MWS]WCRFCY  # FGR 12/03/2010 : X3SUIVI63191
                If !fstat  
                    [F:RPW]RPLWST(0)    =[F:MWS2]WST
                    [F:RPW]RPLWSTDES(0) =[F:MWS2]WSTDES 
                    [F:RPW]WCR(0)       =[F:MWS2]WCR
                    [F:RPW]WSTTYP(0)    =[F:MWS2]WSTTYP
                Endif          
            Endif   
            Write [F:RPW] 
        Endif
        # initialisation zones RCCP , contraint , Regroupement
        If !find([F:MWS]RCCP,1,2)       : [F:MWS]RCCP = 2       : Endif
        If !find([F:MWS]CONSTRAINT,1,2) : [F:MWS]CONSTRAINT = 2 : Endif
        If !find([F:MWS]GRPFLG,1,2)     : [F:MWS]GRPFLG = 1     : Endif
        Rewrite [F:MWS]
    #Endif
    COMPTEUR +=1
    If COMPTEUR>GMAXUPDTRS
        CLE1 = [F:MWS]WST
        CLE3 = [F:MWS]WCRFCY
        STOP = 1
        Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_RPW : Endif
Close Local File [MWS]
Close Local File [MWS2]
Close Local File [RPW] 

#-------------------------------------------------------------------------------#
#  Initialisation de la table MFGHEAD                                           #
#  + Initialisation du champ SUSFLG                                             #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGHEAD" [MFG]

Local Integer I, GOK

Call ECR_TIME("DOSMAJ14 : Work Orders Header Process") From DOSSUB

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MFG
If STOP=1
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [MFG]
For [MFG] Where evalue(CRITERE) 
    #Readlock [F:MFG]MFG0 Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
    #Else
        If !find([F:MFG]SUSFLG,1,2): [F:MFG]SUSFLG = 1 : Endif
        Rewrite [MFG]
    #Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS 
        CLE1 = [F:MFG]MFGNUM
        STOP = 1 
        Break 
    Endif
Next
Commit
If STOP : Goto BOUCLE_MFG : Endif
Close Local File [MFG]

#-------------------------------------------------------------------------------#
#  Initialisation de la table MFGTRS                                            #
#  + Initialisation du champ MCCIMPMOD                                          #
#  + Initialisation des champs stock                                            #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGTRS"   [MTS]

Call ECR_TIME("DOSMAJ14 : Manufacturing transaction Process") From DOSSUB

Trbegin [MTS]
For [MTS]MTS0
    #Readlock [MTS] Curr      # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File MFGTRS, Error ="-num$(fstat),1) From GESECRAN
    #Else
        Case [F:MTS]MTSTYP
            When 1:  Raz INDIC : If [F:MTS]MCCIMPMOD = 0 : INDIC = 1 : [F:MTS]MCCIMPMOD = 1 : Endif
            When 2:  Raz INDIC
                     Gosub  TXNSTOCK
        Endcase
        If INDIC = 1 
           Rewrite [MTS]
        Endif
    #Endif
Next
Commit
Close Local File [MTS]

#-------------------------------------------------------------------------------#
#  Initialisation de la table MFGITMTRK                                         #
#  + Initialisation des champs CSTFLG,PJT,ITMTYP,QUAFLG                         #
#-------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".MFGITM"    [MFI]
Local File =[F:ADS]DOSSIER+".MFGITMTRK" [MKI]
Local File =[F:ADS]DOSSIER+".ITMMASTER" [ITM]

Local Integer I, GOK

Call ECR_TIME("DOSMAJ14 : Product tracking Process") From DOSSUB

Raz CLE1, CLE2, STOP
$BOUCLE_MKI
If STOP=1
    STOP= 2 : CRITERE='MFGTRKNUM ="'+CLE1+'"'+'& ITMTRKLIN>'+ num$(CLE2)        # 03.06 35256
Elsif STOP= 2
    STOP= 0 : CRITERE='MFGTRKNUM>"'+CLE1 +'"'
Else
    CRITERE ="1=1"
Endif
CRITERE += "& PRODTYP = 1"


Raz COMPTEUR
Trbegin [MKI]
For [MKI] Where evalue(CRITERE) 
    #Readlock [F:MKI]MKI0 Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File MFGITMTRK, Error ="-num$(fstat),1) From GESECRAN
    #Else
        Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
        If !fstat
             [F:MKI]CSTFLG = [F:MFI]CSTFLG
             [F:MKI]PJT    = [F:MFI]PJT
             [F:MKI]ITMTYP = [F:MFI]ITMTYP
        Endif
        Read [F:ITM]ITM0   = [F:MKI]ITMREF
        If !fstat
             [F:MKI]QUAFLG = [F:ITM]QUAFLG
        Endif
        Rewrite [MKI]
    #Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS 
        CLE1 = [F:MKI]MFGTRKNUM
        CLE2 = [F:MKI]ITMTRKLIN
        STOP = 1 
        Break 
    Endif
Next
Commit
If STOP : Goto BOUCLE_MKI : Endif
Close Local File [MKI]
Close Local File [MFI]
Close Local File [ITM]

#-------------------------------------------------------------------------------#
#  MFGCOST, table des prix de revient de fabrication                            #
#  Initialisation du champs type (MFCTYP)                                       #
#-------------------------------------------------------------------------------#
# 1:Cout prévisionnel théorique
# 2:Cout prévisionnel lancement
# 3:Cout prévisionnel production
# 4:Prix de revient de fabrication (seul type possible en 130)


Local Char    ERR_TRA(120)

If clalev([MFC]) = 0 Local File =[F:ADS]DOSSIER+".MFGCOST" [MFC] Endif

Call ECR_TIME("DOSMAJ14 : Manufacturing Cost Type process") From DOSSUB

Call DEBTRANS From GLOCK
Trbegin [MFC]

Update [MFC] Where MFCTYP=0 With MFCTYP=4
If fstat 
   Call ECR_TRACE("File MFGCOST, Error="-num$(fstat),1) From GESECRAN
Endif
Commit

Gosub UNSET_FIRST From TRTFIRST

End


##############################################################################################
$TXNSTOCK
#   Init nouveaux champs stock sur MTS
If [F:MTS]SRGWAIFLG=0  [F:MTS]SRGWAIFLG=1  : Endif   : # A quai  (non)

#   Bloc document
If [F:MTS]UOMSAIFLG=0 [F:MTS]UOMSAIFLG=1 : Endif                         : # Saisie UC     (non)
If !find([F:MTS]LOTCOD,1,2,3)    INDIC=1 : [F:MTS]LOTCOD=1 : Endif       : # Num.lot       (saisie)
If [F:MTS]LOTCOD<>0  & [F:MTS]LOTSCR=0 INDIC=1 : [F:MTS]LOTSCR=1  : Endif
If !find([F:MTS]SLOCOD,1,2,3)    INDIC=1 : [F:MTS]SLOCOD=3 : Endif       : # Num.sous-lot  (invisible)
If [F:MTS]SLOCOD<>0  & [F:MTS]SLOSCR=0 INDIC=1 : [F:MTS]SLOSCR=1  : Endif
If [F:MTS]NBSLOFLG=0  [F:MTS]NBSLOFLG=1 : Endif                          : # Nbr s-lot     (invisible)
If !find([F:MTS]LOCCOD,1,2,3)    INDIC=1 : [F:MTS]LOCCOD=3 : Endif       : # Emplacement   (invisible)
If [F:MTS]LOCCOD<>0  & [F:MTS]LOCSCR=0 INDIC=1 : [F:MTS]LOCSCR=1  : Endif
If !find([F:MTS]SERCOD,1,2,3)    INDIC=1 : [F:MTS]SERCOD=3    : Endif    : # Num série     (invisible)
If [F:MTS]SERCOD<>0  & [F:MTS]SERSCR=0 INDIC=1 : [F:MTS]SERSCR=1  : Endif
If !find([F:MTS]SERECOD,1,2)     INDIC=1 : [F:MTS]SERECOD=2   : Endif    : # Num série     (invisible)
If [F:MTS]SERECOD<>0 & [F:MTS]SERESCR=0 INDIC=1 : [F:MTS]SERESCR=1  : Endif
If !find([F:MTS]MVTDESCOD,1,2,3) INDIC=1 : [F:MTS]MVTDESCOD=3 : Endif    : # Dési.mvt      (invisible)
If [F:MTS]MVTDESCOD<>0  & [F:MTS]MVTDESSCR=0 INDIC=1 : [F:MTS]MVTDESSCR=1  : Endif
#   Bloc détail
If [F:MTS]UOMSAIFLG1=0 [F:MTS]UOMSAIFLG1=1 : Endif                       : # Saisie UC     (non)
If !find([F:MTS]IDECOD1,1,2,3)     INDIC=1 : [F:MTS]IDECOD1=3 : Endif    : # Identifiant 1 (invisible)
If [F:MTS]IDECOD1<>0  & [F:MTS]IDESCR1=0 INDIC=1 : [F:MTS]IDESCR1=1  : Endif
If !find([F:MTS]IDECOD2,1,2,3)     INDIC=1 : [F:MTS]IDECOD2=3 : Endif    : # Identifiant 2 (invisible)
If [F:MTS]IDECOD2<>0  & [F:MTS]IDESCR2=0 INDIC=1 : [F:MTS]IDESCR2=1  : Endif
If !find([F:MTS]PRNCOD1,1,2,3,4,5) INDIC=1 : [F:MTS]PRNCOD1=1 : Endif    : # Impression    (pas impre)
If [F:MTS]PRNSCR1=0   INDIC=1 : [F:MTS]PRNSCR1=1  : Endif
If [F:MTS]PRNNBFLG1=0 INDIC=1 : [F:MTS]PRNNBFLG1=1 : Endif               : # Nbr document  (non)
If [F:MTS]PRNNBFLG1<>0 & [F:MTS]PRNNBSCR1=0 INDIC=1 : [F:MTS]PRNNBSCR1=1 : Endif
If !find([F:MTS]SERECOD1,1,2)      INDIC=1 : [F:MTS]SERECOD1=2 : Endif   : # Num série     (invisible)
If [F:MTS]SERECOD1<>0 & [F:MTS]SERESCR1=0 INDIC=1 : [F:MTS]SERESCR1=1  : Endif
If !find([F:MTS]MVTDESCOD1,1,2,3)  INDIC=1 : [F:MTS]MVTDESCOD1=3 : Endif : # Dési.mvt     (invisible)
If !find([F:MTS]AVSTOCOD1,1,2)     INDIC=1 : [F:MTS]AVSTOCOD1=2  : Endif : # Stock dispo  (invisible)
If [F:MTS]AVSTOCOD1<>0 & [F:MTS]AVSTOSCR1=0 INDIC=1 : [F:MTS]AVSTOSCR1=1  : Endif
If !find([F:MTS]SPERFLG,1,2)       INDIC=1 : [F:MTS]SPERFLG=2  : Endif   : # Péremption   (oui)
If !find([F:MTS]SPOTFLG,1,2)       INDIC=1 : [F:MTS]SPOTFLG=2  : Endif   : # Titre        (oui)
If !find([F:MTS]SRUB1FLG,1,2)      INDIC=1 : [F:MTS]SRUB1FLG=1 : Endif   : # Rub 1        (non)
If !find([F:MTS]SRUB2FLG,1,2)      INDIC=1 : [F:MTS]SRUB2FLG=1 : Endif   : # Rub 2        (non)
If !find([F:MTS]SRUB3FLG,1,2)      INDIC=1 : [F:MTS]SRUB3FLG=1 : Endif   : # Rub 3        (non)
If !find([F:MTS]SRUB4FLG,1,2)      INDIC=1 : [F:MTS]SRUB4FLG=1 : Endif   : # Rub 4        (non)

If !find([F:MTS]CCECODS,1,2,3)  INDIC=1 : [F:MTS]CCECODS = 1    : Endif
#   sorties
If !find([F:MTS]LOTCODS,1,2,3)    INDIC=1 : [F:MTS]LOTCODS=1 : Endif       : # Num.lot       (saisie)
If [F:MTS]LOTCODS<>0  & [F:MTS]LOTSCRS=0 INDIC=1 : [F:MTS]LOTSCRS=1  : Endif
If !find([F:MTS]SLOCODS,1,2,3)    INDIC=1 : [F:MTS]SLOCODS=3 : Endif       : # Num.sous-lot  (invisible)
If [F:MTS]SLOCODS<>0  & [F:MTS]SLOSCRS=0 INDIC=1 : [F:MTS]SLOSCRS=1  : Endif
If !find([F:MTS]AQRCODS,1,2,3)    INDIC=1 : [F:MTS]AQRCODS=3 : Endif       : # Statut        (invisible)
If [F:MTS]AQRCODS<>0  & [F:MTS]AQRSCRS=0 INDIC=1 : [F:MTS]AQRSCRS=1  : Endif
If !find([F:MTS]LOCCODS,1,2,3)    INDIC=1 : [F:MTS]LOCCODS=3 : Endif       : # Emplacement   (invisible)
If [F:MTS]LOCCODS<>0  & [F:MTS]LOCSCRS=0 INDIC=1 : [F:MTS]LOCSCRS=1  : Endif
If !find([F:MTS]SERCODS,1,2,3)    INDIC=1 : [F:MTS]SERCODS=3    : Endif    : # Num série     (invisible)
If [F:MTS]SERCODS<>0  & [F:MTS]SERSCRS=0 INDIC=1 : [F:MTS]SERSCRS=1  : Endif
If !find([F:MTS]SERECODS,1,2)     INDIC=1 : [F:MTS]SERECODS=2   : Endif    : # Num série     (invisible)
If [F:MTS]SERECODS<>0 & [F:MTS]SERESCRS=0 INDIC=1 : [F:MTS]SERESCRS=1  : Endif
If !find([F:MTS]MVTDESCODS,1,2,3) INDIC=1 : [F:MTS]MVTDESCODS=3 : Endif    : # Dési.mvt      (invisible)
If [F:MTS]MVTDESCODS<>0  & [F:MTS]MVTDESSCRS=0 INDIC=1 : [F:MTS]MVTDESSCRS=1  : Endif
Return

#################################################################################
# Moulinette Après mise à jour concernant le module GPAO                        #
#################################################################################
Subprog GPAMAJ14
End
