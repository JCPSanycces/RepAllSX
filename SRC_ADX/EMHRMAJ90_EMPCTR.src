#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_EMPCTR UTI process                                  PAY Module
#                  Migration To U12 - Vnext version
#
# ==>  Update Emplyment Contract from Employee table
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update Emplyment Contract from Employee table") From LECFIC

  Call MAJ_EMHRMAJ90_EMPCTR(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_EMPCTR(LDOSSIER)
Value Char LDOSSIER

Onerrgo CYCLECHECKERROR
Local Char THISPROC(20) : THISPROC = "EMHRMAJ90_EMPCTR"
Local Integer COMPTEUR

Call TEMPON("O") From GESECRAN
Call ECR_TRACE("EMHRMAJ90_EMPCTR: Update Emplyment Contract from Employee table",0) From GESECRAN
Call ECR_TRACE("EMHRMAJ90_EMPCTR: Start of process on : "+LDOSSIER,0) From GESECRAN

Gosub TRANSFER_SA
Gosub TRANSFER_MID
Gosub TRANSFER_AFR

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_EMPCTR: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

#############################################################################################
# Transfer code for different legislations
# Add the tables to open and the fields that must be migrated here
#############################################################################################

#############################################################################################
# South Africa
#############################################################################################
$TRANSFER_SA


If filinfo(filpath("FIL","EMPLOIDSA","fde",LDOSSIER),0)>0 & filinfo(filpath("FIL","EMPLOCTRSA","fde",LDOSSIER),0)>0

  # Tables to open for migration
  If clalev ([F:CTRSA]) = 0 : Local File =LDOSSIER+".EMPLOCTRSA" [CTRSA] : Endif #Destination
  If clalev ([F:ESAR]) = 0  : Local File =LDOSSIER+".EMPLOIDSA" [ESAR] : Endif #Source
  Raz [L]COMPTEUR

  For[ESAR]
    Filter [F:CTRSA] Where REFNUM=[F:ESAR]REFNUM Order By CTRDAT Desc

  # Fields that must be migrated
    Trbegin [CTRSA]
    Readlock [CTRSA] First
    If fstat
      Gosub TRACE_LOG
      Rollback
    Else
      [CTRSA] = [F:ESAR]
#      [CTRSA]ADDCNTCDE   = [F:ESAR]ADDCNTCDE
#      [CTRSA]ADDCOR      = [F:ESAR]ADDCOR
#      [CTRSA]ADDCPX      = [F:ESAR]ADDCPX
#      [CTRSA]ADDPOSAGN   = [F:ESAR]ADDPOSAGN
#      [CTRSA]ADDPOSCDE   = [F:ESAR]ADDPOSCDE
#      [CTRSA]ADDPOSCOF   = [F:ESAR]ADDPOSCOF
#      [CTRSA]ADDPOSINM   = [F:ESAR]ADDPOSINM
#      [CTRSA]ADDPOSNAM   = [F:ESAR]ADDPOSNAM
#      [CTRSA]ADDPOSNUM   = [F:ESAR]ADDPOSNUM
#      [CTRSA]ADDPOSOTH   = [F:ESAR]ADDPOSOTH
#      [CTRSA]ADDPRI      = [F:ESAR]ADDPRI
#      [CTRSA]ADDPRV      = [F:ESAR]ADDPRV
#      [CTRSA]ADDSRVTYP   = [F:ESAR]ADDSRVTYP
#      [CTRSA]ADDSTA      = [F:ESAR]ADDSTA
#      [CTRSA]ADDSTRNAM   = [F:ESAR]ADDSTRNAM
#      [CTRSA]ADDSTRNUM   = [F:ESAR]ADDSTRNUM
#      [CTRSA]ADDSUB      = [F:ESAR]ADDSUB
#      [CTRSA]ADDTWN      = [F:ESAR]ADDTWN
#      [CTRSA]ADDTYP      = [F:ESAR]ADDTYP
      Rewrite [CTRSA]
      Commit
    Endif
    [L]COMPTEUR +=1
    Gosub TRACE_LOG_PROCESSING
  Next

  Gosub TRACE_LOG

  Close Local File [CTRSA], [ESAR]
Else
  Call ECR_TRACE(THISPROC+" : Table EMPLOIDSA does not exist",0) From GESECRAN
Endif
Return



#############################################################################################
# Middle East
#############################################################################################
$TRANSFER_MID
If filinfo(filpath("FIL","EMPLOIDMID","fde",LDOSSIER),0)>0 & filinfo(filpath("FIL","EMPLOCTRMID","fde",LDOSSIER),0)>0

  If clalev ([F:CTRMID]) = 0 : Local File =LDOSSIER+".EMPLOCTRMID" [CTRMID] : Endif  #Destination
  If clalev ([F:EMIR]) = 0   : Local File =LDOSSIER+".EMPLOIDMID" [EMIR]  : Endif  #Source
  Raz [L]COMPTEUR

  For[EMIR]
    Filter [F:CTRMID] Where REFNUM=[F:EMIR]REFNUM Order By CTRDAT Desc

    Trbegin [CTRMID]
    Readlock [CTRMID] First
    If fstat
      Gosub TRACE_LOG
      Rollback
    Else
      [CTRMID] = [F:EMIR]
#      [CTRMID]MIDCNTCDE    = [F:EMIR]MIDCNTCDE
#      [CTRMID]MIDCOR       = [F:EMIR]MIDCOR
#      [CTRMID]MIDCPX       = [F:EMIR]MIDCPX
#      [CTRMID]MIDPOSAGN    = [F:EMIR]MIDPOSAGN
#      [CTRMID]MIDPOSCDE    = [F:EMIR]MIDPOSCDE
#      [CTRMID]MIDPOSCOF    = [F:EMIR]MIDPOSCOF
#      [CTRMID]MIDPOSINM    = [F:EMIR]MIDPOSINM
#      [CTRMID]MIDPOSNAM    = [F:EMIR]MIDPOSNAM
#      [CTRMID]MIDPOSNUM    = [F:EMIR]MIDPOSNUM
#      [CTRMID]MIDPOSOTH    = [F:EMIR]MIDPOSOTH
#      [CTRMID]MIDPRI       = [F:EMIR]MIDPRI
#      [CTRMID]MIDPRV       = [F:EMIR]MIDPRV
#      [CTRMID]MIDSRVTYP    = [F:EMIR]MIDSRVTYP
#      [CTRMID]MIDSTA       = [F:EMIR]MIDSTA
#      [CTRMID]MIDSTRNAM    = [F:EMIR]MIDSTRNAM
#      [CTRMID]MIDSTRNUM    = [F:EMIR]MIDSTRNUM
#      [CTRMID]MIDSUB       = [F:EMIR]MIDSUB
#      [CTRMID]MIDTWN       = [F:EMIR]MIDTWN
#      [CTRMID]MIDTYP       = [F:EMIR]MIDTYP
      Rewrite [CTRMID]
      Commit
    Endif
    [L]COMPTEUR +=1
    Gosub TRACE_LOG_PROCESSING
  Next

  Gosub TRACE_LOG

  Close Local File [CTRMID], [EMIR]
Else
  Call ECR_TRACE(THISPROC+" : Table EMPLOIDMID does not exist ",0) From GESECRAN
Endif
Return


#############################################################################################
# Africa
#############################################################################################
$TRANSFER_AFR
If filinfo(filpath("FIL","EMPLOCTRAFR","fde",LDOSSIER),0)>0 & filinfo(filpath("FIL","EMPLOIDAFR","fde",LDOSSIER),0)>0
  If clalev ([F:CTRAFR]) = 0 : Local File =LDOSSIER+".EMPLOCTRAFR" [CTRAFR] : Endif  #Destination
  If clalev ([F:EAFR]) = 0   : Local File =LDOSSIER+".EMPLOIDAFR" [EAFR]  : Endif  #Source
  Raz [L]COMPTEUR

  For[EAFR]
    Filter [F:CTRAFR] Where REFNUM=[F:EAFR]REFNUM Order By CTRDAT Desc

    Trbegin [CTRAFR]
    Readlock [CTRAFR] First
    If fstat
      Gosub TRACE_LOG
      Rollback
    Else
      [CTRAFR] = [F:EAFR]
#      [CTRAFR]AFRCNTCDE  = [F:EAFR]AFRCNTCDE
#      [CTRAFR]AFRCOR     = [F:EAFR]AFRCOR
#      [CTRAFR]AFRCPX     = [F:EAFR]AFRCPX
#      [CTRAFR]AFRPOSCDE  = [F:EAFR]AFRPOSCDE
#      [CTRAFR]AFRPOSNUM  = [F:EAFR]AFRPOSNUM
#      [CTRAFR]AFRPRI     = [F:EAFR]AFRPRI
#      [CTRAFR]AFRPRV     = [F:EAFR]AFRPRV
#      [CTRAFR]AFRSTA     = [F:EAFR]AFRSTA
#      [CTRAFR]AFRSTRNAM  = [F:EAFR]AFRSTRNAM
#      [CTRAFR]AFRSTRNUM  = [F:EAFR]AFRSTRNUM
#      [CTRAFR]AFRSUB     = [F:EAFR]AFRSUB
#      [CTRAFR]AFRTRDAUZ  = [F:EAFR]AFRTRDAUZ
#      [CTRAFR]AFRTWN     = [F:EAFR]AFRTWN
#      [CTRAFR]AFRTYP     = [F:EAFR]AFRTYP
#      [CTRAFR]AFRVIG     = [F:EAFR]AFRVIG
      Rewrite [CTRAFR]
      Commit
    Endif
    [L]COMPTEUR +=1
    Gosub TRACE_LOG_PROCESSING
  Next

  Gosub TRACE_LOG

  Close Local File [CTRAFR], [EAFR]
Else
  Call ECR_TRACE(THISPROC+" : Table EMPLOIDAFR does not exist ",0) From GESECRAN
Endif
Return



#############################################################################################
# Logging
#############################################################################################
$TRACE_LOG_PROCESSING
  Call ECR_TRACE(THISPROC+" : " +num$(COMPTEUR)+" : Processing record: "+REFNUM,0) From GESECRAN
Return

$TRACE_LOG
If fstat Then
  Call ECR_TRACE(THISPROC+" : " +num$(COMPTEUR)+" Failed to process records "+LDOSSIER+", fstat:"+num$(fstat),-1) From GESECRAN
Else
  Call ECR_TRACE(THISPROC+" : " +num$(COMPTEUR)+" records processed in folder "+LDOSSIER,0) From GESECRAN
Endif
Return

$PERIOD_DATA_MIGRATION
If filinfo(filpath("FIL","WTEMPPERIOD","fde",LDOSSIER),0)>0
  If clalev([WTPER])=0  : Local File =LDOSSIER+".WTEMPPERIOD" [WTPER]  : Endif
  If clalev([HRPEOH])=0 : Local File =LDOSSIER+".HRPEOHEA"   [HRPEOH] : Endif
  If clalev([HRPEOD])=0 : Local File =LDOSSIER+".HRPEODET"   [HRPEOD] : Endif

  Local Integer PERIODROWS : PERIODROWS = 0:
  Call ECR_TRACE("EMHRMAJ90_EMPCTR: Copying data from WTEMPPERIOD to HRPEOD and HRPEOH",0) From GESECRAN

  Filter [WTPER]
  For [F:WTPER]
    [HRPEOH]CPY = ""
    [HRPEOH]FCY = [F:WTPER]FCY
    [HRPEOH]LEG = GDOSLEG
    [HRPEOH]PERYEA = [F:WTPER]YEA
    [HRPEOH]DES = 'MIG'
    [HRPEOH]PERCOD = num$([F:WTPER]YEA) + num$([F:WTPER]FCY) + num$([F:WTPER]LIG)
    Write [HRPEOH]
    If !fstat
      Call FSTA('HRPEOH') From GLOCK : WOK = 0
    Endif
    If WOK <> 0
      [HRPEOD]PERNUM = [F:WTPER]LIG
      [HRPEOD]PERCOD = num$([F:WTPER]YEA) + num$([F:WTPER]FCY) + num$([F:WTPER]LIG)
      [HRPEOD]PERYEA = [F:WTPER]YEA
      [HRPEOD]PYRDAT = [F:WTPER]PYRDAT
      [HRPEOD]STA = [F:WTPER]STA
      [HRPEOD]PERSTR = [F:WTPER]PERSTR
      [HRPEOD]PEREND = [F:WTPER]PEREND
      [HRPEOD]NUMWEK = [F:WTPER]NUMWEK
      [HRPEOD]YEAWEK = [F:WTPER]YEAWEK
      [HRPEOD]EXPNUM = [F:WTPER]EXPNUM
      Write [HRPEOD]
      PERIODROWS += 1
    Endif
  Next

  Call ECR_TRACE("EMHRMAJ90_EMPCTR: Number of rows in WTEMPPERIOD to HRPEOD and HRPEOH - " - num$(PERIODROWS),0) From GESECRAN

  Close Local File [F:HRPEOH], [F:HRPEOD], [F:WTPER]
Else
  Call ECR_TRACE("EMHRMAJ90_EMPCTR: Table WTEMPPERIOD does not exist",0) From GESECRAN
Endif

Return


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_EMPCTR(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_EMPCTR(APPLI)
End

