#<AdxTL>@(#)11.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : [M:CSAT]    = [M:SAT1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUN])  = 0 : Local File TABUNIT    [TUN]  : Endif
If clalev([F:STJ])  = 0 : Local File STOJOU     [STJ]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER  [ITM1] : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT [ITF1] : Endif
If clalev([F:ITV1]) = 0 : Local File ITMMVT     [ITV1] : Endif
If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif
If clalev([F:STL1]) = 0 : Local File STOLOT     [STL1] : Endif
If clalev([F:STE])  = 0 : Local File STOPAR     [STE]  : Endif
If clalev([F:STC])  = 0 : Local File STOLOC     [STC]  : Endif
If clalev([F:ITG])  = 0 : Local File ITMCATEG   [ITG]  : Endif
#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K, L
Local Integer WOK
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSAT"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SAT1]FLG = 0
[M:SAT1]    = [M:CSAT]
Return
############################################################
$AP_MAGNETO
[M:SAT1]FLG = 0
Return
############################################################
$SETBOUT
If [M:SAT1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(7)  = [M:SAT2]STOFCY(nolign-1)
      PARAM(8)  = [M:SAT2]ITMREF(nolign-1)
      PARAM(9)  = [M:SAT2]IPTDAT(nolign-1)
      PARAM(10) = num$([M:SAT2]MVTSEQ(nolign-1))
      PARAM(11) = num$([M:SAT2]MVTIND(nolign-1))
      REPONSE = GSTAFIN
      If [M:SAT1]SELFLG = 9
        Gosub LOA_MSKSTO
      Endif
    Endif
Endcase
Return
############################################################
$LOA_MSKSTO
Local Char    WFCY : WFCY = PARAM(7)
Local Char    WITM : WITM = PARAM(8)
Local Date    WDAT : WDAT = PARAM(9)
Local Decimal WSEQ : WSEQ = val(PARAM(10))
Local Decimal WIND : WIND = val(PARAM(11))
Read [STJ]STJ0=WFCY;1;WITM;WDAT;WSEQ;WIND
If fstat = 0 & dim([M:STO]YPCU) > 0
  If [M:STO]NBLIG2 > 0
    Effzo [M:STO]30
    Raz [M:STO]NBLIG2
    Raz [M:STO]LOTEXI
  Endif
  Effzo [M:STO]25
  [M:STO]YPCU(0)         = "" : # Pour supprimer le filtre sur unité
  [M:STO]YQTYPCU(0)      = 0  : # Pour supprimer le filtre sur quantité
  [M:STO]YQTYPCUSEL(0)   = 0  : # Pour supprimer le filtre sur quantité
  [M:STO]YSTA(0)         = [F:STJ]STA
  [M:STO]YLOC(0)         = [F:STJ]LOC
  [M:STO]YPCUSTUCOE(0)   = [F:STJ]PCUSTUCOE
  [M:STO]YQTYSTU(0)      = ([F:STJ]QTYSTU*-1)
  [M:STO]YDAT(0)         = WDAT
  [M:STO]YSEQ(0)         = WSEQ
  [M:STO]NBLIG1          = 1
  If dim([M:STO]LOT) > 0
     [M:STO]LOT          = [F:STJ]LOT
  Endif
  [M:STO]VCRTYP          = [F:STJ]VCRTYP
  [M:STO]VCRNUM          = [F:STJ]VCRNUM
  [M:STO]VCRLIN          = [F:STJ]VCRLIN
  [M:STO]VCRTYPWAI       = [F:STJ]VCRTYP
  [M:STO]VCRNUMWAI       = [F:STJ]VCRNUM
  [M:STO]VCRLINWAI       = [F:STJ]VCRLIN
  [M:STO]VCRTYPORI       = [F:STJ]VCRTYPORI
  [M:STO]VCRNUMORI       = [F:STJ]VCRNUMORI
  [M:STO]VCRLINORI       = [F:STJ]VCRLINORI
  [M:STO]MVTDES          = [F:STJ]MVTDES
  [M:STO]PJT             = [F:STJ]PJT
  [M:STO]BPRNUM          = [F:STJ]BPRNUM
  [M:STO]TRSTYPORI       = [F:STJ]TRSTYP
  For I=1 To GNBDIE
    [M:STO]CCE(I-1) = [F:STJ]CCE(I-1)
    [M:STO]DIE(I-1) = [F:STJ]DIE(I-1)
  Next I
  Affzo [M:STO]10
  Affzo [M:STO]YPCU(0)
  Affzo [M:STO]YQTYPCU(0)
  Affzo [M:STO]YSTA(0)
  Affzo [M:STO]YLOC(0)
  Affzo [M:STO]YPCUSTUCOE(0)
  Affzo [M:STO]YQTYSTU(0)
  Affzo [M:STO]LOT
Endif
Return
############################################################
$FERME
If clalev([F:STO1]) <> 0 : Filter [STO1] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SAT1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Read [ITM1]ITM0=PARAM(I)
        If !fstat
          [M:SAT1]ITMREFSTR = [F:ITM1]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Read [ITM1]ITM0=PARAM(I)
        If !fstat
          [M:SAT1]ITMREFEND = [F:ITM1]ITMREF
        Endif
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:SAT1]SELFLG = val(PARAM(I))
      Endif
    When 6 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSAT]) <> 0 & [M:CSAT]MEMO = "STD"  : # <MG> 26/04/00
  [M:SAT1] = [M:CSAT]                            : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
Return
############################################################
$LECTURE
If CHGPAG = 3
   CHGPAG = 1
Endif
If [M:SAT1]FLG = 2 & [M:SAT1]ITMREFSTR = "" & [M:SAT1]ITMREFEND = ""
  [M:SAT1]FLG = 0
  NBLU = 0
  Return
Else
  [M:SAT1]FLG = 0
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STJ]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SAT2]
    WLIG = 0
    For [STJ]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SAT1]FLG = 0
  [M:SAT1]FLG = 1
  Raz [M:SAT2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  If [M:SAT1]FCY <> ""
    Filter [STJ] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                Order By Key STJ0
  Else
    Filter [STJ] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                Order By Key STJ2
  Endif
  Raz [F:STJ]
Endif
Return
############################################################
$LOAD_FILTER
# Filtre code mis à jour
WFIL = "[F:STJ]UPDCOD=1"
# Filtre site
If [M:SAT1]FCY <> ""
  WFIL += "&[F:STJ]STOFCY=[M:SAT1]FCY"
Endif
# Filtre article
If [M:SAT1]ITMREFSTR <> "" | [M:SAT1]ITMREFEND <> ""
  If [M:SAT1]ITMREFSTR = [M:SAT1]ITMREFEND
    WFIL += "&[F:STJ]ITMREF=[M:SAT1]ITMREFSTR"
  Else
    WFIL += "&[F:STJ]ITMREF>=[M:SAT1]ITMREFSTR"
    WFIL += "&[F:STJ]ITMREF<=[M:SAT1]ITMREFEND"
  Endif
Endif
Return
############################################################
$LOA_LIGNE
[M:SAT2] = [F:STJ]

#--- calcul du no série de fin
If dim([M:SAT2]SERNUM) > 0
   If [M:SAT2]SERNUM(nolign-1) <> ""
      If abs([M:SAT2]QTYSTU(nolign-1)) = 1
         [M:SAT2]SERFIN(nolign-1) = [M:SAT2]SERNUM(nolign-1)
      Else Call PLUS_NB([M:SAT2]SERNUM(nolign-1),abs([M:SAT2]QTYSTU(nolign-1)),[M:SAT2]SERFIN(nolign-1),WOK) From STKLIB
      Endif
   Endif
Endif

#--- lecture de l'article
Read [ITM1]ITM0=[F:STJ]ITMREF
If fstat Raz [F:ITM1] Endif
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF1]STOFCY <> [F:STJ]STOFCY | [F:ITF1]ITMREF <> [F:STJ]ITMREF
   Read [ITF1]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF1]
   Endif
Endif


[M:SAT2]REGFLG(nolign-1)  = 1
#[M:SAT2]ITMDES1(nolign-1) = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:SAT2]ITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
If dim([M:SAT2]STOMGTCOD) > 0
  [M:SAT2]STOMGTCOD(nolign-1) = [F:ITF1]STOMGTCOD
  [M:SAT2]LOTMGTCOD(nolign-1) = [F:ITM1]LOTMGTCOD
Endif
# hcb 31169 deb
If dim([M:SAT2]SERMGTCOD) > 0
  [M:SAT2]SERMGTCOD(nolign-1) = [F:ITM1]SERMGTCOD
Endif
# hcb 31169 fin

#--- lecture du cumul article-site
Read [ITV1]ITV0=[F:STJ]ITMREF;[F:STJ]STOFCY
If fstat = 0
  [M:SAT2]PHYSTO(nolign-1)  = [F:ITV1]PHYSTO    + [F:ITV1]CTLSTO       + [F:ITV1]REJSTO
  [M:SAT2]PLFSTO(nolign-1)  = [F:ITV1]PLFPHYSTO + [F:ITV1]PLFCTLSTO    + [F:ITV1]PLFREJSTO
  [M:SAT2]BPRSTO(nolign-1)  = [F:ITV1]BPRPHYSTO + [F:ITV1]BPRCTLSTO    + [F:ITV1]BPRREJSTO
  [M:SAT2]SCOSTO(nolign-1)  = [F:ITV1]SCOPHYSTO + [F:ITV1]SCOCTLSTO    + [F:ITV1]SCOREJSTO
  [M:SAT2]ALLSTO(nolign-1)  = [F:ITV1]PHYALL    + [F:ITV1]CTLALL       + [F:ITV1]REJALL    +
&                             [F:ITV1]SCOPHYALL + [F:ITV1]SCOCTLALL    + [F:ITV1]SCOREJALL
  [M:SAT2]GLOALL(nolign-1)  = [F:ITV1]GLOALL
  [M:SAT2]GLOSHT(nolign-1)  = [F:ITV1]GLOSHT
  [M:SAT2]DETSHT(nolign-1)  = [F:ITV1]DETSHT
  [M:SAT2]TRFSTO(nolign-1)  = [F:ITV1]TRFSTO
  [M:SAT2]TRASTO(nolign-1)  = [F:ITV1]TRASTO
  [M:SAT2]ORDSTO(nolign-1)  = [F:ITV1]ORDSTO
  [M:SAT2]SALSTO(nolign-1)  = [F:ITV1]SALSTO
  [M:SAT2]WAISTO(nolign-1)  = [F:ITV1]WAISTO
Endif

#--- calcul du stock dispo en statut A, Q, R
[M:SAT2]AVAFLG(nolign-1) = 1
Read [ITG]ITG1=[F:ITM1]TCLCOD;[F:ITV1]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM1]TCLCOD;""
   If fstat Raz [F:ITG] Endif
Endif

If [F:ITG]GLOAAAFLG = 2 WSTA   = 1 Else WSTA = 0 Endif
If [F:ITG]GLOQQQFLG = 2 WSTA  += 2 Endif
If [F:ITG]GLORRRFLG = 2 WSTA  += 4 Endif

If WSTA <> 0
   WDISPO=0
   #--- TS 106217
   #Call STODISPO("[F:ITV1]",[M:SAT2]STOFCY(nolign-1),[M:SAT2]ITMREF(nolign-1),"*","*",1,WSTA,"","","",WDISPO) From STKLIB
   Call STODISPO("[F:ITV1]",[M:SAT2]STOFCY(nolign-1),[M:SAT2]ITMREF(nolign-1),"*","*",1,WSTA,"","","","",WDISPO) From STKLIB
   #---
   If WDISPO > 0 [M:SAT2]AVAFLG(nolign-1) = 2 Endif
Endif
Return

############################################################
Subprog IB_NBLIG
Local Char WFILITM(250)
If !instr(1,GUSRAUZ,"I")
  GBOUT3 = ""
Else
  If [F:STE]STOFCY <> [M:SAT2]STOFCY(nolign-1)
    Read [STE]STE0=[M:SAT2]STOFCY(nolign-1);""
    If fstat
      GBOUT3 = ""
    Endif
  Endif
  If dim([M:SAT2]SERMGTCOD) > 0
    WFILITM = "[M:SAT2]SERMGTCOD(nolign-1)=1"
  Else
    WFILITM = "1=1"
  Endif
# Si activité LOT
  WFILITM += "&[M:SAT2]LOTMGTCOD(nolign-1)=1"
  If !evalue(WFILITM)
    GBOUT3 = ""
  Endif
Endif
#
If [M]ALLSTO(nolign-1) = 0
  GBOUT4 = ""
Endif
If [M]GLOALL(nolign-1) = 0
  GBOUT5 = ""
Endif
If [M]DETSHT(nolign-1) = 0
  GBOUT6 = ""
Endif
If !instr(1,GUSRAUZ,"H")
  GBOUT7 = ""
Endif
If [M:SAT2]ITMREF(nolign-1) <> [F:ITM]ITMREF
  Read [ITM]ITM0=[M:SAT2]ITMREF(nolign-1)
Endif
#MAE, bg 76683
If dim([M:SAT2]LOT) > 0
    #If [M:SAT2]LOT(nolign-1)="" or [F:ITM]TRKCOD<=1 Then
    If [M:SAT2]LOT(nolign-1)=""
      Raz GBOUT9
    Endif
Endif
If [F:ITM]TRKCOD<=1
      Raz GBOUT9
Endif
End
############################################################
Subprog AS_NBLIG
End
############################################################
Subprog AV_STOFCY(VALEUR)
Variable Char    VALEUR()
If [M]AVAFLG(nolign-1) = 2
  pcolor = GCOUL(3)
Else
  pcolor = GCOUL(0)
Endif
End
############################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SAT1]FLG = 0
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SAT1]FLG  = 0
[M]ITMREFEND = VALEUR
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SAT1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog AV_AVAFLG(VALEUR)
Variable Integer    VALEUR
If VALEUR = 2
  pcolor = GCOUL(3)
Else
  pcolor = GCOUL(0)
Endif
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SAT") From SUBGTC

End

