Subprog C_SERVEUR(VALEUR)
Variable Char    VALEUR()
End


##########################################################################
##########################################################################
## Etiquette ajoutée par le superviseur 12-05-2004 11:10:37 (CCORA)
##########################################################################
Subprog B2_NBLIG

#  Priorité +
Call CHGIMPREQ([M]SERVEUR,[M]NJOB(nolign-1),"+")
End

Subprog B3_NBLIG
#  Priorité -
Call CHGIMPREQ([M]SERVEUR,[M]NJOB(nolign-1),"-")
End

Subprog B4_NBLIG
#  Priorité Max
Call CHGIMPREQ([M]SERVEUR,[M]NJOB(nolign-1),"MAX")
End

Subprog B5_NBLIG
#  Priorité Min
Call CHGIMPREQ([M]SERVEUR,[M]NJOB(nolign-1),"MIN")
End

##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 12-05-2004 14:44:01 (CCORA)
##########################################################################
Subprog IB_NBLIG
#   En fonction du statut du job et des droits on autorise
#   la modification de priorité et la suppression

#  On ne peut supprimer qu'un job qui appartient à GUSER sauf si on a tous les droits

If [M]USER(nolign-1)<>GUSER and !instr(1,GUSRAUZ(1),"K")
  GBOUT1 = ""
Endif
#  On en peut pas changer la priorité d'un job actif
If [M]PHASE(nolign-1)=145 or [M]PHASE(nolign-1)=264 or [M]PHASE(nolign-1)=62
 GBOUT2 = ""
 GBOUT3 = ""
 GBOUT4 = ""
 GBOUT5 = ""
Endif

End


######################################################################################
