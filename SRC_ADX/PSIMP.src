#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"PSIMP","PSIMP","XWPSIMP") From GSAISIE
End

$ACTION
Case ACTION
  When "DEBUT"       : Gosub DEBUT
  When "BOUTON"      : Gosub BOUTON
Endcase
Return

$DEBUT
Raz [M]
Return

$BOUTON
Case BOUT
 When "A"   : # Actualiser
            Local Char SERVEUR(200) : SERVEUR=[M]SERVEUR 
            Gosub CHARGJOBSERV
Endcase
Return



$CHARGJOBSERV:
#                     Valeurs retournées par le GetUi au serveur d'impression
#
# NORDRE          : No d'ordre
# NJOB            : Numéro de job
# NPROC           : Numéro de processus
# NSECATT         : Nombre de secondes d'attente du process
# NSECEXE         : Nombre de secondes d'exécution du process
# STATUT          : Statut courant (127 Erreur, 128 OK)
# PHASE           : Phase de traitement 
#                           0 Réception demande
#                         116 Lecture paramètres
#                         170 Mise à jour du cache
#                         238 Traitement pièces jointes 
#                         144 Attente disponibilité du serveur d'impression,
#                         145 Prise en compte par le processus d'impression, 
#                         264 Prise en compte par le print engine crystal
#                          62 Impression terminée
#                         146 Erreur
# DEST            : Destination du rapport (70 Prévisu, 6 Imprimante, 103 Fichier, 68 Message)
# RAPPORT         : Nom de l'état
# DOSSIER         : Application cliente
# USER            : Code utilisateur X3
# CLIENT          : adresse IP Client
  Local Char RESULT(250)(1..100),SEP,SERVEUR1(200)
  Local Char CAR(30)
  Local Integer POS,DEB,I,J
  Local Integer NORDRE(1..100)
  Local Integer NJOB(1..100)
  Local Integer NPROC(1..100)
  Local Integer NSECATT(1..100)
  Local Integer NSECEXE(1..100)
  Local Integer STATUT(1..100)
  Local Integer PHASE(1..100)
  Local Integer DEST(1..100)
  Local Char    RAPPORT(15)(1..100)
  Local Char    DOSSIER(30)(1..100)
  Local Char    USER(15)(1..100) 
  Local Char    CLIENT(30)(1..100)
  Local Integer NJOBLIE(1..100)
  Effzo [M]20,30,40
  SERVEUR1=SERVEUR
  If SERVEUR="" : Goto AFFICHAGE : Endif
  If right$(SERVEUR,len(SERVEUR))<>"@" : SERVEUR1=SERVEUR+"@" : Endif
  Onerrgo AFFICHERR
  Getui RESULT=SERVEUR1 With "SrvImpDispJobs"
  SEP="|"
  For I=1 To 100
    If RESULT(I)="" : Break 1 : Endif
    DEB=0
    For J=1 To 12
      POS=instr(DEB+1,RESULT(I),SEP)
      If POS=0 : Break 1 : Endif
      CAR=mid$(RESULT(I),DEB+1,max(POS-DEB-1,0))
      DEB=POS
      Case J
        When 1  : NORDRE(I)=val(CAR)
        When 2  : NJOB(I)=val(CAR)
        When 3  : NPROC(I)=val(CAR)
        When 4  : NSECATT(I)=val(CAR)
        When 5  : NSECEXE(I)=val(CAR)
        When 6  : STATUT(I)=val(CAR)
        When 7  : PHASE(I)=val(CAR)
        When 8  : DEST(I)=val(CAR)
        When 9  : RAPPORT(I)=CAR
                  If instr(1,RAPPORT(I),".rpt")<>0 
                    RAPPORT(I)=left$(RAPPORT(I),len(RAPPORT(I))-4)
                  Endif
        When 10 : DOSSIER(I)=CAR
        When 11 : USER(I)=CAR
        When 12 : CLIENT(I)=CAR
        When 13 : NJOBLIE(I)=val(CAR)
      Endcase
    Next J
  Next I
  [M]NBLIG=max(I-1,0)

#  Tri à rajouter

#  Chargement du libellé de la phase   
  For I=0 To [M]NBLIG
    Case PHASE(I+1)
      When 0   : [M]LPHASE(I)=mess(1,21,1)-"1"
      When 116 : [M]LPHASE(I)=mess(1,21,1)-"2"
      When 170 : [M]LPHASE(I)=mess(1,21,1)-"3"
      When 238 : [M]LPHASE(I)=mess(1,21,1)-"4"
      When 144 : [M]LPHASE(I)=mess(1,21,1)-"5"
      When 145 : [M]LPHASE(I)=mess(2,21,1)-"1"
      When 264 : [M]LPHASE(I)=mess(2,21,1)-"2"
      When 146 : [M]LPHASE(I)=mess(7,21,1)
      When  62 : [M]LPHASE(I)=mess(3,21,1)
      When Default : [M]LPHASE(I)=""
    Endcase
  Next I

#  Paramètres de configuration du serveur
  Getui RESULT=SERVEUR1 With "SrvImpDispClients"
  For I=1 To 100
    If RESULT(I)="" : Break 1 : Endif
    DEB=0
    For J=1 To 2
      POS=instr(DEB+1,RESULT(I),SEP)
      If POS=0 : Break 1 : Endif
      CAR=mid$(RESULT(I),DEB+1,max(POS-DEB-1,0))
      DEB=POS
      Case J
        When 1  : [M]TSTAMP(I-1)=CAR
        When 2  : [M]CLICON(I-1)=CAR
      Endcase
    Next J
  Next I
  [M]NBCLI=max(I-1,0)
  [M]NBLIG1=max(I-1,0)

  Getui RESULT=SERVEUR1 With "SrvImpGetConfig"
  DEB=0
  For J=1 To 3
      POS=instr(DEB+1,RESULT,SEP)
      If POS=0 : Break 1 : Endif
      CAR=mid$(RESULT,DEB+1,max(POS-DEB-1,0))
      DEB=POS
      Case J
        When 1  : [M]PROC=val(CAR)
        When 2  : [M]PROCMAX=val(CAR)
        When 3  : [M]CONFIG=CAR
      Endcase
  Next J

#  Affichage
$AFFICHAGE
  For I=1 To [M]NBLIG
    [M]NORDRE(I-1)=NORDRE(I)
    [M]NJOB(I-1)=NJOB(I)
    [M]NJOBLIE(I-1)=NJOBLIE(I)
    [M]NPROC(I-1)=NPROC(I)
    [M]DEST(I-1)=DEST(I)
    [M]STATUT(I-1)=STATUT(I)
    [M]PHASE(I-1)=PHASE(I)
    [M]RAPPORT(I-1)=RAPPORT(I)
    [M]DOSSIER(I-1)=DOSSIER(I)
    [M]USER(I-1)=USER(I)
    [M]CLIENT(I-1)=CLIENT(I)
    [M]NSECATT(I-1)=NSECATT(I)
    [M]NSECEXE(I-1)=NSECEXE(I)
  Next I
  Affzo [M]
  Onerrgo
Return

$AFFICHERR
Resume



Subprog SUPIMPREQ(SERVEUR,NOJOB)
Value Char SERVEUR()
Value Integer NOJOB

Local Char RETOUR(250)(1..5)
Local Char SERVEUR1(GLONAMC)
Local Integer OK

Call AVERTIR(mess(123,105,1)-"Job "+num$(NOJOB),OK) From GESECRAN
If OK<>2 : End : Endif

SERVEUR1=SERVEUR
If right$(SERVEUR,len(SERVEUR))<>"@" : SERVEUR1=SERVEUR+"@" : Endif

Callui RETOUR=SERVEUR1    With "SRVAction=" + chr$(1) + "DeleteRptJob",
& "SRVRptJobId=" + chr$(1) + num$(NOJOB)
Gosub CHARGJOBSERV
zonsui = "SERVEUR"
Affzo
mkstat =2
End



Subprog CHGIMPREQ(SERVEUR,NOJOB,ORDERJ)
Value Char SERVEUR(),ORDERJ
Value Integer NOJOB

Local Char RETOUR(250)(1..5)
Local Char SERVEUR1(GLONAMC)

SERVEUR1=SERVEUR
If right$(SERVEUR,len(SERVEUR))<>"@" : SERVEUR1=SERVEUR+"@" : Endif

Callui RETOUR=SERVEUR1    With "SRVAction=" + chr$(1) + "ChangeOrderRptJob",
& "SRVRptJobId=" + chr$(1) + num$(NOJOB),
& "SRVRptJobOrder=" + chr$(1) + ORDERJ
Gosub CHARGJOBSERV
End



# Gestion du masque PSIMP

