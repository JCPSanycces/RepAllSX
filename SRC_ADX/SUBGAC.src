#<AdxTL>@(#)0.0.0.0 $Revision$ Comptes généraux
#   Modifications
#   CBO 2012.10.02 FQ67615 : low value asset
#   angre 2017.10.06 #X3-42495 DATEV compliancy check on account length

Raz GPILOBJ, GPILNAV
Raz GBIDC1, GBIDC2
Call OBJET("GAC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "EFFMASK"      : Gosub EFFMASK
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "FILTRE"       : Gosub FILTRE
 When "EXEBOUT"      : Gosub EXEBOUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD  ##YYFIN_X3-8276_FEB
 When "VERF_CHG"     : Gosub VERIF_CHG
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CHANGE"       : Gosub CHANGE
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "VERF_TABLE"   : Gosub VERF_TABLE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "ANNULE"       : Gosub ANNULE
 When "STYLE"        : Gosub STYLE
 When "FIN"          : Gosub FIN
 When "AP_VERF_ANU"  : Gosub AP_VERF_ANU
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "STATUT"       : Gosub STATUT
 When "FERME"        : Gosub FERME
Endcase
Return

######################################################################################
$OUVRE
Local Char    PYRAM(GLONGYM)(1..50), WPARAM(GLONADW)
Local Integer NBPYRAM : NBPYRAM = 0
Local Integer NUMBPA  : NUMBPA = 5
Local Char    BPA(GLONBPA)
Local Integer SAVCONS
Local Char    CNSCPTC3(GLONCPY), CNSNATC3(GLONCPY)
Local Integer CNSCPTI1, CNSNATI1

Global Char   GWCOA(GLONCOA)

If clalev([F:GYM])  = 0 : Local File GACCPYM    [GYM]  : Endif
If clalev([F:COA])  = 0 : Local File GCOA       [COA]  : Endif
If clalev([F:COA2]) = 0 : Local File GCOA       [COA2] : Endif
If clalev([F:GYP])  = 0 : Local File GACCPYMPRT [GYP]  : Endif
If clalev([F:GYK])  = 0 : Local File GACCPYMLIK [GYK]  : Endif
If clalev([F:GRY])  = 0 : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:GCD])  = 0 : Local File GACCDIM    [GCD]  : Endif
If clalev([F:GCF])  = 0 : Local File GACCDEF    [GCF]  : Endif
If clalev([F:PBS])  = 0 : Local File GAPARBSE   [PBS]  : Endif
If clalev([F:GAC2]) = 0 : Local File GACCOUNT   [GAC2] : Endif
If clalev([F:GAC3]) = 0 : Local File GACCOUNT   [GAC3] : Endif
If clalev([F:GAA])  = 0 : Local File GACCOUNTA  [GAA]  : Endif #YYFIN_X3-8276_FEB
If clalev([F:CPY])  = 0 : Local File COMPANY    [CPY]  : Endif
If clalev([F:CLS])  = 0 : Local File GACCCLS    [CLS]  : Endif
If clalev([F:CLS2]) = 0 : Local File GACCCLS    [CLS2] : Endif
If clalev([F:CAZ3]) = 0 : Local File CAAUZ      [CAZ3] : Endif
If clalev([F:TVT])  = 0 : Local File TABVAT     [TVT]  : Endif #YYFIN_X3-8276_FEB

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GGRPFCY)>0 : Local Char SAV_GGRPFCY(GLONADI) : SAV_GGRPFCY = GGRPFCY   : Endif

If !GIMPORT
 If CLE2=""
  Read [COA]COA0 First
  CLE2 = [F:COA]COA
 Endif
 GBIDC1 = CLE2
 GWCOA = GBIDC1

 Gosub SEARCHPARAMCONS
 Gosub SEARCHPARAMCONSANA
Endif
Return


$FIN
Gosub MAJ_LIENS
Return

$FERME
If dim(SAV_GCURLEG)>0  : GCURLEG  = SAV_GCURLEG  : Endif
If dim(SAV_GGRPFCY)>0  : GGRPFCY  = SAV_GGRPFCY  : Endif
If dim(GWCOA)>0 : Kill GWCOA : Endif
Return

######################################################################################
Subprog BPA(PLAN,COMPTE,BPA)
Value    Char PLAN
Value    Char COMPTE
Variable Char BPA()
BPA = format$("K:3X",PLAN)+COMPTE : # Attention, ça peut dépasser 15!!  type BPA à augmenter
End

######################################################################################
# Gestion des comptes de cumuls pour le Portugal (BY 09/02/2009)
# Vérification par rapport à la pyramide de référence
######################################################################################
$VERIF_CRE
Call VERIF_CUMUL([M:GAC0]COA,[M:GAC0]ACC,[M:GAC0]SAC,1,OK)

# Si Duplication d'un compte vérifier les règles de propagation
# pour le nouveau compte comme fait en C_DEFACC en parcourant tab cptes par défaut
If GREP="D"
 For I=0 To [M:GAC1]COANBR-1
  If [M:GAC1]DEFACC(I) <> ""
   Read [GAC3]GAC0 = [M:GAC1]OTHCOA(I);[M:GAC1]DEFACC(I)
   If !fstat
    Local Integer PARINV
    PARINV = find([M:GAC0]COA,[F:GAC3]OTHCOA(0..dim([F:GAC3]OTHCOA)-1))
    If PARINV > 0
     If !pat([M:GAC0]ACC,[F:GAC3]SCRACC(PARINV-1))
      # Crible incompatible avec le crible du Compte ...(...) pour le Plan de compte ...(...)
      GMESSAGE=(mess(123,102,1)-[M:GAC1]DEFACC(I)-"(plan "+[F:GAC3]COA+")"-mess(128,102,1)
&              -[F:GAC3]OTHCOA(PARINV-1) -"("+[F:GAC3]DEFACC(PARINV-1)+")")
     zonsui = "DEFACC"
     OK=0 : Break
     Endif
    Endif
   Endif
  Endif
Next
Endif

$VERIF_MOD
######################################################################################
##YYFIN_X3-8276_FEB (Control 6) Controls Authorisation/ Restriction Tax codes
######################################################################################
If dim([M:GAC2]TYPVATCTL)>0
If [M:GAC2]TYPVATCTL=2 and [M:GAC2]VAT(0)<>""
  Call LEC_COA([M:GAC0]COA) From CPTLEC
  If [F:COA]LEG<>""
   Call LEC_TVT_LEG([F:COA]LEG,[M:GAC2]VAT(0)) From CPTLEC
  Else
   Read [TVT]TVT0 = [M:GAC2]VAT(0)
  Endif
  If [F:TVT]VATTYP=1  #Tax type="VAT"
   If  (!find([M:GAC2]VAT(0),[M:GAC2]VATCTL(0..[M:GAC2]NBVAT-1)))
    #"The default tax code must be present in the authorized code table"
    GMESSAGE = mess(151,102,1)
    OK=0 : Return
   Endif
  Endif
Endif

If [M:GAC2]TYPVATCTL=3 and [M:GAC2]VAT(0)<>""
 If find([M:GAC2]VAT(0),[M:GAC2]VATCTL(0..[M:GAC2]NBVAT-1))
  #"The default tax code must not be present in the table of forbidden codes"
  GMESSAGE = mess(152,102,1)
  OK=0 : Return
 Endif
Endif

If  [M:GAC2]NBVAT=0 and [M:GAC2]TYPVATCTL>1
 If [M:GAC2]TYPVATCTL=2
 #===========
  #"At least one authorized tax code must be entered in the authorization table"
  GMESSAGE = mess(154,102,1)
   OK=0 : Return
 Else
   #===========
   #"At least one prohibited tax code must be entered in the Prohibited Table"
   GMESSAGE = mess(155,102,1)
   OK=0 : Return
  Endif
 Endif
 Endif

Return

$VERIF_CHG
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
Filter [GAC2] Where (COA<>SUPP or ACC<>OCODE)
Call VERIF_CUMUL(SUPP,NCODE,[F:GAC]SAC,1,OK)
Filter [GAC2]
Return

Subprog VERIF_CUMUL(PLAN,COMPTE,COLLEC,SAI,OK)
Value    Char    PLAN
Value    Char    COMPTE
Value    Integer SAI
Value    Integer COLLEC
Variable Integer OK
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
Local Char    PYRAM(GLONGYM) , GROUPE(GLONGRY)
Local Integer L , RANG , NIVEAU
Call LECTURE("COA",PLAN,"") From CONTOBJ
PYRAM  = [F:COA]PYRREF
OK     = 1
If PYRAM<>""

 # Vérif qu'il n'englobe pas un groupe

 For [GRY]GRY0(2) Where [F:GRY]PYM=PYRAM & left$([F:GRY]GRU,len(COMPTE))=COMPTE
  GMESSAGE = mess(38,113,1)-PYRAM-":"-mess(43,113,1)-[F:GRY]GRU : # Il existe le groupe
  OK = 0 : Break
 Next
 If !OK : End : Endif

 # Vérif des collectifs (idem v5)

 If COLLEC=2
  For L=len(COMPTE) To 1 Step-1
   Read [GAC2]GAC0 = PLAN;left$(COMPTE,L)
   If fstat=0 & [F:GAC2]SAC<>2
    GMESSAGE = mess(9,113,1)-[F:GAC2]ACC : # Il existe le compte
    OK = 0 : Break
   Endif
  Next L
  If !OK : End : Endif
  For [GAC2]GAC0 Where COA=PLAN & left$(ACC,len(COMPTE))=COMPTE
   GMESSAGE = mess(9,113,1)-[F:GAC2]ACC : # Il existe le compte
   OK = 0 : Break
  Next
  If !OK : End : Endif
 Else
  For L=len(COMPTE) To 1 Step -1
   Read [GAC2]GAC0 = PLAN;left$(COMPTE,L)
   If fstat=0
    If [F:GAC2]SAC=2
     GMESSAGE = mess(8,113,1)-[F:GAC2]ACC : # Il existe le collectif
     OK = 0 : Break
    Elsif SAI
     OK = 2 : Call AVERTIR(mess(9,113,1)-[F:GAC2]ACC,OK) From GESECRAN
     If OK<>2
      OK = 0 : Break
     Endif
    Endif
   Endif
  Next L
 Endif
 If !OK : End : Endif

 # Vérif d'un groupe de rattachement

 OK = 0
 For L=len(COMPTE)-1 To 1 Step -1
  Read [GRY]GRY0(2) = PYRAM;left$(COMPTE,L)
  If !fstat
   OK = 1
   GROUPE = [F:GRY]GRU
   NIVEAU = [F:GRY]LEV
   RANG   = [F:GRY]PRNROW
   Break
  Endif
 Next L
 If !OK
  GMESSAGE = mess(38,113,1)-PYRAM-":"-mess(44,113,1)-left$(COMPTE,2) : # Il n'existe pas de compte de cumul commençant par
  End
 Else
  If SAI : # (SAI=0 pour la création via CPTAUTO)
   K = find(PYRAM,[M:GAC5]PYM(0..[M:GAC5]NRPYR-1))
   If K=0
    [M:GAC5]NRPYR += 1
    K = [M:GAC5]NRPYR
   Endif
   [M:GAC5]PYM(K-1)    = PYRAM
   [M:GAC5]GRU(K-1)    = GROUPE
   [M:GAC5]LEV(K-1)    = NIVEAU
   [M:GAC5]PRNROW(K-1) = RANG
   [M:GAC5]FLGGES(K-1) = 1
   Affzo [GAC5]
  Endif
 Endif
Endif
End

Subprog SUP_CUMUL(PLAN,COMPTE)
Value Char PLAN
Value Char COMPTE
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
Local Char PYRAM(GLONGYM)
Call LECTURE("COA",PLAN,"") From CONTOBJ
PYRAM  = [F:COA]PYRREF
If PYRAM<>""
 Filter [GRY] Where PYM=PYRAM & ACC=COMPTE
 Read [GRY] First
 Filter [GRY]
 If fstat<=2
  If [F:GRY]LIN=1
   [F:GRY]ACC = ""
   Rewrite [GRY]
   If fstat
    GOK = 0 : Call FSTA("GRY") From GLOCK
   Endif
  Else
   Delete [GRY]
  Endif
 Endif
Endif
End

Subprog CRE_CUMUL(PLAN,COMPTE)
Value Char PLAN
Value Char COMPTE
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
Local Char PYRAM(GLONGYM)
Call LECTURE("COA",PLAN,"") From CONTOBJ
PYRAM  = [F:COA]PYRREF
If PYRAM<>""
 For L=len(COMPTE)-1 To 2 Step -1
  Filter [GRY] Where PYM=PYRAM & GRU=left$(COMPTE,L)
  Read [GRY]GRY0 First
  If fstat<=2
   If [F:GRY]ACC="" & [F:GRY]SBBGRU=""
    [F:GRY]ACC    = COMPTE
    Rewrite [GRY]
   Else
    Read [GRY]GRY0 Last
    [F:GRY]PYM    = PYRAM
    [F:GRY]GRU    = left$(COMPTE,L)
    [F:GRY]LIN   += 1
    [F:GRY]ACC    = COMPTE
    [F:GRY]SBBGRU = ""
    Write [GRY]
   Endif
   If fstat
    GOK=0 : Call FSTA("GRY") From GLOCK : Break
   Endif
   Break
  Endif
 Next L
 Filter [GRY]
Endif
End

######################################################################################
$CREATION


#X3-42495 DATEV Compliancy
Local Integer DATCOMP : DATCOMP = 0
Call CHECK_DATEV_COMP(DATCOMP)
If DATCOMP = 1 : Return : Endif
#X3-42495 DATEV Compliancy End

Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub ADDRBID
# En création, on ajoute le compte aux pyramides où il est référencé implicitement
Call CRECPT([F:GAC]COA,[F:GAC]ACC) From LIENPYRACC
If GOK<1 : Return : Endif
Gosub ADDGRUPYM
If GOK<1 : Return : Endif
Gosub PARAMINV
If GOK<1 : Return : Endif
# Update of GACCOUNTA table with VAT codes Authorized/Forbidden
 If dim([M:GAC2]TYPVATCTL)>0
Gosub MAJVATAUT #YYFIN_X3-8276_FEB
If GOK<1 : Return : Endif
Endif
Return

######################################################################################
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub ADDRBID
Gosub DELGRUPYM
If GOK<1 : Return : Endif
Gosub ADDGRUPYM
If GOK<1 : Return : Endif
Gosub PARAMINV
If GOK<1 : Return : Endif
# Update of GACCOUNTA table with VAT codes Authorized/Forbidden
If dim([M:GAC2]TYPVATCTL)>0
 Gosub MAJVATAUT #YYFIN_X3-8276_FEB
If GOK<1 : Return : Endif
Endif
Return

######################################################################################
$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCOUNT","DESTRA",CLECUR2,CLECUR1,"GACCOUNT","DESTRA",[M:GAC0]COA,[M:GAC0]ACC)  From ATEXTRA
 Call DUPTEXTRA("GACCOUNT","SHOTRA",CLECUR2,CLECUR1,"GACCOUNT","SHOTRA",[M:GAC0]COA,[M:GAC0]ACC)  From ATEXTRA
Endif
Call MAJTEXTRA([M:GAC0]DESTRA,"GACCOUNT","DESTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
Call MAJTEXTRA([M:GAC1]SHOTRA,"GACCOUNT","SHOTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
Return

######################################################################################
$SEARCHPARAMCONS
#--- Zoom vers la consultation compte
# Recherche d'un société en lien avec ce code plan CONSCPT... (cf fenêtre OGAC)
# Recherche d'un société qui a ce code plan (dans l'ordre) :
#        - sous le Référentiel Général Principal
#        - ... 1er Référentiel Général trouvé
Raz CNSCPTC3, CNSCPTI1
For I=1 To GLEDNBR
 If GLEDFLGGEN(I)=2 & GLEDCOA(I)=GBIDC1
  For J=1 To GGCMNBR
   If GLEDGEN(J)=GLED(I)
    Filter [CPY] Where ACM=GGCM(J)
     Read [CPY]First
      If !fstat
       CNSCPTC3 = [F:CPY]CPY
       CNSCPTI1 = GLEDTYPGEN(J)
       Break 2
      Endif
   Endif
  Next
 Endif
Next
If CNSCPTC3="" or CNSCPTI1=0
 For I=1 To GLEDNBR
  If GLEDFLGGEN(I)=2 & GLEDCOA(I)=GBIDC1
   For J=1 To GGCMNBR
    For K=1 To 10
     If evalue("GLED"+num$(K)+"("+num$(J)+")")=GLED(I)
      Filter [CPY] Where ACM=GGCM(J)
      Read [CPY]First
       If !fstat
        CNSCPTC3 = [F:CPY]CPY
        CNSCPTI1 = K
        Break 3
       Endif
     Endif
    Next
   Next
  Endif
 Next
Endif
Filter [CPY]
Return


######################################################################################
$SEARCHPARAMCONSANA
#--- Zoom vers la consultation compte
# Recherche d'un société en lien avec ce code plan CONSNAT... (cf fenêtre OGAC)
# Recherche d'un société qui a ce code plan (dans l'ordre) :
#        - sous le Référentiel Analytique Principal
#        - ... 1er Référentiel Analytique trouvé
Raz CNSNATC3, CNSNATI1
If CNSNATC3="" or CNSNATI1=0
 For I=1 To GLEDNBR
  If GLEDFLGANA(I)=2 & GLEDCOA(I)=GBIDC1
   For J=1 To GGCMNBR
    If GLEDANA(J)=GLED(I)
     Filter [CPY] Where ACM=GGCM(J)
     Read [CPY]First
     If !fstat
      CNSNATC3 = [F:CPY]CPY
      CNSNATI1 = GLEDTYPANA(J)
      Break 2
     Endif
    Endif
   Next
  Endif
 Next
Endif
If CNSNATC3="" or CNSNATI1=0
 For I=1 To GLEDNBR
  If GLEDFLGANA(I)=2 & GLEDCOA(I)=GBIDC1
   For J=1 To GGCMNBR
    For K=1 To 10
     If evalue("GLED"+num$(K)+"("+num$(J)+")")=GLED(I)
      Filter [CPY] Where ACM=GGCM(J)
      Read [CPY]First
      If !fstat
       CNSNATC3 = [F:CPY]CPY
       CNSNATI1 = K
       Break 3
      Endif
     Endif
    Next
   Next
  Endif
 Next
Endif
Filter [CPY]
Return

######################################################################################
$ADDRBID
Default Mask [BPAG]
Call BPA([M:GAC0]COA,[M:GAC0]ACC,BPA)
Call CREBPA(NUMBPA,BPA) From TRTBPA
If GOK < 1 : Return : Endif
#
If clalev([M:BIDG])
 Default Mask [BIDG]
 Call CRERIB(NUMBPA,BPA) From TRTBPA
 If GOK < 1 : Return : Endif
Endif
Gosub DEFAUT
Return

######################################################################################
$DELGRUPYM
For [GRY] Where ACC=[M:GAC0]ACC
 Read [GYM]GYM0 = [F:GRY]PYM
 If !fstat & [F:GYM]COA=[M:GAC0]COA
  OK = 0
  For I=0 To [M:GAC5]NRPYR-1
   If [M:GAC5]FLGGES(I)=0 & [M:GAC5]PYM(I)=[F:GYM]PYM & [M:GAC5]GRU(I)=[F:GRY]GRU
    OK = 1
   Endif
  Next
  If !OK
   If [F:GRY]LIN=1
    [F:GRY]ACC = ""
    Rewrite [GRY]
    If fstat
     GOK = 0 : Call FSTA("GRY") From GLOCK : Break
    Endif
   Else
    Delete [GRY]
    If fstat=1
     GOK = -1 : GLOCK = "$GACCGRUPYM"-[F:GRY]PYM-[F:GRY]GRU : Break
    Endif
   Endif
   If !find([F:GYM]PYM,PYRAM(1..NBPYRAM))
    NBPYRAM += 1
    PYRAM(NBPYRAM) = [F:GYM]PYM
   Endif
  Endif
 Endif
Next
Return

######################################################################################
$ADDGRUPYM
For I=0 To [M:GAC5]NRPYR-1
 If [M:GAC5]FLGGES(I)=1
  Filter [GRY] Where PYM=[M:GAC5]PYM(I) & GRU=[M:GAC5]GRU(I)
  OK = 0
  For [GRY]GRY0
   If pat([M:GAC0]ACC,[F:GRY]ACC)<>0
    OK = 1
   Endif
  Next
  If !OK
   Read [GRY]GRY0 First
   If [F:GRY]ACC="" & [F:GRY]SBBGRU=""
    [F:GRY]ACC    = [M:GAC0]ACC
    Rewrite [GRY]
    If fstat
     GOK=0 : Call FSTA("GRY") From GLOCK : Break
    Endif
   Else
    Read [GRY]GRY0 Last
    If fstat<=2
     [F:GRY]PYM    = [M:GAC5]PYM(I)
     [F:GRY]GRU    = [M:GAC5]GRU(I)
     [F:GRY]LIN   += 1
     [F:GRY]ACC    = [M:GAC0]ACC
     [F:GRY]SBBGRU = ""
     Write [GRY]
     If fstat
      GOK=0 : Call FSTA("GRY") From GLOCK : Break
     Endif
    Endif
   Endif
   If !find([F:GRY]PYM,PYRAM(1..NBPYRAM))
    NBPYRAM += 1
    PYRAM(NBPYRAM) = [F:GRY]PYM
   Endif
  Endif
  Filter [GRY]
 Endif
Next I
Return

######################################################################################
$PARAMINV
Local Integer I,K
For I=0 To [M:GAC1]COANBR-1
 # The line of the default accounts array has been modified if the line is different in the invisible array.
 # The default account of the other COA's account is updated if the line has been modified or if it's a new line
 K = find([M:GAC1]OTHCOA(I),[M:GAC1]OTHCOAINV)
 If !K | [M:GAC1]DEFACC(I)<>[M:GAC1]DEFACCINV(K-1)
&      | [M:GAC1]SCRACC(I)<>[M:GAC1]SCRACCINV(K-1)
&      | [M:GAC1]OBYIPT(I)<>[M:GAC1]OBYIPTINV(K-1)
  Read [GAC3]GAC0 = [M:GAC1]OTHCOA(I);[M:GAC1]DEFACC(I)
  If !fstat
   Local Integer PARINV
   PARINV = find([M:GAC0]COA,[F:GAC3]OTHCOA(0..dim([F:GAC3]OTHCOA)-1))
   If PARINV <> 0
    If [F:GAC3]DEFACC(PARINV-1) = ""
     [F:GAC3]DEFACC(PARINV-1)   = [M:GAC0]ACC
     [F:GAC3]SCRACC(PARINV-1)   = "*"
     If [F:GAC3]DEFACC(PARINV-1) <> ""
      [F:GAC3]OBYIPT(PARINV-1) = 2
     Elsif [F:GAC3]OBYIPT(PARINV-1) = 0
      [F:GAC3]OBYIPT(PARINV-1) = 1
     Endif
     Rewrite[GAC3]
     If fstat
      GOK=0 : Call FSTA("GAC") From GLOCK : Break
     Endif
    Endif
   Else
    Local Integer J
    J = [F:GAC3]COANBR + 1
    [F:GAC3]OTHCOA(J-1) = [M:GAC0]COA
    [F:GAC3]DEFACC(J-1) = [M:GAC0]ACC
    [F:GAC3]SCRACC(J-1) = "*"
    [F:GAC3]COANBR      = J
    If [F:GAC3]DEFACC(J-1) <> ""
     [F:GAC3]OBYIPT(J-1) = 2
    Else
     [F:GAC3]OBYIPT(J-1) = 1
    Endif
    Rewrite[GAC3]
    If fstat
      GOK=0 : Call FSTA("GAC") From GLOCK : Break
    Endif
   Endif
  Endif
 Endif
Next I
Return
######################################################################################
#YYFIN_X3-8276_FEB
# Update of GACCOUNTA table with VAT codes Authorized/Forbidden
$MAJVATAUT
Local Integer I,K

#If the tax code control is deactivated (TYPVATCTL changed for 2 or 3 to 1) :
# - the grid of authorized / restricted tax code is RTZ and
# - the corresponding records deleted from table GACCOUNTA

If dim([M:GAC2]TYPVATCTL)<0 : Return : Endif

Read [GAA]GAA0 = [M:GAC0]COA;[M:GAC0]ACC
If !fstat
  Gosub MAJVATCTL
  If [M:GAC2]TYPVATCTL > 1
   Rewrite[GAA]
   If fstat
     GOK=0 : Call FSTA("GAA") From GLOCK : Return
   Endif
  Else
   Delete [GAA]
  Endif
Else
  If [M:GAC2]TYPVATCTL > 1
   [F:GAA]= [F:GAC]
   Gosub MAJVATCTL
   Write[GAA]
   If fstat
    GOK=0 : Call FSTA("GAA") From GLOCK : Return
   Endif
  Endif
Endif
Return

$MAJVATCTL
Local Integer J

 For J=1  To dim([M:GAC2]VATCTL)
  If [M:GAC2]TYPVATCTL < 2
   [F:GAA]VATCTL(J-1) =  ""
  Else
    [F:GAA]VATCTL(J-1) =  [M:GAC2]VATCTL(J-1)
  Endif
 Next
Return

######################################################################################
$STYLE
Actzo [M:GAC5]PYM,GRU
For I=0 To [M:GAC5]NRPYR-1
 If [M:GAC5]FLGGES(I)=2
  Grizo [M:GAC5]PYM(I),GRU(I)
 Else
  Actzo [M:GAC5]PYM(I),GRU(I)
 Endif
Next I
Return

######################################################################################
$LIENS
Default Mask [BPAG]
Call LECTURE("COA",[M:GAC0]COA,"") From CONTOBJ
Call BPA([M:GAC0]COA,[M:GAC0]ACC,BPA)
Call CHARG_BPA(NUMBPA,BPA,[F:GAC]BPAADD) From TRTBPA
#
If clalev([M:BIDG])
Default Mask [BIDG]
Call CHARG_RIB(NUMBPA,BPA,[F:GAC]BIDNUM) From TRTBPA
Endif
Gosub DEFAUT
[M:BPAG]NUMBPA = NUMBPA
If [F:GAC]FCY<>""
 Call LIENFCYCPY([F:GAC]FCY,"[M:GAC1]LIBFCY") From CFYSUB
Endif
Call LECTEXTRA([M:GAC0]DESTRA,"GACCOUNT","DESTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
Call LECTEXTRA([M:GAC1]SHOTRA,"GACCOUNT","SHOTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
## Reporting Codes
If dim([M:GAC6]NBLIG6)>-1
 For I=0 To min(dim([F:GAC]RPTCODDEB)-1,dim([M:GAC6]RPTCODDEB)-1)
  If [F:GAC]RPTCODDEB(I)<>"" | [F:GAC]RPTCODCDT(I)<>""
   [M:GAC6]NBLIG6 = I+1
  Endif
 Next I
Endif
Gosub LOAD_NBLIG
If [M:GAC0]SAC=2
 [M:GAC3]NBLIG3 = len(mess(0,277,1))
Else
 [M:GAC3]NBLIG3 = 0
Endif
Gosub GENE_ANA


If [F:COA]TAXMGT=2
 If dim([M:GAC2]VAT)>0
 Call GRISE_VAT([F:GAC]FLGVAT)
 Call GRISE_VATCTL([F:GAC]FLGVAT)
 #YYFIN_X3-8276_FEB
 If [F:GAC]FLGVAT>=2
  Gosub CHARGE_VATCTL
 Endif
 #YYFIN_X3-8276_FEB
Endif
Endif

If [F:COA]GENTRK=2
 Call GRISE_DAS([F:GAC]DAS)
Endif
If [F:COA]ANATRK=2
 Actzo [M:GAC4]
 Call GRISE_BUD([F:GAC]BUDTRK)
 Call GRISE_UOM([F:GAC]FLGUOM)
Else
 Effzo [M:GAC4]
 Grizo [M:GAC4]
Endif

If [F:GAC]SAC<>2 or [F:COA]GENTRK<>2
 Effzo [M:GAC3]UPDBLC
 Grizo [M:GAC3]UPDBLC
Else
 Actzo [M:GAC3]UPDBLC
Endif

If dim([M:GAC6]CSLFLGFLW)>0
 If [F:GAC]CSLFLGFLW<=1
  Effzo [M:GAC6]FLODEB,FLOCDT
  Grizo [M:GAC6]FLODEB,FLOCDT
 Else
  Actzo [M:GAC6]FLODEB,FLOCDT
 Endif
Endif

If dim([M:GAC3]FLGABL)>0
 If [M:GAC3]FLGABL = 2
   Actzo [GAC3]FLGEXPCRE
   Actzo [GAC3]GACACN
 Else
   Grizo [GAC3]FLGEXPCRE
   Grizo [GAC3]GACACN
 Endif
Endif

Gosub LOAD_PYRGRU
[M:GAC0]LEGCLS = [F:COA]LEGCLS
Call LECTEXTRA([M:GAC1]CLSNAM,"GACCCLS","DESTRA",[F:COA]LEGCLS,[F:GAC]CLSCOD) From ATEXTRA
GCURLEG = [F:COA]LEG

# FQ67615
If dim([M:GAC3]FLGABL)>0
  If (GCURLEG = "GER" or GCURLEG = "AUT")
    Chgfmt [M:GAC3]LVATYP With "+LO:1X"
    If [M:GAC3]FLGABL = 2
      Actzo [GAC3]LVATYP
    Else
      Grizo [GAC3]LVATYP
    Endif
  Else
    Chgfmt [M:GAC3]LVATYP With "-LO:1X"
  Endif
Endif

If dim(GSAITAX)>0
 Call PARAM(GCURLEG,"SAITAX",WPARAM)
 GSAITAX = val(WPARAM)
Endif

For K=0 To [M:GAC1]COANBR-1
 [M:GAC1]DEFACCINV(K) = [M:GAC1]DEFACC(K)
 [M:GAC1]OBYIPTINV(K) = [M:GAC1]OBYIPT(K)
 [M:GAC1]SCRACCINV(K) = [M:GAC1]SCRACC(K)
 [M:GAC1]OTHCOAINV(K) = [M:GAC1]OTHCOA(K)
 [M:GAC1]NBRCOA +=1
Next

Call LEC_CLS([M:GAC0]LEGCLS,[M:GAC1]CLSCOD) From CPTLEC
Gosub LOAD_CNVACC
Gosub SAI_CNVACC

## The flag "Writing partner" is editable only if the "Partner Management" is  "Mandatory" or "Optional"
## If the account is a collective account ==> the "Writing partner"  is not editable
If dim([M:GAC6]CSLBPRACE)>0
 If [F:GAC]CSLFLGBPR<2 | [F:GAC]SAC=2
  Grizo [M:GAC6]CSLBPRACE
 Else
  Actzo [M:GAC6]CSLBPRACE
 Endif
Endif

#ISSUE 47123 - 2017-09-27 by MANOW
Call REFBANKPAYTRA(GCURLEG) From SUBGAC
#ISSUE END
Return

######################################################################################

# allowed fields (or not) about Conversion variance
$SAI_CNVACC

# Conversion variance
If [F:CLS]TYP = 1
 Actzo [M:GAC2]DIF
Else
 [M:GAC2]DIF = 1
 Grizo [M:GAC2]DIF
Endif
Actzo [M:GAC2]NBCNV, CNVACC(4), CNVACC(5), CNVACC(6), CNVACC(7), CNVACC(8), CNVACC(9)
If [M:GAC2]DIF > 1 and [F:CLS]TYP = 1
 Actzo [M:GAC2]TYPRATFLG
Else
 Effzo [M:GAC2]TYPRATFLG, CNVACC(0), CNVACC(1), CNVACC(2), CNVACC(3), ZCNVACC(0), ZCNVACC(1), ZCNVACC(2), ZCNVACC(3)
 Grizo [M:GAC2]TYPRATFLG, CNVACC(0), CNVACC(1), CNVACC(2), CNVACC(3)
Endif

If [M:GAC2]TYPRATFLG <> [V]CST_AYES
# Effzo [M:GAC2]TYPRAT
 [M:GAC2]TYPRAT= 0
 Affzo [M:GAC2]TYPRAT
 Grizo [M:GAC2]TYPRAT
Else
 Actzo [M:GAC2]TYPRAT
Endif
Affzo [M:GAC2]DIF, TYPRATFLG, TYPRAT

Return

# Load datas about Conversion variance
$LOAD_CNVACC

[M:GAC2]CNVACCDES(0) = mess(5, 2649, 1)
[M:GAC2]CNVACC(0) = [F:GAC]CNVACC1
[M:GAC2]CNVACCDES(1) = mess(6, 2649, 1)
[M:GAC2]CNVACC(1) = [F:GAC]CNVACC2
[M:GAC2]CNVACCDES(2) = mess(7, 2649, 1)
[M:GAC2]CNVACC(2) = [F:GAC]CNVACC3
[M:GAC2]CNVACCDES(3) = mess(8, 2649, 1)
[M:GAC2]CNVACC(3) = [F:GAC]CNVACC4
[M:GAC2]CNVACCDES(4) = mess(9, 2649, 1)
[M:GAC2]CNVACC(4) = [F:GAC]CNVACC5
[M:GAC2]CNVACCDES(5) = mess(10, 2649, 1)
[M:GAC2]CNVACC(5) = [F:GAC]CNVACC6
[M:GAC2]CNVACCDES(6) = mess(14, 2649, 1)
[M:GAC2]CNVACC(6) = [F:GAC]CNVACC7
[M:GAC2]CNVACCDES(7) = mess(15, 2649, 1)
[M:GAC2]CNVACC(7) = [F:GAC]CNVACC8
[M:GAC2]CNVACCDES(8) = mess(12, 2649, 1)
[M:GAC2]CNVACC(8) = [F:GAC]CNVACC9
[M:GAC2]CNVACCDES(9) = mess(13, 2649, 1)
[M:GAC2]CNVACC(9) = [F:GAC]CNVACC10
[M:GAC2]NBCNV = 10

Return

Subprog PARAM(LEG,PARAM,VALEUR)
Value Char    LEG
Value Char    PARAM
Variable Char VALEUR()

$PARAM_
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
VALEUR = ""
Read [ADP]ADP1 = PARAM
If fstat : End : Endif

Read [ADW]ADW0 = "*";LEG;PARAM
If fstat
 Read [ADW]ADW0 = "";"";PARAM
Endif
If !fstat
 VALEUR = [F:ADW]VALEUR
Else
 VALEUR = ""
Endif
End

######################################################################################
$GENE_ANA
Call LECTURE("COA",[M:GAC0]COA,"") From CONTOBJ
If [F:COA]GENTRK<>2
 If dim([M:GAC3]RITTYP)>0    : Grizo [GAC3]RITTYP    : Endif
 If dim([M:GAC3]DAS)>0       : Grizo [GAC3]DAS       : Endif
 If dim([M:GAC3]DASTYP)>0    : Grizo [GAC3]DASTYP    : Endif
#If dim([M:GAC3]FLGEXPCRE)>0 : Grizo [GAC3]FLGEXPCRE : Endif
 If dim([M:GAC3]GACACN)>0    : Grizo [GAC3]GACACN    : Endif
 # FQ67615
 If dim([M:GAC3]LVATYP)>0    : Grizo [GAC3]LVATYP    : Endif
 If dim([M:GAC3]FLGDEP)>0    : Grizo [M:GAC3]FLGDEP  : Endif
 Diszo [GAC2]DIF,DIFFLG
 Diszo [BPAG]
 Diszo [BIDG]
Else
 If dim([M:GAC3]RITTYP)>0    : Actzo [GAC3]RITTYP    : Endif
 If dim([M:GAC3]DAS)>0       : Actzo [GAC3]DAS       : Endif
 If dim([M:GAC3]DASTYP)>0    : Actzo [GAC3]DASTYP    : Endif
 If dim([M:GAC3]FLGABL)>0    : Actzo [GAC3]FLGABL    : Endif
 If dim([M:GAC3]FLGEXPCRE)>0 : Actzo [GAC3]FLGEXPCRE : Endif
 If dim([M:GAC3]GACACN)>0    : Actzo [GAC3]GACACN    : Endif
 # FQ67615
 If dim([M:GAC3]LVATYP)>0    : Actzo [GAC3]LVATYP    : Endif
 If dim([M:GAC3]FLGDEP)>0    : Actzo [GAC3]FLGDEP    : Endif
 Actzo [GAC2]DIF,DIFFLG
 Actzo [BPAG]
 Actzo [BIDG]
Endif

If func AFNC.ACTIV("BE281")
 If [F:COA]GENTRK=2
  Actzo [M:GAC3]FLG281
 Else
  Grizo [M:GAC3]FLG281
 Endif
 If [M:GAC3]FLG281=2
  Actzo [M:GAC3]TYP281
 Else
  Grizo [M:GAC3]TYP281
 Endif
Endif

If [F:COA]ANATRK<>2
 Diszo [GAC4]
 If dim([M:GAC3]GACPVS)>0    : Diszo [GAC3]GACPVS    : Endif
Else
 Actzo [GAC4]
 If dim([M:GAC3]GACPVS)>0    : Actzo [GAC3]GACPVS    : Endif
Endif

If [F:COA]AUX<>2
 [M:GAC0]SAC = 1
 Grizo [GAC0]SAC
Else
 Actzo [GAC0]SAC
Endif

If dim([M:GAC2]VAT)>0
 #==== Tax management="No"
 If [F:COA]TAXMGT<>2
  Grizo [GAC2]FLGVAT,VATIPT,VAT
  If dim([M:GAC2]ESDTRK)>0
   Grizo [M:GAC2]ESDTRK
  Endif
  #YYFIN_X3-8276_FEB
  If dim([M:GAC2]TYPVATCTL)>0
    Grizo [M:GAC2]TYPVATCTL
    Grizo [M:GAC2]45
   Endif   #/YYFIN_X3-8276_FEB
 Else
  #====   #Tax management="Yes"
  Actzo [GAC2]FLGVAT,VATIPT,VAT
  If dim([M:GAC2]ESDTRK)>0
   Actzo [M:GAC2]ESDTRK
  Endif
  #YYFIN_X3-8276_FEB
  If dim([M:GAC2]TYPVATCTL)>0
   Actzo [M:GAC2]TYPVATCTL
   Actzo [M:GAC2]45
  Endif   #/YYFIN_X3-8276_FEB
 Endif
Endif

Return

######################################################################################
$LOAD_PYRGRU
Raz [M:GAC5]
# charge  de la table Pramides - groupes
I = 0
Filter [GRY]
For [GRY] Where  pat([M:GAC0]ACC,[F:GRY]ACC)<>0
 Call LECTURE("GYM",[F:GRY]PYM,"") From CONTOBJ
 If [F:GYM]COA=[M:GAC0]COA
  [M:GAC5]PYM(I)     = [F:GRY]PYM
  [M:GAC5]GRU(I)     = [F:GRY]GRU
  [M:GAC5]LEV(I)     = [F:GRY]LEV
  [M:GAC5]PRNROW(I)  = [F:GRY]PRNROW
  [M:GAC5]FLGGES(I)  = 0
  If [M:GAC0]ACC<>[F:GRY]ACC
   [M:GAC5]FLGGES(I) = 2
   [M:GAC5]CRI(I)    = [F:GRY]ACC
  Endif
  I += 1
 Endif
Next
[M:GAC5]NRPYR = I
Return

######################################################################################
$DEFAUT
Call ISWINDOWOK(nomap,"OCPY") From INTRUTILB
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From WGOCPY
 Endif
Next MA
Return

######################################################################################
$RAZCRE
$RAZDUP
Gosub LOAD_NBLIG
Affzo [GAC3]NBLIG3,DESIG
If GIMPORT : [M:GAC0]COA = [F:GAC]COA : Endif
Gosub GENE_ANA
Raz [M:BPAG]
Actzo [M:GAC2]DIF, TYPRATFLG, NBCNV, CNVACC
Gosub LOAD_CNVACC
Affzo [M:GAC2]NBCNV, CNVACCDES, CNVACC

Return

######################################################################################
$INIMOD
$INICRE
I = find(2,[M:BPAG]BPAADDFLG(0..[M:BPAG]NBADR-1))
If I
 [F:GAC]BPAADD = [M:BPAG]CODADR(I-1)
Else
 [F:GAC]BPAADD = [M:BPAG]CODADR(0)
Endif
If clalev([M:BIDG])
 I = find (2,[M:BIDG]BIDNUMFLG (0..[M:BIDG]NBRIB -1))
 If I
  [F:GAC]BIDNUM = [M:BIDG]BIDNUM (I-1)
 Else
  [F:GAC]BIDNUM = [M:BIDG]BIDNUM(0)
 Endif
Endif
## Reporting Codes
If dim([M:GAC6]NBLIG6)>0
 For I=[M:GAC6]NBLIG6+1 To min(dim([F:GAC]RPTCODDEB)-1,dim([M:GAC6]RPTCODDEB)-1)
  Raz [F:GAC]RPTCODDEB(I-1) , [F:GAC]RPTCODCDT(I-1)
 Next I
Endif
If dim([F:GAC]DES)>0
 [F:GAC]DES = [M:GAC0]DESTRA
Endif

# Conversion variance
[F:GAC]CNVACC1 = [M:GAC2]CNVACC(0)
[F:GAC]CNVACC2 = [M:GAC2]CNVACC(1)
[F:GAC]CNVACC3 = [M:GAC2]CNVACC(2)
[F:GAC]CNVACC4 = [M:GAC2]CNVACC(3)
[F:GAC]CNVACC5 = [M:GAC2]CNVACC(4)
[F:GAC]CNVACC6 = [M:GAC2]CNVACC(5)
[F:GAC]CNVACC7 = [M:GAC2]CNVACC(6)
[F:GAC]CNVACC8 = [M:GAC2]CNVACC(7)
[F:GAC]CNVACC9 = [M:GAC2]CNVACC(8)
[F:GAC]CNVACC10 = [M:GAC2]CNVACC(9)

Return

######################################################################################
$CHANGE
If clalev([F:BPA])=0 : Local File BPADDRESS   [BPA] : Endif
Local Char OBPA(GLONBPA) , NBPA(GLONBPA)
Call BPA(SUPP,OCODE,OBPA)
Call BPA(SUPP,NCODE,NBPA)
Call CHGBPA(5,OBPA,NBPA) From TRTBPA
If clalev([M:BIDG])
 Call CHGRIB(5,OBPA,NBPA) From TRTBPA
Endif
Call SUP_CUMUL(SUPP,[L]OCODE)
Call CRE_CUMUL(SUPP,[L]NCODE)

If filinfo(filpath("FIL","GDIAACC","fde",0),0)>=0
 # Schéma de comptes
 If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
 If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
 Local Integer PLCP

 Filter [GDC] Where find([L]OCODE,ACC)<>0
 For [GDC]GDC0
  If [F:GDA]DIA<>[F:GDC]DIA
   Read [F:GDA]GDA0=[F:GDC]DIA
   If fstat : Raz [F:GDA] : Endif
  Endif
  For PLCP=1 To dim([F:GDC]ACC)
   If [F:GDA]COA(PLCP-1)=SUPP
    Readlock [GDC]GDC0 Curr
    If fstat=1
     GOK =- 1 : Call RSTA("GDC",OCODE) From GLOCK : Break 2
    Elsif fstat=0
     [F:GDC]ACC(PLCP-1)= NCODE
     Rewrite [GDC]
     If fstat
      GOK = 0 : Call FSTA("GDC") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Next
 Next
 Filter [GDC]
 If GOK<1 : Return : Endif
Endif

# Codes comptables
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:CCL])=0 : Local File GACCCODLIG [CCL] : Endif
Local Integer IND, I, J

For [CAC] Where [F:CAC]COA = SUPP & find([L]OCODE,[F:CAC]ACC(0..dim([F:CAC]ACC)-1))
 For IND=1 To dim([F:CAC]ACC)
  If [F:CCL]TYP<>[F:CAC]TYP or [F:CCL]NUMLIG<>IND
   Read [CCL]CCL0 = [F:CAC]TYP;IND
  Endif
  If [F:CCL]TYPCPT<>2
   Readlock [CAC]CAC0 Curr
   If fstat=1
    GOK =- 1 : Call RSTA("CAC",OCODE) From GLOCK : Break 2
   Elsif fstat=0
    J=0
    If [F:CAC]ACC(IND-1) = OCODE : [F:CAC]ACC(IND-1) = NCODE : J = 1 : Endif
    If J
     Rewrite [CAC]
     If fstat
      GOK = 0 : Call FSTA("CAC") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Endif
 Next
Next
If GOK<1 : Return : Endif
Return

######################################################################################
$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GACCOUNT","DESTRA",[M:GAC0]COA,[M:GAC0]ACC,[M:GAC0]COA,NCODE) From ATEXTRA
#Call CHGTEXTRA("GACCOUNT","SHOTRA",[M:GAC0]COA,[M:GAC0]ACC,[M:GAC0]COA,NCODE) From ATEXTRA
Call CHGTEXTRA("GACCOUNT","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("GACCOUNT","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
If !adxlog
 Trbegin [GAC]
  Call DELCPT(SUPP,OCODE) From LIENPYRACC
  Call DELCPT(SUPP,NCODE) From LIENPYRACC
  Call CRECPT(SUPP,NCODE) From LIENPYRACC
 Commit
Else
 Call DELCPT(SUPP,OCODE) From LIENPYRACC
 Call DELCPT(SUPP,NCODE) From LIENPYRACC
 Call CRECPT(SUPP,NCODE) From LIENPYRACC
Endif
Return

######################################################################################
$ANNULE
Local Char BPA(GLONBPA)
# Dév : simplification des cptes. Peut être transférer indépendemment.
If clalev([F:BPA])=0 : Local File BPADDRESS   [BPA] : Endif
Call BPA(SUPP,[L]CODE,BPA)
Call ANNBPA(5,BPA) From TRTBPA
If clalev([M:BIDG])
 Call ANNRIB(5,BPA) From TRTBPA
Endif
#Class[M] à éviter car $annule peut être appelé d'un utilitaire externe ANUCOD
#Call SUPTEXTRA("GACCOUNT","DESTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
#Call SUPTEXTRA("GACCOUNT","SHOTRA",[M:GAC0]COA,[M:GAC0]ACC) From ATEXTRA
Call SUPTEXTRA("GACCOUNT","DESTRA",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("GACCOUNT","SHOTRA",SUPP,[L]CODE) From ATEXTRA
Call SUP_CUMUL(SUPP,[L]CODE)
If !adxlog
 Trbegin [GAC]
 Call DELCPT(SUPP,[L]CODE) From LIENPYRACC
 Commit
Else
 Call DELCPT(SUPP,[L]CODE) From LIENPYRACC
Endif
Return

######################################################################################
$LOAD_NBLIG
[M:GAC3]NBLIG3 = len(mess(0,277,1))
For I=1 To [M:GAC3]NBLIG3
 [M:GAC3]DESIG(I-1) = mess(I,277,1)
Next I
Return

######################################################################################
$EFFMASK
If MA=0
 [M:GAC0]COA = GBIDC1
 Affzo [M:GAC0]COA
Endif
Return

######################################################################################
$FILTRE
If GFONCTION="GESGAC" & zoncou<>"DEFACC" & dim(CRITERE)>0
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:GAC]COA="'+GWCOA+'"'
Endif
Return

######################################################################################
$FILGAUCHE
FILGAUCHE = '[F:GAC]COA="'+GWCOA+'"'
Return

######################################################################################
$EXEBOUT
Case REP
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  VALBOUT = [M]COA
  PARBOUT(1) = "COA"
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  FLGEXE = 1
  GACTION = "SELOBJW"
  GCURLEG = ""
  Call S_TAB_CHAR(VALBOUT,PARBOUT,"SELOBJ","SELOBJ","") From GACTION

  If VALBOUT<>""
   Gosub MAJ_LIENS
   Gosub DEVERROU From GOBJET
   Effzo
   [M:GAC0]COA = VALBOUT
   Affzo [GAC0]COA
   GBIDC1 = [M:GAC0]COA
   GWCOA = GBIDC1
   Gosub REMPLIT From GOBJSUB
   Filter [GAC] Where COA=GBIDC1
   Read [GAC]GAC0 First
   Filter [GAC]
   If !fstat
    CLECUR  = 1
    CLECUR1 = [F:GAC]ACC
    CLECUR2 = GBIDC1
   Else
    CLECUR = 0
   Endif
   Gosub RELIT From GOBJSUB

  Gosub SEARCHPARAMCONS
  Gosub SEARCHPARAMCONSANA
  Call LECTURE("COA",[M:GAC0]COA,"") From CONTOBJ
  GCURLEG = [F:COA]LEG

#  Gosub GENE_ANA
  Endif
Endcase
Return

######################################################################################
$MAJ_LIENS
If GBIDC1<>"" & NBPYRAM>0
 Call TEMPON("V") From GESECRAN
 For I=1 To NBPYRAM
  Call PYRAMPRT(GBIDC1,PYRAM(I),nomap) From LIENPYRACC
  Call PYRAMLIK(GBIDC1,PYRAM(I),nomap) From LIENPYRACC
 Next I
 Call TEMPOFF From GESECRAN
 NBPYRAM = 0
Endif
Return

######################################################################################
$SEL_TABLE
Case TABLE
 When "GACSELSHO"
  If clalev([F:GAC2])=0 : Local File GACCOUNT [GAC2] : Endif
  Default File [GAC]

  CRITERE = 'ACCSHO<>"" & COA="'+[M:GAC0]COA+'"'
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "ACCSHO" : TIT(NBCOL) = mess(1,113,1)  : # Code d'appel
  NBCOL += 1 : COL(NBCOL) = "COA"    : TIT(NBCOL) = mess(36,113,1) : # Plan de compte
  NBCOL += 1 : COL(NBCOL) = "ACC"    : TIT(NBCOL) = mess(2,113,1)  : # Compte
  NBCOL += 1 : COL(NBCOL) = "DES"    : TIT(NBCOL) = mess(3,113,1)  : # Intitulé
  TIT(0) = mess(18,100,1)-mess(1,113,1) : # Sélection Code d'appel
 When "SELGRUGYM"
  OBJET = "GRC"
  CRITERE = 'PYM="'+[M:GAC5]PYM(nolign-1)+'" & LIN=1'
Endcase
Return

######################################################################################
$VERF_TABLE
Case TABLE
 When "GACSELSHO" : mkstat = 1
Endcase
Return

######################################################################################
$SETBOUT
CHMEN = ""
If GREP<>"" or TUNNEL or !instr(1,GUSRAUZ(1),"1")
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If CLECUR
 Local Integer OKACC
 Call LECACC([F:GAC]ACS,OKACC) From SUBACS
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Else
  If CNSCPTC3 <> "" and CNSCPTI1 > 0
   CHMEN += "2"
  Endif
  If CNSNATC3 <> "" and CNSNATI1 > 0
   CHMEN += "5"
  Endif
 Endif
Endif
If GREP=""
 CHMEN += "3"
 CHMEN += "4"
Endif
# FQ121669 - Pas de copie de plan possible si l'on n'a pas le droit de créer des comptes
If not instr(1,GUSRAUZ(1),"C")
  Call VIREBOUT(CHMEN,"3") From GOBJET
Endif
#TODO(R) make it depend on activity code DATEV (when available)
CHMEN += "6"
Return

######################################################################################
$AVANT_MODFIC
# Mise à jour de la devise des banques et caisses associées au compte
If [M:GAC1]CUR<>[F:GAC]CUR
 If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
 If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
 NB=0 : GOK=1 : MESSA=""
 Filter [BAN] Where COA=[M:GAC0]COA
 For [BAN] Where BANACC=[M:GAC0]ACC
  GCLE = [F:BAN]BAN
  Readlock [BAN]
  If fstat=1
   GOK = -1 : GLOCK="$BANK"-GCLE : Break
  Elsif fstat
   GOK = 0 : Call RSTA("BAN",GCLE) From GLOCK : Break
  Else
   # OLDCUR : ancienne devise
   If [M:GAC1]CUR=[F:BAN]OLDCUR
    [F:BAN]OLDCUR = ""
   Else
    [F:BAN]OLDCUR = [F:BAN]CUR
   Endif
   # CUR : devise de tenue
   If [M:GAC1]CUR<>""
    [F:BAN]CUR=[M:GAC1]CUR
   Else
    Read [CPY]CPY0 = [F:BAN]CPY
    If !fstat : [F:BAN]CUR=[F:CPY]ACCCUR : Endif
   Endif
   If [F:BAN]CUR=[F:BAN]OLDCUR
    [F:BAN]OLDCUR = ""
   Endif
   Rewrite [BAN]
   If fstat
    GOK=0 : Call FSTA("BAN") From GLOCK : Break
   Else
    NB+=1 : MESSA-=[F:BAN]BAN+":"-[F:BAN]CUR+","
   Endif
  Endif
 Next
 Filter [BAN]
 If GOK<1 : Return : Endif
 If NB
  # Les banques suivantes ont été modifiées :
  Call MESSAGE(mess(90,102,1)-left$(MESSA,len(MESSA)-1)) From GESECRAN
 Endif
Endif
Return

######################################################################################
$AP_VERF_ANU
Local Char TIT(80), DES(GLONAX3)
If [F:GAC]SAC=2
 If clalev([F:GSC])=0 :  Local File GRPSAC [GSC]  : Endif
 Call TITFNC("GESGSC",TIT) From CONTOBJ
 Filter [GSC] Where COA=[F:GAC]COA & SAC=[F:GAC]ACCSHO
 Read [GSC] First
 If !fstat
  Call LECTEXTRA([L]DES,"GRPSAC","DESTRA",[F:GAC]COA,[F:GSC]GRU) From ATEXTRA
  # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
  GMESSAGE = mess(101,126,1)-[F:GSC]GRU-"("+[L]DES+")"-mess(198,133,1)-"GRPSAC ("+TIT+")\"-mess(176,115,1)
  OKANU = 0
 Endif
 Filter [GSC]
Endif
If !OKANU : Return : Endif

If filinfo(filpath("FIL","GDIAACC","fde",0),0)>=0
 # Contrôle bloquant si le compte du plan de compte se trouve dans un schéma de comptes
 If clalev([F:GDA])=0 : Local File GDIAACC     [GDA] : Endif
 If clalev([F:GDC])=0 : Local File GDIAACCD    [GDC] : Endif
 Local Integer PLCP

 Filter [GDC] Where find([L]CODE,ACC)<>0
 For [GDC]GDC0
  PLCP = find([L]CODE,[F:GDC]ACC)
  If [F:GDA]DIA<>[F:GDC]DIA
   Read [F:GDA]GDA0=[F:GDC]DIA
   If fstat : Raz [F:GDA] : Endif
  Endif
  If [F:GDA]COA(PLCP-1)=SUPP
   OKANU = 0 : Break
  Endif
 Next
 Filter [GDC]
 If OKANU=0
  # Annulation xxx dans
  REFERR(1) = mess(46,150,1)-[L]CODE-SUPP-mess(198,133,1)-"GACCOUNT"
  # La fiche est utilisée par xx dans
  REFERR(2) = mess(101,126,1)-[F:GDC]DIA-mess(198,133,1)-"GDIAACCD"
  # Il faut d'abord supprimer ce lien
  REFERR(3) = mess(176,115,1)
  If !GSERVEUR & !GIMPORT
   Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
  Else
   GMESSAGE = REFERR(1)+"\"+REFERR(2)
   If !GIMPORT
    GMESSAGE+="\"+REFERR(3)
   Endif
  Endif
 Endif
Endif

# Contrôle codes comptables
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:CCL])=0 : Local File GACCCODLIG [CCL] : Endif
Local Integer IND

For [CAC] Where [F:CAC]COA = SUPP & find([L]CODE,[F:CAC]ACC(0..dim([F:CAC]ACC)-1))
 IND = find([L]CODE,[F:CAC]ACC(0..dim([F:CAC]ACC)-1))
 Read [CCL]CCL0 = [F:CAC]TYP;IND-1
 If [F:CCL]TYPCPT<>2
  OKANU = 0 : Break
 Endif
Next : # [CAC]
If OKANU=0
 # Annulation xxx dans
 REFERR(1) = mess(46,150,1)-[L]CODE-SUPP-mess(198,133,1)-"GACCOUNT"
 # La fiche est utilisée par xx dans
 REFERR(2) = mess(101,126,1)-[F:CAC]ACCCOD-"("+num$(mess([F:CAC]TYP,602,1))+")"-mess(198,133,1)-"GACCCODE"
 # Il faut d'abord supprimer ce lien
 REFERR(3) = mess(176,115,1)
 If !GSERVEUR & !GIMPORT
  Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
 Else
  GMESSAGE = REFERR(1)+"\"+REFERR(2)
  If !GIMPORT
   GMESSAGE+="\"+REFERR(3)
  Endif
 Endif
 Return
Endif

Close Local File [CAC], [CCL]
Return

######################################################################################
$AVANTBOUT
Case BOUT
 When "4"
  #--- Zoom vers le plan de compte
   SAVCONS = GCONSULT
   GCONSULT = 2
 When "2"
    GBIDC3 = CNSCPTC3
    GBIDI1 = CNSCPTI1
 When "5"
    GBIDC3 = CNSNATC3
    GBIDI1 = CNSNATI1
Endcase
Return

###########################################################################
$STATUT
Case BOUT
 When "4"
  GCONSULT = SAVCONS
Endcase
Return

#X3-42495 DATEV Compliancy
Subprog CHECK_DATEV_COMP(OK)
  Variable Integer OK
  Local Char GERDATDIS(2)
  Local Char GERDATLEN(2)
  If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
  If !func AFNC.ACTIV("DATEV") : End : Endif #if activity code DATEV is active
  Call PARAM("", "GERDATDIS", GERDATDIS) From ADOVAL
  If GERDATDIS = "2" : End : Endif # If DATEV complinacy check is active
  If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
  Read[F:COA]COA0 = [M:GAC0]COA
  If !fstat
    If [F:COA]LEG <> "GER" : End : Endif #If COA is linked to german legislation
  Endif
   Call PARAM("", "GERDATLEN", GERDATLEN) From ADOVAL
   If val(GERDATLEN) <> len([M:GAC0]ACC)
   #JOJAC - 2018-08-15 - X3-104356 - START
    #Call OUINON(mess(24,3653,1),OK) From GESECRAN
    Call OUINON(mess(24,3653,1)-mess(00205,00100,1),OK) From GESECRAN
    If OK <> 2
      GOK=0
    Endif
    #JOJAC - 2018-08-15 - X3-104356 - END
   Endif
End
#X3-42495 DATEV Compliancy end

######################################################################################
## écran GAC0
######################################################################################

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
Local Integer LENGTH
If VALEUR="" : End : Endif

If clalev([F:GAC2]) = 0 : Local File GACCOUNT   [GAC2] : Endif
Look [GAC2]GAC0 = [M]COA;VALEUR
If !fstat : End : Endif
# Fill left the account with zeroes according to the length account defined on chart account
# if on COA the accounts are fixed length
Call LECTURE("COA",[M:GAC0]COA,"") From CONTOBJ
If [F:COA]FXDLEN = 2
 LENGTH      = [F:COA]ACCLEN
 VALEUR      = left$(VALEUR+string$(LENGTH,"0"),LENGTH)
 [M:GAC0]ACC = VALEUR
 Affzo [M:GAC0]ACC
Endif

If vireblc(format$("K:"+[F:COA]ACCFMT,VALEUR),2)<>VALEUR
 ## Format du compte incorrect
 GMESSAGE = mess(4,113,1)
 mkstat = 2 : End
Endif

# Pas d'application des axes & comptes par défaut si la fiche est en duplication
# Comme la "classification" est une donnée obligatoire, si celle ci est initialisée, nous sommes en duplication.
If [M:GAC1]CLSCOD<>"" : End : Endif

# Application des axes et comptes par défaut
Look [GAC2]GAC0 = [M]COA;VALEUR
If fstat
 Call AXE_DEF(VALEUR)
 Call CPT_DEF(VALEUR)
 Call RPT_DEF(VALEUR)
 [M:GAC0]LEGCLS = [F:COA]LEGCLS
 Call CLASSE([M:GAC0]COA,VALEUR,[M:GAC1]CLSCOD) : Affzo [GAC1]CLSCOD
Endif
End

Subprog AXE_DEF(COMPTE)
Value Char COMPTE
If dim([M:GAC4]DACDIENBR)<=0 : End : Endif
Local Integer K
[M:GAC4]DACDIENBR = 0
For [GCD]GCD0 Where COA=[M:GAC0]COA
 If [F:GCD]ACCSTR="*" or left$(COMPTE,len([F:GCD]ACCSTR))=[F:GCD]ACCSTR
  K = find([F:GCD]DIE,[M:GAC4]DIE(0..[M:GAC4]DACDIENBR-1))
  If !K
   If [M:GAC4]DACDIENBR<dim([M:GAC4]DIE)
    [M:GAC4]DIE([M:GAC4]DACDIENBR)    = [F:GCD]DIE
    [M:GAC4]CCEDEF([M:GAC4]DACDIENBR) = [F:GCD]CCE
    [M:GAC4]DACDIENBR += 1
   Endif
  Elsif [M:GAC4]CCEDEF(K-1)=""
   [M:GAC4]CCEDEF(K-1) = [F:GCD]CCE
  Endif
 Endif
Next
Affzo [GAC4]DIE,ZDIE,CCEDEF
End

Subprog CPT_DEF(COMPTE)
Value Char COMPTE
Local Integer K
[M:GAC1]COANBR = 0
Raz [M:GAC1]OTHCOA, [M:GAC1]DEFACC, [M:GAC1]SCRACC, [M:GAC1]OBYIPT
For [GCF]GCF0 Where COAORI=[M:GAC0]COA
 If [F:GCF]COASTR="*" or left$(COMPTE,len([F:GCF]COASTR))=[F:GCF]COASTR
  K = find([F:GCF]COADEN,[M:GAC1]OTHCOA(0..[M:GAC1]COANBR-1))
  If !K
   If [M:GAC1]COANBR<dim([M:GAC1]OTHCOA)
    [M:GAC1]OTHCOA([M:GAC1]COANBR) = [F:GCF]COADEN
    [M:GAC1]DEFACC([M:GAC1]COANBR) = [F:GCF]ACC
    If [F:GCF]ACC<>""
     [M:GAC1]SCRACC([M:GAC1]COANBR) = [F:GCF]ACC
    Else
     [M:GAC1]SCRACC([M:GAC1]COANBR) = "*"
    Endif
    If [M:GAC1]DEFACC([M:GAC1]COANBR)<>""
     [M:GAC1]OBYIPT([M:GAC1]COANBR) = 2
    Else
     [M:GAC1]OBYIPT([M:GAC1]COANBR) = 1
    Endif
    [M:GAC1]COANBR += 1
   Endif
  Else
   If [M:GAC1]DEFACC(K-1)=""
    If [F:GCF]ACC<>""
     [M:GAC1]DEFACC(K-1) = [F:GCF]ACC
    Else
     [M:GAC1]DEFACC(K-1) = "*"
    Endif
    If [M:GAC1]DEFACC(K-1)<>""
     [M:GAC1]OBYIPT(K-1) = 2
    Else
     [M:GAC1]OBYIPT(K-1) = 1
    Endif
    If !pat([M:GAC1]DEFACC(K-1),[M:GAC1]SCRACC(K-1))
     [M:GAC1]SCRACC(K-1) = [F:GCF]ACC
    Endif
   Endif
  Endif
 Endif
Next
Affzo [GAC1]OTHCOA,DEFACC,SCRACC,OBYIPT
End

Subprog RPT_DEF(COMPTE)
Value Char COMPTE

[M:GAC6]NBLIG6 = 0
Raz [M:GAC6]RPTCODDEB,RPTCODCDT
For [PBS] Where COA=[M:GAC0]COA
 If left$(COMPTE,len([F:PBS]ACCSTR))=[F:PBS]ACCSTR
  If [F:PBS]NUMCOD<=dim([M:GAC6]RPTCODDEB)
   [M:GAC6]RPTCODDEB([F:PBS]NUMCOD-1) = [F:PBS]CODDEB
   [M:GAC6]RPTCODCDT([F:PBS]NUMCOD-1) = [F:PBS]CODCDT
   [M:GAC6]NBLIG6 = max([M:GAC6]NBLIG6,[F:PBS]NUMCOD)
  Endif
 Endif
Next
Affzo [GAC6]RPTCODDEB,RPTCODCDT
End

Subprog AS_SAC(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & GREP<>"D"
 mkstat = 2 : End
Endif
End

Subprog AM_SAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:GAC3]FRWCUR = 2
 Actzo [M:GAC3]UPDBLC

##YYFIN_105932_US3
## If the account is a collective account,
##  the flag "Writing partner" is not editable
If dim([M:GAC6]CSLBPRACE)>0
  [M:GAC6]CSLBPRACE=2
  Affzo [M:GAC6]CSLBPRACE
  Grizo [M:GAC6]CSLBPRACE
 Endif

 #DdM54465 : on invalide le masque pour forcer les contrôles
 If !GIMPORT
  If clalev([M:GAC1]) : Setmok [M:GAC1] With 0 : Endif
 Endif
 #FDdM

Else
 Raz [M:GAC1]ACCSHO

 ##YYFIN_105932_US3
 If dim([M:GAC6]CSLBPRACE)>0
  Actzo [M:GAC6]CSLBPRACE
 Endif
Endif
End

######################################################################################
## écran GAC1
######################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog AS_ACCSHO(VALEUR)
Variable Char    VALEUR()
If [M:GAC0]SAC = [V]CST_AYES
 If !find(GREP,"C","D") : mkstat=2 : End : Endif
Else
 If !find(GREP,"C","D","M","") : mkstat=2 : End : Endif
Endif
End

Subprog C_ACCSHO(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 Read [GAC2]GAC1 = [M:GAC0]COA;VALEUR
 If !fstat & [F:GAC2]ACC<>[M:GAC0]ACC
  GMESSAGE = mess(11,113,1) : # Code d'appel déjà existant
  mkstat = 2 : End
 Endif
Endif
If VALEUR="" & [M:GAC0]SAC=2
 GMESSAGE = mess(10,123,1) :# Zone obligatoire
 mkstat = 1 : End
Endif
If len(VALEUR)=1
 GMESSAGE = mess(12,113,1) : # La longueur du code d'appel\doit être supérieure à 1 caractère
 mkstat = 2 : End
Endif
If [M:GAC0]SAC = [V]CST_AYES and len(VALEUR) > 4
 GMESSAGE = mess(45,113,1) : # La longueur du code d'appel\ne doit pas dépasser 4 caractères
 mkstat = 2 : End
Endif

If [M:GAC0]SAC <> [V]CST_AYES and len(format$(GFMTACC, VALEUR)) < len(VALEUR)
 GMESSAGE = mess(46,113,1) : # La longueur du code d'appel\ne doit pas dépasser celle autoriséepour le compte.
 mkstat = 2 : End
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
If clalev([F:COA])=0 : Local File GCOA      [COA] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
Local Integer REPONSE
Local Integer ERRLEG
ERRLEG = 0
Call LECTURE("COA",[M:GAC0]COA,"") From CONTOBJ
Call GETTYPSOCSITGRP(VALEUR,REPONSE) From CPTDIV
Case REPONSE
 When 1
  ## Société
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  If [F:COA]LEG<>"" & [F:COA]LEG<>[F:CPY]LEG : ERRLEG = 1 : Endif
 When 2
  ## Site
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  If [F:COA]LEG<>"" & [F:COA]LEG<>[F:CPY]LEG : ERRLEG = 1 : Endif
Endcase
If ERRLEG
 GMESSAGE = mess(36,113,1)-":"-[M:GAC0]COA+"\"+mess(62,127,1)-":"-[F:COA]LEG
 mkstat = 2 : End
Endif
End

Subprog C_OTHCOA(VALEUR)
Variable Char    VALEUR()
If [M:GAC0]COA=VALEUR
 # Valeur incorrecte
 Call ERREUR(mess(83,123,1)) From GESECRAN
 mkstat=2 : End
Endif
Call UNICITE(VALEUR,[M:GAC1]OTHCOA(0..[M]COANBR-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog C_DEFACC(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL

Read [GAC3]GAC0 = [M:GAC1]OTHCOA(NOL);VALEUR
If fstat : End : Endif

#Compatibilité entre société et site
Call COMPAT([M:GAC1]FCY,[F:GAC3]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif

#Contrôle compte HBI + Paramétrage inverse
Read [COA2]COA0 = [M:GAC1]OTHCOA(NOL)
If !fstat
 If VALEUR<>""
  #Contrôle HBI
  Read [CLS] CLS0 = [M:GAC0]LEGCLS;[M:GAC1]CLSCOD
  Read [CLS2]CLS0 = [F:COA2]LEGCLS;[F:GAC3]CLSCOD
  If !fstat
   If ([F:CLS]TYP = 2 & [F:CLS2]TYP <> 2 ) | ([F:CLS]TYP <> 2 & [F:CLS2]TYP = 2 )
    # Compte OTHCOA DEFACC : classe incompatible avec COA ACC (Hors-Bilan)
    Call ERREUR(mess(45,102,1)-[M:GAC1]OTHCOA(NOL)-VALEUR-" : "-mess(147,102,1)-[M:GAC0]COA-[M:GAC0]ACC
&               -"("-mess(2,690,1)-")")From GESECRAN
    mkstat=2 : End
   Endif
  Endif
 Endif
 #Paramétrage Inverse
 Local Integer PARINV
 PARINV = find([M:GAC0]COA,[F:GAC3]OTHCOA(0..dim([F:GAC3]OTHCOA)-1))
 If PARINV > 0
  If !pat([M:GAC0]ACC,[F:GAC3]SCRACC(PARINV-1))
   # Crible incompatible avec le crible du Compte ...(...) pour le Plan de compte ...(...)
   Call ERREUR(mess(123,102,1)-VALEUR-"(plan "+[F:GAC3]COA+")"-mess(128,102,1)
&              -[F:GAC3]OTHCOA(PARINV-1) -"("+[F:GAC3]DEFACC(PARINV-1)+")") From GESECRAN
   mkstat=2 : End
  Endif
 Endif
 If [M:GAC1]AUZ<>"" & [F:GAC3]AUZ<>""
  Look [CAZ3]CAZ0 = 3 ; [M:GAC1]AUZ ; [F:GAC3]AUZ
  If !fstat
   # Interdit avec le compte
   Call ERREUR(mess(119,102,1)) From GESECRAN
   # Code interdiction incompatible
   mkstat=2 : End
  Endif
 Endif
Endif
End

Subprog AM_DEFACC(VALEUR)
Variable Char    VALEUR()
#Si un compte par défaut alors crible=compte par défaut
If VALEUR<>""
 [M]SCRACC(nolign-1) = VALEUR
Endif
End

Subprog AS_SCRACC(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# En création si compte par défaut vide alors crible est au minimun * et
# la VPD du crible est tjs *
# En Modification (ajout/insertion/Modification ligne) si crible vide alors VPD = *
If VALEUR="" & [M]DEFACC(NOL)=""
 VALEUR="*"
Endif
End

Subprog C_SCRACC(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = nolign-1
If [M:GAC1]DEFACC(I)<>"" & VALEUR<>"" & !pat([M:GAC1]DEFACC(I),VALEUR)
 Call ERREUR (mess(95,102,1)-[M:GAC1]DEFACC(I)) From GESECRAN
 # Crible incompatible avec le compte
 mkstat=2 : End
Endif
End

Subprog AS_OBYIPT(VALEUR)
Variable Integer VALEUR
Local Integer I
I = nolign-1
If [M:GAC1]DEFACC(I)<>""
 VALEUR = 2
 mkstat = 2 : End
Endif
End

Subprog D_CLSCOD(VALEUR)
Variable Char VALEUR
Call CLASSE([M:GAC0]COA,[M:GAC0]ACC,VALEUR)
End

Subprog C_CLSCOD(VALEUR)
Variable Char VALEUR
Local Integer NOL
Call LEC_CLS([M:GAC0]LEGCLS, VALEUR) From CPTLEC
If [F:CLS]TYP=3
 # Classe inutilisée
 GMESSAGE = mess(5,113,1)
 mkstat = 1 : End
Endif

#Contrôle compte HBI
For NOL=0 To [M:GAC1]COANBR-1
 If [M:GAC1]DEFACC(NOL)<>""
  Read [GAC3]GAC0 = [M:GAC1]OTHCOA(NOL);[M:GAC1]DEFACC(NOL)
  Read [COA2]COA0 = [M:GAC1]OTHCOA(NOL)
  Read [CLS2]CLS0 = [F:COA2]LEGCLS;[F:GAC3]CLSCOD
  If !fstat & ( ([F:CLS]TYP=2 & [F:CLS2]TYP<>2 ) | ([F:CLS]TYP<>2 & [F:CLS2]TYP=2 ) )
   # Compte OTHCOA DEFACC : classe incompatible avec COA ACC (Hors-Bilan)
   Call ERREUR(mess(45,102,1)-[M:GAC1]OTHCOA(NOL)-[M:GAC1]DEFACC(NOL)-" : "-mess(147,102,1)
&              -[M:GAC0]COA-[M:GAC0]ACC-"("-mess(2,690,1)-")")From GESECRAN
   mkstat=2 : End
  Endif
 Endif
Next

 Gosub SAI_CNVACC

End

Subprog CLASSE(PLAN,COMPTE,CLASSE)
Value    Char    PLAN
Value    Char    COMPTE
Variable Char    CLASSE
Local Integer I , J
Call LECTURE("COA",PLAN,"") From CONTOBJ
CLASSE = ""
For I=len(COMPTE) To 1 Step -1
 J = find(left$(COMPTE,I),[F:COA]PFX(0..[F:COA]PFXNBR-1))
 If J
  CLASSE = [F:COA]CLSCOD(J-1)
  Break
 Endif
Next
End

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
If filinfo(filpath("FIL","BANK","fde",0),0)>=0
 If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
 NB = 0 : MESSA = ""
 Filter [BAN] Where COA=[M:GAC0]COA
  For [BAN]BAN0 Where BANACC=[M:GAC0]ACC
   NB += 1 : MESSA -= [F:BAN]BAN+","
  Next
 Filter [BAN]
  If NB
   # La devise des banques (ou caisses) suivantes sera modifiée :
   Call MESSAGE(mess(13,113,1)-left$(MESSA,len(MESSA)-1)) From GESECRAN
  Endif
Endif
End

######################################################################################
## Etiquettes écran GAC2
######################################################################################

Subprog C_FLGVAT(VALEUR)
Variable Integer  VALEUR
 Call GRISE_VAT(VALEUR)
 Call GRISE_VATCTL(VALEUR)
End

Subprog GRISE_VAT(VALEUR)
Value Integer VALEUR
Local Integer I
If dim([M:GAC2]VAT)>0
 If VALEUR<2
  [M:GAC2]VATIPT = 0
  Effzo [M:GAC2]VAT
  Grizo [M:GAC2]VATIPT,VAT
 Else
  Actzo [M:GAC2]VATIPT,VAT
 Endif
Endif
## <DES>
If dim([M:GAC2]ESDTRK)>0
 If VALEUR = 2
  Actzo [GAC2]ESDTRK
 Else
  [GAC2]ESDTRK=0
  Effzo [GAC2]ESDTRK
  Grizo [GAC2]ESDTRK
 Endif
Endif
## <Fin DES>

End

Subprog GRISE_VATCTL(VALEUR)
Value Integer VALEUR

If dim([M:GAC2]TYPVATCTL)>0
 If VALEUR<2 # Non Soumis ou Soumis
  [M:GAC2]TYPVATCTL = 1
  Affzo [M:GAC2]TYPVATCTL
  Grizo [M:GAC2]TYPVATCTL
  Effzo [M:GAC2]45
  Grizo [M:GAC2]45
 Else
  Actzo [M:GAC2]TYPVATCTL
  Actzo [M:GAC2]45
 Endif
Endif
End

#YYFIN_X3-8276_FEB
$CHARGE_VATCTL

If dim([M:GAC2]TYPVATCTL)>0
 Raz [M:GAC2]NBVAT
 If [F:GAC]TYPVATCTL>1
  Read[F:GAA]GAA0= [F:GAC]COA;[F:GAC]ACC
  If fstat=0
   For I=0 To dim([F:GAA]VATCTL)-1
    If [F:GAA]VATCTL(I)<>""
     [M:GAC2]VATCTL(I) = [F:GAA]VATCTL(I)
     [M:GAC2]NBVAT +=1
    Endif
   Next
  Endif
  Affzo [M:GAC2]45
 Endif
Endif
Return
#YYFIN_X3-8276_FEB End

Subprog AS_VAT(VALEUR)
Variable Char     VALEUR
If [M:GAC2]FLGVAT<2 : mkstat = 1 : End : Endif
End

##YYFIN_X3-8276_FEB (Control 6)
Subprog AM_VAT(VALEUR)
Variable Char    VALEUR()
Local Integer I_VAT

If VALEUR<>"" and indice=0
 Call LEC_COA([M:GAC0]COA) From CPTLEC
 If [F:COA]LEG<>""
  Call LEC_TVT_LEG([F:COA]LEG,VALEUR) From CPTLEC
 Else
  Read [TVT]TVT0 = VALEUR
 Endif
 If [M:GAC2]TYPVATCTL=3
  I_VAT= (find(VALEUR,[M:GAC2]VATCTL(0..dim([M:GAC2]VATCTL)-1)))
  If I_VAT>0 and I_VAT<=[M:GAC2]NBVAT
   # The default tax code must not be present in the table of forbidden tax codes"
   #-- ==> Deletion of the line
   Call SUPP([M:GAC2]VATCTL(I_VAT-1))
  Endif
 Else
  # Adding the default tax code into the authorized tax code table
  If ([F:TVT]VATTYP=1) and ([M:GAC2]NBVAT < dim([M:GAC2]VATCTL)-1) and
&    [M:GAC2]TYPVATCTL=2  & (!find(VALEUR,[M:GAC2]VATCTL(0..dim([M:GAC2]VATCTL)-1)))
   [M:GAC2]VATCTL([M:GAC2]NBVAT)=VALEUR
   [M:GAC2]NBVAT +=1
   Affzo [M:GAC2]VATCTL(NBVAT-1),ZVATCTL(NBVAT-1)
   #Affzo [M:GAC2]NBVAT
   Affzo [M:GAC2]45
  Endif
 Endif
Endif

End

##YYFIN_X3-8276_FEB (Control 6)
Subprog SUPP(DELVATCTL)
Value Char DELVATCTL()
Local Integer NOLI

For NOLI=[M:GAC2]NBVAT To 0 Step-1
 If find(DELVATCTL,[M:GAC2]VATCTL(NOLI))
  Dela NOLI, 1  VATCTL, ZVATCTL
 Endif
Next
[M:GAC2]NBVAT-=1
Affzo [M:GAC2]45
End

Subprog C_VAT(VALEUR)
Variable Char     VALEUR
If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
If clalev([F:COA])=0 : Local File GCOA   [COA] : Endif

If VALEUR<>""
 Call LEC_COA([M:GAC0]COA) From CPTLEC
 If [F:COA]LEG<>""
  Call LEC_TVT_LEG([F:COA]LEG,VALEUR) From CPTLEC
 Else
  Read [TVT]TVT0 = VALEUR
 Endif
 If indice>0 & [F:TVT]VATTYP=1
  GMESSAGE = mess(23,119,1) : # Taxe de type TVA
  mkstat = 2 : End
 Endif
Endif

If indice=2
 If dim(GSAITAX)>0 & GSAITAX=2   # Code taxe obligatoire au niveau du compte (GSAITAX=2)
  If [M]VAT(0)="" & [M]VAT(1)="" & VALEUR=""
   GMESSAGE = mess(43,102,1) : # Il faut au moins un code TVA
   mkstat = 2 : End
  Endif
 Endif
Endif
If VALEUR<>""
 nolign = indice+1
 Call UNICITE(VALEUR,[M]VAT) From OBJDIV
 If mkstat : End : Endif
Endif
End

Subprog AS_VATIPT(VALEUR)
Variable Integer  VALEUR
If [M]FLGVAT<2 : mkstat=1 : End : Endif
End

## <DES>
Subprog D_ESDTRK(VALEUR)
Variable Integer VALEUR
## Initialisation à "Oui" ssi :
## - le compte de TVA est de type collectée (VATIPT=1, 2 ou 8)
## - le code taxe par défaut est lié à un régime CEE
If [M]FLGVAT<>2 : VALEUR = 1 : End : Endif

If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif
If clalev([F:COA])=0 : Local File GCOA      [COA] : Endif
Local Char REGIME(GLONADI)

If find([M]VATIPT,1,2,8)
 Call LEC_COA([M:GAC0]COA) From CPTLEC
 If [F:COA]LEG<>""
  Call LEC_TVT_LEG([F:COA]LEG,[M]VAT(0)) From CPTLEC
 Else
  Read [TVT]TVT0 = [M]VAT(0)
 Endif
 If !fstat
  REGIME = [F:TVT]VATVAC
  If REGIME<>""
   Call LEC_TVB(GCURLEG,REGIME) From CPTLEC
   If !fstat & [F:TVB]ENAFLG=2 & [F:TVB]REGVAC=4
    VALEUR = 2
   Endif
  Endif
 Endif
Endif
If VALEUR = 0 : VALEUR = 1 : Endif
End
## <Fin DES>

##############################
#YYFIN_X3-8276_FEB
Subprog AM_TYPVATCTL(VALEUR)
Variable Integer VALEUR

If VALEUR<2
 Effzo [M:GAC2]NBVAT, VATCTL
 Grizo [M:GAC2]NBVAT
Else
 Effzo [M:GAC2]NBVAT, VATCTL
 Actzo [M:GAC2]NBVAT
Endif

If VALEUR=2  #"authorization"
 If [M:GAC2]VAT(0)<>""
  Call LEC_COA([M:GAC0]COA) From CPTLEC
  If [F:COA]LEG<>""
   Call LEC_TVT_LEG([F:COA]LEG,[M:GAC2]VAT(0)) From CPTLEC
  Else
   Read [TVT]TVT0 = [M:GAC2]VAT(0)
  Endif
  If [F:TVT]VATTYP = 1
   [M:GAC2]VATCTL(0)= [M:GAC2]VAT(0)
   [M:GAC2]NBVAT=1
   Affzo [M:GAC2]VATCTL(0), ZVATCTL(0)
  Endif
 Endif
Endif

End
##############################
#YYFIN_X3-8276_FEB
Subprog AS_NBVAT

 If dim([M:GAC2]TYPVATCTL)>0
 If [M:GAC2]FLGVAT<2 or [M:GAC2]TYPVATCTL<2
   [M:GAC2]NBVAT = 0 : mkstat=2 : End
 Endif
 Endif
End
##############################
#YYFIN_X3-8276_FEB
Subprog C_NBVAT

If [M:GAC2]TYPVATCTL<>2 : End : Endif

# --> Control if deletion line
If status = 65
 NOL=nolign-1
 If [M:GAC2]VAT(0)<>"" and [M:GAC2]VATCTL(NOL)=[M:GAC2]VAT(0)
  # Unable to delete the default tax code in the table
  GMESSAGE = mess(1,115,1)-":"-mess(151,102,1) : # Can not be deleted
  mkstat=2 : End
 Endif
Endif

## --> Control if modification of a line
#If status = 75
# NOL=nolign-1
# If [M:GAC2]VATCTL(NOL)=[M:GAC2]VAT(0)
#  # Unable to modify the default tax code in the table
#  GMESSAGE = mess(9,123,1)-":"-mess(151,102,1) : # Can not be modified
#  mkstat=2 : End
# Endif
#Endif

If status = 68 | status = 83
 For NOL=nolign-1 To nolign1-1
  If [M:GAC2]VAT(0)<>"" and [M:GAC2]VATCTL(NOL)=[M:GAC2]VAT(0)
    GMESSAGE = mess(1,115,1)-":"-mess(151,102,1) : # Can not be deleted
    mkstat=2 :   Break : Endif
 Next NOL
 If mkstat : End :  Endif
Endif

End
##############################
#YYFIN_X3-8276_FEB
Subprog AS_VATCTL(VALEUR)
Variable Char    VALEUR()
If [M:GAC2]TYPVATCTL<2 or [M:GAC2]FLGVAT<2
 mkstat = 2 :  End
Endif
End
##############################
#YYFIN_X3-8276_FEB
Subprog C_VATCTL(VALEUR)
Variable Char     VALEUR
 #===========
 # Control 3
 If  indice= 0 and VALEUR=""
  If [M:GAC2]TYPVATCTL=2
   #"At least one authorized tax code must be entered in the authorization table"
   GMESSAGE = mess(154,102,1)
   mkstat=2 : End
  Endif
  If [M:GAC2]TYPVATCTL=2
   #===========
   # Control 3
   #"At least one prohibited tax code must be entered in the Prohibited Table"
   GMESSAGE = mess(155,102,1)
   mkstat=2 : End
  Endif
 Endif
#===========
#Control 6
If [M:GAC2]TYPVATCTL=3 and [M:GAC2]VAT(0)<>""
 If VALEUR= [M:GAC2]VAT(0)
  GERR=1
  #"The default tax code must not be present in the table of forbidden codes"
  GMESSAGE = mess(152,102,1)
  mkstat=2 : End
 Endif
Endif
#===========
# Unicite
If VALEUR<>""
 nolign = indice+1
 Call UNICITE(VALEUR,[M:GAC2]VATCTL(0..[M]NBVAT-1)) From OBJDIV
 If mkstat : End : Endif
Endif

End
##############################
#YYFIN_X3-8276_FEB
Subprog AM_VATCTL(VALEUR)
Variable Char    VALEUR()

# --> Control if modification of a line
If [M:GAC2]TYPVATCTL=2
 If (VALEUR <> [M:GAC2]VATCTL(nolign-1)) and  ([M:GAC2]VAT(0)<> "")  and
&              [M:GAC2]VATCTL(nolign-1) = [M:GAC2]VAT(0)
  # Unable to modify the default tax code in the table
  GMESSAGE = mess(9,123,1)-":"-mess(151,102,1) : # Can not be modified
  mkstat=2 : End
 Endif
Endif

End
#==============================
Subprog AS_SUBACC(VALEUR)
Variable Char    VALEUR()
End

Subprog C_SUBACC(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:GAC0]ACC
 GMESSAGE = mess(31,102,1) : # Compte incorrect
 mkstat = 2 : End
Elsif VALEUR<>""
 Read [GAC2]GAC0 = [M:GAC0]COA;VALEUR
 If fstat
  GMESSAGE = mess(31,102,1) : # Compte incorrect
  mkstat = 2 : End
 Endif
 Call COMPAT([M:GAC1]FCY,[F:GAC2]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
 If [F:GAC2]SAC<>2 : # Pour le collectif on fait le contrôle sur le tiers
  Filter [GAC2] Where SUBACC=VALEUR & ACC<>[M:GAC0]ACC & COA=[M:GAC0]COA
  Read [GAC2] First
  Filter [GAC2]
  If !fstat
   Call LECTEXTRA(GMESSAGE,"GACCOUNT","DESTRA",[M:GAC0]COA,[F:GAC2]ACC) From ATEXTRA
   GMESSAGE = mess(88,102,1)-"\"+[F:GAC2]ACC-GMESSAGE : # Compte abonné déjà défini
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_SUBBPR(VALEUR)
Variable Char    VALEUR()
If [M:GAC0]SAC=2 | [M:GAC2]SUBACC=""
 mkstat = 1 : End
Endif
Read [GAC2]GAC0 = [M:GAC0]COA;[M:GAC2]SUBACC
If fstat | [F:GAC2]SAC<>2 : # Normal
 mkstat = 1 : End
Endif
End

Subprog C_SUBBPR(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR<>""
 Call LECTURE("BPR",VALEUR,"") From CONTOBJ
 Read [GAC2]GAC0 = [M:GAC0]COA;[M:GAC2]SUBACC
 OK  = [F:BPR]BPCFLG=2 & [F:GAC2]AUZBPR(0)=2
 OK += [F:BPR]BPSFLG=2 & [F:GAC2]AUZBPR(1)=2
 OK += [F:BPR]BPTFLG=2 & [F:GAC2]AUZBPR(2)=2
 OK += [F:BPR]FCTFLG=2 & [F:GAC2]AUZBPR(3)=2
 OK += [F:BPR]REPFLG=2 & [F:GAC2]AUZBPR(4)=2
 OK += [F:BPR]BPRACC=2 & [F:GAC2]AUZBPR(5)=2
 If !OK
  GMESSAGE = mess(45,106,1) : # Tiers incompatible avec le collectif
  mkstat = 2 : End
 Endif
Else
 GMESSAGE = mess(10,123,1) :# Zone obligatoire
 mkstat = 2 : End
Endif
Filter [GAC2] Where SUBACC=[M:GAC2]SUBACC & SUBBPR=VALEUR & ACC<>[M:GAC0]ACC
Read [GAC2] First
Filter [GAC2]
If !fstat
 Call LECTEXTRA(GMESSAGE,"GACCOUNT","DESTRA",[M:GAC0]COA,[F:GAC2]ACC) From ATEXTRA
 GMESSAGE = mess(88,102,1)-"\"+[F:GAC2]ACC-GMESSAGE : # Compte abonné déjà défini
 mkstat = 2 : End
Endif
End

Subprog AS_DIFFLG(VALEUR)
Variable Integer VALEUR
Call LEC_CLS([M:GAC0]LEGCLS, [M:GAC1]CLSCOD) From CPTLEC
If [F:CLS]TYP=2
 VALEUR = 1
 mkstat = 2 : End
Endif
End

Subprog AS_DIF(VALEUR)
Variable Integer VALEUR
Call LEC_CLS([M:GAC0]LEGCLS, [M:GAC1]CLSCOD) From CPTLEC
If [F:CLS]TYP=2
 VALEUR = 1
 mkstat = 2 : End
Endif
End

Subprog AM_DIF(VALEUR)
Variable Integer VALEUR

If VALEUR > 1
 Actzo [M:GAC2]TYPRATFLG, NBCNV, CNVACC
Else
 Effzo [M:GAC2]TYPRATFLG, TYPRAT, CNVACC(0), CNVACC(1), CNVACC(2), CNVACC(3), ZCNVACC(0), ZCNVACC(1), ZCNVACC(2), ZCNVACC(3)
 Grizo [M:GAC2]TYPRATFLG, TYPRAT, CNVACC(0), CNVACC(1), CNVACC(2), CNVACC(3)
Endif

End

Subprog AS_NBLIG6
If [M:GAC6]NBLIG6=0
 Local Integer I , J
 For J=0 To dim([F:GAC]RPTCODDEB)-1
  For I=len([M:GAC0]ACC) To 1 Step -1
   Read [PBS]PBS0 = [M:GAC0]COA;J+1;left$([M:GAC0]ACC,I)
   If !fstat
    [M:GAC6]RPTCODDEB(J) = [F:PBS]CODDEB
    [M:GAC6]RPTCODCDT(J) = [F:PBS]CODCDT
    [M:GAC6]NBLIG6       = J+1
    Break
   Endif
  Next I
 Next J
 Affzo RPTCODDEB, RPTCODCDT
Endif
End

Subprog D_RPTCODDEB(VALEUR)
Variable Char    VALEUR()
Local    Integer  I, NOL
NOL = nolign-1
For I=len([M:GAC0]ACC) To 1 Step -1
 Read [PBS]PBS0 = [M:GAC0]COA;NOL+1;left$([M:GAC0]ACC,I)
 If !fstat
  VALEUR = [F:PBS]CODDEB
  [M:GAC6]RPTCODCDT(NOL) = [F:PBS]CODCDT
  Break
 Endif
Next I
End

Subprog D_RPTCODCDT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M:GAC6]RPTCODDEB(nolign-1)
Endif
End

Subprog C_CSLFLGFLW(VALEUR)
Variable Integer VALEUR
Call GRISE_CSL(VALEUR)
End

Subprog GRISE_CSL(VALEUR)
Value Integer VALEUR
Local Integer I
If dim([M:GAC6]CSLFLGFLW)>0
 If VALEUR<2
  Effzo [M:GAC6]FLODEB,FLOCDT
  Grizo [M:GAC6]FLODEB,FLOCDT
 Else
  Actzo [M:GAC6]FLODEB,FLOCDT
 Endif
Endif
End

Subprog C_FLODEB(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & dim([M:GAC6]CSLFLGFLW)>0 & [M:GAC6]CSLFLGFLW=3
 GMESSAGE = mess(10,123,1) :# Zone obligatoire
 mkstat = 2 : End
Endif
End

Subprog AS_CSLCDT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]CSLDEB
Endif
End

Subprog C_FLOCDT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & dim([M:GAC6]CSLFLGFLW)>0 & [M:GAC6]CSLFLGFLW=3
 GMESSAGE = mess(10,123,1) :# Zone obligatoire
 mkstat = 2 : End
Endif
End


## If the "Partner Management" is  "Mandatory" or "Optional", the flag "Writing partner" is editable
## If the account is a collective account ==> the "Partner management" is not editable
Subprog C_CSLFLGBPR(VALEUR)
Variable Integer VALEUR
If [M]SAC=2
 [M:GAC6]CSLBPRACE=2
 Grizo [M:GAC6]CSLBPRACE
Elsif VALEUR<2
 Effzo [M:GAC6]CSLBPRACE
 Grizo [M:GAC6]CSLBPRACE
Else
 Actzo [M:GAC6]CSLBPRACE
Endif
End

End

######################################################################################
## Etiquettes écran GAC3
######################################################################################
Subprog AS_DAS(VALEUR)
Variable Integer  VALEUR
Call LEC_CLS([M:GAC0]LEGCLS, [M:GAC1]CLSCOD) From CPTLEC
If [F:CLS]TYP=2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog C_DAS(VALEUR)
Variable Integer  VALEUR
Call GRISE_DAS(VALEUR)
End

Subprog GRISE_DAS(VALEUR)
Value Integer VALEUR
If dim([M:GAC3]DASTYP)>0
 If VALEUR <> 2
  [M:GAC3]DASTYP=0
  Affzo [M:GAC3]DASTYP
  Grizo [M:GAC3]DASTYP
 Else
  Actzo [M:GAC3]DASTYP
 Endif
Endif
End

Subprog AS_DASTYP(VALEUR)
Variable Integer  VALEUR
If [M:GAC3]DAS<>2 : mkstat=1 : End : Endif
End

Subprog AS_FLGABL(VALEUR)
Variable Integer    VALEUR()
If [M:GAC0]SAC=2 : VALEUR = 1 : mkstat = 2 : End : Endif
End

Subprog AM_FLGABL(VALEUR)
Variable Integer    VALEUR()
If VALEUR=2
 [M:GAC3]FLGEXPCRE = 2
 [M:GAC3]GACACN    = 1
 Actzo [M:GAC3]FLGEXPCRE, GACACN
# Affzo [M:GAC3]FLGEXPCRE, GACACN, LVATYP
 Affzo [M:GAC3]FLGEXPCRE, GACACN
Else
 [M:GAC3]FLGEXPCRE = 1
 [M:GAC3]GACACN    = 0
 Grizo [M:GAC3]FLGEXPCRE, GACACN
 Affzo [M:GAC3]FLGEXPCRE, GACACN
Endif

  # FQ67615 : ajout de lvatype
  If dim([M:GAC3]LVATYP) >= 0
    If VALEUR = G_OUI and (GCURLEG = "GER" or GCURLEG = "AUT")
      Actzo [M:GAC3]LVATYP
    Else
      Diszo [M:GAC3]LVATYP
      [M:GAC3]LVATYP = 1
    Endif
    Affzo [M:GAC3]LVATYP
  Endif
End

Subprog AS_FLGEXPCRE(VALEUR)
Variable Integer    VALEUR()
If [M:GAC0]SAC=2 : VALEUR = 1 : mkstat = 2 : End : Endif
End

Subprog AS_GACACN(VALEUR)
Variable Integer VALEUR
If [M]SAC=2
 VALEUR = 0 : mkstat = 2 : End
Endif
End

