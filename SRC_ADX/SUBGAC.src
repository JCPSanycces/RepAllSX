Subprog AM_FLG281(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:GAC3]TYP281
 Affzo [M:GAC3]TYP281
Else
 [M:GAC3]TYP281=0
 Grizo [M:GAC3]TYP281
 Affzo [M:GAC3]TYP281
Endif
