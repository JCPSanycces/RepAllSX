VALEUR = [M:GAC3]SNSDEF
End

Subprog AS_MTC(VALEUR)
Variable Integer  VALEUR
Call LEC_CLS([M:GAC0]LEGCLS, [M:GAC1]CLSCOD) From CPTLEC
If [F:CLS]TYP=2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog AS_LOSGAIGNR(VALEUR)
Variable Integer VALEUR
If [M]MTC<>2
 VALEUR = 1
 mkstat = 2 : End
Endif
End


Subprog AS_CEN(VALEUR)
Variable Integer  VALEUR
If [M:GAC0]SAC=2 : mkstat=1 : End : Endif
End

Subprog AS_FRWCUR(VALEUR)
Variable Integer VALEUR
Call LEC_CLS([M:GAC0]LEGCLS, [M:GAC1]CLSCOD) From CPTLEC
If [M:GAC1]CUR<>""
 VALEUR = 2 : mkstat = 2
Elsif [F:CLS]ERA=1
 VALEUR = 1 : mkstat = 2
Elsif VALEUR=0
 If [M:GAC0]SAC=2
  VALEUR = 2
 Else
  VALEUR = 1
 Endif
Endif
End

Subprog AS_UPDBLC(VALEUR)
Variable Integer  VALEUR
If [M:GAC0]SAC<>2 : mkstat=1 : End : Endif
End

Subprog AS_AUZBPR(VALEUR)
Variable Integer  VALEUR
## Si MAJ solde client, alors client autorisé
If [M:GAC3]UPDBLC=2 & nolign=1
 VALEUR = 2 : mkstat = 2
## Si MAJ solde fourn, alors fourn autorisé
Elsif [M:GAC3]UPDBLC=3 & nolign=2
 VALEUR = 2 : mkstat = 2
Elsif VALEUR=0
 If find(nolign,1,2,6) : # Cli, fou, divers
  VALEUR = 2
 Else
  VALEUR = 1
 Endif
Endif
End

Subprog AS_NBLIG3
If [M:GAC0]SAC<>2
  [M:GAC3]NBLIG3 = 0 : mkstat=2 : End
Elsif [M:GAC3]NBLIG3=0
 Local Integer I
 [M:GAC3]NBLIG3 = len(mess(0,277,1))
 For I=1 To [M:GAC3]NBLIG3
  If (I=1 & [M:GAC3]UPDBLC=2) or (I=2 & [M:GAC3]UPDBLC=3) or I=6
   [M:GAC3]AUZBPR(I-1) = 2
  Else
   [M:GAC3]AUZBPR(I-1) = 1
  Endif
 Next I
Endif
Affzo 50
End


######################################################################################
## Etiquette écran GAC4
######################################################################################
Subprog C_BUDTRK(VALEUR)
Variable Integer VALEUR
Call GRISE_BUD(VALEUR)
End

Subprog GRISE_BUD(VALEUR)
Value Integer VALEUR
If dim([M:GAC4]TIMDSP) < 1 : End : Endif
If VALEUR<>2
 Effzo [GAC4]TIMDSP
 Grizo [GAC4]TIMDSP
Else
 Actzo [GAC4]TIMDSP
Endif
End

Subprog AS_TIMDSP(VALEUR)
Variable Char    VALEUR()
If [M:GAC4]BUDTRK<>2 : mkstat = 1 : End : Endif
End

Subprog C_FLGUOM(VALEUR)
Variable Integer VALEUR
Call GRISE_UOM(VALEUR)
End

Subprog AS_UOM(VALEUR)
Variable Char VALEUR()
If [M]FLGUOM<>2 : mkstat = 1 : End : Endif
End

Subprog AS_VALUOM(VALEUR)
Variable Decimal VALEUR
If [M]FLGUOM<>2 : mkstat = 1 : End : Endif
End

Subprog GRISE_UOM(VALEUR)
Value Integer VALEUR
If VALEUR<>2
 Effzo [GAC4]UOM,VALUOM
 Grizo [GAC4]UOM,VALUOM
Else
 Actzo [GAC4]UOM,VALUOM
Endif
End

Subprog C_DSP(VALEUR)
Variable Char    VALEUR()
If clalev([F:DSP])= 0 : Local File CADSP [DSP]  : Endif
Gosub SETNOL
Call LECTURE("DSP",VALEUR,"") From CONTOBJ
Call COMPAT([M:GAC1]FCY,[F:DSP]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
End

Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 For I=0 To [M:GAC4]DACDIENBR-1
  Raz [M:GAC4]CCEDEF(I)
 Next
 Affzo [M:GAC4]40
Else
 Effzo CCEDEF
Endif
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
End

Subprog AS_CCEDEF(VALEUR)
Variable Char    VALEUR()
If [M:GAC4]DSP<>"" : mkstat = 1 : End : Endif
End


Subprog C_CCEDEF(VALEUR)
Variable Char    VALEUR()
If clalev([F:CCE])  = 0 : Local File CACCE      [CCE]  : Endif
Gosub SETNOL
Call LECTURE("CCE",VALEUR,[M]DIE(NOL)) From CONTOBJ
Call COMPAT([M:GAC1]FCY,[F:CCE]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
End


######################################################################################
## Etiquette écran GAC5
######################################################################################
Subprog C_NRPYR
Local Integer I,NOL
I = nolign-1
If status=65 & [M:GAC5]FLGGES(I)=2
 GMESSAGE = mess(1,115,1) : # Suppression impossible
 mkstat = 2 : End
Endif
End

Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
If clalev([F:GYM])  = 0 : Local File GACCPYM    [GYM]  : Endif
Call LECTURE("GYM",VALEUR,"") From CONTOBJ
If [F:GYM]COA<>[M:GAC0]COA
 ## Pyramide associée au plan de compte [F:GYM]COA
 GMESSAGE = mess(93,108,1)-[F:GYM]COA
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M]PYM(0..[M]NRPYR-1)) From OBJDIV
If mkstat : End : Endif
End
Call UNICITE(VALEUR,[M:GAC5]PYM(0..[M:GAC5]NRPYR-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog C_GRU(VALEUR)
Variable Char    VALEUR()
Filter [GRY] Where PYM=[M:GAC5]PYM(nolign-1) and GRU=VALEUR
Read [GRY]GRY0 First
If fstat
 GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
 mkstat = 2
Else
 [M:GAC5]GRU(nolign-1)    = VALEUR
 [M:GAC5]LEV(nolign-1)    = [F:GRY]LEV
 [M:GAC5]PRNROW(nolign-1) = [F:GRY]PRNROW
 [M:GAC5]FLGGES(nolign-1) = 1 #new line
 Affzo [M:GAC5]PYM(nolign-1),GRU(nolign-1)
Endif
Filter [GRY]
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran GAC3) 02/10/2012 14:14:18 (CBO)
######################################################################################
# FQ67615
Subprog AS_LVATYP(VALEUR)
Variable Integer VALEUR

  If [M:GAC3]FLGABL = G_OUI and (GCURLEG = "GER" or GCURLEG = "AUT")
    Actzo [M:GAC3]LVATYP
  Else
    Diszo [M:GAC3]LVATYP
  Endif
  If GCURLEG = "AUT"
    GMENLOC(3)=1
  Else
    GMENLOC(3)=0
  Endif
  Affzo [M:GAC3]LVATYP
End

Subprog AM_TYPRATFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = [V]CST_AYES
 Actzo [M:GAC2]TYPRAT
Else
 [M:GAC2]TYPRAT= 0
 Affzo [M:GAC2]TYPRAT
 Grizo [M:GAC2]TYPRAT
Endif
End


#ISSUE 47123 - 2017-09-27 by MANOW
Subprog REFBANKPAYTRA(VALEUR)
Value Char VALEUR()
If (func AFNC.PARAM("FIFRC", VALEUR) = "2") and (func AFNC.ACTIV("FIFRC"))
  Chgfmt [M:GAC3]FIFOVARPRO   With "K:10X"
Else
  Chgfmt [M:GAC3]FIFOVARPRO   With "-K:10X"
Endif
End
#ISSUE END

