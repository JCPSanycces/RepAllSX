############################################################
## Globales pour traductions
# programme faisaint appel a AGLOBTRADB spe a chque produit
# si les valeur des poste 0 sont vide attention plus de remonter de trad
############################################################

$DEFVAR
Global Char    GMAGIC(100)    : # Fichier de développement
Global Char    GINDUS(100)    : # Appli d'indus

GMAGIC   = "sophia_gaillard"
Raz GINDUS

Global Char    GFOLDER_V150(100)(6)     : # Appli d'indus en version V5 (atexte est commun qqsoit version)
#Global Char    GFOLDER_V200(100)(6)     : # Appli d'indus en version V10-avenger
#Global Char    GFOLDER_R080(100)(6)     : # Appli d'indus en version V11-challenger
Global Char    GFOLDER_R090(100)(6)     : # Appli d'indus en version V12 2017Rn

Raz GFOLDER_V150
#Raz GFOLDER_V200
#Raz GFOLDER_R080
Raz GFOLDER_R090

Global Integer GNBLANSTD
Global Char    GLANSTD(GLONLAN)(1..20) , GREFER(10)(1..20) , GDEMOF(10)(1..20) , GREFFRA(10)(1..20), GUSRLAN(GLONAUS)(1..20)

Global Char    GFRA(GLONLAN)
Global Char    GLANREF(GLONLAN)
Global Char    GLANTRAD(GLONLAN)
#-----------------------------
# prog spe a chaque produit
#-----------------------------
Local Integer WOK
WOK = 0
Call EXISTE_ADX ("","","AGLOBTRADB",WOK) From ORDSYS
If WOK = 1
    Gosub CHARG_TRANSLATE From AGLOBTRADB
Endif

#
GFRA     = "FRA"
Local Char    WLANREF(250)
Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
GLANREF=WLANREF
If GLANREF="" : GLANREF=GLANDEF : Endif
If GLANREF="" : GLANREF=GFRA    : Endif
#
Local Char    WLANTRA(250)
Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
GLANTRAD=WLANTRA
If GLANTRAD="" : GLANTRAD=GLANGUE : Endif
If GLANTRAD=GLANREF : # Pour tests
 GLANTRAD = "ENG"
Endif

Local Integer WIND_TRAD
WIND_TRAD = 0

# affiche message temporaire pour migration.. mettre un WARNING !!!!!
#GMESSAGE = "CAUTION : Cloud Migration is in progress, if you translate your changes will be lost for V6"
#Call ERREND(GMESSAGE) From GESECRAN
#GMESSAGE = ""

Return

