End

Subprog C_FLGDEF(VALEUR)
Variable Integer VALEUR
#ADNGO - X3PEOP-1240 - 11-10-2016 - START

# Une seule nature par défaut pour un groupe à visualiser sur le planning individuel
If clalev([F:NAT1])=0 : Local File NATACTIV [NAT1] : Endif
If VALEUR=2
 For [NAT1] Where PLNEMP=[M]PLNEMP & FLGDEF=2 & COD<>[M]COD
  # xxxx est déjà cochée en nature par défaut pour le groupe yyy
  GMESSAGE = [F:NAT1]COD-mess(155,10709,1)-mess([M]PLNEMP,10417,1)
  mkstat=2 : Break
 Next
Endif
#ADNGO - X3PEOP-1240 - 11-10-2016 - END
End

