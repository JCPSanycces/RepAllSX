Variable Char    VALEUR()
  GCURLEG=VALEUR
  Effzo [M:NAT1]FAM
  Effzo [M:NAT1]SFAM
  Gosub STYLE
  Affzo [NAT1]
End
#ADNGO - X3PEOP-1240 - 11-10-2016 - END


######################################################################################

#ADNGO - 2016-11-01 - START
##################################################
Subprog CONTNAT(COD)
Variable Char    COD()

  If GFONCTION = "GESNAT" | COD="" : End : Endif

  If clalev([F:NAT])=0 : Local File NATACTIV [NAT] : Endif

  If COD <> ""
    Filter [F:NAT] Where COD=[L]COD
    Read [F:NAT] First
    Filter [F:NAT]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        #Filter [F:NAT]
        #Read [F:NAT]NAT0 = [L]COD
        Read [F:NAT]NAT0 = GCURLEG;[L]COD

        If fstat
          #Filter [F:NAT] Where COD=[L]COD
          Filter [F:NAT] Where COD=[L]COD & LEG=GCURLEG
          Read [F:NAT] First
          Filter [F:NAT]
          If [F:NAT]LEG<>""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:NAT]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:NAT]

End

#ADNGO - 2016-11-01 - END
##################################################
#ADNGO - 2016-11-01 - START
Subprog TUNNAT(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONNAT)
   TOKILL = 1
  Endif

  If clalev([F:NAT])=0 : Local File NATACTIV [NAT] : Endif

  VCOD = COD

  #ADNGO - 2017-04-12 - START
  If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
    Filter [NAT] Where LEG=GCURLEG
    Read [F:NAT] First
    Filter [NAT]
    If !fstat : VCOD=[F:NAT]COD : Endif
  Else
    Read [NAT]NAT0 = GCURLEG;VCOD
  Endif
  #ADNGO - 2017-04-12 - END

  #ADNGO - 2017-02-09 - START
  Raz GLEGFIL
  #ADNGO - 2017-02-09 - END

  #ADNGO - 2017-04-12 - START
  #Call OBJET("NAT",VCOD,"") From GOBJET
  #Call OBJET("NAT",GCURLEG,VCOD) From GOBJET
  Call OBJET("NAT",VCOD,GCURLEG) From GOBJET
  #ADNGO - 2017-04-12 - END
  COD = VCOD

  If TOKILL : Kill VCOD : Endif

End
#ADNGO - 2016-11-01 - END

######################################################################################
## Section automatically added (screen NAT1) 11/09/2016 14:17:47 (ADNGO)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & GCURLEG <> [F:CPY]LEG Then
     mkstat=2
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
   Endif
Endif
Filter [CPY]
End
######################################################################################

######################################################################################
## Section automatically added (screen NAT1) 11/09/2016 14:27:53 (ADNGO)
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Filter [FCY] Where [F:FCY]FCY = VALEUR
Read [FCY] First
If !fstat
  If [F:FCY]LEGCPY <>[M:NAT1]CPY & [M:NAT1]CPY <> ""
  mkstat=2
   GMESSAGE = VALEUR-func AFNC.MES1(mess(171,104,1),[M:NAT1]CPY)
  Else
   If GCURLEG <> [F:FCY]LEG &  VALEUR <> "" & GCURLEG <> ""
           mkstat=2
     GMESSAGE=VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
   Endif
   Endif
Endif
Filter [FCY]

#If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
#Filter [FCY] Where [F:FCY]FCY=VALEUR
#Read [FCY] First
