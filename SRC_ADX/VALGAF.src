#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
End
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return


##############################################################################
$OUVRE
Local Integer  OK , STAT
Local Char     FILTRE(250) , MESSA(250) , SYMBOLE(30)
Local Date     OLDDAT , NEWDAT
Local Date     PREMDAT , DERDAT
Local Char     IDENT(30)(1..2) , ABTCUR(10)
Local Integer  I , J , K , V
Local Decimal  COEFF , TOTCOEF , CUM0
Local Decimal  MONTDEB , MONTCRE , CUMDEB , CUMCRE , MONT0 , MONTANT
Local Decimal  MTANA , QTANA , CUMANA , CUMQTE
Local Decimal  EXERCICE , PERIODE
Local Char     TBCUR(GLONCUR)(1..4)
Local Integer  NBCUR, NOL, NOLI, NUM
Local Integer  CONSCUR
Local Char     ECHPAM(3)(1..1)
Local Integer  ECHTYP(1..1)
Local Decimal  ECHMNT(1..1)
Local Integer  ECHSOI(1..1)
Local Shortint NECHE
Local Char     ACC(GLONGAC), PLAN(GLONCOA)
Local Integer  STAECT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Gosub OUVFIC


Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]
Local Mask GACCENT0 [HAE0] , GACCENT1 [HAE1] , GACCENT2 [HAE2]
Local Mask VENTILE  [VTL] ,  VENTILE2 [VT2] ,  VALGAF   [DIA]

TIT = mess(37,107,1) : # Génération abonnements

Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp4") From GMEMO
Return

$OUVFIC
If clalev([F:TCU])=0 : Local File TABCUR      [TCU] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM     [AVN] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP])=0 : Local File CADSP       [DSP] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT    [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE       [CCE] : Endif
If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP    [FGR] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE   [TCH] : Endif
If clalev([F:BAL])=0 : Local File BALANCE     [BAL] : Endif
If clalev([F:BLA])=0 : Local File BALANA      [BLA] : Endif
If clalev([F:GAF])=0 : Local File GACCFIX     [GAF] : Endif
If clalev([F:DTP])=0 : Local File CADISTMP    [DTP] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD      [PER] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY   [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE] : Endif
If clalev([F:DAA])=0 : Local File GACCENTRYA  [DAA] : Endif
If clalev([F:HAE1])=0: Local File GACCENTRY   [HAE1]: Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:JOU])=0 : Local File GJOURNAL    [JOU] : Endif
If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE] : Endif
If clalev([F:GCM])=0 : Local File GACM        [GCM] : Endif
Return

##############################################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]TOUSOC,[M:DIA]SOCIETE,[M:DIA]TYPGEN,SAI) From CPTDIV2
If SAI : Return : Endif

Local Integer OK
If [M:DIA]TOUSOC=2
 SOC=""
Else
 SOC=[M:DIA]SOCIETE
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return


##############################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

FILTRE = 'COD>="'+[M:DIA]ABTDEB+'"'
If [M:DIA]ABTFIN<>""
 FILTRE -= '& COD<="'+[M:DIA]ABTFIN+'"'
Endif
If [M:DIA]TOUUSR<>2
 FILTRE -= '& (UPDUSR="'+[M:DIA]USER+'" | (UPDUSR="" & CREUSR="'+[M:DIA]USER+'"))'
Endif

For [GAF]GAF0 Where evalue(FILTRE)
 ABTCUR = [F:GAF]COD
 If [F:GAF]ENAFLG = 2
  If GTRACE<>"" : Call ECR_TRACE([F:GAF]COD-[F:GAF]DES,0) From GESECRAN : Endif
  Read [HAE]HAE0 = [F:GAF]REFTYP;[F:GAF]REFNUM
  If fstat
   MESSA = mess(38,107,1) : Gosub ERREUR
  Else
   OK = 1
   If [M:DIA]TOUSOC<>2
    OK *= ([F:HAE]CPY=[M:DIA]SOCIETE)
   # If all cpy should take care of the legislation : leg cpy = screen leg
   Else
    Call LEC_CPY([F:HAE]CPY) From CPTLEC
    OK *= ([F:CPY]LEG = GCURLEG)
   Endif
   If [M:DIA]TOUSIT<>2
    OK *= ([F:HAE]FCY=[M:DIA]SITE)
   Endif
   If OK
    Gosub DELABT
    If GOK>0
     Gosub VALABT
    Endif
   Endif
  Endif
  If GTRACE<>"" : Call ECR_TRACE(string$(65,"-"),0) From GESECRAN : Endif
 Endif
Next

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

$ERREUR
Call ECR_TRACE(MESSA,1) From GESECRAN
Return

#######################################################
$VALABT
SYMBOLE = "GAF"+[F:GAF]COD
Lock =SYMBOLE With lockwait=0
If fstat
 MESSA = mess(39,107,1) : Gosub ERREUR : Return
Endif
OLDDAT = [F:GAF]LASDAT
If [F:GAF]TYP=2 : # Lisse
 PREMDAT = addmonth([F:GAF]STRDAT,-[F:GAF]PERNBR)
 PREMDAT = eomonth(PREMDAT)
 DERDAT = eomonth([F:GAF]ENDDAT)
Else            : # Fixe
 PREMDAT = [F:GAF]STRDAT-1
Endif
If OLDDAT=[0/0/0] | OLDDAT<[F:GAF]STRDAT
 OLDDAT = PREMDAT
 NEWDAT = [F:GAF]STRDAT
Else
 Call INCDATE(OLDDAT,NEWDAT,[F:GAF]STRDAT,[F:GAF]PERNBR,[F:GAF]PERTYP)
Endif
If NEWDAT<=[F:GAF]ENDDAT & NEWDAT<=[M:DIA]DATFIN
 CUM0 = [F:GAF]AMTCUM
 Repeat
  Gosub LIRE_PIECE
  Close Local File [HAE], [DAE], [DAA]
  If [F:GAF]DUDDAT=""
   [M:HAE1]DUDDAT = NEWDAT
  Else
   Raz [M:HAE1]DUDDAT
   Call DATECHE([F:GAF]DUDDAT,NEWDAT,1000,0.01,
&  ECHPAM,ECHTYP,ECHMNT,[M:HAE1]DUDDAT,ECHSOI,NECHE,[M:HAE0]FCY) From SUBTPT
   If [M:HAE1]DUDDAT=[0/0/0] : [M:HAE1]DUDDAT = NEWDAT : Endif
  Endif
  Call DEBTRANS From GLOCK
  Gosub TR1
  If STAT
   Gosub ERREUR
   Local File GACCENTRY [HAE] , GACCENTRYD [DAE] , GACCENTRYA [DAA]
   Break
  Endif
  If GTRACE<>""
   If [M:DIA]TYPGEN=1 & STAECT=2 & [M:DIA]ECTSTA<>STAECT
    Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-[M:HAE0]NUM
&    -format$("D:"+GFMDAT4,[M:HAE0]ACCDAT)-"("+tolower(mess(192,107,1))+")",0) From GESECRAN
   Else
    Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-[M:HAE0]NUM
&    -format$("D:"+GFMDAT4,[M:HAE0]ACCDAT),0) From GESECRAN
   Endif
  Endif
# Création pièce
  OLDDAT = NEWDAT
  Call INCDATE(OLDDAT,NEWDAT,[F:GAF]STRDAT,[F:GAF]PERNBR,[F:GAF]PERTYP)
  Local File GACCENTRY [HAE] , GACCENTRYD [DAE] , GACCENTRYA [DAA]
 Until NEWDAT>[F:GAF]ENDDAT | NEWDAT>[M:DIA]DATFIN
Endif
Unlock =SYMBOLE
Return

$LIRE_PIECE
Raz [M:HAE0], [M:HAE1], [M:HAE2]
Raz STAT
Read [HAE]HAE0 = [F:GAF]REFTYP;[F:GAF]REFNUM
[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]
Default Mask [HAE2]
Default Mask [HAE1]
Default Mask [HAE0]
Gosub LIENS From SUBGAS
Default Mask [HAE2]
Default Mask [HAE1]
Default Mask [HAE0]
Return

$TR1
GOK=1
Local Char  TZONE(10)(1..10) : # Table of zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char  TVAL(30)(1..10)  : # Table of values for zones to be forced     #*X3-39795

Trbegin GACCTMP [HAE] , GACCTMPD [DAE] , GACCTMPA [DAA]
&     , [AVN] , [GAF]
 Readlock [GAF]GAF0 = ABTCUR
 If fstat=1
  GOK=-1 : GLOCK="$GACCFIX"-ABTCUR : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("GAF",ABTCUR) From GLOCK : Goto AB_TR1
 Endif
 Raz [M:HAE0]NUM
 Raz [M:HAE2]ACCNUM, [M:HAE2]CHRNUM
 Raz [M:HAE2]MTC, [M:HAE2]MTCDAT, [M:HAE2]MTCDATMAX, [M:HAE2]MTCDATMIN
 Raz [M:HAE2]CHK, [M:HAE2]CHKDAT
 Raz [M:HAE2]AMTVAT
 Raz [M:HAE1]RATMLT, RATDIV, RATDAT
 [M:HAE0]ACCDAT = NEWDAT
 Call GETSOC([M:HAE0]FCY) From DEVSUB
 Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
 Call GETPERSOC(GSOCIETE,GTYPGEN,NEWDAT,EXERCICE,PERIODE) From CPTSUB
 [M:HAE0]FIY = EXERCICE
 [M:HAE0]PER = PERIODE
 [M:HAE1]ENTDAT = NEWDAT
 [M:HAE1]VALDAT = [M:HAE1]DUDDAT
 If [M:DIA]TYPGEN=1 : # Validation réelle
  [M:HAE0]TYP = [F:GAF]TYP1
  [M:HAE0]JOU = [F:GAF]JOU1
  [M:HAE0]CAT = 1 : # Réelle

  If [M:DIA]TOUSOC=2 & func AFNC.PARAM("FRADGI",[M:HAE0]CPY)="2"
   STAECT = 2
  Else
   STAECT = [M:DIA]ECTSTA
  Endif
  [M:HAE0]STA = STAECT : # Provisoire/définitif

  Gosub CONTROL_PERIOD_YEAR_CLOSED
  If MESSA<>""
   STAT = 1 : GOK=0 : Goto AB_TR1
  Endif

 Else
  [M:HAE0]TYP = [M:DIA]TYPPCE
  [M:HAE0]JOU = [M:DIA]JOU
  [M:HAE0]CAT = [M:DIA]TYPGEN : # Simulation active ou non
  [M:HAE0]STA = [M:DIA]ECTSTA : # Provisoire/définitif
 Endif

 If [F:GAF]RVSDAT<>[0/0/0] & TYPGEN=1
  [M:HAE1]RVS    = 2
  [M:HAE1]RVSDAT = [F:GAF]RVSDAT
 Else
  [M:HAE1]RVS    = 1
  [M:HAE1]RVSDAT = [0/0/0]
 Endif
 If [F:GAF]FORREF<>""
  Onerrgo RIEN
  [M:HAE1]REF = evalue([F:GAF]FORREF)
  Onerrgo
 Endif
 If [F:GAF]FORDES<>""
  Onerrgo RIEN
  [M:HAE1]DESVCR = evalue([F:GAF]FORDES)
  Onerrgo
  For I=0 To [M:HAE2]NBLIG-1
   Onerrgo RIEN
   [M:HAE2]DES(I) = evalue([F:GAF]FORDES)
   Onerrgo
  Next I
 Endif
 If [M:DIA]TYPGEN>=2 : # Simul
  [M:HAE1]REFSIM = "AS"+ABTCUR
 Endif
 If [F:GAF]TYP=2 : # Lisse
  Gosub MONTANT
 Endif
 GPOINT = "BEFCREVCR" : Gosub ENTREE From EXEFNC
 If [F:GAF]TYP=1 | MONTANT<>0 : # Fixe
  MESSA =""
  Call CONTROLE(STAT,MESSA) From CPTBATCH
  If STAT
   Gosub MESSAGE From CPTAUTO
   STAT = 1 : GOK=0 : Goto AB_TR1
  Endif

   #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH : # Pas de MAJ balances
   TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading                #*X3-39795
   TZONE(6)= "ORICOD" : TVAL(6)= "VALABT"                                      #*X3-39795 MWA
   Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH : # Pas de MAJ balances #*X3-39795

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  [M:HAE0]NUM = [F:HAE]NUM
  If [M:DIA]TYPGEN=1 : # Réel
   [F:GAF]LASTYP(0) = [M:HAE0]TYP
   [F:GAF]LASNUM(0) = [M:HAE0]NUM
   [F:GAF]LASDAT(0) = [M:HAE0]ACCDAT
   If [F:GAF]TYP=2 : # Lisse
    [F:GAF]AMTCUM += MONTANT
   Endif
  Else : # Simul
   [F:GAF]LASTYP(1) = [M:HAE0]TYP
   [F:GAF]LASNUM(1) = [M:HAE0]NUM
   [F:GAF]LASDAT(1) = [M:HAE0]ACCDAT
  Endif
  Rewrite [GAF]
  If fstat
   GOK=0 : Call FSTA("GAF") From GLOCK : Goto AB_TR1
  Endif
 Endif
Commit
If [F:GAF]TYP=2 : CUM0 += MONTANT : Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$DELABT
GOK = 1
For [HAE1] Where REFSIM="AS"+ABTCUR & ACCDAT<=[M:DIA]DATFIN With Nohint
 If GTRACE<>""
  Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
 Endif
# Annulation pièce
 Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
 If GOK<1 : Break : Endif
Next
Return
###############################################################
# Control if period\fiscal year are opened                    #
###############################################################
$CONTROL_PERIOD_YEAR_CLOSED

Call LEC_GTE_LEG(GCURLEG,[M:HAE0]TYP) From CPTLEC
Raz MESSA
For I=0 To len(mess(0,2644,1))-1
 Raz mkstat
 If [F:GTE]AUZLED(I)>1 & [M:HAEF]LEDC(I)<>""
  Call CONTPER([M:HAE0]ACCDAT,I+1,[M:HAE0]FCY) From CPTSUB
  If mkstat=2
   MESSA += [M:HAE0]ACCDAT-GMESSAGE+" ("+mess(I+1,2644,1)+")\"
  Endif
 Endif
Next

Return
###############################################################
# Incrémentation date écriture suivant périodicité abonnement #
###############################################################
Subprog INCDATE(OLDDAT,NEWDAT,INIDAT,NPERIO,UPERIO)
Variable Date    OLDDAT
Variable Date    NEWDAT
Variable Date    INIDAT
Value    Integer NPERIO
Value    Integer UPERIO

Local Integer I, J, DIF

Case UPERIO
 When 1 : # Jour
  NEWDAT = OLDDAT+NPERIO
 When 2 : # Semaine
  NEWDAT = OLDDAT+7*NPERIO
 When 3 : # Décade
  For I=1 To NPERIO
   J = day(OLDDAT)
   If    J<=10
    NEWDAT = OLDDAT+10
   Elsif J<=20
    NEWDAT = OLDDAT+10
    If month(NEWDAT)<>month(OLDDAT)
     NEWDAT = eomonth(OLDDAT)
    Endif
   Else
    J = mod(day(INIDAT),10)
    If J=0 : J = 10 : Endif
    NEWDAT = gdat$(J,month(OLDDAT)+1,year(OLDDAT))
   Endif
   OLDDAT = NEWDAT
  Next I
 When 4 : # Quinzaine
  For I=1 To NPERIO
   J = day(OLDDAT)
   If    J<=15
    NEWDAT = OLDDAT+15
    If month(NEWDAT)<>month(OLDDAT)
     NEWDAT = eomonth(OLDDAT)
    Endif
   Else
    J = mod(day(INIDAT),15)
    If J=0 : J = 15 : Endif
    NEWDAT = gdat$(J,month(OLDDAT)+1,year(OLDDAT))
   Endif
   OLDDAT = NEWDAT
  Next I
 When 5 : # Mois
  NEWDAT = addmonth(OLDDAT,NPERIO)
  If OLDDAT=eomonth(OLDDAT) & [F:GAF]STRDAT=eomonth([F:GAF]STRDAT)
   NEWDAT = eomonth(NEWDAT)
  Endif
  # Après passage sur février, on n'accède plus aux jours 29, 30 et 31
  DIF = day([F:GAF]STRDAT)-day(NEWDAT)
  If DIF<>0 & month(NEWDAT)<>2 & NEWDAT<>eomonth(NEWDAT)
   NEWDAT += DIF
  Endif
Endcase
End

$RIEN
Resume

## Calcul montant pour abonnement lissé
$MONTANT
## Calcul montant de base
Read [DTP]DTP0 = [F:GAF]DSPTMP
Call LEC_TCU([M:HAE1]CUR) From CPTLEC
If NEWDAT>=[F:GAF]ENDDAT
 MONTANT = [F:GAF]AMT-CUM0
Elsif [F:GAF]TYP=2 & eomonth(NEWDAT)>=[F:GAF]ENDDAT : #Lissé->Mois, la dernière périodicité était incorrecte
 MONTANT = [F:GAF]AMT-CUM0
Else
 Call COEF(PREMDAT+1,DERDAT,TOTCOEF)
 Call COEF(eomonth(OLDDAT)+1,eomonth(NEWDAT),COEFF)
 MONTANT = arr([F:GAF]AMT*COEFF/TOTCOEF,[F:TCU]CURRND)
 If [F:GAF]AMT>0
  MONTANT = min(MONTANT,[F:GAF]AMT-CUM0)
 Else
  MONTANT = max(MONTANT,[F:GAF]AMT-CUM0)
 Endif
Endif
## Calcul du tableau d'écritures
Raz CUMDEB , CUMCRE
If [M:HAE2]DEB(0)<>0
 MONT0  = [M:HAE2]DEB(0)
Else
 MONT0  = [M:HAE2]CDT(0)
Endif
COEFF  = MONTANT/MONT0
For I=0 To [M:HAE2]NBLIG-1
 If [M:HAE2]DEB(I)<>0
  MONTDEB = arr((CUMDEB+[M:HAE2]DEB(I))*COEFF,[F:TCU]CURRND)
&          -arr(CUMDEB*COEFF,[F:TCU]CURRND)
  CUMDEB += [M:HAE2]DEB(I)
  [M:HAE2]DEB(I) = MONTDEB
 Else
  MONTCRE = arr((CUMCRE+[M:HAE2]CDT(I))*COEFF,[F:TCU]CURRND)
&          -arr(CUMCRE*COEFF,[F:TCU]CURRND)
  CUMCRE += [M:HAE2]CDT(I)
  [M:HAE2]CDT(I) = MONTCRE
 Endif
 # boucle sur tous les comptes : on recherche le 1er compte renseigné (ACC1, ACC2...ACC9)
 For J=1 To len(mess(0,2644,1))
  [L]ACC=evalue("[M:HAE2]ACC"+num$(J)+"("+num$(I)+")")
  If [L]ACC<>""
   [L]PLAN = evalue("[M:HAE2]COA"+num$(J)+"("+num$(I)+")")
   Call LEC_GAC([L]ACC,[L]PLAN) From CPTLEC
   If [F:GAC]UOM<>""
    Call LEC_TUN([F:GAC]UOM) From CPTLEC
    [M:HAE2]QTY(I) = arr([M:HAE2]QTY(I)*COEFF,10^-[F:TUN]UOMDEC)
    Break
   Endif
  Endif
 Next
 If [M:HAE2]PTV(I)<>0
  Raz CUMANA , CUMQTE
  For V=[M:HAE2]PTV(I) To [M:HAE2]PTF(I)
   MTANA = arr((CUMANA+[M:VT2]TBAMT(V))*COEFF,[F:TCU]CURRND)
&         -arr(CUMANA*COEFF,[F:TCU]CURRND)
   CUMANA += [M:VT2]TBAMT(V)
   [M:VT2]TBAMT(V) = MTANA
   QTANA = arr((CUMQTE+[M:VT2]TBQTY(V))*COEFF,[F:TCU]CURRND)
&         -arr(CUMQTE*COEFF,[F:TCU]CURRND)
   CUMQTE += [M:VT2]TBQTY(V)
   [M:VT2]TBQTY(V) = QTANA
  Next V
  [M:HAE2]QTY(I) = sum([M:VT2]TBQTY([M:HAE2]PTV(I)..[M:HAE2]PTF(I)))
 Endif
Next I
Return

Subprog COEF(DATDEB,DATFIN,COEFF)
Value    Date    DATDEB
Value    Date    DATFIN
Variable Decimal COEFF
Local Integer A , M , J , N
Local Date    DATCUR
DATCUR = DATDEB
COEFF = 0
While DATCUR<>[0/0/0]
 A = year(DATCUR)
 M = month(DATCUR)
 N = day(eomonth(DATCUR))
 If M=month(DATFIN) & A=year(DATFIN)
  J = DATFIN-DATCUR+1
  DATCUR = [0/0/0]
 Else
  J = eomonth(DATCUR)-DATCUR+1
  DATCUR = eomonth(DATCUR)+1
 Endif
 COEFF += [F:DTP]COE(M-1)*J/N
Wend
End

#######################################
Subprog AS_TOUSOC(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo TOUSOC
 Actzo SOCIETE,TOUSIT
 mkstat = 1 : End
Endif
End

Subprog C_TOUSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SOCIETE,SITE : Grizo SOCIETE,SITE
 [M]TOUSIT=2 : Affzo TOUSIT : Grizo TOUSIT
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo SOCIETE,TOUSIT
 If dim([M]LEG)>0  : Effzo LEG : Grizo LEG : Endif
Endif
End

Subprog AS_SOCIETE(VALEUR)
Variable Char     VALEUR
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog C_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR)From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]LEG
 [M]TYPPCE=""
 [M]JOU=""
Endif
End

Subprog AS_TOUSIT(VALEUR)
Variable Integer  VALEUR
If [M]TOUSOC=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
If VALEUR=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
End

Subprog C_TOUSIT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SITE : Grizo SITE
 GCURFCY=""
 If [M]SOCIETE<>""
  I = find([M]SOCIETE,GSOCSITE(1..GNBSITE))
  GCURFCY = GSITE(I)
 Endif
Else
 Actzo SITE
Endif
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSIT=2 : mkstat = 1 : End : Endif
End

Subprog C_SITE(VALEUR)
Variable Char VALEUR
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_USER(VALEUR)
Variable Char     VALEUR
If [M]TOUUSR = 2 : mkstat = 1 : End : Endif
If VALEUR=""
 VALEUR = GUSER
Endif
End

Subprog AS_ECTSTA(VALEUR)
Variable Integer VALEUR
If [M]TYPGEN<>1 : VALEUR = 0 : mkstat = 2 : End : Endif
If [M]SOCIETE<>""
 If func AFNC.PARAM("FRADGI",[M]SOCIETE)="2" : # Paramètre à Oui
  VALEUR = 2 : mkstat = 2 : End
 Endif
Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog D_DATFIN(VALEUR)
Variable Date    VALEUR
Local Decimal EXE , PER
If [M]TOUSOC<>2
 If [M]SITE<>""
  Call GETSOC([M]SITE) From DEVSUB
 Else
  Call LEC_CPY([M]SOCIETE) From CPTLEC
  Call GETSOC([F:CPY]MAIFCY) From DEVSUB
 Endif
 Call GETPER([F:FCY]FCY,GTYPGEN,datesyst,EXE,PER) From CPTSUB
 Read [FIY]FIY0 = SOCIETE;GTYPGEN;EXE
 VALEUR = [F:FIY]FIYEND
Endif
End

Subprog AM_TYPGEN(VALEUR)
Variable Integer VALEUR
[M:DIA]TYPPCE = ""
[M:DIA]JOU = ""
If !GIMPORT
 # En réel, le type de pièce et le journal sont saisis dans l'abonnement
 If VALEUR=1 : Grizo [M]TYPPCE, JOU : Actzo ECTSTA
 Else : Actzo [M]TYPPCE, JOU : Grizo ECTSTA
 Endif
 Affzo [M]TYPPCE, JOU
Endif

End

Subprog AS_TYPPCE(VALEUR)
Variable Char    VALEUR()
If (VALEUR="" & [M:DIA]TYPGEN<>1)
 If [M]SITE<>""
  Call PARAM([M]SITE,"TYPACC",VALEUR) From ADOVAL
 Elsif [M]SOCIETE<>""
  Call PARAM([M]SOCIETE,"TYPACC",VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,"TYPACC",VALEUR) From CPTLEC
 Endif
Endif
End

Subprog C_TYPPCE(VALEUR)
Variable Char    VALEUR()
Local Integer RES
If VALEUR=""
 If [M:DIA]TYPGEN<>1
  GMESSAGE = mess(10,123,1) : mkstat = 2 :  End
 Endif
Endif

If [M:DIA]TYPGEN=1 : VALEUR = "" : End : Endif
Call CONTEXE([F:GTE]ACS) From CPTSUB : If mkstat : End : Endif
If [F:GTE]VCRSIM<>2
 GMESSAGE = mess(32,107,1) : mkstat = 2 : End
Elsif [F:GTE]COU=""
 GMESSAGE = mess(31,107,1) : mkstat = 2 : End
Elsif [F:GTE]VLYSTR>[M:DIA]DATFIN
 GMESSAGE = mess(34,107,1)-format$("D:"+GFMDAT4,[F:GTE]VLYSTR)
 mkstat = 2 : End
Elsif [F:GTE]VLYEND<>[0/0/0] & [F:GTE]VLYEND<[M:DIA]DATFIN
 GMESSAGE = mess(35,107,1)-format$("D:"+GFMDAT4,[F:GTE]VLYEND)
 mkstat = 2 : End
Endif
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYPPCE<>""
 Call LEC_GTE_LEG(GCURLEG,[M]TYPPCE) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
 If [M:DIA]TYPGEN<>1
  GMESSAGE = mess(10,123,1) : mkstat = 2   : End
 Endif
Endif
If [M:DIA]TYPGEN=1 : VALEUR = "" : End : Endif
Call LEC_JOU_LEG(GCURLEG,VALEUR) From CPTLEC
Call CONTEXE([F:JOU]ACS) From CPTSUB : If mkstat : End : Endif
Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE) From CPTLEC
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = mess(51,106,1) : mkstat = 2 : End
Elsif [M:DIA]SOCIETE <>"" & [F:JOU]FCY <>""
 Call VERSOC([F:JOU]FCY,[M:DIA]SOCIETE,[M:DIA]SITE,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif
End


Subprog C_TOUUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]USER="" : Affzo USER : Grizo USER : Else : Actzo USER : Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End

$GRISE
If [M]TOUSOC=2
 [M]SOCIETE = "" : [M]SITE = ""
 Grizo SOCIETE, SITE
 [M]TOUSIT=2 : Affzo TOUSIT : Grizo TOUSIT
Else
 Actzo SOCIETE, TOUSIT
Endif
If [M]TOUSIT=2 : [M]SITE = "" : Grizo SITE : Else : Actzo SITE : Endif
If [M]TOUUSR=2 : [M]USER = "" : Affzo USER : Grizo USER : Else : Actzo USER : Endif
If [M]TYPGEN=1 : [M]TYPPCE = "" : [M]JOU = "" : Grizo TYPPCE, JOU : Actzo ECTSTA
Else           : Actzo TYPPCE, JOU : Grizo ECTSTA
Endif
Return

Subprog AS_ABTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]ABTDEB : VALEUR=[M]ABTDEB : Endif
End

Subprog C_ABTDEB(VALEUR)
Variable Char    VALEUR()
Gosub CTRLABT
End

Subprog C_ABTFIN(VALEUR)
Variable Char    VALEUR()
Gosub CTRLABT
End

$CTRLABT
If clalev([F:HAE])=0  :  Local File GACCENTRY [HAE] : Endif
If clalev([F:CPY])=0  :  Local File COMPANY [CPY]   : Endif
If VALEUR <>""
 Call LECTURE ("GAF",VALEUR,"")From CONTOBJ
 Read [HAE]HAE0 = [F:GAF]REFTYP;[F:GAF]REFNUM
 If  !fstat
  Call LECTURE ("CPY",[F:HAE]CPY,"")From CONTOBJ
  If [F:CPY]LEG <> GCURLEG
   GMESSAGE = mess(226,107,1)- mess(221,107,1)
   mkstat = 2
  Endif
 Else
  GMESSAGE  = mess(38,107,1)
  mkstat = 2
 Endif
Else
 If  VALEUR<>"" & VALEUR<[M]ABTDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
 Endif
Endif
Return

######################################################################################

