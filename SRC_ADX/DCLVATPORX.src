#<AdxTL>@(#)3.0.0.0 $Revision$
#################################################################################################
#################################################################################################
$ACTION

Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE_BATCH" : Gosub INIT
  When "EXEC"        : Gosub EXEC
Endcase

Return
#################################################################################################
#################################################################################################
$INIT

Local Integer OK
Local Integer STAT
Local Char    NAM(GDIMFIC), FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), CRITSPE(250)
Local Char    FICDON(GDIMFIC),URL(GDIMFIC), SEPCHP, SEPENR
Local Integer STAT
Local Char    NOMFIC(GDIMFIC)
Local Mask    DCLVATPORX [DIA]
############################################################################
## Options d'export
############################################################################
SEPCHP = chr$(59)                                          : # Séparateur de champ (;)
SEPENR = chr$(13)+chr$(10)                                 : # Séparateur de ligne (CR+LF)
NAM    = 'VAT_'+[F:DVPH]CPY+"_"+num$([F:DVPH]DCLTYP)+"_"+format$("D:DDMMYYYYhhmmss", date$) # Nom du fichier
If [F:DVPH]ENDDAT < [01/09/2017]
    EXT    = 'txt'
Else
    EXT    = 'xml'
Endif
TRA = 1
TMP = 1

Raz [M:DIA]
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
  [M]VOLFIL = "[TMP]"
Endif
Actzo [M]VOLFIL

[M]TYPEXP=2
Call AM_TYPEXP([M]TYPEXP)

Return
#################################################################################################
#################################################################################################
$EXEC

Call VATDCLEXP(PARAM(1),[M:DIA]TYPEXP,[L]FICDON,[L]NAM,[L]EXT)

Return
#################################################################################################
#################################################################################################
Subprog VATDCLEXP(DCLNUM, TYPEXP, FILNAM,NAM,EXT)
Value Char    DCLNUM
Value Integer TYPEXP
Value Char    FILNAM
Value Char    NAM
Value Char    EXT
Local Char    FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), CRITSPE(250)
Local Char    FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT,OK
Local Char    NOMFIC(GDIMFIC)

If [L]DCLNUM = "" : End : Endif

Gosub OPEN_TABLES
Gosub DECLARE_VARS

Read [F:DVPH]DVPH0 = [L]DCLNUM
If fstat : End : Endif

Read [F:CPY]CPY0 = [F:DVPH]CPY
If fstat : End : Endif

Gosub OPEN_FILE

Case [F:DVPH]DCLTYP
  When 1
    If [F:DVPH]ENDDAT < [01/09/2017]
        Gosub EXPORT From CALVATPORPX
    Else
        Gosub EXPORT From CALVATPORPXXML
    Endif
  When 4
    Gosub EXPORT From CALVATPOREX
Endcase

Gosub CLOSE_FILE

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

End
#################################################################################################
#################################################################################################
$OPEN_TABLES

Local File DCLVATPORH [DVPH]
Local File DCLVATPORL [DVPL]
Local File DCLVATPORF [DVPF]
Local File COMPANY    [CPY]

Return
#################################################################################################
#################################################################################################
$DECLARE_VARS

Local Char    FILEPATHTMP(GDIMFIC)
Local Integer STAT

Return
#################################################################################################
#################################################################################################
$OPEN_FILE

#Onerrgo $ERROR
##opening file to write to (on temporary folder)
#[L]FILEPATHTMP = filpath('tmp','VAT_'+[F:DVPH]CPY+"_"+num$([F:DVPH]DCLTYP)+"_"+format$("D:DDMMYYYYhhmmss", date$),'txt')
#
##empty file if exists
#Openo [L]FILEPATHTMP, 0         Using [VATF]
#
#Onerrgo

FICHIER = [M:DIA]FIC
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = [L]NAM

If [M]TYPEXP=1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
 If filinfo(FICDON,7)>0
  ## Fichier existant, souhaitez-vous l'écraser ?
  Call OUINON(mess(127,105,1), OK) From GESECRAN
  If OK=1 : Return : Endif
 Endif
Endif

Openo FICDON,0         Using [VATF]

Return
#################################################################################################
#################################################################################################
$ERROR

GMESSAGE = mess(93,100,1)- num$(errl) - "("+errp+"):" - errmes$(errn)+"\"+errm
OK = 0

Resume
#################################################################################################
#################################################################################################
$CLOSE_FILE

Openo Using [VATF]

If [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : TRA=0
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : TRA=0
 Endif
Endif

Call FERME_TRACE From LECFIC

Return
######################################################################################
######################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Actzo [M]VOLFIL
Endif
End
######################################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If GBATCH & VALEUR=1
 # Le poste client est inaccessible en batch
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif

End
######################################################################################
######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL

End
######################################################################################
######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End
######################################################################################
######################################################################################

