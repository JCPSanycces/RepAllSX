#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog CHARGE_GRAPHE(PABR)
Value Char PABR

Case PABR
    When "[MFC1]" :
        Raz [M:MFC1]NBLIG, [M:MFC1]CST, [M:MFC1]LBL
        If [M:MFC1]DETFLG<>2
            If [M:MFC1]MATFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]MATTOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(1,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]MACFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]MACTOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(2,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]LABFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]LABTOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(3,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]SCOFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]SCOTOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(4,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]INVDTAFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]INVDTATOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(2,2201,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]OVEFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]OVETOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(5,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]TOTFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]TOTWITOVE
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(62,197,1)
                [M:MFC1]NBLIG += 1
            Endif
        Else
            If [M:MFC1]MATFLG=2
                For I=0 To GACTMAT-1
                    [M:MFC1]CST([M:MFC1]NBLIG) = [F:MFC]MATCST(I)
                    [M:MFC1]LBL([M:MFC1]NBLIG) = mess(I+1,325,1)
                    [M:MFC1]NBLIG += 1
                Next
            Endif
            If [M:MFC1]MACFLG=2
                For I=0 To GACTMAC-1
                    [M:MFC1]CST([M:MFC1]NBLIG) = [F:MFC]MACCST(I)
                    [M:MFC1]LBL([M:MFC1]NBLIG) = mess(1,313,1)+"-"+mess(I+1,316,1)
                    [M:MFC1]NBLIG += 1
                Next
            Endif
            If [M:MFC1]LABFLG=2
                For I=0 To GACTLAB-1
                    [M:MFC1]CST([M:MFC1]NBLIG) = [F:MFC]LABCST(I)
                    [M:MFC1]LBL([M:MFC1]NBLIG) = mess(2,313,1)+"-"+mess(I+1,316,1)
                    [M:MFC1]NBLIG += 1
                Next
            Endif
            If [M:MFC1]SCOFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]SCOTOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(4,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]INVDTAFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]INVDTATOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(2,2201,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]OVEFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]OVETOT
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(5,319,1)
                [M:MFC1]NBLIG += 1
            Endif
            If [M:MFC1]TOTFLG=2
                [M:MFC1]CST([M:MFC1]NBLIG) = [M:MFC1]TOTWITOVE
                [M:MFC1]LBL([M:MFC1]NBLIG) = mess(62,197,1)
                [M:MFC1]NBLIG += 1
            Endif
        
        Endif
        Affzo [M:MFC1]
    When "[MFC2]" :
        Raz [M:MFC2]NBLIG, [M:MFC2]CST, [M:MFC2]LBL
        If [M:MFC2]DETFLG<>2
            If [M:MFC2]MATFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]MATTOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(1,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]MACFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]MACTOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(2,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]LABFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]LABTOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(3,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]SCOFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]SCOTOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(4,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]INVDTAFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]INVDTATOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(2,2201,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]OVEFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]OVETOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(5,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]TOTFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]TOTWITOVE
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(62,197,1)
                [M:MFC2]NBLIG += 1
            Endif
        Else
            If [M:MFC2]MATFLG=2
                For I=0 To GACTMAT-1
                    [M:MFC2]CST([M:MFC2]NBLIG) = [F:MFC]MATCST(I)
                    [M:MFC2]LBL([M:MFC2]NBLIG) = mess(I+1,325,1)
                    [M:MFC2]NBLIG += 1
                Next
            Endif
            If [M:MFC2]MACFLG=2
                For I=0 To GACTMAC-1
                    [M:MFC2]CST([M:MFC2]NBLIG) = [F:MFC]MACCST(I)
                    [M:MFC2]LBL([M:MFC2]NBLIG) = mess(1,313,1)+"-"+mess(I+1,316,1)
                    [M:MFC2]NBLIG += 1
                Next
            Endif
            If [M:MFC2]LABFLG=2
                For I=0 To GACTLAB-1
                    [M:MFC2]CST([M:MFC2]NBLIG) = [F:MFC]LABCST(I)
                    [M:MFC2]LBL([M:MFC2]NBLIG) = mess(2,313,1)+"-"+mess(I+1,316,1)
                    [M:MFC2]NBLIG += 1
                Next
            Endif
            If [M:MFC2]SCOFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]SCOTOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(4,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]INVDTAFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]INVDTATOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(2,2201,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]OVEFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]OVETOT
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(5,319,1)
                [M:MFC2]NBLIG += 1
            Endif
            If [M:MFC2]TOTFLG=2
                [M:MFC2]CST([M:MFC2]NBLIG) = [M:MFC2]TOTWITOVE
                [M:MFC2]LBL([M:MFC2]NBLIG) = mess(62,197,1)
                [M:MFC2]NBLIG += 1
            Endif
        
        Endif
        Affzo [M:MFC2]
Endcase
End
