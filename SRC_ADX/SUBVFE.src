End
#=====================================#
Subprog AVANT_NBBOX

  If  [M:VFE2]TYPBOX(nolign-1) = 3 : # Total
    [M:VFE2]VATAMT(nolign-1)  = func CALCFOR([M:VFE2]CLCFOR(nolign-1))
  Endif

End
#=====================================#
Subprog AS_VATAMT(VALEUR)
Variable Decimal VALEUR

  If  [M:VFE2]TYPBOX(nolign-1) = 3 : # Total
    [M:VFE2]VATAMT(nolign-1)  = func CALCFOR([M:VFE2]CLCFOR(nolign-1))
  Endif

End
#=====================================#
Subprog AM_VATAMT(VALEUR)
Variable Decimal VALEUR

Local Integer I

  If VALEUR <> [M:VFE2]VATAMT(nolign-1) and  [M:VFE2]TYPBOX(nolign-1) = 2 # detail
    [M:VFE2]VATAMT(nolign-1) = VALEUR

    For I=1 To [M:VFE2]NBBOX
      If [M:VFE2]TYPBOX(I-1) = 3  # Total
        [M:VFE2]VATAMT(I-1)  = func CALCFOR([M:VFE2]CLCFOR(I-1))
        Affzo  [M:VFE2]VATAMT(I-1)
      Endif
    Next
  Endif

End
#=====================================#
Subprog AS_COMMENT(VALEUR)
Variable Char    VALEUR()

End
###################################################
Funprog CALCFOR(FORMULE)
Value    Char    FORMULE
Local Decimal TOTAL
Local Char    CHAINE1(250), CHAINE2(250)
Local Integer I, SNSNEG, I_LIG

  # Issue X3-93383
  TOTAL = 0
  Local Integer B_ERR
  Call EVALUE_FORMULA ("E", FORMULE, TOTAL, B_ERR) From SUBVFE

End TOTAL

###################################################
# Issue X3-91052 X3-93383
Subprog EVALUE_FORMULA (PAR, FRM, RES, ERR)
Value Char       PAR   : # "S" Setup "E" Execution
Value Char       FRM
Variable Decimal RES
Variable Integer ERR

  Local Char FORMUL(250) :  FORMUL  = FRM
  Local Char RESULT(250) :  RESULT  = ''

  Local Char    FLD(250) : # Field
  Local Integer I_LIG
  Local Integer I
  Local Integer Q


  If (FORMUL <> "") Then
    For I = 1 To len(FORMUL)
      If mid$(FORMUL, I, 1) = "'"
        Q += 1
      Endif
      If !Q
        RESULT += mid$(FORMUL, I, 1)
      Endif

      If (Q = 1) Then
        If (mid$(FORMUL, I, 1) <> "'") Then
          FLD += mid$(FORMUL, I, 1)
        Endif
      Endif

      If Q = 2
        Q = 0
        If PAR = 'E'  : # Execution
          I_LIG=find(FLD,[M:VFE2]VATBOX(0..[M:VFE2]NBBOX ) )
          RESULT += "[M:VFE2]VATAMT("-num$(I_LIG-1)-")"
          FLD = ""
        Endif
        If PAR = 'S'  : # Setup
          I_LIG=find(FLD,[M:VEF1]VATBOX(0..[M:VEF1]NBBOX ) )
          RESULT += num$(I_LIG)
        Endif
        FLD = ""
      Endif
    Next
  Endif

  Onerrgo FORMULA_ERROR
  RES = evalue(RESULT)
  Onerrgo
End
###################################################
$FORMULA_ERROR
  ERR = 1
  RES = 0
  Resume
Return
###################################################
# Issue X3-101745
Subprog C_PERNUM(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 1 or VALEUR > 12
    GERR = 1
    GMESSAGE = mess(178,107,1)
    mkstat = 2
  Endif
End
# End Issue X3-101745

