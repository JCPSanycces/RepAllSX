#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet VFE
Raz GPILOBJ , GNBMASKOUV
Call OBJET("VFE",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-112946 - 2018-10-23 by MDJ : VATID not found & Folder mono leg
# Issue X3-101747 - 2018-07-30 by CBO : Add URL to manage TEST / PrePROD / PROD environment
# Issue X3-101736 - 2018-07-25 by CBO : Manage return message from Submissions tool
# Issue X3-101745 - 2018-07-23 by CBO : Manage PERNUM
# Issue X3-101659 - 2018-07-20 by MDJ : st_val type incomptability
# Issue X3-100056 - 2018-07-10 by CBO : Enhancements
# Issue EPIC_X3-74826 (X3-98320) - 2018-06-27 by FHA : Refactoring
# Issue X3-98320 - 2018-06-26 by CBO : Refactoring
# Issue X3-85094 - 2018-06-25 by CBO : Store results of submission in form
# Issue X3-91223 - 2018-06-12 by CBO : Function to check the result
# Issue X3-85098 - 2018-05-30 by CBO : Function to submit VAT and create json
# Issue EPIC_X3-63065 (X3-93383) - 2018-05-30 by MWA : Advanced formula execution
# Issue EPIC_X3-63065 (X3-91052) - 2018-05-30 by MWA : Advanced formula setup
# Issue EPIC_X3-63065 (X3-73530) - 2018-02-06 by MDJ : MTD_Form_Entry

####################################################################################################
# Tables
#   VATFRMENT [VFE]
###########################################################################################################
# Masks           Windows   Function    Programs    Object/action
# -----          --------   -------     --------     --------|
# VATENT1 [VFE1]  | OVFE    GESVFE      SUBVFE        VFE ( Objet simply)|
###########################################################################################################

$ACTION

  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "SETBOUT"     : Gosub SETBOUT
    When "LIENS"       : Gosub LIENS
    When "FILTRE"      : Gosub FILTRE
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When "RAZCRE"      : Gosub RAZCRE
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When "FIN_TABLE"   : Gosub FIN_TABLE

    When "EXEBOUT"     : Gosub EXEBOUT # Issue X3-85098
    When Default
  Endcase

Return
###################################################
$OUVRE

If clalev([F:VFE2])  = 0   : Local File VATFRMENT    [VFE2]  : Endif

If clalev([F:VFED])   = 0  : Local File VATFRMENTD   [VFED]  : Endif
If clalev([F:VEF])    = 0  : Local File VATENTFRM    [VEF]   : Endif
If clalev([F:VEFD])   = 0  : Local File VATENTFRMD   [VEFD]  : Endif

If clalev([F:AXX])   = 0   : Local File ATEXTRA      [AXX]   : Endif
If clalev([F:TCA])   = 0   : Local File TABCOUAFF    [TCA]   : Endif
If clalev([F:CPY])   = 0   : Local File COMPANY      [CPY]   : Endif
If clalev([F:FGR])   = 0   : Local File FACGROUP     [FGR]   : Endif
If clalev([F:TCY])   = 0   : Local File TABCOUNTRY   [TCY]   : Endif

Global Char    GDEVFMTV(10) : # Format VATAMT
Global Date    G_DCLSTRDAT  : # start date of the original VAT setting
Global Date    G_DCLENDDAT  : # end date of the original VAT setting

Local Char    VATIDSEQ(5)      : # Sequence number counter
Local Char    VATIDNUM(8)      : # Sequence number
Local Integer STAT             : # Variables diverses
Local Char WRTRN_CODE(30), WMESSAGE(250), WDIGIT_VAT_NUMBER(30)
Local Char WURL(250) # issue X3-101747

  If dim(GCURLEG)>0
    Local Char SAV_GCURLEG(GLONADI)
    SAV_GCURLEG = GCURLEG
  Endif

Return
###################################################
$SETBOUT

  # It's not possible to delete a VAT form setting if the Status is "validated"
  If [M:VFE0]STA >= [V]CST_VALIDATED
    Call VIREBOUT(CHAINE, "A") From GOBJET
  Else
    If instr(1, CHAINE, 'A') = 0
      CHAINE += 'A'
    Endif
  Endif

  If GUSRACS <> 2
    # Option "C" ==>  Create "C" GSTACRE
    GBIDC2 = "C"
    Gosub  AUTORIS_OPT From CONTX3
    If GBIDI2 = 0
      Call VIREBOUT(CHAINE, "C") From GOBJET
    Endif

    # Option "M" ==>  Save "E" GSTAENR
    GBIDC2 = "M"
    Gosub  AUTORIS_OPT From CONTX3
    If GBIDI2 = 0
      Call VIREBOUT(CHAINE, "E") From GOBJET
    Endif

    # Option "S" ==>  Delete "A" GSTAENR
    GBIDC2 = "S"
    Gosub  AUTORIS_OPT From CONTX3
    If GBIDI2 = 0
      Call VIREBOUT(CHAINE, "A") From GOBJET
    Endif
  Endif

  # It's not possible to validate if status is <> 1 (in progress) or in creation or edit mode
  If [M:VFE0]STA <> [V]CST_IN_PROGRESS or GREP = "C" or GREP = "M"
    Call VIREBOUT(CHAINE, "l") From GOBJET
  Else
    If instr(1, CHAINE, "l") = 0
      CHAINE += "l"
    Endif
  Endif

  # It's not possible to submit VAT if the Status is not validated or rejected or in creation or edit mode
  If ([M:VFE0]STA <> [V]CST_VALIDATED and [M:VFE0]STA <> [V]CST_AERROR) or GREP = "M"
    Call VIREBOUT(CHAINE, "s") From GOBJET
  Else
    If instr(1, CHAINE, 's') = 0
      CHAINE += "s"
    Endif
  Endif

  # It's not possible to check VAT if the Status is not "submitted" or in creation or edit mode
  If [M:VFE0]STA <> [V]CST_SUBMITED or GREP = "M"
    Call VIREBOUT(CHAINE, "c") From GOBJET
  Else
    If instr(1, CHAINE, "c") = 0
      CHAINE += "c"
    Endif
  Endif

  # It's not possible to display the result if the Status is not submitted or rejected or in creation or edit mode
  If [M:VFE0]STA < [V]CST_SUBMITED or GREP = "M"
    Call VIREBOUT(CHAINE, "r") From GOBJET
  Else
    If instr(1, CHAINE, 'r') = 0
      CHAINE += "r"
    Endif
  Endif

Return
###################################################
$EXEBOUT

Local Integer WOK
  Case BOUT
    When "l"  : # Validate VAT

      If func CTRL_VAT_NUMBER([M:VFE1]EECNUM, [M:VFE1]VATFNC, WDIGIT_VAT_NUMBER, GMESSAGE) <> [V]CST_AOK
        mkstat = 2
        GERR = 1
        Return
      Endif

      WOK = [V]CST_AYES
      Call OUINON(mess(221,104,1), WOK) From GESECRAN
      If WOK <> [V]CST_AYES
        Return
      Endif

      Gosub TRT_VALIDATE_VAT From SUBVFE2
      Gosub RELIT From GOBJET
    When "s"  : # Submit VAT

      If func CTRL_VAT_NUMBER([M:VFE1]EECNUM, [M:VFE1]VATFNC, WDIGIT_VAT_NUMBER, GMESSAGE) <> [V]CST_AOK
        mkstat = 2
        GERR = 1
        Return
      Endif

      # issue X3-101747
      If func SUBVFE2.GET_CTRL_PARAM_URL([M:VFE1]VATFNC, [M:VFE1]CPY, [M:VFE1]CODURL, WURL, GMESSAGE) <> [V]CST_AOK
        mkstat = 2
        GERR = 1
        Return
      Endif
      # End issue X3-101747

      WOK = [V]CST_AYES
      Call OUINON(mess(222,104,1), WOK) From GESECRAN
      If WOK <> [V]CST_AYES
        Return
      Endif

      Gosub TRT_SUBMIT_VAT From SUBVFE2
      If GOK > 0
        Gosub RELIT From GOBJET
      Endif
    When "c"  : # Check status from VAT
      Call  CHKSTS_SBMVAT([M:VFE0]VATENTNUM, [M:VFE1]VERSION, WRTRN_CODE) From SUBVFE2
      Gosub RELIT From GOBJET
    When "r"
      # Action VFERES
    When Default
  Endcase

Return

###################################################
$LIENS

Local Char    LVATBOX(10), WSTYLE(10)

  # reading translatable text for DESTRA field
  Call LECTEXTRA ( [M:VFE0]DESTRA,
&                  "VATENTFRM",
&                  "DESTRA",
&                  [M:VFE0]VATFRM,[M:VFE1]VATFNC+"~"+[M:VFE1]LEG )
&                From ATEXTRA

  nolign = 0
  Raz [M:VFE2]NBBOX

  # Loading of the VAT boxes tab
  For [VFED]VFED0 Where VATENTNUM = [F:VFE]VATENTNUM

    If nolign >= dim([M:VFE2]VATBOX)
      Break
    Endif

    nolign += 1
    [M:VFE2] = [F:VFED]
    LVATBOX = [M:VFE2]VATBOX(nolign-1)

    # reading translatable text for DESLIN field
    Call LECTEXTRA ( [M:VFE2]DESLIN(nolign-1),
&                    "VATENTFRMD",
&                    "DESLIN",
&                    [M:VFE0]VATFRM,
&                    [M:VFE1]VATFNC+"~"+[M:VFE1]LEG+"~"+num$(LVATBOX) )
&                 From ATEXTRA
  Next

  Read [CPY]CPY0 = [M:VFE1]CPY
  [M:VFE1]EECNUM = [F:CPY]EECNUM
  [M:VFE1]LASSBM = func SUBVFE2.FMTDT([F:VFE]LASSBM)

  If func CTRL_VAT_NUMBER([M:VFE1]EECNUM, [M:VFE1]VATFNC, WDIGIT_VAT_NUMBER, GMESSAGE) <> [V]CST_AOK
    mkstat = 2
    GERR = 1
    Return
  Endif

  # issue X3-101747
  If func SUBVFE2.GET_CTRL_PARAM_URL([M:VFE1]VATFNC, [M:VFE1]CPY, [M:VFE1]CODURL, WURL, GMESSAGE) <> [V]CST_AOK
    mkstat = 2
    GERR = 1
    Return
  Endif
  # End issue X3-101747


  Read [F:VEF]VEF0 = [M:VFE0]VATFRM; [M:VFE1]VATFNC; [M:VFE1]LEG

  [M:VFE2]NBBOX = nolign
  Affzo [M:VFE2]

  For I = 1 To [M:VFE2]NBBOX
    WSTYLE = ""
    # Reading the form settings for style and formula retrieval
    Read [VEFD]VEFD1=[M:VFE0]VATFRM;[M:VFE1]VATFNC;[M:VFE1]LEG;[M:VFE2]VATBOX(I-1)
    If fstat = 0
      If  [F:VEFD]ASYCOD <> ""
        WSTYLE = [F:VEFD]ASYCOD
      Else
        WSTYLE = ""
      Endif
      Chgstl [M:VFE2]NBBOX(I-1) With WSTYLE
      [M:VFE2]FLDTYP(I-1) = [F:VEFD]FLDTYP
      [M:VFE2]CLCFOR(I-1) = [F:VEFD]CLCFOR
      [M:VFE2]CNDFOR(I-1) = [F:VEFD]CNDFOR
    Endif
  Next
  Affzo [M:VFE2]

  # It's not possible to modify DCLSTRDAT, DCLENDDAT, STA, VATRTNTYP if the VAT form status is not in progress or in error
  If  [M:VFE0]STA = [V]CST_IN_PROGRESS or [M:VFE0]STA = [V]CST_AERROR
    Actzo [M:VFE0]STA
    Actzo [M:VFE1]VATRTNTYP, DCLSTRDAT, DCLENDDAT
    # Issue X3-101745
    If [M:VFE1]VATFNC = "DCLVATBRI"
      Actzo [M:VFE1]PERNUM
    Else
      Diszo [M:VFE1]PERNUM
    Endif
    # End Issue X3-101745
    Actzo [M:VFE2]NBBOX
  Else
    Grizo [M:VFE0]STA
    Grizo [M:VFE1]VATRTNTYP, DCLSTRDAT, DCLENDDAT, PERNUM # Issue X3-101745
    Diszo [M:VFE2]NBBOX
  Endif

  If [M:VFE0]STA >= [V]CST_VALIDATED
    Diszo [M:VFE0]VATFRM
    Diszo [M:VFE1]VATFNC, LEG, CPY
  Else
    Actzo [M:VFE0]VATFRM
    Actzo [M:VFE1]VATFNC, LEG, CPY
  Endif
  Affzo [M:VFE0]VATFRM
  Affzo [M:VFE1]VATFNC, LEG, CPY, EECNUM, LASSBM

  # It's not possible to modify the VAT form if the VAT form status is "validated"
  If ([M:VFE0]STA = [V]CST_IN_PROGRESS or [M:VFE0]STA = [V]CST_AERROR)
    Actzo [M:VFE2]NBBOX
  Else
    Diszo [M:VFE2]NBBOX
  Endif
  Affzo [M:VFE2]NBBOX

  For I=1 To [M:VFE2]NBBOX
    If ([M:VFE0]STA = [V]CST_IN_PROGRESS or [M:VFE0]STA = [V]CST_AERROR) and [M:VFE2]TYPBOX(I-1) = 2 # detail
      Actzo [M:VFE2]VATAMT(I-1), COMMENT(I-1)
    Else
      Diszo [M:VFE2]VATAMT(I-1), COMMENT(I-1)
    Endif

    If [M:VFE2]TYPBOX(I-1) = 2
#      Actzo [M:VFE2]VATAMT(I-1)
      Case [M:VFE1]DEC
        When 0 :  GDEVFMTV  = "13.0"
        When 1 :  GDEVFMTV  = "12.1"
        When 2 :  GDEVFMTV  = "11.2"
        When 3 :  GDEVFMTV  = "10.3"
      Endcase
    Endif
    Chgfmt [M:VFE2]VATAMT(I-1) With "Nz3:"+GDEVFMTV
  Next

   G_DCLSTRDAT  = [F:VEF]VLYSTRDAT
   G_DCLENDDAT  = [F:VEF]VLYENDDAT

Return
###################################################
$FILGAUCHE

Local Char WSOC(GLONCPY)
Local Integer I, STAT, NBSOC, ISOC
Local Char TBSOC(GLONCPY) (0..)

  If GLEGFIL<>""
    If FILGAUCHE <> ""
      FILGAUCHE -= "&"
    Endif
    FILGAUCHE -= "(find([F:VFE]LEG, '" + GLEGFIL + "','') > 0)"
    If FILGAUSUP <> ""
      FILGAUSUP += " & "
    Endif
    FILGAUSUP += "(find([F:VFE]LEG, '" + GLEGFIL + "','') > 0)"
  Endif

  #... if there are no authorization restrictions
  If GUSRFCY(1)="\" or  GNBAUZ= GNBSITE : Return : Endif

  Raz TBSOC
  #... otherwise, only the authorized companies
  For [VFE]VFE2
    Call VERFALLFCY([F:VFE]CPY,[L]STAT) From SUPCPT
    If [L]STAT >=0
      TBSOC(I) = [F:VFE]CPY
      I +=1
    Endif
  Next

  NBSOC=I

  If NBSOC > 0
    Call ADDCRIT(CRITERE,IFILGAUSUP,"FILGAUCHE","(find([F:VFE]CPY,TBSOC)>0)","&") From GOBJSUB
  Endif

Return
###################################################
$FILTRE

Return
###################################################
$RAZCRE

  # X3-101659 [M:VFE1]LASSBM = AVOID.ADATTIM
  Raz [M:VFE1]LASSBM
  [M:VFE0]STA = [V]CST_IN_PROGRESS
  Affzo [M:VFE0]STA

Return
###################################################
$INICRE

  Raz [F:VFED]VATBOX  # If not empty, X3 display "Record already exists" (see keys on VATENTFRM Table)
  Raz [F:VFED]TYPBOX  # To inhibit the Transclass of Supervisor

  #----- Counter VATID recovery (at folder level only) -----#
  If GMANCOU <> 2
    Read [TCA]TCA0 = 2; ""; ""

    #*X3-112946 If fstat and GNBLEG = 1
    #*X3-112946   Read [TCA]TCA0 = 2; GDOSLEG; ""
    #*X3-112946 Endif

    #*X3-112946
    If fstat or [F:TCA]CODNUM(21)=""
      If GNBLEG=1
      Read [TCA]TCA0 = 2; GDOSLEG; ""
    Endif
    Endif #*X3-112946 END

    If fstat
      GMESSAGE= mess(22, 866, 1) - "error"
      GERR=1
      GOK=0
      Return
    Else
      VATIDSEQ = [F:TCA]CODNUM(21)
    Endif
    Call NUMERO(VATIDSEQ,"",[0/0/0],"",VATIDNUM,STAT) From SUBANM
    If GOK<0
      Return
    Elsif GOK < 1 or STAT <> 0
      Local Char MESSA(80)
      GMESSAGE = mess(60, 199, 1)-"("+VATIDSEQ+") : "
      Gosub MESSAGE From SUBANM
      GMESSAGE-=MESSA : GOK=0 : GERR=1
      Return
    Endif
    [F:VFE]VATENTNUM=VATIDNUM
    [M:VFE0]VATENTNUM=VATIDNUM
    Affzo [M:VFE0]VATENTNUM
  Else
    If  VATIDSEQ=""
    # The VAT declaration number must be entered
      GMESSAGE= mess(22, 866, 1)
      GERR=1
      GOK=0
      Return
    Endif
  Endif

Return
###################################################
$VERIF_CRE

 Local Integer VFE2_COUNT :  VFE2_COUNT=0

  Filter [VFE2] Where VATFRM      = [M:VFE0]VATFRM    &
&                     VATFNC      = [M:VFE1]VATFNC    &
&                     LEG         = [M:VFE1]LEG       &
&                     CPY         = [M:VFE1]CPY       &
&                     DCLSTRDAT   = [M:VFE1]DCLSTRDAT &
&                     DCLENDDAT   = [M:VFE1]DCLENDDAT
  VFE2_COUNT= rowcount([VFE2])
  Filter[VFE2]

  If VFE2_COUNT > 0
    GOK=0
    # There is already one declaration for the company and the period entered
    GMESSAGE = mess(217, 104, 1)
    Return
  Endif

  If GREP ="C" or GREP="D"

    Filter  [VFE2] Where (VATFRM =  [M:VFE0]VATFRM  and
&                         VATFNC =  [M:VFE1]VATFNC  and
&                         LEG    =  [M:VFE1]LEG     and
&                         CPY    =  [M:VFE1]CPY)    and
&            (([M:VFE1]DCLSTRDAT >= DCLSTRDAT and  [M:VFE1]DCLSTRDAT <= DCLENDDAT ) or
&             ([M:VFE1]DCLSTRDAT <= DCLSTRDAT and  [M:VFE1]DCLENDDAT >= DCLSTRDAT ) or
&             ([M:VFE1]DCLENDDAT >= DCLSTRDAT and  [M:VFE1]DCLENDDAT <= DCLENDDAT))
    Look [VFE2]VFE0  First
    Filter [VFE2]
    If fstat = 0
      GERR=1
      # Chevauchement de dates de validité non autorisé pour même 'Déclaration' et 'Législation'
      #'The declaration dates cannot overlap for the same 'Declaration' , 'Legislation' and company'
      GMESSAGE = mess(218, 104, 1)
      OK=0
      Return
    Endif
  Endif

  Gosub VERIF_CRE_MOD

Return
###################################################
$VERIF_MOD

    Filter  [VFE2] Where (VATFRM =  [M:VFE0]VATFRM  and
&                         VATFNC =  [M:VFE1]VATFNC  and
&                         LEG    =  [M:VFE1]LEG     and
&                         CPY    =  [M:VFE1]CPY     and
&                         VATENTNUM <>  [M:VFE0]VATENTNUM)    and
&            (([M:VFE1]DCLSTRDAT >= DCLSTRDAT and  [M:VFE1]DCLSTRDAT <= DCLENDDAT ) or
&             ([M:VFE1]DCLSTRDAT <= DCLSTRDAT and  [M:VFE1]DCLENDDAT >= DCLSTRDAT ) or
&             ([M:VFE1]DCLENDDAT >= DCLSTRDAT and  [M:VFE1]DCLENDDAT <= DCLENDDAT))
    Look [VFE2]VFE0  First
    Filter [VFE2]
    If fstat = 0
      GERR=1
      # Chevauchement de dates de validité non autorisé pour même 'Déclaration' et 'Législation'
      #'The declaration dates cannot overlap for the same 'Declaration' , 'Legislation' and company'
      GMESSAGE = mess(218, 104, 1)
      OK=0
      Return
    Endif
###################################################
$VERIF_CRE_MOD

  If [M:VFE1]DCLSTRDAT > [M:VFE1]DCLENDDAT
    GERR=1
    # Chevauchement de dates de validité non autorisé pour même 'Déclaration' et 'Législation'
    #'The declaration dates cannot overlap for the same 'Declaration' , 'Legislation' and company'
    GMESSAGE = mess(1,104,1) - ":" - format$("D:" + GFMDAT4, [M:VFE1]DCLSTRDAT) - ">" - format$("D:" + GFMDAT4, [M:VFE1]DCLENDDAT)
    OK=0
  Endif

  # Read the setting of the form to see if it's active or not (could have been disabled)
  Read[VEF]VEF0=[M:VFE0]VATFRM;[M:VFE1]VATFNC;[M:VFE1]LEG
  If fstat=0
    If [F:VEF]ENAFLG <> 2
      GOK=0
      # "The setting of the form is inactive"
      GMESSAGE = mess(213, 104, 1)
      Return
    Endif
  Endif

Return
###################################################
$CREATION

  # Create records in the VATFRMENT table (LIN > 0)
  For NOL=0 To [M:VFE2]NBBOX-1
   nolign = NOL+1
   [F:VFED]           = [M:VFE1]
   [F:VFED]           = [M:VFE2]
   [F:VFED]VATENTNUM  = [M:VFE0]VATENTNUM
   [F:VFED]LIN        = nolign

   Write [F:VFED]
   If fstat
    GOK = 0 : Call FSTA("VFED") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Return : Endif

Return
###################################################
$APRES_CRE

  Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..3)
  CLEPRIM   = 'VATENTNUM'   :# Issue X3-98320
  CLESEC(0) = 'VATFNC'      :# Issue X3-98320
  CLESEC(1) = 'LEG'
  CLESEC(2) = 'CPY'
  Gosub RELIT From GOBJET

Return
###################################################
$APRES_MOD

  Gosub APRES_CRE
  zoncou     = ""
  Gosub RAFFRAICHIR From GOBJSUB

Return
###################################################
$INIMOD

  Raz [F:VFED]VATBOX  # If not empty, X3 display "Record already exists" (see keys on VATENTFRM Table)
  Raz [F:VFED]TYPBOX  # To inhibit the Transclass of Supervisor

Return
###################################################
$MODIF

  Delete [VFED] Where VATENTNUM   = [F:VFE]VATENTNUM &
&                     VATFNC      = [F:VFE]VATFNC &
&                     LEG         = [F:VFE]LEG &
&                     CPY         = [F:VFE]CPY

  If fstat=1
    GOK = -1 : Call RSTA("VFED",[F:VFE]VATENTNUM-[F:VFE]VATFNC) From GLOCK : Return     :# Issue X3-98320
  Endif
  If GOK<1 : Return : Endif

  Gosub CREATION
  If GOK<1 : Return : Endif

Return
###################################################
$AV_ANNULE
Local Integer I
Local Char    LACTION(1), LVATBOX(10)

  For I=1 To [M:VFE2]NBBOX
    LACTION="A" : # Delete all
    LVATBOX=[M:VFE2]VATBOX(I-1)
  Next I

Return
###################################################
$ANNULE

  Local Integer VFE_COUNT :  VFE_COUNT=0

  Delete [VFED] Where VATENTNUM   = [F:VFE]VATENTNUM
  If fstat=1
    GOK = -1 : Call RSTA("VFED", [F:VFE]VATENTNUM-"/"-[F:VFE]VATFNC-"/"-[F:VFE]LEG) From GLOCK : Return     :# Issue X3-98320
  Endif
  If GOK<1 : Return : Endif

Return
###################################################
$CHARGE_BOX

Local Integer I
Local Char    WSTYLE(10)

 Raz [M:VFE2]NBBOX
 #*----------------------------------------------------------------
 #* Loading of the VAT boxes
 #*-----------------------------------------------------------------
  nolign=0
  Filter [VEFD] Where VATFRM = [M:VFE0]VATFRM and  VATFNC = [M:VFE1]VATFNC and LEG = [M:VFE1]LEG
  For [VEFD]VEFD0
    nolign+=1
    [M:VFE2] = [F:VEFD]
    LVATBOX = [M:VFE2]VATBOX(nolign-1)
    Call LECTEXTRA([M:VFE2]DESLIN(nolign-1), "VATENTFRMD", "DESLIN", [M:VFE0]VATFRM,
&                  [M:VFE1]VATFNC + "~" + [M:VFE1]LEG + "~" + num$(LVATBOX)) From ATEXTRA
  Next
  Filter [VEFD]       # Issue X3-98320

  [M:VFE2]NBBOX = nolign
  Affzo [M:VFE2]

  For I=1 To [M:VFE2]NBBOX
    If [M:VFE2]TYPBOX(I-1)=2
      Case [M:VFE1]DEC
        When 0 :  GDEVFMTV  = "13.0"
        When 1 :  GDEVFMTV  = "12.1"
        When 2 :  GDEVFMTV  = "11.2"
        When 3 :  GDEVFMTV  = "10.3"
      Endcase
    Endif
    Chgfmt [M:VFE2]VATAMT(I-1) With "Nz3:"+GDEVFMTV
   Next

  For I=1 To [M:VFE2]NBBOX
    WSTYLE = ""
    If  [M:VFE2]ASYCOD(I-1) <> ""
      WSTYLE =  [M:VFE2]ASYCOD(I-1)
    Else
      WSTYLE = ""
    Endif
    Chgstl [M:VFE2]NBBOX(I-1) With WSTYLE
    If ([M:VFE0]STA = [V]CST_IN_PROGRESS or [M:VFE0]STA = [V]CST_AERROR) and [M:VFE2]TYPBOX(I-1) = 2 # detail
      Actzo [M:VFE2]VATAMT(I-1)
      Actzo [M:VFE2]COMMENT(I-1)
    Else
      Diszo [M:VFE2]VATAMT(I-1)
      Diszo [M:VFE2]COMMENT(I-1)
    Endif
  Next

  For I=1 To [M:VFE2]NBBOX
    If  [M:VFE2]TYPBOX(I-1) =3 : # Total
      [M:VFE2]VATAMT(I-1)  = func CALCFOR([M:VFE2]CLCFOR(I-1))
      Affzo [M:VFE2]VATAMT(I-1)
    Endif
  Next

Return
###################################################
$SEL_TABLE

  Case TABLE
    When "SELVATFRM"     : Gosub SELVATFRM
  Endcase

Return
###################################################
$SEL_LISTE

  Case LISTE
    When "SELCPYVFE"      : Gosub SET_CPYFCY
  Endcase

Return
###################################################
$SELVATFRM

  If !clalev([F:VEF]) : Local File VATENTFRM    [VEF] : Endif

  Default File [VEF]
  TIT(0)  = mess(18,100,1)
  OBJET   = "VEF"
  START   = "VATFRM"
  ORDRE   = "VATFRM;VATFNC;LEG"
  CRITERE = "ENAFLG=2"

Return
#-------------------------------------------------------------------------------
$SET_CPYFCY

Local Integer STAT

# ******  List of authorized companies  *************
  NBTEX = 0
  Call TITOBJ("CPY","!",TIT(0)) From CONTOBJ
  TIT(0)  = mess(12,123,1)-TIT(0) : # Choix

  If clalev([F:WCPY])=0 : Local File COMPANY [WCPY] : Endif

  Local Integer MAXCPY
  [L]MAXCPY=rowcount([F:WCPY])
  Local Char TEX(50)(0..MAXCPY) , TEXTE(80)(1..MAXCPY,1..2)

  TIT(1) = mess(143,7773,1) : # Company
  TIT(2) = mess(15,7771,1)  : # Name

  For [F:WCPY] Where CPYLEGFLG=2 and LEG=[M:VFE1]LEG
    mkstat = 0
    Call VERFALLFCY([F:WCPY]CPY,[L]STAT) From SUPCPT
    If [L]STAT >=0
      NBTEX         += 1
      TEX(NBTEX)     = [F:WCPY]CPY
      TEXTE(NBTEX,1) = [F:WCPY]CPY
      TEXTE(NBTEX,2) = [F:WCPY]CPYNAM
    Else
      # Not to have an error message when companies for the legislation are not authorized
      mkstat=0 : GMESSAGE=""
    Endif
  Next

Return
###################################################
$FIN_TABLE

  Case TABLE
    When "SELVATFRM" : Gosub FIN_VATFRM
  Endcase

Return
###################################################
$FIN_VATFRM

   Diszo [M:VFE0]STA
   Diszo [M:VFE1]VATFNC, LEG, CPY, DCLSTRDAT, DCLENDDAT

   If [F:VEF]VATFRM = ""  or  [F:VEF]ENAFLG <> 2
     Disable GSTACRE
     Return
   Endif

   [M:VFE0]VATFRM       = [F:VEF]VATFRM
   [M:VFE1]VATFNC       = [F:VEF]VATFNC
   [M:VFE1]LEG          = [F:VEF]LEG
   G_DCLSTRDAT          = [F:VEF]VLYSTRDAT
   G_DCLENDDAT          = [F:VEF]VLYENDDAT
   [M:VFE1]AMTVATCUR    = [F:VEF]AMTVATCUR
   [M:VFE1]DEC          = [F:VEF]DEC

   Affzo [M:VFE0]VATFRM
   Affzo [M:VFE1]VATFNC, LEG, CPY, DCLSTRDAT, DCLENDDAT
   Actzo [M:VFE0]STA
   Actzo [M:VFE1]CPY, DCLSTRDAT, DCLENDDAT

   Call LECTEXTRA([M:VFE0]DESTRA, "VATENTFRM", "DESTRA", [M:VFE0]VATFRM, [M:VFE1]VATFNC + "~" + [M:VFE1]LEG) From ATEXTRA

   Gosub CHARGE_BOX

Return
###################################################
#**
#* for BRI VAT, the number must have 9 digits (sometimes, we cut th country at the beginning)
#*
#* @param PVATNUMBER
#* @param PVATFNC
#* @param RDIGIT_VAT_NUMBER
#* @param RMESSAGE
#*!
Funprog CTRL_VAT_NUMBER(PVATNUMBER, PVATFNC, RDIGIT_VAT_NUMBER, RMESSAGE)
Value Char PVATNUMBER()
Value Char PVATFNC()
Variable Char RDIGIT_VAT_NUMBER()
Variable Char RMESSAGE()

Local Integer I, WLENGTH
Local Char WCHAR(1)

  Raz RDIGIT_VAT_NUMBER, RMESSAGE
  If PVATFNC <> "DCLVATBRI"
    End [V]CST_AOK
  Endif

  WLENGTH = len(PVATNUMBER)
  For I = 1 To WLENGTH
    WCHAR = mid$(PVATNUMBER, I, 1)
    If WCHAR >= "0" and WCHAR <= "9"
      RDIGIT_VAT_NUMBER += WCHAR
    Endif
  Next I

  If len(RDIGIT_VAT_NUMBER) = 9
    End [V]CST_AOK
  Endif

  RMESSAGE = mess(6,127,1) - ":" - PVATNUMBER
End [V]CST_AERROR

# End Issue X3-91223

###################################################
## Labels of VATENT1 screen
###################################################
#=====================================#
Subprog AM_VATFRM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = [M:VFE0]VATFRM
    End
  Endif

  Filter [VEF] Where VATFRM = VALEUR and ENAFLG = [V]CST_AYES
  Read [VEF]VEF0 First
  Filter [VEF]
  If fstat
    GERR=1
    # "Form does not exist or is inactive"
    GMESSAGE = mess(214, 104, 1)
    mkstat=2
    End
  Endif

  [M:VFE1]CPY       = ""
  [M:VFE1]DCLSTRDAT = [0/0/0]
  [M:VFE1]DCLENDDAT = [0/0/0]

  [M:VFE0]VATFRM    = VALEUR
  [M:VFE1]VATFNC    = [F:VEF]VATFNC
  [M:VFE1]LEG       = [F:VEF]LEG
  G_DCLSTRDAT       = [F:VEF]VLYSTRDAT
  G_DCLENDDAT       = [F:VEF]VLYENDDAT
  [M:VFE1]AMTVATCUR = [F:VEF]AMTVATCUR
  [M:VFE1]DEC       = [F:VEF]DEC

  Affzo [M:VFE0]VATFRM
  Affzo [M:VFE1]VATFNC, LEG, CPY, DCLSTRDAT, DCLENDDAT
  Actzo [M:VFE0]STA
  Actzo [M:VFE1]CPY, DCLSTRDAT, DCLENDDAT

  Call LECTEXTRA([M:VFE0]DESTRA, "VATENTFRM", "DESTRA", [M:VFE0]VATFRM, [M:VFE1]VATFNC + "~" + [M:VFE1]LEG) From ATEXTRA
  Gosub CHARGE_BOX

End
#=====================================#
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()

End
#=====================================#
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

Local Char WDIGIT_VAT_NUMBER(30), WURL(250)
 # Check that there is at least one authorized site for the company
 Call CONTALLFCY(VALEUR) From CFYSUB
 If mkstat
   # At least one site is not authorized for the company
   GMESSAGE = mess(277, 133, 1)-VALEUR :
   End
 Endif
 [M:VFE1]EECNUM = [F:CPY]EECNUM

  If func CTRL_VAT_NUMBER([M:VFE1]EECNUM, [M:VFE1]VATFNC, WDIGIT_VAT_NUMBER, GMESSAGE) <> [V]CST_AOK
    mkstat = 2
    GERR = 1
    End
  Endif

  # issue X3-101747
  If func SUBVFE2.GET_CTRL_PARAM_URL([M:VFE1]VATFNC, VALEUR, [M:VFE1]CODURL, WURL, GMESSAGE) <> [V]CST_AOK
    mkstat = 2
    GERR = 1
    End
  Endif
  Affzo [M:VFE1]CODURL
  # End issue X3-101747

#If VALEUR <> [M:VFE1]CPY
#  GREP = "C"
#Endif
End
#=====================================#
Subprog AM_DCLSTRDAT(VALEUR)
Variable Date    VALEUR

  #  DCLESTRDAT Must be in validity period of setup
  If VALEUR = [0/0/0] or VALEUR < G_DCLSTRDAT or VALEUR > G_DCLENDDAT
    GERR=1
    #"The declaration start date must be included in the limits defined in the form"
    GMESSAGE=mess(215, 104, 1)
    mkstat=2
    End
  Endif

End
#=====================================#
Subprog AM_DCLENDDAT(VALEUR)
Variable Date    VALEUR

  #  > DCLENDDAT   must be in validity period of setup
  If VALEUR = [0/0/0] or VALEUR < G_DCLSTRDAT or VALEUR > G_DCLENDDAT
    GERR=1
    #"The declaration end date must be included in the limits defined in the form"
    GMESSAGE=mess(216, 104, 1)
    mkstat=2
    End
  Endif

End
