#
  #  > DCLSTRDAT  must be in validity period of setup
  If VALEUR = [0/0/0] or VALEUR < G_DCLSTRDAT or VALEUR > G_DCLENDDAT
    GERR=1
    #"The declaration start date must be included in the limits defined in the form"
    GMESSAGE=mess(215, 104, 1)
    mkstat=2
    End
  Endif

End
