Variable Date    VALEUR

  #  > DCLENDDAT   must be in validity period of setup
  If VALEUR = [0/0/0] or VALEUR < G_DCLSTRDAT or VALEUR > G_DCLENDDAT
    GERR=1
    #"The declaration end date must be included in the limits defined in the form"
    GMESSAGE=mess(216, 104, 1)
    mkstat=2
