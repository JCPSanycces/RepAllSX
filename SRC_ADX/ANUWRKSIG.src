#<AdxTL>@(#)6.0.0.0 $Revision$
Call ANUSIG("","MB")
End

#-----------------------------------------------------------#
# Appelé par le moniteur workflow
#-----------------------------------------------------------#

Subprog ANUSIG(CHRONO,USRDES)
Value Char CHRONO , USRDES , NEWACT
Local Char PARAM(250)(1..6) , VALEUR(10) , SPETRT(GLONADC)
PARAM(1) = CHRONO
PARAM(2) = USRDES
Call TRTSPE(nomap,"ANUWRK",SPETRT) From SUBACT
Call TRAITE_CHAR(VALEUR,PARAM,"","ANUWRKSIG","",1,SPETRT) From GTRAITE
GOK = val(PARAM(3))
End

#-----------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#--------------- GTRAITE -----------------------------------#
$INIT
Local Integer ERN , ERD , ERT , NUM , NBCLE , VERROU , STAT
Local Char    CHRONO(GLONVCR) , NUMORG(GLONVCR) , NUMGRP(GLONVCR) , CHRREF(GLONVCR)
Local Char    USRORG(GLONAUS) , USRDES(GLONAUS) , USRSIG(GLONAUS) , USRMAIL(GLONMAI)
Local Char    WRKORG(GLONAWA) , USRTOP(GLONAUS)
Local Char    ERM(250) , PREF(3)
Local Char    NOMPROG(GLONADC) , NOMPRIG(GLONADC) , PROGOBJ(GLONADC)
Local Char    CHAINE(250) , VALCLE(250) , CLE(GLONID1)(1..16)
Local Char    FILTRE(250) , RESULT(250) , NEWACT(GLONADI)
Local Char    SYMBOLE(80) , POSTE(80) , UTIL(GLONID1) , VERHIS(30)
Local Char    VEROBJ(80) , FORMULE(255)
Local Char    REASON(GLONDES) , REACOD(GLONADI)
Local Integer REANUM
Local Char    SAVCOD(GLONAWA) , SAVREG(GLONAWR) , SAVMOD(GLONAWM)
Local Date    DATSIG
Local Char    TIMSIG(10)
Local Char    S_USER(GLONAUS) , S_CLEOBJ(GLONID2) , S_ABREV(GLONAOB)
Local Integer LEVSIG , S_NBRUSR , NBRUSR

If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif
If clalev([F:AWV])=0  : Local File AWRKREGVAL [AWV]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif

Local Char    CTX(GLONID1)(1..dim([F:AWF]VARCTX)) , USER(GLONAUS)(1..dim([F:AWV]USER))

CHRONO  = PARAM(1)        : # Chrono de l'évènément sur lequel on va annuler la signature
USRDES  = PARAM(2)        : # Code user du destinataire
STAT    = 0               : # Erreur Status de fin d'annulation

# Chrono à annuler
STAT = 4
Read [AWS2]AWS0 = CHRONO;USRDES
If !fstat
 Case [F:AWS2]FLGSIG
  When 1       : STAT = 2
  When 2,3     : STAT = 3
  When Default : STAT = 0
 Endcase
Else
 For [AWS2]AWS0 Where [F]CHRONO=[L]CHRONO
  USRDES = [F:AWS2]DEST
  Case [F:AWS2]FLGSIG
   When 1       : STAT = 2
   When 2,3     : STAT = 3
   When Default : STAT = 0
  Endcase
  Break
 Next AWS2
Endif
Case STAT
 When 2 : ERM = USRDES-CHRONO-":"-mess(157,75,1) : # Suivi annulé
 When 3 : ERM = USRDES-CHRONO-":"-mess(111,75,1) : # Suivi non signé
 When 4 : ERM = USRDES-CHRONO-":"-mess(100,75,1) : # Suivi non trouvé
Endcase
If STAT : Goto ERREUR : Endif

# Chrono à annuler
NUMORG = [F:AWS2]NUMORG   : # Chrono de l'évènement d'origine sur lequel a été faite la première signature
USRORG = [F:AWS2]USRORG   : # Destinataire de cet événement
USRTOP = [F:AWS2]USRTOP   : # Destinataire principal (les autres sont des délégués)
NUMGRP = [F:AWS2]NUMGRP   : # Groupe de l'évènement à signer
DATSIG = [F:AWS2]DATSIG
TIMSIG = [F:AWS2]TIMSIG
If NUMORG<>""
 CHRREF = NUMORG          : # Chrono de l'évènement principal
Else
 CHRREF = CHRONO
Endif
For I=1 To dim(CTX)
 CTX(I) = evalue("[F:AWS2]VALCTX"+num$(I))
Next I
S_USER   = [F:AWS2]EMETTEUR
S_CLEOBJ = [F:AWS2]CLEDEC
LEVSIG   = [F:AWS2]LEVSIG
NBRUSR   = [F:AWS2]NBRUSR
For J=1 To NBRUSR
 If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
  USER(J) = evalue("[F:AWS2]USRSIG"+num$(J))
 Endif
Next J

# Chrono origine
If NUMORG<>""
 Read [AWS2]AWS0 = NUMORG;USRORG
 If fstat
  ERM = NUMORG-USRORG-":"-mess(113,75,1) : # Suivi d'origine non trouvé
  STAT = 2 : Goto ERREUR
 Endif
Else
 Read [AWS2]AWS0 = CHRONO;USRDES
Endif
Call SET_PREF([F:AWS2]CODWRK,PREF) From SUBAWA
NOMPRIG = PREF+[F:AWS2]CODWRK
S_ABREV  = [F:AWS2]ABROBJ
S_NBRUSR = [F:AWS2]NBRUSR

# Règle d'origine
Read [AWA]AWA0 = [F:AWS2]CODWRK
If fstat
 ERM = [F:AWS2]CODWRK-":"-mess(107,75,1) : # Paramètrage workflow inexistant
 STAT = 2 : Goto ERREUR
Endif
Read [AWF]AWF0 = [F:AWS2]CODWRK

ERD = ([F:AWA]DEBUG=2)
ERN = 0

# On vérifie que personne n'est en train de signer ces chronos
VERHIS = func GOBJACT.SYMBOLE_VERROU("AWS","")
For SYMBOLE=VERHIS+CHRONO,VERHIS+NUMORG
 If len(SYMBOLE)>3
  Call DEBTRANS From GLOCK
  Gosub VERROU
  If !VERROU
   Call QUILOCKE(SYMBOLE,POSTE,UTIL) From OBJDIV
   ERM = mess(82,75,1) : # Signature en cours
   If UTIL<>""
    ERM += "\"+UTIL+"\"+POSTE
   Endif
   ERM += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
   STAT = 1 : Break
  Endif
 Endif
Next SYMBOLE
If STAT : Goto ERREUR : Endif
Return

#----------------------------------------------------#
$CONTROLE

# Si la signature de ce chrono a déclenché une autre signature,
# on vérifie que cette signature n'a pas été signée (pas visée)
K = 1
For [AWS2]AWS1 Where NUMORG=CHRREF & [F]CHRONO>[L]CHRONO
 If [F:AWS2]DATSIG=[L]DATSIG & [F:AWS2]TIMSIG>=[L]TIMSIG & [F:AWS2]FLGSIG & [F:AWS2]FLGSIG<>4
  K = 0 : Break
 Elsif [F:AWS2]DATSIG>[L]DATSIG & [F:AWS2]FLGSIG<>4
  K = 0 : Break
 Endif
Next AWS2
If !K
 # Annulation impossible\Chrono déjà signé
 ERM = mess(49,117,1)+"\"+[F:AWS2]CHRONO-mess(127,75,1)
 STAT = 2 : Goto ERREUR
Endif
Return

#----------------------------------------------------#
$SORTIE
PARAM(3) = num$(GOK) : # Status de signature
Gosub DEVERROU
Return

#----------------------------------------------------#
$EXEC

# Trace
If ERD
 If !GSERVEUR
  Call OUVRE_TRACE(mess(158,75,1)-CHRONO) From LECFIC : # Annulation du suivi
  TRA = 1
 Else
  ERM = string$(80,"-")+"\"+mess(158,75,1)-CHRONO+"\"+string$(80,"-")
  Gosub TRACE
 Endif
Endif

# Chrono origine
If NUMORG<>""
 Read [AWS2]AWS0 = NUMORG;USRORG
Else
 Read [AWS2]AWS0 = CHRONO;USRDES
Endif

# Si l'évènement déclenchant est un objet on locke l'objet
If [F:AWS2]TYPEVT=2
 PROGOBJ = "WO"+[F:AWS2]CODEVT
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 CHAINE = [F:AWS2]CLEOBJ
 NBCLE = 0
 While CHAINE<>""
  NBCLE += 1
  I = instr(1,CLE,"~")
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
 If TYPGES=2
  SYMBOLE = NOMFIC
 Else
  Case NBCLE
   When 1
    SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1))
   When Default
    If TYPGES=3
     SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1)+"\"+CLE(2))
    Else
     SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(2)+"\"+CLE(1))
    Endif
    For I=3 To NBCLE
     SYMBOLE += "\"+CLE(I)
    Next I
  Endcase
 Endif
 Call DEBTRANS From GLOCK
 Gosub VERROU
 If !VERROU
  Call QUILOCKE(SYMBOLE,POSTE,UTIL) From OBJDIV
  # Fiche $1$ verrouillée dans l'objet $2$
  ERM = func AFNC.MES2(mess(83,143,1),right$(SYMBOLE,len(ABFIC)+1),[F:AWS2]CODEVT)
  If UTIL<>""
   ERM = "\"+UTIL+"\"+POSTE
  Endif
  ERM += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
  STAT = 1 : Goto ERREUR
 Endif
 VEROBJ = SYMBOLE
Endif

# Lecture de la table principale
Gosub OUVREF From =NOMPRIG
OK = (TABREF<>"")
If OK
 Gosub LNKREF From =NOMPRIG
 CHAINE = [F:AWS2]IDENTREF
 K = instr(1,CHAINE,"/")
 CHAINE = right$(CHAINE,K+1)
 For I=1 To dim(DEFREF)
  If DEFREF(I)<>""
   K = instr(1,CHAINE,"~")
   If K
    VALCLE = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    VALCLE = CHAINE
    CHAINE = ""
   Endif
   Onerrgo ERR
   Case TYPREF(I)
    When 1,2,3,4,5,6 : Assign ("[F]"+DEFREF(I)) With val(VALCLE)
    When Default     : Assign ("[F]"+DEFREF(I)) With VALCLE
   Endcase
   Onerrgo
   If ERN : ERN = 0 : Break : Endif
  Endif
 Next I
 Read [F] =
 If fstat
  ERM = [F:AWS2]IDENTREF-":"-mess(81,75,1) : # Enregistrement non trouvé
  STAT = 2 : Goto ERREUR
 Endif
 Gosub LECENT From =NOMPRIG : # Lecture des tables 1,1
Endif

# Ouverture de la table des lignes
If OK
 Gosub LNKGRP From =NOMPRIG : # Filtre groupe
 CHAINE = [F:AWS2]IDENTGRP
 K = instr(1,CHAINE,"/")
 CHAINE = right$(CHAINE,K+1)
 Raz FILTRE
 For I=1 To dim(DEFGRP)
  If DEFGRP(I)<>""
   K = instr(1,CHAINE,"~")
   If K
    VALCLE = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    VALCLE = CHAINE
    CHAINE = ""
   Endif
   If I>1 : FILTRE += ' & ' : Endif
   FILTRE += DEFGRP(I)+'='
   Case TYPGRP(I)
    When 1,2,3,4,5,6 : FILTRE += VALCLE
    When 8           : FILTRE += '['+right$(VALCLE,7)+'/'+mid$(VALCLE,5,2)+'/'+left$(VALCLE,4)+']'
    When Default     : FILTRE += '"'+VALCLE+'"'
   Endcase
  Endif
 Next I
 If FILTRE="" : FILTRE = "1=1" : Endif
 # Pour se positionner sur un des enregistrements du groupe
 Gosub LNKLIG From =NOMPRIG : # Ouverture du link
 If clalev([F:LNK_])>0
  For [LNK_] Where evalue(FILTRE)
   Break
  Next LNK_
 Endif
Endif

# Chrono à annuler
Read [AWS2]AWS0=[L]CHRONO;[L]USRDES

# Recherche de l'opération CAN dans la règle workflow de l'évènement d'origine
Raz NEWACT
For I=1 To [F:AWF]NBRSIG
 If [F:AWF]OPESIG(I-1)="CAN"
  K = 1
  If [F:AWF]CNDSIG(I-1)<>""
   FORMULE = format$("KTv2:250X",[F:AWF]CNDSIG(I-1))
   Onerrgo ERR
   K = val(num$(evalue(FORMULE)))
   Onerrgo
   FORMULE = ""
   If ERN : K = 0 : Endif
  Endif
  If K
   NEWACT = [F:AWF]ACTSIG(I-1)
   Break
  Endif
 Endif
Next I
If NEWACT=""
 ERM = mess(49,117,1) : # Annulation impossible
 STAT = 2 : Goto ERREUR
Endif
NUM = find(NEWACT,[F:AWF]ACTSIG)

# Evaluation de la formule , modif éventuelle du résultat et saisie éventuelle du motif
Raz RESULT , FORMULE , REASON , REANUM , REACOD
If NUM
 If [F:AWF]EXPVAL(NUM-1)<>""
  FORMULE = format$("KTv2:255X",[F:AWF]EXPVAL(NUM-1))
  Onerrgo RIEN
  RESULT = num$(evalue(FORMULE))
  Onerrgo
  FORMULE = ""
 Endif
 If [F:AWF]MODSIG(NUM-1)=2
  Gosub VALSIG From =NOMPRIG
  If !GSERVEUR
   Call SAICAR(RESULT,mess(158,75,1),INTZON,TYPZON,LIBZON,LNGZON,"",OK) From GESECRAN : # Annulation signature
  Endif
 Endif
 If !GSERVEUR
  If [F:AWF]REANUM(NUM-1)<>0
   REANUM = [F:AWF]REANUM(NUM-1)
   Call SAICAR(REACOD,mess(155,75,1),mess(155,75,1),"ADI",REANUM,0,"",OK) From GESECRAN : # Motif réponse
   If REACOD<>""
    Call LECTEXTRA(REASON,"ATABDIV","LNGDES",num$(REANUM),REACOD) From ATEXTRA
   Endif
  Endif
 Endif
Endif

# Transaction annulation signature
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_ANU
Else
 Gosub ANU
Endif

If GOK=1
 ERM = CHRONO-":"-mess(157,75,1) : # Suivi annulé
 Gosub TRACE
Endif

# Fin de trace
If ERD
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
 Else
  ERM = string$(80,"-")
  Gosub TRACE
 Endif
Endif

Return

#------------------------------------------------------------------------------------#
$TR_ANU
Trbegin [AWA]
 Gosub ANU
 If GOK=-1 : Goto ROLL_ANU
 Elsif GOK<1 : Goto AB_ANU
 Endif
Commit
Return

$AB_ANU
Rollback
Return

$ROLL_ANU
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANU : Endif

#------------------------------------------------------#
$ANU
# Mise à jour du champ défini dans le paramètrage workflow
If GOK=1 & NUM & [F:AWF]FLDMAJ(NUM-1)<>""
 If clalev([F:LNK_])>0
  Gosub MAJ_LINK : # Mise à jour groupe
 Else
  Gosub MAJ_TABLE : # Mise à jour sur une des tables liées 1,1
 Endif
Endif

# Traitement du workflow associé à l'action
If GOK=1 & NUM & [F:AWF]OPESIG(NUM-1)<>""
 ERM = mess(159,75,1)-[F:AWF]OPESIG(NUM-1)-CHRONO : # Exécution workflow annulation signature
 Gosub TRACE
 CHAINE  = [L]CHRREF
 CHAINE += "~"+USRORG
 CHAINE += "~"+CHRONO
 CHAINE += "~"+USRDES
 CHAINE += "~"+GUSER
 CHAINE += "~"+num$(LEVSIG)
 CHAINE += "~"+REASON
 Call WORKFLOW(1,"CAN","",CHAINE) From AWRK
Endif

# Annulation de la ligne du suivi (uniquement signature des suivis du destinataire principal)
If GOK=1
 Gosub MAJ_SUI
Endif

Return

#-------------------------------------------------------------------#
$DEVERROU
VERHIS = func GOBJACT.SYMBOLE_VERROU("AWS","")
For SYMBOLE=VERHIS+CHRONO,VERHIS+NUMORG,VEROBJ
 If len(SYMBOLE)>3
  Unlock =SYMBOLE
 Endif
Next SYMBOLE
Return

#-------------------------------------------------------------------#
$VERROU
Lock =SYMBOLE With lockwait=0
If !fstat
 VERROU = 1
Else
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL
  VERROU = 0
 Else
  Goto VERROU
 Endif
Endif
Return

#----------------------------------------------------#
$RIEN
Resume

#----------------------------------------------------#
$ERR
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
Gosub TRACE
Resume

#----------------------------------------------------#
$TRACE
If ERD
 If FORMULE<>""
  ERM += "\"+mess(65,106,1)-"\"+FORMULE : # Erreur en évaluation de la formule
 Endif
 Call ECR_TRACE(ERM,ERN) From GESECRAN
Endif
Return

#----------------------------------------------------#
$ERREUR
If ERM<>""
 Call ECR_TRACE(ERM,STAT) From GESECRAN
Endif
Gosub DEVERROU
Case STAT
 When 1       : PARAM(6) = "-1" : # On a le droit de réessayer (Erreur de lock)
 When Default : PARAM(6) = "0"  : # Erreur grave
Endcase
FIN = 1
Return

#----------------------------#
$MAJ_LINK
Gosub DEFSUI From =NOMPRIG
If TABSUI<>""
 For [LNK_] Where evalue(FILTRE)
  Gosub REW_LINK
  If GOK<1 : Break : Endif
 Next LNK_
Endif
Return

$REW_LINK
Readlock =
If fstat=1
 GOK=-1 : GLOCK="$"+TABSUI : Return
Elsif fstat
 GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
Endif
Onerrgo ERR
Case evalue("type("+[F:AWF]FLDMAJ(NUM-1)+")")
 When 1,2,4,5,6,7 : Assign [F:AWF]FLDMAJ(NUM-1) With val(RESULT)
 When 3           : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
 When Default     : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
Endcase
Onerrgo
If ERN
 Raz ERN : Return
Else
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
 Endif
 ERM = mess(92,75,1)-[F:AWF]FLDMAJ(NUM-1)-"("+RESULT+")" : # Mise à jour du champ
 If CLEGRP<>""
  ERM -= "-"-mess(139,75,1)-evalue(CLEGRP) : # Regroupement
 Endif
 Gosub TRACE
Endif
Return

#----------------------------#
$MAJ_TABLE
Gosub DEFSUI From =NOMPRIG
If TABSUI<>""
 Readlock =
 If fstat=1
  GOK=-1 : GLOCK="$"+TABSUI : Return
 Elsif fstat
  GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
 Endif
 Onerrgo ERR
 Case evalue("type("+[F:AWF]FLDMAJ(NUM-1)+")")
  When 1,2,4,5,6,7 : Assign [F:AWF]FLDMAJ(NUM-1) With val(RESULT)
  When 3           : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
  When Default     : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
 Endcase
 Onerrgo
 If ERN
  Raz ERN
 Else
  Rewrite [F]
  If fstat
   GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
  Endif
  ERM = mess(92,75,1)-[F:AWF]FLDMAJ(NUM-1)-"("+RESULT+")" : # Mise à jour du champ
  Gosub TRACE
 Endif
Endif
Return

#----------------------------------------------------#
$MAJ_SUI
For [AWS2]AWS0 Where [F]CHRONO=[L]CHRONO
 Readlock [AWS2]AWS0 Curr
 If fstat=1
  GOK=-1 : GLOCK="$AWRKHISSUI" : Break
 Elsif fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
 [F:AWS2]FLGSIG = 3 : # A signer
 [F:AWS2]ACTSIG = ""
 [F:AWS2]USRSIG = ""
 [F:AWS2]MAISIG = ""
 [F:AWS2]DATSIG = [0/0/0]
 [F:AWS2]TIMSIG = "000000"
 [F:AWS2]REASON = [L]REASON
 [F:AWS2]REANUM = [L]REANUM
 [F:AWS2]REACOD = [L]REACOD
 Rewrite [AWS2]
 If fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
Next AWS2
If GOK<1 : Return : Endif
For [AWS2]AWS1 Where NUMORG=CHRREF & [F]CHRONO>[L]CHRONO
 Readlock [AWS2]AWS0 Curr
 If fstat=1
  GOK=-1 : GLOCK="$AWRKHISSUI" : Break
 Elsif fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
 [F:AWS2]FLGSIG = 1 : # Annulé
 [F:AWS2]REASON = [L]REASON
 [F:AWS2]REANUM = [L]REANUM
 [F:AWS2]REACOD = [L]REACOD
 Rewrite [AWS2]
 If fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
Next AWS2
Return

