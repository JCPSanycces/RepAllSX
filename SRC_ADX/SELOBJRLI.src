#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "SEL_TABLE" : Gosub SEL_TABLE
        When Default     : Gosub SEL_DEFAULT
    Endcase
Return


$SEL_DEFAULT
Return


#** #####################################################################################
#*
#* Sub chunk:  SEL_TABLE
#*
#* Purpose:    ...
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$SEL_TABLE
    # Set selection column. This will be the column for the return value of the selection.
    #
    # Note: The standard for a combined object is the second index key. But in our case we
    #       need the third one.

    Case TABLE
        When "REPLINDEF"
            OBJET = "REPLIND2"
            START = "[F:RLI]COD"
            CRITERE = PARAM(1) # Parameter "Filtre" from action SELOBJRLI
            ORDRE = "[F:RLI]COD"
    Endcase
Return

