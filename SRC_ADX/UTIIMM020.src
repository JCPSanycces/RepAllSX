#<AdxTL>@(#)7.0.0.0 $Revision$
# Sert à initialiser le nouveau champ FLGCNXFLX de la table FXDLIFL FQ66894
  Call PATCH(nomap)
End

Subprog EXE_UTIIMM014(APPLI)
Value Char APPLI

  If clalev([F:WFAS]) : Close Local File [WFAS] : Endif
  Local File =APPLI+".FXDASSETS" [WFAS]
  If clalev([F:WCNX]) : Close Local File [WCNX] : Endif
  Local File =APPLI+".CONTEXT" [WCNX]
  If clalev([F:WCPY]) : Close Local File [WCPY] : Endif
  Local File =APPLI+".COMPANY" [WCPY]

  Call ECR_TRACE("UTIIMM014: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM014

  Call ECR_TRACE("UTIIMM014: Process End on : "+APPLI,0) From GESECRAN

  If clalev([F:WFAS]) : Close Local File [WFAS] : Endif
  If clalev([F:WCNX]) : Close Local File [WCNX] : Endif
  If clalev([F:WCPY]) : Close Local File [WCPY] : Endif
End


#### Corps de la moulinette - début
$TR_UTIIMM014
  Trbegin [WFAS]

  Local Char     FLXGENE(G300MAX), FLXNOTG(G300MAX)
  Local Shortint N_PLAN, N_CNX
  Local Integer  NB_BCO
  Local Date     CNXDATDEB(G300MAX)
  Local Date     CNXDATFIN(G300MAX)

  For [F:WCPY]
    [L]FLXGENE="33333333333"
    [L]FLXNOTG="33333333333"
    For [F:WCNX] Where CPY=[F:WCPY]CPY
      For N_PLAN = 0 To [F:WCNX]NBPLC-1
        If [F:WCNX]FLUTRATXS(N_PLAN) <> "" or [F:WCNX]FLUTRAACC(N_PLAN) = G_OUI
          [L]FLXGENE = func GLOFUNC.SETRNGSTR([L]FLXGENE, [F:WCNX]CNX, "1")
          [L]FLXNOTG = func GLOFUNC.SETRNGSTR([L]FLXNOTG, [F:WCNX]CNX, "2")
        Endif
      Next
    Next

    For [WFAS] Where CPY=[F:WCPY]CPY and [F:WFAS]FLGCNXFLX=""
      If ([F:WFAS]OWNTYP=GVML_TDMODEL) or ([F:WFAS]OWNTYP=GVML_TDANNUL) or ([F:WFAS]ISSFIYPRE=G_OUI)
        [F:WFAS]FLGCNXFLX = [L]FLXGENE
      Else
        [F:WFAS]FLGCNXFLX = [L]FLXNOTG
      Endif

      Rewrite [F:WFAS] Curr
      If fstat
        Call ECR_TRACE(mess(13,100,1)-"FXDASSETS"-num$(fstat),1) From GESECRAN
        GOK = -1
        Break 2
      Endif

      NB_BCO += 1
    Next
  Next

  If !GOK Then
    Goto AB_UTIIMM014
  Else
    Call ECR_TRACE(mess(192,124,1)-" FXDASSETS :"-num$(NB_BCO),0) From GESECRAN
    Commit
  Endif
Return

$AB_UTIIMM014
  Rollback
Return
#### Corps de la moulinette - fin


Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(4) <> 2 : End : Endif

  If filinfo(filpath("FIL","FXDASSETS","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM014(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=GDOSX3 : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  # cg correction module
  If [F:ADS]MODULE(13) <> 2 : End : Endif

  If filinfo(filpath("FIL","FXDASSETS","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM014(APPLI)
End
