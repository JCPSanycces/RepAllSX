#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet AYD
Call OBJET("AYD",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion des Profils Xtend 
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "SETBOUT"        : Gosub SETBOUT
 When "MODIF"          : Gosub MODIF
 When "CREATION"       : Gosub CREATION
 When "ANNULE"         : Gosub ANNULE
 When default
Endcase
Return

#---------------------------------------------------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT,"AYTPRF","INTIT",[M]FCYCOD,[M]PRFCOD) From  ATEXTRA
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTPRF" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

#---------------------------------------------------------------#
$AVANT_OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#

$OUVRE
Local Char WSTR1 (250)
Local Integer WI
Gosub DSYFCY From SUBAYS     # Infos site
#If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
#Read [F:AYS]AYS0 = GAYTFCYWRK 
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
Call AFF_PAG([M]ALLACS) 
Call AFF_INT([M]ALLACS)
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Endif
Return

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYD1]PRFCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
Call AFF_PAG([M]ALLACS) : Affzo [M:AYD1]15
# Modif SB interfaces protégées
Call AFF_INT([M]ALLACS) : Affzo [M:AYD1]20
# Fin modif SB interfaces protégées
Return

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]PRFCOD 
#
Raz [F:AYD]PAGNBR, [F:AYD]PAGCOD        
If [M]ALLACS=1    # pas tous
    For WI=0 To [M]PAGNBR-1
        If [M]PAGACS(WI)=2
            [F:AYD]PAGCOD([F:AYD]PAGNBR)=[M]PAGCOD(WI)
            [F:AYD]PAGNBR+=1
        Endif
    Next
Endif
# Modif SB interfaces protégées
Raz [F:AYD]INTNBR, [F:AYD]INTCOD        
If [M]ALLACS=1    # pas tous
    For WI=0 To [M]INTNBR-1
        If [M]INTACS(WI)=2
            [F:AYD]INTCOD([F:AYD]INTNBR)=[M]INTCOD(WI)
            [F:AYD]INTNBR+=1
        Endif
    Next
Endif
# Fin modif SB interfaces protégées


Return
#---------------------------------------------------------------#

######################################################################################
# Utilitaires
######################################################################################
Subprog AFF_PAG(A_ALLACS)
Value Integer A_ALLACS
Raz [M]PAGCOD, [M]PAGNBR, [M]PAGACS
If A_ALLACS=2 : Grizo [M]PAGACS : Else : Actzo [M]PAGACS : Endif
For [AYG]AYG0 Where FCYCOD=[M]FCYCOD and ACSMOD=2    # Protégé
    [M]PAGCOD([M]PAGNBR)=[F:AYG]PAGCOD
    If A_ALLACS=2 
        [M]PAGACS([M]PAGNBR)=2
    Else
        WJ=find([M]PAGCOD([M]PAGNBR), [F:AYD]PAGCOD)
        If WJ : [M]PAGACS([M]PAGNBR)=2 : Else : [M]PAGACS([M]PAGNBR)=1 : Endif
    Endif
    [M]PAGNBR+=1
Next
End

# Modif sb Ajout interface protégée
Subprog AFF_INT(A_ALLACS)
Value Integer A_ALLACS
Raz [M]INTCOD, [M]INTNBR, [M]INTACS
If A_ALLACS=2 : Grizo [M]INTACS : Else : Actzo [M]INTACS : Endif
For [AYI]AYI0 Where FCYCOD=[M]FCYCOD and ACSMOD=2    # Protégé
    [M]INTCOD([M]INTNBR)=[F:AYI]INTCOD
    If A_ALLACS=2 
        [M]INTACS([M]INTNBR)=2
    Else
        WJ=find([M]INTCOD([M]INTNBR), [F:AYD]INTCOD)
        If WJ : [M]INTACS([M]INTNBR)=2 : Else : [M]INTACS([M]INTNBR)=1 : Endif
    Endif
    [M]INTNBR+=1
Next
End

# fin modif sb Ajout interface protégée


Subprog AM_ALLACS(VALEUR)
Variable Integer VALEUR
Call AFF_PAG(VALEUR) : Affzo [M:AYD1]15
# Modif SB interfaces protégées
Call AFF_INT(VALEUR) : Affzo [M:AYD1]20

# Fin modif SB interfaces protégées

End

Subprog AS_PAGNBR
If [M]ALLACS=2 : mkstat=2 : Endif
End

Subprog B1_PAGNBR        # Oui à tous le reste
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
For WI=SAVNOL-1 To [M:AYD1]PAGNBR-1
  [M:AYD1]PAGACS(WI)=2 
Next
Affzo [M:AYD1]PAGACS : mkstat=4
End

Subprog B2_PAGNBR        # Non à tous le reste
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
For WI=SAVNOL-1 To [M:AYD1]PAGNBR-1
  [M:AYD1]PAGACS(WI)=1
Next
Affzo [M:AYD1]PAGACS : mkstat=4
End

