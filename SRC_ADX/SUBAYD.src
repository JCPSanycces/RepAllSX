# Modif sb Ajout interface protégée

Subprog AS_INTNBR
If [M]ALLACS=2 : mkstat=2 : Endif
End

Subprog B1_INTNBR
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
For WI=SAVNOL-1 To [M:AYD1]INTNBR-1
  [M:AYD1]INTACS(WI)=2 
Next
Affzo [M:AYD1]INTACS : mkstat=4
End

Subprog B2_INTNBR
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
For WI=SAVNOL-1 To [M:AYD1]INTNBR-1
  [M:AYD1]INTACS(WI)=1
Next
Affzo [M:AYD1]INTACS : mkstat=4
End

# Fin modif sb Ajout interface protégée
