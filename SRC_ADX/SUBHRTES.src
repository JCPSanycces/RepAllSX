########################################
Subprog C_CCE(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR="" : End : Endif

## fq 105501
##Call LECTURE("CCE",[L]VALEUR,num$(nolign)) From CONTOBJ
#If [F:CCE]IPT<>2
# [V]GMESSAGE=[L]VALEUR-mess(24,106,1) : # Section non imputable
# mkstat     =2
# End
#Endif
#
#Call CONTEXE([F:CCE]ACS) From CPTSUB
#If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]  : Endif
GGRPFCY = [M:HRTES0]GRP
If GGRPFCY<>""
  Call LEC_CCE(VALEUR,[M:HRTES0]DIE(nolign-1)) From CPTLEC
  If [F:CCE]FCY<>"" and [F:CCE]FCY<>GGRPFCY
     Call LEC_FCY([F:CCE]FCY) From CPTLEC
     If !fstat
        Call CONTSITE([F:CCE]FCY) From SUBAGF
     Else
        Call CONTSOC ([F:CCE]FCY) From SUBAGF
     Endif
     If mkstat : GERR=1 : End Endif
  Endif
Endif

#If clalev([F:FCY])=0 : Local File FACILITY   [FCY]  : Endif
#GGRPFCY = [M:TES0]GRP
#If GGRPFCY<>""
#  Call LEC_CCE(VALEUR,[M:TES0]DIE(nolign-1)) From CPTLEC
#  If [F:CCE]FCY<>"" and [F:CCE]FCY<>GGRPFCY
#     Call LEC_FCY([F:CCE]FCY) From CPTLEC
#     If !fstat
#        Call CONTSITE([F:CCE]FCY) From SUBAGF
#     Else
#        Call CONTSOC ([F:CCE]FCY) From SUBAGF
#     Endif
#     If mkstat : GERR=1 : End Endif
#  Endif
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END

End
