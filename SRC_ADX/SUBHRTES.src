######################################################################################

Subprog CONTHRTES(CODE)
Variable Char    CODE()
If GFONCTION = "GESHRTES" | CODE="" : End : Endif
If clalev([F:HRTES])=0 : Local File HRTABEXPENS [HRTES] : Endif

If CODE <> ""
  Filter [F:HRTES] Where CODEXP=[L]CODE
  Read [F:HRTES] First
  If fstat
      GMESSAGE = CODE-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:HRTES]
      Read [F:HRTES]HRTES0 = GCURLEG;[L]CODE
      If fstat
        Filter [F:HRTES] Where CODEXP=[L]CODE
        Read [F:HRTES] First
        GMESSAGE = CODE-":"-mess(62,127,1)-":"-[F:HRTES]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:HRTES]

End

######################################################################################

Subprog TUNHRTES(COD)
Variable Char    COD()
#Variable Char    LEG()
#ADNGO - 2016-11-25 END

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRTES)
 TOKILL = 1
Endif

If clalev([F:HRTES])=0 : Local File HRTABEXPENS [HRTES] : Endif
# To update the CODEXP code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#  If no code is specified, it's better to select one of the curent legislation
  Filter [HRTES] Where LEG=GCURLEG
  Read [F:HRTES] First
  Filter [HRTES]
  If !fstat : VCOD=[F:HRTES]CODEXP : Endif
Else
  Read [HRTES]HRTES0 = GCURLEG;VCOD
Endif

#Infbox VCOD
Call OBJET("HRTES",GCURLEG,VCOD) From GOBJET
#Infbox VCOD
COD = VCOD

If TOKILL : Kill VCOD : Endif
End
######################################################################################




