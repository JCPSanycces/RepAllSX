######################################################################################
## Section automatically added (screen HRTES0) 03/03/2015 15:48:08 (LUCUE) ## fq 105501
######################################################################################
Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
## Check the compliant with the "Company/Site/Group" in GESCCE
Local Integer I
If clalev([F:XGR])=0 : Local File FACGROUP   [XGR]  : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY    [AGC]  : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY]  : Endif
GGRPFCY = VALEUR
GERR = 0

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
If VALEUR<>""
  For I=0 To [M:HRTES0]NBRCCE-1
    If [M:HRTES0]CCE(I)<>""
      Raz [F:CCE]
      Call LEC_CCE([M:HRTES0]CCE(I),[M:HRTES0]DIE(I)) From CPTLEC
      If [F:CCE]FCY<>"" and [F:CCE]FCY<>GGRPFCY
         ### Site
         Call LEC_FCY([F:CCE]FCY) From CPTLEC
         If !fstat
            Read [F:XGR]FGR0=VALEUR;[F:CCE]FCY
            If fstat
                mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(24,127,1)-GGRPFCY : # Site non inclus dans le groupe
                GMESSAGE+="\"-mess(36,103,1)+":"-[M:HRTES0]CCE(I) #DIRAS Local menu query
                GERR=1 : Break
            Endif
         Else
           ### Company
           Call LEC_CPY([F:CCE]FCY) From  CPTLEC
           If !fstat and [F:CPY]CPYLEGFLG=2
             Read [F:AGC]AGC0=VALEUR;[F:CCE]FCY
             If fstat
                 mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(64,127,1)-GGRPFCY
                 GMESSAGE+="\"-mess(36,103,1)+":"-[M:HRTES0]CCE(I) #DIRAS Local menu query
                 GERR=1: Break
             Endif
           Else
             ### Group
             Read [F:AGC]AGC0=[F:CCE]FCY;GGRPFCY
             If fstat
                 mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(64,127,1)-GGRPFCY
                 GMESSAGE+="\"-mess(36,103,1)+":"-[M:HRTES0]CCE(I) #DIRAS Local menu query
                GERR=1 : Break
             Endif
            Endif
         Endif
     Endif
    Endif
  Next I
 Endif

#If VALEUR<>""
#  For I=0 To [M:TES0]NBRCCE-1
#    If [M:TES0]CCE(I)<>""
#      Raz [F:CCE]
#      Call LEC_CCE([M:TES0]CCE(I),[M:TES0]DIE(I)) From CPTLEC
#      If [F:CCE]FCY<>"" and [F:CCE]FCY<>GGRPFCY
#         ### Site
#         Call LEC_FCY([F:CCE]FCY) From CPTLEC
#         If !fstat
#            Read [F:XGR]FGR0=VALEUR;[F:CCE]FCY
#            If fstat
#                mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(24,127,1)-GGRPFCY : # Site non inclus dans le groupe
#                GMESSAGE+="\"-mess(36,103,1)+":"-[M:TES0]CCE(I)
#                GERR=1 : Break
#            Endif
#         Else
#           ### Company
#           Call LEC_CPY([F:CCE]FCY) From  CPTLEC
#           If !fstat and [F:CPY]CPYLEGFLG=2
#             Read [F:AGC]AGC0=VALEUR;[F:CCE]FCY
#             If fstat
#                 mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(64,127,1)-GGRPFCY
#                 GMESSAGE+="\"-mess(36,103,1)+":"-[M:TES0]CCE(I)
#                 GERR=1: Break
#             Endif
#           Else
#             ### Group
#             Read [F:AGC]AGC0=[F:CCE]FCY;GGRPFCY
#             If fstat
#                 mkstat=2: GMESSAGE= [F:CCE]FCY-":"-mess(64,127,1)-GGRPFCY
#                 GMESSAGE+="\"-mess(36,103,1)+":"-[M:TES0]CCE(I)
#                GERR=1 : Break
#             Endif
#            Endif
#         Endif
#     Endif
#    Endif
#  Next I
# Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END

End


