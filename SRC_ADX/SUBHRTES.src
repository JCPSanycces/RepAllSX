#<AdxTL>@(#)0.0.0.0 $Revision$ Expense codes
#DIRAS - 2017/05/10 - JIRA X3-11781 - START
Raz [V]GPILOBJ
Call OBJET("HRTES",[V]GBIDC1,"1") From GOBJET
End

#Raz [V]GPILOBJ
#Call OBJET("TES",[V]GBIDC1,"1") From GOBJET
#End
#DIRAS - 2017/05/10 - JIRA X3-11781 - END


$ACTION
Case [L]ACTION
 When "OUVRE"     : Gosub OUVRE : #92876-US2590
 When "RAZCRE"    : Gosub RAZCRE : # [M:TES0]NBRCCE=[V]GOPTCANA : Affzo [TES0] AXE, CCEDAC
 When "LIENS"     : Gosub LIENS : #[M:TES0]NBRCCE=[V]GOPTCANA : Call AM_TYPVLT([M:TES0]TYPVLT)
#-------------------------------------------------------------------------------
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "AVANT_CHOI" : Gosub AVANTCH : #92876-US2780
 #DIRAS - 2017/05/10 - JIRA X3-11781 - START
 When "FERME"     : Gosub FERME
 When "ANNULE"    : Gosub ANNULE
 When "TEXTRA"    : Gosub TEXTRA
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "SEL_TABLE" : Gosub SEL_TABLE
 #DIRAS - 2017/05/10 - JIRA X3-11781 - END
Endcase
Return

#92876-US2780
$AVANTCH
  If W_FORCEMODIF
       Gosub ENTRE_MODIF From GOBJSUB
       Gosub SETBOUT From GOBJSUB
  Endif
  W_FORCEMODIF=0
Return

#DIRAS - 2017/05/22 - JIRA X3-11781 - START
$ANNULE
Call SUPTEXTRA("HRTABEXPENS","DESEXP",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRTABEXPENS","DESSHO",SUPP,[L]CODE) From ATEXTRA
Return
#DIRAS - 2017/05/22 - JIRA X3-11781 - END

#DIRAS - 2017/05/22 - JIRA X3-11781 - START
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRTABEXPENS","DESEXP",CLECUR1,"","HRTABEXPENS","DESEXP",GCURLEG,[F:HRTES]CODEXP)  From ATEXTRA
 Call DUPTEXTRA("HRTABEXPENS","DESSHO",CLECUR1,"","HRTABEXPENS","DESSHO",GCURLEG,[F:HRTES]CODEXP)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESEXP,"HRTABEXPENS","DESEXP",GCURLEG,[F:HRTES]CODEXP) From ATEXTRA
Call MAJTEXTRA([M]DESSHO,"HRTABEXPENS","DESSHO",GCURLEG,[F:HRTES]CODEXP) From ATEXTRA
Return
#DIRAS - 2017/05/22 - JIRA X3-11781 - END

#DIRAS - 2017/05/22 - JIRA X3-11781 - START
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return
#DIRAS - 2017/05/22 - JIRA X3-11781 - END

#DIRAS - 2017/05/22 - JIRA X3-11781 - START
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return
#DIRAS - 2017/05/22 - JIRA X3-11781 - END

#DIRAS - 2017/05/22 - JIRA X3-11781 - START
$SEL_TABLE
Case TABLE
  When "SELHRTES"
    If clalev ([F:HRTES])=0 : Local File HRTABEXPENS [HRTES] : Endif
    Filter [F:HRTES]
    OBJET     = "HRTES"
    #ADNGO - 2016-11-25 - START
      #If PARAM(1)<>""
      #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:CUM]LEG="'+PARAM(1)+'" | [F:CUM]LEG="")',"&") From GOBJSUB
       #If GCURLEG<>""
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRTES]LEG="'+GCURLEG+'" | [F:HRTES]LEG="")',"&") From GOBJSUB
     #ADNGO - 2016-11-25 - END
    #Endif

# Case TABLE
#  When "SELHRTIM"
#    If clalev ([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
#    Filter [F:TIM]
#    OBJET="HRTIM"
####    START="[F:TIM]COD"
#  #Filter based on code legislation
#    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")',"&") From GOBJSUB
#  Endcase

Endcase
Return
#DIRAS - 2017/05/22 - JIRA X3-11781 - END

$OUVRE
#92876-US2590- Codes comptables si on nouvre pas ici il le fait au SELCAC du au type CAC aprés le CONTCACC
# ce qui réinitialise l'enregistrement et on a une erreur d'enregistrement inexistant.
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
#92876-US2780
If clalev ([F:CCE])=0 : Local File  =GTABCPT+"CACCE" [CCE] : Endif
If clalev ([F:CCE2])=0 : Local File =GTABCPT+"CACCE" [CCE2] : Endif
If clalev ([F:FGR])=0 : Local File =GTABCPT+"FACGROUP" [FGR] : Endif

If clalev ([F:CDI])=0 : Local File CADIEDEF [CDI] : Endif
Local Integer NUMDIE
# SBA ajout lien vers table compta
Local Integer ISLNKCPT
ISLNKCPT=GCOMPTA<>3
# on force l'enregistrement si on ajoute de nouveaux axes
Local Integer W_FORCEMODIF

NUMDIE = 8 : # Rang dans le menu 2230
Read [CDI]CDI0 = NUMDIE

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END
Return

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#DIRAS - 2017/05/10 - JIRA X3-11781 - END


#92876-US2780
$RAZCRE
#[M:TES0]NBRCCE=[V]GOPTCANA : Affzo [TES0] AXE, CCEDAC

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
If dim([M:HRTES0]DIE)>0
   # Rang 8 dans le menu 2230 Evénement
   Call INIT_DIE(8,"","HRTES0","NBRCCE","HRTES","DIE","CCE","DIE","CCE") From TRTHRCPT
   Affzo [HRTES0]60
Endif

#If dim([M:TES0]DIE)>0
#   # Rang 8 dans le menu 2230 Evénement
#   Call INIT_DIE(8,"","TES0","NBRCCE","TES","DIE","CCE","DIE","CCE") From TRTHRCPT
#   Affzo [TES0]60
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END

Return

#92876-US2780
$LIENS
#[M:TES0]NBRCCE=[V]GOPTCANA : Call AM_TYPVLT([M:TES0]TYPVLT)
Local Integer WI
W_FORCEMODIF=0

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
Call AM_TYPVLT([M:HRTES0]TYPVLT)
  If dim([M:HRTES0]DIE)>0
   # Rang 6 dans le menu 2230 Evénement
   Call CHARG_DIE(8,"","HRTES0","NBRCCE","HRTES","DIE","CCE","DIE","CCE") From TRTHRCPT
   #SBA init CCEDAC
   For WI=0 To [M]NBRCCE-1
    #92876-US2780
    If([M]CCEDAC(WI)= 0) : [M]CCEDAC(WI)= 1 : W_FORCEMODIF=1 : Endif
   Next WI
   Affzo [HRTES0]60
  Endif

GCURLEG = [F:HRTES]LEG

Call LECTEXTRA([M]DESEXP,"HRTABEXPENS","DESEXP",GCURLEG,[M]CODEXP) From ATEXTRA
Call LECTEXTRA([M]DESSHO,"HRTABEXPENS","DESSHO",GCURLEG,[M]CODEXP) From ATEXTRA


#Call AM_TYPVLT([M:TES0]TYPVLT)
#  If dim([M:TES0]DIE)>0
#   # Rang 6 dans le menu 2230 Evénement
#   Call CHARG_DIE(8,"","TES0","NBRCCE","TES","DIE","CCE","DIE","CCE") From TRTHRCPT
#   #SBA init CCEDAC
#   For WI=0 To [M]NBRCCE-1
#    #92876-US2780
#    If([M]CCEDAC(WI)= 0) : [M]CCEDAC(WI)= 1 : W_FORCEMODIF=1 : Endif
#   Next WI
#   Affzo [TES0]60
#  Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END
Return

#92876-US2780
$VERIF_CRE
$VERIF_MOD
#For [CCE]CCE0 Where find(CCE,[M:TES0]CCE(0..[M:TES0]NBRCCE-2))<>0
# For [CCE2]CCE0 Where find(CCE,[M:TES0]CCE([F:CCE]AXI..[M:TES0]NBRCCE-1))<>0
#  Look [AUZ]AUZ0=1;[F:CCE]AUZ;[F:CCE2]AUZ
#  If !fstat
#   [V]GMESSAGE=[F:CEE]CCE-mess(26,106,1)-[F:CCE2]CCE : # Interdit avec la section
#   [L]OK      =0
#   Break 2
#  Endif
# Next
#Next
#
Local Integer AXE
#SBA : table different if link with x3
If ISLNKCPT
  If clalev([F:CAZ])=0 : Local File =GTABCPT+"CAAUZ" [CAZ] : Endif
Else
 If clalev([F:AUZ])=0 : Local File CAAUZ [AUZ] : Endif
Endif
For AXE=1 To GOPTCANA
  If [M]CCE(AXE-1)<>""
    nolign=AXE
    Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
    Call C_CCE([M]CCE(AXE-1))
    If mkstat
      Break
    Else :# Contrôle interdiction section/section
     # Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
      For I=AXE+1 To GOPTCANA
        If [M]CCE(I-1)<>""
          Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
          If ISLNKCPT
            Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
          Else
            Look [AUZ]AUZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
          Endif
          If !fstat
            # Interdit avec la section
            GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
            [L]OK      =0
            Break 2
          Endif
        Endif
      Next
    Endif
  Endif
Next
Return

########################################
Subprog AM_TYPVLT(VALEUR)
Variable Integer VALEUR
# 61650 : Ajout des effzo Z* pour raz les libellés des tables diverses

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
Case [L]VALEUR
When 1
 Actzo [HRTES0] VLTDEFPAR
 Effzo [HRTES0] VLTPFDPAR,ZVLTPFDPAR
 Grizo [HRTES0] VLTPFDPAR
When 2
 Actzo [HRTES0] VLTDEFPAR, VLTPFDPAR
When Default
 Effzo [HRTES0] VLTDEFPAR, VLTPFDPAR, ZVLTDEFPAR, ZVLTPFDPAR
 Grizo [HRTES0] VLTDEFPAR, VLTPFDPAR
Endcase

#Case [L]VALEUR
#When 1
# Actzo [TES0] VLTDEFPAR
# Effzo [TES0] VLTPFDPAR,ZVLTPFDPAR
# Grizo [TES0] VLTPFDPAR
#When 2
# Actzo [TES0] VLTDEFPAR, VLTPFDPAR
#When Default
# Effzo [TES0] VLTDEFPAR, VLTPFDPAR, ZVLTDEFPAR, ZVLTPFDPAR
# Grizo [TES0] VLTDEFPAR, VLTPFDPAR
#Endcase
#DIRAS - 2017/05/10 - JIRA X3-11781 - END

End

########################################
Subprog C_VLTDEFPAR(VALEUR)
Variable Char    VALEUR()

#DIRAS - 2017/05/10 - JIRA X3-11781 - START
If [M:HRTES0]TYPVLT<2  & [L]VALEUR=""
 [V]GMESSAGE=mess(10,123,1) : # Zone obligatoire
 mkstat     =2
Endif

#If [M:TES0]TYPVLT<2  & [L]VALEUR=""
# [V]GMESSAGE=mess(10,123,1) : # Zone obligatoire
# mkstat     =2
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11781 - END

End

