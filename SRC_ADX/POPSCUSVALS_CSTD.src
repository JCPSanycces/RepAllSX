#<AdxTL>@(#)0.0.0.0 $Revision$
# Class POPSCUSVALS_OPCUSFLDS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"                   : Gosub AINIT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
      Endcase
  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "FINDDEFAULTSITE" : Gosub FINDDEFAULTSITE
    When "REMOVEDEFAULTSITE" : Gosub REMOVEDEFAULTSITE
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$AINIT
    Local Char DEFFCY(GLONFCY)

    [L]DEFFCY = fmet this.FINDDEFAULTSITE()
    If [L]DEFFCY = ""
        this.DEFFLG = 2
    Endif
Return

#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AINSERT_OR_AUPDATE_CONTROL_BEFORE
    Local Char WTEXTE(50)
    Local Char WMESSAGE(250)
    Local Char DEFFCY(GLONFCY)

    # Need to check if the same value has been set for both fields
    If this.WOCUSFLDS(1).WOCUSFLD = this.WOCUSFLDS(2).WOCUSFLD
        Call TEXTE(56965, WTEXTE) From OBJDIV
        WMESSAGE = " : " + mess(390,193,1)
        [L]ASTATUS = fmet this.ASETERROR (WTEXTE, WMESSAGE, [V]CST_AERROR)
        Return
    Endif
    If this.OPCUSFLDS(1).OPCUSFLD = this.OPCUSFLDS(2).OPCUSFLD
        Call TEXTE(56967, WTEXTE) From OBJDIV
        WMESSAGE = " : " + mess(391,193,1)
        [L]ASTATUS = fmet this.ASETERROR (WTEXTE, WMESSAGE, [V]CST_AERROR)
        Return
    Endif
    # Only allow project code if PJM is enabled
    If (this.WOCUSFLDS(1).WOCUSFLD = 3 | this.WOCUSFLDS(2).WOCUSFLD = 3) & func AFNC.ACTIV("PJM") = 0
        If this.WOCUSFLDS(1).WOCUSFLD = 3
            Call TEXTE(56965, WTEXTE) From OBJDIV
        Else
            Call TEXTE(56966, WTEXTE) From OBJDIV
        Endif
        WMESSAGE = " : " + mess(395,193,1)
        [L]ASTATUS = fmet this.ASETERROR (WTEXTE, WMESSAGE, [V]CST_AERROR)
        Return
    Endif

Return

$FINDDEFAULTSITE
    Local Char DEFFCY(GLONFCY)

    Local File POPSCUSVALS [PSCV]
    [L]DEFFCY = ""

    Filter [PSCV] Where DEFFLG = 2
    Read [PSCV]PSCV0 First
    If fstat = [V]CST_AOK
        [L]DEFFCY = [F:PSCV]FCY
    Endif
    Filter [PSCV]

    ARET_VALUE = [L]DEFFCY
Return

$REMOVEDEFAULTSITE
    Local Char WMESSAGE(250)
    Local Integer OK

    Local Instance POPSCUSVALS Using C_POPSCUSVALS
    [L]POPSCUSVALS = NewInstance C_POPSCUSVALS AllocGroup null

    [L]OK = fmet [L]POPSCUSVALS.AREAD(FCY)
    If [L]OK = [V]CST_AOK
        [L]POPSCUSVALS.DEFFLG = 1
        [L]OK = fmet [L]POPSCUSVALS.AUPDATE()
        If [L]OK <> [V]CST_AOK
            WMESSAGE = func LCCLIB.MAXMSG([L]POPSCUSVALS)
            ASTATUS = fmet this.ASETERROR("", WMESSAGE, [V]CST_AERROR)
        Endif
    Endif

    FreeGroup [L]POPSCUSVALS
    ARET_VALUE = ASTATUS
Return

