#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UUMGTRTCPT05                                      Module  Accounting   #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Budget Entry                                             #
#            BUD                                                         #
#                                                                        #
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTCPT05") From LECFIC
  Endif

  #Call RAZ_UUMGTRTCPT05(DOSSIER)
  Call MAJ_UUMGTRTCPT05(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTCPT05(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMBUDM
Call MIGTABNAME (DOSSIER,"BUD",WNAMBUDM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMBUDM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"BUD",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGTRTCPT05",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTCPT05(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMBUDM
Call MIGTABNAME (DOSSIER,"BUD",WNAMBUDM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMBUDM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTCPT05 table BUD Process") From DOSSUB
Call ECR_TRACE("UUMGTRTCPT05 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BUD",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:BUD])  = 0 : Local File =DOSSIER+".BUD"    [BUD]  : Endif

# X3 Renamed File
If clalev([F:BUDM]) = 0 : Local File =DOSSIER+"."+WNAMBUDM  [BUDM] : Endif

# Fichier X3 Standard
If clalev([F:BUP])  = 0 : Local File =DOSSIER+".BUDPAR"   [BUP]  : Endif
If clalev([F:FCY])  = 0 : Local File =DOSSIER+".FACILITY" [FCY]  : Endif
If clalev([F:LED])  = 0 : Local File =DOSSIER+".GLED"     [LED]  : Endif

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00
Local Integer DSTDIE

# Variables to manage Flush instruction
Local Char WTAB_BUD(30)(adxwrb)
Local Shortint WCPT_BUD

Local Integer NBMIGKEY : NBMIGKEY=8
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTCPT05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(8))

If val(VERSION)<GMIGX3VER60
 Link [BUDM] With [BUP]BUP0~=[F:BUDM]BUD, [FCY]FCY0=[F:BUDM]FCY
&     As  [LNK]
&     Order By Key CLE=[F:BUDM]FCY;[F:BUDM]BUD;[F:BUDM]FIY;[F:BUDM]CNA;[F:BUDM]CCE1;[F:BUDM]CCE2;[F:BUDM]CCE3
Else
 Link [BUDM] With [BUP]BUP0~=[F:BUDM]BUD
&     As  [LNK]
&     Order By Key CLE=[F:BUDM]CPY;[F:BUDM]BUD;[F:BUDM]ACCNUM
Endif

# EP to add a criteria in the "where"
FLUX="UUMGTRTCPT05" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CPT05
Raz NB

If val(VERSION)<GMIGX3VER60
 If STOP = 1
  STOP = 2
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]FIY='+TABMIGKEY(3)
&  +' & [F:BUDM]CNA="'+TABMIGKEY(4)+'" & [F:BUDM]CCE1="'+TABMIGKEY(5)+'" & [F:BUDM]CCE2="'+TABMIGKEY(6)+'" & [F:BUDM]CCE3>"'+TABMIGKEY(7)+'"'
 Elsif STOP=2
  STOP = 3
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]FIY='+TABMIGKEY(3)
&          +' & [F:BUDM]CNA="'+TABMIGKEY(4)+'" & [F:BUDM]CCE1="'+TABMIGKEY(5)+'" & [F:BUDM]CCE2>"'+TABMIGKEY(6)+'"'
 Elsif STOP=3
  STOP = 4
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]FIY='+TABMIGKEY(3)
&          +' & [F:BUDM]CNA="'+TABMIGKEY(4)+'" & [F:BUDM]CCE1>"'+TABMIGKEY(5)+'"'
 Elsif STOP=4
  STOP = 5
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]FIY='+TABMIGKEY(3)
&          +' & [F:BUDM]CNA>"'+TABMIGKEY(4)+'"'
 Elsif STOP=5
  STOP = 6
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]FIY>'+TABMIGKEY(3)
 Elsif STOP=6
  STOP = 7
  CRITERE = '[F:BUDM]FCY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD>"'+TABMIGKEY(2)+'"'
 Elsif STOP=7
  STOP = 0
  CRITERE = '[F:BUDM]FCY>"'+TABMIGKEY(1)+'"'
 Else
  CRITERE = '1=1'
 Endif
Else
 If STOP = 1
  STOP = 2
  CRITERE = '[F:BUDM]CPY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD="'+TABMIGKEY(2)+'" & [F:BUDM]ACCNUM>'+TABMIGKEY(3)
 Elsif STOP=2
  STOP = 3
  CRITERE = '[F:BUDM]CPY="'+TABMIGKEY(1)+'" & [F:BUDM]BUD>"'+TABMIGKEY(2)+'"'
 Elsif STOP=3
  STOP = 0
  CRITERE = '[F:BUDM]CPY>"'+TABMIGKEY(1)+'"'
 Else
  CRITERE = '1=1'
 Endif
Endif

Trbegin [BUD]
GOK = 1

For [F:LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 If val(VERSION)<GMIGX3VER60
  # By company - Initialization of Variables linked to the Account Core Model
  Case [F:BUP]LEV
   When 1 : COMPANY=[F:BUDM]FCY
   When 2 : COMPANY=[F:FCY]LEGCPY
  Endcase
 Else
  COMPANY=[F:BUDM]CPY
 Endif
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTCPT05" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  Raz [F:BUD]
  [F:BUD] = [F:BUDM]

  If val(VERSION)<GMIGX3VER60
   Gosub MAJ30_BUD
   If !GOK : Break 2 : Endif
  Endif

  Gosub MAJ70_BUD
  If !GOK : Break 2 : Endif

  Gosub WRI_BUD
  If !GOK : Break 2 : Endif

  NB+=1
  If NB>GMAXUPDTRS

   If val(VERSION)<GMIGX3VER60
    TABMIGKEY(1) = [F:BUDM]FCY
    TABMIGKEY(2) = [F:BUDM]BUD
    TABMIGKEY(3) = num$([F:BUDM]FIY)
    TABMIGKEY(4) = [F:BUDM]CNA
    TABMIGKEY(5) = [F:BUDM]CCE1
    TABMIGKEY(6) = [F:BUDM]CCE2
    TABMIGKEY(7) = [F:BUDM]CCE3
   Else
    TABMIGKEY(1) = [F:BUDM]CPY
    TABMIGKEY(2) = [F:BUDM]BUD
    TABMIGKEY(3) = num$([F:BUDM]ACCNUM)
   Endif
   STOP=1
   Break 2
  Endif

 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTCPT05",7,ERR) From TRTMIG
Else
 Flush [F:BUD]
 If fstat
  Call ECR_TRACE("File BUD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub BUD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(8)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTCPT05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTCPT05",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_CPT05
 Endif
Endif

Filter [LNK]

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BUD]
Close Local File [BUDM]
Close Local File [GCM], [LED], [CPY], [FCY], [BUP]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"BUD",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTCPT05") From TRTMIG
Call ECR_TIME("UUMGTRTCPT05 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$MAJ30_BUD

 If [F:BUP]LEV=1
  Raz [F:BUD]FCY
 Endif

 #--- New fields's assignation
 [F:BUD]CPY    = [L]COMPANY
 [F:BUD]LEDTYP = [L]TYPANA
 [F:BUD]VER    = "1"
 [F:BUD]LED    = [L]LEDANA
 [F:BUD]COA    = [L]COAANA
 [F:BUD]ACC    = [F:BUDM]CNA
 [F:BUD]CUR    = [F:BUP]CUR

 #If [F:BUDM]AXI1>0 : [F:BUD]DIE1   = evalue("[L]AXEA("+num$([F:BUDM]AXI1)+")") : Endif
 #If [F:BUDM]AXI2>0 : [F:BUD]DIE2   = evalue("[L]AXEA("+num$([F:BUDM]AXI2)+")") : Endif
 #If [F:BUDM]AXI3>0 : [F:BUD]DIE3   = evalue("[L]AXEA("+num$([F:BUDM]AXI2)+")") : Endif

 If [F:BUDM]AXI1>0 : [F:BUD]DIE1   = [L]AXEA([F:BUDM]AXI1) : Endif
 If [F:BUDM]AXI2>0 : [F:BUD]DIE2   = [L]AXEA([F:BUDM]AXI2) : Endif
 If [F:BUDM]AXI3>0 : [F:BUD]DIE3   = [L]AXEA([F:BUDM]AXI3) : Endif

 #[F:BUD]UOM    = [F:CNAM]UOM
 #Read [GAC]GAC0=[L]COAANA;[F:BUDM]CNA
 #If !fstat
 # [F:BUD]UOM    = [F:GAC]UOM
 #Endif

 Call ACCNUM_BUD([F:BUD]ACCNUM)    # It must initialize a new ACCNUM

Return


################################################
$MAJ70_BUD
# - l’ordre des axes dans la table BUD a changé :
# o avant : correspond à l’ordre des axes dans la table BUDPAR
# o après : correspond à l’ordre des axes dans le référentiel de la société concernée

Raz [F:BUD]DIE1, DIE2, DIE3, CCE1, CCE2, CCE3

# chargement du référentiel du budget courant
If [F:LED]LED <> [F:BUDM]LED
 Read [F:LED]LED0 = [F:BUDM]LED
Endif

If [F:BUDM]DIE1<>""
 # recherche de la nouvelle position de l'axe
 DSTDIE = find([F:BUDM]DIE1, [F:LED]DIE)
 If DSTDIE>0
  If DSTDIE=1
   [F:BUD]DIE1 = [F:BUDM]DIE1
   [F:BUD]CCE1 = [F:BUDM]CCE1
  Elsif DSTDIE=2
   [F:BUD]DIE2 = [F:BUDM]DIE1
   [F:BUD]CCE2 = [F:BUDM]CCE1
  Elsif DSTDIE=3
   [F:BUD]DIE3 = [F:BUDM]DIE1
   [F:BUD]CCE3 = [F:BUDM]CCE1
  Elsif DSTDIE=4
   [F:BUD]DIE4 = [F:BUDM]DIE1
   [F:BUD]CCE4 = [F:BUDM]CCE1
  Elsif DSTDIE=5
   [F:BUD]DIE5 = [F:BUDM]DIE1
   [F:BUD]CCE5 = [F:BUDM]CCE1
  Elsif DSTDIE=6
   [F:BUD]DIE6 = [F:BUDM]DIE1
   [F:BUD]CCE6 = [F:BUDM]CCE1
  Elsif DSTDIE=7
   [F:BUD]DIE7 = [F:BUDM]DIE1
   [F:BUD]CCE7 = [F:BUDM]CCE1
  Elsif DSTDIE=8
   [F:BUD]DIE8 = [F:BUDM]DIE1
   [F:BUD]CCE8 = [F:BUDM]CCE1
  Elsif DSTDIE=9
   [F:BUD]DIE9 = [F:BUDM]DIE1
   [F:BUD]CCE9 = [F:BUDM]CCE1
  Endif
 Endif
Endif
If [F:BUDM]DIE2<>""
 # recherche de la nouvelle position de l'axe
 DSTDIE = find([F:BUDM]DIE2, [F:LED]DIE)
 If DSTDIE>0
  If DSTDIE=1
   [F:BUD]DIE1 = [F:BUDM]DIE2
   [F:BUD]CCE1 = [F:BUDM]CCE2
  Elsif DSTDIE=2
   [F:BUD]DIE2 = [F:BUDM]DIE2
   [F:BUD]CCE2 = [F:BUDM]CCE2
  Elsif DSTDIE=3
   [F:BUD]DIE3 = [F:BUDM]DIE2
   [F:BUD]CCE3 = [F:BUDM]CCE2
  Elsif DSTDIE=4
   [F:BUD]DIE4 = [F:BUDM]DIE2
   [F:BUD]CCE4 = [F:BUDM]CCE2
  Elsif DSTDIE=5
   [F:BUD]DIE5 = [F:BUDM]DIE2
   [F:BUD]CCE5 = [F:BUDM]CCE2
  Elsif DSTDIE=6
   [F:BUD]DIE6 = [F:BUDM]DIE2
   [F:BUD]CCE6 = [F:BUDM]CCE2
  Elsif DSTDIE=7
   [F:BUD]DIE7 = [F:BUDM]DIE2
   [F:BUD]CCE7 = [F:BUDM]CCE2
  Elsif DSTDIE=8
   [F:BUD]DIE8 = [F:BUDM]DIE2
   [F:BUD]CCE8 = [F:BUDM]CCE2
  Elsif DSTDIE=9
   [F:BUD]DIE9 = [F:BUDM]DIE2
   [F:BUD]CCE9 = [F:BUDM]CCE2
  Endif
 Endif
Endif
If [F:BUDM]DIE3<>""
 # recherche de la nouvelle position de l'axe
 DSTDIE = find([F:BUDM]DIE3, [F:LED]DIE)
 If DSTDIE>0
  If DSTDIE=1
   [F:BUD]DIE1 = [F:BUDM]DIE3
   [F:BUD]CCE1 = [F:BUDM]CCE3
  Elsif DSTDIE=2
   [F:BUD]DIE2 = [F:BUDM]DIE3
   [F:BUD]CCE2 = [F:BUDM]CCE3
  Elsif DSTDIE=3
   [F:BUD]DIE3 = [F:BUDM]DIE3
   [F:BUD]CCE3 = [F:BUDM]CCE3
  Elsif DSTDIE=4
   [F:BUD]DIE4 = [F:BUDM]DIE3
   [F:BUD]CCE4 = [F:BUDM]CCE3
  Elsif DSTDIE=5
   [F:BUD]DIE5 = [F:BUDM]DIE3
   [F:BUD]CCE5 = [F:BUDM]CCE3
  Elsif DSTDIE=6
   [F:BUD]DIE6 = [F:BUDM]DIE3
   [F:BUD]CCE6 = [F:BUDM]CCE3
  Elsif DSTDIE=7
   [F:BUD]DIE7 = [F:BUDM]DIE3
   [F:BUD]CCE7 = [F:BUDM]CCE3
  Elsif DSTDIE=8
   [F:BUD]DIE8 = [F:BUDM]DIE3
   [F:BUD]CCE8 = [F:BUDM]CCE3
  Elsif DSTDIE=9
   [F:BUD]DIE9 = [F:BUDM]DIE3
   [F:BUD]CCE9 = [F:BUDM]CCE3
  Endif
 Endif
Endif
Return

################################################
Subprog ACCNUM_BUD(NUMERO)
Variable Integer NUMERO
If !clalev([BUD]) : Local File =[F:ADS]DOSSIER+".BUD" [BUD] : Endif
NUMERO = uniqid([F:BUD])
End

################################################
$WRI_BUD
# To Save reference
Gosub BUD_STK
WriteB [F:BUD]
If fstat
 Call ECR_TRACE("File BUD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub BUD_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$BUD_STK
Call STK (WTAB_BUD,WCPT_BUD,[F:BUD]BUD+"/"+[F:BUD]FCY+"/"+num$([F:BUD]FIY)+"/"+[F:BUD]ACC+"/"+[F:BUD]CCE1+"/"+[F:BUD]CCE2+"/"+[F:BUD]CCE3) From TRTMIG
Return

#################################################
$BUD_ERRTRA
Call ERRTRA (WTAB_BUD,WCPT_BUD,"File BUD(BUD/FCY/FIY/ACC/CCE1/CCE2/CCE3)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTCPT05(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)                   #
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTCPT05(APPLI)
End

