#<AdxTL>@(#)0.0.0.0 $Revision$

Local Integer WSTARTS,WENDS
Local Char ACRITROLE

ACRITROLE = "[F:SOH]CRESUER"
WSTARTS = instr(1,ACRITROLE,"[")
           While WSTARTS>0
            WENDS = instr(1,ACRITROLE,"]")
            ACRITROLE = right$(ACRITROLE,WENDS+1)
            WSTARTS = instr(1,ACRITROLE,"[")
           Wend

Infbox ACRITROLE

End

#Local Char ACRITROLE(250)(1..)
#Local Integer ASTATUS
#Local Integer NBREP
#Local Char    NAMQRY(30)               : # Name query class
#Local Char    PRGQRY(30)               : # Program contains subprog base access
#Local Char    TBPRO(30)(1..)           : # Name of properties of representation used in where critera
#Local Char    TBFIL(30)(1..)            : # Name of properties (Abbreviation & name) of files
#Local Integer TBTYP(1..)                : # Types
#Local Char    TBPTH(30)(1..)           : # path
#[L]ASTATUS = fmet GACTX.AGETCRITROLE(GACTX,"AQCITEM","AQCITM",ACRITROLE,[V]CST_AFALSE)
#
#Infbox ACRITROLE
#Gosub  SEARCH_DECODE_CRITERIA From WMJSOAQCITEM
# ACRITROLE(1) =  toSData(T0,T1,ACRITROLE(1))
#Infbox ACRITROLE(1)
#Infbox ctrans(ACRITROLE(1),'"',"'")
#
End
#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer    ERROR : ERROR = [V]CST_AOK
Local Integer    ASTATUS
Local Instance LACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Local Integer   I,J
Local Char SEP(1),SEP(1)

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  REPRESENTATIONS    Using C_ASYRJSO  : REPRESENTATIONS=null
Local Instance  REPRESENTATION      Using C_ASYRJSO  : REPRESENTATION=null

Local Clbfile AUTHORIZEDFUNCTIONS_CLB
Local Char AUTHORIZEDFUNCTIONS(GLONAFC)(1..)
Local Integer    AUTHORIZEDFUNCTIONSFCY(1..)
Local Clbfile    AUTHORIZEDFCYBYFUNCTION
Local Clbfile ACCESSCODES

Local Integer NBFUNC
Local Integer NBFUNC
Local Char ETAG(20),RIGHTSETAG(20)
Local Char WDOSX3(GLONADS)
Local Char CRITERIA(250)

Local Char ACRITROLE(250)(1..),PREFIXSRD(10)
Local Integer OKROLE

Local Char T0(30)(1..)
Local Char T1(30)(1..)
Local Integer NBPRO,WENDS,WSTARTS

NBPRO += 1  : T1(NBPRO) = "false" : T0(NBPRO) = "[V]CST_ANO"
NBPRO += 1  : T1(NBPRO) = "true" : T0(NBPRO) = "[V]CST_AYES"

PREFIXSRD = func APREFIXTRT.GET_PREFIX_SRD
RIGHTSETAG = func ASYRFNC.READ_RIGHTSETAG(ACTX.AFOLDER)
If RIGHTSETAG=""
 Call  UPDATE_RIGHTSETAG(ACTX.AFOLDER) From ASYRFNC
 RIGHTSETAG = func ASYRFNC.READ_RIGHTSETAG(ACTX.AFOLDER)
Endif
ASND.HEADERCOD(1) = "ETag"
ASND.HEADERVAL(1) = RIGHTSETAG

ETAG = func ASYRMAIN.HEADVAL(ARCV,"If-None-Match")
If ETAG <> ""
 If ETAG =RIGHTSETAG
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_MODIFIED,"")
  End ERROR
 Endif
Endif

LACTX = evalue("NewInstance  "+[V]CST_C_NAME_CLASS_CONTEXT + " AllocGroup null")

ASTATUS = fmet LACTX.AINIT

ASTATUS = fmet LACTX.ACTX_INIT_LANISO(nomap,ACTX.LANISO,toupper(PSYR.SELREP))
If ASTATUS>0
  Local Integer CTXERROR : CTXERROR=[L]ASTATUS
  Local Integer HTTP_STATUS : HTTP_STATUS=CST_AHTTP_CREATED
  Local Char ERRMSG(250)
  Gosub CHECK_CTXERROR From ASYRMAIN
  FreeGroup LACTX
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,HTTP_STATUS,ERRMSG)
  End ERROR
Endif

WDOSX3=fmet LACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,nomap,"SUPDOS")

# Create the list of access codes :
Raz ACCESSCODES,SEP
ASTATUS = fmet LACTX.AGETACSRIGHTALL
If ASTATUS=[V]CST_AOK
 If LACTX.ALLACS = 2
   Local File ACCCOD   [ACS_R]
   For [ACS_R]
    Append ACCESSCODES, SEP
    Append ACCESSCODES, [ACS_R]CODACC
    SEP = ","
   Next
## NEXT VERIO : ACCESSCODES="*"
 Else
  For I=1 To maxtab(LACTX._APROFIL.AACS)
   Append ACCESSCODES, SEP
   Append ACCESSCODES, LACTX._APROFIL.AACS(I).ACODACC
   SEP = ","
  Next I
 Endif
Endif

# Create the list of authorized functions
#If LACTX._APROFIL.ALLFCT = 2 & LACTX.AFOLDER<>[L]WDOSX3
# AUTHORIZEDFUNCTIONS_CLB = "*"
#Else
 Call LISTAFCUSER(0,LACTX.LAN,LACTX.AFOLDER,LACTX.USER,NBFUNC,AUTHORIZEDFUNCTIONS) From ACONTEXT_CMET
 Raz AUTHORIZEDFUNCTIONS_CLB,SEP
 For I=1 To NBFUNC
    AUTHORIZEDFUNCTIONSFCY(I) =  0
    Append AUTHORIZEDFUNCTIONS_CLB, SEP
    Append AUTHORIZEDFUNCTIONS_CLB, AUTHORIZEDFUNCTIONS(I)
    SEP=','
 Next I
#Endif

# Create the list of disabled functions
Local Clbfile DISABLEDFUNCTIONS
Local File AFONCTION [AFC_]
Raz SEP

If LACTX.AFOLDER<>[L]WDOSX3
 Local File =[L]WDOSX3+".AFONCTION" [AFC2_]
 For [AFC2_]CODINT
  Read [AFC_]CODINT=[AFC2_]CODINT
  If fstat
   Append DISABLEDFUNCTIONS,SEP
   Append DISABLEDFUNCTIONS,[AFC2_]CODINT
   SEP=","
  Endif
 Next AFC_
 Close Local File [AFC2_]
Endif


For [AFC_]CODINT Where [AFC_]CODACT <> ""
 If ! func ASYRFNC.ACTIV([AFC_]CODACT)
  Append DISABLEDFUNCTIONS,SEP
  Append DISABLEDFUNCTIONS,[AFC_]CODINT
  SEP=","
 Endif
Next AFC_
Close Local File [AFC_]


## Create lists of authorisez facilities by function
Local Clbfile FILTREREP
If LACTX.AFOLDER=nomap
 Local File AUTILIS       [AUS_ACTX]
 Local File AFCTFCY      [AFF_ACTX]
 Local File AFONCTION   [AFC_ACTX]
 Local File AOBJET        [AOB_ACTX]
 Local File AROLE         [ARL_ACTX]
 Local File AUSRBPR      [AUB_ACTX]
 Local File ATABLE         [ATB_ACTX]
Else
 Local File =LACTX.AFOLDER+".AUTILIS"   [AUS_ACTX]
 Local File =LACTX.AFOLDER+".AFCTFCY"   [AFF_ACTX]
 Local File =LACTX.AFOLDER+".AFONCTION"   [AFC_ACTX]
 Local File =LACTX.AFOLDER+".AOBJET"   [AOB_ACTX]
 Local File =LACTX.AFOLDER+".AROLE" [ARL_ACTX]
 Local File =LACTX.AFOLDER+".AUSRBPR"  [AUB_ACTX]
 Local File =LACTX.AFOLDER+".ATABLE"  [ATB_ACTX]
Endif

Read [AUS_ACTX]CODUSR = LACTX.USER

Read [AUB_ACTX]AUB0 = LACTX.USER
If !fstat
 OKROLE = 1
Else
 OKROLE =0
Endif

CRITERIA = "1=1"
If LACTX.AFOLDER=[L]WDOSX3 & !GSOPHIA
 CRITERIA = "[F:ASW]MODULE=1"
Endif
Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDOBJECT(NODES,ROOT,"$authorizedRepresentations",REPRESENTATIONS)  From ASYRJSO
Local File ASHW    [ASW]
For [ASW]ASW0 Where evalue(CRITERIA)
 If  ((len( [ASW]AFCRIGHT) = 0) or LACTX._APROFIL.ALLFCT = 2 or  find([ASW]AFCRIGHT,AUTHORIZEDFUNCTIONS))
& and ( (len( [ASW]CODACT) = 0) or func ASYRFNC.ACTIV([F:ASW]CODACT) )
  Call JSON_ADDOBJECT(NODES,REPRESENTATIONS,[ASW]CODREP,REPRESENTATION)  From ASYRJSO
  If [ASW]CODREP <> [ASW]CODCLA
   Call JSON_ADDSTRING(NODES,REPRESENTATION,'$entity',[ASW]CODCLA)  From ASYRJSO
  Endif
  If len( [ASW]AFCRIGHT)
   I = find( [ASW]AFCRIGHT,AUTHORIZEDFUNCTIONS)
   If I
    Raz AUTHORIZEDFCYBYFUNCTION,SEP
    For [AFF_ACTX]AFF1 Where PRFCOD=[F:AUS_ACTX]PRFFCT and  FNC=AUTHORIZEDFUNCTIONS(I)
     If len([AFF_ACTX]FCY)
      Append AUTHORIZEDFCYBYFUNCTION,SEP
      Append AUTHORIZEDFCYBYFUNCTION,[AFF_ACTX]FCY
      SEP=','
     Endif
    Next AFF_ACTX
    If len(AUTHORIZEDFCYBYFUNCTION)
     Call JSON_ADDCLB(NODES,REPRESENTATION,'$sites',AUTHORIZEDFCYBYFUNCTION)  From ASYRJSO
    Endif
    If [F:ASW]AFCRIGHT<>"" & OKROLE>0
     Read [AFC_ACTX]CODINT=[F:ASW]AFCRIGHT
     If !fstat & [AFC_ACTX]ACTION="GOBJET"& [AFC_ACTX]VALPAR(0)<>""
      Read [AOB_ACTX]ABREV=evalue([AFC_ACTX]VALPAR(0))
      If !fstat
       Read [F:ATB_ACTX]CODFIC = [AOB_ACTX]NOMFIC
       If !fstat
        Raz ACRITROLE
        [L]ASTATUS = fmet LACTX.AGETCRITROLE(LACTX,[AOB_ACTX]ABREV, [F:ATB_ACTX]ABRFIC,ACRITROLE,[V]CST_AFALSE)
        If sum(ACRITROLE)<>"1=1"
         If ERROR=[V]CST_AOK
          For I=1 To dim(ACRITROLE)
           If ACRITROLE(I)="" : Break : Endif
           # ALIAS equal field , old WMSRD traitment
           WSTARTS = instr(1,ACRITROLE(I),"[")
           While WSTARTS>0
            WENDS = instr(1,ACRITROLE(I),"]")
            ACRITROLE(I) = left$(ACRITROLE(I),WSTARTS-1)+right$(ACRITROLE(I),WENDS+1)
            WSTARTS = instr(1,ACRITROLE(I),"[")
           Wend
           #119010
           #ACRITROLE(I) =  toSData(T0,T1,ACRITROLE(I))
           #ACRITROLE(I) = ctrans(ACRITROLE(I),'"',"'")
          Next
          #119010
          FILTREREP=sum(ACRITROLE)
          FILTREREP=toSData(T0,T1,FILTREREP)
          FILTREREP = ctrans(FILTREREP,'"',"'")
          #Call JSON_ADDSTRING_WITHOUTQUOTE(NODES,REPRESENTATION,'$conditions','[{"$type": "authorization","$where": "'+sum(ACRITROLE)+'"}]')  From ASYRJSO
          FILTREREP='[{"$type": "authorization","$where": "'+FILTREREP+'"}]'
          Call JSON_ADDCLB_WITHOUTQUOTE(NODES,REPRESENTATION,'$conditions',FILTREREP)  From ASYRJSO
          Raz FILTREREP : #VVVVV
          #
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Next ASW

Close Local File [AUS_ACTX]
Close Local File [AFF_ACTX]
Close Local File [AOB_ACTX]
Close Local File [AFC_ACTX]
Close Local File [AUB_ACTX]
Close Local File [ATB_ACTX]
Close Local File [ARL_ACTX]

Call JSON_ADDCLB(NODES,ROOT,'$disabledFunctions',DISABLEDFUNCTIONS)  From ASYRJSO
Call JSON_ADDCLB(NODES,ROOT,'$authorizedFunctions',AUTHORIZEDFUNCTIONS_CLB)  From ASYRJSO
Call JSON_ADDCLB(NODES,ROOT,'$accessCodes',ACCESSCODES)  From ASYRJSO
Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO
LogicClose File
FreeGroup LACTX

End ERROR


$ERR
ERROR=[V]CST_AOK
Resume

