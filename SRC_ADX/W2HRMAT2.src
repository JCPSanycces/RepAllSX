$ON_GUAATH
Onevent CONTROL Call C_GUAATH(zc) From W2HRMAT2
Onevent BEFORE_INPUT Call AS_GUAATH(zc) From W2HRMAT2
Return

Subprog AS_GUAATH(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_GUAATH(zc) From W2HRMAT2
Gosub _AFF
End

Subprog C_GUAATH(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ACONTFIC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ACONTFIC"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTFIC","SELFICREP","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GUAATH" : GZNUM = 10483 : Endif
Endif
Gosub _AFF
End

Subprog S_GUAATH(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELFICREP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFICREP"
 PARMSK(1) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 GACTION = SAVACT
Endif
Gosub _AFF
End

$TIT_COL
Gosub TIT_COL From W3HRMAT2
Return


