#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_DPDTYP
Onevent INIT_AREA Call D_DPDTYP(zc) From W2HRMAT2
Onevent BEFORE_INPUT Call AS_DPDTYP(zc) From W2HRMAT2
Return

Subprog D_DPDTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]DPDTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DPDTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DPDTYPMID
Onevent AFTER_CHANGE Gosub AMM_DPDTYPMID From W2HRMAT2
Onevent INIT_AREA Call D_DPDTYPMID(zc) From W2HRMAT2
Onevent BEFORE_INPUT Call AS_DPDTYPMID(zc) From W2HRMAT2
Return

Subprog D_DPDTYPMID(VALEUR)
Variable Integer VALEUR
If varinit([M]DPDTYPMID,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DPDTYPMID(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_DPDTYPMID
Call AM_DPDTYPMID(zc)
If !mkstat & GOBJET
 zoncou = "DPDTYPMID" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DPDTYPMID(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_DPDTYPMID(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "DPDTYPMID" : GZNUM = 55311 : Endif
Gosub _AFF
End

$ON_CHDNAM
Onevent INIT_AREA Call D_CHDNAM(zc) From W2HRMAT2
Onevent CONTROL Call C_CHDNAM(zc) From W2HRMAT2
Return

Subprog D_CHDNAM(VALEUR)
Variable Char    VALEUR()
If varinit([M]CHDNAM,indice)=0
 ## Action STD
 Call D_CHDNAM(VALEUR) From SUBEML2
Endif
Gosub _AFF
End

Subprog C_CHDNAM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CHDNAM" : GZNUM = 55 : Endif
Gosub _AFF
End

