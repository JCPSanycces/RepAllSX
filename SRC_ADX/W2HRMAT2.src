$ON_DATCHDBRN
Onevent CONTROL Call C_DATCHDBRN(zc) From W2HRMAT2
Onevent BEFORE_AREA Gosub AV_DATCHDBRN From W2HRMAT2
Return

$AV_DATCHDBRN
Chgfmt [M]DATCHDBRN(indice) With "DzZ:"+GFMDAT4
Gosub _AFF
Return

Subprog C_DATCHDBRN(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DATCHDBRN" : GZNUM = 12782 : Endif
Gosub _AFF
End

$ON_LNKPAR
Onevent CONTROL Call C_LNKPAR(zc) From W2HRMAT2
Onevent BEFORE_INPUT Call AS_LNKPAR(zc) From W2HRMAT2
Return

Subprog AS_LNKPAR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_LNKPAR(zc) From W2HRMAT2
Gosub _AFF
End

Subprog C_LNKPAR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_LNKPAR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "LNKPAR" : GZNUM = 22583 : Endif
Gosub _AFF
End

Subprog S_LNKPAR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELJNTNAM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELJNTNAM"
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELJNTNAM","SUBEML","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

