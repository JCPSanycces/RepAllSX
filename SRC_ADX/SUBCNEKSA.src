#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################################
## FLIP 19/05/2013 - Added this subprogram to calcu;ate days for leave cycles in RSA specific
## 19/05/2014 FLNEL - Subprogram is called from SUBCNE and INITCP
############################################################################################

#JASMI - 2014-09-04 - START
#JASMI - 2014-10-29 - 2999 - START
#Subprog CALC_LVE_DATES_KSA(TIM,CPY,YEA,REFNUM,CTRNUM,EMPLVESTR,EMPLVEEND,EMPCYCSTR,EMPCYCEND)
Subprog CALC_LVE_DATES_KSA(TIM,CPY,YEA,REFNUM,CTRNUM,EMPLVESTR,EMPLVEEND,EMPCYCSTR,EMPCYCEND,CURRENTDATE,NEWYEA)
#JASMI - 2014-10-29 - 2999 - END
Value Char      TIM,CPY,REFNUM,CTRNUM
Value Integer   YEA
Variable Date   EMPLVESTR,EMPLVEEND,EMPCYCSTR,EMPCYCEND
#JASMI - 2014-10-29 - 2999 - START
Value Date      CURRENTDATE
Variable Integer   NEWYEA
#JASMI - 2014-10-29 - 2999 - END
Local Integer   LVESEL, LVETRM
Local Integer   ADDYEARS

#JASMI - 2014-09-04 - START
#If func AFNC.ACTIV("KSA")>0
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JASMI - 2014-09-04 - END
  If !clalev([F:HRCTR])  : Local File EMPLOCTR  [HRCTR]  : Endif
  Filter [F:HRCTR] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM
  Read[F:HRCTR]CTR0 Last
  Filter [F:HRCTR]
#JASMI - 2017-11-09 - X3-63494 - START
  Local Date SENIORITY_DATE
  Local Char THIS_OPTION(1)
  Call PARAM([F:HRCTR]ETRFCY,"LVESENDAT",[L]THIS_OPTION) From ADOVAL
  Case [L]THIS_OPTION
  When '1'
    [L]SENIORITY_DATE=evalue('[F:HRCTR]DATANC')
  When '3'
    [L]SENIORITY_DATE=evalue('[F:HRCTR]DATFCY')
  When Default
    [L]SENIORITY_DATE=evalue('[F:HRCTR]DATCPY')
  Endcase
#JASMI - 2017-11-09 - X3-63494 - END
  Read [CNG]CNG0=[L]CPY;[L]YEA;[L]TIM
  [L]LVESEL=[F:CNG]LVESEL
  If [F:CNG]LVETRM = 0 Then
    [L]LVETRM=1
  Else
    [L]LVETRM=[F:CNG]LVETRM
  Endif
  Case [L]LVESEL
    When 1
    #JASMI - 2014-10-29 - 2999 - START
      If [L]CURRENTDATE <> [0/0/0] Then
      #JASMI - 2015-11-04 - Req. No. 111578 - START
#        If month([L]CURRENTDATE) < month([F:CTR]DATFCY) Then
#JASMI - 2017-11-09 - X3-63494 - START
#        If month([L]CURRENTDATE) < month([F:HRCTR]DATFCY) Then
        If month([L]CURRENTDATE) < month([L]SENIORITY_DATE) Then
#JASMI - 2017-11-09 - X3-63494 - END
      #JASMI - 2015-11-04 - Req. No. 111578 - END
          [L]YEA = [L]YEA - 1
          [L]NEWYEA = [L]YEA
        Endif
      Endif
    #JASMI - 2014-10-29 - 2999 - END
    #JASMI - 2015-11-04 - Req. No. 111578 - START
#      [L]ADDYEARS = [L]YEA - year([F:CTR]DATFCY)
#      [L]EMPLVESTR=gdat$(day([F:CTR]DATFCY),month([F:CTR]DATFCY),year([F:CTR]DATFCY)+[L]ADDYEARS)
#      [L]ADDYEARS = int(([L]YEA - year([F:CTR]DATFCY)) / [L]LVETRM) * [L]LVETRM
#      [L]EMPCYCSTR=gdat$(day([F:CTR]DATFCY),month([F:CTR]DATFCY),year([F:CTR]DATFCY)+[L]ADDYEARS)
#JASMI - 2017-11-09 - X3-63494 - START
#      [L]ADDYEARS = [L]YEA - year([F:HRCTR]DATFCY)
#      [L]EMPLVESTR=gdat$(day([F:HRCTR]DATFCY ),month([F:HRCTR]DATFCY),year([F:HRCTR]DATFCY)+[L]ADDYEARS)
#      [L]ADDYEARS = int(([L]YEA - year([F:HRCTR]DATFCY)) / [L]LVETRM) * [L]LVETRM
#      [L]EMPCYCSTR=gdat$(day([F:HRCTR]DATFCY),month([F:HRCTR]DATFCY),year([F:HRCTR]DATFCY)+[L]ADDYEARS)
      [L]ADDYEARS = [L]YEA - year([L]SENIORITY_DATE)
      [L]EMPLVESTR=gdat$(day([L]SENIORITY_DATE),month([L]SENIORITY_DATE),year([L]SENIORITY_DATE)+[L]ADDYEARS)
      [L]ADDYEARS = int(([L]YEA - year([L]SENIORITY_DATE)) / [L]LVETRM) * [L]LVETRM
      [L]EMPCYCSTR=gdat$(day([L]SENIORITY_DATE),month([L]SENIORITY_DATE),year([L]SENIORITY_DATE)+[L]ADDYEARS)
#JASMI - 2017-11-09 - X3-63494 - END
    #JASMI - 2015-11-04 - Req. No. 111578 - END
    When 2
      [L]EMPLVESTR=[F:CNG]DEBDAT
    #JASMI - 2015-11-04 - Req. No. 111578 - START
#      [L]EMPLVEEND=[F:CNG]FINDAT
    #JASMI - 2015-11-04 - Req. No. 111578 - END
      [L]EMPCYCSTR=[F:CNG]DEBDAT
    #JASMI - 2015-11-04 - Req. No. 111578 - START
#      [L]EMPCYCEND=[F:CNG]FINDAT
    #JASMI - 2015-11-04 - Req. No. 111578 - END
    When 3
      [L]EMPLVESTR=evalue([F:CNG]LVEFOR)
    #JASMI - 2016-08-18 - X3PEOP-432 - START
      [L]EMPCYCSTR=evalue([F:CNG]LVEFOR)
    #JASMI - 2016-08-18 - X3PEOP-432 - END
  Endcase
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  If [L]LVESEL<>2 Then
#JASMI - 2015-11-04 - Req. No. 111578 - END
#calc [L]EMPLVEEND
    YEAR_OF_DATE=year([L]EMPLVESTR)+1
    DAY_OF_DATE=day([L]EMPLVESTR)-1
    If DAY_OF_DATE > 0 Then
      MONTH_OF_DATE=month([L]EMPLVESTR)
      [L]EMPLVEEND=gdat$(DAY_OF_DATE,MONTH_OF_DATE,YEAR_OF_DATE)
    Else
      If month([L]EMPLVESTR) = 1 Then
        MONTH_OF_DATE=12
        YEAR_OF_DATE=YEAR_OF_DATE - 1
      Else
        MONTH_OF_DATE=month([L]EMPLVESTR)-1
      Endif
      [L]EMPLVEEND=eomonth(gdat$(1,MONTH_OF_DATE,YEAR_OF_DATE))
    Endif
#calc [L]EMPCYCEND
    YEAR_OF_DATE=year([L]EMPCYCSTR)+[L]LVETRM
    DAY_OF_DATE=day([L]EMPCYCSTR)-1
    If DAY_OF_DATE > 0 Then
      MONTH_OF_DATE=month([L]EMPCYCSTR)
      [L]EMPCYCEND=gdat$(DAY_OF_DATE,MONTH_OF_DATE,YEAR_OF_DATE)
    Else
      If month([L]EMPCYCSTR) = 1 Then
        MONTH_OF_DATE=12
        YEAR_OF_DATE=YEAR_OF_DATE - 1
      Else
        MONTH_OF_DATE=month([L]EMPCYCSTR)-1
      Endif
      [L]EMPCYCEND=eomonth(gdat$(1,MONTH_OF_DATE,YEAR_OF_DATE))
    Endif
#JASMI - 2015-11-04 - Req. No. 111578 - START
#  Endif
#JASMI - 2015-11-04 - Req. No. 111578 - END

Endif
End
#JASMI - 2014-09-04 - END

#JASMI - 2017-11-28 - X3-63494 - START
Subprog VERF_PARAM(PARAM, VALINT, RET)
Value Char       PARAM
Value Char       VALINT
Variable Integer RET

  If PARAM='LVESENDAT'
    Infbox mess(128,193,1)
  Endif

End
#JASMI - 2017-11-28 - X3-63494 - END

