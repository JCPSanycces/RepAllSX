##########################################################
##  SDD management                                      ##
##########################################################

#############################################################################
##  SDD management                                                         ##
## Display of "UMR number" field on customer's invoice screens : BIC1      ##
## The show/hide of the field depends on :                                 ##
##     - the activity code (SDD) and the value of the SDDMGT parameter     ##
## The Entry of the field depends on the payment terms                     ##
##                                                                         ##
#############################################################################
$SHOW_HIDE_UMRNUM
If dim([M:BIC1]UMRNUM)<=0 : Return : Endif

If GSDDMGT = 2
 If [M:BIC1]STA=3
  Chgfmt [M:BIC1]UMRNUM With "KP:"+num$(type([M:BIC1]UMRNUM)-10)+"X"
 Else
  Chgfmt [M:BIC1]UMRNUM With "K:"+num$(type([M:BIC1]UMRNUM)-10)+"X"
  Gosub GRIZO_UMRNUM
 Endif
Else
 Chgfmt [M:BIC1]UMRNUM With "-K:"+num$(type([M:BIC1]UMRNUM)-10)+"X"
Endif
Return

#############################################################################
##  SDD management                                                         ##
## Display of "UMR number" field on customer's invoice screens : BIC1      ##
## The show/hide of the field depends on :                                 ##
##     - the activity code (SDD) and the value of the SDDMGT parameter     ##
## The Entry of the field depends on the payment terms                     ##
##                                                                         ##
#############################################################################
$GRIZO_UMRNUM
If dim([M:BIC1]UMRNUM)<=0 : Return : Endif
Local Integer FLG_UMRNUM
Call PTESDD([M:BIC1]PTE,FLG_UMRNUM) From INVSDDLIB

If ![L]FLG_UMRNUM
 Grizo [M:BIC1]UMRNUM
Else
 Actzo [M:BIC1]UMRNUM
Endif
Affzo [M:BIC1]UMRNUM
Return


###############################################################################
## SDD management                                                            ##
## Initialization of "UMR number" field                                      ##
## The initialization of the field depends on :                              ##
##     - the company and & bpartner pay                                      ##
##                                                                           ##
###############################################################################
Subprog INIT_UMRNUM(CPY,BPR,MAI,STA,UMR)
Value    Char    CPY
Value    Char    BPR
Value    Integer MAI   # Main   mandate ML1
Value    Integer STA   # Status mandate ML3631
Variable Char UMR

If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
Raz [L]UMR

If [L]MAI<>0
 Filter [MDT] Where CPY=[L]CPY & BPCNUM=[L]BPR  & STA=[L]STA & MAIMDTFLG=[L]MAI
Else
 Filter [MDT] Where CPY=[L]CPY & BPCNUM=[L]BPR & STA=[L]STA
Endif

Read [MDT]MDT1 First
If !fstat
 [L]UMR=[F:MDT]UMRNUM
Endif
Filter [MDT]

GPOINT = "INIRUM" : Gosub ENTREE From EXEFNC

End

###############################################################################
## SDD management                                                            ##
## Control of "UMR number" field                                             ##
## The control of the field depends on :                                     ##
##     - the company and & bpartner pay                                      ##
##                                                                           ##
###############################################################################
Subprog CTL_UMRNUM2(UMR,CPY,BPR,TAM)
Value    Char    UMR
Value    Char    CPY
Value    Char    BPR
Value    Char    TAM

If UMR<>"" : Goto CTL : Endif

If clalev([F:TAM])=0 : Local File TABPAM  [TAM] : Endif
Call LEC_TAM(GCURLEG,TAM) From CPTLEC
If !fstat & [F:TAM]SDDFLG=2
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
Goto CTL

Subprog CTL_UMRNUM(UMR,CPY,BPR)
Value    Char    UMR
Value    Char    CPY
Value    Char    BPR

$CTL
If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
Raz mkstat, GMESSAGE

If [F:MDT]UMRNUM<>[L]UMR | [F:MDT]CPY<>[L]CPY
 Read [MDT]MDT0 = [L]CPY;[L]UMR
Endif
If [F:MDT]CPY<>[L]CPY
 GMESSAGE=mess(83,123,1)+"\"+mess(2,45,1)-[F:MDT]CPY+"<>"+[L]CPY
 mkstat=2 : End
Endif
If [F:MDT]BPCNUM<>[L]BPR
 GMESSAGE=mess(83,123,1)+"\"+mess(143,121,1)-[F:MDT]BPCNUM+"<>"+[L]BPR
 mkstat=2 : End
Endif
End

###############################################################################
## SDD management                                                            ##
## This sub programm allows to know if the invoice (NUMERO) contains an open ##
## item checked SDD, at least                                                ##
###############################################################################
Subprog DUDPAMSDD(TYPTIERS,NUMERO,FLGSDD)
Value    Integer TYPTIERS
Value    Char    NUMERO
Variable Integer FLGSDD

Local Integer OK , NUMECH

[L]FLGSDD=0
If TYPTIERS=1
 If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
 If [F:SIH]NUM<>NUMERO
  Read [SIH]SIH0 = NUMERO
  If fstat : OK = 0 : End : Endif
 Endif
 NUMECH   = [F:SIH]ACCNUM
Elsif TYPTIERS=3
 If clalev([F:BRH])=0 : Local File BPSRINV [BRH] : Endif
 If [F:BRH]NUM<>NUMERO
  Read [F:BRH]PIH0 = NUMERO
  If fstat : OK = 0 : End : Endif
 Endif
 NUMECH   = [F:BRH]ACCNUM
Else
 If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
 If [F:PIH]NUM<>NUMERO
  Read [PIH]PIH0 = NUMERO
  If fstat : OK = 0 : End : Endif
 Endif
 NUMECH   = [F:PIH]ACCNUM
Endif

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif

For [DUD]DUD1 Where ACCNUM=NUMECH
 Call LEC_TAM(GCURLEG,[F:DUD]PAM) From CPTLEC
 If !fstat & [F:TAM]SDDFLG=2
  [L]FLGSDD = 1 : Break
 Endif
Next
End

###############################################################################
## SDD management                                                            ##
## This sub programm allows to know if the invoice (NUMERO) is associated    ##
## to a payment term that contains, at least, a payment mode checked 'SDD'   ##
###############################################################################
Subprog PTESDD(PTE,FLGSDD)
Value    Char    PTE
Variable Integer FLGSDD

If clalev([F:TPT])=0    : Local File TABPAYTERM [TPT] : Endif
If clalev([F:TAM])=0    : Local File TABPAM     [TAM] : Endif

Local Char    TPTLEG(GLONADI)

[L]FLGSDD = 0
Call LEC_TPT_LEG(GCURLEG,[L]PTE,1) From CPTLEC
If !fstat
 [L]TPTLEG = [F:TPT]LEG
 For [F:TPT] Where PTE=[L]PTE & LEG=[L]TPTLEG
  Call LEC_TAM(GCURLEG,[F:TPT]PAM) From CPTLEC
  If !fstat & [F:TAM]SDDFLG=2
   [L]FLGSDD= 1 : Break
  Endif
 Next
Endif
End
