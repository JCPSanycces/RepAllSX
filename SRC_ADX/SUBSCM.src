######################################################################################
Subprog AM_BOMOFS(VALEUR)
Variable Decimal VALEUR
#Value    Date     WORIDAT   # Ctrl des sources
Local    Char     WORIFCY(GLONFCY)
Local    Integer  WLTI
Local    Date     WDSTDAT
#
# Calcul Date mise à dispo du composant
  If VALEUR>0 & [F:SCO]RETDAT <> [0/0/0] & [M:SCMW]SCOFLG=2
  # Date de livraison des matières: obligatoire pour génération de l'encours MSx
    Local Integer WOFS : WOFS=VALEUR
    Local Date    WSTRDAT,WENDDAT
    If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Else WSTRDAT=[F:SCO]ORDDAT Endif
    If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[F:SCO]RETDAT Endif
    Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[M:SCM0]STOFCY,WOFS,[M:SCMW]DLVDAT) From SCOLIB
  Endif
#
  MMODIF = 1
End

######################################################################################
Subprog AS_BOMSHO(VALEUR)
Variable Char    VALEUR()
End

######################################################################################

Subprog AS_RETQTY(VALEUR)
Variable Decimal VALEUR

End

Subprog C_RETQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 & [M:SCMW]MATSTA<>4 & [M:SCMW]CPNTYP<>5 : mkstat = 2 : End : Endif
If VALEUR > 0 & VALEUR < [M:SCMW]USEQTY
   Call MESSAGE(mess(63,193,1)) From GESECRAN
   mkstat=2
   End
Endif
End

Subprog AM_RETQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer NOL : NOL = nolign-1
Local    Integer VS

If clalev([M:SCO1]) # Issue 93349 GA 10/2013
    WEXT = VALEUR
    # vérification seuil solde automatique atteint
    WCPL = [M:SCMW]USEQTY
    Call CONT_SOLDE_MAT([M:SCM0]STOFCY, [M:SCM0]CPNITMREF, WCPL, WEXT, WRET) From SCOLIB

    If WRET = 1
        VS=1
        Call AVERTIR(mess(53,190,1),VS) From GESECRAN
        If VS = 1
            VALEUR = [M:SCMW]RETQTY
            mkstat = 2
            End
        Endif
        [M:SCMW]MATSTA = 3
        Diszo [M:SCMW]
    Endif
Endif

# FQ 74682 GA 07/2011
Gosub CALC_LINAMT_SCMW From SCOLIB

MMODIF = 1

End

######################################################################################

Subprog C_DLVDAT(VALEUR)
Variable Date    VALEUR
#
If VALEUR = [0/0/0] : mkstat = 2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SCM0]STOFCY) From MFGLIB

End

Subprog AM_DLVDAT(VALEUR)
Variable Date    VALEUR

If VALEUR > [F:SCO]RETDAT
    Call ERREUR(mess(64,193,1)) From GESECRAN
    mkstat=2
    End
Endif

# FQ 67864 GA 10/2010 ne pas faire ce contrôle
# Message de mise en garde si date dépassée
# Call CHECK_PAST(VALEUR, 2)  From MFGLIB

MMODIF=1
End



######################################################################################
# Les enreg [F:ITM] et [F:ITF] sont déjà chargés
######################################################################################

Subprog RECH_SCM_CPNITMREF(LCPNITMREF)
Variable Char    LCPNITMREF()
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer WOK  : WOK  = 2

#----- Contrôle si article actif ? -----#
WOK = func ITMLIB.IS_ACTIVE ( LCPNITMREF )
If WOK=1  : mkstat=1: End : Endif

If [M:SCMW]DLVDAT=[0/0/0]
  # Date de livraison des matières
  Local Integer WOFS : WOFS=[M:SCMW]BOMOFS
  Local Date    WSTRDAT,WENDDAT
  If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Else WSTRDAT=[F:SCO]ORDDAT Endif
  If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[F:SCO]RETDAT Endif
  Call UPD_MAT_DAT([F:SCS]OPESTR, [F:SCS]OPEEND,[M:SCMW]STOFCY,WOFS,[M:SCMW]DLVDAT) From SCOLIB
Endif
#---------------------------------------
# Quantités
#---------------------------------------
    If dim([M:SCMW]BOMUOM)>0    # UML actif # FQ 76146 GA 09/2011
       If [M:SCMW]BOMUOM="" : [M:SCMW]BOMUOM = [F:ITM]STU : Endif
    Endif
    [M:SCMW]STU      = [F:ITM]STU
    [M:SCMW]STOMGTCOD= func ITMLIB.GET_STOMGTCOD(LCPNITMREF, [M:SCM0]STOFCY)
    LQTY = [F:SCI]RMNEXTQTY # Issue 105344 GA 01/2015 before EXTQTY
    [M:SCMW]BASQTY=[F:SCI]BASQTY # Issue 80922 GA 05/2012 ?
  # calcul quantité matière nécessaire pour produire LQTY
  # Issue 105344 GA 01/2015
    Local Integer WLIKQTYCOD : WLIKQTYCOD=1 # Proportionnal to calculate, and then fixed qty
    Call CALCUL_QTY([F:SCI]BASQTY   , [M:SCMW]STU   , WLIKQTYCOD,
&                   [M:SCMW]LIKQTY   , [M:SCMW]QTYRND, [M:SCMW]SCA,
&                   [M:SCMW]RELSCATIA, [M:SCMW]RETQTY, LQTY) From SCOLIBM

    [M:SCMW]MATSTA = 1
    [M:SCMW]CPNTYP = 1   # Issue 86384
    Affzo [SCMW]
End

######################################################################################

Subprog CTRL_SCOFLG (LSCOFLG)
Value Integer LSCOFLG
Local Decimal WDIS
Local Integer WRET

If LSCOFLG=2
# -----------------------------------------------
# Matière mise à disposition du sous-traitant
# -----------------------------------------------

  [M:SCMW]PICPRN = 2
  # Issue 105344 GA 01/2015 [F:SCO]MFGFCY => [F:SCO]MFGFCY
  If [M:SCMW]MFGFCY<> [F:SCO]MFGFCY & [F:SCO]MFGFCY<>""
     [M:SCMW]MFGFCY = [F:SCO]MFGFCY
  Endif

  If [M:SCMW]CPNTYP>1
  # "Ce type de composant ne peut être mis à disposition du sous-traitant"
     GMESSAGE=mess(524,199,1) : mkstat=1 : GERR = 1 : End
  Endif

# "Pas d'emplacement de sous-traitance pour ce fournisseur: livraison impossible !"
  If [M:SCMW]LOC="" & [F:SCI]LOC=""
     GMESSAGE=mess(525,199,1) : mkstat=1 : End
  Endif

#
#----- article géré en stock ?              -----#
  [M:SCMW]STOMGTCOD = func ITMLIB.GET_STOMGTCOD([M:SCM0]CPNITMREF,[M:SCM0]STOFCY)
  Affzo [M:SCMW]STOMGTCOD
  If [M:SCMW]STOMGTCOD=2
    # recherche stock disponible site
    Call LECITV2([M:SCM0]STOFCY,[M:SCM0]CPNITMREF,WRET) From MFGLIB

    #--- Issue 115110 : Added LECCVAL parameter in 10th position
    Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
    If dim([M:SCM0]ECCVALMAJ)>0 & [M:SCM0]ECCVALMAJ<>""
      If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
      Call LECSRU([M:SCM0]STOFCY,[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
      If WRET=0 & [F:SRU]ORDVER=2
        WECCVALMAJ=[M:SCM0]ECCVALMAJ
      Endif
    Endif
    Call STODISALL([M:SCM0]STOFCY,[M:SCM0]CPNITMREF,36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
    #Call STODISALL([M:SCM0]STOFCY,[M:SCM0]CPNITMREF,36,1,2,1,2,"","",WDIS,WRET) From STKALL
    #--- End Issue 115110

    [M:SCMW]AVAQTY    = WDIS + [M:SCMW]ALLQTY
  Endif

  # Date de livraison des matières
  Local Integer WOFS : WOFS=[M:SCMW]BOMOFS
  Local Date    WSTRDAT,WENDDAT
  If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Else WSTRDAT=[F:SCO]ORDDAT Endif
  If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[F:SCO]RETDAT Endif
  Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[M:SCM0]STOFCY,WOFS,[M:SCMW]DLVDAT) From SCOLIB

Else

  If LSCOFLG=3
  # Est-ce que cet article est acheté ? sinon pb génération de la commande
    WOK = func ITMLIB.IS_BOUGHT ( [M:SCM0]CPNITMREF )
    If WOK=1 : mkstat=1: End : Endif

  # les matières sont sur le site du sous-traitant
    [M:SCM0]STOFCY = [F:SCI]PRHFCY : Affzo [M:SCM0]STOFCY

  Endif

# -----------------------------------------------
# Matière interne ou fournie par le sous-traitant
# -----------------------------------------------
  [M:SCMW]PICPRN = 1 : : Affzo [M:SCMW]PICPRN
  If LSCOFLG=3 | [M:SCMW]CPNTYP=5
     #----- article non géré en stock         -----#
     [M:SCMW]STOMGTCOD  =1  : Affzo [M:SCMW]STOMGTCOD
     Raz [M:SCMW]AVAQTY     : Affzo [M:SCMW]AVAQTY
     Raz [M:SCMW]LOC        : Affzo [M:SCMW]LOC
     Raz [M:SCMW]MFGFCY     : Affzo [M:SCMW]MFGFCY
     Raz [M:SCMW]LOT        : Affzo [M:SCMW]LOT
     Raz [M:SCMW]DLVDAT     : Affzo [M:SCMW]DLVDAT

  Elsif [M:SCM0]STOFCY=""
     [M:SCM0]STOFCY = [F:SCI]PRHFCY : Affzo [M:SCM0]STOFCY
  Endif

Endif

End


# Saisie LOC & LOT ssi composant mis à dispo du sous-traitant

Subprog AS_LOT(VALEUR)
Variable Char     VALEUR
If [M:SCMW]SCOFLG<>2 mkstat=2 Endif
End
Subprog AS_LOC(VALEUR)
Variable Char     VALEUR
If [M:SCMW]SCOFLG<>2 mkstat=2 Endif
End



######################################################################################
# FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
# Issue 105334 GA 01/2015
If clalev([M:SCO1]) & [M:SCO1]ITMSTA>2 : mkstat=2 : End : Endif
If [M:SCMW]SCOFLG<>3
  Raz [M:SCMW]GROPRI,NETPRI,PRIREN,REFPRI
  If dim([F:SCI]CHGTYP)>0
    Gosub CALC_LINAMT_SCMW From SCOLIB
    Affzo [M:SCMW]
  Endif
  mkstat=2
Endif
End

######################################################################################
# FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR

If VALEUR=0 & clalev([M:SCO2])  # Issue 93349 GA 10/2013
  Local Integer  J, NOL : NOL=nolign-1
  # Relecture du tarif achat dans [M:SCO2]
  Call UPD_MAT_PRI(NOL) From SCOLIB
  VALEUR=[M:SCO2]GROPRI(NOL)
  [M:SCMW]PRIREN = [M:SCO2]PRIREN(NOL)
  [M:SCMW]NETPRI = [M:SCO2]NETPRI(NOL)
  [M:SCMW]LINAMT = [M:SCO2]LINAMT(NOL)
  [M:SCMW]REFPRI = [M:SCO2]REFPRI(NOL)
  [M:SCMW]NETPRIL= [M:SCO2]NETPRIL(NOL)
  [M:SCMW]LINAMTL= [M:SCO2]LINAMTL(NOL)
Else

  Local Decimal  MT1, MT2, DISCRGVAL(0..8)
  For J=1 To 9
      If evalue("dim([M:SCMW]DISCRGVAL"+num$(J)+")")>0
          If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&             MT1=evalue("[M:SCMW]DISCRGVAL"+num$(J)+"*MT2")
              Call ARRDEV(MT1,[F:SCI]CUR) From TRTDIV
              Assign "[M:SCMW]DISCRGVAL"+num$(J) With MT1
          Endif
          [L]DISCRGVAL(J-1)=evalue("[M:SCMW]DISCRGVAL"+num$(J))
      Endif
  Next J
  If dim(GCALNETLIN)>0  GCALNETLIN=1          : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:SCMW]" : Endif
  Call CALNET(2,[F:BPS]PLISTC,VALEUR,[L]DISCRGVAL,[M:SCMW]RETQTY,
&               [M:SCMW]NETPRI,[F:SCO]CUR) From TRTPRICE
#
  If dim(GDACMANPUR)<0 | GDACMANPUR=0      # Issue 93852 GA 01/2014
    [M:SCMW]PRIREN=GUPDPRIPUR         # 8=Motif ne venant pas du tarif
  Else
    [M:SCMW]PRIREN=GDACMANPUR         # Motif de saisie manuelle du prix de la DA
  Endif

  # FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
  If dim([F:SCI]CHGTYP)>0
    Gosub CALC_LINAMT_SCMW From SCOLIB
    Affzo [M:SCMW]
  Endif
Endif
MMODIF = 1
End

Subprog AP_GROPRI(VALEUR)               # Suite Issue 93852 GA 06/2014
Variable Decimal VALEUR
#---------------------------------------------------------------------------------#
# Après saisie du prix brut : si matière fournie par le sous-traitant             #
#---------------------------------------------------------------------------------#
If [M:SCMW]SCOFLG<>3 VALEUR=0 Endif
End

######################################################################################
# Issue 91501 GA 07/2013

Subprog D_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCM]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub D_CCEX
End

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
# Issue X3_39028 - 2017-06-06 by MUARN : SCMA et non SCM
Local    Integer AXE : AXE=find([M:SCMA]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub AS_CCEX
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCM]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub C_CCEX
End

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SCM","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[F:SCO]RETDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[F:SCS]SRVITMREF
Endif
Return

######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer LRET

# Issue 111417 - 2015-09-30 by CCC : wait ECCVALMIN if necessary
# Issue 114828 - 2016-02-26 by SR : DLVDAT instead of STRDAT
If func ECCLIB.NBRCPN([M:SCM0]CPNITMREF)=1
    # Issue 110904 - 2015-09-30 by GA : [M:SCM0]ITMREF replaced by [M:SCM0]CPNITMREF
    Call CTRECC([M:SCM0]CPNITMREF,"SCM0","ECCVALMAJ",VALEUR,[M:SCM0]ECCVALMIN,
&               [M:SCM0]DLVDAT,LRET,[M:SCM0]ECCERRMSG) From ECCLIB

    [M:SCM0]ECCERRCOD = LRET
Endif

# Issue 110904 - 2016-04-13 by JUSYN : Display message for error in major version
If find(LRET,1,4)
    GMESSAGE=[M:SCM0]ECCERRMSG
    mkstat=2
Endif

End

######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Local Integer LRET

# Issue 110904 - 2015-09-30 by GA : [M:SCM0]ITMREF replaced by [M:SCM0]CPNITMREF
# Issue 114828 - 2016-02-26 by SR : DLVDAT instead of STRDAT
Call CTRECC([M:SCM0]CPNITMREF,"SCM0","ECCVALMIN",[M:SCM0]ECCVALMAJ,VALEUR,
&           [M:SCM0]DLVDAT,LRET,[M:SCM0]ECCERRMSG) From ECCLIB

[M:SCM0]ECCERRCOD = LRET

# Issue 110904 - 2016-04-13 by JUSYN : Display message for error in minor version
If find(LRET,1,4)
    GMESSAGE=[M:SCM0]ECCERRMSG
    mkstat=2
    GERR = 1
Endif

End
######################################################################################

