#<AdxTL>@(#)10.0.0.0 $Revision$
# Gestion du masque SCMW          (selon MFMW et SUBMFG2)
# Les actions sont dans SCOWINLIB (selon MFMWINLIB)
######################################################################################
# Issue 93349 GA 10/2013 Cohabitation SCMFICH avec l'action SCKFICH
# dans SUBSCM on utilise à présent les buffers [F:SCO], [F:SCI], [F:SCS] au lieu des masques écrans
# le chargement est fait dans SCOWINLIB DEB_SCMFICH et/ou DEB_SCKFICH
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
Subprog AS_CPNITMREF(VALEUR)
Variable Char    VALEUR()
If GMODMAT <> 2 : mkstat = 2 : Endif
End

######################################################################################
Subprog C_CPNITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer    I
Local Integer    WOK  : WOK  = 2
Local Char       WFCY(GLONFCY) : WFCY = [F:SCI]PRHFCY # Issue 105334 GA 01/2015 before [F:SCO]POHFCY
Local Char       WCPNITM(GLONITM) : WCPNITM=VALEUR # Issue 93349 GA 10/2013
#
If [M:SCM0]STOFCY <> "" & [F:SCI]PRHFCY <> [M:SCM0]STOFCY
   WFCY = [M:SCM0]STOFCY
Endif

#---------------------------------------------------#
#  Lecture ITM et ITF
#---------------------------------------------------#
WOK = func ITMLIB.READ_ITM_ITF (WCPNITM, WFCY)
If WOK=1  mkstat=1 : End : Endif
#
# Issue X3-38334 - 2017-12-18 by SR : Permettre d'ajouter un composant non géré en stock si fourni pas le SST
#If [M:SCMW]SCOFLG=2
# # Contrôle de validité d'une matière #
# # ITM & ITF doivent être chargés ... #
# ######################################
# #  Call CONTMATITM(WFCY, 1) From MFGLIB
#    Call CONTMATITM(WCPNITM, WFCY, "SCM", GERR, GMESSAGE) From MFGLIB
#    If GERR=4
#        GERR = 1
#        mkstat=2
#        End
#    Endif
#Endif
# si non géré en stock, initialiser avec la valeur "fournie pas le sous-traitant"
If [F:ITM]STOMGTCOD = 1
   [M:SCMW]SCOFLG = 3
Else
   [M:SCMW]SCOFLG = 2
Endif
Call CONTMATITM(WCPNITM, WFCY, [M:SCMW]SCOFLG, "SCMW",WOK,GMESSAGE ) From SCOLIB
If WOK = 4 : mkstat = 1 : End : Endif
# End issue X3-38334
#
If clalev([M:SCO2]) # Issue 93349 GA 10/2013
  #For I=0 To [M:SCO2]NBLIG-1
  #    If [M:SCO2]CPNITMREF(I) = VALEUR
  #      If [M:SCO2]BOMSEQ(I)=0
  #         GMESSAGE = mess(67,193,1)
  #         mkstat = 2
  #         Break
  #      Endif
  #    Endif
  #Next I
  K = find (WCPNITM,[M:SCO2]CPNITMREF(0..[M:SCO2]NBLIG-1))
  If K
     GMESSAGE = WCPNITM - mess(67,193,1)
     mkstat = 2
  Endif
Elsif clalev([M:PSCM]) # Issue 93349 GA 11/2013
  K = find (WCPNITM,[M:PSCM]ITMREF(0..[M:PSCM]NBMAT-1))
  If K
     GMESSAGE = WCPNITM - mess(67,193,1)
     mkstat = 2
  Endif
Endif
#
End

######################################################################################
Subprog AM_CPNITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer L : L = nolign-1
Local Integer I
Local Char WSECTION(GLONCCE)

If !clalev([F:BOH]) Local File BOM  [F:BOH] Endif
If !clalev([F:BOD]) Local File BOMD [F:BOD] Endif

If [F:SCI]ITMREF<> [F:BOH]ITMREF | [F:SCI]BOMALT <> [F:BOH]BOMALT
 # on charge les données de l'entête de nomenclature
   Read [BOH]BOH0=[F:SCI]ITMREF;[F:SCI]BOMALT;3
Endif
[M:SCMW] = [F:BOH]

# Issue 100710 GA 06/2014 new component initialization
[M:SCMW]ALLSTA = 1
[M:SCMW]MATSTA = 1
# Issue X3-38334 - 2017-12-18 by SR : Déjà initialisé en C_CPNITMREF
#[M:SCMW]SCOFLG = 2

If VALEUR <> [F:BOD]CPNITMREF
 # on charge la 1ere matière qui correspond
   Filter [BOD] Where ITMREF=[F:SCI]ITMREF and BOMALT=[F:SCI]BOMALT and CPNITMREF=VALEUR
&                 and BOMALTTYP = 3
&                 and (BOMSTRDAT=[0/0/0] or BOMSTRDAT <= [F:SCO]ORDDAT)
&                 and (BOMENDDAT=[0/0/0] or BOMENDDAT >= [F:SCO]ORDDAT)
   Read   [BOD] BOD0 First : If ! fstat : [M:SCMW] = [F:BOD]: Else Raz [F:BOD] : Endif
   Filter [BOD]
Endif

# Lecture [F:ITM] prise en charge par C_CPNITMREF
Call RECH_SCM_CPNITMREF(VALEUR)

# Issue 105334 GA 01/2015 unexpected material
If [F:BOD]BOMSEQ=0
   [M:SCMW]LIKQTYCOD = 2
   [M:SCM0]CPNITMREF = VALEUR
   Call CTRL_SCOFLG([M:SCMW]SCOFLG)
Endif

# Issue 79808 - 2012-03-12 by CCC
Call INIT_TABCCE ("SCMA","DIE","CCE","NBDIE","SCM","PTR",2) From TRTX3CPT

# Issue 110904/114860 - 2016-04-12 by JUSYN : Display or hide for BOM version fields
Call ECCAFF(VALEUR , "SCM0" , 0) From SCOECCLIB

Affzo [M:SCMW]
Affzo [M:SCMA]
End

Subprog AP_CPNITMREF(VALEUR)
Variable Char     VALEUR
zonsui = "QTYCOD"
End

######################################################################################
Subprog AS_QTYCOD(VALEUR)
Variable Integer VALEUR
If GMODMAT > 0 : mkstat = 2 : Endif
End

Subprog AM_QTYCOD(VALEUR)
Variable Integer VALEUR
Local    Decimal WBES
Local    Decimal LQTY
#
Case VALEUR
 When 1    : [M:SCMW]BASQTY = 1
 When 2, 4 : [M:SCMW]BASQTY = 100
 When 3    : [M:SCMW]BASQTY = 1000
 When 5    : # lot réappro du site de l'alternative s'il est renseigné
      If !clalev([F:ITFW]) Local File ITMFACILIT [F:TIFW] Endif
      Read [ITFW]ITF0 = [F:SCI]ITMREF;[F:SCI]PRHFCY
      If !fstat : [M:SCMW]BASQTY = [F:ITFW]MFGLOTQTY : Endif
 When Default : [M:SCMW]BASQTY = 1
Endcase
Affzo [SCMW]BASQTY
#
#If [M:SCMW]RETQTY <> 0
# Issue 80922 GA 05/2012 avant [M:SCMW]BASQTY ko
#  # Qté commandée pour le composé
#    LQTY     = [F:SCI]QTYPUU
#    Call CALCUL_BESOIN([M:SCMW]BASQTY,[M:SCMW]STU,[M:SCMW]LIKQTYCOD,[M:SCMW]LIKQTY,
#&                      [M:SCMW]QTYRND,[M:SCMW]SCA,[M:SCMW]RELSCATIA,WBES,LQTY) From MFGLIBM
#    [M:SCMW]RETQTY = WBES
      LQTY = [F:SCI]EXTQTY
      Call CALCUL_QTY([F:SCI]BASQTY   , [M:SCMW]STU   , [M:SCMW]LIKQTYCOD,
&                     [M:SCMW]LIKQTY   , [M:SCMW]QTYRND, [M:SCMW]SCA,
&                     [M:SCMW]RELSCATIA, [M:SCMW]RETQTY, LQTY) From SCOLIBM
      Affzo [M:SCMW]RETQTY
#Endif
#
End

######################################################################################
Subprog AS_BASQTY(VALEUR)
Variable Decimal VALEUR
# initialisation de la quantité selon le code quantité
mkstat = 2 : # non saisissable sauf quand code "par lot"
End
Case [M:SCMW]QTYCOD
 When 1 : VALEUR = 1
 When 2 : VALEUR = 100
 When 3 : VALEUR = 1000
 When 4 : VALEUR = 100
 When 5 : # lot réappro du site de l'alternative s'il est renseigné
    mkstat = 0
    If [M:SCMW]BASQTY = 0 :
       VALEUR = 1
    Endif
    Read [ITF]ITF0 = [F:SCI]ITMREF;[F:SCO]POHFCY
    If !fstat : VALEUR = [F:ITF]MFGLOTQTY : Endif
 When Default : VALEUR = 1
Endcase
#
End

Subprog AM_BASQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY

#If [M:SCMW]RETQTY <> 0
# Issue 80922 GA 05/2012 avant [M:SCMW]BASQTY ko
#  # Qté commandée pour le composé
#    LQTY     = [F:SCI]QTYPUU
#    Call CALCUL_BESOIN(VALEUR,[M:SCMW]STU,[M:SCMW]LIKQTYCOD,[M:SCMW]LIKQTY,
#&                      [M:SCMW]QTYRND,[M:SCMW]SCA,[M:SCMW]RELSCATIA,WBES,LQTY) From MFGLIBM
#    [M:SCMW]RETQTY = WBES
      LQTY = [F:SCI]EXTQTY
      Call CALCUL_QTY([F:SCI]BASQTY   , [M:SCMW]STU   , [M:SCMW]LIKQTYCOD,
&                     [M:SCMW]LIKQTY   , [M:SCMW]QTYRND, [M:SCMW]SCA,
&                     [M:SCMW]RELSCATIA, [M:SCMW]RETQTY, LQTY) From SCOLIBM
      Affzo [M:SCMW]RETQTY
#Endif
MMODIF = 1
End

######################################################################################
Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif

If VALEUR = "" : VALEUR = [M]STU : Endif    # llc 09.03
TYP=0
Read [TUN]TUN0=[M]STU
If !fstat
    TYP = [F:TUN]UOMTYP
Endif

If (TYP <>3 & TYP <>4)
    VALEUR =[M]STU
    [M]BOMSTUCOE=1
    [M]BOMQTY=[M]LIKQTY
    mkstat=2
Endif

End

Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local    Decimal WBES
Local    Decimal LQTY

  If [M:SCMW]BOMUOM<>VALEUR
     [M:SCMW]BOMQTY=0 : [M:SCMW]LIKQTY=0
     Affzo [SCMW]BOMQTY,LIKQTY
  Endif

MMODIF =1
End

######################################################################################
Subprog AM_BOMQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY

#If [M:SCMW]RETQTY <> 0
# Issue 80922 GA 05/2012 avant [M:SCMW]BASQTY ko
#  # Qté commandée pour le composé
#    LQTY     = [F:SCI]QTYPUU
#    Call CALCUL_BESOIN([M:SCMW]BASQTY,[M:SCMW]STU,[M:SCMW]LIKQTYCOD,[M:SCMW]LIKQTY,
#&                      [M:SCMW]QTYRND,[M:SCMW]SCA,[M:SCMW]RELSCATIA,WBES,LQTY) From MFGLIBM
#    [M:SCMW]RETQTY = WBES
      LQTY = [F:SCI]EXTQTY
      If [M:SCMW]LIKQTY=0 [M:SCMW]LIKQTY=VALEUR Endif
      Call CALCUL_QTY([F:SCI]BASQTY   , [M:SCMW]STU   , [M:SCMW]LIKQTYCOD,
&                     VALEUR, [M:SCMW]QTYRND, [M:SCMW]SCA,
&                     [M:SCMW]RELSCATIA, [M:SCMW]RETQTY, LQTY) From SCOLIBM
      Affzo [M:SCMW]RETQTY
#Endif
MMODIF =1

End

