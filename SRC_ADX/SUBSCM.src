######################################################################################
Subprog AS_SCOFLG(VALEUR)
Variable Integer VALEUR
  GMENLOC(1)=1
  # Issue X3-38334 - 2017-12-18 by SR : si article non géré en stock, valeur initialisée à "Fournie par le sous-traitant"  et non modifiable
  If [F:ITM]ITMREF <> [M:SCM0]CPNITMREF
   Read [F:ITM]ITM0 = [M:SCM0]CPNITMREF
   If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]STOMGTCOD = 1 : mkstat = 2 : End : Endif
  # End issue X3-38334
End

Subprog AM_SCOFLG(VALEUR)
Variable Integer VALEUR

# si on passe de 2:"mise à dispo du sous-traitant" à 3:"fournie par le sous-traitant"
If find(VALEUR,1,3) & [M:SCMW]SCOFLG=2 & [M:SCMW]WIPNUM<>""
# maj non autorisée si matière déjà dans la commande
  If [M:SCMW]POHNUM<> ""
     Read [POQ]POQ0=[M:SCMW]POHNUM;[M:SCMW]POPLIN;[M:SCMW]POQSEQ
     If fstat Raz [F:POQ] : Endif
     If [F:POQ]POHNUM=[M:SCMW]POHNUM
       # Vous devez d'abord annuler la commande:
        GMESSAGE=mess(345,194,1)-[M:SCMW]POHNUM-"/"-num$([M:SCMW]POPLIN)
     Endif
  Endif
# plus besoin de date de livraison
  Raz [M:SCMW]DLVDAT : Affzo [M:SCMW]DLVDAT

Elsif VALEUR=2
  # Recherche du composant
    Filter [BOD] Where ITMREF=[F:SCI]ITMREF
&                  and BOMALT=[F:SCI]BOMALT       and BOMALTTYP=3
&                  and CPNITMREF=[M:SCM0]CPNITMREF and CPNTYP<6
&                  and (BOMENDDAT = [0/0/0] | BOMENDDAT >= [F:SCO]ORDDAT )
&                  and (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= [F:SCO]ORDDAT )
    Read   [BOD] First
    If fstat : Raz [F:BOD] : Endif
    Filter [BOD]
#
    If [M:SCMW]BOMOFS=0 [M:SCMW]BOMOFS = [F:BOD]BOMOFS : Affzo [M:SCMW]BOMOFS : Endif
#
Endif

Call CTRL_SCOFLG( VALEUR )

End

