#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRCLV",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "AS_COD"      : Raz GCURLEG
 When "INICRE"      : Gosub INICRE    : # SBA-114309
 When "RAZCRE"      : Gosub RAZCRE    : # SBA-114309
Endcase
Return
# SBA-114309
$RAZCRE
If func AFNC.ACTIV("LEG")=0
  [M]LEG=GDOSLEG(1)
  Affzo [M]LEG
Endif
GCURLEG=[M]LEG
Gosub DISPLAY_HIDE
Return

########################################
$OUVRE
If clalev ([F:HRCLV])=0 : Local File HRCLLCVT [HRCLV] : Endif
If clalev ([F:HRCLV2])=0 : Local File HRCLLCVT [HRCLV2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#LIPET - 2017-08-22 - START
If dim([M:HRCLV1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
Return

########################################
$LIENS

GCURLEG = [F:HRCLV]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([M:HRCLV1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DESAXX,"HRCLLCVT","DESAXX",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRCLLCVT","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
# To display or to hide fields based on legilation code
Gosub DISPLAY_HIDE
Return

########################################
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRCLLCVT","DESAXX",CLECUR1,"","HRCLLCVT","DESAXX",[F:HRCLV]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRCLLCVT","SHOAXX",CLECUR1,"","HRCLLCVT","SHOAXX",[F:HRCLV]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESAXX,"HRCLLCVT","DESAXX",[F:HRCLV]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HRCLLCVT","SHOAXX",[F:HRCLV]COD,GCURLEG) From ATEXTRA
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# SBA-114309
$INICRE
If dim([F]HERDIF)>0 : Raz [F]HERDIF : Endif
If dim([F]CODN4H)>0 & !func DIVPAYE.IS_KFR() : Raz  [F]CODN4H : Endif

Return
########################################
$VERIF_CRE
$VERIF_MOD
If [M]DEFVAL=2
 Filter [F:HRCLV2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
 Read [F:HRCLV2]HRCLV0 First
 Filter [F:HRCLV2]
 If !fstat
  # A default value already exist for this legislation : XXX
  GMESSAGE = mess(1,10712,1)-":'"-[F:HRCLV2]COD+"'"
  OK = 0 : Return
 Endif
Endif
Return

########################################
$DISPLAY_HIDE
# SBA-114309
Local Char W_SIGN(1)
Case GCURLEG
 When "FRA",""
   W_SIGN=""
 When Default
   W_SIGN="-"
   Raz [M]CODN4H
Endcase
Chgfmt [M]CODN4H With W_SIGN+"K:10X"
Affzo [M]
Return

########################################
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
$AP_CHANGE
Call CHGTEXTRA("HRCLLCVT","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("HRCLLCVT","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("HRCLLCVT","DESAXX",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRCLLCVT","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRCLV) : Endif
VCOD = CLE2
Return

########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File HRCLLCVT [HRCLV1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".HRCLLCVT"  [HRCLV1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File HRCLLCVT [HRCLV2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".HRCLLCVT"  [HRCLV2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [HRCLV1], [HRCLV2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

########################################

$TR_COP
GOK = 1
Gosub CHECK_COPYLEG From DIVPAYE
If !GOK : Return : Endif

Trbegin [HRCLV2]
 Delete [HRCLV2] Where TYP=TABLE & LEG=LEGDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRCLLCVT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRCLV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRCLV1] Where TYP=TABLE & LEG=TABLE2
  [F:HRCLV2] = [F:HRCLV1]
  [F:HRCLV2]LEG =LEGDES
  If TABLE2=LEGDES
    Call COPTEXTRA("HRCLLCVT","DESAXX",TABLE,TABLE2) From ATEXTRA
    Call COPTEXTRA("HRCLLCVT","SHOAXX",TABLE,TABLE2) From ATEXTRA
  Else
    Call COPTEXTRA1("HRCLLCVT","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
    Call COPTEXTRA1("HRCLLCVT","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
  Endif
  If dim([F:HRCLV2]UPDUSR)>0 : [F:HRCLV2]UPDUSR = GUSER : Endif
  If dim([F:HRCLV2]UPDDAT)>0 : [F:HRCLV2]UPDDAT = date$ : Endif
  Write [HRCLV2]
  If fstat
   GOK = 0 : Call FSTA("HRCLV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$TR_COP_OLD
GOK = 1
Trbegin [HRCLV2]
 Delete [HRCLV2] Where TYP=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRCLLCVT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRCLV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRCLV1] Where TYP=TABLE & LEG=TABLE2
  [F:HRCLV2] = [F:HRCLV1]
  Call COPTEXTRA("HRCLLCVT","DESAXX",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("HRCLLCVT","SHOAXX",TABLE,TABLE2) From ATEXTRA
  If dim([F:HRCLV2]UPDUSR)>0 : [F:HRCLV2]UPDUSR = GUSER : Endif
  If dim([F:HRCLV2]UPDDAT)>0 : [F:HRCLV2]UPDDAT = date$ : Endif
  Write [HRCLV2]
  If fstat
   GOK = 0 : Call FSTA("HRCLV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

########################################
$AB_TR_COP
Rollback
Return

########################################
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

########################################
$SEL_TABLE

Case TABLE
 When "SELHRCLV"
  If clalev ([F:HRCLV])=0 : Local File HRCLLCVT   [HRCLV] : Endif
  OBJET="HRCLV"
  START="[F:HRCLV]COD"
#  EXPSTART="[F:HRCLV]COD>='"+VALEUR+"'"
  #Filter based on code legislation
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCLV]LEG="'+PARAM(1)+'" | [F:HRCLV]LEG="")',"&") From GOBJSUB
  Endif
  #Filter based on group of company
  If PARAM(2)<>""
    #OBJET=""
    DEFPAG = 1
    TIT=mess(5,10712,1) :
    Gosub NOMFIC From ="WOHRCLV"
    Call  TRANSCOL("HRCLV",NBCOL,COL,TIT,FMTCOL) From OBJDIV
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
    If GUSRACS = 2
      Link [HRCLV] With
&     [AGC]AGC0=[F:HRCLV]GRP,
&     [AXX]AXX0="HRCLLCVT";"DESAXX";GLANGUE;[F:HRCLV]COD;[F:HRCLV]LEG
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRCLV]GRP="")',"&") From GOBJSUB
    Else
      Link [HRCLV] With
&     [AGC]AGC0=[F:HRCLV]GRP,
&     [AXX]AXX0="HRCLLCVT";"DESAXX";GLANGUE;[F:HRCLV]COD;[F:HRCLV]LEG,
&     [ACC]CODACC=GUSER;[F:HRCLV]CODACS
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRCLV]GRP="") & ([F:HRCLV]CODACS="" or [F:ACC]CONSUL=2) ',"&") From GOBJSUB
    Endif

    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRCLV]ENAFLG=2',"&") From GOBJSUB

    NBCOL += 1 : COL(NBCOL) = "[F:HRCLV]GRP"    : COLTYP(NBCOL) =  type([F:HRCLV]GRP)    : TIT(NBCOL) =mess(237,133,1)
    Default File [LNK]
   Endif
Endcase
Return


# To do a generic Call CONTSEL... from
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRCLV(COD,LEG,SOC)
End

########################################
Subprog CONTHRCLV(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS

If GFONCTION = "GESHRCLV" | COD="" : End : Endif

If clalev([F:HRCLV])=0 : Local File HRCLLCVT [HRCLV] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [HRCLV]HRCLV0=COD;LEG
 If fstat
  Read [HRCLV]HRCLV0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [HRCLV]HRCLV0(1)=COD
 If !fstat
  LEG = [F:HRCLV]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [HRCLV] Where COD=COD
 Look [HRCLV]HRCLV0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [HRCLV]
 mkstat = 2 : End
Endif
If CAS=2
 Call CONTROLE("HRCLV","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("HRCLV","","",COD,mkstat) From CONTOBJ
Endif

If [F:HRCLV]GRP<>"" & SOC<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:HRCLV]GRP;SOC
  If fstat
   GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRCLV]GRP : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
Endif

If GUSRACS<>2
 If [F:HRCLV]CODACS <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:HRCLV]CODACS
  If fstat or [F:ACC]CONSUL <> 2
   GMESSAGE = [F:HRCLV]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

End

########################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub DISPLAY_HIDE
End

########################################
Subprog TUNHRCLV(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRCLV)
 TOKILL = 1
Endif


If clalev([F:HRCLV])=0 : Local File HRCLLCVT [HRCLV] : Endif

# To update the HRCLV code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRCLV record with LEG="" secondly a HRCLV record with LEG<>""
 Read [HRCLV]HRCLV0 = VCOD;LEG
 If fstat
  Read [HRCLV]HRCLV0(1)=VCOD
  If !fstat
   LEG = [F:HRCLV]LEG
  Endif
 Endif
Endif

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRCLV] Where LEG=[L]LEG
  Read [F:HRCLV] First
  Filter [HRCLV]
  If !fstat : VCOD=[F:HRCLV]COD : Endif
Else
  Read [HRCLV]HRCLV0 = VCOD;LEG
Endif

If fstat : LEG = "" : Endif

Call OBJET("HRCLV",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End

########################################
Subprog DEFHRCLV(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG()
Value    Char    SOC()

If GFONCTION = "GESHRCLV" | COD<>"" : End : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRCLV])=0  : Local File HRCLLCVT [HRCLV]  : Endif

If LEG<>""
#JOJAC - 2016-03-10 REQ 114309 US22 - START
 #Filter [F:HRCLV] Where LEG=[L]LEG & DEFVAL=2
 Filter [F:HRCLV] Where LEG=[L]LEG & DEFVAL=2 & ENAFLG=2

#JOJAC - 2016-03-10 REQ 114309 US22 - END
 Read[F:HRCLV]HRCLV0 First
 #Filter [F:HRCLV]
 If !fstat
  COD=[F:HRCLV]COD
  End
 Endif
Endif

End

########################################
Subprog SIMPLEREAD(COD,LEG,ERR)
Value Char COD ()
Value Char LEG ()
Variable Integer ERR         :#return the 'fstat' about the read

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRCLV])=0 : Local File HRCLLCVT [HRCLV] : Endif

[L]ERR=1

If [L]LEG<>""
 Read[F:HRCLV]HRCLV0=[L]COD;[L]LEG
 [L]ERR=fstat
Endif
If [L]ERR
 Read[F:HRCLV]HRCLV0=[L]COD;""
 [L]ERR=fstat
Endif
End

