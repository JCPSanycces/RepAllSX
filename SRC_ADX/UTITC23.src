#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTITC23   Suppression code activite  WRE                     Module TC #
#           Modification code activité WRH                               #
##########################################################################
# TS 08/10/2009 : Lot D04
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Init CREMVTSEQ") From LECFIC

  Call MAJ_UTITC23(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End
##########################################################################
Subprog MAJ_UTITC23(SZAPPLI)
Value Char SZAPPLI

  Call ECR_TRACE("UTITC23: Process Start on : "+SZAPPLI, 0) From GESECRAN
  Local File =SZAPPLI + ".ACTIV" [ACV]
  Read [ACV]CODACT="WRH"
  If !fstat
    [F:ACV]DEP=1 : [F:ACV]ACTFOR="" : [F:ACV]RANG=2
    Rewrite [ACV]
  Endif 
  Read [ACV]CODACT="EMP"
  If !fstat
    [F:ACV]RANG=2
    Rewrite [ACV]
  Endif 
  Read [ACV]CODACT="WRE"
  If !fstat
    Delete [ACV]
  Endif 

  If SZAPPLI=GDOSX3
     Local File =SZAPPLI + ".ADOSACT" [ADA]
     Delete [ADA] Where CODACT="WRE"
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat THEN
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC23(APPLI)        
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    # 
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI=GDOSX3 Then
    End
  Endif
  Call MAJ_UTITC23(APPLI)
End

