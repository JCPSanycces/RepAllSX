#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTINCS201810001
# Issue X3-111831 - 2018-10-08 by BAKHA : delete obsolete record for function GESNCS
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Deletion of obsolete record for function GESNCS") From LECFIC
    # -------------------------
    Call MAJ_UTINCS201810001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTINCS201810001(DOSSIER)
Value Char DOSSIER


  Call ECR_TRACE("MAJ_UTINCS201810001: Process Start on : "+DOSSIER,0) From GESECRAN

  Local File =DOSSIER+".AFCTFCY" [AFF]

  Trbegin [AFF]
   Delete [AFF] Where FNC="GESNCS"
  Commit

  Close Local File [AFF]

  Call ECR_TRACE("MAJ_UTINCS201810001: Process End", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

   Call MAJ_UTINCS201810001(DOSSIER)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

   Call MAJ_UTINCS201810001(DOSSIER)

End

