#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ASYRREQPEND


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


$AQUERY_OPEN_AFTER
If PQRY.QWHERE<>"" : PQRY.QWHERE -= 'and' : Endif
PQRY.QWHERE -= 'NUMREQ gt 0'

Local Char QUERY_ID (10) : QUERY_ID=""
Gosub CHARGE_TAB

Local File    (
& Integer FLAG,
& Integer NUMREQ,
& Char DOSSIER (GLONADS),
& Char TACHE (GLONABT),
& Char USER (GLONALO),
& Char LOGIN (GLONALO),
& Date DAT,
& Char HEURE(10),
& Char HDEB(10),
& Char HFIN (10),
& Char LAN (GLONLAN),
& Char LANISO(10),
& Char SERVER(GLONAMC),
& Integer PORT,
& Integer MONO,
& Integer RECURRENT,
& Integer MAISRV,
& Char GRP(GLONABG),
& Char CODABT(GLONABA),
& Integer EXENOW )
&             From Variable
& TFLAG  ,
& TNUMREQ  ,
& TDOSSIER   ,
& TTACHE   ,
& TUSER   ,
& TLOGIN  ,
& TDAT  ,
& THEURE  ,
& THDEB  ,
& THFIN ,
& TLAN  ,
& TLANISO  ,
& TSERVER ,
& TPORT  ,
& TMONO  ,
& TRECURRENT  ,
& TMAISRV  ,
& TGRP  ,
& TCODABT  ,
& TEXENOW  As [LNK_]

Return

###############################################
$CHARGE_TAB

Local Integer TFLAG  (1..)
Local Integer TNUMREQ  (1..)
Local Char TDOSSIER (GLONADS)  (1..)
Local Char TTACHE (GLONABT)  (1..)
Local Char TUSER (GLONALO)  (1..)
Local Char TLOGIN (GLONALO)  (1..)
Local Date TDAT  (1..)
Local Char THEURE(10)  (1..)
Local Char THDEB(10)  (1..)
Local Char THFIN (10)  (1..)
Local Char TLAN (GLONLAN)  (1..)
Local Char TLANISO(10)  (1..)
Local Char TSERVER(GLONAMC)  (1..)
Local Integer TPORT  (1..)
Local Integer TMONO  (1..)
Local Integer TRECURRENT  (1..)
Local Integer TMAISRV  (1..)
Local Char TGRP(GLONABG)  (1..)
Local Char TCODABT(GLONABA)  (1..)
Local Integer TEXENOW  (1..)
Local Char WLAN(GLONLAN),WLANISO(10),WLOGIN(GLONALO)
Local File ABATTAC [ABT]
Local File ABATRQT [PABR], ABATRQT [ABR]
Local Integer OKLIG,WEXENOW
Local Integer NB : NB=0
Local Integer NBMONO : NBMONO=0
Local Char TABMONO(GLONADS)(1..)
Local Char HH(10), HS(10)
Local Date DD

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR

Local Char NOMDOS(GLONADS)
NOMDOS=fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","SUPDOS")

Filter [PABR] Where find(FLAG,1,2,5)>0  Order By FLAG Desc; DAT Asc; HEURE Asc; NUMREQ Asc
For [PABR]
 OKLIG=1
 If [F:PABR]FLAG=1
  If find([F:PABR]DOSSIER,TABMONO(1..NBMONO))>0
   OKLIG=0
  Endif
 Endif
 If [F:PABR]MONO=2 & find([F:PABR]DOSSIER,TABMONO(1..NBMONO))=0
  NBMONO+=1
  TABMONO(NBMONO)=[F:PABR]DOSSIER
 Endif
 If OKLIG
   NB+=1
   If [F:PABR]FLAG<>1
    WEXENOW=2
   Elsif [F:PABR]DAT<DD or ([F:PABR]DAT=DD & [F:PABR]HEURE<=HH)
    WEXENOW=2
   Else
    WEXENOW=1
   Endif
   Onerrgo ERR_QUERY
      Local File =[F:PABR]DOSSIER+".AUTILIS" [AUS]
      If OKLIG
       WLAN=[F:PABR]LAN
       If [F:PABR]LAN=""
        If [F:PABR]DOSSIER=NOMDOS
         WLAN=GACTX.LAN
        Else
         WLAN=func ADS_TOOL.GET_LANDEF([F:PABR]DOSSIER)
        Endif
       Endif
       WLANISO=func ADS_TOOL.SEARCH_ISOLAN([F:PABR]DOSSIER,WLAN )
       If WLANISO=""
        WLAN=func ADS_TOOL.GET_LANDEF([F:PABR]DOSSIER)
        WLANISO=func ADS_TOOL.SEARCH_ISOLAN([F:PABR]DOSSIER,WLAN )
       Endif
       Read [AUS]CODUSR=[F:PABR]USER
       If fstat
        Gosub QUERY_ON_ERROR_USER
        WLOGIN=""
       Else
        WLOGIN=[F:AUS]LOGIN
       Endif
      Endif
      Close Local File [AUS]
   Onerrgo
 Endif
 If OKLIG & WEXENOW=2
   NB+=1
   TLAN (NB)=WLAN
   TLANISO (NB)=WLANISO
   TLOGIN (NB)=WLOGIN
   TEXENOW (NB)=WEXENOW
   TFLAG (NB)= [F:PABR]FLAG
   TNUMREQ (NB)=[F:PABR]NUMREQ
   TDOSSIER (NB)=[F:PABR]DOSSIER
   TTACHE (NB)=[F:PABR]TACHE
   TUSER (NB)=[F:PABR]USER
   TDAT (NB)=[F:PABR]DAT
   THEURE (NB)=[F:PABR]HEURE
   THDEB (NB)=[F:PABR]HDEB
   THFIN (NB)=[F:PABR]HFIN
   TSERVER (NB)=[F:PABR]SERVER
   TPORT (NB)=[F:PABR]PORT
   TMONO (NB)=[F:PABR]MONO
   TRECURRENT (NB)=([F:PABR]FRQ<>0)+1
   Read [ABT]CODTAC=[F:PABR]TACHE
   If fstat : Raz [F:ABT] : Endif
   TMAISRV (NB) = func ASYRDIV.NEED_PRIMARY_SERVER([F:PABR]TACHE,[F:ABT]FONCTION)

   TGRP (NB)=[F:PABR]GRP
   TCODABT (NB)=[F:PABR]CODABT
 Endif
Next
Filter [PABR]
Return


$ERR_QUERY
OKLIG=0
Local Char MESSAGE(250)
MESSAGE=errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-":"-errmes$(errn)-errm
Gosub TRACE_ERR_QUERY
Resume

$QUERY_ON_ERROR_USER
OKLIG=0
Local Char MESSAGE(250)
MESSAGE=mess(24,100,1)-[F:PABR]USER
Gosub TRACE_ERR_QUERY
Return

$TRACE_ERR_QUERY
Local Integer REQUETE,NUMERO
Local Char    RQTID(50)
Local Char    FICTRQ(GDIMFIC)
Local Char    HH(10), HS(10)
Local Date    DD

REQUETE=[F:PABR]NUMREQ
NUMERO=[F:PABR]NUMGRP
Gosub TR_INTERR From ASYRREQ_CSTD
TFLAG (NB)=NEWFLAG
Read [ABR]NUMREQ=REQUETE
If fstat
 Return
Endif
Gosub IDENT_RQT From SERVEUR

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR

#Call STRACE(FICTRA,10001,[F:ABR]NUMREQ,toupper(WSEVERITY)-':'-WMESSAGE) From SERVEUR
Call RTRACE(FICTRQ,10001,MESSAGE) From SERVEUR
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return


$AQUERY_TRANS_AFTER
this.ABR.FLAG      = [LNK_]FLAG
this.ABR.NUMREQ    = [LNK_]NUMREQ
this.ABR.DOSSIER      = [LNK_]DOSSIER
this.ABR.TACHE   = [LNK_]TACHE
this.ABR.USER    = [LNK_]USER
this.ABR.LOGIN  = [LNK_]LOGIN
this.ABR.DAT     = [LNK_]DAT
this.ABR.HEURE      = [LNK_]HEURE
this.ABR.HDEB    = [LNK_]HDEB
this.ABR.HFIN    = [LNK_]HFIN
this.ABR.LAN       = [LNK_]LAN
this.ABR.LANISO       = [LNK_]LANISO
this.ABR.SERVER       = [LNK_]SERVER
this.ABR.PORT       = [LNK_]PORT
this.ABR.MONO   = [LNK_]MONO
this.ABR.RECURRENT     = [LNK_]RECURRENT
this.ABR.MAISRV        = [LNK_]MAISRV
this.ABR.GRP    = [LNK_]GRP
this.ABR.CODABT      = [LNK_]CODABT
this.ABR.EXENOW   = [LNK_]EXENOW
Return


$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "FLAG"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.FLAG"
             TBFIL(NBPRO) = "[LNK_]FLAG"
NBPRO += 1 : TBPRO(NBPRO) = "NUMREQ"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.NUMREQ"
             TBFIL(NBPRO) = "[LNK_]NUMREQ"
NBPRO += 1 : TBPRO(NBPRO) = "DOSSIER"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.DOSSIER"
             TBFIL(NBPRO) = "[LNK_]DOSSIER"
NBPRO += 1 : TBPRO(NBPRO) = "TACHE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.TACHE"
             TBFIL(NBPRO) = "[LNK_]TACHE"
NBPRO += 1 : TBPRO(NBPRO) = "USER"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.USER"
             TBFIL(NBPRO) = "[LNK_]USER"
NBPRO += 1 : TBPRO(NBPRO) = "LOGIN"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.LOGIN"
             TBFIL(NBPRO) = "[LNK_]LOGIN"
NBPRO += 1 : TBPRO(NBPRO) = "DAT"
           : TBTYP(NBPRO) = 11 : TBPTH(NBPRO) = "ABR.DAT"
             TBFIL(NBPRO) = "[LNK_]DAT"
NBPRO += 1 : TBPRO(NBPRO) = "HEURE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.HEURE"
             TBFIL(NBPRO) = "[LNK_]HEURE"
NBPRO += 1 : TBPRO(NBPRO) = "HDEB"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.HDEB"
             TBFIL(NBPRO) = "[LNK_]HDEB"
NBPRO += 1 : TBPRO(NBPRO) = "HFIN"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.HFIN"
             TBFIL(NBPRO) = "[LNK_]HFIN"

NBPRO += 1 : TBPRO(NBPRO) = "LAN"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.LAN"
             TBFIL(NBPRO) = "[LNK_]LAN"
NBPRO += 1 : TBPRO(NBPRO) = "LANISO"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.LANISO"
             TBFIL(NBPRO) = "[LNK_]LANISO"
NBPRO += 1 : TBPRO(NBPRO) = "SERVER"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.SERVER"
             TBFIL(NBPRO) = "[LNK_]SERVER"
NBPRO += 1 : TBPRO(NBPRO) = "PORT"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.PORT"
             TBFIL(NBPRO) = "[LNK_]PORT"
NBPRO += 1 : TBPRO(NBPRO) = "MONO"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.MONO"
             TBFIL(NBPRO) = "[LNK_]MONO"
NBPRO += 1 : TBPRO(NBPRO) = "RECURRENT"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.RECURRENT"
             TBFIL(NBPRO) = "[LNK_]RECURRENT"
NBPRO += 1 : TBPRO(NBPRO) = "MAISRV"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.MAISRV"
             TBFIL(NBPRO) = "[LNK_]MAISRV"

NBPRO += 1 : TBPRO(NBPRO) = "GRP"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.GRP"
             TBFIL(NBPRO) = "[LNK_]GRP"
NBPRO += 1 : TBPRO(NBPRO) = "CODABT"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ABR.CODABT"
             TBFIL(NBPRO) = "[LNK_]CODABT"
NBPRO += 1 : TBPRO(NBPRO) = "EXENOW"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "ABR.EXENOW"
             TBFIL(NBPRO) = "[LNK_]EXENOW"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]NUMREQ "
Return

