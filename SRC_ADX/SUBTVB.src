#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################
# SUBTVB                                                               #
#    REGIME DE TAXE TIERS                                              #
########################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "AFFMASK"     : Gosub AFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 #When "CHANGE"      : Call CHANGE_AXX ("TABVACBPR", [L]SUPP(0), [L]OCODE, [L]SUPP(0), [L]NCODE ) From TRTX3TEX
 When "LIENS"       : Gosub LIENS
 When "FERME"       : Gosub FERME
 When "SEL_LISTE"
   Case LISTE
     When "SELTVB"  : Gosub SELTVBL
   Endcase
 When "SEL_TABLE"
   Case TABLE
     When "SELTVB"  : Gosub SELTVB
   Endcase
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "CHGCOD"      : Gosub CHGCOD
 When Default
Endcase
Return

######################################################################################
$OUVRE
If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
If !clalev([F:AWI]) : Local File AWINDOW  [AWI] : Endif
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif

Local Integer LEGOK
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes

Return
######################################################################
$SETBOUT
#------------------------------#
# Désactivation bouton "Copie" #
#------------------------------#
If GREP<>"" | !CLECUR
  Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
#------------------------------#
#  Données légales/Législation #
#** Legal datas/Legislation    #
#------------------------------#
LEGOK=0
If [M:TVB1]LEG<>""
 fstat = 0
 If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>[M:TVB1]LEG
  Read [ADI]CODE = 959;[M:TVB1]LEG
 Endif
 If !fstat & [F:ADI]A5<>""
  If [F:AWI]WIN<>[F:ADI]A5
   Read [AWI]AWI0 = [F:ADI]A5
  Endif
  If !fstat
   LEGOK=1
  Endif
 Endif
Else
 ##  Si le code legislation est vide alors on lit la table diverse sur une
 #   législation (du dossier X3) pour laquelle une fenêtre est définie pour
 #   TVB dans la table diverse 959.
 ##
 #** If the legislation code is empty then we will use another legislation
 #*  (of the current X3 Folder) which present a window in the miscelleanous
 #*  table 959 for TVB.
 #*!
 fstat = 0
 If [F:ADS]DOSSIER<>nomap
  Read [ADS]DOSSIER = nomap
 Endif
 If !fstat
  Filter [ADI] Where NUMTAB=959 & find([F:ADI]CODE,[F:ADS]DOSLEG(0..dim([F:ADS]DOSLEG)-1)) & [F:ADI]A5<>""
  For [ADI]
   If [F:AWI]WIN<>[F:ADI]A5
    Read [AWI]AWI0 = [F:ADI]A5
   Endif
   If !fstat
    LEGOK=1 : Break
   Endif
  Next
  Filter [ADI]
 Endif
Endif
If REP="C" | REP="D" | !LEGOK
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return
######################################################################
$INICRE
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABVACBPR","DESAXX",CLECUR1,"","TABVACBPR","DESAXX",[F:TVB]VACBPR,[F:TVB]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABVACBPR","SHOAXX",CLECUR1,"","TABVACBPR","DESAXX",[F:TVB]VACBPR,[F:TVB]LEG)  From ATEXTRA
Endif
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TVB1]DESAXX,"TABVACBPR","DESAXX",[M:TVB1]VACBPR,[M:TVB1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TVB1]SHOAXX,"TABVACBPR","SHOAXX",[M:TVB1]VACBPR,[M:TVB1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TVB]LANDESSHO)>0
   [F:TVB]LANDESSHO=GLANGUE+"~"+[M:TVB1]DESAXX+"~"+[M:TVB1]SHOAXX
Endif


#--CPO 71937 Contrôle global de cohérence avant enregistrement
Gosub CONTROLE_COHERENCE

Return
######################################################################
$AP_CHANGE
Call CHGTEXTRA("TABVACBPR","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABVACBPR","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return
######################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG

Return
######################################################################
$RAZCRE
Gosub GRILEG

Return
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:TVB1]LEG
  [M:TVB1]LEG=GDOSLEG(1)
  Affzo [M:TVB1]LEG
Endif
Return
######################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTVB) : Endif
VCOD = CLE2

Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABVACBPR" & IDENT1=[F:TVB]VACBPR & IDENT2=[F:TVB]LEG
Return

######################################################################
$LIENS

GCURLEG = [F:TVB]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TVB]LEG

Return

##################################################
## Actions of the data type TVB
