#If [L]LEG<>""
# ##############################################################################################################
# ## Cas avec [L]LEG<>"" :  Appel à la vue LEGTVBSEL selectionnant les Régimes de taxe avec LEG en parametre
# ##                             et la vue LEGTVBGRP  (TVBG) pour le groupe
# ##############################################################################################################
#
# ERR = 0
# Repeat
#  # -----------------------------------------------------------------------------------------------
#  # ERR=0  : Pas d'erreur, on sort
#  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
#  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
#  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
#  # -----------------------------------------------------------------------------------------------
#  Onerrgo ERRVUE
#  SZVIEW = "LEGTVBSEL"
#  Local File =SZVIEW [TVBS]
#  Onerrgo
# Until ERR <> -1
#
# If ERR : OBJET = "TVB" : Return : Endif    :   #-- Si problème, on se déroute sur le select standard
#
# #------------------------------------------------------------------------------------------------------------------------------#
# #-- Link de TVB avec                                                                                                           #
# #         [FGR]  : Enregistrement groupe                                                                                       #
# #         [TVBG] : Enregistrement de la vue des régimes de taxe avec groupe                                                    #
# #         [TVBS] : Enregistrement de la vue des régimes de taxe avec LEG     --> TVB non selectionnée si TVBS non ramené       #
# #------------------------------------------------------------------------------------------------------------------------------#
#
# #-- Vue de Reg Taxe avec un groupe
# Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
#&                [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
#&                [F:TVBS]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG;[L]LEG,
#&                [F:TVBG]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY
#&   As [LTVB]
#
#Else
#
# ##############################################################################################################
# ## Cas avec [L]LEG="" :  Appel à la vue LEGTVBPAR selectionnant les Régimes de taxe sans LEG
# ##                            et la vue LEGTVBGRP  (TVBG) pour le groupe si  GROUPE ou CPY ou FCY <>''
# ##############################################################################################################
# ERR = 0
# Onerrgo ERRVUE
#
# Repeat
#   # -----------------------------------------------------------------------------------------------
#   # ERR=0  : Pas d'erreur, on sort
#   # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
#   # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
#   # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
#   # -----------------------------------------------------------------------------------------------
#   Onerrgo ERRVUE
#   SZVIEW = "LEGTVBPAR"
#   Local File =SZVIEW [TVBP]
#   Onerrgo
# Until ERR <> -1
#
#
# If ERR : OBJET = "TVB" : Return : Endif :  #-- Si problème, on se déroute sur le select standard
#
#
# If FCY="" & CPY="" & GRP=""
#   Link [TVB] With  [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
#&                [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
#&                [F:TVBP]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG
#&   As [LTVB]
# Else
#   #------ Règle R2.3 : Une fois la sélection sur la LEG effectuée, si nous sommes sur un élément n’ayant pas de  groupe
#   #------                   (ou contexte déterminant un groupe) -> on retient l’enregistrement quel que soit le groupe
#   #------                   (que l’enregistrement ait un groupe ou  Tous Groupes).
#   Link [TVB] With  [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
#&                [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
#&                [F:TVBG]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY,
#&                [F:TVBP]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG
#&   As [LTVB]
#
# Endif
#
#Endif
#
#Default File [LTVB] : DEFPAG = 1
#
#Return


####################################################################################################
## $SELTVB : X3SUIVI 71937 : Données par législation pour le régime de taxe                       ##
##       --> Si [L]LEG<>""                           --> Utilisation de la vue LEGTVBSEL  (TVBS)  ##
##       --> Si [L]LEG=""                            --> Utilisation de la vue LEGTVBPAR  (TVBP)  ##
##       --> Si [L]LEG=<>"" OU (LEG="" & GROUPE<>'') --> Utilisation de la vue LEGTVBGRP  (TVBG)  ##
##   FACGROUP --> Table de lien Groupe et site                                                    ##
##   AGRPCPY  --> Table de lien Groupe et société                                                 ##
####################################################################################################
$SELTVB

If clalev([F:TVB])=0  : Local File TABVACBPR  [TVB] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY), CPY(GLONCPY), LEG(GLONADI),   GRP(GLONAGC)
Local Integer WNOL, ERR
Local Integer ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

#--CPO 71937 Pour déterminer les options de sélection
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(6)
CHAMPCOD=PARAM(7)

#--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
#--On charge les options définies sur le type de données du champ du masque
#OPTIONS=""
#If CODMSK<>"" & CHAMPCOD<>""
#  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
#  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
#Endif
#--/CPO
#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTVB"  Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TVB"
  Return
Endif

AUTRE_CRIT = '1=1'

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL"     :#--"Parameter values". Data type = ???
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif
Else
  LEG  = PARAM(1)
  FCY  = PARAM(2)
  GRP  = PARAM(3)
  CPY  = PARAM(4)
  If dim(PARAM(5))>0 & PARAM(5)<>"" : AUTRE_CRIT -= '& '+PARAM(5) Endif
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS=""
  If CODMSK<>"" & CHAMPCOD<>""
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
  Endif
  #--/CPO

Endif

#-- Initialisation de législation
If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG="" :  [L]LEG = GCURLEG : Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTVB
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("TVB","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TVB]VACBPR"
ORDRE   = "[F:TVB]VACBPR;[F:TVB]LEG"
OBJET   = ""
#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1 & [F:TVB]ENAFLG=2'

#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
  #--Cas du groupe étant une société
  Read [F:AGF]AGF0=[L]GRP
  If !fstat
    If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
  Endif
  #--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Site
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TVB]SOC="" | ([F:TVB]SOC<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Société
Elsif [L]CPY<>""
  CRITERE(1) -= '& ([F:TVB]SOC="" | ([F:TVB]SOC<>"" & [F:TVBC]LEGCPY="'+[L]CPY+'"))'
Endif

##--Groupe soc/sites
#If FCY="" & CPY="" & GRP<>""
#  CRITERE(1) -= '& ([F:TVB]SOC="'+GRP+'" or [F:TVB]SOC="")'
#Endif

#--Législation
If LEG<>""
  CRITERE(2) -= '& ([F:TVB]LEG="'+[L]LEG+'" | [F:TVB]LEG="")'
Endif

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TVB]VACBPR,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3

##MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TVB",FILROLE) From SUBARL
##END MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

##--------------------------------------------------------------------------------------------------
### Appel à la vue LEGTVBGRP selectionnant les Régimes de taxe avec groupe soc/site
##--------------------------------------------------------------------------------------------------
#ERR = 0
#Repeat
#  # -----------------------------------------------------------------------------------------------
#  # ERR=0  : Pas d'erreur, on sort
#  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
#  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
#  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
#  # -----------------------------------------------------------------------------------------------
#  Onerrgo ERRVUE
#  SZVIEW = "LEGTVBGRP"
#  Local File =SZVIEW [TVBG]
#  Onerrgo
#Until ERR <> -1
#If ERR Then
#  # Si problème, on se déroute sur le select standard
#  OBJET = "TVB"
#  Return
#Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVBYGRP"
      Local File =SZVIEW [TVBY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVB"
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVBZGRP"
      Local File =SZVIEW [TVBZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVB"
      Return
    Endif
  Endif
Endif

ERR = 0
Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGTVBCPY"
  Local File =SZVIEW [TVBC]
  Onerrgo
Until ERR <> -1
If ERR Then
  # Si problème, on se déroute sur le select standard
  OBJET = "TVB"
  Return
Endif

If [L]LEG<>""
 #--View throughout GCURLEG
 #--------------------------------------------------------------------------------------------------
 ## Appel à la vue
 #--------------------------------------------------------------------------------------------------
 ERR = 0
 Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGTVBSEL"
  Local File =SZVIEW [TVBS]
  Onerrgo
 Until ERR <> -1

 If ERR : OBJET = "TVB" : Return : Endif    :   #-- Si problème, on se déroute sur le select standard

 If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
    Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                   [F:TVBY]TVBY0 ~= [L]GRP;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG,
&                   [F:TVBS]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG;[L]LEG
&                As [LTVB]
 Else
    Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                   [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
&                   [F:TVBC]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY,
&                   [F:TVBS]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG;[L]LEG
&                As [LTVB]
 Endif

Else
 #--View without legislation
  ERR = 0
  Repeat
   # -----------------------------------------------------------------------------------------------
   # ERR=0  : Pas d'erreur, on sort
   # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
   # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
   # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
   # -----------------------------------------------------------------------------------------------
   Onerrgo ERRVUE
   SZVIEW = "LEGTVBPAR"
   Local File =SZVIEW [TVBP]
   Onerrgo
  Until ERR <> -1

 If ERR : OBJET = "TVB" : Return : Endif :  #-- Si problème, on se déroute sur le select standard

  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
    Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                   [F:TVBZ]TVBZ0 ~= [L]GRP;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG
&                As [LTVB]
  Else
    Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                   [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
&                   [F:TVBC]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY,
&                   [F:TVBP]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG
&                As [LTVB]
  Endif
Endif

#--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTVB
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTVB] : DEFPAG = 1

Return

################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

