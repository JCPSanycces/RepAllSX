######################################################################################
#--CPO 71937 14.02.2013 Uniformisation du code (semblable aux autres objets déclinés)
# Control
Subprog CONTTVB(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTVB" | COD="" : End : Endif

If clalev([F:TVB]) =0 : Local File TABVACBPR  [TVB]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON    [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif

If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 [L]LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		If [F:FCY]FCY<>[L]FCY
			Read [F:FCY]FCY0=[L]FCY
			If fstat : Raz [F:FCY] Endif
		Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		If [F:CPY]CPY<>[L]CPY
			Read [F:CPY]CPY0=[L]CPY
			If fstat : Raz [F:CPY] Endif
		Endif
		[L]LEG=[F:CPY]LEG
	Endif
Endif
#--/

If LEG<>""
 Read [TVB]TVB0=COD;LEG
 If fstat
  Read [TVB]TVB0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TVB]TVB0(1)=COD
 If !fstat
  LEG = [F:TVB]LEG
  CAS = 2
 Endif
Endif
If fstat
 #Filter [TVB] Where COD=[L]COD
 Filter [TVB] Where VACBPR=[L]COD :#--CPO 97629
 Look [TVB]TVB0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TVB]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVACBPR, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TVB]SOC<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TVB]SOC
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVB]SOC<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TVB]SOC : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TVB]SOC;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TVB]SOC : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVB]SOC<>"" and LEG<>""
	Call CTLGFYLEG([F:TVB]SOC,LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'entrée retenue
If GROUPE <> "" and [F:TVB]LEG <> "" Then
  Call CTLGFYLEG(GROUPE, [F:TVB]LEG, "", "") From TRTVENCTL
  If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de l'escompte courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe de la taxes et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
	If CPY="" & FCY="" & [F:TVB]SOC<>"" & [F:TVB]SOC<>GROUPE
  	#--Les groupes doivent avoir au moins une société en commun
  	Gosub CTLSOCGRP
		If mkstat : End : Endif
	Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TVB",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TVB",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

#--CPO 71937 Contrôle global de cohérence avant enregistrement
#--Cohérence [TVB]VAT et paramètres
If mkstat > 0 : End : Endif

If GSOCIETE = "" Then
    # Issue SAM119092 - 2016-11-22 by FGR : if GSOCIETE="" we are in a setup function. This test mustn't be done
  End
Endif

If [F:TVB]VAT<>""
  If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif

  Call CONTTVT([TVB]VAT,[L]LEG,"","",[L]FCY,GROUPE,[L]CPY) From SUBTVT
  If mkstat
  	If [L]LEG=""
  		GMESSAGE = [L]COD-":"-mess(39,105,1)-GMESSAGE
  	Else
  		GMESSAGE = [L]COD-"["+[L]LEG+"]"-":"-mess(39,105,1)-GMESSAGE
  	Endif
  	End
  Endif
Endif

End

#--/CPO
#-------------------------------
$CTLSOCGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVB]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVBZGRP"
    Local File =SZVIEW [TVBZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVBZ]TVBZ0 = [L]GROUPE;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG
  If fstat
    GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVB]SOC-":"-mess(178,187,1)
    mkstat=1
    Return
  Endif
Else
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVBYGRP"
    Local File =SZVIEW [TVBY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVBY]TVBY0 = [L]GROUPE;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG
  If fstat
    GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVB]SOC-":"-mess(178,187,1)
    mkstat=1
    Return
  Endif
Endif
Return

######################################################################################
## Tunnel Régime de taxe
Subprog TUNTVB(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONVAT)
  TOKILL = 1
Endif

If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif

VCOD = COD

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TVT record with LEG="" secondly a TVT record with TVT<>""
Elsif LEG=""
  Read [TVB]TVB0 = VCOD;LEG
  If fstat
    Read [TVB]TVB0(1)=VCOD
    If !fstat
      LEG = [F:TVB]LEG
    Endif
  Endif
Endif

Read [TVB]TVB0 = COD;LEG
If fstat : LEG = "" : Endif

Call OBJET("TVB",LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End

######################################################################################
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

If PVALEUR="" End Endif

If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

[L]SAVE_GCURFCY = GCURFCY
[L]SAVE_GSOCIETE= GSOCIETE

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
  FCY  = [M:ADWP]FCY : GCURFCY = FCY
  CPY  = [M:ADWP]CMP : GSOCIETE= CPY
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif

  #--Initialisation de législation
  If [L]LEG=""
    If [L]FCY<>""
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      GSOCIETE = [F:FCY]LEGCPY
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY<>""
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG=""
    [L]LEG = GCURLEG
  Endif
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #Call CONTTVB(PVALEUR,LEG,"","",FCY,"",CPY)
  Call CONTTVB(PVALEUR,LEG,"MULTILEGADP",PPARAM,FCY,"",CPY)
  If mkstat : POK=0 : Endif
Endif

GCURFCY = [L]SAVE_GCURFCY
GSOCIETE= [L]SAVE_GSOCIETE

End



#################################################################################
$ANCSELTVB

If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGC)
Local Integer WNOL
Local Integer ERR

LEG  = PARAM(1)
FCY  = PARAM(2)
GRP  = PARAM(3)
CPY  = PARAM(4)

# Initialisation de législation
If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTVB
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("TVB","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TVB]VACBPR"
ORDRE   = "[F:TVB]VACBPR;[F:TVB]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

# Les 2 façons fonctionnent voir la mieux
CRITERE(1) = '1=1 & [F:TVB]ENAFLG=2'
#CRITERE(1) = '1=1'

#--Site
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TVB]SOC="" | ([F:TVB]SOC<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Société
Elsif [L]CPY<>""
  CRITERE(1) -= '& ([F:TVB]SOC="" | ([F:TVB]SOC<>"" & [F:TVBC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Groupe de soc/sites
If FCY="" & CPY=""
  CRITERE(1) -= '& ([F:TVB]SOC="'+GRP+'")'
Endif
#--Législation
If LEG<>""
  CRITERE(2) -= '& ([F:TVB]LEG="'+[L]LEG+'" | [F:TVB]LEG="")'
Endif

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TVB]VACBPR,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
## Appel à la vue
#--------------------------------------------------------------------------------------------------

Onerrgo ERRVUE
If clalev([F:TVBC]) : Close Local File [TVBC] : Endif
#--Pas besoin de revalider car on ne transmet pas de paramètres à la requête de la vue
#Call MAJVUE("LEGTVBCPY",nomap) From DOSVUE
Local File LEGTVBCPY [TVBC]
Onerrgo
If ERR
  # Si problème, on se déroute sur le select standard
  OBJET = "TVB" : Return
Endif

#--------------------------------------------------------------------------------------------------
## Appel à la vue
#--------------------------------------------------------------------------------------------------
If [L]LEG<>""

 # Vue via GCURLEG

 ERR = 0
 Onerrgo ERRVUE
 If clalev([F:TVBS]) : Close Local File [TVBS] : Endif
 #--CPO penser à sauvegarder GCURLEG !!!!!
 Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
 GCURLEG = [L]LEG
 Call MAJVUE("LEGTVBSEL",nomap) From DOSVUE
 GCURLEG=SAVE_LEG
 Local File LEGTVBSEL [TVBS]
 Onerrgo
 If ERR
  # Si problème, on se déroute sur le select standard
  OBJET = "TVB" : Return
 Endif

 Link [TVB] With [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
&                [F:TVBC]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY,
&                [F:TVBS]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG
&   As [LTVB]

Else

 # Vue LEG vide
 ERR = 0
 Onerrgo ERRVUE
 If clalev([F:TVBP]) : Close Local File [TVBP] : Endif
 #--Pas besoin de revalider car on ne transmet pas de paramètres à la requête de la vue
 #Call MAJVUE("LEGTVBPAR",nomap) From DOSVUE
 Local File LEGTVBPAR [TVBP]
 Onerrgo
 If ERR
  # Si problème, on se déroute sur le select standard
  OBJET = "TVB" : Return
 Endif

Link [TVB] With  [F:AXX]AXX0    = "TABVACBPR";"DESAXX";GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TVB]SOC,
&                [F:TVBC]TVB0   = [F:TVB]VACBPR;[F:TVB]LEG;[F:TVB]SOC;[L]CPY,
&                [F:TVBP]TVB0  ~= [F:TVB]VACBPR;[F:TVB]LEG
&   As [LTVB]

Endif

Default File [LTVB]
DEFPAG = 1

Return

#$ERRVUE
#ERR = errn
#Resume
#Return

#####################################################################################################
### $SELTVB : X3SUIVI 71937 : Données par législation pour le régime de taxe                       ##
