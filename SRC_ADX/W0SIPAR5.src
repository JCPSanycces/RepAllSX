#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR5 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone STRPER
mkstat = 0
zoncou = "STRPER"
indice = 0
If varinit([M]STRPER,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call D_STRPER([M]STRPER) From SUBSIP
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]STRPER,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "STRPER" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "STD"
  Call C_STRPER([M]STRPER) From SUBSIP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STRPER" : GZNUM = 9567 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ACM
mkstat = 0
zoncou = "ACM"
indice = 0
SAVACT = GACTION : GACTION = "STD"
Call AV_ACM([M]ACM) From SUBSIP
GACTION = SAVACT
If mkstat=1 : Raz [M]ACM : Endif
If !mkstat
 If varinit([M]ACM,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call D_ACM([M]ACM) From SUBSIP
  GACTION = SAVACT
 Endif
Endif
If !mkstat
 If varmode([M]ACM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACM" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("GCM","!",[M]ACM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACM" : GZNUM = 27516 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_ACM([M]ACM) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ACM" : GZNUM = 27516 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBJOU
mkstat = 0
zoncou = "NBJOU"
indice = 0
status = 1
zoncou = "NBJOU"
If varinit([M]NBJOU,indice)=0
 [M]NBJOU = 8
Endif
If varmode([M]NBJOU,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBJOU From SUBSIP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBJOU : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBJOU" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBJOU
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBJOU = nolign
   status = 75
   Call SAI_NBJOU(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone OPTACC
mkstat = 0
zoncou = "OPTACC"
indice = 0
IMPENT = [M]OPTACC
If varinit([M]OPTACC,indice)=0
 IMPENT = 2
Endif
If varmode([M]OPTACC,indice)=0
 [M]OPTACC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTACC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPTACC(indice)
 Endif
Endif
[M]OPTACC = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone DACDIAGEN
mkstat = 0
zoncou = "DACDIAGEN"
indice = 0
If varmode([M]DACDIAGEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DACDIAGEN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DACDIAGEN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("GDE","",[M]DACDIAGEN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DACDIAGEN([M]DACDIAGEN) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DACDIAGEN" : GZNUM = 4974 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ACCTMP
mkstat = 0
zoncou = "ACCTMP"
indice = 0
SAVACT = GACTION : GACTION = "INIACCFMT"
Call INIACCFMT(num$([M:SIP5]COA)) From SETGLBCOA
GACTION = SAVACT
If mkstat=1 : Raz [M]ACCTMP : Endif
If !mkstat
 If varinit([M]ACCTMP,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call D_ACCTMP([M]ACCTMP) From SUBSIP
  GACTION = SAVACT
 Endif
Endif
If !mkstat
 If varmode([M]ACCTMP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCTMP" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("GAC","!G",[M]ACCTMP,num$([M:SIP5]COA),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCTMP" : GZNUM = 32440 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone OPTANA
mkstat = 0
zoncou = "OPTANA"
indice = 0
IMPENT = [M]OPTANA
If varinit([M]OPTANA,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPTANA,indice)=0
 [M]OPTANA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTANA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPTANA(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_OPTANA(IMPENT) From SUBSIP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "OPTANA" : GZNUM = 32373 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]OPTANA = IMPENT

## Zone CCEDEF
mkstat = 0
zoncou = "CCEDEF"
indice = 0
If varmode([M]CCEDEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCEDEF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCDE"
 Call CONTCDE([M]CCEDEF,[M:SIP0]CPY) From SUBCDE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCEDEF" : GZNUM = 4054 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CDE","!",[M]CCEDEF,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCEDEF" : GZNUM = 4054 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DACDIAANA
mkstat = 0
zoncou = "DACDIAANA"
indice = 0
If varmode([M]DACDIAANA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DACDIAANA" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]DACDIAANA,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DACDIAANA" : GZNUM = 25504 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("GDE","",[M]DACDIAANA,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DACDIAANA" : GZNUM = 25504 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DACDIAANA([M]DACDIAANA) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DACDIAANA" : GZNUM = 25504 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone GTEFACACH
mkstat = 0
zoncou = "GTEFACACH"
indice = 0
If varmode([M]GTEFACACH,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GTEFACACH" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]GTEFACACH,"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTEFACACH" : GZNUM = 13046 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GTEFACACH
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GTEFACACH = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GTEFACACH" : GZNUM = 13046 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GTEAVCACH
mkstat = 0
zoncou = "GTEAVCACH"
indice = 0
If varmode([M]GTEAVCACH,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GTEAVCACH" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]GTEAVCACH,"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTEAVCACH" : GZNUM = 41377 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GTEAVCACH
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GTEAVCACH = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GTEAVCACH" : GZNUM = 41377 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GTEFACVEN
mkstat = 0
zoncou = "GTEFACVEN"
indice = 0
If varmode([M]GTEFACVEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GTEFACVEN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]GTEFACVEN,"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTEFACVEN" : GZNUM = 13071 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GTEFACVEN
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GTEFACVEN = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GTEFACVEN" : GZNUM = 13071 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GTEAVCVEN
mkstat = 0
zoncou = "GTEAVCVEN"
indice = 0
If varmode([M]GTEAVCVEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GTEAVCVEN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]GTEAVCVEN,"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTEAVCVEN" : GZNUM = 41378 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GTEAVCVEN
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GTEAVCVEN = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GTEAVCVEN" : GZNUM = 41378 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBJOU(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBJOU
mkstat = 0
zoncou = "NBJOU"

## Zone GTE
mkstat = 0
zoncou = "GTE"
If varmode([M]GTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GTE" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTGTE"
 Call CONTGTE([M]GTE(indice),"","") From SUBGTE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]GTE(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]GTE(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_GTE([M]GTE(indice)) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GTE" : GZNUM = 436 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBJOU
mkstat = 0
zoncou = "NBJOU"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR5"
Return

