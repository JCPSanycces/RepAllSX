#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPSNP0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
WCHAR = [M]OPPNUM
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPPNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","A",[M]OPPNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]OPPNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPPNUM([M]OPPNUM) From SUBPJMOPSNP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SNPCOD
mkstat = 0
zoncou = "SNPCOD"
indice = 0
If varmode([M]SNPCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SNPCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"PJMOPSNPH","DESAXX",[M:PJSNP0]SNPCOD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMOPSNP0"
Return

