#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTISTO06   Moulinette pour réinitialiser                  Module STOCK #
#            l'en commande client [F:ITV]SALSTO                          #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTISTO06(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO06(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTISTO06: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ITV])  =0  Local File =DOSSIER+".ITMMVT"   [ITV] : Endif
If clalev([F:ORD])  =0  Local File =DOSSIER+".ORDERS"   [ORD] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ITV]
For [ITV]
   Readlock [ITV] Curr    
   If !fstat
      Raz [F:ITV]SALSTO
      For [ORD]ORD1 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF &
&                      WIPSTA=1 & find(WIPTYP,1,8)
         [F:ITV]SALSTO += [F:ORD]RMNEXTQTY
      Next
      Rewrite [F:ITV]
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [ORD]
Close Local File [ITV]

Call ECR_TRACE("UTISTO06 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO06(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTISTO06(APPLI)
End
