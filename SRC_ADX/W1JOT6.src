#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque JOT6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:16"
A_USER  = "DOC"
A_STAMP = "20181109230516"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRLIG"
  If [M]NBRLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask JOT6 [JOT6]
Gosub HORODAT
Local Inpbox "JOT6" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT6] As [SIM_]
Grizo [JOT6]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [JOT6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=24
Return

$ON_NBRLIG
Onevent BEFORE_INPUT Call AS_NBRLIG From W1JOT6
Return

Subprog AS_NBRLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44921,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRLIG From W1JOT6
Gosub _AFF
End

Subprog B1_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M]REFNUM(nolign-1)
 Call OBJET_CHAR(OBJCLE,"ECP","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_REFNUM
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1JOT6
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CIVCTRA
Return

$CHG_STY
Return


