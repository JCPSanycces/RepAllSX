######################################################################################
## Etiquette ajoutée par le superviseur (écran CSI0) 27/06/2012 10:52:20 (SEGAY)
######################################################################################
#**
#* Control code parcours type
#* SEGAY 26/06/12 81085 US500
#* @param  VALEUR  : code parcours type
#*!
Subprog C_TCS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer WOK
Call CRTCPY_TCSCTR(VALEUR,[M:CSI1]REFNUM,[M:CSI1]CTR,[M:CSI1]CTRDAT,WOK,1)

End

#**
#* Control CPY of TCS and CPY of CTR
#* SEGAY 26/06/12 81085 US500
#* @param  PTCSCOD  : code parcours type
#* @param  PREFNUM  : code refnum
#* @param  PCTR     : code CTR
#* @param  PCTRDAT  : date CTR
#* @param  OK       : return (0/1)
#* @param  DISPMSG  : 1 Display error message
#*!
Subprog CRTCPY_TCSCTR(PTCSCOD,PREFNUM,PCTR,PCTRDAT,OK,DISPMSG)
Value    Char    PTCSCOD()
Value    Char    PREFNUM()
Value    Char    PCTR()
Value    Date    PCTRDAT()
Variable Integer OK
Value    Integer DISPMSG
Local    Integer I
Local    Char    LIS_CPY(GLONCPY)(0..100)

OK=1
Call LECTURE("TCS",PTCSCOD,"") From CONTOBJ
If PCTR <> "" & [F:TCS]CPY <> ""
  Read [HRCTR]CTR0=PREFNUM;PCTR;PCTRDAT
  If !fstat
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ

    I=0 : Call CALC_GRPCPY([F:TCS]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then : # C'est un groupe de sociétés
      If !find([F:CPY]CPY,LIS_CPY) Then
        OK=0
        mkstat=2
      Endif
    Elsif [F:TCS]CPY <> [F:CPY]CPY
      OK=0
      mkstat=2
    Endif
  Endif
Endif
If(!OK & DISPMSG)
  # La société du parcours type est différente de celle du contrat
  GMESSAGE = mess(286,10717,1)
Endif
End
######################################################################################


#**
#* Après modif du code parcours type
#* SEGAY
#* @param  VALEUR  : code parcours type
#*!
Subprog AM_TCS(VALEUR)
Variable Char    VALEUR()
Local Char    WSHOAXX
Local Integer L_OK
If VALEUR="" : End : Endif
Call LECTURE("TCS",VALEUR,"") From CONTOBJ
[M:CSI0]TCS=VALEUR
Call LECTEXTRA(WSHOAXX,"TYPCOURSE","DESAXX",[M:CSI0]TCS,"") From ATEXTRA

If WSHOAXX<>""
 [M:CSI0]DESAXX=mess(138,10717,1)-WSHOAXX :#Parcours
Else
 [M:CSI0]DESAXX=mess(138,10717,1)-[F:TCS]COD :#Parcours
Endif
If GREP<>"C" and [M:CSI0]COD <> ""
  Call OUINON(mess(155,10717,1),L_OK) From GESECRAN
  #### Voulez-vous initialiser le parcours par les données du parcours type ?
Else
  L_OK=2
Endif
If L_OK=2
    Call GET_TYPCOURSE(VALEUR)
    Call GET_TCS(VALEUR)
Endif

#19/06/12 - DKA - Use Training Type Company Legislation for Context
Call SET_CONTEXT
#LIPET - 2017-11-29 - START
 [M]LEG = [F:TCS]LEG
 GCURLEG = [M]LEG
 Affzo [M]LEG
#LIPET - 2017-11-29 - END
#If [CSI1]CTR<>""
#  Read [HRCTR]CTR0(2)=[CSI1]REFNUM;[CSI1]CTR
#  If !fstat
#    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
#    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#  Else
#    Read [ID]ID0=[CSI1]REFNUM
#    If !fstat
#     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
#     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Endif
#Else
#  If [CSI0]TCS<>""
#    Read [TCS]TCS0=[CSI0]TCS
#    If !fstat
#      Call LECTURE("CPY",[F:TCS]CPY,"") From CONTOBJ
#      GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Else
#    Read [ID]ID0=[CSI1]REFNUM
#    If !fstat
#     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
#     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Endif
#Endif
#If GNBLEG=1 : GCURLEG = GDOSLEG : Endif


#20/06/12 - DKA - Hide fields based on legislation
Call DISPLAY_HIDE() From SUBCSILEG

Affzo [M:CSI0]
#LIPET - X3-29543 - 2017-11-29 - START
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - START
If func AFNC.ACTIV("FKSSD")>0
  If func DIVPAYE.EXISTE_KXX("SUBCSISA") Then
    Call AM_TCS(VALEUR) From SUBCSISA
  Endif
Endif
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - END
#LIPET - X3-29543 - 2017-11-29 - END
End


#**
#* Avant saisie du code salarié
#* SEGAY
#* @param  VALEUR  : code salarié
#*!
Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
#SEGAY - 02/05/11 - 73325
[M]FLGSELEMP=0
[M]FLGSELCTR=0
#END - 73325
If VALEUR=""
  #sba 29/06/2012
#  Call PARAMUTIL("REFNUM",VALEUR,GUSER,"") From SUBAUS
  # SBA check value: if ok valeur=tmpmat else do nothing
 Local Char TMPMAT
 Call PARAMUTIL("REFNUM",TMPMAT,GUSER,"") From SUBAUS
 Local Char TMPCTR
 Local Date L_DAT
 Local Integer NBCTR
 Local Char T_TABC(1)(0..100)
 If [M:CSI1]STRDAT<>[0/0/0]
   L_DAT = [M:CSI1]STRDAT
  Else
   L_DAT = date$
  Endif
  Call SELCONTRATBASE(TMPMAT,L_DAT,L_DAT,T_TABC,T_TABC,T_TABC,T_TABC,NBCTR,1,0)
  GMESSAGE=""
  If NBCTR<>0
     VALEUR=TMPMAT
  Endif
Endif
End
#**
#* Controle saisie du code salarié
#* SEGAY
#* @param  VALEUR  : code salarié
#*!
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
If func READ_EMP(VALEUR) > 0 Then
  # Ce salarié n'existe pas
  GMESSAGE = mess(94,10717,1)
  mkstat=2
Elsif [F:ID]ENAFLG = 1 Then
  # Ce salarié est inactif
  GMESSAGE = mess(100,10717,1)
  mkstat=2
Endif
End



#**
#* Aprés modif du code salarié
#* SEGAY
#* @param  VALEUR  : code salarié
#*!
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char CONTRAT(GLONHRCTR)
# FQ94656
Gosub INI_DAT1DAT2

#SEGAY 26/06/2012 - 81085 US500
Local Integer WOK
# check contrat
Local Integer NBCTR
Local Char T_TABC(1)(0..100)
Call SELCONTRATBASE(VALEUR,L_DAT1,L_DAT2,T_TABC,T_TABC,T_TABC,T_TABC,NBCTR,1,1)
If NBCTR=0
    GMESSAGE  = mess(158,10702,1)
    mkstat=2
    End
Endif
If !func TEST_REFNUMT(VALEUR,0)
   mkstat=2 : End
Endif

#SEGAY - 02/05/11 - 73325
If ![M]FLGSELEMP :  Raz [M:CSI1]CTR : Endif
[M]FLGSELEMP=0
#END - 73325
# FQ94656
If ! func READ_EMP(VALEUR) Then
  If [F:ID]FLGMULCTR<>2
   Call CHERCHE_CTR(VALEUR,[L]L_DAT1,CONTRAT) From DIVPAYE
  # Vérifie que le salarié est présent dans la société
   Call VERIF_PRESENCE_DAT(VALEUR,CONTRAT,[L]L_DAT1,[L]L_DAT2,0,[0/0/0],[L]L_CTRDAT) From SUBCSI :# FQ94656

  #END - 73325
   If mkstat=2 :[M]FLGSELCTR=0: End : Endif

  #SEGAY 26/06/2012 - 81085 US500
   If [M:CSI0]TCS <> ""
     Call CRTCPY_TCSCTR([M:CSI0]TCS,VALEUR,CONTRAT,[L]L_CTRDAT,WOK,1)
     If mkstat=2 Then End : Endif
   Endif
   #20/06/2012 - DKA
   # Controls that the contract is in the correct leg
   Call CHECK_LEGCTR(VALEUR,CONTRAT)

   If mkstat=2 Then End : Endif

  #  # Contrôle que le salarié appartient à la cible
  #  Call VERIF_CIBLE(VALEUR,CONTRAT)
   [M:CSI1]CTR = CONTRAT
   [M:CSI1]CTRDAT = [L]L_CTRDAT : # FQ94656
   Affzo [CSI1]CTRDAT
   Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Endif
  Call GRISE_CTR([F:ID]FLGMULCTR)

  #20/06/12 - DKA - Hide fields based on legislation
  Call DISPLAY_HIDE() From SUBCSILEG
  #ADNGO - 2017-02-15 - START
  #** V7 : Waiting Time Management **#
  #If GMODU(4)=2 & GPAYE
  #  Call SOLDE_DIF(VALEUR,[M:CSI1]CTR,[M:CSI1]STRDAT,[M:CSI1]NBRHOUDIF) From DIVPAYE
  #Endif
  #*!
  If GMODU(15)=2 & GPAYE
    Call SOLDE_DIF(VALEUR,[M:CSI1]CTR,[M:CSI1]STRDAT,[M:CSI1]NBRHOUDIF) From DIVPAYE
  Endif
  #ADNGO - 2017-02-15 - END
  Gosub AFF_NAMSRN
  Affzo [M:CSI1]NBRHOUDIF
Endif
#SEGAY - 02/05/11 - 73325
[M]FLGSELEMP=0
#   SEGAY 26/06/12 81085 US500
[M:CSI1]REFNUM = VALEUR
End

#20/06/12 - DKA - Check Contract valid
Subprog CHECK_LEGCTR(MAT,CTR)
Value Char MAT
Value Char CTR


Local Integer OK
Local Char TMPLEG
Local Char CURLEG
Local Char SAVLEG
SAVLEG=GCURLEG
CURLEG=GCURLEG

Call GET_LEGHRCTR(MAT,CTR,OK,TMPLEG,0) From TOOLSHRLEG

GCURLEG=SAVLEG
If(CURLEG <>"" and CURLEG<>TMPLEG)
  GMESSAGE = mess(276,10717,1)- CURLEG : # La législation du contrat doit être
  mkstat=2
Endif
End

######################################################################################
## Vérifie que le salarié est présent dans la société
######################################################################################
# FQ94656
#**
#*
#*
#* @param MATRI1
#* @param CTR1
#* @param DAT1 : test date contrat CTRDAT
#* @param DAT2 : test date de fin de contrat XITDAT # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
#* @param SELECTCTR : if end selection contrat
#* @param DATCTR : test date contrat CTRDAT
#* @param PCTRDAT : return date contrat CTRDAT
#*!

Subprog VERIF_PRESENCE_DAT(MATRI1,CTR1,DAT1,DAT2,SELECTCTR,DATCTR,PCTRDAT)
Value Char    MATRI1()
Value Char    CTR1()
Value Date    DAT1
Value Date    DAT2
Value Date    DATCTR
Value Integer SELECTCTR
Variable Date PCTRDAT
Local Integer OK
Local Integer OK

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If SELECTCTR
## Entrée-Sorties
  Filter [HRCTR] Where REFNUM=MATRI1 & CTRNUM=CTR1 & CTRDAT=DATCTR
&              & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT2)

Else
  Filter [HRCTR] Where REFNUM=MATRI1 & CTRNUM=CTR1 & CTRDAT<=DAT1
&              & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT2)
Endif
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If fstat<=2
 If [F:HRCTR]XITDAT<>[0/0/0] and [F:HRCTR]XITDAT<DAT2 and [F:HRCTR]XITFNL=2
  # Salarié non présent dans la société
  GMESSAGE = mess(67,10717,1)
  mkstat = 2 : End
 Elsif [F:HRCTR]XITDAT<>[0/0/0]
  OK = 2
  # Sortie du salarié le xx/xx/xx
  Call AVERTIR (mess(68,10717,1)-num$([F:HRCTR]XITDAT),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
  PCTRDAT=[F:HRCTR]CTRDAT
 Endif
Else
 # Salarié non présent dans la société
 GMESSAGE = mess(67,10717,1)
 mkstat = 2 : End
Endif
End


######################################################################################
## Vérifie que le salarié est présent dans la société
######################################################################################
#SEGAY - 02/05/11 - 73325
#**
#*
#*
#* @param MATRI1
#* @param CTR1
#* @param DAT1 : test date contrat CTRDAT
#* @param DAT2 : test date de fin de contrat XITDAT # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
#* @param SELECTCTR : if end selection contrat
#* @param DATCTR : test date contrat CTRDAT
#*!
Subprog VERIF_PRESENCE(MATRI1,CTR1,DAT1,DAT2,SELECTCTR,DATCTR)
Value Char    MATRI1()
Value Char    CTR1()
Value Date    DAT1
Value Date    DAT2
Value Date    DATCTR
Value Integer SELECTCTR
Local Date    WCTRDAT
Call VERIF_PRESENCE_DAT(MATRI1,CTR1,DAT1,DAT2,SELECTCTR,DATCTR,WCTRDAT)
End

Subprog VERIF_PRESENCEOLD(MATRI1,CTR1,DAT1,SELECTCTR,DATCTR)
Value Char    MATRI1()
Value Char    CTR1()
Value Date    DAT1
Value Date    DATCTR
Value Integer SELECTCTR
Local Integer OK

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If SELECTCTR
## Entrée-Sorties
  Filter [HRCTR] Where REFNUM=MATRI1 & CTRNUM=CTR1 & CTRDAT=DATCTR
&              & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT1)

Else
  Filter [HRCTR] Where REFNUM=MATRI1 & CTRNUM=CTR1 & CTRDAT<=DAT1
&              & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT1)
Endif
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If fstat<=2
 If [F:HRCTR]XITDAT<>[0/0/0] and [F:HRCTR]XITDAT<DAT1 and [F:HRCTR]XITFNL=2
  # Salarié non présent dans la société
  GMESSAGE = mess(67,10717,1)
  mkstat = 2 : End
 Elsif [F:HRCTR]XITDAT<>[0/0/0]
  OK = 2
  # Sortie du salarié le xx/xx/xx
  Call AVERTIR (mess(68,10717,1)-num$([F:HRCTR]XITDAT),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
 Endif
Else
 # Salarié non présent dans la société
 GMESSAGE = mess(67,10717,1)
 mkstat = 2 : End
Endif
End

#**
#* Activation du code contrat
#* Si multicontrat activation
#* Si pas multicontrat déactivation
#* SEGAY
#* @param  VALEUR  : flag multicontrat
#*!
Subprog GRISE_CTR(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:CSI1]CTR
Else
 Diszo [M:CSI1]CTR
Endif
Affzo [M:CSI1]CTR
End
#**
#* Affiche le matricule
#* Si on est en modification
#*!
Subprog AFF_MAT
#If GREP <>'D' & GREP <>'C'
#  Diszo [M:CSI1]REFNUM
#Else
#  Actzo [M:CSI1]REFNUM
#Endif
Affzo [M:CSI1]REFNUM
End
#**
#* Degriseage de CSI0
#* Si on est en duplication
#*!
Subprog AFF_CSI0
Actzo [M:CSI0]TCS,FLGPRO
Actzo [M:CSI1]JOBPOT,POT
Affzo [M:CSI0]TCS,FLGPRO
Affzo [M:CSI1]JOBPOT,POT
End
#**
#* Grise le parcours type,FLGPRO,JOBPOT,POT
#* Si demande existe
#* modification impossible s'il existe des demandes
#*!
Subprog GRISE_IS_DEM
If func DEM_EXIST([M:CSI0]COD,[M:CSI1]REFNUM,[M:CSI1]CTR)
  Diszo [M:CSI0]TCS,FLGPRO
  Diszo [M:CSI1]JOBPOT,POT
Else
  Actzo [M:CSI0]TCS,FLGPRO
  Actzo [M:CSI1]JOBPOT,POT
Endif
Affzo [M:CSI0]TCS,FLGPRO
Affzo [M:CSI1]JOBPOT,POT
End

#**
#* Lecture de la table d'état civil EMPLOID
#*
#* @param P_REFNUM : matricule qui est cherché
#*!
Funprog READ_EMP(P_REFNUM)
Value Char P_REFNUM()
  Read [F:ID]ID0 = P_REFNUM
End fstat

#**
#* Avant saisie du code contrat
#* SEGAY
#* @param  VALEUR  : code contrat
#*!
Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
# FQ94656
Gosub INI_DAT1DAT2

If [M:CSI1]CTR=""
  Call SELCTR([M:CSI1]REFNUM,L_DAT1,L_DAT2,0,VALEUR) From SUBCSI # US 2323 94656
Else
  #SEGAY 70715 pour griser si aprés avoir fait creation on fait abandon
  If func GET_EMPLOID([M:CSI1]REFNUM) & GREP <> "M" # US 2323 94656
    Call GRISE_CTR([F:ID]FLGMULCTR)
  Endif
Endif
End


#**
#* Controle du code contrat
#* Contrôle que le salarié est présent
#* SEGAY
#* @param  VALEUR  : code contrat
#*!
Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
#SEGAY 26/06/2012 - 81085 US500
Local Integer WOK
# FQ94656
Gosub INI_DAT1DAT2

## Contrôle que le salarié est présent
If VALEUR<>""
  Call VERIF_PRESENCE([M:CSI1]REFNUM,VALEUR,L_DAT1,L_DAT2,[M:CSI1]FLGSELCTR,[M:CSI1]CTRDAT) From SUBCSI
  If mkstat=2 : End : Endif
  # # Contrôle que le salarié appartient à la cible
  # Call VERIF_CIBLE([M:DEM1]REFNUM,VALEUR)
  # If mkstat=2 : End : Endif
    #SEGAY 26/06/2012 - 81085 US500
  If [M:CSI0]TCS <> ""
    Call CRTCPY_TCSCTR([M:CSI0]TCS,[M:CSI1]REFNUM,VALEUR,[F:HRCTR]CTRDAT,WOK,1)
    If mkstat=2 Then End : Endif
  Endif
Else
  GMESSAGE=mess(10,123,1)
  mkstat=2
Endif
End

#**
#* Aprés modification du code contrat
#* SEGAY
#* @param  VALEUR  : code contrat
#*!
Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
#  SEGAY 73325
#SEGAY - 02/05/11 - 73325
If ![M]FLGSELCTR
  Filter [F:HRCTR]
  If [M:CSI1]STRDAT<>[0/0/0]
    Filter [HRCTR] Where [HRCTR]REFNUM=[M:CSI1]REFNUM and [HRCTR]CTRNUM=VALEUR
&                and [HRCTR]CTRDAT<=[M:CSI1]STRDAT
&                and ([HRCTR]XITDAT=[0/0/0] or [HRCTR]XITDAT>=[M:CSI1]STRDAT)
  Else
    Filter [HRCTR] Where [HRCTR]REFNUM=[M:CSI1]REFNUM and [HRCTR]CTRNUM=VALEUR
#&                and [HRCTR]CTRDAT<=date$ # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
#&                and ([HRCTR]XITDAT=[0/0/0] or [HRCTR]XITDAT>=date$) # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
  Endif
  Read [HRCTR]CTR0 Last
  If !fstat
    [M:CSI1]CTRDAT = [F:HRCTR]CTRDAT
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
    Affzo [CSI1]CTRDAT
  Endif
  Filter [F:HRCTR]
Endif
[M]FLGSELCTR=0

#20/06/12 - DKA - Hide fields based on legislation
Call DISPLAY_HIDE() From SUBCSILEG
#   SEGAY 26/06/12 81085 US500
[M:CSI1]CTR = VALEUR
Raz [M:CSI3]NBACN
Gosub RAZ_SUIACN

End

#**
#* Après modification poste type
#* Alimentation de l'emploi-type
#* Initialisation des compétences requises par les données du poste
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : poste type
#*!
Subprog AM_POT(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
If func IS_CAR
  L_OK = 1
  Call OUINON(mess(154,10717,1),L_OK) From GESECRAN
  #### Attention votre choix va modifier les compétences requises  ?
  If L_OK<>2
   VALEUR=[M:CSI1]POT
   End
  Endif
Endif
Call LECTURE("POT",VALEUR,"") From CONTOBJ
If [F:POT]JOBPOT<>""
 [M:CSI1]JOBPOT = [F:POT]JOBPOT
 Affzo [M:CSI1]JOBPOT,ZJOBPOT
Endif
If func IS_CAR
  Call INIT_CPC(VALEUR,1) From SUBCSI
Endif
mkstat = 0
End

#**
#* Après modification emploi type
#* Initialisation des compétences requises par les données du poste
#* SEGAY
#* @since 03/07/10
#* @param VALEUR :  poste type
#*!
Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
L_OK = 1
If func IS_CAR
  Call OUINON(mess(154,10717,1),L_OK) From GESECRAN
  #### Attention votre choix va modifier les compétences requises  ?
  If L_OK<>2
   VALEUR=[M:CSI1]JOBPOT
   End
  Endif
  Call INIT_CPC(VALEUR,2) From SUBCSI
  mkstat = 0
Endif
End

#**
#* Bouton MAJ Champs du poste type
#* Alimentation de l'emploi-type
#* Initialisation des compétences requises par les données du poste
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : poste type
#*!
Subprog B2_POT(VALEUR)
Variable Char    VALEUR()
# mkstat=4 permet d'être en modification et d'avoir en suivant AM_POT qui initialise les compétences requises
mkstat = 4
End

#**#####################################################################################
#* Sélection poste type
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : poste type
#*!
Subprog B2_DESJOB(VALEUR)
Variable Char    VALEUR()
Local Char  PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:POT]) : Local File POSTE     [POT] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "POT"
PARMSK(2) = ""
PARMSK(3) = ""
#PARMSK(4) = "([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M]CTRDAT)"
#PARMSK(5) = "([M]XITDAT=[0/0/0] | [F:POT]DATSTRVLY<=[M]XITDAT)"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
GACTION = SAVACT
Read [POT]POT0=VALEUR
If !fstat
# VALEUR = [F:POT]DES
 Local Char DES
 Call LECTEXTRA(DES,"POSTE","DES",VALEUR,"") From ATEXTRA
 VALEUR=DES
Else
 VALEUR = SAVVALEUR
Endif
End
#**#####################################################################################
#* Initilisation Bouton Sélection emploi-type
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : emploi-type
#*!
Subprog B3_DESJOB(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:JOT]) : Local File JOBTYP    [JOT] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "JOT"
PARMSK(2) = ""
PARMSK(3) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJSTD","SELOBJ","") From GACTION
GACTION = SAVACT
Read [JOT]JOT0=VALEUR
If !fstat
#SBA 04/07/2012 mod leg GESJOT
 #VALEUR = [F:JOT]DES
 Call LECTEXTRA(VALEUR,"JOBTYP","DES",VALEUR,"") From ATEXTRA
  #SBA end
Else
 VALEUR = SAVVALEUR
Endif
End

#**
#* Après modification tuteur
#* Alimentation des champs tuteur
#* Vérifie que le salarié est présent dans la société
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : tuteur
#*!
Subprog AM_REFNUMT(VALEUR)
Variable Char    VALEUR()
Local Char CONTRAT(GLONHRCTR)
If !func TEST_REFNUMT(VALEUR,1)
  mkstat=2 : End
Endif
# FQ94656
If ! func READ_EMP(VALEUR) Then
  If [F:ID]FLGMULCTR<>2
   Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  # Vérifie que le salarié est présent dans la société
   Gosub INI_DAT1DAT2
   If [M:CSI1]STRDAT=[0/0/0]
      L_DAT1 = date$
      L_DAT2 = date$
   Endif
   Call VERIF_PRESENCE(VALEUR,CONTRAT,L_DAT1,L_DAT2,0,[0/0/0] ) From SUBCSI
   If mkstat=2 : End : Endif
  #  # Contrôle que le salarié appartient à la cible
  #  Call VERIF_CIBLE(VALEUR,CONTRAT)
  #  If mkstat=2 : End : Endif
  Endif
  Gosub AFF_NAMSRN_T : # FQ94656
Else
  Call GET_TUTEUR(VALEUR) : # FQ94656
Endif
End

#**#####################################################################################
#* Avant saisie de l'unité temps, Supression de l'item heure
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : unité temps
#*!
Subprog AS_UOMTIM(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
#segay 07/09/11 75372
#UOMTIM= jour/semaine/mois/année ML 313
#GMENLOC(2) = 1
#GMENLOC(4) = 1
#END 07/09/11 75372
End
#**
#* Controle date début
#* Test sur la période de stage
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : date début
#*!
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Date WDATE

## FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
Gosub READ_CTR_CSI
If fstat
 # Salarié non présent le ../../..
 GMESSAGE = mess(171,10717,1)-num$(VALEUR)
 GERR = 1
 mkstat = 2 : End
Endif

Filter [F:CSIX] Where [F:CSIX]COD <> [M:CSI0]COD & [F:CSIX]REFNUM = [M:CSI1]REFNUM & [F:CSIX]CTR = [M:CSI1]CTR & [F:CSIX]STRDAT = VALEUR
If rowcount ([F:CSIX]) > 0
  Filter [F:CSIX]
  mkstat = 2
  # Il existe déjà  un parcours pour ce salarié commençant à cette date
  GMESSAGE = mess(165,10717,1)
  GERR = 1
  End
Endif
Filter [F:CSIX]


End

#**
#* Après modification durée
#* Alimentation date fin avec durée
#* FRRIC
#* @since 03/10/11
#* @param VALEUR : durée
#*!
Subprog AM_DUREE(VALEUR)
Variable Decimal VALEUR
Local Integer I
#FRRIC 03/10/11 77497
If [M]DUREE > 0 and [M]STRDAT > [0/0/0]
  Case [M]UOMTIM
   When 1 : [M]ENDDAT = [M]STRDAT+VALEUR-1              : # Jour
   When 2 : [M]ENDDAT = [M]STRDAT+(VALEUR*7)-1          : #Semaine
   When 3 : [M]ENDDAT = addmonth([M]STRDAT,VALEUR)-1    : #Mois
   When 4 : [M]ENDDAT = addmonth([M]STRDAT,VALEUR*12)-1 : #Année
  Endcase
  Affzo [M]ENDDAT
Endif
End
#END 03/10/11 77497

#**
#* Après modification de l'unité temps
#* Alimentation date fin avec durée
#* FRRIC
#* @since 03/10/11
#* @param VALEUR : durée
#*!
Subprog AM_UOMTIM(VALEUR)
Variable Integer VALEUR
Local Integer I
#FRRIC 03/10/11 77497
If [M]DUREE > 0 and [M]STRDAT > [0/0/0]
  Case VALEUR
   When 1 : [M]ENDDAT = [M]STRDAT+[M]DUREE-1              : # Jour
   When 2 : [M]ENDDAT = [M]STRDAT+([M]DUREE*7)-1          : #Semaine
   When 3 : [M]ENDDAT = addmonth([M]STRDAT,[M]DUREE)-1    : #Mois
   When 4 : [M]ENDDAT = addmonth([M]STRDAT,[M]DUREE*12)-1 : #Année
  Endcase
  Affzo [M]ENDDAT
Endif
End
#END 03/10/11 77497

#**
#* Après modification date début
#* Test sur la période de stage
#* Alimentation date fin avec durée
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : date début
#*!
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer I
Local Integer W_OK

For I=0 To [M:CSI2]NBLIG-1
  # Avertir si date est dans la période de stage
  # On sort si on en trouve 1 en dehors pour ne pas boucler sur tous les stages
  W_OK = func AV_NO_DATE_STG([M:CSI2]STG(I), VALEUR, [M:CSI1]ENDDAT, 2)
  If W_OK = 1 : mkstat=2:Break :Endif
  If W_OK = 2 : Break :Endif

  # Avertir si la période du parcours comprend date de début souhaitée du stage
  # On sort si on en trouve 1 en dehors pour ne pas boucler sur tous les stages
  W_OK = func AV_NO_DATES_STG([M:CSI2]STG(I), [M:CSI2]STRDATS(I), VALEUR, [M:CSI1]ENDDAT)
  If W_OK = 1 : mkstat=2:Break :Endif
  If W_OK = 2 : Break :Endif

Next
If mkstat = 2 : End : Endif

If [M]ENDDAT =[0/0/0]
   [M]ENDDAT = VALEUR
Endif

#segay 07/09/11 75372
#UOMTIM= jour/semaine/mois/année ML 313
If [M]DUREE > 0
  Case [M]UOMTIM
   When 1 : [M]ENDDAT = VALEUR+[M]DUREE-1              : # Jour
   When 2 : [M]ENDDAT = VALEUR+([M]DUREE*7)-1          : #Semaine
   When 3 : [M]ENDDAT = addmonth(VALEUR,[M]DUREE)-1    : #Mois
   When 4 : [M]ENDDAT = addmonth(VALEUR,[M]DUREE*12)-1 : #Année
  Endcase
Else
  [M]ENDDAT = VALEUR
Endif
Affzo [M]ENDDAT
#END 07/09/11 75372

If [M]ENDDAT =[0/0/0]
   [M]ENDDAT = VALEUR
   Affzo [M]ENDDAT
Endif
#ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#If GMODU(4)=2 & GPAYE
#  Call SOLDE_DIF([M:CSI1]REFNUM,[M:CSI1]CTR,VALEUR,[M:CSI1]NBRHOUDIF) From DIVPAYE
#Endif
If GMODU(15)=2 & GPAYE
  Call SOLDE_DIF([M:CSI1]REFNUM,[M:CSI1]CTR,VALEUR,[M:CSI1]NBRHOUDIF) From DIVPAYE
Endif
#ADNGO - 2017-02-15 - END
Affzo [M:CSI1]NBRHOUDIF
# FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
Gosub READ_CTR_CSI
If !fstat
 If [F:HRCTR]CTRDAT <> [M:CSI1]CTRDAT
    [M:CSI1]CTRDAT=[F:HRCTR]CTRDAT
    Affzo [M:CSI1]CTRDAT
 Endif
Endif
# END FQ94656
End

# FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
$READ_CTR_CSI
Filter [HRCTR] Where REFNUM=[M:CSI1]REFNUM & CTRNUM=[M:CSI1]CTR & CTRDAT<=VALEUR
Read [HRCTR]CTR0 Last  # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
Filter [HRCTR]
Return

#**
#* Controle date fin
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : date fin
#*!
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

End

#**
#* Après modification date fin
#* Test sur la période de stage
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : date fin
#*!
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer I
Local Integer W_OK

For I=0 To [M:CSI2]NBLIG-1
  # Avertir si date est dans la période de stage
  # On sort si on en trouve 1 en dehors pour ne pas boucler sur tous les stages
  W_OK = func AV_NO_DATE_STG([M:CSI2]STG(I), [M:CSI1]STRDAT, VALEUR, 2)
  If W_OK = 1 : mkstat=2:Break :Endif
  If W_OK = 2 : Break :Endif

  # Avertir si la période du parcours comprend date de début souhaitée du stage
  # On sort si on en trouve 1 en dehors pour ne pas boucler sur tous les stages
  W_OK = func AV_NO_DATES_STG([M:CSI2]STG(I), [M:CSI2]STRDATS(I), [M:CSI1]STRDAT, VALEUR)
  If W_OK = 1 : mkstat=2:Break :Endif
  If W_OK = 2 : Break :Endif
Next
If mkstat = 2 : End : Endif

End


#**
#* Chargement à l'écran stage des infos du stage
#* SEGAY
#* @since 03/07/10
#* @param PNBLIG : ligne
#* @param PSTG : stage
#*!
Subprog CHARGE_INFO_STG(PNBLIG,PSTG)
Value Integer PNBLIG
Value Char PSTG
Raz [F:STG]
Call LECTURE("STG",PSTG,"") From CONTOBJ
[M:CSI2]DOM(PNBLIG)=[F:STG]DOM
[M:CSI2]THM(PNBLIG)=[F:STG]THM
# 26/06/12 SEGAY 81085 US500
If dim(GCURLEG)>0 & GCURLEG <> ""
   If [F:STG]LEG <> "" & [F:STG]LEG <> GCURLEG
      [M:CSI2]DOM(PNBLIG)=""
      [M:CSI2]THM(PNBLIG)=""
   Endif
Endif
# 29/12/10 SEGAY Bug 70244 le nbre de jour est repris si type <> autre stage
If [F:STG]TYPSTG <> 2
  [M:CSI2]NBRDAY(PNBLIG)=[F:STG]NBRDAY
Endif
[M:CSI2]NBRHOUIPT(PNBLIG)=[F:STG]NBRHOUIPT

End

#**
#* Chargement à l'écran stage des initialisation champs par le stage
#* SEGAY 02/02/11 bug 71254
#* @since 03/02/11
#* @param PNBLIG : ligne
#* @param PSTG : stage
#*!
Subprog CHARGE_INI_STG(PNBLIG,PSTG)
Value Integer PNBLIG
Value Char PSTG
Raz [F:STG]
Call LECTURE("STG",PSTG,"") From CONTOBJ
If !fstat
  [M:CSI2]NATFIS(PNBLIG)=[F:STG]NATFIS
  [M:CSI2]CATACN(PNBLIG)=[F:STG]CATACN
  [M:CSI2]TYPFRT(PNBLIG)=[F:STG]TYPFRT
  Affzo [M:CSI2]NATFIS(PNBLIG)
  Affzo [M:CSI2]CATACN(PNBLIG)
  Affzo [M:CSI2]TYPFRT(PNBLIG)
Endif

End
#**
#* Chargement à l'écran stage des infos du stage réalisé
#* SEGAY
#* @since 28/12/10
#* @param PNBLIG : ligne
#* @param PSTG : stage
#*!
Subprog CHARGE_INFO_STG_R(PNBLIG,PSTG)
Value Integer PNBLIG
Value Char PSTG
Raz [F:STG]
Call LECTURE("STG",PSTG,"") From CONTOBJ
# 29/12/10 SEGAY Bug 70244 le nbre de jour est repris si type <> autre stage
If [F:STG]TYPSTG = 2
   [M:CSI2]NBRDAYREAA(PNBLIG)=0
Else
   [M:CSI2]NBRDAYREAA(PNBLIG)=[M:CSI2]NBRDAYREA(PNBLIG)
Endif
End
#**#####################################################################################
#* Affichage du total jours et heures prévues
#* SEGAY
#* @since 03/08/10
#*!
Subprog AFF_AFFTOT_PREV
[M:CSI2]NBRDAYT = sum([M:CSI2]NBRDAY(0..[M:CSI2]NBLIG))
[M:CSI2]NBRHOUIPTT = sum([M:CSI2]NBRHOUIPT(0..[M:CSI2]NBLIG))
Affzo [M:CSI2]NBRDAYT
Affzo [M:CSI2]NBRHOUIPTT
End

#**#####################################################################################
#* Affichage du total jours et heures effectuées
#* SEGAY
#* @since 03/08/10
#*!
Subprog AFF_AFFTOT_EFF
[M:CSI2]NBRDAYREAT = sum([M:CSI2]NBRDAYREAA(0..[M:CSI2]NBLIG))
[M:CSI2]NBRHOUREAT = sum([M:CSI2]NBRHOUREA(0..[M:CSI2]NBLIG))
[M:CSI2]NBRHOUIPT2T = sum([M:CSI2]NBRHOUIPT2(0..[M:CSI2]NBLIG))
Affzo [M:CSI2]NBRDAYREAT
Affzo [M:CSI2]NBRHOUREAT
Affzo [M:CSI2]NBRHOUIPT2T
End


#**
#* Avertir si date est dans la période de stage
#*
#* @param PSTG
#* @param PDATDEB
#* @param PDATFIN
#* @param PTYPTEST 1=stage, 2=datedeb,3=datefin
#*!
Funprog AV_NO_DATE_STG(PSTG,PDATDEB,PDATFIN,PTYPTEST)
Value Char PSTG()
Value Date PDATDEB,PDATFIN
Value Integer PTYPTEST
Local Integer L_OK
Local Char PMESSAGE(250)
L_OK = 0
If PSTG<>""  & PDATDEB<>[0/0/0] & PDATFIN<>[0/0/0]
  Call LECTURE("STG",PSTG,"") From CONTOBJ
    If(([F:STG]STRVLY<>[0/0/0] & PDATDEB<[F:STG]STRVLY) | ([F:STG]ENDVLY<>[0/0/0] & PDATDEB>[F:STG]ENDVLY)
&    | ([F:STG]STRVLY<>[0/0/0] & PDATFIN<[F:STG]STRVLY) | ([F:STG]ENDVLY<>[0/0/0] & PDATFIN>[F:STG]ENDVLY))
      # La période de validité du stage est du ../../.. au ../../..
     PMESSAGE = mess(160,10717,1)-PSTG-mess(161,10717,1)-num$([F:STG]STRVLY)-mess(95,100,1)-num$([F:STG]ENDVLY)
     If PTYPTEST = 1
      PMESSAGE += chr$(10)+mess(162,10717,1)
     Else
      PMESSAGE += chr$(10)+mess(163,10717,1)
     Endif
     Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
    Endif
Endif
End L_OK
#**
#* Avertir si la période du parcours comprend date de début souhaitée du stage
#*
#* @param PSTG
#* @param PDATDEBS
#* @param PDATDEB
#* @param PDATFIN
#*!
Funprog AV_NO_DATES_STG(PSTG,PDATDEBS,PDATDEB,PDATFIN)
Value Char PSTG()
Value Date PDATDEBS,PDATDEB,PDATFIN
Local Integer L_OK
Local Char PMESSAGE(250)
L_OK = 0
If PSTG<>""  & PDATDEB<>[0/0/0] & PDATFIN<>[0/0/0]
  If(PDATDEBS<>[0/0/0] & (PDATDEBS<PDATDEB | PDATDEBS>PDATFIN))
    # La date de début souhaitée du stage est ../../..
   PMESSAGE = mess(200,10717,1)-PSTG-mess(201,10717,1)-num$(PDATDEBS)
   PMESSAGE += chr$(10)+mess(163,10717,1)
   Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
  Endif
Endif
End L_OK

#**#####################################################################################
#* Action sur ecran CSI2 STAGE
#* SEGAY
#
#**
#* Avant n° de ligne tableau stage activation des lignes de stages
#* Trop lent quand on le fait sur plusieurs lignes
#*!
#Subprog AVANT_NBLIG
#Integer I
#I = nolign-1
#If [M:CSI2]STG(I)<> ""
# If func DEM_STG_EXIST([M:CSI0]COD, [M:CSI1]REFNUM,[M:CSI1]CTR, [M:CSI2]STG(I)) Then
#  Grizo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
#  Affzo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
# Else
#  Actzo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
# Endif
#Endif
#End
#**
#* Init bouton du tableau des stages
#* Il est interdit de générer des inscriptions des stages de parcours sans demande générée ou déjà inscrit
#* Init Tunel sur Inscription
#* Tunel uniquement si STA(ML471) = 2 Engagé ou 3=Réalisée
#*!
Subprog IB_NBLIG
If [M:CSI2]STG(nolign-1) ="" or GREP<>""
 Raz GBOUT3
Else
   # Il est interdit de générer des inscriptions des stages de parcours sans demande générée ou déjà inscrit
  If !func DEM_STG_EXIST([M:CSI0]COD, [M:CSI1]REFNUM, [M:CSI1]CTR, [M:CSI2]STG(nolign-1)) or find([M:CSI2]STA(nolign-1),2,3) Then
    Raz GBOUT3
  Else
    GBOUT3 = mess(159,10717,1) #Proposition inscription
  Endif
Endif

# SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
# Init Tunel sur Inscription
# Tunel uniquement si STA(ML471) = 2 Engagé ou 3=Réalisée
If [M:CSI2]STA(nolign-1)< 2
 Raz GBOUT2
Else
  GBOUT2 = mess(71,10717,1) #Inscription
Endif

End


# L'exécution des boutons  et "Proposition" se fait dans la le sousprog B2_NBLIG , de façon
# à pouvoir rafraîchir la ligne de stage
Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action INSPRO
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "INSPRO"
 PARMSK(1) = [M:CSI2]STG(nolign-1)
 #MABOS-26/07/13-FQ81085-US1833-fenêtre avec mémo-
 #Call TRAITE_NUM(BASPAG,PARMSK,"LISDEM","INSPRO","INSPRO",3,"XYINSPRO") From GTRAITE
 Call TRAITE_NUM(BASPAG,PARMSK,"LISDEM","INSPRO","INSPRO",4,"XYINSPRO") From GTRAITE

GACTION = SAVACT
 Read [F:CIL]CIL0=[M:CSI0]COD;[M:CSI2]CILLIG(nolign-1)
 If !fstat
    [M:CSI2]STRDATR(nolign-1)=[F:CIL]STRDATR
    [M:CSI2]ENDDATR(nolign-1)=[F:CIL]ENDDATR
    [M:CSI2]STA(nolign-1)=[F:CIL]STA
    # 29/12/10 SEGAY Bug 70244 le nbre de jour est repris si type <> autre stage
    Raz [F:STG]
    Call LECTURE("STG",[M:CSI2]STG(nolign-1),"") From CONTOBJ
    If [F:STG]TYPSTG <> 2
      [M:CSI2]NBRDAYREA(nolign-1)=[F:CIL]NBRDAYREA
      [M:CSI2]NBRDAYREAA(nolign-1)=[M:CSI2]NBRDAYREA(nolign-1)
    Else
      [M:CSI2]NBRDAYREA(nolign-1)=[M:CSI2]NBRDAYREA(nolign-1)
      [M:CSI2]NBRDAYREAA(nolign-1)=0
    Endif
    [M:CSI2]NBRHOUREA(nolign-1)=[F:CIL]NBRHOUREA
    [M:CSI2]NBRHOUIPT2(nolign-1)=[F:CIL]NBRHOUIPT2
    Affzo [M:CSI2]STRDATR(nolign-1),ENDDATR(nolign-1),STA(nolign-1),NBRDAYREAA(nolign-1),NBRHOUREA(nolign-1),NBRHOUIPT2(nolign-1)
    Call AFF_AFFTOT_EFF
 Endif
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
End



#**
#* Calcul du n° de ligne tableau stage en fonction des valeurs disponibles
#* Il est interdit de supprimer des stages de parcours dont la demande est générée
#*!
Subprog C_NBLIG
Call INSERE("CILLIG") From TABLEAUX
If status=65 | status=68 | status=83
 # Il est interdit de supprimer des stages de parcours dont la demande est générée
  If func DEM_STG_EXIST([M:CSI0]COD, [M:CSI1]REFNUM, [M:CSI1]CTR, [M:CSI2]STG(nolign-1)) Then
    GMESSAGE = mess(156,10717,1)
     GERR=1
     mkstat = 2 : End
   Endif
Endif
End

Subprog APRES_NBLIG
Call LINNUM("CILLIG") From TABLEAUX
Call AFF_AFFTOT_PREV
End
#**
#* Avant stage tableau stage activation des lignes de stages
#*!
Subprog AS_STG(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
 If func DEM_STG_EXIST([M:CSI0]COD, [M:CSI1]REFNUM, [M:CSI1]CTR, VALEUR) Then
    mkstat = 2 : End
 Endif
Endif
End
#**#####################################################################################
#* Aprés sasie du stage, récupération des données
#* Le aprés modif faisait que l'enregistrement se trouvait sur la 1er ligne ???
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Stage
#*!
Subprog AP_STG(VALEUR)
Variable Char    VALEUR()
Local Integer NBRLIG

NBRLIG=nolign-1
Call CHARGE_INFO_STG(NBRLIG,VALEUR())

Affzo [M:CSI2]DOM(NBRLIG)
Affzo [M:CSI2]THM(NBRLIG)
Affzo [M:CSI2]NBRDAY(NBRLIG)
Affzo [M:CSI2]NBRHOUIPT(NBRLIG)
End


#**#####################################################################################
#* Controle de l'unicité du stage
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Stage
#*!
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
If mkstat Then End Endif

Local Integer L_OK
L_OK = 1
Call UNICITE(VALEUR,[M:CSI2]STG) From OBJDIV
If mkstat : End : Endif
End

#**#####################################################################################
#* Aprés modif stage
#* Test sur la période de stage
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Stage
#*!
Subprog AM_STG(VALEUR)
Variable Char    VALEUR()
Local Integer NBRLIG

If VALEUR<>""
 If (func AV_NO_DATE_STG(VALEUR,[M:CSI1]STRDAT,[M:CSI1]ENDDAT,1)) = 1 Then
  mkstat = 2 : End
 Endif
Endif

#SEGAY 02/02/11 BUG 71254
NBRLIG=nolign-1
Call CHARGE_INI_STG(NBRLIG,VALEUR())

End

