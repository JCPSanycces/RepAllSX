Else
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0
  CTRNUMERO = ""
 Else
  CTRNUMERO = TBCTR(NUMCTR)
 Endif
Endif
End
#**
#* Selection base contract
#* @param  MATRI  : matricule
#* @param DAT1 : Date begin
#* @param DAT2 : Date end
#* @param TBCTR : Tab contract
#* @param LIBCTR : Tab libelle contract
#* @param TIT : Tab TITLE for selection
#* @param COL : Tab COLON for selection
#* @param NBCTR : NB contract
#* @param FILTAB : 1=display selection
#* @param PAMREFNUM : 1=AM field REFNUM
#*!
Subprog SELCONTRATBASE(MATRI,DAT1,DAT2,TBCTR,LIBCTR,TIT,COL,NBCTR,FILTAB,PAMREFNUM)
Value Char MATRI
Value Date DAT1,DAT2
Variable Char    TBCTR()() , LIBCTR()()
Variable Char    TIT()(),COL()()
Variable Integer NBCTR
Value Integer FILTAB
Value Integer PAMREFNUM
# SEGAY 26/06/12 81085 US500
Local Char    DESSRV(GLONDES)
Local Char WLEG(GLONADI)
Local Integer WOK
#SEGAY-10/12/2012 US 1045 81085
# if PAMREFNUM = 1 WLEG="" because for go to create
If PAMREFNUM
   WLEG=""
Else
If GREP<>"C"
  WLEG=GCURLEG
Else
  If GCURLEG = ""
    If !PAMREFNUM
      WLEG=GLEGFIL
    Else
      WLEG=""
    Endif
  Else
    WLEG=GCURLEG
  Endif
Endif
Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
If clalev([F:SRV])=0    : Local File SERVICE  [SRV]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif : # 71796
If clalev([F:ACC])=0    : Local File ACCES    [ACC]   : Endif : # 71796
#SBA 02/07/2012 set tit and col
If FILTAB
  Local Char CODFIC
  Local Integer NBCOL
  NBCOL = 1 : COL(NBCOL) = "JOBPOT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE
   # Colonne Poste
  NBCOL += 1 : COL(NBCOL) = "POT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE
Endif
For [HRCTR]CTR0 Where REFNUM=MATRI & CTRDAT<=DAT1 & (XITDAT=[0/0/0] | XITDAT>=DAT2)
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
# / 71796

 If GUSRACS<>2
  Read [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   If [F:ID]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
   Endif
  Endif
 Endif
 # SEGAY 26/06/12 81085 US500
 Call CRTCPY_TCSCTR([M:CSI0]TCS,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,WOK,0)
 #sba 29/12/2012 : Attention la fonction fait planter l'avant zone car mkstat est à 2
 mkstat=0
 #fin sba
 If WOK and (WLEG = "" or WLEG=[F:FCY]LEG)
  If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
   NBCTR += 1
   If FILTAB
   TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
#  SEGAY 16/05/12 To manage translated texts (data type AX3 & AX1)
#   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
#&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-TIT(1)-[F:HRCTR]JOBPOT-"-"-TIT(2)-[F:HRCTR]POT
#&                 -"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-[F:SRV]DES
   Call LECTEXTRA(DESSRV,"SERVICE","DES",[F:HRCTR]ETRSRV,"") From ATEXTRA
   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-TIT(1)-[F:HRCTR]JOBPOT-"-"-TIT(2)-[F:HRCTR]POT
&                 -"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-DESSRV
  Endif
  Endif
 Endif
 #Endif
# 71796 /
Next
End


Funprog IS_CAR
Local Integer WOK
WOK = func AFNC.ACTIV("CAR")
End WOK
#**
#* Affectation du code parcours individualisé
#* SEGAY
#* @param  VALEUR  : numéro
#* @param TCS : parcours type
#*!
Subprog CPT_CSI (VALEUR, TCS)
Variable Char VALEUR()
Value Char TCS ()
Local Char COMPTEUR(GLONANM)
Local Integer STAT
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
GOK=1
#Read [TCA]TCA0 = 20 : # Module gestion des talents
#COMPTEUR = [F:TCA]CODNUM(2)
#If COMPTEUR=""
# GMESSAGE = mess(139,10717,1) : # Compteur parcours non défini
# GOK = 0 : End
#Endif
 #SEGAY 26/06/2012 - 81085 US500
#Need to have GCURLEG and GSOCIETE on line
Call LECTCA(20,STAT) From SUBTCA
If !STAT
 GMESSAGE = mess(139,10717,1) : # Compteur parcours non défini
 GOK = 0 : Return
Else
 COMPTEUR= [F:TCA]CODNUM(2)
Endif

Call NUMERO(COMPTEUR,"",datesyst,TCS,VALEUR,STAT) From SUBANM
If STAT
 GMESSAGE = mess(104,117,1)-COMPTEUR : # "Erreur sur compteur"
 GOK = 0 : End
Endif
Call VERIF_VCR(VALEUR,COMPTEUR)
If GOK=0 : End : Endif
End

#**
#* Vérification compteur parcours individualisé
#* SEGAY
#* @param  NUM  : numéro
#* @param  COMPTEUR  : compteur
#*!
Subprog VERIF_VCR(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:CSIZ])=0 : Local File COURSEI [CSIZ] : Endif
Read [CSIZ]CSI0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",datesyst,"",NUM,STAT) From SUBANM
 Read [CSIZ]CSI0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(104,117,1)-COMPTEUR
 GOK = 0 : End
Endif
End
#**
#* Test s'il existe demande pour le parcours
#* SEGAY
#* @param  P_COD  : parcours
#* @param  P_REFNUM  : matricule
#* @param  P_CTR    : contrat
#*!
Funprog DEM_EXIST(P_COD,P_REFNUM,P_CTR)
Value Char P_COD()
Value Char P_REFNUM()
Value Char P_CTR()
Local Integer DEM_OK
DEM_OK = 0
If P_COD <> ""
  Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=P_REFNUM & [F:DML]CTRNUM=P_CTR & [F:DEM]CODCSI=P_COD & [F:DEM]ORIDEM=2
  If rowcount([F:DM_])<>0 Then : # on regarde si la demande existe déjà
    DEM_OK=1
  Endif
Endif
End DEM_OK
#**
#* Test s'il existe demande pour le parcours et le stage
#* SEGAY
#* @param  P_COD  : parcours
#* @param  P_REFNUM  : matricule
#* @param  P_CTR    : contrat
#* @param  P_STG  : stage
#*!
Funprog DEM_STG_EXIST(P_COD,P_REFNUM,P_CTR,P_STG)
Value Char P_COD()
Value Char P_REFNUM()
Value Char P_CTR()
Value Char P_STG()
Local Integer DEM_OK
DEM_OK = 0
If P_COD <> ""
  Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=P_REFNUM & [F:DML]CTRNUM=P_CTR & [F:DEM]CODCSI=P_COD & [F:DEM]STG=P_STG & [F:DEM]ORIDEM=2
  If rowcount([F:DM_])<>0 Then : # on regarde si la demande existe déjà
    DEM_OK=1
  Endif
Endif
End DEM_OK

#**
#* Test s'il existe pour la compétence une compétence salarié parcours
#* SEGAY
#* @param  P_CPE  : compétence
#* @param  P_REFNUM  : matricule
#* @param  P_DAT    : date
#*!
Funprog CPE_CSI_EXIST(P_CPE,P_REFNUM,P_DAT)
Value Char P_CPE()
Value Char P_REFNUM()
Value Date P_DAT
Local Integer DEM_OK
CPE_OK = 0
If P_DAT <> [0/0/0]
  Filter [CPE] Where [CPE]REFNUM=P_REFNUM & [CPE]CPC=P_CPE & [CPE]CPCDAT=P_DAT & [CPE]ORICPC=6 # ML 2402 Parcours
Else
  Filter [CPE] Where [CPE]REFNUM=P_REFNUM & [CPE]CPC=P_CPE & [CPE]ORICPC=6 # ML 2402 Parcours
Endif
If rowcount([F:CPE])<>0 Then : # on regarde la compétence salarié existe
  CPE_OK=1
Endif
Filter [CPE]
End CPE_OK
# Maj du flag indiquant si on doit mettre à jour CPE
#**
#* Test de maj de la compétence acquise salarié type parcours CPE
#* SEGAY
#* @param  P_REFNUM  : matricule
#* @param  P_CPE     : compétence
#* @param  P_DAT     : date
#* @param  P_LEV     : niveau
#*!
Funprog ISMAJCPE(P_REFNUM,P_CPE,P_DAT,P_LEV)
Value Char P_REFNUM()
Value Char P_CPE()
Value Date P_DAT
Value Char P_LEV()
Local Integer LMAJCPE
LMAJCPE = 1
If P_DAT <> [0/0/0]
  Filter [CPE] Where [CPE]REFNUM=P_REFNUM & [CPE]CPCDAT=P_DAT & [CPE]CPC=P_CPE
#& & [CPE]ORICPC = 6 # ML 2402 Parcours
  If rowcount([CPE]) = 0
   LMAJCPE = 2
  Else
    Read [CPE]CPE1 Last
    If !fstat
      If P_LEV <> "" & [CPE]LEVCPC <> P_LEV
        LMAJCPE = 2
      Endif
    Endif
  Endif
  Filter [CPE]
Endif
End LMAJCPE

Funprog NB_CPC_SAL
Local Integer NB_CPC
NB_CPC = 0
For [CPE]CPE1(2) Where [F:CPE]REFNUM=[M]REFNUM & [F:CPE]CPCDAT<>[0/0/0]
 # CPE1 * REFNUM+CPC+CPCDAT
 NB_CPC+=1
Next
End NB_CPC
#**
#* Alimentation des champs désignation parcours type
#* SEGAY
#* @param  P_TCS  : parcours type
#*!
Subprog GET_TYPCOURSE(P_TCS)
Value Char P_TCS
Local Char    WDESAXX
Read [CSI]CSI0=P_TCS
Call LECTEXTRA(WDESAXX,"TYPCOURSE","DESAXX",P_TCS,"") From ATEXTRA
If WDESAXX<>""
  [M:CSI0]DESTCS = WDESAXX
  Affzo [M:CSI0]DESTCS
Endif
End
#####################################################################################
# JML 28/07/10 LOT P02 Separation of required skills et validate skills, required skills don't have any date
#**
#* Alimentation des champs des compétences requises CPC
#* Venants du poste et emploi type
#* SEGAY
#* @param  PNUMLIG  : ligne
#* @param  PPOT  : poste type
#* @param  PJOBPOT  : emploi type
#*!
Subprog REMTAB_CPC(PNUMLIG,PPOT,PJOBPOT)
#################################################################################
# JML 13/09/10 CG Always read from POSTE or JOBTYP
# On charge toutes les compétences, avec leurs derniers niveaux
Variable Shortint PNUMLIG
Value Char PPOT()
Value Char PJOBPOT()
If !func IS_CAR
  End
Endif
Call LECTURE("POT",PPOT,"") From CONTOBJ
If PPOT<>"" & [F:POT]JOBPOT=PJOBPOT
  For J=0 To dim([F:POT]CPC)-1
   If [F:POT]CPC(J)="" : Break : Endif
   If !find([F:POT]CPC(J),[M:CSI4]CPC)
&     & (dim(GCURLEG)<0 | (func SUBJOT.CHECKLEG_CPC([F:POT]CPC(J),GCURLEG))) # SEGAY 25/10/12 US 930 81085
     If PNUMLIG>=dim([M:CSI4]CPC)
       # Le nombre de compétences requises est supérieur à
      Call ERREUR( mess(158,10717,1)-num$(dim([M:CSI4]CPC))) From GESECRAN
      Break
     Endif

     PNUMLIG+=1
     [M:CSI4]CPC(PNUMLIG-1)    = [F:POT]CPC(J)
     [M:CSI4]LEVCPC(PNUMLIG-1) = [F:POT]NIV(J)
     [M:CSI4]LEVREF(PNUMLIG-1) = func SUBECP.CPC_LEVREF([F:POT]CPC(J),[F:POT]NIV(J))
     If [F:POT]ORI(J)<>4 & [F:POT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compétence ou manuelle
      [M:CSI4]ORICPC(PNUMLIG-1) = [F:POT]ORI(J)
     Else
      # Si =4 ML 2400 Groupe de compétence
      [M:CSI4]ORICPC(PNUMLIG-1) = 6 : # ML 2400 Poste
     Endif
     [M:CSI4]FLGGPEC(PNUMLIG-1) = 2
     Call REMLIG_CPC2(PNUMLIG)
   Endif
  Next J
Elsif PJOBPOT<>""
  Call LECTURE("JOT",PJOBPOT,"") From CONTOBJ
  For J=0 To dim([F:JOT]CPC)-1
   If [F:JOT]CPC(J)="" : Break : Endif
   If !find([F:JOT]CPC(J),[M:CSI4]CPC)
&     & (dim(GCURLEG)<0 | (func SUBJOT.CHECKLEG_CPC([F:JOT]CPC(J),GCURLEG))) # SEGAY 25/10/12 US 930 81085
     If PNUMLIG>=dim([M:CSI4]CPC)
      #Tableau des compétences plein
      Call ERREUR(mess(158,10717,1)-num$(dim([M:CSI4]CPC))) From GESECRAN
      Break
     Endif

     PNUMLIG+=1
     [M:CSI4]CPC(PNUMLIG-1)    = [F:JOT]CPC(J)
     [M:CSI4]LEVCPC(PNUMLIG-1) = [F:JOT]NIV(J)
     [M:CSI4]LEVREF(PNUMLIG-1) = func SUBECP.CPC_LEVREF([F:JOT]CPC(J),[F:JOT]NIV(J))
     If [F:JOT]ORI(J)<>4 & [F:JOT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compétence ou manuelle
      [M:CSI4]ORICPC(PNUMLIG-1) = [F:JOT]ORI(J)
     Else
      # Si =4 ML 2400 Groupe de compétence
      [M:CSI4]ORICPC(PNUMLIG-1) = 5 : # ML 2400 Emploi type
     Endif
     [M:CSI4]FLGGPEC(PNUMLIG-1) = 2
     Call REMLIG_CPC2(PNUMLIG)
   Endif
  Next J
Endif
# FIN JML 13/09/10 CG Always read from POSTE or JOBTYP
#################################################################################
End

#**
#* Alimentation des champs date, flag modification, Ancienne valeur des compétences requises CPC
#* Chargement graphique des compétences requises CPC
#* SEGAY
#* @param  PNUMLIG  : ligne
#*!
Subprog REMLIG_CPC2(PNUMLIG)
Value Shortint PNUMLIG
If !func IS_CAR
  End
Endif
[M:CSI4]CPCDAT(PNUMLIG-1) = [0/0/0]
[M:CSI4]FLGMOD(PNUMLIG-1) = 1
[M:CSI4]FLGOLD(PNUMLIG-1) = 2
Call REMLIG_CPCGRA(PNUMLIG)
# JML 10/09/10 CG Tunnel Echelle
Call LECTURE("CPC",[M:CSI4]CPC(PNUMLIG-1),"") From CONTOBJ
[M:CSI4]CODSCACPC(PNUMLIG-1) = [F:CPC]CODSCA
End
#**
#* Chargement graphique des compétences requises CPC
#* SEGAY
#* @param  PNUMLIG  : ligne
#*!
Subprog REMLIG_CPCGRA(PNUMLIG)
Value Shortint PNUMLIG
If !func IS_CAR
  End
Endif
# Now some graphicals, required
If !find([M:CSI4]CPC(PNUMLIG-1),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
 If [M:CSI4]NBRGRA>=dim([M:CSI4]CPCGRA)
  #Tableau des compétences plein
     # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    End
 Endif
 [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPC(PNUMLIG-1)
 [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(PNUMLIG-1)
 [M:CSI4]NBRGRA += 1
Endif
End
#**
#* Chargement graphique des compétences requises CPC
#* SEGAY
#*!
Subprog REMTAB_CPCGRA
Local Shortint PNUMLIG
If !func IS_CAR
  End
Endif
# Now some graphicals, required
For PNUMLIG = 1 To [M:CSI4]NBRCPC
  Call REMLIG_CPCGRA(PNUMLIG)
Next
End
#**
#* Chargement des compétences acquises CIC GPEC
#* SEGAY
#* @param  PNUMLIG  : ligne
#*!
Subprog REMLIG_CICREQ_GPEC(PNUMLIG)
Variable Shortint PNUMLIG
If !func IS_CAR
  End
Endif
Filter [CIC] Where COD=[M:CSI0]COD & CPCDAT=[0/0/0] & FLGGPEC = 2 & ORICPC<>len(mess(0,10937,1)) Order By COD Asc; CPC Asc; CPCDAT Desc
For [CIC]
  If !find([F:CIC]CPC,[M:CSI4]CPC)
    PNUMLIG+=1
    If PNUMLIG > dim([M:CSI4]CPC)
      # Le nombre de compétences requises est supérieur à
      GMESSAGE = mess(158,10717,1)-num$(dim([M:CSI4]CPC))
      GERR = 1
      Break
    Endif
    # Watchout here, don't make a 'transclass' !
    [M:CSI4]CPC(PNUMLIG-1)    = [F:CIC]CPC
    [M:CSI4]LEVCPC(PNUMLIG-1) = [F:CIC]LEVCPC
    If [F:CIC]LEVREFVAL<>0
     [M:CSI4]LEVREF(PNUMLIG-1) = [F:CIC]LEVREFVAL
    Else
     [M:CSI4]LEVREF(PNUMLIG-1) = func SUBECP.CPC_LEVREF([F:CIC]CPC,[F:CIC]LEVCPC)
    Endif
    [M:CSI4]CPCDAT(PNUMLIG-1) = [F:CIC]CPCDAT
    [M:CSI4]ORICPC(PNUMLIG-1) = [F:CIC]ORICPC
    [M:CSI4]FLGMOD(PNUMLIG-1) = 1
    [M:CSI4]FLGOLD(PNUMLIG-1) = 2
    [M:CSI4]FLGGPEC(PNUMLIG-1) = [F:CIC]FLGGPEC

    # Now some graphicals, Learned
    L_IJ = find([F:CIC]CPC,[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
    If L_IJ
     [M:CSI4]REQUIS(L_IJ-1)   = [M:CSI4]LEVREF(PNUMLIG-1)
    Else
     [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [F:CIC]CPC
     [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(PNUMLIG-1)
     [M:CSI4]NBRGRA += 1
    Endif
    Call LECTURE("CPC",[F:CIC]CPC,"") From CONTOBJ
    [M:CSI4]CODSCACPC(PNUMLIG-1) = [F:CPC]CODSCA
  Endif
Next : # [CIC]
Filter [CIC]
End
#**
#* Chargement des compétences acquises CIC
#* SEGAY
#* @param  PNUMLIG  : ligne
#*!
Subprog REMLIG_CICREQ(PNUMLIG)
Variable Shortint PNUMLIG
If !func IS_CAR
  End
Endif
Filter [CIC] Where COD=[M:CSI0]COD & CPCDAT=[0/0/0]& FLGGPEC = 1 & ORICPC=len(mess(0,10937,1)) Order By COD Asc; CPC Asc; CPCDAT Desc
For [CIC]
  If !find([F:CIC]CPC,[M:CSI4]CPC)
    PNUMLIG+=1
    If PNUMLIG > dim([M:CSI4]CPC)
      # Le nombre de compétences requises est supérieur à
      GMESSAGE = mess(158,10717,1)-num$(dim([M:CSI4]CPC))
      GERR = 1
      Break
    Endif
    # Watchout here, don't make a 'transclass' !
    [M:CSI4]CPC(PNUMLIG-1)    = [F:CIC]CPC
    [M:CSI4]LEVCPC(PNUMLIG-1) = [F:CIC]LEVCPC
    If [F:CIC]LEVREFVAL<>0
     [M:CSI4]LEVREF(PNUMLIG-1) = [F:CIC]LEVREFVAL
    Else
     [M:CSI4]LEVREF(PNUMLIG-1) = func SUBECP.CPC_LEVREF([F:CIC]CPC,[F:CIC]LEVCPC)
    Endif

    [M:CSI4]CPCDAT(PNUMLIG-1) = [F:CIC]CPCDAT
    [M:CSI4]ORICPC(PNUMLIG-1) = [F:CIC]ORICPC
    [M:CSI4]FLGMOD(PNUMLIG-1) = 1
    [M:CSI4]FLGOLD(PNUMLIG-1) = 2
    [M:CSI4]FLGGPEC(PNUMLIG-1) = [F:CIC]FLGGPEC

    # Now some graphicals, Learned
    L_IJ = find([F:CIC]CPC,[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
    If L_IJ
     [M:CSI4]REQUIS(L_IJ-1)   = [M:CSI4]LEVREF(PNUMLIG-1)
    Else
     [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [F:CIC]CPC
     [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(PNUMLIG-1)
     [M:CSI4]NBRGRA += 1
    Endif
    Call LECTURE("CPC",[F:CIC]CPC,"") From CONTOBJ
    [M:CSI4]CODSCACPC(PNUMLIG-1) = [F:CPC]CODSCA
  Endif
Next : # [CIC]
Filter [CIC]
End

#**
#* Chargement des compétences du poste type
#* SEGAY
#* @param  L_COD  : code parcours type ou emploi type
#*!
Subprog INIT_CPC(L_COD, L_TYP)
Value    Char    L_COD()      : # Code for POSTE or JOBTYP
Value    Integer L_TYP        : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
Local Integer I, L_IJ
If !func IS_CAR
  End
Endif

If L_TYP=1 or L_TYP=2
  # Suppression lignes venant de POSTE or JOBTYP du tableau compétence requise
  For I=[M:CSI4]NBRCPC-1 To 0 Step -1
    If [M:CSI4]FLGGPEC(I)=2 & [M:CSI4]FLGOLD(I)=2 & !find([M:CSI4]ORICPC(I),len(mess(0,10937,1))) Then
#      If !find([M:CSI4]CPC(I),[M:CSI4]CPCDLT(0..[M:CSI4]NBRDLT-1)) | find([M:CSI4]CPCDAT(I),[M:CSI4]DATDLT(0..[M:CSI4]NBRDLT-1))
      If !find([M:CSI4]CPC(I),[M:CSI4]CPCDLT(0..[M:CSI4]NBRDLT-1))
        If [M:CSI4]NBRDLT>=dim([M:CSI4]CPCDLT)
        # Veuillez enregistrer les modifications avant de continuer.
          mkstat=2
          GMESSAGE = mess(558,9900,1)
          Call ERREUR(GMESSAGE) From GESECRAN
          GMESSAGE = ""
          End
        Endif
        [M:CSI4]CPCDLT([M:CSI4]NBRDLT) = [M:CSI4]CPC(I)
        [M:CSI4]DATDLT([M:CSI4]NBRDLT) = [M:CSI4]CPCDAT(I)
        [M:CSI4]NBRDLT +=1
      Endif
      Dela I, 1 [M:CSI4]NBRCPC
      [M:CSI4]NBRCPC -= 1
    Endif
  Next
  # Suppression du tableau graphique
  For L_IJ=[M:CSI4]NBRGRA-1 To 0 Step -1
    Dela L_IJ,1 [M:CSI4]NBRGRA
    [M:CSI4]NBRGRA -= 1
  Next
  # ajout lignes venant de POSTE or JOBTYP du tableau compétence requise + graphique
  If L_TYP=1
    Call REMTAB_CPC([M:CSI4]NBRCPC,L_COD,[M:CSI1]JOBPOT)
  Else
    Call REMTAB_CPC([M:CSI4]NBRCPC,[M:CSI1]POT,L_COD)
  Endif
  # ajout graphique des lignes manuelles du tableau compétence requise
  For I=0 To [M:CSI4]NBRCPC-1
    If [M:CSI4]CPCDAT(I)=[0/0/0] & [M:CSI4]FLGGPEC(I)=1
      # Now some graphicals, Learned
      L_IJ = find([M:CSI4]CPC(I),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
      If L_IJ
       [M:CSI4]REQUIS(L_IJ-1)   = [M:CSI4]LEVREF(I)
      Else
       [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPC(I)
       [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(I)
       [M:CSI4]NBRGRA += 1
      Endif
    Endif
  Next
  Sorta [M:CSI4]NBRCPC [M:CSI4]NBRCPC Order By [M:CSI4]CPC([S]indice)
 # ajout graphique des lignes du tableau compétence acquise
  For I=0 To [M:CSI4]NBRVAL-1
    # Now some graphicals, Learned
    L_IJ = find([M:CSI4]CPCVAL(I),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
    If L_IJ
     [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFVAL(I)
    Else
     [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPCVAL(I)
     [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFVAL(I)
     [M:CSI4]NBRGRA += 1
    Endif
  Next
  Sorta [M:CSI4]NBRGRA [M:CSI4]NBRGRA Order By [M:CSI4]CPCGRA([S]indice)
  Affzo [M:CSI4]5,25 : # Validées
Endif
End

#**
#* Récupération donnée du parcours type
#* SEGAY
#* Chargement des champs du parcours type
#* Chargement des compétences du poste type
#* Chargement des stages du parcours type
#* @param  VALEUR  : code parcours type
#*!
Subprog GET_TCS(VALEUR)
Value Char VALEUR()
Local Integer SAVNOLIGN, I, SAVSTATUS

#Chargement des champs du parcours type
Call LECTURE("TCS",VALEUR,"") From CONTOBJ
If VALEUR <>""
  [M:CSI1]POT=[F:TCS]POT
  [M:CSI1]JOBPOT=[F:TCS]JOBPOT
  [M:CSI1]DESJOB=[F:TCS]DESJOB
  [M:CSI1]DUREE=[F:TCS]DUREE
  [M:CSI1]UOMTIM=[F:TCS]UOMTIM
  Affzo[M:CSI1]
  #Chargement des compétences du poste type
  If func IS_CAR
    Call INIT_CPC([M:CSI1]POT,1) From SUBCSI
  Endif
Endif
#Chargement des stages du parcours type
For I=0 To [M]NBLIG-1
  Dela I, 1 [M]NBLIG
  [M]NBLIG -= 1
Next

nolign = 1
Filter [F:TCL] Where COD=VALEUR Order By Key TCL0
For [F:TCL]
 If (func AV_NO_DATE_STG ([F:TCL]STG,[M:CSI1]STRDAT,[M:CSI1]ENDDAT,1)) <> 1 Then
   [M:CSI2]STG(nolign-1)=[F:TCL]STG
   [M:CSI2]ORDRE(nolign-1)=[F:TCL]ORDRE
   [M:CSI2]FLGOBG(nolign-1)=[F:TCL]FLGOBG
   [M:CSI2]STA(nolign-1)=1
   [M:CSI2]CILLIG(nolign-1) = 0
   [M:CSI2]CREFLG(nolign-1) = 0
   Call CHARGE_INFO_STG(nolign-1,[F:TCL]STG)
   #SEGAY 02/02/11 BUG 71254
   Call CHARGE_INI_STG(nolign-1,[F:TCL]STG)

   [M:CSI1]NBRHOUMAX += [F:STG]NBRHOUIPT
   SAVSTATUS=status
   status=1
   Call LINNUM("CILLIG") From TABLEAUX
   status=SAVSTATUS
   nolign+=1
 Endif
Next
Filter [F:TCL]
[M:CSI2]NBLIG=nolign-1
Call AFF_AFFTOT_PREV
Affzo[M:CSI2]
Affzo [M:CSI1]NBRHOUMAX
End

# FQ94656
$AFF_NAMSRN
[M:CSI1]NAM=[F:ID]NAM
[M:CSI1]SRN=[F:ID]SRN
Affzo [CSI1]NAM,SRN
Return

