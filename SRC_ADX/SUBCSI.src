Return

#**
#* Alimentation champ du tuteur
#* SEGAY
#* @param  P_REFNUM  : code salarié
#*!
Funprog GET_TUTEUR(P_REFNUM)
Value Char P_REFNUM()
Local Integer WOK
WOK = 1
#SEGAY 07/03/11 bug 72143
If P_REFNUM <>""
  If func READ_EMP(P_REFNUM) <> 0 Then
    WOK = 0 : End WOK
  Endif
  Gosub AFF_NAMSRN_T : # FQ94656
Else
  [M:CSI1]NAMT=""
  [M:CSI1]SRNT=""
  WOK = 0
  Affzo [CSI1]NAMT,SRNT
Endif
End WOK

#**#####################################################################################
#* Fonction qui teste l'égalité entre le salarié et le tuteur
#* #* SEGAY
#* @since 17/12/10
#* @param VALEUR : salarié/tuteur
#* @param PTUT : 0 = salarié, 1 = tuteur
#*!
Funprog TEST_REFNUMT(PREFNUM ,PTUT)
Value Char    PREFNUM()
Value Integer PTUT
Local Integer WOK
WOK = 1
If PTUT = 1
  If PREFNUM = [M:CSI1]REFNUM
     GMESSAGE = mess(186,10717,1) : # Le salarié ne peut-être son tuteur
     GERR = 1 : WOK = 0
  Endif
Else
  If PREFNUM = [M:CSI1]REFNUMT
     GMESSAGE = mess(186,10717,1) : # Le salarié ne peut-être son tuteur
     GERR = 1 : WOK = 0
  Endif
Endif
End WOK

