#**#####################################################################################
#* Action sur ecran CSI4 EVALUATION COMPETENCES REQUISES
#* SEGAY
#*
#*!

#**
#* Controle variable bas de tableau compétences requises
#* Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
#* Stocke dans le tableau invisible, les compétences supprimées
#* SEGAY
#*!
Subprog C_NBRCPC
Local Integer I,WCPT_CPT
Local Integer NOL #  SEGAY 05/06/12 - FQ82661
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle)
#40643
#If status=65 & [M:CSI4]FLGOLD(nolign-1)=2 & [M:CSI4]ORICPC(nolign-1)<>1 & [M:CSI4]ORICPC(nolign-1)<>5
If status=65 & [M:CSI4]FLGOLD(nolign-1)=2 & !find([M:CSI4]ORICPC(nolign-1),len(mess(0,10937,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
 GMESSAGE = mess(19,10720,1)
 mkstat = 2 : End
Endif
# On stocke dans le tableau invisible, les compétences supprimées
#40643
#If status=65 & [M:CSI4]FLGOLD(nolign-1)=2 & ([M:CSI4]ORICPC(nolign-1)=1 | [M:CSI4]ORICPC(nolign-1)=5)
If status=65 & [M:CSI4]FLGOLD(nolign-1)=2 & find([M:CSI4]ORICPC(nolign-1),len(mess(0,10937,1)))
 If [M:CSI4]NBRDLT>=dim([M:CSI4]CPCDLT)
  # Veuillez enregistrer les modifications avant de continuer.
  GMESSAGE = mess(558,9900,1)
  mkstat=2 : End
 Endif
 [M:CSI4]CPCDLT([M:CSI4]NBRDLT) = [M:CSI4]CPC(nolign-1)
 [M:CSI4]DATDLT([M:CSI4]NBRDLT) = [M:CSI4]CPCDAT(nolign-1)
 [M:CSI4]NBRDLT +=1
Endif
#Ajout compétences
If status=71 | status=82
  If[M:CSI4]CPC(nolign-1) = ""
  #Comptage des compétences manuelles ou rajoutées
   Raz WCPT_CPT
   For I=0 To [M:CSI4]  NBRCPC-1
      If [M:CSI4]ORICPC(I)=len(mess(0,10937,1))or [M:CSI4]FLGOLD(I)<>2
        WCPT_CPT+=1
      Endif
   Next
   If WCPT_CPT >= dim([M:CSI4]CPC)
    # Le nombre de compétences requises est supérieur à
     GMESSAGE = mess(158,10717,1)-num$(dim([M:CSI4]CPC))
     mkstat=2 : End
   Endif
  Endif
Endif
#  SEGAY 05/06/12 - FQ82661 - Annulation multiple
If status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  If[M:CSI4]FLGOLD(NOL)=2 & !find([M:CSI4]ORICPC(NOL),len(mess(0,2400,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
   GMESSAGE = mess(19,10720,1)
   mkstat = 2 : Break
  Elsif  [M:CSI4]FLGOLD(NOL)=2 & find([M:CSI4]ORICPC(NOL),len(mess(0,2400,1)))
 # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
   If [M:CSI4]NBRDLT>=dim([M:CSI4]CPCDLT)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    mkstat=2 : Break
   Endif
   [M:CSI4]CPCDLT([M:CSI4]NBRDLT) = [M:CSI4]CPC(NOL)
   [M:CSI4]DATDLT([M:CSI4]NBRDLT) = [M:CSI4]CPCDAT(NOL)
   [M:CSI4]NBRDLT +=1
  Endif
 Next
Endif

End

Subprog IB_NBRCPC
If !func IS_CAR
  Raz GBOUT1,GBOUT2,GBOUT3
Endif
End

#**
#* Chargement des compétences du poste type
#* SEGAY
#* @since 03/07/10
#*!
Subprog B3_NBRCPC
#Chargement des compétences du poste type
If func IS_CAR
  Call INIT_CPC([M:CSI1]POT,1) From SUBCSI
  If mkstat <> 2 & [M:CSI4]NBRCPC
    mkstat = 4            : # Pour dégriser le bouton Enregistrer
  Endif
Endif

End

#**
#* Avant saisie compétence requise
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : compétence
#*!
Subprog AS_CPC(VALEUR)
Variable Char    VALEUR()
# Modification de la compétence interdite si c'est une compétence antérieure
If [M:CSI4]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
End
#**
#* Après modification compétence requise
#* Controle d'unicité
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : compétence
#*!
Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M]CPC) From OBJDIV
If mkstat : End : Endif

# Afficher le dernier niveau acquis pour cette compétence
#Filter [CIC] Where [CIC]COD=[M:CSI0]COD & [CIC]CPC=VALEUR
#Read [CIC]CIC1 Last
#Filter [CIC]
#If !fstat
# [M:CSI4]LEVCPC(nolign-1) = [F:CIC]LEVCPC
#Else
# Call BASNIVCPC(VALEUR,[M:CSI4]LEVCPC(nolign-1)) From SUBCPC
#Endif
End

#**
#* Avant saisie niveau compétence requise
#* SEGAY
#* Modification de la compétence interdite si c'est une compétence antérieure
#* @since 03/07/10
#* @param VALEUR : niveau compétence
#*!
Subprog AS_LEVCPC(VALEUR)
Variable Char    VALEUR()
# Modification de la compétence interdite si c'est une compétence antérieure et # manuelle
If [M:CSI4]FLGOLD(nolign-1)=2 & !find([M:CSI4]ORICPC(nolign-1),len(mess(0,10937,1)))
 mkstat=2 : End
Endif
Local    Integer I,J
If VALEUR=""
 Call LECTURE("CPC",[M:CSI4]CPC(nolign-1),"") From CONTOBJ
 If !fstat
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  If !fstat
   I = find("",[F:HRSCA]LEV)
   J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
   If J : VALEUR = [F:HRSCA]LEV(J-1) : Endif
  Endif
 Endif
Endif
End
#**
#* Après modification niveau compétence requise
#* SEGAY
#* Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
#* @since 03/07/10
#* @param VALEUR : niveau compétence
#*!
Subprog AM_LEVCPC(VALEUR)
Variable Char    VALEUR()
# Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
# JML 13/09/10 ML passe de 2402 à 2400
If [M:CSI4]ORICPC(nolign-1)<>1 | [M:CSI4]ORICPC(nolign-1)<>len(mess(0,10937,1))
 [M:CSI4]ORICPC(nolign-1) = len(mess(0,10937,1))
Endif
[M:CSI4]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([M:CSI4]CPC(nolign-1),VALEUR)
# SEGAY 12/05/11 73807 MAJ requis du graphique
# Now some graphicals, Lear ned
L_IJ = find([M:CSI4]CPC(nolign-1),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
If L_IJ
 [M:CSI4]REQUIS(L_IJ-1)   = [M:CSI4]LEVREF(nolign-1)
Else
 # DBA 30/09 : Add the condition to make a test about 'full table'
 If [M:CSI4]NBRGRA<dim([M:CSI4]CPCGRA)
  [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPC(nolign-1)
  [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(nolign-1)
  [M:CSI4]NBRGRA += 1
 Else
  # Tableau plein
  Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
  GMESSAGE = ""
 Endif
Endif
Affzo [CSI4]25  : # Le tableau graphique...
# END 73807 MAJ requis du graphique
End

#**
#* Avant saisie date d'acquisition
#* SEGAY
#* Modification de la date interdite si c'est une compétence antérieure
#* @since 03/07/10
#* @param VALEUR : date d'acquisition
#*!
Subprog AS_CPCDAT(VALEUR)
Variable Date    VALEUR
# Modification de la date interdite si c'est une compétence antérieure
If [M:CSI4]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] : VALEUR = datesyst : Endif
End
#**
#* Avant saisie origine compétence requise
#* SEGAY
#* Modification de l'origine de la compétence interdite si
#* la compétence antérieure n'est ni initiale ni manuelle
#* @since 03/07/10
#* @param VALEUR : origine compétence requise
#*!
Subprog AS_ORICPC(VALEUR)
Variable Integer    VALEUR()
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est ni initiale ni manuelle
If [M:CSI4]FLGOLD(nolign-1)=2 & VALEUR<>len(mess(0,10937,1))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(1) = 1 : # Dossier
GMENLOC(2) = 1 : # Famille
GMENLOC(3) = 1 : # Metier
GMENLOC(4) = 1 : # Groupe de compétences
GMENLOC(5) = 1 : # Emploi type
GMENLOC(6) = 1 : # Poste
End
#**
#* Après modification ligne compétence requise
#* SEGAY
#* Alimentation tableau graphique
#* @since 03/07/10
#*!
Subprog APRES_NBRCPC
For I=0 To [M]NBRCPC-1
  # Now some graphicals, Learned
  L_IJ = find([M:CSI4]CPC(I),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
  If L_IJ
   [M:CSI4]REQUIS(L_IJ-1)   = [M:CSI4]LEVREF(I)
  Else
   [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPC(I)
   [M:CSI4]REQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREF(I)
   [M:CSI4]NBRGRA += 1
  Endif
Next
Affzo [M:CSI4]25
End



######################################################################################

#**#####################################################################################
#* Action sur ecran CSI4 EVALUATION COMPETENCES VALIDEES
#* SEGAY
#*
#*
#*
#**#####################################################################################

Subprog IB_NBRVAL
#------------------------------------------------------#
# Initialisation bouton                                #
# B1 : init compétences                                #
# B2 : Echelle de niveaux                              #
# B3 : Compétence                                      #
#------------------------------------------------------#
If !func IS_CAR
  Raz GBOUT1,GBOUT2,GBOUT3
Endif
If find(2,[M:CSI4]FLGCPE(0..[M:CSI4]NBRVAL-1))
  Raz GBOUT1
Endif

End
#**
#* Controle variable bas de tableau compétences acquises
#* Stocke dans le tableau invisible, les compétences supprimées
#*!
Subprog C_NBRVAL
Local Integer NOL #  SEGAY 05/06/12 - FQ82661
# JML 13/09/10 CG now we can delete
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle)
If status=65 & [M:CSI4]FLGOLDVAL(nolign-1)=2 & !find([M:CSI4]ORICPCVAL(nolign-1),1,len(mess(0,10939,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
 GMESSAGE = mess(19,10720,1)
 mkstat = 2 : End
Endif
If status=65 & [M:CSI4]FLGOLDVAL(nolign-1)=2
  If [M:CSI4]FLGCPE(nolign-1) = 2
    # Il est interdit de supprimer des compétences ayant mis à jour des compétences salariés
    GMESSAGE = mess(170,10717,1)
    mkstat = 2 : End
  Endif
Endif
# On stocke dans le tableau invisible, les compétences supprimées (non initiale et non manuelle )
If status=65 & [M:CSI4]FLGOLDVAL(nolign-1)=2 & find([M:CSI4]ORICPCVAL(nolign-1),1,len(mess(0,10939,1)))
 # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
 If !find([M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCDLTVAL(0..[M:CSI4]NBRDLTVAL-1))

   If [M:CSI4]NBRDLTVAL>=dim([M:CSI4]CPCDLTVAL)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    mkstat=2 : End
   Endif
   [M:CSI4]CPCDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]CPCVAL(nolign-1)
   # Date sauvegardée(old), car la date a pu être modifiée
   [M:CSI4]DATDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]OLDDATVAL(nolign-1)
   [M:CSI4]NBRDLTVAL +=1
   Endif
Endif
#  SEGAY 05/06/12 - FQ82661 - Annulation multiple
If status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  If [M:CSI4]FLGOLDVAL(NOL)=2 & [M:CSI4]FLGOLDVAL(NOL)=2 & !find([M:CSI4]ORICPCVAL(NOL),1,len(mess(0,2402,1)))
      # Il est interdit de supprimer des compétences ayant mis à jour des compétences salariés
      GMESSAGE = mess(19,10720,1)
      mkstat = 2 : Break
  Elsif [M:CSI4]FLGOLDVAL(NOL)=2 &[M:CSI4]FLGCPE(NOL) = 2
    # Il est interdit de supprimer des compétences ayant mis à jour des compétences salariés
    GMESSAGE = mess(170,10717,1)
    mkstat = 2 : Break
  Elsif [M:CSI4]FLGOLDVAL(NOL)=2 & find([M:CSI4]ORICPCVAL(NOL),1,len(mess(0,2402,1)))
 # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
   If !find([M:CSI4]CPCVAL(NOL),[M:CSI4]CPCDLTVAL(0..[M:CSI4]NBRDLTVAL-1))
     If [M:CSI4]NBRDLTVAL>=dim([M:CSI4]CPCDLTVAL)
      # Veuillez enregistrer les modifications avant de continuer.
      GMESSAGE = mess(558,9900,1)
      mkstat=2 : Break
     Endif
     [M:CSI4]CPCDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]CPCVAL(NOL)
     # Date sauvegardée(old), car la date a pu être modifiée
     [M:CSI4]DATDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]OLDDATVAL(NOL)
     [M:CSI4]NBRDLTVAL +=1
   Endif
  Endif
 Next
Endif
End
## JML 13/09/10 CG Init like 'Compétences validées dans Carrière'
Subprog B1_NBRVAL
Local Integer L_IJ
For L_IJ=0 To [M:CSI4]NBRVAL-1
 If [M:CSI4]FLGOLDVAL(L_IJ)=2
   # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
   If !find([M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCDLTVAL(0..[M:CSI4]NBRDLTVAL-1))
    If [M:CSI4]NBRDLTVAL>=dim([M:CSI4]CPCDLTVAL)
     # Veuillez enregistrer les modifications avant de continuer.
     GMESSAGE = mess(558,9900,1)
     GERR = 1
     mkstat=2 : Break
    Endif
    [M:CSI4]CPCDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]CPCVAL(L_IJ)
    # Date sauvegardée(old), car la date a pu être modifiée
    [M:CSI4]DATDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]OLDDATVAL(L_IJ)
    [M:CSI4]NBRDLTVAL +=1
   Endif
 Endif
Next L_IJ
If mkstat
 Call ERREUR(GMESSAGE) From GESECRAN
 GMESSAGE = ""
 End
Endif
Effzo [CSI4]15 : # Validées
For L_IJ=[M:CSI4]NBRGRA-1 To 0 Step -1
 If [M:CSI4]REQUIS(L_IJ)<>0
  [M:CSI4]ACQUIS(L_IJ) = 0
 Else
  If !find([M:CSI4]CPCGRA(L_IJ),[M:CSI4]CPC(0..[M:CSI4]NBRCPC-1))
    Dela L_IJ,1 [M:CSI4]NBRGRA
    [M:CSI4]NBRGRA -= 1
  Endif
 Endif
Next L_IJ
nolign=0
# Chargement des compétences validées ([F:CPE]CPCDAT<>[0/0/0]) du salarié .
For [CPE]CPE1(2) Where [F:CPE]REFNUM=[M]REFNUM & [F:CPE]CPCDAT<>[0/0/0]
 # CPE1 * REFNUM+CPC+CPCDAT
# SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
 Call LECTURE("CPC",[F:CPE]CPC,"") From CONTOBJ
 If dim(GCURLEG)< 0 | [F:CPC]LEG="" | ([F:CPC]LEG<>"" & [F:CPC]LEG=GCURLEG) Then
# SEGAY - 24/12/10 - EXI 66105 LOT P02 - V6.1
   If nolign>=dim([M:CSI4]CPCVAL)
     # Trop de compétences à analyser
     Call ERREUR( mess(48,10720,1)-num$(dim([M:EVA2]CPCVAL))) From GESECRAN
     Break
   Endif
   nolign+=1
   For [CPE]CPE1
    # Watchout here, don't make a 'transclass' !
    [M:CSI4]CPCVAL(nolign-1)       = [F:CPE]CPC
    [M:CSI4]LEVCPCVAL(nolign-1)    = [F:CPE]LEVCPC
    [M:CSI4]LEVREFVAL(nolign-1)    = func SUBECP.CPC_LEVREF([F:CPE]CPC,[F:CPE]LEVCPC)
    [M:CSI4]LEVREFEVA(nolign-1)    = 0
    [M:CSI4]CPCDATVAL(nolign-1)    = [F:CPE]CPCDAT
    # Sauvegarde de la date si on la modifie il faut pouvoir supprimer dans CIC la compétences à l'ancienne date
    [M:CSI4]OLDDATVAL(nolign-1)    = [F:CPE]CPCDAT
    [M:CSI4]ORICPCVAL(nolign-1)    = [F:CPE]ORICPC
    [M:CSI4]FLGMODVAL(nolign-1)    = 1
    [M:CSI4]FLGOLDVAL(nolign-1)    = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
    [M:CSI4]FLGCPE(nolign-1) = 1
    mkstat = 4
    # Now some graphicals, Learned
    L_IJ = find([F:CPE]CPC,[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
    If L_IJ
     [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFVAL(nolign-1)
    Else
     # DBA 30/09 : Add the condition to make a test about 'full table'
     If [M:CSI4]NBRGRA<dim([M:CSI4]CPCGRA)
      [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [F:CPE]CPC
      [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFVAL(nolign-1)
      [M:CSI4]NBRGRA += 1
     Else
      # Tableau plein
      Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
      GMESSAGE = ""
      Break 2
     Endif
    Endif
   Next : # [CPE]CPE1
   # JML 10/09/10 CG Tunnel Echelle
   Call LECTURE("CPC",[F:CPE]CPC,"") From CONTOBJ
   [M:CSI4]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
 Endif # SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
Next : # [CPE]CPE1(2)
[M:CSI4]NBRVAL = nolign
Sorta [M]NBRVAL [M]NBRVAL Order By [M]CPCVAL([S]indice)
Sorta [M]NBRGRA [M]NBRGRA Order By [M]CPCGRA([S]indice)
Affzo [CSI4]15,25 : # Validées
If [M:CSI4]NBRVAL
 mkstat = 4            : # Pour dégriser le bouton Enregistrer
Endif
End
#**
#* Avant saisie compétence acquise
#* SEGAY
#* Modification de la compétence interdite si
#* la compétence est en modification
#* @since 03/07/10
#* @param VALEUR : compétence acquise
#*!
Subprog AS_CPCVAL(VALEUR)
Variable Char    VALEUR()
If [M:CSI4]FLGOLDVAL(nolign-1)=2
 mkstat=2 : End
Endif
End
#**
#* Avant modification compétence acquise
#* SEGAY
#* Unicité de la compétence
#* @since 03/07/10
#* @param VALEUR : compétence acquise
#*!
Subprog AM_CPCVAL(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
Call UNICITE(VALEUR,[M:CSI4]CPCVAL) From OBJDIV
If mkstat : End : Endif
Call LECTURE("CPC",VALEUR,"") From CONTOBJ
If !fstat
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
 If !fstat
  I = find("",[F:HRSCA]LEV)
  J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
  If J
   [M:CSI4]LEVCPCVAL(nolign-1) = [F:HRSCA]LEV(J-1)
   [M:CSI4]LEVREFVAL(nolign-1) = func SUBECP.CPC_LEVREF([F:CPC]COD,[F:HRSCA]LEV(J-1))
   [M:CSI4]LEVREFEVA(nolign-1) = 0
   Affzo [M:CSI4]LEVCPCVAL(nolign-1),LEVREFVAL(nolign-1),LEVREFEVA(nolign-1)
  Endif
 Endif
Endif
Gosub MOD_VAL
End

#**
#* Avant saisie niveau évalué compétence acquise
#* SEGAY
#* Modification de la compétence interdite si c'est une compétence antérieure
#* @since 03/07/10
#* @param VALEUR : niveau évalué compétence
#*!
Subprog AS_LEVCPCEVA(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
If VALEUR=""
 Call LECTURE("CPC",[M:CSI4]CPCVAL(nolign-1),"") From CONTOBJ
 If !fstat
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  If !fstat
   I = find("",[F:HRSCA]LEV)
   J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
   If J : VALEUR = [F:HRSCA]LEV(J-1) : Endif
  Endif
 Endif
Endif
End
#**
#* Après modification niveau evalué compétence acquise
#* SEGAY
#* Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
#* @since 03/07/10
#* @param VALEUR : niveau évalué compétence
#*!
Subprog AM_LEVCPCEVA(VALEUR)
Variable Char    VALEUR()
Local Integer L_IJ
# Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
If !find([M:CSI4]ORICPCVAL(nolign-1),1,len(mess(0,10939,1))) and [M:CSI4]ORICPCVAL(nolign-1)<> 6
 [M:CSI4]ORICPCVAL(nolign-1) = len(mess(0,10939,1))
Endif
[M:CSI4]LEVREFEVA(nolign-1) = func SUBECP.CPC_LEVREF([M:CSI4]CPCVAL(nolign-1),VALEUR)
#-  Lorsque le niveau d’une compétence est modifié, la date d’acquisition est modifiée automatiquement à la date du jour
[M:CSI4]CPCDATVAL(nolign-1) = datesyst
Affzo [M:CSI4]CPCDATVAL(nolign-1)
# On stocke dans le tableau invisible, des compétences supprimées puisque la date fait parti de la cle de CIC
If [M:CSI4]FLGOLDVAL(nolign-1)=2 & [M:CSI4]OLDDATVAL(nolign-1) <> [0/0/0]
 # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
 If !find([M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCDLTVAL(0..[M:CSI4]NBRDLTVAL-1))
   If [M:CSI4]NBRDLTVAL>=dim([M:CSI4]CPCDLTVAL)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GMESSAGE = ""
    mkstat=2 : End
   Endif
   [M:CSI4]CPCDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]CPCVAL(nolign-1)
   # Date sauvegardée(old), car la date a pu être modifiée
   [M:CSI4]DATDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]OLDDATVAL(nolign-1)
   [M:CSI4]NBRDLTVAL +=1
 Endif
Endif
Gosub MOD_VAL
# JML 29/09/10 CG MAJ temps réél du graphique
# Now some graphicals, Learned
L_IJ = find([M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
If L_IJ
 [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFEVA(nolign-1)
Else
 # DBA 30/09 : Add the condition to make a test about 'full table'
 If [M:CSI4]NBRGRA<dim([M:CSI4]CPCGRA)
  [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPCVAL(nolign-1)
  [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFEVA(nolign-1)
  [M:CSI4]NBRGRA += 1
 Else
  # Tableau plein
  Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
  GMESSAGE = ""
 Endif
Endif
Affzo [CSI4]25  : # Le tableau graphique...
End
#**
#* Avant saisie origine compétence acquise
#* SEGAY
#* Modification de l'origine de la compétence interdite si
#* la compétence antérieure n'est ni initiale ni manuelle
#* @since 03/07/10
#* @param VALEUR : origine compétence acquise
#*!
Subprog AS_ORICPCVAL(VALEUR)
Variable Integer VALEUR
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est pas manuelle
If [M:CSI4]FLGOLDVAL(nolign-1)=2 & !find(VALEUR,1,len(mess(0,10939,1)))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(1) = 1 : # Initial
GMENLOC(2) = 1 : # Stage
GMENLOC(3) = 1 : # Evaluation
GMENLOC(4) = 1 : # Poste
GMENLOC(5) = 1 : # Emploi type
GMENLOC(6) = 1 : # Parcours
VALEUR = len(mess(0,10939,1)) : # ML 2402 Manuel
mkstat = 2 : End
End
#**
#* Avant saisie date d'acquisition
#* SEGAY
#* Initialisation à la date système
#* @since 03/07/10
#* @param VALEUR : date d'acquisition
#*!
Subprog AS_CPCDATVAL(VALEUR)
Variable Date    VALEUR
# JML 13/09/10 CG Now it's possible to modify
# Modification de la date interdite si c'est une compétence antérieure
#If [M:CSI4]FLGOLDVAL(nolign-1)=2
# mkstat=2 : End
#Endif
If VALEUR=[0/0/0] : VALEUR = datesyst : Endif
End


#**
#* Après modification date d'acquisition
#* SEGAY
#* Test Compétence déjà saisie à la même date
#* @since 03/07/10
#* @param VALEUR : date d'acquisition
#*!
Subprog AM_CPCDATVAL(VALEUR)
Variable Date    VALEUR
Local Integer L_IJ
For L_IJ=0 To nolign-2
 If [M:CSI4]CPCVAL(L_IJ)=[M:CSI4]CPCVAL(nolign-1) & [M:CSI4]CPCDATVAL(L_IJ)=VALEUR
  # Compétence déjà saisie à la même date
  GMESSAGE = mess(20,10720,1)
  Call ERREUR(GMESSAGE) From GESECRAN
  GMESSAGE = ""
  mkstat = 2 : Break
 Endif
Next L_IJ
If mkstat=2 : End : Endif
# On stocke dans le tableau invisible, des compétences supprimées puisque la date fait parti de la cle de CIC
If [M:CSI4]FLGOLDVAL(nolign-1)=2 & [M:CSI4]OLDDATVAL(nolign-1) <> [0/0/0]
 # On teste dans le tableau invisible, des compétences supprimées à la date sauvegardée pour le pas faire plusieurs indice,puisque la date fait parti de la cle de CIC
 If !find([M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCDLTVAL(0..[M:CSI4]NBRDLTVAL-1))
   If [M:CSI4]NBRDLTVAL>=dim([M:CSI4]CPCDLTVAL)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GMESSAGE = ""
    mkstat=2 : End
   Endif
   [M:CSI4]CPCDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]CPCVAL(nolign-1)
   # Date sauvegardée(old), car la date a pu être modifiée
   [M:CSI4]DATDLTVAL([M:CSI4]NBRDLTVAL) = [M:CSI4]OLDDATVAL(nolign-1)
   [M:CSI4]NBRDLTVAL +=1
 Endif
Endif
# Modif de l'origine d'une compétence à Manuelle
Gosub MOD_VAL
End

#**
#* Après modification ligne compétence acquise
#* SEGAY
#* Alimentation tableau graphique
#* @since 03/07/10
#*!
Subprog APRES_NBRVAL
For I=0 To [M]NBRVAL-1
  # Now some graphicals, Learned
  L_IJ = find([M:CSI4]CPCVAL(I),[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
  If L_IJ
   [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFVAL(I)
  Else
   [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [M:CSI4]CPCVAL(I)
   [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFVAL(I)
   [M:CSI4]NBRGRA += 1
  Endif
Next
Affzo [M:CSI4]25
End
# SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
#**
#* Init Tunel sur Inscription
#* Tunel uniquement si FLGINS(ML464) > 2 3=Inscription 4=Réalisée
#*!
Subprog IB_NBRDEM
If [M:CSI5]FLGINS(nolign-1)< 3
 Raz GBOUT3
Else
  GBOUT3 = mess(71,10717,1) #Inscription
Endif

End


Subprog SET_CONTEXT
Local    Integer I, K, DIFF_LEG
Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5)

If [M:CSI1]CTR<>""
  Read [HRCTR]CTR0(2)=[M:CSI1]REFNUM;[M:CSI1]CTR
  If !fstat
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Else
    Read [ID]ID0=[M:CSI1]REFNUM
    If !fstat
     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
    Endif
  Endif
Else
  If [M:CSI0]TCS<>""
    Read [TCS]TCS0=[M:CSI0]TCS
    If !fstat
#      Call LECTURE("CPY",[F:TCS]CPY,"") From CONTOBJ
#      GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
      I=0 : Call CALC_GRPCPY([F:TCS]CPY, LIS_CPY, I) From TOOLSVAR
      If I>0 Then : # C'est un groupe de sociétés
        For K=0 To I-1
          Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
          GCURLEG=[F:CPY]LEG
          If GCURLEG<>"" Then Break : Endif
        Next
      Else
        Call LECTURE("CPY",[F:TCS]CPY,"") From CONTOBJ
        GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
      Endif
    Endif
  Else
  #SEGAY 26/06/12 81085 US500
#    Read [ID]ID0=[CSI1]REFNUM
#    If !fstat
#     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
#     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Else
#      GCURLEG=GLEGFIL
#    Endif
    If GREP<>"C" & ([M:CSI1]REFNUM <> "" | [M:CSI0]TCS <> "")
      GCURLEG=GLEGFIL
    Else
      GCURLEG="" : GSOCIETE=""
    Endif
  Endif
Endif
End
#**
#* Controls that the training period is in the correct leg for contract
#* 26/06/12 SEGAY 81085 US500
#* @param PLEG : LEG
#*!
Subprog CTR_LEGSTG(PLEG)
Value Char PLEG()
If [M:CSI2]NBLIG = 0
  End
Endif
For I=0 To [M:CSI2]NBLIG-1
  # Controls that the training period is in the correct leg for contract
  Raz [F:STG]
  Call LECTURE("STG",[M:CSI2]STG(I),"") From CONTOBJ
  If [F:STG]LEG <> "" & PLEG <> "" & [F:STG]LEG <> PLEG
     GMESSAGE = mess(271,10717,1)- PLEG : # La législation du stage doit être
     mkstat=2 : Break
  Endif
Next
End

