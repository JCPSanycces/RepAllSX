######################################################################################
# Gestion du masque CSI0 (Parcours individualisé de formation)
# Gestion de fiche Parcours individualisé (table COURSEI)
#
#
# Creation :
#     SEGAY - 03/09/10 - EXI 66191 LOT 1
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     SEGAY - 24/12/10 - 70247 lot P24 - V6.1
# Modification :
#     SEGAY - 02/05/11 - 73325
#         sélection matricule et contrat avec poste et emploi type + écran CSI1
#     SEGAY - 12/05/11 - 73807
#         Affichage graphique des compétences + écran CSI4
#     SEGAY - 07/09/11 - 75372
#         UOMTIM= jour/semaine/mois/année ML 313
#     SEGAY - 05/06/12 - BUG 82661 - V6.3
#            Dans l'onglet Compétences, quand on supprime des lignes de compétences validées,
#            celles-ci ne sont pas toujours supprimées.
#     SEGAY - 13/01/13 - EXI FQ94656 US 2323 :Contrat non encore actif
######################################################################################
Raz GPILOBJ
Call OBJET("CSI",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEFLIG"      : Gosub DEFLIG #Tableau stage
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD # 26/06/12 SEGAY 81085 US500
 When "INICRE_LIG"  : Gosub INICRE_LIG #Tableau stage
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "AV_VERF_ANU" : Gosub AV_VERF_ANU #Tableau stage
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "FIN"         : Gosub FIN
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "AB2_NBLIG"   : Gosub AB2_NBLIG # SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
 When "AB3_NBRDEM"  : Gosub AB3_NBRDEM # SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
  # Sélections SEGAY - 02/05/11 - Bug  73325
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "ABANDON"     : Gosub ABANDON
 When "FERME"       : Gosub FERME
 When "GRISE"       : Gosub GRISE : #FQ94656
 When "DEGRISE"     : Gosub DEGRISE : #FQ94656

Endcase
#LIPET - X3-29543 - 2017-11-29 - START
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - START
If func AFNC.ACTIV("FKSSD")>0
  If func DIVPAYE.EXISTE_KXX("SUBCSISA") Then
    Gosub ACTION From SUBCSISA
  Endif
Endif
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - END
#LIPET - X3-29543 - 2017-11-29 - END
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Else
 FILTSUP = "1=1"
Endif
#MABOS-FQ81085-US1540-07/05/13
#Remove action SELCSILEG in screen GENDEM (-> managed by TOOLSHRLEG)
#If maskcou="GENDEM" Then
#SEGAY 01/07/13 US1752 81085 81491
If maskcou="GENDEM" & (GPILNAV <2 or  GNAVIG(GPILNAV)<>"GESCSI") & GCURLEG<>"" Then
  FILTSUP -= "& find([F:FCY]LEG,'','"+GCURLEG+"')>0"
Endif
Return

$FILGAUCHE
If GUSRACS<>2
 FILGAUSUP  = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILGAUSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If [L]FILGAUSUP<>"" : [L]FILGAUSUP -= "& " : Endif
 FILGAUSUP += 'find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
Endif
# FQ81085 - MABON 25/06/12 - Filter left list according LEGFIL
#If GLEGFIL<>""
#  If(FILGAUCHE<>"") :FILGAUCHE-="&" : Endif
#  FILGAUCHE -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
#  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
#  FILGAUSUP += "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
#Endif
# End MABON
If GLEGFIL <> ""
  FILGAUCHE = "[F:TCS]LEG='"+GLEGFIL+"'|[F:TCS]LEG=''"
Else
  FILGAUCHE = ""
Endif

Return

$OUVRE
If clalev([F:CSIX])=0   : Local File COURSEI   [CSIX] : Endif
If clalev([F:CIL])=0    : Local File COURISLIG [CIL]  : Endif
If clalev([F:TCS])=0    : Local File TYPCOURSE [TCS]  : Endif
If clalev([F:TCL])=0    : Local File TCOURLIG  [TCL]  : Endif
If clalev([F:STG])=0    : Local File STAGE     [STG]  : Endif
If clalev([F:COU])=0    : Local File COUT      [COU]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If GPAYE=1
 If clalev([F:HSP])=0   : Local File HISTOPAYE [HSP]  : Endif
 If clalev([F:VEP])=0   : Local File VALEMP    [VEP]  : Endif
Endif
#ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#**If clalev([F:TIP])=0    : Local File TIMEMP    [TIP]  : Endif
#**If clalev([F:TIM])=0    : Local File TIMCOD    [TIM]  : Endif
#**If GMODU(4)=2
#** If clalev([F:TIG])=0   : Local File TIMREGUL  [TIG]  : Endif
#**Endif
#**
If clalev([F:TIP])=0    : Local File TIMEMP    [TIP]  : Endif
If clalev([F:TIM])=0    : Local File TIMCOD    [TIM]  : Endif
If GMODU(15)=2
  If clalev([F:TIG])=0   : Local File TIMREGUL  [TIG]  : Endif
Endif
#ADNGO - 2017-02-15 - END
#Compétence
If clalev([F:ACV])=0    : Local File ACTIV     [ACV]  : Endif
If func IS_CAR
 If clalev([F:EVE])=0   : Local File EVAEMP    [EVE]  : Endif
 If clalev([F:CPE])=0   : Local File CPCEMP    [CPE]  : Endif
Endif
If clalev([F:EPO])=0    : Local File EMPLOPOT  [EPO]  : Endif
If clalev([F:POT])=0    : Local File POSTE     [POT]  : Endif
If clalev([F:JOT])=0    : Local File JOBTYP    [JOT]  : Endif

If clalev([F:CPE])=0    : Local File CPCEMP    [CPE]  : Endif
If clalev([F:CIC])=0    : Local File CSICPC    [CIC]  : Endif
If clalev([F:HRSCA])=0  : Local File SCALE     [HRSCA]: Endif
If clalev([F:CPC])=0    : Local File COMPETENCE[CPC]  : Endif
If clalev([F:DEM])=0    : Local File DEMANDE   [DEM]  : Endif
If clalev([F:DML])=0    : Local File DEMLIG    [DML]  : Endif
If clalev([F:INS])=0    : Local File INSCRIPT  [INS]  : Endif

If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

# Tableau de ligne de stages
Gosub DECLARE From TABLEAUX

Gosub DECLARE

Local Char CRITCSI(250)
Return

$ABANDON
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#**####################################################################################
#* Etiquette appelée par TABLEAUX, pour définir la table et la clé secondaire de TCOURLIG
#*!
$DEFLIG
Local Char ZONLIG

  # Définition des lignes:
  Default Mask [CSI2]
  Default File [CIL]
  # Critère de chargement des lignes:
  CRIT = "COD='"+[M:CSI0]COD+"'"
  # Fichier pour gestion détails:
  FICLIG = "COURISLIG" : ABLIG = "CIL"
  # Zone deuxième partie de clé:
  ZONLIG = "CILLIG"
Return
#####################################
$DECLARE
Local Char VALCPT (GLONCSI)
Local Integer I
Local Char WCPC
Local Integer L_IJ
Local Integer L_NBCPC_SAL
Local Integer L_NBCP  : #SEGAY - 24/12/10 - 70247 lot P24 - V6.1
#     SEGAY - 02/05/11 - 73325
Local Date L_DAT1, L_DAT2

Return
#**#####################################################################################
#* SEGAY - 14/10/10 - En création, on initialise le tableau avec toutes les colonnes par défaut
#* Par ailleurs, on initialise le tableau de M:CSI3 par les valeurs par défaut paramétrées dans ADI468
#*!
$RAZCRE
Gosub RAZ_SUIACN
Gosub INITMASK

#SEGAY 26/06/12 81085 US500
#GCURLEG = GLEGFIL
Return
$RAZDUP
Raz [M:CSI3]NBACN

Gosub RAZ_SUIACN
Call AFF_MAT
Gosub INITMASK
Call GRISE_IS_DEM
Call AFF_CSI0
Return

$CREATION
Call MAJTEXTRA([M]DESAXX,"COURSEI","DESAXX",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"COURSEI","SHOAXX",[M]COD,"") From ATEXTRA
Gosub CREATION From TABLEAUX
# Réinitialisation des variables utilisées dans TABLEAUX stage pour définir si une ligne est ajoutée ou modifiée
For I=0 To [M]NBLIG-1
  [M]CREFLG(I)=I+1
  [M]UPDFLG(I)=0
Next
Return

$MODIF
Call MAJTEXTRA([M]DESAXX,"COURSEI","DESAXX",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"COURSEI","SHOAXX",[M]COD,"") From ATEXTRA
Gosub MODIF From TABLEAUX
# Réinitialisation des variables utilisées dans TABLEAUX stage pour définir si une ligne est ajoutée ou modifiée
For I=0 To [M]NBLIG-1
  [M]CREFLG(I)=I+1
  [M]UPDFLG(I)=0
Next
Return

$SETBOUT
# On ne peut pas supprimer un parcours si une demande existe pour ce parcours
If func DEM_EXIST([M:CSI0]COD,[M:CSI1]REFNUM,[M:CSI1]CTR): Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
# On ne peut pas supprimer un parcours si une compétence parcours existe pour ce salarié
If func IS_CAR
  If find(2,[M:CSI4]FLGCPE(0..[M:CSI4]NBRVAL-1))
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif
Endif
# On ne peut pas généré les demandes ou des Propoisition d'inscription si on est en crétion ou est en train de modifier le parcours ou si on n'a pas de stage
If GREP<>"" | [M:CSI2]NBLIG=0
 Call VIREBOUT(CHAINE,"1") From GOBJET :#Bouton Génération en masse
 Call VIREBOUT(CHAINE,"2") From GOBJET :#Bouton Proposition
Endif
# On ne peut pas valider les compétences si on est en crétion ou est en train de modifier le parcours
If (GREP<>"") or !func IS_CAR or [M:CSI4]NBRVAL=0
 Call VIREBOUT(CHAINE,"3") From GOBJET :#Bouton Validation compétences
Endif

Call SET_CONTEXT
Return

$EXEBOUT
#Case BOUT
# When "3" : Gosub VAL_CPC :#Bouton Validation compétences
#Endcase
Return
#**#####################################################################################
#* Suppression des enregistrements secondaires de COURSISLIG tableaux stages
#*!
$AV_VERF_ANU
Gosub ANNULE From TABLEAUX
Return

$ANNULE
Delete [AXX] Where CODFIC="COURSEI" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
If GOK<1 : Return : Endif
#Pas de delete sur CPE dans le parcours on met à jour les compétences, mais on ne les supprime pas.
#For I=0 To [M:CSI4]NBRVAL-1
#Delete [CPE] Where [CPE]REFNUM=[F:CSI]REFNUM & [CPE]CPC=[M:CSI4]CPCVAL(I) & [CPE]CPCDAT=[M:CSI4]OLDDATVAL(I) & [CPE]ORICPC=6
#If fstat=1 | fstat>5
# GOK=-1 : GLOCK="$CPCEMP" : Return
#Endif
#Next I
#Pas besoin de delete sur CIC car on a le lien de suppression sur le COD du Parcours (CSI) dans la table CIC
Return

$CHANGE
Update [AXX] Where CODFIC="COURSEI" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA COURSEI"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$FIN_ACTION
#If BOUT = "G" Then
#  Gosub CHARGE_DEM
#Endif
Return
#**#####################################################################################
#* Kill des globales
#*!
$FIN
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking into account GLEGFIL
$FILCSI

  CRITCSI="1=1"
  If GUSRACS<>2
    CRITCSI -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
    CRITCSI -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
  Endif
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
    CRITCSI -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
  Endif
  If GLEGFIL<>""
    CRITCSI -= "& (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  Filter [CSI_] Where evalue(CRITCSI)
Return

#####################################
# L'exécution des boutons "Génération demande" et "Proposition" se fait dans l'étiquette APRES_CHOI, de façon
# à pouvoir rafraîchir le browser et les écrans, en positionnant REPONSE à GSTARAF
$APRES_CHOI
  Case REPONSE
    When GSTABOU+1 :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      GACTION = "GENDEM"
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","GENDEM","GENDEM",3,"XYGENDEM") From GTRAITE
      REPONSE = GSTARAF

    When GSTABOU+2 :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      GACTION = "INSPRO"
      #MABOS-26/07/13-FQ81085-US1833-fenêtre avec mémo-
      # Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISDEM","INSPRO","INSPRO",3,"XYINSPRO") From GTRAITE
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISDEM","INSPRO","INSPRO",4,"XYINSPRO") From GTRAITE

      REPONSE = GSTARAF

    When GSTABOU+3
       Gosub VAL_CPC :#Bouton Validation compétences
       REPONSE = GSTARAF

    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILCSI
      If REPONSE=GSTASUI Then Read [CSI_]CSI0 > [M:CSI0]COD : Endif
      If REPONSE=GSTAPRE Then Read [CSI_]CSI0 < [M:CSI0]COD : Endif
      If REPONSE=GSTAFIR Then Read [CSI_]CSI0 First         : Endif
      If REPONSE=GSTALAS Then Read [CSI_]CSI0 Last          : Endif
      Filter [CSI_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

# Aprés la création griseage du matricule car c'est le seul endroit possible quand on fait une duplication
$APRES_CRE
#Diszo [M:CSI1]REFNUM
Affzo [M:CSI1]REFNUM
Return
#**
#* Etiquette APRES_MODIF, Si on modifie le salarié ou le contrat on doit passer en duplication
#* Pour éviter de mettre le salarié et le contrat dans la clé primaire, j'ai trouvé cet astuce
#*!
$APRES_MODIF
#SEGAY-10/12/2012 US 1045 81085
#If COUZON='REFNUM'
If COUZON='REFNUM' & GREP <> "C" &  GREP <> "D" : # US 2323 94656 in modif or duplic REFNUM et CTRNUM isn't seisable
  COUZON='COD'
  CZ=''
  COUIND=0
  Raz [M:CSI0]COD
  Affzo[M:CSI0]COD
Endif
#SEGAY-10/12/2012 US 1045 81085
#If COUZON='CTR'
If COUZON='CTR' & GREP <> "C" &  GREP <> "D" : # US 2323 94656 in modif or duplic REFNUM et CTRNUM isn't seisable
  COUZON='COD'
  CZ=''
  COUIND=0
  Raz [M:CSI0]COD
  Affzo [M:CSI0]COD
Endif
Return

$LIENS
Call GET_TYPCOURSE([M:CSI0]TCS)

If func GET_EMPLOID([M:CSI1]REFNUM)
 Call GRISE_CTR([F:ID]FLGMULCTR)
Endif
Call AFF_MAT
Call GRISE_IS_DEM
Call GET_TUTEUR([M:CSI1]REFNUMT)
#ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#If GMODU(4)=2 & GPAYE
#  Call SOLDE_DIF([M:CSI1]REFNUM,[M:CSI1]CTR,[M:CSI1]STRDAT,[M:CSI1]NBRHOUDIF) From DIVPAYE
#Endif
#*!
If GMODU(15)=2 & GPAYE
  Call SOLDE_DIF([M:CSI1]REFNUM,[M:CSI1]CTR,[M:CSI1]STRDAT,[M:CSI1]NBRHOUDIF) From DIVPAYE
Endif
#ADNGO - 2017-02-15 - END
Affzo [M:CSI1]NBRHOUDIF

Call SET_CONTEXT

#If [CSI1]CTR<>""
#  Read [HRCTR]CTR0(2)=[CSI1]REFNUM;[CSI1]CTR
#  If !fstat
#    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
#    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#  Else
#    Read [ID]ID0=[CSI1]REFNUM
#    If !fstat
#     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
#     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Endif
#Else
#  #19/06/12 - DKA - Use Training Type Company Legislation for Context
#  If [CSI0]TCS<>""
#    Read [TCS]TCS0=[CSI0]TCS
#    If !fstat
#      Call LECTURE("CPY",[F:TCS]CPY,"") From CONTOBJ
#      GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Else
#    Read [ID]ID0=[CSI1]REFNUM
#    If !fstat
#     Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
#     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    Endif
#  Endif
#Endif
#If GNBLEG=1 : GCURLEG = GDOSLEG : Endif


# Récupération actions suivi
Gosub CHARGE_ACN
Gosub INITMASK
# Tableau de ligne de stages
Gosub LIENS From TABLEAUX
Gosub ACTIV_STG
Call AFF_AFFTOT_PREV
Call AFF_AFFTOT_EFF
If func IS_CAR
  Gosub CHARGE_CPC
  Gosub CHARGE_CIC
  Sorta [M]NBRGRA [M]NBRGRA Order By [M]CPCGRA([S]indice)
Endif
Gosub CHARGE_DEM
[M:CSI6]RRHCMT = [F:CSI]RRHCMT
Affzo [M:CSI6]RRHCMT

#LIPET - 2017-11-29 - START
 Filter [F:TCS] Where COD = [M:CSI0]TCS
 Read [F:TCS] First
 Filter [F:TCS]
 If !fstat Then
   [M:CSI0]LEG = [F:TCS]LEG
   GCURLEG = [M:CSI0]LEG
   Affzo [M:CSI0]LEG
 Endif
#LIPET - 2017-11-29 - END
#20/06/12 - DKA - Hide fields based on legislation
Call DISPLAY_HIDE() From SUBCSILEG
Return
#**
#* Activation lignes de stages
#*!
$ACTIV_STG
Actzo [M:CSI2]NBLIG
For I=0 To [M:CSI2]NBLIG-1
# Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=[M:CSI1]REFNUM & [F:DML]CTRNUM=[M:CSI1]CTR & [F:DEM]CODCSI=[M:CSI0]COD & [F:DEM]STG=[M:CSI2]STG(I) & [F:DEM]ORIDEM=2
# If rowcount([F:DM_])<>0 Then : # on regarde si la demande existe déjà
#  Grizo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
#  Affzo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
# Else
#  Actzo [M:CSI2]STG(I),ORDRE(I),FLGOWT(I),FLGOBG(I),STRDATS(I),TYPFRT(I),NATFIS(I)
# Endif
  Call CHARGE_INFO_STG(I,[M:CSI2]STG(I))
  Call CHARGE_INFO_STG_R(I,[M:CSI2]STG(I))

  Affzo [M:CSI2]DOM(I)
  Affzo [M:CSI2]THM(I)
  Affzo [M:CSI2]NBRDAY(I)
  Affzo [M:CSI2]NBRHOUIPT(I)
  Affzo [M:CSI2]NBRDAYREAA(I)
Next

Return

#**
#* Chargement des actions suivi
#*!
$CHARGE_ACN
  nolign=1
  For I=0 To dim([F:CSI]SUIACN)-1
    If [M:CSI3]SUIACN(I)<>"" Then
      [M:CSI3]SUIACN(nolign-1)=[F:CSI]SUIACN(I)
      [M:CSI3]SUIDAT(nolign-1)=[F:CSI]SUIDAT(I)
      [M:CSI3]SUICMT(nolign-1)=[F:CSI]SUICMT(I)
      nolign+=1
    Endif
  Next
  [M:CSI3]NBACN=nolign-1
Return
#**
#* Chargement des compétences requises
#*!
$CHARGE_CPC
If !func IS_CAR
  Return
Endif
nolign=0
#Call REMTAB_CPC(nolign,[M:CSI1]POT,[M:CSI1]JOBPOT)
Call REMLIG_CICREQ_GPEC(nolign)

Call REMLIG_CICREQ(nolign)
[M:CSI4]NBRCPC = nolign
Sorta [M:CSI4]NBRCPC [M:CSI4]NBRCPC Order By [M:CSI4]CPC([S]indice)
Sorta [M:CSI4]NBRGRA [M:CSI4]NBRGRA Order By [M:CSI4]CPCGRA([S]indice)

Return

#**
#* Chargement des compétences acquises
#*!
$CHARGE_CIC
Raz WCPC
nolign=0
Filter [CIC] Where COD=[M:CSI0]COD & CPCDAT<>[0/0/0] Order By COD Asc; CPC Asc; CPCDAT Desc
#For [CIC]CIC1(2)
For [CIC]
 # CIC1 * COD+CPC+CPCDAT
#  For [CIC]CIC1
  If WCPC <> [F:CIC]CPC Then
    # SEGAY 22/01/13 BUG 87090 ACTIV CODE CPC
    If nolign>=dim([M:CSI4]CPCVAL)
       # Tableau plein
      Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
      Break
    Endif
    # END SEGAY 22/01/13 BUG 87090 ACTIV CODE CPC
    WCPC = [F:CIC]CPC
    nolign+=1
    # Watchout here, don't make a 'transclass' !
    [M:CSI4]CPCVAL(nolign-1)    = [F:CIC]CPC
    [M:CSI4]LEVCPCVAL(nolign-1) = [F:CIC]LEVCPC
    [M:CSI4]LEVCPCEVA(nolign-1) = [F:CIC]LEVCPCEVA
    If [F:CIC]LEVREFVAL<>0
     [M:CSI4]LEVREFVAL(nolign-1)    = [F:CIC]LEVREFVAL
    Else
     [M:CSI4]LEVREFVAL(nolign-1) = func SUBECP.CPC_LEVREF([F:CIC]CPC,[F:CIC]LEVCPC)
    Endif
    If [F:CIC]LEVREFEVA<>0
     [M:CSI4]LEVREFEVA(nolign-1)    = [F:CIC]LEVREFEVA
    Else
     [M:CSI4]LEVREFEVA(nolign-1)    = func SUBECP.CPC_LEVREF([F:CIC]CPC,[F:CIC]LEVCPCEVA)
    Endif
# SEGAY 03/02/11 Bug 71326
#    [M:CSI4]ACTDEV(nolign-1)       = [F:CIC]ACTDEV
    [M:CSI4]CPCDATVAL(nolign-1) = [F:CIC]CPCDAT
    # Sauvegarde de la date si on la modifie il faut pouvoir supprimer dans CIC la compétences à l'ancienne date
    [M:CSI4]OLDDATVAL(nolign-1) = [F:CIC]CPCDAT

    [M:CSI4]ORICPCVAL(nolign-1) = [F:CIC]ORICPC
    [M:CSI4]FLGMODVAL(nolign-1) = 1
    [M:CSI4]FLGOLDVAL(nolign-1) = 2
    [M:CSI4]FLGCPE(nolign-1) = [F:CIC]FLGCPE
    # Now some graphicals, Learned
    L_IJ = find([F:CIC]CPC,[M:CSI4]CPCGRA(0..[M:CSI4]NBRGRA-1))
    If [M:CSI4]LEVREFEVA(nolign-1)=0
      If L_IJ
       [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFVAL(nolign-1)
      Else
       If [M:CSI4]NBRGRA<dim([M:CSI4]CPCGRA)
         [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [F:CIC]CPC
         [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFVAL(nolign-1)
         [M:CSI4]NBRGRA += 1
       Else
        # Tableau plein
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
        Break
       Endif
      Endif
    Else
      If L_IJ
       [M:CSI4]ACQUIS(L_IJ-1)   = [M:CSI4]LEVREFEVA(nolign-1)
      Else
       If [M:CSI4]NBRGRA<dim([M:CSI4]CPCGRA)
         [M:CSI4]CPCGRA([M:CSI4]NBRGRA)   = [F:CIC]CPC
         [M:CSI4]ACQUIS([M:CSI4]NBRGRA)   = [M:CSI4]LEVREFEVA(nolign-1)
         [M:CSI4]NBRGRA += 1
       Else
        # Tableau plein
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
        Break
       Endif
      Endif
    Endif
# SEGAY 02/05/11 - 73807 Pour ne pas charger les compétences vides
  Call LECTURE("CPC",[F:CIC]CPC,"") From CONTOBJ
  [M:CSI4]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
  Endif
# Next : # [CIC]CIC1
 # JML 10/09/10 CG Tunnel Echelle
# SEGAY 02/05/11 - 73807 Pour ne pas charger les compétences vides
# Call LECTURE("CPC",[F:CIC]CPC,"") From CONTOBJ
# [M:CSI4]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
Next : # [CIC]CIC1(2)
Filter [CIC]
[M:CSI4]NBRVAL = nolign
Return

#####################################
$CHARGE_DEM
nolign=1
For I=0 To [M:CSI2]NBLIG-1
  # on charge les demandes de stages de parcours dont la demande est générée, sauf les refusés

  Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=[M:CSI1]REFNUM & [F:DML]STA<>3 & [F:DML]CTRNUM=[M:CSI1]CTR & [F:DEM]CODCSI=[M:CSI0]COD & [F:DEM]STG=[M:CSI2]STG(I) & [F:DEM]
& ORIDEM=2
  If rowcount([F:DM_])<>0 Then : # on regarde si la demande existe déjà
    For [F:DM_]
     [M:CSI5]=[F:DEM]
     [M:CSI5]STA(nolign-1)=[F:DML]STA
     [M:CSI5]FLGINS(nolign-1)=[F:DML]FLGINS
     [M:CSI5]CATFRT(nolign-1)=[F:DML]CATFRT
     [M:CSI5]DESTYPFRT(nolign-1)=[F:DML]DESTYPFRT
     [M:CSI5]TYPFIN(nolign-1)=[F:DML]TYPFIN
     [M:CSI5]ORGFIN(nolign-1)=[F:DML]ORGFIN
     [M:CSI5]SRV(nolign-1)=[F:DML]SRV
#     [M:CSI5]RENREF(nolign-1)=[F:DML]RENREF
     nolign+=1
    Next
  Endif
Next
[M:CSI5]NBRDEM=nolign-1
Return

#**
#* Initialisation des champs
#* Si PAYE total DIF non saisissable
#* Pour la duplication
#* Suppresion ligne demande écran CSI5
#* Suppresion ligne évaluation acquis écran CSI4
#*!
$INITMASK
If GPAYE
  Grizo [M:CSI1]NBRHOUDIF
Endif
If [M:CSI2]NBLIG > 0
  Gosub RAZREA_STG
  Call AFF_AFFTOT_PREV
  Call AFF_AFFTOT_EFF
  Affzo [M:CSI2]1-99
Endif
If func IS_CAR
  If [M:CSI4]NBRGRA > 0
    Dela 0, [M:CSI4]NBRGRA [M:CSI4]NBRGRA
  Endif
  Raz [M:CSI4]NBRGRA
  Raz [M:CSI4]CPCGRA
  If [M:CSI4]NBRVAL > 0
    Dela 0, [M:CSI4]NBRVAL [M:CSI4]NBRVAL
  Endif
  Raz [M:CSI4]NBRVAL
  Raz [M:CSI4]CPCVAL
  Raz [M:CSI4]CPCDLT

  Raz [M:CSI4]NBRDLT
  Raz [M:CSI4]CPCDLTVAL
  Raz [M:CSI4]NBRDLTVAL
  Affzo [M:CSI4]1-99
  Call REMTAB_CPCGRA
  Affzo [M:CSI4]1-99
#Else
#  Grizo[M:CSI4]
Endif
Raz [M:CSI5]NBRDEM
Affzo [M:CSI5]1-99
Raz [M:CSI6]RRHCMT
Affzo [M:CSI6]
Return
#**
#* En création, on initialise le tableau de suivi écran M:CSI3 par les valeurs par défaut paramétrées dans ADI468
#*!
$RAZ_SUIACN
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  I=0
  Local Char WLEGFILCURLEG(GLONADI)
  WLEGFILCURLEG=""
  If dim(GCURLEG)>0 & dim(GLEGFIL)>0
    WLEGFILCURLEG=GLEGFIL
    If GCURLEG<>"" & GCURLEG<>GLEGFIL
      WLEGFILCURLEG=GCURLEG
    Endif
  Endif
  For [F:ADI] Where NUMTAB=10468 and N1=2
#  SEGAY 26/06/12 GCURLEG
# 26/06/12 SEGAY 81085 US500
    If WLEGFILCURLEG<>"" & [F:ADI]LEG <> "" & [F:ADI]LEG <> WLEGFILCURLEG
    Else
      [M:CSI3]SUIACN(I)=[F:ADI]CODE
      Raz [M:CSI3]SUIDAT(I)
      Raz [M:CSI3]SUICMT(I)
      I += 1
    Endif
  Next
  [M:CSI3]NBACN=I
  Affzo [M:CSI3]
Return


$INICRE
# Affectation du code parcours
If [F:CSI]COD=""
 Call CPT_CSI(VALCPT,[F:CSI]TCS)
 If GOK
  [M:CSI0]COD = VALCPT
  [F:CSI]COD  = VALCPT
  Affzo [M:CSI0]COD
 Endif
Endif
If GOK<=0 : Return : Endif
#  Enregistrement actions suivi
Gosub SAUVE_ACN
Gosub SAUVE_CIC
If GOK<=0 : Return : Endif
Return

$VERIF_CRE
## Action %OBLIG
If vireblc([M:CSI1]REFNUM,2)=""
 mkstat = 2 : SUIZON="[M:CSI1]REFNUM" : GERR=1 : OK=0 :GMESSAGE = mess(10,123,1) : Return
Endif
Call C_REFNUM([M:CSI1]REFNUM)
If mkstat=2
  SUIZON="[M:CSI1]REFNUM" : GERR=1 :OK=0 : Return
Endif
## Action %OBLIG
If [M:CSI1]STRDAT=[0/0/0]
 mkstat = 2 : SUIZON="[M:CSI1]REFNUM" : GERR=1 : OK=0 : GMESSAGE = mess(10,123,1)
Endif

Call C_STRDAT([M:CSI1]STRDAT)
If mkstat=2
  SUIZON="[M:CSI1]STRDAT" : GERR=1 :OK=0 : Return
Endif
# 26/06/12 SEGAY 81085 US500
Call CTR_LEGSTG(GCURLEG)
If mkstat=2 Then OK=0 : Return : Endif

Return

# 26/06/12 SEGAY 81085 US500
$VERIF_MOD
Call CTR_LEGSTG(GCURLEG)
If mkstat=2 Then OK=0 : Return : Endif
Return

# Creation de ligne tableaux stage Affectation du code parcours
$INICRE_LIG
# Affectation du code parcours
If [F:CIL]COD=""
  [F:CIL]COD=[F:CSI]COD
Endif
Return

$INIMOD
# Enregistrement actions suivi
Gosub SAUVE_ACN
Gosub SAUVE_CIC
If GOK<=0 : Return : Endif
Return
#**
#* Réinitialisation du réalisé des lignes de stages
#*!
$RAZREA_STG
For I=0 To [M:CSI2]NBLIG-1
  Raz [M:CSI2]STRDATS(I)
  Raz [M:CSI2]STRDATR(I)
  Raz [M:CSI2]ENDDATR(I)
  [M:CSI2]STA(I)=1
  Raz [M:CSI2]NBRDAYREA(I)
  Raz [M:CSI2]NBRDAYREAA(I)
  Raz [M:CSI2]NBRHOUREA(I)
  Raz [M:CSI2]NBRHOUIPT2(I)
Next
Return

#**
#* Sauvegarde des actions suivi
#*!
$SAUVE_ACN
  Raz [F:CSI]SUIACN, [F:CSI]SUIDAT, [F:CSI]SUICMT
  For I=0 To [M:CSI3]NBACN-1
    [F:CSI]SUIACN(I) = [M:CSI3]SUIACN(I)
    [F:CSI]SUIDAT(I) = [M:CSI3]SUIDAT(I)
    [F:CSI]SUICMT(I) = [M:CSI3]SUICMT(I)
  Next
Return

#**
#* Sauvegarde des compétences requises et acquises
#*!
$SAUVE_CIC
If !func IS_CAR
  Return
Endif

# Des compétences requises ont-elles été supprimées
If [M:CSI4]NBRDLT>0
 For I=0 To [M:CSI4]NBRDLT-1
  Delete [CIC]CIC0=[M:CSI0]COD;[M:CSI4]DATDLT(I);[M:CSI4]CPCDLT(I)
  If fstat=1
   GOK = -1 : GLOCK = "$CPCEMP"-[M:CSI0]COD-num$([M:CSI4]DATDLT(I))-[M:CSI4]CPCDLT(I)
   Break
  Endif
 Next I
Endif
If GOK<=0 : Return : Endif
# Enregistrement compétences requises
For I=[M:CSI4]NBRCPC To 1 Step -1
 Readlock [F:CIC]CIC1=[M:CSI0]COD;[M:CSI4]CPC(I-1);[M:CSI4]CPCDAT(I-1)
 If fstat
  Raz [F:CIC]
  [F:CIC]COD = [M:CSI0]COD
  [F:CIC]CPCDAT = [M:CSI4]CPCDAT(I-1)
  [F:CIC]CPC    = [M:CSI4]CPC(I-1)
  [F:CIC]LEVCPC = [M:CSI4]LEVCPC(I-1)
  [F:CIC]LEVREFVAL = [M:CSI4]LEVREF(I-1)

  [F:CIC]ORICPC = [M:CSI4]ORICPC(I-1)
  [F:CIC]FLGGPEC = [M:CSI4]FLGGPEC(I-1)

  #  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
  [M:CSI4]FLGOLD(I-1) = 2
  [M:CSI4]CPCDAT(I-1) = [F:CIC]CPCDAT


  If dim([F:CIC]CREDAT)>0 : [F:CIC]CREDAT = date$     : Endif
  If dim([F:CIC]CRETIM)>0 : [F:CIC]CRETIM = time      : Endif
  If dim([F:CIC]CREUSR)>0 : [F:CIC]CREUSR = GUSER     : Endif
  If dim([F:CIC]EXPNUM)>0 : [F:CIC]EXPNUM = [C]EXPORT : Endif
  Write [CIC]
  If fstat
   GOK = 0 : Call FSTA("CIC") From GLOCK : Break
  Endif
 Else
  [F:CIC]LEVCPC = [M:CSI4]LEVCPC(I-1)
  [F:CIC]LEVREFVAL = [M:CSI4]LEVREF(I-1)
  [F:CIC]ORICPC = [M:CSI4]ORICPC(I-1)

  #  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
  [M:CSI4]FLGOLD(I-1) = 2
  [M:CSI4]CPCDAT(I-1) = [F:CIC]CPCDAT

  If dim([F:CIC]UPDDAT)>0 : [F:CIC]UPDDAT = date$     : Endif
  If dim([F:CIC]UPDTIM)>0 : [F:CIC]UPDTIM = time      : Endif
  If dim([F:CIC]UPDUSR)>0 : [F:CIC]UPDUSR = GUSER     : Endif
  If dim([F:CIC]EXPNUM)>0 : [F:CIC]EXPNUM = [C]EXPORT : Endif
  Rewrite[F:CIC]
  If fstat
   GOK = 0 : Call FSTA("CIC") From GLOCK : Break
  Endif
 Endif
Next I
If GOK<1 : Return : Endif
# JML 12/08/10 LOT P02
# Des compétences acquises ont-elles été supprimées
If [M:CSI4]NBRDLTVAL>0
 For I=0 To [M:CSI4]NBRDLTVAL-1
  Delete [CIC]CIC0=[M:CSI0]COD;[M:CSI4]DATDLTVAL(I);[M:CSI4]CPCDLTVAL(I)
  If fstat=1
   GOK = -1 : GLOCK = "$CPCEMP"-[M:CSI0]COD-num$([M:CSI4]DATDLTVAL(I))-[M:CSI4]CPCDLTVAL(I)
   Break
  Endif
 Next
Endif
If GOK<=0 : Return : Endif
# Enregistrement compétences acquises
For I=[M:CSI4]NBRVAL To 1 Step -1
 Readlock [F:CIC]CIC1=[M:CSI0]COD;[M:CSI4]CPCVAL(I-1);[M:CSI4]CPCDATVAL(I-1)
 If fstat
  Raz [F:CIC]
  [F:CIC]COD = [M:CSI0]COD
  [F:CIC]CPCDAT = [M:CSI4]CPCDATVAL(I-1)
  [F:CIC]CPC    = [M:CSI4]CPCVAL(I-1)
  [F:CIC]LEVCPC = [M:CSI4]LEVCPCVAL(I-1)
  [F:CIC]LEVREFVAL = [M:CSI4]LEVREFVAL(I-1)
  [F:CIC]ORICPC = [M:CSI4]ORICPCVAL(I-1)
  [F:CIC]FLGGPEC = [M:CSI4]FLGGPEC(I-1)
#  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
  [M:CSI4]FLGOLDVAL(I-1) = 2
  [M:CSI4]OLDDATVAL(I-1) = [F:CIC]CPCDAT

# SEGAY 03/02/11 Bug 71326
#  [F:CIC]ACTDEV = [M:CSI4]ACTDEV(I-1)
  [F:CIC]LEVCPCEVA = [M:CSI4]LEVCPCEVA(I-1)
  [F:CIC]LEVREFEVA = [M:CSI4]LEVREFEVA(I-1)
  [F:CIC]FLGCPE  = [M:CSI4]FLGCPE(I-1)
  If dim([F:CIC]CREDAT)>0 : [F:CIC]CREDAT = date$     : Endif
  If dim([F:CIC]CRETIM)>0 : [F:CIC]CRETIM = time      : Endif
  If dim([F:CIC]CREUSR)>0 : [F:CIC]CREUSR = GUSER     : Endif
  If dim([F:CIC]EXPNUM)>0 : [F:CIC]EXPNUM = [C]EXPORT : Endif
  Write [CIC]
  If fstat
   GOK = 0 : Call FSTA("CIC") From GLOCK : Break
  Endif
 Else
  [F:CIC]LEVCPC = [M:CSI4]LEVCPCVAL(I-1)
  [F:CIC]LEVREFVAL = [M:CSI4]LEVREFVAL(I-1)
  [F:CIC]ORICPC = [M:CSI4]ORICPCVAL(I-1)

#  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
  [M:CSI4]FLGOLDVAL(I-1) = 2
  [M:CSI4]OLDDATVAL(I-1) = [F:CIC]CPCDAT
# SEGAY 03/02/11 Bug 71326
#  [F:CIC]ACTDEV = [M:CSI4]ACTDEV(I-1)
  [F:CIC]LEVCPCEVA = [M:CSI4]LEVCPCEVA(I-1)
  [F:CIC]LEVREFEVA = [M:CSI4]LEVREFEVA(I-1)
  [F:CIC]FLGCPE  = [M:CSI4]FLGCPE(I-1)
  [F:CIC]FLGGPEC = [M:CSI4]FLGGPEC(I-1)

  If dim([F:CIC]UPDDAT)>0 : [F:CIC]UPDDAT = date$     : Endif
  If dim([F:CIC]UPDTIM)>0 : [F:CIC]UPDTIM = time      : Endif
  If dim([F:CIC]UPDUSR)>0 : [F:CIC]UPDUSR = GUSER     : Endif
  If dim([F:CIC]EXPNUM)>0 : [F:CIC]EXPNUM = [C]EXPORT : Endif
  Rewrite[CIC]
  If fstat
   GOK = 0 : Call FSTA("CIC") From GLOCK : Break
  Endif
 Endif
Next I
If GOK<1 : Return : Endif
#  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
If func IS_CAR
  If [M:CSI4]NBRDLT > 0
    Dela 0, [M:CSI4]NBRDLT [M:CSI4]NBRDLT
  Endif
  If [M:CSI4]NBRDLTVAL > 0
    Dela 0, [M:CSI4]NBRDLTVAL [M:CSI4]NBRDLTVAL
  Endif
  Raz [M:CSI4]NBRDLT
  Raz [M:CSI4]CPCDLT
  Raz [M:CSI4]CPCDLTVAL
  Raz [M:CSI4]NBRDLTVAL
Endif
Return
#Validation compétences
$VAL_CPC
GOK = 1
If !func IS_CAR
  Return
Endif
# Veuillez enregistrer les modifications avant de continuer.
If GREP <>""
  GMESSAGE = mess(558,9900,1)
  GOK = 0
  mkstat=2 : Return
Endif
#SEGAY - 24/12/10 - 70247 lot P24 - V6.1
TIT = mess(66,10720,1) : # Mise à jour des compétences dans la carrière
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN # Mise à jour des compétences dans la carrière

Call DEBTRANS From GLOCK
Trbegin [CPE]
 Gosub TRANSAC
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1 : Return
Endif
Commit
#SEGAY - 24/12/10 - 70247 lot P24 - V6.1
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If L_NBCP>0
 #Nombre de compétences mis à jour :
 Call ECR_TRACE(mess(67,10720,1)-":"-num$(L_NBCP),0) From GESECRAN
Else
 #Aucun compétence à traiter
 Call ECR_TRACE(mess(68,10720,1),0) From GESECRAN
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 # Affichage de la trace
 Call LEC_TRACE From LECFIC
Endif

Affzo [CSI4]15
#SAVREP= "M"
Return

#######################################################
$AB_TR1
Rollback
Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return
#######################################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VAL_CPC : Endif
#######################################################
#######
$TRANSAC
Local Integer WSTAT

#SEGAY - 24/12/10 - 70247 lot P24 - V6.1
L_NBCP = 0
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#Mise à jour des compétences dans la carrière
Call ECR_TRACE(mess(66,10720,1)-":"-[M:CSI1]REFNUM,0) From GESECRAN

L_NBCPC_SAL = func NB_CPC_SAL

# Création de la compétence dans CPCEMP, pour historique
For nolign=1 To [M:CSI4]NBRVAL
 # JML 24/09/10 CG uniquement si le niveau change
# If [M:CSI4]FLGMODVAL(nolign-1)=2 & [M:CSI4]LEVCPCEVA(nolign-1)<>""
#& & [M:CSI4]LEVCPCEVA(nolign-1)<>[M:CSI4]LEVCPCVAL(nolign-1)
 If (func ISMAJCPE([M:CSI1]REFNUM,[M:CSI4]CPCVAL(nolign-1),[M:CSI4]CPCDATVAL(nolign-1),[M:CSI4]LEVCPCEVA(nolign-1))=2)
  Readlock [CPE]CPE0=[M:CSI1]REFNUM;[M:CSI4]CPCDATVAL(nolign-1);[M:CSI4]CPCVAL(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$CPCEMP"-[M:CSI1]REFNUM-num$([M:CSI4]CPCDATVAL(nolign-1))-[M:CSI4]CPCVAL(nolign-1) : Break
#  Elsif fstat=0 & [M:CSI4]LEVCPCVAL(nolign-1)<>[F:CPE]LEVCPC
  Elsif fstat=0 & [M:CSI4]LEVCPCEVA(nolign-1)<>[F:CPE]LEVCPC
   [F:CPE]LEVCPC = [M:CSI4]LEVCPCEVA(nolign-1)
   [F:CPE]ORICPC = 6     : # ML 2402 Parcours
   [F:CPE]UPDDAT = date$
   [F:CPE]UPDUSR = GUSER
   [F:CPE]UPDTIM = time
   Rewrite [CPE]
   If fstat
    GOK=0 : Call FSTA("CPE") From GLOCK : Break
   Endif
   [M:CSI4]FLGCPE(nolign-1)=2
   Readlock [CIC]CIC0=[M:CSI0]COD;[M:CSI4]CPCDATVAL(nolign-1);[M:CSI4]CPCVAL(nolign-1)
   WSTAT = fstat
   If fstat=1
    GOK=-1 : GLOCK="$CSICPC"-[F:CIC]COD-num$([F:CIC]CPCDAT)-[F:CIC]CPC : Break
   Elsif fstat
    GOK=0 : Call RSTA("CIC",[F:CIC]COD-num$([F:CIC]CPCDAT)-[F:CIC]CPC) From GLOCK : Break
   Endif
   [F:CIC]FLGCPE=2
   Rewrite [CIC]
   If fstat
    GOK=0 : Call FSTA("CIC") From GLOCK : Break
   Endif
   #SEGAY - 24/12/10 - 70247 lot P24 - V6.1
   #Mise à jour du niveau de compétence :
   Call ECR_TRACE(space$(5)+mess(16,10720,1)-mess(95,100,1)-num$([F:CPE]CPCDAT)-":"-[F:CPE]CPC-[F:CPE]LEVCPC-mess([F:CPE]ORICPC,10939,1),0) From GESECRAN
   L_NBCP += 1

  Elsif fstat
   Filter [F:CPE] Where [F:CPE]REFNUM=[M:CSI1]REFNUM & [F:CPE]CPCDAT <> [0/0/0] & [F:CPE]CPC = [M:CSI4]CPCVAL(nolign-1)
   Read [F:CPE]CPE1(2)=[F:CPE]REFNUM;[M:CSI4]CPCVAL(nolign-1)
   Filter [F:CPE]
   If fstat & L_NBCPC_SAL >= dim([M:CSI4]CPCVAL)
      # Trop de compétences à analyser
      Call ERREUR(mess(48,10720,1)-num$(dim([M:CSI4]CPCVAL))) From GESECRAN
      GOK=0  : Break
   Endif
   L_NBCPC_SAL += 1
   Raz [F:CPE]
   [F:CPE] = [M:CSI4]
   [F:CPE]REFNUM = [M:CSI1]REFNUM
   [F:CPE]CPCDAT = [M:CSI4]CPCDATVAL(nolign-1)            : # Date début parcours ou Date d'acquisition ?
   [F:CPE]CPC    = [M:CSI4]CPCVAL(nolign-1)
   [F:CPE]LEVCPC = [M:CSI4]LEVCPCEVA(nolign-1)
   [F:CPE]ORICPC = 6     : # ML 2402 Parcours
   [F:CPE]CREDAT = date$
   [F:CPE]CREUSR = GUSER
   [F:CPE]CRETIM = time
   Raz [F:CPE]UPDDAT
   Raz [F:CPE]UPDUSR
   Raz [F:CPE]UPDTIM
   Write [CPE]
   If fstat
    GOK=0 : Call FSTA("CPE") From GLOCK : Break
   Endif
   [M:CSI4]FLGCPE(nolign-1)=2
   Readlock [CIC]CIC0=[M:CSI0]COD;[M:CSI4]CPCDATVAL(nolign-1);[M:CSI4]CPCVAL(nolign-1)
   If fstat=1
    GOK=-1 : GLOCK="$CSICPC"-[F:CIC]COD-num$([F:CIC]CPCDAT)-[F:CIC]CPC : Break
   Elsif fstat
    GOK=0 : Call RSTA("CIC",[F:CIC]COD-num$([F:CIC]CPCDAT)-[F:CIC]CPC) From GLOCK : Break
   Endif
   [F:CIC]FLGCPE=2
   Rewrite [CIC]
   If fstat
    GOK=0 : Call FSTA("CIC") From GLOCK : Break
   Endif
   #SEGAY - 24/12/10 - 70247 lot P24 - V6.1
   #Compétence attribuée :
   Call ECR_TRACE(space$(5)+mess(14,10720,1)-mess(95,100,1)-num$([F:CPE]CPCDAT)-":"-[F:CPE]CPC-[F:CPE]LEVCPC-mess([F:CPE]ORICPC,10939,1),0) From GESECRAN
   L_NBCP += 1

  Endif
 Endif : #  If [M:EVA2]FLGMODVAL(nolign-1)=2
Next nolign
If GOK<1 : Return : Endif

#Pas de delete sur CPE dans le parcours on met à jour les compétences, mais on ne les supprime pas comme dans évaluation.
#For I=0 To [M:CSI4]NBRVAL-1
#Filter [CPE] Where [CPE]REFNUM=[M:CSI1]REFNUM & [CPE]CPCDAT=[M:CSI4]OLDDATVAL(I) & [CPE]ORICPC=6 # ML 2402 Parcours
#For [CPE]CPE0
# If !find([F:CPE]CPC,[M:CSI4]CPCVAL(0..[M:CSI4]NBRVAL-1))
#  Delete [CPE] Curr
#  If fstat=1 | fstat>5
#   GOK=-1 : GLOCK="$CPCEMP" : Break
#  Endif
# Endif
#Next
#Filter [CPE]
#If GOK<1 : Break : Endif
#Next I
#If GOK<1 : Return : Endif
Return

################################################################################
# Action Sélection en table 73325
################################################################################
$SEL_TABLE
Case [L]TABLE
  When "SELCTRPOT" : Gosub S_SELCTRJOTPOT
  When "SELEMPPOT" : Gosub S_SELEMPJOTPOT

Endcase
Return

$FIN_TABLE
Case [L]TABLE
  When "SELCTRPOT"
    If [F:HRCTR]CTRNUM <> "" Then
      [L]VALEUR=[F:HRCTR]CTRNUM
      [M:CSI1]CTRDAT=[F:HRCTR]CTRDAT
      Affzo [M:CSI1]CTRDAT
      [M:CSI1]FLGSELCTR = 1
    Endif
  When "SELEMPPOT"
# SEGAY 26/06/12 81085 US500
#    If [F:HRCTR]CTRNUM <> "" Then
#      [L]VALEUR=[F:HRCTR]REFNUM
#      [M:CSI1]REFNUM= [F:HRCTR]REFNUM
#      [M:CSI1]CTR=[F:HRCTR]CTRNUM
#      [M:CSI1]CTRDAT=[F:HRCTR]CTRDAT
    If [F:ILEG]CTRNUM <> "" Then
      [L]VALEUR=[F:ILEG]REFNUM
      [M:CSI1]REFNUM= [F:ILEG]REFNUM
      [M:CSI1]CTR=[F:ILEG]CTRNUM
      [M:CSI1]CTRDAT=[F:ILEG]CTRDAT

      Affzo [M:CSI1]CTR
      Affzo [M:CSI1]CTRDAT
      [M:CSI1]FLGSELEMP = 1
      [M:CSI1]FLGSELCTR = 1
      # Pour que le controle du champ se lance on met mkstat=99 uniquement si la sélection se fait par un bouton de type autre que sélection
#      mkstat=99
    Endif

Endcase
Return

# FQ94656
$INI_DAT1DAT2
  Local Date L_DAT1, L_DAT2, L_CTRDAT
  If [M:CSI1]STRDAT<>[0/0/0]
   L_DAT1 = [M:CSI1]STRDAT
   L_DAT2 = [M:CSI1]STRDAT
  Else
 # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif
   L_DAT1 = [31/12/9999]
   L_DAT2 = [0/0/0]
  Endif
Return
# FQ94656
$INI_SELJOTPOT
  Local Char CODFIC(GLONATB)
# SEGAY 26/06/12 81085 US500
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
  Local Char WID_ILEG(30)
  Local Char WCTR_ILEG(30)
  Local Char WLEGFCY_ILEG(30)
  Local Char WFCY_ILEG(30)

  If GREP<>"C"
    WLEG=GCURLEG
    WCPY=GSOCIETE
  Else
    If GCURLEG = ""
      WLEG=GLEGFIL
    Else
      WLEG=GCURLEG
    Endif
    Raz [F:TCS]
    Call LECTURE("TCS",[M:CSI0]TCS,"") From CONTOBJ
    WCPY=[F:TCS]CPY
  Endif

  If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
  If clalev([F:ACC])=0    : Local File ACCES    [ACC]   : Endif
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif

  [M:CSI1]FLGSELCTR = 0
  [M:CSI1]FLGSELEMP = 0
  Gosub INI_DAT1DAT2
Return

# FQ94656
$ALIM_SELJOTPOT
  # Colonne Matricule
  NBCOL += 1 : COL(NBCOL) = "REFNUM" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"REFNUM"
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1)    : COL(NBCOL)=WID_ILEG+"NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  : COL(NBCOL)=WID_ILEG+"SRN"

  CODFIC = "EMPLOCTR"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"CTRNUM"
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"CTRDAT"
  # Colonne Date de sortie
  NBCOL += 1 : COL(NBCOL) = "XITDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"XITDAT"

  CODFIC = "EMPLOID"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  COL(NBCOL)=WLEGFCY_ILEG+"LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)=WFCY_ILEG
  # Colonne Emploi type
  NBCOL += 1 : COL(NBCOL) = "JOBPOT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"JOBPOT"
  # Colonne Poste
  NBCOL += 1 : COL(NBCOL) = "POT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"POT"
  # Colonne Service
  NBCOL += 1 : COL(NBCOL) = "ETRSRV"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"ETRSRV"
  # Colonne Profil
  NBCOL += 1 : COL(NBCOL) = "PROPRF"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)=WCTR_ILEG+"PROPRF"
  # Colonne Sortie définitive
  NBCOL += 1 : COL(NBCOL) = "XITFNL"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="mess("+WCTR_ILEG+"XITFNL,1,1)"

Return
################################################################################
# Action SELCTRJOTPOT : sélection contrat avec Emploi type et poste
################################################################################
$S_SELCTRJOTPOT
  Gosub INI_SELJOTPOT : # FQ94656
  WID_ILEG="[F:ID]" : # FQ94656
  WCTR_ILEG="[F:HRCTR]" : # FQ94656
  WFCY_ILEG="[F:FCY]FCY" : # FQ94656
  WLEGFCY_ILEG="[F:FCY]" : # FQ94656

  Raz [F:HRCTR] # SEGAY 26/06/12 81085 US500
  # Je ne veux que les contrat qui ne sont pas sortis de la société
  Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY,
&                   [F:ACC]CODACC = GUSER;[F:ID]CODACS
&                As [NEW]
&             Where [F:HRCTR]REFNUM=[M:CSI1]REFNUM
&               and ([F:FCY]LEG=WLEG or WLEG="")
&               and (WCPY="" | [F:FCY]LEGCPY = WCPY)
&               and [F:HRCTR]CTRDAT<=L_DAT1 and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=L_DAT2)
&               & (GUSRACS = 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) ))
#&               and [F:HRCTR]CTRDAT<=L_DAT1 and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=L_DAT1) # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif

  TIT(0)  = mess(244,10717,1) : # Choix du contrat
  Default File [NEW]

  NBCOL = 0
  CODFIC = "EMPLOCTR"

  Gosub ALIM_SELJOTPOT : # FQ94656

  [L]ORDRE = "[F:HRCTR]REFNUM;[F:ID]NAM;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT"
  [L]EXPSTART = "[F:HRCTR]REFNUM>='"+evalue([L]PARAM(1))+"'"
  [L]DEFPAG = 1    :# To have page up and page down

Return
################################################################################
# Action SELEMPJOTPOT : sélection salarié/contrat avec Emploi type et poste
################################################################################
$S_SELEMPJOTPOT
  Gosub INI_SELJOTPOT : # FQ94656
  WID_ILEG="[F:ILEG]" : # FQ94656
  WCTR_ILEG="[F:ILEG]" : # FQ94656
  WFCY_ILEG="[F:ILEG]FCYID" : # FQ94656
  WLEGFCY_ILEG="[F:FCY]" : # FQ94656

  Local    Integer I, K, DIFF_LEG
  Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5)

  Raz [F:HRCTR] # SEGAY 26/06/12 81085 US500
  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  Raz [F:ILEG]
  # Je ne veux que les contrat qui ne sont pas sortis de la société
  CRITERECPY="(1=1"
  If WCPY<>"" Then
    I=0 : Call CALC_GRPCPY(WCPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then : # C'est un groupe de sociétés
      CRITERECPY -= "& find([F:ILEG]LEGCPY,"
      For K=0 To I-1
        CRITERECPY += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERECPY += "," : Endif
      Next
      CRITERECPY += ")>0"
    Else
      CRITERECPY -= " & ([F:ILEG]LEGCPY ='"+WCPY+"')"
    Endif
  Endif
  CRITERECPY += ")"

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  Link [F:ILEG] With [F:ACC]CODACC = GUSER;[F:ILEG]CODACS,
&                    [F:CPY]CPY0=[F:ILEG]LEGCPY
&                As [NEW1]
&             Where [F:ILEG]CTRDAT<=L_DAT1 and ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=L_DAT2)
&               & (GUSRACS = 2 | ( ([F:ILEG]CODACS="" or [F:ACC]CONSUL=2) & find([F:ILEG]ETRSRV,GAUTSRV(1..GNBSERV)) ))
&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | evalue(CRITERECPY)))
#&             Where [F:ILEG]CTRDAT<=L_DAT1 and ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=L_DAT1) # FQ94656 - SEGAY 13/01/13 - Contrat non encore actif

  TIT(0)  = mess(245,10717,1) : # Choix du salarié
  Default File [NEW1]

  NBCOL = 0
  CODFIC = "EMPLOID"

  Gosub ALIM_SELJOTPOT : # FQ94656

  [L]ORDRE = "[F:ILEG]REFNUM;[F:ILEG]NAM;[F:ILEG]LEGCPY;[F:ILEG]FCYID;[F:ILEG]CTRNUM;[F:ILEG]CTRDAT"
  [L]EXPSTART = "[F:ILEG]REFNUM>='"+VALEUR+"'"
  [L]START = "[F:ILEG]CTRDAT"
  [L]DEFPAG = 1    :# To have page up and page down
Return

$S_SELCTRJOTPOTOLD
  Local Char CODFIC(GLONATB)
# SEGAY 26/06/12 81085 US500
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
  If GREP<>"C"
    WLEG=GCURLEG
    WCPY=GSOCIETE
  Else
    If GCURLEG = ""
      WLEG=GLEGFIL
    Else
      WLEG=GCURLEG
    Endif
    Raz [F:TCS]
    Call LECTURE("TCS",[M:CSI0]TCS,"") From CONTOBJ
    WCPY=[F:TCS]CPY
  Endif

  If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
  If clalev([F:ACC])=0    : Local File ACCES    [ACC]   : Endif
  [M:CSI1]FLGSELCTR = 0
  [M:CSI1]FLGSELEMP = 0
  If [M:CSI1]STRDAT<>[0/0/0]
   L_DAT1 = [M:CSI1]STRDAT
   L_DAT2 = [M:CSI1]STRDAT
  Else
   L_DAT1 = date$
   L_DAT2 = date$
  Endif
  Raz [F:HRCTR] # SEGAY 26/06/12 81085 US500
  # Je ne veux que les contrat qui ne sont pas sortis de la société
  Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY,
&                   [F:ACC]CODACC = GUSER;[F:ID]CODACS
&                As [NEW]
&             Where [F:HRCTR]REFNUM=[M:CSI1]REFNUM
&               and ([F:FCY]LEG=WLEG or WLEG="")
&               and (WCPY="" | [F:FCY]LEGCPY = WCPY)
&               and [F:HRCTR]CTRDAT<=L_DAT1 and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=L_DAT1)
&               & (GUSRACS = 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) ))
#&               & ([M:CSI0]TCS="" | [F:TCS]CPY="" | [F:FCY]LEGCPY = [F:TCS]CPY)

  TIT(0)  = mess(244,10717,1) : # Choix du contrat
  Default File [NEW]

  NBCOL = 0
  CODFIC = "EMPLOCTR"
  # Colonne Matricule
  NBCOL += 1 : COL(NBCOL) = "REFNUM" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]REFNUM"
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1)    : COL(NBCOL)="[F:ID]NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  : COL(NBCOL)="[F:ID]SRN"

  CODFIC = "EMPLOCTR"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRNUM"
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRDAT"
  # Colonne Date de sortie
  NBCOL += 1 : COL(NBCOL) = "XITDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]XITDAT"

  CODFIC = "EMPLOID"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  # COL(NBCOL)="[F:ID]CPY"
  COL(NBCOL)="[F:FCY]LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)="[F:FCY]FCY"
  # Colonne Emploi type
  NBCOL += 1 : COL(NBCOL) = "JOBPOT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]JOBPOT"
  # Colonne Poste
  NBCOL += 1 : COL(NBCOL) = "POT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]POT"
  # Colonne Service
  NBCOL += 1 : COL(NBCOL) = "ETRSRV"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]ETRSRV"
  # Colonne Profil
  NBCOL += 1 : COL(NBCOL) = "PROPRF"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]PROPRF"
  # Colonne Sortie définitive
  NBCOL += 1 : COL(NBCOL) = "XITFNL"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="mess([F:HRCTR]XITFNL,1,1)"

  [L]ORDRE = "[F:HRCTR]REFNUM;[F:ID]NAM;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT"
  [L]EXPSTART = "[F:HRCTR]REFNUM>='"+evalue([L]PARAM(1))+"'"
  [L]DEFPAG = 1    :# To have page up and page down

Return

################################################################################
# Action SELEMPJOTPOT : sélection salarié/contrat avec Emploi type et poste
################################################################################
$S_SELEMPJOTPOTOLD
Local    Char    CODFIC(GLONATB)
# SEGAY 26/06/12 81085 US500
Local    Char    WLEG(GLONADI)
Local    Char    WCPY(GLONCPY)
Local    Integer I, K, DIFF_LEG
Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5)

  Raz [F:TCS]
  If [M:CSI0]TCS<>"" Then
    Call LECTURE("TCS",[M:CSI0]TCS,"") From CONTOBJ
  Endif

  If GREP<>"C"
    WLEG    = GCURLEG
    WCPY    = GSOCIETE
  Else
    If GCURLEG = ""
      WLEG=GLEGFIL
    Else
      WLEG=GCURLEG
    Endif
    WCPY    = [F:TCS]CPY
  Endif
  If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
  If clalev([F:ACC])=0    : Local File ACCES    [ACC]   : Endif
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
  #If clalev([F:TCS])=0    : Local File COURSEI [TCS]    : Endif
  [M:CSI1]FLGSELCTR = 0
  [M:CSI1]FLGSELEMP = 0

  If [M:CSI1]STRDAT<>[0/0/0]
    L_DAT1 = [M:CSI1]STRDAT
    L_DAT2 = [M:CSI1]STRDAT
  Else
    L_DAT1 = date$
    L_DAT2 = date$
  Endif

  Raz [F:HRCTR] # SEGAY 26/06/12 81085 US500
  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  Raz [F:ILEG]
  # Je ne veux que les contrat qui ne sont pas sortis de la société
#  Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
#&                   [F:FCY]FCY0=[F:HRCTR]ETRFCY,
#&                   [F:ACC]CODACC = GUSER;[F:ID]CODACS,
#&                   [F:CPY]CPY0=[F:FCY]LEGCPY
#&                As [NEW1]
#&             Where [F:HRCTR]CTRDAT<=L_DAT1 and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=L_DAT1)
#&               & (GUSRACS = 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) ))
#&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:FCY]LEGCPY = WCPY))
##&               & ([M:CSI0]TCS="" | [F:TCS]CPY="" | [F:FCY]LEGCPY = [F:TCS]CPY)

  CRITERECPY="(1=1"
  If WCPY<>"" Then
    I=0 : Call CALC_GRPCPY(WCPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then : # C'est un groupe de sociétés
      CRITERECPY -= "& find([F:ILEG]LEGCPY,"
      For K=0 To I-1
        CRITERECPY += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERECPY += "," : Endif
      Next
      CRITERECPY += ")>0"
    Else
      CRITERECPY -= " & ([F:ILEG]LEGCPY ='"+WCPY+"')"
    Endif
  Endif
  CRITERECPY += ")"

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  Link [F:ILEG] With [F:ACC]CODACC = GUSER;[F:ILEG]CODACS,
&                    [F:CPY]CPY0=[F:ILEG]LEGCPY
&                As [NEW1]
&             Where [F:ILEG]CTRDAT<=L_DAT1 and ([F:ILEG]XITDAT=[0/0/0] | [F:ILEG]XITDAT>=L_DAT1)
&               & (GUSRACS = 2 | ( ([F:ILEG]CODACS="" or [F:ACC]CONSUL=2) & find([F:ILEG]ETRSRV,GAUTSRV(1..GNBSERV)) ))
&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | evalue(CRITERECPY)))
#&               &   [F:ILEG]REFNUM>=VALEUR
#&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:ILEG]LEGCPY = WCPY))

  TIT(0)  = mess(245,10717,1) : # Choix du salarié
  Default File [NEW1]

  NBCOL = 0
  CODFIC = "EMPLOID"
  # Colonne Matricule
#  NBCOL += 1 : COL(NBCOL) = "REFNUM"        : Gosub TEXTE : COL(NBCOL)="[F:ID]REFNUM"
  NBCOL += 1 : COL(NBCOL) = "REFNUM"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]REFNUM"
  # Colonne Nom
#  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1)    :               COL(NBCOL)="[F:ID]NAM"
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1)    :               COL(NBCOL)="[F:ILEG]NAM"
  # Colonne Prénom
#  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  :               COL(NBCOL)="[F:ID]SRN"
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  :               COL(NBCOL)="[F:ILEG]SRN"

  CODFIC = "EMPLOCTR"
  # Colonne Contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRNUM"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRNUM"
  NBCOL += 1 : COL(NBCOL) = "CTRNUM"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]CTRNUM"
  # Colonne Date du contrat
#  NBCOL += 1 : COL(NBCOL) = "CTRDAT"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRDAT"
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]CTRDAT"
  # Colonne Date de sortie
#  NBCOL += 1 : COL(NBCOL) = "XITDAT"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]XITDAT"
  NBCOL += 1 : COL(NBCOL) = "XITDAT"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]XITDAT"

  CODFIC = "EMPLOID"
  # Colonne Société
#  NBCOL += 1 : COL(NBCOL) = "CPY"           : Gosub TEXTE : COL(NBCOL)="[F:FCY]LEGCPY"
  NBCOL += 1 : COL(NBCOL) = "CPY"           : Gosub TEXTE : COL(NBCOL)="[F:ILEG]LEGCPY"
  # Colonne Site
#  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)      :               COL(NBCOL)="[F:FCY]FCY"
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)      :               COL(NBCOL)="[F:ILEG]FCYID"
  # Colonne Emploi type
  CODFIC = "EMPLOCTR"
#  NBCOL += 1 : COL(NBCOL) = "JOBPOT"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]JOBPOT"
  NBCOL += 1 : COL(NBCOL) = "JOBPOT"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]JOBPOT"
  # Colonne Poste
#  NBCOL += 1 : COL(NBCOL) = "POT"           : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]POT"
  NBCOL += 1 : COL(NBCOL) = "POT"           : Gosub TEXTE : COL(NBCOL)="[F:ILEG]POT"
  # Colonne Service
#  NBCOL += 1 : COL(NBCOL) = "ETRSRV"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]ETRSRV"
  NBCOL += 1 : COL(NBCOL) = "ETRSRV"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]ETRSRV"
  # Colonne Profil
#  NBCOL += 1 : COL(NBCOL) = "PROPRF"        : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]PROPRF"
  NBCOL += 1 : COL(NBCOL) = "PROPRF"        : Gosub TEXTE : COL(NBCOL)="[F:ILEG]PROPRF"
  # Colonne Sortie définitive
#  NBCOL += 1 : COL(NBCOL) = "XITFNL"        : Gosub TEXTE : COL(NBCOL)="mess([F:HRCTR]XITFNL,1,1)"
  NBCOL += 1 : COL(NBCOL) = "XITFNL"        : Gosub TEXTE : COL(NBCOL)="mess([F:ILEG]XITFNL,1,1)"

#  [L]ORDRE = "[F:ID]REFNUM;[F:ID]NAM;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT"
#  [L]EXPSTART = "[F:ID]REFNUM>='"+VALEUR+"'"
#  [L]START = "[F:HRCTR]CTRDAT"
  [L]ORDRE = "[F:ILEG]REFNUM;[F:ILEG]NAM;[F:ILEG]LEGCPY;[F:ILEG]FCYID;[F:ILEG]CTRNUM;[F:ILEG]CTRDAT"
  [L]EXPSTART = "[F:ILEG]REFNUM>='"+VALEUR+"'"
  [L]START = "[F:ILEG]CTRDAT"
  [L]DEFPAG = 1    :# To have page up and page down
Return
$TEXTE
  Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return
# SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
#**
#* Avant exécution du bouton Tunnel Inscription
#* Tunel uniquement si FLGINS(ML464) > 2 3=Inscription 4=Réalisée
#*!
$AB2_NBLIG
#----------------------------------#
# Avant exécution du bouton Tunnel #
#----------------------------------#
Local Char WCLE2(20)(0..1)
Local Char WCLE1(20)
Local Char WOBJET(4)
# On ne connait pas le code session, donc lecture de l'inscription à partir de la demande
Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=[M:CSI1]REFNUM & [F:DML]CTRNUM=[M:CSI1]CTR & [F:DEM]CODCSI=[M:CSI0]COD & [F:DEM]STG=[M:CSI2]STG(nolign-1) & [F:DEM]ORIDEM=2
If rowcount([F:DM_])<>0 Then : # on regarde si la demande existe déjà
  Read [F:DM_] First
  Call LECTURE("DEM",[F:DML]DEMNUM, "") From CONTOBJ
  Filter [F:INS] Where STG=[M:CSI2]STG(nolign-1)and REFNUM=[M:CSI1]REFNUM and DEM=[F:DML]DEMNUM Order By Key
  Read [F:INS] First
  Filter [F:INS]
  If !fstat
   WOBJET="INS" : WCLE1=num$([M:CSI1]REFNUM) : WCLE2(0)=[F:INS]SES
  Endif
Endif
Return

# SEGAY - 29/12/10 - Bug  70243 LOT P24 - V6.1
#**
#* Avant exécution du bouton Tunnel Inscription
#* Tunel uniquement si FLGINS(ML464) > 2 3=Inscription 4=Réalisée
#*!
$AB3_NBRDEM
#----------------------------------#
# Avant exécution du bouton Tunnel #
#----------------------------------#
Local Char WCLE2(20)(0..1)
Local Char WCLE1(20)
Local Char WOBJET(4)
# On ne connait pas le code session, donc lecture de l'inscription à partir de la demande
Call LECTURE("DEM", [M:CSI5]DEMNUM(nolign-1), "") From CONTOBJ
Filter [F:INS] Where STG=[M:CSI5]STG(nolign-1)and REFNUM=[M:CSI1]REFNUM and DEM=[M:CSI5]DEMNUM(nolign-1) Order By Key
Read [F:INS] First
Filter [F:INS]
If !fstat
 WOBJET="INS" : WCLE1=num$([M:CSI1]REFNUM) : WCLE2(0)=[F:INS]SES
Endif
Return

$MOD_VAL
If [M:CSI4]ORICPCVAL(nolign-1) <> 6  Then # ML 2402 Parcours
  [M:CSI4]ORICPCVAL(nolign-1) = len(mess(0,10939,1)) : # ML 2402 Manuelle
Endif
[M:CSI4]FLGMODVAL(nolign-1) = 2
Affzo [M:CSI4]ORICPCVAL(nolign-1),FLGMODVAL(nolign-1)
Return

# US 2323 94656 in modif or duplic REFNUM et CTRNUM isn't seisable
$GRISE
If GREP = "M" # US 2323 94656
  Diszo [M:CSI1]REFNUM
  Diszo [M:CSI1]CTR
Endif
Return
# US 2323 94656 <> modif or duplic REFNUM is seisable
$DEGRISE
Actzo [M:CSI1]REFNUM
Call GRISE_CTR([F:ID]FLGMULCTR)
Return

################################################################################
## Sélection d'un no de contrat + Poste Emploi type
################################################################################
Subprog SELCTR(MATRI,DAT1,DAT2,PAMREFNUM,CTRNUMERO)
Value    Char MATRI
Value    Date DAT1, DAT2
Value    Integer PAMREFNUM
Variable Char CTRNUMERO()
Local Integer NBCTR , NUMCTR
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(130)(0..100)
Local Char    TIT(30)(0..100)
Local Char    CODFIC
Local Char    COL(30)(0..100)
Call SELCONTRATBASE(MATRI,DAT1,DAT2,TBCTR,LIBCTR,TIT,COL,NBCTR,1,PAMREFNUM)

# SBA 02/07/2012 refactoring


