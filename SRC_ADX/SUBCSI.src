#**
#* Test non bloquant de l'ordre, pour voir si date souhaitée est cohérente avec les autres stages
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Ordre
#*!
Subprog AM_ORDRE(VALEUR)
Variable Decimal VALEUR
Local Integer L_OK
Local Integer I #SEGAY 02/02/11 Bug 71227

L_OK = 0

#SEGAY 02/02/11 Bug 71227
#Controle si date et en cohérence avec l'ordre
If VALEUR<>0 & [M:CSI2]STRDATS(nolign-1) <> [0/0/0]
  For I=0 To nolign-2
   If [M:CSI2]STRDATS(I)<>[0/0/0] & [M:CSI2]ORDRE(I)<> 0 & [M:CSI2]ORDRE(I)<VALEUR & [M:CSI2]STRDATS(nolign-1) < [M:CSI2]STRDATS(I)
    # La date de début souhaitée du stage ../../.. devrait être supérieure ou égale à celle du stage ...
     PMESSAGE = mess(200,10717,1)-num$([M:CSI2]STRDATS(nolign-1))-mess(218,10717,1)-[M:CSI2]STG(I)-num$([M:CSI2]STRDATS(I))
     Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
     If L_OK = 1
       Break
     Endif
   Endif
   If [M:CSI2]STRDATS(I)<>[0/0/0] & [M:CSI2]ORDRE(I)<> 0 & [M:CSI2]ORDRE(I)>VALEUR & [M:CSI2]STRDATS(nolign-1) > [M:CSI2]STRDATS(I)
    # La date de début souhaitée du stage ../../.. devrait être inférieure ou égale à celle du stage ...
     PMESSAGE = mess(200,10717,1)-num$([M:CSI2]STRDATS(nolign-1))-mess(219,10717,1)-[M:CSI2]STG(I)-num$([M:CSI2]STRDATS(I))
     Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
     If L_OK = 1
       Break
     Endif
   Endif
  Next

  If L_OK = 1
     mkstat = 2 : End
  Endif

  For I=nolign To [M:CSI2]NBLIG-1
   If [M:CSI2]STRDATS(I)<>[0/0/0] & [M:CSI2]ORDRE(I)<> 0 & [M:CSI2]ORDRE(I)<VALEUR & [M:CSI2]STRDATS(nolign-1) < [M:CSI2]STRDATS(I)
    # La date de début souhaitée du stage ../../.. devrait être supérieure ou égale à celle du stage ...
     PMESSAGE = mess(200,10717,1)-num$([M:CSI2]STRDATS(nolign-1))-mess(218,10717,1)-[M:CSI2]STG(I)-num$([M:CSI2]STRDATS(I))
     Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
     If L_OK = 1
       Break
     Endif
   Endif
   If [M:CSI2]STRDATS(I)<>[0/0/0] & [M:CSI2]ORDRE(I)<> 0 & [M:CSI2]ORDRE(I)>VALEUR & [M:CSI2]STRDATS(nolign-1) > [M:CSI2]STRDATS(I)
    # La date de début souhaitée du stage ../../.. devrait être inférieure ou égale à celle du stage ...
     PMESSAGE = mess(200,10717,1)-num$([M:CSI2]STRDATS(nolign-1))-mess(219,10717,1)-[M:CSI2]STG(I)-num$([M:CSI2]STRDATS(I))
     Call AVERTIR(PMESSAGE,L_OK) From GESECRAN
     If L_OK = 1
       Break
     Endif
   Endif
  Next
  If L_OK = 1
     mkstat = 2 : End
  Endif
Endif
End
#**
#* Avant flag HTT tableau stage activation des lignes de stages
#*!
Subprog AS_FLGOWT(VALEUR)
Variable Integer VALEUR
If func DEM_STG_EXIST([M:CSI0]COD, [M:CSI1]REFNUM, [M:CSI1]CTR, [M:CSI2]STG(nolign-1)) Then
    mkstat = 2 : End
Endif
End
