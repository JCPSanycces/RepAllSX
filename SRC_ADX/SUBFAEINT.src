#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBFAEINT","FAEINT",4,"SPEFAEINT") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : # Batch mode
 When "INIT"         : Gosub OUVRE : # Interactive mode
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "CONT_BATCH"   : Gosub CONT_BATCH
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FAE])=0 : Local File FAEPAR     [FAE] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif

Local Char    TIT(200)
Local Char    PATH(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    VOLPATH(GDIMFIC)
Local Char    MACHINE(GDIMFIC), MACFIC(GDIMFIC), ODBGSTR(200)
Local Integer NBRLIN, OK, STAT, PERSTR
# Issue X3-59762 - 2017-11-06 by MWA : FIN variable not declared
Local Integer FIN

TIT = mess(334,107,1)

Local Mask FAEINT [DIA]
Raz [M:DIA]

Call GET_DERLU([M:DIA]IDT,"FAE","") From GOBJACT
If [M:DIA]IDT<>""
 Call AM_IDT([M:DIA]IDT)
 Call AP_IDT([M:DIA]IDT)
 Call C_CPY([M:DIA]CPY)
Endif
Setmok [M:DIA] With 0
Return

$DEBUT
If [M:DIA]IDT<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
 Call AP_FIYPER([M:DIA]FIYPER)
Endif
Affzo [M:DIA]
Return

$CONTROLE
If GSTATUT=GSTAESC
 FIN = 1 : Return
Endif
If !GSERVEUR
 Gosub CTRL_DATE
 If FIN = 1 : Return : Endif
Endif
TMP = 1
Return

$CONT_BATCH
If GSTATUT=GSTAESC
 FIN = 1 : Return
Else
 Gosub CTRL_DATE
 If FIN = 1 : Return : Endif
Endif
Return

$CTRL_DATE
If [M]CODPVT="ACCENTFILN"
 If dim(GUPDFNLPST)>0 and GUPDFNLPST=2
  fstat = 0
  If [F:ADW]PARAM <> "UPDFNLPST"
   Read [ADW]ADW1(1) = "UPDFNLPST"
  Endif
  If !fstat & [M]FIYSTR>=[F:ADW]CREDAT
   Call ERREUR(mess(633,199,1)) From GESECRAN
   FIN = 1 : Return
  Endif
 Endif
Else
 If dim(GUPDFNLPST)>0 and GUPDFNLPST=2
  fstat = 0
  If [F:ADW]PARAM <> "UPDFNLPST"
   Read [ADW]ADW1(1) = "UPDFNLPST"
  Endif
  If !fstat & [M]FIYSTR<=[F:ADW]CREDAT
   OK = 1 : Call AVERTIR(mess(634,199,1),OK) From GESECRAN
   If OK<>2 : FIN = 1 : Return : Endif
  Endif
 Else
  Call ERREUR(mess(631,199,1)) From GESECRAN
  FIN = 1 : Return
 Endif
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
 Call TRACE_MASQUE("FAEINT","DIA",nomap) From GTRAITE
Endif
Call ECR_TRACE(string$(100,"="),0) From GESECRAN

Call TEMPON(mess(3,100,1)) From GESECRAN

Call TRT_FAE('FAE', [M]IDT, [M]CODPVT, [M]LEDTYP, [M]CPY, [M]FIYNUM, [M]PERSTR, [M]PEREND, NBRLIN, OK) From PITFAE
Gosub TRF_FILES

Call ECR_TRACE(mess(3,7710,1)-":"-num$(NBRLIN), 0) From GESECRAN
If [M]TYPEXP=1
 Call ECR_TRACE(mess(178,115,1), 0) From GESECRAN
Else
 Call ECR_TRACE("|"+mess(104,121,1)-VOLPATH, 0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$SET_FILENAME
Call MACHINE([M:DIA]DRTWRK,MACHINE,MACFIC) From ORDSYS

## PATH contains the path of the temporary file generated in the current application,
## in the 'tmp' directory and with the 'pitfae' Extension
PATH = filpath("tmp",tolower([M:DIA]IDT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitfae")

Call LEC_CPY([M:DIA]CPY) From CPTLEC
Read [FIY]FIY0=[M:DIA]CPY;[M:DIA]LEDTYP;[M:DIA]FIYNUM
FICHIER = [F:CPY]CRN+"FEC"+num$(format$("D:YYYYMMDD",[F:FIY]FIYEND))
If [M:DIA]PERSTR<>[0/0/0]
 Filter [PER] Where CPY=[M:DIA]CPY and LEDTYP=[M:DIA]LEDTYP and FIYNUM=[M:DIA]FIYNUM and PERSTR=[M:DIA]PERSTR
 Read [PER] First
 [L]PERSTR = [F:PER]PERNUM
 FICHIER += "_"+string$(2-len(num$([F:PER]PERNUM)), "0")+num$([L]PERSTR)
 Filter [PER] Where CPY=[M:DIA]CPY and LEDTYP=[M:DIA]LEDTYP and FIYNUM=[M:DIA]FIYNUM and PEREND=[M:DIA]PEREND
 Read [PER] First
 Filter [PER]
 If [F:PER]PERNUM<>[L]PERSTR
  FICHIER += string$(2-len(num$([F:PER]PERNUM)), "0")+num$([F:PER]PERNUM)
 Endif
Endif
If right$([M:DIA]VOLFIL, len([M:DIA]VOLFIL))<>"/" : [M:DIA]VOLFIL += "/" : Endif
VOLPATH = [M:DIA]VOLFIL+FICHIER+".txt"
FICHIER = filpath([M:DIA]DRTWRK, FICHIER, "txt", "", "", MACHINE)
Return

$TRF_FILES
Gosub SET_FILENAME
If [M:DIA]TYPEXP=1
 If left$(FICHIER,2)="#@"
  FICHIER = right$(FICHIER,3)
 Endif
 Call COPCLI(PATH,FICHIER,STAT) From ORDSYS
Elsif [M:DIA]TYPEXP=2
 Call MOVE_EMPTY(PATH,FICHIER,STAT) From ORDSYS
Endif
Return

$TERMINE
If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SEL_TABLE
Case COUZON
 When "PERSTR" : Gosub S_PER
 When "PEREND" : Gosub S_PER
 When Default
Endcase
Return

$FIN_TABLE
Default File ODBGSTR
Return

$S_PER
ODBGSTR = dbgstr(2)
Default File [PER]
CRITERE="[F:PER]CPY='"+[M]CPY+"' AND [F:PER]LEDTYP="+num$([M]LEDTYP)+" AND [F:PER]FIYNUM="+num$([M]FIYNUM)

NBCOL=1
TIT(0)=mess(18,100,1) # window title
If PARAM(1)="PERSTR"
 TIT(1)=mess(54,108,1) # column title
Else
 TIT(1)=mess(55,108,1) # column title
Endif

COL(1)= PARAM(1) # column value
Return

Subprog C_IDT(VALEUR)
Variable Char    VALEUR()
Read [FAE]FAE0=VALEUR
If fstat
 GMESSAGE=mess(13,7710,1)-"("+VALEUR+")"
 mkstat = 2 : End
Endif
End

Subprog AM_IDT(VALEUR)
Variable Char    VALEUR()
Read [FAE]FAE0=VALEUR
If !fstat
 [M:DIA]=[F:FAE]
 If [M:DIA]VOLFIL<>"" & left$([M:DIA]VOLFIL,1)="["
  [M:DIA]TYPEXP = 2 : # Server
 Else
  If GBATCH
   [M:DIA]TYPEXP = 2
  Else
   [M:DIA]TYPEXP = 1
  Endif
 Endif
 Affzo [M:DIA]
 Call AM_TYPEXP([M:DIA]TYPEXP)
 Call AP_FIYPER([M:DIA]FIYPER)
Endif
End

Subprog AP_IDT(VALEUR)
Variable Char    VALEUR()
Affzo [M:DIA]
Setmok [M:DIA] With 0
Call SET_DERLU("FAE",VALEUR) From GOBJACT
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else Raz [M]VOLFIL : Grizo [M]VOLFIL
 Endif
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M:DIA]VOLFIL = [F:FAE]VOLFIL
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog C_FIYNUM(VALEUR)
Variable Decimal VALEUR
If [F:FIY]CPY<>[M]CPY or [F:FIY]LEDTYP<>[M]LEDTYP or [F:FIY]FIYNUM<>VALEUR : Read [FIY]FIY0=[M]CPY;[M]LEDTYP;VALEUR : Endif
If fstat : GMESSAGE=mess(7,101,1) : mkstat=2 : End : Endif
If [M]FIYPER=1 and [F:FIY]FIYSTA<>3 : GMESSAGE=mess(108,107,1) : mkstat=2 : End : Endif
[M]FIYSTR = [F:FIY]FIYSTR
[M]FIYEND = [F:FIY]FIYEND
Affzo [M]FIYSTR, FIYEND
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call LECLEDMAIN(1, VALEUR, [M]LEDTYP) From CPTDIV
End

Subprog C_PERSTR(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]FIYSTR or VALEUR>[M]FIYEND
 GMESSAGE=mess(53,116,1) : mkstat=2 : End
Endif
Filter [PER] Where CPY=[M]CPY & LEDTYP=[M]LEDTYP & FIYNUM=[M]FIYNUM & PERSTR<=VALEUR
Read [PER]PER0 Last
Filter [PER]
If fstat=4
 GMESSAGE=mess(73,104,1)
 mkstat=2
 End
Endif
VALEUR=[F:PER]PERSTR
End

Subprog C_PEREND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]FIYSTR or VALEUR>[M]FIYEND
 GMESSAGE=mess(53,116,1) : mkstat=2 : End
Endif
Filter [PER] Where CPY=[M]CPY & LEDTYP=[M]LEDTYP & FIYNUM=[M]FIYNUM & PEREND>=VALEUR & PEREND>=[M]PERSTR
Read [PER]PER0 First
Filter [PER]
If fstat=4
 GMESSAGE=mess(14,101,1)
 mkstat=2
 End
Endif
VALEUR=[F:PER]PEREND

Filter [PER] Where CPY=[M]CPY & LEDTYP=[M]LEDTYP & FIYNUM=[M]FIYNUM & PERSTR>=[M]PERSTR & PEREND<=VALEUR & PERSTA<>3
If rowcount([PER])>0
 Filter [PER] : GMESSAGE=mess(69,107,1) : mkstat=2 : End
Endif
Filter [PER]
End

Subprog AP_FIYPER(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]PERSTR, PEREND
 Grizo [M:DIA]PERSTR, PEREND
Else
 Actzo [M:DIA]PERSTR, PEREND
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CRN="" : GMESSAGE=mess(21,122,1) : mkstat=2 : End : Endif
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End

