Subprog C_COMPTEUR(VALEUR)
Variable Char    VALEUR()
If clalev([F:ANM])=0 : Local File ACODNUM [ANM] : Endif
Read [ANM]ANM0 =VALEUR
#LIPET - 05-01-2017 - X3-12094 - START
Filter [ANM]
#LIPET - 05-01-2017 - X3-12094 - END
If !fstat & [F:ANM]LNG>GLONAUS
 GMESSAGE = mess(51,105,1) : # Compteur de longueur trop grande
 mkstat = 2 : End
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#LIPET - 05-01-2017 - X3-12094 - START
If clalev([F:CPY1])=0  : Local File COMPANY [CPY1] : Endif

If VALEUR <> ""
  Filter [CPY1] Where CPY=VALEUR
  Read [CPY1] First
  Filter [CPY1]
  If !fstat
   GCURLEG = [CPY1]LEG
  Endif
Endif
#LIPET - 05-01-2017 - X3-12094 - END
End

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 05-01-2017 - X3-12094 - START
 If GCURLEG = ""
  GCURLEG = VALEUR
 Endif
#LIPET - 05-01-2017 - X3-12094 - END
End


