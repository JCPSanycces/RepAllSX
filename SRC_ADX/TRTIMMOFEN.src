#================
#
$OK_FASADV
  # FQ75616

  # Récupération des informations  du bien.
  nolign = G_NOL
  [M:FAS3] = [M:FASA]

  # Reprise avancée
  [M:FAS3]BREPRISE(nolign-1) = 1

  Affzo [M:FAS3]

  If (G_ACTCCN=G_OUI) : # FQ107991
    [M:FAS6] = [M:FASA]
    Affzo [M:FAS6]
  Endif

  If !GIMPORT
    mkstat = 4
    G_ARECALCULER = 1
    FIN=1
  Endif
Return
#================
#
$OK_FASRST
  # FQ59941 FQ80825
  # Mise à jour des plans dans FAS3
  For I_PLN = 1 To [M:FAS3]NBLIG1
  # Statut
    [M:FAS3]KSTPDEPSTA(I_PLN-1) = [M:FASB]KSTPDEPSTAN(I_PLN-1) : Affzo [M:FAS3]KSTPDEPSTA(I_PLN-1)
  Next

  #-1 ---------------------------------------------
  If ([M:FPC]LEG = "RUS" )  Then
  # Nombre de mois d'arrêt
  If clalev([F:DEPW])=0    : Local File DEPREC        [DEPW]   : Endif
  Local Integer N_I
  # Positionnement sur le plan comptable
  N_I = find(G301CPT, [M:FAS3]DPRPLN)
  Local Date PDTDBAMT :  PDTDBAMT = [M:FAS3]STRDPRDAT(N_I-1)
  Local Date PDATMES  :  PDATMES  = [M:FAS1]ITSDAT
  Local Date RDTDBAMTREG
  Gosub DEB_AMT_MODES_RUSSES From GLOBB8

  Local Integer B_DEBUT
  If ( RDTDBAMTREG <= [M:FAS3]PERENDDAT(N_I-1) ) Then
    # Le bien est effectivement amorti sur le plan comptable
    If ( [M:FAS2]KPSEPLN <> "" ) Then
      # Lecture du plan de saisonnalité
      If clalev([F:PSE]) =0 : Local File PSEPLN    [PSE]  : Endif      : # Société
      Read [F:PSE]PSE0= [M:FAS0]CPY;[M:FAS2]KPSEPLN
      If (fstat) Then
        Read [F:PSE]PSE0= "";[M:FAS2]KPSEPLN
      Endif
    Endif

    #>>>>>>>>
    For N_I = 1 To [M:FAS3]NBLIG1
      # Pour les plans du contexte fiscal & comptable (hors mode UR)
        If ([M:FAS3]CNX(N_I-1) = G300CPFI and
&         find([M:FAS3]DPM(N_I-1), G_DPMLR, G_DPMCR, G_DPMSR, G_DPMDR) <> 0) Then
        B_DEBUT = 0
        If (RDTDBAMTREG = [M:FAS3]PERSTRDAT(N_I-1)) Then
          # Période de début d'amortissement
          B_DEBUT = 1
        Else
          # Lecture du DEPREC  (Pc-1)
          Read [DEPW]DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(N_I-1);[M:FAS3]FIYENDDAT(N_I-1);[M:FAS3]PERENDDAT(N_I-1)
          Read [DEPW]DEP0 Prev
          If ( fstat <> 0 ) Then
            # L'enregistement n'existe pas
            B_DEBUT = 1
          Elsif (fstat = 0 ) Then
            # L'enregistement existe
            If ([F:DEPW]FIYENDDAT <> [M:FAS3]FIYENDDAT(N_I-1))Then
              # Pas dans l'exericce courant ( période courante = 1ère période de l'exercice )
              B_DEBUT = 1
            Endif
          Endif
        Endif
        Gosub ENTRETENIR_KFIYNBMSTP
      Endif
    Next N_I
    #>>>>>>>>
  Endif
  Endif
  #-1 ---------------------------

  If !GIMPORT
    G_ARECALCULER = 1
    mkstat = 4
    FIN=1
  Endif
Return

$ENTRETENIR_KFIYNBMSTP

  #- 0 -----------------------------------
  If (B_DEBUT) Then
    # --
    # Intialisation
    # --
    # FQ80825
    If ( find([M:FAS3]KSTPDEPSTA(N_I-1), GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0) Then
      # Arrêt
      [M:FAS3]KFIYNBMSTP(N_I-1) = 0
      If ( [M:FAS2]KPSEPLN <> "" and val(mid$([M:FAS2]KSESFLG, [M:FAS3]DPRPLN(N_I-1), 1)) = G_OUI) Then
        # Saisonnalité applicable au plan
        If ( [F:PSE]ACTFLG(month([M:FAS3]PERSTRDAT(N_I-1))-1) = G_OUI ) Then
          # La période est active
          [M:FAS3]KFIYNBMSTP(N_I-1) = 1
        Endif
      Else
        # Pas de saisonnalité pour le plan
        [M:FAS3]KFIYNBMSTP(N_I-1) = 1
      Endif
    Else
      # Redemarrage
      [M:FAS3]KFIYNBMSTP(N_I-1) = 0
    Endif
  #- 0 -----------------------------------
  Else
    # --
    # Incrémént
    # --
    # FQ80825
    If ( find([M:FAS3]KSTPDEPSTA(N_I-1) , GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0) Then
      # Arrêt
      [M:FAS3]KFIYNBMSTP(N_I-1) = [F:DEPW]KFIYNBMSTP
      If ( [M:FAS2]KPSEPLN <> "" and val(mid$([M:FAS2]KSESFLG, [M:FAS3]DPRPLN(N_I-1), 1)) = G_OUI) Then
        # Saisonnalité applicable au plan
        If ( [F:PSE]ACTFLG(month([M:FAS3]PERSTRDAT(N_I-1))-1) = G_OUI ) Then
          # La période est active
          [M:FAS3]KFIYNBMSTP(N_I-1) = [F:DEPW]KFIYNBMSTP + 1
        Endif
      Else
        # Pas de saisonnalité pour le plan
        [M:FAS3]KFIYNBMSTP(N_I-1) = [F:DEPW]KFIYNBMSTP + 1
      Endif
    Else
      # Redemarrage
      [M:FAS3]KFIYNBMSTP(N_I-1) = [F:DEPW]KFIYNBMSTP
    Endif
  Endif
  #- 0 -----------------------------------
Return

