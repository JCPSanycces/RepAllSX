#
$SETBOUT_FASISR
  If [M:FAS0]ISSFIYPRE = G_OUI
    Call VIREBOUT(CHBOU,"GSTAOK") From GOBJET
    Gosub SET_BOUT_STD From GSAISIE
  Endif
Return

#================ FQ33140
#
$SETBOUT_FASVEH
  If ([M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]ISSDAT < GDEBEXECPF) or ([M:FAS0]ISSFIYPRE = G_OUI)
    Call VIREBOUT(CHBOU,"GSTAOK") From GOBJET
    Gosub SET_BOUT_STD From GSAISIE
  Endif
Return

#================
#
$SETBOUT_FASNSP
  #If (LACCID = G_OUI ) Then : # FQ33140
  If (LACCID = G_OUI ) or ([M:FAS0]ISSFIYPRE = G_OUI) Then
    Call VIREBOUT(CHBOU,"GSTAOK") From GOBJET
    Gosub SET_BOUT_STD From GSAISIE
  Endif
Return

#================
#
$APRES_MODIF_FASADV
  # FQ75616
  REP="M"
Return

