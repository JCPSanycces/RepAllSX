$OK_FASDUR
  # FQ59941
  Local Integer BIDINT
  Local Decimal DUREE
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("M", DUREE, [M:FASU]DPRDURMON, DUREE, DUREM ) From GLOBI9
  VALEUR = DUREE
  zonsui = "[M:FAS3]DPRDUR"
  If !GIMPORT
    mkstat = 4
    FIN=1
  Endif
Return

