  If !GIMPORT
    mkstat = 4
    FIN=1
  Endif
Return

#================
#
$OK_FASVEH
  # Affectation pour mise à jour en sortie.
  [M:FAS8] = [M:FASV]
  #*Fq-76430 Si Maj coeff. admission après maj VEHTYP
  If dim(GMAJCOE)>0    #*Fq-80049
  If GMAJCOE = G_OUI and GVALCOE <> [M:FAS1]ADMCOE
     [M:FAS1]ADMCOE = GVALCOE
     Affzo [M:FAS1]ADMCOE
     Call AM_ADMCOE([M:FAS1]ADMCOE) From SUBFAS
  Endif
  Endif
  If !GIMPORT
    mkstat = 4
    FIN=1
  Endif

Return

#================
#
$OK_FASNSP
  # Affectation pour mise à jour en sortie.
  For nolign = 1 To [M:FASN]NBLIG1
    [M:FAS3]NSPVAL(nolign-1) = [M:FASN]NSPVAL(nolign-1)
  Next nolign

  If !GIMPORT
    mkstat = 4
    FIN=1
  Endif
Return

#================
#
$OK_FASDPE

  # Affectation pour mise à jour en sortie.
  # Récupération des informations  du bien.
  [M:FAS3]ENDDPEFLG(G_NOL-1) = [M:FASD]ENDDPEFLG
  [M:FAS3]ENDDPE(G_NOL-1)    = [M:FASD]ENDDPE

  # FQ59941
  # Si le bien n'a pas été déprecié : Suivi Réel et Théorique en phase
  If ( [M:FAS3]IMLBLC(G_NOL-1)= 0 ) Then
    [M:FAS3]ENDDPET(G_NOL-1)= [M:FASD]ENDDPE
    # Si le bien n'a été ni déprécié ni réévalué  Suivi Réel, Théorique, Inital en phase
    If ( [M:FAS3]BSEVAL(G_NOL-1) = [M:FAS3]DPRBAS(G_NOL-1) and
&        [M:FAS3]DPRCUM(G_NOL-1) = [M:FAS3]EXECLOCUMI(G_NOL-1) and [M:FAS3]PERCLOCUM(G_NOL-1) = [M:FAS3]PERCLOCUMI(G_NOL-1) ) Then
      [M:FAS3]ENDDPEI(G_NOL-1)= [M:FASD]ENDDPE
    Endif
  Endif

  If !GIMPORT
    mkstat = 4
    G_ARECALCULER = 1
    FIN=1
  Endif
Return

