#    Modification
# GLE   12.05.2015 FQ107991  : Erreur si code activité CCN à Non
# MDJ   30.09.2014 FQ86292   : Taxe VEH FY2014
# MWA   24.10.2012 FQ75616   : Reprise avancée
# MDJ   05.09.2012 FQ80049   : Taxe VEH : changement taux et puissance (pb annexe sur GMAJCOE)
# MWA   13.06.2012 FQ80825   : Arrêt/Redémarrage modes roumains
# MDJ   22.09.2011 FQ76430   : appel à AM_ADMCOE après maj VEHTYP
# GLE   13.07.2011 FQ74815   : Pas de modification du Genre Véhicule si le bien est sorti
# GBO   03.03.2011 FQ67577   : Pologne - Modernisation
# MWA   01.09.2010 FQ59941   : Gestion des modes russes - Ajout de la possibilité de saisir une durée en mois
# GLE   30.03.2010 FQ33140   : les informations Véhicule ne doivent pas être modifiables si le bien est sorti
# MDJ   14.10.2009 FQ58084   : affichage fenêtre véhicule : diszo de certains champs
#*********************************************************************
#
$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT        : # Début
    When "SETBOUT"       : Gosub SETBOUT      : # Setbout
    When "APRES_MODIF"   : Gosub APRES_MODIF  : # Après modif
    When "OK"            : Gosub OK           : # OK
    When "ABA"           : Gosub ABA          : # Abandon
    When "FIN"           : Gosub FIN          : # Fin
    When Default
  Endcase
Return

#
#*********************************************************************
#

#================
#
$DEBUT
  Case GACTION
    When "FASADV"  : Gosub DEBUT_FASADV   : # FQ75616
    When "FASRST"  : Gosub DEBUT_FASRST   : # FQ59941
    When "FASDUR"  : Gosub DEBUT_FASDUR   : # FQ59941
    When "FASISR"  : Gosub DEBUT_FASISR
    When "FASVEH"  : Gosub DEBUT_FASVEH
    When "FASNSP"  : Gosub DEBUT_FASNSP
    When "FASDPE"  : Gosub DEBUT_FASDPE
    When "FASIVY"  : Gosub DEBUT_FASIVY
  Endcase
Return

#================
#
$SETBOUT
  Case GACTION
    When "FASRST"  : Gosub SETBOUT_FASRST : # FQ59941
    When "FASDUR"  : Gosub SETBOUT_FASDUR : # FQ59941
    When "FASNSP"  : Gosub SETBOUT_FASNSP
    When "FASISR"  : Gosub SETBOUT_FASISR
    When "FASVEH"  : Gosub SETBOUT_FASVEH
  Endcase
Return

#================
#
$APRES_MODIF
  Case GACTION
    When "FASADV"  : Gosub APRES_MODIF_FASADV  : # FQ75616
    When "FASRST"  : Gosub APRES_MODIF_FASRST  : # FQ59941
    When "FASDUR"  : Gosub APRES_MODIF_FASDUR  : # FQ59941
    When "FASISR"  : Gosub APRES_MODIF_FASISR
    When "FASVEH"  : Gosub APRES_MODIF_FASVEH
    When "FASNSP"  : Gosub APRES_MODIF_FASNSP
    When "FASDPE"  : Gosub APRES_MODIF_FASDPE
    When "FASIVY"  : Gosub APRES_MODIF_FASIVY
  Endcase
Return

#================
#
$OK
  Case GACTION
    When "FASADV"  : Gosub OK_FASADV   : # FQ75616
    When "FASRST"  : Gosub OK_FASRST   : # FQ59941
    When "FASDUR"  : Gosub OK_FASDUR   : # FQ59941
    When "FASISR"  : Gosub OK_FASISR
    When "FASVEH"  : Gosub OK_FASVEH
    When "FASNSP"  : Gosub OK_FASNSP
    When "FASDPE"  : Gosub OK_FASDPE
    When "FASIVY"  : Gosub OK_FASIVY
  Endcase
Return

#================
#
$ABA
  Case GACTION
    When "FASADV"  : Gosub ABA_FASADV   : # FQ75616
    When "FASDUR"  : Gosub ABA_FASDUR   : # FQ59941
    When "FASISR"  : Gosub ABA_FASISR
    When "FASVEH"  : Gosub ABA_FASVEH
    When "FASNSP"  : Gosub ABA_FASNSP
    When "FASDPE"  : Gosub ABA_FASDPE
    When "FASIVY"  : Gosub ABA_FASIVY
  Endcase
Return

#================
#
$FIN
  Case GACTION
    When "FASADV"  : Gosub FIN_FASADV   : # FQ75616
    When "FASRST"  : Gosub FIN_FASRST   : # FQ59941
    When "FASDUR"  : Gosub FIN_FASDUR   : # FQ59941
    When "FASDPE"  : Gosub FIN_FASDPE
  Endcase
Return

#================
#
$DEBUT_FASADV
  # FQ75616
  Global Integer G_NOL

  If (GIMPORT) Then
    If (SEPNUM = 4) Then
      G_NOL = find ( G_CCNPLNCAD, [M:FAS3]DPRPLN )
    Else
      G_NOL = nolign
    Endif
  Else
    G_NOL = val(PARAM(1))
  Endif

  # Récupération des informations  du bien.
  nolign = G_NOL
  [M:FASA]    = [M:FAS3]

  If (G_ACTCCN=G_OUI) : # FQ107991
    [M:FASA]  = [M:FAS6]
  Endif

  # Alimentation par défaut des champs en création
  Gosub LOAD_VAL_MSK_FROM_FAS From SUBFASA

  # Conditionnement des champs de l'écran FASADV
  Gosub COND_MSK_FIELDS From SUBFASA

  Affzo [M]1-99
Return
#================
#
$DEBUT_FASRST
  # FQ59941
  Global Char    G_REP : G_REP = GREP

  #--------------
  [M:FASB]PERSTRDAT = [M:FAS3]PERSTRDAT(0)
  [M:FASB]PERENDDAT = [M:FAS3]PERENDDAT(0)
  Local Integer I_P : IP = 0
  nolign = 0
   For I_P = 1 To [M:FAS3]NBLIG1
    If ( [M:FAS3]CNX(I_P-1) = G300CPFI ) Then
      nolign += 1
      [M:FASB]DPRPLN(nolign-1)    = [M:FAS3]DPRPLN(I_P-1)
      [M:FASB]DPM(nolign-1)       = [M:FAS3]DPM(I_P-1)
      [M:FASB]PERENDDPE(nolign-1) = [M:FAS3]PERENDDPE(I_P-1)
      [M:FASB]KSTPDEPSTAO(nolign-1)  = [M:FAS3]KSTPDEPSTA(I_P-1) # FQ80825
      [M:FASB]KSTPDEPSTAN(nolign-1)  = [M:FAS3]KSTPDEPSTA(I_P-1) # FQ80825
   Endif
  Next I_P
  [M:FASB]NB_PCPF = nolign
  Affzo [M:FASB]1-99

  # Conditionnement des plans non concernés par l'Arrêt/Redémarrage
  IP = 0 : nolign = 0
  For I_P = 1 To [M:FAS3]NBLIG1
    If ( [M:FAS3]CNX(I_P-1) = G300CPFI ) Then
      nolign += 1
      If (find([M:FAS3]DPM(I_P-1),   G_DPMRL,G_DPMRX,G_DPMRD,G_DPMLR,G_DPMCR,G_DPMSR,G_DPMDR) = 0) Then
        [M:FASB]KSTPDEPSTAO(nolign-1)  = GVML_SSNOSTP
        [M:FASB]KSTPDEPSTAN(nolign-1)  = GVML_SSNOSTP
        Diszo [M:FASB]KSTPDEPSTAN(nolign-1)
      Endif
    Endif
  Next I_P

Return

#================
#
$DEBUT_FASDUR
  # FQ59941
  Global Integer G_NOL
  G_NOL = val(PARAM(1))
  Global Char    G_REP
  G_REP = GREP
  # Récupération des informations  du bien.
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:FAS3]DPRDUR(G_NOL-1), DUREM, [M:FAS3]DPRDUR(G_NOL-1), DUREM ) From GLOBI9
  [M:FASU]DPRDURMON = DUREM
  If (G_REP = "M") Then : Diszo [M:FASU]DPRDURMON : Endif
Return

#================
#
$DEBUT_FASISR
  # Récupération des informations assurance du bien.
  [M:FASI] = [M:FAS8]
  # conditionnement et affichage.
  If ( [M:FASI]ISRTYP = GVML_TAASSUR ) Then
    Call ACTION_BLOCK (ACB_DISZO, "FASISR", "ISRTYP") From GLOBIENS
    Actzo [M:FASI]ISRTYP
  Else
    Call ACTION_BLOCK (ACB_ACTZO, "FASISR", "ISRTYP") From GLOBIENS
  Endif

  # FQ33140 : Pas de saisie possible si le bien est sorti dans un exercice antérieur pour tous ses contextes
  If [M:FAS0]ISSFIYPRE = G_OUI
    Grizo [M]1-99
  Endif

  Call ACTION_BLOCK (ACB_AFFZO, "FASISR", "ISRTYP") From GLOBIENS
Return

#================
#
$DEBUT_FASVEH

Local Char LDES
Local Integer ERROR

  # Récupération des informations véhicule du bien.
  [M:FASV] = [M:FAS8]
  # Affichage du code type de taxe
  If ( [M:FASV]TAXPLI = 0) Then
    #*FQ86292 ==>  Plein tarif par défaut au lieu de exonéré  [M:FASV]TAXPLI = 3
    [M:FASV]TAXPLI = 1 # Plein tarif par défaut
  Endif
  Diszo  [M:FASV]VEHTAXTYP   #Fq-58084
  Diszo  [M:FASV]VEHCO2RAT   #Fq-58084
  # conditionnement et affichage.
  If ([M:FAS1]OWNTYP <> GVML_TDLOCAT ) Then
    Diszo [M:FASV]RNTSTRDAT : [M:FASV]RNTSTRDAT = [0/0/0]
    Diszo [M:FASV]RNTENDDAT : [M:FASV]RNTENDDAT = [0/0/0]
    Diszo [M:FASV]RNTMONDUR : [M:FASV]RNTMONDUR = 0
    Diszo [M:FASV]RNTDAYDUR : [M:FASV]RNTDAYDUR = 0
  Endif
  If (G_ACTLEA = G_OUI) Then
    # Le module Contrat Financement est actif
    If ([M:FAS2]LEAREF <> "" ) Then
      Read[LEA]LEA0 = [M:FAS2]LEAREF
      # Maj des dates de location uniquement s'il s'agit d'un véhicule
      If  !(fstat) and [M:FASV]NPL <> "" Then
        Diszo [M:FASV]RNTSTRDAT : [M:FASV]RNTSTRDAT = [F:LEA]STRLEADAT
        Diszo [M:FASV]RNTENDDAT : [M:FASV]RNTENDDAT = [F:LEA]ENDLEADAT
        Diszo [M:FASV]RNTMONDUR : [M:FASV]RNTMONDUR = 0
        Diszo [M:FASV]RNTDAYDUR : [M:FASV]RNTDAYDUR = 0
      Endif
    Endif
  Endif
  If ( [M:FASV]RNTSTRDAT = [0/0/0] and [M:FASV]RNTENDDAT = [0/0/0]  ) Then
    Diszo [M:FASV]RNTMONDUR : [M:FASV]RNTMONDUR = 0
    Diszo [M:FASV]RNTDAYDUR : [M:FASV]RNTDAYDUR = 0
  Endif

  # FQ33140 : Pas de saisie possible si le bien est sorti dans un exercice antérieur pour le contexte comptable et fiscal
  If ([M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]ISSDAT < GDEBEXECPF) or ([M:FAS0]ISSFIYPRE = G_OUI)
    Grizo [M]1-99
  Endif

  # FQ74815
  If ([M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]EXTISSFLG <> G_OUI )
    Grizo [M:FASV]VEHTYP
  Endif

  Affzo [M]1-99
Return

#================
#
$DEBUT_FASNSP
Local Integer LACCID

  # Récupération des informations.
  [M:FASN]NSPVALP = [M:FAS3]NSPVAL(0)
  [M:FASN]ACGCUR  = [M:FAS1]ACGCUR
  [M:FASN]RVAAPR  = [M:FAS0]RVAAPR
  [M:FASN]RVACMT  = [M:FAS0]RVACMT
  # Chargement du tableau
  For nolign = 1 To [M:FAS3]NBLIG1
    [M:FASN]DPRPLN(nolign-1) = [M:FAS3]DPRPLN(nolign-1)
    [M:FASN]CUR(nolign-1)    = [M:FAS3]CUR(nolign-1)
    [M:FASN]CURTYP(nolign-1) = [M:FAS3]CURTYP(nolign-1)
    [M:FASN]RATCUR(nolign-1) = [M:FAS3]RATCUR(nolign-1)
    [M:FASN]NSPVAL(nolign-1) = [M:FAS3]NSPVAL(nolign-1)
  Next nolign
  [M:FASN]NBLIG1 = [M:FAS3]NBLIG1
  # Affichage.
  Affzo [M:FASN]1-99
  # conditionnement
  For nolign = 1 To [M:FASN]NBLIG1
    # Type de cours, Cours de change et Valeur marché ne sont pas saisissables pour les plans
    # exprimés dans la devise société
    If ( [M:FASN]CUR(nolign-1) = GCOUDEV ) Then
      Diszo [M:FASN]CURTYP(nolign-1)
      Diszo [M:FASN]RATCUR(nolign-1)
      Diszo [M:FASN]NSPVAL(nolign-1)
    Endif
  Next nolign

  LACCID = G_NON
  For nolign = 1 To [M:FAS3]NBLIG1
    # La valeur marché ne peut pas être modifiée si le bien a subi une dépréciation ou
    # une réévaluation dans la période courante.
    #=============================
    If ([M:FAS3]IML(nolign-1) = 0 and [M:FAS3]IMLRVE(nolign-1) = 0  ) Then
      #===================
      If ( [M:FAS3]PERENDDAT(nolign-1) = [0/0/0] ) Then
        If ( [M:FAS3]RVADAT(nolign-1) >= [M:FAS3]FIYSTRDAT(nolign-1) and
&            [M:FAS3]RVADAT(nolign-1) <= [M:FAS3]FIYENDDAT(nolign-1) ) Then
          LACCID = G_OUI : Break 1
        Endif
      #===================
      Else
        If ( [M:FAS3]RVADAT(nolign-1) >= [M:FAS3]PERSTRDAT(nolign-1) and
&            [M:FAS3]RVADAT(nolign-1) <= [M:FAS3]PERENDDAT(nolign-1) ) Then
          LACCID = G_OUI : Break 1
        Endif
      Endif
      #===================
    Else
      LACCID = G_OUI : Break 1
    Endif
    #=============================
  Next nolign
  If ( LACCID = G_OUI ) Then
      Call ACTION_BLOCK (ACB_DISZO, "FASNSP", "NSPVALP") From GLOBIENS
      Call ACTION_BLOCK (ACB_DISZO, "FASNSP", "NBLIG1") From GLOBIENS
  Endif

  # FQ33140 : Pas de saisie possible si le bien est sorti dans un exercice antérieur pour tous ses contextes
  If [M:FAS0]ISSFIYPRE = G_OUI
    Grizo [M]1-99
    Affzo [M]1-99
  Endif
Return

#================
#
$DEBUT_FASDPE
  Global Integer G_NOL
  G_NOL = val(PARAM(1))

  # Récupération des informations  du bien.
  [M:FASD]DPRPLN    = [M:FAS3]DPRPLN(G_NOL-1)
  [M:FASD]CUR       = [M:FAS3]CUR(G_NOL-1)
  [M:FASD]FIYSTRDAT = [M:FAS3]FIYSTRDAT(G_NOL-1)
  [M:FASD]FIYENDDAT = [M:FAS3]FIYENDDAT(G_NOL-1)
  [M:FASD]PERSTRDAT = [M:FAS3]PERSTRDAT(G_NOL-1)
  [M:FASD]PERENDDAT = [M:FAS3]PERENDDAT(G_NOL-1)
  [M:FASD]ENDDPEFLG = [M:FAS3]ENDDPEFLG(G_NOL-1)
  [M:FASD]ENDDPE    = [M:FAS3]ENDDPE(G_NOL-1)
  [M:FASD]PERDPEFLG = [M:FAS3]PERDPEFLG(G_NOL-1)
  [M:FASD]PERENDDPE = [M:FAS3]PERENDDPE(G_NOL-1)
  [M:FASD]DPRBAS    = [M:FAS3]DPRBAS(G_NOL-1)   : # X3-42056

  # Interdiction de forcer la dotation exercice
  #
  If ( [M:FAS3]IML(G_NOL-1) <> 0  or [M:FAS3]IMLRVE(G_NOL-1) <> 0 ) Then
    # la dotation ne peut pas être forcée, Si dépréciation ou reprise de dépréciation sur la pér. cour.
    GMESSAGE = mess(593,7773,1)
    GERR = 1 : FIN = 1
    Return
  Endif
  If ( [M:FAS3]RVAAMT(G_NOL-1) <> 0  ) Then
    # La dotation ne peut pas être forcée, le bien a fait l'objet d'une réévaluation dans la pér. cour.
    GMESSAGE = mess(594,7773,1)
    GERR = 1 : FIN = 1
    Return
  Endif
  If ( [M:FAS3]MTCDPEDAT(G_NOL-1) <> [0/0/0]  ) Then
    # La dotation ne peut pas être forcée, le bien a fait l'objet d'un changement de méthode dans la pér. cour.
    GMESSAGE = mess(595,7773,1)
    GERR = 1 : FIN = 1
    Return
  Endif

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI & [M:FAS3]KMDRDEV(nolign-1)<>0
   # La dotation ne peut pas être forcée si une modernisation est en cours sur le plan d'amortissement
   GMESSAGE = mess(827,GML_MSGFAS,1)
   GERR = 1 : FIN = 1
  Endif
  #Fin-Pologne

  Affzo [M]1-99
Return

#================
#
$DEBUT_FASIVY
  # Récupération des informations assurance du bien.
  [M:FASY] = [M:FAS8]

  # conditionnement et affichage.
  Affzo [M:FASY]1-99
Return

#================
#
