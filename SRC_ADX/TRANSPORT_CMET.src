#######################################################################################
$SHIPT_GET_INDEX
#Value Shortint LIGNE
#Local Integer ARET_VALUE

  [L]ARET_VALUE = find(LIGNE,this.SHIPT(1..maxtab(this.SHIPT)).STLIN)
Return

#######################################################################################
# Mise à jour de la date de réception prévue sur les shipments
# Issue 111257 US 32- 2015-11-30 by MAE : mise à jour de toutes les infos stockées dans la table des expés
$UPD_SHIP
  Local  Instance WSHIPMENT Using C_SHIPMENT
  Local File SHIPMENT[SHH]

  #lecture de la classe
  Filter [SHH] Where TRNNUM = this.TRNNUM

  For [SHH]SHH0
    # MAE, bug 110733, allocation de la classe dans la boucle (vu aves LSE)
    WSHIPMENT = NewInstance C_SHIPMENT AllocGroup null
    WRET = fmet WSHIPMENT.AREAD([F:SHH]SHIPNUM)
    If WRET <> [V]CST_AOK
       [L]ASTATUS = fmet this.ASETERROR("SHIPMENT",mess(525,194,1),[V]CST_AERROR)
       FreeGroup WSHIPMENT
       Break
    Else
      WSHIPMENT.ARVEXPDAT = this.ARVEXPDAT
      WSHIPMENT.DPEDAT = this.DPEDAT
      WSHIPMENT.ARVDAT = this.ARVDAT
      WSHIPMENT.DPETPC = this.DPETPC
      WSHIPMENT.ARVTPC = this.ARVTPC
      WSHIPMENT.TRNMOD = this.TRNMOD
      WSHIPMENT.BPTNUM = this.BPTNUM
      WRET = fmet WSHIPMENT.AUPDATE()
      If WRET <> [V]CST_AOK
        [L]ASTATUS = fmet this.ASETERROR("SHIPMENT",mess(525,194,1),[V]CST_AERROR)
        FreeGroup WSHIPMENT
        Break
      Endif
    Endif
    # MAE, bug 110733, libération de la classe dans la boucle (vu aves LSE)
    FreeGroup WSHIPMENT
  Next
  Filter [SHH]
  # End issue 111257 US 32
Return
