$SHIPT_ADELLINE_AFTER
If func SYRCOLLECTION.SORTDEL(this, "TRKSORT", this.TRKSORT, "SHIPT", 10)<> CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("",func ASYRFNC.MES2(mess(273,133,1), 'SHIPT', 'TRANSPORT'), [V]CST_AERROR)
Endif
Return

