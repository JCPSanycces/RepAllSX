#######################################################################################
# Issue 111257 US 39
$TOT_LTI
Local Shortint WLTI, WOLDLTI
WLTI = 0 : WOLDLTI = 0

For I=1 To maxtab(this.EVT)
  # 1- Totalisation des délais sur les incidents et mise à jour du décalage
  If this.EVT(I) <> null and find(this.EVT(I).ASTALIN, [V]CST_ANEWDEL) < 1
    If this.EVT(I).snapshot.EVTLTI <> 0
      WOLDLTI += this.EVT(I).snapshot.EVTLTI
    Endif
    #les lignes supprimées ne sont pas rajoutées dans le total
    If this.EVT(I).EVTLTI <> 0 & find(this.EVT(I).ASTALIN, [V]CST_ADEL) < 1
      WLTI += this.EVT(I).EVTLTI
    Endif
  Endif
Next I
If WLTI<>0 | WOLDLTI<>0
  this.SHIPSLAG += WLTI - WOLDLTI
Endif
Return
# End issue 111257 US 39
