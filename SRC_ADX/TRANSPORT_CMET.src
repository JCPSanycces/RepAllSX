#######################################################################################
$EVT_ADDLINE_AFTER
  #INIT Key
  this.TRNNUM = this.APARENT.TRNNUM
  this.EVTNUM = 1 + max(this.APARENT.EVT(1..maxtab(this.APARENT.EVT)).EVTNUM)
Return

#######################################################################################
$AINSERT_CONTROL_BEFORE
Return

#######################################################################################
$ADELETE_BEFORE
  If this.TRNSTA <> 1
      WMESSAGE = mess(526,194,1)
      ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
      Return
  Endif
Return

#######################################################################################
$AINSERT_CONTROL_AFTER
  # Issue 111257 US 32
  Gosub TOT_LTI

  # End issue 111257 US 32
  #Déplacé dans SHIP_LIB
  #Gosub CTL_TPC
  #Gosub SEARCHARVEXPDAT
  #Gosub CTR_DATE_PLACE
  # Issue 111257 US 20 : Zones supprimées de l'écran lors de la création de l'onglet document
  #Gosub CTL_DOC

Gosub CTR_INSERT From SHIP_LIB

Return

#######################################################################################
$AUPDATE_CONTROL_AFTER
  # Issue 111257 US 32
  Gosub TOT_LTI
  # End issue 111257 US 32
  Gosub CONTROL

  # Issue 111257 US 20 : Zones supprimées de l'écran lors de la création de l'onglet document
  #Gosub CTL_DOC
  # Issue 111257
  #déplacé dans SHIP_LIB
  #Gosub SEARCHARVEXPDAT
  #Gosub CTR_DATE_PLACE
  #Gosub CTR_DATE
  #Gosub CTL_TPC
  Gosub CTR_UPDATE From SHIP_LIB

Return

#######################################################################################
$AUPDATE_AFTER
# Issue 111257 US 32
  #MAE, modification des expéditions uniquement si la date d'arrivée prévue a été modifiée
  If (this.ARVEXPDAT<>this.snapshot.ARVEXPDAT) | (this.ARVDAT<> this.snapshot.ARVDAT) |(this.DPEDAT<> this.snapshot.DPEDAT)
&   | (this.DPETPC<>this.snapshot.DPETPC)
&   |(this.ARVTPC<>this.snapshot.ARVTPC) | (this.TRNMOD<>this.snapshot.TRNMOD) | (this.BPTNUM<>this.snapshot.BPTNUM)
    Gosub UPD_SHIP
  Endif
# End issue 111257 US 32
# Issue 58314_2 : controle dépendances
Gosub CONTROLE_DEP From SHIPTRACK_CSTD
# Issue 53814_2

Return

#######################################################################################
$AINSERT_BEFORE
  Local Char WSEQ_CODE(25)
  Local Integer WMANUAL
  Local Char WMESSAGE(250)

  If this.TRNSTA = 0
    this.TRNSTA=1
  Endif

  #gestion du compteur
  #If this.TRNNUM=AVOID.ACHAR   # Issue X3-86304 - 2018-04-23 by MAE
    If func TCA_TOOL.LECTCA(this.ACTX, 6, fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR("","LEGCPY"),
&   fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR("","LEG"),17, WSEQ_CODE, WMANUAL, WMESSAGE) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR ("TRNNUM", mess(64,199,1), [V]CST_AERROR)
      If [L]ASTATUS>= [V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      Endif
    Endif
    If (this.TRNNUM = AVOID.ACHAR ) | (this.TRNNUM <> AVOID.ACHAR & WMANUAL= [V]CST_ANO)  # Issue X3-86304 - 2018-04-23 by MAE : si affectation manuelle à Non, compteur obligatoire
      #Appel du numéro
      [L]ASTATUS=func ANM_TOOL.NUMERO(this.ACTX,WSEQ_CODE,"",date$,"",this.TRNNUM,WMESSAGE)
      If [L]ASTATUS>= [V]CST_AERROR
         [L]ASTATUS = fmet this.ASETERROR ("TRNNUM", WMESSAGE, [V]CST_AERROR)
      Endif
    Endif
  #Endif                        # Issue X3-86304 - 2018-04-23 by MAE
  If this.TRNNUM = AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR ("TRNNUM", mess(10,123,1), [V]CST_AERROR)
  Endif
Return

######################################################################################
$CONTROL
  #fields not modifiable
  #Transport num
  If this.TRNNUM <> this.snapshot.TRNNUM
    WMESSAGE = mess(489,194,1) + " - " + mess(9,123,1)
    [L]ASTATUS = fmet this.ASETERROR ("TRNUM", WMESSAGE, [V]CST_AERROR)
    Return
  Endif

  # si status supérieur à création
  # il faudra rajouter non lié à shipment
  If this.TRNSTA  > 1
    #Transporteur
    If this.BPTNUM <> this.snapshot.BPTNUM
      WMESSAGE = mess(129,198,1) + " - " + mess(9,123,1)
      [L]ASTATUS = fmet this.ASETERROR ("BPTNUM", WMESSAGE, [V]CST_AERROR)
      Return
    Endif
    #Type de transport
    If this.TRNMOD <> this.snapshot.TRNMOD
      WMESSAGE = mess(490,194,1) + " - " + mess(9,123,1)
      [L]ASTATUS = fmet this.ASETERROR ("TRNMOD", WMESSAGE, [V]CST_AERROR)
      Return
    Endif
  Endif
Return

