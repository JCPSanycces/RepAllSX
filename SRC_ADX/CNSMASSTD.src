 Call CTRL_COD([M]CODCOMP,[M]DAT,1,[M:MAS1]ACTSCE2,[M:MAS1]ACTHYP2,[M:MAS1]ACTDEB2,[M:MAS1]ACTFIN2,VALEUR)
 If mkstat : End : Endif
Endif

End

######################################################################################

Subprog C_RUB(VALEUR)
  Variable  Char    VALEUR()
  Local Char LCODACC(GLONACS)
  Local Char LCODGRP(GLONADI)

  If VALEUR <> ""
  #7236 Amélioration contrôles par rapport à la liste + code accès.
    Read [MSR1]MSR0=VALEUR
    If fstat
      Read [RUB1]RUB0=GCURLEG;VALEUR
      If fstat
        GMESSAGE =  mess(11,10702,1) : # Rubrique inexistante
        mkstat = 2 : End
      Elsif !fstat & [F:RUB1]CODGRP=""
        GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
        mkstat = 2 : End
      Else
        LCODACC=[F:RUB1]CODACC
        LCODGRP=[F:RUB1]CODGRP
      Endif
    Elsif !fstat & [F:MSR1]CODGRP=""
      GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
      mkstat = 2 : End
    Else
      LCODACC=[F:MSR1]CODACC
      LCODGRP=[F:MSR1]CODGRP
    Endif

    #control droit d'accès de la rubrique
    Call CONTEXE(LCODACC) From CPTSUB

    #Si groupe saisi, controle cohérence
    If [M:CMAS]GRP<>"" & [M:CMAS]GRP<>LCODGRP
      GMESSAGE = mess(40,10722,1)-[M:CMAS]GRP #La rubrique n'appartient pas au groupe
      mkstat = 2 : End
    Endif

    #Si Catégorie controle cohérence groupe rubrique et catégorie
    If [M:CMAS]CAT<>""
      Read [ADI]CODE(2) = 10654;LCODGRP
      If !fstat & [ADI]A1 <> [M:CMAS]CAT
          GMESSAGE = mess(43,10722,1)-[M:CMAS]CAT :#Le groupe de cette rubrique n'appartient pas à la catégorie
          mkstat = 2 : End
      Endif
    Endif

    #Si liste de rubrique, contrôle que la rubrique appartient à la liste
    If [M:CMAS]LISRUB<>""
      Look [MLR1]MLR1(2)=[M:CMAS]LISRUB;VALEUR
      If fstat
        GMESSAGE = mess(38,10722,1)-":"-[M:CMAS]LISRUB #La rubrique n'appartient pas à la liste
        mkstat = 2 : End
      Endif
    Endif
  Endif
  #end 7236
End

# FQ70994 - MABON 11/04/11 - Affichage d'un graphe
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  If dim(GLIBLEV)>0    Then Kill GLIBLEV    : Endif
  If dim(GAMTCOMP)>0   Then Kill GAMTCOMP   : Endif
  If dim(GREACOMP)>0   Then Kill GREACOMP   : Endif
  If dim(GECARTCOMP)>0 Then Kill GECARTCOMP : Endif
  If dim(CURSCECOD)>0  Then Kill CURSCECOD  : Endif
  If dim(CURDATREV)>0  Then Kill CURDATREV  : Endif
Return

Subprog AM_FLGGRA(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When 2
      [M]NODSP(nolign-1) = ""
    When Default
      [M]NODSP(nolign-1) = "X"
  Endcase
  [M]FLGGRA(nolign-1)=VALEUR
  Affzo [M]
End

