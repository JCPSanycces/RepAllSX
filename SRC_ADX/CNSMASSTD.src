 GAMTCOMP=mess(45,10722,1)   : # Budgété Scénario 2
 GREACOMP=mess(46,10722,1)   : # Réalisé Scénario 2
 GECARTCOMP=mess(47,10722,1) : # Ecart Scénario 2
#Onglet 1
 Chgfmt [M:MAS2]AMTCOMP    With 'NP3z:11.2'
 Chgfmt [M:MAS2]REACOMP    With 'NP3z:11.2'
 Chgfmt [M:MAS2]ECARTCOMP  With 'NP3z-:11.2'
 Chgfmt [M:MAS2]LIBTTBCOMP With 'KP:15W'
 Chgfmt [M:MAS2]LIBTTRCOMP With 'KP:15W'
 Chgfmt [M:MAS2]LIBTTECOMP With 'KP:15W'
 Chgfmt [M:MAS2]TTBUDCOMP  With 'NP3:11.2'
 Chgfmt [M:MAS2]TTREACOMP  With 'NP3:11.2'
 Chgfmt [M:MAS2]TTECACOMP  With 'NP3-:11.2'
 Chgtbk [M:MAS2]30         With "Totaux scénario 2"
#Onglet 2
 Chgfmt [M:MAS3]AMTCOMP    With 'NP3z:11.2'
 Chgfmt [M:MAS3]REACOMP    With 'NP3z:11.2'
