Endif

#exercices précédents
Chgtbk [M:MAS2]45          With ""
Chgtbk [M:MAS3]45          With ""
Chgtbk [M:MAS4]45          With ""
Chgfmt [M:MAS2]TTN1ECA     With '-NP3:11.2'
Chgfmt [M:MAS2]TTN2ECA     With '-NP3:11.2'
Chgfmt [M:MAS3]TTN1ECA     With '-NP3:11.2'
Chgfmt [M:MAS3]TTN2ECA     With '-NP3:11.2'
Chgfmt [M:MAS4]TTN1ECA     With '-NP3:11.2'
Chgfmt [M:MAS4]TTN2ECA     With '-NP3:11.2'
If [M:MAS1]CODN1 <> "" | [M:MAS1]CODN2 <> ""
 Chgtbk [M:MAS2]45         With "Exercices précédents"
 Chgtbk [M:MAS3]45         With "Exercices précédents"
 Chgtbk [M:MAS4]45         With "Exercices précédents"
 If [M:MAS1]CODN1 <> ""
  Chgfmt [M:MAS2]TTN1ECA   With 'NP3-:11.2'
  Chgfmt [M:MAS3]TTN1ECA   With 'NP3-:11.2'
  Chgfmt [M:MAS4]TTN1ECA   With 'NP3-:11.2'
 Endif
 If [M:MAS1]CODN2 <> ""
  Chgfmt [M:MAS2]TTN2ECA   With 'NP3-:11.2'
  Chgfmt [M:MAS3]TTN2ECA   With 'NP3-:11.2'
  Chgfmt [M:MAS4]TTN2ECA   With 'NP3-:11.2'
 Endif
Endif

#Ecart en % ou montant
If [M:MAS1]DISPLAY = 1
 Chgfmt [M:MAS2]ECART     With 'NP3z-:11.2[ %]'
 Chgfmt [M:MAS2]TTECA     With 'NP3z-:11.2[ %]'
 Chgfmt [M:MAS3]ECART     With 'NP3z-:11.2[ %]'
 Chgfmt [M:MAS3]TTECA     With 'NP3z-:11.2[ %]'
 Chgfmt [M:MAS4]ECART     With 'NP3z-:11.2[ %]'
 Chgfmt [M:MAS4]TTECA     With 'NP3z-:11.2[ %]'
 If [M:MAS1]CODCOMP <> ""
  Chgfmt [M:MAS2]ECARTCOMP With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS2]TTECACOMP With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS3]ECARTCOMP With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS3]TTECACOMP With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS4]ECARTCOMP With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS4]TTECACOMP With 'NP3z-:11.2[ %]'
 Endif
 If [M:MAS1]CODN1 <> ""
  Chgfmt [M:MAS2]TTN1ECA   With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS3]TTN1ECA   With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS4]TTN1ECA   With 'NP3z-:11.2[ %]'
 Endif
 If [M:MAS1]CODN2 <> ""
  Chgfmt [M:MAS2]TTN2ECA   With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS3]TTN2ECA   With 'NP3z-:11.2[ %]'
  Chgfmt [M:MAS4]TTN2ECA   With 'NP3z-:11.2[ %]'
 Endif

Else
 Chgfmt [M:MAS2]ECART     With 'NP3z-:11.2'
 Chgfmt [M:MAS2]TTECA     With 'NP3-:11.2'
 Chgfmt [M:MAS3]ECART     With 'NP3z-:11.2'
 Chgfmt [M:MAS3]TTECA     With 'NP3-:11.2'
 Chgfmt [M:MAS4]ECART     With 'NP3z-:11.2'
 Chgfmt [M:MAS4]TTECA     With 'NP3-:11.2'
Endif

If clalev([M:CMAS])>0 Then
  If [M:CMAS]AFFAMT=1 Then
    Chgfmt [M:MAS2]AMT    With '-NP3z:11.2'
    Chgfmt [M:MAS3]AMT    With '-NP3z:11.2'
    Chgfmt [M:MAS4]AMT    With '-NP3z:11.2'
  Else
    Chgfmt [M:MAS2]AMT    With 'NP3z:11.2'
    Chgfmt [M:MAS3]AMT    With 'NP3z:11.2'
    Chgfmt [M:MAS4]AMT    With 'NP3z:11.2'
  Endif

  If [M:CMAS]AFFREA=1 Then
    Chgfmt [M:MAS2]REA    With '-NP3z:11.2'
    Chgfmt [M:MAS3]REA    With '-NP3z:11.2'
    Chgfmt [M:MAS4]REA    With '-NP3z:11.2'
  Else
    Chgfmt [M:MAS2]REA    With 'NP3z:11.2'
    Chgfmt [M:MAS3]REA    With 'NP3z:11.2'
    Chgfmt [M:MAS4]REA    With 'NP3z:11.2'
 Endif

  If [M:CMAS]AFFECART=1 Then
    Chgfmt [M:MAS2]ECART  With '-NP3Z:11.2'
    Chgfmt [M:MAS3]ECART  With '-NP3Z:11.2'
    Chgfmt [M:MAS4]ECART  With '-NP3Z:11.2'
  Else
    Chgfmt [M:MAS2]ECART  With 'NP3Z:11.2'
    Chgfmt [M:MAS3]ECART  With 'NP3Z:11.2'
    Chgfmt [M:MAS4]ECART  With 'NP3Z:11.2'
  Endif

  If [M:MAS1]CODCOMP<>"" Then
    If [M:CMAS]AFFAMT2=1 Then
      Chgfmt [M:MAS2]AMTCOMP    With '-NP3z:11.2'
      Chgfmt [M:MAS3]AMTCOMP    With '-NP3z:11.2'
      Chgfmt [M:MAS4]AMTCOMP    With '-NP3z:11.2'
    Else
      Chgfmt [M:MAS2]AMTCOMP    With 'NP3z:11.2'
      Chgfmt [M:MAS3]AMTCOMP    With 'NP3z:11.2'
      Chgfmt [M:MAS4]AMTCOMP    With 'NP3z:11.2'
    Endif

    If [M:CMAS]AFFREA2=1 Then
      Chgfmt [M:MAS2]REACOMP    With '-NP3z:11.2'
      Chgfmt [M:MAS3]REACOMP    With '-NP3z:11.2'
      Chgfmt [M:MAS4]REACOMP    With '-NP3z:11.2'
    Else
      Chgfmt [M:MAS2]REACOMP    With 'NP3z:11.2'
      Chgfmt [M:MAS3]REACOMP    With 'NP3z:11.2'
      Chgfmt [M:MAS4]REACOMP    With 'NP3z:11.2'
    Endif

    If [M:CMAS]AFFECART2=1 Then
      Chgfmt [M:MAS2]ECARTCOMP  With '-NP3Z:11.2'
      Chgfmt [M:MAS3]ECARTCOMP  With '-NP3Z:11.2'
      Chgfmt [M:MAS4]ECARTCOMP  With '-NP3Z:11.2'
    Else
      Chgfmt [M:MAS2]ECARTCOMP  With 'NP3Z:11.2'
      Chgfmt [M:MAS3]ECARTCOMP  With 'NP3Z:11.2'
      Chgfmt [M:MAS4]ECARTCOMP  With 'NP3Z:11.2'
    Endif
  Endif
Endif
Return

$SETBOUT
If [M:MAS1]COD = ""
 Chgfmt [M:MAS2]INDIC   With '-KP:80X'
 Chgfmt [M:MAS3]INDIC   With '-KP:80X'
 Chgfmt [M:MAS4]INDIC   With '-KP:80X'
 #78924 fields not exported by Excel Export
# Chgfmt [M:MAS2]ZCAT    With '-KP:80X'
# Chgfmt [M:MAS3]ZCAT    With '-KP:80X'
# Chgfmt [M:MAS4]ZCAT    With '-KP:80X'
# Chgfmt [M:MAS2]ZCODGRP With '-KP:80X'
# Chgfmt [M:MAS3]ZCODGRP With '-KP:80X'
# Chgfmt [M:MAS4]ZCODGRP With '-KP:80X'
 Chgfmt [M:MAS2]LIBCAT  With '-KP:30X'
 Chgfmt [M:MAS3]LIBCAT  With '-KP:30X'
 Chgfmt [M:MAS4]LIBCAT  With '-KP:30X'
 Chgfmt [M:MAS2]LIBGRP  With '-KP:30X'
 Chgfmt [M:MAS3]LIBGRP  With '-KP:30X'
 Chgfmt [M:MAS4]LIBGRP  With '-KP:30X'
 #end 78924
Endif

Case [M:MAS1]NIVEAU
 When 3 # Catégorie
  Call VIREBOUT (CHAINE,"P") From GOBJET
 When 2 # Groupe
 When 1 # Rubrique
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endcase

# FQ70994 - MABON 11/04/11 - Ajout styles dans les graphes
Local Integer IL
For IL=1 To [M:MAS2]NBLIG : # Ecran MAS2
  Case [M:MAS2]COUNT(IL-1)
    When 2 : Chgstl [M:MAS2]NBLIG(IL-1) With "PLGCUR"
    When 3 : Chgstl [M:MAS2]NBLIG(IL-1) With "PLGCUR2"
    When 4 : Chgstl [M:MAS2]NBLIG(IL-1) With "PLGCUR3"
  Endcase
Next
For IL=1 To [M:MAS3]NBLIG : # Ecran MAS3
  Case [M:MAS3]COUNT(IL-1)
    When 2 : Chgstl [M:MAS3]NBLIG(IL-1) With "PLGCUR"
    When 3 : Chgstl [M:MAS3]NBLIG(IL-1) With "PLGCUR2"
    When 4 : Chgstl [M:MAS3]NBLIG(IL-1) With "PLGCUR3"
  Endcase
Next
For IL=1 To [M:MAS4]NBLIG : # Ecran MAS4
  Case [M:MAS4]COUNT(IL-1)
    When 2 : Chgstl [M:MAS4]NBLIG(IL-1) With "PLGCUR"
    When 3 : Chgstl [M:MAS4]NBLIG(IL-1) With "PLGCUR2"
    When 4 : Chgstl [M:MAS4]NBLIG(IL-1) With "PLGCUR3"
  Endcase
Next
If [M:MAS2]NBLIG>0 Then Chgstl [M:MAS2]NBLIG([M:MAS2]NBLIG-1) With "JOUR2" : Endif
If [M:MAS3]NBLIG>0 Then Chgstl [M:MAS3]NBLIG([M:MAS3]NBLIG-1) With "JOUR2" : Endif
If [M:MAS4]NBLIG>0 Then Chgstl [M:MAS4]NBLIG([M:MAS4]NBLIG-1) With "JOUR2" : Endif
# Fin MABON

Affzo [M:MAS2]
Affzo [M:MAS3]
Affzo [M:MAS4]
Return

$EXEBOUT
Effzo [M:MAS2]5 : Effzo [M:MAS3]5  : Effzo [M:MAS4]5
Case BOUT
 When "P" : [M:MAS1]NIVEAU += 1
 When "M" : [M:MAS1]NIVEAU -= 1
Endcase
# FQ70994 - MABON 11/04/11 - Affichage d'un graphe
Chgfmt [M:MAS2]LIBLEV    With 'KP:30X'
Case [M:MAS1]NIVEAU
 When 3 # Catégorie
  # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
  #78924 fields not exported by Excel Export
  #Chgfmt [M:MAS2]ZCAT    With '-KP:30X'
  #Chgfmt [M:MAS3]ZCAT    With '-KP:30X'
  #Chgfmt [M:MAS4]ZCAT    With '-KP:30X'
  Chgfmt [M:MAS2]LIBCAT  With '-KP:30X'
  Chgfmt [M:MAS3]LIBCAT  With '-KP:30X'
  Chgfmt [M:MAS4]LIBCAT  With '-KP:30X'
  #end 78924
  # Fin MABON
  #78924 fields not exported by Excel Export
#  Chgfmt [M:MAS2]ZCODGRP With '-KP:30X'
#  Chgfmt [M:MAS3]ZCODGRP With '-KP:30X'
#  Chgfmt [M:MAS4]ZCODGRP With '-KP:30X'
  Chgfmt [M:MAS2]LIBGRP  With '-KP:30X'
  Chgfmt [M:MAS3]LIBGRP  With '-KP:30X'
  Chgfmt [M:MAS4]LIBGRP  With '-KP:30X'
  #end 78924
  Chgfmt [M:MAS2]RUB     With '-KP:30X'
  Chgfmt [M:MAS3]RUB     With '-KP:30X'
  Chgfmt [M:MAS4]RUB     With '-KP:30X'
 When 2 # Groupe
  # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
  #78924 fields not exported by Excel Export
#  Chgfmt [M:MAS2]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS3]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS4]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS2]ZCODGRP With '-KP:30X'
#  Chgfmt [M:MAS3]ZCODGRP With '-KP:30X'
#  Chgfmt [M:MAS4]ZCODGRP With '-KP:30X'
  Chgfmt [M:MAS2]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS3]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS4]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS2]LIBGRP  With '-KP:30X'
  Chgfmt [M:MAS3]LIBGRP  With '-KP:30X'
  Chgfmt [M:MAS4]LIBGRP  With '-KP:30X'
  #end 78924
  # Fin MABON
  Chgfmt [M:MAS2]RUB     With '-KP:30X'
  Chgfmt [M:MAS3]RUB     With '-KP:30X'
  Chgfmt [M:MAS4]RUB     With '-KP:30X'
 When 1 # Rubrique
  # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
  #78924 fields not exported by Excel Export
#  Chgfmt [M:MAS2]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS3]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS4]ZCAT    With 'KP:30X'
#  Chgfmt [M:MAS2]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS3]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS4]ZCODGRP With 'KP:30X'
  Chgfmt [M:MAS2]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS3]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS4]LIBCAT  With 'KP:30X'
  Chgfmt [M:MAS2]LIBGRP  With 'KP:30X'
  Chgfmt [M:MAS3]LIBGRP  With 'KP:30X'
  Chgfmt [M:MAS4]LIBGRP  With 'KP:30X'
  #end 78924
#  Chgfmt [M:MAS2]RUB     With 'KP:30X'
#  Chgfmt [M:MAS3]RUB     With 'KP:30X'
#  Chgfmt [M:MAS4]RUB     With 'KP:30X'
  Chgfmt [M:MAS2]RUB     With '-KP:30X'
  Chgfmt [M:MAS3]RUB     With '-KP:30X'
  Chgfmt [M:MAS4]RUB     With '-KP:30X'
  # Fin MABON
Endcase
Gosub PAG_PREM From GCONSULT
Return

# FQ70994 - MABON 02/05/11 - Récupération des variables nécessaires aux contrôles des champs de critères
$EXEBOUT2

  Case BOUT
    When "R" : If [M:CMAS]COD<>"" Then Call AM_COD([M:CMAS]COD) : Endif
  Endcase
Return

######################################################################################
######################################################################################
Subprog ALIM_HYPO_ACTIV(NS,CODX,DMIN,DMAX,SCEN,LIGN,DDEB,DFIN,EXEFULL,TINI)
Value       Shortint NS
Value       Char     CODX ()
Value       Date     DMIN
Value       Date     DMAX
Variable    Char     SCEN()(1..)
Variable    Decimal  LIGN (1..)
Variable    Date     DDEB (1..)
Variable    Date     DFIN (1..)
Variable    Decimal  EXEFULL
Value       Shortint TINI


#73172 : fiels mandatory
If CODX="" or DMIN=[0/0/0] : End : Endif

#tableau buffer
Local Date      WDMIN , WDMAX
Local Shortint  WMAX , W , WI , J
Local Char      WSCE (GLONMCH) (1..dim(SCEN))
Local Shortint  WHYP (1..dim(LIGN))
Local Date      WDEB (1..dim(DDEB))
Local Date      WFIN (1..dim(DFIN))
Local Date      WDATREV


#Alimentation du tableau des hypothèses actives par période

# -- Parcours des hypothèses du scénario et remplissage d'un tableau des hypothèses à considérer à chaque période
DMIN       = DMIN-1
ACTMAX(NS) = 0
EXEFULL    = 1
WDATREV = CURDATREV
Gosub REMPLI_PERIOD


# -- Si il existe des périodes sans hypothèse, on doit combler avec le scénario de référence
# -- C'est ici aussi que l'on traite le cas de la consultation d'un scénario initial
CODX = [F:MCH]CODINI

While EXEFULL = 0
 If [F:MCH]TYPMCH <> 1
  Read [F:MCH2]MCH0 = CODX
 Else
  [F:MCH2] = [F:MCH]
 Endif
 If fstat : Break : Endif

 EXEFULL = 1

 If [F:MCH2]TYPMCH = 1         : # Scénario type INITIAL
  # Ajout d'une occurence avec le AIA (si c'est le scénario en critere, On prend ce qui est précisé dans l'écran critère)
  If ACTMAX(NS) < dim(SCEN)
   ACTMAX(NS) += 1
   SCEN(ACTMAX(NS)) = [F:MCH2]COD
   If SCEN(ACTMAX(NS)) = [F:MCH]COD & TINI = 7
    LIGN(ACTMAX(NS)) = 0
   Else
    LIGN(ACTMAX(NS)) = 1
   Endif
   DDEB(ACTMAX(NS)) = [F:MCH2]STRDAT
   DFIN(ACTMAX(NS)) = [F:MCH2]ENDDAT
  Else
   EXEFULL = 0
  Endif
  Break
 Else                          : # Scénario type BUDGETAIRE
  WDATREV = [F:MCH2]DATREVBUD
  Gosub REMPLI_PERIOD
 Endif

 CODX = [F:MCH2]CODINI
Wend

#Si on arrive ici avec EXEFULL=0 > il reste des périodes non couvertes (on a pas pu remonter jusqu'au scénario initial)
# affichage d'un message ?

End

$REMPLI_PERIOD

WMAX   = 0
WDMIN  = DMIN
WDMAX  = DMAX

# -- Parcours des hypothèses du scénario et remplissage d'un tableau des hypothèses à considérer à par période

#On commence par remplir un tableau de travail
Filter [F:MCL] Where COD = CODX Order By Key MCL2
Read [F:MCL] First
While fstat = 0
 If find([F:MCL]STAHYP,1,2)
  If WMAX <> 0 & [F:MCL]STRHYP <= WDEB(WMAX) & [F:MCL]ENDHYP >= WFIN(WMAX)
   # Période d'activation recouverte : on remplace cette occurence
   WSCE(WMAX) = [F:MCL]COD
   WHYP(WMAX) = [F:MCL]NUMLIG + 1 : # les hypothèses hors ATM/AIA sont numérotées à partir de 2
   WDEB(WMAX) = [F:MCL]STRHYP
   WFIN(WMAX) = [F:MCL]ENDHYP
  Else
   If ([F:MCL]STRHYP > WDMIN + 1) | ([F:MCL]STRHYP <= WDATREV & WDATREV > WDMIN + 1)
   #On détecte une période non couverte par les hypothèses
    EXEFULL = 0
   Endif
   # Période d'activation décalée : Nouvelle occurence (Scénario + n°ligne + début activation + fin activation)
   WMAX += 1
   WSCE(WMAX) = [F:MCL]COD
   WHYP(WMAX) = [F:MCL]NUMLIG + 1 : # les hypothèses hors ATM/AIA sont numérotées à partir de 2
   WDEB(WMAX) = [F:MCL]STRHYP
   WFIN(WMAX) = [F:MCL]ENDHYP
  Endif
  If [F:MCL]ENDHYP > WDMIN
   WDMIN = [F:MCL]ENDHYP
  Endif
  If WMAX >= dim(SCEN)
   Break
  Endif
 Endif
 Read [F:MCL] Next
Wend
Filter [MCL]
Raz fstat
If WMAX = 0 | WDMIN < WDMAX
 #On détecte une période non couverte par les hypothèses
 EXEFULL = 0
Endif

If WMAX > 0
# Insertion du tableau de travail à la fin du tableau des hypothèses par période
# Le tableau est rempli de la ligne d'hypothèse la + élevée à prendre en compte à la plus basse (n à 1)
# en commençant par les hypothèses du scénario puis celles du/des scénarii de référence (rév.budg. puis budg. puis AIA)
 DEBINSER = ACTMAX(NS) + 2

 For W = 1 To WMAX
  If ACTMAX(NS) < dim(SCEN)
   ACTMAX(NS) += 1
   For WI = ACTMAX(NS) To DEBINSER Step -1
    SCEN(WI) = SCEN(WI-1)
    LIGN(WI) = LIGN(WI-1)
    DDEB(WI) = DDEB(WI-1)
    DFIN(WI) = DFIN(WI-1)
   Next
   SCEN(WI) = WSCE(W)
   LIGN(WI) = WHYP(W)
   DDEB(WI) = WDEB(W)
   DFIN(WI) = WFIN(W)
  Else
   EXEFULL = 0
  Endif
 Next

# Si il existe un période non couverte , vérification sur l'ensemble du tableau pour confirmer
 If !EXEFULL
  EXEFULL = 1
  WDMIN = DDEB(1) - 1
  WDMAX = DFIN(1) + 1

  For W=1 To ACTMAX(NS)
   If DFIN(W) < WDMIN
   # potentiel trou le mois d'avant, on parcourt tt le tableau jusqu'à trouver une occurence pour combler
    EXEFULL = 0
    For WI = 1 To ACTMAX(NS)
     If DFIN(WI) >= WDMIN & DDEB(WI) < WDMIN
      WDMIN = DDEB(WI) - 1
      EXEFULL = 1
      Break
     Endif
    Next
   Endif
   If DDEB(W) > WDMAX
   # potentiel trou le mois d'après, on parcourt tt le tableau jusqu'à trouver une occurence pour combler
    EXEFULL = 0
    For WI = 1 To ACTMAX(NS)
     If DDEB(WI) <= WDMAX & DFIN(WI) > WDMAX
      WDMAX = DFIN(WI) + 1
      EXEFULL = 1
      Break
     Endif
    Next
   Endif
   If EXEFULL = 0 : Break : Endif
  Next
  If WDMIN > DMIN | WDMAX < DMAX | (WDMIN <= WDATREV & WDATREV > DMIN+1)
   EXEFULL = 0
  Endif
 Endif

Endif
Return

######################################################################################
$FILT_HYP_ACTIV
#Recherche dans le tableau des hypothèses actives par période
IND1 = 0
IND2 = 0
#Scénario 1
For I = 0 To ACTMAX(1)
 If [F:MHS]DAT >= [M:MAS1]ACTDEB1(I) & [F:MHS]DAT <= [M:MAS1]ACTFIN1(I)
  If [F:MHS]COD = [M:MAS1]ACTSCE1(I) & [F:MHS]LIGHYP = [M:MAS1]ACTHYP1(I)
   IND1 = I+1
  Endif
  Break
 Endif
Next
If [F:MHS]COD = [M:MAS1]COD & [F:MHS]SIM = 1 : # PAIE réelle
 IND1 = -1
Endif
#Scénario 2
For I = 0 To ACTMAX(2)
 If [F:MHS]DAT >= [M:MAS1]ACTDEB2(I) & [F:MHS]DAT <= [M:MAS1]ACTFIN2(I)
  If [F:MHS]COD = [M:MAS1]ACTSCE2(I) & [F:MHS]LIGHYP = [M:MAS1]ACTHYP2(I)
   IND2 = I+1
  Endif
  Break
 Endif
Next
If [F:MHS]COD = [M:MAS1]CODCOMP & [F:MHS]SIM = 1
 IND2 = -1
Endif
Return
######################################################################################
$N1N2_FILT_ACTIV
#Recherche dans le tableau des hypothèses actives par période
IND3 = 0
IND4 = 0
#Scénario N-1
For I = 0 To ACTMAX(3)
 If [F:MHS]DAT >= [M:MAS1]ACTDEB3(I) & [F:MHS]DAT <= [M:MAS1]ACTFIN3(I)
  If [F:MHS]COD = [M:MAS1]ACTSCE3(I) & [F:MHS]LIGHYP = [M:MAS1]ACTHYP3(I)
   IND3 = I+1
  Endif
  Break
 Endif
Next
If [F:MHS]COD = [M:MAS1]CODN1 & [F:MHS]SIM = 1 : # PAIE réelle
 IND3 = -1
Endif
#Scénario N-2
For I = 0 To ACTMAX(4)
 If [F:MHS]DAT >= [M:MAS1]ACTDEB4(I) & [F:MHS]DAT <= [M:MAS1]ACTFIN4(I)
  If [F:MHS]COD = [M:MAS1]ACTSCE4(I) & [F:MHS]LIGHYP = [M:MAS1]ACTHYP4(I)
   IND4 = I+1
  Endif
  Break
 Endif
Next
If [F:MHS]COD = [M:MAS1]CODN2 & [F:MHS]SIM = 1 : # PAIE réelle
 IND4 = -1
Endif
Return

######################################################################################
$LECT_MOIS

# 57077 # Enreg d'histo sur le mois sélectionné (et non sur la date de paye)
If year([F:MHS]DAT) = year([M:MAS1]DAT) & month([F:MHS]DAT) = month([M:MAS1]DAT)

#Alimentation de la 1ère colonne. Affichée si détail demandé
 If FRUPT2 <> ""
  [M:MAS2]INDIC(nolign-1) = evalue("[F:MHS]"+FRUPT2)-evalue("[F:MHS]"+FRUPT)
 Elsif FRUPT <> ""
  [M:MAS2]INDIC(nolign-1) = evalue("[F:MHS]"+FRUPT)
 Endif

 [M:MAS2]CAT(nolign-1)       = [F:MHS]CAT
 [M:MAS2]CODGRP(nolign-1)    = [F:MHS]GRP
 [M:MAS2]RUB(nolign-1)       = [F:MHS]RUB
 # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
 Local Char CHAINELEV(250)
 #78924 fields not exported by Excel Export
# Case [M:MAS1]NIVEAU
#    When 3 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
#             [M:MAS2]LIBLEV(nolign-1) = CHAINELEV
#    When 2 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
#             [M:MAS2]LIBLEV(nolign-1) = CHAINELEV
##    When 1 : [M:MAS2]LIBLEV(nolign-1) = [F:MHS]RUB : # FQ76304 - MABON 19/09/11 - Code remplacé par Libellé
#    When 1 : [M:MAS2]LIBLEV(nolign-1) =  func GET_RUB_LIB([F:MHS]RUB): #[F:RUB]DES #76770
# Endcase
 If [F:MHS]CAT <> [L]PRECCAT
  Call LECTEXTRA([L]SAVLIBCAT, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
  [L]PRECCAT=[F:MHS]CAT
 Endif
 If [M:MAS1]NIVEAU<3 & [F:MHS]GRP <> [L]PRECGRP
  Call LECTEXTRA([L]SAVLIBGRP, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
  [L]PRECGRP=[F:MHS]GRP
 Endif
 [M:MAS2]LIBCAT(nolign-1)=[L]SAVLIBCAT
 [M:MAS2]LIBGRP(nolign-1)=[L]SAVLIBGRP
 Case [M:MAS1]NIVEAU
    When 3 : [M:MAS2]LIBLEV(nolign-1) = [M:MAS2]LIBCAT(nolign-1)
    When 2 : [M:MAS2]LIBLEV(nolign-1) =  [M:MAS2]LIBGRP(nolign-1)
    When 1 : [M:MAS2]LIBLEV(nolign-1) =  func GET_RUB_LIB([F:MHS]RUB)
 Endcase
  #end 78924
 If [M:MAS1]DETAIL>1 Then [M:MAS2]LIBLEV(nolign-1)=[M:MAS2]INDIC(nolign-1)-"-"-[M:MAS2]LIBLEV(nolign-1) : Endif
 # Fin MABON
 V_PROJ = 0
 V1_AMT = [M:MAS2]AMT(nolign-1)     : V1_REA = [M:MAS2]REA(nolign-1)     : V1_ECA = [M:MAS2]ECART(nolign-1)
 V2_AMT = [M:MAS2]AMTCOMP(nolign-1) : V2_REA = [M:MAS2]REACOMP(nolign-1) : V2_ECA = [M:MAS2]ECARTCOMP(nolign-1)
  Gosub ALIM_LIGN
 [M:MAS2]AMT(nolign-1)     = V1_AMT : [M:MAS2]REA(nolign-1)     = V1_REA : [M:MAS2]ECART(nolign-1)     = V1_ECA
 [M:MAS2]AMTCOMP(nolign-1) = V2_AMT : [M:MAS2]REACOMP(nolign-1) = V2_REA : [M:MAS2]ECARTCOMP(nolign-1) = V2_ECA
 # FQ76933 - MABON 11/10/11 - On met dans ces colonnes uniquement les montants qui seront à cumuler dans les sous-totaux et totaux
 If [F:RUB]NOSUMMS <> 2 & [F:MSR]NOSUMMS <> 2
  [M:MAS2]AMTT(nolign-1)     += V1_AMTT : [M:MAS2]REAT(nolign-1)     += V1_REAT
  [M:MAS2]AMTCOMPT(nolign-1) += V2_AMTT : [M:MAS2]REACOMPT(nolign-1) += V2_REAT
 Endif
 # Fin MABON
Endif
Return
######################################################################################
$LECT_CUMMOI

If [F:MHS]DAT >= [M:MAS1]STRDAT(0) & [F:MHS]DAT <= [M:MAS1]DATFIN

 If FRUPT2 <> ""
  [M:MAS3]INDIC(NBCUM-1) = evalue("[F:MHS]"+FRUPT2)-evalue("[F:MHS]"+FRUPT)
 Elsif FRUPT <> ""
  [M:MAS3]INDIC(NBCUM-1) = evalue("[F:MHS]"+FRUPT)
 Endif

 [M:MAS3]CAT(NBCUM-1)     = [F:MHS]CAT
 [M:MAS3]CODGRP(NBCUM-1)  = [F:MHS]GRP
 [M:MAS3]RUB(NBCUM-1)     = [F:MHS]RUB
 # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
 #78924 - Replace nolign by NBCUM
 Local Char CHAINELEV(250)
 #78924 fields not exported by Excel Export
# Case [M:MAS1]NIVEAU
#    When 3 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
#             [M:MAS3]LIBLEV(nolign-1) = CHAINELEV
#    When 2 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
#             [M:MAS3]LIBLEV(nolign-1) = CHAINELEV
##    When 1 : [M:MAS3]LIBLEV(nolign-1) = [F:MHS]RUB : # FQ76304 - MABON 19/09/11 - Code remplacé par Libellé
#    When 1 : [M:MAS3]LIBLEV(nolign-1) = [F:RUB]DES
# Endcase
 If [F:MHS]CAT <> [L]PRECCAT
  Call LECTEXTRA([L]SAVLIBCAT, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
  [L]PRECCAT=[L]PRECCAT
 Endif
 If [M:MAS1]NIVEAU<3 & [F:MHS]GRP <> [L]PRECGRP
  Call LECTEXTRA([L]SAVLIBGRP, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
  [L]PRECGRP=[L]PRECGRP
 Endif
 [M:MAS3]LIBCAT(NBCUM-1)=[L]SAVLIBCAT
 [M:MAS3]LIBGRP(NBCUM-1)=[L]SAVLIBGRP
 Case [M:MAS1]NIVEAU
    When 3 : [M:MAS3]LIBLEV(NBCUM-1) = [M:MAS3]LIBCAT(NBCUM-1)
    When 2 : [M:MAS3]LIBLEV(NBCUM-1) = [M:MAS3]LIBGRP(NBCUM-1)
    When 1 : [M:MAS3]LIBLEV(NBCUM-1) =  func GET_RUB_LIB([F:MHS]RUB)
 Endcase
 #end 78924
 If [M:MAS1]DETAIL>1 Then [M:MAS3]LIBLEV(NBCUM-1)=[M:MAS3]INDIC(NBCUM-1)-"-"-[M:MAS3]LIBLEV(NBCUM-1) : Endif
 # Fin MABON
 V_PROJ = 0
 V1_AMT = [M:MAS3]AMT(NBCUM-1)     : V1_REA = [M:MAS3]REA(NBCUM-1)     : V1_ECA = [M:MAS3]ECART(NBCUM-1)
 V2_AMT = [M:MAS3]AMTCOMP(NBCUM-1) : V2_REA = [M:MAS3]REACOMP(NBCUM-1) : V2_ECA = [M:MAS3]ECARTCOMP(NBCUM-1)
  Gosub ALIM_LIGN
 [M:MAS3]AMT(NBCUM-1)     = V1_AMT : [M:MAS3]REA(NBCUM-1)     = V1_REA : [M:MAS3]ECART(NBCUM-1)     = V1_ECA
 [M:MAS3]AMTCOMP(NBCUM-1) = V2_AMT : [M:MAS3]REACOMP(NBCUM-1) = V2_REA : [M:MAS3]ECARTCOMP(NBCUM-1) = V2_ECA
 # FQ76933 - MABON 11/10/11 - On met dans ces colonnes uniquement les montants qui seront à cumuler dans les sous-totaux et totaux
 If [F:RUB]NOSUMMS <> 2 & [F:MSR]NOSUMMS <> 2
  [M:MAS3]AMTT(NBCUM-1)     += V1_AMTT : [M:MAS3]REAT(NBCUM-1)     += V1_REAT
  [M:MAS3]AMTCOMPT(NBCUM-1) += V2_AMTT : [M:MAS3]REACOMPT(NBCUM-1) += V2_REAT
 Endif
 # Fin MABON

 [M:MAS3]NBLIG=NBCUM

Endif
Return
######################################################################################
$LECT_PROJEX
If [F:MHS]DAT >= [M:MAS1]STRDAT(0) & [F:MHS]DAT <= [M:MAS1]ENDDAT(0)
 If FRUPT2 <> ""
  [M:MAS4]INDIC(NBPRJ-1) = evalue("[F:MHS]"+FRUPT2)-evalue("[F:MHS]"+FRUPT)
 Elsif FRUPT <> ""
  [M:MAS4]INDIC(NBPRJ-1) = evalue("[F:MHS]"+FRUPT)
 Endif

 [M:MAS4]CAT(NBPRJ-1)     = [F:MHS]CAT
 [M:MAS4]CODGRP(NBPRJ-1)  = [F:MHS]GRP
 [M:MAS4]RUB(NBPRJ-1)     = [F:MHS]RUB
 # FQ70994 - MABON 11/04/11 - Affichage d'un graphe
 #78924 - Replace nolign by NBPRJ
 Local Char CHAINELEV(250)
 #78924 fields not exported by Excel Export
# Case [M:MAS1]NIVEAU
#    When 3 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
#             [M:MAS4]LIBLEV(nolign-1) = CHAINELEV
#    When 2 : Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
#             [M:MAS4]LIBLEV(nolign-1) = CHAINELEV
##    When 1 : [M:MAS4]LIBLEV(nolign-1) = [F:MHS]RUB : # FQ76304 - MABON 19/09/11 - Code remplacé par Libellé
#    When 1 : [M:MAS4]LIBLEV(nolign-1) = [F:RUB]DES
# Endcase
 If [F:MHS]CAT <> [L]PRECCAT
  Call LECTEXTRA([L]SAVLIBCAT, "ATABDIV", "LNGDES", '10655', [F:MHS]CAT) From ATEXTRA
  [L]PRECCAT=[F:MHS]CAT
 Endif
 If [M:MAS1]NIVEAU<3 & [F:MHS]GRP <> [L]PRECGRP
  Call LECTEXTRA([L]SAVLIBGRP, "ATABDIV", "LNGDES", '10654', [F:MHS]GRP) From ATEXTRA
  [L]PRECGRP = [F:MHS]GRP
 Endif
 [M:MAS4]LIBCAT(NBPRJ-1)=[L]SAVLIBCAT
 [M:MAS4]LIBGRP(NBPRJ-1)=[L]SAVLIBGRP
 Case [M:MAS1]NIVEAU
    When 3 : [M:MAS4]LIBLEV(NBPRJ-1) = [M:MAS4]LIBCAT(NBPRJ-1)
    When 2 : [M:MAS4]LIBLEV(NBPRJ-1) = [M:MAS4]LIBGRP(NBPRJ-1)
    When 1 : [M:MAS4]LIBLEV(NBPRJ-1) =  func GET_RUB_LIB([F:MHS]RUB)
 Endcase
 #end 78924
 If [M:MAS1]DETAIL>1 Then [M:MAS4]LIBLEV(NBPRJ-1)=[M:MAS4]INDIC(NBPRJ-1)-"-"-[M:MAS4]LIBLEV(NBPRJ-1) : Endif
 # Fin MABON
 V_PROJ = 1
 V1_AMT = [M:MAS4]AMT(NBPRJ-1)     : V1_REA = [M:MAS4]REA(NBPRJ-1)     : V1_ECA = [M:MAS4]ECART(NBPRJ-1)
 V2_AMT = [M:MAS4]AMTCOMP(NBPRJ-1) : V2_REA = [M:MAS4]REACOMP(NBPRJ-1) : V2_ECA = [M:MAS4]ECARTCOMP(NBPRJ-1)
  Gosub ALIM_LIGN
 [M:MAS4]AMT(NBPRJ-1)     = V1_AMT : [M:MAS4]REA(NBPRJ-1)     = V1_REA : [M:MAS4]ECART(NBPRJ-1)     = V1_ECA
 [M:MAS4]AMTCOMP(NBPRJ-1) = V2_AMT : [M:MAS4]REACOMP(NBPRJ-1) = V2_REA : [M:MAS4]ECARTCOMP(NBPRJ-1) = V2_ECA
 # FQ76933 - MABON 11/10/11 - On met dans ces colonnes uniquement les montants qui seront à cumuler dans les sous-totaux et totaux
 If [F:RUB]NOSUMMS <> 2 & [F:MSR]NOSUMMS <> 2
  [M:MAS4]AMTT(NBPRJ-1)     += V1_AMTT : [M:MAS4]REAT(NBPRJ-1)     += V1_REAT
  [M:MAS4]AMTCOMPT(NBPRJ-1) += V2_AMTT : [M:MAS4]REACOMPT(NBPRJ-1) += V2_REAT
 Endif
 # Fin MABON

[M:MAS4]NBLIG=NBPRJ
Endif
Return
######################################################################################
$TOTAUX
If [F:RUB]NOSUMMS <> 2 & [F:MSR]NOSUMMS <> 2

#57273
#If CRITERE<>OLDCRIT | CRITERE0<>OLDCRIT0 |CRITERE1<>OLDCRIT1 | find(2,[M:MAS1]RAZSUM(0..1))
#70009
If CRITERE<>OLDCRIT | CRITERE0<>OLDCRIT0 |CRITERE1<>OLDCRIT1 | CRITERE3<>OLDCRIT3 | find(2,[M:MAS1]RAZSUM(0..1)) | OLDDAT<>CRITDAT
If year([F:MHS]DAT) = year([M:MAS1]DAT) & month([F:MHS]DAT) = month([M:MAS1]DAT)   :#MOIS
  V_PROJ = 0
  V1_AMT = [M:MAS2]TTBUD     : V1_REA = [M:MAS2]TTREA     : V1_ECA = [M:MAS2]TTECA
  V2_AMT = [M:MAS2]TTBUDCOMP : V2_REA = [M:MAS2]TTREACOMP : V2_ECA = [M:MAS2]TTECACOMP
   Gosub ALIM_LIGN
  [M:MAS2]TTBUD     = V1_AMT : [M:MAS2]TTREA     = V1_REA : [M:MAS2]TTECA     = V1_ECA
  [M:MAS2]TTBUDCOMP = V2_AMT : [M:MAS2]TTREACOMP = V2_REA : [M:MAS2]TTECACOMP = V2_ECA
 Endif
 If [F:MHS]DAT >= [M:MAS1]STRDAT(0) & [F:MHS]DAT <= [M:MAS1]DATFIN                 :#Cumul MOIS
  V_PROJ = 0
  V1_AMT = [M:MAS3]TTBUD     : V1_REA = [M:MAS3]TTREA     : V1_ECA = [M:MAS3]TTECA
  V2_AMT = [M:MAS3]TTBUDCOMP : V2_REA = [M:MAS3]TTREACOMP : V2_ECA = [M:MAS3]TTECACOMP
   Gosub ALIM_LIGN
  [M:MAS3]TTBUD     = V1_AMT : [M:MAS3]TTREA     = V1_REA : [M:MAS3]TTECA     = V1_ECA
  [M:MAS3]TTBUDCOMP = V2_AMT : [M:MAS3]TTREACOMP = V2_REA : [M:MAS3]TTECACOMP = V2_ECA
 Endif
 If [F:MHS]DAT >= [M:MAS1]STRDAT(0) & [F:MHS]DAT <= [M:MAS1]ENDDAT(0)              :#Projection
  V_PROJ = 1
  V1_AMT = [M:MAS4]TTBUD     : V1_REA = [M:MAS4]TTREA     : V1_ECA = [M:MAS4]TTECA
  V2_AMT = [M:MAS4]TTBUDCOMP : V2_REA = [M:MAS4]TTREACOMP : V2_ECA = [M:MAS4]TTECACOMP
   Gosub ALIM_LIGN
  [M:MAS4]TTBUD     = V1_AMT : [M:MAS4]TTREA     = V1_REA : [M:MAS4]TTECA     = V1_ECA
  [M:MAS4]TTBUDCOMP = V2_AMT : [M:MAS4]TTREACOMP = V2_REA : [M:MAS4]TTECACOMP = V2_ECA
 Endif
Endif

Endif

Return


######################################################################################
$ALIM_LIGN
# Alimentation d'une ligne pour le scénario 1 ou pour le scénario 2
# projection : récupération du simulé dans le réel au delà de la date de maj du réel
# FQ76933 - MABON 11/10/11 - Ajout V1_AMTT, V1_REAT, V2_AMTT et V2_REAT
V1_AMTT = 0 : V1_REAT = 0
V2_AMTT = 0 : V2_REAT = 0
If IND1 <> 0
 If [F:MHS]SIM = 2             : # Calcul MS
  V1_AMT     += [F:MHS]AMT : V1_AMTT = [F:MHS]AMT
  If V_PROJ & ( [F:MHS]DAT > [M:MAS1]READAT(0) | [F:MHS]EMP <> "" )  : # 73294
   V1_REA     += [F:MHS]AMT : V1_REAT = [F:MHS]AMT
  Endif
 Else
  V1_REA     += [F:MHS]REA     : #Paie Réelle
  V1_REAT     = [F:MHS]REA
 Endif
 Gosub CALCUL_ECA1

# Si on voulait comparer le même scénario (!) on mettrait endif/if au lieu de elsif
#Elsif IND2 <> 0
Endif
If IND2 <> 0
 If [F:MHS]SIM = 2
  V2_AMT += [F:MHS]AMT : V2_AMTT = [F:MHS]AMT
  If V_PROJ & ( [F:MHS]DAT > [M:MAS1]READAT(1) | [F:MHS]EMP <> "" )  : # 73294
   V2_REA     += [F:MHS]AMT : V2_REAT = [F:MHS]AMT
  Endif
 Else
  V2_REA += [F:MHS]REA : V2_REAT = [F:MHS]REA
 Endif
 Gosub CALCUL_ECA2

Endif

Return

$CALCUL_ECA1
#calcul de l'écart réalisé - budgété
 If [M:MAS1]DISPLAY = 1 & V1_REA <> 0 & V1_AMT <> 0   : # en %
  V1_ECA     = (( V1_REA / V1_AMT ) - 1 ) * 100
 Elsif [M:MAS1]DISPLAY = 2                            : # en montant
  V1_ECA     = V1_REA - V1_AMT
 Endif
Return

$CALCUL_ECA2
 If [M:MAS1]DISPLAY = 1 & V2_REA <> 0 & V2_AMT <> 0
  V2_ECA = (( V2_REA / V2_AMT ) - 1 ) * 100
 Elsif [M:MAS1]DISPLAY = 2
  V2_ECA = V2_REA - V2_AMT
 Endif
Return

######################################################################################
$CREER_FILTRE
#Filtre des données à parcourir selon les critères de sélection
CRITERE ="1=1"
CRITERE0="1=2"  : # parce que c'est un 'or' dans TRI_FILTRE
CRITERE1="1=1"
CRITERE2="1=1"
CRITERE3="1=1" #70009

CRITDAT = [M:MAS1]DAT

#Les scénarii , la paie réelle et Les hypothèses actives par périodes
If ACTMAX(1) < 6   : # Si il y a peu d'hypothèses à sélectionner on a la place dans CRITERE
 CRITERE    =  '(([F:MHS]COD="'+CURSCECOD+'" & ([F:MHS]SIM=1'
 For I = 0 To ACTMAX(1)-1
  If I > 0 and ([M:MAS1]ACTSCE1(I) <> [M:MAS1]ACTSCE1(I-1))
   CRITERE +=  string$(I>0,')) |')
   CRITERE -=  '([F:MHS]COD="'+[M:MAS1]ACTSCE1(I)+'"'
   If I>0 & CURDATREV<>[0/0/0]
    CRITERE -= '& [F:MHS]DAT<['+num$(CURDATREV)+']'
   Endif
   CRITERE -=  '& ('
  Else
   CRITERE -=  '|'
  Endif
  CRITERE  -=  '[F:MHS]LIGHYP='+num$([M:MAS1]ACTHYP1(I))
 Next
 CRITERE   +=  ')))'
Else         : # Si il y a trop d'hypothèses à sélectionner on simplifie
# 58935 WGA
# CRITERE   = 'find([F:MHS]COD,[M:MAS1]ACTSCE1)<> 0'
 CRITERE    =  '([F:MHS]COD="'+CURSCECOD+'"'
 For I = 0 To ACTMAX(1)-1
  If [M:MAS1]ACTSCE1(I) <> CURSCECOD & [M:MAS1]ACTSCE1(I) <> [M:MAS1]ACTSCE1(I-1)
   CRITERE -=  '| ([F:MHS]COD="'+[M:MAS1]ACTSCE1(I)+'" & [F:MHS]SIM=2'
    If I>0 & CURDATREV<>[0/0/0]
      CRITERE -= '& [F:MHS]DAT<['+num$(CURDATREV)+'])'
    Else
      CRITERE +=")"
    Endif
  Endif
 Next
 CRITERE   +=  ')'
# fin 58935
Endif

If [M:MAS1]CODCOMP <> ""
 If ACTMAX(2) < 6
  CRITERE0    =  '(([F:MHS]COD="'+[M:MAS1]CODCOMP+'" & ([F:MHS]SIM=1'
  For I = 0 To ACTMAX(2)-1
   If I > 0 and [M:MAS1]ACTSCE2(I) <> [M:MAS1]ACTSCE2(I-1)
    CRITERE0 +=  string$(I>0,')) |')
    CRITERE0 -=  '([F:MHS]COD="'+[M:MAS1]ACTSCE2(I)+'"'
    If I>0 & CURDATREV<>[0/0/0]
      CRITERE0 -= '& [F:MHS]DAT<['+num$(CURDATREV)+']'
    Endif
    CRITERE0 -=  '& ('
   Else
    CRITERE0 -=  '|'
   Endif
   CRITERE0  -=  '[F:MHS]LIGHYP='+num$([M:MAS1]ACTHYP2(I))
  Next
  CRITERE0   +=  ')))'
 Else
 # 58935 WGA
 # CRITERE0    = 'find([F:MHS]COD,[M:MAS1]ACTSCE2)<> 0'
  CRITERE0   =  '([F:MHS]COD="'+[M:MAS1]CODCOMP+'"'
  For I = 0 To ACTMAX(2)-1
   If [M:MAS1]ACTSCE2(I) <> [M:MAS1]CODCOMP & [M:MAS1]ACTSCE2(I) <> [M:MAS1]ACTSCE2(I-1)
    CRITERE0 -=  '| ([F:MHS]COD="'+[M:MAS1]ACTSCE2(I)+'" & [F:MHS]SIM=2'
      If I>0 & CURDATREV<>[0/0/0]
        CRITERE0 -= '& [F:MHS]DAT<['+num$(CURDATREV)+'])'
      Else
        CRITERE0 +=")"
      Endif
   Endif
  Next
  CRITERE0  +=  ')'
 # fin 58935
 Endif
Endif

#Les types de montants
CRITERE1  = '[F:MHS]TYP < 6 & [F:MHS]GRP <> ""'

#Les critères de sélection

#57313
If [M:MAS1]FCY<>""
 CRITERE1 -= '& [F:MHS]FCY="'+[M:MAS1]FCY+'"'
Elsif [M:MAS1]CPY<>""
 Read [CPY]CPY0=[M:MAS1]CPY
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITERE1 -= '& [F:MHS]CPY="'+[M:MAS1]CPY+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  Raz FCYGRP()
  For [FGR]FGR0 Where CPY=[M:MAS1]CPY
   If !find([F:FGR]FCY,FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
#70018
#   CRITERE1 = 'find([F:MHS]FCY,FCYGRP(1..'+num$(I-1)+'))'
   CRITERE1 -= '& find([F:MHS]FCY, FCYGRP(1..'+num$(I-1)+'))'
#end 70018
  Endif
 Endif
Endif
# fin 57313
If [M:MAS1]SRV<>""
 CRITERE1 -= '& [F:MHS]SRV="'+[M:MAS1]SRV+'"'
Endif
If [M:MAS1]EMP<>""
 CRITERE1 -= '& (([F:MHS]EMP="'+[M:MAS1]EMP+'" & [F:MHS]MSEMP="") | [F:MHS]MSEMP="'+[M:MAS1]EMP+'")'
Endif
If [M:MAS1]CTR<>""
 CRITERE1 -= '& [F:MHS]CTR="'+[M:MAS1]CTR+'"'
Endif

#Les filtres supplémentaires
If [M:CMAS]CAT<>""
 CRITERE1 -= '& [F:MHS]CAT="'+[M:CMAS]CAT+'"'
Endif
If [M:CMAS]GRP<>""
 CRITERE1 -= '& [F:MHS]GRP="'+[M:CMAS]GRP+'"'
Endif
#72636
If [M:CMAS]RUB<>""
  CRITERE1 -= '& [F:MHS]RUB="'+[M:CMAS]RUB+'"'
Elsif [M:MAS1]LISRUB<>""
  I=1
  Raz RUBGRP()
  For [MLR]MLR0 Where COD = [M:MAS1]LISRUB
    If func CTRL_RUB_ACCES([F:MLR]CODRUB) & !find([F:MLR]CODRUB,RUBGRP(1..I))
      RUBGRP(I) = [F:MLR]CODRUB
      I +=1
    Endif
  Next
  If I>1
   CRITERE1 -= '& find([F:MHS]RUB, RUBGRP(1..'+num$(I-1)+'))'
  Endif
Endif
#end 72636
#70009
If [M:MAS1]PRF<>""
  CRITERE3 = '[F:MHS]PRF="'+[M:MAS1]PRF+'"'
Endif
If [M:MAS1]JOBPOT<>""
  CRITERE3 -= '& [F:MHS]JOBPOT="'+[M:MAS1]JOBPOT+'"'
Endif
If [M:MAS1]POT<>""
  CRITERE3 -= '& [F:MHS]POT="'+[M:MAS1]POT+'"'
Endif
#end 70009

#Gestion de la pagination
#57273
#If CRITERE=OLDCRIT & CRITERE0=OLDCRIT0 & CRITERE1=OLDCRIT1
If CRITERE=OLDCRIT & CRITERE0=OLDCRIT0 & CRITERE1=OLDCRIT1 & CRITDAT=OLDDAT & CRITERE3=OLDCRIT3
 Gosub FILTRE_NAV
Endif
Return

######################################################################################
$TRI_FILTRE
#Clé de tri des données parcourues en fonction du détail demandé
If CHGPAG>0
Case [M:MAS1]DETAIL # ML 489
 When 1 # Pas de détail
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
#& Order By Key CLE = [F:MHS]CAT;[F:MHS]GRP;[F:MHS]RUB - 70009 Tri selon rang sur table div.655
 When 2 # Détail sociétés
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]CPY;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 3 # Détail sites
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]FCY;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 4 # Détail services
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]SRV;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 5 # Détail profil
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]PRF;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 6 # Détail emploi type
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]JOBPOT;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 7 # Détail poste
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]POT;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
 When 8,9 # Détail salarié & contrat
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]MSEMP;[F:MHS]EMP;[F:MHS]CTR;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Endcase
Else
Case [M:MAS1]DETAIL
 When 1 # Pas de détail
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 2 # Détail sociétés
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]CPY Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 3 # Détail sites
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]FCY Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 4 # Détail services
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]SRV Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 5 # Détail profil
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]PRF Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 6 # Détail emploi type
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]JOBPOT Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 7 # Détail poste
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]POT Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
 When 8,9 # Détail salarié & contrat
  Filter [F:LNK] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
& Order By Key CLE = [F:MHS]MSEMP Desc;[F:MHS]EMP Desc;[F:MHS]CTR Desc;[F:ADI0]N1 Desc;[F:MHS]GRP Desc;[F:MHS]RUB Desc
Endcase
Endif
Return

######################################################################################
$CHG_PAGE
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
Return

######################################################################################
$LIEN
If [M:MAS1]POP<>""
 Link [F:MHS] With
&   [F:HRPOA]POA0  = [M:MAS1]POP;[F:MHS]EMP
& , [F:RUB]RUB0  = [F:MHS]RUB
& , [F:MSR]MSR0  = [F:MHS]RUB
& , [F:ADI0]CODE = 10655;[F:MHS]CAT
&   As [LNK]
&   Where [F:HRPOA]REFNUM<>""
Else
 Link [F:MHS] With
&   [F:RUB]RUB0  = [F:MHS]RUB
& , [F:MSR]MSR0  = [F:MHS]RUB
& , [F:ADI0]CODE = 10655;[F:MHS]CAT
&   As [LNK]
Endif

Return

######################################################################################
$RUPTURE
Raz RUPT , FRUPT , FRUPT2
#Ruptures sur le niveau affiché (Rubrique,Groupe,Catégorie)
If [M:MAS1]NIVEAU = 1
 If [F:MHS]RUB <> SAVRUB | [F:MHS]GRP <> SAVGRP | [F:MHS]CAT <> SAVCAT
  RUPT = 1
 Endif
Elsif [M:MAS1]NIVEAU = 2
 If [F:MHS]GRP <> SAVGRP | [F:MHS]CAT <> SAVCAT
  RUPT = 1
 Endif
Else
 If [F:MHS]CAT <> SAVCAT
  RUPT = 1
 Endif
Endif

#Ruptures sur le détail affiché - menu local 489
Case [M:MAS1]DETAIL
 When 2 # Détail par société
  If [F:MHS]CPY <> SAVCPY : RUPT = 1 : Endif
  FRUPT = "CPY"
 When 3 # Détail par site
  If [F:MHS]FCY <> SAVFCY : RUPT = 1 : Endif
  FRUPT = "FCY"
 When 4 # Détail par service
  If [F:MHS]SRV <> SAVSRV : RUPT = 1 : Endif
  FRUPT = "SRV"
 When 5 # Détail par profil
  If [F:MHS]PRF <> SAVPRO : RUPT = 1 : Endif
  FRUPT = "PRF"
 When 6 # Détail par emploi type
  If [F:MHS]JOBPOT <> SAVJOB : RUPT = 1 : Endif
  FRUPT = "JOBPOT"
 When 7 # Détail par poste
  If [F:MHS]POT <> SAVPOT : RUPT = 1 : Endif
  FRUPT = "POT"
 When 8 # Détail par salarié
  If [F:MHS]EMP <> SAVEMP |  [F:MHS]MSEMP <> SAVMSE
   RUPT = 1
  Endif
  FRUPT = "EMP"
  If [F:MHS]MSEMP <> "" : FRUPT = "MSEMP" : Endif
 When 9 # Détail par contrat
  If [F:MHS]CTR <> SAVCTR |  [F:MHS]MSEMP <> SAVMSE
   RUPT = 1
  Endif
  FRUPT = "CTR"  : FRUPT2 = "EMP"
  If [F:MHS]MSEMP <> "" : FRUPT = "MSEMP" : Raz FRUPT2 : Endif
Endcase
Return

######################################################################################
$FILTRE_NAV
#Selon le détail consulté et le niveau d'agrégation des rubriques
Case CHGPAG

 When 2 :#suite
  Case [M:MAS1]NIVEAU
   When 1   : CRITERE2 = '[F:MHS]CAT >="'+FINCAT+'"'-'& [F:MHS]GRP >="'+FINGRP+'"'-'& [F:MHS]RUB >="'+FINRUB+'"'
   When 2   : CRITERE2 = '[F:MHS]CAT >="'+FINCAT+'"'-'& [F:MHS]GRP >="'+FINGRP+'"'
   When 3   : CRITERE2 = '[F:MHS]CAT >="'+FINCAT+'"'
  Endcase
  Case [M:MAS1]DETAIL # ML 489
   When 2   : CRITERE2  = '([F:MHS]CPY ="'+FINCPY+'" &'-CRITERE2+') | [F:MHS]CPY >"'+FINCPY+'"'
   When 3   : CRITERE2  = '([F:MHS]FCY ="'+FINFCY+'" &'-CRITERE2+') | [F:MHS]FCY >"'+FINFCY+'"'
   When 4   : CRITERE2  = '([F:MHS]SRV ="'+FINSRV+'" &'-CRITERE2+') | [F:MHS]SRV >"'+FINSRV+'"'
   When 5   : CRITERE2  = '([F:MHS]PRF ="'+FINPRO+'" &'-CRITERE2+') | [F:MHS]PRF >"'+FINPRO+'"'
   When 6   : CRITERE2  = '([F:MHS]JOBPOT ="'+FINJOB+'" &'-CRITERE2+') | [F:MHS]JOBPOT >"'+FINJOB+'"'
   When 7   : CRITERE2  = '([F:MHS]POT ="'+FINPOT+'" &'-CRITERE2+') | [F:MHS]POT >"'+FINPOT+'"'
   When 8,9 : CRITERE2  =
&         '(([F:MHS]MSEMP ="'+FINMSE+'"'-'& [F:MHS]EMP ="'+FINEMP+'"'-'& [F:MHS]CTR >="'+FINCTR+'")'
&         -'&'-CRITERE2+') |'
          If FINMSE<>""
           CRITERE2 -='([F:MHS]MSEMP >"'+FINMSE+'"'-'& [F:MHS]EMP >="'+FINEMP+'")'
          Else
           CRITERE2 -='[F:MHS]EMP >"'+FINEMP+'"'
          Endif
  Endcase

 When -2 :#retour
  Case [M:MAS1]NIVEAU
   When 1   : CRITERE2 = '[F:MHS]CAT <="'+DEBCAT+'"'-'& [F:MHS]GRP <="'+DEBGRP+'"'-'& [F:MHS]RUB <"'+DEBRUB+'"'
   When 2   : CRITERE2 = '[F:MHS]CAT <="'+DEBCAT+'"'-'& [F:MHS]GRP <"'+DEBGRP+'"'
   When 3   : CRITERE2 = '[F:MHS]CAT <"'+DEBCAT+'"'
  Endcase
  Case [M:MAS1]DETAIL # ML 489
   When 2   : CRITERE2  = '([F:MHS]CPY ="'+DEBCPY+'" &'-CRITERE2+') | [F:MHS]CPY <"'+DEBCPY+'"'
   When 3   : CRITERE2  = '([F:MHS]FCY ="'+DEBFCY+'" &'-CRITERE2+') | [F:MHS]FCY <"'+DEBFCY+'"'
   When 4   : CRITERE2  = '([F:MHS]SRV ="'+DEBSRV+'" &'-CRITERE2+') | [F:MHS]SRV <"'+DEBSRV+'"'
   When 5   : CRITERE2  = '([F:MHS]PRF ="'+DEBPRO+'" &'-CRITERE2+') | [F:MHS]PRF <"'+DEBPRO+'"'
   When 6   : CRITERE2  = '([F:MHS]JOBPOT ="'+DEBJOB+'" &'-CRITERE2+') | [F:MHS]JOBPOT <"'+DEBJOB+'"'
   When 7   : CRITERE2  = '([F:MHS]POT ="'+DEBPOT+'" &'-CRITERE2+') | [F:MHS]POT <"'+DEBPOT+'"'
   When 8,9 : CRITERE2  =
&         '(([F:MHS]MSEMP ="'+DEBMSE+'"'-'& [F:MHS]EMP ="'+DEBEMP+'"'-'& [F:MHS]CTR <="'+DEBCTR+'")'
&         -'&'-CRITERE2+') |'
          If DEBMSE<>""
           CRITERE2 -='([F:MHS]MSEMP <"'+DEBMSE+'"'-'& [F:MHS]EMP <="'+DEBEMP+'")'
          Else
           CRITERE2 -='[F:MHS]EMP <"'+DEBEMP+'"'
          Endif
  Endcase
Endcase
Return

######################################################################################
$LIB_MCH
[M:MAS2]MCH  = mess(16,10722,1)-mess([M:MAS1]TYPMCH(0),10486,1)                        : #Scénario type
If [M:MAS1]TYPMCH(0) = 1
 [M:MAS2]MCH -= "("+[M:MAS1]CODHYP(0)+")"
Endif
[M:MAS2]MCH -= ",   "+mess(94,100,1)-format$("D:DD[/]MM[/]YYYY",[M:MAS1]STRDAT(0)) : #Du
[M:MAS2]MCH -= mess(95,100,1)-format$("D:DD[/]MM[/]YYYY",[M:MAS1]ENDDAT(0))        : #au
[M:MAS2]MCH -= ",   "+mess(21,10722,1)-format$("D:MM[/]YYYY",[M:MAS1]MTHREF(0))      : #Mois de référence

[M:MAS3]MCH  = [M:MAS2]MCH
[M:MAS4]MCH  = [M:MAS2]MCH
Affzo [M:MAS2]MCH
Affzo [M:MAS3]MCH
Affzo [M:MAS4]MCH
Return

######################################################################################
$LOOK_EXEPRE
#On essai d'optimiser et ne recalculer que le scénario qui a changé
#57273
#If CRITERE <> OLDCRIT | CRITERE0 <> OLDCRIT0 | CRITERE1 <> OLDCRIT1
If CRITERE <> OLDCRIT | CRITERE0 <> OLDCRIT0 | CRITERE1 <> OLDCRIT1 | CRITDAT<>OLDDAT | CRITERE3 <> OLDCRIT3
 [M:MAS1]RAZSUM(2) = 2
 [M:MAS1]RAZSUM(3) = 2
Endif
If find(2,[M:MAS1]RAZSUM(2..3))
 If [M:MAS1]RAZSUM(2) = 2
  Raz [M:MAS2]TTN1BUD , [M:MAS2]TTN1REA , [M:MAS2]TTN1ECA
  Raz [M:MAS3]TTN1BUD , [M:MAS3]TTN1REA , [M:MAS3]TTN1ECA
  Raz [M:MAS4]TTN1BUD , [M:MAS4]TTN1REA , [M:MAS4]TTN1ECA
 Endif
 If [M:MAS1]RAZSUM(3) = 2
  Raz [M:MAS2]TTN2BUD , [M:MAS2]TTN2REA , [M:MAS2]TTN2ECA
  Raz [M:MAS3]TTN2BUD , [M:MAS3]TTN2REA , [M:MAS3]TTN2ECA
  Raz [M:MAS4]TTN2BUD , [M:MAS4]TTN2REA , [M:MAS4]TTN2ECA
 Endif
 Gosub N1N2_FILTRE
 Gosub N1N2_LIEN
 Filter [F:LNK2] Where (evalue (CRITEREN) | evalue (CRITEREN0)) & evalue (CRITEREN1)  & evalue (CRITEREN3)
 ENR = rowcount([LNK2])
 Call SET_BOITE("Exercices précédents",ENR) From GESECRAN
#parcours et cumul
 For [F:LNK2]

  Gosub N1N2_FILT_ACTIV
  If (
&     ([F:MHS]TYP=2 & [F:RUB]TYPRUB=6) | ([F:MHS]TYP=2 & [F:MSR]TYPRUB=6) | ([F:RUB]TYPRUB<>6 & [F:MSR]TYPRUB<>6)
&    )
&    & [F:RUB]NOSUMMS <> 2 & [F:MSR]NOSUMMS <> 2

   If IND3 <> 0                    :  # Enreg d'histo sur le scénario3 N-1
    If [F:MHS]SIM = 2              :  # Paie simulée -calcul MS-
     If year([F:MHS]DAT) = year([M:MAS1]DATPAYN(0)) & month([F:MHS]DAT) = month([M:MAS1]DATPAYN(0))   :#MOIS N-1
      [M:MAS2]TTN1BUD     += [F:MHS]AMT
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(2) & [F:MHS]DAT <= [M:MAS1]DATPAYN(0)             :#CUM MOIS N-1
      [M:MAS3]TTN1BUD     += [F:MHS]AMT
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(2) & [F:MHS]DAT <= [M:MAS1]ENDDAT(2)              :#ANNUEL N-1
      [M:MAS4]TTN1BUD     += [F:MHS]AMT
      # pour la projexion
      If [F:MHS]DAT > [M:MAS1]READAT(2)
       [M:MAS4]TTN1REA    += [F:MHS]AMT
      Endif
     Endif
    Else                          :  # Paie réelle
     If year([F:MHS]DAT) = year([M:MAS1]DATPAYN(0)) & month([F:MHS]DAT) = month([M:MAS1]DATPAYN(0))   :#Réel MOIS N-1
      [M:MAS2]TTN1REA     += [F:MHS]REA
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(2) & [F:MHS]DAT <= [M:MAS1]DATPAYN(0)             :#Réel CUM MOIS N-1
      [M:MAS3]TTN1REA     += [F:MHS]REA
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(2) & [F:MHS]DAT <= [M:MAS1]ENDDAT(2)              :#Réel ANNUEL N-1
      [M:MAS4]TTN1REA     += [F:MHS]REA
     Endif
    Endif
   Endif

   If IND4 <> 0                    :  # Enreg d'histo sur le scénario4 N-2
    If [F:MHS]SIM = 2
     If year([F:MHS]DAT) = year([M:MAS1]DATPAYN(1)) & month([F:MHS]DAT) = month([M:MAS1]DATPAYN(1))   :#MOIS N-2
      [M:MAS2]TTN2BUD     += [F:MHS]AMT
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(3) & [F:MHS]DAT <= [M:MAS1]DATPAYN(1)             :#CUM MOIS N-2
      [M:MAS3]TTN2BUD     += [F:MHS]AMT
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(3) & [F:MHS]DAT <= [M:MAS1]ENDDAT(3)              :#ANNUEL N-2
      [M:MAS4]TTN2BUD     += [F:MHS]AMT
      # pour la projexion
      If [F:MHS]DAT > [M:MAS1]READAT(3)
       [M:MAS4]TTN2REA    += [F:MHS]AMT
      Endif
     Endif
    Else
     If year([F:MHS]DAT) = year([M:MAS1]DATPAYN(1)) & month([F:MHS]DAT) = month([M:MAS1]DATPAYN(1))   :#Réel MOIS N-2
      [M:MAS2]TTN2REA     += [F:MHS]REA
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(3) & [F:MHS]DAT <= [M:MAS1]DATPAYN(1)             :#Réel CUM MOIS N-2
      [M:MAS3]TTN2REA     += [F:MHS]REA
     Endif
     If [F:MHS]DAT >= [M:MAS1]STRDAT(3) & [F:MHS]DAT <= [M:MAS1]ENDDAT(3)              :#Réel ANNUEL N-2
      [M:MAS4]TTN2REA     += [F:MHS]REA
     Endif
    Endif
   Endif
  Endif
 Next
Endif

V1_AMT = [M:MAS2]TTN1BUD : V1_REA = [M:MAS2]TTN1REA : V1_ECA = [M:MAS2]TTN1ECA
V2_AMT = [M:MAS2]TTN2BUD : V2_REA = [M:MAS2]TTN2REA : V2_ECA = [M:MAS2]TTN2ECA
Gosub CALCUL_ECA1
Gosub CALCUL_ECA2
[M:MAS2]TTN1BUD = V1_AMT : [M:MAS2]TTN1REA = V1_REA : [M:MAS2]TTN1ECA = V1_ECA
[M:MAS2]TTN2BUD = V2_AMT : [M:MAS2]TTN2REA = V2_REA : [M:MAS2]TTN2ECA = V2_ECA

V1_AMT = [M:MAS3]TTN1BUD : V1_REA = [M:MAS3]TTN1REA : V1_ECA = [M:MAS3]TTN1ECA
V2_AMT = [M:MAS3]TTN2BUD : V2_REA = [M:MAS3]TTN2REA : V2_ECA = [M:MAS3]TTN2ECA
Gosub CALCUL_ECA1
Gosub CALCUL_ECA2
[M:MAS3]TTN1BUD = V1_AMT : [M:MAS3]TTN1REA = V1_REA : [M:MAS3]TTN1ECA = V1_ECA
[M:MAS3]TTN2BUD = V2_AMT : [M:MAS3]TTN2REA = V2_REA : [M:MAS3]TTN2ECA = V2_ECA

V1_AMT = [M:MAS4]TTN1BUD : V1_REA = [M:MAS4]TTN1REA : V1_ECA = [M:MAS4]TTN1ECA
V2_AMT = [M:MAS4]TTN2BUD : V2_REA = [M:MAS4]TTN2REA : V2_ECA = [M:MAS4]TTN2ECA
Gosub CALCUL_ECA1
Gosub CALCUL_ECA2
[M:MAS4]TTN1BUD = V1_AMT : [M:MAS4]TTN1REA = V1_REA : [M:MAS4]TTN1ECA = V1_ECA
[M:MAS4]TTN2BUD = V2_AMT : [M:MAS4]TTN2REA = V2_REA : [M:MAS4]TTN2ECA = V2_ECA

OLDCRITN  = CRITEREN
OLDCRITN0 = CRITEREN0
OLDCRITN1 = CRITEREN1
Return
######################################################################################
$N1N2_FILTRE
#Filtre des données à parcourir selon les critères de sélection
CRITEREN ="1=2"
CRITEREN0="1=2"
CRITEREN1="1=1"
CRITEREN3="1=1"

#Les scénarii , la paie réelle et Les hypothèses actives par périodes
If [M:MAS1]CODN1 <> "" & [M:MAS1]RAZSUM(2) = 2
 If ACTMAX(3) < 6   : # Si il y a peu d'hypothèses à sélectionner on a la place dans CRITEREN
  CRITEREN    =  '(([F:MHS]COD="'+[M:MAS1]CODN1+'" & [F:MHS]SIM=1) |'
  For I = 0 To ACTMAX(3)-1
   If I = 0 or [M:MAS1]ACTSCE3(I) <> [M:MAS1]ACTSCE3(I-1)
    CRITEREN +=  string$(I>0,')) |')
    CRITEREN -=  '([F:MHS]COD="'+[M:MAS1]ACTSCE3(I)+'"'
    CRITEREN -=  '& ('
   Else
    CRITEREN -=  '|'
   Endif
   CRITEREN  -=  '[F:MHS]LIGHYP='+num$([M:MAS1]ACTHYP3(I))
  Next
  CRITEREN   +=  ')))'
 Else         : # Si il y a trop d'hypothèses à sélectionner on simplifie
  # 58935 WGA
  #CRITEREN   = 'find([F:MHS]COD,[M:MAS1]ACTSCE3)<> 0'
  CRITEREN   =  '([F:MHS]COD="'+[M:MAS1]CODN1+'"'
  For I = 0 To ACTMAX(3)-1
   If [M:MAS1]ACTSCE3(I) <> [M:MAS1]CODN1 & [M:MAS1]ACTSCE3(I) <> [M:MAS1]ACTSCE3(I-1)
    CRITEREN -=  '| ([F:MHS]COD="'+[M:MAS1]ACTSCE3(I)+'" & [F:MHS]SIM=2)'
   Endif
  Next
  CRITEREN   +=  ')'
  # fin 58935
 Endif
Endif
If [M:MAS1]CODN2 <> "" & [M:MAS1]RAZSUM(3) = 2
 If ACTMAX(4) < 6
  CRITEREN0    =  '(([F:MHS]COD="'+[M:MAS1]CODN2+'" & [F:MHS]SIM=1) |'
  For I = 0 To ACTMAX(4)-1
   If I = 0 or [M:MAS1]ACTSCE4(I) <> [M:MAS1]ACTSCE4(I-1)
    CRITEREN0 +=  string$(I>0,')) |')
    CRITEREN0 -=  '([F:MHS]COD="'+[M:MAS1]ACTSCE4(I)+'"'
    CRITEREN0 -=  '& ('
   Else
    CRITEREN0 -=  '|'
   Endif
   CRITEREN0  -=  '[F:MHS]LIGHYP='+num$([M:MAS1]ACTHYP4(I))
  Next
  CRITEREN0   +=  ')))'
 Else
  # 58935 WGA
  #  CRITEREN0    = 'find([F:MHS]COD,[M:MAS1]ACTSCE4)<> 0'
  CRITEREN0    =  '([F:MHS]COD="'+[M:MAS1]CODN2+'"'
  For I = 0 To ACTMAX(4)-1
   If [M:MAS1]ACTSCE4(I) <> [M:MAS1]CODN2 & [M:MAS1]ACTSCE4(I) <> [M:MAS1]ACTSCE4(I-1)
    CRITEREN0 -=  '| ([F:MHS]COD="'+[M:MAS1]ACTSCE4(I)+'" & [F:MHS]SIM=2)'
   Endif
  Next
  CRITEREN0   +=  ')'
  # fin 58935
 Endif
Endif

#Les types de montants
CRITEREN1  = '[F:MHS]TYP < 6'

#Les critères de sélection
#57313
If [M:MAS1]FCY<>""
 CRITEREN1 -= '& [F:MHS]FCY="'+[M:MAS1]FCY+'"'
Elsif [M:MAS1]CPY<>""
 Read [CPY]CPY0=[M:MAS1]CPY
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITEREN1 -= '& [F:MHS]CPY="'+[M:MAS1]CPY+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  Raz FCYGRP()
  For [FGR]FGR0 Where CPY=[M:MAS1]CPY
   If !find([F:FGR]FCY, FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
#70018
#   CRITEREN1 = 'find([F:MHS]FCY,FCYGRP(1..'+num$(I-1)+'))'
   CRITEREN1 -= '& find([F:MHS]FCY, FCYGRP(1..'+num$(I-1)+'))'
#end 70018
  Endif
 Endif
Endif
# fin 57313

If [M:MAS1]SRV<>""
 CRITEREN1 -= '& [F:MHS]SRV="'+[M:MAS1]SRV+'"'
Endif
If [M:MAS1]EMP<>""
 CRITEREN1 -= '& (([F:MHS]EMP="'+[M:MAS1]EMP+'" & [F:MHS]MSEMP="") | [F:MHS]MSEMP="'+[M:MAS1]EMP+'")'
Endif
If [M:MAS1]CTR<>""
 CRITEREN1 -= '& [F:MHS]CTR="'+[M:MAS1]CTR+'"'
Endif

#Les filtres supplémentaires
If [M:CMAS]CAT<>""
 CRITEREN1 -= '& [F:MHS]CAT="'+[M:CMAS]CAT+'"'
Endif
If [M:CMAS]GRP<>""
 CRITEREN1 -= '& [F:MHS]GRP="'+[M:CMAS]GRP+'"'
Endif
#72636
If [M:CMAS]RUB<>""
  CRITEREN1 -= '& [F:MHS]RUB="'+[M:CMAS]RUB+'"'
Elsif [M:MAS1]LISRUB<>""
  I=1
  Raz RUBGRP()
  For [MLR]MLR0 Where COD = [M:MAS1]LISRUB
    If func CTRL_RUB_ACCES([F:MLR]CODRUB) & !find([F:MLR]CODRUB,RUBGRP(1..I))
      RUBGRP(I) = [F:MLR]CODRUB
      I +=1
    Endif
  Next
  If I>1
   CRITEREN1 -= '& find([F:MHS]RUB, RUBGRP(1..'+num$(I-1)+'))'
  Endif
Endif
#end 72636

#70009
If [M:MAS1]PRF<>""
  CRITEREN3 = '[F:MHS]PRF="'+[M:MAS1]PRF+'"'
Endif
If [M:MAS1]JOBPOT<>""
  CRITEREN3 -= '& [F:MHS]JOBPOT="'+[M:MAS1]JOBPOT+'"'
Endif
If [M:MAS1]POT<>""
  CRITEREN3 -= '& [F:MHS]POT="'+[M:MAS1]POT+'"'
Endif
#end 70009

Return
######################################################################################
$N1N2_LIEN

#Liaison
If [M:MAS1]POP<>""
 Link [F:MHS] With
&   [F:HRPOA]POA0 = [M:MAS1]POP;[F:MHS]EMP
& , [F:RUB]RUB0 = [F:MHS]RUB
& , [F:MSR]MSR0 = [F:MHS]RUB
&   As [LNK2]
&   Where [F:HRPOA]REFNUM<>"" & [F:MHS]GRP <> ""
Else
 Link [F:MHS] With
&   [F:RUB]RUB0 = [F:MHS]RUB
& , [F:MSR]MSR0 = [F:MHS]RUB
&   As [LNK2]
&   Where  [F:MHS]GRP <> ""

Endif
Return
######################################################################################
Subprog CTRL_COD(CODS,DATS,N,SCEN,LIGN,DDEB,DFIN,TINI)
Value    Char    CODS ()
Value    Date    DATS
Value    Integer N
Variable Char    SCEN()(1..)
Variable Decimal LIGN (1..)
Variable Date    DDEB (1..)
Variable Date    DFIN (1..)
Value    Integer TINI


Raz [M:MAS1]STRDAT(N) , [M:MAS1]ENDDAT(N) , [M:MAS1]MTHREF(N) , [M:MAS1]READAT(N)
Raz [M:MAS1]TYPMCH(N)
Raz SCEN, LIGN , DDEB , DFIN

If CODS <> ""
 If [F:MCH]COD <> CODS
  Read [F:MCH]MCH0= CODS
 Endif
 [M:MAS1]STRDAT(N) = [F:MCH]STRDAT
 [M:MAS1]ENDDAT(N) = [F:MCH]ENDDAT
 [M:MAS1]READAT(N) = [F:MCH]DATMAJREA
 [M:MAS1]MTHREF(N) = [F:MCH]MTHREF
 [M:MAS1]TYPMCH(N) = [F:MCH]TYPMCH
 If [F:MCH]TYPMCH = 1
  If TINI = 7
   [M:MAS1]CODHYP(N) = [F:MCH]BUD(0)
  Else
   [M:MAS1]CODHYP(N) = [F:MCH]BUD(1)
  Endif
 Endif

 If DATS < [M:MAS1]STRDAT(N) | DATS > [M:MAS1]ENDDAT(N)
  GMESSAGE = "("+CODS+")"-num$(DATS)-mess(14,10722,1) : # Date en dehors de la période de simulation
  mkstat = 2 : End
 Endif

 EXEFULL = 1
 Call ALIM_HYPO_ACTIV(N+1,CODS,[M:MAS1]STRDAT(N),[M:MAS1]ENDDAT(N),SCEN,LIGN,DDEB,DFIN,EXEFULL,TINI)
 If EXEFULL = 0
 Endif

 Filter
 #On vérifie l'homogénéité des critères des scénarii
 If [F:MCH]CPY <> SAVCRIT(1) | [F:MCH]FCY <> SAVCRIT(2) | [F:MCH]SRV <> SAVCRIT(3) | [F:MCH]PRF <> SAVCRIT(4)
& | [F:MCH]STRMAT <> SAVCRIT(5) | [F:MCH]ENDMAT <> SAVCRIT(6) | [F:MCH]POP <> SAVCRIT(7) | [F:MCH]CRI <> SAVCRIT1
& | [F:MCH]JOBPOT <> SAVCRIT(8) | [F:MCH]POT <> SAVCRIT(9) #70009
  Call MESSAGE(mess(28,10722,1)-'"'+[M:MAS1]COD+'"') From GESECRAN
  #Critère sur fiche scénario : Sélection de salariés différente du scénario
 Endif
Endif
End
######################################################################################
Subprog CTRL_DAT (DATS)
Variable Date    DATS
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**#On sélectionne les paies historisées dans le mois calendaire, donc date saisie non modifiée
#**DATPAY = DATS
#**If [M:MAS1]FCY=""
#** Call CADRE_PYRDAT(DATPAY,"") From TPSSUB
#** If mkstat
#**  Raz mkstat
#**  Filter [HRPEO] Where PERSTR(0)<=DATPAY & PEREND(0)>=DATPAY
#**  Read [HRPEO] First
#**  Filter [HRPEO]
#**  If fstat>2
#**   GMESSAGE = format$("D:MMMMMMMMM[]YYYY",DATS)-":"-mess(12,10709,1) : # Pas de paye définie à cette date
#**   mkstat = 2 : End
#**  Endif
#** Endif
#**Else
#** Call CADRE_PYRDAT(DATPAY,[M:MAS1]FCY) From TPSSUB
#** If mkstat
#**  GMESSAGE = format$("D:MMMMMMMMM[]YYYY",DATS)-":"-mess(12,10709,1) : # Pas de paye définie à cette date
#**  End
#** Endif
#**Endif
#**
DATPAY = DATS
If [M:MAS1]FCY=""
 Call CADRE_PYRDAT(DATPAY,"") From TPSSUB
 If mkstat
  Raz mkstat
  Filter [HRPEOD] Where PERSTR(0)<=DATPAY & PEREND(0)>=DATPAY
  Read [HRPEOD] First
  Filter [HRPEOD]
  If fstat>2
   GMESSAGE = format$("D:MMMMMMMMM[]YYYY",DATS)-":"-mess(12,10709,1) : # Pas de paye définie à cette date
   mkstat = 2 : End
  Endif
 Endif
Else
 #ADNGO - 2017-05-20 - START
 #Call CADRE_PYRDAT(DATPAY,[M:MAS1]FCY) From TPSSUB
 Call CADRE_PYRDAT(DATPAY,[F:HRPEOD]PERCOD) From TPSSUB
 #ADNGO - 2017-05-20 - END
 If mkstat
  GMESSAGE = format$("D:MMMMMMMMM[]YYYY",DATS)-":"-mess(12,10709,1) : # Pas de paye définie à cette date
  End
 Endif
Endif
#ADNGO - 2017-05-20 - END
End

######################################################################################
######################################################################################
##         Etiquette masque CONSMAS1 & CRITMAS   00/00/0000 00:00:00 (WGA)          ##
######################################################################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()

Raz [M:MAS1]STRDAT(0) , [M:MAS1]ENDDAT(0) , [M:MAS1]MTHREF(0) , [M:MAS1]TYPMCH(0), [M:MAS1]READAT(0)
Raz [M:MAS1]ACTSCE1   , [M:MAS1]ACTHYP1   , [M:MAS1]ACTDEB1   , [M:MAS1]ACTFIN1

CURSCECOD=VALEUR

If [F:MCH]COD <> VALEUR
 Read [F:MCH]MCH0= VALEUR
Endif

CURDATREV=[F:MCH]DATREVBUD

[M:MAS1]CPY = [F:MCH]CPY  :  Affzo [M:MAS1]CPY
[M:MAS1]FCY = [F:MCH]FCY  :  Affzo [M:MAS1]FCY
[M:MAS1]SRV = [F:MCH]SRV  :  Affzo [M:MAS1]SRV
#70009
[M:MAS1]PRF = [F:MCH]PRF  :  Affzo [M:MAS1]PRF
[M:MAS1]JOBPOT = [F:MCH]JOBPOT  :  Affzo [M:MAS1]JOBPOT
[M:MAS1]POT = [F:MCH]POT  :  Affzo [M:MAS1]POT
#end 70009
[M:MAS1]POP = [F:MCH]POP  :  Affzo [M:MAS1]POP

[M:MAS1]STRDAT(0) = [F:MCH]STRDAT
[M:MAS1]ENDDAT(0) = [F:MCH]ENDDAT
[M:MAS1]READAT(0) = [F:MCH]DATMAJREA
[M:MAS1]MTHREF(0) = [F:MCH]MTHREF
[M:MAS1]TYPMCH(0) = [F:MCH]TYPMCH
If [F:MCH]TYPMCH = 1
 If [M:MAS1]TYPINI = 7
  [M:MAS1]CODHYP(0) = [F:MCH]BUD(0)
 Else
  [M:MAS1]CODHYP(0) = [F:MCH]BUD(1)
 Endif
Endif
Gosub LIB_MCH : # Description du scénario dans [M:MAS2]MCH

#sauvegarde des critères du scénario
SAVCRIT(1)=[F:MCH]CPY
SAVCRIT(2)=[F:MCH]FCY
SAVCRIT(3)=[F:MCH]SRV
SAVCRIT(4)=[F:MCH]PRF
SAVCRIT(5)=[F:MCH]STRMAT
SAVCRIT(6)=[F:MCH]ENDMAT
SAVCRIT(7)=[F:MCH]POP
SAVCRIT(8)=[F:MCH]JOBPOT  #70009
SAVCRIT(9)=[F:MCH]POT     #70009
SAVCRIT1  =[F:MCH]CRI

EXEFULL = 1
Raz [M:MAS1]ACTSCE1 , [M:MAS1]ACTHYP1 , [M:MAS1]ACTDEB1 , [M:MAS1]ACTFIN1

Call ALIM_HYPO_ACTIV(1,VALEUR,[M:MAS1]STRDAT(0),[M:MAS1]ENDDAT(0),
&                    [M:MAS1]ACTSCE1,[M:MAS1]ACTHYP1,[M:MAS1]ACTDEB1,[M:MAS1]ACTFIN1,EXEFULL,[M:MAS1]TYPINI)
If EXEFULL = 0
Endif
End

Subprog AM_CODSHW(VALEUR)
Variable Char    VALEUR()

If [M:MAS1]COD<>VALEUR
  [M:MAS1]COD=VALEUR
  Call AM_COD([M:MAS1]COD)
Endif
End

Subprog AM_DAT(VALEUR)
Variable Date    VALEUR

If !clalev([F:MHS3]) : Local File MSHISTOH [MHS3] : Endif
If !clalev([F:MCH3]) : Local File MSSCENAH [MCH3] : Endif

Read [F:MCH3]MCH0=CODSHW
If fstat | [F:MCH3]TYPMCH = 1
  End
Endif

Repeat
  Filter [F:MHS3] Where COD=[F:MCH3]COD Order By Key MHH3
  Read [F:MHS3] First

  If year([F:MHS3]DAT)>year(VALEUR)| (year([F:MHS3]DAT)=year(VALEUR) & month([F:MHS3]DAT)>month(VALEUR))
    Read [F:MCH3]MCH0=[F:MCH3]CODINI
    If fstat | [F:MCH3]TYPMCH = 1
      Break
    Endif
  Endif
Until year([F:MHS3]DAT)<year(VALEUR)| (year([F:MHS3]DAT)=year(VALEUR) & month([F:MHS3]DAT)<=month(VALEUR))

Call AM_COD([F:MCH3]COD)
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR

Raz [M:MAS1]DATDEB , [M:MAS1]DATFIN

[M:MAS1]RAZSUM(0) = 1
[M:MAS1]RAZSUM(1) = 1
[M:MAS1]RAZSUM(2) = 1
[M:MAS1]RAZSUM(3) = 1

If VALEUR < [M:MAS1]STRDAT(0) | VALEUR > [M:MAS1]ENDDAT(0)
 GMESSAGE = "("+[M:MAS1]COD+")"-num$(VALEUR)-mess(14,10722,1) : # Date en dehors de la période de simulation
 mkstat = 2 : End
Endif

Call CTRL_DAT(VALEUR)
If mkstat : End :Endif

[M:MAS1]DATDEB = gdat$(1, month(VALEUR), year(VALEUR))
If month(VALEUR) <12
 [M:MAS1]DATFIN = gdat$(0, month(VALEUR)+1, year(VALEUR))
Else
 [M:MAS1]DATFIN = gdat$(31,12, year(VALEUR))
Endif
Affzo [M:MAS1]DATDEB
Affzo [M:MAS1]DATFIN


If VALEUR <> [M:MAS1]DAT
[M:MAS1]RAZSUM(0) = 2
[M:MAS1]RAZSUM(1) = 2

#tester si N-1 et N-2 change
#[M:MAS1]RAZSUM(2) = 2
#[M:MAS1]RAZSUM(3) = 2

Endif

End

