Chgfmt [M:MAS2]LIBCAT  With 'KP:30X'
Chgfmt [M:MAS3]LIBCAT  With 'KP:30X'
Chgfmt [M:MAS4]LIBCAT  With 'KP:30X'
Chgfmt [M:MAS2]LIBGRP  With '-KP:30X'
Chgfmt [M:MAS3]LIBGRP  With '-KP:30X'
Chgfmt [M:MAS4]LIBGRP  With '-KP:30X'
#end 78924
Chgfmt [M:MAS2]RUB     With '-KP:30X'
Chgfmt [M:MAS3]RUB     With '-KP:30X'
Chgfmt [M:MAS4]RUB     With '-KP:30X'
Case [M:MAS1]NIVEAU
 When 3
  # FQ70994 - MABON 11/04/11 - Pour pouvoir afficher le graphe dont l'abscisse dépend du détail demandé, on
  # met les données significatives dans la colonne LIBLEV. Du coup, la colonne ZCAT doit être masquée
  GLIBLEV=mess(8,105,1) : # Catégorie
  #78924 fields not exported by Excel Export
#  Chgfmt [M:MAS2]ZCAT    With '-KP:30X'
#  Chgfmt [M:MAS3]ZCAT    With '-KP:30X'
#  Chgfmt [M:MAS4]ZCAT    With '-KP:30X'
  Chgfmt [M:MAS2]LIBCAT    With '-KP:30X'
  Chgfmt [M:MAS3]LIBCAT    With '-KP:30X'
  Chgfmt [M:MAS4]LIBCAT    With '-KP:30X'
  #end 78924
 When 2
  # FQ70994 - MABON 11/04/11 - Pour pouvoir afficher le graphe dont l'abscisse dépend du détail demandé, on
  # met les données significatives dans la colonne LIBLEV. Du coup, la colonne ZCODGRP doit être masquée
  GLIBLEV=mess(2,914,1) : # Groupe
#  Chgfmt [M:MAS2]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS3]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS4]ZCODGRP With 'KP:30X'
 When 1
  #78924 fields not exported by Excel Export
  Chgfmt [M:MAS2]LIBGRP  With 'KP:30X'
  Chgfmt [M:MAS3]LIBGRP  With 'KP:30X'
  Chgfmt [M:MAS4]LIBGRP  With 'KP:30X'
#  Chgfmt [M:MAS2]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS3]ZCODGRP With 'KP:30X'
#  Chgfmt [M:MAS4]ZCODGRP With 'KP:30X'
  #end 78924
  # FQ70994 - MABON 11/04/11 - Pour pouvoir afficher le graphe dont l'abscisse dépend du détail demandé, on
  # met les données significatives dans la colonne LIBLEV. Du coup, la colonne RUB doit être masquée
  GLIBLEV=mess(32,147,1) : # Rubrique
