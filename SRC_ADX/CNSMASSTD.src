#SEGAY US1933 81085 23/09/2013 :
Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
If VALEUR ="" :  End     : Endif
Call LECTURE("HRCTR", VALEUR,"") From CONTOBJ
Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
Call LECTURE("CPY", [F:FCY]LEGCPY, "") From CONTOBJ
If [F:CPY]LEG<>GCURLEG
 GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
 mkstat = 2
Endif
End


Subprog C_CODCOMP(VALEUR)
Variable Char    VALEUR()
#Call CTRL_COD(VALEUR,[M:MAS1]DAT,1,[M:MAS1]ACTSCE2,[M:MAS1]ACTHYP2,[M:MAS1]ACTDEB2,[M:MAS1]ACTFIN2,[M:MAS1]TYPIN2)
Call CTRL_COD(VALEUR,[M]DAT,1,[M:MAS1]ACTSCE2,[M:MAS1]ACTHYP2,[M:MAS1]ACTDEB2,[M:MAS1]ACTFIN2,[M:MAS1]TYPIN2)
If mkstat : End : Endif

End

Subprog AM_CODN1(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
 [M:MAS1]RAZSUM(2)=2

 If month([M:MAS1]DAT) <12
  [M:MAS1]DATPAYN(0) = gdat$(0, month([M:MAS1]DAT)+1, year([M:MAS1]DAT)-1)
 Else
  [M:MAS1]DATPAYN(0) = gdat$(31,12, year([M:MAS1]DAT)-1)
 Endif

 Call CTRL_DAT([M:MAS1]DATPAYN(0))
 If mkstat : End :Endif

 Call CTRL_COD(VALEUR,[M:MAS1]DATPAYN(0),2,[M:MAS1]ACTSCE3,[M:MAS1]ACTHYP3,[M:MAS1]ACTDEB3,[M:MAS1]ACTFIN3,[M:MAS1]TYPINI)
 If mkstat : End : Endif

Else
 [M:MAS1]RAZSUM(2)=1
Endif

End

Subprog AM_CODN2(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
 [M:MAS1]RAZSUM(3)=2

 If month([M:MAS1]DAT) <12
  [M:MAS1]DATPAYN(1) = gdat$(0, month([M:MAS1]DAT)+1, year([M:MAS1]DAT)-2)
 Else
  [M:MAS1]DATPAYN(1) = gdat$(31,12, year([M:MAS1]DAT)-2)
 Endif

 Call CTRL_DAT([M:MAS1]DATPAYN(1))
 If mkstat : End :Endif

 Call CTRL_COD(VALEUR,[M:MAS1]DATPAYN(1),3,[M:MAS1]ACTSCE4,[M:MAS1]ACTHYP4,[M:MAS1]ACTDEB4,[M:MAS1]ACTFIN4,[M:MAS1]TYPINI)
 If mkstat : End : Endif

Else
 [M:MAS1]RAZSUM(3)=1
Endif

End

