$LECTURE
If [M:MAS1]COD = "" | [M:MAS1]DAT = [00/00/0000] Then
  NBLU=0
  Chgfmt [M:MAS2]LIBLEV  With '-KP:30X'
  Chgfmt [M:MAS3]LIBLEV  With '-KP:30X'
  Chgfmt [M:MAS4]LIBLEV  With '-KP:30X'
  Return
Endif

Gosub CREER_FILTRE
Gosub CHG_PAGE
Raz  NBCUM , NBPRJ
#57273
#If CRITERE<>OLDCRIT | CRITERE0<>OLDCRIT0 | CRITERE1<>OLDCRIT1 | find(2,[M:MAS1]RAZSUM(0..1))
#70009
If CRITERE<>OLDCRIT | CRITERE0<>OLDCRIT0 | CRITERE1<>OLDCRIT1 | CRITERE3<>OLDCRIT3 | find(2,[M:MAS1]RAZSUM(0..1)) | CRITDAT<>OLDDAT
 Effzo [M:MAS2]25-30    : #totaux hors N-1 & N-2
 Effzo [M:MAS3]5-30     : #tableau et totaux hors N-1 & N-2
 Effzo [M:MAS4]5-30
Else
 Effzo [M:MAS3]5        : #que le tableau
 Effzo [M:MAS4]5
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:MAS2]5 : Endif
Gosub LIEN

Gosub TRI_FILTRE

nolign = 0
TFULL  = 1
Raz IND1 , IND2 , IND3 , IND4

For [LNK]CLE
 Gosub FILT_HYP_ACTIV
 If (IND1 <> 0 | IND2 <> 0) &
& (([F:MHS]TYP=2 & [F:RUB]TYPRUB=6) | ([F:MHS]TYP=2 & [F:MSR]TYPRUB=6) | ([F:RUB]TYPRUB<>6 & [F:MSR]TYPRUB<>6))
# interdire la saisi d'un groupe MS dès la modif de la rubrique plutôt que tester ci-avant

  Gosub TOTAUX
  If TFULL <> 2
   SAVNOL = NOL
   If NBLU = 1                                     : # 1 enreg lu
    If CHGPAG=2 | CHGPAG=-2                        : # Suite ou Retour
     Effzo [M:MAS2]5
     Effzo [M:MAS3]5
     Effzo [M:MAS4]5
    Endif
    NBLU = 2
   Endif
   If CHGPAG > 0                                   : # Recherche(1),Suite(2),Raffraichissement(3)
    If NOL >= MAXLIG-2 : SUITE=2 : TFULL = 2 : Endif
    NOL    += 1
    If NOL=0
     DEBCPY = [F:MHS]CPY
     DEBFCY = [F:MHS]FCY
     DEBSRV = [F:MHS]SRV
     DEBMSE = [F:MHS]MSEMP
     DEBEMP = [F:MHS]EMP
     DEBCTR = [F:MHS]CTR
     DEBCAT = [F:MHS]CAT
     DEBGRP = [F:MHS]GRP
     DEBRUB = [F:MHS]RUB
     DEBPOT = [F:MHS]POT
     DEBJOB = [F:MHS]JOBPOT
     DEBPRO = [F:MHS]PRF
    Endif
    FINCPY = [F:MHS]CPY
    FINFCY = [F:MHS]FCY
    FINSRV = [F:MHS]SRV
    FINMSE = [F:MHS]MSEMP
    FINEMP = [F:MHS]EMP
    FINCTR = [F:MHS]CTR
    FINCAT = [F:MHS]CAT
    FINGRP = [F:MHS]GRP
    FINRUB = [F:MHS]RUB
    FINPOT = [F:MHS]POT
    FINJOB = [F:MHS]JOBPOT
    FINPRO = [F:MHS]PRF
   Else
    If NOL <= 0 : RETOUR=2 : TFULL = 2 : Endif
    NOL    -= 1
    If NOL=MAXLIG-1
     FINCPY = [F:MHS]CPY
     FINFCY = [F:MHS]FCY
     FINSRV = [F:MHS]SRV
     FINMSE = [F:MHS]MSEMP
     FINEMP = [F:MHS]EMP
     FINCTR = [F:MHS]CTR
     FINCAT = [F:MHS]CAT
     FINGRP = [F:MHS]GRP
     FINRUB = [F:MHS]RUB
     FINPOT = [F:MHS]POT
     FINJOB = [F:MHS]JOBPOT
     FINPRO = [F:MHS]PRF
    Endif
    DEBCPY = [F:MHS]CPY
    DEBFCY = [F:MHS]FCY
    DEBSRV = [F:MHS]SRV
    DEBMSE = [F:MHS]MSEMP
    DEBEMP = [F:MHS]EMP
    DEBCTR = [F:MHS]CTR
    DEBCAT = [F:MHS]CAT
    DEBGRP = [F:MHS]GRP
    DEBRUB = [F:MHS]RUB
    DEBPOT = [F:MHS]POT
    DEBJOB = [F:MHS]JOBPOT
    DEBPRO = [F:MHS]PRF
   Endif

# Gestion des ruptures
   Gosub RUPTURE
   #On change de ligne lors de ruptures
   #On s'assure que l'on a valorisé la ligne courante, pour ne pas afficher des lignes sans montant
   #S'il fallait effacer les lignes qui n'ont que du réalisé, on enlèverait ici le test [M:MASn]REA
   If RUPT | nolign=0
    If nolign <> 0 & [M:MAS2]AMT(nolign-1) = 0 & [M:MAS2]REA(nolign-1) = 0
&                  & [M:MAS2]AMTCOMP(nolign-1) = 0 &  [M:MAS2]REACOMP(nolign-1) = 0  : #onglet1
     NOL   = SAVNOL
     TFULL = 1
    Else
     nolign=NOL+1
    Endif
    If NBCUM <= dim([M:MAS3]RUB) &
&           (  NBCUM=0 | [M:MAS3]AMT(NBCUM-1) <> 0 | [M:MAS3]REA(NBCUM-1) <> 0
&              | [M:MAS3]AMTCOMP(NBCUM-1)<>0 | [M:MAS3]REACOMP(NBCUM-1) <> 0    )   : #onglet2
     NBCUM+=1
    Endif
    If NBPRJ <= dim([M:MAS4]RUB) &
&           (  NBPRJ=0 | [M:MAS4]AMT(NBPRJ-1) <> 0 | [M:MAS4]REA(NBPRJ-1) <> 0
&              | [M:MAS4]AMTCOMP(NBPRJ-1) <> 0 | [M:MAS4]REACOMP(NBPRJ-1) <> 0  )   : #onglet3
     NBPRJ+=1
    Endif
   Else
    NOL = SAVNOL
    TFULL = 1
   Endif
   If TFULL <> 2 & ([F:MHS]AMT <> 0 | [F:MHS]REA <> 0)
    Gosub RAZSAVCATGRP : Gosub LECT_MOIS
    If NBCUM <= dim([M:MAS3]RUB) : Gosub RAZSAVCATGRP : Gosub LECT_CUMMOI : Endif
    If NBPRJ <= dim([M:MAS4]RUB) : Gosub RAZSAVCATGRP : Gosub LECT_PROJEX : Endif
   Endif
#zones pour les ruptures
   SAVCPY = [F:MHS]CPY
   SAVFCY = [F:MHS]FCY
   SAVSRV = [F:MHS]SRV
   SAVEMP = [F:MHS]EMP
   SAVMSE = [F:MHS]MSEMP
   SAVCTR = [F:MHS]CTR
   SAVCAT = [F:MHS]CAT
   SAVGRP = [F:MHS]GRP
   SAVRUB = [F:MHS]RUB
   SAVPOT = [F:MHS]POT
   SAVJOB = [F:MHS]JOBPOT
   SAVPRO = [F:MHS]PRF
  Endif
 Endif
Next

If NOL>0 & [M:MAS2]CAT(NOL)= ""
 NOL-=1
Endif

Filter [F:LNK]

#Parcours Exercices précédents
If [M:MAS1]CODN1 <> "" | [M:MAS1]CODN2 <> ""
 Gosub LOOK_EXEPRE
Endif

# FQ70994 - MABON 11/04/11 - Affichage des totaux et sous-totaux
Local Integer NOL3, NOL4
# Ligne total dans MAS2
If [M:MAS2]NBLIG<dim([M:MAS2]RUB) Then : # FQ75798- MABON 23/08/11 - Vérif sur le nombre de lignes avant incrémentation
  Call CALC_LEV(2, NOL)
Endif
# Ligne total dans MAS3
If [M:MAS3]NBLIG<dim([M:MAS3]RUB) Then : # FQ75798- MABON 23/08/11 - Vérif sur le nombre de lignes avant incrémentation
  NOL3=[M:MAS3]NBLIG : Call CALC_LEV(3, NOL3)
Endif
# Ligne total dans MAS4
If [M:MAS4]NBLIG<dim([M:MAS4]RUB) Then : # FQ75798- MABON 23/08/11 - Vérif sur le nombre de lignes avant incrémentation
  NOL4=[M:MAS4]NBLIG : Call CALC_LEV(4, NOL4)
Endif
# Fin MABON

#57273
OLDDAT=CRITDAT
OLDCRIT=CRITERE
OLDCRIT0=CRITERE0
OLDCRIT1=CRITERE1
OLDCRIT3=CRITERE3 #70009
Gosub LIB_MCH
Affzo  [M:MAS2]
Affzo  [M:MAS3]
Affzo  [M:MAS4]
Return

$RAZSAVCATGRP
  Raz [L]PRECCAT, [L]PRECGRP
  Raz [L]SAVLIBCAT, [L]SAVLIBGRP
Return

Subprog CALC_SS_LEV(LEV, NUMTAB, LEVCOUNT, NUMMASK, NOL)
Value    Char    LEV, NUMTAB
Value    Integer LEVCOUNT, NUMMASK
Variable Integer NOL
Local    Integer IL, II
Local    Char    SAV_LEV, CHAINELEV(250), LIBINDIC
Local    Decimal TOTAMT, TOTREA, TOTAMTCOMP, TOTREACOMP

  IL=1
  # FQ76933 - MABON 11/10/11 :
  # - evalue sur le numéro du masque
  # - < et non <=, sinon, on a une ligne en trop dans les écrans CONSMAS3 et CONSMAS4
#  While IL<=NOL+1 & [M:MAS2]NBLIG<dim([M:MAS2]RUB) : # FQ75798- MABON 23/08/11 - Vérif sur le nombre de lignes avant incrémentation
  While IL<NOL+1 & evalue("[M:MAS"+num$(NUMMASK)+"]NBLIG")<evalue("dim([M:MAS"+num$(NUMMASK)+"]RUB)") : # FQ75798- MABON 23/08/11 - Vérif sur le nombre de lignes avant incrémentation
  # Fin MABON
    SAV_LEV=evalue("[M:MAS"+num$(NUMMASK)+"]"+LEV+"(IL-1)")
#    If SAV_LEV<>"" Then
    If evalue("[M:MAS"+num$(NUMMASK)+"]COUNT("+num$(IL-1)+")")=5 Then
      TOTAMT=0 : TOTREA=0 : TOTAMTCOMP=0 : TOTREACOMP=0
      While IL<=NOL+1 & SAV_LEV=evalue("[M:MAS"+num$(NUMMASK)+"]"+LEV+"(IL-1)")
        # FQ76933 - MABON 11/10/11 - ototalise que les montants autorisés
#        TOTAMT     += evalue("[M:MAS"+num$(NUMMASK)+"]AMT(IL-1)")     : TOTREA     += evalue("[M:MAS"+num$(NUMMASK)+"]REA(IL-1)")   :
#        TOTAMTCOMP += evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP(IL-1)") : TOTREACOMP += evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP(IL-1)")
        TOTAMT     += evalue("[M:MAS"+num$(NUMMASK)+"]AMTT(IL-1)")     : TOTREA     += evalue("[M:MAS"+num$(NUMMASK)+"]REAT(IL-1)")
        TOTAMTCOMP += evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMPT(IL-1)") : TOTREACOMP += evalue("[M:MAS"+num$(NUMMASK)+"]REACOMPT(IL-1)")
        # Fin MABON
        IL += 1
      Wend
      Case NUMMASK
        When 2 : Insa IL-1, 1 [M:MAS2]NBLIG
        When 3 : Insa IL-1, 1 [M:MAS3]NBLIG
        When 4 : Insa IL-1, 1 [M:MAS4]NBLIG
      Endcase
      CHAINELEV=SAV_LEV
      If NUMTAB<>"" Then
        Call LECTEXTRA(CHAINELEV, "ATABDIV", "LNGDES", NUMTAB, SAV_LEV) From ATEXTRA
      Endif
      Assign("[M:MAS"+num$(NUMMASK)+"]LIBLEV("+num$(IL-1)+")")  With mess(151,115,1)-CHAINELEV
      If LEVCOUNT=3 & [M:MAS1]DETAIL>1 Then
        For II=IL To 0 Step -1
          LIBINDIC=evalue("[M:MAS"+num$(NUMMASK)+"]INDIC("+num$(II)+")")
          If LIBINDIC<>"" Then Break : Endif
        Next
        Assign("[M:MAS"+num$(NUMMASK)+"]LIBLEV("+num$(IL-1)+")")  With mess(151,115,1)-CHAINELEV-LIBINDIC
      Endif
      Assign("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(IL-1)+")")     With TOTAMT
      Assign("[M:MAS"+num$(NUMMASK)+"]REA("+num$(IL-1)+")")     With TOTREA
      Assign("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(IL-1)+")") With TOTAMTCOMP
      Assign("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(IL-1)+")") With TOTREACOMP
      If [M:MAS1]DISPLAY=1 Then
        Local Decimal CALCECART
        If TOTAMT>0 Then
          # FQ74881 - MABON 08/07/11 - Si écart à -100, le mettre à 0
          CALCECART=(TOTREA-TOTAMT)*100/TOTAMT
          If CALCECART=-100 Then
            Assign("[M:MAS"+num$(NUMMASK)+"]ECART("+num$(IL-1)+")")     With 0
          Else
            Assign("[M:MAS"+num$(NUMMASK)+"]ECART("+num$(IL-1)+")")     With CALCECART
          Endif
        Endif
        If TOTAMTCOMP>0 Then
          # FQ74881 - MABON 08/07/11 - Si écart à -100, le mettre à 0
          CALCECART=(TOTREACOMP-TOTAMTCOMP)*100/TOTAMTCOMP
          If CALCECART=-100 Then
            Assign("[M:MAS"+num$(NUMMASK)+"]ECARTCOMP("+num$(IL-1)+")") With 0
          Else
            Assign("[M:MAS"+num$(NUMMASK)+"]ECARTCOMP("+num$(IL-1)+")") With CALCECART
          Endif
        Endif
      Else
        Assign("[M:MAS"+num$(NUMMASK)+"]ECART("+num$(IL-1)+")")     With (TOTREA-TOTAMT)
        Assign("[M:MAS"+num$(NUMMASK)+"]ECARTCOMP("+num$(IL-1)+")") With (TOTREACOMP-TOTAMTCOMP)
      Endif
      Assign("[M:MAS"+num$(NUMMASK)+"]COUNT("+num$(IL-1)+")")   With LEVCOUNT
      Assign("[M:MAS"+num$(NUMMASK)+"]NODSP("+num$(IL-1)+")")   With "X"
      Case NUMMASK
        When 2 : [M:MAS2]NBLIG += 1
        When 3 : [M:MAS3]NBLIG += 1
        When 4 : [M:MAS4]NBLIG += 1
      Endcase
      NOL += 1 : IL += 1
    Else
      IL += 1
    Endif
  Wend
End

Subprog CALC_LEV(NUMMASK, NOL)
Value    Integer NUMMASK
Variable Integer NOL
Local    Integer IL
Local    Decimal TOTECART, TOTECARTCOMP

  # Initialisation de la variable COUNT :
  #     - 5 : ligne simple de données
  #     - 4 : Ligne de sous-total des Groupes
  #     - 3 : Ligne de sous-total des Catégories
  #     - 2 : Ligne de sous-total du niveau Détail
  #     - 1 : Ligne de total général
  For IL=1 To NOL+1
    Assign("[M:MAS"+num$(NUMMASK)+"]COUNT("+num$(IL-1)+")")  With 5
    Assign("[M:MAS"+num$(NUMMASK)+"]NODSP("+num$(IL-1)+")")  With ""
    Assign("[M:MAS"+num$(NUMMASK)+"]FLGGRA("+num$(IL-1)+")") With 2
  Next
  Case NUMMASK
    When 2 : [M:MAS2]NBLIG=NOL+1
  Endcase

  # Lignes de sous-totaux
  Case [M:MAS1]NIVEAU
    When 3 :
      If [M:MAS1]DETAIL>1 & [M:MAS1]LEVTOTDET=2 Then Call CALC_SS_LEV("INDIC", "", 2, NUMMASK, NOL) : Endif
    When 2 :
      If [M:MAS1]DETAIL>1 & [M:MAS1]LEVTOTDET=2 Then Call CALC_SS_LEV("INDIC", "", 2, NUMMASK, NOL) : Endif
      If [M:MAS1]LEVTOTCAT=2 Then Call CALC_SS_LEV("CAT",    "10655", 3, NUMMASK, NOL) : Endif
    When 1 :
      If [M:MAS1]DETAIL>1 & [M:MAS1]LEVTOTDET=2 Then Call CALC_SS_LEV("INDIC", "", 2, NUMMASK, NOL) : Endif
      If [M:MAS1]LEVTOTCAT=2 Then Call CALC_SS_LEV("CAT",    "10655", 3, NUMMASK, NOL) : Endif
      If [M:MAS1]LEVTOTGRP=2 Then Call CALC_SS_LEV("CODGRP", "10654", 4, NUMMASK, NOL) : Endif
  Endcase
  # Ligne total
  Case NUMMASK
    When 2 : NOL += 1
  Endcase
  Assign("[M:MAS"+num$(NUMMASK)+"]LIBLEV("+num$(NOL)+")")  With mess(151,115,1) : # Total
  Assign("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")     With 0
  Assign("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")")     With 0
  Assign("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")") With 0
  Assign("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")") With 0
  For nolign=1 To NOL
    If evalue("[M:MAS"+num$(NUMMASK)+"]COUNT("+num$(nolign-1)+")")=5 Then
      # FQ76933 - MABON 11/10/11 - On ne totalise que les montants autorisés
#      Assign("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")     With evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(nolign-1)+")")
#      Assign("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")")     With evalue("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]REA("+num$(nolign-1)+")")
#      Assign("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")") With evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(nolign-1)+")")
#      Assign("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")") With evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(nolign-1)+")")
      Assign("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")     With evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]AMTT("+num$(nolign-1)+")")
      Assign("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")")     With evalue("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]REAT("+num$(nolign-1)+")")
      Assign("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")") With evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMPT("+num$(nolign-1)+")")
      Assign("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")") With evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")") + evalue("[M:MAS"+num$(NUMMASK)+"]REACOMPT("+num$(nolign-1)+")")
      # Fin MABON
    Endif
  Next
  If [M:MAS1]DISPLAY=1 Then
    If evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")>0 Then
      TOTECART     = (evalue("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")")-evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")"))*100/evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")
      # FQ74881 - MABON 08/07/11 - Si écart à -100, le mettre à 0
      If TOTECART=-100 Then TOTECART=0 : Endif
      Assign("[M:MAS"+num$(NUMMASK)+"]ECART("+num$(NOL)+")")     With TOTECART
    Endif
    If evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")")>0 Then
      TOTECARTCOMP = (evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")")-evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")"))*100/evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")")
      # FQ74881 - MABON 08/07/11 - Si écart à -100, le mettre à 0
      If TOTECARTCOMP=-100 Then TOTECARTCOMP=0 : Endif
      Assign("[M:MAS"+num$(NUMMASK)+"]ECARTCOMP("+num$(NOL)+")") With TOTECARTCOMP
    Endif
  Else
    TOTECART     = evalue("[M:MAS"+num$(NUMMASK)+"]REA("+num$(NOL)+")")-evalue("[M:MAS"+num$(NUMMASK)+"]AMT("+num$(NOL)+")")
    TOTECARTCOMP = evalue("[M:MAS"+num$(NUMMASK)+"]REACOMP("+num$(NOL)+")")-evalue("[M:MAS"+num$(NUMMASK)+"]AMTCOMP("+num$(NOL)+")")
    Assign("[M:MAS"+num$(NUMMASK)+"]ECART("+num$(NOL)+")")     With TOTECART
    Assign("[M:MAS"+num$(NUMMASK)+"]ECARTCOMP("+num$(NOL)+")") With TOTECARTCOMP
  Endif
  Assign("[M:MAS"+num$(NUMMASK)+"]NODSP("+num$(NOL)+")") With "X"
  Assign("[M:MAS"+num$(NUMMASK)+"]COUNT("+num$(NOL)+")") With 1
  Case NUMMASK
    When 3 : [M:MAS3]NBLIG += 1
    When 4 : [M:MAS4]NBLIG += 1
  Endcase
  # FQ76933 - MABON 11/10/11 - La dernière ligne "Total" ne doit pas être dans le graphe, par défaut
  If NUMMASK>2 Then
    Assign("[M:MAS"+num$(NUMMASK)+"]FLGGRA("+num$(evalue("[M:MAS"+num$(NUMMASK)+"]NBLIG-1"))+")") With 1
  Endif
  # Fin MABON
End

$AV_AFFICHE
#Supression des colonnes hors contexte et alimentation des titres

#Affichage colonne du niveau de détail
Case [M:MAS1]DETAIL
 When 1
  Chgfmt [M:MAS2]INDIC  With '-KP:80X'
  Chgfmt [M:MAS3]INDIC  With '-KP:80X'
  Chgfmt [M:MAS4]INDIC  With '-KP:80X'
 When Default
  Chgfmt [M:MAS2]INDIC  With 'KP:30X'
  Chgfmt [M:MAS3]INDIC  With 'KP:30X'
  Chgfmt [M:MAS4]INDIC  With 'KP:30X'
Endcase

#Affichage colonnes Catégorie (niv3), Groupe (niv2), Rubrique (niv1)
Chgfmt [M:MAS2]CAT     With '-KP:80X'
Chgfmt [M:MAS3]CAT     With '-KP:80X'
Chgfmt [M:MAS4]CAT     With '-KP:80X'
Chgfmt [M:MAS2]CODGRP  With '-KP:80X'
Chgfmt [M:MAS3]CODGRP  With '-KP:80X'
Chgfmt [M:MAS4]CODGRP  With '-KP:80X'
# FQ70994 - MABON 11/04/11 - Affichage de la colonne contenant le libellé du détail
Chgfmt [M:MAS2]LIBLEV  With 'KP:30X'
Chgfmt [M:MAS3]LIBLEV  With 'KP:30X'
Chgfmt [M:MAS4]LIBLEV  With 'KP:30X'
# Fin MABON
