If [M]CODN1 <> ""
 Call CTRL_COD([M]CODN1,[M:MAS1]DATPAYN(0),2,[M:MAS1]ACTSCE3,[M:MAS1]ACTHYP3,[M:MAS1]ACTDEB3,[M:MAS1]ACTFIN3,VALEUR)
 If mkstat : End : Endif
Endif

If [M]CODN2 <> ""
 Call CTRL_COD([M]CODN2,[M:MAS1]DATPAYN(1),3,[M:MAS1]ACTSCE4,[M:MAS1]ACTHYP4,[M:MAS1]ACTDEB4,[M:MAS1]ACTFIN4,VALEUR)
 If mkstat : End : Endif
