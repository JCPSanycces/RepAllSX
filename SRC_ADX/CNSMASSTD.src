  Endif
End

# Tout cocher
Subprog B1_NBLIG

  For nolign=1 To [M]NBLIG
    If [M]COUNT(nolign-1)=5 Then
      [M]FLGGRA(nolign-1)= 2
      [M]NODSP(nolign-1) = ""
    Endif
  Next
  Affzo [M]
End

# Tout décocher
Subprog B2_NBLIG

  For nolign=1 To [M]NBLIG
    If [M]COUNT(nolign-1)=5 Then
      [M]FLGGRA(nolign-1)= 1
      [M]NODSP(nolign-1) = "X"
    Endif
  Next
  Affzo [M]
End

# Cocher tous les totaux
Subprog B3_NBLIG

  For nolign=1 To [M]NBLIG
    If [M]COUNT(nolign-1)<>5 Then
      [M]FLGGRA(nolign-1)= 2
      [M]NODSP(nolign-1) = ""
    Endif
  Next
  Affzo [M]
End

# Décocher tous les totaux
Subprog B4_NBLIG

  For nolign=1 To [M]NBLIG
    If [M]COUNT(nolign-1)<>5 Then
      [M]FLGGRA(nolign-1)= 1
      [M]NODSP(nolign-1) = "X"
    Endif
  Next
  Affzo [M]
End

Subprog AV_FLGGRA(VALEUR)
Variable Integer VALEUR

#  If [M]COUNT(nolign-1)<>5 Then mkstat=2 : Endif
End
# Fin MABON

#71636
Subprog AM_LISRUB(VALEUR)
  Variable Char    VALEUR()

  If VALEUR<>""
    Raz [M:CMAS]CAT, GRP, RUB, DESRUB
    Affzo [M:CMAS]
  Endif
End

Subprog AM_CAT(VALEUR)
  Variable Char    VALEUR()

  If VALEUR<>""
    Raz [M:CMAS]GRP, RUB, DESRUB
    Affzo [M:CMAS]
  Endif
End

Subprog AM_GRP(VALEUR)
  Variable Char    VALEUR()

  If VALEUR<>""
    Raz [M:CMAS]RUB, DESRUB
    Affzo [M:CMAS]RUB, DESRUB
  Endif
End

Subprog AM_RUB(VALEUR)
  Variable Char    VALEUR()

  Raz [M:CMAS]DESRUB

  If VALEUR <> ""
    Read [MSR1]MSR0=VALEUR
    If !fstat
      [M:CMAS]DESRUB = [MSR1]DES
    Else
      Read [RUB1]RUB0=GCURLEG;VALEUR
      If !fstat
        Call LECTEXTRA([M:CMAS]DESRUB,"RUBRIQUE","DES",GCURLEG,VALEUR) From ATEXTRA
      Endif
    Endif
  Endif
End

Subprog C_CAT(VALEUR)
  Variable Char    VALEUR()
  Local Integer CATOK

  If VALEUR <> ""
    If [M:CMAS]LISRUB<>""
      CATOK=0
      #contrôle groupe existe pour au moins une rubrique
      For [MLR1]MLR0 Where COD=[M:CMAS]LISRUB
        Read [MSR1]MSR0=[MLR1]CODRUB
        If fstat
          Read [RUB1]RUB0=GCURLEG;[MLR1]CODRUB
          If !fstat
            Read [ADI]CODE(2) = 10654;[RUB1]CODGRP
            If !fstat & [ADI]A1 = VALEUR
              CATOK=1 : Break
            Endif
          Endif
        Else
          Read [ADI]CODE(2) = 10654;[MSR1]CODGRP
          If !fstat & [ADI]A1 = VALEUR
            CATOK=1 : Break
          Endif
        Endif
      Next

      If !CATOK
        GMESSAGE = mess(44,10722,1)-":"-VALEUR : #Aucun groupe des rubriques de la liste n'appartient à la catégorie
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

Subprog C_GRP(VALEUR)
  Variable Char VALEUR()
  Local Integer GRPOK

  If VALEUR <> ""
    If [M:CMAS]CAT<>""
      Read [ADI]CODE(2) = 10654;VALEUR
      If !fstat & [ADI]A1 <> [M:CMAS]CAT
          GMESSAGE = mess(42,10722,1)-[M:CMAS]CAT :#Ce groupe ne fait pas partie de la catégorie
          mkstat = 2 : End
      Endif
    Endif

    If [M:CMAS]LISRUB<>""
      GRPOK=0
      #contrôle groupe existe pour au moins une rubrique
      For [MLR1]MLR0 Where COD=[M:CMAS]LISRUB
        Read [MSR1]MSR0=[MLR1]CODRUB
        If fstat
          Read [RUB1]RUB0=GCURLEG;[MLR1]CODRUB
          If !fstat & [F:RUB1]CODGRP=VALEUR
            GRPOK=1 : Break
          Endif
        Elsif [F:MSR1]CODGRP=VALEUR
          GRPOK=1 : Break
        Endif
      Next

      If !GRPOK
        GMESSAGE = mess(41,10722,1)-":"-VALEUR : #Aucune rubrique de la liste ne contient le groupe
        mkstat = 2 : End
      Endif
    Endif
  Endif
End

#DLE : contrôle droit d'une rubrique de la liste
Funprog CTRL_RUB_ACCES(CODRUB)
  Value Char CODRUB
  Local Integer ISOK
  Local Char LCODACC
  ISOK=1

  If GUSRACS=2 | CODRUB="" : End ISOK : Endif

  If !clalev([F:RUB1]) : Local File RUBRIQUE [RUB1] : Endif
  If !clalev([F:MSR1]) : Local File MSRUB    [MSR1] : Endif
  If !clalev([F:MLR1]) : Local File MSLRUB   [MLR1] : Endif
  If !clalev([F:ACC])  : Local File ACCES    [ACC]  : Endif

  Raz LCODACC

  Read [MSR1]MSR0=CODRUB
  If fstat
    Read [RUB1]RUB0=GCURLEG;CODRUB
    If !fstat
      LCODACC=[F:RUB1]CODACC
    Endif
  Else
    LCODACC=[F:MSR1]CODACC
  Endif

  If LCODACC<>""
    Read [ACC]CODACC = GUSER;LCODACC
    If fstat | [F:ACC]EXEC<>2
      ISOK=0
    Endif
  Endif
End ISOK
#end 71636


#76770
#78924 : Display the code and the description of the heading
Funprog GET_RUB_LIB(CODRUB)
  Value Char CODRUB
  Local Char RUBLIB(50)
  Local Char VRUBLIB(35)

  RUBLIB=CODRUB

  If !clalev([F:RUB2]) : Local File RUBRIQUE [RUB2] : Endif
  If !clalev([F:MSR2]) : Local File MSRUB    [MSR2] : Endif

  Read [MSR2]MSR0=CODRUB
  If !fstat & [F:MSR2]DES<>""
    RUBLIB-="("+[F:MSR2]DES+")"
  Else
    Read [RUB2]RUB0=GCURLEG;CODRUB
    If !fstat
      Call LECTEXTRA(VRUBLIB,"RUBRIQUE","DES",GCURLEG,CODRUB) From ATEXTRA
      RUBLIB-="("+VRUBLIB+")"
    Endif
  Endif
End RUBLIB
#end 76770
