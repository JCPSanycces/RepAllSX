Raz GTUNCPT
Local Char PARAM(10)(1..7)

Call GCONSULT("MAS","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AV_AFFICHE
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "EXEBOUT2"   : Gosub EXEBOUT2
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "FERME"      : Gosub FERME
 When Default
Endcase

Return

$AV_MAGNETO
  Gosub CREER_FILTRE
  Filter [F] Where (evalue (CRITERE) | evalue (CRITERE0)) & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
  CURDAT=[M:MAS1]DAT
Return

$AP_MAGNETO
  If fstat<>4 & (year([F:MHS]DAT)=year(CURDAT) & month([F:MHS]DAT)=month(CURDAT))
    If REPONSE=GSTASUI
      Gosub SUIVANT From GCONSULT
    Elsif REPONSE=GSTAPRE
      Gosub PRECEDENT From GCONSULT
    Endif
    Return
  Endif
  Raz CURDAT
  If [M:MAS1]DAT <> [00/00/0000]
   Call C_DAT([M]DAT)
   If [M:MAS1]CODN1 <> ""
    Call AM_CODN1([M]CODN1)
   Endif
   If [M:MAS1]CODN2 <> ""
    Call AM_CODN2([M]CODN2)
   Endif
  Endif
Return

# SEGAY 20/05/11 - EXI 72645
$APRES_CHOI
  Case REPONSE
    When GSTAEDI :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      Local Char    SAVACT(GLONACT)
      Local Integer FLGEXE
      PARBOUT(1) = "SUIMAS"
      PARBOUT(2) = GFONCTION
      PARBOUT(3) = num$(0)
      FLGEXE = 1
      SAVACT = GACTION
      GACTION = "AIMP1"
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AIMP1","AIMP1",4,"XYAIMP1") From GTRAITE
      GACTION = SAVACT
      REPONSE=0
  Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
