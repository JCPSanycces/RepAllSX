#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. 
#
# l'affectation se fait à partir des tables 
#############################################################################
$COR_SET_HEA_INFO
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      [M:COR0]CNTNUM = [F:AIN]CNTNUM
      [M:COR0]UPDCNTNUM = 0
    When "CPYEML"
      #E-mail professionnel
      [M:COR2]CPYEML = [F:CNT]WEB 
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [F:AIN]CNTEMA
    When "CPYZIP"
      #Code postal professionnel
      [M:COR2]CPYZIP = [F:BPA]POSCOD
    When "HOMZIP"
      [M:COR3]HOMZIP = [F:AIN]ZIP
    When "CPYSAT"
      #Etat professionnel
      [M:COR2]CPYSAT = [F:BPA]SAT
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [F:AIN]SAT
    When "LNA"
      #Nom
      [M:COR0]LNA = [F:AIN]CNTLNA
    When "CPYCRY"
      #Pays (prodessionel)
      [M:COR2]CPYCRY = [F:BPA]CRY
    When "CPYCRYNAM"
      #Libellé Pays (prodessionel)
      [M:COR2]CPYCRYNAM = [F:BPA]CRYNAM
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [F:AIN]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [F:AIN]CRYNAM
    When "FNA"
      #Prénom
      [M:COR0]FNA = [F:AIN]CNTFNA     
    When "CPYADD"
      #Adresse rue (professionnel)
      Case indice
        When 0
          [M:COR2]CPYADD(0) = [F:BPA]BPAADDLIG(0)
        When 1    
          [M:COR2]CPYADD(1) = [F:BPA]BPAADDLIG(1)
        When 2
          [M:COR2]CPYADD(2) = [F:BPA]BPAADDLIG(2)
      Endcase
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [F:AIN]ADD(0)
        When 1    
          [M:COR3]HOMADD(1) = [F:AIN]ADD(1)
        When 2
          [M:COR3]HOMADD(2) = [F:AIN]ADD(2)
      Endcase
    When "BPRNUM"
      #Code tiers
      [M:COR2]BPRNUM = [F:BPC]BPCNUM
      [M:COR2]UPDBPRNUM = 0
    When "BPRLIB"
      #Libellé tiers
      [M:COR2]BPRLIB = [F:BPC]BPCNAM
    When "CPYFAX"
      #Fax (professionnel)
      [M:COR2]CPYFAX = [F:CNT]FAX
    When "HOMFAX"
      #Fax (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTFAX, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMFAX = ""
      Else
        [M:COR3]HOMFAX = [F:AIN]CNTFAX
      Endif
    When "CPYTEL"
      #Téléphone (professionnel)
      [M:COR2]CPYTEL = [F:CNT]TEL
    When "HOMTEL"
      #Téléphone (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTETS, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMTEL = ""
      Else
        [M:COR3]HOMTEL = [F:AIN]CNTETS
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      [M:COR3]HOMMOB = [F:AIN]CNTMOB
    When "FNC"    
      #code fonction
      [M:COR2]FNC = [F:CNT]CNTFNC
    #When "FNCLIB"
    #  # FGR 26/03/2009 : X3SUIVI50275 : changement sur la façon de gérer ça
    #  #Libellé fonction
    #  [M:COR2]FNCLIB = mess([F:CNT]CNTFNC,233,1)
    When "TTL"
      #Civilité
      [M:COR0]TTL = [F:AIN]CNTTTL
    When "CPYCTY"
      #Ville (professionnel)
      [M:COR2]CPYCTY = [F:BPA]CTY 
    When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [F:AIN]CTY
    When "CPYBPANUM"
      #code adresse
      [M:COR2]CPYBPANUM = [F:BPA]BPAADD
      [M:COR2]CPYBPATYP = [F:BPA]BPATYP
    When "CPYBPADES"
      #Inttitulé adresse
      [M:COR2]CPYBPADES = [F:BPA]BPADES
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        [M:COR4]COPREP(0) = GSZREP
      Endif
  Endcase
Return
