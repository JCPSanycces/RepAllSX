#Subprog B4_NBLIG
#Local Integer L_IJ
#
#  For L_IJ=nolign-1 To [M]NBLIG-1
#    [M]SELFLG(L_IJ) = 1
#    Affzo [M]SELFLG(L_IJ)
#  Next L_IJ
#End
######################################################################################

