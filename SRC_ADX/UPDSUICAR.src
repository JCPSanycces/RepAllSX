#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################################################
# MABON 07/03/11 Gestion UPDSUICAR Maj flag suivi carrière + fiches carrières associées
# MABOS 10/10/13 FQ81085- US2047 - Modif memo code: emp -> sca
#########################################################################################################################
Local Char     PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = ""        : #

## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères
## Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,GPROGSPE)

Call TRAITE_CHAR(VALEUR,PARAM,"UPDSUICAR","UPDSUICAR","GENUPDSUICAR",4,"") From GTRAITE
End

#########################################
## Traitement des actions : UPDSUICAR
#########################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "BOUTON"      : Gosub BOUTON
    When "OK"          : Gosub OK
    When "END"         : FIN = 1
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXECFIN # SEGAY 25/10/12 US 940 81085

Endcase
Return

#########################################################################################################################
$INIT
Local Mask   GENUPDSUICAR [DIA]

Local Char      CRITERE_DAT(GDIMFIC)
Local Char      CRITERE_CPY(GDIMFIC), CRITERE_FCY(GDIMFIC), CRITERE_SRV(GDIMFIC), CRITERE_PRF(GDIMFIC)
Local Char      CRITERE_DEB(GDIMFIC), CRITERE_FIN(GDIMFIC), CRITERE_LIBRE(GDIMFIC), CRITERE_POP(GDIMFIC)
Local Char      CRITERE_POT(GDIMFIC), CRITERE_JOB(GDIMFIC)
Local Char      CRITERE_LEG(GDIMFIC) # SEGAY 25/10/12 US 940 81085
Gosub OUVFIC
Raz [M:DIA] # SEGAY 25/10/12 US 940 81085
#81085-#MABOS-FQ81085-US1833 - manage memo
Call INI_LEG From DIVPAYE
Call LECMEMO("STD","[M:DIA]","sca") From GMEMO :#MABOS-FQ81085-US2047
#end MABOS-FQ81085-US1833
Return

$OUVRE
#MABOS-FQ81085-US1833 - manage mémo
# Done in INIT to not re-init STD after come back at the end of the TRT
#  If BOITE="GENUPDSUICAR"
#    Call LECMEMO("STD","[M:DIA]","emp") From GMEMO
   # Call AFF_MEMO From DIVPAYE: #81085
#  Endif

Return

$DEBUT

  If BOITE="UPDSUICAR"
    Gosub CHARGE_CRIT
    Gosub CHARGE_MSK
  Else
    Affzo [M:DIA]: Setmok [M:DIA] With 0
#MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
     # SEGAY 25/10/12 US 940 81085
#    If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> "" : GCURLEG=[M:DIA]LEG : Endif :
#    If BOITE="GENUPDSUICAR"
#      If dim([M]LEG)>0 : Call AM_LEG([M]LEG) From GENUPDSUICAR : Endif
#      Call D_INI([M]INI) From DIVPAYE
#      Call GRISE_LEG([M]CPY,[M]FCY) From DIVPAYE
#    Endif
    Call AFF_MEMO2(1) From DIVPAYE
#end MABOS-FQ81085-US1833

  Endif
Return

$OK
  If BOITE="GENUPDSUICAR"
# SEGAY 25/10/12 US 940 81085
#     Gosub CONTROLE_LEG_OK
     BOX = 1
     If GERR : Return : Endif
# END SEGAY 25/10/12 US 940 81085


    BOX = 0 : # To keep [M:DIA] open
  Elsif BOITE="UPDSUICAR"
    Gosub EXEC
  Endif
Return

#  - On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
# en réel après l'avoir lancé en simulation)
# SEGAY 25/10/12 US 940 81085
$EXECFIN
  If BOITE="UPDSUICAR"
     SAI=1
  Endif
Return

# SEGAY 25/10/12 US 940 81085
$CONTROLE_LEG_OK
# controle LEG
Local Char WLEGSRV(GLONADI), WLEGPRF(GLONADI), WLEGPOT(GLONADI), WLEGJOBPOT(GLONADI), WLEGPOP(GLONADI)
Local Char WLISTLEG(GLONADI)(1..5)
Local Char WLEGCOUR(GLONADI)
Local Char WORIFIELD(250)
Local Char WDESFIELD(250)
Local Integer WOK
Local Char WFIELD(30) (1..5)
Local Char ZFIELD(30) (1..5)
Local Char WECR
Local Char WMES(250)
If clalev([F:AMZ_])=0 : Local File AMSKZON [AMZ_] : Endif
WECR="GENUPDSUICAR"
ZFIELD(1)="SRV"
ZFIELD(2)="PRF"
ZFIELD(3)="POT"
ZFIELD(4)="JOBPOT"
ZFIELD(5)="POP"
For I =1 To 5
    WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,ZFIELD(I))
Next

WOK = 1
Raz WLEGSRV, WLEGPRF, WLEGPOT, WLEGJOBPOT, WLEGPOP
If [M:DIA]LEG = ""
  If [M:DIA]ALLSRV <> 2 & [M:DIA]SRV<> ""
     Call GET_LEGSRV([M:DIA]SRV,WOK,WLEGSRV,0) From TOOLSHRLEG
     WLISTLEG(1)=WLEGSRV
  Endif
  If [M:DIA]ALLPRF <> 2 & [M:DIA]PRF<> ""
     Call GET_LEGPRF([M:DIA]PRF,WOK,WLEGPRF,0)  From TOOLSHRLEG
     WLISTLEG(2)=WLEGPRF
  Endif
  If [M:DIA]ALLPOT <> 2 & [M:DIA]POT<> ""
     Call GET_LEGPOT([M:DIA]POT,WOK,WLEGPOT,0)  From TOOLSHRLEG
     WLISTLEG(3)=WLEGPOT
  Endif
  If [M:DIA]ALLJOBPOT <> 2 & [M:DIA]JOBPOT<> ""
     Call GET_LEGJOBPOT([M:DIA]JOBPOT,WOK,WLEGJOBPOT,0)  From TOOLSHRLEG
     WLISTLEG(4)=WLEGJOBPOT
  Endif
  If [M:DIA]POP<> ""
     Call GET_LEGPOP([M:DIA]POP,WOK,WLEGPOP,0)  From TOOLSHRLEG
     WLISTLEG(5)=WLEGPOP
  Endif

  If WOK
    WLEGCOUR=WLISTLEG(1)
    WORIFIELD = WFIELD(1)

    For I =2 To 5
      WDESFIELD = WFIELD(I)
      WLEGDEST=WLISTLEG(I)
      Call LEGOK(WORIFIELD,WLEGCOUR,WDESFIELD,WLEGDEST , WOK,WMES, 0)  From TOOLSHRLEG
      If !WOK Then : Break : Endif
    Next
    If !WOK
#       GMESSAGE = WMES:  GERR=1 : SAI=1 :GOK=0:  REPONSE=GSTAESC :Return
       GMESSAGE = WMES:  mkstat = 2 :Return
    Endif
  Endif
Endif
Return
# END SEGAY 25/10/12 US 940 81085

$CONTROLE
  If GSTATUT<>GSTAOK
    # To exit If End button is activated on criteria window
    FIN = 1
  Endif

Return


######################################################
## Ouverture des tables
######################################################
$OUVFIC

  If clalev([F:FCY])=0   : Local File FACILITY   [FCY]   : Endif
  If clalev([F:ACV])=0   : Local File ACTIV      [ACV]   : Endif
  If clalev([F:ACC])=0   : Local File ACCES      [ACC]   : Endif
  If clalev([F:ADW])=0   : Local File ADOVAL     [ADW]   : Endif
  If clalev([F:ATB])=0   : Local File ATABLE     [ATB]   : Endif
  If clalev([F:ATZ])=0   : Local File ATABZON    [ATZ]   : Endif
  If clalev([F:ATI])=0   : Local File ATABIND    [ATI]   : Endif
  If clalev([F:ATX])=0   : Local File ATEXTE     [ATX]   : Endif
  If clalev([F:ATY])=0   : Local File ATYPE      [ATY]   : Endif
  If clalev([F:DIC])=0   : Local File DICOEMP    [DIC]   : Endif
  If clalev([F:TCY])=0   : Local File TABCOUNTRY [TCY]   : Endif
  If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
  If clalev([F:HRSMH])=0 : Local File SCREMPH    [HRSMH] : Endif
  If clalev([F:HRSMD])=0 : Local File SCREMPD    [HRSMD] : Endif
  If clalev([F:ECT])=0   : Local File EMPCTR     [ECT]   : Endif
  If clalev([F:JOD])=0   : Local File JOBTYPDEF  [JOD]   : Endif
  If clalev([F:POD])=0   : Local File POSTEDEF   [POD]   : Endif
  If clalev([F:EPO])=0   : Local File EMPLOPOT   [EPO]   : Endif

  Gosub OUVRE From WPDEFTABLE
Return

#########################################################################################################################
$CHARGE_CRIT
Local Char    LIS_CPY(GLONCPY)(0..100) # SEGAY 25/10/12 US 940 81085
  CRITERE_DAT  = '[F:HRCTR]CTRDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
  CRITERE_DAT += '&([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'

# SEGAY 25/10/12 US 940 81085
#  CRITERE_CPY = "1=1"  : If [M:DIA]CPY<>""    Then CRITERE_CPY += "& [F:FCY]LEGCPY='"+[M:DIA]CPY+"'"     : Endif
  CRITERE_CPY = "1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE_CPY -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE_CPY += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE_CPY += "," : Endif
      Next
      CRITERE_CPY += ")>0"
    Else
      If [M:DIA]CPY <> ""
        CRITERE_CPY="1=2"
      Endif
    Endif
  Endif

  CRITERE_FCY = "1=1"  : If [M:DIA]FCY<>""    Then CRITERE_FCY += "& [F:HRCTR]ETRFCY='"+[M:DIA]FCY+"'"     : Endif
  CRITERE_SRV = "1=1"  : If [M:DIA]SRV<>""    Then CRITERE_SRV += "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"     : Endif
  CRITERE_PRF = "1=1"  : If [M:DIA]PRF<>""    Then CRITERE_PRF += "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"     : Endif
  CRITERE_DEB = "1=1"  : If [M:DIA]MATDEB<>"" Then CRITERE_DEB += "& [F:HRCTR]REFNUM>='"+[M:DIA]MATDEB+"'" : Endif
  CRITERE_FIN = "1=1"  : If [M:DIA]MATFIN<>"" Then CRITERE_FIN += "& [F:HRCTR]REFNUM<='"+[M:DIA]MATFIN+"'" : Endif
  CRITERE_POT = "1=1"  : If [M:DIA]POT<>""    Then CRITERE_POT += "& [F:HRCTR]POT='"+[M:DIA]POT+"'"        : Endif
  CRITERE_JOB = "1=1"  : If [M:DIA]JOBPOT<>"" Then CRITERE_JOB += "& [F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"'"  : Endif
#  CRITERE_POP = "1=1"  : If [M:DIA]POP<>""    Then CRITERE_POP += "& [F:HRPOA]REFNUM<>''"                  : Endif
  CRITERE_POP = "1=1"  : If [M:DIA]POP<>""    Then CRITERE_POP += "& [F:HRPOA]REFNUM<>'' & [F:HRPOA]CTRNUM<>''" : Endif

  If [M:DIA]CRITERE<>"" Then
    CRITERE_LIBRE = [M:DIA]CRITERE
  Else
    CRITERE_LIBRE = "1=1"
  Endif
# SEGAY 25/10/12 US 940 81085
  CRITERE_LEG= "1=1"
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
    CRITERE_LEG += "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)"
  Endif

Return

#########################################################################################################################
$CHARGE_MSK
Local Integer   L_OK, L_IJ
  If CRITERE_POP<>"1=1" Then
# SEGAY 25/10/12 US 940 81085
#    Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
#&                   , [FCY]FCY0 = [F:HRCTR]ETRFCY
#&                 , [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
#&              As [LCTR]
#&              Where [F:HRCTR]SUICAR<>2 & evalue(CRITERE_POP)
#&                 , [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT

    Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
&                   , [FCY]FCY0 = [F:HRCTR]ETRFCY
&                   , [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&              As [LCTR]
&              Where [F:HRCTR]SUICAR<>2 & evalue(CRITERE_POP)
&                    & evalue(CRITERE_LEG) # SEGAY 25/10/12 US 940 81085
  Else
    Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
&                   , [FCY]FCY0 = [F:HRCTR]ETRFCY
&              As [LCTR]
&              Where [F:HRCTR]SUICAR<>2
&                    & evalue(CRITERE_LEG) # SEGAY 25/10/12 US 940 81085
  Endif
#Onerrgo ERREUR

  Raz [M:UPDS]

  If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> "" : GCURLEG=[M:DIA]LEG : Endif : # SEGAY 25/10/12 US 940 81085

  GERR   = 0
  nolign = 0
  For [LCTR]CTR0(2) Where evalue(CRITERE_DAT)
&                       & evalue(CRITERE_CPY) & evalue(CRITERE_FCY)
&                       & evalue(CRITERE_SRV) & evalue(CRITERE_PRF)
&                       & evalue(CRITERE_DEB) & evalue(CRITERE_FIN)
&                       & evalue(CRITERE_POT) & evalue(CRITERE_JOB)
&                       & [F:ID]ENAFLG=2
    L_OK = 1
    Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,CRITERE_LIBRE,L_OK,1) From DIVPAYE
    If L_OK
      nolign += 1
      [M:UPDS] = [F:ID]
      [M:UPDS] = [F:HRCTR]
      [M:UPDS]SELFLG(nolign-1) = 2
      [M:UPDS]CPY(nolign-1)    = [F:FCY]LEGCPY : # La société est aussi dans [F:ID], et on veut celle de [F:FCY]
    Endif : # If L_OK
  Next : # [LCTR]CTR0(2)
  If GERR : Return : Endif
  Onerrgo
  [M:UPDS]NBLIG = nolign
  Affzo [UPDS]
Return


#########################################################################################################################
######################################################
$ERREUR
Resume

######################################################
## It begins here...
######################################################
$EXEC

  # FQ72832 - MABON 11/04/11 - Ajout d'une trace
  TIT = mess(74,10720,1) : # Mise à jour Suivi carrière
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(mess(74,10720,1),0) From GESECRAN : # Mise à jour Suivi carrière
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  For L_IJ=0 To [M:UPDS]NBLIG-1
    If [M:UPDS]SELFLG(L_IJ)=2
      Gosub TR1
      If GOK<1 : Break : Endif
    Endif
  Next L_IJ

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  #  - On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
# en réel après l'avoir lancé en simulation)

Return

##############
$TR1
  GOK = 1
  Call DEBTRANS From GLOCK
  Trbegin [F:HRCTR], [F:EPO]
  # Maj contrat
  Read [F:HRCTR]CTR0=[M:UPDS]REFNUM(L_IJ);[M:UPDS]CTRNUM(L_IJ);[M:UPDS]CTRDAT(L_IJ)
  If !fstat Then
    [F:HRCTR]SUICAR = 2
    Rewrite [HRCTR]
    If fstat
      GOK = 0 : Call FSTA("HRCTR") From GLOCK
    Endif
  Endif

  # FQ72832 - MABON 11/04/11 - On en profite pour mettre à Manuel, les lignes qui ne sont ni Automatique, ni Manuel
  Update [F:EPO] Where [F:EPO]REFNUM=[M:UPDS]REFNUM(L_IJ)
&                  & [F:EPO]CTRNUM=[M:UPDS]CTRNUM(L_IJ)
&                  & [F:EPO]ORIGINE<>1 & [F:EPO]ORIGINE<>2
&                With [EPO]ORIGINE=2

  # On supprime les lignes avec même données, et qui sont Automatique
  Delete [EPO] Where [F:EPO]REFNUM=[M:UPDS]REFNUM(L_IJ)
&                  & [F:EPO]CTRNUM=[M:UPDS]CTRNUM(L_IJ)
&                  & [F:EPO]DATPOT=[M:UPDS]CTRDAT(L_IJ)
&                  & [F:EPO]ORIGINE=1
  If fstat=1
   GOK = -1 : GLOCK = "$EMPLOPOT"-[M:UPDS]REFNUM(L_IJ)+"\"+[M:UPDS]CTRNUM(L_IJ)+"\"+[M:UPDS]CTRDAT(L_IJ)+"\1" : Return
  Endif

  # FQ72832 - MABON 11/04/11 - On vérifie si une ligne existe déjà à la même date, mais en manuelle
  Read [F:EPO]EPO0=[M:UPDS]REFNUM(L_IJ);[M:UPDS]CTRNUM(L_IJ);2;[M:UPDS]CTRDAT(L_IJ)
  # FQ72832 - MABON 11/04/11 - Si oui, on la supprime avant de la re-créer
  If !fstat Then
    Delete [EPO] Curr
  Endif
  Raz [F:EPO]
  [F:EPO]REFNUM  = [M:UPDS]REFNUM(L_IJ)
  [F:EPO]CTRNUM  = [M:UPDS]CTRNUM(L_IJ)
  [F:EPO]ORIGINE = 1 : # ML 399 Automatique
  [F:EPO]DATPOT  = [M:UPDS]CTRDAT(L_IJ)
#  [F:EPO]NUMLIG  = 1
  [F:EPO]POT     = [M:UPDS]POT(L_IJ)
  [F:EPO]JOBPOT  = [M:UPDS]JOBPOT(L_IJ)
  [F:EPO]CREDAT  = date$
  [F:EPO]CRETIM  = time
  [F:EPO]CREUSR  = GUSER
  Write [EPO]
  If fstat
   GOK = 0 : Call FSTA("EPO") From GLOCK : Return
  Else
    # FQ72832 - MABON 11/04/11 - Ajout d'une trace
    Call ECR_TRACE("   "-mess(5,10506,1)-[M:UPDS]REFNUM(L_IJ)-";"-mess(6,10506,1)-[M:UPDS]CTRNUM(L_IJ),0) From GESECRAN : # Salarié ; Contrat
  Endif

  If GOK=-1 : Goto ROLL_TR1
  Elsif GOK<1 : Goto AB_TR1
  Endif
  Commit
Return

$AB_TR1

  Rollback
Return

$ROLL_TR1

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
Return

$BOUTON
# SEGAY 25/10/12 US 940 81085
#  Case BOUT
#    When "C" : For I=0 To [M:UPDS]NBLIG-1 : [M:UPDS]SELFLG(I)=2 : Next
#    When "D" : For I=0 To [M:UPDS]NBLIG-1 : [M:UPDS]SELFLG(I)=1 : Next
#  Endcase
#  Affzo [M:UPDS]
#81085-#MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
Case BOITE
  When "UPDSUICAR"
    Case BOUT
      When "C" : For I=0 To [M:UPDS]NBLIG-1 : [M:UPDS]SELFLG(I)=2 : Next : Affzo [M:UPDS]
      When "D" : For I=0 To [M:UPDS]NBLIG-1 : [M:UPDS]SELFLG(I)=1 : Next : Affzo [M:UPDS]
     Endcase
  When "GENUPDSUICAR"
    Case BOUT
     When "R" :
          # Button "Rappel MEMO"
#         If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif : # Button "MEMO"
#         If dim([M:DIA]LEG)>0 : Call AM_LEG([M:DIA]LEG) From GENUPDSUICAR : Endif
#         Call D_INI([M:DIA]INI) From DIVPAYE
#         Call GRISE_LEG([M:DIA]CPY,[M:DIA]FCY) From DIVPAYE
#         If dim([M:DIA]LEG)>0 : Call AM_LEG([M:DIA]LEG) From GENUPDSUICAR : Endif
         Call AFF_MEMO2(1) From DIVPAYE: #81085
    Endcase
Endcase
#end MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
Return

