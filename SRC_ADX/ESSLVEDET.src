#<AdxTL>@(#)%I% HRESS


Subprog ESSLVEDET(EMP,CTR,EVT,DAT)
Value    Char    EMP,CTR,EVT
Value    Date    DAT

Local Char    _WINDOW(GLONFEN)
Local Char    _MAINPROCESS(GLONADC)
Local Char    _SPEPROCESS(GLONADC)
Local Char    _ACTION(GLONACT)
Local Char    PARMSK(250)(1..20)
Local Decimal BASPAG

If func AFNC.ACTIV("GLM")
  _WINDOW      = "ESSHRLTA"
  _MAINPROCESS  = "ESSHRLTA"
  _SPEPROCESS   = "SPEESSHRLTA"
  _ACTION       = "ESSHRLTA"
  #Parameters
  PARMSK(1) = EMP
  PARMSK(2) = CTR
  PARMSK(3) = EVT
  PARMSK(4) = DAT

Else
  _WINDOW      = "ESSDLS"
  _MAINPROCESS  = "ESSDLS"
  _SPEPROCESS   = "SPEESSDLS"
  _ACTION       = "ESSDLS"
  #Parameters
  PARMSK(1) = EMP
Endif


SAVACT = GACTION : GACTION = _ACTION
Call SAISIE_NUM(BASPAG,PARMSK,_WINDOW,_MAINPROCESS,_SPEPROCESS) From GSAISIE
GACTION = SAVACT

End


##################################################
Subprog ESSDLSBAL
Gosub LECTURE From ESSDLS

End

