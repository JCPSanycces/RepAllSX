###################################################################################
#  CBO 12.01.2016  FQ113414  : Erreur maj ATABDIV
#  MWA 30.12.2015  FQ113273  : Erreur dans le traitement SETGLBGCM
# GLE  02.06.2015  FQ108289  : Archive folder management
# MDJ  22.05.2015  FQ108397  : Comptes non renseignûˋs car filinfo sur FIXASSET V5 au mauvais endroit
#CBO/MDJ 15.04.2015 FQ108370  : Erreur (level 20) en migration sur dûˋpenses (pb d'alimentation du CODLOF)
#  CBO 15.04.2015  FQ107357  : Renumûˋrotation de LINLOF
#  MDJ 26.03.2015  FQ107220  : Alimentation des PERCLOCUMI, PERCLOCUMT et PERREFCLC* et initialisation PROWEK
#  MDJ 09.01.2015  FQ105293  : Maj DPRCUMFLG mûˆme si pas d'enreg dans la table X3-V5 FIXWRO
#  CBO 28.11.2014  FQ104360  : Undo a linked expense when balance sht val is changed
#  GLE 01/07/2014 (Fq-XXXXXX): Dûˋplacement de la trace sur crûˋation des exercices et pûˋriode
#  CBO 05/08/2014 (Fq-101136): GACACN û  0 : initialisûˋ dans la mûˆme boucle pour [FAS] avec GAC = ""
#  GLE 27/06/2014 (Fq-101079): Error on WTITLE if the migrated folder didn't manage Fixed Assets (Fq-94333)
#  MDJ 23/04/2014 (Fq-99396) : New Matching table for depreciation methods (miscellaneous table nô¯600)
#  MDJ 23/04/2014 (Fq-94333) : Control of asset module : for the assets migration, the FIXASSET table must exist
#  MDJ 27/03/2014 (Fq-98440) : No X3 plan found : alimentation table 591 si pas de typamort "T" dans table 312 (V5)
#  MDJ 26/12/2013 (Fq-95065) : Reprise des factures liûˋes aux immobilisations
#  MDJ 12/11/2013 (Fq-94022) : Cas oû¿ pas de type amort "E" dans le dossier X3V5
#  CBO 17/01/2013 (Fq-86584) : Init de IVYFLG et IVYFCY dans AFASMAJ30
#  GLE 04/04/2012 (Fq-81340) : Modification de l'algorithme de crûˋation des DEPREC
#                              Mise au propre Trbegin/Commit avec G_TRANSAC
#  GLE 02/04/2012 (Fq-80070) : Pas de DEPREC pour les immos ayant un "_" dans leur rûˋfûˋrence en V5
#                              On considû´re comme une erreur une ûˋcriture avec clûˋ en double des DERPEC
#  MDJ 12/10/2011 (Fq-76701) : Pb exercice suivant avec mauvais statut (suite)
#  MDJ 28/09/2011 (Fq-76652) : Alimentation des champs HRZEXE & HRZPER
#  GLE 31/08/2011 (Fq-75790) : Plantage sur type de donnûˋe lors de la crûˋation de l'association valeur ADMCOE
#  MDJ 29/06/2011 (Fq-64733d): Associations : accû´s û  la table div 961 du dossier X3 (P16)
#  MDJ 19/05/2011 (Fq-73917) : Rûˋcup. champs PLC1, PLC2, POSCOD et SERNUM dans zones libres (P16)
#  MDJ 19/05/2011 (Fq-73916) : Modif. rû´gles d'alimentation de ISSTYP
#                             + rûˋcupûˋration biens en cours de validation (P16)
#  MDJ 22/03/2011 (Fq-73011) : Pb exercice suivant avec mauvais statut
#                              + init [F:CNX]COA et init GACACN (=2) + flag acti = "Actif" (P15)
#  MDJ 22/03/2011 (Fq-72770) : Pb crûˋation de 2 pûˋriodes courantes==> cumuls repris erronûˋs (P15)
#  MDJ 02/12/2010 (Fq-69531) : Remplacement variable PDOSSIER par [F:ADS]DOSSIER
#  MDJ 28/09/2010 (Fq-64733c): Associations hors plan non-alimentûˋes
#  MDJ 02/07/2010 (Fq-64733) : Compte et nature non alimentûˋs aprû´s migration (suite)
#  MDJ 11/05/2010 (Fq-64731) : Valeur rûˋsiduelle non reprise û  tort (P9)
#  MDJ 11/05/2010 (Fq-64731) : Table 591 non alimentûˋe
#  MDJ 18/03/2010 (Fq-63364) : Migration V5 => V6  tables IMMOS V6 vides
#  MDJ 18/03/2010 (Fq-53345) : Concessions :  Table diverse 581 modifiûˋe en 591
#  MDJ 29/12/2009 (Fq-61043) : Migration modû´les import/export
## MDJ 30/09/2009 (Fq-58253) : alimentation variable EXTISSFLG (=1)+ date rûˋf, pûˋr rûˋgul TVA
###################################################################################
Subprog AFASMAJ30

  Call ECR_TRACE("Start AFASMAJ30",0) From GESECRAN
  Onerrgo ERREUR From DOSMAJ30

#-------------------------------------#
#         Avant mise û  jour           #
#-------------------------------------#
Local Char    WTITLE(250)

  WTITLE = "FASMAJ30 - Fixed Assets module "
  Call ECR_TRACE("**********************************",0) From GESECRAN
  Call ECR_TRACE(WTITLE,0)                               From GESECRAN
  Call ECR_TRACE("**********************************",0) From GESECRAN

  #*FQ94333 Check that the assets module is enable (FIXASSET table exists or not)
  If filinfo(filpath("FIL","FIXASSET","fde",[F:ADS]DOSSIER),0) <=0
    Call ECR_TIME(WTITLE+": Fixed Assets module not enabled in V5 ==>  End AFASMAJ30 ") From DOSSUB
    End
  Endif

  Gosub SUP_GLOBALES
  Gosub CRT_GLOBALES

  If (func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)) : # FQ108289
    # Nothing is done for an achive folder
     Call ECR_TRACE("Nothing done for an achive folder",0) From GESECRAN
  Else
    Call ECR_TIME(WTITLE+": ATABDIV 540 table created") From DOSSUB
    Call ECR_TIME(WTITLE+": ATABDIV 591 table created") From DOSSUB
    Call AMAJ_TDIV ([F:ADS]DOSSIER)     From FASMAJ30

    #Fq-86584
    Call ECR_TIME(WTITLE+": FACILITY table upgrade") From DOSSUB
    Call AMAJ_FACILITY ([F:ADS]DOSSIER)     From FASMAJ30

    Call ECR_TIME(WTITLE+": DPRMOD table upgrade") From DOSSUB
    Call AMAJ_DPRMOD ([F:ADS]DOSSIER)     From FASMAJ30

    Call ECR_TIME(WTITLE+": CONTEXT table upgrade") From DOSSUB
    Call AMAJ_CONTEXT ([F:ADS]DOSSIER)    From FASMAJ30

    Call ECR_TIME(WTITLE+": RUBASSDEF table upgrade") From DOSSUB
    Call AMAJ_ASSOC ([F:ADS]DOSSIER)   From FASMAJ30

    Call ECR_TIME(WTITLE+": FXDASSETS table upgrade") From DOSSUB
    Call AMAJ_FXDASSETS ([F:ADS]DOSSIER)  From FASMAJ30

    Call ECR_TIME(WTITLE+": DEPREC table upgrade") From DOSSUB
    Call AMAJ_DEPREC ([F:ADS]DOSSIER ) From FASMAJ30

    # FQ104360
    Call ECR_TIME(WTITLE+": FLGDETEXP flag from LAYOUTFAS table upgrade") From DOSSUB
    Call AMAJ_LAYOUTFAS ([F:ADS]DOSSIER ) From FASMAJ30
  Endif

  Gosub SUP_GLOBALES
  Call ECR_TRACE("End AFASMAJ30",0) From GESECRAN

End
#--------------------------------------
$CRT_GLOBALES

  Global Char G_COA

  # Indique si l'exûˋcution se fait dans une transaction
  Global Integer G_TRANSAC : G_TRANSAC = adxlog

  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM

Return
#--------------------------------------
$SUP_GLOBALES

  If (dim(G_COA)       >0)  : Kill G_COA        : Endif
  If (dim(G_TRANSAC)   >0)  : Kill G_TRANSAC    : Endif

Return
###################################################################################
###################################################################################
###################################################################################
Subprog FASMAJ30

#-------------------------------------#
#         Aprû´s mise û  jour           #
#-------------------------------------#

  Call ECR_TRACE("Start FASMAJ30",0) From GESECRAN

  If (func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)) : # FQ108289
    # Nothing is done for an achive folder
     Call ECR_TRACE("Nothing done for an achive folder",0) From GESECRAN
  Else
    Onerrgo ERREUR From DOSMAJ30

  #FQ108397  #*FQ94333 Check that the assets module is enable (FIXASSET table exists or not)
  #FQ108397  If filinfo(filpath("FIL","FIXASSET","fde",[F:ADS]DOSSIER),0) <=0
  #FQ108397    Call ECR_TIME("Fixed Assets module not enabled in V5 ==>  End FASMAJ30 ") From DOSSUB : # FQ101079 : deletion of WTITLE which is not declared here
  #FQ108397   End
  #FQ108397  Endif #*FQ94333 END

    Local Char  LCOMPTE
    Local Char  RCOA
    Local Char  RGCM : #      # Issue FQ113273
    # Indique si l'exûˋcution se fait dans une transaction
    Global Integer G_TRANSAC : G_TRANSAC = adxlog
    Global Char G_COA

    If clalev([F:CAC]) : Close File  [CAC] : Endif
    Local File =[F:ADS]DOSSIER+".GACCCODE" [CAC]

    If clalev([F:GAC]) : Close File  [GAC] : Endif
    Local File =[F:ADS]DOSSIER+".GACCOUNT"  [GAC]

    If clalev([F:CPY]) : Close File  [CPY] : Endif
    Local File =[F:ADS]DOSSIER+".COMPANY"  [CPY]

    If clalev([F:FAS]) : Close File  [FAS] : Endif
    Local File =[F:ADS]DOSSIER+".FXDASSETS" [FAS]

    If clalev([F:LOF]) : Close File  [LOF] : Endif #FQ95065
    Local File =[F:ADS]DOSSIER+".LAYOUTFAS" [LOF]

    # Table des sociûˋtûˋs migrûˋes ---------------------------------------
    If clalev([F:W540]) : Close File  [W540] : Endif
    Local File =[F:ADS]DOSSIER+".ATABDIV"   [W540]

    If !G_TRANSAC : Trbegin [FAS] : Endif
    #************
    For [CPY]CPY0
       # Issue FQ113273
       #Call LECMAINPLAN(1,[F:CPY]CPY,RCOA) From CPTDIV
       Gosub INIT_RGCM_RCOA
       # End issue FQ113273
       G_COA=RCOA
       If G_COA ="" : G_COA="FRA" : Endif
       # FQ101136 prise en compte de GACACN = 0
  #     For [FAS]FAS0 Where CPY=[F:CPY]CPY and GAC=""  With Stability
       For [FAS]FAS0 Where CPY=[F:CPY]CPY and (GAC="" or GACACN = 0) With Stability
          #########################################################
          # - Objet  : Mise û  jour de la tables des biens comptables
          # mise û  jour du compte comptable PCG
          # activation des biens    (û  voir)
          #########################################################
          If [F:FAS]GAC = ""
             Read[CAC]CAC0=15;[F:FAS]ACCCOD;G_COA
             If fstat=0
                LCOMPTE = [F:CAC]ACC(0)
                [F:FAS]GAC = LCOMPTE
                Local Integer LGACACN
                For [GAC] Where ACC=LCOMPTE and COA=G_COA
                   Read [GAC]GAC0 First
                   #Fq-73011 If fstat = 0
                   If fstat = 0 and  [F:GAC]GACACN > 0
                      [F:FAS]GACACN = [F:GAC]GACACN
                   Else
                      [F:FAS]GACACN = 2 ##Fq-73011 "En service"
                   Endif
                   Break
                Next # [GAC]
             Endif
          Else
             # FQ101136/2 relire le compte : si trouvûˋ, mettre la bonne nature
             Read [GAC]GAC0 = G_COA; [F:FAS]GACACN
             If fstat
                [F:FAS]GACACN = 2
             Else
                [F:FAS]GACACN = [F:GAC]GACACN
             Endif
          Endif
          #FQ95065 updating of expenses linked with assets
          For [LOF]LOF0 Where AASREF = [F:FAS]AASREF
             [F:LOF]GAC     =  [F:FAS]GAC
             [F:LOF]GACACN  =  [F:FAS]GACACN
             Rewrite[LOF]
             If (fstat)
               Call ECR_TRACE("LAYOUTFAS, Level 14 - File Error ="-num$(fstat),1) From GESECRAN
               GERRDOS = 1
          Endif
          Next # [LOF]
          Rewrite[FAS]
          If (fstat)
             Call ECR_TRACE("FXDASSETS, Level 14 - File Error ="-num$(fstat),1) From GESECRAN
             GERRDOS = 1
          Endif
       Next   # [FAS]
    Next # Sociûˋtûˋ
    If !G_TRANSAC : Commit : Endif
    Close File [FAS]
    If (dim(G_COA)       >0)  : Kill G_COA        : Endif
    If (dim(G_TRANSAC)   >0)  : Kill G_TRANSAC    : Endif
  Endif

  Call ECR_TRACE("End FASMAJ30",0) From GESECRAN

End
#########################################################
Subprog  AMAJ_TDIV(PDOSSIER)
Value Char PDOSSIER

  Onerrgo ERREUR From DOSMAJ30

  # RAZ de la table diverse 540 et ajout des sociûˋtûˋs û  migrer
  If clalev([F:W540]) : Close File           [W540] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"      [W540]

  # Tables X3V5 ---------------------------------------
  If clalev([F:CPY5]) : Close File           [CPY5] : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY5]
  If clalev([F:FAS5]) : Close File           [FAS5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXASSET"     [FAS5]

  If !G_TRANSAC : Trbegin [W540] : Endif
  Delete [W540] Where NUMTAB=540
  For[CPY5]CPY0
     Filter [FAS5] Where CPY= [F:CPY5]CPY
        Read [FAS5]First
        If fstat: Goto NEXTCPY : Endif
     Filter [FAS5]
     [F:W540]NUMTAB = 540
     [F:W540]CREUSR = GUSER
     [F:W540]CREDAT = date$
     [F:W540]CRETIM = time
     [F:W540]UPDUSR = GUSER
     [F:W540]UPDDAT = date$
     [F:W540]UPDTIM = time
     [F:W540]CODE   = [F:CPY5]CPY
     [F:W540]A1     = [F:CPY5]CPY
     Write [W540]
     $NEXTCPY
  Next

  If !G_TRANSAC : Commit : Endif
  Close File [W540]

  # Maj de la table diverse 591 et correspondance avec plans V6
  If clalev([F:W591]) : Close File     [W591] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"      [W591]
  # Tables X3V5 ---------------------------------------
  If clalev([F:ADI5]) : Close File     [ADI5] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"      [ADI5]

  If !G_TRANSAC : Trbegin [W591] : Endif
  Delete [W591] Where [W591]NUMTAB=591
  Local Integer N_TYP : N_TYP=0  #*FQ98440
  Local Integer N_LIB : N_LIB=10 #*FQ98440
  Filter [ADI5] Where NUMTAB=312
   For [ADI5]
     [F:W591]NUMTAB = 591
     [F:W591]CREUSR = GUSER
     [F:W591]CREDAT = date$
     [F:W591]CRETIM = time
     [F:W591]UPDUSR = GUSER
     [F:W591]UPDDAT = date$
     [F:W591]UPDTIM = time
     [F:W591]CODE   = [F:ADI5]CODE
     N_TYP+=1
     #*FQ98440  Case   [F:ADI5]CODE
     #*FQ98440    When "E"     : [F:W591]N1 = 1
     #*FQ98440    When "F"     : [F:W591]N1 = 2
     #*FQ98440    When "T"     : [F:W591]N1 = 10
     #*FQ98440    When Default : [F:W591]N1 = 11
     #*FQ98440 Endcase
     #*FQ98440
     Case   [F:ADI5]CODE
         When "E", "F"
            [F:W591]N1 = N_TYP
         When Default
           [F:W591]N1 = N_LIB
           N_LIB+=1
      Endcase
     Write [W591]
     Next
  Filter [ADI5]  #*FQ98440 END

  #FQ-94022  We check that there is a corresponding record at accounting plan in table 591
  # otherwise it is the finance plan that will be the accounting plan
  Read [F:W591]CODE=591;"E"
  If (fstat)
     Read [F:W591]CODE=591;"F"
     If fstat=0
        [F:W591]N1 = 1
        Rewrite [F:W591]
        If (fstat)
           Call ECR_TRACE("ATABDIV-591, Step AMAJ_TDIV - File Error ="-num$(fstat),1) From GESECRAN
           GERRDOS = 1
        Endif
     Else
        # message d'anomalie : pas de plan correpondant au plan comptable
        Call ECR_TRACE("ATABDIV-591, No Accounts plan in table 591 -  ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
     Endif
  Endif
  #FQ-94022 END

  If !G_TRANSAC : Commit : Endif
  Close File [W591]
  ####################################################################
  # Crûˋation automatique des familles comptables
  #
  # Tables X3V5 ---------------------------------------
  If clalev([FCA5])  : Close File       [FCA5]  : Endif
  Local File =[F:ADS]DOSSIER+".FIXCAT"        [FCA5]
  # Tables V6
  If clalev([F:XADI]) : Close File      [XADI] : Endif
  Local File = [F:ADS]DOSSIER+".ATABDIV"      [XADI]            #* --> numtab = 611 : crûˋation familles
  If clalev([F:ATX]) : Close File       [ATX] : Endif
  Local File = [F:ADS]DOSSIER+".ATEXTE"       [ATX]
  If clalev([F:AXX]) : Close File       [AXX] : Endif
  Local File = [F:ADS]DOSSIER+".ATEXTRA"      [AXX]

 Local Char WFAM
 Local Char WFAM_DES
 Local Char TEXTE(80)

 If !G_TRANSAC : Trbegin [XADI]: Endif

 For [FCA5]FCA0 With Stability
    WFAM =  sum( num$([F:FCA5]CAT),num$([F:FCA5]SUBCAT) )
    Read[XADI]CODE = 611;WFAM
    If fstat
       Raz [F:XADI]
       [F:XADI]NUMTAB  = 611
       [F:XADI]CODE    = WFAM
       [F:XADI]CREDAT  = date$
       [F:XADI]CREUSR  = GUSER
       If [F:FCA5]DES <> ''
          WFAM_DES = [F:FCA5]DES
       Else
          WFAM_DES = [F:XADI]CODE
       Endif
       Call MAJTEXTRA(WFAM_DES,"ATABDIV","LNGDES",num$([F:XADI]NUMTAB), [F:XADI]CODE) From ATEXTRA
       Call MAJTEXTRA(WFAM_DES,"ATABDIV","SHODES",num$([F:XADI]NUMTAB), [F:XADI]CODE) From ATEXTRA
       Call LECTEXTRA(TEXTE,"ATABTAB","LNGDES",num$([F:XADI]NUMTAB),"") From ATEXTRA
       # Donnûˋe de base crûˋûˋe automatiquement : Table diverse n CODE LNGDES
       Call ECR_TRACE(mess(46,7772,1)-TEXTE- [F:XADI]CODE-WFAM_DES,0) From GESECRAN
       Write [XADI]
       If fstat and fstat <> 3
          Call ECR_TRACE("ATABDIV-611, Step 01 - File Error ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
       Endif
    Endif
  Next

  If !G_TRANSAC : Commit : Endif
  Close Local File [XADI]

End

  #Fq-86584
Subprog AMAJ_FACILITY (PDOSSIER)
Value Char PDOSSIER

  If clalev([F:WFCY]) : Close File  [WFCY] : Endif
  Local File = PDOSSIER + ".FACILITY"   [WFCY]
  If !G_TRANSAC
    Trbegin [WFCY]
  Endif
  Update [WFCY]   With IVYFLG = 2 , IVYFCY = [F:WFCY]FCY

  If !G_TRANSAC
    Commit
  Endif
  Close File  [WFCY]
End
#########################################################
Subprog  AMAJ_DPRMOD (PDOSSIER)
#
#
# - Objet      : Mise û  jour de la tables des Modes d'amortissement
#                û  partir du dossier racine
#
# - Rû´gles :   Copie de tous les modes du dossier racine dans le dossier issu de la migration
#
Value Char PDOSSIER

  Local Integer NB_CRE  : NB_CRE = 0
  Local Integer NB_MAJ  : NB_MAJ = 0
  Local Integer NB_DEL  : NB_DEL = 0

  If clalev([DPX3]) : Close File [DPX3] : Endif
  If clalev([DOX3]) : Close File [DOX3] : Endif
  If clalev([DRX3]) : Close File [DRX3] : Endif
  Local File =GDOSX3+".DPRMOD"    [DPX3]
  Local File =GDOSX3+".DPRMODOPT" [DOX3]
  Local File =GDOSX3+".DPRMODRAT" [DRX3]

  If clalev([DPM])  : Close File [DPM]  : Endif
  If clalev([DMO])  : Close File [DMO]  : Endif
  If clalev([DMR])  : Close File [DMR]  : Endif
  Local File =[F:ADS]DOSSIER+".DPRMOD"        [DPM]
  Local File =[F:ADS]DOSSIER+".DPRMODOPT"     [DMO]
  Local File =[F:ADS]DOSSIER+".DPRMODRAT"     [DMR]

  ###############
  # MODES LIBRES
  ###############
  If !G_TRANSAC : Trbegin [DPM], [DMO], [DMR] : Endif

  # Mise û  jour des modes
   For [DPX3]
      [F:DPM] = [F:DPX3]
      Write [F:DPM]
      If fstat<> 0  and fstat <> 3
        Call ECR_TRACE("DPRMOD"-[F:DPM]DPM-", LEVEL 01 - File ERROR ="-num$(fstat),1) From GESECRAN
        GERRDOS = 1
      Endif

      # Mise û  jour du taux dans la table des taux
      For [DRX3] Where DPM=[F:DPM]DPM & CPY=[F:DPM]CPY
        [F:DMR] = [F:DRX3]
        Write [DMR]
          If fstat<> 0  and fstat <> 3
          Call ECR_TRACE("DPRMODRAT"-[F:DPM]DPM-", LEVEL 02 - File ERROR ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next
      # Et copie ûˋgalement de ses options et de ses taux
      For [DOX3] Where STDDPM=[F:DPX3]DPM & CPY=[F:DPX3]CPY
         [F:DMO] = [F:DOX3]
          Write [DMO]
            If fstat<> 0  and fstat <> 3
            Call ECR_TRACE("DPRMODOPT"-[F:DMO]STDDPM-", LEVEL 03 - File ERROR ="-num$(fstat),1) From GESECRAN
            GERRDOS = 1
          Endif
      Next
      # Et copie ûˋgalement de ses options et de ses taux
      For [DOX3] Where STDDPM=[F:DPX3]DPM & CPY=[F:DPX3]CPY
        [F:DMO] = [F:DOX3]
        Write [DMO]
          If fstat<> 0  and fstat <> 3
          Call ECR_TRACE("DPRMODOPT"-[F:DMO]STDDPM-", LEVEL 04 - File ERROR ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next

      For [DRX3] Where DPM=[F:DPX3]DPM & CPY=[F:DPX3]CPY
        [F:DMR] = [F:DRX3]
        Write [DMR]
          If fstat<> 0  and fstat <> 3
          Call ECR_TRACE("DPRMODRAT"-[F:DMR]DPM-", LEVEL 05 - File ERROR ="-num$(fstat),1) From GESECRAN
          GERRDOS = 1
        Endif
      Next
   Next
  If !G_TRANSAC : Commit : Endif

  Close File [DPX3]
  Close File [DOX3]
  Close File [DRX3]
  Close File [DPM]
  Close File [DMO]
  Close File [DMR]
End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_DPRMOD -*
#*************************************
#*************************************

#########################################################
Subprog  AMAJ_CONTEXT (PDOSSIER)
#
# - Objet  : Mise û  jour de la tables des Contextes
#
# - Rû´gles :
#            - Intialisation des nouveaux champs :
#                LNKPLN     Lien entre plans         -> 0
#                FLGCNXUO   Gestion des UO           -> 1 "non"
#            - Intialisation du champs ORIBASDPR selon redimensionnement
#                Report de la valeur ORIBASDPR(0) sur les plans gûˋrûˋs
#
Value Char PDOSSIER

Onerrgo ERREUR From DOSMAJ30

  # Tables X3V5 ---------------------------------------
  If clalev([F:CPY5]) : Close File     [CPY5] : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY5]

  If clalev([PER5])  : Close File      [PER5]  : Endif
  Local File =[F:ADS]DOSSIER+".PERIOD"       [PER5]

  If clalev([FAY5])  : Close File      [FAY5]  : Endif
  Local File =[F:ADS]DOSSIER+".FISCALYEAR"   [FAY5]

  If clalev([F:FAS5]) : Close File     [FAS5]  : Endif
  Local File =[F:ADS]DOSSIER+".FIXASSET"     [FAS5]

  # Tables V6 -[F:ADS]DOSSIER--------------------------------------
  If clalev([CNX])  : Close File       [CNX]   : Endif
  Local File =[F:ADS]DOSSIER+".CONTEXT"      [CNX]

  #FQ-63364 If clalev([FIY])  : Close File       [FIY]   : Endif
  #FQ-63364 Local File =PDOSSIER+".FISCYEAR"     [FIY]
  If clalev([FSY])  : Close File       [FSY]   : Endif
  Local File =[F:ADS]DOSSIER+".FISCYEAR"     [FSY]

  If clalev([CPY])  : Close File       [CPY]   : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY]

  If clalev([LED])  : Close File       [LED]   : Endif
  Local File =[F:ADS]DOSSIER+".GLED"         [LED]

  If clalev([GCM])  : Close File       [GCM]   : Endif
  Local File =[F:ADS]DOSSIER+".GACM"         [GCM]

  If clalev([F:W540]) : Close File     [W540]  : Endif
  #FQ-63364 Local File = "ATABDIV"     [W540]
  Local File =[F:ADS]DOSSIER+".ATABDIV"      [W540]

  If clalev([F:W591]) : Close File     [W591]  : Endif
  #FQ-63364 Local File = "ATABDIV"     [581]
  Local File =[F:ADS]DOSSIER+".ATABDIV"      [W591]

  Local Integer NBTYP             : # Nombre de types d'amortissements
  Local Char    TYPAMORT(1)(1..5) : # Tableau des types d'amortissement

  For [W591]CODE Where NUMTAB=591
     NBTYP += 1
     TYPAMORT(NBTYP)  = [F:W591]CODE
  Next

  #*Fq-76652 Nombre d'exercices û  calculer
  Local Integer L_HRZEXE, L_HRZPER
  Local Char    L_PARAM
  Call PARAM("","NBEXESTO",L_PARAM) From ADOVAL
  If (L_PARAM = "" ) Then
    L_HRZEXE = 2
    L_HRZPER = 2
  Else
    L_HRZEXE = val(L_PARAM)
    If ( L_HRZEXE > 3 ) Then : L_HRZPER = 3 : Else : L_HRZPER = L_HRZEXE : Endif
  Endif

  Local Integer I_SOC : I_SOC = 0
  Local Char    WLEG
  Local Char    WLED
  Local Integer WLEDTYP
  #************
  If !G_TRANSAC : Trbegin [CNX], [FSY] : Endif

  For[W540] Where NUMTAB=540
     Read [CPY]CPY0 =  [F:W540]A1
     If fstat Goto NEXTSOC : Endif
        Read[CNX]CNX0=[F:CPY]CPY;1
        If fstat= 0 : Goto NEXTSOC  Endif   # Si le contexte comptable et fiscal existe dûˋjû  pour la sociûˋtûˋ
        Read [GCM]GCM0=[F:CPY]ACM
        If fstat=0
           WLEG = [F:GCM]LEG
           WLEDTYP = [F:GCM]GENLEDTYP
           WLED    = [F:GCM]LED([F:GCM]GENLEDTYP-1)
        Endif
        Call ECR_TRACE ("AMAJ_CONTEXT-1"-num$([F:CPY]CPY)-" CONTEXT  COMPANY" , 0) From GESECRAN  #FQ-63364
        # crûˋation contexte comptable et fiscal
        [F:CNX]CPY   =   [F:CPY]CPY
        [F:CNX]CNX   =   1
        [F:CNX]CUR   =   [F:CPY]ACCCUR
        #FQ-63364 If TYPAMORT(1) <> ""
        [F:CNX]PLNCAA(0)     = G301CPT
        [F:CNX]ORIBASDPR(0)  = GVML_OBPCG
        [F:CNX]PROWEK        = 1    #FQ107220 Prorata en semaine = "Non"
        #*Fq-76652 Alimentation des champs HRZEXE et HRZPER
        #*Fq-81340 Ajout d'un test d'existence pour pouvoir livrer ce traitement en avance de phase
        If dim([F:CNX]HRZEXE)>=0
          If L_HRZEXE = 0
             [F:CNX]HRZEXE = 2
          Else
             [F:CNX]HRZEXE = L_HRZEXE
          Endif
        Endif
        If dim([F:CNX]HRZPER)>=0
          If L_HRZPER = 0
             [F:CNX]HRZPER = 2
          Else
             [F:CNX]HRZPER = L_HRZPER
          Endif
        Endif
        If   WLEG = "FRA"
           [F:CNX]PLNSTD(0)     = GVML_NPCRC
        Else
           [F:CNX]PLNSTD(0)     = GVML_NPSTD
        Endif
        [F:CNX]LEDTYP(0)     = WLEDTYP
        [F:CNX]LED(0)        = WLED
        [F:CNX]COA(0)        = WLED
        If [F:CPY]CRY = 'FR'
           [F:CNX]FLUTRATXS(0) = [F:CPY]CRY
        Else
           [F:CNX]FLUTRATXS(0) = ""
        Endif
        [F:CNX]NBPLC = 1
        #FQ-63364 Endif     FQ-63364
        If TYPAMORT(2) <> ""
           [F:CNX]PLNCAA(1) = G301FIS
           [F:CNX]ORIBASDPR(1)  = GVML_OBPCG
           [F:CNX]PLNSTD(1)     = GVML_NPSTD
           [F:CNX]LEDTYP(1)     = WLEDTYP
           [F:CNX]LED(1)        = WLED
           [F:CNX]COA(1)        = WLED #Fq-73011
           [F:CNX]NBPLC += 1
         Endif
         If TYPAMORT(3) <> ""
            [F:CNX]PLNCAA(2) = G301LI1
            [F:CNX]ORIBASDPR(2)  = GVML_OBPCG
            [F:CNX]PLNSTD(2)     = GVML_NPSTD
            [F:CNX]LEDTYP(2)     = WLEDTYP
            [F:CNX]LED(2)        = WLED
            [F:CNX]COA(2)        = WLED #Fq-73011
            [F:CNX]NBPLC += 1
         Endif
         If TYPAMORT(4) <> ""
            [F:CNX]PLNCAA(3) = G301LI2
            [F:CNX]ORIBASDPR(3)  = GVML_OBPCG
            [F:CNX]PLNSTD(3)     = GVML_NPSTD
            [F:CNX]LEDTYP(3)     = WLEDTYP
            [F:CNX]LED(3)        = WLED
            [F:CNX]COA(3)        = WLED #Fq-73011
            [F:CNX]NBPLC += 1
         Endif
         If TYPAMORT(5) <> ""
            [F:CNX]PLNCAA(4) = G301LI3
            [F:CNX]ORIBASDPR(4)  = GVML_OBPCG
            [F:CNX]PLNSTD(4)     = GVML_NPSTD
            [F:CNX]LEDTYP(4)     = [M:FPC]GENLEDTYP
            [F:CNX]LED(4)        = WLED
            [F:CNX]COA(4)        = WLED #Fq-73011
            [F:CNX]NBPLC += 1
         Endif
         Write [CNX]
         If (fstat)  and fstat <> 3
            Call ECR_TRACE("CONTEXT, Level 06 - File Error ="-num$(fstat),1) From GESECRAN
            GERRDOS = 1
         Else
            # <1 <<<<<<<<<<<
            Call ECR_TRACE ("AMAJ_CONTEXT-2"-num$([F:CNX]CPY)-" CONTEXT  COMPANY CREATED  " , 0) From GESECRAN  #FQ-63364
            Call ECR_TRACE ("AMAJ_CONTEXT-3"-num$([F:CNX]CNX)-" CONTEXT  CONTEXT CREATED  " , 0) From GESECRAN  #FQ-63364
         Endif
         #########################################################
         # - Objet  : Mise û  jour de la tables des exercice
         #
         # - Rû´gles : crûˋation des exercices/pûˋriodes
         #########################################################
         Local Integer NBPERFAY
         Local Integer NB_DAY
         Local Integer NB_MONTH
         Local Integer NB_WEEK
         Local Decimal NB_YEAR
         Local Integer WEXECOUR   :   WEXECOUR  = 0
         Local Integer WEXESUIV   :   WEXESUIV  = 0
         Local Integer WEXESUIV2  :   WEXESUIV2 = 0
         Local Integer WPERCOUR   :   WPERCOUR  = 0
         Local Integer NBPER
         #FQ-72770 Filter [FAY5] Where CPY=[F:CPY]CPY and LEDTYP=1 and FIYSTA < 3       # fiysta = 1-non-ouvert ou 2-ouvert
         Filter [FAY5] Where ( CPY=[F:CPY]CPY  and LEDTYP=1  and FIYSTA < 3 )       # fiysta = 1-non-ouvert ou 2-ouvert
         For [FAY5]
            NBPER    = 1
            #FQ-72770 WPERCOUR = 0
            Raz [F:FSY]
            [F:FSY]CPY        = [F:CPY]CPY
            [F:FSY]CNX        = [F:CNX]CNX
            [F:FSY]DATSTRFIY  = [F:FAY5]FIYSTR
            [F:FSY]DATENDFIY  = [F:FAY5]FIYEND
            If [F:FAY5]FIYSTA = 2  and WEXECOUR = 0
               [F:FSY]STAFIY = 2
               WEXECOUR  = 1
            Else
               #Fq-73011 If  WEXECOUR = 1 and WEXESUIV = 0
               If  WEXECOUR = 1 and WEXESUIV = 0 and   WEXESUIV2 = 0
                  [F:FSY]STAFIY = 3   # Suivant
                  WEXESUIV  = 1
               Else
                  If  WEXECOUR = 1 and WEXESUIV = 1 and   WEXESUIV2 = 0
                     [F:FSY]STAFIY = 4   # Suivant+1
                     WEXESUIV2 = 1
                  Else
                     If  WEXECOUR = 1 and WEXESUIV = 1 and   WEXESUIV2 =1
                        [F:FSY]STAFIY = 0   # Suivant+n
                     Endif
                  Endif
               Endif
            Endif
            # ------------------------------
            NBPERFAY = 0
            # Chargement des pûˋriodes si besoin
            For[PER5]PER0 Where  CPY=[F:CPY]CPY and LEDTYP=1 and FIYNUM = [F:FAY5]FIYNUM
               [F:FSY]DATSTRPER(NBPER-1)     = [F:PER5]PERSTR
               [F:FSY]DATENDPER(NBPER-1)     = [F:PER5]PEREND
               Call CALCUL_NB_D_M_W_Y ([F:FSY]DATSTRPER(NBPER-1), [F:FSY]DATENDPER(NBPER-1), NB_DAY, NB_MONTH, NB_WEEK, NB_YEAR) From GLOBIENS
               [F:FSY]NBRMONPER  (NBPER-1)   = NB_MONTH
               [F:FSY]NBRWEKPER  (NBPER-1)   = NB_WEEK
               [F:FSY]NBRDAYPER  (NBPER-1)   = NB_DAY
               Case  [F:PER5]PERSTA
                  When 2 # ==> pûˋriode ouverte
                     If WPERCOUR = 0  and [F:FSY]STAFIY = GVML_TECOURA
                        [F:FSY]STAPER     (NBPER-1) = GVML_SPCOURA
                        [F:FSY]INDCURPER    = NBPER
                         WPERCOUR = 1
                     Else
                        [F:FSY]STAPER     (NBPER-1)  = GVML_SPOUVER
                     Endif
                     [F:FSY]TYPPST     (NBPER-1)  = GVML_TPSTPRO
                  When 1 # ==> pûˋriode non-ouverte
                    [F:FSY]STAPER     (NBPER-1)  = GVML_SPFERME
                    [F:FSY]TYPPST     (NBPER-1)  = 0
                  When 3 # ==> pûˋriode fermûˋe
                    [F:FSY]STAPER     (NBPER-1)  = GVML_SPCLOSE
                    [F:FSY]TYPPST     (NBPER-1)  = 0
               Endcase
               If   [F:FSY]INDCURPER    = 0
                    [F:FSY]INDCURPER    = 1
               Endif
               #---------------
               NBPER += 1
               NBPERFAY +=1
               # Suite de la boucle
            Next # pûˋriode suivante
            [F:FSY]NBRPER =  NBPERFAY
            Write[FSY]
            If (fstat)
              If fstat<> 3 #Fq-72770
                Call ECR_TRACE("FISCYEAR, Level 07 - File Error ="-num$(fstat),1) From GESECRAN
                GERRDOS = 1
              Endif #Fq-72770
            Else
              Call ECR_TRACE ("AMAJ_CONTEXT-4"-num$([F:FSY]CPY)-" FISCYEAR COMPANY CREATED  " , 0) From GESECRAN  #FQ-63364
              Call ECR_TRACE ("AMAJ_CONTEXT-5"-num$([F:FSY]CNX)-" FISCYEAR CONTEXT CREATED  " , 0) From GESECRAN  #FQ-63364
            Endif
            #  ------------------------------
            # Suite de la boucle
         Next # exercice suivant
         Filter[FAY5]
         # ------------------------------
         # <1 <<<<<<<<<<<
      $NEXTSOC
    Next # sociûˋtûˋ

   If !G_TRANSAC : Commit : Endif

Close Local File [FSY]
Close Local File [CNX]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_CONTEXT -*
#*************************************
#*************************************
#########################################################
Subprog  AMAJ_ASSOC (PDOSSIER)
#
# - Objet  : Crûˋation d'associations
#
# - Rû´gles :
#

Value Char PDOSSIER

  Onerrgo ERREUR From DOSMAJ30

  # Tables X3V5 ---------------------------------------
  If clalev([FCA5])  : Close File      [FCA5]  : Endif
  Local File =[F:ADS]DOSSIER+".FIXCAT"       [FCA5]

  If clalev([FCD5])  : Close File      [FCD5]  : Endif
  Local File =[F:ADS]DOSSIER+".FIXCATDEP"    [FCD5]
  # Tables V6 ---------------------------------------
  If clalev([RDE])  : Close File             [RDE]  : Endif
  Local File =[F:ADS]DOSSIER+".RUBASSDEF"    [RDE]

  If clalev([RVA])  : Close File             [RVA]  : Endif
  Local File =[F:ADS]DOSSIER+".RUBASSVAL"    [RVA]

  If clalev([RDP])  : Close File             [RDP]  : Endif
  Local File =[F:ADS]DOSSIER+".RUBASSDEFP"   [RDP]

  If clalev([RVP])  : Close File            [RVP]  : Endif
  Local File =[F:ADS]DOSSIER+".RUBASSVALP"  [RVP]

  If clalev([F:CNX]) : Close File           [CNX] : Endif
  Local File =[F:ADS]DOSSIER+".CONTEXT"     [CNX]

  If clalev([CPY])  : Close File            [CPY]  : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]

  If clalev([LED])  : Close File            [LED]  : Endif
  Local File =[F:ADS]DOSSIER+".GLED"        [LED]

  If clalev([GCM])  : Close File            [GCM]  : Endif
  Local File =[F:ADS]DOSSIER+".GACM"        [GCM]
  #---------------------------------------
  If clalev([F:W540]) : Close File          [W540] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"     [W540]               #* --> numtab = 540 : sociûˋtûˋ û  migrer

  #Fq-64733d If clalev([F:WADR]) : Close File     [WADR] : Endif
  #Fq-64733d Local File =[F:ADS]DOSSIER+".ATABDIV"      [WADR]   #* --> numtab = 961 : rubriques dûˋterminûˋes
  If clalev([F:W961]) : Close File          [W961] : Endif
  Local File =GDOSX3+".ATABDIV"             [W961]

  If clalev([F:W591]) : Close File          [W591] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"     [W591]               #* --> numtab = 591 : Types d'amortissement

  #*FQ99396 Correspondences between Depreciation methods V5 and Depreciation methods V6
  If clalev([F:W600]) : Close File          [W600] : Endif       #* --> numtab = 600 : Migration Depreciation methods
  Local File =GDOSX3+".ATABDIV"             [W600]


  #---------------------------------------
  Local Integer I_PLN, I_RUB, I_R
  Local Char    WLEG
  Local Char    WLED
  Local Integer WLEDTYP
  #************
  If !G_TRANSAC : Trbegin [RDE], [RDP], [RVA], [RVP] : Endif

  For[W540] Where NUMTAB=540
     Read [CPY]CPY0=[F:W540]A1
     If fstat : Goto NEXTENR : Endif
     Read [GCM]GCM0=[F:CPY]ACM
     If fstat=0
        WLEG    = [F:GCM]LEG
        WLEDTYP = [F:GCM]GENLEDTYP
        WLED    = [F:GCM]LED([F:GCM]GENLEDTYP-1)
     Endif
     Raz[RDE]
     [F:RDE]REFOBJ    = 2
     [F:RDE]DETAAS    = 1
     [F:RDE]ACM       = [F:CPY]ACM
     [F:RDE]CPY       = [F:CPY]CPY
     [F:RDE]LEG       = WLEG
     [F:RDE]ENAFLG    = 1
     [F:RDE]NUMASS= sum(num$(2),num$(1),[F:CPY]ACM,[F:CPY]CPY )
     Local Integer I_R : I_R = 1
     #Fq-64733Filter [W961] Where (NUMTAB = 961 and pat(A1,"B*" ) and A2 <> "CCN")  Order By N1 Asc; CODE Asc
     Filter [W961] Where (NUMTAB=961 and ( pat(A1,"B*" ) or pat(A1,"F*" )) and A2 <> "CCN") Order By N1 Asc; CODE Asc
       For [W961]
         [F:RDE]RUBRAS(I_R-1)  = [F:W961]CODE
         [F:RDE]MGTFLG(I_R-1) = 2
         [F:RDE]UPDFLG(I_R-1) = 2
         [F:RDE]FRCFLG(I_R-1) = 1
         #*------------------------------------------------------------------------------
         I_R += 1
       Next
     Filter[W961]
     [F:RDE]NBRUB0  = I_R-1
     [F:RDE]NBRUB   = I_R-1
     #-------------------
     Write [RDE]
     If (fstat)
        If fstat <> 3
           Call ECR_TRACE("RUBASSDEF, Level 08 - File Error ="-num$(fstat),1) From GESECRAN
           Goto NEXTENR
        Endif
     Endif

     Raz[RVA]
     For [FCA5]FCA0
        WFAM =  sum( num$([F:FCA5]CAT),num$([F:FCA5]SUBCAT) )
        [F:RVA]REFOBJ    = 2
        [F:RVA]DETAAS    = 1
        [F:RVA]ACM       = [F:CPY]ACM
        [F:RVA]CPY       = [F:CPY]CPY
        [F:RVA]LEG       = WLEG
        [F:RVA]NUMASS= sum(num$(2),num$(1),[F:CPY]ACM,[F:CPY]CPY )
        [F:RVA]VALDETAAS = WFAM
        For I=1 To [F:RDE]NBRUB0-1
            [F:RVA]RUBRAS(I-1) =  [F:RDE]RUBRAS(I-1)
            If  [F:RDE]RUBRAS(I-1) = "AASTYP"
               Case [F:FCA5]FASTYP
                  When 1   :   [F:RVA]VALDETEAS (I-1) = "2"      # --> Incorporel
                  When 2   :   [F:RVA]VALDETEAS (I-1) = "1"      # --> Corporel
                  When 3   :   [F:RVA]VALDETEAS (I-1) = "1"      # --> Corporel
                  When 4   :   [F:RVA]VALDETEAS (I-1) = "3"      # --> Goodwill
                  When 5   :   [F:RVA]VALDETEAS (I-1) = "4"      # --> Financiû´re
               Endcase
               [F:RVA]NOLIB (I-1) = 3151
            Endif
            If  [F:RDE]RUBRAS(I-1) = "CMPSTA"
               [F:RVA]NOLIB (I-1) = 3229
            Endif
            If  [F:RDE]RUBRAS(I-1) = "GACACN"
               [F:RVA]NOLIB (I-1) = 2628
            Endif
            If  [F:RDE]RUBRAS(I-1) = "IASACN"
               [F:RVA]NOLIB (I-1) = 2628
            Endif
            If  [F:RDE]RUBRAS(I-1) = "PRATYP"
               [F:RVA]NOLIB (I-1) = 3105
            Endif
            If  [F:RDE]RUBRAS(I-1) = "STABILTYP"
               [F:RVA]NOLIB (I-1) = 3156
            Endif
            If  [F:RDE]RUBRAS(I-1) = "TAXTYP"
               [F:RVA]NOLIB (I-1) = 3158
            Endif
            If  [F:RDE]RUBRAS(I-1) = "ACCCOD"
                [F:RVA]VALDETEAS (I-1)= [F:FCA5]ACCCOD
            Endif
            If  [F:RDE]RUBRAS(I-1) = "ADMCOE"
                #[F:RVA]VALDETEAS (I-1)= 1 : # FQ75790
                [F:RVA]VALDETEAS (I-1)= "1"
            Endif
        Next
        #Fq-64733
        If [F:RDE]NBRUB0 > 0
         [F:RVA]NBLIG = [F:RDE]NBRUB0-1
        Else
         [F:RVA]NBLIG=0
        Endif #Fq-64733
        Write [RVA]
        If (fstat)
           If (fstat <> 3 )
              Call ECR_TRACE("RUBASSVAL,  Level 18 - File Error ="-num$(fstat),1) From GESECRAN
              GERRDOS = 1
           Endif
        Endif
     Next # catûˋgorie/sous-catûˋgorie

     Raz[RDP]
     # Enregistrement des  plans gûˋrûˋs dans la table RUBASSDEFP
     [F:RDP]REFOBJ = 2
     [F:RDP]DETAAS = 1
     [F:RDP]CPY    = [F:CPY]CPY
     [F:RDP]ACM    = [F:CPY]ACM
     [F:RDP]LEG    = WLEG
     [F:RDP]NUMASS = sum(num$(2),num$(1),[F:CPY]ACM,[F:CPY]CPY)
     Local Integer NBTYP             : # Nombre de types d'amortissements
     Local Char    TYPAMORT(1)(1..5) : # Tableau des types d'amortissement
     For [W591] Where NUMTAB=591
        Case   [F:W591]N1
           When 1  :  [F:RDP]DPRPLN = 1
           When 2  :  [F:RDP]DPRPLN = 2
           When 3  :  [F:RDP]DPRPLN = 3
           When 4  :  [F:RDP]DPRPLN = 4
           When 5  :  [F:RDP]DPRPLN = 5
           When 6  :  [F:RDP]DPRPLN = 6
           When 7  :  [F:RDP]DPRPLN = 7
           When 8  :  [F:RDP]DPRPLN = 8
           When 9  :  [F:RDP]DPRPLN = 9
           When 10 :  [F:RDP]DPRPLN = 10
           When 11 :  [F:RDP]DPRPLN = 11
           When 12 :  [F:RDP]DPRPLN = 12
           When 13 :  [F:RDP]DPRPLN = 13
           When 14 :  [F:RDP]DPRPLN = 14
           When 15 :  [F:RDP]DPRPLN = 15
        Endcase
        [F:RDP]RUBRASP(0)  = "DPM"
        [F:RDP]MGTFLGP(0) = 2
        [F:RDP]UPDFLGP(0) = 2
        [F:RDP]FRCFLGP(0) = 1
        [F:RDP]RUBRASP(1)  = "DPRDUR"
        [F:RDP]MGTFLGP(1) = 2
        [F:RDP]UPDFLGP(1) = 2
        [F:RDP]FRCFLGP(1) = 1
        [F:RDP]RUBRASP(2)  = "DPRRAT"
        [F:RDP]RUBRASP(3)  = "ALWCOD"
        [F:RDP]RUBRASP(4)  = "CRBVEHCOD"
        [F:RDP]RUBRASP(5)  = "DPRRAT2"
        [F:RDP]RUBRASP(6)  = "PRATYP"
        [F:RDP]RUBRASP(7)  = "ACLCOE"
        [F:RDP]ENAFLG      = 1 #"Non"
        [F:RDP]NBRUBP = 8
        #---------------
        Write [RDP]
        If (fstat)  and fstat <> 3
           Call ECR_TRACE("RUBASSDEFP, Level 09 - File Error ="-num$(fstat),1) From GESECRAN
           GERRDOS = 1
        Endif

     Local Char WFAMP
     Raz[RVP]
     For [FCD5]FCD0
        WFAMP =  sum( num$([F:FCD5]CAT),num$([F:FCD5]SUBCAT))
        [F:RVP]REFOBJ    = 2
        [F:RVP]DETAAS    = 1
        [F:RVP]ACM       = [F:CPY]ACM
        [F:RVP]CPY       = [F:CPY]CPY
        [F:RVP]NUMASS= sum(num$(2),num$(1),[F:CPY]ACM,[F:CPY]CPY )
        [F:RVP]VALDETAAS = WFAMP
        [F:RVP]DPRPLN    =  [F:RDP]DPRPLN
        [F:RVP]ALWCOD    = 1

        #*FQ99396 Case [FCD5]WROMOD
        #*FQ99396    When  "C"  :    [F:RVP]DPM = "PR"
        #*FQ99396    When  "D"  :    [F:RVP]DPM = "DF"
        #*FQ99396    When  "E"  :    [F:RVP]DPM = "SO"
        #*FQ99396    When  "L"  :    [F:RVP]DPM = "LP"
        #*FQ99396    When  "N"  :    [F:RVP]DPM = "SA"
        #*FQ99396    When Default :  [F:RVP]DPM = "SA"
        #*FQ99396 Endcase

        #*FQ99396 Matching table for depreciation methods (miscellaneous table nô¯600)
        Read [W600]CODE=600;[FCD5]WROMOD
        If fstat=0
           [F:RVP]DPM = [F:W600]A1
        Else
           [F:RVP]DPM = "SA"
        Endif
        #*FQ99396 END
        #*
        [F:RVP]DPRDUR    =  [F:FCD5]YEANBR
        [F:RVP]DPRRAT    =  ([F:FCD5]DEPRAT / 100 )
        [F:RVP]LEG       =  WLEG
        [F:RVP]PRATYP    =  [F:FCD5]RNDTYP
        Write [RVP]
        If (fstat)  and fstat <> 3
           Call ECR_TRACE("RUBASSVALP,  Level 18 - File Error ="-num$(fstat),1) From GESECRAN
            GERRDOS = 1
        Endif
      Next # Catûˋgorie/sous-catûˋgorie
     Next   # plan gûˋrûˋ
     $NEXTENR
   Next # Sociûˋtûˋ

  If !G_TRANSAC : Commit : Endif

  #************
  Close Local File [RDP]
  Close Local File [RDE]
  Close Local File [RVA]
  Close Local File [RVP]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_ASSOC -*
#*************************************
#*************************************
#########################################################
Subprog  AMAJ_FXDASSETS (PDOSSIER)
#
# - Objet  : Mise û  jour de la tables des Biens comptables
#
# - Rû´gles :
#
Value Char PDOSSIER

  Onerrgo ERREUR From DOSMAJ30
  Local Char LCOMPTE

  Global Char GFASLEDSOC
  # Table des sociûˋtûˋs û  migrer ---------------------------------------
  If clalev([F:W540]) : Close File  [W540] : Endif
  #FQ-63364 Local File = "ATABDIV"  [W540]
  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W540]

  # Tables X3V5 ---------------------------------------
  If clalev([F:FCA5]) : Close File        [FCA5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXCAT"    [FCA5]

  If clalev([F:FAS5]) : Close File        [FAS5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXASSET"  [FAS5]

  #FQ95065 Lignes factures immo
  If clalev([F:FIL5]) : Close File         [FIL5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXINVLIG"  [FIL5]

  # Tables V6 ---------------------------------------
  If clalev([F:CPY]) : Close File       [CPY] : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY" [CPY]

  If clalev([F:CNX]) : Close File       [CNX] : Endif
  Local File =[F:ADS]DOSSIER+".CONTEXT" [CNX]

  If clalev([F:WCAC]) : Close File        [WCAC] : Endif
  #FQ-63364 Local File =[F:ADS]DOSSIER+".GACCCODE" [WCAC]
  Local File =[F:ADS]DOSSIER+".GACCCODE"  [WCAC]

  If clalev([F:WGAC]) : Close File        [WGAC] : Endif          #Fq-63364
  Local File =[F:ADS]DOSSIER+".GACCOUNT"  [WGAC]            #Fq-63364

  If clalev([F:WCCE]) : Close File        [WCCE] : Endif
  Local File =[F:ADS]DOSSIER+".CACCE"     [WCCE]

  If clalev([F:WFAS]) : Close File        [WFAS] : Endif
  Local File =[F:ADS]DOSSIER+".FXDASSETS" [WFAS]

  #FQ95065 Sauvegarde Immobilisations pour lignes factures
  If clalev([F:XFAS]) : Close File        [XFAS] : Endif
  Local File =[F:ADS]DOSSIER+".FXDASSETS" [XFAS]

  #FQ95065 Dûˋpenses immo
  If clalev([F:WLOF]) : Close File         [WLOF] : Endif
  Local File =[F:ADS]DOSSIER+".LAYOUTFAS"  [WLOF]
  # FQ107357
  If clalev([F:WLFC]) : Close File         [WLFC] : Endif
  Local File =[F:ADS]DOSSIER+".LAYOUTFAS"  [WLFC]

  #<Fq-73917
  # FQ113414 les W501 û  W504 sont remplacûˋs par WTDI
  If clalev([F:WTDI]) : Close File        [WTDI] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"   [WTDI]

#  If clalev([F:W501]) : Close File        [W501] : Endif
#  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W501]
#
#  If clalev([F:W502]) : Close File        [W502] : Endif
#  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W502]
#
#  If clalev([F:W503]) : Close File        [W503] : Endif
#  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W503]
#
#  If clalev([F:W504]) : Close File        [W504] : Endif
#  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W504]   #Fq-73917>

  If clalev([F:AXX]) :  Close File        [AXX] : Endif # FQ113414
  Local File = [F:ADS]DOSSIER+".ATEXTRA"  [AXX] # FQ113414

   Local Integer NBFAS5
   Local Integer NBFIL5 #FQ95065 : nb de factures V5
   Local Char RCOA
   Local Char RGCM : #      # Issue FQ113273

   #*Fq-73917 Trbegin [WFAS]
   If !G_TRANSAC : Trbegin [WFAS] : Endif

   #************
   For[W540] Where NUMTAB=540
      Read [CPY]CPY0=[F:W540]A1
      If fstat  : Goto NEXT540 : Endif
      # Issue FQ113273
      #Call LECMAINPLAN(1,[F:CPY]CPY,RCOA) From CPTDIV
      Gosub INIT_RGCM_RCOA
      # End issue FQ113273
      G_COA=RCOA
      # Les immo ayant un ûˋtat inactif (STA=2)  ou en attente de validation (ACCFLG=1)
      # ne seront pas ûˆtre prises en compte dans la migration
      #FQ-73916 Filter [FAS5] Where CPY=[F:CPY]CPY and [F:FAS5]STA <> 2 and [F:FAS5]ACCFLG<>1
      #FQ-73916 On prendra dûˋsormais aussi les biens en attente de validation (bien en-cours)
      Filter [FAS5] Where CPY=[F:CPY]CPY and [F:FAS5]STA <> 2
      For [FAS5]FAS0 With Stability
         #########################################################
         # - Objet  : Mise û  jour de la tables des biens comptables
         # - Rû´gles : crûˋation des biens
          #########################################################
         Raz [F:WFAS]
         [F:WFAS]CPY        = [F:CPY]CPY
         Read [CNX]CNX0=[F:CPY]CPY;1
         [F:WFAS]FCY        = [F:FAS5]FINFCY
         [F:WFAS]AASREF     = sum(num$([F:FAS5]FASCOD),"_",num$([F:FAS5]FASNUM))
         [F:WFAS]AASDES1    = [F:FAS5]DES
         [F:WFAS]AASDES2    = [F:FAS5]DESSUP(0)
         If [F:FAS5]FASREF <> ""
            [F:WFAS]SET     = [F:FAS5]FASREF
         Else
            [F:WFAS]SET     = [F:WFAS]AASREF
         Endif
         [F:WFAS]ACGGRP     = sum( num$([F:FAS5]CAT),num$([F:FAS5]SUBCAT) )
         [F:WFAS]ACCCOD     = [F:FAS5]ACCCOD
         Filter [WCAC] Where TYP=15 and ACCCOD=[F:WFAS]ACCCOD
         For [WCAC]
            If [F:WCAC]COA=G_COA
               GFASLEDSOC=G_COA
               LCOMPTE = [F:WCAC]ACC(0)
               [F:WFAS]GAC = LCOMPTE
               For [WGAC] Where ACC=LCOMPTE and COA=G_COA
                  Read [WGAC]GAC0 First
                 #Fq-73011 If fstat = 0
                  If fstat = 0 and [F:WGAC]GACACN > 0
                     [F:WFAS]GACACN = [F:WGAC]GACACN
                  Else
                     #Fq-73011 [F:WFAS]GACACN = 0
                     [F:WFAS]GACACN = 2 #Fq-XXXX "En service"
                  Endif
                  Break
               Next
            Endif
         Next # [WCAC]
         Filter [WCAC]
         [F:WFAS]PURDAT     = [F:FAS5]PURDAT
         [F:WFAS]AASIPTDAT  = [F:FAS5]PURDAT
         [F:WFAS]ITSDAT     = [F:FAS5]ACTDAT
         [F:WFAS]OWNTYP     = 1
         Case [F:FAS5]TYPRCP
            When "F" :    [F:WFAS]PURNAT = 2      # --> Occasion
            When "L" :    [F:WFAS]PURNAT = 1      # --> Neuf
            When "N" :    [F:WFAS]PURNAT = 1      # --> Neuf
            When "O" :    [F:WFAS]PURNAT = 2      # --> Occasion
         Endcase
         If [F:FAS5]QTY = 0
            [F:WFAS]AASQTY    = 1
         Else
             [F:WFAS]AASQTY   = [F:FAS5]QTY
         Endif
         Read [FCA5]FCA0=[F:FAS5]CAT;[F:FAS5]SUBCAT
         If fstat=0
            Case [F:FCA5]FASTYP
               When 1   :    [F:WFAS]AASTYP = 2      # --> Incorporel
               When 2   :    [F:WFAS]AASTYP = 1      # --> Corporel
               When 3   :    [F:WFAS]AASTYP = 1      # --> Corporel
               When 4   :    [F:WFAS]AASTYP = 3      # --> Goodwill
               When 5   :    [F:WFAS]AASTYP = 4      # --> Financiû´re
            Endcase
         Endif
         [F:WFAS]ETRNAT     = 1
         # [F:WFAS]ETRNAT     = val([F:FAS5]TYPRCP)
         #-----------------------------------------
         # Montant HT
         If [F:FAS5]TOTAMTNOT = 0 or  [F:FAS5]TOTAMTNOT = [F:FAS5]TOTAMTATI
            [F:WFAS]ACGETRNOT   = [F:FAS5]AMTORI
         Else
            [F:WFAS]ACGETRNOT  = [F:FAS5]TOTAMTNOT
         Endif

         If [F:FAS5]TOTAMTNOT <> 0
            # Montant TVA facturûˋe = TTC - HT
            [F:WFAS]IVCVATAMT  =   [F:FAS5]TOTAMTATI- [F:FAS5]TOTAMTNOT
            If  ( [F:FAS5]AMTORI < [F:FAS5]TOTAMTATI ) or ( [F:FAS5]AMTORI <  [F:FAS5]TOTAMTNOT )
               [F:WFAS]DEDVATAMT = [F:FAS5]TOTAMTATI -  [F:FAS5]AMTORI
            Else
               [F:WFAS]DEDVATAMT  = 0
            Endif
         Else
            [F:WFAS]IVCVATAMT  =  0
            [F:WFAS]DEDVATAMT  =  0
         Endif
         # Dans tous les cas forûÏage des montants de TVA facturûˋe et rûˋcupûˋrûˋe
         [F:WFAS]IVCVATFLG = 2
         [F:WFAS]DEDVATFLG = 2
         If [F:WFAS]ACGETRNOT <> 0
            [F:WFAS]IVCVATRAT  =   [F:WFAS]IVCVATAMT/[F:WFAS]ACGETRNOT
         Endif
         If [F:WFAS]DEDVATAMT <> 0
            [F:WFAS]DEDVATRAT  =   [F:WFAS]IVCVATAMT/ [F:WFAS]DEDVATAMT
         Else
            [F:WFAS]IVCVATRAT  =   1
            [F:WFAS]DEDVATRAT  =   1
         Endif
         #-----------------------------------------
         If [F:WFAS]IVCVATRAT <> 0
           [F:WFAS]IVCVATRAT = [F:WFAS]IVCVATRAT * 100
         Endif
         If [F:WFAS]DEDVATRAT <> 0
           [F:WFAS]DEDVATRAT = [F:WFAS]DEDVATRAT * 100
         Endif
         #-----------------------------------------
         [F:WFAS]TAXBAS  = [F:FAS5]BASTAX
         #If [F:FAS5]TIT = G_OUI   # Taxe professionnelle
         If [F:FAS5]TIT = 2   # Taxe professionnelle
            [F:WFAS]TAXTYP  = 1
         Else
            If [F:FAS5]PTA = 2
               [F:WFAS]TAXTYP = 2
            Else
               [F:WFAS]TAXTYP = 3
            Endif
         Endif
         [F:WFAS]VATREGDAT  = [F:FAS5]PURDAT
         If ( [F:WFAS]TAXTYP = GVML_TTFONCI ) Then
            If ( [F:WFAS]VATREGDAT < [01/01/1996]) Then
              [F:WFAS]THESLI = 10
            Else
              [F:WFAS]THESLI = 20
            Endif
         Else
           [F:WFAS]THESLI = 5
         Endif
         If (  [F:WFAS]THESLI <> 0 )
            # Bien comptable
            [F:WFAS]VATRSD  =[F:WFAS]THESLI -(( year(GDEBEXECPF)- year( [F:WFAS]VATREGDAT) )+1)
         Endif
         [F:WFAS]GEOFCY    = [F:FAS5]FCY
         [F:WFAS]DSP       = [F:FAS5]DSP
         For I=1 To 9
           [F:WFAS]DIE(I-1) = GDIE(I)
           [F:WFAS]CCE(I-1) = [F:FAS5]CCE(I-1)
         Next I
         #Fq-54730 [F:WFAS]USRFLDA1  = [F:FAS5]SERNUM
         #<Fq-73917 Rûˋcupûˋration du code postal dans la TDI 501

         # # FQ113414 : les 4 tables diverses sont corrigûˋes de la mûˆme maniû´re.
         # Il reste l'ancien code uniquement pour la 503

         Local Char WPOSCOD
         If [F:FAS5]POSCOD <> ""
           Read [F:WTDI]CODE=501;[F:FAS5]POSCOD
           If fstat <> 0
              [F:WTDI]NUMTAB = 501
              [F:WTDI]CREUSR = GUSER
              [F:WTDI]CREDAT = date$
              [F:WTDI]CRETIM = time
              [F:WTDI]UPDUSR = GUSER
              [F:WTDI]UPDDAT = date$
              [F:WTDI]UPDTIM = time
              [F:WTDI]CODE   = [F:FAS5]POSCOD

              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "LNGDES", "501", [F:WTDI]CODE) From ATEXTRA
              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "SHODES", "501", [F:WTDI]CODE) From ATEXTRA

              Write [F:WTDI]
              If fstat and fstat <> 3
                Call ECR_TRACE("ATABDIV-501, Code =" - [F:WTDI]CODE - "File Error status =" - num$(fstat), 1) From GESECRAN
                GERRDOS = 1
              Endif

           Endif
           [F:WFAS]USRFLDA1  = [F:FAS5]POSCOD
         Endif
         #Fq-73917 Rûˋcupûˋration du BûÂtiment dans la TDI 502
         If [F:FAS5]PLC1 <> ""
           Read [F:WTDI]CODE=502;[F:FAS5]PLC1
           If fstat <> 0
              [F:WTDI]NUMTAB = 502
              [F:WTDI]CREUSR = GUSER
              [F:WTDI]CREDAT = date$
              [F:WTDI]CRETIM = time
              [F:WTDI]UPDUSR = GUSER
              [F:WTDI]UPDDAT = date$
              [F:WTDI]UPDTIM = time
              [F:WTDI]CODE   = [F:FAS5]PLC1

              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "LNGDES", "502", [F:WTDI]CODE) From ATEXTRA
              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "SHODES", "502", [F:WTDI]CODE) From ATEXTRA

              Write [F:WTDI]
              If fstat and fstat <> 3
                Call ECR_TRACE("ATABDIV-502, Code =" - [F:WTDI]CODE - "File Error status =" - num$(fstat), 1) From GESECRAN
                GERRDOS = 1
              Endif

              Write [F:WTDI]
           Endif
           [F:WFAS]USRFLDA2  = [F:FAS5]PLC1
         Endif
         #Fq-73917 Rûˋcupûˋration de l'ûˋtage dans la TDI 503
# FQ113414
#         If [F:FAS5]PLC2 <> ""
#           Read [F:W503]=503;[F:FAS5]PLC2
#           If fstat <> 0
#              [F:W503]NUMTAB = 503
#              [F:W503]CREUSR = GUSER
#              [F:W503]CREDAT = date$
#              [F:W503]CRETIM = time
#              [F:W503]UPDUSR = GUSER
#              [F:W503]UPDDAT = date$
#              [F:W503]UPDTIM = time
#              [F:W503]CODE   = [F:FAS5]PLC2
#              Write [F:W503]
#           Endif
#           [F:WFAS]USRFLDA3  = [F:FAS5]PLC2
#         Endif
         If [F:FAS5]PLC2 <> ""
           Read [F:WTDI]CODE=503;[F:FAS5]PLC2
           If fstat <> 0
              [F:WTDI]NUMTAB = 503
              [F:WTDI]CREUSR = GUSER
              [F:WTDI]CREDAT = date$
              [F:WTDI]CRETIM = time
              [F:WTDI]UPDUSR = GUSER
              [F:WTDI]UPDDAT = date$
              [F:WTDI]UPDTIM = time
              [F:WTDI]CODE   = [F:FAS5]PLC2

              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "LNGDES", "503", [F:WTDI]CODE) From ATEXTRA
              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "SHODES", "503", [F:WTDI]CODE) From ATEXTRA

              Write [F:WTDI]
              If fstat and fstat <> 3
                Call ECR_TRACE("ATABDIV-503, Code =" - [F:WTDI]CODE - "File Error status =" - num$(fstat), 1) From GESECRAN
                GERRDOS = 1
              Endif

           Endif
           [F:WFAS]USRFLDA3  = [F:FAS5]PLC2
         Endif
         #Fq-73917 Rûˋcupûˋration du Bureau dans la TDI 504
         If [F:FAS5]PLC3 <> ""
           Read [F:WTDI]CODE=504;[F:FAS5]PLC3
           If fstat <> 0
              [F:WTDI]NUMTAB = 504
              [F:WTDI]CREUSR = GUSER
              [F:WTDI]CREDAT = date$
              [F:WTDI]CRETIM = time
              [F:WTDI]UPDUSR = GUSER
              [F:WTDI]UPDDAT = date$
              [F:WTDI]UPDTIM = time
              [F:WTDI]CODE   = [F:FAS5]PLC3

              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "LNGDES", "504", [F:WTDI]CODE) From ATEXTRA
              Call MAJTEXTRA([F:WTDI]CODE, "ATABDIV", "SHODES", "504", [F:WTDI]CODE) From ATEXTRA

              Write [F:WTDI]
              If fstat and fstat <> 3
                Call ECR_TRACE("ATABDIV-504, Code =" - [F:WTDI]CODE - "File Error status =" - num$(fstat), 1) From GESECRAN
                GERRDOS = 1
              Endif

                Write [F:WTDI]
             Endif
             [F:WFAS]USRFLDA4  = [F:FAS5]PLC3
         Endif
         #Fq-73917>
         [F:WFAS]SRLNBR    = [F:FAS5]SERNUM
         [F:WFAS]ISSDAT    = [F:FAS5]SALDAT
         [F:WFAS]ISSDAT    = [F:FAS5]SALDAT
         If [F:WFAS]ISSDAT <> [0/0/0]
            # Type de sortie (vente ou rebut)
            #Fq-73916               Case [F:FAS5]SALREN
            #            When "C"     :  [F:WFAS]ISSTYP = GVML_TSVENTE
            #            When "R"     :  [F:WFAS]ISSTYP = GVML_TSREBUT
            #            When Default : # On a une construction du type <Motif de cession>_<Motif de mise au rebut>
            #             If instr(1,[F:FAS5]SALREN,"_") = 1
            #                # chaine de la forme _<Motif de mise au rebut> -> rebut
            #                [F:WFAS]ISSTYP = GVML_TSREBUT
            #             Else
            #                # chaine de la forme <Motif de cession>_ -> cession
            #                [F:WFAS]ISSTYP = GVML_TSVENTE
            #             Endif
            #Fq-73916  Endcase
            #Fq-73916 *Si en V5 SALREN est <> blanc >  ISSTYP  V6 = 1 - Vente
            #         *Si en V5 DILREN est <> blanc >  ISSTYP  V6 = 2 - Rebut
            #*
            If [F:FAS5]SALREN <> ""
               [F:WFAS]ISSTYP  = GVML_TSVENTE
            Else
               If [F:FAS5]DILREN <> ""
                  [F:WFAS]ISSTYP = GVML_TSREBUT
               Else
                  [F:WFAS]ISSTYP  = GVML_TSVENTE
               Endif #*Fq-73916

            Endif
         Endif
         [F:WFAS]ISSAMT    = [F:FAS5]SALPRI
         [F:WFAS]EXTISSFLG = 1               #*Fq-58253
         [F:WFAS]BUY       = [F:FAS5]BPC
         [F:WFAS]GAL(0)    = [F:FAS5]SALVAL
         [F:WFAS]VATREGDED = [F:FAS5]AMTVATRMN
         [F:WFAS]RVACMT    = [F:FAS5]RVAREN
         [F:WFAS]ACGCUR    = [F:CNX]CUR
         [F:WFAS]ASJCOE    = 1.
         [F:WFAS]TAXCOE    = 1.
         [F:WFAS]TAXCOEFLG = 1
         [F:WFAS]ADMCOE    = 1.
         [F:WFAS]DEDCOE    = 1.
         [F:WFAS]IVCVATRAT = 100           #*Fq-58253
         [F:WFAS]ACGETRNOT = [F:FAS5]AMTORI
         [F:WFAS]IVCSALISS = [F:FAS5]SALINVNUM
         [F:WFAS]STABILTYP = 1               #??? Fixe
         [F:WFAS]PURNAT    = 1               #??? Achat
         [F:WFAS]SALCLSDAT = [0/0/0]
         # Coeff de rûˋûˋvaluation 76
         [F:WFAS]R76COE = 1.
         # Plan de production
         [F:WFAS]PROPLN = ""
         Local Char     WDEFUOM(30)
         Call PARAM("","DEFUOM",WDEFUOM) From ADOVAL
         [F:WFAS]AASUOM    = WDEFUOM
         [F:WFAS]CMPSTA    = 1
         #Fq-73011 [F:WFAS]ENAFAS    = 1  # ==> "Inactif"
         [F:WFAS]ENAFAS    = 2  # ==> "Actif"
         [F:WFAS]CREORI    = 3  # ==> "Reprise"
         [F:WFAS]CREUSR    = GUSER
         [F:WFAS]CREDAT    = date$
         # Flag û  recalculer
         [F:WFAS]FLGCLC = 2
         [F:WFAS]FLGCNXCLC(0) = 2
         # Ecriture FAS
         [F:XFAS] = [F:WFAS]
         Write[WFAS]
         If (fstat)
            If fstat <> 3
               Call ECR_TRACE("FXDASSETS, Level 10 - File Error ="-num$(fstat),1) From GESECRAN
               GERRDOS = 1
            Else
               NBFAS5+=1
            Endif
         Else
            NBFAS5+=1
         Endif
         #FQ95065 -------------------------------
         #  Migration des factures rattachûˋes û  l'immobilisation V5
         Local Shortint WCPTRLIN  # FQ107357
         WCPTRLIN = 0             # FQ107357
         For [FIL5] Where FASCOD=[F:FAS5]FASCOD and FASNUM=[F:FAS5]FASNUM
            [F:WLOF] = [F:XFAS]
            [F:WLOF] = [F:FIL5]
            [F:WLOF]CREORI  = 3  # 3--> Reprise

            Gosub TRT_NUMLIN # FQ107357
            #FQ108370 [F:WLOF]CODLOF  = [F:FIL5]INVNUM
            [F:WLOF]CODLOF  = [F:FIL5]FASCOD
            # FQ107357 [F:WLOF]LINLOF  = [F:FIL5]INVLIN
            [F:WLOF]LINLOF  = WCPTRLIN
            [F:WLOF]BPRVCR  = [F:FIL5]BPSVCR
            If   [F:FIL5]PURDAT <> [0/0/0]
               [F:WLOF]DATVCR  = [F:FIL5]PURDAT
               [F:WLOF]DATIMP  = [F:FIL5]PURDAT
            Else
               [F:WLOF]DATVCR  = date$
               [F:WLOF]DATIMP  = date$
            Endif
            If   [F:WLOF]UOM = ""
                 [F:WLOF]UOM = WDEFUOM
            Endif
            If  [F:WLOF]TYPVCR = 0
               [F:WLOF]TYPVCR=1  # 1--> Facture par dûˋfaut
            Endif
            [F:WLOF]BPR = [F:FIL5]BPS
            Local Char    L_PARAM(30)
            Call PARAM("","DEFJOU",L_PARAM) From ADOVAL
            [F:WLOF]JOU = L_PARAM
            [F:WLOF]AMTNOTCUR = [F:FIL5]AMTNOTLIN
            [F:WLOF]FLGLIKAAS = 2
            [F:WLOF]AASREF     =  [F:XFAS]AASREF
            [F:WLOF]DES        =  [F:XFAS]AASDES1
            [F:WLOF]DES2       =  [F:XFAS]AASDES2
            [F:WLOF]CPMCREORI  =  1  # 1 --> Facture achat
            [F:WLOF]LIGORI     =  [F:FIL5]INVLIN
            [F:WLOF]TYPORI     = ""
            If  ([F:WLOF]CODLOF <> "") & ([F:WLOF]LINLOF > 0 )
               Write[WLOF]
               If (fstat)
                  If  fstat <> 3
                     Call ECR_TRACE("LAYOUTFAS, Level 19 - File Error ="-num$(fstat),1) From GESECRAN
                     GERRDOS = 1
                  Endif
               Else
                  NBFIL5+=1
               Endif
            Else # FQ107357
                # FQ108370
#               Call ECR_TRACE("LAYOUTFAS, Level 20 - CODLOF =" - [F:WLOF]CODLOF - "LINLOF = " -num$([F:WLOF]LINLOF),1) From GESECRAN
                Call ECR_TRACE("LAYOUTFAS, Level 20 - CODLOF = '" + [F:WLOF]CODLOF + "' / LINLOF = " -num$([F:WLOF]LINLOF), 1) From GESECRAN
            Endif
         Next #[FIL5]
         #FQ95065 END-------------------------------
      Next # [FAS5] bien suivant
      Filter[FAS5]
      # ------------------------------
      # <1 <<<<<<<<<<<
      $NEXT540
   Next # sociûˋtûˋ

  If !G_TRANSAC : Commit : Endif
  Call ECR_TRACE ("    "-num$(NBFAS5)-" CREATED FXDASSETS" , 0) From GESECRAN
  Call ECR_TRACE ("    "-num$(NBFIL5)-" CREATED LAYOUTFAS" , 0) From GESECRAN #FQ95065

  Close Local File [FAS5]
  Close Local File [FIL5] #FQ95065
  Close Local File [WFAS]
  Close Local File [XFAS] #FQ95065
  Close Local File [WLOF] #FQ95065
  Close Local File [WTDI]

End
#*************************************
#*************************************
# => FIN POUR    *- AMAJ_FXDASSETS -*
#*************************************
#*************************************
#########################################################

# FQ107357
$TRT_NUMLIN

  # rûˋinitialise le compteur si on change de code de dûˋpense, sinon incrûˋmente
  #FQ108370 If [F:WLOF]CODLOF = [F:FIL5]INVNUM
  If [F:WLOF]CODLOF = [F:FIL5]FASCOD
    WCPTRLIN += 1
  Else
    WCPTRLIN = 1
  Endif

  # contrûÇle si la clef est libre (et incrûˋmente jusqu'û  Ok)
  While WCPTRLIN < 10000
    Read [WLFC]LOF0 = [F:WLOF]CODLOF; WCPTRLIN
    If fstat
      Break
    Endif
    WCPTRLIN += 1
  Wend

  # remet û  0 si dûˋpassement (pas de write fait)
  If WCPTRLIN >= 10000
    WCPTRLIN = 0
  Endif

Return

Subprog  AMAJ_DEPREC (PDOSSIER)
#
# - Origine : AMAJ_DEPREC de FASMAJ25
#
# - Objet  : Mise û  jour de la table DEPREC
#
#
Value Char PDOSSIER

  Onerrgo ERREUR From DOSMAJ30

  # Table des sociûˋtûˋs û  migrer - TDIV 540  ---------------------------------------
  If clalev([F:W540]) : Close File  [W540] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W540]
  # Table des types amort - TDIV 591 ---------------------------------------
  If clalev([F:W591]) : Close File  [W591] : Endif
  Local File =[F:ADS]DOSSIER+".ATABDIV"   [W591]
  # Tables X3V5 ---------------------------------------
  If clalev([F:FAS5]) : Close File  [FAS5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXASSET"  [FAS5]

  If clalev([F:FDP5]) : Close File  [FDP5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXDEP"    [FDP5]

  If clalev([F:FWR5]) : Close File  [FWR5] : Endif
  Local File =[F:ADS]DOSSIER+".FIXWRO"    [FWR5]
  # Tables V6 ---------------------------------------
  If clalev([F:WCPY]) : Close File  [WCPY] : Endif
  Local File =[F:ADS]DOSSIER+".COMPANY"   [WCPY]

  If clalev([F:WCNX]) : Close File  [WCNX] : Endif
  Local File =[F:ADS]DOSSIER+".CONTEXT"   [WCNX]

  If clalev([F:WFIY]) : Close File  [WFIY] : Endif
  Local File =[F:ADS]DOSSIER+".FISCYEAR"  [WFIY]

  If clalev([F:WFAS]) : Close File  [WFAS] : Endif
  Local File =[F:ADS]DOSSIER+".FXDASSETS" [WFAS]

  If clalev([F:XDEP]) : Close File  [XDEP] : Endif
  Local File =[F:ADS]DOSSIER+".DEPREC"    [XDEP]

  If clalev([F:WDEP]) : Close File  [WDEP] : Endif
  Local File =[F:ADS]DOSSIER+".DEPREC"    [WDEP]

  #*FQ99396 Correpondences between Depreciation methods V5 and Depreciation methods V6
  If clalev([F:W600]) : Close File          [W600] : Endif  #* --> numtab = 600 : Migration Depreciation methods
  Local File =GDOSX3+".ATABDIV"             [W600]

  Local Integer  NBDEP
  Local Date     FIYSTRDAT2
  Local Date     FIYENDDAT2
  Local Date     PERENDDAT2
  Local Date     PERENDDAT2
  Local Integer  K
  Local Char     WDEPTYP
  Local Decimal  WEXE
  Local Decimal  WPER

  NB_MAJ     = 0
  If !G_TRANSAC : Trbegin [XDEP] : Endif

  For[W540] Where NUMTAB=540
      #>1 >>>>>>>>>>>>>>>>>>>>
      Read [WCPY]CPY0=[F:W540]A1
      If fstat : Goto NEXTD : Endif
      # Contexte comptable et Fiscal uniquement
      Read  [WCNX]CNX0=[F:WCPY]CPY;1
      If fstat
        Call ECR_TRACE("Context not found"-[F:WCPY]CPY-num$(fstat),1) From GESECRAN
        GERRDOS = 1
        Goto NEXTD
      Endif
      Local Date    WDEBEXE : Raz WDEBEXE
      Local Date    WFINEXE : Raz WFINEXE
      Local Date    WDEBPER : Raz WDEBPER
      Local Date    WFINPER : Raz WFINPER
      # Exercice courant / Pûˋriode courante
      Read [WFIY]FIY1=[F:WCPY]CPY;[F:WCNX]CNX;2
      If fstat
        Call ECR_TRACE("Current fiscal year not found"-[F:WCPY]CPY-num$([F:WCNX]CNX)-num$(fstat),1) From GESECRAN
        GERRDOS = 1
        Goto NEXTD
      Endif
      WDEBEXE = [F:WFIY]DATSTRFIY
      WFINEXE = [F:WFIY]DATENDFIY
      WDEBPER = [F:WFIY]DATSTRPER([F:WFIY]INDCURPER-1)
      WFINPER = [F:WFIY]DATENDPER([F:WFIY]INDCURPER-1)
      # => Dûˋfinition exercice et pûˋriode X3V5 d'aprû´s la date (sociûˋtûˋ)
      Call GETPERSOC([F:WCPY]CPY,1,WDEBPER,WEXE,WPER)
      For [WFAS]FAS0 Where CPY=[F:WCPY]CPY
        K = 0
        # FQ80070
        #K=instr(1,num$([F:WFAS]AASREF) ,"_")
        K=func FASMAJ30.INSTR_BACK([F:WFAS]AASREF, "_")
        # FQ80070
        If K = 0
          Call ECR_TRACE("Problem on fixed asset"-[F:WFAS]AASREF-"Please check this item",-1) From GESECRAN
          Goto NEXTFAS
        Endif

        Read [FAS5]FAS0=left$([F:WFAS]AASREF,K-1);val(right$([F:WFAS]AASREF,K+1))
        If fstat
          Call ECR_TRACE("X3V5 fixed asset"-left$([F:WFAS]AASREF,K-1)-right$([F:WFAS]AASREF,K+1)-" not found"-num$(fstat),1) From GESECRAN
          GERRDOS = 1
          Goto NEXTFAS
        Endif

        For I_PLN = 1 To [F:WCNX]NBPLC
          # DEBUT FQ81340
          #<-3 dûˋb plan-----------------
          Raz [F:XDEP]

          [F:XDEP]CPY        = [F:WFAS]CPY
          [F:XDEP]FCY        = [F:WFAS]FCY
          [F:XDEP]AASREF     = [F:WFAS]AASREF
          [F:XDEP]DPRPLN     = [F:WCNX]PLNCAA(I_PLN-1)

          # Recherche du plan X3 correpondant dans la table diverse 591
          Filter [W591] Where N1=[F:XDEP]DPRPLN
          Read [W591]CODE(1)=591
          Filter [W591]
          If fstat
            Call ECR_TRACE("Table 591 : no X3 plan found for"-mess([F:XDEP]DPRPLN,3101,1)-num$(fstat),1) From GESECRAN
            GERRDOS = 1
            Goto NEXT_I_PLN
          Endif
          WDEPTYP = [F:W591]CODE

          Read [FDP5]FDP0=[F:FAS5]FASCOD;[F:FAS5]FASNUM;WDEPTYP
          If fstat
            Call ECR_TRACE("X3 plan not found"-[F:FAS5]FASCOD-num$([F:FAS5]FASNUM)-WDEPTYP-" not found"-num$(fstat),1) From GESECRAN
            GERRDOS = 1
            Goto NEXT_I_PLN
          Endif

          [F:XDEP]STRDPRDAT  = [F:FAS5]DEPDAT
          [F:XDEP]BSEVAL     = [F:FAS5]AMTORI
          [F:XDEP]DPRBAS     = [F:FAS5]AMTDEP
          [F:XDEP]DPRCUM     = [F:FDP5]OLDWRO  #Fq-72770

          #*FQ99396 Case [F:FDP5]WROMOD
          #*FQ99396    When  "C"  :    [F:XDEP]DPM = "PR"
          #*FQ99396    When  "D"  :    [F:XDEP]DPM = "DF"
          #*FQ99396    When  "E"  :    [F:XDEP]DPM = "SO"
          #*FQ99396    When  "L"  :    [F:XDEP]DPM = "LP"
          #*FQ99396    When  "N"  :    [F:XDEP]DPM = "SA"
          #*FQ99396    When Default :  [F:XDEP]DPM = "SA"
          #*FQ99396 Endcase

          #*FQ99396 Matching table for depreciation methods (miscellaneous table nô¯600)
          Read [W600]CODE=600;[F:FDP5]WROMOD
          If fstat=0
              [F:XDEP]DPM = [F:W600]A1
          Else
              [F:XDEP]DPM = "SA"
          Endif
          #*FQ99396 END

          [F:XDEP]DPRDUR =  [F:FDP5]YEANBR
          [F:XDEP]DPRRAT =  ([F:FDP5]DEPRAT / 100 )
          If [F:XDEP]DPRRAT <> 0
            [F:XDEP]DPRRATFLG = 2
          Else
            [F:XDEP]DPRRATFLG = 1
          Endif
          [F:XDEP]PRATYP =  [F:FDP5]RNDTYP
          [F:XDEP]ALWCOD =   1 # Rû´gle particuliû´re = "Aucune"

          For  [FWR5] Where FASCOD = [F:FAS5]FASCOD and FASNUM = [F:FAS5]FASNUM and
&                           DEPTYP = WDEPTYP and FIY <= WEXE #Fq-72770 and PER <= WPER
            If [FWR5]FIY < WEXE
              ##Fq-72770 [F:XDEP]DPRCUM = [FDP5]OLDWRO
              [F:XDEP]DPRCUM += ( [F:FWR5]AMTWRO + [F:FWR5]AMTEXC ) #Fq-72770
              [F:XDEP]RSDVAL =  [F:FWR5]AMTRSDVAL   #*FQ-64731bis
            Else
              If [FWR5]FIY = WEXE
                If WPER > 1 and [FWR5]PER < WPER
                  [F:XDEP]PERCLOCUM +=  ([F:FWR5]AMTWRO    +  [F:FWR5]AMTEXC)
                  # Si pas de Rûˋûˋvaluation et pas de Dûˋprûˋciation ?
                  If ([F:FWR5]AMTREV = 0 and [F:FWR5]AMTDER = 0)
                  [F:XDEP]PERCLOCUMI +=  ([F:FWR5]AMTWRO    +  [F:FWR5]AMTEXC) #*FQ107220
                  [F:XDEP]PERCLOCUMT +=  ([F:FWR5]AMTWRO    +  [F:FWR5]AMTEXC) #*FQ107220
                  Endif
                  [F:XDEP]ENDDPE    +=  ([F:FWR5]AMTWRO    +  [F:FWR5]AMTEXC)
                Else
                  [F:XDEP]ENDDPE    +=  ([F:FWR5]AMTWRO    +  [F:FWR5]AMTEXC)
                  [F:XDEP]RSDVAL     =  [F:FWR5]AMTRSDVAL   ##FQ-64731
                Endif
              Endif
            Endif
          Next   #FQ105293

          # On positionne le flag de forûÏage du cumul d'amortissement û  Oui pour les plans dont la date de dûˋbut
          # d'amortissement est antûˋrieure û  la date de dûˋbut d'exercice
          #FQ105293 dûˋplacûˋ en dehors de la boucle car concerne aussi des biens qui n'ont pas d'enreg FIXWRO car
          #FQ105293 dûˋjû  complû´tement amortis en V5
          If ( [F:XDEP]STRDPRDAT < WDEBEXE)
            [F:XDEP]DPRCUMFLG = 2
            Else
              [F:XDEP]DPRCUMFLG = 1
            Endif

     # Next FQ105293

          [F:XDEP]DEPSTA     = GVML_SCNOCAL
          [F:XDEP]PRATYP     = 0
          [F:XDEP]EXECLOCUMI = [F:XDEP]DPRCUM #Fq-72770
          [F:XDEP]EXECLOCUMT = [F:XDEP]DPRCUM #Fq-72770
          [F:XDEP]CNX        = [F:WCNX]CNX
          [F:XDEP]UOM        = GDEFUOM
          [F:XDEP]FIYSTRDAT  = WDEBEXE
          [F:XDEP]PERREFCLC  = WDEBEXE   #*FQ107220
          [F:XDEP]PERREFCLCI = WDEBEXE   #*FQ107220
          [F:XDEP]PERREFCLCT = WDEBEXE   #*FQ107220
          [F:XDEP]FIYENDDAT  = WFINEXE
          [F:XDEP]PERSTRDAT  = WDEBPER
          [F:XDEP]PERENDDAT  = WFINPER
          [F:XDEP]DEPSTA     = GVML_SCNOCAL  #Fq-74731
          [F:XDEP]FLGMIG     = 2
          Write [XDEP]
          #If fstat <> 0 and fstat <> 3  : # FQ80070
          If fstat <> 0
            Call ECR_TRACE("DEPREC"-[F:XDEP]AASREF-num$([F:XDEP]DPRPLN)-[F:XDEP]FIYENDDAT-[F:XDEP]PERENDDAT-num$(fstat),1) From GESECRAN
            GERRDOS = 1
          Else
            NBDEP += 1
          Endif
          $NEXT_I_PLN
          #<3 fin plan-----------------
          # FIN FQ81340
        Next I_PLN
        #<2 <<<<<<<<<<<<<<<<<<<<
        $NEXTFAS
      Next # FAS
      #<1 <<<<<<<<<<<<<<<<<<<<
      $NEXTD
  Next # sociûˋtûˋ

  If !G_TRANSAC : Commit : Endif
  Call ECR_TRACE ("    "-num$(NBDEP)-" CREATED DEPREC" , 0) From GESECRAN

  #<1 <<<<<<<<<<<<<<<<<<<<

  Close Local File [XDEP]
  Close Local File [WDEP]
  Close Local File [WFIY]
  Close Local File [WFAS]
  Close Local File [WCPY]
  Close Local File [WCNX]

End


# FQ104360
Subprog  AMAJ_LAYOUTFAS (PDOSSIER)
#
# - Object  : FLGDETEXP flag from LAYOUTFAS
#
#
Value Char PDOSSIER

  If clalev([F:WLOF]) : Close File  [WLOF] : Endif
  Local File =[F:ADS]DOSSIER+".LAYOUTFAS"   [WLOF]

  If !G_TRANSAC
    Trbegin [WLOF]
  Endif

  Update [WLOF] Where FLGDETEXP = 0 With FLGDETEXP = 2

  If !G_TRANSAC
    Commit
  Endif
  Close File  [WLOF]

End

# FQ80070 - recherche d'une sous-chaine dans une chaine û  partir de la fin
Funprog INSTR_BACK(PSTRING, PSUBSTRING)
Value Char PSTRING
Value Char PSUBSTRING

  If len(PSTRING) < len(PSUBSTRING) : End 0 : Endif

  Local Integer RANG, N_I

  RANG = 0

  For N_I = len(PSTRING)-len(PSUBSTRING)+1 To 1 Step -1
    If seg$(PSTRING, N_I, N_I+len(PSUBSTRING)-1) = PSUBSTRING
      RANG = N_I
      Break
    Endif
  Next N_I

End RANG

#*************************************
#*************************************
# => FIN POUR    *- AMAJ_DEPREC -*
#*************************************
#*************************************
#============================================
#######Fq-63364##########################################################################
Subprog GETPERSOC(SOC,TYPLED,DAT,EXE,PER)

Value    Char    SOC
Value    Integer TYPLED
Value    Date    DAT
Variable Decimal EXE
Variable Decimal PER

$SETPER
If clalev([F:GCM]) : Close File  [GCM] : Endif
If clalev([F:GCM])=0 : Local File =[F:ADS]DOSSIER+".GACM"   [GCM] : Endif
If clalev([F:PER]) : Close File  [PER] : Endif
If clalev([F:PER])=0 : Local File =[F:ADS]DOSSIER+".PERIOD" [PER] : Endif
Raz EXE, PER

If TYPLED<1 : End : Endif
# Si Rûˋfûˋrentiel automatique, il faut recherche les exercices/pûˋriodes du rûˋfûˋrentiel saisi.
# Issue FQ113273
#Local Char    MODELE(GLONGCM)
#Call SETGCM(SOC,MODELE)
Local Char  MODELE
Local Char  RCOA
Local Char  RGCM
Gosub INIT_RGCM_RCOA
MODELE=RGCM
# End issue FQ113273

Call LEC_GCM(MODELE)
If [F:GCM]CFMAUT(TYPLED-1)=2
 TYPLED = [F:GCM]ORILEDTYP(TYPLED-1)
Endif

If DAT>=[F:PER]PERSTR & DAT<=[F:PER]PEREND & SOC=[F:PER]CPY & TYPLED=[F:PER]LEDTYP
 EXE = [F:PER]FIYNUM
 PER = [F:PER]PERNUM
 End
Endif
For [PER]PER0 Where CPY=SOC & PERSTR<=DAT & PEREND>=DAT & LEDTYP=[L]TYPLED
 EXE = [F:PER]FIYNUM
 PER = [F:PER]PERNUM
Next
End
#######Fq-63364##########################################################################
## Modû´le comptable pour une sociûˋtûˋ ou un site
########################################################################
Subprog SETGCM(SOCIETE,MODELE)
Value    Char    SOCIETE   : # Sociûˋtûˋ ou site
Variable Char    MODELE    : # Modû´le comptable
Local Integer ISOC, ISITE
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(SOCIETE,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Endif
MODELE = GGCMSOC(ISOC)
End
#######Fq-63364##########################################################################
Subprog LEC_GCM(MODELE)
Value Char MODELE
fstat = 0
If [F:GCM]GCM<>MODELE
 Read [GCM]GCM0 = MODELE
Endif
End
#######FQ113273##########################################################################
$INIT_RGCM_RCOA
# Issue FQ113273
If clalev([F:XADW])<> 0 : Close File  [XADW] : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [XADW]
Local Char WGACM(30)
Raz WGACM
Read [XADW]ADW0 = "";"";"MIGGCM"
If !fstat : WGACM= [F:XADW]VALEUR : Endif

If clalev([F:RGCM])<> 0 : Close Local File [RGCM] : Endif
If clalev([F:RLED])<> 0 : Close Local File [RLED] : Endif
Local File =[F:ADS]DOSSIER+".GACM" [RGCM]
Local File =[F:ADS]DOSSIER+".GLED" [RLED]
Read [RGCM]GCM0 = WGACM
If !fstat : RGCM = [F:RGCM]GCM : Endif
Read [RLED]LED0 = [F:RGCM]LED(0)
If !fstat : RCOA = [F:RLED]COA : Endif
Close File [RGCM]
Close File [RLED]
Return

