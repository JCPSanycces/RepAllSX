#X3-100003 8/6/2018
Subprog C_DEFORDIND(VALEUR)
Variable Integer VALEUR()
If VALEUR=2
 Local Integer I, NOL
 NOL = nolign-1
 I = find(VALEUR,[M]DEFORDIND(0..NOL-1),[M]DEFORDIND(NOL+1..dim([M]DEFORDIND)-1))
 If I
  If I>NOL
   I += 1
  Endif
  GERR = 1
  GMESSAGE = func AFNC.MES1(mess(247,125,1),num$(I)) : # L'index cluster est déjà défini sur la ligne $1$
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_DEFORDIND(VALEUR)
Variable Integer VALEUR
If GADONIX <> 2 mkstat=2 Endif
End

Subprog AM_ORDIND(VALEUR)
Variable Integer VALEUR
If VALEUR=[V]CST_AYES & [M:ATB3]ORDINDSTA<[V]CST_AYES & GTYPDBA=2
  [M:ATB3]ORDINDSTA=[V]CST_AYES
  Affzo [M:ATB3]ORDINDSTA
Endif
End
#X3-100003
#X3-111764 10/5/2018
Subprog C_ORDINDSTA(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  If find(2,[M:ATB3]DEFORDIND(0..dim([M]DEFORDIND)-1))=0 & find(2,[M:ATB3]ORDIND(0..dim([M]ORDIND)-1))=0
    GERR = 1
    GMESSAGE = mess(362,139,1) : #Must have a clustered index selected in order to activate
    mkstat=2 : End
  Endif
Endif
End
