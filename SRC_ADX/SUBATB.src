#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ATB",GBIDC1,GBIDC2) From GOBJET

End

#--------------------------------------------------------#
$ACTION
If dim([L]PSUBT)<=0
 Local Integer PSUBT
 Call EXISTE_ADX("","","SUBATBB",PSUBT) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "EXEBOUT"     : Gosub EXEBOUT
 When "STATUT"      : Gosub STATUT
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "INICRE"      : Gosub INICRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "INIMOD"      : Gosub INIMOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "INIPAG"      : Gosub INIPAG
 When "ABANDON"     : Gosub ABANDON
 When "RAZDUP"      : Gosub RAZDUP
 When "APRES_MOD" : Gosub APRES_MOD
 When "APRES_CRE" : Gosub APRES_CRE
Endcase
If PSUBT
 Gosub ACTION From SUBATBB
Endif
Return

#----------------------------------------------------------#
$OUVRE
Local Char    IND(1)
Local Integer I, J, K, ERR, AUDIT , OKTRT
Local Integer NO_LIGNE
Local Integer TYP_FIC, TABSUP, FERME_TABSUP, STAT
Local Char    PROGINI(GLONADC), TRTINI(GLONADC), FICTRT(GDIMFIC), SUF(5)
Local Char    MESSA(250)
Local Mask AFFCLOB [AFF]
If clalev([F:AP2])=0  : Local File AMSKPAR [AP2]  : Endif
If clalev([F:ATB2])=0 : Local File ATABLE  [ATB2] : Endif
If clalev([F:ATZ2])=0 : Local File ATABZON [ATZ2] : Endif
If GLIAISON<>"" or GLIAISON(1)<>""
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
 Local Integer WNB0 , WNB1
 Local Schar    WLNK0(10)(1..500) , WLNK1(10)(1..500)
Endif
FERME_TABSUP = 0
TRTINI = "WWINI"
GFMT = "20X"
Gosub SET_CDBA
AUDIT = (GAUDIT=2 & dim([M:ATB4]NBCHP)>0)
If AUDIT
 If clalev([F:ATA])=0 : Local File ATABAUD [ATA] : Endif
Endif
Gosub SET_FLDSYS
Gosub SET_TABSYS
Return

#----------------#
$SET_FLDSYS
Local Integer NBFLD , MAXFLD
MAXFLD = 5
Local Char    FLDSYS(GLONAVA)(1..MAXFLD) , TYPFLD(GLONATY)(1..MAXFLD)
Local Char    LNKFLD(GLONATB)(1..MAXFLD)
Local Integer INTFLD(1..MAXFLD) , NBFLD , ANUFLD(1..MAXFLD)
NBFLD = 0
While NBFLD<dim(FLDSYS)
 NBFLD += 1
 Case NBFLD
  When 1 : FLDSYS(NBFLD) = "CREDATTIM" : TYPFLD(NBFLD) = "ADATIM"
  When 2 : FLDSYS(NBFLD) = "UPDDATTIM" : TYPFLD(NBFLD) = "ADATIM"
  When 3 : FLDSYS(NBFLD) = "AUUID"     : TYPFLD(NBFLD) = "AUUID"
  When 4 : FLDSYS(NBFLD) = "CREUSR"    : TYPFLD(NBFLD) = "AUS" : LNKFLD(NBFLD) = "AUTILIS" : ANUFLD(NBFLD) = 4
  When 5 : FLDSYS(NBFLD) = "UPDUSR"    : TYPFLD(NBFLD) = "AUS" : LNKFLD(NBFLD) = "AUTILIS" : ANUFLD(NBFLD) = 4
 Endcase
 If clalev([F:ATY])>0
  #119254
  #Call LECTURE("ATY",TYPFLD(NBFLD),"") From CONTOBJ
  Read [ATY]CODTYP=TYPFLD(NBFLD)
  If !fstat
    [L]INTFLD(NBFLD) = [F:ATY]INTITTYP
  Endif
 Endif
Wend
Return

#----------------#
$SET_TABSYS
Local Char    TABSYS(GLONATB)(1..20)
Local Integer NBSYS
NBSYS = 0
NBSYS += 1 : TABSYS(NBSYS) = "APLLCK"
NBSYS += 1 : TABSYS(NBSYS) = "APLCOM"
NBSYS += 1 : TABSYS(NBSYS) = "AUDITH"
NBSYS += 1 : TABSYS(NBSYS) = "AUDITL"
NBSYS += 1 : TABSYS(NBSYS) = "AJSAUDIT"
NBSYS += 1 : TABSYS(NBSYS) = "AUDITBI"
Return

#----------------#
$SET_CDBA
Local Integer CDBA , KDBA : # Uniquement pour le contrôle de la taille d'un enregistrement
Local File ADOSSIER [ADS_]
Read [ADS_]DOSSIER = nomap
If !fstat
 CDBA = [F:ADS_]CODDBA
 If CDBA<=0 : CDBA = 1 : Endif
Else
 CDBA = 1
Endif
Close Local File [ADS_]
If GADONIX=2
 KDBA = 2 : # Pour contrôler par rapport à SQL unicode
Else
 Case GTYPDBA
  When 1 : # Oracle
   KDBA = val(getenv$("STUSIZE"))
   If KDBA<=0 : KDBA = 2 : Endif
  When 2 : # Sql
   Case CDBA
    When 1 : # Ascii
     KDBA = 1
    When 2 : # Unicode
     KDBA = 2
    When Default
     KDBA = 1
   Endcase
 Endcase
Endif
Return

#----------------#
$OUVRE_FIC
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:AP2])=0 : Local File AMSKPAR [AP2] : Endif
If GLIAISON<>"" or GLIAISON(1)<>""
 If clalev([F:ALI])=0 : Local File ALINK   [ALI] : Endif
Endif
Gosub OUVOBJ From GOBJET
Gosub OUVRE  From WOATB
If AUDIT
 If clalev([F:ATA])=0 : Local File ATABAUD [ATA] : Endif
Endif
Return

#--------------------------#
$INIPAG
Affzo 10
Return

#--------------------------#
$RAZDUP
Call DUPLI_PAR([M]CODFIC,zc) From PARMNT
Return

#--------------------------#
$ABANDON
If REP="D"
 Look [ATB]CODFIC = [M]CODFIC
 If fstat
  Delete [AMP] Where TYPAFF=2 & CODAFF=[M]CODFIC
  If fstat=1  : GOK=-1 : Call RSTA("AMP",[M]CODFIC) From GLOCK : Return : Endif
 Endif
Else
 Call VERIF_ACT_ATB([M]CODFIC) From PARMNT
Endif
Return

#----------------------------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR=0 or REP="M" or (!VERROU & (dim([L]MLOCK)<=0 or ![L]MLOCK))
 Call VIREBOUT(CHAINE,"V123") From GOBJET : # Validation, Traitement, Copie, Raz
Elsif GCONSULT
 Call VIREBOUT(CHAINE,"123") From GOBJET : # Traitement, Copie, Raz
Endif
## Il ne faut pas pouvoir valider une table "système X3" dans un dossier autre que le superviseur
If [F:ATB]TYPFIC=3 & nomap<>GDOSX3 & GADONIX<>2
 Call VIREBOUT(CHAINE,"V13") From GOBJET
Endif
If CLECUR
 CHMEN += "45" : # Infos/Visu source
 If filinfo(filpath("FIL",CLECUR1,"fde"),0)>0
  CHMEN += "6" : # Maintenance des tables
 Endif
Endif
Return

#----------------------------------------------------------#
$APRES_CHOI
# Verrou avant utilisation d'un bouton "validant"
If REPONSE>=GSTABOU & REPONSE<=GSTABOU+NBTEX
 If dim([L]MLOCK)>0 & [L]MLOCK
  Gosub VERROU From GOBJET
  If !VERROU
   Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
   REPONSE = 0 : Return
  Endif
 Endif
Endif
Case REPONSE
 When GSTAANU
  If filinfo(filpath("FIL",CLECUR1,"fde",0),0)>=0
   OK=2 : Call OUINON(mess(93,123,1),OK) From GESECRAN
   If OK<>2 : REPONSE = 0 : Endif
  Endif
 When GSTAPRG, GSTASVG, GSTASEL, GSTARAF, GSTATIR, GSTASUI, GSTAPRE, GSTALAS, GSTAFIR
  # mb 23.5.1 Après un close le fillbox plante
  If FERME_TABSUP : REPONSE = 0 : Endif
Endcase
Return

#----------------------------------------------------------#
$EXEBOUT
Gosub SET_TABSUP
Case REP
 When "V"
  Gosub VERIF
  If OK
   # C'est obligatoire pour les tables Superviseur ... mais on perd les listes de gauche !!!
   If TABSUP
    Close File : # Le Close Local File ne ferme les tables 'non fermées' des trt appelant
    FERME_TABSUP = 1
   Endif
   Call VALDIC From VALDIC
   Gosub EXE_TRTINI
   If nomap=GDOSX3 & find(CLECUR1,"ADOSSIER","ADOSDIM","ADOSACT","ADOSSOL")
    If clalev([F:ADS])>0 : Close Local File [ADS] : Endif
    If clalev([F:ADD])>0 : Close Local File [ADD] : Endif
    If clalev([F:ADA])>0 : Close Local File [ADA] : Endif
    If clalev([F:ADE])>0 : Close Local File [ADE] : Endif
    Local File ADOSSIER [ADS] , ADOSACT [ADA] , ADOSDIM [ADE] , ADOSSOL [ADD]
    For [ADS]
     If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
      Onerrgo RIEN
      Call CREPAR From DOSDIV : # Régénération des fichiers PARAM.ini
      Onerrgo
     Endif
    Next ADS
    Close Local File [ADS] , [ADA] , [ADE] , [ADD]
   Endif
   If TABSUP
    Gosub OUVRE_FIC
    REAFF_BOITE = 1
    REPONSE = GSTAEND
   Endif
   Read [ATB]CODFIC = CLECUR1
   Call OUVRE_TRACE("") From LECFIC
   Call GENVUE(nomap) From DOSVUE
   Call FERME_TRACE From LECFIC
   Call EFFACE(filpath("TRA",GTRACE,"tra"),STAT) From ORDSYS
   Raz GTRACE , GERRTRACE
  Endif
 When "1"
  Gosub SAI_TRTINI
 When "3"
  If filinfo(filpath("FIL",CLECUR1,"fde",0),0)>=0
   If TABSUP
    Close File : # Le Close Local File ne ferme les tables 'non fermées' des trt appelant
    FERME_TABSUP = 1
    Call RAZFIC(CLECUR1,[M:ATB1]FLG130) From VALDIC
    Gosub OUVRE_FIC
    REAFF_BOITE = 1
    REPONSE = GSTAEND
   Else
    Call RAZFIC(CLECUR1,[M:ATB1]FLG130) From VALDIC
   Endif
  Endif
Endcase
Return

$RIEN
Resume

#-----------------------------------------------------#
$FIN_ACTION
# Déverrou après utilisation d'un bouton "validant"
If REPONSE>=GSTABOU & REPONSE<=GSTABOU+NBTEX
 If dim([L]MLOCK)>0 & [L]MLOCK
  Gosub DEVERROU From GOBJET
  Call SET_IMAGE(AIMGLCK) From GESECRAN
 Endif
Endif
Return

#----------------------------------------------------------#
$APRES_MODIF
Case zoncou
 When "FICCFG"
  If !VERROU
   Gosub INICFG
   Call LIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
  Endif
Endcase
Return

$APRES_CRE
$APRES_MOD
# On affiche tout bien à la fin
If !GIMPORT
 Gosub RELIT From GOBJSUB
Endif
Return

#----------------#
$SET_TABSUP
TABSUP = 0
If find(CLECUR1,"AOBJTXT","ALSTRD","AWINDOW","ACCES","APLLCK","ATEXTRA","ATEXTE","ACTIV")
 # Tables ouvertes dans GOBJET
 TABSUP = 1
Elsif find(CLECUR1,"AFONCTION","AFCTFCY","AFCTPRF","AFCTFCT")
 # Tables ouvertes dans EXEFNC
 TABSUP = 1
Else
 # Tables ouvertes dans la gestion de l'objet ATB
 If CLECUR1="ATABLE"
  TABSUP = 1
 Else
  For [AOT] Where ABREV="ATB"
   If find([F:AOT]TABFIC,CLECUR1,"ATABLE")
    TABSUP = 1 : Break
   Endif
  Next AOT
 Endif
Endif
Return

#----------------------------------------------------------#
$STATUT
Case BOUT
 When "4" : Gosub INFOS
 When "5" : Gosub VISU_SRF
Endcase
Return

#----------------------------------------------------------#
$VISU_SRF
If filinfo(filpath("FIL",[M:ATB0]CODFIC,"srf",nomap),0)>0
 Openi filpath("FIL",[M:ATB0]CODFIC,"srf",nomap) Using [FI_]
 Iomode adxirs "" Using [FI_]
 Iomode adxifs "" Using [FI_]
 Iomode adxium GUTF8 Using [FI_]
 Rdseq [M:AFF]AFFCLB Using [FI_]
 Openi Using [FI_]
Else
 [M:AFF]AFFCLB = filpath("FIL",[M:ATB0]CODFIC,"srf",nomap)-":"-mess(101,100,1) : # Fichier inexistant
Endif
Call DIALWIN(OK,mess(258,139,1),"AFFCLOB") From GESECRAN : # Visualisation source
Return

#----------------------------------------------------------#
$SAI_TRTINI
PROGINI = TRTINI+[M:ATB0]ABRFIC
FICTRT = filpath("TRT",nomap+"."+PROGINI,"src")
If filinfo(FICTRT,0)<0
 Openo FICTRT,0 Using [AINI]
 Iomode adxifs ""       Using [AINI]
 Iomode adxirs chr$(10) Using [AINI]
 Iomode adxium GUTF8    Using [AINI]
 # Initialisation zones du fichier
 Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"-mess(16,139,1)-[M:ATB0]CODFIC Using [AINI]
 Wrseq "##################################################" Using [AINI]
 Wrseq "#"-mess(16,139,1)-[M:ATB0]CODFIC Using [AINI]
 Wrseq "##################################################" Using [AINI]
 Wrseq "$INIZON" Using [AINI]
 Wrseq "# Example :" Using [AINI]
 Wrseq "# Local integer I" Using [AINI]
 Wrseq "# For I=0 to dim([F]FIELDNAME)-1" Using [AINI]
 Wrseq "#  [F]FIELDNAME(I) = date$" Using [AINI]
 Wrseq "# Next I" Using [AINI]
 Wrseq "Return" Using [AINI]
 Wrseq "" Using [AINI]
 Wrseq "$OUVRE" Using [AINI]
 Wrseq "If clalev([F:"+[M:ATB0]ABRFIC+"])>0 : "; Using [AINI]
 Wrseq "Close Local File [F:"+[M:ATB0]ABRFIC+"] : Endif" Using [AINI]
 Wrseq "Local File"-[M:ATB0]CODFIC-"["+[M:ATB0]ABRFIC+"]" Using [AINI]
 Wrseq "Return" Using [AINI]
 Wrseq "" Using [AINI]
 Wrseq "$DEFAUT" Using [AINI]
 Wrseq "Default File ["+[M:ATB0]ABRFIC+"]" Using [AINI]
 Wrseq "Return" Using [AINI]
 Wrseq "" Using [AINI]
 Wrseq "$FERME" Using [AINI]
 Wrseq "Close Local File ["+[M:ATB0]ABRFIC+"]" Using [AINI]
 Wrseq "Return" Using [AINI]
 Openo Using [AINI]
Endif
Local Char VALPAR(GLONADC)
Call S_AFF_CHAR(VALPAR,PROGINI,"","ADOTRT","") From GACTION
Return

$EXE_TRTINI
PROGINI = TRTINI+[M:ATB0]ABRFIC
Call EXISTE_ADX("",nomap,PROGINI,OKTRT) From ORDSYS
If OKTRT>0
 Gosub OUVRE From =PROGINI
 Call DEBTRANS From GLOCK
 Gosub TR_INI
 Gosub FERME From =PROGINI
Endif
Return

$TR_INI
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGINI
 For [F]
  Gosub INIZON From =PROGINI
  Rewrite [F]
  If fstat
   GOK=0 : Call FSTA([M:ATB0]ABRFIC) From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_INI : Endif
Commit
Return

$AB_TR_INI
Rollback
Return

$ROLL_TR_INI
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_INI : Endif

$SUP_TRTINI
PROGINI = TRTINI+[M:ATB0]ABRFIC
FICTRT = filpath("TRT",nomap+"."+PROGINI,"src",0)
If filinfo(FICTRT,0)>=0
 Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
Call EXISTE_ADX("",nomap,PROGINI,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX("",nomap,PROGINI,STAT) From ORDSYS
Endif
Return

#----------------------------------------------------------#
$VERIF_CRE
Read [AVW]AVW0=[M]CODFIC
If !fstat
 Call ERREUR(VALEUR-":"-mess(74,139,1)) From GESECRAN : # Il existe déjà une vue du même nom
 OK = 0 : Return
Endif
If func DOSBASE.ISBASE_RESERVED_WORDS([M]CODFIC)
 Call ERREUR(func AFNC.MES1(mess(272,133,1),[M]CODFIC)) From GESECRAN : # $1$ est un mot réservé aux bases de données
 OK = 0 : Return
Endif
Gosub VERIF
Return

#----------------------------------------------------------#
$VERIF_MOD
If [M]CODFIC="APLLCK"
 # La modification de la structure de la table APLLCK peut entrainer des dysfonctionnements
 # Voulez-vous continuer ?
 MESSA = mess(154,125,1)+"\"+mess(205,100,1)
 Call AVERTIR(MESSA,OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif
Gosub VERIF
Return

#----------------------------------------------------------#
$VERIF
If [M:ATB2]NBZONE=0
 Call ERREUR(mess(28,176,1))From GESECRAN
 # La table ne comporte aucune zone
 OK = 0 : Return
Endif
If [M:ATB3]NBINDEX=0
 Call ERREUR(mess(23,176,1)) From GESECRAN
 # La table ne comporte pas de clé primaire
 OK = 0 : Return
Endif
If [M:ATB1]INTIT<>"" & !find([M:ATB1]INTIT,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(107,123,1)) From GESECRAN : # Le champ intitulé n'est pas référencé
 OK = 0 : Return
Endif
If [M:ATB1]INTITC<>"" & !find([M:ATB1]INTITC,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(210,123,1)) From GESECRAN : # Le champ intitulé court n'est pas référencé
 OK = 0 : Return
Endif
#91088/5
If [M:ATB1]SYMBOL<>"" & !find([M:ATB1]SYMBOL,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(316,123,1)) From GESECRAN : # La colonne symbole n'est pas référencée
 OK = 0 : Return
Endif
If [M:ATB1]COLFMT<>"" & !find([M:ATB1]COLFMT,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(317,123,1)) From GESECRAN : # La colonne symbole n'est pas référencée
 OK = 0 : Return
Endif
If [M:ATB1]COLLNG<>"" & !find([M:ATB1]COLLNG,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(318,123,1)) From GESECRAN : # La colonne symbole n'est pas référencée
 OK = 0 : Return
Endif
If [M:ATB1]COLDEC<>"" & !find([M:ATB1]COLDEC,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(319,123,1)) From GESECRAN : # La colonne symbole n'est pas référencée
 OK = 0 : Return
Endif
#
If dim([M:ATB1]FLGLEG)>0 & [M:ATB1]FLGLEG=2 & !find(2,[M:ATB2]CHPLEG(0..[M:ATB2]NBZONE-1))
 Call ERREUR(mess(240,133,1)) From GESECRAN : # La table ne comporte pas de champ LEG
 OK = 0 : Return
Endif
If dim([M:ATB1]FLGLEG)>0 & [M:ATB1]FLGLEG<>2
 For [ATB2] Where FLGLEG=2
  For [ATZ2] Where CODFIC=[F:ATB2]CODFIC & CHPLEG=2
   If [ATZ2]LIEN=[M:ATB0]CODFIC & [ATZ2]LIEN<>"ATABDIV"
    # Table utilisée en lien pour la gestion par législation de la table : TABLE ( Champ CHAMP )
    Call ERREUR(mess(247,133,1)-":"-[F:ATB2]CODFIC-"("-mess(36,124,1)-[F:ATZ2]CODZONE-")") From GESECRAN
    OK = 0 : Break
   Endif
  Next ATZ2
 Next ATB2
Endif
If !OK : Return : Endif
For I=0 To [M:ATB3]NBINDEX-1
 Call VERF_INDEX([M:ATB3]DESCRIPT(I),I,MESSA,ERR)
 Case ERR
  When 1 : Call ERREUR(MESSA) From GESECRAN : OK = 0 : Break
  When 2 : Call AVERTIR(MESSA,OK) From GESECRAN : If OK<>2 : OK = 0 : Break : Endif
 Endcase
Next I
If !OK : Return : Endif
For [ATI] Where CODFIC=[M:ATB0]CODFIC
 If !find([F:ATI]CODIND,[M:ATB3]CODIND)
  For [AOB] Where NOMFIC=[M:ATB0]CODFIC
   If [F:AOB]SELCLE=[F:ATI]CODIND
    Call ERREUR([F:AOB]SELCLE-":"-mess(130,126,1)-[F:AOB]ABREV) From GESECRAN
    # Index utilisé par l'objet
    OK = 0 : Break 2
   Endif
   For [AWI]AWI1 Where OBJ=[F:AOB]ABREV
    Read [AWB]AWB0 = [F:AWI]WIN
     For I=0 To [F:AWB]NBLIS-1
      If [F:AWB]CLELIS(I)=[F:ATI]CODIND
       Call ERREUR([F:AWB]CLELIS(I)-":"-mess(105,133,1)-[F:AWI]WIN) From GESECRAN
       # Index utilisé par la fenêtre
       OK = 0 : Break 3
      Endif
     Next I
   Next AWI
  Next AOB
 Endif
Next ATI
If !OK : Return : Endif
Call VERF_DESCRIPT(OK)
If !OK : Return : Endif
If [M:ATB1]GENTRA=2 & !find("AXX",[M:ATB2]CODTYP) & !find("AX1",[M:ATB2]CODTYP)
&                   & !find("AX2",[M:ATB2]CODTYP) & !find("AX3",[M:ATB2]CODTYP)
 Call ERREUR(mess(11,127,1)) From GESECRAN : # Pas de texte traduisible dans cette table
 OK = 0 : zonsui = "[ATB1]GENTRA" : Return
Endif
Return

Subprog VERF_DESCRIPT(OK)
Variable Integer OK
Local Integer L
OK = 1
For L=0 To [M]NBINDEX-1
 If [M]DESCRIPT(L)<>""
  For [ANX]ANX1 Where TABLE=[M]CODFIC & FLACT=2
   If [M]DESCRIPT(L)=[F:ANX]DESCRIPT
    # Composantes de clé déjà saisies pour l'index
    If dim([F:ANX]COMMENT)>0 & [F:ANX]COMMENT<>""
     Call ERREUR(mess(21,176,1)-[F:ANX]COMMENT) From GESECRAN
    Else
     Call ERREUR(mess(21,176,1)-func AFNC.TEXTRA("AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND)) From GESECRAN
    Endif
    OK = 0 : Break 2
   Endif
  Next ANX
 Endif
Next L
End

#----------------------------------------------------------#
$INICRE
$INIMOD
# Rajout des champs Syracuse
#93128
#If !find([M:ATB0]CODFIC,TABSYS(1..NBSYS))
If !find([M:ATB0]CODFIC,TABSYS(1..NBSYS)) & [M:ATB1]FLG130<>2
 K = [M:ATB2]NBZONE
 For I=1 To dim(FLDSYS)
  If FLDSYS(I)<>"" & !find(FLDSYS(I),[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
   [M:ATB2]NBZONE += 1
   [M:ATB2]CODZONE([M:ATB2]NBZONE-1) = FLDSYS(I)
   [M:ATB2]CODTYP([M:ATB2]NBZONE-1)  = TYPFLD(I)
   [M:ATB2]NUMLI([M:ATB2]NBZONE-1)   = [M:ATB2]NBZONE
   [M:ATB2]DIME([M:ATB2]NBZONE-1)    = 1
   [M:ATB2]NOABREG([M:ATB2]NBZONE-1) = INTFLD(I)
   [M:ATB2]NOCOURT([M:ATB2]NBZONE-1) = INTFLD(I)
   [M:ATB2]NOLONG([M:ATB2]NBZONE-1)  = INTFLD(I)
   [M:ATB2]CHPLEG([M:ATB2]NBZONE-1)  = 0
   Case TYPFLD(I)
    When "AUS"   : [M:ATB2]VERIF([M:ATB2]NBZONE-1) = 1
    When Default : [M:ATB2]VERIF([M:ATB2]NBZONE-1) = 0
   Endcase
   [M:ATB2]ANNUL([M:ATB2]NBZONE-1)   = ANUFLD(I)
   [M:ATB2]LIEN([M:ATB2]NBZONE-1)    = LNKFLD(I)
   [M:ATB2]OBLIG([M:ATB2]NBZONE-1)   = 1
   [M:ATB2]ZERO([M:ATB2]NBZONE-1)    = 1
  Endif
 Next I
 If K<>[M:ATB2]NBZONE : Affzo [ATB2] : Endif
Endif
[F:ATB]UPDFLG = 0
[F:ATB] = [M:ATB0] : # A cause de CODACT
[F:ATB] = [M:ATB1]
If AUDIT & find([F:ATB]CODFIC,"ALOGIN","AUDITH","AUDITL","AUDITBI")
 If [F:ATB]AUDCRE=2 or [F:ATB]AUDUPD=2 or [F:ATB]AUDDEL=2 or [M:ATB4]NBCHP>0
  Call MESSAGE(mess(17,127,1)) From GESECRAN
#  Pas d'audit sur les tables d'audit
  [F:ATB]AUDCRE = 1
  [F:ATB]AUDUPD = 1
  [F:ATB]AUDDEL = 1
  [M:ATB4]AUDCRE = [F:ATB]AUDCRE
  [M:ATB4]AUDUPD = [F:ATB]AUDUPD
  [M:ATB4]AUDDEL = [F:ATB]AUDDEL
  If dim([F:ATB]AUDBI)>0
   [F:ATB]AUDBI  = 1
  Endif
  If dim([M:ATB4]AUDBI)>0
   [M:ATB4]AUDBI  = 1
  Endif
  If dim([F:ATB]AUDSDA)>0
   [F:ATB]AUDSDA  = 1
  Endif
  If dim([M:ATB4]AUDSDA)>0
   [M:ATB4]AUDSDA  = 1
  Endif
  [M:ATB4]NBCHP  = 0
  Affzo [ATB4]
 Endif
Endif
Return

#----------------------------------------------------------#
$CREATION
# On écrit dans le fichier des lignes de fichiers
nolign = 0
For I=0 To [M:ATB2]NBZONE-1
 nolign += 1
 Raz [F:ATZ]
 [F:ATZ] = [M:ATB0]
 [F:ATZ] = [M:ATB2]
 [F:ATZ]NUMLIG = nolign
 Write [ATZ]
 If fstat
  GOK=0 : Call FSTA("ATZ") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
# On écrit dans le fichier des index de fichiers
nolign = 0
For I=0 To [M:ATB3]NBINDEX-1
 nolign += 1
 Raz [F:ATI]
 [F:ATI] = [M:ATB0]
 [F:ATI] = [M:ATB3]
 [F:ATI]NUMLIG = nolign
 Write [ATI]
 If fstat
  GOK=0 : Call FSTA("ATI") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
If GLIAISON(1)<>""
 WNB0 = 0 : Gosub CRE_LIENS
Endif
# Fichier .cfg
Gosub INICFG
Call ECRIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
Call MODIF_CFG(NOMCFG,[M:ATB1]SECURE)
Call LIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
Affzo [M:ATB3]FICCFG
# Audit
If AUDIT
 Gosub CRE_AUDIT
 If GOK<1 : Return : Endif
Endif
AFF = CLECUR1 : Gosub VERFACT_ATB From PARMNT
Return

$CRE_AUDIT
Local Char AUDFLD(GLONAVA)
I = 0
K = 0
While I<=[M:ATB4]NBCHP-1
 AUDFLD = [M:ATB4]FLD(I)
 Gosub VERF_AUDIT
 If !mkstat
  Raz [F:ATA]
  [F:ATA]CODFIC = [F:ATB]CODFIC
  [F:ATA]NUMLIG = I+1
  [F:ATA]FLD    = [M:ATB4]FLD(I)
  [F:ATA]OPE    = [M:ATB4]FLDOPE(I)
  [F:ATA]VALEUR = [M:ATB4]FLDINT(I)
  Write [ATA]
  If fstat
   GOK = 0 : Call FSTA("ATA") From GLOCK : Break
  Endif
  I += 1
 Else
  Dela I,1,[M:ATB4]NBCHP [M:ATB4]NBCHP
  [M:ATB4]NBCHP -= 1
  K = 1
 Endif
Wend
Raz GMESSAGE
If K
 Affzo [ATB4]
Endif
Return

#----------------------------------------------------------#
$MODIF
Delete [ATZ] Where [F:ATZ]CODFIC=[M:ATB0]CODFIC
If fstat=1 : GOK=-1 : GLOCK="$ATABZON" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ATZ") From GLOCK : Return
Endif
nolign=0
For I=0 To [M:ATB2]NBZONE-1
 nolign += 1
 Raz [F:ATZ]
 [F:ATZ] = [M:ATB0]
 [F:ATZ] = [M:ATB2]
 [F:ATZ]NUMLIG = nolign
 Write [ATZ]
 If fstat
  GOK=0 : Call FSTA("ATZ") From GLOCK : Break
 Endif
Next I
Delete [ATI] Where [F:ATI]CODFIC=[M:ATB0]CODFIC
If fstat=1 : GOK=-1 : GLOCK="$ATABIND" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ATI") From GLOCK : Return
Endif
nolign=0
For I=0 To [M:ATB3]NBINDEX-1
 Raz [F:ATI]
 nolign += 1
 [F:ATI] = [M:ATB0]
 [F:ATI] = [M:ATB3]
 [F:ATI]NUMLIG = nolign
 Write [ATI]
 If fstat
  GOK=0 : Call FSTA("ATI") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
For [AP2] Where TYPAFF=2 & CODAFF=[M:ATB0]CODFIC
 If !find([F:AP2]CODZON,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
  Delete [AMP] Where TYPAFF=2 & CODAFF=[M:ATB0]CODFIC & CODZON=[F:AP2]CODZON
  If fstat=1 : GOK=-1 : GLOCK="$AMSKPAR" : Break
  Elsif fstat>5 : GOK=0 : Call FSTA("AMP") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
If GLIAISON(1)<>""
 Gosub CRE_LIENS
Endif
# Fichier .cfg
Gosub INICFG
Call ECRIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
Call MODIF_CFG(NOMCFG,[M:ATB1]SECURE)
Call LIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
Affzo [M:ATB3]FICCFG
# Audit
If AUDIT
 Delete [ATA] Where CODFIC=[F:ATB]CODFIC
 If fstat=1 : GOK = -1 : GLOCK="$ATABAUD" : Return : Endif
 Gosub CRE_AUDIT
 If GOK<1 : Return : Endif
Endif
AFF = CLECUR1 : Gosub VERFACT_ATB From PARMNT
Return

$CRE_LIENS
WNB1 = 0
For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC & NOLIB<>0
 WNB1 += 1
 WLNK1(WNB1) = num$([F:ATZ]NOLIB)
Next ATZ
For I=1 To WNB0
 If !find(WLNK0(I),WLNK1(1..WNB1))
  Delete [ALI] Where USRCOD=GLIAISON(1) & SRCOBJ="AML" & SRCKEY=WLNK0(I)
&                  & DSTOBJ="ATB" & DSTKEY=[F:ATB]CODFIC
 Endif
Next I
For I=1 To WNB1
 If !find(WLNK1(I),WLNK0(1..WNB0))
  Raz [F:ALI]
  [F:ALI]USRCOD = GLIAISON(1)
  [F:ALI]SRCOBJ = "AML"
  [F:ALI]SRCKEY = WLNK1(I)
  [F:ALI]DSTOBJ = "ATB"
  [F:ALI]DSTKEY = [F:ATZ]CODFIC
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]DSTTIT = 1176
  Call TEXTE([F:ATB]INTITFIC,[F:ALI]DSTDES) From OBJDIV
  [F:ALI]LNK    = "U"
  [F:ALI]INVFLG = 2
  [F:ALI]AUTFLG = 2
  [F:ALI]ENAFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  Write [ALI]
 Endif
Next I
Return

#----------------------------------------------------------#
$LIENS
Gosub SUP_TRTINI
Call TEXTE([M:ATB0]INTITFIC,[M:ATB0]ZINTITFIC) From OBJDIV
Raz nolign
For [ATZ]NUMLIG Where [ATZ]CODFIC=[M:ATB0]CODFIC
 nolign += 1
 [M:ATB2] = [F:ATZ]
 Call TEXTE([M:ATB2]NOCOURT(nolign-1),[M:ATB2]INTITCOURT(nolign-1)) From OBJDIV
 Call TEXTE([M:ATB2]NOABREG(nolign-1),[M:ATB2]INTITABREG(nolign-1)) From OBJDIV
 Call TEXTE([M:ATB2]NOLONG(nolign-1),[M:ATB2]INTITLONG(nolign-1)) From OBJDIV
Next ATZ
[M:ATB2]NBZONE = min(nolign,dim([M:ATB2]CODZONE))
nolign=0
For [ATI]NUMLIG Where CODFIC=[M:ATB0]CODFIC
 nolign += 1
 [M:ATB3] = [F:ATI]
Next
[M:ATB3]NBINDEX = min(nolign,dim([M:ATB3]CODIND))
If GLIAISON(1)<>""
 WNB0 = 0
 For [ATZ]CODZONE Where CODFIC=[M:ATB0]CODFIC & NOLIB<>0
  WNB0 += 1
  WLNK0(WNB0) = num$([F:ATZ]NOLIB)
 Next ATZ
Endif
Gosub GRISE_OPT
Gosub GRISE_COL : #91088/5
Gosub INICFG
Call LIRE_CFG(NOMCFG,[M:ATB3]FICCFG)
If AUDIT
 K = 1
 If find([M:ATB0]CODFIC,"ALOGIN","AUDITH","AUDITL","AUDITBI") : # Les triggers utilisent ces tables
  K = 0
 Elsif [M:ATB1]TYPFIC=3 : # Tables système
  K = 0
 Else
  #Gosub SET_NOVIEW From CREHISTO : # Tables locales au dossier historisé (table de travail en général)
  #K = !find([M:ATB0]CODFIC,TABNOVIEW(1..NBNOVIEW))
 Endif
 If K
  Actzo [ATB4]
  nolign = 0
  For [ATA]ATA0 Where CODFIC=[M:ATB0]CODFIC
   K = find([F:ATA]FLD,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
   If K
    nolign += 1
    NOL = nolign-1
    [M:ATB4]FLD(NOL)    = [F:ATA]FLD
    [M:ATB4]FLDOPE(NOL) = [F:ATA]OPE
    [M:ATB4]FLDVAL(NOL) = [F:ATA]VALEUR
    Read [ATY]CODTYP = [M:ATB2]CODTYP(K-1)
    Gosub SET_AUDIT
    Gosub GRISE_VAL
    If [M:ATB4]FLDOPE(NOL)<>1
     Call CHARGE([M:ATB4]FLDVAL(NOL),[M:ATB4]FLDTYP(NOL),[M:ATB4]FLDLIB(NOL),[M:ATB4]FLDLNG(NOL),[M:ATB4]FLDINT(NOL)) From FMTVAR
     If GERR<>0
      Call ERREUR(mess(279,139,1)-[F:ATA]FLD-":"-GMESSAGE) From GESECRAN : # Erreur champ audité
      Raz GMESSAGE , GERR
     Endif
    Endif
   Endif
  Next ATA
  [M:ATB4]NBCHP = nolign
  Gosub GRISE_AUDBI
  Gosub GRISE_AUDCLE
  Gosub GRISE_AUDSDA
  Gosub GRISE_ASDCLE
 Else
  Effzo [ATB4]
  Grizo [ATB4]
 Endif
Endif
Affzo [ATB2]CODTYP
For nolign=1 To [M:ATB2]NBZONE
 K = 0
 Read [ATY]CODTYP=[M:ATB2]CODTYP(nolign-1)
 If !fstat
  K = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
  If [F:ATY]OBJLIEN<>""
   Read [AOB]ABREV=[F:ATY]OBJLIEN
   If !fstat
    If [F:AOB]LIBPAR<>0 : K = 1 : Endif
   Endif
  Endif
  K += ([F:ATY]PARTAB<>"")
 Endif
 If K
  Chgstl [ATB2]CODTYP(nolign-1) With "AMKACT"
 Else
  Chgstl [ATB2]CODTYP(nolign-1) With ""
 Endif
Next nolign
Return

#----------------------------------------#
$GRISE_AUDBI
If dim([M:ATB4]AUDBI)>0
 If [M:ATB4]AUDBI=2
  Actzo [M:ATB4]AUDBI
 Else
  Grizo [M:ATB4]AUDBI
 Endif
Endif
Return

#----------------------------------------#
$GRISE_AUDSDA
If dim([M:ATB4]AUDSDA)>0
 If func AFNC.ACTIV("ASD") & !find(nomap(0),"X3","X3INDV6","PAYINDV6") : # Temporaire
  Actzo [ATB4]AUDSDA
 Else
  [M:ATB4]AUDSDA = 1
  Affzo [ATB4]AUDSDA
  Grizo [ATB4]AUDSDA
 Endif
Endif
Return

#----------------------------------------#
$GRISE_ASDCLE
If dim([M:ATB4]AUDSDA)>0
 If [M:ATB4]AUDSDA=2
  Actzo [ATB4]ASDCLE
 Else
  [M:ATB4]ASDCLE = ""
  Affzo [ATB4]ASDCLE
  Grizo [ATB4]ASDCLE
 Endif
Endif
Return

#----------------------------------------#
$GRISE_AUDCLE
If [M:ATB4]AUDCRE<>2 & [M:ATB4]AUDUPD<>2 & [M:ATB4]AUDDEL<>2 & (dim([M:ATB4]AUDBI)<0 or [M:ATB4]AUDBI<>2)
 [M:ATB4]AUDCLE = ""
 Affzo [ATB4]AUDCLE
 Grizo [ATB4]AUDCLE
Else
 Actzo [ATB4]AUDCLE
Endif
Return

#----------------------------------------#
$GRISE_OPT
Case [M:ATB1]TYPFIC
 When 3 : # Système X3
  [M:ATB1]CRE = 1 : # Pas de copie
  Affzo [ATB1]CRE : Diszo [ATB1]CRE
 When 4 : # Dictionnaire
  [M:ATB1]CRE = 2 : # Copie automatique
  Affzo [ATB1]CRE : Diszo [ATB1]CRE
 When Default
  Actzo [ATB1]CRE
Endcase
If [M:ATB1]CRE<>3
 [M:ATB1]OPT = 0   : Affzo [ATB1]OPT    : Grizo [ATB1]OPT
Else
 Actzo [ATB1]OPT
Endif
If dim([M:ATB1]FLGLEG)>0
 If !find([M:ATB1]CRE,2,3) or find([M:ATB1]TYPFIC,3,4)
  [M:ATB1]FLGLEG=0  : Affzo [ATB1]FLGLEG : Grizo [ATB1]FLGLEG
 Else
  Actzo [ATB1]FLGLEG
 Endif
Endif
Return

$GRISE_COL
#91088/5
If [M:ATB1]SYMBOL=""
 Raz [M:ATB1]COLFMT : Grizo [M:ATB1]COLFMT
 Raz [M:ATB1]COLLNG : Grizo [M:ATB1]COLLNG
 Raz [M:ATB1]COLDEC : Grizo [M:ATB1]COLDEC
Else
 If [M:ATB1]COLFMT<>""
  Raz [M:ATB1]COLLNG : Grizo [M:ATB1]COLLNG
  Raz [M:ATB1]COLDEC : Grizo [M:ATB1]COLDEC
 Else
  Actzo [M:ATB1]COLLNG
  Actzo [M:ATB1]COLDEC
 Endif
 If [M:ATB1]COLLNG<>"" | [M:ATB1]COLDEC<>""
  Raz [M:ATB1]COLFMT : Grizo [M:ATB1]COLFMT
 Else
  Actzo [M:ATB1]COLFMT
 Endif
Endif
Return

#----------------------------------------#
$GRISE_VAL
If [M:ATB4]FLDOPE(nolign-1)=1
 [M:ATB4]FLDVAL(nolign-1) = ""
 Affzo [ATB4]FLDVAL(nolign-1)
 Grizo [ATB4]FLDVAL(nolign-1)
Else
 Actzo [ATB4]FLDVAL(nolign-1)
Endif
Return

#--------------------------#
$INICFG
Local Char NOMCFG(GDIMFIC)
NOMCFG = filpath("FIL",[M:ATB0]CODFIC,"cfg",0)
Return

#-------------------------------------------------------------#
Funprog GET_CFG(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Clbfile     AVALUE
Value Char CLE
Call LIRE_CFG(filpath("FIL",CLE,"cfg",0),AVALUE)
End 0

#-------------------------------------------------------------#
Funprog GET_CFGCNT(AINSTANCE,APRONAME,AVALCNT,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Char AVALCNT
Value Char CLE
[L]AVALCNT="text/plain"
End 0

#-------------------------------------------------------------#
Funprog GET_CFGEXIST(AINSTANCE,APRONAME,AEXIST,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable  Tinyint AEXIST
Value Char CLE
If filinfo(filpath("FIL",CLE,"cfg",0),0)>=0
 [L]AEXIST=1
Else
 [L]AEXIST=0
Endif
End 0

#-------------------------------------------------------------#
Funprog PUT_CFG(AINSTANCE,APRONAME,AVALUE,CLE)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char CLE
Call ECRIRE_CFG(filpath("FIL",CLE,"cfg",0),AVALUE)
End 0

#----------------------------------------#
Subprog LIRE_CFG(NOMCFG,CLOB)
Value Char NOMCFG
Variable Clbfile CLOB
Local Integer I , J , K , NB , ER , DIME , LEVEL , TROUVE
Local Char    CHAINE(255)
DIME = 300
Local Char    LIGNE(255)(1..DIME) , TETADO(80)
TETADO = "#<AdxT"+GADOVERS+">@(#)%I%"+"$Revision$"
Raz CLOB
If filinfo(NOMCFG,0)<0 : End : Endif
Openi NOMCFG Using [FIC]
Iomode adxifs ""       Using [FIC]
Iomode adxirs chr$(10) Using [FIC]
Iomode adxium GUTF8    Using [FIC]
Raz LIGNE , NB , ER
Rdseq CHAINE Using [FIC]
While 1=1
 If NB=0
  If left$(CHAINE,5)<>left$(TETADO,5)
   NB += 1 : LIGNE(NB) = CHAINE
  Endif
 Elsif NB>=DIME
  Call ERREUR("|"+NOMCFG-"|\"-mess(161,115,1)) From GESECRAN : # Trop de lignes
  ER = 1 : Break
 Else
  NB += 1 : LIGNE(NB) = CHAINE
 Endif
 Rdseq CHAINE Using [FIC]
 If fstat & CHAINE=""
  Break
 Endif
Wend
Openi Using [FIC]
If ER : End : Endif
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Recherche Niveau sécurité actuel
Raz I , LEVEL , TROUVE
While I<NB
 I += 1
 If instr(1,toupper(LIGNE(I)),'$SECURITY')
  J = I-1
  While J<NB
   J += 1
   If instr(1,toupper(LIGNE(J)),'{"LEVEL')
    K = J-1
    While K<NB
     K += 1
     If instr(1,toupper(LIGNE(K)),'END')
      LEVEL = val(mid$(LIGNE(J),instr(1,toupper(LIGNE(J)),'{"LEVEL')+7,1))
      TROUVE = 1 : Break 3
     Endif
    Wend
   Endif
  Wend
 Endif
Wend
If TROUVE & find(LEVEL,0,1)
 # Suppression des lignes LEVEL
 If K<>J
  Dela K,1 LIGNE : NB -= 1
 Endif
 If J<>I
  Dela J,1 LIGNE : NB -= 1
 Endif
 Dela I,1 LIGNE : NB -= 1
Endif
For I=1 To NB
 LIGNE(I) += chr$(13)+chr$(10)
Next I
Setlob CLOB With LIGNE
End

Subprog ECRIRE_CFG(NOMCFG,CLOB)
Value Char NOMCFG
Variable Clbfile CLOB
Local Integer DIME , I , K , NB , STAT
DIME = 300
Local Char    LIGNE(255)(1..DIME) , TETADO(80) , CHAINE(250)
TETADO = "#<AdxT"+GADOVERS+">@(#)%I%"+"$Revision$"
Setlob LIGNE With CLOB
CHAINE = ctrans(sum(LIGNE),chr$(13)+chr$(10)+" ","")
If sum(CHAINE)=""
 If filinfo(NOMCFG,0)>0
  Call EFFACE(NOMCFG,STAT) From ORDSYS
 Endif
 End
Endif
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Pour virer les CR du clob
For I=1 To NB
 LIGNE(I) = ctrans(LIGNE(I),chr$(13),"")
Next I
Openo NOMCFG,0 Using [FIC]
Iomode adxifs ""       Using [FIC]
Iomode adxirs chr$(10) Using [FIC]
Iomode adxium GUTF8    Using [FIC]
Wrseq TETADO Using [FIC]
Iomode adxirs ""       Using [FIC]
For I=1 To NB
 Wrseq LIGNE(I) Using [FIC]
Next I
If right$(LIGNE(NB),len(LIGNE(NB)))<>chr$(10)
 Wrseq chr$(10) Using [FIC]
Endif
Openo Using [FIC]
End

#----------------------------------------#
Subprog MODIF_CFG(NOMCFG,SECU)
Value Char    NOMCFG
Value Integer SECU
Local Integer I , J , K , NB , DIME , STAT , MODIF , OK , ER , LEVEL , TROUVE
DIME = 300
Local Char    LIGNE(255)(1..DIME) , CHAINE(255) , TETADO(80)
TETADO = "#<AdxT"+GADOVERS+">@(#)%I%"+"$Revision$"
Raz LIGNE , NB , ER
If filinfo(NOMCFG,0)>0
 Openi NOMCFG Using [FIC]
 Iomode adxifs ""       Using [FIC]
 Iomode adxirs chr$(10) Using [FIC]
 Iomode adxium GUTF8    Using [FIC]
 Rdseq CHAINE Using [FIC]
 While 1=1
  If NB=0
   If left$(CHAINE,5)<>left$(TETADO,5)
    NB += 1 : LIGNE(NB) = CHAINE
   Endif
  Elsif NB>=DIME
   Call ECR_TRACE("|"+NOMCFG-"|\"-mess(161,115,1),1) From GESECRAN : # Trop de lignes
   ER = 1 : Break
  Else
   NB += 1 : LIGNE(NB) = CHAINE
  Endif
  Rdseq CHAINE Using [FIC]
  If fstat & CHAINE=""
   Break
  Endif
 Wend
 Openi Using [FIC]
Endif
If ER : End : Endif
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Recherche niveau sécurité actuel
Raz I , TROUVE , MODIF
LEVEL = -1
While I<NB
 I += 1
 If instr(1,toupper(LIGNE(I)),'$SECURITY')
  J = I-1
  While J<NB
   J += 1
   If instr(1,toupper(LIGNE(J)),'{"LEVEL')
    K = J-1
    While K<NB
     K += 1
     If instr(1,toupper(LIGNE(K)),'END')
      LEVEL = val(mid$(LIGNE(J),instr(1,toupper(LIGNE(J)),'{"LEVEL')+7,1))
      TROUVE = 1 : Break 3
     Endif
    Wend
   Endif
  Wend
 Endif
Wend
# On ne modifie(ou vire) le fichier .cfg que si nécessaire
If (SECU=2 & LEVEL<>0) or (SECU<>2 & LEVEL=0)
 MODIF = 1
 If TROUVE
  # Suppression des lignes LEVEL
  If K<>J
   Dela K,1 LIGNE : NB -= 1
  Endif
  If J<>I
   Dela J,1 LIGNE : NB -= 1
  Endif
  Dela I,1 LIGNE : NB -= 1
 Endif
 # On rajoute/modifie le § SECURITY avec la clause LEVEL0 pour avoir une table non sécurisée
 If SECU=2
  If NB+3>DIME
   Call ECR_TRACE("|"+NOMCFG-"|\"-mess(161,115,1),1) From GESECRAN : # Trop de lignes
   ER = 1
  Else
   Insa 1,3 LIGNE
   LIGNE(1) = '$SECURITY'
   LIGNE(2) = '{"LEVEL0"}'
   LIGNE(3) = 'End'
  Endif
 Endif
Endif
If ER : End : Endif
If MODIF
 NB = DIME
 While NB & LIGNE(NB)=""
  NB -= 1
 Wend
 If !NB
  If filinfo(NOMCFG,0)>0
   Call EFFACE(NOMCFG,STAT) From ORDSYS
  Endif
 Else
  Openo NOMCFG,0 Using [FIC]
  Iomode adxifs ""       Using [FIC]
  Iomode adxirs chr$(10) Using [FIC]
  Iomode adxium GUTF8    Using [FIC]
  Wrseq TETADO Using [FIC]
  For I=1 To NB
   Wrseq LIGNE(I) Using [FIC]
  Next I
  Openo Using [FIC]
 Endif
Endif
End

#----------------------------------------------------------#
$ANNULE
Local Char WDOS(GLONADS)
[L]WDOS = [L]APPLI

$PROG_ANNULE
Local Integer WSTAT
Local Char    WSUF(10) , WFICTRT(GDIMFIC) , DOSHISTO(GLONADS)
Delete [ATZ] Where CODFIC=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ATZ",[L]CODE) From GLOCK : Return : Endif
Delete [ATI] Where CODFIC=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ATI",[L]CODE) From GLOCK : Return : Endif
Delete [AMP] Where TYPAFF=2 & CODAFF=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("AMP","2"+[L]CODE) From GLOCK : Return : Endif
Call SYSTEME(adxmac(0),"valfil -n"-WDOS-[L]CODE,"",WSTAT) From ORDSYS
Call SYSTEME(adxmac(0),"valfil -d"-WDOS-[L]CODE,"",WSTAT) From ORDSYS
For WSUF = "srf", "fde", "dat", "idx" , "cfg"
 WFICTRT = filpath("FIL",[L]CODE,WSUF,WDOS)
 If filinfo(WFICTRT,0)>=0
  Call EFFACE(WFICTRT,WSTAT) From ORDSYS
 Endif
Next WSUF
#107271 uniquement GEODE
If GPRODUIT=1
 WDOSHISTO = func DOSCONT.HISTO(WDOS)
 If WDOSHISTO<>"" & filinfo(filpath("FIL",[L]CODE,"fde",WDOSHISTO),0)>0
  Call SYSTEME(adxmac(0),"valfil -n"-WDOSHISTO-[L]CODE,"",WSTAT) From ORDSYS
  Call SYSTEME(adxmac(0),"valfil -d"-WDOSHISTO-[L]CODE,"",WSTAT) From ORDSYS
  For WSUF = "srf", "fde", "viw" , "dat" , "idx" , "cfg"
   WFICTRT = filpath("FIL",[L]CODE,WSUF,WDOSHISTO)
   If filinfo(WFICTRT,0)>=0
    Call EFFACE(WFICTRT,WSTAT) From ORDSYS
   Endif
  Next WSUF
 Endif
Endif
Return

#----------------------------------------#
$INFOS
Local Char    MESSAGE(250)
Local Integer NB1, NB2, NB3, NBB, DIMZON, LNGZON, LNGBLOB
REPONSE = 0
NB1 = 0
NB2 = 0
NBB = 0
For NOL=0 To [M:ATB2]NBZONE-1
 If find([M:ATB2]CODTYP(NOL),"AXX","AX1","AX2","AX3")=0
  DIMZON = [M:ATB2]DIME(NOL)
  Call REPTAB([M:ATB2]CODACT(NOL),DIMZON) From DOSSUB
  If DIMZON<>0
   Read [ATY]CODTYP = [M:ATB2]CODTYP(NOL)
   If fstat
    LNGZON = 1
    DIMZON = 1
   Else
    DIMZON = abs(DIMZON)
    Case [F:ATY]TYPTYP
     When 1 : LNGZON = 1                  : # Libellé
     When 2 : LNGZON = 2                  : # Entier court
     When 3 : LNGZON = 4                  : # Entier long
     When 4 : LNGZON = 8                  : # DCB
     When 5 : LNGZON = 4                  : # Float
     When 6 : LNGZON = 8                  : # Double
     When 7                               : # Alphanumérique
      If [F:ATY]LNGTYP<>0
       LNGZON = ([F:ATY]LNGTYP+1)
      Else
       LNGZON = ([M:ATB2]LONG(NOL)+1)
      Endif
      LNGZON *= KDBA                      : # Unicode
     When 8  : LNGZON = 3                 : # Date
     When 9, 10                           : # Blob, Clob
      LNGZON = 0
      If [F:ATY]LNGTYP<>0
       LNGBLOB = [F:ATY]LNGTYP
      Else
       LNGBLOB = [M:ATB2]LONG(NOL)
      Endif
      LNGBLOB = 2^LNGBLOB
      NBB += DIMZON*LNGBLOB
    Endcase
   Endif
   NB1 += DIMZON
   NB2 += DIMZON*LNGZON
  Endif
 Endif
Next NOL
If filinfo(filpath("FIL",CLECUR1,"fde"),0)>=0
 Local File =CLECUR1 [AAA]
 NB3 = nbrecord([AAA])
 Close Local File [AAA]
Endif
# Champs : x \Longueur : y \Lignes : z
MESSAGE = mess(149,123,1)-":"-num$(NB1)         : # Champs
MESSAGE -= "\"+mess(81,124,1)-":"-num$(NB2)     : # Longueur
If NBB>0
 MESSAGE -= "("+mess(9,30,1)+"="+num$(NBB)+"K)" : # Blob
Endif
MESSAGE -= "\"+mess(176,133,1)-":"-num$(NB3)    : # Lignes
Call MESSAGE(MESSAGE) From GESECRAN
Return

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ATABLE  [ATB1]
 Local File ATABZON [ATZ1]
 Local File ATABIND [ATI1]
 If filinfo(filpath("FIL","ATABAUD","fde"),0)>0
  Local File ATABAUD [ATA1]
 Endif
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".ATABLE"  [ATB1]
 Local File =[M]DOSORG+".ATABZON" [ATZ1]
 Local File =[M]DOSORG+".ATABIND" [ATI1]
 If filinfo(filpath("FIL","ATABAUD","fde",[M]DOSORG),0)>0
  Local File =[M]DOSORG+".ATABAUD" [ATA1]
 Endif
 Local File =[M]DOSORG+".AMSKPAR" [AMP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ATABLE  [ATB2]
 Local File ATABZON [ATZ2]
 Local File ATABIND [ATI2]
 If filinfo(filpath("FIL","ATABAUD","fde"),0)>0
  Local File ATABAUD [ATA2]
 Endif
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
 If filinfo(filpath("FIL","AVIEW","fde"),0)>0
  Local File AVIEW [AVW2]
 Endif
Else
 Local File =[M]DOSDES+".ATABLE"  [ATB2]
 Local File =[M]DOSDES+".ATABZON" [ATZ2]
 Local File =[M]DOSDES+".ATABIND" [ATI2]
 If filinfo(filpath("FIL","ATABAUD","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".ATABAUD" [ATA2]
 Endif
 Local File =[M]DOSDES+".AMSKPAR" [AMP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
 If filinfo(filpath("FIL","AVIEW","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".AVIEW" [AVW2]
 Endif
Endif
Local Integer NBENR , AUD1 , AUD2 , AUD3 , AUD4 , AUD5 , AUD6 , AUDIT , ABI , ASD
Local Char    AUDC(GLONANX) , AUDCLE(GLONANX)
AUDIT = func AFNC.ACTIVDOS([M]DOSDES,"AUDIT")
ABI   = func AFNC.ACTIVDOS([M]DOSDES,"ABI")
ASD   = func AFNC.ACTIVDOS([M]DOSDES,"ASD")
OK = 1
If GTRACE=""
 Read [ATB2]CODFIC = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Read [ATB1]CODFIC = TABLE
 Read [ATB2]ABRFIC = [F:ATB1]ABRFIC
 If !fstat & [F:ATB2]CODFIC<>TABLE
  Call ECR_TRACE(mess(17,176,1)-"("+[F:ATB2]CODFIC+")",1) From GESECRAN : # Abréviation déjà existante
  OK = 0
 Endif
Endif
If OK & clalev([F:AVW2])>0
 Read [AVW2]AVW0 = TABLE
 If !fstat
  Call ECR_TRACE(TABLE-":"-mess(75,139,1),1) From GESECRAN : # Il existe déjà une vue du même nom
  OK = 0
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ATB1], [ATZ1], [ATI1], [ATX1]
&              , [ATB2], [ATZ2], [ATI2], [ATX2]
If clalev([F:AVW2])>0 : Close Local File [AVW2] : Endif
If clalev([F:ATA2])>0 : Close Local File [ATA2] : Endif
If clalev([F:ATA1])>0 : Close Local File [ATA1] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ATB2] , [ATZ2] , [ATI2] , [ATX2]
 Read [ATB2]CODFIC = TABLE
 If !fstat
  NBENR = [F:ATB2]NBENREG
  If !AUDIT
   AUD1 = 1
   AUD2 = 1
   AUD3 = 1
   AUD4 = 1
  Elsif dim([F:ATB2]AUDCRE)>0
   AUD1  = [F:ATB2]AUDCRE
   AUD2  = [F:ATB2]AUDUPD
   AUD3  = [F:ATB2]AUDDEL
   AUD4  = [F:ATB2]AUDWRK
  Endif
  If !ABI
   AUD5 = 1
   AUDK = ""
  Elsif dim([F:ATB2]AUDBI)>0
   AUD5 = [F:ATB2]AUDBI
   AUDK = [F:ATB2]AUDCLE
  Endif
  If !ASD
   AUD6 = 1
   AUDC = ""
  Elsif dim([F:ATB2]AUDSDA)>0
   AUD6 = [F:ATB2]AUDSDA
   AUDC = [F:ATB2]ASDCLE
  Endif
 Else
  Read [ATB1]CODFIC = TABLE
  NBENR = [F:ATB1]NBENREG
  AUD1  = 1
  AUD2  = 1
  AUD3  = 1
  AUD4  = 1
  AUD5  = 1
  AUD6  = 1
  AUDC  = ""
  AUDK  = ""
 Endif
 Delete [ATB2] Where CODFIC=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABLE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATB2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ATZ2] Where CODFIC=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABZON" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATZ2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ATI2] Where CODFIC=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABIND" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATI2","") From GLOCK : Goto AB_TR_COP
 Endif
 If clalev([F:ATA2])>0
  Delete [ATA2] Where CODFIC=TABLE
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABAUD" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("ATA2","") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
 Delete [AMP2] Where TYPAFF=2 & CODAFF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMSKPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ATB1]CODFIC Where CODFIC=TABLE
  [F:ATB2] = [F:ATB1]
  [F:ATB2]NBENREG = NBENR
  If dim([F:ATB2]AUDCRE)>0
   [F:ATB2]AUDCRE  = AUD1
   [F:ATB2]AUDUPD  = AUD2
   [F:ATB2]AUDDEL  = AUD3
   [F:ATB2]AUDWRK  = AUD4
  Endif
  If dim([F:ATB2]AUDBI)>0
   [F:ATB2]AUDBI  = AUD5
   [F:ATB2]AUDCLE = AUDK
  Endif
  If dim([F:ATB2]AUDSDA)>0
   [F:ATB2]AUDSDA  = AUD6
   [F:ATB2]ASDCLE  = AUDC
  Endif
  Call COPTEXTE([F:ATB1]INTITFIC,[F:ATB2]INTITFIC) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ATB2]UPDUSR)>0 : [F:ATB2]UPDUSR = GUSER : Endif
  If dim([F:ATB2]UPDDAT)>0 : [F:ATB2]UPDDAT = date$ : Endif
  If dim([F:ATB2]UPDTIM)>0 : [F:ATB2]UPDTIM = time  : Endif
  Write [ATB2]
  If fstat
   GOK=0 : Call FSTA("ATB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ATZ1]NUMLIG Where CODFIC=TABLE
  [F:ATZ2] = [F:ATZ1]
  Call COPTEXTE([F:ATZ1]NOABREG,[F:ATZ2]NOABREG) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ATZ1]NOCOURT,[F:ATZ2]NOCOURT) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ATZ1]NOLONG,[F:ATZ2]NOLONG) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ATZ2]
  If fstat
   GOK=0 : Call FSTA("ATZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ATI1]NUMLIG Where CODFIC=TABLE
  [F:ATI2] = [F:ATI1]
  Write [ATI2]
  If fstat
   GOK=0 : Call FSTA("ATI2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif
 If clalev([F:ATA2])>0 & clalev([F:ATA1])>0
  For [ATA1]ATA0 Where CODFIC=TABLE
   [F:ATA2] = [F:ATA1]
   Write [ATA2]
   If fstat
    GOK=0 : Call FSTA("ATA2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Goto AB_TR_COP : Endif
 Endif
 For [AMP1]CODPAR Where TYPAFF=2 & CODAFF=TABLE
  [F:AMP2] = [F:AMP1]
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#----------------------------------------------------------------------------#
# Etiquettes du masque ATB0
#----------------------------------------------------------------------------#

Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
Read [AVW]AVW0=VALEUR
If !fstat
 GMESSAGE = mess(75,139,1) : # Il existe déjà une vue du même nom
 mkstat = 1 : End
Endif
If func DOSBASE.ISBASE_RESERVED_WORDS(VALEUR)
 Call MESSAGE(func AFNC.MES1(mess(272,133,1),VALEUR)) From GESECRAN : # $1$ est un mot réservé aux bases de données
Endif
End

Subprog C_ABRFIC(VALEUR)
Variable Char    VALEUR()
Read [ATB]ABRFIC = VALEUR
If !fstat & [M]CODFIC<>[F:ATB]CODFIC
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(56,123,1)-":"-[F:ATB]CODFIC : # Table
 mkstat=2 : End
Endif
Read [AVW]AVW1=VALEUR
If !fstat
 GMESSAGE = VALEUR-":"-mess(17,176,1) : # Abréviation déjà existante
 GMESSAGE += "\"+mess(77,139,1)-":"-[F:AVW]CODVUE : # Vue
 mkstat=2 : End
Endif
End

Subprog AM_ABRFIC(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ZINTITFIC(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog C_QUOTE(CHAINE)
Variable Char CHAINE()
If instr(1,CHAINE,'"')
 GMESSAGE = '"'-":"-mess(94,123,1) : # Caractère interdit
 mkstat=2 : End
Endif
End

#----------------------------------------------------------------------------#
# Etiquettes du masque ATB1
#----------------------------------------------------------------------------#

Subprog C_FLG130(VALEUR)
Value Integer VALEUR
If VALEUR=2
 For I=1 To [M:ATB2]NBZONE
  Call LECTURE("ATY",[M:ATB2]CODTYP(I-1),"") From CONTOBJ
  #93128
  #If find([F:ATY]TYPTYP,9,10)
  If find([F:ATY]TYPTYP,9,10,11,12)
   Call ERREUR(mess(93,100,1)-num$(I)+"\"+[F:ATY]CODTYP-":"-mess(30,139,1)) From GESECRAN
   # Erreur en ligne x\y : Type de donnée non géré
   mkstat = 2 : Break
  Endif
 Next I
Endif
End

Subprog C_TYPFIC(VALEUR)
Value Integer VALEUR
[M]TYPFIC = VALEUR
Gosub GRISE_OPT
End

Subprog C_CRE(VALEUR)
Value Integer VALEUR
[M]CRE = VALEUR
Gosub GRISE_OPT
End

Subprog AS_RNG(VALEUR)
Value Integer VALEUR
If [M]CRE<2 : mkstat=1 : Endif
End

Subprog AS_TYPDBA(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1 : # C-ISAM
GMENLOC(5) = 5 : # DB2
End

#----------------------------------------------------------------------------#
# Etiquettes du masque ATB2
#----------------------------------------------------------------------------#

Subprog AVANT_NBZONE
Local Char BIDON(1)
GFMT = "20X" : If inpmode=2 : Call AV_INTITABREG(BIDON) : Endif
End

Subprog C_NBZONE
Local Decimal I, N, R, E, L, B, C, M, Z
If adxgtb=0 : End : Endif
Gosub SET_CDBA

Raz N , E , Z , C , B
For I=0 To [M]NBZONE-1
 If find([M]CODTYP(I),"AXX","AX1","AX2","AX3")=0
  R = [M]DIME(I)
  If [M]CODACT(I)<>""
   Read [ACV]CODACT = [M]CODACT(I)
   If !fstat & ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
    R = max([F:ACV]DIMFIL,[F:ACV]DIME)
   Endif
   R = max(R,1)
  Endif
  If R<>0
   Read [ATY]CODTYP = [M]CODTYP(I)
   Case [F:ATY]TYPTYP
    When 1 : L = 1                  : # Libellé
    When 2 : L = 2                  : # Entier court
    When 3 : L = 4                  : # Entier long
    When 4 : L = 8                  : # DCB
    When 5 : L = 4                  : # Float
    When 6 : L = 8                  : # Double
    When 7,12                       : # Alphanumérique/Datetime
     If [F:ATY]LNGTYP<>0
      L = ([F:ATY]LNGTYP+1)
     Else
      L = ([M]LONG(I)+1)
     Endif
     L *= KDBA                      : # Unicode
    When 8  : L = 3                 : # Date
    When 9,10                       : # Blob, clob
     L = 0
     C += R    : # Nombre de clob/blob
     If [F:ATY]LNGTYP<>0
      B += R*1024*(2^[F:ATY]LNGTYP) : # Taille du clob/blob
     Else
      B += R*1024*(2^[M]LONG(I))
     Endif
    When 11 : L = 16                : # Uuid
   Endcase
   E += R * L  : # Taille de l'enregistrement (sans les clob/blob)
   N += R      : # Nombre de colonnes
   Z += 1      : # Nombre de zones
  Endif
 Endif
Next

Gosub SET_NOLIMIT From DOSTAB

#-----------------------------------------------------------------------#
# La limite de 512 colonnes pour une table est imposée par Adonix
#-----------------------------------------------------------------------#
# Le nombre de colonnes maximum est de
#  1000 pour Oracle
#  1024 pour SQL7
#  pas de limite sous DB2
#-----------------------------------------------------------------------#

If dim([M:ATB1]FLG130)>0 & [M:ATB1]FLG130=2 : # Version 130
 M = 256
Else
 M = 512
Endif
If N>M & !find([M:ATB0]CODFIC,TABMAXCOL(1..NBMAXCOL))
 GMESSAGE = mess(213,123,1)-":"-num$(N)-"("+num$(M)+")" : # Nombre de colonnes trop grand
 mkstat = 1 : End
Endif

#---------------------------------------------------------------------------------------#
# Le nombre de zones est limité à 255 par table
# Il n'est possible d'utiliser les champs > 255 dans les clause where ou dans un index
#---------------------------------------------------------------------------------------#

M = 255
If Z>M & !find([M:ATB0]CODFIC,TABMAXZON(1..NBMAXZON))
 GMESSAGE = mess(49,123,1)-":"-num$(Z)-"("+num$(M)+")" : # Nombre de zones trop grand
 mkstat = 1 : End
Endif

#-----------------------------------------------------------------------#
#  La taille maximum d'un enreg pour le moteur Adonix est 32k
#-----------------------------------------------------------------------#
#  mais les vraies limites sont en fait imposées par les bases de données
#
#  Oracle : Pas de limite connue
#
#  SQLServer 7  : 8 060 octets
#  Windows 2000 : 8 060 octets
#
#  DB2 : Suivant le paramétrage des tables spaces
#  4005  octets si la taille de la page du table space est de 4k
#  8101  ---------------------------------------------------- 8k
#  16239 --------------------------------------------------- 16k
#  32677 --------------------------------------------------- 32k
#-----------------------------------------------------------------------#

If GADONIX=2
 M = 8060
Else
 Case GTYPDBA
  When 1       : M = 32000
  When Default : M = 32000 : # SAM 114549 8060
 Endcase
Endif

If E>M & !find([M:ATB0]CODFIC,TABMAXLNG(1..NBMAXLNG))
 GMESSAGE = mess(50,123,1)-":"-num$(E)-"("+num$(M)+")" : # Longueur de ligne trop grande
 mkstat = 1 : End
Endif

#-----------------------------------------------------------------------#
# Blobs Clobs
#-----------------------------------------------------------------------#
# Limites : 1 blob/clob de 2 gigas maxi par enregistrement
#-----------------------------------------------------------------------#
M = 65536
If C>1 & E+B>M
 GMESSAGE = mess(212,123,1)-":"-num$(E) : # Longueur des blobs trop grande
 mkstat = 1 : End
Endif

#------------------------------------------------------------------------------#
# La taille d'une clé est limitée à 512 octets (256 caractères en utf8-2)
#------------------------------------------------------------------------------#

End

Subprog C_CODZONE(VALEUR)
Variable Char    VALEUR()
If vireblc(format$("KT:30X",VALEUR),2)<>VALEUR : # mb 27.11.01 A cause bouton Codification
 mkstat = 1 : End
Endif
If find(toupper(VALEUR),"ROWID","UPDTICK")
 GMESSAGE = toupper(VALEUR)-":"-mess(129,133,1) : # Code réservé
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]CODZONE) From OBJDIV
If mkstat : End : Endif
If VALEUR<>[M]CODZONE(nolign-1)
 Call PLAGE_ZON([M]CODFIC,VALEUR) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog AM_CODZONE(VALEUR)
Variable Char VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(0..50) , INTIT(30)
NBTEX = 0
For [ATZ]DICO Where CODZONE = VALEUR
 NBTEX += 1
 Call TEXTE([F:ATZ]NOCOURT,INTIT) From OBJDIV
 TEX(NBTEX) =  format$("K:11X",[F:ATZ]CODFIC)+format$("K:"+num$(GLONATY)+"X",[F:ATZ]CODTYP)
 TEX(NBTEX) += format$("Nz:5F",[F:ATZ]LONG)+" "+INTIT
 If NBTEX>=dim(TEX)-1 : Break : Endif
Next
If NBTEX
 Call SAITEX(NBTEX,TEX,NUM,mess(108,123,1)-VALEUR) From GESECRAN
 If NUM<>0 & status<>7
  Read [ATB]CODFIC = vireblc(left$(TEX(NUM),10),2)
  Read [ATZ]CODZONE = [F:ATB]CODFIC;VALEUR
  [M] = [F:ATZ]
  Call TEXTE([F:ATZ]NOCOURT,[M]INTITCOURT(nolign-1)) From OBJDIV
  Call TEXTE([F:ATZ]NOABREG,[M]INTITABREG(nolign-1)) From OBJDIV
  Call TEXTE([F:ATZ]NOLONG,[M]INTITLONG(nolign-1)) From OBJDIV
 Endif
Endif
End

Subprog AS_CODTYP(VALEUR)
Variable Char VALEUR
Local Integer OK
If VALEUR="" : End : Endif
Raz GBOUT2
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
OK = ([F:ATY]NBTYP>0)
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OK=1 : Endif
Endif
OK += ([F:ATY]PARTAB<>"")
If OK
 GBOUT2 = mess(174,100,1) : # Paramètres
Endif
End

Subprog C_CODTYP(VALEUR)
Variable Char VALEUR
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
#93128
#If [M:ATB1]FLG130=2 & find([F:ATY]TYPTYP,9,10)
If [M:ATB1]FLG130=2 & find([F:ATY]TYPTYP,9,10,11,12)
 Call ERREUR([F:ATY]CODTYP-":"-mess(30,139,1)) From GESECRAN : # x : Type de donnée non géré
 mkstat = 2 : End
Endif
End

Subprog AP_CODTYP(VALEUR)
Variable Char VALEUR
Local Integer NOL , K
NOL = nolign-1
K = 0
Read [ATY]CODTYP=[M:ATB2]CODTYP(NOL)
If !fstat
 K = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
 If [F:ATY]OBJLIEN<>""
  Read [AOB]ABREV=[F:ATY]OBJLIEN
  If !fstat
   If [F:AOB]LIBPAR<>0 : K = 1 : Endif
  Endif
 Endif
 K += ([F:ATY]PARTAB<>"")
Endif
If K
 Chgstl [M:ATB2]CODTYP(NOL) With "AMKACT"
Else
 Chgstl [M:ATB2]CODTYP(NOL) With ""
Endif
nolign = NOL+1
End

Subprog AM_CODTYP(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR="" : End : Endif
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
Raz GBIDC1
OK = ([F:ATY]NBTYP>0)
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OK=1 : Endif
Endif
OK += ([F:ATY]PARTAB<>"")
If OK
 For [AMP]CODPAR Where TYPAFF=2  & CODAFF=[M]CODFIC & CODZON=[M]CODZONE(nolign-1)
  GBIDC1 = "PAR" : Break
 Next AMP
Endif
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Call LECTURE("ATY",[M:ATB2]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]TYPTYP<>1 or [F:ATY]NOLIB<>0
 mkstat = 1
Endif
End

Subprog AM_NOLIB(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Read [AML]MENLOC = VALEUR
If fstat=0 & [F:AML]LONG<>0
 [M]LONG(NOL) = [F:AML]LONG : Affzo [M]LONG(NOL)
Endif
End

Subprog D_LONG(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]FORTYP=""  & [F:ATY]LNGTYP=0 : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1  : VALEUR = 15  : # Libellé
  When 2  : VALEUR = 4   : # Entier Court
  When 3  : VALEUR = 8   : # Entier Long
  When 4  : VALEUR = 9.2 : # Décimal
  When 7  : VALEUR = 10  : # Alphanumérique
  When 9  : VALEUR = 1   : # Blob
  When 10 : VALEUR = 1   : # Clob
 Endcase
Endif
End

Subprog AS_LONG(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]FORTYP<>"" or [F:ATY]LNGTYP<>0 or find([F:ATY]TYPTYP,8) or find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3")
& or find([F:ATY]TYPTYP,11,12) : # Uuid/Datetime
 mkstat=1
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
Local Integer E, D , ER
Gosub SETNOL
ER = 0
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
Case [F:ATY]TYPTYP
 When 2  : If VALEUR<=0 | VALEUR>5 : ER = 1 : Endif                         : # Entier court
 When 3  : If VALEUR<=0 | VALEUR>8 : ER = 1 : Endif                         : # Entier long
 When 4  : E = int(VALEUR)                                                  : # Décimal
           D = val(right$(num$(mod(VALEUR,1)),3))
           If (E+D>32) | (E=0 & D=0) : ER = 1 : Endif
 When 7  : If VALEUR<=0 | VALEUR>250 | VALEUR<>fix(VALEUR) : ER = 1 : Endif : # Char
 When 9  : If VALEUR<=0 | VALEUR>13 | VALEUR<>fix(VALEUR)  : ER = 1 : Endif : # Blob
 When 10 : If VALEUR<=0 | VALEUR>13 | VALEUR<>fix(VALEUR)  : ER = 1 : Endif : # Clob
Endcase
If ER
 mkstat = 2 : GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

Subprog D_CODACT(VALEUR)
Variable Char VALEUR()
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
VALEUR = [F:ATY]CODACT
End

Subprog C_CODACT(VALEUR)
Variable Char    VALEUR()
If VALEUR>="X" & find([M:ATB1]TYPFIC,3,4) : # Système/Dictionnaire
 # Le développement spécifique n'est pas possible sur les tables dictionnaire et système
 Call ERREUR(mess(192,125,1)) From GESECRAN
 mkstat = 1 : End
Endif
End

Subprog C_INTITCOURT(VALEUR)
Variable Char VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog AV_INTITABREG(VALEUR)
Variable Char VALEUR()
Local Integer TYP, I
Local Decimal LONGUEUR
Local Integer ENTIER, DEC, NBBLANC
Gosub SETNOL
Gosub SETLONG
If LONGUEUR<=20
 NBBLANC = 20-LONGUEUR
 GFMT = num$(LONGUEUR)+"X"+"["+string$(NBBLANC," ")+"]"
Else
 GFMT = num$(20)+"X"+num$(19)+">"+num$(LONGUEUR-20)+"X"
Endif
End

Subprog D_INTITABREG(VALEUR)
Variable Char VALEUR()
Local Decimal LONGUEUR
Local Integer ENTIER, DEC, NBBLANC
Local Integer TYP , I
Gosub SETNOL
If len([M:ATB2]INTITCOURT(nolign-1))<=12
 VALEUR = [M:ATB2]INTITCOURT(nolign-1)
 [M]NOABREG(nolign-1) = [M]NOCOURT(nolign-1)
Endif
End

$SETLONG
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
TYP = [F:ATY]TYPTYP
LONGUEUR = [F:ATY]LNGTYP
If LONGUEUR=0 : LONGUEUR = [M:ATB2]LONG(NOL) : Endif
If TYP=8 & LONGUEUR=0   : LONGUEUR = 8 : Endif : # Cas de la date
If [M]CODTYP(NOL)="TEX" : LONGUEUR = 20 : Endif : # Cas du texte
If find(TYP,4,5,6) : Gosub CALLNG : Endif
Return

$CALLNG
I=instr(1,num$(LONGUEUR),".")
If I
 ENTIER = val(left$(num$(LONGUEUR),I-1))
 DEC  = val(right$(num$(LONGUEUR),I+1))
 LONGUEUR = ENTIER+DEC+1 : # +1 pour la virgule...
Endif
Return

Subprog C_INTITABREG(VALEUR)
Variable Char VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog D_INTITLONG(VALEUR)
Variable Char VALEUR()
VALEUR = [M:ATB2]INTITCOURT(nolign-1)
[M]NOLONG(nolign-1) = [M]NOCOURT(nolign-1)
End

Subprog C_INTITLONG(VALEUR)
Variable Char VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog C_OPTION(VALEUR)
Variable Char VALEUR()
Local Integer I , OK
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
Gosub DEF_OPTFMT From SELAMK
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),TEX(1..NBTEX))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
Case [F:ATY]TYPTYP
 When 1,8,9,10
 When 4 : # DCB
  # Dans la gestion des tables on accepte de saisir l'option F avec des décimales (Sql Server)
 When 7 : # Alpha
  #115175
  #If [F:ATY]FORTYP<>""
  If mid$([F:ATY]FORTYP,1,1)="="
   OK = 1
   For I=1 To len(VALEUR)
    If find(mid$(VALEUR,I,1),"A","#")
     OK = 0 : Break
    Endif
   Next I
   If !OK
    GMESSAGE = mid$(VALEUR,I,1)-":"-mess(53,139,1)-[F:ATY]FORTYP-"("+mess(21,115,1)-[F:ATY]CODTYP+")"
    # Option incompatible avec le format x (Type de donnée y)
    mkstat = 2 : End
   Endif
  Endif
 When Default
Endcase
End

Subprog AM_OPTION(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
#115175
#If [F:ATY]TYPTYP=7 & [F:ATY]FORTYP<>"" & instr(1,VALEUR,"C")
If [F:ATY]TYPTYP=7 & mid$([F:ATY]FORTYP,1,1)="=" & instr(1,VALEUR,"C")
 GMESSAGE = "C :"-mess(53,139,1)-[F:ATY]FORTYP-"("+mess(21,115,1)-[F:ATY]CODTYP+")"
 # Option incompatible avec le format x (Type de donnée y)
 mkstat = 2 : End
Endif
End

Subprog AS_LIEN(VALEUR)
Variable Char VALEUR()
If VALEUR=""
 Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]FICLIEN<>""
  VALEUR = [F:ATY]FICLIEN
 Endif
Endif
End

Subprog C_LIEN(VALEUR)
Variable Char VALEUR()
Local Integer OK
If VALEUR="" : End : Endif
If GPRODUIT=-1
 Look [ATB]CODFIC=VALEUR
 If fstat
  Call AVERTIR(VALEUR-":"-mess(23,100,1),OK) From GESECRAN : # Fiche inexistante
  If OK<>2 : mkstat = 1 : Endif
 Endif
Else
 Call CONTROLE("ATB","$!",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog AS_EXPLIEN(VALEUR)
Variable Char    VALEUR()
If [M]LIEN(nolign-1)=""
 mkstat = 1 : End
Endif
End

Subprog C_EXPLIEN(VALEUR)
Variable Char    VALEUR()
Local Integer I , J , NBCLE , NBPART , OK
Local Char    CLE(120)
Gosub SETNOL
OK = ([M]LIEN(NOL)<>"")
If OK & GPRODUIT=-1
 Look [ATB]CODFIC=[M]LIEN(NOL)
 OK = !fstat
Endif
If !OK : End : Endif
VALEUR = vireblc(format$("KT:250X",VALEUR),2)
Read [ATI]NUMLIG(2) = [M]LIEN(NOL);1
CLE = [F:ATI]DESCRIPT
NBCLE = 0
While CLE<>""
 NBCLE += 1
 I = instr(1,CLE,"+")
 J = instr(1,CLE,"-")
 If I & J : I = min(I,J)
 Elsif !I : I = J
 Endif
 If I
  CLE = right$(CLE,I+1)
 Else
  CLE = ""
 Endif
Wend
CLE = VALEUR
NBPART = 0
While CLE<>""
 NBPART += 1
 I = instr(1,CLE,";")
 If I
  CLE = right$(CLE,I+1)
 Else
  CLE = ""
 Endif
Wend
If NBCLE<>NBPART & (VALEUR<>"" | NBCLE>1)
 GMESSAGE = mess(56,123,1)-[M]LIEN(NOL)+"\"+mess(55,123,1)-":"-[F:ATI]DESCRIPT : # Table\Clé
 GMESSAGE += "\"+mess(101,123,1) : # Expression de lien incorrecte
 mkstat = 2
Endif
End

Subprog AM_EXPLIEN(VALEUR)
Variable Char VALEUR
Local Char    CLE(250) , ZON(250) , MESSA(250)
Local Integer I , OK , NBCLE , POS
Gosub SETNOL
OK = ([M]LIEN(NOL)<>"")
If OK & GPRODUIT=-1
 Look [ATB]CODFIC=[M]LIEN(NOL)
 OK = !fstat
Endif
If !OK : End : Endif
Call NBCLE(VALEUR,NBCLE)
CLE = vireblc(format$("KT:250X",VALEUR),2)
While CLE<>""
 I = instr(1,CLE,";")
 If I
  POS +=1
  ZON = left$(CLE,I-1)
  CLE = right$(CLE,I+1)
 Else
  POS +=1
  ZON = CLE
  CLE = ""
 Endif
 Gosub CONT_ZON
 If mkstat : Break : Endif
Wend
End

$CONT_ZON
#I = instr(1,ZON,"(indice")
I = instr(1,ZON,"(")
If I
 Local Char IND(20)
 IND = seg$(ZON,I+1,len(ZON)-1)
 If IND<>"indice" & num$(val(IND))<>IND
  GMESSAGE = ZON-":"-mess(102,123,1) : # Zone de lien incorrecte
  mkstat = 2
  Return
 Else
  ZON = left$(ZON,I-1)
 Endif
Endif
OK = 0
MESSA = mess(102,123,1) : # Zone de lien incorrecte
Onerrgo ERR_EVAL
I = find(ZON,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
If I : OK = 1 : Endif
If ZON=[M]CODZONE(nolign-1) : # Zone du fichier
 OK = 1
Endif
If instr(1,ZON,'"') : # Expr.alpha
 OK = 1
Endif
I = evalue(ZON+'=val(num$('+ZON+'))') : # Expr.numérique
If I : OK = 1 : Endif
If evalue('dim('+ZON+')>0') : # Var.globale ?
 If left$(ZON,3)<>"[V]"
  If ZON ="GSUPCLE"
   GMESSAGE = ZON-":"-mess(102,123,1) : # Zone de lien incorrecte
   mkstat = 2
   Return
  Endif
  MESSA = mess(28,139,1) : # Une variable globale doit être précédée par [V]
 Else
  If ZON ="[V]GSUPCLE" & (POS<>NBCLE or NBCLE<2)
   GMESSAGE = ZON-":"-mess(102,123,1) : # Zone de lien incorrecte
   mkstat = 2
   Return
  Else
   OK = 1
  Endif
 Endif
Endif
If !OK
 OK = 1
 Call AVERTIR(ZON-":"-MESSA,OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif
Endif
Onerrgo
Return

$ERR_EVAL
Resume

Subprog AS_ANNUL(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]LIEN(NOL)="" : mkstat=1 : End : Endif
End

Subprog AS_VERIF(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]LIEN(NOL)="" : mkstat=1 : End : Endif
End

Subprog AS_OBLIG(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]LIEN(NOL)<>""
 Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
 If [F:ATY]OBJLIEN<>"" & [M]ANNUL(NOL)=3
# Si R.A.Z., on force à 'Non' la zone
  VALEUR = 1 : mkstat=2 : End
 Endif
Endif
End

Subprog AS_DIME(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M]CODACT(NOL)<>""
 Read [ACV]CODACT = [M]CODACT(NOL)
 If !fstat & [F:ACV]DIME<>0
  mkstat=1
 Endif
Endif
End

Subprog NBCLE(VALEURS,NBCLE)
Value    Char    VALEURS
Variable Integer NBCLE
Local Integer I,J
I = instr(1,VALEURS,";")
While I>0
 VALEURS = right$(VALEURS,I+1)
 I = instr(1,VALEURS,";")
 J += 1
Wend
NBCLE = J+1
End

#----------------------------------------------------------------------------#
# Etiquettes du masque ATB3
#----------------------------------------------------------------------------#

Subprog C_CODIND(VALEUR)
Variable Char VALEUR()
If left$(VALEUR,4)="SPE_" : mkstat = 1 : End : Endif
Call UNICITE(VALEUR,[M]CODIND) From OBJDIV
End

Subprog C_DESCRIPT(VALEUR)
Variable Char VALEUR()
Local Integer I , J , K , L , ERR , OK
Local Char    MESSA(250) , CHAINE(250)
VALEUR = vireblc(toupper(VALEUR),2)
If VALEUR="" : mkstat=1 : End : Endif
Gosub SETNOL
For L=0 To [M]NBINDEX-1
 If L<>NOL & VALEUR=[M]DESCRIPT(L)
  Call ERREUR(mess(21,176,1)-[M]CODIND(L)) From GESECRAN : # Composantes de clé déjà saisies pour l'index
  mkstat = 2 : Break
 Endif
Next L
If mkstat : End : Endif
Call VERF_INDEX(VALEUR,NOL,MESSA,ERR)
Case ERR
 When 1 : Call ERREUR(MESSA) From GESECRAN : mkstat = 2 : End
 When 2 : Call AVERTIR(MESSA,OK) From GESECRAN : If OK<>2 : mkstat = 2 : End : Endif
Endcase
End

Subprog AS_NIVDEC(VALEUR)
Variable Decimal VALEUR
If [M]HOMONYM(nolign-1)<>1
 mkstat = 1 : End
Elsif instr(1,[M]DESCRIPT(nolign-1),"+")=0 and instr(1,[M]DESCRIPT(nolign-1),"-")=0
 mkstat = 1 : End
Endif
End

Subprog C_NIVDEC(VALEUR)
Variable Decimal VALEUR
Local Char    CLE(GLONAVA)(1..16) , CHAINE(250)
Local Integer AI , AJ , NBCLE , OK
CHAINE = [M]DESCRIPT(nolign-1)
Raz CLE, NBCLE
While CHAINE<>""
 AI = instr(1,CHAINE,"+")
 AJ = instr(1,CHAINE,"-")
 If AI & AJ
  AI = min(AI,AJ)
 Elsif AJ & !AI
  AI = AJ
 Endif
 NBCLE += 1
 If AI
  CLE(NBCLE) = left$(CHAINE,AI-1)
  CHAINE = right$(CHAINE,AI+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
If VALEUR=0
 End
Elsif abs(VALEUR)>=NBCLE
 # Le nombre de champs déclinés est trop grand
 GMESSAGE = mess(260,139,1)
 mkstat = 2 : End
Elsif VALEUR>0
 For AI=1 To VALEUR
  Gosub CTL_NIVDEC
  If !OK : Break : Endif
 Next AI
 If !OK : mkstat = 2 : End : Endif
Else
 For AI=NBCLE To NBCLE+VALEUR+1 Step -1
  Gosub CTL_NIVDEC
  If !OK : Break : Endif
 Next AI
 If !OK : mkstat = 2 : End : Endif
Endif
End

$CTL_NIVDEC
OK = 1
AJ = find(CLE(AI),[M:ATB2]CODZONE)
If AJ
 Read [ATY]CODTYP=[M:ATB2]CODTYP(AJ-1)
 If fstat or [F:ATY]TYPTYP<>7
  # Les champs de déclinaison doivent être de type alphanumérique
  GMESSAGE = mess(259,139,1)
  OK = 0
 Endif
Endif
Return

Subprog VERF_INDEX(INDEX,NOL,MESSA,ERR)
Variable Char    INDEX()
Value    Integer NOL
Variable Char    MESSA
Variable Integer ERR
Local Integer I , J , K , NB
Local Char    DESCRIPTEUR(120), ZINDEX(120), ZCLE(GLONAVA+5)(1..16) , ERRIND(250) , ZONE(GLONAVA)
Local Decimal LNGZON , LNGCLE , DIME , DIMAX
Gosub SET_CDBA
Raz ERR, NB
DESCRIPTEUR = INDEX
LNGCLE = 1
While DESCRIPTEUR<>""
 ERR = 0
 NB += 1
 If NB>dim(ZCLE) : Break : Endif
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  ZINDEX = left$(DESCRIPTEUR,I-1)
# CC    14/02/2013   ----   Pour autoriser des index avec - sur la première colonne
  If J=1 and ZINDEX=""
    I = instr(2,DESCRIPTEUR,"+")
    J = instr(2,DESCRIPTEUR,"-")
    If I<>0 or J<>0
      ZINDEX=mid$(DESCRIPTEUR,2,max(I,J)-1)
    Else
      ZINDEX=right$(DESCRIPTEUR,2)
      DESCRIPTEUR=""
    Endif
    I=J
  Endif
  DESCRIPTEUR = right$(DESCRIPTEUR,I+1)
 Else
  ZINDEX = DESCRIPTEUR
  DESCRIPTEUR = ""
 Endif
 If ZINDEX<>""
  I = instr(1,ZINDEX,"(")
  If I
   ZONE = left$(ZINDEX,I-1)
   DIME = val(right$(ZINDEX,I+1))+1
  Else
   ZONE = ZINDEX
   DIME = 1
  Endif
 Endif
 K = find(ZONE,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
 If K=0
  MESSA = mess(10,176,1)-INDEX+"\"+ZONE-mess(11,176,1)
  # Index/Zone inexistante
  ERR = 1 : Break
 Elsif find([M:ATB2]CODTYP(K-1),"AXX","AX1","AX2","AX3")
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
  # Index/Ce type de champ est interdit dans les index
  ERR = 1 : Break
 Elsif find(ZINDEX,ZCLE(1..NB-1))
  # Index/Champ déjà existant
  MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(278,123,1)
  ERR = 1 : Break
 Else
  DIMAX = [M:ATB2]DIME(K-1)
  If [M:ATB2]CODACT(K-1)<>""
   Read [ACV]CODACT = [M:ATB2]CODACT(K-1)
   If fstat or [F:ACV]FLACT<>2
    ERRIND -= ZINDEX
    ERR = 2
   Else
    If [F:ACV]DIME<>0
     #DIMAX = [F:ACV]DIME
    Endif
   Endif
  Endif
  If DIMAX>1 or DIME>1
   # Index/Zone dimensionnée
   MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-":"-mess(105,123,1)
   ERR = 1 : Break
  Endif
  If !ERR
   LNGCLE += 2
   Read [ATY]CODTYP=[M:ATB2]CODTYP(K-1)
   Case [F:ATY]TYPTYP
    When 1,2,3,5
     LNGZON = 4
    When 4,6
     LNGZON = 8
    When 7
     If [F:ATY]LNGTYP<>0
      LNGZON = ([F:ATY]LNGTYP+1)*2
     Else
      LNGZON = ([M:ATB2]LONG(K-1)+1)*2
     Endif
    When 8
     LNGZON = 3
    When 9,10
     MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
     # Index/Ce type de champ est interdit dans les index
     ERR = 1 : Break
   Endcase
   LNGCLE += LNGZON
  Endif
 Endif
 ZCLE(NB) = ZINDEX
Wend

#---------------------------------------------------------------------------------------#
#  La longueur de la clé est limité à 500 octets (limite adonix)
#  Le nombre maxi d'index est 19 (un index est réservé en cas de link)
#  Une clé peut être composée de 16 champs maximum
#---------------------------------------------------------------------------------------#

If LNGCLE>500
 MESSA = INDEX-":"-mess(33,126,1)-num$(LNGCLE)+"(500)" : # Clé trop longue
 ERR = 1
Elsif NB>dim(ZCLE)
 MESSA = INDEX-":"-mess(29,176,1) : # Trop de composantes de clé (maximum #)
 K = instr(1,MESSA,"#")
 If K : MESSA = left$(MESSA,K-1)+num$(dim(ZCLE))+right$(MESSA,K+1) : Endif
 ERR = 1
Elsif NB=0
 MESSA = INDEX-":"-mess(158,133,1) : # Aucune zones actives sur cet index
 ERR = 2
Elsif ERRIND<>""
 # Index...Zone avec un code activité inactif
 MESSA = mess(10,176,1)-INDEX+"\"+ERRIND-mess(22,176,1)
 ERR = 2
Endif
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

#----------------------------------------------------------------------------#
# Etiquettes du masque ATB4
#----------------------------------------------------------------------------#

Subprog AS_AUDCLE(VALEUR)
Variable Char    VALEUR()
If [M]AUDCRE<>2 & [M]AUDUPD<>2 & [M]AUDDEL<>2 & (dim([M]AUDBI)<0 or [M]AUDBI<>2)
 mkstat = 1 : End
Endif
End

Subprog C_AUDCLE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR="" : End : Endif
OK = 0
If find(VALEUR,[M:ATB3]CODIND(0..[M:ATB3]NBINDEX-1))
 OK = 1
Else
 Read [ANX]ANX2=[M:ATB0]CODFIC;VALEUR
 If !fstat : OK = 1 : Endif
Endif
If !OK
 GMESSAGE = mess(1,127,1) : # Clé incorrecte
 mkstat = 2 : End
Endif
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Char    AUDFLD(GLONAVA)
Gosub SETNOL
Call UNICITE(VALEUR,[M:ATB4]FLD) From OBJDIV
If mkstat : End : Endif
AUDFLD = VALEUR
Gosub VERF_AUDIT
If mkstat : End : Endif
Gosub SET_AUDIT
End

$VERF_AUDIT
K = find(AUDFLD,[M:ATB2]CODZONE(0..[M:ATB2]NBZONE-1))
If K=0
 GMESSAGE = mess(13,133,1) : # Champ inexistant dans cette table
 mkstat = 2 : Return
Endif
If find([M:ATB2]CODTYP(K-1),"AXX","AX1","AX2","AX3")
 GMESSAGE = mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : Return
Endif
Read [ATY]CODTYP = [M:ATB2]CODTYP(K-1)
If [F:ATY]TYPTYP>8
 GMESSAGE = mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : Return
Endif
mkstat = 0
Return

$SET_AUDIT
[M:ATB4]FLDTYP(NOL) = [F:ATY]CODTYP
If [M:ATB2]LONG(K-1)=0
 [M:ATB4]FLDLNG(NOL) = [F:ATY]LNGTYP
Else
 [M:ATB4]FLDLNG(NOL) = [M:ATB2]LONG(K-1)
Endif
[M:ATB4]FLDLIB(NOL) = 0
[M:ATB4]FLDSUP(NOL) = ""
If [F:ATY]NOLIB<>0
 [M:ATB4]FLDLIB(NOL) = [F:ATY]NOLIB
Elsif [M:ATB2]NOLIB(K-1)<>0
 [M:ATB4]FLDLIB(NOL) = [M:ATB2]NOLIB(K-1)
Elsif [M:ATB2]CODTYP(K-1)="ADI"
 Read [AMP]CODPAR=2;[M:ATB0]CODFIC;[M:ATB2]CODZONE(K-1);"ADI"
 If !fstat
  [M:ATB4]FLDLIB(NOL) = val(num$(evalue([F:AMP]VALPAR)))
  [M:ATB4]FLDSUP(NOL) = num$(evalue([F:AMP]VALPAR))
 Endif
Endif
[M:ATB4]FLDDES(NOL) = [M:ATB2]INTITCOURT(K-1)
Return

Subprog AS_FLDVAL(VALEUR)
Variable Char    VALEUR()
If [M]FLDOPE(nolign-1)=1
 mkstat = 1 : End
Endif
End

Subprog C_FLDOPE(VALEUR)
Variable Integer VALEUR
If VALEUR=8
 Read [ATY]CODTYP = [M]FLDTYP(nolign-1)
 If [F:ATY]TYPTYP<>7
  GMESSAGE = mess(16,127,1) : # Opérateur incorrect
  mkstat = 2 : End
 Endif
Endif
[M]FLDOPE(nolign-1) = VALEUR
Gosub GRISE_VAL
End

Subprog B1_NBCHP
Local Integer I , K , NOL , OK
Local Char    AUDFLD(GLONAVA)
OK = 0
For I=1 To [M:ATB2]NBZONE
 NOL = find([M:ATB2]CODZONE(I-1),[M:ATB4]FLD(0..[M:ATB4]NBCHP-1))
 If !NOL
  AUDFLD = [M:ATB2]CODZONE(I-1)
  Gosub VERF_AUDIT
  If !mkstat
   OK = 1
   K   = I
   NOL = [M:ATB4]NBCHP
   [M:ATB4]FLD(NOL)    = [M:ATB2]CODZONE(K-1)
   Gosub SET_AUDIT
   [M:ATB4]FLDOPE(NOL) = 1
   [M:ATB4]FLDVAL(NOL) = ""
   [M:ATB4]FLDINT(NOL) = ""
   [M:ATB4]NBCHP += 1
  Endif
 Endif
Next I
If OK
 Affzo [ATB4]
 mkstat = 4
Endif
End

Subprog AM_GENTRA(VALEUR)
Variable Integer VALEUR
Local Char DOSSUP(GLONADS)
Local Integer ER
If GADONIX=2 : End : Endif
Call PARAM("","SUPDOS",DOSSUP) From ADOVAL
If DOSSUP="" : End : Endif
Onerrgo ERFIC
Local File =DOSSUP+".ATABLE" [AT__]
Read [AT__]CODFIC=[M]CODFIC
If !fstat & !ER
 # Attention, cette modification nécessite une modification dans les états Crystal liés à cette table
 Call MESSAGE(mess(209,139,1)) From GESECRAN
Endif
Close Local File [AT__]
Onerrgo
End

$ERFIC
ER = errn
Resume

Subprog C_CHPLEG(VALEUR)
Variable Integer VALEUR

If VALEUR<=1 : End : Endif

Local Integer I , OK

Local File ATABLE  [ATB2]
Local File ATABZON [ATZ2]
Local File AMSKPAR [AMP2]

If instr(1,[M:ATB2]EXPLIEN(nolign-1),"[V]GSUPCLE")>0
 GMESSAGE = "[V]GSUPCLE"-":"-mess(102,123,1) : # Zone de lien incorrecte
 mkstat = 2 : End
Endif
If [M:ATB1]FLGLEG<>2
 GMESSAGE = mess(243,133,1) : # Table non gérée par législation
 mkstat = 2 : End
Endif
If [M:ATB2]LIEN(nolign-1)=""
 GMESSAGE = mess(248,133,1) : # Champ non géré par législation
 mkstat = 2 : End
Endif
OK = 1
For I=0 To [M:ATB2]NBZONE-1
 If [M:ATB2]CHPLEG(I)=2 & I<>nolign-1
  GMESSAGE = mess(244,133,1) : # Il y a déja un champ géré par législation
  mkstat = 2 : OK = 0 : Break
 Endif
Next
If !OK : End: Endif
If [M:ATB2]LIEN(nolign-1)<>"ATABDIV"
 Read [ATB2]CODFIC=[M:ATB2]LIEN(nolign-1)
 If !fstat
  If [F:ATB2]FLGLEG<>2
   OK = 0
  Endif
 Endif
Else
 Read [AMP]CODPAR=2;[M:ATB0]CODFIC;[M:ATB2]CODZONE(nolign-1);"ADI"
 If !fstat & num$(evalue([F:AMP]VALPAR))<>"909"
  OK = 0
 Elsif fstat
  GMESSAGE = [M:ATB2]CODZONE(nolign-1)-":"-mess(70,127,1) : # Paramètres du type de donnée ADI non renseignés
  OK = 0
 Endif
Endif
If OK
 For [ATZ2] Where CODFIC=[M:ATB2]LIEN(nolign-1) & CODTYP="ADI" & CHPLEG=2
  Read [AMP]CODPAR=2;[F:ATZ2]CODFIC;[F:ATZ2]CODZONE;"ADI"
  If !fstat & num$(evalue([F:AMP]VALPAR))<>"909"
   OK = 0
   Break
  Elsif fstat
   GMESSAGE = [F:ATZ2]CODZONE-":"-mess(70,127,1) : # Paramètres du type de donnée ADI non renseignés
   OK = 0
   Break
  Endif
 Next ATZ2
Endif
If !OK
 If GMESSAGE = ""
  GMESSAGE = mess(243,133,1) : # Table non gérée par législation
 Endif
 mkstat = 2 : End
Endif
End

Subprog AS_CHPLEG(VALEUR)
Variable Integer VALEUR
If [M:ATB2]LIEN(nolign-1)=""  or [M:ATB1]FLGLEG<>2 or [M:ATB2]LIEN(nolign-1)=[M:ATB0]CODFIC
 mkstat = 1 : End
Endif
If [M:ATB2]LIEN(nolign-1)<>"ATABDIV"
 Read [ATB2]CODFIC=[M:ATB2]LIEN(nolign-1)
 If !fstat
  If [F:ATB2]FLGLEG<>2
   mkstat = 1 : End
  Endif
 Endif
Endif
End

Subprog AV_AUDBI(VALEUR)
Variable Integer VALEUR
End

Subprog C_AUDBI(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIVDOS(nomap,"ABI") & filinfo(filpath("FIL","ABIREGORG","fde",nomap),0)>0 & VALEUR<>2
 Local File ABIREGORG [ABV]
 Local File ABIDIM    [ABI]
 Local Char REGLE(200),DIMENSION(200)
 For [ABV]ABV1 Where TABORG=[M:ATB0]CODFIC & DESFLG<>2
  REGLE -= [F:ABV]CODREG
 Next ABV
 For [ABI] Where TABORG=[M:ATB0]CODFIC & TYPMAJ=3
  DIMENSION-= [F:ABI]CODDIM
 Next ABV
 If REGLE<>""
  GMESSAGE = mess(96,127,1)+": \"+REGLE: # Cette table est auditée pour une règle de synchronisation BI
  mkstat = 2 : End
 Endif
 If DIMENSION<>""
  GMESSAGE = mess(103,127,1)+": \"+DIMENSION: # Cette table est auditée pour une dimension BI
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_ASDCLE(VALEUR)
Variable Char    VALEUR()
If dim([M]AUDSDA)<0 or [M]AUDSDA<>2
 mkstat = 1 : End
Endif
End

Subprog C_ASDCLE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR="" : End : Endif
OK = 0
If find(VALEUR,[M:ATB3]CODIND(0..[M:ATB3]NBINDEX-1))
 OK = 1
Else
 Read [ANX]ANX2=[M:ATB0]CODFIC;VALEUR
 If !fstat : OK = 1 : Endif
Endif
If !OK
 GMESSAGE = mess(1,127,1) : # Clé incorrecte
 mkstat = 2 : End
Endif
End

Subprog AM_AUDSDA(VALEUR)
Variable Integer VALEUR
[M]AUDSDA = VALEUR
Gosub GRISE_ASDCLE
End

