[M]AUDBI = VALEUR
Gosub GRISE_AUDCLE
End

Subprog C_ORDIND(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local Integer I, NOL
 NOL = nolign-1
 I = find(VALEUR,[M]ORDIND(0..NOL-1),[M]ORDIND(NOL+1..dim([M]ORDIND)-1))
 If I
  If I>NOL
   I += 1
  Endif
  GERR = 1
  GMESSAGE = func AFNC.MES1(mess(247,125,1),num$(I)) : # L'index cluster est déjà défini sur la ligne $1$
  mkstat=2 : End
 Endif
Endif
End

######################################################################################
Subprog C_SYMBOL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer I
 I=find(VALEUR,[M:ATB2]CODZONE)
 If I=0
  GMESSAGE = VALEUR-":"-mess(13,133,1) : # Champ inexistant sur la table
  mkstat=2 : End
 Elsif func ATY_TOOL.GET_INTERNAL_TYP_LM30([M:ATB2]CODTYP(I-1))<>7
  GMESSAGE = VALEUR-":"-mess(14,133,1) : # Type de données incorrect
  mkstat=2 : End
 Endif
Endif
[M]SYMBOL=VALEUR
Gosub GRISE_COL
End


