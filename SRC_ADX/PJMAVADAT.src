#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMAVADAT
# Issue X3-34419 - 2017-07-11 by FGR
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

##########################################################################################################
$DEBUT
  # -----------------------------
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  Effzo [M:PAVD0]1-99
  Effzo [M:PAVD1]1-99
  # -----------------------------
  [M:PAVD0]OPPNUM = PARAM(1)
  [M:PAVD0]TASCOD = PARAM(2)
  [M:PAVD0]ITMREF = PARAM(3)
  # -----------------------------
  [M:PAVD0]LINTAS = fmet GZINSPJM.PJM(1).TAS_GET_INDEX([M:PAVD0]TASCOD)
  [M:PAVD0]TASSTATE = GZINSPJM.PJM(1).TAS([M:PAVD0]LINTAS).TASSTATE
  # -----------------------------
  [M:PAVD0]LINITM = fmet GZINSPJM.PJM(1).TAS([M:PAVD0]LINTAS).RITT_GET_INDEX_ITMREF([M:PAVD0]ITMREF)
  [M:PAVD0]REQDAT = GZINSPJM.PJM(1).TAS([M:PAVD0]LINTAS).RITT([M:PAVD0]LINITM).REQDAT
  [M:PAVD0]UOM = GZINSPJM.PJM(1).TAS([M:PAVD0]LINTAS).RITT([M:PAVD0]LINITM).UOM
  [M:PAVD0]QTY = GZINSPJM.PJM(1).TAS([M:PAVD0]LINTAS).RITT([M:PAVD0]LINITM).ITTQTY
  # -----------------------------
  Call LOAD_PAGE()
Return

##########################################################################################################
Subprog LOAD_PAGE()

Local Integer NI
Local Decimal NSUMQTY
Local Date DAVADAT
Local Integer IAVADATSTA

  # -----------------------------
  NSUMQTY = func GET_SUM_QTY([M:PAVD0]OPPNUM, [M:PAVD0]TASCOD, [M:PAVD0]ITMREF, [M:PAVD0]UOM)
  #Call GET_AVADAT([M:PAVD0]OPPNUM, [M:PAVD0]TASCOD, [M:PAVD0]ITMREF, DAVADAT, IAVADATSTA)                          # Issue X3-62303 - 2017-11-24 by TEJAC
  Call GET_AVADAT([M:PAVD0]OPPNUM, [M:PAVD0]TASCOD, [M:PAVD0]ITMREF, 0, AVOID.ACHAR, 0, DAVADAT, IAVADATSTA)        # Issue X3-62303 - 2017-11-24 by TEJAC
  Chgstl [M:PAVD0]QTY With func GET_STYLE_ITTQTY(DAVADAT, [M:PAVD0]QTY, NSUMQTY, ([M:PAVD0]TASSTATE = 4))
  # -----------------------------
  If GMODU(8) = [V]CST_AYES Then
    # If manufacturing module
    Local File VPJMAVADATMF [PJAVDA]
  Else
    # If not
    Local File VPJMAVADAT [PJAVDA]
  Endif
  # -----------------------------
  nolign = 0
  Filter [PJAVDA] Where [F:PJAVDA]OPPNUM = [M:PAVD0]OPPNUM and [F:PJAVDA]TASCOD = [M:PAVD0]TASCOD and [F:PJAVDA]ITMREF = [M:PAVD0]ITMREF Order By [F:PJAVDA]DAT Desc
  For [PJAVDA]
    nolign += 1
    [M:PAVD1] = [F:PJAVDA]
    Case [M:PAVD1]AOB(nolign-1)
      When 1
        # Purchase order
        [M:PAVD1]AOBCOD(nolign-1) = "POH"
        [M:PAVD1]KEYCOD(nolign-1) = [M:PAVD1]POHNUM(nolign-1)
        [M:PAVD1]STA(nolign-1) = mess(3,17,1) - ":" - mess([F:PJAVDA]STA,1,1)
      When 2
        # Work orders
        [M:PAVD1]AOBCOD(nolign-1) = "MFG"
        [M:PAVD1]KEYCOD(nolign-1) = [M:PAVD1]MFGNUM(nolign-1)
        [M:PAVD1]STA(nolign-1) = mess([F:PJAVDA]STA,363,1)
      When 3
        # Sub-contracts
        [M:PAVD1]AOBCOD(nolign-1) = "SCO"
        [M:PAVD1]KEYCOD(nolign-1) = [M:PAVD1]SCONUM(nolign-1)
        [M:PAVD1]STA(nolign-1) = mess([F:PJAVDA]STA,2221,1)
      When Default
        [M:PAVD1]AOBCOD(nolign-1) = ""
        [M:PAVD1]KEYCOD(nolign-1) = ""
        [M:PAVD1]STA(nolign-1) = ""
    Endcase
    # Issue X3-49591 - 2017-07-21 by FGR : BEGIN
    Call SET_AVADATSTA([M:PAVD1]AVADATSTA(nolign-1))
    [M:PAVD1]UOMITM(nolign-1) = [M:PAVD0]UOM
    [M:PAVD1]QTYITM(nolign-1) = func CONVERT_QTY([M:PAVD1]UOM(nolign-1), [M:PAVD1]UOMITM(nolign-1), [M:PAVD1]QTY(nolign-1))
    # Issue X3-49591 - 2017-07-21 by FGR : END
  Next
  Filter [PJAVDA]
  [M:PAVD1]NBLIG = nolign
  Affzo [M:PAVD1]1-99
  # -----------------------------
  If [M:PAVD0]REQDAT <> [0/0/0] Then
    For NI = 0 To [M:PAVD1]NBLIG-1
      # Issue X3-49591 - 2017-07-21 by FGR : BEGIN
      Chgstl [M:PAVD1]DAT(NI) With func GET_STYLE_REQDATE([M:PAVD0]REQDAT, [M:PAVD1]DAT(NI), ([M:PAVD1]AVADATSTA(NI) = [V]CST_AYES or [M:PAVD0]TASSTATE = 4))
      # Issue X3-34419 - 2017-07-11 by FGR : END
    Next NI
    Affzo [M:PAVD1]1-99
  Endif
  # -----------------------------
End

##########################################################################################################
# SUBROUTINES
##########################################################################################################
Funprog GET_SUM_QTY(SOPPNUM, STASCOD, SITMREF, SUOM)
Value Char SOPPNUM
Value Char STASCOD
Value Char SITMREF
Value Char SUOM

Local Decimal NARENDRE
Local Char SKEYCONCAT(250)

  # Issue X3-49591 - 2017-07-21 by FGR
  NARENDRE = 0
  If GMODU(8) = [V]CST_AYES Then
    # If manufacturing module
    Local File VPJMAVADATMF [PJAVDA]
  Else
    # If not
    Local File VPJMAVADAT [PJAVDA]
  Endif
  SKEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, SOPPNUM, STASCOD)
  Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF
  For [PJAVDA]
    NARENDRE += func CONVERT_QTY([F:PJAVDA]UOM, SUOM, [F:PJAVDA]QTY)
  Next
  Filter [PJAVDA]
End NARENDRE

##########################################################################################################
Funprog CONVERT_QTY(SFROMUOM, STOUOM, NFROMQTY)
Value Char SFROMUOM
Value Char STOUOM
Value Decimal NFROMQTY

Local Decimal NARENDRE

  # Issue X3-49591 - 2017-07-21 by FGR
  NARENDRE = NFROMQTY
  If SFROMUOM <> STOUOM Then
    Call CONVERT_QTY(GACTX, SFROMUOM, STOUOM, NARENDRE) From TRTX3_SYRA
  Endif
End NARENDRE

##########################################################################################################
Funprog GET_STYLE_REQDATE(DREQDAT, DAVADAT, ICLOSED)
Value Date DREQDAT
Value Date DAVADAT
Value Integer ICLOSED

Local Char SARENDRE(250)

  # Issue X3-49591 - 2017-07-21 by FGR
  SARENDRE = AVOID.ACHAR
  If ICLOSED = [V]CST_AFALSE Then
    If DREQDAT <> [0/0/0] and DAVADAT <> [0/0/0] Then
      If DREQDAT < DAVADAT Then
        SARENDRE = "PJMWARN1"
      Elsif DREQDAT >= DAVADAT Then
        SARENDRE = "PJMWARN2"
      Endif
    Endif
  Endif
End SARENDRE

##########################################################################################################
Funprog GET_STYLE_ITTQTY(DAVADAT, NITTQTY, NSUMQTY, ICLOSED)
Value Date DAVADAT
Value Decimal NITTQTY
Value Decimal NSUMQTY
Value Integer ICLOSED

Local Char SARENDRE(250)
Local Char SKEYCONCAT(250)

  # Issue X3-49591 - 2017-07-21 by FGR
  SARENDRE = AVOID.ACHAR
  If ICLOSED = [V]CST_AFALSE and DAVADAT <> [0/0/0] Then
    If NITTQTY > NSUMQTY Then
      SARENDRE = "PJMWARN1"
    Elsif NITTQTY = NSUMQTY Then
      SARENDRE = "PJMWARN2"
    Elsif NITTQTY < NSUMQTY Then
      SARENDRE = "PJMWARN3"
    Endif
  Endif
End SARENDRE

##########################################################################################################
#Subprog GET_AVADAT(SOPPNUM, STASCOD, SITMREF, DAVADAT, IAVADATSTA)                      # Issue X3-62303 - 2017-11-24 by TEJAC
Subprog GET_AVADAT(SOPPNUM, STASCOD, SITMREF, IAOB, SNUM, INUMLIN, DAVADAT, IAVADATSTA)  # Issue X3-62303 - 2017-11-24 by TEJAC
Value Char SOPPNUM
Value Char STASCOD
Value Char SITMREF
Value Integer IAOB                                                                       # Issue X3-62303 - 2017-11-24 by TEJAC
Value Char SNUM                                                                          # Issue X3-62303 - 2017-11-24 by TEJAC
Value Integer INUMLIN                                                                    # Issue X3-62303 - 2017-11-24 by TEJAC
Variable Date DAVADAT
Variable Integer IAVADATSTA

Local Char SKEYCONCAT(250)

  # Issue X3-49591 - 2017-07-21 by FGR
  Raz DAVADAT
  IAVADATSTA = [V]CST_ANO
  If GMODU(8) = [V]CST_AYES Then
    # If manufacturing module
    Local File VPJMAVADATMF [PJAVDA]
  Else
    # If not
    Local File VPJMAVADAT [PJAVDA]
  Endif
  SKEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, SOPPNUM, STASCOD)
  # Issue X3-62303 - 2017-11-24 by TEJAC : START
  #Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF Order By DAT Desc
  If IAOB <> 0 Then
    Case IAOB
      When 1
        # Purchase orders
        Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF and [F:PJAVDA]POHNUM = SNUM and [F:PJAVDA]POPLIN = INUMLIN
      When 2
        # Work orders
        Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF and [F:PJAVDA]MFGNUM = SNUM and [F:PJAVDA]MFGLIN = INUMLIN
      When 3
        # Sub-contracts
        Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF and [F:PJAVDA]SCONUM = SNUM and [F:PJAVDA]SCILIN = INUMLIN
    Endcase
  Else
    Filter [PJAVDA] Where [F:PJAVDA]PJT = SKEYCONCAT and [F:PJAVDA]ITMREF = SITMREF Order By DAT Desc
  Endif
  # Issue X3-62303 - 2017-11-24 by TEJAC : END
  For [PJAVDA]
    DAVADAT = [F:PJAVDA]DAT
    Call SET_AVADATSTA(IAVADATSTA)
    Break
  Next
  Filter [PJAVDA]
End

##########################################################################################################
Subprog SET_AVADATSTA(IAVADATSTA)
Variable Integer IAVADATSTA

  # Issue X3-49591 - 2017-07-21 by FGR
  IAVADATSTA = [V]CST_ANO
  Case [F:PJAVDA]AOB
    When 1
      # Purchase order POH
      If [F:PJAVDA]STA = [V]CST_AYES Then
        IAVADATSTA = [V]CST_AYES
      Endif
    When 2
      # Work orders MFG
      If [F:PJAVDA]STA = 3 Then
        IAVADATSTA = [V]CST_AYES
      Endif
    When 3
      # Sub-contracts SCO
      If [F:PJAVDA]STA = 5 Then
        IAVADATSTA = [V]CST_AYES
      Endif
  Endcase
End

#######################################################################################
Funprog IS_AVADAT_RECORD_EXIST(ACTX, SOPPNUM, STASCOD, SITMREF, IAOB)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char STASCOD
Value Char SITMREF
Value Integer IAOB

Local Integer IARENDRE

  # Issue X3-48904 - 2017-07-26 by SINGC
  IARENDRE = [V]CST_ANO
  If GMODU(8) = [V]CST_AYES Then
    # If manufacturing module
    Local File VPJMAVADATMF [PJAVDA]
  Else
    # If not
    Local File VPJMAVADAT [PJAVDA]
  Endif
  # -----------------------------
  Filter [PJAVDA] Where [F:PJAVDA]OPPNUM = SOPPNUM and [F:PJAVDA]TASCOD = STASCOD and [F:PJAVDA]ITMREF = SITMREF and [F:PJAVDA]AOB = IAOB
  For [PJAVDA]
    IARENDRE = [V]CST_AYES
    Break
  Next
  # -----------------------------
End IARENDRE

