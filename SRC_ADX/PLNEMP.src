#<AdxTL>@(#)0.0.0.0 $Revision$
#**********************************************************
#* Modifications :
#*    FQ85820 - 29/04/13 - prise en compte date d'effet + fiches de rétroactivité
#**********************************************************
#*!
# Gestion du masque PLNEMP

Local Char PARAM(30)(1..3) , VALEUR(10)
PARAM(1) = "ASN200200000015"
PARAM(2) = "20090330"
PARAM(3) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"WFPLE","PLNEMP","XWPLNEMP") From GSAISIE
End

$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE From PLNEMP2
 When "OUVRE"       : Gosub OUVRE From PLNEMP2
 When "DEBUT"       : Gosub DEBUT From PLNEMP2
 When "ENR"         : Gosub ENREGISTRE From PLNEMP2
 When "ABA"         : Gosub ABANDON From PLNEMP2
 When "END"         : Gosub FIN From PLNEMP2
 When "APRES_MODIF" : Gosub APRES_MODIF From PLNEMP2
 When "SETBOUT"     : Gosub SETBOUT From PLNEMP2
 When "MEN"         : Gosub MENU From PLNEMP2
 When "SUI"         : Gosub SUI From PLNEMP2
 When "PRE"         : Gosub PRE From PLNEMP2
 When "FIR"         : Gosub FIR From PLNEMP2
 When "LAS"         : Gosub LAS From PLNEMP2
 When "BOUTON"      : Gosub BOUTON From PLNEMP2
 When Default
Endcase
Return

######################################################################################
## Etiquette écran WMPLE
######################################################################################

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
Read [ID]ID0 = VALEUR
[M:PLE0]NAM = [F:ID]NAM-[F:ID]SRN
Affzo [M:PLE0]NAM
Raz [M:PLE0]CTRNUM
# FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
# D'où l'ajout du test sur FLGINT
If [F:ID]FLGMULCTR<>2
#If [F:ID]FLGMULCTR<>2 & [F:ID]FLGINT<>2
 Effzo [M:PLE0]CTRNUM
 #ADNGO - 2017-01-30 - X3-11992 - START
 #Diszo [M:PLE0]CTRNUM
 #ADNGO - 2017-01-30 - X3-11992 - END
Else
 Actzo [M:PLE0]CTRNUM
Endif
Affzo [M:PLE0]CTRNUM
# FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
# D'où l'ajout du test sur FLGINT
If [F:ID]FLGMULCTR<>2
#If [F:ID]FLGMULCTR<>2 & [F:ID]FLGINT<>2
 If [M:PLE0]YEA<>0 & [M:PLE0]NUMWEK<>0
  [M:PLE0]REFNUM = VALEUR
  Gosub REMP_CTR From PLNEMP2
  Gosub CHARGE From PLNEMP2
 Endif
Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Date DEBUT,FIN
If [M:PLE0]YEA<>0 & [M:PLE0]NUMWEK<>0
#MIPEA - 2017-11-26- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = VALEUR
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END
 Call SEMAINE([M:PLE0]YEA,[M:PLE0]NUMWEK,DEBUT,FIN) From SUBPLN
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
# Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & CTRDAT<=FIN
#ADNGO - 2017-01-13 - X3-11992 - START
 #Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=VALEUR & (CTRDAT<=FIN | (FLGRET=2 & RETDATEFF<=FIN))
 Filter [HRCTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=VALEUR & (CTRDAT<=FIN | (FLGRET=2 & RETDATEFF<=FIN))
#ADNGO - 2017-01-13 - X3-11992 - END
 # Fin MABON
Else
#ADNGO - 2017-01-13 - X3-11992 - START
 #Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=VALEUR
 Filter [HRCTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=VALEUR
#ADNGO - 2017-01-13 - X3-11992 - END
Endif
#ADNGO - 2017-01-13 - X3-11992 - START
#Read [CTR]CTR0 Last
#Filter [CTR]
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#ADNGO - 2017-01-13 - X3-11992 - END
If !fstat
 # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
# [M]FCY    = [F:CTR]ETRFCY
# [M]SRV    = [F:CTR]ETRSRV
#ADNGO - 2017-01-13 - X3-11992 - START
 #[M:PLE0]FCY=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,VALEUR,[F:CTR]CTRDAT,FIN,"ETRFCY","CTR")
 #[M:PLE0]SRV=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,VALEUR,[F:CTR]CTRDAT,FIN,"ETRSRV","CTR")
 [M:PLE0]FCY=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,VALEUR,[F:HRCTR]CTRDAT,FIN,"ETRFCY","HRCTR")
 [M:PLE0]SRV=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,VALEUR,[F:HRCTR]CTRDAT,FIN,"ETRSRV","HRCTR")
#ADNGO - 2017-01-13 - X3-11992 - END
 # Fin FQ85820
 Affzo [M:PLE0]FCY, SRV
Endif
If [M:PLE0]YEA<>0 & [M:PLE0]NUMWEK<>0
 [M:PLE0]CTRNUM = VALEUR
 Gosub CHARGE From PLNEMP2
Endif

Actzo [M:PLE0]CTRNUM
End

Subprog C_NUMWEK(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
#MIPEA - 2017-11-26- US X3-63170- START
If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
Read [F:HRCTR8] Last
Filter [F:HRCTR8]
Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END
Call VERIF_SEM([M:PLE0]YEA,VALEUR,OK)
If OK=0
#ADNGO - 2017-01-13 - X3-11992 - START
 #GMESSAGE = mess(150,709,1)-num$([M:PLE0]YEA) : # Semaine inexistante dans l'année XXXX
 GMESSAGE = mess(150,10709,1)-num$([M:PLE0]YEA) : # Semaine inexistante dans l'année XXXX
#ADNGO - 2017-01-13 - X3-11992 - END
 mkstat = 2 : End
Endif
End

Subprog VERIF_SEM(AN,SEM,OK)
Value    Integer AN, SEM
Variable Integer OK
Local    Date    DEBUT, FIN
Local    Integer ANNEE, SEMAINE
OK = 0
Call SEMAINE(AN,SEM,DEBUT,FIN) From SUBPLN
Call DAT(DEBUT,ANNEE,SEMAINE) From SUBPLN
If ANNEE=AN & SEMAINE=SEM
 OK = 1
Endif
End

Subprog AM_NUMWEK(VALEUR)
Variable Decimal VALEUR
If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
Read [ID]ID0 = [M:PLE0]REFNUM
If [M:PLE0]REFNUM<>"" & [M:PLE0]YEA<>0
 [M:PLE0]NUMWEK = VALEUR
 # FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
 # D'où l'ajout du test sur FLGINT
 If [F:ID]FLGMULCTR<>2
# If [F:ID]FLGMULCTR<>2 & [F:ID]FLGINT<>2
  Gosub REMP_CTR From PLNEMP2
 Endif
 Gosub CHARGE  From PLNEMP2
Endif
End

Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
Local Integer OK
If [M:PLE0]REFNUM<>"" & [M:PLE0]NUMWEK<>0
 [M:PLE0]YEA = VALEUR
#MIPEA - 2017-11-26- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END
 Call VERIF_SEM([M:PLE0]YEA,[M:PLE0]NUMWEK,OK)
 If OK=1
 # FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
 # D'où l'ajout du test sur FLGINT
 If [F:ID]FLGMULCTR<>2
# If [F:ID]FLGMULCTR<>2 & [F:ID]FLGINT<>2
  Gosub REMP_CTR From PLNEMP2
 Endif
 Gosub CHARGE From PLNEMP2
 Endif
Endif
End

