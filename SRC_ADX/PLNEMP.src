Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
  GCURLEG = ""
  Raz [M:PLE0]LEG
End
######################################################################################
#ADNGO - 2017-01-25 - X3-11992 - START
Subprog C_YEA(VALEUR)
Variable Decimal    VALEUR()
If VALEUR<1900
 GMESSAGE = mess(106,10709,1) : # Année incorrecte
 mkstat = 2 : End
Endif
End
#ADNGO - 2017-01-25 - X3-11992 - END

######################################################################################
## Section automatically added (screen WMPLE0) 01/31/2017 14:59:48 (ADNGO)
######################################################################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-01-31 - X3-11992 - START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] First
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:PLE0]LEG = GCURLEG
    Endif
#ADNGO - 2017-01-31 - X3-11992 - END
End


