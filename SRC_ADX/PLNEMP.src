######################################################################################
## ENDTIM
######################################################################################

$PLG_NUL
Local Integer I
If VALEUR=""
 Effzo ="STRTIM"+PLG
 Effzo ="ENDTIM"+PLG
 Effzo ="BRKTIM"+PLG
 Effzo ="NATCOD"+PLG
 For I=1 To GOPTCANA
  If evalue("dim([M]CCE"+num$(I)+PLG+")")>0
   Effzo ="[M]CCE"+num$(I)+PLG
  Elsif evalue("dim([M]ICCE"+num$(I)+")")>0
   Effzo ="[M]ICCE"+num$(I)+"("+IND+")"
  Endif
 Next
Endif
Return

Subprog C_ENDTIM11(VALEUR)
Variable Char    VALEUR()
Local Char PLG(2), IND(2)
PLG = "11" : IND = "0"
If [M]STRTIM11="" & VALEUR<>""
 Raz VALEUR
Endif
Gosub PLG_NUL
If GNBHOR>=2
 Call CTRL_TIM(VALEUR,[M]STRTIM12,[M]ENDTIM12,"2","2",[M]STRTIM11) From SUBSTY
 If mkstat : End : Endif
Endif
If GNBHOR=3
 Call CTRL_TIM(VALEUR,[M]STRTIM13,[M]ENDTIM13,"3","2",[M]STRTIM11) From SUBSTY
 If mkstat : End : Endif
Endif
End

