######################################################################################
## NBRDAY
######################################################################################

Subprog AS_NBRDAY(VALEUR)
Variable Decimal VALEUR
Local    Char    NUM(1)

  NUM=mid$(zoncou,7,1)
  If evalue("[M]TYPDAY"+NUM)=3 : # Jour chômé
   mkstat = 1 : End
  Endif
  If evalue("[M]NBRHOU"+NUM)<>0 & VALEUR=0
   VALEUR = 1
  Endif
End

Subprog C_NBRDAY(VALEUR)
Variable Decimal VALEUR
Local    Char    NUM(1)

  NUM=mid$(zoncou,7,1)
  If VALEUR>1
  #ADNGO - 2017-01-13 - X3-11992 - START
   #GMESSAGE = mess(110,702,1) : # Le nombre de jours ne doit pas dépasser 1
   GMESSAGE = mess(110,10702,1) : # Le nombre de jours ne doit pas dépasser 1
  #ADNGO - 2017-01-13 - X3-11992 - END
   mkstat   = 2 : End
  Endif
  If (VALEUR<>0 & evalue("[M]NBRHOU"+NUM)=0) | (VALEUR=0 & evalue("[M]NBRHOU"+NUM)<>0)
  #ADNGO - 2017-01-13 - X3-11992 - START
   #GMESSAGE = mess(117,709,1) : # Nombre d'heures incorrect
   GMESSAGE = mess(117,10709,1) : # Nombre d'heures incorrect
  #ADNGO - 2017-01-13 - X3-11992 - END
   mkstat   = 2 : End
  Endif
End

