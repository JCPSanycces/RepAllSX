Subprog AS_BRKTIM11(VALEUR)
Variable Decimal VALEUR
If [M]TYPDAY1=3 : # Chômé
 mkstat = 1 : End
Endif
If [M]STRTIM11=""
 mkstat=1 : End
Endif
End

Subprog C_BRKTIM_GEN(VALEUR)
Variable Decimal VALEUR
Local    Decimal VALHMDEB, VALHMFIN, TOTH
Local    Char    DJR(1), PLA(1)

  DJR=mid$(zoncou,7,1)
  PLA=mid$(zoncou,8,1)
  TOTH = evalue("[M]NBRHOU"+DJR)-VALEUR+evalue("[M]BRKTIM"+DJR+PLA)
  Call CONVERTHM(evalue("[M]STRTIM"+DJR+PLA),VALHMDEB) From SUBSTY
  Call CONVERTHM(evalue("[M]ENDTIM"+DJR+PLA),VALHMFIN) From SUBSTY
  Gosub C_BRKTIM
End

Subprog AS_BRKTIM(VALEUR)
Variable Decimal VALEUR
Local    Char    DJR(1), PLA(1)

  DJR=mid$(zoncou,7,1)
  PLA=mid$(zoncou,8,1)
  If evalue("[M]TYPDAY"+DJR)=3 : # Chômé
   mkstat = 1 : End
  Endif
  If evalue("[M]STRTIM"+DJR+PLA)=""
   mkstat=1 : End
  Endif
End

Subprog C_BRKTIM11(VALEUR)
Variable Decimal VALEUR

  Call C_BRKTIM_GEN(VALEUR)
End

