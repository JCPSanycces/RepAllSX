Subprog C_STRTIM11(VALEUR)
Variable Char    VALEUR()
Local Char PLG(2), IND(2)
PLG = "11" : IND = "0"
Gosub PLG_NUL
If GNBHOR>=2
 Call CTRL_TIM(VALEUR,[M]STRTIM12,[M]ENDTIM12,"2","1","") From SUBSTY
 If mkstat : End : Endif
Endif
If GNBHOR=3
 Call CTRL_TIM(VALEUR,[M]STRTIM13,[M]ENDTIM13,"3","1","") From SUBSTY
 If mkstat : End : Endif
Endif
End

