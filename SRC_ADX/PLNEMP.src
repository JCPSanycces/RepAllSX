######################################################################################
## AS_CCE
######################################################################################

$AS_CCE
Local Integer AXE,COL,PLA

AXE=val(mid$(zoncou,4,1))
COL=val(mid$(zoncou,5,1))
PLA=val(mid$(zoncou,6,1))

If evalue("[M]TYPDAY"+num$(COL))=3 : # Jour chômé
 mkstat = 1 : Return
Endif
If AXE>[M:PLE0]NBRDIE Then mkstat=2 : Return : Endif

If GNBHOR>0 & evalue("[M]STRTIM"+num$(COL)+num$(PLA))="" & evalue("[M]ENDTIM"+num$(COL)+num$(PLA))=""
 mkstat = 1 : Return
Endif

Local Char SAU_GSOCIETE(GLONCPY)
SAU_GSOCIETE=GSOCIETE
If clalev([F:TIM])=0 : Local File TIMCOD   [TIM] : Endif
If clalev([F:NAT])=0 : Local File NATACTIV [NAT] : Endif
#ADNGO - 2017-01-13 - X3-11992 - START
#Call LECTURE("TIM",GTPSW,"") From CONTOBJ
Call LECTURE("HRTIM",GTPSW,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-13 - X3-11992 - END
#ADNGO - 2017-01-25 - X3-11992 - START
#Call LECTURE("NAT",evalue("[M]NATCOD"+num$(COL)+num$(PLA)),"") From CONTOBJ
Call LECTURE("NAT",evalue("[M]NATCOD"+num$(COL)+num$(PLA)),GCURLEG) From CONTOBJ
#ADNGO - 2017-01-25 - X3-11992 - END
# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRFCY
#Call LECTURE("CPY",func DIVPAYE.GETSOC([F:CTR]ETRFCY),"") From CONTOBJ
Local Date DEBUT,FIN
If [M:PLE0]YEA<>0 & [M:PLE0]NUMWEK<>0
#MIPEA - 2017-11-26- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END
 Call SEMAINE([M:PLE0]YEA,[M:PLE0]NUMWEK,DEBUT,FIN) From SUBPLN
Endif
#ADNGO - 2017-01-13 - X3-11992 - START
#Call LECTURE("CPY",func DIVPAYE.GETSOC(func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:CTR]CTRDAT,FIN,"ETRFCY","CTR")),"") From CONTOBJ
Call LECTURE("CPY",func DIVPAYE.GETSOC(func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:HRCTR]CTRDAT,FIN,"ETRFCY","HRCTR")),"") From CONTOBJ
#ADNGO - 2017-01-13 - X3-11992 - END
# Fin FQ85820
Local Integer AXE_TIM
AXE_TIM=find([M:PLE0]DIE(AXE-1),[F:TIM]DIE)
If AXE_TIM>0 Then
#  If [F:TIM]CCEDAC(AXE_TIM-1)<>2 : # Axe non saisissable
#   VALEUR = ""
#  # Call INICCE(GTPSW,AXE,VALEUR) From TPSSTD
#   GSOCIETE=func DIVPAYE.GETSOC([M]FCYD(COL))
#   If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
#   Call INICCE(evalue("[M:PLE"+num$(PLA)+"]NATCOD"+num$(COL)+num$(PLA)),GTPSW,AXE_TIM,VALEUR) From TPSDIV
#   GSOCIETE=SAU_GSOCIETE
#   mkstat = 2 : Return
#  Endif
#  # FQ92876 - 03/06/14 - Pour une date donnée, il n’est pas possible de saisir une section sur un axe non suivi par la société du contrat
#  # et période d’activité
#  Local Integer OKDIE
#  Call CPY_AXE (AXE, [M:PLE0]FCYD(COL-1), OKDIE) From TPSDIV
#  If !OKDIE Then mkstat = 2 : Return : Endif
#
#  # Axe saisissable non initialisé
#  If !mkstat & [F:TIM]CCEDAC(AXE_TIM-1)=2 & VALEUR=""
#   GSOCIETE=func DIVPAYE.GETSOC([M]FCYD(COL))
#   If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
#   Call INICCE(evalue("[M:PLE"+num$(PLA)+"]NATCOD"+num$(COL)+num$(PLA)),GTPSW,AXE_TIM,VALEUR) From TPSDIV
#   GSOCIETE=SAU_GSOCIETE
#  Endif

  # FQ92876 - 03/06/14 - Pour une date donnée, il n’est pas possible de saisir une section sur un axe non suivi par la société du contrat
  # et période d’activité
  Local Integer OKDIE
  Call CPY_AXE (AXE, [M:PLE0]FCYD(COL-1), OKDIE) From TPSDIV
  If !OKDIE Then mkstat = 2 : Return : Endif

  If [F:TIM]CCEDAC(AXE_TIM-1)<>2 : # Axe non saisissable
   VALEUR = ""
  Endif

  # Axe non initialisé
  If !mkstat & VALEUR=""
   GSOCIETE=func DIVPAYE.GETSOC([M]FCYD(COL-1))
   If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
   Call INICCE(evalue("[M:PLE"+num$(PLA)+"]NATCOD"+num$(COL)+num$(PLA)),GTPSW,AXE_TIM,VALEUR) From TPSDIV
   GSOCIETE=SAU_GSOCIETE
  Endif

  If [F:TIM]CCEDAC(AXE_TIM-1)<>2 : # Axe non saisissable
   mkstat = 2 : Return
  Endif
Else
  mkstat = 2 : Return
Endif
Return

