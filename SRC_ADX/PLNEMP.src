$C_BRKTIM
Local Decimal VALHOU
If (VALHMFIN>=VALHMDEB & VALEUR>=VALHMFIN-VALHMDEB)|(VALHMFIN<VALHMDEB & VALEUR>=24-VALHMDEB+VALHMFIN)
 # Temps de pause incorrect
#ADNGO - 2017-01-13 - X3-11992 - START
 #GMESSAGE = mess(115,709,1)
 GMESSAGE = mess(115,10709,1)
#ADNGO - 2017-01-13 - X3-11992 - END
 mkstat = 2 : Return
Endif
VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M:PLE0]FCY))
If VALHOU>0 & TOTH>VALHOU
 # Maximum d'heures par jour
#ADNGO - 2017-01-13 - X3-11992 - START
 #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU)
 GMESSAGE = mess(4,10709,1)-":"-num$(VALHOU)
#ADNGO - 2017-01-13 - X3-11992 - END
 mkstat = 2 : Return
Endif
Return

######################################################################################
## NBRHOU
######################################################################################

Subprog AS_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local    Decimal SUMHRS
Local    Char    NUM(1)

  NUM=mid$(zoncou,7,1)
  If evalue("[M]TYPDAY"+NUM)=3 : # Jour chômé
   mkstat = 1 : End
  Endif
  Gosub MASK_CCE From PLNEMP2
  Call SUMHRS(NUM,SUMHRS) From PLNEMP2
  If SUMHRS
   VALEUR = SUMHRS
  Endif
  If GNBHOR>0
   mkstat=2 : End
  Endif
End

Subprog C_NBRHOU(VALEUR)
Variable Decimal VALEUR
Local    Decimal SUMHRS
Local    Char    NUM(1)

  NUM=mid$(zoncou,7,1)
  Call SUMHRS(NUM,SUMHRS) From PLNEMP2
  If VALEUR<>SUMHRS & SUMHRS
  #ADNGO - 2017-01-13 - X3-11992 - START
   #GMESSAGE = mess(117,709,1) : # Nombre d'heures incorrect
   GMESSAGE = mess(117,10709,1) : # Nombre d'heures incorrect
  #ADNGO - 2017-01-13 - X3-11992 - END
   mkstat   = 2 : End
  Endif
End

