#<AdxTL>@(#)7.0.0.0 $Revision$
################################################################################
## Etat LIVRESTD
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Droits d'accés
# 05/07/2011 DLE : corr #74709
#################################################################################

Call IMPRIME("LIVRESTD","") From ETAT
End

####################################################
## Etat livrepaye
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:HSP])=0 : Local File HISTOPAYE   [HSP] : Endif
If clalev([F:VEP])=0 : Local File VALEMP      [VEP] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP    [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE    [RUB] : Endif
If clalev([F:TMP])=0 : Local File TMPLIVRESTD [TMP] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE      [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA     [AXX] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA      [HRPOA] : Endif
If clalev([F:ACC])=0 : Local File ACCES       [ACC] : Endif
If clalev([F:CUM])=0 : Local File CUMUL       [CUM] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR      [ECT] : Endif
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
If clalev([F:SRV])=0 : Local File SERVICE     [SRV] : Endif

Gosub OUVRE From WPDEFTABLE

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Date    DATEDEB , DATEFIN
Local Integer RUBDEB , RUBFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV)
Local Char    CRIT1(250), CRIT2(250)
Local Integer I , J , K , NBMOIS , GROUPE , NUMREQ , LIGTMP , OK
Local Char    MATRI(GLONEML) , POPULATION(GLONPOP), CTR(GLONHRCTR)
Local Date    DATMAT
Local Integer NCOL , ICOL
Local Integer NBRUB , MAXRUB
Local Integer DETSAL , DETRUB
Local Integer NBSAL , NBVEP
Local Integer TEST
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
Local Char    SVFONCTION(GLONAFC)

TEST = 0

NCOL   = 8
MAXRUB = nbrecord([F:RUB])+10

Local Integer TBRUB(1..MAXRUB)
Local Char TBCRUB(GLONRUB)(1..MAXRUB)
Local Integer OKSAL
Local Char    TBMAT(GLONEML)(1..NCOL)
Local Decimal RESULT(1..MAXRUB,1..NCOL)
Local Decimal TOTRUB(1..MAXRUB) , TOTLIG

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("rubdeb",NBPAR,PARAMETRE,PARAM) : RUBDEB = val(PARAM)
Call GETPARAM("rubfin",NBPAR,PARAMETRE,PARAM) : RUBFIN = val(PARAM) : If RUBFIN=0 : RUBFIN = 999999 : Endif
Call GETPARAM("detsal",NBPAR,PARAMETRE,PARAM) : DETSAL = val(PARAM)
Call GETPARAM("detrub",NBPAR,PARAMETRE,PARAM) : DETRUB = !val(PARAM)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
Call SETPARAM("user",NBPAR,PARAMETRE,GUSER) From ETAT

Read [CPY]CPY0 = SOCIETE
If fstat
 Call ERREUR(mess(65,10702,1)) From GESECRAN : # Société inexistante
 GOK = 0 : End
Endif
Call SETPARAM("nomsoc",NBPAR,PARAMETRE,[F:CPY]CPYNAM) From ETAT

Call TEMPON("O") From GESECRAN

## Critère salarié

CRIT1 = '1=1'
If MATDEB<>""
 CRIT1 -= '& [F:ID]REFNUM>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRIT1 -= '& [F:ID]REFNUM<="'+MATFIN+'"'
Endif

## Critère feuille de paye : site, profil, service

CRIT2  =   '[F:VEP]PYRDAT>=['+format$(GFMD,DATEDEB)+']'
CRIT2 -= '& [F:VEP]PYRDAT<=['+format$(GFMD,DATEFIN)+']'
If SITEDEB<>""
 CRIT2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRIT2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRIT2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRIT2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif

## Critère population, société + link

If POPULATION<>""
 Link [VEP]
& With [F:ID]ID0    = [F:VEP]EMP
&    , [F:FGR]FGR0 ~= SOCIETE;[F:VEP]FCY
&    , [F:HRPOA]POA0 ~= POPULATION;[F:ID]REFNUM
& As [LVEP]
& Where evalue(CRIT1) & evalue(CRIT2)
& Order By Key CLE = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]BUL
Else
 Link [VEP]
& With [F:ID]ID0    = [F:VEP]EMP
&    , [F:FGR]FGR0 ~= SOCIETE;[F:VEP]FCY
& As [LVEP]
& Where evalue(CRIT1) & evalue(CRIT2)
& Order By Key CLE = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]BUL
Endif

# Lecture rubriques

NBRUB = 0
If !DETRUB
 Filter [RUB] Where AMTPRN>1 and LEG=GCURLEG
Else
  Filter [RUB] Where LEG=GCURLEG
Endif
For [RUB]RUB1 Where ROW>=RUBDEB & ROW<=RUBFIN
 NBRUB += 1
 TBRUB(NBRUB) = [F:RUB]ROW
 [L]TBCRUB(NBRUB) = [F:RUB]COD
Next
Filter [RUB]

# Transaction

If TEST
 Call OUVRE_TRACE("") From LECFIC
Endif
Call DEBTRANS From GLOCK
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION) From ETAT
Call AUTORIS From EXEFNC

Gosub TR1

# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC

Call TEMPOFF From GESECRAN
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End



$TR1
GOK = 1
Raz NBSAL , NBVEP
LIGTMP = 0
GROUPE = 0
Trbegin [TMP]
 Delete [TMP] Where USR=GUSER & DAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPLIVRE"-GUSER : Goto ROLL_TR1
 Endif

 Raz ICOL, TBMAT, RESULT

 For [LVEP]CLE(1)   : # Salarié
  NBSAL += 1
  MATRI  = [F:VEP]EMP
  OKSAL  = 0

  For [LVEP]CLE(2)  : # Salarié+Contrat
   CTR    = [F:VEP]CTRNUM

   For [LVEP]CLE    : # Bulletin
    NBVEP += 1
    If TEST
     Call ECR_TRACE(MATRI-CTR-[F:VEP]BUL-[F:FGR]CPY-[F:FGR]FCY-"("+[F:VEP]FCY+")",0) From GESECRAN
    Endif

    DATMAT = [F:VEP]ENDDAT
    Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
    Read [HRCTR]CTR0 Last
    Filter [HRCTR]
    If !fstat
     Call CONTROLE(MATRI,DATMAT,CTR,"",OK,0) From DIVPAYE
    # Droits par service
    # SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
    # Test pour avoir la même chose que dans l'état accés en consultation
    # Car le tableau GAUTSRV est rempli si on a seulement droit exécution = "Oui"
    # Droits par salarié
    # Test pour avoir la même chose que dans l'état accés en consultation
    # Car dans sous prog CONTROLE on teste seulement droit exécution = "Oui"
     If OK
      Gosub CONTROLE_SRV_EMP
     Endif
    Else
     OK = 0
    Endif
    If OK
     For I=1 To [L]NBRUB
       For [HSP]HSP3(2) Where BUL=[F:VEP]BUL & RUB=[L]TBCRUB(I) & (TYP=1 or TYP=7)
         If OKSAL=0
          OKSAL = 1
          ICOL += 1
          TBMAT(ICOL) = MATRI
         Endif
         RESULT(I,ICOL) += [F:HSP]AMT
       Next
     Next I
    Endif
   Next : # Feuille de paye
  Next : # Contrat

# Droits par service
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Pour afficher le total si le nombre de colonne est < NBCOL
# On cumule dans TOTRUB et quand on ICOL=NBCOL on recommence les calculs

  If ICOL=NCOL
   GROUPE += 1
   For I=1 To NBRUB
    Raz [F:TMP]
    TOTLIG = 0
    For J=1 To ICOL
     [F:TMP]EMP(J-1) = TBMAT(J)
     [F:TMP]AMT(J-1) = RESULT(I,J)
     TOTLIG += RESULT(I,J)
    Next J
    If TOTLIG<>0
     TOTRUB(I) += TOTLIG
     If DETSAL
      LIGTMP += 1
      [F:TMP]USR = GUSER
      [F:TMP]RQT = [L]NUMREQ
      [F:TMP]LIG = LIGTMP
      [F:TMP]GRP = GROUPE
      [F:TMP]DAT = date$
      [F:TMP]ROW = TBRUB(I)
      Write [TMP]
     Endif
    Endif
   Next I
   Raz ICOL, TBMAT, RESULT
  Endif
 Next : # Salarié

  #74709
  For J=1 To ICOL
    For I=1 To NBRUB
      TOTRUB(I) += RESULT(I,J)
    Next
  Next
  #end 74709
 If DETSAL
  ICOL += 1
 Else
  ICOL = 1
 Endif
 TBMAT(ICOL) = mess(52,103,1) : # Total
 GROUPE += 1
 For I=1 To NBRUB
  Raz [F:TMP]
  RESULT(I,ICOL) = TOTRUB(I)
  TOTLIG = 0
  For J=1 To ICOL
   [F:TMP]EMP(J-1) = TBMAT(J)
   [F:TMP]AMT(J-1) = RESULT(I,J)
   TOTLIG += RESULT(I,J)
  Next J
  If TOTLIG<>0
   LIGTMP += 1
   [F:TMP]USR = GUSER
   [F:TMP]RQT = [L]NUMREQ
   [F:TMP]LIG = LIGTMP
   [F:TMP]GRP = GROUPE
   [F:TMP]DAT = date$
   [F:TMP]ROW = TBRUB(I)
   Write [TMP]
  Endif
 Next I

Commit
If TEST
 Call ECR_TRACE(num$(NBSAL)-"salariés"-num$(NBVEP)-"bulletins",0) From GESECRAN
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###############################################################################
# Droits par service
# Droits par salarié
$CONTROLE_SRV_EMP
# Droits par service
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Test pour avoir la même chose que dans l'état accés en consultation
# Car le tableau GAUTSRV est rempli si on seulement droit exécution = "Oui"
If GUSRACS<>2 Then
  Read [SRV]SRV0 = [F:HRCTR]ETRSRV
  If !fstat
    Read [ACC]CODACC = GUSER;[F:SRV]CODACC
    If fstat or [F:ACC]EXEC<>2 or [F:ACC]CONSUL<>2
       OK = 0 : Return
    Endif
  Else
    OK = 0 : Return
  Endif
Endif
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Droits par salarié
# Test pour avoir la même chose que dans l'état accés en consultation
# Car dans sous prog CONTROLE on teste seulement droit exécution = "Oui"
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2 or [F:ACC]CONSUL<>2
  OK = 0 : Return
 Endif
Endif
Return
###############################################################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
