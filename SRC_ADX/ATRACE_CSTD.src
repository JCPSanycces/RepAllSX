#-------------------------------------------------------------#
Funprog GET_CLOBFILE(AINSTANCE,APRONAME,AVALUE,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Char       VOLUME
Value Char NAME

Local Integer  FSEEK:FSEEK=0
#Call GET_CLOBFILE(AINSTANCE,APRONAME,AVALUE,VOLUME,0,FULLNAME) From ASYRSTO
AVALUE = func ASYRCOM.READ_TRACE([L]NAME,FSEEK)
End 0
#-------------------------------------------------------------#
Funprog GET_CLOBCNT(AINSTANCE,APRONAME,AVALCNT,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALCNT
Value Char       VOLUME
Value Char NAME
AVALCNT=""
End 0
#-------------------------------------------------------------#
Funprog GET_CLOBEXIST(AINSTANCE,APRONAME,AEXIST,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Tinyint     AEXIST
Value Char       VOLUME
Value Char NAME
[L]AEXIST=1
End 0
#-------------------------------------------------------------#
Funprog DEL_CLOBFILE(AINSTANCE,APRONAME,VOLUME,NAME)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Value Char       VOLUME
Value Char NAME
Local Char     FULLNAME(50)
FULLNAME = [L]NAME + ".tra"
Call DEL_CLOBFILE(AINSTANCE,APRONAME,VOLUME,FULLNAME) From ASYRSTO
End 0

