# Classe ATRACE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"             : Gosub AREAD
      When "ADELETE"           : Gosub ADELETE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



$AREAD
Local Instance IVOLUME Using C_AVOLUME
Local Datetime FTIMESTAMP
Local Integer  FSIZE
Local Char     FILEKEY(50)
Local Char     FCOMMENT(100)

FILEKEY = this.NAME + ".tra"

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD("TRA")
If ASTATUS : Return : Endif

ASTATUS = fmet IVOLUME.GETFILEDATETIME(FILEKEY,FTIMESTAMP)
If ASTATUS : Return : Endif

ASTATUS = fmet IVOLUME.GETFILEINFO(FILEKEY,7,FSIZE)
If ASTATUS : Return : Endif

ASTATUS = fmet IVOLUME.GETFILECOM(FILEKEY,FCOMMENT)
If ASTATUS : Return : Endif

this.TIMESTAMP  = FTIMESTAMP
this.SIZE       = FSIZE
this.COMMENT    = FCOMMENT
FreeGroup IVOLUME
Return

$ADELETE
Local Char     FULLNAME(50)
FULLNAME = this.NAME + ".tra"
ASTATUS = func ASYRSTO.DELETEFILE("TRA",FULLNAME)
Return

