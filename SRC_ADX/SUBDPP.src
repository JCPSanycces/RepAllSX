Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()
 If (G_ACTCCN = G_OUI and ( [M:DPP1]CURDPP <> G_CCNPLNCAD or G_CCNRPR <> G_OUI or [F:FAS]OWNTYP <> GVML_TDCONCE )) Then
    Chgfmt [M:DPP1]EXECADCRB With "-Nz3:13.2#"
    Chgfmt [M:DPP1]TRFCADCUM With "-Nz3:13.2#"
 Endif
 If (G_ACTCCN = G_NON) Then
    Chgfmt [M:DPP1]EXECADCRB With "-Nz3:13.2#"
    Chgfmt [M:DPP1]TRFCADCUM With "-Nz3:13.2#"
 Endif
End

#------------------------------------------------
Subprog AV_LSTFLD2(VALEUR)
Variable Char    VALEUR()
 If (G_ACTCCN = G_OUI and ( [M:DPP1]CURDPP <> G_CCNPLNCAD or G_CCNRPR <> G_OUI or [F:FAS]OWNTYP <> GVML_TDCONCE) ) Then
    Chgfmt [M:DPP1]PERCADCRB2 With "-Nz3:13.2#"
    Chgfmt [M:DPP1]TRFCADCUM2 With "-Nz3:13.2#"
    Chgfmt [M:DPP1]CADCRBDEV  With "-Nz3:13.2#"
    Chgfmt [M:DPP1]PSTCADCRB  With "-Nz3:13.2#"
    Chgfmt [M:DPP1]P_1CADCRB  With "-Nz3:13.2#"
 Endif
 If (G_ACTCCN = G_NON) Then
    Chgfmt [M:DPP1]PERCADCRB2 With "-Nz3:13.2#"
    Chgfmt [M:DPP1]TRFCADCUM2 With "-Nz3:13.2#"
    Chgfmt [M:DPP1]CADCRBDEV  With "-Nz3:13.2#"
    Chgfmt [M:DPP1]PSTCADCRB  With "-Nz3:13.2#"
    Chgfmt [M:DPP1]P_1CADCRB  With "-Nz3:13.2#"
 Endif
End




