Subprog AV_DPRRAT(VALEUR)
Variable Decimal VALEUR
  If ( [M:DPP1]DPRRATFLG(nolign-1) = G_OUI) Then
    Chgstl [M:DPP1]DPRRAT(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:DPP1]DPRRAT(nolign-1) With ""
  Endif
End

################################
Subprog AV_DPRRAT2E(VALEUR)
Variable Decimal VALEUR

 Local Char PAYS(GLONCRY)
 PAYS = func TRTFAS.GET_MODE_PAYS( "", "IT" )
 Local Char LEGI
 LEGI = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )


 If ( PAYS = "" or ( PAYS <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:DPP1]CPY) = PAYS ) and
&     LEGI = "" or ( LEGI <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:DPP1]CPY) = LEGI ) ) Then
  Chgfmt [M:DPP1]DPRRAT2E With "-N:3.6#"
 Else
  Chgfmt [M:DPP1]DPRRAT2E With "N:3.6#"
 Endif
End


