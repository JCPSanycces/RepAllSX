#<AdxTL>@(#)5.0.0.0 $Revision$

#*********************************************************************
#
#                    GESTION DES PLANS D'AMORTISSEMENT
#
#*********************************************************************
#    Création
#    MWA - 25.02.2003
#
#*********************************************************************
#    Modification
#    MWA 26.02.2015 FQ105600  Ajout unité d'oeuvre pour le plan de production
#    MWA 30.10.2013 FQ75616   Reprise avancée
#    MDJ 12.06.2013 FQ82871   Adaptations pour Convergence (pcolor)
#    MWA 19.06.2012 FQ80825   Arrêt redémarrage modes roumains
#    MWA 29.06.2011 FQ74865   La repr. de dépréciation/sortie n'est pas sur la période courante
#    MWA 29.06.2011 FQ74665   SRA bien déprécié, la repr. de dépréciation/sortie n'est pas sur la période courante
#    MWA 03.06.2011 FQ74283   Onglet suivi, Cumuls amort Théo. & Init.ne tiennent pas compte de l'amt except.
#    MWA 16.12.2010 FQ67577   Gestion des modes polonais
#    MWA 09.06.2010 FQ64311   Réévaluation négative
#    MWA 04.05.2010 FQ64544   Comptabilisation écart sur plan liés
#    MWA 07.04.2009 FQ54202   Affichage du site financier porté par le plan
#
#*********************************************************************
#
  Call OBJET("DPP",GBIDC1,GBIDC2) From GOBJET
  End

  $ACTION
  #If GUSER = "MWA" Then : Infbox "ACTION="-num$(ACTION) : Endif

  Case ACTION
   When "OUVRE"             : Gosub OUVRE          : # Début  - Avant toute chose
   When "VERROU"            : Gosub VERROU         : #
   When "LIENS"             : Gosub LIENS          : # Début  - Lecture informations tables liées

   When "APRES_MODIF"       : Gosub APRES_MODIF

   When "SETBOUT"           : Gosub SETBOUT        : #        - Désactivation des boutons
   When "FIN_ACTION"        : Gosub FIN_ACTION     : #
   When "AVANT_DEVERROU"    : Gosub AVANT_DEVERROU : #        - Avant déverrouillage
   When "FERME"             : Gosub FERME
   When Default
  Endcase

Return
#
#*********************************************************************
#
#=====================================================================
#

#=====================================================================
#
$APRES_MODIF
  # If GUSER = "MWA" Then : Infbox "APRES_MODIF " : Endif
  OK = 0
Return

#=====================================================================
#
$OUVRE

Global Integer G_COULIG1        : # N° ligne de l'exercice courant
Global Date G_FISSTRDPR      : # Date de début d'amortissement pour le plan fiscal
Global Date G_FIYENDCUR      : # Date de fin de l'exercice courant
# FQ74865
Global Date G_PERSTRCUR      : # Date de début de l'exercice courant
Global Date G_PERENDCUR      : # Date de fin de la période courante de l'exercice courant
Global Date G_FIYENDNXT      : # Date de fin de l'exercice suivant
Global Date G_PERENDNXT      : # Date de fin de la période courante de l'exercice suivant

Local Integer LCURDPP, LCURCNX
Local Char    LAASREF(GLONAAS)

  # Sauvegarde du contexte - variables globales
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif

  # Entrée par tunnel
  If ( CLE2 <> "") Then
    [L]LCURDPP = val(CLE2) : # Récupération du paramètre
    [L]LAASREF = CLE1      : # Sauvegarde de la référence du bien appelant
    CLE2    = ""           : # Remise à vide, pour ne rien perturber
  Else
    [L]LCURDPP = G301CPT
    [L]LAASREF = ""
  Endif
  [M:DPP1]CURDPP = [L]LCURDPP

  # Gestion tables
  If clalev([F:FAS]) =0   : Local File FXDASSETS     [FAS]    : Endif
  If clalev([F:DEP]) =0   : Local File DEPREC        [DEP]    : Endif
  If clalev([F:DEP1])=0   : Local File DEPREC        [DEP1]   : Endif
  If clalev([F:DEP2])=0   : Local File DEPREC        [DEP2]   : Endif
  If clalev([F:DEP3])=0   : Local File DEPREC        [DEP3]   : Endif
  If clalev([F:FIS]) =0   : Local File FISCYEAR      [FIS]    : Endif
  If clalev([F:CNX]) =0   : Local File CONTEXT       [CNX]    : Endif

  # FQ105600
  If clalev([F:PPH]) =0    : Local File PROPLNH       [PPH]    : Endif

  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

  #-------------------------
  # Fiche uniquement en consultation ( ça entraine des dysfonctionnements
  # dans l'écran des biens au retour "Modification impossible")
  # GCONSULT = 1

Return

#=====================================================================
#
$VERROU
 OK = 0
Return

#=====================================================================
#
$LIENS

  Local Integer I_LGN

  #If GUSER = "MWA" Then : Infbox "Liens"  : Endif
  #If GUSER = "MWA" Then : Dbgaff  : Endif

  # Initialisation du contexte en cours
  [M:DPP1]CURDPP = [L]LCURDPP

  # FQ80825
  If ([M:FPC]LEG = "") Then
    #> Chargement du masque de travail contenant le paramétrage comptable de la société
    Local Integer ERR
    Call LOAD_FASPARCPY([M:DPP1]CPY,"",G_NON,ERR) From GLOFCYCPY
  Endif


  # Lecture de la devise du contexte en cours
  Call GET_CNX_FROM_PLAN ([F:FAS]CPY, [L]LCURDPP, [L]LCURCNX) From GLOBIENS
  Read [CNX] CNX0=[F:FAS]CPY;[L]LCURCNX
  If (fstat) Then : Raz [F:CNX] : Endif
  [M:DPP1]CUR=[F:CNX]CUR

  # FQ105600
  If ([F:FAS]PROPLN <> "") Then
    If clalev([F:PPH]) =0    : Local File PROPLNH       [PPH]    : Endif
    Read [F:PPH]PPH0=[F:FAS]PROPLN
  Endif

  # Récupération de la date de fin de l'exercice courant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TECOURA
  Read [FIS]First
  If (fstat) Then : Raz [F:FIS] : Endif
  Filter [FIS]
  G_FIYENDCUR = [F:FIS]DATENDFIY
  # FQ74865
  G_PERSTRCUR = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  G_PERENDCUR = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  # Récupération de la date de fin de l'exercice suivant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TESUIV
  Read [FIS]First
  Filter [FIS]
  If (fstat) Then : Raz [F:FIS] : Endif
  G_FIYENDNXT = [F:FIS]DATENDFIY
  G_PERENDNXT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)


  # Lecture des paramètres d'amortissement et des dotations concernant le plan d'amortissement du bien
  nolign = 1
  Call ACTION_BLOCK (ACB_EFFZO, "DPP1", "NBLIG2") From GLOBIENS

  Filter [DEP1] Where AASREF=[M:DPP1]AASREF and DPRPLN=LCURDPP
&  Order By Key CLE=AASREF; DPRPLN; FIYENDDAT; PERENDDAT Desc
  #> 1 >>>>>>>>>>>>>>>>>
  For [DEP1] CLE(3)
    #> 2 >>>>>>>>>>>>>>>>>
    For [DEP1] CLE

      #- 3 ----------------
      If ( [F:DEP1]STRDPRDAT <= [F:DEP1]FIYENDDAT ) Then

        # -- Positionnement sur la dernière période de chaque exercice
        #=================
        [M:DPP1] = [F:DEP1]
        #=================

        # Lecture DEPREC début exercice
        Filter [DEP3] Where AASREF=[M:DPP1]AASREF and DPRPLN=[M:DPP1]CURDPP and FIYENDDAT=[F:DEP1]FIYENDDAT
&                  Order By AASREF; DPRPLN; FIYENDDAT; PERENDDAT
        Read  [DEP3] First
        If (fstat) Then : Infbox num$(fstat) : Endif
        Filter [DEP3]

        #FQ54202
        # Site financier
        [M:DPP1]FCY1(nolign-1)       = [F:DEP1]FCY
        # -- Champs calculés
        [M:DPP1]FIYENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:DEP1]FIYENDDAT)
        #-- Durée résiduelle
        [M:DPP1]RSDDUR(nolign-1)   = [F:DEP3]RSDDUR
        #-- Valeur amortissable
        [M:DPP1]DPRVAL(nolign-1) = [F:DEP1]DPRBAS - [F:DEP1]RSDVAL
        [M:DPP1]DPRBAS(nolign-1) = [F:DEP1]DPRBAS
        #-- Solde dépréciation début
        # FQ75616 [M:DPP1]IMLBLC(nolign-1)   = [F:DEP3]IMLBLC
        [M:DPP1]IMLBLC(nolign-1)   = [F:DEP3]EXEIMLCUM - [F:DEP3]EXERVECUM - [F:DEP3]EXETRFCUM
        #-- Dépréciation
        [M:DPP1]IML(nolign-1)       = [F:DEP1]PERIMLCUM + [F:DEP1]IML
        #-- Reprise de dépréciation
        [M:DPP1]IMLRVE(nolign-1)    = [F:DEP1]PERRVECUM + [F:DEP1]IMLRVE
        #-- Reprise de dépréciation tranférée en Amrot except
        [M:DPP1]IMLRVETRF(nolign-1) = [F:DEP1]PERTRFCUM + [F:DEP1]IMLRVETRF
        #-- Reprise de dépréciation / sortie
        If ( [F:FAS]ISSDAT <> [0/0/0] and
&            [F:FAS]ISSDAT >= [F:DEP1]FIYSTRDAT and [F:FAS]ISSDAT <= [F:DEP1]FIYENDDAT ) Then
          [M:DPP1]IMLRVEISS(nolign-1) = [F:FAS]IMLRVEISS ([M:DPP1]CURDPP-1)
        Endif
        #-- Reprise de dérogatoire / sortie
        If ( [F:FAS]ISSDAT <> [0/0/0] and
&            [F:FAS]ISSDAT >= [F:DEP1]FIYSTRDAT and [F:FAS]ISSDAT <= [F:DEP1]FIYENDDAT ) Then
          [M:DPP1]DERRVEISS(nolign-1) = [F:FAS]DERRVEISS
        Endif
        #-- Taux amortissement exceptionnelle - FQ49232
        [M:DPP1]DPRRAT2E(nolign-1)   = [F:DEP1]DPRRAT2
        #-- UO résiduelle début d'exercice
        [M:DPP1]RSDQTY(nolign-1)    = [F:DEP1]RSDQTY + [F:DEP1]FIYQTY - [F:DEP1]PERQTY
        #-- Réévaluation
        Filter [DEP2] Where AASREF=[M:DPP1]AASREF and DPRPLN=[M:DPP1]CURDPP and
&                           FIYENDDAT=[M:DPP1]FIYENDDAT(nolign-1)
&                  Order By AASREF; DPRPLN; FIYENDDAT; PERENDDAT
        [M:DPP1]RVAAMT(nolign-1)    = 0
        [M:DPP1]RVACRB(nolign-1)    = 0
        [M:DPP1]MTCDEVADJ(nolign-1) = 0
        [M:DPP1]MTCDPEDEV(nolign-1) = 0
        For [DEP2]
          If ([F:DEP2]RVAAMT <> 0 ) Then : [M:DPP1]RVAAMT(nolign-1) += [F:DEP2]RVAAMT : Endif
          [M:DPP1]RVACRB(nolign-1) += [F:DEP2]RVACRB
          If ( [F:DEP2]MTCDPEDAT <> [0/0/0] ) Then
            [M:DPP1]MTCDEVADJ(nolign-1) = [F:DEP2]MTCDEVADJ
            [M:DPP1]MTCDPEDEV(nolign-1) = [F:DEP2]MTCDPEDEV
          Endif
        Next
        Filter [DEP2]

        # FQ64311
        If ( ( [M:DPP1]DPRBAS(nolign-1) > 0 and  [M:DPP1]EXERVADEV(nolign-1) < 0 ) or
&            ( [M:DPP1]DPRBAS(nolign-1) < 0 and  [M:DPP1]EXERVADEV(nolign-1) > 0 )     ) Then
          [M:DPP1]EXERVADEV(nolign-1) = 0
        Endif

        # FQ54343
        If (G_ACTCCN = G_OUI ) Then
          [M:DPP1]EXECADCRB(nolign-1)  = [F:DEP1]P_1CADCRB + [F:DEP1]PERCADCRB
          [M:DPP1]TRFCADCUM(nolign-1)  = [F:DEP3]TRFCADCUM
        Endif

        # FQ75616
        [M:DPP1]RVAAMT(nolign-1) = [F:DEP3]PERRVACUM + [F:DEP3]RVAAMT
        [M:DPP1]RVACRB(nolign-1) = [F:DEP3]PERRVACUM - [F:DEP3]PERRVADEV + [F:DEP3]RVACRB

        # ----- Exercice courant
        If ([F:DEP1]FIYENDDAT = G_FIYENDCUR ) Then : G_COULIG1=nolign-1 :  Endif

        nolign += 1

      Endif
      #- 3 ----------------
      Break 1
    Next
    #> 2 >>>>>>>>>>>>>>>>>
  Next
  #> 1 >>>>>>>>>>>>>>>>>
  Filter [DEP1]
  [M:DPP1]NBLIG1 = nolign-1


  # Récupération de la date de début d'amortissement du bien pour le plan fiscal
  G_FISSTRDPR = [0/0/0]
  If ( ( LCURDPP = G301FIS or LCURDPP = G301CPT ) ) Then
    Filter [DEP] Where AASREF=[M:DPP1]AASREF and DPRPLN=G301FIS
    Read [DEP]DEP0 First
    Filter [DEP]
    If (fstat) Then
      G_FISSTRDPR = [0/0/0]
    Else
      G_FISSTRDPR = [F:DEP]STRDPRDAT
    Endif
  Endif

Local Integer  LCONTEXT

  # Ouverture des fichiers
  If clalev([F:DEPW])=0 : Local File DEPREC      [DEPW] : Endif
  If clalev([F:FASW])=0 : Local File FXDASSETS   [FASW] : Endif



Return

#=====================================================================
#
$SETBOUT

  # Désactivation de l'action Créer, Dupliquer, Supprimer, Changer de clé
  #Call VIREBOUT(CHAINE,"CDAHM") From GOBJET

  # Positionnement du focus sur la ligne de l'exercice courant
  If ( [M:DPP1]NBLIG1 > 0 ) Then
    zonsui="NBLIG1("+num$(G_COULIG1)+")"
  Endif

  # Activation menu Actions
  # Menu B Actions

  CHMEN += "IN"

Return

#=====================================================================
#
$FIN_ACTION

  # Infbox "BOUT="-num$(BOUT)
  Case BOUT
    When "O"        : # Autres Plans
      CLECUR1 = [M:DPP1]AASREF
      Gosub RELIT From GOBJSUB
    When Default
  Endcase

Return

#=====================================================================
#
$AVANT_DEVERROU

  # Pas de déverrouillage du Bien appelant
  If (LAASREF <> "") Then
    OK = 0
  Endif

Return

#=====================================================================
#
$FIN

  Kill G_FISSTRDPR
  Kill G_FIYENDCUR
  # FQ74865
  Kill G_PERSTRCUR
  Kill G_PERENDCUR
  Kill G_FIYENDNXT
  Kill G_PERENDNXT
  Kill G_COULIG1

  Gosub DELOCK_TBL_DEST From FUNLOFLDAB
Return

#=====================================================================
$FERME
  If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM : Endif
Return

#
#*********************************************************************
#        *DPP1             E C R A N      D P P 1
#*********************************************************************
#
#############################################"
Subprog AS_NBLIG1

Local Integer NOL
####Local Integer LRIENLU


  # Plan dérogatoire n'est pas accessible pour les plans autres que Fiscal ou Comptable
  If ( ( [M:DPP1]DPRPLN <> G301FIS and [M:DPP1]DPRPLN <> G301CPT ) or
&     func GLOBIENS.CPY_PLN_GERE([M:DPP1]CPY, G301FIS) = G_NON or func GLOBIENS.CPY_PLN_GERE([M:DPP1]CPY, G301CPT) = G_NON ) Then
    GBOUT1=""
  Endif

  # Lecture des dotations périodiques de l'exercice choisi dans le tableau

  [L]NOL=nolign-1
  [M:DPP1]ZONCUR = [M:DPP1]FIYENDDAT([L]NOL)

  nolign = 1
  Call ACTION_BLOCK (ACB_EFFZO, "DPP1", "NBLIG2") From GLOBIENS

  # FQ74665
  Local Integer NISS : NISS = 0

  Filter [DEP] Where AASREF=[M:DPP1]AASREF and DPRPLN=[M:DPP1]CURDPP and FIYENDDAT = [M:DPP1]ZONCUR
&              Order By AASREF; DPRPLN; FIYENDDAT; PERENDDAT

    For [DEP]

      # FQ54202
      [M:DPP1]FCY2(nolign-1)       = [F:DEP]FCY
      [M:DPP1]FIYSTRDAT2(nolign-1) = [F:DEP]FIYSTRDAT
      [M:DPP1]FIYENDDAT2(nolign-1) = [F:DEP]FIYENDDAT
      [M:DPP1]PERSTRDAT(nolign-1)  = [F:DEP]PERSTRDAT
      [M:DPP1]PERENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:DEP]PERENDDAT)
      [M:DPP1]PERENDDAT(nolign-1)  = [F:DEP]PERENDDAT
      [M:DPP1]DPRBAS2(nolign-1)    = [F:DEP]DPRBAS
      [M:DPP1]RSDVAL2(nolign-1)    = [F:DEP]RSDVAL
      [M:DPP1]DPRVAL2(nolign-1)    = [F:DEP]DPRBAS - [F:DEP]RSDVAL
      [M:DPP1]PERCLOCUM(nolign-1)  = [F:DEP]DPRCUM + [F:DEP]PERCLOCUM + [F:DEP]PERCLOEXC
      [M:DPP1]IMLBLC2(nolign-1)    = [F:DEP]IMLBLC
      # FQ64544
      [M:DPP1]PERDPEFLG(nolign-1)  = [F:DEP]PERDPEFLG
      [M:DPP1]PERENDDPE(nolign-1)  = [F:DEP]PERENDDPE
      [M:DPP1]PEREXCDPR(nolign-1)  = [F:DEP]PEREXCDPR
      [M:DPP1]IML2(nolign-1)       = [F:DEP]IML
      [M:DPP1]IMLRVE2(nolign-1)    = [F:DEP]IMLRVE
      [M:DPP1]IMLRVETRF2(nolign-1) = [F:DEP]IMLRVETRF

      # FQ74665
      #If ([F:FAS]ISSDAT <> [0/0/0] and [F:DEP]FLGUPDISS = G_OUI ) Then
      # FQ74865
      If ( [F:FAS]ISSDAT <> [0/0/0] and
&          ( [F:FAS]ISSDAT < G_PERSTRCUR and [F:DEP]FLGUPDISS = G_OUI) or
&          ( [F:FAS]ISSDAT >= [F:DEP]PERSTRDAT and [F:FAS]ISSDAT <= [F:DEP]PERENDDAT) ) Then
        If (NISS <> 0) Then
          [M:DPP1]IMLRVEISS2(NISS-1) = 0
          [M:DPP1]DERRVEISS2(NISS-1) = 0
        Endif
        [M:DPP1]IMLRVEISS2(nolign-1) = [F:FAS]IMLRVEISS ([M:DPP1]CURDPP-1)
        [M:DPP1]DERRVEISS2(nolign-1) = [F:FAS]DERRVEISS
        NISS = nolign
      Endif

      [M:DPP1]NBV2(nolign-1)       = [F:DEP]NBV
      # FQ59941 FQ80825
      If ( G_ACTKRU = G_OUI or [F:DEP]DPM = G_DPMRD ) Then
        [M:DPP1]KBIRNBV(nolign-1)       = [F:DEP]KBIRNBV
        [M:DPP1]KBIRDAT(nolign-1)       = [F:DEP]KBIRDAT
      Endif
      # FQ67577
      If ( G_ACTKPL = G_OUI ) Then
        [M:DPP1]KMDRDEV(nolign-1)       = [F:DEP]KMDRDEV
        [M:DPP1]KMDRDAT(nolign-1)       = [F:DEP]KMDRDAT
      Endif
      [M:DPP1]IMLRVELIM(nolign-1)  = [F:DEP]IMLRVELIM
      [M:DPP1]NSPVAL2(nolign-1)    = [F:DEP]NSPVAL
      [M:DPP1]IMLTYP2(nolign-1)    = [F:DEP]IMLTYP
      [M:DPP1]INTIMLTYP2(nolign-1) = [F:DEP]INTIMLTYP
      [M:DPP1]EXTIMLTYP2(nolign-1) = [F:DEP]EXTIMLTYP
      [M:DPP1]RVADAT2(nolign-1)    = [F:DEP]RVADAT
      [M:DPP1]RVATIADAT(nolign-1)  = [F:DEP]RVATIADAT
      [M:DPP1]RVATYP(nolign-1)     = [F:DEP]RVATYP
      [M:DPP1]RVACOE2(nolign-1)    = [F:DEP]RVACOE
      [M:DPP1]RVACOEREF(nolign-1)  = [F:DEP]RVACOEREF
      [M:DPP1]EXERVADEV2(nolign-1) = [F:DEP]EXERVADEV + [F:DEP]PERRVADEV
      # FQ64311
      If ( ( [M:DPP1]DPRBAS2(nolign-1) > 0 and [M:DPP1]EXERVADEV2(nolign-1) < 0 ) or
&          ( [M:DPP1]DPRBAS2(nolign-1) < 0 and [M:DPP1]EXERVADEV2(nolign-1) > 0 )     ) Then
        [M:DPP1]EXERVADEV2(nolign-1) = 0
      Endif
      [M:DPP1]RVAAMT2(nolign-1)    = [F:DEP]RVAAMT
      [M:DPP1]RVACRB2(nolign-1)    = [F:DEP]RVACRB
      [M:DPP1]DPM2(nolign-1)       = [F:DEP]DPM
      [M:DPP1]DPRDUR2(nolign-1)    = [F:DEP]DPRDUR
      [M:DPP1]APLDUR2(nolign-1)    = [F:DEP]APLDUR
      [M:DPP1]RSDDUR2(nolign-1)    = [F:DEP]RSDDUR
      [M:DPP1]DPRRATFLG2(nolign-1) = [F:DEP]DPRRATFLG
      [M:DPP1]DPRRAT2(nolign-1)    = [F:DEP]DPRRAT
      [M:DPP1]DPRRAT2P(nolign-1)   = [F:DEP]DPRRAT2
      [M:DPP1]ACLCOE2(nolign-1)    = [F:DEP]ACLCOE
      [M:DPP1]PRATYP2(nolign-1)    = [F:DEP]PRATYP
      [M:DPP1]STRDPRDAT2(nolign-1) = [F:DEP]STRDPRDAT
      [M:DPP1]ENDDPRDAT2(nolign-1) = [F:DEP]ENDDPRDAT
      [M:DPP1]ALWCOD2(nolign-1)    = [F:DEP]ALWCOD
      [M:DPP1]RSDQTY2(nolign-1)    = [F:DEP]RSDQTY
      [M:DPP1]FIYQTY2(nolign-1)    = [F:DEP]FIYQTY
      [M:DPP1]PERQTY(nolign-1)     = [F:DEP]PERQTY
      [M:DPP1]MTCDPEDAT(nolign-1)  = [F:DEP]MTCDPEDAT
      [M:DPP1]MTCTIATYP(nolign-1)  = [F:DEP]MTCTIATYP
      [M:DPP1]MTCTIADAT(nolign-1)  = [F:DEP]MTCTIADAT
      [M:DPP1]DPEDEV(nolign-1)     = [F:DEP]DPEDEV
      [M:DPP1]EXCDEV(nolign-1)     = [F:DEP]EXCDEV
      [M:DPP1]DERDEV(nolign-1)     = [F:DEP]DERDEV
      [M:DPP1]DERRVEDEV(nolign-1)  = [F:DEP]DERRVEDEV
      [M:DPP1]RVACRBDEV(nolign-1)  = [F:DEP]RVACRBDEV
      [M:DPP1]RVETRFDEV(nolign-1)  = [F:DEP]RVETRFDEV
      [M:DPP1]PSTDPE(nolign-1)     = [F:DEP]PSTDPE
      [M:DPP1]PSTEXC(nolign-1)     = [F:DEP]PSTEXC
      [M:DPP1]PSTDER(nolign-1)     = [F:DEP]PSTDER
      [M:DPP1]PSTDERRVE(nolign-1)  = [F:DEP]PSTDERRVE
      [M:DPP1]PSTRVACRB(nolign-1)  = [F:DEP]PSTRVACRB
      [M:DPP1]PSTRVETRF(nolign-1)  = [F:DEP]PSTRVETRF
      [M:DPP1]MTCDPEDEV2(nolign-1) = [F:DEP]MTCDPEDEV
      [M:DPP1]MTCDEVADJ2(nolign-1) = [F:DEP]MTCDEVADJ

      [M:DPP1]PERREFCLC2(nolign-1) = [F:DEP]PERREFCLC
      [M:DPP1]DPMI2(nolign-1)      = [F:DEP]DPMI
      [M:DPP1]PERREFCL2I(nolign-1) = [F:DEP]PERREFCLCI
      [M:DPP1]DPMT2(nolign-1)      = [F:DEP]DPMT
      [M:DPP1]PERREFCL2T(nolign-1) = [F:DEP]PERREFCLCT
      [M:DPP1]BSEVAL2(nolign-1)    = [F:DEP]BSEVAL
      # FQ74283
      [M:DPP1]PERCLOCUMI(nolign-1) = [F:DEP]EXECLOCUMI + [F:DEP]PERCLOCUMI + [F:DEP]PERCLOEXCI
      [M:DPP1]PERCLOCUMT(nolign-1) = [F:DEP]EXECLOCUMT + [F:DEP]PERCLOCUMT + [F:DEP]PERCLOEXCT
      [M:DPP1]DPEI(nolign-1)       = [F:DEP]DPEI
      [M:DPP1]DPET(nolign-1)       = [F:DEP]DPET
      [M:DPP1]PEREXCDPRI(nolign-1) = [F:DEP]PEREXCDPRI
      [M:DPP1]PEREXCDPRT(nolign-1) = [F:DEP]PEREXCDPRT
      [M:DPP1]NBVI2(nolign-1)      = [F:DEP]NBVI
      [M:DPP1]NBVT2(nolign-1)      = [F:DEP]NBVT
      # FQ64544
      [M:DPP1]LNKCUM(nolign-1)     = [F:DEP]LNKCUM
      [M:DPP1]PERLNKCUM(nolign-1)  = [F:DEP]PERLNKCUM
      [M:DPP1]LNK(nolign-1)        = [F:DEP]LNK
      [M:DPP1]LNKDEV(nolign-1)     = [F:DEP]LNKDEV
      [M:DPP1]PSTLNK(nolign-1)     = [F:DEP]PSTLNK
      # FQ54343
      If (G_ACTCCN = G_OUI and [M:DPP1]CURDPP = G_CCNPLNCAD and G_CCNRPR = G_OUI and [F:FAS]OWNTYP = GVML_TDCONCE) Then
        [M:DPP1]PERCADCRB2(nolign-1)  = [F:DEP]PERCADCRB
        [M:DPP1]CADCRBDEV(nolign-1)   = [F:DEP]CADCRBDEV
        [M:DPP1]PSTCADCRB(nolign-1)   = [F:DEP]PSTCADCRB
        [M:DPP1]TRFCADCUM2(nolign-1)  = [F:DEP]TRFCADCUM
        [M:DPP1]P_1CADCRB(nolign-1)   = [F:DEP]P_1CADCRB
      Endif

      nolign += 1
    Next
    Filter [DEP]
    [M:DPP1]NBLIG2 = nolign-1
    Call ACTION_BLOCK (ACB_AFFZO, "DPP1", "NBLIG2") From GLOBIENS
####  Endif

End


################################
Subprog AV_FIYSTRDAT(VALEUR)
Variable Date    VALEUR

   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
  If ([M:DPP1]FIYENDDAT(nolign-1) = G_FIYENDCUR) Then
    Chgstl NBLIG1 (nolign-1) With "AWARNLOW"
    pcolor = GCOUL(3)
  Else
    Chgstl NBLIG1 (nolign-1) With ""
    pcolor = GCOUL(0)
  Endif
End

################################
Subprog AV_PERSTRDAT(VALEUR)
Variable Date    VALEUR

##  If ([M:DPP1]PERENDDAT(nolign-1) = G_PERENDCUR   or
##&     [M:DPP1]PERENDDAT(nolign-1) = G_PERENDNXT ) Then
   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
  If ([M:DPP1]PERENDDAT(nolign-1) = G_PERENDCUR ) Then
   Chgstl NBLIG2 (nolign-1) With "AWARNLOW"
    pcolor = GCOUL(3)
  Else
    Chgstl NBLIG2 (nolign-1) With ""
    pcolor = GCOUL(0)
  Endif
End

