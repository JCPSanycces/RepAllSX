 Local Char PAYS(GLONCRY)
 PAYS = func TRTFAS.GET_MODE_PAYS( "", "IT" )
 Local Char LEGI
 LEGI = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )


 If ( PAYS = "" or ( PAYS <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:DPP1]CPY) = PAYS ) and
&     LEGI = "" or ( LEGI <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:DPP1]CPY) = LEGI ) ) Then
