#<AdxTL>@(#)4.0.0.0 $Revision$
# Classe AVISULIC

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD" : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
 When "_AUPDLICDB" : Gosub _AUPDLICDB
Endcase
Return

$_AUPDLICDB
If func ASYRLIC.CTLLIC
 If dim(this.ACTX._ASYRLIC.AFILE)<0
  [L]ASTATUS = fmet this.ASETERROR("",mess(157,123,1),[V]CST_AERROR )
  Return
 Elsif len(this.ACTX._ASYRLIC.AFILE)=0
  [L]ASTATUS = fmet this.ASETERROR("",mess(157,123,1),[V]CST_AERROR )
  Return
 Endif
 Call UPDATE_LIC_DB(this.ACTX.AFOLDER,this.ACTX._ASYRLIC.AFILE,1) From ASYRLIC
Endif
[L]ASTATUS = fmet this.ASETERROR("",mess(358,139,1),[V]CST_AINFO )
Return


###########################################################
$AREAD
If this.ACTX._ASYRLIC=null and func ASYRLIC.CTLLIC=0
 Gosub LOAD_TEST
Endif

If this.ACTX._ASYRLIC=null
 [L]ASTATUS=fmet this.ASETERROR("",mess(22,139,1),[V]CST_AERROR) : Return : # Licence incoorecte
Endif

Gosub LOAD_PARTNERS
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_ACTIVITIES
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_MODULES
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_LANGUAGES
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_LEGISLATIONS
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_KITS
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_PARAMETERS
If [L]ASTATUS = [V]CST_AERROR : Return : Endif

Gosub LOAD_FUNCTIONS
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return


###########################################################
$LOAD_FUNCTIONS
Local Integer IFUNC,PPFUNC
For IFUNC=1 To maxtab(this.ACTX._ASYRLIC.KEYFUNCTIONS)
 PPFUNC = fmet this.ADDLINE("AFUNCTIONS",[V]CST_ALASTPOS)
 If PPFUNC=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.AFUNCTIONS(PPFUNC).CODE     = this.ACTX._ASYRLIC.KEYFUNCTIONS(IFUNC).CODE
 this.AFUNCTIONS(PPFUNC).SVALUE  = this.ACTX._ASYRLIC.KEYFUNCTIONS(IFUNC).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_PARAMETERS
Local Integer IPAR,PPAR
For IPAR=1 To maxtab(this.ACTX._ASYRLIC.PARAMETERS)
 PPAR = fmet this.ADDLINE("APARAMETERS",[V]CST_ALASTPOS)
 If PPAR=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.APARAMETERS(PPAR).CODE     = this.ACTX._ASYRLIC.PARAMETERS(IPAR).CODE
 this.APARAMETERS(PPAR).SVALUE  = this.ACTX._ASYRLIC.PARAMETERS(IPAR).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_KITS
Local Integer IKIT,PKIT
For IKIT=1 To maxtab(this.ACTX._ASYRLIC.KITS)
 PKIT = fmet this.ADDLINE("AKITS",[V]CST_ALASTPOS)
 If PKIT=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.AKITS(PKIT).CODE     = this.ACTX._ASYRLIC.KITS(IKIT).CODE
 this.AKITS(PKIT).SVALUE  = this.ACTX._ASYRLIC.KITS(IKIT).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_LEGISLATIONS
Local Integer ILEG,PLEG
For ILEG=1 To maxtab(this.ACTX._ASYRLIC.LEGISLATIONS)
 PLEG = fmet this.ADDLINE("ALEGISLATION",[V]CST_ALASTPOS)
 If PLEG=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.ALEGISLATION(PLEG).CODE     = this.ACTX._ASYRLIC.LEGISLATIONS(ILEG).CODE
 this.ALEGISLATION(PLEG).SVALUE  = this.ACTX._ASYRLIC.LEGISLATIONS(ILEG).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_LANGUAGES
Local Integer ILAN,ILAN
For ILAN=1 To maxtab(this.ACTX._ASYRLIC.LANGUAGES)
 ILAN = fmet this.ADDLINE("ALANGUAGES",[V]CST_ALASTPOS)
 If ILAN=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.ALANGUAGES(ILAN).CODE     = this.ACTX._ASYRLIC.LANGUAGES(ILAN).CODE
 this.ALANGUAGES(ILAN).SVALUE  = this.ACTX._ASYRLIC.LANGUAGES(ILAN).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_MODULES
Local Integer IMOD,PMOD
For IMOD=1 To maxtab(this.ACTX._ASYRLIC.MODULES)
 PMOD = fmet this.ADDLINE("AMODULES",[V]CST_ALASTPOS)
 If PMOD=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.AMODULES(PMOD).CODE     = this.ACTX._ASYRLIC.MODULES(IMOD).CODE
 this.AMODULES(PMOD).SVALUE = this.ACTX._ASYRLIC.MODULES(IMOD).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_ACTIVITIES
Local Integer IACT,PACT
For IACT=1 To maxtab(this.ACTX._ASYRLIC.ACTIVITIES)
 PACT = fmet this.ADDLINE("ACTIVITIES",[V]CST_ALASTPOS)
 If PACT=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.ACTIVITIES(PACT).CODE     = this.ACTX._ASYRLIC.ACTIVITIES(IACT).CODE
 this.ACTIVITIES(PACT).SVALUE = this.ACTX._ASYRLIC.ACTIVITIES(IACT).SVALUE
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
$LOAD_PARTNERS
Local Integer ILIC,PPART
For ILIC=1 To maxtab(this.ACTX._ASYRLIC.LICENSES)
 PPART = fmet this.ADDLINE("APARTNERS",[V]CST_ALASTPOS)
 If PPART=[V]CST_ANOTDEFINED
  [L]ASTATUS=fmet this.ASETERROR("",mess(275,143,1),[V]CST_AERROR) : Break
 Endif
 this.APARTNERS(PPART).PARTNERID         = this.ACTX._ASYRLIC.LICENSES(ILIC).PARTNERID
 this.APARTNERS(PPART).PRODUCTCODE       = this.ACTX._ASYRLIC.LICENSES(ILIC).PRODUCTCODE
 this.APARTNERS(PPART).PRODUCTVER        = this.ACTX._ASYRLIC.LICENSES(ILIC).PRODUCTVER
 this.APARTNERS(PPART).POLICYCODE        = this.ACTX._ASYRLIC.LICENSES(ILIC).POLICYCODE
 this.APARTNERS(PPART).POLICYVER         = this.ACTX._ASYRLIC.LICENSES(ILIC).POLICYVER
 this.APARTNERS(PPART).EXPIRED           = this.ACTX._ASYRLIC.LICENSES(ILIC).EXPIRED
 this.APARTNERS(PPART).PRODUCTNAME       = this.ACTX._ASYRLIC.LICENSES(ILIC).PRODUCTNAME
 this.APARTNERS(PPART).SERIAL            = this.ACTX._ASYRLIC.LICENSES(ILIC).SERIAL
Next
If [L]ASTATUS = [V]CST_AERROR : Return : Endif
Return

###########################################################
Subprog LOAD_LIC
Gosub LOAD_TEST
End
###########################################################
$LOAD_TEST
Local Clbfile JSON
Local Integer ERROR
Local Char TCNAME(20):TCNAME="TC001"

Append JSON, '{'
Append JSON, '    "licenses": ['
Append JSON, '        {'
Append JSON, '            "partnerId": "",'
Append JSON, '            "productCode": "'+func ASYRLIC.GET_CHPRODUCTSTDCODE+'",'
Append JSON, '            "productVersion": "'+func APRODUCT.AGETVERSLIC+'",'
Append JSON, '            "policyCode": "ERPSTD",'
Append JSON, '            "policyVersion": "1.0",'
If GPRODUIT=-1 & find(adxusr,"ccl ")
Append JSON, '            "licenseExpired": true,'
Else
Append JSON, '            "licenseExpired": false,'
Endif
Append JSON, '            "productName": "Sage X3",'
Append JSON, '            "serial": "12345ABCDE"'
If nomap<>"SUPERV" & GPRODUIT<>-1
Append JSON, '        }'
Else
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P1",'
 Append JSON, '            "productCode": "P1_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P1_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "productName": "",'
 Append JSON, '            "serial": ""'
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P2",'
 Append JSON, '            "productCode": "P2_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P2_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "productName": "",'
 Append JSON, '            "serial": ""'
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P3",'
 Append JSON, '            "productCode": "P3_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P3_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "productName": "",'
 Append JSON, '            "serial": ""'
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P4",'
 Append JSON, '            "productCode": "P4_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P4_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "productName": "",'
 Append JSON, '            "serial": ""'
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P5",'
 Append JSON, '            "productCode": "P5_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P5_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "productName": "",'
 Append JSON, '            "serial": ""'
 Append JSON, '        },'
 Append JSON, '        {'
 Append JSON, '            "partnerId": "P6",'
 Append JSON, '            "productCode": "P6_ADDON",'
 Append JSON, '            "productVersion": "2.4",'
 Append JSON, '            "policyCode": "P5_ADDONSTD",'
 Append JSON, '            "policyVersion": "1.3",'
 Append JSON, '            "licenseExpired": true,'
 Append JSON, '            "serial": ""'
 Append JSON, '        }'
Endif
Append JSON, '    ],'
Append JSON, '    "activityCodes": {'
If GPRODUIT=-1
Append JSON, '        "SUP": true,'
Else
Append JSON, '        "SUP": false,'
Endif
If nomap="SUPERV" & GPRODUIT=-1
 Append JSON, '        "AC1": true,'
 Append JSON, '        "AC2": false,'
 Append JSON, '        "AC1": true,'
 Append JSON, '        "AC2": false,'
 Append JSON, '        "AC1": true,'
 Append JSON, '        "AC2": false,'
 Append JSON, '        "AC1": true,'
Endif
If GPRODUIT=-1 & adxusr="mbeinat"
 Append JSON, '        "AD1": false,'
Endif
Append JSON, '        "FAL": true'
Append JSON, '    },'
Append JSON, '    "languages": {'
If filinfo(filpath("FIL","TABLAN","fde",nomap),0)>=0
 Local File TABLAN [TLA]
 For [TLA]
 Append JSON, '        "'+[TLA]LAN+'": true,'
 Next
Endif
Append JSON, '        "ZZZ": false'
Append JSON, '    },'
Append JSON, '    "parameterKits": {'
If filinfo(filpath("FIL","ADELIVER","fde",nomap),0)>=0
 Local File ADELIVER [ADL]
 For [ADL]
 Append JSON, '        "'+[ADL]COD+'": true,'
 Next
Endif
Append JSON, '        "ZZZ": false'
Append JSON, '    },'
Append JSON, '    "legislations": {'
If filinfo(filpath("FIL","ATABDIV","fde",nomap),0)>=0
 Local File ATABDIV [ADI]
 For [ADI] Where NUMTAB=909
 Append JSON, '        "'+[ADI]CODE+'": true,'
 Next
Endif
Append JSON, '        "ZZZ": false'
Append JSON, '    },'
Append JSON, '    "modules": {'
Local Integer I
For I=1 To len(mess(0,14,1))
If GPRODUIT=-1 & adxusr="mbeinat" & I=2
 Append JSON, '        "'+num$(I)+'": false,'
Else
 Append JSON, '        "'+num$(I)+'": true,'
Endif
Next
Append JSON, '        "30": false'
Append JSON, '    },'
Append JSON, '    "keyFunctions": {'
Append JSON, '        "GESAMK": true,'
Append JSON, '        "GESAFC": true,'
If GPRODUIT=-1 & find(adxusr,"ccl ","vpo3")
#Append JSON, '        "PATCH": false,'
#Append JSON, '        "APATCH": false,'
#Append JSON, '        "APATCHA": false,'
Append JSON, '        "GESATB": false,'
Append JSON, '        "ADPVAL": false,'
Append JSON, '        "GESACLA": false,'
Endif
Append JSON, '        "ZZZZZZ": false'
Append JSON, '    },'
Append JSON, '    "parameters": {'
Append JSON, '        "MAXFIXEDASSETS": 1000000,'
Append JSON, '        "MAXWEBSERVICES": 100,'
Append JSON, '        "MAXTERMINALRF": 100'
Append JSON, '    }'
Append JSON, '}'

ERROR = func ASYRLIC.LOAD_LICENSE(GACTX,JSON)
Return

