      If PIHUOM<>[F:MAT]TOLUOM                        # Convert to invoice UOM
        #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
        Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
        If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]IQEQTY,[F:MAT]TOLUOM,XIQEQTY,PORSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XIQEQTY,PORSTU,XIQEQTY,PIHUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,abs(QTYUOM1-PIDQTY),PIHUOM,XIQEQTY,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,QTYDIF*-1,[F:MAT]TOLUOM,[F:MAT]IQEQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif
Endif

Return
###########################################################################################
#  $PIDNETPRI_CTL = PO Net Price to Invoice Net Price Control
$PIDNETPRI_CTL
Local Decimal PRIDIF,PRICUR1,PRICUR2,PORAMT,PIHAMT,AMTDIF,AMTCUR1,AMTCUR2,XMESS
Local Decimal XUILAMT,XUIUAMT,XOIUAMT,XOILAMT
Local Integer XERR

If PORFLG & PIHFLG                                  # Both PO and Invoice data available
  If [F:MAT]UIUCTLP=2
    Call CUR_DIF(PORNETPRI,PORCUR, INVNETPRI,PIHCUR,[F:MAT]TOLCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]UIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If [F:MAT]UIUCTLP=2 & (PRICUR1 > PRICUR2)     # Net Price difference
      Call PERCENT_CLCUND(PRICUR2,PRICUR1,PCTDIF) # Calc percent under
      If (abs(PCTDIF) > [F:MAT]UIUPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]UIUACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]UIUACT)
        XMESS = 14

        If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
          Call CUR_DIF(PRICUR1,[F:MAT]TOLCUR,PRICUR2,[F:MAT]TOLCUR,PIHCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
          If ERR : XERR=[F:MAT]UIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PCTDIF*-1,"%",[F:MAT]UIUPER,PRICUR1,PRICUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PCTDIF*-1,"%",[F:MAT]UIUPER,PRICUR1,PRICUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif
      Endif
    Endif
  Endif

  If [F:MAT]UIUCTLA=2
    Call CUR_DIF(PORNETPRI,PORCUR, INVNETPRI,PIHCUR,[F:MAT]TOLCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]UIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If !ERR & [F:MAT]UIUCTLA=2 & (PRIDIF > [F:MAT]UIUAMT) & PRIDIF <> 0
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]UIUACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]UIUACT)
      XMESS = 14

      If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
        Call CUR_DIF(PRICUR1,[F:MAT]TOLCUR,PRICUR2,[F:MAT]TOLCUR,PIHCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
        If ERR : XERR=[F:MAT]UIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
        Call CONVERT([F:MAT]TOLCUR,PIHCUR,GDEVISE,1,PIHDAT,[F:MAT]UIUAMT,XUIUAMT,ERR) From TRTDEV
        If ERR : XERR=[F:MAT]UIUACT :Gosub ERR_CURR : Return : Endif # No Curr conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PRIDIF,PIHCUR,XUIUAMT,PRICUR1,PRICUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PRIDIF,[F:MAT]TOLCUR,[F:MAT]UIUAMT,PRICUR1,PRICUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif

    Endif
  Endif

  If [F:MAT]OIUCTLP=2
    Call CUR_DIF(INVNETPRI,PIHCUR,PORNETPRI,PORCUR,[F:MAT]TOLCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]OIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If [F:MAT]OIUCTLP=2 & (PRICUR1 > PRICUR2)     # Invoice Net Price over PO price
      Call PERCENT_CLCOVR(PRICUR2,PRICUR1,PCTDIF) # Percent Over
      If (abs(PCTDIF) > [F:MAT]OIUPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]OIUACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]OIUACT)
        XMESS = 13

        If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
          Call CUR_DIF(PRICUR1,[F:MAT]TOLCUR,PRICUR2,[F:MAT]TOLCUR,PIHCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
          If ERR : XERR=[F:MAT]OIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PCTDIF,"%",[F:MAT]OIUPER,PRICUR2,PRICUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PCTDIF,"%",[F:MAT]OIUPER,PRICUR2,PRICUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif
      Endif
    Endif
  Endif

  If [F:MAT]OIUCTLA=2
    Call CUR_DIF(INVNETPRI,PIHCUR,PORNETPRI,PORCUR,[F:MAT]TOLCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]OIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If !ERR & [F:MAT]OIUCTLA=2 & (PRIDIF > [F:MAT]OIUAMT) & PRIDIF <> 0
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]OIUACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]OIUACT)
      XMESS = 13

      If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
        Call CUR_DIF(PRICUR1,[F:MAT]TOLCUR,PRICUR2,[F:MAT]TOLCUR,PIHCUR,PRIDIF,PRICUR1,PRICUR2,PIHDAT,ERR,ERRMSG)
        If ERR : XERR=[F:MAT]OIUACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
        Call CONVERT([F:MAT]TOLCUR,PIHCUR,GDEVISE,1,PIHDAT,[F:MAT]OIUAMT,XOIUAMT,ERR) From TRTDEV
        If ERR : XERR=[F:MAT]OIUACT :Gosub ERR_CURR : Return : Endif # No Curr conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PRIDIF,PIHCUR,XOIUAMT,PRICUR2,PRICUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,PRIDIF,[F:MAT]TOLCUR,[F:MAT]OIUAMT,PRICUR2,PRICUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

  # Calculate Extended Amounts
  # PORAMT = PORQTYSTU * PORNETPRI # To evaluate for follow-up invoices # 105557.o
  PORAMT = PORQTY * PORNETPRI # To evaluate for follow-up invoices # 105557.n
  PIHAMT = PIDQTY * INVNETPRI
  #If [M:PIH3]TYPORI(NOL)=1  #116996.o
  If TYPORI = 1 #118572.n Invoiced direct orders
    If !clalev([PID3]) : Local File PINVOICED     [PID3] : Endif
    If !clalev([PID4]) : Local File PINVOICED     [PID4] : Endif # 114111.n
    # PORAMT = [F:POQ]QTYSTU(NOL) * PORNETPRI # Full order line check  # 91931.o
    # PORAMT = [F:POQ]QTYSTU * PORNETPRI # Full order line check       # 91931.n # 105557.o
    PORAMT = [F:POQ]QTYPUU * PORNETPRI # Full order line check         # 105557.n
    #For [PID3] Where [PID3]NUMORI=[M:PIH3]NUMORI(NOL) & [PID3]NUM<>[M:PIH0]NUM & [PID3]LINORI=[M:PIH3]LINORI(NOL) #116996.o
    For [PID3] Where [PID3]NUMORI=[POQ]POHNUM & [PID3]NUM<>[M:PIH0]NUM & [PID3]LINORI=[POQ]POPLIN #116996.n
      #PIHAMT += [PID3]AMTNOTLIN(NOL) # 94761.o
      PIHAMT += [PID3]AMTNOTLIN       # 94761.n
      # 114111.sn - Look for any associated credit memos to remove from the total
      #For [PID4] Where [PID4]INVNUM=[F:PID3]NUM & [PID4]NUM<>[M:PIH0]NUM & [PID4]INVLIN=[M:PIH3]LINORI(NOL) & [PID4]INVTYP=2 #116996.o
      For [PID4] Where [PID4]INVNUM=[F:PID3]NUM & [PID4]NUM<>[M:PIH0]NUM & [PID4]INVLIN=[POQ]POPLIN & [PID4]INVTYP=2 #116996.n
        PIHAMT -= [PID4]AMTNOTLIN
      Next
      # 114111.en
    Next
  Endif

  If [F:MAT]UILCTLP=2
    Call CUR_DIF(PORAMT,PORCUR,PIHAMT,PIHCUR,[F:MAT]TOLCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]UILACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If [F:MAT]UILCTLP=2 & (PORAMT > PIHAMT)         # Extended Invoice Amount Under PO amount
      Call PERCENT_CLCUND(AMTCUR2,AMTCUR1,PCTDIF)   # Calc percent short
      If (abs(PCTDIF) > [F:MAT]UILPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]UILACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]UILACT)
        XMESS = 16

        If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
          Call CUR_DIF(AMTCUR1,[F:MAT]TOLCUR,AMTCUR2,[F:MAT]TOLCUR,PIHCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,PCTDIF*-1,"%",[F:MAT]UILPER,AMTCUR1,AMTCUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,PCTDIF*-1,"%",[F:MAT]UILPER,AMTCUR1,AMTCUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif
      Endif
    Endif
  Endif

  If [F:MAT]UILCTLA=2
    Call CUR_DIF(PIHAMT,PIHCUR,PORAMT,PORCUR,[F:MAT]TOLCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]UILACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If !ERR & [F:MAT]UILCTLA=2 & AMTDIF < 0 & ((AMTDIF*-1) > [F:MAT]UILAMT)
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]UILACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]UILACT)
      XMESS = 16

      If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
        Call CUR_DIF(AMTCUR1,[F:MAT]TOLCUR,AMTCUR2,[F:MAT]TOLCUR,PIHCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
        Call CONVERT([F:MAT]TOLCUR,PIHCUR,GDEVISE,1,PIHDAT,[F:MAT]UILAMT,XUILAMT,ERR) From TRTDEV
        If ERR : XERR=[F:MAT]UILACT :Gosub ERR_CURR : Return : Endif # No Curr conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,AMTDIF*-1,PIHCUR,XUILAMT,AMTCUR2,AMTCUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,AMTDIF*-1,[F:MAT]TOLCUR,[F:MAT]UILAMT,AMTCUR2,AMTCUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

  If [F:MAT]OILCTLP=2
    Call CUR_DIF(PORAMT,PORCUR,PIHAMT,PIHCUR,[F:MAT]TOLCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG) ###
    If ERR : XERR=[F:MAT]OILACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If [F:MAT]OILCTLP=2 &  (PORAMT < PIHAMT)        # Extended Invoice Amount Over PO amount
      Call PERCENT_CLCOVR(AMTCUR1,AMTCUR2,PCTDIF)   # Percent Exceeded
      If (abs(PCTDIF) > [F:MAT]OILPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]OILACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]OILACT)
        XMESS = 15

        If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
          Call CUR_DIF(AMTCUR1,[F:MAT]TOLCUR,AMTCUR2,[F:MAT]TOLCUR,PIHCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,PCTDIF,"%",[F:MAT]OILPER,AMTCUR1,AMTCUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,PCTDIF,"%",[F:MAT]OILPER,AMTCUR1,AMTCUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif
      Endif
    Endif
  Endif

  If [F:MAT]OILCTLA=2
    Call CUR_DIF(PIHAMT,PIHCUR,PORAMT,PORCUR,[F:MAT]TOLCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
    If ERR : XERR=[F:MAT]OILACT :Gosub ERR_CURR : Return : Endif          # No Curr conversion
    If !ERR & [F:MAT]OILCTLA=2 & AMTDIF <> 0 & (AMTDIF > [F:MAT]OILAMT)
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]OILACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]OILACT)
      XMESS = 15

      If PIHCUR<>[F:MAT]TOLCUR      # Convert to invoice CURR
        Call CUR_DIF(AMTCUR1,[F:MAT]TOLCUR,AMTCUR2,[F:MAT]TOLCUR,PIHCUR,AMTDIF,AMTCUR1,AMTCUR2,PIHDAT,ERR,ERRMSG)
        Call CONVERT([F:MAT]TOLCUR,PIHCUR,GDEVISE,1,PIHDAT,[F:MAT]OILAMT,XOILAMT,ERR) From TRTDEV
        If ERR : XERR=[F:MAT]OILACT :Gosub ERR_CURR : Return : Endif # No Curr conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,AMTDIF,PIHCUR,XOILAMT,AMTCUR2,AMTCUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNOTLIN,PIDNOTLIN,AMTDIF,[F:MAT]TOLCUR,[F:MAT]OILAMT,AMTCUR2,AMTCUR1,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

Endif # If PORFLG & PIHFLG

Return

###########################################################################################
$ERR_UOM
TWMSTA = func TWMSTA_CHK(TWMSTA,XERR)
TWMTSTA = func TWMSTA_CHK(TWMTSTA,XERR)
Raz ERR
XMESS=1
TWMEXP(NOL)=ERRMSG
If dim([M:PTH0]PTHNUM)>0
  Raz TWMVAR,TWMMETRIC,TWMTOLA,TWMPODQTY,TWMPTDQTY,QTYDIF,QTYUOM1,QTYUOM2
  Call ERR_MSG(TWMVAR,TWMMETRIC,TWMTOLA,TWMPODQTY,TWMPTDQTY,QTYDIF,[F:MAT]TOLUOM,[F:MAT]QSQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
Else
  Raz TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,QTYDIF,QTYUOM1,QTYUOM2
  Call ERR_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,QTYDIF,[F:MAT]TOLUOM,[F:MAT]UIUAMT,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
Endif
Return
##########################################################################################
$ERR_CURR
TWMSTA = func TWMSTA_CHK(TWMSTA,XERR)
TWMTSTA = func TWMSTA_CHK(TWMTSTA,XERR)
Raz ERR
XMESS=2
TWMEXP(NOL)=ERRMSG
Call ERR_MSG(TWMVAR,TWMMETRIC,TWMTOL,PODNETPRI,PIDNETPRI,0,"",0,PRICUR1,PRICUR2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
Return
###########################################################################################
#  PERCENT_CLC = Calculate Percentage
Subprog PERCENT_CLC(NUMERATOR,DENOMINATOR,PERCENT_DIF)
Value Decimal NUMERATOR,DENOMINATOR
Variable Decimal PERCENT_DIF
Raz PERCENT_DIF
If DENOMINATOR <> 0
    #PERCENT_DIF=arr((1-(NUMERATOR/DENOMINATOR))*100,.1) # 81531.o
    PERCENT_DIF=(1-(NUMERATOR/DENOMINATOR)*100)          # 81531.n
Else
  # 112890 - If AMT1 is 0 and AMT 2 is >0, Percent diff is infinite.
  # Give a response of 999 to ensure failure.
  If NUMERATOR<>0 : PERCENT_DIF=999.99 : Endif  # 112890.n
Endif
End
############################################################################################
##  PERCENT_CLC = Calculate Percentage
Subprog PERCENT_CLCOVR(AMT1,AMT2,PERCENT_DIF)
Value Decimal AMT1,AMT2
Variable Decimal PERCENT_DIF
Raz PERCENT_DIF
If AMT1 <> 0
    #PERCENT_DIF=arr((AMT2-AMT1)/AMT1*100,.1)   # 81531.o
    PERCENT_DIF=((AMT2-AMT1)/AMT1*100)          # 81531.n
Else
  # 112890 - If AMT1 is 0 and AMT 2 is >0, Percent diff is infinite.
  # Give a response of 999 to ensure failure.
  If AMT2<>0 : PERCENT_DIF=999.99 : Endif  # 112890.n
Endif
End
############################################################################################
##  PERCENT_CLC = Calculate Percentage
Subprog PERCENT_CLCUND(AMT1,AMT2,PERCENT_DIF)
Value Decimal AMT1,AMT2
Variable Decimal PERCENT_DIF
Raz PERCENT_DIF

If AMT2 <> 0
    #PERCENT_DIF=arr((AMT2-AMT1)/AMT2*100*-1,.1)  # 81531.o
    PERCENT_DIF=((AMT2-AMT1)/AMT2*100*-1)         # 81531.n
Else
  # 112890 - If AMT1 is 0 and AMT 2 is >0, Percent diff is infinite.
  # Give a response of 999 to ensure failure.
  If AMT1<>0 : PERCENT_DIF=999.99 : Endif  # 112890.n
Endif
End
###########################################################################################
#  QTY_DIF = Calculate Quantity Difference
#Subprog QTY_DIF(TXNQTYSTU1,UOMSTU,TXNQTYSTU2,RETUOM,QTYDIF,RETQTY1,RETQTY2,WITMREF,WBPSNUM,ERR,ERRMSG) # 107025.o
Subprog QTY_DIF(TXNQTYSTU1,UOMSTU,TXNQTYSTU2,RETUOM,QTYDIF,RETQTY1,RETQTY2,WITMREF,WBPSNUM,K,ERR,ERRMSG) # 107025.n
Value Decimal TXNQTYSTU1,TXNQTYSTU2, K
Value Char UOMSTU,RETUOM,WITMREF,WBPSNUM
Variable Decimal QTYDIF,RETQTY1,RETQTY2
Variable Integer ERR
Variable Char ERRMSG
Local Integer ERW

# TXNQTYSTU1, TXNQTYSTU2 = Quantities in stock UOM
# UOMSTU = Stock UOM
# RETQTY1, RETQTY2 = Return Quantities in RETUOM
# RETUOM = Return UOM
# WITMREF = Used to determine conversion factors from ITMMASTER
# WITMREF + WBPSNUM = Used to determine conversion factors from ITMBPS

Raz QTYDIF,ERR,ERRMSG,fstat

Local Decimal QTYDIF,WCOEUOM,COEUOM


Call PCAL_QTY(TXNQTYSTU1,UOMSTU,RETQTY1,RETUOM,WITMREF,WBPSNUM,1,WCOEUOM) From TRTACHQTE1    # Convert first quantity to RETUOM
Call PCAL_QTY(TXNQTYSTU2,UOMSTU,RETQTY2,RETUOM,WITMREF,WBPSNUM,1,WCOEUOM) From TRTACHQTE1    # Convert second quantity to RETUOM

QTYDIF=RETQTY1 - RETQTY2                                # Difference in Converted quantities in RETUOM

# uom conversion check for TWM unit
#If [F:MAT]TOLUOM <> "" & UOMSTU <> RETUOM # 107025.o
If [F:MAT]TOLUOM <> "" & UOMSTU <> RETUOM & K=1 # 107025.n
 Read [TCO]TCO0=RETUOM;UOMSTU
 If fstat
   Read [TCO]TCO0=UOMSTU;RETUOM
     If fstat
      ERR=1
      ERRMSG=mess(1,584,1) + " " + UOMSTU + " to " + RETUOM
      Raz fstat
      End
  Else Raz [F:TCO] : [F:TCO]COEUOM=1
     Endif
 Endif
Endif

End

############################################################################################
#    CUR_DIF - Determine difference between two currency amounts in Tolerance currency
Subprog CUR_DIF(ORGAMT1,ORGCUR1,ORGAMT2,ORGCUR2,DESCUR,CURDIF,PRICUR1,PRICUR2,CNVDAT,ERR,ERRMSG)

Value Decimal ORGAMT1,ORGAMT2            # Currency amounts to convert
Value Char ORGCUR1,ORGCUR2,DESCUR
Value Date CNVDAT
Variable Decimal CURDIF,PRICUR1,PRICUR2
Variable Integer ERR
Variable Char ERRMSG

Raz PRICUR1,PRICUR2,CURDIF,ERR,ERRMSG

#If  (ORGCUR1 = ORGCUR2) & (ORGCUR1 = DESCUR)   # No currency conversion # 111069.o
If ((ORGCUR1 = ORGCUR2) & (ORGCUR1 = DESCUR)) | DESCUR = ""   # No currency conversion # 111069.n
    #CURDIF=arr(ORGAMT1 - ORGAMT2,2)
     CURDIF=ORGAMT1 - ORGAMT2
    PRICUR1 = ORGAMT1
    PRICUR2 = ORGAMT2
Else
    Call CONVERT(ORGCUR1,DESCUR,GDEVISE,1,CNVDAT,ORGAMT1,PRICUR1,ERR) From TRTDEV
    If  ERR
        ERRMSG=mess(20,584,1) + " " + ORGCUR1 + " to " + DESCUR # Unable to convert currency
    Else
        Call CONVERT(ORGCUR2,DESCUR,GDEVISE,1,CNVDAT,ORGAMT2,PRICUR2,ERR) From TRTDEV
        If  ERR
            ERRMSG=mess(20,584,1) + " " + ORGCUR2 + " to " + DESCUR # Unable to convert currency
        Else
            CURDIF = PRICUR1 - PRICUR2
        Endif
    Endif
Endif
End

#############################################################################################
#     ADD_MSG - adds an array of messages based on menu 584 tolerance messages
#                     and 581 order control messages
#############################################################################################
Subprog ADD_MSGDAYS(TWMVAR,TWMMETRIC,TWMTOLAMT,REQRECDAT,RECDAT,VALVAR,VALMETRIC,VALTOLAMT,EXPRECDAT,ACTRECDAT,NOL,TWMEXP,VALSTA,TWMLINSTA,MESNUM)
Value Integer MESNUM, VALVAR, VALSTA
Value Date EXPRECDAT,ACTRECDAT
Variable Decimal TWMVAR(),TWMTOLAMT()
Value Char VALMETRIC()
Value Decimal VALTOLAMT
Variable Char TWMMETRIC()(),TWMEXP()()
Variable Integer NOL,TWMLINSTA()
Variable Date REQRECDAT(), RECDAT()

If NOL < dim(TWMEXP)
    NOL+=1
    TWMEXP(NOL-1)    = mess(MESNUM,584,1)
    TWMLINSTA(NOL-1) = VALSTA
    TWMVAR(NOL-1)    = VALVAR
    TWMMETRIC(NOL-1) = VALMETRIC
    TWMTOLAMT(NOL-1) = VALTOLAMT
    REQRECDAT(NOL-1) = EXPRECDAT
    RECDAT(NOL-1)    = ACTRECDAT
Endif
End

##############################################################################################
##     ADD_MSG - adds an array of messages based on menu 584 tolerance messages
##                     and 581 order control messages
Subprog ADD_MSG(TWMVAR,TWMMETRIC,TWMTOLAMT,TWMAMT1,TWMAMT2,VALTWMVAR,VALMETRIC,VALTOLAMT,VALAMT1,VALAMT2,NOL,TWMEXP,VALSTA,TWMLINSTA,MESNUM)
Value Integer MESNUM,VALSTA
Value Char VALMETRIC()
Value Decimal VALAMT1,VALAMT2,VALTWMVAR,VALTOLAMT
Variable Decimal TWMVAR(),TWMTOLAMT(),TWMAMT1(),TWMAMT2()
Variable Char TWMMETRIC()(),TWMEXP()()
Variable Integer NOL,TWMLINSTA()

If NOL < dim(TWMEXP)
    NOL+=1
    TWMEXP(NOL-1)    = mess(MESNUM,584,1)
    TWMLINSTA(NOL-1) = VALSTA
    TWMVAR(NOL-1)    = VALTWMVAR
    TWMMETRIC(NOL-1) = VALMETRIC
    TWMTOLAMT(NOL-1) = VALTOLAMT
    TWMAMT1(NOL-1 )  = VALAMT1
    TWMAMT2(NOL-1)   = VALAMT2
Endif

End

###################################################################################
Subprog ERR_MSG(TWMVAR,TWMMETRIC,TWMTOLAMT,TWMAMT1,TWMAMT2,VALTWMVAR,VALMETRIC,VALTOLAMT,VALAMT1,VALAMT2,NOL,TWMEXP,VALSTA,TWMLINSTA,MESNUM)
Value Integer MESNUM,VALSTA
Value Char VALMETRIC()
Value Decimal VALAMT1,VALAMT2,VALTWMVAR,VALTOLAMT
Variable Decimal TWMVAR(),TWMTOLAMT(),TWMAMT1(),TWMAMT2()
Variable Char TWMMETRIC()(),TWMEXP()()
Variable Integer NOL,TWMLINSTA()

If NOL < dim(TWMEXP)
    NOL+=1
    TWMLINSTA(NOL-1) = VALSTA
    TWMVAR(NOL-1)    = VALTWMVAR
    TWMMETRIC(NOL-1) = VALMETRIC
    TWMTOLAMT(NOL-1) = VALTOLAMT
    TWMAMT1(NOL-1 )  = VALAMT1
    TWMAMT2(NOL-1)   = VALAMT2
Endif

End
#####################################################################################
# Label added by supervisor (screen TWMLIBTSA4) 09/26/2011 17:02:29 (RCB)
#####################################################################################
Subprog AS_NBLIG
Local Integer SAVNOLIGN,PIDLIN
SAVNOLIGN = nolign
If find(GACTION,"TWMDOCMAT","TWMLINMAT")  # Invoicing
[L]PIDLIN = [M:TWS1]PIDLIN(nolign-1)
nolign = 0
Raz [M:TWS1]NBLIG1

For NOL=1 To [M:TWS3]NBLIG1
    If  [L]PIDLIN = [M:TWS3]PIDLINMAT(NOL-1)
        nolign+=1
        [M:TWS1]PIDLINMAT(nolign-1) = [M:TWS3]PIDLINMAT(NOL-1)
        [M:TWS1]TWMLINSTA(nolign-1) = [M:TWS3]TWMLINSTA(NOL-1)
        [M:TWS1]TWMEXP(nolign-1)    = [M:TWS3]TWMEXP(NOL-1)
        [M:TWS1]TWMVAR(nolign-1)    = [M:TWS3]TWMVAR(NOL-1)
        [M:TWS1]TWMMETRIC(nolign-1) = [M:TWS3]TWMMETRIC(NOL-1)
        [M:TWS1]TWMALLOW(nolign-1)  = [M:TWS3]TWMALLOW(NOL-1)
        [M:TWS1]PODQTY(nolign-1)    = [M:TWS3]PODQTY(NOL-1)
        [M:TWS1]PTDQTY(nolign-1)    = [M:TWS3]PTDQTY(NOL-1)
        [M:TWS1]PIDQTY(nolign-1)    = [M:TWS3]PIDQTY(NOL-1)
        [M:TWS1]PODNETPRI(nolign-1) = [M:TWS3]PODNETPRI(NOL-1)
        [M:TWS1]PIDNETPRI(nolign-1) = [M:TWS3]PIDNETPRI(NOL-1)
        [M:TWS1]PODNOTLIN(nolign-1) = [M:TWS3]PODNOTLIN(NOL-1)
        [M:TWS1]PIDNOTLIN(nolign-1) = [M:TWS3]PIDNOTLIN(NOL-1)
        [M:TWS1]CUR(nolign-1)       = [M:TWS3]CUR(NOL-1)
        [M:TWS1]UOM(nolign-1)       = [M:TWS3]UOM(NOL-1)
    Endif
Next
[M:TWS1]NBLIG1 = nolign
nolign = SAVNOLIGN
Affzo [M:TWS1]10
Else  # Receiving
[L]PIDLIN = [M:TWS2]PIDLIN(nolign-1)
nolign = 0
Raz [M:TWS2]NBLIG1

For NOL=1 To [M:TWS3]NBLIG1
    If  [L]PIDLIN = [M:TWS3]PIDLINMAT(NOL-1)
        nolign+=1
        [M:TWS2]PIDLINMAT(nolign-1) = [M:TWS3]PIDLINMAT(NOL-1)
        [M:TWS2]TWMLINSTA(nolign-1) = [M:TWS3]TWMLINSTA(NOL-1)
        [M:TWS2]TWMEXP(nolign-1)    = [M:TWS3]TWMEXP(NOL-1)
        [M:TWS2]TWMVAR(nolign-1)    = [M:TWS3]TWMVAR(NOL-1)
        [M:TWS2]TWMMETRIC(nolign-1) = [M:TWS3]TWMMETRIC(NOL-1)
        [M:TWS2]TWMALLOW(nolign-1)  = [M:TWS3]TWMALLOW(NOL-1)
        [M:TWS2]PODQTY(nolign-1)    = [M:TWS3]PODQTY(NOL-1)
        [M:TWS2]PTDQTY(nolign-1)    = [M:TWS3]PTDQTY(NOL-1)
        [M:TWS2]PIDQTY(nolign-1)    = [M:TWS3]PIDQTY(NOL-1)
        [M:TWS2]PODNETPRI(nolign-1) = [M:TWS3]PODNETPRI(NOL-1)
        [M:TWS2]PIDNETPRI(nolign-1) = [M:TWS3]PIDNETPRI(NOL-1)
        [M:TWS2]PODNOTLIN(nolign-1) = [M:TWS3]PODNOTLIN(NOL-1)
        [M:TWS2]PIDNOTLIN(nolign-1) = [M:TWS3]PIDNOTLIN(NOL-1)
        [M:TWS2]CUR(nolign-1)       = [M:TWS3]CUR(NOL-1)
        [M:TWS2]UOM(nolign-1)       = [M:TWS3]UOM(NOL-1)
        [M:TWS2]EXPRCP(nolign-1)    = [M:TWS3]EXPRCP(NOL-1)
        [M:TWS2]RCPDAT(nolign-1)    = [M:TWS3]RCPDAT(NOL-1)
    Endif
Next
[M:TWS2]NBLIG1 = nolign
nolign = SAVNOLIGN
Affzo [M:TWS2]10
Endif

End
######################################################################################################
$PIDQTY_CREDITS  #109135.sn Check for other invoices not associated with a receipt/return - such as credit invioce with no return.
Local Decimal CRQTYSTU
Raz CRQTYSTU
  If [M:PIH0]PIHTYP=1 & [M:PIH3]TYPORI=2 # Debit invoice against receipt
    If !clalev([PTD])  : Local File PRECEIPTD  [PTD] : Endif
    If !clalev([POQ])  : Local File PORDERQ    [POQ] : Endif
    If !clalev([PID4]) : Local File PINVOICED [PID4] : Endif
    If !clalev([PID5]) : Local File PINVOICED [PID5] : Endif
    #CATUA X3-59561.sn
    #Need to properly retireve the correct line number using SAVNOL variable or else it always default to the first line
    #Filter [PTD] Where [PTD]PTHNUM=[M:PIH3]NUMORI(NOL) & [PTD]PTDLIN=[M:PIH3]LINORI #CATUA X3-59561.o
    Filter [PTD] Where [PTD]PTHNUM=[M:PIH3]NUMORI(SAVNOL) & [PTD]PTDLIN=[M:PIH3]LINORI(SAVNOL)
    #CATUA X3-59561.en
    Read [PTD] Last # Finding parent receipt of current invoice
    If !fstat
      Filter [POQ] Where POHNUM=[PTD]POHNUM & POPLIN=[PTD]POPLIN
      Read [POQ] Last  # Finding parent order of current invoice
      If !fstat
        For [PID4] Where [PID4]TYPORI=2 & [PID4]POHNUM=[POQ]POHNUM & [PID4]POPLIN=[POQ]POPLIN # Debit invoice
          # BODEL X3-38652.sn
          #For [PID5] Where find([PID5]TYPORI,4,5)>0 & [PID5]NUMORI=[PID4]NUM & [PID5]PIHTYP=3 & [PID5]INVLIN=[PID4]PIDLIN # Credit invoice w/no return
          #
          # Sent the filter of TYPORI to SQL instead of allowing 4Gl to filter using the find(TYPORI,4,5) function. X3-38652.o
          For [PID5]Where ( TYPORI=4 | TYPORI=5 ) & [PID5]NUMORI=[PID4]NUM & [PID5]PIHTYP=3 & [PID5]INVLIN=[PID4]PIDLIN # Credit invoice w/no return - X3-38652.n
          # BODEL X3-38652.en
            CRQTYSTU+=[PID5]QTYSTU # Credit qty
          Next # PID5
        Next # PID4
      Endif
      Filter [POQ]
    Endif
    Filter [PTD]
  PTRQTYSTU+=CRQTYSTU # Adding Credit invoice (no return) qty to receipt quantity
  Endif
Return #109135.en

