####################################################################################
# Program Name: TWMLIB
# Description : Three Way Matching Library
# Author      : GRNA
####################################################################################


##################################################
#  Determine 3 Matching code for non-manual PO'
Subprog GET_TWMCOD(WBPSNUM,WITMREF,WTOLCOD)
Value Char WBPSNUM(),WITMREF()
Variable Char WTOLCOD()

Local Char SAVBPSNUM(GLONBPR), SAVITMREF(GLONITM)
Raz WTOLCOD                        # Default WTOLCOD if error occurs

If !clalev([F:BPS]) : Local File BPSUPPLIER [F:BPS] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [F:ITM] : Endif
If !clalev([F:ITP]) : Local File ITMBPS     [F:ITP] : Endif

SAVBPSNUM = [F:BPS]BPSNUM
SAVITMREF = [F:ITM]ITMREF

# Read data required to determine matching tolerance code
If [F:BPS]BPSNUM <> WBPSNUM
    Read [BPS]BPS0=WBPSNUM
    If fstat : Raz [F:BPS] : Endif
Endif

If [F:ITM]ITMREF <> WITMREF
   Read [F:ITM]ITM0 = WITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

If ([F:ITP]ITMREF <> WITMREF) | ([F:ITP]BPSNUM <> WBPSNUM)
   Read [F:ITP]ITP0 = WITMREF;WBPSNUM
   If fstat : Raz [F:ITP] : Endif
Endif

# Determine Matching Tolerance Code
Call POH_D_MATTOL(WTOLCOD)

# Restore buffers
If [F:BPS]BPSNUM <> SAVBPSNUM
    Read [BPS]BPS0=SAVBPSNUM
    If fstat : Raz [F:BPS] : Endif
Endif

If [F:ITM]ITMREF <> SAVITMREF
   Read [F:ITM]ITM0 = SAVITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

If ([F:ITP]ITMREF <> SAVITMREF) | ([F:ITP]BPSNUM <> SAVBPSNUM)
   Read [F:ITP]ITP0 = SAVITMREF;SAVBPSNUM
   If fstat : Raz [F:ITP] : Endif
Endif

End

#################################################
Subprog POH_D_MATTOL(VALEUR)
Variable Char    VALEUR()

If    [F:ITP]MATTOL<>"" : VALEUR=[F:ITP]MATTOL
Elsif [F:ITM]MATTOL<>"" : VALEUR=[F:ITM]MATTOL
Elsif [F:BPS]MATTOL<>"" : VALEUR=[F:BPS]MATTOL
Endif

End

##################################################
Subprog PTH_D_MATTOL(VALEUR)
Variable Char    VALEUR()

If dim([M:PTH1]POHNUM(nolign-1))>0  # No direct orders
  If [F:POP]MATTOL<>"" : VALEUR=[F:POP]MATTOL : Endif
Endif

End


####################################################################################
Subprog PIH_D_MATTOL(VALEUR)
Variable Char    VALEUR()

# Always load from the order
If [F:POP]MATTOL<>"" : VALEUR=[F:POP]MATTOL : Endif

End


############################################################
$PTH_VERIF
Local Integer XOK, XMAT
## Just check for blocking or warning code on any line
If GFONCTION<>"GESPTH" : Return : Endif # Bypass ADC for now

For I=0 To [M:PTH1]NBLIG-1
  If dim([M:PTH1]POHNUM(I))>0              # No direct orders
     If left$([M:PTH1]TWMACT(I),1)="4"     # Error
       XMAT=1
       Break
     Elsif left$([M:PTH1]TWMACT(I),1)="3"  # Warning - keep looping in case of error
       XMAT=2
     Endif
  Endif
Next

If XMAT=2   # Warning message
  If GIMPORT  # 56915.n
    Call ECR_TRACE(mess(23,584,1),-1) From GESECRAN # Warning message
  Else
    Call OUINON(mess(11,584,1),XOK) From GESECRAN # Warning message prompt
    If XOK<>2
      GERR=1
    Endif
  Endif
Endif

If XMAT=1   # Blocking message
  If GACTION="SAISTOENTM"
    Call ERREUR(mess(21,584,1)) From GESECRAN # Blocking error message
  Else
    Call ERREUR(mess(10,584,1)) From GESECRAN # Blocking error message
  Endif
  GERR=1: ERR=1: GOK=0: OK=0
Endif

Return


###########################################################
Subprog PTH_APRES_NBLIG
Local Integer PTHACT, XACT, XPTHACT, XMATCH  # 1 = Block, 2 = Warning, 3 = blank (LM 581)
Local Decimal PTHQTY,POQTY,COEUOM, XRCTQTY, XMESS
Local Shortint NOL : NOL = nolign-1

GOK=1
GERR=0

WVCRTYP=6
Local Char TWMEXP(100)(25), ERRMSG(250),TWMMETRIC(10)(25),STYLE(20)
Local Integer I,ERR,POH_FND,PTH_FND,TWMSTA(25),TWMBLK, TWMTSTA(25) ###
Local Decimal TWMVAR(25),TWMALLOW(25),PODQTY(25),PTDQTY(25),PIDQTY(25),PODNETPRI(25),PIDNETPRI(25),PODNOTLIN(25),PIDNOTLIN(25)
Local Date REQRECDAT(25), RECDAT(25)

Raz I,ERR,ERRMSG,[L]TWMEXP,[L]TWMSTA,[L]TWMBLK,POH_FND,PTH_FND,[L]TWMMETRIC,[L]PODQTY,[L]PTDQTY,[L]PIDQTY,[L]PODNETPRI,[L]PIDNETPRI
Raz [L]PODNOTLIN,[L]PIDNOTLIN,[L]REQRECDAT,[L]RECDAT, [L]TWMTSTA
Call TWMLIN(WVCRTYP,NOL,POH_FND,PTH_FND,TWMVAR,TWMMETRIC,TWMALLOW,PODQTY,PTDQTY,PIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,
&        REQRECDAT,RECDAT,TWMTSTA,TWMSTA,TWMEXP,TWMBLK,ERR,ERRMSG) From TWMLIB

# display messages for ADC
If GFONCTION="VXAPR"
  Call APR_TWMMESS(TWMBLK,TWMEXP(find(TWMBLK,TWMSTA)-1))
  End
Endif

Call PTH_TWMMESS(TWMBLK,1,NOL)
# Affzo [M:PTH1]1-99                          # Performance- 82380

End

###########################################################
Subprog ENM_APRES_NBLIG(ENMNOL)
Value Decimal ENMNOL
Local Integer PTHACT, XACT, XPTHACT, XMATCH  # 1 = Block, 2 = Warning, 3 = blank (LM 581)
Local Decimal PTHQTY,POQTY,COEUOM, XRCTQTY, XMESS
#Local Shortint NOL : NOL = nolign-1

GOK=1
GERR=0

If !find(GFONCTION,"GESPTH","VXAPR") : End : Endif

WVCRTYP=6
Local Char TWMEXP(100)(25), ERRMSG(250),TWMMETRIC(10)(25),STYLE(20)
Local Integer I,ERR,POH_FND,PTH_FND,TWMSTA(25),TWMBLK, TWMTSTA(25) ###
Local Decimal TWMVAR(25),TWMALLOW(25),PODQTY(25),PTDQTY(25),PIDQTY(25),PODNETPRI(25),PIDNETPRI(25),PODNOTLIN(25),PIDNOTLIN(25)
Local Date REQRECDAT(25), RECDAT(25)

Raz I,ERR,ERRMSG,[L]TWMEXP,[L]TWMSTA,[L]TWMBLK,POH_FND,PTH_FND,[L]TWMMETRIC,[L]PODQTY,[L]PTDQTY,[L]PIDQTY,[L]PODNETPRI,[L]PIDNETPRI
Raz [L]PODNOTLIN,[L]PIDNOTLIN,[L]REQRECDAT,[L]RECDAT, [L]TWMTSTA

Call TWMLIN(WVCRTYP,ENMNOL,POH_FND,PTH_FND,TWMVAR,TWMMETRIC,TWMALLOW,PODQTY,PTDQTY,PIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,
&        REQRECDAT,RECDAT,TWMTSTA,TWMSTA,TWMEXP,TWMBLK,ERR,ERRMSG) From TWMLIB

Call PTH_TWMMESS(TWMBLK,1,ENMNOL)
#Affzo [M:PTH1]             # RBU 94497 Performance

End


#################################################################################
Subprog AM_RCPDAT(NOL)
Value Integer NOL
Local Integer PTHACT, XACT, XPTHACT, XMATCH  # 1 = Block, 2 = Warning, 3 = blank (LM 581)
Local Decimal PTHQTY,POQTY,COEUOM, XRCTQTY, XMESS

GOK=1
GERR=0

WVCRTYP=6
Local Char TWMEXP(100)(25), ERRMSG(250),TWMMETRIC(10)(25),STYLE(20)
Local Integer I,ERR,POH_FND,PTH_FND,TWMSTA(25),TWMBLK, TWMTSTA(25)
Local Decimal TWMVAR(25),TWMALLOW(25),PODQTY(25),PTDQTY(25),PIDQTY(25),PODNETPRI(25),PIDNETPRI(25),PODNOTLIN(25),PIDNOTLIN(25)
Local Date REQRECDAT(25), RECDAT(25)

Raz I,ERR,ERRMSG,[L]TWMEXP,[L]TWMSTA,[L]TWMBLK,POH_FND,PTH_FND,[L]TWMMETRIC,[L]PODQTY,[L]PTDQTY,[L]PIDQTY,[L]PODNETPRI,[L]PIDNETPRI
Raz [L]PODNOTLIN,[L]PIDNOTLIN,[L]REQRECDAT,[L]RECDAT, [L]TWMTSTA

Call TWMLIN(WVCRTYP,NOL,POH_FND,PTH_FND,TWMVAR,TWMMETRIC,TWMALLOW,PODQTY,PTDQTY,PIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,
&        REQRECDAT,RECDAT,TWMTSTA,TWMSTA,TWMEXP,TWMBLK,ERR,ERRMSG) From TWMLIB

Call PTH_TWMMESS(TWMBLK,1,NOL)
#Affzo [M:PTH1]             # RBU 94497 Performance

End
# to refresh MATEXP message at bottom of screen
###########################################################
Subprog PTH_AS_NBLIG
Local Integer NOL : NOL = nolign-1
 GOK=1
 GERR=0
  If [M:PTH1]TWMACT(NOL)=""
   Call PTH_TWMMESS(2,0,NOL)
  Else
   Call PTH_TWMMESS(val(left$([M:PTH1]TWMACT(NOL),1)),val(right$([M:PTH1]TWMACT(NOL),2)),NOL)
  Endif
End

###########################################################
$PTH_FIN_PICK
Local Integer ACT,MSG

# RBU 94497 Performance
For NOL=0 To [M:PTH1]NBLIG-1
  If dim([M:PTH1]MATTOL)>0 and [M:PTH1]MATTOL(NOL)<>""
      ACT = val(left$([M:PTH1]TWMACT(NOL),1))
      PTHMESS = val(right$([M:PTH1]TWMACT(NOL),2))
      Gosub TWMMESS
      Chgstl [M:PTH1]ITMREF(NOL) With STYLE
      Affzo [M:PTH1]ITMREF(NOL)
  Endif
Next
#Affzo [M:PTH1]ITMREF(0)               # RBU 94497 Performance

Return
############################################################
$PTH_LIENS     # Saved receipts match status is either successful or not matched
Local Integer NOL : NOL = nolign-1

Call PTH_APRES_NBLIG

# Affzo [M:PTH1]1-99                          # Performance- 82380
Return
############################################################
Funprog TWMSTA_CHK(TWSSTA,OTWMBLK)
Value Integer TWSSTA, OTWMBLK

If TWSSTA = 4  : End TWSSTA : Endif # Blocked

If OTWMBLK=1    # Block
  TWSSTA=4
Elsif OTWMBLK=2 # Warning
  TWSSTA=3
Else
  TWSSTA=2      # Successful
Endif

End TWSSTA
####################################################################################
Funprog TWMTSTA_CHK(TWTSTA,OTWMBLK)
Value Integer TWTSTA, OTWMBLK

If OTWMBLK=1    # Block
  TWTSTA=4
Elsif OTWMBLK=2 # Warning
  TWTSTA=3
Else
  TWTSTA=2      # Successful
Endif

End TWTSTA
###################################################################################
Subprog PTH_TWMMESS(ACT,MSG,NOL)
Value    Integer ACT,MSG,NOL
#Local Integer NOL : NOL = nolign-1

If NOL<0 : End : Endif
If ACT>0               # Tolerance warning or block
  [M:PTH1]TWMACT(NOL) = num$(ACT) + num$(MSG)
Else
  [M:PTH1]TWMACT(NOL) = num$(ACT) + num$(9)
Endif

If !(dim(GPTH_PICK)>0 and GPTH_PICK<>0)        # RBU 94497 PERFORMANCE - due to cell colors in the displayed grid
  If dim([M:PTH1]MATTOL)>0 and [M:PTH1]MATTOL(NOL)<>""
      Gosub TWMMESS
      Chgstl [M:PTH1]ITMREF(NOL) With STYLE
  Endif
Endif                                         # RBU 94497

If dim([M:PTH1]TWMSTA(NOL))>0
  [M:PTH1]TWMSTA(NOL) = ACT
   If !(dim(GPTH_PICK)>0 and GPTH_PICK<>0)
     # Issue 96203 - 2014-02-14 by SR : Perf
#     Affzo [M:PTH1]TWMSTA(NOL)                # RBU 94497 PERFORMANCE - due to cell colors in the displayed grid
   Endif
Endif

End

###########################################################
Subprog APR_TWMMESS(ACT,MESSAGE)
Value    Integer ACT
Value    Char    MESSAGE

Case ACT  # Match status
  When 4  # blocked
    GMESSAGE = mess(22,584,1) + ":" - MESSAGE
    mkstat=2
  When 3  # warning
    Local Integer TWMOK : TWMOK=2
    Call OUINON(mess(23,584,1) + ":" - MESSAGE + "\" + mess(641,196,1),TWMOK) From GESECRAN
    If TWMOK<>2  # continue = no
      mkstat=2
    Endif
  When 2  # successful
    Call MESSAGE(mess(9,584,1)) From GESECRAN
  When 1  # not matched
    # do nothing
Endcase

End
###########################################################
$PIH_APRES_NBLIG

If dim(STYLE)<>1 : Local Char STYLE(20) : Endif

#For NOL=0 To [M:PIH3]NBLIG-1  # To update PIH3 dynamically # 83001.o - performance
