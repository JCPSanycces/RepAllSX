Return

###########################################################
$PIH_TWMSTA
Local Integer J
If [M:PIH1]TWMSTA=5       : Return  : Endif
Return
###########################################################
$TWS_TWMSTA
Local Integer J

If dim([M:PIH1]TWMSTA)>0
 If [M:PIH1]TWMSTA=5 : [M:TWS0]TWMSTA = 5 : Return : Endif  # Unblocked invoice
Endif

# RBU #94497 - Performance
[M:TWS0]TWMSTA = 1
If WVCRTYP=6 # Receiving
  If find(4,[M:PTH1]TWMSTA(0..[M:PTH1]NBLIG-1))
    [M:TWS0]TWMSTA = 4
  Elsif find(3,[M:PTH1]TWMSTA(0..[M:PTH1]NBLIG-1))
    [M:TWS0]TWMSTA = 3
  Elsif find(2,[M:PTH1]TWMSTA(0..[M:PTH1]NBLIG-1))
    [M:TWS0]TWMSTA = 2
  Endif
Else # Invoicing
  If find(4,[M:PIH3]TWMSTAL(0..[M:PIH3]NBLIG-1)) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
    [M:TWS0]TWMSTA = 4
  Elsif find(3,[M:PIH3]TWMSTAL(0..[M:PIH3]NBLIG-1)) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
    [M:TWS0]TWMSTA = 3
  Elsif find(2,[M:PIH3]TWMSTAL(0..[M:PIH3]NBLIG-1)) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
    [M:TWS0]TWMSTA = 2
  Endif
Endif

# RBU #94497 - Performance
#If WVCRTYP=6 # Receiving
#[M:TWS0]TWMSTA = 1
#For J=0 To [M:PTH1]NBLIG-1
#   If [M:PTH1]TWMSTA(J)=4    : [M:TWS0]TWMSTA = 4 : Break : Endif # Block
#   If [M:PTH1]TWMSTA(J)=3    : [M:TWS0]TWMSTA = 3                 # Warning
#   Elsif [M:PTH1]TWMSTA(J)=2 & [M:TWS0]TWMSTA <> 3
#                               [M:TWS0]TWMSTA = 2                 # Successful
#   Elsif [M:PTH1]TWMSTA(J)=1 & [M:TWS0]TWMSTA<>2 & [M:TWS0]TWMSTA<>3
#                               [M:TWS0]TWMSTA = 1                 # No match
#   Endif
#Next
#Else # Invoicing
#[M:TWS0]TWMSTA = 1
#For J=0 To [M:PIH3]NBLIG-1
#   If [M:PIH3]TWMSTA(J)=4    : [M:TWS0]TWMSTA = 4 : Break : Endif # Block
#   If [M:PIH3]TWMSTA(J)=3    : [M:TWS0]TWMSTA = 3                 # Warning
#   Elsif [M:PIH3]TWMSTA(J)=2 & [M:TWS0]TWMSTA <> 3
#                               [M:TWS0]TWMSTA = 2                 # Successful
#   Elsif [M:PIH3]TWMSTA(J)=1 & [M:TWS0]TWMSTA<>2 & [M:TWS0]TWMSTA<>3
#                               [M:TWS0]TWMSTA = 1                 # No match
#   Endif
#Next
#Endif
# RBU #94497 - Performance

If dim([M:PIH1]TWMSTA)>0
 If [M:PIH1]TWMSTA=5 : [M:TWS0]TWMSTA = 5 : Endif  # Unblocked invoice
Endif

Return
##########################################################
$PIH_TWMACT
Local Integer WVCRTYP,PIH_CHECK,TWMBLK,SAV_NOL,SAVSTA
Local Integer SAVSTAL                                     # 87269.n

If dim(BLKSTA)<>1 : Local Integer BLKSTA : Endif
If [F:PIH]STA=3 : Return : Endif # On re-evaluation on validated invoices

SAV_NOL = NOL
WVCRTYP = 17
PIH_CHECK=1

Gosub TWMATCH
PIH_CHECK=0
NOL = SAV_NOL

SAVSTAL = [M:PIH3]TWMSTAL(NOL)                             # 87269.n # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
If [M:PIH3]TYPORI(NOL)<3  # Receipt or PO origin
 [M:PIH3]TWMSTAL(NOL) = TWMBLK # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
Else
 [M:PIH3]TWMSTAL(NOL) = 1 # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
Endif

[M:PIH1]TWMSTA = max([M:PIH3]TWMSTAL(NOL),[M:PIH1]TWMSTA) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)

If [M:PIH1]TWMSTA=5 & [M:PIH3]TWMSTAL(NOL)=4 # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
  SAVSTA=4 # To block invoice on addition of lines to an unblocked invoice
Endif

# Affzo [M:PIH1]TWMSTA                                    # 83001.o
# Affzo [M:PIH3]TWMSTA(NOL)                               # 83001.o

# 87269.sn - only Affzo if something changed
If SAVSTAL<>[M:PIH3]TWMSTAL(NOL) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
  Affzo [M:PIH3]TWMSTAL(NOL) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
Endif
# 87269.en

Return


## Called from SUBPIHD.PICKE_CDE, SUBPIH.AM_TYPORI
#####################################################################################
$PIH_TWMCHK

If [M:PIH3]TYPORI(NOL)>2 : Return : Endif

# Exit if credit or item is blank
If [M:PIH0]PIHTYP>2 | [M:PIH3]ITMREF(NOL)="" : Return : Endif

If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
  Read [ITM]ITM0=[M:PIH3]ITMREF(NOL)
  If fstat : Raz [F:ITM] : Endif
Endif

# Exit if item is not receivable
If [F:ITM]RCPFLG<>2 : Return : Endif

# PI Line Load
# 1 - No restriction
# 2 - Select from PO lines only when no receipt exists
# 3 - Select from receipt lines only
Local Integer PIBLKR : PIBLKR = val(func AFNC.PARAM("PIBLKR",[M:PIH0]FCY))

#Issue 121266.sn - 2017-02-17 by CRT
#Allow loading for PO direct to customer back-to-back orders
#If [M:PIH3]TYPORI(NOL)=1 & (PIBLKR=3 | (PIBLKR=2 & [F:POQ]RCPCLEFLG=2))
If [M:PIH3]TYPORI(NOL)=1
  If [F:POQ]SOHNUM<>"" & [F:POQ]ORI=2
    #For PO direct to customer back-to-back orders
    #Error if param is receipt only (3) and order has been received
    #Error if param is order/no receipt (2) and order has been received
    If find(PIBLKR,2,3) & [F:POQ]PTHNUM<>""
      GMESSAGE = mess(19,584,1) : mkstat=2
      FIN=1
    Endif
  Else
    #Error if param is receipt only (3)
    #Error if param is order/no receipt (2) and order has been received
    If PIBLKR=3 | (PIBLKR=2 & [F:POQ]PTHNUM<>"")
      GMESSAGE = mess(19,584,1) : mkstat=2
      FIN=1
    Endif
  Endif
Endif
#Issue 121266.en - 2017-02-17 by CRT

Return

###########################################################
$PIH_FIN_PICK
# Recheck all the colors
Local Integer ACT,MSG
For NOL=0 To [M:PIH3]NBLIG-1
  ACT = val(left$([M:PIH3]TWMACT(NOL),1))
  PTHMESS = val(right$([M:PIH3]TWMACT(NOL),2))
  Gosub TWMMESS
  Chgstl [M:PIH3]ITMREF(NOL) With STYLE
Next

Return

####################################################################################
Subprog TWMSTYLE(TWMBLK, STYLE)
Value Integer TWMBLK
Variable Char STYLE()
Case TWMBLK
    When 4 : STYLE = "TWMBLOCK"
    When 3 : STYLE = "TWMWARN"
    When Default: STYLE = ""
Endcase
End

####################################################################################
$TWMMESS
Local Char MESSAGE(250),STYLE(20), STYLEA(20)

Case ACT
  When 4
    MESSAGE = mess(MSG,584,1)  # Blocking message
    STYLE   = "TWMBLOCK"  #"TWMORANGE"
    STYLEA  = "AWARNHIGH"
  When 3
    MESSAGE = mess(MSG,584,1)  # Warning message
    STYLE   = "TWMWARN"  # "TWMBLUE"
    STYLEA  = "AWARNLOW"
  When 2
    MESSAGE =  ""              # OK
    STYLE   = ""
    STYLEA  = ""
  When Default
    MESSAGE = mess(MSG,584,1)  # Other
    STYLE   = ""
    STYLEA  = ""
Endcase

If dim(WSTOFLG)>0 & WSTOFLG(NOL)=0 & [M:PTH1]CREFLG(NOL)=0  # Incomplete line
Case ACT
 When 4
  STYLE  = "TWMBLOCKIC"  #"TWMORAIC"  # Red font / Orange bg
 When 3
  STYLE  = "TWMWARNIC"   #"TWMBLUEIC" # Red font / Blue bg
 When 2
  STYLE  = "AWARNHIGH"
  STYLEA = ""
 When Default
  STYLE  = "AWARNHIGH"
  STYLEA = ""
Endcase
Endif

Return

####################################################################################
$PIH_SETBOUT
Local Integer NOL
Local Integer TSTAT
Local Char STYLE

# activate menu option (EU = “Unblock”)
If GREP="" & [M:PIH1]STA<3 & [M:PIH1]TWMSTA=4
  GBIDC2="U": Gosub AUTORIS_OPT From CONTX3  # "U" option set in GESPAY function
  If GBIDI2 : CHMEN+="U" : Endif
Endif

# disable Post if Matching blocked
If [M:PIH1]TWMSTA=4
  Call VIREBOUT(CHAINE,"2")  From GOBJET
Endif

If clalev ([F:PTR])=0   Local File PURTRS [PTR] : Endif
 Read [PTR]PTR0=8;GFLAG
 If !fstat
  If [F:PTR]MATFLG<> 2
     Call VIREBOUT(CHAINE,"4") From GOBJET  # Disable match results button
  Endif
 Endif

If dim([M:PIH0]NUM)>0 & [F:PIH]STA=3
 Call VIREBOUT(CHAINE,"4") From GOBJET  # Disable match results button
Endif

For NOL=0 To [M:PIH3]NBLIG-1
   Call TWMSTYLE([M:PIH3]TWMSTAL(NOL), STYLE) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
   Chgstl [M:PIH3]ITMREF(NOL) With STYLE
Next

Return

################################################################################
PTH_SETBOUT
If clalev ([F:PTR])=0   Local File PURTRS [PTR] : Endif
 If [F:PTR]MATFLG<> 2
    Call VIREBOUT(CHAINE,"4") From GOBJET  # Disable match results button
 Endif

Return
#################################################################################
# Called from SUBPIHA.MODIF (on save)
####################################################################################
$PIH_TWMSTA_CHK
Local Integer BLOCK, BLKSTA
# Perform matching tolerance checks

# The invoice has been previously unblocked and the total line amount is now greater,
# it will be blocked and require attention before posting will be allowed.

If [F:PIH]TWMSTA=5 & [F:PIH]UBLAMT<[F:PIH]BASTAX
  BLKSTA=1

For NOL=0 To [M:PIH3]NBLIG-1
 Gosub PIH_TWMACT
 If [M:PIH3]TWMSTAL(NOL)=4 # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
   Update [PID] Where NUM=[F:PIH]NUM & PIDLIN=[M:PIH3]PIDLIN(NOL) With TWMSTA=4
   If fstat
    GOK = 0 : Call FSTA("PID") From GLOCK : Rollback
   Endif
 Endif
Next

  [F:PIH]TWMSTA=4
  Rewrite [PIH]
  If fstat
   GOK = 0 : Call FSTA("PIH") From GLOCK : Rollback
  Endif

Endif

Return
####################################################################################
# Called from TWNUNBLK action
####################################################################################
Subprog PIUNBLK(NUM)
Value    Char    NUM
Local Integer I

If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
Local Integer OK

# Verifications
# Confirm Unblocking
OK = 1 : Call OUINON(mess(12,584,1),OK) From GESECRAN
If OK<>2 : End : Endif

# Read Invoice
Read [PIH]PIH0=NUM
If fstat : End : Endif

# Invoice not posted
If [F:PIH]STA>2 : End : Endif

# Invoice not blocked or already unblocked

For I=0 To [M:PIH3]NBLIG-1
 If [M:PIH3]TWMSTAL(I)=4 : [M:PIH3]TWMSTAL(I)=5: Endif # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
Next

Trbegin [PIH],[PID]
[F:PIH]UBLUSR = GUSER
[F:PIH]UBLDAT = date$
[F:PIH]UBLAMT = [F:PIH]BASTAX
[F:PIH]TWMSTA = 5
Rewrite [PIH]
If fstat
  GOK = 0 : Call FSTA("PIH") From GLOCK : Rollback : End
Endif

Update [PID] Where NUM=[L]NUM & TWMSTA=4 With TWMSTA=5
If fstat
  GOK = 0 : Call FSTA("PID") From GLOCK : Rollback : End
Endif

Commit

End


#################################################################################################
#################################################################################################
#  Action - TWMDOCMAT = Review Entire Invoice Document
$ACTION

Case ACTION
    When "OUVRE"   : Gosub OUVRE
    When "DEBUT"   : Gosub DEBUT
    When "Default" :
Endcase

Return

$OUVRE
If  !clalev([F:MAT]) : Local File MATCHTOL : Endif
Return

#################################################################################################
#  Display matching
$DEBUT
Local Integer WVCRTYP,NOL,WLIN
If dim(BLKSTA)<>1 : Local Integer BLKSTA : Endif

If dim([M:PIH0]NUM)>0 & [F:PIH]STA=3 : Return : Endif # On re-evaluation on validated invoices

[M:TWS0]NUM = [L]PARAM(1)
WVCRTYP = val([L]PARAM(2))                        # Invoicing
NOL = val([L]PARAM(3))                            # Line number on line inquiry

GOK=1

Gosub TWS_TWMSTA

Case WVCRTYP
    When 6  : WLIN = [M:PTH1]NBLIG-1 : Raz [M:TWS2]    # Receiving
    When 17 : WLIN = [M:PIH3]NBLIG-1 : Raz [M:TWS1]    # Invoicing
    When Default :
Endcase

If find(GACTION,"TWMLINMAT","TWMLINMATA") | (GACTION="SAISTOENTM" & clalev ([M:ENM]))
    Gosub TWMATCH
Else
    For NOL=0 To WLIN
        Gosub TWMATCH
    Next
Endif

# Save Match lines in TWS3 for redisplay
If WVCRTYP=17
  #121259.sn
  #Use Transmask to improve performance
  #For nolign = 1 To [M:TWS1]NBLIG1
    #[M:TWS3]=[M:TWS1]
  #Next
  Transmask [M:TWS1] To [M:TWS3]
  #121259.en
Else
  #121259.sn
  #Use Transmask to improve performance
  #For nolign = 1 To [M:TWS2]NBLIG1
    #[M:TWS3]=[M:TWS2]
  #Next
  Transmask [M:TWS2] To [M:TWS3]
  #121259.en
Endif

Raz nolign
If WVCRTYP=17
 Affzo [M:TWS1]   #NBLIG1
Else
 Affzo [M:TWS2]   #NBLIG1
Endif

Affzo [M:TWS0]
Return

#####################################################################################
$TWMATCH
Local Char TWMEXP(100)(25), ERRMSG(250),TWMMETRIC(10)(25),STYLE(20)
Local Integer I,ERR,POH_FND,PTH_FND,TWMSTA(25),TWMBLK, TWMTSTA(25) ###
Local Decimal TWMVAR(25),TWMALLOW(25),PODQTY(25),PTDQTY(25),PIDQTY(25),PODNETPRI(25),PIDNETPRI(25),PODNOTLIN(25),PIDNOTLIN(25)
Local Date REQRECDAT(25), RECDAT(25)

Raz I,ERR,ERRMSG,[L]TWMEXP,[L]TWMSTA,[L]TWMBLK,POH_FND,PTH_FND,[L]TWMMETRIC,[L]PODQTY,[L]PTDQTY,[L]PIDQTY,[L]PODNETPRI,[L]PIDNETPRI
Raz [L]PODNOTLIN,[L]PIDNOTLIN,[L]REQRECDAT,[L]RECDAT, [L]TWMTSTA

Call TWMLIN(WVCRTYP,NOL,POH_FND,PTH_FND,TWMVAR,TWMMETRIC,TWMALLOW,PODQTY,PTDQTY,PIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,
&        REQRECDAT,RECDAT,TWMTSTA,TWMSTA,TWMEXP,TWMBLK,ERR,ERRMSG) From TWMLIB

If dim([M:PIH0]NUM)>0
 If [M:PIH3]TWMSTAL(NOL)=5 & (!BLKSTA | [M:PIH3]UPDFLG(NOL)=0) # 95938.n # changed field name from TMWSTA(NOL) to TMWSTAL(NOL)
    TWMBLK=5
 Endif # already unblocked
Endif


If TWMBLK<>3 and TWMBLK<>4    # Done if line is not blocked and not set as warning
    Return
Endif

If dim(PIH_CHECK)>0 & PIH_CHECK<>0        # Update status only on every line
    Return
Endif

# Display line grid information
If WVCRTYP = 17
nolign  = [M:TWS1]NBLIG
Else
nolign  = [M:TWS2]NBLIG
Endif

If WVCRTYP = 17 # Invoices
If  nolign+1 < dim([M:TWS1]TWMLINSTA)
    nolign+=1
Else
    ERR=1
    #ERRMSG="No more screen lines available in [M:TWS1]NBLIG" # 89187.o
    ERRMSG=mess(26,584,1) + " [M:TWS1]NBLIG" # 89187.n
    Return
Endif

Else # Receipts
If  nolign+1 < dim([M:TWS2]TWMLINSTA)
    nolign+=1
Else
    ERR=1
    #ERRMSG="No more screen lines available in [M:TWS2]NBLIG" # 89187.o
    ERRMSG=mess(26,584,1) + " [M:TWS2]NBLIG" # 89187.n
    Return
Endif
Endif

Case WVCRTYP
  When 6  : Gosub TWM_PTH
  When 17 : Gosub TWM_PIH
Endcase

If WVCRTYP = 17 # Invoices
If ERR
   [M:TWS1]TWMEXP=ERRMSG
   If  nolign+1 > dim([M:TWS1]TWMLINSTA)
       nolign+=1
   Endif
Endif

Else   # Receipts
If ERR
   [M:TWS2]TWMEXP=ERRMSG
   If  nolign+1 > dim([M:TWS2]TWMLINSTA)
       nolign+=1
   Endif
Endif

Endif

If WVCRTYP = 17 # Invoices
  [M:TWS1]NBLIG1 = nolign
    Affzo [M:TWS1]NBLIG
Else            # Receipts
  [M:TWS2]NBLIG1 = nolign
  Affzo [M:TWS2]NBLIG
Endif

Return

#####################################################################################
$TWM_PTH
[M:TWS2]PIDLIN(nolign-1) = [M:PTH1]PTDLIN(NOL)
[M:TWS2]TWMSTA(nolign-1) = [L]TWMBLK
Call TWMSTYLE(TWMBLK, STYLE)
Chgstl [M:TWS2]ITMREF(nolign-1) With STYLE
[M:TWS2]ITMREF(nolign-1) = [M:PTH1]ITMREF(NOL)
[M:TWS2]BPSNUM(nolign-1) = [M:PTH0]BPSNUM
[M:TWS2]TWMCOD(nolign-1) = [M:PTH1]MATTOL(NOL)

If  POH_FND
        [M:TWS2]POHNUM(nolign-1) = [M:PTH1]POHNUM(NOL)
        [M:TWS2]POPLIN(nolign-1) = [M:PTH1]POPLIN(NOL)
Endif

[M:TWS2]NBLIG = nolign
# Display Match grid information
nolign = [M:TWS2]NBLIG1
For I=0 To dim([L]TWMEXP)-1
    If  [L]TWMEXP(I)<>""
        If  nolign+1 < dim([M:TWS2]TWMLINSTA)
            nolign+=1
        Else
            ERR=1
            #ERRMSG="No more screen lines available in [M:TWS2]NBLIG" # 89187.o
            ERRMSG=mess(26,584,1) + " [M:TWS2]NBLIG" # 89187.n
            Break
        Endif
        [M:TWS2]PIDLINMAT(nolign-1)  = [M:PTH1]PTDLIN(NOL)
        [M:TWS2]TWMLINSTA(nolign-1)  = [L]TWMTSTA(I)
        [M:TWS2]TWMEXP(nolign-1)     = [L]TWMEXP(I)
        [M:TWS2]TWMVAR(nolign-1)     = [L]TWMVAR(I)
        [M:TWS2]TWMMETRIC(nolign-1)  = [L]TWMMETRIC(I)
        [M:TWS2]TWMALLOW(nolign-1)   = [L]TWMALLOW(I)
        [M:TWS2]PODQTY(nolign-1)     = [L]PODQTY(I)
        [M:TWS2]PTDQTY(nolign-1)     = [L]PTDQTY(I)
        [M:TWS2]PIDQTY(nolign-1)     = [L]PIDQTY(I)
        [M:TWS2]PODNETPRI(nolign-1)  = [L]PODNETPRI(I)
        [M:TWS2]PIDNETPRI(nolign-1)  = [L]PIDNETPRI(I)
        [M:TWS2]PODNOTLIN(nolign-1)  = [L]PODNOTLIN(I)
        [M:TWS2]PIDNOTLIN(nolign-1)  = [L]PIDNOTLIN(I)
        [M:TWS2]CUR(nolign-1)        = [F:MAT]TOLCUR
        [M:TWS2]UOM(nolign-1)        = [F:MAT]TOLUOM
        [M:TWS2]EXPRCP(nolign-1)     = [L]REQRECDAT(I)
        [M:TWS2]RCPDAT(nolign-1)     = [L]RECDAT(I)
    Else
        Break
    Endif
Next

Return

######################################################################################
$TWM_PIH
[M:TWS1]PIDLIN(nolign-1) = [M:PIH3]PIDLIN(NOL)
[M:TWS1]TWMSTA(nolign-1) = [L]TWMBLK
Call TWMSTYLE(TWMBLK, STYLE)
Chgstl [M:TWS1]ITMREF(nolign-1) With STYLE
[M:TWS1]ITMREF(nolign-1) = [M:PIH3]ITMREF(NOL)
[M:TWS1]BPSNUM(nolign-1) = [M:PIH3]BPSNUM(NOL)
[M:TWS1]TWMCOD(nolign-1) = [M:PIH3]MATTOL(NOL)

If  PTH_FND
    [M:TWS1]PTHNUM(nolign-1) = [M:PIH3]NUMORI(NOL)
    [M:TWS1]PTDLIN(nolign-1) = [M:PIH3]LINORI(NOL)
Endif
If  POH_FND
    If  PTH_FND
        [M:TWS1]POHNUM(nolign-1) = [F:POH]POHNUM
        [M:TWS1]POPLIN(nolign-1) = [F:POQ]POPLIN
        [M:TWS1]POQSEQ(nolign-1) = [F:POQ]POQSEQ
    Else
        [M:TWS1]POHNUM(nolign-1) = [M:PIH3]NUMORI(NOL)
        [M:TWS1]POPLIN(nolign-1) = [M:PIH3]LINORI(NOL)
    Endif
Endif

[M:TWS1]NBLIG = nolign

# Display Match grid information
nolign = [M:TWS1]NBLIG1
For I=0 To dim([L]TWMEXP)-1
    If  [L]TWMEXP(I)<>""
        If  nolign+1 < dim([M:TWS1]TWMLINSTA)
            nolign+=1
        Else
            ERR=1
            # ERRMSG="No more screen lines available in [M:TWS1]NBLIG" # 89187.o
            ERRMSG=mess(26,584,1) + " [M:TWS1]NBLIG" # 89187.n
            Break
        Endif
        [M:TWS1]PIDLINMAT(nolign-1)  = [M:PIH3]PIDLIN(NOL)
        [M:TWS1]TWMLINSTA(nolign-1)  = [L]TWMTSTA(I)
        [M:TWS1]TWMEXP(nolign-1)     = [L]TWMEXP(I)
        [M:TWS1]TWMVAR(nolign-1)     = [L]TWMVAR(I)
        [M:TWS1]TWMMETRIC(nolign-1)  = [L]TWMMETRIC(I)
        [M:TWS1]TWMALLOW(nolign-1)   = [L]TWMALLOW(I)
        [M:TWS1]PODQTY(nolign-1)     = [L]PODQTY(I)
        [M:TWS1]PTDQTY(nolign-1)     = [L]PTDQTY(I)
        [M:TWS1]PIDQTY(nolign-1)     = [L]PIDQTY(I)
        [M:TWS1]PODNETPRI(nolign-1)  = [L]PODNETPRI(I)
        [M:TWS1]PIDNETPRI(nolign-1)  = [L]PIDNETPRI(I)
        [M:TWS1]PODNOTLIN(nolign-1)  = [L]PODNOTLIN(I)
        [M:TWS1]PIDNOTLIN(nolign-1)  = [L]PIDNOTLIN(I)
        [M:TWS1]CUR(nolign-1)        = [F:MAT]TOLCUR
        [M:TWS1]UOM(nolign-1)        = [F:MAT]TOLUOM
    Else
        Break
    Endif
Next

Affzo [M:TWS0]TWMSTA

Return

#################################################################################################
#    get purchase order given receipt number
$GET_POH

# 83001.so
#Link [F:PTD] With [F:PTH]PTH0=[F:PTD]PTHNUM, [F:POH]POH0=[F:PTD]POHNUM, [F:POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ,
#&    [F:POP]POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ As [LNK]
#&    Where [F:PTD]PTHNUM=[M:PIH3]NUMORI(NOL) & [F:PTD]PTDLIN=[M:PIH3]LINORI(NOL)
#Read [LNK] First
#If  !fstat
#    POH_FND=1
#Endif
#Filter [LNK]
# 83001.eo

# 83001.sn - Performance
If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
  Read [F:PTD]PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
  If fstat : Raz [F:PTD] : Return : Endif
Endif
If [F:POQ]POHNUM<>[F:PTD]POHNUM | [F:POQ]POPLIN<>[F:PTD]POPLIN |[F:POQ]POQSEQ<>[F:PTD]POQSEQ
  Read [F:POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
  If fstat : Raz [F:POQ] : Return : Endif
Endif
If [F:POP]POHNUM<>[F:PTD]POHNUM | [F:POP]POPLIN<>[F:PTD]POPLIN |[F:POP]POPSEQ<>[F:PTD]POQSEQ
  Read [F:POP]POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
  If fstat : Raz [F:POP] : Return : Endif
Endif
If [F:POH]POHNUM<>[F:PTD]POHNUM
  Read [F:POH]POH0=[F:PTD]POHNUM
  If fstat : Raz [F:POH] : Return : Endif
Endif
POH_FND=1
# 83001.en - Performance

Return

##################################################################################################
$GET_POHLIN
# get correct purchase order line for match comparison
# 83001.so
#Read [F:POQ]POQ0=[M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
#If fstat
#  POH_FND=1
#Endif
# 83001.eo
# 83001.sn
#If [F:POQ]POHNUM<>[F:PTD]POHNUM | [F:POQ]POPLIN<>[F:PTD]POPLIN |[F:POQ]POQSEQ<>[F:PTD]POQSEQ #119455.o CATUA
If [F:POQ]POHNUM<>[M:PTH1]POHNUM(NOL) | [F:POQ]POPLIN<>[M:PTH1]POPLIN(NOL) | [F:POQ]POQSEQ<>[M:PTH1]POQSEQ(NOL) #119455.n CATUA
  Read [F:POQ]POQ0=[M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
  If fstat : Raz [F:POQ] : Return : Endif
Endif
POH_FND=1
# 83001.en
Return
#################################################################################################
$TOTAL_PTD
# To reduce open receipt amount from prior invoices
# 83001.so
#Read [F:PTD]PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
#If !fstat
#   RRCTQTY=[F:PTD]QTYSTU
#Else
#   RRCTQTY=0
#Endif
# 83001.eo
# 83001.sn
If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
  Read [F:PTD]PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
  If fstat : Raz [F:PTD] : Endif
Endif
RRCTQTY=[F:PTD]QTYSTU
# 83001.en

If !clalev([PID2]) : Local File PINVOICED     [PID2] : Endif
For [PID2] Where [PID2]NUMORI=[M:PIH3]NUMORI(NOL) & [PID2]NUM<>[M:PIH0]NUM & [PID2]LINORI=[M:PIH3]LINORI(NOL) & [PID2]TYPORI=2
  RRCTQTY-=[PID2]QTYSTU
Next

If [M:PIH3]TYPORI(NOL)=2  # 83001.n
  If !clalev([PND]) : Local File PRETURND     [PND] : Endif
#  For [PND] Where [PND]PTHNUM=[M:PIH3]NUMORI(NOL) & [PND]PTDLIN=[M:PIH3]LINORI(NOL) & [M:PIH3]TYPORI=2  # 83001.o
  For [PND]PND1 Where [PND]PTHNUM=[M:PIH3]NUMORI(NOL) & [PND]PTDLIN=[M:PIH3]LINORI(NOL)  # 83001.n
    RRCTQTY-=[PND]QTYSTU
  Next
Endif

Return
################################################################################################
$GET_POH_INV
# get correct purchase order line for match comparison
# 83001.so
#Read [F:POQ]POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
#Read [F:POP]POP0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
#Read [F:POH]POH0=[M:PIH3]NUMORI(NOL)
#If !fstat
#    POH_FND=1
#Endif
# 83001.eo
Read [F:POH]POH0=[M:PIH3]NUMORI(NOL) # 89187.n   POH not fully loaded
# 83001.sn
If [F:POQ]POHNUM<>[M:PIH3]NUMORI(NOL) | [F:POQ]POPLIN<>[M:PIH3]LINORI(NOL) |[F:POQ]POQSEQ<>[M:PIH3]SEQORI(NOL)
  Read [F:POQ]POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
  If fstat : Raz [F:POQ] : Return : Endif
Endif
If [F:POP]POHNUM<>[M:PIH3]NUMORI(NOL) | [F:POP]POPLIN<>[M:PIH3]LINORI(NOL) |[F:POP]POPSEQ<>[M:PIH3]SEQORI(NOL)
  Read [F:POP]POP0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
  If fstat : Raz [F:POP] : Return : Endif
Endif
#If [F:POH]POHNUM<>[M:PIH3]NUMORI(NOL)     # 89187.so
#  Read [F:POH]POH0=[M:PIH3]NUMORI(NOL)
#  If fstat : Raz [F:POH] : Return : Endif
#Endif                                     # 89187.eo
POH_FND=1
# 83001.en

Return
#################################################################################################
Subprog TWMLIN(WVCRTYP,NOL,POH_FND,PTH_FND,TWMVAR,TWMMETRIC,TWMALLOW,TWMPODQTY,TWMPTDQTY,TWMPIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,
&        REQRECDAT,RECDAT,TWMTSTA,TWMLINSTA,TWMEXP,TWMBLK,ERR,ERRMSG)
Value Integer WVCRTYP,NOL
Variable Integer POH_FND,PTH_FND
Variable Integer TWMLINSTA(),TWMBLK,TWMTSTA(),ERR
Variable Char ERRMSG(),TWMEXP()(),TWMMETRIC()()
Variable Decimal TWMVAR(),TWMALLOW(),TWMPODQTY(),TWMPTDQTY(),TWMPIDQTY(),PODNETPRI(),PIDNETPRI(),PODNOTLIN(),PIDNOTLIN()
Variable Date REQRECDAT(),RECDAT()
Local Integer TWMSTA,TYPORI
Local Decimal XRCTQTY, XINVQTY,RRCTQTY,XRETQTY,XPOQTY
Local Decimal XQTYUOM,XQTYSTU,XCOE,ECOE
Local Char XUOM,XSTU

TYPORI = 1
If WVCRTYP=17 : TYPORI = [M:PIH3]TYPORI(NOL) : Endif

Case TYPORI
  When 1 : If WVCRTYP=6
             PTH_FND=1
             Else PTH_FND=0  # Invoicing PO directly
           Endif
           If WVCRTYP=6
             Gosub GET_POHLIN
             Else Gosub GET_POH_INV # for mixed order / receipt Invoices
           Endif
  When 2 : PTH_FND = 1
           Raz [F:POH],[F:POQ],[F:POP]
           Gosub GET_POH
  When Default : End
Endcase

Case WVCRTYP
  When 6     # Receipt
    Raz XRETQTY,XRCTQTY,XPOQTY
# 83001.so
#    Read [F:PTD]PTD0=[M:PTH0]PTHNUM;[M:PTH1]PTDLIN(NOL)
#    If !fstat & [F:POQ]RCPQTYSTU<>0
#      XRCTQTY = [F:POQ]RCPQTYSTU - [F:PTD]QTYSTU    # To achieve true open PO quantity
#    Else
#      XRCTQTY = [F:POQ]RCPQTYSTU
#    Endif
# 83001.eo
# 83001.sn
#    If [F:PTD]PTHNUM<>[M:PTH0]PTHNUM | [F:PTD]PTDLIN<>[M:PTH1]PTDLIN(NOL)              # 86915.o
    If !GIMPORT & ([F:PTD]PTHNUM<>[M:PTH0]PTHNUM | [F:PTD]PTDLIN<>[M:PTH1]PTDLIN(NOL))  # 86915.n
      Read [F:PTD]PTD0=[M:PTH0]PTHNUM;[M:PTH1]PTDLIN(NOL)
      If fstat : Raz [F:PTD] : Endif
    Endif
    XRCTQTY = [F:POQ]RCPQTYSTU - [F:PTD]QTYSTU
# 83001.en

    If POH_FND   # Reduce open PO qty by returns applied to PO
# 83001.so
#      Read [F:PND]PND3=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
#      If !fstat & [F:PND]ORDFLG=2 & [F:PND]PTHNUM=[M:PTH0]PTHNUM
#        Read [F:PNH]PNH0=[PND]PNHNUM
#        If !fstat & [F:PNH]CFMFLG=2
#          XRETQTY=[F:PND]QTYSTU
#        Endif
#      Endif
# 83001.eo
# 83001.sn
      If [F:PND]POHNUM<>[F:POQ]POHNUM | [F:PND]POPLIN<>[F:POQ]POPLIN | [F:PND]POQSEQ<>[F:POQ]POQSEQ
        Read [F:PND]PND3=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
        If fstat : Raz [F:PND] : Endif
      Endif
      If [F:PND]ORDFLG=2 & [F:PND]PTHNUM=[M:PTH0]PTHNUM
        Read [F:PNH]PNH0=[F:PND]PNHNUM
        If !fstat & [F:PNH]CFMFLG=2
          XRETQTY=[F:PND]QTYSTU
        Endif
      Endif
# 83001.en

      If XRETQTY = [M:PTH1]QTYSTU(NOL) : Raz XRETQTY : Endif
      If [F:POQ]LINCLEFLG=2 & [F:POQ]RCPQTYSTU = [F:POQ]QTYSTU & abs(XRCTQTY) <> XRETQTY
        Raz XRETQTY
      Endif #If PO = CLOSED DUE To SECOND RECEIPT. No over receivers.
    Endif

    XPOQTY=[F:POQ]QTYSTU-XRCTQTY-XRETQTY

    If GACTION = "SAISTOENTM" & clalev([M:ENM]) # Receipt modif
      For J=0 To [M:ENM]NBLIG
        If [M:ENM]PCUSTUCOE(J)<>0 : ECOE=[M:ENM]PCUSTUCOE(J): Else ECOE=1 : Endif
        XQTYUOM += [M:ENM]QTYSTU(J) / ECOE #Invalid when multiple UOM on [M:ENM]. No impact however.
        XUOM    = [M:ENM]PCU(J)
        XQTYSTU += [M:ENM]QTYSTU(J)
        XSTU    = [M:ENM]STU
        XCOE    += [M:ENM]PCUSTUCOE(J)
      Next
    Else
      XQTYUOM = [M:PTH1]QTYUOM(NOL)
      XUOM    = [M:PTH1]UOM(NOL)
      XQTYSTU = [M:PTH1]QTYSTU(NOL)
      XSTU    = [M:PTH1]STU(NOL)
      XCOE    = [M:PTH1]UOMPUUCOE(NOL)
    Endif

    GPOINT="CALCTWM" : Gosub ENTREE From EXEFNC #101454.n

    Call TWMLINTOL(WVCRTYP,TYPORI,[M:PTH1]MATTOL(NOL),NOL,WVCRTYP,[M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,POH_FND,[F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU-XRCTQTY-XRETQTY,
&        [F:POQ]STU,[F:POQ]UOMPUUCOE,[F:POP]NETPRI,[F:POH]CUR,[F:POQ]ORDDAT,
&        PTH_FND,XQTYUOM,XUOM,XQTYSTU,XSTU,XCOE,[M:PTH1]NETPRI(NOL),
&        [M:PTH1]NETCUR(NOL),[M:PTH0]RCPDAT,1,0,[M:PTH1]UOM(NOL),0,[M:PTH1]STU(NOL),[M:PTH1]UOMPUUCOE(NOL),0,
&        [M:PTH1]NETCUR,
&        [M:PTH0]RCPDAT,TWMVAR,TWMMETRIC,TWMALLOW,TWMPODQTY,TWMPTDQTY,TWMPIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,TWMSTA,
&        REQRECDAT,RECDAT,TWMTSTA,TWMLINSTA,TWMEXP,ERR,ERRMSG) From TWMLIB

  When 17  # Invoice
    Raz XINVQTY,RRCTQTY
# 83001.so
#    Read [F:PID]PID0=[M:PIH0]NUM;[M:PIH3]PIDLIN(NOL)
#    If !fstat & [F:POQ]INVQTYSTU<>0
#      XINVQTY=[F:POQ]QTYSTU - [F:POQ]INVQTYSTU + [F:PID]QTYSTU # To achieve true open PO quantity
#    Else
#      XINVQTY=[F:POQ]QTYSTU - [F:POQ]INVQTYSTU
#        If !clalev([PND]) : Local File PRETURND     [PND] : Endif
#        For [PND] Where [PND]PTHNUM=[M:PIH3]NUMORI(NOL) & [PND]PTDLIN=[M:PIH3]LINORI(NOL) & [M:PIH3]TYPORI=2
#          XINVQTY-=[PND]QTYSTU
#        Next
#    Endif
# 83001.eo
# 83001.sn
#    If [F:PID]NUM<>[M:PIH0]NUM | [F:PID]PIDLIN<>[M:PIH3]PIDLIN(NOL)              # 86915.o
    If !GIMPORT & ([F:PID]NUM<>[M:PIH0]NUM | [F:PID]PIDLIN<>[M:PIH3]PIDLIN(NOL))  # 86915.n
      Read [F:PID]PID0=[M:PIH0]NUM;[M:PIH3]PIDLIN(NOL)
      If fstat : Raz [F:PID] : Endif
    Endif
     #XINVQTY=[F:POQ]QTYSTU - [F:POQ]INVQTYSTU + [F:PID]QTYSTU # 89187.o # To achieve true open PO quantity
# 83001.en
    If [F:POQ]INVQTYSTU<>0  # 89187.sn
      XINVQTY=[F:POQ]QTYSTU - [F:POQ]INVQTYSTU + [F:PID]QTYSTU # To achieve true open PO quantity
    Else
      XINVQTY=[F:POQ]QTYSTU - [F:POQ]INVQTYSTU
    Endif                   # 89187.en

    Gosub TOTAL_PTD

    If [M:PIH3]TYPORI(NOL)=2  # To set open PO qty to receipt qty for multiple receipts per one PO
      XINVQTY=RRCTQTY
    Endif

    If [F:POQ]UOMPUUCOE <> 0 : XCOE=[F:POQ]UOMPUUCOE : Else XCOE=1 : Endif

    Call TWMLINTOL(WVCRTYP,TYPORI,[M:PIH3]MATTOL(NOL),NOL,WVCRTYP,[M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),POH_FND,[F:POQ]QTYPUU,[F:POQ]PUU,XINVQTY,
&        [F:POQ]STU,[F:POQ]UOMPUUCOE,([F:POP]NETPRI/XCOE),[F:POH]CUR,[F:POQ]ORDDAT,
&        PTH_FND,[F:PTD]QTYUOM,[F:PTD]UOM,RRCTQTY,[F:PTD]STU,[F:PTD]UOMPUUCOE,[F:PTD]NETPRI,[F:PTD]NETCUR,
&        [F:PTD]RCPDAT,
&        1,[M:PIH3]QTYUOM(NOL),[M:PIH3]UOM(NOL),[M:PIH3]QTYSTU(NOL),[M:PIH3]STU(NOL),[M:PIH3]UOMPUUCOE(NOL),[M:PIH3]NETPRI(NOL)/[M:PIH3]UOMPUUCOE(NOL),
&        [M:PIH3]WCUR,
&        [M:PIH3]RCPDAT(NOL),TWMVAR,TWMMETRIC,TWMALLOW,TWMPODQTY,TWMPTDQTY,TWMPIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,TWMSTA,
&        REQRECDAT,RECDAT,TWMTSTA,TWMLINSTA,TWMEXP,ERR,ERRMSG) From TWMLIB
Endcase

If TWMSTA=4  # Block
    TWMBLK = 4
Elsif TWMSTA>0  & TWMBLK<>4 # Sync up
   TWMBLK = TWMSTA
Else
   TWMBLK = 1
Endif

End

#################################################################################################
#  TWNLINTOL = Determine Blocking Status on Line Matching
Subprog TWMLINTOL(WVCRTYP,TYPORI,TWMCOD,NOL,TWMVCRTYP,ITMREF,BPSNUM,PORFLG,PORQTY,PORUOM,PORQTYSTU,PORSTU,PORCOE,PORNETPRI,PORCUR,PORDAT,
&                 PTRFLG,PTRQTY,PTRUOM,PTRQTYSTU,PTRSTU,PTRCOE,PTRPRI,PTRCUR,PTRDAT,
&                 PIHFLG,PIDQTY,PIHUOM,PIDQTYSTU,PIHSTU,PIHCOE,INVNETPRI,PIHCUR,PIHDAT,
&                 TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,TWMPIDQTY,PODNETPRI,PIDNETPRI,PODNOTLIN,PIDNOTLIN,TWMSTA,
&                 REQRECDAT,RECDAT,TWMTSTA,TWMLINSTA,TWMEXP,ERR,ERRMSG)

Value Integer PORFLG,PTRFLG,PIHFLG,TWMVCRTYP,WVCRTYP,TYPORI,NOL
Value Decimal PORQTY,PORQTYSTU,PORCOE,PORNETPRI,PTRQTY,PTRQTYSTU,PTRCOE,PTRPRI,PIDQTY,PIDQTYSTU,PIHCOE,INVNETPRI
Value Char TWMCOD,PORUOM,PORSTU,PORCUR,PTRUOM,PTRSTU,PTRCUR,PIHUOM,PIHSTU,PIHCUR,ITMREF,BPSNUM
Value Date PORDAT,PTRDAT,PIHDAT
Variable Integer TWMLINSTA(),TWMTSTA(),ERR,TWMSTA
Variable Char ERRMSG(),TWMEXP()(),TWMMETRIC()()
Variable Decimal TWMVAR(),TWMTOL(),TWMPODQTY(),TWMPTDQTY(),TWMPIDQTY(),PODNETPRI(),PIDNETPRI(),PODNOTLIN(),PIDNOTLIN()
Variable Date REQRECDAT(),RECDAT()

#CATUA X3-59561.sn Save NOL variable before it gets set to zero
Local Integer SAVNOL
SAVNOL = NOL
#CATUA X3-59561.en

Local Integer NOL,TWMSTA
# TWMVCRTYP = menu 701 - Receipt(6) and Supplier(17) Invoice value
# PORFLG when 0 PO data not passed,otherwise PO data passed
# PTRFLG when 0 Receipt data not passed,otherwise Receipt data passed
# PIHFLG when 0 Invoice data not passed,otherwise Invoice data passed
# All quantities are in purchase UOM -> Extended purchase price = Quantity * Price
Raz TWMLINSTA,TWMEXP,ERR,ERRMSG
NOL = 0

# Blank TWMCOD means no tolerance check
If  vireblc([L]TWMCOD,2) = ""
  TWMLINSTA = 1 # Not matched  LM 585
  End
Endif

TWMLINSTA =  2  # Successful default if TWMCOD found

# Retrieve TWMCOD to determine highest level of blocking
If [L]TWMCOD <> [F:MAT]MATTOL
  Read [F:MAT]MAT0 = [L]TWMCOD
  If fstat
    TWMLINSTA = 1 # Not matched  LM 585
    ERR = fstat
    #ERRMSG = "Unable to retrieve Three Way Match code ["+[L]TWMCOD+"]" # 89187.o
    ERRMSG=mess(27,584,1) + "[" +[L]TWMCOD+ "]" # 89187.n
    End
  Endif
Endif

Case TWMVCRTYP
  When 6    : Gosub TWM_PTRTOL                     # Receipt Tolerance
  When 17   : Gosub TWM_PIHTOL                     # Supplier Invoice Tolerance
  When Default :
Endcase

End

###########################################################################################
#  TWM_PTRTOL = Three Way Matching - Receipt Line Control
$TWM_PTRTOL
TWMSTA = func TWMSTA_CHK(TWMSTA,0)        # Successful default
TWMTSTA = func TWMSTA_CHK(TWMTSTA,0)      # Successful default
Gosub PTRQTY_CTL                          # Quantity Over/Under Control
If !ERR : Gosub PTRDAYS_CTL   : Endif     # Days Late/Early Control - Stop if blocking status or error occurred
Return

###########################################################################################
#  $TWM_PIHTOL = Three Way Matching - Purchase Invoice Line Control
$TWM_PIHTOL
TWMSTA = func TWMSTA_CHK(TWMSTA,0)      # Successful default
TWMTSTA = func TWMSTA_CHK(TWMTSTA,0)    # Successful default
Gosub PIDQTY_CTL                        # Quantity Over/Under Control
If !ERR : Gosub PIDNETPRI_CTL : Endif   # Invoice Unit Price Control
Return

###########################################################################################
#  $PTRQTY_CTL = Receipt to PO quantity Check
$PTRQTY_CTL
Local Decimal PCTDIF,QTYDIF,QTYUOM1,QTYUOM2,TWMTOLA,XMESS,COEUOM,XCOEUOM,NEWQTY,XQSQTY,XQEQTY
Local Char XUOM
Local Integer XERR

If PORFLG & PTRFLG                                   # Both PO and Receipt data available
  If [F:MAT]QSCTLP=2                                 # Quantity Shortage Control - Percentage
    #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short    # 107025.o
     Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]QSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If [F:MAT]QSCTLP=2 & (QTYUOM2 < QTYUOM1)          # Quantity received less than open PO quantity
      Call PERCENT_CLCUND(QTYUOM2,QTYUOM1,PCTDIF)     # Calc percent short
      If (abs(PCTDIF) > [F:MAT]QSPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]QSACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]QSACT)
        XMESS = 8

        If PTRUOM<>[F:MAT]TOLUOM                      # Convert to receipt UOM
          #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty   # 107025.o
          Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
          If ERR : XERR=[F:MAT]QSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCUND(PTRQTY,QTYUOM1,PCTDIF)  # Calc percent short
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(PCTDIF),"%",[F:MAT]QSPER,QTYUOM1,PTRQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(PCTDIF),"%",[F:MAT]QSPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If [F:MAT]QSCTLQ=2                                  # Quantity Shortage Control - Quantity
    #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]QSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If !ERR & [F:MAT]QSCTLQ=2 & QTYDIF <> 0 & (QTYDIF > [F:MAT]QSQTY)
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]QSACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]QSACT)
      XMESS = 8

      If PTRUOM<>[F:MAT]TOLUOM                      # Convert to receipt UOM
        #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
        Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
        If ERR : XERR=[F:MAT]QSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]QSQTY,[F:MAT]TOLUOM,XQSQTY,PORSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XQSQTY,PORSTU,XQSQTY,PTRUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(QTYUOM1-PTRQTY),PTRUOM,XQSQTY,QTYUOM1,PTRQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(QTYUOM2-QTYUOM1),[F:MAT]TOLUOM,[F:MAT]QSQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

  If [F:MAT]QECTLP=2                                  # Quantity Exceeded Control - Percentage
    #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]QEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If [F:MAT]QECTLP=2 & (QTYUOM1 < QTYUOM2)          # Quantity Exceeded Control = Quantity received exceeds open PO quantity
      Call PERCENT_CLCOVR(QTYUOM1,QTYUOM2,PCTDIF)     # Percent Exceeded
      If (abs(PCTDIF) > [F:MAT]QEPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]QEACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]QEACT)
        XMESS=3

        If PTRUOM<>[F:MAT]TOLUOM                      # Convert to receipt UOM
          #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
          Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
          If ERR : XERR=[F:MAT]QEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCOVR(QTYUOM1,PTRQTY,PCTDIF)  # Calc percent over
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(PCTDIF),"%",[F:MAT]QEPER,QTYUOM1,PTRQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,PCTDIF,"%",[F:MAT]QEPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If !ERR & [F:MAT]QECTLQ=2                           # Quantity Exceeded Control - Quantity
    #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]QEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If !ERR & [F:MAT]QECTLQ=2 & QTYDIF < 0 & (abs(QTYDIF) > [F:MAT]QEQTY)
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]QEACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]QEACT)
      XMESS=3

      If PTRUOM<>[F:MAT]TOLUOM                        # Convert to receipt UOM
        #Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
        Call QTY_DIF(PORQTYSTU,PORSTU,PTRQTY,PTRUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
        If ERR : XERR=[F:MAT]QEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]QEQTY,[F:MAT]TOLUOM,XQEQTY,PORSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XQEQTY,PORSTU,XQEQTY,PTRUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(QTYUOM1-PTRQTY),PTRUOM,XQEQTY,QTYUOM1,PTRQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPTDQTY,abs(QTYUOM2-QTYUOM1),[F:MAT]TOLUOM,[F:MAT]QEQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif
Endif

Return
###########################################################################################
#  $PTRDAYS_CTL = Receipt date to PO requested receipt date Check
$PTRDAYS_CTL
Local Date EXPRECDAT,ACTRECDAT
Local Decimal XMESS

If PORFLG & PTRFLG                                    # Both PO and Receipt data available
  EXPRECDAT = [F:POQ]EXTRCPDAT                        # Expected receipt date
  ACTRECDAT =  [M:PTH0]RCPDAT                         # Actual Receipt date

  If [F:MAT]ERCTL=2 & (EXPRECDAT - ACTRECDAT > [F:MAT]ERDAYS) # Receipt Early = Receipt date before PO requested Receipt date
    TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]ERACT)
    TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]ERACT)
    XMESS=18
    Call ADD_MSGDAYS(TWMVAR,TWMMETRIC,TWMTOL,REQRECDAT,RECDAT,EXPRECDAT-ACTRECDAT,"Days",[F:MAT]ERDAYS,EXPRECDAT,ACTRECDAT,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
  Elsif [F:MAT]LRCTL=2 & (ACTRECDAT - EXPRECDAT > [F:MAT]LRDAYS) # Receipt Late =  Receipt date after PO requested Receipt date
    TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]LRACT)
    TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]LRACT)
    XMESS=17
    Call ADD_MSGDAYS(TWMVAR,TWMMETRIC,TWMTOL,REQRECDAT,RECDAT,ACTRECDAT-EXPRECDAT,"Days",[F:MAT]LRDAYS,EXPRECDAT,ACTRECDAT,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
  Endif
Endif

Return

###########################################################################################
#  $PIDQTY_CTL = Receipt Quantity to Invoice Quantity Control
$PIDQTY_CTL
Local Decimal PCTDIF,QTYDIF,QTYUOM1, QTYUOM2,XCOEUOM,  NEWQTY,XIQSQTY,XIQEQTY
Local Char XUOM
Local Integer XERR

If PTRFLG & PIHFLG & TYPORI=2                         # Both Receipt and Invoice data available
  Gosub PIDQTY_CREDITS #109135.n
  If [F:MAT]IQSCTLP=2                                 # Quantity Shortage Control - Percentage
    #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short # 107025.o
    Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If [F:MAT]IQSCTLP=2 & (QTYUOM2 < QTYUOM1)         # Quantity Shortage % Control = Invoice Quantity less than receipt quantity
      Call PERCENT_CLCUND(QTYUOM2,QTYUOM1,PCTDIF)     # Calc percent short
      If (abs(PCTDIF) > [F:MAT]IQSPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQSACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQSACT)
        XMESS = 6

        If PIHUOM<>[F:MAT]TOLUOM                      # Convert to invoice UOM
          #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Inv qty # 107025.o
          Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Inv qty  # 107025.n
          If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCUND(PIDQTY,QTYUOM1,PCTDIF)  # Calc percent short
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,abs(PCTDIF),"%",[F:MAT]IQSPER,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,PCTDIF*-1,"%",[F:MAT]IQSPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If [F:MAT]IQSCTLQ=2                                   # Quantity Shortage Control - Quantity
    #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short # 107025.o
    Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If !ERR & [F:MAT]IQSCTLQ=2 & QTYDIF<>0 & (QTYDIF > [F:MAT]IQSQTY)# Quantity Shortage Amt Control = Quantity invoiced quantity less than receipt quantity
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQSACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQSACT)
      XMESS = 6

      If PIHUOM<>[F:MAT]TOLUOM                        # Convert to invoice UOM
       # Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Inv qty # 107025.o
        Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Inv qty # 107025.n
        If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]IQSQTY,[F:MAT]TOLUOM,XIQSQTY,PTRSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XIQSQTY,PTRSTU,XIQSQTY,PIHUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,abs(QTYUOM1-PIDQTY),PIHUOM,XIQSQTY,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,QTYDIF,[F:MAT]TOLUOM,[F:MAT]IQSQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

  If [F:MAT]IQECTLP=2                                 # Quantity Exceeded Control - Percentage
    #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short # 107025.o
    Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If [F:MAT]IQECTLP=2 & (QTYUOM2 > QTYUOM1)         # Quantity Exceeded % Control = Quantity invoiced exceeds receipt quantity
      Call PERCENT_CLCOVR(QTYUOM1,QTYUOM2,PCTDIF)     # Calc percent exceeded
      If (abs(PCTDIF) > [F:MAT]IQEPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQEACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQEACT)
        XMESS = 7

        If PIHUOM<>[F:MAT]TOLUOM                      # Convert to invoice UOM
          #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
          Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
          If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCOVR(QTYUOM1,PIDQTY,PCTDIF) # Calc percent over
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,abs(PCTDIF),"%",[F:MAT]IQEPER,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,PCTDIF,"%",[F:MAT]IQEPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If [F:MAT]IQECTLQ=2                                 # Quantity Exceeded Control - Quantity
    #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Quantity Short # 107025.o
    Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # Quantity Short # 107025.n
    If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
    If !ERR & [F:MAT]IQECTLQ=2 & QTYDIF < 0 & (abs(QTYDIF) > [F:MAT]IQEQTY)  # Quantity Exceeded Qty Control = Quantity invoiced exceeds receipt quantity
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQEACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQEACT)
      XMESS = 7

      If PIHUOM<>[F:MAT]TOLUOM                        # Convert to invoice UOM
        #Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
        Call QTY_DIF(PTRQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
        If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]IQEQTY,[F:MAT]TOLUOM,XIQEQTY,PTRSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XIQEQTY,PTRSTU,XIQEQTY,PIHUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,abs(QTYUOM1-PIDQTY),PIHUOM,XIQEQTY,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPTDQTY,TWMPIDQTY,QTYDIF*-1,[F:MAT]TOLUOM,[F:MAT]IQEQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif    ###
    Endif
  Endif
Endif

If PORFLG & PIHFLG & TYPORI=1                         # Both PO and Invoice data available
  If [F:MAT]IQSCTLP=2                                 # Quantity Shortage Control - Percentage
    #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]IQSACT :Gosub ERR_UOM : Return : Endif          # No UOM conversion
    If [F:MAT]IQSCTLP=2 & (QTYUOM2 < QTYUOM1)       # Quantity Shortage % Control = Quantity invoiced less than PO quantity
      Call PERCENT_CLCUND(QTYUOM2,QTYUOM1,PCTDIF)   # Calc percent short
      If (abs(PCTDIF) > [F:MAT]IQSPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQSACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQSACT)
        XMESS = 5

        If PIHUOM<>[F:MAT]TOLUOM                      # Convert to invoice UOM
          #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Inv qty # 107025.o
          Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Inv qty # 107025.n
          If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCUND(PIDQTY,QTYUOM1,PCTDIF)  # Calc percent short
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,abs(PCTDIF),"%",[F:MAT]IQSPER,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,PCTDIF*-1,"%",[F:MAT]IQSPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If [F:MAT]IQSCTLQ=2                                 # Quantity Shortage Control - Quantity
    #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]IQSACT :Gosub ERR_UOM : Return : Endif          # No UOM conversion
    If !ERR & [F:MAT]IQSCTLQ=2 & QTYDIF <> 0 & (QTYDIF > [F:MAT]IQSQTY)  # Quantity Shortage Qty Control = Quantity invoiced less than PO quantity
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQSACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQSACT)
      XMESS = 5

      If PIHUOM<>[F:MAT]TOLUOM                        # Convert to invoice UOM
        #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Inv qty # 107025.o
        Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Inv qty # 107025.n
        If ERR : XERR=[F:MAT]IQSACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
        Call PCAL_QTY([F:MAT]IQSQTY,[F:MAT]TOLUOM,XIQSQTY,PORSTU,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call PCAL_QTY(XIQSQTY,PORSTU,XIQSQTY,PIHUOM,[L]ITMREF,[L]BPSNUM,1,XCOEUOM) From TRTACHQTE1 # Match tolerance conversion
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,abs(QTYUOM1-PIDQTY),PIHUOM,XIQSQTY,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Raz XUOM,XCOEUOM
      Else
        Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,QTYDIF,[F:MAT]TOLUOM,[F:MAT]IQSQTY,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
      Endif
    Endif
  Endif

  If [F:MAT]IQECTLP=2                                 # Quantity Exceeded Control - Percentage
    #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]IQEACT :Gosub ERR_UOM : Return : Endif          # No UOM conversion
    If [F:MAT]IQECTLP=2 & (QTYUOM2 > QTYUOM1)         # Quantity Exceeded % Control = Quantity invoiced exceeds PO quantity
      Call PERCENT_CLCOVR(QTYUOM1,QTYUOM2,PCTDIF)     # Calc percent exceeded
      If (PCTDIF > [F:MAT]IQEPER)
        TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQEACT)
        TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQEACT)
        XMESS = 4

        If PIHUOM<>[F:MAT]TOLUOM                      # Convert to invoice UOM
          #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # Convert to Rct qty # 107025.o
          Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTY,PIHUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,1,ERR,ERRMSG) # Convert to Rct qty # 107025.n
          If ERR : XERR=[F:MAT]IQEACT : Gosub ERR_UOM : Return : Endif # No UOM conversion
          Call PERCENT_CLCOVR(QTYUOM1,PIDQTY,PCTDIF) # Calc percent over
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,abs(PCTDIF),"%",[F:MAT]IQEPER,QTYUOM1,PIDQTY,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Else
          Call ADD_MSG(TWMVAR,TWMMETRIC,TWMTOL,TWMPODQTY,TWMPIDQTY,PCTDIF,"%",[F:MAT]IQEPER,QTYUOM1,QTYUOM2,NOL,TWMEXP,TWMSTA,TWMLINSTA,XMESS)
        Endif  ###
      Endif
    Endif
  Endif

  If [F:MAT]IQECTLQ=2                                 # Quantity Exceeded Control - Quantity
    #Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,ERR,ERRMSG) # 107025.o
    Call QTY_DIF(PORQTYSTU,PORSTU,PIDQTYSTU,[F:MAT]TOLUOM,QTYDIF,QTYUOM1,QTYUOM2,[L]ITMREF,[L]BPSNUM,0,ERR,ERRMSG) # 107025.n
    If ERR : XERR=[F:MAT]IQEACT :Gosub ERR_UOM : Return : Endif          # No UOM conversion
    If [F:MAT]IQECTLQ=2 & QTYDIF < 0 & (abs(QTYDIF) > [F:MAT]IQEQTY) # Quantity Exceeded % Control = Quantity invoiced exceeds PO quantity
      TWMSTA = func TWMSTA_CHK(TWMSTA,[F:MAT]IQEACT)
      TWMTSTA(NOL) = func TWMTSTA_CHK(0,[F:MAT]IQEACT)
