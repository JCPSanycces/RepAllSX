  Chgstl [M:PIH3]ITMREF(NOL) With STYLE
#Next # 83001.o
If dim(SAVSTA)=1 & SAVSTA=4 : [M:PIH1]TWMSTA=4 : Affzo [M:PIH1]TWMSTA : Raz SAVSTA : Endif
Affzo [M:PIH1]TWMSTA # 95938.n
Return
############################################################
$PIH_LIENS
[M:PIH3]TWMSTAL(NOL) = [F:PID]TWMSTA  # 95938.n # new line
If [F:PIH]STA=3 : Return : Endif # On re-evaluation on validated invoices
Gosub PIH_TWMACT
If dim(SAVSTA)=1 & SAVSTA=4 : [M:PIH1]TWMSTA=4 : Affzo [M:PIH1]TWMSTA : Raz SAVSTA : Endif
Return
