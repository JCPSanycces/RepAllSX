# 95938.n
$PIH_INICRE_LIG
$PIH_INIMOD_LIG
# The header TWNSTA field was being overwritten by the first line detail TWNSTA field, so PIH3 was changed to TWNSTAL per the PRD
[F:PID]TWMSTA = [M:PIH3]TWMSTAL(nolign-1)
Return
# 95938.en
####################################################################################
# 95549.n this routine was copied from PTH_VERIF and then modifed for invoices
# 02/06/14 - No warning or blocking messages are / will be displayed in Invoice entry
$PIH_VERIF
Local Integer XOK, XMAT

## The PTH_VERIF_MOD and PTH_VERIF_CRE routine were combined here as they were the same
# Set the header value to 1 (lowest) because it will be reset in PIH_TWMACT as the max value of the line or header
[M:PIH1]TWMSTA = 1
For NOL=0 To [M:PIH3]NBLIG-1
 Gosub PIH_TWMACT
Next
If dim(SAVSTA)=1 & SAVSTA=4 : [M:PIH1]TWMSTA=4 : Raz SAVSTA : Endif
##
Affzo [M:PIH1]TWMSTA

Return
# 95549.en
