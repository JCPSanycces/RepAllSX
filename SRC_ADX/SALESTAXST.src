#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
# Program Name: SALESTAXST
# Description : Sales Tax Report
####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

####################################################################################
$ACTION

Return

##############################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char TEST(20)

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]CRITERE = "1=1"
[L]SCRITERE = "1=1"
[L]SFCRITERE = "1=1"

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "societe"
    [L]CRITERE -= "& [SIH]CPY ='"+[L]VALEUR+"'"
    [L]SCRITERE -= "& [SIH]CPY ='"+[L]VALEUR+"'"
    [L]SFCRITERE -= "& [SIH]CPY ='"+[L]VALEUR+"'"
   When "taxcodeb"
    [L]CRITERE -= "& [SVV]VAT >='"+[L]VALEUR+"'"
    [L]TAXCOCRITERE = [L]VALEUR
    [L]SFCRITERE -= "& [SVF]DTAVAT >='"+[L]VALEUR+"'"
   When "taxcofin"
    [L]CRITERE -= "& [SVV]VAT <='"+[L]VALEUR+"'"
    [L]TAXCOCRITERE2 = [L]VALEUR
    [L]SFCRITERE -= "& [SVF]DTAVAT <='"+[L]VALEUR+"'"
   When "datedeb"
    [L]DTEDEB=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "datefin"
    [L]DTEFIN=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "datesel"
    [L]DATCRITERE = val(VALINT1(3)) # Accounting or Invoice date
   When "rptform"
    [L]SUMCRITERE = val(VALINT1(4)) # Summary or detail
   When "invelem"
    [L]INVCRITERE = val(VALINT1(5)) # Invoice elements
   When "frtelem"
    [L]FRTELEM = val(VALINT1(6)) # Taxable freight element
   When "frtelemnt"
    [L]FRTELEMNT = val(VALINT1(7)) # Non taxable freight element
 Endcase
 Endif
Next

# Initialize the STB table to prepare to load it with new information.
Lock [STB]
Delete[STB] Where PID=num$(adxpid) | CREDAT<date$-7

Unlock [STB]
Read [CPY]CPY0=[L]VALEUR(0)

# Write the SVV Records
Gosub SVV_LOOP

# Write the SVF records (invoicing elements)
If [L]INVCRITERE = 2
 Gosub SVF_LOOP
Endif

# Write the BP Invoice Records
Gosub SIL_LOOP

End

####################################################################################
$OUVRE

If !clalev([F:STB])  : Local File SALESTAX    [STB]  : Endif
If !clalev([F:SIL])  : Local File BPCINVLIG   [SIL]  : Endif
If !clalev([F:SIH])  : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY   [HAE]  : Endif
If !clalev([F:SVV])  : Local File SVCRVAT     [SVV]  : Endif
If !clalev([F:SVF])  : Local File SVCRFOOT    [SVF]  : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER  [BPC]  : Endif
If !clalev([F:SFI])  : Local File SFOOTINV    [SFI]  : Endif
If !clalev([F:PYD])  : Local File PAYMENTD    [PYD]  : Endif
If !clalev([F:TVT])  : Local File TABVAT      [TVT]  : Endif
If !clalev([F:CPY])  : Local File COMPANY     [CPY]  : Endif
# V7 If !clalev([F:TVB])  : Local File TABVACBPR   [TVB]  : Endif
If !clalev([F:TVC])  : Local File TABVAC      [TVC]  : Endif
If !clalev([F:SID])  : Local File SINVOICED   [SID]  : Endif #120697.n

Local Char    LTYP(3)

Return

####################################################################################
$DECLARE

Local Char    CRITERE(255),SCRITERE(255),SFCRITERE(255), PARAM(30),VALEUR(30),ETAT(15),TAXCOCRITERE,TAXCOCRITERE2
Local Date    DTEDEB,DTEFIN
Local Integer NUMREQ,RFLAG,DATCRITERE,SUMCRITERE,INVCRITERE,FRTELEM,FRTELEMNT
Local Integer LRET, TMP_ADXLOG

Return

####################################################################################
$SVV_LOOP

Local Decimal WDTATAX,WDTANTAX,WDTAEXE,WSALES,WBASTAX
Local Decimal SID_TAX,SID_NTAX,LIN_TAX,LIN_NTAX #120697.n
Local Char SVCRNUM, WEXEMPT

SFLAG = 1

Link [SIH] With [SVV]SVV0(2)=4;[F:SIH]NUM,
&    [HAE]HAE0=[F:SIH]GTE;[F:SIH]NUM As [STAX]
& Where evalue([L]CRITERE) & (([HAE]CREDAT >= DTEDEB & [HAE]CREDAT <= DTEFIN and [L]DATCRITERE = 1)
&                          |  ([HAE]ACCDAT >= DTEDEB & [HAE]ACCDAT <= DTEFIN and [L]DATCRITERE >1 )) Order By Key CLE = [SVV]VAT;[SIH]NUM  # VAT code and invoice

For [STAX]
  SVCRNUM=[SVV]VCRNUM
  If [SVV]AMTTAX=0
    WDTANTAX=[SVV]VATGRO   # Non-taxable element base
    Raz WDTATAX
  Else
    If [L]INVCRITERE=2
      WDTATAX=[SVV]BASTAX
    Else
      WDTATAX=[SVV]VATGRO    # Taxable element base
    Endif
    Raz WDTANTAX

    #120697.sn Calculate non-taxable amount using the SINVOICE table
    Raz SID_TAX,SID_NTAX
    For [SID] Where NUM=[SVV]VCRNUM
      For J=0 To dim([SID]VAT)-1
        Raz LIN_TAX,LIN_NTAX
        If [SID]VAT(J)=[SVV]VAT
          If [SID]AMTTAXLIN(J)<>0
            LIN_TAX=[SID]AMTNOTLIN
          Else
            LIN_NTAX=[SID]AMTNOTLIN
          Endif
          Break
        Endif
      Next

      SID_TAX = SID_TAX + LIN_TAX
      SID_NTAX = SID_NTAX + LIN_NTAX
    Next

    If SID_NTAX<>0
      WDTATAX=SID_TAX
      WDTANTAX=SID_NTAX
    Endif
    #120697.en
  Endif

  If [L]INVCRITERE=2
    WBASTAX=[SVV]AMTTAX # Tax
    WSALES=[SVV]VATGRO + [SVV]VATAMT + [SVV]VATSUPAMT  # Sales amount
  Else
    WBASTAX=[SVV]VATAMT # Tax
    WSALES=[SVV]VATGRO + [SVV]VATAMT + [SVV]VATSUPAMT  # Sales amount
  Endif

  Read [BPC]BPC0=[SIH]BPRPAY
  If !fstat & [BPC]VATEXN<>"" &  WDTANTAX <> 0
    WEXEMPT = [BPC]VATEXN
    #120697.sn
    #WDTAEXE = [SVV]VATGRO # Exempt sale
    #Raz WDTATAX,WDTANTAX
    WDTAEXE = WDTANTAX
    Raz WDTANTAX
    #120697.en
  Endif

  If WBASTAX <> 0 | WSALES <> 0
    Gosub TAX_COLLECTED
    Gosub WRITE_RECORD
  Endif
  Raz WDTATAX,WDTANTAX,WBASTAX,WSALES,WEXEMPT,WDTAEXE
Next

Return
####################################################################################
$SVF_LOOP

Local Integer RCP_IN_RANGE,INV_IN_RANGE,SLIN,WFREIGHT,WFREIGHTNT
Local Decimal WDTATAX,WDTANTAX,WDTAEXE,WSALES,WBASTAX
Local Char SVCRNUM, WEXEMPT

SFLAG = 3

Link [SIH] With [SVF]SVF0(2)=[F:SIH]NUM;4,
&    [HAE]HAE0=[F:SIH]GTE;[F:SIH]NUM,
&    [SFI]SFI0=[SVF]DTA As [STA2]
& Where evalue([L]SFCRITERE) &  ( ([HAE]CREDAT >= DTEDEB & [HAE]CREDAT <= DTEFIN and [L]DATCRITERE = 1)
&                          |      ([HAE]ACCDAT >= DTEDEB & [HAE]ACCDAT <= DTEFIN and [L]DATCRITERE >1 )) Order By Key CLE = [SVF]DTAVAT();[SIH]NUM  # VAT code and invoice

For [STA2]
    For J=0 To dim([SVF]DTAVATAMT)-1
    If  [SVF]DTAVAT(J)>=TAXCOCRITERE & [SVF]DTAVAT(J)<=TAXCOCRITERE2
     If [SFI]SFINUM=[L]FRTELEM
      WFREIGHT=1
     Elsif [SFI]SFINUM=[L]FRTELEMNT
      WFREIGHTNT=1
     Endif
       WBASTAX=[SVF]DTAVATAMT(J)  # Tax
       If [SVF]DTAVATAMT(J)<>0
        WDTATAX=[SVF]DTANET(J)    # Taxable element base
       Else
        WDTANTAX=[SVF]DTANET(J)   # Non-taxable element base
       Endif
     If [SVF]AMTCOD>1
      WSALES=[SVF]DTAAMT          # Sales amount
      If [SFI]VALTYP=1 : WSALES+=[SVF]DTAVATAMT(J) : Endif
     Else
      WSALES=[SVF]DTANOT          # Sales amount based on %
      WSALES+=[SVF]DTAVATAMT(J)  #: Endif
     Endif

    Read [BPC]BPC0=[SIH]BPRPAY
    If !fstat & [BPC]VATEXN<>"" &  WDTANTAX <> 0
     WDTAEXE = WDTANTAX           # Exempt sale
     WEXEMPT = [BPC]VATEXN
     Raz WDTATAX,WDTANTAX
    Endif
    #WSALES+=[SVF]DTAAMT # Add to transaction amount
    If WDTANTAX <> 0 | WDTATAX <> 0 | WDTAEXE <> 0
     Gosub WRITE_RECORD
    Endif
    Raz WFREIGHT, WFREIGHTNT, WBASTAX, WDTATAX, WDTANTAX, WEXEMPT, WDTAEXE, WSALES
    Endif
    Next
Next

Return
####################################################################################
$SIL_LOOP

Local Integer RCP_IN_RANGE,INV_IN_RANGE
Local Decimal WDTATAX,WDTANTAX,WDTAEXE,WSALES
Local Char WEXEMPT,SILVAT

SFLAG = 2

Link [SIH] With [SIL]SIL0(1)=[F:SIH]NUM,
&    [HAE]HAE0=[F:SIH]GTE;[F:SIH]NUM As [STA3]
& Where evalue([L]SCRITERE) & ( ([HAE]CREDAT >= DTEDEB & [HAE]CREDAT <= DTEFIN and [L]DATCRITERE = 1)
&                          |    ([HAE]ACCDAT >= DTEDEB & [HAE]ACCDAT <= DTEFIN and [L]DATCRITERE >1 )) Order By Key CLE2 = [SIL]VAT;[SIH]NUM  # VAT code and invoice

For [STA3]
      If [SIL]VAT=""
        SILVAT = func SIL_VAT([SIH]VAC,[F:CPY]LEG)
      Else SILVAT = [SIL]VAT
      Endif
       If [SIL]AMTVAT=0
          WDTANTAX=[SIL]AMTNOTLIN          # Non-taxable element base
       Else
          WDTATAX=[SIL]AMTNOTLIN           # Taxable element base
       Endif
          WBASTAX=[SIL]AMTTAX1+[SIL]AMTTAX2+[SIL]AMTVAT # Tax
          WSALES=WDTATAX+WDTANTAX+WBASTAX  # Sales amount
    Read [BPC]BPC0=[SIH]BPRPAY
    If !fstat & [BPC]VATEXN<>"" &  WDTANTAX <> 0
     WDTAEXE = WDTANTAX                     # Exempt sale
     WEXEMPT = [BPC]VATEXN
     Raz WDTATAX,WDTANTAX
    Endif
  Gosub TAX_COLLECTED
  If ((WDTANTAX <> 0 | WDTATAX <> 0 | WDTAEXE <> 0 | WSALES <> 0) and (SILVAT>=[L]TAXCOCRITERE &  SILVAT <=[L]TAXCOCRITERE2))
   Gosub WRITE_RECORD
    Raz WDTATAX,WDTANTAX,WBASTAX,WSALES,WEXEMPT,WDTAEXE,SILVAT
  Endif
  Raz WDTATAX,WDTANTAX,WBASTAX,WSALES,WDTAEXE,SILVAT
Next

Return

####################################################################################
Funprog SIL_VAT (SILVAT,SILLEG)
Value Char SILVAT,SILLEG


# V7 below
#Read[TVB]TVB0=SILVAT;SILLEG
#If fstat
# Read[TVB]TVB0(1)=SILVAT
#Endif
#If !fstat
# SILVAT = [TVB]VAT
#Else
# Raz SILVAT
#Endif

# V6 below
Read [TVC]TVC1(1)=SILVAT
If !fstat
 SILVAT = [TVC]VAT
Else
 Raz SILVAT
Endif

End SILVAT

####################################################################################
$TAX_COLLECTED
Local Decimal WPAYAMT,WCOLL

Filter [PYD] Where VCRNUM=[SIH]NUM and VCRTYP=[SIH]GTE

For [PYD]
 WPAYAMT+=[PYD]PAYCURLIN
Next

If WPAYAMT >= [SIH]AMTATIL : WCOLL=1 : Endif
Filter [PYD]


Return
####################################################################################
$WRITE_RECORD

TMP_ADXLOG  = adxlog

Raz [STB]

If  !TMP_ADXLOG : Trbegin [STB] : Endif

Case SFLAG
 When 1       # SVV available
    [STB]     = [SVV]
 When 2       # SIL available
    Read [STB]STB1=[SIL]NUM;4;SILVAT;num$(adxpid)
    If !fstat
     [STB]AMTTAX+=WDTATAX   # Taxable basis
     [STB]AMTNON+=WDTANTAX  # Non-taxable basis
     [STB]AMTEXE+=WDTAEXE   # Exempt
     [STB]VATTAX+=WBASTAX   # Tax
     [STB]VATGRO+=WSALES    # Sales
    Goto REWRITE_STB
    Else
    [STB]     = [SIL]
    [STB]     = [SIH]
    [STB]VCRNUM = [SIH]NUM
    [STB]VAT  = SILVAT
    If WBASTAX >0 : [STB]VATTYP = 1 : Endif

    #[STB]VCRTYP = 4 #107806.o

    If WDTATAX > 0 : [STB]VATRAT = arr((WBASTAX/WDTATAX)*100,.01) : Endif
    Endif
 When 3       # SVF available
    Read [STB]STB1=[SVF]VCRNUM;[SVF]VCRTYP;[SVF]DTAVAT(J);num$(adxpid)
    If !fstat
     If WFREIGHT  # Freight invoicing element
      [STB]FRTTAX+=WDTATAX  # Taxable freight
      [STB]VATGRO+=WSALES    # Sales
     Else         # Other invoicing elements
      [STB]AMTEXE+=WDTAEXE   # Exempt
      [STB]VATGRO+=WSALES    # Sales
      If WFREIGHTNT: [STB]FRTNON+=WDTANTAX : Endif # Non taxable freight - not reported
      If WCOLL : [STB]VATCOLL+=WBASTAX  : Endif # Tax collected - not reported
     Endif
    Goto REWRITE_STB
    Else
     If !TMP_ADXLOG: Commit : Endif
     Goto SVF_FAIL
     #[STB]  = [SVF]
     #[STB]VAT=[SVF]DTAVAT(J)
    Endif
 When Default
Endcase

#107806.sn
#[SIH]INVTYP(Invoice Type)
If [SIH]INVTYP = 2 or [SIH]INVTYP = 4 #2 Credit Memo & 4 Credit Note
    #[STB]VCRTYP(Sales Document Type)
    [STB]VCRTYP = 5 #Credit Memo
Else
    [STB]VCRTYP = 4 #Invoice
Endif
#107806.en

# V7 Read [TVT]TVT0=[STB]VAT;[CPY]LEG
# V7 If fstat
# V7 Read [TVT]TVT1=[STB]VAT #Missing legislation
# V7 Endif
Read [TVT]TVT0=[STB]VAT # V6
[STB]VATDES=[TVT]VATDES
[STB]GTE=[SIH]GTE
[STB]AMTTAX=WDTATAX   # Taxable basis
[STB]AMTNON=WDTANTAX  # Non-taxable basis
[STB]AMTEXE=WDTAEXE   # Exempt
[STB]VATTAX=WBASTAX   # Tax
[STB]VATGRO=WSALES    # Sales
[STB]VATEXN=WEXEMPT   # Exemption number
[STB]VCRDAT=[HAE]ACCDAT # Invoice date
[STB]ACCDAT=[HAE]CREDAT # Post date
If [L]DATCRITERE=2
 [STB]FYEAR=year([HAE]ACCDAT) # Fiscal year
 [STB]FPER=month([HAE]ACCDAT) # Fiscal period
Else
 [STB]FYEAR=year([HAE]CREDAT) # Fiscal year
 [STB]FPER=month([HAE]CREDAT) # Fiscal period
Endif
[STB]PID = num$(adxpid)
If WCOLL : [STB]VATCOLL=WBASTAX  : Endif # Tax collected

Write [STB]

If fstat
  If !TMP_ADXLOG : Rollback : Endif
Else
  If !TMP_ADXLOG: Commit : Endif
Endif
$SVF_FAIL
Return
#########################################################################################
$REWRITE_STB
Rewrite [STB]

If fstat
  If !TMP_ADXLOG : Rollback : Endif
Else
  If !TMP_ADXLOG: Commit : Endif
Endif

Return

