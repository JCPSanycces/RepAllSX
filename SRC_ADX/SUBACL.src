###############################################################
# Action ACONTACL utilisée dans le type de donnée AVV
###############################################################
Subprog CONTACL(VALINT,CODTYP,TABCONT,DEPCOD)
Value    Char    VALINT
Value    Char    CODTYP
Value    Char    TABCONT
Value    Char    DEPCOD
If CODTYP="" | TABCONT="" : End : Endif
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Read [ATY]CODTYP = CODTYP
If !fstat
 Case [F:ATY]TYPTYP
  When 1
   Local Integer VALPAR
   VALPAR = val(VALINT)
   Call CONTACL_LIB(TABCONT,DEPCOD,VALPAR) From SUBACL
  When 2,3,4,5,6
   Local Decimal VALPAR
   VALPAR = val(VALINT)
   Call CONTACL_NUM(TABCONT,DEPCOD,VALPAR) From SUBACL
  When 7
   Local Char VALPAR(250)
   VALPAR = VALINT
   Call CONTACL_CHAR(TABCONT,DEPCOD,VALPAR) From SUBACL
  When 8
   Local Date VALPAR
   VALPAR = gdat$(VALINT)
   Call CONTACL_DAT(TABCONT,DEPCOD,VALPAR) From SUBACL
 Endcase
Endif
End

##################################################################
#  Contrôle d'une zone par rapport à un code contrôle            #
##################################################################
Subprog CONTACL_CHAR(CODE,DEPCOD,VALEUR)
Value    Char    CODE
Value    Char    DEPCOD
Variable Char    VALEUR
Goto CONTACL_

Subprog CONTACL_NUM(CODE,DEPCOD,VALEUR)
Value    Char    CODE
Value    Char    DEPCOD
Variable Decimal VALEUR
Goto CONTACL_

Subprog CONTACL_DAT(CODE,DEPCOD,VALEUR)
Value    Char    CODE
Value    Char    DEPCOD
Variable Date    VALEUR
Goto CONTACL_

Subprog CONTACL_LIB(CODE,DEPCOD,VALEUR)
Value    Char    CODE
Value    Char    DEPCOD
Variable Integer VALEUR
Goto CONTACL_

$CONTACL_
Local Integer OK
Local Integer ERR , NUL , OBLIG
Local Char    MESSAGE(250) , FORMULE(250) , TABLE(10)
If clalev([F:ACL])=0 : Local File ACTL [ACL] : Endif
Call LECTURE("ACL",CODE,"") From CONTOBJ
## Test zone obligatoire
OK  = 1
NUL = 0
Case type(VALEUR)
 When 1,2,4,5,6,7,8,9
  If VALEUR=0 : NUL = 1 : Endif
 When 3
  If VALEUR=[0/0/0] : NUL = 1 : Endif
 When Default
  If VALEUR="" : NUL = 1  : Endif
Endcase
If NUL
 If [F:ACL]OBL<>2
  OBLIG = 0
 Elsif [F:ACL]CTLOBL=""
  OBLIG = 1
 Else
  Onerrgo ERR
  OBLIG = evalue([F:ACL]CTLOBL)
  Onerrgo
  If ERR
   OBLIG = 1
  Endif
 Endif
 If OBLIG
  MESSAGE = mess(10,123,1) : # Zone obligatoire
  Goto ERR_CTL
 Else
  End
 Endif
Endif

## Vérif zones obligatoire et interdites et bornes
If find([F:ACL]TYPCTL,1,2,3)
 MESSAGE = [F:ACL]MSG
 Call VERIF_CTL([F:ACL]TYPCTL,[F:ACL]LSTVAL,[F:ACL]NBRVAL,[F:ACL]FRM,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif
If find([F:ACL]TYPCTL2,1,2,3)
 MESSAGE = [F:ACL]MSG2
 Call VERIF_CTL([F:ACL]TYPCTL2,[F:ACL]LSTVAL2,[F:ACL]NBRVAL2,[F:ACL]FRM2,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL2
& ,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif
If find([F:ACL]TYPCTL3,1,2,3)
 MESSAGE = [F:ACL]MSG3
 Call VERIF_CTL([F:ACL]TYPCTL3,[F:ACL]LSTVAL3,[F:ACL]NBRVAL3,[F:ACL]FRM3,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL3
& ,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif

## Vérifs tables liées

If [F:ACL]TYPCTL=4
 TABLE = [F:ACL]LSTVAL(0) : MESSAGE = [F:ACL]MSG : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL2=4
 TABLE = [F:ACL]LSTVAL2(0) : MESSAGE = [F:ACL]MSG2 : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL3=4
 TABLE = [F:ACL]LSTVAL3(0) : MESSAGE = [F:ACL]MSG3 : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif

## Vérif formules

If [F:ACL]TYPCTL=5
 FORMULE = [F:ACL]FRM : MESSAGE = [F:ACL]MSG : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL2=5
 FORMULE = [F:ACL]FRM2 : MESSAGE = [F:ACL]MSG2 : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL3=5
 FORMULE = [F:ACL]FRM3 : MESSAGE = [F:ACL]MSG3 : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif

End

$ERR_CTL
ERR = 0
Onerrgo ERR
GMESSAGE = evalue(MESSAGE)
Onerrgo
If ERR
 GMESSAGE = MESSAGE
Endif
mkstat = 2
End

$LIEN_CTL
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Read [ATB]CODFIC = TABLE
If fstat
 MESSAGE = TABLE-":"-mess(124,124,1) : # Table inexistante
 OK = 0 : Return
Endif
Call LEC_TABLE(TABLE,[F:ATB]ABRFIC,VALEUR,ERR)
If ERR
 MESSAGE = mess(162,115,1)+"\"+TABLE : # Lien incorrect
 OK = 0
Elsif fstat
 If MESSAGE=""
  MESSAGE = mess(23,100,1) : # Fiche inexistante
 Endif
 OK = 0
Endif
Return

Subprog LEC_TABLE(TABLE,ABREV,VALEUR,ERR)
Variable Integer ERR
Local Integer I , J
I = type(VALEUR)
J = func TYPKEY(TABLE)
Case J
 When 1,2,4,5,6,7,8,9
  Local Integer VALKEY
  If find(I,1,2,4,5,6,7,8,9)
   VALKEY = VALEUR
  Else
   VALKEY = val(VALEUR)
  Endif
 When 3
  Local Date VALKEY
  VALKEY = VALEUR
 When Default
  Local Char VALKEY(250)
  If find(I,1,2,4,5,6,7,8,9)
   VALKEY = num$(VALEUR)
  Else
   VALKEY = VALEUR
  Endif
Endcase
Local File =TABLE
Assign "[G:"+ABREV+"]currind" With 1
Assign "[G:"+ABREV+"]currlen" With 1
ERR = 0
Onerrgo ERR
Read [F] = VALKEY
Onerrgo
End

#X3-55886
#Funprog TYPKEY(TABLE)
#Value Char TABLE
#Local Char INDEX(80) , CHAMP(20)
#Local Integer I , J , TYP
#Local File ATABIND [ATI_]
#Read [ATI_]NUMLIG(1)=TABLE
#INDEX = [F:ATI_]DESCRIPT
#I = instr(1,CHAMP,"-")
#J = instr(1,CHAMP,"+")
#If I & J
# I = min(I,J)
#Elsif J & !I
# I = J
#Endif
#If I
# CHAMP = left$(INDEX,I-1)
#Else
# CHAMP = INDEX
#Endif
#Local File =TABLE
#TYP = evalue("type([F]"+CHAMP+")")
#End TYP
Funprog TYPKEY(TABLE)
Value Char TABLE
Local Integer I , J , TYP
Local File ATABIND [ATI_]
Read [ATI_]NUMLIG(1)=TABLE
I = instr(1,[F:ATI_]DESCRIPT,"-")
J = instr(1,[F:ATI_]DESCRIPT,"+")
If I & J
 I = min(I,J)
Elsif J & !I
 I = J
Endif
Local File =TABLE
If I
  TYP = evalue("type([F]"+left$([F:ATI_]DESCRIPT,I-1)+")")
Else
  TYP = evalue("type([F]"+[F:ATI_]DESCRIPT+")")
Endif
End TYP
#End X3-55886

$FRM_CTL
ERR = 0
Onerrgo ERR
OK = evalue(FORMULE)
Onerrgo
If ERR
 OK = 0
 MESSAGE = mess(37,124,1)+"\"+vireblc(format$("KT:120X",FORMULE),2) : # Expression incorrecte
Elsif !OK
 If MESSAGE=""
  MESSAGE = mess(83,123,1) : # Valeur incorrecte
 Endif
Endif
Return

Subprog VERIF_CTL(TYP,LISTE,NB,FORMULE,MESSAGE,OK,DEPCOD,LISTEDEP,VALEUR)
Value    Integer TYP
Value    Char    LISTE()()
Value    Integer NB
Value    Char    FORMULE
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    DEPCOD
Value    Char    LISTEDEP()()

Local Integer I, ERR,J
Local Char    VCAR(30)


OK = 1
J  = 1
Case type(VALEUR)
 When 1,2,4,5,6,7,8 : VCAR = num$(VALEUR)
 When Default       : VCAR = VALEUR
Endcase
Case TYP
 When 1
  If DEPCOD <> ""
   For I=0 To NB-1
    If ((LISTEDEP(I) <> DEPCOD) & LISTEDEP(I)<>"")
     LISTE(I) = ""
    Endif
   Next I
  Endif
  If !find(VCAR,LISTE(0..NB-1))
   If MESSAGE=""
    MESSAGE = mess(1,79,1)+":" : # Valeurs obligatoires
    For I=0 To NB-1
     MESSAGE -= LISTE(I)
     If (I<>NB-1) & (LISTE(I)<>"") : MESSAGE += "," : J=0 : Endif
    Next I
    If J=1 : MESSAGE = VCAR-mess(99,133,1)-DEPCOD : Endif : # ne dépend pas de
   Endif
   OK = 0
  Endif
 When 2
  If find(VCAR,LISTE(0..NB-1))
   If MESSAGE=""
    MESSAGE = mess(2,79,1)+":" : # Valeurs interdites
    For I=0 To NB-1
     MESSAGE -= LISTE(I)
     If I<>NB-1 : MESSAGE += "," : Endif
    Next I
   Endif
   OK = 0
  Endif
 When 3
  If val(VCAR) < val(LISTE(0)) | val(VCAR) > val(LISTE(1))
   If MESSAGE=""
    MESSAGE  = mess(3,79,1)+":" : # Bornes de valeurs
    MESSAGE -= LISTE(0)
    MESSAGE -= "-"-LISTE(1)
   Endif
   OK = 0
  Endif
Endcase
End

$ERR
ERR = errn
Resume

##################################################################
#  Sélection d'une zone par rapport à une table de contrôle      #
##################################################################
$SEL_LISTE
Case LISTE
 When "SELACLDEP" : Gosub SELACLDEP
 When Default     : Gosub SELACL
Endcase
Return

$SELACL
Local Char DEPEND(50)
DEPEND =  num$(PARAM(2))
TIT = mess(16,9003,1) :# Choix possibles :
If clalev([F:ACL])=0 : Local File ACTL [ACL] : Endif
Call LECTURE("ACL",PARAM(1),"") From CONTOBJ

$LISTE
If [F:ACL]TYPCTL=1
 Raz NBTEX
 For I=0 To [F:ACL]NBRVAL-1
  If NBTEX>=dim(TEX)-1 : Break : Endif
  If DEPEND<>""
   If (([F:ACL]DEPVAL(I)=DEPEND) | ([F:ACL]DEPVAL(I)=""))
    NBTEX += 1
    TEX(NBTEX) = [F:ACL]LSTVAL(I)
   Endif
  Else
   NBTEX += 1
   TEX(NBTEX) = [F:ACL]LSTVAL(I)
  Endif
 Next I
Elsif [F:ACL]TYPCTL2=1
 Raz NBTEX
 For I=0 To [F:ACL]NBRVAL2-1
  If NBTEX>=dim(TEX)-1 : Break : Endif
  If DEPEND<>""
   If (([F:ACL]DEPVAL2(I)=DEPEND) | ([F:ACL]DEPVAL2(I)=""))
    NBTEX += 1
    TEX(NBTEX) = [F:ACL]LSTVAL2(I)
   Endif
  Else
   NBTEX += 1
   TEX(NBTEX) = [F:ACL]LSTVAL2(I)
  Endif
 Next I
Elsif [F:ACL]TYPCTL3=1
 Raz NBTEX
 For I=0 To [F:ACL]NBRVAL3-1
  If NBTEX>=dim(TEX)-1 : Break : Endif
  If DEPEND<>""
   If (([F:ACL]DEPVAL3(I)=DEPEND) | ([F:ACL]DEPVAL3(I)=""))
    NBTEX += 1
    TEX(NBTEX) = [F:ACL]LSTVAL3(I)
   Endif
  Else
   NBTEX += 1
   TEX(NBTEX) = [F:ACL]LSTVAL3(I)
  Endif
 Next I
Endif
Return

$SELACLDEP
TIT = mess(16,9003,1) :# Choix possibles :
If clalev([F:ACL2])=0 : Local File ACTL [ACL2] : Endif
NBTEX = 0
If    [M:ACL1]DEPCTL  <> "" :  Read [ACL2]ACL0=[M:ACL1]DEPCTL
Elsif [M:ACL2]DEPCTL2 <> "" :  Read [ACL2]ACL0=[M:ACL2]DEPCTL2
Elsif [M:ACL3]DEPCTL3 <> "" :  Read [ACL2]ACL0=[M:ACL3]DEPCTL3
Endif
If !fstat
 If [F:ACL2]TYPCTL = 1
  For I=0 To 29
   If [F:ACL2]LSTVAL(I) = "" : Break : Return: Endif
   NBTEX += 1
   TEX  (NBTEX)  = [F:ACL2]LSTVAL(I)
   TEXTE(NBTEX)  = [F:ACL2]CTL
   TEXTE(NBTEX) += "     "+[F:ACL2]LSTVAL(I)
  Next I
 Elsif [F:ACL2]TYPCTL2 = 1
  For I=0 To 29
   If [F:ACL2]LSTVAL2(I) = "" : Break : Return: Endif
   NBTEX += 1
   TEX  (NBTEX)  = [F:ACL2]LSTVAL2(I)
   TEXTE(NBTEX)  = [F:ACL2]CTL
   TEXTE(NBTEX) += "     "+[F:ACL2]LSTVAL2(I)
  Next I
 Elsif [F:ACL2]TYPCTL3 = 1
  For I=0 To 29
   If [F:ACL2]LSTVAL3(I) = "" : Break : Return: Endif
   NBTEX += 1
   TEX  (NBTEX)  = [F:ACL2]LSTVAL3(I)
   TEXTE(NBTEX)  = [F:ACL2]CTL
   TEXTE(NBTEX) += "     "+[F:ACL2]LSTVAL3(I)
  Next I
 Endif
Endif
Return

##############################################################

$SEL_TABLE
Case TABLE
 When "SELACL"
  OBJET = "ACL"
  If dim([M]CTL)>0 & zoncou="DEPCTL"
   CRITERE = 'CTL<>"'+[M]CTL+'"'
  Endif
 When Default
  If clalev([F:ACL])=0 : Local File ACTL [ACL] : Endif
  Call LECTURE("ACL",PARAM(1),"") From CONTOBJ
  If [F:ACL]TYPCTL=4
   Call SELOBJ([F:ACL]LSTVAL(0),OBJET,CRITERE)
  Elsif [F:ACL]TYPCTL2=4
   Call SELOBJ([F:ACL]LSTVAL2(0),OBJET,CRITERE)
  Elsif [F:ACL]TYPCTL3=4
   Call SELOBJ([F:ACL]LSTVAL3(0),OBJET,CRITERE)
  Endif
Endcase
Return

##############################################################
Subprog SELOBJ(FICHIER,OBJET,CRITERE)
Value    Char FICHIER
Variable Char OBJET
Variable Char CRITERE()()

Local File AOBJET [AAA_]
Filter [AAA_] Where NOMFIC=[L]FICHIER
Read [AAA_]ABREV First
Filter [AAA_]
If fstat : End : Endif

OBJET = [F:AAA_]ABREV

Gosub NOMFIC From ="WO"+OBJET
Gosub SETCLE From ="WO"+OBJET

CRITERE = ""
If [F:ACL]TYPCTL=3
 Call SELBORNE(CRITERE,CLEPRIM,[F:ACL]LSTVAL(0),[F:ACL]LSTVAL(1))
Endif
If [F:ACL]TYPCTL2=3
 Call SELBORNE(CRITERE,CLEPRIM,[F:ACL]LSTVAL2(0),[F:ACL]LSTVAL2(1))
Endif
If [F:ACL]TYPCTL3=3
 Call SELBORNE(CRITERE,CLEPRIM,[F:ACL]LSTVAL3(0),[F:ACL]LSTVAL3(1))
Endif
If [F:ACL]TYPCTL=5
 Call SELEXP(CRITERE,[F:ACL]FRM,CLEPRIM)
Endif
If [F:ACL]TYPCTL2=5
 Call SELEXP(CRITERE,[F:ACL]FRM2,CLEPRIM)
Endif
If [F:ACL]TYPCTL3=5
 Call SELEXP(CRITERE,[F:ACL]FRM3,CLEPRIM)
Endif
If CRITERE="" : CRITERE = "1=1" : Endif
End

Subprog SELBORNE(CRITERE,CLEPRIM,DEB,FIN)
Variable Char CRITERE
Value    Char CLEPRIM
Value    Char DEB
Value    Char FIN
If CRITERE<>"" : CRITERE -= "&" : Endif
CRITERE -= CLEPRIM+">="+DEB+" & "+CLEPRIM+"<="+FIN
End

Subprog SELEXP(CRITERE,FORMULE,CLEPRIM)
Variable Char CRITERE
Value    Char FORMULE
Value    Char CLEPRIM
Local Char    CHAINE(250)
Local Integer I
CHAINE = vireblc(format$("KT:120X",FORMULE),2)
Repeat
 I = instr(1,CHAINE,"zc")
 If I
  CHAINE = left$(CHAINE,I-1)+CLEPRIM+right$(CHAINE,I+2)
 Endif
Until I=0
Repeat
 I = instr(1,CHAINE,"VALEUR")
 If I
  CHAINE = left$(CHAINE,I-1)+CLEPRIM+right$(CHAINE,I+6)
 Endif
Until I=0
If CRITERE<>"" : CRITERE -= "&" : Endif
CRITERE -= "("+CHAINE+")"
End

Subprog AS_DEPVAL(VALEUR)
Variable Char     VALEUR
If [M:ACL1]DEPCTL = ""
 mkstat = 2
Endif
End

Subprog AS_DEPVAL2(VALEUR)
Variable Char     VALEUR
If [M:ACL2]DEPCTL2 = ""
 mkstat = 2
Endif
End

Subprog AS_DEPVAL3(VALEUR)
Variable Char     VALEUR
If [M:ACL3]DEPCTL3 = ""
 mkstat = 2
Endif
End


Subprog C_DEPCTL(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M:ACL0]CTL
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2
Endif
End

Subprog C_DEPCTL2(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M:ACL0]CTL
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2
Endif
End

Subprog C_DEPCTL3(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M:ACL0]CTL
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2
Endif
End

Subprog C_DEPVAL(VALEUR)
Variable Char    VALEUR()
Local Integer ONGLET
ONGLET = 1
Call CONTDEPVAL(VALEUR,ONGLET)
If ONGLET = 0
  mkstat = 2
Endif
End

Subprog C_DEPVAL2(VALEUR)
Variable Char    VALEUR()
Local Integer ONGLET
ONGLET = 2
Call CONTDEPVAL(VALEUR,ONGLET)
If ONGLET = 0
  mkstat = 2
Endif
End

Subprog C_DEPVAL3(VALEUR)
Variable Char    VALEUR()
Local Integer ONGLET
ONGLET = 3
Call CONTDEPVAL(VALEUR,ONGLET)
If ONGLET = 0
  mkstat = 2
Endif
End

Subprog CONTDEPVAL(VALEUR,ONGLET)
Value Char VALEUR()
Variable Integer ONGLET
Local Integer I,OK
If clalev([F:ACL2])=0 : Local File ACTL [ACL2] : Endif
I = 0
OK = 0

Case ONGLET
 When 1 : If [M:ACL1]DEPCTL <> ""
           Read[ACL2]ACL0=[M:ACL1]DEPCTL
           If !fstat
            OK = 1
           Endif
          Endif
 When 2 : If [M:ACL2]DEPCTL2 <> ""
           Read[ACL2]ACL0=[M:ACL2]DEPCTL2
           If !fstat
            OK = 1
           Endif
          Endif
 When 3 : If [M:ACL3]DEPCTL3 <> ""
           Read[ACL2]ACL0=[M:ACL3]DEPCTL3
           If !fstat
            OK = 1
           Endif
          Endif
Endcase
If OK
 If [F:ACL2]TYPCTL = 1
  I = find(VALEUR,[F:ACL2]LSTVAL(0..29))
 Elsif [F:ACL2]TYPCTL2 = 1
  I = find(VALEUR,[F:ACL2]LSTVA2(0..29))
 Elsif [F:ACL2]TYPCTL3 = 1
  I = find(VALEUR,[F:ACL2]LSTVA3(0..29))
 Endif
Endif
If I = 0
 Case ONGLET
  When 1 : GMESSAGE = VALEUR -mess(99,133,1)- DEPCTL
  When 2 : GMESSAGE = VALEUR -mess(99,133,1)- DEPCTL2
  When 3 : GMESSAGE = VALEUR -mess(99,133,1)- DEPCTL3
 Endcase
 ONGLET = 0
Endif
End

