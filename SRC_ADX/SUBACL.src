#<AdxTL>@(#)0.0.0.0 $Revision$ 
Call OBJET("ACL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "ANNULE"    : Gosub ANNULE
 When "CHANGE"    : Gosub CHANGE
 When "SETBOUT"   : Gosub SETBOUT
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

$SETBOUT
If !CLECUR or REP<>""
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$LIENS
Case [F:ACL]TYPCTL
 When 3
  [M]DEBUT = val([F:ACL]LSTVAL(0))
  [M]FIN   = val([F:ACL]LSTVAL(1))
  [M]NBRVAL = 0
 When 4
  [M]REFTAB = [F:ACL]LSTVAL(0)
  [M]NBRVAL = 0
Endcase
Case [F:ACL]TYPCTL2
 When 3
  [M]DEBUT2  = val([F:ACL]LSTVAL2(0))
  [M]FIN2    = val([F:ACL]LSTVAL2(1))
  [M]NBRVAL2 = 0
 When 4
  [M]REFTAB2 = [F:ACL]LSTVAL2(0)
  [M]NBRVAL2 = 0
Endcase
Case [F:ACL]TYPCTL3
 When 3
  [M]DEBUT3  = val([F:ACL]LSTVAL3(0))
  [M]FIN3    = val([F:ACL]LSTVAL3(1))
  [M]NBRVAL3 = 0
 When 4
  [M]REFTAB3 = [F:ACL]LSTVAL3(0)
  [M]NBRVAL3 = 0
Endcase
Gosub GRISE_OBL
Gosub GRISE
Gosub GRISE2
Gosub GRISE3
If    [F:ACL]TYPCTL  = 1 : Call GRISEDEP(1,[M]TYPCTL)
Elsif [F:ACL]TYPCTL2 = 1 : Call GRISEDEP(2,[M]TYPCTL2)
Elsif [F:ACL]TYPCTL3 = 1 : Call GRISEDEP(2,[M]TYPCTL3)
Endif
Return

$INICRE
$INIMOD
Case [M]TYPCTL
 When 3
  [F:ACL]LSTVAL(0) = num$([M]DEBUT)
  [F:ACL]LSTVAL(1) = num$([M]FIN)
 When 4
  [F:ACL]LSTVAL(0) = [M]REFTAB
Endcase
Case [M]TYPCTL2
 When 3
  [F:ACL]LSTVAL2(0) = num$([M]DEBUT2)
  [F:ACL]LSTVAL2(1) = num$([M]FIN2)
 When 4
  [F:ACL]LSTVAL2(0) = [M]REFTAB2
Endcase
Case [M]TYPCTL3
 When 3
  [F:ACL]LSTVAL3(0) = num$([M]DEBUT3)
  [F:ACL]LSTVAL3(1) = num$([M]FIN3)
 When 4
  [F:ACL]LSTVAL3(0) = [M]REFTAB3
Endcase
Return

$CREATION
$MODIF
Call MAJTEXTRA([M]DES,"ACTL","DES",[M]CTL,"") From ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="ACTL" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="ACTL" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ACTL"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ACTL  [ACL1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".ACTL"  [ACL1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ACTL  [ACL2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".ACTL"  [ACL2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACL1], [ACL2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [ACL2]
 Delete [ACL2] Where CTL=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTL" : Goto ROLL_TR_COP
 Endif
 For [ACL1]ACL0 Where CTL=TABLE
  [F:ACL2] = [F:ACL1]
  Call COPTEXTRA("ACTL","DES",TABLE,"") From ATEXTRA
  If dim([F:ACL2]UPDUSR)>0 : [F:ACL2]UPDUSR = GUSER : Endif
  If dim([F:ACL2]UPDDAT)>0 : [F:ACL2]UPDDAT = date$ : Endif
  Write [ACL2]
  If fstat
   GOK=0 : Call FSTA("ACL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog C_TYPCTL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 # Impossible, contrôle déjà existant
 If    [M:ACL2]TYPCTL2 = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Elsif [M:ACL3]TYPCTL3 = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Endif
 Call GRISEDEP(1,VALEUR)
Else
 Grizo [M:ACL1]DEPCTL
 Effzo [M:ACL1]DEPCTL
Endif
[M]TYPCTL = VALEUR : Gosub GRISE
End

Subprog C_TYPCTL2(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 # Impossible, contrôle déjà existant
 If    [M:ACL1]TYPCTL  = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Elsif [M:ACL3]TYPCTL3 = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Endif
 Call GRISEDEP(2,VALEUR)
Else
 Grizo [M:ACL2]DEPCTL2
 Effzo [M:ACL2]DEPCTL2
Endif
[M]TYPCTL2 = VALEUR : Gosub GRISE2
End

Subprog C_TYPCTL3(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 # Impossible, contrôle déjà existant
 If    [M:ACL1]TYPCTL   = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Elsif [M:ACL2]TYPCTL2  = 1 : GMESSAGE = mess(46,139,1) : mkstat = 2 : End
 Endif
 Call GRISEDEP(3,VALEUR)
Else
 Grizo [M:ACL3]DEPCTL3
 Effzo [M:ACL3]DEPCTL3
Endif
[M]TYPCTL3 = VALEUR : Gosub GRISE3
End

Subprog GRISEDEP(ONGLET,VALEUR)
Value Integer VALEUR
Value Integer ONGLET
Case ONGLET
 When 1  : # on est sur l'onglet 1
  Effzo [ACL2]DEPCTL2,DEPVAL2
  Effzo [ACL3]DEPCTL3,DEPVAL3
  Grizo [ACL2]DEPCTL2
  Grizo [ACL3]DEPCTL3
  If VALEUR <> 1
   Grizo [M:ACL1]DEPCTL : Effzo [M:ACL1]DEPCTL
   Grizo [M:ACL1]LSTVAL : Effzo [M:ACL1]LSTVAL
  Else
   Actzo [M:ACL1]DEPCTL
   Affzo [M:ACL1]DEPCTL
  Endif
 When 2 : # on est sur l'onglet 2
  Effzo [ACL1]DEPCTL,DEPVAL
  Effzo [ACL3]DEPCTL3,DEPVAL3
  Grizo [ACL1]DEPCTL
  Grizo [ACL3]DEPCTL3
  If VALEUR <> 1
   Grizo [M:ACL2]DEPCTL2 : Effzo [M:ACL2]DEPCTL2
   Grizo [M:ACL2]LSTVAL2 : Effzo [M:ACL2]LSTVAL2
  Else
   Actzo [M:ACL2]DEPCTL2
  Endif
 When 3 : # on est sur l'onglet 3
  Effzo [ACL1]DEPCTL,DEPVAL
  Effzo [ACL2]DEPCTL2,DEPVAL2
  Grizo [ACL1]DEPCTL
  Grizo [ACL2]DEPCTL2
  If VALEUR <> 1
   Grizo [M:ACL3]DEPCTL3 : Effzo [M:ACL3]DEPCTL3
   Grizo [M:ACL3]LSTVAL3 : Effzo [M:ACL3]LSTVAL3
  Else
   Actzo [M:ACL3]DEPCTL3
  Endif
Endcase
End

$GRISE_OBL
If [M]OBL<>2
 [M:ACL0]CTLOBL = ""
 Grizo [ACL0]CTLOBL
Else
 Actzo [ACL0]CTLOBL
Endif
Return

$GRISE
Case [M]TYPCTL
 When 1, 2
  Grizo [ACL1]DEBUT, FIN, REFTAB, ZREFTAB, FRM
  Effzo [ACL1]DEBUT, FIN, REFTAB, ZREFTAB, FRM
  Actzo [ACL1]NBRVAL, MSG
 When 3
  Grizo [ACL1]NBRVAL, REFTAB, ZREFTAB, FRM
  Effzo [ACL1]15, REFTAB, ZREFTAB, FRM
  Actzo [ACL1]DEBUT, FIN, MSG
 When 4
  Grizo [ACL1]NBRVAL, DEBUT, FIN, FRM
  Effzo [ACL1]15, DEBUT, FIN, FRM
  Actzo [ACL1]REFTAB, ZREFTAB, MSG
 When 5
  Grizo [ACL1]NBRVAL, DEBUT, FIN, REFTAB, ZREFTAB
  Effzo [ACL1]15, DEBUT, FIN, REFTAB, ZREFTAB
  Actzo [ACL1]FRM, MSG
 When 6
  Grizo [ACL1]NBRVAL, DEBUT, FIN, REFTAB, ZREFTAB, FRM, MSG
  Effzo [ACL1]15, DEBUT, FIN, REFTAB, ZREFTAB, FRM, MSG
Endcase
Return

$GRISE2
Case [M]TYPCTL2
 When 1, 2
  Grizo [ACL2]DEBUT2, FIN2, REFTAB2, ZREFTAB2, FRM2
  Effzo [ACL2]DEBUT2, FIN2, REFTAB2, ZREFTAB2, FRM2
  Actzo [ACL2]NBRVAL2, MSG2
 When 3
  Grizo [ACL2]NBRVAL2, REFTAB2, ZREFTAB2, FRM2
  Effzo [ACL2]15, REFTAB2, ZREFTAB2, FRM2
  Actzo [ACL2]DEBUT2, FIN2, MSG2
 When 4
  Grizo [ACL2]NBRVAL2, DEBUT2, FIN2, FRM2
  Effzo [ACL2]15, DEBUT2, FIN2, FRM2
  Actzo [ACL2]REFTAB2, ZREFTAB2, MSG2
 When 5
  Grizo [ACL2]NBRVAL2, DEBUT2, FIN2, REFTAB2, ZREFTAB2
  Effzo [ACL2]15, DEBUT2, FIN2, REFTAB2, ZREFTAB2
  Actzo [ACL2]FRM2, MSG2
 When 6
  Grizo [ACL2]NBRVAL2, DEBUT2, FIN2, REFTAB2, ZREFTAB2, FRM2, MSG2
  Effzo [ACL2]15, DEBUT2, FIN2, REFTAB2, ZREFTAB2, FRM2, MSG2
Endcase
Return

$GRISE3
Case [M]TYPCTL3
 When 1, 2
  Grizo [ACL3]DEBUT3, FIN3, REFTAB3, ZREFTAB3, FRM3
  Effzo [ACL3]DEBUT3, FIN3, REFTAB3, ZREFTAB3, FRM3
  Actzo [ACL3]NBRVAL3, MSG3
 When 3
  Grizo [ACL3]NBRVAL3, REFTAB3, ZREFTAB3, FRM3
  Effzo [ACL3]15, REFTAB3, ZREFTAB3, FRM3
  Actzo [ACL3]DEBUT3, FIN3, MSG3
 When 4
  Grizo [ACL3]NBRVAL3, DEBUT3, FIN3, FRM3
  Effzo [ACL3]15, DEBUT3, FIN3, FRM3
  Actzo [ACL3]REFTAB3, ZREFTAB3, MSG3
 When 5
  Grizo [ACL3]NBRVAL3, DEBUT3, FIN3, REFTAB3, ZREFTAB3
  Effzo [ACL3]15, DEBUT3, FIN3, REFTAB3, ZREFTAB3
  Actzo [ACL3]FRM3, MSG3
 When 6
  Grizo [ACL3]NBRVAL3, DEBUT3, FIN3, REFTAB3, ZREFTAB3, FRM3, MSG3
  Effzo [ACL3]15, DEBUT3, FIN3, REFTAB3, ZREFTAB3, FRM3, MSG3
Endcase
Return

Subprog AM_OBL(VALEUR)
Variable Integer  VALEUR
[M]OBL = VALEUR
Gosub GRISE_OBL
End

Subprog AS_NBRVAL
If !find([M]TYPCTL,1,2)
 Effzo 15
 mkstat = 1
Endif
End

