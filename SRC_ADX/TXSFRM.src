#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(250)(1..2) , VALEUR(250)
VALEUR = ""
PARAM(1) = "44..45 70(9) A1(DD) -MCI(C1)"
#PARAM(1) = "NM('AAB.AA10','CDC:ORGA.EEE1','S') GM('AD0','A*','ORGA.EEE1') L3:8(2) $ABC.VER(L1(2)) R(A/B)"
#PARAM(1) = '[IAS]"AAB.AA10"'
#PARAM(1) = '-MD"AAB.AA10" MP12'
PARAM(1) = 'GM("ADX","111","ACHAT","C*")'
Local File TXSA [TXS]
Read [TXS]TXS0 = "ZBY"
Call SAISIE_CHAR(VALEUR,PARAM,"TXSFRM","TXSFRM","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"    : Gosub DEBUT
Endcase
Return

$DEBUT
Local File TXSA [TXS]
Local Integer NBTEXTE
Local Char    TEXTE(250)(1..100)
Call TEXTE(toupper(PARAM(1)),NBTEXTE,TEXTE)
Raz [M]DES
[M]FORMULE = PARAM(1)
For I=1 To NBTEXTE
 TEXTE(I) += chr$(10)
Next I
If NBTEXTE
 Setlob [M]DES With TEXTE(1..NBTEXTE)
Endif
Affzo
Grizo
Return

Subprog TEXTE(FORMULE,NBTEX,TEXTE)
Value    Char    FORMULE
Variable Integer NBTEX
Variable Char    TEXTE()(1..)

Local Char    EXPRESSION(250) , CHAINE(250) , CAR(1) , CAR2(2) , TABLO(30)
Local Char    DEB(20) , FIN(20) , EXC(20)
Local Char    LIGINF(250) , LIGNE2(250) , LIGNE3(250)(1..12)
Local Integer NARG
Local Char    ARG(250)(1..12) , LIBARG(250)(1..12) , LIBVAR(50)
Local Integer TYPMNT , TYPSOL , MOINS , NBLIG
Local Integer L1 , L2
Local Integer I , J , K , ER , IAS , TYPSCT
Local Integer NBAXE
Local Char    AXE(GLONDIE)(1..9)
Local Char    DESIG(GLONAX3)

If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Read [FCY]FCY0 = GFCYDEF
Read [CPY]CPY0 = [F:FCY]LEGCPY
Read [GCM]GCM0 = [F:CPY]ACM
[M]CPY = [F:CPY]CPY

Gosub DEFVAR From SUBTXSB

ANALYSE = 1
LIGNE = vireblc(FORMULE,2)
NBTEX = 0
NBLIG = 0
CALCUL = 0
MAXCOL = 999
MAXLIG = 999
Gosub TRT_LIGNE From SUBTXSB
If ER
 NBTEX  = 1 : TEXTE(NBTEX) = mess(207,111,1)
 NBTEX += 1 : TEXTE(NBTEX) = ""
 NBTEX += 1 : TEXTE(NBTEX) = GMESSAGE
Elsif NBLIG>1
 Insa 1,2,NBTEX+2 TEXTE
 NBTEX += 2
 TEXTE(1) = mess(147,111,1) : # Somme des montants suivants:
 TEXTE(2) = ""
Endif
End

$CALCUL
Raz LIGINF,LIGNE2,LIGNE3
Case FONC
 When "C"                                    : Gosub TRT_CPT
 When "A"  , "B"                             : Gosub TRT_BIL
 When "H"  , "I"                             : Gosub TRT_COL
 When "NM" , "EM" , "PM" , "NQ", "EQ" , "PQ" : Gosub TRT_ANA
 When "GM" , "GQ"                            : Gosub TRT_BUD
 When "L"                                    : Gosub TRT_SOM
 When "R"                                    : Gosub TRT_EXP
 When "V"
  If dim([M:TXA3]VARNAM)>0
   K = find(ZONE,[M:TXA3]VARNAM(0..[M:TXA3]NBVAR-1))
   If K & [M:TXA3]VARDEF(K-1)<>""
    LIGNE = [M:TXA3]VARDEF(K-1)
    Gosub TRT_LIGNE From SUBTXSB
    Return
   Endif
  Elsif dim([M:TXM2]VARNAM)>0
   K = find(ZONE,[M:TXM2]VARNAM(0..[M:TXM2]NBVAR-1))
   If K & [M:TXM2]VARVAL(K-1)<>""
    LIGNE = [M:TXM2]VARVAL(K-1)
    Gosub TRT_LIGNE From SUBTXSB
    Return
   Endif
  Endif
  LIGINF = mess(183,111,1)-ZONE
  Call GETLIB(ZONE,LIBVAR)
  If LIBVAR<>"" : LIGINF -= "("+LIBVAR+")" : Endif
Endcase
If LIGINF<>""
 NBTEX += 1 : NBLIG += 1
 TEXTE(NBTEX) = num$(NBLIG)+")"-LIGINF
 If LIGNE2<>""
  NBTEX += 1
  TEXTE(NBTEX) = space$(20)+string$(left$(LIGNE2,1)<>"(","-")+" "+LIGNE2
  For I=1 To dim(LIGNE3)
   If LIGNE3(I)<>""
    NBTEX += 1
    TEXTE(NBTEX) = space$(20)+string$(left$(LIGNE3(I),1)<>"(","-")+" "+LIGNE3(I)
   Else
    Break
   Endif
  Next I
 Endif
Endif
Return

#########################################################################################
## Comptes
#########################################################################################
$TRT_CPT
If left$(ZONE,2)="V_"
 LIGINF  = mess(148,111,1) : # Soldes
 LIGINF -= mess(164,111,1)-ZONE : # contenu dans la variable
 Call GETLIB(ZONE,LIBVAR)
 If LIBVAR<>"" : LIGINF -= "("+LIBVAR+")" : Endif
 Return
Endif
Gosub DEB_CPT
Gosub SETREFGEN
CRITERE = 'COA="'+PLAN+'"'
If right$(CPT_FIN,len(CPT_FIN))=chr$(255)
 CPT_FIN = left$(CPT_FIN,len(CPT_FIN)-1)
Endif
If CPT_DEB=CPT_FIN
 LIGINF -= mess(152,111,1)-CPT_DEB : # des comptes de racine
 CRITERE -= "& left$(ACC,"+num$(len(CPT_DEB))+')="'+CPT_DEB+'"'
Else
 LIGINF -= mess(152,111,1)-mess(153,111,1)-CPT_DEB-mess(154,111,1)-CPT_FIN : # des comptes de racine de à
 CRITERE -= "& left$(ACC,"+num$(len(CPT_DEB))+')>="'+CPT_DEB+'" & left$(ACC,'+num$(len(CPT_FIN))+')<="'+CPT_FIN+'"'
Endif
If EXCLUS<>""
 LIGINF -= mess(155,111,1)-EXCLUS : # sauf la racine
 CRITERE -= '& left$(ACC,'+num$(len(EXCLUS))+')<>"'+EXCLUS+'"'
Endif
Filter [GAC] Where evalue(CRITERE)
Read [GAC]GAC0 First
If fstat<=2
 Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 LIGINF -= "("+mess(205,111,1)-PLAN-":"-[F:GAC]ACC-DESIG+")" : # Plan
Endif
Filter [GAC]
Return

$DEB_CPT
Gosub MOINS
Case ENGAGE
 When 0
  If DEBIT or CREDIT
   Case DEBIT
    When 1 : LIGINF -= mess(148,111,1)-mess(150,111,1) : # Soldes débiteurs
    When 2 : LIGINF -= mess(149,111,1)-mess(150,111,1) : # Montants débiteurs
   Endcase
   Case CREDIT
    When 1 : LIGINF -= mess(148,111,1)-mess(151,111,1) : # Soldes créditeurs
    When 2 : LIGINF -= mess(149,111,1)-mess(151,111,1) : # Montants créditeurs
   Endcase
  Elsif QTE
   LIGINF -= mess(219,111,1) : # Quantités
  Else
   LIGINF = mess(148,111,1) : # Soldes
  Endif
 When 1
  If QTE
   LIGINF -= mess(171,111,1) : # Quantités engagées
  Else
   LIGINF -= mess(170,111,1) : # Montants engagés
  Endif
 When 2
  If QTE
   LIGINF -= mess(173,111,1) : # Quantités pré-engagées
  Else
   LIGINF -= mess(172,111,1) : # Montants pré-engagés
  Endif
Endcase
Return

$TRT_BIL
If NUMBIL=0
 Goto TRT_PYR
Endif
Gosub SETREFGEN
Gosub DEB_CPT
LIGINF -= mess(159,111,1)-ARG(1)-mess(160,111,1)-num$(NUMBIL) : # des comptes ayant...comme code bilan numéro
Case FONC
 When "A" : LIGNE2 = "("+mess(157,111,1)+")" : # avec parcours des comptes individuels
 When "B" : LIGNE2 = "("+mess(158,111,1)+")" : # sans parcours des comptes individuels
Endcase
CRITERE = 'COA="'+PLAN+'"'
If CREDIT=2
 CRITERE -= '& RPTCODCDT('+num$(NUMBIL-1)+')="'+ARG(1)+'"'
Elsif DEBIT=2
 CRITERE -= '& RPTCODDEB('+num$(NUMBIL-1)+')="'+ARG(1)+'"'
Else
 CRITERE -= '& (RPTCODCDT('+num$(NUMBIL-1)+')="'+ARG(1)+'" or RPTCODDEB('+num$(NUMBIL-1)+')="'+ARG(1)+'")'
Endif
Filter [GAC] Where evalue(CRITERE)
Read [GAC]GAC0 First
If fstat<=2
 Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 LIGNE3(1) = "("+mess(192,111,1)-mess(205,111,1)-PLAN-":"-[F:GAC]ACC-DESIG+")" : # Plan
Endif
Filter [GAC]
Return

$TRT_COL
Gosub SETREFGEN
Gosub DEB_CPT
LIGINF -= mess(161,111,1)-ARG(1) : # des comptes du collectif
Read [GAC]GAC1 = PLAN;ARG(1)
If !fstat
 Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 LIGINF -= "("+mess(205,111,1)-PLAN-":"-DESIG+")" : # Plan
Endif
Case FONC
 When "I" : LIGINF -= "("+mess(162,111,1)+")" : # avec détail des comptes
 When "H" : LIGINF -= "("+mess(163,111,1)+")" : # sans détail des comptes
Endcase
Return

$TRT_PYR
Gosub DEB_CPT
Gosub SETREFGEN
LIGINF -= mess(209,111,1)-"("+mess(205,111,1)-PLAN+")" : # d'une pyramide...plan
K = instr(1,ARG(1),".")
Call PYRCPT(left$(ARG(1),K-1),right$(ARG(1),K+1),LIGNE2)
Return

###############################################################################
## Analytique
###############################################################################
$TRT_ANA
Gosub SETREFANA
FLAXE = 0
For I=1 To max(NBAXE+1,NARG)
 If left$(ARG(I),2)="V_"
  Call REPLACE(ARG(I),ARG(I))
 Endif
 If left$(ARG(I),2)="V_"
  LIBARG(I) = mess(164,111,1)-ARG(I) : # contenu dans la variable
  Call GETLIB(ARG(I),LIBVAR)
  If LIBVAR<>"" : LIBARG(I) -= "("+LIBVAR+")" : Endif
 Else
  K = instr(1,ARG(I),":")
  If K
   FLAXE   = 1
   IAXE(I) = left$(ARG(I),K-1)
   ARG(I)  = right$(ARG(I),K+1)
  Else
   IAXE(I) = ""
  Endif
  If ARG(I)="*" or ARG(I)=""
   If I=1
    LIBARG(I) = mess(190,111,1) : # Toutes natures
   Else
    LIBARG(I) = mess(191,111,1) : # Toutes sections
   Endif
  Elsif instr(1,ARG(I),"*") or instr(1,ARG(I),"?") or instr(1,ARG(I),"!") or instr(1,ARG(I),"#")
   LIBARG(I) = mess(165,111,1)-ARG(I) : # satisfaisant le modèle
  Elsif instr(1,ARG(I),"..")
   K = instr(1,ARG(I),"..")
   If I=1
    LIBARG(I) = mess(152,111,1)-mess(153,111,1)-left$(ARG(I),K-1)-mess(154,111,1)-right$(ARG(I),K+2) : # de..à
   Else
    LIBARG(I) = mess(227,111,1)-mess(153,111,1)-left$(ARG(I),K-1)-mess(154,111,1)-right$(ARG(I),K+2) : # de..à
   Endif
  Elsif instr(1,ARG(I),"(")
   K = instr(1,ARG(I),"(")
   If I=1
    LIBARG(I) = mess(152,111,1)-left$(ARG(I),K-1)-mess(155,111,1)-ctrans(ARG(I),"()","") : # sauf
   Else
    LIBARG(I) = mess(227,111,1)-left$(ARG(I),K-1)-mess(155,111,1)-ctrans(ARG(I),"()","") : # sauf
   Endif
  Else
   K = instr(1,ARG(I),".")
   If K
    If I=1
     Call PYRCPT(left$(ARG(I),K-1),right$(ARG(I),K+1),LIBARG(I))
    Else
     Call PYRANA(left$(ARG(I),K-1),right$(ARG(I),K+1),LIBARG(I))
    Endif
   Else
    LIBARG(I) = ARG(I)
   Endif
  Endif
 Endif
Next I

Read [GAC]GAC0 = PLAN;ARG(1)
If !fstat
 Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 LIBARG(1) -= "("+DESIG+")"
Endif
If FLAXE
 For I=2 To NARG
  Read [CCE]CCE0 = IAXE(I);ARG(I)
  If !fstat
   Call LECTEXTRA(DESIG,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
   LIBARG(I) -= "("+DESIG+")"
  Endif
  LIGNE3(I-1) = mess(179,111,1)-mess(206,111,1)-IAXE(I)-":"-LIBARG(I) : # sections...axe
 Next I
Else
 For I=2 To NBAXE+1
  Read [CCE]CCE0 = AXE(I-1);ARG(I)
  If !fstat
   Call LECTEXTRA(DESIG,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
   LIBARG(I) -= "("+DESIG+")"
  Endif
  LIGNE3(I-1) = mess(179,111,1)-mess(206,111,1)-AXE(I-1)-":"-LIBARG(I) : # sections...axe
 Next I
Endif

Case FONC
 When "NM" : LIGINF -= mess(168,111,1) : # Montants analytiques
 When "NQ" : LIGINF -= mess(169,111,1) : # Quantités analytiques
 When "EM" : LIGINF -= mess(170,111,1) : # Montants engagés
 When "EQ" : LIGINF -= mess(171,111,1) : # Quantités engagées
 When "PM" : LIGINF -= mess(172,111,1) : # Montants pré-engagés
 When "PQ" : LIGINF -= mess(173,111,1) : # Quantités pré-engagées
Endcase
LIGINF -= "("+mess(208,111,1)-mess(NUMREF,2644,1)+")" : # Référentiel
LIGNE2 = mess(178,111,1)-mess(205,111,1)-PLAN-":"-LIBARG(1) : # natures...plan
Return

###############################################################################
## Budgets
###############################################################################
$TRT_BUD
Gosub SETREFANA
If left$(ARG(1),2)="V_"
 Call REPLACE(ARG(1),ARG(1))
Endif
Read [BUP]BUP0 = ARG(1)
If !fstat
 PLAN   = [F:BUP]COA
 For I=1 To [F:BUP]DIENBR
  If [F:BUP]DIE(I-1)<>""
   AXE(I) = [F:BUP]DIE(I-1)
  Else
   AXE(I) = ""
  Endif
 Next
Else
 Raz PLAN,AXE
Endif

If left$(ARG(2),2)="V_"
 Call REPLACE(ARG(2),ARG(2))
Endif

For I=3 To 12
 If left$(ARG(I),2)="V_"
  Call REPLACE(ARG(I),ARG(I))
 Endif
 If left$(ARG(I),2)="V_"
  LIBARG(I) = mess(164,111,1)-ARG(I) : # contenu dans la variable
  Call GETLIB(ARG(I),LIBVAR)
  If LIBVAR<>"" : LIBARG(I) -= "("+LIBVAR+")" : Endif
 Else
  If ARG(I)="*" or ARG(I)=""
   If I=3
    LIBARG(I) = mess(190,111,1) : # Toutes natures
   Else
    LIBARG(I) = mess(191,111,1) : # Toutes sections
   Endif
  Elsif instr(1,ARG(I),"*") or instr(1,ARG(I),"?") or instr(1,ARG(I),"!") or instr(1,ARG(I),"#")
   LIBARG(I) = mess(165,111,1)-ARG(I) : # satisfaisant le modèle
  Elsif instr(1,ARG(I),"..")
   K = instr(1,ARG(I),"..")
   If I=3
    LIBARG(I) = mess(152,111,1)-mess(153,111,1)-left$(ARG(I),K-1)-mess(154,111,1)-right$(ARG(I),K+2) : # de..à
   Else
    LIBARG(I) = mess(227,111,1)-mess(153,111,1)-left$(ARG(I),K-1)-mess(154,111,1)-right$(ARG(I),K+2) : # de..à
   Endif
  Elsif instr(1,ARG(I),"(")
   K = instr(1,ARG(I),"(")
   If I=3
    LIBARG(I) = mess(152,111,1)-left$(ARG(I),K-1)-mess(155,111,1)-ctrans(ARG(I),"()","") : # sauf
   Else
    LIBARG(I) = mess(227,111,1)-left$(ARG(I),K-1)-mess(155,111,1)-ctrans(ARG(I),"()","") : # sauf
   Endif
  Else
   K = instr(1,ARG(I),".")
   If K
    If I=3
     Call PYRCPT(left$(ARG(I),K-1),right$(ARG(I),K+1),LIBARG(I))
    Else
     Call PYRANA(left$(ARG(I),K-1),right$(ARG(I),K+1),LIBARG(I))
    Endif
   Else
    LIBARG(I) = ARG(I)
    Case I
     When 3
      If PLAN<>""
       Read [GAC]GAC0 = PLAN;ARG(I)
       If !fstat
        Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        LIBARG(I) -= "("+DESIG+")"
       Endif
      Endif
     When Default
      If AXE(I-3)<>""
       Read [CCE]CCE0 = AXE(I-3);ARG(I)
       If !fstat
        Call LECTEXTRA(DESIG,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
        LIBARG(I) -= "("+DESIG+")"
       Endif
      Endif
    Endcase
   Endif
  Endif
 Endif
Next I
Case FONC
 When "GM" : LIGINF -= mess(174,111,1) : # Montants budgétés
 When "GQ" : LIGINF -= mess(175,111,1) : # Quantités budgétées"
Endcase

LIGINF -= mess(176,111,1)-ARG(1)-mess(194,111,1)-ARG(2) : # sur le budget... version
LIGNE2 = mess(178,111,1)-mess(205,111,1)-PLAN-":"-LIBARG(3) : # natures...plan
For I=4 To 12
 If AXE(I-3)<>""
  LIGNE3(I-3) = mess(179,111,1)-mess(206,111,1)-AXE(I-3)-":"-LIBARG(I) : # sections...axe
 Endif
Next I
Return

###############################################################################
## Sous-pros
###############################################################################
$SETREFGEN
If NUMREF=0
 NUMREF = [F:TXS]GENLEDTYP
 If NUMREF=0 : NUMREF = 1 : Endif
Endif
Gosub SETREF
Return

$SETREFANA
If NUMREF=0
 NUMREF = [F:TXS]ANALEDTYP
 If NUMREF=0 : NUMREF = 2 : Endif
Endif
Gosub SETREF
Return

$SETREF
Read [LED]LED0 = [F:GCM]LED(NUMREF-1)
PLAN = [F:LED]COA
NBAXE = [F:LED]DIENBR
For I=1 To NBAXE
 AXE(I) = [F:LED]DIE(I-1)
Next I
Return

$MOINS
If SIGN<0
 LIGINF -= "("+mess(156,111,1)+")" : # en moins
Endif
Return

###############################################################################
## Libellés pyramides
###############################################################################
Subprog PYRCPT(PYRAM,GROUPE,LIBEL)
Value    Char PYRAM
Value    Char GROUPE
Variable Char LIBEL()
Local Integer K
Local Char    DESIG(GLONAX3)
LIBEL = mess(166,111,1) : # pyramide
If left$(PYRAM,2)="V_"
 Call REPLACE(PYRAM,PYRAM)
Endif
If left$(PYRAM,2)="V_"
 LIBEL -= mess(164,111,1)-PYRAM : # contenu dans la variable
 Call GETLIB(PYRAM,LIBVAR)
 If LIBVAR<>"" : LIBEL -= "("+LIBVAR+")" : Endif
Else
 LIBEL -= PYRAM
 Read [GYM]GYM0 = PYRAM
 If !fstat
  Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
  LIBEL -= "("+DESIG+")"
 Endif
Endif
LIBEL -= ","-mess(167,111,1) : # groupe
If left$(GROUPE,2)="V_"
 Call REPLACE(GROUPE,GROUPE)
Endif
If left$(GROUPE,2)="V_"
 LIBEL -= mess(164,111,1)-GROUPE : # contenu dans la variable
 Call GETLIB(GROUPE,LIBVAR)
 If LIBVAR<>"" : LIBEL -= "("+LIBVAR+")" : Endif
Else
 LIBEL -= GROUPE
 Read [GRY]GRY0(2) = PYRAM;GROUPE
 If !fstat
  Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
  LIBEL -= "("+DESIG+")"
 Endif
Endif
End

Subprog PYRANA(PYRAM,GROUPE,LIBEL)
Value    Char PYRAM
Value    Char GROUPE
Variable Char LIBEL()
Local Integer K
Local Char    DESIG(GLONAX3)
LIBEL = mess(166,111,1) : # pyramide
If left$(PYRAM,2)="V_"
 Call REPLACE(PYRAM,PYRAM)
Endif
If left$(PYRAM,2)="V_"
 LIBEL -= mess(164,111,1)-PYRAM : # contenu dans la variable
 Call GETLIB(PYRAM,LIBVAR)
 If LIBVAR<>"" : LIBEL -= "("+LIBVAR+")" : Endif
Else
 LIBEL -= PYRAM
 Read [CYM]CYM0 = PYRAM
 If !fstat
  Call LECTEXTRA(DESIG,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
  LIBEL -= "("+DESIG+")"
 Endif
Endif
LIBEL -= ","-mess(167,111,1) : # groupe
If left$(GROUPE,2)="V_"
 Call REPLACE(GROUPE,GROUPE)
Endif
If left$(GROUPE,2)="V_"
 LIBEL -= mess(164,111,1)-GROUPE : # contenu dans la variable
 Call GETLIB(GROUPE,LIBVAR)
 If LIBVAR<>"" : LIBEL -= "("+LIBVAR+")" : Endif
Else
 LIBEL -= GROUPE
 Read [CRY]CRY0(2) = PYRAM;GROUPE
 If !fstat
  Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
  LIBEL -= "("+DESIG+")"
 Endif
Endif
End

###############################################################################
## Libellé variable
###############################################################################
Subprog GETLIB(VARIA,LIBEL)
Value    Char VARIA
Variable Char LIBEL()
Local Integer K
If dim([M:TXM2]VARNAM)>0
 K = find(VARIA,[M:TXM2]VARNAM(0..[M:TXM2]NBVAR-1))
 If K & [M:TXM2]VARDES(K-1)<>""
  LIBEL = [M:TXM2]VARDES(K-1)
 Endif
Elsif dim([M:TXA3]VARNAM)>0
 K = find(VARIA,[M:TXA3]VARNAM(0..[M:TXA3]NBVAR-1))
 If K & [M:TXA3]VARDES(K-1)<>""
  LIBEL = [M:TXA3]VARDES(K-1)
 Endif
Endif
End

Subprog REPLACE(VARIA,VALEUR)
Value    Char VARIA
Variable Char VALEUR
Local Integer K
VALEUR = VARIA
If dim([M:TXM2]VARNAM)>0
 K = find(VARIA,[M:TXM2]VARNAM)
 If K & [M:TXM2]VARVAL(K-1)<>""
  VALEUR = [M:TXM2]VARVAL(K-1)
  End
 Endif
Endif
If dim([M:TXA3]VARNAM)>0
 K = find(VARIA,[M:TXA3]VARNAM)
 If K & [M:TXA3]VARDEF(K-1)<>""
  VALEUR = [M:TXA3]VARDEF(K-1)
  End
 Endif
Endif
End

###############################################################################
## Autres
###############################################################################
$TRT_SOM
If LIGDEB=LIGFIN
 If NOCOL=0
  LIGINF -= mess(185,111,1)-num$(LIGDEB)-mess(188,111,1)
 Else
  LIGINF -= mess(185,111,1)-num$(LIGDEB)-mess(187,111,1)-num$(NOCOL)
  # Montant de la ligne...colonne
 Endif
 If AUTTAB=""
  If dim([M:TXA2]FRM0)>0
   LIGNE2 = "("+[M:TXA2]FRM0(LIGDEB-1)+")"
  Elsif dim([M:TXM1]INTIT)>0
   LIGNE2 = "("+[M:TXM1]INTIT(LIGDEB-1)+")"
  Endif
 Endif
Else
 If NOCOL=0
  LIGINF -= mess(186,111,1)-num$(LIGDEB)-mess(154,111,1)-num$(LIGFIN)-","-mess(188,111,1)
  # Somme des lignes...à...colonne courante
 Else
  LIGINF -= mess(186,111,1)-num$(LIGDEB)-mess(154,111,1)-num$(LIGFIN)-","-mess(187,111,1)-num$(NOCOL)
  # Somme des lignes...à...colonne
 Endif
 If AUTTAB=""
  If dim([M:TXA2]FRM0)>0
   LIGNE2 = "("+[M:TXA2]FRM0(LIGDEB-1)-"=>"-[M:TXA2]FRM0(LIGFIN-1)+")"
  Elsif dim([M:TXM1]INTIT)>0
   LIGNE2 = "("+[M:TXM1]INTIT(LIGDEB-1)-"=>"-[M:TXM1]INTIT(LIGFIN-1)+")"
  Endif
 Endif
Endif
If AUTTAB<>""
 If left$(AUTTAB,2)="V_"
  Call REPLACE(AUTTAB,AUTTAB)
 Endif
 LIGINF -= mess(193,111,1)-AUTTAB
Endif
If AUTVER<>""
 If left$(AUTVER,2)="V_"
  Call REPLACE(AUTVER,AUTVER)
 Endif
 LIGINF -= mess(194,111,1)-AUTVER
Endif
Return

$TRT_EXP
LIGINF = mess(189,111,1)-ZONE : # Calcul de l'expression
Return

