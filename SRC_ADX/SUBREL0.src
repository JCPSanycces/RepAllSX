Raz GBIDC1, GBIDC2
# GTEST=99
Call OBJET("REL",GBIDC1,GBIDC2) From GOBJET
End

#################################################################
# Etiquette masque RELEVE
#################################################################

$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
   When "SELNUM" : Gosub SEL_NUM
  Endcase
 When "VERF_TABLE"
  Case TABLE
   When "SELNUM" : Gosub V_SEL_NUM
  Endcase
 When "FIN_TABLE"
  Case TABLE
   When "SELNUM" : Gosub F_SEL_NUM
  Endcase
Endcase
Return

Subprog AP_SOINUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=4 : Endif
End

Subprog AM_SOINUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Look [SOI]SOI0 = VALEUR
 If fstat : VALEUR = "" : Endif
Endif
End

Subprog AM_BPR(VALEUR)
Variable Char     VALEUR
Raz [M:REL0]SAC : Raz [M:REL0]FCY : Raz [M:REL0]CPY : Raz [M:REL0]CUR
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR
Call PARAM(VALEUR,"SOICPT",GDIV(0)) From ADOVAL  :# Comptabilisation relevé
Call PARAM(VALEUR,"SOISAC",GDIV(1)) From ADOVAL  :# Relevé mono-colectif
Call PARAM(VALEUR,"SOIFCY",GDIV(2)) From ADOVAL  :# Relevé mono-site
Call PARAM(VALEUR,"SOIBPR",GDIV(3)) From ADOVAL  :# Tiers du relevé
Call SETMAINREF(VALEUR,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(VALEUR,GTYPGEN,[M]COA) From CPTDIV
GSOCIETE = VALEUR
GCURLEG  = [F:CPY]LEG
End

Subprog C_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 ## Site obligatoire dans les cas suivants
 ##   - Comptabilisation relevé
 ##   - Pas de comptabilisation et relevé mono-site
 If GDIV(0)="2"
  mkstat=1
 Else
  If GDIV(2)="1"
   mkstat=1
  Endif
 Endif
Else  :# Le site doit appartenir à la société saisie préalablement
 Call CONTFCYCPY(VALEUR,[M]CPY) From CPTSUB
 Call GETSOC(VALEUR) From DEVSUB
 Call CONTFCY(VALEUR) From CPTSUB
Endif
End

Subprog D_SAC(VALEUR)
Variable Char     VALEUR
Local Char CODCPT(GLONCAC)
Call LECTURE("BPR",[M]BPR,"") From CONTOBJ          :# Tiers
If [F:BPR]BPCFLG=2
 Call LECTURE("BPC",[M]BPR,"") From CONTOBJ         :# Client
 Call INIT_COMPTE([M]BPR,[M]CPY,"C",CODCPT) From CPTSUB
 If [L]CODCPT<>"" & [F:BPC]BPCSTA=2
  Call LECTURE("CAC",[L]CODCPT,"2~"+[M]COA) From CONTOBJ
 Endif
Elsif [F:BPR]BPSFLG=2
 Call LECTURE("BPS",[M]BPR,"") From CONTOBJ         :# Fournisseur
 Call INIT_COMPTE([M]BPR,[M]CPY,"F",CODCPT) From CPTSUB
 If [L]CODCPT<>"" & [F:BPS]ENAFLG=2
  Call LECTURE("CAC",[L]CODCPT,"3~"+[M]COA) From CONTOBJ :# Code comptable
 Endif
Else
 End
Endif
Call LECTURE("GAC",[F:CAC]ACC(0),[M]COA) From CONTOBJ   :# Compte
VALEUR=[F:GAC]ACCSHO
[M:REL0]SACACC=[F:GAC]ACC : Affzo [M:REL0]SACACC
End

Subprog C_SAC(VALEUR)
Variable Char     VALEUR()
Raz [F:GAC]
If VALEUR=""
 ## Collectif obligatoire dans les cas suivants
 ##   - Comptabilisation relevé
 ##   - Pas de comptabilisation et relevé mono-collectif
 If GDIV(0)="2"
  mkstat=1 : End
 Else
  If GDIV(1)="1"
   mkstat=1 : End
  Endif
 Endif
Else
 Local Integer OK
 Call LECTURE("BPR",[M]BPR,"") From CONTOBJ          :# Tiers
 Read [GAC]GAC1 = [M]COA;VALEUR
 If fstat : Raz [F:GAC] : Endif
 OK  = [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
 OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
 If !OK
  GMESSAGE = mess(45,106,1) : # Tiers incompatible avec le collectif
  mkstat = 2 : End
 Endif
Endif

# JML 09/09/99, pour rester compatible avec version<120, ou si saisie manuelle
#               De quel type (Cli/Fou) est le relevé ?
If find(GREP,"C","D") | [M]BPRTYP=0
 Local Libelle BPR_TYP : BPR_TYP = [M]BPRTYP
 Call CLIFOU([M]BPR,[M]COA,[F:GAC]ACC,2,BPR_TYP) From PAYDIV
 [M]BPRTYP = BPR_TYP
 Affzo TYPBPR :
Endif
End

Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()
Read [GAC]GAC1 = [M]COA;VALEUR
If !fstat
 [M:REL0]SACACC=[F:GAC]ACC
Else
 Raz [M:REL0]SACACC
Endif
End

Subprog D_CUR(VALEUR)
Variable Char     VALEUR
If [M]BPRTYP=1
 Call LECTURE("BPC",[M:REL0]BPR,"") From CONTOBJ
 VALEUR = [F:BPC]CUR
Else
 Call LECTURE("BPS",[M:REL0]BPR,"") From CONTOBJ
 VALEUR = [F:BPS]CUR
Endif
End

Subprog IB_DUDNBR
Local Integer NOL
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
NOL = nolign-1
Look [HAE]HAE0 = [M]TYP(NOL);[M]NUM(NOL)
If !fstat : GBOUT1 = mess(145,117,1) : Endif    # Pièce comptable
Read [SIH]SIH2 = [M]TYP(NOL);[M]NUM(NOL)
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : GBOUT2 = mess(43,109,1)    # Facture Tiers Client
  When 5 : GBOUT3 = mess(45,109,1)    # Facture Vente
 Endcase
Else
 Read [PIH]PIH2 = [M]TYP(NOL);[M]NUM(NOL)
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : GBOUT4 = mess(44,109,1)    # Facture Tiers fournisseur
   When 6 : GBOUT5 = mess(46,109,1)    # Facture Achat
  Endcase
 Endif
Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
## Reprise de la pièce de la ligne précédente
If VALEUR=""
 If nolign>1
  VALEUR=[M:REL0]TYP(nolign-2)
  [M:REL0]TYP(nolign-1)=[M:REL0]TYP(nolign-2)
  Affzo [REL0]TYP(nolign-1)
 Else
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
## Reprise de la pièce de la ligne précédente
If VALEUR=""
 If nolign>1 & [M:REL0]TYP(nolign-1)=[M:REL0]TYP(nolign-2)
  VALEUR=[M:REL0]NUM(nolign-2)
  [M:REL0]NUM(nolign-1)=VALEUR
  Affzo NUM(nolign-1)
 Else
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 1 : End
 Endif
Endif
Gosub SETNOL
# Vérif d'existence
Call LECTURE("GAS",VALEUR,[M:REL0]TYP(NOL)) From CONTOBJ
If fstat
 GMESSAGE=mess(28,107,1) : mkstat=1 : End   :# Pièce inexistante
Elsif [F:HAE]FLGREP=2 : # GH 07/12/99
 GMESSAGE = mess(20,121,1) : mkstat=2 : End   :# Pièce de fin d'exercice
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# Vérifier que l'échéance n'est pas en cours de lettrage pour ne pas la régler une 2eme fois
If [M]ACCNUM(NOL)<>0
 Filter [MTB] Where ACCNUM=[M]ACCNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  GMESSAGE=mess(70,119,1) : mkstat=2    :# Echéance en cours de lettrage
 Endif
Endif
End


#################################################################
###########    Sélection d'une échéance de la pièce
#################################################################
## Action SELECH
##
$SELECH
Case ACTSELECH
 When "DEBUT"
  Local Integer FINFIN
  If VALEUR=[M]NUM(nolign-1) & [M]TYP(nolign-1)=[M]OTYP(nolign-1)
   FIN = 1 : FINFIN = 1 : Return
  Endif
  If [M]ACCNUM(nolign-1)<>0
   FIN = 1 : FINFIN = 1 : Return
  Endif
  Gosub SETNOL
  Gosub CRIT_ECHE
  Local Integer XACC,XLIG,OK
  XACC = [M:REL0]ACCNUM(NOL)
  XLIG = [M:REL0]DUDLIG(NOL)
  Filter [F:DUD2] Where TYP=[M:REL0]TYP(NOL) & NUM=VALEUR & evalue(CRITECH)
 When "FIN"
  If !FINFIN
   NOL = nolign-1
   Filter [F:DUD2]
   Case val(PARAM(3))
    When -1
     mkstat = 2
    When 0
     GERR = 2 : GMESSAGE = mess(66,117,1) : mkstat=2 : # Aucune échéance à proposer
    When Default
     Read [DUD]DUD1 = val(PARAM(1));val(PARAM(2))
   Endcase
   If mkstat : Return : Endif
   Gosub VERIF_ECHE
   If mkstat : GERR = 1 : Return : Endif
   [L]OK = ([L]XACC<>[M:REL0]ACCNUM(NOL) or [L]XLIG<>[M:REL0]DUDLIG(NOL))
   Gosub CHARG_ECHE
   Affzo [REL0]RMT, RMTREG
   If [L]OK : mkstat=4 : Endif : # on a changé d'échéance
  Endif
Endcase
Return

$SEL_NUM
If !find(GREP,"C","D") & !instr(1,GCHAINE,"M")
 # Si on ne peut pas modifier le relevé, on ne peut pas changer d'échéance
 OK = 0 : Return
Endif
Gosub SETNOL
Gosub CRIT_ECHE
Filter [DUD] Where evalue(CRITECH) & TYP=[M:REL0]TYP(NOL)
Local Char TIERS(GLONBPR) , SITE(GLONFCY)
TIERS = [M:REL0]BPR : SITE = [M:REL0]FCY
Gosub SEL_DUD From SELDUD1
Return

$V_SEL_NUM
NOL = nolign-1
If [F:DUD]NUM<>""
 # lecture, car on a besoin de champs qui ne sont pas présents dans la boite de sélection
 Read [DUD]DUD1 = [F:DUD]ACCNUM;[F:DUD]DUDLIG
 Gosub VERIF_ECHE
 If mkstat : GERR = 1 : Return : Endif
 Gosub CHARG_ECHE
 Affzo [M:REL0]
Endif
Return

$F_SEL_NUM
Filter [DUD]
Return

#################################################################

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

$CRIT_ECHE
Local Char    CRITECH(255)
Case GDIV(3)
 When "2" : CRITECH="BPR='"+[M:REL0]BPR+"'"  :# Tiers facturé
 When Default : CRITECH="BPRPAY='"+[M:REL0]BPR+"'"  :# Tiers payeur
Endcase
If [M:REL0]SAC<>""
 CRITECH -= "& SAC='"+[M:REL0]SAC+"'"
Endif
If [M:REL0]FCY<>""
 CRITECH -= "& FCY='"+[M:REL0]FCY+"'"
Else
 CRITECH -= "& CPY='"+[M:REL0]CPY+"'"
Endif
If [M:REL0]SOINUM=""
 CRITECH -= "& SOINUM=''"
Else
 CRITECH -= "& (SOINUM='' | SOINUM='"+[M:REL0]SOINUM+"')"
Endif
CRITECH -= "& SOI=2 & DUDSTA=2"
CRITECH -= "& CUR='"+[M:REL0]CUR+"'"
Return

$VERIF_ECHE
For I = 0 To [M:REL0]DUDNBR-1
 If [M:REL0]ACCNUM(I)=[F:DUD]ACCNUM & [M:REL0]DUDLIG(I)=[F:DUD]DUDLIG & NOL<>I
  # Echéance déjà saisie en ligne
  GMESSAGE=mess(46,117,1)-num$(I+1)
  mkstat=1 : Break
 Endif
Next
If mkstat : Return : Endif
If [F:DUD]FLGCLE=2 or [F:DUD]FLGCLE=4
 # Echéance déjà soldée
 Call AVERTIR(mess(15,117,1),[L]OK) From GESECRAN
 If [L]OK=1 : mkstat=1 : Endif
Endif
Return

$CHARG_ECHE
## Lecture de la pièce
Read [HAE]HAE0=[F:DUD]TYP;[F:DUD]NUM
## Chargement de l'échéance
[M:REL0]ACCDAT(NOL)    = [F:HAE]ACCDAT
[M:REL0]LIGDUDDAT(NOL) = [F:DUD]DUDDAT
[M:REL0]LIGPAM(NOL)    = [F:DUD]PAM
[M:REL0]LIGAMT(NOL)    = [F:DUD]AMTCUR*[F:DUD]SNS
[M:REL0]LIGPAY(NOL)    = ([F:DUD]PAYCUR + [F:DUD]TMPCUR)*[F:DUD]SNS
[M:REL0]TYP(NOL)       = [F:DUD]TYP
[M:REL0]OTYP(NOL)      = [M:REL0]TYP(NOL)
[M:REL0]NUM(NOL)       = [F:DUD]NUM
[M:REL0]LIG(NOL)       = [F:DUD]LIG
[M:REL0]DUDLIG(NOL)    = [F:DUD]DUDLIG
[M:REL0]ACCNUM(NOL)    = [F:DUD]ACCNUM
[M:REL0]SNS(NOL)       = [F:DUD]SNS
[M:REL0]DUDFCY(NOL)    = [F:DUD]FCY
If GDIV(0)="2"  :# Comptabilisation des relevés
 Filter [F:SOI2] Where TYPSOI=[F:DUD]TYP & NUMSOI=[F:DUD]NUM & FLGFWD=2
&                Order By Key CLE=TYPSOI;NUMSOI
 Read [SOI2]CLE First
 If fstat=0
  # Plutôt que 0/1 je prends désormais le No de relevé, plus facile à gérer pour les reports automatique si SOICPT=2
  [M:REL0]SOIDUD(NOL) = [F:SOI2]SOINUM
 Endif
 Filter [F:SOI2]
Endif
Return

Subprog C_SOIDAT(VALEUR)
Variable Date    VALEUR
Call CONTDEV([M]CUR,VALEUR) From TRTDEV
#->KC: dates par modules
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,[M]CPY) From CPTSUB
 If mkstat : End : Endif
Endif
#<-KC
End

