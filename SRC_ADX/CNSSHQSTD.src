#<AdxTL>@(#)2.0.0.0 $Revision$ Consultation STL
#########################################################################
# CNSSHQSTD : Consultation Fiche qualité                   HN  15/06/04 #
# ECRAN 1   : CONSSHQ1                                                  #
# ECRAN 2   : CONSSHQ2                                                  #
# ECRAN CRIT: CRITSHQ                                                   #
#########################################################################
Local Char PARAM(20)(1..9)
PARAM(1) = "0"
PARAM(2) = "012"
PARAM(3) = "A-HN140"
PARAM(4) = "QUA012040002795"
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
PARAM(9) = ""
Call GCONSULT("SHQ","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Raz [M:CSHQ]:Transmask [M:SHQ1] To [M:CSHQ] #[M:CSHQ] = [M:SHQ1]  # Issue 25606_Transmak
  When "FIN_CRIT"   : [M:SHQ1] = [M:CSHQ]
  When "AV_MAGNETO" : Gosub AV_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:QLH1])= 0  : Local File STOQLYH     [QLH1] : Endif
If clalev([F:QLD1])= 0  : Local File STOQLYD     [QLD1] : Endif
If clalev([F:QLA1])= 0  : Local File QLYCRDASW   [QLA1] : Endif
If clalev([F:ITF]) = 0  : Local File ITMFACILIT  [ITF]  : Endif     # hcb V6CQ
If clalev([F:QLC1])= 0  : Local File QLYCRD      [QLC1] : Endif     # hcb V6CQ

#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Local Char    WFIRDEM(20)
Local Integer WFIRLIN
Local Decimal WFIRSEQ
#
Local Char    WLASDEM(20)
Local Integer WLASLIN
Local Decimal WLASSEQ
#
Local Char    WCURDEM(20), WQLYCRD(10)
Local Integer WCURLIN
Local Decimal WCURSEQ
Gosub DEFCRIT

NAVIG="CONSSHQ"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FERME
If clalev([F:QLA]) <> 0 : Filter [QLA] : Endif
If dim(WGCONSULT) > 0   : GCONSULT = WGCONSULT : Endif
Return
#############################################################
$DEFCRIT
Local Integer I
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
#          [M:SHQ1]STOFCY = [F:FCY]FCY   # hcb V6CQ
        Endif
        [M:SHQ1]STOFCY = [F:FCY]FCY      # hcb V6CQ
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SHQ1]       = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        If [F:QLH1]VCRNUM<>PARAM(I)  Read [QLH1]QLH0=28;PARAM(I)
                                    If fstat  Raz [F:QLH1], PARAM(I) : Endif
        Endif
        [M:SHQ1]DEMSEL   = [F:QLH1]VCRNUM
        If [F:QLH1]VALFLG=2
          [M:SHQ1]VALFLGO=2
          [M:SHQ1]VALFLGN=1
        Else
          [M:SHQ1]VALFLGN=2
          [M:SHQ1]VALFLGO=1
        Endif
#        If dim([M]QLYCRD)>0             # hcb V6CQ
#          [M]QLYCRD=[F:QLH1]QLYCRD      # hcb V6CQ
#        Endif                           # hcb V6CQ
      Endif
    When 5 :
      If val(PARAM(I)) <> 0
        [M:SHQ1]VCRTYPSEL = val(PARAM(I))
      Else
        [M:SHQ1]VCRTYPSEL = 19
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:SHQ1]VCRNUMSEL = PARAM(I)
      Endif
    When 7 :
      If val(PARAM(I)) <> 0
        [M:SHQ1]VCRLINSEL = val(PARAM(I))
      Endif
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
    When 9 :                                     # hcb V6CQ
      If PARAM(I) <> ""
        [M:SHQ1]QLYCRDSEL = PARAM(I)
      Endif

  Endcase
Next I
# validé oui
If !find([M:SHQ1]VALFLGO,1,2) : [M:SHQ1]VALFLGO=1 : Endif
# validé non
If !find([M:SHQ1]VALFLGN,1,2) : [M:SHQ1]VALFLGN=2 : Endif

Raz [M:SHQ1]WSMPTYP                                                      # hcb V6CQ
If [M:SHQ1]ITMREF <> [F:ITF]ITMREF | [M:SHQ1]STOFCY <> [F:ITF]STOFCY     # hcb V6CQ
   Read [F:ITF]ITF0 = [M:SHQ1]ITMREF;[M:SHQ1]STOFCY                      # hcb V6CQ
   If fstat                                                              # hcb V6CQ
      Raz [F:ITF]                                                        # hcb V6CQ
   Endif                                                                 # hcb V6CQ
Endif                                                                    # hcb V6CQ
If [F:ITF]SMPTYP > 1                                                     # hcb V6CQ
   [M:SHQ1]WSMPTYP = mess(84,187,1) + " : " + mess([F:ITF]SMPMOD,2756,1) # hcb V6CQ
Endif                                                                    # hcb V6CQ


# -- copie de l'écran critères  vers le masque 1
Gosub CRITENT From =PROGCNS

Return
############################################################
$LECTURE
NBLU   = 2
If [M:SHQ1]ITMREF = ""
  NBLU = 0
  Return
Endif
Case CHGPAG
  When 1 :
    Gosub TRT_FILTER
    If NBLU <> 0
      nolign = 1
      WINCR  = 1
      Gosub LOA_PAGE
    Endif
  When 2 :
    Gosub LEC_SUI
    If NBLU <> 0
      nolign = 1
      WINCR  = 1
      Gosub LOA_PAGE
    Endif
  When -1 :
    Read [LNK]LNK0(3) Last
    If fstat = 0
      nolign = MAXLIG
      WINCR  = -1
      Gosub LOA_PAGE
    Endif
  When -2 :
    Gosub LEC_PRE
    If NBLU <> 0
      nolign = MAXLIG
      WINCR  =  -1
      Gosub LOA_PAGE
    Endif
Endcase
If [F:QLA]QLYCTLDEM = WFIRDEM &
&  [F:QLA]VCRLIN    = WFIRLIN &
&  [F:QLA]CRDSEQ    = WFIRSEQ
  RETOUR = 1
Else
  RETOUR = 0
Endif

If [F:QLA]QLYCTLDEM = WLASDEM &
&  [F:QLA]VCRLIN    = WLASLIN &
&  [F:QLA]CRDSEQ    = WLASSEQ
  SUITE = 1
Else
  SUITE = 0
Endif
Return
############################################################
$TRT_FILTER
Raz [M:SHQ2]
If [M]DEMSEL<>""
    If [F:QLH1]VCRNUM<>[M]DEMSEL
        Read [QLH1]QLH0=28;PARAM(I)
        If fstat  Raz [F:QLH1] : Endif
    Endif
#    If WQLYCRD=[F:QLH1]QLYCRD  Endif    # hcb V6CQ
Endif
Gosub LOAD_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [QLA] With [QLH1]QLH0=28;[QLA]QLYCTLDEM,[QLD1]QLD0=28;[QLA]QLYCTLDEM;[QLA]VCRLIN
&          As [LNK]
&          Where evalue(WFIL)  &
&                evalue(WFILS) &
&                evalue(WFILSPE)
&          Order By Key LNK0=[QLA]QLYCTLDEM Asc; [QLA]VCRLIN Asc; [QLA]CRDSEQ Desc; [QLA]QSTNUM Asc
Raz WFIRDEM, WFIRSEQ, WFIRLIN
Raz WLASDEM, WLASSEQ, WLASLIN
Raz WCURDEM, WCURLIN, WCURSEQ
Read [LNK]LNK0 Last
  If fstat = 0
    WLASDEM = [F:QLA]QLYCTLDEM
    WLASLIN = [F:QLA]VCRLIN
    WLASSEQ = [F:QLA]CRDSEQ
   Endif
Read [LNK]LNK0 First
  If fstat = 0
    WFIRDEM = [F:QLA]QLYCTLDEM
    WFIRLIN = [F:QLA]VCRLIN
    WFIRSEQ = [F:QLA]CRDSEQ
  Else
    NBLU = 0
  Endif
Return
############################################################
$LOAD_FILTER
WFIL = "[F:QLD1]ITMREF=[M:SHQ1]ITMREF"
If [M:SHQ1]DEMSEL <> ""
   WFIL += "& [F:QLA]QLYCTLDEM=[M:SHQ1]DEMSEL"
Endif
If GFONCTION1 = "GESSTQ"
   If dim(GCONSSHQ) > 0
      Case GCONSSHQ
           When 1 :
               If [M:SHQ1]QLYCRDSEL <> ""
                  WFIL += "& [F:QLA]QLYCRD=[M:SHQ1]QLYCRDSEL"
               Endif

           When 2 :
               If [M:SHQ1]VCRLINSEL <> 0
                  WFIL += "& [F:QLA]VCRLIN = [M:SHQ1]VCRLINSEL"
               Endif
      Endcase
   Endif
Else
   If [M:SHQ1]QLYCRDSEL <> ""
      WFIL += "& [F:QLA]QLYCRD=[M:SHQ1]QLYCRDSEL"
   Endif
   If [M:SHQ1]VCRTYPSEL > 1
      WFIL += "& [F:QLH1]VCRTYPORI=[M:SHQ1]VCRTYPSEL"
   Endif
   If [M:SHQ1]VCRNUMSEL <> ""
      WFIL += "& [F:QLH1]VCRNUMORI=[M:SHQ1]VCRNUMSEL"
   Endif
   If [M:SHQ1]VCRLINSEL <> 0
      WFIL += "& [F:QLD1]VCRLINORI=[M:SHQ1]VCRLINSEL"
   Endif
Endif
Return

Return
############################################################
$LEC_SUI
Read [LNK]LNK0(3) Next
  If fstat
    NBLU = 0
  Endif
If [F:QLA]QLYCTLDEM = WCURDEM &
&  [F:QLA]VCRLIN    = WCURLIN &
&  [F:QLA]CRDSEQ    = WCURSEQ
  Goto LEC_SUI
Endif
Return
############################################################
$LEC_PRE
Read [LNK]LNK0(3) Prev
  If fstat
    NBLU = 0
  Endif
If [F:QLA]QLYCTLDEM = WCURDEM &
&  [F:QLA]VCRLIN    = WCURLIN &
&  [F:QLA]CRDSEQ    = WCURSEQ
  Goto LEC_PRE
Endif
Return
############################################################
$LOA_PAGE
Columns [QLH1](VCRNUMORI,VCRTYPORI,ENDCTLDAT,VALFLG)
Filter [QLH1] Where VCRTYP=28 & VCRNUM=[QLA]QLYCTLDEM
&             Order By Key QLH0
For [QLH1]
    [M:SHQ2]VCRNUMORI = [F:QLH1]VCRNUMORI
    [M:SHQ2]VCRTYPORI = [F:QLH1]VCRTYPORI
    [M:SHQ2]ENDCTLDAT = [F:QLH1]ENDCTLDAT
    [M:SHQ2]VALFLG    = [F:QLH1]VALFLG
    Break
Next
Filter [QLH1]
Columns [QLH1]

[M:SHQ2]VCRLINORI = [F:QLD1]VCRLINORI
If dim([M:SHQ2]LOT)>0
    [M:SHQ2]LOT       = [F:QLD1]LOT
Endif
If dim([M:SHQ2]SLO)>0
    [M:SHQ2]SLO       = [F:QLD1]SLO
Endif
If dim([M:SHQ2]SERNUM)>0
    [M:SHQ2]SERNUM    = [F:QLD1]SERNUM
Endif
If dim([M:SHQ2]LOT)>0 & dim([M:SHQ2]SLOT)<=0
    For [STL] Where ITMREF=[F:QLD1]ITMREF & LOT=[F:QLD1]LOT
      [M:SHQ2]BPSLOT       = [F:STL]BPSLOT
      Break
    Next
Elsif dim([M:SHQ2]LOT)>0 & dim([M:SHQ2]SLOT)>0
    For [STL] Where ITMREF=[F:QLD1]ITMREF & LOT=[F:QLD1]LOT & SLO=[F:QLD1]SLO
      [M:SHQ2]BPSLOT       = [F:STL]BPSLOT
      Break
    Next
Endif
[M:SHQ2] = [F:QLA]
If [M:SHQ2]QLYCRD=""
    [M:SHQ2]QLYCRD=[L]WQLYCRD
Endif
[M:SHQ2]MVTSEQ1 = 10000 - [F:QLA]CRDSEQ
[M:SHQ2]VCRLIN  = [F:QLA]VCRLIN
#
Read [QLC]QLC0(1)=[M:SHQ2]QLYCRD
[G:QLC]currlen = 0
If fstat = 0
  # FGR 24/09/2009 : X3SUIVI58062
  #[M:SHQ2]QLYCRDDES = [F:QLC]QLYCRDDES
  Call LECTEXTRA([M:SHQ2]QLYCRDDES,"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA
Endif
#
WCURDEM = [F:QLA]QLYCTLDEM
WCURLIN = [F:QLA]VCRLIN
WCURSEQ = [F:QLA]CRDSEQ
#
If WINCR > 0
  Filter [QLA1] Where QLYCTLDEM = [F:QLA]QLYCTLDEM
&                   & VCRLIN    = [F:QLA]VCRLIN
&                   & CRDSEQ    = [F:QLA]CRDSEQ
&               Order By Key QLA0
Else
  Filter [QLA1] Where QLYCTLDEM = [F:QLA]QLYCTLDEM
&                   & VCRLIN    = [F:QLA]VCRLIN
&                   & CRDSEQ    = [F:QLA]CRDSEQ
&               Order By Key QLA0 Desc
Endif
For [QLA1]
  If nolign > 0 & nolign <= dim([M:SHQ2]ASW)
    [M:SHQ2] = [F:QLA1]
    Read [QLQ]QLQ0=[F:QLA1]QSTNUM
    If fstat = 0
      #Call LECTEXTRA([M:SHQ2]QSTDES(nolign-1),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA
      #[M:SHQ2]QSTDES(nolign-1) = [F:QLQ]QSTDES # V6 champ remplacé
      Call LECTEXTRA([M:SHQ2]QSTDESAXX(nolign-1),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA  # hcb 76080
      If [F:QLQ]DEMCTLTYP=1
        Read [TCT]TCT1=[F:QLQ]TCT;[F:QLA1]ASW;0
        If !fstat
          [M:SHQ2]ASWDES(nolign-1)=[F:TCT]DESCOD
        Endif
      Endif
      If [F:QLQ]DEMASWTYP=4
        [M:SHQ2]ASWDES(nolign-1)=mess([F:QLA1]NUMASW+1,1,1)
      Endif
    Else
      fstat = 0
      # FGR 15/01/2010 : X3SUIVI60986
      #[M:SHQ2]QSTDES(nolign-1) = "?"
      [M:SHQ2]QSTDESAXX(nolign-1) = "?"  # hcb 76080
    Endif

    nolign += WINCR
    NOL    += WINCR
  Else
    Break
  Endif
Next
Filter [QLA1]
If [M]QLYCRD="" & WQLYCRD<>""
  [M]QLTCRD=WQLYCRD
Endif

Return
############################################################
$AV_MAGNETO
Raz [M:CSHQ]DEMSEL,[M:CSHQ]VCRTYPSEL,[M:CSHQ]VCRNUMSEL,[M:CSHQ]VCRLINSEL,[M:CSHQ]QLYCRDSEL
#[M:SHQ1] = [M:CSHQ]   # hcb 89821
Return

############################################################
Subprog C_DEMSEL(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If [F:QLH1]VCRNUM<>VALEUR
  Read [QLH1]QLH0=28;VALEUR
  If fstat  Raz [F:QLH1] : End : Endif
Endif
[M]STOFCY   = [F:QLH1]STOFCY
[M]ITMREF   = [F:QLH1]ITMREF
[M]DEMSEL   = [F:QLH1]VCRNUM
[M]VCRTYPSEL= [F:QLH1]VCRTYPORI
[M]VCRNUMSEL= [F:QLH1]VCRNUMORI
If [F:QLH1]VALFLG=2
    [M]VALFLGO=2
    [M]VALFLGN=1
Else
    [M]VALFLGN=2
    [M]VALFLGO=1
Endif
#If dim([M]QLYCRD)>0                 # hcb V6CQ
#  [M]QLYCRD=[F:QLH1]QLYCRD          # hcb V6CQ
#ENDIF                               # hcb V6CQ
Affzo [M]1-99
End
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    # Issue X3-96177 - 2018-08-27 by MAE : Ajout du changement de stock:29
    #If !find(I,6,13,15,19)
    If !find(I,6,13,15,19,29)
        GMENLOC(I) = 1
    Endif
Next I
End


## Etiquette ajoutée hcb V6CQ
Subprog C_QLYCRDSEL(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & VALEUR <> [M]QLYCRDSEL
   Read [QLC1]QLC0=VALEUR
   If fstat
      GMESSAGE=mess(23,100,1)
      mkstat=2
   Endif
Endif

End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SHQ") From SUBGTC

End

