#<AdxTL>@(#)9.0.0.0 $Revision$
Call EDIT_CMD("NOR0806F1100004","WEB")
End

Subprog EDIT_CMD(NUM,TRANSAC)
Value Char NUM
Value Char TRANSAC

##Dbgaff
If !clalev([F:ARV]) Local File AREPORTV [ARV] Endif
If !clalev([F:SOH]) Local File SORDER   [SOH] Endif
If !clalev([F:BPR]) Local File BPARTNER   [BPR] Endif




Local    Char    WETAT
Local    Char    IMPRIMANTE
Local    Char    LANGUE
Local    Integer TRACE
Local    Char    MSGIMP
Local    Char    TBPAR(50)(1..1)
Local    Char    TBVAL(50)(1..1)

Read [F:SOH]SOH0=[L]NUM
If fstat : End : Endif
Read [BPR]BPR0 = [F:SOH]BPCORD
If fstat : End : Endif

[L]WETAT      = func PRINTWAS.GET_ETAT(TRANSAC)
[L]IMPRIMANTE = "MESSPDF"
[L]LANGUE     = [F:BPR]LAN
[L]TRACE      = 1
[L]MSGIMP     = "test ol"
Raz [L]TBPAR, [L]TBVAL

Call  ETAT(WETAT,IMPRIMANTE,LANGUE,TRACE,MSGIMP,TBPAR,TBVAL) From AIMP3




End

############
Funprog GET_ETAT(TRANSAC)
Value Char TRANSAC()

Local Char ETAT(GLONARP)

If !clalev([F:SLT]) : Local File SALTRS [SLT] : Endif

Read [SLT]SLT0 = 2;[L]TRANSAC
If !fstat
 [L]ETAT = [F:SLT]DOCNAM
Endif

End ETAT
