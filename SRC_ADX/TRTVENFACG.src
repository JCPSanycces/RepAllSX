#     When "SAU"        :  IMPMOD=1 : [M]SAU(nolign-1)=
#     When "QTY"        :  IMPMOD=1 : [M]QTY(nolign-1)=
#                          --- gestion textes lignes sur 1er champ obligatoire
#                              autre que ITMREF qui garni les textes par defaut
#                              - ouvrir masque ACLOB [ACL] et table TEXCLOB [TXC] en debut
#                              - garnir [M:ACL]CLOB avec le texte
#                              - mettre abréviation de la table dans le champ lien
#                          Local Integer T_OK
