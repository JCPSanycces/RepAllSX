#$MSK_DETAIL
#Case IMPZON
#     When "NBLIG"      :  IMPMOD=1 : [M]NBLIG(nolign-1)=   : #--- masque SIH4
#     When "ITMREF"     :  IMPMOD=1 : [M]ITMREF(nolign-1)=
#                          --- recuperation des liens des textes entete
#                          If nolign=1
#                             If [M]I_SIHTEX1<>"" : [M]SIHTEX1=[M]I_SIHTEX1 : Raz [M]I_SIHTEX1 : Endif
#                             If [M]I_SIHTEX2<>"" : [M]SIHTEX2=[M]I_SIHTEX2 : Raz [M]I_SIHTEX2 : Endif
#                          Endif
