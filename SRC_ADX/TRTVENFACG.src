#########################################################################
## X3-23080
$CHECK_INV_MSK
Local Integer OKTRT

  If filinfo(filpath("ECR","WSIH4INV","msk",0),0) < 0 Then
    GMESSAGE=mess(262,191,1) - ":" - mess(263,191,1) - mess(264,191,1)
    LERR=1
  Else
     Call EXISTE_ADX("", "","W0WSIH4INV", OKTRT) From ORDSYS
    If OKTRT > 0 Then
      # Il existe, c'est bon
    Else
      # Si l'écran existe on peut tenter de le valider : ça génèrera automatiquement le script
      If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
      If [F:ADS]DOSSIER <> nomap Then
        Read [F:ADS]DOSSIER=nomap
      Endif
      Call VALID("WSIH4INV", nomap, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OKTRT) From VALMSK
      Call EXISTE_ADX("", "","W0WSIH4INV", OKTRT) From ORDSYS
      If OKTRT > 0 Then
        # Il existe, c'est bon
      Else
        GMESSAGE = mess(262,191,1) - ":" - mess(263,191,1) - mess(265,191,1)
        LERR=1
      Endif
     Endif
    Endif
Return

