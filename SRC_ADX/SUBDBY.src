$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"STKDBYD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:DBY0]IPTDAT) From TRTX3CPT
Return


# type soustraitance obsoltete accord GL et JAM le 15 01 09
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
# si la nomenclature est deja descendu on ne modifier pas le type d'alternative
If [M:DBY0]BOMFLG = 2 & [M:DBY1]NBLIG<>0
   mkstat = 2
Endif

End

