##########################################################################
## Etiquette ajoutée par le superviseur 29/08/2003 15:58:53 (HCB)
##########################################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer WRET

#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative
If VALEUR = 0
   [M:DBY0]BOMALTTYP(nolign-1) = 2
   Diszo [M:DBY0]BOMALTTYP(nolign-1)
Else
   Call CTRBOMALT([M:DBY0]STOFCY, [M:DBY0]ITMREF(nolign-1), date$ , "DBY0", (nolign-1), VALEUR, WRET) From TRTBBYBOM
   If WRET <> 0
      mkstat=2
      End
   Endif
   Actzo [M:DBY0]BOMALTTYP(nolign-1)
Endif
End

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char SECTION
Local Integer Y
GFCY=VALEUR : Gosub CHARG_PARAM From SUBDBYA       # ana

[M:DBY0]STOFCY = VALEUR
For Y=1 To GNBDIE
    Call INISEC(SECTION, "STKDBYH", Y) From TRTX3CPT
    Assign "[M:DBY0]CCE(Y-1)"   With SECTION
    [F:SMH]CCE(Y-1)                = SECTION
    [M:DBY0]CCE(Y-1) = SECTION                         # hcb 51677
Next
Gosub AFF_TITCOL  From SUBDBYA          # hcb 103041

If dim([M:DBY0]WRHE)>0
   Call WRHINIT([M:DBY0]WRHE,VALEUR,10) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
[M:DBY0]STOFCY=VALEUR
Gosub WRH_ETAT From SUBDBYA
GSAISTOFCY = 2   # hcb 107851
End


##########################################################################
## Etiquette ajoutée par le superviseur 13/02/2004 11:40:12 (HCB)
##########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
#    Lecture article et article/site
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat
      GMESSAGE = mess(134,100,1)
      mkstat = 2
      End
    Endif
Endif

End


