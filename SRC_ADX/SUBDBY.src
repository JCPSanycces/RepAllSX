##########################################################
#                 GESTION de l'OBJET DBY                 #
#                                                        #
# $SUBDBY gère les mouvements désassemblage   #
#                                                        #
##########################################################

Call OBJET("DBY", GBIDC1, GBIDC2) From GOBJET
End

$ACTION
Case ACTION

 When "DEFTRANS"     : Gosub DEFTRANS     From SUBDBYA
 When "VARIANTE"     : Gosub VARIANTE     From SUBDBYA
 When "SETTRANS"     : Gosub SETTRANS     From SUBDBYA
 When "OUVRE"        : Gosub OUVRE        From SUBDBYA
 When "FILTRE"       : Gosub FILTRE       From SUBDBYA
 When "LIENS"        : Gosub LIENS        From SUBDBYA
 When "DEFLIG"       : Gosub DEFLIG       From SUBDBYA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBDBYA
 When "SETBOUT"      : Gosub SETBOUT      From SUBDBYA

 When "RAZCRE"       : Gosub RAZCRE       From SUBDBYA
 When "RAZDUP"       : Gosub RAZDUP       From SUBDBYA
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBDBYA
 When "INIMOD"       : Gosub INIMOD       From SUBDBYA

 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBDBYA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBDBYA
 When "INICRE"       : Gosub INICRE       From SUBDBYA
 When "CREATION"     : Gosub CREATION     From SUBDBYA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBDBYA
 When "VALLIG"       : Gosub VALLIG       From SUBDBYA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBDBYA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBDBYA
 When "MODIF"        : Gosub MODIF        From SUBDBYA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBDBYA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBDBYA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBDBYA


 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBDBY
 When "AB3_NBLIG"    : Gosub AB3_NBLIG    From SUBDBY

 When "ANNULE"       : Gosub ANNULE       From SUBDBYA
 When "ABANDON"      : Gosub ABANDON      From SUBDBYA
 When "FIN"          : Gosub ABANDON      From SUBDBYA
 When "FERME"        : Gosub FERME        From SUBDBYA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBDBYA
 When "GRISE"        : Gosub GRISE        From SUBDBYA

 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBDBYA
 When "FILGAUCHE"    : Gosub FILGAUCHE    From SUBDBYA
 When "PICKE"        : Gosub PICKE        From SUBDBYA
 When "FIN_PICK"     : Gosub FIN_PICK     From SUBDBYA
 When "DEPICK"       : Gosub DEPICK       From SUBDBYA

# When "CLE_GAUCHE"   # Gosub CLE_GAUCHE   From SUBDBYA

 When Default        :
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return


########################################
########################################
#
#    ACTIONS CHAMPS EN-TETE
#
########################################
########################################

########################################
# SMRNUM
########################################
# Initialise le type de document
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
If GFONCTION = "GESDBY"
   [M:DBY0]VCRTYP=31          #assemblage
Endif
If GFONCTION = "GESDBY"
   [M:DBY0]VCRTYP=32          #desassemblage
Endif

End

########################################
# Vérifie que le numéro est renseigné si le document n'a pas de compteur affecté.
#
Subprog C_VCRNUM(VALEUR)
Variable Char VALEUR
    #-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
    If (VALEUR="" &  GSTKCPT(17)="")
        mkstat = 2
        End
    Endif
    #-- Si on est en création , n° saisi vide et un compteur est présent on sort
    If (GREP="C" & VALEUR="" &  GSTKCPT(17)<>"")
        End
    Endif

    #-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
    If [M:DBY0]VCRNUM="" & GREP<>"C"
        Look [F:SMH]SMH0=[M:DBY0]VCRTYP;VALEUR
        If fstat
            GMESSAGE=mess(178,199,1)   # ce document n existe pas
            mkstat=2
            End
        Endif
    Endif

    If VALEUR<>"" & GSTKCPTMAN(17)<>2
        Look [F:SMH]SMH0=[M:DBY0]VCRTYP;VALEUR
        If fstat
            Raz VALEUR
            End
        Endif
    Endif
End

########################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M:DBY1]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

########################################
########################################
#
#    ACTIONS CHAMPS LIGNES
#
########################################
########################################

########################################
Subprog C_NBLIG
Local Integer WRET, I
Gosub SET_NOL
    Case status
        When 65     :                                # Suppression d'une ligne
            If [M:DBY0]CREFLG(NOL)=0
               [M:DBY0]QTYSTU (NOL) = 0
                Call DELSTOSORW(NOL,NOL,"DBY0",[M:DBY0]STOFCY,WRET) From STKSOR
                If WRET<>0 : mkstat=2 : Endif
            Else
                GMESSAGE = mess (6,184,1)            # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                mkstat = 2
            Endif

        When 68, 83 :                                # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                If [M:DBY0]CREFLG(I)<>0
                    GMESSAGE = mess (6,184,1)            # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                    mkstat=2
                    Break
                Endif
            Next
            If !mkstat
                Call DELSTOSORW(NOL,nolign1-1,"DBY0",[M:DBY0]STOFCY,WRET) From STKSOR
                If WRET<>0 : mkstat=2 : Endif
                For I=nolign-1 To nolign1-1
                    [M:DBY0]QTYSTU (NOL) = 0
                Next
            Endif

        When 73, 82 :
            If [M:DBY0]PNTMVTCOD <> 1                          # 28649
               Call STKACTLIGM(nolign-1,"DBY0") From STKECR
            Endif                                              # 28649
            Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)
            If dim([M]PCU)>0
                Actzo [M]PCU(nolign-1),QTYPCU(nolign-1)
            Endif
            If dim([M]PCUSTUCOE)>0
                Actzo [M]PCUSTUCOE(nolign-1)
            Endif

        When 75     :
            If nolign-1 = 0
               If [M:DBY0]CREFLG(nolign-1)<>0
                   mkstat=2
               Endif
            Endif
    Endcase
GMODIF = 0
End

########################################
Subprog AVANT_NBLIG
If [M:DBY0]VCRNUMORI = ""               # hcb 22993
   Gosub SET_NOL
# Lecture article et règle de gestion
   Call INIZONSOR("DBY0",[M:DBY0]ITMREF(NOL),[M:DBY0]STOFCY,NOL,[M:DBY0]TRSTYP,[M:DBY0]TRSCOD,"") From STKECR
Endif                                   # hcb 22993
#                                                  # hcb 71276 deb
If status<>73 & status<>82
  If dim([M:DBY0]ECCVALMAJ)>0
    Diszo [M:DBY0]ECCVALMAJ(nolign-1)
  Endif
  If dim([M:DBY0]ECCVALMIN)>0
    Diszo [M:DBY0]ECCVALMIN(nolign-1)
  Endif
Endif
#                                                  # hcb 71276 fin
End

########################################
Subprog IB_NBLIG
# Bouton  2 : Saisie des sorties
# Bouton  3 : Modification des sorties
# Bouton  6 : mouvement par articles
Gosub SET_NOL
#   dans le tableau in ni a qu une ligne
If NOL <> 0
   End
Endif
GOUVSOR = 1
If nolign-1 = 0
   If [M:DBY0]CREFLG(NOL) <> 0  # Saisie détail
       GBOUT2 = ""
   Endif
   If [M]ITMREF(NOL) = "" | [M:DBY0]PNTMVTCOD = 1    # hcb 28649
      Raz GBOUT2, GBOUT3, GBOUT6
      End
   Endif

   If [M:DBY0]CREFLG(NOL)=0
        GBOUT3 = ""    # Modif détail
   Endif

   If GREP<>""
        GBOUT3 = ""    # Modif détail
   Endif
Endif
If [M:DBY0]VCRNUMORI <> ""
        GBOUT2 = ""    # Saisie détail
        GBOUT3 = ""    # Modif détail
Endif
If [M:DBY0]VCRNUMORI = ""
        GBOUT6 = ""    # Consultation mvt stock
Endif

End

#########################################################################
# Etiquette exécutée avant l'action SAISTOSOR
#########################################################################

$AB3_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:DBY0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVSOR=0
   Return
Else
   GOUVSOR = 1
Endif
Return


$AAPRES_NBLIG

Local Integer WRET
Raz WRET
Raz GOUVSOR
Gosub SET_NOL

If [M:DBY0]PNTMVTCOD = 1    # hcb 28649
   Return                   # hcb 28649
Endif                       # hcb 28649

# test rajouté sinon erreur enregistrement article inexistant si escape sur la ligne
If [M:DBY0]ITMREF(NOL) = ""
   Return
Endif
# Si sortie tableau validante
If adxgtb<>1 & !find(status,65,68,83)
   # Si ligne saisie mais non créée ou
   # ligne déjà créée et pièce avec validation non validée
   If [M:DBY0]CREFLG(NOL)=0 | ([M:DBY0]CREFLG(NOL)<>0 & [M:DBY0]CFMFLG<>2)
      # Alimentation de [M:ALP]
      Gosub ALI_ALP From SUBDBYA
      # Détermination du stock à sortir (automatisme, saisie)
        Diszo [M:DBY0]ITMREF(NOL)
        Call OUVSOR("DBY0",NOL,[M:DBY0]NBLIG,[M:DBY0]WSTOSEQ(NOL),[M:DBY0]STKFLG,WRET) From STKSOR   # hcb 50197
        Affzo [M:DBY0]ITMREF(NOL)
    Endif
Endif
Return

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WQTY
Local    Integer J, NOL
If [M:DBY0]PNTMVTCOD = 1    # hcb 28649
   End                      # hcb 28649
Endif

NOL=nolign-1
pcolor=GCOUL(0)
# Colorisation de l'article
# - si tout le stock à sortir n'a pas été renseigné
# - s'il y a une qunatité en rupture
# Nouvelle ligne ou ligne modifiée
If [M:DBY0]CREFLG(NOL)=0 | ([M:DBY0]CREFLG(NOL)<>0 & [M:DBY0]UPDFLG(NOL)<>0)
   # Si ligne en cours de saisie
   If [M:DBY0]QTYSTU(NOL)=0
      pcolor=GCOUL(1)
   Else
      WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:DBY0]WSTOSEQ(NOL)))
      # Tout le stock à sortir n'a pas été renseigné
      If WQTY<>[M:DBY0]QTYSTU(NOL)
         pcolor=GCOUL(1)
      Else
         WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                  ([M:SOW]WSTOSEQ(J)=[M:DBY0]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
         # Il y a une quantité en rupture
         If WQTY<>[M:DBY0]QTYSTU(NOL)
            pcolor=GCOUL(2)
         Endif
      Endif
   Endif
Elsif [M:DBY0]FLGRUP(NOL)=1
   pcolor=GCOUL(2)
Endif
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Gosub SET_NOL

 If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
    Read [ITF]ITF0 = VALEUR;[M:DBY0]STOFCY
    If fstat
       mkstat = 2
       GMESSAGE = mess(25,192,1)
       End
    Endif
    If [F:ITF]STOMGTCOD<2
       GMESSAGE = mess(283,197,1)
       mkstat = 2
       End
    Endif

    # Lecture article et règle de gestion
    Call INIZONSOR("DBY0",VALEUR,[M:DBY0]STOFCY,nolign-1,[M:DBY0]TRSTYP,[M:DBY0]TRSCOD,"") From STKECR



    [M:DBY0]STOMGTCOD(NOL) = [F:ITF]STOMGTCOD

    #[M:DBY0]ITMDES1(NOL) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:DBY0]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:DBY0]PCU(NOL)        = [F:ITM]STU
    [M:DBY0]PCUSTUCOE(NOL)  = 1
    [M:DBY0]STU(NOL)        = [F:ITM]STU
    Diszo [M:DBY0]PCUSTUCOE(NOL)
    Affzo [M:DBY0]PCU(NOL),PCUSTUCOE(NOL),STU(NOL)
    If [M]STOMGTCOD(NOL)<>1 & dim([M:DBY0]LOC)>0 & [M:DBY0]PNTMVTCOD <> 1    # hcb 28649
       Call STKINIEMPS([M:DBY0]LOC(NOL)) From STKLOC
    Endif


#--------------------------------#
# Recherche alternative valide   #
# pour proposition auto.         #
#--------------------------------#
If VALEUR = [M:DBY0]ITMREF(0)
   If [M:DBY0]BOMALT(0) <> 0
      End
   Endif
Endif

Local Integer WALT
#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative : si unique elle est proposée

Call INITBOMALT([M:DBY0]STOFCY, VALEUR, date$ , "DBY0", (nolign-1), WALT) From TRTBBYBOM




End

########################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

Local Integer LMODIF
Local Decimal LCOEF

    Gosub SET_NOL
    # Recherche du nouveau coefficient UC-US
    Call CTLUOM([M]ITMREF(NOL),3,"",VALEUR,LCOEF,GBIDC1,GBIDC2,LMODIF) From STKACT
    If mkstat=2 End Endif
    [M]PCUSTUCOE(NOL) = LCOEF
    If LMODIF < 2
        Diszo [M:DBY0]PCUSTUCOE(NOL)
    Else
        Actzo [M:DBY0]PCUSTUCOE(NOL)
    Endif
    Call QTEARR( [M:DBY0]QTYPCU(NOL), VALEUR ) From TRTDIV
    [M:DBY0]QTYSTU(NOL) = [M:DBY0]QTYPCU(NOL)*[M:DBY0]PCUSTUCOE(NOL)
    Call QTEARR( [M:DBY0]QTYSTU(NOL), [M:DBY0]STU(NOL) ) From TRTDIV
    Affzo [M:DBY0]PCUSTUCOE(NOL), QTYSTU(NOL)
If VALEUR <> [M:DBY0]PCU(NOL)
   GMODIF = 2
Endif

End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
   mkstat=2
Endif

Gosub SET_NOL                                                 # hcb 22993
If [M:DBY0]VCRTYPORI = 31 & VALEUR > [M:DBY0]QTYPCUORI(NOL)   # hcb 22993
   mkstat = 2                                                 # hcb 22993
Endif                                                         # hcb 22993

End
########################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
   mkstat=2
Endif

Gosub SET_NOL
If[M:DBY0]VCRTYPORI = 31 & VALEUR  > [M:DBY0]QTYSTUORI(NOL)   # hcb 22993
   mkstat = 2                                                 # hcb 22993
Endif                                                         # hcb 22993

End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
[M:DBY0]QTYSTU(NOL) = VALEUR * [M:DBY0]PCUSTUCOE(NOL)
Call QTEARR([M:DBY0]QTYSTU(NOL),[M:DBY0]STU(NOL)) From TRTDIV
Affzo [M:DBY0]QTYSTU(NOL)


If VALEUR <> [M:DBY0]QTYPCU(NOL)
   GMODIF = 2
Endif

End

########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL
    [M:DBY0]QTYSTU(NOL) = [M:DBY0]QTYPCU(NOL) * VALEUR
Call QTEARR([M:DBY0]QTYSTU(NOL),[M:DBY0]STU(NOL)) From TRTDIV
Affzo [M:DBY0]QTYSTU(NOL)

If VALEUR <> [M:DBY0]PCUSTUCOE(NOL)
   GMODIF = 2
Endif

End

########################################
# Dépôt
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:DBY0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:DBY0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M:DBY0]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M:DBY0]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
NOL=nolign-1

If VALEUR<>""
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBDBYA
   # Détermination no série fin
   Call CTLSORSER("DBY0",NOL,VALEUR,[M:DBY0]QTYSTU(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:DBY0]SERNUMF(NOL)
   Else
      [M:DBY0]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:DBY0]SERNUMF(NOL)
Endif
End

