######################################################################################
Subprog IB_LOT
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran DBY0) 18/04/2011 15:49:47 (HCB)
######################################################################################
Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
# si la nomenclature est deja descendu on ne modifier pas l alternative
If [M:DBY0]BOMFLG(0) = 2 & [M:DBY1]NBLIG<>0
   mkstat = 2
Endif

End

Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
[M:DBY0]BOMFLG(0) = 0

End

Subprog C_BOMALTTYP(VALEUR)
Variable Integer VALEUR
Local Char    WFCY
Local Integer WALT
Local Date    WDAT
Local Integer WMSG
WDAT=date$
WMSG=1
WFCY=[M:DBY0]STOFCY

If [F:TBO]BOMALT <> [M:DBY0]BOMALT(nolign-1) | [F:TBO]BOMALTTYP <> VALEUR
    Read [TBO]TBO0= VALEUR;[M:DBY0]BOMALT(nolign-1)
Endif


If [TBO]FCY <> ""
   If [TBO]FCY  <> [M:DBY0]STOFCY
      mkstat = 2
      GMESSAGE = mess(225,199,1)
   Endif
Endif


Read [BOH]BOH0=[M:DBY0]ITMREF(nolign-1);[M:DBY0]BOMALT(nolign-1);VALEUR
If fstat
    GMESSAGE = mess(95,193,1)
    mkstat=2
    End
Endif

Call STKCTRALT(WFCY,WALT,WDAT,WMSG) From TRTBBYBOM
If WALT = 0
   mkstat = 2
   End
Endif

End

Subprog AM_BOMALTTYP(VALEUR)
Variable Integer VALEUR
[M:DBY0]BOMFLG(0) = 0

#                                                 # hcb 71276 deb
If [F:ITM]ECCSTO > 1 &  dim([M:DBY0]ECCVALMAJ) > 0
   Local Char    LABR
   Local Integer LNOL
   LNOL = 0
   LABR = "DBY0"
   Gosub RECH_ECCVAL  From TRTBBYBOM
Endif
#                                                 # hcb 71276 fin
End

#                                                   # hcb 71276  deb
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET

Call CTLECCVAL(VALEUR,[M:DBY0]STOFCY,[M:DBY0]ITMREF(nolign-1),
&             [M:DBY0]TRSTYP,[M:DBY0]TRSCOD,[M:DBY0]IPTDAT,LRET) From STKSOR
If LRET>0 mkstat=2 Endif
End

######################################################################################

#                                                                        # hcb 51677 deb
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
Local Char    LSEC
Local Integer I
If [M:DBY1]NBLIG=0
   [M:DBY0]PJT=VALEUR
   For I=1 To GNBDIE
       If dim([M:DBY0]CCE)>0
          Raz [M:DBY0]CCE(I-1)
          Call INISEC (LSEC, "STKDBYH", I) From TRTX3CPT
          [M:DBY0]CCE(I-1) = LSEC
       Else
          Break
       Endif
    Next
Endif
End
#                                                                        # hcb 51677 fin

