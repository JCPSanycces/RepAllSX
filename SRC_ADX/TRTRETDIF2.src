#<AdxTL>@(#)2.0.0.0 $Revision$
#---------------------------------------------------------------------------
# TRTRETDIF2 : Différence entre deux contrats  (72211)
#---------------------------------------------------------------------------
Local Char VALBOUT(250) , PARBOUT(250)(1..20)

#Contrat origine -> Bulletin 1100007106
[L]PARBOUT(1) = "FIFRELIN"
[L]PARBOUT(2) = "ASN00000204"
[L]PARBOUT(3) = "20100601"

#Avenant retroactif -> Bulletin 1000007319
[L]PARBOUT(4) = "ASN00000204"
[L]PARBOUT(5) = "20110201"

FLGEXE = 1
GACTION = "TRTRETDIF2"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"TRTRETDIF2","TRTRETDIF2","XYTRTRETDIF2") From GSAISIE
End

###############
$ACTION
Case [L]ACTION
  When "OUVRE" : Gosub OUVRE 
  When "DEBUT" : Gosub DEBUT 
Endcase
Return

###########################
$OUVRE
Gosub OUVRE From TRTRETDIF
If clalev([F:VRAW])=0  : Local File VARIA      [VRAW] : Endif
If clalev([F:VLAW])=0  : Local File VALEUR     [VLAW] : Endif
If clalev([F:VFDW])=0  : Local File VALFDR     [VFDW] : Endif
If clalev([F:VCPW])=0  : Local File VALCPY     [VCPW] : Endif
If clalev([F:VFCW])=0  : Local File VALFCY     [VFCW] : Endif
If clalev([F:VLAX])=0  : Local File VALEUR     [VLAX] : Endif
Return

#################
$DEBUT
Gosub AFFECT From TRTRETDIF
If [M:DIA]REFNUMORI <> "" & [M:DIA]REFNUMDST <> ""
 Gosub CHARGEMENT From TRTRETDIF
 If WBULDES<>""
   Gosub COMPARE
 Endif
Endif
Affzo [M:DIA]
Return

#Comparaison entre les valeurs de variables utilisées dans le dernier bulletin lié au contrat d'origine 
#et celles utilisées dans le bulletin lié à l'avenant
########################
$COMPARE
nolign=1
For [F:VRAW]VRA0 Where FLGRET=2 & LEG=GCURLEG        :#GCURLEG is defined in $CHARGEMENT from TRTRETDIF

## Valeurs salarié
 Read [F:VEPW]VEP5=WBULORI
 If !fstat
  Read[F:VLAW]VLA0=4;"";"";[F:VEPW]EMP;[F:VEPW]PYRDAT;[F:VRAW]COD;[F:VEPW]BUL
  If !fstat
   OK=0
   Read [F:VEPW]VEP5=WBULDES
   If !fstat
    Read[F:VLAX]VLA0=4;"";"";[F:VEPW]EMP;[F:VEPW]PYRDAT;[F:VRAW]COD;[F:VEPW]BUL
    If !fstat & [F:VLAX]VARVAL<>[F:VLAW]VARVAL
     If nolign<dim([M:DIA]VARCOD)
      [M:DIA]=[F:VLAX]
      nolign+=1
      OK=1
     Endif
    Endif
    If OK=1
     [M:DIA]=[F:VLAW]
     nolign+=1
    Endif
   Endif
  Endif
 Endif

 ## Valeurs site
 Filter [F:VFCW] Where FCY=[F:CTRW]ETRFCY & DAT<=WPYRDATORI #& LEG=[F:VRAW]LEG
 Read [F:VFCW]VFC0 Last
 Filter [F:VFCW]
 If !fstat
  Read[F:VLAW]VLA0=3;"";[F:VFCW]FCY;"";[F:VFCW]DAT;[F:VRAW]COD;""
  If !fstat
   OK=0
   ## Valeurs dossier
   Filter [F:VFCW] Where FCY=[F:CTRX]ETRFCY & DAT<=WPYRDATDES
   Read [F:VFCW]VFC0 Last
   Filter [F:VFCW]
   If !fstat
    Read[F:VLAX]VLA0=3;"";[F:VFCW]FCY;"";[F:VFCW]DAT;[F:VRAW]COD;""
    If !fstat & [F:VLAX]VARVAL<>[F:VLAW]VARVAL
     If nolign<dim([M:DIA]VARCOD)
      [M:DIA]=[F:VLAX]
      nolign+=1
      OK=1
     Endif
    Endif
    If OK=1
     [M:DIA]=[F:VLAW]
     nolign+=1
    Endif
   Endif
  Endif
 Endif

## Valeurs société
 Filter [F:VCPW] Where CPY=WCPYORI & DAT<=WPYRDATORI #& LEG=[F:VRAW]LEG
 Read [F:VCPW]VCP0 Last
 Filter [F:VCPW]
 If !fstat
  Read[F:VLAW]VLA0=2;[F:VCPW]CPY;"";"";[F:VCPW]DAT;[F:VRAW]COD;""
  If !fstat
   OK=0
   ## Valeurs dossier
   Filter [F:VCPW] Where CPY=WCPYDES & DAT<=WPYRDATDES
   Read [F:VCPW]VCP0 Last
   Filter [F:VCPW]
   If !fstat
    Read[F:VLAX]VLA0=2;[F:VCPW]CPY;"";"";[F:VCPW]DAT;[F:VRAW]COD;""
    If !fstat & [F:VLAX]VARVAL<>[F:VLAW]VARVAL
     If nolign<dim([M:DIA]VARCOD)
      [M:DIA]=[F:VLAX]
      nolign+=1
      OK=1
     Endif
    Endif
    If OK=1
     [M:DIA]=[F:VLAW]
     nolign+=1
    Endif
   Endif
  Endif
 Endif

## Valeurs dossier
 Filter [F:VFDW] Where DAT<=WPYRDATORI #& LEG=[F:VRAW]LEG
 Read [F:VFDW]VFD0 Last
 Filter [F:VFDW]
 If !fstat
  Read[F:VLAW]VLA0=1;"";"";"";[F:VFDW]DAT;[F:VRAW]COD;""
  If !fstat
   OK=0
   ## Valeurs dossier
   Filter [F:VFDW] Where DAT<=WPYRDATDES
   Read [F:VFDW]VFD0 Last
   Filter [F:VFDW]
   If !fstat
    Read[F:VLAX]VLA0=1;"";"";"";[F:VFDW]DAT;[F:VRAW]COD;""
    If !fstat & [F:VLAX]VARVAL<>[F:VLAW]VARVAL
     If nolign<dim([M:DIA]VARCOD)
      [M:DIA]=[F:VLAX]
      nolign+=1
      OK=1
     Endif
    Endif
    If OK=1
     [M:DIA]=[F:VLAW]
     nolign+=1
    Endif
   Endif
  Endif
 Endif


Next
[M:DIA]NBLIG=nolign-1
Return
