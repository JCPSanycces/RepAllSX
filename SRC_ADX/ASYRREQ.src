Funprog FIELDS_LIST(FORMULE,FIELDS,NBFIELDS)
Value Char FORMULE()
Variable Char FIELDS()(1..)
Value Integer NBFIELDS
Local Integer I
Local Char VALRET(250)

FORMULE=ctrans(FORMULE,',',';')
 If instr(1,FORMULE,'"')<>0
   FORMULE=ctrans(FORMULE,'"','')
 Elsif instr(1,FORMULE,"'")<>0
   FORMULE=ctrans(FORMULE,"'",'')
 Endif
 Repeat
   I=instr(1,FORMULE,";")
   If I
     J=val(left$(FORMULE,I-1))
     FORMULE=right$(FORMULE,I+1)
   Else
     J=val(FORMULE)
   Endif
   If J<>0 and J<=NBFIELDS
     VALRET+=string$(VALRET<>"",",")+'"'+FIELDS(J)+'"'
   Endif
 Until I=0
End VALRET

# Modification done to implement categories, colors, and additional legends/tooltip for calendars (SAM 107432) - Dominique BOPP
# Subprog that gets a unique field number as a parameter

Funprog FIELD_UNIQ(FORMULE,FIELDS,NBFIELDS)
Value Char FORMULE()
Variable Char FIELDS()(1..)
Value Integer NBFIELDS
Local Integer I,J

 FORMULE=ctrans(FORMULE,',',';')
 If instr(1,FORMULE,'"')<>0
   FORMULE=ctrans(FORMULE,'"','')
 Elsif instr(1,FORMULE,"'")<>0
   FORMULE=ctrans(FORMULE,"'",'')
 Endif
 I=instr(1,FORMULE,";")
 If I
   J=val(left$(FORMULE,I-1))
 Else
   J=val(FORMULE)
 Endif
 If J=0 or J>NBFIELDS : End "" : Endif
End '"'+FIELDS(J)+'"'

# End of modification (SAM 107432) - Dominique BOPP



# For debugging purposes
Funprog GDTM(NUMD)
Value Decimal NUMD
Local Decimal D1,D2,D3
D1=int(NUMD/1000)
D2=mod(D1,3600*24)
D3=int(D1/3600/24)
End format$("D:DD[/]MM[/]YYYY",[1/1/1970]+D3)
&  -format$("N0:2#",int(D2/3600))+":"
&  +format$("N0:2#",int(mod(D2,3600)/60))+":"
&  +format$("N0:2#",mod(D2,60))+" "
&  +format$("N0:3#",mod(NUMD,1000))

