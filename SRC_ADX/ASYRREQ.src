#<AdxTL>@(#)1.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer  ERROR : ERROR = [V]CST_AOK
Local Char      KEYVAL(250)(1..16)      : # Values of key components
Local Char     TYPE_REPRES(30)         : # Facet
Local Char     REPRESENTATION(30)
Local Char KEYS(50)(0..3)

REPRESENTATION = PSYR.CODREP
TYPE_REPRES = PSYR.CODFAC
KEYVAL = PSYR.SELREP
Gosub GET
End ERROR

#----------------------------------------------------------------#
# Request for a request!
#----------------------------------------------------------------#

$GET

Local Clbfile QWHERE(3)
Local Char PARAM(15)(1..100),VALBEG(250)(1..100),VALEND(250)(1..100)
Local Libelle STRICTBEG(1..100),STRICTEND(1..100)
Local  Libelle PARTYPE(1..100)
Local Char PROGNAME(20)
Local Char MSG(250)
Local Integer ERR,LEVEL,NBLIG(1..20),MAXLEVEL,FIRSTLINE,NBLINES
Local Char REQUID(36), UUIREQ(36)
Local Date COMPDATE : # Not yet used, returns the computation date
Local Integer OK, LIMITS(1..2),TBSIZE
Local Integer BATCHID
Local Libelle IFLINE(1..2),FORCED_EXEC,IFSHARED,IFBULK
Local Integer IFCUBE
Local Integer LINE_LIMIT
Local Integer STARTIND
Local Char PORTVIEW(20)
Local Date NOWDAT
Local Decimal EXECUTION_TIME,NOW
Local Integer J,FRQ
Local Char PAR_VAL(30)
Local Char REQUEST_CODE(30)
Local Char SUPERADMIN(30)

Local Integer NUMREQ        # NUMREQ of pending or processing batch task used to refresh data

# Modification October 22,2014: handle the calendar presentation
Local Clbfile CALENDAR_PROTO(1)
Local Integer K1,K2
Local Char K1F(250),K2F(250)
Local Char FIELDS(20)(1..)
Local Integer NBFIELDS
Local Integer ERRNUM

  If clalev([APV]) : LogicClose File [APV] : Endif : Local File APTLVW [APV]
  If clalev([ACC]) : LogicClose File [ACC] : Endif : Local File ACCES [ACC]
  If clalev([ALH]) : LogicClose File [ALH] : Endif : Local File ALISTEH [ALH]
  If clalev([AUS]) : LogicClose File [AUS] : Endif : Local File AUTILIS [AUS]
  If clalev([AFT]) : LogicClose File [AFT] : Endif : Local File AFCTFCT [AFT]
  If clalev([AFP]) : LogicClose File [AFP] : Endif : Local File AFCTPRF [AFP]
  If clalev([AME]) : LogicClose File [AME] : Endif : Local File AMETUTI [AME]
  If clalev([ZAP]) : LogicClose File [ZAP] : Endif : Local File APLSTD [ZAP]

# Should not remain at the end
  Local Char LAN(30)
  LAN=GACTX.LAN : #  : If LAN='' : LAN=GACTX.LANDEF : If LAN='' : LAN='ENG' : Endif : Endif

# Init the response buffer
  Raz ASND.DATA

# Define the program and check if it exists
# Bug fix September 23, 2014 by Dom : the script must be in the current folder (nomap has been added in filpath)

  REQUEST_CODE=right$(KEYVAL(1),instr(1,KEYVAL(1),"~")+1)
  PROGNAME=func SUBALH11.PREFIX_TRT_DATA+REQUEST_CODE
  If filinfo(filpath('TRT',PROGNAME,"adx",nomap),7)<=0
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(26,149,1),PSYR.CODREP))
    REPRESENTATION=KEYVAL(1)
    Return
  Endif

# Let's check the habilitations (added September 13, 2013)
  SUPERADMIN=fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,nomap,'ADMUSR')
  Read [AUS]CODUSR=GACTX.USER
  If fstat=0
    If [AUS]CODMET<>""
       Read [AME]AME0=[AUS]CODMET
       If fstat<>0
        ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,mess(30,149,1))
         Return : # Error when accessing user rights data
       Endif
       Read [AFT]AFT0=[AME]PRFFCT
    Else
      Read [AFT]AFT0=[AUS]PRFFCT
    Endif
  Endif

  If fstat
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,mess(30,149,1))
    Return : # Error when accessing user rights data
  Endif

  If [AFT]PRFCOD<>SUPERADMIN
    Read [ALH]ALH0=REQUEST_CODE
    If fstat
      REPRESENTATION=KEYVAL(1)
      ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(26,149,1),PSYR.CODREP))
      Return
    Elsif [ALH]ACS<>"" & [AFT]ALLACS<>2 & [ALH]ALLUSR<>2
      Read [ACC]CODACC = GACTX.USER;[F:ALH]ACS
      If fstat or [F:ACC]CONSUL<>2
        J=instr(1,REPRESENTATION,"~99") : If J : REPRESENTATION=left$(REPRESENTATION,J-1) : Endif : # Fix Dom April 14, 2015 J-1 instead of J
        ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(29,149,1),PSYR.CODREP))
        Return : # Access denied
      Endif
    Endif
    # Access to the function : it must at least be available on a group
    If [ALH]FCTLNK<>"" & [ALH]ALLUSR<>2 & [AFT]ALLFCT<>2
      J=0
      For [AFP] Where PRFCOD=[AFT]PRFCOD and FNC=[ALH]FCTLNK and ACS=2
        J=1 : Break
      Next
      If J=0
        J=instr(1,REPRESENTATION,"~99") : If J : REPRESENTATION=left$(REPRESENTATION,J-1) : Endif : # Fix Dom April 14, 2015 J-1 instead of J
        ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(29,149,1),PSYR.CODREP))
        Return : # Access denied
      Endif
    Endif
  Endif

# Let's analyze the additional parameters sent in the URL
  FORCED_EXEC = toupper(func ASYRMAIN.PARVAL(ARCV,"forcedExecution"))="TRUE"
  Call GET_PARAMS(PARAM,PARTYPE,MAXLEVEL,IFSHARED) From =PROGNAME
  QWHERE = func ASYRMAIN.PARVAL(ARCV,"Where")

# To be discussed with Eric April 14,2015
# Local Char CHAINE(100)
# CHAINE=func ADYRMAIN(PARVAL(ARCV,"level"))
# If CHAINE=""
#   J=instr(1,REPRESENTATION,"~")
#   If J
#     LEVEL=val(right$(REPRESENTATION,J+1)
#   Else
#     LEVEL=0
#   Endif
# Else
#   LEVEL=val(CHAINE)
# Endif
# This would replace the next line
  LEVEL = val(func ASYRMAIN.PARVAL(ARCV,"level"))
  LIMITS(1) = val(func ASYRMAIN.PARVAL(ARCV,"linesLimit"))
  LIMITS(2) = val(func ASYRMAIN.PARVAL(ARCV,"timeLimit"))
  FIRSTLINE = max(val(func ASYRMAIN.PARVAL(ARCV,"startRecord")),val(func ASYRMAIN.PARVAL(ARCV,"startIndex")),1)
  REQUID = mid$(func ASYRMAIN.PARVAL(ARCV,"requestID"),2,36)
  UUIREQ="" : # Forced request id (only for batch computations)
  IFLINE(1) = func ASYRMAIN.PARVAL(ARCV,"displayLineNum")='true'
  IFLINE(2) = func ASYRMAIN.PARVAL(ARCV,"displayHeader")='false'
  IFCUBE=(1-(func ASYRMAIN.PARVAL(ARCV,"cube")='false'))
  STARTIND= val(func ASYRMAIN.PARVAL(ARCV,"startIndex"))
  # Problem in specification, I will accept both recordsPerPage and recordPerPage
  If NBLINES=0 : NBLINES = val(func ASYRMAIN.PARVAL(ARCV,"recordsPerPage")) : Endif
  If NBLINES=0 : NBLINES = val(func ASYRMAIN.PARVAL(ARCV,"recordPerPage")) : Endif
  If NBLINES=0 : NBLINES = val(func ASYRMAIN.PARVAL(ARCV,"count")) : Endif
  PORTVIEW = func ASYRMAIN.PARVAL(ARCV,"PORTVIEW")
  FRQ=val(func ASYRMAIN.PARVAL(ARCV,"frequency"))

  If FRQ
    Gosub FRQ_SET
  Endif

# If a portal view set of parameters exists, we have to manage the execution time and the level
# If GACTX.USER="DOM" : Openo filpath('TRA','req','tra'),0 Using [ZZH] : Wrseq "Portview="-PORTVIEW Using [ZZH] : Openo Using [ZZH] : Endif
  If PORTVIEW<>""
    Read [APV]APV0=PORTVIEW
    If fstat=0
      For PAR_VAL='FRQ','INITLEVEL'
        J=find(PAR_VAL,[APV]SRCPARCOD(0..dim([APV]SRCPARCOD)-1))
        If J
          Case PAR_VAL
            When 'FRQ'
            # Frequency of computation : 1=always, 2=every hour, 3=every day, 4=every week, 5=every month, 6=never
            # EXECUTION_TIME is assigned as a time stamp numeric value (if 0, recomputation is not required)
              FRQ=val(func EVALCHAR([APV]SRCPARFOR(J-1)))
              Gosub FRQ_SET
            When "INITLEVEL" : # Modification done the 16th of September 2013 : level=99 added
              If LEVEL=0 or LEVEL=99 : LEVEL=val(func EVALCHAR([APV]SRCPARFOR(J-1))) : Endif
          Endcase
        Endif
      Next

      # Dom October 14, 2014
      # If a calendar is used:
      # - first, get the list of fields by calling a new subprogram (FIELDS) in the generated script
      # - second, create the JSON prototype complement that maps the fields with the calendar
      If find([APV]CMPCODTYP,"FCA","FCR")
        Call FIELDS(FIELDS,NBFIELDS) From=PROGNAME

        K1=find("FCDATEDEB",[APV]CMPPARCOD)
        K2=find("FCHEURDEB",[APV]CMPPARCOD)
        K1F=""
        K2F=""
        If K1<>0 : K1F=func FIELDS_LIST([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K2<>0 : K2F=func FIELDS_LIST([APV]CMPPARFOR(K2-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"start":['+K1F
          If K2F<>""
            CALENDAR_PROTO+=','+K2F
          Endif
          CALENDAR_PROTO+="]"
        Endif

        K2=find("FCHEURFIN",[APV]CMPPARCOD)
        K2F=""
        If K2<>0 : K2F=func FIELDS_LIST([APV]CMPPARFOR(K2-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"end":['+K1F
          If K2F<>""
            CALENDAR_PROTO+=','+K2F
          Endif
          CALENDAR_PROTO+="]"
        Endif

        K1=find("FCTITRE",[APV]CMPPARCOD)
        K1F=""
        If K1<>0 : K1F=func FIELDS_LIST([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"summary":['+K1F+']'
        Endif

        K1=find("FCSUBTITLE",[APV]CMPPARCOD)
        K1F=""
        If K1<>0 : K1F=func FIELDS_LIST([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"subtitle":['+K1F+']'
        Endif

        K1=find("FCTEXTE",[APV]CMPPARCOD)
        K1F=""
        If K1<>0 : K1F=func FIELDS_LIST([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"description":['+K1F+']'
        Endif

# Modification done to implement categories, colors, and additional legends/tooltip for calendars (SAM 107432) - Dominique BOPP

        K1=find("FCCATEG",[APV]CMPPARCOD)
        K1F=""
        If K1<>0 : K1F=func FIELD_UNIQ([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"category":{"property":'+K1F
          K1=find("FCALEGEND",[APV]CMPPARCOD)
          K1F=""
          If K1<>0 : K1=val(ctrans([APV]CMPPARFOR(K1-1),"'"+'"',"")):Endif
          If K1<>0
            CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"legend":{'
            J=0
            For [ZAP]LAN Where LAN=[L]LAN and LANCHP=K1 and LANNUM>0
              CALENDAR_PROTO+=string$(J,",")+'"'+num$([ZAP]LANNUM)+'":"'+escJson([ZAP]LANMES)+'"' : J=1
            Next
            CALENDAR_PROTO+='}'
          Endif
          CALENDAR_PROTO+='}'
        Endif

        K1=find("FCCOLOR",[APV]CMPPARCOD)
        K1F=""
        If K1<>0 : K1F=func FIELD_UNIQ([APV]CMPPARFOR(K1-1),FIELDS,NBFIELDS):Endif
        If K1F<>""
          CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"color":{"property":'+K1F
          K1=find("FCOLEGEND",[APV]CMPPARCOD)
          K1F=""
          If K1<>0 : K1=val(ctrans([APV]CMPPARFOR(K1-1),"'"+'"',"")):Endif
          If K1<>0
            CALENDAR_PROTO+=string$(CALENDAR_PROTO<>"",",")+'"legend":{'
            J=0
            For [ZAP]LAN Where LAN=[L]LAN and LANCHP=K1 and LANNUM>0
              CALENDAR_PROTO+=string$(J,",")+'"'+num$([ZAP]LANNUM)+'":"'+escJson([ZAP]LANMES)+'"' : J=1
            Next
            CALENDAR_PROTO+='}'
          Endif
          CALENDAR_PROTO+='}'
        Endif

# End of modification done (SAM 107432) - Dominique BOPP


      Endif
    Endif
  Endif

# Set some default values
  LEVEL = max(min(LEVEL,MAXLEVEL),1)
  If FIRSTLINE=0 : FIRSTLINE=1 : Endif
  If NBLINES=0
      If TYPE_REPRES="$bulk"
        NBLINES=fmet GACTX.APARAM.AGETUSERVALNUM("NBRREQBLK")
        If NBLINES=0 : NBLINES=200 : Endif
        IFBULK=1
      Else
        NBLINES=fmet GACTX.APARAM.AGETUSERVALNUM("NBRREQ")
        If NBLINES=0 : NBLINES=20 : Endif
        IFBULK=0
      Endif
   Endif

## If a paging option or zoom option is sent, forced execution is not triggered and time option is no more used
## Except if the level is the first one and page is the first one
## Attempt to solve the refresh options - SAM 103847
#  If FIRSTLINE>1 or (REQUID<>"" and LEVEL<>1) : FORCED_EXEC=0 : EXECUTION_TIME=0 : Endif
#  If FORCED_EXEC : adxmpr=adxmpr : Endif
#
# Analyze the where sentence
  Call PARSE_WHERE(QWHERE,PARAM,PARTYPE,VALBEG,STRICTBEG,VALEND,STRICTEND,ERR,MSG) From ASYRFNC
  If ERR
    #Call TRACE(func AFNC.MES1(MESSAGE, MSG)) From ASYRCOM
    Call SPLIT(KEYS,PSYR.SELREP,"~") From ASYRSUB
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(27,149,1),KEYS(1)-":"-MSG-num$(ERR)))
    Return
  Endif
  OK=0
  ERRNUM=0

# Let's analyse first_xxx and last_xxx parameters if QWHERE is empty
  If QWHERE=""
    Onerrgo NOTHING
    Call PARSE_PARAM(ARCV,VALBEG,VALEND,STRICTBEG,STRICTEND) From =PROGNAME
  Endif

# Get the recomputation parameter
  LINE_LIMIT=fmet GACTX.APARAM.AGETVALNUM(1,"","SELWARN")
  If LINE_LIMIT=0 : LINE_LIMIT=10000 : Endif

# If unique id not set, and  forced execution requested, execute first : SAM 119277
  Local Char MAINTABLE(50): MAINTABLE= func =PROGNAME+".GET_MAINTABLE" With ()
  If REQUID="" and FORCED_EXEC=1
    If fmet GACTX.APARAM.AGETVALNUM(1,"","TYPDBA")=1
      Call GET_NBREC_ORACLE(TBSIZE, MAINTABLE)
    Else
      Call GET_NBREC_SQL(TBSIZE, MAINTABLE)
    Endif
    If TBSIZE>LINE_LIMIT
      Gosub RQTBATCH
    Else
      adxmpr=adxmpr : # Purge the program stack in case the request has been revalidated
      Call EXEC_RQT(GACTX,VALBEG,VALEND,STRICTBEG,STRICTEND,LIMITS,NBLIG,REQUID,UUIREQ) From =PROGNAME
      Gosub GETRQT
    Endif
# Otherwise, try to read it first
  Else
    Gosub GETRQT

 # Modified by Dom : SAM 114121
    If OK=6
      OK=0
      REQUID=''
      FIRSTLINE=1
      LEVEL=1
      Gosub GETRQT
    Endif
  # End of modification

    # If the request was never executed, or if the parameter don't fit
    If find(OK,3,5)
      If fmet GACTX.APARAM.AGETVALNUM(1,"","TYPDBA")=1
        Call GET_NBREC_ORACLE(TBSIZE,MAINTABLE)
      Else
        Call GET_NBREC_SQL(TBSIZE,MAINTABLE)
      Endif
      If TBSIZE>LINE_LIMIT
        Gosub RQTBATCH
      Else
        OK=0
        # Added a reexecution Dec 10, 2012
        Call EXEC_RQT(GACTX,VALBEG,VALEND,STRICTBEG,STRICTEND,LIMITS,NBLIG,REQUID,UUIREQ) From =PROGNAME
        Gosub GETRQT
      Endif
    Endif
  Endif

  # Issue X3-75518 - 2018-08-09 by CCC : alert when data are refreshed by batch
  If [L]NUMREQ=0    # It means that no batch has been requested => check if a batch task is running to update data
      Call GET_REQBAT(PROGNAME,UUIREQ, NUMREQ)
      If [L]NUMREQ<>0
        OK=1    # Avoid to display old/not complete data
        ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AWARNING,[V]CST_AHTTP_OK,
&                                        func ASYRFNC.MES1(mess(74,149,1),num$([L]NUMREQ)))
      Endif
  Else
      OK=1
      ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AWARNING,[V]CST_AHTTP_OK,
&                                      mess(75,149,1))
      ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AWARNING,[V]CST_AHTTP_OK,
&                                        func ASYRFNC.MES1(mess(73,149,1),num$([L]NUMREQ)))
  Endif

  Case OK
    When 2 :
     Call SPLIT(KEYS,PSYR.SELREP,"~") From ASYRSUB
     ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(27,149,1),KEYS(1)))
    When 4 :
     # Access rights error
     ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(29,149,1),PSYR.CODREP))
    When 6 :
     ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(28,149,1),PSYR.CODREP))
    When 7 :
      # TODO : error in transaction for posting the batch request
      ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(28,149,1),PSYR.CODREP))
  Endcase

  If OK=0
    ERRNUM=0
    ASND.STAT     = 200
    ASND.URL      = PSYR.PREFIX+'/'+REPRESENTATION
    #SAM 110364 {
    If !len(ASND.DATA)
     ASND.DATA   = '{ "$totalResults": 0, "$portview":"'+PORTVIEW+'", "$clink":"'+string$(CALENDAR_PROTO<>'','calendar')+'","$resources": []}' : #SAM 119198 - Added $portview
    Endif
    #} SAM 110364
    ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRESENTATION+"."+TYPE_REPRES
  Elsif OK=1
    ERRNUM=0
    ASND.STAT     = 202
    ASND.URL      = PSYR.PREFIX+'/'+REPRESENTATION
    ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRESENTATION+"."+TYPE_REPRES
    ASND.DATA     = '{"headerMessage":"'+func AFNC.MES1(func AJSONLIB.M(LAN,146,24),num$(BATCHID)-UUIREQ)+'"}'
   Endif

Return

# Frequency of computation : 1=always, 2=every hour, 3=every day, 4=every week, 5=every month, 6=never
# Added the 18th of March 2014 : 7=every 10 minutes, 8=every minute, 9=every 10 seconds
$FRQ_SET
  NOW=val(timestamp$) : NOWDAT=[1/1/1970]+int(NOW/(24*3600*1000))
  If find(FRQ,2,3,4,6)
    EXECUTION_TIME=(FRQ<>6)*NOW-(FRQ=2)*(3600*1000)-(FRQ=3)*24*3600*1000-(FRQ=4)*7*24*3600*1000
  Elsif FRQ=5
    EXECUTION_TIME=24*3600*1000*(gdat$(1,month(NOWDAT),year(NOWDAT))-[1/1/1970])-1
  Elsif FRQ=1
    FORCED_EXEC=1
  Elsif FRQ=7
    EXECUTION_TIME=NOW-(60*10000)
  Elsif FRQ=8
    EXECUTION_TIME=NOW-(60*1000)
  Elsif FRQ=9
    EXECUTION_TIME=NOW-(10*1000)
  Endif
Return
#----------------------------------------------------------------#
# Error response
#----------------------------------------------------------------#
$ERR_DETAIL
Local Char DBG_ERR(250)
DBG_ERR = "Error"-num$(errn)-"line"-(errl)-errp-errmes$(errn)
Return

#**
#* Return UUIREQ of request and NUMREQ of pending/processing batch task
#*
#* @param PROGNAME : script name of the request
#* @param UUIREQ   : request ID (returned)
#* @param NUMREQ   : batch task number (returned)
#*!
Subprog GET_REQBAT(PROGNAME,UUIREQ, NUMREQ)
Value Char PROGNAME
Variable Char UUIREQ
Variable Integer NUMREQ

  UUIREQ=""
  [L]NUMREQ=0

  Local File ABATRQTL [ABL]
  Local File ABATRQT [AQ1],ABATRQTL [AQ2]
  Link [AQ2] With [AQ1]NUMREQ=[AQ2]NUMREQ As [AQ3]
&            Where find([AQ1]FLAG,1,2)<>0
&              and [AQ1]DOSSIER=GACTX.AFOLDER
&              and [AQ1]TACHE=func GET_REQ_TASK_NAME()
&              and [AQ1]USER=GACTX.USER
&              and [AQ2]PARAM="TRTNAM"
&              and [AQ2]VALEUR=PROGNAME

  For [AQ3]
    For [ABL] Where [ABL]NUMREQ=[AQ1]NUMREQ and pat(PARAM,"UUIREQ*")<>0
      UUIREQ=right$([ABL]PARAM,8)+[ABL]VALEUR
      [L]NUMREQ = [F:ABL]NUMREQ
      Break 2
    Next
  Next
  Close Local File [AQ1],[AQ2]

End

#**
#* return the name of batch task to use to refreh data of a request
#*!
Funprog GET_REQ_TASK_NAME
End "SYRAREP"

# Creates a request
$RQTBATCH
Local Char TACHE_REQ(20)
Local Char UUIREQ(36)
Local Integer NBATTEMPT
Local Char HM1(20)
TACHE_REQ = func GET_REQ_TASK_NAME()
If clalev([F:ABP])=0 : Local File ABATPAR [ABP]  : Endif
If clalev([F:ABT])=0 : Local File ABATTAC [ABT]  : Endif
If clalev([F:ABR])=0 : Local File ABATRQT [ABR]  : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif


# Modification done the February 19th, 2013 by Dom
# Check if this request already exist and is in progress or waiting state
# If this is the case, don't submit it again in batch, but return the uuid
  Call GET_REQBAT(PROGNAME,UUIREQ, NUMREQ)
  If UUIREQ<>""
    OK=1
    Return
  Endif


$TR_RQT
  Trbegin [ABP] , [ABR]
  Readlock [ABP]SPOOL First With lockwait=5
  If fstat=1
    OK=2 : Goto ROLL_RQT
  Elsif fstat
    OK=7 : Goto AB_RQT
  Endif
  BATCHID= [F:ABP]NUMREQ
  [F:ABP]NUMREQ+=1
  Rewrite [ABP]
  If fstat=1
    OK=2 : Goto ROLL_RQT
  Elsif fstat
    OK=7 : Goto AB_RQT
  Endif
  Read [ABT]CODTAC = TACHE_REQ
  Raz [F:ABR]
  [F:ABR] = [F:ABT]
  [F:ABR]DOSSIER = GACTX.AFOLDER
  [F:ABR]USER    = GACTX.USER
  [F:ABR]LAN    = GACTX.LAN :#109897
  [F:ABR]TACHE   = TACHE_REQ
  [F:ABR]ETAT    = [F:ABT]TRAIT
  [F:ABR]NUMREQ  = BATCHID
  [F:ABR]FLAG    = 1 : # Waiting for execution
  [F:ABR]DAT     = date$
  HM1=time$
  [F:ABR]HEURE   = left$(HM1,2)+mid$(HM1,4,2)
  #109897
  #[F:ABR]SERVICE = "" : # TODO : manage later the multi-service
  [F:ABR]GRP     = ""
  [F:ABR]NUMGRP  = 0
  Write [ABR]
  If fstat
    OK=7 : Goto AB_RQT
  Endif
  UUIREQ=num$(getUuid)

  OK=evalue("func "+PROGNAME+"."+"WR_CRIT(STRICTBEG,STRICTEND,VALBEG,VALEND,UUIREQ)")
  If OK
    OK=7 : Goto AB_RQT
  Endif
  Commit
  OK=1
  NUMREQ = [F:ABR]NUMREQ        # Issue X3-75518 - 2018-08-09 by CCC : used to alert the user that a batch has been created to refresh data
Return

$AB_RQT : Rollback : Return

$ROLL_RQT
NBATTEMPT+=1
If NBATTEMPT>3
  GOK=7
Else
  Rollback
  Sleep 1
  Goto TR_RQT
Endif
Return

