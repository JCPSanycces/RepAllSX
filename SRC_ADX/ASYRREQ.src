 CH_TRAPAR="/home/dom/tmp/trareq"
 Openo CH_TRAPAR Using [RRQ]
 Wrseq time$-"LISTE="+LISTE Using [RRQ]
 Wrseq " LEVEL="+num$(LEVEL) Using [RRQ]
 Wrseq " VALBEG="+"('"+VALBEG(1)+"','"+VALEND(1)+"');"+"('"+VALBEG(2)+"','"+VALEND(2)+"');"+"('"+VALBEG(3)+"','"+VALEND(3)+"')" Using [RRQ]
 Wrseq " REQUID="+REQUID Using [RRQ]
 Wrseq " FIRSTLINE="+num$(FIRSTLINE) Using [RRQ]
 Wrseq " NBLINES="+num$(NBLINES) Using [RRQ]
 Wrseq " COMPDATETIME="+func GDTM(COMPDATETIME) Using [RRQ]
 Wrseq " IFLINE="+num$(IFLINE(1))-num$(IFLINE(2)) Using [RRQ]
 Wrseq " IFBULK="+num$(IFBULK) Using [RRQ]
 Wrseq " IFCUBE="+num$(IFCUBE) Using [RRQ]
 Wrseq " STARTIND="+num$(STARTIND) Using [RRQ]
 Wrseq "" Using [RRQ]
 Openo Using [RRQ]
Return

