#<AdxTL>@(#)12.0.0.0 $Revision$
#####################################################################################################
# UTITC39                                                                 Module Tronc Commun       #
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Réinitialiser à 1 les champs DWIPSTA et RWIPSTA s'ils sont à 0 dans la table MTOLINK           #
#                                                                                                   #
#####################################################################################################
# Issue 82463 - 2012-05-31 by GH
#####################################################################################################

Call MAJ_UTITC39
End

#-------------------------------------------------------------------
Subprog MAJ_UTITC39

Local Char DOSSIER(30)
DOSSIER=nomap

Call SAIDOS(DOSSIER,"UTITC39 - Correction [MLK]DWIPSTA") From SAIDOS

If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC39 - Correction [MLK]DWIPSTA") From LECFIC
  Call EXE_UTITC39(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

End
#-------------------------------------------------------------------
Subprog EXE_UTITC39(DOSSIER)
Value Char    DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde", DOSSIER),0) < 0 : End : Endif

Call ECR_TIME("UTITC39 : Correction DWIPSTA & RWIPSTA in table MTOLINK : Started") From DOSSUB

Local File =DOSSIER+".MTOLINK"   [MLK]
Local Integer NBENR

Trbegin [MLK]
  Update [MLK] Where DWIPSTA=0 With DWIPSTA=1
  NBENR += adxuprec
  Update [MLK] Where RWIPSTA=0 With RWIPSTA=1
  NBENR += adxuprec
Commit

Call ECR_TIME("UTITC39 : Correction DWIPSTA & RWIPSTA in table MTOLINK : Ended"-"("-num$(NBENR)+" records processed"-")") From DOSSUB

End

#-----------------------------------------------------------------------------------------------
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde",DOSSIER),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC39(DOSSIER)

End
#-----------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Pour exécution depuis dosmaj (validation dossier)                #
#------------------------------------------------------------------#
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If filinfo(filpath("FIL","MTOLINK","fde",APPLI),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif

Read [ADS]DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC39(APPLI)

End
