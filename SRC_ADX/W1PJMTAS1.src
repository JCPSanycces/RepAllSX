 PARMSK(4) = [M:PJTA1]REQDAT(nolign-1)
 PARMSK(5) = [M:PJTA0B]TASNUM
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = "2"
 PARMSK(10) = GUSER
 PARMSK(11) = [M:PJTA0]KEYCONCAT
 PARMSK(12) = num$([M:PJTA1]REACT)
 PARMSK(13) = ""
 Call SAISIE_NUM(BASPAG,PARMSK,"DCREWOX","BENCHLIB","XYZBENCHLIB") From GSAISIE
 [M:PJTA0B]TASNUM = PARMSK(5)
 [M:PJTA1]REACT = val(PARMSK(12))
 ACTION = "BB2_NBART" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

