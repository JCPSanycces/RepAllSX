#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:57"
A_USER  = "DOC"
A_STAMP = "20181109230557"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBART"
  If [M]NBART=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTAS1 [PJTA1]
Gosub HORODAT
Local Inpbox "PJMTAS1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA1] As [SIM_]
Grizo [PJTA1]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTA1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=25
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_NBART
Onevent CONTROL Call C_NBART From W1PJMTAS1
Onevent BEFORE_INPUT Call AS_NBART From W1PJMTAS1
Return

Subprog IB_NBART
Local Decimal BASPAG
## Action STD
Call IB_NBART From SUBPJTA
Gosub _AFF
End

Subprog AS_NBART
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(13080,GBOUT1) From OBJDIV
Call TEXTE(3555,GBOUT2) From OBJDIV
Call TEXTE(5727,GBOUT3) From OBJDIV
Call TEXTE(13907,GBOUT4) From OBJDIV
Call TEXTE(1002795,GBOUT5) From OBJDIV
Call TEXTE(18050,GBOUT6) From OBJDIV
Call TEXTE(16848,GBOUT7) From OBJDIV
Call IB_NBART
Onkey 129 Titled GBOUT1 Call B1_NBART From W1PJMTAS1
Onkey 130 Titled GBOUT2 Call B2_NBART From W1PJMTAS1
Onkey 131 Titled GBOUT3 Call B3_NBART From W1PJMTAS1
Onkey 132 Titled GBOUT4 Call B4_NBART From W1PJMTAS1
Onkey 133 Titled GBOUT5 Call B5_NBART From W1PJMTAS1
Onkey 134 Titled GBOUT6 Call B6_NBART From W1PJMTAS1
Onkey 135 Titled GBOUT7 Call B7_NBART From W1PJMTAS1
Gosub _AFF
End

Subprog C_NBART
Local Decimal BASPAG
## Action STD
Call C_NBART From SUBPJTA
If mkstat : GERR = 1 : GZONE = "NBART" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBART
Local Decimal BASPAG
If !GWEBSERV
 ## Action SAICREPOX
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SAICREPOX"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBART" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:PJTA1]STOFCY(nolign-1)
 PARMSK(2) = [M:PJTA1]ITMREF(nolign-1)
 PARMSK(3) = "2"
 PARMSK(4) = GUSER
 PARMSK(5) = "2"
 PARMSK(6) = num$([M:PJTA1]REACT)
 PARMSK(7) = [M:PJTA0]KEYCONCAT
 PARMSK(8) = num$([M:PJTA1]ITTQTY(nolign-1))
 PARMSK(9) = [M:PJTA1]REQDAT(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"DCREPOX","BENCHLIBP","XYZBENCHLIBP") From GSAISIE
 [M:PJTA1]REACT = val(PARMSK(6))
 [M:PJTA0]KEYCONCAT = PARMSK(7)
 ACTION = "BB1_NBART" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBART
