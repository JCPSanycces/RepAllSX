#ADNGO - 2017-06-09 - X3-11585 - START
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK

If !clalev([F:AIM])  : Local File APRINTER [AIM] : Endif

If PARAM="EMLIMPDES"
  Read [F:AIM]AIM0=VALEUR
  If !fstat
    If [F:AIM]PRT<>3
      OK = 0
      GMESSAGE=mess(83,123,1)
      End
    Endif
  Endif
Endif

End
#ADNGO - 2017-06-09 - X3-11585 - END

