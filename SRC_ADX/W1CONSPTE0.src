$ON_PTETYP
Onevent CONTROL Call C_PTETYP(zc) From W1CONSPTE0
Onevent BEFORE_INPUT Call AS_PTETYP(zc) From W1CONSPTE0
Onevent AFTER_CHANGE Gosub AMM_PTETYP From W1CONSPTE0
Return

Subprog AS_PTETYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(41572,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PTETYP(zc) From W1CONSPTE0
Onkey   2 Titled GBOUTS Call S_PTETYP(zc) From W1CONSPTE0
Onkey 144 Titled GBOUTP Call P_PTETYP(zc) From W1CONSPTE0
Onkey 146 Titled GBOUTA Call SA_PTETYP(zc) From W1CONSPTE0
Gosub _AFF
End

Subprog C_PTETYP(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("PJTC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PTETYP" : GZNUM = 41572 : Endif
Gosub _AFF
End

$AMM_PTETYP
Call AM_PTETYP(zc)
If !mkstat & GOBJET
 zoncou = "PTETYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PTETYP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPTETYP)")>indice
 [M]PTETYP(indice) = VALEUR
 Affzo ZPTETYP(indice)
Endif
Gosub _AFF
End

Subprog S_PTETYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "PJTC"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_PTETYP(VALEUR)
Variable Char    VALEUR()
Call OBJET("PJTC",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_PTETYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PJTC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PTETYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PJTC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPTETYP
Onevent BEFORE_AREA Gosub AV_ZPTETYP From W1CONSPTE0
Return

$AV_ZPTETYP
Call LECTEXTRA(zc,"PJMTIMCAT","DESAXX",num$([M]PTETYP(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


