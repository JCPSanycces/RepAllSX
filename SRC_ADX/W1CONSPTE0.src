$ON_PJTDSPALL
Onevent INIT_AREA Call D_PJTDSPALL(zc) From W1CONSPTE0
Onevent BEFORE_INPUT Call AS_PJTDSPALL(zc) From W1CONSPTE0
Return

Subprog D_PJTDSPALL(VALEUR)
Variable Integer VALEUR
If varinit([M]PJTDSPALL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PJTDSPALL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PTEDATDEB
Onevent CONTROL Call C_PTEDATDEB(zc) From W1CONSPTE0
Onevent BEFORE_AREA Gosub AV_PTEDATDEB From W1CONSPTE0
Return

$AV_PTEDATDEB
Chgfmt [M]PTEDATDEB(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_PTEDATDEB(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PTEDATDEB" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_PTEDATFIN
Onevent CONTROL Call C_PTEDATFIN(zc) From W1CONSPTE0
Onevent BEFORE_AREA Gosub AV_PTEDATFIN From W1CONSPTE0
Return

$AV_PTEDATFIN
Chgfmt [M]PTEDATFIN(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_PTEDATFIN(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
If !mkstat
 ## Action DATDEBFIN
 Call DATDEBFIN(VALEUR,[M:PTE0]PTEDATDEB) From EXEFNC
 If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
Endif
Gosub _AFF
End

$ON_PTESTA1
Onevent INIT_AREA Call D_PTESTA1(zc) From W1CONSPTE0
Onevent BEFORE_INPUT Call AS_PTESTA1(zc) From W1CONSPTE0
Return

Subprog D_PTESTA1(VALEUR)
Variable Integer VALEUR
If varinit([M]PTESTA1,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PTESTA1(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

