#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXBRKI
$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When "OK"            : Gosub OK
  Endcase
Return

######################################################################################
$DEBUT
  Raz [M:XBRKI]
  Grizo [M:XBRKI]ELPFLG
  [M:XBRKI]ELPFLG = 0
  Grizo [M:XBRKI]DURATION
  Affzo [M:XBRKI]
Return

######################################################################################
$OK

  Local Char      CHARBLANK(20)(1) # Using this for all that we don't need
  Local Integer   INTBLANK(1)      # Using this for all that we don't need
  Local Decimal   DECBLANK(1)      # Using this for all that we don't need
  Local Integer   NUMJOBS : NUMJOBS = 1

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null
  Local Integer CSTATUS

  If [M:XBRKI]ELPFLG = [V]CST_AYES
    Gosub ELAPSED
  Else
    Gosub START
  Endif

  FreeGroup SFTTXN
  Kill SFTTXN

Return

######################################################################################
$ELAPSED
  Local Integer   INDTYP(1)
  Local Char      BRKCOD(3)(1), ACTTYP(3)(1)
  Local Decimal   DURATION(1)

  BRKCOD(0) = [M:XBRKI]BRKCOD
  INDTYP(0) = 2
  DURATION(0) = [M:XBRKI]DURATION
  ACTTYP(0) = "EBK"
  NUMJOBS(0) = 1

  If fmet SFTTXN.TIME_TRACKING([M:XBRKI]EMPNUM, [M:XBRKI]FCY, BRKCOD, INDTYP,
&                                       INTBLANK, NUMJOBS, CHARBLANK, CHARBLANK,
&                                       DURATION, DECBLANK, DECBLANK, ACTTYP,
&                                       DECBLANK, INTBLANK, INTBLANK, 1)

    Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(3,2416,1)))) From GESECRAN
    Return
  Endif

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XBRKI]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES1(mess(90,2422,1),tolower(mess(3,2416,1)))) From GESECRAN
Return

######################################################################################
$START
  If fmet SFTTXN.BREAK_START([M:XBRKI]EMPNUM, [M:XBRKI]FCY, 3, [M:XBRKI]BRKCOD, 2) <> [V]CST_AOK
    Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(3,2416,1)))) From GESECRAN
    Return
  Endif

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XBRKI]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES2(mess(77,2422,1), [M:XBRKI]BRKCOD, OTIME) ) From GESECRAN
Return

######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Local Integer EMPTYP
  Local File TABMAT [TMA]

  Read [TMA]TMA0=VALEUR
  If fstat # Check if record exists
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 1
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  LogicClose File [TMA]

  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO # Are they active
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 1
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB

  #Check if an employee or team is on a break or on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 1
    End
  Endif



End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Raz [M:XBRKI]BRKCOD
  Raz [M:XBRKI]DURATION

  Local File TABMAT [TMA]

  Read [TMA]TMA0=VALEUR

  [M:XBRKI]EMPDES = [F:TMA]EMPDES
  [M:XBRKI]FCY    = [F:TMA]DEFFCY
  [M:XBRKI]EMPTYP = [F:TMA]EMPTYP

  If [F:TMA]ELPFLG = [V]CST_AYES
    Local Char PARAMRET(4)
    Raz PARAMRET
    # check if clock in is needed for this site
    Call PARAM([M:XBRKI]FCY,"SFTELPDEF",PARAMRET) From ADOVAL

    If val([L]PARAMRET) = [V]CST_AYES
      [M:XBRKI]ELPFLG = [V]CST_AYES
      Actzo [M:XBRKI]DURATION
    Else
      [M:XBRKI]ELPFLG = [V]CST_ANO
      Grizo [M:XBRKI]DURATION
    Endif
    [M:XBRKI]WELPFLG = mess(870,197,1)
    [M:XBRKI]WDURATION = mess(881,197,1)
    [M:XBRKI]WUOM = mess(882,197,1)
    Actzo [M:XBRKI]ELPFLG
    Affzo [M:XBRKI]
  Else
    Grizo [M:XBRKI]ELPFLG
    Grizo [M:XBRKI]DURATION
    Raz [M:XBRKI]WELPFLG
    Raz [M:XBRKI]WDURATION
    Raz [M:XBRKI]WUOM
    Affzo [M:XBRKI]
  Endif

  LogicClose File [TMA]

End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  Local Char PARAMRET(4)
  Raz PARAMRET
  # check if clock in is needed for this site
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:XBRKI]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:XBRKI]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:XBRKI]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:XBRKI]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:XBRKI]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:XBRKI]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog C_BRKCOD(VALEUR)
Variable Char    VALEUR()

  Local File SFTINDREF [SFTIR]
  Read [SFTIR]SFTAG0  = VALEUR

  If ([SFTIR]INDTYP <> 2)
    GMESSAGE = func AFNC.MES1(mess(81,2422,1), VALEUR)
    mkstat = 1
    End
  Endif
  LogicClose File [SFTIR]

End

######################################################################################
Subprog C_DURATION(VALEUR)
Variable Decimal VALEUR

    If [M:XBRKI]ELPFLG = [V]CST_AYES and VALEUR = 0
    GMESSAGE = mess(92,2422,1)
    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  #CT-2297 sn
  #[M:XBRKI]ELPFLG initialized to zero if employee's [TMA]ELPFLG is unchecked
  If [M:XBRKI]ELPFLG <> 0
  Local Char PARAMRET(4)
  Raz PARAMRET
    Call PARAM(VALEUR,"SFTELPDEF",PARAMRET) From ADOVAL
  Actzo [M:XBRKI]ELPFLG

  If val([L]PARAMRET) = [V]CST_AYES
    [M:XBRKI]ELPFLG = [V]CST_AYES
    Actzo [M:XBRKI]DURATION
  Else
    Grizo [M:XBRKI]DURATION
      [M:XBRKI]ELPFLG = [V]CST_ANO
    Endif
  Endif
  #CT-2297 en
  Affzo [M:XBRKI]

End

######################################################################################
Subprog AM_ELPFLG(VALEUR)
Variable Integer    VALEUR()

  If VALEUR = [V]CST_AYES
    Actzo [M:XBRKI]DURATION
  Else
    Grizo [M:XBRKI]DURATION
  Endif

End


######################################################################################

