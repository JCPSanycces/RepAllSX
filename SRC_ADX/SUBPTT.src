#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################
# SUBPTT : Transactions de saisie des commandes ouvertes              #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:PTR]PURTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 3 écrans de saisie à partir des écrans de base POC1   #
#                                                              POC2   #
#                                                              POC3   #
#                                                              POC4   #
# Nom des écrans générés : WExyyyyyz                                  #
#                            x = 1 pour appels d'offre                #
#                                2 pour demandes d'achat              #
#                                3 pour commandes standard            #
#                                5 pour commandes ouvertes            #
#                                8 pour factures / avoirs             #
#                                                                     #
#                        yyyyy = nom de la transaction (PTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0 et 1 pour appels d'offre           #
#                                1 pour demandes d'achat              #
#                                1, 2 et 3 pour commandes standards   #
#                                9 pour commandes par article         #
#                                0 à  2 pour commandes ouvertes       #
#                                0, 1, 2, 3 et 4 pour factures/avoirs #
#######################################################################

Call OBJET("PTT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=5
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
                      Gosub INVISIBLE # Issue 120000 - 2016-11-25 by SR
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PTT0]PTRTYP=5
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="PURTRS" & IDENT1=num$([F:PTR]PTRTYP) & IDENT2=[F:PTR]PTRNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="PTR"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "FERME"       : Call IMPSCR From ATRTX3
 When Default
Endcase
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char APPLI
APPLI=nomap
Return

#-----------------------------------------------------------#
# Ne traiter que les transactions de type commande ouverte  #
#-----------------------------------------------------------#
$FILTRE
FILTSUP="PTRTYP=5"
Return

# Issue 120000 - 2016-11-25 by SR : Non exploité en commandes ouvertes
$INVISIBLE
Chgfmt [M:PTX4]CPRCOECOD       With "-N:1#"
Chgfmt [M:PTX4]CPRCOESCR       With "-N:1#"
Chgfmt [M:PTX4]STCNUMCOD       With "-N:1#"
Chgfmt [M:PTX4]STCNUMSCR       With "-N:1#"
Chgfmt [M:PTX4]CSTPURCOD       With "-N:1#"
Chgfmt [M:PTX4]CSTPURSCR       With "-N:1#"
Chgfmt [M:PTX4]CPRCOD          With "-N:1#"
Chgfmt [M:PTX4]CPRSCR          With "-N:1#"
Chgfmt [M:PTX4]REACSTPURCOD    With "-N:1#"
Chgfmt [M:PTX4]REACSTPURSCR    With "-N:1#"
Chgfmt [M:PTX4]QTYWEUCOD       With "-N:1#"
Chgfmt [M:PTX4]QTYWEUSCR       With "-N:1#"
Chgfmt [M:PTX4]QTYVOUCOD       With "-N:1#"
Chgfmt [M:PTX4]QTYVOUSCR       With "-N:1#"

Return
# End issue 120000

#---------------------------------------------#
# Désactivation bouton "Validation" et "Copie #
#---------------------------------------------#
$SETBOUT
If GREP<>"" | !CLECUR | GHISTO
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
#----- Suppression de l'option "Changement de clé" -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#----------------------------------------#
# Après lecture de chaque enregistrement #
#----------------------------------------#
$LIENS
If [M:PTT1]LEDTYPSCR=0  [M:PTT1]LEDTYPSCR=1  : Endif
#-----
If dim([M:PTT1]NBLEDTYP)>0 & len(mess(0,2644,1))>0
  If [M:PTT1]NBLEDTYP=0  [M:PTT1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTT1]15 : Endif
  For nolign=1 To [M:PTT1]NBLEDTYP
    If [M:PTT1]LEDTYPCOD(nolign-1)=0  [M:PTT1]LEDTYPCOD(nolign-1)=1 : Endif
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTT1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTT1]LEDTYPCOD(nolign-1)
      Chgstl [PTT1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Endif
  Next nolign
Endif
#-----
[M:PTT1]BPSINVCOD =[F:PTR]BPSCOD(1)
[M:PTT1]BPRPAYCOD =[F:PTR]BPSCOD(2)
# Issue 71069 - 2016-02-01 by MUARN : pjt entête
If [M:PTT1]PJTHCOD=0  [M:PTT1]PJTHCOD=3  : Endif
# Issue 112754 - 2016-10-18 by SR : Services
If [M:PTT2]ITMKNDCOD=0  [M:PTT2]ITMKNDCOD=2  : Endif
[M:PTT2]ITMDES1COD=[F:PTR]ITMDESCOD(1)
If dim([M:PTX4]DISCRGCOD1)>0
  [M:PTX4]DISCRGCOD1=[F:PTR]DISCRGCOD(0)
  [M:PTX4]DISCRGSCR1=[F:PTR]DISCRGSCR(0)
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  [M:PTX4]DISCRGCOD2=[F:PTR]DISCRGCOD(1)
  [M:PTX4]DISCRGSCR2=[F:PTR]DISCRGSCR(1)
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  [M:PTX4]DISCRGCOD3=[F:PTR]DISCRGCOD(2)
  [M:PTX4]DISCRGSCR3=[F:PTR]DISCRGSCR(2)
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  [M:PTX4]DISCRGCOD4=[F:PTR]DISCRGCOD(3)
  [M:PTX4]DISCRGSCR4=[F:PTR]DISCRGSCR(3)
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  [M:PTX4]DISCRGCOD5=[F:PTR]DISCRGCOD(4)
  [M:PTX4]DISCRGSCR5=[F:PTR]DISCRGSCR(4)
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  [M:PTX4]DISCRGCOD6=[F:PTR]DISCRGCOD(5)
  [M:PTX4]DISCRGSCR6=[F:PTR]DISCRGSCR(5)
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  [M:PTX4]DISCRGCOD7=[F:PTR]DISCRGCOD(6)
  [M:PTX4]DISCRGSCR7=[F:PTR]DISCRGSCR(6)
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  [M:PTX4]DISCRGCOD8=[F:PTR]DISCRGCOD(7)
  [M:PTX4]DISCRGSCR8=[F:PTR]DISCRGSCR(7)
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  [M:PTX4]DISCRGCOD9=[F:PTR]DISCRGCOD(8)
  [M:PTX4]DISCRGSCR9=[F:PTR]DISCRGSCR(8)
Endif
#-----
If [M:PTT0]ENAFLG=0 [M:PTT0]ENAFLG=2 : Endif
If [M:PTT1]DEPCOD=0     [M:PTT1]DEPCOD=1     : Endif : # Escompte
If [M:PTT1]INVDTACOD=0  [M:PTT1]INVDTACOD=1  : Endif : # Eléments facturation
If [M:PTT1]STAFLG=0     [M:PTT1]STAFLG=2     : Endif : # Etat de la commande
If [M:PTT1]PRISCR=0     [M:PTT1]PRISCR=1     : Endif
If [M:PTT1]BPSINVCOD=0  [M:PTT1]BPSINVCOD=3  : Endif : # Fournisseur facturant
If [M:PTT1]BPRPAYCOD=0  [M:PTT1]BPRPAYCOD=3  : Endif : # Tiers payé
If [M:PTT1]VACBPRCOD=0  [M:PTT1]VACBPRCOD=1  : Endif : # Régime taxe
If [M:PTT1]INVFCYCOD=0  [M:PTT1]INVFCYCOD=1  : Endif : # Site facturation
If [M:PTT2]ITMDESCOD=0  [M:PTT2]ITMDESCOD=1  : Endif : # Désignation article traduite
If [M:PTT2]ITMDES1COD=0 [M:PTT2]ITMDES1COD=3 : Endif : # Désignation article standard
# Issue 112754 - 2016-10-18 by SR : Services
If [M:PTT2]ITMKNDCOD=0  [M:PTT2]ITMKNDCOD=2  : Endif : # Type d'article
#                                                   # hcb 71276 deb
If dim([M:PTT2]ECCCOD)>0 &  [M:PTT2]ECCCOD=0
    [M:PTT2]ECCCOD=1
Endif
If dim([M:PTT2]ECCCODMIN)>0 &  [M:PTT2]ECCCODMIN=0
    [M:PTT2]ECCCODMIN=1
Endif
#                                                   # hcb 71276 end

If [M:PTT2]STOFCYCOD=0  [M:PTT2]STOFCYCOD=1  : Endif : # Site d'expédition
If [M:PTT2]RCPADDCOD=0  [M:PTT2]RCPADDCOD=1  : Endif : # Adresse site réception
# Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#If [M:PTT2]PJTSCR=0     [M:PTT2]PJTSCR=1     : Endif
If [M:PTT2]ACCCOD=0     [M:PTT2]ACCCOD=1     : Endif : # Compte général
If [M:PTT2]PURTYPCOD=0  [M:PTT2]PURTYPCOD=1  : Endif : # Type d'achat
If GACTDEB=2 & dim([M:PTT2]EECINCSCR)>0
  If [M:PTT2]EECINCSCR=0  [M:PTT2]EECINCSCR=1  : Endif
Endif
If [M:PTT2]ORICRYSCR=0  [M:PTT2]ORICRYSCR=1  : Endif
If [M:PTT2]QUAFLGSCR=0  [M:PTT2]QUAFLGSCR=1  : Endif
If dim([M:PTX4]DISCRGCOD1)>0
  If [M:PTX4]DISCRGCOD1=0 [M:PTX4]DISCRGCOD1=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  If [M:PTX4]DISCRGCOD2=0 [M:PTX4]DISCRGCOD2=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  If [M:PTX4]DISCRGCOD3=0 [M:PTX4]DISCRGCOD3=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  If [M:PTX4]DISCRGCOD4=0 [M:PTX4]DISCRGCOD4=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  If [M:PTX4]DISCRGCOD5=0 [M:PTX4]DISCRGCOD5=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  If [M:PTX4]DISCRGCOD6=0 [M:PTX4]DISCRGCOD6=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  If [M:PTX4]DISCRGCOD7=0 [M:PTX4]DISCRGCOD7=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  If [M:PTX4]DISCRGCOD8=0 [M:PTX4]DISCRGCOD8=1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  If [M:PTX4]DISCRGCOD9=0 [M:PTX4]DISCRGCOD9=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR1)>0
  If [M:PTX4]DISCRGSCR1=0 [M:PTX4]DISCRGSCR1=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR2)>0
  If [M:PTX4]DISCRGSCR2=0 [M:PTX4]DISCRGSCR2=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR3)>0
  If [M:PTX4]DISCRGSCR3=0 [M:PTX4]DISCRGSCR3=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR4)>0
  If [M:PTX4]DISCRGSCR4=0 [M:PTX4]DISCRGSCR4=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR5)>0
  If [M:PTX4]DISCRGSCR5=0 [M:PTX4]DISCRGSCR5=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR6)>0
  If [M:PTX4]DISCRGSCR6=0 [M:PTX4]DISCRGSCR6=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR7)>0
  If [M:PTX4]DISCRGSCR7=0 [M:PTX4]DISCRGSCR7=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR8)>0
  If [M:PTX4]DISCRGSCR8=0 [M:PTX4]DISCRGSCR8=1 : Endif
Endif
If dim([M:PTX4]DISCRGSCR9)>0
  If [M:PTX4]DISCRGSCR9=0 [M:PTX4]DISCRGSCR9=1 : Endif
Endif
If [M:PTT1]PRIFLG=1    Grizo [PTT1]PRISCR    Else Actzo [PTT1]PRISCR    : Endif
# Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#If [M:PTT2]PJTCOD=3    Grizo [PTT2]PJTSCR    Else Actzo [PTT2]PJTSCR    : Endif
If GACTDEB=2 & dim([M:PTT2]EECINCCOD)>0 & dim([M:PTT2]EECINCSCR)>0
  If [M:PTT2]EECINCCOD=3 Grizo [PTT2]EECINCSCR Else Actzo [PTT2]EECINCSCR : Endif
Endif

If [M:PTT2]ORICRYCOD=3 Grizo [PTT2]ORICRYSCR Else Actzo [PTT2]ORICRYSCR : Endif
If [M:PTT2]QUAFLGCOD=3 Grizo [PTT2]QUAFLGSCR Else Actzo [PTT2]QUAFLGSCR : Endif
If dim([M:PTX4]DISCRGCOD1)>0
  If [M:PTX4]DISCRGCOD1=3 Grizo [PTX4]DISCRGSCR1 Else Actzo [PTX4]DISCRGSCR1 : Endif
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  If [M:PTX4]DISCRGCOD2=3 Grizo [PTX4]DISCRGSCR2 Else Actzo [PTX4]DISCRGSCR2 : Endif
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  If [M:PTX4]DISCRGCOD3=3 Grizo [PTX4]DISCRGSCR3 Else Actzo [PTX4]DISCRGSCR3 : Endif
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  If [M:PTX4]DISCRGCOD4=3 Grizo [PTX4]DISCRGSCR4 Else Actzo [PTX4]DISCRGSCR4 : Endif
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  If [M:PTX4]DISCRGCOD5=3 Grizo [PTX4]DISCRGSCR5 Else Actzo [PTX4]DISCRGSCR5 : Endif
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  If [M:PTX4]DISCRGCOD6=3 Grizo [PTX4]DISCRGSCR6 Else Actzo [PTX4]DISCRGSCR6 : Endif
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  If [M:PTX4]DISCRGCOD7=3 Grizo [PTX4]DISCRGSCR7 Else Actzo [PTX4]DISCRGSCR7 : Endif
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  If [M:PTX4]DISCRGCOD8=3 Grizo [PTX4]DISCRGSCR8 Else Actzo [PTX4]DISCRGSCR8 : Endif
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  If [M:PTX4]DISCRGCOD9=3 Grizo [PTX4]DISCRGSCR9 Else Actzo [PTX4]DISCRGSCR9 : Endif
Endif
Gosub PE_PURTRS From SUBPTX
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
[M:PTT0]PTRTYP= 5
[M:PTT0]ENAFLG= 2
#-----
If [M:PTT1]LEDTYPSCR=0  [M:PTT1]LEDTYPSCR=1  : Endif
#-----
If dim([M:PTT1]NBLEDTYP)>0 & len(mess(0,2644,1))>0
  If [M:PTT1]NBLEDTYP=0  [M:PTT1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTT1]15 : Endif
  For nolign=1 To [M:PTT1]NBLEDTYP
    [M:PTT1]LEDTYPINT(nolign-1)=nolign
    If func TRTX3CPT.TYPLEDAUTO(nolign)
      [M:PTT1]LEDTYPCOD(nolign-1)=3
      Grizo  [PTT1]LEDTYPCOD(nolign-1)
      Chgstl [PTT1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Else
      [M:PTT1]LEDTYPCOD(nolign-1)=1
    Endif
  Next nolign
Endif
#-----
[M:PTT1]INVDTACOD=1
[M:PTT1]STAFLG=1
[M:PTT1]PRIFLG=1
[M:PTT1]PRISCR=1
Grizo [PTT1]PRISCR
#-----
[M:PTT1]BPSINVCOD=3
[M:PTT1]BPRPAYCOD=3
[M:PTT1]BUYCOD=1
# Issue 71069 - 2016-02-01 by MUARN : pjt entête
[M:PTT1]PJTHCOD=1
[M:PTT1]ORDREFCOD=1
[M:PTT1]PTECOD=1
[M:PTT1]DEPCOD=1
[M:PTT1]CURCOD=1
[M:PTT1]MDLCOD=1
[M:PTT1]BPTCOD=1
[M:PTT1]VACBPRCOD=1
[M:PTT1]INVFCYCOD=1
[M:PTT1]OCNDATCOD=1
[M:PTT1]OCNNUMCOD=1
[M:PTT1]OCNREMCOD=1
#-----
[M:PTT2]ITMDESCOD=1
[M:PTT2]ITMDES1COD=1
# Issue 112754 - 2016-10-18 by SR : Services
[M:PTT2]ITMKNDCOD=2
[M:PTT2]STOFCYCOD=1
[M:PTT2]RCPFCYCOD=1
[M:PTT2]RCPADDCOD=1
[M:PTT2]USEPLCCOD=1
[M:PTT2]EXTQTYCOD=1
[M:PTT2]PLICOD=1
[M:PTT2]PJTCOD=1
# Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#[M:PTT2]PJTSCR=1
[M:PTT2]ACCCOD=1
[M:PTT2]PURTYPCOD=1
If GACTDEB=2
  If dim([M:PTT2]EECINCCOD)>0  [M:PTT2]EECINCCOD=1 : Endif
  If dim([M:PTT2]EECINCSCR)>0  [M:PTT2]EECINCSCR=1 : Endif
Endif
[M:PTT2]ORICRYCOD=1
[M:PTT2]ORICRYSCR=1
[M:PTT2]QUAFLGCOD=1
[M:PTT2]QUAFLGSCR=1
#                                            # hcb 72176 deb
If dim([M:PTT2]ECCCOD)>0
  [M:PTT2]ECCCOD=1
Endif
If dim([M:PTT2]ECCCODMIN)>0
  [M:PTT2]ECCCODMIN=1
Endif
#                                            # hcb 72176 fin

#---
If dim([M:PTX4]DISCRGCOD1)>0
  [M:PTX4]DISCRGCOD1=1
  [M:PTX4]DISCRGSCR1=1
  Actzo [PTX4]DISCRGSCR1
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  [M:PTX4]DISCRGCOD2=1
  [M:PTX4]DISCRGSCR2=1
  Actzo [PTX4]DISCRGSCR2
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  [M:PTX4]DISCRGCOD3=1
  [M:PTX4]DISCRGSCR3=1
  Actzo [PTX4]DISCRGSCR3
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  [M:PTX4]DISCRGCOD4=1
  [M:PTX4]DISCRGSCR4=1
  Actzo [PTX4]DISCRGSCR4
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  [M:PTX4]DISCRGCOD5=1
  [M:PTX4]DISCRGSCR5=1
  Actzo [PTX4]DISCRGSCR5
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  [M:PTX4]DISCRGCOD6=1
  [M:PTX4]DISCRGSCR6=1
  Actzo [PTX4]DISCRGSCR6
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  [M:PTX4]DISCRGCOD7=1
  [M:PTX4]DISCRGSCR7=1
  Actzo [PTX4]DISCRGSCR7
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  [M:PTX4]DISCRGCOD8=1
  [M:PTX4]DISCRGSCR8=1
  Actzo [PTX4]DISCRGSCR8
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  [M:PTX4]DISCRGCOD9=1
  [M:PTX4]DISCRGSCR9=1
  Actzo [PTX4]DISCRGSCR9
Endif
#---
# Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#Actzo [PTT2]PJTSCR, ORICRYSCR, QUAFLGSCR
Actzo [PTT2]ORICRYSCR, QUAFLGSCR
If GACTDEB=2 & dim([M:PTT2]EECINCSCR)>0  Actzo [PTT2]EECINCSCR : Endif
Gosub PE_PURTRS From SUBPTX
Affzo [PTT0]ENAFLG
Affzo [PTT1]1-99
Affzo [PTT2]1-99
Affzo [PTX4]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "PRIFLG"
       If val(CZ)=1
         [M:PTT1]PRISCR=1
         If !GIMPORT Affzo [PTT1]PRISCR    : Grizo [PTT1]PRISCR    : Endif
       Elsif !GIMPORT
         Actzo [PTT1]PRISCR
       Endif
# Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#  When "PJTCOD"
#       If val(CZ)=3
#         [M:PTT2]PJTSCR=1
#         If !GIMPORT Affzo [PTT2]PJTSCR    : Grizo [PTT2]PJTSCR    : Endif
#       Elsif !GIMPORT
#         Actzo [PTT2]PJTSCR
#       Endif
  When "EECINCCOD"
       If GACTDEB=2 & dim([M:PTT2]EECINCSCR)>0
         If val(CZ)=3
           [M:PTT2]EECINCSCR=1
           If !GIMPORT Affzo [PTT2]EECINCSCR : Grizo [PTT2]EECINCSCR : Endif
         Elsif !GIMPORT
           Actzo [PTT2]EECINCSCR
         Endif
       Endif
  When "ORICRYCOD"
       If val(CZ)=3
         [M:PTT2]ORICRYSCR=1
         If !GIMPORT Affzo [PTT2]ORICRYSCR : Grizo [PTT2]ORICRYSCR : Endif
       Elsif !GIMPORT
         Actzo [PTT2]ORICRYSCR
       Endif
#                                                  # hcb 71276 deb
  When "ECCCOD"
       If val(CZ) = 2 & [M:PTT2]ECCCODMIN=1
           [M:PTT2]ECCCODMIN = 2
           If !GIMPORT Affzo [PTT2]ECCCODMIN : Endif
       Endif
       If val(CZ)=3
         [M:PTT2]ECCCODMIN = 3
         If !GIMPORT Affzo [PTT2]ECCCODMIN : Grizo [PTT2]ECCCODMIN : Endif
       Elsif !GIMPORT
         Actzo [PTT2]ECCCODMIN
       Endif
#                                                  # hcb 71276 fin

  When "QUAFLGCOD"
       If val(CZ)=3
         [M:PTT2]QUAFLGSCR=1
         If !GIMPORT Affzo [PTT2]QUAFLGSCR : Grizo [PTT2]QUAFLGSCR : Endif
       Elsif !GIMPORT
         Actzo [PTT2]QUAFLGSCR
       Endif
  When "DISCRGCOD1"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR1=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR1 : Grizo [PTX4]DISCRGSCR1 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR1
       Endif
  When "DISCRGCOD2"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR2=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR2 : Grizo [PTX4]DISCRGSCR2 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR2
       Endif
  When "DISCRGCOD3"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR3=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR3 : Grizo [PTX4]DISCRGSCR3 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR3
       Endif
  When "DISCRGCOD4"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR4=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR4 : Grizo [PTX4]DISCRGSCR4 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR4
       Endif
  When "DISCRGCOD5"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR5=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR5 : Grizo [PTX4]DISCRGSCR5 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR5
       Endif
  When "DISCRGCOD6"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR6=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR6 : Grizo [PTX4]DISCRGSCR6 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR6
       Endif
  When "DISCRGCOD7"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR7=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR7 : Grizo [PTX4]DISCRGSCR7 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR7
       Endif
  When "DISCRGCOD8"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR8=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR8 : Grizo [PTX4]DISCRGSCR8 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR8
       Endif
  When "DISCRGCOD9"
       If val(CZ)=3
         [M:PTX4]DISCRGSCR9=1
         If !GIMPORT Affzo [PTX4]DISCRGSCR9 : Grizo [PTX4]DISCRGSCR9 : Endif
       Elsif !GIMPORT
         Actzo [PTX4]DISCRGSCR9
       Endif
  When Default
       Gosub PE_PURTRS From SUBPTX
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARG_COMPLEMENT
[F:PTR]BPSCOD(1)=[M:PTT1]BPSINVCOD
[F:PTR]BPSCOD(2)=[M:PTT1]BPRPAYCOD
Gosub CHARGE_ATEXTRA From SUBPTT
Gosub PE_PURTRS      From SUBPTX
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
Gosub CHARG_COMPLEMENT
[F:PTR]BPSCOD(1)=[M:PTT1]BPSINVCOD
[F:PTR]BPSCOD(2)=[M:PTT1]BPRPAYCOD
Return

#---------------------------#
# Chargement complémentaire #
#---------------------------#
$CHARG_COMPLEMENT
[F:PTR]BPSCOD(1)   =[M:PTT1]BPSINVCOD
[F:PTR]BPSCOD(2)   =[M:PTT1]BPRPAYCOD
[F:PTR]ITMDESCOD(1)=[M:PTT2]ITMDES1COD
If dim([M:PTX4]DISCRGCOD1)>0
  [F:PTR]DISCRGCOD(0)=[M:PTX4]DISCRGCOD1
  [F:PTR]DISCRGSCR(0)=[M:PTX4]DISCRGSCR1
Endif
If dim([M:PTX4]DISCRGCOD2)>0
  [F:PTR]DISCRGCOD(1)=[M:PTX4]DISCRGCOD2
  [F:PTR]DISCRGSCR(1)=[M:PTX4]DISCRGSCR2
Endif
If dim([M:PTX4]DISCRGCOD3)>0
  [F:PTR]DISCRGCOD(2)=[M:PTX4]DISCRGCOD3
  [F:PTR]DISCRGSCR(2)=[M:PTX4]DISCRGSCR3
Endif
If dim([M:PTX4]DISCRGCOD4)>0
  [F:PTR]DISCRGCOD(3)=[M:PTX4]DISCRGCOD4
  [F:PTR]DISCRGSCR(3)=[M:PTX4]DISCRGSCR4
Endif
If dim([M:PTX4]DISCRGCOD5)>0
  [F:PTR]DISCRGCOD(4)=[M:PTX4]DISCRGCOD5
  [F:PTR]DISCRGSCR(4)=[M:PTX4]DISCRGSCR5
Endif
If dim([M:PTX4]DISCRGCOD6)>0
  [F:PTR]DISCRGCOD(5)=[M:PTX4]DISCRGCOD6
  [F:PTR]DISCRGSCR(5)=[M:PTX4]DISCRGSCR6
Endif
If dim([M:PTX4]DISCRGCOD7)>0
  [F:PTR]DISCRGCOD(6)=[M:PTX4]DISCRGCOD7
  [F:PTR]DISCRGSCR(6)=[M:PTX4]DISCRGSCR7
Endif
If dim([M:PTX4]DISCRGCOD8)>0
  [F:PTR]DISCRGCOD(7)=[M:PTX4]DISCRGCOD8
  [F:PTR]DISCRGSCR(7)=[M:PTX4]DISCRGSCR8
Endif
If dim([M:PTX4]DISCRGCOD9)>0
  [F:PTR]DISCRGCOD(8)=[M:PTX4]DISCRGCOD9
  [F:PTR]DISCRGSCR(8)=[M:PTX4]DISCRGSCR9
Endif
#-----
Gosub CHARGE_ATEXTRA From SUBPTT
Gosub PE_PURTRS      From SUBPTX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:PTT0]DESAXX,"PURTRS","DESAXX",num$([M:PTT0]PTRTYP),[M:PTT0]PTRNUM) From ATEXTRA
[F:PTR]PTRDES   =GLANGUE+"~"+[M:PTT0]DESAXX
[F:PTR]PTRTYPCAR=num$([F:PTR]PTRTYP)
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char    APPLI : Endif
If dim(OK)<0    Local Integer OK    : Endif
If APPLI="" APPLI=nomap : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO  (GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG, WINTIT
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
#----- Noms fenêtres et traitement -----#
Local Char     WINREF(GLONFEN)  : WINREF="OPOC"
Local Char     NOMWIN(GLONFEN)  : NOMWIN="WOPOC"+[M:PTT0]PTRNUM
#----- Modif écran de base pour ajout libellé sur champ ITMDES1 -----#
If [M:PTT2]ITMDESCOD=3 & [M:PTT2]ITMDES1COD<>3
   Gosub MODIF_ITMDES1 : If GOK<1 Return : Endif
Endif
#----- 1er écran -----#
MFROM="POC1"
MTO="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:PTT1]BPSINVCOD>1 TZONE(IZON)="BPSINV"
                          TMOD(IZON) =[M:PTT1]BPSINVCOD
                          IZON+=1
                          TZONE(IZON)="BPAINV"
                          TMOD(IZON) =[M:PTT1]BPSINVCOD
                          IZON+=1
   Endif
   If [M:PTT1]BPRPAYCOD>1 TZONE(IZON)="BPRPAY"
                          TMOD(IZON) =[M:PTT1]BPRPAYCOD
                          IZON+=1
                          TZONE(IZON)="BPAPAY"
                          TMOD(IZON) =[M:PTT1]BPRPAYCOD
                          IZON+=1
   Endif
   If [M:PTT1]PTECOD>1    TZONE(IZON)="PTE"
                          TMOD(IZON) =[M:PTT1]PTECOD
                          IZON+=1
   Endif
   If [M:PTT1]DEPCOD>1    TZONE(IZON)="DEP"
                          TMOD(IZON) =[M:PTT1]DEPCOD
                          IZON+=1
   Endif
   If [M:PTT1]CURCOD>1    TZONE(IZON)="CUR"
                          TMOD(IZON) =[M:PTT1]CURCOD
                          IZON+=1
                          TZONE(IZON)="CHGTYP"
                          TMOD(IZON) =[M:PTT1]CURCOD
                          IZON+=1
   Endif
   If [M:PTT1]CURCOD=2    TBLOC(2)=2
   Endif
   If [M:PTT1]CURCOD=3    TBLOC(2)=1
   Endif
   If [M:PTT1]BUYCOD>1    TZONE(IZON)="BUY"
                          TMOD(IZON) =[M:PTT1]BUYCOD
                          IZON+=1
   Endif
   # Issue 71069 - 2016-02-01 by MUARN : pjt entête
   If [M:PTT1]PJTHCOD>1   TZONE(IZON)="PJTH"
                          TMOD(IZON) =[M:PTT1]PJTHCOD
                          IZON+=1
   Endif
   If [M:PTT2]RCPFCYCOD>1  TZONE(IZON)="RCPFCY"
                           TMOD(IZON) =[M:PTT2]RCPFCYCOD
                           IZON+=1
   Endif

   If [M:PTT2]STOFCYCOD>1  TZONE(IZON)="STOFCY"
                           TMOD(IZON) =[M:PTT2]STOFCYCOD
                           IZON+=1
   Endif
   If [M:PTT1]INVFCYCOD>1 TZONE(IZON)="INVFCY"
                          TMOD(IZON) =[M:PTT1]INVFCYCOD
                          IZON+=1
   Endif
   If [M:PTT1]MDLCOD>1    TZONE(IZON)="MDL"
                          TMOD(IZON) =[M:PTT1]MDLCOD
                          IZON+=1
   Endif
   If [M:PTT1]BPTCOD>1    TZONE(IZON)="BPTNUM"
                          TMOD(IZON) =[M:PTT1]BPTCOD
                          IZON+=1
   Endif
   If [M:PTT1]VACBPRCOD>1 TZONE(IZON)="VACBPR"
                          TMOD(IZON) =[M:PTT1]VACBPRCOD
                          IZON+=1
   Endif
   If [M:PTT1]MDLCOD=2 &
&     [M:PTT1]BPTCOD=2 &
&     [M:PTT1]VACBPRCOD=2 TBLOC(4)=2
   Endif
   If [M:PTT1]MDLCOD=3 &
&     [M:PTT1]BPTCOD=3 &
&     [M:PTT1]VACBPRCOD=3 TBLOC(4)=1
   Endif
   #----- Test si les sections d'entête sont affichées -----#
   If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
      TBLOC(5)=2
      TZONE(IZON)="CCE"
      TMOD(IZON)=2
      IZON+=1
   Endif
   #----- Test si les sections d'entête sont invisibles -----#
   If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
      TBLOC(5)=1
      TZONE(IZON)="CCE"
      TMOD(IZON)=3
      IZON+=1
   Endif
   #----- Etat de la commande (signée-imprimée-soldée-recue-facturée) -----#
   If [M:PTT1]STAFLG=1    TZONE(IZON)="APPFLG"
                          TMOD(IZON) = 3
                          IZON+=1
                          TZONE(IZON)="PRNFLG"
                          TMOD(IZON) = 3
                          IZON+=1
                          TZONE(IZON)="CLEFLG"
                          TMOD(IZON) = 3
                          IZON+=1
                          TZONE(IZON)="RCPFLG"
                          TMOD(IZON) = 3
                          IZON+=1
                          TZONE(IZON)="INVFLG"
                          TMOD(IZON) = 3
                          IZON+=1
                          TBLOC(6)=1
   Endif
   Gosub PE_PURTRS From SUBPTX
Else
   OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
#----- 2ème écran -----#
MFROM="POC2"
MTO="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
   If [M:PTT2]ITMDESCOD>1  TZONE(IZON)="ITMDES"
                           TMOD(IZON) =[M:PTT2]ITMDESCOD
                           IZON+=1
   Endif
   If [M:PTT2]ITMDES1COD>1 TZONE(IZON)="ITMDES1"
                           TMOD(IZON) =[M:PTT2]ITMDES1COD
                           IZON+=1
   Endif
   # Issue 112754 - 2016-10-18 by SR : Services
  If [M:PTT2]ITMKNDCOD>1  TZONE(IZON)="ITMKND"
                           TMOD(IZON) =[M:PTT2]ITMKNDCOD
                           IZON+=1
   Endif
   # End issue 112754
   If [M:PTT2]STOFCYCOD>1  TZONE(IZON)="LINSTOFCY"
                           TMOD(IZON) =[M:PTT2]STOFCYCOD
                           IZON+=1
   Endif
   If [M:PTT2]RCPFCYCOD>1  TZONE(IZON)="PRHFCY"
                           TMOD(IZON) =[M:PTT2]RCPFCYCOD
                           IZON+=1
   Endif
   If [M:PTT2]RCPADDCOD>1  TZONE(IZON)="FCYADD"
                           TMOD(IZON) =[M:PTT2]RCPADDCOD
                           IZON+=1
   Endif
   If [M:PTT2]USEPLCCOD>1  TZONE(IZON)="USEPLC"
                           TMOD(IZON) =[M:PTT2]USEPLCCOD
                           IZON+=1
   Endif
   If [M:PTT2]EXTQTYCOD>1  TZONE(IZON)="EXTQTYPUU"
                           TMOD(IZON) =[M:PTT2]EXTQTYCOD
                           IZON+=1
                           TZONE(IZON)="PUU"
                           TMOD(IZON) =[M:PTT2]EXTQTYCOD
                           IZON+=1
   Endif
   If [M:PTT2]PLICOD>1     TZONE(IZON)="PLI"
                           TMOD(IZON) =[M:PTT2]PLICOD
                           IZON+=1
   Endif
#                                                                  # hcb 71276 deb
   If dim([M:PTT2]ECCCOD)>0
      If [M:PTT2]ECCCOD>1 TZONE(IZON)="ECCVALMAJ"
                          TMOD(IZON) =[M:PTT2]ECCCOD
                          IZON+=1
      Endif
      If [M:PTT2]ECCCODMIN>1  TZONE(IZON)="ECCVALMIN"
                              TMOD(IZON) =[M:PTT2]ECCCODMIN
                              IZON+=1
      Endif
   Endif

#                                                                  # hcb 71276 fin

   # Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
   If [M:PTT2]PJTCOD>1    TZONE(IZON)="PJT"
                          TMOD(IZON) =[M:PTT2]PJTCOD
                          IZON+=1
   Endif


   #----- Test si les comptes sont affichées -----#
   If [M:PTT2]ACCCOD=2
      TZONE(IZON)="LINACC"
      TMOD(IZON)=2
      TBLOC(3)=2
      IZON+=1
   Endif
   #----- Test si les comptes sont invisibles -----#
   If [M:PTT2]ACCCOD=3
      TBLOC(3)=1
   Endif
   #-----
   If [M:PTT2]PURTYPCOD>1  TZONE(IZON)="LINPURTYP"
                           TMOD(IZON) =[M:PTT2]PURTYPCOD
                           IZON+=1
   Endif
   If dim([M:PTX4]DISCRGCOD1)>0
     If [M:PTX4]DISCRGCOD1>1 TZONE(IZON)="DISCRGVAL1"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD1
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR1>1 TZONE(IZON)="DISCRGVAL1"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR1)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD2)>0
     If [M:PTX4]DISCRGCOD2>1 TZONE(IZON)="DISCRGVAL2"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD2
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR2>1 TZONE(IZON)="DISCRGVAL2"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR2)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD3)>0
     If [M:PTX4]DISCRGCOD3>1 TZONE(IZON)="DISCRGVAL3"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD3
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR3>1 TZONE(IZON)="DISCRGVAL3"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR3)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD4)>0
     If [M:PTX4]DISCRGCOD4>1 TZONE(IZON)="DISCRGVAL4"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD4
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR4>1 TZONE(IZON)="DISCRGVAL4"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR4)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD5)>0
     If [M:PTX4]DISCRGCOD5>1 TZONE(IZON)="DISCRGVAL5"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD5
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR5>1 TZONE(IZON)="DISCRGVAL5"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR5)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD6)>0
     If [M:PTX4]DISCRGCOD6>1 TZONE(IZON)="DISCRGVAL6"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD6
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR6>1 TZONE(IZON)="DISCRGVAL6"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR6)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD7)>0
     If [M:PTX4]DISCRGCOD7>1 TZONE(IZON)="DISCRGVAL7"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD7
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR7>1 TZONE(IZON)="DISCRGVAL7"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR7)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD8)>0
     If [M:PTX4]DISCRGCOD8>1 TZONE(IZON)="DISCRGVAL8"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD8
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR8>1 TZONE(IZON)="DISCRGVAL8"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR8)
                             IZON+=1
     Endif
   Endif
   If dim([M:PTX4]DISCRGCOD9)>0
     If [M:PTX4]DISCRGCOD9>1 TZONE(IZON)="DISCRGVAL9"
                             TMOD(IZON) =[M:PTX4]DISCRGCOD9
                             IZON+=1
     Endif
     If [M:PTX4]DISCRGSCR9>1 TZONE(IZON)="DISCRGVAL9"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:PTX4]DISCRGSCR9)
                             IZON+=1
     Endif
   Endif
   If [M:PTT1]PRIFLG=1    TZONE(IZON)="NETPRI"
                          TMOD(IZON) =3
                          IZON+=1
   Endif
   If [M:PTT1]PRISCR>1    TZONE(IZON)="NETPRI"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTT1]PRISCR)
                          IZON+=1
   Endif
   If [M:DST]CCESCR>1
     For I=0 To 19
       TZONE(IZON)="CCE"+num$(I+1)
       TMOD(IZON) =9
       TINT(IZON) =num$([M:DST]CCESCR)
       IZON+=1
     Next I
   Endif
   # Issue 71069 - 2016-02-01 by MUARN : pjt dans article et non conditions tarifaire
#   If [M:PTT2]PJTCOD>1    TZONE(IZON)="PJT"
#                          TMOD(IZON) =[M:PTT2]PJTCOD
#                          IZON+=1
#   Endif
#   If [M:PTT2]PJTSCR>1    TZONE(IZON)="PJT"
#                          TMOD(IZON) =9
#                          TINT(IZON) =num$([M:PTT2]PJTSCR)
#                          IZON+=1
#   Endif
   If [M:PTT2]QUAFLGCOD>1 TZONE(IZON)="QUAFLG"
                          TMOD(IZON) =[M:PTT2]QUAFLGCOD
                          IZON+=1
   Endif
   If [M:PTT2]QUAFLGSCR>1 TZONE(IZON)="QUAFLG"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTT2]QUAFLGSCR)
                          IZON+=1
   Endif
   If GACTDEB=2
     If dim([M:PTT2]EECINCCOD)>0
       If [M:PTT2]EECINCCOD>1 TZONE(IZON)="EECINCRAT"
                              TMOD(IZON) =[M:PTT2]EECINCCOD
                              IZON+=1
       Endif
     Endif
     If dim([M:PTT2]EECINCSCR)>0
       If [M:PTT2]EECINCSCR>1 TZONE(IZON)="EECINCRAT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:PTT2]EECINCSCR)
                              IZON+=1
       Endif
     Endif
   Endif
   If [M:PTT2]ORICRYCOD>1 TZONE(IZON)="ORICRY"
                          TMOD(IZON) =[M:PTT2]ORICRYCOD
                          IZON+=1
   Endif
   If [M:PTT2]ORICRYSCR>1 TZONE(IZON)="ORICRY"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:PTT2]ORICRYSCR)
                          IZON+=1
   Endif
   Gosub PE_PURTRS From SUBPTX
Endif
#CHECK UNUSED_BEGIN
Gosub PARAM_CTRL_CCE_AV : If GOK<1 Return : Endif
#CHECK UNUSED_END

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR

#CHECK UNUSED_BEGIN
Gosub PARAM_CTRL_CCE_AP : If GOK<1 Return : Endif
#CHECK UNUSED_END

If RETOUR<>0 GOK=0 : Return : Endif
#----- 3ème écran -----#
MFROM="POC3"
MTO="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
   #----- Si élément de facturation invisible -----#
   If [M:PTT1]INVDTACOD=3
     TBLOC(0)=1
   #----- Si élément de facturation affiché -----#
   Elsif [M:PTT1]INVDTACOD=2
     TBLOC(0)=2
   Else
    If dim([M:PTT1]LEDTYPSCR)>0 & [M:PTT1]LEDTYPSCR>1
      For I=0 To 9
        TZONE(IZON)="ACC"+num$(I+1)
        TMOD(IZON) =9
        TINT(IZON) =num$([M:PTT1]LEDTYPSCR)
        IZON+=1
      Next I
    Endif
    If dim([M:DST]DSPCOD)>0 & [M:DST]DSPCOD>1
                          TZONE(IZON)="DSP"
                          TMOD(IZON) =[M:DST]DSPCOD
                          IZON+=1
    Endif
    If dim([M:DST]DSPSCR)>0 & [M:DST]DSPSCR>1
                          TZONE(IZON)="DSP"
                          TMOD(IZON) =9
                          TINT(IZON) =num$([M:DST]DSPSCR)
                          IZON+=1
    Endif
    If [M:DST]CCESCR>1
      For I=0 To 19
        TZONE(IZON)="PFICCE"+num$(I+1)
        TMOD(IZON) =9
        TINT(IZON) =num$([M:DST]CCESCR)
        IZON+=1
      Next I
    Endif
  Endif
  #-----
   If [M:PTT1]OCNDATCOD>1 TZONE(IZON)="OCNDAT"
                          TMOD(IZON) =[M:PTT1]OCNDATCOD
                          IZON+=1
   Endif
   If [M:PTT1]OCNNUMCOD>1 TZONE(IZON)="OCNNUM"
                          TMOD(IZON) =[M:PTT1]OCNNUMCOD
                          IZON+=1
   Endif
   If [M:PTT1]OCNREMCOD>1 TZONE(IZON)="OCNREM"
                          TMOD(IZON) =[M:PTT1]OCNREMCOD
                          IZON+=1
   Endif
   If [M:PTT1]OCNDATCOD=2 &
&     [M:PTT1]OCNNUMCOD=2 &
&     [M:PTT1]OCNREMCOD=2 TBLOC(2)=2
   Endif
   If [M:PTT1]OCNDATCOD=3 &
&     [M:PTT1]OCNNUMCOD=3 &
&     [M:PTT1]OCNREMCOD=3 TBLOC(2)=1
   Endif
#  #----- Si bloc 1 et bloc 3 invisibles alors bloc 2 invisible -----#
   If TBLOC(0)=1 & TBLOC(2)=1  TBLOC(1)=1 : Endif
   Gosub PE_PURTRS From SUBPTX
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
#----- Restauration écran de base -----#
If [M:PTT2]ITMDESCOD=3 & [M:PTT2]ITMDES1COD<>3
   Gosub RESTAUR_ITMDES1 : If GOK<1 Return : Endif
Endif
#-----
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Return

#CHECK UNUSED_BEGIN
#----------------------------------------------------------------------------#
# Changement valeur paramètre WCTLFCY pour ne pas avoir un contrôle bloquant #
# lorsque la saisie des sections analytiques est en fiche uniquement.        #
#----------------------------------------------------------------------------#
$PARAM_CTRL_CCE_AV
If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR" [AMP] : Endif
For I=0 To dim ([M:PTT1]CCECOD)-1
  If [M:PTT1]CCESCR(I)=2
    Update [AMP] Where TYPAFF=1 & CODAFF="POC2" & CODZON="CCE"+num$(I+1) & CODPAR="WCTLFCY"
&                With  VALPAR="8"
    If fstat GOK=0 : Call FSTA("AMP") From GLOCK : Break : Endif
  Endif
Next
Return

#--------------------------------------------------#
# Remise à la valeur initiale du paramètre WCTLFCY #
#--------------------------------------------------#
$PARAM_CTRL_CCE_AP
If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR" [AMP] : Endif
For I=0 To dim ([M:PTT1]CCECOD)-1
  If [M:PTT1]CCESCR(I)=2
    Update [AMP] Where TYPAFF=1 & CODAFF="POC2" & CODZON="CCE"+num$(I+1) & CODPAR="WCTLFCY"
&                With  VALPAR="3"
    If fstat GOK=0 : Call FSTA("AMP") From GLOCK : Break : Endif
  Endif
Next
Return
#CHECK UNUSED_END

#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
Call DELWIN(NOMWIN,APPLI) From MSKDIV
Return

#-------------------------------------------------------------#
# Ajout du libellé au champ ITMDES1 si champ ITMDES invisible #
#-------------------------------------------------------------#
$MODIF_ITMDES1
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMZ] CODE="POC2";"ITMDES"
If fstat Raz [F:AMZ] : Endif
WINTIT=[F:AMZ]INTIT
Readlock [AMZ] CODE="POC2";"ITMDES1"
If fstat=1  GOK=-1 : GLOCK="$AMSKZON POC2 ITMDES1"              : Return
Elsif fstat GOK=0  : Call RSTA("AMZ","POC2 ITMDES1") From GLOCK : Return
Endif
[F:AMZ]INTIT=WINTIT
Rewrite [AMZ] : If fstat GOK=0 : Call FSTA("AMZ") From GLOCK : Return : Endif
Return

#-----------------------------------------#
# Suppression du libellé du champ ITMDES1 #
#-----------------------------------------#
$RESTAUR_ITMDES1
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Readlock [AMZ] CODE="POC2";"ITMDES1"
If fstat=1  GOK=-1 : GLOCK="$AMSKZON POC2 ITMDES1"              : Return
Elsif fstat GOK=0  : Call RSTA("AMZ","POC2 ITMDES1") From GLOCK : Return
Endif
[F:AMZ]INTIT=0
Rewrite [AMZ] : If fstat GOK=0 : Call FSTA("AMZ") From GLOCK : Return : Endif
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNPURTRS
#----- Suppression fenêtre si transaction non active -----#
If [M:PTT0]ENAFLG=1 Gosub TRT_SUP_FEN : Return : Endif
#----- Génération fenêtre si transaction active -----#
Delete [AWI] Where WIN=NOMWIN
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN : Return
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN) From GLOCK : Return
Endif
Delete [AWP] Where WIN=NOMWIN
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN : Return
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN) From GLOCK : Return
Endif
Delete [AWB] Where WIN=NOMWIN
If fstat=1  GOK=-1 : GLOCK="$AWINBRO"-NOMWIN : Return
Elsif fstat GOK=0  : Call RSTA ("AWB",NOMWIN) From GLOCK : Return
Endif
Delete [AWT] Where WIN=NOMWIN
If fstat=1  GOK=-1 : GLOCK="$AWINBOUT"-NOMWIN : Return
Elsif fstat GOK=0  : Call RSTA ("AWT",NOMWIN) From GLOCK : Return
Endif
Read [AWI] AWI0=WINREF
If !fstat
  [F:AWI]WIN       = NOMWIN
  [F:AWI]MSKENT    = "POC0"
  WNOMMSK="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"1" : Gosub ONGLET_INVISIBLE
  I=find("POC1",[F:AWI]NOMMSK)-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  WNOMMSK="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"2" : Gosub ONGLET_INVISIBLE
  I=find("POC2",[F:AWI]NOMMSK)-1 : If I<0 I=1 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  WNOMMSK="WE"+num$([M:PTT0]PTRTYP)+[M:PTT0]PTRNUM+"3" : Gosub ONGLET_INVISIBLE
  I=find("POC3",[F:AWI]NOMMSK)-1 : If I<0 I=2 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:PTT0]ACSCOD
  If dim([F:AWI]LIBEL)>0
    [F:AWI]LIBEL   = [M:PTT0]DESAXX
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]MDL       = 1
  [F:AWI]TRN       = [M:PTT0]PTRNUM
  #----- Point d'entrée PURTRSWIN pour intervention sur fenêtre générée -----#
  Gosub PE_PURTRSWIN From SUBPTX
  #-----
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF
    [F:AWB]WIN = NOMWIN
    #----- Point d'entrée PURTRSAWB pour intervention sur browser de fenêtre générée -----#
    Gosub PE_PURTRSAWB From SUBPTX : #VPO 13/01/11 70621
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWT] AWT0 Where WIN=WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
If !OK  GOK=0 : Endif
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return

Subprog AS_PTRNUM(VALEUR)
#-----------------------#
# Avant saisie document #
#-----------------------#
Variable Char    VALEUR()
[M:PTT0]PTRTYP =5
End

#-----------------------#
# Avant saisie NBLEDTYP #
#-----------------------#
Subprog AS_NBLEDTYP
If [M:PTT1]NBLEDTYP=0
  Local Integer I
  [M:PTT1]NBLEDTYP=len(mess(0,2644,1)) : Affzo [PTT1]10
  For I=1 To [M:PTT1]NBLEDTYP
    If func TRTX3CPT.TYPLEDAUTO(I)
      [M:PTT1]LEDTYPCOD(I-1)=3
      Grizo  [PTT1]LEDTYPCOD(nolign-1)
      Chgstl [PTT1]LEDTYPCOD(nolign-1) With "ITALIQUE"
    Else
      [M:PTT1]LEDTYPCOD(I-1)=1
    Endif
  Next I
Endif
End

#----------------------------------------------------------#
# Après modification du mode saisie du type de référentiel #
#----------------------------------------------------------#
Subprog AM_LEDTYPCOD(VALEUR)
Variable Integer VALEUR
End

#--------------------#
# Avant saisie NBAXE #
#--------------------#
Subprog AS_NBAXE
If NBAXE=0 NBAXE=GOPTCANA : Affzo 10 : Endif
End

#CHECK UNUSED_BEGIN
#------------------------------------#
# Avant saisie du code tableau-fiche #
#------------------------------------#
Subprog AS_CCESCR(VALEUR)
Variable Integer VALEUR
If [M:PTT1]CCECOD(nolign-1)=3 VALEUR=1 : mkstat=2 : Endif
End
#CHECK UNUSED_END

# Issue 112754 - 2016-10-18 by SR : ITMKND non saisissable en commande ouverte
######################################################################################
Subprog AS_ITMKNDCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1) = 1
End

#-------------------------------------#
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(4)
Local Char WABR(4)(4)
#-----
Call TEXTFIC("PURTRS","PTRNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("PURTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:PTT0]PTRNUM-[M:PTT0]DESAXX-WINT(1)+" : "+[M:PTT0]ACSCOD
WMSK(0) = "PTT1"
WMSK(1) = "PTT2"
WMSK(2) = "PTX4"
WMSK(3) = "DIESCRTRS"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
OK=0 : # Pour ne pas imprimer tout de suite !
Return


########################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Local Integer TYP : TYP=5
Gosub GENPATCH From FUNPURTRS
End


##########################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer TYP : TYP=5
Gosub GENDOS From FUNPURTRS
End


########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=6
Local Integer TYP       : TYP=5
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran PTT2) 23/06/2015 08:42:39 (HCB)
######################################################################################
Subprog AS_ECCCODMIN(VALEUR)
Variable Integer VALEUR

Raz GMENLOC
If [M:PTT2]ECCCOD = 2 : GMENLOC(1) = 1 : Endif
End

