# ------------------------------------------------------------
#   Récupération dans un CLOB du résultat d'une vue portail

Subprog CLOBEXP(COD,CLOBOUT)
Value Char COD            : # Code la requête ou de la statistique dans le portail
Variable Clbfile CLOBOUT()  : # Résultat
Local Char CODE(250),CODE1(250)
Local Char PAR1(100)(1..10),VAL1(100)(1..10)
Local Integer P1,P2,NBPAR
#  Décodage de CODE1 si on est en zoom
CODE=COD
P1=instr(1,CODE,",")
If P1<>0
  CODE=left$(COD,P1-1)
  CODE1=right$(COD,P1+1)
  P2=instr(1,CODE1,",")
  If P2=0 : P2=len(CODE1)+1 : Endif
  While P2<>0
    NBPAR+=1
    P1=instr(1,CODE1,"=")
    P2=instr(1,CODE1,",")
    If P2=0 : P2=len(CODE1)+1 : Endif
    PAR1(NBPAR)=toupper(left$(CODE1,P1-1))
    If PAR1(NBPAR)="LEVEL" : PAR1(NBPAR)="NIVEAU" : Endif
    If left$(PAR1(NBPAR),9)="CRITERION" : PAR1(NBPAR)="CRIT"+right$(PAR1(NBPAR),10) : Endif
    VAL1(NBPAR)=mid$(CODE1,P1+1,P2-P1-1)
    CODE1=right$(CODE1,P2+1)
    P2=instr(1,CODE1,",")
    If P2=0 and instr(1,CODE1,"=")<>0 : P2=len(CODE1)+1 : Endif
  Wend
Endif

If dim(GPRE_VIEW)>0 : End : Endif

Local Char TYP
If clalev([F:APV])=0 : Local File APTLVW [APV] : Endif
Read [APV]APV0=CODE
If fstat<>0 : End : Endif
TYP=[F:APV]SRCCODTYP

Local Char WPARAMID(50)(1..10)
Local Char WPARAMVALUE(250)(1..10)
Local Integer WI,WNBPARAM
[L]WPARAMID(1) = "HTCCLBSIZ"      :   [L]WPARAMVALUE(1) = "10"     
[L]WPARAMID(2) = "HTCPRVTYP"      :   [L]WPARAMVALUE(2) = "PORTAL"+TYP
[L]WPARAMID(3) = "ACTION"         :   [L]WPARAMVALUE(3) = "LOAD"
If TYP="MLT" :   [L]WPARAMVALUE(3) = "FIRSTALL" : Endif
If TYP="AGD" :   [L]WPARAMVALUE(3) = "INIT" : Endif
[L]WPARAMID(4) = "PVIEWCODE"      :   [L]WPARAMVALUE(4) =  CODE
[L]WNBPARAM = 4

#  Traitement des descentes et remontées de niveau
If CLOBOUT<>"" 
  Local Integer IPOS,IPOS1
  Local Char LEV,CRIT1(100),CRIT2(100)
  IPOS=instr(1,CLOBOUT,"Level>")
  If IPOS<>0
    IPOS1=instr(IPOS+1,CLOBOUT,"</")
    LEV=mid$(CLOBOUT,IPOS+6,IPOS1-IPOS-6)
   [L]WNBPARAM += 1
   [L]WPARAMID([L]WNBPARAM) = "NIVEAU"         :   [L]WPARAMVALUE([L]WNBPARAM) = LEV
  Endif

  # Criterion --> CRIT
  For WI=1 To 8                                        # E51009 - Pb statistique + de 2 niveaux
      IPOS=instr(1,CLOBOUT,"Criterion"+num$(WI)+">")
      If IPOS<>0
       IPOS1=instr(IPOS+1,CLOBOUT,"</")
       CRIT1=mid$(CLOBOUT,IPOS+11,IPOS1-IPOS-11)
       [L]WNBPARAM += 1
       [L]WPARAMID([L]WNBPARAM) = "CRIT"+num$(WI)     :   [L]WPARAMVALUE([L]WNBPARAM) = CRIT1
      Else
        Break
      Endif
  Next

Endif

Raz CLOBOUT

For IP1=1 To NBPAR
 [L]WNBPARAM += 1
 [L]WPARAMID([L]WNBPARAM) = PAR1(IP1)         :   [L]WPARAMVALUE([L]WNBPARAM) = VAL1(IP1)
Next IP1

If dim(GSTAPORT)>0 : GSTAPORT=1 : Endif
Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]CLOBOUT) From SUBAPSMON
If dim(GSTAPORT)>0 : GSTAPORT=0 : Endif
End

Subprog CLOBEXPSAV(COD,CLOBOUT)
# ------------------------------------------------------------

Value Char COD            : # Code la requête ou de la statistique dans le portail
Variable Clbfile CLOBOUT()  : # Résultat

Local Char CODE(250),CODE1(250)
Local Char PAR1(100)(1..10),VAL1(100)(1..10)
Local Integer P1,P2,NBPAR
#  Décodage de CODE1 si on est en zoom
CODE=COD
P1=instr(1,CODE,",")
If P1<>0
  CODE=left$(COD,P1-1)
  CODE1=right$(COD,P1+1)
  P2=instr(1,CODE1,",")
  If P2=0 : P2=len(CODE1)+1 : Endif
  While P2<>0
    NBPAR+=1
    P1=instr(1,CODE1,"=")
    P2=instr(1,CODE1,",")
    If P2=0 : P2=len(CODE1)+1 : Endif
    PAR1(NBPAR)=toupper(left$(CODE1,P1-1))
    If PAR1(NBPAR)="LEVEL" : PAR1(NBPAR)="NIVEAU" : Endif
    If left$(PAR1(NBPAR),9)="CRITERION" : PAR1(NBPAR)="CRIT"+right$(PAR1(NBPAR),10) : Endif
    VAL1(NBPAR)=mid$(CODE1,P1+1,P2-P1-1)
    CODE1=right$(CODE1,P2+1)
    P2=instr(1,CODE1,",")
    If P2=0 and instr(1,CODE1,"=")<>0 : P2=len(CODE1)+1 : Endif
  Wend
Endif

If dim(GPRE_VIEW)>0 : End : Endif

Local Char TYP
Raz CLOBOUT
If clalev([F:APV])=0 : Local File APTLVW [APV] : Endif
Read [APV]APV0=CODE
If fstat<>0 : End : Endif
TYP=[F:APV]SRCCODTYP

Local Char WPARAMID(50)(1..10)
Local Char WPARAMVALUE(250)(1..10)
Local Integer WI,WNBPARAM
[L]WPARAMID(1) = "HTCCLBSIZ"      :   [L]WPARAMVALUE(1) = "10"     
[L]WPARAMID(2) = "HTCPRVTYP"      :   [L]WPARAMVALUE(2) = "PORTAL"+TYP
[L]WPARAMID(3) = "ACTION"         :   [L]WPARAMVALUE(3) = "LOAD"
If TYP="MLT" :   [L]WPARAMVALUE(3) = "FIRSTALL" : Endif
If TYP="AGD" :   [L]WPARAMVALUE(3) = "INIT" : Endif
[L]WPARAMID(4) = "PVIEWCODE"      :   [L]WPARAMVALUE(4) =  CODE
[L]WNBPARAM = 4

For IP1=1 To NBPAR
 [L]WNBPARAM += 1
 [L]WPARAMID([L]WNBPARAM) = PAR1(IP1)         :   [L]WPARAMVALUE([L]WNBPARAM) = VAL1(IP1)
Next IP1


Global Integer GRAPHBLOC   : # Pour forcer l'écriture dans le Clob
Global Integer IGBL1
#Global Char GRAPHBLOC1(200)(1..2000)
Global Integer GRAPHBLOC1
Global Char GRAPHBLOC2(250)
GRAPHBLOC2= filpath("tmp","F"+num$(adxuid(1))+"_"+CODE+"_"+num$(int(rnd(200))),"par",nomap)
Openo GRAPHBLOC2,0 Using [P_OT]
Iomode adxifs ""  Using [P_OT]
Iomode adxirs ""  Using [P_OT]

Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]CLOBOUT) From SUBAPSMON
Openo Using [P_OT]

Openi GRAPHBLOC2 Using [P_IT]
Iomode adxifs ""  Using [P_IT]
Iomode adxirs ""  Using [P_IT]
Local Clbfile CL1(12)
Rdseq CL1 Using [P_IT]
Openi Using [P_IT]
Call EFFACE(GRAPHBLOC2,P1) From ORDSYS
CLOBOUT=CL1
Kill GRAPHBLOC,GRAPHBLOC1,IGBL1,GRAPHBLOC2
End



# ------------------------------------------------------------
#   Activation d'un lien sur une vue portail

Subprog LINKVUE(FONCTION,OBJET,PARAM)
Value Char FONCTION
Value Char OBJET
Value Char PARAM

#  FONCTION :  Nom de la fonction à appeler
#  OBJET    :  Code de l'objet
#  PARAM    :  Paramètres à passer (clé objet par exemple)

Local Char CLE1(30),CLE2(30)
Local Integer I,OK

#   Pour la CRM on donne la main au programme ad-hoc si il existe

If find(OBJET,"TSK","CLL","BAP")
  Call EXISTE_ADX("","","CRMAINTERFL",OK) From ORDSYS
  If OK=1
    Call CRMLINK(FONCTION,OBJET,PARAM) From CRMAINTERFL
    End
  Endif
Endif

GFONCTION1="APTLOBJ"   :#  CC   07/10/2010   Bug 66495
If  GPILNAV<2
 FLGNAV = 1
 GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION1
Endif


If OBJET = "_"  # E56116 - Appel generique
    Local Char O_QS(250)
    O_QS=PARAM
    Gosub O_EXECUTE From SUBAPSOBJ
    If GPILNAV=1 and GNAVIG(GPILNAV)="APTLOBJ" : GPILNAV=0 : Endif
    End
Endif


If PARAM<>""
  I=instr(1,PARAM,"~")
  If I <> 0     
    CLE1=left$(PARAM,I-1)
    CLE2=right$(PARAM,I+1)
  Else
    CLE1=PARAM : CLE2=""
  Endif
Endif

    # Appel objet
    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
If OBJET<>""
  Call OBJET(OBJET,CLE1,CLE2) From GOBJET
Endif

If GPILNAV=1 and GNAVIG(GPILNAV)="APTLOBJ" : GPILNAV=0 : Endif

End


