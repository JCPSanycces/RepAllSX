        U_HEXTOTXT=U_SRCPARVAL(MW_I) : Gosub U_TXTTOHEX From SUBAPSUTI
        U_TECMES='  <'+[F:APV]SRCPARCOD(MW_I)+'>'+U_TXTTOHEX+'</'+[F:APV]SRCPARCOD(MW_I)+'>': Gosub U_TECPUT From SUBAPSUTI
    Endif
Next
U_TECMES='</UsedDataSrcPar>' : Gosub U_TECPUT From SUBAPSUTI
Return

