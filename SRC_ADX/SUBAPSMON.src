# Traitement de test du sous programme "MONITEUR". Appel via F5
# ------------------------------------------------------------
$WEB
  Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM

  Local Clbfile WCLOBOUT(13)        # Attention doit être en phase avec HTCCLBSIZ

  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "13"     # Taille blob (spécif WEB)
  #  demande
  [L]WPARAMID(2) = "HTCPRVTYP" :   [L]WPARAMVALUE(2) = "PORTALPAGE"
  [L]WPARAMID(3) = "ACTION"    :   [L]WPARAMVALUE(3) = "FIRST"
  #  en fonction de la demande
  [L]WPARAMID(4) = "PAGE"      :   [L]WPARAMVALUE(4) = "null"
  [L]WNBPARAM = 4

  #maxmem = maxmem + 10000000
  #Infbox("Free: "-num$(freemem) -"max: "- num$(maxmem))

  #Appel du point d'entrée du portail 
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT)

  #Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]")
  Local Char WSTROUT(250)(1..100) :# 25 Ko Max !
  Setlob [L]WSTROUT With [L]WCLOBOUT
  Call OUVRE_TRACE("Clob en sortie") From LECFIC
  Call ECR_TRACE("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]", 0) From GESECRAN
  For WI=1 To 100
    If WSTROUT(WI)="" : Break : Endif
    Call ECR_TRACE(WSTROUT(WI), 0) From GESECRAN
  Next  
  Call FERME_TRACE From LECFIC 
  Call LEC_TRACE From LECFIC
End



