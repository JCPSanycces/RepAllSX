#<AdxTL>@(#)11.0.0.0 $Revision$
$GENSSPSTD
  Call ECR_TIME(mess(500,183,1)) From DOSSUB
  #On nettoie le répertoire des supports de sélection
  Trbegin [SSP], [SSC]
  Delete [SSP] Where [F:SSP]SPTSTD = 1
  If fstat Then
    Rollback
    Call ECR_TRACE(mess(501,183,1),1) From GESECRAN
    IPBL = 1
    Return
  Endif
  Delete [SSC] Where [F:SSC]SPTCPNSTD = 1
  If fstat Then
    Rollback
    Call ECR_TRACE(mess(501,183,1),1) From GESECRAN
    IPBL = 1
    Return
  Endif
  Commit
  Gosub DELSTDSSP
  Gosub DELALLSSP
  If IPBL Then
    Return
  Endif
  #####################################
  #On génère 
  Trbegin [SSP], [SSC]
  #Sélection de tous les tiers
  #ALLBPARTNER
  Call TEXTELAN(1, 32, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("ALLBPARTNER", "BPARTNER", SZTEXTFID, mess(34,183,1), 3, "", IPBL)
  #Sélection de premier niveau sur les tiers et les tables du module CRM.
  #SELBPARTNER
  Call TEXTELAN(1, 3, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("SELBPARTNER", "BPARTNER", SZTEXTFID, mess(4,183,1), 4, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "BPC0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPSUPPLIER", "BPSNUM", [F:SSP]SPTTGR, "BPRNUM", "BPS0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCARRIER", "BPTNUM", [F:SSP]SPTTGR, "BPRNUM", "BPT0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "BPA0", "1;[F:BPR]BPRNUM;[F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "TASK", "TSKCMP", [F:SSP]SPTTGR, "BPRNUM", "TSK2", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "PHONECALL", "CLLCMP", [F:SSP]SPTTGR, "BPRNUM", "CLL2", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "CALLATTEMP", "CTTCMP", [F:SSP]SPTTGR, "BPRNUM", "CTT1", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BAPPOINT", "APTCMP", [F:SSP]SPTTGR, "BPRNUM", "APP5", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "OPPOR", "OPPCMP", [F:SSP]SPTTGR, "BPRNUM", "OPP4", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SERREQUEST", "SREBPC", [F:SSP]SPTTGR, "BPRNUM", "SRE3", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "INTERVEN", "BPC", [F:SSP]SPTTGR, "BPRNUM", "ITN2", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "MACHINES", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "MAC2", "[F:BPR]BPRNUM", IPBL)
