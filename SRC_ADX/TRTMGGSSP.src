##########################################################################
Subprog DELETE_SSP_SSC (SPTNUM, IPBL)
Value Char SPTNUM
Variable Integer IPBL

  If IPBL = 0 Then
    Trbegin [SSP], [SSC]
    Delete [SSP] Where [F:SSP]SPTNUM = SPTNUM
    If fstat Then
      Rollback
      Call ECR_TRACE(mess(501,183,1) - "[SSP]" - SPTNUM,1) From GESECRAN
      IPBL = 1
      End
    Endif
    Delete [SSC] Where [F:SSC]SPTNUM = SPTNUM
    If fstat Then
      Rollback
      Call ECR_TRACE(mess(501,183,1) - "[SSC]" - SPTNUM,1) From GESECRAN
      IPBL = 1
      End
    Endif
    Commit
  Endif
End

##########################################################################
Subprog WRITE_SSP(SZSPTNUM, SZSPTTGR, SZSPTNAM, SZSPTDES, ISPTTYP, SZSPTPRO, IPBL)
Value Char SZSPTNUM
Value Char SZSPTTGR
Value Char SZSPTNAM()(,) # FGR 22/07/2009 : X3SUIVI56465
Value Char SZSPTDES
Value Integer ISPTTYP
Value Char SZSPTPRO
Variable Integer IPBL

  If IPBL = 0 Then
    [F:SSP]SPTNUM = SZSPTNUM
    [F:SSP]SPTTGR = SZSPTTGR
    [F:SSP]SPTDES = SZSPTDES
    [F:SSP]SPTTYP = ISPTTYP
    [F:SSP]SPTPRO = SZSPTPRO
    [F:SSP]SPTSTD = 1
    Write [SSP]
    If fstat Then
      Call ECR_TRACE(mess(502,183,1) - "[SSP]" - SZSPTNUM - "." - SZSPTTGR,1) From GESECRAN
      IPBL = 1
      End
    Endif
    #Call MAJTEXTRA(SZSPTNAM, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
    Call MAJTEXTRALAN(SZSPTNAM, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From TRTMGGGEN # FGR 22/07/2009 : X3SUIVI56465
    If GOK < 1 Then
      IPBL = 1
      End
    Endif
  Endif
End

##########################################################################
Subprog WRITE_SSC (SZSPTNUM, ISPTLEV, SZSPTTAB, SZSPTKEY, SZSPTTABPAE, SZSPTKEYPAE, SZSPTIDX, SZSPTFLT, IPBL)
Value Char SZSPTNUM
Value Integer ISPTLEV
Value Char SZSPTTAB
Value Char SZSPTKEY
Value Char SZSPTTABPAE
Value Char SZSPTKEYPAE
Value Char SZSPTIDX
Value Char SZSPTFLT
Variable Integer IPBL

  If IPBL = 0 Then
    [F:SSC]SPTNUM = SZSPTNUM
    [F:SSC]SPTLEV = ISPTLEV
    [F:SSC]SPTTAB = SZSPTTAB
    [F:SSC]SPTKEY = SZSPTKEY
    [F:SSC]SPTTABPAE = SZSPTTABPAE
    [F:SSC]SPTKEYPAE = SZSPTKEYPAE
    [F:SSC]SPTIDX = SZSPTIDX
    [F:SSC]SPTFLT = SZSPTFLT
    [F:SSC]SPTCPNSTD = 1
    Write [SSC]
    If fstat Then
      Call ECR_TRACE(mess(502,183,1) - "[SSC]" - SZSPTNUM - '.' - SPTTAB - '.' - SPTKEY,1) From GESECRAN
      IPBL = 1
      End
    Endif
  Endif
End
