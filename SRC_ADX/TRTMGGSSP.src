  #Sélection de toutes les solutions
  #ALLSOLUTION
  Call TEXTELAN(1, 399, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("ALLSOLUTION", "SOLUTION", SZTEXTFID, mess(400,183,1), 3, "", IPBL)
  #Sélection de premier niveau sur les solutions
  #SELSOLUTION
  Call TEXTELAN(1, 401, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("SELSOLUTION", "SOLUTION", SZTEXTFID, mess(402,183,1), 4, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SERREQUEST", "SOLNUM", [F:SSP]SPTTGR, "NUM", "SRE6", "[F:SOL]NUM", IPBL)
  #Sélection par regroupement sur les solutions
  #GRUSOLUTION
  Call TEXTELAN(1, 403, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUSOLUTION", "SOLUTION", SZTEXTFID, mess(402,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SERREQUEST", "SOLNUM", [F:SSP]SPTTGR, "NUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SREMAC", "SRENUM", "SERREQUEST", "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 3, "MACHINES", "MACNUM", "SREMAC", "MACNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "ITMMASTER", "ITMREF", "MACHINES", "MACPDTCOD", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 5, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SREMACCPN", "SRENUM", "SERREQUEST", "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "HDKTASK", "SRENUM", "SERREQUEST", "SRENUM", "", "", IPBL)
  #Sélection de toutes les demandes de service
  #ALLSERREQUEST
  Call TEXTELAN(1, 404, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("ALLSERREQUEST", "SERREQUEST", SZTEXTFID, mess(405,183,1), 3, "", IPBL)
  #Sélection de premier niveau sur les demandes de service
  #SELSERREQUEST
  Call TEXTELAN(1, 406, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("SELSERREQUEST", "SERREQUEST", SZTEXTFID, mess(407,183,1), 4, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SOLUTION", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "SOL1", "[F:SRE]SRENUM", IPBL)
  #Sélection par regroupement sur les demandes de service
  #GRUSERREQUEST
  Call TEXTELAN(1, 411, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUSERREQUEST", "SERREQUEST", SZTEXTFID, mess(412,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SOLUTION", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SREMAC", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "MACHINES", "MACNUM", "SREMAC", "MACNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 3, "ITMMASTER", "ITMREF", "MACHINES", "MACPDTCOD", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SREMACCPN", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "ESCSRE", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "HDKTASK", "SRENUM", [F:SSP]SPTTGR, "SRENUM", "", "", IPBL)
  If IPBL Then
    Rollback
    Return
  Endif
  Commit
  Call ECR_TIME(mess(503,183,1)) From DOSSUB
Return

