  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "OPPOR", "OPPNUM", "SORDER", "PJT", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "TABSOHTYP", "SOHTYP", "SORDER", "SOHTYP", "", "", IPBL)
