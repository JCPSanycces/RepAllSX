  Call WRITE_SSP ("GRUBPRQUOTE", "BPARTNER", SZTEXTFID, mess(14,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SQUOTE", "BPCORD", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SQUOTED", "SQHNUM", "SQUOTE", "SQHNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 3, "ITMMASTER", "ITMREF", "SQUOTED", "ITMREF", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "OPPOR", "OPPNUM", "SQUOTE", "PJT", "", "", IPBL)
  #Sélection par regroupement sur les commandes de ventes (Quantité).
  #GRUBPRSORDERQ
  Call TEXTELAN(1, 15, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
