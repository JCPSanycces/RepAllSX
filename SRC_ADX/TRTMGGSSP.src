  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "CONTQUAL", "CONNUM", "CONTSERV", "CONNUM", "", "", IPBL)
  #Sélection par regroupement sur les devis.
  #GRUBPRQUOTE
