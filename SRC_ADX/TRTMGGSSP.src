  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "CONTSERV", "CONBPC", [F:SSP]SPTTGR, "BPRNUM", "CON2", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "HISTOOMM", "BPRNUM", [F:SSP]SPTTGR, "BPRNUM", "HIM4", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "REPSEC", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "RSE1", "[F:BPR]BPRNUM", IPBL)
  #Sélection de premier niveau sur les prestataires et donneurs d'ordre.
  #SELBPRPRXDOO
  Call TEXTELAN(1, 5, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("SELBPRPRXDOO", "BPARTNER", SZTEXTFID, mess(6,183,1) - mess(7,183,1), 4, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SUBCONT", "BPRNUM", [F:SSP]SPTTGR, "BPRNUM", "PRX0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SBGEO", "BPRNUM", [F:SSP]SPTTGR, "BPRNUM", "SBG0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SBPBL", "BPRNUM", [F:SSP]SPTTGR, "BPRNUM", "SBP0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "ORDCOMP", "BPRNUM", [F:SSP]SPTTGR, "BPRNUM", "DOO0", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "DOOBPCLNK", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "DBL2", "[F:BPR]BPRNUM", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "DOOBPCINT", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "DBI0", "[F:BPR]BPRNUM", IPBL)
  #Sélection de premier niveau sur les secteurs de marchés.
  #SELBPRMARDEF
  Call TEXTELAN(1, 8, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("SELBPRMARDEF", "BPARTNER", SZTEXTFID, mess(9,183,1) - mess(10,183,1), 4, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "MARASSDEF", "RECORDNUM", [F:SSP]SPTTGR, "BPRNUM", "MAD1", "[F:BPR]BPRNUM;'BPR'", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "MARASSREP", "RECORDNUM", [F:SSP]SPTTGR, "BPRNUM", "MAR1", "[F:BPR]BPRNUM;'BPR'", IPBL)
  #Sélection par regroupement sur les réponses aux scripts d'appels.
  #GRUBPRSCPCLL
  Call TEXTELAN(1, 11, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUBPRSCPCLL", "BPARTNER", SZTEXTFID, mess(12,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "PHONECALL", "CLLCMP", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SCPASW", "CLL", "PHONECALL", "CLLNUM", "", "", IPBL)
  #Sélection par regroupement sur les contrats de service
  #GRUBPRCONTRACT
  Call TEXTELAN(1, 441, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUBPRCONTRACT", "BPARTNER", SZTEXTFID, mess(442,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "CONTCOV", "BPC", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
