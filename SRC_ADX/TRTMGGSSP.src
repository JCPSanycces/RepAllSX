  Call WRITE_SSP ("GRUBPRRETURN", "BPARTNER", SZTEXTFID, mess(25,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
