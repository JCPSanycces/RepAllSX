  Call WRITE_SSP ("GRUBPRSORDERP", "BPARTNER", SZTEXTFID, mess(16,183,1) - mess(19,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SORDER", "BPCORD", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SORDERP", "SOHNUM", "SORDER", "SOHNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 3, "ITMMASTER", "ITMREF", "SORDERP", "ITMREF", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "OPPOR", "OPPNUM", "SORDER", "PJT", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "TABSOHTYP", "SOHTYP", "SORDER", "SOHTYP", "", "", IPBL)
  #Sélection par regroupement sur les livraisons.
  #GRUBPRDELIVERY
  Call TEXTELAN(1, 20, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUBPRDELIVERY", "BPARTNER", SZTEXTFID, mess(21,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "SDELIVERY", "BPCORD", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "SDELIVERYD", "SDHNUM", "SDELIVERY", "SDHNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 3, "ITMMASTER", "ITMREF", "SDELIVERYD", "ITMREF", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 4, "TABLINCFG", "CFGLIN", "ITMMASTER", "CFGLIN", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 2, "OPPOR", "OPPNUM", "SDELIVERY", "PJT", "", "", IPBL)
  #Sélection par regroupement sur les factures de ventes.
  #GRUBPRINVOICE
  Call TEXTELAN(1, 22, 183, SZTEXTFID) From TRTMGGGEN   # FGR 22/07/2009 : X3SUIVI56465
  Call WRITE_SSP ("GRUBPRINVOICE", "BPARTNER", SZTEXTFID, mess(23,183,1), 1, "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPCUSTOMER", "BPCNUM", [F:SSP]SPTTGR, "BPRNUM", "", "", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "BPADDRESS", "BPANUM", [F:SSP]SPTTGR, "BPRNUM", "", "[F:BPA]BPATYP = 1 and [F:BPA]BPAADD = [F:BPR]BPAADD", IPBL)
  Call WRITE_SSC ([F:SSP]SPTNUM, 1, "GACCDUDATE", "BPR", [F:SSP]SPTTGR, "BPRNUM", "", "[F:DUD]TYP = '*SO'", IPBL)
