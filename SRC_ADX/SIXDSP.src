#<AdxTL>@(#)6.0.0.0 $Revision$

End

#########################################################################
#  SIXDSP : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXDSP                                                        #
#     Création des répartitions Analytiques                             #
#                                                                       #
# --------------------------------------------------------------------- #
# PRE-REQUIS :                                                          #
# --------------------------------------------------------------------- #
#                                                                       #
#     1 - Migrations précédentes : axes et sections analytiques         #
#########################################################################
# Supp...
If !clalev([F:DSP])  : Local File CADSP      [DSP]  : Endif   # Répartitions analytiques

If !clalev([F:XVTL]) : Local File XIVTLMDL   [XVTL] : Endif   # Ventilations modèles

Local Integer NBDSP

Trbegin [DSP], [XVTL]
 Delete [DSP] Where 1=1
 Update [XVTL] Where 1=1 With FLGREP=1
Commit 
# Fin Supp
End
Gosub SI_CONTEXT From SIXFONCTION
NBDSP = 0
For [XVTL]IND0 Where SECANA=""
 NBDSP += 1
Next
Global Integer X_NB
Call OUVRE_BOITE("XIVTLMDL",NBDSP) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXDSP : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Création enregistrement CADSP ------#
Call ECR_TIME("SIXDSP : "+SI_MES(159)+" CADSP") From DOSSUB
#---- Création répartitions analytiques X3 à partir des ventilations modèles de l'Intégrale
Call SI_CADSP
If GOK<>1 : Goto FIN_DSP : Endif

$FIN_DSP
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume


############################################################################################
## Création des répartitions analytiques à partir des ventilations modèles de l'Intégrale
## (Table XIVTLMDL (VTL_MDL)) 
############################################################################################
Subprog SI_CADSP

Local Char    LREPRISE(50)
Local Char    ABRFIC(5), MESSA(250)
Local Integer STOP, NB, NBVTL, STAT
Local Integer IGCM , ILED , AXE

## Tables X3
If !clalev([F:CCE])  : Local File =SI_DOSSIER+".CACCE"      [CCE]  : Endif   # Sections analytiques
If !clalev([F:DSP])  : Local File =SI_DOSSIER+".CADSP"      [DSP]  : Endif   # Répartitions analytiques
If !clalev([F:LED])  : Local File =SI_DOSSIER+".GLED"       [LED]  : Endif   # Référentiel
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Sociétés

## Tables Intégrale
If !clalev([F:XCAN]) : Local File =SI_DOSSIER+".XICNTANA"   [XCAN] : Endif   # Centres analytiques
If !clalev([F:XPAN]) : Local File =SI_DOSSIER+".XIPLACBANA" [XPAN] : Endif   # Sections analytiques
If !clalev([F:XVTL]) : Local File =SI_DOSSIER+".XIVTLMDL"   [XVTL] : Endif   # Ventilations modèles
If !clalev([F:XVT2]) : Local File =SI_DOSSIER+".XIVTLMDL"   [XVT2] : Endif   # Ventilations modèles
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

SI_SUBPRG = "SIXDSP"
SI_TABLE  = "XIVTLMDL"
Gosub SI_CRITSUP From SIXFONCTION

Call VARGLOBANA(MESSA,STAT) From SIXGAS
If STAT
 ## Nb d'axes définis dans l'Intégrale pas cohérent avec le dimensionnement du code activité ANA => On arrête
 Call ECR_TRACE(MESSA,1) From GESECRAN : End
Endif

Read [CPY]CPY0 First
IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
If IGCM
 ILED = find(GLEDANA(IGCM),GLED(1..GLEDNBR))
Endif

$LOOP_DSP_ANA
Raz NB

If STOP=1
 CRITERE = "NUMVTL>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [DSP] 
 
# Traitement des répartitions analytiques à partir des ventilations modèles de l'Intégrale (table XIVTLMDL)
For [XVTL]IND0(1) Where left$(NUMVTL,2)<>"$$" & FLGREP<>2 & SECANA=""
&                    & evalue(CRITERE)
&                    & evalue(SI_CRITERE)
 GOK = 1
 Call AFFBOITE([F:XVTL]NUMVTL) From SUBSIM

 # creation répartitions ana (CADSP)
 Gosub CRE_DSP_ANA
 If GOK>0 & SI_SIMU<>2
  For [XVT2]IND0 Where NUMVTL=[F:XVTL]NUMVTL
   [F:XVT2]FLGREP = 2
   Rewrite [F:XVT2]
  Next
 Endif

 If GOK<1 & SI_SIMU <> 2
  Break
 Endif

 # NB alimenté dans CRE_DSP_ANA
 If NB>1000
  LREPRISE  = [F:XVTL]NUMVTL
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_DSP_ANA
 Endif
Else
 Rollback
Endif
End


##################################################################
$CRE_DSP_ANA
NBVTL = 0
For [XVT2]IND0 Where NUMVTL = [F:XVTL]NUMVTL & SECANA<>""

 NBVTL += 1

 Raz [F:DSP]


 # Initialisation sections de chaque axe
 #-------------------------------------------------
 [F:DSP]DSP    = [F:XVTL]NUMVTL
 [F:DSP]NBRDSP = [L]NBVTL

  For AXE=1 To GLEDDIENBR(ILED)
   [F:DSP]DIE(AXE-1) = evalue("GDIE"+num$(AXE)+"("+num$(ILED)+")")
  Next
  Call INICCE([F:XVT2]SECANA,"[F:DSP]CCE",0) From SIXGAS
  [F:DSP]NBRDIE = GLEDDIENBR(ILED)

 # Intitulé de la répartition analytique
 #-------------------------------------------------
 [F:DSP]DESSHO = [F:XVTL]LIB
 [F:DSP]DES    = [F:XVTL]LIB-[F:XVTL]STELIB
 Call MAJTEXTRA([F:DSP]DES,"CADSP","DESTRA",[F:DSP]DSP,"") From ATEXTRA
 Call MAJTEXTRA([F:DSP]DESSHO,"CADSP","SHOTRA",[F:DSP]DSP,"") From ATEXTRA

 # Coefficient
 #-------------------------------------------------
 [F:DSP]COE = [F:XVT2]PRC

 # Dates et utilisateurs
 #-------------------------------------------------
 [F:DSP]CREDAT = date$
 [F:DSP]CREUSR = GUSER              
 [F:DSP]UPDDAT = date$  
 [F:DSP]UPDUSR = GUSER


 SI_TABLE = "CADSP"
 Gosub SI_BEFWRI From SIXFONCTION

 Write [DSP]
 If fstat
  # Répartition analytique XXX, section YYY  : Erreur d'écriture 
  Call ECR_TRACE(mess(52,15,1)-[F:XVT2]NUMVTL-mess(48,105,1)-[F:XVT2]SECANA-"("+[F:XVT2]X3CLE+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Break
 Endif
Next
If GOK<1 : Return
Else     : NB += 1
Endif
Return




