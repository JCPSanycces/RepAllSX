$MODIF
$CREATION
  If !func DIVPAYE.IS_KZA(GCURLEG) : Return : Endif



#  Read [ACV]CODACT="KSA"
#  If !fstat & [F:ACV]FLACT=2
    Delete [FCYSA] Where FCY=[F:FCY]FCY
    If fstat=1
     GOK = -1
     GLOCK = "$HRFACILITYSA"-[F:FCY]FCY
     Return
    Elsif fstat>5
     GOK = 0
     Call RSTA("FCYSA",[F:FCY]FCY) From GLOCK
     Return
    Endif
    [F:FCYSA]FCY = [F:FCY]FCY
    #[F:FCYSA]    = [M:FCYP] #FRLAA - 2015/04/30 Requirement 108198 US 3580
    [F:FCYSA]    = [M:CNF]
    [F:FCYSA]    = [M:FCY1]
    Write [FCYSA]
    If fstat
     GOK=0 : Return
    Endif
#  Endif
Return

$FILTRE
