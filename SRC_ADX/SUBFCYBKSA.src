   Endif
#Endif
Return


Subprog AS_SADDPRI(VALEUR)
Variable Decimal VALEUR
Local Integer AC
Local Integer PRNR
  If VALEUR=0
    PRNR=1
    For AC=0 To dim([M]SADDPRI)-1
      If [M]SADDPRI(AC)=PRNR
        PRNR+=1
      Endif
    Next
    VALEUR=PRNR
    If PRNR=1
       [M]SADDCOR(nolign-1)=2
       Affzo [M]SADDCOR(nolign-1)
    Else
       [M]SADDCOR(nolign-1)=1
       Affzo [M]SADDCOR(nolign-1)
    Endif
    [M]SADDSTA(nolign-1)=2
    Affzo [M]SADDSTA(nolign-1)
  Endif
End

Subprog AM_SADDPRI(VALEUR)
Variable Decimal VALEUR
Local    Integer AC, AC2
#Dbgaff
  If VALEUR < [M]SADDPRI(nolign-1)
    AC=[M]SADDPRI(nolign-1)-VALEUR
    For AC2=0 To (NBRADS-1)
    If [M]SADDPRI(AC2)<[M]SADDPRI(nolign-1)
       If [M]SADDPRI(AC2)>=VALEUR
         [M]SADDPRI(AC2)+=1
         Affzo [M]SADDPRI(AC2)
       Endif
     Endif
     Next
       AC2=0
  Endif
  If VALEUR > [M]SADDPRI(nolign-1)
    AC=VALEUR-[M]SADDPRI(nolign-1)
    For AC2=0 To (NBRADS-1)
    If [M]SADDPRI(AC2)>[M]SADDPRI(nolign-1)
       [M]SADDPRI(AC2)-=1
       Affzo [M]SADDPRI(AC2)
     Endif
     Next
       AC2=0
  Endif

  If [M]SADDTYP(nolign-1) = 0
    If !find(1,[M]SADDTYP) Then [M]SADDTYP(nolign-1)=1 : End : Endif
    If !find(2,[M]SADDTYP) Then [M]SADDTYP(nolign-1)=2 : End : Endif
    If !find(3,[M]SADDTYP) Then [M]SADDTYP(nolign-1)=3 : End : Endif
  Endif
End

Subprog AV_SADDSTYP(VALEUR)
#Dbgaff
Variable Integer VALEUR
  If [M]SADDTYP(nolign-1)<>2
   Grizo [M]SADDSTYP(nolign-1)
  Else
   Actzo [M]SADDSTYP(nolign-1)
  Endif
End

Subprog C_SADDSTRNUM(VALEUR)
Variable Char    VALEUR()
  If [M]SADDTYP(nolign-1)<>2
    If vireblc(VALEUR,2)=""
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
End

Subprog C_SADDSTRNAM(VALEUR)
Variable Char    VALEUR()
  If [M]SADDTYP(nolign-1)<>2
    If vireblc(VALEUR,2)=""
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
End

Subprog C_SADDPOSCDE(VALEUR)
Variable Char    VALEUR()
If [M]SADDTYP(nolign-1)=2
  If vireblc(VALEUR,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End

Subprog AS_SADDCNTCDE(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR="SA"
Endif
End

Subprog C_SADDCOR(VALEUR)
Variable Integer VALEUR
Local    Integer AC
  If VALEUR=2
    For AC=0 To dim([M]SADDPRI)-1
      If AC<>nolign-1
        [M]SADDCOR(AC)=1
        Affzo [M]SADDCOR(AC)
      Endif
    Next
  Endif
End

Subprog AM_TAXYR(VALEUR)
Variable Integer  VALEUR
Local Char STCCYY,ENDCCYY
Local Integer ENDDAY

If VALEUR = 1
  [M:FCYP]TAXYRSTR=gdat$(0,0,0)
  Affzo [M:FCYP]TAXYRSTR

  [M:FCYP]TAXYREND=gdat$(0,0,0)
  Affzo [M:FCYP]TAXYREND

  [M:FCYP]TAXSITSTR=gdat$(0,0,0)
  Affzo [M:FCYP]TAXSITSTR

  [M:FCYP]TAXSITEND=gdat$(0,0,0)
  Affzo [M:FCYP]TAXSITEND
  End
Endif

STCCYY=left$(mess(VALEUR,11663,1),4)
ENDCCYY=right$(mess(VALEUR,11663,1),6)

If (val(ENDCCYY)/4=int(val(ENDCCYY)/4) and val(ENDCCYY)/100<>int(val(ENDCCYY)/100))
&  or val(ENDCCYY)/400=int(val(ENDCCYY)/400)
  ENDDAY=29
Else
  ENDDAY=28
Endif

[M:FCYP]TAXYRSTR=gdat$(1,3,val(STCCYY))
Affzo [M:FCYP]TAXYRSTR

[M:FCYP]TAXYREND=gdat$(ENDDAY,2,val(ENDCCYY))
Affzo [M:FCYP]TAXYREND

[M:FCYP]TAXSITSTR=gdat$(1,3,val(STCCYY))
Affzo [M:FCYP]TAXSITSTR

[M:FCYP]TAXSITEND=gdat$(ENDDAY,2,val(ENDCCYY))
Affzo [M:FCYP]TAXSITEND
End

#FRLAA - 2015/05/11 Requirement 108198 US 3580  START
Subprog AM_LEGCPY(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KZA")=0 : End :  Endif
If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA       [CPYKSA]         : Endif
Read [F:CPYKSA]CPYKSA0 = VALEUR
  If !fstat
    [M:FCYP] = [F:CPYKSA]
  Endif
  Affzo [M:FCYP]
End
#FRLAA - 2015/05/11 Requirement 108198 US 3580  END


Subprog C_UIFNUM(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)<>"U"
  GMESSAGE=mess(6,11662,1)
  mkstat=2
  End
Endif
Call TEST_VALID_RSA_NUMBER(VALEUR,7)
End

Subprog C_SDLNUM(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)<>"L"
  GMESSAGE=mess(8,11662,1)
  mkstat=2
  End
Endif
Call TEST_VALID_RSA_NUMBER(VALEUR,9)
End

# JASMI - 2014/03/10 - Requirement 93909 US 2439
Subprog C_PAYREFNUM(VALEUR)
Variable Char    VALEUR()
Case left$(VALEUR,1)
When "0", "1", "2", "3", "7", "9"
  Call TEST_VALID_RSA_NUMBER(VALEUR,12)
When Default
  GMESSAGE=mess(11,11662,1)
  mkstat=2
  End
Endcase
End
# JASMI - 2014/03/10 - Requirement 93909 US 2439

Subprog TEST_VALID_RSA_NUMBER(VALEUR,RSA_MES)
Value Integer RSA_MES
Variable Char    VALEUR()
Local Integer RSATAX_NUM(1..10)
Local Integer RSATAX_NUM2
Local Integer COUNTER2
Local Integer TEMP_CALC4, TEMP_CALC5

  COUNTER2=0

  For COUNTER2=2 To 10
    If ascii(mid$(VALEUR,COUNTER2,1))>=48 &ascii(mid$(VALEUR,COUNTER2,1)) <=57
      RSATAX_NUM(COUNTER2)=val(mid$(VALEUR,COUNTER2,1))
    Else
      GMESSAGE=mess(3,11662,1)-num$(COUNTER2)-mess(4,11662,1)
      mkstat=2
      End
    Endif
  Next
  RSATAX_NUM(1)=4
  TEMP_CALC4=RSATAX_NUM(2)+RSATAX_NUM(4)+RSATAX_NUM(6)+RSATAX_NUM(8)

  For COUNTER2=1 To 9
    TEMP_CALC5=(RSATAX_NUM(COUNTER2)*2)
    If TEMP_CALC5>9
      TEMP_CALC5=TEMP_CALC5-9
    Endif
    TEMP_CALC4=TEMP_CALC4+TEMP_CALC5
    COUNTER2=COUNTER2+1
  Next
  TEMP_CALC5=(10-mod(TEMP_CALC4,10))
#JASMI - 2015-04-10 - Requirement number: 107613 - START
  If TEMP_CALC5=10
    TEMP_CALC5=0
  Endif
#JASMI - 2015-04-10 - Requirement number: 107613 - END

  If TEMP_CALC5<>RSATAX_NUM(10)
    GMESSAGE=mess(RSA_MES,11662,1)
    mkstat=2
    End
  Endif
End

