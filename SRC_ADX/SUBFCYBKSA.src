    If !fstat
      [M:FCYP] = [F:CPYKSA]
    Endif
    Affzo [M:FCYP]
#FRLAA - 2015/04/30 - Requirement 108198 US 3580  END

    Read [F:FCYSA]FCYSA0=[M:FCY0]FCY
    If !fstat
      #[M:FCYP] = [F:FCYSA] #FRLAA - 2015/04/30 - Requirement 108198 US 3580
      [M:CNF]  = [F:FCYSA]
      [M:FCY1] = [F:FCYSA]
    Endif
    Call CHARG_BPA_KSA(NUMBPA,[M:FCY0]FCY) From TRTBPAKSA
#  Endif

