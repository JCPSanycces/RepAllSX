Subprog AS_TIMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TIMUOM(zc) From W1PJMOVE0
Onkey 144 Titled GBOUTP Call P_TIMUOM(zc) From W1PJMOVE0
Onkey 146 Titled GBOUTA Call SA_TIMUOM(zc) From W1PJMOVE0
Gosub _AFF
End

Subprog C_TIMUOM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TIMUOM" : GZNUM = 2915 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TUN","B",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TIMUOM" : GZNUM = 2915 : Endif
 If !mkstat
  ## Action STD
  Call C_TIMUOM(VALEUR) From PJMOVE
  If mkstat : GERR = 1 : GZONE = "TIMUOM" : GZNUM = 2915 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TIMUOM
Call AM_TIMUOM(zc)
If !mkstat & GOBJET
 zoncou = "TIMUOM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

