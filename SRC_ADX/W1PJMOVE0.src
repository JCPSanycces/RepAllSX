Subprog AM_TCACOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TCACOD(VALEUR) From PJMOVE
If mkstat : GERR = 1 : GZONE = "TCACOD" : GZNUM = 41950 : Endif
Gosub _AFF
End

Subprog S_TCACOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CTA"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_TCACOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("CTA",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_TCACOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTA"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TCACOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

