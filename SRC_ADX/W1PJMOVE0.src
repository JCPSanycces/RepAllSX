$ON_PRCCPLADI
Onevent INIT_AREA Call D_PRCCPLADI(zc) From W1PJMOVE0
Onevent CONTROL Call C_PRCCPLADI(zc) From W1PJMOVE0
Onevent AFTER_CHANGE Gosub AMM_PRCCPLADI From W1PJMOVE0
Onevent BEFORE_INPUT Call AS_PRCCPLADI(zc) From W1PJMOVE0
Return

Subprog D_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If varinit([M]PRCCPLADI,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"387","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"387") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PRCCPLADI(zc) From W1PJMOVE0
Onkey   2 Titled GBOUTS Call S_PRCCPLADI(zc) From W1PJMOVE0
Onkey 144 Titled GBOUTP Call P_PRCCPLADI(zc) From W1PJMOVE0
Onkey 146 Titled GBOUTA Call SA_PRCCPLADI(zc) From W1PJMOVE0
Gosub _AFF
End

Subprog C_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"387","") From SUBADI
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1004132 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"387",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1004132 : Endif
Endif
Gosub _AFF
End

$AMM_PRCCPLADI
Call AM_PRCCPLADI(zc)
If !mkstat & GOBJET
 zoncou = "PRCCPLADI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PRCCPLADI(VALEUR) From PJMOVE
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1004132 : Endif
Gosub _AFF
End

Subprog S_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "387"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"387") From GOBJET
Gosub _AFF
End

Subprog SA_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "387"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "387"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

