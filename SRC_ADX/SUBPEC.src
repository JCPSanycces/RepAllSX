#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet PEC
Call OBJET ("PEC", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "AVANTBOUT"  : Gosub AVANTBOUT
    When "RAZCRE"     : Gosub RAZCRE  
    When "AFFMASK"    : Gosub AFFMASK
    When "LIENS"      : Gosub LIENS
    When "FILTRE"     : Gosub FILTRE
    When "FILGAUCHE"  : Gosub FILGAUCHE
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "ANNULE"     : Gosub ANNULE
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$LIENS
Local Integer TESTNBLIG

  Raz [M:PEC1]NBLIG
  # Chargement du tableau des concurrents
  For TESTNBLIG = 0 To dim([F:PEC]ESCACTNUM)-1
    If [M:PEC1]ESCACTNUM(TESTNBLIG) = "" Then
      Break
    Endif
    [M:PEC1]NBLIG += 1
  Next
  Affzo [M:PEC1]
Return

##########################################################################################################
$INICRE
Return

##########################################################################################################
$VERIF_CRE
Return

##########################################################################################################
$VERIF_MOD
Return

##########################################################################################################
$CREATION
Return

##########################################################################################################
$MODIF
Return

##########################################################################################################
$ANNULE
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$AFFMASK
Return

##########################################################################################################
$FILTRE
Return

##########################################################################################################
$FILGAUCHE
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
Return

##########################################################################################################
$RAZCRE
  [M:PEC0]ENAFLG = 2
  Affzo [M:PEC0]
Return

##########################################################################################################
Subprog C_ESCACTNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code solution n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim([M:PEC1]ESCACTNUM)-1
    If I <> nolign-1 Then
      If [M:PEC1]ESCACTNUM(I) = VALEUR and [M:PEC1]ESCACTNUM(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        #Une même action ne peut pas être saisie plusieurs fois pour une escalade.
        GMESSAGE = mess(936,182,1) 
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog AM_ESCACTNUM(VALEUR)
Variable Char    VALEUR()

  [M:PEC1]ESCACTNUM(nolign-1) = VALEUR
  If [M:PEC1]ESCACTNUM(nolign-1) = "" Then
    Raz [M:PEC1]ESCACTNAM(nolign-1)
  Else
    Call GET_LIB(455, [M:PEC1]ESCACTNUM(nolign-1), [M:PEC1]ESCACTNAM(nolign-1)) From CRM_UTIL
  Endif
  Affzo [M:PEC1]ESCACTNUM(nolign-1), ESCACTNAM(nolign-1)
End
