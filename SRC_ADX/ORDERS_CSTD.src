#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe ORDERS
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"               : Gosub AREAD_AFTER                     From ORDERS_CSTD_EVENTS # Issue X3-34326 - 2017-04-26 by FGR
      When "ACONTROL"                  : Gosub ACONTROL                        From ORDERS_CSTD_EVENTS
      When "AINSERT_CONTROL_BEFORE"    : Gosub AINSERT_CONTROL_BEFORE          From ORDERS_CSTD_EVENTS
      When "AUPDATE_CONTROL_BEFORE"    : Gosub AUPDATE_CONTROL_BEFORE          From ORDERS_CSTD_EVENTS
    Endcase
Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "LOAD_TECPJT"                 : Gosub LOAD_TECPJT                     From ORDERS_CSTD_METHODS # Issue X3-34326 - 2017-04-26 by FGR
    When "WIP_AUTOMAP"                 : Gosub WIP_AUTOMAP                     From ORDERS_CSTD_METHODS
    When "_WIP_CREATE"                 : Gosub _WIP_CREATE                     From ORDERS_CSTD_METHODS
    When "_WIP_UPDATE"                 : Gosub _WIP_UPDATE                     From ORDERS_CSTD_METHODS
    When "_WIP_CONSUM"                 : Gosub _WIP_CONSUM                     From ORDERS_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "ORDERS_FROM_PJM"             : Gosub ORDERS_FROM_PJM                 From ORDERS_CSTD_OPERATIONS
    When "ORDERS_FROM_PJM_SOQ"         : Gosub ORDERS_FROM_PJM_SOQ             From ORDERS_CSTD_OPERATIONS # Issue X3-31898 - 2017-11-23 by FGR
    When "ORDERS_FROM_PREQUISD"        : Gosub ORDERS_FROM_PREQUISD            From ORDERS_CSTD_OPERATIONS ##US 71069/260 by RBA 07/29/2016
    #
    When "WIP"                         : Gosub WIP                             From ORDERS_CSTD_OPERATIONS
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "STOFCY"                      : Gosub STOFCY                          From ORDERS_CSTD_PROPERTIES # Issue X3-34326 - 2017-04-26 by FGR
    When "WIPTYP"                      : Gosub WIPTYP                          From ORDERS_CSTD_PROPERTIES
    When "ATECORI"                     : Gosub ATECORI                         From ORDERS_CSTD_PROPERTIES
    When "OPTFLG"                      : Gosub OPTFLG                          From ORDERS_CSTD_PROPERTIES
  Endcase
Return

