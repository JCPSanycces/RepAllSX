#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* PRCPQTY : Pre-receipt quantity
#*!
#**
#* 1 - Si pré réception des commandes => qté expédiée = qté pré-réceptionnée<br\>
#* 2 - Si qté pré-réceptionnée <> 0, flag pré-réceptionné = Yes<br\>
#* 3 - Si qté cde <> 0, recalcul des qtés en Unités d'achat et unités de stock
#*!
$PRCPQTY_PROPAGATE
  Local File PORDERQ [POQ]
  # 1
  If this.APARENT <> null
    If this.APARENT.SHIPTYP = 2 & this.PRCPQTY<> AVOID.ADEC
      this.SHIQTY = this.PRCPQTY
    Endif
  Endif

  # 2
  If this.PRCPQTY <> AVOID.ADEC
    this.PRCPFLG = CST_AYES
    this.CLEFLG =  CST_ANO
  Elsif this.PRCPFLG<>CST_ANO
      this.PRCPFLG = CST_ANO
  Endif


  # 3
  Read [POQ] POQ0=this.POHNUM;this.POPLIN;this.POQSEQ
  If fstat Raz [F:POQ] : Return : Endif
  If [F:POQ]QTYUOM <> 0
    this.PRCPQTYPUU = [F:POQ]QTYPUU * this.PRCPQTY / [F:POQ]QTYUOM
    this.PRCPQTYSTU = [F:POQ]QTYSTU * this.PRCPQTY / [F:POQ]QTYUOM
  Else
    this.PRCPQTYPUU = [F:POQ]QTYPUU
    this.PRCPQTYSTU = [F:POQ]QTYSTU
  Endif
Return
#**
#* SHIQTY : Shipped quantity
#*!
#**
#**
#* 1 - Si qté cde <> 0, recalcul des qtés en Unités d'achat et unités de stock<br\>
#* 2 - Recalcul du poids et du volume par à la qté en unité de stock<br\>
#* 3 - Calcul du coefficient UOM/UA (unité ligne doc/unité d'achat)
#*!
$SHIQTY_PROPAGATE
  Local File PORDERQ [POQ]

  #1 -
  Read [POQ] POQ0=this.POHNUM;this.POPLIN;this.POQSEQ
  If fstat Raz [F:POQ] : Return : Endif
#If this.ACTX.USER="MAE" Dbgaff : Endif
  If [F:POQ]QTYUOM <>0
    this.SHIQTYPUU = [F:POQ]QTYPUU * this.SHIQTY / [F:POQ]QTYUOM
    this.SHIQTYSTU = [F:POQ]QTYSTU * this.SHIQTY / [F:POQ]QTYUOM
    this.LINAMT = [F:POQ]LINAMT * this.SHIQTY / [F:POQ]QTYUOM
    Call ARRDEV(this.LINAMT,[F:POQ]NETCUR) From TRTDIV  # Issue X3-70790 - 2018-01-15 by MAE
  Else
    this.SHIQTYPUU = [F:POQ]QTYPUU
    this.SHIQTYSTU = [F:POQ]QTYSTU
    this.LINAMT = [F:POQ]LINAMT
  Endif

  #2
  If [F:POQ]QTYSTU <> 0
    this.QTYWEU = this.SHIQTYSTU * [F:POQ]QTYWEU / [F:POQ]QTYSTU
    this.QTYVOU = this.SHIQTYSTU * [F:POQ]QTYVOU / [F:POQ]QTYSTU
  Else
    this.QTYWEU = 0
    this.QTYVOU = 0
  Endif

  #3
  If this.SHIQTY <>0
     this.UOMPUUCOE = arr(this.SHIQTYPUU / this.SHIQTY, 0.00000001)
  Endif
  If this.UOMPUUCOE=0 : this.UOMPUUCOE = 1 : Endif
Return

#**
#* PRCPFLG : Pre-receipt flag
#*!
$PRCPFLG_INIT
this.PRCPFLG = 1
Return

#**
#* Si la ligne est pré-receptionnée et la qté pré-réceptionnée est à oui => la ligne est soldée
#*!
$PRCPFLG_PROPAGATE
  If this.PRCPFLG = 2 & this.PRCPQTY = 0
    #On ne solde plus une pré-réception à 0
    #this.CLEFLG = 2
  Elsif this.PRCPFLG = 1 & this.PRCPQTY<>0
    this.PRCPQTY = 0
    this.CLEFLG = 1
  Elsif this.PRCPFLG = 1 & this.PRCPQTY=0
    this.CLEFLG = 1
  Endif
Return
#**
#* QTYEXPFLG : quantité réintégrée flag
#*!
$QTYEXPFLG_INIT
this.QTYEXPFLG = 1
Return

