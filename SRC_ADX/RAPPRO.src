#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
 When "CONT1" : Gosub CONT1
Endcase
Return

######################################################################

$CONT1
Local Integer K
Local Char    CRITERE(250)
If [M]PARCOD(nolign-1)="numrbk" & zc<>""
 CRITERE = "RBKNUM='"+zc+"'"
 K = find("bandeb",[M]PARCOD)-1
 If K>=0 & [M]VALINT1(K)<>""
  CRITERE-="& BAN>='"+[M]VALINT1(K)+"'"
 Endif
 If K>=0 & [M]VALINT2(K)<>""
  CRITERE-="& BAN<='"+[M]VALINT2(K)+"'"
 Endif
 If !clalev([F:RBK]) : Local File RELBANK [RBK] : Endif
 Filter [RBK] Where evalue(CRITERE)
 Read [RBK]RBK0 First
 Filter [RBK]
 If fstat
  If [M]VALINT1(K)<>"" | [M]VALINT2(K)<>""
   # Relevé inexistant sur cette banque
   GMESSAGE = mess(33,120,1)
  Else
   # Relevé inexistant
   GMESSAGE = mess(191,117,1)
  Endif
  mkstat = 2 : Return
 Endif
Endif
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local File GACCENTRY[HAE], GACCENTRYD[DAE], AREPORTM[ARM], RELBANK[RBK],
&          GTYPACCENT[GTE], ACCES[ACS], BANK[BAN], COMPANY[CPY], TABCUR[TCU], GACM [GCM]
Local File GACCENTRYD [DAE2], RELBANK [RBK2], FISCALYEAR [FIY]


Local Integer NUMREQ, WNUMLIG, NB, TEM, KO
Local Decimal SOLDEREL, TXEDI
Local Date    DATECRDEB, DATECRFIN, DATRBKDEB, DATRBKFIN, BEGDAT
Local Char    ETAT(GLONARP), PARAM(30), VALEUR(30), DEVEDI(GLONCUR), DEVBAN(GLONCUR), CPYCUR(GLONCUR)
Local Char    BANDEB(GLONBAN), BANFIN(GLONBAN), NUMRBK(15), NUMREL(15)
Local Integer TYPREF, SNSB
Local Char    REFER(GLONGCM)
Local Char    CRITERE(250)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,[L]VALEUR) From ETAT
[L]NUMREQ = val([L]VALEUR)
Call SETPARAM("numreq",NBPAR,PARAMETRE,[L]VALEUR) From ETAT
Call GETPARAM("bandeb",NBPAR,PARAMETRE,[L]BANDEB) From ETAT
Call GETPARAM("banfin",NBPAR,PARAMETRE,[L]BANFIN) From ETAT
Call GETPARAM("datecrdeb",NBPAR,PARAMETRE,PARAM) From ETAT   : DATECRDEB = PARAM
Call GETPARAM("datecrfin",NBPAR,PARAMETRE,PARAM) From ETAT   : DATECRFIN = PARAM
Call GETPARAM("datrbkdeb",NBPAR,PARAMETRE,PARAM) From ETAT   : DATRBKDEB = PARAM
Call GETPARAM("datrbkfin",NBPAR,PARAMETRE,PARAM) From ETAT   : DATRBKFIN = PARAM
Call GETPARAM("numrbk",NBPAR,PARAMETRE,[L]NUMRBK) From ETAT
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]ETAT) From ETAT

If [L]NUMRBK<>""
 CRITERE = "RBKNUM='"+[L]NUMRBK+"'"
 If [L]BANDEB<>"" : CRITERE-="& BAN>='"+[L]BANDEB+"'" : Endif
 If [L]BANFIN<>"" : CRITERE-="& BAN<='"+[L]BANFIN+"'" : Endif
 If !clalev([F:RBK]) : Local File RELBANK [RBK] : Endif
 Filter [RBK] Where evalue(CRITERE)
 Read [RBK]RBK0 First
 Filter [RBK]
 If fstat
  If [L]BANDEB<>"" | [L]BANFIN(K)<>""
   # Relevé inexistant sur cette banque
   Call ECR_TRACE(mess(33,120,1),1) From GESECRAN
  Else
   # Relevé inexistant
   Call ECR_TRACE(mess(191,117,1),1) From GESECRAN
  Endif
  GOK=0 : End
 Endif
Endif

Trbegin [ARM]
 Delete [ARM] Where RPTCOD="RAPPRO" & USR=GUSER & CREDAT<date$
Commit

Call TEMPON("") From GESECRAN
[L]WNUMLIG = 0
Filter [BAN] Where BAN>=[L]BANDEB & BAN<=[L]BANFIN & BANCSH=1 Order By Key CLE=CPY;BAN
For [BAN]CLE(1)
 Read [CPY]CPY0 = [F:BAN]CPY
 If fstat
  Call RSTA("CPY",[F:BAN]CPY) From GLOCK : GOK=0 : Break
 Endif
 Filter [FIY] Where CPY=[F:BAN]CPY & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 SNSB = val(func AFNC.PARAM("SNSBNQ",[F:BAN]CPY))
 Read [GCM]GCM0 = [F:CPY]ACM
 TYPREF = [F:GCM]GENLEDTYP
 REFER  = [F:GCM]LED(TYPREF-1)
 CPYCUR = [F:GCM]CUR(TYPREF-1)
 For [BAN]CLE
  Read [ACS]CODACC = GUSER;[F:BAN]ACS
  If !fstat & [F:ACS]CONSUL=2
    [L]DEVBAN = [F:BAN]CUR
    If [L]DATRBKFIN >= [F:BAN]CHGDAT
      [L]DEVEDI = [F:BAN]CUR
    Else
      [L]DEVEDI = ""
    Endif
    Call DEBTRANS From GLOCK
    Gosub SELRBK      # sélection des relevés bancaires
    If GOK<1 : Break 2 : Endif

    Call DEBTRANS From GLOCK
    Gosub SOLDE_REL   # calcul du solde du relevé ds la devise d'édition
    If GOK<1 : Break 2 : Endif

    Call DEBTRANS From GLOCK
    Gosub SELECR      # sélection des écritures comptables
    If GOK<1 : Break 2 : Endif
  Endif
 Next   # banque
Next   # société
Filter [BAN]
Call TEMPOFF From GESECRAN
Call MESSAGE(mess(38,114,1)-num$([L]NUMREQ)) From GESECRAN : # Requête numéro xxxxx
End

$SOLDE_REL
[L]TXEDI=1
If [L]DEVEDI<>[L]DEVBAN
  If [L]DEVEDI<>GEURO
   Call LECTURE("TCU",[L]DEVEDI,"") From CONTOBJ
   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] or [F:TCU]EURDAT<=[F:BAN]CHGDAT)
     [L]TXEDI = [F:TCU]EURRAT
   Endif
  Endif
Endif
[L]BEGDAT = [0/0/0]
[L]SOLDEREL = 0
[L]NUMREL = ""
Filter [RBK] Where BAN=[F:BAN]BAN & RECTYP=3 & OPEDAT<=[L]DATRBKFIN
&               & ([L]NUMRBK="" | RBKNUM<=[L]NUMRBK)
Read [RBK]RBK1 Last
If !fstat
  [L]BEGDAT = [F:RBK]OPEDAT
  [L]NUMREL = [F:RBK]RBKNUM
  If [F:RBK]CUR=[L]DEVEDI
   [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR
  Else
   If [L]DEVEDI=[L]DEVBAN
    [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR/[L]TXEDI
   Else
    [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR*[L]TXEDI
   Endif
  Endif
Endif
Filter [RBK] Where BAN=[F:BAN]BAN & RECTYP=1 & [L]BEGDAT<=OPEDAT & OPEDAT<=[L]DATRBKFIN
&               &  RBKNUM<>[L]NUMREL & ([L]NUMRBK="" | RBKNUM<=[L]NUMRBK)
Read [RBK]RBK1 Last
If !fstat
  [L]BEGDAT = [F:RBK]OPEDAT
  [L]NUMREL = [F:RBK]RBKNUM
  If [F:RBK]CUR=[L]DEVEDI
   [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR
  Else
   If [L]DEVEDI=[L]DEVBAN
    [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR/[L]TXEDI
   Else
    [L]SOLDEREL = [F:RBK]SNS*[F:RBK]AMTCUR*[L]TXEDI
   Endif
  Endif
  Filter [RBK] Where BAN=[F:BAN]BAN & RECTYP=2 & [L]BEGDAT<=OPEDAT & OPEDAT<=[L]DATRBKFIN
&               &  RBKNUM=[L]NUMREL
  For [RBK]RBK1
    If [F:RBK]CUR=[L]DEVEDI
     [L]SOLDEREL += [F:RBK]SNS*[F:RBK]AMTCUR
    Else
     If [L]DEVEDI=[L]DEVBAN
      [L]SOLDEREL += [F:RBK]SNS*[F:RBK]AMTCUR/[L]TXEDI
     Else
      [L]SOLDEREL += [F:RBK]SNS*[F:RBK]AMTCUR*[L]TXEDI
     Endif
    Endif
  Next
Endif
Filter [RBK]
Gosub ECR1
Return

$ECR1
Trbegin [ARM]
WNUMLIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = [L]WNUMLIG
[F:ARM]CLEA1  = "SOLDEREL"
[F:ARM]CLEA2  = [F:BAN]CPY
[F:ARM]CLEA3  = [F:BAN]BAN
[F:ARM]CLEA4  = [L]DEVEDI
[F:ARM]CLEA6  = [L]CPYCUR
[F:ARM]CLEMD1 = [L]SOLDEREL
[F:ARM]CLEN2  = SNSB
[F:ARM]CLEN3  = [F:FIY]FIYNUM
[F:ARM]CREDAT = datesyst
Write [F:ARM]
If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Goto AB_ECR1 : Endif
Commit
Return

$AB_ECR1
Rollback
Return

#############################################################
$SELECR
CRITECR  = 'CPY="'+[F:BAN]CPY+'"'
If [F:BAN]FCY<>""
 CRITECR -= '& FCYLIN="'+[F:BAN]FCY+'"'
Endif
CRITECR -= '& LEDTYP='+num$(TYPREF)
CRITECR -= '& ACCDAT>=['+format$(GFMD,DATECRDEB)+']'
CRITECR -= '& ACCDAT<=['+format$(GFMD,DATECRFIN)+']'
CRITECR -= '& COA="'+[F:BAN]COA+'"'
CRITECR -= '& ACC="'+[F:BAN]BANACC+'"'
CRITECR -= '& BPR="'+[F:BAN]BANBPR+'"'
CRITECR -= '& (CUR=[L]DEVBAN | [L]CPYCUR=[L]DEVBAN |  CUR=[L]DEVEDI | [L]CPYCUR=[L]DEVEDI)'

Filter [DAE] Where evalue(CRITECR)

Trbegin [ARM]
GOK=1
For [DAE]DAE0(1) With Nohint
 Call LEC_GTE_LEG([F:CPY]LEG,[F:DAE]TYP) From CPTLEC
 # Edition des ANX saisi... (Pièce générale OK mais PER=1 NOK)
 If !fstat
  For [DAE]DAE0(2)
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   #Edition des ANX saisi...
   If !fstat & [F:HAE]CAT=1  & [F:HAE]FLGREP<>2    # pièce réelle
    For [DAE]DAE0
     TEM = 0
     If [F:DAE]CHK="*"
      TEM=1
     Elsif [F:DAE]CHK<>""
      # on scrute tous les relevés ayant ce code pointage,
      # si au moins un relevé a une date > DATRBKFIN, on prend l'écriture KO=0 sinon KO=1
      NB=0
      KO = 1
      For [RBK]RBK1 Where CHK=[F:DAE]CHK & RECTYP=2 & BAN=[F:BAN]BAN With Nohint
       NB+=1
       If [F:RBK]OPEDAT>[L]DATRBKFIN : KO = 0 : Break : Endif
      Next
      If !NB
       KO = 0
       # on scrute toutes les écritures comptables ayant ce code pointage,
       # si toutes ces écritures ont une date cpt > DATECRFIN, on prend l'écriture
       For [DAE2]DAE3 Where CPY=[F:BAN]CPY & ([F:BAN]FCY="" | FCYLIN=[F:BAN]FCY) & LEDTYP=TYPREF
&                         & COA=[F:BAN]COA & ACC=[F:BAN]BANACC & BPR=[F:BAN]BANBPR
&                         & CHK=[F:DAE]CHK & NUM<>[DAE]NUM
&                     With Nohint
        NB=1
        If [F:DAE2]ACCDAT<=[L]DATECRFIN : TEM=1 : Break : Endif
       Next
      Endif
      If !NB | KO=1 : TEM=1 : Endif
     Endif
     If [F:DAE]CHK="" | TEM=0
      Gosub ECR2
      If GOK<1 : Break 3 : Endif
     Endif
    Next
   Endif
  Next   # pièce comptable
 Endif
Next   # type de pièce
Filter [DAE]
If GOK=1 : Commit
Else : Rollback
Endif
Return

$ECR2
WNUMLIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = [L]WNUMLIG
[F:ARM]CLEA1  = "ECRITURE"
[F:ARM]CLEA2  = [F:BAN]CPY
[F:ARM]CLEA3  = [F:BAN]BAN
[F:ARM]CLEA4  = [L]DEVEDI
[F:ARM]CLEA6  = [L]CPYCUR
[F:ARM]CLEN1  = [F:DAE]ACCNUM
[F:ARM]CLEN2  = SNSB
[F:ARM]CLEN3  = [F:FIY]FIYNUM
[F:ARM]CREDAT = datesyst
Write [F:ARM]
If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif
Return


#############################################################
$SELRBK
Filter [RBK] Where RECTYP=2 & OPEDAT>=DATRBKDEB & OPEDAT<=DATRBKFIN & BAN=[F:BAN]BAN
&                & ([L]NUMRBK="" | RBKNUM<=[L]NUMRBK)
Trbegin [ARM]
GOK=1
For [RBK]RBK1
 If [L]DEVEDI="" : [L]DEVEDI=[F:RBK]CUR : Endif
 TEM=0
 If [F:RBK]CHK="*"
  TEM=1
 Elsif [F:RBK]CHK<>""
  # on scrute toutes les écritures comptables ayant ce code pointage,
  # si au moins une écriture a une date cpt > DATECRFIN, on prend le relevé KO=0 sinon KO=1
  NB=0
  KO=1
  For [DAE]DAE3 Where ACC=[F:BAN]BANACC & BPR=[F:BAN]BANBPR & CPY=[F:BAN]CPY & CHK=[F:RBK]CHK
&                  & ([F:BAN]FCY="" | FCYLIN=[F:BAN]FCY) With Nohint
   NB=1
   If [F:DAE]ACCDAT>[L]DATECRFIN : KO=0 : Break : Endif
  Next
  If !NB
   KO=0
   # on scrute tous les relevés comptables ayant ce code pointage,
   # si toutes ces relevés ont une date cpt > DATRBKFIN, on prend le relevé
   For [RBK2]RBK1 Where CHK=[F:RBK]CHK & RECTYP=2 & BAN=[F:BAN]BAN & RBKNUM<>[RBK]RBKNUM With Nohint
    NB+=1
    If [F:RBK2]OPEDAT<=[L]DATRBKFIN : TEM=1 : Break : Endif
   Next
  Endif
  If !NB | KO=1 : TEM=1 : Endif
 Endif
 If [F:RBK]CHK="" | TEM=0
  Gosub ECR3
  If GOK<1 : Break : Endif
 Endif
Next
Filter [RBK]
If GOK=1 : Commit
Else : Rollback
Endif
Return

$ECR3
WNUMLIG += 1
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]NUMLIG = [L]WNUMLIG
[F:ARM]CLEA1  = "RELEVE"
[F:ARM]CLEA2  = [F:BAN]CPY
[F:ARM]CLEA3  = [F:BAN]BAN
[F:ARM]CLEA4  = [L]DEVEDI
[F:ARM]CLEA5  = [F:RBK]RBKNUM
[F:ARM]CLEA6  = [L]CPYCUR
[F:ARM]CLEN1  = [F:RBK]RBKLIN
[F:ARM]CLEN2  = SNSB
[F:ARM]CLEN3  = [F:FIY]FIYNUM
[F:ARM]CREDAT = datesyst
Write [F:ARM]
If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif
Return
