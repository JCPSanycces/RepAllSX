#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################
# UTITC54                                                  Module Tronc commun                        #
# Initialisation de MAILXML.LAN="FRA"                                                                   #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-08-07 by MAE :
 #Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif
 If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC54: add descriptions") From LECFIC

 Call MAJ_UTITC54(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################################
Subprog MAJ_UTITC54(APPLI)
Value Char APPLI

  If filinfo(filpath("FIL", "MAILXML", "fde", APPLI), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  #
  Call ECR_TRACE("UUTITC54: Process Start on: "+APPLI,0) From GESECRAN
  Local File =APPLI+".MAILXML" [MXL]
  Local File =APPLI+".ATEXTRA" [AXX]
  #
  Trbegin [MXL]
  For [F:MXL]
    # ---------------
    Call MAJTEXTRA(left$([F:MXL]NUM,GLONAX1), "MAILXML", "MXLSHOAX1", [F:MXL]NUM, "") From ATEXTRA
    If GOK < 1 Then
      Call ECR_TRACE("File ATEXTRA MAILXML-MXLSHOAX1" - [F:MXL]NUM + ",Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      Break
    Endif
    # ---------------
    Call MAJTEXTRA(left$([F:MXL]NUM,GLONAX3), "MAILXML", "MXLDESAX3", [F:MXL]NUM, "") From ATEXTRA
    If GOK < 1 Then
      Call ECR_TRACE("File ATEXTRA MAILXML-MXLDESAX3" - [F:MXL]NUM + ",Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      Break
    Endif
    # ---------------
  Next
  If GOK = 0 Then
    Goto AB_UUTITC54
  Endif
  Commit
  Call ECR_TRACE("UUTITC54: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITC54
  Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","MAILXML","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"MAILXML") : End : Endif
  # End MAE 108760

  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC54(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
If APPLI=GDOSX3
     End
Endif

  # Issue 108760 - 2015-08-07 by MAE :
  If filinfo(filpath("FIL","MAILXML","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"MAILXML") : End : Endif
  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC54(APPLI)
End

