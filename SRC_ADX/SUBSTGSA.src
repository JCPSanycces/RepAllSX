Subprog S_CPCPIOCOD(VALEUR)
Variable Char    VALEUR()
Local Char    SETASEL
SETASEL = [M:STG2]SETSEL

#If !GWEBSERV
Filter [HRCPC] Where SETACOD = SETASEL
#LIPET - X3-29541 - 2017-11-24 - START
#VALEUR = SETASEL
#LIPET - X3-29541 - 2017-11-24 - END

 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "HRSCPC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [HRCPC]
#Endif
Gosub AFF From GSAISIE

End

#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - START
Subprog AM_CPYTRG(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("KZA")>0
  If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA   [CPYKSA] : Endif
  Read [F:CPYKSA]CPYKSA0 = VALEUR
  If !fstat
    [M:STG2]SETSEL = [F:CPYKSA]SDLSETA
  Else
    [M:STG2]SETSEL = ""
  Endif
  Affzo [M:STG2]SETSEL
Endif
End


If clalev([F:FCYSA])=0 : Local File HRFACILITYSA   [FCYSA] : Endif
Read [F:FCYSA]FCYSA0 = VALEUR
If !fstat
  [M:STG2]SETSEL = [F:FCYSA]SDLSETA
Else
  [M:STG2]SETSEL = ""
  Endif
  Affzo [M:STG2]SETSEL
End
#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - END

#LIPET - X3-29541 - 2017-11-24 - START
Subprog C_CPCPIOCOD(VALEUR)
Variable Char VALEUR()
Variable Integer I : I=1

If [M:STG2]SETSEL <> "" & VALEUR <> "" Then
  Filter [HRCPC] Where SETACOD = [M:STG2]SETSEL
  For [HRCPC]
    If VALEUR = [HRCPC]CPCPIOCOD Then
      I = 0 :Break
    Endif
  Next
  If I>0:GMESSAGE=VALEUR-':'-mess(00023,00100,1):mkstat=2:End:Endif
  Filter [HRCPC]
Endif
End
#LIPET - X3-29541 - 2017-11-24 - END
