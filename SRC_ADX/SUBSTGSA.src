#FRLAA - 2015-03-18 - Requirement 101301 US 1 - START

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "FILTRE"    : Gosub FILTRE
Endcase
Return

$OUVRE
    If clalev([F:HRTPER])=0    : Local File HRSTRAINPER  [HRTPER]         : Endif
    If clalev([F:HRCPC])=0 : Local File HRSCPCPIO    [HRCPC]         : Endif
Return

$LIENS
Read [F:HRTPER]HRTPER0=[M:STG0]COD
  If !fstat
    [M:STG2] = [F:HRTPER]
#    #FRLAA - 2015-04-17 - Requirement 104631 US 3487 - START
#    If clalev([F:CPY])=0 : Local File HRCOMPANYKSA   [FCYSA] : Endif
#    Read [F:FCYSA]FCYSA0 = [STR]FCYTRG
#    If !fstat
#      [M:STG2]SETSEL = [F:FCYSA]SDLSETA
#    Endif
#    #FRLAA - 2015-04-17 - Requirement 104631 US 3487 - END
  Endif
Return

$MODIF
$CREATION
  Delete [HRTPER] Where COD=[F:STG]COD
    If fstat=1
     GOK = -1
     GLOCK = "$HRSTRAINPER"-[F:STG]COD
     Return
    Elsif fstat>5
     GOK = 0
     Call RSTA("HRTPER",[F:STG]COD) From GLOCK
     Return
    Endif
    [F:HRTPER]COD = [F:STG]COD
    [F:HRTPER]    = [M:STG2]
    Write [HRTPER]
    If fstat
     GOK=0 : Return
    Endif
Return


$FILTRE
  If clalev([F:HRTPER])=0 : Local File HRSTRAINPER    [HRTPER]         : Endif
    If [F:STG]COD<>[F:HRTPER]COD
      Read [HRTPER]HRTPER0 = [F:STG]COD
    Endif
  Return


