#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE(mess(536, 196, 2)) From LECFIC
 Call FEEDMAR(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################################

#####################################################################################################################
# Alimentation de la table MARASSDEF sur la base du contenu de la table REPSEC      Module CRM     15 janvier 2002  #
#                                                                                                                   #
# Moulinette associée à la gestion des secteurs de marché.                                                          #
#                                                                                                                   #
#####################################################################################################################

Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

Read [ADS] DOSSIER=APPLI
If fstat
    Raz [F:ADS]
    End
Endif

If [F:ADS]MODULE(12) <> 2 : End : Endif

Call FEEDMAR(APPLI)

End

#######################################################################
Subprog FEEDMAR(SZAPPLI)
Value Char SZAPPLI

Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TRACE(mess(533, 196, 2) + SZAPPLI,0) From GESECRAN  #Début de l'alimentation des secteurs de marchés
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

If !clalev([F:MAR]) : Local File =SZAPPLI+".MARASSREP" [MAR] : Endif
If !clalev([F:RSE]) : Local File =SZAPPLI+".REPSEC" [RSE] : Endif
If !clalev([F:BPC]) : Local File =SZAPPLI+".BPCUSTOMER" [BPC] : Endif
If !clalev([F:BPR]) : Local File =SZAPPLI+".BPARTNER" [BPR] : Endif
If !clalev([F:BPD]) : Local File =SZAPPLI+".BPDLVCUST" [BPD] : Endif

Local Integer ITER
Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
Local Char SZCLE
Local Integer ICLECOUNT
Local Integer ICUT
Local Char SZCBPCNUM
Local Char SZCBPCADD
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
STOPLOOP = 0
LOOPCRIT = ""
SZCBPCNUM = ""
SZCBPCADD = ""
IPERF = 0
IPBL = 0
INTR = 0
ITER = 1
SZCLE = ""
ICUT = 1750
ICLECOUNT = ICUT

#Alimentation sur la base des représentants principaux
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [BPC] Where [F:BPC]BPCNUM > SZCLE Order By [F:BPC]BPCNUM Asc

    For [BPC]
        SZCLE = [F:BPC]BPCNUM

        If IPERF = 0
            If !INTR
                Call DEBTRANS From GLOCK 
                Trbegin [MAR]
                INTR = 1
            Endif
        Endif

        Read [BPR] BPR0 = [F:BPC]BPCNUM
        If !fstat
            ITER = 1
            For ITER = 1 To dim([F:BPC]REP)
                If [F:BPC]REP(ITER - 1) <> ""
                    Read [MAR] MAR2 = [F:BPC]BPCNUM;[F:BPR]BPAADD;"BPR";ITER
                    If fstat
                    #L'affectation n'existe pas il faut la créer
                        [F:MAR]RECORDNUM = [F:BPC]BPCNUM
                        [F:MAR]RECORDADD = [F:BPR]BPAADD
                        [F:MAR]RECORDTYP = "BPR"
                        [F:MAR]REPNUM = [F:BPC]REP(ITER - 1)
                        [F:MAR]REPTYP = ITER
                        [F:MAR]REPMSS = ""
                        [F:MAR]REPITM = ""
                        [F:MAR]MANASS = 1
                        Write [MAR]
                        If fstat
                            #Erreur lors de l'affectation des représentants à l'enregistrement : 
                            Call ECR_TRACE(mess(532, 196, 2) + [F:BPC]BPCNUM,1) From GESECRAN
                            IPBL = 1
                            INTR = 0
                            Rollback
                            Break
                        Else
                            If IPERF >= 500
                                Commit
                                Call DEBTRANS From GLOCK 
                                Trbegin [MAR]
                                INTR = 1
                                IPERF = 1
                            Else
                                IPERF += 1
                            Endif
                        Endif
                    Else
                    #L'affectation existe il faut la modifier
                        [F:MAR]RECORDNUM = [F:BPC]BPCNUM
                        [F:MAR]RECORDADD = [F:BPR]BPAADD
                        [F:MAR]RECORDTYP = "BPR"
                        [F:MAR]REPNUM = [F:BPC]REP(ITER - 1)
                        [F:MAR]REPTYP = ITER
                        [F:MAR]REPMSS = ""
                        [F:MAR]REPITM = ""
                        [F:MAR]MANASS = 1
                        Rewrite [MAR]
                        If fstat
                            #Erreur lors de l'affectation des représentants à l'enregistrement : 
                            Call ECR_TRACE(mess(532, 196, 2) + [F:BPC]BPCNUM,1) From GESECRAN
                            IPBL = 1
                            INTR = 0
                            Rollback
                            Break
                        Else
                            If IPERF >= 500
                                Commit
                                Call DEBTRANS From GLOCK 
                                Trbegin [MAR]
                                INTR = 1
                                IPERF = 1
                            Else
                                IPERF += 1
                            Endif
                        Endif
                    Endif
                Endif
            Next
        Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif

        If IPBL : Break : Endif
    Next

    Filter [BPC]

    If IPBL : Break : Endif
Wend

If IPBL
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(535, 196, 2),0) From GESECRAN  #Alimentation des secteurs de marchés terminée sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
Endif

If INTR
    If !IPBL
        Commit
    Endif
Endif

#Alimentation sur la base des clients livrés
SZCBPCNUM = ""
SZCBPCADD = ""
IPERF = 0
IPBL = 0
INTR = 0
ITER = 1
ICUT = 1750
ICLECOUNT = 0
STOPLOOP = 0
LOOPCRIT = ""

$SNAPLOOP
If STOPLOOP = 1
      STOPLOOP = 2
      LOOPCRIT = "[F:BPD]BPCNUM=SZCBPCNUM & [F:BPD]BPAADD>SZCBPCADD"

Elsif STOPLOOP = 2
      STOPLOOP = 0
      LOOPCRIT = "[F:BPD]BPCNUM>SZCBPCNUM"

Else
      LOOPCRIT = "1=1"
Endif
ICLECOUNT = 0

For [BPD]BPD0 Where evalue(LOOPCRIT)
    If IPERF = 0
        If !INTR
            Call DEBTRANS From GLOCK 
            Trbegin [MAR]
            INTR = 1
        Endif
    Endif

    ITER = 1
    For ITER = 1 To dim([F:BPD]REP)
         If [F:BPD]REP(ITER - 1) <> ""
             Read [MAR] MAR2 = [F:BPD]BPCNUM;[F:BPD]BPAADD;"BPR";ITER
             If fstat
                 #L'affectation n'existe pas il faut la créer
                 [F:MAR]RECORDNUM = [F:BPD]BPCNUM
                 [F:MAR]RECORDADD = [F:BPD]BPAADD
                 [F:MAR]RECORDTYP = "BPR"
                 [F:MAR]REPNUM = [F:BPD]REP(ITER - 1)
                 [F:MAR]REPTYP = ITER
                 [F:MAR]REPMSS = ""
                 [F:MAR]REPITM = ""
                 [F:MAR]MANASS = 1
                 Write [MAR]
                 If fstat
                     #Erreur lors de l'affectation des représentants à l'enregistrement : 
                     Call ECR_TRACE(mess(532, 196, 2) + [F:BPD]BPCNUM,1) From GESECRAN
                     IPBL = 1
                     INTR = 0
                     Rollback
                     Break
                 Else
                     IPERF += 1
                 Endif
             Endif
         Endif
    Next

    ITER = 1
    For ITER = 1 To dim([F:BPD]REP)
        If [F:BPD]REP(ITER - 1) <> ""
            Read [MAR] MAR2 = [F:BPD]BPCNUM;[F:BPD]BPAADD;"BPD";ITER
            If fstat
                #L'affectation n'existe pas il faut la créer
                [F:MAR]RECORDNUM = [F:BPD]BPCNUM
                [F:MAR]RECORDADD = [F:BPD]BPAADD
                [F:MAR]RECORDTYP = "BPD"
                [F:MAR]REPNUM = [F:BPD]REP(ITER - 1)
                [F:MAR]REPTYP = ITER
                [F:MAR]REPMSS = ""
                [F:MAR]REPITM = ""
                [F:MAR]MANASS = 1
                Write [MAR]
                If fstat
                    #Erreur lors de l'affectation des représentants à l'enregistrement : 
                    Call ECR_TRACE(mess(532, 196, 2) + [F:BPD]BPCNUM,1) From GESECRAN
                    IPBL = 1
                    INTR = 0
                    Rollback
                    Break
                Else
                    If IPERF >= 500
                        Commit
                        Call DEBTRANS From GLOCK 
                        Trbegin [MAR]
                        INTR = 1
                        IPERF = 1
                    Else
                        IPERF += 1
                    Endif
                Endif
            Else
                #L'affectation existe il faut la modifier
                [F:MAR]RECORDNUM = [F:BPD]BPCNUM
                [F:MAR]RECORDADD = [F:BPD]BPAADD
                [F:MAR]RECORDTYP = "BPD"
                [F:MAR]REPNUM = [F:BPD]REP(ITER - 1)
                [F:MAR]REPTYP = ITER
                [F:MAR]REPMSS = ""
                [F:MAR]REPITM = ""
                [F:MAR]MANASS = 1
                Rewrite [MAR]
                If fstat
                    #Erreur lors de l'affectation des représentants à l'enregistrement : 
                    Call ECR_TRACE(mess(532, 196, 2) + [F:BPD]BPCNUM,1) From GESECRAN
                    IPBL = 1
                    INTR = 0
                    Rollback
                    Break
                Else
                    If IPERF >= 500
                        Commit
                        Call DEBTRANS From GLOCK 
                        Trbegin [MAR]
                        INTR = 1
                        IPERF = 1
                    Else
                        IPERF += 1
                    Endif
                Endif
            Endif
        Endif
    Next

    If IPBL : Break : Endif

    ICLECOUNT += 1
    If ICLECOUNT >= ICUT
        SZCBPCNUM = [F:BPD]BPCNUM
        SZCBPCADD = [F:BPD]BPAADD
        STOPLOOP = 1
        Break
    Endif
Next

If STOPLOOP
    Goto SNAPLOOP
Endif 

If IPBL
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(535, 196, 2),0) From GESECRAN  #Alimentation des secteurs de marchés terminée sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
Endif

If INTR
    If !IPBL
        Commit
    Endif
Endif

#Alimentation sur la base des représentants secondaires
IPERF = 0
IPBL = 0
INTR = 0
ITER = 0

#Supprime toutes les affectations manuelles existantes issues de la saisie des représentants secondaires
Call DEBTRANS From GLOCK 
Trbegin [MAR]
Delete [MAR] Where [F:MAR]REPTYP = 0 and [F:MAR]RECORDTYP = "BPR" and [F:MAR]MANASS = 1
If fstat
    #Erreur lors de la suppression des affectations manuelles de représentants secondaires.
    Call ECR_TRACE(mess(537, 196, 2),1) From GESECRAN
    IPBL = 1
    Rollback
Else
    Commit
Endif

If IPBL
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(535, 196, 2),0) From GESECRAN  #Alimentation des secteurs de marchés terminée sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
Endif

For [RSE]
    If IPERF = 0
        If !INTR
            Call DEBTRANS From GLOCK 
            Trbegin [MAR]
            INTR = 1
        Endif
    Endif

    If [F:RSE]AUTASS = 0
        Read [BPR] BPR0 = [F:RSE]BPCNUM
        If !fstat
           #L'affectation n'existe pas il faut la créer
           [F:MAR]RECORDNUM = [F:RSE]BPCNUM
           [F:MAR]RECORDADD = [F:BPR]BPAADD
           [F:MAR]RECORDTYP = "BPR"
           [F:MAR]REPNUM = [F:RSE]REPNUM
           [F:MAR]REPTYP = ITER
           [F:MAR]REPMSS = [F:RSE]MSS
           [F:MAR]REPITM = [F:RSE]GRPITM
           [F:MAR]MANASS = 1
           Write [MAR]
           If fstat
               #Erreur lors de l'affectation des représentants à l'enregistrement : 
               Call ECR_TRACE(mess(532, 196, 2) + [F:RSE]BPCNUM,1) From GESECRAN
               IPBL = 1
               INTR = 0
               Rollback
               Break
           Else
               If IPERF >= 500
                    Commit
                    IPERF = 0
                    INTR = 0
               Else
                    IPERF += 1
               Endif
           Endif
        Endif
    Endif
Next

If IPBL
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(535, 196, 2),0) From GESECRAN  #Alimentation des secteurs de marchés terminée sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
Endif

If INTR
    If !IPBL
        Commit
    Endif
Endif

Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TRACE(mess(534, 196, 2) + SZAPPLI,0) From GESECRAN  #Alimentation des secteurs de marchés terminée.
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

End


#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(12) <> 2 : End : Endif
Call FEEDMAR(APPLI)

End




