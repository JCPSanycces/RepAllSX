######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"DAP",GBIDC2) From GOBJET
End

## Etiquette ajoutée par le superviseur (Objet DAP) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"
  Case TABLE
   When "SELEMPDDS"   : Gosub SELEMPDDS
  Endcase
 When "BS_WEMP"     : Gosub BS_WEMP
 #SEGAY US1840 US1933 81085 25/09/2013 action envoyée de SELEMPCTR
 When "BAS_WCTR"  : Gosub BAS_CTRNUM From TOOLSHRLEG
Endcase
Return

#######################################################################################################################################
# BOITE DE DIALOGUE + BOUTON NOUVEAU
#######################################################################################################################################
###################################

###################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]WYEA=[F]YEAEMPDDS
[M:DIA]WEMP=[F]EMPDDS
#SEGAY US1840 US1933 81085 25/09/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([M:DIA]WEMP,"[M:DIA]","WNAM","WSRN",0,0) From DIVPAYE
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
If GFONCTION="GESHRDPP"
 [M:DIA]WREFCTR=[F]REFCTR
 Read [DAP2]DAP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
 If !fstat
  [M:DIA]WNUMDCS=[F:DAP2]NUMDCS
 Endif
Endif
Return

###################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

###################################
$EXEC
If GFONCTION="GESHRDPP"
 Gosub NEWDPP
Else
 Gosub NEWDAP
Endif
Return

###################################
$NEWDAP
# Vérif existance fiche DADS-U
Read [DAE2]DAE0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;1
If fstat
 #Période d'activité salarié dads-u inexistante
 GMESSAGE = mess(80,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [DAP2]DAP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If !fstat
 #Ce contrat de prévoyance dads-u existe déjà
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(82,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [DPP2]DPP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif

SYMBOLE = "DAP"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR

Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
Return

###################################
$TR1
GOK=1
Trbegin [DAP2],[DPP2]
Raz[F:DAP2]
Gosub TR_DAP
If GOK : Gosub TR_DPP : Endif
If GOK<0    : Goto ROL_TR1
Elsif GOK=0 : Goto AB_TR1
Endif
Commit
Return

###################################
$TR_DAP
[F:DAP2]=[F:DAE2]
[F:DAP2]REFCTR=[M:DIA]WREFCTR
[F:DAP2]NUMDCS=[M:DIA]WNUMDCS
#Nb enfants
Call LECTURE("EML",[M:DIA]WEMP,"") From CONTOBJ
[F:DAP2]NBRCHD= num$([F:ID]CHD)
Write [DAP2]
If fstat<>0
 GOK = 0 : Call FSTA("DAP") From GLOCK
Endif
Return

###################################
$AB_TR1
Rollback
Return

###################################
$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##################################
$NEWDPP
# Vérif existance fiche prévoyance DADS-U
Read [DAP2]DAP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR
If fstat
 #Contrat de prévoyance dads-u inexistant
 GMESSAGE = mess(81,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif
# Vérif absence fiche Prévoyance DADS-U
Read [DPP2]DPP0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;[M:DIA]WREFCTR;[M:DIA]WDATDEB
If !fstat
 #Une période de cotisations existe déjà en date du
 GMESSAGE = [M:DIA]WREFCTR-":"-mess(83,10705,1)-num$([M:DIA]WDATDEB)
 GERR = 1 : SAI = 1
 Return
Endif
SYMBOLE = "DPP"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+[M:DIA]WREFCTR+"\"+[M:DIA]WDATDEB
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR2
Unlock =SYMBOLE
Return

###################################
$TR2
GOK=1
Trbegin[DPP2]
Gosub TR_DPP
If GOK<0    : Goto ROL_TR2
Elsif GOK=0 : Goto AB_TR2
Endif
Commit
Return

###################################
$TR_DPP
GOK=1
Raz[F:DPP2]
[F:DPP2]=[F:DAP2]
[F:DPP2]STRDATCTR=[M:DIA]WDATDEB
[F:DPP2]ENDDATCTR=[M:DIA]WDATFIN
Write [DPP2]
If fstat<>0
 GOK = 0 : Call FSTA("DPP") From GLOCK
Endif
Return

###################################
$AB_TR2
Rollback
Return

###################################
$ROL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###################################
$SELEMPDDS
Local Char ANCOUR (4)
ANCOUR=PARAM(1)
Case GFONCTION
 When "GESHRDPP" : OBJET = "DAP" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"'"
 When "GESDMP" : OBJET = "DMU" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"'"
 When Default  : OBJET = "DAE" : CRITERE = "YEAEMPDDS='"+PARAM(1)+"' & FLGDNA=1"
Endcase
If VALEUR<>""
 CRITERE -= "& EMPDDS>='"+VALEUR+"'"
Endif
START = "EMPDDS"
Return

###################################
$BS_WEMP
Gosub DEFTAB
Gosub AFFDIA
Return

###################################
$DEFTAB
Case GFONCTION
 When "GESHRDPP" : Default File [DAP]
 When "GESDMP" : Default File [DMU]
 When Default  : Default File [HRDAE]
Endcase
Return

###################################
$AFFDIA
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
If GFONCTION="GESHRDPP" |  GFONCTION="GESDMP"
 [M:DIA]WREFCTR=[F]REFCTR
 [M:DIA]WNUMDCS=[F]NUMDCS
Endif
Affzo [M:DIA]
Return

#########################################################################################################
# Ecran
#########################################################################################################

Subprog AS_WYEA(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Call PARAM("","DADYEA",VALEUR) From ADOVAL : Endif
If GFONCTION ="GESDAP" | GFONCTION ="GESDMU"
 Grizo [M:DIA]25
Elsif GFONCTION ="GESHRDPP" | GFONCTION ="GESDMP"
 Grizo [M:DIA]15
 Grizo [M:DIA]25
Endif
End

###################################
Subprog C_WEMP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub DEFTAB
If VALEUR<>[M:DIA]WEMP & VALEUR<>[F]EMPDDS
 If GFONCTION="GESHRDPP"
  Filter [DAP] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR
  Read [DAP]DAP0 First
  Filter [DAP]
 #59275
 Elsif GFONCTION ="GESDMP"
  Filter [DMP] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR
  Read [DMP]DMP0 First
  Filter [DMP]
 Else
  Filter [HRDAE] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR & FLGDNA=1
  Read [HRDAE]DAE0 First
  Filter [HRDAE]
 Endif
 If !fstat
  Gosub AFFDIA
 Else
  GMESSAGE=mess(23,100,1) #: Fiche inexistante
  mkstat=2 : End
 Endif
Endif
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If [F:ID]FLGMULCTR=2
 Effzo [M:DIA]WCTR
 Actzo [M:DIA]WCTR
Else
 Grizo [M:DIA]WCTR
Endif
End

