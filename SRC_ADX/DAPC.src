######################################################################################
Subprog AM_WEMP(VALEUR)
Variable Char    VALEUR()
#SEGAY US1840 US1933 81085 25/09/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(VALEUR,"[M:DIA]","WNAM","WSRN",0,0) From DIVPAYE
End


