#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRNCT",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "AS_COD"      : Raz GCURLEG        :#Used in SELOBJETL action to disable the filter under the current legislation
Endcase
Return

########################################
$OUVRE
If clalev ([F:HRNCT])=0 : Local File HRNATCON   [HRNCT] : Endif
If clalev ([F:HRNCT2])=0 : Local File HRNATCON   [HRNCT2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#LIPET - 2017-08-22 - START
If dim([M:HRNCT1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
Return

########################################
$LIENS

GCURLEG = [F:HRNCT]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([M:HRNCT1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DESAXX,"HRNATCON","DESAXX",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRNATCON","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
# To display or to hide fields based on legislation code
Gosub DISPLAY_HIDE
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRNATCON","DESAXX",CLECUR1,"","HRNATCON","DESAXX",[F:HRNCT]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRNATCON","SHOAXX",CLECUR1,"","HRNATCON","SHOAXX",[F:HRNCT]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESAXX,"HRNATCON","DESAXX",[F:HRNCT]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HRNATCON","SHOAXX",[F:HRNCT]COD,GCURLEG) From ATEXTRA
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]DEFVAL=2
 Filter [F:HRNCT2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
 Read [F:HRNCT2]HRNCT0 First
 Filter [F:HRNCT2]
 If !fstat
  # A default value already exist for this legislation : XXX
  GMESSAGE = mess(1,10712,1)-":'"-[F:HRNCT2]COD+"'"
  OK = 0 : Return
 Endif
Endif
Return

########################################
$DISPLAY_HIDE
Case GCURLEG
 When "FRA",""
   Chgfmt [M]CODN4H  With "K:10X"
   Chgfmt [M]CODDUE  With "K:10X"
 When Default
   Chgfmt [M]CODN4H  With "-K:10X"
   Chgfmt [M]CODDUE  With "-K:10X"
Endcase
Return

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("HRNATCON","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("HRNATCON","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("HRNATCON","DESAXX",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRNATCON","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRNCT) : Endif
VCOD = CLE2
Return

###############################################################################
##  Button 'Copy'
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File HRNATCON  [HRNCT1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".HRNATCON"  [HRNCT1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File HRNATCON [HRNCT2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".HRNATCON"  [HRNCT2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [HRNCT1], [HRNCT2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [HRNCT2]
 Delete [HRNCT2] Where TYP=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRNATCON" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRNCT2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRNCT1] Where TYP=TABLE & LEG=TABLE2
  [F:HRNCT2] = [F:HRNCT1]
  Call COPTEXTRA("HRNATCON","DESAXX",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("HRNATCON","SHOAXX",TABLE,TABLE2) From ATEXTRA
  If dim([F:HRNCT2]UPDUSR)>0 : [F:HRNCT2]UPDUSR = GUSER : Endif
  If dim([F:HRNCT2]UPDDAT)>0 : [F:HRNCT2]UPDDAT = date$ : Endif
  Write [HRNCT2]
  If fstat
   GOK = 0 : Call FSTA("HRNCT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

############################################################################################
## Subprog of screen HRNCT0
############################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub DISPLAY_HIDE
End


############################################################################################
## Action on the datatype
############################################################################################

#Selection
########################################
$SEL_TABLE
Case TABLE
 When "SELHRNCT"
  If clalev ([F:HRNCT])=0 : Local File HRNATCON   [HRNCT] : Endif
  OBJET="HRNCT"
  START   = "[F:HRNCT]COD"
  #Filter based on code legislation
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRNCT]LEG="'+PARAM(1)+'" | [F:HRNCT]LEG="")',"&") From GOBJSUB
  Endif
  #Filter based on group of company
  If PARAM(2)<>""
    #OBJET=""
    DEFPAG = 1    :# To have page up and page down
    TIT=mess(2,10712,1) : #Type of contract
    Gosub NOMFIC From ="WOHRNCT"
    Call  TRANSCOL("HRNCT",NBCOL,COL,TIT,FMTCOL) From OBJDIV
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
    If GUSRACS=2
     Link [HRNCT] With
&    [AGC]AGC0=[F:HRNCT]GRP,
&    [AXX]AXX0="HRNATCON";"DESAXX";GLANGUE;[F:HRNCT]COD;[F:HRNCT]LEG
&    As [LNK]
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRNCT]GRP="")',"&") From GOBJSUB
   Else
     Link [HRNCT] With
&    [AGC]AGC0=[F:HRNCT]GRP,
&    [AXX]AXX0="HRNATCON";"DESAXX";GLANGUE;[F:HRNCT]COD;[F:HRNCT]LEG,
&    [ACC]CODACC=GUSER;[F:HRNCT]CODACS
&     As [LNK]
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRNCT]GRP="") & ([F:HRNCT]CODACS="" | [F:ACC]CONSUL=2)',"&") From GOBJSUB
    Endif

    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRNCT]ENAFLG=2',"&") From GOBJSUB

    NBCOL += 1 : COL(NBCOL) = "[F:HRNCT]GRP"    : COLTYP(NBCOL) =  type([F:HRNCT]GRP)    : TIT(NBCOL) =mess(237,133,1)
    Default File [LNK]
   Endif
Endcase
Return


# To do a generic Call CONTSEL... from
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRNCT(COD,LEG,SOC)
End


# Controls
##################################################
Subprog CONTHRNCT(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS

If GFONCTION = "GESHRNCT" | COD="" : End : Endif

If clalev([F:HRNCT])=0 : Local File HRNATCON [HRNCT] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [HRNCT]HRNCT0=COD;LEG
 If fstat
  Read [HRNCT]HRNCT0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [HRNCT]HRNCT0(1)=COD
 If !fstat
  LEG = [F:HRNCT]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [HRNCT] Where COD=COD
 Look [HRNCT]HRNCT0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [HRNCT]
 mkstat = 2 : End
Endif
If CAS=2
 Call CONTROLE("HRNCT","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("HRNCT","","",COD,mkstat) From CONTOBJ
Endif

If [F:HRNCT]GRP<>"" & SOC<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:HRNCT]GRP;SOC
  If fstat
   GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRNCT]GRP : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
 Endif

If GUSRACS<>2
 If [F:HRNCT]CODACS <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:HRNCT]CODACS
  If fstat or [F:ACC]CONSUL <> 2
   GMESSAGE = [F:HRNCT]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

End

#Zoom
##################################################
Subprog TUNHRNCT(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRNCT)
 TOKILL = 1
Endif

If clalev([F:HRNCT])=0 : Local File HRNATCON [HRNCT] : Endif

# To update the HRNCT code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRNCT record with LEG="" secondly a HRNCT record with LEG<>""
 Read [HRNCT]HRNCT0 = VCOD;LEG
 If fstat
  Read [HRNCT]HRNCT0(1)=VCOD
  If !fstat
   LEG = [F:HRNCT]LEG
  Endif
 Endif
Endif

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRNCT] Where LEG=[L]LEG
  Read [F:HRNCT] First
  Filter [HRNCT]
  If !fstat : VCOD=[F:HRNCT]COD : Endif
Else
  Read [HRNCT]HRNCT0 = VCOD;LEG
Endif

If fstat : LEG = "" : Endif

Call OBJET("HRNCT",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End


#Return the default value
##################################################
Subprog DEFHRNCT(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG()
Value    Char    SOC()

If GFONCTION = "GESHRNCT" | COD<>"" : End : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif

If LEG<>""
 Filter [F:HRNCT] Where LEG=[L]LEG & DEFVAL=2
 Read[F:HRNCT]HRNCT0 First
 Filter [F:HRNCT]
 If !fstat
  COD=[F:HRNCT]COD
  End
 Endif
Endif

Filter [F:HRNCT] Where LEG="" & DEFVAL=2
Read[F:HRNCT]HRNCT0 First
Filter [F:HRNCT]
If !fstat
 COD=[F:HRNCT]COD
 End
Endif
End

##################################
Subprog SIMPLEREAD(COD,LEG,ERR)
Value Char COD ()
Value Char LEG ()
Variable Integer ERR         :#return the 'fstat' about the read

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif

[L]ERR=1

If [L]LEG<>""
 Read[F:HRNCT]HRNCT0=[L]COD;[L]LEG
 [L]ERR=fstat
Endif
If [L]ERR
 Read[F:HRNCT]HRNCT0=[L]COD;""
 [L]ERR=fstat
Endif
End

