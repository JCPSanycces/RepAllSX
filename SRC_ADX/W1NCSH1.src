Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELNCSDOC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELNCSDOC"
 PARMSK(1) = num$([M:NCSH1]DOCTYP(nolign-1))
 PARMSK(2) = num$([M:NCSH1]VCRLIN(nolign-1))
 PARMSK(3) = [M:NCSH0]SITE
 PARMSK(4) = [M:NCSH0]NCSBPC
 PARMSK(5) = [M:NCSH0]NCSBPS
 PARMSK(6) = [M:NCSH0]PRODUCT
 PARMSK(7) = func TRTX3FNC.VALFLD_C("[M:NCSH0]ECCVALMAJ")
 PARMSK(8) = func TRTX3FNC.VALFLD_C("[M:NCSH0]ECCVALMIN")
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELNCSDOC","SELNCSDOC","") From GACTION
 [M:NCSH1]VCRLIN(nolign-1) = val(PARMSK(2))
 GACTION = SAVACT
Endif
Gosub _AFF
End

