Subprog AS_PJT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(43841,GBOUT1) From OBJDIV
Call TEXTE(14667,GBOUT2) From OBJDIV
Call TEXTE(54273,GBOUT3) From OBJDIV
Call TEXTE(43844,GBOUT4) From OBJDIV
Call TEXTE(43868,GBOUT15) From OBJDIV
Call TEXTE(17676,GBOUT16) From OBJDIV
Call TEXTE(54274,GBOUT17) From OBJDIV
Call TEXTE(54275,GBOUT18) From OBJDIV
Call TEXTE(11781,GBOUT19) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_PJT(VALEUR)
## Action PJTBEFZON
Call PJT_BEFORE_ZONE(VALEUR,"","","","","","",""
&,"","","","","","","",""
&,"","","","") From TRTPJT
If mkstat=2
 [M]PJT(INDIC) = VALEUR
 Affzo PJT(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PJT(zc) From W1NCSH1
Onkey 130 Titled GBOUT2 Call B2_PJT(zc) From W1NCSH1
Onkey 131 Titled GBOUT3 Call B3_PJT(zc) From W1NCSH1
Onkey 132 Titled GBOUT4 Call B4_PJT(zc) From W1NCSH1
Onkey 172 Titled GBOUT15 Call B15_PJT(zc) From W1NCSH1
Onkey 173 Titled GBOUT16 Call B16_PJT(zc) From W1NCSH1
Onkey 174 Titled GBOUT17 Call B17_PJT(zc) From W1NCSH1
Onkey 175 Titled GBOUT18 Call B18_PJT(zc) From W1NCSH1
Onkey 176 Titled GBOUT19 Call B19_PJT(zc) From W1NCSH1
Onkey   2 Titled GBOUTS Call S_PJT(zc) From W1NCSH1
Onkey 144 Titled GBOUTP Call P_PJT(zc) From W1NCSH1
Onkey 146 Titled GBOUTA Call SA_PJT(zc) From W1NCSH1
Gosub _AFF
End

