#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:30"
A_USER  = "DOC"
A_STAMP = "20181109230530"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG3"
  If [M]NBLIG3=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSH1 [NCSH1]
Gosub HORODAT
Local Inpbox "NCSH1" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH1] As [SIM_]
Grizo [NCSH1]5
Grizo [NCSH1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSH1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=7
X1(1)=1 : X2(1)=74 : Y1(1)=8 : Y2(1)=20
Return

$ON_NCSPROCAU
Onevent INIT_AREA Call D_NCSPROCAU(zc) From W1NCSH1
Onevent CONTROL Call C_NCSPROCAU(zc) From W1NCSH1
Onevent BEFORE_INPUT Call AS_NCSPROCAU(zc) From W1NCSH1
Onevent AFTER_CHANGE Gosub AMM_NCSPROCAU From W1NCSH1
Return

Subprog D_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
If varinit([M]NCSPROCAU,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"804","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_NCSPROCAU(zc) From W1NCSH1
Onkey 144 Titled GBOUTP Call P_NCSPROCAU(zc) From W1NCSH1
Onkey 146 Titled GBOUTA Call SA_NCSPROCAU(zc) From W1NCSH1
If VALEUR="" : Call INIADI(VALEUR,"804") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"804","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"804",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_NCSPROCAU
Call AM_NCSPROCAU(zc)
If !mkstat & GOBJET
 zoncou = "NCSPROCAU" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZNCSPROCAU)")>indice
 [M]NCSPROCAU(indice) = VALEUR
 Affzo ZNCSPROCAU(indice)
Endif
Gosub _AFF
End

Subprog S_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "804"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "804"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NCSPROCAU(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "804"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNCSPROCAU
Onevent BEFORE_AREA Gosub AV_ZNCSPROCAU From W1NCSH1
Return

$AV_ZNCSPROCAU
Call LECTEXTRA(zc,"ATABDIV","LNGDES","804",num$([M]NCSPROCAU(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBLIG3
Onevent CONTROL Call C_NBLIG3 From W1NCSH1
Onevent AFTER_AREA Call AP_NBLIG3 From W1NCSH1
Onevent BEFORE_INPUT Call AS_NBLIG3 From W1NCSH1
Return

Subprog IB_NBLIG3
Local Decimal BASPAG
## Action STD
Call IB_NBLIG3 From SUBNCSH
Gosub _AFF
End

Subprog AS_NBLIG3
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(735,GBOUT1) From OBJDIV
Call TEXTE(454,GBOUT2) From OBJDIV
Call TEXTE(30140,GBOUT3) From OBJDIV
Call IB_NBLIG3
Onkey 129 Titled GBOUT1 Call B1_NBLIG3 From W1NCSH1
Onkey 130 Titled GBOUT2 Call B2_NBLIG3 From W1NCSH1
Onkey 131 Titled GBOUT3 Call B3_NBLIG3 From W1NCSH1
Gosub _AFF
End

Subprog C_NBLIG3
Local Decimal BASPAG
## Action STD
Call C_NBLIG3 From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NBLIG3" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog AP_NBLIG3
Local Decimal BASPAG
## Action STD
Call AP_NBLIG3 From SUBNCSH
If mkstat : GERR = 1 : GZONE = "NBLIG3" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBLIG3
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0A
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0A"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG3" : PROGSUB = "SUBNCSH" : PROGSPE = "SPENCSH" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 Local Char    OBJCLE(30)
 OBJCLE = [M:NCSH1]VCRNUM(nolign-1)
 Call OBJET_CHAR(OBJCLE,[M:NCSH1]CODOBJ(nolign-1),num$([M:NCSH1]VCRTYP(nolign-1))) From GOBJET
 ACTION = "BB1_NBLIG3" : PROGSUB = "SUBNCSH" : PROGSPE = "SPENCSH" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG3
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBLIG3 From SUBNCSH
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG3
Local Decimal BASPAG
If !GWEBSERV
 ## Action NCSDOCLIN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "NCSDOCLIN"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB3_NBLIG3" : PROGSUB = "SUBNCSH" : PROGSPE = "SPENCSH" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:NCSH1]VCRNUM(nolign-1)
 PARMSK(2) = num$([M:NCSH1]VCRLIN(nolign-1))
 PARMSK(3) = num$([M:NCSH1]NCSQTY(nolign-1))
 PARMSK(4) = num$([M:NCSH1]DOCLIN(nolign-1))
 PARMSK(5) = num$([M:NCSH1]DOCQTY(nolign-1))
 PARMSK(6) = [M:NCSH1]STU(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"DNCSD","NCSDOCLIN","") From GSAISIE
 [M:NCSH1]NCSQTY(nolign-1) = val(PARMSK(3))
 ACTION = "BB3_NBLIG3" : PROGSUB = "SUBNCSH" : PROGSPE = "SPENCSH" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_NCSID
Return

$ON_DOCTYP
Onevent BEFORE_INPUT Call AS_DOCTYP(zc) From W1NCSH1
Onevent CONTROL Call C_DOCTYP(zc) From W1NCSH1
Onevent AFTER_CHANGE Gosub AMM_DOCTYP From W1NCSH1
Onevent INIT_AREA Call D_DOCTYP(zc) From W1NCSH1
Return

Subprog D_DOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]DOCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DOCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(3718) From COMBOS
## Action STD
Call AS_DOCTYP(VALEUR) From SUBNCSH
If mkstat=2
 [M]DOCTYP(INDIC) = VALEUR
 Affzo DOCTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,3718,1))))
Endif
If !mkstat
 Discombo 0 From DOCTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From DOCTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_DOCTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_DOCTYP(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
Gosub _AFF
End

$AMM_DOCTYP
Call AM_DOCTYP(zc)
If !mkstat & GOBJET
 zoncou = "DOCTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DOCTYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_DOCTYP(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
Gosub _AFF
End

