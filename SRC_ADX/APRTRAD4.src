#<AdxTL>@(#)12.0.0.0 $Revision$ 
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1)="A5T"
PARAM(2)=""
PARAM(3)="FRA"
Call SAISIE_CHAR(VALEUR,PARAM,"APRTRAD4","APRTRAD4","SPEAPRTRAD4") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"           : Gosub INIT
Endcase
Return

$INIT
[M]VCODPRO=PARAM(1)
[M]VCODLEG=PARAM(2)
[M]VLANGUE=PARAM(3)
Call CLOBEXPLANG([M]VCODPRO,[M]VCODLEG,[M]VLANGUE,[M]APROC) From SUBAPR
Affzo [ATD4]
Return




# Gestion du masque APRTRAD4

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD4) 03/02/2009 09:48:03 (CCORA)
######################################################################################
Subprog AM_VLANGUE(VALEUR)
Variable Char    VALEUR()
Call CLOBEXPLANG([M]VCODPRO,[M]VCODLEG,VALEUR,[M]APROC) From SUBAPR
Affzo [ATD4]
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD4) 03/02/2009 13:57:44 (CCORA)
######################################################################################
Subprog AM_VCODPRO(VALEUR)
Variable Char    VALEUR()
Raz [M]VCODLEG    
Raz [M]APROC
Call CLOBEXPLANG(VALEUR,[M]VCODLEG,[M]VLANGUE,[M]APROC) From SUBAPR
Call LECTEXTRA([M]INTIT1,"APROCESSUS","INTIT1",VALEUR,"") From ATEXTRA
Affzo [ATD4]
End

Subprog AM_VCODLEG(VALEUR)
Variable Char    VALEUR()
Effzo [M]APROC
Call CLOBEXPLANG([M]VCODPRO,VALEUR,[M]VLANGUE,[M]APROC) From SUBAPR
Affzo [M]APROC
End

