#<AdxTL>@(#)0.0.0.0 $Revision$
 # Representation Class script: CCMPLAND_RSTD, Change request plan detail

$METHODS

  Case CURPTH
    When "CCMPH.CCMPLAND"
      Case ACTION
        When "AREAD_AFTER"
          Gosub POPULATE_ACTIONDESC
          Gosub POPULATE_ACTIONERNAME
        When "ADDLINE_BEFORE"
          Gosub CHECK_PLANNER
        When "ADELLINE_BEFORE"
          Gosub CHECK_PLANNER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Check the logged-in user is the planner. If not then disable actions.
$CHECK_PLANNER

  If (fmet this.APARENT.IS_PLANNER_USER(this.CRID) <> CST_ATRUE)
    ASTATUS = fmet this.ASETERROR("", mess(23,2038,1), CST_AERROR)
  Elsif (this.IMPLEMENT = 2)
    ASTATUS = fmet this.ASETERROR("", mess(55,2038,1), CST_AERROR)
  Endif

Return

$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "CCMPH.CCMPLAND.TRANTYPE.PROPAGATE"   : Gosub PROPAGATE_TRANTYPE
    When "CCMPH.CCMPLAND.ACTIONID.PROPAGATE"   : Gosub POPULATE_ACTIONDESC
    When "CCMPH.CCMPLAND.ACTIONER.PROPAGATE"   : Gosub PROPAGATE_ACTIONER
    When "CCMPH.CCMPLAND.LINESTATUS.PROPAGATE" : Gosub PROPAGATE_LINESTATUS
  Endcase

Return

# --------------------------------------------------
# Populate the Representation only (Action) Description.
$POPULATE_ACTIONDESC

  Local Instance CCMACTION Using C_CCMACTION
  CCMACTION = NewInstance C_CCMACTION AllocGroup null

  If (this.ACTIONID <> "")
    ASTATUS = fmet CCMACTION.AREAD(this.ACTIONID)
    If (ASTATUS <> CST_AOK)
      this.ACTIONDESC = ""
    Else
      this.ACTIONDESC = mess(CCMACTION.TRANACTION,2032,1)
    Endif
  Else
    this.ACTIONDESC = ""
  Endif

  FreeGroup CCMACTION

Return

# --------------------------------------------------
# Populate the Representation only (Actioner) Name.
$POPULATE_ACTIONERNAME

  Local Instance USER Using C_AUTILIS
  USER = NewInstance C_AUTILIS AllocGroup null

  If (this.ACTIONER <> "")
    ASTATUS = fmet USER.AREAD(this.ACTIONER)
    If (ASTATUS <> CST_AOK)
      this.ACTIONERNAME = ""
    Else
      this.ACTIONERNAME = USER.NOMUSR
    Endif
  Else
    this.ACTIONERNAME = ""
  Endif

  FreeGroup USER

Return

# --------------------------------------------------
# If the Transaction type changes then reset the Action / (Action) Description.
$PROPAGATE_TRANTYPE

  If (this.snapshot.TRANTYPE <> this.TRANTYPE)
    this.ACTIONID = ""
    this.ACTIONDESC = ""
  Endif

Return

# --------------------------------------------------
# ACTIONER property propagate actions ...
$PROPAGATE_ACTIONER

  Local Integer DUMMY_RTV

  Gosub POPULATE_ACTIONERNAME

  # Enable / disable other properties ...
  DUMMY_RTV = fmet this.APARENT.SET_ATTRIBUTES()

Return

# --------------------------------------------------
# LINESTATUS property propagate actions ...
$PROPAGATE_LINESTATUS

  Local Integer DUMMY_RTV

  # Enable / disable IMPLEMENT properties ...
  DUMMY_RTV = fmet this.APARENT.SET_ATTRIBUTES_IMPLEMENT()

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

