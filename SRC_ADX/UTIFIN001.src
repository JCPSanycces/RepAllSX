#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIFIN001   UTI process called by UTI2018R08                                   Module CPT  #
##########################################################################

# Issue X3-113104 - 2018-10-30 by CBO : Error in UTIBASE when X3 folder
# Issue X3-113885 - 2018-10-23 by CBO : manage n folders
Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("BTC -> ABA Accounting recurring task migration.") From LECFIC
  Call MAJ_UTIFIN001(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTIFIN001(DOSSIER)
Value Char DOSSIER()

  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTIFIN001 : Not performed on archive folder : " + DOSSIER, 0) From GESECRAN
    End
  Endif

  Call ECR_TRACE("UTIFIN001 : Accounting recurring task migration. BTC/ABA", 0) From GESECRAN
  Call ECR_TRACE("UTIFIN001 : Start of process on : " + DOSSIER, 0) From GESECRAN

# Issue X3-113885
  Call MAJ_UTIFIN001(DOSSIER, [V]CST_AYES, [V]CST_ANO) From UTIFIN001GEN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI()

# Issue X3-113104
#If APPLI = GDOSX3
#  End
#Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI) = 0
  End
Endif

If [F:ADS]MODULE(1) <> 2  # module compta
  End
Endif

Call MAJ_UTIFIN001(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI()

# Issue X3-113104
#If APPLI = GDOSX3
#  End
#Endif

If [F:ADS]MODULE(1) <> 2
  End
Endif                                 : # module compta

Call MAJ_UTIFIN001(APPLI)
End

