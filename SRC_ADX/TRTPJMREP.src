#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
####################################################################################################
# Traitement lié à l'action PJMREPEAT
####################################################################################################
####################################################################################################
$ACTION
  Case ACTION
    When "INIT"          : Gosub INIT
    When "DEBUT"         : Gosub DEBUT
    When "BOUTON"        : Gosub BOUTON
    When "EXEC"          : Gosub EXEC
    When "TERMINE"       : Gosub TERMINE
  Endcase
Return

####################################################################################################
$INIT
  Case GACTION
    When "PJMREPEAT"     : Gosub INIT_PJMREPEAT
  Endcase
Return

####################################################################################################
$DEBUT
  Case GACTION
    When "PJMREPEAT"     : Gosub DEBUT_PJMREPEAT
  Endcase
Return

####################################################################################################
$BOUTON
  Case GACTION
    When "PJMREPEAT"     : Gosub BOUTON_PJMREPEAT
  Endcase
Return

####################################################################################################
$EXEC
  Case GACTION
    When "PJMREPEAT"     : Gosub EXEC_PJMREPEAT
  Endcase
Return

####################################################################################################
$TERMINE
  Case GACTION
    When "PJMREPEAT"     : Gosub TERMINE_PJMREPEAT
  Endcase
Return

####################################################################################################
########################### ACTION PJMREPEAT #######################################################
####################################################################################################
####################################################################################################
$INIT_PJMREPEAT
  If GIMPORT Then
    # En import on ressort
    FIN = 1
  Endif
  # --------------------------
Return

####################################################################################################
$DEBUT_PJMREPEAT
  [M:CHX]TEXTE = PARAM(1)
  Affzo [M:CHX]TEXTE
Return

####################################################################################################
$BOUTON_PJMREPEAT
Local Char PJTACTION(GLONDCO)

  PARAM(2) = BOUT    #OK
  FIN = 1
Return

####################################################################################################
$EXEC_PJMREPEAT
Return

####################################################################################################
$TERMINE_PJMREPEAT
Return

####################################################################################################
####################################################################################################
Funprog ASK_QUESTION_MESSAGE(IDEFAULT, SMESSAGE)
Value Integer IDEFAULT
Value Char SMESSAGE

Local Integer IARENDRE

  # Issue X3-34418 - 2017-05-02 by FGR
  If !GWEBSERV Then
    ## Action PJMREPEAT
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    Local Integer IRETBOUT
    Local Date VALEUR

    SAVACT = GACTION : GACTION = "PJMREPEAT"
    PARMSK(1) = SMESSAGE
    PARMSK(2) = num$(IDEFAULT)
    Call TRAITE_DAT(VALEUR,PARMSK,"","TRTPJMREP","DPJMREPEAT",4,"") From GTRAITE
    IARENDRE = val(PARMSK(2))
    GACTION = SAVACT
  Endif
End IARENDRE

####################################################################################################
Funprog ASK_THE_QUESTION(IDEFAULT)
Value Integer IDEFAULT

Local Integer IARENDRE

  IARENDRE = func ASK_QUESTION_MESSAGE(IDEFAULT, mess(350,2260,1))  # Issue X3-46557 - 2017-06-27 by FGR : func was missing
End IARENDRE

