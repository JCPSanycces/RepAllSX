#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNPCMP2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:53"
A_USER  = "DOC"
A_STAMP = "20181109230553"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBTYP"
  If [M]NBTYP=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMSNPCMP2 [PJSC2]
Gosub HORODAT
Local Inpbox "PJMSNPCMP2" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSC2] As [SIM_]
Grizo [PJSC2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJSC2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=20
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_NBTYP
Onevent BEFORE_AREA Call AV_NBTYP From W1PJMSNPCMP2
Return

Subprog AV_NBTYP
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBTYP" : Gosub TIT_COL From W4PJMSNPCMP2
Endif
Gosub _AFF
End

$ON_ICO
Onevent INIT_AREA Call D_ICO(zc) From W1PJMSNPCMP2
Return

Subprog D_ICO(VALEUR)
Variable Char    VALEUR()
If varinit([M]ICO,indice)=0
 VALEUR = "Folder.GIF"
Endif
Gosub _AFF
End

$ON_EXPFLG
Onevent INIT_AREA Call D_EXPFLG(zc) From W1PJMSNPCMP2
Return

Subprog D_EXPFLG(VALEUR)
Variable Decimal VALEUR
If varinit([M]EXPFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Gosub CHG_STY From W4PJMSNPCMP2
Return

$TIT_COL
Gosub TIT_COL From W4PJMSNPCMP2
Return


