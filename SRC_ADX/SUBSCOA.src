Gosub VERIF
If OK=0 Return Else OK=1 : Endif
# Ouverture fichier trace pour alertes budget si nécessaire
# et pour inter-sites
Gosub OUVERTURE_TRACE
Return

########################################################################
$AVANT_MODFIC
#----------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:SCO]  #
#----------------------------------------------------------------#

# on a viré le texte
If [M:SCO1]SCOTEX="" & [F:SCO]SCOTEX <> "" & left$([F:SCO]SCOTEX,3) = "SCO"
   Call SUP_CLOB([F:SCO]SCOTEX,WRET) From TRTX3TEX
Endif

# V6 Affectations
Gosub AVANT_MODFIC From SCOMTOLIB

Return

########################################################################
$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
Gosub CHARGENTETE
#
# tant qu'on n'utilise pas INICRE_LIG et INIMOD_LIG (TABLEAUX sur SCO1)
Gosub CHARGLIGNE
#
[F:SCO]UPDDAT  = date$        # FQ 51325 déplacé car écrasé par CHARGENTETE
[F:SCO]UPDUSR  = GUSER
#
Return

########################################################################
$MODIF
# pour déclencher VALLIG
#Gosub MODIF From TABLEAUX

#----------------------------#
# Modification article lancé #
#----------------------------#
Gosub MODIF From SUBSCO1
If GOK<1 : Return : Endif

#--------------------------#
# Mise à jour Matières     #
#--------------------------#
Gosub MODIF From SUBSCO2
If GOK<1 : Return : Endif

#--------------------------#
# Mise à jour Opérations   #
#--------------------------#
Gosub MODIF From SUBSCO3
If GOK<1 : Return : Endif

Return

########################################################################
$APRES_MOD
#--------------------------------------------------------------------------#
# Après modification : affichage indicateurs entête et rechargement lignes #
#--------------------------------------------------------------------------#
  Local Integer WRET : WRET=0
  Call UPD_SCOTRKFLG([F:SCO]SCONUM,WRET) From SCOLIB

  If [F:SCO]SCOSTA = 1 | GMEMSTA = 2 : Gosub MAJ_MTO_AP_ALL From SCOMTOLIB : Endif

#--------------------------------------------------#
# v 150 Calcul automatique des coûts prévisionnels # (CPT et CPL)
#--------------------------------------------------#
  If GCLCEOCAUT = 3 & [F:SCO]SCOSTA = 1
    # appel direct possible car la boite de dlg ne s'ouvre pas
    # charger les paramètres.   # FQ 47987 avant PARAM, VALEUR
    Local Char PARAM_CLC(50)(1..14) , VAL_CLC(10)
# Issue 87011 - 2013-01-04 by CCC
#    PARAM_CLC(1) = [M:SCO0]POHFCY
    PARAM_CLC(1) = [M:SCO1]PRHFCY
    PARAM_CLC(2) = [M:SCO0]SCONUM
    PARAM_CLC(4) = "1"
    PARAM_CLC(5) = "4"
    PARAM_CLC(13) = "2"   # Issue 89622 - 2013-06-05 by CCC
    Case [F:PTR]MCCIMPMOD
         When 0, 1  : PARAM_CLC(12) = "2"
                      PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
         When 2     : PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
         When 3     : PARAM_CLC(12) = "2"
    Endcase
    PARAM_CLC(14) = "36"   : # VCRTYP 36 pour EO
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
  Endif

  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS From SUBSCOA
  Endif


Return


########################################################################
$AB_MODIF
#-----------------------------------------------#
# Abandon de la modification suite à une erreur #
#-----------------------------------------------#
Return

########################################################################
$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
GOK=SAVGOK                          : # Restitution de GOK
Return

########################################################################
$VERF_ANU
#-------------------------------------------------#
# Contrôles de suppression :                      #
#-------------------------------------------------#
# CCC (2009-10-28) Bug 57995 : Si des en-cours ont été comptabilisés, on ne permet pas la suppression
If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif
Filter [MWI] Where VCRTYP=36 & VCRNUM=[M:SCO0]SCONUM and GLPSTA=2
Look [F:MWI] First
Filter [MWI]
If !fstat
    Call MESSAGE(mess(759,197,1)) From GESECRAN
    OK=0
    Return
Endif

# Issue 76130 GA 03/2012
If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
Filter [SDD] Where VCRTYPORI=36 & VCRNUMORI=[M:SCO0]SCONUM
Look [F:SDD] First
Filter [SDD]
If !fstat
    Call MESSAGE(mess(792,197,1)-[F:SDD]SDHNUM) From GESECRAN
    OK=0
    Return
Endif

# V6 Affectations
Gosub VERF_ANU From SCOMTOLIB

Return

########################################################################
$AV_ANNULE
# annulation affectations
Gosub SUP_MTO_AV_ALL From SCOMTOLIB
Return

########################################################################
$ANNULE
#------------------------------------------------------------------- #
# Annulation  ordre de sous-traitance SCO Annulation des lignes SCS  #
#------------------------------------------------------------------- #
Gosub ANNULE From SUBSCO3
If GOK<1 : Return : Endif

#------------------------------------------------------------------ #
# Annulation ordre de sous-traitance SCO Annulation des lignes SCM  #
#------------------------------------------------------------------ #
Gosub ANNULE From SUBSCO2
If GOK<1 : Return : Endif

#------------------------------------------------------------------ #
# Annulation ordre de sous-traitance SCO Annulation des lignes SCI  #
#------------------------------------------------------------------ #
Gosub ANNULE From SUBSCO1
If GOK<1 : Return : Endif

#------------------------------------------------------------------ #
# Annulation des données <Calcul des coûts> liées à cet EO          #
#------------------------------------------------------------------ #
Gosub ANNULE_EO From SUBMCCA

Return

########################################################################
$FERME

# Tiroir sur les commandes d'achat
If dim(GBOXPO3)>0      Kill GBOXPO3      : Endif
If dim(GSCO_PICK)>0    Kill GSCO_PICK    : Endif

If dim(GMEMSTA)>0      Kill GMEMSTA   : Endif
If dim(GMODMAT)>0      Kill GMODMAT   : Endif
If dim(GWIPTYP)>0      Kill GWIPTYP   : Endif
If dim(GWIPNUM)>0      Kill GWIPNUM   : Endif
If dim(GITMREF)>0      Kill GITMREF   : Endif
If dim(GFLTTBO)>0      Kill GFLTTBO   : Endif

#--------------------------------------------------------------------#
#- toujours restaurer les variables globales GA selon MBT 09/2007   -#
#--------------------------------------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

If GFONC1="GESSCO"
  Raz GORITITCOL
Endif
# FQ 56026
Gosub FERMETURE_TRACE : # Fermeture fichier trace si nécessaire

# GH 26/11/2014 bug 103230 pour rafraichir la cde client d'où on vient en amont
If GFONC1 = "GESSOH" : mkstat=GSTALIT : Endif
Return

########################################################################
$VERIF
#---------------------------------------------------------------#
# Vérifications : Au moins une ligne,  Sections obligatoires    #
#---------------------------------------------------------------#
If [M:SCO0]CPY = ""
   [M:SCO0]CPY = GSOCIETE
Endif
If [M:SCO0]BPRNUM = ""
   GMESSAGE = mess(00057,00194,1) : # Aucun fournisseur sélectionné
   zonsui="[M:SCO0]BPRNUM"
   GERR=1 : mkstat=1
Endif
If [M:SCO0]ITMREF = ""
   GMESSAGE = mess(00152,00190,1) : # Saisie d'un article obligatoire
   zonsui="[M:SCO0]ITMREF"
   GERR=1 : mkstat=1
Endif
If [M:SCO0]BOMALT = 0               # Issue 90090 GA 05/2013
   GMESSAGE = mess(00015,00187,1) : # Alternative de nomenclature non autorisée pour ce traitement
   zonsui="[M:SCO0]BOMALT"
   GERR=1 : mkstat=1
Endif
If !GIMPORT
  #----- Relecture transaction de saisie si nécessaire -----#
  If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>GSCOPTRNUM
     Read [PTR] PTR0=9;GSCOPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
Endif
# Issue 113031 - 2016-02-23 by SR : sortir si problème/Positionner GOK à 1 avant l'appel
If GERR = 1  | mkstat  = 1 : Return : Endif
GOK = 1
# Issue 85534 suite GA 11/2012 OK=0 pour empêcher la validation
Gosub VERIF From SUBSCO1
If GOK<1 | GERR=1 : OK=0 : mkstat=1 : Return : Endif
Gosub VERIF From SUBSCO2
If GOK<1 | GERR=1 : OK=0 : mkstat=1 : Return : Endif
Gosub VERIF From SUBSCO3
If GOK<1 | GERR=1 : OK=0 : mkstat=1 : Return : Endif

Return

########################################################################
$CHARGENTETE
#------------------------------------------------------#
# Chargement entête avant le Write ou le Rewrite       #
#------------------------------------------------------#
# pour INICRE et INIMOD
If GFCY<>[M:SCO0]POHFCY | GSOCIETE=""
   GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
Endif
# FQ 74682 GA 07/2011 déjà ok, sinon pb de valorisation
#If [F:BPR]BPRNUM=[M:SCO0]BPRNUM
#   GCUR           = [F:BPR]CUR
#   [M:SCO1]CUR    = [F:BPR]CUR
#   [M:SCO1]LAN    = [F:BPR]LAN
#Else
#   GCUR           = GLOCALDEV
#   [M:SCO1]CUR    = GLOCALDEV
#   [M:SCO1]LAN    = GLANGUE
#Endif

[F:SCO] = [M:SCO0]
[F:SCO] = [M:SCO1]
[F:SCO]CPY=GSOCIETE
[F:SCO]SCONUM=[M:SCO0]SCONUM
Return

$CHARGLIGNE
#-----------------------------------------------#
# Chargement ligne avant le Write ou le Rewrite #
#-----------------------------------------------#
# pour INICRE_LIG et INIMOD_LIG si on utilise TABLEAUX
# appel dans INICRE et INIMOD pour le moment ...
[F:SCI]CPY=GSOCIETE
[F:SCI]SCONUM=[M:SCO0]SCONUM
[F:SCI] = [M:SCO0]
[F:SCI] = [M:SCO1]
Return

$CHARG_PARAM
# Issue 99884 GA 07/2014 [F:PTR]PRTNUM lost after purchase order access
# on perd [F:PTR]PTRNUM après action SAIMODPOX
#If [F:PTR]PTRNUM="" & GFLAG<>"" Gosub DEFTRANS Endif
If ([F:PTR]PTRNUM="" | [F:PTR]PTRTYP<>9) & GFLAG<>"" Gosub DEFTRANS Endif

#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#            GFINRSP    : Site financier                               #
#            GRCPFCY    : Site réception par défaut                    #
# Récupération des paramètres ACHATS                                   #
# Récupération des paramètres BUDGET                                   #
#            GBUDCTLPOH : Contrôle en gestion commande (1=Non 2=Oui)   #
#            GBUDCTLPOL : Contrôle indicatif ligne cde (1=Non 2=Oui)   #
#            GPURCMM    : Mise à jour des engagements  (1=Non 2=Oui)   #
#            GPURCMMDAT : Date engagement (1=Date cde  2=Date Récept)  #
#            GCNTBUD    : type de contrôle engagements                 #
#                         (1=Aucun 2=Bloquant 3=Non bloquant)          #
# Contrôle existence paramétrage des règles de signature pour GSOCIETE #
#----------------------------------------------------------------------#
Local  Char     PARAM2(10)
#----- Chargement des globales référentiels, comptes et sections de la société -----#
# GA 02/2008 pour la V6
If GMODU(2)=2 : # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT
Endif
If GFINRSP=""  GFINRSP=GFCY : Endif
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH

# Issue 79923 - GA 02/2012 déplacé depuis $OUVRE sinon on perd l'info
If dim([F:PTR]MODALL)>0
  [M:SCO0]MODALL=[F:PTR]MODALL
Else
  [M:SCO0]MODALL=3 : # Allocation automatique des matières (détaillée)
Endif

Raz GMESSAGE
Return



#==================================================
# TRAITE_PWO: mettre à jour encours listés dans PWO
#==================================================
$TRAITE_PWO
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
  Filter [PWO] Where PRONUM = adxuid(1) & CODFNC="SCO"
  For [PWO]
  # Consommer les encours listés dans PWO
    Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
    If !fstat
       If [F:ORD]WIPTYP=13 & [F:ORD]WIPSTA=3 & [F:PWO]QTYSTU>= [F:ORD]RMNEXTQTY
       # Supression des EOS consommés entièrement
         Delete [ORD] Curr
      Else
       # Maj des EOS ou SOF consommés
         Readlock [ORD] Curr
         If !fstat
            [F:ORD]RMNEXTQTY -= [F:PWO]QTYSTU
            If [F:ORD]RMNEXTQTY <0 : [F:ORD]RMNEXTQTY=0 : Endif
            Rewrite [F:ORD]
         Endif
      Endif
    Endif
  Next
  Filter [PWO]
Commit
Call TEMPOFF From GESECRAN
Return



#==================================================
# DELETE_PWO: supprimer dans PWO les encours listés
#==================================================
$DELETE_PWO
Call TEMPON ("O") From GESECRAN
## GH 19/03/2013 bug 88677 pour ne pas remettre GOK=1 en cas de AB_CREATION
# Call DEBTRANS From GLOCK
Trbegin [PWO]
 Delete [PWO] Where PRONUM = adxuid(1) & CODFNC="SCO"
Commit
Call TEMPOFF From GESECRAN
Return



#CHECK UNUSED_BEGIN
$SUPPRESS_TEX
#-----------------------------------------#
# Suppression des textes après un abandon #
#-----------------------------------------#
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:SCO1]TEX,3)="SCI"
    Call SUP_CLOB([M:SCO1]TEX,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes lignes PORDSCM -----#
For I=0 To [M:SCO2]NBLIG-1
  If left$([M:SCO2]SCMTEX(I),3)="SCM" & [M:SCO2]CREFLG(I)=0
    Call SUP_CLOB([M:SCO2]SCMTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
#----- Suppression des textes lignes PORDSCS -----#
### une seule opération de sous-traitance ...
###For I=0 To [M:SCO3]NBLIG-1
###  If left$([M:SCO3]SCSTEX(I),3)="SCS" & [M:SCO3]CREFLG(I)=0
###    Call SUP_CLOB([M:SCO3]SCSTEX(I),GBIDI1) From TRTX3TEX
###  Endif
###Next I
   Call SUP_CLOB([M:SCO3]SCSTEX,GBIDI1) From TRTX3TEX
#-----
Call RAZ_CLOB From ACLOB
Return
#CHECK UNUSED_END

$OUVERTURE_TRACE
#---------------------------------------#
# Ouverture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE=0 & !GIMPORT
  # FQ 56026 pas de trace en création directe
  # Call OUVRE_TRACE(mess(641,197,1)) From LECFIC : GPURTRACE=1
Endif
Return

$LECTURE_TRACE
#-----------------------------------------------------------#
# Lecture du fichier trace des alertes budget si nécessaire #
#-----------------------------------------------------------#
If GPURTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  GPURTRACE=0
Endif
Return

$LECT_EFFAC_TRACE
#----------------------------------------------------------#
# Lecture et effacement trace si abandon de la transaction #
#----------------------------------------------------------#
If GPURTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call SUPP_TRACE  From LECFIC
  GPURTRACE=0
Endif
Return

$FERMETURE_TRACE
#---------------------------------------#
# Fermeture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE<>0 & !GIMPORT
  Call FERME_TRACE From LECFIC : GPURTRACE=0
Endif
Return


##################################################################
# Insertion des composants et du service
# dans les onglets SCO2 et SCO3
# si on est en création d'un ordre de sous-traitance
##################################################################
Subprog CHARGE_BOMALT(LITMREF,LBPRNUM,LBOMALT,OK)
Value Char    LITMREF
Value Char    LBPRNUM   # FQ 74682 GA 07/2011
Value Integer LBOMALT
Variable Integer OK
Local Integer I
#
#----- Lecture BPARTNER   nécessaire pour chargement CUR, LAN      -----#
#----- Lecture BPSUPPLIER nécessaire pour chargement PLISTC tarifs -----#
WBPRNUM = LBPRNUM
Gosub READ_BPR From BPRLIB
Gosub READ_BPS From BPRLIB

# Issue 97606 GA 04/2014 table should have been closed if tunnel used before creating
If !clalev([F:BOH])   Local File BOM          [BOH] : Endif
If !clalev([F:BOD])   Local File BOMD         [BOD] : Endif

Default Mask [SCO1]
Gosub RAZCRE From SUBSCO1

# Issue 116684 - 2016-05-23 by MUARN : init devise/langue
[M:SCO1]CUR    = [F:BPS]CUR
[M:SCO1]LAN    = [F:BPR]LAN

#
# Issue 86439 GA 12/2012 revérifier validité alternative de nomenclature
If [F:TBO]BOMALT<>LBOMALT
   Read [TBO]TBO0=3;LBOMALT
   If fstat Raz [F:TBO] Endif
Endif
If [F:TBO]FCY<>"" & [F:TBO]FCY<>[M:SCO1]PRHFCY
   [M:SCO1]PRHFCY=[F:TBO]FCY : Affzo [M:SCO1]PRHFCY
Endif
# Issue 86439  avant [M:SCO0]BPRNUM
Call FIND_PRHFCY ([M:SCO0]POHFCY,LBPRNUM,[M:SCO1]BPAADD,[M:SCO1]MFGFCY,[M:SCO1]PRHFCY,[M:SCO1]PRHADD,[M:SCO1]LOC) From SCOLIB
Affzo [M:SCO1]BPAADD : Affzo [M:SCO1]MFGFCY : Affzo [M:SCO1]PRHFCY : Affzo [M:SCO1]PRHADD : Affzo [M:SCO1]LOC
#
If [F:FCY]FCY<>[M:SCO1]PRHFCY
   Read [FCY]FCY0=[M:SCO1]PRHFCY
   If fstat Raz [F:FCY] Endif
Endif

# Issue 86439 GA 12/2012 code déplacé depuis C_BPRNUM
#----- Contrôle et chargement des zones inter-sites -----#
Call CTRL_INTERSITE ([M:SCO0]POHFCY,[M:SCO0]BPRNUM) From SUBSCOA
If mkstat
  Local Char WMESS(80) : WMESS=GMESSAGE
  GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
  GMESSAGE=WMESS
  GERR=1 : mkstat=1 : End
Endif
# Récup Adresse Client livré et Emplacement de sous-traitance
If [M:SCO1]BPAADD="" & [M:SCO0]BPRNUM<>"" & [M:SCO1]PRHFCY=""
   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
   If [M:SCO1]BPAADD<>""
      Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
   Endif
   Affzo [M:SCO1]BPAADD
Endif
If [M:SCO1]BPAADD="" & [M:SCO1]MFGFCY<>""
   Call FIND_FCYADD([M:SCO1]MFGFCY,[M:SCO1]BPAADD) From BPRLIB
Endif
If [M:SCO1]PRHADD="" & [M:SCO1]PRHFCY<>""
   Call FIND_FCYADD([M:SCO1]PRHFCY,[M:SCO1]PRHADD) From BPRLIB
Endif
# FIN - Issue 86439 GA 12/2012 code déplacé depuis C_BPRNUM

# FQ 74682 GA 07/2011 + LBPRNUM
Call CHARGE_SCO1_FROM_BOH ( LITMREF, LBPRNUM, LBOMALT,OK )
If OK<>2 : End : Endif
Affzo [SCO1]1-99  # Issue 91501 GA 08/2013 ajout 1-99 pour ne pas déclencher l'init trop tôt

# Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
# Check validity date of the link
Local Integer WBOMDATCTL : WBOMDATCTL=2
Local Date    WBOMDAT
#If [M:SCO1]ORDDAT<>[0/0/0] WBOMDAT=[M:SCO1]ORDDAT Else WBOMDAT=date$ Endif
Gosub PE_BOMDATCTL From SCOAUTLIB
Case WBOMDATCTL
  When 1       : WBOMDAT=[M:SCO1]RETDAT
  When Default : WBOMDAT=[M:SCO1]ORDDAT  # standard mode
Endcase
If WBOMDAT=[0/0/0] WBOMDAT=date$ Endif
# Issue 86701 GA 12/2012 pb chargement des composant si [M:SCO1]ORDDAT non renseignée
#Local Date WDATE
#If [M:SCO1]ORDDAT<>[0/0/0] WDATE=[M:SCO1]ORDDAT Else WDATE=date$ Endif
Default Mask [SCO2]
I=0
For [BOD] Where ITMREF=LITMREF and BOMALT=LBOMALT and BOMALTTYP=3 and CPNTYP<6 &
&              (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WBOMDAT)) &
&              (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WBOMDAT))

##  # contrôle lot valide
##    If LLOT <> ""
##        If ([F:BOD]BOMSTRLOT <> "" & LLOT < [F:BOD]BOMSTRLOT)
##&        | ([F:BOD]BOMENDLOT <> "" & LLOT > [F:BOD]BOMENDLOT)
##        Goto NEXT_BOD
##        Endif
##    Endif
     OK=2

     Raz mkstat
     nolign=I+1
     Gosub RAZCRE From SUBSCO2
     # FQ 74682 GA 07/2011 + LBPRNUM
     Call CHARGE_SCO2_FROM_BOD ( LITMREF,LBPRNUM,LBOMALT,[F:BOD]CPNITMREF, I)
     #If GOK<>1  : OK=1 : Break : Endif   # FQ 74423 GA 06/2011
     I+=1

$NEXT_BOD
Next
If OK=1 : End : Endif   # FQ 74423 GA 06/2011

[M:SCO2]NBLIG=I
Affzo [SCO2]1-99  # Issue 91501 GA 08/2013 ajout 1-99 pour ne pas déclencher l'init trop tôt
#
Default Mask [SCO3]
I=0
# Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
# Check validity date of the link
Local Integer WBOMDATCTL : WBOMDATCTL=2
Local Date    WBOMDAT
#If [M:SCO1]ORDDAT<>[0/0/0] WBOMDAT=[M:SCO1]ORDDAT Else WBOMDAT=date$ Endif
Gosub PE_BOMDATCTL From SCOAUTLIB
Case WBOMDATCTL
  When 1       : WBOMDAT=[M:SCO1]RETDAT
  When Default : WBOMDAT=[M:SCO1]ORDDAT  # standard mode
Endcase
If WBOMDAT=[0/0/0] WBOMDAT=date$ Endif
# Issue 86701 GA 12/2012 pb chargement des composant si [M:SCO1]ORDDAT non renseignée
#Local Date WDATE
#If [M:SCO1]ORDDAT<>[0/0/0] WDATE=[M:SCO1]ORDDAT Else WDATE=date$ Endif
For [BOD] Where ITMREF=LITMREF and BOMALT=LBOMALT and BOMALTTYP=3 and CPNTYP=7     &
&              (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WBOMDAT)) &
&              (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WBOMDAT))
     #nolign=I+1
     Gosub RAZCRE From SUBSCO3
     # FQ 74682 GA 07/2011 + LBPRNUM
     Call CHARGE_SCO3_FROM_BOS ( LITMREF,LBPRNUM,LBOMALT,[F:BOD]CPNITMREF, I)
     #If GOK<>1  : OK=1 : Break : Endif   # FQ 74423 GA 06/2011
     Break
Next
If [M:SCO3]SRVITMREF=""
   # Issue 100626 GA 06/2014 return previous error
   # "Aucun service valide au niveau de la nomenclature de sous-traitance !"
   GMESSAGE=mess(378,194,1)-GMESSAGE : OK=1
Endif
If OK=1 : End : Endif   # FQ 74423 GA 06/2011
### [M:SCO3]NBLIG=I
Affzo [SCO3]1-99  # Issue 91501 GA 08/2013 ajout 1-99 pour ne pas déclencher l'init trop tôt
#
# FQ 77115 GA 12/2011
#Local Decimal WLTI,WQUALTI
#Call CALCUL_DELAI([M:SCO1]EXTQTY,WLTI,WQUALTI) From SCOLIB
#If WLTI+WQUALTI > [M:SCO1]LTI  : # GA 06/2008 si délai fournisseur déjà indiqué, ne pas l'écraser
#   [M:SCO1]LTI = WLTI+WQUALTI : Affzo [M:SCO1]LTI
#Endif
If [M:SCO3]SCOLTI>0
   [M:SCO1]LTI=[M:SCO3]SCOLTI
Else
   # Issue 80129 & 77115 Piloté par délai du Service
   #Local Integer WLTI : WLTI=[M:SCO1]LTI
   #Call FIND_LTI (LITMREF,LBPRNUM,[M:SCO0]POHFCY,WLTI) From SCOLIB
   #[M:SCO1]LTI=WLTI
   Call FIND_SCI_LTI(LITMREF,LBPRNUM,[M:SCO0]POHFCY,LBOMALT,[M:SCO3]SRVITMREF,[M:SCO1]LTI) From SCOLIB
Endif
#
# Calcul date besoin
Local Integer ILTI : ILTI=[M:SCO1]LTI
Call UPD_ITM_DAT(ILTI,[M:SCO0]POHFCY,[M:SCO1]ORDDAT, [M:SCO1]RETDAT) From SCOLIB
#
Call CTRECCCPN(-1) From SCOECCLIB      # Control each line of component and highlight them if necessary

Default Mask [SCO1]
End

##################################################################
Subprog CHARGE_SCO1_FROM_BOH(LITMREF,LBPRNUM,LBOMALT,OK)
Value Char    LITMREF
Value Char    LBPRNUM   # FQ 74682 GA 07/2011
Value Integer LBOMALT
Variable Integer OK

# Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
Local Char    WFCY(GLONFCY)

# -------
# Site
# -------
#If [M:SCO1]PRHFCY=""
#   [M:SCO1]PRHFCY = [M:SCO0]POHFCY
#Endif

If LITMREF <> [F:BOH]ITMREF | LBOMALT <> [F:BOH]BOMALT | [F:BOH]BOMALTTYP <> 3
  Read [BOH]BOH0=LITMREF;LBOMALT;3
  If fstat : Gosub RAZ_SCO1_ITMREF : Endif
Endif

GOK=1
# contrôle article
Local Char WITMREF(GLONITM) : WITMREF=LITMREF
Gosub READ_ITM From ITMLIB
If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : End : Endif

If [F:FCY]WRHFLG=2
  # contrôle article/site
  Local Char WFCY   (GLONFCY) : WFCY=[M:SCO1]PRHFCY
  Gosub READ_ITF From ITMLIB
  #If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : End : Endif  # Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
  If GOK<>1 : GOK=1 : Raz GMESSAGE : Endif
Endif

# FQ 74168 GA 06/2011 pour chargement de l'UA - FQ 74682 avant [M:SCO0]BPRNUM ko en création
# contrôle article/fournisseur
Local Char WBPRNUM(GLONBPR) : WBPRNUM=LBPRNUM
# Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
#Gosub READ_ITP From ITMLIB
##If GOK=-1 : OK=1 : GMESSAGE=mess(23,198,1)-WITMREF-WBPRNUM : Endif
If [M:SCO1]PRHFCY <> ""
  WFCY = [M:SCO1]PRHFCY
Else
  WFCY = [M:SCO0]POHFCY
Endif
Call FIND_ITMBPSFCY_ITMBPS(WITMREF,WBPRNUM,WFCY,WITMBPS) From TRTACHDEF1
# End issue X3-55891

If [F:BOH]USESTA=1
# Cette nomenclature est en cours d'élaboration (exploitation non autorisée) !
   GMESSAGE=mess(51,193,1) : OK=1
   Gosub RAZ_SCO1_ITMREF
Endif

# GA 18/09/2008 le transclasse ne fonctionne pas correctement à cause des CCE
#[M:SCO1] = [F:ITM]
Gosub CHARGE_SCO1_FROM_ITM

[M:SCO1] = [F:BOH] : # Renseigne [M:SCO1]BASQTY, [M:SCO1]QTYCOD

# Issue 88337 GA 03/2013
Call UPD_ITM_UOM(0) From SCOLIB

# Unité de commande: ctrl et recalcul du coef [M:SCO1]PUUSTUCOE
Call C_PUU([M:SCO1]PUU)  From SUBSCO1

If [M:SCO1]QTYPUU<>0
   Call AM_QTYPUU([M:SCO1]QTYPUU) From SUBSCO1
Endif

If [M:SCO1]LTI=0
# lecture du délai de sous-traitance
   # Issue 80129 & 77115 Piloté par délai du Service
   # FQ 74682 avant [M:SCO0]ITMREF,[M:SCO0]BPRNUM ko en création (appel AM_BPRNUM)
   #Local Integer WLTI : WLTI=[M:SCO1]LTI
   #Call FIND_LTI (LITMREF,LBPRNUM,[M:SCO0]POHFCY,WLTI) From SCOLIB
   #[M:SCO1]LTI=WLTI
   Call FIND_SCI_LTI(LITMREF,LBPRNUM,[M:SCO0]POHFCY,LBOMALT,[M:SCO3]SRVITMREF,[M:SCO1]LTI) From SCOLIB
Endif

# FQ 69614 GA 12/2010 pour chargement des composants/service avec dates de validité
If [M:SCO1]ORDDAT = [0/0/0] [M:SCO1]ORDDAT=date$ Endif

# FQ 77488 GA 10/2011 le taux de conversion dépend de [M:SCO3]OPESTR
#### FQ 74682 GA 07/2011 à cause du Raz [M:SCO1] en (re)chargement de la nomenclature
###If dim([M:SCO1]CHGTYP)>0
###   Local Shortint  WCHGTYP : WCHGTYP=[M:SCO1]CHGTYP
###   Call FIND_CUR(LBPRNUM,[M:SCO1]ORDDAT,[M:SCO1]CUR,WCHGTYP,[M:SCO1]CHGCOE) From SCOLIB
###   [M:SCO1]CHGTYP=WCHGTYP
###Endif

End
$RAZ_SCO1_ITMREF
Raz [F:ITM]
Raz [F:BOH]
Default Mask [SCO1]
End
##################################################################
$CHARGE_SCO1_FROM_ITM
[M:SCO1] = [F:ITM]
If dim([M:SCO1]CCE)>0  # Issue 107611 GA 04/2015
   Raz [M:SCO1]CCE
Endif
# FQ 57892 GA 09/2009 ceci pose pb sur l'affichage des sections
#Local Shortint K
#If GNBDIE>0
#  For K=1 To GNBDIE
#    If [M:SCO1]CCE(K-1)=""
#      Call INIT_CCE([M:SCO1]CCE(K-1),K,"SCI","",0) From TRTX3CPT
#    Endif
#  Next J # ?????
#Endif
Call CHARG_SCI_CPTANALIN(-1) From SCOCPTLIB

Return

##################################################################
Subprog CHARGE_SCO2_FROM_BOD(LITMREF,LBPRNUM,LBOMALT,LCPNITMREF,LMAT)
Value    Char    LITMREF
Value    Char    LBPRNUM   # FQ 74682 GA 07/2011
Value    Integer LBOMALT
Value    Char    LCPNITMREF
Value    Integer LMAT
#
# ------------------------
# 1) Chargement de [F:ITM]
# ------------------------
Local Char WITMREF(GLONITM): WITMREF=LCPNITMREF
Gosub READ_ITM From ITMLIB
#If fstat : Gosub RAZ_SCO2_CPNITMREF : Endif

nolign = LMAT+1
# FQ 76637 GA 11/2011 selon FQ 57892
#[M:SCO2] = [F:ITM]                  # Chargement STU en particulier

# Issue 83440 GA 11/2012 raz de la modif 79808
# [F:ITM] pointe sur le composant, on doit donc ré-écraser [M:SCO2]ITMREF(LMAT)
# Issue 79808 - 2012-03-12 by CCC : déplacé après alim de ITMREF
Gosub CHARGE_SCO2_FROM_ITM
[M:SCO2]ITMREF(LMAT)=LITMREF        # Raz par le transclasse
[M:SCO2]CPNITMREF(LMAT)=LCPNITMREF
# Issue 79808 - 2012-03-12 by CCC
#Gosub CHARGE_SCO2_FROM_ITM

# Issue 81641 GA 08/2012 maj site/emplacement des composants
### If [M:SCO2]STOFCY(LMAT)=""
###    [M:SCO2]STOFCY(LMAT)=[M:SCO0]POHFCY
### Endif
GPE=0 : GPOINT = "UPDMATFCY" : Gosub ENTREE From EXEFNC
If !GPE & [M:SCO1]PRHFCY<>""  # Issue 85534 selon [M:SCO1]PRHFCY
   If [F:FCY]WRHFLG=2 # Issue 83440 GA 11/2012 maj ssi site de stockage
     #Call UPD_MAT_FCY([M:SCO1]PRHFCY,LMAT) From SCOLIB
     [M:SCO2]STOFCY(LMAT)=[M:SCO1]PRHFCY
     [M:SCO2]LOC(LMAT)=[M:SCO1]LOC
   Endif
Endif

# ------------------------
# 2) Chargement de [F:BOD]
# ------------------------
If LCPNITMREF <> [F:BOD]CPNITMREF
  # Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
  # Check validity date of the link
  Local Integer WBOMDATCTL : WBOMDATCTL=2
  Local Date    WBOMDAT
  #If [M:SCO1]ORDDAT<>[0/0/0] WBOMDAT=[M:SCO1]ORDDAT Else WBOMDAT=date$ Endif
  Gosub PE_BOMDATCTL From SCOAUTLIB
  Case WBOMDATCTL
    When 1       : WBOMDAT=[M:SCO1]RETDAT
    When Default : WBOMDAT=[M:SCO1]ORDDAT  # standard mode
  Endcase
  If WBOMDAT=[0/0/0] WBOMDAT=date$ Endif

  # Issue 86701 GA 12/2012 pb chargement des composant si [M:SCO1]ORDDAT non renseignée
  #Local Date WDATE
  #If [M:SCO1]ORDDAT<>[0/0/0] WDATE=[M:SCO1]ORDDAT Else WDATE=date$ Endif
  Filter [BOD] Where ITMREF=LITMREF
&                and BOMALT=LBOMALT       and BOMALTTYP=3
&                and CPNITMREF=LCPNITMREF and CPNTYP<6
&                and (BOMENDDAT = [0/0/0] | BOMENDDAT >= WBOMDAT )
&                and (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= WBOMDAT )
  Read   [BOD] First
  If fstat : Raz [F:BOD] : Endif
  Filter [BOD]
# pas d'erreur si non trouvé
# If fstat : Gosub RAZ_SCO2_CPNITMREF : Endif
Endif
If [F:BOD]CPNITMREF = LCPNITMREF
   #nolign = NOL
   [M:SCO2] = [F:BOD]
#
   If [F:BOD]BOMOFS<>0  # FQ 77115 GA 12/2011 avant >0 uniquement
      [M:SCO2]BOMOFS(LMAT)= [F:BOD]BOMOFS
   ### FQ 77115 GA 12/2011 pas de délai si rien sur la nomenclature
   ###Else
   ###   Local Integer ILTI : ILTI=[M:SCO2]BOMOFS(LMAT)
   ###   Call FIND_LTI(LCPNITMREF,LBPRNUM,[M:SCO0]POHFCY,ILTI) From SCOLIB
   ###   [M:SCO2]BOMOFS(LMAT)=ILTI
   Endif
#
   # Issue 103531 - 2014-12-17 by JUSYN : Component/material text from Subcontract BOM. Immediate changings would be overwritten, so textnumber
   #                                      has to be checked as well.
   # If [F:BOD]BOMTEXNUM <> ""
   If [F:BOD]BOMTEXNUM <> "" & left$([M:SCO2]SCMTEX(LMAT),3)<>"SCM"
      [M:SCO2]SCMTEX(LMAT)  = [F:BOD]BOMTEXNUM
   Endif
   Call RECH_SCO2_CPNITMREF(LCPNITMREF,LITMREF,LBPRNUM) From SUBSCO2

   # Issue 83440 GA 11/2012 ctrl déplacés => VERIF de SUBSCO2
   ##Call AM_BOMOFS([M:SCO2]BOMOFS(LMAT)) From SUBSCO2
   ### Issue 82823 GA 06/2012 Matière interne
   ##Call CTRL_SCOFLG([M:SCO2]SCOFLG(LMAT),LMAT) From SUBSCO2

   # Issue 86439 GA 12/2012 changt BOMALT avec [M:SCO1]EXTQTY déjà rempli
   If [M:SCO1]EXTQTY<>0
      Call UPD_MAT_QTY([M:SCO1]EXTQTY, LMAT) From SCOLIB
      Call UPD_MAT_PRI(LMAT) From SCOLIB
   Endif
Endif
#
# FQ 74137 GA 06/2011 pb si nomenclature avec [F:BOH]BASQTY>1
# ------------------------
# 3) Chargement de [F:BOH]
# ------------------------
If [F:BOH]ITMREF<>LITMREF | [F:BOH]BOMALT<>LBOMALT
   Read [BOH]BOH0=LITMREF;LBOMALT;3
   If fstat Raz [F:BOH] Endif
Endif
# Issue 101293 GA 09/2014 If [F:BOH]BASQTY>1
If [F:BOH]BASQTY<>1
   [M:SCO2]BASQTY(LMAT)      = [F:BOH]BASQTY
   #[M:SCO2]QTYCOD(LMAT)      = [F:BOH]QTYCOD
Endif
End
$RAZ_SCO2_CPNITMREF
Raz [F:ITM]
Raz [F:BOD]
WOK = 0
Default Mask [SCO1]
End
##################################################################
$CHARGE_SCO2_FROM_ITM
# FQ 76637 GA 11/2011 selon FQ 57892
[M:SCO2] = [F:ITM]
If dim([M:SCO2]CCE)>0  # Issue 107611 GA 04/2015
  If dim(I)<1  Local Integer I : Endif
  If dim(WSECTION)<1 : Local Char WSECTION(GLONCCE) : Endif
  For I=1 To GNBDIE
  # Issue 79808 - 2012-03-12 by CCC
  #  Assign "[M:SCO2]CCE"+num$(I)+"(nolign-1)" With ""
      Call INIT_CCE(WSECTION,I,"SCM","",nolign-1) From TRTX3CPT
      Assign "[M:SCO2]CCE"+num$(I)+"(nolign-1)" With WSECTION
  Next I
Endif
Call CHARG_SCM_CPTANALIN(nolign-1) From SCOCPTLIB
Return


##################################################################

Subprog CHARGE_SCO3_FROM_BOS(LITMREF,LBPRNUM,LBOMALT,LSRVITMREF,LSRV)
Value    Char    LITMREF
Value    Char    LBPRNUM   # FQ 74682 GA 07/2011
Value    Integer LBOMALT
Value    Char    LSRVITMREF
Value    Integer LSRV : # inutilisé dans cette version

# Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
Local Char    WFCY(GLONFCY)

# -------
# Site
# -------
#If [M:SCO1]PRHFCY=""
#   [M:SCO1]PRHFCY = [M:SCO0]POHFCY
#Endif
#If [M:SCO3]PRHFCY=""
#   [M:SCO3]PRHFCY = [M:SCO1]PRHFCY
#Endif

# -------
# Devise
# -------
[M:SCO3]CUR = [M:SCO1]CUR  # FQ 54650

# ------------------------
# 1) Chargement de [F:ITM]
# ------------------------
Local Char WITMREF(GLONITM) : WITMREF=LSRVITMREF
Gosub READ_ITM From ITMLIB
If fstat : Gosub RAZ_SCO3_SRVITMREF : Endif
#nolign = LSRV+1

# FQ 74168 GA 06/2011 pour chargement de l'UA - FQ 74682 GA 07/2011 [M:SCO0]BPRNUM ko en création
# contrôle article/fournisseur
Local Char WBPRNUM(GLONBPR) : WBPRNUM=LBPRNUM
# Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
#Gosub READ_ITP From ITMLIB
##If GOK=-1 : OK=1 : GMESSAGE=mess(23,198,1)-WITMREF-WBPRNUM : Endif
If [M:SCO1]PRHFCY <> ""
  WFCY = [M:SCO1]PRHFCY
Else
  WFCY = [M:SCO0]POHFCY
Endif
Call FIND_ITMBPSFCY_ITMBPS(WITMREF,WBPRNUM,WFCY,WITMBPS) From TRTACHDEF1
# End issue X3-55891

# FQ 57892 GA 09/2009 le transclasse ne fonctionne pas correctement à cause des CCE
#[M:SCO3] = [F:ITM]
Gosub CHARGE_SCO3_FROM_ITM
[M:SCO3]ITMREF=LITMREF        # Raz par le transclasse
[M:SCO3]SRVITMREF=LSRVITMREF

# ------------------------
# 2) Chargement de [F:BOD]
# ------------------------
If LSRVITMREF <> [F:BOD]CPNITMREF
  # Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
  # Check validity date of the link
  Local Integer WBOMDATCTL : WBOMDATCTL=2
  Local Date    WBOMDAT
  #If [M:SCO1]ORDDAT<>[0/0/0] WBOMDAT=[M:SCO1]ORDDAT Else WBOMDAT=date$ Endif
  Gosub PE_BOMDATCTL From SCOAUTLIB
  Case WBOMDATCTL
    When 1       : WBOMDAT=[M:SCO1]RETDAT
    When Default : WBOMDAT=[M:SCO1]ORDDAT  # standard mode
  Endcase
  If WBOMDAT=[0/0/0] WBOMDAT=date$ Endif

  # Issue 86701 GA 12/2012 pb chargement des composant si [M:SCO1]ORDDAT non renseignée
  #Local Date WDATE
  #If [M:SCO1]ORDDAT<>[0/0/0] WDATE=[M:SCO1]ORDDAT Else WDATE=date$ Endif
  Filter [BOD] Where ITMREF=LITMREF
&                and BOMALT=LBOMALT       and BOMALTTYP=3
&                and CPNITMREF=LSRVITMREF and CPNTYP=7
&                and (BOMENDDAT = [0/0/0] | BOMENDDAT >= WBOMDAT )
&                and (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= WBOMDAT )
  Read   [BOD] First
  If fstat : Raz [F:BOD] : Endif
  Filter [BOD]
# pas d'erreur si non trouvé
# If fstat : Gosub RAZ_SCO3_SRVITMREF : Endif
Endif
If LSRVITMREF = [F:BOD]CPNITMREF
#  nolign = LSRV+1
   # Issue 98583 GA 04/2014 le chargement [F:BOD] est impératif (appel depuis GENSRV)
   #If [M:SCO3]SRVITMREF<>LSRVITMREF
   # nouveau service: on recharge tout
      [M:SCO3] = [F:BOD]
      [M:SCO3]SRVITMREF = [F:BOD]CPNITMREF  : # 02/2007 changt nom de champ Service
      [M:SCO3]STRQTYCOD = [F:BOD]LIKQTYCOD
      If [F:BOD]BOMOFS>0
         [M:SCO3]SCOLTI = [F:BOD]BOMOFS
      Else
         Local Integer ILTI : ILTI=[M:SCO3]SCOLTI
         Call FIND_LTI(LSRVITMREF,LBPRNUM,[M:SCO0]POHFCY,ILTI) From SCOLIB
         # FQ 59151 pb si aucun délai sur le Service: prendre le délai article lancé
         If ILTI>0
            [M:SCO3]SCOLTI = ILTI
         Else
            [M:SCO3]SCOLTI = [M:SCO1]LTI
         Endif
      Endif
      # Issue 103531 - 2014-12-17 by JUSYN : Service text from Subcontract BOM. Immediate changings would be overwritten, so textnumber
      #                                      has to be checked as well.
      # If [F:BOD]BOMTEXNUM <> ""
      If [F:BOD]BOMTEXNUM <> "" & left$([M:SCO3]SCSTEX,3)<>"SCS"
         [M:SCO3]SCSTEX  = [F:BOD]BOMTEXNUM
      Endif
      Local Integer WOFS : WOFS=[M:SCO3]SCOLTI
      Raz [M:SCO3]OPESTR
      Call UPD_SRV_DAT(WOFS,[M:SCO3]OPESTR,[M:SCO3]OPEEND,0) From SCOLIB
  # Else
  # # réaffichage d'une opération: codes quantités
  #    [M:SCO3]STRQTYCOD = [F:BOD]LIKQTYCOD
  # Endif

  # Issue 87115 GA 01/2013 [F:BOD] prioritaire idem UPD_SRV_UOM
  # Issue 69609 GA 02/2012
  # => UOM lue dans [F:BOD] avec coeff saisi sur la nomenclature
  # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
  # => STU de l'article service
  [M:SCO3]OPESTU    = [F:ITM]STU
  [M:SCO3]OPESTRCOE = 1
  [M:SCO3]OPESTUCOE = 1
  # Issue 87021 GA 01/2013 ce coeff renseigne plutôt [F:SCS]OPESTUCOE
  If dim([F:BOD]BOMUOM)>0 & [F:BOD]BOMUOM<>""
     [M:SCO3]SCOPUU    = [F:BOD]BOMUOM
     [M:SCO3]OPESTUCOE = [F:BOD]BOMSTUCOE  # Issue 87021 GA 01/2013
  Endif
  If [M:SCO3]SCOPUU="" | [M:SCO3]SCOPUU = [F:ITP]PUU
     [M:SCO3]SCOPUU    = [F:ITP]PUU
     If [F:ITP]PUUSTUCOE<>0            # Issue 77611
        [M:SCO3]OPESTRCOE = 1/[F:ITP]PUUSTUCOE
     Endif
   Elsif [M:SCO3]SCOPUU="" | [M:SCO3]SCOPUU = [F:ITM]PUU
     [M:SCO3]SCOPUU    = [F:ITM]PUU
     If [F:ITM]PUUSTUCOE<>0            # Issue 77611
        [M:SCO3]OPESTRCOE = 1/[F:ITM]PUUSTUCOE
     Endif
  Endif
  If [M:SCO3]OPESTU<>[M:SCO3]SCOPUU & [M:SCO3]OPESTRCOE=1 & [M:SCO3]STRQTYCOD<>2
    # Coef de conversion entre "Unité lancement" et "Unité oeuvre"
    Call RECH_COEFF([M:SCO3]SRVITMREF,[M:SCO0]BPRNUM,[M:SCO3]OPESTU,[M:SCO3]SCOPUU,GBIDD1) From SCOLIB
    [M:SCO3]OPESTRCOE = GBIDD1
  Endif

  # Issue 86439 GA 12/2012 changt BOMALT avec [M:SCO1]EXTQTY déjà rempli
   If [M:SCO1]EXTQTY<>0
      Call UPD_SRV_QTY([M:SCO1]EXTQTY,[M:SCO3]OPESTU,[M:SCO3]SCOPUU,0) From SCOLIB
      Call UPD_SRV_PRI(0) From SCOLIB
   Endif
Endif
#
# -------------------------------------------------
# 3) Données de l'article sous-traitance dans SCO3
# -------------------------------------------------
Call RECH_SCO3_SRVITMREF(LSRVITMREF,LITMREF,LBPRNUM) From SUBSCO3
#
# FQ 74137 GA 06/2011 pb si nomenclature avec [F:BOH]BASQTY>1
# ------------------------
# 4) Chargement de [F:BOH]
# ------------------------
If [F:BOH]ITMREF<>LITMREF | [F:BOH]BOMALT<>LBOMALT
   Read [BOH]BOH0=LITMREF;LBOMALT;3
   If fstat Raz [F:BOH] Endif
Endif
End
$RAZ_SCO3_SRVITMREF
Raz [F:BOD]
WOK = 0
Default Mask [SCO1]
End
##################################################################
$CHARGE_SCO3_FROM_ITM
# FQ 57892 GA 09/2009 pb car les sections de [F:ITM] sont différentes
[M:SCO3] = [F:ITM]
If dim([M:SCO3]CCE)>0  # Issue 107611 GA 04/2015
   Raz [M:SCO3]CCE
Endif
Call CHARG_SCS_CPTANALIN(-1) From SCOCPTLIB
Return

##################################################################

Subprog CTRL_INTERSITE (LPOHFCY,LBPRNUM)
Variable Char    LPOHFCY
Variable Char    LBPRNUM

#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# LPOHFCY : Site de commande                          #
# LBPRNUM : Fournisseur de la commande                #
# WORI    : Origine de l'appel (1=POHFCY, 2=BPRNUM)   #
#-----------------------------------------------------#
If LBPRNUM="" : End : Endif

If GREP="D"
  Local Char    SVGCPY(GLONCPY) : SVGCPY=GCPY
  Local Integer SVGBET          : SVGBET=[M:SCO0]BETFCY
Endif
Raz GRCPFCY
Raz [M:SCO1]MFGFCY
Call CTRL_INTERSITE(LPOHFCY,LBPRNUM,2,[M:SCO0]BETFCY,[M:SCO0]BETCPY,[M:SCO1]SALFCY,
&                   [M:SCO1]MFGFCY,[M:SCO1]BPCORD,[M:SCO1]INVFCY,[M:SCO1]BPCINV,
&                   [M:SCO1]DME) From TRTACHCTL1
If mkstat  GERR=1 : End : Endif
Affzo [M:SCO0]BETFCY,BETCPY   # FQ 53166
#-----
If [M:SCO0]BETFCY=2 | [M:SCO0]BETCPY=2
   [M:SCO1]ORIFCY=LPOHFCY
   # Issue 119621 - 2016-11-08 by MUARN : contrôle site
   If [M:SCO1]PRHFCY="" : [M:SCO1]PRHFCY=GRCPFCY : Call AM_PRHFCY([M:SCO1]PRHFCY) From SUBSCO1 : Endif
   Actzo [M:SCO1]MFGFCY
   Affzo [M:SCO1]MFGFCY : Affzo [M:SCO1]PRHFCY
Else
  Raz [M:SCO1]ORIFCY, GSTOFCY
  Grizo [M:SCO1]MFGFCY
Endif

# Issue 83440 GA 11/2012 is there any default receipt facility associated ?
If [M:SCO1]PRHFCY="" & GRCPFCY<>""
  [M:SCO1]PRHFCY=GRCPFCY
  # Issue 119621 - 2016-11-08 by MUARN : contrôle site
  Call AM_PRHFCY([M:SCO1]PRHFCY) From SUBSCO1
  Affzo [M:SCO1]PRHFCY
Endif

# Issue 83440 GA 11/2012: ctrl supressed on SCO2/SCO3
#### -----------------------------------------------
#### Ctrl du site associé aux Matières dans [M:SCO2]
#### -----------------------------------------------
###If GREP="D" & [M:SCO2]NBLIG<>0
###  If [M:SCO0]BETFCY<>2 | SVGCPY<>GCPY
###    For I=0 To [M:SCO2]NBLIG-1
###      Raz [M:SCO2]STOFCY(I)
###      If [M:SCO0]BETFCY=2
###      # Les matières sont sur le site de commande
###        Look [ITF] ITF0=[M:SCO2]CPNITMREF(I);[M:SCO0]POHFCY
###        If !fstat
###          [M:SCO2]STOFCY(I)=[M:SCO0]POHFCY
###        Elsif [M:SCO0]POHFCY<>[M:SCO1]PRHFCY
###        # Les matières sont sur le site de réception
###          Look [ITF] ITF0=[M:SCO2]CPNITMREF(I);[M:SCO1]PRHFCY
###          If !fstat
###            [M:SCO2]STOFCY(I)=[M:SCO1]PRHFCY
###          Endif
###        Endif
###      Endif
###    Next
###  Endif
###Endif
###
#### -----------------------------------------------
#### Ctrl du site associé aux Opérations dans [M:SCO3]
#### -----------------------------------------------
###If GREP="D" & [M:SCO2]NBLIG<>0
###  If [M:SCO0]BETFCY<>2 | SVGCPY<>GCPY
###      If [M:SCO0]BETFCY=2
###      # Le service existe sur le site de réception
###        Look [ITF] ITF0=[M:SCO3]SRVITMREF;[M:SCO1]PRHFCY
###        If !fstat
###          [M:SCO3]PRHFCY = [M:SCO1]PRHFCY
###        Endif
###      Endif
###  Endif
###Endif

# Demande LLC: afficher un libellé plutôt que BETFCY et BETCPY
If [M:SCO0]BETCPY = 2
   [M:SCO0]ZBETCPY = mess(491,197,1)
Elsif [M:SCO0]BETFCY = 2
   [M:SCO0]ZBETCPY = mess(645,197,1)
Else
   [M:SCO0]ZBETCPY = ""
Endif
# GA 09/2006 demande GL on affiche les indicateurs plutôt que le libellé
#Affzo [M:SCO0]ZBETCPY
Affzo [M:SCO0]BETCPY,BETFCY

End

################################################################
Funprog GET_POQLNK (LPOPLIN, LPOQSEQ)
Value Integer LPOPLIN, LPOQSEQ
Local Char WPOQLNK(10)

WPOQLNK = mid$("00000000",1,8-len(num$(LPOPLIN)))+num$(LPOPLIN)
&       + mid$("00000000",1,8-len(num$(LPOQSEQ)))+num$(LPOQSEQ)

End WPOQLNK


#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:SCO2]ACC1)>0 | dim([M:SCO2]CCE1)>0) & [F:PTR]PTRNUM<>""
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE9"+[F:PTR]PTRNUM+"2"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SCO2]NBLIG=0
     [M:SCO2]NBLIG=1 : Affzo [SCO2]5 : Effzo [SCO2]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

########################################################################
Subprog TEST_DOSSIER(LDOSOK)             # selon TEST_DOSSIER de SUBMFGA
Variable Integer LDOSOK
Local Char    XMESS(110)

# Issue 82790 GA 06/2012 sauf si alloc manuelle
If [F:PTR]MODALL > 1
   LDOSOK = func SCOLIB.CTRL_ALLMGT ()
Else
   LDOSOK = 1
Endif

End

