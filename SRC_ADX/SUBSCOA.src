$VALLIG
#----------------------------------------------------------------------#
# Traitements complémentaires ligne commande                           #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
# TRTLIG vaut "C","M","A" en créa, modif, annule                       #
# l'enregistrement "ligne" est en ligne                                #
#----------------------------------------------------------------------#
# voir MODIF FROM SUBSCO1
Return

$CRELIG
# à rajouter si plan multi-articles par la suite
Return

$MODLIG
#-------------------------------------------#
# Après Rewrite de la ligne de commande POP #
#-------------------------------------------#
# à rajouter si plan multi-articles par la suite
Return

$SUPLIG
Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
GCONSLCT = GCONSULT
Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
# pb TS le 17/09/2008 CHARG_PARAM à faire toujours
Gosub CHARG_PARAM
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#----- Ecran SCO0 -----#
Actzo [SCO0]1-99
[M:SCO0]POHFCY=GFCY
[M:SCO0]CPY=GSOCIETE
If GUSRFCY(1)<>"\" & GNBAUZ=1 & [M:SCO0]POHFCY<>""
  Diszo [SCO0]POHFCY        : # Saisie inutile si un seul site permis
Else
  Actzo [SCO0]POHFCY        : # Activation saisie si plusieurs sites possibles
Endif
[M:SCO1]ORDDAT=date$
[M:SCO1]INVFCY=GFINRSP      : # maj par CHARG_PARAM (appel de GETDEV)
Return

$RAZDUP
GCONSLCT = GCONSULT
#-------------------#
# Avant duplication #
#-------------------#
Gosub RAZDUP From SUBSCO1
Gosub RAZDUP From SUBSCO2
Gosub RAZDUP From SUBSCO3
# FQ 78917 suite FQ 77115 GA 01/2012: réouvrir les zones de dates en duplication d'EO
Actzo [M:SCO3]OPESTR : Actzo [M:SCO3]OPEEND :  Actzo [M:SCO3]SCOLTI
Actzo [M:SCO1]RETDAT : Actzo [M:SCO2]DLVDAT
# Issue 85528 GA 11/2012
If [F:PTR]RCPFCYCOD=1
   Actzo [M:SCO1]PRHFCY
Endif
Return

#########################################################################""
$LIENS
Actzo [SCO0]
Actzo [SCO1] : Raz [M:SCO1]
Actzo [SCO2] : Raz [M:SCO2]
Actzo [SCO3] : Raz [M:SCO3]

GMEMSTA = [F:SCO]SCOSTA

# Chargement de données par site/sté + interface comptable
Call AM_POHFCY([M:SCO0]POHFCY) From SUBSCO

# Chargement de données par Fournisseur
Call AM_BPRNUM([M:SCO0]BPRNUM) From SUBSCO

Gosub CHARG_PARAM : # Si GMESSAGE chargé pas de paramétrage signature
If GMESSAGE<>""
  GERR=1 : OK=0 : Return
Endif

#---------------------------#
# Lecture Article   [F:SCI] #
#---------------------------#
Gosub LIENS From SUBSCO1
#If OK=0 Return Else OK=1 : Endif

#---------------------------#
# Lecture Matières  [F:SCM] #
#---------------------------#
Gosub LIENS From SUBSCO2
#If OK=0 Return Else OK=1 : Endif

#---------------------------#
# Lecture Opération [F:SCS] #
#---------------------------#
Gosub LIENS From SUBSCO3
#If OK=0 Return Else OK=1 : Endif

# Issue 84760 - 2012-10-31 by CCC
GCUR = [M:SCO1]CUR

#----- Contrôle et chargement des zones inter-sites -----#
Call CTRL_INTERSITE ([M:SCO0]POHFCY,[M:SCO0]BPRNUM) From SUBSCOA

# Si la commande a été créée, on ne peut plus changer le Site et le fournisseur, ni les dates
If [M:SCO3]POHNUM<>"" | [M:SCO1]POHNUM<>"" | [M:SCO1]ITMSTA>2 | [M:SCO3]OPESTA>2
   Grizo [M:SCO0]POHFCY : Grizo [M:SCO0]BPRNUM
   # FQ 77115 GA 12/2011 pas de maj des dates dès que la commande est partie
   Grizo [M:SCO3]OPESTR :  Grizo [M:SCO3]OPEEND :  Grizo [M:SCO3]SCOLTI
   Grizo [M:SCO1]ORDDAT :  Grizo [M:SCO1]RETDAT
   Grizo [M:SCO2]DLVDAT
   # Issue 88046 & 95308 GA 01/2014 site réception et adresses non modifiables si commandé
   # Issue 85528 GA 11/2012
   #If [F:PTR]RCPFCYCOD=1
      Grizo [M:SCO1]PRHFCY : Grizo [M:SCO1]PRHADD : Grizo [M:SCO1]BPAADD
   #Endif
Else
   Actzo [M:SCO0]POHFCY : Actzo [M:SCO0]BPRNUM
   # FQ 77115 GA 12/2011
   Actzo [M:SCO3]OPESTR : Actzo [M:SCO3]OPEEND :  Actzo [M:SCO3]SCOLTI
   Actzo [M:SCO1]RETDAT : Actzo [M:SCO2]DLVDAT
   # Issue 88046 & 95308 GA 01/2014 site réception et adresses modifiables si non commandé et maj site rcp autorisée
   Actzo [M:SCO1]BPAADD
   # Issue 85528 GA 11/2012
   If [F:PTR]RCPFCYCOD=1
      Actzo [M:SCO1]PRHFCY : Actzo [M:SCO1]PRHADD
   Endif
Endif

#
# Aucune maj autorisée
If [M:SCO1]SCOSTA=4 | [M:SCO1]SCOTRKFLG=5 : # Ordre clos ou soldé
   GCONSLCT=1
Endif

# Issue 107513/US10 GA 06/2015
Gosub LIENS From SCOECCLIB

#----- Affichage icone texte, màj listes gauche picking et affichage trace -----#
If !GIMPORT
  Gosub TIROIR                         : # Màj listes de gauche picking
Endif
Return

########################################################################
$VERIF_CRE
#---------------------------#
# Vérifications en création #
#---------------------------#
Gosub VERIF
If OK=0 Return Else OK=1 : Endif
# Ouverture fichier trace pour alertes budget si nécessaire
# et pour inter-sites
Gosub OUVERTURE_TRACE
Return

########################################################################
$INICRE
#---------------------------#
# Chargement avant le Write #
#---------------------------#
Local Integer STAT
# -------------------------------------------
# Affectation du no de plan de sous-traitance
# -------------------------------------------
#If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:SCO0]SCONUM,2)="")
  # Call NUMERO(GCODNUM,GFCY,[M:SCO1]ORDDAT,"",[M:SCO0]SCONUM,STAT) From SUBANM
  Call NUMERO(6,14,GCODNUM,GFCY,[M:SCO1]ORDDAT,"",[M:SCO0]SCONUM,STAT) From TRTX3TCA
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  Affzo [M:SCO0]SCONUM
#Endif
#
Gosub CHARGENTETE
#
# tant qu'on n'utilise pas INICRE_LIG et INIMOD_LIG (TABLEAUX sur SCO1)
Gosub CHARGLIGNE
#
[F:SCO]CREDAT  = date$              # FQ 51325 déplacé car écrasé par CHARGENTETE
[F:SCO]CREUSR  = GUSER
[F:SCO]EXPNUM  = [C]EXPORT
Raz [F:SCO]UPDDAT,[F:SCO]UPDUSR
#
Return

########################################################################
$CREATION
#--------------------------------------------#
# Création détail ordre de sous-traitance    #
#--------------------------------------------#
#-------------------------- #
# Insertion des lignes SCI  #
#-------------------------- #
Gosub CREATION From SUBSCO1
If GOK<1 : Goto ERR_CREATION : Endif

#-------------------------- #
# Insertion des lignes SCM  #
#-------------------------- #
Gosub CREATION From SUBSCO2
If GOK<1 : Goto ERR_CREATION : Endif

#-------------------------- #
# Insertion des lignes SCS  #
#-------------------------- #
Gosub CREATION From SUBSCO3
If GOK<1 : Goto ERR_CREATION : Endif

Return
$ERR_CREATION   # Issue 88677 idem SUBMFGA
Raz [M:SCO0]SCONUM : Return

########################################################################
$APRES_CRE
#---------------------------------------------------------------#
# Effacement fichier de travail et affichage numéro de commande #
#---------------------------------------------------------------#
  Local Integer WRET : WRET=0
  Call UPD_SCOTRKFLG([F:SCO]SCONUM,WRET) From SCOLIB

  If clalev([F:PWO])<>0
# ========== traiter   les lignes PWO ============
     Gosub TRAITE_PWO
# ========== supprimer les lignes PWO ============
     Gosub DELETE_PWO
     ###If GOK=0 | mkstat Goto AB_PWO : Endif
  Endif
  If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>GSCOPTRNUM : # Relecture transaction si nécessaire
    Read [PTR] PTR0=9;GSCOPTRNUM      : If fstat Raz [F:PTR] : Endif
  Endif

If [F:SCO]SCOSTA = 1 : Gosub MAJ_MTO_AP_ALL From SCOMTOLIB : Endif        # mise à jour des affectations

Local Integer DOSOK
DOSOK = 0
Call TEST_DOSSIER(DOSOK)
If DOSOK = 1
   Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
   # Bon de sortie matières
   If dim([F:PTR]DOCFLG)>0 & [F:PTR]DOCFLG = 2 & [F:PTR]DOCNAM<>""
     Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
     Call ETAT([F:PTR]DOCNAM,"GESSCO",TBPAR,TBVAL) From ETAT
   Endif
   # Bon de travail
   If dim([F:PTR]NPRFLG)>0 & [F:PTR]NPRFLG = 2 & [F:PTR]NPRNAM<>""
     Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
     Call ETAT([F:PTR]NPRNAM,"GESSCO",TBPAR,TBVAL) From ETAT
   Endif
   # Fiche technique
   If dim([F:PTR]TECFLG)>0 & [F:PTR]TECFLG = 2 & [F:PTR]TECNAM<>""
     Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
     Call ETAT([F:PTR]TECNAM,"GESSCO",TBPAR,TBVAL) From ETAT
   Endif
Endif

#--------------------------------------------------#
# v 150 Calcul automatique des coûts prévisionnels # (CPT et CPL)
#--------------------------------------------------#
  If GCLCEOCAUT > 1 & [F:SCO]SCOSTA = 1
    # appel direct possible car la boite de dlg ne s'ouvre pas
    # charger les paramètres.   # FQ 47987 avant PARAM, VALEUR
    Local Char PARAM_CLC(50)(1..14) , VAL_CLC(10)
    # Issue 84784 - 2012-09-26 by CCC
    #PARAM_CLC(1)  = [M:SCO0]POHFCY
    PARAM_CLC(1)  = [M:SCO1]PRHFCY
    PARAM_CLC(2)  = [M:SCO0]SCONUM
    PARAM_CLC(4)  = "1"
    PARAM_CLC(5)  = "4"
    PARAM_CLC(13) = "2"   # Issue 89622 - 2013-06-05 by CCC
    Case [F:PTR]MCCIMPMOD
         When 0, 1  : PARAM_CLC(12) = "2"
                      PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
         When 2     : PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
         When 3     : PARAM_CLC(12) = "2"
    Endcase
    PARAM_CLC(14) = "36"   : # VCRTYP 36 pour EO
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
  Endif
  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS From SUBSCOA
  Endif

Return


$AB_CREATION
#-------------------------------------------#
# Abandon de la création suite à une erreur #
#-------------------------------------------#
Gosub LECT_EFFAC_TRACE
  If clalev([F:PWO])<>0
# ========== supprimer les lignes PWO ============
     Gosub DELETE_PWO
     ###If GOK=0 | mkstat Goto AB_PWO : Endif
  Endif

Return

