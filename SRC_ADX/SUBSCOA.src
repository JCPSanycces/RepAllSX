##########################################################################
# SUBSCOA : Gestion des Ordres d'achat de sous-traitance                 #
# ---------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "SCO"                        #
# Les traitements sur champ "Call" se trouvent dans le SUBSCO            #
##########################################################################

###########################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                         #
#         et          LIKQTYCOD         STRQTYCOD                         #
###########################################################################

$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=9;GFLAG
  If fstat | [F:PTR]ENAFLG=1 | [F:PTR]TRSAUTO = 2 : Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=9;VARCOD
If fstat | [F:PTR]ENAFLG=1 | [F:PTR]TRSAUTO = 2 : OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=9;GFLAG : If fstat Raz [F:PTR] : Endif
GSCOPTRNUM=[F:PTR]PTRNUM
#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return

$FILTRE
If clalev ([F:PTR])=0  : # Pb si appel depuis les écrans Calcul des coûts
   Gosub SETTRANS
Endif
# Filtrer les listes sur le site courant
If dim(GSCOFILTRE)>0
   If GSCOFILTRE<>""
      FILTSUP=GSCOFILTRE
   Endif
Endif
Return

$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
# Issue 83952 GA 08/2012 le bon de sortie matières n'est pas très adapté ici ...
#### #----- Si document renseigné dans la transaction, prendre celui-la -----#
#### If [F:PTR]DOCNAM<>"" [L]REPORT1=[F:PTR]DOCNAM : Endif
Return

$AP_IMPRIME
#---------------------------------------------------------------#
# Après une impression il faut être sur d'être sur le bon enreg #
#---------------------------------------------------------------#
Gosub RELIT From GOBJSUB
Return

$OUVRE
#--------------------------------------------------------------------#
#- toujours sauvegarder les variables globales GA selon MBT 09/2007 -#
#--------------------------------------------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#
Global Integer  GCONSLCT : GCONSLCT = GCONSULT
Global Integer  GMEMSTA  : # pour sauvegarde de la valeur [M:SCO1]SCOSTA
Global Integer  GMODMAT  : GMODMAT     = 0
# pour appel de la fenêtre OWIP
Global Integer  GWIPTYP
Global Char     GWIPNUM(GLONVCR)
Global Char     GITMREF(GLONITM)
# Fin - pour appel de la fenêtre OWIP

# pour appel de la fenêtre OTBO
Global Char     GFLTTBO(1) : GFLTTBO="3" : # BOMALTTYP

Local Integer  OK  : OK=1
# nécessaire pour chargements de GETCPY() From TRTX3CPT
Raz GSOC_ACTIVE

# Tiroir sur les commandes d'achat
Local  Char     WNUM(GLONVCR), WPOQLNK(16)
Local  Integer  WLIN, WSEQ, WERR
Global  Libelle GSCO_PICK         : # Indique qu'un picking/dépicking est en cours

Local Integer OMODIF

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

#----- Ouverture fichiers si module Compta à Oui -----#
Gosub OPEN_FILES From TRTX3CPT

If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:BPD])  : Local File BPDLVCUST  [BPD] : Endif
If !clalev([F:MVS])  : Local File BPSUPPMVT  [MVS] : Endif
If !clalev([F:TCY])  : Local File TABCOUNTRY [TCY] : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY] : Endif
If !clalev([F:POS])  : Local File POSCOD     [POS] : Endif
If clalev([F:PPK])=0 : Local File PPRICLINK  [PPK] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:ITS]) : Local File ITMSALES   [ITS] : Endif
  If !clalev([F:MVC]) : Local File BPCUSTMVT  [MVC] : Endif
  If !clalev([F:SOH]) : Local File SORDER     [SOH] : Endif
Endif
#----- Ouverture fichiers liens Appel d'offre avec DA et adresse -----#
If !clalev([F:PSA]) : Local File PREQUISA  [PSA] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif

If !clalev([F:ORD])   Local File ORDERS       [ORD] : Endif
If !clalev([F:TBO])   Local File TABBOMALT    [TBO] : Endif
If !clalev([F:BOH])   Local File BOM          [BOH] : Endif
If !clalev([F:BOD])   Local File BOMD         [BOD] : Endif
If !clalev([F:ITP])   Local File ITMBPS       [ITP] : Endif

If !clalev([F:PWO])   Local File PWRKORDERS   [PWO] : Endif
If !clalev([F:POQW])  Local File PORDERQ      [POQW]: Endif # pour FIND_POF
Gosub OPEN_FILES_SCO From SCOLIB

#---------------------------------- #
# Ouverture masques des paramètres  #
#---------------------------------- #
If clalev([M:ORDK])=0 : Local Mask ORDK     [ORDK] : Endif
If clalev([M:ORCK])=0 : Local Mask ORCK     [ORCK] : Endif
If clalev([M:SBCK])=0 : Local Mask SBCK     [SBCK] : Endif
If clalev([M:SCMW])=0 : Local Mask SCMW     [SCMW] : Endif

#-----------------------------------------------------------------#
# Récupération des paramètres achats et budgets                   #
#-----------------------------------------------------------------#
Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
Gosub CHARG_PARAM : # Si GMESSAGE chargé pas de paramétrage signature
If GMESSAGE<>""
  GERR=1 : OK=0 : Return
Endif
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0 : GVACFLG=0 : GDATFLG=0 : GORITITCOL=1

#------------------------------------------------------------------#
# Récupération des codes compteur et effacement fichier de travail #
#------------------------------------------------------------------#
If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : OUVFICFLG=1 : Endif
#----- Compteur des commandes -----#
# MODULE=6 pour Achats
Call LECTCA(6,OK) From SUBTCA
If OK=0
  GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1)
  GERR=1 : OK=0 : Return
Endif
# Le compteur PEO est à la 15ème position (indice=14)
GMANCOU=[F:TCA]MANCOU(14) : GCODNUM=[F:TCA]CODNUM(14)

#------ Compteur des encours article ------#
Call LECTCA(7,OK) From SUBTCA
If OK=0
  GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
  GERR=1 : OK=0 : Return
Endif
GWIP=[F:TCA]CODNUM(8) : I=9
#----- Contrôle longueur compteur pas supérieure à 15 caractères: GA 25 ? -----#
Local Integer  WRET
Call CTRCPT(GWIP,GLONVCR+10,WRET) From STKLIB
If WRET<>0   GMESSAGE=mess(222,199,1) : GERR=1 : OK=0 : Return : Endif

If OUVFICFLG=1 Close Local File [TCA] : Raz OUVFICFLG : Endif

#-----------------------------------------------------#
# Contrôle existence de la structure tarif par défaut #
# et chargement des libellés colonnes par défaut      #
#-----------------------------------------------------#
Raz GRCPFCY, GPLISTC, GPUU, GREVFLG, GAPPFLG, GPLIFLG, GVACFLG, GDATFLG,
&   GCOEUOM, GPURTRACE
Local Libelle  WMODULE : WMODULE=6
Local Char     CODE(3)
Local Integer  I, WRET, WCOD, MAJCDE
Local Shortint OUVFICFLG
Local Libelle  WPE_POHCLEFLG, WCLEFLG, WTRAIT
Call CTLSTRUCT(2,WRET) From TRTPRICE
If WRET<>0 OK=0 : Return : Endif
GPLISTC="none" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call COLREM("C",2,"")   From TRTPRICE
Call TYPREM(2,"")       From TRTPRICE
Call TARIFCHGT(WMODULE) From TRTPRICE
#----- chargement des formats évalués pour fonctionnement mode fiche-tableau -----#
For I=0 To 8 [M:SCO3]FMTREM(I)="NZ:9.2#" : Next I

GMODIF  = 2 : # utilisé par le ctrl action PASLIN

# utilisé par le tunnel sur le type de données TBO (champ BOMALT) ?
GTBOSEL = '([F:TBO]FCY=""|[F:TBO]FCY=[M:SCO0]POHFCY) & [F:TBO]BOMALTTYP=3'

Raz GBIDC1 # Issue 112239 - 2015-11-06 by MUARN : pour le code affaire

#-----------------------------------------------#
# Déclaration des variables pour tableau lignes #
#-----------------------------------------------#
# à rajouter si plan multi-articles par la suite
#Gosub DECLARE From TABLEAUX
Return

$APRES_MODIF
# GH 28/02/2013 bug 88285 refresh de l'EO après tunnel vers cde achat
If COUZON="ITMREF" & CZ=[M:SCO0]ITMREF & GREP=""
   Gosub RELIT From GOBJET
   OK=-1 : SUIZON=COUZON
Endif
Return

$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#    AX : Texte entête       : Actif si SCO en ligne ou création                        #
#    BS : Situation          : Actif si SCO en ligne en visu                            #
#    BC : Coût prév.         : Actif si SCO en ligne en visu                            #
#    BD : Coût revient       : Actif si SCO en ligne en visu                            #
#    BE : Consult coût prév. : Actif si SCO en ligne en visu                            #
#    BT : Transaction        : Actif si SCO en ligne ou création                        #
# ------------------------------------------------------------------------------------- #
# Issue 101696 - 2014-11-13 by JUSYN : Single character using for menu
If find(GREP,"C","D") | CLECUR
#    CHMEN += "AX"
#    CHMEN += "BT"
    CHMEN += "X"
    CHMEN += "T"

Endif
# Issue 101696 - 2014-11-13 by JUSYN : Excluding BE for Production cost inquiry. Single character using for menu.
If GREP = "" & CLECUR
#    CHMEN += "BS"
#    CHMEN += "BC"
#    CHMEN += "BD"
#    CHMEN += "BE"
#    CHMEN += "BF"
    CHMEN += "S"
    CHMEN += "C"
    CHMEN += "D"
    CHMEN += "F"

    If [F:SCO]SCOSTA = 4 & [F:SCO]SCOTRKFLG = 6
        CHMEN += "E"
    Endif
Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE

# ------------------------------------------------------------------------------------- #
# Boutons bas d'écrans                                                                  #
# ------------------------------------------------------------------------------------- #
#     2 : Allocation                                                                    #
#     3 : Commande                                                                      #
#     4 : Solde                                                                         #
# ------------------------------------------------------------------------------------- #
GCONSLCT = GCONSULT
# uniquement visu si GCONSULT=1 (tunnel)
If GCONSLCT=1
    Call VIREBOUT(CHAINE,"MADH12") From GOBJET
Endif
If CLECUR & [F:PTR]SCOSTA = 1 & [M:SCO1]SCOSTA = 1     # maj autorisée si planifié uniquement
    Call VIREBOUT(CHAINE,"MADH12") From GOBJET
    GCONSLCT = 1
Endif
If CLECUR & [F:PTR]SCOSTA = 2 & [M:SCO1]SCOSTA = 2     # maj autorisée si ferme uniquement
    Call VIREBOUT(CHAINE,"MADH12") From GOBJET
    GCONSLCT = 1
Endif
# 05.05 30050
If [M:SCO1]SCOTRKFLG = 2
    Call VIREBOUT(CHAINE,"MADH2") From GOBJET
Endif

# pas de duplication ???
# Call VIREBOUT(CHAINE,"H") From GOBJET

#
# pas de suppression
# - si déjà commandé (=> pas de modif dans un premier temps) ...
If [M:SCO1]POHNUM<>""
    Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
# pas de modification/suppression si statut soldé
If [M:SCO1]SCOTRKFLG > 4
    Call VIREBOUT(CHAINE,"MA") From GOBJET
Endif

# pas d'allocation si pas de matières
If !CLECUR | GREP <> "" | [M:SCO2]NBLIG = 0
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif

# Pas d'action commander
# - si aucun encours EOx référencé
# - si déjà commandé (=> pas de modif dans un premier temps) ...
# FQ 60084 GA 11/2009 autoriser plusieurs commandes
#If [M:SCO1]WIPTYP<>13 | [M:SCO1]POHNUM<>""
If [M:SCO1]WIPTYP<>13 | [M:SCO1]ORDQTY>=[M:SCO1]EXTQTY
   Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

# Pas d'actions Alloc,Commande,Solde
# - si statut de l'ordre <> "Ferme"
# - si Situation est Soldé
If [M:SCO1]SCOSTA<>1 | [M:SCO1]SCOTRKFLG > 4
    Call VIREBOUT(CHAINE,"234") From GOBJET
Endif

#----- Menu "Traçabilité" -----#
# MABON 09/09/2009 : branchement traçabilité pièces
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then
  CHMEN += "P"
Endif

Return

#######################################################
$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
  Case BOUT
       When "2" : # Allouer
            Gosub AVANTBOUT_2
       When "3" : # Commander
            Gosub AVANTBOUT_3
       When "4" : # Solder
            Gosub AVANTBOUT_4
       When "S" : # Situation article lancé
            OMODIF=GMODIF : GMODIF=1
  Endcase
Return

$AVANTBOUT_2
Local Integer WCPT : WCPT = 0
# Appel possible si et seulement si
# au moins 1 matière doit être livrée au sous-traitant
  Call COUNT_MSX (WCPT) From SCOLIBM
  If WCPT=0 : mkstat=1 : GMESSAGE=mess(249,193,1) : Endif
Return

$AVANTBOUT_3
Raz [M:SBCK]
#If [M:SCO1]WIPTYP=0 : mkstat=1 : GMESSAGE="Vous devez valider la saisie" : Endif
Return

$AVANTBOUT_4
Return

#######################################################

$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
#------------------------------------#
  Case BOUT
      When "2" : # Allouer
             Gosub APRESBOUT_2
      When "3" : # Commander
             Gosub APRESBOUT_3
      When "4" : # Solder
             Gosub APRESBOUT_4
  Endcase
Return

$APRESBOUT_2
If dim(GALL) < 0 : Global Integer GALL : Endif
# Affectation du statut d'allocation sur l'ordre de sous-traitance
# [M:SCO1]ALLSTA = [F:SCO]ALLSTA
# on relit tout après SCOALL
###  If GALL <> 0 & !GIMPORT ### GA 03/2006 revoir maj de GALL ????
  If !GIMPORT
     Gosub RELIT From GOBJSUB
  Endif
Return

$APRESBOUT_3
# Affectation de la référence commande dans SCI
  Call FIND_POF From SUBSCO1

# Affectation de la référence commande dans SCS
  Call FIND_POF From SUBSCO3

# Affectation de la référence commande dans SCM
  Local Integer IMAT
  For IMAT=0 To [M:SCO2]NBLIG-1
     Call FIND_POF(IMAT) From SUBSCO2
  Next IMAT

# Issue 71243 - 2011-02-02 by CCC : Lancer le calcul du prévisionnel si création commande
  If GCLCEOCAUT = 3 & [M:SCO1]POHNUM<>""
      If dim([L]PARAM_CLC)>0
        Raz PARAM_CLC,VAL_CLC
      Else
        Local Char PARAM_CLC(15)(1..14) , VAL_CLC(10)
      Endif
      # Issue 84784 - 2012-09-26 by CCC
      #PARAM_CLC(1) = [F:SCO]POHFCY
      If [F:SCI]SCONUM<>[F:SCO]SCONUM
          Read [SCI]SCI0(1)=[F:SCO]SCONUM
          [G:SCI]currlen=0
      Endif
      PARAM_CLC(1) = [F:SCI]PRHFCY
      PARAM_CLC(2) = [F:SCO]SCONUM
      PARAM_CLC(4) = "1"
      PARAM_CLC(5) = "4"
      PARAM_CLC(13) = "2"   # Issue 89622 - 2013-06-05 by CCC
      Case [F:PTR]MCCIMPMOD
           When 0, 1  : PARAM_CLC(12) = "2"
                        PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
           When 2     : PARAM_CLC(13) = "1"   # Issue 89622 - 2013-06-05 by CCC
           When 3     : PARAM_CLC(12) = "2"
      Endcase
      # positionner PARAM_CLC(12) à "2" SI ON NE VEUT PAS l'édition du calcul
      # positionner PARAM_CLC(13) & "2" si on ne veut pas la trace
      # si traitement multiple alors rien
      If [M:SCOK]AUTOTRT = 2
          PARAM_CLC(12) = "2"
          PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
      Endif
      PARAM_CLC(14) = "36"   : # VCRTYP 36 pour EO
      Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
  Endif

  If !GIMPORT
     Gosub RELIT From GOBJSUB
  Endif
Return

$APRESBOUT_4
# on relit tout après TRTCLESCO
  If !GIMPORT
     Gosub RELIT From GOBJSUB
  Endif
Return


#######################################################
# Actions relatives au(x) tiroir(s) liste gauche(s)
#######################################################

$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXPO3(10)
GBOXPO3="GAU_CHE"+num$(find("PO3",OBJLIS(1..8))) : # Picking des commandes
Return

$HINTCLE
#-----------------------------------------------------------#
# Clé pour optimisation du remplissage des listes de gauche #
#-----------------------------------------------------------#
Case currbox
  When GBOXPO3 : HINTLIS(val(right$(GBOXPO3,8)))="POQ2"
   When Default :
Endcase
Return

###########################################################################################
$FILGAUCHE
Raz FILGAUSUP(0)
Case currbox
    When GBOXPO3 :
        FILGAUSUP(0)+="[F:POQ]VCRTYPORI=36"
      # FILGAUSUP(0) ="& [F:POQ]POHFCY=[M:SCO0]POHFCY"
      # If [M:SCO0]BPRNUM<>"" FILGAUSUP(0)+=" & [F:POQ]BPSNUM    = [M:SCO0]BPRNUM" : Endif
        If [M:SCO0]SCONUM<>"" FILGAUSUP(0)+=" & [F:POQ]VCRNUMORI = [M:SCO0]SCONUM" : Endif
      # If [M:SCO0]ITMREF<>"" FILGAUSUP(0)+=" & [F:POQ]ITMREF    = [M:SCO0]ITMREF" : Endif

        # Si pas de clé courante dans la liste de picking: cdes sous-traitance non soldées
        If (!CLECUR) :  FILGAUSUP(1)=' & [F:POQ]LINCLEFLG=1' : Endif

      # GBIDC3="" : Call FILROLE("SCO",GBIDC3) From SUBARL
      # FILGAUSUP(1) += "&" + GBIDC3
   When Default :
Endcase
Return

$AP_FILGAUCHE
#---------------------------------------------------------#
# Après pagination avant ou arrière d'une liste de gauche #
#---------------------------------------------------------#
If !find(currbox,GBOXPO3) Return : Endif
WPICK=2 : # Gosub ACTUALIS_MARQUAGE
Return

$TIROIR
#---------------------------------------------------#
# Click sur un tiroir                               #
# Désormais entièrement géré par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel à la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
If !find(currbox,GBOXPO3)  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
Return

$DEB_PICK
#---------------#
# Début picking #
#---------------#
If !find(currbox,GBOXPO3) Return : Endif
Raz WERR
WDEBPICK=1 : GSCO_PICK=1
Return

$PICKE
#----------------------#
# Nouvel élément pické #
#----------------------#
If !find(currbox,GBOXPO3) Return : Endif
If REP=""
  If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
  Gosub AVANT_MOD : If !OK  Return : Endif
Endif
Case currbox
  When GBOXPO3 : Gosub PICKE_CDE  From SUBSCOB
Endcase
# Gosub GRISAGE
Return

$DEPICK
#------------------------#
# Nouvel élément dépické #
#------------------------#
If !find(currbox,GBOXPO3) Return : Endif
Case currbox
  When GBOXPO3 : Gosub DEPICK_CDE  From SUBSCOB
Endcase
# Gosub GRISAGE
Return

$FIN_PICK
#-------------#
# Fin picking #
#-------------#
WDEBPICK=0 : GSCO_PICK=0
Return

$GRISAGE
#-----------------------------------------------------#
# Traitement du grisage et dégrisage des champs écran #
#-----------------------------------------------------#
If GREP="C"
  Actzo [SCO0]POHFCY, BPRNUM
Else
  Diszo [SCO0]POHFCY, BPRNUM
Endif
Return


#######################################################

$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
#-------------------------------------------#
Case BOUT
  When "X"      : If mkstat=4 & GREP=""             # texte entête EO
                     #MAE, bg 50938
                     #GREP="M" : REP="M"
                     #Gosub SETBOUT From GOBJSUB
                     Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If [M:SCO1]SCOTEX <> "" & !GIMPORT
                        Call SET_IMAGE (4) From GESECRAN
                  Elsif !GIMPORT
                        Call RESET_IMAGE (4) From GESECRAN
                  Endif
  When "S"      : # situation article lancé
                  # GH 28/02/2013 bug 88285 refresh si tunnel effectué sur cde d'achat de l'EO
                  If GMODIF=2
                      Gosub RELIT From GOBJET
                  Endif
                  GMODIF=OMODIF
  When "C"      : # coût prévisionnel
  When "T"      : # transaction
  When Default  :
Endcase
Return

$DEFLIG
# à rajouter si plan multi-articles par la suite
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro de ligne(ZONLIG)     #
#----------------------------------#
Default Mask [SCO1]
Default File [SCI]
CRIT   = 'SCONUM="'+[M:SCO0]SCONUM+'"'
FICLIG = "SCOITM"
ABLIG  = "SCI"
ZONLIG = "SCILIN"
Return

$LIENS_LIG
# à rajouter si plan multi-articles par la suite
Return


