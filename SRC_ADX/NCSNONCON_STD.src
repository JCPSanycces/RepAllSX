#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-66804-66804 - 2017-12-06 by YARAM : Appropriate validations for planner and actioner parameters for a user
# Issue X3-94378 - 2018-06-15 by ALSHE : Restructure NCS data base
Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
# ISSUE X3-66804 - 2017-12-06 By YARAM
Local Char NCSPLANNER(30)
Local Char NCSQAMAN(30)
# End issue X3-66804

# Issue X3-94378 replace CCM by NCS
If (clalev([NCSRC]) = 0) : Local File NCSRECENT [NCSRC] : Endif

  If (PARAM = "NCSQAMAN")
    If (VALEUR = "1")
      # Issue X3-69858 - 2018-01-11 by ALSHE : prohibit unset of QA manager if it is the default QA manager
#      If func AFNC.PARAM("NCSQADEF","") = [M:AUS0]USR
      Filter [ADW] Where [ADW]PARAM = "NCSQADEF" and [ADW]VALEUR = [M:AUS0]USR
      Read [ADW]ADW0 First
      If fstat = 0
          OK = 0
          GMESSAGE = func ASYRFNC.MES1(mess(27,3702,1),[M:AUS0]USR)
          GERR = 1
      Else
      # End issue X3-69858
    # ISSUE X3-66804 - 2017-12-06 By YARAM
    # Issue X3-94378 replace CCM by NCS
      For [NCSRC] Where NCSMANAGER = [M:AUS0]USR & NCSREC = 2  # Issue X3-62786 - 2017-11-30 by JUSYN : CCM fields used for NCS CCMUSRID instead of NCSMANAGER
    # End issue X3-66804
        If ([F:NCSRC]NCSSTA <> 7)
          OK = 0
          GMESSAGE =  mess(9,3702,1)
          GERR = 1
          Break
        Endif
      Next
      Endif
    Endif
  Elsif (PARAM = "NCSPLANNER")
    If (VALEUR = "1")
      # Issue X3-69858 - 2018-01-11 by ALSHE : prohibit unset of olanner if it is the default planner
#     If func AFNC.PARAM("NCSPLADEF","") = [M:AUS0]USR
      Filter [ADW] Where [ADW]PARAM = "NCSPLADEF" and [ADW]VALEUR = [M:AUS0]USR
      Read [ADW]ADW0 First
      If fstat = 0
          OK = 0
          GMESSAGE =  func ASYRFNC.MES1(mess(28,3702,1),[M:AUS0]USR)
          GERR = 1
      Else
      # End issue X3-69858
    # ISSUE X3-66804 - 2017-12-06 By YARAM
    # Issue X3-94378 replace CCM table by NCS table
      For [NCSRC] Where NCSPLANNER = [M:AUS0]USR & NCSREC = 2  # Issue X3-62786 - 2017-11-30 by JUSYN : CCM fields used for NCS PLANNER instead of NCSPLANNER
    # End issue X3-66804
        If ([F:NCSRC]NCSSTA <> 7)
          OK = 0
          GMESSAGE =  mess(9,3702,1)
          GERR = 1
          Break
        Endif
      Next
      Endif
    Endif
    Elsif (PARAM = "NCSAPPROVE")
    # Issue X3-94378 replace CCM table by NCS table
    If (VALEUR = "1")
      If (clalev([NCSAPPR]) = 0) : Local File NCSAPPROVER [NCSAPPR] : Endif

      For [NCSAPPR] Where NCSAPPUSR = [M:AUS0]USR  # Issue X3-62786 - 2017-11-30 by JUSYN : CCM fields used for NCS APPRUSER instead of NCSAPPUSR
      # ISSUE X3-66804 - 2017-12-06 By YARAM
        Filter [NCSRC] Where NCSID = [F:NCSAPPR]NCSID & NCSREC = 2
        # End issue X3-66804
        Read [NCSRC] First
        If (fstat = 0 and [F:NCSRC]NCSSTA <> 7)
          OK = 0
          GMESSAGE =  mess(9,3702,1)
          GERR = 1
          Break
        Endif
      Next
      Close Local File [NCSAPPR]
    Endif
    # ISSUE X3-66804 - 2017-12-06 By YARAM
    Elsif (PARAM = "NCSQADEF")
       Call PARAMUTIL("NCSQAMAN", NCSQAMAN, VALEUR, "") From SUBAUS
       If (NCSQAMAN <> "2")
         OK = 0
         GMESSAGE =  func ASYRFNC.MES1(mess(8,3702,1),VALEUR)
         GERR = 1
      Endif
    Elsif (PARAM = "NCSPLADEF")
      Call PARAMUTIL("NCSPLANNER", NCSPLANNER, VALEUR, "") From SUBAUS
      If (NCSPLANNER <> "2")
         OK = 0
         GMESSAGE =  func ASYRFNC.MES1(mess(23,3702,1),VALEUR)
         GERR = 1
      Endif
    # End issue X3-66804
 Endif
 Filter [ADW]
 Close Local File [NCSRC]

End

