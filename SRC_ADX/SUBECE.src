#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet ECE
Call OBJET ("ECE", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "TITRE"      : Gosub TITRES
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "AVANTBOUT"  : Gosub AVANTBOUT
    When "RAZCRE"     : Gosub RAZCRE  
    When "AFFMASK"    : Gosub AFFMASK
    When "LIENS"      : Gosub LIENS
    When "FILTRE"     : Gosub FILTRE
    When "FILGAUCHE"  : Gosub FILGAUCHE
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "ANNULE"     : Gosub ANNULE
    When default
  Endcase
Return

##########################################################################################################
$TITRES

  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
       TIT = mess(937,182,1) - ":" - num$([M:SRE2]ECETIT)
    Endif
Endif
Return

##########################################################################################################
$OUVRE
Global Integer GIECECONSULT

  GIECECONSULT = GCONSULT
  GCONSULT = 1
Return

##########################################################################################################
$FERME
  GCONSULT = GIECECONSULT 
  Kill GIECECONSULT
Return

##########################################################################################################
$LIENS
Local Integer TESTNBLIG

  Raz [M:ECE1]NBLIG
  # Chargement du tableau des actions
  For TESTNBLIG = 0 To dim([F:ECE]ESCACTNUM)-1
    If [M:ECE1]ESCACTNUM(TESTNBLIG) = "" Then
      Break
    Endif
    [M:ECE1]NBLIG += 1
  Next
  Raz [M:ECE0]SREDETCLA
  If [M:ECE0]SREDET <> "" Then
    Case SREASS
      When 1
        Read [FCY]FCY0=[M:ECE0]SREDET
        If fstat Then
          [M:ECE0]SREDETCLA = [M:ECE0]SREDET
        Else
          [M:ECE0]SREDETCLA = [F:FCY]FCYNAM
        Endif
      When 2
        Read [AUS]CODUSR=[M:ECE0]SREDET
        If fstat Then
          [M:ECE0]SREDETCLA = [M:ECE0]SREDET
        Else
          [M:ECE0]SREDETCLA = [F:AUS]NOMUSR
        Endif
      When 3
        Read [QUE]QUE0=[M:ECE0]SREDET
        If fstat Then
          [M:ECE0]SREDETCLA = [M:ECE0]SREDET
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #[M:ECE0]SREDETCLA = [F:QUE]TTR
          Call LECTEXTRA([M:ECE0]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        Endif
      When Default
    Endcase
  Endif
  Affzo [M:ECE0]1-99
  Affzo [M:ECE1]1-99
Return

##########################################################################################################
$INICRE
Return

##########################################################################################################
$VERIF_CRE
Return

##########################################################################################################
$VERIF_MOD
Return

##########################################################################################################
$CREATION
Return

##########################################################################################################
$MODIF
Return

##########################################################################################################
$ANNULE
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$AFFMASK
Return

##########################################################################################################
$FILTRE
Return

##########################################################################################################
$FILGAUCHE
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
Return

##########################################################################################################
$RAZCRE
Return
