#<AdxTL>@(#)0.0.0.0 $Revision$Class Tax
# Supervisor
## ATY-ATYPE ## VATESS
# 2018-11-09 07:15:26 630

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,VAT,LEG,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char VAT
Value Char LEG
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File TABVAT [TVT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".TABVAT" [TVT]
Endif

Default File [F:TVT]
Read [F:TVT]TVT0 = [L]VAT;[L]LEG
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]VAT)+"~"+num$([L]LEG)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "A"
  [L]ATSTFILTER = ([F:TVT]VATTYP=1) : [L]AMESFILTER= func ASYRFNC.TEXTE(10586)
 When "B"
  [L]ATSTFILTER = ([F:TVT]VATTYP=2 or [F:TVT]VATTYP=3) : [L]AMESFILTER= func ASYRFNC.TEXTE(10588)
 When "C"
  [L]ATSTFILTER = ([F:TVT]VATTYP=4) : [L]AMESFILTER= func ASYRFNC.TEXTE(41665)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]VAT)+"~"+num$([L]LEG)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


