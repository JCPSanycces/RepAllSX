#<AdxTL>@(#)162.0.0.0 $Revision$
######################################################################## 
# FUNPPCACT : Activation/Désactivation               créé JLS et SR    # 
#             et changement priorité              modifié MBT 24/07/98 # 
#             des tarifs ACHATS                                        # 
#----------------------------------------------------------------------# 
# Table mise à jour  : [F:PPC]PPRICCONF                                # 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             de l'écran [M:PP1]PPCACTIF                               # 
########################################################################

######################################################################## 
# Etiquettes ACTION
######################################################################## 
$ACTION
#--- Actions liées à la fenêtre 
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "TITRE"        : Gosub TITLE
  When "DEBUT"        : Raz [M:PP1]
  When "AV_CHOIX"     : Gosub AV_CHOIX
  When "APRES_MODIF"  : If !GHISTO  REP="M" : Endif
  When "ABA"          : REP=""
  When "ENR"          : Gosub ENR : REP="" 
  When Default
Endcase

#---------------------------------------------------------------------#
$OUVRE
If clalev ([F:PPC])=0 : Local File PPRICCONF [PPC] : Endif
Return

#---------------------------------------------------------------------#
$TITLE
TIT=mess(61,195,1)
Return

#---------------------------------------------------------------------#
$AV_CHOIX
nolign = 0
For [PPC]
 nolign += 1
 [M:PP1] = [F:PPC]
 Call LECTEXTRA ([M:PP1]PLIDES(nolign-1),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
 [M]OPIO(nolign-1)=[F:PPC]PIO
 [M]OPLIENAFLG(nolign-1)=[F:PPC]PLIENAFLG
 Next
[M:PP1]NBTAR = nolign
Affzo [PP1]
If GHISTO  Diszo [PP1]1-99 : Endif
Return

#---------------------------------------------------------------------#
$ENR
Local Integer I

Call DEBTRANS From GLOCK

Trbegin [PPC]
  For I=0 To [M]NBTAR-1
  If [M]PIO(I)<>[M]OPIO(I) | [M]PLIENAFLG(I)<>[M]OPLIENAFLG(I)
     [M]UPDUSR(I)=GUSER
     [M]UPDDAT(I)=date$
  Endif
    Update [PPC] Where PLI=[M]PLI(I)
&                With PLIENAFLG=[M]PLIENAFLG(I), PIO=[M]PIO(I), UPDUSR=[M]UPDUSR(I), UPDDAT=[M]UPDDAT(I)
    If fstat GOK=0 : Call FSTA("PPC") From GLOCK : Break : Endif
  Next I

If GOK=1   Commit  Else  Rollback   Endif

Return

######################################################################### 
# Actions champs de l'écran PPCACTIF                                    # 
######################################################################### 
Subprog AV_NBTAR
If [M:PP1]NBTAR=0 : mkstat=2 : End : Endif
End

########################################
Subprog AM_PIO(VALEUR) 
Variable Decimal VALEUR 
If VALEUR<1 | VALEUR>99 : mkstat=1 : Endif 
End 
 
######################################################################### 
