#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..4) , VALEUR(10)
#PARAM(1)="A5T"
#PARAM(2)=""
#PARAM(3)="ENG"
#PARAM(4)="FRA"

PARAM(1)="SAM118755"
PARAM(2)=""
PARAM(3)="ENG"
PARAM(4)="FRA"
Call SAISIE_CHAR(VALEUR,PARAM,"APRTRAD3","APRTRAD3","SPEAPRTRAD3") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"           : Gosub DEBUT
Endcase
Return

$DEBUT
Local Char ACODPRO,ACODLEG,ALAN,ALANREF
[M]CODPRO=PARAM(1)
[M]CODLEG=PARAM(2)
[M]LAN=PARAM(3)
[M]LANREF=PARAM(4)
[M]LANDEFV=[M]LANREF
If GLANGUE=[M]LAN : [M]LANDEFV=[M]LAN : Endif
ACODPRO=[M]CODPRO : ACODLEG=[M]CODLEG : ALAN=[M]LAN : ALANREF=[M]LANREF
[M]MAJ="12"
Gosub CHARGE
Return



$CHARGE
If clalev([F:APR])=0  : Local File APROCESSUS [APR]  : Endif
If clalev([F:AXP])=0  : Local File APROCTEXTE [AXP]  : Endif
If clalev([F:AXP1])=0 : Local File APROCTEXTE [AXP1] : Endif
Local Integer NL
Effzo [M]10
Filter [AXP] Where CODPRO=ACODPRO and CODLEG=ACODLEG and LANG=ALANREF
For [AXP]
  [M]AJOUR(NL)=2
  Read [AXP1]AXP0=ACODPRO;ACODLEG;ALAN;[F:AXP]UNIQIDP
  If fstat<>0
    Raz [M]VLDDAT(NL) : [M]AJOUR(NL)=1
  Else
   If [F:AXP]UPDDAT<>[0/0/0]
     If [F:AXP1]UPDDAT<>[0/0/0]
       If [F:AXP1]UPDDAT<[F:AXP]UPDDAT or ([F:AXP1]UPDDAT=[F:AXP]UPDDAT and [F:AXP1]UPDDATTIM<[F:AXP]UPDDATTIM)
         [M]AJOUR(NL)=1
       Endif
     Else
       If [F:AXP1]CREDAT<[F:AXP]UPDDAT or ([F:AXP1]CREDAT=[F:AXP]UPDDAT and [F:AXP1]CREDATTIM<[F:AXP]UPDDATTIM)
         [M]AJOUR(NL)=1
       Endif
     Endif
   Else
     If [F:AXP1]UPDDAT<>[0/0/0]
       If [F:AXP1]UPDDAT<[F:AXP]CREDAT or ([F:AXP1]UPDDAT=[F:AXP]CREDAT and [F:AXP1]UPDDATTIM<[F:AXP]CREDATTIM)
         [M]AJOUR(NL)=1
       Endif
     Else
       If [F:AXP1]CREDAT<[F:AXP]CREDAT or ([F:AXP1]CREDAT=[F:AXP]CREDAT and [F:AXP1]CREDATTIM<[F:AXP]CREDATTIM)
         [M]AJOUR(NL)=1
       Endif
     Endif
   Endif
   If [F:AXP1]UPDDAT<>[0/0/0]
     [M]VLDDAT(NL)=[F:AXP1]UPDDAT
   Else
     [M]VLDDAT(NL)=[F:AXP1]CREDAT
   Endif
  Endif

  [M]IDTEXT(NL)=[F:AXP]UNIQIDP
  If [F:AXP]UPDDAT<>[0/0/0]
    [M]VLDDATREF(NL)=[F:AXP]UPDDAT
  Else
    [M]VLDDATREF(NL)=[F:AXP]CREDAT
  Endif

  NL+=1
Next
[M]NBLIG=NL
Filter [AXP]
Effzo[M]15-35
Call LECTEXTRA([M]INTIT1,"APROCESSUS","INTIT1",ACODPRO,"") From ATEXTRA
Affzo [M:ATD3]
Return


# Gestion du masque APRTRAD3

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD3) 03/02/2009 08:56:58 (CCORA)
######################################################################################
Subprog AM_CODPRO(VALEUR)
Variable Char    VALEUR()
Local Char ACODPRO,ACODLEG,ALAN,ALANREF
ACODPRO=VALEUR : ACODLEG=[M]CODLEG : ALAN=[M]LAN : ALANREF=[M]LANREF
Gosub CHARGE
End

Subprog AM_CODLEG(VALEUR)
Variable Char    VALEUR()
Local Char ACODPRO,ACODLEG,ALAN,ALANREF
ACODPRO=[M]CODPRO : ACODLEG=VALEUR: ALAN=[M]LAN : ALANREF=[M]LANREF
Gosub CHARGE
End

Subprog AM_LANREF(VALEUR)
Variable Char    VALEUR()
Local Char ACODPRO,ACODLEG,ALAN,ALANREF
ACODPRO=[M]CODPRO : ACODLEG=[M]CODLEG : ALAN=[M]LAN : ALANREF=VALEUR
Gosub CHARGE
If GLANGUE<>[M]LAN : [M]LANDEFV=VALEUR : Endif
End

Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
Local Char ACODPRO,ACODLEG,ALAN,ALANREF
ACODPRO=[M]CODPRO : ACODLEG=[M]CODLEG : ALAN=VALEUR : ALANREF=[M]LANREF
Gosub CHARGE
If GLANGUE=[M]LAN : [M]LANDEFV=[M]LANREF : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD3) 03/02/2009 09:07:11 (CCORA)
######################################################################################
Subprog AS_NBLIG
If clalev([F:AXP])=0  : Local File APROCTEXTE [AXP]  : Endif
Effzo [M]15
Effzo [M]30
Effzo [M]35
Read [AXP]AXP0=[M]CODPRO;[M]CODLEG;[M]LANREF;[M]IDTEXT(nolign-1)
If fstat=0
  [M]CLB1=unescJson([F:AXP]CLBTEXT) :#SAM 118755
Endif
Read [AXP]AXP0=[M]CODPRO;[M]CODLEG;[M]LAN;[M]IDTEXT(nolign-1)
If fstat=0
  [M]CLB2=unescJson([F:AXP]CLBTEXT) :#SAM 118755
Endif
[M:ATD3]VISUT="<DESC><URL><TIT></TIT>"+"<TAD>LOC</TAD>"+"<PAG><![CDATA["
If [M]ECTRA<>2
  [M:ATD3]VISUT+=[M]CLB1+']]></PAG></URL></DESC>'
  [M]ECREF=2 : [M]ECTRA=1
Else
  [M:ATD3]VISUT+=[M]CLB2+']]></PAG></URL></DESC>'
  [M]ECREF=1 : [M]ECTRA=2
Endif
[M]IDT1=[M]IDTEXT(nolign-1)
Affzo [M]15
Affzo [M]30
Affzo [M]35
Affzo [M]IDT1
Affzo ECREF,ECTRA
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD3) 03/02/2009 09:13:42 (CCORA)
######################################################################################
Subprog CL_INIT1(VALEUR)
Variable Char    VALEUR()
If [M]IDT1=""
 Infbox(mess(269,123,1))  : # Vous devez préalablement sélectionner un texte
 End
Endif
[M]CLB2=[M]CLB1
Affzo [M]30
If [M]ECTRA=2
  [M:ATD3]VISUT="<DESC><URL><TIT></TIT>"+"<TAD>LOC</TAD>"+"<PAG><![CDATA["
  [M:ATD3]VISUT+=[M]CLB2+']]></PAG></URL></DESC>'
  Affzo [M]35
Endif
End

Subprog CL_MAJ(VALEUR)
Variable Char    VALEUR()
If [M]IDT1=""
 Infbox(mess(269,123,1))  : # Vous devez préalablement sélectionner un texte
 End
Endif
If [M]CLB2=""
 Infbox(mess(270,123,1))  : # Vous devez préalablement copier le texte et le traduire
 End
Endif

If clalev([F:AXP])=0  : Local File APROCTEXTE [AXP]  : Endif
Local Integer MODENR
Local Char ABFIC : ABFIC="AXP"
Read [AXP]AXP0=[M]CODPRO;[M]CODLEG;[M]LAN;[M]IDT1
If fstat=0 : MODENR=1 : Endif

Trbegin [AXP]
[F:AXP]CODPRO=[M]CODPRO
[F:AXP]CODLEG=[M]CODLEG
[F:AXP]UNIQIDP=[M]IDT1
[F:AXP]LANG=[M]LAN
[F:AXP]CLBTEXT=escJson([M]CLB2) :#SAM 118755
If MODENR=1
  Gosub INIMOD From GOBJSUB
  Rewrite [AXP]
Else
  Gosub INICRE From GOBJSUB
  Write [AXP]
Endif
Commit

Local Char ACODPRO,ACODLEG,ALAN,ALANREF
ACODPRO=[M]CODPRO : ACODLEG=[M]CODLEG : ALAN=[M]LAN : ALANREF=[M]LANREF
Gosub CHARGE
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD3) 20/02/2009 09:50:23 (CCORA)
######################################################################################
Subprog CL_VISUREF(VALEUR)
Variable Char    VALEUR()
[M:ATD3]VISUT="<DESC><URL><TIT></TIT>"+"<TAD>LOC</TAD>"+"<PAG><![CDATA["
[M:ATD3]VISUT+=[M]CLB1+']]></PAG></URL></DESC>'
[M]IDT1=[M]IDTEXT(nolign-1)
Affzo VISUT
[M]ECREF=2
[M]ECTRA=1
Affzo ECREF,ECTRA
End

Subprog CL_VISUTRAD(VALEUR)
Variable Char    VALEUR()
[M:ATD3]VISUT="<DESC><URL><TIT></TIT>"+"<TAD>LOC</TAD>"+"<PAG><![CDATA["
[M:ATD3]VISUT+=[M]CLB2+']]></PAG></URL></DESC>'
[M]IDT1=[M]IDTEXT(nolign-1)
Affzo VISUT
[M]ECREF=1
[M]ECTRA=2
Affzo ECREF,ECTRA
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran APRTRAD3) 02/03/2009 17:17:46 (CCORA)
######################################################################################
Subprog AM_CLB2(VALEUR)
Variable Clbfile VALEUR
If [M]ECTRA=2
  [M:ATD3]VISUT="<DESC><URL><TIT></TIT>"+"<TAD>LOC</TAD>"+"<PAG><![CDATA["
  [M:ATD3]VISUT+=VALEUR+']]></PAG></URL></DESC>'
  Affzo [M]35
Endif

End


