#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 11 Mai       2015 13:53:21

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EFASRNW" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EFASRNW" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub FASRNW
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$FASRNW
 #--> Désignation
 [F:EVT0]DES        = [F:FAS]AASDES1
 #--> Menus locaux
 [F:EVT0]ISSDATRUL  = [F:RWPS]ISSDATRUL
 If G_ACTCCN=G_OUI
  [F:EVT0]RNWFLG     = [F:FAS]RNWFLG
 Endif
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:FAS]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:FAS]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:FAS]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:FAS]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:FAS]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:FAS]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:FAS]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:FAS]USRFLDC2
 If G_ACTCCN=G_OUI
  [F:EVT0]CCNTRFCAD  = GCCNTRFCAD
 Endif
 If G_ACTCCN=G_OUI
  [F:EVT0]CCNTRFGRT  = GCCNTRFGRT
 Endif
 If G_ACTCCN=G_OUI
  [F:EVT0]CCNTRFRPR  = GCCNTRFRPR
 Endif
 If G_ACTCCN=G_OUI
  [F:EVT0]CCNCADDEV  = [F:FAS]CCNCADDEV
 Endif
 If G_ACTCCN=G_OUI
  [F:EVT0]RVERPRVAL  = [F:FAS]RVERPRVAL
 Endif
 If G_ACTCCN=G_OUI
  [F:EVT0]CCNCADEXC  = [F:FAS]CCNCADEXC
 Endif
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [F:FAS]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,G301CPT)
 [F:EVT0]USRFLDA1   = [F:FAS]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:FAS]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:FAS]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:FAS]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:FAS]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:FAS]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:FAS]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:FAS]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:FAS]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:FAS]USRFLDA10
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:FAS]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:FAS]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:FAS]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:FAS]USRFLDD4
 If G_ACTCCN=G_OUI
  [F:EVT0]RNWDAT     = [F:RWPS]RNWDAT
 Endif
Return

$ECLATE_NBFLD
 LNBFLD=6
Return

$ECLATE_STATUS
  T_INTNOMZON(0)    = "CCNCADDEV"
  T_INTNOMZON(1)    = "CCNCADEXC"
  T_INTNOMZON(2)    = "CCNTRFCAD"
  T_INTNOMZON(3)    = "CCNTRFGRT"
  T_INTNOMZON(4)    = "CCNTRFRPR"
  T_INTNOMZON(5)    = "RNWVAL"
  T_INTNOMZON(6)    = "RVERPRVAL"
Return

$INFO_EVTINT
 EVT = "FASRNW"
 LPLN= 16
Return

