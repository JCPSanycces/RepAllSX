$DECLARE_ALL
Local Clbfile THIS_CLASS_STRING(2), THIS_CLASS_JSON(2), DATA, DATA_SENT
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(200)(1..10)
Local Clbfile RESHEAD(0),RESBODY(0)
Local Clbfile RESHEADRET(0), RESBODYRET(0)
Local Integer HTTP_STATUS,RETVAL,I
Local Integer MAXTEXT, MAXCOUNTER
Local Char MAINKEYFIELD(GLONAVA)
Local Char WEBSERNAME (50)
Local Char HTTPMETHOD (10)
Local Char SUBURL(255)

MAXTEXT = 250
Local Char W_MESS(MAXTEXT)
MAXCOUNTER = MAXTEXT
Return

Funprog STRINGIFYL(STRUCTURE,LEVEL)
Value Integer LEVEL
Local Clbfile CHAINE,CHAINE1
Local Char PROG(100)
Local Integer I,J,K,L,N
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".STRINGIFYL"
If dim(STRUCTURE,0)>1
End "**Error too many dimensions**"
Endif
If dim(STRUCTURE)>1
  CHAINE="[ "
  If dim(STRUCTURE)=32767
    L=maxtab(STRUCTURE)
    For I=0 To L
     If (type(STRUCTURE)=524 and STRUCTURE(I)<>null) or type(STRUCTURE)<>524 : Gosub ADD_MEMBER : Endif
     CHAINE+=string$(I<L,", ")
    Next I
  Else
    L=dim(STRUCTURE,-1)+dim(STRUCTURE,1)-1
    For I=dim(STRUCTURE,-1) To L
      Gosub ADD_MEMBER
      CHAINE+=string$(I<L,", ")
    Next I
  Endif
  CHAINE+=" ]"
Else
  I=0
  Gosub ADD_MEMBER
Endif
End CHAINE


$ADD_MEMBER
Local Char TESTME(30)
Local Integer VARTYPE
Local Char    TEXT(255)
#ASTATUS=fmet this.ASETERROR("","custom msg",[V]CST_AINFO)
Case type(STRUCTURE)
When 1,2,4,5,6,7 : CHAINE+=num$(STRUCTURE(I))
When 3 : CHAINE+= '"'+format$("D:4Y[-]MM[-]DD",STRUCTURE(I))+'"'
When 522 : K=b64Encode(STRUCTURE(I),CHAINE1) : CHAINE+= "'"+CHAINE1+"'"
When 524 : LEVEL+=1 : CHAINE+="{ "+chr$(10)+space$(3*LEVEL) : N=0 :
If(STRUCTURE(I) <> null)
K=STRUCTURE(I).ObjectNbs
For J=1 To K
  If find(STRUCTURE(I).ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN","AUUID")=0
& and ((LEVEL=1) or find(STRUCTURE(I).ObjectVar(J),"CREDATTIM","UPDDATTIM","CREUSR","UPDUSR")=0)
    Gosub GETPROP
    If STRUCTURE(I).ObjectVar(J) = "STG"
    Local Integer YY
    Endif
    CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
    CHAINE+='"'+STRUCTURE(I).ObjectVar(J)+'" :' +evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+",LEVEL)")
  Endif
Next J
Endif

LEVEL=max(LEVEL-1,0)
CHAINE+=chr$(10)+space$(3*LEVEL)+" }"
When 525,526 : CHAINE+='"'+num$(STRUCTURE(I))+'"'
When Default : CHAINE+= '"'+escJson(STRUCTURE(I))+'"'
Endcase
Return


$GETPROP
Local Integer VARTYPE
Local Char    TEXT(255)

# First evaluate the type
VARTYPE  =evalue("type(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+")")

# If not a child instance, add a line of description
If VARTYPE<>524
  If VARTYPE>10 and VARTYPE<266
    TEXT = evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))#+func IFARRAY(DIMENSION) :# "String character"
  Else
    TEXT =  "Unknown data type"
    Case VARTYPE
      When 1       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Byte"+func IFARRAY(DIMENSION)
      When 2       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Short Integer"+func IFARRAY(DIMENSION)
      When 3       : TEXT =      evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))  #"Date"+func IFARRAY(DIMENSION)
      When 4       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Integer"+func IFARRAY(DIMENSION)
      When 5       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Floating point"+func IFARRAY(DIMENSION)
      When 6       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Double floating point"+func IFARRAY(DIMENSION)
      When 7       : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Decimal value"+func IFARRAY(DIMENSION)
      When 522     : TEXT = "TODO.. Binary large object"                     #"Binary large object"+func IFARRAY(DIMENSION)
      When 523     : TEXT = "TODO.. Character large object"                  #"Character large object"+func IFARRAY(DIMENSION)
      When 525     : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Unique ID"+func IFARRAY(DIMENSION)
      When 526     : TEXT = num$(evalue("STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J))) #"Date Time"+func IFARRAY(DIMENSION)
      When 524     : TEXT = "TODO.. Class Instance"                          #"Class Instance"+func IFARRAY(DIMENSION)
      When Default : #If VARTYPE>10 and VARTYPE<266
                       #"String character ("+num$(VARTYPE)+")"+func IFARRAY(DIMENSION)
                     #Else
                       #"Unknown data type"
                    # Endif
      Endcase
    Endif
Endif
Return


Funprog RET_STRUCTURE_VAL(STRUCTURE)
End STRUCTURE

Funprog JSON_FORMSTRING(TEXT)
Variable Char TEXT
Local Integer WLEN,I

If TEXT=AVOID.ACHAR : End TEXT : Endif

If pat(TEXT,'*"*')<>0
  I = 1
  WLEN = len(TEXT)
  While I<=WLEN
    If seg$(TEXT,I,I)='"'
      TEXT = left$(TEXT,I-1)+"'"+right$(TEXT,I+1)
    Endif
    I+=1
    If pat(TEXT,'*"*')=0 : I=WLEN+1 : Endif
  Wend
Endif
End TEXT



Funprog GETTYP(STRUCTURE,PROPERTY)
Value Char PROPERTY
Local Integer VARTYPE,J,K
# First evaluate the type

If STRUCTURE <> null
  K=STRUCTURE.ObjectNbs
  For J=1 To K
    If STRUCTURE.ObjectVar(J) = PROPERTY
      VARTYPE = evalue("type(STRUCTURE."+STRUCTURE.ObjectVar(J)+")")
      Break
    Endif
  Next J
Endif
End VARTYPE




$CONVERT_PROPVAL
Case PROTYPE
  When 1       : Local Tinyint PROPVALCON     : PROPVALCON  = int(val(CONVERTED_PVALUE))  #"Byte"+func IFARRAY(DIMENSION)
  When 2       : Local Shortint PROPVALCON    : PROPVALCON  = int(val(CONVERTED_PVALUE)) #"Short Integer"+func IFARRAY(DIMENSION)
  When 3       : Local Date PROPVALCON        : PROPVALCON  = mid$(CONVERTED_PVALUE,3,2)+mid$(CONVERTED_PVALUE,6,2)+mid$(CONVERTED_PVALUE,9,2)
  When 4       : Local Shortint PROPVALCON    : PROPVALCON  = int(val(CONVERTED_PVALUE))#"Integer"+func IFARRAY(DIMENSION)
  When 5       : Local Float PROPVALCON       : ROPVALCON   = val(CONVERTED_PVALUE) #"Floating point"+func IFARRAY(DIMENSION)
  When 6       : Local Double PROPVALCON      : PROPVALCON  = val(CONVERTED_PVALUE) #"Double floating point"+func IFARRAY(DIMENSION)
  When 7       : Local Decimal PROPVALCON     : PROPVALCON  = val(CONVERTED_PVALUE) #"Decimal value"+func IFARRAY(DIMENSION)
  When Default : Local Char PROPVALCON(250)   : PROPVALCON = CONVERTED_PVALUE
Endcase
Return

Funprog CONVERTED_PVALUE_DATE(PROVALUE)
Value Char PROVALUE
Local Char CONV_VALUE(250)
#Needed format - "yymmdd"

End

