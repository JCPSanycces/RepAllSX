# Supervisor
## ACLA-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:17 381

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIXMLFIL
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_MSGFOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_TYPFIL From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_CACHEUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_ABRCLA From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_REPCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_CODACT From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_FILDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_MSGDIR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_VALID From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_FLGMUX From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_UUIDXMLTYP From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_KEYALIAS From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_KEYDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_KEYPROPERTY From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_KEYPROTOPATH From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIXMLFIL : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIXMLFIL
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIXMLFIL
Gosub LNKPRO_MSGCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub LNKPRO_MSGREL From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub LNKPRO_MSGFILNOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Gosub LNKPRO_CODACT From WMC1EDIXMLFIL : Gosub TESTALLSTAT
For AINDCLA=1 To 20
 If this.EXFN(AINDCLA)<>null& find(this.EXFN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFN(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXSD)
 If this.EXSD(AINDCLA)<>null& find(this.EXSD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXSD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFD)
 If this.EXFD(AINDCLA)<>null& find(this.EXFD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFF)
 If this.EXFF(AINDCLA)<>null& find(this.EXFF(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFF(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_KEYALIAS From WMC1EDIXMLFIL : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



