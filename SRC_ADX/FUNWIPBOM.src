#<AdxTL>@(#)6.0.0.0 $Revision$
Local File WIPCOST
Local Date LDAT
LDAT = [01/01/2009]
Trbegin [MWI]
Delete [MWI] Where TXNTYP=18 & TXNDAT>=LDAT
Update [MWI] Where RGPMWI<>""
&                & TXNDAT>=LDAT
&            With  RGPMWI=""
Commit
End

# Gestion du masque MWF1          Traitement FUNWIPMFC
# Finalisation d'en-cours BOM à partir de la table WIPCOST
# Solde des encours
##########################################################################

$ACTION
Case ACTION
 When "INIT"        Gosub INIT
 When "SETBOUT"     Gosub SETBOUT
 When "APRES_MODIF" Gosub APRES_MODIF
 When "BOUTON"      Gosub BOUTON
 When "CONTROLE"    Gosub CONTROLE
 When "OK"          Gosub ACT_OK
 When "EXEC"        Gosub EXEC
 When "SORTIE"      Gosub SORTIE
Endcase
Return

##########################################################################
$INIT
Gosub SAUV_GLOB From TRTX3GLOB

If !clalev([F:CAL])  : Local File CPTANALIN  [CAL]  : Endif
If !clalev([F:MWI])  : Local File WIPCOST    [MWI]  : Endif
If !clalev([F:MWI2]) : Local File WIPCOST    [MWI2] : Endif
If !clalev([F:MWH])  : Local File MFGWIP     [MWH]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif 
# On ouvre le masque MWF1 pour pouvoir l'utiliser dans l'action EXEC
Local Mask MWF1 [MWF1]
If !GSERVEUR
    Raz [M:MWF1]
Endif
Return

##########################################################################
$SETBOUT
If GBATCH    # Pas de bouton recherche en saisie des paramètres Batch
    Call VIREBOUT(CHMEN,"R") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
Elsif [M:MWF1]NBCRE=0 & [M:MWF1]NBDEB=0
    Call VIREBOUT(CHBOU,"O") From GOBJET
    Gosub SET_BOUT_STD From GSAISIE
Endif
Return

##########################################################################
$APRES_MODIF
If find(COUZON,"STOFCY","DATSTR","DATEND")
    Effzo [M:MWF1]10-20
    Raz [M:MWF1]NBCRE, [M:MWF1]NBDEB
Endif
Return

##########################################################################
$BOUTON
Case BOUT
    When "R" : Call REFRESH
Endcase
Return

##########################################################################
$CONTROLE
If GSTATUT=GSTAESC FIN=1 Endif
Return

##########################################################################
# Le bouton par défaut est "OK" => c'est lui qui est activé (même s'il est grisé) avec la touche "Entrée"
# Donc quand aucun tableau n'est chargé, on les charge au lieu de lancer la création des txntyp=18
# Si la fonction est lancée par batch, on n'a pas besoin de charger le tableau
$ACT_OK
If !GSERVEUR & !GBATCH & [M:MWF1]NBCRE=0 & [M:MWF1]NBDEB=0 : ## GH 17/01/12 bug 86838 ajout du test !GBATCH
    Call REFRESH
    FIN=0
Endif
Return

##########################################################################
$EXEC
Local Char SYMBOLE
SYMBOLE="FUNWIPBOM"+[M:MWF1]STOFCY
Lock =SYMBOLE With lockwait = 0
If fstat
    Call ERREUR(mess(234,188,1)) From GESECRAN
    Return
Endif

Local Char    LMWHNUM(GLONVCR)
Local Integer LTRKTYP
Local Integer LOUVTRC
Local Char    LCCE(GLONCCE)

If [M:MWF1]DATEND=[0/0/0]
    [M:MWF1]DATEND = date$
Endif

If GTRACE=""
    Call OUVRE_TRACE(mess(7,344,1)) From LECFIC
    LOUVTRC=1
Endif

Call ECR_TRACE([M:MWF1]STOFCY-num$([M:MWF1]DATSTR)-num$([M:MWF1]DATEND),0) From GESECRAN

For LTRKTYP=2 To 3
    Raz LMWHNUM
    Trbegin [MWI]
    Link [MWI2] With [MWH]MWH0=37;[MWI2]VCRNUM
&              As [LNK]
&              Where [M:MWF1]DATSTR<=[MWI2]TXNDAT & [MWI2]TXNDAT<=[M:MWF1]DATEND
&                  & [MWI2]MFGFCY = [M:MWF1]STOFCY
&                  & [MWI2]RGPMWI = ""
&                  & [MWH]TRKTYP = LTRKTYP

    For [LNK]
        If dim(GMWHBOMEXI)>0 & GMWHBOMEXI=2
            Raz [F:MWH]VCRNUM
            Filter [MWH] Where MFGFCY=[M:MWF1]STOFCY
&                            & STRDAT<=[M:MWF1]DATSTR
&                            & ENDDAT>=[M:MWF1]DATEND
            Read [MWH] First
            Filter [MWH]
            LMWHNUM=[F:MWH]VCRNUM
        Endif
        If LMWHNUM=""
            LMWHNUM = func GETMWHNUM([M:MWF1]STOFCY,[M:MWF1]DATSTR,[M:MWF1]DATEND,[F:MWI]TXNDAT,LTRKTYP)
        Endif
        If LMWHNUM<>""
            Filter [MWI] Where VCRTYP=37
&                            & VCRNUM=LMWHNUM
&                            & TXNTYP=18
&                            & GLPSTA<>2
            Read [MWI] First
            Filter [MWI]
            If fstat
                Raz [F:MWI]
                [F:MWI]VCRTYP = 37
                [F:MWI]VCRNUM = LMWHNUM
                [F:MWI]VCRNUM = LMWHNUM
                [F:MWI]MFGFCY = [M:MWF1]STOFCY
                [F:MWI]TXNTYP = 18
                [F:MWI]TXNDAT = date$
                [F:MWI]AMOUNT = -[F:MWI2]AMOUNT
                Gosub ALI_CSTELM
                [F:MWI]RGPMWI = LMWHNUM
                [F:MWI]ENTCOD    = GACCWIPENT 
                [F:MWI]GLPSTA    = 1
                Call ECR_MWI From MWIPLIB
            Else
                [F:MWI]AMOUNT -= [F:MWI2]AMOUNT
                Gosub ALI_CSTELM
                [F:MWI]UPDUSR = GUSER
                [F:MWI]UPDDAT = date$
                [F:MWI]RGPMWI = LMWHNUM
                Rewrite [MWI]
            Endif
            Call ECR_TRACE(LMWHNUM-":"-string$(sgn(-[F:MWI2]AMOUNT)>=0,"+")+num$(-[F:MWI2]AMOUNT)-"("-[F:MWI2]VCRNUM-[F:MWI2]MFGTRKNUM-num$([F:MWI2]MFGTRKLIN)-mess([F:MWI2]TXNTYP,2358,1)-")",0)
&                From GESECRAN
            Update [MWI] Where VCRTYP=37
&                            & VCRNUM=[F:MWI2]VCRNUM
&                            & TXNTYP=[F:MWI2]TXNTYP
&                            & WIPSEQ=[F:MWI2]WIPSEQ
&                        With RGPMWI = LMWHNUM
        Endif
    Next
    Commit
Next

Unlock =SYMBOLE

If LOUVTRC
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

Raz [M:MWF1]
If !GSERVEUR
    SAI=1
Endif
Return

##########################################################################
$ALI_CSTELM
    Case [F:MWI2]TXNTYP
        When 1 : [F:MWI]CSTELM(4) -= [F:MWI2]AMOUNT
        When 2 : [F:MWI]CSTELM(5) -= [F:MWI2]AMOUNT
        When 3 : [F:MWI]CSTELM(6) -= [F:MWI2]AMOUNT
        When 4 : [F:MWI]CSTELM(7) -= [F:MWI2]AMOUNT
        When 5,6,7,8 : [F:MWI]CSTELM(8) -= [F:MWI2]AMOUNT
        When 14 : If [F:MWI2]ITMTYP=2
                    [F:MWI]CSTELM(4) -= [F:MWI2]AMOUNT
                  Else
                    [F:MWI]CSTELM(4) -= [F:MWI2]CSTELM(0)
                    [F:MWI]CSTELM(5) -= [F:MWI2]CSTELM(1)
                    [F:MWI]CSTELM(6) -= [F:MWI2]CSTELM(2)
                    [F:MWI]CSTELM(7) -= [F:MWI2]CSTELM(3)
                    [F:MWI]CSTELM(8) -= sum([F:MWI2]CSTELM(4..7))
                  Endif
    Endcase
    If [F:MWI2]TXNTYP=14 & [F:MWI2]ITMTYP<>2
        [F:MWI]CSTELM(1) -= [F:MWI2]AMOUNT
    Else
        [F:MWI]CSTELM(0) -= [F:MWI2]AMOUNT    # Dépense totale
    Endif

Return

##########################################################################
$SORTIE
Gosub REST_GLOB From TRTX3GLOB
Return

##########################################################################
Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
If [M:MWF1]STOFCY=""
    Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
    VALEUR = GFCY
Endif
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# charger les éventuels paramètres de niveau site
Call GLOBVAR(VALEUR)    From WWGLOBGPA
End


##########################################################################
Subprog C_DATSTR(VALEUR)
Variable Date    VALEUR
    If VALEUR>date$
        GMESSAGE = mess(60,192,1)
        mkstat=2
    Endif
End

##########################################################################
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
    If VALEUR<>[0/0/0] & VALEUR<[M:MWF1]DATSTR
        GMESSAGE = mess(90,121,1)
        mkstat=2
    Endif
    If VALEUR>date$
        GMESSAGE = mess(60,192,1)
        mkstat=2
    Endif
End

##########################################################################
Subprog REFRESH
Local Date LDATSTR, LDATEND

Effzo [M:MWF1]10-99

LDATSTR=[M:MWF1]DATSTR
If [M:MWF1]DATEND=[0/0/0]
    LDATEND=date$
Else
    LDATEND=[M:MWF1]DATEND
Endif
Link [MWI] With [MWH]MWH0=37;[MWI]VCRNUM
&          As [LNK]
&          Where LDATSTR<=[MWI]TXNDAT & [MWI]TXNDAT<=LDATEND
&              & [MWI]MFGFCY = [M:MWF1]STOFCY
&              & [MWI]RGPMWI = ""
&              & [MWH]TRKTYP>1
For [LNK]
    If [MWI]TXNTYP<9
        If [M:MWF1]NBDEB<dim([M:MWF1]MFGNUMD)
            [M:MWF1]MFGNUMD([M:MWF1]NBDEB)    = [F:MWI]VCRNUM
            [M:MWF1]TXNTYPD([M:MWF1]NBDEB)    = [F:MWI]TXNTYP
            [M:MWF1]ITMREFD([M:MWF1]NBDEB)    = [F:MWI]ITMREF
            [M:MWF1]WSTD([M:MWF1]NBDEB)       = [F:MWI]WST
            [M:MWF1]TXNACTD([M:MWF1]NBDEB)    = [F:MWI]TXNACT
            [M:MWF1]TXNDATD([M:MWF1]NBDEB)    = [F:MWI]TXNDAT
            [M:MWF1]QTYD([M:MWF1]NBDEB)       = [F:MWI]QTY
            [M:MWF1]STUD([M:MWF1]NBDEB)       = [F:MWI]STU
            [M:MWF1]AMOUNTD([M:MWF1]NBDEB)    = [F:MWI]AMOUNT
            [M:MWF1]CPLSETTIMD([M:MWF1]NBDEB) = [F:MWI]CPLSETTIM
            [M:MWF1]CPLOPETIMD([M:MWF1]NBDEB) = [F:MWI]CPLOPETIM
            [M:MWF1]EMPNUMD([M:MWF1]NBDEB)    = [F:MWI]EMPNUM
            [M:MWF1]MFGTRKNUMD([M:MWF1]NBDEB) = [F:MWI]MFGTRKNUM
            [M:MWF1]MFGTRKLIND([M:MWF1]NBDEB) = [F:MWI]MFGTRKLIN
            [M:MWF1]NBDEB+=1
        Endif
    Else
        If [M:MWF1]NBCRE<dim([M:MWF1]MFGNUMC)
            [M:MWF1]MFGNUMC([M:MWF1]NBCRE)    = [F:MWI]VCRNUM
            [M:MWF1]TXNTYPC([M:MWF1]NBCRE)    = [F:MWI]TXNTYP
            [M:MWF1]ITMREFC([M:MWF1]NBCRE)    = [F:MWI]ITMREF
            [M:MWF1]TXNACTC([M:MWF1]NBCRE)    = [F:MWI]TXNACT
            [M:MWF1]TXNDATC([M:MWF1]NBCRE)    = [F:MWI]TXNDAT
            [M:MWF1]QTYC([M:MWF1]NBCRE)       = [F:MWI]QTY
            [M:MWF1]STUC([M:MWF1]NBCRE)       = [F:MWI]STU
            [M:MWF1]AMOUNTC([M:MWF1]NBCRE)    = [F:MWI]AMOUNT
            [M:MWF1]MFGTRKNUMC([M:MWF1]NBCRE) = [F:MWI]MFGTRKNUM
            [M:MWF1]MFGTRKLIND([M:MWF1]NBCRE) = [F:MWI]MFGTRKLIN
            [M:MWF1]OVENAT([M:MWF1]NBCRE)     = [F:MWI]OVENAT
            [M:MWF1]NBCRE+=1
        Endif
    Endif
#    If [M:MWF1]NBDEB>=dim([M:MWF1]MFGNUMD) & [M:MWF1]NBCRE>=dim([M:MWF1]MFGNUMC)
#        Break
#    Endif
    [M:MWF1]ECART+=[F:MWI]AMOUNT
Next
Affzo [M:MWF1]
End

###################################################################################
Funprog GETMWHNUM(PFCY,PDATSTR,PDATEND,PDAT,PTRKTYP)
Value Char PFCY         # FGR 01/02/2010 : X3SUIVI60986
Value Date PDATSTR      # FGR 01/02/2010 : X3SUIVI60986
Value Date PDATEND      # FGR 01/02/2010 : X3SUIVI60986
Value Date PDAT         # FGR 01/02/2010 : X3SUIVI60986
Value Integer PTRKTYP   # FGR 01/02/2010 : X3SUIVI60986

Local Char    LMWHNUM(GLONVCR)
Local Integer ERR, WOK

# nouveau chrono (compteur 'MWH')   # Récupération du compteur :
# V6 09/2008 Call LECTCA(8,WOK) From SUBTCA
#If WOK=0 
#    ERR = 5
#    Raz [F:TCA] 
#Else
#    Call NUMERO([F:TCA]CODNUM(6),PFCY,date$,"",LMWHNUM,ERR) From SUBANM
#Endif
Call NUMERO(8,6,"",PFCY,date$,"",LMWHNUM,ERR) From TRTX3TCA
If ERR=0
    Raz [F:MWH]
    [F:MWH]VCRTYP    = 37
    [F:MWH]VCRNUM    = LMWHNUM  # nouveau compteur
    [F:MWH]MFGFCY    = [M:MWF1]STOFCY
    [F:MWH]STRDAT    = [M:MWF1]DATSTR
    [F:MWH]ENDDAT    = [M:MWF1]DATEND
    [F:MWH]TRKTYP    = PTRKTYP
    [F:MWH]CREUSR    = GUSER
    [F:MWH]CREDAT    = date$
    [F:MWH]UPDUSR    = ""
    [F:MWH]UPDDAT    = [0/0/0]
    [F:MWH]EXPNUM    = [C]EXPORT        
    Write [MWH]
    If fstat 
        Call FSTA("MWH") From GLOCK
        GOK = 0
    Endif
#Else
#    Gosub MESSAGE
Endif
End LMWHNUM

# Message d'erreurs gestion des compteurs (GMESSAGE est exploité au retour)
# V6 09/2008 déjà fait dans NUMERO ... From TRTX3TCA
# $MESSAGE
# Case ERR
#  When 1  : GMESSAGE = mess(12,114,1)  : # Compteur inexistant
#  When 2  : GMESSAGE = mess(13,114,1)  : # Dépassement de compteur
#  When 3  : GMESSAGE = mess(20,101,1)  : # Exercice non ouvert
#  When 4  : GMESSAGE = mess(111,123,1) : # Longueur incorrecte
#  When 5  : GMESSAGE = mess(64,199,1)  : # aucun compteur n'est affecté à ce document
#  When 99 : GMESSAGE = mess(135,133,1) : # Compteur verrouillé
# Endcase
# GMESSAGE += " ("+[F:TCA]CODNUM(6)+")"
# Return


