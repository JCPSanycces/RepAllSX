#<AdxTL>@(#)10.0.0.0 $Revision$
End
#########################################################################
#  SIXCPY : pour traitements de bascule Integrale --> X3                #
#    Intégrale => XXSOC (SOC,SOC_DIV_1,SOC_DIV_2,SOC_DIV_3)             #
#########################################################################
#                                                                       #
# Subprog SIXCPY                                                        #
#     Création de la société (avec MAJ Adresse)                         #
#     Création des périodes/exercices comptables                        #
#     Création de la société DAS (non fait)                             #
#     Initialiser la X3DAT de la table XIHISCBGNR et X3HISANA           # 
#                                                                       #
#     Mise à jour du paramètre CRYDEF                                   #
#     Mise à jour de la variable globale GPAYS                          #
#                                                                       #
#     Mise à jour du paramètre SYSCUR                                   #
#     Mise à jour de la variable globale GSYSCUR                        #
#                                                                       #
#     Init des tables Sociétés/Sites                                    #
#     Init des table des reports à nouveaux                             #    
#                                                                       #
# --------------------------------------------------------------------- #
# PRE-REQUIS :                                                          #
# --------------------------------------------------------------------- #
#     1 - Migrations précédentes : Pays, Devises                        #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################
# Supp...
If !clalev([F:CPY])  : Local File COMPANY     [CPY]  : Endif   # Société
If !clalev([F:AGC])  : Local File AGRPCPY     [AGC]  : Endif   # Groupe de société
If !clalev([F:AGF])  : Local File AGRPFCY     [AGF]  : Endif   # Groupe de sites
If !clalev([F:BPA])  : Local File BPADDRESS   [BPA]  : Endif   # Adresses
If !clalev([F:FIY])  : Local File FISCALYEAR  [FIY]  : Endif   # Exercices
If !clalev([F:PER])  : Local File PERIOD      [PER]  : Endif   # Périodes
If !clalev([F:IDP])  : Local File INVDACPAR   [IDP]  : Endif   # Paramétrage saisie fact. tiers

If !clalev([F:XSOC]) : Local File XISOC       [XSOC] : Endif   # Société Intégrale
If !clalev([F:XHCB]) : Local File XIHISCBGNR  [XHCB] : Endif   # Historique général
If !clalev([F:XHAN]) : Local File XIHISANA    [XHAN] : Endif   # Historique analytique
If !clalev([F:XBCB]) : Local File XIBROCBGNR  [XBCB] : Endif   # Brouillard général
If !clalev([F:XBAN]) : Local File XIBROCBANA  [XBAN] : Endif   # Brouillard analytique


Trbegin [CPY], [AGC], [AGF], [BPA], [FIY], [PER], [IDP], [XSOC], [XHCB],[XHAN]
Delete [CPY]  Where 1=1
Delete [AGC]  Where 1=1
Delete [AGF]  Where 1=1
Delete [BPA]  Where BPATYP=2
Delete [FIY]  Where 1=1
Delete [PER]  Where 1=1
Delete [IDP]  Where 1=1
Update [XSOC] Where 1=1 With FLGREP=1
Update [XHCB] Where 1=1 With X3DAT=[0/0/0]
Update [XHAN] Where 1=1 With X3DAT=[0/0/0]
Update [XBCB] Where 1=1 With X3DAT=[0/0/0]
Update [XBAN] Where 1=1 With X3DAT=[0/0/0]
Commit 
# Fin Supp

Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("XISOC",1) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC
Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXCPY : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#########################################################################
#########################################################################
#########################################################################
# ATTENTION
#########################################################################
#########################################################################
#########################################################################
#########################################################################
# Suppression des sociétés impossible sous GX3APP
#########################################################################
If SI_DOSSIER="GX3APP" 
 Call ECR_TRACE(SI_DOSSIER,-1) From GESECRAN
 End 
Endif

#--- Nouveau contrôle... Demande
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
Read [XSOC]  First
If !fstat & [F:XSOC]FLGREP=2 : End : Endif

#--- Contrôle du paramétrage
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX]  First
If [F:SPX]ACM=""
 # Modèle comptable inexistant - Paramètre non défini
 Call ECR_TRACE(mess(198,105,1)-":"-mess(141,105,1),1) From GESECRAN : End
Endif

#----  Suppression des informations du dossier de référence sur la société ------#
Call DELETE_COMPANY
If GOK<>1 : Goto FIN_CPY : Endif

#----  Migration de la société : COMPANY  ------#
Call ECR_TIME("SIXCPY : "+SI_MES(48)-"COMPANY") From DOSSUB
Call SI_COMPANY
If GOK<>1 : Goto FIN_CPY : Endif

#----  Initialisation X3DAT               ------#
#----    Tables XIHISCBGNR, XIHISANA, XIBROCBGNR, XIBROCBANA                     
Gosub INI_X3DAT
If GOK<=0 : Goto FIN : Endif

#----  Initialisation INISOC               ------#
Call INISOC From GLOBSUP
If GOK<=0 : Goto FIN : Endif

#----  Table des reports à nouveaux               ------#
Call EXEAN  From GLOBCPT

#----  Initialisation Variables globales          ------#
Call GLOBVAR From SETGLBGCM

$FIN_CPY
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Création de la société
#########################################################################
Subprog SI_COMPANY

If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
If !clalev([F:XSO1]) : Local File =SI_DOSSIER+".XISOCDIV1"  [XSO1] : Endif   # Société Intégrale
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Société Intégrale
If !clalev([F:XSO3]) : Local File =SI_DOSSIER+".XISOCDIV3"  [XSO3] : Endif   # Société Intégrale

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
If !clalev([F:AGC])  : Local File =SI_DOSSIER+".AGRPCPY"    [AGC]  : Endif   # Groupe de société
If !clalev([F:AGF])  : Local File =SI_DOSSIER+".AGRPFCY"    [AGF]  : Endif   # Groupe de sites

If !clalev([F:DCP])  : Local File =SI_DOSSIER+".DADCPY"     [DCP]  : Endif   # Société DADS X3
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif    # Codes comptables

If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA]  : Endif   # Adresses

If !clalev([F:FIY])  : Local File =SI_DOSSIER+".FISCALYEAR" [FIY]  : Endif   # Exercices
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"     [PER]  : Endif   # Périodes

If !clalev([F:ADW])  : Local File =SI_DOSSIER+".ADOVAL"     [ADW]  : Endif   # Variable globale
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 

If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable
If !clalev([F:LED])  : Local File =SI_DOSSIER+".GLED"       [LED]  : Endif   # Référentiel

SI_SUBPRG = "SIXCPY"
SI_TABLE  = "XISOC"
Gosub SI_CRITSUP From SIXFONCTION

# creation Société (COMPANY)
Read [XSOC]  First
If [F:XSOC]FLGREP=2 : End : Endif
Read [XSO1] First
Read [XSO2] First
Read [XSO3] First

Call DEBTRANS From GLOCK
Trbegin [CPY], [AGC], [XSOC], [ADW], [LED]
GOK = 1
Gosub CRE_SOC
If GOK<=0 : Goto FIN : Endif

# creation Groupe de société/site (AGRPCPY/AGRPFCY)
Gosub CRE_AGRP
If GOK<=0 : Goto FIN : Endif

# creation adresse (BPADDRESS)
Gosub CRE_BPA 
If GOK<=0 : Goto FIN : Endif

# creation période (FISCALYEAR/PERIOD)
Gosub CRE_PER
If GOK<=0 : Goto FIN : Endif

# creation société DAS (DADCPY)
If GMODU(2)=2  :# Compta
 If func AFNC.ACTIV("CPT") & func AFNC.ACTIV("DAS")    
  Gosub CRE_DCP
  If GOK<=0 : Goto FIN : Endif
 Endif
Endif

# création des transactions de factures tiers
If GMODU(2)=2  :# Compta
 If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable
 If !clalev([F:IDP])  : Local File =SI_DOSSIER+".INVDACPAR"  [IDP]  : Endif   # Paramétrage saisie fact. tiers
 Call CREIDP([F:CPY]CPY,[F:CPY]ACM) From SUBIDP
Endif

# création des axes anaytiques X3
Gosub SI_AXI from SIXCCE

Local Integer NBRAXE, AXE
Call NBAXE(NBRAXE) From SIXCCE
For AXE=0 To dim([F:CPY]DIE)-1
  [F:CPY]DIE(AXE) = ""
  [F:CPY]CCE(AXE) = ""
  [F:CPY]OBYDIE(AXE) = 0
  [F:CPY]DACDIE(AXE) = 0
Next
For AXE=1 To NBRAXE
 If AXE<dim([F:CPY]DIE)
  [F:CPY]DIE(AXE-1) = "AX"+num$(AXE)
  [F:CPY]CCE(AXE-1) = ""
  [F:CPY]OBYDIE(AXE-1) = 1
  [F:CPY]DACDIE(AXE-1) = 1
 Endif
Next
Rewrite [CPY]
If fstat
 # Société... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif

# Mise à jour du référentiel analytique.
Local Char COAANA(GLONCOA)
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

Read [LED]LED0 = [L]COAANA
If !fstat
 [F:LED]DIENBR = NBRAXE
 For AXE = 1 To NBRAXE
  [F:LED]DIE(AXE-1) = "AX"+num$(AXE)
 Next
 Rewrite [LED]
 If fstat
  # Référentiel... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(208,111,1)-[F:SPX]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

Readlock [XSOC] Curr
[F:XSOC]FLGREP = 2
Rewrite [XSOC]

$FIN
If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_SOC
Raz [F:CPY]

Call AFFBOITE(num$([F:XSOC]CODSOC)) From SUBSIM

# recuperation et controle code société
If !func SIXFONCTION.SI_CTL("CPY",[F:XSOC]X3CLE,"XISOC ("+num$([F:XSOC]CODSOC)+")")
 GOK=0 : Return
Else
 [F:CPY]CPY    = [F:XSOC]X3CLE
Endif
[F:CPY]BPAADD  = "001"

# Données initialiées par la fonction de paramètrage
#-------------------------------------------------
Read [SPX]  First
[F:CPY]MAIFCY  = [F:SPX]FCY       # Site principal

# Données initialiées par les tables de l'Intégrale
#-------------------------------------------------
[F:CPY]CPYNAM    = [F:XSOC]RSC

If [F:XSOC]CODPAY <> ""
 [F:CPY]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XSOC]CODPAY,"TABCOUNTRY",mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")")
 Gosub MAJ_CRY 
 If GOK<1 : Return : Endif
Endif  

[F:CPY]CRN    = vireblc([F:XSOC]NUMSIRET,4)     # Numéro de SIRET
[F:CPY]NAF    = [F:XSOC]CODAPE                  # Code NAF (X3) = Code APE (Intégrale)
[F:CPY]EECNUM = [F:XSO1]NUMIDETVA               # Identificateur CEE (X3) =  Identification TVA (Intégrale)

If [F:XSOC]DVSIPC <> ""    # Devise implicite (Intégrale) <=> Devise comptable (X3)
 [F:CPY]ACCCUR = func SIXFONCTION.SI_COR("XIDVS",[F:XSOC]DVSIPC,"TABCUR",mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")")
 Gosub MAJ_CUR
 If GOK<1 : Return : Endif
 [F:CPY]RGCCUR    = [F:CPY]ACCCUR     # Devise 'Social'
 [F:CPY]RGCAMT    = [F:XSO3]CPS       # Capital Social
Endif  

# Données initialiées par défaut
#-------------------------------------------------
[F:CPY]LEG = GDOSLEG
[F:CPY]CPYLEGFLG = 2

Read [GCM]GCM0 = [F:SPX]ACM
If !fstat
 Call INITACCCOD_LED([F:CPY]ACCCOD,[F:GCM]LED([F:GCM]GENLEDTYP-1),[V]GCACCPY) From SITSIG
Endif

# Date du premier exercice
#-------------------------------------------------
[F:CPY]STRPER  = [F:SPX]STRPER 
[F:CPY]ACM     = [F:SPX]ACM

# Dates et utilisateurs
#-------------------------------------------------
[F:CPY]CREDAT   = date$
[F:CPY]CREUSR   = GUSER              
[F:CPY]UPDDAT   = date$   
[F:CPY]UPDUSR   = GUSER   

SI_TABLE = "COMPANY"
Gosub SI_BEFWRI From SIXFONCTION

Write [CPY]
If fstat
 # Société... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
Return

########
$MAJ_CRY
Readlock [ADW]ADW0 = "";"";"CRYDEF"
If fstat
 Raz [F:ADW]
 [F:ADW]PARAM  = "CRYDEF"
 [F:ADW]VALEUR = [F:CPY]CRY
 Write [ADW]
Else
 [F:ADW]VALEUR = [F:CPY]CRY
 Rewrite [ADW]
Endif
If fstat
 # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(28,71,1)-"CRYDEF"-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Return
Endif
Call PARAM("","CRYDEF",GPAYS) From ADOVAL
Return

########
$MAJ_CUR
Readlock [ADW]ADW0 = "";"";"SYSCUR"
If fstat
 Raz [F:ADW]
 [F:ADW]PARAM  = "SYSCUR"
 [F:ADW]VALEUR = [F:CPY]ACCCUR
 Write [ADW]
Else
 [F:ADW]VALEUR = [F:CPY]ACCCUR
 Rewrite [ADW]
Endif
If fstat
 # Anomalie mise à jour paramètre    ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(28,71,1)-"SYSCUR"-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Return
Endif
Call PARAM("","SYSCUR",GSYSCUR) From ADOVAL
Return


##################################################################
#  Creation AGRPCPY/AGRPFCY
##################################################################
$CRE_AGRP
Raz [F:AGC]

[F:AGC]GRP = [F:CPY]CPY
[F:AGC]CPY = [F:CPY]CPY

Write [AGC]
If fstat
 # Société ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif

Raz [F:AGF]
[F:AGF]GRP    = [F:CPY]CPY
[F:AGF]DES    = [F:CPY]CPYNAM
[F:AGF]SHO    = [F:CPY]CPYSHO
[F:AGF]FLGCPY = [F:CPY]CPYLEGFLG
[F:AGF]FLGLEG = [F:CPY]CPYLEGFLG
[F:AGF]CREDAT = [F:CPY]CREDAT
[F:AGF]CREUSR = [F:CPY]CREUSR
[F:AGF]CRETIM = time
Write [AGF]
If fstat
 # Société ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
Return

##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Integer LEXI : Raz LEXI
Local Char LBPAADD(3)
If dim([F:CPY]BPAADD) > 0   & [F:CPY]BPAADD<>""
   LBPAADD    = [F:CPY]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPA]BPA0 = 2;[F:CPY]CPY;LBPAADD
If fstat <> 0
 Readlock [BPA]BPA0=2;[F:CPY]CPY;LBPAADD
 If fstat
  Raz [F:BPA]
  Raz LEXI
 Else
  LEXI = 1
 Endif
 
 # Rubriques reprises de l'Integrale
 [F:BPA]BPAADDLIG (0) =  [F:XSOC]ADRLIG1   # Ligne adresse 1
 [F:BPA]BPAADDLIG (1) =  [F:XSOC]ADRLIG2   # Ligne adresse 2
 [F:BPA]BPAADDLIG (2) =  [F:XSOC]ADRLIG3   # Ligne adresse 3
 [F:BPA]POSCOD        =  [F:XSOC]CODPST    # Code postal     
 [F:BPA]CTY           =  [F:XSOC]VIL       # Ville           
 [F:BPA]WEB           =  [F:XSO3]ADRMAI    # Adresse internet

 Call NUMONLY([F:XSOC]TEL,[F:BPA]TEL) From SIXFONCTION    # Téléphone
 Call NUMONLY([F:XSOC]TLC,[F:BPA]FAX) From SIXFONCTION    # Fax

 # Code pays 
 If [F:XSOC]CODPAY <> ""
  [F:BPA]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XSOC]CODPAY,"TABCOUNTRY",mess(2,45,1)-[F:CPY]CPY-"("+num$([F:XSOC]CODSOC)+")")
 Endif  
 # Nom pays
 If [F:BPA]CRY <> "" 
  Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
 Endif

 # Rubriques reprises du client X3
 [F:BPA]BPATYP    = 2                      # Type entité
 [F:BPA]BPANUM    = [F:CPY]CPY             # Entité
 [F:BPA]BPAADD    = LBPAADD                # Adresse 
 [F:BPA]CREDAT    = [F:CPY]CREDAT          # Date création
 [F:BPA]CREUSR    = [F:CPY]CREUSR          # Opérateur création
 [F:BPA]UPDDAT    = [F:CPY]UPDDAT          # Date modification
 [F:BPA]UPDUSR    = [F:CPY]UPDUSR          # Opérateur modification
 
 # Rubriques par defaut 
 [F:BPA]BPAADDFLG = 2                      # Par défaut
 [F:BPA]CRETIM    = time                   # Heure
 [F:BPA]UPDTIM    = time                   # Heure

 # Maj
 If LEXI
  [F:BPA]UPDDAT = date$ 
  [F:BPA]UPDUSR = GUSE  
  [F:BPA]UPDTIM = time                   # Heure
  Rewrite [BPA]
 Else
  SI_TABLE = "BPADDRESS"
  Gosub SI_BEFWRI From SIXFONCTION
  Write [BPA]
  If fstat
  # Adresse ... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(33,102,1)-[F:CPY]CPY-"("+[F:XSOC]SOC+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0
  Endif
 Endif
Endif
Return

##################################################################
#  Creation FISCALYEAR/PERIOD
##################################################################
$CRE_PER 
Local Integer NBEXE     : # Compteur nombre d'exercices créés
Local Integer PERMAX    : # Période maxi selon le code activité PER
Local Integer FLAG      : # Indicateur si la table "Périodicité Comptable" est vide ou non vide

If !clalev([F:ACV]) : Local File =SI_DOSSIER+".ACTIV"     [ACV] : Endif
Read [ACV]CODACT = "PER"
If !fstat : PERMAX = min(12,[F:ACV]DIME) : Endif

If !clalev([F:XPC]) : Local File =SI_DOSSIER+".XIPRDCTB"  [XPC] : Endif   # Période comptable

If nbrecord([F:XPC])>0
 FLAG = 0
Else
 FLAG = 1
Endif

# Intégrale ne gère que 3 exercices... 
Raz NBEXE 
If [F:XSOC]DEBEXCN2=[F:CPY]STRPER
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN2,[F:XSOC]FINEXCN2,FLAG,[F:XSOC]NBRMOIEXCN2,PERMAX,[F:XSOC]ETAEXCN2,3)
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN1,[F:XSOC]FINEXCN1,FLAG,[F:XSOC]NBRMOIEXCN1,PERMAX,[F:XSOC]ETAEXCN1,2)
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN,[F:XSOC]FINEXCN,FLAG,[F:XSOC]NBRMOIEXCN,PERMAX,[F:XSOC]ETAEXCN,1)
Elsif [F:XSOC]DEBEXCN1=[F:CPY]STRPER
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN1,[F:XSOC]FINEXCN1,FLAG,[F:XSOC]NBRMOIEXCN1,PERMAX,[F:XSOC]ETAEXCN1,2)
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN,[F:XSOC]FINEXCN,FLAG,[F:XSOC]NBRMOIEXCN,PERMAX,[F:XSOC]ETAEXCN,1)
Elsif [F:XSOC]DEBEXCN=[F:CPY]STRPER
 NBEXE+=1 : Call CRE_EXE([F:CPY]CPY,NBEXE,[F:XSOC]DEBEXCN,[F:XSOC]FINEXCN,FLAG,[F:XSOC]NBRMOIEXCN,PERMAX,[F:XSOC]ETAEXCN,1)
Endif
Return


Subprog CRE_EXE(CPY,EXE,DATSTR,DATEND,FLG,NBPER,MAXPER,STATUT,NOPER)
Value Char    CPY()
Value Integer EXE
Value Date    DATSTR
Value Date    DATEND
Value Integer FLG
Value Integer NBPER
Value Integer MAXPER
Value Char    STATUT
Value Integer NOPER

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable
If !clalev([F:FIY])  : Local File =SI_DOSSIER+".FISCALYEAR" [FIY]  : Endif   # Exercices
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"     [PER]  : Endif   # Périodes

If !clalev([F:XPC])  : Local File =SI_DOSSIER+".XIPRDCTB"   [XPC]  : Endif   # Période comptable

Local Integer PERIO
Local Integer STA
Local Integer NBREF

#Demande 47698 : Les périodes sont ouvertes !!
#If [L]STATUT='O' or [L]STATUT='G'
 [L]STA = 2
#Else
# [L]STA = 3
#Endif

Read [CPY]CPY0=[L]CPY
Read [GCM]GCM0=[CPY]ACM

# pour tous les types de référentiels
For NBREF=1 To len(mess(0,2644,1))
 If [F:GCM]LED(NBREF-1)<>""
  Raz [FIY]   
  [F:FIY]CPY    = [L]CPY
  [F:FIY]LEDTYP = NBREF
  [F:FIY]FIYNUM = [L]EXE
  [F:FIY]FIYSTR = [L]DATSTR
  [F:FIY]FIYEND = [L]DATEND
  [F:FIY]FIYSTA = 2
  If year([L]DATSTR)=year([L]DATEND)
   [F:FIY]DES = mess(10,47,1)-num$(year([L]DATEND)) # Exercice
   [F:FIY]DESSHO = num$(year([L]DATEND))
  Endif 
  [F:FIY]CREDAT = date$
  [F:FIY]CREUSR = GUSER
  If [F:GCM]CFMAUT(NBREF-1) = 2 : [F:FIY]LEDTYPAUT = 2 : Endif
  Write [FIY] 
  If fstat
   GOK=0 : Call FSTA("FIY") From GLOCK
  Endif
  If GOK<1 : End : Endif

  If [L]FLG
   # Table des périodicités vides => période défini sur le mois calendaire
   For PERIO=1 To [L]NBPER
    Raz [PER]
    [F:PER]CPY       = [L]CPY
    [F:PER]LEDTYP    = NBREF
    [F:PER]FIYNUM    = [L]EXE
    [F:PER]PERNUM    = PERIO
    [F:PER]PERSTA    = [L]STA
    [F:PER]PERSTOSTA = 1
    [F:PER]PERSTR = addmonth([F:FIY]FIYSTR,PERIO-1)
    # <PP 07/05/07> La date de fin de la douzième période de chaque exercice était erronée
    #If PERIO=MAXPER
    If PERIO=[L]NBPER
     [F:PER]PEREND = [F:FIY]FIYEND
    Else
     [F:PER]PEREND = addmonth([F:FIY]FIYSTR,PERIO)-1
    Endif
    [F:PER]LEDTYPAUT = [F:FIY]LEDTYPAUT
    Write [PER]
    If fstat
     GOK=0 : Call FSTA("PER") From GLOCK : Break 1
    Endif
   Next PERIO
  Else
   Raz PERIO
   # Table des périodicités non vides => récupération des périodes
   For [XPC] Where CODEXC=[L]NOPER
    Raz [PER]
    PERIO+=1
    [F:PER]CPY       = [L]CPY
    [F:PER]LEDTYP    = NBREF
    [F:PER]FIYNUM    = [L]EXE
    [F:PER]PERNUM    = PERIO 
    [F:PER]PERSTA    = [L]STA
    [F:PER]PERSTOSTA = 1
    [F:PER]PERSTR = [F:XPC]DEBPRD
    [F:PER]PEREND = [F:XPC]FINPRD
    Write [PER]
    If fstat
     GOK=0 : Call FSTA("PER") From GLOCK : Break 1
    Endif
   Next PERIO
  Endif
 Endif
Next NBREF
End

$CRE_DCP
Return

Subprog C_STRPER(VALEUR)
Variable Date    VALEUR
Local Char FIYSTA(1)
If !clalev([F:XSOC]) : Local File XISOC       [XSOC] : Endif   # Société Intégrale
Read [XSOC]  First

# Contrôle I : Date premier exercice doit correspondre à une date de début d'exercice
Case VALEUR
 When [F:XSOC]DEBEXCN2 : [L]FIYSTA=[F:XSOC]ETAEXCN2
 When [F:XSOC]DEBEXCN1 : [L]FIYSTA=[F:XSOC]ETAEXCN1
 When [F:XSOC]DEBEXCN  : [L]FIYSTA=[F:XSOC]ETAEXCN
 When Default
  # Ne correspond pas à une date de début d'exercice
  GMESSAGE = SI_MES(164) : mkstat=2 : End
Endcase

# Contrôle II : Si la date correspond à un exercice ouvert, celui ci doit être le premier.
If [L]FIYSTA='O'
 Raz mkstat
 If [F:XSOC]DEBEXCN2<>[0/0/0] 
  If [F:XSOC]DEBEXCN2<>VALEUR & [F:XSOC]ETAEXCN2='O'  : mkstat=2 : Endif
  If [F:XSOC]DEBEXCN1<>VALEUR & [F:XSOC]ETAEXCN1='O'  : mkstat=2 : Endif
 Elsif [F:XSOC]DEBEXCN1<>[0/0/0] 
  If [F:XSOC]DEBEXCN1<>VALEUR & [F:XSOC]ETAEXCN1='O' : mkstat=2 : Endif
  If [F:XSOC]DEBEXCN<>VALEUR  & [F:XSOC]ETAEXCN ='O' : mkstat=2 : Endif
 Elsif [F:XSOC]DEBEXCN<>[0/0/0] 
  If [F:XSOC]DEBEXCN<>VALEUR  & [F:XSOC]ETAEXCN ='O' : mkstat=2 : Endif
 Endif
 If mkstat 
  # Ne correspond pas à la date du première exercice ouvert
  GMESSAGE = SI_MES(165) : End
 Endif
Endif

# Contrôle III : L'exercice peut être fermé.    
If !find([L]FIYSTA,'O','C') 
 # Etat de l'exercice incompatible
 mkstat = 2 : GMESSAGE = SI_MES(166) : End
Endif

# Contrôle IV : Si la date correspond à un exercice fermé, celui ci doit être le dernier.
If [L]FIYSTA='C'
 Raz mkstat
 If [F:XSOC]DEBEXCN<>[0/0/0] & [F:XSOC]ETAEXCN='C'
  If [F:XSOC]DEBEXCN<>VALEUR  : mkstat=2 : Endif
 Elsif [F:XSOC]DEBEXCN1<>[0/0/0] & [F:XSOC]ETAEXCN1='C'
  If [F:XSOC]DEBEXCN1<>VALEUR : mkstat=2 : Endif 
 Elsif [F:XSOC]DEBEXCN2<>[0/0/0] & [F:XSOC]ETAEXCN2 ='C'
  If [F:XSOC]DEBEXCN2<>VALEUR : mkstat=2 : Endif
 Endif
 If mkstat 
  # Ne correspond pas à la date du dernier exercice fermé
  GMESSAGE = SI_MES(203) : End
 Endif
Endif
End

Subprog CTL_STRPER(MESSA,STAT)
Variable Char    MESSA()
Variable Integer STAT
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Call C_STRPER([F:SPX]STRPER)
STAT=mkstat
# Paramétrage à revoir (Onglet Comptabilité\Général) : 
MESSA=mess(86,105,1)-"("+mess(63,105,1)-mess(2,14,1)+"\"+mess(147,195,1)+")"
Raz mkstat, GMESSAGE
End


#########################################################################
# Suppression de la société
#########################################################################
Subprog DELETE_COMPANY

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
If !clalev([F:AGC])  : Local File =SI_DOSSIER+".AGRPCPY"    [AGC]  : Endif   # Groupes de société X3
If !clalev([F:AGF])  : Local File =SI_DOSSIER+".AGRPFCY"    [AGF]  : Endif   # Groupes de site X3
If !clalev([F:DCP])  : Local File =SI_DOSSIER+".DADCPY"     [DCP]  : Endif   # Société DADS X3
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY]  : Endif   # Sites   X3

If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA]  : Endif   # Adresses

If !clalev([F:FIY])  : Local File =SI_DOSSIER+".FISCALYEAR" [FIY]  : Endif   # Exercices
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"     [PER]  : Endif   # Périodes

If GMODU(2)=2  :# Compta
 If !clalev([F:IDP])  : Local File =SI_DOSSIER+".INVDACPAR"  [IDP]  : Endif   # Paramétrage saisie fact. tiers
Endif

Trbegin [CPY], [AGC], [AGF], [DCP], [FCY], [BPA], [FIY], [PER]
GOK=1
For [CPY]
 Gosub SUPP_CPY
Next
If !GOK  : Rollback : End : Endif

Delete [CPY] Where 1=1
Delete [AGF] Where 1=1
Delete [AGC] Where 1=1
Commit
End

$SUPP_CPY
 Delete [BPA]  Where BPATYP=2 & BPANUM=[F:CPY]CPY
 If fstat : GOK=0 :  Return : Endif
 Delete [FCY]  Where LEGCPY=[F:CPY]CPY
 If fstat : GOK=0 :  Return : Endif
 Delete [DCP]  Where CPY=[F:CPY]CPY
 If fstat : GOK=0 :  Return : Endif
 Delete [FIY]  Where CPY=[F:CPY]CPY
 If fstat : GOK=0 :  Return : Endif
 Delete [PER]  Where CPY=[F:CPY]CPY
 If fstat : GOK=0 :  Return : Endif
 If GMODU(2)=2  :# Compta
  Delete [IDP]  Where CPY=[F:CPY]CPY
  If fstat : GOK=0 :  Return : Endif
 Endif
Return





##################################################################
#  Initialisation X3DAT
##################################################################
$INI_X3DAT 
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"     [CPY]  : Endif   # Société X3
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"        [GCM]  : Endif   # Modèle comptable
If !clalev([F:FIY])  : Local File =SI_DOSSIER+".FISCALYEAR"  [FIY]  : Endif   # Exercices
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"      [PER]  : Endif   # Périodes

If !clalev([F:XHCB]) : Local File =SI_DOSSIER+".XIHISCBGNR"  [XHCB] : Endif   # Historique général
If !clalev([F:XHAN]) : Local File =SI_DOSSIER+".XIHISANA"    [XHAN] : Endif   # Historique analytique
If !clalev([F:XBCB]) : Local File =SI_DOSSIER+".XIBROCBGNR"  [XBCB] : Endif   # Brouillard général
If !clalev([F:XBAN]) : Local File =SI_DOSSIER+".XIBROCBANA"  [XBAN] : Endif   # Brouillard analytique

Local Decimal EXERCICE, PERIODE
Local Date DATDEB, DATFIN, SVGDAT, CLE1, CLE7
Local Integer LEC, STOP, NB, CLE5, CLE6, CLE8
Local Char CRITERE(250), CLE2(50), CLE3(50), CLE4(50)

# Mises à jour X3DAT
Call TEMPON(left$(SI_MES(163),12)-"X3DAT") From GESECRAN

Read [CPY] First
Read [GCM]GCM0 = [F:CPY]ACM

Gosub SET_FIRST From TRTFIRST 

Gosub MAJ_HCB : If GOK<>1 : Return : Endif
Gosub MAJ_HAN : If GOK<>1 : Return : Endif
Gosub MAJ_BCB : If GOK<>1 : Return : Endif
Gosub MAJ_BAN : If GOK<>1 : Return : Endif
Gosub UNSET_FIRST From TRTFIRST 
Call TEMPOFF From GESECRAN
Return

############
$MAJ_HCB
GOK = 1
LEC = 1
Filter [XHCB] Order By Key CLE=[F:XHCB]DATECR;[F:XHCB]CODJRN;[F:XHCB]NUMECR
Raz STOP
$LOOP_XHCB
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMECR>CLE5"
Elsif STOP = 2 
 STOP = 3
 CRITERE = "DATECR=CLE1 & CODJRN>CLE2"
Elsif STOP = 3 
 STOP = 0
 CRITERE = "DATECR>CLE1"
Else
 CRITERE = "1=1"
Endif


Trbegin [XHCB]
For [XHCB] Where evalue(CRITERE)
 If LEC | [F:XHCB]DATECR<>SVGDAT
  Call GETPERSOC([F:CPY]CPY,[F:GCM]GENLEDTYP,[F:XHCB]DATECR,EXERCICE,PERIODE) From CPTSUB
  Call DATPER([F:CPY]CPY,[F:GCM]GENLEDTYP,EXERCICE,PERIODE,DATDEB,DATFIN)
  SVGDAT = [F:XHCB]DATECR
  LEC = 0 
 Endif

 [F:XHCB]X3DAT = DATDEB
 Rewrite [XHCB]
 If fstat
  # X3DAT ... (...) Erreur d'écriture
  Call ECR_TRACE("X3DAT "-[F:CPY]CPY-"("+[F:XSOC]SOC+")"-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
  GOK = 0 : STOP = 0 : Break
 Else
  NB+=1
  If NB>GMAXUPDTRS
   CLE1=[F:XHCB]DATECR
   CLE2=[F:XHCB]CODJRN
   CLE5=[F:XHCB]NUMECR
   STOP=1
   Break
  Endif
 Endif
Next
Gosub FIN_INI 
If STOP
 Goto LOOP_XHCB
Endif
Filter [XHCB]
Return

############
$MAJ_HAN
GOK = 1
LEC = 1
Filter [XHAN] Order By Key CLE=[F:XHAN]DATECR;[F:XHAN]CODJRN;[F:XHAN]NUMPIEDEB;[F:XHAN]NUMPIEFIN;[F:XHAN]NUMECRHIS;[F:XHAN]NUMVTL

Raz STOP
$LOOP_XHAN
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMECRHIS=CLE5 & NUMVTL>CLE6"
Elsif STOP = 2 
 STOP = 3
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMECRHIS>CLE5"
Elsif STOP = 3 
 STOP = 4
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN>CLE4"
Elsif STOP = 4
 STOP = 5
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB>CLE3"
Elsif STOP = 5
 STOP = 6
 CRITERE = "DATECR=CLE1 & CODJRN>CLE2"
Elsif STOP = 6
 STOP = 0
 CRITERE = "DATECR>CLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [XHAN]
For [XHAN] Where evalue(CRITERE)
 If LEC | [F:XHAN]DATECR<>SVGDAT
  Call GETPERSOC([F:CPY]CPY,[F:GCM]GENLEDTYP,[F:XHAN]DATECR,EXERCICE,PERIODE) From CPTSUB
  Call DATPER([F:CPY]CPY,[F:GCM]GENLEDTYP,EXERCICE,PERIODE,DATDEB,DATFIN)
  SVGDAT = [F:XHAN]DATECR
  LEC = 0
 Endif

 [F:XHAN]X3DAT = DATDEB
 Rewrite [XHAN]
 If fstat
  Call ECR_TRACE("X3DAT "-[F:CPY]CPY-"("+[F:XSOC]SOC+")"-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
  GOK = 0 : STOP=0 : Break
 Else
  NB+=1
  If NB>GMAXUPDTRS
   CLE1=[F:XHAN]DATECR
   CLE2=[F:XHAN]CODJRN
   CLE3=[F:XHAN]NUMPIEDEB
   CLE4=[F:XHAN]NUMPIEFIN
   CLE5=[F:XHAN]NUMECRHIS
   CLE6=[F:XHAN]NUMVTL
   STOP=1
   Break
  Endif
 Endif
Next
Gosub FIN_INI 
If STOP
 Goto LOOP_XHAN
Endif
Filter [XHAN]
Return

############
$MAJ_BCB
GOK = 1
LEC = 1 
Filter [XBCB] Order By Key CLE=[F:XBCB]DATECR;[F:XBCB]CODJRN;[F:XBCB]NUMLOT;[F:XBCB]DATSAILOT;[F:XBCB]NUMORDLOT

Raz STOP
$LOOP_XBCB
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMLOT=CLE5 & DATSAILOT=CLE7 & NUMORDLOT>CLE6"
Elsif STOP = 2 
 STOP = 3
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMLOT=CLE5 & DATSAILOT>CLE7"
Elsif STOP = 3 
 STOP = 4
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMLOT>CLE5"
Elsif STOP = 4
 STOP = 5
 CRITERE = "DATECR=CLE1 & CODJRN>CLE2"
Elsif STOP = 5
 STOP = 0
 CRITERE = "DATECR>CLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [XBCB]
For [XBCB] Where evalue(CRITERE)
 If LEC | [F:XBCB]DATECR<>SVGDAT
  Call GETPERSOC([F:CPY]CPY,[F:GCM]GENLEDTYP,[F:XBCB]DATECR,EXERCICE,PERIODE) From CPTSUB
  Call DATPER([F:CPY]CPY,[F:GCM]GENLEDTYP,EXERCICE,PERIODE,DATDEB,DATFIN)
  SVGDAT = [F:XBCB]DATECR
  LEC = 0 
 Endif

 [F:XBCB]X3DAT = DATDEB
 Rewrite [XBCB]
 If fstat
  Call ECR_TRACE("X3DAT "-[F:CPY]CPY-"("+[F:XSOC]SOC+")"-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
  GOK = 0 : STOP = 0 : Break
 Else
  NB+=1
  If NB>GMAXUPDTRS
   CLE1=[F:XBCB]DATECR
   CLE2=[F:XBCB]CODJRN
   CLE5=[F:XBCB]NUMLOT
   CLE7=[F:XBCB]DATSAILOT
   CLE6=[F:XBCB]NUMORDLOT
   STOP=1
   Break
  Endif
 Endif
Next
Gosub FIN_INI 
If STOP
 Goto LOOP_XBCB
Endif
Filter [XBCB]
Return

############
$MAJ_BAN
GOK = 1
LEC = 1 
Filter [XBAN] Order By Key CLE=[F:XBAN]DATECR;[F:XBAN]CODJRN;[F:XBAN]NUMPIEDEB;[F:XBAN]NUMPIEFIN;[F:XBAN]NUMLOT;[F:XBAN]NUMORDLOT;[F:XBAN]NUMVTLLOT;[F:XBAN]DATSAILOT

Raz STOP
$LOOP_XBAN
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMLOT=CLE5 & NUMORDLOT=CLE6 & NUMVTLLOT=CLE8 & DATSAILOT>CLE7"
Elsif STOP = 2 
 STOP = 3
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMLOT=CLE5 & NUMORDLOT=CLE6 & NUMVTLLOT>CLE8"
Elsif STOP = 3 
 STOP = 4
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMLOT=CLE5 & NUMORDLOT>CLE6"
Elsif STOP = 4
 STOP = 5
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN=CLE4 & NUMLOT>CLE5"
Elsif STOP = 5
 STOP = 6
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB=CLE3 &  NUMPIEFIN>CLE4"
Elsif STOP = 6
 STOP = 7
 CRITERE = "DATECR=CLE1 & CODJRN=CLE2 & NUMPIEDEB>CLE3"
Elsif STOP = 7
 STOP = 8
 CRITERE = "DATECR=CLE1 & CODJRN>CLE2"
Elsif STOP = 8
 STOP = 0
 CRITERE = "DATECR>CLE1"
Else
 CRITERE = "1=1"
Endif

Trbegin [XBAN]
For [XBAN] Where evalue(CRITERE)
 If LEC | [F:XBAN]DATECR<>SVGDAT
  Call GETPERSOC([F:CPY]CPY,[F:GCM]GENLEDTYP,[F:XBAN]DATECR,EXERCICE,PERIODE) From CPTSUB
  Call DATPER([F:CPY]CPY,[F:GCM]GENLEDTYP,EXERCICE,PERIODE,DATDEB,DATFIN)
  SVGDAT = [F:XBAN]DATECR
  LEC = 0 
 Endif

 [F:XBAN]X3DAT = DATDEB
 Rewrite [XBAN]
 If fstat
  Call ECR_TRACE("X3DAT "-[F:CPY]CPY-"("+[F:XSOC]SOC+")"-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
  GOK = 0 : STOP=0 : Break
 Else
  NB+=1
  If NB>GMAXUPDTRS
   CLE1=[F:XBAN]DATECR
   CLE2=[F:XBAN]CODJRN
   CLE3=[F:XBAN]NUMPIEDEB
   CLE4=[F:XBAN]NUMPIEFIN
   CLE5=[F:XBAN]NUMLOT
   CLE6=[F:XBAN]NUMORDLOT
   CLE7=[F:XBAN]DATSAILOT
   CLE8=[F:XBAN]NUMVTLLOT
   STOP=1
   Break
  Endif
 Endif
Next
Gosub FIN_INI 
If STOP
 Goto LOOP_XBAN
Endif
Filter [XBAN]
Return

############
$FIN_INI
If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif
Return




Subprog DATPER(SOC,TYPLED,EXE,PER,DATDEB,DATFIN)
Value    Char SOC
Value    Integer TYPLED
Value    Decimal EXE
Value    Decimal PER
Variable Date DATDEB
Variable Date DATFIN
Raz DATDEB, DATFIN

Filter [PER] Where CPY=SOC & FIYNUM=EXE & PERNUM=PER & LEDTYP=[L]TYPLED
Read [PER]PER0 First
Filter [PER]
If !fstat
 DATDEB = [F:PER]PERSTR
 DATFIN = [F:PER]PEREND
Endif
End




Subprog INI_COA(GCM,COA)
Value    Char GCM
Variable Char COA
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable
If !clalev([F:LED])  : Local File =SI_DOSSIER+".GLED"       [LED]  : Endif   # Référentiel

Read [GCM]GCM0 = [L]GCM
If !fstat
 Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
 If !fstat
  [L]COA =  [F:LED]COA
 Endif
Endif
End

Subprog LEC_COA(CAS,CPY,COA)
## Renvoie le code plan associé au référentiel principal général (si CAS=1)
## ou principal analytique (si CAS=2) de la société passé en paramètre
Value    Integer  CAS   : # Si 1:général si 2:analytique
Value    Char     CPY() : # Société
Variable Char     COA() : # Code référentiel

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société
If !clalev([F:GCM])  : Local File =SI_DOSSIER+".GACM"       [GCM]  : Endif   # Modèle comptable
If !clalev([F:LED])  : Local File =SI_DOSSIER+".GLED"       [LED]  : Endif   # Référentiel

Read [CPY]CPY0 = CPY
If !fstat
 Read [GCM]GCM0 = [F:CPY]ACM
 If !fstat
  Case CAS
   When 1 : Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
   When 2 : Read [LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
  Endcase
  If !fstat
   [L]COA =  [F:LED]COA
  Endif
 Endif
Endif
End 



