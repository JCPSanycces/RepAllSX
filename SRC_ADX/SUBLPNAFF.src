######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 08/02/2018 16:04:51 (MAE)
######################################################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
If [M:LPNA]ITMREFSEL <> AVOID.ACHAR & VALEUR <> AVOID.ACHAR
  Read [STL]STL0 = [M:LPNA]ITMREFSEL;VALEUR
  If fstat
  GMESSAGE = mess(123,199,1)
  mkstat = 2 : End
  Endif
Endif
[M:LPNA]LOTSTR = VALEUR
[M:LPNA]LOTEND = VALEUR


End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 09/02/2018 07:43:40 (MAE)
######################################################################################
Subprog AM_LOCSEL(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
  Actzo [M:LPNA]LOTSEL
  Actzo [M:LPNA]ECSSEL

Else
  Raz [M:LPNA]LOTSEL
  Raz [M:LPNA]ECSSEL
  Diszo [M:LPNA]LOTSEL
  Diszo [M:LPNA]ECSSEL
Endif
[M:LPNA]LOCSTR = VALEUR
[M:LPNA]LOCEND = VALEUR
End


