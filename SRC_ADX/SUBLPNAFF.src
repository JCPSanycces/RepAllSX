########################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
    [M:LPNA]VCRTYP = 29
End

########################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()


#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If (VALEUR="" &  GSTKCPT(14)="")
  mkstat = 2 : End
Endif
#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If (GREP="C" & VALEUR="" &  GSTKCPT(14)<>"")
  End
Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:LPNA]VCRNUM="" & GREP<>"C"
  Look [F:SGH]SGH0=VALEUR
  If fstat
    GMESSAGE=mess(178,199,1) : mkstat=2 : End
  Endif
Endif

If VALEUR<>"" & GSTKCPTMAN(14)<>2
  Look [F:SGH]SGH0=VALEUR
  If fstat
    Raz VALEUR : End
  Endif
Endif

End

##########################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ligne déjà saisie, plus d'accés au site de stock
If [M:LPNA]NBLIG<>0 mkstat=2 Endif
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

GFCY=VALEUR : Gosub CHARG_PARAM From SUBLPNAFA

[M:SGW]FCYDES = VALEUR

# Actzo ou Diszo du dépôt
[M:LPNA]STOFCY=VALEUR
#Gosub WRH_ETAT From SUBLPNAFA

End
##########################################################################
Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
Local Integer  LRET
Local Shortint WRET
If VALEUR=""
  [M:LPNA]ITMREFSEL = VALEUR
  GSCSAUZSST = "A*,Q*,R*"
  End
Endif
If dim([M:LPNA]WRHSTR)> 0
  Raz [M:LPNA]WRHSTR, WRHEND
Endif
Raz [M:LPNA]AUZSST,FORSTA,LOTSTR,LOTEND
Raz [M:LPNA]SERNUMSTR,SERNUMEND
Call LECITM([M:LPNA]STOFCY,VALEUR,"",3,"",LRET) From STKLIB
If LRET
  mkstat=2 : End
Endif
# hcb
If [F:ITF]STOFCY <>[M:LPNA]STOFCY | [F:ITF]ITMREF <> VALEUR
   Read [ITF]ITF0 = VALEUR;[M:LPNA]STOFCY
   If fstat
      GMESSAGE=VALEUR-[M:LPNA]STOFCY-":"-mess(139,197,1)
      mkstat=2 : End
   Else
# Article non géré en stock
      If [F:ITF]STOMGTCOD = 1
         GMESSAGE = VALEUR-":"-mess(2,196,1)-[M:LPNA]STOFCY
         mkstat=2 : End
      Endif
      If [F:ITFD]STOFCY <>[M:LPNA]STOFCY| [F:ITFD]ITMREF <> VALEUR
         Read [ITFD]ITF0 = VALEUR;[M:LPNA]STOFCY
         If fstat
            GMESSAGE=VALEUR-[M:LPNA]STOFCY-":"-mess(139,197,1)
            mkstat=2: End
         Endif
      Endif
   Endif
Else
   If [F:ITFD]STOFCY <>[M:LPNA]STOFCY| [F:ITFD]ITMREF <> VALEUR
      Read [ITFD]ITF0 = VALEUR;[M:LPNA]STOFCY
      If fstat
         GMESSAGE=VALEUR-[M:LPNA]STOFCY-":"-mess(139,197,1)
         mkstat=2: End
      Endif
   Endif
Endif

#--- Bug 65411
# Si dépôt destination entête renseigné et dépôt destination ligne non saisissable
# Contrôle existence article dépôt
If dim([M:LPNA]WRHDESH)>0 & [M:LPNA]WRHDESH<>""
   Read [ITW]ITW0=VALEUR;[M:LPNA]WRHDESH
   If fstat
      GERR=1 : GMESSAGE=mess(978,196,1)-[M:LPNA]WRHDESH
      mkstat=2 : End
   Endif
Endif
#---

If [F:ITF]LPNMGTCOD <> 2
  GMESSAGE = VALEUR-":"-mess(531,184,1)
  mkstat=2 : End
Endif

# Lecture règle de gestion pour flux d'entrée
Call LECSRU([M:LPNA]STOFCY,[F:ITM]TCLCOD,26,"","",LRET)
&             From STKLIB
  If LRET<>0 mkstat=2 : End Endif
  GSCSAUZSST = [F:SRU]AUZSST

[M:LPNA]ITMREFSEL = VALEUR

If VALEUR <> AVOID.ACHAR & [F:ITM]LOTMGTCOD > 1
  Actzo [M:LPNA]LOTSEL
Else
  Diszo [M:LPNA]LOTSEL
Endif
If VALEUR <> AVOID.ACHAR & [F:ITM]ECCFLG = 2
  Actzo [M:LPNA]ECSSEL
Else
  Diszo [M:LPNA]ECSSEL
Endif

End

##########################################################################
#--- TS 106217
Subprog C_ECSSEL(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET

If VALEUR="" : End : Endif
If [M:LPNA]ITMREFSEL="" : VALEUR="" : End : Endif

#test d'existence
Read [ECS]ECS0=[M:LPNA]ITMREFSEL;VALEUR
If fstat
  mkstat=2 : GMESSAGE=mess(406,184,1) : End
Endif

End
#---

