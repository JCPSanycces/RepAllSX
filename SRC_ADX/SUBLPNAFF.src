Variable Char    VALEUR()

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 01/03/2018 13:43:46 (MAE)
######################################################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
  Read [STC]STC0 = [M:LPNA]STOFCY;VALEUR
  If fstat
   GMESSAGE = mess(125,184,1)
   mkstat=2 : End
  Endif
  If dim([M:LPNA]WRHDES)>0
    [M:LPNA]WRHDES(nolign-1) = [F:STC]WRH
  Endif

  #controle de l'emplacement du LPN
  Call STKCTREMP([M:LPNA]WLOCSEQ,36,"",[M:LPNA]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNA]LOCTYPDES(nolign-1),VALEUR,"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
  If mkstat = 2 : End : Endif
  [M:LPNA]LOCTYPDES(nolign-1) = [F:STC]LOCTYP
  If dim([M:LPNA]WRHDESH)>0 : [M:LPNA]WRHDES(nolign-1)=[F:STC]WRH : Affzo [M:LPNA]WRHDES(nolign-1) : Endif
  Affzo [M:LPNA]LOCTYPDES(nolign-1)
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 28/03/2018 08:08:38 (MAE)
######################################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local Decimal WTOTQTYPCU
Local Decimal WTOTQTYSTU
Local Integer LRET
If [M:LPNA]WSTOCOU(nolign-1) <> [F:STO]STOCOU
  Read [STO]STO0 = [M:LPNA]STOFCY;[M:LPNA]WSTOCOU(nolign-1)
Endif
WTOTQTYSTU = [F:STO]QTYSTU - [F:STO]CUMWIPQTY + sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)<>0)*[M:SGW]WWIPQTY(indcum)*([M:SGW]WSTOCOU(indcum)=[M:LPNA]WSTOCOU(nolign-1)))
WTOTQTYPCU = sigma(0,[M:LPNA]NBLIG,([M:LPNA]WSTOCOU(nolign-1) = [M:LPNA]WSTOCOU(indcum))*[M:LPNA]QTYPCU(indcum)) + VALEUR - [M:LPNA]QTYPCU(nolign-1)
If [M:LPNA]PCUSTUCOE(nolign-1) * WTOTQTYPCU >  WTOTQTYSTU
  Call ERREUR(func AFNC.MES1(mess(535,184,1),num$([M:LPNA]WSTOCOU(nolign-1)))) From GESECRAN
  mkstat = 2 : End
Endif
Call MAJQTY(1,VALEUR,LRET) From SUBLPNAFB
  If LRET
    mkstat=2 : End
  Endif
End


