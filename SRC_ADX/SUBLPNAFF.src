##########################################################################
Subprog C_LOCDESH(VALEUR)
Variable Char    VALEUR()

Local Shortint W_K

VALEUR = toupper(VALEUR)
If !find(VALEUR,"",[M:LPNA]LOCDESH)
  Read [STC]STC0=[M:LPNA]STOFCY;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Elsif [F:STC]LOCCAT >2
    GMESSAGE = mess(16,196,1)
    mkstat=2 : End
  Endif
Endif

If VALEUR<>""
  [M:LPNA]LOCTYPDESH = [F:STC]LOCTYP
  If dim([M:LPNA]WRHDES)>0 : [M:LPNA]WRHDESH = [F:STC]WRH : Endif
Endif

End

