######################################################################################
## Etiquette ajoutée par le superviseur (Objet LPNAFF) 13/12/2017 09:27:23 (MAE)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE        From SUBLPNAFA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBLPNAFA

 When "FILTRE"       : Gosub FILTRE       From SUBLPNAFA
 When "LIENS"        : Gosub LIENS        From SUBLPNAFA
 When "DEFLIG"       : Gosub DEFLIG       From SUBLPNAFA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBLPNAFA

 When "SETBOUT"      : Gosub SETBOUT      From SUBLPNAFA
 When "EXEBOUT"      : Case BOUT
                            When "1" :Gosub TIROIR From SUBLPNAFP
                       Endcase

 When "RAZCRE"       : Gosub RAZCRE       From SUBLPNAFA
 When "RAZDUP"       : Gosub RAZDUP       From SUBLPNAFA
 When "CREATION"     : Gosub CREATION     From SUBLPNAFA
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBLPNAFA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBLPNAFA
 When "INICRE"       : Gosub INICRE       From SUBLPNAFA
 When "INIMOD"       : Gosub INIMOD       From SUBLPNAFA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBLPNAFA
 When "VALLIG"       : Gosub VALLIG       From SUBLPNAFA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBLPNAFA
 When "MODIF"        : Gosub MODIF        From SUBLPNAFA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBLPNAFA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBLPNAFA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBLPNAFA
 When "ABANDON"      : Gosub ABANDON      From SUBLPNAFA
 When "FIN"          : Gosub ABANDON      From SUBLPNAFA
 When "FERME"        : Gosub FERME        From SUBLPNAFA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBLPNAFA
 When "TIROIR"           : Gosub TIROIR       From SUBLPNAFP
 When "FILGAUCHE"        : Gosub FILGAUCHE    From SUBLPNAFP
 When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE From SUBLPNAFP
 When "DEB_PICK"         : Gosub DEB_PICK     From SUBLPNAFP
 When "PICKE"            : Gosub PICKE        From SUBLPNAFP
 When "DEPICK"           : Gosub DEPICK       From SUBLPNAFP
 When "FIN_PICK"         : Gosub FIN_PICK     From SUBLPNAFP
 When Default
Endcase
Return

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
Case ACTION
 When "BB3_ITMREFSEL"    : VALEUR=[M:LPNA]ITMREFSEL
 When Default
Endcase

Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

