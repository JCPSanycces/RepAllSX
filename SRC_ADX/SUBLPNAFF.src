##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
Local Integer CTRIPTDAT
If [M:LPNA]ITMREF(nolign-1)<>""
  If GREP = "M"
    If CTRIPTDAT <> CST_AOK & [M:LPNA]IPTDAT < date$
        CTRIPTDAT = CST_AERROR
        # Attention ! la date d imputation est antérieure à la date du jour
        Call MESSAGE(mess(162,184,1)) From GESECRAN
    Endif
  Endif

  Call LECITM2( [M:LPNA]STOFCY, [M:LPNA]ITMREF(nolign-1), "", LRET ) From STKLIB

  # Si changement stock, lecture règle de gestion pour flux d'entrée
  Call LECSRU([M:LPNA]STOFCY,[F:ITM]TCLCOD,26,"","",LRET) From STKLIB
  If LRET<>0 mkstat=2 : End Endif
Endif

End

##########################################################################
Subprog IB_NBLIG
Local Integer LRET

If [M:LPNA]ITMREF(nolign-1)<>""
  Call LECITM2( [M:LPNA]STOFCY, [M:LPNA]ITMREF(nolign-1), "", LRET ) From STKLIB
  GOUVENT = 1
Endif

# Btn 4 = saisie serie globales         110327 #
GBOUT4 = mess(655,199,1)

# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If GBOUT1 = "" | [F:ITM]SERMGTCOD <> 4 | [M:LPNA]WSTOCOU (nolign-1)= 0 | [M:LPNA]QTYSTUDES (nolign-1)= 0
   Raz GBOUT4
Endif
If [M:LPNA]LPNNUMDES(nolign-1) = AVOID.ACHAR or [M:LPNA]LPNNUMDES(nolign-1) = "$"
  Raz GBOUT2
Endif
# Issue 106909 - 2018-09-20 by MAE : pas de consultation si création ou duplication
If GREP="C" or GREP="D"
  Raz GBOUT1,GBOUT2
Endif


End

##########################################################################
Subprog C_NBLIG
Local Integer LRET
Case status
  When 65     :                       # Suppression d'une ligne
    If [M:LPNA]CREFLG(nolign-1)=0
      Call DELSTOCHGW("LPNA", [M:LPNA]STOFCY, nolign-1, nolign-1,1, LRET) From SUBSCSB
    Else
      mkstat = 2
    Endif

  When 68, 83 :                       # Suppression d'un groupe de lignes
    For I=nolign-1 To nolign1-1
      If [M:LPNA]CREFLG(I)<>0
        mkstat=2 : Break
      Endif
    Next
    If !mkstat
      Call DELSTOCHGW("LPNA", [M:LPNA]STOFCY, nolign-1, nolign1-1,1, LRET) From SUBSCSB
    Endif

  When 75     :
    If [M:LPNA]CREFLG(nolign-1)<>0
      mkstat=2
    Endif
Endcase

If LRET : mkstat=2 : Endif

If find(status,73,75)
  If [M:SGW]NBLIG+sigma(0,[M:SGW]NBLIG-1,[M:SGW]WSTOSEQ(indcum)=[M:LPNA]WSTOSEQ(nolign-1))>=dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)) From GESECRAN
    mkstat=2 : End
  Endif
Endif

End

##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
    If [F:ITM]SERMGTCOD=2 & VALEUR<>""
        Call STKCTRSER(VALEUR,[M:LPNA]ITMREF(nolign-1),nolign-1,[M:LPNA]NBLIG,
&                      [M:LPNA]WSTOSEQ(nolign-1),36,[M:LPNA]VCRTYP,
&                      [M:LPNA]VCRNUM,[M:LPNA]VCRLIN(nolign-1),0,"",0,0,0,"" )
&            From STKACT
    Endif
End


#########################################################################
Subprog APRES_NBLIG
Local Integer LRET
Local Decimal LQTY
Local Integer LSEQ
LQTY = [M:LPNA]QTYSTUDES(nolign-1)
#suppression du STOCHGW et on le recréé (il est forcément déjà créé : soit en pcking, soit en insertion auto)
Call DELSTOCHGW("LPNA", [M:LPNA]STOFCY, nolign-1, nolign-1,1, LRET) From SUBSCSB
Call STKWSTOSEQ ("LPNA", [M:LPNA]NBLIG-1, [M:LPNA]NBLIG, 2, LSEQ, LRET) From STKECR

Call FILLCHGW("LPNA", nolign-1, 1, [M:LPNA]WSTOSEQ(nolign-1), [M:LPNA]STOFCY, LRET, LQTY) From SUBSCSB

If [M:LPNA]MODAFFLPN = 2 #Répartition sur plusieurs contenants
#la ligne a été créée avec un choix multiple
# la ligne n'a pas encore été traitée
#la ligne est la derniére du tableau
  If ([M:LPNA]QTYSTUDES(nolign-1) < [M:LPNA]STUDIS(nolign-1)) & [M:LPNA]LGAFFLPN(nolign-1) = 2 & [M:LPNA]LGTRTFLG(nolign-1) = 0 & nolign = [M:LPNA]NBLIG
    #Ouverture d'une ligne dans le tableau
    nolign = [M:LPNA]NBLIG
    Insa nolign,1,[M:LPNA]NBLIG [M:LPNA]NBLIG
    [M:LPNA]NBLIG += 1
    nolign = [M:LPNA]NBLIG
    NOL = nolign-1
    status = 73
    Call INSERE("VCRLIN") From TABLEAUX
    status = 71
    Call LINNUM("VCRLIN") From TABLEAUX
    status = 0

    [M:LPNA]ITMREF(NOL) = [M:LPNA]ITMREF(NOL-1)
    If dim([M:LPNA]LOT)>0
      [M:LPNA]LOT(NOL)    = [M:LPNA]LOT(NOL-1)
    Endif
    If dim([M:LPNA]SLO)>0
      [M:LPNA]SLO(NOL)    = [M:LPNA]SLO(NOL-1)
    Endif
    If dim([M:LPNA]ECCVALMAJ)>0
      [M:LPNA]ECCVALMAJ(NOL) = [M:LPNA]ECCVALMAJ(NOL-1)
    Endif
    If dim([M:LPNA]PALNUMDES)>0
      [M:LPNA]PALNUMDES(NOL) = [M:LPNA]PALNUMDES(NOL-1)
    Endif
    If dim([M:LPNA]CTRNUMDES)>0
      [M:LPNA]CTRNUMDES(NOL) = [M:LPNA]CTRNUMDES(NOL-1)
    Endif
    [M:LPNA]STA(NOL)    = [M:LPNA]STA(NOL-1)
    If dim([M:LPNA]LOC)>0
      [M:LPNA]LOC(NOL) = [M:LPNA]LOC(NOL-1)
    Endif
    If dim([M:LPNA]LOCTYP)>0
      [M:LPNA]LOCTYP(NOL) = [M:LPNA]LOCTYP(NOL-1)
    Endif
    If dim([M:LPNA]WRH)>0
      [M:LPNA]WRH(NOL) = [M:LPNA]WRH(NOL-1)
    Endif
    If dim([M:LPNA]SERNUM)>0
      [M:LPNA]SERNUM(NOL) = [M:LPNA]SERNUM(NOL-1)
    Endif
    If dim([M:LPNA]STOFLD1)>0
      [M:LPNA]STOFLD1(NOL) = [M:LPNA]STOFLD1(NOL-1)
    Endif
    If dim([M:LPNA]STOFLD2)>0
      [M:LPNA]STOFLD2(NOL) = [M:LPNA]STOFLD2(NOL-1)
    Endif
    [M:LPNA]OWNER(NOL)     = [M:LPNA]OWNER(NOL-1)
    [M:LPNA]PCU(NOL)       = [M:LPNA]PCU(NOL-1)
    [M:LPNA]PCUSTUCOE(NOL) = [M:LPNA]PCUSTUCOE(NOL-1)
    If [M:LPNA]PCUSTUCOE(NOL-1) <> 0
      [M:LPNA]QTYPCU(NOL)  = ([M:LPNA]STUDIS(NOL-1) - [M:LPNA]QTYSTUDES(NOL-1))/[M:LPNA]PCUSTUCOE(NOL-1)
    Else
      [M:LPNA]QTYPCU(NOL)  = [M:LPNA]STUDIS(NOL-1) - [M:LPNA]QTYSTUDES(NOL-1)
    Endif
    [M:LPNA]QLYCTLDEM(NOL) = [M:LPNA]QLYCTLDEM(NOL-1)
    [M:LPNA]STUDIS(NOL)    = [M:LPNA]STUDIS(NOL-1) - [M:LPNA]QTYSTUDES(NOL-1)
    [M:LPNA]QTYSTUDES(NOL) = [M:LPNA]STUDIS(NOL-1) - [M:LPNA]QTYSTUDES(NOL-1)
    [M:LPNA]LOCDES(NOL)    = [M:LPNA]LOCDES(NOL-1)
    [M:LPNA]LOCTYPDES(NOL) = [M:LPNA]LOCTYPDES(NOL-1)
    [M:LPNA]WSTOCOU(NOL)   = [M:LPNA]WSTOCOU(NOL-1)
    [M:LPNA]STU(NOL)       = [M:LPNA]STU(NOL-1)
    [M:LPNA]ITMDES1(NOL)   = [M:LPNA]ITMDES1(NOL-1)
    [M:LPNA]PCUDES(NOL)    = [M:LPNA]PCUDES(NOL-1)
    [M:LPNA]COEDES(NOL)    = [M:LPNA]COEDES(NOL-1)
    [M:LPNA]STADES(NOL)    = [M:LPNA]STADES(NOL-1)
    #la ligne précédente a été traitée
    [M:LPNA]LGTRTFLG(NOL-1) = 1
    #la ligne a été créée à partir d'un choix multiple
    [M:LPNA]LGAFFLPN(NOL) = 2
    #rensiegnement du STOCHGW pour simuler un picking
    LQTY = [M:LPNA]QTYSTUDES(NOL)
    Call STKWSTOSEQ ("LPNA", NOL, [M:LPNA]NBLIG, 2, LSEQ, LRET) From STKECR
    Call FILLCHGW("LPNA", NOL, 1, [M:LPNA]WSTOSEQ(NOL), [M:LPNA]STOFCY, LRET, LQTY) From SUBSCSB
    nolign=NOL+1
    Affzo [M:LPNA]
  Endif
 Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 20/12/2017 09:39:37 (MAE)
######################################################################################
Subprog AM_LPNDESH(VALEUR)
Variable Char    VALEUR()
Local Integer NBROW

Read [LPN]LPN0 = VALEUR
[M:LPNA]TCTRNUMH = [F:LPN]TCTRNUM
[M:LPNA]MONITMFLG = [F:LPN]MONITMFLG
[M:LPNA]MONLOTFLG = [F:LPN]MONLOTFLG
If [F:LPN]LOC <> AVOID.ACHAR
  #lecture de l'emplacement pour rfécupérer le depot
  Read [STC]STC0 = [M:LPNA]STOFCY;[F:LPN]LOC
  [M:LPNA]LOCTYPDESH = [F:STC]LOCTYP
  #initialisation de l'emplacement et du dépot de dépose
  [M:LPNA]LOCDESH = [F:LPN]LOC
  If dim([M:LPNA]WRHDESH)>0
    [M:LPNA]WRHDESH =  [F:LPN]WRH
  Endif
  If [F:LPN]LPNSTAT = 2
    Diszo [M:LPNA]LOCDESH
    Chgstl [M:LPNA]LPNDESH With "BACKORANGE"
  Else
    Actzo [M:LPNA]LOCDESH
    Chgstl [M:LPNA]LPNDESH With ""
  Endif
Else
  Raz [M:LPNA]LOCDESH
  Raz [M:LPNA]LOCTYPDESH
  If dim([M:LPNA]WRHDESH)>0
    Raz [M:LPNA]WRHDESH
  Endif
  Actzo [M:LPNA]LOCDESH
  Chgstl [M:LPNA]LPNDESH With ""
Endif

Filter [STO1]
Affzo [M:LPNA]
End



######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 26/01/2018 10:24:02 (MAE)
######################################################################################
Subprog AM_MODAFFLPN(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  Actzo [M:LPNA]25
Else
  [M:LPNA]LPNDESH = AVOID.ACHAR
  [M:LPNA]LOCDESH = AVOID.ACHAR
  [M:LPNA]TCTRNUMH = AVOID.ACHAR
  [M:LPNA]MONITMFLG = 1
  [M:LPNA]MONLOTFLG = 1
  If dim([M:LPNA]WRHDES)>0 : [M:LPNA]WRHDESH  = AVOID.ACHAR : Endif
  Chgstl [M:LPNA]LPNDESH With ""
  Affzo [M:LPNA]25
  Grizo [M:LPNA]25
  Actzo [M:LPNA]MODAFFLPN
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNAFF) 29/01/2018 08:46:35 (MAE)
######################################################################################
Subprog AM_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
  Read [LPN]LPN0 = VALEUR
  [M:LPNA]TCTRNUM(nolign-1) = [F:LPN]TCTRNUM
  [M:LPNA]LOCDES(nolign-1) = [F:LPN]LOC
  If [F:LPN]LOC <> AVOID.ACHAR
    If [F:LPN]LPNSTAT = 2
      Diszo [M:LPNA]LOCDES(nolign-1)
      Chgstl [M:LPNA]LPNNUMDES(nolign-1) With "BACKORANGE"
      #controle de l'emplacement du LPN : s'il a du stock, il n'est pas modifiable
      Call STKCTREMP([M:LPNA]WLOCSEQ,36,"",[M:LPNA]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNA]LOCTYPDES(nolign-1),[M:LPNA]LOCDES(nolign-1),"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
    Else
      Actzo [M:LPNA]LOCDES(nolign-1)
      zonsui = [M:LPNA]LOCDES(nolign-1)
      Chgstl [M:LPNA]LPNNUMDES(nolign-1) With ""
    Endif
    #lecture de l'emplacement pour le type d'emplacement
    Read [STC]STC0 = [M:LPNA]STOFCY;[F:LPN]LOC
    [M:LPNA]LOCTYPDES(nolign-1) = [F:STC]LOCTYP
    If dim([M:LPNA]WRHDESH)>0 : [M:LPNA]WRHDES(nolign-1)= [F:STC]WRH : Endif
    Filter [STO1]
  Else
    Actzo [M:LPNA]LOCDES(nolign-1)
    Chgstl [M:LPNA]LPNNUMDES(nolign-1) With ""
  Endif
Endif

End


