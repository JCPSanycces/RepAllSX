#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------#
# DOSDICASW   Filling the dictionary of Representation
#------------------------------------------------------------#

$DICASW
Call ECR_TIME(mess(15,125,1)-mess(255,125,1)) From DOSSUB
# MAJ dictionnaire - Classes représentations

Local File =GDOSREF+".ASHW"       [ASW]
&         ,=GDOSREF+".ASHWFLD"    [ASWF]
&         ,=GDOSREF+".ASHWPAR"    [ASWP]
&         ,=GDOSREF+".ASHWOPT"    [ASWO]
&         ,=GDOSREF+".ASHWCOL"    [ASWC]
&         ,=GDOSREF+".ASHWSEC"    [ASWS]
&         ,=GDOSREF+".ASHWBLC"    [ASWB]
&         ,=GDOSREF+".ASHWMENU"   [ASWMN]
&         ,=GDOSREF+".ASHWMET"    [ASWM]
&         ,=GDOSREF+".ASHWPARMET" [ASWMP]
&         ,=GDOSREF+".ASHWEXPPRO" [ASWR]
&         ,=GDOSREF+".ASHWLNK"    [ASWK]
Local File =[F:ADS]DOSSIER+".ASHW"       [DASW]
&         ,=[F:ADS]DOSSIER+".ASHW"       [DASW2]
&         ,=[F:ADS]DOSSIER+".ASHW"       [DASW3]
&         ,=[F:ADS]DOSSIER+".ASHWFLD"    [DASWF]
&         ,=[F:ADS]DOSSIER+".ASHWFLD"    [DASWF2]
&         ,=[F:ADS]DOSSIER+".ASHWPAR"    [DASWP]
&         ,=[F:ADS]DOSSIER+".ASHWOPT"    [DASWO]
&         ,=[F:ADS]DOSSIER+".ASHWCOL"    [DASWC]
&         ,=[F:ADS]DOSSIER+".ASHWSEC"    [DASWS]
&         ,=[F:ADS]DOSSIER+".ASHWBLC"    [DASWB]
&         ,=[F:ADS]DOSSIER+".ASHWMENU"   [DASWMN]
&         ,=[F:ADS]DOSSIER+".ASHWMET"    [DASWM]
&         ,=[F:ADS]DOSSIER+".ASHWPARMET" [DASWMP]
&         ,=[F:ADS]DOSSIER+".ASHWEXPPRO" [DASWR]
&         ,=[F:ADS]DOSSIER+".ASHWLNK"    [DASWK]
&         ,=[F:ADS]DOSSIER+".ACTIV"      [DACV]
&         ,=[F:ADS]DOSSIER+".ACLAOPT"    [DACLAO]

Local Integer B,I,J,WTYPPAR,WAFFLNK,OK_LNK
Local Char WCODFLD(GLONAVC),WCODLNK(GLONAVB)
Local Integer WENAFAC(10)

Local Integer WNBFLDGRPPRO
Local Char WFLDGRPPRO(GLONAVC)(1..)

Local Integer WNBEXPPRO
Local Char WEXPPRO(GLONAVC)(1..)

Local Integer WNBCOL
Local Char WCOL(GLONAVC)(1..)

Local Char WBLC(20),WSEC(20)
Local Char WREP(GLONASW)

#95271
Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR, RES_NO
Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(30)(0..)
Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..), WWNBRPARALL
#

Local Char WACTBLC (GLONACV), WACTSEC(GLONACV)
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(255,125,1),"") From GESECRAN
Endif

GNBASW = 0

## Deleting old Representation

If !GCRE
 Trbegin [DASW] , [DASWF], [DASWP], [DASWO],[DASWC],[DASWS],[DASWB], [DASWMN],[DASWM], [DASWMP], [DASWR], [DASWK]
  For [DASW]ASW0 Where CODREP<GXX
   Call SPEC([F:DASW]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ASW]ASW0 = [F:DASW]CODREP
    If fstat
     Call EFFACE([F:DASW]CODREP)
    Endif
   Endif
  Next
 Commit
Endif

## Update of Representation

Filter [ASW] Where CODREP<GXX
Read [ASW]ASW0 First
While fstat<=2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(255,125,1),[F:ASW]CODREP) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DASW] , [DASWF], [DASWP], [DASWO],[DASWC],[DASWS],[DASWB], [DASWMN],[DASWM], [DASWMP], [DASWR], [DASWK]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DASW]ASW0 = [F:ASW]CODREP
  If !fstat
   OLD = 1
   Call SPEC([F:DASW]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ASW]CODACT,[F:ASW]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC

    Call EFFACE([F:ASW]CODREP)

   Elsif NEWREC & !OLD

    Raz [F:DASW]
    RWO = 1
    [F:DASW] = [F:ASW]
    [F:DASW]CREUSR = GUSER
    GNBASW += 1
    Write [DASW]
    If fstat : Call ERREUR("ASHW"-[F:DASW]CODREP,1) From DOSDIC : Endif
    For [ASWF]ASWF0 Where CODREP=[F:ASW]CODREP
     [F:DASWF] = [F:ASWF]
     Write [DASWF]
     If fstat : Call ERREUR("ASHWFLD"-[F:DASWF]CODREP-[F:DASWF]CODFLD,1) From DOSDIC : Endif
    Next
    For [ASWP]ASWP0 Where CODREP=[F:ASW]CODREP
     [F:DASWP] = [F:ASWP]
     Write [DASWP]
     If fstat : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&         func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&         ,1) From DOSDIC
     Endif
    Next
    For [ASWO]ASWO0 Where CODREP=[F:ASW]CODREP
     [F:DASWO] = [F:ASWO]
     Write [DASWO]
     If fstat : Call ERREUR("ASHWOPT"-[F:DASWO]CODREP,1) From DOSDIC : Endif
    Next
    For [ASWC]ASWC0 Where CODREP=[F:ASW]CODREP
     [F:DASWC] = [F:ASWC]
     Write [DASWC]
     If fstat : Call ERREUR("ASHWCOL"-[F:DASWC]CODREP,1) From DOSDIC : Endif
    Next
    For [ASWS]ASWS0 Where CODREP=[F:ASW]CODREP
     [F:DASWS] = [F:ASWS]
     Write [DASWS]
     If fstat : Call ERREUR("ASHWSEC"-[F:DASWS]CODREP,1) From DOSDIC : Endif
    Next
    For [ASWB]ASWB0 Where CODREP=[F:ASW]CODREP
     [F:DASWB] = [F:ASWB]
     Write [DASWB]
     If fstat : Call ERREUR("ASHWBLC"-[F:DASWB]CODREP,1) From DOSDIC : Endif
    Next
    For [ASWMN]ASWMN0 Where CODREP=[F:ASW]CODREP
     [F:DASWMN] = [F:ASWMN]
     Write [DASWMN]
     If fstat : Call ERREUR("ASHWMENU"-[F:DASWMN]CODREP-[F:DASWMN]CODMENU,1) From DOSDIC : Endif
    Next
    For [ASWM]ASWM0 Where CODREP=[F:ASW]CODREP
     [F:DASWM] = [F:ASWM]
     Write [DASWM]
     If fstat : Call ERREUR("ASHWMET"-[F:DASWM]CODREP-[F:DASWM]CODMET,1) From DOSDIC : Endif
    Next
    For [ASWMP]ASWMP0 Where CODREP=[F:ASW]CODREP
     [F:DASWMP] = [F:ASWMP]
     Write [DASWMP]
     If fstat : Call ERREUR("ASHWPARMET"-[F:DASWMP]CODREP-[F:DASWMP]CODMET-[F:DASWMP]CODPARMET,1) From DOSDIC : Endif
    Next
    For [ASWR]ASWR0 Where CODREP=[F:ASW]CODREP
     [F:DASWR] = [F:ASWR]
     Write [DASWR]
     If fstat : Call ERREUR("ASHWEXPPRO"-[F:DASWR]CODREP-[F:DASWR]ALIAS-[F:DASWR]CODPRO-num$([F:DASWR]NUMPRO),1) From DOSDIC : Endif
    Next
    For [ASWK]ASWK0 Where CODREP=[F:ASW]CODREP
     [F:DASWK] = [F:ASWK]
     Write [DASWK]
     If fstat : Call ERREUR("ASHWLNK"-[F:DASWK]CODREP-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:DASWK]AFFLNK,[F:DASWK]ANCLNK,[F:DASWK]CODLNK)
&             ,1) From DOSDIC : Endif
    Next

   Elsif NEWREC & OLD

    Raz WNBFLDGRPPRO,WNBEXPPRO,WNBCOL
    Raz WFLDGRPPRO,WEXPPRO,WCOL
    WENAFAC(0)=1 : WENAFAC(1)=1 : WENAFAC(2)=1 : WENAFAC(3)=1 : WENAFAC(4)=1 : WENAFAC(5)=1
    WENAFAC(6)=1 : WENAFAC(6)=1 : WENAFAC(6)=1 : WENAFAC(9)=1
    DIFF = 0

    ## Compare the header

    If [F:ASW]ABRCLA     <>  [F:DASW]ABRCLA     : DIFF = 1 : Endif
    If [F:ASW]INTREP     <>  [F:DASW]INTREP     : DIFF = 1 : Endif
    If [F:ASW]CODACT     <>  [F:DASW]CODACT     : DIFF = 1 : Endif
    If [F:ASW]MODULE     <>  [F:DASW]MODULE     : DIFF = 1 : Endif
    If [F:ASW]TYPREP     <>  [F:DASW]TYPREP     : DIFF = 1 : Endif
    If [F:ASW]DEFREP     <>  [F:DASW]DEFREP     : DIFF = 1 : Endif
    If [F:ASW]TYPMSKREP  <>  [F:DASW]TYPMSKREP  : DIFF = 1 : Endif
    If [F:ASW]CODCLA     <>  [F:DASW]CODCLA     : DIFF = 1 : Endif
    If [F:ASW]FONCTION   <>  [F:DASW]FONCTION   : DIFF = 1 : Endif
    If [F:ASW]AFCRIGHT   <>  [F:DASW]AFCRIGHT   : DIFF = 1 : Endif
    If [F:ASW]FLGSYSTEM  <>  [F:DASW]FLGSYSTEM  : DIFF = 1 : Endif

    If [F:ASW]DESCRIPT   <> [F:DASW]DESCRIPT      : DIFF = 1 : Endif
    If [F:ASW]CODIND     <> [F:DASW]CODIND      : DIFF = 1 : Endif
    If [F:ASW]NBRTRT     <> [F:DASW]NBRTRT      : DIFF = 1 : Endif
    If [F:ASW]NBRFAC     <> [F:DASW]NBRFAC      : DIFF = 1 : Endif
    If [F:ASW]NBRCOM     <> [F:DASW]NBRCOM      : DIFF = 1 : Endif

    If !DIFF : Call TXT([F:ASW]INTREP,DIFF) From DOSSUB : Endif

    ## Comparison of treatments
    If !DIFF
     For B=0 To [F:ASW]NBRTRT-1
      If [F:ASW]CODTRT(B) <> [F:DASW]CODTRT(B) | !find([F:DASW]ACTTRT(B),GSPE(1..GNBSPE))
       If [F:ASW]CODTRT(B) <> [F:DASW]CODTRT(B)     : DIFF = 1 : Endif
       If [F:ASW]TYPTRT(B) <> [F:DASW]TYPTRT(B)     : DIFF = 1 : Endif
       If [F:ASW]ACTTRT(B) <> [F:DASW]ACTTRT(B)     : DIFF = 1 : Endif
       If [F:ASW]RANTRT(B) <> [F:DASW]RANTRT(B)     : DIFF = 1 : Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:ASW]ACTTRT(B),ACTIV) From DOSSUB
     Next B
    Endif

    ## Comparison of behavior
    If !DIFF
     For B=0 To [F:ASW]NBRCOM-1
       If [F:ASW]CODCOM(B) <> [F:DASW]CODCOM(B)     : DIFF = 1 : Endif
       If [F:ASW]ENACOM(B) <> [F:DASW]ENACOM(B)     : DIFF = 1 : Endif
     Next B
    Endif

    #--------------------------------#
    # Comparison and update options

    For [ASWO]ASWO0 Where CODREP=[F:ASW]CODREP
     Read [DASWO]ASWO0=[F:ASWO]CODREP;[F:ASWO]OPTCOD
     If fstat
      DIFF = 1
      [F:DASWO] = [F:ASWO]
      Write [DASWO]
      If fstat : Call ERREUR("ASHWOPT"-[F:ASWO]CODREP-[F:ASWO]OPTCOD,1) From DOSDIC : Endif
     Else
       RW = 0
       If [F:DASWO]OPTFLGCLA=2
         Read [DACLAO]ACLAO0=[F:ASW]CODCLA;[F:DASWO]OPTCOD
         If !fstat & !find([F:DACLAO]OPTACT,GSPE(1..GNBSPE))
          # non-specific option, comparison
          Call DIFFACT([F:ADS]DOSSIER,[F:ASWO]OPTACT,ACTIV) From DOSSUB
          If [F:ASWO]OPTFLGCLA   <> [F:DASWO]OPTFLGCLA  : RW = 1 : Endif
          If [F:ASWO]OPTLIB      <> [F:DASWO]OPTLIB     : RW = 1 : Endif
          If [F:ASWO]OPTCND      <> [F:DASWO]OPTCND     : RW = 1 : Endif
          If [F:ASWO]OPTERR      <> [F:DASWO]OPTERR     : RW = 1 : Endif
          If [F:ASWO]OPTACT      <> [F:DASWO]OPTACT     : RW = 1 : Endif
          If [F:ASWO]OPTOBY      <> [F:DASWO]OPTOBY     : RW = 1 : Endif
          If [F:ASWO]OPTDEF      <> [F:DASWO]OPTDEF     : RW = 1 : Endif

          If !RW : Call TXT([F:ASWO]OPTLIB,RW) From DOSSUB : Endif
          If !RW : Call TXT([F:ASWO]OPTERR,RW) From DOSSUB : Endif
         Endif
       Elsif !find([F:DASWO]OPTACT,GSPE(1..GNBSPE))
          # non-specific option, comparison
          Call DIFFACT([F:ADS]DOSSIER,[F:ASWO]OPTACT,ACTIV) From DOSSUB
          If [F:ASWO]OPTFLGCLA   <> [F:DASWO]OPTFLGCLA  : RW = 1 : Endif
          If [F:ASWO]OPTLIB      <> [F:DASWO]OPTLIB     : RW = 1 : Endif
          If [F:ASWO]OPTCND      <> [F:DASWO]OPTCND     : RW = 1 : Endif
          If [F:ASWO]OPTERR      <> [F:DASWO]OPTERR     : RW = 1 : Endif
          If [F:ASWO]OPTACT      <> [F:DASWO]OPTACT     : RW = 1 : Endif
          If [F:ASWO]OPTOBY      <> [F:DASWO]OPTOBY     : RW = 1 : Endif
          If [F:ASWO]OPTDEF      <> [F:DASWO]OPTDEF     : RW = 1 : Endif

          If !RW : Call TXT([F:ASWO]OPTLIB,RW) From DOSSUB : Endif
          If !RW : Call TXT([F:ASWO]OPTERR,RW) From DOSSUB : Endif
       Endif

      If RW
       DIFF  = 1
       [F:DASWO] = [F:ASWO]
       Rewrite [DASWO]
       If fstat : Call ERREUR("ASHWOPT"-[F:DASWO]CODREP-[F:DASWO]OPTCOD,2) From DOSDIC : Endif
      Endif
     Endif
    Next ASWO

    # removal of excess options

    For [DASWO]ASWO0 Where CODREP=[F:ASW]CODREP
     If [F:DASWO]OPTFLGCLA=2
       Read [DACLAO]ACLAO0=[F:ASW]CODCLA;[F:DASWO]OPTCOD
       If fstat
         Delete [DASWO]
         If fstat=1 : Call ERREUR("ASHWOPT"-[F:DASWO]CODREP-[F:DASWO]OPTCOD,3) From DOSDIC : Endif
       Elsif !find([F:DACLAO]OPTACT,GSPE(1..GNBSPE))
        Read [ASWO]ASWO0=[F:DASWO]CODREP;[F:DASWO]OPTCOD
        If fstat
         Delete [DASWO]
         If fstat=1 : Call ERREUR("ASHWOPT"-[F:DASWO]CODREP-[F:DASWO]OPTCOD,3) From DOSDIC : Endif
        Endif
       Endif
     Else
       If !find([F:DASWO]OPTACT,GSPE(1..GNBSPE))
        Read [ASWO]ASWO0=[F:DASWO]CODREP;[F:DASWO]OPTCOD
        If fstat
         Delete [DASWO]
         If fstat=1 : Call ERREUR("ASHWOPT"-[F:DASWO]CODREP-[F:DASWO]OPTCOD,3) From DOSDIC : Endif
        Endif
       Endif
     Endif
    Next DASWO

    # --------------------------------#
    ## Comparison and update fields

    For [ASWF]ASWF0 Where CODREP=[F:ASW]CODREP
     Read [DASWF]ASWF0 = [F:ASWF]CODREP;[F:ASWF]CODFLD

     If fstat
      DIFF = 1
      [F:DASWF] = [F:ASWF]
      Write [DASWF]
      If fstat : Call ERREUR("ASHWFLD"-[F:DASWF]CODREP-[F:DASWF]CODFLD,1) From DOSDIC : Endif
      WTYPPAR=1
      WAFFLNK=1
      WCODFLD=[F:ASWF]CODFLD
      WCODLNK=""
      Gosub CREPAR
      WTYPPAR=2
      WAFFLNK=1
      WCODFLD=[F:ASWF]CODFLD
      WCODLNK=""
      Gosub CREPAR

     Elsif !find([F:DASWF]ACTFLD,GSPE(1..GNBSPE))

      # non-specific field, comparison

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ASWF]ACTFLD,ACTIV) From DOSSUB
      If [F:ASWF]NUMLIG   <> [F:DASWF]NUMLIG       : RW = 1 : Endif
      If [F:ASWF]NUMFLD   <> [F:DASWF]NUMFLD       : RW = 1 : Endif
      If [F:ASWF]INTFLD   <> [F:DASWF]INTFLD       : RW = 1 : Endif
      If [F:ASWF]INTSHTFLD<> [F:DASWF]INTSHTFLD    : RW = 1 : Endif
      If [F:ASWF]ACTFLD   <> [F:DASWF]ACTFLD       : RW = 1 : Endif
      If [F:ASWF]CODTYP   <> [F:DASWF]CODTYP       : RW = 1 : Endif

      If [F:ASWF]LONG     <> [F:DASWF]LONG         : RW = 1 : Endif
      If [F:ASWF]OBLIG    <> [F:DASWF]OBLIG        : RW = 1 : Endif
      If [F:ASWF]NOLIB    <> [F:DASWF]NOLIB        : RW = 1 : Endif
      If [F:ASWF]ACS      <> [F:DASWF]ACS          : RW = 1 : Endif
      If [F:ASWF]CODCTL   <> [F:DASWF]CODCTL       : RW = 1 : Endif
      If [F:ASWF]TABCONT  <> [F:DASWF]TABCONT      : RW = 1 : Endif
      If [F:ASWF]FLDGRP   <> [F:DASWF]FLDGRP       : RW = 1 : Endif
      If [F:ASWF]FLGACCGET<> [F:DASWF]FLGACCGET    : RW = 1 : Endif
      If [F:ASWF]INTEVAL  <> [F:DASWF]INTEVAL      : RW = 1 : Endif
      If [F:ASWF]LOBTAB   <> [F:DASWF]LOBTAB       : RW = 1 : Endif
      If [F:ASWF]LOBFLD   <> [F:DASWF]LOBFLD       : RW = 1 : Endif
      If [F:ASWF]LOBCNT   <> [F:DASWF]LOBCNT       : RW = 1 : Endif

      If !RW : Call TXT([F:ASWF]INTFLD,RW) From DOSSUB : Endif
      If !RW : Call TXT([F:ASWF]INTSHTFLD,RW) From DOSSUB : Endif

      If RW
       DIFF  = 1
       [F:DASWF2] = [F:DASWF]
       [F:DASWF] = [F:ASWF]
       If [F:DASWF2]CODCTL<>""
        [F:DASWF]CODCTL  = [F:DASWF2]CODCTL
        [F:DASWF]TABCONT  = [F:DASWF2]TABCONT
       Endif : # Table de contrôle
       # On conserve le code d'accès
       # On conserve le code d'accès sauf s'il commence par un "/"
       If left$([F:DASWF2]ACS,1)<>"/"
        [F:DASWF]ACS  = [F:DASWF2]ACS
       Endif
       Rewrite [DASWF]
       If fstat : Call ERREUR("ASHWFLD"-[F:DASWF]CODREP-[F:DASWF]CODFLD,2) From DOSDIC : Endif
      Endif

      # update or creation of field parameters

      For [ASWP]ASWP0 Where CODREP=[F:ASWF]CODREP & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:ASWF]CODFLD
       Read [DASWP]ASWP0 = [F:ASWP]CODREP;[F:ASWP]TYPPAR;[F:ASWP]TYPKEY;[F:ASWP]CODFLD;"";1;[F:ASWP]CODPAR
       If fstat
        DIFF = 1
        [F:DASWP] = [F:ASWP]
        Write [DASWP]
        If fstat : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&         func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&         ,1) From DOSDIC
        Endif
       Else
        RW = 0
        If [F:ASWP]AFFLNK   <> [F:DASWP]AFFLNK   : RW = 57 : Endif
        If [F:ASWP]NUMPAR   <> [F:DASWP]NUMPAR   : RW = 57 : Endif
        If [F:ASWP]INTVAL   <> [F:DASWP]INTVAL   : RW = 57 : Endif
        If [F:ASWP]VALEUR   <> [F:DASWP]VALEUR   : RW = 57 : Endif
        If [F:ASWP]TYPINT   <> [F:DASWP]TYPINT   : RW = 57 : Endif
        If [F:ASWP]ADRVAL   <> [F:DASWP]ADRVAL   : RW = 57 : Endif
        If [F:ASWP]TYPAFF   <> [F:DASWP]TYPAFF   : RW = 57 : Endif
        If [F:ASWP]NOLIB    <> [F:DASWP]NOLIB    : RW = 57 : Endif
        If [F:ASWP]LNG      <> [F:DASWP]LNG      : RW = 57 : Endif
        If [F:ASWP]PARFIL   <> [F:DASWP]PARFIL   : RW = 57 : Endif
        If [F:ASWP]PARENT   <> [F:DASWP]PARENT   : RW = 57 : Endif

        If RW
         DIFF = RW
         [F:DASWP] = [F:ASWP]
         Rewrite [DASWP]
         If fstat : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&         func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&         ,2) From DOSDIC
         Endif
        Endif
       Endif
      Next ASWP

      #95271
      Gosub FILL_FLD_PAR

      # removal of excess field parameters

      For [DASWP]ASWP0  Where CODREP=[F:ASWF]CODREP & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:ASWF]CODFLD
       Read [ASWP]ASWP0 = [F:DASWP]CODREP;[F:DASWP]TYPPAR;[F:DASWP]TYPKEY;[F:DASWP]CODFLD;"";1;[F:DASWP]CODPAR
       #95271
       If fstat & ([F:DASWP]TYPPAR=2
&          | ([F:DASWP]TYPPAR=1 & [F:DASWP]TYPKEY=2 & !find([F:DASWP]CODPAR,WWCODPAR(0..[L]WWNBRPARALL-1)))
&          | ([F:DASWP]TYPPAR=1 & [F:DASWP]TYPKEY<>2 & !find([F:DASWP]CODPAR,RES_COD(0..[L]RES_NBR-1)))
&                 )
        Delete [DASWP]
        If fstat=1 : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&         func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&         ,3) From DOSDIC
        Endif
       Endif
      Next DASWP

     Endif
    Next ASWF

    # removal of excess fields

    For [DASWF]ASWF0 Where CODREP=[F:ASW]CODREP
     If !find([F:DASWF]ACTFLD,GSPE(1..GNBSPE))
      Read [ASWF]ASWF0=[F:ASW]CODREP;[F:DASWF]CODFLD
      If fstat
       DIFF = 1
       Delete [DASWP] Where CODREP=[F:DASWF]CODREP & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:DASWF]CODFLD
       If fstat=1 : Call ERREUR("ASHWPAR"-[F:DASWF]CODREP-"1"-[F:DASWF]CODFLD,3) From DOSDIC : Endif
       Delete [DASWF]
       If fstat=1 : Call ERREUR("ASHWFLD"-[F:DASWF]CODREP-[F:DASWF]CODFLD,3) From DOSDIC : Endif
      Endif
     Endif
    Next DASWF

    # --------------------------------#
    # Comparison and update menus

    For [ASWMN]ASWMN0 Where CODREP=[F:ASW]CODREP
     Read [DASWMN]ASWMN0=[F:ASWMN]CODREP;[F:ASWMN]CODMENU
     If fstat
      DIFF = 1
      [F:DASWMN] = [F:ASWMN]
      Write [DASWMN]
      If fstat : Call ERREUR("ASHWMENU"-[F:ASWMN]CODREP-[F:ASWMN]CODMENU,1) From DOSDIC : Endif
     Elsif !find([F:DASWMN]ACTMENU,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ASWMN]ACTMENU,ACTIV) From DOSSUB
      RW = 0
      If [F:ASWMN]LIBMENU   <> [F:DASWMN]LIBMENU   : RW = 58 : Endif
      If [F:ASWMN]PARMENU   <> [F:DASWMN]PARMENU   : RW = 58 : Endif
      If [F:ASWMN]ACTMENU   <> [F:DASWMN]ACTMENU   : RW = 58 : Endif
      If [F:ASWMN]ORDMENU   <> [F:DASWMN]ORDMENU   : RW = 58 : Endif
      If !RW : Call TXT([F:ASWMN]LIBMENU,RW) From DOSSUB : Endif
      If RW
       DIFF = RW
       [F:DASWMN] = [F:ASWMN]
       Rewrite [DASWMN]
       If fstat : Call ERREUR("ASHWMENU"-[F:ASWMN]CODREP-[F:ASWMN]CODMENU,2) From DOSDIC : Endif
      Endif
     Endif
    Next ASWMN

    # removal of excess MENU

    For [DASWMN]ASWMN0 Where CODREP=[F:ASW]CODREP
     If !find([F:DASWMN]ACTMENU,GSPE(1..GNBSPE))
      Read [ASWMN]ASWMN0=[F:DASWMN]CODREP;[F:DASWMN]CODMENU
      If fstat
       Delete [DASWMN]
       If fstat=1 : Call ERREUR("ASHWMENU"-[F:DASWMN]CODREP-[F:DASWMN]CODMENU,3) From DOSDIC : Endif
      Endif
     Endif
    Next DASWMN

    # --------------------------------#
    # Comparison and update methods

    For [ASWM]ASWM0 Where CODREP=[F:ASW]CODREP
     Read [DASWM]ASWM0=[F:ASWM]CODREP;[F:ASWM]CODMET
     If fstat
      DIFF = 1
      [F:DASWM] = [F:ASWM]
      Write [DASWM]
      If fstat : Call ERREUR("ASHWMET"-[F:ASWM]CODREP-[F:ASWM]CODMET,1) From DOSDIC : Endif
      Gosub CREPARMET
     Elsif !find([F:DASWM]ACTMET,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ASWM]ACTMET,ACTIV) From DOSSUB
      RW = 0
      If [F:ASWM]NOMET    <> [F:DASWM]NOMET    : RW = 58 : Endif
      If [F:ASWM]DONMET   <> [F:DASWM]DONMET   : RW = 58 : Endif
      If [F:ASWM]INTMET   <> [F:DASWM]INTMET   : RW = 58 : Endif
      If [F:ASWM]ACTMET   <> [F:DASWM]ACTMET   : RW = 58 : Endif
      #If [F:ASWM]HLPMET   <> [F:DASWM]HLPMET   : RW = 58 : Endif
      If !RW : Call TXT([F:ASWM]INTMET,RW) From DOSSUB : Endif
      If RW
       DIFF = RW
       [F:DASWM] = [F:ASWM]
       Rewrite [DASWM]
       If fstat : Call ERREUR("ASHWMET"-[F:ASWM]CODREP-[F:ASWM]CODMET,2) From DOSDIC : Endif
      Endif

      # update or creation of method parameters

      For [ASWMP]ASWMP0 Where CODREP=[F:ASWM]CODREP & CODMET=[F:ASWM]CODMET
       Read [DASWMP]ASWMP0 = [F:ASWMP]CODREP;[F:ASWMP]CODMET;[F:ASWMP]CODPARMET
       If fstat
        DIFF = 1
        [F:DASWMP] = [F:ASWMP]
        Write [DASWMP]
        If fstat : Call ERREUR("ASHWPARMET"-[F:DASWMP]CODREP-[F:DASWMP]CODMET-[F:DASWMP]CODPARMET,1) From DOSDIC : Endif
       Else
        RW = 0
        If [F:ASWMP]NOPARMET <> [F:DASWMP]NOPARMET : RW = 59 : Endif
        If [F:ASWMP]TYPPARMET<> [F:DASWMP]TYPPARMET: RW = 59 : Endif
        If [F:ASWMP]INTPARMET<> [F:DASWMP]INTPARMET: RW = 59 : Endif
        If [F:ASWMP]CLAPARMET<> [F:DASWMP]CLAPARMET: RW = 59 : Endif
        If [F:ASWMP]MODPARMET<> [F:DASWMP]MODPARMET: RW = 59 : Endif
        If [F:ASWMP]DIMPARMET<> [F:DASWMP]DIMPARMET: RW = 59 : Endif
        If !RW : Call TXT([F:ASWMP]INTPARMET,RW) From DOSSUB : Endif
        If RW
         DIFF = RW
         [F:DASWMP] = [F:ASWMP]
         Rewrite [DASWMP]
         If fstat : Call ERREUR("ASHWPARMET"-[F:DASWMP]CODREP-[F:DASWMP]CODMET-[F:DASWMP]CODPARMET,2) From DOSDIC : Endif
        Endif
       Endif
      Next ASWMP

      # removal of excess method parameters

      For [DASWMP]ASWMP0  Where CODREP=[F:ASWM]CODREP & CODMET=[F:ASWM]CODMET
       Read [ASWMP]ASWMP0 = [F:DASWMP]CODREP;[F:DASWMP]CODMET;[F:DASWMP]CODPARMET
       If fstat
        Delete [DASWMP]
        If fstat=1 : Call ERREUR("ASHWPARMET"-[F:DASWMP]CODREP-[F:DASWMP]CODMET-[F:DASWMP]CODPARMET,3) From DOSDIC : Endif
       Endif
      Next DASWMP

     Endif
    Next ASWM

    # removal of excess methods

    For [DASWM]ASWM0 Where CODREP=[F:ASW]CODREP
     If !find([F:DASWM]ACTMET,GSPE(1..GNBSPE))
      Read [ASWM]ASWM0=[F:DASWM]CODREP;[F:DASWM]CODMET
      If fstat
       Delete [DASWMP] Where CODREP=[F:DASWM]CODREP & CODMET=[F:DASWM]CODMET
       If fstat=1 : Call ERREUR("ASHWPARMET"-[F:DASWM]CODREP-[F:DASWM]CODMET,3) From DOSDIC : Endif
       Delete [DASWM]
       If fstat=1 : Call ERREUR("ASHWMET"-[F:DASWM]CODREP-[F:DASWM]CODMET,3) From DOSDIC : Endif
      Endif
     Endif
    Next DASWM

    #--------------------------------#
    # Comparison and update sections

    For [ASWS]ASWS0 Where CODREP=[F:ASW]CODREP
     Read [DASWS]ASWS0=[F:ASWS]CODREP;[F:ASWS]CODSEC
     If fstat
      DIFF = 1
      [F:DASWS] = [F:ASWS]
      Write [DASWS]
      If fstat : Call ERREUR("ASHWSEC"-[F:ASWS]CODREP-[F:ASWS]CODSEC,1) From DOSDIC : Endif
     Elsif !find([F:DASWS]ACTSEC,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ASWS]ACTSEC,ACTIV) From DOSSUB
      RW = 0

       If [F:ASWS]CODSEC <> [F:DASWS]CODSEC     : RW = 55 : Endif
       If [F:ASWS]ACTSEC <> [F:DASWS]ACTSEC     : RW = 55 : Endif
       If [F:ASWS]NIVSEC <> [F:DASWS]NIVSEC     : RW = 55 : Endif
       If [F:ASWS]INTSEC <> [F:DASWS]INTSEC     : RW = 55 : Endif
       If !RW : Call TXT([F:ASWS]INTSEC,RW) From DOSSUB : Endif

      If RW
       DIFF = RW
       [F:DASWS] = [F:ASWS]
       Rewrite [DASWS]
       If fstat : Call ERREUR("ASHWSEC"-[F:ASWS]CODREP-[F:ASWS]CODSEC,2) From DOSDIC : Endif
      Endif
     Endif
    Next ASWS

    #--------------------------------#
    # Comparison and update blocks

    For [ASWB]ASWB0 Where CODREP=[F:ASW]CODREP
     Read [DASWB]ASWB0=[F:ASWB]CODREP;[F:ASWB]CODBLC
     If fstat
      # new block, creation if not in a specific section
      WREP=[F:ASWB]CODREP
      WSEC=[F:ASWB]SECBLC
      Gosub FIND_ACTSEC
      If !find(WACTSEC,GSPE(1..GNBSPE))
        DIFF = 1
        [F:DASWB] = [F:ASWB]
        Write [DASWB]
        If fstat : Call ERREUR("ASHWBLC"-[F:ASWB]CODREP-[F:ASWB]CODBLC,1) From DOSDIC : Endif
      Endif
     Elsif !find([F:DASWB]ACTBLC,GSPE(1..GNBSPE))
      WREP=[F:ASWB]CODREP
      WSEC=[F:DASWB]SECBLC
      Gosub FIND_ACTSEC
      If !find(WACTSEC,GSPE(1..GNBSPE))
        Call DIFFACT([F:ADS]DOSSIER,[F:ASWB]ACTBLC,ACTIV) From DOSSUB
        RW = 0

         If [F:ASWB]CODBLC <> [F:DASWB]CODBLC     : RW = 56 : Endif
         If [F:ASWB]SECBLC <> [F:DASWB]SECBLC     : RW = 56 : Endif
         If [F:ASWB]ACTBLC <> [F:DASWB]ACTBLC     : RW = 56 : Endif
         If [F:ASWB]NIVBLC <> [F:DASWB]NIVBLC     : RW = 56 : Endif
         If [F:ASWB]INTBLC <> [F:DASWB]INTBLC     : RW = 56 : Endif
         If !RW : Call TXT([F:ASWB]INTBLC,RW) From DOSSUB : Endif

        If RW
         DIFF = RW
         [F:DASWB] = [F:ASWB]
         Rewrite [DASWB]
         If fstat : Call ERREUR("ASHWBLC"-[F:ASWB]CODREP-[F:ASWB]CODBLC,2) From DOSDIC : Endif
        Endif
      Endif
     Endif
    Next ASWB

    #--------------------------------#
    # Comparison and update collections

    For [ASWC]ASWC0 Where CODREP=[F:ASW]CODREP
     Read [DASWC]ASWC0=[F:ASWC]CODREP;[F:ASWC]CODCOL
     If fstat
      DIFF = 1
      [F:DASWC] = [F:ASWC]
      Write [DASWC]
      If fstat : Call ERREUR("ASHWCOL"-[F:ASWC]CODREP-[F:ASWC]CODCOL,1) From DOSDIC : Endif
     Elsif !find([F:DASWC]ACTCOL,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ASWC]ACTCOL,ACTIV) From DOSSUB
      RW = 0

       If [F:ASWC]CODCOL <> [F:DASWC]CODCOL     : RW = 54 : Endif
       If [F:ASWC]ALIASCOL <> [F:DASWC]ALIASCOL : RW = 54 : Endif
       If [F:ASWC]ACTCOL <> [F:DASWC]ACTCOL     : RW = 54 : Endif
       If [F:ASWC]MINCOL <> [F:DASWC]MINCOL     : RW = 54 : Endif
       If [F:ASWC]MAXCOL <> [F:DASWC]MAXCOL     : RW = 54 : Endif
       If [F:ASWC]PROCOL <> [F:DASWC]PROCOL     : RW = 54 : Endif
       If [F:ASWC]INTCOL <> [F:DASWC]INTCOL     : RW = 54 : Endif
       If [F:ASWC]FLGINSCOL <> [F:DASWC]FLGINSCOL     : RW = 54 : Endif
       If [F:ASWC]FLGSUPCOL <> [F:DASWC]FLGSUPCOL     : RW = 54 : Endif
       If [F:ASWC]FLGTRICOL <> [F:DASWC]FLGTRICOL     : RW = 54 : Endif
       If [F:ASWC]FLGAPDCOL <> [F:DASWC]FLGAPDCOL     : RW = 54 : Endif
       If !RW : Call TXT([F:ASWC]INTCOL,RW) From DOSSUB : Endif

      If RW
       DIFF = RW
       [F:DASWC] = [F:ASWC]
       Rewrite [DASWC]
       If fstat : Call ERREUR("ASHWCOL"-[F:ASWC]CODREP-[F:ASWC]CODCOL,2) From DOSDIC : Endif
      Endif
     Endif
    Next ASWC

    # --------------------------------#
    # Comparison and update properties

    For [ASWR]ASWR0 Where CODREP=[F:ASW]CODREP
     Read [DASWR]ASWR0=[F:ASWR]CODREP;[F:ASWR]ALIAS
     If fstat
      # new propertie, creation if not in a specific block/section
      WREP=[F:ASWR]CODREP
      WBLC=[F:ASWR]BLCPRO
      Gosub FIND_ACTBLCSEC
      If !find(WACTBLC,GSPE(1..GNBSPE)) & !find(WACTSEC,GSPE(1..GNBSPE))
        DIFF = 1
        [F:DASWR] = [F:ASWR]
        Write [DASWR]
        If fstat : Call ERREUR("ASHWEXPPRO"-[F:ASWR]CODREP-[F:ASWR]ALIAS-[F:ASWR]CODPRO-num$([F:ASWR]NUMPRO),1) From DOSDIC : Endif
      Endif
     Elsif !find([F:DASWR]ACTPRO,GSPE(1..GNBSPE))
      # old propertie, compare if not in a specific block/section
      WREP=[F:ASWR]CODREP
      WBLC=[F:DASWR]BLCPRO
      Gosub FIND_ACTBLCSEC
      If !find(WACTBLC,GSPE(1..GNBSPE)) & !find(WACTSEC,GSPE(1..GNBSPE))
        Call DIFFACT([F:ADS]DOSSIER,[F:ASWR]ACTPRO,ACTIV) From DOSSUB
        RW = 0
        If [F:ASWR]CODPRO   <> [F:DASWR]CODPRO   : RW = 58 : Endif
        If [F:ASWR]NUMPRO   <> [F:DASWR]NUMPRO   : RW = 58 : Endif
        If [F:ASWR]TAGPRO   <> [F:DASWR]TAGPRO   : RW = 58 : Endif
        If [F:ASWR]BLCPRO   <> [F:DASWR]BLCPRO   : RW = 58 : Endif
        If [F:ASWR]ALIAS    <> [F:DASWR]ALIAS    : RW = 58 : Endif
        If [F:ASWR]ORDPRO   <> [F:DASWR]ORDPRO   : RW = 58 : Endif
        If [F:ASWR]INTPRO   <> [F:DASWR]INTPRO   : RW = 58 : Endif
        If [F:ASWR]INTSHTPRO<> [F:DASWR]INTSHTPRO: RW = 58 : Endif
        If [F:ASWR]ACTPRO   <> [F:DASWR]ACTPRO   : RW = 58 : Endif
        If [F:ASWR]UOMPRO   <> [F:DASWR]UOMPRO   : RW = 58 : Endif
        If [F:ASWR]QRYPRO   <> [F:DASWR]QRYPRO   : RW = 58 : Endif
        If [F:ASWR]DETPRO   <> [F:DASWR]DETPRO   : RW = 58 : Endif
        If [F:ASWR]EDIPRO   <> [F:DASWR]EDIPRO   : RW = 58 : Endif
        If [F:ASWR]LOKPRO   <> [F:DASWR]LOKPRO   : RW = 58 : Endif
        If [F:ASWR]SUMPRO   <> [F:DASWR]SUMPRO   : RW = 58 : Endif
        If [F:ASWR]TYPAFFPRO<> [F:DASWR]TYPAFFPRO: RW = 58 : Endif
        #If [F:ASWR]STAINIPRO<> [F:DASWR]STAINIPRO: RW = 58 : Endif
        If [F:ASWR]STAQRYPRO<> [F:DASWR]STAQRYPRO: RW = 58 : Endif
        If [F:ASWR]STADETPRO<> [F:DASWR]STADETPRO: RW = 58 : Endif
        If [F:ASWR]STAEDIPRO<> [F:DASWR]STAEDIPRO: RW = 58 : Endif
        If [F:ASWR]STALOKPRO<> [F:DASWR]STALOKPRO: RW = 58 : Endif
        If [F:ASWR]STASUMPRO<> [F:DASWR]STASUMPRO: RW = 58 : Endif
        If [F:ASWR]PARFILPRO <> [F:DASWR]PARFILPRO   : RW = 58 : Endif
        If [F:ASWR]PARENTPRO <> [F:DASWR]PARENTPRO   : RW = 58 : Endif
        If [F:ASWR]INTEVALPRO<> [F:DASWR]INTEVALPRO  : RW = 58 : Endif
        If !RW : Call TXT([F:ASWR]INTPRO,RW) From DOSSUB : Endif
        If !RW : Call TXT([F:ASWR]INTSHTPRO,RW) From DOSSUB : Endif

        If RW
         DIFF = RW
         [F:DASWR] = [F:ASWR]
         Rewrite [DASWR]
         If fstat : Call ERREUR("ASHWEXPPRO"-[F:ASWR]CODREP-[F:ASWR]ALIAS-[F:ASWR]CODPRO-num$([F:ASWR]NUMPRO),2) From DOSDIC : Endif
        Endif

      Endif # (!SPE)
     Endif
    Next ASWR

    # removal of excess properties

    For [DASWR]ASWR0 Where CODREP=[F:ASW]CODREP
     # old propertie, compare if not in a specific block/section
     WBLC=[F:DASWR]BLCPRO
     Gosub FIND_ACTBLCSEC
     If !find([F:DASWR]ACTPRO,GSPE(1..GNBSPE)) & !find(WACTBLC,GSPE(1..GNBSPE)) & !find(WACTSEC,GSPE(1..GNBSPE))
      Read [ASWR]ASWR0=[F:DASWR]CODREP;[F:DASWR]ALIAS
      If fstat
       Delete [DASWR]
       If fstat=1 : Call ERREUR("ASHWEXPPRO"-[F:DASWR]CODREP-[F:DASWR]ALIAS-[F:DASWR]CODPRO-num$([F:DASWR]NUMPRO),3) From DOSDIC : Endif
      Else
        WNBFLDGRPPRO+=1
        WFLDGRPPRO(WNBFLDGRPPRO)=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_DOSS([F:ADS]DOSSIER,[F:DASW]CODREP,[F:DASW]CODCLA,[F:DASW]ABRCLA,[F:DASWR]CODPRO,1)
        WNBEXPPRO+=1
        WEXPPRO(WNBEXPPRO)=[F:DASWR]CODPRO
        If [F:DASWR]DETPRO=2 : WENAFAC(0)=2 : Endif
        If [F:DASWR]QRYPRO=2 : WENAFAC(2)=2 : Endif
        If [F:DASWR]EDIPRO=2 : WENAFAC(1)=2 : Endif
        If [F:DASWR]LOKPRO=2 : WENAFAC(3)=2 : Endif
        If [F:DASWR]SUMPRO=2 : WENAFAC(4)=2 : Endif
      Endif
     Else
      WNBFLDGRPPRO+=1
      WFLDGRPPRO(WNBFLDGRPPRO)=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_DOSS([F:ADS]DOSSIER,[F:DASW]CODREP,[F:DASW]CODCLA,[F:DASW]ABRCLA,[F:DASWR]CODPRO,1)
      WNBEXPPRO+=1
      WEXPPRO(WNBEXPPRO)=[F:DASWR]CODPRO
      If [F:DASWR]DETPRO=2 : WENAFAC(0)=2 : Endif
      If [F:DASWR]QRYPRO=2 : WENAFAC(2)=2 : Endif
      If [F:DASWR]EDIPRO=2 : WENAFAC(1)=2 : Endif
      If [F:DASWR]LOKPRO=2 : WENAFAC(3)=2 : Endif
      If [F:DASWR]SUMPRO=2 : WENAFAC(4)=2 : Endif
     Endif
    Next DASWR


    #--------------------------------#
    # removal of excess collections
    For [DASWC]ASWC0 Where CODREP=[F:ASW]CODREP
     If !find([F:DASWC]ACTCOL,GSPE(1..GNBSPE))
      #delete non-used collections
      # 118904
      #Read [ASWC]ASWC0=[F:DASWC]CODREP;[F:DASWC]CODCOL
      #If fstat
       J=0
       If WNBFLDGRPPRO>0
         J+=find([F:DASWC]CODCOL,WFLDGRPPRO(1..WNBFLDGRPPRO))
       Endif
       If J=0
        For [DASWF] Where CODREP=[F:DASW]CODREP & FLDGRP=[F:DASWC]CODCOL
          J=1
          Break
        Next
       Endif
       If J=0
         Delete [DASWC]
         If fstat=1 : Call ERREUR("ASHWCOL"-[F:DASWC]CODREP-[F:DASWC]CODCOL,3) From DOSDIC : Endif
       Else
        WNBCOL+=1
        WCOL(WNBCOL)=[F:DASWC]CODCOL
       Endif
     # 118904
     # Else
     #  WNBCOL+=1
     #  WCOL(WNBCOL)=[F:DASWC]CODCOL
     # Endif
     Else
      WNBCOL+=1
      WCOL(WNBCOL)=[F:DASWC]CODCOL
     Endif
    Next DASWC

    # --------------------------------#
    # Comparison and update Links

    For [ASWK]ASWK0 Where CODREP=[F:ASW]CODREP
     [L]OK_LNK=1
     Case [F:ASWK]AFFLNK
      When 1
        If !find([F:ASWK]ANCLNK,WEXPPRO(1..WNBEXPPRO)) : [L]OK_LNK=0 : Endif
      When 2,3
        If !find([F:ASWK]ANCLNK,WCOL(1..WNBCOL)) : [L]OK_LNK=0 : Endif
     Endcase

     Read [DASWK]ASWK0=[F:ASWK]CODREP;[F:ASWK]AFFLNK;[F:ASWK]ANCLNK;[F:ASWK]CODLNK
     If fstat
      If [L]OK_LNK=1
        DIFF = 1
        [F:DASWK] = [F:ASWK]
        Write [DASWK]
        If fstat : Call ERREUR("ASHWLNK"-[F:ASWK]CODREP-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:DASWK]AFFLNK,[F:DASWK]ANCLNK,[F:DASWK]CODLNK)
&             ,1) From DOSDIC : Endif
        WTYPPAR=3
        WAFFLNK=[F:ASWK]AFFLNK
        WCODFLD=[F:ASWK]ANCLNK
        WCODLNK=[F:ASWK]CODLNK
        Gosub CREPAR
      Endif
     Elsif !find([F:DASWK]ACVLNK,GSPE(1..GNBSPE))
      If [L]OK_LNK=1
        Call DIFFACT([F:ADS]DOSSIER,[F:ASWK]ACVLNK,ACTIV) From DOSSUB
        RW = 0
        If [F:ASWK]NUMLNK    <> [F:DASWK]NUMLNK    : RW = 58 : Endif
        If [F:ASWK]INTLNK    <> [F:DASWK]INTLNK    : RW = 58 : Endif
        If [F:ASWK]CMPLNK    <> [F:DASWK]CMPLNK    : RW = 58 : Endif
        If [F:ASWK]TARLNK    <> [F:DASWK]TARLNK    : RW = 58 : Endif
        If [F:ASWK]TYPLNK    <> [F:DASWK]TYPLNK    : RW = 58 : Endif
        If [F:ASWK]ANCLNK    <> [F:DASWK]ANCLNK    : RW = 58 : Endif
        If [F:ASWK]CODOPELNK <> [F:DASWK]CODOPELNK : RW = 58 : Endif
        If [F:ASWK]FLGASYLNK <> [F:DASWK]FLGASYLNK : RW = 58 : Endif
        If [F:ASWK]CODMETLNK <> [F:DASWK]CODMETLNK : RW = 58 : Endif
        If [F:ASWK]CODFNCLNK <> [F:DASWK]CODFNCLNK : RW = 58 : Endif
        If [F:ASWK]CLALNK    <> [F:DASWK]CLALNK    : RW = 58 : Endif
        If [F:ASWK]CLAPTRLNK <> [F:DASWK]CLAPTRLNK : RW = 58 : Endif
        If [F:ASWK]REPLNK    <> [F:DASWK]REPLNK    : RW = 58 : Endif
        If [F:ASWK]FREELNK   <> [F:DASWK]FREELNK   : RW = 58 : Endif
        If [F:ASWK]RPTCOD    <> [F:DASWK]RPTCOD    : RW = 58 : Endif :#104754/3
        If [F:ASWK]MENLNK    <> [F:DASWK]MENLNK    : RW = 58 : Endif
        If [F:ASWK]ORDLNK    <> [F:DASWK]ORDLNK    : RW = 58 : Endif
        If [F:ASWK]ORDTECLNK <> [F:DASWK]ORDTECLNK : RW = 58 : Endif
        If [F:ASWK]ATTLNK    <> [F:DASWK]ATTLNK    : RW = 58 : Endif
        If [F:ASWK]ACVLNK    <> [F:DASWK]ACVLNK    : RW = 58 : Endif
        If [F:ASWK]AFFLNK    <> [F:DASWK]AFFLNK    : RW = 58 : Endif
        If [F:ASWK]FLGSTDLNK <> [F:DASWK]FLGSTDLNK : RW = 58 : Endif
        If [F:ASWK]REMSTDLNK <> [F:DASWK]REMSTDLNK : RW = 58 : Endif
        If [F:ASWK]DETLNK    <> [F:DASWK]DETLNK    : RW = 58 : Endif
        If [F:ASWK]QRYLNK    <> [F:DASWK]QRYLNK    : RW = 58 : Endif
        If [F:ASWK]EDILNK    <> [F:DASWK]EDILNK    : RW = 58 : Endif
        If [F:ASWK]LOKLNK    <> [F:DASWK]LOKLNK    : RW = 58 : Endif
        If [F:ASWK]SUMLNK    <> [F:DASWK]SUMLNK    : RW = 58 : Endif
        If [F:ASWK]ENALNK    <> [F:DASWK]ENALNK    : RW = 58 : Endif
        If [F:ASWK]INVLNK    <> [F:DASWK]INVLNK    : RW = 58 : Endif
        If !RW : Call TXT([F:ASWK]INTLNK,RW) From DOSSUB : Endif

        If RW
         DIFF = RW
         [F:DASWK] = [F:ASWK]
         Rewrite [DASWK]
         If fstat : Call ERREUR("ASHWLNK"-[F:ASWK]CODREP-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:DASWK]AFFLNK,[F:DASWK]ANCLNK,[F:DASWK]CODLNK)
&             ,2) From DOSDIC : Endif
        Endif

        # update or creation of link parameters

        For [ASWP]ASWP0 Where CODREP=[F:ASWK]CODREP & TYPPAR=3 & AFFLNK=[F:ASWK]AFFLNK & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK
         Read [DASWP]ASWP0 = [F:ASWP]CODREP;[F:ASWP]TYPPAR;[F:ASWP]TYPKEY;[F:ASWP]CODFLD;[F:ASWP]CODLNK;[F:ASWP]AFFLNK;[F:ASWP]CODPAR
         If fstat
          DIFF = 1
          [F:DASWP] = [F:ASWP]
          Write [DASWP]
          If fstat : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&           func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&           ,1) From DOSDIC : Endif
         Else
          RW = 0
          If [F:ASWP]NUMPAR   <> [F:DASWP]NUMPAR   : RW = 57 : Endif
          If [F:ASWP]INTVAL   <> [F:DASWP]INTVAL   : RW = 57 : Endif
          If [F:ASWP]VALEUR   <> [F:DASWP]VALEUR   : RW = 57 : Endif
          If [F:ASWP]TYPINT   <> [F:DASWP]TYPINT   : RW = 57 : Endif
          If [F:ASWP]ADRVAL   <> [F:DASWP]ADRVAL   : RW = 57 : Endif
          If [F:ASWP]TYPAFF   <> [F:DASWP]TYPAFF   : RW = 57 : Endif
          If [F:ASWP]NOLIB    <> [F:DASWP]NOLIB    : RW = 57 : Endif
          If [F:ASWP]LNG      <> [F:DASWP]LNG      : RW = 57 : Endif
          If [F:ASWP]PARFIL   <> [F:DASWP]PARFIL   : RW = 57 : Endif
          If [F:ASWP]PARENT   <> [F:DASWP]PARENT   : RW = 57 : Endif

          If RW
           DIFF = RW
           [F:DASWP] = [F:ASWP]
           Rewrite [DASWP]
           If fstat : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&             func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&             ,2) From DOSDIC : Endif
          Endif
         Endif
        Next ASWP

        # removal of excess link parameters

        For [DASWP]ASWP0  Where CODREP=[F:ASWK]CODREP & TYPPAR=3 & AFFLNK=[F:ASWK]AFFLNK & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK
         Read [ASWP]ASWP0 = [F:DASWP]CODREP;[F:DASWP]TYPPAR;[F:DASWP]TYPKEY;[F:DASWP]CODFLD;[F:DASWP]CODLNK;[F:DASWP]AFFLNK;[F:DASWP]CODPAR
         If fstat
          Delete [DASWP]
          If fstat=1 : Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&             func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&             ,3) From DOSDIC : Endif
         Endif
        Next DASWP

      Endif
     Endif
    Next ASWK

    # removal of excess Links

    For [DASWK]ASWK0 Where CODREP=[F:ASW]CODREP
     If !find([F:DASWK]ACVLNK,GSPE(1..GNBSPE))
      [L]OK_LNK=1
      Read [ASWK]ASWK0=[F:DASWK]CODREP;[F:DASWK]AFFLNK;[F:DASWK]ANCLNK;[F:DASWK]CODLNK
      If fstat
        [L]OK_LNK=0
      Else
       Case [F:DASWK]AFFLNK
        When 1
          If !find([F:DASWK]ANCLNK,WEXPPRO(1..WNBEXPPRO)) : [L]OK_LNK=0 : Endif
        When 2,3
          If !find([F:DASWK]ANCLNK,WCOL(1..WNBCOL)) : [L]OK_LNK=0 : Endif
       Endcase
      Endif
      If [L]OK_LNK=0
       Delete [DASWP] Where CODREP=[F:DASWK]CODREP & TYPPAR=3 & AFFLNK=[F:DASWK]AFFLNK & CODFLD=[F:DASWK]ANCLNK & CODLNK=[F:DASWK]CODLNK
       If fstat=1 : Call ERREUR("ASHWPAR"-[F:DASWK]CODREP-"3"-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:DASWK]AFFLNK,[F:DASWK]ANCLNK,[F:DASWK]CODLNK)
&             ,3) From DOSDIC : Endif
       Delete [DASWK]
       If fstat=1 : Call ERREUR("ASHWLNK"-[F:DASWK]CODREP-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:DASWK]AFFLNK,[F:DASWK]ANCLNK,[F:DASWK]CODLNK)
&             ,3) From DOSDIC : Endif
      Endif
     Endif
    Next DASWK


    #--------------------------------#
    # removal of excess blocks
     #delete non-used blocks
    For [DASWB]ASWB0 Where CODREP=[F:ASW]CODREP
     J=0
     For [DASWR] Where CODREP=[F:DASWB]CODREP & BLCPRO=[F:DASWB]CODBLC
        J=1
        Break
     Next
     If J=0
       Delete [DASWB]
       If fstat=1 : Call ERREUR("ASHWBLC"-[F:DASWB]CODREP-[F:DASWB]CODBLC,3) From DOSDIC : Endif
#     Elsif !find([F:DASWB]ACTBLC,GSPE(1..GNBSPE))
#      Read [ASWB]ASWB0=[F:DASWB]CODREP;[F:DASWB]CODBLC
#      If fstat
#       Delete [DASWB]
#       If fstat=1 : Call ERREUR("ASHWBLC"-[F:DASWB]CODREP-[F:DASWB]CODBLC,3) From DOSDIC : Endif
#      Endif
     Endif
    Next DASWB

    #--------------------------------#
    # removal of excess sections
    #delete non-used sections
    For [DASWS]ASWS0 Where CODREP=[F:ASW]CODREP
     J=0
     For [DASWB] Where CODREP=[F:DASWS]CODREP & SECBLC=[F:DASWS]CODSEC
        J=1
        Break
     Next
     If J=0
       Delete [DASWS]
       If fstat=1 : Call ERREUR("ASHWSEC"-[F:DASWS]CODREP-[F:DASWS]CODSEC,3) From DOSDIC : Endif
#     Elsif !find([F:DASWS]ACTSEC,GSPE(1..GNBSPE))
#      Read [ASWS]ASWS0=[F:DASWS]CODREP;[F:DASWS]CODSEC
#      If fstat
#       Delete [DASWS]
#       If fstat=1 : Call ERREUR("ASHWSEC"-[F:DASWS]CODREP-[F:DASWS]CODSEC,3) From DOSDIC : Endif
#      Endif
     Endif
    Next DASWS


    #--------------------------------#
    ## Comparison of facets
    If !DIFF
     For B=0 To [F:ASW]NBRFAC-1
       Call DIFFACT([F:ADS]DOSSIER,[F:ASW]ACTLNKFAC(B),ACTIV) From DOSSUB
       If [F:ASW]CODFAC(B) <> [F:DASW]CODFAC(B)     : DIFF = 1 : Endif
       If [F:ASW]ENAFAC(B) <> [F:DASW]ENAFAC(B)     : DIFF = 1 : Endif
       If [F:ASW]ENAFAC(B) <> WENAFAC(B)            : DIFF = 1 : Endif
       If [F:ASW]DEFLNKFAC(B) <> [F:DASW]DEFLNKFAC(B)     : DIFF = 1 : Endif
       If [F:ASW]AFFLNKFAC(B) <> [F:DASW]AFFLNKFAC(B)     : DIFF = 1 : Endif
       If [F:ASW]LNKMENFAC(B) <> [F:DASW]LNKMENFAC(B)     : DIFF = 1 : Endif
       If [F:ASW]ACTLNKFAC(B) <> [F:DASW]ACTLNKFAC(B)     : DIFF = 1 : Endif
     Next B
    Endif


    #########################
    # Update header
    #########################
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff"-mess(255,125,1)-[F:ASW]CODREP-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DASW2] = [F:DASW]
     [F:DASW] = [F:ASW]

     ## Update of facets
     For B=0 To [F:ASW]NBRFAC-1
       [F:DASW]ENAFAC(B) = WENAFAC(B)
       If find([F:DASW2]ACTLNKFAC(B),GSPE(1..GNBSPE))
          [F:DASW]DEFLNKFAC(B) = [F:DASW2]DEFLNKFAC(B)
          [F:DASW]AFFLNKFAC(B) = [F:DASW2]AFFLNKFAC(B)
          [F:DASW]LNKMENFAC(B) = [F:DASW2]LNKMENFAC(B)
          [F:DASW]ACTLNKFAC(B) = [F:DASW2]ACTLNKFAC(B)
       Endif
     Next B

     # Get specifics treatments
     For B=0 To [F:DASW2]NBRTRT-1
      If find([F:DASW2]ACTTRT(B),GSPE(1..GNBSPE))
       J=find([F:DASW2]CODTRT(B),[F:DASW]CODTRT(0..[F:DASW]NBRTRT-1))
       If J
          [F:DASW]CODTRT(J-1) = [F:DASW2]CODTRT(B)
          [F:DASW]TYPTRT(J-1) = [F:DASW2]TYPTRT(B)
          [F:DASW]ACTTRT(J-1) = [F:DASW2]ACTTRT(B)
          [F:DASW]RANTRT(J-1) = [F:DASW2]RANTRT(B)
       Else
          J=[F:DASW]NBRTRT
          [F:DASW]NBRTRT +=1
          [F:DASW]CODTRT(J) = [F:DASW2]CODTRT(B)
          [F:DASW]TYPTRT(J) = [F:DASW2]TYPTRT(B)
          [F:DASW]ACTTRT(J) = [F:DASW2]ACTTRT(B)
          [F:DASW]RANTRT(J) = [F:DASW2]RANTRT(B)
       Endif
      Endif
     Next B

     GNBASW += 1
     [F:DASW]UPDUSR = GUSER
     Rewrite [DASW]
     If fstat : Call ERREUR("ASHW"-[F:DASW]CODREP,2) From DOSDIC : Endif

    Elsif ACTIV : # Change of activity code

     RWO = 1
     [F:DASW]UPDUSR = GUSER
     GNBASW += 1
     Rewrite [DASW]
     If fstat : Call ERREUR("ASHW"-[F:DASW]CODREP,2) From DOSDIC : Endif

    Endif

   Endif : # (new & old)
  Endif : # (spec)

 Commit

 Read [ASW]ASW0 Next
Wend

Close Local File [DASW], [DASW2], [DASW3], [DASWF], [DASWF2], [DASWP], [DASWO],[DASWC],[DASWS],[DASWB], [DASWMN],[DASWM], [DASWMP], [DASWR], [DASWK]
Close Local File [DACV] , [DACLAO]
Close Local File [ASW], [ASWF], [ASWP], [ASWO],[ASWC],[ASWS],[ASWB], [ASWMN],[ASWM], [ASWMP], [ASWR], [ASWK]

Return

#-----------------------------------#
$CREPARMET
For [ASWMP]ASWMP0 Where CODREP=[F:ASW]CODREP & CODMET=[F:ASWM]CODMET
 [F:DASWMP] = [F:ASWMP]
 Write [DASWMP]
 If fstat : Call ERREUR("ASHWPARMET"-[F:DASWMP]CODREP-[F:DASWMP]CODMET-[F:DASWMP]CODPARMET,1) From DOSDIC : Endif
Next
Return

#-----------------------------------#
$CREPAR
For [ASWP]ASWP0 Where CODREP=[F:ASW]CODREP & TYPPAR=WTYPPAR & CODFLD=WCODFLD & AFFLNK=WAFFLNK & CODLNK=WCODLNK
 [F:DASWP] = [F:ASWP]
 Write [DASWP]
 If fstat
    Call ERREUR("ASHWPAR"-[F:DASWP]CODREP-
&       func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:DASWP]TYPPAR,[F:DASWP]AFFLNK,[F:DASWP]TYPKEY,[F:DASWP]CODLNK,[F:DASWP]CODFLD,[F:DASWP]CODPAR)
&               ,1) From DOSDIC
 Endif
Next
Return

#--------------------------------------------#
# Find actvity code for a block/section (WBLC)
#--------------------------------------------#
$FIND_ACTBLCSEC
Raz WACTBLC, WACTSEC
Read [DASWB]ASWB0=WREP;WBLC
If !fstat
  WACTBLC=[F:DASWB]ACTBLC
  Read [DASWS]ASWS0=WREP;[F:DASWB]SECBLC
  If !fstat
    WACTSEC=[F:DASWS]ACTSEC
  Endif
Endif
Return

#--------------------------------------------#
# Find actvity code for a section (WSEC)
#--------------------------------------------#
$FIND_ACTSEC
Raz WACTSEC
Read [DASWS]ASWS0=WREP;WSEC
If !fstat
  WACTSEC=[F:DASWS]ACTSEC
Endif
Return


## Deleting a data class
#-----------------------------------#
Subprog EFFACE(WREP)
Value Char WREP
Call ECR_TRACE(mess(257,125,1)-WREP,0) From GESECRAN  : # Suppression représentation

Call DELETE_ALLSTC([F:ADS]DOSSIER,WREP) From ASHWVALSUB

Delete [DASW] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHW"-WREP,3) From DOSDIC : Endif
Delete [DASWF] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWFLD"-WREP,3) From DOSDIC : Endif
Delete [DASWP] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWPAR"-WREP,3) From DOSDIC : Endif
Delete [DASWO] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWOPT"-WREP,3) From DOSDIC : Endif
Delete [DASWC] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWCOL"-WREP,3) From DOSDIC : Endif
Delete [DASWS] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWSEC"-WREP,3) From DOSDIC : Endif
Delete [DASWB] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWBLC"-WREP,3) From DOSDIC : Endif
Delete [DASWMN] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWMENU"-WREP,3) From DOSDIC : Endif
Delete [DASWM] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWMET"-WREP,3) From DOSDIC : Endif
Delete [DASWMP] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWPARMET"-WREP,3) From DOSDIC : Endif
Delete [DASWR] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWEXPPRO"-WREP,3) From DOSDIC : Endif
Delete [DASWK] Where CODREP=WREP
If fstat=1 : Call ERREUR("ASHWLNK"-WREP,3) From DOSDIC : Endif
End

#------------------------------------------------------
$FILL_FLD_PAR
#95271
Raz RES_COD,RES_CLA, RES_TIT
Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR
Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
If filinfo(filpath("FIL","AVIEWIND","fde",[F:ADS]DOSSIER),0)<0
 Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]
Else
 Local File =[F:ADS]DOSSIER+".AVIEWIND" [ATI]
Endif
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

If [F:ASWF]CODTYP<>""
 Read [ATY]CODTYP = [F:ASWF]CODTYP
 If !fstat
  Call LOAD_TYPE_PARAM([F:ADS]DOSSIER,[F:ASWF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC
 Endif
 If [F:ASWF]LOBTAB<>""
  Read [ATI]NUMLIG = [F:ASWF]LOBTAB;1
  If !fstat
   Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,[F:ADS]DOSSIER,[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA
  Endif
 Elsif [F:ATY]CODCLA<>""
  Call CHARGE_CLA_ATI_CLE([F:ADS]DOSSIER,[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
 Endif
Endif
LogicClose File [ATI],[ATY]
Return

