#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation TABCHANGE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
       When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
       When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
       When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
       When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
       When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "COLTCH.EQUAL"                   : Gosub COLTCH_EQUAL
  When "COLTCH.REVCOURS"                : Gosub COLTCH_REVCOURS
  When "COLTCH.CURSYM"                  : Gosub COLTCH_CURSYM
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



###########################################################################################################

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "CURDEN" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "TCH.CURDEN" : TBFIL(NBPRO) = "[LNK_]CURDEN"
NBPRO += 1
TBPRO(NBPRO) = "CURSYM" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "TCU_CURSYM" : TBFIL(NBPRO) = "[LNK_]CURSYM"
NBPRO += 1
TBPRO(NBPRO) = "CURTYP" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "TCH.CHGTYP" : TBFIL(NBPRO) = "[LNK_]CHGTYP"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]CURDEN;[LNK_]CHGTYP"
Return

$AQUERY_JOIN_AFTER
Return

$AQUERY_OPEN_AFTER
Local File TABCHANGE [TCH]
Local File TABCUR    [TCU]

Local Integer I : I=0
Local Char    TCURDEN(GLONCUR)(1..),TCURSYM(10)(1..)
Local Integer TCHGTYP(1..)

Link [F:TCH] With [F:TCU]TCU0=[F:TCH]CURDEN As [QRY_LNK] Order By Key KEY1=[F:TCH]CURDEN Asc;[F:TCH]CHGTYP Asc
For [QRY_LNK]KEY1(2)
    I+=1
    TCURDEN(I)       = [F:TCH]CURDEN
    If [F:TCU]CURSYM<>AVOID.ACHAR
      TCURSYM(I)     = [F:TCU]CURSYM
    Else
      TCURSYM(I)     = [F:TCU]CUR
    Endif

    TCHGTYP(I)       = [F:TCH]CHGTYP
Next

Local File (Char CURDEN(GLONCUR), Char CURSYM(10), Integer CHGTYP) From Variable TCURDEN,TCURSYM,TCHGTYP As [LNK_]

Return

$AQUERY_TRANS_AFTER
this.TCH.CURDEN     = [LNK_]CURDEN
this.TCH.CURSYM     = [LNK_]CURSYM
this.TCH.CHGTYP     = [LNK_]CHGTYP
Return

$AQUERY_CLOSE_AFTER
Close Local File [QRY_LNK]
Return

############################################################################################################
$AREAD_AFTER
Local Integer ILINE,MY_STATUS

For ILINE=1 To maxtab(this.TCH.COLTCH)
  [L]MY_STATUS = fmet this.TCH.COLTCH(ILINE).ASETATTRIBUTE("CHGTYP", "$isDisabled", "true")
  [L]MY_STATUS = fmet this.TCH.COLTCH(ILINE).ASETATTRIBUTE("CURSYMDEN", "$isDisabled", "true")
  [L]MY_STATUS = fmet this.TCH.COLTCH(ILINE).ASETATTRIBUTE("CURSYM", "$isDisabled", "true")
  [L]MY_STATUS = fmet this.TCH.COLTCH(ILINE).ASETATTRIBUTE("REVCOURS", "$isDisabled", "true")
  [L]MY_STATUS = fmet this.TCH.COLTCH(ILINE).ASETATTRIBUTE("EQUAL", "$isDisabled", "true")
Next
Return


$COLTCH_EQUAL
Local Integer MY_STATUS
Case [L]ARULE
  When "INIT"                     : [L]MY_STATUS = fmet this.ASETATTRIBUTE("EQUAL", "$isDisabled", "true")
  When Default:
Endcase
Return

$COLTCH_REVCOURS
Local Integer MY_STATUS
Case [L]ARULE
  When "INIT"                     : [L]MY_STATUS = fmet this.ASETATTRIBUTE("REVCOURS", "$isDisabled", "true")
  When Default:
Endcase
Return

$COLTCH_CURSYM
Local Integer MY_STATUS
Case [L]ARULE
  When "INIT"                     : [L]MY_STATUS = fmet this.ASETATTRIBUTE("CURSYM", "$isDisabled", "true")
  When Default:
Endcase
Return

