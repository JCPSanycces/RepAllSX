#<AdxTL>@(#)0.0.0.0 $Revision$ Composants assemblage
#########################################################################
#                                                                       #
#    TRAITEMENTS LIES aux NOMENCLATURES Assemblage/Desassemblage        #
#                                                                       #
#   ACTIONS , CONTROLES                                                 #
#########################################################################

#########################################################################
#                                                         A C T I O N S #
#########################################################################

#########################################################################
# BBYBOM : descente nomenclature et remplissage ecran composants        #
#########################################################################
Subprog BBYBOM(M,ALT,TYP,DAT,FUNCTION,LABR,RET)
Value    Char    M               :# Compose
Value    Integer ALT             :# Alternative
Value    Integer TYP             :# Type Alternative
Value    Date    DAT             :# Date de référence
Value    Integer FUNCTION        :# Fonction 1 Assemblage / 2 desassemblage
Value    Char    LABR            :# ecran du compose
Variable Integer RET
Local    Integer NL              :# Ligne  composant
Local    Char    ITM
Local    Char    WCOMPOSE
Local    Integer AFF
Local    Decimal WQTYCPE         :# quantite du compose en Us
Local    Char    WFCY            :# Societe
Local    Char    WTRSCOD
Local    Char    WSUPP
NL  = 0
AFF = 1
RET = 0
If dim(GQTYCPE) < 0
   Global Decimal GQTYCPE
Endif

If clalev ([F:BOM])  <= 0 Local File BOM      [BOH] Where ITMREF = M Endif
If clalev ([F:BOMD]) <= 0 Local File BOMD     [BOD] Where ITMREF = M Endif
If clalev ([F:ITG])  <= 0 Local File ITMCATEG [ITG] Endif
If clalev ([F:ITV])  <= 0 Local File ITMMVT   [ITV] Endif
If clalev ([F:EVL])  <= 0 Local File ECCVAL   [EVL] Endif            # hcb 71276

Case FUNCTION
     When 1 :   # Assemblage
          If  [M:BBY0]BOMALT(0)   = 0
              [M:BBY0]BOMFLG(0)   = 2
          Endif
          If [M:BBY0]BOMFLG(0)    = 2
              End
          Else
              If LABR =  "BBY0"
                 WQTYCPE  = [M:BBY0]QTYSTU(0)
              Else
                 WQTYCPE  = GQTYCPE
              Endif
              WCOMPOSE = M
              WFCY     = [M:BBY0]STOFCY
              WTRSCOD  = [M:BBY0]TRSCOD
          Endif
     When 2 :   # Desassemblage
          If  [M:DBY0]BOMALT(0)   = 0
              [M:DBY0]BOMFLG(0)   = 2
          Endif

          If [M:DBY0]BOMFLG(0)    = 2
              End
          Else
              If LABR =  "DBY0"
                 WQTYCPE  = [M:DBY0]QTYSTU(0)
              Else
                 WQTYCPE  = GQTYCPE
              Endif
              WCOMPOSE = M
              WFCY     = [M:DBY0]STOFCY
              WTRSCOD  = [M:DBY0]TRSCOD
          Endif
Endcase
DAT = date$
WSUPP = WCOMPOSE +"~"+ num$(TYP)
Call LECTURE("BOD", num$(ALT), WSUPP) From CONTOBJ
If fstat  <> 0
   RET=2    # hcb 45502
   End
Endif

# point d'entrée génération tableau composants
GPE    = 0                  # hcb 39463
GPOINT = "BOMDETBY"         # hcb 39463
Gosub ENTREE From EXEFNC    # hcb 39463
If GPE = 0                  # hcb 39463
   For [BOD]BOD0 Where ITMREF     = [F:BOH]ITMREF  & BOMALT     = [F:BOH]BOMALT & CPNTYP     = 1
&         &    BOMALTTYP = [F:BOH]BOMALTTYP
&         &    (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <= DAT & BOMSTRDAT <> [0/0/0]))
&         &    (BOMENDDAT = [0/0/0] | (BOMENDDAT >= DAT & BOMENDDAT <> [0/0/0]))
&         &    CPNTYP <> 5
#       ITM = [F:BOD]CPNITMREF   # hcb 39463
        Gosub INSERE
        Raz ITM
        If RET = 3
           Break
        Else
           RET = 0
        Endif
   Next
   If RET=3 End Endif
Endif                       # hcb 39463

If FUNCTION = 1
   Local Integer I
   If M = [M:BBY0]ITMREF(0)

      Call STKDISCOL("BBY1",[M:BBY1]NBLIG) From STKECR
      Diszo [M:BBY1]ITMREF,ITMDES1
      Actzo [M:BBY1]ITMREF([M:BBY1]NBLIG),ITMDES1([M:BBY1]NBLIG)
      For I = 0 To [M:BBY1]NBLIG-1
          [M:BBY1]VCRLIN    (I) = 1000 * (I+2)
      Next
      Affzo [M:BBY1]5

# flagage BOMFLG de l ecran composé disant que la nomenclature est descendue avec succes
      If [M:BBY1]NBLIG > 0
         [M:BBY0]BOMFLG(0)    = 2
         [M:BBY0]QTYSTUORI(0) = [M:BBY0]QTYSTU(0)
      Endif
   Endif


Else
   If M = [M:DBY0]ITMREF(0)
      Local Integer I
      Call STKDISCOL("DBY1",[M:DBY1]NBLIG) From STKECR
      Diszo [M:DBY1]ITMREF,ITMDES1
      Actzo [M:DBY1]ITMREF([M:DBY1]NBLIG),ITMDES1([M:DBY1]NBLIG)
      For I = 0 To [M:DBY1]NBLIG-1
          [M:DBY1]VCRLIN    (I) = 1000 * (I+2)
      Next
      Affzo [M:DBY1]5

# flagage BOMFLG de l ecran composé disant que la nomenclature est descendue avec succes
      If [M:DBY1]NBLIG > 0
         [M:DBY0]BOMFLG(0)    = 2
         [M:DBY0]QTYSTUORI(0) = [M:DBY0]QTYSTU(0)
      Endif
   Endif
Endif
End

##############################################################
# Insertion d'une ligne                                      #
##############################################################
$INSERE
Local Decimal  LIKQTY, COEF, WQTY
Local Integer  ORI1
Local Integer  OK, WRET
Local Char     BPAADD
Local Char     REP
Local Char     STOFCY
Local Integer  I
Local Shortint WRET1
Local Decimal  LSTUACTDIS
Local Char     SECTION
Local Integer  I1
Local Char     WMSG(80)
Local Char     WWRH(GLONWRH)
Local Char     LECCMAJ(GLONECS), LECCMIN(GLONEVL)
ITM = [F:BOD]CPNITMREF       # hcb 39463

Gosub CTL_ITM
If find(RET,1)
   Return
Endif
Case FUNCTION
     When 1 :   # Assemblage
          Default Mask [BBY1]
          #----- Relecture transaction de saisie  -----#
          If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GBBYNUM                   # hcb 50197
             Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
          Endif
     When 2 :   # Desassemblage
          Default Mask [DBY1]
          #----- Relecture transaction de saisie  -----#
          If [F:SRT]SRTTYP <> 7 | [F:SRT]SRTNUM <> GDBYNUM                   # hcb 50197
             Read [SRT]SRT0=7;GBBYNUM : If fstat Raz [F:SRT] : Endif
          Endif
Endcase

Local    Integer  WCOD, WRND
Local    Decimal  WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN, WQTYBAS, WQTYL, WPER
Local    Char    WSTU(GLONUOM)

# Calcul quantité
If [F:BOD]LIKQTY <> 0
    WSTU   = [F:ITM]STU
    WQTYBAS= [F:BOH]BASQTY
    WCOD   = [F:BOD]LIKQTYCOD
    WQTYL  = [F:BOD]LIKQTY
    WRND   = [F:BOD]QTYRND
    WPER   = [F:BOD]SCA
    WQTYN  = 0
    WQTYNA = 0
    WQTYB  = 0
    WQTYBA = 0
    If WQTYCPE <> 0
        Call LIKQTY(WQTYCPE,WSTU,WQTYBAS,WCOD,WQTYL,WRND,WPER,WQTYN,WQTYNA,WQTYB,WQTYBA)
&        From MFGLIB
    Endif

    If [F:SRT]COBMVTCOD = 0
       [F:SRT]COBMVTCOD = 1
    Endif

    # Choix quantité brute ou nette
      Case [F:SRT]COBMVTCOD
        When 1 WQTY = WQTYNA
        When 2 WQTY = WQTYBA
      Endcase
Else
    WQTY = 0
Endif
If WQTY <= 0
   I= 1
   WMSG=ITM-mess(56,184,1)
   Call OUINON(WMSG,I) From GESECRAN
   If I = 1
     Return
   Endif
Endif

# --> Insertion de la ligne sf s'il s'agit d'un remplacement
nolign = NL + 1
If dim([M]ITMREF)>0 = [M]NBLIG+1
   Insa NL,1 [M]NBLIG : # Pas de borne sinon plantage
Else
   Insa NL,1,[M]NBLIG [M]NBLIG
Endif
[M]NBLIG+=1
nolign = NL+1
status = 0

# --> Chargement de la ligne
[M]QTYSTU    (NL) = WQTY
[M]QTYSTUORI (NL) = WQTY
[M]ITMREF    (NL) = ITM
#[M]ITMDES1   (NL) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M]STOMGTCOD (NL) = [F:ITF]STOMGTCOD
[M]QTYPCU    (NL) = [M]QTYSTU    (NL)
[M]STU       (NL) = [F:ITM]STU
[M]PCU       (NL) = [F:ITM]STU
[M]PCUSTUCOE (NL) = 1
# Lecture article et règle de gestion
If FUNCTION = 1
   # Alimentation dépôt
   If dim([M:BBY0]WRHE)>0 & [F:FCY]WRHGES=2
      #--- Bug 65492
      If [F:ITF]LOCMGTCOD>1
         [M:BBY1]WRH(NL) = [M:BBY0]WRHE
         # Dépôt entête obligatoire
         If GWRHOBY=2
            Diszo WRH(NL)
         Else
            Actzo WRH(NL)
         Endif
      Else
         Raz [M:BBY1]WRH(NL) : Grizo WRH(NL)
      Endif
   Endif
   For I1 = 1 To GNBDIE
     Call INISEC(SECTION,"STKBBYD",I1) From TRTX3CPT
     Assign "[M:BBY1]CCE"+num$(I1)+"(nolign-1)" With SECTION
   Next I1
   # Lecture article et règle de gestion
   Call INIZONSOR("BBY1",[M:BBY1]ITMREF(NL),[M:BBY0]STOFCY,NL,[M:BBY0]TRSTYPC,[M:BBY0]TRSCOD,"") From STKECR   # hcb 87271

#                                                 # hcb 71276 deb

   If [F:ITM]ECCSTO > 1 &  dim([M:BBY1]ECCVALMAJ) > 0
 # bomalttyp = 1 commerce 2 production
      Case [F:BOH]BOMALTTYP
          When 1
          When 2
            [M:BBY1]ECCVALMAJ   (NL) = [F:BOD]ECCVALMAJ
            [M:BBY1]ECCVALMIN   (NL) = [F:BOD]ECCVALMIN
      Endcase
   Endif
#                                                 # hcb 71276 fin

Else
   For I1 = 1 To GNBDIE
     Call INISEC(SECTION,"STKDBYD",I1) From TRTX3CPT
     Assign "[M:DBY1]CCE"+num$(I1)+"(nolign-1)" With SECTION
   Next I1

   Call INIZONENT([M]ITMREF(NL),"DBY1",[M:DBY0]STOFCY,"",0,"",NL,[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,[M:DBY0]VCRNUM,0,1) From STKECR

#                                                 # hcb 71276 deb

   If [F:ITM]ECCSTO > 1 &  dim([M:DBY1]ECCVALMAJ) > 0
      Raz [M:DBY1]ECCVALMAJ(NL)
      Raz [M:DBY1]ECCVALMIN(NL)
      Raz [M:DBY1]ECCSAIFLG(NL)
 #     Raz [M:DBY1]ECCBOMFLG(NL)
 # bomalttyp = 1 commerce 2 production
      Case [F:BOH]BOMALTTYP
          When 1
          When 2
            [M:DBY1]ECCVALMAJ   (NL) = [F:BOD]ECCVALMAJ
            [M:DBY1]ECCVALMAJORI(NL) = [F:BOD]ECCVALMAJ
            [M:DBY1]ECCVALMIN   (NL) = [F:BOD]ECCVALMIN
            [M:DBY1]ECCVALMINORI(NL) = [F:BOD]ECCVALMIN
            [M:DBY1]ECCSAIFLG   (NL) = 9   # les versions issues de la nomenclure ne sont pas modifiables
      Endcase
   Endif
#                                                 # hcb 71276 fin
   If [F:ITF]LOCMGTCOD > 1
     If dim([M:DBY1]LOC) > 0
       If dim([M:DBY1]WRH) > 0
         WWRH=[M:DBY1]WRH(NL)
       Else
         WWRH=""
       Endif

       Local Decimal LQTY
# Récupération de l'emplacement par défaut de l'art-site pour le type mouvement
       Call STKSUGEMP([M:DBY1]WLOCSEQ(NL),[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,
&           [M:DBY0]STOFCY,[M:DBY1]ITMREF(NL),[M:DBY1]PCU(NL),[M:DBY1]QTYPCU(NL),
&           [M:DBY1]STA(NL),[M:DBY1]LOCTYP(NL),[M:DBY1]LOC(NL),"","QU","",WWRH) From STKLOC
       If mkstat = 2 mkstat = 0 Endif
# Controle de l'emplacement par défaut de l'art-site pour le type mouvement
       Call STKCTREMP([M:DBY1]WLOCSEQ(NL),[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,
&           [M:DBY0]STOFCY,[M:DBY1]ITMREF(NL),[M:DBY1]PCU(NL),[M:DBY1]QTYPCU(NL),
&           [M:DBY1]STA(NL),[M:DBY1]LOCTYP(NL),[M:DBY1]LOC(NL),"",0,mkstat,LQTY,
&           string$([M:DBY1]STA(NL)="","S"),"",WWRH) From STKLOC
       If mkstat = 2 mkstat = 0 Endif
# si  type quai mise à blanc des zones type et emplacement
       If [M:DBY1]LOCTYP (NL) <> ""
         Read [TLO]TLO0=[M:DBY0]STOFCY;[M:DBY1]LOCTYP (NL)
         If fstat
           Raz [F:TLO]
         Else
# type quai non autorisé
           If [F:TLO]LOCCAT = 2
             Raz [M:DBY1]LOCTYP (NL)
             Raz [M:DBY1]LOC    (NL)
           Endif
         Endif
       Endif
     Endif
   Endif
Endif


NLIG=NL

[M]UPDFLG(NL)  = 1



########################################################################
# Stock
########################################################################

Case FUNCTION
     When 1 :   # Assemblage
         [M:ALP]VCRTYP    = 31
# Chargement STOSORW par éxécution de l'algorithme
         [M:ALP]TRSTYP    = [M:BBY0]TRSTYPC
         [M:ALP]TRSCOD    = WTRSCOD
         [M:ALP]STOFCY    = WFCY
         [M:ALP]ITMREF    = [M]ITMREF(NL)
         [M:ALP]QTY       = [M]QTYSTU(NL)
         [M:ALP]TYPQTY    = 2              # (voir SUBSMOB  comentaire de Cyrille apres discussion TS)
         [M:ALP]PCU       = [M]PCU(NL)
         [M:ALP]PCUSTUCOE = [M]PCUSTUCOE(NL)
         [M:ALP]BESDAT    = [M:BBY0]IPTDAT
         [M:ALP]DLVDAT    = [M:BBY0]IPTDAT
         [M:ALP]ALLDAT    = [0/0/0]
         [M:ALP]STOLOC    = ""
         [M:ALP]PECINTLOC = 2
         [M:ALP]PECSCOLOC = 1
         [M:ALP]PECPLFLOC = 2
         [M:ALP]PECCUNLOK = 1
         [M:ALP]VCRNUM    = ""
         [M:ALP]VCRLIN    = 0
         [M:ALP]VCRSEQ    = 0
         [M:ALP]FILSTO    = ""
         Raz [M:ALP]LOT, [M:ALP]LOC, [M:ALP]STA
         If dim([M:BBY1]WRH)>0 [M:ALP]WRH=[M:BBY1]WRH(NL) Endif
         If dim([M:BBY1]ECCVALMAJ)>0 [M:ALP]ECCVALMAJ=[M:BBY1]ECCVALMAJ(NL) Endif      # hcb 71276

         Raz WRET
# Si stock à sortir non encore déterminé, init emplacement par défaut
# hcb 28654 rajout test STOMGTCOD
         If dim([M:BBY1]LOC)>0 & [M:BBY1]WSTOSEQ(NL)=0 & [M:BBY1]STOMGTCOD(NL) > 1
            Call STKINIEMPS([M:BBY1]LOC(NL)) From STKLOC
         Endif
# Détermination du stock à sortir (automatisme, saisie)
         Call OUVSOR("BBY1",NL,[M:BBY1]NBLIG,[M:BBY1]WSTOSEQ(NL),[M:BBY0]STKFLG,WRET) From STKSOR           # hcb 50197
     When 2 :   # Desassemblage
         If [M:DBY1]STOMGTCOD(NL) > 1              # hcb 28654
            Call OUVENT([M:DBY0]STOFCY,"DBY1",1,[M:DBY0]TRSCOD,"",19,[M:DBY0]IPTDAT,nolign-1,[M:DBY1]NBLIG,"SRT","",WRET1) From STKENT
            Raz LECCMAJ, LECCMIN
            If dim([M:DBY1]ECCVALMAJ)>0
                [L]LECCMAJ = string$([M:DBY1]ECCVALMAJ(NL)<>"$",[M:DBY1]ECCVALMAJ(NL))
                [L]LECCMIN = string$([M:DBY1]ECCVALMIN(NL)<>"$",[M:DBY1]ECCVALMIN(NL))
            Endif
            Call SETNEWPRIOVE([M:DBY1]ITMREF(NL),LECCMAJ,LECCMIN,[M:DBY0]STOFCY,[M:DBY0]IPTDAT,[M:DBY1]WSTOSEQ(NL),[M:DBY1]PRIORD(NL),[M:DBY0]TRSTYPC,[M:DBY1]QTYSTU(NL),"",WRET) From STKVAL
         Endif                                     # hcb 28654
Endcase

########################################################################


NL+=1

#---------------------------------------------------------------------#
# Cas d'un fantôme : -->                                              #
#     Assemblage                                                      #
#          Controle du disponible en statut "A"                       #
#               si dispo inferieur lien Descente de la nomenclature   #
#               Suppression de la ligne fantôme                       #
#     Desassemblage                                                   #
#               si pas gere en stock  Descente de la nomenclature     #
#               Suppression de la ligne fantôme                       #
#---------------------------------------------------------------------#

If  [F:ITM]PHAFLG = 2
    # point d'entrée génération tableau composants
    GPE    = 0                  # hcb 43444
    GPOINT = "BOMPHABY"         # hcb 43444
    Gosub ENTREE From EXEFNC    # hcb 43444
    If GPE = 0                  # hcb 43444
       Case FUNCTION
       When 1 :  # Assemblage
            Raz LSTUACTDIS
            Read [ITV]ITV0=[F:ITM]ITMREF;WFCY
            If fstat
               Raz [F:ITV]
            Endif
# lecture ITMCATEG
            Read [ITG]ITG0=WFCY;[F:ITM]TCLCOD
            If fstat
               Read [ITG]ITG1=[F:ITM]TCLCOD;""
               If fstat
                  Raz [ITG]
               Endif
            Endif

            Call STODISTOT("",1,0,"",LSTUACTDIS) From STKLIB

            If LSTUACTDIS < WQTY
               ORI1 = NL-1
               GQTYCPE = [M:BBY1]QTYSTU(ORI1)
               Call SUP_LIG (ORI1, WRET) From SUBBBY1
               Call BBYBOM(ITM,ALT,TYP,DAT,FUNCTION,"BBY1",RET)
               If RET = 3
                  Return
               Endif
               If RET = 2       # hcb 45502
                  NL -=1        # hcb 45502
               Endif            # hcb 45502
            Endif
       When 2 :  # Desassemblage
            If [F:ITF]STOMGTCOD = 1
               ORI1 = NL-1
               GQTYCPE = [M:DBY1]QTYSTU(ORI1)
               Call SUP_LIG (ORI1, WRET) From SUBDBY1
               Call BBYBOM(ITM,ALT,TYP,DAT,FUNCTION,"DBY1",RET)
               If RET = 3
                  Return
               Endif
               If RET = 2       # hcb 45502
                  NL -=1        # hcb 45502
               Endif            # hcb 45502
            Endif
       Endcase
    Endif                  # hcb 43444
Endif
Return


##############################################################
# Controles à réaliser sur la ligne à insérer                #
##############################################################
$CTL_ITM

# Sous produit non traité
If [F:BOD]CPNTYP = 4
   WMSG = ITM-mess(374,199,1)
   Gosub CTL_ITM_AVERTIR
Endif
If [F:BOD]CPNTYP = 6
   WMSG = ITM-mess(518,199,1)
   Gosub CTL_ITM_AVERTIR
   Return
Endif

# --> Vérif existence article : ITM
Local Integer I
    Read [ITM]ITM0=ITM
If fstat <> 0
   WMSG = ITM-mess(212,199,1)    # article inexistant
   Gosub CTL_ITM_AVERTIR
   Return
Endif
# si article fantome on saute les tests suivants
If  [F:ITM]PHAFLG = 2
    Return
Endif


# Article avec statut non actif (message)
Case [F:ITM]ITMSTA
    When 1 :
    When 6 :
       WMSG = ITM-mess(3,196,1)+"("+mess([F:ITM]ITMSTA,246,1)+")"  # Accès non autorisé sur cet article
       Gosub CTL_ITM_AVERTIR
       Return
    When Default :
      I= 1
      Call OUINON(ITM-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"+mess(36,100,1),I) From GESECRAN
      If I = 1
        RET = 1
        Return
      Endif
Endcase
# --> Lecture article-site si article géré en stock

If clalev ([F:ITF]) <= 0 Local File ITMFACILIT [ITF] : Endif
If [F:ITF]ITMREF <>  ITM | [F:ITF]STOFCY <> WFCY
    Read [ITF]ITF0 = ITM;WFCY
    If fstat
       WMSG = ITM-mess(25,192,1)    # article inixixtant sur le site
       Gosub CTL_ITM_AVERTIR
       Return
    Else
       If [F:ITF]STOMGTCOD = 1
          I= 1
          Call OUINON(ITM-mess(2,196,1)+"  "+mess(36,100,1),I) From GESECRAN    # hcb 62155
          If I = 1
             RET = 1
             Return
          Endif
       Endif
    Endif
Endif


# Contrôle non bloqué en inventaire
If [F:ITF]CUNFLG = 2
   I = 1
   Call AVERTIR(ITM-mess(185,199,1),I) From GESECRAN
   If I = 1
      RET = 1
      Return
   Endif
Endif

Return

##############################################################
# message bloquant
##############################################################
$CTL_ITM_AVERTIR
Call ERREUR(WMSG) From GESECRAN
RET=1
Return


###########################################################################
# BBYNBLIG : re-calcul quantite composants si modification quantite compose
###########################################################################
Subprog BBYNBLIG(FUNCTION,RET)
Value          Integer FUNCTION        :# Fonction 1 Assemblage / 2 desassemblage
Variable       Integer RET
Local Decimal  RAPPORT
Local Integer  OK
Local Integer  I
Local Decimal  WDIMQTY
Local Decimal  WPREQTY
Local Integer  WRET
Local Shortint WRET1

# si nomenclature pas encore descendue
#    ON FORCE VCRLIN à 1 ET  on sort
If [M]BOMFLG(0) <> 2
   [M]VCRLIN(0) = 1
   End
Endif

If GMODIF <> 2
   End
Endif
# si desassemblage d assemblage on calcul sort
If FUNCTION = 2 & [M:DBY0]VCRNUMORI <> ""     # hcb 22993
   Gosub CALCUL_PARTIEL From SUBDBYA          # hcb 22993
   End                                        # hcb 22993
Endif                                         # hcb 22993


#  MSG=Repercussion sur les composants ?

Call OUINON(mess(14,191,1),OK) From GESECRAN
If OK <>  2
   End
Endif

# si qte origine = qte saisie  on sort
If [M]QTYSTU (0) = [M]QTYSTUORI (0)
   RAPPORT = 1
Else
# calcul du rapport
   If [M]QTYSTUORI(0) = 0
      RAPPORT = 1
   Else
      RAPPORT    = [M]QTYSTU(0) / [M]QTYSTUORI(0)
   Endif
Endif
Case FUNCTION
     When 1 :   # Assemblage
          Default Mask [BBY1]
     When 2 :   # Desassemblage
          Default Mask [DBY1]
Endcase
For I = 0 To [M]NBLIG-1
    If [M]QTYSTUORI(I) <> 0
        WPREQTY =[M]QTYSTU   (I)
       [M]QTYSTU   (I) = RAPPORT * [M]QTYSTUORI(I)
       Call QTEARR([M]QTYSTU(I),[M]STU(I)) From TRTDIV
       [M]QTYPCU   (I) = [M]QTYSTU    (I)

       If WPREQTY          > [M]QTYSTU (I)
           WDIMQTY = WPREQTY         - [M]QTYSTU (I)
           If WDIMQTY>0
# Diminution de la qté stockée dans STOSORW
              Call QTEARR(WDIMQTY,[M]STU(I)) From TRTDIV
              If FUNCTION = 1
                 Call DIM_STOSORW(I,"BBY1",[M:BBY0]STOFCY,WDIMQTY,WRET) From STKSOR
              Else
                 Call LECFICENT([M:DBY0]STOFCY,"", "",I,[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,1) From STKECR
                 Call OUVENT([M:DBY0]STOFCY,"DBY1",1,[M:DBY0]TRSCOD,"",19,[M:DBY0]IPTDAT,I,[M:DBY1]NBLIG,"SRT","",WRET1) From STKENT
              Endif
           Endif
       Else
           WDIMQTY =  [M]QTYSTU (I) - WPREQTY
           If WDIMQTY>0
# Augmentation  de la qté stockée dans STOSORW
              Call QTEARR(WDIMQTY,[M]STU(I)) From TRTDIV
              If FUNCTION = 1
                [M:ALP]VCRTYP    = 31
# Chargement STOSORW par éxécution de l'algorithme
                [M:ALP]TRSTYP    = [M:BBY0]TRSTYPC
                [M:ALP]TRSCOD    = [M:BBY0]TRSCOD
                [M:ALP]STOFCY    = [M:BBY0]STOFCY
                [M:ALP]ITMREF    = [M]ITMREF(I)
                [M:ALP]QTY       = WDIMQTY
                [M:ALP]TYPQTY    = 1    # (voir SUBSMOB  comentaire de Cyrille apres discussion TS)
                [M:ALP]PCU       = [M]PCU(I)
                [M:ALP]PCUSTUCOE = [M]PCUSTUCOE(I)
                [M:ALP]BESDAT    = [M:BBY0]IPTDAT
                [M:ALP]DLVDAT    = [M:BBY0]IPTDAT
                [M:ALP]ALLDAT    = [0/0/0]
                [M:ALP]STOLOC    = ""
                [M:ALP]PECINTLOC = 2
                [M:ALP]PECSCOLOC = 1
                [M:ALP]PECPLFLOC = 2
                [M:ALP]PECCUNLOK = 1
                [M:ALP]VCRNUM    = ""
                [M:ALP]VCRLIN    = 0
                [M:ALP]VCRSEQ    = 0
                [M:ALP]FILSTO    = ""
                [M:ALP]ALLQTY    = 0
                Raz [M:ALP]LOT, [M:ALP]LOC, [M:ALP]STA
                If dim([M:BBY1]WRH)>0 [M:ALP]WRH=[M:BBY1]WRH(I) Endif                 # hcb 121662
                If dim([M:BBY1]ECCVALMAJ)>0 [M:ALP]ECCVALMAJ=[M:BBY1]ECCVALMAJ(I) Endif      # hcb 71276
                Raz WRET
                Call GENSTOSORW("BBY1",I,[M:BBY1]NBLIG,1,"C",WRET) From STKSOR
              Else
                Call LECFICENT([M:DBY0]STOFCY,"", "",I,[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,1) From STKECR
                Call OUVENT([M:DBY0]STOFCY,"DBY1",1,[M:DBY0]TRSCOD,"",19,[M:DBY0]IPTDAT,I,[M:DBY1]NBLIG,"SRT","",WRET1) From STKENT
                Affzo [M:DBY1]ITMREF(I)
              Endif
           Endif

       Endif
    Endif
Next

Affzo [M]

End


#########################################################################
#                                                     C O N T R O L E S #
#########################################################################

#########################################################################
# Contrôle de validité d'une alternative  Commerciale / production      #
#                          (utilisé dans l assemblage par exemple)      #
# TBO & BOH doivent être chargés ...                                    #
# Paramètres E : LFCY    = Site                                         #
#                LDAT    = date pour controle validitée                 #
#                LMSG    = Affichage erreur                             #
#            S : LALT    = numéro alternative                           #
#########################################################################
Subprog STKCTRALT(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG
LALT=0
Local Integer VS
Raz VS

# Alternative de production ? (si commerciale demande de confirmation)
If [F:TBO]BOMALTTYP=1
    If LMSG<>0
       VS = 1
        GMESSAGE =mess(135,195,1)
        Call AVERTIR(GMESSAGE+chr$(13)+mess(205,100,1),VS) From GESECRAN
        GMESSAGE = ""
       If VS = 1
          End
       Else
# si commerciale verification si options / variantes

          For [BOD]BOD0 Where ITMREF     = [F:BOH]ITMREF  & BOMALT     = [F:BOH]BOMALT & CPNTYP     > 1
&             &     BOMALTTYP = [F:BOH]BOMALTTYP
&             &    (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <= LDAT & BOMSTRDAT <> [0/0/0]))
&             &    (BOMENDDAT = [0/0/0] | (BOMENDDAT >= LDAT & BOMENDDAT <> [0/0/0]))
             GMESSAGE=mess(159,184,1)
             VS = 1
             Break
          Next
       Endif
       If VS = 1
          End
       Endif
    Endif
# Si sous-traitance interdit
Elsif [F:TBO]BOMALTTYP = 3
        GMESSAGE =mess(264,184,1)
        Call ERREUR(GMESSAGE) From GESECRAN
        End
Endif
# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TBO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0
       GMESSAGE=mess(46,193,1)
    Endif
    End
Endif
# Site ?
If ([F:TBO]FCY<>"" & [F:TBO]FCY<>LFCY)
    If LMSG<>0
       GMESSAGE=mess(48,193,1)
    Endif
    End
Endif

If [F:TBO]BOMALTTYP = 2
# Utilisable en production ? (uniquement si alternative de production)
   If [F:TBO]MFGUSE<>2
      If LMSG<>0
         GMESSAGE=mess(49,193,1)
        Call ERREUR(GMESSAGE) From GESECRAN

      Endif
      End
   Endif
Endif
# Utilisable en exploitation ?
If [F:BOH]USESTA<>2
    If LMSG<>0
       GMESSAGE=mess(51,193,1)
       Call ERREUR(GMESSAGE) From GESECRAN

    Endif
    End
Endif
# Nomenclature valide ?
If ([F:BOH]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH]BOHSTRDAT)
    If LMSG<>0 : GMESSAGE=mess(50,193,1)
       Endif
    End
Endif
If ([F:BOH]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH]BOHENDDAT)
    If LMSG<>0
       GMESSAGE=mess(50,193,1)
    Endif
    End
Endif
#
LALT=[F:BOH]BOMALT
End
######################################################################
#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative : si unique elle est proposée
######################################################################
Subprog INITBOMALT(LFCY, LITM, LDAT, LABR, LNOL, LALT)
Value Char       LFCY
Value Char       LITM
Value Date       LDAT
Value Char       LABR
Value Integer    LNOL
Variable Integer LALT

Local Integer WMSG
Local Integer NBALT
Raz WMSG
Raz NBALT
#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative : si unique elle est proposée


If clalev ([F:BOH])=0 : Local File BOM [BOH] : Endif

For [BOH]BOH0 Where ITMREF=LITM & BOMALTTYP < 3 & USESTA = 2
&         &     ([F:BOH]BOHSTRDAT = [0/0/0] | ([F:BOH]BOHSTRDAT <= LDAT & [F:BOH]BOHSTRDAT <> [0/0/0]))
&         &     ([F:BOH]BOHENDDAT = [0/0/0] | ([F:BOH]BOHENDDAT >= LDAT & [F:BOH]BOHENDDAT <> [0/0/0]))
    If [F:BOH]BOMALTTYP = 2
       Read [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
       If !fstat
           Call CONTMFGNOM(LFCY,LALT,LDAT,WMSG) From MFGLIB
           If LALT =  0
              Goto NEXBOH
           Endif
       Endif
    Endif

    NBALT+=1
    If NBALT>1
       Raz LALT
       Break
    Endif
    LALT=[F:BOH]BOMALT
$NEXBOH

Next

If LALT <> 0
   Assign "[M:"+LABR+"]BOMALT(LNOL)"    With [F:BOH]BOMALT
#                                                               hcb 71276 deb
   Assign "[M:"+LABR+"]BOMALTTYP(LNOL)" With [F:BOH]BOMALTTYP
   Affzo [M]BOMALT   (LNOL)
   Affzo [M]BOMALTTYP(LNOL)
   If [F:ITM]ECCSTO > 1 & evalue("dim([M:"+LABR+"]ECCVALMAJ)") >= 0
      Gosub RECH_ECCVAL
   Endif
#                                                               hcb 71276 fin
Endif

End

######################################################################
#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative
######################################################################
Subprog CTRBOMALT(LFCY, LITM, LDAT, LABR, LNOL, LALT,LRET)
Value    Char    LFCY
Value    Char    LITM
Value    Date    LDAT
Value    Char    LABR
Value    Integer LNOL
Value    Integer LALT
Variable Integer LRET
Local    Integer WMSG
Raz              WMSG
#    Lecture BOM
# determination alternative par défaut :
#   recherche premiere alternative

If clalev ([F:BOH])=0 : Local File BOM [BOH] : Endif
LRET = 9
GMESSAGE = mess(320,193,1)                           # hcb 71276


For [BOH]BOH0 Where ITMREF=LITM & BOMALTTYP < 3  & BOMALT = LALT & USESTA = 2
&         &     ([F:BOH]BOHSTRDAT = [0/0/0] | ([F:BOH]BOHSTRDAT <= LDAT & [F:BOH]BOHSTRDAT <> [0/0/0]))
&         &     ([F:BOH]BOHENDDAT = [0/0/0] | ([F:BOH]BOHENDDAT >= LDAT & [F:BOH]BOHENDDAT <> [0/0/0]))
    If [F:BOH]BOMALTTYP = 2
       Read [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
       If !fstat
           Call CONTMFGNOM(LFCY,LALT,LDAT,1) From MFGLIB
           If LALT =  0
              Goto NEXBOHCTR
           Endif
       Endif
    Endif
    Raz LRET
#   GMESSAGE = mess(95,193,1)                       # hcb 71276
    Raz GMESSAGE                                    # hcb 71276
    Break
$NEXBOHCTR
Next

If LRET = 0
   Assign "[M:"+LABR+"]BOMALTTYP(LNOL)" With [F:BOH]BOMALTTYP
#                                                               hcb 71276 deb
   Affzo [M]BOMALTTYP(LNOL)
   If [F:ITM]ECCSTO > 1 & evalue("dim([M:"+LABR+"]ECCVALMAJ)") >= 0
      Gosub RECH_ECCVAL
   Endif
#                                                               hcb 71276 fin
Endif

End
#                                                               hcb 71276 deb

$RECH_ECCVAL
If clalev ([F:EVL])  <= 0 Local File ECCVAL   [EVL] Endif

Local Char FILTREEVL
Raz GPE
GPOINT = "READECCBOM"
Gosub  ENTREE From EXEFNC
If FILTREEVL = ""
   FILTREEVL = "1=1"
Endif
If GPE = 0
# bomalttyp = 1 commerce 2 production
   Case [F:BOH]BOMALTTYP
      When 1
      When 2
         Filter [EVL] Where ITMREF=[F:ITM]ITMREF & ECCTYP=2 & USESTA=2 & evalue(FILTREEVL)
         Read [EVL]EVL0 Last
         If fstat>2
            Filter [EVL] Where ITMREF=[F:ITM]ITMREF & ECCTYP=2
            Read [EVL]EVL0 Last
            If fstat
               Raz [F:EVL]
            Endif
         Endif
         Filter [EVL]
   Endcase
Endif
Assign "[M:"+LABR+"]ECCVALMAJ(LNOL)" With [F:EVL]ECCVALMAJ
Assign "[M:"+LABR+"]ECCVALMIN(LNOL)" With [F:EVL]ECCVALMIN
If evalue("dim([M:"+LABR+"]ECCSAIFLG)") >= 0
   Assign "[M:"+LABR+"]ECCSAIFLG(LNOL)" With 9
Endif
If evalue("dim([M:"+LABR+"]ECCVALMAJORI)") >= 0
   Assign "[M:"+LABR+"]ECCVALMAJORI(LNOL)" With [F:EVL]ECCVALMAJ
Endif
If evalue("dim([M:"+LABR+"]ECCVALMINORI)") >= 0
   Assign "[M:"+LABR+"]ECCVALMINORI(LNOL)" With [F:EVL]ECCVALMIN
Endif
Affzo [M]ECCVALMAJ(LNOL)
Affzo [M]ECCVALMIN(LNOL)
Diszo [M]ECCVALMAJ(LNOL)
Diszo [M]ECCVALMIN(LNOL)
Return
#                                                               hcb 71276 fin




