#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DDEBPOR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:52"
A_USER  = "DOC"
A_STAMP = "20181109230352"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DDEBPOR [DIA]
Gosub HORODAT
Local Inpbox "DDEBPOR" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=33 : X2(0)=80 : Y1(0)=13 : Y2(0)=16
Return

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1DDEBPOR
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1DDEBPOR
Onevent AFTER_CHANGE Gosub AMM_CPY From W1DDEBPOR
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPY(zc) From W1DDEBPOR
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1DDEBPOR
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1DDEBPOR
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1DDEBPOR
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat
 ## Action ACONTCPY
 Call CONTSOC(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("CPY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  If !mkstat
   ## Action CONTCPYLEG
   Call CONTCPYLEG(VALEUR,"POR") From TRTX3
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPY
Call AM_CPY(zc)
If !mkstat & GOBJET
 zoncou = "CPY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCPY)")>indice
 [M]CPY(indice) = VALEUR
 Affzo ZCPY(indice)
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCPYLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCPYLEG"
 PARMSK(1) = "POR"
 Call S_TAB_CHAR(VALEUR,PARMSK,"","TRTX3","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1DDEBPOR
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_FLO
Onevent BEFORE_INPUT Call AS_FLO(zc) From W1DDEBPOR
Onevent INIT_AREA Call D_FLO(zc) From W1DDEBPOR
Onevent CONTROL Call C_FLO(zc) From W1DDEBPOR
Return

Subprog D_FLO(VALEUR)
Variable Integer VALEUR
If varinit([M]FLO,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLO(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_FLO(VALEUR) From FUNDEBPOR
If mkstat=2
 [M]FLO(INDIC) = VALEUR
 Affzo FLO(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLO(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FLO" : GZNUM = 24916 : Endif
Gosub _AFF
End

$ON_DAT
Onevent AFTER_CHANGE Gosub AMM_DAT From W1DDEBPOR
Onevent CONTROL Call C_DAT(zc) From W1DDEBPOR
Onevent BEFORE_AREA Gosub AV_DAT From W1DDEBPOR
Return

$AV_DAT
Chgfmt [M]DAT(indice) With "D:"+GFMMOI4
Gosub _AFF
Return

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 212 : Endif
Gosub _AFF
End

$AMM_DAT
Call AM_DAT(zc)
If !mkstat & GOBJET
 zoncou = "DAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_DAT(VALEUR) From FUNDEBPOR
If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 212 : Endif
Gosub _AFF
End

$CHG_STY
Return


