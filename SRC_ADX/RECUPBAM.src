#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBAM","UTIRECBAM",3,"") From GTRAITE
End

#######################################################
## Actions Process
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return


$OUVRE
## Opening Tables
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif : # Account Core Models
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif : # Ledgers
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Companies
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif : # Facilities
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif : # Fiscal years
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif : # Fiscal Periods
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Accounts
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif : # Currencies

If clalev([F:HAE])=0  : Local File GACCENTRY   [HAE] : Endif : # Journal Entry
If clalev([F:DAE])=0  : Local File GACCENTRYD  [DAE] : Endif : # Accounting Document Lines
If clalev([F:DAA])=0  : Local File GACCENTRYA  [DAA] : Endif : # Analytic Accounting Document Lines
If clalev([F:BAM])=0  : Local File BALDEM      [BAM] : Endif : # Double Entry Balance
If clalev([F:BAI])=0  : Local File BALDEMIDT   [BAI] : Endif : # Double Entry Balance (index table)
If clalev([F:BAL])=0  : Local File BALANCE     [BAL] : Endif : # General Balance

If clalev([F:HAT])=0  : Local File GACCTMP     [HAT] : Endif : # Journal Entry
If clalev([F:DAT])=0  : Local File GACCTMPD    [DAT] : Endif : # Accounting Document Lines

Local Integer FLGDEM : FLGDEM = 0
Return

$INIT
Gosub OUVRE
If !GBROWS : TMP = 1 : Endif
Return


$INIT_DIA
[M:DIA]CPY = GDEFSOC
Call FLGDEM(GDEFSOC,FLGDEM) From CPTDIV
If FLGDEM = 2
 [M:DIA]CPY = GDEFSOC
Else
 Call CPYDEM([M:DIA]CPY,[M:DIA]LEDTYP) From CPTDIV
Endif
Call DEFEXE([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY) From CPTSUB
Call DATEXE([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY,[M:DIA]STRDAT,[M:DIA]ENDDAT) From CPTSUB
Return


#######################################################
## Process Execution
#######################################################
$EXEC
Local Integer ANOM
Call RECUPBAM([M:DIA]CPY,[M:DIA]ALLFCY,[M:DIA]FCY,[M:DIA]LEDTYP,
&             [M:DIA]FIY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]CUR,[M:DIA]TYP,GSERVEUR,0,ANOM)
TRA = 1
Return


Subprog RECUPBAM(COMPANY,ALLFCY,FCY,LEDTYP,FIYNUM,STRDATE,ENDDATE,SELCUR,TYPTRT,BATCH,DIRECT,ANOM)
Value    Char    COMPANY   : # Company
Value    Integer ALLFCY    : # All Sites
Value    Char    FCY       : # Site
Value    Integer LEDTYP    : # Ledger type
Value    Integer FIYNUM    : # Fiscal Years
Value    Date    STRDATE   : # First Period
Value    Date    ENDDATE   : # Last Period
Value    Char    SELCUR    : # Selection Currency
Value    Integer TYPTRT    : # 1:Balances Comparison    2:Double Entry Balance Resynchronization
Value    Integer BATCH
Value    Integer DIRECT
Variable Integer ANOM

Gosub OUVRE

Local Char    FILTECT(250)(0..4)
Local Integer IFILE

Local Char    CHART(GLONCOA)     # Chart of accounts
Local Char    SITBAL(GLONFCY)    # Site
Local Integer OK
Local Integer FLCPY
Local Integer FLSIT

# Variables : Feature 79527 - SP2US26
Local Char    FILTHAT(250)(0..4)
Local Integer IFILH

#-- Lof File Opening
If !(BATCH | DIRECT)
 ## Double Entry Balance Resynchronization
 Call OUVRE_TRACE(mess(54,116,1)) From LECFIC
 If GBROWS : Call OUVRE_VLC(mess(54,116,1),"","") From GESECRAN : Endif
Endif

If !DIRECT
 Call MONOCPY(COMPANY,OK) From AX3MONO
 If !OK : Goto FIN : Endif
Endif

GSOCIETE = COMPANY
Read [FIY]FIY0 = COMPANY;[L]LEDTYP;FIYNUM
If fstat
 ## Incorrect Fiscal Year
 Call ECR_TRACE(COMPANY-num$(FIYNUM)-mess(52,116,1),1) From GESECRAN
 ANOM = 1 : Goto FIN
Endif

Call LECTURE("CPY",COMPANY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED(LEDTYP-1),"") From CONTOBJ
CHART = [F:LED]COA
Call LECTURE("COA",CHART,"") From CONTOBJ

#-- Feature 79527 - SP2US26
Gosub VERF_HAT
Read [LNK] First
If !fstat
 If [L]TYPTRT=2
  Call ECR_TRACE(mess(186,123,1)+"."-mess(49,114,1),1) From GESECRAN
  Goto FIN
 Else
  Call ECR_TRACE(mess(43,187,1)+"."-mess(49,114,1),-1) From GESECRAN
 Endif
Endif

Case [L]TYPTRT
 When 1
  Gosub CMPBAL
 When 2
  Gosub RECBAM
Endcase


#######################################################
## End of Process (Log Reading)
#######################################################
$FIN
If !DIRECT
 Call MULTICPY(COMPANY) From AX3MONO
Endif

If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC
 If GBROWS  : Call FERME_VLC From GESECRAN : Endif
Endif
End


############################################################################################################
# Double Entry Balance Resynchronization
############################################################################################################
$RECBAM

Local Char    FILTPAG(250)(0..4)
Local Date    DATCUR, STRDAT, ENDDAT

Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

Local Integer FLCPY, FLSIT
Local Integer NBPER
Local Decimal EXE, PDEB, PFIN

Local Integer NBECR, ECRMAX
ECRMAX = 10000

## Log File Header
Call LECTURE("CPY",COMPANY,"") From CONTOBJ
Call ECR_TRACE(mess(73,116,1),0) From GESECRAN                               # Récupération balance analytique
Call ECR_TRACE(mess(2,116,1)-COMPANY,0) From GESECRAN                        # Company
Call ECR_TRACE(mess(3,116,1)-num$(FIYNUM),0) From GESECRAN                   # Fiscal Year
If ALLFCY=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                               # All Sites
Elsif FCY<>""
 Call ECR_TRACE(mess(5,116,1)-FCY,0) From GESECRAN                           # Site
Endif
If SELCUR<>""
 Call ECR_TRACE(mess(55,116,1)-SELCUR,0) From GESECRAN                       # Currency
Endif

#-- Recovery Start
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

Call DATEXE([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY,[L]STRDAT,[L]ENDDAT) From CPTSUB
If [L]STRDAT = [L]STRDATE & [L]ENDDAT = [L]ENDDATE
 TRTFIY =1 : PDEB = 1
 Call NBPER([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY,NBPER) From CPTSUB
 PFIN = NBPER
Else
 TRTFIY = 0
 Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[L]STRDATE,EXE,PDEB) From CPTSUB
 Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[L]ENDDATE,EXE,PFIN) From CPTSUB
Endif

#-- Reset to Zero
Gosub RAZBAL

#-- Resynchronization by Site
If ALLFCY=2 or FCY=""
 If ALLFCY=2
  FLCPY = 1 : FLSIT = 1
 Else
  FLCPY = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=COMPANY & FINFLG=2
  FCY = [F:FCY]FCY
  Gosub BALSIT
 Next
Else
 FLCPY = 0 : FLSIT = 1
 Gosub BALSIT
Endif
Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Recovery End
Return


$BALSIT
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'CPY="'+COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'FCYLIN="'+FCY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'ACCDAT>=['+format$(GFMD,[L]STRDATE)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'ACCDAT<=['+format$(GFMD,[L]ENDDATE)+']'," & ") From GOBJSUB
If SELCUR<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",' CUR="'+SELCUR+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCNUMDOE",'ACCNUMDOE='+num$(0)," & ") From GOBJSUB

Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;CUR;ACCDAT;ACCNUMDOE;ANALIN


TOTECR = 0
DATCUR = [0/0/0]

# To avoid the "snapshot too old"
$LOOP_BAL
NBECR  = 0
STOP = 0
Raz FILTPAG

If DATCUR<>[0/0/0]
 Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'ACCDAT>=['+format$(GFMD,ENDDATE)+']'," & ") From GOBJSUB
Endif

If FILTPAG="" : FILTPAG="1=1" : Endif

## Analytic Accounting Line
For [DAA]CLE(5) Where evalue(FILTECT) and evalue(FILTPAG)

 If NBECR>=ECRMAX
  STOP = 1
  DATCUR = [F:DAA]ACCDAT
  Break 2
 Endif

 For [DAA]CLE
  Read [HAE]HAE0 = [F:DAA]TYP ; [F:DAA]NUM
  Call BALDEM2(+1,FLCPY,FLSIT) From CPTBAL
  NBECR += 1
 Next
Next

TOTECR += NBECR
If STOP
 Goto LOOP_BAL
Endif
Filter [DAA]
Return


########################################
$RAZBAL

Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(FIYNUM)," & ") From GOBJSUB
If SELCUR<>""
 Call ADDCRIT(FILTBAL,IFILE,"CUR",' CUR="'+SELCUR+'"'," & ") From GOBJSUB
Endif

If ALLFCY=2
 For [FCY]FCY0 Where LEGCPY=COMPANY & FINFLG=2
  SITBAL = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TR1
 Next
 SITBAL = ""
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 If FCY<>""
  SITBAL = FCY
 Else
  SITBAL = ""
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
Return

$TR1
GOK = 1

Trbegin [BAM]
 If TRTFIY
  ## We re-synchronize all the Fiscal Year => Deletion of the balance on the Fiscal Year
  Delete [BAM] Where evalue(FILTBAL) & FCY=SITBAL
  If fstat=1
   GOK = -1 : GLOCK = "$BALDEM" : Goto ROLL_TR1
  Endif
 Else
  ## We don't re-synchronize all the Fiscal Year but only period(s) => Reset to zero of the amounts(s) on the period(s)
  For [BAM] Where evalue(FILTBAL) & FCY=SITBAL
   For NPER=PDEB To PFIN
    Raz [F:BAM]AMTCUR(NPER), [F:BAM]AMTLED(NPER), [F:BAM]QTY(NPER)
   Next
   Rewrite [F:BAM]
   If fstat
    GOK=0 : Call FSTA("BAM") From GLOCK : Break
   Endif
  Next
  If    GOK<0 : Goto ROLL_TR1
  Elsif GOK=0 : Goto AB_TR1
  Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif



############################################################################################################
# Comparison of the General Balance (BALANCE Table) & the Double Entry Balance (BALDEM Table)
############################################################################################################
$CMPBAL

Local Char    FILTBAL(250)(0..4)
Local Char    FILTBAM(250)(0..4)
Local Char    BALCUR(GLONCUR)

Local Date    STRDAT, ENDDAT

Local Integer IFILTA
Local Integer FLCPY, FLSIT
Local Integer NBPER

Local Decimal EXE, PDEB, PFIN
Local Decimal CUMDEB, CUMDEB2
Local Decimal CUMCDT, CUMCDT2
Local Decimal CUMDEBLED, CUMDEBLED2
Local Decimal CUMCDTLED, CUMCDTLED2

## Log File header
Call LECTURE("CPY",COMPANY,"") From CONTOBJ
Call ECR_TRACE(mess(154,104,0),0) From GESECRAN                              # Double Entry Balance Resynchronization
Call ECR_TRACE(mess(2,116,1)-COMPANY,0) From GESECRAN                        # Company
Call ECR_TRACE(mess(3,116,1)-num$(FIYNUM),0) From GESECRAN                   # Fiscal Year
If ALLFCY=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                               # All Sites
Elsif FCY<>""
 Call ECR_TRACE(mess(5,116,1)-FCY,0) From GESECRAN                           # Site
Endif
If SELCUR<>""
 Call ECR_TRACE(mess(55,116,1)-SELCUR,0) From GESECRAN                       # Selection currency
Endif

#-- Verification Start
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

Call DATEXE([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY,[L]STRDAT,[L]ENDDAT) From CPTSUB
If [L]STRDAT = [L]STRDATE & [L]ENDDAT = [L]ENDDATE
 TRTFIY =1 : PDEB = 1
 Call NBPER([M:DIA]CPY,[M:DIA]LEDTYP,[M:DIA]FIY,NBPER) From CPTSUB
 PFIN = NBPER
Else
 TRTFIY = 0
 Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[L]STRDATE,EXE,PDEB) From CPTSUB
 Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,[L]ENDDATE,EXE,PFIN) From CPTSUB
Endif

Link [BAL] With [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC As [LNK]

#-- Resynchronization by Site
If ALLFCY=2 or FCY=""
 If ALLFCY=2
  FLCPY = 1 : FLSIT = 1
 Else
  FLCPY = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=COMPANY & FINFLG=2
  FCY = [F:FCY]FCY
  Gosub VERIF
 Next

 FCY = "" : Gosub VERIF
Else
 FLCPY = 0 : FLSIT = 1
 Gosub VERIF
Endif
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Verification End
Return


$VERIF
Raz FILTBAL, IFILTA
Raz FILTBAM

Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FCY",'FCY="'+FCY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(FIYNUM)," & ") From GOBJSUB
If SELCUR<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+SELCUR+'"'," & ") From GOBJSUB
Endif
FILTBAM = FILTBAL
If dim([M:DIA]ACC)>0 & [M:DIA]ACC<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+[M:DIA]ACC+'"'," & ") From GOBJSUB
Endif

Raz CUMDEB, CUMCDT

Filter [LNK] Where evalue(FILTBAL) Order By Key CLE = LEDTYP;CPY;FCY;FIY;ACC;BPR;CUR

For [LNK]CLE Where ([GAC]SAC<>2) | ([GAC]SAC=2 & BPR<>"")
 ACCOUNT   = [F:BAL]ACC
 BPARTNER  = [F:BAL]BPR
 BALCUR = [F:BAL]CUR
 CUMDEB    = sum([F:BAL]DEB(PDEB..PFIN))
 CUMCDT    = sum([F:BAL]CDT(PDEB..PFIN))
 CUMDEBLED = sum([F:BAL]DEBLED(PDEB..PFIN))
 CUMCDTLED = sum([F:BAL]CDTLED(PDEB..PFIN))
 Gosub LIRE_BAM
 If (CUMDEB<>CUMDEB2) | (CUMCDT<>CUMCDT2) | (CUMDEBLED<>CUMDEBLED2) | (CUMCDTLED<>CUMCDTLED2)
  If [L]FCY<>""
   Call ECR_TRACE(mess(45,102,1)-ACCOUNT+","-tolower(mess(18,105,1))-BALCUR+","-tolower(mess(3,45,1))-[L]FCY-":",1) From GESECRAN
  Else
   Call ECR_TRACE(mess(45,102,1)-ACCOUNT+","-tolower(mess(18,105,1))-BALCUR+","-tolower(mess(4,116,1))-":",1) From GESECRAN
  Endif
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(format$("K:25X",mess(152,104,1))-":"-num$(CUMDEB)-mess(1,626,1)-";"-space$(20)-num$(CUMCDT)-mess(2,626,1)
&                -"**********"-mess(151,104,1)-[F:BAL]CURLED-":"-num$(CUMDEBLED)-mess(1,626,1)-";"-space$(20)-num$(CUMCDTLED)
&                -mess(2,626,1),0) From GESECRAN
  Call ECR_TRACE(format$("K:25X",mess(153,104,1))-":"-num$(CUMDEB2)-mess(1,626,1)-";"-space$(20)-num$(CUMCDT2)-mess(2,626,1)
&                -"**********"-mess(151,104,1)-[F:BAL]CURLED-":"-num$(CUMDEBLED2)-mess(1,626,1)-";"-space$(20)-num$(CUMCDTLED2)
&                -mess(2,626,1),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
 Endif
Next
Filter [LNK]
Return

$LIRE_BAM
Raz CUMDEB2, CUMCDT2, CUMDEBLED2, CUMCDTLED2
For [BAM]BAM0 Where evalue(FILTBAM) & DEBACC=ACCOUNT & DEBBPR=BPARTNER & CUR=BALCUR
 CUMDEB2    += sum([F:BAM]AMTCUR(PDEB..PFIN))
 CUMDEBLED2 += sum([F:BAM]AMTLED(PDEB..PFIN))
Next
For [BAM]BAM0 Where evalue(FILTBAM) & CDTACC=ACCOUNT & CDTBPR=BPARTNER & CUR=BALCUR
 CUMCDT2    += sum([F:BAM]AMTCUR(PDEB..PFIN))
 CUMCDTLED2 += sum([F:BAM]AMTLED(PDEB..PFIN))
Next
Return

#-- Feature 79527 - SP2US26
$VERF_HAT
Raz FILTHAT, IFILH

Call ADDCRIT(FILTHAT,IFILH,"LEDTYP",'[F:DAT]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTHAT,IFILH,"CPY",'[F:DAT]CPY="'+COMPANY+'"'," & ") From GOBJSUB
If FCY<>""
 Call ADDCRIT(FILTHAT,IFILH,"FCY",'[F:DAT]FCYLIN="'+FCY+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTHAT,IFILH,"FIY",'FIY='+num$(FIYNUM)," & ") From GOBJSUB
If SELCUR<>""
 Call ADDCRIT(FILTHAT,IFILH,"CUR",'[F:DAT]CUR="'+SELCUR+'"'," & ") From GOBJSUB
Endif


#-- Link GACCOUNT & GACCENTRY
Link [DAT] With [HAT]HAT0~=[F:DAT]TYP;[F:DAT]NUM As [LNK]
&              Where [F:HAT]FLG>=100 & evalue(FILTHAT)
Return


######################################################################################
## RECUPBAM Screen Labels
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M]CPY,9) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char LED(GLONLED),DEV(GLONCUR)
Local Integer ILED
Call LECLED([M]CPY,VALEUR,LED,DEV) From CPTDIV
If VALEUR <= 0 :  GMESSAGE = func AFNC.MES1(mess(283,7711,1),[M]CPY) : mkstat = 2 :  Endif
ILED = find(LED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M]COA = GLEDCOA(ILED)
Call DEFEXE([M:DIA]CPY,VALEUR,[M]FIY) From CPTSUB
Call DATEXE([M:DIA]CPY,VALEUR,[M]FIY,[M]STRDAT,[M]ENDDAT) From CPTSUB
If !GIMPORT
 Affzo FIY, STRDAT, ENDDAT
Endif
If VALEUR <= 0 :  GMESSAGE = func AFNC.MES1(mess(283,7711,1),[M]CPY) : mkstat = 2 :  Endif
End

Subprog C_FIY(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;VALEUR
If fstat
 # Incorrect Fiscal Year
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
If [F:FIY]FIYSTA>2
 Local Integer OK
 # Fiscal Year Already Closed
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]STRDAT = [F:FIY]FIYSTR
[M]ENDDAT = [F:FIY]FIYEND
End

Subprog AS_FIY(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Call DEFEXE([M]CPY,[M]LEDTYP,VALEUR) From CPTSUB
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif : # Fiscal Periods
Local Decimal EXE, PER
Local Date STRDATE, ENDDATE
Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,VALEUR,EXE,PER) From CPTSUB
If EXE<>[M:DIA]FIY
 ## Date incorrect with respect to the Fiscal Year Entered
 GMESSAGE = mess(150,104,1)
 mkstat = 2 : End
Endif
Call DATPER([M:DIA]CPY,[M:DIA]LEDTYP,EXE,PER,STRDATE,ENDDATE) From CPTSUB
If STRDATE<>VALEUR
 ## The date is not a period start date
 GMESSAGE = mess(49,108,1)
 mkstat = 2 : End
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif : # Fiscal Years
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif : # Fiscal Periods
Local Decimal EXE, PER
Local Integer OK
Local Date STRDATE, ENDDATE
Call GETPERSOC([M:DIA]CPY,[M:DIA]LEDTYP,VALEUR,EXE,PER) From CPTSUB
If EXE<>[M:DIA]FIY
 ## Date incorrect with respect to the Fiscal Year Entered
 GMESSAGE = mess(150,104,1)
 mkstat = 2 : End
Endif
Call DATPER([M:DIA]CPY,[M:DIA]LEDTYP,EXE,PER,STRDATE,ENDDATE) From CPTSUB
If ENDDATE<>VALEUR
 ## The date is not a period end date
 GMESSAGE = mess(50,108,1)
 mkstat = 2 : End
Endif
End

