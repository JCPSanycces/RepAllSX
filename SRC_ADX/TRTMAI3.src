#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
# Etape 3 de la définition d'un mailing                             Module CRM          29 novembre 2000 #
##########################################################################################################
# Sélection interlocuteurs
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZCCNSEL
Global Integer GISTATRET

  GSZCCNSEL = "CCN"
  GISTATRET = 0
  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:MOG]) : Local File MKGOPG [MOG] : Endif
  If !clalev([F:MKL]) : Local File MKGLEVEL [MKL] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:SCLW]) : Local File SELCMGLIS [SCLW] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETABOU(GSPE1) = 0
  If [M:MAI3]CNTTTR <> "" Then
    ETABOU(GSPE1) = 1
  Else
    If [M:MAI3]NBMQR >0 Then
      ETABOU(GSPE1) = 1        
    Endif
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer INBLIGNE
Local Integer INBCOL

  INBLIGNE = 0
  INBCOL = 0
  [M:MAI3]MASTERSEL = 1
  #Teste si une sélection maitre a été définie précédemment.
  Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  For [SEC]
    #GIMASTERSEL = 1
    [M:MAI3]MASTERSEL=2
    Break
  Next
  Filter [SEC]
  #Définit GIDEFADD et GIHIEBPR en fonction du type de sélection en cours de demande
  If [M:MAI3]MASTERSEL = 2 Then
    [M:MAI3]DEFADD = 1
    [M:MAI3]HIEBPR = 2
  Else
    [M:MAI3]DEFADD = 2
    [M:MAI3]HIEBPR = 1
  Endif
  #Affiche les informations d'une sélection déjà définie pour cette opération.
  Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL = "CCN"
  For [SEC]
    [M:MAI3]CNTTTR = [F:SEC]CNTTTR
    [M:MAI3]DEFADD = [F:SEC]DEFADD
    [M:MAI3]HIEBPR = [F:SEC]HIEBPR
    [M:MAI3]USEQUR  = [F:SEC]USEQUR 
    Break
  Next
  Filter [SEC]
  #Affiche la selection des ciblages si il y e n a
  INBCOL  = 0
  INBLIGNE = 0 
  Read[DVA]DVA0="MKL";GSZOPGNUM
  While [F:DVA]ALHX(INBCOL) <> ""
    Read [MQR]MQR0=[F:DVA]ALHX(INBCOL)
    If fstat = 0 Then
      [M:MAI3]QURNUM(INBLIGNE) = [F:MQR]QURNUM 
      [M:MAI3]QURNAM(INBLIGNE) = [F:MQR]QURNAM 
      INBLIGNE += 1
    Endif
    INBCOL+= 1
  Wend
  [M:MAI3]NBMQR= INBLIGNE 
  #Définit GIDEFADD pour un usage ultérieur
  If [M:MAI3]MASTERSEL = 2 Then
    Actzo [M:MAI3]DEFADD
    Actzo [M:MAI3]CNTTTR
  Else
    Grizo [M:MAI3]DEFADD
    Grizo [M:MAI3]CNTTTR
  Endif
  Affzo [M:MAI3]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:MAI3]
  Kill GSZCCNSEL
  Kill GISTATRET
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Gosub ONNOTHING
    When "E"
      If [M:MAI3]CNTTTR = "" and [M:MAI3]NBMQR = 0 Then
        FIN = 0
      Else
        Gosub CANCELSTEP
        Gosub VARCCNSEL From TRTMGG
        Gosub RUNSELCCN From TRTMGG
        FIN = 1
        GISTECPL(GICSTEP-1) = 1
      Endif
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONNOTHING
  #Si aucune sélection tiers n'est définie on ne fait rien.
  If [M:MAI3]MASTERSEL=1 Then
    Return
  Endif
  #Si aucun titre générique n'est renseigné, on ne fait rien.
  If [M:MAI3]CNTTTR = "" Then
    Return
  Endif
  Gosub CANCELSTEP
  Gosub VARCCNSEL From TRTMGG
  INOTHING = 1
  Gosub CRECCNSEL From TRTMGG
  INOTHING = 0
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

##########################################################################################################
$CANCELSTEP
Local Integer ITRANSFLG

  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:MKL]) : Local File MKGLEVEL [MKL] : Endif

  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SEC]
  Endif
  Delete [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL = "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SEC") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
  Endif
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SCL") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
  Endif
  Delete [DVA] Where [F:DVA]OBC = "MKL" and [F:DVA]PARAM = GSZOPGNUM 
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("DVA") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [MKL]
  Endif
  Delete [MKL] Where [F:MKL]OPGNUM= GSZOPGNUM and [F:MKL]KEYTYPE = "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("MKL") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
Return
