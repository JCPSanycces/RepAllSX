#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# FUNUTIPOC : Contrôle des contrats inter-sites             HN  23/10/03 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                 #
#   - TRTUTIPOC : Fonction de contrôle des contrats inter-sites          #
##########################################################################

$ACTION
#------------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)               #
# TRTUTIPOC  : Fonction de contrôle des contrats inter-sites #
#------------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
If dim(OK)<1  Local Integer OK : Endif
OK=1 : Call OUINON(mess(533,197,1),OK) From GESECRAN
If OK<>2  FIN=1 : Return : Endif
Gosub OUVRE        : # Ouverture fichiers et déclaration variables locales
Return


###########################
# Exécution du traitement #
###########################
$EXEC
Call OUVRE_TRACE(mess(533,197,1)) From LECFIC
#----- Début du traitement -----#
$BOUCLE_POH
CRITERE='[F:POH]POHTYP=2 & [F:POH]BETFCY=2 & [F:POH]ENDDAT>=date$' : # Contrat inter-sites
For [POH] POH0 Where evalue(CRITERE)
  NBENR+=1
  WMSG=[F:POH]POHNUM+space$(GLONPOH-len([F:POH]POHNUM)+1)+":"
  #----- Lecture du Business Partner fournisseur si nécessaire -----#
  If [F:BPR]BPRNUM<>[F:POH]BPSNUM
    Read [BPR] BPR0=[F:POH]BPSNUM
    If fstat 
      WMSG-=mess(12,100,1)-"BPARTNER"-[F:POH]BPSNUM+", Error="+num$(fstat)
      Call ECR_TRACE(WMSG,1) From GESECRAN
      NBCOR+=1
      Raz [F:BPR]
    Endif
  Endif
  Raz FLAGBPC
  If [F:BPR]FCY<>""
    Raz GSOCIETE, GCPY
    I=find([F:POH]POHFCY,GSITE(1..GNBSITE))
    If I  GSOCIETE=GSOCSITE(I) : Endif
    I=find([F:BPR]FCY ,GSITE(1..GNBSITE))
    If I  GCPY    =GSOCSITE(I) : Endif
    I=[F:POH]BETCPY
    Read [BPR2] BPR2(2)=2;[F:POH]POHFCY
    If fstat  Raz [F:BPR2] : Endif
    [G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut
    #----- Le client lié au site de commande ne correspond pas ! -----#
    If [F:BPR2]BPRNUM<>[F:POH]BPCORD
      WMSG-=mess(534,197,1)-[F:BPR2]BPRNUM-"<>"-[F:POH]BPCORD
      Call ECR_TRACE(WMSG,1) From GESECRAN
      NBCOR+=1
      FLAGBPC=1
    Else
      #---- Vérif que le site réception correspond à une adresse client livré -----#
      Filter [BPD] Where BPCNUM=[F:POH]BPCORD & RCPFCY=[F:POH]RCPFCY
      Look [BPD] BPD0 First
      Filter [BPD]
      If fstat
        WMSG =[F:POH]POHNUM+space$(GLONPOH-len([F:POH]POHNUM))-":"
        WMSG-=right$(mess(267,194,1),instr(1,mess(267,194,1),":")+1)
        WMSG-=[F:POH]BPCORD-"("+[F:POH]RCPFCY+")"
        Call ECR_TRACE(WMSG,1) From GESECRAN
        NBCOR+=1
      Else
        #----- Cela ne devrait jamais arriver sauf si on on modifie le site lié au client !
        If (GSOCIETE<>GCPY & GSOCIETE<>"" & GCPY<>"") & [F:POH]BETCPY=1
          # inter-site : le site de réception doit être sur la m soc que le site fourn
          WMSG-=mess(536,197,1)-[F:POH]RCPFCY-"("+GSOCIETE+")"-[F:BPR]FCY-"("+GCPY+")"
          Call ECR_TRACE(WMSG,1) From GESECRAN
          NBCOR+=1
        Elsif (GSOCIETE=GCPY & GSOCIETE<>"" & GCPY<>"") & [F:POH]BETCPY=2
          # inter-soc : le site de réception ne doit être pas sur la m soc que le site fourn
          WMSG-=mess(535,197,1)-[F:POH]RCPFCY-"("+GSOCIETE+")"-[F:BPR]FCY-"("+GCPY+")"
          Call ECR_TRACE(WMSG,1) From GESECRAN
          NBCOR+=1
        Endif
      Endif
    Endif
    #----- Vérif que le site de vente correspond au fournisseur -----#
    If [F:POH]SALFCY<>"" & [F:POH]SALFCY<>[F:BPR]FCY
      WMSG =[F:POH]POHNUM+space$(GLONPOH-len([F:POH]POHNUM)+1)+":"
      WMSG-=mess(606,197,1)-[F:POH]SALFCY-"<>"-[F:BPR]FCY
      Call ECR_TRACE(WMSG,1) From GESECRAN
      NBCOR+=1
    Endif
  Else
    WMSG-=mess(408,199,1)-[F:POH]BPSNUM
    Call ECR_TRACE(WMSG,1) From GESECRAN
    NBCOR+=1
  Endif
  #----- Vérif que les sites réception lignes correspondent à une adr client livré -----#
  If FLAGBPC=0
    For [POC] POC0 Where POHNUM=[F:POH]POHNUM
      If [F:POC]PRHFCY<>[F:POH]RCPFCY
        NBENR+=1
        Filter [BPD] Where BPCNUM=[F:POH]BPCORD & RCPFCY=[F:POC]PRHFCY
        Look [BPD] BPD0 First
        Filter [BPD]
        If fstat
          WMSG =[F:POH]POHNUM+space$(GLONPOH-len([F:POH]POHNUM))
          WMSG-=[F:POC]ITMREF+space$(GLONITM-len([F:POC]ITMREF))-":"
          WMSG-=right$(mess(267,194,1),instr(1,mess(267,194,1),":")+1)
          WMSG-=[F:POH]BPCORD-"("+[F:POC]PRHFCY+")"
          Call ECR_TRACE(WMSG,1) From GESECRAN
          NBCOR+=1
        Endif
      Endif
    Next
  Endif
Next
WMSG=mess(451,197,1)-num$(NBENR)+",  "-mess(99,116,1)-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Raz WMSG
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
If !GSERVEUR
  #----- Fermeture et affichage de la trace -----#
  Call FERME_TRACE From LECFIC : TRA=1
Endif
Close Local File  [POH]
Close Local File  [BPR]
Close Local File  [BPR2]
Close Local File  [BPD]
Return


#--------------------------------------------#
# Variables locales + ouverture des fichiers #
#--------------------------------------------#
$OUVRE
#----- Variables locales -----#
Local Char     CRITERE(90), WMSG(100)
Local Integer  I, NBENR, NBCOR, FLAGBPC
#----- Ouverture des fichiers -----#
If !clalev([F:POH])   Local File PORDER     [POH]  : Endif
If !clalev([F:POC])   Local File PORDERC    [POC]  : Endif
If !clalev([F:BPR])   Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPR2])  Local File BPARTNER   [BPR2] : Endif
If !clalev([F:BPD])   Local File BPDLVCUST  [BPD]  : Endif
Return


###################
# Erreur en Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
