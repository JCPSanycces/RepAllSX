#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ABW",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------------------#
$ACTION
Case ACTION
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "TRT_DIV"   : Gosub TRT_DIV
Endcase
Return

#-------------------------------#
$SEL_LISTE
Case LISTE
 When "ASELSOLBI"
  Local Char LIGNE(250) , NOMFIC(GDIMFIC) , TEXTE(30)(1..10,1..1) , TIT(30)(0..1) , CAR(1)
  Local Integer OKSOL
  Call BOWORLD(NOMFIC)
  If NOMFIC="" : Return : Endif
  TIT(0) = mess(18,100,1) : # Sélection
  TIT(1) = mess(232,151,1) : # Solution
  Openi NOMFIC,0 Using [BOS_]
  Iomode adxifs ""  Using [BOS_]
  Iomode adxirs chr$(10)  Using [BOS_]
  Iomode adxium GUTF8  Using [BOS_]
  Raz OKSOL
  Rdseq LIGNE Using [BOS_]
  While !fstat
   If instr(1,toupper(LIGNE),"<SOLUTION ")
    OKSOL = instr(1,toupper(LIGNE),toupper("ID='"+GINSTID+"'"))
    OKSOL += instr(1,toupper(LIGNE),toupper('ID="'+GINSTID+'"'))
   Elsif OKSOL & instr(1,toupper(LIGNE),toupper("</SOLUTION>"))
    OKSOL = 0
   Endif
   If OKSOL : # On est dans le noeud de la bonne solution x3
    If instr(1,toupper(LIGNE),toupper("<SOLUTIONBI "))
     CAR = ""
     I = instr(1,toupper(LIGNE),toupper("ID='"))
     If I
      CAR = "'"
     Else
      I = instr(1,toupper(LIGNE),toupper('ID="'))
      If I : CAR = '"' : Endif
     Endif
     If CAR<>""
      I += 3
      J = instr(I+1,toupper(LIGNE),CAR)
      If J
       NBTEX += 1 : TEX(NBTEX) = seg$(LIGNE,I+1,J-1)
      Endif
     Endif
    Endif
   Endif
   Rdseq LIGNE Using [BOS_]
  Wend
  Openi Using [BOS_]
Endcase
Return

#-------------------------------#
$TRT_DIV
Case TRAIT
 When "ACNTSOLBI"
  Local Char MACHINE(250)
  Call MACHINE_BO(VALEUR,MACHINE)
  If MACHINE=""
   Call ERREUR(mess(78,148,1)) From GESECRAN : # Impossible de déterminer la machine BO
   mkstat = 2 : Return
  Endif
Endcase
Return

#---------------------------------------------------------------------------------------------#
# Création des répertoires de l'application BI dans la solution BI
#---------------------------------------------------------------------------------------------#

Subprog CREAPL(APPLI,OK)
Value    Char    APPLI
Variable Integer OK

Onerrgo ERREUR

If GINFO
 Call AFF_VLC(mess(10,125,1),"") From GESECRAN : # Mise à jour répertoires
Endif
Call ECR_TIME(mess(10,125,1)) From DOSSUB :  # Mise à jour répertoires

Local Char    REPERT(GDIMFIC) , REPBASE(GDIMFIC) , PATH(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , APPLI_BO(GDIMFIC)
Local Char    REP(GDIMFIC) , FICH(GDIMFIC) , ORDSYS(250)
Local Char    NOMFIC(GDIMFIC)
Local Integer STAT , K , ER

Call MACHINE_BO([F:ABW]SOLBI,MACHINE)
If MACHINE = ""
 Call ECR_TRACE(mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
 OK = 0 : End
Endif
APPLI_BO = [F:ABW]COD

# Recherche application racine

Call VAR_BOWORLD("path",[F:ABW]SOLBI,"",PATH,ER)

# Répertoire de base

ER = 0
REPBASE = PATH
If !find(right$(REPBASE,len(REPBASE)),"\","/")
 REPBASE += "/"
Endif
REPBASE += APPLI_BO
REPERT = filpath(REPBASE,"","","","",MACHINE)
Gosub CREREP
If ER : OK = 0 : End : Endif

# Fichiers .users et .passwd
# Il faut les créer maintenant pour que le prochain filpath reconnaisse l'appli

For FICH = ".users",".passwd"
 NOMFIC = filpath(REPBASE,FICH,"","","",MACHINE)
 If filinfo(NOMFIC,0)<0
  Call ECR_TRACE("|"+mess(12,125,1)-ctrans(NOMFIC,"\","/"),0) From GESECRAN : # Création du fichier
  Openo NOMFIC , 0
  Openo
  If filinfo(NOMFIC,0)<0
   Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(NOMFIC,"\","/")+"|",1) From GESECRAN
   ER = 1 : Break
  Endif
 Endif
Next FICH
If ER : OK = 0 : End : Endif

# Fichier appli.ext : un datawarehouse ne peut être géré que par une seule appli

Gosub SET_EXT From SUBABW
NOMFIC = filpath(REPBASE,APPLI,EXT,"","",MACHINE)
If filinfo(NOMFIC,0)<0
 Call ECR_TRACE("|"+mess(12,125,1)-ctrans(NOMFIC,"\","/"),0) From GESECRAN : # Création du fichier
 Openo NOMFIC , 0
 Openo
 If filinfo(NOMFIC,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(NOMFIC,"\","/")+"|",1) From GESECRAN
  ER = 1
 Endif
Endif
If ER : OK = 0 : End : Endif

# Fichier APL.ini

NOMFIC = filpath("","APL","ini",APPLI_BO,"",MACHINE)
Openo NOMFIC,0
adxifs = "" : adxirs = chr$(10)
Wrseq "#<AdxTJ>@(#)%I%"
Wrseq 'adxmother(0) = "'+APPLI_BO+'"'
Wrseq 'adxmso       = 10'
Wrseq 'adxmto       = 80'
Wrseq 'maxmem       = 2560'
Wrseq 'adxtct       = "APLCOM"'
Wrseq 'adxtlk       = "APLLCK"'
Wrseq 'adxtms       = "APLSTD"'
Openo

# Sous-répertoires

For REP = "TRT","FIL","TRA","tmp"
 REPERT = filpath(REP,"","",APPLI_BO,"",MACHINE)
 Gosub CREREP
 If ER : Break : Endif
Next REP
If ER : OK = 0 : End : Endif

Onerrgo

OK = 1

End

#--------------------------#
$CREREP
If filinfo(REPERT,0)<0
 Call ECR_TRACE("|"+mess(11,125,1)-ctrans(REPERT,"\","/"),0) From GESECRAN : # Création du répertoire
 K = instr(1,REPERT,"@")
 If K
  ORDSYS = 'ae_mkdir'-'"'+right$(REPERT,K+1)+'"'
 Else
  ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
 Endif
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 If filinfo(REPERT,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+ctrans(REPERT,"\","/")+"|",1) From GESECRAN
  ER = 1
 Endif
Endif
Return

#--------------------------#
$ERREUR
ER = errn
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(ER)+"\"+errmes$(ER)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

#---------------------------------------------------------------------------------------------#
# Création de l'application BI dans la base BI (Oracle ou SQL)
#---------------------------------------------------------------------------------------------#

Subprog CREBASE(APPLI,OK)
Value    Char    APPLI
Variable Integer OK

Onerrgo ERREUR

Local Char    ORDSYS(250)(1..2)
Local Integer STAT , I , ER , K
Local Char    MESSAGE(255)(1..2) , FICHIERLOG(GDIMFIC) , LIGNE(255)
Local Char    APPLI_BO(GDIMFIC) , MACHINE(GDIMFIC)
Local Char    FICTRA(GDIMFIC) , FICTRT(GDIMFIC)
Local Char    TYPBAS(20) , TYPOS(20) , PWD(50) , DATNAM(50) , DATSRC(50) , PATH(GDIMFIC)
Local Char    X3_PWD(100), AUTHEN_LOGIN(100)

##############################################################################################
#----- Pour NT
# les quatre variables suivantes devront être fournies par le programme de valid de dossier
# ces paramètres sont utilisés lors de l'appel de adcrapora.bat et adcrapdb2.bat
# et adcrapss7 lors de groupe de fichier
##############################################################################################

Local Integer INITINCDAT : # taille initiale DAT
Local Integer INITNXTDAT : # taille next     DAT
Local Integer INITINCIDX : # taille initiale IDX
Local Integer INITNXTIDX : # taille initiale IDX

##############################################################################################
#----- Pour Db2
# PC 16/12/99
# les variables suivantes seront renseignees afin de définir les chemins d'installations des conteneurs
# Pour l'instant ils sont definis par defaut
# mais on peut tres bien concevoir qu'un jour ils soient differents ! ! !
##############################################################################################

Local Char    CHMCONTDAT(100) : # chemin d'acces au conteneur de donnees
Local Char    CHMCONTIDX(100) : # chemin d'acces au conteneur des index

Call MACHINE_BO([F:ABW]SOLBI,MACHINE)
APPLI_BO = [F:ABW]COD

FICTRA = filpath("TRA",GTRACE,"tra")

Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",TYPBAS,ER)
Call VAR_BOWORLD("os",[F:ABW]SOLBI,"database",TYPOS,ER)
Case TYPBAS
 When "ORACLE"    : Gosub ORACLE
 When "SQLSERVER" : Gosub SQLS7
Endcase

OK = 1
MESSAGE(1) = "SPACE FOR STORAGE NOT FOUND"
MESSAGE(2) = "USER NOT FOUND"
FICHIERLOG = filpath("!","tmp/show_user_"+APPLI_BO,"log","","",MACHINE)
If filinfo(FICHIERLOG,0)>0
 Openi FICHIERLOG Using [LOG_]
 Iomode adxifs ""       Using [LOG_]
 Iomode adxirs chr$(10) Using [LOG_]
 Iomode adxium GASCII   Using [LOG_]
 Rdseq LIGNE Using [LOG_]
 While !fstat
  For I=1 To 2
   If instr(1,LIGNE,MESSAGE(I))<>0
    Call ECR_TRACE(MESSAGE(I),1) From GESECRAN
    OK = 0 : Break
   Endif
  Next I
  Rdseq LIGNE Using [LOG_]
 Wend
 Openi Using [LOG_]
Endif

Onerrgo

End

#--------------------------#
#---- pour Oracle
#--------------------------#

$ORACLE
Local Char WOS(10)
# Os de la solution décionnelle
#Call VAR_BOWORLD("os",[F:ABW]SOLBI,"database",WOS,ER) From ABICREBAS
#If ER : OK = 0 : Return : Endif

#If WOS="" : WOS= GOS : Endif

WOS =  tolower(GOS) : # 119668

# Mot de passe system
Call VAR_BOWORLD("adminpwd",[F:ABW]SOLBI,"database",PWD,ER)
If ER : OK = 0 : Return : Endif

Call CREER_ROLE_BI([F:ABW]SOLBI,APPLI_BO,ER) From TRTGRANT
If ER : OK = 0 : Return : Endif

If GINFO
   Call AFF_VLC(mess(13,125,1),"") From GESECRAN : # Création user Oracle
Endif
Call ECR_TIME(mess(13,125,1)) From DOSSUB : # Création user Oracle


# pour instant on va chercher dans solution de l appli mais il faudra peut etre voir a prendre ailleurs
#recuperation du password pour X3 tiger par example X3_PWD
# si on trouve rien tiger par defaut......
Call PASSWD("database.software.sqlfolderpwd",X3_PWD,ER) From DOSBASE

# recuperation du compte sa....AUTHEN_LOGIN
# si on trouve rien system par défaut.....
Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,ER) From DOSBASE


If WOS= "unix" : # Unix

  # Recherche application racine
  Call VAR_BOWORLD("path",[F:ABW]SOLBI,"",PATH,ER)
  #####################################################################################################
  # usage : $1 [-v] [-p syspas] -d sizdat -i sizidx -r appliref [-o dossier_origine] nomap idapl
  #####################################################################################################

  ORDSYS(1)  = 'adcrap'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-u'-num$(AUTHEN_LOGIN)
  Endif
  ORDSYS(1) -= '-p "'-num$(PWD)+'"'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-P'-num$(X3_PWD)
  Endif
  ORDSYS(1) -= '-d'-num$([F:ABW]SIZDAT)
  ORDSYS(1) -= '-i'-num$([F:ABW]SIZIDX)
  ORDSYS(1) -= '-r BIDON'
  ORDSYS(1) -= '-o BI$'
  ORDSYS(1) -= APPLI_BO
  ORDSYS(1) -= APPLI_BO
  ORDSYS(2)  = FICTRA
  Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS

 Else  : # Windows

  #########################################################################
  # Windows NT (identifié comme Dos ! )
  # Attention : On utilise les variables ORACLE_SID et ORACLE_BASE
  # qui doivent donc être définies dans la base de registre ...
  #########################################################################

  # Modifier les lignes suivantes :
  INITINCDAT = 100
  INITNXTDAT = 100
  INITINCIDX = 100
  INITNXTIDX = 100

  CHEMINWRK = filpath("!","tmp","","","",MACHINE)
  K = instr(1,CHEMINWRK,"@")
  If K
   CHEMINWRK = right$(CHEMINWRK,K+1)
  Endif
  FICTRT = filpath("!","ebin\adcrapora","bat","","",MACHINE)
  K = instr(1,FICTRT,"@")
  If K
   FICTRT = right$(FICTRT,K+1)
  Endif

  # Nom de la base
  Call VAR_BOWORLD("name",[F:ABW]SOLBI,"database",DATNAM,ER)
  If ER : OK = 0 : Return : Endif

  ###########################################################################################
  # Usage :
  # -------
  #   adcrapora p1 p2 p3 p4 p5 p6 p7 p8 p9 p10
  #
  #   p1  = Data tablespace size
  #   p2  = Index tablespace size
  #   p3  = Folder name
  #   p4  = Parent Folder (parent folder for archive folder or folder name)
  #   p5  = system login a partir de R091
  #   p6  = system password
  #   p7  = Oracle file identifier
  #   p8  = Oracle SID
  #   p9  = working path : adxdir + tmp (ex. d:\x3\adox3\tmp) (%ADXDIR%\tmp)
  #   p10  apartir de R091 password x3 folder like tiger
  ###########################################################################################

  ORDSYS(1) = FICTRT
  ORDSYS(1) -= num$([F:ABW]SIZDAT)
  ORDSYS(1) -= num$([F:ABW]SIZIDX)
  ORDSYS(1) -= APPLI_BO
  ORDSYS(1) -= "BI$"
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        ORDSYS(1) -= num$(AUTHEN_LOGIN)
  Endif
  ORDSYS(1) -= '"'+num$(PWD)+'"'
  ORDSYS(1) -= APPLI_BO
  ORDSYS(1) -= DATNAM
  ORDSYS(1) -= '"'+CHEMINWRK+'"'#-num$(INITINCDAT)-num$(INITNXTDAT)-num$(INITINCIDX)-num$(INITNXTIDX)
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        ORDSYS(1) -= num$(X3_PWD)
  Endif
  ORDSYS(2) = FICTRA
  Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
Endif
Return

$RIEN
Resume

#--------------------------#
#----- Pour Sql server
#--------------------------#

$SQLS7
# a faire pour linux aussi .......

#recuperation du password pour X3 tiger par example X3_PWD
# si on trouve rien tiger par defaut......
Call PASSWD("database.software.sqlfolderpwd",X3_PWD,ERR) From DOSBASE

# jira X3-86047 86048 86049
# recuperation du compte sa....AUTHEN_LOGIN
# si on trouve rien sa par défaut.....
Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,ERR) From DOSBASE


If GINFO
 Call AFF_VLC(mess(80,125,1),"") From GESECRAN : # Création user Sql-server
Endif
Call ECR_TIME(mess(80,125,1)) From DOSSUB : # Création user Sql-server

# Modifier les lignes suivantes :
INITINCDAT = 100
INITNXTDAT = 100
INITINCIDX = 100
INITNXTIDX = 100

CHEMINWRK = filpath("!","tmp","","","",MACHINE)
K = instr(1,CHEMINWRK,"@")
If K
 CHEMINWRK = right$(CHEMINWRK,K+1)
Endif

FICTRT = filpath("!","ebin\adcrapss7","bat","","",MACHINE)
K = instr(1,FICTRT,"@")
If K
 FICTRT = right$(FICTRT,K+1)
Endif

# Nom de la base
Call VAR_BOWORLD("name",[F:ABW]SOLBI,"database",DATNAM,ER)

# Mot de passe sa
Call VAR_BOWORLD("adminpwd",[F:ABW]SOLBI,"database",PWD,ER)

ORDSYS(1) = FICTRT
ORDSYS(1) -= APPLI_BO
ORDSYS(1) -= DATNAM
ORDSYS(1) -= CHEMINWRK
ORDSYS(1) -= "BI$"

If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        #################################################################################
        # p1 = Folder name (ex. DEMO)
        # p2 = Database name (ex. Adonix)
        # p3 = Working path (ADXDIR\tmp)
        # p4 = Parent Folder (parent folder for archive folder or folder name)
        # p5 = AUTHENTIFICATION LOGIN (EXAMPLE SA )
        # p6 = AUTHENTIFICATION password
        # p7 = X3 password For Folder 'ex. tiger'
        # p8 = Repartition in file groups YES/NO
        # p9 = Data file size if file groups
        # p10 = Index file size if file groups
        #################################################################################
        ORDSYS(1) -= '"'+num$(AUTHEN_LOGIN)+'"'-'"'+num$(PWD)+'"'-'"'+num$(X3_PWD)+'"'
Else
      #################################################################################
      # p1 = Folder name (ex. DEMO)
      # p2 = Database name (ex. Adonix)
      # p3 = Working path (ADXDIR\tmp)
      # p4 = Parent Folder (parent folder for archive folder or folder name)
      # p5 = sa password
      # p6 = Repartition in file groups YES/NO
      # p7 = Data file size if file groups
      # p8 = Index file size if file groups
      #################################################################################
      ORDSYS(1) -= '"'+num$(PWD)+'"'
Endif
If dim([F:ABW]GRPFIL)<=0 or [F:ABW]GRPFIL=1
            ORDSYS(1) -= 'NO'
Elsif [F:ABW]GRPFIL=2
            ORDSYS(1) -= 'YES'
Endif
ORDSYS(1) -= num$(INITINCDAT)
ORDSYS(1) -= num$(INITINCIDX)

ORDSYS(2) = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS




#---- fichier adxodbc
# on execute adxodbc pour creer le fichier adxodbc qui va bien ...
# le 03/10/2000 pour les groupes de fichiers adxodbc doit donner le nom des groupes de fichier dat et idx
# 4 octobre 2002 on ne cree plus par defaut le fichier adxodbc sauf si groupe fichier

If dim([F:ABW]GRPFIL)>0 and [F:ABW]GRPFIL=2

 #################################################################################################
 # adxodbc -b databasename -u folder -p passwd -d DATASOURCE -t folder_DAT -i folfer_IDX folder
 #################################################################################################

 Call VARADX("DATASOURCE",MACHINE,DATSRC) From ADXD

 ORDSYS(1) = 'adxodbc'
 ORDSYS(1) -= '-b'-DATNAM
 ORDSYS(1) -= '-u'-APPLI_BO
 ORDSYS(1) -= '-p'-X3_PWD
 ORDSYS(1) -= '-d'-DATSRC
 ORDSYS(1) -= '-t'-APPLI_BO+'_DAT'
 ORDSYS(1) -= '-i'-APPLI_BO+'_IDX'
 ORDSYS(1) -= APPLI_BO
 ORDSYS(2) = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
Endif
Return

#-----------------------------------------------------------------------------------------------------#
# Machine de la solution BI
#-----------------------------------------------------------------------------------------------------#

Subprog MACHINE_BO(SOLBI,MACHINE)
Value Char SOLBI
Variable Char MACHINE
Local Char PORT(GDIMFIC)
Local Integer ER
Call VAR_BOWORLD("host",SOLBI,"runtime",MACHINE,ER)
If ER
 MACHINE = "" : End
Elsif MACHINE=""
 MACHINE = adxmac(0)
Endif
Call VAR_BOWORLD("port",SOLBI,"runtime",PORT,ER)
If ER
 MACHINE = "" : End
Elsif PORT<>""
 MACHINE += ":"+PORT
Endif
End

#----------------------------------------------#
# Recherche du fichier boworld
#----------------------------------------------#

Subprog BOWORLD(NOMFIC)
Variable Char NOMFIC
Local Char PORT(250) , MACHINE(250) , REPERT(GDIMFIC)
Local Integer ERR
NOMFIC = ""
Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If ERR or PORT="" : End : Endif
Call RECHPROP("component.busobj.servername",MACHINE,ERR) From INTRUTILA
If ERR or MACHINE="" : End : Endif
Call RECHPROP("component.busobj.path",REPERT,ERR) From INTRUTILA
If ERR or REPERT="" : End : Endif
NOMFIC = filpath(REPERT,"boworld","xml","","",MACHINE+":"+num$(PORT))
If filinfo(NOMFIC,0)<=0 : NOMFIC = "" : End : Endif
End

#-----------------------------------------#
# Structure du fichier BOWORLD
#-----------------------------------------#
#<SOLUTION ID='' HOST='' PATH=''>
#    <PROXYPASS></PROXYPASS>
#    <SOLUTIONBIS>
#        <SOLUTIONBI ID='' SUPERUSER='' SUPERVPWD=''>
#            <HOST></HOST>
#            <PATH></PATH>
#            <DATABASE ID='' >
#                <NAME></NAME>
#                <TYPE></TYPE>
#                <HOST></HOST>
#                <PORT></PORT>
#                <OS></OS>
#                <ADMINUSER></ADMINUSER>
#                <ADMINPWD></ADMINPWD>
#                <DBLINK></DBLINK>
#            </DATABASE>
#            <RUNTIME ID='' >
#                <HOST></HOST>
#                <PORT></PORT>
#                <PATH></PATH>
#                <OS></OS>
#            </RUNTIME>
#        </SOLUTIONBI>
#    </SOLUTIONBIS>
#</SOLUTION>

#-----------------------------------------------------------------------------------------------------#
# Valeur d'un attribut (parcours du noeud de la solution BI dans le fichier boworld)
#-----------------------------------------------------------------------------------------------------#

Subprog VAR_BOWORLD(PROPERTY,SOLBI,DATA,VPROP,ERR)
Value Char PROPERTY  : # Nom de l'attribut
Value Char SOLBI     : # Nom de la solution BI (facultatif)
Value Char DATA      : # Nom du noeud (database,runtime) (facultatif)
Variable Char VPROP  : # Valeur de l'attribut
Variable Integer ERR : # <>0 -> erreur

Local Char    NOMFIC(GDIMFIC) , LIGNE(250), VALPROP(250)
Local Integer I , J , OKSOL , OKBI , OKDAT

Call BOWORLD(NOMFIC)
If NOMFIC="" : ERR = 1 : End : Endif

# Contenu du fichier boworld
ERR = 1
Openi NOMFIC,0 Using [BOS_]
Iomode adxifs ""  Using [BOS_]
Iomode adxirs chr$(10)  Using [BOS_]
Iomode adxium GUTF8  Using [BOS_]
Raz OKSOL , OKBI , OKDAT
Rdseq LIGNE Using [BOS_]
While !fstat
 If instr(1,toupper(LIGNE),"<SOLUTION ")
  OKSOL = instr(1,toupper(LIGNE),toupper("ID='"+GINSTID+"'"))
  OKSOL += instr(1,toupper(LIGNE),toupper('ID="'+GINSTID+'"'))
 Elsif OKSOL & instr(1,toupper(LIGNE),toupper("</SOLUTION>"))
  OKSOL = 0
 Endif
 If OKSOL : # On est dans le noeud de la bonne solution x3
  If SOLBI=""
   OKBI = 1
  Elsif instr(1,toupper(LIGNE),toupper("<SOLUTIONBI "))
   OKBI = instr(1,toupper(LIGNE),toupper("ID='"+SOLBI+"'"))
   OKBI += instr(1,toupper(LIGNE),toupper('ID="'+SOLBI+'"'))
  Elsif OKBI & instr(1,toupper(LIGNE),toupper("</SOLUTIONBI>"))
   OKBI = 0
  Endif
  If OKBI : # On est dans le noeud de la bonne solution BI
   If DATA=""
    OKDAT = 1
   Elsif instr(1,toupper(LIGNE),toupper("<"+DATA))
    OKDAT = 1
   Elsif OKDAT & instr(1,toupper(LIGNE),toupper("</"+DATA))
    OKDAT = 0
   Endif
   If OKDAT : # On est dans le bon noeud
    I = instr(1,toupper(LIGNE),toupper("<"+PROPERTY))
    If I
     J = instr(I+len(PROPERTY),toupper(LIGNE),toupper(PROPERTY))
     If J : # Pour traiter les propriétés sous forme <pppp/>
      I = instr(I+1,toupper(LIGNE),">")
      J = instr(I+1,toupper(LIGNE),"<")
      VALPROP = mid$(LIGNE,I+1,J-I-1)
      ERR = 0
     Endif
     Break
    Endif
   Endif
  Endif
 Endif
 Rdseq LIGNE Using [BOS_]
Wend
Openi Using [BOS_]
If !ERR & toupper(PROPERTY)="ADMINPWD"
 Call DECRYPTO(VALPROP,LIGNE) From GESUSER
 VPROP = LIGNE
Elsif !ERR
 VPROP=VALPROP
Endif
End

#---------------------------------------------------------------------------------------------#
# Création des droits d'accès sur l'application BI (Oracle ou SQL)
#---------------------------------------------------------------------------------------------#

Subprog CREDROIT(APPLI,FORCE,OK)
Value    Char    APPLI
Value    Integer FORCE
Variable Integer OK

Local Char    MACHINE(250) , PATH(GDIMFIC)
Local Integer I , J , ONEBASE , I1 , I2 , ER
Local Char    MAC1(250) , MAC2(250)

Call MACHINE_BO([F:ABW]SOLBI,MACHINE)
If MACHINE = ""
 Call ECR_TRACE(mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
 OK = 0 : End
Endif

Call VARADX("ADXDIR",MACHINE,PATH) From ADXD
ONEBASE = (PATH=getenv$("ADXDIR"))

MAC2 = toupper(MACHINE)
If adxmac(0)=""
 MAC1 = toupper(adxmac(-1))
Else
 MAC1 = toupper(adxmac(0))
Endif
I = instr(1,MAC1,".")
J = instr(1,MAC1,":")
If I=0 & J=0 : I1 = len(MAC1)+1
Elsif I=0    : I1 = J
Elsif J=0    : I1 = I
Else           I1 = min(I,J)
Endif
I = instr(1,MAC2,".")
J = instr(1,MAC2,":")
If I=0 & J=0 : I2 = len(MAC2)+1
Elsif I=0    : I2 = J
Elsif J=0    : I2 = I
Else           I2 = min(I,J)
Endif
If left$(MAC1,I1-1)<>left$(MAC2,I2-1)
 ONEBASE = 0
Endif

Case ONEBASE
 When 1 : # L'appli BI est sur la même base que les dossiers de référence X3
  Call DONNE_DROITS([F:ABW]COD,APPLI,"T",ER) From TRTGRANT
  If APPLI<>nomap : # Cas où c'est la console qui a lancé la procédure
   Call DONNE_DROITS([F:ABW]COD,nomap,"T",ER) From TRTGRANT
  Endif
 When Default : # On crée le pseudo dossier
  Call GENLIEN(APPLI,FORCE,ER)
  If APPLI<>nomap : # Cas où c'est la console qui a lancé la procédure
   Call GENLIEN(nomap,FORCE,ER)
  Endif
Endcase

OK = !ER
If !OK : End : Endif

# Création des droits d'accès pour la synchronisation du datawarehouse
Call ECR_TRACE(mess(86,148,1),ER) From GESECRAN

End

#----------------------------------------------------#
Subprog GENLIEN(APPLI,FORCE,ER)
Value    Char    APPLI
Value    Integer FORCE
Variable Integer ER

Local Char    MACHINE(250) , CHAINE(250) , DATNAM(30) , DATSRC(30) , PWD(250)
Local Integer I , TYPOS , TYPBAS , OK , SERVICE
Local Char    BASE(10) , USER(10) , TABDAT(10) , TABIDX(10)

# Machine/Service
Call MACHINE_BO([F:ABW]SOLBI,MACHINE)
If MACHINE="" : ER = 1 : End : Endif
I = instr(1,MACHINE,":")
If I
 SERVICE = val(right$(MACHINE,I+1))
 MACHINE = left$(MACHINE,I-1)
Endif
If SERVICE=0 : ER = 1 : End : Endif

# Type d'os (unix/window/linux)
#Call VAR_BOWORLD("os",[F:ABW]SOLBI,"database",CHAINE,ER)
#If CHAINE="" or ER : End : Endif
#If find(toupper(CHAINE),"WIN32","WIN64") : TYPOS = 2 : Else : TYPOS = 1 : Endif

If tolower(GOS)= "unix" : # Unix
 TYPOS = 1
Else
 TYPOS = 2
Endif

If tolower(GOS)= "unix" : # Unix
 TYPOS = 1
Else
 TYPOS = 2
Endif

# Type de base (Oracle/Sql)
Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",CHAINE,ER)
If CHAINE="" or ER : End : Endif
If toupper(CHAINE)="ORACLE" : TYPBAS = 1 : Else : TYPBAS = 2 : Endif

# Path
PATH = filpath("","","",[F:ABW]COD,"",MACHINE+":"+num$(SERVICE))
PATH = left$(PATH,len(PATH)-len([F:ABW]COD)-1)
I = instr(1,PATH,"@")
If I : PATH = right$(PATH,I+1) : Endif

# Nom de la base
Call VAR_BOWORLD("name",[F:ABW]SOLBI,"database",DATNAM,ER)
If ER : End : Endif

# Datasource
Call VARADX("DATASOURCE",MACHINE+":"+num$(SERVICE),DATSRC) From ADXD

# User passwd
Call PASSE(MACHINE+":"+num$(SERVICE)+"@"+[F:ABW]COD,BASE,USER,PWD,TABDAT,TABIDX) From ORAPASSE

Call CREDOS(MACHINE,TYPOS,TYPBAS,SERVICE,PATH,DATNAM,DATSRC,[F:ABW]COD,PWD,APPLI,FORCE,OK) From CPTX3

ER = !OK
End

