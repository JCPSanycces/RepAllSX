# Issue 118632 - 2017-03-09 by STLIG :
#**---------------------------------------------------------------------<br/>
#* IS_HIDDEN : Determine whether a screen field is Hidden (return 1) or
#*             not Hidden (return 0).
#**<br/>----------------------------------------------------------------<br/>
#* @param P_FOLDER = Folder
#* @param P_SCREEN = Screen
#* @param P_FIELD  = Field
#**<br/>----------------------------------------------------------------
#*!
Funprog IS_HIDDEN(P_FOLDER,P_SCREEN,P_FIELD)
Value Char P_FOLDER
Value Char P_SCREEN
Value Char P_FIELD

Local Integer L_HIDDEN : L_HIDDEN=0

  If (clalev([F:AMZ])=0) : Local File =P_FOLDER+".AMSKZON" [AMZ] : Endif

  Read [AMZ]CODE=P_SCREEN;P_FIELD
  If (fstat=0)
    If ([F:AMZ]SAIAFF=3)  # 3 = Hidden
      L_HIDDEN=1
    Endif
  Endif

End L_HIDDEN

