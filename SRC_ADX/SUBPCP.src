#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("PCP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SELECH"      : Gosub SELECH
 When Default
Endcase
Return

$APRES_CHOI
Return

$AFFMASK
Diszo CMT, CMTBPR
Return


$OUVRE
If !clalev([F:CPY])    : Local File COMPANY     [CPY]  : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT  [GTE]  : Endif
If !clalev([F:BAN])    : Local File BANK        [BAN]  : Endif
If !clalev([F:BPR])    : Local File BPARTNER    [BPR]  : Endif
If !clalev([F:RLT2])   : Local File RELMT940    [RLT2] : Endif
If !clalev([F:RLD2])   : Local File RELMT940D   [RLD2] : Endif
If !clalev([F:SIH])    : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:TPY])    : Local File TABPAYTYP   [TPY]  : Endif

Local Integer STAT
Return

$APRES_MODIF
Case zoncou
 When "FILNUM"
  Read [RLT]RLT1 = [M]BAN ; CZ
  [M]FILNUM = CZ
  Gosub LIENS
Endcase
Return

$MODIF
For nolign=1 To [M:PCP]NBLIG
 Read [RLD2]RLD0 = [M:PCP]FILNUM ; [M:PCP]TRFNUM ; [M:PCP]SEQNUM(nolign-1) ; [M:PCP]LIN(nolign-1)
 If !fstat
  [F:RLD2] = [M:PCP]
  Rewrite [RLD2]
  If fstat
   GOK=0 : Call FSTA("PIL") From GLOCK : Break
  Endif
  ## Mise à jour échéance (montant temporaire...) 
 Endif
Next
If GOK<1 : Return : Endif
Return


$LIENS
## Vu avec JLT : un fichier FMT940 comprend plusieurs transactions (tag 20, Référence number). Chaque
## transaction comporte plusieurs numéros de séquences (tag C28) et plusieurs ordres de paiements TOUS
## associés à la même devise (celle associée au tag 60F)
## Lors de l'importation du fichier bancaire MT940, on créera autant de numéro de relevé (compteur) que
## de transactions (tag 20). La devise des ordres de paiements d'un relevé X3 étant donc la même, on peut
## l'afficher en en-tête. Le total des ordres de paiements sera donc exprimé dans cette unique devise
[M]CURTOTAMT = [F:RLT]CUR
Call LECTURE("BAN",[F:RLT]BAN,"") From CONTOBJ
[M]CPY = [F:BAN]CPY
[M]FCY = [F:BAN]FCY
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
[M]CURCPY = [F:CPY]ACCCUR
Raz nolign : [M]TOTAMT = 0
Affzo CPY, FCY, CURCPY, CUR, TOTAMT
Gosub CHARGEMENT
Return

$CHARGEMENT
If [M:PCP]NBLIG<>0 : Return : Endif
nolign = 0
Filter [RLD2] Where BAN=[M:PCP]BAN & FILNUM=[M:PCP]FILNUM
For [RLD2]RLD1
 nolign += 1
 OKECH = 0
 [M:PCP] = [F:RLD2]
 [M:PCP]NUMECH(nolign-1) = num$([F:RLD2]DUDNUM)+"/"+num$([F:RLD2]DUDLIG)
 If [F:RLD2]SNS="C" | [F:RLD2]SNS="RD"
  [M:PCP]SIGN(nolign-1) = 1
 Else #  D ou RC
  [M:PCP]SIGN(nolign-1) = -1
 Endif 
 TYPCOURS = 1
 If [M]PAYTYP(nolign-1)<>""
  Call LEC_TPY_LEG(GCURLEG,[M]PAYTYP(nolign-1)) From CPTLEC
  If !fstat
   TYPCOURS = [F:TPY]RATTYP
  Endif
 Endif
 [M:PCP]TOTAMT += [M:PCP]AMTCUR(nolign-1)*[M:PCP]SIGN(nolign-1)
Next
[M:PCP]OSEQNUM = [F:RLT]SEQNUM
[M:PCP]NBLIG = nolign
[M:PCP]NBRPAY = nolign
Filter [RLD2]
Affzo [M:PCP]
Return


$SETBOUT
Call VIREBOUT(CHAINE,"C") From GOBJET
If [M]NBLIG=0
 Call VIREBOUT(CHAINE,"O") From GOBJET
 REP="M" : CHAINE += "M" 
Endif
If find(2,[M:PCP]FLGCRE(0..[M]NBLIG-1))
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
 When "O" : SAVREP = "M" 
Endcase
Return

$SEL_TABLE
Case COUZON
 When "NUM" : Gosub S_NUM : # Numéro de pièce imputée
Endcase
Return


$SEL_LISTE
Case COUZON
 When "FILNUM"
  Local Char    CHP(100)
  TIT = mess(12,123,1)-mess(42,117,1)  :# Choix relevé
  NBTEX = 0 
  Filter [RLT] Where BAN=[M]BAN
  For [RLT]RLT2(2)
   CHP = mess(46,120,1)+format$("K:15X",[F:RLT]FILNUM)  : # Relevé no
   NBTEX += 1
   TEX(NBTEX)   = num$([F:RLT]FILNUM)
   TEXTE(NBTEX) = CHP
 Next
 Filter [RLT]
Endcase
Return

$S_NUM
## Vu avec JLT : forcément des factures (pas d'acomptes sur commandes clients) => sélection
## uniquement des échéances de type autre que *SO 
Local File GACCDUDATE [DUD]
Filter [DUD] Where CPY=[M]CPY & TYP=[M]TYP(nolign-1) & BPRTYP=1
&                & FLGCLE=1 & BPRFCT=''
Local Char SITE(GLONFCY), TIERS(GLONBPR)
SITE=[M]FCYLIN(nolign-1) : TIERS=[M]BPRPAY(nolign-1)
Gosub SEL_DUD From SELDUD1
Return

$SELECH
Gosub SELECH From SUBPCP2
Return

######################################################################################
## Etiquette masque PAYCREPRO [PCP]
######################################################################################
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If !clalev([F:BAN]) : Local File BANK      [BAN] : Endif
If !clalev([F:RLT]) : Local File RELMT940  [RLT] : Endif
If VALEUR=""
 Call BANDEF(VALEUR) From SUBCHK
 If VALEUR<>""
  Call LECTURE("BAN",VALEUR,"") From CONTOBJ
  [M]CPY = [F:BAN]CPY
  Filter [RLT] Where BAN=VALEUR
  Read [RLT]RLT1 Last
  Filter [RLT]
  [M]FILNUM = [F:RLT]FILNUM
  Affzo CPY, FILNUM
 Endif
Endif
End

Subprog AP_BAN(VALEUR)
Variable Char    VALEUR()
If !clalev([F:BAN]) : Local File BANK      [BAN] : Endif
If VALEUR<>""
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 [M]CPY = [F:BAN]CPY
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 [M]CURCPY = [F:CPY]ACCCUR
 Call AM_CPY([M]CPY) From CPTTRT
 Affzo CPY, CURCPY
Endif
End

Subprog C_FILNUM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:RLT3])   : Local File RELMT940    [RLT3] : Endif
Read [RLT3]RLT1 = [M]BAN ; VALEUR
If fstat
 ## Rélevé inexistant
 GMESSAGE = mess(191,117,1)
 mkstat = 2 : End
Endif
End

Subprog IB_NBLIG
Gosub SETNOL
## Bouton 1 : Génération règlement
## Bouton 2 : Zoom sur règlement
## Bouton 3 : Suppression règlement : la suppression d'un règlement généré à partir de cette fonction
##            d'affectation des ordres de paiements ne peut se faire qu'à partir de cette fonction
If !clalev([F:PYH])   : Local File PAYMENTH [PYH] : Endif
Local Integer OKSUPP
If [M:PCP]FLGCRE(NOL)<>2
 GBOUT1 = mess(51,107,1)-tolower(mess(47,109,1)) : # Génération règlement
Else
 GBOUT1 = ""
Endif
If [M:PCP]FLGCRE(NOL)=2
 Read [PYH]PYH0 = [M:PCP]NUMREG(NOL)
 If !fstat & [F:PYH]STA=1
  OKSUPP = 1
 Else
  OKSUPP = 0
 Endif
Else
 OKSUPP = 0 
Endif
If [M:PCP]FLGCRE(NOL)=2
 GBOUT2 = mess(47,109,1)                         : # Règlement
Else
 GBOUT2 = ""
Endif
If OKSUPP
 GBOUT3 = mess(2,24,1)-tolower(mess(47,109,1))   : # Suppression règlement
Else
 GBOUT3 = ""
Endif
End

Subprog B1_NBLIG
Gosub INIT From PCPCREPAY
Call SETPLAN([M:PCP]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
Call SETCUR(1,[M:PCP]CPY,DEVLED) From CPTDIV
NOLI = nolign-1
Gosub TR_GENER From PCPCREPAY
If GOK<1 | STAT : End : Endif
Affzo [M:PCP]
mkstat = 4
End

Subprog B3_NBLIG
## Possibilité de supprimer le règlement X3 ci-celui n'est pas comptabilisé
## Dans ce cas, suppression dans les tables de règlements (PAYMENTH, PAYMENTD, PAYMENTA) + 
## décrémentation du montant de l'échéance
Gosub SETNOL
Local Integer STAT : STAT = 0
If !clalev([F:PYH])   : Local File PAYMENTH [PYH] : Endif
Read [PYH]PYH0 = [M:PCP]NUMREG(NOL)
If !fstat & [F:PYH]STA>1
 ## Règlement validé, annulation impossible
 GMESSAGE = mess(54,117,1)-mess(49,117,1)
 mkstat = 2 : End
Else
 Call DELREG([M:PCP]NUMREG(NOL),[M:PCP]DUDNUM(NOL),[M:PCP]DUDLIG(NOL),NOL,STAT)
 If !STAT
  [M:PCP]FLGCRE(NOL) = 0
  [M:PCP]NUMREG(NOL) = ""
  Affzo [M:PCP]
  mkstat = 4
 Endif
Endif
End


Subprog AVANT_NBLIG
If find(status,73,75,82) : # Ajout / Insertion / Modif d'une ligne  
 [M]OD1=[M]DUDNUM(nolign-1)
 [M]OD2=[M]DUDLIG(nolign-1)
Endif
End

Subprog AS_NBLIG
Gosub SETNOL
If !clalev([F:RLD3])   : Local File RELMT940D   [RLD3] : Endif

Local Integer I, K
## Affichage référence libre (tab 86, ?20->?29)
Raz [M]CMT
Read [RLD3]RLD0 = [M]FILNUM ; [M]TRFNUM ; [M]SEQNUM(NOL) ; [M]LIN(NOL)
Setlob [M]CMT With sigma(K=0,dim([F:RLD3]FREREF)-1,[F:RLD3]FREREF(K)+chr$(13))
Affzo [M]CMT
## Affichage référence tiers (tab 86, ?00 ?30...)
Raz [M]CMTBPR
Read [RLD3]RLD0 = [M]FILNUM ; [M]TRFNUM ; [M]SEQNUM(NOL) ; [M]LIN(NOL)
Setlob [M]CMTBPR With sigma(K=0,dim([F:RLD3]BPRREF)-1,[F:RLD3]BPRREF(K)+chr$(13))
Affzo [M]CMTBPR
End

Subprog C_NBLIG
End


Subprog B2_PAYTYP(VALEUR)
Variable Char    VALEUR()
Local Char    TRANSAC(GLONTPY)
Local Integer I
Gosub SETNOL
If VALEUR<>""
 TRANSAC = VALEUR
 SIGNE = [M:PCP]SIGN(NOL)
 For I=0 To [M]NBLIG-1
  If [M]PAYTYP(I)="" & SIGNE = [M:PCP]SIGN(I)
   [M]PAYTYP(I) = [L]TRANSAC
  Endif
 Next
 Affzo PAYTYP
Endif
End


Subprog AS_BPRPAY(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PCP]FLGCRE(NOL) = 2
 mkstat = 2 : End
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PCP]FLGCRE(NOL) = 2
 mkstat = 2 : End
Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_GTE_LEG([F:CPY]LEG,VALEUR) From CPTLEC
 If fstat
  ## Type de pièce inexistant
  GMESSAGE=mess(17,114,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_NUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]TYP(NOL)=""
 mkstat = 1
 Raz [M:PCP]DUDNUM(NOL), [M:PCP]DUDLIG(NOL), [M:PCP]NUMECH(NOL)
 Raz [M:PCP]BPRINV(NOL), [M:PCP]DUDDAT(NOL), [M:PCP]FCYLIN(NOL)
 Raz [M:PCP]PAM(NOL)
 [M:PCP]LET(NOL) = "C"
 End
Endif
If [M]FLGCRE(NOL)=2
 mkstat = 2 : End
Endif
If [M]DUDNUM(NOL)<>0
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL))
 If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0 : mkstat=2 : End : Endif
Endif
# Facture
GBOUT3 = mess(4,413,1)
End

Subprog B3_NUM(VALEUR)
Variable Char    VALEUR()
Local Char VALC2(20)
If zoncou="NUM" : [L]VALC2=toupper(zc) : Else [L]VALC2=[M]NUM(nolign-1) : Endif
Gosub AB3_FACTURE
Call OBJET([L]VALC1,[L]VALC2,[L]VALC3) From GOBJET
End

$AB3_FACTURE
Local Integer K, I, NOL
Local Char    OPT(5), VALC1(20), VALC3(20)
If [L]VALC2="" : mkstat=2 : Return : Endif

NOL=nolign-1 
OPT="12"   

For I=1 To 2
 Case mid$(OPT,I,1)
  When "1" : # Facture client   
   Call LECTURE("BIC",[L]VALC2,"") From CONTOBJ
   If fstat=0 & [F:SIH]GTE=[M]TYP(NOL)
    If [F:SIH]ORIMOD=3 
     [L]VALC1 = "BIC"
    Else
     [L]VALC1 = "SIH"
    Endif
    Break
   Endif
  When "2" : # Pièce comptable
   Onerrgo ERREUR From CONTROLE
   If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : K=1 : Endif
   Onerrgo
   If !GERREUR
    Call LECTURE("GAS",[L]VALC2,[M]TYP(NOL)) From CONTOBJ
    If fstat=0 : [L]VALC1 = "GAS" :  [L]VALC3=[M]TYP(NOL) : Endif
    If K : Close Local File [HAE] : K=0 : Endif
    If [L]VALC1<>"" : Break : Endif
   Else GERREUR=0
   Endif
 Endcase
Next I
Return


Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Local Char SOCIETE(GLONCPY)
Gosub SETNOL
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Call LECTURE("GAS",VALEUR,[M:PCP]TYP(NOL)) From CONTOBJ
If fstat : # Pièce comptable inexistante
 Read [DUD]DUD0(2) = [M:PCP]TYP(NOL);VALEUR
 If fstat
  ## Pièce comptable inexistante
  GMESSAGE = mess(3,659,1)-mess(20,117,1)
  mkstat=2 : End
 Else 
  [L]SOCIETE=[F:DUD]CPY
 Endif
Else 
 [L]SOCIETE=[F:HAE]CPY
Endif
If [L]SOCIETE<>[M:PCP]CPY 
 # Pièce comptable de la societe
 GMESSAGE = mess(3,659,1)-mess(5,117,1)-[L]SOCIETE
 mkstat=2 : End
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PCP]DUDNUM(NOL)<>0
 If !clalev([F:MTB])    : Local File MTCBATCH    [MTB]  : Endif
 If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
 # On vérifie que l'échéance n'est pas en cours de lettrage pour ne pas la régler une 2eme fois
 Filter [MTB] Where ACCNUM=[M:PCP]DUDNUM(NOL) & DUDLIG=[M:PCP]DUDLIG(NOL)
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  ## Echéance en cours de lettrage
  GMESSAGE = mess(70,119,1)
  mkstat=2 : End 
 Endif
 Read [DUD]DUD1 = [M:PCP]DUDNUM(NOL);[M:PCP]DUDLIG(NOL)
 If !fstat
  [M:PCP]BPRINV(NOL)    = [F:DUD]BPR
  If [M:PCP]BPRPAY(NOL) = ""
   [M:PCP]BPRPAY(NOL) = [F:DUD]BPRPAY
  Endif
  Affzo BPRINV, BPRPAY 
 Endif
Endif
End


Subprog AS_FCYLIN(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:PCP]FLGCRE(NOL) = 2
 mkstat = 2 : End
Endif
End

Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If [M:PCP]FLGCRE(NOL) = 2
 mkstat = 2 : End
Endif
End


######################################################################################
## Etiquette masque PAYCREPAY [DIA]
######################################################################################
Subprog C_LEVEL(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : mkstat = 2 : End : Endif
Gosub LIST_VAL
If !find(VALEUR,[L]CODRAP(1..NBVAL))
 ## Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
End

Subprog S_LEVEL(VALEUR)
Variable Char    VALEUR()
Gosub LIST_VAL
Local Integer NBTEX, REPONSE
Local Char    TEX(50)(200) 
NBTEX = 0 
For I=1 To [L]NBVAL
 NBTEX += 1 
 TEX(NBTEX) = mess(46,104,1)-[L]CODRAP(I) 
Next 
If NBTEX>0 
 Call SAITEX(NBTEX,TEX,REPONSE,mess(10,16,1)-mess(46,104,1)) From GESECRAN : # Choix niveau
 If status<>7 & REPONSE<>0 :  VALEUR = [L]CODRAP(REPONSE) : Endif 
Endif 
End


$LIST_VAL
Local Char    CODRAP(1)(1..dim([M:PCP]LET))
Local Integer I, NBVAL
For I=0 To [M:PCP]NBLIG-1
 If [M:PCP]LET(I)<>"" & !find([M:PCP]LET(I),[L]CODRAP(1..dim([M:PCP]NBLIG)))
  NBVAL += 1
  CODRAP(NBVAL) = [M:PCP]LET(I)
 Endif
Next
If NBVAL>1
 Sorta NBVAL CODRAP Order By CODRAP(indice) Asc
Endif
Return


#######################
Subprog LECDUD(NUM,LIG)
#######################
Value Integer NUM,LIG
If [F:DUD]ACCNUM<>NUM | [F:DUD]DUDLIG<>LIG
 Read [DUD]DUD1 = NUM;LIG
Else
 fstat=0
Endif
End
End


Subprog DELREG(NUMREG,DNUM,DLIG,NOLIG,STAT)
Value    Char    NUMREG()  : # Numéro règlement
Value    Integer DNUM      : # N° interne échéance (accnum)    
Value    Integer DLIG      : # N° échéance
Value    Integer NOLIG     : # N° ligne de l'ordre de paiement dans le masque [M:PCP]
Variable Integer STAT      : # Statut de retour
If !clalev([F:DUD])  : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:RLD2]) : Local File RELMT940D   [RLD2] : Endif
If !clalev([F:PYH])  : Local File PAYMENTH    [PYH]  : Endif
If !clalev([F:PYD])  : Local File PAYMENTD    [PYD]  : Endif
If !clalev([F:PYA])  : Local File PAYMENTA    [PYA]  : Endif
Gosub TR_SUPP
If GOK<1 : STAT = 99 : Endif
End

$TR_SUPP
Trbegin [PYH], [PYD], [PYA], [DUD], [RLD2]
 Readlock [PYH]PYH0 = [L]NUMREG
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-[L]NUMREG : Goto ROLL_TR_SUPP
 Elsif fstat
  GOK=0 : Call RSTA("PYH",[L]NUMREG) From GLOCK : Goto AB_TR_SUPP
 Endif
 If [M:PCP]DUDNUM(NOLIG)<>0 & [M:PCP]DUDLIG(NOLIG)
  Readlock [DUD]DUD1 = [L]DNUM ; [L]DLIG
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$([L]DNUM)-num$([L]DLIG) : Goto ROLL_TR_SUPP
  Elsif fstat
   GOK=0 : Call RSTA("DUD",num$([L]DNUM)-num$([L]DLIG)) From GLOCK : Goto AB_TR_SUPP
  Endif
  ## 1/ On décrémente les montants règlés (TMP*) des échéances. Boucle sur [PYD] mais théoriquement, une seule
  ## ligne imputée... 
  For [PYD]PYD0 Where NUM = [L]NUMREG & DUDNUM=[L]DNUM & DUDLIG=[L]DLIG
   [F:DUD]TMPCUR -= [F:PYD]PAYCURLIN
   [F:DUD]TMPLOC -= [F:PYD]PAYLOCLIN
  Next
  Rewrite [F:DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Goto AB_TR_SUPP
  Endif
 Endif
 ## 2/ On supprime le numéro de règlement associée à la ligne d'ordre de paiement et on remet le flag
 ## FLGCRE à 0
 Readlock [RLD2]RLD0 = [M:PCP]FILNUM ; [M:PCP]TRFNUM ; evalue("[M:PCP]SEQNUM("+num$(NOLIG)+")") ; evalue("[M:PCP]LIN("+num$(NOLIG)+")")
 If fstat=1
  GOK=-1 : GLOCK="$RELMT940D"-[M:PCP]FILNUM-[M:PCP]TRFNUM-evalue("[M:PCP]SEQNUM"+num$(NOLIG))-evalue("[M:PCP]LIN("+num$(NOLIG)+")") : Goto ROLL_TR_SUPP
 Elsif fstat
  GOK=0 : Call RSTA("RLD2",[M:PCP]FILNUM-[M:PCP]TRFNUM-evalue("[M:PCP]SEQNUM"+num$(NOLIG))-evalue("[M:PCP]LIN("+num$(NOLIG)+")")) From GLOCK : Goto AB_TR_SUPP
 Endif
 [F:RLD2]NUMREG = ""
 [F:RLD2]FLGCRE = 0
 Rewrite [F:RLD2]
 If fstat
  GOK=0 : Call FSTA("RLD2") From GLOCK : Goto AB_TR_SUPP
 Endif
 ## 3/ Suppression des tables de règlements : PAYMENTH, PAYMENTD, PAYMENTA
 Delete [PYH]PYH0 = [L]NUMREG
 If fstat=1
  GOK=-1 :  GLOCK="$PAYMENTH"-[L]NUMREG : Goto ROLL_TR_SUPP
 Elsif fstat>5
  GOK=0 :  Call RSTA("PYH",[M:PCP]NUMREG) From GLOCK : Goto AB_TR_SUPP
 Endif
 Delete [PYD] Where NUM = [L]NUMREG
 If fstat=1
  GOK=-1 :  GLOCK="$PAYMENTD"-[L]NUMREG : Goto ROLL_TR_SUPP
 Elsif fstat>5
  GOK=0 :  Call RSTA("PYD",[L]NUMREG) From GLOCK : Goto AB_TR_SUPP
 Endif
 Delete [PYA] Where NUM = [L]NUMREG
 If fstat=1
  GOK=-1 :  GLOCK="$PAYMENTA"-[L]NUMREG : Goto ROLL_TR_SUPP
 Elsif fstat>5
  GOK=0 :  Call RSTA("PYA",[L]NUMREG) From GLOCK : Goto AB_TR_SUPP
 Endif
Commit
End

$AB_TR_SUPP
Rollback
Return

$ROLL_TR_SUPP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SUPP : Endif



$SETNOL
Local Integer NOL
NOL = nolign-1
Return
