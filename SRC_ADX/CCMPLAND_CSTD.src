#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMPLAND_CSTD, Change request plan detail

$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Initialise Line no. (LINENO) and Status (LINESTATUS) for new Plan Details.
$INCREMENT_LINE_NUMBER

  Local Integer DUMMY_RTV

  this.LINENO = 1 + max(this.APARENT.CCMPLAND(1..maxtab(this.APARENT.CCMPLAND)).LINENO)
  this.LINESTATUS = 1

  # Enable / disable other properties ...
  DUMMY_RTV = fmet this.APARENT.SET_ATTRIBUTES()

Return


# --------------------------------------------------

$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "LINESTATUS.PROPAGATE"
      Gosub UPDATE_START_END_DATES
    When "ACTIONER.CONTROL"
      Gosub CHECK_ACTIONER_AUTHORISATION
    When "TRANTYPE.CONTROL"
      Gosub CHECK_ACTIONER_AUTHORISATION
  Endcase

Return

# --------------------------------------------------
# Maintain Plan Detail Start and End dates.
$UPDATE_START_END_DATES

  Local Integer TOTALPLANLINES, PLANLINES, INPROGRESSLINES, COMPLETEDLINES

  # If line Status is Pending then reset Start and End dates,
  # If line Status is In progress then set Start date to today's date and reset End date,
  # If line Status is Completed then set Start date to today's date (if not set) and End date to today's date ...
  If (this.LINESTATUS = 1)
    this.STARTDATE = AVOID.ADATE
    this.ENDDATE = AVOID.ADATE
  Elsif (this.LINESTATUS = 2)
    this.STARTDATE = date$
    this.ENDDATE = AVOID.ADATE
  Else
    If (this.STARTDATE = AVOID.ADATE)
      this.STARTDATE = date$
    Endif
    this.ENDDATE = date$
  Endif

Return

# --------------------------------------------------
# Check Actioner Site (Change Request) and Transaction Type authorisation.
$CHECK_ACTIONER_AUTHORISATION

  Local Char ERROR_MESSAGE(100)
  Local Integer STAT
  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null

  ASTATUS = fmet CHANGE_REQUEST.AREAD(this.APARENT.CRID)

  ASTATUS = fmet this.ADELETEERROR("ACTIONER")
  If (fmet CHANGE_REQUEST.CHECK_USER_SITE(this.ACTIONER, CHANGE_REQUEST.SITE, this.TRANTYPE) = CST_AERROR)

    Local Instance AUTILIS Using C_AUTILIS
    AUTILIS = NewInstance C_AUTILIS AllocGroup null
    STAT = fmet AUTILIS.AREAD(this.ACTIONER)

    ERROR_MESSAGE = func ASYRFNC.MES4(mess(59,2038,1),
&     this.ACTIONER,
&     AUTILIS.NOMUSR,
&     mess(this.TRANTYPE,2039,1),
&     CHANGE_REQUEST.SITE)
    ASTATUS = fmet this.ASETERROR("ACTIONER", ERROR_MESSAGE, CST_AERROR)

    FreeGroup AUTILIS

  Endif

  FreeGroup CHANGE_REQUEST

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

