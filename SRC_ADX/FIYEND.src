#<AdxTL>@(#)3.0.0.0 $Revision$
# Issue X3-59028 - 2018-01-23 by CBO : Changes of accounting task for mindo

Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","FIYEND","FIYEND",4,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "OK"          : GOK = 1
 When "END"         : GOK = 0
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "DEBUT"       : Affzo [DIA]
 When "BOUTON"      : Gosub BOUTON
Endcase
Return

#######################################################
$CONTROLE
If GOK<1
 FIN = 1 : Return
Endif
OK = 2
#### Point d'entrée CONTROLE
GPOINT = "CONTROLE"  :  Gosub ENTREE From EXEFNC
If OK<>2
 FIN = 1
Else
 TMP = 1 : # Pour afficher des tempon/tempoff
Endif

If FIN : Return : Endif
Call AVERTDGI2([M:DIA]NBLIG,[M:DIA]CPY,"",1,SAI) From CPTDIV2
If SAI : Return : Endif
Return

#######################################################
$OUVRE
Local Char    TIT(50)             : # Titre de la fonction
Local Integer OK, STAT            : # Variables diverses
Local Decimal EXER                : # No exercice
Local Integer REFER               : # Référentiel
Local Char    SOC(GLONCPY)        : # Société
Local Char    SYMBOLE(80)
Local Integer ISOC , TEXE
Local Integer I , J , K , R
Local Char    TYPPCE(GLONGTE)(1..2) , JOURNAL(GLONJOU)(1..2)
Local Integer OKARCH

Gosub OUVFIC

Local Mask GACCFIYEND [DIA]

Raz [M:DIA]
TIT = mess(70,107,1) : # Fin d'exercice
[M:DIA]NBLIG = 1
Call INICPY([M:DIA]CPY(0)) From SUPCPT : #[M:DIA]CPY(0) = "FINEX"
nolign = 1
[M]TOUREF(0) = 2
[M]LEDTYP(0) = 0
Call C_TOUREF([M]TOUREF(0))
If mkstat
 Call LECTURE("CPY",[M]CPY(0),"") From CONTOBJ
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 [M]TOUREF(0) = 1
 [M]LEDTYP(0) = [F:GCM]GENLEDTYP
 Call C_LEDTYP([M]LEDTYP(0))
Endif
Call LECMEMO("STD","[M:DIA]","fiy") From GMEMO
Gosub VERIF_DATES
Return

#######################################################
$OUVFIC
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Sociétés
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif : # Modèles
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif : # Référentiels
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif : # Sites
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif : # Exercices
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif : # Périodes
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif : # Journaux comptables
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif : # Type de pièce
Return

#######################################################
## Réaffectation exercice si rappel
## (sinon on peut cloturer plusieurs fois!!!)
#######################################################
$BOUTON
Case BOUT
 When "R"
  Gosub VERIF_DATES
Endcase
Return

$VERIF_DATES
For nolign=1 To [M:DIA]NBLIG
 Call C_CPY([M:DIA]CPY(nolign-1))
 Call C_TOUREF([M:DIA]TOUREF(nolign-1))
 If [M:DIA]LEDTYP(nolign-1)<>0
  Call C_LEDTYP([M:DIA]LEDTYP(nolign-1))
 Endif
 Affzo DATFIYNEW(nolign-1)
Next nolign
Return

#######################################################
## Exécution
#######################################################
$EXEC
If GSTATUT<>GSTAOK : End : Endif
If [M:DIA]SIMUL=2
 TIT -= "-"-mess(27,107,1)
Endif
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
Endif

For I=0 To [M:DIA]NBLIG-1
 SOC = [M:DIA]CPY(I)
 If SOC<>""
  If !OKARCH
   Call LEC_CPY(SOC) From CPTLEC
   Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Endif
  If [M:DIA]TOUREF=2
   Call LEC_CPY(SOC) From CPTLEC
   Call LEC_GCM([F:CPY]ACM) From CPTLEC
   For REFER=1 To len(mess(0,2644,1))
    GOK=1
    If [F:GCM]LED(REFER-1)<>"" & [F:GCM]CFMAUT(REFER-1)<>2
     Call PARAM(SOC,"GTEFRW"+num$(REFER),TYPPCE(1)) From ADOVAL
     If TYPPCE(1)=""
      GOK=0 : Call ECR_TRACE("GTEFRW"+num$(REFER)-mess(171,133,1),1) From GESECRAN
     Endif
     Call LEC_GTE_LEG([F:CPY]LEG,TYPPCE(1)) From CPTLEC
     JOURNAL(1) = [F:GTE]DEFJOU
     Call LEC_LED([F:GCM]LED(REFER-1)) From CPTLEC
     If [F:LED]ENDVCR=2    : # Pièce de clôture (ex code activité ACV => ITALIE)
      Call PARAM(SOC,"GTECLO"+num$(REFER),TYPPCE(2)) From ADOVAL
      If TYPPCE(2)=""
       GOK=0 : Call ECR_TRACE("GTECLO"+num$(REFER)-mess(171,133,1),1) From GESECRAN
      Endif
      Call LEC_GTE_LEG([F:CPY]LEG,TYPPCE(2)) From CPTLEC
      JOURNAL(2) = [F:GTE]DEFJOU
     Else
      TYPPCE(2) = ""
      JOURNAL(2) = ""
     Endif
     If GOK
      Gosub CTL_ARCH
      Gosub SOCREF
     Endif
     If (GOK<1 or STAT) & [M:DIA]SIMUL<>2 : Break 2 : Endif
    Endif
   Next REFER
  Else
   REFER      = [M:DIA]LEDTYP(I)
   TYPPCE(1)  = [M:DIA]TYP(I)
   JOURNAL(1) = [M:DIA]JOU(I)
   TYPPCE(2)  = [M:DIA]TYP2(I)
   JOURNAL(2) = [M:DIA]JOU2(I)
   Gosub CTL_ARCH
   Gosub SOCREF
   If (GOK<1 or STAT) & [M:DIA]SIMUL<>2 : Break : Endif
  Endif
 Endif
Next
Return

#########################################################################################
 # Contrôle que les archives fiscales doivent être générées
#########################################################################################
$CTL_ARCH
# Clôture d'un référentiel principal sur une société de législation FRA
If !OKARCH & find(REFER,[F:GCM]GENLEDTYP,[F:GCM]IASLEDTYP) & func AFNC.PARAM("FRADGI",[F:CPY]CPY)="2"
 If !GSERVEUR
  OK = 1
  # Les archives fiscales doivent être générées
  Call AVERTIR(mess(63,101,1),OK) From GESECRAN
  If OK<>2    : # Annuler
   STAT=1 : Return
  Endif
 Else
  # Les archives fiscales doivent être générées
  Call ECR_TRACE(mess(63,101,1),1) From GESECRAN
 Endif
 OKARCH = 1
Endif
Return

#########################################################################################
# 1 société (SOC), 1 référentiel (REFER)
#########################################################################################
$SOCREF
SYMBOLE = "FIYEND"+SOC
Lock =SYMBOLE
If fstat
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN
 Return
Endif

########################################################################################
## Fin d'exercice proprement dite
########################################################################################

Call LEC_CPY(SOC) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call GETEXE(SOC,REFER,[M:DIA]DATFIYNEW(I)-1,EXER) From CPTSUB
Call GNRPCE(SOC,REFER,EXER,TYPPCE,JOURNAL,([M:DIA]TRACE=2),([M:DIA]SIMUL=2),STAT) From FIYENDGEN
Call ECR_TRACE(string$(100,"-"),0) From GESECRAN # ajout JFL

########################################################################################
## MAJ Exercice de report à nouveau et recalcul des à-nouveaux provisoires
########################################################################################
If GOK=1 & !STAT
 If GRAN=2                                        : # Est-ce que l'option est toujours globale ?
  ISOC = find(SOC,GSOC(1..GNBSOC))
  For R=1 To len(mess(0,2644,1))
   If R=REFER or ([F:GCM]CFMAUT(R-1)=2 & [F:GCM]ORILEDTYP(R-1)=REFER)
    GEXEAN(ISOC,R) += 1                           : # A priori indicé par référentiel ?
#    TEXE = EXER+1                                 : # On récupère l'exercice suivant ?
     TEXE = GEXEAN(ISOC,R)+1  #DdM61777
    Call RECUPBAL(SOC,R,TEXE) From SIMULFINEX     : # A priori par référentiel ?
   Endif
  Next R
 Endif
Endif

########################################################################################

# Issue X3-59028 Call SETFLG From BATCHCPT                          : # Mise à jour globales de la tâche batch.
#Call MULTICPY(SOC) From AX3MONO
Unlock =SYMBOLE
Return

#######################################################
## Fin des courses
#######################################################
$FIN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

#######################################################
## Ecran GACCFIYEND
#######################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer NOL , I
NOL = nolign-1
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]CPY(I)=VALEUR & [M]TOUREF(I)=2
  GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà défini en ligne
  mkstat = 2 : Break
 Endif
Next I
End

Subprog C_TOUREF(VALEUR)
Variable Integer VALEUR
Local Integer NOL , I , IREF , OKREF
Local Char    REF(GLONLED)
Local Date    DDEB
NOL = nolign-1
If VALEUR=2
 For I=0 To [M]NBLIG-1
  If I<>NOL & [M]CPY(I)=[M]CPY(NOL)
   GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà défini en ligne
   mkstat = 2 : Break
  Endif
 Next I
 If mkstat : End : Endif
 Call LEC_CPY([M]CPY(NOL)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 OKREF = 1
 For IREF=1 To len(mess(0,2644,1))
  REF = [F:GCM]LED(IREF-1)
  If REF<>"" & [F:GCM]CFMAUT(IREF-1)<>2
   Filter [FIY] Where LEDTYP=IREF & CPY=[M]CPY(NOL) & FIYSTA=2
   Read [FIY]FIY0 First
   Filter [FIY]
   If fstat
    OKREF = 0 : Break
   Else
    If DDEB=[0/0/0]
     DDEB = [F:FIY]FIYEND+1
    Elsif DDEB<>[F:FIY]FIYEND+1
     OKREF = 0 : Break
    Endif
   Endif
  Endif
 Next IREF
 If !OKREF
  GMESSAGE = mess(114,104,1) : # Dates incompatibles entre les référentiels
  mkstat = 2 : End
 Endif
 [M]DATFIYNEW(NOL) = DDEB
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL = nolign-1
If [M]TOUREF(NOL)=2
 mkstat = 1 : End
Endif
Call LEDTYP_CHOICE([M]CPY(NOL),6) From CPTDIV
End

Subprog D_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL , IREF , K , OKREF
NOL = nolign-1
Call LEC_CPY([M]CPY(NOL)) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
For IREF=1 To len(mess(0,2644,1))
 OKREF = 1
 For K=0 To [M]NBLIG-1
  If K<>NOL & [M]CPY(NOL)=[M]CPY(K) & [M]LEDTYP(K)=IREF
   OKREF = 0 : Break
  Endif
 Next K
 If OKREF
  VALEUR = IREF : Break
 Endif
Next IREF
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL , I
NOL = nolign-1
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]CPY(I)=[M]CPY(NOL) & ([M]TOUREF(I)=2 or [M]LEDTYP(I)=VALEUR)
  GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà défini en ligne
  mkstat = 2 : Break
 Endif
Next I
Filter [FIY] Where LEDTYP=VALEUR & CPY=[M]CPY(NOL) & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
If fstat
 GMESSAGE = mess(201,111,1) : # Référentiel incorrect
 mkstat = 2 : End
Endif
[M]DATFIYNEW(NOL) = [F:FIY]FIYEND+1
Call LEC_CPY([M]CPY(NOL)) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED(VALEUR-1)) From CPTLEC
[M]CPYCLO(NOL) = [F:LED]ENDVCR
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
If [M]TOUREF(nolign-1)=2 : mkstat = 1 : End : Endif
Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
[V]GCURLEG = [F:CPY]LEG

If VALEUR=""
 Call PARAM([M]CPY(nolign-1),"GTEFRW"+num$([M]LEDTYP(nolign-1)),VALEUR) From ADOVAL
 If VALEUR=""
  Filter [GTE] Where LEG=GCURLEG & PER=2 & AUZJOU(6)=2
  Gosub INI_GTE
  If VALEUR=""
   Filter [GTE] Where LEG="" & PER=2 & AUZJOU(6)=2
   Gosub INI_GTE
  Endif
 Endif
Endif
End

$INI_GTE
Read [GTE]GTE0 First
Filter [GTE]
If !fstat : VALEUR = [F:GTE]TYP : Endif
Return

Subprog AS_TYP2(VALEUR)
Variable Char    VALEUR()
If [M]TOUREF(nolign-1)=2 or [M]CPYCLO(nolign-1)<>2 : mkstat = 1 : End : Endif
Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
[V]GCURLEG = [F:CPY]LEG

If VALEUR=""
 Call PARAM([M]CPY(nolign-1),"GTECLO"+num$([M]LEDTYP(nolign-1)),VALEUR) From ADOVAL
 If VALEUR=""
  Filter [GTE] Where LEG=GCURLEG & PER=3
  Gosub INI_GTE
  If VALEUR=""
   Filter [GTE] Where LEG="" & PER=3
   Gosub INI_GTE
  Endif
 Endif
Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
Call CONTTYP(VALEUR,[M]CPY(nolign-1),[M]LEDTYP(nolign-1),2) From FIYENDGEN
End

Subprog C_TYP2(VALEUR)
Variable Char    VALEUR()
Call CONTTYP(VALEUR,[M]CPY(nolign-1),[M]LEDTYP(nolign-1),3) From FIYENDGEN
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
If [M]TOUREF(nolign-1)=2 : mkstat = 1 : End : Endif
If VALEUR=""
 Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
 Call LEC_GTE_LEG([F:CPY]LEG,[M]TYP(nolign-1)) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog AS_JOU2(VALEUR)
Variable Char    VALEUR()
If [M]TOUREF(nolign-1)=2 or [M]CPYCLO(nolign-1)<>2 : mkstat = 1 : End : Endif
If VALEUR=""
 Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
 Call LEC_GTE_LEG([F:CPY]LEG,[M]TYP2(nolign-1)) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Call CONTJOU(VALEUR,7)
End

Subprog C_JOU2(VALEUR)
Variable Char    VALEUR()
Call CONTJOU(VALEUR,0)
End

Subprog CONTJOU(VALEUR,TYPJOU)
Variable Char    VALEUR()
Value    Integer TYPJOU
# KC : $AS_JOU no read each time [CPY] (Ex: if we go back on an existing or filled-in line )
# $AS_JOU doesn't read [CPY] all the time (Ex: If we return on a line already entered)
Call LEC_CPY([M]CPY(nolign-1)) From CPTLEC
Call LEC_JOU_LEG([F:CPY]LEG,VALEUR) From CPTLEC
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat : End : Endif
If TYPJOU<>0 & [F:JOU]TYP<>TYPJOU
 GMESSAGE = mess(67,107,1) : # Type de journal erroné
 mkstat=2 : End
Endif
If [F:JOU]FCY<>""
 Call VERSOC([F:JOU]FCY,[M]CPY(nolign-1),"",VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif
End
