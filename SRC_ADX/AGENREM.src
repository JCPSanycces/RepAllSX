########################################################################################################

# JPGA 18/03/2011 BUG-70761 : Mise en Generique des Dossiers d'industrialisation de la Remontee des Trads en fonction de l'abreviation
$DECL_AFFECTATION_VAR
   If dim([L]WABREV)<0
      Local Char WABREV(10)
   Endif
   If dim([L]WDOSS)<0
      Local Char WDOSS(100)
   Endif
Return

# JPGA 18/03/2011 BUG-70761 : Mise en Generique des Dossiers d'industrialisation ed la Remontee des Trads en fonction de l'abreviation
$DECL_AFFECTATION_DOSSIER
   Case left$([L]WABREV,3)

     When "X2S"   :  [L]WDOSS=GFOLDER_R090(0)  # appli V12 SUPERV
     When "X2Z"   :  [L]WDOSS=GFOLDER_R090(1)  # appli V12 x3
     When "X2X"   :  [L]WDOSS=GFOLDER_R090(2)  # appli V12 geode
     When "X2W"   :  [L]WDOSS=GFOLDER_R090(3)  # appli V12 paye

#     When "X0S"   :  [L]WDOSS=GFOLDER_V200(0)  # appli V10 SUPERVAVENG
#     When "X0Z"   :  [L]WDOSS=GFOLDER_V200(1)  # appli V10 x3
#     When "X0X"   :  [L]WDOSS=GFOLDER_V200(2)  # appli V10 geode
#     When "X0W"   :  [L]WDOSS=GFOLDER_V200(3)  # appli V10 paye
#
#     When "X1S"   :  [L]WDOSS=GFOLDER_R080(0)  # appli V11 SUPERVCHAL
#     When "X1Z"   :  [L]WDOSS=GFOLDER_R080(1)  # appli V11 x3
#     When "X1X"   :  [L]WDOSS=GFOLDER_R080(2)  # appli V11 geode
#     When "X1W"   :  [L]WDOSS=GFOLDER_R080(3)  # appli V11 paye

     When Default :  [L]WDOSS=""
   Endcase
Return

# JPGA 18/03/2011 BUG-70761 : La remontee de Trad ne testait pas l'existence du code activite dans le dossier cible de copie
$ENVINDUS_DECL_CODACT
   If clalev([XACV])    :  Close File [XACV] : Endif

   Gosub DECL_AFFECTATION_VAR  :  [L]WABREV=ABREV_DOC  :  Gosub DECL_AFFECTATION_DOSSIER
   Local File =[L]WDOSS+".ACTIV" [XACV]
Return

# JPGA 18/03/2011 BUG-70761 : La remontee de Trad ne testait pas l'existence du code activite dans le dossier cible de copie
$MAJ_CODACT_INEXISTANTS
   If [XLW]CODACT<>""
      Read [XACV]CODACT=[XLW]CODACT
      If fstat
         [XLW]CODACT="FAL"
      Endif
   Endif
Return

$ENVINDUS_CLOS
If clalev([XAS])<>0      : Close Local File [XAS],  [XAS1], [XAS2], [XAS3] : Endif
If clalev([XLW])<>0      : Close Local File [XLW],  [XLW3], [XLW4]         : Endif
If clalev([X_W1])<>0     : Close Local File [XLW1], [XLW2], [X_W1], [X_W2] : Endif

If clalev([X2S])<>0  : Close Local File [X2S],  [X2S1], [X2S2], [X2S3] : Endif
If clalev([X2W])<>0  : Close Local File [X2W],  [X2W1], [X2W2], [X2W3] : Endif
If clalev([X2X])<>0  : Close Local File [X2X],  [X2X1], [X2X2], [X2X3] : Endif
If clalev([X2Z])<>0  : Close Local File [X2Z],  [X2Z1], [X2Z2], [X2Z3] : Endif

#If clalev([X0S])<>0  : Close Local File [X0S],  [X0S1], [X0S2], [X0S3] : Endif
#If clalev([X0W])<>0  : Close Local File [X0W],  [X0W1], [X0W2], [X0W3] : Endif
#If clalev([X0X])<>0  : Close Local File [X0X],  [X0X1], [X0X2], [X0X3] : Endif
#If clalev([X0Z])<>0  : Close Local File [X0Z],  [X0Z1], [X0Z2], [X0Z3] : Endif
#
#If clalev([X1S])<>0  : Close Local File [X1S],  [X1S1], [X1S2], [X1S3] : Endif
#If clalev([X1W])<>0  : Close Local File [X1W],  [X1W1], [X1W2], [X1W3] : Endif
#If clalev([X1X])<>0  : Close Local File [X1X],  [X1X1], [X1X2], [X1X3] : Endif
#If clalev([X1Z])<>0  : Close Local File [X1Z],  [X1Z1], [X1Z2], [X1Z3] : Endif

If clalev([XACV])<>0     : Close Local File [XACV] : Endif
Return

$ENVINDUS_DEFAULT_FILE
   Default File "["+ABREV_DOC+"]"
Return

######################################################################################
Subprog ENVINDUS_ALIM_ADO (DOC_ABREV, DOC_LAN, DOC_TYP, DOC_COD, DOC_LEV, DOC_SUBLEV)
Value Char    DOC_ABREV()
Value Char    DOC_LAN()
Value Char    DOC_TYP()
Value Char    DOC_COD()
Value Integer DOC_LEV
Value Integer DOC_SUBLEV

   If DOC_LAN <> ""     :  Assign "[F:"+DOC_ABREV+"]LAN"    With DOC_LAN     :  Endif
   If DOC_TYP <> ""     :  Assign "[F:"+DOC_ABREV+"]TYP"    With DOC_TYP     :  Endif
   If DOC_COD <> ""     :  Assign "[F:"+DOC_ABREV+"]COD"    With DOC_COD     :  Endif
   If DOC_LEV <> 0      :  Assign "[F:"+DOC_ABREV+"]LEV"    With DOC_LEV     :  Endif
   If DOC_SUBLEV <> 0   :  Assign "[F:"+DOC_ABREV+"]SUBLEV" With DOC_SUBLEV  :  Endif
End

Subprog ENVINDUS_ALIM_ADB (DOC_ABREV, DOC_LAN, DOC_TYP, DOC_COD, DOC_LEV, DOC_SUBLEV, DOC_LIG)
Value Char    DOC_ABREV()
Value Char    DOC_LAN()
Value Char    DOC_TYP()
Value Char    DOC_COD()
Value Integer DOC_LEV
Value Integer DOC_SUBLEV
Value Integer DOC_LIG

   If DOC_LAN <> ""     :  Assign "[F:"+DOC_ABREV+"]LAN"    With DOC_LAN     :  Endif
   If DOC_TYP <> ""     :  Assign "[F:"+DOC_ABREV+"]TYP"    With DOC_TYP     :  Endif
   If DOC_COD <> ""     :  Assign "[F:"+DOC_ABREV+"]COD"    With DOC_COD     :  Endif
   If DOC_LEV <> 0      :  Assign "[F:"+DOC_ABREV+"]LEV"    With DOC_LEV     :  Endif
   If DOC_SUBLEV <> 0   :  Assign "[F:"+DOC_ABREV+"]SUBLEV" With DOC_SUBLEV  :  Endif
   If DOC_LIG <> 0      :  Assign "[F:"+DOC_ABREV+"]LIG"    With DOC_LIG     :  Endif
End

Subprog ENVINDUS_ALIM_ADZ (DOC_ABREV, DOC_LAN, DOC_MOTCLE)
Value Char    DOC_ABREV()
Value Char    DOC_LAN()
Value Char    DOC_MOTCLE()

   If DOC_LAN <> ""     :  Assign "[F:"+DOC_ABREV+"]LAN"    With DOC_LAN     :  Endif
   If DOC_MOTCLE <> ""  :  Assign "[F:"+DOC_ABREV+"]MOTCLE" With DOC_MOTCLE  :  Endif
End

######################################################################################
######################################################################################
Funprog IS_ENVINDUS_DOC (PLANTRA)
Value Char    PLANTRA()
RETOUR=0
Gosub DEFVAR From AGLOBTRAD

If dim(GFOLDER_V150)<0 : End RETOUR : Endif
# JPGA - 26/01/2009 - Bug-51352 : Non necessaire
# Gosub ENVINDUS_DECL

If filinfo(filpath("",GMAGIC,""),0)>=0
 For ILAN=1 To GNBLANSTD
  If PLANTRA=""    # Test environnements de TRAD sans le code LANGUE
    If GUSER=GUSRLAN(ILAN) and nomap=GREFER(ILAN)
      RETOUR=1
    Endif
  Else             # Test environnements de TRAD avec le code LANGUE
    If GUSER=GUSRLAN(ILAN) and PLANTRA=GLANSTD(ILAN) and nomap=GREFER(ILAN)
      RETOUR=1
    Endif
  Endif
 Next ILAN
Endif

# JPGA - 26/01/2009 - Bug-51352 : Non necessaire
# Gosub ENVINDUS_CLOS
End RETOUR

######################################################################################
# IS_DOSSIER_SAGE : Retourne le booleen donnant l'information : Le dossier courant est il interne a SAGE ?
Funprog IS_DOSSIER_SAGE
Local Integer RETOUR  :  [L]RETOUR=0

  If GSOPHIA |
&    filinfo(filpath("",GMAGIC,"",adxmother(1)),0)>0 |
&    filinfo(filpath("",GMAGIC,"",adxmother(0)),0)>0
    [L]RETOUR=1
  Endif
End [L]RETOUR

#####################################################################################
# FOLDER_OPENED_FILE : Retourne le dossier sous forme MACHINE:PORT@APPLI
#                    a partir de l'abreviation de la table ouverte passee en parametre
Funprog FOLDER_OPENED_FILE(PABREV)
Value Char      PABREV

Local Integer INDFILEABREV, I : [L]INDFILEABREV=0
Local Char FOLDERPATH(255)    : [L]FOLDERPATH="NOT_FOUND"
Local Char FILEPATH(255)      : [L]FILEPATH="NOT_FOUND"
Local Char FOLDER_APPLI(50)   : [L]FOLDER_APPLI="NOT_FOUND"

[L]INDFILEABREV = find(PABREV,[S]fileabre(1..dim([S]fileabre)))
[L]FOLDERPATH = [S]filename(INDFILEABREV)

[L]FILEPATH=right$([L]FOLDERPATH,instr(1,[L]FOLDERPATH,"@")+1)
I=instr(1,[L]FILEPATH,".")
If I
  [L]FOLDER_APPLI=left$([L]FILEPATH,I-1)
Else
  [L]FOLDER_APPLI=[L]FILEPATH
Endif

End [L]FOLDER_APPLI

