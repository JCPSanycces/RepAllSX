#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################################
## AGENREM
## Procedures de remontee de traduction appelees depuis tous les programmes du generateur de DOC.
##
## (split de AGENLIBA)
##################################################################################################
Subprog MAJ_ENVINDUS_DOC (PLANTRA,PTYP,PCOD,PHLPFIL)
Variable Char    PLANTRA()
Variable Char    PTYP()
Variable Char    PCOD()
Value Integer PHLPFIL

Local Integer MAJ_KO

Gosub DEFVAR From AGLOBTRAD
If dim(GFOLDER_V150)<0 : End : Endif
Gosub ENVINDUS_DECL
Gosub TRACAGE_INDUS_ADO From AGENLIBA    : ### trace des modif dans MNTPRD
If    func AGENREM.IS_ENVINDUS_DOC(PLANTRA)
  Gosub REMONTEE_TRAD_ADO                : ### remontee des traductions dans les autres Applis et Trace des modifs dans MNTPRD
Elsif func AGENREM.IS_DOSSIER_SAGE
  # JPGA 23/04/2014 EXI-96830-1 : Chez nous, si la remontee des traductions n'a pas ete faite : On le precise
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES3(mess(136,176,1), PLANTRA, GUSER, nomap),-1) From GESECRAN : Endif
Endif
Gosub ENVINDUS_CLOS
End

$REMONTEE_TRAD_ADO
Gosub TRACAGE_ADO From AGENLIBA : ### trace des modif dans MNTPRD

##### Remontee dans le Dossier RACINE
## 1) on recherche en francais dans dossier indus
Read [XAS]ADO0=GFRA;PTYP;PCOD
If fstat <>0
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE("XAS")-"-"-mess(130,176,1)-mess(128,176,1),-1) From GESECRAN : Endif
  Return # on ne met rien a jour car pas present
Endif

## 2) on recherche en francais dans dossier de ref
Read [XLW]ADO0=GFRA;PTYP;PCOD
If fstat <>0
    # on ne met rien a jour car pas present
    ##Return
    [XLW]=[XAS]
Endif

If PLANTRA<>'FRA' & ([XAS]VLDDAT<>[XLW]VLDDAT or [XAS]VLDFLG<>[XLW]VLDFLG)
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES2 (mess(131,176,1), func AGENREM.FOLDER_OPENED_FILE("XAS"), func AGENREM.FOLDER_OPENED_FILE("XLW"))-mess(128,176,1),-1)
& From GESECRAN : Endif
  Return # on ne met rien a jour car francais different
Endif

Filter [XLW]
Filter [XLW] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
For [XLW]ADO0
    # on copie les paragraphes inexistants, on met a jour les autres
    Read [XAS]ADO0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
    If fstat<>0
        [XAS]=[XLW]
        Write [XAS]
    Else
        [XAS]=[XLW]
        Rewrite [XAS]
    Endif
    If fstat
      Call FSTA("XAS") From GLOCK
    Else
      If [L]TRANSLATE_FOLDER_LIST="" : [L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE("XAS") : Endif
    Endif
    # on copie aussi les textes des paragraphes
    Raz [XLW1]
    Read [XLW1]ADH0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
    If fstat<>0
        Raz [X_W1]
        Read [X_W1]ADH0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
        [XLW1]=[X_W1]
    Endif
    Read [XAS1]ADH0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
    If fstat<>0
        If [XLW1]COD<>"" : # uniquement s'il y a un texte
            [XAS1]=[XLW1]
            Write [XAS1]
            If fstat : Call FSTA("XAS1") From GLOCK  : Endif
        Endif
    Else
        If [XLW1]COD<>"" : # uniquement s'il y a un texte
            [XAS1]=[XLW1]
            Rewrite [XAS1]
        Else
            Delete [XAS1] Curr
        Endif
        If fstat : Call FSTA("XAS1") From GLOCK  : Endif
    Endif
Next
Filter [XLW]
If PHLPFIL=2
    # on copie les fichiers lies
    For [XLW2] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
        Read [XAS2]ADB0=[XLW2]LAN;[XLW2]TYP;[XLW2]COD;[XLW2]LEV;[XLW2]SUBLEV;[XLW2]LIG
        If fstat<>0
            [XAS2]=[XLW2]
            Write [XAS2]
        Else
            [XAS2]=[XLW2]
            Rewrite [XAS2]
        Endif
        If fstat : Call FSTA("XAS2") From GLOCK  : Endif
    Next
    For [X_W2] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
        [XLW2]=[X_W2]
        Read [XAS2]ADB0=[XLW2]LAN;[XLW2]TYP;[XLW2]COD;[XLW2]LEV;[XLW2]SUBLEV;[XLW2]LIG
        If fstat<>0
            [XAS2]=[XLW2]
            Write [XAS2]
        Else
            [XAS2]=[XLW2]
            Rewrite [XAS2]
        Endif
        If fstat : Call FSTA("XAS2") From GLOCK  : Endif
    Next
Endif

##### Remontee dans le Dossier produit d'INDUS de la version N-1
#Gosub DOC_ENVINDUS_V1V0 ==> Passage V12 continue, on ne remonte plus dans N-1
##### Remontee dans le Dossier SUPERVISEUR de la version N   et les autres produits de la version N
Gosub DOC_ENVINDUS_SUPV2
#Gosub DOC_ENVINDUS_SUPV1
##### Remontee dans le Dossier SUPERVISEUR de la version N-1 et les autres produits de la version N-1
#Gosub DOC_ENVINDUS_SUPV0 ==> PASSAGE V12 CONTINUE, ON NE REMONTE PLUS DANS N-1

# SI024 94779_1 TCH : Trace dans remontee des traductions
If GTRACE<>"" & [L]TRANSLATE_FOLDER_LIST<>""
  Call ECR_TRACE(string$(3," ")+mess(132,176,1)-":"-[L]TRANSLATE_FOLDER_LIST,0) From GESECRAN
Endif

Return

#################
#$DOC_MAJ_X3V1  # Tout ce qui est reference 1 concerne la V11 challenger
#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1Z"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call DOC_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return
#
#$DOC_MAJ_GEODEV1
#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1X"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call DOC_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return

$DOC_MAJ_X3V2  # Tout ce qui est reference 2 concerne la V12 2017Rn
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2Z"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call DOC_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$DOC_MAJ_PAYV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2W"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call DOC_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$DOC_MAJ_GEODEV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2X"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call DOC_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

#####################################################
Subprog DOC_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PHLPFIL, MAJ_KO)
Value Char       DOSSIER_IND()
Value Char       ABREV_DOC()
Value Char       PLANTRA()
Value Char       PTYP()
Value Char       PCOD()
Value Integer    PHLPFIL
Variable Integer MAJ_KO : MAJ_KO=0

Local Char ABREV_DOCSAV(5) : [L]ABREV_DOCSAV=ABREV_DOC

  If DOSSIER_IND <> ""
    # ------------------------------------------------
    # lecture dossier d'indus et verification si c'est le même
    ABREV_DOC=[L]ABREV_DOCSAV
    Gosub ENVINDUS_DEFAULT_FILE
    Filter [F] Where LAN=GFRA & TYP=PTYP & COD=PCOD
    Read [F] First
    Filter [F]
    If fstat <>0
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(133,176,1)-mess(129,176,1),0) From GESECRAN :
& Endif
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Endif
    If PLANTRA<>'FRA' & ([XAS]VLDDAT<>evalue("["+ABREV_DOC+"]VLDDAT") or [XAS]VLDFLG<>evalue("["+ABREV_DOC+"]VLDFLG"))
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(134,176,1)-func AGENREM.FOLDER_OPENED_FILE("XAS")-
& mess(129,176,1),0) From GESECRAN : Endif
        # on ne met rien a jour car francais different
        MAJ_KO = 1 : End
    Endif

    # JPGA 18/03/2011 BUG-70761 : Ouverture de la table des Code activite dans le dossier copie pour recherche d'existence des codes activite par paragraphe
    Gosub ENVINDUS_DECL_CODACT

    # ok on peut mettre a jour pour PLANTRA
    Filter [XLW]
    Filter [XLW] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
    For [XLW]ADO0
        # JPGA 18/03/2011 BUG-70761 : Si le code activite du paragraphe n'existe pas dans le dossier copie : On le met en FAL
        Gosub MAJ_CODACT_INEXISTANTS

        # on copie les paragraphes inexistants, on met a jour les autres
        #JPGA 16/11/2010 BUG-69166 : Remontees de TRAD KO : uniquement paragraphe TIT remonte
        ABREV_DOC=[L]ABREV_DOCSAV
        Gosub ENVINDUS_DEFAULT_FILE
        Call  ENVINDUS_ALIM_ADO(ABREV_DOC, [XLW]LAN, [XLW]TYP, [XLW]COD, [XLW]LEV, [XLW]SUBLEV)
        Read [F] =
        If fstat<>0
            [F]=[XLW]
            Write [F]
        Else
            WMOD=[F]MODULE
            [F]=[XLW]
            [F]MODULE=WMOD
            Rewrite [F]
        Endif
        If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
        # on copie aussi les textes des paragraphes
        Raz [XLW1]
        Read [XLW1]ADH0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
        If fstat<>0
            Raz [X_W1]
            Read [X_W1]ADH0=[XLW]LAN;[XLW]TYP;[XLW]COD;[XLW]LEV;[XLW]SUBLEV
            [XLW1]=[X_W1]
        Endif

        ABREV_DOC=[L]ABREV_DOCSAV+"1"
        Gosub ENVINDUS_DEFAULT_FILE
        Call  ENVINDUS_ALIM_ADO(ABREV_DOC, [XLW]LAN, [XLW]TYP, [XLW]COD, [XLW]LEV, [XLW]SUBLEV)
        Read [F] =
        If fstat<>0
            If [XLW1]COD<>"" : # uniquement s'il y a un texte
                [F]=[XLW1]
                Write [F]
                If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
            Endif
        Else
            If [XLW1]COD<>"" : # uniquement s'il y a un texte
                [F]=[XLW1]
                Rewrite [F]
            Else
                Delete [F] Curr
            Endif
            If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
        Endif
    Next
    Filter [XLW]

    If PHLPFIL=2
        # on copie les fichiers lies
        For [XLW2] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
            Gosub DOC_MAJ_PHLPFIL
        Next
        For [X_W2] Where LAN=PLANTRA and TYP=PTYP and COD=PCOD
            [XLW2]=[X_W2]
            Gosub DOC_MAJ_PHLPFIL
        Next
    Endif
  Endif
End

$DOC_MAJ_PHLPFIL
   ABREV_DOC=[L]ABREV_DOCSAV+"2"
   Gosub ENVINDUS_DEFAULT_FILE
   Call  ENVINDUS_ALIM_ADB(ABREV_DOC, [XLW2]LAN, [XLW2]TYP, [XLW2]COD, [XLW2]LEV, [XLW2]SUBLEV, [XLW2]LIG)
   Read [F] =
   If fstat<>0
      [F]=[XLW2]
      Write [F]
   Else
      [F]=[XLW2]
      Rewrite [F]
   Endif
   If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
Return

#####################################################
Subprog DOC_SUP_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PHLPFIL, MAJ_KO)
Value Char       DOSSIER_IND()
Value Char       ABREV_DOC()
Value Char       PLANTRA()
Value Char       PTYP()
Value Char       PCOD()
Value Integer    PHLPFIL
Variable Integer MAJ_KO : MAJ_KO=0

    ## on recherche en francais dans dossier indus
    Read [XAS]ADO0=GFRA;PTYP;PCOD
    If fstat <>0
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Else
        If [F:XAS]MODULE <> 1
            MAJ_KO = 1 : End
        Endif
    Endif

    # ok on est sur un chapitre superviseur
    # lecture superv et verification si c'est le même
    Call DOC_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PHLPFIL, MAJ_KO)
End

#################
$DOC_ENVINDUS_SUPV2
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
If GPRODUIT = -1  :  Return  :  Endif  :  # si on est deja dans l'appli superviseur on ne fait rien.

Gosub DECL_AFFECTATION_VAR   : [L]WABREV="X2S"  :  Gosub DECL_AFFECTATION_DOSSIER
Call DOC_SUP_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PHLPFIL, [L]MAJ_KO)
If [L]MAJ_KO      :  Return  :  Endif
# SI014 TCH
[L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV)

Case GPRODUIT
  When 0          : # gproduit = 0 : c'est x3
    Gosub DOC_MAJ_PAYV2
    #Gosub DOC_MAJ_GEODEV2                        : # appli geode V12
  When 1          : # gproduit = 1 : c'est geode
    #Gosub DOC_MAJ_X3V2                           : # appli x3    V12
    #Gosub DOC_MAJ_PAYV2
  When 2          : # gproduit = 2 : c'est paye
    Gosub DOC_MAJ_X3V2                           : # appli x3    V12
  When 3          : # gproduit = 3 : c'est abelx3 : # appli abelx3  V6 et + : n existe plus
Endcase
Return

#################
