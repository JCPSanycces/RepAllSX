######################################################################################
## TRAITEMENTS POUR LES TRADUCTIONS #JPGA 22-10-2009 : Bug-57790 Remaniement generique des remontees
######################################################################################
$ENVINDUS_DECL
Local File ADOCUMENT [XLW], ADOCFLD   [XLW3], ADOCFNC   [XLW4]
#######
###ATTENTION les liens doivent exister vers toutes les applis a mettre a jour
#######

# SI024 94779_1 TCH : Trace dans remontee des traductions
If dim(TRANSLATE_FOLDER_LIST)<=0 : Local Char TRANSLATE_FOLDER_LIST(120) : Endif
If dim(DOSSUP)<=0 : Local Char DOSSUP(50) : Endif

Gosub VERDOC From AGENDOCA

# JPGA - 26/01/2009 - Bug-51352 : Ne pas ouvrir les tables si on est pas sur un dossier de reference
If find(nomap,GREFER(1..GNBLANSTD))=0 : Return : Endif

If filinfo(filpath("",GMAGIC,""),0)>=0
    Local Char WDOSMOTH(12)  :  WDOSMOTH = "*"+adxmother(0)+"*"

    If pat (GINDUS , WDOSMOTH)
       #JPGA 20/05/2010 BUG-64925: Suite a l'augmentation de la taille des BLOBS en V6 de 510Ko(BLB de 9) a 1020 Ko(BLB de 10) : Plus de Memoire disponible
       maxmem = max(int(maxmem/1024),50000)

       DOSSUP=func AFNC.PARAM('SUPDOS','')
       ###Local File ADOCUMENT [XLW] , ADOCFLD   [XLW3]
       Local File ADOCCLB      [XLW1], =DOSSUP+".ADOCCLB" [X_W1], ADOCBLB [XLW2], =DOSSUP+".ADOCBLB" [X_W2]
       If GINDUS = ""
          Local File ADOCUMENT [XAS], ADOCCLB   [XAS1], ADOCBLB   [XAS2], ADOCFLD   [XAS3]
       Else
          Local File =adxmother(0)+"."+"ADOCUMENT" [XAS], =adxmother(0)+"."+"ADOCCLB" [XAS1], =adxmother(0)+"."+"ADOCBLB" [XAS2], =adxmother(0)+"."+"ADOCFLD" [XAS3]
       Endif

       Gosub DECL_AFFECTATION_VAR
       #Gosub DECL_V1 # N-1 autres produits ==> Passage V12 continue, on ne remonte plus dans N-1
       Gosub DECL_V2 # N
    Endif
Endif
Return

#####################################################################################################

$DECL_V2
  [L]WABREV="X2S"   :  Gosub DECL_AFFECTATION_DOSSIER : # appli SUPERV V12

  If [L]WDOSS <> ""
    Local File =[L]WDOSS+".ADOCUMENT" [X2S], =[L]WDOSS+".ADOCCLB" [X2S1], =[L]WDOSS+".ADOCBLB" [X2S2], =[L]WDOSS+".ADOCFLD" [X2S3]
  Endif
    Case GPRODUIT
      When 0        : # gproduit = 0 : c'est x3
        Gosub DECL_V2_GEODE
        Gosub DECL_V2_PAYE
      When 1        : # gproduit = 1 : c'est geode
        Gosub DECL_V2_X3
        Gosub DECL_V2_PAYE
      When 2        : # gproduit = 2 : c'est paye
        Gosub DECL_V2_X3
        Gosub DECL_V2_GEODE
      When 3        : # gproduit = 3 : c'est abelx3   : # appli abelx3 V6 et + : n existe plus
    Endcase
Return

$DECL_V2_X3
  [L]WABREV="X2Z"   : Gosub DECL_AFFECTATION_DOSSIER  : # appli x3     V12
  If [L]WDOSS <> "" : Local File =[L]WDOSS+".ADOCUMENT" [X2Z], =[L]WDOSS+".ADOCCLB" [X2Z1], =[L]WDOSS+".ADOCBLB" [X2Z2], =[L]WDOSS+".ADOCFLD" [X2Z3] : Endif
Return
$DECL_V2_GEODE
  #[L]WABREV="X2X"  : Gosub DECL_AFFECTATION_DOSSIER  : # appli geode  V12
  #If [L]WDOSS <> "" : Local File =[L]WDOSS+".ADOCUMENT" [X2X], =[L]WDOSS+".ADOCCLB" [X2X1], =[L]WDOSS+".ADOCBLB" [X2X2], =[L]WDOSS+".ADOCFLD" [X2X3] : Endif
Return
$DECL_V2_PAYE
  [L]WABREV="X2W"  : Gosub DECL_AFFECTATION_DOSSIER  : # appli paye   V12
  If [L]WDOSS <> "" : Local File =[L]WDOSS+".ADOCUMENT" [X2W], =[L]WDOSS+".ADOCCLB" [X2W1], =[L]WDOSS+".ADOCBLB" [X2W2], =[L]WDOSS+".ADOCFLD" [X2W3] : Endif
Return

