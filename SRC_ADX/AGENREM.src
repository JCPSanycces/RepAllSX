If [L]MAJ_KO      :  Return  :  Endif
# SI024 94779_1 TCH : Trace dans remontee des traductions
[L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV)

Case GPRODUIT
  When 0          : # gproduit = 0 : c'est x3
    Gosub FLD_MAJ_PAYV2                           : # appli x3      V12
    #Gosub FLD_MAJ_GEODEV2                        : # appli geode   V12
