#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1X"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call FIL_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return

$FIL_MAJ_X3V2     # Tout ce qui est reference 2 concerne la V12 2017Rn
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2Z"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FIL_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$FIL_MAJ_PAYV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2W"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FIL_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$FIL_MAJ_GEODEV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2X"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FIL_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

#####################################################
Subprog FIL_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, MAJ_KO)
Value Char    DOSSIER_IND()
Value Char    ABREV_DOC()
Value Char    PLANTRA()
Value Char    PTYP()
Value Char    PCOD()
Value Integer PLEV
Value Integer PSUBLEV
Value Integer PLIG
Variable Integer MAJ_KO : MAJ_KO=0

Local Char ABREV_DOCSAV(5) : [L]ABREV_DOCSAV=ABREV_DOC

  If DOSSIER_IND <> ""
    # ------------------------------------------------
    # lecture dans dossier d'indus et verification si c'est le même
    ABREV_DOC=[L]ABREV_DOCSAV
    Gosub ENVINDUS_DEFAULT_FILE
    Filter [F] Where LAN=GFRA & TYP=PTYP & COD=PCOD
    Read [F] First
    Filter [F]
    If fstat <>0
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(133,176,1)-mess(129,176,1),0) From GESECRAN :
& Endif
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Endif

    If PLANTRA<>'FRA' & ([XAS]VLDDAT<>evalue("["+ABREV_DOC+"]VLDDAT") or [XAS]VLDFLG<>evalue("["+ABREV_DOC+"]VLDFLG"))
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(134,176,1)-func AGENREM.FOLDER_OPENED_FILE("XAS")-
& mess(129,176,1),0) From GESECRAN : Endif
        # on ne met rien a jour car francais different
        MAJ_KO = 1 : End
    Endif

    # ok on peut mettre a jour pour PLANTRA
    Read [XLW2]ADB0=PLANTRA;PTYP;PCOD;PLEV;PSUBLEV;PLIG
    If fstat<>0
        Read [X_W2]ADB0=PLANTRA;PTYP;PCOD;PLEV;PSUBLEV;PLIG
        If fstat <>0
            # on ne met rien a jour car pas present ???
            MAJ_KO = 1 : End
        Endif
        [XLW2]=[X_W2]
    Endif

    ABREV_DOC=[L]ABREV_DOCSAV+"2"
    Gosub ENVINDUS_DEFAULT_FILE
    Call  ENVINDUS_ALIM_ADB(ABREV_DOC, [XLW2]LAN, [XLW2]TYP, [XLW2]COD, [XLW2]LEV, [XLW2]SUBLEV, [XLW2]LIG)
    Read [F] =
    If fstat<>0
        [F]=[XLW2]
        Write [F]
    Else
        [F]=[XLW2]
        Rewrite [F]
    Endif
    If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
  Endif
End


#####################################################
Subprog FIL_SUP_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, MAJ_KO)
Value Char       DOSSIER_IND()
Value Char       ABREV_DOC()
Value Char       PLANTRA()
Value Char       PTYP()
Value Char       PCOD()
Value Integer    PLEV
Value Integer    PSUBLEV
Value Integer    PLIG
Variable Integer MAJ_KO : MAJ_KO=0

    ## on recherche en francais dans dossier indus
    Read [XAS]ADO0=GFRA;PTYP;PCOD
    If fstat <>0
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Else
        If [F:XAS]MODULE <> 1
            MAJ_KO = 1 : End
        Endif
    Endif

    # ok on est sur un chapitre superviseur
    # lecture superv et verification si c'est le même
    Call FIL_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, MAJ_KO)
End

#################
$FIL_ENVINDUS_SUPV2
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
If GPRODUIT = -1  :  Return  :  Endif  :  # si on est deja dans l'appli superviseur on ne fait rien.

Gosub DECL_AFFECTATION_VAR   : [L]WABREV="X2S"  :  Gosub DECL_AFFECTATION_DOSSIER
Call FIL_SUP_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
If [L]MAJ_KO      :  Return  :  Endif
# SI014 TCH
[L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV)

Case GPRODUIT
  When 0          : # gproduit = 0 : c'est x3
    Gosub FIL_MAJ_PAYV2                           : # appli paie    V12
    #Gosub FIL_MAJ_GEODEV2                        : # appli geode   V12
  When 1          : # gproduit = 1 : c'est geode
    #Gosub FIL_MAJ_X3V2                           : # appli x3      V12
  When 2          : # gproduit = 2 : c'est paye
    Gosub FIL_MAJ_X3V2                           : # appli x3      V12
  When 3          : # gproduit = 3 : c'est abelx3 : # appli abelx3  V6 et + : n existe plus
Endcase
Return

