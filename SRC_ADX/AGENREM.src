Subprog MAJ_ENVINDUS_ADF (PTYP,PCOD)
Variable Char    PTYP()
Variable Char    PCOD()

Gosub DEFVAR From AGLOBTRAD
If dim(GFOLDER_V150)<0 : End : Endif
Gosub ENVINDUS_DECL
Gosub TRACAGE_INDUS_ADF From AGENLIBA : ### trace des modif dans MNTPRD
Gosub ENVINDUS_CLOS
End


######################################################################################
######################################################################################
Subprog MAJ_ENVINDUS_FLD (PLANTRA,PMOTCLE)
Variable Char    PLANTRA()
Variable Char    PMOTCLE()

Local Integer MAJ_KO

Gosub DEFVAR From AGLOBTRAD
If dim(GFOLDER_V150)<0 : End : Endif
Gosub ENVINDUS_DECL
Gosub TRACAGE_INDUS_ADZ From AGENLIBA    : ### trace des modif dans MNTPRD
If    func AGENREM.IS_ENVINDUS_DOC(PLANTRA)
  Gosub REMONTEE_TRAD_ADZ                : ### remontee des traductions dans les autres Applis et Trace des modifs dans MNTPRD
Elsif func AGENREM.IS_DOSSIER_SAGE
  # JPGA 23/04/2014 EXI-96830-1 : Chez nous, si la remontee des traductions n'a pas ete faite : On le precise
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES3(mess(136,176,1), PLANTRA, GUSER, nomap),-1) From GESECRAN : Endif
Endif
Gosub ENVINDUS_CLOS
End

$REMONTEE_TRAD_ADZ
Gosub TRACAGE_ADZ From AGENLIBA : ### trace des modif dans MNTPRD
## 1) on recherche en francais dans dossier indus
Read [XAS3]ADZ0=GFRA;PMOTCLE
If fstat <>0
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE("XAS3")-"-"-mess(130,176,1)-mess(128,176,1),-1) From GESECRAN : Endif
  Return # on ne met rien a jour car pas present
Endif

## 2) on recherche en francais dans dossier de ref
Read [XLW3]ADZ0=GFRA;PMOTCLE
If fstat <>0
    # on ne met rien a jour car pas present
    ##Return
    [XLW3]=[XAS3]
Endif

If [XAS3]CREDAT<>[XLW3]CREDAT or (PLANTRA<>'FRA' & [XAS3]UPDDAT<>[XLW3]UPDDAT )
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES2(mess(131,176,1),func AGENREM.FOLDER_OPENED_FILE("XAS3"),func AGENREM.FOLDER_OPENED_FILE("XLW3"))-mess(128,176,1),-1)
& From GESECRAN : Endif
  Return # on ne met rien a jour car francais different
Endif

Read [XLW3]ADZ0=PLANTRA;PMOTCLE
If fstat <>0
    # SI024 94779_1 TCH : Trace dans remontee des traductions
    If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-mess(135,176,1)-func AGENREM.FOLDER_OPENED_FILE("XLW3")-"=> pas de remontee",0) From GESECRAN
& : Endif
    # on ne met rien a jour car pas present ???
    Return
Endif

Read [XAS3]ADZ0=PLANTRA;PMOTCLE
If fstat<>0
    [XAS3]=[XLW3]
    Write [XAS3]
Else
    [XAS3]=[XLW3]
    Rewrite [XAS3]
Endif
If fstat
  Call FSTA("XAS3") From GLOCK
Else
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  [L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE("XAS3")
Endif

##### Remontee dans le Dossier produit d'INDUS de la version N-1
#Gosub FLD_ENVINDUS_V1V0 ==> Passage V12 continue, on ne remonte plus dans N-1
##### Remontee dans le Dossier SUPERVISEUR de la version N   et les autres produits de la version N
Gosub FLD_ENVINDUS_SUPV2
#Gosub FLD_ENVINDUS_SUPV1
##### Remontee dans le Dossier SUPERVISEUR de la version N-1 et les autres produits de la version N-1
#Gosub FLD_ENVINDUS_SUPV0 ==> Passage V12 continue, on ne remonte plus dans N-1

# SI024 94779_1 TCH : Trace dans remontee des traductions
If GTRACE<>"" & [L]TRANSLATE_FOLDER_LIST<>""
  Call ECR_TRACE(string$(3," ")+mess(132,176,1)-":"-[L]TRANSLATE_FOLDER_LIST,0) From GESECRAN
Endif

Return

#################
#$FLD_MAJ_X3V1
#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1Z"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call FLD_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PMOTCLE, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return
#
#$FLD_MAJ_GEODEV1
#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1X"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call FLD_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PMOTCLE, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return

$FLD_MAJ_X3V2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2Z"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FLD_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PMOTCLE, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$FLD_MAJ_PAYV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2W"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FLD_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PMOTCLE, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

$FLD_MAJ_GEODEV2
   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X2X"  :  Gosub DECL_AFFECTATION_DOSSIER
   Call FLD_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PMOTCLE, [L]MAJ_KO)
   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
Return

#####################################################
Subprog FLD_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PMOTCLE, MAJ_KO)
Value Char       DOSSIER_IND()
Value Char       ABREV_DOC()
Value Char       PLANTRA()
Value Char       PMOTCLE()
Variable Integer MAJ_KO : MAJ_KO=0

Local Char ABREV_DOCSAV(5) : [L]ABREV_DOCSAV=ABREV_DOC

  If DOSSIER_IND <> ""
    # ------------------------------------------------
    # lecture dans dossier d'indus et verification si c'est le même
    ABREV_DOC=[L]ABREV_DOCSAV+"3"
    Gosub ENVINDUS_DEFAULT_FILE
    Call  ENVINDUS_ALIM_ADZ(ABREV_DOC, GFRA, PMOTCLE)
    Read [F] =
    If fstat <>0
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(133,176,1)-mess(129,176,1),0) From GESECRAN : Endif
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Endif

    If [XAS3]CREDAT<>evalue("["+ABREV_DOC+"]CREDAT") or (PLANTRA<>'FRA' & [XAS3]UPDDAT<>evalue("["+ABREV_DOC+"]UPDDAT"))
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE(ABREV_DOC)-"-"-mess(134,176,1)-func AGENREM.FOLDER_OPENED_FILE("XAS3")-
& mess(129,176,1),0) From GESECRAN : Endif
        # on ne met rien a jour car francais different
        MAJ_KO = 1 : End
    Endif

    Read [XLW3]ADZ0=PLANTRA;PMOTCLE
    If fstat <>0
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-mess(135,176,1)-func AGENREM.FOLDER_OPENED_FILE("XLW3")-mess(129,176,1),0) From GESECRAN : Endif
        # on ne met rien a jour car pas present ???
        MAJ_KO = 1 : End
    Endif

    ABREV_DOC=[L]ABREV_DOCSAV+"3"
    Gosub ENVINDUS_DEFAULT_FILE
    Call  ENVINDUS_ALIM_ADZ(ABREV_DOC, PLANTRA, PMOTCLE)
    Read [F] =
    If fstat<>0
        [F]=[XLW3]
        Write [F]
    Else
        WMOD=[F]MODULE
        [F]=[XLW3]
        [F]MODULE=WMOD
        Rewrite [F]
    Endif
    If fstat : Call FSTA(ABREV_DOC) From GLOCK  : Endif
  Endif
End

Subprog FLD_SUP_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PMOTCLE, MAJ_KO)
Value Char       DOSSIER_IND()
Value Char       ABREV_DOC()
Value Char       PLANTRA()
Value Char       PMOTCLE()
Variable Integer MAJ_KO : MAJ_KO=0

Local Char ABREV_DOCSAV(5) : [L]ABREV_DOCSAV=ABREV_DOC

    ## on recherche en francais dans dossier indus
    Read [XAS3]ADZ0=GFRA;PMOTCLE
    If fstat <>0
        # on ne met rien a jour car pas present
        MAJ_KO = 1 : End
    Else
        If [F:XAS3]MODULE <> 1
            MAJ_KO = 1 : End
        Endif
    Endif

    # ok on est sur un chapitre superviseur
    # lecture superv et verification si c'est le même
    Call FLD_MAJ_GENERIQUE(DOSSIER_IND, ABREV_DOC, PLANTRA, PMOTCLE, MAJ_KO)
End

##################
$FLD_ENVINDUS_SUPV2
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
If GPRODUIT = -1  :  Return  :  Endif  :  # si on est deja dans l'appli superviseur on ne fait rien.

Gosub DECL_AFFECTATION_VAR   : [L]WABREV="X2S"  :  Gosub DECL_AFFECTATION_DOSSIER
