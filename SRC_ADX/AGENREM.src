######################################################################################
######################################################################################
Subprog MAJ_ENVINDUS_FIL (PLANTRA,PTYP,PCOD,PLEV,PSUBLEV,PLIG)
Variable Char    PLANTRA()
Variable Char    PTYP()
Variable Char    PCOD()
Value Integer PLEV
Value Integer PSUBLEV
Value Integer PLIG

Local Integer MAJ_KO

Gosub DEFVAR From AGLOBTRAD
If dim(GFOLDER_V150)<0 : End : Endif
Gosub ENVINDUS_DECL
Gosub TRACAGE_INDUS_ADO From AGENLIBA    : ### trace des modif dans MNTPRD
If    func AGENREM.IS_ENVINDUS_DOC(PLANTRA)
  Gosub REMONTEE_TRAD_FIL                : ### remontee des traductions dans les autres Applis et Trace des modifs dans MNTPRD
Elsif func AGENREM.IS_DOSSIER_SAGE
  # JPGA 23/04/2014 EXI-96830-1 : Chez nous, si la remontee des traductions n'a pas ete faite : On le precise
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES3(mess(136,176,1), PLANTRA, GUSER, nomap),-1) From GESECRAN : Endif
Endif
Gosub ENVINDUS_CLOS
End

$REMONTEE_TRAD_FIL
Gosub TRACAGE_ADO From AGENLIBA : ### trace des modif dans MNTPRD
## 1) on recherche en francais dans dossier indus
Read [XAS]ADO0=GFRA;PTYP;PCOD
If fstat <>0
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AGENREM.FOLDER_OPENED_FILE("XAS")-"-"-mess(130,176,1)-mess(128,176,1),-1) From GESECRAN : Endif
  Return # on ne met rien a jour car pas present
Endif

## 2) on recherche en francais dans dossier de ref
Read [XLW]ADO0=GFRA;PTYP;PCOD
If fstat <>0
    # on ne met rien a jour car pas present
    ##Return
    [XLW]=[XAS]
Endif

If PLANTRA<>'FRA' & ([XAS]VLDDAT<>[XLW]VLDDAT or [XAS]VLDFLG<>[XLW]VLDFLG)
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-func AFNC.MES2 (mess(131,176,1), func AGENREM.FOLDER_OPENED_FILE("XAS"), func AGENREM.FOLDER_OPENED_FILE("XLW"))-mess(128,176,1),-1)
& From GESECRAN : Endif
  Return # on ne met rien a jour car francais different
Endif

Read [XLW2]ADB0=PLANTRA;PTYP;PCOD;PLEV;PSUBLEV;PLIG
If fstat<>0
    Read [X_W2]ADB0=PLANTRA;PTYP;PCOD;PLEV;PSUBLEV;PLIG
    If fstat <>0
        # SI024 94779_1 TCH : Trace dans remontee des traductions
        If GTRACE<>"" : Call ECR_TRACE(string$(3," ")+mess(127,176,1)-":"-mess(135,176,1)-func AGENREM.FOLDER_OPENED_FILE("X_W2")-"=> pas de remontee",0) From GESECRAN :
& Endif
        # on ne met rien a jour car pas present ???
        Return
    Endif
    [XLW2]=[X_W2]
    [L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE("XLW2")
Endif

Read [XAS2]ADB0=[XLW2]LAN;[XLW2]TYP;[XLW2]COD;[XLW2]LEV;[XLW2]SUBLEV;[XLW2]LIG
If fstat<>0
    [XAS2]=[XLW2]
    Write [XAS2]
Else
    [XAS2]=[XLW2]
    Rewrite [XAS2]
Endif
If fstat
  Call FSTA("XAS2") From GLOCK
Else
  # SI024 94779_1 TCH : Trace dans remontee des traductions
  [L]TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE("XAS2")
Endif

##### Remontee dans le Dossier produit d'INDUS de la version N-1
#Gosub FIL_ENVINDUS_V1V0 ==> Passage V12 continue, on ne remonte plus dans N-1
##### Remontee dans le Dossier SUPERVISEUR de la version N   et les autres produits de la version N
Gosub FIL_ENVINDUS_SUPV2
#Gosub FIL_ENVINDUS_SUPV1
##### Remontee dans le Dossier SUPERVISEUR de la version N-1 et les autres produits de la version N-1
#Gosub FIL_ENVINDUS_SUPV0 ==> Passage V12 continue, on ne remonte plus dans N-1

# SI024 94779_1 TCH : Trace dans remontee des traductions
If GTRACE<>"" & [L]TRANSLATE_FOLDER_LIST<>""
  Call ECR_TRACE(string$(3," ")+mess(132,176,1)-":"-[L]TRANSLATE_FOLDER_LIST,0) From GESECRAN
Endif

Return

#################
#$FIL_MAJ_X3V1     # Tout ce qui est reference 1 concerne la V11 challenger
#   Gosub DECL_AFFECTATION_VAR     : [L]WABREV="X1Z"  :  Gosub DECL_AFFECTATION_DOSSIER
#   Call FIL_MAJ_GENERIQUE([L]WDOSS, [L]WABREV, PLANTRA, PTYP, PCOD, PLEV, PSUBLEV, PLIG, [L]MAJ_KO)
#   If [L]MAJ_KO=0 : TRANSLATE_FOLDER_LIST -= func AGENREM.FOLDER_OPENED_FILE([L]WABREV) : Endif
#Return
