#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
# SUBSDP : Saisie/Affichage détail de coût                                   #
##############################################################################
# Traitement de l'action SAIDECPRI & actions sur champs de l'écran SAIDECPRI #
##############################################################################
# Paramètres de l'action SAIDECPRI:
#    ORI     = chaine permettant d'indiquer à partir de quoi charger l'écran
#
#  si l'action est appelée depuis un document les 4 paramètres suivants doivent être renseignés
#    NOLIG   = indice dans le tableau des lignes du document
#    WSTOSEQ = valeur du champ WSTOSEQ correspondant à laligne de doc
#    VCRTYP  = Type de document (oriente sur le masque d'origine) pour le chargement des paramètres
#    ZONE    = Zone prix du document
#
#    AFFMSK  = 2:affichage seulement (bouton 'ok' grisé)
#    OPTION  = rien pour l'instant
##############################################################################

$ACTION
Case ACTION
    When "TITRE"       : Gosub TITLE
    When "DEBUT"       : Gosub DEBUT
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "OK"          : Gosub ACT_OK
    When "SETBOUT"     : Gosub SETBOUT
    When "FERME"       : Gosub FERME
Endcase
Return

$FERME
Kill GAFFMSK
Return

$TITLE
    Case PARAM(1)
        When "AVC" :
            TIT = mess(1,171,1)   # Décomposition PMP
            Chgfmt [M:SDP]NBONA With "-N:8"
        When "LAS" :
            TIT = mess(2,171,1)   # Décomposition dernier prix
            Chgfmt [M:SDP]NBONA With "-N:8"
        When "ITCD", "ICLD" :
            TIT = mess(3,171,1)
        When "ITCA", "ICLA" :
            TIT = mess(4,171,1)
        When "ITCB", "ICLB" :
            TIT = mess(5,171,1)
        When "ITCS", "ICLS" :
            TIT = mess(6,171,1)
        When "SJVO", "VALW" :
            Call TEXTE(39175,TIT) From OBJDIV  # Détail prix d'ordre
        When "SJVV" :
            Call TEXTE(39176,TIT) From OBJDIV  # Détail prix de valorisation
        When "STD", "STDL" :
            Call TEXTE(21952,TIT) From OBJDIV  # Détail coût standard
        When "MFC", "MFCL" :
            Call TEXTE(22249,TIT) From OBJDIV  # Détail coût PRF
    Endcase
Return

$SETBOUT

  If val(PARAM(6))=2
    Call VIREBOUT(CHBOU,"O") From GOBJET
  Endif

  If val(PARAM(7))=2
    Call VIREBOUT(CHBOU,"O") From GOBJET
    Grizo [M:SDP]
  Endif

Return

##########################################
$DEBUT
If !clalev([F:ONA]) : Local File OVENAT : Endif

Local Integer LLIGDOC, LLIGW, LVCRTYP
Local Decimal LPRIORI
Local Decimal LDIFPRI
Global Char    GPRIORI
Local Integer LMODIF    # 0= pas de modif ; 1= au moins une composante modifiée

If dim(GAFFMSK)<=0
    Global Integer GAFFMSK    # bit 1(  1) = tout saisissable (prioritaire sur les autre possibilités)
                              # bit 2(  2) = rien n'est saisissable (prioritaire sur les suivants)
                              # bit 3(  4) = matière saisissable
                              # bit 4(  8) = machine saisissable
                              # bit 5( 16) = main d'oeuvre saisissable
                              # bit 6( 32) = sous-traitance saisissable
                              # bit 7( 64) = totaux FG saisissables
                              # bit 8(128) = natures FG saisissables
Endif
Actzo [M:SDP]
Effzo [M:SDP]

GPRIORI = PARAM(1)    # paramètre ORI

If !find(GPRIORI,"STD","STDL", "ACT", "ACTL")
    Chgfmt [M:SDP]BTNNIV With "-K:3X"
    Chgfmt [M:SDP]INTNIV With "-K:3X"
Elsif find(GPRIORI,"STD", "ACT")
    [M:SDP]BTNNIV="80"
    [M:SDP]NIV = 2
Else
    [M:SDP]BTNNIV="81"
    [M:SDP]NIV = 1
Endif

If find(GPRIORI,"LAS","AVC")
#    Chgfmt [M:SDP]NBONA With "-N:8" #X3-38338.o MJH 14 Sep 2017
    Chgtbk [M:SDP]30 With ""
Endif

LLIGDOC = val(PARAM(2))    # paramètre NOLIG
If val(PARAM(3))>0    # paramètre WSTOSEQ
    LLIGW = find(val(PARAM(3)),[M:VALW]WSTOSEQ)-1
Else
    LLIGW = -1
Endif

LVCRTYP = val(PARAM(4))    # paramètre VCRTYP
If PARAM(5)<>""            # paramètre ZONE
    LPRIORI = evalue(PARAM(5))
Elsif clalev([M:VALW])>0 & [M:VALW]ZONPRI<>""
    LPRIORI = evalue([M:VALW]ZONPRI+"(LLIGDOC)")
Endif

GAFFMSK = val(PARAM(6))    # paramètre AFFMSK

Gosub CHARGE_PARAM From SUBSDPCOM
If FIN=1
    Return
Endif
If GAFFMSK=0
    FIN=1
    Return
Endif

If LLIGW>=0
    Call LOAD_VAL(LLIGW)
    [M:SDP]PRI = [M:VALW]PRI(LLIGW)
    If LPRIORI<>[M:VALW]PRI(LLIGW)
        LDIFPRI = LPRIORI - [M:VALW]PRI(LLIGW)
        # Ajouter la différence dans une composante
        Gosub REPARTIR
    Endif
Endif


# Calculs des totaux
Gosub CAL_TOT

# Recalcule les % et diszone les champs nécessaire
Gosub REFRESH

Chgstl [M:SDP]MATCST(GACTMAT) With "GRAS"
Chgstl [M:SDP]MACCST(GACTMAC) With "GRAS"
Chgstl [M:SDP]LABCST(GACTLAB) With "GRAS"
Diszo [M:SDP]MATCST(GACTMAT)
Diszo [M:SDP]MACCST(GACTMAC)
Diszo [M:SDP]LABCST(GACTLAB)

Affzo [M:SDP]


Return

##########################################
$APRES_MODIF
    If COUZON="PRI"
        LDIFPRI=val(CZ)-[M:SDP]PRI    # LDIFPRI déclarée dans $DEBUT
        Gosub REPARTIR
        [M:SDP]AMTTOT = val(CZ)*[M:SDP]QTY
    Elsif !find(COUZON,"NBMAT","NBMAC","NBLAB","NBONA","OVENAT","ONATYP","ONAAMT","ONATYP")
        If evalue("type([M:SDP]"+COUZON+")")<10
            Assign "[M:SDP]"+COUZON+"(indice)" With val(CZ)    # Pour que le calcul des totaux soit bon
        Else
            Assign "[M:SDP]"+COUZON+"(indice)" With CZ    # Pour que le calcul des totaux soit bon
        Endif
        Gosub CAL_TOT
        [M:SDP]AMTTOT = [M:SDP]PRI*[M:SDP]QTY
    Endif
    If !find(COUZON,"NBMAT","NBMAC","NBLAB","NBONA","OVENAT","ONATYP","ONAAMT","ONATYP")
        Gosub REFRESH
    Endif
    [M:SDP]PRISAI = GPRISAIMAN
Return


######################################
# LOAD_VAL : Charge les valeur de VALW dans SDP
######################################
Subprog LOAD_VAL(PIND)
Value Integer PIND

Call LOAD_VALX("SDP",PIND)

End

Subprog LOAD_VALX(PABR,PIND)
Value Char    PABR
Value Integer PIND

Local Integer I, J, N

    #------- MATIERE ---------#
    For I=0 To GACTMAT-1
        If dim([M:VALW]OMATCST)>0
            Assign "[M:"+PABR+"]MATCST(I)" With [M:VALW]OMATCST(PIND*GACTMAT+I)
        Endif
    Next

    Assign "[M:"+PABR+"]OVEMATCST" With [M:VALW]OOVEMATCST(PIND)

    #------- MACHINE ---------#
    For I=0 To GACTMAC-1
        If dim([M:VALW]OMACCST)>0
            Assign "[M:"+PABR+"]MACCST(I)" With [M:VALW]OMACCST(PIND*GACTMAC+I)
        Endif
    Next

    Assign "[M:"+PABR+"]OVEMACCST" With [M:VALW]OOVEMACCST(PIND)

    #------- MAIN D'OEUVRE ---------#
    For I=0 To GACTLAB-1
        If dim([M:VALW]OLABCST)>0
            Assign "[M:"+PABR+"]LABCST(I)" With [M:VALW]OLABCST(PIND*GACTLAB+I)
        Endif
    Next

    Assign "[M:"+PABR+"]OVELABCST" With [M:VALW]OOVELABCST(PIND)

    #------- SOUS-TRAITANCE ---------#
    Assign "[M:"+PABR+"]SCOCST" With [M:VALW]OSCOTOT(PIND)
    Assign "[M:"+PABR+"]SCOTOT" With [M:VALW]OSCOTOT(PIND)
    Assign "[M:"+PABR+"]OVESCOCST" With [M:VALW]OOVESCOCST(PIND)

    Assign "[M:"+PABR+"]INVDTACST" With [M:VALW]OINVDTACST(PIND)

    J=find([M:VALW]WSTOSEQ(PIND),[M:VALW]OWSTOSEQ)
    If J>0
        Raz N
        For I=J-1 To [M:VALW]NBONA
            If [M:VALW]OWSTOSEQ(I)=[M:VALW]WSTOSEQ(PIND)
                Assign "[M:"+PABR+"]OVENAT(N)" With [M:VALW]OVENAT(I)
                Assign "[M:"+PABR+"]ONATYP(N)" With [M:VALW]ONATYP(I)
                Assign "[M:"+PABR+"]ONAAMT(N)" With [M:VALW]ONAAMT(I)
                N+=1
            Endif
        Next
        Assign "[M:"+PABR+"]NBONA" With N
    Endif
End

######################################
# CAL_PRITOT : Calcule le prix total ainsi que les sous-totaux
######################################
$CAL_TOT
    [M:SDP]MATTOT = sum([M:SDP]MATCST(0..GACTMAT-1))
    [M:SDP]MATCST(GACTMAT) = [M:SDP]MATTOT
    [M:SDP]MACTOT = sum([M:SDP]MACCST(0..GACTMAC-1))
    [M:SDP]MACCST(GACTMAC) = [M:SDP]MACTOT
    [M:SDP]LABTOT = sum([M:SDP]LABCST(0..GACTLAB-1))
    [M:SDP]LABCST(GACTLAB) = [M:SDP]LABTOT
    [M:SDP]SCOTOT = [M:SDP]SCOCST
    # Issue 69578 - 2010-12-01 by CCC : La mise à jour doit aussi se faire lors de la saisie de la 1ère nature
    #If [M:SDP]NBONA>0
    # Issue 82159 - 2012-07-06 by CCC
    If !sigma(0,[M:SDP]NBONA-1,[M:SDP]ONATYP(indcum)<2)
        [M:SDP]OVEMATCST = sigma(0,max([M:SDP]NBONA-1,min(nolign-1,dim([M:SDP]ONAAMT)-1)),[M:SDP]ONAAMT(indcum)*([M:SDP]ONATYP(indcum)=2))
        [M:SDP]OVEMACCST = sigma(0,max([M:SDP]NBONA-1,min(nolign-1,dim([M:SDP]ONAAMT)-1)),[M:SDP]ONAAMT(indcum)*([M:SDP]ONATYP(indcum)=3))
        [M:SDP]OVELABCST = sigma(0,max([M:SDP]NBONA-1,min(nolign-1,dim([M:SDP]ONAAMT)-1)),[M:SDP]ONAAMT(indcum)*([M:SDP]ONATYP(indcum)=4))
        [M:SDP]OVESCOCST = sigma(0,max([M:SDP]NBONA-1,min(nolign-1,dim([M:SDP]ONAAMT)-1)),[M:SDP]ONAAMT(indcum)*([M:SDP]ONATYP(indcum)=5))
    Endif
    #Endif
    [M:SDP]PRI    = [M:SDP]MATTOT    + [M:SDP]MACTOT    + [M:SDP]LABTOT    + [M:SDP]SCOTOT + [M:SDP]INVDTACST
&                  +[M:SDP]OVEMATCST + [M:SDP]OVEMACCST + [M:SDP]OVELABCST + [M:SDP]OVESCOCST
    [M:SDP]AMTTOT = [M:SDP]PRI*[M:SDP]QTY
Return

######################################
# REFRESH : Recalcule les pourcentages
######################################
$REFRESH
Local Integer I

    #------- MATIERE ---------#
    For I=0 To GACTMAT
        Raz [M:SDP]PERMAT(I)
        If [M:SDP]MATCST(I)<>0 & [M:SDP]PRI<>0
            [M:SDP]PERMAT(I) = num$(arr([M:SDP]MATCST(I)*100/[M:SDP]PRI,0.1))+"%"
        Endif
    Next
    Raz [M:SDP]PEROVEMAT
    If [M:SDP]OVEMATCST<>0 & [M:SDP]PRI<>0
        [M:SDP]PEROVEMAT = num$(arr([M:SDP]OVEMATCST*100/[M:SDP]PRI,0.1))+"%"
    Endif


    #------- MACHINE ---------#
    For I=0 To GACTMAC
        Raz [M:SDP]PERMAC(I)
        If [M:SDP]MACCST(I)<>0 & [M:SDP]PRI<>0
            [M:SDP]PERMAC(I) = num$(arr([M:SDP]MACCST(I)*100/[M:SDP]PRI,0.1))+"%"
        Endif
    Next
    Raz [M:SDP]PEROVEMAC
    If [M:SDP]OVEMACCST<>0 & [M:SDP]PRI<>0
        [M:SDP]PEROVEMAC = num$(arr([M:SDP]OVEMACCST*100/[M:SDP]PRI,0.1))+"%"
    Endif


    #------- MAIN D'OEUVRE ---------#
    For I=0 To GACTLAB
        Raz [M:SDP]PERLAB(I)
        If [M:SDP]LABCST(I)<>0 & [M:SDP]PRI<>0
            [M:SDP]PERLAB(I) = num$(arr([M:SDP]LABCST(I)*100/[M:SDP]PRI,0.1))+"%"
        Endif
    Next
    Raz [M:SDP]PEROVELAB
    If [M:SDP]OVELABCST<>0 & [M:SDP]PRI<>0
        [M:SDP]PEROVELAB = num$(arr([M:SDP]OVELABCST*100/[M:SDP]PRI,0.1))+"%"
    Endif


    #------- SOUS-TRAITANCE ---------#
    Raz [M:SDP]PERSCO
    If [M:SDP]SCOTOT<>0 & [M:SDP]PRI<>0
        [M:SDP]PERSCO = num$(arr([M:SDP]SCOTOT*100/[M:SDP]PRI,0.1))+"%"
    Endif
    Raz [M:SDP]PEROVESCO
    If [M:SDP]OVESCOCST<>0 & [M:SDP]PRI<>0
        [M:SDP]PEROVESCO = num$(arr([M:SDP]OVESCOCST*100/[M:SDP]PRI,0.1))+"%"
    Endif

    Raz [M:SDP]PERINV
    If [M:SDP]INVDTACST<>0 & [M:SDP]PRI<>0
        [M:SDP]PERINV = num$(arr([M:SDP]INVDTACST*100/[M:SDP]PRI,0.1))+"%"
    Endif

    [M:SDP]INTNIV = string$(find([M]NIV,1,2)>0,mess([M]NIV,481,1))

    For I=0 To GACTMAT-1
        [M:SDP]FAMMAT(I) = mess(I+1,325,1)
    Next
    [M:SDP]FAMMAT(I) = mess(1,379,1)
    [M:SDP]NBMAT = GACTMAT+1

    For I=0 To GACTMAC-1
        [M:SDP]FAMMAC(I) = mess(I+1,316,1)
    Next
    [M:SDP]FAMMAC(I) = mess(3,379,1)
    [M:SDP]NBMAC = GACTMAC+1

    For I=0 To GACTLAB-1
        [M:SDP]FAMLAB(I) = mess(I+1,316,1)
    Next
    [M:SDP]FAMLAB(I) = mess(5,379,1)
    [M:SDP]NBLAB = GACTLAB+1

    Gosub ACTIVE_ZONES

Affzo [M:SDP]

Return

####################################
# REPARTIR : Répartit une différence de prix sur toutes les composantes non nulles
#    LDIFPRI = différence de prix
# Attention : la table ITMMASTER [ITM] est lue et est donc ouverte si nécessaire
####################################
$REPARTIR
Local Integer I
Local Decimal LREP, LDELTA, LVALMAX
Local Char    LZON1(GLONAVA+4) : Raz LZON1
Local Char    LZONMAX(GLONAVA+4) : Raz LZONMAX
Local Integer LBRDCOD : Raz LBRDCOD

# Si la somme des composantes n'est pas égale au prix total, on calcule la différence supplémentaire à appliquer

LSDPTOT = func SUBSDPCOM.SUMCST("SDP")
LDIFPRI += [M:SDP]PRI-LSDPTOT


    #------- MATIERE ---------#
    For I=0 To GACTMAT-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]MATCST(I)
            Raz [M:SDP]MATCST(I)
        Elsif [M:SDP]MATCST(I)<>0
            LDELTA = arr([M:SDP]MATCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]MATCST(I) += LDELTA
            If LZON1=""
                LZON1 = "MATCST("+num$(I)+")"
            Endif
        Endif
        If LZONMAX="" & [M:SDP]MATCST(I)>0 | LZONMAX<>"" & [M:SDP]MATCST(I)>LVALMAX
            LZONMAX="MATCST("+num$(I)+")"
            LVALMAX=[M:SDP]MATCST(I)
        Endif
        LREP += LDELTA
        Raz LDELTA
    Next
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVEMATCST
        Raz [M:SDP]OVEMATCST
    Elsif [M:SDP]OVEMATCST<>0
        LDELTA = arr([M:SDP]OVEMATCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVEMATCST += LDELTA
        If LZON1=""
            LZON1 = "OVEMATCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVEMATCST>0 | LZONMAX<>"" & [M:SDP]OVEMATCST>LVALMAX
        LZONMAX="OVEMATCST"
        LVALMAX=[M:SDP]OVEMATCST
    Endif
    LREP += LDELTA
    Raz LDELTA

    #------- MACHINE ---------#
    For I=0 To GACTMAC-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]MACCST(I)
            Raz [M:SDP]MACCST(I)
        Elsif [M:SDP]MACCST(I)<>0
            LDELTA = arr([M:SDP]MACCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]MACCST(I) += LDELTA
            If LZON1=""
                LZON1 = "MACCST("+num$(I)+")"
            Endif
        Endif
        LREP += LDELTA
        Raz LDELTA
        If LZONMAX="" & [M:SDP]MACCST(I)>0 | LZONMAX<>"" & [M:SDP]MACCST(I)>LVALMAX
            LZONMAX="MACCST("+num$(I)+")"
            LVALMAX=[M:SDP]MACCST(I)
        Endif
    Next
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVEMACCST
        Raz [M:SDP]OVEMACCST
    Elsif [M:SDP]OVEMACCST<>0
        LDELTA = arr([M:SDP]OVEMACCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVEMACCST += LDELTA
        If LZON1=""
            LZON1 = "OVEMACCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVEMACCST>0 | LZONMAX<>"" & [M:SDP]OVEMACCST>LVALMAX
        LZONMAX="OVEMACCST"
        LVALMAX=[M:SDP]OVEMACCST
    Endif
    LREP += LDELTA
    Raz LDELTA

    #------- MAIN D'OEUVRE ---------#
    For I=0 To GACTLAB-1
        If [M:SDP]PRI=0
            LDELTA = -[M:SDP]LABCST(I)
            Raz [M:SDP]LABCST(I)
        Elsif [M:SDP]LABCST(I)<>0
            LDELTA = arr([M:SDP]LABCST(I)*LDIFPRI/LSDPTOT,10^-GDECPRI)
            [M:SDP]LABCST(I) += LDELTA
            If LZON1=""
                LZON1 = "LABCST("+num$(I)+")"
            Endif
        Endif
        LREP += LDELTA
        Raz LDELTA
        If LZONMAX="" & [M:SDP]LABCST(I)>0 | LZONMAX<>"" & [M:SDP]LABCST(I)>LVALMAX
            LZONMAX="LABCST("+num$(I)+")"
            LVALMAX=[M:SDP]LABCST(I)
        Endif
    Next
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVELABCST
        Raz [M:SDP]OVELABCST
    Elsif [M:SDP]OVELABCST<>0
        LDELTA = arr([M:SDP]OVELABCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVELABCST += LDELTA
        If LZON1=""
            LZON1 = "OVELABCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVELABCST>0 | LZONMAX<>"" & [M:SDP]OVELABCST>LVALMAX
        LZONMAX="OVELABCST"
        LVALMAX=[M:SDP]OVELABCST
    Endif
    LREP += LDELTA
    Raz LDELTA


    #------- SOUS-TRAITANCE ---------#
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]SCOCST
        Raz [M:SDP]SCOCST
    Elsif [M:SDP]SCOCST<>0
        LDELTA = arr([M:SDP]SCOCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]SCOCST += LDELTA
        If LZON1=""
            LZON1 = "SCOCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]SCOCST>0 | LZONMAX<>"" & [M:SDP]SCOCST>LVALMAX
        LZONMAX="SCOCST"
        LVALMAX=[M:SDP]SCOCST
    Endif
    LREP += LDELTA

    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]OVESCOCST
        Raz [M:SDP]OVESCOCST
    Elsif [M:SDP]OVESCOCST<>0
        LDELTA = arr([M:SDP]OVESCOCST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]OVESCOCST += LDELTA
        If LZON1=""
            LZON1 = "OVESCOCST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]OVESCOCST>0 | LZONMAX<>"" & [M:SDP]OVESCOCST>LVALMAX
        LZONMAX="OVESCOCST"
        LVALMAX=[M:SDP]OVESCOCST
    Endif
    LREP += LDELTA

    #---------- Eléments de facturation -------------#
    Raz LDELTA
    If [M:SDP]PRI=0
        LDELTA = -[M:SDP]INVDTACST
        Raz [M:SDP]INVDTACST
    Elsif [M:SDP]INVDTACST<>0
        LDELTA = arr([M:SDP]INVDTACST*LDIFPRI/LSDPTOT,10^-GDECPRI)
        [M:SDP]INVDTACST += LDELTA
        If LZON1=""
            LZON1 = "INVDTACST"
        Endif
    Endif
    If LZONMAX="" & [M:SDP]INVDTACST>0 | LZONMAX<>"" & [M:SDP]INVDTACST>LVALMAX
        LZONMAX="INVDTACST"
        LVALMAX=[M:SDP]INVDTACST
    Endif
    LREP += LDELTA

    If LREP=0
        If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
        If [F:ITM]ITMREF<>[M:SDP]ITMREF
            Read [ITM]ITM0 = [M:SDP]ITMREF
        Endif
        LBRDCOD = [F:ITM]BRDCOD
        [M:SDP]MATCST(max(0,LBRDCOD-1)) += LDIFPRI
    Elsif LZONMAX<>"" & LREP<>LDIFPRI
        Assign "[M:SDP]"+LZONMAX With evalue("[M:SDP]"+LZONMAX)+(LDIFPRI-LREP)
    Endif

    Effzo [M:SDP]30
    If [M:SDP]OVEMATCST+[M:SDP]OVEMACCST+[M:SDP]OVELABCST+[M:SDP]OVESCOCST<>0
        [M:SDP]OVENAT(0) = "ZZZ"
        [M:SDP]ONATYP(0) = 2
        [M:SDP]ONAAMT(0) = [M:SDP]OVEMATCST+[M:SDP]OVEMACCST+[M:SDP]OVELABCST+[M:SDP]OVESCOCST
        [M:SDP]NBONA = 1
    Endif

Gosub CAL_TOT

Affzo [M:SDP]

Return

$ACT_OK
    If clalev([M:VALW])
        Gosub ENR
        Assign [M:VALW]ZONPRI+"(LLIGDOC)" With [M:SDP]MATTOT + [M:SDP]MACTOT + [M:SDP]LABTOT + [M:SDP]SCOTOT + [M:SDP]INVDTACST
        Assign [M:VALW]ZONPRIORD+"(LLIGDOC)" With [M:SDP]PRI
    Endif
    # Enregistrement du coût standard
    # (GPRIORI n'existe qu'en saisie du détail)
    If dim(GPRIORI)>0
        Case GPRIORI
            When "ICLD" :
                Raz [M:ICLD], [M:ITCD]
                # Issue X3-25085 - 2017-03-24 by ERMIL : Transmask function for performance enhancement
                #[M:ICLD] = [M:SDP]
                #[M:ITCD] = [M:SDP]
                Transmask [M:SDP] To [M:ICLD]
                Transmask [M:SDP] To [M:ITCD]
                Call ICLD2ICD From SUBITCB    # Affzo se fait après le chargement du graphique dans Affzonpri
        Endcase
    Endif

    Gosub AFFZONPRI From SUBSDPCOM
Return

####################################
$ENR
# On regarde si les composantes ont été modifiées manuellement
# (LMODIF existe uniquement en saisie dans SAIDECPRI)
If dim(LMODIF)>0 & clalev([M:VALW])
    Raz LMODIF
    If !LMODIF
        For I=0 To GACTMAT-1
            If [M:SDP]MATCST(I) <> [M:VALW]OMATCST(LLIGW*GACTMAT+I)
                LMODIF=1
                Break
            Endif
        Next
    Endif
    If !LMODIF
        For I=0 To GACTMAC-1
            If [M:SDP]MACCST(I) <> [M:VALW]OMACCST(LLIGW*GACTMAC+I)
                LMODIF=1
                Break
            Endif
        Next
    Endif
    If !LMODIF
        For I=0 To GACTLAB-1
            If [M:SDP]LABCST(I) <> [M:VALW]OLABCST(LLIGW*GACTLAB+I)
                LMODIF=1
                Break
            Endif
        Next
    Endif
    If !LMODIF
        If [M:SDP]SCOTOT <> [M:VALW]OSCOTOT(LLIGW)
            LMODIF=1
        Endif
    Endif
    If !LMODIF
        If [M:SDP]INVDTACST <> [M:VALW]OINVDTACST(LLIGW)
            LMODIF=1
        Endif
    Endif
    If !LMODIF
        If [M:SDP]OVEMATCST <> [M:VALW]OOVEMATCST(LLIGW)
&        | [M:SDP]OVEMACCST <> [M:VALW]OOVEMACCST(LLIGW)
&        | [M:SDP]OVELABCST <> [M:VALW]OOVELABCST(LLIGW)
&        | [M:SDP]OVESCOCST <> [M:VALW]OOVESCOCST(LLIGW)
            LMODIF=1
        Endif
    Endif
Endif

Call COPSDP2VALW(LLIGW,"VALW","SDP") From SUBSDPCOM

Return

######################################################################################
Subprog C_NBONA
Local Integer I
    If find(status,65,68,83)
        For I=nolign-1 To max(nolign,nolign1)-1
            [M:SDP]ONAAMT(I) = 0
        Next
#        If nolign1-nolign+1>=[M:SDP]NBONA
#            [M:SDP]NBONA=0
#        Endif
        Gosub CAL_TOT
        Gosub REFRESH
    Endif
End

######################################################################################
Subprog APRES_NBONA
Gosub CAL_TOT
Gosub REFRESH
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran SAIDECPRI) 13/09/2006 17:40:36 (CCC)
######################################################################################
Subprog AS_ONATYP(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
If mod(GAFFMSK,2)=1     : End          : Endif    # Tout saisissable
If mod(GAFFMSK,8)<4     : GMENLOC(2)=1 : Endif    # Saisie matière
If mod(GAFFMSK,16)<8    : GMENLOC(3)=1 : Endif    # Saisie machine
If mod(GAFFMSK,32)<16   : GMENLOC(4)=1 : Endif    # Saisie main d'oeuvre
If mod(GAFFMSK,64)<32   : GMENLOC(5)=1 : Endif    # Saisie sous-traitance
End


######################################################################################

######################################################################################
Subprog IB_NBONA
# En affichage des FG on ne peut pas les calculer
# Ils ne sont calculables que poiur un type de mouvement donné
If !(mod(GAFFMSK,2)=1 | mod(GAFFMSK,256)=128) | [M]TRSTYP=0
    Raz GBOUT2
Endif
End
######################################################################################
Subprog B2_NBONA

Local Integer I, LRET
Local Decimal LBASQTY, LBASAMT

If func STKVALPAR.WITHOVE([M]TRSTYP,-1)
    If !clalev ([F:OVE]) : Local File OVERHEAD [OVE] : Endif
    Call LECOVE([M]ITMREF, [M]STOFCY, [M]TRSTYP, LRET) From STKVAL
Else
    End
Endif

Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))

    If !LRET
        Raz [M]OVEMATCST, [M]OVEMACCST, [M]OVELABCST, [M]OVESCOCST
        Effzo [M:SDP]30

        Gosub CAL_TOT

        LBASQTY=[M]QTY
        LBASAMT=[M]AMTTOT-[M]INVDTACST*[M]QTY

        # Issue 100192 - 2014-06-23 by CCC
        GPOINT = "BASFGSDP"
        Gosub ENTREE From EXEFNC

        Call CALOVELIN([M]ITMREF, [M]STOFCY, [M]TRSTYP, 0, "", 0, 0, LBASQTY, LBASAMT, "", LTABNAT, LTABTYP, LTABFXD, LTABVAR, LRET) From STKVAL

        If LRET : End : Endif

        For I=0 To dim(LTABNAT)-1
            If LTABNAT(I)=""
                Break
            Endif
            If [M]NBONA=dim([M]OVENAT)
                Break
            Endif
            [M]OVENAT  ([M]NBONA) = LTABNAT(I)
            [M]ONAAMT  ([M]NBONA) = LTABFXD(I)+LTABVAR(I)
            [M]ONATYP  ([M]NBONA) = LTABTYP(I)
            # Somme des ONAAMT en fonction des types de nature (Le type de nature "selon contexte" alimente les FG matière)
            Case [M]ONATYP([M]NBONA)
                When 1,2 : [M]OVEMATCST += [M]ONAAMT([M]NBONA)
                When 3   : [M]OVEMACCST += [M]ONAAMT([M]NBONA)
                When 4   : [M]OVELABCST += [M]ONAAMT([M]NBONA)
                When 5   : [M]OVESCOCST += [M]ONAAMT([M]NBONA)
            Endcase
            [M]NBONA +=1
        Next
        #----- Calcul du prix unitaire des FG
        # Somme des ONAAMT pour WSTOSEQ=PWSTOSEQ en fonction des types de nature (Le type de nature "selon contexte" alimente les FG matière)
        # LIND1 = indice de la 1ère ligne de nature renseignée pour ce WSTOSEQ
        [M]OVEMATCST /= [M]QTY
        [M]OVEMACCST /= [M]QTY
        [M]OVELABCST /= [M]QTY
        [M]OVESCOCST /= [M]QTY

        [M:SDP]PRISAI = GPRISAIAUT

        Gosub CAL_TOT
        Gosub REFRESH
    Endif
End

######################################################################################

$ACTIVE_ZONES
    If mod(GAFFMSK,2)=0    # Si tout n'est pas saisissable...
        If mod(GAFFMSK,4)>=2    # Affichage uniquement
            Diszo [M:SDP]     # Pas de saisie
        Else
            If sum([M:SDP]ONAAMT)>0
                Diszo [M:SDP]OVEMATCST,OVEMACCST,OVELABCST,OVESCOCST
            Else
                Actzo [M:SDP]OVEMATCST,OVEMACCST,OVELABCST,OVESCOCST
            Endif
            If mod(GAFFMSK,8)<4     : Diszo [M:SDP]MATCST, OVEMATCST : Endif    # Saisie matière
            If mod(GAFFMSK,16)<8    : Diszo [M:SDP]MACCST, OVEMACCST : Endif    # Saisie machine
            If mod(GAFFMSK,32)<16   : Diszo [M:SDP]LABCST, OVELABCST : Endif    # Saisie main d'oeuvre
            If mod(GAFFMSK,64)<32   : Diszo [M:SDP]SCOTOT, OVESCOCST : Endif    # Saisie sous-traitance
            If mod(GAFFMSK,128)<64  : Diszo [M:SDP]OVEMATCST, OVEMACCST, OVELABCST, OVESCOCST
                                      Diszo [M:SDP]30     : Endif    # Frais généraux
            If mod(GAFFMSK,256)<128 : Diszo [M:SDP]30     : Endif    # Natures frais généraux
            If mod(GAFFMSK,512)<256 : Diszo [M:SDP]INVDTACST : Endif    # Eléments de facture

        Endif
    Else    # Tout est saisissable
        If sum([M:SDP]ONAAMT)>0
            Diszo [M:SDP]OVEMATCST,OVEMACCST,OVELABCST,OVESCOCST
        Else
            Actzo [M:SDP]OVEMATCST,OVEMACCST,OVELABCST,OVESCOCST
        Endif
    Endif

    If !find(GPRIORI,"STD","STDL", "ACT", "ACTL")
        Grizo [M:SDP]BTNNIV
    Else
        Actzo [M:SDP]BTNNIV
    Endif

Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran SAIDECPRI) 15/11/2006 17:34:06 (CCC)
######################################################################################
Subprog AM_OVEMATCST(VALEUR)
Variable Decimal VALEUR
Local Integer I

Call AMOVECST(2,VALEUR)
End

Subprog AM_OVESCOCST(VALEUR)
Variable Decimal VALEUR
Call AMOVECST(5,VALEUR)
End

Subprog AM_OVEMACCST(VALEUR)
Variable Decimal VALEUR
Call AMOVECST(3,VALEUR)
End

Subprog AM_OVELABCST(VALEUR)
Variable Decimal VALEUR
Call AMOVECST(4,VALEUR)
End

Subprog AMOVECST(PTYP,PVAL)
Value Integer PTYP
Value Integer PVAL

Local Integer I

I= sigma(0,[M:SDP]NBONA-1,(indcum+1)*([M:SDP]OVENAT(indcum)="ZZZ" & [M:SDP]ONATYP(indcum)=PTYP & I=0 & sigma(I=1,1,1)))-1
If I>=0
    [M:SDP]ONAAMT(I) = PVAL
Else
    [M:SDP]ONATYP([M:SDP]NBONA) = PTYP
    [M:SDP]OVENAT([M:SDP]NBONA) = "ZZZ"
    [M:SDP]ONAAMT([M:SDP]NBONA) = PVAL
    [M:SDP]NBONA+=1
Endif

End
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SAIDECPRI) 16/06/2008 11:38:19 (CCC)
######################################################################################
Subprog CL_BTNNIV(VALEUR)
Variable Char    VALEUR()

Local Integer  LVCRTYP

    Effzo [M:SDP]10-99

    If [M:SDP]NIV=2
        VALEUR="81"
        [M:SDP]NIV=1
        GPRIORI = GPRIORI+"L"
    Else
        VALEUR="80"
        [M:SDP]NIV=2
        GPRIORI = left$(GPRIORI,3)
    Endif

    Gosub CHARGE_PARAM From SUBSDPCOM
    # Calculs des totaux
    Gosub CAL_TOT

    # Recalcule les % et diszone les champs nécessaire
    Gosub REFRESH

    Affzo [M:SDP]1-99
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SAIDECPRI) 03/07/2008 15:41:56 (CCC)
######################################################################################
Subprog AM_OVENAT(VALEUR)
Variable Char    VALEUR()
Read [ONA]ONA0=VALEUR
[M:SDP]ONATYP(nolign-1)=[F:ONA]TYPCST
End

