##########################################################################################################
Subprog AVANT_NBLIG

Local Integer INOL
Local Integer GMANCOU12      # FGR 13/10/2015 : X3SUIVI111665

  INOL = nolign-1
  Call READ_COUNTER([M:SRE0]SALFCY, 12, 11, GSOCIETE, GCURLEG, GSR2CSRECPT, GMANCOU12) From CRM_UTIL    # FGR 23/07/2015 : X3SUIVI109755
  Call LOADTOTPIT(0) From SUBSREB1
  Call LOADTOTHDT(1) From SUBSREB1
  # Sortie de stock
  Call INIZONSOR("SRE9", [M:SRE9]HDTITM(nolign-1), [M:SRE9]HDTSTOFCY(nolign-1), INOL, 24, [M:SRE0]TRSCOD , "") From STKECR
End

##########################################################################################################
Subprog APRES_NBLIG

  Call LOADTOTPIT(1) From SUBSREB1
  Call LOADTOTHDT(1) From SUBSREB1
  Grizo [M:SRE8]SRECUR
  Grizo [M:SRE0]SALFCY
  Grizo [M:SRE7]TYPMAC
  Grizo [M:SRE7]MACFLT
  Grizo [M:SRE7]MACFLTINT
  Affzo [M:SRE7]TYPMAC, MACFLT, MACFLTINT
End

