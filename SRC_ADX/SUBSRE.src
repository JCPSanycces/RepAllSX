Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()

Local Integer AXE

  AXE=20
  Gosub C_CCEX
End

##########################################################################################################
$D_CCEX

  #------------------------------------#
  # Initialisation commune aux 20 axes #
  #------------------------------------#
  If AXE > GNBDIE Then
    Return
  Endif
  Call INIT_CCE(VALEUR,AXE,"HDT","",0) From TRTX3CPT
Return

##########################################################################################################
$AS_CCEX

  #----------------------------------#
  # Avant saisie commune aux 20 axes #
  #----------------------------------#
  Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

##########################################################################################################
$C_CCEX

  #-----------------------------#
  # Contrôle commun aux 20 axes #
  #-----------------------------#
  Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SRE1]CREDAT) From TRTX3CPT
Return

