##########################################################################################################
Subprog IB_SRENUM

  Raz GBOUT4
  #Raz GBOUT6  # FGR 16/06/2015 : X3SUIVI108602
  #Recherche par chrono client.
  If GREP = "" Then
    GBOUT4 = mess(252,182,1)
  Endif
  Raz GBOUT5

Local Integer IFUNOPEN

  IFUNOPEN = 0
  Call ISFUNOPEN("GESITN", IFUNOPEN) From CRMUTIL140
  If IFUNOPEN Then
    End
  Endif

  #Interventions / demande
  If GREP = "" Then
    GBOUT5 = mess(239,182,1)
    #---------------------------------------------------#
    #Définit la clé Intervention pour les tunnels sur interventions.
    #---------------------------------------------------#
    GLASITN = ""
    Filter [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM Order By [F:ITN]DATX Desc
    For [ITN] Hint Key ITN1
      GLASITN = [F:ITN]NUM
      Break
    Next
    Filter [ITN]
    [M:SRE7]SRENAVTYP = "SRE"
  Endif
  #Envoi de la demande par E-Mail
  # FGR 16/06/2015 : X3SUIVI108602 (début)
  #  If GBROWS Then
  #    End
  #  Endif
  #  If GREP <> "" Then
  #    End
  #  Endif
  #  If [M:SRE0]SRENUM = "" Then
  #    End
  #  Endif
  #  Read [DVA]DVA0="OXP";"HTMLEMAIL"
  #  If fstat Then
  #    End
  #  Endif
  #  #Envoyer la demande par E-Mail
  #  GBOUT6 = mess(93,177,1)
  # FGR 16/06/2015 : X3SUIVI108602 (fin)
End

##########################################################################################################
Subprog B2_NBMAC

  Call MNGHORO([M:SRE0]SRENUM, 1, [M:SRE7]MAC(nolign-1)) From SUBSREB1
End

##########################################################################################################
Subprog C_SRENUMBPC(VALEUR)
Variable Char    VALEUR()

  #Vérifie si un chrono client identique à déjà saisi pour le même client.
  If VALEUR <> "" Then
    If [M:SRE0]SRENUM = "" Then
      Filter [SRE] Where [F:SRE]SREBPC = [M:SRE0]SREBPC and [F:SRE]SRENUMBPC = VALEUR
    Else
      Filter [SRE] Where [F:SRE]SREBPC = [M:SRE0]SREBPC and [F:SRE]SRENUMBPC = VALEUR and [F:SRE]SRENUM <> [M:SRE0]SRENUM
    Endif
    For [SRE]SRE5
      #Un chrono client identique identifie déjà une autre demande pour ce même client. Saisie refusée.
      GMESSAGE = mess(253,182,1)
      GERR = 1
      mkstat = 2
      Break
    Next
    Filter [SRE]
  Endif
End

##########################################################################################################
Subprog IB_SRENUMBPC

  Raz GBOUT1
  #Proposer un chrono client
  If [M:SRE0]SRENUMBPC = "" Then
    If [M:SRE0]SREBPC <> "" Then
      GBOUT1 = mess(254,182,1)
    Endif
  Endif
End

##########################################################################################################
Subprog B1_SRENUMBPC(VALEUR)
Variable Char    VALEUR()

  Gosub SUBB1_SRENUMBPC From SUBSREB3
  [M:SRE0]SRENUMBPC = ""
  #Enregistre le chrono sur la demande de service
  If GREP = "" Then
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    Readlock [SRE]SRE0=[M:SRE0]SRENUM
    If fstat Then
      #Erreur lors de la génération du chrono client.
      GMESSAGE = mess(255,182,1)
      GERR = 1
      Rollback
      Unlock [SRE]
      End
    Else
      [F:SRE]SRENUMBPC = SZCHRONO
      Rewrite [SRE]
      If fstat Then
        #Erreur lors de la génération du chrono client.
        GMESSAGE = mess(255,182,1)
        GERR = 1
        Rollback
        Unlock [SRE]
        End
      Else
        Commit
        Unlock [SRE]
        [M:SRE0]SRENUMBPC = SZCHRONO
      Endif
    Endif
  Else
    [M:SRE0]SRENUMBPC = SZCHRONO
  Endif
  Affzo [M:SRE0]SRENUMBPC
End

##########################################################################################################
Subprog IB_MACFLT

  Raz GBOUT1
  Raz GBOUT2
  Call TEXTE(19061, GBOUT1) From OBJDIV      #Ciblages
  If [M:SRE7]MACFLT <> "" Then
    Read [MQR]MQR0=[M:SRE7]MACFLT
    If !fstat Then
      If [F:MQR]QURNAM = "" Then
        Call TEXTE(6425, GBOUT2) From OBJDIV      #Critères
      Else
        GBOUT2 = [F:MQR]QURNAM
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_MACFLT(VALEUR)
Variable Char    VALEUR()

Local Integer OK

  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    End
  Endif
  #La modification de la couverture globale fait rentrer en modification
  #On anticipe donc le contrôle de verrouillage de la demande effectué en principe dans l'AVANT_MOD
  If GREP = "" Then
    OK = 1
    [M:SRE0]PREUPDFLG = 0
    Gosub AVANT_MOD From SUBSREA
    [M:SRE0]PREUPDFLG = 1
    If OK = 0 Then
      mkstat = 2
      End
    Endif
  Endif
  Read [MQR]MQR0=VALEUR
  If fstat Then
    #Ce code ne correspond à aucun ciblage existant. Saisie refusée.
    GMESSAGE = mess(258,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

