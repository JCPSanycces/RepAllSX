End

##########################################################################################################
Subprog IB_SRECCN

  If [M:SRE0]SREBPC = "" Then
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog B4_NBLIG

  If [M:SRE9]ITNNUM(nolign-1) = "" Then
    GBCRMFLGNEW = 1
  Endif
  ## Action GOBJETC1
Local Char    PARMSK(250)(1..20) , SAVACT(20)

  SAVACT = GACTION : GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:SRE9]ITNNUM(nolign-1),"ITN","") From GOBJET
  GACTION = SAVACT
End

##########################################################################################################
# FGR 07/07/2008 : X3SUIVI48011 (DEBUT)
##########################################################################################################
##########################################################################################################
Subprog IB_NBINV

  Raz GBOUT1
  If [M:SREF]INVVCR(nolign-1) <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
  Endif
End

##########################################################################################################
Subprog AS_NBINV

  If nolign > 0 Then
    If nolign < dim([M:SREF]INVVCR)-1 Then
      If GSZINVNUM <> [M:SREF]INVVCR(nolign-1) Then
        GSZINVNUM = [M:SREF]INVVCR(nolign-1)
        Call LOADECHE(GSZINVNUM) From SUBSREB1
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_NBINV

  If nolign > 0 Then
    If nolign < dim([M:SREF]INVVCR)-1 Then
      If GSZINVNUM <> [M:SREF]INVVCR(nolign-1) Then
        GSZINVNUM = [M:SREF]INVVCR(nolign-1)
        Call LOADECHE(GSZINVNUM) From SUBSREB1
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_NBDUD

  If nolign > 0 Then
    Call LOADPAY(GSZINVNUM) From SUBSREB1
  Endif
End

##########################################################################################################
Subprog C_NBDUD

  If nolign > 0 Then
    Call LOADPAY(GSZINVNUM) From SUBSREB1
  Endif
End

##########################################################################################################
Subprog IB_NBPAY

  Raz GBOUT1
  If [M:SREF]PAYNUM(nolign-1) <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
  Endif
End
##########################################################################################################
# FGR 07/07/2008 : X3SUIVI48011 (FIN)
##########################################################################################################

######################################################################################
Subprog IB_NBCPN
  Call IB_NOTECHECK([M:SRE7]CPNITM(nolign-1),"ITM",4)  From TRTNTSCTL # CRM notes
End

######################################################################################
Subprog AV_SFISSTCOD(VALEUR)
Variable Char    VALEUR()

  # 101380 - Do not alow updating of SST code for certain cases.
  # See SUBSFIT for setting of override flag.
  If [M:SRE8]SFISSTOVRFLG(nolign-1) = 1 Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Integer NOL

  # FGR 10/04/2015 : X3SUIVI105605
  NOL = nolign-1
  Call CTLECCVAL(VALEUR, [M:SRE9]HDTSTOFCY(NOL), [M:SRE9]HDTITM(NOL), 4, "", [M:SRE1]CREDAT, LRET) From STKSOR
  If LRET >= 1 Then
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

  # FGR 10/04/2015 : X3SUIVI105605
  Raz WECCVALMAJ
  Raz WECCVALMIN
  Raz PITM
  # si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:SRE9]HDTITM(nolign-1) Then
    Read [ITM]ITM0=[M:SRE9]HDTITM(nolign-1)
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:SRE9]ECCVALMIN(nolign-1) = WECCVALMIN
    Affzo [M:SRE9]ECCVALMIN(nolign-1)
  Elsif VALEUR = "" and [M:SRE9]ECCVALMIN(nolign-1) <> "" Then
    Raz [M:SRE9]ECCVALMIN(nolign-1)
    Affzo [M:SRE9]ECCVALMIN(nolign-1)
  Endif
End

##########################################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

##########################################################################################################
$ECCVALMAJMIN_ENABLE
  # FGR 01/04/2015 : X3SUIVI105605
  If [M:SRE9]HDTTYP(nolign-1) <> 2 Then
    mkstat = 2
  Endif
  If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
    mkstat = 2
  Endif
Return

