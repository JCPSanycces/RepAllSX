##########################################################################################################
Subprog AM_MACDEF(VALEUR)
Variable Integer VALEUR

Local Integer ITER

  If VALEUR = 2 Then
    [M:SRE0]SREMAC = [M:SRE7]MAC(nolign-1)
    For ITER = 0 To [M:SRE7]NBMAC(ITER)-1
      [M:SRE7]MACDEF(ITER) = 1
    Next
  Endif
  [M:SRE7]MACDEF(nolign-1) = VALEUR
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE7]1-99
End

