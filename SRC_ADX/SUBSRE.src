##########################################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

  #LSE 01/03/2005 gestion des sites
  If [M:SRE0]SREBPC = "" or [M:SRE0]SALFCY = "" or VALEUR = "" Then
    Grizo [M:SRE9]5
  Else
    Actzo [M:SRE9]5
  Endif
End
