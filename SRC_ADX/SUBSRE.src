##########################################################################################################
Subprog C_TYPMAC(VALEUR)
Variable Integer VALEUR

Local Integer OK

  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    End
  Endif
  #La modification de la couverture globale fait rentrer en modification
  #On anticipe donc le contrôle de verrouillage de la demande effectué en principe dans l'AVANT_MOD
  If GREP = "" Then
    OK = 1
    [M:SRE0]PREUPDFLG = 0
    Gosub AVANT_MOD From SUBSREA
    [M:SRE0]PREUPDFLG = 1
    If OK = 0 Then
      mkstat = 2
      End
    Endif
  Endif
  If [M:SRE7]NBMAC = 0
    End
  Endif

Local Char SZMESS(250)
Local Integer IASK

  SZMESS = mess(289,182,1) + " " + mess(290,182,1)
  IASK = 0
  If VALEUR <> [M:SRE7]TYPMAC Then
    Call OUINON(SZMESS, IASK) From GESECRAN
    If IASK <> 2 Then
      GMESSAGE = mess(291,182,1) #Modification abandonnée.
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TYPMAC(VALEUR)
Variable Integer VALEUR

Local Integer INOL
Local Integer INOL2

  If [M:SRE7]NBMAC > 0 Then
    INOL = 0
    INOL2 = [M:SRE7]NBMAC - 1
    Gosub DELMACLINES From SUBSREB4
    Call RAZMAC From SUBSREB2
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE9]1-99
  Endif
  #Call RAZMAC From SUBSREB2
  If VALEUR = 2 Then
    Actzo [M:SRE7]MACFLT
    Actzo [M:SRE7]MACFLTINT
    [M:SRE7]MACFLTINT = 2
  Else
    [M:SRE7]MACFLT = ""
    [M:SRE7]MACFLTINT = 2
    Grizo [M:SRE7]MACFLT
    Grizo [M:SRE7]MACFLTINT
  Endif
  [M:SRE7]TYPMAC = VALEUR
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE7]1-99
End

##########################################################################################################
Subprog IB_COVVCR
Local Char SZBPCNAM(GLONNAM)
Local Integer ITISOK

  SZBPCNAM = ""
  ITISOK = 0
  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT3
  Raz GBOUT4
  Raz GBOUT5
  Raz GBOUT6
  If [M:SRE0]SREBPC <> "" Then
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      ITISOK = 0
    Else
      ITISOK = 1
      SZBPCNAM = [F:BPR]BPRNAM
    Endif
    If [M:SRE7]COVSPT(nolign-1) = 1 Then
      #Couvert par contrat de service.
      If ITISOK Then
        GBOUT1 = mess(302,196,1) - SZBPCNAM #Contrats de XXXX
      Else
        GBOUT1 = mess(293,196,1) #Contrats de service
      Endif
    Elsif [M:SRE7]COVSPT(nolign-1) = 2 Then
      #Couvert par commande client.
      If ITISOK Then
        GBOUT2 = mess(303,196,1) - SZBPCNAM #Commandes de XXXX
      Else
        GBOUT2 = mess(75,191,1) #Sélection commandes
      Endif
    Elsif [M:SRE7]COVSPT(nolign-1) = 5 Then
      #Couvert par contrat de prêt.
      GBOUT3 = mess(503,182,1) #Contrats de prêt
    Endif
  Endif
  If [M:SRE7]COVVCR(nolign-1) <> "" Then
    Case [M:SRE7]COVSPT(nolign-1)
      When 1
        GBOUT4 = mess(279,196,1) #Contrat de service
      When 2
        GBOUT5 = mess(10,159, 1) #Commande
      When 5
        GBOUT6 = mess(502,182,1) #Contrat de prêt
    Endcase
  Endif
End

