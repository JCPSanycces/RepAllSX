##########################################################################################################
Subprog IB_TOTPIT

  Raz GBOUT1
  If GREP = "" Then
    If [M:SRE2]SREASS <> 5 Then
      If [M:SRE2]SREASS <> 4 Then
        If [M:SRE2]SRECOVNUM <> "" Then
          Read [CON]CON0=[M:SRE2]SRECOVNUM
          If !fstat Then
            If [F:CON]CONCAT = 4 Then
              #Débit manuel de points
              GBOUT1 = mess(530,182,1)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTCPN(VALEUR)
Variable Char    VALEUR()

  If [M:SRE9]HDTMACSRE(nolign-1) = "" Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_HDTMACSRE(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

  IERRINF = 0
  Read [MAC]MAC0 = VALEUR
  If fstat Then
    [M:SRE9]HDTMACSET(nolign-1) = ""
  Else
    [M:SRE9]HDTMACSET(nolign-1) = [F:MAC]MACPDTCOD
  Endif
  [M:SRE9]HDTMACSRE(nolign-1) = VALEUR
  #Détermination du montant facturable par défaut
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), [M:SRE9]PITHDT(nolign-1), [M:SRE9]INVPITFLG(nolign-1), IERRINF) From TRTAMOUNT
  Else
    IPITHDT = 0
    IINVPITFLG = 0
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
  Endif
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
  Endif
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:SRE9]HDTMACSRE(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1), PITHDT(nolign-1)
  Affzo [M:SRE9]HDTMACSRE(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:SRE9]PITHDT(nolign-1)
  Endif
End

##########################################################################################################
Subprog AM_HDTCPN(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : ça manquait # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

  IERRINF = 0
  [M:SRE9]HDTCPN(nolign-1) = VALEUR
  #Détermination du montant facturable par défaut
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), [M:SRE9]PITHDT(nolign-1), [M:SRE9]INVPITFLG(nolign-1), IERRINF) From TRTAMOUNT
  Else
    IPITHDT = 0
    IINVPITFLG = 0
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
  Endif
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
  Endif
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:SRE9]HDTCPN(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1), PITHDT(nolign-1)
  Affzo [M:SRE9]HDTCPN(nolign-1), HDTINV(nolign-1), HDTAMT(nolign-1), HDTAMTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:SRE9]PITHDT(nolign-1)
  Endif
End

##########################################################################################################
Subprog AM_HDTINV(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:SRE9]HDTAMTINV(nolign-1) <= 0 Then
      [M:SRE9]HDTAMTINV(nolign-1) = [M:SRE9]HDTAMT(nolign-1)
    Endif
  Else
    [M:SRE9]HDTAMTINV(nolign-1) = 0
  Endif
  [M:SRE9]HDTINV(nolign-1) = VALEUR
  Affzo [M:SRE9]HDTINV(nolign-1), HDTAMTINV(nolign-1)
  Call SET_HDTAMTINV_ENABLE_DISABLE([M:SRE9]HDTINV(nolign-1), nolign-1) From SUBSREA     # Issue SAM120376 - 2017-01-09 by FGR
End

