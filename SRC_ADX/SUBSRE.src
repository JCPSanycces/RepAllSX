##########################################################################################################
Subprog AM_HDTTEX(VALEUR)
Variable Char    VALEUR()

  If [M:SRE9]HDTNUM(nolign-1) = "" Then
    If [M:SRE9]HDTNUMSEQ(nolign-1) <> "" Then
      Read [HD7]HD70=[M:SRE9]HDTNUMSEQ(nolign-1);"HDTSEQ";adxuid(1)
      If !fstat Then
        #Ce texte est complété par un texte plus long dans la saisie du texte associé à cette consommation.
        # Saisie refusée.
        GMESSAGE = mess(910,182,1)
        GERR = 2
        VALEUR = [M:SRE9]HDTTEX(nolign-1)
      Endif
    Endif
  Else
    Read [HD7]HD70=[M:SRE9]HDTNUM(nolign-1);"HDT";adxuid(1)
    If !fstat Then
      #Ce texte est complété par un texte plus long dans la saisie du texte associé à cette consommation. Saisie refusée.
      GMESSAGE = mess(910,182,1)
      GERR = 2
      VALEUR = [M:SRE9]HDTTEX(nolign-1)
    Endif
  Endif
  If GERR = 0 Then
    If [M:SRE9]HDTSALTEX(nolign-1) <> "" Then
      Read [TXC]TXC0=[M:SRE9]HDTSALTEX(nolign-1)
      If !fstat Then
        #Ce texte est complété par un texte plus long dans la saisie du texte associé à cette consommation.
        # Saisie refusée.
        GMESSAGE = mess(910,182,1)
        GERR = 2
        VALEUR = [M:SRE9]HDTTEX(nolign-1)
      Endif
    Endif
  Endif
  [M:SRE9]HDTTEX(nolign-1) = VALEUR
  Affzo [M:SRE9]HDTTEX(nolign-1)
End

##########################################################################################################
Subprog IB_SREESCNUM

  Raz GBOUT1
  Gosub LOADESC From SUBSREB3
  If [M:SRE2]SREESCNUM <> "" Then
    If [M:SRE2]SREESCCOD <> "" Then
      Call TEXTE(14520, GBOUT1) From OBJDIV      #Escalade
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SRENUM(VALEUR)
Variable Char    VALEUR()

  If GREP = "" Then          # Issue X3-41593 - 2017-10-13 by FGR
    If VALEUR <> "" Then
      Read [SRE]SRE0=VALEUR
      If !fstat Then
        [M:SRE0]SRENUM = VALEUR
        [M:SRE0]LKP5SEAFLG = 0
        Affzo [M:SRE0]SRENUM
        End
      Endif
    Endif
    If ![M:SRE0]LKP5SEAFLG Then
      VALEUR = ""
    Endif
    [M:SRE0]SRENUM = VALEUR
    [M:SRE0]LKP5SEAFLG = 0
    Affzo [M:SRE0]SRENUM
  Endif
End

##########################################################################################################
Subprog C_MACFLTINT(VALEUR)
Variable Integer VALEUR

Local Integer OK

  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    End
  Endif
  #La modification de la couverture globale fait rentrer en modification
  #On anticipe donc le contrôle de verrouillage de la demande effectué en principe dans l'AVANT_MOD
  If GREP = "" Then
    OK = 1
    [M:SRE0]PREUPDFLG = 0
    Gosub AVANT_MOD From SUBSREA
    [M:SRE0]PREUPDFLG = 1
    If OK = 0
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AS_NBLIG

  #Recalcul des consommations après suppression d'une ou plusieurs consommations
  If [M:SRE0]DELSRE9FLG = 1 Then
    [M:SRE0]DELSRE9FLG = 0
    Gosub RECPTAMT From SUBSREB4
  Endif
End

##########################################################################################################
Subprog C_HDTQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal QTY_UV  # FGR 26/05/2010 : X3SUIVI64914

  If VALEUR <= 0 Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    If [M:SRE9]HDTITM(nolign-1) <> "" Then
      If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
            # FGR 26/05/2010 : X3SUIVI64914 (début)
            If [M:SRE9]HDTUOM(nolign-1) <> [F:ITM]STU Then
              Call SCAL_QUV([M:SRE9]HDTISSISS(nolign-1), [M:SRE9]HDTITM(nolign-1), "", [F:ITM]STU, [M:SRE9]HDTUOM(nolign-1), QTY_UV, GBIDD1) From TRTVENQTE
            Else
              QTY_UV = [M:SRE9]HDTISSISS(nolign-1)
            Endif
            # FGR 26/05/2010 : X3SUIVI64914 (fin)
            #If VALEUR < [M:SRE9]HDTISSISS(nolign-1) Then    # FGR 26/05/2010 : X3SUIVI64914
            If VALEUR < QTY_UV Then                          # FGR 26/05/2010 : X3SUIVI64914
              #La quantité consommée ne peut pas être inférieure à la quantité sortie de stock.
              GMESSAGE = mess(170,177,1)
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
          If GSRE9HDTISSISS(nolign-1) > 0 Then
            # FGR 26/05/2010 : X3SUIVI64914 (début)
            If [M:SRE9]HDTUOM(nolign-1) <> [F:ITM]STU Then
              Call SCAL_QUV(GSRE9HDTISSISS(nolign-1), [M:SRE9]HDTITM(nolign-1), "", [F:ITM]STU, [M:SRE9]HDTUOM(nolign-1), QTY_UV, GBIDD1) From TRTVENQTE
            Else
              QTY_UV = GSRE9HDTISSISS(nolign-1)
            Endif
            # FGR 26/05/2010 : X3SUIVI64914 (fin)
            #If VALEUR < GSRE9HDTISSISS(nolign-1) Then       # FGR 26/05/2010 : X3SUIVI64914
            If VALEUR < QTY_UV Then                          # FGR 26/05/2010 : X3SUIVI64914
              #La quantité consommée ne peut pas être inférieure à la quantité sortie de stock.
              GMESSAGE = mess(170,177,1)
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_HDTUOM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_HDTAMTINV(VALEUR)
Variable Decimal VALEUR

Local Integer IONREP

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    If VALEUR > 0 and [M:SRE9]INVPITFLG(nolign-1) > 0 Then
      #Cette consommation est facturée à travers un débit de points. Saisie refusée.
      GMESSAGE = mess(16,177,1)
      GERR = 2
      mkstat = 2
      End
    Elsif [M:SRE9]HDTINV(nolign-1) = 2 and VALEUR = 0 and [M:SRE9]INVPITFLG(nolign-1) = 0 Then
      # FGR 27/03/2009 : X3SUIVI53964 : Prix nul en demande de service facturable
      IONREP = 2 # Note FGR : initialisé à 2, ça permet de ne rien dire en import, ça accepte
      Call AVERTIR(mess(62,194,1), IONREP) From GESECRAN
      If IONREP <> 2 Then
        mkstat = 2
        End
      Endif
    Endif
  Else
    If [M:SRE9]HDTINV(nolign-1) = 2 and VALEUR = 0 Then
      # FGR 27/03/2009 : X3SUIVI53964 : Prix nul en demande de service facturable
      IONREP = 2 # Note FGR : initialisé à 2, ça permet de ne rien dire en import, ça accepte
      Call AVERTIR(mess(62,194,1), IONREP) From GESECRAN
      If IONREP <> 2 Then
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Integer IMUSTASK
Local Char    WPLISTC # Issue 111465 - 2015-10-02 by CPO

  If GFCY <> VALEUR Then
    GFCY = VALEUR
    Call INIT_GLOBAL_CPT(VALEUR,"HTR",2,GHDKTRSSRE) From TRTX3CPT
    # V6.2 : Certification
    # --- Contrôle date documents
    Call LOAD_GCTLDATORI() From CRMUTIL150  # FGR 25/01/2012 : X3SUIVI78765
    #Local  Char     PARAM(GLONADP)
    #Call PARAM(GFCY,"CTLDATORI",PARAM)    From ADOVAL
    #GCTLDATORI=val(PARAM)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
  Endif
  Gosub CHARG_PARAM From SUBSREA # FGR 26/07/2013 : X3SUIVI87923 (fin)
  #On demande si le site de stockage doit être identique au site en en-tête.
  If VALEUR = "" Then
    End
  Endif
  # Issue 111000 - 2015-09-15 by CPO : Structures tarifaires et tarification consommations sur inte
  #-- !!!!! La devise ne doit surtout pas être renseignée, sinon plantage       !!!!!
  #-- !!!!! The currency is not to be filled, if not, it will raise an error !!!!!
  #-- ALICOLREM it's used mostly for sales/purchase documents
  Call ALICOLREM (1,0,"","SRE9", "", 1,WPLISTC) From TRTPRICE
  # End issue 111000
  #----- Affichage entêtes de colonnes variables -----
  Gosub AFF_TITCOL From SUBSREB1
  #LSE 01/03/2005 gestion des sites
  If [M:SRE0]SREBPC = "" or VALEUR = "" or [M:SRE8]STOFCY = "" Then
    Grizo [M:SRE9]5
  Else
    Actzo [M:SRE9]5
  Endif
  If [M:SRE9]NBLIG > 0 Then
    End
  Endif
  IMUSTASK = 1
  If [M:SRE0]SRENUM <> "" Then
    Filter [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM
    For [ITN]
      IMUSTASK = 0
      Break
    Next
    Filter [ITN]
  Endif
  If IMUSTASK = 0 Then
    End
  Endif
  # FGR 30/06/2008 : X3SUIVI48133 : Il faut demander ici pour le site de stockage et pas dans AM_
  #                  C_ est déclenché avant AM_
  #                  tout ça déplacé dans le sous-programe C_SALFCY
  #IMUSTASK = 0
  #Le site indiqué doit-il également être utilisé comme site de stockage ?
  #Call OUINON(mess(101,177,1), IMUSTASK) From GESECRAN
  #If IMUSTASK <> 2 Then
  #  End
  #Endif
  #[M:SRE8]STOFCY = VALEUR
  #Affzo [M:SRE8]STOFCY
  #LSE 01/03/2005 gestion des sites
  If [M:SRE0]SREBPC = "" or VALEUR = "" or [M:SRE8]STOFCY = "" Then
    Grizo [M:SRE9]5
  Else
    Actzo [M:SRE9]5
  Endif

  Gosub GET_CPY_SSTTAXACT From TRTTAXSST   # 106867.n
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB   # 106867.n
  # 101380 - Show/Hide SST related fields as needed
  Call SETUP_SSTFIELDS From SUBSREA
End

##########################################################################################################
Subprog AP_SALFCY(VALEUR)
Variable Char    VALEUR()

  # Issue X3-41593 - 2017-10-13 by FGR
  If [M:SRE0]SALFCY <> "" Then
    Call READ_COUNTER(VALEUR, 12, 1, GSOCIETE, GCURLEG, GCSRECPT, GMANCOU) From CRM_UTIL
    If GMANCOU = [V]CST_ANO Then
      Grizo [M:SRE0]SRENUM
    Endif
  Endif
End

##########################################################################################################
Subprog C_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZSALFCY(GLONFCY)
Local Char SZHDTITM(GLONITM)
Local Char SZSTOFCY(GLONFCY)
Local Integer IITFOK
Local Integer ILIGNE  # FGR 09/12/2010 : X3SUIVI69775
Local Integer LRET    # FGR 10/04/2015 : X3SUIVI105605

  ILIGNE = nolign-1   # FGR 09/12/2010 : X3SUIVI69775
  SZSALFCY = [M:SRE0]SALFCY
  SZHDTITM = [M:SRE9]HDTITM(nolign-1)
  SZSTOFCY = VALEUR
  IITFOK = 1
  #LSE 14/04/2005 bug 29728
  #Vérifie si un site de stokage est bien présent sur une consomation de type pièce
  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    #consomation de type pièce
    If VALEUR = "" Then
      GMESSAGE = mess(204,177,1) #Il faut obligatoirement saisir un site de stockage.
      GERR = 1
      mkstat = 2
      End
    Endif
    # FGR 10/04/2015 : X3SUIVI105605 (début)
    If dim([M:SRE9]ECCVALMAJ) >= 0 Then
      Call CTLECCVAL([M:SRE9]ECCVALMAJ(ILIGNE), VALEUR, [M:SRE9]HDTITM(ILIGNE), 4, "", [M:SRE1]CREDAT, LRET) From STKSOR
      If LRET >= 1 Then
        mkstat = 2
        End
      Endif
    Endif
    # FGR 10/04/2015 : X3SUIVI105605 (fin)
  Endif
  Gosub CHECKITF From SUBSREB4
  If IITFOK = 0 Then
    End
  Endif
  Gosub CHECKFCY From SUBSREB4
  If IITFOK = 0 Then
    End
  Endif
  # FGR 09/12/2010 : X3SUIVI69775
  Call CTL_HDTDONDAT_HDTSTOFCY([M:SRE9]HDTTYP(ILIGNE), [M:SRE9]HDTSTOISS(ILIGNE), [M:SRE9]HDTDONDAT(ILIGNE), VALEUR) From SUBSREB4
  If mkstat Then
    End
  Endif
End

##########################################################################################################
Subprog AM_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer INOL

  # FGR 15/10/2010 : X3SUIVI67190
  INOL = nolign-1
  # Sorties de stock
  Call INIZONSOR("SRE9", [M:SRE9]HDTITM(INOL), VALEUR, INOL, 24, [M:SRE0]TRSCOD , "") From STKECR
End

##########################################################################################################
Subprog C_HDTAUS(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif

Local Integer IAUZREP
Local Char SZHDKREP(GLONREP)
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  IAUZREP = 0
  #Vérifie si l'utilisateur fait partie du support client
  If [M:SRE9]HDTAUSTYP(nolign-1) = 1 Then
    #Vérification de la validité de l'utilisateur
    Read [AUS]CODUSR=VALEUR
    If fstat
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
      End
    Else
      Call PARAMUTIL("AUSHDKA", SZHDKREP, VALEUR, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP <> 2 Then
        #L'intervenant ne fait pas partie des équipes après-vente. Confirmez-vous la saisie ?
        IAUZREP = 0
        Call OUINON(mess(119,177,1), IAUZREP) From GESECRAN
        If IAUZREP <> 2 Then
          GMESSAGE = mess(120,177,1) #La saisie de cet intervenant est abandonnée.
          GERR = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
  #Le tiers est-il un prestataire
  If [M:SRE9]HDTAUSTYP(nolign-1) = 2 Then
    #Vérification de la validité du tiers
    Read [BPR]BPR0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
      End
    Else
      If [F:BPR]PRVFLG <> 2 Then
        #Le tiers indiqué n'est pas un prestataire après-vente. Confirmez-vous la saisie ?
        IAUZREP = 0
        Call OUINON(mess(121,177,1), IAUZREP) From GESECRAN
        If IAUZREP <> 2 Then
          GMESSAGE = mess(120,177,1) #La saisie de cet intervenant est abandonnée.
          GERR = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_SRECUR(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [TCU]TCU0=VALEUR
    If fstat Then
      GMESSAGE = mess(84,116,1) #Devise incorrecte.
      GERR = 2
      mkstat = 2
      End
    Else
      If [F:TCU]EURFLG = 2 Then
        If [F:TCU]CURENDDAT <> [00/00/00] Then
          If [F:TCU]CURENDDAT < date$ Then
            GMESSAGE = mess(84,116,1) #Devise incorrecte.
            GERR = 2
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SRECUR(VALEUR)
Variable Char    VALEUR()

  If [M:SRE8]SRECUR <> "" Then
    If VALEUR <> ""
      Call INVDTAAMT([M:SRE8]SRECUR, VALEUR, [M:SRE8]SRECHGTYP) From SUBSREB4
    Endif
  Endif
  [M:SRE8]SRECUR = VALEUR
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE8]1-99
End

##########################################################################################################
Subprog IB_HDTITM

  Raz GBOUT3
  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    Call TEXTE(17614, GBOUT3) From OBJDIV      #Stocks articles
  Endif
End

##########################################################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZSOC(GLONCPY)
#Local Integer IMUSTASK # FGR 30/06/2008 : X3SUIVI48133

  # Si le site de stockage est déjà renseigné revérifier la société juridique
  If VALEUR <> "" Then
    # FGR 14/10/2009 : X3SUIVI58782 le faire aussi en création si on change le site et que STOFCY="" pour en avoir un par défaut
    If ([M:SRE8]STOFCY <> "" and [M:SRE8]STOFCY <> VALEUR) or (GREP = "C" and [M:SRE8]STOFCY = "") Then
      # FGR 01/09/2008 : X3SUIVI48927 : On ne pose plus la question. On fait comme pour "Oui".
      #                  Le site de stockage est toujours initialisé pareil
      # FGR 30/06/2008 : X3SUIVI48133 : Il faut demander ici pour le site de stockage et pas dans AM_
      #                  C_ est déclenché avant AM_
      # Le site indiqué doit-il également être utilisé comme site de stockage ?
      #Call OUINON(mess(101,177,1), IMUSTASK) From GESECRAN
      #If IMUSTASK = 2 Then
      #  [M:SRE8]STOFCY = VALEUR
      #  Affzo [M:SRE8]STOFCY
      #Endif
      [M:SRE8]STOFCY = VALEUR
      Affzo [M:SRE8]STOFCY
      #
      Read [FCY]FCY0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
        End
      Else
        SZSOC = [F:FCY]LEGCPY
        Read [FCY]FCY0=[M:SRE8]STOFCY
        If [F:FCY]LEGCPY <> SZSOC Then
          #Le site n'est pas sur la même société juridique
          GMESSAGE = mess(2,194,1)
          GERR = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZSOC(GLONCPY)

  # Si le site de stockage est déjà renseigné revérifier la société juridique
  If VALEUR <> "" Then
    If [M:SRE0]SALFCY <> "" and [M:SRE0]SALFCY <> VALEUR Then
      Read [FCY]FCY0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
        End
      Else
        SZSOC = [F:FCY]LEGCPY
        Read [FCY]FCY0=[M:SRE0]SALFCY
        If [F:FCY]LEGCPY <> SZSOC Then
          #Le site n'est pas sur la même société juridique
          GMESSAGE = mess(2,194,1)
          GERR = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
  If VALEUR <> "" Then
    Read [FCY]FCY0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
      End
    Else
      If [F:FCY]WRHFLG <> 2 Then
        #Le site n'est pas un dépôt.
        GMESSAGE = mess(154,177,1)
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTITM(VALEUR)
Variable Char    VALEUR()

  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    If VALEUR <> "" Then
      If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
          If GSRE9HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTUOM(VALEUR)
Variable Char    VALEUR()

  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    If [M:SRE9]HDTITM(nolign-1) <> "" Then
      If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
             mkstat = 2
             End
          Endif
          If GSRE9HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_COVSPT(VALEUR)
Variable Integer VALEUR

  If [M:SRE7]NBMAC < 2 Then
    mkstat = 2
    End
  Endif
  If [M:SRE7]COVFLG(nolign-1) > 1 Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_COVSPT(VALEUR)
Variable Integer VALEUR

  If [M:SRE7]COVFLG(nolign-1) = 1 Then
    #Totalement couvert
    If VALEUR = 6 Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Endif
  Elsif [M:SRE7]COVFLG(nolign-1) = 3 Then
    #Non couvert
    If VALEUR <> 6 Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

