##########################################################################################################
Subprog C_HDTMACSRE(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif

Local Integer ITER
Local Integer IFOUND

  IFOUND = 0
  #Vérifie que le parc sélectionné provient de l'onglet parc concerné.
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]MAC(ITER) = VALEUR Then
      IFOUND = 1
      Break
    Endif
  Next
  If !IFOUND Then
    #Le parc indiqué ne provient pas de l'onglet Parc concerné. Saisie refusée.
    GMESSAGE = mess(200,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

