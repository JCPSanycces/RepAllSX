######################################################################################

##########################################################################################################
Subprog IB_SRETPL

  Call TEXTE(6109, GBOUT1) From OBJDIV      #Sélection
  If [M:SRE1]SRETPL = "" Then
    Raz GBOUT3
  Else
    Call TEXTE(5562, GBOUT3) From OBJDIV    #Détail
  Endif
End

##########################################################################################################
Subprog C_SRETPL(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [SET]SET0=VALEUR
    If fstat Then
      #Cet identifiant ne correspond pas à un modèle de demande de service enregistré.
      GMESSAGE = mess(200,177,1)
      GERR = 1
      mkstat = 2
    Else
      If !GIMPORT Then
        If [F:SET]TPLSVC <> 2 Then
          #Cet identifiant ne correspond pas à un modèle de demande de service de type prestation.
          GMESSAGE = mess(201,177,1)
          GERR = 1
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SRETPL(VALEUR)
Variable Char    VALEUR()

  [M:SRE1]SRETPL = VALEUR
  Gosub ONSELSET From SUBSREB5
End

