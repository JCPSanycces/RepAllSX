#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier SERREQUEST
##########################################################################################################
$ACTION
#--- Dem 78142
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---
  Case ACTION
    When "BOITE"          : Gosub BOITE     From SUBSREA    # FGR 31/07/2014 : X3SUIVI101463
    When "DEFTRANS"       : Gosub DEFTRANS  From SUBSREA
    When "VARIANTE"       : Gosub VARIANTE  From SUBSREA
    When "SETTRANS"       : Gosub SETTRANS  From SUBSREA
    When "TITRE"          : Gosub TITRES    From SUBSREA
    When "OUVRE_BOITE"    : Gosub OUVRE_BOITE From SUBSREA
    When "AVANT_OUVRE"    : Gosub AVANT_OUVRE From SUBSREA
    When "OUVRE"          : Gosub OUVRE From SUBSREA
    When "AVANT_MOD"      : Gosub AVANT_MOD From SUBSREA
    When "LIENS"          : Gosub LIENS From SUBSREA
    When "RAZDUP"         : Gosub RAZDUP From SUBSREA
    When "RAZCRE"         : Gosub RAZCRE From SUBSREA
    When "FILTRE"         : Gosub FILTRE From SUBSREA
    When "FILGAUCHE"      : Gosub FILGAUCHE From SUBSREA
    When "SETBOUT"        : Gosub SETBOUT From SUBSREA
    When "AVANTBOUT"      : Gosub AVANTBOUT From SUBSREA
    When "EXEBOUT"        : Gosub EXEBOUT From SUBSREA
    When "ABANDON"        : Gosub ABANDON From SUBSREA
    When "VERF_ANU"       : Gosub VERF_ANU From SUBSREA
    When "AV_ANNULE"      : Gosub AV_ANNULE From SUBSREA
    When "ANNULE"         : Gosub ANNULE From SUBSREA
    When "APRES_ANNULE"   : Gosub APRES_ANNULE From SUBSREA # FGR 22/10/2009 : X3SUIVI57254
    When "INICRE"         : Gosub INICRE From SUBSREA
    When "VERIF_CRE"      : Gosub VERIF_CRE From SUBSREA
    When "VERIF_MOD"      : Gosub VERIF_MOD From SUBSREA
    When "CREATION"       : Gosub CREATION From SUBSREA
    When "MODIF"          : Gosub MODIF From SUBSREA
    When "APRES_CRE"      : Gosub APRES_CRE From SUBSREA
    When "APRES_MOD"      : Gosub APRES_MOD From SUBSREA
    When "FERME"          : Gosub FERME From SUBSREA
    When "FIN"            : Call  RAZSTOSORW From STKSOR
    When "AAPRES_NBLIG"   : Gosub AAPRES_NBLIG From SUBSREA
    When "AB2_NBLIG"      : Gosub AB2_NBLIG From SUBSREA
    When "BB2_NBLIG"      : Gosub BB2_NBLIG From SUBSREA    # FGR 13/10/2010 : X3SUIVI68214 : Si annulation sortie de stock décocher aussi
    When "AVANT_CHOI"     : Gosub AVANT_CHOI From SUBSREA
    When "HINTCLE"        : Gosub HINTCLE From SUBSREA
    When Default
  Endcase
Return

##########################################################################################################
Subprog AM_SREDOO(VALEUR)
Variable Char    VALEUR()

  #Affiche le nom en clair du donneur d'ordre.
  If VALEUR = "" Then
    [M:SRE0]SREDOOX = ""
  Else
    Read [BPR]BPR0=VALEUR
    If fstat Then
      [M:SRE0]SREDOOX = ""
    Else
      [M:SRE0]SREDOOX = [F:BPR]BPRNAM
    Endif
  Endif
  # FGR 16/04/2012 : X3SUIVI81400 (début)
  If VALEUR <> "" Then
    Call SETINVINF(VALEUR) From SUBSREB1
  Endif
  # FGR 16/04/2012 : X3SUIVI81400 (fin)
  [M:SRE0]SREDOO = VALEUR
  Affzo [M:SRE0]SREDOOX
End

