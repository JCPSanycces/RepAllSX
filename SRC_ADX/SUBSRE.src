##########################################################################################################
Subprog AM_SREGRALEV(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SRE0]ICOGRALEV = ""
  Else
    Read [ADI]CODE=428;VALEUR
    If fstat Then
      [M:SRE0]ICOGRALEV = ""
    Else
      [M:SRE0]ICOGRALEV = [F:ADI]A1
    Endif
  Endif
  [M:SRE2]SREGRALEV =  VALEUR
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 1, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  [M:SRE2]MANUPD = 2
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE0]1-99
End

##########################################################################################################
Subprog C_CONSPT(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [CON]CON0=VALEUR
    If fstat Then
      Read [COT]COT0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CONSPT(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SRE2]CONSPTCLA = ""
  Else
    #Contrat défini manuellement.
    [M:SRE2]CONSPTCLA = mess(302,182,1)
  Endif
  [M:SRE2]CONSPTFLG = 1
  [M:SRE2]CONSPT = VALEUR
  [M:SRE2]CONSPTTYP = "CON"
  [M:SRE2]MANUPD = 2
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 1, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog AM_COVFLG(VALEUR)
Variable Integer VALEUR

Local Integer ITER

  #La couverture partielle saisie manuellement est interdite
  If VALEUR = 2 Then
    #La couverture partielle manuelle d'un parc est interdite.
    GMESSAGE = mess(178,177,1)
    GERR = 2
    VALEUR = [M:SRE7]COVFLG(nolign-1)
    [M:SRE7]COVFLG(nolign-1) = VALEUR
    Affzo [M:SRE7]COVFLG(nolign-1)
    End
  Endif
  [M:SRE7]COVSPT(nolign-1) = 6
  [M:SRE7]COVVCR(nolign-1) = ""
  [M:SRE7]COVFLG(nolign-1) = VALEUR
  Call COVERMG(1, nolign-1) From TRTCOVER
  [M:SRE2]SRECOVAUT = 0
  #On détecte si un recalcul des montants facturables sera nécessaire en fin de ligne
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
      [M:SRE7]CKKHDTAMT(nolign-1) = 1
      Break
    Endif
  Next
  Affzo [M:SRE7]COVFLG(nolign-1), COVSPT(nolign-1), COVVCR(nolign-1)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog AM_COVSPT(VALEUR)
Variable Integer VALEUR

Local Integer ITER

  [M:SRE7]COVVCR(nolign-1) = ""
  [M:SRE7]COVSPT(nolign-1) = VALEUR
  Call COVERMG(1, nolign-1) From TRTCOVER
  #On détecte si un recalcul des montants facturables sera nécessaire en fin de ligne
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
      [M:SRE7]CKKHDTAMT(nolign-1) = 1
      Break
    Endif
  Next
  Affzo [M:SRE7]COVSPT(nolign-1), COVVCR(nolign-1)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog C_COVVCR(VALEUR)
Variable Char    VALEUR()

  If [M:SRE7]COVSPT(nolign-1) = 1 Then
    If VALEUR <> "" Then
      Read [CON]CON0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Elsif [M:SRE7]COVSPT(nolign-1) = 2 Then
    If VALEUR <> "" Then
      Read [SOH]SOH0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Elsif [M:SRE7]COVSPT(nolign-1) = 5 Then
    If VALEUR <> "" Then
      Read [COT]COT0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_COVVCR(VALEUR)
Variable Char    VALEUR()

Local Integer ITER

  [M:SRE7]COVVCR(nolign-1) = VALEUR
  Call COVERMG(1, nolign-1) From TRTCOVER
  [M:SRE2]CONSPTCLA = mess(302,182,1) #Contrat défini manuellement.
  [M:SRE2]CONSPTFLG = 2
  [M:SRE2]SRECOVAUT = 0
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
      [M:SRE7]CKKHDTAMT(nolign-1) = 1
      Break
    Endif
  Next
  Affzo [M:SRE7]COVVCR(nolign-1)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog AM_CPNCOVFLG(VALEUR)
Variable Integer VALEUR

Local Integer ITER

  #La couverture partielle saisie manuellement est interdite
  If VALEUR = 2 Then
    #La couverture partielle manuelle d'un composant est interdite.
    GMESSAGE = mess(179,177,1)
    GERR = 2
    VALEUR = [M:SRE7]CPNCOVFLG(nolign-1)
    [M:SRE7]CPNCOVFLG(nolign-1) = VALEUR
    Affzo [M:SRE7]CPNCOVFLG(nolign-1)
    End
  Endif
  [M:SRE7]CPNCOVSPT(nolign-1) = 6
  [M:SRE7]CPNCOVVCR(nolign-1) = ""
  [M:SRE7]CPNCOVFLG(nolign-1) = VALEUR
  Call COVERMGC(nolign-1) From TRTCOVER
  [M:SRE2]SRECOVAUT = 0
  For ITER = 0 To [M:SRE9]NBLIG - 1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
      If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
        [M:SRE7]CPNCKKHDT(nolign-1) = 1
        Break
      Endif
    Endif
  Next
  Affzo [M:SRE7]CPNCOVFLG(nolign-1), CPNCOVSPT(nolign-1), CPNCOVVCR(nolign-1)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog AM_CPNCOVSPT(VALEUR)
Variable Integer VALEUR

Local Integer ITER

  [M:SRE7]CPNCOVVCR(nolign-1) = ""
  [M:SRE7]CPNCOVSPT(nolign-1) = VALEUR
  Call COVERMGC(nolign-1) From TRTCOVER
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
      If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
        [M:SRE7]CPNCKKHDT(nolign-1) = 1
        Break
      Endif
    Endif
  Next
  Affzo [M:SRE7]CPNCOVSPT(nolign-1), CPNCOVVCR(nolign-1)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog C_CPNCOVVCR(VALEUR)
Variable Char    VALEUR()

  If [M:SRE7]CPNCOVSPT(nolign-1) = 1 Then
    If VALEUR <> "" Then
      Read [CON]CON0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Elsif [M:SRE7]CPNCOVSPT(nolign-1) = 2 Then
    If VALEUR <> "" Then
      Read [SOH]SOH0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Elsif [M:SRE7]CPNCOVSPT(nolign-1) = 5 Then
    If VALEUR <> "" Then
      Read [COT]COT0=VALEUR
      If fstat Then
        GMESSAGE = mess(83,123,1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CPNCOVVCR(VALEUR)
Variable Char    VALEUR()

Local Integer ITER

  [M:SRE7]CPNCOVVCR(nolign-1) = VALEUR
  Call COVERMGC(nolign-1) From TRTCOVER
  [M:SRE2]CONSPTCLA = mess(302,182,1) #Contrat défini manuellement.
  [M:SRE2]CONSPTFLG = 2
  [M:SRE2]SRECOVAUT = 0
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
      If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
        [M:SRE7]CPNCKKHDT(nolign-1) = 1
        Break
      Endif
    Endif
  Next
  Affzo [M:SRE7]CPNCOVVCR(nolign-1)
  Affzo [M:SRE2]1-99
End

##########################################################################################################
Subprog C_HDTINV(VALEUR)
Variable Integer VALEUR

  # FGR 26/01/2012 : X3SUIVI79673
  #    Une SRE couverte :
  #       - 1-Totalement couverte
  #       - 4-Couverte par contrat de service
  #       - 5-Couverte par commande de vente
  #       - 6-Couverte commercialement
  #       - 7-Couverte par facturation directe
  #    N'est pas facturable. On ne doit pas pouvoir cocher "Facturable"
  # ------------------------------------------------------------------------
  If VALEUR = G_OUI Then
    # FGR 20/12/2012 : X3SUIVI86670 (début)
    #If [M:SRE2]OVRCOV = 1 or [M:SRE2]OVRCOV = 4 or [M:SRE2]OVRCOV = 5 or [M:SRE2]OVRCOV = 6 or [M:SRE2]OVRCOV = 7 Then
    #  GMESSAGE = mess(104,178,1) - '"' + mess([M:SRE2]OVRCOV,3003,1) + '".' - mess(105,178,1)
    #  VALEUR = G_NON
    #  GERR = 1
    #Endif
    If func TRTCONH.COVERED_COMPONENT([M:SRE2]CONSPT, [M:SRE2]OVRCOV, [M:SRE9]HDTMACSRE(nolign-1), [M:SRE9]HDTITM(nolign-1)) = G_YES Then
      #GMESSAGE = mess(104,178,1) - '"' + mess([F:SRE]OVRCOV,3003,1) + '".' - mess(105,178,1)
      GMESSAGE = mess(104,178,1) - '"' + mess([M:SRE2]OVRCOV,3003,1) + '".' - mess(105,178,1)  # FGR 06/05/2014 : X3SUIVI99737
      VALEUR = G_NON
      GERR = 1
    Endif
    # FGR 20/12/2012 : X3SUIVI86670 (fin)
  Endif
End

##########################################################################################################
Subprog AS_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    If [M:SRE9]HDTITM(nolign-1) <> "" Then
      If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
          If GSRE9HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  If [M:SRE9]HDTITM(nolign-1) = "" Then
    mkstat = 2
    End
  Else
    If [M:SRE9]HDTTYP(nolign-1) = 2 Then
      If [M:SRE9]STOMGTCOD(nolign-1) = 1 Then
        mkstat = 2
        End
      Endif
    Else
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTSTOISS(VALEUR)
Variable Integer VALEUR

  If [M:SRE9]HDTITM(nolign-1) = "" Then
    mkstat = 2
  Else
    If [M:SRE9]HDTTYP(nolign-1) = 2 Then
      If [M:SRE9]STOMGTCOD(nolign-1) = 1 Then
        mkstat = 2
      Else
        # FGR 26/01/2011 : X3SUIVI70842 Test incomplet. Il ne faut pas se limiter à test le flag.
        #                  Il faut regarder aussi la quantité sortie (HDTISSISS). Si elle est supérieure à 0
        #                  on n'a pas le droit ; Il faut passer par le bouton "Modification sortie".
        #                  Sinon, rien n'a été fait avec les stocks. On peut décocher.
        # FGR 05/08/2010 : X3SUIVI66063 (début)
        #If [M:SRE9]HDTSTOISS(nolign-1) = 2 and [M:SRE9]SAVSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTSTOISS(nolign-1) = 2 and [M:SRE9]SAVSTOISS(nolign-1) = 2 and [M:SRE9]HDTISSISS(nolign-1) > 0 Then
          # Si la sortie de stock est déjà enregistrée on n'a pas le droit de cliquer ici
          mkstat = 2
        Endif
        # FGR 05/08/2010 : X3SUIVI66063 (fin)
      Endif
    Else
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_HDTSTOISS(VALEUR)
Variable Integer VALEUR

Local Integer ILIGNE

  # FGR 09/12/2010 : X3SUIVI69775
  ILIGNE = nolign-1
  Call CTL_HDTDONDAT_HDTSTOFCY([M:SRE9]HDTTYP(ILIGNE), VALEUR, [M:SRE9]HDTDONDAT(ILIGNE), [M:SRE9]HDTSTOFCY(ILIGNE)) From SUBSREB4
  If mkstat Then
    zonsui = "[M:SRE9]HDTDONDAT(nolign-1)"
    End
  Endif
End

##########################################################################################################
Subprog AM_HDTSTOISS(VALEUR)
Variable Integer VALEUR

Local Integer NOL      # FGR 05/08/2010 : X3SUIVI66063
Local Integer WRET     # FGR 05/08/2010 : X3SUIVI66063

  NOL = nolign-1       # FGR 05/08/2010 : X3SUIVI66063
  If VALEUR = 2 Then
    If [M:SRE9]HDTTYP(NOL) = 2 Then
      If [M:SRE9]HDTDONDAT(NOL) <> [00/00/00] Then
        [M:SRE9]HDTISSQTY(NOL) = [M:SRE9]HDTSTUQTY(NOL)
      Endif
    Endif
  Else
    # FGR 05/08/2010 : X3SUIVI66063 (début)
    #[M:SRE9]HDTISSQTY(NOL) = 0
    Call DELSTOSORW(NOL, NOL, "SRE9", [M:SRE9]HDTSTOFCY(NOL), WRET) From STKSOR
    If WRET <> 0 Then
      VALEUR = 2
      mkstat = 2
      GERR = 2
      End
    Endif
    Raz [M:SRE9]HDTISSQTY(NOL)    # FGR 05/08/2010 : X3SUIVI66063
    Raz [M:SRE9]HDTISSISS(NOL)    # FGR 05/08/2010 : X3SUIVI66063
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
  Endif
  [M:SRE9]HDTSTOISS(NOL) = VALEUR
  Affzo [M:SRE9]HDTSTOISS(NOL)
End

##########################################################################################################
Subprog IB_NBLIG

  Gosub CODE_IB_NBLIG From SUBSREB6
  Call IB_NOTECHECK([M:SRE9]HDTITM(nolign-1),"ITM",6)  From TRTNTSCTL # CRM notes
