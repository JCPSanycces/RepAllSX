##########################################################################################################
Subprog AM_HDTQTY(VALEUR)
Variable Decimal VALEUR

Local Integer IERRINF
Local Integer INOL
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

  INOL = nolign-1
  [M:SRE9]HDTQTY(INOL) = VALEUR
  IERRINF = 0
  Call RUNTARIF(0, [M:SRE9]HDTITM(INOL), [M:SRE9]HDTQTY(INOL), [M:SRE9]HDTUOM(INOL), INOL) From SUBSREB2
  nolign = INOL + 1
  If GERR Then
    End
  Endif
  #Détermination du montant facturable par défaut
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Call AMOUNT(1, "SRE9", INOL, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1),[M:SRE9]PITHDT(nolign-1), [M:SRE9]INVPITFLG(nolign-1), IERRINF) From TRTAMOUNT
  Else
    IPITHDT = 0
    IINVPITFLG = 0
    Call AMOUNT(1, "SRE9", INOL, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
  Endif
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE9]1-99
End

