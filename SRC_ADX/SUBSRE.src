##########################################################################################################
Subprog AM_BHDTDONHOU(VALEUR)
Variable Char    VALEUR()

Local Integer IHDTDONHOU

  IHDTDONHOU = 0
  If VALEUR = "0000" Then
    [M:SRE9]HDTDONHOU(nolign-1) = 0
  Else
    Call HOUTOSEC(val(left$(VALEUR,2)), val(mid$(VALEUR,3,2)), IHDTDONHOU) From CRMUTIL140
    [M:SRE9]HDTDONHOU(nolign-1) = IHDTDONHOU
  Endif
  [M:SRE9]BHDTDONHOU(nolign-1) = VALEUR
  Affzo [M:SRE9]BHDTDONHOU(nolign-1)
End

