##########################################################################################################
Subprog AS_HDTTYP(VALEUR)
Variable Integer VALEUR

  #On ne peut pas modifier une consommation comportant des sorties de stock
  If [M:SRE9]HDTITM(nolign-1) <> "" Then
    If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
      If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
        If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
          mkstat = 2
          End
        Endif
        If GSRE9HDTISSISS(nolign-1) > 0 Then
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
  GMENLOC(1) = 1
  GMENLOC(5) = 1
  If [M:SRE9]HDTITM(nolign-1) <> "" Then
    End
  Endif
  If GDEFHDTTYP < 1 Then
    VALEUR = 2
    End
  Endif
  If GDEFHDTTYP > 3 Then
    VALEUR = 2
    End
  Endif
  VALEUR = GDEFHDTTYP + 1
End

##########################################################################################################
Subprog AM_HDTTYP(VALEUR)
Variable Integer VALEUR

  [M:SRE9]HDTITM(nolign-1) = ""
  [M:SRE9]HDTUOM(nolign-1) = ""
  [M:SRE9]HDTQTY(nolign-1) = 0
  [M:SRE9]HDTAVA(nolign-1) = 0
  [M:SRE9]HDTAVAUOM(nolign-1) = ""
  If GCLOINV = 2 Then
    [M:SRE9]HDTINV(nolign-1) = 2
  Else
    [M:SRE9]HDTINV(nolign-1) = 1
  Endif
  [M:SRE9]HDTAMT(nolign-1) = 0
  [M:SRE9]HDTCUR(nolign-1) = [M:SRE8]SRECUR
  [M:SRE9]HDTTYP(nolign-1) = VALEUR
  Affzo [M:SRE9]HDTITM(nolign-1), HDTUOM(nolign-1), HDTQTY(nolign-1), HDTAVA(nolign-1), HDTAVAUOM(nolign-1)
  Affzo [M:SRE9]HDTAMT(nolign-1), HDTCUR(nolign-1), HDTINV(nolign-1)
End

##########################################################################################################
Subprog AM_HDTAUSTYP(VALEUR)
Variable Integer VALEUR

  [M:SRE9]HDTAUS(nolign-1) = ""
  [M:SRE9]HDTAUSCOD(nolign-1) = ""
  [M:SRE9]HDTAUSTYP(nolign-1) = VALEUR
  Affzo [M:SRE9]HDTAUSTYP(nolign-1), HDTAUS(nolign-1), HDTAUSCOD(nolign-1)
End

##########################################################################################################
Subprog AM_HDTAUS(VALEUR)
Variable Char    VALEUR()

  Case [M:SRE9]HDTAUSTYP(nolign-1)
    When 1
      Read [AUS]CODUSR=VALEUR
      If fstat Then
        [M:SRE9]HDTAUSCOD(nolign-1) = ""
      Else
        [M:SRE9]HDTAUSCOD(nolign-1) = [F:AUS]NOMUSR
      Endif
    When 2
      Read [BPR]BPR0=VALEUR
      If fstat Then
        [M:SRE9]HDTAUSCOD(nolign-1) = ""
      Else
        [M:SRE9]HDTAUSCOD(nolign-1) = [F:BPR]BPRNAM
      Endif
    When Default
  Endcase
  [M:SRE9]HDTAUS(nolign-1) = VALEUR
  Affzo [M:SRE9]HDTAUS(nolign-1), HDTAUSCOD(nolign-1)
End

##########################################################################################################
Subprog AS_HDTDONDAT(VALEUR)
Variable Date    VALEUR

  # FGR 13/10/2010 : X3SUIVI68214 : Non modifiable si sortie de stocke faite
  Gosub NO_MODIF_SSTOK From SUBSREB6
End

##########################################################################################################
Subprog C_HDTDONDAT(VALEUR)
Variable Date    VALEUR

Local Integer ILIGNE

  # FGR 09/12/2010 : X3SUIVI69775
  ILIGNE = nolign-1
  If VALEUR <> [0/0/0] Then
    # Je ne peux pas utiliser l'action : la date n'est pas obligatoire ici
    # FGR 20/06/2014 : X3SUIVI100319 : Seulement si article géré en stock.
    If [F:ITM]ITMREF <> [M:SRE9]HDTITM(ILIGNE) Then
      Read [F:ITM]ITM0=[M:SRE9]HDTITM(ILIGNE)
    Endif
    If [F:ITM]STOMGTCOD <> 1 Then
      Call CONTPER(VALEUR, 1, [M:SRE0]SALFCY) From CPTSUB
      If mkstat Then
        GERR = 1
        End
      Endif
    Endif
  Endif
  #
  Call CTL_HDTDONDAT_HDTSTOFCY([M:SRE9]HDTTYP(ILIGNE), [M:SRE9]HDTSTOISS(ILIGNE), VALEUR, [M:SRE9]HDTSTOFCY(ILIGNE)) From SUBSREB4
  If mkstat Then
    End
  Endif
End

##########################################################################################################
Subprog AM_HDTDONDAT(VALEUR)
Variable Date    VALEUR

Local Integer NOL

  NOL = nolign-1
  If VALEUR = [00/00/00] Then
    [M:SRE9]HDTDONHOU(NOL) = 0
    [M:SRE9]BHDTDONHOU(NOL) = "0000"
    Raz [M:SRE9]HDTISSQTY(NOL)                        # FGR 24/11/2010 : X3SUIVI68817
    Raz [M:SRE9]HDTISSISS(NOL)                        # FGR 24/11/2010 : X3SUIVI68817
  Else
    [M:SRE9]HDTDONHOU(NOL) = time
    Call SECTOHOU([M:SRE9]HDTDONHOU(NOL), [M:SRE9]BHDTDONHOU(NOL)) From CRMUTIL140
    # Sortie de stock
    If [M:SRE9]HDTTYP(NOL) = 2 Then
      If [M:SRE9]HDTSTOISS(NOL) = 2 Then
        [M:SRE9]HDTISSQTY(NOL) = [M:SRE9]HDTSTUQTY(NOL)
      Endif
    Endif
  Endif
  [M:SRE9]HDTDONDAT(NOL) = VALEUR
  Affzo [M:SRE9]HDTDONDAT(NOL), BHDTDONHOU(NOL), HDTISSQTY(NOL), HDTISSISS(NOL)  # FGR 24/11/2010 : X3SUIVI68817
End


##########################################################################################################
Subprog C_HDTITM(VALEUR)
Variable Char    VALEUR()

Local Char SZHDTITM(GLONITM)
Local Char SZSTOFCY(GLONFCY)
Local Integer IITFOK

  Read [ITM]ITM0=VALEUR
  If fstat Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1) # Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Endif
  If [F:ITM]HDKITMTYP <> [M:SRE9]HDTTYP(nolign-1) Then
    # Cet article ne correspond au type indiqué. Saisie refusée.
    GMESSAGE = mess(198,182,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  If [M:SRE9]HDTTYP(nolign-1) <> 2 Then
    If [F:ITM]STOMGTCOD > 1 Then
      #Cet article est géré en stock. Saisie refusée.
      GMESSAGE = mess(189,177,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  # FGR 26/05/2010 : X3SUIVI64415 --> Etape n°3 : Contrôle du statut de l'article (début)
  If [F:ITM]ITMSTA > 1 Then
    GMESSAGE = mess(3,196,1) - "(" + mess([F:ITM]ITMSTA,246,1) + ")"
    If [F:ITM]ITMSTA = 6 Then
      mkstat = 2
      End
    Else
      GERR = 3
    Endif
  Endif
  # FGR 26/05/2010 : X3SUIVI64415 --> Etape n°3 : Contrôle du statut de l'article (fin)

  # FGR 15/10/2010 : X3SUIVI67190 (début) trop tôt
  #Contrôle de l'article site
  #SZHDTITM = VALEUR
  #SZSTOFCY = [M:SRE9]HDTSTOFCY(nolign-1)
  #If SZSTOFCY = "" Then
  #  SZSTOFCY = [M:SRE8]STOFCY
  #Endif
  #IITFOK = 1
  #Gosub CHECKITF From SUBSREB4
  #If IITFOK = 0 Then
  #  End
  #Endif
  # FGR 15/10/2010 : X3SUIVI67190 (fin)
End

