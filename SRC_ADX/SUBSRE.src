##########################################################################################################
Subprog C_SREDOO(VALEUR)
Variable Char    VALEUR()

  #Contrôle s'il s'agit d'un donneur d'ordre
  If VALEUR <> "" Then
    Read [BPR]BPR0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Else
      If [F:BPR]DOOFLG <> 2 Then
        GMESSAGE = VALEUR - mess(606,196,1) #XXX n'EST pas un donneur d'ordre.
        GERR = 1
        mkstat = 2
      Endif
      # FGR 16/04/2012 : X3SUIVI81400 (début)
      If [F:BPR]BPCFLG <> G_OUI Then
        GMESSAGE = mess(1086,196,1)
        GERR = 1
        mkstat = 2
      Endif
      # FGR 16/04/2012 : X3SUIVI81400 (fin)
    Endif
  Endif
End

##########################################################################################################
Subprog C_SREBPC(VALEUR)
Variable Char    VALEUR()

Local Integer IFOUND
Local Integer IONREP
Local Char SZMESS(250)

  IFOUND = 0
  IONREP = 0
  SZMESS = ""
  #Vérifie si le client saisi est un client du donneur d'ordre.
  If VALEUR <> "" Then
    If [M:SRE0]SREDOO <> "" Then
      Filter [DBL] Where [F:DBL]DOONUM = [M:SRE0]SREDOO
      For [DBL]
        If [F:DBL]BPCNUM = VALEUR Then
          IFOUND = 1
          Break
        Endif
      Next
      Filter [DBL]
      If !IFOUND Then
        #Le client saisi n'est pas un client de : [M:SRE0]SREDOOX
        #Souhaitez-vous tout de même poursuivre la saisie ?
        SZMESS = VALEUR - mess(607,196,1) - [M:SRE0]SREDOOX + '.' - mess(608,196,1)
        Call OUINON(SZMESS, IONREP) From GESECRAN
        If IONREP <> 2 Then
          VALEUR = ""
          mkstat = 2
          End  # FGR 15/02/2010 : X3SUIVI62427
        Endif
      Endif
    Endif
    # FGR 15/02/2010 : X3SUIVI62427 (début)
    If [F:BPC]OSTCTL = 3 Then
      SZMESS = VALEUR - ":" - mess(2,178,1)
      Call OUINON(SZMESS, IONREP) From GESECRAN
      If IONREP <> 2 Then
        VALEUR = ""
        mkstat = 2
        End
      Endif
      Call DISPICON_BPC([F:BPC]OSTCTL) From SUBSREB3
    Endif
    # FGR 15/02/2010 : X3SUIVI62427 (fin)
  Endif
End

##########################################################################################################
Subprog IB_SREBPC
Local Integer IFUNOPEN

  If [M:SRE0]SREBPC = "" Then
    Raz GBOUT3
    Raz GBOUT4
    Raz GBOUT5
  Else
    If [M:SRE0]SREBPAADD = "" Then
      #Préciser un site client
      GBOUT3 = mess(772,196,1)
      Raz GBOUT4
    Else
      #Pas de gestion de site client
      Raz GBOUT3
      GBOUT4 = mess(773,196,1)
    Endif
    Raz GBOUT5
    IFUNOPEN = 0
    Call ISFUNOPEN("GESITN", IFUNOPEN) From CRMUTIL140
    If !IFUNOPEN Then
      If GREP = "" Then
        #Interventions / client
        GBOUT5 = mess(240,182,1)
        #---------------------------------------------------------------
        #Définit la clé Intervention pour les tunnels sur interventions.
        #---------------------------------------------------------------
        GLASITN = ""
        Filter [ITN] Where [F:ITN]BPC = [M:SRE0]SREBPC Order By [F:ITN]DATX Desc
        For [ITN] Hint Key ITN2
          GLASITN = [F:ITN]NUM
          Break
        Next
        Filter [ITN]
        [M:SRE7]SRENAVTYP = "BPC"
      Endif
    Endif
  Endif
  Call IB_NOTECHECK([M:SRE0]SREBPC,"CRM",6)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog B4_SREBPC(VALEUR)
Variable Char    VALEUR()

  If [M:SRE0]SREBPC = "" Then
    [M:SRE0]SREBPCCLA = ""
  Else
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      [M:SRE0]SREBPCCLA = ""
    Else
      [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
    Endif
  Endif
  [M:SRE0]SREBPAADD = ""
  If [M:SRE0]SRENUM <> "" Then
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
    Readlock [SRE]SRE0=[M:SRE0]SRENUM
    If fstat Then
      #Erreur lors de la suppression du site client.
      GMESSAGE = mess(774,196,1)
      GERR = 1
      Rollback
    Else
      [F:SRE]SREBPAADD = ""
      Rewrite [SRE]
      If fstat Then
        #Erreur lors de la suppression du site client.
        GMESSAGE = mess(774,196,1)
        GERR = 1
        Rollback
      Else
        Commit
        Unlock [SRE]
      Endif
    Endif
  Endif
  Affzo [M:SRE0]SREBPC, SREBPCCLA
End

