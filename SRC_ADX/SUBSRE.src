##########################################################################################################
Subprog IB_TIMSPGDAY

  Raz GBOUT1
  Call TEXTE(12657, GBOUT2) From OBJDIV      #Préférences
  If [M:SRE9]NBLIG < dim([M:SRE9]HDTCPN)-1 Then
    If [M:SRE2]SREASS <> 5 Then
      If [M:SRE2]SREASS <> 4 Then
        If GREP = "" Then
          If GISRE2TIMFLG Then
            GBOUT1 = mess(183,182,1)
          Else
            GBOUT1 = mess(182,182,1)
          Endif
        Endif
      Endif
    Endif
  Endif
End

