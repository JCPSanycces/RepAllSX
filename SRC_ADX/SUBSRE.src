Subprog AM_SRESAT(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SRE0]ICOSAT = ""
  Else
    Read [ADI]CODE=422;VALEUR
    If fstat Then
      [M:SRE0]ICOSAT = ""
    Else
      [M:SRE0]ICOSAT = [F:ADI]A1
    Endif
  Endif
  [M:SRE2]SRESAT = VALEUR
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE0]1-99
End

