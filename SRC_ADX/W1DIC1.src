$ON_POTFLG
Onevent BEFORE_INPUT Call AS_POTFLG(zc) From W1DIC1
Onevent INIT_AREA Call D_POTFLG(zc) From W1DIC1
Return

Subprog D_POTFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]POTFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_POTFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_POTFLG(VALEUR) From SUBDIC
If mkstat=2
 [M]POTFLG(INDIC) = VALEUR
 Affzo POTFLG(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

