  [L]SERVER = adxmac(0)
  If [L]SERVER = ""
    [L]SERVER = adxmac(-1)
  Endif
End [L]SERVER

#**
#* Get the engine version
#*!
Funprog GET_ENGINE_VERSION()
  If not GXDT_AUTH : End "" : Endif
End func PARTSEP(ver$(0),2," ")

#**
#* Get the actual folder of the current session
#*!
Funprog GET_APP_NAME()
 Local Char    APP_NAME(250)

 APP_NAME = toupper(nomap)
 If APP_NAME = func GET_BATCH_APP_NAME()
  APP_NAME = nomap(1) : # Get parent application
 Endif
End APP_NAME

#**
#* Get the baseurl of the current session
#*!
Funprog GET_BASEURL()
  Local Char URL(255)
  Onerrgo ERR_BASEURL
  URL = baseUrl
  Onerrgo
  If len(URL)=0
    URL = "x3://" + adxmac(-1)+":"+num$(adxtcp)
  Endif
End URL

$ERR_BASEURL
Resume


Funprog GET_OSLOGIN()
  If not GXDT_AUTH : End "" : Endif

  If dim(GXDT_OSLOGIN) > 0
    If func AXDTMAIN.IS_TRACE_ON()
      Call TRACE(".GET_OSLOGIN - 1: OSLOGIN=" + GXDT_OSLOGIN) From AXDTMAIN
    Endif
    End GXDT_OSLOGIN
  Endif

  Global Char GXDT_OSLOGIN(50)
  GXDT_OSLOGIN = func GET_PID_OSLOGIN(adxpid)
  If func AXDTMAIN.IS_TRACE_ON()
    Call TRACE(".GET_OSLOGIN - 2: OSLOGIN=" + GXDT_OSLOGIN) From AXDTMAIN
  Endif
End GXDT_OSLOGIN

Funprog GET_PID_OSLOGIN(PID)
  Value Integer PID

  If not GXDT_AUTH : End "" : Endif

  If func ISMNGSESSIONS
   End func ASESSIONS.GET_PID_OSLOGIN(PID)
  Endif

  Local Char FILTERS(50), OSLOGIN(50), COMMAND(250)

  FILTERS = "left$([F:SYS_]SPROC," + num$(len(num$(PID))) + ")='" + num$(PID) + "'"

  [L]COMMAND = "psadx -axptgfn -b " + nomap

  Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, SUID, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_] Where evalue(FILTERS)

  Onerrgo ERR_IGNORE
  # read header
  Read [SYS_] Next
  # read first line
  Read [SYS_] Next
  OSLOGIN = [F:SYS_]SUSER
  Onerrgo
  Close Local File [SYS_]
End OSLOGIN

#**
#* Gets the debug proxy in the form host:port for the given idekey (studio ID)
#*!
Funprog GET_IDEPROXY(IDEKEY)
Value Char IDEKEY
Local Char PROXY(255)

  PROXY = func GET_SYRACUSE_IDEPROXY(IDEKEY)
  If len(PROXY) = 0
    PROXY = func GET_PROXY()
  Endif
End PROXY

#**
#* Gets the debug proxy host:port value
#*!
Funprog GET_PROXY()
  Local Char PROXY(255)

  If dim(GDBGPXY) < 0 : Global Char GDBGPXY(255) : Endif

  If len(GDBGPXY) = 0
    PROXY = func GET_SYRACUSE_PROXY()
    If len(PROXY) = 0
      PROXY = func GET_STANDALONE_PROXY()
    Endif
    GDBGPXY = PROXY
  Endif

End GDBGPXY


#**
#* Return true if the current session is a syracuse or classic session
#*!
Funprog IS_SYRACUSE_SESSION()
End (dim(GFUSION) > 0 and GFUSION or adxtyp>32)

#**
#* Gets the syracuse debug proxy in the form host:port for the given idekey (studio ID)
#*!
Funprog GET_SYRACUSE_IDEPROXY(IDEKEY)
  Value Char IDEKEY

  # not a syracuse or classic session
  If not func IS_SYRACUSE_SESSION()
    End ""
  Endif

  Local Clbfile RESHEAD
  Local Clbfile RESBODY

  Local Clbfile ARGUMENTS(0)
  Local Char NAME(50)
  NAME='getDbgpProxyAddress'
  Raz ARGUMENTS
  Local Integer STATUSCODE

  If IDEKEY <> ""
    NAME='getStudioDbgpProxyAddress'
    Append ARGUMENTS, '"' + IDEKEY + '"'
  Endif

  Onerrgo ERR_PROXY_SYRA
  STATUSCODE = func SYRA_WAIT_CALL('syracuse-studio/lib/pub/dbgpHelper', NAME, ARGUMENTS, RESHEAD, RESBODY)
  Onerrgo
  If STATUSCODE <> 200
    End ""
  Endif
End RESBODY

#**
#* Gets the syracuse debug proxy host:port value from the syracuse server
#*!
Funprog GET_SYRACUSE_PROXY()
  # delegate call
End func GET_SYRACUSE_IDEPROXY("")

$ERR_PROXY_SYRA
STATUSCODE = 500
Resume

#**
#* Gets the standalone debug proxy host:port value
#*!
Funprog GET_STANDALONE_PROXY()
  Local Char PROXY(255)
  Local Char CFGNAME(GDIMFIC)
  # hack: debugProxy.json is not a json file
  #       but the default configuration of the sandbox only allows access to file with json extension
  CFGNAME = filpath("", adxdir + "/cfg/debugProxy", "json", "")
  If filinfo(CFGNAME, 7) = -20
    # file does not exist, try
    CFGNAME = filpath("", adxdir + "/debugProxy", "conf", "")
    If filinfo(CFGNAME, 7) = -20 : End "" : Endif
  Endif

#  Local Integer STMP
#  STMP = filinfo(CFGNAME, 9)
#  If dim(GDBGPXYSTMP) < 0
#    Global Integer GDBGPXYSTMP : GDBGPXYSTMP = STMP
#  Else
#     If STMP = GDBGPXYSTMP
#       End GDBGPXY
#     Endif
#  Endif

  Openi CFGNAME Using [CFG]
  Iomode adxifs "=" Using [CFG]
  Iomode adxirs chr$(10) Using [CFG]
  Iomode adxium GUTF8 Using [CFG]

  Local Char PKEY(255), PVAL(255), HOST(255), PORT(10)

  Repeat
   Raz PKEY, PVAL
   Rdseq PKEY, PVAL Using [CFG]
   PKEY = tolower(PKEY)
   Case PKEY
     When "proxy.host"
       HOST = ctrans(PVAL, chr$(13) + chr$(10) + " ", "")
     When "proxy.port"
       PORT = ctrans(PVAL, chr$(13) + chr$(10) + " ", "")
   Endcase
  Until PKEY =""

  If HOST = "" : End "" : Endif
  If PORT = "" : PORT = "9514" : Endif

  PROXY = HOST + ":" + PORT
  Openi Using [CFG]
End PROXY


Funprog SYRA_WAIT_CALL(MODULE, FUNCTION, ARGUMENTS, RESHEAD,RESBODY)
  Value Char MODULE
  Value Char FUNCTION
  Variable Clbfile ARGUMENTS
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY

  Local Integer STATUSCODE
  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FUNCTION, 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
End STATUSCODE

Funprog GET_CLOB_LENGTH(N)
  Value Integer N
End 512*(2^N)-2

Funprog GET_CLOB_SIZE(N)
  Value Integer N
End 1024*(2^N)-4

# ============
# DIAGNOSIS TOOLS
# ============

Funprog FINDSTR(TOFIND, NOCASE)
  Value Char TOFIND
  Value Integer NOCASE

  Local Char DOSS(30)
  DOSS=nomap

  Local Char RESULT(200), ORDERC(200),CHEMIN(200),FILNAM(30),TRAC(200),MESSA(200),VALL1(250)
  Local Clbfile FOUND(12)
  Local Double TIMDEB
  Local Integer STA
  Local Char OPT(5) , GUIL(1)
  CHEMIN = filpath("TRT","","",DOSS)
  FILNAM = "REC-"+GUSER+"-"+num$(time)
  TRAC   = filpath("tmp",FILNAM,"txt")
  GUIL = '"'
  If instr(1,TOFIND,GUIL)>0 : GUIL = "'" : Endif
  OPT = "-n"
  # Case insensitive search
  If NOCASE : OPT += "i" : Endif
  ORDERC = "find "-CHEMIN-"-name *.src | sort |xargs grep"-OPT-GUIL+TOFIND+GUIL+" > "+TRAC
  TIMDEB = val(timestamp$)
  System RESULT = adxmac(0)+"@"+ORDERC

  FOUND = ""

  Openi TRAC Using [TTR]
  Iomode adxifs "" Using [TTR]
  Iomode adxirs "" Using [TTR]
  Iomode adxium GUTF8 Using [TTR]

  Rdseq [L]FOUND Using [TTR]
  Append [L]FOUND, num$(val(timestamp$)-TIMDEB) + "ms"
  Openi Using [TTR]

  STA = Delfile(TRAC)
End FOUND

Funprog OPEN_SOCK(HOST, PORT)
Value Char HOST
Value Integer PORT

  If HOST = "" : HOST = adxmac(-2) : Endif
  If PORT <= 0 : PORT = 10000 : Endif

  Local Char ERR_MSG(255)
  ERR_MSG = "OK"

  Onerrgo SOCKET_ERR
  Opsock HOST, PORT Using [OPS]
  Iomode adxium GASCII Using [OPS]
  Iomode adxirs "" Using  [OPS]
  Iomode adxifs "" Using  [OPS]
  Onerrgo
End ERR_MSG

$SOCKET_ERR
  ERR_MSG = "[" + num$(errn) + " - " + errmes$(errn)-errp+"("+num$(errl)+"): '"+errm+"']"
Resume

Funprog CLOSE_SOCK()
  Local Char ERR_MSG(255)
  ERR_MSG = "OK"

  Onerrgo SOCKET_ERR
  Opsock "", 0 Using [OPS]
  Onerrgo
End ERR_MSG

Funprog CHECK_SOCK(HOST, PORT)
Value Char HOST
Value Integer PORT

  Local Char ERR_MSG(255)
  ERR_MSG = func OPEN_SOCK(HOST, PORT)
  If ERR_MSG = "OK"
    ERR_MSG = func CLOSE_SOCK
  Endif
End ERR_MSG

Funprog INIT_DEBUG(HOST, PORT, IDEKEY)
Value Char HOST, IDEKEY
Value Integer PORT

  Local Char ERR_MSG(255)
  Local Char PROXY(255)
  Local Integer POS

  Onerrgo ERR_INIT_DEBUG

  If IDEKEY <> ""
   PROXY = func GET_IDEPROXY(IDEKEY)
   POS = instr(0, PROXY, ":")
   If POS > 0
     HOST = left$(PROXY, POS-1)
     PORT = right$(PROXY, POS+1)
   Endif
  Endif
  If HOST = "" : HOST = func GET_PARAM_("AECLIMAC") : Endif
  If PORT = 0 : PORT = val(func GET_PARAM_("AECLIPRT")) : Endif

  ERR_MSG = func OPEN_SOCK(HOST, PORT)

  If ERR_MSG <> "OK" : End ERR_MSG : Endif

  Local Char SERVER(250)
  Local Clbfile DATA

  If IDEKEY="" : IDEKEY = "com.sage.x3.xdt.dltk.debugger" : Endif
  SERVER = func AXDTMAIN.GET_APP_SERVER()

  DATA = '<init'
  Append DATA, ' idekey="' + IDEKEY + '"'
  Append DATA, ' fileuri=""'
  Append DATA, ' session="' + func AXDTMAIN.GET_BASEURL() + "/$$test$$"
  Append DATA, "?idekey=" + IDEKEY + "&amp;rtm=" + func GET_ENGINE_VERSION + '"'
  Append DATA, ' thread="' + num$(adxpid) + '"'
  Append DATA, ' parent="'
   Append DATA, adxdir
  Append DATA, '"'
  Append DATA, ' appid="'
    Append DATA, SERVER
    Append DATA, ":"
    Append DATA, num$(adxtcp)
    Append DATA, "/"
    Append DATA, func AXDTMAIN.GET_APP_NAME()
    Append DATA, "/"
    Append DATA, func ESCAPE_XML(adxusr)
    Append DATA, "/"
    Append DATA, num$(adxuid(2))
    Append DATA, "/"
    Append DATA, num$(adxuid(1))
  Append DATA, '" language="X3" protocol_version="1.0">'
  Append DATA, '<engine version="' + ver$(0) + '"/>'
  Append DATA, '<author>Sage</author><url><![CDATA[http://www.sage.com]]></url><copyright><![CDATA[Copyright (c) 2000-'
  Append DATA, num$(year(date$))
  Append DATA, ' Sage]]></copyright>'
  Append DATA, '</init>'

  ERR_MSG = func SOCK_SEND(DATA)
  If ERR_MSG <> "OK" : End ERR_MSG : Endif
  Sleep 5
  ERR_MSG = func CLOSE_SOCK
  Onerrgo

End ERR_MSG

$ERR_INIT_DEBUG
  ERR_MSG = "[" + num$(errn) + " - " + errmes$(errn)-errp+"("+num$(errl)+"): '"+errm+"']"
Resume

Funprog SOCK_SEND(DATA)
  Const Clbfile DATA()
  Local Libelle SEP : SEP = 0
  Local Integer I

  Local Char ERR_MSG(255)
  ERR_MSG = "OK"

  Onerrgo SOCKET_ERR
  Wrseq num$(len(DATA)) Using [OPS]
  Putseq 1, SEP Using [OPS]
  Wrseq DATA Using [OPS]
  Putseq 1, SEP Using [OPS]
  Seek 0 Using [OPS]
  Onerrgo
End ERR_MSG

