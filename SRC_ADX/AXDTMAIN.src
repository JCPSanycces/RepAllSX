Funprog GET_REF_FOLDER() : End GDOSX3

#**
#* Gets informations about the environnement
#*!
Funprog GET_ENV_INFO(PROG_LIST)
Value Clbfile PROG_LIST()

#If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Local Clbfile INFO(3)
Local Integer NBSPLIT
Local Integer NBSPLITMAX : NBSPLITMAX = 50
Local Char    PROGS(15)(NBSPLITMAX)
Local Integer I
Local Char VERSION(80)

NBSPLIT = func SPLIT_LOB(ctrans(PROG_LIST, ";",","), ",", PROGS)

INFO = '{'
 Append INFO, '"magic":1'
 Append INFO, ',"solution":{'
  Append INFO, '"name":"' + GINSTID + '"'
  Append INFO, ',"folder-ref":"' + GDOSX3 + '"'
  Append INFO, ',"batch-server":"' + ctrans(func GET_BATCH_APP_NAME(), "\", "/") + '"'
  Append INFO, ',"runtime-dir":"' + ctrans(adxdir, "\", "/") + '"'
  Append INFO, ',"folder-dir":"' + ctrans(filpath("","","",""), "\", "/") + '"'
  Append INFO, ',"pub-dir":"' + ctrans(filpath("","","","X3_PUB"), "\", "/") + '"'
 Append INFO, '}'

 Append INFO, ',"version":{'
  Append INFO, '"runtime":"' + ver$(0) + '"'
  Append INFO, ',"supervisor":"' + GVERSOL + '"'
  Append INFO, ',"self":["'
   Append INFO, func GETVERSION()
   Append INFO, '","'
   Append INFO, func GETHASH()
   Append INFO, '","'
   Append INFO, func GETPLUGINVERSION()
  Append INFO, '"]'

  Append INFO, ',"programs":['
   For I = 0 To NBSPLITMAX-1
    If len(PROGS(I)) = 0 : Break : Endif
    If I > 0
      Append INFO, ','
    Endif
    Append INFO, '["' + toupper(PROGS(I)) + '","'
    Onerrgo ERR_IGNORE
    Append INFO, func =toupper(PROGS(I) + ".GETVERSION") With ()
    Onerrgo
    Append INFO, '","'
    Onerrgo ERR_IGNORE
    Append INFO, func =toupper(PROGS(I) + ".GETHASH") With ()
    Onerrgo
    Append INFO, '","'
    Onerrgo ERR_IGNORE
    Append INFO, func =toupper(PROGS(I) + ".GETPLUGINVERSION") With ()
    Onerrgo
    Append INFO, '","'
    Onerrgo ERR_IGNORE
    Append INFO, func =toupper(PROGS(I) + ".GETUPDATERUNTIME") With ()
    Onerrgo
    Append INFO, '","'
    Onerrgo ERR_IGNORE
    Append INFO, func =toupper(PROGS(I) + ".GETLOCATION") With ()
    Onerrgo
    Append INFO, '"]'
   Next I
  Append INFO, ']'
 Append INFO, '}'

 Append INFO, ',"user":{'
 Append INFO, '"name":"' + adxusr + '"'
 If dim(GUSER) > 0
   Append INFO, ',"code":"' + GUSER + '"'
 Endif
 If dim(GLOGIN) > 0
   Append INFO, ',"login":"' + GLOGIN + '"'
 Endif
 If dim(GLOGNAME) > 0
   Append INFO, ',"logname":"' + GLOGNAME + '"'
 Endif
 Append INFO, '}'

 Append INFO, ',"system":{'
  Append INFO, '"server":{'
   Append INFO, '"host":"' + adxmac(-1) + '"'
   Append INFO, ',"port":"' + num$(adxtcp) + '"'
  Append INFO, '}'
  Append INFO, ',"client":{'
   Append INFO, '"host":"' + adxmac(-2) + '"'
  Append INFO, '}'
  Append INFO, ',"pid":' + num$(adxpid)
  Append INFO, ',"folders":['
   For I = 0 To dim(nomap) - 1
     If nomap(I) = "" : Break : Endif
     If I > 0
       Append INFO, ','
     Endif
     Append INFO, '"' + nomap(I) + '"'
   Next I
  Append INFO, "]"
  Append INFO, ',"stack":['
   I = 0
   While (adxpno(I) <> "")
     If I > 0
       Append INFO, ','
     Endif
     Append INFO, '"' + adxpno(I) + '"'
     I+=1
   Wend
  Append INFO, "]"
 Append INFO, '}'

 Local Char AECLIPSE(1)
 Local Char AECLIDBG(1)
 Local Char AECLIDBGTR(1)
 Local Char AECLIMAC(250)
 Local Char AECLIPRT(15)

 Append INFO, ',"eclipse":{'
  AECLIPSE = func GET_PARAM_("AECLIPSE")
  AECLIDBG = func GET_PARAM_("AECLIDBG")
  AECLIMAC = func GET_PARAM_("AECLIMAC")
  AECLIPRT = func GET_PARAM_("AECLIPRT")
  AECLIDBGTR = func GET_PARAM_("AECLIDBGTR")
  Append INFO, '"AECLIPSE":"' + AECLIPSE + '"'
  Append INFO, ',"AECLIDBG":"' + AECLIDBG + '"'
  Append INFO, ',"AECLIDBGTR":"' + AECLIDBGTR + '"'
  Append INFO, ',"AECLIMAC":"' + AECLIMAC + '"'
  Append INFO, ',"AECLIPRT":"' + AECLIPRT + '"'
 Append INFO, '}' : # eclipse
 Append INFO, ',"date":"' + "" + date$ + '"'
 Append INFO, ',"time":"' + time$ + '"'
 Append INFO, ',"timestamp":' + timestamp$
Append INFO, '}'

End INFO
$ERR_IGNORE
Resume

# No longer used but keep it for backward compatibility
Funprog GET_TIMESTAMP()
End timestamp$

#**
#* Escape special xml char
#*
#* @param XVAL the string to escape
#*!
Funprog ESCAPE_XML(XVAL)
  Value Clbfile XVAL()
  Local Clbfile RES(1)
  Local Integer I,P
  Local Char C(1), R(10)(1..5)

  # "   &quot;
  R(1)="&quot;"
  # '   &apos;
  R(2)="&apos;"
  # <   &lt;
  R(3)="&lt;"
  # >   &gt;
  R(4)="&gt;"
  # &   &amp;
  R(5)="&amp;"

  RES=""
  For I=1 To len(XVAL)
    C = mid$(XVAL, I, 1)
    P = find(C, '"', "'", "<", ">", "&")
    If P > 0
      Append RES, R(P)
    Else
      Append RES, C
    Endif
  Next I
End RES


#**
#* Splits a string with a given separator
#*
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT(CHAINE,SEPARATEUR,RETOUR)
Value Char CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()()

Local Clbfile CHAINE_LOB(1)
CHAINE_LOB = CHAINE

Local Integer NBMOT
NBMOT = func SPLIT_LOB(CHAINE_LOB, SEPARATEUR, RETOUR)
End NBMOT

#**
#* Splits a clbfile with a given separator
#*
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT_LOB(CHAINE,SEPARATEUR,RETOUR)
Value Clbfile CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()() #tableau de chaines de caracteres ou sont renvoyees les chaines decoupees

Local Integer DEBUT , FIN , FINBOUCLE , NBMOT

DEBUT=1 #debut du mot
FIN=1 #fin du mot
FINBOUCLE=0 #sortie de boucle
NBMOT=0 #nombre de mot

#parcourt de la chaine
Repeat
 #recherche d'un mot
 FIN=instr(DEBUT,CHAINE,SEPARATEUR)
 If FIN=0
  FINBOUCLE=1
  FIN=len(CHAINE)+1
 Endif
 RETOUR(NBMOT)=seg$(CHAINE,DEBUT,FIN-1) #ajout du mot au retour
 DEBUT=FIN+len(SEPARATEUR)
 NBMOT+=1
Until FINBOUCLE | NBMOT=dim(RETOUR)
End NBMOT

# Ensure V5 compliance
Funprog PARTSEP(TEXTE, NUM, SEP)
Value Char TEXTE
Value Integer NUM
Value Char SEP

Local Integer ISOK : ISOK = 1
Local Char RET(250)

Onerrgo ERR_PARTSEP
RET = func AFNC.PARTSEP(TEXTE, NUM, SEP)
Onerrgo
If ISOK
  End RET
Endif
Goto PART1

$ERR_PARTSEP
ISOK = 0
Resume

$PART1
Local Char CHAINE(255) , PART(255)(1..10)
Local Integer I , J
If TEXTE="" or NUM<=0 or NUM>dim(PART)
 End ""
Endif
CHAINE = TEXTE
While CHAINE<>"" & J<dim(PART)
 J += 1
 I = instr(1,CHAINE,SEP)
 If I
  PART(J) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+len(SEP))
 Else
  PART(J) = CHAINE
  CHAINE = ""
 Endif
Wend
End PART(NUM)

Funprog FIXUSER()
  Local Char USR(5)
  USR = func GET_USER()
  If dim(GUSER) < 1 and type(GACTX) = 524 and USR <> ""
    Global Char GUSER(5) : GUSER = USR
  Endif
End GUSER

Funprog GET_USER()
  Local Char USR(5)
  Onerrgo ERR_IGNORE
  USR = evalue('GACTX.USER')
  Onerrgo
  If type(GACTX) = 524 and USR <> ""
    End USR
  Elsif dim(GUSER) > 0
    End GUSER
  Endif
End ""

Funprog GET_LANG()
  Local Char LANG(10)
  Onerrgo ERR_IGNORE
  LANG = evalue('GACTX.LAN')
  Onerrgo
  If type(GACTX) = 524 and LANG <> ""
    End LANG
  Elsif dim(GLANGUE) > 0
    End GLANGUE
  Endif
End ""

Funprog GET_CTX_VAL(CTX_NAME)
  Value Char CTX_NAME
  Local Char CTX_VAL(255)
  Onerrgo ERR_IGNORE
  CTX_VAL = evalue('GACTX.' + toupper(CTX_NAME))
  Onerrgo
End CTX_VAL

#**
#* Get raw parameters value for the current user
#*
#* @param PARAM
#*!
Funprog GET_PARAM_(PARAM)
  Value Char PARAM
End func GET_USER_PARAM("", PARAM)

Funprog GET_USER_PARAM(USR, PARAM)
  Value Char USR, PARAM
  Local Char VALEUR(250)
  If USR="" : USR = func GET_USER() : Endif
  Call PARAMUTIL(PARAM, VALEUR, USR, "") From SUBAUS
End VALEUR

#**
#* Get parameters value for the current user
#*
#* @param PARAM
#*!
Funprog GET_PARAM(PARAM)
  Value Char PARAM
  If dim(GXDT_JSON) > 0 and GXDT_JSON
   End '{"value":"' + VALEUR + '"}'
  Endif
End "1" + GXDT_NL_SEP + func GET_PARAM_(PARAM)

#**
#* Check if a parameter is defined in current folder
#*
#* @param PARAM
#*!
Funprog IS_PARAM(PARAM)
 Value Char PARAM
 Local Char VALEUR(250)
 If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
 Read [ADP]ADP1 = PARAM
 VALEUR = "1" + [V]GXDT_NL_SEP
 If fstat
    Append VALEUR, "1"
 Else
    Append VALEUR, "2"
 Endif
 Close Local File [ADP]
End VALEUR

#**
#* Update a user parameter
#*
#* @param PARAM parameter
#* @param USR user (GUSER if blank)
#* @param VALEUR value to set perameter to
#*!
Funprog SET_PARAM(PARAM, VALEUR)
  Value Char PARAM, VALEUR
  Local Char USR(30), RES(5)
  RES = "1"

  # we need GUSER
  Call FIXUSER
  USR = func GET_USER()

  Local File ADOVALAUS [ADU_]
  If !adxlog
   Trbegin [ADU_]
    Gosub SET_PAR
   Commit
  Else
   Gosub SET_PAR
  Endif
  Close Local File [ADU_]
End RES

#--------------------------#
$SET_PAR
 Read [ADU_]ADU0 = USR;PARAM
 If fstat
  Raz [F:ADU_]
  [F:ADU_]PARAM  = PARAM
  [F:ADU_]CODUSR = USR
  [F:ADU_]VALEUR = VALEUR
  Write [ADU_]
 Else
  [F:ADU_]VALEUR = VALEUR
  Rewrite [ADU_]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADU_") From GLOCK
  RES = "0"
 Endif
Return

#**
#* Get eclipse parameters value for the current user
#*
#* @param PARAM
#*!
Funprog GET_ECLIPSE_PARAMS()
  Local Clbfile RES(2)
  Local Char PARAM(20)
  RES = "1" + GXDT_NL_SEP
  For PARAM="AECLIPSE","AECLIMAC","AECLIPRT","AECLIDBG","AECLIDBGTR"
   Append RES, PARAM + GXDT_VALUE_SEP + func GET_USER_PARAM("", PARAM)
   Append RES, GXDT_NL_SEP
  Next
End RES

#**
#* Get the name of the folder that is used for the batch serveur
