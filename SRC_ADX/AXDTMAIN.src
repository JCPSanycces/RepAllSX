#**
#* Verify that requirements are satisfied
#*
#* @param PLUGINVER
#* @param OPTIONS
#*!
Funprog HANDCHECK(PLUGINVER, OPTIONS)
  Value Char PLUGINVER
  Value Clbfile OPTIONS

  If dim(GXDT_PLUGINVER) < 0
    Global Char GXDT_PLUGINVER(50)
  Endif
  GXDT_PLUGINVER=PLUGINVER
  If dim(GXDT_OPTIONS) < 0
    Global Clbfile GXDT_OPTIONS(2)
  Endif
  GXDT_OPTIONS = OPTIONS

  # http connection but with erroneous GLOBVAR initialization
  If adxtyp=30 & (dim(GFUSION) < 0 | GFUSION=0)
    End "The destination folder requires an important update. Please contact your support regarding the issue 112234"
  Endif
End func FUNAUTH("GESAMK")

#**
#* Normalize the plug-in version so that it can be compared
#*
#* @param PLUGINVER
#*!
Funprog NORMALIZE_VER(PLUGINVER)
  Value Char PLUGINVER

  Local Char CHECKVER(40)
  Local Char PARTS(20)(4)
  Local Integer NBPARTS, I

  NBPARTS = func AXDTMAIN.SPLIT(PLUGINVER, ".", PARTS)
  For I=0 To min(NBPARTS-2, 2)
    CHECKVER += format$("N0:4", val(PARTS(I))) + "."
  Next I
  If NBPARTS < 4
    CHECKVER += format$("N0:4", val(PARTS(NBPARTS-1)))
  Else
    CHECKVER += PARTS(NBPARTS-1)
  Endif
End CHECKVER

#**
#* Initialize global variables
#*!
Funprog INIT_VARIABLES()
  Local Clbfile RES(2)
  Local Integer OK : OK=0

  If func IS_TRACE_ON()
    Call TRACE("AXDTMAIN.INIT_VARIABLES 1: GDOSX3=" + GDOSX3)
  Endif

  If dim(GXDT_AUTH) < 0
    Global Libelle GXDT_AUTH
  Endif
  # Check if we have access to the GESAMK X3 function.
  # Aborting initialization will prevent user from being able to use Eclispe.
  RES = func FUNAUTH("GESAMK")
  If func IS_TRACE_ON()
    Call TRACE("AXDTMAIN.INIT_VARIABLES 2: FUNAUTH=" + RES)
  Endif
  If len(RES) > 0
    GXDT_AUTH=0
    End RES
  Endif
  GXDT_AUTH = 1

  If dim(GXDT_ISTRUSTEDENV) < 0
    Global Libelle GXDT_ISTRUSTEDENV
  Endif
  GXDT_ISTRUSTEDENV = 1
  Onerrgo ERR_CALL
    If func VAL_TOOL_SUPPORTED: GXDT_ISTRUSTEDENV = func ADS_TOOL.ISTRUSTEDENV : Endif
  Onerrgo
  If func IS_TRACE_ON()
    Call TRACE("AXDTMAIN.INIT_VARIABLES 3: GXDT_ISTRUSTEDENV=" + num$(GXDT_ISTRUSTEDENV))
  Endif

  Call ENSURE_ENV_VARIABLES

  If func IS_TRACE_ON()
    Call TRACE("AXDTMAIN.INIT_VARIABLES 4:")
  Endif

  If dim(GXDT_JSON) < 0
    Global Libelle GXDT_JSON
  Endif

  If dim(GXDT_NL_SEP) < 0
    Global Char GXDT_NL_SEP(4)
    GXDT_NL_SEP = "#NL#"
  Endif

  If dim(GXDT_VALUE_SEP) < 0
    Global Char GXDT_VALUE_SEP(4)
    GXDT_VALUE_SEP = "#SP#"
  Endif
End RES

$ERR_CALL
  If dim(ERRCODE) > 0 : ERRCODE = errn : Endif
Resume

Subprog TRACE_ENABLE(TRACEON)
  Value Libelle TRACEON

  If dim(GXDT_TRACE) < 0
    Global Libelle GXDT_TRACE
  Endif
  GXDT_TRACE = TRACEON
End

Funprog IS_TRACE_ON()
  If dim(GXDT_TRACE) < 0
    End 0
  Endif
End GXDT_TRACE

Subprog TRACE(DBGT_LINE)
  Value Char DBGT_LINE()

  Onerrgo ERR_TRACE
  Openo filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0), -1 Using [XTR_]
  Wrseq date$ + "-" + time$ + ": " + DBGT_LINE Using [XTR_]

  Openo Using [XTR_]
  Onerrgo
End

Funprog TRACE_CLEAR
  Local Char TRNAME(255)
  TRNAME = filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0)
  Onerrgo ERR_TRACE
  Openo TRNAME, 0 Using [XTR_]
  Openo Using [XTR_]
  Onerrgo
End "Cleared " + TRNAME

$ERR_TRACE
Resume

#**
#* Check for authorization
#*
#* @param FUN
#*!
Funprog FUNAUTH(FUN)
Value Char FUN
  Local Char MSG(255), MSG2(255)
  Local Char F(50)
  MSG = "" : MSG2 = ""
  F = GFONCTION
  GFONCTION = toupper(FUN)

  If GPROFIL=""
    If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
    Read [AUS]CODUSR = GUSER
    MSG2 += "PU="+[F:AUS]PRFFCT + ","
    If [F:AUS]PRFFCT=""
      If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
      Read [AME]AME0 = [F:AUS]CODMET
      GPROFIL = [F:AME]PRFFCT
    Else
      GPROFIL = [F:AUS]PRFFCT
    Endif
  Endif
  MSG2 += "PA="+GPROFIL + ","

  Call AUTORIS From EXEFNC
  Onerrgo ERR_CALL
  Call SET_CURFCT("AECLIPSE",1,"") From PSADX
  Onerrgo

  MSG2 += "A=" + num$(GNBAUZ) + "/" + num$(GNBSITE) + ","
  MSG2 += "T=" + num$(adxtyp)
  If GNBAUZ=0
   If GNBSITE=0
    MSG = mess(33,104,1)
   Else
    MSG = mess(1,123,1)
   Endif
  Endif
  GFONCTION = F
  If len(MSG) > 0 : MSG += " (" + MSG2 + ")" : Endif
End MSG

Funprog VAL_TOOL_SUPPORTED()
  Local Integer OK : OK=0

  If dim(GXDT_VAL_TOOL) > 0 : End GXDT_VAL_TOOL : Endif
  Global Libelle GXDT_VAL_TOOL
  Call EXISTE_ADX("",[V]GDOSX3,"AVAL_TOOL",OK) From ORDSYS
  GXDT_VAL_TOOL = OK
End GXDT_VAL_TOOL

# Do not use ASESSIONS.ISMNGSESSIONS because the script has to work in any env including those without ASESSIONS scripts
Funprog ISMNGSESSIONS
  If dim(GXDT_MNGSESSIONS) > 0 : End GXDT_MNGSESSIONS : Endif
  Global Libelle GXDT_MNGSESSIONS
  GXDT_MNGSESSIONS = func PARTSEP(ver$(0),2," ")>="19r.202"
End GXDT_MNGSESSIONS

Funprog ISSCRIPTALLOWED(REPERT,CODE)
  Value    Char     REPERT : #"STC" or "TRT"
  Value    Char     CODE : #code without extension
  Local Integer ALLOWED : ALLOWED = 1
  If func VAL_TOOL_SUPPORTED
    Onerrgo ERR_CALL
    ALLOWED = func AVAL_TOOL.ISSCRIPTALLOWED(REPERT,CODE)
    Onerrgo
  Endif
End ALLOWED

Subprog VALID_EXTERNAL(REPERT,CODE,DOSSIER,OK,TABMES)
  Value    Char     REPERT : #"STC" or "TRT"
  Value    Char     CODE : #code without extension
  Value    Char     DOSSIER : #full folder server:port@@folder or folder for current app
  Variable Integer OK
  Variable Char     TABMES()(1..5)

  If func VAL_TOOL_SUPPORTED
    Onerrgo ERR_CALL
    Call VALID_EXTERNAL(REPERT, CODE, DOSSIER, OK, TABMES) From AVAL_TOOL
    Onerrgo
  Endif
End

Funprog KILL_VARIABLES()
  If dim(GXDT_TRACE) > 0
    Kill GXDT_TRACE
  Endif

  If dim(GXDT_JSON) > 0
    Kill GXDT_JSON
  Endif

  If dim(GXDT_NL_SEP) > 0
    Kill GXDT_NL_SEP
  Endif

  If dim(GXDT_VALUE_SEP) > 0
    Kill GXDT_VALUE_SEP
  Endif

  Call KILL_ENV_VARIABLES
End ""

#**
#* Ensure environment variables are initialized
#*!
Funprog ENSURE_ENV_VARIABLES()
  If dim(GXDT_LANG) < 0
    Global Char GXDT_LANG(10)
    GXDT_LANG = func GET_LANG()
  Endif

  If dim(GXDT_USER) < 0
    Global Char GXDT_USER(5)
    GXDT_USER = func GET_USER()
  Endif
End ""

Funprog KILL_ENV_VARIABLES()
  If dim(GXDT_LANG) > 0
    Kill GXDT_LANG
  Endif

  If dim(GXDT_USER) > 0
    Kill GXDT_USER
  Endif
End ""

#**
#* Check if there is enough disk space for the given file size
#*
#* @param SIZE the file size
#*!
Funprog CHECK_SPACE(SIZE)
Value Integer SIZE
Local Integer ERR_CODE
  Local Char PATH(255)
  Local Integer RES,I
  Local Schar PAD(1)
  PAD=chr$(0)
  Onerrgo ERR_CHK_SPACE
    PATH = filpath('tmp','dskspc'+num$(adxuid(2)),'')
    Openo PATH,0 Using [DSPC]
    For I=1 To SIZE
      Putseq 1, PAD Using [DSPC]
    Next
    Openo Using [DSPC]
    RES = (filinfo(PATH,7)= SIZE)
    Call EFFACE(PATH, ERR_CODE) From ORDSYS
  Onerrgo
End RES

$ERR_CHK_SPACE
RES=0
Resume


#**
#* Launch a program in Eclipse IDE (via http server)
#*
#* @param NOMFIC the source file name (eg : GTRAITE.src)
#* @param READONLY 1 for open readonly, 0 for open read/write
#*!
Subprog LAUNCH_TRT(NOMFIC, READONLY)
Value Char NOMFIC()
Value Integer READONLY
Local Integer NB_PARAM, I, ECLIPSE, FUSION
NB_PARAM=15
I=1
Local Char JAR_NAME(250)
Local Char JAR_FULLNAME(250)
Local Char JAR_EXT(10)
Local Char PARAM_NAME(250)(1..NB_PARAM)
Local Char PARAM_VALUE(250)(1..NB_PARAM)
Local Char RESULT(250)
Local Char USER(5)

Onerrgo ERR_LAUNCH

ECLIPSE = (func GET_PARAM_("AECLIPSE")="2")
FUSION = (dim(GFUSION)>0 & GFUSION)

JAR_NAME="ideclient"
JAR_EXT="jar"
JAR_FULLNAME=JAR_NAME + "." + JAR_EXT

# set parameters
PARAM_NAME(I)="folder"
PARAM_VALUE(I) = func GET_FOLDER(NOMFIC)
If PARAM_VALUE(I) = ""
  PARAM_VALUE(I)=nomap
Endif

I+=1
PARAM_NAME(I)="server"
PARAM_VALUE(I)=tolower(GMACADO)

I+=1
PARAM_NAME(I)="port"
PARAM_VALUE(I)=num$(adxtcp)

I+=1
PARAM_NAME(I)="src"
PARAM_VALUE(I)=NOMFIC

I+=1
PARAM_NAME(I)="readonly"
If READONLY = 1
  PARAM_VALUE(I)="true"
Else
  PARAM_VALUE(I)="false"
Endif

I+=1
PARAM_NAME(I)="trace"
PARAM_VALUE(I)="false"

I+=1
PARAM_NAME(I)="x.origin"
PARAM_VALUE(I)=func GET_BASEURL

I+=1
PARAM_NAME(I)="x.lang"
PARAM_VALUE(I)=func GET_LANG()

USER = func GET_USER()

I+=1
PARAM_NAME(I)="x.user"
PARAM_VALUE(I)=USER

Local Char PWD(50)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = USER
If fstat=0
  PWD=[F:AUS]NEWPAS
Else
  PWD="error"
Endif

I+=1
PARAM_NAME(I)="x.pwd"
PARAM_VALUE(I)=PWD

I+=1
PARAM_NAME(I)="x.osuser"
PARAM_VALUE(I)=adxcus

I+=1
PARAM_NAME(I)="x.ospwd"
PARAM_VALUE(I)=adxcpw


# check if jar file is available (not necessary in convergence client as we do not use the jar)
If !FUSION
 Local Char INFOFILE(GDIMFIC)(3)
 Local Integer INFORET
 INFORET = func GET_X3CLI_FILE_INFO(JAR_NAME, JAR_EXT, INFOFILE)

 If (INFORET <> 0)
   # Execution impossible - Error when opening file: ...
   Errbox mess(160,115,1) + " - " + mess(10,137,1) + chr$(13)
&   + "'" + INFOFILE(0) + "'" + chr$(13)
   End
 Endif
Endif
# hack to reset errnRemote to 0 by calling a function that should never failed
#If errnRemote <> 0
#  Calliu "XDT_ECLI:setIDERights" With 532250
#Endif
# @see http://ecintradon2/wiki/index.php/Eclipse/Lanceur_ideclient
Local Integer ERRIU__
RESULT = Funciu "XDT_ECLI:openSRC" With (JAR_FULLNAME, PARAM_NAME, PARAM_VALUE)
Kill ERRIU__

Onerrgo

End

$ERR_LAUNCH
If dim(ERRIU__) > 0 & errm <> ""
  Errbox errm + chr$(13)
& + "[" + errp + ":" + num$(errl) + "]"
Else
  # Execution impossible - Verifier votre installation :
  # 'SAFE X3 Studio for Eclipse'
  # Cette application n'est pas configuree sur votre poste. Veuillez contacter l'administrateur du systeme.
  Errbox mess(160,115,1) + " - " + mess(2,9119,1) + " :" + chr$(13)
& + "'SAFE X3 Studio for Eclipse'" + chr$(13)
& + mess(22, 9137,1) + chr$(13)
& + "[" + errmes$(errn) + " (" + num$(errn) + ")]" + chr$(13)
& + "[" + errp + ":" + num$(errl) + "]"
Endif
Resume

#**
#* Return application name by replacing empty name by the current application
#*
#* @param APPL the application name
#*!
Funprog FOLDER_NAME(APPL)
 Value Char APPL()
 If len(APPL)=0 : End nomap : Endif
 If APPL="/" : End nomap(2) : Endif
End APPL

#**
#* Return folder where source file could be found
#*
#* @param SOURCEFILE source name (without extension)
#*!
Funprog GET_FOLDER(SOURCEFILE)
Value Char SOURCEFILE()

If SOURCEFILE = ""
  End ""
Endif

Local Char SOURCENAME(250)
Local Char FOLDR(250)
Local Char WNAME(GDIMFIC)
Local Integer POSEXT
POSEXT = instr(0, SOURCEFILE, ".")
If POSEXT > 0
  SOURCENAME = left$(SOURCEFILE, POSEXT - 1)
Else
  SOURCENAME = SOURCEFILE
Endif

Local Integer I
For I = 0 To dim(nomap) - 1
  If nomap(I) <> ""
    WNAME = filpath("TRT", SOURCENAME, "src", I)
    If filinfo(WNAME, 0) >= 0
      FOLDR = nomap(I)
      Break
    Endif
  Endif
Next I
End FOLDR

#**
#* Return <code>0</code> if file exists in the X3CLI directory and
#* <code>1</code> if it not exists
#* @param FILE_NAME
#* @param FILE_EXT
#*!
Funprog GET_X3CLI_FILE_INFO(FILE_NAME, FILE_EXT, INFO)
Value Char FILE_NAME
Value Char FILE_EXT
Variable Char INFO()()

Local Char REP(GDIMFIC)
Local Char NAMEREP(GDIMFIC)
Local Integer RETVAL

REP = "X3_ROOT/X3CLI"
# == get filename ==
#NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB", "", adxmac(-1))
# without adxmac to get the right machine in case of running in a process server
NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB")
INFO(0) = NAMEREP
# == get size ==
INFO(1) = num$(filinfo(NAMEREP,7))
#Infbox "ret=" + num$(FILE_ERR)
If val(INFO(1)) > 0
#  Infbox mess(101,100,1) + " : " + NAMEREP
  # == get modification date ==
  INFO(2) = num$(filinfo(NAMEREP,9))
  RETVAL = 0 : #OK
Else
  RETVAL = 1 : #KO
Endif

End RETVAL

