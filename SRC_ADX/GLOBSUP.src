#<AdxTL>@(#)11.0.0.0 $Revision$
# Ne pas définir de variables dans GLOBVAR
# Ce programme est réservé au superviseur

Call DEFVAR
Call INIVAR
Call MESSAGE("Variables globales initialisées") From GESECRAN
End

###########################################################
# Définition des variables
###########################################################
Subprog DEFVAR

Onerrgo ERRGLOB From GLOBVAR

Local Integer  OKTRT

If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR   [TCU] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT  [TUN] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif

# Définition des variables globales
Call DEFVAR From WWAGLOBSUP

# Init supplementaires
Call INIEURO
Call INILNK
Call INIROLE
Call INIOBJ

# Présence du fichier sophia_gaillard
Global Integer GSOPHIA
GSOPHIA = (filinfo(filpath("","sophia_gaillard","",nomap),0)>0)

# Pour les ruptures de transaction (moulinettes de passage de version)
If dim(GMAXUPDTRS)<=0
 Global Integer GMAXUPDTRS
Endif
If GMAXUPDTRS=0
 GMAXUPDTRS = 1000
Endif

# Pour les produits qui n'ont pas l'interface compta
If dim([V]GLONCCE)<=0
 Global Integer GLONCCE
 GLONCCE = 10
Endif

GADDCPY = 2
GADDFCY = 3

# Interface compta
Call INT_COMPTA



###########################################################
## Variables propres à chaque produit
###########################################################

If GADONIX<>2 or !find(GPRODUIT,-1,-2)
 Case GPRODUIT
  When 0 : Call DEFVAR From GLOBX3
           Call DEFVAR From GLOBIMM
           Call EXISTE_ADX("","","GLOBPAY",OKTRT) From ORDSYS
           If OKTRT
            Call DEFVAR From GLOBPAY :#HRM inside ERP X3
           Endif
  When 1 : Call DEFVAR From GLOBGEO
  When 2 : Call DEFVAR From GLOBPAY :#HRM like a BOB
  When 3 : Call DEFVAR From GLOBIMM
  When 4 : Call DEFVAR From GLOBLOAN
 Endcase
Endif

If GPRODUIT=-1 : ## GEODE
 Global Char GFCY(3)       : # Site courant
 Global Char GDEP(10)      : # Déposant courant
 Global Integer  GMULSIT   : # Multi-sites
 Global Integer  GMULDEP   : # Multi-déposants
Endif

# Point d'entrée

GPOINT = "OUVRE" : Gosub ENTREE From EXEFNC
End

##############
$ERR_DOSCPT
ERRCPT = errn
Resume

###########################################################
Subprog  INT_COMPTA
Local Integer RET , SERVICE

If dim(GSOLCPT)<=0 : Global Char GSOLCPT(20) : Endif
Call PARAMLINK(nomap,2,GMACCPT,SERVICE,GDOSCPT,GSOLCPT,RET) From INTRUTILA
GPORTCPT = num$(SERVICE)

GCPT130 = 0
GCPT140 = 0

If RET
 Raz GTABCPT, GPORTCPT, GMACCPT, GDOSCPT, GSOLCPT
Else
 If GMACCPT<>"" & GPORTCPT<>""
  GTABCPT = GMACCPT+":"+GPORTCPT+"@"+GDOSCPT+"."
 Else
  GTABCPT = GDOSCPT+"."
 Endif
 Local Integer ERRCPT
 Onerrgo ERR_DOSCPT
 Local File =GTABCPT+"ADOVAL" [A_DW]
 If !ERRCPT
  Read [A_DW]ADW0 = "";"";"RELEASE"
  If !ERRCPT & !fstat & val([F:A_DW]VALEUR)<14
   GCPT130 = 1
  # PAYE V5 qui se déverse dans compta V140
  Elsif !ERRCPT & !fstat & val([F:A_DW]VALEUR)<25
   GCPT140 = 1
  Endif
  Close Local File [A_DW]
 Endif
 Onerrgo ERRGLOB From GLOBVAR
 If ERRCPT
  Call ERREUR(left$(GTABCPT,len(GTABCPT)-1)-":"-mess(124,125,1)) From GESECRAN
  # Dossier comptable inaccessible
 Endif
Endif
End

###########################################################
# Initialisation des variables
###########################################################
Subprog INIVAR

Onerrgo ERRGLOB From GLOBVAR

Local Char VALPAR(30)
Local Integer  OKTRT

If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

###########################################################
## Variables communes à tous les produits
###########################################################
## Superviseur
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL

## Sociétés/sites
Call INISOC

## Euro
Call INIEURO

## Devises
Call INIDEV

## Unités
Call INIUNT

## Licence
#Call LICENCE

###################################
## "Tronc commun compta"
###################################
# Nb d'axes analytiques
Read [ACV]CODACT = "ANA"
#GOPTCANA = max(0,min([F:ACV]DIME,9))
GOPTCANA = max(0,[F:ACV]DIME)

## Divers
GAXE = 1 : # Ne doit jamais valoir 0 pour des pb d'affichage
GACCOBJ  = "GAC"

## Gestion des taxes
Read [ACV]CODACT = "VAT"
If !fstat
 GCPTVAT = [F:ACV]FLACT
Else
 GCPTVAT = 2
Endif

# TVA Portugais
Read [ACV]CODACT = "KPO"
If !fstat & [F:ACV]FLACT=2
 GPORTVA = 1
Else
 GPORTVA = 0
Endif

## <PP IAS>
# Gestion IAS
Read [ACV]CODACT = "IAS"
If !fstat & [F:ACV]FLACT=2 : GIAS = 1 : Else : GIAS = 0 : Endif
## <Fin PP IAS>

GVERSION = "1.9.0" : # Pour le superviseur

###########################################################
## Variables propres à chaque produit
###########################################################
If GADONIX<>2 or !find(GPRODUIT,-1,-2)
 Case GPRODUIT
  When 0  : Call INIVAR From GLOBX3
            Call INIVAR From GLOBIMM
            Call EXISTE_ADX("","","GLOBPAY",OKTRT) From ORDSYS
            If OKTRT
             Call INIVAR From GLOBPAY :#HRM inside ERP X3
            Endif
  When 1  : Call INIVAR From GLOBGEO
  When 2  : Call INIVAR From GLOBPAY :#HRM like a Bob
  When 3  : Call INIVAR From GLOBIMM
  When 4  : Call INIVAR From GLOBLOAN
 Endcase
Endif
End

##############################################################
## Init des tables société/sites                            ##
##############################################################
Subprog INISOC
Local Char    CHAINE(250)
Local Integer I
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Raz GNBSOC
For [CPY]
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 If dim([F:CPY]ACCCUR)>0
  GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 Else
  GDEVSOC(GNBSOC) = ""
 Endif
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 If dim(GTYPSOC)>0
  GTYPSOC(GNBSOC) = [F:CPY]CPYLEGFLG
 Endif
 If dim(GGCMSOC)>0
  If dim([F:CPY]ACM)>0
   GGCMSOC(GNBSOC) = [F:CPY]ACM
  Else
   GGCMSOC(GNBSOC) = ""
  Endif
 Endif
Next
Raz GNBSITE
For [FCY]
 GNBSITE += 1
 GSITE(GNBSITE)    = [F:FCY]FCY
 GSOCSITE(GNBSITE) = [F:FCY]LEGCPY
 GFINSITE(GNBSITE) = [F:FCY]FINRSPFCY
 #----------------------------------------------#
 # si le site financier n'est pas renseigné     #
 # dans ce cas le site est lui même financier   #
 #----------------------------------------------#
 If GFINSITE(GNBSITE)  = ""
  GFINSITE(GNBSITE) = [F:FCY]FCY
 Endif
Next
# GDEFSOC = GSOC(1) : # Pour l'instant
GDEFFIN = ""      : # A voir
If dim([V]GNBLEG)<=0
 Global Integer GNBLEG
 Global Char GDOSLEG(GLONADI)(1..20)
Endif
Call SETLEG("",GDOSLEG,GNBLEG) From DOSCONT
If GNBLEG=0
 Case GPAYS
  When "GB"  : GDOSLEG(1) = "BRI" : GNBLEG = 1
  When "FR"  : GDOSLEG(1) = "FRA" : GNBLEG = 1
  When "IT"  : GDOSLEG(1) = "ITA" : GNBLEG = 1
  When "PT"  : GDOSLEG(1) = "POR" : GNBLEG = 1
  When "ES"  : GDOSLEG(1) = "SPA" : GNBLEG = 1
  When "US"  : GDOSLEG(1) = "USA" : GNBLEG = 1
  When "DE"  : GDOSLEG(1) = "GER" : GNBLEG = 1
  When "CN"  : GDOSLEG(1) = "CHI" : GNBLEG = 1
 Endcase
Endif
End

#############################################
## Init variables euro                     ##
#############################################
Subprog INIEURO
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If GEURO="" : # Code de l'euro
 GEURO = "EUR"
Endif
Read [TCU]TCU0 = GEURO
GEURODEV = [F:TCU]CURRND
End

#############################################
# Init des formats des devises
#############################################
Subprog INIDEV
If clalev([F:TCU])=0 : Local File TABCUR  [TCU] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If GDIMDEV<nbrecord([TCU])+10
 GDIMDEV = max(nbrecord([TCU])+20,100)
 Kill GDEVISE, GDEVFMT1, GDEVDAT
 Global Char    GDEVISE(GLONCUR)(1..GDIMDEV)
 Global Char    GDEVFMT1(10)(1..GDIMDEV)
 Global Date    GDEVDAT(1..GDIMDEV)
Endif
GNBDEV = 0
## Au cas où GSYSCUR est encore utilisée
If dim(GSYSCUR)>0
 If dim(GCURSHR)>0
  If GCURSHR=""
   GCURSHR = GSYSCUR
  Else
   GSYSCUR = GCURSHR
  Endif
 Endif
Endif
## Pour optimiser le find, on met les devises les + fréquentes en premier
If dim(GCURSHR)>0 & GCURSHR<>"" & !find(GCURSHR,GDEVISE(1..GNBDEV))
 GNBDEV += 1
 GDEVISE(GNBDEV) = GCURSHR
 Read [TCU]TCU0 = GCURSHR
 GDEVFMT1(GNBDEV) = [F:TCU]CURFMT1+"#"
 GDEVDAT(GNBDEV)  = [F:TCU]EURDAT
 If [F:TCU]EURFLG<>2 : GDEVDAT(GNBDEV) = [31/12/2999] : Endif
Endif
For [CPY]CPY0 Where CPYLEGFLG=2
 If dim([F:CPY]ACCCUR)>0 & !find([F:CPY]ACCCUR,GDEVISE(1..GNBDEV))
  GNBDEV += 1
  GDEVISE(GNBDEV) = [F:CPY]ACCCUR
  Read [TCU]TCU0 = [F:CPY]ACCCUR
  GDEVFMT1(GNBDEV) = [F:TCU]CURFMT1+"#"
  GDEVDAT(GNBDEV)  = [F:TCU]EURDAT
  If [F:TCU]EURFLG<>2 : GDEVDAT(GNBDEV) = [31/12/2999] : Endif
 Endif
Next
For [TCU]TCU0
 If !find([F:TCU]CUR,GDEVISE(1..GNBDEV))
  GNBDEV += 1
  GDEVISE(GNBDEV)  = [F:TCU]CUR
  GDEVFMT1(GNBDEV) = [F:TCU]CURFMT1+"#"
  GDEVDAT(GNBDEV)  = [F:TCU]EURDAT
  If [F:TCU]EURFLG<>2 : GDEVDAT(GNBDEV) = [31/12/2999] : Endif
 Endif
Next
End

##############################################
# Table des unités
#############################################
Subprog INIUNT
Local Shortint WDEC, WQTY, I
Local Libelle  DIMGDEC
DIMGDEC=(dim([V]GUNTDEC)>0)

If clalev([F:TUN])=0 : Local File TABUNIT  [TUN] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif

If GDIMUNT<nbrecord([TUN])+10
 GDIMUNT = max(nbrecord([TUN])+20,100)
 Kill GUNITE, GUNTFMT1
 Global Char GUNITE(GLONUOM)(1..GDIMUNT)
 Global Char GUNTFMT1(10)(1..GDIMUNT)
 If DIMGDEC
  Kill GUNTDEC
  Global Shortint GUNTDEC(1..GDIMUNT)
 Endif
Endif

Read [ATY]CODTYP = "QTY"
If !fstat
 WQTY = [F:ATY]LNGTYP
Else
 WQTY = 15
Endif

GNBUNT = 0
GNBUNT += 1 : GUNITE(GNBUNT) = "0" : GUNTFMT1(GNBUNT) = num$(int(WQTY))+"F"
If DIMGDEC : GUNTDEC(GNBUNT) = 0 : Endif
If GPRODUIT=1 : ## GEODE
 GNBUNT += 1 : GUNITE(GNBUNT) = "#" : GUNTFMT1(GNBUNT) = num$(WQTY)+"#"
 If DIMGDEC : GUNTDEC(GNBUNT) = 0 : Endif
Endif
For I=1 To 6
 GNBUNT+=1 : GUNITE(GNBUNT)=num$(I) : GUNTFMT1(GNBUNT)=num$(WQTY-I)+"."+num$(I)+"#"
 If DIMGDEC : GUNTDEC(GNBUNT) = I : Endif
Next I
#
## Y-a-t-il des unités plus fréquentes ??
For [TUN]TUN0
 GNBUNT += 1
 WDEC = [F:TUN]UOMDEC
 If WDEC < 0 : # théorique
  GUNTFMT = num$(int(WQTY))+"F"
 Elsif WDEC = 0
  GUNTFMT = num$(WQTY)+"#"
 Else
  GUNTFMT = num$(WQTY-WDEC)+"."+num$(WDEC)+"#"
 Endif
 GUNITE(GNBUNT)   = [F:TUN]UOM
 GUNTFMT1(GNBUNT) = GUNTFMT
 If DIMGDEC : GUNTDEC(GNBUNT)  = max(0,WDEC) : Endif
Next
End

#############################################
# Table des codes sémantiques
#############################################
Subprog INILNK

Call DEFVAR From WWAGLOBLNK

If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
GNBLNK = 0
For [ADI]CODE Where NUMTAB=61
 GNBLNK += 1
 GCODLNK(GNBLNK) = [F:ADI]CODE
 GINVLNK(GNBLNK) = [F:ADI]A1
 Call LECTEXTRA(GLIBLNK(GNBLNK),"ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From ATEXTRA
 If GNBLNK>=dim(GCODLNK) : Break : Endif
Next
End

#############################################
# Table des rôles
#############################################
Subprog INIROLE

Call DEFVAR From WWAGLOBROLE

If clalev([F:ARL])=0 : Local File AROLE [ARL] : Endif
GNBROLE = 0
For [ARL]ARL0
 GNBROLE += 1
 GROLE(GNBROLE)    = [F:ARL]ROL-[F:ARL]OBJ
 GFLDROLE(GNBROLE) = [F:ARL]FLD
 If GNBROLE>=dim(GROLE) : Break : Endif
Next
End

#############################################
# Liste des objets
#############################################
Subprog INIOBJ

Call DEFVAR From WWAGLOBOBJ

Local File AOBJET [AOB_]
Columns [AOB_] (ABREV,TYPGES)
GNBOBJ = 0
For [AOB_] Where TYPGES<4
 GNBOBJ += 1
 GCODOBJ(GNBOBJ) = [F:AOB_]ABREV
Next AOB_
Close Local File [AOB_]
End

## Pour le superviseur

Subprog VERCOM(VERSION)
Variable Char VERSION
VERSION= "V9" : # Pour le superviseur
End
