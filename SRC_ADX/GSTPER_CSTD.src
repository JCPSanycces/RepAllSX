#<AdxTL>@(#)0.0.0.0 $Revision$
# Class GSTPER
######################################################################################
# Handling class GSTPER : GST reporting periods (for Australian GST reporting)
#
# Caution, programming model is hybrid.
#
# Author : Bader
# History:
# 2018-01-04  DNE   Propagate the GST grouping to all lines
# 2018-01-17  Bader PROPERTY_DATSTR_CONTROL/PROPERTY_DATEND_CONTROL check ranges for GST period = "Quarterly"
# 2018-01-17  Bader Call the correct messages from local menu 7704
# 2018-03-09  Bader remove alphanumerical CODGSTPER & rename numerical CODGSTPER1 to CODGSTPER
# 2018-03-21  DNE   Prevent problems with empty DATSTR and DATEND properties.
######################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
Return
$EVENTS
Case [L]CURPTH
    When ""
        Case [L]AEVENT
            When "AREAD_AFTER"            : Gosub EVENT_READ_AFTER
            When "AINSERT_CONTROL_BEFORE" : Gosub INSERT_CONTROL_BEFORE  # Before insert and before field controls
            When "ADELETE_CONTROL_BEFORE" : Gosub DELETE_CONTROL_BEFORE  # Before delete
            When "ADELETE_AFTER"          : Gosub DELETE_AFTER
        Endcase
    When "LINES"
        Case [L]AEVENT
            When "ADDLINE_AFTER"          : Gosub LINES_ADDLINE_AFTER
        Endcase
Endcase
Return




#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "CODGSTGRP"
            Case [L]ARULE
                When "PROPAGATE"      : Gosub PROPAGATE_CODGSTGRP
            Endcase
        When "CODGSTPER"
            Case [L]ARULE
                When "PROPAGATE"      : Gosub PROPAGATE_CODGSTPER
            Endcase
        When "DATSTR" : Gosub PROPERTY_DATSTR
        When "DATEND" : Gosub PROPERTY_DATEND
        When "PREDAT"
            Case [L]ARULE
                When "CONTROL"        : Gosub PROPERTY_PREDAT_CONTROL
            Endcase
        When "GSTGRPSTA"
            Case [L]ARULE
                When "INIT"           : this.GSTGRPSTA = 1 # "In review"
            Endcase
        When "FLGPRE"
            Case [L]ARULE
                When "INIT"           : this.FLGPRE = 1 # Uncheck "Include unreported transaction"
            Endcase
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

$LINES_ADDLINE_AFTER
    this.CODGSTGRP = this.APARENT.CODGSTGRP
    this.CODGSTPER = this.APARENT.CODGSTPER
    this.LIN = 1 + max(this.APARENT.LINES(1..maxtab(this.APARENT.LINES)).LIN)
Return

########################################################################################################################

$EVENT_READ_AFTER
    this.GSTPER = func SET_GSTPER(this.CODGSTGRP)
Return

$INSERT_CONTROL_BEFORE
    Local Char WMESSAGE(250)
    Local Char WCOMP(250)
    Local Char CODPER1(8)

    # Create CODGSTPER
    If this.CODGSTPER=AVOID.AINT
        #call NUMERO
        [L]ASTATUS = func ANM_TOOL.NUMERO(this.ACTX,"GSTP1","",date$,"",CODPER1,WMESSAGE)
        If [L]ASTATUS>= [V]CST_AERROR
           [L]ASTATUS = fmet this.ASETERROR ("CODGSTPER", WMESSAGE, [V]CST_AERROR)
        Else
           this.CODGSTPER = val(CODPER1)
        Endif
    Endif
    If this.CODGSTPER = AVOID.AINT
        # 'Mandatory field'
        [L]ASTATUS = fmet this.ASETERROR ("CODGSTPER", mess(10,123,1), [V]CST_AERROR)
    Endif
    # no creation with status closed
    If this.GSTGRPSTA = 3
        # 'Creation of a period with status closed is not allowed.'
        [L]ASTATUS = fmet this.ASETERROR ("", mess(34,7704,1), [V]CST_AERROR)
    Endif
Return

$DELETE_CONTROL_BEFORE
    If this.GSTGRPSTA = 3 Then # Closed
        # Deletion is not allowed.
        [L]ASTATUS = fmet this.ASETERROR ("", mess(32,7704,1), [V]CST_AERROR) # 'Deletion is not allowed.'
    Endif
Return

$DELETE_AFTER
Local Tinyint ERRCOD : ERRCOD = 0
    Call CLEANPERIODDATA(this.CODGSTPER, this.CODGSTGRP, ERRCOD) From GSTAUSLIB
    If ERRCOD
         # 'Deletion not possible'
        [L]ASTATUS = fmet this.ASETERROR ("",  mess(54,123,1), [V]CST_AERROR)
    Endif
Return
########################################################################################################################

$HANDLE_CPYLST
Local Integer NI, FOUND, LIN
Local File GSTGRPD [GRPD]
  FOUND = 0
  Filter [F:GRPD] Where CODGSTGRP = this.CODGSTGRP
  Read [F:GRPD] First
  For NI = 1 To maxtab(this.LINES)    # check if correct companies already loaded
    If this.LINES(NI) <> null and find(this.LINES(NI).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0 and this.LINES(NI).CPY = [F:GRPD]CPY Then
      FOUND = 1
      Break
    Endif
  Next NI
  If not FOUND                        # wrong companies loaded > remove them and load correct ones
    For NI = 1 To maxtab(this.LINES)
      If this.LINES(NI) <> null and find(this.LINES(NI).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0 Then
         ASTATUS = fmet this.ADELLINE("LINES" ,this.LINES(NI).AORDER)
      Endif
    Next NI
    For [F:GRPD]                      # insert all companies of the group
      LIN = fmet this.ADDLINE("LINES" , maxtab(this.LINES))
      If LIN<>[V]CST_ANOTDEFINED      # If the addition is allowed
          SetInstance this.LINES(LIN) With [F:GRPD]
      Endif
    Next
  Endif
  Filter [F:GRPD]
  LogicClose File [GRPD]
Return

#######################################################################################

$PROPAGATE_CODGSTGRP
    Gosub HANDLE_CPYLST
    this.GSTPER = func SET_GSTPER(this.CODGSTGRP)
Return


#######################################################################################
$PROPAGATE_CODGSTPER
Local Integer NI

    # Propagate period code to all lines.
    For NI = 1 To maxtab( this.LINES )
        If this.LINES(NI) <> null and find(this.LINES(NI).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
            this.LINES(NI).CODGSTPER = this.CODGSTPER
        Endif
    Next NI
Return


########################################################################################################################

$PROPERTY_DATSTR
    Case [L]ARULE
        When "CONTROL" : Gosub PROPERTY_DATSTR_CONTROL
    Endcase
Return

$PROPERTY_DATSTR_CONTROL
    If this.DATSTR = AVOID.ADATE # 2018-03-21 DNE X3-70030
        # 'Mandatory field'
        [L]ASTATUS = fmet this.ASETERROR ( "DATSTR", mess(10,123,1), [V]CST_AERROR )
        Return
    Endif
    If this.DATSTR <> addmonth(eomonth(this.DATSTR) + 1, -1) Then
        # 'Period start date has to be the start date of the month.'
        ASTATUS = fmet this.ASETERROR("", mess(35,7704,1), [V]CST_AERROR)
    Endif
    If this.DATSTR > this.DATEND Then
        # 'Period start date has to be prior to its end date.'
        ASTATUS = fmet this.ASETERROR("", mess(31,7704,1), [V]CST_AERROR)
    Endif
    If this.GSTPER = 2                        # Quarterly
        If mod(month(this.DATSTR),3) <> 1     # Begin of quarter?
            # 'Period start date and end date have to match a calendar quarter.'
            ASTATUS = fmet this.ASETERROR("", mess(38,7704,1), [V]CST_AERROR)
        Endif
    Endif
Return

$PROPERTY_DATEND
    Case [L]ARULE
        When "CONTROL" : Gosub PROPERTY_DATEND_CONTROL
    Endcase
Return

$PROPERTY_DATEND_CONTROL
    If this.DATSTR = AVOID.ADATE # 2018-03-21 DNE X3-70030
        # 'Mandatory field'
        [L]ASTATUS = fmet this.ASETERROR ( "DATSTR", mess(10,123,1), [V]CST_AERROR )
        Return
    Endif
    If this.DATEND <> eomonth(this.DATEND) Then
        # 'Period end date has to be the end date of the month.'
        ASTATUS = fmet this.ASETERROR("", mess(36,7704,1), [V]CST_AERROR)
    Endif
    If this.GSTPER = 1 Then                   # Monthly
        If month(this.DATSTR) <> month(this.DATEND) Then
            # 'Period start date and end date have to be in the same month.'
            ASTATUS = fmet this.ASETERROR("", mess(37,7704,1), [V]CST_AERROR)
        Endif
    Else                                      # Quarterly
        If mod(month(this.DATEND),3) <> 0 or month(this.DATSTR)+2 <> month(this.DATEND)    # End of quarter?
            # 'Period start date and end date have to match a calendar quarter.'
            ASTATUS = fmet this.ASETERROR("DATEND", mess(38,7704,1), [V]CST_AERROR)
        Endif
    Endif
Return

Funprog SET_GSTPER(VCODGSTGRP)
    Value Char VCODGSTGRP()
    Local Integer RESULT

    Local File GSTGRP [GSTGH]
    Read [F:GSTGH]GSTGH0 = VCODGSTGRP
    If fstat = 0 Then
        [L]RESULT = [F:GSTGH]GSTPER
    Endif
    LogicClose File [GSTGH]
End [L]RESULT

$PROPERTY_PREDAT_CONTROL
  If this.FLGPRE = 2
    If this.PREDAT = [0/0/0] or this.PREDAT >= this.DATSTR
      # 'Please enter a date prior the start date of the reporting period.'
      ASTATUS = fmet this.ASETERROR("PREDAT",mess(45,7704,1), [V]CST_AERROR)
    Endif
  Endif
Return

