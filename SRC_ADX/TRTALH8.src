#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ALH8","TRTALH8","",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

$DEBUT
 NOLIG = val(PARAM)
 [M:ALH8]FONT      = [M:ALH1]FONT(NOLIG)
 [M:ALH8]UNDERLINE = [M:ALH1]UNDERLINE(NOLIG)
 [M:ALH8]BOLD      = [M:ALH1]BOLD(NOLIG)
 [M:ALH8]ITALICS   = [M:ALH1]ITALICS(NOLIG)
 Affzo [M:ALH8]
Return

$OK
 NOLIG = val(PARAM)
 [M:ALH1]FONT(NOLIG)      = [M:ALH8]FONT
 [M:ALH1]UNDERLINE(NOLIG) = [M:ALH8]UNDERLINE
 [M:ALH1]BOLD(NOLIG)      = [M:ALH8]BOLD
 [M:ALH1]ITALICS(NOLIG)   = [M:ALH8]ITALICS
 Affzo [M:ALH1]
Return
