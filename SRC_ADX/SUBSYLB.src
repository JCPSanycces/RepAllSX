##########################################################################################################
#  Sous programmes pour la gestion de de la transcodification lors synchronisation Outlook CRM 21/02/2006
##########################################################################################################

##########################################################################################################
# SYLINITCPT : initialisation du compteur synchronisation pour SYNCLINK

# SYLWRITE   : Ecriture d'une anomalie de synchonisation

# SYLDELETE  : Suppression d'une anomalie de synchonisation


##########################################################################################################
Subprog SYLINITCPT (SZSYLCPT ,IERRINF,ICHAPTER,IBRETOUR)
Variable Char SZSYLCPT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Variable Integer IBRETOUR
#------------------------------------------------------------#
# --> Récupération du code compteur synchronisation données  #
#------------------------------------------------------------#
IBRETOUR =1

If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
Read [TCA] TCA0=13
If fstat
    IERRINF=64
    ICHAPTER=199
    IBRETOUR=0
    End
Endif
SZSYLCPT=[F:TCA]CODNUM(9)
End




##########################################################################################################
#Ecriture d'une anomalie de synchonisation
Subprog  SYLWRITE ( SZSYLUSR, SZSYLTYP,  SZSYLKEY ,SYLFIE, SYLVALOTK,
&                   IERRINF,ICHAPTER,IBRETOUR)

Value Char SZSYLUSR
Value Char SZSYLTYP
Value Char SZSYLKEY 
Value Char SYLFIE
Value Char SYLVALOTK()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR


Local Char SZSYLCPT 
Local Char SZSYLNUM
Local Integer STAT
Local Char SZSITE(GLONFCY)

SZSYLCPT =""
SZSYLNUM=""
SZSITE=""
STAT=0

If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif

Call SYLINITCPT (SZSYLCPT ,IERRINF,ICHAPTER,IBRETOUR)
If IBRETOUR = 0 
    # problème lors de la récupération du compteur
    IERRINF = 60
    ICHAPTER = 199
    IBRETOUR = 0
    End
Endif

Call NUMERO (SZSYLCPT ,SZSITE,date$,"",SZSYLNUM,STAT) From SUBANM
If STAT <> 0
    # problème lors de la récupération du compteur
    IERRINF = 60
    ICHAPTER = 199
    IBRETOUR = 0
    End
Endif

[F:SYL]SYLNUM = SZSYLNUM
[F:SYL]SYLUSR = SZSYLUSR 
[F:SYL]SYLTYP = SZSYLTYP
[F:SYL]SYLKEY = SZSYLKEY 
[F:SYL]SYLFIE = SYLFIE
[F:SYL]SYLVALOTK = SYLVALOTK
[F:SYL]SYLVALADX = ""
[F:SYL]SYLFLGDPT = 1
[F:SYL]SYLNIV=0
[F:SYL]CREUSR= GUSER
[F:SYL]CREDAT = date$

Write [SYL]
If fstat
    #Erreur lors de la création des données pour la synchronisation
    IERRINF = 210
    ICHAPTER = 177
    IBRETOUR = 0
    End
Endif

End 


##########################################################################################################
Subprog SYLDELETE( SZSYLTYP , SZKEY, IERRINF,ICHAPTER,IBRETOUR)

Value Char SZKEY
Value Char SZSYLTYP

Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

IBRETOUR = 1

If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif

#On supprime les données de transcodification de type non traité
Delete [SYL] Where  [F:SYL]SYLTYP=SZSYLTYP and [F:SYL]SYLKEY=SZKEY and SYLFLGDPT=1
If fstat
    #Erreur lors de la suppression des données de transcodification
    IERRINF = 253
    ICHAPTER = 177
    IBRETOUR = 0
    End
Endif

IBRETOUR = 1

End


