##################################################################################################################

##################################################################################################################
# $INI_PURPRITYP - Initializing of the amount type PURPRITYP. Called from SUBBIS/C_BPR, SUBBIS/AM_BPR, IMPBIS
# The amount type is initialized with supplier or supplier category or parameter PURPRITYP.
# The amount type can be changet always.
##################################################################################################################
$INI_PURPRITYP
## In case of 'Rebate on VAT' Option, the invoice has to be entered in 'Ex Tax'
## In case of 'Rebate on exempt VAT' Option, the invoice has to be entered in 'Ex Tax' <100922>
If GDEPMGTMOD=1 or (GDEPMGTMOD = 5 & func INVDEPLIB.DSCSFI([M:BIS1]DEP))
 [M:BIS1]PURPRITYP = 1 : Grizo [M:BIS1]PURPRITYP
Elsif [F:BPS]PURPRITYP <> 0
   [M:BIS1]PURPRITYP = [F:BPS]PURPRITYP
Else
   If !clalev([F:BSG])  : Local File BPSCATEG  [BSG]  : Endif
   Read [BSG]BSG0 = [F:BPS]BSGCOD
   If !fstat
      [M:BIS1]PURPRITYP = [BSG]PURPRITYP
   Endif

   If [M:BIS1]PURPRITYP = 0
      If dim(GPURPRITYP)>0
         [M:BIS1]PURPRITYP = GPURPRITYP
      Endif
   Endif

   If [M:BIS1]PURPRITYP = 0
      [M:BIS1]PURPRITYP = 1
   Endif
Endif

[M:BIS3]PURPRITYP = [M:BIS1]PURPRITYP
Affzo [M:BIS1]PURPRITYP
Affzo [M:BIS3]PURPRITYP

Return

##################################################################################################################
# Subprog SETCOLOR - Called from SUBBIS/$LIENS, SUBBIS2/C_NBLIG
# Parameter PPURPRITYP is the amount type [M:BIS3]PURPRITYP. If PURPRITYP="Ex tax", the amount+tax gets gray color
# If PURPRITYP="Tax inc", the amount-tax gets gray color
##################################################################################################################
Subprog SETCOLOR(PPURPRITYP)
Value Integer PPURPRITYP

If PPURPRITYP<>2
   Chgstl [M:BIS3]AMTNOTLIN With ""
   Chgstl [M:BIS3]AMTATILIN With "INACTIV"
Else
   Chgstl [M:BIS3]AMTATILIN With ""
   Chgstl [M:BIS3]AMTNOTLIN With "INACTIV"
Endif

End
##################################################################################################################
# $AS_AMTNOTLIN - the field action. Called from SUBBIS2/AS_AMTNOTLIN
# when amount type ="Ex tax", then skips cursor this field
##################################################################################################################
$AS_AMTNOTLIN

If [M]PURPRITYP=2 & !GIMPORT
   mkstat=2 : Return
Endif
Return

##################################################################################################################
# $RECALTOTAMT - called from SUBBIS2/AM_VAT,SUBBIS2/AS_AMTATILIN
# recalculated total amount
##################################################################################################################

$RECALTOTAMT
Local Integer MAXLIG
MAXLIG = max(nolign,[M:BIS3]NBLIG)-1
[M]TOTNOT = sum([M]AMTNOTLIN(0..MAXLIG))
[M]TOTATI = sum([M]AMTATILIN(0..MAXLIG))
If status<>7
 If !GIMPORT : Affzo TOTNOT , TOTATI : Endif
Endif

Return

##################################################################################################################
#$AM_AMTATILIN - called from SUBBIS2/AM_AMTATILIN
#The tax amount will be recalculated, if gross amount is changed, or tax amountis is not imported
#recalculated total amount
##################################################################################################################

$AM_AMTATILIN
[M]AMTATILIN(nolign-1) = VALEUR
If !GIMPORT
   If dim([M:BIS1]PURPRITYP)>0 & [M:BIS1]PURPRITYP=2
       If [M]TAX1(nolign-1) = "" & [M]TAX2(nolign-1) = ""
          Gosub CALTVA From SUBBIS2
          If [M]CEEFLG<>2
            [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1) - [M]AMTVAT(nolign-1)-[M]AMTTAX1(nolign-1)-[M]AMTTAX2(nolign-1)
          Else
            [M:BIS1]PURPRITYP=1
            [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1)
            Gosub CALTVA From SUBBIS2
            [M:BIS1]PURPRITYP=2
          Endif

       Endif
   Else
      If ([M]TAX1(nolign-1)<>"" | [M]TAX2(nolign-1)<>"" | [M]VAT(nolign-1)<>"")
         Gosub CALTVA From SUBBIS2
         If [M]CEEFLG<>2
            [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1) - [M]AMTVAT(nolign-1)-[M]AMTTAX1(nolign-1)-[M]AMTTAX2(nolign-1)
         Else
            [M:BIS1]PURPRITYP=1
            [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1)
            Gosub CALTVA From SUBBIS2
            [M:BIS1]PURPRITYP=2
         Endif
      Endif
   Endif
   If [M]CEEFLG<>2
      [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1) - [M]AMTVAT(nolign-1)-[M]AMTTAX1(nolign-1)-[M]AMTTAX2(nolign-1)
   Else
      [M]AMTNOTLIN(nolign-1)= [M]AMTATILIN(nolign-1)
   Endif
Affzo [M]AMTNOTLIN(nolign-1)
Affzo [M]AMTVAT(nolign-1)
Affzo [M]AMTATILIN(nolign-1)
Gosub RECALTOTAMT
Endif

Return

##################################################################################################################
#$AM_PURPRITYP - called from SUBBIS2/AM_PURPRITYP
#update of [M:BIS3]PURPRITYP
#changed setting of color
##################################################################################################################

$AM_PURPRITYP
[M:BIS3]PURPRITYP = VALEUR
Affzo [M:BIS3]PURPRITYP
Call SETCOLOR(VALEUR)
Return

##################################################################################################################
#Subprog B2_AMTATILIN - called from SUBBIS2/B2_AMTATILIN
#The right click option “Close”
##################################################################################################################

Subprog B2_AMTATILIN(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL From SUBBIS2
VALEUR = [M]AMTATI-sum([M]AMTATILIN(0..NOL-1))-sum([M]AMTATILIN(NOL+1..[M]NBLIG-1))
End
