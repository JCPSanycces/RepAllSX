#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
$ACTION
  Case ACTION
    When "OUVRE_FAT"      : Gosub OUVRE_FAT
    When "DEBUT_FAT"      : Gosub DEBUT_FAT # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
    When "FILTRE_FAT_INC" : #Gosub FILTRE_FAT_INC
    When "FIN_FAT"        : Gosub FIN_FAT
    When Default
  Endcase
Return

###############################################################################
$OUVRE_FAT

  # ---------------------------
  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #--only needed from some designated synchronisation rules
  #Gosub TRIGGER_AUDIBI
  # End issue X3-38377

  # ---------------------------
  Gosub AVANT_FAT_COMMUN
  Gosub DEBUT_FAT From TRTVENBI
  # ---------------------------
  # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
  #  Variable globale pour récupérer la devise dossier
  #If dim(GBICURFOLD)<=0 Then
  #  Global Char GBICURFOLD(GLONCUR)
  #Endif
  #GBICURFOLD = func TRTX3BI.GETSYSCUR()
  Gosub DEBUT_FAT
  # End issue 110958
	Case [L]TABLE
	  When "F_SADFACT"
      # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
      #--only needed from some designated synchronisation rules
      If find([F:ABV]CODREG,"SADSDD","SADSID","SADSOQ","SADSQD","SADSRD")>0
        If dim(ZWTABAPPLIORI)<0 : Local Char ZWTABAPPLIORI(GLONATB) : Endif
        Raz ZWTABAPPLIORI
        Case [F:ABV]CODREG
          When "SADSDD" : ZWTABAPPLIORI = "SDELIVERY"
          When "SADSID" : ZWTABAPPLIORI = "SINVOICE"
          When "SADSOQ" : ZWTABAPPLIORI = "SORDER"
          When "SADSQD" : ZWTABAPPLIORI = "SQUOTE"
          When "SADSRD" : ZWTABAPPLIORI = "SRETURN"
        Endcase
        Gosub TRIGGER_AUDIBI
      Endif
      # End issue X3-38377
	    # ----------------------------------------
	    Case [F:ABV]CODREG
	      When "SADSOQSOP"       : Gosub SADFACT_OUVRE_SADSOQSOP
	      When Default
	    Endcase
    When Default
	Endcase
Return
###############################################################################
$DEBUT_FAT
  # Issue 110958 - 2015-09-11 by CPO : GBICURFOLD non existent
  #  Variable globale pour récupérer la devise dossier
  If dim(GBICURFOLD)<=0 Then
    Global Char GBICURFOLD(GLONCUR)
  Endif
  GBICURFOLD = func TRTX3BI.GETSYSCUR()
  # End issue 110958

Return
###############################################################################
$FILTRE_FAT_INC
  Case TABLE
    When "F_SADFACT"     : #Gosub FILTRE_FAT_INC_SADFACT
  Endcase
Return

###############################################################################
$FILTRE_FAT_INC_SADFACT
	If [F:AUD]EVT = "UPDATE" Then
		[F:AUD]EVT = "DELETE"
	Endif
Return

###############################################################################
$AVANT_FAT_COMMUN
  #If !clalev([F:WAUJ_]) : Local File =GDOSSIER+".AUDITBI"   [WAUJ_] : Endif
  #--- Méthode TRTX3BI.GETSYSCUR
  If !clalev([F:ADW])   : Local File =GDOSSIER+".ADOVAL"    [ADW]   : Endif
  If !clalev([F:ADP])   : Local File =GDOSSIER+".ADOPAR"    [ADP]   : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If !clalev([F:TCH])   : Local File =GDOSSIER+".TABCHANGE" [TCH]   : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If !clalev([F:ITM])   : Local File =GDOSSIER+".ITMMASTER" [ITM]   : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If !clalev([F:GCM])   : Local File =GDOSSIER+".GACM"      [GCM]   : Endif
  If !clalev([F:LED])   : Local File =GDOSSIER+".GLED"      [LED]   : Endif
  #--- Méthode TRTX3BI.SETACC
  If !clalev([F:GAC])   : Local File =GDOSSIER+".GACCOUNT"  [GAC]   : Endif

  If !clalev([F:CAL])   : Local File =GDOSSIER+".CPTANALIN" [CAL]   : Endif
Return

###############################################################################
$TRIGGER_AUDIBI

  If [L]GEN = 2 Then
    Return    # En Synchro RAZ, pas la peine de faire ça
  Endif

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #-- not good in case of multiple folder synchronization !!
  #If dim(IADBITRT) <= 0 Then
  #  Local Integer IADBITRT  # Pour ne faire le travail qu'une fois dans le process de synchro
  # End issue X3-38377
    Local Integer IONECHANGE
     # On boucle sur le S/P jusqu'à ce qu'il ne fasse plus rien (IONECHANGE = 0)
    # Pour traiter le cas où des utilisateurs travailleraient en même temps que la synchro est réalisée
    IONECHANGE = 0
    #Repeat
      Call MANAGE_AUDITBI([L]GEN, IONECHANGE, [L]TABORG, [L]CRITAUD, [L]DOSAUD, [L]MAXAUD, [L]NBDOSAUD,ZWTABAPPLIORI)
    #Until IONECHANGE = 0
  #Endif                      # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object - not good in case of multiple folder synchronization !!
Return
###############################################################################
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#--Handle cases like : addresse modification on header (trigger on header not on lignes)
Subprog MANAGE_AUDITBI(IGEN, IONECHANGE, STABORG, SCRITAUD, SDOSAUD, NMAXAUD, INBDOSAUD, STABAPPLIORI)
Value Integer    IGEN
Variable Integer IONECHANGE
Value Char       STABORG
Value Char       SCRITAUD
Value Char       SDOSAUD
Variable Decimal NMAXAUD
Value Integer    INBDOSAUD
Variable Char    STABAPPLIORI

Local Integer IEXIST
Local Char    SADXTRP(type([S]adxtrp)-10)
Local Integer ITIMEBEG
Local Integer NB_TRT
Local Integer NI

  # ---------------------------------------
  If IGEN = 2 Then
    End    # En Synchro RAZ, pas la peine de faire ça
  Endif
  # ---------------------------------------
  If find(STABAPPLIORI,'SQUOTE','SORDER','SDELIVERY','SRETURN','SINVOICE') = 0 End Endif

  IONECHANGE = 0
  NB_TRT     = 0
  ITIMEBEG   = time

  # ---------------------------------------
  # Pour ne surtout pas déclencher l'ATRIFIL
  SADXTRP = [S]adxtrp
  [S]adxtrp = ""
  # ---------------------------------------
  Case STABAPPLIORI
    When "SQUOTE"
      Gosub MANAGE_AUDITBI_SQUOTE

    When "SORDER"
      Gosub MANAGE_AUDITBI_SORDER

    When "SDELIVERY"
      Gosub MANAGE_AUDITBI_SDELIVERY

    When "SRETURN"
      Gosub MANAGE_AUDITBI_SRETURN

    When "SINVOICE"
      Gosub MANAGE_AUDITBI_SINVOICE

    When Default
  Endcase
  # ---------------------------------------
  If NB_TRT > 0 Then
    #    Filter [AUD]
    #    For NI = 0 To INBDOSAUD-1
    #      If GDOSSIER = SDOSAUD(NI) Then
    #        Read [AUD_]AUD0 Last
    #        If !fstat Then
    #          MAXAUD(NI) = [F:AUD_]SEQ
    #          SCRITAUD = func ABIMAJBAS.CRITAUD(GDOSSIER, SDOSAUD, NMAXAUD, INBDOSAUD)
    #        Endif
    #        Break
    #      Endif
    #    Next
    #    Filter [AUD] Where TBL=STABORG & (STABI=2 or STABI=4) & evalue(SCRITAUD) : # A traiter
  Endif
  # ---------------------------------------
  [S]adxtrp = SADXTRP
  # ---------------------------------------

End
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_SQUOTE

  Gosub DECL_VAR

  # Lecture de la règle de synchro SADSQD.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "SADSQD"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # SQUOTE
  Local File =GDOSSIER+".SQUOTED" [SQD]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  #SELECT SQD.SQHNUM_0, SQD.SQDLIN_0 From SQUOTED SQD
  #INNER JOIN AUDITBI WAUH ON
  #(WAUH.ID1_0=SQD.SQHNUM_0 and  WAUH.TBL_0='SQUOTE' and WAUH.STABI_0 IN (2,4) and WAUH.EVT_0='UPDATE')
  #Where
  #cast(SQD.SQDLIN_0 As VARCHAR(8))
  #not IN
  #(SELECT WAUD.ID2_0 From AUDITBI WAUD
  #Where
  #WAUD.ID1_0=WAUH.ID1_0 and WAUD.ID2_0<>' ' and WAUD.TBL_0='SQUOTED' and WAUD.STABI_0 IN (2,4) and WAUD.EVT_0 <> 'DELETE')
  #GROUP By SQD.SQHNUM_0,SQD.SQDLIN_0

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT SQD.SQHNUM_0, SQD.SQDLIN_0 FROM SQUOTED SQD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=SQD.SQHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='SQUOTE' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(SQD.SQDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='SQUOTED' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY SQD.SQHNUM_0,SQD.SQDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [SQD]SQD0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [SQD]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [SQD]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_SORDER

  If filinfo(filpath("FIL","SORDER" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","SORDERQ","fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","SORDERP","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro SADSOQ.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "SADSOQ"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # SORDER
  Local File =GDOSSIER+".SORDERQ" [SOQ]
  Local File =GDOSSIER+".SORDERP" [SOP]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  #SELECT SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0
  #From SORDERQ SOQ
  #INNER JOIN AUDITBI WAUH ON
  #(WAUH.ID1_0 = SOQ.SOHNUM_0 and  WAUH.TBL_0 = 'SORDER' and WAUH.STABI_0 IN (2,4) and WAUH.EVT_0 = 'UPDATE')
  #Where
  #CONCAT(CONCAT(cast(SOQ.SOPLIN_0 As VARCHAR(8)), '~'),cast(SOQ.SOQSEQ_0 As VARCHAR(8))) not IN
  #(SELECT WAUD.ID2_0 From AUDITBI WAUD
  #Where WAUD.ID1_0 = WAUH.ID1_0 and WAUD.ID2_0 <> ' '
  #and WAUD.TBL_0 = 'SORDERQ' and WAUD.STABI_0 IN (2,4) and WAUD.EVT_0 <> 'DELETE')
  #GROUP By SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0 FROM SORDERQ SOQ"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0 = SOQ.SOHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0 = 'SORDER' AND WAUH.STABI_0 IN (2,4) AND WAUH.EVT_0 = 'UPDATE')"
  WREQ(1) = "WHERE CONCAT(CONCAT(CAST(SOQ.SOPLIN_0 AS VARCHAR(8)),'~'),CAST(SOQ.SOQSEQ_0 AS VARCHAR(8))) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0 = WAUH.ID1_0 AND WAUD.ID2_0 <>' '"
  WREQ(2) = "AND WAUD.TBL_0 = 'SORDERQ' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN, Integer VCRSEQ)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [SOQ]SOQ0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN;[F:RREQ_]VCRSEQ
    If !fstat
      Rewrite [SOQ]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
    Read [SOP]SOP0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN;[F:RREQ_]VCRSEQ
    If !fstat
      Rewrite [SOP]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [SOQ], [SOP]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_SDELIVERY

  If filinfo(filpath("FIL","SDELIVERY" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","SDELIVERYD","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro SADSDD.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "SADSDD"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # SDELIVERY
  Local File =GDOSSIER+".SDELIVERYD" [SDD]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  #SELECT SDD.SDHNUM_0, SDD.SDDLIN_0 From SDELIVERYD SDD
  #INNER JOIN AUDITBI WAUH ON
  #(WAUH.ID1_0=SDD.SDHNUM_0 and WAUH.TBL_0='SDELIVERY' and WAUH.STABI_0 IN (2,4) and WAUH.EVT_0='UPDATE')
  #Where
  #cast(SDD.SDDLIN_0 As VARCHAR(8)) not IN
  #(SELECT WAUD.ID2_0 From AUDITBI WAUD
  #Where WAUD.ID1_0=WAUH.ID1_0 and WAUD.ID2_0<>' '
  #and WAUD.TBL_0='SDELIVERYD' and WAUD.STABI_0 IN (2,4) and WAUD.EVT_0 <> 'DELETE')
  #GROUP By SDD.SDHNUM_0,SDD.SDDLIN_0

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT SDD.SDHNUM_0, SDD.SDDLIN_0 FROM SDELIVERYD SDD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=SDD.SDHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='SDELIVERY' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(SDD.SDDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='SDELIVERYD' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY SDD.SDHNUM_0,SDD.SDDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [SDD]SDD0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [SDD]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [SDD]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_SRETURN

  If filinfo(filpath("FIL","SRETURN" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","SRETURND","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro SADSRD.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "SADSRD"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # SRETURN
  Local File =GDOSSIER+".SRETURND" [SRD]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  #SELECT SRD.SRHNUM_0, SRD.SRDLIN_0 From SRETURND SRD
  #INNER JOIN AUDITBI WAUH ON
  #(WAUH.ID1_0=SRD.SRHNUM_0 and WAUH.TBL_0='SRETURN' and WAUH.STABI_0 IN (2,4) and WAUH.EVT_0='UPDATE')
  #Where
  #cast(SRD.SRDLIN_0 As VARCHAR(8)) not IN
  #(SELECT WAUD.ID2_0 From AUDITBI WAUD
  #Where WAUD.ID1_0=WAUH.ID1_0 and WAUD.ID2_0<>' '
  #and WAUD.TBL_0='SRETURND' and WAUD.STABI_0 IN (2,4) and WAUD.EVT_0 <> 'DELETE')
  #GROUP By SRD.SRHNUM_0,SRD.SRDLIN_0

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT SRD.SRHNUM_0, SRD.SRDLIN_0 FROM SRETURND SRD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=SRD.SRHNUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='SRETURN' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(SRD.SRDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='SRETURND' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY SRD.SRHNUM_0,SRD.SRDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [SRD]SRD0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [SRD]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [SRD]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
$MANAGE_AUDITBI_SINVOICE

  If filinfo(filpath("FIL","SINVOICE" ,"fde",GDOSSIER),0) <= 0 or
&    filinfo(filpath("FIL","SINVOICED","fde",GDOSSIER),0) <= 0
    Return
  Endif

  Gosub DECL_VAR

  # Lecture de la règle de synchro S.
  # Si elle est désactivée : on n'exécute pas le traitement.
  CODE_SYNCRULE = "SADSID"
  [L]DESFLG = func READ_SYNCRULE(CODE_SYNCRULE, GDOSSIER)
  If [L]DESFLG = 2 Then Return : Endif

  Call ECR_TRACE("Rule : " - time$ -"Origin header table :"-STABAPPLIORI, 0) From GESECRAN

  # SINVOICE
  Local File =GDOSSIER+".SINVOICED" [SID]

  Raz WREQ
  If clalev([F:RREQ_])>0 : Close File [F:RREQ_] : Endif

  #SELECT SIDD.NUM_0, SIDD.SIDLIN_0 FROM SINVOICED SIDD
  #INNER JOIN AUDITBI WAUH ON
  #(WAUH.ID1_0=SIDD.NUM_0 AND WAUH.TBL_0='SINVOICE' AND WAUH.STABI_0 IN (2,4) AND WAUH.EVT_0='UPDATE' )
  #WHERE
  #CAST(SIDD.SIDLIN_0 AS VARCHAR(8)) NOT IN
  #(SELECT WAUD.ID2_0 FROM AUDITBI WAUD
  #WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '
  #AND WAUD.TBL_0='SINVOICED' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0 <> 'DELETE')
  #GROUP BY SIDD.NUM_0,SIDD.SIDLIN_0

  # Requête de sélection des enregistrements
  WREQ(0) = "SELECT SIDD.NUM_0, SIDD.SIDLIN_0 FROM SINVOICED SIDD"
  WREQ(0)-= "INNER JOIN AUDITBI WAUH ON (WAUH.ID1_0=SIDD.NUM_0"
  WREQ(0)-= "AND WAUH.TBL_0='SINVOICE' AND WAUH.STABI_0 IN (2,4)"
  WREQ(1) = "AND WAUH.EVT_0='UPDATE') WHERE CAST(SIDD.SIDLIN_0 AS VARCHAR(8)) NOT IN"
  WREQ(1)-= "(SELECT WAUD.ID2_0 FROM AUDITBI WAUD"
  WREQ(1)-= "WHERE WAUD.ID1_0=WAUH.ID1_0 AND WAUD.ID2_0<>' '"
  WREQ(2) = "AND WAUD.TBL_0='SINVOICED' AND WAUD.STABI_0 IN (2,4) AND WAUD.EVT_0<>'DELETE')"
  WREQ(2)-= "GROUP BY SIDD.NUM_0,SIDD.SIDLIN_0"

  For (Char VCRNUM(GLONVCR), Integer VCRLIN)
&        From WBASE Sql WREQ(0..2) As [F:RREQ_]
    Read [SID]SID0=[F:RREQ_]VCRNUM;[F:RREQ_]VCRLIN
    If !fstat
      Rewrite [SID]
      NB_TRT += 1
      IONECHANGE = 1
    Endif
  Next

  LogicClose File [SID]

  Call ECR_TRACE("End rule : records updated" - num$(NB_TRT) - time$ - "time elapsed : " - num$(time-ITIMEBEG) - "seconds", 0) From GESECRAN

Return
#--------------------------------------------------------------------------------------------------
# End issue X3-38377
###############################################################################
$FIN_FAT

  #If clalev([F:WAUJ_]) : Close Local File  [WAUJ_] : Endif
  #--- Méthode TRTX3BI.GETSYSCUR
  If clalev([F:ADW])   : Close Local File  [ADW]   : Endif
  If clalev([F:ADP])   : Close Local File  [ADP]   : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If clalev([F:TCH])   : Close Local File  [TCH]   : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If clalev([F:ITM])   : Close Local File  [ITM]   : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If clalev([F:GCM])   : Close Local File  [GCM]   : Endif
  If clalev([F:LED])   : Close Local File  [LED]   : Endif
  #--- Méthode TRTX3BI.SETACC
  If clalev([F:GAC])   : Close Local File  [GAC]   : Endif

  If clalev([F:CAL])   : Close Local File  [CAL]   : Endif
Return

###############################################################################
$SADFACT_OUVRE_SADSOQSOP
  #Gosub OUVRE_DIM_DETAIL

  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPSORDERQ"                     [BISOQ_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".SORDERP"                          [WSOP_]
  Local File =GDOSSIER+".SORDERQ"                          [WSOQ_]

Local Char SWHERE(250)
Local Char SVID1(type([F:WAUI_]ID1)-10)
Local Char SVID2(type([F:WAUI_]ID1)-10)(1..2)
Local Integer IADXLOG

  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BISOQ_]
  Endif
  Delete [BISOQ_] Where [BISOQ_]BISOQADXUID = adxuid(1)
	If [L]GEN <> 2 Then
		Raz SVID1
		Filter [WAUI_] Where (TBL = [F:ABV]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1;ID2;SEQ Desc
		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (SOHNUM ='" + [F:WAUI_]ID1 + "')"
				Call DECOUPE_TILDES([F:WAUI_]ID2, SVID2) From TRTDIMBISAD
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (SOPLIN=" + SVID2(1) - "& SOQSEQ=" + SVID2(2) + ")"
				  Gosub CREATE_BISOQ_TRAVAIL
				  SVID1 = [F:WAUI_]ID1 + "~" + [F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BISOQ_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BISOQ_]
  Close Local File [WAUI_]
  Close Local File [WSOP_]
  Close Local File [WSOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_SADSOQ Fin") From DOSSUB
Return

###############################################################################
$CREATE_BISOQ_TRAVAIL
  #--Open orders
  Filter [WSOQ_] Where SOHCAT = 4 and DEMSTA = 1 and evalue(SWHERE)
  For [WSOQ_]
    Raz [F:BISOQ_]
    [F:BISOQ_]BISOQADXUID = adxuid(1)
    [F:BISOQ_]SOHNUM      = [WSOQ_]SOHNUM
    [F:BISOQ_]SOPLIN      = [WSOQ_]SOPLIN
    [F:BISOQ_]SOQSEQ      = [WSOQ_]SOQSEQ
    [F:BISOQ_]SOPSEQ      = 0
    Filter [WSOP_] Where SOHNUM=[WSOQ_]SOHNUM and SOPLIN=[WSOQ_]SOPLIN and STRDAT<=[WSOQ_]DEMDLVDAT Order By STRDAT Desc
    For [WSOP_]
      [F:BISOQ_]SOPSEQ    = [WSOP_]SOPSEQ
      Break
    Next
    Filter [WSOP_]
    #--If there is not a SOP record with STRDAT<=[WSOQ_]DEMDLVDAT, then
    Write [F:BISOQ_]
  Next
  Filter [WSOQ_]
Return
# Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
#-------------------------------------------------------------------------------------------------------------------------
$DECL_VAR
Local Char    WREQ(255)(4) : Raz WREQ  # Contains the SQL query
Local Integer D
Local Integer NB_ENREG     : NB_ENREG=0
Local Char    WBASE(1)     : WBASE=" "
Local Integer DESFLG
Local Char    CODE_SYNCRULE(GLONABV)
Local Integer ITIMEBEG     : ITIMEBEG = time  # start time

  #--getting the database type
  Gosub ALIM_WBASE

Return
#-------------------------------------------------------------------------------------------------------------------------
$ALIM_WBASE

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  WBASE = num$((fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, GACTX.AFOLDER, "TYPDBA") * 2) + 1)

Return
#-------------------------------------------------------------------------------------------------------------------------
Funprog READ_SYNCRULE(CODE_SYNCRULE, VFOLDER)
Variable Char CODE_SYNCRULE
Variable Char VFOLDER

Local Integer DESACT

  DESACT = 1
  If CODE_SYNCRULE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =VFOLDER+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_SYNCRULE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT
# End issue X3-38377
