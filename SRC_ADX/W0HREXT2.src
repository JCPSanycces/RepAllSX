#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"
indice = 0
status = 1
zoncou = "PARNBR"
If varmode([M]PARNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]PARNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]PARNBR = nolign
   status = 75
   Call SAI_PARNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_PARNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"

## Zone PARDTALVL
mkstat = 0
zoncou = "PARDTALVL"
IMPENT = [M]PARDTALVL(indice)
If varinit([M]PARDTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PARDTALVL,indice)=0
 Call INICOMBO(11677) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PARDTALVL(IMPENT) From SUBHREXT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,11677,1))))
 Endif
 [M]PARDTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARDTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PARDTALVL(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PARDTALVL" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "PARDTALVL" : GZNUM = 5230 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]PARDTALVL(indice) = IMPENT

## Zone PARDTACLC
mkstat = 0
zoncou = "PARDTACLC"
If varmode([M]PARDTACLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARDTACLC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PARCOD
mkstat = 0
zoncou = "PARCOD"
If varmode([M]PARCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PARCOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PARTIT
mkstat = 0
zoncou = "PARTIT"
If varmode([M]PARTIT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARTIT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PARTIT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PARTIT" : GZNUM = 1826 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PARTYP
mkstat = 0
zoncou = "PARTYP"
If varmode([M]PARTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARTYP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ATY","!",[M]PARTYP(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PARTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PARNBRLIB
mkstat = 0
zoncou = "PARNBRLIB"
If varmode([M]PARNBRLIB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARNBRLIB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PARLNG
mkstat = 0
zoncou = "PARLNG"
If varmode([M]PARLNG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARLNG" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PARVALTYP
mkstat = 0
zoncou = "PARVALTYP"
IMPENT = [M]PARVALTYP(indice)
If varinit([M]PARVALTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PARVALTYP,indice)=0
 [M]PARVALTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARVALTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PARVALTYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PARVALTYP" : GZNUM = 1334 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]PARVALTYP(indice) = IMPENT

## Zone PARMDT
mkstat = 0
zoncou = "PARMDT"
IMPENT = [M]PARMDT(indice)
If varinit([M]PARMDT,indice)=0
 IMPENT = 1
Endif
If varmode([M]PARMDT,indice)=0
 [M]PARMDT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARMDT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PARMDT(indice)
 Endif
Endif
[M]PARMDT(indice) = IMPENT

## Zone PARDEFDEB
mkstat = 0
zoncou = "PARDEFDEB"
If varmode([M]PARDEFDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARDEFDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PARDEFFIN
mkstat = 0
zoncou = "PARDEFFIN"
If varmode([M]PARDEFFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARDEFFIN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PARNBR
mkstat = 0
zoncou = "PARNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HREXT2"
Return

