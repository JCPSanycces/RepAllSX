#<AdxTL>@(#)0.0.0.0 $Revision$ Mouvements par article
Local Char PARAM(20)(1..8)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "A-HN140"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = "0"
PARAM(7) = ""
PARAM(8) = ""
Raz GPILOBJ, GNBMASKOUV : Call GCONSULT("SMV","",PARAM) From GCONSULT
End
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSMV]:Transmask [M:SMV1] To [M:CSMV]# Issue 25606[M:CSMV] = [M:SMV1]
                      [M:CSMV]FIL001 = mess(28,197,1)
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
Raz GSOC_ACTIVE                                               # Ana

If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:LPN]) = 0 : Local File LPN        [LPN] : Endif  # hcb x3-68149
If clalev([F:SGH]) = 0 : Local File SCHGH      [SGH] : Endif  # MAE x3-106909

If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])    Local File GACM       [GCM] : Endif   # Ana
Endif                                                          # Ana

# Chargement des globales référenciels, comptes et sections de la société
GFCY=GFCYDEF(7)                                                # Ana
Call GETCPY(GFCY,"",0,"") From TRTX3CPT                        # Ana
GORITITCOL=1                                                   # Ana

Global Char   WFIL1(250),WFIL2(250), WFILS(250), WFILF(250), WFILX(250), WSTR(250), WFILSPE(250)    # hcb 78584
Global Char   WFIL11(250),WFILX1(250)   # hcb x3-68149

Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG, WCLA, WSEL, WPAGE
Local Decimal WACT, WSTO, WWSTO
Local Char    WSAP
Local Char    WCOL(13) : WCOL = "1111110001110"
Local Integer WBUT
Local Integer I, J
Local Integer WOK
Local Char    WPAR
Local Integer WLTI, WAGR
Local  Integer WGCONSULT : WGCONSULT = GCONSULT         # hcb 30488

WNOLIGN = nolign
Gosub LOAD_SCREEN

NAVIG="CONSSMV"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SMV1]FLG = 0
[M:SMV1] = [M:CSMV]
Return
############################################################
$AP_MAGNETO
[M:SMV1]FLG = 0
Return
############################################################
$FERME
Raz GORITITCOL                                         # Ana
If clalev([F:STJ]) <>  0  : Filter [STJ] : Endif          #MAE, bg 83763
#GCONSULT = 0                                             # hcb 30488
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif      # hcb 30488

If dim(WNOLIGN) > 0
  nolign = WNOLIGN
Endif
Return
############################################################
$LOAD_SCREEN

For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMV1]FCY = PARAM(I)
        Endif
      Endif
#                                                # hcb 111400 deb
      If GCONSULT = 0 &  [M:SMV1]FCY = ""
         [M:SMV1]FCY = GFCYDEF(0)
      Endif
#                                                # hcb 111400 fin

    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMV1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> "" & dim([M:SMV1]LOTSEL) > 0
        If PARAM(I) = mess(142,124,1)
          [M:SMV1]LOTSEL = "*"
        Else
          [M:SMV1]LOTSEL = PARAM(I)
        Endif
      Endif
    When 5 :
#      [M:SMV1]STOCOUSEL = val(PARAM(I))               #  50809
    When 6 :
      If PARAM(I) <> ""
        [M:SMV1]VCRTYPSEL = val(PARAM(I)) + 1
      Else
        [M:SMV1]VCRTYPSEL = 1
      Endif
    When 7 :
      [M:SMV1]VCRNUMSEL = PARAM(I)
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
    When 9 :
      If PARAM(I) <> ""
        Call LECTURE("WRH",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMV1]WRH = [F:WRH]WRH
        Endif
      Endif
  Endcase
Next I

# Détermination délai d'interrogation (défaut 30 jours)
Call PARAM([M:SMV1]FCY,"INQMVSLTI",WPAR) From ADOVAL
If val(WPAR) <> 0
  WLTI = val(WPAR)
Endif
If WLTI = 0
  WLTI = 30
Endif
#
[M:SMV1]SRTCOD = 7

#If [M:SMV1]STOCOUSEL <> 0 | WFILS <> "1=1" | GCONSULT <> 0   # hcb 55078
If [M:SMV1]STOCOUSEL <> 0 | WFILS <> "1=1"                    # hcb 55078
  [M:SMV1]INQLTI    = WLTI
  [M:SMV1]STDFLG    = 2
  [M:SMV1]MISFLG    = 2
Else
  If clalev([M:CSMV]) <> 0 & [M:CSMV]MEMO = "STD"
    [M:SMV1] = [M:CSMV]
  Else
    [M:SMV1]INQLTI = WLTI
    [M:SMV1]STDFLG = 2
    [M:SMV1]MISFLG = 1
  Endif
Endif
# Issue 106909 - 2018-09-20 by MAE : si on vient des affectations LPN ou des opérations LPN,on selectionne les mvts internes
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESLPNOPE","GESLPNAFF")
        [M:SMV1]MISFLG    = 2
        [M:SMV1]INQLTI = AVOID.ADEC    #pas de durée de consultation
    Endif
Endif
# End issue 106909
Return
############################################################
$LECTURE
# Affichage entêtes de colonne variables                       # Ana
Gosub AFF_TITCOL                                               # Ana

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:SMV1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:SMV1]ITMREF
        Diszo [M:SMV1]FCY
    Endif
    Gosub DIS_ITMREF
   #MAE, bug 105405 + bug 106219
    Call CONTFCY([M:SMV1]FCY) From EXEFNC # controle habilitation
    If mkstat=2 : Return : Endif
Endif

If [M:SMV1]ITMREF = ""
  NBLU = 0
  Return
Endif

# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
WBUT   = 0
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STJ]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Raz [M:SMV2]
    WLIG = 0
    For [STJ]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
# Pas dépositionné
###Filter [STJ]
Return
############################################################
$TRT_FILTER
#MAE, bg 81397
If CHGPAG = 1
  [M:SMV1]FLG =0
Endif

If [M:SMV1]FLG = 0
   Filter [STJ]                     # hcb 27082
  [M:SMV1]FLG = 1
  Raz [M:SMV2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
# Chargement stock initial
  WSTO = 0
  If WSEL = 0
    If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
      Filter [STO] Where evalue(WFILX) & evalue(WFILX1)
&                  Order By Key STO3
      For [STO]
        WSTO += [F:STO]QTYSTU
      Next
      Filter [STO]
    Else
      WSTO = 0
    Endif
  Endif
  WWSTO = WSTO
  Case [M:SMV1]SRTCOD
    When 1 :
      Onerrgo ERR_FORM1
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By Key STJ0
      Onerrgo
    When 3 :
      Onerrgo ERR_FORM3
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 4 :
      Onerrgo ERR_FORM4
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 5 :
      Onerrgo ERR_FORM5
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                 Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 6 :
      Onerrgo ERR_FORM6
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 9 :
      Onerrgo ERR_FORM9
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc : # Bug 88530
#&                  Order By ITMREF; IPTDAT; STOFCY; MVTSEQ Desc; UPDCOD                       : # Bug 88530
      Onerrgo
    When 10 :
      Onerrgo ERR_FORM10
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
      Onerrgo
    When 11 :
      Onerrgo ERR_FORM11
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ Desc
      Onerrgo
    When Default :
      Onerrgo ERR_FORM
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc : # Bug 88530
#&                  Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD                        : # Bug 88530
      Onerrgo
  Endcase
  Raz [F:STJ]
  fstat = 0
Else
  WSTO = WWSTO
Endif
Return

############################################################
$ERR_FORM1
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By Key STJ0
Resume

$ERR_FORM3
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM4
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM5
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM6
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM9
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc : # Bug 88530
#&            Order By ITMREF; IPTDAT; STOFCY; MVTSEQ; UPDCOD                            : # Bug 88530
Resume

$ERR_FORM10
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
Resume

$ERR_FORM11
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ
Resume

$ERR_FORM
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)  & evalue(WFIL11)
&            Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc : # Bug 88530
#&            Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD                        : # Bug 88530
Resume

############################################################
$LOAD_FILTER
Raz WFILX, WFIL1, WFILX1, WFIL11                      # hcb X3-69570
WFILX  = "1=1"
WFIL1  = "1=1"
WFILX1 = "1=1"                                        # hcb X3-69570
WFIL11 = "1=1"                                        # hcb X3-69570
# Chargement des filtres
# WSEL = 1 pour interdir le calcul des champs stock avant et stock après
If [M:SMV1]SRTCOD = 0
  [M:SMV1]SRTCOD = 7
Endif
If find([M:SMV1]SRTCOD,7,9,10,11)
  WSEL = 0
Else
  WSEL = 1
Endif
[M:SMV1]STRDAT = date$-[M:SMV1]INQLTI
# Filtre site
If [M:SMV1]FCY <> ""                             # graph
  WFIL1 += "&[F:STJ]STOFCY=[M:SMV1]FCY"            # graph
  WFILX += "&[F:STO]STOFCY=[M:SMV1]FCY"            # graph
  If [M:SMV1]UPDFLG <> 2                         # graph
    WFIL1 += "&[F:STJ]UPDCOD=2"
  Else
    WSEL   = 1
    WFIL1 += "&[F:STJ]UPDCOD=1"
  Endif
  If [M:SMV1]REGFLG <> 2                    # hcb 040105  24390    # graph
    WFIL1 += "&[F:STJ]REGFLG<>2"            # hcb 040105  24390
  Endif                                     # hcb 040105  24390
Else
  #    Autorisation site
  # 99078 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
  If GUSRFCY(1)<>"\" & [M:SMV1]FCY = "" & GNBAUZ<>GNBSITE
    WFIL1 += "& find([F:STJ]STOFCY,GUSRFCY(1..GNBAUZ))"
    WFILX += "& find([F:STO]STOFCY,GUSRFCY(1..GNBAUZ))"
  Endif
  If [M:SMV1]UPDFLG <> 2                         # graph
    WFIL1 += "&[F:STJ]UPDCOD=2"
  Else
    WSEL  = 1
    WFIL1 += "&[F:STJ]UPDCOD=1"
  Endif
  If [M:SMV1]REGFLG <> 2                    # hcb 040105  24390    # graph
    WFIL1 += "&[F:STJ]REGFLG<>2"            # hcb 040105  24390
  Endif                                     # hcb 040105  24390
Endif
# Filtre dépôt
If dim([M:SMV1]WRH)>0 and [M:SMV1]WRH <> ""                             # graph
#MAE, bg68117
#  WFIL1 = "[F:STJ]WRH=[M:SMV1]WRH"
#  WFILX = "[F:STO]WRH=[M:SMV1]WRH"
  WFIL1 += "& [F:STJ]WRH=[M:SMV1]WRH"
  WFILX += "& [F:STO]WRH=[M:SMV1]WRH"

Endif
# Sélection numéro article
WFIL1 += "&[F:STJ]ITMREF=[M:SMV1]ITMREF"    # graph
If WFILX=""
  WFILX  = "[F:STO]ITMREF=[M:SMV1]ITMREF"   # graph
Else
  WFILX += "&[F:STO]ITMREF=[M:SMV1]ITMREF"  # graph
Endif
# Pas de selection date et tous mouvements si filtre chrono stock
If [M:SMV1]STOCOUSEL <> 0                   # graph
  WFILX += "&[F:STO]STOCOU=[M:SMV1]STOCOUSEL"  # graph
Endif
# Filtre date
If [M:SMV1]INQLTI <> 0                     # graph
  WFIL1 += "&[F:STJ]IPTDAT>=[M:SMV1]STRDAT"
Endif
# Filtre lot (pat)
If dim([M:SMV1]LOTSEL) > 0 & [M:SMV1]LOTSEL <> ""  # graph
  WFIL1 += "&pat([F:STJ]LOT,[M:SMV1]LOTSEL)"  # graph
  WFILX += "&pat([F:STO]LOT,[M:SMV1]LOTSEL)"  # graph
Endif

#--- Issue 110327
If find([F:ITM]SERMGTCOD,2,3)
#--                                                              # hcb 27082 deb
  If dim([M:SMV1]SERNUMSTR) > 0 & [M:SMV1]SERNUMSTR <> ""  # graph
    WFIL1 += "&([F:STJ]SERNUM>=[M:SMV1]SERNUMSTR)"         # graph
    WFILX += "&([F:STO]SERNUM>=[M:SMV1]SERNUMSTR)"         # graph
  Endif
  If dim([M:SMV1]SERNUMEND) > 0 & [M:SMV1]SERNUMEND <> ""  # graph
    WFIL1 += "&([F:STJ]SERNUM<=[M:SMV1]SERNUMEND)"         # graph
    WFILX += "&([F:STO]SERNUM<=[M:SMV1]SERNUMEND)"         # graph
  #
  Endif
#--- Issue 110327
Elsif [F:ITM]SERMGTCOD=4
  If dim([M:SMV1]SERNUMSTR) > 0 & [M:SMV1]SERNUMSTR <> ""  # graph
    WFIL1 += "&([F:STJ]SERFIN>=[M:SMV1]SERNUMSTR)"         # graph
  Endif
  If dim([M:SMV1]SERNUMEND) > 0 & [M:SMV1]SERNUMEND <> ""  # graph
    WFIL1 += "&([F:STJ]SERDEB<=[M:SMV1]SERNUMEND)"         # graph
  Endif
Endif                                                        # hcb 27082 fin
#                                                         # hcb X3-69570 deb
# Filtre lpnnum
If dim([M:SMV1]LPNNUM) > 0 & [M:SMV1]LPNNUM <> ""
  WFIL11 += "&[F:STJ]LPNNUM=[M:SMV1]LPNNUM"
  WFILX1 += "&[F:STO]LPNNUM=[M:SMV1]LPNNUM"
Endif
#                                                         # hcb X3-69570 fin

# Pour filtre les enregistrements bidon d'inventaire
WFIL2 = "[F:STJ]TRSTYP<>0"

# Filtre types de mvts
If !([M:SMV1]MISFLG=2 & [M:SMV1]STDFLG=2 & [M:SMV1]CHGFLG=2) & !([M:SMV1]MISFLG=1 & [M:SMV1]STDFLG=1 & [M:SMV1]CHGFLG=1)   # graph
  If [M:SMV1]STDFLG = 2                                         # graph
    If [M:SMV1]MISFLG = 2      WFIL2 += "&[F:STJ]TRSTYP<>23"    # graph
    # Issue X3-53322- 2018-06-01 by MAE : ajout type 36
    Else If [M:SMV1]CHGFLG = 2 WFIL2 += "&!find([F:STJ]TRSTYP,7,8,9,21,25,36)"  # graph
         Else             WFIL2 += "&!find([F:STJ]TRSTYP,7,8,9,21,23,25,36)"
         Endif
    Endif
  Else
    If [M:SMV1]MISFLG = 2                                      # graph
       If [M:SMV1]CHGFLG = 2   WFIL2 += "&find([F:STJ]TRSTYP,7,8,9,21,23,25,36)"  # graph
       Else               WFIL2 += "&find([F:STJ]TRSTYP,7,8,9,21,25,36)"
       Endif
    Else
       If [M:SMV1]CHGFLG = 2   WFIL2 += "&[F:STJ]TRSTYP=23"      # graph
       Endif
    Endif
  Endif
Endif

# Filtre type pièce
If [M:SMV1]VCRTYPSEL > 1                    # graph
  WSEL   = 1
  WFIL2 += "&[F:STJ]VCRTYP=[M:SMV1]VCRTYPSEL-1"  # graph
Endif
# Filtre numéro pièce
If [M:SMV1]VCRNUMSEL <> ""                        # graph
  WSEL   = 1
  WFIL2 += "&[F:STJ]VCRNUM=[M:SMV1]VCRNUMSEL"
Endif
# Filtre tiers
If [M:SMV1]BPRNUM <> ""                        # graph
  WSEL   = 1
  WFIL2 += "&[F:STJ]BPRNUM=[M:SMV1]BPRNUM"
Endif
# Filtre formule
WFILF = "1=1"
If [M:SMV1]SELFOR <> ""                          # graph
  Read [TFO]TFO0=11;[M:SMV1]SELFOR               # graph
  If fstat = 0
    WSEL  = 1
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return
############################################################
############################################################
$LOA_LIGNE
#MAE, bg 85422
#--- Issue 110327
#If [F:ITM]SERMGTCOD > 1
If find([F:ITM]SERMGTCOD,2,3)
#---
  Gosub AGREG
Endif
If WAGR=1 : Return : Endif

[M:SMV2]               = [F:STJ]

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  [M:SMV2]SERNUM(nolign-1) = [F:STJ]SERDEB
  [M:SMV2]SERFIN(nolign-1) = [F:STJ]SERFIN
Endif
#---

For I=1 To GNBDIE
   Assign "[M:SMV2]CCE"+num$(I)+"(nolign-1)" With [F:STJ]CCE(I-1)
Next I

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF
   Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If dim([M:SMV2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:SMV2]POT(nolign-1) = 0
Endif
If dim([M:SMV2]ACT) > 0 & [F:ITF]STOMGTCOD <> 4
  [M:SMV2]ACT(nolign-1) = 0
Endif
If [F:STJ]VCRTYP = 0
  [M:SMV2]VCRTYPTXT(nolign-1) = ""
Else
  [M:SMV2]VCRTYPTXT(nolign-1) =  mess([F:STJ]VCRTYP,701,1)
Endif
If [F:STJ]VCRTYPORI = 0
  [M:SMV2]VCRTYPORIT(nolign-1) = ""
Else
  [M:SMV2]VCRTYPORIT(nolign-1) =  mess([F:STJ]VCRTYPORI,701,1)
Endif
If [F:FCY]FCY<>[F:STJ]STOFCY
    Read [F:FCY]FCY0=[F:STJ]STOFCY
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
Endif
[M:SMV2]ACCCUR(nolign-1)=[F:CPY]ACCCUR

If dim([M:SMV2]BEFSTO) > 0
  [M:SMV2]AFTSTO(nolign-1) = 0
  [M:SMV2]BEFSTO(nolign-1) = 0
  If WSEL = 0 & WBUT = 0 & [M:SMV2]TRSTYP(nolign-1)<>23
    If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
      [M:SMV2]AFTSTO(nolign-1) = WSTO
      WSTO -= [F:STJ]QTYSTU
      [M:SMV2]BEFSTO(nolign-1) = WSTO
    Else
      [M:SMV2]BEFSTO(nolign-1) = WSTO
      WSTO += [F:STJ]QTYSTU
      [M:SMV2]AFTSTO(nolign-1) = WSTO
    Endif
  Endif
Endif
#--- Issue 110327
If [F:ITM]SERMGTCOD<4
  #--- calcul du no série de finv dans le cas des mvt de sorties
  If dim([M:SMV2]SERNUM(nolign-1))>0 & [M:SMV2]SERNUM(nolign-1) <> ""
    If abs([M:SMV2]QTYSTU(nolign-1)) = 1
        [M:SMV2]SERFIN(nolign-1) = [M:SMV2]SERNUM(nolign-1)
    Else Call PLUS_NB([M:SMV2]SERNUM(nolign-1),abs([M:SMV2]QTYSTU(nolign-1)),[M:SMV2]SERFIN(nolign-1),WOK) From STKLIB
    Endif
  Endif
#--- Issue 110327
Endif

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL                             : # ana
If  dim([M:SMV2]CCE1)>0                                      # hcb 112700
#If GSOC_UPDFLG & dim([M:SMV2]CCE1)>0                        # hcb 112700
  Local Char BASPAG(10)
  Call ISSCREENOK (nomap,"CONSSMV2") From INTRUTILB
  BASPAG="NBLIG" : Gosub TIT_COL From W1CONSSMV2
  # Pour forcer l'utilisation des formats évalués si tableau vide
  If [M:SMV2]NBLIG=0
    [M:SMV2]NBLIG=1 : Affzo [SMV2]5 : Effzo [SMV2]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

#------------------------------------------------------------------------#
# diszo suivant contexte article   (bug 51554)
#------------------------------------------------------------------------#
$DIS_ITMREF
If [M:SMV1]ITMREF<> ""
    If dim([M:SMV1]SERNUMSTR) > 0
       If [F:ITM]SERMGTCOD < 2
          Raz   [M:SMV1]SERNUMSTR
          Raz   [M:SMV1]SERNUMEND
          Affzo [M:SMV1]SERNUMSTR
          Affzo [M:SMV1]SERNUMEND

          Diszo [M:SMV1]SERNUMSTR
          Diszo [M:SMV1]SERNUMEND
       Else
          Actzo [M:SMV1]SERNUMSTR
          Actzo [M:SMV1]SERNUMEND
       Endif
    Endif
   If dim([M:SMV1]LOTSEL) > 0
       If [F:ITM]LOTMGTCOD < 2
          Raz   [M:SMV1]LOTSEL
          Affzo [M:SMV1]LOTSEL

          Diszo [M:SMV1]LOTSEL
       Else
          Actzo [M:SMV1]LOTSEL
       Endif
   Endif
   #                                                     # hcb  X3-68850 deb
  If dim([M:SMV1]LPNNUM) > 0
     If [F:ITF]STOFCY <> [M:SMV1]FCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
        Read [ITF]ITF0 = [F:ITM]ITMREF;[M:SMV1]FCY
        If fstat
           Raz [F:ITF]
        Endif
     Endif
     If [F:ITF]LPNMGTCOD<>2
        Raz   [M:SMV1]LPNNUM
        Affzo [M:SMV1]LPNNUM
        Diszo [M:SMV1]LPNNUM
     Else
        Actzo [M:SMV1]LPNNUM
     Endif
  Endif
#                                                     # hcb  X3-68850 fin

Endif
Return



############################################################
$SETBOUT

If [M:SMV1]ITMREF <> ""          # hcb graph
   CHMEN += "12"                 # hcb graph
Endif                            # hcb graph
Return
############################################################
$EXEBOUT
Return
############################################################
$AGREG
Raz WAGR
# Si agrégation
If [M:CSMV]AGGFLG = 2 & NOL <> -1
  For I = 0 To MAXLIG-1
    If [M:SMV2]STOFCY(I)    = "" : Break : Endif
    If dim([M:SMV2]LOT) > 0
         WLOT = [M:SMV2]LOT(I)
    Else WLOT = ""
    Endif
    If dim([M:SMV2]SLO) > 0
         WSLO = [M:SMV2]SLO(I)
    Else WSLO = ""
    Endif
    If dim([M:SMV2]LOC) > 0
         WLOC = [M:SMV2]LOC(I)
    Else WLOC = ""
    Endif
    If dim([M:SMV2]PALNUM) > 0
         WPAL = [M:SMV2]PALNUM(I)
    Else WPAL = ""
    Endif
    If dim([M:SMV2]CTRNUM) > 0
         WCTR = [M:SMV2]CTRNUM(I)
    Else WCTR = ""
    Endif
    If WLOT                 = [F:STJ]LOT       &
&      WSLO                 = [F:STJ]SLO       &
&      WLOC                 = [F:STJ]LOC       &
&      WPAL                 = [F:STJ]PALNUM    &
&      WCTR                 = [F:STJ]CTRNUM    &
&      [M:SMV2]STA(I)       = [F:STJ]STA       &
&      [M:SMV2]PCU(I)       = [F:STJ]PCU       &
&      [M:SMV2]QLYCTLDEM(I) = [F:STJ]QLYCTLDEM &
&      [M:SMV2]TRSTYP(I)    = [F:STJ]TRSTYP
      [M:SMV2]QTYPCU(I)    += [F:STJ]QTYPCU
      [M:SMV2]QTYSTU(I)    += [F:STJ]QTYSTU
      [M:SMV2]ACTQTY(I)    += [F:STJ]ACTQTY
      [M:SMV2]AMTORD(I)    += [F:STJ]AMTORD
      [M:SMV2]AMTVAL(I)    += [F:STJ]AMTVAL
      [M:SMV2]VARORD(I)    += [F:STJ]VARORD
      [M:SMV2]VARVAL(I)    += [F:STJ]VARVAL
      If dim([M:SMV2]SERNUM) > 0 & [M:SMV2]SERNUM(I)<>""
        [M:SMV2]SERNUM(I) = [F:STJ]SERNUM
        [M:SMV2]SERFIN(I) = "$"
      Endif
      If dim([M:SMV2]BEFSTO) > 0
        If WSEL = 0 & WBUT = 0 & [M:SMV2]TRSTYP(I)<>23
          If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
             #[M:SMV2]AFTSTO(I) = WSTO
             WSTO -= [F:STJ]QTYSTU
             [M:SMV2]BEFSTO(I) = WSTO
           Else
              #[M:SMV2]BEFSTO(I) = WSTO
              WSTO += [F:STJ]QTYSTU
              [M:SMV2]AFTSTO(I) = WSTO
          Endif
        Endif
      Endif
      WAGR=1
      Break
    Endif
  Next I
  If WAGR = 1
    nolign -= 1
    NOL    -= 1
    WLIG   -= 1
    Return
  Endif
Endif
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
## Rajout du dépôt (écran CONSSMV1) 02/02/2010 11:26:08 (PLI)
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
End
############################################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local    Char WPAR
[M:SMV1]FLG = 0
#
If dim([M:SMV1]WRH) > 0
   Raz   [M:SMV1]WRH
   Affzo [M:SMV1]WRH
Endif
# Détermination délai d'interrogation (défaut 30 jours)
If [M:SMV1]INQLTI = 0
  Call PARAM(VALEUR,"INQMVSLTI",WPAR) From ADOVAL
  If val(WPAR) <> 0
    [M:SMV1]INQLTI = val(WPAR)
  Endif
  If [M:SMV1]INQLTI = 0
    [M:SMV1]INQLTI = 30
  Endif
Endif
#--- Bug 77058
GFCY=VALEUR
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Gosub AFF_TITCOL
#---
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SMV1]ITMREF = VALEUR    # hcb X3-70317
Gosub DIS_ITMREF
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
End
############################################################
Subprog AM_INQLTI(VALEUR)
Variable Decimal VALEUR
[M:SMV1]FLG = 0
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
#Controle si le lot existe sur le site
If !clalev([STJ]) : Local File STOJOU [STJ] : Endif
If !clalev([STJ1]) : Local File STOJOU [STJ1] : Endif
If VALEUR  <> "" & [M:SMV1]ITMREF = ""
  If [M:SMV1]FCY <> ""
    Filter [STJ] Where  LOT  = VALEUR & STOFCY = [M:SMV1]FCY
&            Order By Key STJ0 Desc
  Else
      Filter [STJ] Where  LOT  = VALEUR
&            Order By Key STJ0 Desc
  Endif
  Read [STJ] First
  If fstat = 0 & [F:STJ]ITMREF <>""
    If [M:SMV1]FCY <> ""
      Filter [STJ1] Where  ITMREF <> [F:STJ]ITMREF &
&       LOT  = [F:STJ]LOT & STOFCY = [M:SMV1]FCY
    Else
      Filter [STJ1] Where  ITMREF <> [F:STJ]ITMREF &
&       LOT  = [F:STJ]LOT
    Endif
    Read [STJ1] First
    If fstat = 0
      Call MESSAGE (mess(393,184,1)) From GESECRAN
      Raz VALEUR : zonsui = "[M:SMV1]ITMREF"
    Else
      [M:SMV1]ITMREF = [F:STJ]ITMREF : Affzo [M:SMV1]ITMREF : zonsui ="[M:SMV1]ITMREF"
    Endif
  Else
    If fstat
      GMESSAGE=mess(394,184,1)+[M:SMV1]FCY
      mkstat=2
    Endif
  Endif
  Filter [STJ]
  Filter [STJ1]
Endif

End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
[M:SMV1]STOCOUSEL = 0
End
############################################################
Subprog AM_SERNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]SERNUMEND = ""     : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
If [M]SERNUMEND < VALEUR : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
[M:SMV1]FLG = 0
[M:SMV1]STOCOUSEL = 0
End
############################################################
Subprog C_SERNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]SERNUMSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End
############################################################
Subprog AM_SERNUMEND(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
[M:SMV1]STOCOUSEL = 0
End
############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(2) = 1
GMENLOC(8) = 1
GMENLOC(12) = 1     # hcb59291

End
############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
#############################################################
Subprog AS_MISFLG(VALEUR)
Variable Integer VALEUR
End
#############################################################
Subprog AM_SRTCOD(VALEUR)
Variable Integer  VALEUR
[M:SMV1]FLG = 0
End
