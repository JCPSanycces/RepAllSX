[M:SMV1]FLG = 0
End
############################################################
Subprog AM_STDFLG(VALEUR)
Variable Integer VALEUR
[M:SMV1]FLG = 0
End

##########################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,5,6,7,9,10,13,14,16,19,20,21,27,29,30,31,32,33,34,35,36,37)
        GMENLOC(I) = 1
    Endif
Next
End

######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SMV2]LOT
######################################################################################
Subprog IB_NBLIG
    # Seules les réceptions et les entrées OF ont pu être régularisées
    If !find([M:SMV2]TRSTYP(nolign-1),3,5)
        Raz GBOUT2
    Endif
    If [M:SMV2]NUMVCR(nolign-1)=""
        Raz GBOUT3
    Endif
    # Pas de consultation stock/lot ou traçabilité si lot non renseigné
    If dim([M:SMV2]LOT) > 0 Then      # SYMEU 61044
      If [M:SMV2]LOT(nolign-1)="" Then
          Raz GBOUT4
      Endif
    Endif
    If (dim([M:SMV2]LOT) > 0 and [M:SMV2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then   # SYMEU 61044
        Raz GBOUT5
    Endif
    If !GACTDECCST
        Raz GBOUT6, GBOUT7
    Endif
    If !find([M:SMV2]VCRTYP(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT8
    Else
      # Issue X3-73341 - 2018-02-19 by MAE : ajout du type "changement de contenant"
      If [M:SMV2]TRSTYP(nolign-1) <> 36
        GBOUT8 = mess([M:SMV2]VCRTYP(nolign-1),701,1)-"("+[M:SMV2]VCRNUM(nolign-1)+")"
      Else
        # Issue 106909 - 2018-09-21 by MAE : gestion des opérations et affectations LPN
        Read [SGH] SGH0 = [M:SMV2]VCRNUM(nolign-1)
        If fstat
          Raz GBOUT8
        Else
          If find([F:SGH]MODOPELPN,1,2,3)
             GBOUT8 = func AFNC.TEXTE(1003869)-"("+[M:SMV2]VCRNUM(nolign-1)+")"
          Else
             GBOUT8 = func AFNC.TEXTE(1003554)-"("+[M:SMV2]VCRNUM(nolign-1)+")"
          Endif
        Endif
          #pas de tunnel si le type est "changement de contenant" : on ne sait pas si le mouvement provient de l'affectation ou des opérations
          #Raz GBOUT8
         # End issue X3-106909
      Endif
      # End issue X3-73341
    Endif

    If !find([M:SMV2]VCRTYPORI(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT9
    Else
        GBOUT9 = mess([M:SMV2]VCRTYPORI(nolign-1),701,1)-"("+[M:SMV2]VCRNUMORI(nolign-1)+")"
    Endif
    #MAE, bg 76931, type de mouvement : demande d'analyse ou type de piéce : controle qualité
    #=> pas de tunnel
    If [M:SMV2]TRSTYP(nolign-1)=34 | [M:SMV2]VCRTYP(nolign-1)=28
      Raz GBOUT8
      #si piéce origine=changement de stock, pas de tunnel car le changement de stock
      #lié à un controle qualité n'est pas visible par l'objet
      If [M:SMV2]VCRTYPORI(nolign-1)=29
        Raz GBOUT9
      Endif
    Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSMV2) 02/02/2009 10:11:13 (CCC)
######################################################################################
Subprog B6_NBLIG
    GBIDC1="SJVO"
    Gosub ACT_SAIDECPRI
End

Subprog B7_NBLIG
    GBIDC1="SJVV"
    Gosub ACT_SAIDECPRI
End

$ACT_SAIDECPRI
If GACTDECCST
    Raz [F:STJ], [F:SJV]
    For [STJ] Where STOFCY=[M:SMV2]STOFCY(nolign-1)
&                 & UPDCOD=2
&                 & ITMREF=[M:SMV1]ITMREF
&                 & IPTDAT=[M:SMV2]IPTDAT(nolign-1)
&                 & MVTSEQ=[M:SMV2]MVTSEQ(nolign-1)
&                 & MVTIND=[M:SMV2]MVTIND(nolign-1)
        Break
    Next
    Read [SJV]SJV0=[M:SMV2]STOFCY(nolign-1);2;[M:SMV1]ITMREF;[M:SMV2]IPTDAT(nolign-1);[M:SMV2]MVTSEQ(nolign-1);[M:SMV2]MVTIND(nolign-1)
    If fstat
        mkstat=2
    Endif
Endif
Return


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SMV") From SUBGTC

End



######################################################################################
Subprog B8_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMV2]VCRTYP(NOL),[M:SMV2]VCRNUM(NOL),[M:SMV2]TRSTYP(NOL)) # hcb 103385
End

######################################################################################
Subprog B9_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMV2]VCRTYPORI(NOL),[M:SMV2]VCRNUMORI(NOL),0)           # hcb 103385
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM,PTRS)                                         # hcb 103385
Value Integer PTYP
Value Char    PNUM
Value Integer PTRS                                                       # hcb 103385
Local  Integer WGCONSULT1 : WGCONSULT1 = GCONSULT   # hcb 90803
GCONSULT = 2


# hcb 78584 deb
Local Char    WFCY(GLONFCY)
Local Integer WUPD
Local Char    WITM(GLONITM)
Local Char    WLOT(GLONLOT)
Local Char    WLOC(GLONLOC)
Local Char    WSTA(GLONSTA)
Local Char    WPCU(GLONUOM)
Local Decimal WCOE
Local Date    WIPT
Local Date    WDAT
Local Char    WTIM
Local Date    WMDA : # Bug 88530
Local Char    WMTI : # Bug 88530
Local Integer WSEQ
Local Integer WIND
WFCY = [F:STJ]STOFCY
WUPD = [F:STJ]UPDCOD
WITM = [F:STJ]ITMREF
WIPT = [F:STJ]IPTDAT
WSEQ = [F:STJ]MVTSEQ
WIND = [F:STJ]MVTIND
WLOT = [F:STJ]LOT
WLOC = [F:STJ]LOC
WSTA = [F:STJ]STA
WPCU = [F:STJ]PCU
WCOE = [F:STJ]PCUSTUCOE
WTIM = [F:STJ]CRETIM
WDAT = [F:STJ]CREDAT
WMTI = [F:STJ]CREMVTTIM : # Bug 88530
WMDA = [F:STJ]CREMVTDAT : # Bug 88530
Local Char   WWFIL1(250),WWFIL2(250), WWFILS(250), WWFILF(250), WWFILX(250), WWSTR(250), WWFILSPE(250)    # hcb 90908
Local Char   WWFIL11(250),WWFILX1(250)  # hcb X3-69570

WWFIL1    = WFIL1    # 90908
WWFIL2    = WFIL2    # 90908
WWFILS    = WFILS    # 90908
WWFILF    = WFILF    # 90908
WWFILX    = WFILX    # 90908
WWSTR     = WSTR     # 90908
WWFILSPE  = WFILSPE  # 90908
WWFILX1   = WFILX1    # hcb X3-69570
WWFIL11   = WFIL11    # hcb x3-69570

# hcb 78584 deb

Case PTYP
When 2   # commande vente
    Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
When 4   # livraison
    Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
When 5   # Facture vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 6   # reception
    Call OBJET("PTH",PNUM,num$(PTYP)) From GOBJET
When 8   # Retour fournisseur
    Call OBJET("PNH",PNUM,num$(PTYP)) From GOBJET
When 9   # inventaire
    #MAE, bg 76607
    Gosub SET_NOL From STKINV
    GCONSULT = 2
    #Call OBJET("SNL",PNUM,num$(PTYP)) From GOBJET
    Call OBJET("SNL",PNUM,[M:SMV2]VCRNUMORI(NOL)) From GOBJET
    GCONSULT = 0
When 10  # ordre de fabrication
    Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
When 12  # suivi matiere
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 13  # retour client
    If PTRS = 12                                                     # hcb 103385
       # retour livraison
       Call OBJET("SRH",PNUM,num$(PTYP)) From GOBJET
    Elsif PTRS = 18                                                  # hcb 103385
       # retour pret
       Call OBJET("SRL",PNUM,num$(PTYP)) From GOBJET                 # hcb 103385
    Endif                                                            # hcb 103385
When 14  # commande achat
    #MAE, bug 99810
    #Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
    If clalev([F:POH]) = 0 : Local File PORDER[POH] : Endif
    Read [POH]POH0=PNUM
    If [F:POH]POHTYP = 1
      Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
    Else
      Call OBJET("POC",PNUM,num$(PTYP)) From GOBJET
    Endif
When 15  # declaration de production
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 17  # facture achat
    Call OBJET("PIH",PNUM,num$(PTYP)) From GOBJET
When 18  # avoir vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 19  # entrée diverse
    Call OBJET("SMR",PNUM,num$(PTYP)) From GOBJET
When 20  # sortie diverse
    Call OBJET("SMO",PNUM,num$(PTYP)) From GOBJET
When 26  # Réintégration stock (inactif)
    Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
When 28  # controle qualite
    Call OBJET("STQ",PNUM,num$(PTYP)) From GOBJET
When 29  # changement de stock
      If PTRS = 36
       # Issue X3-106909 - 2018-09-21 by MAE : tunnels opérations et affectations
       If find([F:SGH]MODOPELPN,1,2,3)
        Call OBJET("LPNOPE",PNUM,num$(PTYP)) From GOBJET
       Else
        Call OBJET("LPNAFF",PNUM,num$(PTYP)) From GOBJET
       Endif
       # End issue X3-106909
      Else
        Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
      Endif
When 31  # assemblage
    Call OBJET("BBY",PNUM,num$(PTYP)) From GOBJET
When 32  # desassemblage
    Call OBJET("DBY",PNUM,num$(PTYP)) From GOBJET
When 33  # Demande de service
    #Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
    #MAE, Bug 121094
    If clalev([F:SRE]) = 0 : Local File SERREQUEST[SRE] : Endif
    If clalev([F:HDT]) = 0 : Local File HDKTASK[HDT] : Endif
    #lecture de la demande de service
    Read[SRE]SRE0 = PNUM
    If fstat =  0
        Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
    Else
        Read [HDT]HDT0=PNUM        #consommation
        If fstat = 0
            Call OBJET("SRE",[F:HDT]SRENUM,num$(PTYP)) From GOBJET
        Endif
    Endif
#fin MAE bug 121094
When 35  # modification des lots
     #MAE, bg 77811 pas de tunnel sur modification de lot car on ne sait pas
     #quel objet utilisé : SMX ou SLM
     #Call OBJET("SLM",PNUM,num$(PTYP)) From GOBJET
When 36  # Ordre de sous-traitance
    Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
Endcase
#GCONSULT = 0                                             # hcb 90803
If dim(WGCONSULT1) > 0 : GCONSULT = WGCONSULT1 : Endif    # hcb 90803
Global Char   WFIL1(250),WFIL2(250), WFILS(250), WFILF(250), WFILX(250), WSTR(250), WFILSPE(250)    # hcb 90908
Global Char   WFIL11(250), WFILX1(250)  # hcb x3-69570

WFIL1   = WWFIL1    # 90908
WFIL2   = WWFIL2    # 90908
WFILS   = WWFILS    # 90908
WFILF   = WWFILF    # 90908
WFILX   = WWFILX    # 90908
WSTR    = WWSTR     # 90908
WFILSPE = WWFILSPE  # 90908
WFILX1   = WWFILX1    # hcb X3-69570
WFIL11   = WWFIL11    # hcb x3-69570

# hcb 78584 deb
# hcb x3-69570  rajout WFIL11
  Filter [STJ]
  Case [M:SMV1]SRTCOD
    When 1 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE) & evalue(WFIL11)
&                  Order By Key STJ0
      For [STJ]
      If [F:STJ]STOFCY=WFCY &
&        [F:STJ]UPDCOD=WUPD &
&        [F:STJ]ITMREF=WITM &
&        [F:STJ]IPTDAT=WIPT &
&        [F:STJ]MVTSEQ=WSEQ &
&        [F:STJ]MVTIND=WIND
         Break
      Endif
      Next

    When 3 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      For [STJ]
      If [F:STJ]ITMREF>=WITM &
&        [F:STJ]LOT   >=WLOT &
&        [F:STJ]STOFCY>=WFCY &
&        [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]UPDCOD>=WUPD &
&        [F:STJ]MVTIND>=WIND
         Break
      Endif
      Next

    When 4 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      For [STJ]
      If [F:STJ]ITMREF>=WITM &
&        [F:STJ]LOC   >=WLOC &
&        [F:STJ]STOFCY>=WFCY &
&        [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]UPDCOD>=WUPD &
&        [F:STJ]MVTIND>=WIND
         Break
      Endif
      Next
    When 5 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                 Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      For [STJ]
      If [F:STJ]ITMREF>=WITM &
&        [F:STJ]STA   >=WSTA &
&        [F:STJ]STOFCY>=WFCY &
&        [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]UPDCOD>=WUPD &
&        [F:STJ]MVTIND>=WIND
         Break
      Endif
      Next

    When 6 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      For [STJ]
      If [F:STJ]ITMREF    >=WITM &
&        [F:STJ]PCU       >=WPCU &
&        [F:STJ]PCUSTUCOE >=WCOE &
&        [F:STJ]STOFCY    >=WFCY &
&        [F:STJ]IPTDAT    >=WIPT &
&        [F:STJ]MVTSEQ    >=WSEQ &
&        [F:STJ]UPDCOD    >=WUPD &
&        [F:STJ]MVTIND    >=WIND
         Break
      Endif
      Next

    When 9 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc : # Bug 88530
#&                  Order By ITMREF; IPTDAT; STOFCY; MVTSEQ Desc; UPDCOD                       : # Bug 88530
      For [STJ]
#--- Bug 88530
#      If [F:STJ]ITMREF>=WITM &
#&        [F:STJ]IPTDAT>=WIPT &
#&        [F:STJ]STOFCY>=WFCY &
#&        [F:STJ]MVTSEQ>=WSEQ &
#&        [F:STJ]UPDCOD>=WUPD &
#&        [F:STJ]MVTIND>=WIND
      If [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]CREMVTDAT>=WMDA &
&        [F:STJ]CREMVTTIM>=WMTI &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]MVTIND>=WIND
#---
         Break
      Endif
      Next

    When 10 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
      For [STJ]
      If [F:STJ]ITMREF>=WITM &
&        [F:STJ]CREDAT>=WDAT &
&        [F:STJ]CRETIM>=WTIM &
&        [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]MVTIND>=WIND
         Break
      Endif
      Next


    When 11 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ Desc
      For [STJ]
      If [F:STJ]ITMREF>=WITM &
&        [F:STJ]CREDAT>=WDAT &
&        [F:STJ]CRETIM>=WTIM &
&        [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]MVTIND>=WIND
         Break
      Endif
      Next

    When Default :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)  & evalue(WFIL11)
&                  Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc : # Bug 88530
#&                  Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD                        : # Bug 88530
      For [STJ]
#--- Bug 88530
#      If [F:STJ]ITMREF>=WITM &
#&        [F:STJ]IPTDAT>=WIPT &
#&        [F:STJ]STOFCY>=WFCY &
#&        [F:STJ]MVTSEQ>=WSEQ &
#&        [F:STJ]UPDCOD>=WUPD &
#&        [F:STJ]MVTIND>=WIND
      If [F:STJ]IPTDAT>=WIPT &
&        [F:STJ]CREMVTDAT>=WMDA &
&        [F:STJ]CREMVTTIM>=WMTI &
&        [F:STJ]MVTSEQ>=WSEQ &
&        [F:STJ]MVTIND>=WIND
#---
         Break
      Endif
      Next

  Endcase
# hcb 78584 fin

End

