Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
