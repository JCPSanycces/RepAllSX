#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRAFRCLS2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:34"
A_USER  = "DOC"
A_STAMP = "20181109230434"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "LIGNUM"
  If [M]LIGNUM=0
  Endif
 When "LIGNUMREM"
  If [M]LIGNUMREM=0
  Endif
 When "LIGNUMTOT"
  If [M]LIGNUMTOT=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRAFRCLS2 [HRAC2]
Gosub HORODAT
Local Inpbox "HRAFRCLS2" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRAC2] As [SIM_]
Grizo [HRAC2]5
Grizo [HRAC2]10
Grizo [HRAC2]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRAC2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=37 : Y1(0)=1 : Y2(0)=14
X1(1)=38 : X2(1)=74 : Y1(1)=1 : Y2(1)=14
X1(2)=1 : X2(2)=37 : Y1(2)=15 : Y2(2)=28
Return

$ON_DAT
Onevent BEFORE_AREA Gosub AV_DAT From W1HRAFRCLS2
Return

$AV_DAT
Chgfmt [M]DAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATREM
Onevent BEFORE_AREA Gosub AV_DATREM From W1HRAFRCLS2
Return

$AV_DATREM
Chgfmt [M]DATREM(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATTOT
Onevent BEFORE_AREA Gosub AV_DATTOT From W1HRAFRCLS2
Return

$AV_DATTOT
Chgfmt [M]DATTOT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$CHG_STY
Return


