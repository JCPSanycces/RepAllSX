#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM201808001 Delete screen PJMBUD0B
# Issue X3-107733 - 2018-10-09 by FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201808001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201808001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR

  Call ECR_TRACE("UTIPJM201808001: Process Start on : "+DOSSIER,0) From GESECRAN
  IERR = 0
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AMSK"  [AMK]
  Local File =DOSSIER + ".AMSKZON"  [AMZ]
  Local File =DOSSIER + ".AMSKACT"  [AMA]
  Local File =DOSSIER + ".AMSKPAR"  [AMP]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [AMK]
  Filter [AMK] Where [F:AMK]CODMSK = "PJMBUD0B"
  For [AMK]
    # Delete the wrong action
    COMPTEUR += 1
    Delete [AMZ] Where CODMSK=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKZON" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMA] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKACT" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMP] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKPAR" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMK]Curr
    If fstat Then
      Call ECR_TRACE("File AMSKACT" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Call DEL_TRTMSK([F:AMK]CODMSK, DOSSIER) From MSKDIV
  Next
  Filter [AMK]
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201808001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201808001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  #If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTIPJM201808001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  Call MAJ_UTIPJM201808001(APPLI)
End

