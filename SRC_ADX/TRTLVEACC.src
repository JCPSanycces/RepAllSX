#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask management TRTACC
####################################################################################################################

###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLVEACC","TRTLVEACC",4,"") From GTRAITE
End

#########################################

$ACTION

Case ACTION
When "INIT" : Gosub OUVRE
When "EXEC" : Gosub EXEC
When "DEBUT" : Gosub DEBUT
When "OK"          : FIN = 1 : GOK = 1
When "END"         : Gosub FIN
When "CONTROLE"    : Gosub CONTROLE From TRTAUT : #X3-46593
Endcase
Return

$OUVRE
#MIPEA - 2017-08-30- US X3-36337- START
Local Mask TRTLVEACC [DIA]
#MIPEA - 2017-08-30- US X3-36337- END

Gosub OUVRE From WPDEFTABLE
If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA   [HRPEOH] : Endif

Effzo [M]DIA

#MIPEA - 2017-08-30- US X3-36337- START
TIT = mess(24,11691,1)
#TIT = "Manual Leave Accrual Process"
#MIPEA - 2017-08-30- US X3-36337- END

#PEVAN - 2018-09-27 - X3-109636 - START
  Call KILL_GLM_GLOBALS From SUBHRBAL
#PEVAN - 2018-09-27 - X3-109636 - END

Return

$DEBUT

If clalev([M:DIA])>0
 Grizo [M:DIA]CPY
 Grizo [M:DIA]FCY
 Grizo [M:DIA]SRV
 Grizo [M:DIA]PRF
 Grizo [M:DIA]PERCOD
 Grizo [M:DIA]PERNUM
Endif
#ADNGO - 2017-08-02 - X3-36330 - START
If [M:DIA]ALLEXTPER = 2 or [M:DIA]ALLEXTPER = 0
  [M:DIA]ALLPERCOD = 2 : Diszo [M:DIA]ALLPERCOD
Endif
#ADNGO - 2017-08-02 - X3-36330 - END

#LIPET - 2017-06-30 - X3-46779 - START
If GLEGFIL<>"" : GCURLEG=GLEGFIL:Endif
#LIPET - 2017-06-30 - X3-46779 - END
Affzo [M:DIA]
#ADNGO - 2017-08-04 - X3-36330 - START
#zonsui = "[M:DIA]LEG"
 Setmok [DIA] With 0
 Call AFF_MEMO From DIVPAYE
#ADNGO - 2017-08-04 - X3-36330 - END
Return

######################################################################################
## Section automatically added (screen TRTACC) 06/23/2017 12:11:27 (SAVAN)
######################################################################################
Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-08-02 - X3-36330 - START
#If VALEUR <> [M]LEG
#  GCURLEG=VALEUR
#  [M]ALLEXTPER = 2
#  [M]ALLPERCOD = 2
#  Affzo [M]PERCOD
#  Affzo [M]PERNUM
#Endif
#ADNGO - 2017-08-02 - X3-36330 - END
End

$FIN
GOK = 0
#MIPEA - 2018-06-14-  X3-92309- START
Return
#End
#MIPEA - 2018-06-14-  X3-92309- END

$EXEC
Local Char CRITERE(250)
Local Char FUTBALS(250)(0..,0..10)

#Opening the trace and writing the header
#MIPEA - 2018-06-14-  X3-92309- START
#If !GSERVEUR
#MIPEA - 2018-06-14-  X3-92309- END
 Call OUVRE_TRACE(TIT) From LECFIC
#MIPEA - 2018-06-14-  X3-92309- START
#Endif
#MIPEA - 2018-06-14-  X3-92309- END
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = "1=0"
CRITERE -= '| [F:FCY]LEG = "'+GCURLEG+'"'
If [M:DIA]ALLCPY<>2
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLSRV<>2
 CRITERE -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2
 CRITERE -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif
If [M:DIA]ALLEXTPER<>2
 CRITERE -= '& PERCOD="'+[M:DIA]PERCOD+'"'
Endif
If [M:DIA]CTRDEB<>""
 CRITERE -= '& [F:HRCTR]CTRNUM>="'+[M:DIA]CTRDEB+'"'
Endif
If [M:DIA]CTRFIN<>""
 CRITERE -= '& [F:HRCTR]CTRNUM<="'+[M:DIA]CTRFIN+'"'
Endif
#MIPEA 2018-02-19 X3-74480 - START
Local Integer ACC_GOK
Local Char ERRMESSAGE(250)
Call LVE_ENG("",CRITERE,"","","","",[0/0/0],FUTBALS,0,ERRMESSAGE,ACC_GOK,[0/0/0],[0/0/0],0) From SUBACCRUAL
#Call LVE_ENG("",CRITERE,"","","","",[0/0/0],FUTBALS) From SUBACCRUAL
#MIPEA 2018-02-19 X3-74480 - END
Call FERME_BOITE From GESECRAN

#Closing the trace file with a message
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC #Displaying Log file
Endif

Return


Subprog AM_PERCOD(VALEUR)
Variable Char    VALEUR()
[M]ALLPERCOD = 2 : Affzo [M]ALLPERCOD
Raz [M]PERNUM : Affzo [M]PERNUM : Grizo [M]PERNUM
End

Subprog AM_ALLPERCOD(VALEUR)
Variable Integer VALEUR
Local Char VALBOUT : VALBOUT = ""
Local Char PARBOUT : PARBOUT = "HRPER0"
Global Char GFRQCOD
Local Date STR2, END2
Local Date STR2, END2
Local Integer TAXYEA, TAXMON
Local Integer NBPERNUM,NUMPERNUM
Local Char LIBHRPEO(130)(0..100)
Local Integer    TBPERNUM(GLONVCR)(0..100)
Local Char    TITBOITE(250)
#MIPEA - 2017-08-30- US X3-36337- START
#Local Mask TRTLVEACC [TRTLVEAC]
#MIPEA - 2017-08-30- US X3-36337- END
GFRQCOD=[M:DIA]PERCOD

If VALEUR <> [M]ALLPERCOD
  If VALEUR = 1
    If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
    If !clalev([F:HRPEOH]) : Local File HRPEOHEA [HRPEOH] : Endif

    [L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
    [L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))


       Link [F:HRPEOD]
&      With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&      As [LNK]
&      Where [F:HRPEOD]PERCOD=GFRQCOD & [F:HRPEOH]FLGENA=2
&          & (month([F:HRPEOD]PERSTR(1))=month([L]STR2) or month([F:HRPEOD]PEREND(1))=month([L]END2))
&          & (year([F:HRPEOD]PERSTR(1))=year([L]STR2) or year([F:HRPEOD]PEREND(1))=year([L]END2))

If rowcount([LNK]) = 0
  GERR = 2 : GMESSAGE = [M:DIA]PERCOD + " - " + mess(00164,00107,1)+ " " + format$(GFMD,[L]STR2) + " to " + format$(GFMD,[L]END2) + " " + mess(00002,00126,1)
  [M:DIA]ALLPERCOD = 2 : Affzo [M:DIA]ALLPERCOD
  Raz [M:DIA]PERCOD : Affzo [M:DIA]PERCOD
Endif

    [L]TAXMON = [F:HRPEOD]TAXMON
    [L]TAXYEA = [F:HRPEOD]PERYEA

    For [LNK]
      NBPERNUM+=1
      TBPERNUM(NBPERNUM) = [F:HRPEOD]PERNUM
      LIBHRPEO(NBPERNUM) = num$([F:HRPEOD]PERNUM)-num$([F:HRPEOD]PERSTR(1))-"-"-num$([F:HRPEOD]PEREND(1))
    Next
#MIPEA - 2017-08-30- US X3-36337- START - REMOLVED SAITEX FROM THIS SOURCE AS IT IS DUPLICATED
    Call SAITEX(NBPERNUM,LIBHRPEO,NUMPERNUM,TITBOITE) From GESECRAN : # Choose period
#    Call SAITEX(NBPERNUM,LIBHRPEO,NUMPERNUM,TITBOITE) : # Choose period
#MIPEA - 2017-08-30- US X3-36337- END

     Link [F:HRPEOD]
&    With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&    As [LNK]
&    Where [F:HRPEOD]PERCOD=GFRQCOD & [F:HRPEOH]FLGENA=2
&        & [F:HRPEOD]PERNUM=TBPERNUM(NUMPERNUM)

    Read [LNK] First
    If !fstat
      [M:DIA]PERNUM     = [F:HRPEOD]PERNUM    : Affzo [M:DIA]PERNUM    : Grizo [M:DIA]PERNUM
    Endif

  Endif
Endif

If VALEUR = 2
  Raz [M:DIA]PERNUM     : Grizo [M:DIA]PERNUM
Endif

End
End
######################################################################################

