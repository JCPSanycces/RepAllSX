#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  DISPLAY OF TEXT (clob format)                              MCLOB     #
#                                                                       #
#########################################################################

$ACTION
Case ACTION
    When "INIT_DIA" : Gosub INIT_DIA
Endcase
Return

#########################################################################
$INIT_DIA
If !clalev([F:TCC]) Local File TEXCPT  [TCC] Endif
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

Local Integer STAT

If PARAM(1)<>""
   If !find(PARAM(1),GCLOIDE(1..GCLOMAX))   # ?????
      Read [TXC]TXC0=PARAM(1)
      If !fstat
         Call RANGE_CLOB([F:TXC]TEXTE,PARAM(1),STAT) From ACLOB
         If STAT=1
            # memory size for texts exceeded
            Call ERREUR(mess(215,126,1)-"("+num$(GCLOMEM)-"Ko)") From GESECRAN
         Endif
      Endif
   Endif

   Call LIRE_CLOB(CLOB,PARAM(1),STAT) From ACLOB
Endif

Return

