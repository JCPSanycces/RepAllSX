#
#*********************************************************************
#    Modification
#    FQ120877 13.01.2017 -  MWA   Mise au rebut avec amortissement exceptionnel + Sortie rétro active + Différé sans dérogatoire (Dotation exercice erronnée)
#    FQ118852 10.10.2016 -  MWA   Mise au rebut avec amortissement exceptionnel mode SA
#    FQ116123 21.04.2016 -  MWA   Mauvaise répartition de la dotation exercice sur les périodes en reprise de différé
#    FQ112798 17.02.2016 -  MWA   Prise en compte d'une nième modernisation dans l'exercice
#    FQ107988 28.05.2015 -  MWA   Gestion règle particulière "Déduction 40% [15avr15 - 14avr16]"
#    FQ106650 12.02.2015 -  MWA   Adaptation réintégration véhicule (solde en fin d'amortissement)
#    FQ105809 12.02.2015 -  MWA   Ajout modes turques - TL Linéaire turque  & TD Dégressif turque
#    FQ103931 03.12.2014 -  MWA   Plafond différé espagnol (paramètre DPRPLNPIO)
#    FQ104280 24.11.2014 -  MWA   Réinitialisation des zones de travail contenant l'ecart à clôture exercice
#    FQ103339 24.11.2014 -  MWA   Complément sur Différé espagnol 2013 2014
#    FQ100336 08.07.2014 -  MWA   Gestion de la plus ou moins value selon régime d'imposition IR et IS
#    FQ95945  20.01.2014 -  MWA   Effet de bord 90157. (à ne pas faire en reconstitution de cumul)
#    FQ94548  11.12.2013 -  MWA   Problème calcul plafond de reprise de dépréciation sur biens négatifs.
#    FQ94247  07.11.2013 -  MWA   Problème lors du report de la FQ52587
#    FQ90432  24.09.2013 -  MWA   Différé espagnol 2013 2014
#    FQ90157  30.05.2013 -  MWA   Clôture exercice : Mise à jour amortissement exceptionnel exercice dernière periode
#    FQ84281  09.04.2013 -  MWA   Ajout modes suisses - HL Linéaire suisse  & HD Dégressif suisse
#    FQ85936  30.11.2012 -  MWA   Réevaluation fin exercice (autres types de réévaluation)
#    FQ79819  11.09.2012 -  MWA   Réevaluation fin exercice (valeur marché)
#    FQ80825  11.06.2012 -  MWA   Arrêt/redemarrage modes roumains
#    FQ72372  15.02.2012 -  MWA   Dégressif polonais
#    FQ75678  10.08.2011 -  MWA   Adaptation clôture pour bien déprécié en linéaire polonais.
#    FQ74785  05.07.2011 -  MWA   Résultats erronés en SRA d'un bien déprécié.
#    FQ67577  03.12.2010 -  MWA   Gestions des modes polonais.
#    FQ72008  01.03.2011 -  MWA   Correction du calcul du plafond de reprise de réévaluation
#    FQ59941  01.07.2010 -  MWA   Gestion des modes russes
#    FQ61773  28.01.2010 -  MWA   Réintégration sur immobilisation négative
#*********************************************************************
#         C L O T U R E     /    PERIODIQUE & EXERCICE
#*********************************************************************
#
#
#
#########################################################
$CAL_CLORE_EXERCICE_AMT
#
# - Objet  : Exécute la clôture exercice
#            pour les informations du plan d'amortissement
#
# Rem.     : La clôture périodique a été réalisée au préalable
#            sauf dans le cas d'une reconstitution de cumul.
#
# - Entrée : [F:DEPC]
#            Origine de la clôture ("CAL" Calcul / "CLO" Clôture)
#
# - Sortie : [F:DEPS]
#
#   Boite noire gcfc06
#


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

   # FQ90157 Dans certains cas, EXCDPR n'est pas correct, il a été décidé CFF de le mettre à jour avant
   #         clôture exercice sur la dernière periode
  # FQ95945 A ne pas faire en reconstitution de cumul
  If not ([M:DIV]BCUME_1)
  [F:DEPC]EXCDPR     = [F:DEPC]PERCLOEXC  + [F:DEPC]PEREXCDPR    : # Cum E-1 Amt. Except.
  [F:DEPC]EXCDPRT    = [F:DEPC]PERCLOEXCT + [F:DEPC]PEREXCDPRT   : # Cum E-1 Amt. Except. Théo.
  [F:DEPC]EXCDPRI    = [F:DEPC]PERCLOEXCI + [F:DEPC]PEREXCDPRI   : # Cum E-1 Amt. Except. Init.
  Endif

  # --------------------------
  # -- CHANGEMENT DE METHODE
  # --------------------------

  # -- Report à nouveau, Dans l'Exercice
  [F:DEPS]MTCDEVADJ  = 0      : # Type gestion écart "Pas de changement de méthode"
  [F:DEPS]MTCDPEDEV  = 0      : # Ecart sur cumul E-1
  [F:DEPS]MTCDPEDEVI = 0      : # Ecart sur cumul E-1 Init
  [F:DEPS]MTCDPEDEVT = 0      : # Ecart sur cumul E-1 Théo
  [F:DEPS]MTCTIATYP  = 0      : # Prise d'effet du changement de méthode
  [F:DEPS]MTCTIADAT = [0/0/0] : # Date d'effet du changement de méthode
  [F:DEPS]MTCDPEDAT = [0/0/0] : # Date du changement de méthode
  # --

  [F:DEPS]PERREFCLC  = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]FIYENDDAT, 1, "D" )     : # Début exercice
  [F:DEPS]PERREFCLCT = [F:DEPS]PERREFCLC
  [F:DEPS]PERREFCLCI = [F:DEPS]PERREFCLC

  # --------------------------
  # -- AMORTISSEMENT
  # --------------------------

  [F:DEPS]DPRCUMFLG  = G_OUI                                                  : # Cum E-1 forcé
  [F:DEPS]DPRCUM     = [F:DEPC]DPRCUM     + [F:DEPC]ENDDPE  + [F:DEPC]EXCDPR  : # Entretien Cum E-1
  [F:DEPS]EXECLOCUMT = [F:DEPC]EXECLOCUMT + [F:DEPC]ENDDPET + [F:DEPC]EXCDPRT : # Cum E-1 Théorique
  [F:DEPS]EXECLOCUMI = [F:DEPC]EXECLOCUMI + [F:DEPC]ENDDPEI + [F:DEPC]EXCDPRI : # Cum E-1 Initial

  [F:DEPS]PERCLOCUM  = 0                                                    : # 0-> Cum P-1
  [F:DEPS]PERCLOCUMT = 0                                                    : # 0-> Cum P-1 Théo.
  [F:DEPS]PERCLOCUMI = 0                                                    : # 0-> Cum P-1 Init.
  [F:DEPS]ENDDPE     = 0                                                    : # 0-> Dot Exe
  [F:DEPS]ENDDPET    = 0                                                    : # 0-> Dot Exe Théo.
  [F:DEPS]ENDDPEI    = 0                                                    : # 0-> Dot Exe Init.
  [F:DEPS]ENDDPEFLG  = G_NON                                                : # Dot Exe non forcée

  # --------------------------
  # -- AMORT. EXCEPTIONNEL
  # --------------------------

  [F:DEPS]PERCLOEXC  = 0                                                    : # 0-> Cum P-1 Amt. Except. Reel.
  [F:DEPS]PERCLOEXCT = 0                                                    : # 0-> Cum P-1 Amt. Except. Théo.
  [F:DEPS]PERCLOEXCI = 0                                                    : # 0-> Cum P-1 Amt. Except. Init.
  [F:DEPS]EXCCUM     = [F:DEPC]EXCCUM     + [F:DEPC]EXCDPR                  : # Cum E-1 Amt. Except.
  [F:DEPS]EXCCUMT    = [F:DEPC]EXCCUMT    + [F:DEPC]EXCDPRT                 : # Cum E-1 Amt. Except. Théo.
  [F:DEPS]EXCCUMI    = [F:DEPC]EXCCUMI    + [F:DEPC]EXCDPRI                 : # Cum E-1 Amt. Except. Init.
  [F:DEPS]EXCDPR     = 0                                                    : # 0-> Amt Exc.
  [F:DEPS]EXCDPRT    = 0                                                    : # 0-> Amt Exc. Théo.
  [F:DEPS]EXCDPRI    = 0                                                    : # 0-> Amt Exc. Init.

  # --------------------------
  # -- REINTEGRATION
  # --------------------------

  [F:DEPS]CRBCUM     = [F:DEPC]CRBCUM     + [F:DEPC]CRBAMT                  : # Entretien Cum E-1
  [F:DEPS]CRBCUMFLG  = G_OUI                                              : # Cum E-1 forcé
  [F:DEPS]CRBAMT     = 0                                                    : # 0-> Réint. Exe

  # --------------------------
  # -- AIDES FISCALES
  # --------------------------

  [F:DEPS]ALWCUM    = [F:DEPC]ALWCUM + [F:DEPC]ALWAMT   : # Entretien Cum E-1 Aides Fiscales
  [F:DEPS]ALWCUMFLG = G_OUI                             : # Cumul E-1 Aides Fiscales forcée
  [F:DEPS]ALWAMT    = 0                                 : # Aides Fiscales
  [F:DEPS]ALWAMTFLG = G_NON                             : # Aides fiscales non forcée

  # Déduction de l'exercice ( Règle particulière : Déduction 40% [15avr15 - 14avr16] ) FQ107988
  If ([F:DEPC]ALWCOD = GVML_RPDED40 and [F:WFAS]ISSDAT = [0/0/0] ) Then
    If ( func GLOBB9.CAL_DAT_INSIDE([F:DEPC]ENDDPRDAT, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, "I") ) Then
      If ( abs([M:DIV2]GLODED40) > abs([F:DEPC]ALWCUM + [F:DEPC]ALWAMT) ) Then
        [F:DEPS]ALWAMT = [M:DIV2]GLODED40 - ([F:DEPC]ALWCUM + [F:DEPC]ALWAMT)
      Endif
    Endif
  Endif

  # ----------------
  # -- UNITES D'OEUVRE
  # ----------------

    [F:DEPS]PERQTYCUM  = 0                              : # Réinit. UO Cum P-1
    [F:DEPS]FIYQTY     = 0                              : # Réinit. UO Exercice

  # ----------------
  # -- REEVALUATION
  # ----------------

  Local Decimal RVACRBIML : # Reprise de réévaluation suite à dépréciation
  RVACRBIML = func TRTFASIML.GET_RVARVE
&             ([F:DEPC]IML, [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV-[F:DEPC]RVACRB)

  # Entretien Cum E-1 Réserve de réévaluation
  # FQ52587 FQ94247
  # [F:DEPS]EXERVADEV = [F:DEPC]EXERVADEV + [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT  - [F:DEPC]RVACRB
  [F:DEPS]EXERVADEV = [F:DEPC]EXERVADEV + [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT
&                   - [F:DEPC]RVACRB    - RVACRBIML

  # Réinit. Cum P-1 Montant de réévaluation
  [F:DEPS]PERRVACUM = 0
  # Réinit. Cum P-1 Réserve de réévaluation
  [F:DEPS]PERRVADEV = 0
  # -- Prise d'effet de la réévaluation
  [F:DEPS]RVATIADAT = 0


  # ----------------
  # -- DEPRECIATION
  # ----------------
  # Entretien Cum E-1 Depr.
  [F:DEPS]EXEIMLCUM = [F:DEPC]EXEIMLCUM   + [F:DEPC]PERIMLCUM  + [F:DEPC]IML
  # Entretien Cum E-1 Reprise de Depr.
  [F:DEPS]EXERVECUM = [F:DEPC]EXERVECUM   + [F:DEPC]PERRVECUM  + [F:DEPC]IMLRVE
  # Entretien Cum E-1 Repr. Dépr. Transf.
  [F:DEPS]EXETRFCUM = [F:DEPC]EXETRFCUM   + [F:DEPC]PERTRFCUM  + [F:DEPC]IMLRVETRF
  # -- Réinit. Cumul P-1 Dépréciation
  [F:DEPS]PERIMLCUM = 0
  # -- Réinit. Cumul P-1 Reprise de Dépréciation
  [F:DEPS]PERRVECUM = 0
  # -- Réinit. Cumul P-1 Reprise de Dépréciation transféré en Amort Exc.
  [F:DEPS]PERTRFCUM = 0


  # ----------------
  # -- DIFFERE
  # ----------------
  # Solde différé d'amortissement fiscal

  If ( [M:DIV]DIFTYP = GVML_DFBENEF or [M:DIV]DIFRGL = GVML_RGREPDR  ) Then
    # En cas de différé en période bénéficiare ou de reprise du différé sur durée résiduelle,
    # le solde de différé est remis à 0
    [F:DEPS]DFDBLC    = 0
  Else
    # Cas général
    [F:DEPS]DFDBLC    = [F:DEPC]DFDBLC + [F:DEPC]DFD - [F:DEPC]DFDRVE
  Endif
  # Différé fiscal de l'exercice
  # [F:DEPC]DFD       = 0 : FQ103339
  [F:DEPS]DFD       = 0
  # Reprise de différé de l'exercice
  [F:DEPS]DFDRVE    = 0

  # Reinitialisation variable de travail
  Raz [M:DIV]PRVCUME_1R
  Raz [M:DIV]PRVCUME_1I
  Raz [M:DIV]PRVCUME_1T



  # ----------------
  # -- AUTRES
  # ----------------
  # FQ80825
  If ( find([F:DEPC]DPM, G_DPMCR, G_DPMLR,  G_DPMSR, G_DPMUR, G_DPMDR) <> 0) Then
    # RUSSIE FQ59941
    # Remise à zéro du Nombre de mois d'arrêt par défaut
    [F:DEPS]KFIYNBMSTP = 0
    If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
      # L'amortissement est suspendu
      If ( [F:WFAS]KPSEPLN <> "" and val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1)) = G_OUI) Then
        # Saisonnalité applicable au plan
        If ( [F:PSE]ACTFLG(month([F:DEPS]PERSTRDAT)-1) = G_OUI ) Then
          # La période est active
          [F:DEPS]KFIYNBMSTP = 1
        Endif
      Else
        # Pas de saisonnalité pour le plan
        [F:DEPS]KFIYNBMSTP = 1
      Endif
    Endif
  Endif

  # FQ80825
  If ( find([F:DEPC]DPM, G_DPMRL, G_DPMRX,  G_DPMRD) <> 0) Then
    # ROUMANIE
    # Remise à zéro du Nombre de mois d'arrêt par défaut
    [F:DEPS]KFIYNBMSTP = 0
    # Entretien du Nombre de mois d'arrêt par défaut - Modes roumains
    If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
      # L'amortissement est suspendu
      [F:DEPS]KFIYNBMSTP = 1
    Endif
  Endif

  If ([M:DIV]BACTKPL) Then
    # Remise à zéro de la date de mordernisation FQ67577
    # Modernisation sur E+1 FQ72372, FQ112798
    #If ( [F:DEPC]DPM <>  G_DPMMD or [F:DEPS]KMDRDAT <> [F:DEPS]FIYSTRDAT ) Then
    If ( [F:DEPC]KMDRDAT <> [0/0/0] and [F:DEPC]KMDRDAT < [F:DEPC]FIYENDDAT + 1 ) Then
      [F:DEPS]KMDRDAT = [0/0/0]
    Endif
  Endif

  # Prise en compte  Réévaluation Valeur marché Fin Exercice FQ79819
  If ( [F:DEPC]RVATIADAT = GVML_ERENDEX ) Then
    If ( [F:DEPC]RVATYP = GVML_MODVMA ) Then
      [F:DEPS]DPRBAS     = [F:DEPC]NBV
      [F:DEPS]DPRCUM     = 0
      [F:DEPS]EXECLOCUMT = 0
      [F:DEPS]NBV        = [F:DEPC]NBV
      [F:DEPS]NBVT       = [F:DEPC]NBVT
      [F:DEPS]EXETRFCUM  = 0
      [F:DEPS]EXEIMLCUM  = 0
      [F:DEPS]EXERVECUM  = 0
      [F:DEPS]IMLBLC     = 0

      # Passage en résiduel FQ84821 105809
      [F:DEPS]DPM       = [M:DPM]DPMRSD   ([M:DIV]INDMOD-1)
      If ( find([F:DEPC]DPM, G_DPMHL, G_DPMHD, G_DPMRE, G_DPMUL, G_DPMUD, G_DPMTD) = 0 ) Then
        [F:DEPS]PRATYP  = [M:DPM]PRODPMRSD([M:DIV]INDMOD-1)
      Else
        # Si mode HD, HL, RE, UL et UD
        [F:DEPS]PRATYP  = [F:DEPC]PRATYP
      Endif
      If ( [F:DEPS]DPM <> G_DPMML ) Then
        # Début de période suivante
        [F:DEPS]PERREFCLC = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]PERENDDAT, 1, "D" )
      Endif
    Else
      # Autres types de réévaluations FQ85936
      Local Decimal XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR
      Local Decimal XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT
      Local Decimal XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE
      Local Decimal XIMLBLC, XNBV, XRVAAMT

      Call  CAL_RVACOE_ENDFIY ( [F:DEPC]RVACOE, [M:DIV]CUR, [F:DEPC]NBV-[F:DEPC]RVAAMT,
&               [F:DEPC]DPRBAS, [F:DEPC]DPRCUM,     [F:DEPC]PERCLOCUM,  [F:DEPC]PERENDDPE,
&                               [F:DEPC]EXCCUM,     [F:DEPC]PERCLOEXC,  [F:DEPC]PEREXCDPR,
&                               [F:DEPC]EXECLOCUMT, [F:DEPC]PERCLOCUMT, [F:DEPC]DPET,
&                               [F:DEPC]EXCCUMT,    [F:DEPC]PERCLOEXCT, [F:DEPC]PEREXCDPRT,
&                               [F:DEPC]EXETRFCUM,  [F:DEPC]PERTRFCUM,  [F:DEPC]IMLRVETRF,
&                               [F:DEPC]EXEIMLCUM,  [F:DEPC]PERIMLCUM,  [F:DEPC]IML,
&                               [F:DEPC]EXERVECUM,  [F:DEPC]PERRVECUM,  [F:DEPC]IMLRVE,
&               [F:DEPS]DPRBAS, XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR,
&                               XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT,
&                               XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE,
&                               XIMLBLC, XNBV, XRVAAMT )

      If ([F:DEPC]RVAAMT <> XRVAAMT) Then
        [M:DIV]ERRID = 46 : Call ERRFND From =G_GLOB0  : # Dépilement suite à erreur logique
        Return
      Else
        [F:DEPS]DPRCUM     = XCUME_1R + XCUMP_1R + XDPER + XEXCP_1R + XEXCR
        [F:DEPS]EXCCUM     = XEXCE_1R + XEXCP_1R + XEXCR
        [F:DEPS]EXECLOCUMT = XCUME_1T + XCUMP_1T + XDPET + XEXCP_1T + XEXCT
        [F:DEPS]EXCCUMT    = XEXCE_1T + XEXCP_1T + XEXCT
        [F:DEPS]EXEIMLCUM  = XIMLE_1  + XIMLP_1 + XIML
        [F:DEPS]EXERVECUM  = XRVEE_1  + XRVEP_1 + XRVE
        [F:DEPS]EXETRFCUM  = XTRFE_1  + XTRFP_1 + XTRF
      Endif
    Endif
  Endif


  # FQ104280
  # En clôture exercice, il est nécessaire de remettre à zéro les zones de travail contenant les écarts
  # sinon elles restent initialisées sur les exercices futurs à tort uniquement pour le calcul où l'écart àa été déterminé
  [M:DIV]ECACUME_1R = 0
  [M:DIV]ECACUME_1T = 0
  [M:DIV]ECACUME_1I = 0


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return

#########################################################
$CAL_CLORE_PERIODE_AMT
#
# - Objet  : Exécute la clôture périodique d'un plan
#            pour les informations du plan d'amortissement
#
# - Entrée   : [F:DEPC]
#            Origine de la clôture ("CAL" Calcul / "CLO" Clôture)
#
#
# - Sortie   : [F:DEPS]
#



  # --------------------------
  # -- ECART SUR CUMUL E-1
  # --------------------------

  #  GVML_RREPAN   = 1         : # REPORT A NOUVEAU
  #  GVML_REXCEXE  = 2         : # Dotation EXCEPTIONNEL EXERCICE
  #  GVML_REXCPER  = 3         : # Dotation EXCEPTIONNEL PERIODE
  #  GVML_RDOTEXE  = 4         : # Dotation EXERCICE
  #  GVML_RDOTPER  = 5         : # Dotation PERIODE
  #  GVML_RDURRES  = 6         : # DUREE RESIDUELLE

#  If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1 and GUSER = "MWA" and
#&      [F:DEPC]PERENDDAT = [30/06/2000]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Si Prise d'effet du dernier changement de méthode est "Début de période"
  #    en cas de recalcul, il sera nécéssaire de connaître la période du changement de méthode
  # Si la Prise d'effet est "Début d'amortissement" et Ecart E-1 à rattraper lissé sur l'exercice
  #    en cas de recalcul, il sera nécéssaire de connaître l'écart contaté lors du changement de méthode
  If ( [F:DEPC]MTCTIATYP <> GVML_PEDBPE  and
&      [F:DEPC]MTCDEVADJ <> GVML_RDOTPER and [F:DEPC]MTCDEVADJ <> GVML_REXCPER and
&      [F:DEPC]MTCDEVADJ <> GVML_RDOTEXE and [F:DEPC]MTCDEVADJ <> GVML_REXCEXE ) Then
    # Dans les autres cas, les informations changement de méthode sont réinitialisées
    # -- Prise d'effet du changement de méthode
    [F:DEPS]MTCTIATYP = 0
    # -- Date d'effet du changement de méthode
    [F:DEPS]MTCTIADAT = [0/0/0]
  Endif

  # -- Selon type rattrapage de l'écart
  Case [F:DEPC]MTCDEVADJ
    When GVML_RREPAN
    # -- Dans la période
      [F:DEPS]MTCDEVADJ  = 0      : # Type gestion écart "Pas de changement de méthode"
      [F:DEPS]MTCDPEDEV  = 0      : # Ecart sur cumul E-1
      [F:DEPS]MTCDPEDEVI = 0      : # Ecart sur cumul E-1 Init
      [F:DEPS]MTCDPEDEVT = 0      : # Ecart sur cumul E-1 Théo
  Endcase

  # -- Date du changement de méthode
  [F:DEPS]MTCDPEDAT = [0/0/0]


  # ----------------
  # -- CUMUL P-1
  # ----------------

  # ---- Reel
  # Voir MTPlAM ci-dessous
  [F:DEPS]PERCLOCUM   = [F:DEPC]PERCLOCUM    +  [F:DEPC]PERENDDPE
  # ---- Théorique
  [F:DEPS]PERCLOCUMT  = [F:DEPC]PERCLOCUMT   +  [F:DEPC]DPET
  # ---- Initial
  [F:DEPS]PERCLOCUMI  = [F:DEPC]PERCLOCUMI   +  [F:DEPC]DPEI
  # ---- Amt. Except.
  [F:DEPS]PERCLOEXC   = [F:DEPC]PERCLOEXC    +  [F:DEPC]PEREXCDPR
  [F:DEPS]PERCLOEXCT  = [F:DEPC]PERCLOEXCT   +  [F:DEPC]PEREXCDPRT
  [F:DEPS]PERCLOEXCI  = [F:DEPC]PERCLOEXCI   +  [F:DEPC]PEREXCDPRI
  # -- Cumul P-1 Réserve de réévaluation
  # Voir réévaluation ci-dessous
  # -- Cumul P-1 Dépréciation
  # Voir dépréciation ci-dessous


  # ----------------
  # -- DOT. PERIODIQUE Remise à zéro
  # ----------------
  # ---- Reel
  [F:DEPS]PERENDDPE= 0
  [F:DEPS]PERDPEFLG= G_NON
  # ---- Théorique
  [F:DEPS]DPET = 0
  # ---- Initial
  [F:DEPS]DPEI = 0
  # ---- Exceptionnel
  [F:DEPS]PEREXCDPR  = 0
  [F:DEPS]PEREXCDPRT = 0
  [F:DEPS]PEREXCDPRI = 0


  # ----------------
  # -- UNITES D'OEUVRE
  # ----------------

  # -------------
  # FQ59941
  If ( [F:DEPC]DPM = G_DPMUO or  [F:DEPC]DPM = G_DPMUR ) Then
    [F:DEPS]PERQTYCUM  = [F:DEPC]PERQTYCUM + [F:DEPC]PERQTY : # UO Cum P-1    (+ UO Période)
    [F:DEPS]RSDQTY     = [F:DEPC]RSDQTY    - [F:DEPC]PERQTY : # UO Résiduelle (- UO Periode)
    [F:DEPS]PERQTY     = 0                              : # Réinit. UO Periode
  Endif
  # -------------

  # ----------------
  # -- REEVALUATION
  # ----------------

  Local Decimal RVACRBIML : # Reprise de réévaluation suite à dépréciation
  RVACRBIML = func TRTFASIML.GET_RVARVE
&             ([F:DEPC]IML, [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV-[F:DEPC]RVACRB)
  # -- Cumul P-1 Montant de réévaluation
  [F:DEPS]PERRVACUM = [F:DEPC]PERRVACUM + [F:DEPC]RVAAMT
  # -- Cumul P-1 Réserve de réévaluation
  [F:DEPS]PERRVADEV = [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT - [F:DEPC]RVACRB - RVACRBIML
  [F:DEPS]RVAAMT    = 0                  # : Réevaluation à 0
  [F:DEPS]RVACRB    = 0                  # : Repr. réev.  à 0
  [F:DEPS]RVADAT    = [0/0/0]            # : Date de Réevaluation
  [F:DEPS]RVATYP    = 0                  # : Type de Réevaluation
  [F:DEPS]RVACOE    = 0                  # : Coef de Réevaluation
  [F:DEPS]RVACOEREF = ""                 # : Référence Coef de Réevaluation

  # -- Prise d'effet de la réévaluation
  [F:DEPS]RVATIADAT = 0

  # ----------------
  # -- DEPRECIATION
  # ----------------

  # -- Solde depréciation
  # FQ74785 Ajout du OR avec la condition ([M:DIV]BSRA and [F:DEPC]PERSTRDAT = [M:FIY]DATSTRPER([M:DIV]FPC-1))
  If (([M:DIV]BSRA and [F:DEPC]PERSTRDAT = [M:FIY]DATSTRPER([M:DIV]FPC-1) ) or
&     ([F:WFAS]ISSDAT <> [0/0/0] and [F:DEPC]IMLBLC <> 0 and
&      [F:WFAS]ISSDAT >= [F:DEPC]PERSTRDAT and [F:WFAS]ISSDAT <= [F:DEPC]PERENDDAT ) ) Then
    [F:DEPS]IMLBLC = [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF
&                  - [F:WFAS]IMLRVEISS([F:DEPC]DPRPLN-1)
  Else
    [F:DEPS]IMLBLC = [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF
  Endif

  # -------------
  If ( [F:DEPC]IML <> 0 or [F:DEPC]IMLRVE <> 0  ) Then
    # Passage en résiduel FQ84281 FQ105809
    #
    # La clôture officielle prend en charge
    # la génération d'un évènement de changement de méthode
    # car à l'issue celle-ci ne pourra plus être annulée
    #
    [F:DEPS]DPM       = [M:DPM]DPMRSD   ([M:DIV]INDMOD-1)
    If ( find([F:DEPC]DPM, G_DPMHL, G_DPMHD, G_DPMRE, G_DPMUL, G_DPMUD, G_DPMTD, G_DPMTL) = 0 ) Then
      [F:DEPS]PRATYP  = [M:DPM]PRODPMRSD([M:DIV]INDMOD-1)
    Else
      # Si mode HL, HD, RE, UL et UD
      [F:DEPS]PRATYP  = [F:DEPC]PRATYP
    Endif

    # FQ75678
    If ( [F:DEPS]DPM <> G_DPMML ) Then
      # Début de période suivante
      [F:DEPS]PERREFCLC = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]PERENDDAT, 1, "D" )
    Endif

    # -- Cumul P-1 Dépréciation
    [F:DEPS]PERIMLCUM = [F:DEPC]PERIMLCUM + [F:DEPC]IML
    # -- Cumul P-1 Reprise de Dépréciation
    [F:DEPS]PERRVECUM = [F:DEPC]PERRVECUM + [F:DEPC]IMLRVE

  Endif

  # -- Cumul P-1 Reprise de Dépréciation transféré en Amort. Except.
  [F:DEPS]PERTRFCUM = [F:DEPC]PERTRFCUM + [F:DEPC]IMLRVETRF

  # -------------
  # -- Détermination du plafond de Reprise de Dépr.  FQ72008
##  If (  ( abs([F:DEPC]NBVT) > abs([F:DEPC]NBV) )  and
##&       ( [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF ) <> 0 ) Then
##    [F:DEPS]IMLRVELIM = [F:DEPC]NBVT - [F:DEPC]NBV
##  Else
##    [F:DEPS]IMLRVELIM = 0
##  Endif

  # FQ98322 Si repr. totale dépréciation, le réel hérite du mode théorique => pas de dérogatoire
  # En législation française, Reprise du solde de dépréciation - Neutralisation du dérogatoire
#  If ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPCRC and
#&      [F:DEPC]IMLRVE <> 0 and [F:DEPC]IMLBLC <> 0 and [F:DEPS]IMLBLC = 0 ) Then
#    If (([F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMT) or
#&       ([F:DEPS]PERCLOCUM+[F:DEPS]PERCLOEXC = [F:DEPS]PERCLOCUMT+[F:DEPS]PERCLOEXCT)) Then
#       [F:DEPS]DPM       = [F:DEPS]DPMT
#       [F:DEPS]PERREFCLC = [F:DEPS]PERREFCLCT
#    Endif
#  Endif

  [F:DEPS]IMLRVETRF = 0                                      : # Repr. à 0
  [F:DEPS]IML       = 0                                      : # Dépr. à 0
  [F:DEPS]IMLFLG    = G_NON                                  : # Dépr. non forcée
  [F:DEPS]IMLRVE    = 0                                      : # Repr. à 0
  [F:DEPS]IMLRVEFLG = G_NON                                  : # Repr. non forcée
  [F:DEPS]IMLTYP    = 0                                      : # Type de dépréciation à 0
  [F:DEPS]EXTIMLTYP = ""                                     : # Pas de motif externe
  [F:DEPS]INTIMLTYP = ""                                     : # Pas de motif interne


  # ----------------
  # A comptabiliser
  # ----------------
  [F:DEPS]DPEDEV    = 0
  [F:DEPS]EXCDEV    = 0
  [F:DEPS]DERDEV    = 0
  [F:DEPS]DERRVEDEV = 0
  [F:DEPS]RVETRFDEV = 0
  [F:DEPS]RVACRBDEV = 0

  # ----------------
  # -- AUTRES
  # ----------------

  # -- Indicateur de forçage Cumul d'amort. pratiqués dans les exercices précédents.
  # -- La clôture périodique force ce Cumul pour qu'il ne soit plus recalculé.
  [F:DEPS]DPRCUMFLG = G_OUI

  # -- Remise à non du flag sorite dans la période courante
  [F:DEPS]FLGUPDISS = G_NON

  # -- Remise à 0 de la durée résiduelle
  [F:DEPS]RSDDUR = 0
  # FQ80825
  If ( find([F:DEPC]DPM, G_DPMCR, G_DPMLR,  G_DPMSR, G_DPMUR, G_DPMDR) <> 0) Then
    # RUSSIE - FQ59941 FQ3289
    # Entretien du Nombre de mois d'arrêt par défaut  - Modes russes
    If (  [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
      # L'amortissement est suspendu
      If ( [F:WFAS]KPSEPLN <> "" and val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1)) = G_OUI) Then
        # Saisonnalité applicable au plan
        If ( [F:PSE]ACTFLG(month([F:DEPS]PERSTRDAT)-1) = G_OUI ) Then
          # La période est active
          [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
        Endif
      Else
        # Pas de saisonnalité pour le plan
        [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
      Endif
    Endif
  Endif

  # FQ80825
  If ( find([F:DEPC]DPM, G_DPMRL, G_DPMRX,  G_DPMRD) <> 0) Then
    # ROUMANIE
    # Entretien du Nombre de mois d'arrêt par défaut - Modes roumains
    If ( find([F:DEPC]KSTPDEPSTA, GVML_SSTOSTP,GVML_SSSTOPD) <> 0 ) Then
      # L'amortissement est suspendu
      [F:DEPS]KFIYNBMSTP = [F:DEPC]KFIYNBMSTP + 1
    Endif
  Endif

  If ([M:DIV]BACTKPL) Then
    # FQ67577 FQ72372
    If (find([F:DEPC]DPM , G_DPMML, G_DPMMD) <> 0 and [F:DEPC]KMDRDEV <> 0 and [M:DIV]BMDR) Then
      If ( [F:DEPC]KMDRDAT < [F:DEPC]PERSTRDAT and [F:DEPC]KMDRDEV <> 0) Then
          # Mode ML - Si la modernisation est rétroactive elle est effective sur la période courante
          # Remise à 0 du montant de modernisation
          [F:DEPS]KMDRDEV = 0
      Endif
      If ( [F:DEPC]KMDRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]KMDRDEV <> 0) Then
          # Mode ML - Si la modernisation est effective sur la période courante
          # Remise à 0 du montant de modernisation
          [F:DEPS]KMDRDEV = 0
      Endif
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
Return


#
#*********************************************************************
Subprog  CAL_PLAFOND_REPR_DEPRECIATION ( PVLNRFP, PVLNTFP, PSLDIML, RPLFRPRIML )
#
# - Objet  : Calcul de plafond de reprise de dépréciation
#
#            S'il existe un solde de dépréciation en début de période
#            et que la valeur nette "Théorique" fin de période est
#               > à la valeur nette "Reel" fin de période
#            Le plafond de reprise est égal à la différence entre
#               valeur nette "Théorique" fin de période et
#               valeur nette "Reel" fin de période
#            Dans le cas contraire, il est à 0.
#
# - Entrée : [M:DEP]
#
# - Sortie :
#
#   Boite noire gcfc04b
#

Value    Decimal PVLNRFP      : # Valeur nette "Reel"      fin de période
Value    Decimal PVLNTFP      : # Valeur nette "Théorique" fin de période
Value    Decimal PSLDIML      : # Solde de dépréciation    début de période
Variable Decimal RPLFRPRIML   : # Plafond de reprise de dépréciation


  # ---------------------------------------------
  # - Plafond de rerise de dépréciaion
  # ---------------------------------------------

    If (  ( abs(PVLNTFP) > abs(PVLNRFP) )  and PSLDIML <> 0 ) Then
      # FQ94548 RPLFRPRIML = abs(PVLNTFP) - abs(PVLNRFP)
      RPLFRPRIML = PVLNTFP - PVLNRFP
    Else
      RPLFRPRIML = 0
    Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#
#*********************************************************************
Subprog  CAL_REINT_VEH ( PCODREIVEH, PDOTEXE, PBASE, PCUMREI, PDTFNAMT, PDTDBEXE, PDTFNEXE,  RMNTREI )
#
# - Objet  : Calcul de la réintégration selon plafond véhicule
#            Lorsque le prix d'un type de véhicule dépasse un plafond,
#            le dépassement est réintégré en appliquant la formule suivante :
#            Dotation * ( Dépassement / Base )
#
# - Entrée :
#
# - Sortie :
#
#   Boite noire gcfcb2
#
#
#   FQ61773  Prise en compte des immobilisations négatives
#

Value    Char    PCODREIVEH   : # Code véhicule
Value    Decimal PDOTEXE      : # Dotation exercice
Value    Decimal PBASE        : # Base
Value    Decimal PCUMREI      : # Cumul du montant déjà réintégré
Value    Date    PDTFNAMT     : # Fin d'amortissement
Value    Date    PDTDBEXE     : # Début exercice
Value    Date    PDTFNEXE     : # Fin   exercice
Variable Decimal RMNTREI      : # Montant à réintégrer


Local Integer I_PLF



  RMNTREI = 0
  # ---------------------------------------------
  If ( PCODREIVEH <> "" and PDOTEXE <> 0 ) Then
    # Recherche du plafond selon code
    I_PLF = find (PCODREIVEH, [M:TAB]CODVEHPLF)
    # ---------------------------------------------
    If ( I_PLF <> 0 ) Then
      If ( PBASE <> 0 and abs(PBASE) > [M:TAB]VEHPLF(I_PLF-1))  Then
        #-- La base dépasse le plafond
        # Montant à réintégrer
        RMNTREI = abs(PDOTEXE) * ( ( abs(PBASE) - [M:TAB]VEHPLF(I_PLF-1) ) / abs(PBASE) )
      Endif
    Else
      Call ECR_FICH
&     ("FS2", 1, "Warning ! CRBVEHCOD incohérent  Bien ="-[F:DEPC]AASREC-"Valeur"-PCODREIVEH )
&     From =G_GLOB0
    Endif
    # ---------------------------------------------

    # FQ106650 Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (RMNTREI , [M:DIV]CUR , RMNTREI) From =G_GLOB8
    [M:DIV]PV(0)= RMNTREI : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RMNTREI = [M:DIV]RV(1)

    If ( RMNTREI <> 0 ) Then
      Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH Montant à réintégrer = Dotation Exe * ((Base - Plafond) / Base)"       ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH Dotation exercice    ="+ format$([M:DIV]CURFMT,PDOTEXE)                ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH Base                 ="+ format$([M:DIV]CURFMT,PBASE)                  ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH Plafond              ="+ format$([M:DIV]CURFMT,[M:TAB]VEHPLF(I_PLF-1)) ) From =G_GLOB0
    Endif

    #-- On ne peut pas réintégrer plus que le dépassement.
    If ( abs(PBASE) > [M:TAB]VEHPLF(I_PLF-1) and (abs(PCUMREI)+abs(RMNTREI)) > (abs(PBASE) - [M:TAB]VEHPLF(I_PLF-1)) ) Then
       # FQ106650 RMNTREI = abs(PBASE)-[M:TAB]VEHPLF(I_PLF-1)
       RMNTREI = abs(PBASE)-[M:TAB]VEHPLF(I_PLF-1) - PCUMREI
       Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH !!!! Réintégration > au plafond => Régularisation ="+ format$([M:DIV]CURFMT,RMNTREI) ) From =G_GLOB0
    Endif
    # En fin d'amortissement on solde le dépassement FQ106650
    If ( func GLOBB9.CAL_DAT_INSIDE(PDTFNAMT, PDTDBEXE, PDTFNEXE,"I") ) Then
       RMNTREI = abs(PBASE)-[M:TAB]VEHPLF(I_PLF-1) - PCUMREI
       Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH !!!! Fin d'amort. dans l'exer => Solde reste à réintégrer ="+ format$([M:DIV]CURFMT,RMNTREI) ) From =G_GLOB0
    Endif
    # Si la base devient inférieure au plafond : on extourne toute réintégration.
    If ( abs(PBASE) < [M:TAB]VEHPLF(I_PLF-1) ) Then
       Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH !!!! Base < Plafond => Extourne de ce qui a pu déjà être réintégré à tort ="+ format$([M:DIV]CURFMT,RMNTREI) ) From =G_GLOB0
       RMNTREI = abs(PCUMREI) * -1
    Endif

    #-- Bien négatif  (réintégration négative)
    If (PBASE < 0 and RMNTREI <> 0 ) Then : RMNTREI = RMNTREI * -1  : Endif

    If ( RMNTREI <> 0 ) Then
      Call ECR_FICH ("FS1", 6, "CAL_REINT_VEH Montant à réintégrer ="+ format$([M:DIV]CURFMT,RMNTREI) ) From =G_GLOB0
    Endif
  Endif
  # ---------------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#
#*********************************************************************
Subprog  CAL_RVACOE_ENDFIY ( PRVACOE, PCUR, PVALNET,
&                     PBASE, PCUME_1R, PCUMP_1R, PDPER, PEXCE_1R, PEXCP_1R, PEXCR,
&                            PCUME_1T, PCUMP_1T, PDPET, PEXCE_1T, PEXCP_1T, PEXCT,
&                            PTRFE_1 , PTRFP_1 , PTRF , PIMLE_1 , PIMLP_1 , PIML , PRVEE_1 , PRVEP_1 , PRVE,
&                     RBASE, RCUME_1R, RCUMP_1R, RDPER, REXCE_1R, REXCP_1R, REXCR,
&                            RCUME_1T, RCUMP_1T, RDPET, REXCE_1T, REXCP_1T, REXCT,
&                            RTRFE_1 , RTRFP_1 , RTRF , RIMLE_1 , RIMLP_1 , RIML , RRVEE_1 , RRVEP_1 , RRVE,
&                     RIMLBLC, RVALNET, RRVAAMT )
#
# - Objet  : Calcul les valeurs après réévaluation par coefficients "Fin exercice" telles qu'elles doivent
#            l'être sur la première période de l'exercice SUIVANT la réévaluation.
#
# - Rem.   : Les informations en entrée correspondent aux valeurs début Exercice non encore réévaluées
#
# - Entrée :
#
# - Sortie :
#
#   FQ85936  Création du sous programme
#


Value    Decimal PRVACOE      : # Coefficient de réévaluation
Value    Char    PCUR         : # Devise
Value    Decimal PVALNET      : # Valeur nette

Value    Decimal PBASE        : # Base
Value    Decimal PCUME_1R     : # Cumul Amt. E-1 Réel
Value    Decimal PCUMP_1R     : # Cumul Amt. P-1 Réel
Value    Decimal PDPER        : # Amt. Période Réel
Value    Decimal PEXCE_1R     : # Cumul Exc. E-1 Réel
Value    Decimal PEXCP_1R     : # Cumul Exc. P-1 Réel
Value    Decimal PEXCR        : # Exc. Période Réel
Value    Decimal PCUME_1T     : # Cumul Amt. E-1 Théorique
Value    Decimal PCUMP_1T     : # Cumul Amt. P-1 Théorique
Value    Decimal PDPET        : # Amt. Période Théorique
Value    Decimal PEXCE_1T     : # Cumul Exc. E-1 Théorique
Value    Decimal PEXCP_1T     : # Cumul Exc. P-1 Théorique
Value    Decimal PEXCT        : # Exc. Période Théorique
Value    Decimal PTRFE_1      : # Cumul E-1 Repr. Dépréc. transférée en Amort. Excpt.
Value    Decimal PTRFP_1      : # Cumul P-1 Repr. Dépréc. transférée en Amort. Excpt
Value    Decimal PTRF         : # Repr. Dépréc. transféré en Amort. Excpt Période
Value    Decimal PIMLE_1      : # Cumul Dépréciation E-1
Value    Decimal PIMLP_1      : # Cumul Dépréciation P-1
Value    Decimal PIML         : # Dépréciation Période
Value    Decimal PRVEE_1      : # Cumul Reprise Dépréciation E-1
Value    Decimal PRVEP_1      : # Cumul Reprise Dépréciation P-1
Value    Decimal PRVE         : # Reprise Dépréciation Période

Variable Decimal RBASE        : # Base
Variable Decimal RCUME_1R     : # Cumul Amt. E-1 Réel
Variable Decimal RCUMP_1R     : # Cumul Amt. P-1 Réel
Variable Decimal RDPER        : # Amt. Période Réel
Variable Decimal REXCE_1R     : # Cumul Exc. E-1 Réel
Variable Decimal REXCP_1R     : # Cumul Exc. P-1 Réel
Variable Decimal REXCR        : # Exc. Période Réel
Variable Decimal RCUME_1T     : # Cumul Amt. E-1 Théorique
Variable Decimal RCUMP_1T     : # Cumul Amt. P-1 Théorique
Variable Decimal RDPET        : # Amt. Période Théorique
Variable Decimal REXCE_1T     : # Cumul Exc. E-1 Théorique
Variable Decimal REXCP_1T     : # Cumul Exc. P-1 Théorique
Variable Decimal REXCT        : # Exc. Période Théorique
Variable Decimal RTRFE_1      : # Cumul E-1 Repr. Dépréc. transférée en Amort. Excpt.
Variable Decimal RTRFP_1      : # Cumul P-1 Repr. Dépréc. transférée en Amort. Excpt
Variable Decimal RTRF         : # Repr. Dépréc. transféré en Amort. Excpt Période
Variable Decimal RIMLE_1      : # Cumul Dépréciation E-1
Variable Decimal RIMLP_1      : # Cumul Dépréciation P-1
Variable Decimal RIML         : # Dépréciation Période
Variable Decimal RRVEE_1      : # Cumul Reprise Dépréciation E-1
Variable Decimal RRVEP_1      : # Cumul Reprise Dépréciation P-1
Variable Decimal RRVE         : # Reprise Dépréciation Période

Variable Decimal RIMLBLC      : # Solde de dépréciation
Variable Decimal RVALNET      : # Valeur nette
Variable Decimal RRVAAMT      : # Montant de la réévaluation

  # ---------------------------------------------
  # Initialisation paramètres de sortie
  RBASE     = PBASE
  RCUME_1R  = PCUME_1R
  RCUMP_1R  = PCUMP_1R
  RDPER     = PDPER
  REXCE_1R  = PEXCE_1R
  REXCP_1R  = PEXCP_1R
  REXCR     = PEXCR
  RCUME_1T  = PCUME_1T
  RCUMP_1T  = PCUMP_1T
  RDPET     = PDPET
  REXCE_1T  = PEXCE_1T
  REXCP_1T  = PEXCP_1T
  REXCT     = PEXCT
  RTRFE_1   = PTRFE_1
  RTRFP_1   = PTRFP_1
  RTRF      = PTRF
  RIMLE_1   = PIMLE_1
  RIMLP_1   = PIMLP_1
  RIML      = PIML
  RRVEE_1   = PRVEE_1
  RRVEP_1   = PRVEP_1
  RRVE      = PRVE

  # ---------------------------------------------
  If ( PRVACOE > 0 ) Then

    RBASE = PBASE * PRVACOE
    Call CAL_ARRONDI_MNT (RBASE , PCUR , RBASE) From =G_GLOB8

    RCUME_1R = PCUME_1R * PRVACOE
    Call CAL_ARRONDI_MNT (RCUME_1R , PCUR , RCUME_1R) From =G_GLOB8

    RCUMP_1R = PCUMP_1R * PRVACOE
    Call CAL_ARRONDI_MNT (RCUMP_1R , PCUR , RCUMP_1R) From =G_GLOB8

    RDPER = PDPER * PRVACOE
    Call CAL_ARRONDI_MNT (RDPER , PCUR , RDPER) From =G_GLOB8

    REXCE_1R = PEXCE_1R * PRVACOE
    Call CAL_ARRONDI_MNT (REXCE_1R , PCUR , REXCE_1R) From =G_GLOB8

    REXCP_1R = PEXCP_1R * PRVACOE
    Call CAL_ARRONDI_MNT (REXCP_1R , PCUR , REXCP_1R) From =G_GLOB8

    REXCR = PEXCR * PRVACOE
    Call CAL_ARRONDI_MNT (REXCR , PCUR , REXCR) From =G_GLOB8

    RCUME_1T = PCUME_1T * PRVACOE
    Call CAL_ARRONDI_MNT (RCUME_1T , PCUR , RCUME_1T) From =G_GLOB8

    RCUMP_1T = PCUMP_1T * PRVACOE
    Call CAL_ARRONDI_MNT (RCUMP_1T , PCUR , RCUMP_1T) From =G_GLOB8

    RDPET = PDPET * PRVACOE
    Call CAL_ARRONDI_MNT (RDPET , PCUR , RDPET) From =G_GLOB8

    REXCE_1T = PEXCE_1T * PRVACOE
    Call CAL_ARRONDI_MNT (REXCE_1T , PCUR , REXCE_1T) From =G_GLOB8

    REXCP_1T = PEXCP_1T * PRVACOE
    Call CAL_ARRONDI_MNT (REXCP_1T , PCUR , REXCP_1T) From =G_GLOB8

    REXCT = PEXCT * PRVACOE
    Call CAL_ARRONDI_MNT (REXCT , PCUR , REXCT) From =G_GLOB8

    RTRFE_1 = PTRFE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RTRFE_1 , PCUR , RTRFE_1) From =G_GLOB8

    RTRFP_1 = PTRFP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RTRFP_1 , PCUR , RTRFP_1) From =G_GLOB8

    RTRF = PTRF * PRVACOE
    Call CAL_ARRONDI_MNT (RTRF , PCUR , RTRF) From =G_GLOB8

    RIMLE_1 = PIMLE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RIMLE_1 , PCUR , RIMLE_1) From =G_GLOB8

    RIMLP_1 = PIMLP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RIMLP_1 , PCUR , RIMLP_1) From =G_GLOB8

    RIML = PIML * PRVACOE
    Call CAL_ARRONDI_MNT (RIML , PCUR , RIML) From =G_GLOB8

    RRVEE_1 = PRVEE_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RRVEE_1 , PCUR , RRVEE_1) From =G_GLOB8

    RRVEP_1 = PRVEP_1 * PRVACOE
    Call CAL_ARRONDI_MNT (RRVEP_1 , PCUR , RRVEP_1) From =G_GLOB8

    RRVE = PRVE * PRVACOE
    Call CAL_ARRONDI_MNT (RRVE , PCUR , RRVE) From =G_GLOB8

    # ---
    RIMLBLC      =  ( RIMLE_1 + RIMLP_1 + RIML ) - ( RRVEE_1 + RRVEP_1 + RRVE ) - ( RTRFE_1 + RRVEP_1 + RRVE )
    # ---
    RVALNET = RBASE - (RCUME_1R + RCUMP_1R + RDPER) - (REXCP_1R + REXCR) - RIMLBLC
    # ---
    RRVAAMT = RVALNET - PVALNET

  Endif
  # ---------------------------------------------

End

#
#*********************************************************************
Subprog  CAL_SORTIE_TVA
#
# - Objet  : Calcul du montant de TVA due sur sortie
#                   du montant de TVA à régulariser (Déduction ou Reversement)
#
#
# - Entrée :
#            Flag TVA sur sortie
#            Taux de TVA sur sortie (unique)
#            Date de sortie
#            Date de référence TVA
#            Règle de TVA sur vente
#            Montant de sortie en devise société
#            Durée période de régularisation
#            TVA facturée  (PCG ou IAS)
#            TVA récupérée (PCG ou IAS)
#            Cumul regularisation TVA
#            Regularisation TVA

#            Cumul de régularisation de TVA suite à variation dans le temps (PCG ou IAS)
#            Régularisation de TVA (PCG ou IAS)
#
# - Sortie :
#            TVA due sur vente (unique exprimée dans la devise société à partir de Taux de TVA sur sortie)
#            Déduction complémentaire ( PCG ou IAS )
#            Reversement de TVA (PCG ou IAS )
#
#
#   Boite noire gcfc91
#


Local Decimal WTVANR
Local Decimal WDURDET
Local Decimal WDURRES

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Montant de TVA sur sortie
  If ( [F:WFAS]ISSVATFLG <> G_OUI ) Then
    # S'il n'est pas forcé le Montant de TVA sur sortie est calculé
    # en appliquant le Taux de TVA sur sortie au montant de sortie
    [F:WFAS]ISSVATAMT = [F:WFAS]ISSAMT(0) * ([F:WFAS]ISSVATRAT / 100.)
  Endif

  If ( [F:WFAS]ISSVATAMT <> 0 ) Then
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_TVA Montant sortie    ="+ format$([M:DIV]CURFMT, [F:WFAS]ISSAMT(0)) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_TVA Tx TVA  sortie    ="+ format$([M:DIV]CURFMT, [F:WFAS]ISSVATRAT) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_TVA Mt TVA /sortie    ="+ format$([M:DIV]CURFMT, [F:WFAS]ISSVATAMT) ) From =G_GLOB0
  Endif


  [F:WFAS]ACGREVVAT = 0
  [F:WFAS]IASREVVAT = 0
  [F:WFAS]ACGCPLDED = 0
  [F:WFAS]IASCPLDED = 0
  [F:WFAS]ISSVATTRF  = 0
  [F:WFAS]ISSVATTRFI = 0

  # Selon règle de TVA sur vente
  #-----------------------------------
  Case [F:WFAS]PYBVATTYP

    When GVML_SNSREGU
      # ---- Sans régularisation

    When GVML_RVTVA
      #-------------------------------
      # ---- Reversement de TVA
      #-------------------------------
      # Durée de détention en année
      WDURDET = (year([F:WFAS]ISSDAT) - year([F:WFAS]VATREGDAT))+1

      # Durée résiduel de régularisation
      WDURRES = [F:WFAS]THESLI - WDURDET

      #
      # Si la sortie a lieu avant la fin de la période de régularisation (WDURRES > 0)
      #
      # -- PCG --

      # TVA transférable
      [F:WFAS]ISSVATTRF = [F:WFAS]IVCVATAMT * (WDURRES / [F:WFAS]THESLI)
      # Arrondi dans la devise du contexte
      #Call CAL_ARRONDI_MNT ([F:WFAS]ISSVATTRF, [M:DIV]CUR , [F:WFAS]ISSVATTRF) From =G_GLOB8
      [M:DIV]PV(0)= [F:WFAS]ISSVATTRF : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]ISSVATTRF = [M:DIV]RV(1)

      If ( WDURRES > 0 and [F:WFAS]DEDVATAMT <> 0 ) Then
        # Si la TVA facturée a été récupérée totalement ou partiellement et que la bien a été détenu au moins 1 année
        # TVA à reverser  = ((0 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
        [F:WFAS]ACGREVVAT = ((0 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMT ) * (WDURRES / [F:WFAS]THESLI)
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([F:WFAS]ACGREVVAT, [M:DIV]CUR , [F:WFAS]ACGREVVAT) From =G_GLOB8
        [M:DIV]PV(0)= [F:WFAS]ACGREVVAT : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]ACGREVVAT = -[M:DIV]RV(1)
      Endif

      If ([M:DIV]PLNIAS) Then
        # TVA transférable
        [F:WFAS]ISSVATTRFI = [F:WFAS]IVCVATAMTI * (WDURRES / [F:WFAS]THESLI)
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([F:WFAS]ISSVATTRFI, [F:WFAS]IASCUR , [F:WFAS]ISSVATTRFI) From =G_GLOB8
        [M:DIV]PV(0)= [F:WFAS]ISSVATTRFI : [M:DIV]PC(0)= [F:WFAS]IASCUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]ISSVATTRFI = [M:DIV]RV(1)

        # -- IAS --
        If ( WDURRES > 0 and [F:WFAS]DEDVATAMTI <> 0 ) Then
        # Si la TVA facturée a été récupérée totalement ou partiellement et que la bien a été détenu au moins 1 année
          # TVA à reverser  = ((0 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
          [F:WFAS]IASREVVAT = ((0 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMTI ) * (WDURRES / [F:WFAS]THESLI)
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT ([F:WFAS]IASREVVAT, [F:WFAS]IASCUR , [F:WFAS]IASREVVAT) From =G_GLOB8
          [M:DIV]PV(0)= [F:WFAS]IASREVVAT : [M:DIV]PC(0)= [F:WFAS]IASCUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]IASREVVAT = -[M:DIV]RV(1)
        Endif
      Endif


    When GVML_DEDCOMP
      #-------------------------------
      # ---- Déduction complémentaire
      #-------------------------------
      # Durée de détention en année
      WDURDET = year([F:WFAS]ISSDAT) - year([F:WFAS]VATREGDAT)+1
      # Durée résiduel de régularisation
      WDURRES = [F:WFAS]THESLI - WDURDET
      # -- PCG --
      If ( WDURRES > 0  and ([F:WFAS]IVCVATAMT - [F:WFAS]DEDVATAMT ) <> 0  ) Then
        # Si la TVA facturée a été partiellement récupérée et que la bien a été détenu au moins 1 année
        # Déduction compléméntaire  = ((1 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
        [F:WFAS]ACGCPLDED = ((1 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMT ) * (WDURRES / [F:WFAS]THESLI)
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([F:WFAS]ACGCPLDED, [M:DIV]CUR , [F:WFAS]ACGCPLDED) From =G_GLOB8
        [M:DIV]PV(0)= [F:WFAS]ACGCPLDED : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]ACGCPLDED = [M:DIV]RV(1)
      Endif

      # -- IAS --
      If ([M:DIV]PLNIAS) Then
      # Si le bien a été soumis à TVA
        If ( WDURRES > 0  and ([F:WFAS]IVCVATAMTI - [F:WFAS]DEDVATAMTI ) <> 0 ) Then
          # Si la TVA facturée a été partiellement récupérée et que la bien a été détenu au moins 1 année
          # Déduction compléméntaire  = ((1 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
          [F:WFAS]IASCPLDED = ((1 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMTI ) * (WDURRES / [F:WFAS]THESLI)
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT ([F:WFAS]IASCPLDED, [F:WFAS]IASCUR , [F:WFAS]IASCPLDED) From =G_GLOB8
          [M:DIV]PV(0)= [F:WFAS]IASCPLDED : [M:DIV]PC(0)= [F:WFAS]IASCUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]IASCPLDED = [M:DIV]RV(1)
        Endif
      Endif


    When Default
      # ---- Sans régularisation

  Endcase
  #-----------------------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([F:WFAS]ISSVATAMT, [M:DIV]CUR , [F:WFAS]ISSVATAMT) From =G_GLOB8
  [M:DIV]PV(0)= [F:WFAS]ISSVATAMT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]ISSVATAMT = [M:DIV]RV(1)

  If ( [F:WFAS]ACGCPLDED<> 0 ) Then
    Call ECR_FICH ("FS1", 6,
&   "CAL_SORTIE_TVA Déduc compl. PCG   ="+ format$([M:DIV]CURFMT, [F:WFAS]ACGCPLDED) ) From =G_GLOB0
  Endif
  If ( [F:WFAS]IASCPLDED <> 0 ) Then
    Call ECR_FICH ("FS1", 6,
&   "CAL_SORTIE_TVA Déduc compl. IAS   ="+ format$([M:DIV]CURFMT, [F:WFAS]IASCPLDED) ) From =G_GLOB0
  Endif
   If ( [F:WFAS]ACGREVVAT <> 0 ) Then
    Call ECR_FICH ("FS1", 6,
&   "CAL_SORTIE_TVA Revers. TVA  PCG   ="+ format$([M:DIV]CURFMT, [F:WFAS]ACGREVVAT) ) From =G_GLOB0
  Endif
   If ( [F:WFAS]IASREVVAT <> 0 ) Then
    Call ECR_FICH ("FS1", 6,
&   "CAL_SORTIE_TVA Revers. TVA  IAS   ="+ format$([M:DIV]CURFMT, [F:WFAS]IASREVVAT) ) From =G_GLOB0
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#
#*********************************************************************
Subprog  CAL_SORTIE_PMV
#
# - Objet  : Calcul de la plus ou moins value suite à la sortie du bien
#
#   Rem.   : Pas de +/- value pour un plan subvention.
#            Il contient non pas une valeur d'actif mais une part de subvention.
#
#
# - Entrée :
#             Montant de sortie
#             Valeur nette
#             Date de sortie (fichier)
#             Montant déduction complémentaire de TVA (IAS ou PCG)
#             Montant Reversement de TVA (IAS ou PCG)
#             Base d'amortissement non réévaluée
#
# - Sortie :
#             +/- value
#
#   Boite noire gcfc92 gcfc93 gcfc94
#


Local Decimal WVALNET
Local Decimal WPMV

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # -- Par défaut
  [F:WFAS]GAL   ([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = 0

  #- 1 ---------------------------------
  If ( [F:DEPC]DPRPLN <>  G301SUB ) Then
    # Pas de +/- value pour le plan "Subvention"
    #- 2 ---------------------------------
    If ( [M:DIV]LEGSOC = "FRA" and  [F:DEPC]DPRPLN =  G301FIS and
&        [F:WFAS]PURDAT < [01/01/1977] and [F:DEPC]DPRBAS > [F:WFAS]GALREFBAS  ) Then
      # Réév. 76 : +/- value fisc. = Pr. de vente - Val. non réév. (stockée dans Base de référence +/- value)
      # ----------------
      If ( [F:WFAS]R76COE <> 0 ) Then
        WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - ( [F:DEPC]NBV / [F:WFAS]R76COE )
      Else
        WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - [F:DEPC]NBV
      Endif
    Else
    #- 2 ---------------------------------
      # Cas standard
      # ----------------
      If ( [M:DIV]FLGTVAPMV = G_OUI ) Then
        # Si le paramètre "Prise en compte de la TVA pour le calcul de la +/- value" est à Oui
        # Ajustement de la valeur nette avant calcul de la +/- value
        # des plans comptable, fiscal, minimum, origine, ias/ifrs
        If ( [F:DEPC]DPRPLN =  G301CPT or [F:DEPC]DPRPLN =  G301FIS or [F:DEPC]DPRPLN = G301MIN or
&            [F:DEPC]DPRPLN =  G301ORI or [F:DEPC]DPRPLN =  G301IAS ) Then
          # Minorée de la déduction complémentaire (IAS ou PCG)
          # Majorée du reversement de TVA (IAS ou PCG)
          If ( [F:DEPC]DPRPLN =  G301IAS ) Then
            WVALNET =  [F:DEPC]NBV - [F:WFAS]IASCPLDED + [F:WFAS]IASREVVAT
          Else
            WVALNET =  [F:DEPC]NBV - [F:WFAS]ACGCPLDED + [F:WFAS]ACGREVVAT
          Endif
        Else
            WVALNET =  [F:DEPC]NBV
        Endif
      Else
        WVALNET =  [F:DEPC]NBV
      Endif
      # Détermination du montant de la +/- value
      WPMV = [F:WFAS]ISSAMT([F:DEPC]DPRPLN-1) - WVALNET
    Endif
    #- 2 ---------------------------------
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WPMV , [M:DIV]CUR , [F:WFAS]GAL([F:DEPC]DPRPLN-1) ) From =G_GLOB8
    [M:DIV]PV(0)= WPMV : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:WFAS]GAL([F:DEPC]DPRPLN-1) = [M:DIV]RV(1)
  Endif
  #- 1 ---------------------------------


  If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) <> 0 ) Then
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_PMV V. Nette sortie    ="+ format$([M:DIV]CURFMT, [F:DEPC]NBV) )
&   From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_PMV V. Nette +/- value ="+ format$([M:DIV]CURFMT, WVALNET) )
&   From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_PMV Montant +/- value  ="+ format$([M:DIV]CURFMT, [F:WFAS]GAL([F:DEPC]DPRPLN-1)) )
&   From =G_GLOB0
  Endif

  If ( [M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN =  G301FIS and
&      find ([F:WFAS]ISSTYP, GVML_TSVENTE, GVML_TSREBUT, GVML_TSCIG, GVML_TSVOLDI) ) Then
    # La +/- value fiscale d'une société française doit être répartie en Court Terme et Long Terme
    [M:DIV]LVLLIB = "0.CAL_SORTIE_LT_CT" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_SORTIE_LT_CT  From =G_GLOB6
  Endif


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#
#*********************************************************************
Subprog  CAL_SORTIE_LT_CT
#
# - Objet  : Pour une société française et uniquement pour le plan fiscal
#            Calcul de la répartition de la +/- value en long terme et court terme
#
#   Rem.   : Pas de +/- value pour un plan de subvention qui contient une part de subvention
#
# - Entrée :
#             Montant +/- value fiscale
#             Mode d'amortissement
#             Date de référence pour le calcul de la +/- value
#             Date de sortie
#             Cumul Amortissement E_1
#             Dotation Exercice
#             Amortissement exceptionnel Exercice
#
# - Sortie :
#             +/- value long terme
#             +/- value court terme
#


Local Decimal WCUMAMTPRA
Local Date    W2ANS

  # -- Par défaut
  [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = 0

  #- Impôts sur les sociétés
  If ([M:DIV2]TAXRUL = GVML_TRCMPNY) Then
    # FQ100336
    [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)

  #- Impôts sur les revenus
  Else
    # -- Date de reference pour calcul +/- value + 2 ans
    W2ANS = func GLOBB9.CAL_DAT_PLUS( [F:WFAS]GALREFDAT, 2, "Y" )
    # ----------------
    # Sans amortissement
    If ( [F:DEPC]DPM = G_DPMSA ) Then
      If ( [F:WFAS]ISSDAT < W2ANS ) Then
        # -- détention < 2 ans
        [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Else
        # -- détention >= 2 ans
        [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Endif
    Else
    # ----------------
    # Autres mode d'amortissement
      If ( [F:WFAS]ISSDAT < W2ANS ) Then
        # -- détention < 2 ans
        [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
      Else
        # -- détention >= 2 ans
        If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) > 0 ) Then
          # -- Plus value
          WCUMAMTPRA = [F:DEPC]DPRCUM + [F:DEPC]ENDDPE + [F:DEPC]EXCDPR
          If ( [F:WFAS]GAL([F:DEPC]DPRPLN-1) > WCUMAMTPRA ) Then
            [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = WCUMAMTPRA
            [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)- WCUMAMTPRA
          Else
            [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
          Endif
        Else
          # -- Moins value FQ100336
          [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) = [F:WFAS]GAL([F:DEPC]DPRPLN-1)
        Endif
      Endif
    Endif
  Endif

  If ( [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) <> 0 or [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1) <> 0 ) Then
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_LT_CT +/- Value fiscale CT ="+ format$([M:DIV]CURFMT,
&    [F:WFAS]SHOGAL([F:DEPC]DPRPLN-1) ) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_SORTIE_LT_CT +/- value fiscale LT ="+ format$([M:DIV]CURFMT,
&    [F:WFAS]LNGGAL([F:DEPC]DPRPLN-1)) ) From =G_GLOB0
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End



#
#*********************************************************************
$CAL_LNK_FISC_MINI
#
# - Objet  : Traitement lié à la relation entre plan fiscal et minimum
#            pouvant affectée la dotation exercice fiscale
#
# - Entrée :
#
# - Sortie :
#            [M:DIV]DIF         # Différé
#            [F:DEPC]DFDLIM     # Amortissement Différable
#            [F:DEPC]DFD        # Différé
#            [F:DEPC]DFDRVE     # Reprise de différé
#            [F:DEPC]ENDDPE     # Dotation exercice fiscal
#
#

   Local Decimal LECAFISMIN

#  If ( [M:DIV]BDEBUG and [F:DEPC]PERENDDAT = [31/03/2007] and
#&      not ([M:DIV]BCUME_1) ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-- 1 ---------------------------------------
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN  ) Then
    #====================
    # Amortissement minimum
    #====================
    If ( abs([F:DEPC]DPRCUM) >
&        abs([M:PMIN]DPRCUM([M:DIV]DL-1)+[M:PMIN]ENDDPE([M:DIV]DL-1)+[M:PMIN]EXCDPR([M:DIV]DL-1)) ) Then
      WDOTMIN = 0
    Else
      # Ne concerne que le plan fiscal couplée à un plan d'amortissement minimum fiscal
      #-- Amortissement minimum = Cum Minimum Fin Exe. - Cum Fiscal Deb Exe.
      Local Decimal WDOTMIN
      WDOTMIN = ( [M:PMIN]DPRCUM([M:DIV]DL-1) + [M:PMIN]ENDDPE([M:DIV]DL-1) + [M:PMIN]EXCDPR([M:DIV]DL-1) )
&             -   [F:DEPC]DPRCUM
      Call ECR_FICH ("FS1", 6,
&     "CAL_LNK_FISC_MINI Amort. minimum     = Cum Minimum Fin Exe. - Cum Fiscal Deb Exe." ) From  =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&     "CAL_LNK_FISC_MINI Amort. minimum     ="+ format$([M:DIV]CURFMT, [M:PMIN]DPRCUM([M:DIV]DL-1) + [M:PMIN]ENDDPE([M:DIV]DL-1) + [M:PMIN]EXCDPR([M:DIV]DL-1) )
&                                             + "-" + format$([M:DIV]CURFMT, [F:DEPC]DPRCUM )
&                                             + "=" + format$([M:DIV]CURFMT, WDOTMIN ) ) From  =G_GLOB0
      Endif
  Endif
  #-- 1 ---------------------------------------

  #-- 1 ---------------------------------------
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    If ( [F:DEPC]ALWCOD = GVML_RPALOGI ) Then
        # Pas d'application de la règle du minimum pour les logiciels (JRI-14/01/2008)
    Else
      #====================
      # Règle du minimum
      #====================
      # Ne concerne que le plan fiscal couplée à un plan d'amortissement minimum fiscal
      # La règle ne doit pas être appliquée lors d'une reconstitution de cumul (appliquée ailleurs)
      If ( abs(WDOTMIN) > abs([F:DEPC]ENDDPE+[F:DEPC]EXCDPR ) and [F:DEPC]IMLBLC = 0 ) Then
        # Si l'amortissement fiscal est inférieur à l'amortissement minimum fiscal
        # et que le plan fiscal n'a jamais été déprécié, la dotation exercice est majorée de l'écart
        # entre Amortissement minimum et Amortissement fiscal
        Call ECR_FICH ("FS1", 6,
&       "CAL_LNK_FISC_MINI Fisc. avant règle  ="+ format$([M:DIV]CURFMT, [F:DEPC]ENDDPE ) ) From =G_GLOB0
        Call ECR_FICH ("FS1", 6,
&       "CAL_LNK_FISC_MINI A repartir av. rgl.="+ format$([M:DIV]CURFMT, [M:DIV]DOTEXE  ) ) From =G_GLOB0
        # Ecart de la dotation fiscale par rapport à l'amortissement minimum fiscal
        LECAFISMIN = ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
        # FQ118852
        #If (  [F:WFAS]ISSDATRUL = GVML_IRVLNAE and [F:DEPC]DPM = G_DPMSA ) Then : # FQ120877
        # L'actualisation de l'amortissement exceptionnel est peut-être toujours à faire si l'on est en mise au rebut avec amortissement exceptionnel.
        # A étudier si d'autres cas se présentent.
        If (  [F:WFAS]ISSDATRUL = GVML_IRVLNAE and ([F:DEPC]DPM = G_DPMSA or [M:DIV]DIFRGL = GVML_RGNODER)  ) Then
            [F:DEPC]EXCDPR += [M:PMIN]EXCDPR([M:DIV]DL-1)
            [M:DIV]AMTEXC   = [F:DEPC]EXCDPR
        Endif
        # Dotation résiduelle
        [M:DIV]DOTEXE    = [M:DIV]DOTEXE  + ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
        # Dotation entière
        [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE + ( WDOTMIN - ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) )
        Call ECR_FICH ("FS1", 6,
&       "CAL_LNK_FISC_MINI Ecart Fsc./Min.Fsc ="+ format$([M:DIV]CURFMT, LECAFISMIN     ) ) From =G_GLOB0
        Call ECR_FICH ("FS1", 6,
&       "CAL_LNK_FISC_MINI Fisc. après règle  ="+ format$([M:DIV]CURFMT, [F:DEPC]ENDDPE ) ) From =G_GLOB0
        Call ECR_FICH ("FS1", 6,
&       "CAL_LNK_FISC_MINI A repartir ap. rgl.="+ format$([M:DIV]CURFMT, [M:DIV]DOTEXE  ) ) From =G_GLOB0
      Endif
    Endif
  Endif
  #-- 1 ---------------------------------------

  #-- 1 ---------------------------------------
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    #=========================================
    # Amortissement différable
    #=========================================
    # Ne concerne que le plan fiscal couplée à un plan d'amortissement minimum fiscal
    # L'amortissement différable n'a pas à être calculé lors d'une reconstitution de cumul
    # Amortissement différable ([F:DEPC]DFDLIM)  = Dot. fisc. - Amortissement minimum (à concurrence de 0)
    If ( abs([F:DEPC]ENDDPE+[F:DEPC]EXCDPR) > abs(WDOTMIN) ) Then
      [F:DEPC]DFDLIM = ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR ) - WDOTMIN
      Call ECR_FICH("FS1", 5,
&     "CAL_LNK_FISC_MINI - Amort. différable        ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDLIM)) From =G_GLOB0
    Else
      [F:DEPC]DFDLIM = 0.
    Endif
  Else
    [F:DEPC]DFDLIM = 0.
  Endif
  #-- 1 ---------------------------------------

  #-- 1 ---------------------------------------
  If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN and  !([M:DIV]BCUME_1)  ) Then
    #=========================================
    # Amortissement différé
    #=========================================
    # Ne concerne que le plan fiscal couplée à un plan d'amortissement minimum fiscal
    # L'amortissement différable n'a pas à être calculé lors d'une reconstitution de cumul
    #-- Amortissement différé ([F:DEPC]DFD, [F:DEPC]DFDRVE)
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.

    #- 2 -------------------------------
    If ( [F:DEPC]FIYSTRDAT = [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then
      # Le différé ou la reprise de différé n'est constaté que sur  l'Exe. Cour.
      # Pas de stockage
      Case [M:DIV]DIFTYP
        When GVML_DFAUCUN
        # -- Aucun
        When GVML_DFBENEF
        # -- Différé bénéficiaire
          If ( [F:DEPC]DFDLIM <> 0 ) Then
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
              # -- Pourcentage
                [F:DEPC]DFD = [F:DEPC]DFDLIM * ( [M:DIV]DIFRAT / 100.)
                #Call CAL_ARRONDI_MNT ([F:DEPC]DFD, [M:DIV]CUR , [F:DEPC]DFD) From =G_GLOB8
                [M:DIV]PV(0)= [F:DEPC]DFD : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:DEPC]DFD = [M:DIV]RV(1)
              When GVML_RGNODER
              # -- Pas de dérogatoire (Différé d'amt de telle sorte que dot.fisc soit ramenée à dot.cpt)
                If ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR >
&                    [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) ) Then
                  [F:DEPC]DFD = ( [F:DEPC]ENDDPE              + [F:DEPC]EXCDPR              )
&                            - ( [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) )
                Endif
                # Dans la limite du différable
                If ( abs([F:DEPC]DFD) > abs([F:DEPC]DFDLIM) ) Then : [F:DEPC]DFD = [F:DEPC]DFDLIM : Endif
              When Default
            Endcase
          Endif
        When GVML_DFDEFIC
        # -- Différé déficitaire
          If ( [F:DEPC]DFDLIM <> 0 ) Then
            # Stockage différé
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
              # -- Pourcentage
                [F:DEPC]DFD = [F:DEPC]DFDLIM * ( [M:DIV]DIFRAT / 100. )
                #Call CAL_ARRONDI_MNT ([F:DEPC]DFD, [M:DIV]CUR , [F:DEPC]DFD) From =G_GLOB8
                [M:DIV]PV(0)= [F:DEPC]DFD : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:DEPC]DFD = [M:DIV]RV(1)
              When GVML_RGNODER
              # -- Pas de dérogatoire (Différé d'amt de telle sorte que dot.fisc soit ramenée à dot.cpt)
                If ( [F:DEPC]ENDDPE + [F:DEPC]EXCDPR >
&                    [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) ) Then
                  [F:DEPC]DFD = ( [F:DEPC]ENDDPE              + [F:DEPC]EXCDPR              )
&                             - ( [M:PCPT]ENDDPE([M:DIV]DL-1) + [M:PCPT]EXCDPR([M:DIV]DL-1) )
                Endif
                # Dans la limite du différable
                If ( abs([F:DEPC]DFD) > abs([F:DEPC]DFDLIM) ) Then : [F:DEPC]DFD = [F:DEPC]DFDLIM : Endif
              When Default
            Endcase
          Endif
        When GVML_DFREPR
        # -- Reprise de différé
          # Stockage reprise de différé
          If ( [F:DEPC]DFDBLC <> 0 ) Then
            Case [M:DIV]DIFRGL
              When GVML_RGPOURC
              # -- Pourcentage
                [F:DEPC]DFDRVE = [F:DEPC]DFDBLC * ( [M:DIV]DIFRAT / 100. )
                #Call CAL_ARRONDI_MNT ([F:DEPC]DFDRVE, [M:DIV]CUR , [F:DEPC]DFDRVE) From =G_GLOB8
                [M:DIV]PV(0)= [F:DEPC]DFDRVE : [M:DIV]PC(0)= [M:DIV]CUR
                Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:DEPC]DFDRVE = [M:DIV]RV(1)
              When GVML_RGREPDR
              # -- Reprise sur durée résiduelle (Mode DF)
              When Default
            Endcase
          Endif
        When Default
      Endcase
    Endif
    #- 2 -------------------------------

    If ( [F:DEPC]DFD <> 0 or [F:DEPC]DFDRVE <> 0 ) Then
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Différable         ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDLIM ) ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Type           :"- mess([M:DIV]DIFTYP, GML_TYPDFD, 1)     ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Règle          :"- mess([M:DIV]DIFRGL, GML_RGLDFD, 1)     ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Pourcentage    :"- num$([M:DIV]DIFRAT)                    ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Différé            ="+ format$([M:DIV]CURFMT, [F:DEPC]DFD    ) ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_LNK_FISC_MINI Reprise différé    ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
    Endif
  #-- 1 ---------------------------------------
  Else
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
  Endif
  #-- 1 ---------------------------------------



  #-- Amortissement différé Reprise du solde différé en fin d'amortissement

  #-- 1 ---------------------------------------
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and [F:DEPC]DFDBLC <> 0 ) Then

    # Le solde de différé est repris dans l'exercice de l'exercice de fin d'amortissement
    # Dans ce cas, la dotation exercice a été rectifiée par l'application de la règle du minimum
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC
    Call ECR_FICH ("FS1", 6,
&     "CAL_LNK_FISC_MINI Repr. Diff. Fin amt. ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
  Else
    #-- Amortissement différé Actualisation de la dotation rèelle selon différé
    [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE - [F:DEPC]DFD + [F:DEPC]DFDRVE
    [M:DIV]DOTEXE    = [M:DIV]DOTEXE  - [F:DEPC]DFD + [F:DEPC]DFDRVE
    If ( LECAFISMIN <> 0 ) Then
      # Reprise de différé implicite à concurence du solde de différé
      If ( abs([F:DEPC]DFDBLC) > abs(LECAFISMIN - [F:DEPC]DFDRVE) ) Then
        [F:DEPC]DFDRVE += LECAFISMIN - [F:DEPC]DFDRVE
      Else
        [F:DEPC]DFDRVE = [F:DEPC]DFDBLC
      Endif
    Endif
  Endif
  #-- 1 ---------------------------------------

  If ([F:DEPC]DFD + [F:DEPC]DFDRVE <> 0 ) Then
    Call ECR_FICH ("FS1", 6,
& "CAL_LNK_FISC_MINI Fisc. après diff.  ="+ format$([M:DIV]CURFMT, [F:DEPC]ENDDPE ) ) From =G_GLOB0
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
Return

#
#*********************************************************************
$CAL_DIF_ESP_2013_2014
#
# - Objet  : Traitement lié à la relation entre plan fiscal et minimum
#            pouvant affectée la dotation exercice fiscale
#
# - Entrée : FQ90432
#
# - Sortie :
#            [M:DIV]DIF         # Différé
#            [F:DEPC]DFDLIM     # Amortissement Différable
#            [F:DEPC]DFD        # Différé
#            [F:DEPC]DFDRVE     # Reprise de différé
#            [F:DEPC]ENDDPE     # Dotation exercice fiscal
#
#

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2 and [F:DEPC]FIYSTRDAT >= [01/01/2013] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-- 1 ---------------------------------------
  If ([F:DEPC]DPRPLN = G301FIS and !([M:DIV]BCUME_1) ) Then
    #=========================================
    # Amortissement différé 2013 2014
    #=========================================
    # Ne concerne que le plan fiscal
    # Pas de différé ni de reprise ni calcul de l'amortissement différable lors d'une reconstitution de cumul
    # Amortissement différé uniquement sur la dernière période de l'exercice.
    #-- Amortissement différé ([F:DEPC]DFD, [F:DEPC]DFDRVE)
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.


    Local Integer WDIFTYP, B_FIY
    B_FIY = find([F:DEPC]FIYENDDAT,[M:FIY]DATENDFIY)
    If (B_FIY) Then
      WDIFTYP = [M:FIY]DFDTYP(B_FIY-1)
      If (WDIFTYP <> GVML_DFD1314) Then : WDIFTYP = GVML_DFAUCUN : Endif
    Else
      WDIFTYP = GVML_DFAUCUN
    Endif
# FQ103339
#    If ( WDIFTYP = GVML_DFAUCUN and [F:DEPC]DFDBLC <> 0 and
#&   ([F:DEPC]FIYENDDAT > [01/01/2015] or func GLOBB9.CAL_DAT_INSIDE([01/01/2015],[F:DEPC]FIYSTRDAT,[F:DEPC]FIYENDDAT,"I")) ) Then
    If ( WDIFTYP = GVML_DFAUCUN and [F:DEPC]DFDBLC <> 0 and [F:DEPC]FIYSTRDAT >= [01/01/2015]) Then
      WDIFTYP = GVML_DFREPR
    Endif

    Case WDIFTYP
      When GVML_DFAUCUN
      # -- Aucun
      When GVML_DFD1314
      # -- Différé 2013 2014
        # Stockage différé
        # FQ103339
        #If( func GLOBB9.CAL_DAT_INSIDE([F:DEPC]FIYENDDAT, [01/01/2013], [31/12/2014],"I") ) Then
        If( func GLOBB9.CAL_DAT_INSIDE([F:DEPC]FIYSTRDAT, [01/01/2013], [31/12/2014],"I") ) Then
          Local Integer WPLNPIO : WPLNPIO = [M:DIV2]DPRPLNPIO
          If (WPLNPIO = G301FIS) Then
            WPLNPIO = G301CPT
            Call ECR_FICH ("FS1", 6, "CAL_DIF_ESP_2013_2014 Plan prioritaire Fiscal interdit basculé en comptable !!!!!!" ) From =G_GLOB0
          Endif
          # La dotation fiscale est Limitée à 70 % de la dotation du plan paramétré via DPRPLNPIO
          # La part de dotation fiscale au delà de cette limite est differée
          Local Decimal WLIM1314
          Local Integer WDEP
          Case WPLNPIO
            When  G301CPT
              WDEP = find([F:DEPC]PERENDDAT, [M:PCPT]PERENDDAT)
              WLIM1314 = ([M:PCPT]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301FIS
              WDEP = find([F:DEPC]PERENDDAT, [M:PFIS]PERENDDAT)
              WLIM1314 = ([M:PFIS]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301MIN
              WDEP = find([F:DEPC]PERENDDAT, [M:PMIN]PERENDDAT)
              WLIM1314 = ([M:PMIN]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301ORI
              WDEP = find([F:DEPC]PERENDDAT, [M:PORI]PERENDDAT)
              WLIM1314 = ([M:PORI]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301R76
              WDEP = find([F:DEPC]PERENDDAT, [M:PR76]PERENDDAT)
              WLIM1314 = ([M:PR76]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301IAS
              WDEP = find([F:DEPC]PERENDDAT, [M:PIAS]PERENDDAT)
              WLIM1314 = ([M:PIAS]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301TEC
              WDEP = find([F:DEPC]PERENDDAT, [M:PTEC]PERENDDAT)
              WLIM1314 = ([M:PTEC]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301RET
              WDEP = find([F:DEPC]PERENDDAT, [M:PRET]PERENDDAT)
              WLIM1314 = ([M:PRET]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301SUB
              WDEP = find([F:DEPC]PERENDDAT, [M:PSUB]PERENDDAT)
              WLIM1314 = ([M:PSUB]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI1
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI1]PERENDDAT)
              WLIM1314 = ([M:PLI1]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI2
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI2]PERENDDAT)
              WLIM1314 = ([M:PLI2]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI3
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI3]PERENDDAT)
              WLIM1314 = ([M:PLI3]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI4
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI4]PERENDDAT)
              WLIM1314 = ([M:PLI4]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI5
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI5]PERENDDAT)
              WLIM1314 = ([M:PLI5]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  G301LI6
              WDEP = find([F:DEPC]PERENDDAT, [M:PLI6]PERENDDAT)
              WLIM1314 = ([M:PLI6]ENDDPE(WDEP-1)) * ( (100 - 30) / 100. )
            When  Default
          Endcase

          #Call CAL_ARRONDI_MNT (WLIM1314, [M:DIV]CUR , WLIM1314) From =G_GLOB8
          [M:DIV]PV(0)= WLIM1314 : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WLIM1314 = [M:DIV]RV(1)
          If ( abs(WLIM1314) > = abs([F:DEPC]ENDDPE) ) Then
            # Le montant de la limite est supérieur ou égal à la dotation fiscale -> Pas de différé
            [F:DEPC]DFD = 0
            Call ECR_FICH ("FS1", 6,
&           "CAL_DIF_ESP_2013_2014 La limite est supérieure ou égale à la dotation fiscale -> Pas de différé") From =G_GLOB0
          Else
            # La part de dotation fiscal au delà de la limite est différée
            # FQ103339
            Call ECR_FICH ("FS1", 6,
&           "CAL_DIF_ESP_2013_2014 Mt limite différable ="+ format$([M:DIV]CURFMT, WLIM1314 ) ) From =G_GLOB0
            Call ECR_FICH ("FS1", 6,
&           "CAL_DIF_ESP_2013_2014 Repr. Diff. / Sortie ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
            [F:DEPC]DFD = [F:DEPC]ENDDPE - WLIM1314
          Endif
        Endif

      When GVML_DFREPR
      # -- Reprise de différé sur durée résiduelle à concurrence de 10 ans
        # Stockage reprise de différé

        # Fin résiduel 10 ans  = [31/12/2024]
        Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice
        Local Decimal WDURRES  : WDURRES  = 0.       : # Durée réstant à amortir
        Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
        Call ECR_FICH("FS1", 7, "CAL_DIF_ESP_2013_2014 - Reprise en résiduel jour  ") From =G_GLOB0

        Local Date    WDBREPR              : # Début reprise dans l'exercice
        Local Date    WFNREPR              : # Date de fin de reprise
        # FQ103339
#        If (func GLOBB9.CAL_DAT_INSIDE([01/01/2015],[F:DEPC]FIYSTRDAT,[F:DEPC]FIYENDDAT,"I")) Then
#          WDBREPR = [01/01/2015]
#        Else
#          WDBREPR = [F:DEPC]FIYSTRDAT
#        Endif
#        WFNREPR = min([M:DIV]DTFNAMT, [31/12/2024])
        WDBREPR = [F:DEPC]FIYSTRDAT
        If (day([F:DEPC]FIYENDDAT) = 31 and month([F:DEPC]FIYENDDAT) = 12  ) Then
          WFNREPR = [31/12/2024]
        Else
          WFNREPR = gdat$(day([F:DEPC]FIYENDDAT),month(FIYENDDAT),2025)
        Endif
#        WFNREPR = min([M:DIV]DTFNAMT, [31/12/2024])
        WFNREPR = min([M:DIV]DTFNAMT, WFNREPR)
        Call ECR_FICH("FS1", 7, "CAL_DIF_ESP_2013_2014 - Déb reprise    =" + num$(WDBREPR) ) From =G_GLOB0
        Call ECR_FICH("FS1", 7, "CAL_DIF_ESP_2013_2014 - Fin reprise    =" + num$(WFNREPR) ) From =G_GLOB0

        # Durée de détention dans l'exercice
# FQ103339
      # Call  CAL_DUR_DET
      #&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [31/12/2024], [01/01/2015],
      #&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, "D", WDURDET ) From =G_GLOB8
      #  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      #  [M:DIV]PD(3)= [31/12/2024]     : [M:DIV]PD(4)= [01/01/2015]   : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      #  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= "D"

      # Call  CAL_DUR_DET
      #&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, WDBREPR, WFNREPR, [M:DIV]DATNUL,
      #&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, "D", WDURDET ) From =G_GLOB8
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= WDBREPR
        [M:DIV]PD(3)= WFNREPR          : [M:DIV]PD(4)= [M:DIV]DATNUL   : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDURDET = [M:DIV]RV(1)
        Call ECR_FICH("FS1", 7, "CAL_DIF_ESP_2013_2014 - Durée Détent. Exerc.  =" + num$(WDURDET) ) From =G_GLOB0

        # Calcul de la durée restant à amortir
        Call  CAL_DUR_REST_AMT ([01/01/2013], [M:DIV]EXEDATREF, WFNREPR, "D", WDURRES) From =G_GLOB8
        Call ECR_FICH("FS1", 7, "CAL_DIF_ESP_2013_2014 - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0


        #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
        # calcul de la dotation exercice
        If ( WDURRES <> 0 ) Then
          Call ECR_FICH("FS1", 7,
&         "Dotation exercice = Solde différé * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
          [F:DEPC]DFDRVE = [F:DEPC]DFDBLC * ( WDURDET / WDURRES)
          #Call CAL_ARRONDI_MNT ([F:DEPC]DFDRVE, [M:DIV]CUR , [F:DEPC]DFDRVE) From =G_GLOB8
          [M:DIV]PV(0)= [F:DEPC]DFDRVE : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [F:DEPC]DFDRVE = [M:DIV]RV(1)
        Endif
        #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

      When Default
    Endcase


    If ( [F:DEPC]DFD <> 0 or [F:DEPC]DFDRVE <> 0 ) Then
      Call ECR_FICH ("FS1", 6,
&          "CAL_DIF_ESP_2013_2014 Dotation de référence  ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDBLC ) ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_DIF_ESP_2013_2014 Différé                ="+ format$([M:DIV]CURFMT, [F:DEPC]DFD    ) ) From =G_GLOB0
      Call ECR_FICH ("FS1", 6,
&          "CAL_DIF_ESP_2013_2014 Reprise différé        ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
    Endif
  #-- 1 ---------------------------------------
  Else
    [F:DEPC]DFD    = 0.
    [F:DEPC]DFDRVE = 0.
  Endif
  #-- 1 ---------------------------------------

  #-- Amortissement différé Reprise du solde différé en fin d'amortissement
  #-- 1 ---------------------------------------
  If ( [F:DEPC]FIYSTRDAT >= [01/01/2015] and [M:DIV]DTFNAMT < [F:DEPC]FIYSTRDAT and
&      ( [F:DEPC]DFDBLC <> 0 or [F:DEPC]DFD <> 0 ) ) Then
    # Le solde de différé est repris dans l'exercice de fin d'amortissement
    # FQ103339
    #[F:DEPC]DFD    = 0.
    #[F:DEPC]DFDRVE = [F:DEPC]DFDBLC
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC + [F:DEPC]DFD
    Call ECR_FICH ("FS1", 6,
&     "CAL_DIF_ESP_2013_2014 Repr. Diff. Fin amt. ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
  Endif
  #-- 1 ---------------------------------------
  #-- Amortissement différé Reprise du solde différé en cas de sortie
  #-- 1 ---------------------------------------
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and
&      ( [F:DEPC]DFDBLC <> 0 or [F:DEPC]DFD <> 0 ) ) Then
    # Le solde de différé est repris en cas de sortie dans l'exercice
    # FQ103339
    #[F:DEPC]DFD    = 0.
    #[F:DEPC]DFDRVE = [F:DEPC]DFDBLC
    [F:DEPC]DFDRVE = [F:DEPC]DFDBLC + [F:DEPC]DFD
    Call ECR_FICH ("FS1", 6,
&     "CAL_DIF_ESP_2013_2014 Repr. Diff. / Sortie ="+ format$([M:DIV]CURFMT, [F:DEPC]DFDRVE ) ) From =G_GLOB0
  Endif
  #-- 1 ---------------------------------------
  #-- Amortissement différé Actualisation de la dotation rèelle selon différé
  [F:DEPC]ENDDPE   = [F:DEPC]ENDDPE - [F:DEPC]DFD + [F:DEPC]DFDRVE
  [M:DIV]DOTEXE    = [M:DIV]DOTEXE  - [F:DEPC]DFD + [F:DEPC]DFDRVE

  # Sécurité, si la dotation est > à la valeur nette, la dotation est égale à la valeur nette
  # FQ116123
  #Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH ("FS1", 6,
& "CAL_DIF_ESP_2013_2014 Fisc. après diff.  ="+ format$([M:DIV]CURFMT, [F:DEPC]ENDDPE ) ) From =G_GLOB0


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
Return

#
#*********************************************************************
#         P A R T I C U L A R I T E S            F I S C A L E S
#*********************************************************************
#

#########################################################
Subprog  CAL_REGLE_DF_AMT30_2001 ( PAMT, RAMT, RAFI )
#
# - Objet  : Calcule la dotation exercice majorée
#            au titre de la règle fiscale "amortissement acceléré
#
#            Majoration de 30 % de l'amortissement pratiqué au titre
#            des 12 premiers mois suivant l'acquisition. Mesure réservée
#            aux investissements réalisés entre le 17/10/2001 et le
#            31/03/2002.
#
#
# - Entrée : amortissement de l'exercice
#
# - Sortie : amortissement de l'exercice majoré de l'aide fiscale calculée
#            montant de l'aide fiscale calculée
#
#
#   Boite noire GCFC20 - (gcfca5)
#

Value Decimal    PAMT
Variable Decimal RAMT
Variable Decimal RAFI

Local Date     WDTDB                             : # Borne début
Local Date     WDTFN                             : # Borne fin
Local Decimal  WCOE                              : # Borne fin
Local Decimal  WDURAPP                           : # Durée d'application (12 mois)
Local Date     WDTFNAPP                          : # Date de fin d'application
Local Decimal  WAPP                              : # Nombre de mois sur lesquels la règle fiscale doit s'appliquer
Local Decimal  WDETEXE                           : # Nombre de mois de détention dans l'exercice

 # If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-1 ----------------------------------------------------------
  If ( [M:DIV]DTDBAMTREG >= [F:DEPC]FIYSTRDAT and [M:DIV]DTDBAMTREG <= [F:DEPC]FIYENDDAT ) Then
    # L'amortissement débute dans l'exercice
    WCOE = 0.3
  #-1 ----------------------------------------------------------
  Else
    # L'exercice n'est pas celui du démarrage de l'amortissement

    # Evaluation bornes début & fin de l'exercice
    Call CAL_DAT_BORNES
&        ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG, [M:DIV]DATNUL,
&          [M:DIV]DATSORREG,  [M:DIV]DETVTEDAT,  WDTDB, WDTFN ) From =G_GLOB9
    If ([M:DIV]ERROR) Then : End : Endif

    # Evaluation date de fin d'application de la règle fiscale (12 mois)
    WDURAMT = 1.
    WDURAPP = 12
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, WDURAPP, [M:DIV]TYPPRO, WDTFNAPP ) From =G_GLOB9

    # Si règle toujours applicable ( Fin d'application de la règle ultérieure au Début exercice )
    If ( WDTFNAPP > WDTDB ) Then
      # Evaluation du nombre de mois sur laquelle la règle reste à appliquer
      Call CAL_DAT_DIFF( WDTDB, WDTFNAPP, [M:DIV]TYPPRODAT, WAPP ) From =G_GLOB9
      # Evaluation du nombre de mois de détention dans l'exercice
      Call CAL_DAT_DIFF( WDTDB, WDTFN, [M:DIV]TYPPRODAT, WDETEXE ) From =G_GLOB9
      # Plafonnement du nombre de mois résiduel d'application au nombre de mois de détention dans l'Exercice
      # Cas d'un découpage exercice < 12 mois ou d'une sortie moins de 12 mois suivant l'acquisition
      WAPP = min (WAPP, WDETEXE)
      # Evaluation du coef de majoration au prorata du nbre de mois d'application / nbre de mois de détention dans l'exe.
      WCOE = 0.3 * (WAPP / WDETEXE)
    Else
      WCOE = 0.0
    Endif
  Endif
  #-1 ----------------------------------------------------------



  # Détermination de la dotation exercice
  RAMT = PAMT * ( 1. + WCOE )
  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (RAMT , [M:DIV]CUR, RAMT) From =G_GLOB8
  [M:DIV]PV(0)= RAMT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RAMT = [M:DIV]RV(1)

  # Détermination de l'aide fiscale
  RAFI = RAMT - PAMT

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End




#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343


#
#
#
#########################################################
$CCN_CLORE_EXERCICE_RPR
#
# - Objet  : Exécute la clôture exercice
#            pour les informations du plan d'amortissement
#
# Rem.     : La clôture périodique a été réalisée au préalable
#            sauf dans le cas d'une reconstitution de cumul.
#
# - Entrée : [F:DEPC]
#            Origine de la clôture ("CAL" Calcul / "CLO" Clôture)
#
# - Sortie : [F:DEPS]
#
#   Boite noire gcfc06
#


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  [F:RPRS]STRRNWVAL  = [F:RPRC]ENDRNWVAL  : # Valeur de remplacement
  [F:RPRS]RNWVALFLG  = G_NON              : # Valeur de remplacement déforcée sur les exercices futurs

  # --------------------------
  # -- PROVISIONS
  # --------------------------

  [F:RPRS]E_1ACGRPR  = [F:RPRC]E_1ACGRPR  + [F:RPRC]EXEACGRPR    : # Cum E-1 Prov. Cpt.
  [F:RPRS]E_1FISRPR  = [F:RPRC]E_1FISRPR  + [F:RPRC]EXEFISRPR    : # Cum E-1 Prov. Fis.
  [F:RPRS]E_1RVERPR  = [F:RPRC]E_1RVERPR  + [F:RPRC]EXERVERPR    : # Cum E-1 Repr. Prov. Fis.
  [F:RPRS]E_1SUPCAD  = [F:RPRC]E_1SUPCAD  + [F:RPRC]EXESUPCAD    : # Cum E-1 Supplément de caducité

  [F:RPRS]EXEACGRPR  = 0                                         : # 0-> Prov. Cpt.
  [F:RPRS]EXEFISRPR  = 0                                         : # 0-> Prov. Fis.
  [F:RPRS]EXERVERPR  = 0                                         : # 0-> Repr. Prov. Fis.
  [F:RPRS]EXESUPCAD  = 0                                         : # 0-> Supplément de caducité

  [F:RPRS]P_1ACGRPR  = 0                                         : # 0-> Cum P-1 Prov. Cpt.
  [F:RPRS]P_1FISRPR  = 0                                         : # 0-> Cum P-1 Prov. Fis.
  [F:RPRS]P_1RVERPR  = 0                                         : # 0-> Cum P-1 Repr. Prov. Fis.
  [F:RPRS]P_1SUPCAD  = 0                                         : # 0-> Cum P-1 Supplément de caducité


Return

#########################################################
$CCN_CLORE_PERIODE_RPR
#
# - Objet  : Exécute la clôture périodique d'un plan
#            pour les informations du plan d'amortissement
#
# - Entrée   : [F:DEPC]
#            Origine de la clôture ("CAL" Calcul / "CLO" Clôture)
#
#
# - Sortie   : [F:DEPS]
#

  # --------------------------
  # -- PROVISIONS
  # --------------------------


  [F:RPRS]P_1ACGRPR  = [F:RPRC]P_1ACGRPR  + [F:RPRC]PERACGRPR    : # Cum P-1 Prov. Cpt.
  [F:RPRS]P_1FISRPR  = [F:RPRC]P_1FISRPR  + [F:RPRC]PERFISRPR    : # Cum P-1 Prov. Fis.
  [F:RPRS]P_1RVERPR  = [F:RPRC]P_1RVERPR  + [F:RPRC]PERRVERPR    : # Cum P-1 Repr. Prov. Fis.
  [F:RPRS]P_1SUPCAD  = [F:RPRC]P_1SUPCAD  + [F:RPRC]PERSUPCAD    : # Cum P-1 Supplément de caducité
  [F:RPRS]PERACGRPR  = 0                                         : # 0-> Prov. Cpt.
  [F:RPRS]PERFISRPR  = 0                                         : # 0-> Prov. Fis.
  [F:RPRS]PERRVERPR  = 0                                         : # 0-> Repr. Prov. Fis.
  [F:RPRS]PERSUPCAD  = 0                                         : # 0-> Supplément de caducité

Return

