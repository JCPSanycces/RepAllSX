#<AdxTL>@(#)6.0.0.0 $Revision$

#
#*********************************************************************
#
#                    GESTION des CONCESSIONS
#

#*********************************************************************
#    Modification
# Issue X3-109499 -2018-09-20 MDJ : RD - Events Icon in header
# CBO   19.04.2016 FQ115510   : Pb call LOAD_FASPARCPY (FCP mask doesn't exist)
# GLE - 10.09.2013 - FQ92461 : gestion du champ CREORI
# MWA - 31.10.2012 - FQ85464 : Prise en compte de la legislation dans la numérotation automatique
# CBO - 22.06.2012 - FQ82709 : contrôle (général) des axes analytiques
# GLE - 26.07.2011 - FQ70353 : Pas le bouton "Journal des événements" sur les contrats de concession terminés
# MWA - 23/09/2010 - FQ67467 : Problème d'affichage des axes analytiques
# MWA - 26.05.2009             Passage en gestion objet
#
#*********************************************************************
##
#

# Gestion du masque CCN1
Call OBJET("CCN",GBIDC1,GBIDC2) From GOBJET
End

##########################################################################
$ACTION
# CBO 2012.06.22 FQ82709 : ajout de VERIF_CRE et VERIF_MOD
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "OUVRE_BOITE"      : Gosub OUVRE_BOITE

    When "RAZDUP"           : Gosub RAZDUP
    When "RAZCRE"           : Gosub RAZCRE
    When "LIENS"            : Gosub LIENS
    When "AVANT_MOD"        : Gosub AVANT_MOD
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "VERIF_MOD"        : Gosub VERIF_CRE

    When "SETBOUT"          : Gosub SETBOUT

    When "INICRE"           : Gosub INICRE
    When "INIMOD"           : Gosub INIMOD  : # FQ92461

    When "APRES_CHOI"       : Gosub APRES_CHOI
    When "FILGAUCHE"        : Gosub FILGAUCHE
    When "TIROIR"           : Gosub TIROIR

    When "AV_ANNULE"        : Gosub AV_ANNULE

    When "FIN"              : Gosub FIN
    When Default
  Endcase
Return

#=====================================================================
#
$OUVRE



  #-----------------------------------------------------------------------------------#
  # Si on vient par tunnel il faut sauvegarder les variables globales   #
  #-----------------------------------------------------------------------------------#
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif
  If TUNNEL : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif
  #-------------------------
  # Appel à la fonction de gestion des zones libres
  Gosub OUVRE From SUBFRZ
  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

Return

#=====================================================================
$OUVRE_BOITE
  # Déclaration tirroir
  Local Char LTI_FASCCN : LTI_FASCCN = 'GAU_CHE'+num$(find('FA6',OBJLIS(1..10))) : # Bien de la concession
  Local Char LTI_CCNISS : LTI_CCNISS = 'GAU_CHE'+num$(find('CC1',OBJLIS(1..10))) : # Concessions sortis

Return

#=====================================================================
#
$RAZCRE

#  Affichage des valeurs par défaut
Effzo   [M:CCN1]

If ( GREMAFCY = G_NON ) Then
  zonsui = "[M:CCN0]FCY"
Else
  zonsui = "[M:CCN0]CCNREF"
Endif

Return

#=====================================================================
#
$RAZDUP
Return

#=====================================================================
#
$LIENS

  # FQ67467
  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:CCN]CPY,"",G_NON,ERR) From GLOFCYCPY

  # FQ67467
  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRCCE
  Call LOAD_TAB_CCE("[F:CCN]","[M:FPC]","[M:CCN2]",LNBRCCE) From GLOBIENSANA
  [M:CCN2]NBRCCE=LNBRCCE

  # La concession a son statut à "Terminé", elle ne peut plus être modifée
  If ( [M:CCN1]CCNSTA = GVML_CSTERM ) Then
    Diszo [M:CCN1] : Affzo [M:CCN1]
    Diszo [M:CCN2] : Affzo [M:CCN2]
    Diszo [M:CCN9] : Actzo [M:CCN0]EVTLIST : Affzo [M:CCN9] : # FQ70353 # Issue X3-109499
  Else
    Actzo [M:CCN1] : Affzo [M:CCN1]
    Actzo [M:CCN2] : Affzo [M:CCN2]
    Actzo [M:CCN9] : Affzo [M:CCN9]
  Endif

 If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:CCN0]FCY", 0) = G_OUI ) Then : Diszo [M:CCN0]FCY : Endif
 If TUNNEL : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif

 Gosub CHARGE_AVENANTS

Return


#-------------------------------------------------------------------------------
$AVANT_MOD

  # La concession a son statut à "Terminé", elle ne peut pas être modifiée
  If ( [M:CCN1]CCNSTA = GVML_CSTERM ) Then
    GERR=1 : GMESSAGE = mess(740,7773,1)
    OK=0
  Endif

Return


#=====================================================================
$SETBOUT

  # Désactivation des actions
  # -- Changer de clé
  Call VIREBOUT(CHAINE,"H") From GOBJET

Return


#=====================================================================
#
$INICRE
  # Numérotation automatique

  If ( GCCNAUTNUM = 2 or (GCCNAUTNUM = 3 and [M:CCN0]CCNREF="") ) Then
    Local Integer STAT
    # Appel du compteur de document FQ85464
    Call GET_NUMERO("CCN",GVML_NUMCCN-1,1,[M:CCN0]CPY,[M:CCN0]FCY,date$,[F:CCN]CCNREF,STAT) From GLOBIENS
    If ( STAT ) Then : GOK = 0 : Return : Endif
    [M:CCN0]CCNREF = [F:CCN]CCNREF : Affzo [M:CCN0]CCNREF
  Endif

  Gosub INI_CREORI : # FQ92461
Return
#=====================================================================  # FQ92461
#
$INIMOD
  Gosub INI_CREORI
Return

#=====================================================================  # FQ92461
#
$INI_CREORI
  [F:CCN]CREORI = GVML_COSAITR             : # Origine de saisie
  If (GIMPORT) Then
    [F:CCN]CREORI = GVML_COIMPOR
  Endif
Return

#=====================================================================
$APRES_CHOI
  If ( currbox = LTI_FASCCN ) Then
    # Si on est sur le tiroir des biens de la concession
    Case REPONSE
      When GSTALFT
        If dim([M:FAS0]CPY) < 0 Then
          # L'écran des biens n'est pas ouvert : on peut y accéder
          Local Char LFAS : LFAS = [F:FAS]AASREF
          Call OBJET_CHAR(LFAS, "FAS", "") From GOBJET
        Else
          # L'écran des biens est ouvert, tunnel impossible dans ce cas,
          GERR=1: GMESSAGE = mess(689,7773, 1): OK= 0: Return
        Endif
    Endcase
  Endif
Return

#=====================================================================
$TIROIR

  If ( currbox = LTI_FASCCN ) Then
    # Biens de la concession
    Raz CRITERE
    Gosub FILGAUCHE
    If (dim(FILTREG) > 0) Then : FILTREG = 1 : Endif
    Case currbox
      When LTI_FASCCN : Gosub REMPLIT_1 From WGOCCN
    Endcase
  Endif
Return

#=====================================================================
$FILGAUCHE

  If ( currbox = LTI_FASCCN ) Then
    # Biens de la concession
    Raz FILGAUSUP
    FILGAUSUP(0) = "CCNREF=[M:CCN0]CCNREF and CCNREF<>''"
  Elsif ( currbox = LTI_CCNISS ) Then
    # Concessions sortis
    Raz FILGAUSUP
    FILGAUSUP(0) = "[F:CCN]CCNSTA= GVML_CSTERM"
  Endif

Return

#=====================================================================
$AV_ANNULE

 If ( GOK ) Then
   Local Integer LCDRET
   Local Integer NBEVESUP
   Call SUPP_EVE_OBJ(GVML_OMCCN,[M:CCN0]CPY,[M:CCN0]FCY,[M:CCN0]CCNREF,0,[0/0/0],NBEVESUP,LCDRET) From GENEVE
   If ( LCDRET ) Then
     Infbox "SUPP_EVE_OBJ =>"-num$(LCDRET)
     GOK=0
     Return
   Endif
 Endif

Return

# CBO 2012.06.22 FQ82709
$VERIF_CRE
  # Contrôle de validité des axes analytiques :
  Gosub CTRL_TAB_CCE From GLOBIENSANA
Return
#=====================================================================
#
$FIN
  If dim(G_AJOUT) >0 : Kill G_AJOUT  : Endif
Return


######################################################################
#            CCN0-             E C R A N    CCN0
######################################################################


######################################################################################
Subprog C_CCNREF(VALEUR)
Variable Char    VALEUR()

  If ( GCCNAUTNUM=1 and VALEUR="" ) Then
    GERR     = 1
    GMESSAGE = mess(3,77733, 1)
    mkstat   = 2
  Elsif ( VALEUR = "" and !GIMPORT ) Then
    # Création forcée
    mkstat = 4
Endif

End


######################################################################
#            CCN1-             E C R A N    CCN1
######################################################################

######################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  Affzo [M:CCN0]ZCPY

End

############################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer ISITE, OK
  Local Char    SOCIETE (GLONCPY)

  # Recherche de la société du site
  ISITE = find(VALEUR,GSITE(1..GNBSITE))
  If ISITE
    SOCIETE = GSOCSITE(ISITE)
  Else
    GMESSAGE = mess(15,7774,1) : # Site inexistant
    mkstat = 2 : End
  Endif

End

############################################
Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()

  Local Char LZVSOC(GLONCPY)

  LZVSOC = [M:CCN0]CPY
  Call ACTION_FCY (VALEUR, [M:CCN0]CPY) From GLOFCYCPY
  If [M:CCN0]CPY <> LZVSOC Then
    Affzo [M:CCN0]CPY
  Endif


End

############################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  # Affichage de l'intitulé société
  If ( dim([M:CCN0]ZCPY) > 0 ) Then
    Affzo [M:CCN0]ZCPY
  Endif

  # FQ67467
#  If !clalev([M:FCP])# Issue 115510
     #> Chargement du masque de travail contenant le paramétrage comptable de la société
     Local Integer ERR
     Call LOAD_FASPARCPY([M:CCN0]CPY,"",G_NON,ERR) From GLOFCYCPY
#  Endif# Issue 115510

  # FQ67467
  # Code Axes analytiques
  Effzo [M:CCN2]DIE
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
    [M:CCN2]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
  Next I_DIE
  Affzo [M:CCN2]DIE

  ##Effzo [M:FAS1]ACGETRNOT

  # Réinitialisation de champs en cas de changement d'établissement
  [M:CCN0]FCY = VALEUR

  # Masquage de certains champs en fonction du contexte d'exécution
  Gosub MASQUER_CHAMPS

End

######################################################################################
Subprog AV_CCNSTA(VALEUR)
Variable Integer VALEUR

 If ([M:CCN1]CCNSTA = GVML_CSTERM ) Then
   Diszo [M:CCN1]CCNSTA
 Else
   Actzo [M:CCN1]CCNSTA
 Endif

End

############################################
Subprog AS_CCNSTA(VALEUR)
Variable Integer VALEUR

  # GVML_CSPREP    = 1       : # En préparation
  # GVML_CSACTI    = 2       : # Actif
  # GVML_CSTERM    = 3       : # Terminé

  # L'état "Terminé" est exclu
  GMENLOC(GVML_CSTERM)  = 1

  If ( func SUBCCN.FAS_UTILISE_CCN([M:CCN0]CCNREF ) ) Then
    # Si au moins un bien utilise la concession la concession ne peut pas repasser à "En préparation"
    GMENLOC(GVML_CSPREP)  = 1
  Endif
End

######################################################################################
Subprog AV_DFTCCNFLG(VALEUR)
Variable Integer VALEUR

   If (func SUBCCN.FCY_POSSEDE_CCN_PAR_DEFAUT([M:CCN0]CPY,[M:CCN0]FCY,[M:CCN0]CCNREF) ) Then
     Diszo [M:CCN1]DFTCCNFLG
   Else
     Actzo [M:CCN1]DFTCCNFLG
   Endif

End


######################################################################################
Subprog AV_STRCCNDAT(VALEUR)
Variable Date VALEUR

 If (func SUBCCN.FAS_UTILISE_CCN([M:CCN0]CCNREF) ) Then
   Diszo [M:CCN1]STRCCNDAT
 Else
   Actzo [M:CCN1]STRCCNDAT
 Endif

End

######################################################################################
Subprog AV_ENDCCNDAT(VALEUR)
Variable Date VALEUR

 If (func SUBCCN.FAS_UTILISE_CCN([M:CCN0]CCNREF) ) Then
   Diszo [M:CCN1]ENDCCNDAT
 Else
   Actzo [M:CCN1]ENDCCNDAT
 Endif

End

############################################
Subprog C_ENDCCNDAT(VALEUR)
Variable Date    VALEUR
  # La date de fin doit être > à la date de début de la concession
  If ( VALEUR <= [M:CCN1]STRCCNDAT) Then
    GERR= 1 : GMESSAGE= mess(253, 7773, 1)
    mkstat = 2 : End
  Endif
End

############################################
Subprog AM_ENDCCNDAT(VALEUR)
Variable Date    VALEUR
  # En cas de modif, la date de fin doit être >= à la date de début de l'exercice comptable & fiscal
  If ( G_AJOUT <> 82 and VALEUR < GDEBEXECPF ) Then
    GERR= 1 : GMESSAGE= mess(254, 7773, 1)
    mkstat = 2 : End
  Endif
End

##########################################################################
Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()

  # Masquage de certains champs en fonction du contexte d'exécution
  Gosub MASQUER_CHAMPS
End

#====================================================
$MASQUER_CHAMPS

# Pour rendre invisible une colonne
#    Ajouter un 'Avant-zone' sur un champ situé au delà du dernier champ à conditionner ( Ex LSTFLD)
#    Sinon à l'affichage, le prog qui gère l'écran fait un chgfmt qui annule le conditionnement
#    Annuler le format en faisant un 'changement format' et en mettant un - devant le format
#    Attention si un champ n'est pas saisissable, le fait de le rendre visible le rend saisissable. 2 cas possibles :
#    1°) Pour un champ que l'on sait non saississable ajout dizo comme ci-dessous.
#   If ( G_CCNRPR <> G_OUI ) Then
#     Chgfmt[M:CCN1]LSTREVDAT With "-D:"+GFMDAT4
#   Else
#     Chgfmt[M:CCN1]LSTREVDAT With "D:"+GFMDAT4
#     Diszo [M:CCN1]LSTREVDAT
#   Endif
#   2°) Si le champ n'est pas saisissable selon certaines conditions,  tester IS_DISABLE pour le champ et faire le diszo si nécessaire.

   If ( G_CCNRPR <> G_OUI ) Then
     Chgfmt[M:CCN1]REAENDCCN With "-D:"+GFMDAT4
   Else
     Chgfmt[M:CCN1]REAENDCCN With  "D:"+GFMDAT4
     Diszo [M:CCN1]REAENDCCN
   Endif

   # If ( G_CCNRPR <> G_OUI ) Then
   #   Chgfmt[M:CCN1]ACCCOD    With "-KP:"+num$(GLONCAC)+"B"
   # Else
   #   Chgfmt[M:CCN1]ACCCOD    With "KP:" +num$(GLONCAC)+"B"
   # Endif

Return

#====================================================
Funprog FAS_UTILISE_CCN(PCCN)
# Reçoit une concession
# et rend 1 si le mode est utilisé par un bien comptable
# ou rend 0 dans le cas contraire
# ---------------------------------

Value Char    PCCN
Local Integer RRET

  RRET = 0
  If (PCCN <> "") Then
    If clalev([F:FAS])  =0     : Local File FXDASSETS     [FAS]     : Endif
    Local Char CRITERE

    CRITERE = 'CCNREF=PCCN'
    For [FAS]FAS8 Where evalue(CRITERE)
      RRET=1
      Break
    Next
  Endif

End RRET


#====================================================
Funprog FCY_POSSEDE_CCN_PAR_DEFAUT(PCPY, PFCY, PCCN)
# Reçoit la société, l'établissement et la concession courante
# et rend 1 si le mode est utilisé par un bien comptable
# ou rend 0 dans le cas contraire
# ---------------------------------

Value Char    PCPY
Value Char    PFCY
Value Char    PCCN

Local Integer RRET

  If clalev([F:WCCN])  =0     : Local File CONCESSION     [WCCN]     : Endif

  Filter [WCCN] Where CPY= PCPY and FCY= PFCY and CCNREF <> PCCN and DFTCCNFLG= G_OUI
  Read [WCCN]CCN2 First
  Filter [WCCN]
  If (fstat) Then
    RRET = 0
  Else
    RRET = 1
  Endif

End RRET




###################################################################
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()

 If ( VALEUR <> "" ) Then
   If (!clalev([DSP])) Then : Local File CADSP [DSP] : Endif

   Read [DSP]DSP0 = VALEUR;1 : # Lecture de la première ligne

   #> Vérification site / société
   If ( [F:DSP]FCY <> "" ) Then
     Call VERIF_FCY("DSP", [F:DSP]FCY, [M:CCN0]CPY, [M:CCN0]FCY, VALEUR) From GLOBIENS
     If mkstat : End : Endif
   Endif
Endif

End

########################################
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()

  Local Integer N_CCE

  For N_CCE = 0 To GOPTCANA-1
    If VALEUR = ""
      # Si une clé de répartition est remise à blanc, il faut dégriser les axes
      Actzo [M:CCN2]CCE(N_CCE)
    Else
      # Si une clé de répartition est saisie, il faut griser les axes
      [M:CCN2]CCE(N_CCE) = ""
      Diszo [M:CCN2]CCE(N_CCE)
    Endif
  Next N_CCE

End
########################################
$CHARGE_AVENANTS

  If clalev([F:EVT]) =0 : Local File ECCNREV    [EVT]  : Endif
  nolign=1
  Filter [F:EVT] Where CPY=[M:CCN0]CPY and EVTINT="CCNREV" and REF=[M:CCN0]CCNREF Order By TIMSTP
  For [EVT]
    [M:CCN3]REVDAT     (nolign-1) = [F:EVT]CREDAT
    [M:CCN3]REVSTRDAT  (nolign-1) = [M:CCN1]STRCCNDAT
    [M:CCN3]REVENDDATO (nolign-1) = [F:EVT]ENDCCNDATO
    [M:CCN3]REVENDDATN (nolign-1) = [F:EVT]ENDCCNDATN
    [M:CCN3]REVREN     (nolign-1) = [F:EVT]REVREN
    nolign += 1
  Next
  Filter [F:EVT]
  [M:CCN3]NBLIG = nolign-1
  Affzo [M:CCN3]

Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran CCN1) 13/04/2010 11:14:11 (MWA)
######################################################################################
Subprog IB_REAENDCCN
End


######################################################################################
# Issue X3-109499 - RD - Events Icon in header
######################################################################################
Subprog CL_EVTLIST(VALEUR)
Variable Char    VALEUR()

 Call CL_EVTLIST(VALEUR) From SUBFRZ

End
