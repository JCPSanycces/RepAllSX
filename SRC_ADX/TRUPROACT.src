#    GESTION DES ACTIONS METIER SUR LES OBJETS METIERS / TRAITEMENTS COMMUNS
#    GBN
#    Modification le :
#    MWA - 31.12.2013 - FQ  n° 83184 - message en français
#    MDJ - 04.10.2012 - FQ  n° 67621 - Création fact 1/3 client
#    GLE - 01.03.2011 - FQ  n° 70465 - Aucune action possible sur un bien si un contexte est désynchronisé
#    GBO - 27.08.2007 - FQ  n° 42767 - Ouverture du modèle d'action aux spé
#    GBO - 02.10.2006 - FQ  n° 37859 - FIN puis choix de ne pas perdre les modifs : perte des infos action métier
#    MDJ - 29.05.2006 - FQ  n° 36248 - Modif message qd modi. fsur un bien sorti par une cession intra-groupe
#    Gbn - 05.04.2005 - Fq  n° 29415 - Si bien annulé -> menus grisés
#    XXX - 03.03.2005 - Bug n° 28970 - Remplacement abréviation AWB par AWT
################################################################################
# TRUPROACT : Action métier unitaire - trt commun - Modèle 2
######################################################################
 Local Char MASUNI : MASUNI="U"
 Local Char ACTNAM : ACTNAM="FASTEST"
 Call LAUNCH_ACT(MASUNI) From ="TRT"+ACTNAM
End
######################################################################
$ACTION
 If dim(TRTOBJ)>0
  Case ACTION
    When "SETBOUT"      : Gosub OBJ_SETBOUT        #=> Actions de l'objet métier
    When "AVANTBOUT"    : Gosub OBJ_AVANTBOUT      #
    When "FIN_ACTION"   : Gosub OBJ_FIN_ACTION     #
    When "APRES_CHOI"   : Gosub OBJ_APRES_CHOI     #
    When "ABANDON"      : Gosub OBJ_ABANDON        #Gbn-02.10.2006-37859
    When "AVANT_MODFIC" : Gosub OBJ_AVANT_MODFIC   #
    When "APRES_MOD"    : Gosub OBJ_APRES_MOD      #
    When "AB_MODIF"     : Gosub OBJ_AB_MODIF       #
    When Default
  Endcase
 Else
  Case ACTION
    When "OUVRE"        : Gosub ACT_OUVRE
    When "DEBUT"        : Gosub ACT_DEBUT
    When "SETBOUT"      : Gosub ACT_SETBOUT
    When "BOUTON"       : Gosub ACT_BOUTON
    When "AP_CHOIX"     : Gosub ACT_AP_CHOIX
    When "APRES_MODIF"  : Gosub ACT_APRES_MODIF
    When "OK"           : Gosub ACT_OK
    When "ABA"          : Gosub ACT_ABA
    When "END"          : Gosub ACT_END
    When "FIN"          : Gosub ACT_FIN
    When Default
  Endcase
 Endif
Return

#########################################################################
$OBJ_SETBOUT
 # Les codes boutons associés aux actions métiers sont stockés dans la variable LIS_ACT
 # Pour chaque bouton, on va chercher le code action qui lui correspond dans la fenêtre
 # puis on accède à l'étiquette CRITMEN de ACTMEN du TRT+nom d'action pour récupérer la
 # variable CRITMEN. Elle contient l'expression critère qui permet d'activer l'entrée de
 # menu

 Local Char    ACTMET
 Local Char    CRITMEN(100)
 Local Char    CRITSUP(100)
 Local Char    CRITACT(200)
 Local Integer I_BOUT
 Local Char    NOM_ACTION
 Local Integer CDRET
 Local Char    LKEY
 Local Integer OBJET
 Local Char    NOTLOCK
 Local Char    TRTACTION
 Local Integer EXISTE_ADX

 #--> On alimente CRITSUP, critère valable pour toutes les actions si on est pas en création

 If !(GREP="C")
  CRITSUP='!(GREP="M") & num$(VERROU)="1"'
  #CRITSUP="1=1"
 Else
  CRITSUP="0=1"
 Endif

 #--> On passe chaque action en revue et on lui applique son critère CRITMEN + CRITSUP (V1)

 $V1
 If dim(LIS_NAM)>0 : Goto V2  : Endif  # Dev  # Si LIS_NAM n'existe pas on ne peut pas utiliser V2
#If GUSER="GBO"    : Infbox "V1 TRUPROACT" : Endif  # Dev  # on est obliger d'utiliser V1

 Local Char TYPBOUT(1)
 For I_BOUT=0 To dim(LIS_ACT)-1
  If LIS_ACT(I_BOUT)="" : Break : Endif
  Call GET_ACTINF(LIS_ACT(I_BOUT),NOM_ACTION,TYPBOUT,CDRET) From TRTOBJACT
  If !CDRET
   # Ici on vérifie d'abord que le traitement associé à l'action existe
   # S'il n'existe pas, on active pas le menu -> Pas d'accès possible à l'action, donc
   # pas de problème par la suite.
   TRTACTION="TRT"+NOM_ACTION
   Call EXISTE_ADX("","",TRTACTION,EXISTE_ADX) From ORDSYS
   If EXISTE_ADX Then
    Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
    If !(CRITMEN="")        # Si CRITMEN alimenté,
     CRITACT=CRITSUP-"&"-CRITMEN
    Else
     CRITACT=CRITSUP             # Si CRITMEN non alimenté, on active toujours le menu
    Endif
    If evalue (CRITACT)
     If TYPBOUT="B"
      Call VIREBOUT(CHAINE,LIS_ACT(I_BOUT)) From GOBJET # Si c'est un bouton
     Elsif TYPBOUT="M"
      CHMEN+=LIS_ACT(I_BOUT)                            # si c'est un menu
     Endif
    Endif
   Endif
  Endif
 Next I_BOUT

Return

 #--> On passe chaque action en revue et on lui applique son critère CRITMEN + CRITSUP (V2)

 $V2

#If GUSER="GBO" : Infbox "V2 TRUPROACT" : Endif # Dev
 For I_BOUT=0 To dim(LIS_ACT)-1
  If LIS_ACT(I_BOUT)="" : Break : Endif
  TRTACTION="TRT"+LIS_NAM(I_BOUT)
  Call EXISTE_ADX("","",TRTACTION,EXISTE_ADX) From ORDSYS
  If EXISTE_ADX Then
##########################################################################
# Gbn - Correction du 17/08/2004 - Problème d'évaluation de CRITSUP (Fgr)
##########################################################################
#   Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
#   If !(CRITMEN="")        # Si CRITMEN alimenté,
#    CRITACT=CRITSUP-"&"-CRITMEN
#   Else
#    CRITACT=CRITSUP             # Si CRITMEN non alimenté, on active toujours le menu
#   Endif
#   If evalue (CRITACT)
#    If LIS_TYP(I_BOUT)="B"
#     Call VIREBOUT(CHAINE,LIS_ACT(I_BOUT)) From GOBJET # Si c'est un bouton
#    Elsif LIS_TYP(I_BOUT)="M"
#     CHMEN+=LIS_ACT(I_BOUT)                            # si c'est un menu
#    Endif
#   Endif
##########################################################################
# 270106-FQ 33811
  #If [M:FAS0]ENAFAS=G_OUI & [F:FAS]ISSFIYPRE<>G_OUI : # FQ70465
  If [M:FAS0]ENAFAS=G_OUI & [F:FAS]ISSFIYPRE<>G_OUI & func GLOBIENS.IS_DESYNC_CNX([M:FAS0]CPY,0)<>G_OUI
   If LIS_TYP(I_BOUT)="B"
    ##### Gbn 20050405 FQ29415
    If GREP="M" | num$(VERROU)<>"1" | [M:FAS1]OWNTYP=GVML_TDANNUL
      Call VIREBOUT(CHAINE,LIS_ACT(I_BOUT)) From GOBJET
     Else
      Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
      If !(CRITMEN="")
       If evalue (CRITMEN)
        Call VIREBOUT(CHAINE,LIS_ACT(I_BOUT)) From GOBJET # Si c'est un bouton
       Endif
      Endif
     Endif
    Elsif LIS_TYP(I_BOUT)="M"
     ##### Gbn 20050405 FQ29415
     If GREP<>"M" & num$(VERROU)="1" & !([M:FAS1]OWNTYP=GVML_TDANNUL)
      Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
      If CRITMEN=""
       CRITMEN="1=1"
      Endif
      #STANT 23/06/08, on vérifie que le bouton à rajouter n'est pas deja dans la liste. Cas des tunnels.
      Local Integer I
      If evalue (CRITMEN) and !instr(0,CHMEN,LIS_ACT(I_BOUT)) Then
        CHMEN+=LIS_ACT(I_BOUT)
      Endif
     Endif
    Endif
   ##########################################################################
   Endif
  Else
   Call VIREBOUT(CHAINE,LIS_ACT(I_BOUT)) From GOBJET
  Endif
 Next I_BOUT
Return

#########################################################################
$OBJ_AVANTBOUT
 Local Integer I_BOUT
 I_BOUT=find(BOUT,LIS_ACT)
 If I_BOUT
 Endif
Return

#########################################################################
$OBJ_FIN_ACTION
 # En retour d'une action, celle-ci a créé la globale ACTMODIF qui permet de savoir si des modifs ont
 # été validée et doivent être reportées dans le masque courant et si on doit passer le bien en modif.
 # Cette globale est détruite quand c'est fait. On ne passe en modif que si la globale existe.
 If dim(ACTMODIF)>0 & dim(NUMACT)>0                         #=> ACTMODIF existe -> on sort donc d'une action métier
   If ACTMODIF                                              #=> ACTMODIF = 1    -> Des modifs à enregistrer
    ACTMET="REAF_ALIM_MASK" : Gosub ACTMET From TRCPROCOM   #=> réaffichage des masques de la fenêtre objet métier (Voir si possibilité d'automatiser)
    REP="M" : GREP="M"                                      #=> L'objet passe en mode modif
   Else                                                     #=> Pas de modif on nettoie tout ce qui a été crée par l'action
    Gosub NETTOYER
    Kill NUMACT
    Kill ACTMODIF
    Gosub KILL_CONSTANTES From TRCPROCOM                    #=> Destruction des constantes
    Gosub KILL_GLOBALES From TRCPROCOM
   Endif
 Else
  If dim(ACTMODIF)>0 #Gbn-29/09/2004 : supp du masque uniquement si action V2
   If clalev([M:OAC0]) : Close Local Mask [OAC0] : Endif #Gbn - 15092004 : supp masque si on sort aussitôt de l'action
  Endif
 Endif

 If dim(ACTSTATUS)>0                                    #Gbn-17/08/2004 : supp du masque uniquement si action V2
  If clalev([M:OAC0]) : Close Local Mask [OAC0] : Endif #Gbn-05/08/2004
 Endif

Return

#########################################################################
$OBJ_APRES_CHOI
 # Au retour d'une action métier et si des modifs ont été faites, l'objet est en mode modif
 # On peut soit enregistrer les modifs, soit abandonner. Si on abandonne, on détruit la globale
 # NUMACT pour éventuellement pouvoir repartir proprement dans une autre action métier.

#-> Demande Mdr - si clic sur abandon, on a plus accès à aucune entrée de menu !
# If ((REPONSE=GSTAFIN)|(REPONSE=GSTAEND))
#  If dim(LIS_ACT)>0 : Kill LIS_ACT : Endif
#  If dim(LIS_NAM)>0 : Kill LIS_NAM : Endif
#  If dim(LIS_TYP)>0 : Kill LIS_TYP : Endif
# Endif

#Gbn-021006-Fq 37859-Suppression si FIN sur la fenêtre BCO prise en charge dans OBJ_ABANDON.
#If (((REPONSE=GSTAFIN) | (REPONSE=GSTAEND)) & (dim(NUMACT)>0)) # Abandon ou fin et traces d'une action métier
 If ((REPONSE=GSTAFIN)  & (dim(NUMACT)>0)) # Abandon ou fin et traces d'une action métier
  Gosub NETTOYER
  If dim(ACTMODIF)>0 : Kill ACTMODIF : Endif
  Kill NUMACT
  Gosub KILL_CONSTANTES From TRCPROCOM                      #=> Destruction des constantes
  Gosub KILL_GLOBALES From TRCPROCOM
 Endif

Return

#Gbn-021006-Fq 37859-Suppression si FIN sur la fenêtre BCO était pris en charge dans _APRES_CHOI.
#########################################################################
$OBJ_ABANDON
 If ((REPONSE=GSTAEND)  & (dim(NUMACT)>0)) # Abandon ou fin et traces d'une action métier
  Gosub NETTOYER
  If dim(ACTMODIF)>0 : Kill ACTMODIF : Endif
  Kill NUMACT
  Gosub KILL_CONSTANTES From TRCPROCOM                      #=> Destruction des constantes
  Gosub KILL_GLOBALES From TRCPROCOM
 Endif
Return

#########################################################################
$OBJ_AVANT_MODFIC
 # Pendant la transaction de mise à jour de l'objet, on teste la présence de
 # la globale NUMACT :
 #  1 -> Elle est là, on déclenche les automatismes de maj à partir des tables temporaires
 #  2 -> Elle est pas là, on ne fait rien

If dim(ACTMODIF)>0
  Local Char    MES(255)
  Local Integer ERR
  Call REPORTER(NUMACT,TABOBJ,MES,ERR) From TRCPROCOM
  If ERR
   # Erreur : Qu'est-ce qu'on fait ?
   Infbox "Error subprog REPORTER"-num$(ERR)
  Endif
  If GUSER=USRDBG : Infbox "APRèS REPORTER"-MES-"GOK"-num$(GOK) : Endif
    # Vérification des locks sur les éléments physiques rattachés dans le cas d'une sortie de bien
    ACTMET="VERIF_ELT_PHY" : Gosub ACTMET From TRCPROCOM         # Vérification des locks sur les élts phy
#Fq-67621     If GOK=0 Then : End : Endif
 Endif

Return

#########################################################################
$OBJ_APRES_MOD
 # Après la transaction de mise à jour, tous s'est bien passé
 # 1 - On appel le calcul
 #
 # 2 - On nettoie les traces de l'action métier si le NUMACT est là bien sûr

 If dim(NUMACT)>0
  If dim(ACALCULER)>0
   Call PARAM([M]CPY,"CALAUTVAL", ACALCULER) From ADOVAL
   If ACALCULER="2"
    Gosub CALCULER                                      #=> Calcul des composants et complémentaires
   Endif
  Endif
  Gosub NETTOYER
  Kill ACTMODIF
  Kill NUMACT
  Gosub KILL_CONSTANTES From TRCPROCOM                 #=> Destruction des constantes
  Gosub KILL_GLOBALES From TRCPROCOM
 Endif

Return

#########################################################################
$OBJ_AB_MODIF
 # Après la transaction de mise à jour, on s'est planté
 # Il faut donc nettoyer les traces de l'action
 #If dim(NUMACT)>0
 # Gosub NETTOYER
 # Kill ACTMODIF
 # Kill NUMACT
 # Gosub KILL_CONSTANTES From TRCPROCOM                 #=> Destruction des constantes
 # Gosub KILL_GLOBALES From TRCPROCOM
 #Endif
 # En fait, pas la peine de faire tous ça car, si on doit pouvoir rééssayer d'enregsitrer.
 # Si ça se plante une première fois, on doit donc conserver tous le contexte permettant
 # de réenregistrer. Le nettoyage se fait de toute façon si on clique sur abandon ou sur fin
Return

#########################################################################
$ACT_OUVRE
 #Infbox "Declarations - initialisations / traitements unitaires" # tst
 Global Integer ACTMODIF     #=> Globale permettant de savoir si des modifs sont à reporter.

 #Gbn-061005-Fq 32457-Biens en cours de CIG ?
 If ACTREFOBJ="FAS"
  Local Integer BCO_ACTIF
  Call TEST_BIEN_ACTIF([M:FAS0]AASREF, BCO_ACTIF) From GLOBIENS
  If BCO_ACTIF = G_NON
   GERR     = 1
   #***Fq-36248 GMESSAGE = mess(505,7773,1)
   GMESSAGE = mess(536,7773,1)
   FIN      = 1
  Endif
 Endif

 If ACTREFOBJ="PHY"
  Local Integer BCO_ACTIF
  Call TEST_BIEN_ACTIF([M:PHY0]AASREF, BCO_ACTIF) From GLOBIENS
  If BCO_ACTIF = G_NON
   GERR     = 1
   #***Fq-36248 GMESSAGE = mess(505,403,1)
   GMESSAGE = mess(89,7775,1) # Action interdite car cet élément a été sorti par une opération de cession intra-groupe
   FIN      = 1
  Endif
 Endif
Return

#########################################################################
$ACT_DEBUT

#=> Alimentation des zones et des libellés du masque en-tête de l'action unitaire .

 Case ACTREFOBJ  # On alimente l'en-tête en fonction du type d'objet métier traité fourni par TMPOBJ
  When "LOF"
   Chgtbk [M:OAC0]5     With mess(GVML_OMDEPEN,3141,1)           #"Dépense"
   If dim([M:LOF0]CODLOF)>0  : [M:OAC0]OBJREF=[M:LOF0]CODLOF  : Endif
   If dim([M:LOF0]LINLOF)>0
    If dim([M:OAC0]OBJLIN)>0 : [M:OAC0]OBJLIN=[M:LOF0]LINLOF  : Endif
   Endif
   If dim([M:LOF0]DES)>0     : [M:OAC0]OBJDES=[M:LOF0]DES     : Endif
   If dim([M:LOF0]CPY)>0     : [M:OAC0]OBJCPY=[M:LOF0]CPY     : Endif
 When "FAS"
   Chgtbk [M:OAC0]5     With mess(GVML_OMBIEN,3141,1)            #"Bien comptable"
   If dim([M:FAS0]AASREF)>0  : [M:OAC0]OBJREF=[M:FAS0]AASREF  : Endif
   If dim([M:FAS0]AASDES1)>0 : [M:OAC0]OBJDES=[M:FAS0]AASDES1 : Endif
   If dim([M:FAS0]CPY)>0     : [M:OAC0]OBJCPY=[M:FAS0]CPY     : Endif
  When "LEA"
   Chgtbk [M:OAC0]5     With mess(GVML_OMLOCFI,3141,1)           #"Contrat de Location financement"
   If dim([M:LEA0]LEAREF)>0  : [M:OAC0]OBJREF=[M:LEA0]LEAREF  : Endif
   If dim([M:LEA0]LEADES)>0  : [M:OAC0]OBJDES=[M:LEA0]LEADES  : Endif
   If dim([M:LEA0]CPY)>0     : [M:OAC0]OBJCPY=[M:LEA0]CPY     : Endif
  When "PHY"
   Chgtbk [M:OAC0]5     With mess(GVMLOMPHY,3141,1)              #"Elément physique"
   If dim([M:PHY0]PHYREF)>0  : [M:OAC0]OBJREF=[M:PHY0]PHYREF  : Endif
   If dim([M:PHY0]PHYDES1)>0 : [M:OAC0]OBJDES=[M:PHY0]PHYDES1 : Endif
   If dim([M:PHY0]CPY)>0     : [M:OAC0]OBJCPY=[M:PHY0]CPY     : Endif
  When Default
 Endcase

 ACTMET="FILL_HEA" : Gosub ACTMET From TRCPROCOM

#=> Alimentation du critère de sélection CRITOBJ (Valable pour toutes les actions d'un objet métier)

 Gosub SET_CRITERE

#=> Si le paramètre PRECHARGE est à G_OUI, on charge la population ici

 If PRECHARGE=G_OUI
  Local Integer ERR         # Code erreur retourné par les sous-programmes de traitement de la population
  Local Char    MES(255)    # Message retourné par les sous-programmes de traitement de la population
  Gosub LOCKER_POPULATION   # Locke la population sélectionnée
  Gosub CHARGER_POPULATION  # Charge le population sélectionnée dans les tables temporaires
 Endif

Return

#########################################################################
$ACT_SETBOUT

 Call VIREBOUT (CHMEN,"ABC") From GOBJET

 # Si la population est en table temporaire et que les paramètres n'ont pas été appliqués : "Ok" interdit
#If ACTSTATUS=STA_TEMP
# If ACTSTATUS=STA_TEMP
#  If ( dim(CHBOU)>0 ) Then : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
# Endif

Return

#########################################################################
$ACT_BOUTON

 Local Integer ERR         # Code erreur retourné par les sous-programmes de traitement de la population
 Local Char    MES(255)    # Message retourné par les sous-programmes de traitement de la population

If (ACTMETNAM="FASTEST") | (ACTMETNAM="FASRVA") | (ACTMETNAM="FASMTC") | (ACTMETNAM="FASTRFC") | (ACTMETNAM="FASCCN")
& |(ACTMETNAM="FASTRF")  | (ACTMETNAM="FASIML") | (ACTMETNAM="FASISS") | (ACTMETNAM="FASVATREG")
& |(ACTMETNAM="PHYTRF")  | (ACTMETNAM="PHYISS") | (ACTMETNAM="FASVATRGG")

 Case BOUT
  When "D"
   Gosub CONTROLER
  When Default
 Endcase

Else                       # Tst évolution cf CRR 19/03/2004

 Case BOUT
  When "A"
   If GUSER=USRDBG : Infbox "Sélectionner"   : Endif            # tst
   Gosub SET_CRITERE
  #Gosub AFF_CRITERE From TRCPROCOM    # tst
   Gosub LOCKER_POPULATION
   Gosub CHARGER_POPULATION
  When "B"
   If GUSER=USRDBG : Infbox "Appliquer"      : Endif            # tst
   Gosub APPLIQUER_MODIF
  When "C"
   If GUSER=USRDBG : Infbox "Ajuster"        : Endif            # tst
   Call VISUALISER() From TRCPROCOM
  When Default
 Endcase

Endif                      # Tst évolution cf CRR 19/03/2004

Return

#########################################################################
$ACT_AP_CHOIX

 # On clique sur OK. Si le bouton Contrôler a déjà été actionné, on fait
 # le reporter uniquement. Si le bouton Contrôler n'a pas déjà été actionné
 # le ACTSTATUS est de toute façon inférieur ou égal à STA_TEMP. Dans ce cas
 # si PRECHARGE = G_NON, on exécute le Sélectionner puis le Appliquer.
 # NB : on ouvre une trace dans le appliquer, si des erreurs se produisent
 # dans les étiquette TMP1_APPL_TMP1 et TPF1_APPL_TPF1, possibilité d'y
 # écrire les erreurs. Elle n'est ouverte que s'il y a des erreurs. Dans
 # ce cas, on reste sur la fenêtre et on exécute le bouton abandon.
 # Si pas d'erreur, on exécute Report_mask.

 Local Integer ERR         # Code erreur retourné par les sous-programmes de traitement de la population
 Local Char    MES(255)    # Message retourné par les sous-programmes de traitement de la population

 If REPONSE=GSTAOK

  If PRECHARGE=G_NON
   If ACTSTATUS=STA_DEBUT
    If GUSER=USRDBG : Infbox "Sélectionner" : Endif            # Tst
    Gosub SET_CRITERE                                          #=> Construction des critères de sélection
    Gosub LOCKER_POPULATION                                    #=> Lock des éléments de la population
   Endif
   If ACTSTATUS>=STA_LOCK & ACTSTATUS < STA_TEMP
    If GUSER=USRDBG : Infbox "Charger"      : Endif            # Tst
    Gosub SET_CRITERE
    Gosub CHARGER_POPULATION                                   #=> Chargement de la population dans les tables temporaires
   Endif
  Endif

  If ACTSTATUS>=STA_TEMP & ACTSTATUS<STA_MODIF
   If GUSER=USRDBG : Infbox "Appliquer"     : Endif            # Tst
   Gosub SET_CRITERE
   Call OUVRE_TRACE("Test action unitaire") From LECFIC
   Gosub APPLIQUER_MODIF                                      #=> Application des paramètres de l'action
   Call FERME_TRACE From LECFIC
   If ERR=99
    Call SUPP_TRACE From LECFIC
#Gbn-300605-Fq
#   REPONSE=GSTAFIN
    REPONSE=GSTAEND
    Global Integer GABAERR
    Return
   Endif
  Endif

 Endif

Return

#########################################################################
ACT_APRES_MODIF
 #GBN-14082004-Bug 24577
 REP="M"
Return

#########################################################################
$ACT_OK

 # Sortie de la fenêtre en cliquant sur OK. Il faut reporter les infos
 # de l'objet en cours dans ses masques. Peut se faire à partir de
 # l'enregistrement créé dans la table temporaire ou des zones de la fenêtre
 # s'il s'agir d'une action ne portant que sur l'objet en cours et qui n'a pas
 # de correspondance massive (Dans ce dernier cas, il suffit de ne pas appeler.
 # les traitements du modèle unitaire).

 Gosub REPORTER_MASK

Return

#########################################################################
$ACT_ABA
 REP=""
Return

#########################################################################
$ACT_END
 # Exécutée chaque fois que l'on sort de la fenêtre de l'action par (Fin)
Return

#########################################################################
$ACT_FIN
 # Exécutée chaque fois que l'on sort de la fenêtre (sur OK ou sur Fin)
Return


##########################################################################
## Sous-programmes et routines
##########################################################################

#Gbn-110205-Bug n° 28495 - Sauvegardes des globales liées aux actions métier si tunnel
#Gbn-210205-Bug n° 28613 - La sauvegarde et la restauration sont conditionnées par l'existence de ces globales
#========================================================================
$SAUVE_GLOB_TUNNEL

 If dim(LIS_ACT)>0
  Local Integer I
  For I=1 To 20
   GSV_LIS_ACT(I-1)=LIS_ACT(I-1)
   GSV_LIS_NAM(I-1)=LIS_NAM(I-1)
   GSV_LIS_TYP(I-1)=LIS_TYP(I-1)
  Next I
  GEXISTLISACT=G_OUI
 Else
  GEXISTLISACT=G_NON
 Endif

 If dim(G_TRSSAV)>0
  GSV_G_TRSSAV=G_TRSSAV
  GEXISTTRSSAV=G_OUI
 Else
  GEXISTTRSSAV=G_NON
 Endif

Return

#========================================================================
$RESTAURE_GLOB_TUNNEL

 If GEXISTLISACT=G_OUI
  Global Char LIS_ACT(1)(20)
  Global Char LIS_NAM(15)(20)
  Global Char LIS_TYP(1)(20)
  Local Integer I
  For I=1 To 20
   LIS_ACT(I-1)=GSV_LIS_ACT(I-1)
   LIS_NAM(I-1)=GSV_LIS_NAM(I-1)
   LIS_TYP(I-1)=GSV_LIS_TYP(I-1)
  Next I
 Endif

 If GEXISTTRSSAV=G_OUI
  Global Char G_TRSSAV
  G_TRSSAV=GSV_G_TRSSAV
 Endif

Return

#========================================================================
$LOCKER_POPULATION

 #-> Alimentation du numéro de traitement

 Gosub SET_TRTNUM From TRCPROCOM

 #-> Locke de la population

 Call LOCKER(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRCPROCOM
 If ERR=0
  ACTSTATUS=STA_LOCK
  If GUSER=USRDBG : Infbox "ACTSTATUS"-num$(ACTSTATUS) : Endif    # tst
 Else
  # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p LOCKER"+"\"+MES
  Call ERREUR(mess(114,GML_MSGTRC,1) -num$(ERR)-mess(115,GML_MSGTRC,1) +"\"+MES) From GESECRAN  # Erreur, on affiche à l'écran et on nettoie tout
  Gosub NETTOYER
 Endif

Return

#========================================================================
$CHARGER_POPULATION

 Call CHARGER(CRITSUPR,CRITOBJ,CRITACT,CRITSUP1,TABOBJ,MES,ERR) From TRCPROCOM
 If ERR=0
  ACTSTATUS=STA_TEMP                             # On fait progresser le Status de l'action
  If GUSER=USRDBG : Infbox "ACTSTATUS"-num$(ACTSTATUS) : Endif   # tst
 Else
  # FQ83184 "Erreur n°"-num$(ERR)-"dans le s/p CHARGER"+"\"+MES
  Call ERREUR(mess(114,GML_MSGTRC,1)-num$(ERR)-mess(116,GML_MSGTRC,1)+"\"+MES) From GESECRAN # Erreur
  Gosub NETTOYER
  ACTSTATUS=STA_DEBUT
 Endif

Return

#========================================================================
$APPLIQUER_MODIF

 # effectuer un call au s/p APPLIQUE_TEMP (TRCPROCOM)
 # En fonction du résultat du s/p positionner la variable ACTSTATUS

 Call APPLIQUE_TEMP(NUMACT,TMPTAB,TMPTABPLN,MES,ERR) From TRCPROCOM
 If ERR=0
  ACTSTATUS=STA_MODIF
   If GUSER=USRDBG : Infbox "ACTSTATUS"-num$(ACTSTATUS) : Endif # tst
 Elsif ERR=99
  # Erreur fonctionnelle -> Le traitement de l'affichage est pris en charge par le s/p APPLIQUE_TEMP()
 Else
  # FQ83184 "Erreur dans le sous-programme APPLIQUE_TEMP"-"\"-num$(ERR)-MES
  Call ERREUR(mess(117,GML_MSGTRC,1)-"\"-num$(ERR)-MES) From GESECRAN # Erreur
  Gosub NETTOYER
  ACTSTATUS=STA_DEBUT
 Endif

Return

#========================================================================
$CONTROLER

If PRECHARGE=G_NON

  If ACTSTATUS=STA_DEBUT
   If GUSER=USRDBG : Infbox "Sélectionner" : Endif            # Tst
   Gosub SET_CRITERE                                          #=> Construction des critères de sélection
   Gosub LOCKER_POPULATION                                    #=> Lock des éléments de la population
  Endif

  If ACTSTATUS>=STA_LOCK & ACTSTATUS < STA_TEMP
   If GUSER=USRDBG : Infbox "Charger" : Endif                 # Tst
   Gosub SET_CRITERE
   Gosub CHARGER_POPULATION                                   #=> Chargement de la population dans les tables temporaires
  Endif

Endif

  If ACTSTATUS>=STA_TEMP
   If GUSER=USRDBG : Infbox "Appliquer" : Endif               # tst
   Gosub SET_CRITERE
   Gosub APPLIQUER_MODIF                                      #=> Application des paramètres de l'action
  Endif

  If ACTSTATUS>=STA_MODIF
   If GUSER=USRDBG : Infbox "Ajuster" : Endif                 # tst
   Call VISUALISER() From TRCPROCOM                           #=> OUVERTURE de l'objet de reprise
  Endif

Return

#========================================================================
$REPORTER_MASK

 # effectuer un Call au s/p REPORT_MASK (TRCPROCOM) s'il y eu des modifs sur
 # au moins un objet.
 If ACTMODIF=1 | ACTSTATUS=STA_MODIF
  Call REPORT_MASK(NUMACT,TMPTAB,TMPTABPLN,MES,ERR) From TRCPROCOM
 Endif

Return

#========================================================================
$SET_CRITERE

 #=> CRITOBJ

  Case ACTREFOBJ
   When "FAS"   : CRITOBJ='AASREF="'+[M:OAC0]OBJREF+'"'
   When "LOF"   : CRITOBJ='CODLOF="'+[M:OAC0]OBJREF+'" & LINLOF="'+[M:OAC0]OBJLIN+'"'
   When "LEA"   : CRITOBJ='LEAREF="'+[M:OAC0]OBJREF+'"'
   When "PHY"   : CRITOBJ='PHYREF="'+[M:OAC0]OBJREF+'"'
   When Default : CRITOBJ='1=1'
  Endcase

Return

#========================================================================
$NETTOYER

 Local Integer NBDLREC,ERR
 Local Char    MES

 Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM         #=> Nettoyage la table temporaire principale
 If GUSER=USRDBG : Infbox "NBR enr supprimés dans "-TMPTAB-"/"-num$(NBDLREC) : Endif # Tst
 If ACTGESPLN=G_OUI
  Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM     #=> Nettoyage de la table temporaire par plan
  If GUSER=USRDBG : Infbox "Nbr enr supprimés dans "-TMPTABPLN-"/"-num$(NBDLREC) : Endif # Tst
 Endif
 Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM                 #=> Suppression des locks posés pendant l'action

Return

$CALCULER
 If !clalev([F:TMP1]) : Local File TMPMASFAS [TMP1] : Endif
 If !clalev([F:FASU]) : Local File FXDASSETS [FASU] : Endif
 Filter [TMP1] Where TRTNUM=NUMACT
 For [TMP1]
  If [F:TMP1]OBJREF<>[F:FAS]AASREF
    Call CALCULER_BIEN ([F:TMP1]CPY, [F:TMP1]OBJREF, ERROR) From GLOBB
  Endif
 Next
 Filter [TMP1]
Return


#========================================================================
$AFF_LISTE

#==> Pour développement, affichage du résultat
 Local Integer I_ACT
 Local Char    MESBOITE(255)
 For I_ACT=0 To dim(LIS_ACT)-1
  MESBOITE+=LIS_ACT(I_ACT)+'-'+LIS_NAM(I_ACT)+'-'+LIS_TYP(I_ACT)+"/"
 Next I_ACT
 Infbox MESBOITE
#==> Pour développement, affichage du résultat (Fin)

Return

#===========================================
# Récupération des boutons de la fenêtre   #
#===========================================

Subprog GET_WIN_BOUT(PWIN,PTAB_ACT,PTAB_NAM,PTAB_TYP,PRET)
Value    Char PWIN           # Code de la fenêtre courante
Value    Char PTAB_ACT()()   # Liste des codes boutons des actions métier
Variable Char PTAB_NAM()()   # Liste des nom des action métiers associées aux boutons
Variable Char PTAB_TYP()()   # Type de déclencheur - Menu ou Bouton.

Local Integer I_BOUT
Local Integer CDRET

For I_BOUT=0 To dim(PTAB_ACT)-1
  If PTAB_ACT(I_BOUT)="" : Break : Endif
  If PTAB_NAM(I_BOUT)=""
   Call GET_ACTINF(PTAB_ACT(I_BOUT),PTAB_NAM(I_BOUT),PTAB_TYP(I_BOUT),CDRET) From TRTOBJACT
  Endif
Next I_BOUT

End


#===========================================
# Correspondance code bouton -> Action     #
#===========================================

Subprog GET_ACTINF(PCOD,PVAL,PTYP,PRET)
Value    Char    PCOD   # Code BOUTON
Variable Char    PVAL() # Zone banalisé de retour de valeur
Variable Char    PTYP() # Type de bouton (Bouton / Menu / Ligne)
Variable Integer PRET   # Code retour

 Local Char    ACTNAM : Raz ACTNAM # Nom de l'action associé au code bouton
 Local Char    WINNAM : Raz WINNAM # Nom de la fenêtre associée à l'action
 Local Integer BOUTYP : Raz BOUTYP # Type de bouton (Bouton / Menu / Ligne)

 # Correspondance entre le code menu et l'action associée
 If !(clalev([F:AWT])) : Local File AWINBOUT [AWT] : Endif
 Filter [AWT] Where WIN=GBOITE
 For [AWT]
  If right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT))=PCOD
   ACTNAM=[F:AWT]ACTBOUT
   BOUTYP=[F:AWT]TYPBOUT
   Break
  Endif
 Next
 Filter [AWT]

 If ACTNAM=""
  PRET=1 # Erreur
  End
 Else
  PVAL=ACTNAM
  Case BOUTYP
   When 1 : PTYP="B"
   When 3 : PTYP="M"
   When Default
  Endcase
  End
 Endif
End
