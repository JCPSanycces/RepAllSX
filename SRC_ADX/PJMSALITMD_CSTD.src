#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMSALITMD
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                          : Gosub ACONTROL                        From PJMSALITMD_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"            : Gosub AINSERT_CONTROL_BEFORE          From PJMSALITMD_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"            : Gosub AUPDATE_CONTROL_BEFORE          From PJMSALITMD_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"            : Gosub ADELETE_CONTROL_BEFORE          From PJMSALITMD_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                              : Gosub SETERROR                        From PJMSALITMD_CSTD_METHODS
    When "SALES_DOC_EXIST"                       : Gosub SALES_DOC_EXIST                 From PJMSALITMD_CSTD_METHODS
    When "UOM_CONTROL"                           : Gosub UOM_CONTROL                     From PJMSALITMD_CSTD_METHODS
    When "QTY_CONVERT"                           : Gosub QTY_CONVERT                     From PJMSALITMD_CSTD_METHODS
    When "GET_SPLD_KEYCONCAT"                    : Gosub GET_SPLD_KEYCONCAT              From PJMSALITMD_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "TCHACTION"                             : Gosub TCHACTION                       From PJMSALITMD_CSTD_PROPERTIES
    When "ORI"                                   : Gosub ORI                             From PJMSALITMD_CSTD_PROPERTIES
    When "ITMREF"                                : Gosub ITMREF                          From PJMSALITMD_CSTD_PROPERTIES
    When "ECCVALMAJ"                             : Gosub ECCVALMAJ                       From PJMSALITMD_CSTD_PROPERTIES
    When "ITMDES"                                : Gosub ITMDES                          From PJMSALITMD_CSTD_PROPERTIES
    When "SAU"                                   : Gosub SAU                             From PJMSALITMD_CSTD_PROPERTIES
    When "QTY"                                   : Gosub QTY                             From PJMSALITMD_CSTD_PROPERTIES
    When "STU"                                   : Gosub STU                             From PJMSALITMD_CSTD_PROPERTIES
    When "QTYSTU"                                : Gosub QTYSTU                          From PJMSALITMD_CSTD_PROPERTIES
    When "BASPRI"                                : Gosub BASPRI                          From PJMSALITMD_CSTD_PROPERTIES
    When "PRODGRPLVL"                            : Gosub PRODGRPLVL                      From PJMSALITMD_CSTD_PROPERTIES
    When "PSONUM"                                : Gosub PSONUM                          From PJMSALITMD_CSTD_PROPERTIES
    When "PSOLIN"                                : Gosub PSOLIN                          From PJMSALITMD_CSTD_PROPERTIES
    When "KEYCONCAT"                             : Gosub KEYCONCAT                       From PJMSALITMD_CSTD_PROPERTIES
  Endcase
Return

