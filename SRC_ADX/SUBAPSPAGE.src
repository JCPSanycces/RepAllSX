#<AdxTL>@(#)7.0.0.0 $Revision$
#Local Char CL
#Call SELECT("AP1","A",CL,"") From SELOBJA
#End
Local Char AURL(250)
Local Integer AFLGREL    # 1 si adresse relative portail
GPTLPAGE="WEB"
Call CNXTPTLURL(AURL, AFLGREL)
Infbox "AURL:"-AURL-"  AFLGREL    :"-num$(AFLGREL)
End

# ------------------------------------------------------------
# SUBAPSPAGE
# Version: 0002
#      
# $P_EXECUTE
#      Serveur de page du portail
#        M_FONCTION        Code de la fonction serveur de page
#        M_ACTION          Code de l'action à traiter
#
# CNXTPTLURL    ss-prgrm renvoyant l'Url portail à la connexion
# ------------------------------------------------------------
#  E39415 : CNXTPTLURL- Les Url contenant 'File:' ne sont pas en relatif

# ------------------------------------------------------------
$P_EXECUTE                         # Init + type de dialogue
    # Trace
    U_TRAMES="--> Debut: " + "Serveur de page du portail": Gosub U_TRAPUT From SUBAPSUTI 
    
    # init
    Gosub P_INIT

    # Action demandée 
    Case M_ACTION
    When "FIRST"
        P_PAGECODE=GPTLPAGE    # Paramètre global utilisateur
        # Lecture objet
        #If clalev([F:APS])  = 0 : Local File APTLPAGE   [APS]  : Endif # solution de replie
        #Call LECTURE(PC_PAGOBJ,P_PAGECODE ,"")From CONTOBJ
        #If fstat <> 0
        #    U_TRAMES="Page par defaut: " + PC_PAGEDEF
        #    P_PAGECODE=PC_PAGEDEF
        #Endif
    When "GET"
        U_QSCODE=PQ_PAGECODE : Gosub U_QSREAD_UC From SUBAPSUTI
        P_PAGECODE=U_QSVAL
    When Default
        U_MESCODE="X3ACTUNKNOWN" : U_MESP1=M_FONCTION : U_MESP2=M_ACTION : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endcase

    Gosub P_EXE    # traitement

    # Trace
    U_TRAMES="--> Fin: " + "Serveur de page du portail": Gosub U_TRAPUT From SUBAPSUTI 
Return


  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# 
# - - - - - - - - - - - - - - - - - -
$P_EXE
    # trace en zone technique
    U_TECMES= P_PAGECODE : Gosub U_TECPUTCODE From SUBAPSUTI : If U_ERR=UC_ERRG : Return : Endif
    # Lecture objet
    If clalev([F:APS])  = 0 : Local File APTLPAGE   [APS]  : Endif
    Call LECTURE(PC_PAGOBJ,P_PAGECODE ,"")From CONTOBJ
    If fstat <> 0
        U_MESCODE="X3PAGEUNKNOWN" : U_MESP1=P_PAGECODE : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endif

    # Fichier séquentiel à partir d'un source
    Gosub $SET_HTML From SUBAPSHTML
    If U_ERR : Return : Endif    

    # ouverture CDATA et entete Html  - En cas d'erreur faire P_ERR et non pas return
    If fstat=0    
        U_SEQPUT=' <X3HTML><![CDATA[' : Gosub U_PUT From SUBAPSUTI
    Endif
    # Boucle
    For P_HTMLLINE=0 To P_SRCNB                       
        P_TMPLLIG=P_SRC(P_HTMLLINE)
        UW_I=instr(0,P_TMPLLIG,PC_HEADCMTID)
        If UW_I
            U_SEQPUT=left$(P_TMPLLIG, UW_I-1) + "PAGECODE: " +P_PAGECODE + right$(P_TMPLLIG, UW_I + len(PC_HEADCMTID) ) : Gosub U_PUT From SUBAPSUTI  
            Goto NEXTLINE
        Endif
        PW_IFR=instr(0,P_TMPLLIG,PC_FRAMEIDENT)
        If PW_IFR
            Onerrgo P_ERRFRAME
            P_FRAMENUM=val(mid$(P_TMPLLIG, PW_IFR+len(PC_FRAMEIDENT), 1))
            Onerrgo : If U_ERR : Return : Endif
            U_VIEWCODE=[F:APS]APSVW(P_FRAMENUM-1)    # code vue
            If U_VIEWCODE <> "" Then     # Lié à une vue
                # Recherche de la vue
                Call LECTURE(UC_VIEWOBJ,U_VIEWCODE ,"")From CONTOBJ
                If fstat <> 0
                    U_MESCODE="X3VIEWUNKNOWN" : U_MESP1=U_VIEWCODE : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto P_ERR
                Endif
                # Suivant le type source de données
                #  nota: [F:APV]SRCCODTYP
                #     "MLT"        Browser
                #     "REQ"        Requete
                #     "REQS"        Requete Sql
                #     "STA"        Statistique
                #     "CNS"        Consultation
                #     "WEB"        Page web 
                #  nota: L'inclusion d'une page portail passerait par la saisie du code de la page voulue
                #            dans la page portail maitresse (nelle rubrique)  
                Case [F:APV]SRCCODTYP
                When "REQ","STA","MLT","TRT","AGD", "CNS", "REQS"     #E27096 Sql         
                    # Recherche du paramétrage composant visuel
                    P_PARCODE=[F:APV]CMPCODTYP
                    Call LECTURE(PC_PAROBJ,P_PARCODE ,"2")From CONTOBJ
                    If fstat <> 0
                        U_MESCODE="X3PARUNKNOWN" : U_MESP1="2" : U_MESP2=P_PARCODE : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto P_ERR
                    Endif
                    # recherche source lié au composant pour obtenir l'adresse Html
                    PW_I=find([F:APV]SRCCODTYP, [F:APP]SRCCODLNK)    
                    P_SRCURL=""
                    If !PW_I=0 : P_SRCURL=[F:APP]CMPURL(PW_I-1) :ENDIF
                    U_SEQPUT=left$(P_TMPLLIG, PW_IFR-1) + ' ID="' + P_PAGECODE + '_X3FRAME-' + num$(P_FRAMENUM) + '"' : Gosub U_PUT From SUBAPSUTI    # debut
                    U_SEQPUT=' PVIEWCODE="' + U_VIEWCODE + '" ' : Gosub U_PUT From SUBAPSUTI    # URL
                    U_SEQPUT=' SRC="' + P_SRCURL + '"' : Gosub U_PUT From SUBAPSUTI    # Source initial
                    U_SEQPUT=PC_FRAMEPAR: Gosub U_PUT From SUBAPSUTI    # paramètre frame
                    U_SEQPUT=right$(P_TMPLLIG, PW_IFR + len(PC_FRAMEIDENT) +1) : Gosub U_PUT From SUBAPSUTI    # fin
                When "WEB"        # Page web issue d'une vue
                    Raz [F:APP], P_SRCURL
                    U_PARCODE="URL" : U_CTXFOR=mess(40,137,1)-U_VIEWCODE-mess(41,137,1)-U_PARCODE  # code para, contexte 
                    Gosub U_PARSRCREAD From SUBAPSUTI   # lecture
                    If U_ERR=UC_ERRG : Goto P_ERR : Endif
                    U_SEQPUT=left$(P_TMPLLIG, PW_IFR-1) + ' ID="' + P_PAGECODE + '_X3FRAME-' + num$(P_FRAMENUM) + '"' : Gosub U_PUT From SUBAPSUTI    # debut
                    U_SEQPUT=' SRC="' + U_PARVAL + '" ' : Gosub U_PUT From SUBAPSUTI    # URL
                    U_SEQPUT=PC_FRAMEPAR: Gosub U_PUT From SUBAPSUTI    # paramètre frame
                    U_SEQPUT=right$(P_TMPLLIG, PW_IFR + len(PC_FRAMEIDENT) +1) : Gosub U_PUT From SUBAPSUTI    # fin
                When Default
                    U_MESCODE="X3VIEWSRCTYPUNKNOWN" : U_MESP1=U_VIEWCODE : U_MESP2=[F:APV]SRCCODTYP : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Goto P_ERR
                Endcase

                #  Garder pour info: Page Portail incluse
                 #   U_SEQPUT=left$(P_TMPLLIG, PW_IFR-1) + ' ID="X3PORTALPAGE"' : Gosub U_PUT From SUBAPSUTI    # debut
                 #   U_SEQPUT=' PAGECODE="' + [F:APV]SRCCOD(P_FRAMENUM-1) + '" ' : Gosub U_PUT From SUBAPSUTI    # URL
                 #   PW_STR1='behavior:url(".\PortalPage\X3PortalPage.htc")'
                 #   U_SEQPUT=" STYLE='" + PW_STR1 + "' " : Gosub U_PUT From SUBAPSUTI  
                 #   U_SEQPUT=' SRC=".\Ressources\InitPage.gif"' : Gosub U_PUT From SUBAPSUTI    # Source initial
                 #   U_SEQPUT=right$(P_TMPLLIG, PW_IFR + len(PC_FRAMEIDENT) +1) : Gosub U_PUT From SUBAPSUTI    # fin
            Else        # lien type URL   
                U_SEQPUT=left$(P_TMPLLIG, PW_IFR-1) + ' ID="' + P_PAGECODE + '_X3FRAME-' + num$(P_FRAMENUM) + '"' : Gosub U_PUT From SUBAPSUTI    # debut
                U_SEQPUT=' SRC="' + [F:APS]APSURL(P_FRAMENUM-1) + '" ' : Gosub U_PUT From SUBAPSUTI    # URL
                U_SEQPUT=PC_FRAMEPAR: Gosub U_PUT From SUBAPSUTI    # paramètre frame
                U_SEQPUT=right$(P_TMPLLIG, PW_IFR + len(PC_FRAMEIDENT) +1) : Gosub U_PUT From SUBAPSUTI    # fin
            Endif
            Goto NEXTLINE
        Endif            
           # ligne standard
            U_SEQPUT=P_TMPLLIG : Gosub U_PUT From SUBAPSUTI

$NEXTLINE
    Next           

$P_ERR
    # fermeture CDATA
    U_SEQPUT=' ]]></X3HTML>' : Gosub U_PUT From SUBAPSUTI
Return

$P_ERROPENO
    Onerrgo # Eviter boucle si erreur dans la suite
    adxirs=P_SVADXIRS : adxifs=P_SVADXIFS
    U_MESCODE="X3FILEOPEN" : U_MESP1=P_FULLTMPLNAME : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT  From SUBAPSUTI
    # nota: return fait par   Onerrgo : If U_ERR : Return : Endif
    Resume
Return

$P_ERRFRAME
    Onerrgo # Eviter boucle si erreur dans la suite
    adxirs=P_SVADXIRS : adxifs=P_SVADXIFS
    U_MESCODE="X3FRAMENBNUM" : U_MESP1=P_TMPLLIG : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT  From SUBAPSUTI
    Resume
Return


# Variables
# - - - - - - - - - - - - - - - - - -
$P_INIT
    Local Char P_PAGECODE    # Code page
    Local Char PC_PAGOBJ : PC_PAGOBJ="APS"                    # Objet X3 de gestion des pages
    Local Char PQ_PAGECODE : PQ_PAGECODE = "PAGECODE"         # Code de la page demandée dans la QS
    Local Char PC_PAGEDEF : PC_PAGEDEF = "ADONIX"             # code de la pge par défaut
    # paramétres portail
    Local Char P_PARCODE    # Code vue
    Local Char PC_PAROBJ : PC_PAROBJ="APP"                    # Objet X3 de gestion
    If clalev([F:APP])  = 0 : Local File APTLPAR [APP]  : Endif
    Local Char P_SRCURL (200)                                 # Url de la page à charger dans le frame
    # sauvegarde para seq
    Local Char PC_ADXIFS(1), PC_ADXIRS(2) : PC_ADXIFS="" : PC_ADXIRS= chr$(13)+chr$(10)
    Local Char P_SVADXIRS , P_SVADXIFS
    # Gestion Template (Html)
    Local Char P_TMPLLIG (250)                                # ligne du squelette Html
    Local Char P_WDATA (250)                                  # zone de travail
    Local Char PC_HEADCMTID : PC_HEADCMTID="$*HEADCMT"        # identifiant commentaire sur tag HEAD
    Local Char PC_FRAMEIDENT : PC_FRAMEIDENT="$*FRAME"        # identifiant attribut source d'un frame
    Local Integer P_FRAMENUM                                  # numéro du frame
    Local Integer P_HTMLLINE                                  # numéro de la ligne html
    Local Char PC_FRAMEPAR (70)                               # paramtres sur tag frame
    PC_FRAMEPAR='Class="X3Class" frameborder=NO marginwidth=8 marginheight=8'

    # travail
    Local Char PW_STR1(200)
    Local Integer PW_I,PW_IFR

Return

# CNXTPTLURL    ss-prgrm renvoyant l'Url portail à la connexion
# ------------------------------------------------------------
Subprog CNXTPTLURL(AURL, AFLGREL)
Variable Char AURL
Variable Integer AFLGREL    # 1 si adresse relative portail

# Cstes  (nota: non utilisation des routines portail pour gain de temps)
Local Char PC_PAGOBJ : PC_PAGOBJ="APS"                            # Objet X3 de gestion des pages
Local Char UC_VIEWOBJ : UC_VIEWOBJ="APV"                          # Objet vue
Local Char PC_DEFURL (100) : PC_DEFURL="PortalStartCSF.htm"      # Url par defaut du portail

# AURL peut être préchargé par INTRUTILA
If AURL="" : AURL=PC_DEFURL : Endif  # valeur par défaut

#  Bug 37437  : Pas d'envoi de page en direct on passe par le portail
AFLGREL=1
End


# Lecture objet
If clalev([F:APS])  = 0 : Local File APTLPAGE   [APS]  : Endif
Call LECTURE(PC_PAGOBJ,GPTLPAGE ,"")From CONTOBJ
If fstat = 0
    If [F:APS]APSPRE=1    # 1 seul cadre
        If [F:APS]APSURL(0)=""
            If [F:APS]APSVW(0) <> ""        # recherche sur la vue
                # Recherche de la vue
                If clalev([F:APV])  = 0 : Local File APTLVW [APV]  : Endif    # vue portail
                Call LECTURE(UC_VIEWOBJ,[F:APS]APSVW(0) ,"")From CONTOBJ
                If fstat = 0
                    If [F:APV]SRCCODTYP="WEB"        # sources de données web
                        Onerrgo $EVACONNECTPTLURL
                        AURL=evalue([F:APV]SRCPARFOR(0))
                        Onerrgo
                    Endif
                Endif
            Endif 
        Else
            AURL=[F:APS]APSURL 
        Endif
    Endif
Endif

# Flag adresse relative
AFLGREL=1
If toupper(left$(vireblc(AURL,2),5))="HTTP:"        # url externe
    AFLGREL=0
Endif
If toupper(left$(vireblc(AURL,2),5))="FILE:"        # url externe E39415
    AFLGREL=0
Endif

End

$EVACONNECTPTLURL
AURL=PC_DEFURL        # restauration valeur par défaut
Resume
