#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DOSINTEG","DOSINTEG",3,"XYDOSINTEG") From GTRAITE
End

#---------------------------#
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

#---------------------------#
$INIT
Local Char    RETOUR(30) , MESSAGE(250)
Local Char    REPDOS(GDIMFIC) , REPHIS(GDIMFIC) , FICTRA(GDIMFIC)
Local Char    DOSSIER(GLONADS) , HISDOS(GLONADS) , MESSA(250)
TRA = 1
Return

#---------------------------#
$INIT_DIA
If filinfo(filpath("","histo","",nomap),0)>0
 [M:DIA]DOSSIER = adxmother(0)
 [M:DIA]HISTO = 2
Else
 [M:DIA]DOSSIER = nomap(0)
 [M:DIA]HISTO = 1
Endif
[M:DIA]STOVOL = "SVG"
[M:DIA]CFG    = 2 : # Fichier de config d'origine
[M:DIA]SIZ    = 2 : # Taille d'origine
Return

#---------------------------#
$CONTROLE
Return

#---------------------------#
$EXEC
If [M:DIA]HISTO=2
 Local File =[M:DIA]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 HISDOS  = [F:ADW]VALEUR
 DOSSIER = [M:DIA]DOSSIER
 Close Local File [ADW]
Else
 HISDOS  = ""
 DOSSIER = [M:DIA]DOSSIER
Endif
If !func DOSEXTRA.MAJVOL([M:DIA]DOSSIER,[M:DIA]STOVOL,[M:DIA]REPERT,MESSAGE)
 Call ERREUR(MESSAGE) From GESECRAN
 SAI = 1
 Return
Endif
REPHIS = [M:DIA]REPERT
REPDOS = [M:DIA]REPERT
If dim([M:DIA]MOTIVE)>0 and func AFNC.ACTIV("KPO")>0 : # ccl 113472 chg for Portugal
 Call INTEG_KPO(DOSSIER,REPDOS,HISDOS,REPHIS,[M:DIA]FICHIER,num$([M:DIA]CFG),num$([M:DIA]SIZ),"0",0,[M:DIA]MOTIVE,FICTRA,RETOUR)
Else
 Call INTEG(DOSSIER,REPDOS,HISDOS,REPHIS,[M:DIA]FICHIER,num$([M:DIA]CFG),num$([M:DIA]SIZ),"0",0,FICTRA,RETOUR)
Endif
Return

#---------------------------------------------------------------------------------------------#
Subprog INTEG_KPO(DOSSIER,REPDOS,HISDOS,REPHIS,FICHIER,FLGCFG,FLGSIZ,FLGSIL,TOUS,MOTIVE,FICTRA,RETOUR)
Value    Char    DOSSIER , REPDOS , HISDOS , REPHIS , FICHIER
Value    Char    FLGCFG , FLGSIZ , FLGSIL
Value    Integer TOUS,MOTIVE
Variable Char    FICTRA
Variable Char    RETOUR

Goto PRG_INTEG

#---------------------------------------------------------------------------------------------#
Subprog INTEG(DOSSIER,REPDOS,HISDOS,REPHIS,FICHIER,FLGCFG,FLGSIZ,FLGSIL,TOUS,FICTRA,RETOUR)
Value    Char    DOSSIER , REPDOS , HISDOS , REPHIS , FICHIER
Value    Char    FLGCFG , FLGSIZ , FLGSIL
Value    Integer TOUS
Variable Char    FICTRA
Variable Char    RETOUR

Local Integer MOTIVE
Goto PRG_INTEG


#---------------------------------------------------------------------------------------------#
$PRG_INTEG

Local Integer I , K , OK , SUPER , NBFIC , NBVUE , INTERRUPT
Local Char    LISTEFIC(GLONATB+2)(1..5000) , TABLE(GLONATB)
Local Char    REPDAT(GDIMFIC) , REPSVG(GDIMFIC) , TYPDBA(1)
Local Integer OKDBA , FORMAT , V130 , OKTAB , ERR , FLGACV
Local Integer CFG , SIZ , SILENCE , NBERR , ONBERR
Local Char    APPLI(GLONADS) , DOSSUP(GLONADS)
Local Char    REPBIS(GDIMFIC) , APPBIS(GLONADS)
Local Integer STAT,OKTICK

CFG = val(FLGCFG)
SIZ = val(FLGSIZ)
SILENCE = val(FLGSIL)
NBERR = 0
FLGACV = 0

If !GSERVEUR
 Call OUVRE_TRACE(mess(69,125,1)-DOSSIER) From LECFIC : # Intégration données
Endif

Gosub SET_GTRACE : ## Pour l'indus

FICTRA = filpath("TRA",GTRACE,"tra")

If DOSSIER=""
 Call ECR_TRACE(mess(171,133,1),1) From GESECRAN : # Paramètre non renseigné
 NBERR += 1 : Goto FIN
Endif

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = DOSSIER
If fstat
 DOSSUP = ""
 For [ADS]
  If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
   Onerrgo ERR
   Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
   Read [ADW]ADW0 = "";"";"SUPDOS"
   If !ERR & !fstat & [F:ADW]VALEUR=[F:ADS]DOSSIER
    Read [ADW]ADW0 = "";"";"TYPDOS"
    If !fstat & val([F:ADW]VALEUR)-1=GPRODUIT
     DOSSUP = [F:ADS]DOSSIER
    Endif
   Endif
   Close Local File [ADW]
   Onerrgo
   If DOSSUP<>"" : Break : Endif
  Endif
 Next ADS
 If DOSSUP=""
  Call ECR_TRACE(DOSSIER-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
  NBERR += 1
  Goto FIN
 Endif
Endif
Case [F:ADS]TYPDBA
 When 1 : [L]TYPDBA = "3" : # Oracle
 When 2 : [L]TYPDBA = "5" : # SQL-Serveur
 When 3 : [L]TYPDBA = "2" : # C-Isam
 When 4 : [L]TYPDBA = "6" : # DB2
Endcase
FORMAT = [F:ADS]CODDBA : # Ascii/Unicode
Close Local File [ADS] : # Il faut fermer toutes les tables car elles risquent de changer de structure

# On regarde si c'est le superviseur

If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 Onerrgo ERR
 Local File =DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"SUPDOS"
 If ERR
  SUPER = 0
 Elsif !fstat & [F:ADW]VALEUR=DOSSIER
  SUPER = 1
 Else
  SUPER = 0
 Endif
 Close Local File [ADW]
 Onerrgo
Else
 SUPER = 0
Endif

Local Integer TRTKPOB
If func AFNC.ACTIVDOS(DOSSIER,"KPO")
 Call EXISTE_ADX("","","DOSINTEGB",TRTKPOB) From ORDSYS
Endif

FICHIER = toupper(FICHIER)

For APPLI=DOSSIER,HISDOS

 OK = 1
 If HISDOS<>"" & !TOUS & APPLI<>HISDOS
  OK = 0
 Elsif APPLI<>""
  If APPLI=DOSSIER
   REPSVG = REPDOS
  Else
   REPSVG = REPHIS
  Endif
  If REPSVG=""
   Call ECR_TRACE(APPLI-":"-mess(9,141,1),1) From GESECRAN : # Répertoire inexistant
   NBERR += 1
   OK = 0
  Endif
 Else
  OK = 0
 Endif


 If OK

  Call ECR_TRACE(mess(69,125,1)-APPLI+"\"+string$(80,"-")+"\",0) From GESECRAN : # Intégration données
  K = instr(1,REPSVG,".")
  If K
   APPBIS = left$(REPSVG,K-1)
   REPBIS = right$(REPSVG,K+1)
  Else
   APPBIS = APPLI
   REPBIS = REPSVG
  Endif
  REPDAT = filpath(REPBIS,"","",APPBIS)
  If filinfo(REPDAT,0)<0
   Call ECR_TRACE(REPDAT-":"-mess(9,141,1),1) From GESECRAN : # Répertoire inexistant
   NBERR += 1
   OK = 0
  Endif
 Endif

# Liste des fichiers à convertir

 If OK
  If !instr(1,FICHIER,"*") & !instr(1,FICHIER,"?")
   If filinfo(filpath(REPBIS,FICHIER,"fde",APPBIS),0)<0
    NBFIC = 0
   Else
    NBFIC = 1
    LISTEFIC(1) = FICHIER
    Call VUE_OK(LISTEFIC(1),APPBIS,REPBIS,K) From DOSVUE
    If K : NBVUE += 1 : Endif
   Endif
  Else
   Call SYSTEME2(adxmac(0),"lsadx -a"-APPBIS-REPBIS-"fde","",NBFIC,LISTEFIC) From ORDSYS
   I = 1
   NBVUE = 0
   While I<=NBFIC
    If !pat(LISTEFIC(I),FICHIER)
     Dela I,1 LISTEFIC(I)
     NBFIC -= 1
    Else
     Call VUE_OK(LISTEFIC(I),APPBIS,REPBIS,K) From DOSVUE
     If K : NBVUE += 1 : Endif
     I += 1
    Endif
   Wend
  Endif
  If NBFIC=0
   Call ECR_TRACE(APPLI-":"-mess(70,125,1),-1) From GESECRAN : # Pas de données à intégrer
   OK = 0
  Elsif !GSERVEUR & !SILENCE
   # Nb de tables à intégrer
   Call OUINON(APPLI-":"-mess(104,125,1)-":"-num$(NBFIC)-"("+num$(NBVUE)-mess(126,125,1)+")",OK) From GESECRAN
   If OK<>2 : OK = 0 : Endif
  Else
   # Nb de tables à intégrer
   Call ECR_TRACE(APPLI-":"-mess(104,125,1)-":"-num$(NBFIC)-"("+num$(NBVUE)-mess(126,125,1)+")"+"\",0)  From GESECRAN
  Endif
 Endif

 If OK

  If !GSERVEUR & !SILENCE
   Call OUVRE_BOITE(mess(69,125,1)-APPLI,NBFIC) From GESECRAN : # Intégration données
   Call SET_BOITE(mess(69,125,1),NBFIC) From GESECRAN
  Endif

  OKTAB = 1
  TABLE = "ATABLE"
  If filinfo(filpath("FIL","ATABLE","fde",DOSSIER),0)<0
   OKTAB = 0
  Else
   Onerrgo ERR
   If clalev([F:ATB])=0 : Local File =DOSSIER+".ATABLE" [ATB] : Endif
   If ERR
    OKTAB = 0
   Else
    Read [ATB]CODFIC = TABLE
    If ERR : OKTAB = 0 : Endif
   Endif
   Close Local File [ATB]
   Onerrgo
  Endif

  adxifs = ""
  adxirs = chr$(10)
  INTERRUPT = 0

  # Restauration des tables

  K = 0
  For I=1 To NBFIC
   Call VUE_OK(LISTEFIC(I),APPBIS,REPBIS,OK) From DOSVUE
   OK = !OK
   If OK
    K += 1
    If !GSERVEUR & !SILENCE
     Call AFF_BOITE(mess(56,123,1)-LISTEFIC(I),K,INTERRUPT) From GESECRAN : # Table
    Endif
    V130 = 0
    If OKTAB
     If clalev([F:ATB])=0 : Local File =DOSSIER+".ATABLE" [ATB] : Endif
     Read [ATB]CODFIC = LISTEFIC(I)
     If !fstat
      If SUPER=0 & GADONIX<>2 & [F:ATB]TYPFIC=3
       OK = 0
      Elsif dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
       V130 = 1
      Endif
     Endif
     Close Local File [ATB]
    Endif
    If OK
     ONBERR = NBERR
     Call RESTAURE(LISTEFIC(I),APPLI,TYPDBA,REPSVG,CFG,SIZ,FORMAT,V130,NBERR)
     If APPLI=DOSSIER & LISTEFIC(I)="ACTIV" & NBERR=ONBERR
      FLGACV = 1
     Endif
     If TRTKPOB>0
      Gosub MOTIVE From DOSINTEGB : # ccl 113472 chg for Portugal
     Endif
    Endif
   Endif
  Next I

  # Restauration des vues

  For I=1 To NBFIC
   Call VUE_OK(LISTEFIC(I),APPBIS,REPBIS,OK) From DOSVUE
   If OK
    K += 1
    If !GSERVEUR & !SILENCE
     Call AFF_BOITE(mess(77,139,1)-LISTEFIC(I),K,INTERRUPT) From GESECRAN : # Vue
    Endif
    Call RESTAURE(LISTEFIC(I),APPLI,TYPDBA,REPSVG,CFG,SIZ,FORMAT,0,NBERR)
    If TRTKPOB>0
     Gosub MOTIVE From DOSINTEGB : # ccl 113472 chg for Portugal
    Endif
   Endif
  Next I

  If !GSERVEUR & !SILENCE
   Call FERME_BOITE From GESECRAN
  Endif

  # Génération des triggers

  # Triger updtick
  If APPLI<>HISDOS & filinfo(filpath("FIL","ATABZON","fde",APPLI),0)>0 & filinfo(filpath("FIL","ATABLE","fde",APPLI),0)>0
   Raz OK , ERR
   Onerrgo ERR
   Local File =APPLI+".ATABZON" [ATZ]
   Local File =APPLI+".ATABLE" [ATB]
   Onerrgo
   Gosub SET_TABSYS From SUBATB
   For I=1 To NBFIC
    Call VUE_OK(LISTEFIC(I),APPBIS,REPBIS,OK) From DOSVUE
    If !OK
     If type([F:ATB]AUUID)=525 & !find(LISTEFIC(I),TABSYS(1..NBSYS))
      OKTICK = 0
      For [ATZ]CODTYP Where CODFIC=LISTEFIC(I) & CODTYP="AUUID" : OKTICK = 1 : Break : Next ATZ
      If OKTICK : Call TRIGGER_UPDTICK(APPLI,LISTEFIC(I)) From ATRIGGERTICK : Endif
     Endif
    Endif
   Next
   Close Local File [ATZ]
   Close Local File [ATB]
  Endif

  #112168 only on same release, otherwise valdos
  If APPLI<>HISDOS & filinfo(filpath("FIL","ACTIV","fde",APPLI),0)>0
& & func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
   Raz OK , ERR
   Onerrgo ERR
   # Trigger soumis au code activité AUDIT
   Local File =APPLI+".ACTIV" [ACV]
   Read [ACV]CODACT = "AUDIT"
   If !fstat & [F:ACV]FLACT=2
    OK = 1
   Endif
   Close Local File [ACV]
   Onerrgo
   If OK
    Local File ADOSSIER [ADS]
    Read [ADS]DOSSIER=APPLI
    If !fstat
     If !GSERVEUR & !SILENCE
      Call OUVRE_BOITE(mess(69,125,1)-APPLI,NBFIC) From GESECRAN
      Call SET_BOITE(mess(131,139,1),NBFIC) From GESECRAN
     Endif
     Trbegin ADOVAL
      K = 0
      For I=1 To NBFIC
       Call VUE_OK(LISTEFIC(I),APPBIS,REPBIS,OK) From DOSVUE
       If !OK
        If !K
         Call ECR_TRACE("\"+mess(131,139,1),0) From GESECRAN : # Mise à jour des flags d'audit
         K = 1
        Endif
        If !GSERVEUR & !SILENCE
         Call AFF_BOITE(mess(56,123,1)-LISTEFIC(I),I,INTERRUPT) From GESECRAN
        Endif
        Call TRIGGER(APPLI,LISTEFIC(I),"I") From ATRIGGER
        Call TRIGGER(APPLI,LISTEFIC(I),"U") From ATRIGGER
        Call TRIGGER(APPLI,LISTEFIC(I),"D") From ATRIGGER
       Endif
      Next I
     Commit
     If !GSERVEUR & !SILENCE
      Call FERME_BOITE From GESECRAN
     Endif
    Endif
    Close Local File [ADS]
   Endif
  Endif

 Endif

Next APPLI

# Mise à jour du paramètre HISDOS

If DOSSIER<>"" & HISDOS<>"" & FICHIER="*"
 Call MAJPAR(DOSSIER,"HISDOS",HISDOS,OK)
 If OK
  Local File ADOSSIER [ADS]
  Trbegin [ADS]
   Readlock [ADS]DOSSIER=DOSSIER
   If fstat=1
    OK = 0
   Elsif fstat
    OK = 0
   Else
    [F:ADS]DOSHIS = HISDOS
    Rewrite [ADS]
    If fstat : OK = 0 : Endif
   Endif
  If !OK
   Rollback
  Else
   Commit
  Endif
  Close Local File [ADS]
  If !OK
   Call ECR_TRACE(mess(34,141,1)+"\HISDOS"-":"-mess(167,139,1),1) From GESECRAN : # Erreur/Paramètre mis à jour
   NBERR += 1
  Endif
 Endif
Endif

# Mise à jour du paramètre TYPDBA

If DOSSIER<>"" & FICHIER="*"
 Call MAJPAR(DOSSIER,"TYPDBA",num$(GTYPDBA),OK)
 If !OK : NBERR += 1 : Endif
Endif

# Mise à jour du paramètre SUPDOS

If DOSSIER<>"" & FICHIER="*"
 Call MAJPAR(DOSSIER,"SUPDOS",GDOSX3,OK)
 If !OK : NBERR += 1 : Endif
Endif

# Mise à jour de la table ADOSACT

If DOSSIER<>"" & DOSSIER<>DOSSUP & FLGACV
 Local File ADOSACT [ADA] , =DOSSIER+".ACTIV" [ACV]
 OK = 1
 Trbegin [ADA]
  For [ACV]
   Read [ADA]ADA0=DOSSIER;[F:ACV]CODACT
   If fstat=1
    OK = 0
   Elsif fstat=0
    [F:ADA]FLACT = [F:ACV]FLACT
    [F:ADA]DIME  = [F:ACV]DIME
    Rewrite [ADA]
    If fstat : OK = 0 : Endif
   Endif
  Next ACV
 Commit
 If OK
  Call ECR_TRACE(mess(268,139,1),0) From GESECRAN : # Codes activité dossier mis à jour
 Else
  Call ECR_TRACE(mess(34,141,1)+"\"+mess(268,139,1),1) From GESECRAN : # Codes activité dossier mis à jour
  NBERR += 1
 Endif
 Close Local File [ADA] , [ACV]
Endif

#109897
If DOSSIER<>"" & find("AVOLUME",LISTEFIC(1..NBFIC))>0
 Call PATCH(DOSSIER) From UTIMAJREPSRV
Endif

# Regénération des vues invalides

Call GENVUE(DOSSIER) From DOSVUE

# Invalidation du contexte
#Call EFFACE_STC("",DOSSIER,func SUBACLA.PREFIX_CLA+"WMACONTEXT",STAT) From ORDSYS
Call INVALID_STC("",DOSSIER,func SUBACLA.PREFIX_CLA+"WMACONTEXT",STAT) From ORDSYS


$FIN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

RETOUR = num$(NBERR)

End

#-------------------------------------------------------------------#
Subprog MAJPAR(DOSSIER,PARAM,PARVAL,OK)
Value Char DOSSIER , PARAM , PARVAL
Variable Integer OK
Local Integer ERR
OK = 1
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)<=0
 OK = 0
Else
 Onerrgo ERR
 Local File =DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";[L]PARAM
 If ERR
  OK = 0
 Elsif !fstat & [F:ADW]VALEUR=[L]PARVAL
  OK = -1
 Else
  Trbegin [ADW]
   Readlock [ADW]ADW0 = "";"";[L]PARAM
   If fstat=1
    OK = 0
   Elsif fstat
    Raz [F:ADW]
    [F:ADW]PARAM  = [L]PARAM
    [F:ADW]VALEUR = [L]PARVAL
    Write [ADW]
    If fstat : OK = 0 : Endif
   Else
    [F:ADW]VALEUR = [L]PARVAL
    Rewrite [ADW]
    If fstat : OK = 0 : Endif
   Endif
  If !OK
   Rollback
  Else
   Commit
  Endif
 Endif
 Close Local File [ADW]
 Onerrgo
Endif
If OK=1
 Call ECR_TRACE([L]PARAM-":"-mess(167,139,1)-"("+[L]PARVAL+")",0) From GESECRAN : # Paramètre mis à jour
Elsif !OK
 Call ECR_TRACE(mess(34,141,1)+"\"+[L]PARAM-":"-mess(167,139,1),1) From GESECRAN : # Erreur/Paramètre mis à jour
Endif
End

#---------------------------------#
$SET_GTRACE
If GTRACE=""
 GTRACE = "Integ_"+nomap
 Openo filpath("TRA",GTRACE,"tra",0) , 0
 Openo
Endif
Return

#-------------------------------------------------------------------------#
Subprog RESTAURE(FICHIER,APPLI,TYPDBA,REPSVG,CFG,SIZ,FORMAT,V130,NBERR)
Value Char    FICHIER
Value Char    APPLI
Value Char    TYPDBA
Value Char    REPSVG
Value Integer CFG
Value Integer SIZ
Value Integer FORMAT
Value Integer V130
Variable Integer NBERR

Local Integer STAT , IDUNIQ , K , ERR , VUE , OK
Local Char    ORDSYS(250)(1..2) , FICSRC(GDIMFIC) , FICNEW(GDIMFIC) , FICSEQ(GDIMFIC) , FICVIW(GDIMFIC)
Local Char    CFGFIL(GDIMFIC) , CFGSVG(GDIMFIC) , CFGSAV(GDIMFIC) , LIGNE(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    OINITIAL(20) , ONEXT(20) , OPCTINC(20) , OBASE(5)
Local Char    NINITIAL(20) , NNEXT(20) , NPCTINC(20) , NBASE(5)
Local Char    FINITIAL(20) , FNEXT(20) , FPCTINC(20)
Local Char    STORAGE(250)
Local Char    NAMZ(30) , TYPZ(5) , LNGZ(10) , DIMZ(10) , TITZ(80) , NBZ(10) , OTYPDBA(10)
Local Char    FICTRA(GDIMFIC)
Local Char    CHAINE(250) , VERSION(20)
Local Char    REPBIS(GDIMFIC) , APPBIS(GLONADS)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

K = instr(1,REPSVG,".")
If K
 APPBIS = left$(REPSVG,K-1)
 REPBIS = right$(REPSVG,K+1)
Else
 APPBIS = APPLI
 REPBIS = REPSVG
Endif

## Trace des valfil systèmes

FICTRA  = filpath("tmp",FICHIER,"tra",APPLI)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

## Pour l'indus

Gosub SET_GTRACE

## Vue ?

Call VUE_OK(FICHIER,APPBIS,REPBIS,OK) From DOSVUE
If OK

 # Si le .srf est une table il faut virer la table avant de créer la vue, sinon on vire la vue
 If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
  Call ECR_TRACE(mess(53,123,1)-APPLI+".FIL/"+FICHIER,0) From GESECRAN : #  Suppression
  ORDSYS(1) = 'valfil -s -d'-APPLI-FICHIER
  ORDSYS(2) = FICTRA
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Call TRACE(FICTRA,mess(28,125,1)-FICHIER,NBERR) : # Erreur d'effacement
 Endif

 Call ECR_TRACE(mess(91,123,1)-APPLI+".FIL/"+FICHIER-"("+mess(77,139,1)+")",0) From GESECRAN : # Copie (Vue)
 Call ECR_TRACE(mess(77,139,1)-":"-FICHIER,0) From GESECRAN : # Vue

 # Restauration du .srf avec modification du flag base
 FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
 If filinfo(FICSRC,0)>0
  FICNEW = filpath("FIL",FICHIER,"new",APPLI)
  Openi FICSRC
  Openo FICNEW , 0
  Rdseq LIGNE   : Wrseq LIGNE  : # En-tête
  Rdseq LIGNE   : Wrseq LIGNE  : # Abréviation
  Rdseq LIGNE   : Wrseq LIGNE  : # ?
  adxifs = ""
  Rdseq LIGNE : # Infos base
  Call PARBAS(LIGNE,OTYPDBA,OINITIAL,ONEXT,OPCTINC) From DOSTAB
  adxifs = chr$(9)
  Wrseq TYPDBA,OINITIAL,ONEXT,OPCTINC
  adxifs = ""
  Rdseq NBZ
  Wrseq NBZ
  adxifs = chr$(9)
  For I=1 To val(NBZ)
   Rdseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
   Case TYPZ
    When "79" : If FORMAT=1 : TYPZ = "7"  : K = 1 : Endif : # Unicode -> ascii
    When "7"  : If FORMAT=2 : TYPZ = "79" : K = 1 : Endif : # Ascii -> unicode
   Endcase
   Wrseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
  Next I
  adxifs = ""
  Rdseq NBZ
  Wrseq NBZ
  For I=1 To val(NBZ)
   Rdseq LIGNE
   Wrseq LIGNE
  Next I
  Openi
  Openo
  FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
 Endif

 # Restauration du .viw
 FICVIW = filpath("FIL",FICHIER,"viw",APPLI)
 If OTYPDBA<>TYPDBA & filinfo(FICVIW,0)>0
  Call EFFACE(FICVIW,STAT) From ORDSYS
 Endif
 If filinfo(filpath(REPBIS,FICHIER,"viw",APPBIS),0)>0
  Call COPIE(filpath(REPBIS,FICHIER,"viw",APPBIS),FICVIW,STAT) From ORDSYS
 Endif
 If filinfo(FICVIW,0)<=0
  Call ECR_TRACE("|"+FICVIW-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
  NBERR += 1
  End
 Endif

 # Copie du .cfg d'origine
 CFGFIL = filpath("FIL",FICHIER,"cfg",APPLI)
 CFGSVG = filpath(REPBIS,FICHIER,"cfg",APPBIS)
 CFGSAV = filpath(REPBIS,FICHIER,"ocf",APPBIS)
 If CFG=2
  If filinfo(CFGFIL,0)>0
   If filinfo(CFGSVG,0)>0
    Call MOVE(CFGSVG,CFGSAV,STAT) From ORDSYS
   Endif
   Call COPIE(CFGFIL,CFGSVG,STAT) From ORDSYS
  Elsif filinfo(CFGSVG,0)>0
   Call MOVE(CFGSVG,CFGSAV,STAT) From ORDSYS
  Endif
 Elsif filinfo(CFGFIL,0)>0
  Call EFFACE(CFGFIL,STAT) From ORDSYS
 Endif

 # Génération de la vue dans la base
 ORDSYS(1) = 'valfil -s'-APPLI-FICHIER
 ORDSYS(2) = FICTRA
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Call TRACE(FICTRA,mess(78,139,1)-FICHIER,NBERR) : # Erreur en validation de la vue
 End
Endif

## Contrôle si la table a été sauvegardée en taille variable (clob/blob)

FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
If filinfo(FICSRC,0)>0
 Openi FICSRC
 Rdseq LIGNE : # En-tête
 Rdseq LIGNE : # Abréviation
 Rdseq LIGNE : # ???
 Rdseq LIGNE
 Call PARBAS(LIGNE,OBASE,OINITIAL,ONEXT,OPCTINC) From DOSTAB
 adxifs = chr$(9)
 If OBASE="2"
  VERSION = func AFNC.PARTSEP(ver$(0),2," ")
  OK = (left$(VERSION,3)<>"6.4")
  OK *= (VERSION>="14r.316")
  If !OK
   # Le format de sauvegarde de cette table n'est pas compatible avec la version adonix actuelle
   Call ECR_TRACE(FICHIER-":"-mess(114,139,1),1) From GESECRAN
   NBERR += 1
   End
  Endif
 Endif
Endif

## Verrou

If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
 Onerrgo ERR
 Local File =APPLI+"."+FICHIER [F1]
 Lock [F1]
 Onerrgo
 If !ERR & fstat
  Call ECR_TRACE(FICHIER-":"-mess(123,133,1),1) From GESECRAN : # Table en cours d'utilisation
  Close Local File [F1]
  NBERR += 1
  End
 Endif
Endif

## Ancien dimensionnement oracle

Raz OINITIAL , ONEXT , OPCTINC
If TYPDBA="3"
 FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
 If filinfo(FICSRC,0)>0
  Openi FICSRC
  adxifs = ""
  Rdseq LIGNE : # En-tête
  Rdseq LIGNE : # Abréviation
  Rdseq LIGNE : # ???
  Rdseq LIGNE
  Call PARBAS(LIGNE,OBASE,OINITIAL,ONEXT,OPCTINC) From DOSTAB
  adxifs = ""
  Openi
 Endif
Endif

## Nouveau dimensionnement oracle

Raz NINITIAL , NNEXT , NPCTINC
If TYPDBA="3"
 FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
 If filinfo(FICSRC,0)>0
  Openi FICSRC
  adxifs = ""
  Rdseq LIGNE : # En-tête
  Rdseq LIGNE : # Abréviation
  Rdseq LIGNE : # ???
  Rdseq LIGNE
  Call PARBAS(LIGNE,NBASE,NINITIAL,NNEXT,NPCTINC) From DOSTAB
  Openi
 Endif
Endif

FNEXT    = ""
FPCTINC  = ""
If SIZ=2 & OINITIAL<>""
 FINITIAL = OINITIAL
Else
 FINITIAL = NINITIAL
Endif

## Format du dossier

If !V130 & FORMAT
 FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
 FICNEW = filpath(REPBIS,FICHIER,"new",APPBIS)
 If filinfo(FICSRC,0)>0
  K = 0
  Openi FICSRC
  Openo FICNEW,0
  For I=1 To 4
   Rdseq LIGNE
   Wrseq LIGNE
  Next I
  Rdseq NBZ
  Wrseq NBZ
  adxifs = chr$(9)
  For I=1 To val(NBZ)
   Rdseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
   Case TYPZ
    When "79" : If FORMAT=1 : TYPZ = "7"  : K = 1 : Endif : # Unicode -> ascii
    When "7"  : If FORMAT=2 : TYPZ = "79" : K = 1 : Endif : # Ascii -> unicode
   Endcase
   Wrseq NAMZ,TYPZ,LNGZ,DIMZ,TITZ
  Next I
  adxifs = ""
  Rdseq NBZ
  Wrseq NBZ
  For I=1 To val(NBZ)
   Rdseq LIGNE
   Wrseq LIGNE
  Next I
  Openi
  Openo
  If K
   Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
  Endif
  Call EFFACE(FICNEW,STAT) From ORDSYS
 Endif
Endif

## Déverrou

If clalev([F:F1])>0
 Unlock [F1]
 Close Local File [F1]
Endif

## Si le .srf est une vue, il faut virer la vue avant d'intégrer la table, sinon on vire la table

If filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
 Call ECR_TRACE(mess(53,123,1)-APPLI+".FIL/"+FICHIER,0) From GESECRAN : #  Suppression
 Call EFFACE(filpath("FIL",FICHIER,"viw",APPLI),STAT) From ORDSYS
 ORDSYS(1) = 'valfil -s -d'-APPLI-FICHIER
 ORDSYS(2) = FICTRA
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Call TRACE(FICTRA,mess(28,125,1)-FICHIER,NBERR) : # Erreur d'effacement
Endif

## Copie du cfg d'origine

CFGFIL = filpath("FIL",FICHIER,"cfg",APPLI)
CFGSVG = filpath(REPBIS,FICHIER,"cfg",APPBIS)
CFGSAV = filpath(REPBIS,FICHIER,"ocf",APPBIS)
If CFG=2
 If filinfo(CFGFIL,0)>0
  If filinfo(CFGSVG,0)>0
   Call MOVE(CFGSVG,CFGSAV,STAT) From ORDSYS
  Endif
  Call COPIE(CFGFIL,CFGSVG,STAT) From ORDSYS
 Elsif filinfo(CFGSVG,0)>0
  Call MOVE(CFGSVG,CFGSAV,STAT) From ORDSYS
 Endif
Elsif filinfo(CFGFIL,0)>0
 Call EFFACE(CFGFIL,STAT) From ORDSYS
Endif

## Regénération du fde (changement de version)

Call ECR_TRACE(mess(59,123,1)-APPLI+".FIL/"+FICHIER,0) From GESECRAN : # Création
ORDSYS(1) = "valfil -s"
If V130
 ORDSYS(1) -= "-a"
Endif
ORDSYS(1) -= APPBIS-APPBIS+"."+REPBIS+"/"+FICHIER
ORDSYS(2) = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Call TRACE(FICTRA,mess(7,21,1)-FICHIER+".fde",NBERR) : # Erreur

## Prise en compte de la clause storage

If FINITIAL<>"" & TYPDBA="3"
 STORAGE = "Storage (Initial"-FINITIAL
 If FNEXT<>""
  STORAGE -= "Next"-FNEXT
  If FPCTINC<>""
   STORAGE -= "Pctincrease"-FPCTINC
  Endif
 Endif
 STORAGE += ")"
Endif

## Transfert SVG => FIL

ORDSYS(1) = "valfil -s"
If V130
 ORDSYS(1) -= "-a"
Endif
ORDSYS(1) -= "-c -t"+TYPDBA
If STORAGE<>""
 ORDSYS(1) -= "-o"-'"'+STORAGE+'"'
Endif
ORDSYS(1) -= APPLI-APPBIS+"."+REPBIS+"/"+FICHIER-APPLI+".FIL/"+FICHIER
ORDSYS(2) = FICTRA
Call ECR_TRACE(ORDSYS(1),0) From GESECRAN
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Call TRACE(FICTRA,mess(51,123,1)-FICHIER,NBERR) : # Erreur en validation de la table

## Mise à jour du fichier srf

FICSRC = filpath(REPBIS,FICHIER,"srf",APPBIS)
If filinfo(FICSRC,0)>0
 FICNEW = filpath("FIL",FICHIER,"new",APPLI)
 Openi FICSRC
 Openo FICNEW , 0
 adxifs = ""
 Rdseq LIGNE : Wrseq LIGNE  : # En-tête
 Rdseq LIGNE : Wrseq LIGNE  : # Abréviation
 Rdseq LIGNE : Wrseq LIGNE  : # ???
 Rdseq LIGNE
 Call PARBAS(LIGNE,OBASE,OINITIAL,ONEXT,OPCTINC) From DOSTAB
 adxifs = chr$(9)
 Wrseq TYPDBA,FINITIAL,FNEXT,FPCTINC
 adxifs = ""
 Rdseq LIGNE
 While fstat=0
  Wrseq LIGNE : Rdseq LIGNE
 Wend
 Openi
 Openo
 FICSRC = filpath("FIL",FICHIER,"srf",APPLI)
 Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
Endif

## Copie du cfg, et restitution de l'original

If CFG=2
 If filinfo(CFGSVG,0)>0
  Call EFFACE(CFGSVG,STAT) From ORDSYS
 Endif
 If filinfo(CFGSAV,0)>0
  Call MOVE(CFGSAV,CFGSVG,STAT) From ORDSYS
 Endif
Else
 If filinfo(CFGSVG,0)>0
  Call COPIE(CFGSVG,CFGFIL,STAT) From ORDSYS
 Elsif filinfo(CFGFIL,0)>0
  Call EFFACE(CFGFIL,STAT) From ORDSYS
 Endif
Endif

## Intégration fichier .seq
## Sauf pour la table AESPION, à cause du nombre important d'uniqid fait par ORDSYS

FICSEQ = filpath(REPBIS,FICHIER,"seq",APPBIS)
If filinfo(FICSEQ,0)>0 & FICHIER<>"AESPION"
 Openi FICSEQ
 Rdseq IDUNIQ
 Openi
#101730
# Onerrgo ERR_TRA
# Local File =APPLI+"."+FICHIER [SVG]
# Onerrgo
# If ERR
#  NBERR += 1
#  End
# Endif
# While uniqid([SVG])<IDUNIQ
# Wend
# Close Local File [SVG]
 Call SET_UNIQID_TABLE(APPLI,FICHIER,IDUNIQ,ERR)
 If ERR
  NBERR += 1
  End
 Endif
Endif

## Mise à niveau du rowid de la table AUDITH sous SQL

If FICHIER="AUDITH"
 If TYPDBA="5" : # Sql
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  #Call SET_ROWID(APPLI,STAT) From SUBTRIGGER
  Call SET_ROWID_TABLE(APPLI,"AUDITH",STAT) From SUBTRIGGER
 Else
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  #Call SET_ROWID_OR(APPLI,STAT) From SUBTRIGGER
  Call SET_ROWID_OR_TABLE(APPLI,"AUDITH",STAT) From SUBTRIGGER
 Endif
 If STAT : NBERR += 1 : Endif
Endif

If FICHIER="AJSAUDIT"
 If TYPDBA="5" : # Sql
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  Call SET_ROWID_TABLE(APPLI,"AJSAUDIT",STAT) From SUBTRIGGER
 Else
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  Call SET_ROWID_OR_TABLE(APPLI,"AJSAUDIT",STAT) From SUBTRIGGER
 Endif
 If STAT : NBERR += 1 : Endif
Endif

If FICHIER="AUDITBI"
 If TYPDBA="5" : # Sql
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  Call SET_ROWID_TABLE(APPLI,"AUDITBI",STAT) From SUBTRIGGER
 Else
  # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
  Call SET_ROWID_OR_TABLE(APPLI,"AUDITBI",STAT) From SUBTRIGGER
 Endif
 If STAT : NBERR += 1 : Endif
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

GPOINT = "RESTAURE" : Gosub ENTREE From EXEFNC : # mb 3.1.5 Demande 27524

End

#---------------------------#
$ERR_TRA
ERR = errn
Call ECR_TRACE("|"+FICHIER+"|\"+errp+"("+num$(errl)+")\"-num$(ERR)+":"+errmes$(ERR)+"\|"+errm,1) From GESECRAN
NBERR += 1
Resume

$ERR
ERR = errn
Resume

#-----------------------------------------------------------------#
Subprog SET_UNIQID_TABLE(APPLI,TABLE,MAXSEQ,ERR)
Value    Char APPLI
Value    Char TABLE
Value    Integer MAXSEQ
Variable Integer ERR
ERR = 0
#
If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<=0 : ERR=1 : End : Endif
#
#101730
#If func AFNC.PARTSEP(ver$(0),2," ")>="16r.225"
If func AFNC.PARTSEP(ver$(0),2," ")>="17r.218"
 #valfil –i no_sequence DOSSIER TABLE
 Call SYSTEME(adxmac(0),"valfil -i"-num$(MAXSEQ+1)-APPLI-TABLE,"",ERR) From ORDSYS
Else
 Local Integer NBERR
 Onerrgo ERR_TRA
 Local File =APPLI+"."+TABLE [SVG]
 Onerrgo
 While uniqid([SVG])<MAXSEQ
 Wend
 Close Local File [SVG]
Endif

End


#--------------------------------------------------------#
Subprog TRACE(FICTRA,ERRMES,NBERR)
Value Char FICTRA , ERRMES
Variable Integer NBERR
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM , STAT
Local Char    MESSAGE(80)(1..5)
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Openi FICTRA Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Openi Using [TR_]
If MESSAGE(1)<>""
 Call ECR_TRACE(ERRMES+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
 NBERR += 1
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Call EFFACE(FICTRA,STAT) From ORDSYS
End

#--------------------------------------------------------------------------#
# Liste des tables à intégrer
#--------------------------------------------------------------------------#

$SEL_LISTE
Local Integer K , ERR , DIME
Local Char    DOSREF(GLONADS)
Local Char    REPBIS(GDIMFIC) , APPBIS(GLONADS)
Local File ADOSSIER [ADS]
DOSREF = ""
If filinfo(filpath("FIL","ADOVAL","fde",[M:DIA]DOSSIER),0)>0
 Onerrgo ERR
 Local File =[M:DIA]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 First
 If !ERR
  DOSREF = [M:DIA]DOSSIER
 Endif
 Close Local File [ADW]
 Onerrgo
Endif
If DOSREF=""
 For [ADS]
  If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
   Onerrgo ERR
   Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
   Read [ADW]ADW0 = "";"";"SUPDOS"
   If !ERR & !fstat & [F:ADW]VALEUR=[F:ADS]DOSSIER
    Read [ADW]ADW0 = "";"";"TYPDOS"
    If !fstat & val([F:ADW]VALEUR)-1=GPRODUIT
     DOSREF = [F:ADS]DOSSIER
    Endif
   Endif
   Close Local File [ADW]
   Onerrgo
   If DOSREF<>"" : Break : Endif
  Endif
 Next ADS
Endif
K = instr(1,[M:DIA]REPERT,".")
If K
 APPBIS = left$([M:DIA]REPERT,K-1)
 REPBIS = right$([M:DIA]REPERT,K+1)
Elsif [M:DIA]HISTO<>2
 APPBIS = [M:DIA]DOSSIER
 REPBIS = [M:DIA]REPERT
Elsif filinfo(filpath("FIL","ADOVAL","fde",[M:DIA]DOSSIER),0)>0
 Onerrgo ERR
 Local File =[M:DIA]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !ERR & !fstat & [F:ADW]VALEUR<>""
  APPBIS = [F:ADW]VALEUR
 Endif
 REPBIS = [M:DIA]REPERT
 Close Local File [ADW]
Endif
If APPBIS="" : Return : Endif
If DOSREF<>""
 Local File =DOSREF+".ATABLE" [ATB] , =DOSREF+".ATEXTE" [ATX] , =DOSREF+".AVIEW" [AVW]
 DIME = max(nbrecord([F:ATB]),1000)
Else
 DIME = 1000
Endif
Local Char TEX(GLONATB+2)(1..DIME) : # mb 11.2.8 bug du lsadx
Local Char TEXTE(GLONDES)(1..DIME,1..4)
Call SYSTEME2(adxmac(0),"lsadx -a"-APPBIS-REPBIS-"fde","",NBTEX,TEX) From ORDSYS
I = 1
NBTEX = min(NBTEX,dim(TEX))
While I<=NBTEX
 If (instr(1,VALEUR,"*") or instr(1,VALEUR,"?")) & !pat(TEX(I),VALEUR)
  Dela I,1 TEX(I)
  NBTEX -= 1
 Else
  TEXTE(I,1) = TEX(I)
  TEXTE(I,2) = ""
  TEXTE(I,3) = ""
  If clalev([F:ATB])>0
   Read [ATB]CODFIC=TEX(I)
   If !fstat
    TEXTE(I,2) = [F:ATB]ABRFIC
    Call TEXTE([F:ATB]INTITFIC,TEXTE(I,3)) From OBJDIV
   Endif
  Endif
  If TEXTE(I,2)="" & clalev([F:AVW])>0
   Read [AVW]AVW0=TEX(I)
   If !fstat
    TEXTE(I,2) = [F:AVW]CODVUE
    Call TEXTE([F:AVW]INTIT,TEXTE(I,3)) From OBJDIV
    TEXTE(I,4) = mess(77,139,1) : # Vue
   Endif
  Endif
  If TEXTE(I,2)="" & TEX(I)<>""
   TEXTE(I,4) = mess(158,115,1) : # Table non déclarée dans le dictionnaire
  Endif
  I += 1
 Endif
Wend
TIT(0) = mess(38,126,1)  : # Choix fichiers
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(180,115,1) : # Abréviation
TIT(3) = mess(30,109,1)  : # Intitulé
TIT(4) = mess(172,115,1) : # Commentaires
Return

#---------------------------------------------------------------------------------#
# Affectation d'un paramètre à une valeur
#---------------------------------------------------------------------------------#

Subprog SETPAR(NOMPAR,VALPAR)
Value Char NOMPAR
Value Char VALPAR
Call DEBTRANS From GLOCK
Gosub TR_PAR
End

$TR_PAR
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "";"";NOMPAR
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL"-NOMPAR : Goto ROLL_TR_PAR
 Elsif fstat
  GOK = 0 : Call RSTA("ADW",NOMPAR) From GLOCK : Goto AB_TR_PAR
 Endif
 [F:ADW]VALEUR = VALPAR
 Rewrite [ADW]
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_TR_PAR
 Endif
Commit
Return

$AB_TR_PAR
Rollback
Return

$ROLL_TR_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif

#---------------------------------------------------------------------------------#
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=VALEUR
If fstat
 Call AVERTIR(VALEUR-":"-mess(7,125,1),OK) From GESECRAN
 If OK<>2
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Local Char    REPERT(250) , HISTO(GLONADS)
Local Char    APPBIS(GLONADS) , REPBIS(GDIMFIC) , DOSSVG(GLONADS)
If [M]HISTO=2
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 DOSSVG  = [F:ADW]VALEUR
 Close Local File [ADW]
Else
 DOSSVG = [M]DOSSIER
Endif
K = instr(1,VALEUR,".")
If K
 APPBIS = left$(VALEUR,K-1)
 REPBIS = right$(VALEUR,K+1)
Else
 APPBIS = DOSSVG
 REPBIS = VALEUR
Endif
If find(REPBIS,"TRT","FIL","ETM","TRA","tmp","BQR","BQE","BQT","LIA","TXT","REPORT","GRAPH"
&             ,"GEN","PIC","LNK","ECR","PCD","DEC")
& or pat(REPBIS,"M???")
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Elsif instr(1,VALEUR,":") or left$(VALEUR,1)="\" or left$(VALEUR,1)="/"
 GMESSAGE = mess(115,139,1) : # Le répertoire de sauvegarde ne peut pas être en absolu
 mkstat = 2 : End
Elsif VALEUR<>vireblc(VALEUR,4)
 GMESSAGE = mess(71,133,1) : # Caractère <ESPACE> interdit
 mkstat = 2 : End
Endif
REPERT = filpath(REPBIS,"","",APPBIS)
Call EXISTE(REPERT,STAT) From ORDSYS
If STAT<>2
 GMESSAGE = "|"+REPERT+"|\"+mess(86,133,1) : # Répertoire inexistant
 mkstat = 2 : End
Endif
End

Subprog C_HISTO(VALEUR)
Variable Integer VALEUR
Local Integer OK
If VALEUR<>2 : End : Endif
OK = 1
If filinfo(filpath("FIL","ADOVAL","fde",[M]DOSSIER),0)>0
 Local File =[M]DOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADW]VALEUR<>"" & filinfo(filpath("FIL","","",[F:ADW]VALEUR),0)>0
  OK = 1
 Endif
 Close Local File [ADW]
Endif
If !OK
 Call ERREUR(mess(208,133,1)) From GESECRAN : # Dossier historisé inexistant
 mkstat = 1 : End
Endif
End

Subprog AP_DOSSIER(VALEUR)
Variable Char VALEUR
End

Subprog AV_HISTO(VALEUR)
Variable Integer VALEUR
Local Integer OK
OK = 0
If [M]DOSSIER<>""
 If filinfo(filpath("FIL","ADOVAL","fde",[M]DOSSIER),0)>0
  Local File =[M]DOSSIER+".ADOVAL" [ADW]
  Read [ADW]ADW0 = "";"";"HISDOS"
  If !fstat & [F:ADW]VALEUR<>"" & filinfo(filpath("FIL","","",[F:ADW]VALEUR),0)>0
   OK = 1
  Endif
  Close Local File [ADW]
 Endif
Endif
If !OK
 VALEUR = 1
 Grizo HISTO
Else
 Actzo HISTO
Endif
End

Subprog S_FICHIER(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(10)
Call S_LIS_CHAR(VALEUR,PARAM,"","DOSINTEG","") From GACTION
End

Subprog C_STOVOL(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSSIER+".AVOLUME" [AVL]
Read [AVL]CODE=VALEUR
If fstat
 [M]REPERT = VALEUR
Else
 [M]REPERT = [F:AVL]ROOT
Endif
Call C_REPERT([M]REPERT)
End

