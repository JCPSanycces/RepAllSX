#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("BUDHIS","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()

If clalev([F:BUP])=0  : Local File BUDPAR  [BUP]  : Endif
Local Char PARAM(30), VALEUR(30), CODBUD(GLONBUP)


For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "codbud" : [L]CODBUD =[L]VALEUR : Break
  Endcase
 Endif
Next
Call LECTURE("BUP",[L]CODBUD,"") From CONTOBJ 
PARAM = num$([F:BUP]LEV)
Call SETPARAM("typbud",NBPAR,PARAMETRE,PARAM) From ETAT

End


