$ON_WMEDCTR
Onevent CONTROL Call C_WMEDCTR(zc) From W1HRMAT10
Onevent AFTER_CHANGE Gosub AMM_WMEDCTR From W1HRMAT10
Onevent BEFORE_INPUT Call AS_WMEDCTR(zc) From W1HRMAT10
Return

Subprog AS_WMEDCTR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_WMEDCTR(zc) From W1HRMAT10
Onkey 144 Titled GBOUTP Call P_WMEDCTR(zc) From W1HRMAT10
Onkey 146 Titled GBOUTA Call SA_WMEDCTR(zc) From W1HRMAT10
Gosub _AFF
End

Subprog C_WMEDCTR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
If !mkstat
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action CONTCTR
   Call CONTCTR(VALEUR,[M:EMP0]REFNUM) From DIVPAYE
   If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
  Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
Endif
Gosub _AFF
End

$AMM_WMEDCTR
Call AM_WMEDCTR(zc)
If !mkstat & GOBJET
 zoncou = "WMEDCTR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WMEDCTR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WMEDCTR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
Gosub _AFF
End

Subprog S_WMEDCTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTRLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTRLEG"
 PARMSK(1) = [M:EMP0]REFNUM
 PARMSK(2) = "[F:HRCTR]CTRDAT<=[M]WMEDDAT"
 PARMSK(3) = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M]WMEDDAT)"
 PARMSK(4) = GCURLEG
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 PARMSK(10) = ""
 PARMSK(11) = ""
 PARMSK(12) = [M:EMP0]REFNUM
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTRLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_WMEDCTR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WMEDCTR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_WMEDTYP
Onevent BEFORE_INPUT Call AS_WMEDTYP(zc) From W1HRMAT10
Onevent CONTROL Call C_WMEDTYP(zc) From W1HRMAT10
Onevent AFTER_AREA Call AP_WMEDTYP(zc) From W1HRMAT10
Onevent AFTER_CHANGE Gosub AMM_WMEDTYP From W1HRMAT10
Return

Subprog AS_WMEDTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46458,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRMDT
Call DEFHRMDT(VALEUR,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDT
If mkstat=2
 [M]WMEDTYP(INDIC) = VALEUR
 Affzo WMEDTYP(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_WMEDTYP(VALEUR) From SUBEML2
 If mkstat=2
  [M]WMEDTYP(INDIC) = VALEUR
  Affzo WMEDTYP(INDIC) : mkstat = 2
 Endif
 Onkey 129 Titled GBOUT1 Call B1_WMEDTYP(zc) From W1HRMAT10
 Onkey   2 Titled GBOUTS Call S_WMEDTYP(zc) From W1HRMAT10
 Onkey 144 Titled GBOUTP Call P_WMEDTYP(zc) From W1HRMAT10
 Onkey 146 Titled GBOUTA Call SA_WMEDTYP(zc) From W1HRMAT10
Endif
Gosub _AFF
End

Subprog C_WMEDTYP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
If !mkstat
 ## Action CONTHRMDT
 Call CONTHRMDT(VALEUR,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDT
 If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
  If !mkstat
   ## Action STD
   Call C_WMEDTYP(VALEUR) From SUBEML2
   If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog AP_WMEDTYP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_WMEDTYP(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
Gosub _AFF
End

$AMM_WMEDTYP
Call AM_WMEDTYP(zc)
If !mkstat & GOBJET
 zoncou = "WMEDTYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WMEDTYP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WMEDTYP(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWMEDTYP)")>indice
 [M]WMEDTYP(indice) = VALEUR
 Affzo ZWMEDTYP(indice)
Endif
Gosub _AFF
End

Subprog S_WMEDTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRMDT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRMDT"
 PARMSK(1) = [M]WMEDLEG
 PARMSK(2) = [F:FCY]LEGCPY
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRMDT","SUBHRMDT","") From GACTION
 GACTION = SAVACT
