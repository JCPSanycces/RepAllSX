#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT10 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:39"
A_USER  = "DOC"
A_STAMP = "20181109230439"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRVIS"
  If [M]NBRVIS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT10 [EMPA]
Gosub HORODAT
Local Inpbox "HRMAT10" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMPA] As [SIM_]
Grizo [EMPA]10
Grizo [EMPA]20
Grizo [EMPA]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMPA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=8 : Y1(0)=1 : Y2(0)=23
X1(1)=9 : X2(1)=74 : Y1(1)=1 : Y2(1)=13
X1(2)=9 : X2(2)=74 : Y1(2)=14 : Y2(2)=23
Return

$ON_NBRVIS
Onevent BEFORE_INPUT Call AS_NBRVIS From W1HRMAT10
Onevent CONTROL Call C_NBRVIS From W1HRMAT10
Return

Subprog AS_NBRVIS
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRVIS From SUBEML2
Gosub _AFF
End

Subprog C_NBRVIS
Local Decimal BASPAG
## Action STD
Call C_NBRVIS From SUBEML2
If mkstat : GERR = 1 : GZONE = "NBRVIS" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_MEDDAT
Onevent BEFORE_AREA Gosub AV_MEDDAT From W1HRMAT10
Return

$AV_MEDDAT
Chgfmt [M]MEDDAT(indice) With "DPzZ:"+GFMDAT4
Gosub _AFF
Return

$ON_MEDHOU
Onevent AFTER_AREA Call AP_MEDHOU(zc) From W1HRMAT10
Return

Subprog AP_MEDHOU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHM
 Call INIHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "MEDHOU" : GZNUM = 0 : Endif
Endif
Gosub _AFF
End

