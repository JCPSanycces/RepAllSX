End

Subprog C_MEDORG(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "MEDORG" : GZNUM = 35085 : Endif
If !mkstat
 ## Action CONTORG
 Call CONTORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "MEDORG" : GZNUM = 35085 : Endif
Endif
Gosub _AFF
End

