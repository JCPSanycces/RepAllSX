$ON_MEDPOS
Onevent BEFORE_AREA Gosub AV_MEDPOS From W1HRMAT10
Return

$AV_MEDPOS
## Action FMTPOSPAY
Call FMTPOSPAY(GPAYS) From TRTDIV
If GFMT<>""
 Chgfmt [M]MEDPOS(indice) With "KP:"+GFMT
Else
 Chgfmt [M]MEDPOS(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_MEDCTY
Onevent BEFORE_AREA Gosub AV_MEDCTY From W1HRMAT10
Return

$AV_MEDCTY
## Action FMTCTYPAY
Call FMTCTYPAY(GPAYS) From TRTDIV
If GFMT<>""
 Chgfmt [M]MEDCTY(indice) With "KP:"+GFMT
Else
 Chgfmt [M]MEDCTY(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_MEDNEX
Onevent BEFORE_AREA Gosub AV_MEDNEX From W1HRMAT10
Return

$AV_MEDNEX
Chgfmt [M]MEDNEX(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_WMEDLEG
Onevent INIT_AREA Call D_WMEDLEG(zc) From W1HRMAT10
Return

Subprog D_WMEDLEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]WMEDLEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_WMEDCPY
Return

$ON_WADD4
Onevent BEFORE_INPUT Call AS_WADD4(zc) From W1HRMAT10
Onevent INIT_AREA Call D_WADD4(zc) From W1HRMAT10
Return

Subprog D_WADD4(VALEUR)
Variable Integer VALEUR
If varinit([M]WADD4,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WADD4(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WADD4(VALEUR) From SUBEML2
If mkstat=2
 [M]WADD4(INDIC) = VALEUR
 Affzo WADD4(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


