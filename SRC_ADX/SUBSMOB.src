#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP
#--- Issue 95983
Raz [M:ALP]
[M:ALP]TRSTYP     = [M:SMO0]TRSTYP
[M:ALP]TRSCOD     = [M:SMO0]TRSCOD
[M:ALP]VCRTYP     = 20
[M:ALP]STOFCY     = [M:SMO0]STOFCY
[M:ALP]ITMREF     = [M:SMO1]ITMREF(NOL)
[M:ALP]PCU        = [M:SMO1]PCU(NOL)
[M:ALP]PCUSTUCOE  = [M:SMO1]PCUSTUCOE(NOL)
[M:ALP]QTY        = [M:SMO1]QTYSTU(NOL)
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [M:SMO0]IPTDAT
[M:ALP]DLVDAT     = [M:SMO0]IPTDAT
Raz [M:ALP]ALLDAT
Raz [M:ALP]STOLOC
[M:ALP]PECINTLOC  = 2
[M:ALP]PECSCOLOC  = 1
[M:ALP]PECPLFLOC  = 2
[M:ALP]PECCUNLOK  = 1
[M:ALP]PECQLYCTL  = 1
Raz [M:ALP]FILSTO
#--- Bug 90028
Raz [M:ALP]ALLQTY

[M:ALP]VCRNUM     = [M:SMO0]VCRNUM
[M:ALP]VCRLIN     = [M:SMO1]VCRLIN(NOL)
[M:ALP]VCRSEQ     = 0

If dim([M:SMO1]WRH)>0 [M:ALP]WRH=[M:SMO1]WRH(NOL) Endif
#--- TS 106217
If dim([M:SMO1]ECCVALMAJ)>0 [M:ALP]ECCVALMAJ=[M:SMO1]ECCVALMAJ(NOL) Endif
#---

Return

#########################################################################
$CHARGE_STOSOR
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
#-----------------------------------------------------------------------#
[M:SOR]WSTOSEQ   = [M:SMO1]WSTOSEQ(LNOL)
[M:SOR]TRSTYP    = [M:SMO0]TRSTYP
[M:SOR]TRSCOD    = [M:SMO0]TRSCOD
[M:SOR]TRFFCY    = ""
[M:SOR]VCRTYP    = 20
[M:SOR]VCRNUM    = [M:SMO0]VCRNUM
[M:SOR]VCRLIN    = [M:SMO1]VCRLIN(LNOL)
[M:SOR]MVTDES    = [M:SMO1]MVTDES(LNOL)
[M:SOR]STU       = [M:SMO1]STU(LNOL)
[M:SOR]PCU       = [M:SMO1]PCU(LNOL)
[M:SOR]PCUSTUCOE = [M:SMO1]PCUSTUCOE(LNOL)
[M:SOR]SORQTY    = [M:SMO1]QTYSTU(LNOL)   : # TS le 211103 : Attention ça doit être de l'UA
[M:SOR]SORQTYACT = [M:SMO1]QTYSTU(LNOL)
#--- TS 106217
[M:SOR]RETDAT    = [M:SMO0]IPTDAT
[M:SOR]DLVDAT    = [M:SMO0]IPTDAT
[M:SOR]PECPLFLOC = 2
[M:SOR]PECSCOLOC = 1
[M:SOR]PECQLYCTL = 1
[M:SOR]STOLOC    = ""
[M:SOR]XLOT      = ""
[M:SOR]XLOC      = ""
[M:SOR]XSTA      = ""
[M:SOR]CCECODS   = [F:DTR]STOCCECOD                         # Ana
[M:SOR]CUR       = GLOCALDEV
[M:SOR]GLOALLQTY = 0
If dim([M:SMO1]WRH)>0 [M:SOR]XWRH=[M:SMO1]WRH(LNOL) Endif
#--- TS 106217
If dim([M:SMO1]ECCVALMAJ)>0 [M:SOR]WECCVALMAJ=[M:SMO1]ECCVALMAJ(LNOL) Endif
#---
Return


#########################################################################
$APRES_STOSOR
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOR]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOR]SORQTY    contient la quantité US qui était à sortir
#   [M:SOR]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOR]PECQTY    contient la quantité US sortie
#   [M:SOR]PECQTYACT contient la quantité en UA sortie
#   [M:SOR]SHTQTY    contient la quantité US sortie manquante

If WGENR=1
    [M:SMO1]QTYSTU(LNOL) = [M:SOR]PECQTYACT+[M:SOR]SHTQTY
    If [M:SMO1]PCUSTUCOE(LNOL)=0
        [M:SMO1]PCUSTUCOE(LNOL)=1
    Endif
    [M:SMO1]QTYPCU(LNOL) = [M:SMO1]QTYSTU(LNOL)/[M:SMO1]PCUSTUCOE(LNOL)
Endif

Return

#########################################################################
$CHARGE_STOSOM
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSORM pour modif des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA       #
#-----------------------------------------------------------------------#
[M:SOM]TRSTYP    = [M:SMO0]TRSTYP
[M:SOM]TRSCOD    = [M:SMO0]TRSCOD
[M:SOM]TRFFCY    = ""
[M:SOM]VCRTYP    = 20
[M:SOM]VCRNUM    = [M:SMO0]VCRNUM
[M:SOM]VCRLIN    = [M:SMO1]VCRLIN(LNOL)
[M:SOM]STU       = [M:SMO1]STU(LNOL)
[M:SOM]PCU       = [M:SMO1]PCU(LNOL)
[M:SOM]PCUSTUCOE = [M:SMO1]PCUSTUCOE(LNOL)
[M:SOM]SORQTY    = [M:SMO1]QTYSTU(LNOL)
[M:SOM]SORQTYACT = [M:SMO1]QTYSTU(LNOL)
[M:SOM]DLVDAT    = [M:SMO0]IPTDAT
[M:SOM]PECPLFLOC = 2
[M:SOM]PECSCOLOC = 1
[M:SOM]PECQLYCTL = 1
[M:SOM]STOLOC    = ""
[M:SOM]XLOT      = ""
[M:SOM]XLOC      = ""
[M:SOM]XSTA      = ""
If dim([M:SMO1]WRH)>0 [M:SOM]XWRH=[M:SMO1]WRH(LNOL) Endif
#--- TS 106217
If dim([M:SMO1]ECCVALMAJ)>0 [M:SOM]WECCVALMAJ=[M:SMO1]ECCVALMAJ(LNOL) Endif
#---
Return

#########################################################################
$APRES_STOSOM
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - Coloriage de la ligne document si la quantité est nulle
# - etc ...
#-----------------------------------------------------------------------#
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOM]PECQTY    contient la quantité US sortie
#   [M:SOM]PECQTYACT contient la quantité en UA sortie
#   [M:SOM]SHTQTY    contient la quantité manquante

Local    Decimal LQTY, LQTYSTU, DELTAQTY, DELTAQTYSTU

# Maj du détail sortie diverse
Readlock [SMD]SMD0=[M:SMO0]VCRTYP;[M:SMO0]VCRNUM;[M:SMO1]VCRLIN(LNOL)
If fstat = 1 GOK = -1
   GLOCK = "$SMVTD"-[M:SMO0]VCRNUM-num$([M:SMO1]VCRLIN(LNOL))
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SMD",[M:SMO0]VCRNUM-num$([M:SMO1]VCRLIN(LNOL))) From GLOCK
   Return
Endif

# Quantité traitée
LQTYSTU = [M:SOM]PECQTYACT + [M:SOM]SHTQTY

If LQTYSTU = 0
   LQTY = 0
Elsif LQTYSTU = [F:SMD]QTYSTU
   LQTY = [F:SMD]QTYPCU
Else
   LQTY = LQTYSTU * [F:SMD]QTYPCU / [F:SMD]QTYSTU
Endif

If LQTYSTU = 0
   Delete [SMD]
    #----- Suppression  sections de la ligne de document  -----#     # ana
    Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
    If fstat=1                                                                                           # ana
       GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
    Endif                                                                                                # ana
Else
   [F:SMD]QTYPCU = LQTY
   [F:SMD]QTYSTU = LQTYSTU
   Rewrite [SMD]
Endif
If fstat GOK=0 : Call FSTA("SMD") From GLOCK : Return Endif

#-- Maj de l'entête livraison
Readlock [SMH]SMH0=[M:SMO0]VCRTYP;[M:SMO0]VCRNUM
If fstat = 1 GOK = -1
   GLOCK = "$SMVTH"-[M:SMO0]VCRNUM
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SMH",[M:SMO0]VCRNUM) From GLOCK
   Return
Endif

If LQTYSTU = 0
    Filter [SMD] Where VCRTYP=[M:SMO0]VCRTYP
&                    & VCRNUM=[M:SMO0]VCRNUM
    Look [SMD] First
    Filter [SMD]
    If fstat
        Delete [SMH]
        If fstat GOK=0 : Call FSTA("SMH") From GLOCK : Return Endif
        Raz [M:SMO0], [M:SMO1]
    Else
        Dela LNOL,1,[M:SMO1]NBLIG-1 [M:SMO1]NBLIG
        [M:SMO1]NBLIG -= 1
        #--- Issue 109079 by TS
        GRELITSMO = 1
    Endif
Else
   [M:SMO1]QTYPCU(LNOL) = LQTY
   [M:SMO1]QTYSTU(LNOL) = LQTYSTU
   #--- Issue 109079 by TS
   GRELITSMO = 1
Endif

Unlock [SMH]

#--- Issue 109079 by TS
#GRELITSMO = 1

Return

