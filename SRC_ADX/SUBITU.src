#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FILTRE" Gosub FILTRE
 When "LIENS"  Gosub LIENS
 When Default
Endcase
Return

# STANT 30/10/08 : ce filtre sert lorsqu'on vient de la fiche client, bouton "Articles-Client"
# Cela permet de filtrer sur le client
$FILTRE
  If CLE2<>"" and CLE1="" Then
    CRITERE = "BPCNUM='" + CLE2 + "'"
  Endif
Return


$LIENS
If [M]ITSTEX <> "" Then
  WITSTEX = 2
Else
  WITSTEX = 1
Endif
If [M]ITPTEX <> "" Then
  WITPTEX = 2
Else
  WITPTEX = 1
Endif

# MHB 06/11/08 : pour aligner les champs et leurs libellés, on passe par des champs alpha
If clalev([M:ITU0]) Then
  # Code article + désignation
  [M:ITU0]XITMREF = [M:ITU0]ITMREF
  If !clalev([F:ITM]) Then Local File ITMMASTER [F:ITM] Endif
  Read [F:ITM]ITM0=[M:ITU0]ITMREF
  If !fstat Then
    #[M:ITU0]XDESITMREF = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:ITU0]XDESITMREF, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  Endif

  # Code client + désignation
  [M:ITU0]XBPCNUM = [M:ITU0]BPCNUM
  If !clalev([F:BPC]) Then Local File BPCUSTOMER [F:BPC] Endif
  Read [F:BPC]BPC0=[M:ITU0]BPCNUM
  If !fstat Then
    [M:ITU0]XDESBPCNUM = [F:BPC]BPCNAM
  Endif
  #DLUBPC
  If !clalev([F:ITU]) Then Local File ITMBPC [F:ITU] Endif
  Read [F:ITU]ITU0=[M:ITU0]ITMREF;[M:ITU0]BPCNUM
  If !fstat Then
    [M:ITU0]XDLUBPC = [F:ITU]DLUBPC
     # Issue 121377 - 2017-02-07 by MAE : récupération à partir de la table ITMBPC
    If [M:ITU0]PCUSAUCO1 = 0 & [F:ITU]PCUSAUCOE1 <>0
      [M:ITU0]PCUSAUCO1 = [F:ITU]PCUSAUCOE1
    Endif
    If [M:ITU0]PCUSAUCO2 = 0 & [F:ITU]PCUSAUCOE2 <>0
      [M:ITU0]PCUSAUCO2 = [F:ITU]PCUSAUCOE2
    Endif
    # End issue 121377
  Endif
  #Fin DLUBPC


  [M:ITU0]BETFCY = [M:BPRC]BETFCY
Endif
#DLUBPC
If [F:ITM]EXYMGTCOD = 1
  Grizo [M]XDLUBPC
Else
  Actzo [M]XDLUBPC
Endif
#Fin DLUBPC

Return


$CHARGE_ITU
# Chargement des zones à saisir
## If [M:ITU]NBITU > 0 #pour effacer le bloc droite après suppr. ligne(22/12/99)
#MAE, le 08/10/08, ajout client
 [M:ITU]XBPCNUM            = [M:ITU]BPCNUM(NOL)
 [M:ITU]XITMREFBPC         = [M:ITU]ITMREFBPC(NOL)
 [M:ITU]XITMDESBPC         = [M:ITU]ITMDESBPC(NOL)
 If [M:ITU]ISAU(NOL)=""
    [M:ITU]ISAU(NOL)=[M:ITM3]SAU
    [M:ITU]ISAUSTUCOE(NOL)=[M:ITM3]SAUSTUCOE
 Endif
 [M:ITU]XSAU               = [M:ITU]ISAU(NOL)
 [M:ITU]XSAUSTUCOE         = [M:ITU]ISAUSTUCOE(NOL)
 If [M:ITU]XSAU=[M:ITM3]STU
    Diszo [M]XSAUSTUCOE
 Else
    Actzo [M]XSAUSTUCOE
 Endif
 [M:ITU]XPCU1              = [M:ITU]PCU1(NOL)
 [M:ITU]XPCUSAUCO1         = [M:ITU]PCUSAUCOE1(NOL)
 [M:ITU]XPCU2              = [M:ITU]PCU2(NOL)
 [M:ITU]XPCUSAUCO2         = [M:ITU]PCUSAUCOE2(NOL)
 [M:ITU]XPCK               = [M:ITU]PCK(NOL)
 [M:ITU]XPCKCAP            = [M:ITU]PCKCAP(NOL)
 [M:ITU]XITSTEX            = [M:ITU]ITSTEX(NOL)
 [M:ITU]XITPTEX            = [M:ITU]ITPTEX(NOL)
 [M:ITU]WITSTEX = 2
 If [M:ITU]XITSTEX = "" [M:ITU]WITSTEX = 1 Endif
 [M:ITU]WITPTEX = 2
 If [M:ITU]XITPTEX = "" [M:ITU]WITPTEX = 1 Endif
 [M:ITU]XBETFCY            = [M:ITU]BETFCY(NOL)
 [M:ITU]XDLUBPC               = [M:ITU]DLUBPC(NOL)        #DLUBPC
# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ITU]XLOAECCFLG = [M:ITU]LOAECCFLG(NOL)
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
#                                       hcb dlu deb
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
# Issue 113992
If dim([M:ITM2]EXYMGTCOD)>0
  LCOD = [M:ITM2]EXYMGTCOD
  LSHL = [M:ITM2]SHL
  LUOM = [M:ITM2]SHLUOM
  LDLU = [M:ITU]XDLUBPC
  Gosub CALDLULTI From SUBITM
  [M:ITU]DLULTI  = WDLULTI
  [M:ITU]XDLULTI = WDLULTI
Endif
# End issue 113992
#                                        hcb dlu fin

## Endif

#--- Bug 63896
#Affzo [ITU]10
Affzo [ITU]10,15,20,25
#---
Return


########################################
Subprog AS_NBITU
Local Integer NOL

NOL = nolign-1
[M]XLIGITU = nolign-1
Gosub CHARGE_ITU
Raz GBOUT1, GBOUT2
If [M:ITU]BPCNUM(NOL) <> ""
  # Bouton texte document vente
  GBOUT1 = mess(231,198,1)
  # Bouton texte bon préparation
  GBOUT2 = mess(229,198,1)
Endif
End

########################################
Subprog C_NBITU
Local Integer WRETOUR
If !GIMPORT
  #MAE, bg 84123
   If (nolign-1)<[M:ITU]NBITU
    GERR=4 : GMESSAGE = [M:ITU]BPCNUM(nolign-1)
   Endif
Endif
End

########################################
Subprog C_BPCNUM(VALEUR)
Variable Char     VALEUR
Local Integer NOL

Call UNICITE(VALEUR,[M]BPCNUM(0..NBITU-1)) From OBJDIV
If mkstat : End : Endif
End
#######################################
Subprog AP_BPCNUM(VALEUR)
Variable Char     VALEUR
If !GIMPORT & !GINTRA zonsui = "XITMREFBPC" : Endif # << ou mettre en APRES_MODIF
If !GIMPORT
   GERR=4 : GMESSAGE = VALEUR
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 13/01/2004 15:10:20 (LD)
##########################################################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
If [F:BPR]BPRNUM<>VALEUR
    Read [BPR]BPR0=VALEUR
    If fstat Raz [F:BPR] : Endif
Endif
[M]XBETFCY=[F:BPR]BETFCY
[M]BETFCY([M]XLIGITU)=[M]XBETFCY
Affzo [M]XBETFCY
# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ITU]LOAECCFLG([M:ITU]XLIGITU) = [M:ITS]LOAECCFLG
  [M:ITU]XLOAECCFLG = [M:ITU]LOAECCFLG([M:ITU]XLIGITU)
  Affzo [M:ITU]XLOAECCFLG
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
End
########################################
Subprog AM_XITMREFBPC (VALEUR)
Variable Char VALEUR
# pour empêcher de saisir le bloc de droite avant de saisir un client
If [M]NBITU=0
  mkstat = 2
Endif
[M]ITMREFBPC ([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End
# --------------------------------------- XITMDESBPC -----------------------------
Subprog AM_XITMDESBPC (VALEUR)
Variable Char VALEUR
[M]ITMDESBPC ([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

########################################
Subprog C_XSAU(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:ITU]BPCNUM([M]XLIGITU)<> ""
   mkstat=2 : GMESSAGE=mess(10,123,1) : # Zone obligatoire
Endif
End

Subprog AM_XSAU(VALEUR)
Variable Char    VALEUR()

# Bug 27121 - TS le 16/12/04 --> Inversion du if et du elsif
If VALEUR = [M:ITM3]STU
    [M]XSAUSTUCOE=1
    [M:ITU]ISAUSTUCOE([M]XLIGITU) = [M]XSAUSTUCOE
    Diszo [M]XSAUSTUCOE
Elsif VALEUR = [M:ITM3]SAU
    [M]XSAUSTUCOE=[M:ITM3]SAUSTUCOE
    [M:ITU]ISAUSTUCOE([M]XLIGITU) = [M]XSAUSTUCOE
    Actzo [M]XSAUSTUCOE
Else
    If clalev([F:TCO])=0 : Local File TABCOEFF [TCO] : Endif
    Read [TCO]TCO0=VALEUR;[M:ITM3]STU     # corrigé  22/01/04  (bug 20872)
    If !fstat [M]XSAUSTUCOE=[F:TCO]COEUOM : Endif
    Actzo [M]XSAUSTUCOE
Endif
Affzo [M]XSAUSTUCOE
[M]ISAU([M]XLIGITU)       = VALEUR
[M]ISAUSTUCOE([M]XLIGITU) = [M]XSAUSTUCOE
If [M:ITU]BPCNUM([M]XLIGITU) <> ""
  GMESSAGE =mess(307,199,1) : GERR=2   # "vérifiez les coeff rattachés"
Endif
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

# --------------------------------------- XSAUSTUCOE -----------------------------
########################################
Subprog C_XSAUSTUCOE(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [M]XSAU <> ""
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
End

Subprog AM_XSAUSTUCOE(VALEUR)
Variable Decimal VALEUR
[M]ISAUSTUCOE([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End
# --------------------------------------- XPCU1 -----------------------------
Subprog AM_XPCU1 (VALEUR)
Variable Char VALEUR
Local Integer J
[M]PCU1      ([M]XLIGITU) = VALEUR
# correction bug 8214  (05/03/01)
Call MODUNIT(VALEUR,[M:ITU]XSAU,[M:ITU]XPCUSAUCO1) From SUBITM

# si l'UC est parmi les UC de l'article : reprendre le coeff du tableau de PCU
# et passer par le coeff intermédiaire  (rajouté pour v 140)
J = find(VALEUR,[M:ITM3]PCU)
If J > 0
  # Issue 121377 - 2017-02-07 by MAE
  If [M]XSAUSTUCOE <> 0
    [M:ITU]XPCUSAUCO1 = [M:ITM3]PCUSTUCOE(J-1) / [M]XSAUSTUCOE
  Endif
Endif

Affzo [M:ITU]XPCUSAUCO1
[M:ITU]PCUSAUCOE1([M]XLIGITU) = [M:ITU]XPCUSAUCO1

If VALEUR = ""
   If !GIMPORT
      Effzo XPCUSAUCO1
   Endif
   [M]PCUSAUCOE1([M]XLIGITU) = 0
Endif
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XPCUSAUCO1 (VALEUR)
Variable Decimal VALEUR
[M]PCUSAUCOE1([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XPCU2 (VALEUR)
Variable Char VALEUR
Local Integer J
[M]PCU2      ([M]XLIGITU) = VALEUR
# correction bug 8214  (05/03/01)
Call MODUNIT(VALEUR,[M:ITU]XSAU,[M:ITU]XPCUSAUCO2) From SUBITM

# si l'UC est parmi les UC de l'article : reprendre le coeff du tableau de PCU
# et passer par le coeff intermédiaire  (rajouté pour v 140)
J = find(VALEUR,[M:ITM3]PCU)
If J > 0
  # Issue 121377 - 2017-02-07 by MAE
  If [M]XSAUSTUCOE <> 0
    [M:ITU]XPCUSAUCO2 = [M:ITM3]PCUSTUCOE(J-1) / [M]XSAUSTUCOE
  Endif
Endif

Affzo [M:ITU]XPCUSAUCO2
[M:ITU]PCUSAUCOE2([M]XLIGITU) = [M:ITU]XPCUSAUCO2

If VALEUR = ""
   If !GIMPORT
      Effzo XPCUSAUCO2
   Endif
   [M]PCUSAUCOE2([M]XLIGITU) = 0
Endif
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End

Subprog AM_XPCUSAUCO2 (VALEUR)
Variable Decimal VALEUR
[M]PCUSAUCOE2([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End


Subprog AS_XPCK(VALEUR)
Variable Char     VALEUR
#----- Ne faire l'init que si on entre réellement en saisie -----#
If find(status,92,93) : End : Endif : # Appui sur "Enregistrer" ou "Créer", ne rien faire !
If VALEUR=""
  VALEUR    =[M:ITS]PCK
  [M]XPCKCAP=[M:ITS]PCKCAP
  [M]PCKCAP([M]XLIGITU)=[M:ITS]PCKCAP
  If !GIMPORT  Affzo XPCKCAP : Endif
Endif
End


Subprog AM_XPCK (VALEUR)
Variable Char VALEUR
[M]PCK       ([M]XLIGITU) = VALEUR
If VALEUR = ""
   [M]XPCKCAP = 0
   If !GIMPORT
      Affzo XPCKCAP
   Endif
   [M]PCKCAP    ([M]XLIGITU) = 0
Endif
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End


Subprog AS_XPCKCAP(VALEUR)
Variable Decimal VALEUR
If [M]XPCK=""
  VALEUR=0
  [M]XPCKCAP=0
  [M]PCKCAP([M]XLIGITU)=0
  mkstat=2
Endif
End


Subprog AM_XPCKCAP (VALEUR)
Variable Decimal VALEUR
[M]PCKCAP    ([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
End


Subprog AS_XPCUSAUCO1(VALEUR)
Variable Decimal  VALEUR
Call COEFCNV([M]XPCU1,[M]XSAU,VALEUR) From SUBITM
If mkstat = 2  [M:ITU]PCUSAUCOE1([M]XLIGITU) = VALEUR : Endif
End

Subprog AS_XPCUSAUCO2(VALEUR)
Variable Decimal  VALEUR
Call COEFCNV([M]XPCU2,[M]XSAU,VALEUR) From SUBITM
If mkstat = 2  [M:ITU]PCUSAUCOE2([M]XLIGITU) = VALEUR : Endif
End

Subprog C_XPCUSAUCO1(VALEUR)
Variable Decimal  VALEUR
If VALEUR = 0 & [M]XPCU1 <> ""
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
End

Subprog C_XPCUSAUCO2(VALEUR)
Variable Decimal  VALEUR
If VALEUR = 0 & [M]XPCU2 <> ""
   GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
Endif
End

########################################
Subprog APRES_NBITU
# Spécifique à l'import --> Recharger indice pour sortir de la boucle de saisie
#If GIMPORT indice = [M]NBITU -1 Endif : # V130
If GIMPORT nolign = [M]NBITU  Endif    : # V140
End
##########################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran ITU) 06/10/2014 13:43:25 (MAE)
######################################################################################
Subprog C_XDLUBPC(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
Endif

End

Subprog AM_XDLUBPC(VALEUR)
Variable Decimal VALEUR
[M:ITU]DLUBPC    ([M]XLIGITU) = VALEUR
[M]UPDDAT    ([M]XLIGITU) = date$                #hcb 030505 29658
[M]UPDUSR    ([M]XLIGITU) = GUSER                #hcb 030505 29658
[M:ITU]FLMOD([M:ITU]XLIGITU) = 1         # FGR 03/02/2011 : X3SUIVI70453
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
# Issue 113992
If dim([M:ITM2]EXYMGTCOD)>0
  LCOD = [M:ITM2]EXYMGTCOD
  LSHL = [M:ITM2]SHL
  LUOM = [M:ITM2]SHLUOM
  LDLU = VALEUR
  Gosub CALDLULTI From SUBITM
  [M:ITU]DLULTI  = WDLULTI
  [M:ITU]XDLULTI = WDLULTI
  Affzo [M:ITU]XDLULTI
Endif
# End issue 113992

End

