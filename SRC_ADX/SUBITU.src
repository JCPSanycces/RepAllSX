Subprog AM_XLOAECCFLG(VALEUR)
Variable Integer VALEUR

  # FGR 23/04/2015 : X3SUIVI105605
  [M:ITU]LOAECCFLG([M:ITU]XLIGITU) = VALEUR
  [M:ITU]UPDDAT([M:ITU]XLIGITU) = date$
