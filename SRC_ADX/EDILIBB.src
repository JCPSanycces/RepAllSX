#********************************************************************
# Funprog GET_BPRNAM
#********************************************************************
#
#* Get the BPRNAM from BPARTNER using BPANUM
#* #*
#* @param WBPANUM
#* @param WBPRNAM
#*!
Funprog GET_BPRNAM(WBPANUM, WBPRNAM)
Value Char WBPANUM
Variable Char WBPRNAM

  Local Integer WOK
  WOK = [V]CST_AOK

  If WBPANUM <> ""
    Local File BPARTNER [BPR]
    Read [BPR]BPR0 = WBPANUM
    If fstat = [V]CST_AOK
      WBPRNAM = [F:BPR]BPRNAM
    Else
      WOK = [V]CST_AERROR
      WBPRNAM = ""
    Endif
    LogicClose File [BPR]
  Else
    WOK = [V]CST_AERROR
    WBPRNAM = ""
  Endif
End WOK

#********************************************************************
# Funprog GET_BPRNAMADD
#********************************************************************
#
#* Get the BPRNAM and BPAADD from BPARTNER using BPANUM
#* #*
#* @param WBPANUM
#* @param WBPRNAM
#* @param WBPAADD
#*!
Funprog GET_BPRNAMADD(WBPANUM, WBPRNAM, WBPAADD)
Value Char WBPANUM
Variable Char WBPRNAM
Variable Char WBPAADD
  Local Integer WOK
  WOK = [V]CST_AOK

  If WBPANUM <> ""
    Local File BPARTNER [BPR]
    Read [BPR]BPR0 = WBPANUM
    If fstat = [V]CST_AOK
      WBPRNAM = [F:BPR]BPRNAM
      WBPAADD = [F:BPR]BPAADD
    Else
      WOK = [V]CST_AERROR
      WBPRNAM = ""
      WBPAADD = ""
    Endif
    LogicClose File [BPR]
  Else
    WOK = [V]CST_AERROR
    WBPRNAM = ""
    WBPAADD = ""
  Endif
End WOK

#********************************************************************
# Funprog GET_BPADES
#********************************************************************
#
#* Get the BPADES from BPADDRESS using BPATYP+BPANUM+BPAADD
#*
#* @param WBPATYP
#* @param WBPANUM
#* @param WBPAADD
#* @param WBPADES
#*!
Funprog GET_BPADES(WBPATYP, WBPANUM, WBPAADD, WBPADES)
Value Integer WBPATYP
Value Char WBPANUM
Value Char WBPAADD
Variable Char WBPADES

  Local Integer WOK
  WOK = [V]CST_AOK

  If WBPAADD <> "" and WBPANUM <> ""
    Local File BPADDRESS [BPA]
    Read [BPA]BPA0 = WBPATYP;WBPANUM;WBPAADD
    If fstat = [V]CST_AOK
      WBPADES = [F:BPA]BPADES
    Else
      WOK = [V]CST_AERROR
      WBPADES = ""
    Endif
    LogicClose File [BPA]
  Else
    WOK = [V]CST_AERROR
    WBPADES = ""
  Endif
End WOK

#********************************************************************
# Funprog GET_BPAFLG
#********************************************************************
#
#* Get the BPCFLG and BPSFLG from BPARTNER using BPANUM
#*
#* @param WBPANUM
#* @param WBPCFLG
#* @param WBPSFLG
#*!
Funprog GET_BPAFLG(WBPANUM, WBPCFLG, WBPSFLG)
Value Char WBPANUM
Variable Integer WBPCFLG
Variable Integer WBPSFLG

  Local Integer WOK
  WOK = [V]CST_AOK

  If WBPANUM <> ""
    Local File BPARTNER [BPR]
    Read [BPR]BPR0 = WBPANUM
    If fstat = [V]CST_AOK
      WBPCFLG = [F:BPR]BPCFLG
      WBPSFLG = [F:BPR]BPSFLG
    Else
      WOK = [V]CST_AERROR
      WBPCFLG = 1
      WBPSFLG = 1
    Endif
    LogicClose File [BPR]
  Else
    WOK = [V]CST_AERROR
    WBPCFLG = 1
    WBPSFLG = 1
  Endif
End WOK


#********************************************************************
# Funprog GET_CPY
#********************************************************************
#
#* Get the CPY code associated to a FCY
#* @param WFCY   --> Site
#* @return WCPY  --> Company
#*!
Funprog GET_CPY(WFCY)
Value Char WFCY()
  Local Char WCPY(5) #GLONCPY
  WCPY = ""
  Local File FACILITY [FCY]
  Read [F:FCY]FCY0 = WFCY
  If !fstat #si ok
    WCPY = [F:FCY]LEGCPY
  Endif
  LogicClose File [FCY]
End WCPY

#********************************************************************
# Funprog GET_CPY_LEG
#********************************************************************
#
#
#********************************************************************
Funprog GET_CPY_LEG(WCPY)
Value Char WCPY

  Local Char WLEG(20) : WLEG = ""
  If WCPY <> ""
    Local File COMPANY [CPY]
    Read [CPY]CPY0 = WCPY
    If !fstat
      WLEG = [CPY]LEG
    Endif
    LogicClose File [CPY]
  Endif
End WLEG

#********************************************************************
# Funprog GET_FCY_LEG
#********************************************************************
#
#
#********************************************************************
Funprog GET_FCY_LEG(WCPY, WFCY)
Value Char WCPY
Value Char WFCY

  Local Char WLEG(20) : WLEG = ""
  If WCPY <> "" and WFCY <> ""
    Local File FACILITY [FCY]
    Read [FCY]FCY1 = WCPY;WFCY
    If !fstat
      WLEG = [FCY]LEG
    Endif
    LogicClose File [FCY]
  Endif
End WLEG

#********************************************************************
# Funprog GET_CATOPE
#********************************************************************
#
#
#********************************************************************
Funprog GET_CATOPE(WCATCOD, WERR) # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
Value Char WCATCOD
Variable Char WERR

  Local File EDICAT [ECA]
  Read [ECA]ECA0 = WCATCOD
  If fstat = [V]CST_AOK
     WCATOPE = [ECA]CATOPE
     If WCATOPE = 0 : WCATOPE = 2 : Endif #Create by default
  Else
    WCATOPE = 0
    WERR = mess(64,2006,1) #"Cannot find category code"
  Endif
  LogicClose File [ECA]
End WCATOPE

