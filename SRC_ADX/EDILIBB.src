#*******************************************************************
# Funprog PARSE_MY_LIST
#*******************************************************************
# @param WSTATUSCODE
# @param WRESHEAD
# @param WRESBODY
# @param WNUMBATCH
# @param WDOCID_TAB()(1..)
# @param WINS_UUID_TAB()(1..)
# @param WRES_FILENAME_TAB()(1..,1..)
# @param WRES_STA_TAB(1..)
# @param WRES_DIAG_SEVERITY_TAB()(1..,1..)
# @param WRES_DIAG_MESSAGE_TAB()(1..,1..)
# @param WMYLOG
# @return WSTATUS
#*!
Funprog PARSE_MY_LIST(WSTATUSCODE, WRESHEAD, WRESBODY, WRES_UUID_TAB)
Value Integer WSTATUSCODE
Value Clbfile WRESHEAD
Value Clbfile WRESBODY
Variable Char WRES_UUID_TAB()(1..)

  Local Integer WSTATUS      : WSTATUS = [V]CST_AOK
  Local Char WJSFUNCTION(50) : WJSFUNCTION = "MY_LIST"
  Gosub PARSER_MAIN
End WSTATUS

#############################################################################
$PARSER_MAIN
  Local Integer WOK          : WOK = [V]CST_AOK
  Local Integer I, J, K #useful counters
  Local Clbfile WJSON                    #JSON
  If WSTATUSCODE = 0 and maxtab(WRESHEAD) > 0
    WJSON = WRESHEAD
  Elsif WSTATUSCODE = 200 and maxtab(WRESBODY) > 0
    WJSON = WRESBODY
#  Elsif WSTATUSCODE = 500 and maxtab(WRESHEAD) > 0
  Elsif maxtab(WRESHEAD) > 0 #on traite tous les codes erreurs de la même manière (comme une erreur 500)
    WJSON = WRESHEAD
  Else
    #cas non prévu
    WSTATUS = [V]CST_AERROR
    Return
  Endif

  Local Char WTAB_OUT_PARAM(250)(1..)    #JSON
  Local Clbfile WTAB_OUT_VALUE(250)(1..)    #JSON #testRBA
  Local Char WTAB_OUT_PATH(250)(1..)     #JSON
  Local Char WTAB_OUT_FULLPATH(250)(1..) #JSON

#  #exception au traitement
  WOK = func JSON_PARSER(WJSON, WTAB_OUT_PARAM, WTAB_OUT_VALUE, WTAB_OUT_PATH, WTAB_OUT_FULLPATH)


  If WOK = [V]CST_AOK
    If WSTATUSCODE = 0 and maxtab(WRESHEAD) > 0
      Gosub TREAT_ERROR_0
      Case WJSFUNCTION
        When "JS_GENERATE_EDI_FILES"    : Gosub TREAT_AFTER_ERROR_0_JS_GENERATE_EDI_FILES
        When "JS_DECODE_EDI_FILES"      : Gosub TREAT_AFTER_ERROR_0_JS_DECODE_EDI_FILES
        When "JS_GENERATE_IMPORT_FILES" : Gosub TREAT_AFTER_ERROR_0_JS_GENERATE_IMPORT_FILES
        When "JS_PARSE_XSD"             : Gosub TREAT_AFTER_ERROR_0_JS_PARSE_XSD
        When "JS_GET_XML_PATH"          : Gosub TREAT_AFTER_ERROR_0_JS_GET_XML_PATH
        When "JS_VALIDATE_XML_MAPPING"  : Gosub TREAT_AFTER_ERROR_0_JS_VALIDATE_XML_MAPPING
      Endcase
    Elsif WSTATUSCODE = 200 and maxtab(WRESBODY) > 0
      Gosub TREAT_SUCCESS
      Case WJSFUNCTION
        When "JS_GENERATE_EDI_FILES"    : Gosub TREAT_AFTER_SUCCESS_JS_GENERATE_EDI_FILES
        When "JS_DECODE_EDI_FILES"      : Gosub TREAT_AFTER_SUCCESS_JS_DECODE_EDI_FILES
        When "JS_GENERATE_IMPORT_FILES" : Gosub TREAT_AFTER_SUCCESS_JS_GENERATE_IMPORT_FILES
        When "JS_PARSE_XSD"             : Gosub TREAT_AFTER_SUCCESS_JS_PARSE_XSD
        When "JS_GET_XML_PATH"          : Gosub TREAT_AFTER_SUCCESS_JS_GET_XML_PATH
        When "JS_VALIDATE_XML_MAPPING"  : Gosub TREAT_AFTER_SUCCESS_JS_VALIDATE_XML_MAPPING
        When "MY_LIST"                  : Gosub TREAT_AFTER_SUCCESS_MY_LIST
      Endcase
    Elsif maxtab(WRESHEAD) > 0 #on traite tous les codes erreurs de la même manière (comme une erreur 500)
      Gosub TREAT_ERROR_XXX
      Case WJSFUNCTION
        When "JS_GENERATE_EDI_FILES"    : Gosub TREAT_AFTER_ERROR_XXX_JS_GENERATE_EDI_FILES
        When "JS_DECODE_EDI_FILES"      : Gosub TREAT_AFTER_ERROR_XXX_JS_DECODE_EDI_FILES
        When "JS_GENERATE_IMPORT_FILES" : Gosub TREAT_AFTER_ERROR_XXX_JS_GENERATE_IMPORT_FILES
        When "JS_PARSE_XSD"             : Gosub TREAT_AFTER_ERROR_XXX_JS_PARSE_XSD
        When "JS_GET_XML_PATH"          : Gosub TREAT_AFTER_ERROR_XXX_JS_GET_XML_PATH
        When "JS_VALIDATE_XML_MAPPING"  : Gosub TREAT_AFTER_ERROR_XXX_JS_VALIDATE_XML_MAPPING
      Endcase
    Else
      #cas non prévu
      WSTATUS = [V]CST_AERROR
    Endif
  Else
    # technical error
    WSTATUS = [V]CST_AERROR
  Endif
Return

#############################################################################
$TREAT_ERROR_0
  Local Clbfile WRES_FATAL_MESSAGE

  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "message"
      WRES_FATAL_MESSAGE = WTAB_OUT_VALUE(I)
      Break
    Endif
  Next I
Return

#############################################################################
$TREAT_ERROR_XXX
  Local Char WRES_ERROR_STATUSCODE(50)
  Local Char WRES_ERROR_MESSAGE(250)
  Local Clbfile WRES_ERROR_EXCEPTION

  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "statusCode"
      WRES_ERROR_STATUSCODE = WTAB_OUT_VALUE(I)
    Endif
    If WTAB_OUT_PARAM(I) = "message"
      WRES_ERROR_MESSAGE = WTAB_OUT_VALUE(I)
    Endif
    If WTAB_OUT_PARAM(I) = "exception"
      WRES_ERROR_EXCEPTION = WTAB_OUT_VALUE(I)
    Endif
  Next I
Return

#############################################################################
$TREAT_SUCCESS
  Local Integer WLIMIT      : WLIMIT      = 10
  Local Integer WNBLIG      : WNBLIG      = 0
  Local Integer WNBCOL_FILE : WNBCOL_FILE = 0
  Local Integer WNBCOL_MESS : WNBCOL_MESS = 0
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_GENERATE_EDI_FILES
  For I = 1 To maxtab(WDOCID_TAB())
    WRES_STA_TAB(I)              = [V]CST_AERROR
    WRES_DIAG_MESSAGE_TAB(I, 1)  = WRES_FATAL_MESSAGE #"Error msg"
    WRES_DIAG_SEVERITY_TAB(I, 1) = mess(7,21,1) # Error
    WRES_UUID_TAB(I)             = WINS_UUID_TAB(I)
    WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH, WDOCID_TAB(I), WRES_DIAG_MESSAGE_TAB(I, 1), WRES_FATAL_MESSAGE, WRES_DIAG_SEVERITY_TAB(I, 1), WRES_UUID_TAB(I), WMYLOG)
  Next I
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_DECODE_EDI_FILES
  WRES_ERR = WRES_FATAL_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_GENERATE_IMPORT_FILES
  For I = 1 To maxtab(WDOCID_TAB())
    WRES_STA_TAB(I)              = [V]CST_AERROR
    WRES_DIAG_MESSAGE_TAB(I, 1)  = WRES_FATAL_MESSAGE #"Error msg"
    WRES_DIAG_SEVERITY_TAB(I, 1) = mess(7,21,1) # Error
    WRES_UUID_TAB(I)             = num$(NullUuid()) #WINS_UUID_TAB(i)
    WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH, WDOCID_TAB(I), WRES_DIAG_MESSAGE_TAB(I, 1), WRES_FATAL_MESSAGE, WRES_DIAG_SEVERITY_TAB(I, 1), WRES_UUID_TAB(I), WMYLOG)
  Next I
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_PARSE_XSD
  WRES_ERR = WRES_FATAL_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_GET_XML_PATH
  WRES_ERR = WRES_FATAL_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_0_JS_VALIDATE_XML_MAPPING
  WRES_ERR = WRES_FATAL_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_XXX_JS_GENERATE_EDI_FILES
  For I = 1 To maxtab(WDOCID_TAB())
    WRES_STA_TAB(I)              = [V]CST_AERROR
    WRES_DIAG_MESSAGE_TAB(I, 1)  = WRES_ERROR_MESSAGE
    WRES_DIAG_SEVERITY_TAB(I, 1) = WRES_ERROR_STATUSCODE
    WRES_UUID_TAB(I)             = WINS_UUID_TAB(I)
    WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH, WDOCID_TAB(I), WRES_DIAG_MESSAGE_TAB(I, 1), WRES_ERROR_EXCEPTION, WRES_DIAG_SEVERITY_TAB(I, 1), WRES_UUID_TAB(I), WMYLOG)
  Next I
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_XXX_JS_DECODE_EDI_FILES
  WRES_ERR = WRES_ERROR_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_XXX_JS_GENERATE_IMPORT_FILES
  For I = 1 To maxtab(WDOCID_TAB())
    WRES_STA_TAB(I)              = [V]CST_AERROR
    WRES_DIAG_MESSAGE_TAB(I, 1)  = WRES_ERROR_MESSAGE
    WRES_DIAG_SEVERITY_TAB(I, 1) = WRES_ERROR_STATUSCODE
    WRES_UUID_TAB(I)             = num$(NullUuid()) #WINS_UUID_TAB(i)
    WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH, WDOCID_TAB(I), WRES_DIAG_MESSAGE_TAB(I, 1), WRES_ERROR_EXCEPTION, WRES_DIAG_SEVERITY_TAB(I, 1), WRES_UUID_TAB(I), WMYLOG)
  Next I
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_XXX_JS_PARSE_XSD
  WRES_ERR = WRES_ERROR_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_ERROR_XXX_JS_GET_XML_PATH
  WRES_ERR = WRES_ERROR_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

$TREAT_AFTER_ERROR_XXX_JS_VALIDATE_XML_MAPPING
  WRES_ERR = WRES_ERROR_MESSAGE
  WSTATUS = [V]CST_AERROR
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_GENERATE_EDI_FILES
  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "uuid"
      WNBLIG = WNBLIG + 1
      WRES_UUID_TAB(WNBLIG) = WTAB_OUT_VALUE(I)

      For J = I + 1 To maxtab(WTAB_OUT_PARAM)
        If WTAB_OUT_PARAM(J) = "" and WTAB_OUT_PATH(J) = "fileNames" #on a une liste de fichiers pour l'uuid
          WNBCOL_FILE = WNBCOL_FILE + 1
          WRES_FILENAME_TAB(WNBLIG, WNBCOL_FILE) = WTAB_OUT_VALUE(J)

        Elsif WTAB_OUT_PARAM(J) <> "" and WTAB_OUT_PATH(J) = "$diagnoses"
          For K = J To maxtab(WTAB_OUT_PARAM)
            If WTAB_OUT_PARAM(K) = "$message"
              WNBCOL_MESS = WNBCOL_MESS + 1
              WRES_DIAG_MESSAGE_TAB(WNBLIG,WNBCOL_MESS) = WTAB_OUT_VALUE(K)
            Elsif WTAB_OUT_PARAM(K) = "$stackTrace"
              WRES_DIAG_STACK = WTAB_OUT_VALUE(K)
            Elsif WTAB_OUT_PARAM(K) = "$severity"
              WRES_DIAG_SEVERITY_TAB(WNBLIG,WNBCOL_MESS) = WTAB_OUT_VALUE(K)

                If WNBLIG <= maxtab(WDOCID_TAB())
                  WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH,
&                             WDOCID_TAB(WNBLIG),
&                             WRES_DIAG_MESSAGE_TAB(WNBLIG, WNBCOL),
&                             WRES_DIAG_STACK,
&                             WRES_DIAG_SEVERITY_TAB(WNBLIG, WNBCOL),
&                             WRES_UUID_TAB(WNBLIG),
&                             WMYLOG)
                Endif
              Break
            Endif
          Next K
        Else
          WNBCOL_FILE = 0
          WNBCOL_MESS = 0
          Break
        Endif
      Next J
      I = J-1
    Endif
  Next I

  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_DECODE_EDI_FILES
  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "uuid"
      WNBLIG = WNBLIG + 1
      WRES_UUID_TAB(WNBLIG) = WTAB_OUT_VALUE(I)

      If WTAB_OUT_PARAM(I+1) = "id"
        I = I + 1
        WRES_JSON_ID_TAB(WNBLIG) = WTAB_OUT_VALUE(I)
        If WTAB_OUT_PARAM(I+1) = "extId"
          I = I + 1
          WRES_JSON_EXTID_TAB(WNBLIG) = WTAB_OUT_VALUE(I)
        Endif

      Elsif WTAB_OUT_PARAM(I+1) <> "" and WTAB_OUT_PATH(I+1) = "$diagnoses"
        I = I + 1
        For J = I To maxtab(WTAB_OUT_PARAM)
          If WTAB_OUT_PARAM(J) = "$message"
            WNBCOL_MESS = WNBCOL_MESS + 1
            WRES_DIAG_MESSAGE_TAB(WNBLIG,WNBCOL_MESS) = WTAB_OUT_VALUE(J)
          Elsif WTAB_OUT_PARAM(J) = "$stackTrace"
            WRES_DIAG_STACK = WTAB_OUT_VALUE(J)
          Elsif WTAB_OUT_PARAM(J) = "$severity"
            WRES_DIAG_SEVERITY_TAB(WNBLIG,WNBCOL_MESS) = WTAB_OUT_VALUE(J)
            If WNBLIG <= maxtab(WRES_UUID_TAB())
              WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(WNUMBATCH,
&                             WRES_UUID_TAB(WNBLIG),
&                             WRES_DIAG_MESSAGE_TAB(WNBLIG, WNBCOL),
&                             WRES_DIAG_STACK,
&                             WRES_DIAG_SEVERITY_TAB(WNBLIG, WNBCOL),
&                             WRES_UUID_TAB(WNBLIG),
&                             WMYLOG)
            Endif
          Else
            Break
          Endif
        Next J
        WNBCOL_MESS = 0
      Endif
    Endif
  Next I

  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_GENERATE_IMPORT_FILES
  For I = 1 To maxtab(WTAB_OUT_PARAM)   ##JCC
    If WTAB_OUT_PARAM(I) = "uuid"
      WRES_UUID_TAB(I) = WTAB_OUT_VALUE(I)
      If WRES_UUID_TAB(I)<>"": WRES_FILENAME_TAB(I,I)= WTAB_OUT_VALUE(I+1) :Endif
      If WRES_FILENAME_TAB(I,I)<>"": WRES_STA_TAB(I)=[V]CST_AYES: Endif
      Break
    Endif
  Next I                                #JCC
  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_PARSE_XSD
  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "uuid"
      WRES_UUID  = WTAB_OUT_VALUE(I)
      Break
    Endif
  Next I
  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_GET_XML_PATH
  Local Char WSTR(250) : WSTR = ""
  For I = 1 To maxtab(WTAB_OUT_PARAM)
    If WTAB_OUT_PARAM(I) = "startIndex"
      WRES_STARTINDEX = WTAB_OUT_VALUE(I)
    Endif
    If WTAB_OUT_PARAM(I) = "count"
      WRES_COUNT = WTAB_OUT_VALUE(I)
    Endif
    If WTAB_OUT_PARAM(I) = "totalResult"
      WRES_TOTALRESULT = WTAB_OUT_VALUE(I)
    Endif

    If WTAB_OUT_PATH(I)="elems"
      If WTAB_OUT_PARAM(I) = "id"
        WNBCOL_FILE = WNBCOL_FILE + 1
        WRES_ID_TAB(WNBCOL_FILE) = WTAB_OUT_VALUE(I)
      Endif
      If WTAB_OUT_PARAM(I) = "path"
        WRES_PATH_TAB(WNBCOL_FILE) = WTAB_OUT_VALUE(I)
      Endif
      If WTAB_OUT_PARAM(I) = "type"
        WRES_TYPE_TAB(WNBCOL_FILE) = WTAB_OUT_VALUE(I)
      Endif
    Endif

    If pat(WTAB_OUT_PATH(I+1), "*elems.restriction*")
      I = I + 1
      While pat(WTAB_OUT_PATH(I), "*elems.restriction*")
        If WTAB_OUT_PARAM(I) <> ""
          WSTR = WSTR + WTAB_OUT_PARAM(I) + ":" + WTAB_OUT_VALUE(I) + "/"
        Else #enumeration
          If WTAB_OUT_PARAM(I) = ""
            If WTAB_OUT_PARAM(I-1) <> ""
              WSTR = WSTR + "enumeration:"+ WTAB_OUT_VALUE(I) + ","
            Else
              WSTR = WSTR + WTAB_OUT_VALUE(I) + ","
            Endif
          Endif
        Endif
        If pat(WTAB_OUT_PATH(I+1), "*elems.restriction*")
          I = I + 1
        Else
          Break
        Endif
      Wend
      If right$(WSTR,len(WSTR)) = ","
        WSTR = left$(WSTR,len(WSTR)-1)
      Endif
      If right$(WSTR,len(WSTR)) = "/"
        WSTR = left$(WSTR,len(WSTR)-1)
      Endif
      WRES_RESTRICTION_TAB(WNBCOL_FILE) = WSTR
      WSTR = ""
    Endif
  Next I

  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_JS_VALIDATE_XML_MAPPING
  WSTATUS = [V]CST_AOK
Return

#############################################################################
$TREAT_AFTER_SUCCESS_MY_LIST
  For I = 1 To maxtab(WTAB_OUT_PARAM)
    WNBLIG = WNBLIG + 1
    WRES_UUID_TAB(WNBLIG) = WTAB_OUT_VALUE(I)
  Next I
  WSTATUS = [V]CST_AOK
Return

#********************************************************************
# Funprog JSON_PARSER
#********************************************************************
#* This function allows to parse a JSON file and put all variables
#* and values into arrays
#*
#********************************************************************
# @param JSON JSON file
# @param TAB_OUT_PARAM returns array (1..) of parameters
# @param TAB_OUT_VALUE returns array (1..) of values
# @param TAB_OUT_PATH returns array (1..) of paths
# @param TAB_OUT_FULLPATH returns array (1..) of full paths
#*!
Funprog JSON_PARSER(JSON, TAB_OUT_PARAM, TAB_OUT_VALUE, TAB_OUT_PATH, TAB_OUT_FULLPATH)
Value Clbfile JSON
Variable Char TAB_OUT_PARAM()(1..)    #returns
Variable Clbfile TAB_OUT_VALUE()(1..)    #returns testRBA
Variable Char TAB_OUT_PATH()(1..)     #returns
Variable Char TAB_OUT_FULLPATH()(1..) #returns

  Local Integer WOK : WOK = [V]CST_AERROR

  #variables de travail
  Local Char TAB_FAT_KEY(250)(1..)
  Local Char TAB_KEY(250)(1..)
  Local Char TAB_FAT_PRO(250)(1..)
  Local Char TAB_PRO(250)(1..)
  Local Integer TAB_TYP(1..)
  Local Integer TAB_START(1..)
  Local Integer TAB_LENGTH(1..)
  Local Clbfile TAB_VALUE(1)(1..)#testRBA
  Local Char TAB_PATH(250)(1..)#testRBA
  Local Char TAB_PATH_OK(250)(1..)#testRBA
  Local Integer I, J

  #start here
  Local Instance  NODES(1..) Using C_ASYRJSO
  Local Instance  NODE   Using C_ASYRJSO : NODE=null

  WOK = func ASYRJSONPARSE.PARSEJSON(GACTX,JSON,NODES,NODE)
  If WOK <> [V]CST_AOK
    #error
  Else
    #building variables
    For I = 1 To maxtab(NODES)
      TAB_PRO(I)    = NODES(I).PRO
      TAB_TYP(I)    = NODES(I).TYP
      TAB_START(I)  = NODES(I).START
      TAB_LENGTH(I) = NODES(I).LENGTH

      If NODES(I).FAT <> null
        If NODES(I).FAT.FAT <> null
          If NODES(I).FAT.FAT.PRO <> ""
            TAB_FAT_KEY(I) = NODES(I).FAT.FAT.PRO+num$(NODES(I).FAT.FAT.START)+num$(NODES(I).FAT.FAT.LENGTH)
            TAB_FAT_PRO(I) = NODES(I).FAT.FAT.PRO
          Elsif NODES(I).FAT.PRO <> ""
            TAB_FAT_KEY(I) = NODES(I).FAT.PRO+num$(NODES(I).FAT.START)+num$(NODES(I).FAT.LENGTH)
            TAB_FAT_PRO(I) = NODES(I).FAT.PRO

          Else
            TAB_FAT_KEY(I) = ""
            TAB_FAT_PRO(I) = ""
          Endif

        Else
          TAB_FAT_KEY(I) = ""
          TAB_FAT_PRO(I) = ""
        Endif
      Else
        TAB_FAT_KEY(I) = ""
        TAB_FAT_PRO(I) = ""
      Endif
      TAB_KEY(I) = NODES(I).PRO+num$(NODES(I).START)+num$(NODES(I).LENGTH)
    Next I
    #getting values and pahs
    For I = 1 To maxtab(NODES)
    # NODES TYPES:
#    1: object
#    2: array
#    3: string
#    4: number
#    5: word
      If TAB_TYP(I) = 3 or TAB_TYP(I) = 4 or TAB_TYP(I) = 5
        TAB_VALUE(I) = mid$(NODES(I).CLB.CLB, TAB_START(I), TAB_LENGTH(I))
      Else
      Endif
      WOK = func JSON_PARSER_GET_PATH(TAB_FAT_PRO, TAB_KEY,TAB_FAT_KEY, I, TAB_PATH(I), TAB_PATH_OK(I))
    Next I
    #creating returns
    J = 1
    For I = 1 To maxtab(NODES)
#      If TAB_TYP(I) = 3 #value
      If TAB_TYP(I) = 3 or TAB_TYP(I) = 4 or TAB_TYP(I) = 5
        TAB_OUT_PARAM(J) = TAB_PRO(I)
        TAB_OUT_VALUE(J) = func VIREQUOTES(TAB_VALUE(I))
        TAB_OUT_PATH(J)  = TAB_PATH_OK(I)
        If left$(TAB_OUT_PATH(J), 1) = "."
          TAB_OUT_PATH(J) = right$(TAB_OUT_PATH(J),2)
        Endif
        If TAB_OUT_PATH(J) = ""
          TAB_OUT_FULLPATH(J)  = TAB_OUT_PARAM(J)
        Else
          TAB_OUT_FULLPATH(J)  = TAB_OUT_PATH(J)+"."+TAB_OUT_PARAM(J)
        Endif
        J = J + 1
      Endif
    Next I
  Endif

End WOK


Funprog VIREQUOTES(WSTR)
Value Clbfile WSTR
  Local Clbfile WSTRNEW
  Local Integer I
  For I = 1 To len(WSTR)
    If mid$(WSTR,I,1) <> '"'
      WSTRNEW = WSTRNEW + mid$(WSTR,I,1)
    Endif
  Next I

End WSTRNEW

#********************************************************************
# Funprog JSON_PARSER_GET_PATH
#********************************************************************
#* This function is used by the function JSON_PARSER
#* It allows to get the full path of a parameter
#*
#********************************************************************
# @param WTAB_FAT_PRO
# @param WTAB_KEY
# @param WTAB_FAT_KEY
# @param WPOS
# @param WPATH
# @param WPATH_OK
#*!
Funprog JSON_PARSER_GET_PATH(WTAB_FAT_PRO, WTAB_KEY, WTAB_FAT_KEY, WPOS, WPATH, WPATH_OK)
Value Char WTAB_FAT_PRO()(1..)
Value Char WTAB_KEY()(1..)
Value Char WTAB_FAT_KEY()(1..)
Value Integer WPOS
Variable Char WPATH()
Variable Char WPATH_OK()

  Local Integer WOK, I

  If WTAB_FAT_KEY(WPOS) = "" or WTAB_FAT_KEY(WPOS) = "00"
    WPATH = ""
    WPATH_OK = "" #WTAB_FAT_PRO(WPOS)
  Else #on a un père
    WPATH = WTAB_FAT_KEY(WPOS)
    WPATH_OK = WTAB_FAT_PRO(WPOS)
    #on recherche si il a lui-même un père recursivement
    WOK = func JSON_PARSER_GET_FAT(WTAB_FAT_PRO, WTAB_KEY, WTAB_FAT_KEY, WPOS, WPATH, WPATH_OK)
  Endif

End WOK

#********************************************************************
# Funprog JSON_PARSER_GET_FAT
#********************************************************************
#* This function is used by the function JSON_PARSER_GET_PATH
#* It allows to get the fathers of a parameter to build the path
#*
#********************************************************************
# @param WTAB_FAT_PRO
# @param WTAB_KEY
# @param WTAB_FAT_KEY
# @param WPOS
# @param WPATH
# @param WPATH_OK
#*!
Funprog JSON_PARSER_GET_FAT(WTAB_FAT_PRO, WTAB_KEY, WTAB_FAT_KEY, WPOS, WPATH, WPATH_OK)
Value Char WTAB_FAT_PRO()(1..)
Value Char WTAB_KEY()(1..)
Value Char WTAB_FAT_KEY()(1..)
Value Integer WPOS
Variable Char WPATH()
Variable Char WPATH_OK()

  Local Integer WOK, I

  For I = 1 To maxtab(WTAB_KEY)
    If WTAB_KEY(I) = WTAB_FAT_KEY(WPOS)
        WPATH    = WTAB_FAT_KEY(I)+"."+WPATH
        If left$(WPATH, 1) = "."
          WPATH = right$(WPATH,2)
        Endif
        WPATH_OK = WTAB_FAT_PRO(I)+"."+WPATH_OK
        If left$(WPATH_OK, 1) = "."
          WPATH_OK = right$(WPATH_OK,2)
        Endif
      WOK = func JSON_PARSER_GET_FAT(WTAB_FAT_PRO, WTAB_KEY, WTAB_FAT_KEY, I, WPATH, WPATH_OK)
    Endif
  Next I

End WOK

