###########################################################
## Programme de gestion des questions                    ##
###########################################################
## écrit en novembre 1997 par Adeline Lenoir             ##
###########################################################
$ACTION
Case ACTION
  When "SETBOUT"     : Gosub SETBOUT
  When "AVANT_MODFIC": Gosub AVANT_MODFIC
  When "ANNULE"      : Gosub ANNULE
  When "CREATION"    : Gosub CREATION
  When "MODIF"       : Gosub MODIF
  When "CHANGE"      : Call  CHANGE_AXX ("QLYCRDQST", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
############################################################
$SETBOUT
# cas du tunnel pour consultation
Case GCONSULT
  When 1 :
    Call VIREBOUT(CHAINE,"CMADH") From GOBJET
  When 2 :
    Call VIREBOUT(CHAINE,"RCMAD><LI09SH") From GOBJET
Endcase
Return


$AVANT_MODFIC

# Modifier tous les articles de cette catégorie si le type est modifié
If ([M]LOKTYP <> [F:QLQ]LOKTYP)  & ([M]LOKTYP = 4 | [F:QLQ]LOKTYP = 4)
   If clalev([F:QLC])=0  Local File QLYCRD [QLC]  Endif
   Local Char MES(255)
   Local Integer I
   Local Integer Y
   Raz I
   Raz Y
   MES = mess(86,187,1)+"\"           # suite a la modification du type blocage vous devez revalider les fiches
   Filter [QLC] Where QSTNUM = [F:QLQ]QSTNUM
&               Order By Key QLC0
   Columns [QLC] (QLYCRD)
   For [QLC]
       If len(MES) > 240
          MES += ", ...."
          Break
       Endif
       I += 1
       If I > 7
          MES += "\"
          Raz I
          Raz Y
       Endif
       If Y = 0
          MES += [F:QLC]QLYCRD
          Y = 1
       Else
          MES += ","+[F:QLC]QLYCRD
       Endif
   Next
   Filter  [QLC]
   Columns [QLC]
   If I <> 0
      Call MESSAGE(MES) From GESECRAN
   Endif
Endif


Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="QLYCRDQST" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return  # FGR 17/12/2009 : X3SUIVI60986
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]QSTDESAXX,"QLYCRDQST","QSTDESAXX",[M]QSTNUM,"") From ATEXTRA
Call MAJTEXTRA([M]QSTSHOAXX,"QLYCRDQST","QSTSHOAXX",[M]QSTNUM,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]QSTDESAXX,"QLYCRDQST","QSTDESAXX",[M]QSTNUM,"") From ATEXTRA
Call MAJTEXTRA([M]QSTSHOAXX,"QLYCRDQST","QSTSHOAXX",[M]QSTNUM,"") From ATEXTRA

Return
############################################################
Subprog AS_TCT(VALEUR)
Variable Char     VALEUR
If [M:QST1]DEMASWTYP > 2 | [M:QST1]DEMCTLTYP > 1
  mkstat = 2
Endif
End
############################################################
Subprog C_TCT(VALEUR)
Variable Char     VALEUR
If [M]DEMCTLTYP = 1 & VALEUR = ""
  GMESSAGE = mess(10,123,1)
  mkstat   = 2
Endif
If VALEUR <> ""
  Read [TCT]TCT0=VALEUR;1
  If ! fstat & [F:TCT]TCTTYP <> [M]DEMASWTYP
    GMESSAGE=mess(49,199,1)
    mkstat=2
  Endif
Endif
End
############################################################
Subprog AS_DEMCTLTYP(VALEUR)
Variable Integer  VALEUR
If [M:QST1]DEMASWTYP > 2
  VALEUR = 3
  mkstat = 2
Endif
End
############################################################
Subprog AM_DEMCTLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR = 1
  Effzo [M]STRVAL,ENDVAL,ALPSTRVAL,NUMSTRVAL,ALPENDVAL,NUMENDVAL
  Effzo [M]STRVALFOR,ENDVALFOR,NMNVAL,ALPNMNVAL,NUMNMNVAL     # hcb V6CQ
Endif
If VALEUR = 3
  Effzo [M]STRVAL,ENDVAL,ALPSTRVAL,NUMSTRVAL,ALPENDVAL,NUMENDVAL,TCT
  Effzo [M]STRVALFOR,ENDVALFOR,NMNVAL,ALPNMNVAL,NUMNMNVAL     # hcb V6CQ
  [M]LOKTYP = 0
  [M]OSDASW = 0
  Affzo [M]LOKTYP
  Affzo [M]OSDASW
Endif
If VALEUR = 2
  [M]TCT=""
  Affzo [M]TCT
Endif
If VALEUR<>3 & [M]OSDASW=0
  [M]OSDASW = 1
  [M]LOKTYP = 1
  Affzo [M]OSDASW
  Affzo [M]LOKTYP
Endif
End
############################################################
Subprog AS_STRVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMCTLTYP <> 2 | [M]STRVALFOR <> ""  # hcb V6CQ
  mkstat=2
Endif
End
############################################################
Subprog AV_STRVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
  VALEUR=[M]ALPSTRVAL
Else
  VALEUR=num$([M]NUMSTRVAL)
  If [M]NUMSTRVAL=0 & [M]DEMCTLTYP=1
    VALEUR=""
  Endif
Endif
End
############################################################
Subprog AM_STRVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   [M]ALPSTRVAL=VALEUR
Else
   [M]NUMSTRVAL=val(VALEUR)
Endif
End
############################################################
Subprog AS_ENDVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMCTLTYP <> 2 | [M]ENDVALFOR <> ""  # hcb V6CQ
   mkstat=2
Endif
End
############################################################
Subprog AV_ENDVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   VALEUR=[M]ALPENDVAL
Else
   VALEUR=num$([M]NUMENDVAL)
   If [M]NUMENDVAL=0 & [M]DEMCTLTYP=1
      VALEUR=""
   Endif
Endif
End
############################################################
Subprog AM_ENDVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   [M]ALPENDVAL=VALEUR
Else
   [M]NUMENDVAL=val(VALEUR)
Endif
End


############################################################
Subprog C_ENDVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   [M]ALPENDVAL=VALEUR
#   Call CTLALPV([M]ALPENDVAL,[M]ALPSTRVAL) From CONTX3
   Call CTLALPVAL([M]ALPENDVAL,[M]ALPSTRVAL) From CONTX3
   # FQ 55326
   If mkstat=2 [M]ALPENDVAL=[M]ENDVAL Endif
Else
   [M]NUMENDVAL=val(VALEUR)
#   Call CTLNUMV([M]NUMENDVAL,[M]NUMSTRVAL) From CONTX3
   Call CTLNUMVAL([M]NUMENDVAL,[M]NUMSTRVAL) From CONTX3
   # FQ 55326
   If mkstat=2 [M]NUMENDVAL=val([M]ENDVAL) Endif
Endif
End
############################################################
Subprog AS_DEFASW(VALEUR)
Variable Char     VALEUR
Case [M]DEMASWTYP
  When 3 : mkstat = 2
Endcase
End
############################################################
Subprog AV_DEFASW(VALEUR)
Variable Char     VALEUR
Case [M]DEMASWTYP
  When 1 : VALEUR= [M]ALPDEFASW
  #-- Si la question est de type borne et que l'on a 0
  #-- C'est qu'aucune valeur par défaut n'a été saisie
  #-- Si 0 ne fait pas parti des bornes
  When 2 :
       If num$([M]NUMDEFASW)<> "" & [M]DEMCTLTYP = 1
          Read [TCT]TCT1=[M]TCT;"";[M]NUMDEFASW
          If fstat
            Raz VALEUR
          Else
           VALEUR= num$([M]NUMDEFASW)
          Endif
        Endif
        If num$([M]NUMDEFASW)<>"" & [M]DEMCTLTYP = 2
           # Issue 98612 - 2014-05-15 by SR : Seulement si pas de formule
           If [M]NUMDEFASW < [M]NUMSTRVAL | [M]NUMDEFASW > [M]NUMENDVAL &  [M]STRVALFOR = ""
               Raz VALEUR
           Else
               VALEUR= num$([M]NUMDEFASW)
           Endif
        Endif

        If num$([M]NUMDEFASW)<>"" & [M]DEMCTLTYP = 3         # 020305 28706
           VALEUR= num$([M]NUMDEFASW)                        # 020305 28706
        Endif                                                # 020305 28706

  When 4 : VALEUR= num$([M]NUMDEFASW)
Endcase
End
############################################################
Subprog AM_DEFASW(VALEUR)
Variable Char     VALEUR
Case [M]DEMASWTYP
  When 1 : [M]ALPDEFASW = VALEUR
  When 2 : [M]NUMDEFASW = val(VALEUR)
  When 4 : [M]NUMDEFASW = val(VALEUR)
Endcase
End
############################################################
Subprog C_DEFASW(VALEUR)
Variable Char    VALEUR()
Local File TABCTL [TCT]

Case [M]DEMASWTYP
  When 1 :
   #-- Zone alpha
   [M]ALPDEFASW=VALEUR
   If VALEUR <> "" & [M]DEMCTLTYP = 1
      Read [TCT]TCT1=[M]TCT;VALEUR;0
      If fstat
         GMESSAGE=mess(45,199,1)
         mkstat=2
      Endif
   Endif
   # Issue 98612 - 2014-05-15 by SR : Seulement si pas de formule
   If VALEUR <> "" & [M]DEMCTLTYP = 2 &  [M]STRVALFOR = ""
      If VALEUR < [M]ALPSTRVAL | VALEUR > [M]ALPENDVAL
         GMESSAGE=mess(46,199,1)
         mkstat=2
      Endif
   Endif
  When 2 :
   #-- Zone numérique
   If VALEUR<>""
       [M]NUMDEFASW=val(VALEUR)
       If num$([M]NUMDEFASW)<> "" & [M]DEMCTLTYP = 1
          Read [TCT]TCT1=[M]TCT;"";[M]NUMDEFASW
          If fstat
             GMESSAGE=mess(45,199,1)
             mkstat=2
          Endif
        Endif
        # Issue 98612 - 2014-05-15 by SR : Seulement si pas de formule
        If num$([M]NUMDEFASW)<>"" & [M]DEMCTLTYP = 2 &  [M]STRVALFOR = ""
           If [M]NUMDEFASW < [M]NUMSTRVAL | [M]NUMDEFASW > [M]NUMENDVAL
              GMESSAGE=mess(46,199,1)
              mkstat=2
           Endif
        Endif
    Endif
  When 4 :
    If VALEUR = "0" | VALEUR = "1"
      [M]NUMDEFASW=val(VALEUR)
    Else
      mkstat = 2
    Endif
Endcase
End
############################################################
Subprog AS_OSDASW(VALEUR)
Variable Integer  VALEUR
If [M]DEMASWTYP > 2 | [M]DEMCTLTYP = 3
  mkstat=2
Endif
End
############################################################
Subprog AV_OSDASW(VALEUR)
Variable Integer  VALEUR
If VALEUR = 1
  [M]LOKTYP=1
  Affzo [M]LOKTYP
Endif
End
############################################################
Subprog AM_OSDASW(VALEUR)
Variable Integer  VALEUR
If VALEUR = 1
  [M]LOKTYP=1
  Affzo [M]LOKTYP
Endif
End
############################################################
Subprog AS_DEMASWTYP(VALEUR)
Variable Integer VALEUR
If !find(GREP,"C","D")
  mkstat=2
Endif
GMENLOC(5) = 1
# FQ 50451 GA 11/2008
GMENLOC(6) = 1
End
############################################################
Subprog AP_DEMASWTYP(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
############################################################
Subprog AV_DEMASWTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=3 | VALEUR=4
  [M]DEMCTLTYP=3 : [M]OSDASW=0 : [M]LOKTYP=0
  Affzo [M]DEMCTLTYP
  Affzo [M]OSDASW
  Affzo [M]LOKTYP
Endif
End
############################################################
Subprog AS_LOKTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(2) = 1
If [M]DEMASWTYP > 2 | [M]OSDASW<2 | [M]DEMCTLTYP=3
  mkstat = 2
Endif
End

