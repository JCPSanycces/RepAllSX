Subprog AS_NMNVAL(VALEUR)
Variable Char    VALEUR()
If [M]DEMCTLTYP <> 2
  mkstat=2
Endif

End

Subprog AV_NMNVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   VALEUR=[M]ALPNMNVAL
Else
   VALEUR=num$([M]NUMNMNVAL)
   If [M]NUMNMNVAL=0 & [M]DEMCTLTYP=1
      VALEUR=""
   Endif
Endif
End

Subprog AM_NMNVAL(VALEUR)
Variable Char     VALEUR
If [M]DEMASWTYP=1
   [M]ALPNMNVAL=VALEUR
Else
   [M]NUMNMNVAL=val(VALEUR)
Endif
End


Subprog C_NMNVAL(VALEUR)
Variable Char    VALEUR()
If [M]DEMASWTYP=1
   [M]ALPNMNVAL=VALEUR
Else
   [M]NUMNMNVAL=val(VALEUR)
Endif

If [M]DEMASWTYP=1
   If [M]ALPSTRVAL <> ""
      If [M]ALPNMNVAL < [M]ALPSTRVAL
         GMESSAGE=mess(46,199,1)
         mkstat = 2
      Endif
   Endif
   If [M]ALPENDVAL <> ""
      If [M]ALPNMNVAL > [M]ALPENDVAL
         GMESSAGE=mess(46,199,1)
         mkstat = 2
      Endif
   Endif

Else
   If [M]NUMSTRVAL <> 0
      If [M]NUMNMNVAL < [M]NUMSTRVAL
         GMESSAGE=mess(46,199,1)
         mkstat = 2
      Endif
   Endif
   If [M]NUMENDVAL <> 0
      If [M]NUMNMNVAL > [M]NUMENDVAL
         GMESSAGE=mess(46,199,1)
         mkstat = 2
      Endif
   Endif
Endif


End




# hcb V6CQ deb

Subprog C_RPLQLYCRD(VALEUR)
Variable Char    VALEUR()
If clalev([F:QLC3]) = 0 : Local File QLYCRD [QLC3] : Endif
If VALEUR <> "" & VALEUR <> [M]RPLQLYCRD
   Read [QLC3]QLC0=VALEUR
   If fstat
      GMESSAGE=mess(23,100,1)
      mkstat=2
   Endif
Endif

End

Subprog AM_LOKTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 4
   Raz [M]RPLQLYCRD
   Affzo [M]RPLQLYCRD
Endif
End

Subprog AS_RPLQLYCRD(VALEUR)
Variable Char    VALEUR()
If [M]LOKTYP <> 4
   mkstat = 2
Endif

End

Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M:QST1]UOM
   If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
   If [F:TUN]UOM <> VALEUR
      Read [TUN]TUN0 = VALEUR
      If fstat
         Raz [F:TUN]
      Endif
   Endif
   [M:QST1]UOMDEC = [F:TUN]UOMDEC
   Affzo [M:QST1]UOMDEC
Endif

End

Subprog AM_STRVALFOR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Effzo [M]STRVAL
   Effzo [M]ALPSTRVAL
   Effzo [M]NUMSTRVAL
   Affzo [M]STRVAL
Endif

End

Subprog AM_ENDVALFOR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Effzo [M]ENDVAL
   Effzo [M]ALPENDVAL
   Effzo [M]NUMENDVAL
   Affzo [M]ENDVAL
Endif

End
# hcb V6CQ fin
