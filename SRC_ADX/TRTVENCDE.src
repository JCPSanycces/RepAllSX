#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS LIES aux COMMANDES dans les VENTES                   #
#                                                                       #
#########################################################################
#                                                                       #
#-----------------------------------------------------------------------#
# ACTIONS                                                               #
#-----------------------------------------------------------------------#
#                                                                       #
# TRTCLESOH  : Solde d'une commande                                     #
# DIVSOHCLE  : Solde d'une commande depuis le workflow                  #
# TRTCLESOQ  : Solde d'une ligne de commande                            #
#                                                                       #
#-----------------------------------------------------------------------#
# Traitements                                                           #
#-----------------------------------------------------------------------#
#                                                                       #
# Subprog ALICDE (TYPCDE,TYPCLI,VALEUR)                                 #
#      Alimentation des masques SOH et SOR à partir des clients         #
#                                                                       #
# Subprog ALIORDMIN(BPCORD, CURORD, DATORD, ORDMIN)                     #
#      Alimentation du montant mini de cde                              #
#       dans la devise de la commande                                   #
#                                                                       #
# Subprog C_BPCORD(VALEUR)                                              #
#      Contrôle si le client commande est OK                            #
#                                                                       #
# Subprog ALIFMI (WITMREF,WSTOFCY,WFMI)                                 #
#      Alimentation du code FMI dans les lignes de commandes            #
#                                                                       #
# Subprog RECH_DERCDESQH()                                              #
#      Recherche dernier no commande issue du devis                     #
#                                                                       #
# Subprog RECH_DERCDESQD()                                              #
#      Recherche dernier no commande ligne devis suite à suppression    #
#                                                                       #
# Subprog ALISQHSOH()                                                   #
#      Alimentation des masques commandes à partir du 1er devis         #
#                                                                       #
# Subprog ALISQDSOH(NOL,WQTACDE)                                        #
#      Alimentation du masque détail commande à partir d'une ligne devis#
#                                                                       #
# Subprog DIVSOHCLE(WSOHNUM,WMSGFLG)                                    #
#      Solde d'une commande                                             #
#                                                                       #
# Subprog DIVCLESOH(WSOHNUM, WCCLREN)                                   #
#      Solde d'une commande                                             #
#                                                                       #
# Subprog DIVCLESOQ(WSOHNUM, WSOPLIN, WSOQSEQ, WCCLREN)                 #
#      Solde d'une ligne de commande                                    #
#                                                                       #
# Subprog REWSOH                                                        #
#      Réécriture fichier entête commande                               #
#                                                                       #
# Subprog REWSOQ                                                        #
#      Réécriture fichier détail commande quantités                     #
#                                                                       #
# Subprog REWSOP                                                        #
#      Réécriture fichier détail commande prix                          #
#                                                                       #
# Subprog MAJSTASOH(LSOHNUM, LRET)  )                                   # : # 86757
#      Recalcul et mis à jour des statuts d'une commande                # : # 86757
#                                                                       #
# funprog BPCOSTBLK(PBPCNUM)                                            #
#      Vérifie si le client est bloqué                                  #
#-----------------------------------------------------------------------#
# Etiquettes                                                            #
#-----------------------------------------------------------------------#
#                                                                       #
# $VERIF_LIGNE_ITF                                                      #
#   Verif. pr les articles du tableau SOH4 existence enr. article-site  #
#          (site expédition ou site réception pour l'inter-site)        #
#########################################################################
# Issue 111181 - 20151012 by LD : order button in quoted management : SOQSTA not fed
# Issue 119479 - 20161118 by LD : Shipment site inherited from header Quote: wrong in SOF
# Issue X3-38564 - 20170529 by LD : Header text from customser not inherited in SOF when picking quot
# Issue X3-70669 - 20180814 by LD : Remains a global allocation in a sales order

$ACTION
#--- Actions liés au type traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "AVANT_PAR"  : Gosub AVANT_PAR
 When "EXEC"       : Gosub EXEC
Endcase
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"      : Gosub DEBUT
 When "ABA"        : Gosub ABA
 When "OK"         : Gosub OK
 When "END"        : Gosub FIN            : # Bug 69265
 When "APRES_MODIF": Gosub APRES_MODIF
Endcase

Return
#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
 When "TRTCLESOQ"    : Gosub INI_TRTCLESOQ
Endcase
Return
$AVANT_PAR
Case GACTION
 When "TRTCLESOH"    : Gosub AVTPAR_TRTCLESOH
 When "TRTCLESOQ"    : Gosub AVTPAR_TRTCLESOQ
Endcase
Return
$EXEC
Case GACTION
 When "TRTCLESOH"    : Gosub EXEC_TRTCLESOH
 When "TRTCLESOQ"    : Gosub EXEC_TRTCLESOQ
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$DEBUT
Case GACTION
 When "TRTCLESOH"  : Raz [M:SCCR]CCLREN
                     Affzo [M:SCCR]1-99
 When "TRTCLESOQ"  : Local Integer SAVNOLIGN : SAVNOLIGN=nolign
                     Raz [M:SCCR]CCLREN
                     Affzo [M:SCCR]1-99
Endcase
Return

$ABA
Case GACTION
 When "TRTCLESOH","TRTCLESOQ"  : REP = ""
                                 Raz [M:SCCR]CCLREN
                                 Affzo [M:SCCR]1-99
Endcase
Return

# Bug 69265
$FIN
Case GACTION
 When "TRTCLESOH"              : GOK=0
Endcase
Return
# Bug 69265

$APRES_MODIF
Case GACTION
 When "TRTCLESOH","TRTCLESOQ"  : REP = "M"
Endcase
Return

$OK
Case GACTION
 When "TRTCLESOH"  : PARAM(2)=[M:SCCR]CCLREN : GOK=1 : # Bug 69265
 When "TRTCLESOQ"  : nolign=SAVNOLIGN
                     [M:SOH4]DCCLREN(nolign-1)=[M:SCCR]CCLREN
Endcase
Return

################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################
#########################################################################
# TRTCLESOH : Solde d'une commande de vente                             #
#########################################################################
$AVTPAR_TRTCLESOH
If GCCLRENORD <> 2 TYPPRG=1 : Raz PARAM(2) : Endif
Return
#########################################################################
$EXEC_TRTCLESOH
If GOK<1  Return Endif         : # Bug 69265

Call DIVCLESOH (PARAM(1), PARAM(2))
Return
#########################################################################
# TRTCLESOQ : Solde d'une ligne de commande de vente                    #
#########################################################################
$INI_TRTCLESOQ
Local Integer OK
Local Integer NLIG      : NLIG = nolign-1
Local Integer ORI       : ORI = nolign-1
Local Integer NL        : NL  = nolign
Local Integer FUNCTION  : FUNCTION = 2    :    # Identif. cde pour MODNOM
Local Char    COUZON(GLONAVA)

# --> Pas d'éxécution du bouton
If nolign > [M]NBLIG FIN=1: Endif
#   --> Ctrl autorisation bouton solde (on teste l'autorisation de modification)
If !find (GREP, "C", "D")
    GBIDC2="D": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): Return : Endif
Endif
# --> Solde non autorisé : Il ne faut pas bloquer si qte cdee < livré/facturé
If [M:SOH2]ORDCLE = 1 & [M]SOQSTA(NLIG) <> 3
# 107888 : Scheduled invoices : (LD:01/04/16)
# Deliverable item (Direct order/Open order/Loan order)     : We take in Process qty and Delivered qty
# Undeliverable item  (Direct order/Direct invoicing order) : We take in Process qty and Invoiced qty
# Direct invoicing order                                    : We take in Process qty and Invoiced qty
#    If ([M:SOH0]SOHCAT <> 3 & ([M]DLVQTY(NLIG) + [M]ODLQTY(NLIG)) < [M]QTY(NLIG)) |
#&      ([M:SOH0]SOHCAT  = 3 & ([M]INVQTY(NLIG) + [M]ODLQTY(NLIG)) < [M]QTY(NLIG))
    If ([M:SOH0]SOHCAT <> 3 & [M]DLVQTY(NLIG)=2 & ([M]DLVQTY(NLIG) + [M]ODLQTY(NLIG)) < [M]QTY(NLIG)) |
&      (([M]DLVQTY(NLIG)=1 | [M:SOH0]SOHCAT=3)  & ([M]INVQTY(NLIG) + [M]ODLQTY(NLIG)) < [M]QTY(NLIG))
# 107888 : Scheduled invoices : (LD:01/04/16)
        GERR=1 : GMESSAGE = mess(24,192,1) : Return
    Endif
Endif
OK=2
# Si la ligne en préparation, pas de solde possible
If sum([M]LPRQTY(NLIG),[M]OPRQTY(NLIG),[M]PREQTY(NLIG)) <> 0  GERR=1 : Return : Endif

#----- On force le contrôle "AVANT_MOD" -----#
If GREV=0
  Gosub AVANT_MOD From SUBSOHA1 : If OK=0 FIN=1 : Return Endif
Endif

# --> Commande signée, modification ?
# (Si GREV<>0, on est passé dans l'action AVANT_MOD, inutile de reposer la question
If GREV=0
    If find([M:SOH1]APPFLG, 2,3)
        OK=2 : Call AVERTIR(mess(229,191,1)+"\"+mess(60,123,1)-"?",OK) From GESECRAN
       If OK=1 FIN=1 : Return Endif
    Endif
Endif

If [M]WALLQTY(NLIG) <> 0
# Si la ligne de commande est allouée, demander confirmation
    OK=1 : Call OUINON(mess(139,191,1)-":"-mess(205,100,1), OK) From GESECRAN
    If OK=1 FIN=1 : Return Endif
Elsif [M]FMINUM(NLIG) <> "" : # Avertir si la ligne est à contremarque
    OK=1 : Call AVERTIR (mess(52,191,1), OK) From GESECRAN
    If OK=1 : FIN=1 : Return : Endif
Elsif [M]SOQSTA(NLIG) <> 3
# Si la ligne n'est pas soldée, demander confirmation de solde
    Call OUINON(mess(138,191,1), OK) From GESECRAN
Else
# Si la ligne est déjà soldée,  demander confirmation de désolde
    Call OUINON(mess(22,192,1), OK) From GESECRAN
Endif
If OK=1 FIN=1 Endif

Return
#########################################################################
$AVTPAR_TRTCLESOQ

# Pas de saisie du motif annulation si paramêtre non positionné ou désolde de la ligne
If GCCLRENORD <> 2 | [M]SOQSTA(NLIG)=3 | GIMPORT TYPPRG=1 : Endif
Return
#########################################################################
$EXEC_TRTCLESOQ
GMODIF = 5

Gosub TRT_CLESOQ From SUBSOHB
OK=1
# --> Si composé nomenclature : dde de solde des composants
If ([M:SOH4]LINTYP(NLIG) = 6  & find([M:SOH4]LINTYP(NL), 7,8,9))
    Call OUINON(mess(14,191,1),OK) From GESECRAN
# Si pas de solde des composants, tous les composants deviennent des articles normaux
    If OK <> 2
        [M:SOH4]LINTYP(NLIG) = 1
        GMODIF=4 : Gosub MODNOM From TRTVENBOM
        Affzo [M:SOH4]
        nolign = NLIG + 1
    Endif
Endif
If find([M:SOH4]LINTYP(NLIG),2,10) | OK = 2
    Gosub MODNOM From TRTVENBOM
    Affzo [M:SOH4]
    nolign = NLIG + 1
Endif

Affzo [M:SOH4]DLRNOT, DLRATI
Affzo [M:SOH4]WALLQTY(NLIG), SOQSTA(NLIG), DCCLREN(NLIG), DCCLDAT(NLIG)

mkstat=4
GMODIF = 2

Return
#########################################################################
#########################################################################
#-----------------------------------------------------------
# Alimentation des masques SOH et SOR
# à partir des clients
#-----------------------------------------------------------
# Entrée   TYPCDE : 1 = commande classique / 2 = commande ouverte
#          TYPCLI : C = client cde / L = client liv / F = client fac
#---
Subprog ALICDE (TYPCDE,TYPCLI,VALEUR)
Value   Integer TYPCDE
Value   Char    TYPCLI
Value   Char    VALEUR

Local   Decimal COURS
Local   Integer SPSTAT
Local   Decimal ENCOURS, MONTANT
Local   Char    SECTION(GLONCCE), WABMSK(3)      # FGR 20/04/2015 : X3SUIVI107740 pas GLONCDE
Local   Char    WBPCPYR(GLONBPC), WBPCINV(GLONBPC)

If TYPCDE = 1 WABMSK = "SOH"
Else          WABMSK = "SOR" : Endif

Case TYPCLI
 When "C" : Gosub CLICDE
 When "L" : Gosub CLILIV
 When "F" : Gosub CLIFAC
Endcase
End

# ---------------------------------------- #
#   Alimentation depuis client commande    #
# ---------------------------------------- #
$CLICDE
If TYPCDE = 1
   # Utile pour l'init. des sections : La Section par défaut "SOH" utile [M:SQH0]BPCORD
   [M:SOH0]BPCORD = VALEUR
#   [M:SOH0]BPCNAM = [F:BPC]BPCNAM
   [M:SOH1]BPCINV = [F:BPC]BPCINV
#  Alimentation code adresse client facture dans [M:ADB1]                    : # Bug 69487
   If dim([M:ADB1]BPAADD) > 0                                                : # Bug 69487
      If !GIMPORT | [M:ADB1]BPAADD="" [M:ADB1]BPAADD = [F:BPC]BPAADD : Endif : # Bug 69487
   Endif                                                                     : # Bug 69487
   If !GIMPORT & dim([M:ADB2]BPAADD) > 0
       If [F:BPC]BPCTYP=2 [M:ADB2]=[M:ADB1] Else Raz [M:ADB2] : Endif
   Endif
#  Alimentation code adresse client facture dans [M:ADB3]
   If dim([M:ADB3]BPAADD) > 0
      If !GIMPORT If [F:BPC]BPCTYP=2 [M:ADB3]=[M:ADB1] Else Raz [M:ADB3] Endif : Endif
      If !GIMPORT | [M:ADB3]BPAADD="" [M:ADB3]BPAADD = [F:BPC]BPAINV : Endif
   Endif
   [M:SOH1]BPCPYR = [F:BPC]BPCPYR
   [M:SOH1]BPCGRU = [F:BPC]BPCGRU

   # Alimentation à partir du modèle d'édition
   Call ALI_PRTMOD("SOH0",2) From TRTX3
   If [M:SOH0]COPNBR=0 [M:SOH0]COPNBR=1 Endif

Endif
If TYPCDE = 2
   # Utile pour l'init. des sections : La Section par défaut "SOR" utile [M:SOR1]BPCORD
   [M:SOR1]BPCORD = VALEUR
   [M:SOR1]BPCINV = [F:BPC]BPCINV
   [M:SOR1]BPCPYR = [F:BPC]BPCPYR
   [M:SOR1]BPCGRU = [F:BPC]BPCGRU

   # Alimentation à partir du modèle d'édition
   Call ALI_PRTMOD("SOR1",3) From TRTX3
   If [M:SOR1]COPNBR=0 [M:SOR1]COPNBR=1 Endif

Endif

# Initialisation du code condition de paiement
If TYPCDE=1
   Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SOH3]PTE) From TRTX3
   [M:SOH0]LAN = GLANGUE
Else
   Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SOR1]PTE) From TRTX3
   [M]LAN      = GLANGUE
Endif

Read [BPR]BPR0 = VALEUR
If fstat = 0
   If TYPCDE = 1
      [M:SOH0]LAN = [F:BPR]LAN
   Else
      [M]LAN = [F:BPR]LAN
   Endif
Endif

If TYPCDE = 1
   If dim([M:ADB1]CNTNAM)>0 & [M:ADB1]CNTNAM = ""
       Call RECH_CNTNAM(VALEUR, [F:BPC]BPAADD, [M:ADB1]CNTNAM) From TRTVENDIV
   Endif
   [M:SOH0]OCNFLG    = [F:BPC]OCNFLG
   [M:SOH0]ORDMINAMT = [F:BPC]ORDMINAMT
   # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
#   Call INIT_REGIME(VALEUR, GSOCIETE, "C", [M:SOH1]VACBPR) From CPTSUB : # Déplacé à la lecture du client livré
Else
   [M]OCNFLG = [F:BPC]OCNFLG
   # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
   Call INIT_REGIME(VALEUR, GSOCIETE, "C", [M]VACBPR)      From CPTSUB
Endif

# Alimentation des codes statistiques
If TYPCDE = 1
   If dim([M:SOH0]TSCCOD) <> -1
      For I = 1 To dim([M:SOH0]TSCCOD)
        [M:SOH0]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1)
      Next I
   Endif
Else
   If dim([M]TSCCOD) <> -1
      For I = 1 To dim([M]TSCCOD)
        [M]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1)
      Next I
   Endif
Endif

# Ces zones ne sont alimentées que si cde classique
If TYPCDE = 1
   [M:SOH2]ORDCLE = [F:BPC]ORDCLE
   [M:SOH2]ODL    = [F:BPC]ODL

   [M:SOH2]DME    = [F:BPC]DME
   If [M:SOH0]SOHCAT = 3 & [F:BPC]IME = 1
       [M:SOH3]IME = 3
   Else
       [M:SOH3]IME = [F:BPC]IME
   Endif
Endif
If TYPCDE = 1
#  Alimentation du 1er représentant
   If dim([M:SOH1]REP) > 0
      [M:SOH1]REP(0) = [F:BPC]REP(0)
   Endif
#  Alimentation du 2eme représentant
   If dim([M:SOH1]REP) > 1
      If [M:SOH1]REP(0) <> ""
         [M:SOH1]REP(1) = [F:BPC]REP(1)
      Endif
   Endif
Endif
If TYPCDE = 2
   [M:SOR1]ODL = [F:BPC]ODL
   [M:SOR1]IME = [F:BPC]IME
   # Si une facture/cde soldée on force à 1 facture/cde
   If [F:BPC]IME=2 [M:SOR1]IME=3 Endif
   If !GIMPORT : Affzo [SOR1]BPCINV, BPCPYR, BPCGRU : Endif
Endif

Raz [M]SOHTEX1, [M]SOHTEX2
If GSALTEXORD=1
   [M]SOHTEX1 = [F:BPC]ORDTEX
Elsif GSALTEXORD=2
   [M]SOHTEX2 = [F:BPC]ORDTEX
Endif

# Lecture client livré pour alimentation depuis celui-ci
If TYPCDE = 1
   Filter [BPD] Where [BPD]BPCNUM = VALEUR & ENAFLG=2
   Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
   If fstat = 0
      [M:SOH1]BPAADD = [F:BPD]BPAADD
      Gosub CLILIV
   Else
      Read [BPD]BPD0 First
      If fstat = 0
         [M:SOH1]BPAADD = [F:BPD]BPAADD
         Gosub CLILIV
      Endif
   Endif
   Filter [BPD]
Endif

#109199.sn
If TYPCDE = 2
   If clalev ([F:BPD]) <= 0 Local File BPDLVCUST [BPD] : Endif
   Filter [BPD] Where [BPD]BPCNUM = VALEUR & ENAFLG=2
   Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
   If fstat = 0
      If dim([M:SOR1]SSTENTCOD)>0
        [M:SOR1]SSTENTCOD=[F:BPD]SSTENTCOD
      Endif
   Endif
   Filter [BPD]
Endif
#109199.en
# Alimentation de l'état commande (à la fin pour ne pas casser [F:BPC] du clt cde)
# L'en-cours est contrôlé sur le tiers risque du client commande
If [F:BPC]BPCNUM<>[F:BPC]BPCRSK
    Read [BPC]BPC0 = [F:BPC]BPCRSK
    If fstat<>0 : Return : Endif
Endif
If TYPCDE = 1
   [M:SOH1]CDTSTA = 1
   If [F:BPC]OSTCTL = 3 [M:SOH1]CDTSTA = 2 Endif
Endif
If TYPCDE = 2
   [M:SOR1]CDTSTA = 1
   If [F:BPC]OSTCTL = 3 [M:SOR1]CDTSTA = 2 Endif
Endif

# Lecture client facture pour alimentation depuis celui-ci
If TYPCDE = 1
   If [F:BPC]BPCNUM<>[M:SOH1]BPCINV
      Read [BPC]BPC0 = [M:SOH1]BPCINV
      If fstat<>0 : Return : Endif
   Endif
Endif
If TYPCDE = 2
   If [F:BPC]BPCNUM<>[M:SOR1]BPCINV
      Read [BPC]BPC0 = [M:SOR1]BPCINV
      If fstat<>0 : Return : Return
      Endif
   Endif
Endif
Gosub CLIFAC
If TYPCDE = 1 & dim([M:SOH0]BPIEECNUM)>0
    Call INIEECNUM ([M:SOH0]BPCORD,[M:SOH1]BPAADD,[M:SOH1]BPCINV,[M:SOH0]BPIEECNUM,[M:SOH0]EECNUMCRY) From TRTVENDIV
Endif

# Initialisation sections analytiques une fois tout chargé (la devise)
## A cause de l'INISEC "SOH" qui peut être paramétré avec [F:POH]
If TYPCDE=1 & GMODU(6)=2 & GOPTCANA>0 & clalev([F:POH])>0 Raz [F:POH] : Endif
#If dim([M]NBAXE)>0
#   For nolign = 1 To GOPTCANA
#      Call INISEC(SECTION, WABMSK,num$(nolign)) From SUBCDE
#      [M]CCE(nolign-1) = SECTION
#   Next nolign
#Endif
If dim([M]NBAXE)>0
  If [M]NBAXE>0
      For I=1 To [M]NBAXE Raz [M]CCE(I-1) : Next
  Endif
  If TYPCDE=1
      Call INIT_CCEH("SOH3","NBAXE","SOH") From TRTX3CPT
  Else
      Call INIT_CCEH("SOR1","NBAXE","SOR") From TRTX3CPT
  Endif
Endif

If TYPCDE = 2
    If !GIMPORT
        Affzo [M:SOR1]1-99
    Endif
Endif

# Il faut se repositionner sur le clt cde
# -->   Car en AM_BPCORD, on affiche les observations du clt cde
If TYPCDE = 1
   If [F:BPC]BPCNUM <> VALEUR
       Read [BPC]BPC0 = VALEUR
       If fstat<>0  Return  Endif
   Endif
Endif
If TYPCDE = 2
   If [F:BPC]BPCNUM <> VALEUR
       Read [BPC]BPC0 = VALEUR
       If fstat<>0  Return  Endif
   Endif
Endif
Return

# ---------------------------------------- #
#   Alimentation depuis client livré       #
# ---------------------------------------- #

$CLILIV
If TYPCDE = 1
   Local Char WBPCORD(GLONBPC)
   If TYPCLI = "C"
      WBPCORD = VALEUR
   Else
      WBPCORD = [M:SOH0]BPCORD
   Endif
   If TYPCLI = "C" [M:SOH1]BPDNAM = [F:BPD]BPDNAM(0) : Endif
#  On récupère le site si aucune ligne n'a été saisie ou si on dupplique avec changement de client
   If (([F:BPD]STOFCY <> "" & [M:SOH2]STOFCY <> [F:BPD]STOFCY)|([F:BPD]STOFCY="" & GFCYDEF(7) <> "" & [M:SOH2]STOFCY <> GFCYDEF(7)))
&  & ([M:SOH4]NBLIG = 0 | (GREP="D" & TYPCLI="C"))                  # bug 120236
     If [F:BPD]STOFCY<>""                                           # bug 120236
      If [F:FCY]FCY <> [F:BPD]STOFCY Read [FCY]FCY0=[F:BPD]STOFCY : Endif
     Else                                                           # bug 120236
      If [F:FCY]FCY <> GFCYDEF(7)                                   # bug 120236
           Read [FCY]FCY0=GFCYDEF(7)                                # bug 120236
           If fstat: Raz [F:FCY]: Endif                             # bug 120236
       Endif # bug 120236
     Endif                                                          # bug 120236
      If [F:FCY]LEGCPY=GSOCIETE
          Local Integer OK      : OK=1
          Local Char    WFCY : #WFCY=[F:BPD]STOFCY                  # bug 120236
          WFCY = [F:FCY]FCY                                         # bug 120236
          If GREP="D" Gosub VERIF_LIGNE_ITF Endif
          If OK=0
              GMESSAGE -=mess(25,192,1)-WFCY-"\"-mess(96,191,1)
              If GTRACE <> "" Call ECR_TRACE(GMESSAGE, 0) From GESECRAN Endif
          Endif
          If OK=1 [M:SOH2]STOFCY = WFCY Endif
      Endif
   Endif
   [M:SOH2]DRN    = [F:BPD]DRN
   [M:SOH2]DLVPIO = [F:BPD]DLVPIO
   [M:SOH2]DAYLTI = [F:BPD]DAYLTI
   [M:SOH2]MDL    = [F:BPD]MDL
   [M:SOH2]BPTNUM = [F:BPD]BPTNUM
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
    If dim([M:ADB2]BPAADD) > 0
      [M:ADB2]BPAADD    = [F:BPD]BPAADD
#      If [M:ADB2]CNTNAM = ""
      If (GIMPORT & [M:ADB2]CNTNAM = "") | !GIMPORT
          Call RECH_CNTNAM(WBPCORD, [F:BPD]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
      Endif
    Endif
#  Alimentation des représentants s'ils n'ont pas été alimentés par le client commande
   If [F:BPC]BPCNUM <> WBPCORD
       Read [BPC]BPC0 = WBPCORD
       If fstat <> 0 Raz [F:BPC] : Endif
   Endif
#  Alimentation du 1er représentant
   If dim([M:SOH1]REP) > 0 & [F:BPC]REP(0) = ""
      [M:SOH1]REP(0) = [F:BPD]REP(0)
   Endif
#  Alimentation du 2eme représentant
   If dim([M:SOH1]REP) > 1
      If [M:SOH1]REP(0) <> "" & [F:BPC]REP(1) = ""
         [M:SOH1]REP(1) = [F:BPD]REP(1)
      Endif
      # 81661 : Le second représentant ne doit être alimenté si le 1er réprésentant est alimenté
      If [M:SOH1]REP(0)="" [M:SOH1]REP(1) = "" Endif
   Endif
# Alimentation régime de taxe à partir du client livré
   # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
   Call INIT_REGIME(WBPCORD, GSOCIETE, "C", [M:SOH1]VACBPR) From CPTSUB
   If [F:BPD]VACBPR<>"" [M:SOH1]VACBPR = [F:BPD]VACBPR Endif
# Alimentation des champs relatifs au infos douanières
   [M:SOH0]EECICT=[F:BPD]EECICT
   If dim([M:SOH2]EECICT)>0 : [M:SOH2]EECICT=[F:BPD]EECICT : Endif     :#-- CPO 65018
   [M:SOH0]ICTCTY=[F:BPD]ICTCTY
   If dim([M:SOH2]ICTCTY)>0 : [M:SOH2]ICTCTY=[F:BPD]ICTCTY : Endif     :#-- CPO 65018
   [M:SOH0]FFWNUM=[F:BPD]FFWNUM
   [M:SOH0]FFWADD=[F:BPD]FFWADD
   If dim([M:SOH0]EECLOC)>0
       [M:SOH0]EECLOC=[F:BPD]EECLOC
       If TYPCLI = "L" Call INIEECNUM (WBPCORD,VALEUR,[M:SOH1]BPCINV,[M:SOH0]BPIEECNUM,[M:SOH0]EECNUMCRY) From TRTVENDIV Endif
   Endif
Endif
If dim([M:SOH1]SSTENTCOD)>0 :[M:SOH1]SSTENTCOD=[F:BPD]SSTENTCOD :Endif  #LTA.n
Return


# ---------------------------------------- #
#   Alimentation depuis client facture     #
# ---------------------------------------- #

$CLIFAC
Local Integer NBPOSTE
Local Integer SPSTAT
Local Char    WBPCINV(GLONBPC), WBPAINV
If TYPCDE = 1
   If [M:SOH1]CUR = "" [M:SOH1]CUR = GLOCALDEV Endif
Else
   If [M:SOR1]CUR = "" [M:SOR1]CUR = GLOCALDEV Endif
Endif
If TYPCDE = 1
   If TYPCLI = "F"
      Read [BPR]BPR0 = VALEUR
   Else
      Read [BPR]BPR0 = [M:SOH1]BPCINV
   Endif
Endif
If TYPCDE = 2
   If TYPCLI = "F"
      Read [BPR]BPR0 = VALEUR
   Else
      Read [BPR]BPR0 = [M:SOR1]BPCINV
   Endif
Endif
If TYPCDE = 1
   [M:SOH1]CUR    = [F:BPC]CUR
   [M:SOH0]CUR    = [F:BPC]CUR
   If dim([M:ADB3]CNTNAM)>0 & [M:ADB3]CNTNAM = ""
       If TYPCLI="F" WBPAINV=[F:BPC]BPAADD  : WBPCINV=VALEUR
       Else          WBPAINV=[M:ADB3]BPAADD : WBPCINV=[M:SOH1]BPCINV : Endif
       Call RECH_CNTNAM(WBPCINV, WBPAINV, [M:ADB3]CNTNAM) From TRTVENDIV
   Endif
#   If dim([M:ADB3]EECNUM)>0 & [M:ADB3]EECNUM = "" [M:ADB3]EECNUM = [F:BPR]EECNUM Endif
#  Bug : 67515 : Alimentation code adresse client facture dans [M:ADB3]
   If dim([M:ADB3]BPAADD) > 0 & [M:ADB3]BPAADD=""
      If [F:BPC]BPCINV=[F:BPC]BPCNUM & [F:BPC]BPAINV<>[F:BPR]BPAADD
          [M:ADB3]BPAADD = [F:BPC]BPAINV
      Endif
   Endif

   If TYPCLI = "C" [M:SOH1]BPINAM = [F:BPC]BPCNAM Endif
   [M:SOH0]CHGTYP = [F:BPC]CHGTYP
   [M:SOH1]PRITYP = [F:BPC]PRITYP
Endif
If TYPCDE = 2
   [M:SOR1]CUR = [F:BPC]CUR
   [M:SOR1]CHGTYP = [F:BPC]CHGTYP
   [M:SOR1]PRITYP = [F:BPC]PRITYP
Endif

If TYPCLI = "F" & TYPCDE = 1 & dim([M:SOH0]BPIEECNUM)>0
    Call INIEECNUM ([M:SOH0]BPCORD,[M:SOH1]BPAADD,VALEUR,[M:SOH0]BPIEECNUM,[M:SOH0]EECNUMCRY) From TRTVENDIV
Endif

If TYPCDE = 1
# Init. du tableau des éléments de facturation
    NBPOSTE=dim([M:SOH3]INVDTA)
    Raz [M:SOH3]INVDTAAMT
    Call STRUFOOT (3,"SOH3",NBPOSTE,[M:SOH0]CHGTYP,[M:SOH0]CUR, [M:SOH0]CUR, "OUI") From SUBSFIT
    [M:SOH3]NBFAC = NBPOSTE
# Récupération du format de saisie des frais/remises
#    Call FMTREM("SOH4", [M:SOH0]CUR) From TRTPRICE
Endif
If TYPCDE = 2
# Init. du tableau des éléments de facturation
    NBPOSTE=dim([M:SOR1]INVDTA)
    Raz [M:SOR1]INVDTAAMT
    Call STRUFOOT (3,"SOR1",NBPOSTE,[M:SOR1]CHGTYP,[M:SOR1]CUR, [M:SOR1]CUR, "OUI") From SUBSFIT
    [M:SOR1]NBFAC = NBPOSTE
Endif

If TYPCDE = 1
   Call INIPTE ([M:SOH1]BPCPYR, [F:BPC]BPCNUM, "C", [M:SOH3]PTE) From TRTX3
   Call INIT_ESCOMPTE ([F:BPC]BPCNUM,  GSOCIETE, "C", [M:SOH3]DEP) From CPTSUB
Endif
If TYPCDE = 2
   Call INIPTE ([M:SOR1]BPCPYR, [F:BPC]BPCNUM, "C", [M:SOR1]PTE) From TRTX3
   # V6.2 : 60763 Settlements Discounts
   If dim([M:SOR1]DEP)>0 Call INIT_ESCOMPTE ([F:BPC]BPCNUM,  GSOCIETE, "C", [M:SOR1]DEP) From CPTSUB Endif
Endif

If TYPCDE = 1
    # Conversion montant mini cde devise dossier vers devise commande
    If GSYSCUR <> [M:SOH1]CUR
        Call CONVERT(GSYSCUR, [M:SOH1]CUR, GLOCALDEV, [M]CHGTYP, [M]ORDDAT, [M:SOH0]ORDMINAMT, MONTANT,SPSTAT) From TRTDEV
        [M:SOH0]ORDMINAMT = MONTANT
    Endif
    # Alimentation des zones en-cours (dépend du tiers risque du client cde et de la devise du clt facture)
    Call SDCDTSTA("",[M]BPCORD,[M]CHGTYP,0,[M]CUR,[M]ORDDAT,[M]UNL,1,[M]CDTSTA, [M]OST,[M]OSTAUZ) From TRTVENCDT
Endif
If TYPCDE = 2
    # Alimentation des zones en-cours (dépend du tiers risque du client cde et de la devise du clt facture)
    Call SDCDTSTA("",[M]BPCORD,[M]CHGTYP,0,[M]CUR,[M]ORDDAT,1,1,[M]CDTSTA, GBIDD1,GBIDD2) From TRTVENCDT
Endif

# 107890 : Scheduled invoices : (LD:08/12/15)
# Invoicing condition managed only for Normal order
If TYPCDE = 1
    If [M:SOH0]SOHCAT=1
        [M:SOH3]INVCND=[F:BPC]INVCND
    Else
        Raz [M:SOH3]INVCND
    Endif
Endif
# 107890 : Scheduled invoices : (LD:08/12/15)

$CLIFAC1

If TYPCDE = 2
   If TYPCLI = "F"
        [M:SOR1]BPCINV = VALEUR
        If !GIMPORT : Affzo [M:SOR1]1-99 : Endif
    Endif
Endif
Return

# ------------------------------------------------------------------ #
#   Verification de l'existence des articles sur le site expédition  #
#                     ou (pour l'inter-site) sur le site réception   #
# ------------------------------------------------------------------ #
$VERIF_LIGNE_ITF
OK=1
Local Integer I
For I=0 To [M:SOH4]NBLIG-1
    If [F:ITM]ITMREF <> [M]ITMREF(I)
        Read [ITM]ITM0=[M]ITMREF(I)
        If fstat Raz [F:ITM] Endif
    Endif
    If [F:ITM]STOMGTCOD> 1
       If clalev ([F:ITF]) <= 0 Local File ITMFACILIT [ITF] : Endif
       Look [ITF]ITF0 = [M]ITMREF(I);WFCY
       If fstat
           OK=0:GMESSAGE=[M]ITMREF(I) : Break
       Endif
    Endif
Next
Return

#$VERIF_LIGNE_ITF
#OK=1
#Local Integer I
#For I=0 To [M:SOH4]NBLIG-1
#    If [M:SOH4]STOMGTCOD(I) <> 1
#       If clalev ([F:ITF]) <= 0 Local File ITMFACILITY [ITF] : Endif
#       Look [ITF]ITF0 = [M]ITMREF(I);WFCY
#       If fstat
#           OK=0:GMESSAGE=[M]ITMREF(I) : Break
#       Endif
#    Endif
#Next
#Return
#########################################################################
#------------------------------------------------------------------#
# Alimentation du montant mini de cde                              #
# dans le masque SOH dans la devise commande                       #
#------------------------------------------------------------------#
# Entrée   BPCORD : Client commande                                #
#          CURORD : Devise de la commande                          #
#          DATORD : Date de la commande                            #
# Sortie   ORDMIN : Montant mini cde                               #
#------------------------------------------------------------------#
Subprog ALIORDMIN(BPCORD, CURORD, DATORD, ORDMIN)
Value    Char    BPCORD
Value    Char    CURORD
Value    Date    DATORD
Variable Decimal ORDMIN

Local    Decimal MONTANT
Local    Integer SPSTAT

If [F:BPC]BPCNUM <> BPCORD
    Read [F:BPC]BPC0 = BPCORD
    If fstat Raz [F:BPC] : Endif
Endif

# Convertion du montant mini cde devise dossier vers devise commande
If GSYSCUR <> CURORD
   Call CONVERT(GSYSCUR, CURORD, GLOCALDEV, [F:BPC]CHGTYP, DATORD, [F:BPC]ORDMINAMT, MONTANT,SPSTAT) From TRTDEV
   ORDMIN  = MONTANT
Else
   ORDMIN  = [F:BPC]ORDMINAMT
Endif

End
#########################################################################
#-----------------------------------------#
# Contrôle si le client commande est OK   #
#-----------------------------------------#
Subprog C_BPCORD(VALEUR)
Value Char VALEUR

If [F:TSO]SOHCAT = 2 & [F:BPC]LNDAUZ=1  GMESSAGE=mess(34,192,1) : mkstat=2 : End : Endif
If [F:TSO]SOHCAT = 4 & [F:BPC]BPCTYP<>1 mkstat=2 : Endif
End

#########################################################################
# nouvelle version - gestion des affectations v6 (LLC)
#-----------------------------------------------------------
#    Alimentation du code FMI (Méthode pour livrer)
#-----------------------------------------------------------
# Entrée   WITMREF :    Référence article
#          WSTOFCY :    Site de stockage
# Sortie   WFMI    :    Méthode
#-----------
Subprog ALIFMI (WITMREF,WSTOFCY,WFMI)
Value    Char    WITMREF
Value    Char    WSTOFCY
Variable Integer WFMI    : WFMI=1

If clalev([F:ITM]) = 0 Local File ITMMASTER  Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT Endif
If clalev([F:ITS]) = 0 Local File ITMSALES   Endif

If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF <> WITMREF Read [ITS] ITS0=WITMREF
    If fstat Raz [F:ITS] : Endif
Endif

If [F:ITS]CTMFLG <> 2                    : End : Endif
If [F:ITM]PURFLG = 1 & [F:ITM]MFGFLG = 1 : End : Endif

If [F:ITF]ITMREF <> [F:ITM]ITMREF | [F:ITF]STOFCY <> WSTOFCY
    Read [ITF]ITF0=[F:ITM]ITMREF;WSTOFCY
    If fstat : Raz [F:ITF] : Endif
Endif

# Article acheté  : On va gérér une ligne de Contremarque
If [F:ITM]PURFLG = 2
    If [F:ITM]MFGFLG = 1 | ([F:ITM]MFGFLG = 2 & [F:ITF]REOCOD = 2)
        If GMODU(6) = 1 : End : Endif  #   Il faut avoir le module achat
    #   Pour l'instant on dit que c'est une ctm receptionnée
        WFMI = 3
    Endif
Endif

# Article fabriqué : On va gérér un ordre de production
If [F:ITM]MFGFLG = 2
    If [F:ITM]PURFLG = 1 | ([F:ITM]PURFLG = 2 & [F:ITF]REOCOD = 3)
        If GMODU(8) = 1 End : Endif : #   Il faut avoir le module production
        WFMI = 5
    Endif
Endif

GPOINT="ALIFMI" : Gosub ENTREE From EXEFNC

End
#########################################################################
#--------------------------------------------------------------------#
# Recherche dernier no commande issue du devis                       #
#--------------------------------------------------------------------#
Subprog RECH_DERCDESQH()
Local Shortint WOK
Local Char     CRITERE (50)

# Si date ligne livraison < date dernière liv de la cde, on ne change rien
If [F:SQH]ORDDAT > [F:SOQ]ORDDAT End Endif

#If clalev([F:SOP1])=0 Local File SORDERP[SOP1] Endif
#If clalev([F:SOQ1])=0 Local File SORDERQ[SOQ1] Endif
#Filter [SOP1] Where SQHNUM=[F:SOP]SQHNUM
#&                   Order By Key NEWCLE=SQHNUM;SOHNUM

# Pour trouver la dernière commande issue du devis
# On recherche toutes les lignes de commande issues du devis
CRITERE="SQHNUM=[F:SOP]SQHNUM"
# En suppression commande, on peut exclure les lignes de la commande en cours de suppression
If GREP="A" CRITERE -= "& SOHNUM<>[F:SOP]SOHNUM" Endif

Filter [SOP1] Where evalue(CRITERE) Order By Key NEWCLE=SQHNUM;SOHNUM

WOK = 1
Raz [F:SQH]SOHNUM, [F:SQH]ORDDAT
Read [SOP1]NEWCLE Last
If fstat
   WOK = 0
   Goto RECH_FIN
Endif

While [F:SOP1]SOHNUM = [F:SOP]SOHNUM
#   If GREP = "A"
#      Read [SOP1]NEWCLE Prev
#   Elsif !find([F:SOP1]SOPLIN,[M:SOH4]SOPLIN(0..[M:SOH4]NBLIG-1))
   If !find([F:SOP1]SOPLIN,[M:SOH4]SOPLIN(0..[M:SOH4]NBLIG-1))
      Read [SOP1]NEWCLE Prev
   Else
      WOK = 1 : Break
   Endif
   If fstat
      WOK = 0 : Break
   Endif
Wend

$RECH_FIN
If WOK = 1
   [F:SQH]SOHNUM = [F:SOP1]SOHNUM
   Read [SOQ1]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
   If fstat Raz [F:SOQ1] : Endif
   [F:SQH]ORDDAT = [F:SOQ1]ORDDAT
Endif

Filter [SOP1]
#Filter [SOQ1]
#Close Local File [SOP1]
#Close Local File [SOQ1]

End
####################################################################
Subprog RECH_DERCDESQD
#---------------------------------------------------------------#
# Recherche dernier no commande ligne devis suite à suppression #
#---------------------------------------------------------------#

#If clalev([F:SOP1])=0 Local File SORDERP [SOP1] Endif
Filter [SOP1] Where SQHNUM=[F:SQD]SQHNUM & SQDLIN=[F:SQD]SQDLIN
&            Order By Key NEWCLE=SQHNUM;SQDLIN;SOHNUM
Read [SOP1]NEWCLE Last With Nohint
If fstat = 0
   If ([F:SOP1]SOHNUM=[F:SOP]SOHNUM) & ([F:SOP1]SOPLIN=[F:SOP]SOPLIN)
      Read [SOP1]NEWCLE Prev With Nohint
      If fstat = 0
         [F:SQD]SOHNUM = [F:SOP1]SOHNUM
         [F:SQD]SOPLIN = [F:SOP1]SOPLIN
      Else
         Raz [F:SQD]SOHNUM, [F:SQD]SOPLIN
      Endif
   Else
      [F:SQD]SOHNUM = [F:SOP1]SOHNUM
      [F:SQD]SOPLIN = [F:SOP1]SOPLIN
   Endif
Else
   Raz [F:SQD]SOHNUM, [F:SQD]SOPLIN
Endif
Filter [SOP1]
#Close Local File [SOP1]
End
########################################################################
#-----------------------------------------------------------------------#
# Alimentation des masques commandes à partir du 1er devis              #
#-----------------------------------------------------------------------#
Subprog ALISQHSOH(WNEWCUR)
Value Char WNEWCUR

Local Integer I, SPSTAT
Local Decimal MONTANT
Local Char    SECTION(GLONCCE)      # FGR 20/04/2015 : X3SUIVI107740 pas GLONCDE
Local Char    WBPAADD, WPTE
Local Date    WORDDAT
Local Char    SMESSAGE(80)             # FGR 14/12/2011 : X3SUIVI71065
Local Char SVSOHTYP(GLONTSO)           # FGR 26/02/2015 : X3SUIVI104383

WORDDAT= [M:SOH0]ORDDAT
WBPAADD= [M:SOH1]BPAADD
WPTE   = [M:SOH3]PTE

nolign=1
SVSOHTYP = [M:SOH0]SOHTYP              # FGR 26/02/2015 : X3SUIVI104383
[M:SOH0]=[F:SQH]
[M:SOH0]SOHTYP = SVSOHTYP              # FGR 26/02/2015 : X3SUIVI104383
[M:SOH1]=[F:SQH]
[M:SOH2]=[F:SQH]
[M:SOH3]=[F:SQH]

#---CPO 62810 - Pb découvert lors du ttt de cette fiche
#--Le transclasse va initialiser les champs DSPTOTQTY/DSPTOTWEI/DSPTOTVOL avec les valeurs inscrite dans le SQH
#--On doit les Raz car ces champs sont mis à jour dans les ss-pros appelés par les avant et après lignes
Raz [M:SOH0]DSPTOTQTY,[M:SOH0]DSPTOTVOL, [M:SOH0]DSPTOTWEI
#---fin 62810

GBPCNUM  = [F:SQH]BPCORD

[M:SOH0]ORDDAT=WORDDAT

[M:SOH0]CUR= WNEWCUR
[M:SOH1]CUR= WNEWCUR

#----------------------------------------------------#
# Chargement libellés et formats colonnes tarif      #
#----------------------------------------------------#
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Call ALICOLREM (1,2,GFLAG,"SOH4",[M:SOH1]CUR,0,[M:SOH0]PLISTC) From TRTPRICE
#Endif

# Issue 119479
#[M:SOH1]BPAADD=[F:SQD]BPAADD
#[M:SOH2]STOFCY=[F:SQD]STOFCY
[M:SOH1]BPAADD=[F:SQH]BPAADD
[M:SOH2]STOFCY=[F:SQH]STOFCY
# End issue 119479

# FGR 02/12/2011 : X3SUIVI71065 (début)
If func TRTPJT.IS_PJT_AVAILABLE([M:SOH1]PJT, "[M:SOH1]PJT", SMESSAGE) = G_NON Then
  Call PJT_ADD_MSG([M:SOH1]PJT, SMESSAGE) From TRTPJT
  Raz [M:SOH1]PJT
Endif
# FGR 02/12/2011 : X3SUIVI71065 (fin)

# Ne pas écraser la cond. paiement par celle du devis si celle-ci n'était pas renseignée (cas devis prospect)
If [M:SOH3]PTE="" & WPTE<> "" [M:SOH3]PTE=WPTE Endif

Raz [M:ADB1], [M:ADB2]
# Remise à blanc des zones comme en RAZCRE
Raz GTARFLG
Raz [M:SOH0]SOHNUM, REVNUM
Raz [M:SOH2]LASDLVNUM, [M:SOH2]LASDLVDAT
Raz [M:SOH3]PRFNUM, [M:SOH3]LASINVNUM, [M:SOH3]LASINVDAT
If dim([M:SOH1]LNDRTNDAT) > 0 Raz [M:SOH1]LNDRTNDAT Endif

#--CPO 76678 On charge l'en-tête quand c'est le premier devis (le test ne permet pas de prendre la bonne valeur
#--          dans le cas d'un pick/depick puis repick autre devis)
#If [M:SOH0]CUSORDREF = ""
    [M:SOH0]CUSORDREF =[F:SQH]CUSQUOREF
#Endif
#--CPO

# --> Initialisation de la date d'expédition
Local Integer WSENS
If date$ >= [M:SOH0]ORDDAT
    [M:SOH2]SHIDAT = date$
    WSENS=0 :  # (Si indisponibilité on ne peut décaler que vers l'avant)
Else
    [M:SOH2]SHIDAT = [M:SOH0]ORDDAT
    WSENS=1 :  # (Si indisponibilité on peut décaler vers l'arrière)
Endif
# --> Contrôle de la date d'expédition avec les périodes d'indisponibilités du site
If [M:SOH2]STOFCY<>"" Call CTLUVYFCY([M:SOH2]SHIDAT, [M:SOH2]STOFCY, WSENS) From TRTVENCTL Endif
# Calcul de la date de livraison demandée en fonction du délai
Call CALC_DLVDAT([M:SOH2]SHIDAT, [M:SOH2]DAYLTI, [M:SOH1]BPAADD, [M:SOH0]BPCORD, 0, 0, [M:SOH2]DEMDLVDAT) From TRTVENDAT
# Dde 19843 : Test GADJSHIDAT : Globale cachée = 1 : Pas d'ajustement date d'expédition (nvx param en V150)
If dim(GADJSHIDAT)>0 & GADJSHIDAT=1
Else
    # --> Recadrage si possible de la date d'expédition par rapport à la date de livraison demandée calculée
    Local Date WSHIDAT : WSHIDAT=[M:SOH2]SHIDAT
    Call CALC_SHIDAT([M:SOH2]DEMDLVDAT, [M:SOH2]DAYLTI, [M:SOH2]STOFCY, 1, 1, [M:SOH0]ORDDAT, WSHIDAT) From TRTVENDAT
    If WSHIDAT<=[M:SOH2]DEMDLVDAT-[M:SOH2]DAYLTI [M:SOH2]SHIDAT=WSHIDAT : Endif
Endif
[M:SOH1]ORDSTA = 1:[M:SOH1]ALLSTA=1:[M:SOH1]DLVSTA=1:[M:SOH1]INVSTA=1
[M:SOH1]OCNPRN = 1

[M:SOH2]ALLTYP=GALLTYP

# --------------------------------------------------------- #
# Lecture client commande pour alimentation depuis celui-ci #
# --------------------------------------------------------- #
If [F:BPC]BPCNUM <> [M:SOH0]BPCORD
    Read [BPC]BPC0=[M:SOH0]BPCORD
    If fstat Raz [F:BPC] Endif
Endif
#   Alimentation du nom client commande
If [F:SQH]BPCNAM(0) <> "" [M:SOH0]BPCNAM = [F:SQH]BPCNAM(0)
                     Else [M:SOH0]BPCNAM = [F:BPC]BPCNAM    : Endif
[M:SOH1]BPCINV = [F:BPC]BPCINV
#  Alimentation code adresse client facture dans [M:ADB3]
If dim([M:ADB3]BPAADD) > 0
    [M:ADB3]BPAADD    = [F:BPC]BPAINV
Endif
[M:SOH1]BPCPYR    = [F:BPC]BPCPYR
[M:SOH1]BPCGRU    = [F:BPC]BPCGRU
[M:SOH0]OCNFLG    = [F:BPC]OCNFLG
[M:SOH0]ORDMINAMT = [F:BPC]ORDMINAMT
If dim([M:SOH0]TSCCOD) <> -1
    Local Integer I
    For I = 1 To dim([M:SOH0]TSCCOD)
        [M:SOH0]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1)
    Next I
Endif
#  Si client intra-société alors cde inter-sites
#If [F:BPC]BPCTYP = 3
#    [M:SOH2]BETFCY = 2
#Else
#    [M:SOH2]BETFCY = 1
#Endif
[M:SOH2]ORDCLE = [F:BPC]ORDCLE
[M:SOH2]ODL    = [F:BPC]ODL
[M:SOH2]DME    = [F:BPC]DME
If [M:SOH0]SOHCAT = 3 & [F:BPC]IME = 1
    [M:SOH3]IME = 3
Else
    [M:SOH3]IME = [F:BPC]IME
Endif
GFLTBPC=[M:SOH0]BPCORD

# Issue X3-38564
Raz [M]SOHTEX1, [M]SOHTEX2
If GSALTEXORD=1
   [M]SOHTEX1 = [F:BPC]ORDTEX
Elsif GSALTEXORD=2
   [M]SOHTEX2 = [F:BPC]ORDTEX
Endif
# End issue X3-38564

# --------------------------------------------------------- #
# Lecture client livré pour alimentation depuis celui-ci    #
# --------------------------------------------------------- #
# 101841 : Recherche interdit si adresse de livraison vide sur le devis
# Dans ce cas, adresse de livraison initialisée avec adresse de liv par défaut du client
# qui a pû être modifiée manuellement en entête commande
# [M:SOH1]BPAADD adr liv entête vient d'être réalimenté par transclass avec [F:SQD]BPAADD
# WBPAADD est alimenté avec [M:SOH1]BPAADD avant le transclass
#If [M:SOH1]BPAADD = ""                       : # 101841
If [M:SOH1]BPAADD = "" & WBPAADD = ""         : # 101841
    Filter [BPD] Where [BPD]BPCNUM = [M:SOH0]BPCORD & ENAFLG=2
    Read [BPD]BPD0 = [M:SOH0]BPCORD;[F:BPC]BPDADD
    If fstat = 0
       [M:SOH1]BPAADD = [F:BPD]BPAADD
    Else
       Read [BPD]BPD0 First
       If fstat = 0
          [M:SOH1]BPAADD = [F:BPD]BPAADD
       Endif
    Endif
    Filter [BPD]

# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
    If dim([M:ADB2]BPAADD) > 0 & [F:BPD]BPAADD <> ""
      If [M:ADB2]CNTNAM = ""
          Call RECH_CNTNAM([M:SOH0]BPCORD, [F:BPD]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
      Endif
    Endif
#Elsif WBPAADD <> ""                         : # 101841
Elsif WBPAADD <> "" & [M:SOH1]BPAADD=""      : # X3-73245 (LCC-15/02/18) Sales order by picking quote : bad company name
    [M:SOH1]BPAADD = WBPAADD                 : # 101841
Endif
If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [M:SOH1]BPAADD
    Read [BPD]BPD0=[M:SOH0]BPCORD;[M:SOH1]BPAADD
    If fstat Raz [F:BPD] Endif
Endif

# Si devis sans adresse de livraison, il faut alimenter les infos douanières
#--CPO 83969 L'adresse de livraison peut venir de la première ligne du devis
#--Ou si l'adresse reprise de la ligne est différente de l'en-tête
#If [M:SOH1]BPAADD = ""
If [M:SOH1]BPAADD = "" | ([F:SQH]BPAADD<>"" and [F:SQH]BPAADD<>[M:SOH1]BPAADD)
#--/CPO
   [M:SOH0]EECICT=[F:BPD]EECICT
   If dim([M:SOH2]EECICT)>0 : [M:SOH2]EECICT=[F:BPD]EECICT : Endif    :#-- CPO 65018
   [M:SOH0]ICTCTY=[F:BPD]ICTCTY
   If dim([M:SOH2]ICTCTY)>0 : [M:SOH2]ICTCTY=[F:BPD]ICTCTY : Endif    :#-- CPO 65018
   [M:SOH0]FFWNUM=[F:BPD]FFWNUM
   [M:SOH0]FFWADD=[F:BPD]FFWADD
   If dim([M:SOH0]EECLOC)>0
       [M:SOH0]EECLOC=[F:BPD]EECLOC
       Call INIEECNUM ([M:SOH0]BPCORD,[M:SOH1]BPAADD,[M:SOH1]BPCINV,[M:SOH0]BPIEECNUM,[M:SOH0]EECNUMCRY) From TRTVENDIV
   Endif
Endif
#   Alimentation du nom client livré
#--CPO 83969 L'adresse de livraison peut venir de la première ligne du devis
#--On doit tester cela...
#If [F:SQH]BPDNAM(0) <> "" [M:SOH1]BPDNAM = [F:SQH]BPDNAM(0)
If [F:SQH]BPDNAM(0) <> "" and [F:SQH]BPAADD=[M:SOH1]BPAADD
	[M:SOH1]BPDNAM = [F:SQH]BPDNAM(0)
#--/CPO
Else
	[M:SOH1]BPDNAM = [F:BPD]BPDNAM
Endif
[M:SOH2]DRN    = [F:BPD]DRN
[M:SOH2]DLVPIO = [F:BPD]DLVPIO
[M:SOH2]MDL    = [F:BPD]MDL
[M:SOH2]BPTNUM = [F:BPD]BPTNUM
[M:SOH1]CDTSTA = 1

# Alimentation de l'état du crédit : L'en-cours est contrôlé sur le tiers risque du client commande
If [F:BPC]BPCNUM<>[F:BPC]BPCRSK
    Read [BPC]BPC0 = [F:BPC]BPCRSK
    If fstat Raz [F:BPC] Endif
Endif
If [F:BPC]OSTCTL = 3 [M:SOH1]CDTSTA = 2 Endif
# Conversion montant mini cde devise dossier vers devise commande
If GSYSCUR <> [M]CUR
    Call CONVERT(GSYSCUR, [M]CUR, GLOCALDEV, [M]CHGTYP, [M]ORDDAT, [M:SOH0]ORDMINAMT, MONTANT,SPSTAT) From TRTDEV
    [M:SOH0]ORDMINAMT = MONTANT
Endif
# Alimentation des zones en-cours (dépend du tiers risque du client cde et de la devise du clt facture)
Call SDCDTSTA("",[M:SOH0]BPCORD,[M]CHGTYP,0,[M]CUR,[M]ORDDAT,[M]UNL,1,[M]CDTSTA, [M]OST,[M]OSTAUZ) From TRTVENCDT

# --------------------------------------------------------- #
# Lecture client facture pour alimentation depuis celui-ci  #
# --------------------------------------------------------- #
# Supprimer cette lecture tiers qui ne sert à rien
If [F:BPR]BPRNUM <> [M:SOH1]BPCINV
    Read [BPR]BPR0 = [M:SOH1]BPCINV
    If fstat Raz [F:BPR] Endif
Endif
If dim([M:ADB3]CNTNAM)>0
    Call RECH_CNTNAM([M:SOH1]BPCINV, [M:ADB3]BPAADD, [M:ADB3]CNTNAM) From TRTVENDIV
Endif
#If dim([M:ADB3]EECNUM)>0 [M:ADB3]EECNUM = [F:BPR]EECNUM Endif

#   Alimentation du nom client facture
If [M:SOH0]BPCORD <> [M:SOH1]BPCINV
    If [F:BPC]BPCNUM <> [M:SOH1]BPCINV
        Read [BPC]BPC0 = [M:SOH1]BPCINV
        If fstat Raz [F:BPC] Endif
    Endif
    [M:SOH1]BPINAM = [F:BPC]BPCNAM
Else
    [M:SOH1]BPINAM = [M:SOH0]BPCNAM
Endif

#---------------------------#
# Alimentation des adresses #
#---------------------------#
[M:ADB1]BPAADD       = [F:SQH]BPAORD
[M:ADB1]ADBBPR       = [F:SQH]BPCORD
[M:ADB1]BPRNAM(0)    = [F:SQH]BPCNAM(0)
[M:ADB1]BPRNAM(1)    = [F:SQH]BPCNAM(1)
[M:ADB1]BPAADDLIG(0) = [F:SQH]BPCADDLIG(0)
[M:ADB1]BPAADDLIG(1) = [F:SQH]BPCADDLIG(1)
[M:ADB1]BPAADDLIG(2) = [F:SQH]BPCADDLIG(2)
[M:ADB1]POSCOD       = [F:SQH]BPCPOSCOD
[M:ADB1]CTY          = [F:SQH]BPCCTY
[M:ADB1]SAT          = [F:SQH]BPCSAT
[M:ADB1]CRY          = [F:SQH]BPCCRY
[M:ADB1]CRYNAM       = [F:SQH]BPCCRYNAM
[M:ADB1]CNTNAM       = [F:SQH]CNCNAM

If [M:ADB1]BPRNAM <> "" | [M:ADB1]BPAADDLIG <> "" |
&  [M:ADB1]POSCOD <> "" | [M:ADB1]CTY <> "" |
&  [M:ADB1]SAT    <> "" |
&  [M:ADB1]CRY    <> "" | [M:ADB1]CRYNAM <> ""
    [M:ADB1]ADBFLG = 3
Else
    [M:ADB1]ADBFLG = 0
Endif
If dim([M:ADB2]BPAADD) > 0
    [M:ADB2]BPAADD   = [F:SQD]BPAADD
Endif
#--CPO 83969 L'adresse de livraison peut venir de la première ligne du devis
If ([F:SQH]BPAADD<>"" and [M:SOH1]BPAADD=[F:SQH]BPAADD)
#--/CPO
  #--CPO 79848 Contact adresse livraison suite picking
  #[M:ADB2]ADBBPR       = [F:SOH]BPCORD
  [M:ADB2]ADBBPR       = [F:SQH]BPCORD
  #--/CPO
  [M:ADB2]BPRNAM(0)    = [F:SQH]BPDNAM(0)
  [M:ADB2]BPRNAM(1)    = [F:SQH]BPDNAM(1)
  [M:ADB2]BPAADDLIG(0) = [F:SQH]BPDADDLIG(0)
  [M:ADB2]BPAADDLIG(1) = [F:SQH]BPDADDLIG(1)
  [M:ADB2]BPAADDLIG(2) = [F:SQH]BPDADDLIG(2)
  [M:ADB2]POSCOD       = [F:SQH]BPDPOSCOD
  [M:ADB2]CTY          = [F:SQH]BPDCTY
  [M:ADB2]SAT          = [F:SQH]BPDSAT
  [M:ADB2]CRY          = [F:SQH]BPDCRY
  [M:ADB2]CRYNAM       = [F:SQH]BPDCRYNAM
  If [F:SQH]CNDNAM <> ""
      [M:ADB2]CNTNAM       = [F:SQH]CNDNAM
  Endif
#--CPO 83969 L'adresse de livraison peut venir de la première ligne du devis
Else
	If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [M:SOH1]BPAADD
    Read [BPD]BPD0=[M:SOH0]BPCORD;[M:SOH1]BPAADD
  	If fstat Raz [F:BPD] Endif
	Endif
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:SQH]BPCORD | [F:BPA]BPAADD<>[M:SOH1]BPAADD
    Read [BPA]BPA0=1;[M:SOH0]BPCORD;[M:SOH1]BPAADD
    If fstat Raz [F:BPA] Endif
  Endif
  [M:ADB2]ADBBPR       = [F:SQH]BPCORD
  [M:ADB2]BPRNAM(0)    = [F:BPD]BPDNAM(0)
  [M:ADB2]BPRNAM(1)    = [F:BPD]BPDNAM(1)
  [M:ADB2]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:ADB2]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:ADB2]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:ADB2]POSCOD       = [F:BPA]POSCOD
  [M:ADB2]CTY          = [F:BPA]CTY
  [M:ADB2]SAT          = [F:BPA]SAT
  [M:ADB2]CRY          = [F:BPA]CRY
  [M:ADB2]CRYNAM       = [F:BPA]CRYNAM
  If [F:SQH]CNDNAM <> ""
      [M:ADB2]CNTNAM       = [F:SQD]CNDNAM
  Endif
Endif
#--/CPO
If func AFNC.ACTIV("LTA") and dim([M:ADB2]ADRVAL)>0   #LTA.sn
  [M:ADB2]ADRVAL=[F:SQH]ADRVAL
Endif                                                 #LTA.en
If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif

# ACA - On garde l'adresse facturation initialisée par le client

Local Integer NBPOSTE
NBPOSTE=dim([M:SOH3]INVDTA)
Call STRUFOOT (3,"SOH3",NBPOSTE,[M:SOH0]CHGTYP,[M:SOH0]CUR, [M:SOH0]CUR, "NON") From SUBSFIT
[M:SOH3]NBFAC  = NBPOSTE
# Conversion des montants de facturation si nécessaire
If [F:SQH]CUR <> [M:SOH1]CUR & [M:SOH3]NBFAC <> 0
   For I = 0 To [M:SOH3]NBFAC-1
      If [M:SOH3]AMTCOD(I) = 2
          [M:SOH3]FORMAT(I) = "NZ:"+[F:TCU]CURFMT1
         Call CONVERT([F:SQH]CUR, [M:SOH1]CUR, GLOCALDEV, [M]CHGTYP, date$, [M:SOH3]INVDTAAMT(I),MONTANT,SPSTAT) From TRTDEV
         [M:SOH3]INVDTAAMT(I) = MONTANT
      Endif
   Next I
Endif

# A cause de l'INISEC "SOH" qui peut être paramétré avec [F:POH]
#fq72245-Gbn
If GMODU(6)=2 & GOPTCANA>0 & clalev([F:POH])>0 Raz [F:POH] : Endif
#If dim([M:SOH3]NBAXE) > 0
#   For I=1 To GOPTCANA
#       Call INISEC(SECTION,"SOH",num$(I)) From SUBCDE
#       [M:SOH3]CCE(I-1) = SECTION
#   Next I
#Endif
#If dim([M:SOH3]NBAXE) > 0
#    [M:SOH3]NBAXE = GOPTCANA
#Endif
# Chargement des sections analytiques entête du document
Call CHARG_CCEH("SOH3","NBAXE","SQH") From TRTX3CPT
# On complète les sections vides
If dim([M:SOH3]NBAXE)>0
    [M:SOH3]NBAXE=GNBDIE
    For I=1 To GNBDIE
        If [M:SOH3]CCE(I-1)=""
          [M:SOH3]DIE(I-1)=GDIE(I)
          Call INISEC(SECTION,"SOH",GDIE(I)) From SUBCDE
          [M:SOH3]CCE(I-1)=SECTION
        Endif
    Next I
Endif

# 107888 : Scheduled invoices : X3-6395 (LD:28/10/16)
# Invoicing condition managed only for Normal order
If [M:SOH0]SOHCAT=1
    [M:SOH3]INVCND=[F:BPC]INVCND
Else
    Raz [M:SOH3]INVCND
Endif
# 107888 : Scheduled invoices : X3-6395 (LD:28/10/16)

#VPO 26/05/09 55362
# Alimentation à partir du modèle d'édition
Call ALI_PRTMOD("SOH0",2) From TRTX3
If [M:SOH0]COPNBR=0 [M:SOH0]COPNBR=1 Endif

# Issue X3-38564
# Has to be moved, the customer in line is not the good one
### Header text from customer (Order ack text) is not inherited in the sales order when we use picking quote.
### SAM # 121181 (LC-30/01/17)
#Raz [M]SOHTEX1, [M]SOHTEX2
#If GSALTEXORD=1
#   [M]SOHTEX1 = [F:BPC]ORDTEX
#Endif
#If GSALTEXORD=2
#   [M]SOHTEX2 = [F:BPC]ORDTEX
#Endif
## End SAM # 121181
# End issue X3-38564

GPOINT="ALISQHSOH" : Gosub ENTREE From EXEFNC

End

#-----------------------------------------------------------------------#
# Alimentation du masque détail commande  à partir d'une ligne devis    #
#-----------------------------------------------------------------------#
Subprog ALISQDSOH(NOL,WQTACDE)
Value    Integer NOL
Variable Decimal WQTACDE

Local Char    VAT(GLONVAT)(3)
Local Integer WRET, J
Local Char    SECTION(GLONCCE)      # FGR 20/04/2015 : X3SUIVI107740 pas GLONCDE
Local Decimal COEF

# Alimentation [M:SOH4]
[M:SOH4] = [F:SQD]

# ACA - 48862 - Controle statut & substitution
GERR=0
WITM = [F:SQD]ITMREF
WFLDNAM = "ITMREF"
#--CPO 88173 Un devis comporte des lignes sur plusieurs sites d'expédition d'une même société
#[M:SOH4]DSTOFCY(NOL) = [M:SOH2]STOFCY
[M:SOH4]DSTOFCY(NOL) = [F:SQD]STOFCY
#--/CPO
# On vérifie si substitution nécessaire, on passe alors par les tests
# Issue 65392 - 2010-07-08 by ACA : No item substitution when composed (kit or nomenclature)
Call CTLSBSITM(WITM, [M:SOH0]ORDDAT, WRET) From TRTVENCTL
If WRET > 0 : # Si substitution
    If [F:SQD]LINTYP<>2 and [F:SQD]LINTYP<>6
      Gosub TRT_RPLITM From SUBSOHB
    Else
      GERR=1
      GMESSAGE=mess(346,192,1)-"("+[F:SQD]ITMREF+")"
    Endif
    # Si ligne a supprimer, GERR a été mis à 1
Else
    # On vérifie si l'article est utilisable (fait dans TRT_RPLITM si substitut)
    If [F:ITM]ITMSTA = 6
        # 104761
        #GMESSAGE = mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
        GMESSAGE = mess(27,159,1)-WITM-":"-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
        # 104761
        GERR=1
    Endif
Endif

# 101841 : Recherche interdit si adresse de livraison vide sur le devis
# Dans ce cas, adresse de livraison initialisée avec adresse de liv par défaut du client
# qui a ensuite pû être modifiée manuellement en entête commande
# Il faut donc faire la recherche interdit
[M:SOH4]DBPAADD(NOL)    =  [M:SOH1]BPAADD
## 120059 Lcc 16/12/16
If NOL=0 & [F:SQH]BPAADD<>""
   [M:SOH1]BPAADD=[F:SQH]BPAADD
Endif
## End 120059 Lcc 16/12/16
If [F:SQD]BPAADD=""
    Local Char WREP(GLONREP)
    If dim([M:SOH4]REP1(NOL)) > 0 WREP = [M:SOH4]REP1(NOL) Endif
    nolign=NOL+1                 : # La recherche interdit utilise nolign
    Call RECH_INTERDIT ([M:SOH4]ITMREF(NOL), [M:SOH1]BPAADD, WREP, 2) From TRTVENTAR
    If mkstat = 2
        mkstat=0 : GERR=1 : GMESSAGE = mess(27,159,1)-[M:SOH4]ITMREF(NOL)-":"-GMESSAGE
    Endif
Endif
# 101841

If GERR=1
    # 104761
    #Dela nolign, 1 [M:SOH4]NBLIG
    #[M:SOH4]NBLIG = [M:SOH4]NBLIG-1
    If   dim([M:SOH4]ITMREF) = [M:SOH4]NBLIG
         Dela NOL,1 [M:SOH4]NBLIG
    Else Dela NOL,1,[M:SOH4]NBLIG-1 [M:SOH4]NBLIG:Endif
    [M:SOH4]NBLIG -=1
    # 104761
    End
Elsif GERR>0
    Local Integer OK : OK=1
    Call AVERTIR (GMESSAGE, OK) From GESECRAN
Endif

[M:SOH4]VACITM1(NOL)  = [F:SQD]VACITM(0)
[M:SOH4]VACITM2(NOL)  = [F:SQD]VACITM(1)
[M:SOH4]VACITM3(NOL)  = [F:SQD]VACITM(2)
#Call ALITAXEV([M:SOH1]VACBPR,[F:SQD]VACITM,VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SOH0]BPCORD,[M:SOH4]ITMREF(NOL),"SOH4",NOL,VAT) From TRTX3
[M:SOH4]VAT1(NOL)  = VAT(0)
[M:SOH4]VAT2(NOL)  = VAT(1)
[M:SOH4]VAT3(NOL)  = VAT(2)

[M:SOH4]FMI(NOL) = 1
[M:SOH4]DEMSTA(NOL) = 1
# Issue 111181
[M:SOH4]SOQSTA(NOL) = 1
[M:SOH4]INVFLG(NOL) = 1
# End issue 111181

If dim([M:SOH4]TSICOD1(NOL))>0: [M:SOH4]TSICOD1(NOL) = [F:ITM]TSICOD(0): Endif
If dim([M:SOH4]TSICOD2(NOL))>0: [M:SOH4]TSICOD2(NOL) = [F:ITM]TSICOD(1): Endif
If dim([M:SOH4]TSICOD3(NOL))>0: [M:SOH4]TSICOD3(NOL) = [F:ITM]TSICOD(2): Endif
If dim([M:SOH4]TSICOD4(NOL))>0: [M:SOH4]TSICOD4(NOL) = [F:ITM]TSICOD(3): Endif
If dim([M:SOH4]TSICOD5(NOL))>0: [M:SOH4]TSICOD5(NOL) = [F:ITM]TSICOD(4): Endif

# 107890 : Scheduled invoices : (LD:14/01/16)
If [M:SOH4]DLVFLG(NOL)=0
    [M:SOH4]DLVFLG(NOL)=[F:ITM]DLVFLG
Endif
# 107890 : Scheduled invoices : (LD:19/01/16)

# Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
# Invoicing condition managed only for Normal order and
# For Service/Generic category and type of flow sales and not deliverable
If [M:SOH0]SOHCAT=1 & [F:ITM]DLVFLG=1
  If [M:SOH4]FOCFLG(NOL)=3 #--Free product
    #--1st step : taking dedicated free product invoice condition
    #--           from the company level general parameter
    [M:SOH4]DINVCND(NOL) = func AFNC.PARAM("INVCNDFREE", [M:SOH2]STOFCY)
  Endif
  If [M:SOH4]DINVCND(NOL)=""
    [M:SOH4]DINVCND(NOL)=[M:SOH3]INVCND
    If [M:SOH4]DINVCND(NOL)=""
      If [F:ITS]ITMREF <> [F:SQD]ITMREF
        Read [ITS]ITS0 = [F:SQD]ITMREF
        If fstat Raz [F:ITS] Endif
      Endif
      [M:SOH4]DINVCND(NOL)=[F:ITS]INVCND
    Endif
  Endif
Endif
# End issue 107888 US155

# [M:SOH4]DSTOFCY(NOL)    =  [F:SQD]STOFCY # ACA - 48862
#[M:SOH4]STU(NOL)        =  [F:ITM]STU

[M:SOH4]STOMGTCOD(NOL)  = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF<>[M:SOH4]ITMREF(NOL) | [F:ITF]STOFCY<>[M:SOH4]DSTOFCY(NOL)
        Read [ITF] ITF0=[M:SOH4]ITMREF(NOL);[M:SOH4]DSTOFCY(NOL)
        If fstat Raz [F:ITF] : Endif
    Endif
    [M:SOH4]STOMGTCOD(NOL) = [F:ITF]STOMGTCOD
Endif

[M:SOH4]YSTOMGTCOD(NOL) = [M:SOH4]STOMGTCOD(NOL) : # Bug 62932
[M:SOH4]CTMFLG(NOL)     = [F:ITS]CTMFLG          : # Bug 62932

# Alimentation de l'emballage de la capacite et du code texte
#Call LECTURE("ITU", [M:SOH0]BPCORD, [M:SOH4]ITMREF(NOL)) From CONTOBJ
If [F:ITU]ITMREF <> [M:SOH4]ITMREF(NOL)| [F:ITU]BPCNUM <> [M:SOH0]BPCORD
   Read [ITU] ITU0=[M:SOH4]ITMREF(NOL);[M:SOH0]BPCORD
   If fstat Raz [F:ITU] Endif
Endif
If [F:ITU]ITMREF = [M:SOH4]ITMREF(NOL) & [F:ITU]BPCNUM = [M:SOH0]BPCORD
    #CPO 63410 - pb découvert lors de la correction de cette fiche
    # -- l'unité de vente de la ligne doit être égale à l'UV de l'article
    If [M:SOH4]SAU(NOL) = [F:ITU]SAU
      [M:SOH4]PCK(NOL)       = [F:ITU]PCK
      [M:SOH4]PCKCAP(NOL)    = [F:ITU]PCKCAP
    Endif
    [M:SOH4]ITMREFBPC(NOL) = [F:ITU]ITMREFBPC
Endif
If [M:SOH4]PCK(NOL) = ""
#    [M:SOH4]PCK(NOL)        = [F:ITS]PCK
#    [M:SOH4]PCKCAP(NOL)     = [F:ITS]PCKCAP
    #CPO 63410 - pb découvert lors de la correction de cette fiche
    # -- l'unité de vente de la ligne doit être égale à l'UV de l'article
    If [M:SOH4]SAU(NOL) = [F:ITM]SAU
      Call ALIPCK ([M:SOH4]ITMREF(NOL), [M:SOH4]DSTOFCY(NOL), [M:SOH4]PCK(NOL), [M:SOH4]PCKCAP(NOL)) From TRTVENDIV
    Endif
Endif
Raz [M:SOH4]SOQTEX(NOL)

#--CPO 87819 Texte ligne devis ayant été mis à "" sur devis
#If find(GSALTEXLIN,5)                                : # Suivi du texte devis sur la commande
If find(GSALTEXLIN,1,5)                               : # Suivi du texte devis sur la commande
    [M:SOH4]SOQTEX(NOL) = [F:SQD]SQDTEX
    If left$([F:SQD]SQDTEX,3)="SQD"
       Call DUP_CLOB("SOQ",[M:SOH4]SOQTEX(NOL),WRET) From TRTX3TEX
       If WRET<1 Raz [M:SOH4]SOQTEX(NOL) Endif
    Endif
Endif
#If find(GSALTEXLIN,1,5) & [M:SOH4]SOQTEX(NOL)=""     : # Suivi du texte article sur la commande
#   [M:SOH4]SOQTEX(NOL) = [F:ITU]ITSTEX
#   If [M:SOH4]SOQTEX(NOL)=""
#      [M:SOH4]SOQTEX(NOL) = [F:ITS]ITSTEX
#   Endif
#Endif
#--/
[M:SOH4]DETSQHNUM(NOL)  = [F:SQH]SQHNUM

Raz [M:SOH4]SOPLIN(NOL)
# A cause de l'INISEC "SOP" qui peut être paramétré avec [F:POP]
If GMODU(6)=2 & GNBDIE>0 Raz [F:POP] : Endif
# Chargement sections analytiques
Call CHARG_ACCCCE(NOL,"","","[M:SOH4]CCE",
&                    "SQD",0,[F:SQD]SQHNUM,[F:SQD]SQDLIN,0,"") From TRTX3CPT
For J = 1 To GNBDIE
   If evalue("dim([M:SOH4]CCE"+num$(J)+"(NOL))") >0 & evalue("[M:SOH4]CCE"+num$(J)+"(NOL)")=""
       Call INISEC(SECTION,"SOP",J) From TRTX3CPT
       Assign "[M:SOH4]CCE"+num$(J)+"(NOL)" With SECTION
   Endif
Next J
# Gaffe avec les classes

# Alimentation de la quantité à commander
[M:SOH4]QTY(NOL) = WQTACDE
#Call SCAL_QUS(WQTACDE,[M:SOH4]ITMREF(NOL),[M:SOH0]BPCORD,[M:SOH4]SAU(NOL),[M:SOH4]STU(NOL),
#&             [M:SOH4]QTYSTU(NOL),COEF) From TRTVENQTE
Call CNVQTY(WQTACDE,[M:SOH4]SAUSTUCOE(NOL),[M:SOH4]STU(NOL),[M:SOH4]QTYSTU(NOL)) From TRTVENQTE

#[M:SOH4]DBPAADD(NOL)    =  [M:SOH1]BPAADD : # 101841 : Recherche interdit si adresse de livraison vide sur le devis
[M:SOH4]DDRN(NOL)       =  [M:SOH2]DRN
[M:SOH4]DDLVPIO(NOL)    =  [M:SOH2]DLVPIO
[M:SOH4]DMDL(NOL)       =  [M:SOH2]MDL
[M:SOH4]DBPTNUM(NOL)    =  [M:SOH2]BPTNUM
If dim([M:ADB2]CNTNAM)>0
  If [M:SOH4]DLVFLG(NOL)<>1  # 107890 : Scheduled invoices : (LC:18/11/15)
    [M:SOH4]CNDNAM(NOL) =  [M:ADB2]CNTNAM
  Endif                      # 107890 : Scheduled invoices : (LC:18/11/15)
Endif
If [F:SQD]BPAADD <> ""
    [M:SOH4]DBPAADD(NOL)    =  [F:SQD]BPAADD
    If [F:SQD]BPAADD <> [M:SOH1]BPAADD
        If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [F:SQD]BPAADD
            Read [BPD]BPD0=[M:SOH0]BPCORD;[F:SQD]BPAADD
            If fstat Raz [F:BPD] Endif
        Endif
        [M:SOH4]DDRN(NOL)    = [F:BPD]DRN
        [M:SOH4]DDLVPIO(NOL) = [F:BPD]DLVPIO
        [M:SOH4]DMDL(NOL)    = [F:BPD]MDL
        [M:SOH4]DBPTNUM(NOL) = [F:BPD]BPTNUM
    Endif
    [M:SOH4]CNDNAM(NOL)     = [F:SQD]CNDNAM
Endif
[M:SOH4]DDAYLTI(NOL)    =  [F:SQD]DAYLTI
[M:SOH4]DDEMDLVDAT(NOL) =  [M:SOH2]DEMDLVDAT
[M:SOH4]DSHIDAT(NOL)    =  [M:SOH2]SHIDAT

# --> Calcul de la date de livraison prevue
Call CALC_DLVDAT([M:SOH4]DSHIDAT(NOL), [M:SOH4]DDAYLTI(NOL), [M:SOH4]DBPAADD(NOL), [M:SOH0]BPCORD, 0,0,
&                [M:SOH4]EXTDLVDAT(NOL)) From TRTVENDAT

[M:SOH4]DALLTYP(NOL)    =  [M:SOH2]ALLTYP
[M:SOH4]REPCOE(NOL)     =  [F:SQD]REPCOE

[M:SOH4]DPJT(NOL)       =  [F:SQD]PJT  # FGR 24/11/2011 : X3SUIVI71065

# ---------------------------------------------------------------------------- #
#     Gestion du FMI                                                           #
#     On calcule FMI pour kit, composé nom. composants nom. et article normaux #
#     On garde   FMI à 1 pour les composants de kit (Bug 27897)                #
# ---------------------------------------------------------------------------- #
If [F:ITS]CTMFLG = 2 & [F:ITM]PHAFLG <> 2 & !find ([M:SOH4]LINTYP(NOL),3,4,5,11,12,13)
#    -- Article acheté/fabriqué : Vérifier le type de suggestion préférenciel ds article-site
#    If find([F:ITM]CLSTYP, 3,4)
#        If [M:SOH4]STOMGTCOD(NOL) > 1
#            If [F:ITF]ITMREF <> [F:ITM]ITMREF | [F:ITF]STOFCY <> [M:SOH4]DSTOFCY(NOL)
#                Read [ITF] ITF0=[F:ITM]ITMREF;[M:SOH4]DSTOFCY(NOL)
#                If fstat Raz [F:ITF] : Endif
#            Endif
#        Endif
#    Endif
#    -- Article acheté  : On va gérér une ligne de Contremarque
#    If (find([F:ITM]CLSTYP, 1,5,6,8,9) | (find([F:ITM]CLSTYP, 3,4) & [F:ITF]REOCOD = 2)) &
#&          GMODU(6) = 2

# Correction: le test était différent de celui effectué dans ALIFMI,
# pour le même article on avait un FMI différent en saisie directe de cde et en récup devis ... (llc)
#    If [F:ITM]PURFLG=2 & GMODU(6) = 2
    If [F:ITM]PURFLG=2
        If [F:ITM]MFGFLG=1 | ([F:ITM]MFGFLG=2 & [F:ITF]REOCOD=2)
            If GMODU(6) = 2        #   Il faut avoir le module achat
#       --> Calcul de la qtée cdée en UV
                Local Decimal QTY_UV
                If [M]SAU(NOL) <> [F:ITM]SAU
                    Call SCAL_QUV([M]QTY(NOL), [M]ITMREF(NOL),[M:SOH0]BPCORD,[M]SAU(NOL),[F:ITM]SAU, QTY_UV, GBIDD1) From TRTVENQTE
                Else
                    QTY_UV = [M]QTY(NOL)
                Endif
                If QTY_UV < [F:ITS]CTMQTY | [F:ITS]CTMQTY = 0
                    [M]FMI(NOL) = 3
                Else
                    [M]FMI(NOL) = 2
                    [M]STOMGTCOD(NOL) = 1
                Endif
                [M]DALLTYP(NOL) = 2
            Endif
        Endif
    Endif
#    -- Article fabriqué : On va gérér un ordre de production
#    Elsif (find([F:ITM]CLSTYP, 2) | (find([F:ITM]CLSTYP, 3,4) & [F:ITF]REOCOD = 3)) &
#&          GMODU(8) = 2
# Correction: le test était différent de celui effectué dans ALIFMI,
# pour le même article on avait un FMI différent en saisie directe de cde et en récup devis ... (llc)
#    Elsif [F:ITM]MFGFLG=2 & GMODU(8) = 2
    If [F:ITM]MFGFLG = 2
        If [F:ITM]PURFLG = 1 | ([F:ITM]PURFLG = 2 & [F:ITF]REOCOD = 3)
            If GMODU(8) = 2     #   Il faut avoir le module production
                [M]FMI(NOL) = 5
                [M]DALLTYP(NOL) = 2
            Endif
        Endif
    Endif
Endif

If GINIALLORD=2
    # -- Si Commande non bloquée, pas en dépassement d'en-cours avec blocage
    #       Ligne ferme
    #       Article géré en stock ou composé kit/sous-traité
    # ----> Initialisation de la qté à allouer
    If  (find([M]CDTSTA,1,4) | ([M]CDTSTA=3 & GCDTUNL=2)) & [M]DEMSTA(NOL)=1 & [M]FMI(NOL)=1 & ([M]STOMGTCOD(NOL)<>1 | find([M]LINTYP(NOL),2,10))
        Local Decimal COEF
        # (Il faut toujours repartir des qté en US pour effectuer les calculs)
        # --- Qté à allouer = Qté déjà allouée + Reste à allouer
        [M]WALLQTYSTU(NOL) =[M]ALLQTYSTU(NOL)+([M]QTYSTU(NOL)-[M]TALLQTYSTU(NOL))
        COEF=1/[M]SAUSTUCOE(NOL)
        Call CNVQTY([M]WALLQTYSTU(NOL),COEF,[M]SAU(NOL),[M]WALLQTY(NOL)) From TRTVENQTE
    Endif
Endif

[M:SOH4]YQTY(NOL)       =  [M:SOH4]QTY(NOL)
[M:SOH4]CQTY(NOL)       =  [M:SOH4]QTY(NOL)
[M:SOH4]YSOQSTA(NOL)    =  [M:SOH4]SOQSTA(NOL)
[M:SOH4]YDSHIDAT(NOL)   =  [M:SOH4]DSHIDAT(NOL)

#--CPO 90371 Code préparation non alimenté si picking de devis
#--idem AM_DSTOFCY de SUBSOH
# Si modification du site, réinitialisation du code prépa
Local    Char    WTSCCOD(GLONADI) (0..5)
Local    Char    WTSICOD(GLONADI) (0..5)
Local    Integer WI

If dim([M:SOH0]TSCCOD) <> -1
    For WI = 1 To dim([M:SOH0]TSCCOD)
        WTSCCOD(WI-1) = [M:SOH0]TSCCOD(WI-1)
    Next WI
Endif
If dim([M:SOH4]TSICOD1)>0: WTSICOD(0) = [M:SOH4]TSICOD1(NOL): Endif
If dim([M:SOH4]TSICOD2)>0: WTSICOD(1) = [M:SOH4]TSICOD2(NOL): Endif
If dim([M:SOH4]TSICOD3)>0: WTSICOD(2) = [M:SOH4]TSICOD3(NOL): Endif
If dim([M:SOH4]TSICOD4)>0: WTSICOD(3) = [M:SOH4]TSICOD4(NOL): Endif
If dim([M:SOH4]TSICOD5)>0: WTSICOD(4) = [M:SOH4]TSICOD5(NOL): Endif
If [F:BPC]BPCNUM<>[M:SOH0]BPCORD
   Read [BPC]BPC0=[M:SOH0]BPCORD : If fstat Raz [F:BPC] Endif
Endif
Call REC_PRECOD([M:SOH4]DSTOFCY(NOL) ,[M:SOH4]ITMREF(NOL),[F:ITM]TCLCOD,WTSICOD(0),
&               WTSICOD(1),WTSICOD(2),WTSICOD(3),WTSICOD(4),[M:SOH0]BPCORD,
&               [F:BPC]BCGCOD,WTSCCOD(0),WTSCCOD(1),WTSCCOD(2),WTSCCOD(3),
&               WTSCCOD(4),[M:SOH4]PRECOD(NOL)) From STKLIB
#--/
# 107890 : Scheduled invoices : (LC:21/11/16)
If [M:SOH4]DLVFLG(NOL)<>2
   If [M:SOH0]SOHCAT=1
      Raz [M:SOH4]TDLQTY(NOL)
      Raz [M:SOH4]DDEMDLVDAT(NOL)
   Endif

   Raz [M:SOH4]DDAYLTI(NOL)
   Raz [M:SOH4]DSHIDAT(NOL)
   Raz [M:SOH4]EXTDLVDAT(NOL)

   Raz [M:SOH4]CNDNAM(NOL)
   Raz [M:SOH4]USEPLC(NOL)
   [M:SOH4]DDLVPIO(NOL)=1
   [M:SOH4]DDRN(NOL)=1
   Raz [M:SOH4]DMDL(NOL)
   Raz [M:SOH4]DBPTNUM(NOL)
   Raz [M:SOH4]PRECOD(NOL)
   Raz [M:SOH4]PCK(NOL)
   Raz [M:SOH4]PCKCAP(NOL)
   [M:SOH4]DEMSTA(NOL) = 1
   If func AFNC.ACTIV("EDIX3")>0   #SAM 121329 (JUCON 03/02/2017)
     Raz [M:SOH4]DEMDLVHOU(NOL)
     Raz [M:SOH4]MAXDLVHOU(NOL)
     Raz [M:SOH4]MAXDLVDAT(NOL)
     Raz [M:SOH4]BPCSALPRI(NOL)
     Raz [M:SOH4]USELIMDAT(NOL)
    Endif                           #SAM 121329 (JUCON 03/02/2017)
Endif
# 107890 : Scheduled invoices : (LC:21/11/16)

GPOINT="ALISQDSOH" : Gosub ENTREE From EXEFNC

End
#########################################################################
#                                                                       #
# Etiquettes                                                            #
#                                                                       #
#########################################################################
$SOHTYP

Local Integer  CATEG
Local Integer  WRETCTL #--CPO 71937 26.04.2013 Cohérence

If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TSO]) : Local File TABSOHTYP [TSO] : Endif

If GORDCAT = 4 CATEG = 1 : #-- 1-Normale 2-Prêt 3-Factur.directe 4-Cde ouverte --#
Else           CATEG = GORDCAT: Endif

Link [TSO] With [FGR]FGR0=[F:TSO]GFY;GCURFCY As [KTSO]

While CATEG <= GORDCAT & CATEG < 4
    # FGR 19/11/2012 : X3SUIVI71937
    #Filter [KTSO] Where SOHCAT=CATEG & ([TSO]GFY="" | [FGR]FCY=GCURFCY)
    #Read [KTSO]TSO0 First
    Filter [KTSO] Where SOHCAT=CATEG & ([TSO]GFY="" | [FGR]FCY=GCURFCY) & ([TSO]LEG=GCURLEG  | [TSO]LEG="" )
&          Order By Key CLE=[F:TSO]SOHTYP Asc;[F:TSO]LEG Desc
#--CPO 71937 26.04.2013 Cohérence
    #Read [KTSO]CLE First
    #If fstat=0
    #    WSOHTYP = [F:TSO]SOHTYP
    #    WSOHCAT = [F:TSO]SOHCAT
    #    # 75115 : V7 : Extension of Digital Signature : New field delivery type
    #    WSDHTYP = [F:TSO]SDHTYP
    #    GCPT=[F:TSO]CODNUM
    #    CATEG=5
    #Else CATEG+=1
    #Endif
		For [KTSO]CLE
      Call CTL_ML_CONSISTENCY("TSO", "NON",[F:KTSO]SOHTYP,[F:KTSO]LEG,AVOID.ACHAR,GCURFCY,GCURLEG,WRETCTL,AVOID.ACHAR) From TRTVENCTL
      If WRETCTL=0
        #--/
        WSOHTYP = [F:KTSO]SOHTYP
        WSOHCAT = [F:KTSO]SOHCAT
        # 75115 : V7 : Extension of Digital Signature : New field delivery type
        WSDHTYP = [F:KTSO]SDHTYP
        GCPT=[F:KTSO]CODNUM
        CATEG=5
        Break
      Endif
		Next
		CATEG+=1
		#--/
Wend
Filter [KTSO]
Return
####################################################################
$CRELIG_SQD
Local Integer WORDFLG
Local Decimal WDIFF

#-------------------------------------------------#
# Modif. détail devis en création cde    - VALLIG #
#-------------------------------------------------#
If  [M:SOH4]SQDLIN(nolign-1) = 0 : Return : Endif

If  !clalev([F:SQD]) : Local File SQUOTED [SQD] : Endif
Readlock [SQD] SQD0=[M:SOH4]DETSQHNUM(nolign-1);[M:SOH4]SQDLIN(nolign-1)
# Enregistrement locké
If fstat=1 : GOK=-1:GLOCK="$SQUOTED"-[M:SOH4]DETSQHNUM(nolign-1)-num$([M:SOH4]SQDLIN(nolign-1)): Goto CRELIG_FIN: Endif
If fstat=0
    [F:SQD]SOHNUM = [F:SOP]SOHNUM
    [F:SQD]SOPLIN = [F:SOP]SOPLIN
#   Sauvegarde état ligne devis
    WORDFLG = [F:SQD]ORDFLG

    Raz WDIFF
    WDIFF      = [F:SQD]QTY-[F:SQD]ORDQTY

    [F:SQD]ORDFLG=1
    [F:SQD]ORDQTY += [F:SOQ]QTY
    If [F:SQD]ORDQTY >= [F:SQD]QTY
        [F:SQD]ORDFLG=2
    Endif
#    Mise à jour de l'entête devis
    Gosub MAJENTDEV
    If GOK = 0  Return  Endif
    If evalue ("dim([F:SQD]UPDDAT)")>0 [F:SQD]UPDDAT = date$: Endif
    If evalue ("dim([F:SQD]UPDUSR)")>0 [F:SQD]UPDUSR = GUSER: Endif
    If evalue ("dim([F:SQD]EXPNUM)")>0 [F:SQD]EXPNUM = [C]EXPORT: Endif
    Rewrite [SQD]
    If fstat : Call FSTA("SQD") From GLOCK : Goto CRELIG_FIN : Endif
    Goto CRELIG_FIN
Endif
# FGR 01/02/2010 : X3SUIVI60986
#If fstat :GOK=0: Call RSTA("SQD",[M:SOH0]SQHNUM+num$([M:SOH4]SQDLIN(nolign-1))) From GLOCK: Endif
If fstat : GOK=0: Call RSTA("SQD",[F:SOH]SQHNUM+num$([F:SOP]SQDLIN)) From GLOCK: Endif

$CRELIG_FIN
#Local File [SOP]
#Default File [SOP]
Return
####################################################################
$MODLIG_SQD
Local Decimal WDELTAQTY
Local Integer WORDFLG
Local Decimal WDIFF

#-------------------------------------------------#
# Modif. détail devis en modif cde       - VALLIG #
#-------------------------------------------------#
If  [M:SOH4]SQDLIN(nolign-1) = 0 : Return : Endif

WDELTAQTY = [M]QTY(nolign-1) - [M]YQTY(nolign-1)
If WDELTAQTY = 0 : Return : Endif
If  !clalev([F:SQD]) : Local File SQUOTED [SQD] : Endif
Readlock [SQD] SQD0=[M:SOH4]DETSQHNUM(nolign-1);[M:SOH4]SQDLIN(nolign-1)
# Enregistrement locké
If fstat=1 : GOK=-1:GLOCK="$SQUOTED"-[M:SOH4]DETSQHNUM(nolign-1)-num$([M:SOH4]SQDLIN(nolign-1)): Goto MODLIG_FIN: Endif
If fstat=0
#    Sauvegarde état ligne devis
    WORDFLG = [F:SQD]ORDFLG

    Raz WDIFF
    WDIFF      = [F:SQD]QTY-[F:SQD]ORDQTY

    [F:SQD]ORDQTY += WDELTAQTY
    [F:SQD]ORDFLG=1
    If [F:SQD]ORDQTY >= [F:SQD]QTY
        [F:SQD]ORDFLG=2
    Endif
#    Mise à jour de l'entête devis
    Gosub MAJENTDEV
    If GOK = 0  Return  Endif
    If evalue ("dim([F:SQD]UPDDAT)")>0 [F:SQD]UPDDAT = date$: Endif
    If evalue ("dim([F:SQD]UPDUSR)")>0 [F:SQD]UPDUSR = GUSER: Endif
    If evalue ("dim([F:SQD]EXPNUM)")>0 [F:SQD]EXPNUM = [C]EXPORT: Endif
    Rewrite [SQD]
    If fstat : Call FSTA("SQD") From GLOCK : Goto CRELIG_FIN : Endif
    Goto MODLIG_FIN
Endif
# FGR 01/02/2010 : X3SUIVI60986
#If fstat :GOK=0: Call RSTA("SQD",[M:SOH0]SQHNUM+num$([M:SOH4]SQDLIN(nolign-1))) From GLOCK: Endif
If fstat : GOK=0: Call RSTA("SQD",[F:SOH]SQHNUM+num$([F:SOP]SQDLIN)) From GLOCK: Endif

$MODLIG_FIN
#Local File [SOP]
#Default File [SOP]
Return
####################################################################
$SUPLIG_SQD

Local Decimal WDELTAQTY
Local Integer WORDFLG
Local Decimal WDIFF

#-------------------------------------------------#
# Modif. détail devis en suppression cde - VALLIG #
#-------------------------------------------------#
If  [F:SOP]SQDLIN = 0 : Return : Endif

WDELTAQTY = -1 * [F:SOQ]QTY
If !clalev([F:SQD]) : Local File SQUOTED [SQD] : Endif

If [F:SOP]SQHNUM="" [F:SOP]SQHNUM=[F:SOH]SQHNUM : Endif

Readlock [SQD] SQD0=[F:SOP]SQHNUM;[F:SOP]SQDLIN
# Enregistrement locké
If fstat=1 : GOK=-1:GLOCK="$SQUOTED"-[F:SOP]SQHNUM-num$([F:SOP]SQDLIN): Goto SUPLIG_FIN: Endif
If fstat=0
#   Sauvegarde état ligne devis
    WORDFLG = [F:SQD]ORDFLG
    [F:SQD]ORDFLG=1

    Raz WDIFF
    WDIFF      = [F:SQD]QTY-[F:SQD]ORDQTY

#   Recherche nouveau no dernière commande
#    Raz [F:SQD]SOHNUM, [F:SQD]SOPLIN
    Call RECH_DERCDESQD


    [F:SQD]ORDQTY += WDELTAQTY
    Raz [F:SQD]SOHNUM
    Raz [F:SQD]SOPLIN
#   Mise à jour de l'entête devis
    Gosub MAJENTDEV
    If GOK = 0  Return  Endif
    If evalue ("dim([F:SQD]UPDDAT)")>0 [F:SQD]UPDDAT = date$: Endif
    If evalue ("dim([F:SQD]UPDUSR)")>0 [F:SQD]UPDUSR = GUSER: Endif
    If evalue ("dim([F:SQD]EXPNUM)")>0 [F:SQD]EXPNUM = [C]EXPORT: Endif
    Rewrite [SQD]
    If fstat : Call FSTA("SQD") From GLOCK : Goto SUPLIG_FIN : Endif
    Goto SUPLIG_FIN
Endif
If fstat : GOK=0: Call RSTA("SQD",[F:SOH]SQHNUM+num$([F:SOP]SQDLIN)) From GLOCK: Endif

$SUPLIG_FIN
#Local File [SOP]
#Default File [SOP]
Return
####################################################################
$MAJENTDEV
#---------------------------------------------#
# Maj entête de devis (traitement général)    #
#---------------------------------------------#
Local  Decimal  MNTCALC, QTECALC

# Lecture avec lock de l'entête devis
Readlock [SQH] SQH0=[F:SOP]SQHNUM
If fstat = 1 GOK = -1
   GLOCK = "$SQUOTE"-[F:SOP]SQHNUM
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SQH",[F:SOP]SQHNUM) From GLOCK
   Return
Endif
Case TRTLIG
   When "C" : Gosub MAJENTDEV_CRE
   When "M" : Gosub MAJENTDEV_MOD
   When "A" : Gosub MAJENTDEV_ANN
Endcase
If evalue ("dim([F:SQH]UPDDAT)")>0 [F:SQH]UPDDAT = date$: Endif
If evalue ("dim([F:SQH]UPDUSR)")>0 [F:SQH]UPDUSR = GUSER: Endif
If evalue ("dim([F:SQH]EXPNUM)")>0 [F:SQH]EXPNUM = [C]EXPORT: Endif

If WQUOATI <> 0
   # -- Maj mouvement client (en devis)
   Local Char WSENS : WSENS = "+"
   If WQUOATI< 0
      WQUOATI = WQUOATI*(-1)
      WQUONOT = WQUONOT*(-1)
      WSENS   = "-"
   Endif
   Call MAJMVC ([F:SQH]BPCORD, [F:SQH]CUR, [F:SQH]CHGTYP, 0, [F:SQH]QUODAT, [F:SQH]SQHNUM, [F:SQH]SALFCY,
&               WQUONOT, WQUOATI, WSENS, "Q", "", 0) From TRTBPMVT
   If  GOK<1 : Return : Endif
Endif

# Récriture de l'entête devis (SQH)
Rewrite [SQH]
If fstat : GOK = 0 : Call FSTA("SQH") From GLOCK : Return : Endif

Return
#########################################################################
$MAJENTDEV_CRE
#-------------------------------------------------#
# Maj entête de devis en création de ligne        #
#-------------------------------------------------#
# La ligne de devis qui est en ligne n'est pas encore maj (sauf [F:SQD]ORDFLG)
[F:SQH]SOHNUM  = [F:SQD]SOHNUM
[F:SQH]ORDDAT  = [F:SOQ]ORDDAT
# La ligne de devis n'était pas transformée, et elle le devient
If WORDFLG <> 2 & [F:SQD]ORDFLG = 2
    [F:SQH]CFMLINNBR += 1
Endif
# statut du devis : 1 non commandé / 2 partielt cdé / 3 totalement cdé
If [F:SQD]ORDQTY <> 0 [F:SQH]QUOSTA = 2 Endif
If [F:SQH]CFMLINNBR = [F:SQH]LINNBR [F:SQH]QUOSTA = 3 : Endif

# -------------------------------- #
# Mise à jour de l'en-devis client #
# -------------------------------- #
Raz WQUONOT, WQUOATI
# Si Qté cdée > Ce qu'il restait à cder
# alors on décrémente de ce qu'il restait à cder
If [F:SOQ]QTY > WDIFF
   WQUOATI=(WDIFF*[F:SQD]NETPRIATI)*(-1)
   WQUONOT=(WDIFF*[F:SQD]NETPRINOT)*(-1)
# Si Qté cdée <= Ce qu'il restait à cder
# alors on décrémente de la quantité cdée
Else
   WQUOATI= ([F:SOQ]QTY*[F:SQD]NETPRIATI)*(-1)
   WQUONOT= ([F:SOQ]QTY*[F:SQD]NETPRINOT)*(-1)
Endif

Return
#########################################################################
$MAJENTDEV_MOD
#-------------------------------------------------#
# Maj entête de devis en modification de ligne    #
#-------------------------------------------------#
# La ligne de devis qui est en ligne n'est pas encore maj (sauf [F:SQD]ORDFLG)

# La ligne de devis était transformée, et elle ne l'est plus
If WORDFLG = 2 & [F:SQD]ORDFLG <> 2
   [F:SQH]CFMLINNBR -= 1
Endif
# La ligne de devis n'était pas transformée, et elle le devient
If WORDFLG <> 2 & [F:SQD]ORDFLG = 2
   [F:SQH]CFMLINNBR += 1
Endif
# statut du devis : 1 non commandé / 2 partielt cdé / 3 totalement cdé
If [F:SQH]CFMLINNBR = 0
    [F:SQH]QUOSTA = 1
    If [F:SQD]ORDQTY <> 0 [F:SQH]QUOSTA = 2 Endif
Elsif [F:SQH]CFMLINNBR = [F:SQH]LINNBR
    [F:SQH]QUOSTA = 3
Elsif [F:SQH]CFMLINNBR > 0
    [F:SQH]QUOSTA = 2
Endif

#-------------------------------------------------#
# Maj de l'en devis client                        #
#-------------------------------------------------#
Raz WQUONOT, WQUOATI
# Diminution de la qte cdée
If WDELTAQTY<0
   # Si la ligne devis n'était pas complètement cdée, on annule ce qu'il restait à cder
   If WORDFLG<>2  WDIFF=0 : Endif
   # Augmentation de l'en cde
   If (WDIFF-WDELTAQTY)>0
       WQUOATI= (WDIFF-WDELTAQTY)*[F:SQD]NETPRIATI
       WQUONOT= (WDIFF-WDELTAQTY)*[F:SQD]NETPRINOT
   Endif
# Augmentation de la qte cdée
Else
   # La ligne devis n'était pas complètement cdée (pas de maj si la ligne était cdée)
   If WORDFLG<>2
      # Si Qté cdée en plus > Ce qu'il restait à cder
      # alors on décrémente l'en devis de ce qu'il restait à cder
      If WDELTAQTY>WDIFF
         WQUOATI = (WDIFF*[F:SQD]NETPRIATI)*(-1)
         WQUONOT = (WDIFF*[F:SQD]NETPRINOT)*(-1)
      # Si Qté cdée en plus <= Ce qu'il restait à cder
      # alors on décrémente l'en devis de la quantité cdée en plus
      Else
         WQUOATI = (WDELTAQTY*[F:SQD]NETPRIATI)*(-1)
         WQUONOT = (WDELTAQTY*[F:SQD]NETPRINOT)*(-1)
      Endif
   Endif
Endif

Return
#########################################################################
$MAJENTDEV_ANN
#-----------------------------------------------#
# Maj entête de devis en annulation de ligne    #
#-----------------------------------------------#
# La ligne de devis qui est en ligne n'est pas encore maj (sauf [F:SQD]ORDFLG)
# La ligne de devis était transformée, et elle ne l'est plus
If WORDFLG = 2 & [F:SQD]ORDFLG <> 2
   [F:SQH]CFMLINNBR -= 1
Endif
# statut du devis : 1 non commandé / 2 partielt cdé / 3 totalement cdé
# Pb si une ligne partiellement commandée
If [F:SQH]CFMLINNBR = 0
    [F:SQH]QUOSTA = 1
Elsif [F:SQH]CFMLINNBR > 0
    [F:SQH]QUOSTA = 2
Endif

#-------------------------------------------------#
# Maj de l'en devis client                        #
#-------------------------------------------------#
Raz WQUONOT, WQUOATI
If WORDFLG <> 2  WDIFF = 0 : Endif
# Si qte cdée supprimé < (qte cdée-qte devis) du devis, pas de maj
If WDIFF > 0 | (WDIFF <= 0 & [F:SOQ]QTY > WDIFF*(-1))
   WQUOATI = ([F:SOQ]QTY + WDIFF) * [F:SQD]NETPRIATI
   WQUONOT = ([F:SOQ]QTY + WDIFF) * [F:SQD]NETPRINOT
Endif

# Recherche nouveau no dernière commande
#Raz [F:SQH]SOHNUM, [F:SQH]ORDDAT
Call RECH_DERCDESQH()

Return

################################################################################
# DIVSOHCLE : Solde complet d'une commande                                     #
# ---------------------------------------------------------------------------- #
# Subprog DIVSOHCLE (WSOHNUM,WMSGFLG)                                          #
#   Sous-programme appelé par l'action DIVSOHCLE.                              #
#   Cette action est utilisée par le workflow des signatures.                  #
#   Il n'y a pas forcément de transaction en cours.                            #
# ---------------------------------------------------------------------------- #
#   WSOHNUM : Numéro de la commande de vente                                   #
#   WMSGFLG : Indicateur message d'erreur (0 = pas de message d'erreur,        #
#                                          1 = erreur à l'écran (Call ERREUR), #
#                                          2 = GMESSAGE + GERR positionnés,    #
#                                          3 = message dans une trace)         #
################################################################################
Subprog DIVSOHCLE(WSOHNUM,WMSGFLG)
Value    Char    WSOHNUM
Value    Integer WMSGFLG
#----- Variables locales -----#
Local    Integer WRET, OK : OK=1
Local    Libelle WADXLOG
Local    Libelle WORIFLG : WORIFLG=0 : # Appel depuis le Workflow
Local    Char    WCCLREN
#-----
Local File SORDERQ  [SOQ] : # Il faut réouvrir à cause du "Link" workflow

If !clalev([F:SOH])  Local File SORDER    [SOH] : Endif
If !clalev([F:SOP])  Local File SORDERP   [SOP] : Endif
If GMODU(6)=2
    If !clalev([F:POQ]) Local File PORDERQ [POQ] : Endif
Endif

# --- Déclaration classe ecran pour les allocations --- #
If clalev([M:STOK])=0 Local Mask STOK [STOK] Endif
Raz [M:STOK]
# --- Déclaration classe ecran pour les allocations --- #
If clalev([M:ALP])=0 Local Mask ALLPAR [ALP] Endif
Raz [M:ALP]
# --- Déclaration classe ecran pour les encours --- #
If clalev([M:ORDK])=0 Local Mask ORDK [ORDK] Endif
Raz [M:ORDK]

#-----
If !adxlog
  [L]WADXLOG=0
  Call DEBTRANS From GLOCK
Else
  [L]WADXLOG=1
Endif
#-----
$TR_SOHCLE
If [L]WADXLOG=0
  GOK=1
  Trbegin ADOVAL
Endif
#-----
Gosub SOHCLE
If GOK=-1  Goto ROLL_SOHCLE : Endif
If GOK=0   Goto AB_SOHCLE   : Endif
#-----
If [L]WADXLOG=0
  Commit
Endif
End
#-----
$ROLL_SOHCLE
If [L]WADXLOG=0
  Rollback : Call ROLL From GLOCK
  If GROLL  End  Else  Goto TR_SOHCLE : Endif
Else
  End
Endif
#-----
$AB_SOHCLE
If [L]WADXLOG=0
  Rollback
Endif
End

#----- Début de transaction mise à jour solde -----#
$SOHCLE
Local Char     WMSG(250) # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management => why(100) ?
Local Integer  WSOPLIN
Local Decimal  WDLRQTYSTU
Local Libelle  WLOCK

GOK=1 : Raz [L]WRET
If [L]WSOHNUM=""  [L]WRET=11 : Gosub TRT_ERR_SOHCLE : Return : Endif
#----- Contrôle lock logique -----#
Call JELOCKE("SOH"+[L]WSOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="SOH"+[L]WSOHNUM
  If fstat [L]WRET=12 : Gosub TRT_ERR_SOHCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif

# -- Lecture entête commande
Read [SOH]SOH0 = [L]WSOHNUM
If fstat GOK=0 : [L]WRET=14 : Gosub TRT_ERR_SOHCLE : Goto FIN_SOHCLE : Endif
GREV=1

# -- Demande de modification avec ou sans avenant
#  If GSALREV = 2 Call OUINON(mess(51,194,1),OK) From GESECRAN Endif
#   -- Historisation si modif. avec avenant
#  If OK=2
#      GREV = 2
#      [F:SOH]REVNUM+=1
#      Call HISTO_REV ("SOH", "M") From TRTVENMAJ
#  Endif

If [L]WORIFLG=0
    #----- Variables locales -----#
    Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE  =GSOCIETE
    Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV =GLOCALDEV
    Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP   =GFINRSP
    Local Char    SAV_GCURLEG(GLONADI)   : [L]SAV_GCURLEG   =GCURLEG
    Local Integer SAV_GTYPGEN            : [L]SAV_GTYPGEN   =GTYPGEN
    Local Integer SAV_GTYPANA            : [L]SAV_GTYPANA   =GTYPANA
    Call GETDEV([F:SOH]SALFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[F:SOH]SALFCY : Endif
    # --> Récupération du paramètre vente : GSOHAPPOST    : Mvts client si commandes non signées
    Local Char     WPARAM(GLONADP)
    Call PARAML([F:SOH]STOFCY,"SOHAPPOST",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GSOHAPPOST= val(WPARAM)
    # --> Récupération du paramètre vente : GSOHAPPORD    : Encours si commandes non signées
    Local Char     WPARAM(GLONADP)
    Call PARAML([F:SOH]STOFCY,"SOHAPPORD",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GSOHAPPORD= val(WPARAM)
Endif

For [SOQ]SOQ0 Where SOHNUM=[L]WSOHNUM
    If [F:SOQ]SOQSTA=1
       [L]WSOPLIN=[F:SOQ]SOPLIN
       Readlock [SOQ] Curr
       If fstat=1
         GOK=-1 : GLOCK="$SORDERQ"-[L]WSOHNUM-num$([L]WSOPLIN)
         [L]WRET=16 : Gosub TRT_ERR_SOHCLE : Break
       Elsif fstat
         GOK=0  : Call RSTA("SOQ",[L]WSOHNUM-num$([L]WSOPLIN)) From GLOCK
         [L]WRET=17 : Gosub TRT_ERR_SOHCLE : Break
       Endif
       Readlock [SOP] SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
       If fstat=1
         GOK=-1 : GLOCK="$SORDERP"-[L]WSOHNUM-num$([L]WSOPLIN)
         [L]WRET=16 : Gosub TRT_ERR_SOHCLE : Break
       Elsif fstat
         GOK=0  : Call RSTA("SOP",[L]WSOHNUM-num$([L]WSOPLIN)) From GLOCK
         [L]WRET=17 : Gosub TRT_ERR_SOHCLE : Break
       Endif
       If GREV=2
#          -- Historisation si modif. avec avenant
           [F:SOP]LINREVNUM = [F:SOH]REVNUM
           Call HISTO_REV ("SOQ", "M") From TRTVENMAJ
           Call REWSOP        : # Bug 69269
           If fstat
               GOK=0 : Call FSTA("SOP") From GLOCK
               [L]WRET=20 : Gosub TRT_ERR_SOHCLE : Break
           Endif
       Endif
       # 107888 : Scheduled invoices : (LD:01/04/16)
       #If [F:SOH]SOHCAT <> 3
       If [F:SOH]SOHCAT <> 3 & [F:SOQ]DLVFLG=2
       # Deliverable item (Direct order/Open order/Loan order)
       # 107888 : Scheduled invoices : (LD:01/04/16)
#      -- Calcul du reste à livrer pour maj en commande
          [L]WDLRQTYSTU  = [F:SOQ]QTYSTU - [F:SOQ]DLVQTYSTU - [F:SOQ]ODLQTYSTU
#      -- La ligne est facturée si tout ce qui est livré est facturé
          If [F:SOQ]INVQTY <> 0 & [F:SOQ]INVQTY >= [F:SOQ]DLVQTY + [F:SOQ]ODLQTY
              [F:SOQ]INVFLG = 2
              [F:SOH]INVLINNBR+=1
          Endif
       Else
       # 107888 : Scheduled invoices : (LD:01/04/16)
       # Undeliverable item  (Direct order/Direct invoicing order)
       # Direct invoicing order
       # 107888 : Scheduled invoices : (LD:01/04/16)
#      -- Calcul du reste à livrer pour maj en commande
          [L]WDLRQTYSTU = [F:SOQ]QTYSTU - [F:SOQ]INVQTYSTU - [F:SOQ]ODLQTYSTU
#      -- La ligne est facturée si tout ce qui est commandé est facturé
          If ([F:SOQ]INVQTY <> 0 | [F:SOQ]ODLQTY <> 0)
&           & [F:SOQ]INVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
             [F:SOQ]INVFLG = 2
             [F:SOH]INVLINNBR+=1
          Endif
       Endif

#      -- Si solde d'une ligne : Suppression des allocations
       # Issue X3-70669
       #If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & ([F:SOQ]SHTQTY<>0 | [F:SOQ]ALLQTY<>0)
       If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & ([F:SOQ]SHTQTYSTU<>0 | [F:SOQ]ALLQTYSTU<>0)
       # End issue X3-70669
           Local  Decimal  WALLQTYSTU, WSHTQTYSTU
           [L]WALLQTYSTU=[F:SOQ]ALLQTYSTU
           [L]WSHTQTYSTU=[F:SOQ]SHTQTYSTU
           Call GENALLORD("","","A", 1, 1, 0, [L]WALLQTYSTU, [L]WSHTQTYSTU, [L]WRET) From TRTVENALL
           If [L]WRET = 1 GOK=0 : [L]WRET=19 : Gosub TRT_ERR_SOHCLE : Break : Endif
           If [L]WALLQTYSTU<>[F:SOQ]ALLQTYSTU | [L]WSHTQTYSTU<>[F:SOQ]SHTQTYSTU
               GOK=0 : [L]WRET=19 : Gosub TRT_ERR_SOHCLE : Break
           Endif
       Endif
       [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
       [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
       If GOK < 1 Break : Endif
#      -- Suppression de l'en-cours dans ORDERS
       If [F:SOQ]STOMGTCOD <> 1 &  [F:SOQ]DEMNUM <> ""

           # V6 Affectations 69408
           Gosub SUP_MTO_AV_SOQ From SALMTOLIB
           #Gosub RAZFMIPOH From SUBSOHA : # GH 29/10/2013 bug 93962

           Local Decimal WCPLQTY
           If [F:SOH]SOHCAT = 3
               [L]WCPLQTY = [F:SOQ]INVQTYSTU
           Else
               [L]WCPLQTY = [F:SOQ]DLVQTYSTU
           Endif
           Local Char    WTRTORD : Raz [L]WTRTORD
#           If [F:SOQ]ODLQTYSTU = 0 WTRTORD = "A" Else WTRTORD="M" Endif
           If [F:SOQ]ODLQTYSTU = 0 [L]WTRTORD = "A" Else [L]WTRTORD="S" Endif
           Gosub APPELWIP From TRTVENMAJ
           If [L]WTRTORD="A" [F:SOQ]DEMNUM="" Endif
       Endif
       If [L]WCCLREN <> ""
           [F:SOQ]CCLREN=[L]WCCLREN
           [F:SOQ]CCLDAT=date$
       Endif
#      -- Si solde d'une ligne : Décrémentation de l'en-cde client dans les mouvements article
#      --> Si cde signée ou Si paramètre maj encours article cde non signée à Oui
       If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1
           Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, max(0,[L]WDLRQTYSTU), "-", "S", [L]WRET) From TRTVENMAJ
           If GOK<1 [L]WRET=21 : Gosub TRT_ERR_SOHCLE : Break : Endif
       Endif
       [F:SOQ]SOQSTA=3
       [F:SOH]CLELINNBR+=1
       Call REWSOQ        : # Bug 69269
       If fstat
           GOK=0 : Call FSTA("SOQ") From GLOCK
           [L]WRET=18 : Gosub TRT_ERR_SOHCLE : Break
       Endif
#
       [F:SOP]SOQSTA = [F:SOQ]SOQSTA
       # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
       #--All invoice schedule line that have a status other than "invoiced"/"credit memo" are set to "closed"
       If [F:SOQ]SOHCAT=1 and [F:SOP]INVCND<>""
         #TODO
         Gosub SOHCLE_SOQ From LIBSAL_INVCND_SOH
         If GOK=0 or GERR>0
           [L]WRET=22 : Gosub TRT_ERR_SOHCLE : Break
         Endif
       Endif
       # End issue 107888
       Call REWSOP        : # Bug 69269
       If fstat
           GOK=0 : Call FSTA("SOP") From GLOCK
           [L]WRET=20 : Gosub TRT_ERR_SOHCLE : Break
       Endif
    Endif
Next
If GOK<1 Goto FIN_SOHCLE Endif

# Maj si cde signée ou Si Paramètre maj encours client cde non signée à "Oui" et cde non intra-société
If ([F:SOH]APPFLG>2 | GSOHAPPOST=2) & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
    # Bug 70837 : Ne pas décrementer l'en commande client cde (En cde historique)
    ## Maj mouvement client (en commande client cde)
    #Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM,  [F:SOH]SALFCY,
#&         [F:SOH]DLRNOT, [F:SOH]DLRATI, "-", "C", "", [F:SOH]SOHCAT) From TRTBPMVT
    #If GOK<1 Goto FIN_SOHCLE Endif
    # Maj mouvement client (en commande)
    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&         [F:SOH]DLRNOT, [F:SOH]DLRATI, "-", "F", "", [F:SOH]SOHCAT) From TRTBPMVT
    If GOK<1 Goto FIN_SOHCLE Endif
Endif
If [L]WCCLREN <> ""
    [F:SOH]CCLREN=[L]WCCLREN
    [F:SOH]CCLDAT=date$
Endif
Raz [F:SOH]DLRNOT, [F:SOH]DLRATI
If [F:SOH]CLELINNBR >= [F:SOH]LINNBR : [F:SOH]ORDSTA = 2 : Endif
If [F:SOH]INVLINNBR >= [F:SOH]LINNBR : [F:SOH]INVSTA = 3 : Endif

Call REWSOH        : # Bug 69269
If fstat
    GOK=0 : Call FSTA("SOH") From GLOCK
    [L]WRET=15 : Gosub TRT_ERR_SOHCLE : Goto FIN_SOHCLE
Endif

#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPSOH>1 & [L]WORIFLG=1 & [F:SOH]ORDSTA=2 & [F:SOH]APPFLG<3
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  If [F:SOH]SOHCAT<>4
    Call ANNULE_SUIVI("SOH",mess(654,197,1),1,[L]WRET) From TRTVENDIV
  Else
    Call ANNULE_SUIVI("SOC",mess(654,197,1),1,[L]WRET) From TRTVENDIV
  Endif
  If GOK<1  Goto FIN_SOHCLE : Endif
Endif

$FIN_SOHCLE
If [L]WLOCK  Unlock="SOH"+[L]WSOHNUM : Endif

If [L]WORIFLG=0
    #----- Variables locales -----#
    GSOCIETE  =[L]SAV_GSOCIETE
    GLOCALDEV =[L]SAV_GLOCALDEV
    GFINRSP   =[L]SAV_GFINRSP
    GCURLEG   =[L]SAV_GCURLEG
    GTYPGEN   =[L]SAV_GTYPGEN
    GTYPANA   =[L]SAV_GTYPANA
Endif

Return


#-----------------------------------------------------------------#
#                     Traitement des erreurs                      #
# --------------------------------------------------------------- #
# 11 = WSOHNUM Paramètre non renseigné                            #
# 12 = $SORDER xxxxxxxx Modification en cours sur un autre poste  #
# 13 = Erreur d'accès sur le fichier SORDER xxxxxxxx              #
# 14 = xxxxxxxxxx Commande introuvable !                          #
# 15 = Erreur d'écriture sur le fichier SORDER xxxxxxxx           #
# 16 = Erreur d'accès sur le fichier SORDERQ xxxxxxxx             #
# 17 = xxxxxxxxxx 9999 Commande introuvable !                     #
# 18 = Erreur d'écriture sur le fichier SORDERQ xxxxxxxx          #
# 19 = xxxxxxxxxx Problème de mise à jour des allocations         #
# 20 = Erreur d'écriture sur le fichier SORDERP xxxxxxxx          #
# 21 = xxxxxxxxxx Problème de mise à jour des mouvements articles #
#-----------------------------------------------------------------#
$TRT_ERR_SOHCLE
Case [L]WRET
  When 11 : [L]WMSG="WSOHNUM"-mess(136,199,1)              : GOK=0
  When 12 : [L]WMSG="$SORDER"-[L]WSOHNUM-mess(10,100,1)    : GOK=0
  When 13 : [L]WMSG=mess(12,100,1)-"SORDER"-[L]WSOHNUM
  When 14 : [L]WMSG=[L]WSOHNUM-mess(359,197,1)
  When 15 : [L]WMSG=mess(13,100,1)-"SORDER"-[L]WSOHNUM
  When 16 : [L]WMSG=mess(12,100,1)-"SORDERQ"-[L]WSOHNUM
  When 17 : [L]WMSG=[L]WSOHNUM-num$([L]WSOPLIN)-mess(359,197,1)
  When 18 : [L]WMSG=mess(13,100,1)-"SORDERQ"-[L]WSOHNUM
  When 19 : [L]WMSG=[F:SOQ]ITMREF-mess(96,197,1)
  When 20 : [L]WMSG=mess(13,100,1)-"SORDERP"-[L]WSOHNUM
  When 21 : [L]WMSG=[F:SOQ]ITMREF-mess(94,197,1)
  When 22 : [L]WMSG=GMESSAGE : Raz GMESSAGE # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
Endcase
Case [L]WMSGFLG
  When 1 : If GOK=1
             Call MESSAGE ([L]WMSG)    From GESECRAN
           Else
             Call ERREUR ([L]WMSG)     From GESECRAN
           Endif
  When 2 : If GOK=1
             GMESSAGE=[L]WMSG : GERR=2
           Else
             GMESSAGE=[L]WMSG : GERR=1
           Endif
  When 3 : If GOK=1
             Call ECR_TRACE([L]WMSG,0) From GESECRAN
           Else
             Call ECR_TRACE([L]WMSG,1) From GESECRAN
           Endif
#           If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endcase
Return


############################################################################
# Solde d'une commande de vente                 LD  03/07/01               #
############################################################################
Subprog DIVCLESOH(WSOHNUM, WCCLREN)
Value Char WSOHNUM
Value Char WCCLREN

Local Integer  WRET, OK : OK=1
Local Shortint WTRANS
Local Decimal  WDLRQTYSTU

Local    Libelle WORIFLG : WORIFLG=1 : # Appel hors Workflow (annulation suivi)
Local    Integer WMSGFLG : WMSGFLG=3 : # Bug 75425

If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

#----- Début de transaction mise à jour solde -----#
$TR_SOLSOH
GOK=1
If adxlog=0                       : # A voir avec Lucie HN
  WTRANS=1                        : # A voir avec Lucie HN
  Trbegin [SOH], [SOQ], [SOP]
Endif                             : # A voir avec Lucie HN

Gosub SOHCLE
If GOK=-1 Goto ROLL_SOLSOH : Endif
If GOK=0  Goto AB_SOLSOH : Endif
If WTRANS=1  : Commit : Endif     : # A voir avec Lucie HN
End

# A SUPPRIMER  #########################################

# -- Lecture entête commande
  Readlock [SOH]SOH0 = WSOHNUM
  If    fstat=1  GOK=-1 : GLOCK="$SORDER"+WSOHNUM             : Goto ROLL_SOLSOH
  Elsif fstat    GOK=0  : Call RSTA("SOH",WSOHNUM) From GLOCK : Goto AB_SOLSOH
  Endif
  GREV=1
# -- Demande de modification avec ou sans avenant
#  If GSALREV = 2 Call OUINON(mess(51,194,1),OK) From GESECRAN Endif
#   -- Historisation si modif. avec avenant
#  If OK=2
#      GREV = 2
#      [F:SOH]REVNUM+=1
#      Call HISTO_REV ("SOH", "M") From TRTVENMAJ
#  Endif

  For [SOQ]SOQ0 Where SOHNUM=WSOHNUM
    If [F:SOQ]SOQSTA=1
       Readlock [SOQ] Curr
       If fstat=1
         GOK=-1 : GLOCK="$SORDERQ"-WSOHNUM            : Break
       Elsif fstat
         GOK=0  : Call RSTA("SOQ",WSOHNUM) From GLOCK : Break
       Endif
       Readlock [SOP] SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
       If fstat=1
         GOK=-1 : GLOCK="$SORDERQ"-WSOHNUM            : Break
       Elsif fstat
         GOK=0  : Call RSTA("SOQ",WSOHNUM) From GLOCK : Break
       Endif
       If GREV=2
#          -- Historisation si modif. avec avenant
           [F:SOP]LINREVNUM = [F:SOH]REVNUM
           Call HISTO_REV ("SOQ", "M") From TRTVENMAJ
           Rewrite [SOP]
           If fstat GOK=0 : Call FSTA("SOP") From GLOCK : Break : Endif
       Endif
       If [F:SOH]SOHCAT <> 3
#      -- Calcul du reste à livrer pour maj en commande
          WDLRQTYSTU  = [F:SOQ]QTYSTU - [F:SOQ]DLVQTYSTU - [F:SOQ]ODLQTYSTU
#      -- La ligne est facturée si tout ce qui est livré est facturé
          If [F:SOQ]INVQTY <> 0 & [F:SOQ]INVQTY >= [F:SOQ]DLVQTY + [F:SOQ]ODLQTY
              [F:SOQ]INVFLG = 2
              [F:SOH]INVLINNBR+=1
          Endif
       Else
#      -- Calcul du reste à livrer pour maj en commande
          WDLRQTYSTU = [F:SOQ]QTYSTU - [F:SOQ]INVQTYSTU - [F:SOQ]ODLQTYSTU
#      -- La ligne est facturée si tout ce qui est commandé est facturé
          If ([F:SOQ]INVQTY <> 0 | [F:SOQ]ODLQTY <> 0)
&           & [F:SOQ]INVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
             [F:SOQ]INVFLG = 2
             [F:SOH]INVLINNBR+=1
          Endif
       Endif

#      -- Si solde d'une ligne : Suppression des allocations
       If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & ([F:SOQ]SHTQTY<>0 | [F:SOQ]ALLQTY<>0)
           Local  Integer  WRET
           Local  Decimal  WALLQTYSTU, WSHTQTYSTU
           WALLQTYSTU=[F:SOQ]ALLQTYSTU
           WSHTQTYSTU=[F:SOQ]SHTQTYSTU
           Call GENALLORD("","","A", 1, 1, 0, WALLQTYSTU, WSHTQTYSTU, WRET) From TRTVENALL
           If WRET = 1 GOK = 0 : Break : Endif
           If WALLQTYSTU<>[F:SOQ]ALLQTYSTU | WSHTQTYSTU<>[F:SOQ]SHTQTYSTU GOK=0 : Break : Endif
       Endif
       [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
       [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
       If GOK < 1 Break : Endif
#      -- Suppression de l'en-cours dans ORDERS
       If [F:SOQ]STOMGTCOD <> 1 &  [F:SOQ]DEMNUM <> ""
           Local  Decimal  WCPLQTY

           # V6 Affectations 69408
           Gosub SUP_MTO_AV_SOQ From SALMTOLIB
           #Gosub RAZFMIPOH From SUBSOHA : # GH 29/10/2013 bug 93962

           If [F:SOH]SOHCAT = 3
               WCPLQTY = [F:SOQ]INVQTYSTU
           Else
               WCPLQTY = [F:SOQ]DLVQTYSTU
           Endif
           Local Char    WTRTORD : Raz WTRTORD
#           If [F:SOQ]ODLQTYSTU = 0 WTRTORD = "A" Else WTRTORD="M" Endif
           If [F:SOQ]ODLQTYSTU = 0 WTRTORD = "A" Else WTRTORD="S" Endif
           Gosub APPELWIP From TRTVENMAJ
           If WTRTORD="A" [F:SOQ]DEMNUM="" Endif
       Endif
       If WCCLREN <> ""
           [F:SOQ]CCLREN=WCCLREN
           [F:SOQ]CCLDAT=date$
       Endif
#      -- Si solde d'une ligne : Décrémentation de l'en-cde client dans les mouvements article
#      --> Si cde signée ou Si paramètre maj encours article cde non signée à Oui
       If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1
           Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, max(0,WDLRQTYSTU), "-", "S", WRET) From TRTVENMAJ
           If GOK=-1 Break  : Endif
           If GOK=0  Break  : Endif
       Endif
       [F:SOQ]SOQSTA=3
       [F:SOH]CLELINNBR+=1
       Rewrite [SOQ]
       If fstat GOK=0 : Call FSTA("SOQ") From GLOCK : Break : Endif
#
       [F:SOP]SOQSTA = [F:SOQ]SOQSTA
       Rewrite [SOP]
       If fstat : GOK = 0 : Call FSTA("SOP") From GLOCK : Break : Endif
    Endif
  Next
  If GOK=-1 Goto ROLL_SOLSOH : Endif
  If GOK=0  Goto AB_SOLSOH   : Endif

  # Maj si cde signée ou Si Paramètre maj encours client cde non signée à "Oui" et cde non intra-société
  If ([F:SOH]APPFLG>2 | GSOHAPPOST=2) & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
      # Maj mouvement client (en commande client cde)
      Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM,  [F:SOH]SALFCY,
&         [F:SOH]DLRNOT, [F:SOH]DLRATI, "-", "C", "", [F:SOH]SOHCAT) From TRTBPMVT
      If GOK=-1 Goto ROLL_SOLSOH : Endif
      If GOK=0  Goto AB_SOLSOH   : Endif
      # Maj mouvement client (en commande)
      Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&         [F:SOH]DLRNOT, [F:SOH]DLRATI, "-", "F", "", [F:SOH]SOHCAT) From TRTBPMVT
      If GOK=-1 Goto ROLL_SOLSOH : Endif
      If GOK=0  Goto AB_SOLSOH   : Endif
  Endif
  If WCCLREN <> ""
      [F:SOH]CCLREN=WCCLREN
      [F:SOH]CCLDAT=date$
  Endif
  Raz [F:SOH]DLRNOT, [F:SOH]DLRATI
  If [F:SOH]CLELINNBR >= [F:SOH]LINNBR : [F:SOH]ORDSTA = 2 : Endif
  If [F:SOH]INVLINNBR >= [F:SOH]LINNBR : [F:SOH]INVSTA = 3 : Endif

  Rewrite [SOH]
  If fstat GOK=0 : Call FSTA("SOH") From GLOCK : Goto AB_SOLSOH : Endif
If WTRANS=1  : Commit : Endif : # A voir avec Lucie HN
End
# A SUPPRIMER  #########################################



$ROLL_SOLSOH
If WTRANS=1 : #VPO 24/08/09 FQ56832
    Rollback : Call ROLL From GLOCK
    If GROLL  End Else Goto TR_SOLSOH : Endif
Else
    End : # on ne peut pas boucler sans faire un rollback !!
Endif
$AB_SOLSOH
If WTRANS=1 : #VPO 24/08/09 FQ56832
    Rollback
Endif
End

############################################################################
# Solde d'une ligne de commande de vente                 LD  16/07/03      #
############################################################################
Subprog DIVCLESOQ(WSOHNUM, WSOPLIN, WSOQSEQ, WCCLREN)
Value Char    WSOHNUM
Value Integer WSOPLIN
Value Integer WSOQSEQ
Value Char    WCCLREN

Local Decimal  WALLQTY, WDLRQTY, WDLRQTYSTU, WINVQTY
Local Decimal  WLINDLRNOT, WLINDLRATI
Local Char     WSENS

Local Shortint WSUPALL, WTRANS : Raz WSUPALL
Local Integer  WRET, OK : OK=1

If clalev([F:SOH]) = 0 Local File SORDER  Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ Endif
If clalev([F:SOP]) = 0 Local File SORDERP Endif
If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

# --- Déclaration classe ecran pour les encours --- #
If clalev([M:ORDK]) = 0 Local Mask ORDK [ORDK]  Endif
# --- Déclaration classe ecran pour les allocations --- #
If clalev([M:ALP])  = 0 Local Mask ALLPAR [ALP] Endif

#----- Début de transaction mise à jour solde -----#
$TR_SOLSOQ
GOK=1
If adxlog=0
  WTRANS=1
  Trbegin [SOH], [SOQ], [SOP]
Endif
# -- Lecture entête commande
Readlock [SOH]SOH0 = WSOHNUM
If    fstat=1  GOK=-1 : GLOCK="$SORDER"+WSOHNUM             : Goto ROLL_SOLSOQ
Elsif fstat    GOK=0  : Call RSTA("SOH",WSOHNUM) From GLOCK : Goto AB_SOLSOQ
Endif
GREV=1

Readlock [SOQ] SOQ0=WSOHNUM;WSOPLIN;WSOQSEQ
If fstat=1
    GOK=-1 : GLOCK="$SORDERQ"-WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ) : Goto ROLL_SOLSOQ
Elsif fstat
    GOK=0  : Call RSTA("SOQ",WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ)) From GLOCK : Goto AB_SOLSOQ
Endif
Readlock [SOP] SOP0=WSOHNUM;WSOPLIN;WSOQSEQ
If fstat=1
    GOK=-1 : GLOCK="$SORDERP"-WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ) : : Goto ROLL_SOLSOQ
Elsif fstat
    GOK=0  : Call RSTA("SOP",WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ)) From GLOCK : Goto AB_SOLSOQ
Endif

# Calcul du total alloué\livré\facturé
WALLQTY = [F:SOQ]ALLQTY + [F:SOQ]OPRQTY+ [F:SOQ]PREQTY+ [F:SOQ]ODLQTY
# 107888 : Scheduled invoices : (LD:01/04/16)
#If [F:SOH]SOHCAT <> 3
If [F:SOH]SOHCAT <> 3 & [F:SOQ]DLVFLG=2
    # Deliverable item (Direct order/Open order/Loan order)
# 107888 : Scheduled invoices : (LD:01/04/16)
    # Commande normale
    WALLQTY += [F:SOQ]DLVQTY
    # Calcul du reste à livrer
    WDLRQTY     = [F:SOQ]QTY - [F:SOQ]DLVQTY - [F:SOQ]ODLQTY
    WDLRQTYSTU  = [F:SOQ]QTYSTU - [F:SOQ]DLVQTYSTU - [F:SOQ]ODLQTYSTU
    #--------------
    # Calcul du total facturé
    WINVQTY = [F:SOQ]INVQTY
Else
    # 107888 : Scheduled invoices : (LD:01/04/16)
    # Undeliverable item  (Direct order/Direct invoicing order)
    # Direct invoicing order
    # 107888 : Scheduled invoices : (LD:01/04/16)
    # Commande à facturation directe
    WALLQTY += [F:SOQ]INVQTY
    # Calcul du reste à livrer
    WDLRQTY    = [F:SOQ]QTY - [F:SOQ]INVQTY - [F:SOQ]ODLQTY
    WDLRQTYSTU = [F:SOQ]QTYSTU - [F:SOQ]INVQTYSTU - [F:SOQ]ODLQTYSTU
    # Calcul du total facturé
    WINVQTY = [F:SOQ]INVQTY + [F:SOQ]ODLQTY
Endif
# Calcul du Montant net HT à livrer de la ligne
WLINDLRNOT = WDLRQTY*[F:SOP]NETPRINOT
Call ARRDEV (WLINDLRNOT, [F:SOH]CUR) From TRTDIV
# Calcul du Montant net TTC à livrer de la ligne
WLINDLRATI = WDLRQTY*[F:SOP]NETPRIATI
Call ARRDEV (WLINDLRATI, [F:SOH]CUR) From TRTDIV

If [F:SOQ]SOQSTA=1
    Gosub TRT_SOLDE_SOQ
Else
    Gosub TRT_DESOLDE_SOQ
Endif
If GOK=-1 Goto ROLL_SOLSOQ Endif
If GOK=0  Goto AB_SOLSOQ Endif

# Mise à jour de l'en-cde client dans les mouvements article
If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1
    Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, max(0,WDLRQTYSTU), WSENS, "S", WRET) From TRTVENMAJ
    If GOK=-1 Goto ROLL_SOLSOQ : Endif
    If GOK=0  Goto AB_SOLSOQ   : Endif
Endif

Call REWSOQ    : # Bug 69269
If fstat GOK=0 : Call FSTA("SOQ") From GLOCK : Goto AB_SOLSOQ : Endif
#
[F:SOP]SOQSTA = [F:SOQ]SOQSTA
Call REWSOP    : # Bug 69269
If fstat : GOK = 0 : Call FSTA("SOP") From GLOCK : Goto AB_SOLSOQ : Endif
# Maj si cde signée ou Si Paramètre maj encours client cde non signée à "Oui" et cde non intra-société
If ([F:SOH]APPFLG>2 | GSOHAPPOST=2) & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
    # Bug 70837 : Ne pas décrementer l'en commande client cde (En cde historique)
    ## Maj mouvement client (en commande client cde)
    #Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
#&         WLINDLRNOT, WLINDLRATI, WSENS, "C", "", [F:SOH]SOHCAT) From TRTBPMVT
    #If GOK=-1 Goto ROLL_SOLSOQ : Endif
    #If GOK=0  Goto AB_SOLSOQ   : Endif
    # Maj mouvement client (en commande)
    Call  MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&         WLINDLRNOT, WLINDLRATI, WSENS, "F", "", [F:SOH]SOHCAT) From TRTBPMVT
    If GOK=-1 Goto ROLL_SOLSOQ : Endif
    If GOK=0  Goto AB_SOLSOQ   : Endif
Endif
# Recalcul état solde de la commande
If [F:SOH]CLELINNBR >= [F:SOH]LINNBR : [F:SOH]ORDSTA = 2 : Else [F:SOH]ORDSTA=1 : Endif
# Recalcul état facture de la commande
If [F:SOH]INVLINNBR >= [F:SOH]LINNBR
    [F:SOH]INVSTA = 3
Elsif [F:SOH]INVLINNBR>0 | WINVQTY<>0
    [F:SOH]INVSTA = 2
Else
    [F:SOH]INVSTA = 1
Endif

# Recalcul état allocation de la commande
# En cas de solde
# Si la ligne a été désallouée et que la commande était totalement allouée
# --> La commande devient partiellement allouée ou non allouée (pas sûr à tous les coups)
If [F:SOQ]SOQSTA=3 & [F:SOH]ALLSTA=3 & [F:SOQ]STOMGTCOD<>1 & WSUPALL=1
    If [F:SOH]LINNBR=1 | [F:SOH]ALLLINNBR=[F:SOH]LINNBR
        [F:SOH]ALLSTA=1
    Else
        [F:SOH]ALLSTA=2
    Endif
Endif
# En cas de désolde
# Si la ligne est gérée en stock et que la commande était totalement allouée
# --> La commande devient partiellement allouée
If [F:SOQ]SOQSTA=1 & [F:SOH]ALLSTA=3 & [F:SOQ]STOMGTCOD<>1
    [F:SOH]ALLSTA=2
Endif

Call REWSOH    : # Bug 69269
If fstat GOK=0 : Call FSTA("SOH") From GLOCK : Goto AB_SOLSOQ : Endif

If WTRANS=1  : Commit : Endif
End

$ROLL_SOLSOQ
If WTRANS=1 : #VPO 24/08/09 FQ56832
    Rollback : Call ROLL From GLOCK
    If GROLL  End Else Goto TR_SOLSOQ : Endif
Else
    End : # on ne peut pas boucler sans faire un rollback !!
Endif
$AB_SOLSOQ
If WTRANS=1 : #VPO 24/08/09 FQ56832
    Rollback
Endif
End

# ------------------------------------------------- #
#    Etiquette de solde d'une ligne de commande     #
# ------------------------------------------------- #
$TRT_SOLDE_SOQ

# 107888 : Scheduled invoices : (LD:01/04/16)
#If [F:SOH]SOHCAT <> 3
If [F:SOH]SOHCAT <> 3 & [F:SOQ]DLVFLG=2
    # Deliverable item (Direct order/Open order/Loan order)
# 107888 : Scheduled invoices : (LD:01/04/16)
    # Calcul du flag facturé
    # -- La ligne est facturée si tout ce qui est livré est facturé
    If [F:SOQ]INVQTY <> 0 & [F:SOQ]INVQTY >= [F:SOQ]DLVQTY + [F:SOQ]ODLQTY
        [F:SOQ]INVFLG = 2
        [F:SOH]INVLINNBR+=1
    Endif
Else
    # 107888 : Scheduled invoices : (LD:01/04/16)
    # Undeliverable item  (Direct order/Direct invoicing order)
    # Direct invoicing order
    # 107888 : Scheduled invoices : (LD:01/04/16)
    # Calcul du flag facturé
    # -- La ligne est facturée si tout ce qui est commandé est facturé
    If ([F:SOQ]INVQTY <> 0 | [F:SOQ]ODLQTY <> 0) & [F:SOQ]INVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
        [F:SOQ]INVFLG = 2
        [F:SOH]INVLINNBR+=1
    Endif
Endif

# La ligne était à allouer, elle ne l'est plus
If [F:SOQ]STOMGTCOD <> 1 & (WALLQTY<[F:SOQ]QTY | [F:SOQ]SHTQTY<>0) [F:SOH]ALLLINNBR-=1 : Endif
# Suppression des allocations
# Issue X3-70669
#If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA=1 & ([F:SOQ]SHTQTY<>0 | [F:SOQ]ALLQTY<>0)
If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]DEMSTA=1 & ([F:SOQ]SHTQTYSTU<>0 | [F:SOQ]ALLQTYSTU<>0)
# End issue X3-70669
    Local  Integer  WRET
    Local  Decimal  WALLQTYSTU, WSHTQTYSTU
    WSUPALL=1
    WALLQTYSTU=[F:SOQ]ALLQTYSTU
    WSHTQTYSTU=[F:SOQ]SHTQTYSTU
    Call GENALLORD("","","A", 1, 1, 0, WALLQTYSTU, WSHTQTYSTU, WRET) From TRTVENALL
    If WRET = 1 GOK = 0 : Return : Endif
    If WALLQTYSTU<>[F:SOQ]ALLQTYSTU | WSHTQTYSTU<>[F:SOQ]SHTQTYSTU GOK=0 : Return : Endif
    [F:SOQ]ALLQTY = 0 : [F:SOQ]ALLQTYSTU = 0
    [F:SOQ]SHTQTY = 0 : [F:SOQ]SHTQTYSTU = 0
Endif
If GOK < 1 Return : Endif

# Suppression de l'en-cours dans ORDERS
If [F:SOQ]STOMGTCOD <> 1 &  [F:SOQ]DEMNUM <> ""
    Local  Decimal  WCPLQTY

    # V6 Affectations 69408
    Gosub SUP_MTO_AV_SOQ From SALMTOLIB
    #Gosub RAZFMIPOH From SUBSOHA : # GH 29/10/2013 bug 93962

    If [F:SOH]SOHCAT = 3
        WCPLQTY = [F:SOQ]INVQTYSTU
    Else
        WCPLQTY = [F:SOQ]DLVQTYSTU
    Endif
    Local Char    WTRTORD
    If [F:SOQ]ODLQTYSTU = 0 WTRTORD = "A" Else WTRTORD="M" Endif
    Gosub APPELWIP From TRTVENMAJ
    If WTRTORD="A" [F:SOQ]DEMNUM="" Endif
Endif
If WCCLREN <> ""
    [F:SOQ]CCLREN=WCCLREN
    [F:SOQ]CCLDAT=date$
Endif

WSENS="-"                  : # Décrémentation de l'en-cde client dans les mouvements article
[F:SOQ]SOQSTA=3
[F:SOH]CLELINNBR+=1        : # Incrémentation du nbre de lignes soldées de la commande
[F:SOH]DLRNOT-=WLINDLRNOT  : # Diminution du montant à livrer de la commande
[F:SOH]DLRATI-=WLINDLRATI

Return

# --------------------------------------------------- #
#    Etiquette de désolde d'une ligne de commande     #
# --------------------------------------------------- #
$TRT_DESOLDE_SOQ

# La ligne redevient à allouer
If [F:SOQ]STOMGTCOD <> 1 & (WALLQTY<[F:SOQ]QTY | [F:SOQ]SHTQTY<>0) [F:SOH]ALLLINNBR+=1 : Endif
# Recréation de l'en-cours dans ORDERS
If [F:SOQ]STOMGTCOD <> 1
    Local  Decimal  WCPLQTY
    If [F:SOH]SOHCAT = 3
        WCPLQTY = [F:SOQ]INVQTYSTU
    Else
        WCPLQTY = [F:SOQ]DLVQTYSTU
    Endif
    Local Char    WTRTORD
    WTRTORD = "M" : Gosub APPELWIP From TRTVENMAJ
    # V6 Affectations
    Gosub MAJ_MTO_SOQ From SALMTOLIB
Endif
Raz [F:SOQ]CCLREN, [F:SOQ]CCLDAT

WSENS="+"                  : # Incrémentation de l'en-cde client dans les mouvements article
[F:SOQ]SOQSTA=1
[F:SOH]CLELINNBR-=1        : # Décrémentation du nbre de lignes soldées de la commande
[F:SOQ]INVFLG=1
[F:SOH]INVLINNBR-=1        : # Décrémentation du nbre de lignes facturées de la commande
[F:SOH]DLRNOT+=WLINDLRNOT  : # Augmentation du montant à livrer de la commande
[F:SOH]DLRATI+=WLINDLRATI
Return

# Bug 69269
########################################################################
# Réécriture fichier entête commande
########################################################################
Subprog REWSOH

[F:SOH]EXPNUM = [C]EXPORT
[F:SOH]UPDUSR = GUSER
[F:SOH]UPDDAT = date$
GPOINT = "BEFREWSOH"
Gosub ENTREE From EXEFNC
Rewrite [SOH]
End
########################################################################
# Réécriture fichier détail commande prix
########################################################################
Subprog REWSOP

[F:SOP]EXPNUM = [C]EXPORT
[F:SOP]UPDUSR = GUSER
[F:SOP]UPDDAT = date$
GPOINT = "BEFREWSOP"
Gosub ENTREE From EXEFNC
Rewrite [SOP]
End
########################################################################
# Réécriture fichier détail commande quantités
########################################################################
Subprog REWSOQ

[F:SOQ]EXPNUM = [C]EXPORT
[F:SOQ]UPDUSR = GUSER
[F:SOQ]UPDDAT = date$
GPOINT = "BEFREWSOQ"
Gosub ENTREE From EXEFNC
Rewrite [SOQ]
End
########################################################################
# Est-ce que le client passé en paramétre est bloqué (en-cours)
########################################################################
Funprog BPCOSTBLK(PBPCNUM)
Value Char PBPCNUM
Local Integer RBPCOSTBLK : RBPCOSTBLK=1
Local File BPCUSTOMER [BPC1]
Read [F:BPC1]BPC0=PBPCNUM
If fstat Raz [F:BPC1] : Endif
If [F:BPC1]BPCNUM <> [F:BPC1]BPCRSK
 Local Char LBPCRSK : LBPCRSK=[F:BPC1]BPCRSK
 Read [F:BPC1]BPC0=LBPCRSK
 If fstat Raz [F:BPC1] : Endif
Endif
If [F:BPC1]OSTCTL=3
 RBPCOSTBLK=2
Endif
End RBPCOSTBLK

# 86757
#-------------------------------------------------------------------------#
# Recalcul et maj des statuts d'une commande                              #
#-------------------------------------------------------------------------#
# Entrée  LSOHNUM   : N° de la commande                                   #
# Sortie  LRET      : 0 Ok ; 1 Pb                                         #
#-------------------------------------------------------------------------#
Subprog MAJSTASOH (LSOHNUM, LRET)
Value    Char    LSOHNUM
Variable Integer LRET    : LRET=0

Local Integer I, WAALLLINNBR, WALLLINNBR, WLINNBR, WDLVLINNBR, WINVLINNBR
Local Integer WALLSTA, WDLVSTA, WINVSTA
Local Decimal WTOTQTY
Local Integer WTRBEGIN
WALLSTA = 1
WDLVSTA = 1
WINVSTA = 1

If clalev ([F:SOH]) = 0 Local File SORDER  [SOH] : Endif
If clalev ([F:SOQ]) = 0 Local File SORDERQ [SOQ] : Endif

If adxlog=0
  Trbegin [SOH]
  WTRBEGIN=1
Endif

Read [SOH]SOH0=LSOHNUM
If fstat LRET=1 : Call RSTA("SOH", [F:SOH]SOHNUM) From GLOCK : End : Endif

# 95490 : Pas de Maj pour les contrats
If [F:SOH]SOHCAT=4
    If WTRBEGIN=1 Commit Endif
    End
Endif
# 95490
Filter [SOQ] Where SOHNUM = LSOHNUM
For [SOQ]
    # Traitement d'une ligne de la commande
    If [F:SOQ]STOMGTCOD <> 1 & sum([F:SOQ]ALLQTY, [F:SOQ]OPRQTY, [F:SOQ]PREQTY) <> 0 WALLSTA = 2 : Endif

    # 107888 : Scheduled invoices : (LD:01/04/16)
    #If [F:SOH]SOHCAT = 3
    If [F:SOH]SOHCAT = 3 | [F:SOQ]DLVFLG=1
        # Direct invoicing order
        # Undeliverable item  (Direct order/Direct invoicing order) :
    # 107888 : Scheduled invoices : (LD:01/04/16)
        If [F:SOQ]DLVQTY > 0 WDLVSTA = 2 : Endif
        If [F:SOQ]INVQTY > 0 | [F:SOQ]ODLQTY > 0 WINVSTA = 2 Endif
    Else
        # Deliverable item (Direct order/Open order/Loan order)     : # 107888 : Scheduled invoices : (LD:01/04/16)
        If [F:SOQ]DLVQTY > 0 | [F:SOQ]ODLQTY > 0 WDLVSTA = 2 : Endif
        If [F:SOQ]INVQTY > 0 WINVSTA = 2 Endif
    Endif

#   --- Recalcul du nbre de lignes à allouer
    If [F:SOQ]STOMGTCOD <> 1 & [F:SOQ]SOQSTA <> 3
        WLINNBR+=1
        WTOTQTY = sum([F:SOQ]ALLQTY,[F:SOQ]OPRQTY,[F:SOQ]PREQTY,[F:SOQ]ODLQTY)
        If [F:SOH]SOHCAT = 3
            WTOTQTY += sum([F:SOQ]INVQTY)
        Else
            WTOTQTY += sum([F:SOQ]DLVQTY)
        Endif
#       --- Tout n'est pas alloué : Incrémentation du nbre de lignes restant a allouer
        If WTOTQTY < [F:SOQ]QTY | [F:SOQ]SHTQTY <> 0
            WAALLLINNBR += 1
        Elsif WTOTQTY >= [F:SOQ]QTY & [F:SOQ]SHTQTY = 0
#       --- Tout est alloué : Incrémentation du nbre de lignes allouées
            WALLLINNBR += 1
        Endif
    Endif
#   --- Recalcul du nbre de lignes livrées
# 107888 : Scheduled invoices : (LD:01/04/16)
#    If [F:SOH]SOHCAT <> 3
    If [F:SOH]SOHCAT <> 3 & [F:SOQ]DLVFLG=2
        # Only for deliverable item (Direct order/Open order/Loan order)
# 107888 : Scheduled invoices : (LD:01/04/16)
        If [F:SOQ]DLVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
            WDLVLINNBR += 1
        Endif
    Endif
#   --- Recalcul du nbre de lignes facturées
    If [F:SOQ]INVFLG = 2
        WINVLINNBR += 1
    Endif
Next
Filter [SOQ]

# Cde allouée ssi cde non soldée et les lignes gérées en stock et non soldées sont totalement allouées
If [F:SOH]ORDSTA <> 2 & WLINNBR<>0 & WALLLINNBR = WLINNBR WALLSTA = 3 : Endif

If WDLVLINNBR >= [F:SOH]LINNBR WDLVSTA = 3 : Endif
If WINVLINNBR >= [F:SOH]LINNBR WINVSTA = 3 : Endif

If WALLSTA <> [F:SOH]ALLSTA | WAALLLINNBR <> [F:SOH]ALLLINNBR |
&  WDLVSTA <> [F:SOH]DLVSTA | WDLVLINNBR <> [F:SOH]DLVLINNBR |
&  WINVSTA <> [F:SOH]INVSTA | WINVLINNBR <> [F:SOH]INVLINNBR
    #--- TS 92005
    #Readlock [SOH]SOH0=[M:SOH0]SOHNUM
    #--- Issue 119042 ajout du lockwait
    Readlock [SOH]SOH0=LSOHNUM With lockwait=3
    #---
    If fstat LRET=1 : Call RSTA("SOH", [F:SOH]SOHNUM) From GLOCK : End : Endif
    #--- TS 92005
    #Update [SOH] Where SOHNUM=[M:SOH0]SOHNUM With ALLSTA=WALLSTA, ALLLINNBR=WAALLLINNBR,
    Update [SOH] Where SOHNUM=LSOHNUM With ALLSTA=WALLSTA, ALLLINNBR=WAALLLINNBR,
&                                                 INVSTA=WINVSTA, DLVLINNBR=WDLVLINNBR,
&                                                 DLVSTA=WDLVSTA, INVLINNBR=WINVLINNBR
    #---
    If fstat LRET=1 : Call FSTA("SOH") From GLOCK : Endif
Endif

#If adxlog=0
If WTRBEGIN=1
  Commit
Endif

End
# 86757

