#<AdxTL>@(#)3.0.0.0 $Revision$
Subprog PATCH(APPLI)
Value Char APPLI
Local Integer OK
Local File =APPLI+".ALISTED" [ALD]
Local File =APPLI+".ATYPE"   [ATY]
OK =1

If dim([F:ALD]TUN)<=0 : End : Endif

Trbegin [ALD]
 For [F:ALD]ALD0 
  If [F:ALD]STREND <> 3
   Call LECTURE("ATY",[F:ALD]CODTYP,"") From CONTOBJ
   If [F:ATY]OBJLIEN<>"" 
    [F:ALD]TUN = 2
    Rewrite [F:ALD]
    If fstat
     OK=0 : Call FSTA("ALISTED") From GLOCK : Break
    Endif
   Endif
  Endif
 Next ALD
 If OK<1 : Goto AB_TR_ALD : Endif 
Commit
Close Local File [ALD],[ATY]
End

$AB_TR_ALD
Close Local File [ALD],[ATY]
Rollback
End
