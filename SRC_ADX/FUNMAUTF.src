#<AdxTL>@(#)0.0.0.0 $Revision$ Contremarque
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTFMI  : Action contremarque automatique               #
#                                                                       #
#########################################################################
$ACTION

# actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH"   : Gosub OUVRE_BATCH
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "CONT_BATCH"    : Gosub CONT_BATCH
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase

# actions liées à la saisie fenêtre
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "AVANT_OK"     : Gosub AVANT_OK
  When "OK"           : Gosub OK
Endcase

Return

#########################################################################
$OUVRE_BATCH
# Issue 84721 GA 10/2012 autoriser impression en batch
#Global Integer GMAUTFB
Return

#########################################################################
$INIT

# Issue 84721 GA 10/2012 autoriser impression en batch
#If (dim(GMAUTFB) > 0) : Kill GMAUTFB : Endif

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

If !clalev([M:DIA])
  If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
  Read [AWI]AWI0 = BCRIT
  MASQUE = [F:AWI]NOMMSK(0)
  Close Local File [AWI]
  Local Mask =MASQUE [DIA]
Endif

Gosub OUVRE

If LVCR <> "" & LFCY <> ""            # 03.05 29445
#   site de production ?
    Read [FCY]FCY0 = LFCY
    If fstat | [F:FCY]MFGFLG =1
        #Call MESSAGE(LFCY-mess(259,193,1)) From GESECRAN : End : # GH 27/03/2014 bug 84721
        GERR=1 :  GMESSAGE=LFCY-mess(259,193,1) : FIN=1 : Return
    Endif
# ------------------------------------------------------- #
# N° de commande renseigné :                              #
# --> On initialise la fenêtre de sélection sans la saisir#
# ------------------------------------------------------- #
    TYPPRG = 1
    ACTION = "INIT_DIA" : Gosub ACTION From =PROG
    [M:DIA]APSTA=2 : # OF ferme : # pour le print screen
    [M:DIA]VCRNUMDEB = GNUMCDE : [M:DIA]VCRNUMFIN = GNUMCDE
    [M:DIA]TRTAUTO =1
Else
    ACTION = "INIT_DIA" : Gosub ACTION From =PROG
Endif
Return

#########################################################################
$INIT_DIA
## GH 27/03/2014 bug 84721 GMAUTFB plus utilisé, on passe toujours par le même écran même en batch
#If dim(GMAUTFB) > 0 & GMAUTFB>1 & GFONCTION<>"AREQUETE"
#    If clalev([M:DIA]) <> 0 : Close Local Mask [DIA] : Endif
#    BCRIT = "DAUTFMIB"
#    GBOITE = BCRIT
#    Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT) From GTRAITE : # Recherche infos écran critère
#    # sr 08.05 demande 31774
#    If MSKCRIT <> ""
#        If evalue("clalev([M:"+ABRCRIT+"])")=0 : Local Mask =MSKCRIT [DIA] : Endif
#    Else
#        MASQUE = "MAUTFMIB"
#        Local Mask =MASQUE [DIA]
#    Endif
#Else
#    If !clalev([M:DIA]) : Local Mask MAUTFMIB [DIA] : Endif
#Endif

If dim([L]LPRT)<0
   Gosub OUVRE
Endif

# En exécution/visualisation batch, l'écran va être chargé par les paramètres batch après cette action
If GSERVEUR | (GBATCH & GCONSDIA=1) : Return : Endif

If LFCY <> ""
   [M:DIA]MFGFCY    = LFCY
Else
   Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
   [M:DIA]MFGFCY = GFCY
Endif
GNUMCDE = LVCR

#If GUSER<>"" & [F:MTS]MODDOS=2 & dim([M:DIA]PRT)=1 # Suite Issue 84721 GA 09/2013
If GUSER<>"" & !(dim([M:DIA]PRT)<0 | varmode([M:DIA]PRT)=3) & GNUMCDE="" : # GH 27/03/2014 bug 84721
    ETAT = "DOSFAB"
    Read [ARP]ARP0 = ETAT
    If fstat : Raz [F:ARP] : Endif

    # lecture utilisateur pour récupération imprimante par défaut
    Call DEFIMP(ETAT, GUSER, "", LPRT, LOBL) From IMPRIME
    [M:DIA]OBL = LOBL
    [M:DIA]PRT = LPRT : Affzo [DIA]PRT
    If [M:DIA]PRT<>""
       Call C_PRT([M:DIA]PRT)
       GMESSAGE=""
       If mkstat & [M:DIA]OBL=1 : [M:DIA]OBL=2 : Endif
    Endif
    If [M:DIA]OBL=1 : Diszo [DIA]PRT : Endif
Endif
Return

########################################################################
## GH 27/03/2014 bug 84721
########################################################################

$DEBUT
# En saisie(batch/non batch) ou En visualisation des paramètres batch
Gosub CONTEXTE

Affzo [DIA]
If !GCONSDIA & !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3)
   [M:DIA]IMPFLG = 1+([F:MTS]MODDOS=2 & [M:DIA]APSTA=2)
   Affzo [DIA] IMPFLG
Endif
Return

$CONTROLE
$CONT_BATCH
If GSERVEUR or TYPPRG=1
  # En éxécution batch ou absence de saisie de paramètre
  Gosub CONTEXTE
  If TYPPRG=1 & !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3)
     [M:DIA]IMPFLG = 1 +([F:MTS]MODDOS = 2) : # pour le print screen
  Endif
Endif
Return

$CONTEXTE
GFCY = [M:DIA]MFGFCY
Gosub CHARG_PARAM

 # Suite Issue 84721 GA 09/2013
If dim([M:DIA]MFGTRS)<0 | [M:DIA]MFGTRS = ""
    Read [MTS]MTS0=1;GMFGMTSNUM
Else
    Read [MTS]MTS0=1;[M:DIA]MFGTRS
Endif
If fstat : Raz [F:MTS] : Endif

#Call ECR_TRACE("CONTEXTE"-GFCY-[F:MTS]MTSNUM,0) From GESECRAN
Return

########################################################################
$OUVRE
Local    Char    LFCY(GLONFCY) : LFCY = PARAM(1)
Local    Char    LVCR(GLONVCR) : LVCR = PARAM(2)
Local    Integer LRET : LRET = 0

Local Integer  OK
Local Integer  NBFMI
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     WMESS(255)
Local Char     WMESS1(255)
Local Char     WMESS2(255)
Local Date     WORIDAT
Local Char     WORIFCY(GLONFCY)
Local Integer  WLTI
Local Char     WART(GLONITM)
Local Date     WMEMDAT
Local Integer  WMAX
Local Decimal  XLTI
Local Integer  ILTI
Local Decimal  WRMD
Local Decimal  WQTY
Local Date     WOBJ
Local Date     TODAY : TODAY = date$
Local Integer  WRET
Local Char     ETAT(20)
Local Char     PARAM1(10)             # mm  12.02
Local Integer  WCDTSTA                # sr  04/01 8652
Global Char    GDEFIMP(50)            # llc 01.01 7063
Local Char     WFCY(GLONFCY)          # mm 12.02
Local Integer  DOSOK
Local Integer  WSEARCH
Local Integer  WALT

# impression 140
Local Char    LPRT(GLONAIM)
Local Integer LOBL

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFP])  = 0 : Local File MFGPRN      [MFP]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:BOH])  = 0 : Local File BOM         [BOH]  : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING     [ROH]  : Endif
If clalev([F:TBO])  = 0 : Local File TABBOMALT   [TBO]  : Endif
If clalev([F:TRO])  = 0 : Local File TABROUALT   [TRO]  : Endif
If clalev([F:SOQ])  = 0 : Local File SORDERQ     [SOQ]  : Endif    # llc 12.00 7259
If clalev([F:MTS])  = 0 : Local File MFGTRS      [MTS]  : Endif    # llc 01.01 7063
If clalev([F:ARP])  = 0 : Local File AREPORT     [ARP]  : Endif    # llc 01.01 7063
If clalev([F:AUS])  = 0 : Local File AUTILIS     [AUS]  : Endif    # llc 01.01 7063
If clalev([F:SOH])  = 0 : Local File SORDER      [SOH]  : Endif    # sr  04/01 8652
If clalev([F:AIM])  = 0 : Local File APRINTER    [AIM]  : Endif
If clalev([F:AID])  = 0 : Local File APRINTDES   [AID]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:ACC])  = 0 : Local File ACCES       [ACC]  : Endif    # FQ 57065 GA 09/2009
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

#
# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MFGK    [MFGK]
# titre de la boîte

TIT = mess(57,198,1)

Raz [M:DIA]
Return

########################################################################
$EXEC

If [M:DIA]TRTAUTO<>1 : Return : Endif

# Suite Issue 84721 GA 09/2013 déplacé en $INIT_DIA
#If GSERVEUR      # 36039 mm 05.06
#    If [M:DIA]MFGTRS = ""
#        Read [MTS]MTS0=1;GMFGMTSNUM
#        If fstat : Raz [MTS] : Endif
#    Else
#        Read [MTS]MTS0=1;[M:DIA]MFGTRS
#        If fstat : Raz [MTS] : Endif
#    Endif
#Endif

If !GSERVEUR
    # titre de la boîte
    TIT = mess(57,198,1)
    TRA=1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTFMI","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# préparation des critères de filtre
Gosub SEL_FMI

# traitement des contremarques
Gosub TRT_FMI
Return

########################################################################
$TERMINE
If !GSERVEUR  &  [M:DIA]TRTAUTO=1
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBFMI
         GERR=2 : GMESSAGE = mess(107,193,1)
    Endif
    # lecture de la trace
Endif
If GNUMCDE <> "" & NBFMI = 0 : LRET = 9 : Endif

PARAM(3) = num$(LRET)
If GFONC1 = "FUNMAUT" : Raz GFONC1 : Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     FIN = 1
Endcase
Return

########################################################################
$SETBOUT
If GBATCH = 1    # Batch lancé
    Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return

########################################################################
$AVANT_OK
# llc 09.02 16082
If !GSERVEUR & !GBATCH   &
&  [M:DIA]BPCNUMDEB = "" &
&  [M:DIA]BPCNUMFIN = "" &
&  [M:DIA]VCRNUMDEB = "" &
&  [M:DIA]VCRNUMFIN = "" &
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]ENDDATDEB = [0/0/0] &
&  [M:DIA]ENDDATFIN = [0/0/0]
   OK = 2
   Call AVERTIR(mess(64,190,1), OK) From GESECRAN
   If OK = 2 : Return : Endif
   FOK = 0 : GERR = 1 :  FIN = 0
Endif
Return

########################################################################
$OK
# [M:DIA]TRTAUTO= 0 :  pas de lancement automatique effectué
# [M:DIA]TRTAUTO= 1 :  on conserve le fait qu'on a effectué un lancement auto.

If [M:DIA]TRTAUTO = 0 : [M:DIA]TRTAUTO = 1 : Endif
Return

########################################################################
# Préparation du filtre sur la table encours (SOx)                     #
# ATTENTION: utilisé aussi par TRTVISU                                 #
########################################################################
$SEL_FMI
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

# FQ 45437 GA 01/2008 #CRITERE1= "WIPTYP=1"
CRITERE1= "find(WIPTYP,1,8)"                            # commande de vente ou transfert inter-site

CRITERE = "RMNEXTQTY>ALLQTY"                            # GH 27/03/2014 bug 84721 pour ne pas locker la cde vente inutilement
Gosub LOAD_CRITERE2                                     # qté restante non totalement allouée

CRITERE = "WIPSTA=1"                                    # statut=ferme
Gosub LOAD_CRITERE2

CRITERE = "FMI=5"                                       # contremarque prod
Gosub LOAD_CRITERE2

CRITERE  = "STOFCY = [M:DIA]MFGFCY"                     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]BPCNUMDEB <> ""
   CRITERE = "BPRNUM >= [M:DIA]BPCNUMDEB"               # borne début destin.
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]BPCNUMFIN <> ""
   CRITERE = "BPRNUM <= [M:DIA]BPCNUMFIN"               # borne fin   destin.
   Gosub LOAD_CRITERE2
Endif

# no commande
If [M:DIA]VCRNUMDEB <> ""
   CRITERE = "VCRNUM >= [M:DIA]VCRNUMDEB"               # borne début n° commande
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE = "VCRNUM <= [M:DIA]VCRNUMFIN"               # borne fin   n° commande
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"               # borne début article lancé
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"               # borne fin   matière
   Gosub LOAD_CRITERE2
Endif

# llc 09.02 16082
If [M:DIA]ENDDATDEB <> [0/0/0]
   CRITERE = "ENDDAT >= [M:DIA]ENDDATDEB"               # borne début date
   Gosub LOAD_CRITERE2
Endif
# llc 09.02 16082
If [M:DIA]ENDDATFIN <> [0/0/0]
   CRITERE = "ENDDAT <= [M:DIA]ENDDATFIN"               # borne fin   date
   Gosub LOAD_CRITERE2
Endif
Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_FMI
# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Local Char     CUSFLT(255) : Raz CUSFLT
# TODAN-X3-25070 119459.sn
Local Char     ORDHLD(20)  : Raz ORDHLD
Local Integer  SKIPORD     : SKIPORD = [V]CST_ANO
# TODAN-X3-25070 119459.en

GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

If CRITERE2 <> ""
     # FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2)  & evalue(CUSFLT)
&                      Order By Key ORD0
Else
     # FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
    Filter [ORD] Where evalue(CRITERE1) & evalue(CUSFLT)
&                      Order By Key ORD0
Endif

WFCY = [M:DIA]MFGFCY                                                           # mm  12.02
Call PARAM (WFCY,"DIRORDCTL",PARAM1) From ADOVAL  : GDIRORDCTL=val(PARAM1)     # mm  12.02

# boucle de lecture
For  [ORD]
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WVCRSEQ = [F:ORD]VCRSEQ

      # llc 12.00 7259     (ne pas générer OF si déjà existant)
      Read [SOQ]SOQ0=WVCRNUM;WVCRLIN;WVCRSEQ
      If !fstat & [F:SOQ]FMINUM <> "" : Goto N_ORD : Endif

      #----- Vérification si commande bloquée  sr 04/01 8652 -----#
      Read [SOH]SOH0=WVCRNUM
      # If fstat : Raz [F:SOH]: Endif : # GH 27/03/2014 bug 84721
      If fstat : Goto N_ORD : Endif

      # demande 19414  MM 09.03
      # point d'entree permettant d'empêcher la génération d'un OF
      GPE =0
      GPOINT="TRTAUTFMI" : Gosub ENTREE From EXEFNC
      If GPE : Goto N_ORD : Endif
      #
      # Bug 48964 : Ctrl sur clt facture (et non sur clt commande)
      Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&                 [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
      # llc 08.02 15422
      Case WCDTSTA
          When 2:    WMSG=[F:SOH]SOHNUM-mess(67,197,1)-mess(52,192,1)        # bloqué !!
                     Call ECR_TRACE(WMSG,1) From GESECRAN
                     Goto N_ORD
          When 3:  # 16430 11.02 MM
                     If GDIRORDCTL = 1
                         WMSG=[F:SOH]SOHNUM-mess(67,197,1)-mess(29,192,1)    # dépassement en cours
                         Call ECR_TRACE(WMSG,1) From GESECRAN
                         Goto N_ORD
                     Endif
                   #
      Endcase

      # TODAN-X3-25070 119459.sn: Check if the order is on hold and
      # Since we are looping through the lines...we need to skip the order that already been checked.
      If ORDHLD = AVOID.ACHAR | (ORDHLD <> AVOID.ACHAR & ORDHLD <> WVCRNUM)
        ORDHLD = WVCRNUM
        # back-to-back order is allowed
        If [F:SOH]HLDCOD <> AVOID.ACHAR & [F:SOH]HLDSTA = [V]CST_AYES &
&          func MANHLDLIB.BLK_BACK_TO_BACK([F:SOH]HLDSTA, [F:SOH]HLDCOD) = [V]CST_AYES
          #----- Display the message for back to back not allow reason -----#
          WMSG = func AFNC.MES2(mess(583,194,1), [F:SOH]SOHNUM, [F:SOH]HLDCOD)
          Call ECR_TRACE(WMSG, 1) From GESECRAN
          SKIPORD = [V]CST_AYES
          Goto N_ORD
        Else
          SKIPORD = [V]CST_ANO
        Endif
      Else
        If ORDHLD = WVCRNUM & SKIPORD = [V]CST_AYES : Goto N_ORD : Endif
      Endif
      # TODAN-X3-25070 119459.en

      Gosub TRTFMI
$N_ORD
Next
#
Filter [ORD]
#
Return

#-----------------------------------------------------------------------#
# Traitement lancement                                                  #
#-----------------------------------------------------------------------#
$TRTFMI
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Gosub MAJFMI
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête commande                      #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "SOH"+WVCRNUM
## GH 27/03/2014 bug 84721 pour ne pas delocker la cde si lockée en amont
Call TESTLOCK(SYMBOLE,OK) From GLOCKM
If OK
   SYMBOLE=""
   Return
Endif
##
Lock = SYMBOLE With lockwait = 0
If fstat
   Call ECR_TRACE(WVCRNUM - mess(10,100,1),1) From GESECRAN
   OK = 0
   fstat = 0
Else
   OK=1
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
## GH 27/03/2014 bug 84721 ne pas delocker la cde si lockée en amont
# Unlock=SYMBOLE
If SYMBOLE<>""
   Unlock=SYMBOLE
   SYMBOLE=""
Endif
Return

#-----------------------------------------------------------------------#
# Lancement                                                             #
#-----------------------------------------------------------------------#
$MAJFMI
#
#
    WMESS = mess(2,701,1)-WVCRNUM+"/"+num$(WVCRLIN)+"/"+num$(WVCRSEQ)

    Raz [M:MFGK]
#   lecture article
    If [F:ITM]ITMREF <> [F:ORD]ITMREF
        Read [ITM]ITM0=[F:ORD]ITMREF
        If fstat : Return : Endif
    Endif
#   lecture article/site
    If [F:ITF]ITMREF <> [F:ORD]ITMREF |  [F:ITF]STOFCY <> [M:DIA]MFGFCY
        Read [ITF]ITF0=[F:ORD]ITMREF;[M:DIA]MFGFCY
        If fstat : Return : Endif
    Endif
#
    [M:MFGK]CODMAJ = "P"
    [M:MFGK]CODTRS = 1                            # llc 7063, pour pouvoir éditer le dossier
    [M:MFGK]MFGNUM = ""
    [M:MFGK]MFGLIN = 0
    [M:MFGK]MFGFCY = [M:DIA]MFGFCY
    Case [M:DIA]APSTA
        When 1: [M:MFGK]MFGSTA = 2
        When 2: [M:MFGK]MFGSTA = 1
        When Default : [M:MFGK]MFGSTA = 1
    Endcase
    [M:MFGK]ITMREF = [F:ORD]ITMREF
    [M:MFGK]PRVQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY                    # llc 05.03 18026
    [M:MFGK]EXTQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY                    # llc 05.03 18026
    If [M:MFGK]EXTQTY <= 0 : Return : Endif
    # sr 06.02 demande 14660
    If [F:ITF]SHR <> 0
       [M:MFGK]EXTQTY = [M:MFGK]EXTQTY + ([M:MFGK]EXTQTY * ([F:ITF]SHR / 100))
       Call QTEARR([M:MFGK]EXTQTY,[F:ITM]STU) From TRTDIV
    Endif

    ## Issue 111543 - 2015-11-03 by GH - Consideration of QC delay
    # WOBJ           = [F:ORD]ENDDAT
    # [M:MFGK]ENDDAT = [F:ORD]ENDDAT
    If [F:ITF]QUALTI=0
       [M:MFGK]ENDDAT = [F:ORD]ENDDAT
    Else
       WORIDAT = [F:ORD]ENDDAT
       WORIFCY = [M:MFGK]MFGFCY
       WLTI    = [F:ITF]QUALTI
       Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MFGK]ENDDAT) From MFGLIB
    Endif
    WOBJ = [M:MFGK]ENDDAT
    ##

    WORIDAT=[M:MFGK]ENDDAT
    WORIFCY=[M:MFGK]MFGFCY
    WLTI = 0
    WQTY = [M:MFGK]EXTQTY
#   calcul délai
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI
#   calcul date
    WMEMDAT = [F:ORD]STRDAT

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MFGK]STRDAT) From MFGLIB

#   si date début dans le passé, recalcul en aval à partir du jour
    If [M:MFGK]STRDAT < TODAY
       [M:MFGK]STRDAT = TODAY
       WORIDAT = [M:MFGK]STRDAT

       # Issue 119766 GH 03/04/2017 - check if start date is still a working day
       #                              if not, shifts it to the first working day after to the start date
       mkstat=0
       Call CONTROL_DATE_PLN(WORIDAT,WORIFCY) From MFGLIB
       If mkstat
          GMESSAGE=""
          Call CALCUL_DATE_PLN(WORIDAT, 1,  WORIFCY, 0, [M:MFGK]STRDAT) From MFGLIB
          WORIDAT = [M:MFGK]STRDAT
       Endif

       #Call CALCUL_DATE_OF(WORIDAT, WLTI, WORIFCY, 0, 0, [M:MFGK]ENDDAT) From MFGLIB
       # révision calendriers (llc 06.00)
       Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MFGK]ENDDAT) From MFGLIB
    Endif

    ## Issue 111414 - 2016-01 by GH - Implementation of versioning
    If func ECCLIB.NBRCPN([M:MFGK]ITMREF)
      [M:MFGK]ECCVALMAJ = [F:ORD]ECCVALMAJ
      [M:MFGK]ECCVALMIN = [F:ORD]ECCVALMIN
      If [M:MFGK]ECCVALMAJ=""
         WALT = [M:MFGK]BOMALT
         Raz [M:MFGK]ECCVALMIN
         Call INIECCBOM([M:MFGK]ITMREF, [M:MFGK]MFGFCY, [M:MFGK]STRDAT, 2, [M:MFGK]ECCVALMAJ,[M:MFGK]ECCVALMIN,WALT) From MFGECCLIB
         [M:MFGK]BOMALT = WALT
      Endif
    Endif

    If [M:MFGK]BOMALT=0
       # 17942 05.03 MM
       # point d'entrée  pour choisir BOMALT
       GPOINT="CHOBOM" : Gosub ENTREE From EXEFNC
    Endif
    WSEARCH = ([M:MFGK]BOMALT=0) : # WSEARCH = 1 BOM code is to find

$ALT_SEARCH : # GH 11/09/2015 bug 108066

    If [M:MFGK]BOMALT=0
       Call RECH_NOM([M:MFGK]MFGFCY, [M:MFGK]STRDAT, [M:MFGK]BOMALT,2) From BENCHLIB
    Endif

    # Issue 82499 GA 06/2012 autoriser BOMALT=0 dès lors que la transaction accepte "Opérations seules"
###    # 02.05 28346
###    # BOMALT = 0 seulement si seul lancement autorisé par la transaction = opérations seules - 45734 mm 02.08
###    If [F:MTS]MFGMODO = 1| find([F:MTS]MFGMODC,1,2) & [F:MTS]MFGMODM = 2 & [F:MTS]MFGMODO = 2 |
###&    [F:MTS]MFGMODC = 2 & [F:MTS]MFGMODM=1 & [F:MTS]MFGMODO = 2
        If [M:MFGK]BOMALT = 0 & [F:MTS]MFGMODO=1
            WMESS1  = "          "+"("+mess(108,193,1)+")"
            Goto ERR_TRACE
        Endif
###    Endif

    # Si seul lancement autorisé par la transaction = matières seules
    If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
        [M:MFGK]ROUALT  = 0
        [M:MFGK]ROUNUM  = ""
    Else
        If [F:ITF]MFGROU = ""
            [M:MFGK]ROUNUM = [M:MFGK]ITMREF
        Else
            [M:MFGK]ROUNUM = [F:ITF]MFGROU
        Endif

        # Issue 111414 - 2015-01 by GH : implementing route versioning
        [M:MFGK]ROUALT = func RVMLIB.GETRVMALT([M:MFGK]ROUNUM,[M:MFGK]MFGFCY,[M:MFGK]STRDAT)
        If [M:MFGK]ROUALT = 0
           # 12.05 33843 point d'entrée  pour choisir ROUALT
           GPOINT="CHOROU" : Gosub ENTREE From EXEFNC
        Endif
        If [M:MFGK]ROUALT = 0
            Call RECH_GAM([M:MFGK]MFGFCY, [M:MFGK]STRDAT, [M:MFGK]ROUNUM, [M:MFGK]EXTQTY,
&                         [F:ITM]STU, [M:MFGK]BOMALT, [M:MFGK]ROUALT) From BENCHLIB
        Else
           WALT=[M:MFGK]ROUALT
           Call CONT_ROUALT([M:MFGK]MFGFCY, WALT, [M:MFGK]ROUNUM, [M:MFGK]STRDAT, [M:MFGK]EXTQTY,
&                           [F:ITM]STU, [M:MFGK]BOMALT) From BENCHLIB
           If WALT=0
              If [F:MTS]MFGMODM = 1
                 WMESS1  = "          "+"("+mess(63,198,1)-[M:MFGK]ROUNUM-num$([M:MFGK]ROUALT)+")"
                 WMESS1 += "\          "+"("+GMESSAGE+")"
                 Goto ERR_TRACE
              Endif
              [M:MFGK]ROUALT=0 : GMESSAGE=""
           Endif
        Endif
        If [M:MFGK]ROUALT = 0 & [F:MTS]MFGMODM = 2 : Raz [M:MFGK]ROUNUM : Endif
        # 02.05 28346
        If [F:MTS]MFGMODM = 1 & [M:MFGK]ROUALT = 0
           If [M:MFGK]BOMALT<>0 & WSEARCH
              Filter [BOH] Where BOMALT>[M:MFGK]BOMALT
              [M:MFGK]BOMALT=0 : WSEARCH=9 : Goto ALT_SEARCH
           Endif
           WMESS1  = "          "+"("+mess(74,193,1)+")"
           Goto ERR_TRACE
        Endif
    Endif
    If WSEARCH=9 : Filter [BOH] : WSEARCH=0 : Endif

    [M:MFGK]PJT    = [F:ORD]PJT
    [M:MFGK]LOT    = ""
    [M:MFGK]FMI    = [F:ORD]FMI
    [M:MFGK]BPRNUM = [F:ORD]BPRNUM
    [M:MFGK]PIO    = [F:ORD]PIO
    [M:MFGK]VCRTYPORI = 2
    [M:MFGK]VCRNUMORI = WVCRNUM
    [M:MFGK]VCRLINORI = WVCRLIN
    [M:MFGK]VCRSEQORI = WVCRSEQ
    [M:MFGK]WIPTYP = [F:ORD]WIPTYP
    [M:MFGK]WIPNUM = [F:ORD]WIPNUM
    # llc 03.02 12520
    Case [F:MTS]SCDMODSAI
        When 1:    [M:MFGK]SCDMOD = 1
        When 2:    [M:MFGK]SCDMOD = 2
        When Default: [M:MFGK]SCDMOD = 1
    Endcase
    # llc 7063 11.00 - si traitement de masse, pas d'édition dossier
    # If GNUMCDE = "" : [M:MFGK]AUTOTRT = 2 : Endif
    [M:MFGK]AUTOTRT = 2 : # GH 09/02/2016 bug 113698 not to display phantoms if GNUMCDE<>""
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTFMI : Endif

    # GH 09/02/2016 bug 113698 to do the printings in case BtoB is launched from the sale order function
    If [M:MFGK]MFGSTA=1 & TYPPRG=1 & GNUMCDE<>""
       [M:MFGK]AUTOTRT = 1
       Call DOSFAB From MFGAUTLIB
    Endif

    # Issue 84721 GA 10/2012 autoriser impression en batch action FUNMAUTF
    # llc 01.01 7063
    #If GFONC1 = "FUNMAUT" & (dim(GMAUTFB) <= 0) & [M:MFGK]MFGSTA = 1
    # GH 27/03/2014 bug 84721 ajout du test sur AUTOTRT par sécurité
    If [M:MFGK]MFGSTA = 1 & [M:MFGK]AUTOTRT=2 & dim([M:DIA]IMPFLG)=1 & [M:DIA]IMPFLG = 2
        DOSOK = 0
        Call TEST_DOSSIER(DOSOK) From MFGAUTLIB
        If DOSOK=1
            If dim([M:DIA]PRT)=1 : GDEFIMP = [M:DIA]PRT : Else GDEFIMP = "" : Endif
            Read [MFP]MFP0 = [M:MFGK]MFGNUM
            If fstat : Raz [F:MFP] : Endif
            Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
            TBPAR(1)="codimp"        : TBVAL(1) = num$([F:MFP]MFGFDRFLG)
            TBPAR(2)="mfgfcydeb"     : TBVAL(2) = [M:MFGK]MFGFCY
            TBPAR(3)="mfgfcyfin"     : TBVAL(3) = [M:MFGK]MFGFCY
            TBPAR(4)="mfgnumdeb"     : TBVAL(4) = [M:MFGK]MFGNUM
            TBPAR(5)="mfgnumfin"     : TBVAL(5) = [M:MFGK]MFGNUM
            If GSERVEUR
               TBPAR(6)="_nolispar"   : TBVAL(6) = "1" : # GH 27/03/2014 bug 84721 pour schinter les infos techniques imprimées dans la trace
            Endif
            Call ETAT("DOSFAB",GDEFIMP,"",1,"",TBPAR,TBVAL) From AIMP3
            GOK=1 : # GH 27/03/2014 bug 84721 pour ne pas avoir une erreur inconnue sur la requête batch
        Endif
    Endif

    # traces
    Case [M:MFGK]MFGSTA
        When 1:    WMESS -= mess(197,197,1)-"\("+[M:MFGK]MFGNUM+")"
        When 2:    WMESS -= mess(198,197,1)-"\("+[M:MFGK]MFGNUM+")"
    Endcase
    WMESS1  = ""

    # lecture OF pour comparaison dates    llc 02.01 8003
    Read [MFG]MFG0=[M:MFGK]MFGNUM
    If !fstat & WOBJ < [F:MFG]ENDDAT
       WMESS1 = "          "+mess(95,190,1)
    Endif
$FIN_TRACE
    Call ECR_TRACE(WMESS,0) From GESECRAN
    If WMESS1 <> "" : Call ECR_TRACE(WMESS1,0) From GESECRAN : Endif
    Raz WMESS, WMESS1, WMESS2
    NBFMI += 1
    Return
# llc 03.03 17650 + 17215
$ERR_TRACE
    If WSEARCH=9 : Filter [BOH] : WSEARCH=0 : Endif
    Call ECR_TRACE(WMESS,1) From GESECRAN
    If WMESS1 <> "" : Call ECR_TRACE(WMESS1,0) From GESECRAN : Endif
    Raz WMESS, WMESS1, WMESS2
Return

########################################################################
$AB_TRTFMI
Call ECR_TRACE(WMESS-":"-mess(18,114,1),1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
# Issue 84284 GH 16/05/2018 - WO generated with a wrong sequence number if set according company
If [F:FCY]FCY<>GFCY
   Read [FCY]FCY0=GFCY
Endif
GSOCIETE = [F:FCY]LEGCPY
## GH 18/03/2013 bug 88648
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

Subprog AV_MFGFCY(VALEUR)
Variable Char    VALEUR()

#If (dim(GMAUTFB) > 0 & GMAUTFB>1) : End : Endif : ## GH 27/03/2014 bug 84721 GMAUTFB plus utilisé
If dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3 | GCONSDIA : End : Endif

# si édition dossier, flag à oui
If [F:MTS]MODDOS = 2 & [M:DIA]APSTA=2
    Actzo [DIA]25
    If dim([M:DIA]PRT)=1 & [M:DIA]OBL=1 : Diszo [DIA]PRT : Endif
Else
    ## GH 27/03/2014 bug 84721
    [M:DIA]IMPFLG = 1 : Affzo [DIA]IMPFLG
    # [M:DIA]PRT = ""                     : # ne pas razer l'imprimante qui peut être obligatoire
    ##
    Diszo [DIA]25
Endif
End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog AP_APSTA(VALEUR)
Variable Integer VALEUR

If dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3 | GCONSDIA : End : Endif

If [F:MTS]MODDOS = 2 & VALEUR = 2
   Actzo [DIA]25
   If dim([M:DIA]PRT)=1 & [M:DIA]OBL=1 :  Diszo [DIA]PRT : Endif
Else
   [M:DIA]IMPFLG = 1 : Affzo [DIA]IMPFLG
   Diszo [DIA]25
Endif
End

########################################
Subprog AM_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCNUMFIN = VALEUR : Endif
End

########################################
Subprog S_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog S_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AV_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = GNUMCDE : Endif
End

########################################
Subprog AS_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
End

########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AV_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = GNUMCDE : Endif
End

########################################
Subprog AS_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog C_ENDDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]ENDDATDEB : mkstat = 2 : Endif            # llc 09.02 16082
End

########################################
Subprog C_MFGTRS(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Read [MTS]MTS0=1;VALEUR
If fstat
   GMESSAGE = mess(23,100,1) : mkstat = 2
Elsif [F:MTS]TRSAUTO <> 2
   GMESSAGE = mess(194,193,1) : mkstat = 2
Endif
End

########################################
Subprog AM_MFGTRS(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
    Read [MTS]MTS0=1;GMFGMTSNUM
Else
    Read [MTS]MTS0=1;VALEUR
Endif
If fstat : Raz [F:MTS] : Endif

# GH 27/03/2014 bug 84721 GMAUTFB plus utilisé
# If (dim(GMAUTFB) > 0 & GMAUTFB>1) : End : Endif    # 36039 mm 05.06
If dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3 | GCONSDIA : End : Endif

If [F:MTS]MODDOS = 2 &  [M:DIA]APSTA = 2
   Actzo [DIA]25
   If dim([M:DIA]PRT)=1 & [M:DIA]OBL=1 :  Diszo [DIA]PRT : Endif
Else
   [M:DIA]IMPFLG = 1 : Affzo [DIA] IMPFLG
   Diszo [DIA]25
Endif
End

########################################
# GH 27/03/2014 bug 84721 si pas d'édition, ne pas effacer l'imprimante qui peut être obligatoire
Subprog AS_PRT(VALEUR)
Variable Char    VALEUR()
If !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3) & [M:DIA]IMPFLG<>2 : mkstat=2 : Endif
End

########################################
Subprog C_PRT(VALEUR)
Variable Char    VALEUR()
# Issue 84721 GA 10/2012 autoriser impression en batch avec une imprimante avec serveur d'impression et pas prévisu
#If (dim(GMAUTRB) > 0 & GMAUTFB>1): End : Endif
Call LECTURE("AIM",VALEUR,"") From CONTOBJ
If [F:AIM]PRT = 2 & [F:AIM]PRTNAT > 1 & [F:AIM]PRTNAT <> [F:ARP]PRTNAT
    GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")" : # Imprimante de type incorrect
    mkstat = 2 : End
Endif
If [F:AIM]ACS <> ""
    # FQ 71395 GA 02/2011
    If clalev ([F:ACC])<=0 Local File ACCES   [ACC] : Endif
    Read [ACC]CODACC=GUSER;[F:AIM]ACS
    If fstat or [F:ACC]EXEC <> 2
        GMESSAGE = mess(7,133,1) : # Imprimante non autorisée
        mkstat = 2 : End
    Endif
Endif
If GBATCH
    If [F:AIM]PRT=1
        GMESSAGE = mess(12,135,1) : # Pas de prévisu en batch
        mkstat = 2 : End
    Endif
    If [F:AIM]PRTSRV = ""
        GMESSAGE = mess(13,135,1) : # Serveur d'impression non défini
        mkstat = 2 : End
    Endif
Endif
[M:DIA]SERIMP    = [F:AIM]PRTSRV
[M:DIA]DEFIMP    = [F:AIM]PRTNAM
[M:DIA]PRTPOR    = [F:AIM]PRTPOR
[M:DIA]PRTDRV    = [F:AIM]PRTDRV
Raz [M:DIA]PRTDES
For [AID]AID0 Where COD=[F:AIM]COD
 [M:DIA]PRTDES  = [F:AID]PRTDES
Next
End

