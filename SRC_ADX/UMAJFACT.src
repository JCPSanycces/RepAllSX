#<AdxTL>@(#)1.0.0.0 $Revision$
#** FQ100587 UMAJFACT
#*
#* Traitement de synchronisation des tx de TVA
#* en cas de décallage :
#* - la dépense a un mauvais taux par rapport à la facture
#* - l'immo récupère alors des mauvais montants de TVA
#
#*!
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "UMAJFACT", "UMAJFACT", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When "INIT"        : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : GOK=1
    When "END"         : GOK=0
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When "SETBOUT"     : Gosub SETBOUT
Endcase
Return

$INIT_DIA
$INIT
#############################################################################################################


    Local Mask UMAJFACT   [DIA]

    Local Char LIBCALL(250)

Return

$OUVRE
Return

$SETBOUT

Return

$DEBUT
    # vérifier si l'utilisateur a les droits au site
#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        Infbox "droits restreints" - GUSRFCY(1) - GUSRFCY(2)
#    Endif

    Local Char WTB(50)(1..2)
    WTB(1) = mess(90, 7784, 1)
    WTB(2) = mess(91, 7784, 1)
    Infbox WTB(1..2) Titled mess(3, 585, 1)

    If [M:DIA]CPYTOUS = G_NON
        Actzo [M:DIA]CPY
    Else
        Diszo [M:DIA]CPY
    Endif

    If [M:DIA]FCYTOUS = G_NON
        Actzo [M:DIA]FCY
    Else
        Diszo [M:DIA]FCY
    Endif

    [M:DIA]DATECHGT = gdat$(1, 1, 2014)
    Affzo [M:DIA]

Return


$CONTROLE

    If GOK < 1
        Return
    Endif

#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        GMESSAGE = "droits restreints" - GUSER - GUSRFCY(1) - GUSRFCY(2) - GUSRFCY(3) - GUSRFCY(4) - GUSRFCY(5)
#        GERR = 1
#        mkstat = 2
#        Return
#    Endif


    If [M:DIA]SAUVE <> G_OUI and [M:DIA]FLGSIM <> G_OUI
        Call LIBCHPATZ(GLANGUE, "UMAJFACT", "SAUVE", LIBCALL) From UMAJFACT2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        Return
    Endif

Return


# traitement
$EXEC
Local Integer LOK

    If GOK = 0
        Return
    Endif

If GUSER <> "CBO"
    If [M:DIA]FLGSIM = G_NON
        Call OUINON(mess(188, 7774, 1), LOK) From GESECRAN
    Else
        Call OUINON(mess(176, 7774, 1), LOK) From GESECRAN
    Endif
    If (LOK = 1) Then
        FIN      = 0
        GERR     = 1
        Return
    Endif
Endif


    Call UMAJFACT([M:DIA]CPY, [M:DIA]FCY, [M:DIA]DATECHGT, [M:DIA]FLGSIM,
&                 [M:DIA]TRACEDET, [M:DIA]WSEL, [M:DIA]COMPARE) From UMAJFACT2

    GERR = 0
    GOK  = 1

Return

$TERMINE

    GERR = 0
    GMESSAGE = ""
    Close Mask [DIA]

Return

######################################################################################

######################################################################################

Subprog AM_CPYTOUS(VALEUR)
Variable Integer VALEUR

    If VALEUR = G_OUI
        [M:DIA]CPY = ""
        [M:DIA]FCY = ""
        [M:DIA]FCYTOUS = G_NON
        Diszo [M:DIA]CPY, FCY
    Else
        Actzo [M:DIA]CPY
    Endif

    Affzo [M:DIA]

End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

    If [M]CPYTOUS <> G_OUI & VALEUR = ""
        GMESSAGE = mess(27, GML_IMPFXD, 1)
        mkstat=1
        End
    Endif

End


Subprog AM_FCYTOUS(VALEUR)
Variable Integer VALEUR

    If VALEUR = G_OUI
        [M:DIA]FCY = ""
        Diszo [M:DIA]FCY
    Else
        Actzo [M:DIA]FCY
    Endif

    Affzo [M:DIA]

End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

    If [M]FCYTOUS <> G_OUI & VALEUR = ""
        GMESSAGE = mess(28, GML_IMPFXD, 1)
        mkstat=1
        End
    Endif

End

Subprog AM_COMPARE(VALEUR)
Variable Integer VALEUR

    If VALEUR = G_OUI
        [M:DIA]FLGSIM = G_OUI
        [M:DIA]TRACEDET = G_NON
        Diszo [M:DIA]FLGSIM, TRACEDET
    Else
        Actzo [M:DIA]FLGSIM, TRACEDET
    Endif
    Affzo [M:DIA]

End
