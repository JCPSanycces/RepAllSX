#<AdxTL>@(#)6.0.0.0 $Revision$
Subprog FACTAVO(FACTURE)
Value Char FACTURE
Local Integer OK

SYMBOLE = "AVOIR"+FACTURE
Lock =SYMBOLE
If fstat
 Call ERREUR(mess(30,100,1)) From GESECRAN
 # Opération en cours sur autre poste
 End
Endif

#Création d'une facture d'avoir ?
OK = 1 : Call OUINON(mess(53,104,1),OK) From GESECRAN
If OK<>2 : End : Endif
OK=1
If clalev([M:BIC0])=0
 Gosub TRFOUR
Else
 Gosub TRCLI
Endif
Unlock =SYMBOLE
If OK=0
 Call ERREUR(mess(27,110,1)) From GESECRAN
 # Type de pièce non défini
Endif
End

$TRCLI
Raz [M:BIC0]SIVTYP
If func AFNC.ACTIV("KPO")
  Raz [M:BIC1]FLD40REN
  Raz [M:BIC1]FLD41REN
Endif
Call GETSOC([M:BIC0]FCY) From DEVSUB
If clalev([F:TSV9])=0 : Local File TABSIVTYP  [TSV9] : Endif

# BRBAN 105200 US2 - Can't fill with invoice cancellation credit note
If func AFNC.ACTIV("INVCA")>0
  Filter [F:TSV9] Where INVTYP=2 & LEG=GCURLEG & INVCAN<>2
Else
  Filter [F:TSV9] Where INVTYP=2 & LEG=GCURLEG
Endif
#-
Read [F:TSV9]TSV0 First
If !fstat
 [M:BIC0]SIVTYP=[F:TSV9]SIVTYP
Else
 If func AFNC.ACTIV("LEG")
  # BRBAN 105200 US2 - Can't fill with invoice cancellation credit note
  If func AFNC.ACTIV("INVCA")>0
    Filter [F:TSV9] Where INVTYP=2 & LEG="" & INVCAN<>2
  Else
    Filter [F:TSV9] Where INVTYP=2 & LEG=""
  Endif
  #-
  Read [F:TSV9]TSV0 First
  If !fstat
   [M:BIC0]SIVTYP=[F:TSV9]SIVTYP
  Endif
 Endif
Endif
Filter [TSV9]
If [M:BIC0]SIVTYP=""
 OK=0 : Return
Endif
[M:BIC0]NUM=""
[M:BIC0]INVTYP=2
[M:BIC1]INVNUM=FACTURE
# BRBAN 105200 US2 - Need enviroment to block fields for invoice cancellation
If func AFNC.ACTIV("INVCA")>0
  [M:BIC0]INVCRE = 2
Endif
# -
If func AFNC.ACTIV("KPO") & [F:TSV9]INVCAN <> 2
  [M:BIC1]STA=1
  Actzo [M:BIC1]FLD40REN
  Actzo [M:BIC1]FLD41REN
  Call FLD4041DIS([M:BIC1]VAC,[M:BIC0]SIVTYP) From SUBBIC
Endif

Affzo[M:BIC0]NUM, SIVTYP
Affzo[M:BIC1]INVNUM,STA
Setmok [BIC0] With 0
Return

$TRFOUR
Raz [M:BIS0]PIVTYP
If func AFNC.ACTIV("KPO")
  Raz [M:BIS1]FLD40REN
  Raz [M:BIS1]FLD41REN
Endif
Call GETSOC([M:BIS0]FCY) From DEVSUB
If clalev([F:TPV9])=0 : Local File TABPIVTYP  [TPV9] : Endif
Filter [F:TPV9] Where INVTYP=2 & PIHTYP=3 & LEG=GCURLEG
Read [F:TPV9]TPV0 First
If !fstat
 [M:BIS0]PIVTYP=[F:TPV9]PIVTYP
Else
 If func AFNC.ACTIV("LEG")
  Filter [F:TPV9] Where INVTYP=2 & PIHTYP=3 & LEG=""
  Read [F:TPV9]TPV0 First
  If !fstat
   [M:BIS0]PIVTYP=[F:TPV9]PIVTYP
  Endif
 Endif
Endif
Filter [F:TPV9]
If [M:BIS0]PIVTYP=""
 OK=0 : Return
Endif
[M:BIS0]NUM=""
[M:BIS0]INVTYP=2
[M:BIS1]INVNUM=FACTURE
If func AFNC.ACTIV("KPO")
  [M:BIS1]STA=1
  Actzo [M:BIS1]FLD40REN
  Actzo [M:BIS1]FLD41REN
  Call FLD4041DIS([M:BIS1]VAC) From SUBBIS
Endif

Affzo[M:BIS0]NUM, PIVTYP
Affzo[M:BIS1]INVNUM, STA
Setmok [BIS0] With 0

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")
  Gosub RAZDUP_BIS From SWIBVRLIB4
Endif
# SAM 101378 END
Return

