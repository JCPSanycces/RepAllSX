#<AdxTL>@(#)0.0.0.0 $Revision$
# -------------------------------------------------------------------------- #
# Classe représentation SOHEXCCDTD : Liste des cdes en dépassement d'encours #
# -------------------------------------------------------------------------- #
# Classe de données SORDER                                                   #
# -------------------------------------------------------------------------- #
#######################################################################################

#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"                  : Gosub AREAD_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_CRITERIA_AFTER"        : Gosub AQUERY_CRITERIA_AFTER
        When "AQUERY_JOIN_AFTER"            : Gosub AQUERY_JOIN_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When Default
      Endcase
    When Default
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

#######################################################################################
$AREAD_AFTER
Local Char    WBPCRSK(GLONBPR)
Local Char    WOSTCUR(GLONCUR)
Local Date    WOSTDAT
Local Integer WOSTCHGTYP
Local Decimal WENCOURS, WENCOURSSHR
Local Decimal WEXCMNTCPY
Local Integer SPSTAT

Local Char    CTX_CURSHR(GLONCUR)
Local Char    CTX_LOCALDEV(GLONCUR)
Local Integer CTX_OSTCHGTYP          : # Type cours contrôle en-cours
Local Integer CTX_OSTCTL


  # Chargement des propriétés qui ne sont pas dans la classe de données SORDER
  CTX_CURSHR = fmet this.SOH.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.SOH.ACTX.AFOLDER,"CURSHRFLD")
  WENCOURS = func CALENCCPYSHR(this.ACTX,this.SOH.CPY,this.SOH.BPCORD, this.SOH.CHGTYP, this.SOH.ORDDAT)

  # Flag ctrl encours du client risque
  this.OSTCTLRSK=func TRTX2FNC.OSTCTLRSK (this.SOH.BPCORD)
  # Montant de l'encours autorisé du client risque
  this.OSTAUZRSK=func TRTX2FNC.OSTAUZRSK (this.SOH.BPCORD)
  # Montant de l'encours
  this.CALOSTCPY=WENCOURS
  # Calcul du dépassement d'encours : Montant de l'encours - Montant de l'encours autorisé
  WEXCMNTCPY=WENCOURS-this.OSTAUZRSK
  this.EXCMNTCPY=0
  If WEXCMNTCPY>0
    this.EXCMNTCPY=WEXCMNTCPY
  Endif
  this.CURSHR  = CTX_CURSHR
  this.CURSHR1 = CTX_CURSHR
  this.CURSHR2 = CTX_CURSHR
  this.CURSOH  = this.SOH.CUR
Return

#######################################################################################
$AQUERY_OPEN_AFTER
  # Ouverture des tables additionnelles
  Local File BPCUSTOMER [BPC]
Return

#######################################################################################
$AQUERY_CRITERIA_AFTER
  # Ajout de conditions ds la clause Where
Return

#######################################################################################
$AQUERY_PRIMARYKEYS_AFTER
Return

#######################################################################################
$AQUERY_JOIN_AFTER
Local Char VARS(20)(1..3), COLS(20)(1..3)
Local Char QWHERETMP (250)
Local Char    TSOHNUM(GLONVCR)(1..)
Local Char    TBPCORD(GLONBPR)(1..)
Local Date    TORDDAT(1..)
Local Integer TSOHCAT (1..)
Local Integer TUNL (1..)
Local Integer TORDSTA (1..)
Local Integer TOSTCTL (1..)
Local Decimal TEXCMNTCPY (1..)
Local Decimal TORDINVATI (1..)
Local Decimal CEXCMNTCPY

  VARS(1)="OSTCTL"
  COLS(1)="[BPC]OSTCTL"
  # Liste des cdes en dépassement d'encours : Cdes dont le client est en dépassement d'encours
  # Liste des cdes dont le dépassement d'encours > 0
  # Problème :
  # Il faut calculer en tps réel pour chaque cde le dépassement d'encours du clt et filtrer sur ce mnt
  # Le calcul ne peut pas être mis directement dans le filtre : func CALENCEXC ne fonctionne dans le where
  # Solution :
  # Passage par une table temporaire :
  # - Lectures des cdes avec ts les filtres (sf le dépassement d'encours)
  # - Calcul du dépassement et stockage dans un tableau
  # - Ouverture d'une table temporaire que l'on substitue à la table SORDER

  If PQRY.QWHERE<>""
    QWHERETMP="("+PQRY.QWHERE+") and ORDSTA eq 1 and UNL eq 1 and SOHCAT ne 4 and ([F:BPC]OSTCTL eq 1 or [F:BPC]OSTCTL eq 3)"
  Else
    QWHERETMP="ORDSTA eq 1 and UNL eq 1 and SOHCAT ne 4 and ([F:BPC]OSTCTL eq 1 or [F:BPC]OSTCTL eq 3)"
  Endif
  #
  Link [SOH] With [F:BPC]BPC0 = [F:SOH]BPCORD
&              As [TLNK_]
&            Where evalueSData(QWHERETMP,VARS,COLS)

  # - Lectures des cdes avec ts les filtres (sf le dépassement d'encours)
  # - Calcul du dépassement et stockage dans un tableau
  I = 1
  For [TLNK_]
    CEXCMNTCPY = func CALENCEXC(GACTX, [F:SOH]CPY, [F:SOH]BPCORD, [F:SOH]CHGTYP, [F:SOH]ORDDAT)
    If CEXCMNTCPY > 0 Then
      TSOHNUM(I)    = [TLNK_]SOHNUM
      TBPCORD(I)    = [TLNK_]BPCORD
      TORDDAT(I)    = [TLNK_]ORDDAT
      TSOHCAT(I)    = [TLNK_]SOHCAT
      TUNL(I)       = [TLNK_]UNL
      TORDSTA(I)    = [TLNK_]ORDSTA
      TOSTCTL(I)    = [BPC]OSTCTL
      TORDINVATI(I) = [TLNK_]ORDINVATI
      TEXCMNTCPY(I) = CEXCMNTCPY
      #
      I += 1
    Endif
  Next

  # - Ouverture d'une table temporaire que l'on substitue à la classe SORDER
  # C'est cette table ne contenant que les infos nécessaires au quéry qui sera parcourue par le quéry
  If clalev ([LNK_]) Close File [LNK_] Endif
  # -----------------------------------------
  Local File (
&               Char    SOHNUM(GLONVCR),
&               Char    BPCORD(GLONBPR),
&               Date    ORDDAT,
&               Decimal EXCMNTCPY,
&               Decimal ORDINVATI,
&               Integer SOHCAT,
&               Integer UNL,
&               Integer ORDSTA,
&               Integer OSTCTL
&            ) From Variable
&   TSOHNUM, TBPCORD, TORDDAT, TEXCMNTCPY, TORDINVATI, TSOHCAT, TUNL, TORDSTA, TOSTCTL As [LNK_]
&   Where EXCMNTCPY > 0
&   Order By Key SOH0=SOHNUM Asc
  #
#  Local File (Char    SOHNUM(GLONVCR),
#&             Decimal EXCMNTCPY,
#&             Integer OSTCTL
#&            ) From Variable
#&            TSOHNUM, TEXCMNTCPY, TOSTCTL As [TMP_]
#&            Where EXCMNTCPY > 0
#&            Order By Key SOH0=SOHNUM Asc
#  # -----------------------------------------
#  Link [F:SOH] With [F:TMP_]SOH0 = [F:SOH]SOHNUM As [LNK_]
  # -----------------------------------------
  Raz INDEXES
  INDEXES(1)="SOHNUM Desc"
  INDEXES(2)="SOHNUM Asc"
Return

#######################################################################################
$AQUERY_TRANS_AFTER
  # Alimenter des propriétés affichées dans la quéry qui ne sont pas dans la table
  # Permet le chargement de toutes les propriétés de la classe SOH avec la table temporaire
  SetInstance this.SOH With [F:LNK_]
  # Cette propriété n'existe pas dans la classe de données SOH : ALimentation manuelle
  this.EXCMNTCPY=[F:LNK_]EXCMNTCPY
Return

#-------------------------------------------------------------------------#
# Calcul de l'en-cours client en devise dossier pour une societe          #
#-------------------------------------------------------------------------#
# Entrée  CTX          : Classe contexte                                  #
#         WCPY         : Société                                          #
#         WBPCNUM      : Client                                           #
#         WDAT         : Date                                             #
# Sortie  WENCOURSSHR  : En-cours calculé du tiers risque                 #
#                        en devise dossier                                #
#-------------------------------------------------------------------------#
Funprog CALENCCPYSHR (CTX,WCPY,WBPCNUM,WCHGTYP,WDAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     WCPY
Value    Char     WBPCNUM
Value    Libelle  WCHGTYP
Value    Date     WDAT

Local Char    WOSTCUR(GLONCUR), WBPCRSK
Local Date    WOSTDAT
Local Integer WOSTCHGTYP
Local Decimal WENCOURS, WENCOURSSHR
Local Decimal WEXCMNTCPY
Local Integer SPSTAT

Local Char    CTX_CURSHR(GLONCUR)
Local Char    CTX_LOCALDEV(GLONCUR)
Local Integer CTX_OSTCHGTYP          : # Type cours contrôle en-cours
Local Integer CTX_OSTCTL

  Local File COMPANY    [CPY]
  Local File BPCUSTOMER [BPC]
  # --------------------------
  CTX_CURSHR      = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"CURSHRFLD")
  CTX_OSTCHGTYP   = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCHGTYP")
  CTX_OSTCTL      = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCTL")
  # --------------------------
  If [F:CPY]CPY<>WCPY
    Read [F:CPY]CPY0=WCPY
    If fstat : Raz [F:CPY] : Endif
  Endif
  If [F:CPY]ACCCUR<>""
    CTX_LOCALDEV=[F:CPY]ACCCUR
  Else
    CTX_LOCALDEV=CTX_CURSHR
  Endif
  If CTX_OSTCTL=1
    WOSTCUR=CTX_CURSHR    : # Ctrl niveau dossier : Devise : Devise dossier
  Else
    WOSTCUR=CTX_LOCALDEV  : # Ctrl niveau société : Devise : Devise société
  Endif
  If CTX_OSTCHGTYP=2
    # Si Origine cours pour contrôle en-cours = actualisé
    WOSTDAT=datesyst                        : # Date          : date du jour
    WOSTCHGTYP= fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,WCPY,"OSTTYPCUR")
  Else
    # Si Origine cours pour contrôle en-cours = historique
    WOSTDAT=WDAT          : # Date          : date du document
    WOSTCHGTYP=WCHGTYP    : # Type de cours : Type de cours du document
  Endif
  # Le client n'est pas le tiers risque
  If [F:BPC]BPCNUM<>WBPCNUM
    Read [BPC]BPC0=WBPCNUM
    If fstat Raz [F:BPC] Endif
  Endif
  WBPCRSK = [F:BPC]BPCRSK
  # Calcul de l'encours (en devise WOSTCUR : devise dossier ou devise société selon le niveau de ctrl)
  Call CALENC(CTX,WCPY,WBPCRSK, WOSTDAT, WENCOURS) From TRTBPMVT_SYRA
  # Conv. de l'en-cours calculé en devise dossier pour le comparer à l'en-cours autorisé qui est tjs stocké en devise dossier
  WENCOURSSHR = WENCOURS
  If WOSTCUR<>CTX_CURSHR
    Call CONVERT(CTX,WOSTCUR, CTX_CURSHR, CTX_LOCALDEV, WOSTCHGTYP, WOSTDAT, WENCOURS, WENCOURSSHR, SPSTAT) From TRTDEV_SYRA
  Endif
End WENCOURSSHR

#----------------------------------------------------------------------------#
# Calcul du dépassement d'en-cours client en devise dossier pour une societe #
#----------------------------------------------------------------------------#
# Entrée  CTX          : Classe contexte                                     #
#         WCPY         : Société                                             #
#         WBPCRSK      : Tiers risque                                        #
#         WDAT         : Date                                                #
# Sortie  WENCOURSSHR  : En-cours calculé du tiers risque                    #
#                        en devise dossier                                   #
#----------------------------------------------------------------------------#
Funprog CALENCEXC (CTX,WCPY,WBPCNUM,WCHGTYP,WDAT)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     WCPY
Value    Char     WBPCNUM
Value    Libelle  WCHGTYP
Value    Date     WDAT

Local Char    WOSTCUR(GLONCUR), WBPCRSK
Local Date    WOSTDAT
Local Integer WOSTCHGTYP
Local Decimal WENCOURS, WENCOURSSHR, WENCOURSAUZ, WENCOURSEXC
Local Decimal WEXCMNTCPY
Local Integer SPSTAT

Local Char    CTX_CURSHR(GLONCUR)
Local Char    CTX_LOCALDEV(GLONCUR)
Local Integer CTX_OSTCHGTYP          : # Type cours contrôle en-cours
Local Integer CTX_OSTCTL

  Local File COMPANY    [CPY]
  Local File BPCUSTOMER [BPC]
  # --------------------------
  CTX_CURSHR      = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"CURSHRFLD")
  CTX_OSTCHGTYP   = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCHGTYP")
  CTX_OSTCTL      = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"OSTCTL")
  # --------------------------
  If [F:CPY]CPY<>WCPY
    Read [F:CPY]CPY0=WCPY
    If fstat : Raz [F:CPY] : Endif
  Endif
  If [F:CPY]ACCCUR<>""
    CTX_LOCALDEV=[F:CPY]ACCCUR
  Else
    CTX_LOCALDEV=CTX_CURSHR
  Endif
  If CTX_OSTCTL=1
    WOSTCUR=CTX_CURSHR    : # Ctrl niveau dossier : Devise : Devise dossier
  Else
    WOSTCUR=CTX_LOCALDEV  : # Ctrl niveau société : Devise : Devise société
  Endif
  If CTX_OSTCHGTYP=2
    # Si Origine cours pour contrôle en-cours = actualisé
    WOSTDAT=datesyst                        : # Date          : date du jour
    WOSTCHGTYP= fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,WCPY,"OSTTYPCUR")
  Else
    # Si Origine cours pour contrôle en-cours = historique
    WOSTDAT=WDAT          : # Date          : date du document
    WOSTCHGTYP=WCHGTYP    : # Type de cours : Type de cours du document
  Endif
  # Le client n'est pas le tiers risque
  If [F:BPC]BPCNUM<>WBPCNUM
    Read [BPC]BPC0=WBPCNUM
    If fstat Raz [F:BPC] Endif
  Endif
  WBPCRSK=[F:BPC]BPCRSK
  # Calcul de l'encours (en devise WOSTCUR : devise dossier ou devise société selon le niveau de ctrl)
  Call CALENC(CTX,WCPY,WBPCRSK, WOSTDAT, WENCOURS) From TRTBPMVT_SYRA
  # Conv. de l'en-cours calculé en devise dossier pour le comparer à l'en-cours autorisé qui est tjs stocké en devise dossier
  WENCOURSSHR = WENCOURS
  If WOSTCUR<>CTX_CURSHR
    Call CONVERT(CTX,WOSTCUR, CTX_CURSHR, CTX_LOCALDEV, WOSTCHGTYP, WOSTDAT, WENCOURS, WENCOURSSHR, SPSTAT) From TRTDEV_SYRA
  Endif
  # Recherche de l'encours autorisé
  WENCOURSAUZ=func TRTX2FNC.OSTAUZRSK (WBPCRSK)
  # Calcul du dépassement d'encours
  WENCOURSEXC=max(0,WENCOURSSHR-WENCOURSAUZ)
End WENCOURSEXC

