$ON_XMATTOL
Onevent AFTER_CHANGE Gosub AMM_XMATTOL From W2ITP
Onevent CONTROL Call C_XMATTOL(zc) From W2ITP
Onevent BEFORE_INPUT Call AS_XMATTOL(zc) From W2ITP
Return

Subprog AS_XMATTOL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(43884,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_XMATTOL(zc) From W2ITP
Onkey   2 Titled GBOUTS Call S_XMATTOL(zc) From W2ITP
Onkey 144 Titled GBOUTP Call P_XMATTOL(zc) From W2ITP
Onkey 146 Titled GBOUTA Call SA_XMATTOL(zc) From W2ITP
Gosub _AFF
End

Subprog C_XMATTOL(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("MAT","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "XMATTOL" : GZNUM = 43884 : Endif
Gosub _AFF
End

$AMM_XMATTOL
Call AM_XMATTOL(zc)
If !mkstat & GOBJET
 zoncou = "XMATTOL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XMATTOL(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_XMATTOL(VALEUR) From SUBITP
If mkstat : GERR = 1 : GZONE = "XMATTOL" : GZNUM = 43884 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZXMATTOL)")>indice
 [M]XMATTOL(indice) = VALEUR
 Affzo ZXMATTOL(indice)
Endif
Gosub _AFF
End

Subprog S_XMATTOL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "MAT"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_XMATTOL(VALEUR)
Variable Char    VALEUR()
Call OBJET("MAT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_XMATTOL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "MAT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_XMATTOL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("MAT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZXMATTOL
Onevent BEFORE_AREA Gosub AV_ZXMATTOL From W2ITP
Return

$AV_ZXMATTOL
Call LECTEXTRA(zc,"MATCHTOL","TOLDESAXX",num$([M]XMATTOL(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_XBOMALT
Onevent AFTER_CHANGE Gosub AMM_XBOMALT From W2ITP
Onevent BEFORE_INPUT Call AS_XBOMALT(zc) From W2ITP
Onevent CONTROL Call C_XBOMALT(zc) From W2ITP
Return

Subprog AS_XBOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
If !([F:ITM]SCPFLG=2)
 Affzo XBOMALT : mkstat = 2
Endif
If !mkstat
 Onkey   2 Titled GBOUTS Call S_XBOMALT(zc) From W2ITP
 Onkey 144 Titled GBOUTP Call P_XBOMALT(zc) From W2ITP
Endif
Gosub _AFF
End

Subprog C_XBOMALT(VALEUR)
Variable Decimal VALEUR
## Action %CNTOBJ
Call CONTNUM("TBO","!D",VALEUR,"3",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "XBOMALT" : GZNUM = 26829 : Endif
Gosub _AFF
End

$AMM_XBOMALT
Call AM_XBOMALT(zc)
If !mkstat & GOBJET
 zoncou = "XBOMALT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XBOMALT(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_XBOMALT(VALEUR) From SUBITP
If mkstat : GERR = 1 : GZONE = "XBOMALT" : GZNUM = 26829 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZXBOMALT)")>indice
 [M]XBOMALT(indice) = VALEUR
 Affzo ZXBOMALT(indice)
Endif
Gosub _AFF
End

Subprog S_XBOMALT(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELSCONOM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSCONOM"
 PARMSK(1) = ""
 PARMSK(2) = [F:ITM]ITMREF
 Call S_TAB_NUM(VALEUR,PARMSK,"SELSCONOM","SCOSELLIB","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog P_XBOMALT(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = "3"
Call VISU("TBO",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZXBOMALT
Onevent BEFORE_AREA Gosub AV_ZXBOMALT From W2ITP
Return

$AV_ZXBOMALT
Call LECTEXTRA(zc,"TABBOMALT","TBODESAXX","3",num$([M]XBOMALT(indice))) From ATEXTRA
Gosub _AFF
Return

