#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTMIWL  : Action recalcul charges                      #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

########################################################################
$INIT_DIA
Local    Char    LFCY(GLONFCY) : LFCY = PARAM(1)
Local    Char    LDAT(10)      : LDAT = PARAM(2)
Local    Integer LHOR : LHOR = val(PARAM(3))
Local    Integer LJAL : LJAL = val(PARAM(4))                # llc 11.02 16478
Local    Integer LRET : LRET = 0

# titre de la boîte
TIT = mess(134,195,1)
Raz [M:DIA]

If LFCY <> "" : [M:DIA]MFGFCY = LFCY : Else [M:DIA]MFGFCY = GFCY : Endif
If LDAT <> ""
    If instr(1,LDAT,"/")
        [M:DIA]REFDAT = "["+LDAT+"]"
    Else
        [M:DIA]REFDAT = LDAT
    Endif
Endif
If LHOR <> 0  : [M:DIA]SELDAYNBR = LHOR : Endif
Return

########################################################################
$CONTROLE
# llc 11.03 19214
WJALFLG = 1
If [M:DIA]JALFLG = 2 : WJALFLG += 2 : Endif
# X3-23527 - STWIL - OPTFLG will only be visible if Production Scheduler is not activitated
If dim([M:DIA]OPTFLG) > 0 & [M:DIA]OPTFLG = 2 : WJALFLG += 4 : Endif
Gosub CTL_LOAD
TIT=" "
TMP=1
Return


#########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTIWL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# llc 11.02 16381
If [M:DIA]REFDAT = [0/0/0]
  If GSERVEUR
    [M:DIA]REFDAT = date$
  Else
    [M:DIA]REFDAT = datesyst
  Endif
Endif

# recalcul charges
Gosub TRT_IWL

Return

#########################################################################
$TERMINE
If !GSERVEUR
    Call FERME_TRACE From LECFIC
Endif
Return

########################################################################
$OUVRE
Local Integer  MODE
Local Integer  OK
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WFCY(GLONFCY)
Local Date     CUTSTRDAT
Local Integer  HORIZ
Local Char     WWSTD(GLONWST)
Local Char     WWSTF(GLONWST)
Local Char     XCRITERE(255)        # llc 11.03 19214
Local Integer  WJALFLG

# Ouverture tables
Local File ATABZON    [ATZ]
Local File ADOPAR     [ADP]
If clalev([F:ATX]) = 0 : Local File ATEXTE     [ATX] : Endif
Local File FACILITY   [FCY]
Local File PARJAL     [PJA]
Local File OPERATIONS [OPS]        # llc 11.03 19214
Local File SCHEDULING [SCH]        # llc 11.03 19214
Local File MFGHEAD    [MFG]        # llc 11.03 19214
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif

Gosub CHARG_PARAM

Return


#---------------------------------------------------------------------#
# Traitement                                                          #
#---------------------------------------------------------------------#
$TRT_IWL
CUTSTRDAT     = [M:DIA]REFDAT
HORIZ         = [M:DIA]SELDAYNBR
WFCY          = [M:DIA]MFGFCY
WWSTD         = [M:DIA]WSTDEB
WWSTF         = [M:DIA]WSTFIN
# Issue 109999 report 91268 GA 09/2015
# Issue 84411 GA 10/2012 Pas de Raz si on rejalonne
# recalcul découpage seulement si traitement complet site
#If WWSTD = "" & WWSTF = "" & WJALFLG<2
    Call IWKLFCY(WFCY, CUTSTRDAT,WWSTD,WWSTF) From JALLIBD
#Endif
Call JALFCY(WFCY, WWSTD, WWSTF, WJALFLG) From JALLIBD            # llc 11.02 16478 + 11.03 19214
Return


#---------------------------------------------------------------------#
# contrôle charge dans le passé                                       #
# llc 11.03 19214
#---------------------------------------------------------------------#
$CTL_LOAD
If [F:PJA]MFGFCY <> [M:DIA]MFGFCY
    Read [PJA]PJA0=[M:DIA]MFGFCY
    If fstat : Raz [PJA] : Endif
Endif

XCRITERE = "1=1"
If [M:DIA]WSTDEB <> "" : XCRITERE += "&[F:OPS]EXTWST>=[M:DIA]WSTDEB" : Endif
If [M:DIA]WSTFIN <> "" : XCRITERE += "&[F:OPS]EXTWST<=[M:DIA]WSTFIN" : Endif
Link [OPS] With [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
&          As   [SCOP]
&          Where [F:OPS]MFGFCY     = [M:DIA]MFGFCY &
&                [F:OPS]OPESTR     < [M:DIA]REFDAT &
&                [F:SCH]OPESTRDAT <> [0/0/0]       &
&                evalue(XCRITERE)

For [SCOP]OPS1
    If find([F:OPS]OPSSTA,1,2)
        Read [MFG]MFG0=[F:OPS]MFGNUM
        If fstat : Raz [MFG] : Endif
        If [F:MFG]SCDFLG <> 2 : Goto NEXT_CTL_LOAD : Endif
    Else
        If [F:SCH]FITCAPSTR <> [0/0/0] : Goto NEXT_CTL_LOAD : Endif
    Endif
    GMESSAGE = mess(200,190,1)
    Break
$NEXT_CTL_LOAD
Next

If GMESSAGE <> ""
    If find(WJALFLG,3,5,7) & [F:PJA]AUTFRWSCD = 2
       Raz GMESSAGE
    Elsif !GSERVEUR : # Issue 118352 GH 05/10/16 - during batch execution, the warning message stopped the process
       GERR = 3
       FOK = 0
    Endif
Endif

Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################
########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

Local Char    WIN (GLONFEN)
WIN="DAUTMIWL"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT


End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]WSTFIN = VALEUR : Endif
End


########################################
Subprog AV_WSTMESS(VALEUR)
Variable Char    VALEUR()
If [M:DIA]WSTDEB <> "" | [M:DIA]WSTFIN <> ""
    VALEUR = mess(161,190,1)
Else
    VALEUR = ""
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 03/11/2003 14:07:49 (LLC)
##########################################################################
Subprog C_REFDAT(VALEUR)
Variable Date    VALEUR
End


##########################################################################

