#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
Subprog AM_DAYUOM(VALEUR)
Variable Char    VALEUR()

  If !GIMPORT Then
    If [M:ITAV]HDKITMTYP = 3 Then
      If [M:ITAV]HOUUOM <> "" Then
        [M:ITAV]DAYUOM = VALEUR
        Call SREC_COE([M:ITM0]ITMREF, "", [M:ITAV]HOUUOM, [M:ITAV]DAYUOM, [M:ITAV]COEHOUDAY) From TRTVENQTE
      Endif
    Endif
    Affzo [M:ITAV]COEHOUDAY
  Endif
End

##########################################################################
Subprog AM_HOUUOM(VALEUR)
Variable Char    VALEUR()

  If !GIMPORT Then
    If [M:ITAV]HDKITMTYP = 3 Then
      If [M:ITAV]DAYUOM <> "" Then
        [M:ITAV]HOUUOM = VALEUR
        Call SREC_COE([M:ITM0]ITMREF, "", [M:ITAV]HOUUOM, [M:ITAV]DAYUOM, [M:ITAV]COEHOUDAY) From TRTVENQTE
      Endif
    Endif
    Affzo [M:ITAV]COEHOUDAY
  Endif
End

##########################################################################
Subprog AM_HDKITMTYP(VALEUR)
Variable Integer VALEUR

  If !GIMPORT Then
    If VALEUR = 3 Then
      Actzo [M:ITAV]DAYUOM
      Actzo [M:ITAV]HOUUOM
      Actzo [M:ITAV]MNTUOM
      #Propose des valeurs d'unité de temps par défaut.
      If [M:ITM3]SAU <> "" Then
        Read [UOT]UOT0=[M:ITM3]SAU
        If !fstat Then
          Case [F:UOT]TYPUOM
            When 2
              If [M:ITAV]DAYUOM = "" Then
                [M:ITAV]DAYUOM = [M:ITM3]SAU
              Endif
              If [M:ITAV]HOUUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 3 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]HOUUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
              If [M:ITAV]MNTUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 4 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]MNTUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
            When 3
              If [M:ITAV]DAYUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 2 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]DAYUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
              If [M:ITAV]HOUUOM = "" Then
                [M:ITAV]HOUUOM = [M:ITM3]SAU
              Endif
              If [M:ITAV]MNTUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 4 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]MNTUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
            When 4
              If [M:ITAV]DAYUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 2 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]DAYUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
              If [M:ITAV]HOUUOM = "" Then
                Filter [UOT] Where [F:UOT]TYPUOM = 3 Order By [F:UOT]UOM Asc
                For [UOT]
                  [M:ITAV]HOUUOM = [F:UOT]UOM
                  Break
                Next
                Filter [UOT]
              Endif
              If [M:ITAV]MNTUOM = "" Then
                [M:ITAV]MNTUOM = [M:ITM3]SAU
              Endif
          Endcase
        Endif
      Endif
    Else
      [M:ITAV]COEHOUDAY = 0
      [M:ITAV]DAYUOM = ""
      [M:ITAV]HOUUOM = ""
      [M:ITAV]MNTUOM = ""
      Grizo [M:ITAV]DAYUOM
      Grizo [M:ITAV]HOUUOM
      Grizo [M:ITAV]MNTUOM
    Endif
    If VALEUR = 2 Then
      If [M:ITM2]STOMGTCOD > 1 Then
        Actzo [M:ITAV]STOISSDEF
      Else
        Grizo [M:ITAV]STOISSDEF
        [M:ITAV]STOISSDEF = 1
      Endif
    Else
      Grizo [M:ITAV]STOISSDEF
      [M:ITAV]STOISSDEF = 1
    Endif
    If VALEUR = 5 Then
      [M:ITAV]CREMAC = 1
      [M:ITAV]FLYCAT = ""
      [M:ITAV]TPLCONLND = ""
      [M:ITAV]TPLCONGUA = ""
      [M:ITAV]TPLCONSRV = ""
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        [M:ITAV]PITDEB = 0
        [M:ITAV]NULPIO = 0
      Endif
      Raz [M:ITAV]ALTBOMHDK
    Endif
    [M:ITAV]HDKITMTYP = VALEUR
    Gosub SETGRAY From SUBITMCRM
  Endif
End

########################################################################
#Vérifie la cohérence des saisies relatives aux unités de temps
########################################################################
$CHECKITAV
Local Integer ITER

  #Vérifie qu'un article de type Contrat de service est bien de type Autre ou Contrat de service
  If [M:ITAV]TPLCONSRV <> "" Then
    If [M:ITAV]HDKITMTYP <> 1 Then
      If [M:ITAV]HDKITMTYP <> 5 Then
        #Un article associé à un contrat de service doit être soit de type Autre soit de type Contrat de service.
        GMESSAGE = mess(97,177,1)
        GERR = 3
        OK = 0
        Return
      Endif
    Endif
  Endif
  If [M:ITAV]HDKITMTYP <> 3 Then
    Return
  Endif
  #Vérifie que toutes les unités des onglets Unité et Clients sont des unités de temps.
  #Unité de stock
  If [M:ITM3]STU = "" Then
    #Aucune unité de stock n'est précisée. Saisie refusée.
    GMESSAGE = mess(207,182,1)
    GERR = 3
    OK = 0
    Return
  Endif
  Read [UOT]UOT0=[M:ITM3]STU
  If fstat Then
    #L'unité de stock n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(206,182,1)
    GERR = 3
    OK = 0
    Return
  Else
    If [F:UOT]TYPUOM <= 1 Then
      #L'unité de stock n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(206,182,1)
      GERR = 3
      OK = 0
      Return
    Elsif [F:UOT]TYPUOM >= 5 Then
      #L'unité de stock n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(206,182,1)
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
  #Unité de vente
  If [M:ITM3]SAU = "" Then
    #Aucune unité de vente n'est précisée. Saisie refusée.
    GMESSAGE = mess(209,182,1)
    GERR = 3
    OK = 0
    Return
  Endif
  Read [UOT]UOT0=[M:ITM3]SAU
  If fstat Then
    #L'unité de vente n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(208,182,1)
    GERR = 3
    OK = 0
    Return
  Else
    If [F:UOT]TYPUOM <= 1 Then
      #L'unité de vente n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(208,182,1)
      GERR = 3
      OK = 0
      Return
    Elsif [F:UOT]TYPUOM >= 5 Then
      #L'unité de vente n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(208,182,1)
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
  #Vérifie les unités de ventes des articles clients
#MAE, le 16/09/10, bg 67208
If dim([M:ITU]NBITU) > 0
  For ITER = 0 To [M:ITU]NBITU-1
    If [M:ITU]ISAU(ITER) <> "" Then
      Read [UOT]UOT0=[M:ITU]ISAU(ITER)
      If fstat Then
        #L'unité de vente saisie pour le client XXXXX n'est pas une unité de temps. Saisie refusée.
        Read [BPR]BPR0=[M:ITU]BPCNUM(ITER)
        If fstat Then
          GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - mess(217,182,1)
          GERR = 3
          OK = 0
          Break
        Else
          GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - "-" - [F:BPR]BPRNAM - mess(217,182,1)
          GERR = 3
          OK = 0
          Break
        Endif
      Else
        If [F:UOT]TYPUOM <= 1 Then
          #L'unité de vente saisie pour le client XXXXX n'est pas une unité de temps. Saisie refusée.
          Read [BPR]BPR0=[M:ITU]BPCNUM(ITER)
          If fstat Then
            GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - mess(217,182,1)
            GERR = 3
            OK = 0
            Break
          Else
            GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - "-" - [F:BPR]BPRNAM - mess(217,182,1)
            GERR = 3
            OK = 0
            Break
          Endif
        Elsif [F:UOT]TYPUOM >= 5 Then
          #L'unité de vente saisie pour le client XXXXX n'est pas une unité de temps. Saisie refusée.
          Read [BPR]BPR0=[M:ITU]BPCNUM(ITER)
          If fstat Then
            GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - mess(217,182,1)
            GERR = 3
            OK = 0
            Break
          Else
            GMESSAGE = mess(216,182,1) - [M:ITU]BPCNUM(ITER) - "-" - [F:BPR]BPRNAM - mess(217,182,1)
            GERR = 3
            OK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Endif
  If GERR Then
    Return
  Endif
  #Vérifie que les champs DAYUOM, HOUUOM et MNTUOM sont renseignés.
  If [M:ITAV]DAYUOM = "" Then
    #Aucune unité n'est précisée pour valoriser les jours. Saisie refusée.
    GMESSAGE = mess(210,182,1)
    GERR = 3
    OK = 0
    Return
  Endif
  If [M:ITAV]HOUUOM = "" Then
    #Aucune unité n'est précisée pour valoriser les heures. Saisie refusée.
    GMESSAGE = mess(211,182,1)
    GERR = 3
    OK = 0
    Return
  Endif
  If [M:ITAV]MNTUOM = "" Then
    #Aucune unité n'est précisée pour valoriser les minutes. Saisie refusée.
    GMESSAGE = mess(212,182,1)
    GERR = 3
    OK = 0
    Return
  Endif
  #Vérifie que le champ DAYUOM contient une unité de jour
  Read [UOT]UOT0=[M:ITAV]DAYUOM
  If fstat Then
    #L'unité utilisée pour valoriser les jours n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(213,182,1)
    GERR = 3
    OK = 0
    Return
  Else
    If [F:UOT]TYPUOM <> 2 Then
      #L'unité utilisée pour valoriser les jours n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(213,182,1)
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
  #Vérifie que le champ HOUUOM contient une unité d'heure
  Read [UOT]UOT0=[M:ITAV]HOUUOM
  If fstat Then
    #L'unité utilisée pour valoriser les heures n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(214,182,1)
    GERR = 3
    OK = 0
    Return
  Else
    If [F:UOT]TYPUOM <> 3 Then
      #L'unité utilisée pour valoriser les heures n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(214,182,1)
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
  #Vérifie que le champ MNTUOM contient une unité de minute
  Read [UOT]UOT0=[M:ITAV]MNTUOM
  If fstat Then
    #L'unité utilisée pour valoriser les minutes n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(215,182,1)
    GERR = 3
    OK = 0
    Return
  Else
    If [F:UOT]TYPUOM <> 4 Then
      #L'unité utilisée pour valoriser les minutes n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(215,182,1)
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
  #Vérifie qu'une unité acccompagne la saisie d'un crédit de point.
  If type([M:ITAV]PITCDT) > 0 Then
    If [M:ITAV]PITCDT > 0 Then
      If [M:ITAV]PITCDTUOM = "" Then
        #Un crédit de point doit obligatoirement être accompagné d'une unité. Saisie refusée.
        GMESSAGE = mess(475,182,1)
        GERR = 3
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Vérifie que des prestations ne sont pas associées à de la création de parc
  If [M:ITAV]HDKITMTYP > 2 Then
    If [M:ITAV]CREMAC = 2 Then
      Case [F:ITM]HDKITMTYP
        When 3
          #Un article de type main d'oeuvre ne peut pas déclaré en création de parc.
          GMESSAGE = mess(22,177,1)
        When 4
          #Un article de type frais de mission ne peut pas déclaré en création de parc.
          GMESSAGE = mess(23,177,1) 
        When 5
          #Un article de type contrat de service ne peut pas déclaré en création de parc.
          GMESSAGE =  mess(24,177,1)
      Endcase
      GERR = 3
      OK = 0
      Return
    Endif
  Endif
Return

##########################################################################
Subprog AM_TPLCONGUA(VALEUR)
Variable Char    VALEUR()

  Raz [M:ITAV]TPLCONSRV
  [M:ITAV]TPLCONGUA = VALEUR
  Gosub SETGRAY From SUBITMCRM
End

##########################################################################
Subprog AM_TPLCONSRV(VALEUR)
Variable Char    VALEUR()

  Raz [M:ITAV]TPLCONGUA
  [M:ITAV]TPLCONSRV = VALEUR
  If VALEUR <> "" Then
    [M:ITAV]CREMAC = 1
    [M:ITAV]FLYCAT = ""
    [M:ITAV]TPLCONLND = ""
    [M:ITAV]TPLCONGUA = ""
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
      [M:ITAV]PITDEB = 0
      [M:ITAV]NULPIO = 0
    Endif
    Raz [M:ITAV]ALTBOMHDK
    [M:ITAV]HDKITMTYP = 5
  Endif
  Gosub SETGRAY From SUBITMCRM
End

##########################################################################
Subprog AM_TPLCONLND(VALEUR)
Variable Char    VALEUR()

  Raz [M:ITAV]TPLCONSRV
  [M:ITAV]TPLCONLND = VALEUR
  Gosub SETGRAY From SUBITMCRM
End

##########################################################################
Subprog C_TPLCONGUA(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [COT]COT0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(7,135,1)
      GERR = 1
      mkstat = 2
    Else
      If [F:COT]CONCAT <> 1 and [F:COT]CONCAT <> 4 Then
        #La catégorie du modèle de contrat sélectionné est incorrecte.
        GMESSAGE = mess(469,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################
Subprog C_TPLCONSRV(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [COT]COT0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(7,135,1)
      GERR = 1
      mkstat = 2
    Else
      If [F:COT]CONCAT <= 1 Then
        #La catégorie du modèle de contrat sélectionné est incorrecte.
        GMESSAGE = mess(469,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################
Subprog C_TPLCONLND(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [COT]COT0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(7,135,1)
      GERR = 1
      mkstat = 2
    Else
      If [F:COT]CONCAT = 4 Then
        #La catégorie du modèle de contrat sélectionné est incorrecte.
        GMESSAGE = mess(469,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################
Subprog AM_PITCDT(VALEUR)
Variable Decimal VALEUR

  [M:ITAV]PITCDT = VALEUR
  Gosub SETGRAY From SUBITMCRM
End

##########################################################################
Subprog C_DAYUOM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    End
  Endif
  #Vérifie que le champ DAYUOM contient une unité de jour
  Read [UOT]UOT0=VALEUR
  If fstat Then
    #L'unité utilisée pour valoriser les jours n'est pas une unité de temps. Saisie refusée.
    GMESSAGE = mess(213,182,1)
    GERR = 3
    mkstat = 2
    End
  Else
    If [F:UOT]TYPUOM <> 2 Then
      #L'unité utilisée pour valoriser les jours n'est pas une unité de temps. Saisie refusée.
      GMESSAGE = mess(213,182,1)
      GERR = 3
      mkstat = 2
      End
    Endif
  Endif
End

