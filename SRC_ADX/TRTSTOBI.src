#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################################################
# TRTSTOBI      Fonctions pour la Business Intelligence            Stocks   #
#############################################################################
# GETQTYSTU  (LSTOFCY,LITMREF,LIPTDAT)                                      #
#    Renvoie la quantité en stock d'un article/site début période           #
# GETAMTVAL  (LSTOFCY,LITMREF,LIPTDAT)                                      #
#    Renvoie le stock en valeur d'un article/site début période (devise soc)#
# GETAMTVALR (LSTOFCY,LITMREF,LIPTDAT)                                      #
#    Renvoie le stock en valeur d'un article/site début période (devise rpt)#
# GETRCPFLG  (TRSTYP,QTYSTU,AMTVAL)                                         #
#    Renvoie 2 si le mouvement correspond à une entrée en stock, 1 sinon    #
# GETISSFLG  (TRSTYP,QTYSTU,AMTVAL)                                         #
#    Renvoie 2 si le mouvement correspond à une sortie de stock, 1 sinon    #
# GETSTOQLYD (VCRTYP,VCRNUM,VCRLIN,QTYSTU)                                  #
#    Renvoie le Statut Qualité origine si mvt de stock <Ctrl qualité>       #
# GETBPRNUM  (VCRTYP,VCRNUM,VCRLIN,QTYSTU)                                  #
#    Recherche le Nom de fournisseur   si mvt de stock <Ctrl qualité>       #
#############################################################################
# la table temporaire WRKSTOPER contient une estimation du stock article/site
# a une date donnée correspondant à chaque début de période
#############################################################################

###################################################################
## ACTION Mise à jour des tables de faits X3                      #
###################################################################
$ACTION
Case ACTION
 When "DEBUT_FAT"  : Gosub DEBUT_FAT
 When "FIN_FAT"    : Gosub FIN_FAT
Endcase
Return

$DEBUT_FAT
Case TABLE
 When "F_STOJOU"     : Gosub DEBUT_STOJOU
Endcase
Return

$FIN_FAT
Case TABLE
 When "F_STOJOU"     : Gosub FIN_STOJOU
Endcase
Return

###################################################################
## DEBUT_STOJOU Mise à jour de STOJOU                             #
###################################################################
$DEBUT_STOJOU                                          # FQ 60829 #
Local Integer CPT,CPTREG : CPT=0 : CPTREG=0
Local Date WDAT
Local Char WCLE(80)
Local Char WDOSSIER(50) : WDOSSIER=GDOSSIER            # FQ 78611 GA 01/2012 avant =nomap
Local Char WMACHINE(50)
Local File =WDOSSIER+".STOJOU"                 [STJ_]
Local File =WDOSSIER+".AUDITH"                 [AUD_]
Local File =MACHINE+"@"+[F:ABW]COD+".F_STOJOU" [BBB_] # Table de faits

# --------------------------------------
# Date de dernière synchro STOJOU
# --------------------------------------
If dim(GPE)<=0 Local Integer GPE : GPE=0 Endif
If !GPE
    Filter [F:AUD_] Where TBL="STOJOU" & STABI = 3
    Read [AUD_]AUD0 Last
    If !fstat
       WDAT=[F:AUD_]DAT
    Endif
    Filter [F:AUD_]
    Close Local File [AUD_]
Endif

# --------------------------------------
# Suppression des lignes régularisées
# --------------------------------------
Raz CPT
# Issue 111792  - 2015-10-29 by MAE : delete si credat ou upddat >= WDAT
#For [STJ_] Where UPDDAT>=WDAT & REGFLG=2
For [STJ_] Where (UPDDAT>=WDAT & REGFLG=2)|(CREDAT>=WDAT & REGFLG=2)
  # ACLE contient la clé de STOJOU
   WCLE=[STJ_]STOFCY+"~"+num$([STJ_]UPDCOD)+"~"+[STJ_]ITMREF+"~"+num$([STJ_]IPTDAT)+"~"+num$([STJ_]MVTSEQ)+"~"+num$([STJ_]MVTIND)
   Read [BBB_]=WDOSSIER;"STOJOU1";0;WCLE
   If !fstat
       Delete  [BBB_] Curr
       CPT+=1
   Else
       CPTREG+=1
   Endif
Next
If CPT>0
   Call ECR_TRACE("**   TRTSTOBI: STOJOU"-num$(CPT)-"rows deleted",0) From GESECRAN
Else
   Call ECR_TRACE("**   TRTSTOBI: STOJOU"-num$(WDAT)-" no rows deleted"-num$(CPTREG),0) From GESECRAN
Endif

Close Local File [STJ_]
Close Local File [BBB_]
Return

###################################################################
## FIN_STOJOU Mise à jour de STOJOU                               #
###################################################################
$FIN_STOJOU
Local File =MACHINE+"@"+[F:ABW]COD+".F_STOJOU" [BBB_]
Local Integer CPT : CPT=0

# --------------------------------------
# 1er traitement:
# maj des RCPFLG et ISSFLG si nécessaire
# (déjà fait dans la règle de synchro)
# --------------------------------------
# FQ 60119 filtrer les mvts à mettre à jour
Filter [BBB_] Where [BBB_]ISSFLG=0 | [BBB_]RCPFLG=0

For [BBB_]
   # Maz des qtés sur les mvts de type "23=changt de valeur"
   # -------------------------------------------------------
   If [BBB_]TRSTYP=23 : [BBB_]QTYSTU=0 : Endif

   # Entrée ou Sortie ou Autre ?
   # ---------------------------
   If [BBB_]ISSFLG = 0 :
      [BBB_]ISSFLG = func GETISSFLG([BBB_]TRSTYP,[BBB_]QTYSTU,[BBB_]AMTVAL)
   Endif
   If [BBB_]RCPFLG = 0
      [BBB_]RCPFLG = func GETRCPFLG([BBB_]TRSTYP,[BBB_]QTYSTU,[BBB_]AMTVAL)
   Endif

   Rewrite [BBB_]
   CPT+=1
Next
If CPT>0
   Call ECR_TRACE("**   TRTSTOBI: STOJOU"-num$(CPT)-"rows updated (1)",0) From GESECRAN
Endif
Filter [BBB_]

# --------------------------------------
# 2eme traitement:
# Maz des qtés sur les mvts de type "23=changt de valeur"
# --------------------------------------
Raz CPT
Filter [BBB_] Where [BBB_]TRSTYP=23 & [BBB_]QTYSTU<>0
For [BBB_]
   [BBB_]QTYSTU=0
   Rewrite [BBB_]
   CPT+=1
Next
If CPT>0
   Call ECR_TRACE("**   TRTSTOBI: STOJOU"-num$(CPT)-"rows updated (2)",0) From GESECRAN
Endif
Filter [BBB_]

Close Local File [BBB_]
Return


#############################################################################
# GETBPRNUM Recherche le fournisseur           si mvt de stock Ctrl qualité #
#############################################################################
Funprog GETBPRNUM (LVCRTYP,LVCRNUM,LVCRLIN,LBPRNUM)
Value    Integer  LVCRTYP
Value    Char     LVCRNUM
Value    Integer  LVCRLIN
Value    Char     LBPRNUM

Local    Char     WBPR (GLONBPR)  : # Fournisseur

  If LVCRTYP=28 & LBPRNUM=""

   # Lecture de l'entête <Ctrl qualité>
     If !clalev([F:QLH])   Local File =GDOSSIER+"."+"STOQLYH"    [QLH]   Endif
     If [F:QLH]VCRTYP<>LVCRTYP | [F:QLH]VCRNUM<>LVCRNUM
         Read [F:QLH] QLH0 = LVCRTYP;LVCRNUM
         If fstat Raz [F:QLH] Endif
     Endif

   # Lecture de l'entête <Réception>
     If [F:QLH]VCRTYPORI=6
        If !clalev([F:PTH])   Local File =GDOSSIER+"."+"PRECEIPT"    [PTH]   Endif
        If [F:PTH]PTHNUM<>[F:QLH]VCRNUMORI
            Read [F:PTH] PTH0 = [F:QLH]VCRNUMORI
            If fstat Raz [F:PTH] Endif
        Endif

        WBPR = [F:PTH]BPSNUM
     Endif
  Else
     WBPR = LBPRNUM
  Endif


End WBPR



#############################################################################
# GETSTOQLYD Renvoie le Statut Qualité origine si mvt de stock Ctrl qualité #
#############################################################################
Funprog GETSTOQLYD  (VCRTYP,VCRNUM,VCRLIN,QTYSTU)
Value    Integer  VCRTYP
Value    Char     VCRNUM
Value    Integer  VCRLIN
Value    Decimal  QTYSTU

Local    Char     WSTA (GLONSTA)  : # Statut de stock

  If VCRTYP=28 & QTYSTU > 0
     If !clalev([F:QLD])   Local File =GDOSSIER+"."+"STOQLYD"    [QLD]   Endif

     If [F:QLD]VCRTYP<>VCRTYP | [F:QLD]VCRNUM<>VCRNUM | [F:QLD]VCRLIN<>VCRLIN
         Read [F:QLD] QLD0 = VCRTYP;VCRNUM;VCRLIN
         If fstat Raz [F:QLD] Endif
     Endif
     WSTA = [F:QLD]STA
  Else
     WSTA = ""
  Endif

End WSTA


#############################################################################
# Parcours des lignes ITMMVTHIS pour renseigner la table tempo WRKSTOPER    #
#############################################################################
$CRE_WSP

Local    Char     WMESSAGE (250)  : # trace

If clalev([F:ITHW]) = 0 : Local File =GDOSSIER+"."+"ITMMVTHIS"  [ITHW] : Endif

   Filter [F:WSP] Where STOFCY=LSTOFCY and ITMREF=LITMREF and IPTDAT<LIPTDAT
   Raz  [F:WSP]
   Read [F:WSP] Last
   If fstat
   # 1er cas: il n'existe aucune ligne dans WSP pour cet article-site
   #          on relit toutes les lignes ITMMVTHIS - les compteurs repartent à zéro
     Filter [F:ITHW] Where STOFCY=LSTOFCY and ITMREF=LITMREF and PERSTR<LIPTDAT
     [F:WSP]STOFCY = LSTOFCY
     [F:WSP]ITMREF = LITMREF
   Else
   # 2eme cas: au moins une ligne dans WSP pour une période précédente
   #           on relit les lignes ITMMVTHIS postérieures à cette période
   #           les cumuls QTYSTU et AMTVAL sont complétés
     Filter [F:ITHW] Where STOFCY=LSTOFCY and ITMREF=LITMREF and PERSTR<LIPTDAT and PERSTR>=[F:WSP]IPTDAT
   Endif
   For [F:ITHW]
     [F:WSP]QTYSTU += [F:ITHW]MONRCPQTY - [F:ITHW]MONISSQTY
     [F:WSP]AMTVAL += [F:ITHW]MONRCPAMT - [F:ITHW]MONISSAMT
   Next
   [F:WSP]IPTDAT = LIPTDAT
   Write [F:WSP]
   If fstat
      WMESSAGE = "TRTSTOBI(CRE_WSP): erreur "- num$(fstat) - " écriture [F:WSP] "- LSTOFCY+"/"+LITMREF+"/"+num$(LIPTDAT)
      Call ECR_TRACE(WMESSAGE,0) From GESECRAN
   Endif

   Filter [F:ITHW]
   Filter [F:WSP]

Return


#############################################################################
# GETQTYSTU  Renvoie la quantité en stock d'un article/site début période   #
#############################################################################
Funprog GETQTYSTU  (LSTOFCY,LITMREF,LIPTDAT)
Value    Char     LSTOFCY
Value    Char     LITMREF
Value    Date     LIPTDAT


   If !clalev([F:WSP]) :  Local File =GDOSSIER+"."+"WRKSTOPER"    [WSP]  : Endif

   If [F:WSP]STOFCY<>LSTOFCY | [F:WSP]ITMREF<>LITMREF | [F:WSP]IPTDAT<>LIPTDAT
       Read [F:WSP] WSP0 = LSTOFCY;LITMREF;LIPTDAT
       If fstat : Gosub CRE_WSP
       #Else
       #   WMESSAGE = "TRTSTOBI(GETQTYSTU): relecture ok [F:WSP] "- LITMREF - LSTOFCY - num$(LIPTDAT)
       #   Call ECR_TRACE(WMESSAGE,0) From GESECRAN
       Endif
   Endif

End [F:WSP]QTYSTU


#############################################################################
# GETAMTVAL  Renvoie le stock en valeur d'un article/site début période     #
#############################################################################
Funprog GETAMTVAL  (LSTOFCY,LITMREF,LIPTDAT)
Value    Char     LSTOFCY
Value    Char     LITMREF
Value    Date     LIPTDAT


   If !clalev([F:WSP]) :  Local File =GDOSSIER+"."+"WRKSTOPER"    [WSP]  : Endif

   If [F:WSP]STOFCY<>LSTOFCY | [F:WSP]ITMREF<>LITMREF | [F:WSP]IPTDAT<>LIPTDAT
       Read [F:WSP] WSP0 = LSTOFCY;LITMREF;LIPTDAT
       If fstat : Gosub CRE_WSP : Endif
   Endif
End [F:WSP]AMTVAL


#############################################################################
# GETAMTVALR Renvoie le stock en valeur d'un article/site début période     #
#############################################################################
Funprog GETAMTVALR (LSTOFCY,LITMREF,LIPTDAT)
Value    Char     LSTOFCY
Value    Char     LITMREF
Value    Date     LIPTDAT

Local    Decimal  WAMTVAL1 , WAMTVAL2

  # Valorisation en devise société
  WAMTVAL1 = func TRTSTOBI.GETAMTVAL(LSTOFCY,LITMREF,LIPTDAT)

  # Conversion en devise reporting
  WAMTVAL2 = func TRTX3BI.CNVCPYRPT(LSTOFCY,LIPTDAT,WAMTVAL1 )

End WAMTVAL2

#############################################################################
# GETRCPFLG  (TRSTYP,QTYSTU,AMTVAL)                                         #
#    Renvoie 2 si le mouvement correspond à une entrée en stock, 1 sinon    #
#############################################################################
Funprog GETRCPFLG  (TRSTYP,QTYSTU,AMTVAL)
Value    Integer  TRSTYP
Value    Decimal  QTYSTU
Value    Decimal  AMTVAL
Local Integer WFLG
  #If find(TRSTYP,1,3,5,12,16,18,19,26,28,33) : # Mvt d'entrée en stock
  If find(TRSTYP,1,2,3,4,5,6,11,12,13,14,19,23,24,29)
     If (QTYSTU>0 | (QTYSTU=0 & AMTVAL>0))
        WFLG = 2
     Else
        WFLG = 1
     Endif
  Else
     WFLG = 1
  Endif

End WFLG

#############################################################################
# GETISSFLG  (TRSTYP,QTYSTU,AMTVAL)                                         #
#    Renvoie 2 si le mouvement correspond à une sortie de stock, 1 sinon    #
#############################################################################
Funprog GETISSFLG  (TRSTYP,QTYSTU,AMTVAL)
Value    Integer  TRSTYP
Value    Decimal  QTYSTU
Value    Decimal  AMTVAL
Local Integer WFLG
  #If find(TRSTYP,2,4,6,11,17,20,24,25,27,29,32) : # Mvt de sortie de stock
  If find(TRSTYP,1,2,3,4,5,6,11,12,13,14,19,23,24,29)
     If (QTYSTU<0 | (QTYSTU=0 & AMTVAL<0))
        WFLG = 2
     Else
        WFLG = 1
     Endif
  Else
     WFLG = 1
  Endif

End WFLG

