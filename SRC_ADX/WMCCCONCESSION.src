If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_USRFLDD2 From WMC2CONCESSION : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_USRFLDD3 From WMC2CONCESSION : Gosub TESTALLSTAT :  Endif
