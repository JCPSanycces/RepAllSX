#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# Programme de synchronisation des appels
#
# CLL_SET        : Mise à jour d'un appel depuis Outlook vers Adonix
# CLL_LOADSET    : Transformation des info de Outlook en Adonix
# CLL_SET_OK     : Confirmation mise à jour Outlook vers Adonix
#
# CLL_GET_DESC   : Description passage info Adonix/Outlook
# CLL_GET        : Mise à jour d'un appel depuis Adonix vers Outlook
# CLL_GET_OK     : Confirmation mise à jour Adonix vers Outlook
##########################################################################################################
# FGR 21/07/2009 : X3SUIVI56584 : Remplacement de USERID(login X3) par GUSER(AUS) partout "où il faut"
##########################################################################################################
# subprog CLL_SET (MAJ dans Adonix)
##########################################################################################################
Subprog CLL_SET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, CALLID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char CALLID()            # ID permettant de retrouver l'appel (OL ou X3)
Value Char UPDFLG()
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer TBVINT(1..)
Variable Char TBKDEC()(1..)       # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char TBKDATTIM()(1..)    # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char TBKCLOB()(1..)      # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCLLUSR(GLONAUS)
Local Integer LERRCOD
Local Integer ITRACE
Local Integer IOPENTRACE
Local Integer INBRECORD
Local Char SZMODE(GLONDES)
Local Integer IBERROR
Local Integer INBMES
Local Char SZCLLNUM(GLONCLL)
Local Char SZOBJET(GLONAOB)

  LERRCOD = 0
  IBRETOUR = 1
  IBERROR = MC_FALSE
  INBMES = 1
  INBRECORD = 0
  RET = MC_OK
  Raz SZCLLUSR
  Raz SZMODE
  Raz SZCLLNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #Traitement de l'identifiant appel
  Call DECOD_OTKID(CALLID, "CLL", SZCLLNUM, SZOBJET) From SUBSYDUTIL
  If GCRMSYNC <> 2 Then
    RET = MC_OK
    End
  Endif
  If GCRMSYNCCLL <> 2 Then
    RET = MC_OK
    End
  Endif
  If USERID = "" Then
    MSGFLG(INBMES) = MC_ERROR
    #Aucun utilisateur n'est défini pour la synchronisation.
    MSGTXT(INBMES) = mess(231,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
    End
  Endif
  ITRACE = 1
  #Reinitialisation type conflit
  GITYPECONFLIT = 0
  GDTDATEMODIFOTK = [00/00/00]
  GDTDATEMODIFADX = [00/00/00]
  Local File PHONECALL [CLL]
  Local File SYNCDATA [SYD]
  #"Traitement données outlook +" CALLID="  + SZCLLNUM + " " Type+" : " UPDFLG
  Call ECR_TRACE((mess(228,177,1) - "CALLID=" + CALLID + "  " + mess(115,123,1) - ":" - UPDFLG), 0) From GESECRAN
  If UPDFLG = MC_UPD_RES Then
    If SZCLLNUM = "" Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et l'appel a le mode restauration.
      MSGTXT(INBMES) = mess(353,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Else
      #Deux cas soit la appel existe encore et on passe en modif
      #         soit la appel n'existe plus et on passe en création avec le code passé
      Read [CLL]CLL0=SZCLLNUM
      If fstat <> 0 Then
        #If faut créer
        UPDFLG = MC_UPD_CRE
      Else
        UPDFLG = MC_UPD_MOD
      Endif
    Endif
  Else
    If UPDFLG = MC_UPD_CRE Then
      SZCLLNUM = ""
    Endif
  Endif
  If SZCLLNUM = "" Then
    If UPDFLG <> MC_UPD_CRE Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et l'appel n'est pas nouveau.
      MSGTXT(INBMES) = mess(352,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Endif
  Endif
  If RET = MC_KO_NEXT or RET = MC_KO Then
    #On sort
    End
  Endif
  If UPDFLG = MC_UPD_CRE Then
    #Cas d'une nouvelle appel
    If GIBCLLADXCRE = MC_TRUE Then
      #On a le droit de creer un appel donc on la creer
      SZMODE = MC_UPD_CRE
      Gosub CLL_LOADSET
      #Rq: transaction géré dans la fonction avec commit ou rollback
      Call CRECLL("SUBSYDCLL", ITRACE, 0, SZCLLNUM, LERRCOD) From SUBCLLCC
      If LERRCOD = 0 Then
        CALLID = "CLL" + SZCLLNUM
        Call DEBTRANS From GLOCK
        Read [CLL]CLL0=SZCLLNUM
        If fstat = 0 Then
          Trbegin [SYD]
          #Si pas de problème lors de la création de la appel, on cree une info de synchro
          Call SYDWRITE(GUSER, [F:CLL]SALFCY, [F:CLL]CLLNUM, "CLL", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            IBERROR = MC_TRUE
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour le nouvel appel+" : "+ [F:CLL]CLLNUM
            MSGTXT(INBMES) = mess(354,177,1) - ":" - [F:CLL]CLLNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            Rollback
          Else
            Commit
          Endif
          #Traitement des zones à transcoder
          If IBERROR = MC_FALSE Then
            Gosub TRTERRORCODIF
          Endif
        Else
          RET = MC_KO_NEXT
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la lecture de l'appel+" : "+ [F:CLL]CLLNUM
          MSGTXT(INBMES) = mess(346,177,1) - ":" - [F:CLL]CLLNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          IBERROR = MC_TRUE
        Endif
      Else
        MSGFLG(INBMES) = MC_ERROR
        MSGTXT(INBMES) = GMESSIMP
        INBMES += 1
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la création d'un nouvel appel.
        MSGTXT(INBMES) = mess(355,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
        IBERROR = MC_TRUE
      Endif
    Endif
  Else
    #On est en modification ou en suppression
    #On vérifie que la appel existe
    Read [CLL]CLL0=SZCLLNUM
    If fstat <> 0 Then
      #appel non trouve, elle a du être supprimé
      If UPDFLG <> MC_UPD_SUP Then
        #La appel existe dans Outlook
        #On vérifie que l'on a une trace pour l'utilisateur dans la synchro
        INBRECORD = 0
        Call DEBTRANS From GLOCK
        Trbegin [SYD]
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
          INBRECORD + = 1
          If [F:SYD]SYDATTTYP <> "A" Then
            Readlock [SYD]Curr
            If fstat = 0 Then
              [F:SYD]SYDATTTYP = "A"
              [F:SYD]SYDOTKSTA = 1
              [F:SYD]SYDUPD = 1
              [F:SYD]SYDDAT = date$
              [F:SYD]SYDHOU = time$
              [F:SYD]CREUSR= GUSER
              [F:SYD]CREDAT = date$
              Rewrite [SYD]
              If fstat <> 0 Then
                RET = MC_KO_NEXT
                IBERROR = MC_TRUE
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de la modification des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                MSGTXT(INBMES) = mess(356,177,1) - ":" - [F:CLL]CLLNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                Break
              Endif
            Else
              RET = MC_KO_NEXT
              IBERROR = MC_TRUE
              MSGFLG(INBMES) = MC_ERROR
              #Impossible de locker les données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
              MSGTXT(INBMES) = mess(357,177,1) - ":" - [F:CLL]CLLNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              Break
            Endif
          Endif
        Next
        If INBRECORD = 0 and IBERROR = MC_FALSE Then
          #On n'a pas de donné de synchronisation
          #On crée une donnée pour indiqué à OutLook de supprimé
          Call SYDWRITE(GUSER, [F:CLL]SALFCY, SZCLLNUM, "CLL", "A", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
            MSGTXT(INBMES) = mess(358,177,1) - ":" - [F:CLL]CLLNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            IBERROR = MC_TRUE
          Endif
        Endif
        #On vérifie que l'on a une transaction en cours
        If adxlog Then
          If IBERROR = MC_TRUE Then
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Else
      #La appel existe
      If UPDFLG = MC_UPD_SUP Then
        #Il faut supprimer la appel
        If GIBCLLADXDLT = MC_TRUE Then
          SZMODE = MC_UPD_SUP
          Gosub CLL_LOADSET
          #Rq: transaction géré dans la fonction avec commit ou rollback
          Call DELCLL("SUBSYDCLL", ITRACE, IOPENTRACE, SZCLLNUM, LERRCOD) From SUBCLLCA
          If LERRCOD > 0 Then
            RET = MC_KO_NEXT
            MSGFLG(INBMES) = MC_ERROR
            MSGTXT(INBMES) = GMESSIMP
            INBMES += 1
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la suppression de l'appel+" : "+ [F:CLL]CLLNUM
            MSGTXT(INBMES) = mess(359,177,1) - ":" - [F:CLL]CLLNUM
            Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
            INBMES += 1
          Endif
          If LERRCOD = 0 Then
            #On a pu supprimer la appel et l'ordre vient de Outlook
            #On supprime les liens
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
            If fstat <> 0 Then
              Rollback
              IBERROR = MC_TRUE
              #Problème car incohérence entre TASK ET SYNCDATA
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la suppression des données de synchronisation pour l'appel+" : "+SZCLLNUM
              MSGTXT(INBMES) = mess(360,177,1) - ":" - SZCLLNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
            Else
              Commit
            Endif
          Endif
        Endif
      Else
        #On est en modif sur un appel qui existe
        Call GETUTIFROMREP([F:CLL]CLLREP, SZCLLUSR, IERRINF, ICHAPTER, IBRETOUR) From CRMUTIL150
        If IBRETOUR <> 0 Then
          If SZCLLUSR <> GUSER Then
            #On a eu un changement de représentant
            #On vérifie dans les données de synchro pour l'ancien
            INBRECORD = 0
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            For [SYD]SYD1 Where [F:SYD]SYDUSR = SZCLLUSR and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
              INBRECORD + = 1
              If [F:SYD]SYDATTTYP <> "P" Then
                Readlock [SYD]Curr
                If fstat = 0 Then
                  [F:SYD]SYDATTTYP = "P"
                  [F:SYD]SYDOTKSTA = 1
                  [F:SYD]SYDUPD = 1
                  [F:SYD]SYDDAT = date$
                  [F:SYD]SYDHOU = time$
                  [F:SYD]CREUSR= GUSER
                  [F:SYD]CREDAT = date$
                  Rewrite [SYD]
                  If fstat <> 0 Then
                    RET = MC_KO_NEXT
                    MSGFLG(INBMES) = MC_ERROR
                    #Erreur lors de la modification des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                    MSGTXT(INBMES) = mess(356,177,1) - ":" - [F:CLL]CLLNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    IBERROR = MC_TRUE
                    Break
                  Endif
                Else
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Impossible de locker les données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                  MSGTXT(INBMES) = mess(357,177,1) - ":" - [F:CLL]CLLNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                  Break
                Endif
              Endif
            Next
            If INBRECORD = 0 and IBERROR = MC_FALSE Then
              #On crée une donnée pour indiqué à OutLook de supprimé pour l"utilisateur
              Call SYDWRITE(SZCLLUSR, [F:CLL]SALFCY, SZCLLNUM, "CLL", "P", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBRETOUR = 0 Then
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de l'écriture des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                MSGTXT(INBMES) = mess(358,177,1) - ":" - [F:CLL]CLLNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
              Endif
            Endif
            #On vérifie que l'on a une transaction en cours
            If adxlog Then
              If IBERROR = MC_TRUE Then
                Rollback
              Else
                Commit
              Endif
            Endif
          Endif
          #On modifie la appel
          If GIBCLLADXUPD = MC_TRUE and IBERROR = MC_FALSE Then
            INBRECORD = 0
            For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
              INBRECORD += 1
              Break
            Next
            If INBRECORD  > 0 Then
              #appel aussi modifier dans X3 donc Conflit
              #On recherche le type de conflit
              Gosub GETTYPECONFLIT
            Endif
            SZMODE = MC_UPD_MOD
            Gosub CLL_LOADSET
            #Rq: transaction géré dans la fonction avec commit ou rollback
            Call UPDCLL("SUBSYDCLL", ITRACE, IOPENTRACE, SZCLLNUM, LERRCOD) From SUBCLLCM
            If LERRCOD = 0 Then
              #On vérifie que l'on a une donnée de synchro
              INBRECORD = 0
              Call DEBTRANS From GLOCK
              Trbegin [SYD]
              For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
                INBRECORD += 1
                If [F:SYD]SYDATTTYP <> "M" Then
                  Readlock [SYD]Curr
                  If fstat = 0 Then
                    [F:SYD]SYDATTTYP = "M"
                    [F:SYD]SYDOTKSTA = 1
                    [F:SYD]SYDUPD = 1
                    [F:SYD]SYDDAT = date$
                    [F:SYD]SYDHOU = time$
                    [F:SYD]CREUSR= GUSER
                    [F:SYD]CREDAT = date$
                    Rewrite [SYD]
                    If fstat <> 0 Then
                      RET = MC_KO_NEXT
                      IBERROR = MC_TRUE
                      MSGFLG(INBMES) = MC_ERROR
                      #Erreur lors de la modification des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                      MSGTXT(INBMES) = mess(356,177,1) - ":" - [F:CLL]CLLNUM
                      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                      INBMES += 1
                      Break
                    Endif
                  Else
                    RET = MC_KO_NEXT
                    IBERROR = MC_TRUE
                    MSGFLG(INBMES) = MC_ERROR
                    #Impossible de locker les données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                    MSGTXT(INBMES) = mess(357,177,1) - ":" - [F:CLL]CLLNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    Break
                  Endif
                Endif
              Next
              If INBRECORD = 0 and IBERROR = MC_FALSE Then
                #On n'a pas de donné de synchronisation
                #On crée une donnée pour indiqué à OutLook d'en tenir compte
                Call SYDWRITE(GUSER, [F:CLL]SALFCY, SZCLLNUM, "CLL", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
                If IBRETOUR = 0 Then
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Erreur lors de l'écriture des données de synchronisation pour l'appel+" : "+ [F:CLL]CLLNUM
                  MSGTXT(INBMES) = mess(358,177,1) - ":" - [F:CLL]CLLNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                Endif
              Endif
              #On vérifie que l'on a une transaction en cours
              If adxlog Then
                If IBERROR = MC_TRUE Then
                  Rollback
                Else
                  Commit
                Endif
              Endif
              #Traitement des zones à transcoder
              If IBERROR = MC_FALSE Then
                Gosub TRTERRORCODIF
              Endif
            Else
              MSGFLG(INBMES) = MC_ERROR
              MSGTXT(INBMES) = GMESSIMP
              INBMES += 1
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la modification de l'appel+" : "+ [F:CLL]CLLNUM
              MSGTXT(INBMES) = mess(361,177,1) - ":" - [F:CLL]CLLNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              RET = MC_KO_NEXT
            Endif
          Else
            RET= MC_OK
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Recherche du type de conflit
##########################################################################################################
$GETTYPECONFLIT
Local Integer IFIND

  #date de modification dans Outlook
  #Date de modification
  IFIND = find("LastModificationTime", TBKDATTIM )
  If IFIND > 0 Then
    Call GETDATEFROMCHAR(TBVDATTIM(IFIND),GDTDATEMODIFOTK,IERRINF,ICHAPTER,IBRETOUR) From SUBSYDUTIL
  Endif
  #date de modification dans Adonix
  GDTDATEMODIFADX = [F:CLL]UPDDAT
  If GDTDATEMODIFADX >= GDTDATEMODIFOTK
    GITYPECONFLIT = MC_RECENTADX
  Else
    GITYPECONFLIT = MC_RECENTOTK
  Endif
Return

##########################################################################################################
# Transfert des infos de Outlook vers Adonix
##########################################################################################################
$CLL_LOADSET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Integer IOTK
Local Integer IVALEUR
Local Integer INBHOUR
Local Char SZREP(GLONREP)
Local Char SZSITE(GLONFCY)
Local Char SZBPRCOR(GLONCOR)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Date DTVALEUR
Local Char SZVALEUR(250)
Local Char SZVALEURTMP(250)
Local Char SZOLDSYNCHOU(250)
Local Date DTOLDSYNCDATE(250)
Local Integer IBOLD_OK
Local Integer IBCONTINUE
Local Integer IFIND
Local Integer IINDICE
Local Char SZCHAINE(250)
Local Char SZCORID(250)
Local Char SZOBJET(GLONAOB)

  Raz SZBPRCOR
  Raz SZREP
  Raz SZSITE
  DTOLDSYNCDATE = [00/00/00]
  SZOLDSYNCHOU = "0000"
  IBOLD_OK = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = MC_TRUE
  DTVALEUR = [00/00/00]
  Raz SZVALEUR
  Raz SZVALEURTMP
  #Tableau de char
  Raz GTBKCHR
  Raz GTBVCHR
  #Tableau entiers
  Raz GTBKINT
  Raz GTBVINT
  #Tableau decimal
  Raz GTBKDEC
  Raz GTBVDEC
  #tableau date
  Raz GTBKDATTIM
  Raz GTBVDATTIM
  #tableau clob
  Raz GTBKCLOB
  Raz GTBVCLOB
  Raz GTBTRTFIE
  Raz GTBTRTVAL
  GNBTRT = 0
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  #Recherche du nombre de contact
  If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
  IFIND = 0
  IBCONTINUE = 1
  Raz SZCHAINE
  IINDICE = 0
  While IBCONTINUE = 1
    If GIBSYNCTSKGERECOR = MC_FALSE Then
      Break
    Endif
    IINDICE += 1
    If IINDICE >= dim(TBKCHR) Then
      IBCONTINUE = 0
      Break
    Endif
    SZCHAINE = "Lk_" + num$(IINDICE) + "_CtAdxId"
    #On recherche CtAdxId
    IFIND = find(SZCHAINE, TBKCHR)
    If IFIND > 0 Then
      If TBVCHR(IFIND) <> "" Then
        #Traitement de l'identifiant correspondant
        Call DECOD_OTKID(TBVCHR(IFIND), "COR", SZCORID, SZOBJET) From SUBSYDUTIL
        IBCONTINUE = 0
        Read [COR]COR0=SZCORID
        If fstat = 0 Then
          GTBKCHR(ICHAR) = "CLLCOR"
          GTBVCHR(ICHAR) = SZCORID
          ICHAR += 1
          If [F:COR]CNTNUM <> "" Then
            GTBKCHR(ICHAR) = "CLLCCN"
            GTBVCHR(ICHAR) = [F:COR]CNTNUM
            ICHAR += 1
          Else
            GTBKCHR(ICHAR) = "CLLCCN"
            GTBVCHR(ICHAR) = ""
            ICHAR += 1
          Endif
          SZBPRCOR = [F:COR]BPRNUM
        Else
          SZBPRCOR  = ""
        Endif
      Else
        GTBKCHR(ICHAR) = "CLLCOR"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        GTBKCHR(ICHAR) = "CLLCCN"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        SZBPRCOR  = ""
      Endif
    Else
      # FGR 25/08/2014 : X3SUIVI102228 : en 2013 il n'y a plus le contact, donc ne pas l'effacer si on arrive ici
      If dim(GSYNOLVERSION) >= 0 and GSYNOLVERSION >= "15.0" Then
      Else
        # Jusqu'à OL2010
        GTBKCHR(ICHAR) = "CLLCOR"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        GTBKCHR(ICHAR) = "CLLCCN"
        GTBVCHR(ICHAR) = ""
        ICHAR += 1
        SZBPRCOR  = ""
        IBCONTINUE = 0
      Endif
      Break
    Endif
  Wend
  #Traitement du tableau de char d'outlook
  IOTK = 1
  While IOTK < dim(TBKCHR)+1
    Case TBKCHR(IOTK)
      When "Companies"
        #Société
        If TBVCHR(IOTK) <> "" Then
          Call SYN_GETBPR(TBVCHR(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
          If SZVALEUR <> "" Then
            GTBKCHR(ICHAR) = "CLLCMP"
            GTBVCHR(ICHAR) = SZVALEUR
            ICHAR += 1
          Else
            If SZBPRCOR <> "" Then
              GTBKCHR(ICHAR) = "CLLCMP"
              GTBVCHR(ICHAR) = SZBPRCOR
              ICHAR += 1
            Else
              GTBTRTFIE(GNBTRT)= "CLLCMP"
              GTBTRTVAL(GNBTRT)= TBVCHR(IOTK)
              GNBTRT+ = 1
            Endif
          Endif
        Else
          GTBKCHR(ICHAR) = "CLLCMP"
          GTBVCHR(ICHAR) = ""
          ICHAR += 1
        Endif
    Endcase
    IOTK + = 1
  Wend
  #Traitement du tableau entier d'outlook
  IOTK = 1
  While IOTK < dim(TBKINT)+1
    Case TBKINT(IOTK)
      When "ActualWork"
        #durée
        GTBKINT(IINT) = "CLLDUR"
        GTBVINT(IINT) = TBVINT(IOTK)
        IINT += 1
      When "Complete"
        #Terminé Oui/non
        GTBKINT(IINT) = "CLLDON"
        If TBVINT(IOTK) = 1 Then
          GTBVINT(IINT) = 2
        Else
          GTBVINT(IINT) = 1
        Endif
        IINT += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de décimal d'outlook
  IOTK = 1
  While IOTK < dim(TBKDEC)+1
    Case TBKDEC(IOTK)
      When "test"
    Endcase
    IOTK += 1
  Wend
  #première boucle pour trouver la date/heure stocker
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    Case TBKDATTIM(IOTK)
      When "AdxTaskDateTime"
        #Date stockée
        DTVALEUR = [00/00/00]
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        DTOLDSYNCDATE = DTVALEUR
        #Heure stocké
        Raz SZVALEUR
        Call GETTIMEFROMCHAR(TBVDATTIM(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        SZOLDSYNCHOU = SZVALEUR
        Break
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de date d'outlook
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    Case TBKDATTIM(IOTK)
      When "StartDate"
        #Echéance
        GTBKDATTIM(IDATE) = "CLLDAT"
        DTVALEUR = [00/00/00]
        Call GETDATEFROMCHAR(TBVDATTIM(IOTK), DTVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        GTBVDATTIM(IDATE) = DTVALEUR
        IDATE += 1
        If DTVALEUR = DTOLDSYNCDATE Then
          IBOLD_OK = 1
        Else
          IBOLD_OK = 0
        Endif
        #Heure
        GTBKCHR(ICHAR) = "CLLHOU"
        Raz SZVALEURTMP
        Call GETTIMEFROMCHAR(TBVDATTIM(IOTK), SZVALEURTMP, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
        If SZVALEURTMP <> "000000" Then
          SZVALEUR = SZVALEURTMP
        Else
          If IBOLD_OK = 1 Then
            SZVALEUR = SZOLDSYNCHOU
          Else
            SZVALEUR = "090000"
          Endif
        Endif
        GTBVCHR(ICHAR) = SZVALEUR
        ICHAR += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de clob d'outlook
  IOTK = 1
  While IOTK < dim(TBKCLOB)+1
    Case TBKCLOB(IOTK)
       When "Subject"
         GTBKCLOB(ICLOB) = "FULOBJ"
         GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
         ICLOB += 1
       When "Body"
         GTBKCLOB(ICLOB) = "FULRPO"
         GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
         ICLOB += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement des zones spéciales
  #Représentant
  Call PARAMUTIL("AUSCRMF", SZREP, GUSER, SZSITE) From SUBAUS
  GTBKCHR(ICHAR) = "CLLREP"
  GTBVCHR(ICHAR) = SZREP
  ICHAR += 1
  #Site
  Raz SZSITE
  Call SITECRMREP("ACT", SZREP, SZSITE) From CRM_UTIL
  If SZSITE <> "" Then
    GTBKCHR(ICHAR) = "SALFCY"
    GTBVCHR(ICHAR) = SZSITE
    ICHAR += 1
  Endif
  #Numéro de appel (cas particulier de la restoration)
  If SZCLLNUM  <> "" Then
    GTBKCHR(ICHAR) = "CLLNUM"
    GTBVCHR(ICHAR) = SZCLLNUM
    ICHAR += 1
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un appel. (exemple)
#############################################################################
$CLL_SET_HEA_INFO
Local Integer INDEXE
Local Char SZREP(GLONREP)
Local Integer IBAFFECTE

  SZREP = ""
  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INDEXE = 0
  IBAFFECTE= MC_FALSE
  Case IMPZON
    When "CLLNUM"
      #Numéro de appel
      If GREP = "C" Then
        INDEXE = find("CLLNUM", GTBKCHR)
        If INDEXE <> 0 Then
          [M:CLL0]CLLNUM = GTBVCHR(INDEXE)
        Endif
      Endif
    When "SALFCY"
      #Site
      If GREP = "C" Then
        INDEXE = find("SALFCY", GTBKCHR)
        If INDEXE <> 0 Then
          [M:CLL0]SALFCY = GTBVCHR(INDEXE)
        Endif
      Endif
    When "CLLCMP"
      #Tiers
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLCMP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL0]CLLCMP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLCCN"
      #Interlocuteur
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLCCN", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL0]CLLCCN = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLCOR"
      #Interlocuteur
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLCOR", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL0]CLLCOR = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLOPP"
      #Affaire
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLOPP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL0]CLLOPP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLDAT"
      #Date
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLDAT", GTBKDATTIM)
          If INDEXE <> 0 Then
            [M:CLL1]CLLDAT = GTBVDATTIM(INDEXE)
          Endif
          # FGR 05/03/2010 : X3SUIVI62924 (début)
          INDEXE = find("CLLORIADI", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLORIADI = GTBVCHR(INDEXE)
            [M:CLL1]CLLORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:CLL1]CLLORIADI)
            Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150
          Endif
          INDEXE = find("CLLORIVCR", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLORIVCR = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("CLLORIVCRL", GTBKINT)
          If INDEXE <> 0 Then
            [M:CLL1]CLLORIVCRL = GTBVINT(INDEXE)
          Endif
          INDEXE = find("CLLCMGNUM", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLCMGNUM = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("CLLOPGNUM", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLOPGNUM = GTBVCHR(INDEXE)
          Endif
          INDEXE = find("CLLOPGTYP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLOPGTYP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
     When "CLLHOU"
      #Heure
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLHOU", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLHOU = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLTYP"
      #Type de l'appel
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLTYP", GTBKINT)
          If INDEXE <> 0 Then
            [M:CLL0]CLLTYP = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "CLLREP"
      #Représentant
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLREP", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL1]CLLREP = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CLLDON"
      #Effectué
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLDON", GTBKINT)
          If INDEXE <> 0 Then
            [M:CLL0]CLLDON = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "CLLDUR"
      #Durée (minute)
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLDUR", GTBKINT)
          If INDEXE <> 0 Then
            [M:CLL3]CLLDUR = GTBVINT(INDEXE)
          Endif
        Endif
      Endif
    When "CLLSAO"
      #Satisfaction
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CLLSAO", GTBKCHR)
          If INDEXE <> 0 Then
            [M:CLL3]CLLSAO = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "FULOBJ"
      #Objet
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULOBJ", GTBKCLOB)
          If INDEXE <> 0 Then
            [M:CLL1]FULOBJ = GTBVCLOB(INDEXE)
          Endif
        Endif
      Endif
    When "FULRPO"
      #Compte-rendu
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("FULRPO", GTBKCLOB)
          If INDEXE <> 0 Then
            Local Clbfile LBCLOB(3)

            LBCLOB = GTBVCLOB(INDEXE)
            Call CLEANCLOBBAP(LBCLOB) From SUBSYDUTIL
            [M:CLL3]FULRPO = LBCLOB
          Endif
        Endif
      Endif
  Endcase
Return

##########################################################################################################
# Traitement de l'enregistrement des erreurs de transcodifications
$TRTERRORCODIF
Local Integer ITRT

  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  ITRT = 0
  If GNBTRT > 0 Then
    #On a des données a sauvegarder
    Call DEBTRANS From GLOCK
    Trbegin [SYL]
    While ITRT < GNBTRT
      Call  SYLWRITE(GUSER, "CLL",  SZCLLNUM, GTBTRTFIE(ITRT), GTBTRTVAL(ITRT), IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
      If IBRETOUR = MC_FALSE Then
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de l'écriture des traces de transcodifications. Appel+" : "+ [F:CLL]CLLNUM + Champs +GTBTRTFIE(ITRT)
        MSGTXT(INBMES) = mess(362,177,1) - ":" - [F:CLL]CLLNUM - mess(149,123,1) - GTBTRTFIE(ITRT)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
      ITRT += 1
    Wend
    If IBRETOUR = MC_TRUE Then
      Commit
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
Return

##########################################################################################################
# Confirmation Set (Outlook vers Adonix)
# ------------------------------------------------------------
Subprog CLL_SET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, CALLID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char CALLID()               # ID permettant de retrouver la appel


#Initialisation variables
Gosub INITVAR From SUBSYDSYN

Local Integer IBERROR
Local Integer INBMES
Local Char SZCLLNUM(GLONCLL)
Local Char SZOBJET(GLONAOB)
Local Char SZRET(GLONDES)
Local Integer WI

  IBERROR = MC_FALSE
  Raz SZCLLNUM
  Raz SZOBJET
  # Analyse des messages si besoin
  WI = find(2,MSGFLG)
  #  If(WI! = 0) .....
  WI = find(1,MSGFLG)
  #  If(WI! = 0) .....
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données outlook" CALLID = "  + CALLID + " " Status +" : " + RET
  Call ECR_TRACE((mess(258,177,1) - "CALLID =" - CALLID + "  " + mess(259,123,1) - ":" - RET), 0) From GESECRAN
  #Traitement de l'identifiant appel
  Call DECOD_OTKID(CALLID, "CLL", SZCLLNUM, SZOBJET) From SUBSYDUTIL
  Local File SYNCDATA [SYD]
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  IBERROR = MC_FALSE
  If SZRET <> MC_OK Then
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour l'appel+" : "+ SZCLLNUM
          MSGTXT(INBMES) = mess(356,177,1) - ":" - SZCLLNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour l'appel+" : "+ SZCLLNUM
        MSGTXT(INBMES) = mess(357,177,1) - ":" - SZCLLNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
      RET = MC_OK
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
End

##########################################################################################################
# Description passage info Adonix/Outlook
# ------------------------------------------------------------
Subprog CLL_GET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer INBMES

  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 100
Local Integer WI : WI = 0
Local Char WDSC(200)(1..SC_MAX)

  #Gosub CLL_INIGETDSC From SUBSYDCLLD    # FGR 23/08/2010 : X3SUIVI66826
  #Gosub CLL_LD_GETDESC From SUBSYDCLLD   # FGR 23/08/2010 : X3SUIVI66826
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog CLL_GET(MAJ OutLook depuis Adonix)
# ------------------------------------------------------------
Subprog CLL_GET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, CALLID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char CALLID()            # ID permettant de retrouver la appel (OL ou X3)
Variable Char UPDFLG()            # Type de mise à jour (C,M,S)
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer  TBVINT(1..)
Variable Char  TBKDEC()(1..)      # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char  TBKDATTIM()(1..)   # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char  TBKCLOB()(1..)     # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  #Mise à vide des tableaux dynamiques
  Gosub RAZPARAMDYN From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer INBRECORD
Local Char SZSYDATTTYP(250)
Local Integer ISYDGEN
Local Integer ISYDUPD
Local Integer INBMES
Local Char SZCLLNUM(GLONCLL)
Local Char SZOBJET(GLONAOB)
Local Integer IBERROR
Local Char SZMESSAGE(250)

  IBERROR = 0
  Raz SZMESSAGE
  IBRETOUR = 1
  INBRECORD = 0
  ISYDGEN = 0
  ISYDUPD = 0
  Raz SZSYDATTTYP
  INBMES = 1
  Raz SZCLLNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  RET = MC_OK
  Local File PHONECALL [CLL]
  Local File SYNCDATA [SYD]
  Local File HD4CLOB [HD4]
  Local File HD5CLOB [HD5]
  Local File CORRESPOND [COR]
  If GIBCLLOTKCRE = MC_FALSE and GIBCLLOTKUPD = MC_FALSE and  GIBCLLOTKDLT = MC_FALSE Then
    #Aucun droit synchronisation  dans Outlook on sort
    GINUMTRTGET = 3
    End
  Endif
  #Ontraite les enregistrements par type
  #Rappel
  # "C" création,
  # "D" duplication,
  # "M" modification,
  # "A" annulation
  # "P" changement utilisateur (pour ancien)
  # "R" restauration ou forcage synchro
  INBRECORD = 0
  #Etape 1
  #Enregistrement à créer
  If GINUMETAPEGET = 1 Then
    If GIBCLLOTKCRE = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 2
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "C" or [F:SYD]SYDATTTYP = "D")
        INBRECORD += 1
        SZCLLNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 2
        GINUMETAPEGET = 2
      Endif
    Endif
  Endif
  #Etape 2
  #Enregistrement modifié
  If GINUMETAPEGET = 2 Then
    If GIBCLLOTKUPD = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 3
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "M"
        INBRECORD += 1
        SZCLLNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 3
        GINUMETAPEGET = 3
      Endif
    Endif
  Endif
  #Etape 3
  #Enregistrement restauration ou forcage synchro
  If GINUMETAPEGET = 3 Then
    If GIBCLLOTKCRE = MC_FALSE and GIBCLLOTKUPD = MC_FALSE Then
      #Pas le droit de créer et de modifer  On passe à l'étape 4
      GINUMETAPEGET = 4
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDOTKSTA = 1  and [F:SYD]SYDATTTYP = "R"
        INBRECORD += 1
        SZCLLNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 4
        GINUMETAPEGET = 4
      Endif
    Endif
  Endif
  #Etape 4
  #suppression enregistrement non touché par synchro
  If GINUMETAPEGET = 4 Then
    If GIBCLLOTKDLT = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 5
      GINUMETAPEGET = 5
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "A" or [F:SYD]SYDATTTYP = "P")
        INBRECORD += 1
        SZCLLNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 5
        GINUMETAPEGET = 5
      Endif
    Endif
  Endif
  If GINUMETAPEGET <> 5 Then
    #On a un enregistrement, il faut le traiter
    #Cas des enregistrements nouveaux ou modifiés (la appel existe dans Adonix)
    Call CODE_OTKID(SZCLLNUM, "CLL", CALLID) From SUBSYDUTIL
    #"Traitement données Adonix "CALLID = "  + CALLID+ " " Type+" : " SZSYDATTTYP
    Call ECR_TRACE((mess(260,177,1) - "CALLID =" - CALLID + "  " + mess(115,123,1) - ":" - SZSYDATTTYP), 0) From GESECRAN
    If SZSYDATTTYP = "P" Then
      UPDFLG = "A"
    Else
      UPDFLG = SZSYDATTTYP
    Endif
    If SZSYDATTTYP  <> "A" Then
      Read [CLL]CLL0=SZCLLNUM
      If fstat <> 0 Then
        #Problème car incohérence entre TASK ET SYNCDATA
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la lecture de l'appel+" : "+ SZCLLNUM
        MSGTXT(INBMES) = mess(346,177,1) - ":" - SZCLLNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
      Endif
    Endif
    If RET = MC_OK Then
      #On charge les tableaux dynamiques
      Gosub CLL_LOADGET
    Endif
  Else
    GINUMTRTGET = 3
  Endif
End

##########################################################################################################
# Transfert des infos de Adonix vers Outlook
##########################################################################################################
$CLL_LOADGET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Char SZVALEUR(250)     # FGR 25/02/2014 : X3SUIVI97224
Local Integer IBEXIST
Local Char SZREPCONNECT(GLONREP)
Local Integer IBVIDE
#Local Clbfile LBCLOBENTETE   # FGR 15/01/2013 : X3SUIVI87223
Local Clbfile LBCLOBENTETE(3) # FGR 25/08/2013 : X3SUIVI102228
Local Char SZTEXTE(250)       # FGR 15/01/2013 : X3SUIVI87223
Local Char SZTEXTE1(250)      # FGR 25/02/2014 : X3SUIVI97224

  Raz SZREPCONNECT
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  Raz SZVALEUR
  IBEXIST = 0
  IBVIDE = MC_FALSE
  If UPDFLG = "A" Then
    IBVIDE = MC_TRUE
  Endif
  Call GETREPFROMUTI(GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT = "" Then
    #Erreur, aucun représentant n'est associé à cet utilisateur : GUSER
    MSGTXT(INBMES) = mess(301,177,1) - ":" - GUSER
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
  Endif
  #Tiers
  TBKCHR(ICHAR) = "Companies"
  Call SYN_SETBPR([F:CLL]CLLCMP, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
  If IBRETOUR = MC_TRUE and IBVIDE = MC_FALSE Then
    TBVCHR(ICHAR) = SZVALEUR
  Endif
  ICHAR += 1
  If GIBSYNCTSKGERECOR = MC_TRUE Then
    #Interlocuteur
    IBERROR = 0
    If [F:CLL]CLLCOR <> "" Then
      TBKCHR(ICHAR) = "Lk_1_CtAdxId"
      Call CODE_OTKID([F:CLL]CLLCOR, "COR", TBVCHR(ICHAR)) From SUBSYDUTIL
      ICHAR += 1
      TBKCHR(ICHAR) = "Lk_1_Name"
      Read [COR]COR0=[F:CLL]CLLCOR
      If fstat = 0 Then
        TBVCHR(ICHAR) = [F:COR]LNA - [F:COR]FNA
      Else
        TBVCHR(ICHAR) = [F:CLL]CLLCOR
      Endif
      ICHAR += 1
    Endif
  Endif
  #Travail réel
  TBKINT(IINT) = "ActualWork"
  If IBVIDE = MC_FALSE Then
    TBVINT(IINT) = [F:CLL]CLLDUR
  Endif
  IINT += 1
  #Status
  TBKINT(IINT) = "Status"
  If IBVIDE = MC_FALSE Then
    If [F:CLL]CLLDON = 2 Then
      TBVINT(IINT) = 2
    Else
      If ([F:CLL]CLLDUR) > 0 Then
        TBVINT(IINT) = 1
      Else
        TBVINT(IINT) = 0
      Endif
    Endif
  Endif
  IINT += 1
  #Date début
  TBKDATTIM(IDATE) = "StartDate"
  If IBVIDE = MC_FALSE Then
    Raz SZVALEUR
    Call SETDATETIMETOCHAR([F:CLL]CLLDATX, [F:CLL]CLLHOU, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  IDATE += 1
  #Echéance
  TBKDATTIM(IDATE) = "DueDate"
  If IBVIDE = MC_FALSE Then
    Raz SZVALEUR
    Call SETDATETIMETOCHAR([F:CLL]CLLDATX, [F:CLL]CLLHOU, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  IDATE += 1
  #AdxTaskDateTime
  #Date début
  TBKDATTIM(IDATE) = "AdxTaskDateTime"
  If IBVIDE = MC_FALSE Then
    Raz SZVALEUR
    Call SETDATETIMETOCHAR([F:CLL]CLLDATX, [F:CLL]CLLHOU, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    TBVDATTIM(IDATE) = SZVALEUR
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (début)
  Raz LBCLOBENTETE
  # ------------------------
  # FGR 25/02/2014 : X3SUIVI97224 (début)
  # Entête
  If [F:CLL]CLLTYP = 1 Then
    LBCLOBENTETE += mess(678,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:CLL]CLLNUM, "GESCLL", [F:CLL]CLLNUM)
  Else
    LBCLOBENTETE += mess(679,177,1) - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:CLL]CLLNUM, "GESCLL", [F:CLL]CLLNUM)
  Endif
  LBCLOBENTETE += chr$(13) + chr$(10) + string$(50, '-')
  #
  If [F:CLL]CLLCMP <> "" Then
    Call GETBPRTYP([F:CLL]CLLCMP, SZTEXTE, SZTEXTE1) From CRM_UTIL
    Call SYN_SETBPR([F:CLL]CLLCMP, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    Read [BPR]BPR0=[F:CLL]CLLCMP
    If SZTEXTE1 = "" Then
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - SZVALEUR
    Else
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:BPR]BPRNAM, "GES" + SZTEXTE1, [F:CLL]CLLCMP) - ":" - SZVALEUR
    Endif
  Endif
  If [F:CLL]CLLCCN <> "" Then
    If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
    Read [AIN]AIN0=[F:CLL]CLLCCN
    If !fstat Then
      SZTEXTE = mess([F:AIN]CNTTYP,3038,1)
      Call BUILDFULNAM("AIN", SZVALEUR) From CRMUTIL140
      If [F:AIN]CNTTYP = 1 Then
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESAIN", [F:CLL]CLLCCN) #- ":" - SZVALEUR - "(" + [F:CLL]CLLCCN + ")"
      Else
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESLDS", [F:CLL]CLLCCN) #- ":" - SZVALEUR - "(" + [F:CLL]CLLCCN + ")"
      Endif
    Endif
  Endif
  If [F:CLL]CLLCOR <> "" Then
    Call TEXTE(15307, SZTEXTE) From OBJDIV
    If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
    Read [COR]COR0=[F:CLL]CLLCOR
    If !fstat Then
      Call BUILDFULNAM("COR", SZVALEUR) From CRMUTIL140
      LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZVALEUR, "GESCOR", [F:CLL]CLLCOR) #- ":" - SZVALEUR - "(" + [F:CLL]CLLCOR + ")"
      Call GET_INFO_CORRESPONDANT([F:CLL]CLLCOR, LBCLOBENTETE) From SUBSYDUTIL
    Endif
  Endif
  If [F:CLL]CLLOPP <> "" Then
    Call TEXTE(18260, SZTEXTE) From OBJDIV
    If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
    Read [OPP]OPP0=[F:CLL]CLLOPP
    If !fstat Then
      If dim([F:OPP]OPPDES) >= 0 Then
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK([F:OPP]OPPDES, "GESOPP", [F:CLL]CLLOPP) #- ":" - [F:OPP]OPPDES - "(" + [F:CLL]CLLOPP + ")"
      Else
        Call LECTEXTRA(SZTEXTE1, "PIMPL", "PIMDESAXX", [F:CLL]CLLOPP, "") From ATEXTRA
        LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":" - func SUBSYDUTIL.GET_HYPERLINK(SZTEXTE1, "GESOPP", [F:CLL]CLLOPP) #- ":" - [F:OPP]OPPDES - "(" + [F:CLL]CLLOPP + ")"
      Endif
    Endif
  Endif
  # FGR 25/02/2014 : X3SUIVI97224 (fin)
  # ------------------------
  # "Qualification"
  Call TEXTE(14448, SZTEXTE) From OBJDIV
  LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":"
  If [F:CLL]CLLCAT <> "" Then
    Call TEXTE(707, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - [F:CLL]CLLCAT - "(" + func CRM_UTIL.FGET_LIB(432, [F:CLL]CLLCAT, "LNGDES") + ")"
  Else
    Call TEXTE(707, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ": ***" + mess(962,182,1) + "***"
  Endif
  If [F:CLL]CLLPIOLEV <> "" Then
    Call TEXTE(14482, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - [F:CLL]CLLPIOLEV - "(" + func CRM_UTIL.FGET_LIB(405, [F:CLL]CLLPIOLEV, "LNGDES") + ")"
  Else
    Call TEXTE(14482, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE
    Call TEXTE(16710, SZTEXTE) From OBJDIV
    LBCLOBENTETE += " : ***" + SZTEXTE + "***"
  Endif
  # ------------------------
  # "Informations"
  Call TEXTE(7789, SZTEXTE) From OBJDIV
  LBCLOBENTETE += chr$(13) + chr$(10) + SZTEXTE - ":"
  # Issue X3-42496 - 2017-06-15 by FGR : BEGIN
  #If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  ## TABCOUNTRY
  #If [F:CLL]CLLCCNCRY <> "" Then
  #  Read [TCY]TCY0=[F:CLL]CLLCCNCRY
  #Else
  #  Raz [F:TCY]
  #Endif
  # Issue X3-42496 - 2017-06-15 by FGR : END
  If [F:CLL]CLLETS <> "" Then
    Call TEXTE(14402, SZTEXTE) From OBJDIV
    # Issue X3-42496 - 2017-06-15 by FGR : BEGIN
    #LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - format$([F:TCY]TELFMT,[F:CLL]CLLETS)
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:CLL]CLLCCNCRY, [F:CLL]CLLETS)
    # Issue X3-42496 - 2017-06-15 by FGR : END
  Endif
  If [F:CLL]CLLMOB <> "" Then
    Call TEXTE(9564, SZTEXTE) From OBJDIV
    # Issue X3-42496 - 2017-06-15 by FGR : BEGIN
    #LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - format$([F:TCY]TELFMT,[F:CLL]CLLMOB)
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:CLL]CLLCCNCRY, [F:CLL]CLLMOB)
    # Issue X3-42496 - 2017-06-15 by FGR : END
  Endif
  If [F:CLL]CLLEML <> "" Then
    Call TEXTE(1828, SZTEXTE) From OBJDIV
    LBCLOBENTETE += chr$(13) + chr$(10) + "        " + SZTEXTE - ":" - [F:CLL]CLLEML
  Endif
  # ------------------------
  If LBCLOBENTETE <> "" Then
    Call ADDBALISEBAP(LBCLOBENTETE) From SUBSYDUTIL
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (fin)
  #Description
  TBKCLOB(ICLOB) = "Subject"
  If IBVIDE = MC_FALSE Then
    If [F:CLL]NUMFULOBJ <> "" and [F:CLL]TYPFULOBJ <> "" Then
      Read [HD5]HD50=[F:CLL]NUMFULOBJ;[F:CLL]TYPFULOBJ
      If fstat = 0 Then
        TBVCLOB(ICLOB) = [F:HD5]CLOB
      Endif
    Endif
  Endif
  ICLOB += 1
  #Compte rendu
  TBKCLOB(ICLOB) = "Body"
  # FGR 15/01/2013 : X3SUIVI87223 (début)
  If LBCLOBENTETE <> "" Then
    TBVCLOB(ICLOB) = LBCLOBENTETE
  Endif
  # FGR 15/01/2013 : X3SUIVI87223 (fin)
  If IBVIDE = MC_FALSE Then
    If [F:CLL]NUMFULRPO <> "" and [F:CLL]TYPFULRPO <> "" Then
      Read [HD4]HD40=[F:CLL]NUMFULRPO;[F:CLL]TYPFULRPO
      If fstat = 0 Then
        # FGR 15/01/2013 : X3SUIVI87223 (début)
        #TBVCLOB(ICLOB) = [F:HD4]CLOB
        If LBCLOBENTETE <> "" Then
          TBVCLOB(ICLOB) += chr$(13) + chr$(10) + chr$(13) + chr$(10) + [F:HD4]CLOB
        Else
          TBVCLOB(ICLOB) = [F:HD4]CLOB
        Endif
        # FGR 15/01/2013 : X3SUIVI87223 (fin)
      Endif
    Endif
  Endif
  ICLOB += 1
Return

##########################################################################################################
# Confirmation Get
# ------------------------------------------------------------
Subprog CLL_GET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, CALLID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char CALLID()               # ID permettant de retrouver la appel

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Char SZCLLNUM(GLONCLL)
Local Char SZOBJET(GLONAOB)
Local Integer INBMES
Local Integer IBERROR
Local Char SZRET(GLONDES)

  Raz SZCLLNUM
  Raz SZOBJET
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données Adonix" CALLID = "  + CALLID + " " Status +" : " + RET
  Call ECR_TRACE((mess(261,177,1) - "CALLID =" - CALLID + "  " + mess(259,123,1) - ":" - RET), 0) From GESECRAN
  IBERROR = MC_FALSE
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  Local File SYNCDATA [SYD]
  Call DECOD_OTKID(CALLID, "CLL", SZCLLNUM, SZOBJET) From SUBSYDUTIL
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If SZRET = MC_OK Then
    #Tout s'est bien passé, on supprime les enregistrements de SYNCDATA
    Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
    If fstat <> 0 Then
      IBERROR = MC_TRUE
      #Problème car incohérence entre TASK ET SYNCDATA
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de la suppression des données de synchronisation pour l'appel+" : "+SZCLLNUM
      MSGTXT(INBMES) = mess(363,177,1) - ":" - SZCLLNUM
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
    Endif
  Else
    #Problème on met à jour le flag
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = SZCLLNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour l'appel+" : "+SZCLLNUM
          MSGTXT(INBMES) = mess(356,177,1) - ":" - SZCLLNUM
          Call ECR_TRACE(SGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour l'appel+" : "+SZCLLNUM
        MSGTXT(INBMES) = mess(357,177,1) - ":" - SZCLLNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
  Endif
  If IBERROR = MC_FALSE Then
    Commit
    RET = MC_OK
  Else
    Rollback
    RET = MC_KO_NEXT
  Endif
End

