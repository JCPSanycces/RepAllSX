#<AdxTL>@(#)0.0.0.0 $Revision$
# Class GSTPERD
######################################################################################
# Handling class GSTPERD : GST reporting periods (for Australian GST reporting)
#
# Caution, programming model is hybrid.
#
# Author : ???
#
# 2018-01-08  DNE   GSTMEMSTA iniatilized with 1 (Status "Temporary")
# 2018-02-09  Bader Add events AINSERT_CONTROL_BEFORE and AUPDATE_CONTROL_BEFORE
# 2018-03-07  Bader use message texts from local menu 7704 in CONTROL_BEFORE
######################################################################################



#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE" : Gosub CONTROL_BEFORE  # Before insert and before field controls
      When "AUPDATE_CONTROL_BEFORE" : Gosub CONTROL_BEFORE  # Before update and before field controls
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
       When "GSTMEMSTA"
           Case [L]ARULE
              When "INIT"  : this.GSTMEMSTA = 1 # Status "Temporary"
           Endcase
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



$CONTROL_BEFORE
# Dependencies between fringe benfit fields per company:
# if F2/F3 filled > F1 and F4 need to be filled as well
# if F2 filled > F3 needs to be filled as well
# if F4 filled > F3/F4 need to be filled as well
If this.GSTADDF02 <> 0.0
    If this.GSTADDF01 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F1", [V]CST_AERROR)
    Endif
    If this.GSTADDF03 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F3", [V]CST_AERROR)
    Endif
    If this.GSTADDF04 = ""
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F4", [V]CST_AERROR)
    Endif
Endif
If this.GSTADDF03 <> 0.0
    If this.GSTADDF02 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F2", [V]CST_AERROR)
    Endif
    If this.GSTADDF04 = ""
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F4", [V]CST_AERROR)
    Endif
Endif
If this.GSTADDF04 <> ""
    If this.GSTADDF02 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F2", [V]CST_AERROR)
    Endif
    If this.GSTADDF03 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"FBT F3", [V]CST_AERROR)
    Endif
Endif

# PAYG W.. fields: If W1 entered, then W2 is mandatory and vice versa
If this.GSTADDW01 <> 0.0 and this.GSTADDW02 = 0.0
    ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"PAYG W2", [V]CST_AERROR)
Endif
If this.GSTADDW02 <> 0.0 and this.GSTADDW01 = 0.0
    ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"PAYG W1", [V]CST_AERROR)
Endif

# PAYG T.. fields:
# T1/T7: one of them has to be filled (excluding each other)
If this.GSTADDT01 = 0.0 and this.GSTADDT07 = 0.0
    # exception: all T.. fields may be empty
    If this.GSTADDT02 <> 0.0 or this.GSTADDT03 <> 0.0 or this.GSTADDT04 <> "" or this.GSTADDT08 <> 0.0 or this.GSTADDT09 <> 0.0
        ASTATUS = fmet this.ASETERROR("", func AFNC.MES2(mess(48,7704,1), "PAYG T1", "PAYG T7"), [V]CST_AERROR)
    Endif
Endif
# If T7 filled > T8/T9: if one of these fields is filled, all other fields are mandatory
If this.GSTADDT07 <> 0.0
    If this.GSTADDT08 <> 0.0 and this.GSTADDT09 = 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"PAYG T9", [V]CST_AERROR)
    Elsif this.GSTADDT08 = 0.0 and this.GSTADDT09 <> 0.0
        ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"PAYG T8", [V]CST_AERROR)
    Endif
Endif
# If T1 filled > T2 or T3 has to be filled (excluding each other)
If this.GSTADDT01 <> 0.0 and this.GSTADDT02 = 0.0 and this.GSTADDT03 = 0.0
    ASTATUS = fmet this.ASETERROR("", func AFNC.MES2(mess(48,7704,1), "PAYG T2", "PAYG T3"), [V]CST_AERROR)
Endif
If this.GSTADDT01 <> 0.0 and this.GSTADDT02 <> 0.0 and this.GSTADDT03 <> 0.0
    ASTATUS = fmet this.ASETERROR("", func AFNC.MES2(mess(49,7704,1), "PAYG T2", "PAYG T3"), [V]CST_AERROR)
Endif
# If T3 or T9 filled > T4 has to be filled
If (this.GSTADDT03 <> 0.0 or this.GSTADDT09 <> 0.0) and this.GSTADDT04 = ""
    ASTATUS = fmet this.ASETERROR("", mess(10,123,1)-"PAYG T4", [V]CST_AERROR)
Endif
# If T4 filled > T3 or T9 has to be filled
If this.GSTADDT04 <> "" and this.GSTADDT03 = 0.0 and this.GSTADDT09 = 0.0
    ASTATUS = fmet this.ASETERROR("", func AFNC.MES2(mess(48,7704,1), "PAYG T3", "PAYG T9"), [V]CST_AERROR)
Endif
Return

