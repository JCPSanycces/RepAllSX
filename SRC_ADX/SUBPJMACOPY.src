######################################################################################
# ACTION - PJMACTAFCP
######################################################################################
$ACTION
  Case ACTION
    When Default
  Endcase
Return

######################################################################################
# Screens fields
######################################################################################
# PJMACOPY0
######################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  Call INIT_ENVIRONMENT(VALEUR) From PJMACTACOPY
End

######################################################################################
Subprog AM_CRMFLG(VALEUR)
Variable Integer VALEUR

  Call MANAGE_CRMFLG (VALEUR) From PJMACTACOPY
End

######################################################################################
Subprog AP_DESTAFF(VALEUR)
Variable Char VALEUR

  If VALEUR = [M:PJMAC0]OPPNUM Then
    GMESSAGE = mess(170,2260,1)
    mkstat = 2
  Endif
End

######################################################################################
Subprog AV_CRMOPP(VALEUR)
Variable Char    VALEUR()

Global Char GPIMLSTFCY(GLONCPY)

  GPIMLSTFCY = [M:PJMAC0]SALFCY
End

######################################################################################
Subprog AP_CRMOPP(VALEUR)
Variable Char    VALEUR()

  If dim(GPIMLSTFCY) > 0 Then
    Kill GPIMLSTFCY
  Endif
End

######################################################################################
# PJMACOPY0A
######################################################################################
Subprog AM_TSALFCY(VALEUR)
Variable Char    VALEUR()
Local Char TCPY(GLONCPY)

  If VALEUR <> AVOID.ACHAR Then
    [M:PJMAC0A]TOPEDEFFCY = VALEUR                                                       # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    TCPY = fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY")
    [M:PJMAC0A]TCUR = fmet GZTECPJMCOP.ACTX.ACACHE.ACPY.AGETVALCHAR(TCPY, "ACCCUR")      # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Call GET_CUR_CHANGE([M:PJMAC0A]TCUR) From PJMACTACOPY                                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    # Change all budget sites to sales site
    For NI = 1 To [M:PJMAC1]NBLIGB
      [M:PJMAC1]PBUFCY(NI-1) = VALEUR
    Next NI
    # Change all task sites to sales site
    For NI = 1 To [M:PJMAC2]NBLIGT
      [M:PJMAC2]TASFCY(NI-1) = VALEUR
    Next NI
    Affzo [M:PJMAC0]1-99
    Affzo [M:PJMAC0A]1-99                                                                # Issue X3-99916 - 2018-07-16 by FGR
    Affzo [M:PJMAC1]1-99
    Affzo [M:PJMAC2]1-99
  Endif
End

######################################################################################
Subprog C_TOPEDEFFCY(VALEUR)
Variable Char    VALEUR()

  If fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJMAC0A]TSALFCY, "LEGCPY") <> fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY") Then
    # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    GMESSAGE = func AFNC.MES1(mess(116,2260,1), [M:PJMAC0]SALFCY)
    GERR = 1
    OK = 0
    mkstat = 2
    End
  Endif
End

######################################################################################
Subprog AM_TCUR(VALEUR)
Variable Char VALEUR()

  If VALEUR <> AVOID.ACHAR Then
    Call GET_CUR_CHANGE(VALEUR) From PJMACTACOPY
  Endif
End

######################################################################################
Subprog AP_TACDAT(VALEUR)
Variable Integer VALEUR()

  If VALEUR = [V]CST_AYES Then
    [M:PJMAC0A]TASPRDAT  = [V]CST_AYES # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TACDUEDAT = [V]CST_AYES # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TASOPDAT  = [V]CST_AYES # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TASASSDAT = [V]CST_AYES # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  Else
    [M:PJMAC0A]TASPRDAT  = [V]CST_ANO  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TACDUEDAT = [V]CST_ANO  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TASOPDAT  = [V]CST_ANO  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
    [M:PJMAC0A]TASASSDAT = [V]CST_ANO  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  Endif
  Affzo [M:PJMAC0A]1-99                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
End

######################################################################################
Subprog AP_TASOPDAT(VALEUR)
Variable Integer VALEUR()

  If VALEUR = [V]CST_AYES Then
    [M:PJMAC0A]TASASSDAT = [V]CST_AYES # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  Else
    [M:PJMAC0A]TASASSDAT = [V]CST_ANO  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  Endif
  Affzo [M:PJMAC0A]TASASSDAT           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
End

######################################################################################
Subprog AM_TACALL(VALEUR)
Variable Integer VALEUR

Local Integer NI
Local Char CALLEDFROM(6)
Local Char BUDCODE(type([M:PJMAC2]TASPBU)-10)

  CALLEDFROM = "SELTAC"
  For NI = 0 To [M:PJMAC2]NBLIGT-1
    [M:PJMAC2]SELTAC(NI) = VALEUR
  Next NI
  If VALEUR = 2 Then
    For NI = [M:PJMAC2]NBLIGT-1 To 0 Step-1
      BUDCODE = [M:PJMAC2]TASPBU(NI)
      If BUDCODE <> AVOID.ACHAR Then
        Gosub UPDATE_BUDSEL
      Endif
    Next NI
  Endif
  Affzo [M:PJMAC2]SELTAC
  Affzo [M:PJMAC1]SELBUD
  # Issue X3-99916 - 2018-07-16 by FGR : BEGIN
  If VALEUR = [V]CST_AYES Then
    [M:PJMAC0A]TASOPL = [V]CST_AYES
    [M:PJMAC0A]TASPRL = [V]CST_AYES
    [M:PJMAC0A]TASASSL = [V]CST_ANO
  Else
    [M:PJMAC0A]TASOPL = [V]CST_ANO
    [M:PJMAC0A]TASPRL = [V]CST_ANO
    [M:PJMAC0A]TASASSL = [V]CST_ANO
  Endif
  Affzo [M:PJMAC0A]15
  # Issue X3-99916 - 2018-07-16 by FGR : END
End

######################################################################################
Subprog AM_BUDALL(VALEUR)
Variable Integer VALEUR

Local Integer NI
Local Integer NIT
Local Char CALLEDFROM(6)

  For NI = 0 To [M:PJMAC1]NBLIGB-1
    If [M:PJMAC0A]BUDALL = [V]CST_AYES Then      # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
      [M:PJMAC1]SELBUD(NI) = [V]CST_ANO
      CALLEDFROM = "SELBUD"
      Gosub DESELECT_CHILD_TASK_FROM_BUD
    Else
      [M:PJMAC1]SELBUD(NI) = [V]CST_AYES
    Endif
  Next NI
  Affzo [M:PJMAC1]SELBUD
  Affzo [M:PJMAC2]SELTAC
  # Issue X3-99916 - 2018-07-16 by FGR : BEGIN
  If VALEUR = [V]CST_AYES Then
    [M:PJMAC0A]BLIGNES = [V]CST_AYES
  Else
    [M:PJMAC0A]BLIGNES = [V]CST_ANO
  Endif
  Affzo [M:PJMAC0A]20
  # Issue X3-99916 - 2018-07-16 by FGR : END
End

######################################################################################
# PJMACOPY1 (Budgets)
######################################################################################
# 1) if child is selected, then must auto select all parent levels up the tree
# 2) if budget is de-selected, then must look down the tree and deselect all levels down,
#    and if on task must, must de-select all related tasks
######################################################################################
Subprog AP_SELBUD(VALEUR)
Variable Integer VALEUR

Local Char CALLEDFROM(6)

  CALLEDFROM = "SELBUD"
  [M:PJMAC1]SELBUD(nolign-1) = VALEUR
  If VALEUR = [V]CST_AYES
    Gosub SELECT_PARENT_BUDGET
  Else
    Gosub DESELECT_CHILD_BUDGET
    Gosub DESELECT_CHILD_TASK_FROM_BUD
  Endif
  Affzo [M:PJMAC1]SELBUD
  Affzo [M:PJMAC2]SELTAC
End

######################################################################################
Subprog AP_DESTCOD(VALEUR)
Variable Char VALEUR

Local Integer NI

  For NI = 1 To [M:PJMAC1]NBLIGB
    If NI <> nolign Then
      If VALEUR = [M:PJMAC1]DESTCOD(NI-1) Then
        GMESSAGE = mess(172,2260,1)
        GERR     = 1
        mkstat   = 2
        Break
      Endif
    Endif
  Next NI
End

######################################################################################
Subprog C_PBUFCY(VALEUR)
Variable Char VALEUR()

  If fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJMAC0A]TSALFCY, "LEGCPY") <> fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY") Then
    # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    GMESSAGE = func AFNC.MES1(mess(116,2260,1), [M:PJMAC0A]TSALFCY)  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    GERR = 1
    OK = 0
    mkstat = 2
    End
  Endif
End

######################################################################################
# PJMACOPY2 (Tasks)
######################################################################################
Subprog AP_SELTAC(VALEUR)
Variable Integer VALEUR

Local Char CALLEDFROM(6)
Local Char BUDCODE(type([M:PJMAC2]TASPBU)-10)

  CALLEDFROM = "SELTAC"
  [M:PJMAC2]SELTAC(nolign-1) = VALEUR
  If VALEUR = [V]CST_AYES Then
    BUDCODE = [M:PJMAC2]TASPBU(nolign-1)
    If BUDCODE <> AVOID.ACHAR Then
      Gosub UPDATE_BUDSEL
    Endif
    Gosub SELECT_PARENT_TASK
  Else
    Gosub DESELECT_CHILD_TASK
  Endif
  Affzo [M:PJMAC1]SELBUD
  Affzo [M:PJMAC2]SELTAC
End

######################################################################################
Subprog AP_TASNCOD(VALEUR)
Variable Char VALEUR

Local Integer NI

  For NI = 1 To [M:PJMAC2]NBLIGT
    If NI <> nolign Then
      If VALEUR = [M:PJMAC2]TASNCOD(NI-1) Then
        GMESSAGE = mess(171,2260,1)
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next NI
End

######################################################################################
Subprog C_TASFCY(VALEUR)
Variable Char VALEUR()

  If fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJMAC0A]TSALFCY, "LEGCPY") <> fmet GZTECPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY") Then
    # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    GMESSAGE = func AFNC.MES1(mess(116,2260,1), [M:PJMAC0A]TSALFCY)  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    GERR = 1
    OK = 0
    mkstat = 2
    End
  Endif
End

######################################################################################
# PJMACOPY3 (Additinal selection criteria)
######################################################################################
Subprog CL_BTNTAC(VALEUR)
Variable Char VALEUR()

Local Integer NI
Local Char SMESSAGE(250)

  # Apply prefix and/or suffix to the new task code(s)
  Raz SMESSAGE
  For NI = 0 To [M:PJMAC2]NBLIGT-1
    If [M:PJMAC2]SELTAC(NI) = [V]CST_AYES Then
      If len([M:PJMAC3]TPREFIX + [M:PJMAC2]TASNCOD(NI) + [M:PJMAC3]TSUFFIX) <= GLONTAC Then
        [M:PJMAC2]TASNCOD(NI) = [M:PJMAC3]TPREFIX + [M:PJMAC2]TASCOD(NI) + [M:PJMAC3]TSUFFIX
      Else
        If SMESSAGE <> AVOID.ACHAR Then
          SMESSAGE += ","
        Endif
        SMESSAGE -= [M:PJMAC2]TASNCOD(NI)
      Endif
    Endif
  Next NI
  Affzo [M:PJMAC2]1-99
  If SMESSAGE <> AVOID.ACHAR Then
    GMESSAGE = func AFNC.MES1(mess(962,2260,1), SMESSAGE)
    GERR = 2
  Endif
End

######################################################################################
Subprog CL_BTNPBU(VALEUR)
Variable Char VALEUR()

Local Integer NI
Local Char SMESSAGE(250)

  # Apply prefix and/or suffix to the new budget code(s)
  For NI = 0 To [M:PJMAC1]NBLIGB-1
    If [M:PJMAC1]SELBUD(NI) = [V]CST_AYES Then
      If len([M:PJMAC3]PBPREFIX + [M:PJMAC1]DESTCOD(NI) + [M:PJMAC3]PBSUFFIX) <= GLONPBU Then
        [M:PJMAC1]DESTCOD(NI) = [M:PJMAC3]PBPREFIX + [M:PJMAC1]PBUCOD(NI) + [M:PJMAC3]PBSUFFIX
      Else
        If SMESSAGE <> AVOID.ACHAR Then
          SMESSAGE += ","
        Endif
        SMESSAGE -= [M:PJMAC1]PBUCOD(NI)
      Endif
    Endif
  Next NI
  Affzo [M:PJMAC1]1-99
  If SMESSAGE <> AVOID.ACHAR Then
    GMESSAGE = func AFNC.MES1(mess(963,2260,1), SMESSAGE)
    GERR = 2
  Endif
End

######################################################################################
# SUBROUTINES
######################################################################################
$SELECT_PARENT_BUDGET
Local Integer CURR_NOLIGN
Local Char PARENT_BUCOD(GLONPBU)
Local Integer PBI

  CURR_NOLIGN = nolign-1
  If CALLEDFROM = "SELTAC"
    CURR_NOLIGN = BI2
  Endif
  PARENT_BUCOD = [M:PJMAC1]PBUPAE(CURR_NOLIGN)
  While PARENT_BUCOD <> AVOID.ACHAR
    For PBI = 0 To [M:PJMAC1]NBLIGB-1
      If PARENT_BUCOD = [M:PJMAC1]PBUCOD(PBI) Then
        [M:PJMAC1]SELBUD(PBI) = [V]CST_AYES
        PARENT_BUCOD = [M:PJMAC1]PBUPAE(PBI)
      Endif
    Next
  Wend
Return

######################################################################################
$SELECT_PARENT_TASK
Local Integer CURR_NOLIGN
Local Char PARENT_TASCOD(GLONTAC)
Local Integer PSI

  CURR_NOLIGN = nolign-1
  PARENT_TASCOD = [M:PJMAC2]TASPAE(CURR_NOLIGN)
  While PARENT_TASCOD <> AVOID.ACHAR
    For PSI = 0 To [M:PJMAC2]NBLIGT-1
      If PARENT_TASCOD = [M:PJMAC2]TASCOD(PSI) Then
        [M:PJMAC2]SELTAC(PSI) = [V]CST_AYES
        PARENT_TASCOD = [M:PJMAC2]TASPAE(PSI)
        BUDCODE = [M:PJMAC2]TASPBU(PSI)
        If BUDCODE <> AVOID.ACHAR Then
          Gosub UPDATE_BUDSEL
        Endif
      Endif
    Next
  Wend
Return

######################################################################################
$UPDATE_BUDSEL
Local Integer BI
Local Integer SPTI
Local Integer BI2

  For BI = [M:PJMAC1]NBLIGB-1 To 0 Step -1
    If BUDCODE = [M:PJMAC1]PBUCOD(BI) Then
      [M:PJMAC1]SELBUD(BI) = VALEUR
      BI2 = BI
      For SPTI = BI2 To 0 Step -1
        Gosub SELECT_PARENT_BUDGET
      Next SPTI
    Endif
  Next BI
Return

######################################################################################
$DESELECT_CHILD_BUDGET
Local Integer CURR_NOLIGN
Local Integer CURR_NOLIGN2
Local Char TREE_STACK_BUD(20)(1..)      # array contain all branches of tree
Local Integer STACK_BUD_POS             # position on tree_stack that we are dealing with
Local Integer NEXT_STACK_BUD_POS        # next position on the tree stack
Local Integer SBCI                      # counter
Local Integer FND_ON_STACK              # make sure value not already added to stack

  CURR_NOLIGN = nolign-1
  CURR_NOLIGN2 = CURR_NOLIGN-1
  STACK_BUD_POS      = 1
  NEXT_STACK_BUD_POS = 1
  [M:PJMAC1]SELBUD(CURR_NOLIGN) = [V]CST_ANO
  TREE_STACK_BUD(STACK_BUD_POS) = [M:PJMAC1]PBUCOD(CURR_NOLIGN)
  While TREE_STACK_BUD(STACK_BUD_POS) <> AVOID.ACHAR
    For SBCI = 0 To [M:PJMAC1]NBLIGB-1
      If [M:PJMAC1]PBUPAE(SBCI) = TREE_STACK_BUD(STACK_BUD_POS) Then
        [M:PJMAC1]SELBUD(SBCI) = [V]CST_ANO
        FND_ON_STACK = find([M:PJMAC1]PBUCOD(SBCI),TREE_STACK_BUD(1..))
        If FND_ON_STACK = 0 Then
          NEXT_STACK_BUD_POS += 1
          TREE_STACK_BUD(NEXT_STACK_BUD_POS) = [M:PJMAC1]PBUCOD(SBCI)
        Endif
      Endif
    Next STCI
    STACK_BUD_POS += 1
  Wend
Return

######################################################################################
$DESELECT_CHILD_TASK
Local Integer CURR_NOLIGN
Local Integer CURR_NOLIGN2
Local Char TREE_STACK(20)(1..)      # array contain all branches of tree
Local Integer STACK_POS             # position on tree_stack that we are dealing with
Local Integer NEXT_STACK_POS        # next position on the tree stack
Local Integer STCI                  # counter
Local Integer FND_ON_STACK          # make sure value not already added to stack

  CURR_NOLIGN = nolign-1
  If CALLEDFROM = "SELBUD" Then
    CURR_NOLIGN = DCTI
  Endif
  CURR_NOLIGN2 = CURR_NOLIGN-1
  STACK_POS = 1
  NEXT_STACK_POS = 1
  [M:PJMAC2]SELTAC(CURR_NOLIGN) = [V]CST_ANO
  TREE_STACK(STACK_POS) = [M:PJMAC2]TASCOD(CURR_NOLIGN)
  While TREE_STACK(STACK_POS) <> AVOID.ACHAR
    For STCI = 0 To [M:PJMAC2]NBLIGT-1
      If [M:PJMAC2]TASPAE(STCI) = TREE_STACK(STACK_POS) Then
        [M:PJMAC2]SELTAC(STCI) = [V]CST_ANO
        FND_ON_STACK = find([M:PJMAC2]TASCOD(STCI),TREE_STACK(1..))
        If FND_ON_STACK = 0 Then
          NEXT_STACK_POS += 1
          TREE_STACK(NEXT_STACK_POS) = [M:PJMAC2]TASCOD(STCI)
        Endif
      Endif
    Next STCI
    STACK_POS += 1
  Wend
Return

######################################################################################
# Called when deselecting a budget code
# Need to make sure that all linked tasks codes and children are deselected
######################################################################################
$DESELECT_CHILD_TASK_FROM_BUD
Local Integer DCTI

  For DCTI = 0 To [M:PJMAC2]NBLIGT-1
    If [M:PJMAC2]SELTAC(DCTI) = [V]CST_AYES
      If [M:PJMAC2]TASPBU(DCTI) <> AVOID.ACHAR Then
        Local Integer FND_BUDLINE
        FND_BUDLINE = find([M:PJMAC2]TASPBU(DCTI),[M:PJMAC1]PBUCOD)
        If FND_BUDLINE > 0
          If [M:PJMAC1]SELBUD(FND_BUDLINE-1) = [V]CST_ANO
            Gosub DESELECT_CHILD_TASK
          Endif
        Endif
      Endif
    Endif
  Next DCTI
Return

