#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque CFGFUN
########################################
Subprog OLD_AS_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = GFCYDEF(0)
Endif
End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# Issue 93004 GA 10/2013 Site pré-fxé
If [F:CSC]SCENUM=[M:CFGF]SCENUM & [F:CSC]FCY<>""
  VALEUR = [F:CSC]FCY
  [M]FCY=VALEUR : Affzo [M]FCY
  mkstat=2 : End
Endif
End

########################################
Subprog AS_IPTDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
  VALEUR = date$
Endif
End
########################################
Subprog IB_SCENUM
Local Char W_PROINI(5)
Call PARAM([M]FCY,"CFGINI",W_PROINI) From ADOVAL
If W_PROINI = ""
  GBOUT2 = ""
Endif
End

########################################
# Issue 82989 GA 06/2012
Subprog AM_SCENUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  If VALEUR<>[F:CSC]SCENUM
     Read [CSC]CSC0=VALEUR
     If fstat Raz [F:CSC] Endif
  Endif
  [M]BOMALTREF = [F:CSC]BOMALTREF
  [M]BOMALT    = [F:CSC]BOMALT
  [M]ROUALTREF = [F:CSC]ROUALTREF
  [M]ROUALT    = [F:CSC]ROUALT
  If [F:CSC]FCY<>"" & [F:CSC]FCY<>[M]FCY
     # Issue 105345 GA 04/2015 only authorized site ...
     Call CFGCTRFCY([F:CSC]FCY) From CFGLIB
     If mkstat : End
     Else
        [M]FCY = [F:CSC]FCY
  Endif
  Endif
  Affzo [M:CFGF]
Endif
End

########################################
# Issue 82989 GA 06/2012
Subprog AM_BOMALTREF(VALEUR)
Variable Decimal    VALEUR()
If VALEUR>0
   Gosub CTL_TBO
Endif
End

########################################
# Issue 82989 GA 06/2012
Subprog AM_BOMALT(VALEUR)
Variable Decimal    VALEUR()
If VALEUR>0
   Gosub CTL_TBO
Endif
End

$CTL_TBO
Local Integer WBOMALT : WBOMALT=VALEUR
If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
Read [TBO]TBO0=[F:CSC]BOMALTTYP;WBOMALT
If fstat | ([F:TBO]FCY<>"" & [F:TBO]FCY<>[M]FCY)
   mkstat = 2
Endif
Return

########################################
# Issue 82989 GA 06/2012
Subprog AM_ROUALTREF(VALEUR)
Variable Decimal    VALEUR()
If VALEUR>0
   Gosub CTL_TRO
Endif
End

########################################
# Issue 82989 GA 06/2012
Subprog AM_ROUALT(VALEUR)
Variable Decimal    VALEUR()
If VALEUR>0
   Gosub CTL_TRO
Endif
End

$CTL_TRO
Local Integer WROUALT : WROUALT=VALEUR
If clalev([F:TRO])=0 : Local File TABROUALT [TRO] : Endif
# Issue 89355 GA 05/2013 Read [TRO]TRO1=[M]FCY;WROUALT
Read [TRO]TRO0=WROUALT
If fstat | ([F:TRO]FCY<>"" & [F:TRO]FCY<>[M]FCY)
   mkstat = 2
Endif
Return
