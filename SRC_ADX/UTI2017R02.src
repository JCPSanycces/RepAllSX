#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTI2017R02 UTI process for 2017R2 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017R2 - passage de R1 vers R2
#
#      correction utility to be done at the end of the patch - move from R1 to R2
#
##########################################################################
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2017R02 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  #Infbox "only update folder by patch"
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R02 (APPLI)

End

###################################################
Subprog EXE_UTI2017R02(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R02-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

  Call PATCH  (LDOSSIER) From UTICPT91
#  Call PATCH  (LDOSSIER) From UTIXXX

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM012             # Issue X3-18442/120906 - 2017-01-13 by FGR
    Call PATCH(LDOSSIER) From UTIPJM013             # Issue X3-18442/120906 - 2017-01-13 by FGR
    Call PATCH(LDOSSIER) From UTIPJM014             # Issue X3-17872/121095 - 2017-01-24 by SINGC
    Call PATCH(LDOSSIER) From UTIPJM015             # Issue X3-27075/121759 - 2017-02-28 by FGR
    Call PATCH(LDOSSIER) From UTIPJM016             # Issue X3-28419/122095 - 2017-03-21 by FGR
    If LDOSSIER = GDOSX3 and GADONIX = 2 Then       # Issue X3-47712 - 2017-07-06 by FGR
      Call PATCH(LDOSSIER) From UTIPJM018           # Issue X3-33100 - 2017-04-12 by FGR : Sage internal usage only.
    Endif
    Call PATCH(LDOSSIER) From UTIPJM019             # Issue X3-34418 - 2017-05-02 by FGR
    Call PATCH(LDOSSIER) From UTIPJM020             # Issue X3-35865 - 2017-05-04 by FGR
  Endif

  If [F:ADS]MODULE(6) = 2 Then
    Call PATCH(LDOSSIER) From SUBMDL                # Issue 121293 - 13/04/2017 by GH : Assignment workbench regeneration
  Endif

Call ECR_TRACE("END : UTI2017R02-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R02
End

