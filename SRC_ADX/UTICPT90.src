#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT90   UTI process                                    FIN Module
#            Migration To U12 - Vnext version
#
# *YYFIN-X3-30158 : Migration of default dimensions (MDJ)
# ==>  Move of the value "None" from 26 to 34 in the local menu 693
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Common Data Module
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update CACCEDEF (update value = 'None' in default dimensions)") From LECFIC

  Call MAJ_UTICPT90(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT90(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT90 : Start of process on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","CACCEDEF","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"CACCEDEF")<>0 : End : Endif

If clalev([F:CDE])=0  Local File =DOSSIER+".CACCEDEF"   [CDE] : Endif

 Local Integer STOP, NB
 Local Char CRITERE(250)
 Local Char ACLE1(30), ACLE2(30)
 Local Integer WCOUNT

 Gosub SET_FIRST From TRTFIRST
 Raz STOP
 $LOOP_CDE
 Raz NB
 Raz WCOUNT
 If STOP = 1
  STOP = 2
  CRITERE = "[F:CDE]COD='"+ACLE1+"' & [F:CDE]CPY>'"+ACLE2+"'"
 Elsif STOP = 2
  STOP = 0
  CRITERE = "[F:CDE]COD>'"+ACLE1+"'"
 Else
  CRITERE = "1=1"
 Endif

Call DEBTRANS From GLOCK
Trbegin [CDE]
 GOK = 1

 For [CDE]CDE0 Where evalue(CRITERE)
  For AXE=1 To 20
    For IND=0 To dim([F:CDE]CCE1)-1
     If evalue("[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")") = 26
      Assign "[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")" With 34
     Endif
    Next
  Next
  Rewrite [CDE]
  If fstat
   Call ECR_TRACE("UTICPT90 : File CACCEDEF, ERROR while update "-[F:CDE]COD-" = "-num$(fstat),1) From GESECRAN
   GOK = 0
  Else
    WCOUNT+=1
  Endif
  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:CDE]COD
   ACLE2 = [F:CDE]CPY
   STOP=1
   Break
  Endif
 Next

If GOK<1
  Rollback
Else
  Commit
Endif

Close Local File [CDE]

Call ECR_TRACE("UTICPT90 / CACCEDEF : " + num$(WCOUNT) + " [CDE] records processed", 0) From GESECRAN
Call ECR_TRACE("UTICPT90 : End of process on : "+DOSSIER,0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT90(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif
Call MAJ_UTICPT90(APPLI)
End

