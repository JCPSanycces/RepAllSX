#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "DEBUT"       : Gosub DEBUT
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "ABA"         : Gosub ABANDON
    When "ENR"         : Gosub ENREGISTRER
    When "SETBOUT"     : Gosub SETBOUT
    When "BOUTON"      : Gosub BOUTON  #MZOUH
    When "FIN"         : Gosub FIN
  Endcase

Return

#=================================================================================
#-----<Début>-MZOUH
$BOUTON
  Case BOUT
      When "x":  Gosub XIMPRIME
  Endcase

Return

#=================================================================================
$XIMPRIME
  If clalev([F:EMPDLC])=0 : Local File HREMPDLC  [EMPDLC] : Endif

Local Integer NBPAR : NBPAR = 3
Local Char TBPAR(20)(1..50),TBVAL(20)(1..50),XRPTNAM
Local Char XSOC

  If [M:HRSDM0]MDLDCL ="" Then
    Local Char    PARMSK(250)(1..20) , SAVACT(20),XX

    SAVACT = GACTION : GACTION = "XGSELRPT"
    PARMSK(1) = ""
    PARMSK(2) = ""
    Call S_TAB_CHAR(XX,PARMSK,"XGSELRPT","XGSELRPT","") From GACTION

    GACTION = SAVACT

  Elsif [M:HRSDM0]MDLDCL ="CIMR"
    For [EMPDLC] Where MDLDCL=[M:HRSDM0]MDLDCL
      XSOC = [EMPDLC]CPY : Break
    Next

    If XSOC = "" Then XSOC=GDEFSOC  : Endif

    TBPAR(1)="societe"
    TBVAL(1)=XSOC
    TBPAR(2)="datedeb"
    TBVAL(2)=[M:HRSDM0]STRDAT
    TBPAR(3)="datefin"
    TBVAL(3)=[M:HRSDM0]ENDDAT
    Call ETAT("XMA","1",TBPAR(1..NBPAR),TBVAL(1..NBPAR)) From ETAT

  Elsif [M:HRSDM0]MDLDCL ="9421"
    For [EMPDLC] Where MDLDCL=[M:HRSDM0]MDLDCL
      XSOC = [EMPDLC]CPY : Break
    Next
    If XSOC = "" Then XSOC=GDEFSOC  : Endif

    TBPAR(1)="societe"
    TBVAL(1)=XSOC
    TBPAR(2)="datedeb"
    TBVAL(2)=[M:HRSDM0]STRDAT
    TBPAR(3)="datefin"
    TBVAL(3)=[M:HRSDM0]ENDDAT
    Call ETAT("XMB","1",TBPAR(1..NBPAR),TBVAL(1..NBPAR)) From ETAT

  Endif

Return

#-----<FIN>-MZOUH
#=================================================================================
$DEBUT
Local Integer I, J, OK, K
Local Char   SYMBOLE(30), PCOD(GLONRUB)

  If clalev([F:HRSDS])  = 0  : Local File  HRSTADCLSET   [HRSDS]  : Endif
#JASMI - 2016-11-11 - X3PEOP-2602 - START
#  If clalev([F:HREDC2])  = 0 : Local File  HREMPDLC      [HREDC2] : Endif
  If clalev([F:ID7])  = 0    : Local File  EMPLOID       [ID7]    : Endif
#JASMI - 2016-11-11 - X3PEOP-2602 - END
  If clalev([F:HRIDC1])  = 0 : Local File  HRINCDLC      [HRIDC1] : Endif   #EELKA
  If clalev([F:HRSDT1])  = 0 : Local File  HRSTADCLTRA   [HRSDT1] : Endif   #EELKA
  If clalev([F:HRSDB1])  = 0 : Local File  HRSTADCLBEN   [HRSDB1] : Endif   #EELKA
  If clalev([F:HRLOP1])  = 0 : Local File  HRLSTPMT      [HRLOP1] : Endif   #EELKA
  If clalev([F:HRTPY1])  = 0 : Local File  HRTOTPAY      [HRTPY1] : Endif   #EELKA
  If clalev([F:HREFT1])  = 0 : Local File  HREFFTOT      [HREFT1] : Endif   #EELKA
  If clalev([F:HRSBP1])  = 0 : Local File  HRSTADCLBSP   [HRSBP1]  : Endif   #EELKA
#JASMI - 2016-11-14 - X3PEOP-2602 - START
#  If clalev([F:HRIDC2])  = 0 : Local File  HRINCDLC      [HRIDC2] : Endif   #EELKA
#JASMI - 2016-11-14 - X3PEOP-2602 - END
  If clalev([F:HREDC1])  = 0 : Local File  HREMPDLC      [HREDC1] : Endif

  Effzo[M:HRSDM1]: Effzo[M:HRSDM0] : Effzo[M:HRSDM2] : Effzo[M:HRSDM4]: Effzo[M:HRSDM3]: Effzo[M:HRSDM6] : Effzo[M:HRSDM7] : Effzo[M:HRSDM5]

  [M:HRSDM0]STRDAT= gdat$(1,1,year(gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))))

##[M:HRSDM0]ENDDAT= gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Local Date XDATE2  #EELKA

  If [M:HRSDM0]MDLDCL="CIMR" Then #EELKA
    XDATE2=gdat$(1,month([M:HRSDM0]STRDAT)+2,year([M:HRSDM0]STRDAT)) #EELKA
    [M:HRSDM0]ENDDAT=eomonth(XDATE2)  #EELKA
  Elsif [M:HRSDM0]MDLDCL="9421" Then
    [M:HRSDM0]ENDDAT=gdat$(31,12,year([M:HRSDM0]STRDAT)) #EELKA
  Endif

  Actzo [M:HRSDM0]STRDAT,ENDDAT
  Affzo [M:HRSDM1]: Affzo [M:HRSDM0]: Affzo [M:HRSDM2] : Affzo [M:HRSDM4] : Affzo [M:HRSDM3] : Affzo [M:HRSDM6] : Affzo[M:HRSDM5]

Return

#=================================================================================
$APRES_MODIF
  Case COUZON
    When "CPY" #JASMI - 2016-11-14 - X3PEOP-2602 - START
      If [M:HRSDM0]MDLDCL<>"" & [M:HRSDM0]STRDAT<>[0/0/0] & [M:HRSDM0]ENDDAT<>[0/0/0]
        [M:HRSDM0]CPY=CZ
        Gosub CHARGE
      Endif #JASMI - 2016-11-14 - X3PEOP-2602 - END
    When "MDLDCL"
      If [M:HRSDM0]STRDAT<>[0/0/0] & [M:HRSDM0]ENDDAT<>[0/0/0]
        [M:HRSDM0]MDLDCL=CZ            #EELKA
        Gosub CHARGE
      Endif
    When "REFNUM"
      If [M:HRSDM0]MDLDCL<>"" & [M:HRSDM0]STRDAT<>[0/0/0] & [M:HRSDM0]ENDDAT<>[0/0/0]
        [M:HRSDM0]REFNUM=CZ            #EELKA
        Gosub CHARGE
      Endif
    When "STRDAT"
      If [M:HRSDM0]MDLDCL<>"" &  [M:HRSDM0]ENDDAT<>[0/0/0]
        [M:HRSDM0]STRDAT=CZ            #EELKA
        Gosub CHARGE
      Endif
    When "ENDDAT"
      If [M:HRSDM0]MDLDCL<>"" & [M:HRSDM0]STRDAT<>[0/0/0]
        [M:HRSDM0]ENDDAT=CZ            #EELKA
        Gosub CHARGE
      Endif
    When "NBLIG2"
      If GREP=""
        If instr(1,GUSRAUZ(1),"M")
          GREP = "M"
          Gosub GRISE
        Else
          mkstat = 2
        Endif
      Endif
    When "NBLIG"
      If GREP=""
        If instr(1,GUSRAUZ(1),"M")
          GREP = "M"
          Gosub GRISE
        Else
          mkstat = 2
        Endif
      Endif
  Endcase

  If !find (COUZON,"MDLDCL","REFNUM","STRDAT","ENDDAT") Then
    mkstat=4 #EELKA (gestion d'enregistrement)
  Endif

Return

#=================================================================================
$ABANDON
    Gosub DEVERROU
    Gosub DEGRISE
    SUIZON="[M:HRSDM0]STRDAT"
    Gosub CHARGE
    Affzo [M:HRSDM1]: Affzo[M:HRSDM0]

    REP=""      #MZOUH (gestion d'enregistrement)
Return

#=================================================================================
$DEGRISE
Actzo [M:HRSDM0]STRDAT,ENDDAT,REFNUM,MDLDCL
Return

#=================================================================================
$GRISE
Grizo [M:HRSDM0]STRDAT,ENDDAT,REFNUM,MDLDCL
Return

#=================================================================================
$DEVERROU
For I=0 To [M:HRSDM1]NBLIG2-1
 SYMBOLE = "DAT"+[M:HRSDM1]SYM(I)
 Unlock =SYMBOLE
Next I
Return

#=================================================================================
$ENREGISTRER
    Local Char YCRIT(250) : [L]YCRIT="1=1"
    Call DEBTRANS From GLOCK
    If [M]MDLDCL="9421" Then
        Gosub TR1_IR
    Else
        Gosub TR1_CIMR
    Endif
    REP=""
    # EELKA Gosub ABANDON

Return

#=================================================================================
$TR1_CIMR
Local Integer XL : Raz XL
Local Integer XI,I : Raz XI,I

Trbegin [HRIDC1]

If [M:HRSDM0]REFNUM<>"" Then [L]YCRIT='[F:HRIDC1]EMP="'+[M:HRSDM0]REFNUM+'"' : Endif

For[HRIDC1]
     Delete[HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and month([HRIDC1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRIDC1]STRDAT)=year([M:HRSDM0]STRDAT)
&    and month([HRIDC1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRIDC1]ENDDAT)=year([M:HRSDM0]ENDDAT)  and evalue([L]YCRIT)
&    and [HRIDC1]CPY=[M:HRSDM0]CPY #JASMI - 2016-11-11 - X3PEOP-2602 - START
Next


For K=0 To [M:HRSDM1]NBLIG-1
    Raz [F:HRIDC1]
    [F:HRIDC1]=[M:HRSDM0]
    [F:HRIDC1]=[M:HRSDM1]
    [F:HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL
    [F:HRIDC1]EMP=[M:HRSDM1]REFNUM1(K)
    [F:HRIDC1]DAT=[M:HRSDM0]ENDDAT #[M:HRSDM1]DAT(K)
    [F:HRIDC1]STRDAT =[M:HRSDM0]STRDAT
    [F:HRIDC1]ENDDAT =[M:HRSDM0]ENDDAT
  #JASMI - 2016-11-30 - X3PEOP-2602 - START
    [F:HRIDC1]CAICAT=[M:HRSDM1]CAICAT(K)
  #JASMI - 2016-11-30 - X3PEOP-2602 - END

    Raz XI
    For I=0 To [F:HRSDS]NBRCOL-1
        XI+=1
        [F:HRIDC1]DESCOL(XI-1)=[F:HRSDS]DESCOL(I)
    Next

    Raz XI
    For I=0 To [F:HRSDS]NBRFLD-1
        XI+=1
        #JASMI
        #[F:HRIDC1]TITFLD(XI-1)=[F:HRSDS]TIT(I)
        Call LECTEXTRA([F:HRIDC1]TITFLD(XI-1),"HRSTADCLSET","TIT",[M]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
        #JASMI
    Next

    #Colonnes FLD
    For J=0 To dim([F:HRIDC1]FLD)-1
           [F:HRIDC1]FLD(J)= evalue( "[M:HRSDM1]FLD"+num$(J+1)+"(K)" )
    Next J

    XL=find([M:HRSDM1]REFNUM1(K),[M:HRSDM1]REFNUM2(0..[M:HRSDM1]NBLIG2-1))
    If XL<>0 Then
        #Colonne AMT
        For J=0 To dim([F:HRIDC1]AMT)-1

            [F:HRIDC1]AMT(J)=  evalue("[M:HRSDM1]AMT"+num$(J+1)+"("+num$(XL-1)+")" )

         Next J
   Endif
   Write [HRIDC1]
Next
If fstat
   GOK = 0 : Call FSTA("HRIDC1") From GLOCK : Goto AB_TR1
Endif
Commit
Gosub CHARGE
Return

#=================================================================================
$AB_TR1
    Rollback
    Goto FIN
Return

#=================================================================================
$SETBOUT
If func AFNC.ACTIV("CSL")<0 Then
    Call VIREBOUT(CHMEN,"y") From GOBJET
Endif
If [M:HRSDM0]MDLDCL="CIMR" Then
    Raz [M:HRSDM2],[M:HRSDM4],[M:HRSDM3],[M:HRSDM6],[M:HRSDM5] #,[M:HRSDM7] 20/04/2015
    Diszo[M:HRSDM2]:Diszo[M:HRSDM4]: Diszo[M:HRSDM3]:Diszo[M:HRSDM6] : Diszo[M:HRSDM7] : Diszo [M:HRSDM5]
Elsif [M:HRSDM0]MDLDCL="9421" Then
    Actzo[M:HRSDM2]: Actzo[M:HRSDM4]: Actzo[M:HRSDM3]: Actzo[M:HRSDM6] : Actzo[M:HRSDM7]: Actzo [M:HRSDM5]
Endif
#---<Début>-MZOUH (gestion d'enregistrement)
If mkstat=4 Then
    Local Integer ETABOU(1..GNBBOU)

    ETABOU (GENRE) = 1
    ETABOU (GABAN) = 1
    Call SETBOUT(ETABOU) From GESECRAN
    REP="M" : GREP="M"
Endif
Actzo [M:HRSDM0]
Return
#---<Fin>-MZOUH

#=================================================================================
$FIN
 Gosub DEVERROU

Return


#=====================================================================================
$CHARGE
  Gosub XCHARGE

  If [M:HRSDM0]MDLDCL="9421" Then
     Gosub XCHARGE_OCCAS
     Gosub XCHRAGE_BENIF
     Gosub XCHARG_STAG
     Gosub XCHARG_VERS
     Gosub XCHARG_EPARGNE
  Endif

  If find ([M:HRSDM0]MDLDCL,"9421","CIMR") Then
     Gosub XCHARG_TOT
  Endif

Return

#=====================================================================================
$XCHARGE
  Call TEMPON("R") From GESECRAN

Local Integer XI : Raz XI
Local Char YCRIT(250) : [L]YCRIT="1=1"

  If [M:HRSDM0]REFNUM<>"" Then [L]YCRIT="[HRIDC1]EMP=[M:HRSDM0]REFNUM" : Endif

  If [M:HRSDM0]MDLDCL="9421" Then
    [L]YCRIT+="& [HRIDC1]EMPTYP=1"
    Raz  [M:HRSDM7]TOTGROTAX,PEMAMT,TOTNETTAX,TOTMONDED,TOTMONPIC,NBRPEM
  Elsif[M:HRSDM0]MDLDCL="CIMR" Then
    Raz  [M:HRSDM7]NBRPEM
  Endif

  I=0 : K=0

  #Filter [HRSDS] Where [HRSDS]COD=[M:HRSDM0]MDLDCL
#JASMI - 2016-11-11 - X3PEOP-2602 - START
#  Filter [HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and [HRIDC1]STRDAT>=[M:HRSDM0]STRDAT and [HRIDC1]ENDDAT <=[M:HRSDM0]ENDDAT and evalue([L]YCRIT) Order By [HRIDC1]EMP
  Filter [HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and [HRIDC1]STRDAT>=[M:HRSDM0]STRDAT
&                       and [HRIDC1]ENDDAT <=[M:HRSDM0]ENDDAT and evalue([L]YCRIT)
&                       and [HRIDC1]CPY=[M:HRSDM0]CPY
&                 Order By [HRIDC1]EMP
#JASMI - 2016-11-11 - X3PEOP-2602 - END
  For [HRIDC1]
    XI+=1  #EELKA

    #Charger tableau des champs salariés
    I=0

    [M:HRSDM1]REFNUM1(XI-1)=[F:HRIDC1]EMP #EELKA
  #JASMI - 2016-11-30 - X3PEOP-2602 - START
    [M:HRSDM1]CAICAT(XI-1)=[F:HRIDC1]CAICAT
  #JASMI - 2016-11-30 - X3PEOP-2602 - END
    For J=0 To [F:HRSDS]NBRFLD -1
      Assign "[M:HRSDM1]FLD"+num$(J+1)+"(XI-1)"  With [F:HRIDC1]FLD(J)
      I+=1
    Next J
    #Charger tableau des données de la paie

    [M:HRSDM1]DAT(K)=[F:HRIDC1]DAT
    [M:HRSDM1]REFNUM2(K)=[F:HRIDC1]EMP #EELKA

    For J=0 To [F:HRSDS]NBRCOL -1
      Assign "[M:HRSDM1]AMT"+num$(J+1)+"("+num$(K)+")"  With [F:HRIDC1]AMT(J)

      If [M:HRSDM0]MDLDCL="9421"
        If [F:HRIDC1]DESCOL(J)="mtRevenuBrutImposable" Then
          [M:HRSDM7]TOTGROTAX+=[F:HRIDC1]AMT(J)
        Elsif [F:HRIDC1]DESCOL(J)="mtBrutTraitementSalaire" Then
          [M:HRSDM7]PEMAMT  +=[F:HRIDC1]AMT(J)
        Elsif[F:HRIDC1]DESCOL(J)="mtRevenuNetImposable" Then
          [M:HRSDM7]TOTNETTAX+=[F:HRIDC1]AMT(J)
        Elsif [F:HRIDC1]DESCOL(J)="mtTotalDeduction" Then
          [M:HRSDM7]TOTMONDED+=[F:HRIDC1]AMT(J)
        Elsif [F:HRIDC1]DESCOL(J)="irPreleve" Then
          [M:HRSDM7]TOTMONPIC+=[F:HRIDC1]AMT(J)
        Endif

      Endif
    Next
    K+=1
  Next

  [M:HRSDM1]NBLIG =XI  #EELKA
  [M:HRSDM1]NBLIG2=K
  If [M:HRSDM0]MDLDCL="9421" Then
    [M:HRSDM7]NBRPEM=XI
    [M:HRSDM7]NBRTRE=[M:HRSDM3]NBLIG
    [M:HRSDM7]EFFTOT=[M:HRSDM7]NBRPEM+[M:HRSDM7]NBROCA+[M:HRSDM7]NBRTRE
    [M:HRSDM7]TOTSUMPAY=[M:HRSDM7]PEMAMT+[M:HRSDM7]CASAMT+[M:HRSDM7]TREAMT

    Affzo [M:HRSDM7]
  Elsif [M:HRSDM0]MDLDCL="CIMR" Then
    [M:HRSDM7]NBRPEM=XI
    [M:HRSDM7]EFFTOT=[M:HRSDM7]NBRPEM
    Affzo [M:HRSDM7]
  Endif

  Affzo [M:HRSDM1]

  If clalev([F:HRSDS])=0 : Local File HRSTADCLSET [HRSDS] : Endif
  Filter [HRSDS]
  Filter [HRIDC1]

  Call TEMPOFF From GESECRAN

Return

#========================================================================================
$XCHARGE_OCCAS
Local Integer XI   : Raz XI
Local Char YCRIT2(250) : [L]YCRIT2="1=1"
If [M:HRSDM0]REFNUM<>"" Then [L]YCRIT2="[HRIDC1]EMP=[M:HRSDM0]REFNUM" : Endif
[L]YCRIT2+="& [HRIDC1]EMPTYP=2"

Raz  [M:HRSDM7]TOTGROSMS,CASAMT,TOTPIC,NBROCA

I=0 : K=0
Filter [HRSDS] Where [HRSDS]COD=[M:HRSDM0]MDLDCL
#JASMI - 2016-11-11 - X3PEOP-2602 - START
#Filter [HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and [HRIDC1]STRDAT >=[M:HRSDM0]STRDAT and [HRIDC1]ENDDAT <=[M:HRSDM0]ENDDAT and evalue([L]YCRIT2) Order By [F]EMP
Filter [HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and [HRIDC1]STRDAT >=[M:HRSDM0]STRDAT
&                     and [HRIDC1]ENDDAT <=[M:HRSDM0]ENDDAT and evalue([L]YCRIT2)
&                     and [HRIDC1]CPY=[M:HRSDM0]CPY
&               Order By [F]EMP
#JASMI - 2016-11-11 - X3PEOP-2602 - END
For [HRIDC1]
    XI+=1  #EELKA

    #Charger tableau Occasionnels
    I=0
#dehen test 1
    [M:HRSDM2]REFNUM1(XI-1)=[F:HRIDC1]EMP
  #JASMI - 2016-11-30 - X3PEOP-2602 - START
    [M:HRSDM2]CAICAT(XI-1)=[F:HRIDC1]CAICAT
  #JASMI - 2016-11-30 - X3PEOP-2602 - END
    For J=0 To [F:HRSDS]NBRFLD -1
            Assign "[M:HRSDM2]FLD"+num$(J+1)+"(XI-1)"  With [F:HRIDC1]FLD(J)
            I+=1
    Next J

    #Charger tableau des données de la paie

    [M:HRSDM2]DAT(K)=[F:HRIDC1]DAT
    [M:HRSDM2]REFNUM2(K)=[F:HRIDC1]EMP #EELKA

    For J=0 To [F:HRSDS]NBRCOL -1
        Assign "[M:HRSDM2]AMT"+num$(J+1)+"("+num$(K)+")"  With [F:HRIDC1]AMT(J)
         If [F:HRIDC1]DESCOL(J)="mtBrutSommes" Then
            [M:HRSDM7]TOTGROSMS+=[F:HRIDC1]AMT(J)
            [M:HRSDM7]CASAMT +=[F:HRIDC1]AMT(J)

         Elsif [F:HRIDC1]DESCOL(J)="irPreleve" Then
               [M:HRSDM7]TOTPIC+=[F:HRIDC1]AMT(J)
         Endif
    Next
    K+=1
Next

[M:HRSDM2]NBLIG =XI  #EELKA
[M:HRSDM2]NBLIG2=K

[M:HRSDM7]NBROCA=XI
[M:HRSDM7]NBRTRE=[M:HRSDM3]NBLIG
[M:HRSDM7]EFFTOT=[M:HRSDM7]NBRPEM+[M:HRSDM7]NBROCA+[M:HRSDM7]NBRTRE
[M:HRSDM7]TOTSUMPAY=[M:HRSDM7]PEMAMT+[M:HRSDM7]CASAMT+[M:HRSDM7]TREAMT

Affzo [M:HRSDM2] : Affzo [M:HRSDM7]
Filter [HRSDS]
Filter [HRIDC1]

Return

#==========================================================
$XCHARG_TOT
Local Integer XI : Raz XI
Local Decimal XTOTBRUTST,XTOTBRUTIN, XTOTRETST ,  XTOTREVST,XTOTMNTAB ,XMNTSAL

  For XI=0 To [M:HRSDM3]NBLIG-1
    [L]XTOTBRUTST +=[M:HRSDM3]GROSAL (XI)
    [L]XTOTBRUTIN +=[M:HRSDM3]GRONSS (XI)
    [L]XTOTRETST  +=[M:HRSDM3]DEDAMT (XI)
    [L]XTOTREVST  +=[M:HRSDM3]RVNAMT (XI)
    [L]XMNTSAL    +=[M:HRSDM3]GROSAL (XI)
  Next

  Raz XI
  For XI=0 To [M:HRSDM5]NBLIG-1
    [L]XTOTMNTAB +=[M:HRSDM5]EMRCTBAMT (XI)
  Next

  [M:HRSDM7]TOTGROSAL = [L]XTOTBRUTST
  [M:HRSDM7]TOTGROALW = [L]XTOTBRUTIN
  [M:HRSDM7]TOTDED  = [L]XTOTRETST
  [M:HRSDM7]TOTINCAMT  = [L]XTOTREVST
  [M:HRSDM7]TOTEMRCON = [L]XTOTMNTAB
  [M:HRSDM7]TREAMT   = [L]XMNTSAL
  [M:HRSDM7]TOTSUMPAY=[M:HRSDM7]PEMAMT+[M:HRSDM7]CASAMT+[M:HRSDM7]TREAMT

  Affzo [M:HRSDM7]

  If [M:HRSDM1]NBLIG<>0 or [M:HRSDM1]NBLIG2<>0 or [M:HRSDM2]NBLIG<>0 or [M:HRSDM2]NBLIG2<>0 or [M:HRSDM3]NBLIG<>0 Then
    Trbegin [HREFT1]
#JASMI - 2016-11-14 - X3PEOP-2602 - START
#    Read [F:HREFT1]HREFT0=[M:HRSDM0]MDLDCL;[M:HRSDM0]STRDAT;[M:HRSDM0]ENDDAT
    Read [F:HREFT1]HREFT0=[M:HRSDM0]MDLDCL;[M:HRSDM0]STRDAT;[M:HRSDM0]ENDDAT;[M:HRSDM0]CPY
#JASMI - 2016-11-14 - X3PEOP-2602 - END
    If !fstat Then
      [F:HREFT1]=[M:HRSDM7]
      Rewrite[F:HREFT1]
      If fstat
        GOK = 0 : Call FSTA("HREFT1") From GLOCK
      Endif
    Else
      [F:HREFT1]=[M:HRSDM0]
      [F:HREFT1]=[M:HRSDM7]
      Write[F:HREFT1]
      If fstat
        GOK = 0 : Call FSTA("HREFT1") From GLOCK
      Endif
    Endif

    If GOK<1 Then Rollback Else Commit : Endif

  Endif

Return

#========================================================================================
$TR1_IR
Local Integer XL,XI : Raz XL,XI
Trbegin [HRIDC1]
If clalev([F:HRSDS])=0 : Local File HRSTADCLSET [HRSDS] : Endif
Read[F:HRSDS]HRSDS0=[M:HRSDM0]MDLDCL

If [M:HRSDM0]REFNUM<>"" Then [L]YCRIT='[F:HRIDC1]EMP="'+[M:HRSDM0]REFNUM+'"' : Endif
For[HRIDC1]
     Delete[HRIDC1] Where [HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL and month([HRIDC1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRIDC1]STRDAT)=year([M:HRSDM0]STRDAT)
&    and month([HRIDC1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRIDC1]ENDDAT)=year([M:HRSDM0]ENDDAT)  and evalue([L]YCRIT)
&    and [HRIDC1]CPY=[M:HRSDM0]CPY #JASMI - 2016-11-11 - X3PEOP-2602 - START
Next
#LIPET - X3-80550 - 2018-04-19 - START
#OLCAU X3-69872 Start
For[HREDC1]
     Delete[HREDC1] Where [HREDC1]MDLDCL=[M:HRSDM0]MDLDCL and month([HREDC1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HREDC1]STRDAT)=year([M:HRSDM0]STRDAT)
&    and month([HREDC1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HREDC1]ENDDAT)=year([M:HRSDM0]ENDDAT)  and evalue([L]YCRIT)
&    and [HREDC1]CPY=[M:HRSDM0]CPY
Next
#OLCAU X3-69872 End
#LIPET - X3-80550 - 2018-04-19 - END
#Commit
#Trbegin [HRIDC1]

#Salariés permanents
For K=0 To [M:HRSDM1]NBLIG-1
    Raz [F:HRIDC1]
    [F:HRIDC1]=[M:HRSDM0]
    [F:HRIDC1]=[M:HRSDM1]
    [F:HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL
    [F:HRIDC1]EMP=[M:HRSDM1]REFNUM1(K)
    [F:HRIDC1]DAT=[M:HRSDM0]ENDDAT #[M:HRSDM1]DAT(K)
    [F:HRIDC1]STRDAT =[M:HRSDM0]STRDAT
    [F:HRIDC1]ENDDAT =[M:HRSDM0]ENDDAT
    [F:HRIDC1]YEA =year([M:HRSDM0]STRDAT )
    [F:HRIDC1]EMPTYP=1
  #JASMI - 2016-11-30 - X3PEOP-2602 - START
    [F:HRIDC1]CAICAT=[M:HRSDM1]CAICAT(K)
  #JASMI - 2016-11-30 - X3PEOP-2602 - END

    Raz XI
    For I=0 To [HRSDS]NBRCOL-1
        If find([HRSDS]ALLHEA(I),2,4) Then
           XI+=1
          [F:HRIDC1]DESCOL(XI-1)=[HRSDS]DESCOL(I)
        Endif
    Next

  Raz XI
    For I=0 To [HRSDS]NBRFLD-1
         If find([HRSDS]ALLDTA(I),2,4) Then
            XI+=1
            #JASMI
            #[F:HRIDC1]TITFLD(XI-1)=[HRSDS]TIT(I)
            Call LECTEXTRA([F:HRIDC1]TITFLD(XI-1),"HRSTADCLSET","TIT",[M]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
            #JASMI
         Endif
    Next


    For J=0 To dim([F:HRIDC1]FLD)-1
           [F:HRIDC1]FLD(J)= evalue( "[M:HRSDM1]FLD"+num$(J+1)+"(K)" )
    Next J

    XL=find([M:HRSDM1]REFNUM1(K),[M:HRSDM1]REFNUM2(0..[M:HRSDM1]NBLIG2-1))
    If XL<>0 Then
        For J=0 To dim([F:HRIDC1]AMT)-1
            [F:HRIDC1]AMT(J)=  evalue("[M:HRSDM1]AMT"+num$(J+1)+"("+num$(XL-1)+")" )
        Next J
   Endif
   Write [HRIDC1]
Next

#Salarié occasionnels

For K=0 To [M:HRSDM2]NBLIG-1
    Raz [F:HRIDC1]
    [F:HRIDC1]=[M:HRSDM0]
    [F:HRIDC1]=[M:HRSDM2]
    [F:HRIDC1]MDLDCL=[M:HRSDM0]MDLDCL
    [F:HRIDC1]EMP=[M:HRSDM2]REFNUM1(K)
    [F:HRIDC1]DAT=[M:HRSDM0]ENDDAT #[M:HRSDM2]DAT(K)
    [F:HRIDC1]STRDAT =[M:HRSDM0]STRDAT
    [F:HRIDC1]ENDDAT =[M:HRSDM0]ENDDAT
    [F:HRIDC1]YEA =year([M:HRSDM0]STRDAT )
    [F:HRIDC1]EMPTYP=2
    #Colonnes FLD
  #JASMI - 2016-11-30 - X3PEOP-2602 - START
    [F:HRIDC1]CAICAT=[M:HRSDM2]CAICAT(K)
  #JASMI - 2016-11-30 - X3PEOP-2602 - END

    Raz XI
    For I=0 To [HRSDS]NBRCOL-1
        If find([HRSDS]ALLHEA(I),3,4) Then
           XI+=1
          [F:HRIDC1]DESCOL(XI-1)=[HRSDS]DESCOL(I)
        Endif
    Next

    Raz XI
    For I=0 To [HRSDS]NBRFLD-1
         If find([HRSDS]ALLDTA(I),3,4) Then
            XI+=1
            #JASMI
            #[F:HRIDC1]TITFLD(XI-1)=[HRSDS]TIT(I)
            Call LECTEXTRA([F:HRIDC1]TITFLD(XI-1),"HRSTADCLSET","TIT",[M]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
            #JASMI
         Endif
    Next


    For J=0 To dim([F:HRIDC1]FLD)-1
           [F:HRIDC1]FLD(J)= evalue( "[M:HRSDM2]FLD"+num$(J+1)+"(K)" )
    Next J

    XL=find([M:HRSDM2]REFNUM1(K),[M:HRSDM2]REFNUM2(0..[M:HRSDM2]NBLIG2-1))
    If XL<>0 Then
        #Colonne AMT
        For J=0 To dim([F:HRIDC1]AMT)-1
            [F:HRIDC1]AMT(J)=  evalue("[M:HRSDM2]AMT"+num$(J+1)+"("+num$(XL-1)+")" )
         Next J
   Endif
   Write [HRIDC1]
Next

If fstat
   GOK = 0 : Call FSTA("HRIDC1") From GLOCK : Goto AB_TR1
Endif

#*******************************************************************************

#JASMI - 2016-11-11 - X3PEOP-2602 - START
#For [HRIDC1]Where MDLDCL=[M:HRSDM0]MDLDCL & YEA =year([M:HRSDM0]STRDAT) & STRDAT=[M:HRSDM0]STRDAT
For [HRIDC1] Where MDLDCL=[M:HRSDM0]MDLDCL & YEA =year([M:HRSDM0]STRDAT) & STRDAT=[M:HRSDM0]STRDAT & [HRIDC1]CPY=[M:HRSDM0]CPY
#JASMI - 2016-11-11 - X3PEOP-2602 - END
    Filter[HREDC1]
    Read [HREDC1]HREDC0=[HRIDC1]MDLDCL;[HRIDC1]EMP;[M:HRSDM0]STRDAT;[M:HRSDM0]ENDDAT
    If fstat Then
       [F:HREDC1]=[F:HRIDC1]
       [F:HREDC1]YEA=[F:HRIDC1]YEA
       [F:HREDC1]DAT=[M:HRSDM0]ENDDAT
        Write [F:HREDC1]
    Endif
Next

If fstat
   GOK = 0 : Call FSTA("HREDC1") From GLOCK : Goto AB_TR1
Endif

#*******************************************************************************

Gosub XENR_BENEF
Gosub XENR_STAGI
Gosub XENR_VERS
Gosub XENR_EPARGNE
Gosub XENR_TOTAUX
If GOK<1 Then Rollback Else Commit : Endif
Gosub CHARGE

Return

