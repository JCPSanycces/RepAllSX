######################################################################################
## Section automatically added (screen GENHRSDM3) 02/05/2016 10:20:49 (DEHEN)
######################################################################################
Subprog AVANT_NBLIG
  Value Integer NBLIG
  Local Integer XNOL : XNOL=nolign-1

  [M:HRSDM7]TOTGROSAL-=[M:HRSDM3]GROSAL(XNOL)
  [M:HRSDM7]TOTGROALW-=[M:HRSDM3]GRONSS(XNOL)
  [M:HRSDM7]TOTDED -=[M:HRSDM3]DEDAMT(XNOL)
  [M:HRSDM7]TOTINCAMT -=[M:HRSDM3]RVNAMT(XNOL)
  [M:HRSDM7]TREAMT  -=[M:HRSDM3]GROSAL(XNOL)
  [M:HRSDM7]TOTEMRCON-=[M:HRSDM5]EMRCTBAMT(XNOL)
  Affzo [M:HRSDM7]
End

Subprog APRES_NBLIG
  Value Integer NBLIG
  Local Integer XNOL : XNOL=nolign-1

  [M:HRSDM7]TOTGROSAL+=[M:HRSDM3]GROSAL(XNOL)
  [M:HRSDM7]TOTGROALW+=[M:HRSDM3]GRONSS(XNOL)
  [M:HRSDM7]TOTDED +=[M:HRSDM3]DEDAMT(XNOL)
  [M:HRSDM7]TOTINCAMT +=[M:HRSDM3]RVNAMT(XNOL)
  [M:HRSDM7]TREAMT  +=[M:HRSDM3]GROSAL(XNOL)
  [M:HRSDM7]TOTEMRCON+=[M:HRSDM5]EMRCTBAMT(XNOL)
  Affzo [M:HRSDM7]
End


