Subprog AM_MDLDCL(VALEUR)
Variable Char VALEUR()
Local  Integer I
Local  Char COLPAIE(100)(0..19)
Local  Char COLFLD(100)(0..19)

Local  Char XCOLOCC(100)(0..19)
Local  Char XFLDOCC(100)(0..19)

  If VALEUR <> '' Then
#  Gosub $ENREGISTRER
    If VALEUR="CIMR" Then
      Local Date XDATE2
      XDATE2=gdat$(1,month([M:HRSDM0]STRDAT)+2,year([M:HRSDM0]STRDAT))
      [M:HRSDM0]ENDDAT=eomonth(XDATE2)
      Effzo [M:HRSDM1] : Effzo [M:HRSDM2]:Effzo [M:HRSDM4]:Effzo [M:HRSDM3]:Effzo [M:HRSDM6]:Effzo [M:HRSDM7]
      Diszo[M:HRSDM2]:Diszo[M:HRSDM4]: Diszo[M:HRSDM3]:Diszo[M:HRSDM6] : Diszo[M:HRSDM7]
    #JASMI - 2017-11-08 - X3-48441 - START
      If dim([M:HRSDM2]NBLIG)>0  : Chgfmt [M:HRSDM2]NBLIG  With "-N:4" : Raz [M:HRSDM2]NBLIG  : Endif
      If dim([M:HRSDM2]NBLIG2)>0 : Chgfmt [M:HRSDM2]NBLIG2 With "-N:4" : Raz [M:HRSDM2]NBLIG2 : Endif
      If dim([M:HRSDM3]NBLIG)>0  : Chgfmt [M:HRSDM3]NBLIG  With "-N:4" : Raz [M:HRSDM3]NBLIG  : Endif
      If dim([M:HRSDM4]NBLIG)>0  : Chgfmt [M:HRSDM4]NBLIG  With "-N:4" : Raz [M:HRSDM4]NBLIG  : Endif
    #JASMI - 2017-11-08 - X3-48441 - END
    Elsif VALEUR="9421"
#      Gosub TR1_IR
      If [M:HRSDM0]STRDAT<>[0/0/0] Then
        [M:HRSDM0]ENDDAT=gdat$(31,12,year([M:HRSDM0]STRDAT))
        Actzo[M:HRSDM2]: Actzo[M:HRSDM4]: Actzo[M:HRSDM3]: Actzo[M:HRSDM6] : Actzo[M:HRSDM7]
        Effzo [M:HRSDM1]
      #JASMI - 2017-11-08 - X3-48441 - START
        If dim([M:HRSDM2]NBLIG)>0  : Chgfmt [M:HRSDM2]NBLIG  With "N:4" : Raz [M:HRSDM2]NBLIG  : Endif
        If dim([M:HRSDM2]NBLIG2)>0 : Chgfmt [M:HRSDM2]NBLIG2 With "N:4" : Raz [M:HRSDM2]NBLIG2 : Endif
        If dim([M:HRSDM3]NBLIG)>0  : Chgfmt [M:HRSDM3]NBLIG  With "N:4" : Raz [M:HRSDM3]NBLIG  : Endif
        If dim([M:HRSDM4]NBLIG)>0  : Chgfmt [M:HRSDM4]NBLIG  With "N:4" : Raz [M:HRSDM4]NBLIG  : Endif
      #JASMI - 2017-11-08 - X3-48441 - END
      Endif
    Endif
    Affzo [M:HRSDM0]ENDDAT

    Local Integer XI,XU
    #Récuperer les intitulé de la colonnes Paie en fonction du modèle / Recover the title Payroll columns by model
    If clalev([F:HRSDS])=0 : Local File HRSTADCLSET [HRSDS] : Endif
      Filter [HRSDS] Where MDLEXP = VALEUR
      Raz XI,XU
      For I=0 To [HRSDS]NBRCOL-1
#        If VALEUR="9421"
#          If find([HRSDS]ALLDTA(I),0,2,4) Then #DEHEN - 2016-08-22 : Added 0 to retreive all headings
#            XI+=1
#            COLPAIE(XI-1)=[HRSDS]DESCOL(I)
#          Endif
#          If find([HRSDS]ALLDTA(I),0,3,4) Then #DEHEN - 2016-08-22 : Added 0 to retreive all headings
#            XU+=1
#            XCOLOCC(XU-1)=[HRSDS]DESCOL(I)
#          Endif
#        Else #CIMR
#          COLPAIE(I)=[HRSDS]DESCOL(I)
#        Endif
#DEHEN - Code review for inc
#        If VALEUR="9421"
#          If find([HRSDS]ALLDTA(I),2,4) Then
#            XI+=1
#            COLPAIE(XI-1)=[HRSDS]DESCOL(I)
#          Endif
#          If find([HRSDS]ALLDTA(I),3,4) Then
#            XU+=1
#            XCOLOCC(XU-1)=[HRSDS]DESCOL(I)
#          Endif
#        Else #CIMR
#          COLPAIE(I)=[HRSDS]DESCOL(I)
#       Endif
#DEHEN - Code review for testing
#JASMI - ALLDTA SHOULD BE ALLHEA - START
        If VALEUR="9421"
          If find([HRSDS]ALLHEA(I),2,4) Then
            XI+=1
            COLPAIE(XI-1)=[HRSDS]DESCOL(I)
          Endif
          If find([HRSDS]ALLHEA(I),3,4) Then
            XU+=1
            XCOLOCC(XU-1)=[HRSDS]DESCOL(I)
          Endif
        Else #CIMR
          COLPAIE(I)=[HRSDS]DESCOL(I)
       Endif
#JASMI - ALLDTA SHOULD BE ALLHEA - END
    #JASMI
#       Filter [HRSDS]
     #JASMI
     Next

    #Récuperer les intitulé de la colonnes Champs salariés en fonction du modèle / Retrieve the title of the columns
    Raz XI,XU
    For I=0 To [HRSDS]NBRFLD-1
      If VALEUR="9421"
        If find([HRSDS]ALLDTA(I),2,4) Then
          XI+=1
          #JASMI
          #COLFLD(XI-1)=[HRSDS]TIT(I)
          Call LECTEXTRA(COLFLD(XI-1),"HRSTADCLSET","TIT",VALEUR,[HRSDS]FLD(I)) From ATEXTRA
          #JASMI
        Endif
        If find([HRSDS]ALLDTA(I),3,4) Then
          XU+=1
          #JASMI
          #XFLDOCC(XU-1)=[HRSDS]TIT(I)
          Call LECTEXTRA(XFLDOCC(XU-1),"HRSTADCLSET","TIT",VALEUR,[HRSDS]FLD(I)) From ATEXTRA
          #JASMI
#JASMI - WHY - START
#        Else
#          Call LECTEXTRA(XFLDOCC(XU-1),"HRSTADCLSET","TIT",VALEUR,[HRSDS]FLD(I)) From ATEXTRA
#JASMI - WHY - END
        Endif
      Else #CIMR
        #JASMI
        #COLFLD(I)=[HRSDS]TIT(I)
        Call LECTEXTRA(COLFLD(I),"HRSTADCLSET","TIT",VALEUR,[HRSDS]FLD(I)) From ATEXTRA
        #Infbox(num$(COLFLD(I)))
        #JASMI
      Endif
    Next
    #Intitulés des colonnes / Column titles

    Titcol[M:HRSDM1]NBLIG2 mess(38,11706,1),COLPAIE(0),COLPAIE(1),COLPAIE(2),COLPAIE(3),COLPAIE(4),COLPAIE(5),COLPAIE(6),COLPAIE(7),COLPAIE(8),COLPAIE(9),
&                               COLPAIE(10),COLPAIE(11),COLPAIE(12),COLPAIE(13),COLPAIE(14),COLPAIE(15),COLPAIE(16),COLPAIE(17),COLPAIE(18),COLPAIE(19)

    Titcol[M:HRSDM1]NBLIG mess(38,11706,1),COLFLD(0),COLFLD(1),COLFLD(2),COLFLD(3),COLFLD(4),COLFLD(5),COLFLD(6),COLFLD(7),COLFLD(8),COLFLD(9),
&                               COLFLD(10),COLFLD(11),COLFLD(12),COLFLD(13),COLFLD(14),COLFLD(15),COLFLD(16),COLFLD(17),COLFLD(18),COLFLD(19)

    Titcol[M:HRSDM2]NBLIG2 mess(38,11706,1),XCOLOCC(0),XCOLOCC(1),XCOLOCC(2),XCOLOCC(3),XCOLOCC(4),XCOLOCC(5),XCOLOCC(6),XCOLOCC(7),XCOLOCC(8),XCOLOCC(9),
&                               XCOLOCC(10),XCOLOCC(11),XCOLOCC(12),XCOLOCC(13),XCOLOCC(14),XCOLOCC(15),XCOLOCC(16),XCOLOCC(17),XCOLOCC(18),XCOLOCC(19)

    Titcol[M:HRSDM2]NBLIG mess(38,11706,1),XFLDOCC(0),XFLDOCC(1),XFLDOCC(2),XFLDOCC(3),XFLDOCC(4),XFLDOCC(5),XFLDOCC(6),XFLDOCC(7),XFLDOCC(8),XFLDOCC(9),
&                               XFLDOCC(10),XFLDOCC(11),XFLDOCC(12),XFLDOCC(13),XFLDOCC(14),XFLDOCC(15),XFLDOCC(16),XFLDOCC(17),XFLDOCC(18),XFLDOCC(19)

    Filter [HRSDS]

  Endif
End

