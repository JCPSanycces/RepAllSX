 Delete[HRTPY1] Where [HRTPY1]MDLDCL=[M:HRSDM0]MDLDCL and month([HRTPY1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRTPY1]STRDAT)=year([M:HRSDM0]STRDAT)
