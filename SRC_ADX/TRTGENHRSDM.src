    Else
#JASMI - 2016-11-14 - X3PEOP-2602 - START
#        [HRTPY1]MDLDCL   =[F:HRLOP1]MDLDCL
#        [HRTPY1]STRDAT   =[F:HRLOP1]STRDAT
#        [HRTPY1]ENDDAT   =[F:HRLOP1]ENDDAT
        [HRTPY1]=[M:HRSDM0]
#JASMI - 2016-11-14 - X3PEOP-2602 - END
        [HRTPY1]MON  =[F:HRLOP1]MON
        [HRTPY1]YEA      =[F:HRLOP1]YEA
        [HRTPY1]TOTPAY=[F:HRLOP1]TOTPAY
        [HRTPY1]LSTDAT=[F:HRLOP1]DATPAY
        Write[HRTPY1]
        If fstat Then
            Call FSTA("HRTPY1") From GLOCK
            GOK=0  :  Break
        Endif
    Endif
Next
Filter [HRLOP1] : Filter[HRTPY1]

Return

