  For[HREFT1]
       Delete[HREFT1] Where [HREFT1]MDLDCL=[M:HRSDM0]MDLDCL and month([HREFT1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HREFT1]STRDAT)=year([M:HRSDM0]STRDAT)
&      and month([HREFT1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HREFT1]ENDDAT)=year([M:HRSDM0]ENDDAT)
