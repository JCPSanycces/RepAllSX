#&               and month([HRLOP1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRLOP1]ENDDAT)=year([M:HRSDM0]ENDDAT)
#&               Order By [F:HRLOP1]MON;[HRLOP1]DATPAY
Filter [HRLOP1] Where [HRLOP1]MDLDCL=[M:HRSDM0]MDLDCL
&               and month([HRLOP1]STRDAT) >=month([M:HRSDM0]STRDAT) and year([HRLOP1]STRDAT)=year([M:HRSDM0]STRDAT)
&               and month([HRLOP1]ENDDAT) <=month([M:HRSDM0]ENDDAT) and year([HRLOP1]ENDDAT)=year([M:HRSDM0]ENDDAT)
&               and [HRLOP1]CPY=[M:HRSDM0]CPY
&               Order By [F:HRLOP1]MON;[HRLOP1]DATPAY
#JASMI - 2016-11-16 - X3PEOP-2602 - END
For [HRLOP1]
#JASMI - 2016-11-11 - X3PEOP-2602 - START
#    Read[HRTPY1]HRTPY0=[M:HRSDM0]MDLDCL;[F:HRLOP1]STRDAT;[F:HRLOP1]ENDDAT;[F:HRLOP1]MON
    Read[HRTPY1]HRTPY0=[M:HRSDM0]MDLDCL;[F:HRLOP1]STRDAT;[F:HRLOP1]ENDDAT;[F:HRLOP1]MON;[M:HRSDM0]CPY
#JASMI - 2016-11-11 - X3PEOP-2602 - END
    If !fstat Then
        [HRTPY1]TOTPAY+=[F:HRLOP1]TOTPAY
        [HRTPY1]LSTDAT=[F:HRLOP1]DATPAY
        Rewrite[HRTPY1]
        If fstat Then
            Call FSTA("HRTPY1") From GLOCK
            GOK=0  :  Break
