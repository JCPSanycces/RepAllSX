######################################################################################
## Section automatically added (screen GENHRSDM0) 11/26/2015 15:44:29 (DEHEN)
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date VALEUR()
Local Char XMOD
Local Date XDATE1,XDATE2 : XDATE1=VALEUR

  If GFONCTION="GENHRSDM" Then
    [L]XMOD=[HRSDM0]MDLDCL
  Else
    [L]XMOD=[M]MDLDCL
    [M]YEA=year(XDATE1)
    Affzo [M]YEA
  Endif
  If [L]XMOD="CIMR" Then
    XDATE2=gdat$(1,month(XDATE1)+2,year(XDATE1))
    [M]ENDDAT=eomonth(XDATE2)
  Elsif [L]XMOD="9421"
    [M]ENDDAT=gdat$(31,12,year(XDATE1))
  Endif
  Affzo [M]ENDDAT

End


######################################################################################

######################################################################################
## Section automatically added (screen GENHRSDM0) 11/26/2015 15:57:18 (DEHEN)
######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR()

  If [M]MDLDCL="CIMR" Then
    Local Date XDATE1: XDATE1=VALEUR
    If !find(month(XDATE1),3,6,9,12) Then
      Errbox(mess(39,11706,1))
      mkstat=2
      End
    Endif
    Local Date XDATE1,XDATE2 : XDATE1=[M]STRDAT
    XDATE2=gdat$(1,month(XDATE1)+2,year(XDATE1))
    If VALEUR<>eomonth(XDATE2) Then
      Errbox(mess(40,11706,1)+":"+num$(eomonth(XDATE2)))
      mkstat=2
    Endif
  Elsif [M]MDLDCL="9421" Then
    Local Date XDATE1: XDATE1=VALEUR
    If !find(month(XDATE1),12) Then
      Errbox(mess(41,11706,1))
      mkstat=2
      End
    Endif
    Local Date XDATE1,XDATE2 : XDATE1=[M]STRDAT
    XDATE2=gdat$(31,12,year(XDATE1))

    If month(VALEUR)<>12 or day(VALEUR)<>31 or year(VALEUR)<>year(XDATE1)Then
      mkstat=2
      Errbox(mess(40,11706,1)+":"+num$(XDATE2))
    Endif
  Endif

End


######################################################################################

######################################################################################
## Section automatically added (screen GENHRSDM0) 02/05/2016 09:46:37 (DEHEN)
######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Char XMOD (30)

  [L]XMOD=[M]MDLDCL
  If [L]XMOD="CIMR" Then
    Local Date XDATE1: XDATE1=VALEUR
    If !find(month(XDATE1),1,4,7,10) Then
      Errbox(mess(42,11706,1))
      mkstat=2
    Endif
  Elsif [M]MDLDCL="9421" Then
    Local Date XDATE1: XDATE1=VALEUR
    If !find(month(XDATE1),1) Then
      Errbox(mess(43,11706,1))
      mkstat=2
      End
    Endif

    Local Date XDATE1,XDATE2 : XDATE1=VALEUR

    XDATE2=gdat$(1,1,year(XDATE1))

    If month(VALEUR)<>1 or day(VALEUR)<>1 Then
      mkstat=2
      Errbox(mess(40,11706,1)+":"+num$(XDATE2))
    Endif
  Endif
End


