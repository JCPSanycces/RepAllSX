#<AdxTL>@(#)0.0.0.0 $Revision$
# Class EDIFIL
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
        When "AREAD_AFTER"                  : Gosub AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "MSGCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDF.MSGCOD"     : TBFIL(NBPRO) = "[LNK_]MSGCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "MSGREL"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDF.MSGREL"     : TBFIL(NBPRO) = "[LNK_]MSGREL"
  NBPRO += 1 : TBPRO(NBPRO) = "MSGFILNOR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDF.MSGFILNOR"  : TBFIL(NBPRO) = "[LNK_]MSGFILNOR"
  NBPRO += 1 : TBPRO(NBPRO) = "MSGFOR"     : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDF.MSGFOR"     : TBFIL(NBPRO) = "[LNK_]MSGFOR"
  NBPRO += 1 : TBPRO(NBPRO) = "FILDES"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDF.FILDES"     : TBFIL(NBPRO) = "[LNK_]FILDES"
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  ASTDKEY = ASTDKEY + "[LNK_]MSGCOD;"
  ASTDKEY = ASTDKEY + "[LNK_]MSGREL;"
  ASTDKEY = ASTDKEY + "[LNK_]MSGFILNOR;"
  ASTDKEY = ASTDKEY + "[LNK_]MSGFOR;"
Return

###############################################################################

$AQUERY_OPEN_AFTER
 Local Char    WMSGCOD(20)(1..)
 Local Char    WMSGREL(5)(1..)
 Local Char    WMSGFILNOR(20)(1..)
 Local Integer WMSGFOR(1..)
 Local Char    WFILDES(50)(1..)
 Local Integer I : I = 0

 Local File EDISEQFIL [ESF]
 Filter [ESF]
 For [ESF]
  I = I + 1
  WMSGCOD(I)    = [ESF]MSGCOD
  WMSGREL(I)    = [ESF]MSGREL
  WMSGFILNOR(I) = [ESF]MSGFILNOR
  WMSGFOR(I)    = 1 #Seq
  WFILDES(I)    = [ESF]FILDES
 Next
 Filter [ESF]
 LogicClose File [ESF]

 Local File EDIXMLFIL [EXF]
 Filter [EXF]
 For [EXF]
  I = I + 1
  WMSGCOD(I)    = [EXF]MSGCOD
  WMSGREL(I)    = [EXF]MSGREL
  WMSGFILNOR(I) = [EXF]MSGFILNOR
  WMSGFOR(I)    = 2 #Xml
  WFILDES(I)    = [EXF]FILDES
 Next
 Filter [EXF]
 LogicClose File [EXF]

 Local File
& ( Char MSGCOD(20),
&   Char MSGREL(5),
&   Char MSGFILNOR(20),
&   Integer MSGFOR,
&   Char FILDES(50)
& )
& From Variable
&   WMSGCOD,
&   WMSGREL,
&   WMSGFILNOR,
&   WMSGFOR,
&   WFILDES
& As [LNK_]

#Local Char STR(50)
#For [LNK_]
#  STR = [LNK_]MSGCOD
#Next

Return

###############################################################################

$AQUERY_TRANS_AFTER
  this.EDF.MSGCOD    = [LNK_]MSGCOD
  this.EDF.MSGREL    = [LNK_]MSGREL
  this.EDF.MSGFILNOR = [LNK_]MSGFILNOR
  this.EDF.MSGFOR    = [LNK_]MSGFOR
  this.EDF.FILDES    = [LNK_]FILDES
Return

###############################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

###############################################################################

$AREAD_AFTER
#  #Load the Detail facet
Return

