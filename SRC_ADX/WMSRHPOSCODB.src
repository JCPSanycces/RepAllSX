$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 750: RES='Codes postaux'
   When 263: RES='Pays'
   When 210: RES='Code postal'
   When 573: RES='Code commune'
