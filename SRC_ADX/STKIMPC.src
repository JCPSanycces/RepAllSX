#<AdxTL>@(#)0.0.0.0 $Revision$ $Revision$
########################################################################
# Traitement STKIMPC - Librairie des composants de màj stock      V140 #
#                      Import changement emplacement          HCB 2004 #
########################################################################
# Etiquette appelée par Gosub depuis le STKIMP                         #
#                                                                      #
# Changement  : Traitement de l'import des changements emplacements    #
#                                                                      #
########################################################################

$CHGEMPL
If GSTK_TRACE=2 & GSTK_ACTION<>"IMP_ZONE"
  GSTK_ACT=GSTK_ACTION : GSTK_PGM="STKIMPC" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Case GSTK_ACTION
  When "OUVRE"       : Gosub OUVRE
  When "RAZCRE"      : Gosub RAZCRE
  When "SAIMSK"      : Gosub SAIMSK
  When "IMP_ZONE"    : Gosub IMP_ZONE
  When "RUPT_LIGDOC" : Gosub RUPT_LIGDOC
  When "VALID"       : Gosub VALID
  When "IMP_FERME"   : Gosub IMP_FERME
Endcase
Return

#-----------------------------------------#
# Début import : définition des variables #
#-----------------------------------------#
$OUVRE
#----- Variables globales -----#
Global Integer  GSTK_NBLIG              : # Nbre lignes document
Global Char     GSTK_TRSCOD(GLONADI)    : # Code mouvement
Global Char     GSTK_ENTCOD(GLONGAU)    : # Code pièce auto
#----- Variables locales -----#
Local  Char     WSTK_ITMREF(GLONITM), WSTK_STOFCY(GLONFCY)
Local  Integer  WSTK_WRET, WSTK_NBLIGSCD
Local  Char     WSTK_ABRMSK(10)
Local  Integer  LLIGDOC

#----- Chargement abréviation du masque des lignes du document -----#
[L]WSTK_ABRMSK=mid$(GSTK_BASTAB,4,instr(1,GSTK_BASTAB,"]")-4)
#----- Principaux contrôles sur le modèle -----#
If find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1) &
& !find("[F:STJ]PCU(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=1 : Gosub TRT_ERREUR : Return : # Qté en UC sans l'UC !
Endif

#----- Ouverture fichiers si nécessaire -----#

If !clalev([F:STJ])  Local File STOJOU     [STJ]  : Endif
If !clalev([F:STO])  Local File STOCK      [STO]  : Endif
If !clalev([F:TUN])  Local File TABUNIT    [TUN]  : Endif
If !clalev([F:TCO])  Local File TABCOEFF   [TCO]  : Endif
If !clalev([F:STL])  Local File STOLOT     [STL]  : Endif
If !clalev([F:STO])  Local File STOCK      [STO]  : Endif
If !clalev([F:ITFD]) Local File ITMFACILIT [ITFD] : Endif
If !clalev([F:SRU1]) Local File TABSTORUL  [SRU1] : Endif
If !clalev([F:QLD])  Local File STOQLYD    [QLD]  : Endif

# Initialisation des tables nécessaires à la gestion d'emplacements
Gosub STK_INILOC From STKLOC

#  ecran stockage mvt du document
If clalev([M:SCD])=0  Local Mask STOCHG    [SCD] : Endif
If clalev([M:SGW])=0  Local Mask STOCHGW   [SGW] : Endif
#  ecran de travail enreg mvt du document
If clalev([M:STW])=0  Local Mask STOWORK   [STW] : Endif

Raz [M:SCD]
Raz [M:SGW]
Raz [M:STW]

Return

#-----------------------------#
# Nouveau document à importer #
#-----------------------------#
$RAZCRE
Raz GSTK_NBLIG
Return

#---------------------------------------------#
# Chargement masque STOCHG                    #
#---------------------------------------------#
$SAIMSK
If GSTK_ERR
   Return
Endif
#----- Nouvelle ligne de document -----#
If !GSTK_NBLIG

   #----- Si article non géré en stock c'est fini ! -----#
   If [F:ITF]STOMGTCOD <2
      Return
   Endif
   #-----
   GSTK_NBLIG=evalue(GSTK_BASTAB)
   WSTK_ITMREF=[F:ITM]ITMREF
   WSTK_STOFCY=[F:ITF]STOFCY
   Gosub NOUV_LIGDOC
Endif
#----- Chargement d'une ligne de détail stock -----#
[M:SCD]NBLIG+=1
nolign=[M:SCD]NBLIG : indice=nolign-1
#status=73              # hcb 1804
Default File [STJ]

If GSTK_TRACE=2
   GSTK_ACT="SAI_NBLIG("+num$(indice)+")" : GSTK_PGM="W0STOCHG" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Default Mask [SCD]

Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

Call SAI_NBLIG("STJ","IMP_ZONE","SUBIMPOBJ") From W0STOCHG

Setmode
If mkstat
 #   Gosub DELRESSTO_STJ                        # hcb X3-46849
   Gosub DELRESSTO  From IMPSCSS               # hcb X3-46849
   GREP="" : REP="" : mkstat=0 : [L]WSTK_WRET=9 : Gosub TRT_ERREUR : Return
Endif
Return


#                                     # hcb 107241 deb
$DELRESSTO_STJ
Local Decimal LPOT
Local Decimal LQTY, LQTYRES
Raz LQTY
Raz LQTYRES
LPOT = 1

Local Integer WTRBEGIN
# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO]
   WTRBEGIN=1
Endif
Readlock [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If !fstat
   If [F:ITF]STOMGTCOD=3
      Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
      LPOT = [F:STL]POT/100
   Else
      LPOT = 1
   Endif

   LQTY = ([F:STO]QTYSTU-[F:STO]CUMWIPQTY-([F:STO]CUMALLQTY*([F:SRT]BETFCYCOD=2)))

    # Si mouvement interne avec chgt emplacement et priorité aux allocations
   If [F:SRT]BETFCYCOD=1 & [F:SRT]CHGEMPCOD=2 & [F:SRT]PIOQTY=3
      LQTYRES = max(0,LQTY-[F:STO]CUMALLQTY)
   Else
      LQTYRES = min(LQTY,[F:STO]QTYSTU-[F:STO]CUMWIPQTY-[F:STO]CUMALLQTY)
   Endif
   If LQTY <> 0
      [F:STO]CUMWIPQTY +=  LQTYRES
      [F:STO]CUMWIPQTA += LQTYRES * LPOT
    # Suppression qté en cours de traitement
      Call DEL_STOWIPW([F:STO]STOCOU,LQTYRES) From STKLIB
      Rewrite [F:STO]
   Endif
Endif

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif
Return
#                                     # hcb 107241 fin



#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
# --------------------------------------- #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#                                         #
#-----------------------------------------#
$IMP_ZONE
Case IMPZON
  When "PCUDES"
        If find("[F:STJ]PCU(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(PCUDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]PCUDES(indice)<>[F:STJ]PCU
              [M:SCD]PCUDES(indice)= [F:STJ]PCU : IMPMOD=1
           Endif
           OK=0
        Endif
  When "QTYPCUDES"
        If find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(QTYPCUDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]QTYPCUDES(indice)<>[F:STJ]QTYPCU
              [M:SCD]QTYPCUDES(indice)= [F:STJ]QTYPCU : IMPMOD=1
           Endif
           OK=0
        Endif
  When "COEDES"
        If find("[F:STJ]PCUSTUCOE(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(COEDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]COEDES(indice)<>[F:STJ]PCUSTUCOE
              [M:SCD]COEDES(indice)= [F:STJ]PCUSTUCOE : IMPMOD=1
           Endif
           OK=0
        Endif
  When "QTYSTUDES"
        If find("[F:STJ]QTYSTU(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(QTYSTUDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]QTYSTUDES(indice)<>[F:STJ]QTYSTU
              [M:SCD]QTYSTUDES(indice)= [F:STJ]QTYSTU : IMPMOD=1
           Endif
           OK=0
        Endif
  When "STADES"
        If find("[F:STJ]STA(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(STADES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]STADES(indice)<>[F:STJ]STA
              [M:SCD]STADES(indice)= [F:STJ]STA : IMPMOD=1
           Endif
           OK=0
        Endif
#                                                                       # hcb 119490 deb
 When "LOCTYPDES"
        If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(LOCTYPDES)" : GSTK_PGM="STKIMPC"
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]LOCDES(indice)<>[F:STJ]LOC
              Read [STC]STC0=[F:SGH]STOFCY;[F:STJ]LOC
              If fstat
                 Raz [F:STC]
              Endif
              [M:SCD]LOCTYPDES(indice)= [F:STC]LOCTYP : IMPMOD=1
           Endif
           OK=0
        Endif
#                                                                       # hcb 119490 fin
  When "LOCDES"
        If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(LOCDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]LOCDES(indice)<>[F:STJ]LOC
              [M:SCD]LOCDES(indice)= [F:STJ]LOC : IMPMOD=1
           Endif
           OK=0
           #--- Bug 65601
           If !find("[F:STJ]WRH(0)",[M:AOE2]ZONMSK1)
             If [F:STJ]LOC<>""
               If dim([M:SCD]WRHDES)>0
                 [M:SCD]WRHDES(indice)=""
               Endif
             Endif
           Endif
           #---
        Endif
#  hcb 78544 deb
  When "PALNUMDES"
        If find("[F:STJ]PALNUM(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(PALNUMDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]PALNUMDES(indice)<>[F:STJ]PALNUM
              [M:SCD]PALNUMDES(indice)= [F:STJ]PALNUM : IMPMOD=1
           Endif
           OK=0
        Endif
  When "CTRNUMDES"
        If find("[F:STJ]CTRNUM(0)",[M:AOE2]ZONMSK1)
           If GSTK_TRACE=2
              GSTK_ACT="IMP_ZONE(CTRNUMDES)" : GSTK_PGM="STKIMPC"     # hcb 119490
              Gosub TRACE_DETAILLEE From STKIMP
           Endif
           If [M:SCD]CTRNUMDES(indice)<>[F:STJ]CTRNUM
              [M:SCD]CTRNUMDES(indice)= [F:STJ]CTRNUM : IMPMOD=1
           Endif
           OK=0
        Endif
#  hcb 78544 fin
Endcase

Return

#----------------------------------------------#
# Avant transaction de màj du document importé #
# Si erreur OK=0                               #
#----------------------------------------------#
$VALID
If GSTK_NBLIG
   If GSTK_TRACE=2
      GSTK_ACT="RUPT_LIGDOC" : GSTK_PGM="STKIMPC" : Gosub TRACE_DETAILLEE From STKIMP
   Endif
   Gosub RUPT_LIGDOC : Raz GSTK_NBLIG
Endif
Return

#------------#
# Fin import #
#------------#
$IMP_FERME
If dim(GSTK_NBLIG)>0 Kill GSTK_NBLIG, GSTK_TRSCOD, GSTK_ENTCOD : Endif
If dim(GSTK_MESS) >0 Kill GSTK_MESS,  GSTK_PGM,    GSTK_ACT    : Endif
Return

#-------------------------------#
# Rupture sur ligne de document #
#-------------------------------#
$RUPT_LIGDOC

Raz GSTK_NBLIG
If [L]WSTK_NBLIGSCD>[M:SCD]NBLIG  [M:SCD]NBLIG=[L]WSTK_NBLIGSCD : Endif
Raz [L]WSTK_WRET

# Contrôle que l'enregistrement peut se faire
Call AVANT_ENRCHG  From TRTSTOCHGB
If mkstat  [L]WSTK_WRET=7 : Gosub TRT_ERREUR : Return : Endif

Call ENR_CHG(WSTK_ABRMSK,LLIGDOC)  From TRTSTOCHGB

Return

#-----------------------------------------------------------------#
# Nouvelle ligne de document : début chargement écran             #
#-----------------------------------------------------------------#
$NOUV_LIGDOC
If GSTK_TRACE=2
   GSTK_ACT="NOUV_LIGDOC" : GSTK_PGM="STKIMPC" : Gosub TRACE_DETAILLEE From STKIMP
Endif

Local Char    LMABR(10) : LMABR   = "[M:"+WSTK_ABRMSK+"]"
Local Integer I
Local Integer LRET
Local Char    W_LOT(GLONLOT)
Local Char    W_SLO(GLONSLO)

LLIGDOC = GSTK_NBLIG-1
Default Mask [SCD]

Gosub FORMAT_INV From STKLIB
#-----

If left$(GWSINVSER,1)= "-"
  If dim([M:SCD]SERNUMF)>0  Grizo [M:SCD]SERNUMF : Endif
  If dim([M:SCD]SERNUM )>0  Grizo [M:SCD]SERNUM  : Endif
Else
  If dim([M:SCD]SERNUMF)>0  Actzo [M:SCD]SERNUMF : Endif
  If dim([M:SCD]SERNUM )>0  Actzo [M:SCD]SERNUM  : Endif
Endif

Raz [M:SCD]
[M:SCD]BETCPY = 1
[M:SCD]ITMREF     = WSTK_ITMREF
[M:SCD]TRSTYP     = GSTK_TRSTYP
[M:SCD]TRSCOD     = GSTK_TRSCOD
[M:SCD]VCRTYP     = GSTK_VCRTYP
If GREP = "C"
   [M:SCD]VCRNUM     = [F:SGD]VCRNUM
   [M:SCD]VCRLIN     = [F:SGD]VCRLIN
Else
   [M:SCD]VCRNUM     = [M:SCS1]VCRNUM
   [M:SCD]VCRLIN     = [M:SCS1]VCRLIN
Endif

[M:SCD]STOFCY     = WSTK_STOFCY
[M:SCD]FCYDES     = WSTK_STOFCY

[M:SCD]STA        = evalue(LMABR+"STA(LLIGDOC)")
If evalue("dim("+LMABR+"LOT)>0") & dim([M:SCD]LOT)>0
    [M:SCD]LOT        = evalue(LMABR+"LOT(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"SLO)>0") & dim([M:SCD]SLO)>0
    [M:SCD]SLO        = evalue(LMABR+"SLO(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"POT)>0") & dim([M:SCD]POT)>0
    [M:SCD]POT        = evalue(LMABR+"POT(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"LOCTYP)>0") & dim([M:SCD]LOCTYP)>0
    [M:SCD]LOCTYP     = evalue(LMABR+"LOCTYP(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"LOC)>0") & dim([M:SCD]LOC)>0
    [M:SCD]LOC        = evalue(LMABR+"LOC(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"QLYCTLDEM)>0")
    [M:SCD]QLYCTLDEM  = evalue(LMABR+"QLYCTLDEM(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"MVTDES)>0")
    [M:SCD]MVTDES     = evalue(LMABR+"MVTDES(LLIGDOC)")
Endif

If [F:ITM]SERMGTCOD=3 & dim([M:SCD]SERNUMDEP)>0
    [M:SCD]SERNUMDEP  = evalue(LMABR+"SERNUM(LLIGDOC)")
    [M:SCD]SERNUMFDEP = evalue(LMABR+"SERNUMF(LLIGDOC)")
Endif
If dim([M:SCD]PALNUM)>0
   [M:SCD]PALNUM     = evalue(LMABR+"PALNUM(LLIGDOC)")
Endif
If dim([M:SCD]CTRNUM)>0
   [M:SCD]CTRNUM     = evalue(LMABR+"CTRNUM(LLIGDOC)")
Endif

If evalue("dim("+LMABR+"STOFLD1)>0") &  dim([M:SCD]STOFLD1)>0
   [M:SCD]STOFLD1    = evalue(LMABR+"STOFLD1(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"STOFLD2)>0") &  dim([M:SCD]STOFLD2)>0
   [M:SCD]STOFLD2    = evalue(LMABR+"STOFLD2(LLIGDOC)")
Endif
#                                                                 # hcb X3-98706 deb
If evalue("dim("+LMABR+"LPNNUM)>0") & dim([M:SCD]LPNNUM)>0
    [M:SCD]LPNNUM        = evalue(LMABR+"LPNNUM(LLIGDOC)")
Endif
#                                                                 # hcb X3-98706 fin
[M:SCD]QTYPCU     = evalue(LMABR+"QTYPCU(LLIGDOC)")
[M:SCD]PCU        = evalue(LMABR+"PCU(LLIGDOC)")
[M:SCD]PCUSTUCOE  = evalue(LMABR+"PCUSTUCOE(LLIGDOC)")
[M:SCD]QTYSTU     = evalue(LMABR+"QTYSTUDES(LLIGDOC)")
[M:SCD]STU        = evalue(LMABR+"STU(LLIGDOC)")

[M:SCD]CCECODS        = [F:DTR]STOCCECOD
If [M:SCD]CCECODS=0
    [M:SCD]CCECODS        = 3
Endif

[M:SCD]COEUCUS = "1"-[M:SCD]PCU-"="-num$([M:SCD]PCUSTUCOE)-[M:SCD]STU
If dim([M:SCD]LOT)>0
   W_LOT = [M:SCD]LOT
Endif
If dim([M:SCD]SLO)>0
   W_SLO = [M:SCD]SLO
Endif
Call POSTABLE([M:SCD]FCYDES, [M:SCD]ITMREF, W_LOT, W_SLO, LRET) From SUBSCSB
If LRET
    FIN = 1
    Return
Endif

If evalue(LMABR+"CREFLG(LLIGDOC)")=0
    Gosub LOAD_FROM_SGW From TRTSTOCHGB
Else
    Gosub LOAD_FROM_STJ From TRTSTOCHGB
Endif

#---- Si demande d'analyse alors on interdit le changement de statut ----#
If [M:SCD]QLYCTLDEM<>""
    Diszo [M:SCD]STADES
Endif

Gosub MAJ_PECQTY From TRTSTOCHGB
Affzo [M:SCD]

GSCSAUZSST = [F:SRU]AUZSST

Setmode
#-----
[L]WSTK_NBLIGSCD=[M:SCD]NBLIG
Raz [M:SCD]NBLIG
Return

#---------------------------------------------------------------------------------#
#                            Traitement des erreurs                               #
# ------------------------------------------------------------------------------- #
#  1 = Modèle d'import erroné : L'unité de conditionnement doit être paramétrée ! #
#  2 =                                                                            #
#  3 =                                                                            #
#  4 =                                                                            #
#  5 =                                                                            #
#  6 =                                                                            #
#  7 = Détail des mouvements de stock erroné !                                    #
#  8 =                                                                            #
#  9 = Erreur chargement ligne détail stock !                                     #
# 10 =                                                                            #
#---------------------------------------------------------------------------------#
$TRT_ERREUR
Case [L]WSTK_WRET
  When  1 : GMESSAGE=mess(558,197,1)
  When  2 :
  When  3 :
  When  4 :
  When  5 :
  When  6 :
  When  7 : GMESSAGE=mess(619,197,1)
  When  8 :
  When  9 : GMESSAGE=mess(580,197,1)
  When 10 :
Endcase
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
[L]OK=0 : GOK=0
Return

