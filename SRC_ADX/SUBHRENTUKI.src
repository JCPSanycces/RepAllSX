#MASHI - 2017-05-26 - JIRA X3-42004 - START

Subprog C_WSTRDLC(VALEUR)
Variable Integer VALEUR
#Clear and set tax code values
Raz [M:ENT6]TAXCOD
Raz [M:ENT6]TAXLBE
Raz [M:ENT6]WK1MH1
#Actzo [M:ENT6]WK1MH1

Case VALEUR
  When 1
    [M:ENT6]WK1MH1      = 1
#    Actzo [M:ENT6]TAXCOD
    Affzo [M:ENT6]WK1MH1
  When 2
    [M:ENT6]TAXCOD      = "L"
#MASHI - 2017-05-26 - JIRA X3-42004 - START
    [M:ENT6]TAXCODAMT   = 1150
#MASHI - 2017-05-26 - JIRA X3-42004 - END
    [M:ENT6]TAXLBE      = "1150L"
    [M:ENT6]WK1MH1      = 1
#MASHI - 2017-05-26 - JIRA X3-44331 - START
    Affzo [M:ENT6]TAXCOD
    Affzo [M:ENT6]TAXCODAMT
    Affzo [M:ENT6]TAXLBE
    Affzo [M:ENT6]WK1MH1
#MASHI - 2017-05-26 - JIRA X3-44331 - END
  When 3
    [M:ENT6]TAXCOD      = "L"
#MASHI - 2017-05-26 - JIRA X3-42004 - START
    [M:ENT6]TAXCODAMT   = 1150
#MASHI - 2017-05-26 - JIRA X3-42004 - END
    [M:ENT6]TAXLBE      = "1150L"
    [M:ENT6]WK1MH1      = 2
#MASHI - 2017-05-26 - JIRA X3-44331 - START
    Affzo [M:ENT6]TAXCOD
    Affzo [M:ENT6]TAXCODAMT
    Affzo [M:ENT6]TAXLBE
    Affzo [M:ENT6]WK1MH1
#MASHI - 2017-05-26 - JIRA X3-44331 - END
  When 4
    [M:ENT6]TAXCOD      = "BR"
    [M:ENT6]TAXCODAMT   = 0
    [M:ENT6]WK1MH1      = 1
    [M:ENT6]TAXLBE      = "BR"
#MASHI - 2017-05-26 - JIRA X3-44331 - START
    Affzo [M:ENT6]TAXCOD
    Affzo [M:ENT6]TAXCODAMT
    Affzo [M:ENT6]TAXLBE
    Affzo [M:ENT6]WK1MH1
#MASHI - 2017-05-26 - JIRA X3-44331 - END
  When 5
    [M:ENT6]TAXCOD      = "0T"
    [M:ENT6]TAXCODAMT   = 0
    [M:ENT6]WK1MH1      = 2
    [M:ENT6]TAXLBE      = "0T"
#MASHI - 2017-05-26 - JIRA X3-44331 - START
    Affzo [M:ENT6]TAXCOD
    Affzo [M:ENT6]TAXCODAMT
    Affzo [M:ENT6]TAXLBE
    Affzo [M:ENT6]WK1MH1
#MASHI - 2017-05-26 - JIRA X3-44331 - END
Endcase
Affzo [M:ENT6]TAXCOD

End

Subprog CHECK_STULOATYP
  If [M:ENT6]STULOATYP >= 1 Then
    Actzo [M:ENT6]STULOADAT
    Actzo [M:ENT6]STULOADATEND
    Actzo [M:ENT6]STULOAPIO
  Else
    Grizo [M:ENT6]STULOADAT
    Grizo [M:ENT6]STULOADATEND
    Grizo [M:ENT6]STULOAPIO
  Endif
End

Subprog C_WSTULOATYP(VALEUR)
Variable Integer VALEUR
  Call CHECK_STULOATYP
End
#DEHEN - X3-35270 - 2017-05-09 - END

#ANCOA - 2017-05-26 - JIRA X3-42004 - START
Subprog C_PRVFRM(VALEUR)
Variable Integer VALEUR
Local Integer SHOW
[L]SHOW=0
Call SHOW_HIDE_P45(SHOW)
Call SHOW_HIDE_STARTER(SHOW)
Call SHOW_HIDE_SECONDED(SHOW)
Call SHOW_HIDE_PERSIONER(SHOW)
[L]SHOW=1
Case VALEUR
  When 1
    #None existing: nothing to show?
  When 2
    Call SHOW_HIDE_P45(SHOW)
  When 3
    Call SHOW_HIDE_STARTER(SHOW)
  When 4
    Call SHOW_HIDE_SECONDED(SHOW)
  When 5
    Call SHOW_HIDE_PERSIONER(SHOW)
Endcase

End

#P45: Starting declaration
Subprog SHOW_HIDE_P45(SHOW)
Variable Integer SHOW
  If SHOW #show
    Actzo [M:ENT6]STRDLC
  Else #hide
    Grizo [M:ENT6]STRDLC
  Endif
End

#Starter
Subprog SHOW_HIDE_STARTER(SHOW)
Variable Integer SHOW
  If SHOW #show
    Actzo [M:ENT6]STRDLC
  Else #hide
    Grizo [M:ENT6]STRDLC
  Endif
End

#Seconded
Subprog SHOW_HIDE_SECONDED(SHOW)
Variable Integer SHOW
  If SHOW #show
    Actzo [M:ENT6]EEACIT, EPMSCH,LIVMOR, LIVLES, WRKIUKLIVABD
    Actzo [M:ENT6]STRDLC

  Else #hide
    Grizo [M:ENT6]EEACIT, EPMSCH,LIVMOR, LIVLES, WRKIUKLIVABD
    Grizo [M:ENT6]STRDLC

  Endif
End

#Pensioner
Subprog SHOW_HIDE_PERSIONER(SHOW)
Variable Integer SHOW
  If SHOW #show
    Actzo [M:ENT6]OCCPEN
    If [M:ENT6]OCCPEN = 2
      Actzo [M:ENT6]RECBEROCCPEN, ANNPENAMTOCC
    Endif
  Else #hide
    Grizo [M:ENT6]OCCPEN, RECBEROCCPEN, ANNPENAMTOCC

  Endif
End


#ANCOA - 2017-05-26 - JIRA X3-42004 - END
#MASHI - 2017-05-26 - JIRA X3-42004 - START
Subprog C_OCCPEN(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    Actzo [M:ENT6]RECBEROCCPEN, ANNPENAMTOCC
  Else
    Grizo [M:ENT6]RECBEROCCPEN, ANNPENAMTOCC
  Endif

End

Subprog AP_LIVMOR(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:ENT6]LIVLES = 2
    [M:ENT6]LIVLES = 1
    Affzo [M:ENT6]LIVLES
  Endif
  If VALEUR = 2 and [M:ENT6]WRKIUKLIVABD = 2
    [M:ENT6]WRKIUKLIVABD = 1
    Affzo [M:ENT6]WRKIUKLIVABD
  Endif
End

Subprog AP_LIVLES(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:ENT6]LIVMOR = 2
    [M:ENT6]LIVMOR = 1
    Affzo [M:ENT6]LIVMOR
  Endif
  If VALEUR = 2 and [M:ENT6]WRKIUKLIVABD = 2
    [M:ENT6]WRKIUKLIVABD = 1
    Affzo [M:ENT6]WRKIUKLIVABD
  Endif
End

Subprog AP_WRKIUKLIVABD(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 and [M:ENT6]LIVMOR = 2
    [M:ENT6]LIVMOR = 1
    Affzo [M:ENT6]LIVMOR
  Endif
  If VALEUR = 2 and [M:ENT6]LIVLES = 2
    [M:ENT6]LIVLES = 1
    Affzo [M:ENT6]LIVLES
  Endif
End

Subprog AM_TAXCOD(VALEUR)
Variable Char    VALEUR()
Local Decimal TAXCODAMT
Local Char TAXCOD(10)
[L]TAXCOD = VALEUR
If VALEUR = "BR" or VALEUR= "D0" or VALEUR = "D1" or VALEUR = "NT" or VALEUR = "0T"
  Raz [M:ENT6]TAXCODAMT
  Raz [M:ENT6]TAXLBE
  Diszo [M:ENT6]TAXCODAMT
Else
  Actzo [M:ENT6]TAXCODAMT
  TAXCODAMT = [M:ENT6]TAXCODAMT
  Gosub SET_TAXLBE
Endif
End

Subprog AM_TAXCODAMT(VALEUR)
Variable Decimal VALEUR
Local Decimal TAXCODAMT
Local Char TAXCOD(10)
TAXCODAMT   = VALEUR
TAXCOD      = [M:ENT6]TAXCOD
Gosub SET_TAXLBE
End


$SET_TAXLBE
If TAXCODAMT = 0 : Return : Endif
If TAXCOD = "K"
  [M:ENT6]TAXLBE = TAXCOD+num$(TAXCODAMT)
Else
   [M:ENT6]TAXLBE = num$(TAXCODAMT)+TAXCOD
Endif
Affzo [M:ENT6]TAXLBE

Return

Subprog C_TAXCODAMT(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  GMESSAGE=mess(00021,00131,1)
  mkstat=2
Endif
End

#MASHI - 2017-05-26 - JIRA X3-42004 - END

Subprog C_NICAT(VALEUR)
Variable Char    VALEUR()

Call NI_CATEGORY_VALIDATION("", [M:ENT1]DATBRN, [M:ENT1]SEX, VALEUR, VALEUR) From SUBCTRUKI
End

