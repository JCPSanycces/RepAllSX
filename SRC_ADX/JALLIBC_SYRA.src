#<AdxTL>@(#)0.0.0.0 $Revision$
# JALLIBC_SYRA
#
# Routines diverses de traitement jalonnement
#########################################################################
# Subprog INIWKL(LMFGFCY,LWCR,LWST,LUSER,LRET)                                #
#########################################################################
#########################################################################
# Initialisation WKL du poste
#   LMFGFCY : Site
#   LWCR    : Centre de charge
#   LWST    : Code du poste
#   LUSER   : Current user
#   LRET    : Code retour
#
Subprog INIWKL(LMFGFCY,LWCR,LWST,LUSER,LRET)
#
Value Char       LMFGFCY
Value Char       LWCR
Value Char       LWST
Value Char       LUSER
Variable Integer LRET
#
Local Integer WMXPERNBR
Local Date    WCUTSTRD
Local Integer WDAY
Local Integer WWEE
Local Integer WMON
Local Integer WJOU
Local Char    WTAB
Local Char    WCLE
#
Local Integer WNBJP,WNBPER
Local Date    WDAT
#
Local Integer I,J,K,WCOR,WRET,WNBJOP
Local Decimal WPERDISTH,WPERDIS
Local Date    WDATD,WDATF
#
Local Integer NBPMX : NBPMX = 1000   : # dimension tables périodes
#
Local Date    DPER(NBPMX)            : # date début période
Local Date    FPER(NBPMX)            : # date fin période
Local Integer NBJPER(NBPMX)          : # nombre de jours période
#
Local Integer NBJMX : NBJMX = 2000   : # dimension tables calendrier
#
Local Decimal WCAP1(NBJMX)           : # capacités journalières théoriques
Local Decimal WCAP2(NBJMX)           : # capacités journalières corrigées
#
Raz LRET
#
If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
#
# Lecture des paramètres de définition découpage en périodes
#
#   CUTSTRDAT : Date début du découpage
#   WKLDAYNBR : Nb de jours du découpage en jours
#   WKLWEENBR : Nb de semaines du découpage en semaines
#   WKLMONNBR : Nb de mois du découpage en mois
#   WKLBUCCOR : Flag d'ajustement
#
Read [PJA]PJA0=LMFGFCY
#If fstat : WTAB="PJA" : WCLE = LMFGFCY : Goto AB_INIWKL : Endif
If fstat  : Gosub CRE_PARJAL : Endif        # llc 07.01 (9738)
#
WCUTSTRD  = [F:PJA]CUTSTRDAT
WDAY      = [F:PJA]WKLDAYNBR
WWEE      = [F:PJA]WKLWEENBR
WMON      = [F:PJA]WKLMONNBR
WCOR      = [F:PJA]WKLBUCCOR
#
If WCUTSTRD = [0/0/0] : WCUTSTRD = date$ : Endif
WDAT = WCUTSTRD
WJOU = 1
#
# Réajuste éventuellement
#
If WCOR = 2
  Call CORBUC(WCOR,WDAT,WJOU,WDAY,WWEE,WMON,WDATF) From CBNLIB
Endif
#
# Définition découpage en périodes
#
#   Initialisations
#
WNBPER = 0
#
WNBJP  = 1
While WDAY > 0
  DPER(WNBPER)   = WDAT
  FPER(WNBPER)   = WDAT
  NBJPER(WNBPER) = WNBJP
  WDAT   += 1
  WNBPER += 1
  WDAY   -= 1
Wend
#
WNBJP  = 0
While WWEE > 0
  DPER(WNBPER)   = WDAT
  WDAT  += 1
  WNBJP += 1
  J = dayn(WDAT)
  While J <> WJOU
    WDAT  += 1
    WNBJP += 1
    J = dayn(WDAT)
  Wend
  FPER(WNBPER)   = WDAT - 1
  NBJPER(WNBPER) = WNBJP
  WNBJP   = 0
  WNBPER += 1
  WWEE   -= 1
Wend
#
WNBJP  = 0
While WMON > 0
  DPER(WNBPER)   = WDAT
  For J = day(WDAT) To day(eomonth(WDAT))
    WDAT  += 1
    WNBJP += 1
  Next J
  FPER(WNBPER)   = WDAT - 1
  NBJPER(WNBPER) = WNBJP
  WNBJP   = 0
  WNBPER += 1
  WMON   -= 1
Wend
#
WMXPERNBR = WNBPER
#
# mise à jour nombre de périodes sur PARJAL
#
Readlock [PJA]PJA0=LMFGFCY
If fstat : WTAB="PJA" : WCLE = LMFGFCY : Goto AB_INIWKL : Endif
[F:PJA]MAXPERNBR = WMXPERNBR
[F:PJA]UPDDAT = date$
[F:PJA]UPDUSR = LUSER
Rewrite [PJA]
If fstat : WTAB="PJA" : WCLE = LMFGFCY : Goto AB_INIWKL : Endif
#Unlock [PJA] : # GH 28/08/12 inutile : tout ce qui est locké dans une transaction n'est délocké qu'à la fin de celle-ci
#
# préparation WKL du poste
#
$STR_WKL
#
#   positionne les bornes du calendrier
#
WDATD = DPER(0)
WDATF = FPER(WNBPER-1)
#
#   lecture du calendrier
#
# WCOR=1
# Call LOACAL(LCAL,WDATD,WDATF,WCOR,WCAP1,WRET) From JALLIBB

#  (llc 08.00 v130) nouvelle gestion des capacités
If [F:MWS]WST <> LWST | [F:MWS]WCRFCY <> LMFGFCY
    Read [MWS]WST0=LWST;LMFGFCY
    If fstat : WTAB="MWS" : WCLE=LWST : Goto AB_INIWKL : Endif
Endif
Call LOACAP (WDATD,WDATF,WCAP1,WRET) From JALLIBB_SYRA

#WCOR=2
#Call LOACAL(LCAL,WDATD,WDATF,WCOR,WCAP2,WRET) From JALLIBB
#
#   constitution structure WORKLOAD
#
WTAB=""
For I = 0 To WNBPER-1
#
#     calcule disponibilité période
#
  WPERDISTH = 0
  WPERDIS   = 0
  WNBJOP = 0
#
  For J = 0 To NBJPER(I)-1
    K = DPER(I) - WDATD + J
    WPERDISTH += WCAP1(K)
#    WPERDIS   += WCAP2(K)
    WPERDIS   += WCAP1(K)
    If WCAP1(K) > 0
      WNBJOP += 1
    Endif
  Next J
#
  [F:WKL]MFGFCY    = LMFGFCY
  [F:WKL]WCR       = LWCR
  [F:WKL]WST       = LWST
  [F:WKL]PERNUM    = I+1
  [F:WKL]PERDAYNBR = NBJPER(I)
  [F:WKL]PERWRKNBR = WNBJOP
  [F:WKL]PERSTR    = DPER(I)
  [F:WKL]PEREND    = FPER(I)
  [F:WKL]PERTHEAVA = WPERDISTH
  [F:WKL]PERAVA    = WPERDIS
  [F:WKL]PERLOD    = 0
  [F:WKL]OWFLOD    = 0
  [F:WKL]OWPLOD    = 0
  [F:WKL]OWSLOD    = 0
  [F:WKL]CREDAT    = date$
  [F:WKL]CREUSR    = LUSER
  [F:WKL]UPDDAT    = date$
  [F:WKL]UPDUSR    = LUSER
#
  Write [WKL]
  If fstat
    WTAB="WKL"
    WCLE=LMFGFCY-LWST-FPER(I)
    Break
  Endif
Next I
If WTAB<>"" : Goto AB_INIWKL : Endif
#
End
#########################################################################
#
#   fin anormale
#
$AB_INIWKL
#
# Called from Syracuse - always assume that we are running in batch mode
#If !GSERVEUR
#    GOK=0 : Call RSTA(WTAB,WCLE) From GLOCK
#Endif
#
LRET=1
#
End

#########################################################################
#   création PARJAL par défaut # llc 07.01 (9738)
$CRE_PARJAL
Raz [F:PJA]
[F:PJA]MFGFCY     = LMFGFCY
[F:PJA]MAXPERNBR  = 180
[F:PJA]WKLDAYNBR  = 180
[F:PJA]WKLBUCCOR  = 2
[F:PJA]AUTFRWSCD  = 2
[F:PJA]AUTFRCSCD  = 2
[F:PJA]CREUSR     = LUSER
[F:PJA]CREDAT     = date$
Write [PJA]
Return

