#<AdxTL>@(#)0.0.0.0 $Revision$ Object management SQHREV
#########################################################################
# SUBSQHREV   New window for Revision management - Quotes               #
#       # Issue X3-57674 : X3-77177 - 2018-01-18 by APL                 #
#########################################################################
$ACTION

  Case ACTION
    When "FILTRE"     : Gosub FILTRE
    When "LIENS"      : Gosub LIENS
    When "EXEBOUT"    : Gosub EXEBOUT
    When "STYLE"      : Gosub STYLE
    When Default
  Endcase
Return

#########################################################################
$FILTRE
  Default File [VQH_]
  If dim([M:SQH0]SQHNUM) >= 0 Then
    CRITERE = "[F:VQH]SQHNUM = '" + [M:SQH0]SQHNUM + "'"
  Endif
Return

#########################################################################
$EXEBOUT
  Case BOUT
    When "1"
      # resynchronization
      Call VQH_RESYNCHRONIZATION()
  Endcase
Return

#########################################################################
$LIENS

  If [F:VQH]CURREVFLG = [V]CST_AYES  Then
    # This part is still necessary because for current revision, information are in [F:SQH].
    # Current [F:VQH] is empty in this case.
    Read [F:SQH]SQH0 = [F:VQH]SQHNUM
    If clalev([M:SQHREV0])>0 :  [M:SQHREV0]  = [F:SQH] : Endif
    If clalev([M:SQHREV0H])>0 : [M:SQHREV0H] = [F:SQH] : Endif
    If clalev([M:SQHREV1])>0 :  [M:SQHREV1]  = [F:SQH] : Endif
    If clalev([M:SQHREV1H])>0 : [M:SQHREV1H] = [F:SQH] : Endif
    If clalev([M:SQHREV3])>0 :  [M:SQHREV3]  = [F:SQH] : Endif
    If clalev([M:SQHREV3H])>0 : [M:SQHREV3H] = [F:SQH] : Endif
    If clalev([M:SQHREV2])>0 :  [M:SQHREV2]  = [F:SQH] : Endif
    If clalev([M:SQHREV2H])>0 : [M:SQHREV2H] = [F:SQH] : Endif
  Endif

  Call REV_HDR([M:SQHREV0]REVNUM)
  Call REV_HDR_HIST([M:SQHREV0]REVNUM-1)

  If ([M:SQHREV0]REVNUM <> [M:SQH0]REVNUM)
    Call REV_LINE([M:SQHREV0]REVNUM)
  Else
    Call CUR_LINE()
  Endif

  Call REV_LINE_HIST([M:SQHREV0]REVNUM-1)

  Diszo [M:SQHREV0]1-99
  Diszo [M:SQHREV1]1-99
  Diszo [M:SQHREV2]1-99
  Diszo [M:SQHREV3]1-99

Return
#########################################################################
$STYLE
  Call CHNG_REV_HDR_STYLE("SQHREV0","SQHREV0H",[M:SQHREV0]REVNUM,0, "AWARNHIGH")
  Call CHNG_REV_HDR_STYLE("SQHREV1","SQHREV1H",[M:SQHREV0]REVNUM,0, "AWARNHIGH")

  Call CHNG_REV_HDR_STYLE("SQHREV3","SQHREV3H",[M:SQHREV0]REVNUM,1, "AWARNHIGH")
  Call CHNG_REV_HDR_STYLE("SQHREV3","SQHREV3H",[M:SQHREV0]REVNUM,2, "AWARNHIGH")

  Call CHNG_REV_GRID_STYLE("SQHREV3","SQHREV3H",[M:SQHREV0]REVNUM,3, "AWARNHIGH")
  Call CHNG_REV_GRID_STYLE("SQHREV3","SQHREV3H",[M:SQHREV0]REVNUM,4, "AWARNHIGH")

  Call CHNG_REV_LIN_STYLE("SQHREV2","SQHREV2H",[M:SQHREV0]REVNUM,2, "AWARNHIGH")

  Affzo [M:SQHREV0]1-99
  Affzo [M:SQHREV1]1-99
  Affzo [M:SQHREV2]1-99
  Affzo [M:SQHREV3]1-99

Return

#########################################################################

# SUBROUTINES
#########################################################################
Subprog VQH_RESYNCHRONIZATION()

Local Integer IERR
Local Integer ICOUNT
Local Integer ICOUNTTOT
Local Integer IADXLOG
Local Integer ISALREVQ

  # ----------------------
  Local File FACILITY [FCY]
  Local File VSQUOTE [VQH]
  Local File SQUOTE  [SQH]
  # ----------------------
  IERR = 0
  IADXLOG = (adxlog = 1)
  # ----------------------
  Call OUVRE_TRACE(mess(553,192,1)) From LECFIC
  # ----------------------
  ICOUNTTOT = 0
  Filter [FCY] Where [F:FCY]SALFLG = [V]CST_AYES
  For [FCY]
    ISALREVQ = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [F:FCY]FCY, "SALREVQ")
    If ISALREVQ = 2 or ISALREVQ = 3 Then
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [VQH]
      Endif
      # ----------------------
      ICOUNT = 0
      Delete [VQH] Where [F:VQH]SALFCY = [F:FCY]FCY and [F:VQH]CURREVFLG = [V]CST_AYES
      For [SQH] Where [F:SQH]SALFCY = [F:FCY]FCY
        Raz [F:VQH]
        [F:VQH]SQHNUM = [F:SQH]SQHNUM
        [F:VQH]REVNUM = [F:SQH]REVNUM
        [F:VQH]SALFCY = [F:SQH]SALFCY
        [F:VQH]CURREVFLG = [V]CST_AYES
        Write [VQH]
        If fstat <> [V]CST_AOK Then
          Call ECR_TRACE([F:FCY]FCY - ":" - mess(552,192,1), 1) From GESECRAN
          IERR = 1
          Break
        Endif
        ICOUNT += 1
      Next
      # ----------------------
      If IERR = 0 Then
        If ICOUNT > 0
          Call ECR_TRACE(func AFNC.MES2(mess(555,192,1), num$(ICOUNT), [F:FCY]FCY), 0) From GESECRAN
        Endif
        If IADXLOG = [V]CST_AFALSE Then
          Commit
        Endif
      Else
        If IADXLOG = [V]CST_AFALSE Then
          Rollback
        Endif
      Endif
      ICOUNTTOT += ICOUNT
    Endif
  Next
  Filter [FCY]
  # ----------------------
  If IERR = 0 Then
    Call ECR_TRACE(func AFNC.MES1(mess(554,192,1), num$(ICOUNTTOT)), 0) From GESECRAN
  Endif
  # ----------------------
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

#########################################################################
#**
#* Create first VSQUOTE record for an new quote
#* @param SSALFCY : Sales site on the quote
#* @param SSQHNUM : Quote number
#* @param IREVNUM : revision number
#*!
Funprog INIT_VSQUOTE_RECORD(SSALFCY, SSQHNUM, IREVNUM)
Value Char SSALFCY
Value Char SSQHNUM
Value Integer IREVNUM

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer ISALREVQ

  IARENDRE = [V]CST_AOK
  # ----------------------
  ISALREVQ = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, SSALFCY, "SALREVQ")
  If ISALREVQ = 2 or ISALREVQ = 3 Then
    # ----------------------
    Local File VSQUOTE [VQH]
    # ----------------------
    Look [VQH]SQH0=SSQHNUM;IREVNUM
    If fstat <> [V]CST_AOK Then
      IADXLOG = (adxlog = 1)
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [F:VQH]
      Endif
      # ----------------------
      Raz [F:VQH]
      [F:VQH]SQHNUM = SSQHNUM
      [F:VQH]REVNUM = IREVNUM
      [F:VQH]SALFCY = SSALFCY
      [F:VQH]CURREVFLG = [V]CST_AYES
      Write [VQH]
      If fstat Then
        GERR = 1
        GMESSAGE = mess(552,192,1)
        IARENDRE = [V]CST_AERROR
      Endif
      # ----------------------
      If IADXLOG = [V]CST_AFALSE Then
        If IARENDRE < [V]CST_AERROR Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Else
      GERR = 1
      GMESSAGE = mess(552,192,1)
      IARENDRE = [V]CST_AERROR
    Endif
  Endif
End IARENDRE

#########################################################################
#**
#* Increase [F:VQH]REVNUM on record [F:VQH]CURREVFLG = [V]CST_AYES for the current quote
#* @param SSALFCY : Sales site on the quote
#* @param SSQHNUM : Quote number
#* @param IOLDREVNUM : OLD current revision number
#* @param INEWREVNUM : NEW current revision number
#*!
Funprog INCREASE_VSQUOTE_RECORD(SSALFCY, SSQHNUM, IOLDREVNUM, INEWREVNUM)
Value Char SSALFCY
Value Char SSQHNUM
Value Integer IOLDREVNUM
Value Integer INEWREVNUM

Local Integer IARENDRE
Local Integer IADXLOG
Local Integer ISALREVQ

  IARENDRE = [V]CST_AOK
  # ----------------------
  ISALREVQ = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, SSALFCY, "SALREVQ")
  If ISALREVQ = 2 or ISALREVQ = 3 Then
    # ----------------------
    Local File VSQUOTE [VQH]
    # ----------------------
    Read [VQH]SQH0=SSQHNUM;IOLDREVNUM
    If fstat = [V]CST_AOK Then
      IADXLOG = (adxlog = 1)
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [F:VQH]
      Endif
      If [F:VQH]CURREVFLG = [V]CST_AYES Then
        [F:VQH]REVNUM = INEWREVNUM     # Increate the revision number
        Rewrite [VQH]
        If fstat Then
          GERR = 1
          GMESSAGE = mess(552,192,1)
        Endif
      Else
        # Revision line given doesn't "[F:VQH]CURREVFLG = [V]CST_AYES".
        # Wrong : we are going to try to fix that to avoid an error
        Filter [VQH] Where [F:VQH]SQHNUM = SSQHNUM and [F:VQH]CURREVFLG = [V]CST_AYES
        For [VQH]
          Delete [VQH]Curr
        Next
        Filter [VQH]
        IARENDRE = func INIT_VSQUOTE_RECORD(SSALFCY, SSQHNUM, INEWREVNUM)
      Endif
      If IADXLOG = [V]CST_AFALSE Then
        If IARENDRE < [V]CST_AERROR Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Else
      # Line is not existing : we are going to create it
      IARENDRE = func INIT_VSQUOTE_RECORD(SSALFCY, SSQHNUM, INEWREVNUM)
    Endif
  Endif
End IARENDRE

######################################################################################
#**
#* get quote creation timestamp for selected revison
#* @param REVNUM      : revision number
#* @return(Datatime)  : Return QTIME
#*!
Funprog GET_QUOTE_DATE(REVNUM)

  Value Integer REVNUM
  Local Datetime QTIME

  Local File VSQUOTE[VQH]
  Read [VQH]SQH0 = [M:SQHREV0]SQHNUM;[L]REVNUM
  QTIME = [F:VQH]CREDATTIM

End QTIME
#########################################################################

#**
#* display quote lines for current revision
#* @param REVNUM : revision number
#*!
Subprog CUR_LINE
  Local Integer NI
  Local File SQUOTED [SQD]
  Raz [M:SQHREV2]
  nolign = 0
  Filter [SQD] Where [F:SQD]SQHNUM = [M:SQH0]SQHNUM Order By [F:SQD]SQDLIN
  For [SQD]
    nolign + = 1

    [M:SQHREV2] = [F:SQD]
    [M:SQHREV2]VACITM1(nolign-1)   = [F:SQD]VACITM(0)
    [M:SQHREV2]VACITM2(nolign-1)   = [F:SQD]VACITM(1)
    [M:SQHREV2]VACITM3(nolign-1)   = [F:SQD]VACITM(2)
    [M:SQHREV2]DAYLTI(nolign-1)   = [F:SQD]DAYLTI

  Next
  Filter [SQD]
  [M:SQHREV2]NBLIG = nolign

End

#########################################################################
#**
#* display quote lines for hitorical revision
#* @param REVNUM : revision number
#*!
Subprog REV_LINE(REVNUM)

  Value Integer REVNUM
  Local Integer NI
  Local Integer SKPLIN
  Local Integer DELLIN
  Local Datetime QTIME


  Local File VSQUOTED [VQD]
  Local File SQUOTED [SQD]

  QTIME = func GET_QUOTE_DATE(REVNUM)
  Raz [M:SQHREV2]
  nolign = 0
  Filter [SQD] Where [F:SQD]SQHNUM = [M:SQH0]SQHNUM and ([F:SQD]LINREVNUM <= [L]REVNUM or [F:SQD]LINREVNUM = 0) Order By [F:SQD]SQDLIN; [F:SQD]LINREVNUM Desc
  For [SQD]
    nolign + = 1
    [M:SQHREV2] = [F:SQD]
    [M:SQHREV2]VACITM1(nolign-1)   = [F:SQD]VACITM(0)
    [M:SQHREV2]VACITM2(nolign-1)   = [F:SQD]VACITM(1)
    [M:SQHREV2]VACITM3(nolign-1)   = [F:SQD]VACITM(2)
    [M:SQHREV2]DAYLTI(nolign-1)   = [F:SQD]DAYLTI

  Next
  Filter [SQD]
  [M:SQHREV2]NBLIG = nolign

  DELLIN = 0

  Filter [VQD] Where [F:VQD]SQHNUM = [M:SQHREV0]SQHNUM and [F:VQD]LINREVNUM <= [L]REVNUM  Order By [F:VQD]SQDLIN; [F:VQD]LINREVNUM Desc

  For [VQD]
    SKPLIN = [V]CST_AFALSE

    If [F:VQD]SQDLIN = DELLIN
      SKPLIN = [V]CST_ATRUE
    Endif

    If [F:VQD]REVCOD = 'A'  and [F:VQD]CREDATTIM < [L]QTIME
      DELLIN = [F:VQD]SQDLIN
      SKPLIN = [V]CST_ATRUE
    Endif

    If find([F:VQD]SQDLIN, [M:SQHREV2]SQDLIN(0..[M:SQHREV2]NBLIG-1)) > 0 Then
      SKPLIN = [V]CST_ATRUE
    Endif

    If SKPLIN = [V]CST_AFALSE
      nolign + = 1
      [M:SQHREV2] = [F:VQD]
      [M:SQHREV2]VACITM1(nolign-1)   = [F:VQD]VACITM(0)
      [M:SQHREV2]VACITM2(nolign-1)   = [F:VQD]VACITM(1)
      [M:SQHREV2]VACITM3(nolign-1)   = [F:VQD]VACITM(2)
      [M:SQHREV2]DAYLTI(nolign-1)   = [F:VQD]DAYLTI
      [M:SQHREV2]NBLIG = nolign
    Endif
  Next

  Filter [VQD]

  Sorta [M:SQHREV2]NBLIG [M:SQHREV2]NBLIG Order By [M:SQHREV2]SQDLIN([S]indice)

  Affzo [M:SQHREV2]1-99

End

######################################################################################
#**
#* display quote lines for previous revision
#* @param REVNUM : revision number
#*!
Subprog REV_LINE_HIST(REVNUM)

  Value Integer REVNUM
  Local Integer NI
  Local Integer DELLIN
  Local Integer SKPLIN
  Local Datetime QTIME

  If [L]REVNUM >= 0

    Local File VSQUOTED [VQD]
    Local File SQUOTED [SQD]

    QTIME = func GET_QUOTE_DATE(REVNUM)
    Raz [M:SQHREV2H]
    nolign = 0
    Filter [SQD] Where [F:SQD]SQHNUM = [M:SQH0]SQHNUM and ([F:SQD]LINREVNUM <= [L]REVNUM or [F:SQD]LINREVNUM = 0) Order By [F:SQD]SQDLIN; [F:SQD]LINREVNUM Desc
    For [SQD]
      nolign + = 1
      [M:SQHREV2H] = [F:SQD]
      [M:SQHREV2H]VACITM1(nolign-1)   = [F:SQD]VACITM(0)
      [M:SQHREV2H]VACITM2(nolign-1)   = [F:SQD]VACITM(1)
      [M:SQHREV2H]VACITM3(nolign-1)   = [F:SQD]VACITM(2)
      [M:SQHREV2H]DAYLTI(nolign-1)    = [F:SQD]DAYLTI

    Next
    Filter [SQD]
    [M:SQHREV2H]NBLIG = nolign

    DELLIN = 0

    Filter [VQD] Where [F:VQD]SQHNUM = [M:SQHREV0]SQHNUM and [F:VQD]LINREVNUM <= [L]REVNUM Order By [F:VQD]SQDLIN; [F:VQD]LINREVNUM Desc

    For [VQD]
      SKPLIN = [V]CST_AFALSE

      If [VQD]SQDLIN = DELLIN
        SKPLIN = [V]CST_ATRUE
      Endif

      If [VQD]REVCOD = 'A' and [F:VQD]CREDATTIM < [L]QTIME
        DELLIN = [VQD]SQDLIN
        SKPLIN = [V]CST_ATRUE
      Endif

      If find([F:VQD]SQDLIN,[M:SQHREV2H]SQDLIN(0..[M:SQHREV2H]NBLIG)) > 0 Then
        SKPLIN = [V]CST_ATRUE
      Endif

      If SKPLIN = [V]CST_AFALSE
        nolign + = 1
        [M:SQHREV2H] = [F:VQD]
        [M:SQHREV2H]VACITM1(nolign-1)   = [F:VQD]VACITM(0)
        [M:SQHREV2H]VACITM2(nolign-1)   = [F:VQD]VACITM(1)
        [M:SQHREV2H]VACITM3(nolign-1)   = [F:VQD]VACITM(2)
        [M:SQHREV2H]DAYLTI(nolign-1)   = [F:VQD]DAYLTI
        [M:SQHREV2H]NBLIG = nolign
      Endif
    Next

    Filter [VQD]

  Endif

End

######################################################################################
#**
#* display header data for revision
#* @param REVNUM : revision number
#*!
Subprog REV_HDR(REVNUM)
Value Integer REVNUM
Local Integer NI

If [L]REVNUM = [M:SQH0]REVNUM
    Local File SQUOTE[SQH]
    Read [SQH]SQH0 = [M:SQHREV0]SQHNUM

    [M:SQHREV3]NBAXE = [M:SQH3]NBAXE
    For NI = 0 To [M:SQH3]NBAXE-1
      [M:SQHREV3]NAMDIE(NI) = [M:SQH3]NAMDIE(NI)
      [M:SQHREV3]CCE(NI) = [F:SQH]CCE(NI)
      [M:SQHREV3]DIE(NI) = [F:SQH]DIE(NI)
    Next NI

    [M:SQHREV3]NBFAC = [M:SQH3]NBFAC
    For NI = 0 To [M:SQH3]NBFAC-1
      [M:SQHREV3]SHO(NI) = [M:SQH3]SHO(NI)
      [M:SQHREV3]INVDTAAMTSTR(NI) = num$([F:SQH]INVDTAAMT(NI))
    Next NI

Else

  If [L]REVNUM >= 0
    Local File VSQUOTE[VQH]
    Read [VQH]SQH0 = [M:SQHREV0]SQHNUM;[L]REVNUM

    [M:SQHREV3]NBAXE = [M:SQH3]NBAXE
    For NI = 0 To [M:SQH3]NBAXE-1
      [M:SQHREV3]NAMDIE(NI) = [M:SQH3]NAMDIE(NI)
      [M:SQHREV3]CCE(NI) = [F:VQH]CCE(NI)
      [M:SQHREV3]DIE(NI) = [F:VQH]DIE(NI)
    Next NI

    [M:SQHREV3]NBFAC = [M:SQH3]NBFAC
    For NI = 0 To [M:SQH3]NBFAC-1
      [M:SQHREV3]SHO(NI) = [M:SQH3]SHO(NI)
      [M:SQHREV3]INVDTAAMTSTR(NI) = num$([F:VQH]INVDTAAMT(NI))
    Next NI

  Endif
Endif


End

######################################################################################
#**
#* display header data for previous revision
#* @param REVNUM : revision number
#*!
Subprog REV_HDR_HIST(REVNUM)
Value Integer REVNUM
Local Integer NI

    Raz [M:SQHREV0H]
    Raz [M:SQHREV1H]
    Raz [M:SQHREV3H]

  If REVNUM >= 0

    Local File VSQUOTE[VQH]

    Read [VQH]SQH0 = [M:SQHREV0]SQHNUM;[L]REVNUM

    [M:SQHREV0H] = [F:VQH]

    [M:SQHREV1H] = [F:VQH]


    [M:SQHREV3H] = [F:VQH]

    [M:SQHREV3H]NBAXE = [M:SQH3]NBAXE

    For NI = 0 To [M:SQH3]NBAXE-1
       [M:SQHREV3H]NAMDIE(NI) = [M:SQH3]NAMDIE(NI)
       [M:SQHREV3H]CCE(NI) = [F:VQH]CCE(NI)
       [M:SQHREV3H]DIE(NI) = [F:VQH]DIE(NI)
    Next NI

    [M:SQHREV3H]NBFAC = [M:SQH3]NBFAC
    For NI = 0 To [M:SQH3]NBFAC-1
      [M:SQHREV3H]INVDTA(NI) = [F:VQH]INVDTA(NI)
      [M:SQHREV3H]SHO(NI)= [M:SQH3]SHO(NI)
      [M:SQHREV3H]INVDTAAMT(NI) = [F:VQH]INVDTAAMT(NI)
      [M:SQHREV3H]INVDTAAMTSTR(NI) = num$([F:VQH]INVDTAAMT(NI))
      [M:SQHREV3H]INVDTATYP(NI) = [F:VQH]INVDTATYP(NI)
      [M:SQHREV3H]SFISSTCOD(NI) = [F:VQH]SFISSTCOD(NI)
    Next NI

  Endif

End

######################################################################################
#**
#* change style for selected fileds in mask
#* @param ABREV   : screen with current revision
#* @param ABFIC   : screen with previous revision
#* @param REVNUM  : revision number
#* @param STYLE   : new style
#*!
Subprog CHNG_REV_HDR_STYLE(ABREV,ABFIC,REVNUM,BLKNUM,STYLE)

  Value    Char     ABREV
  Value    Char     ABFIC
  Value    Integer  REVNUM
  Value    Integer  BLKNUM
  Value    Char     STYLE

  Local    Char     NOMZON(GLONAVA)
  Local    Char     FULFIELD(250)
  Local    Char     FULFIELD1(250)
  Local    Char     FULFIELD2(250)
  Local Integer     MA
  Local Integer     NI

  Gosub DEFVAR From WGOSQHREV
  For MA = 0 To NBMASK
    If ABMSK(MA) = [L]ABREV Then
      Gosub SETMASK From WGOSQHREV
      Break
    Endif
  Next MA


    Local File AMSKZON[AMZ]

    If BLKNUM <> 0
      Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM # specific block
    Else
      Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]SAIAFF < 3 # all blocks in screen
    Endif

    For [AMZ]
      NOMZON = [F:AMZ]CODZON
      FULFIELD = "[M]" + [L]NOMZON
      For NI = 0 To evalue("dim(" + FULFIELD + ")") - 1
        FULFIELD1 = "[M]" + [L]NOMZON + "(" + num$(NI) + ")"
        FULFIELD2 = "[M:" + [L]ABFIC + "]" + [L]NOMZON + "(" + num$(NI) + ")"
        If (evalue("dim(" + FULFIELD1 + ")") >= 0) and (evalue("dim(" + FULFIELD2 + ")") >= 0)
            If evalue(FULFIELD1) <> evalue(FULFIELD2) and [L]REVNUM > 0 Then
              Chgstl =FULFIELD1 With STYLE
            Else
              Chgstl =FULFIELD1 With ""
            Endif
          Endif
      Next NI
    Next
    Filter [AMZ]

End

######################################################################################
#**
#* change style for selected fileds in mask
#* @param ABREV   : screen with current revision
#* @param ABFIC   : screen with previous revision
#* @param REVNUM  : revision number
#* @param STYLE   : new style
#*!
Subprog CHNG_REV_LIN_STYLE(ABREV,ABFIC,REVNUM,BLKNUM, STYLE)

  Value    Char     ABREV
  Value    Char     ABFIC
  Value    Integer  REVNUM
  Value    Integer  BLKNUM
  Value    Char     STYLE

  Local    Char     NOMZON(GLONAVA)
  Local    Char     FULFIELD(250)
  Local   Integer   MA
  Local   Char      ABFICSQDLIN(250)
  Local   Char      ABREVSQDLIN(250)
  Local   Char      SFORMULA(250)
  Local   Integer   ABFICNOLIG
  Local   Integer   ABREVNOLIG
  Local   Char      SNBLIG(GLONAVA)

   Local File AMSKZON[AMZ]
   Gosub DEFVAR From WGOSQHREV
   For MA = 0 To NBMASK
    If ABMSK(MA) = [L]ABREV Then
      Gosub SETMASK From WGOSQHREV
      Break
    Endif
   Next MA

   Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF < 3  and [F:AMZ]NUMBLOC = BLKNUM Order By [F:AMZ]NUMLIG
   For [AMZ]
     SNBLIG = [F:AMZ]CODZON
   Next

   Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]CODTYP <> "ABS" and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM Order By [F:AMZ]NUMLIG
   For [AMZ]

        For ABREVNOLIG = 0 To evalue("[M:" + [L]ABREV + "]" + SNBLIG + "-1")
          NOMZON = [F:AMZ]CODZON
          FULFIELD = "[M]" + [L]NOMZON
          ABREVSQDLIN = "[M:" + [L]ABREV + "]SQDLIN(" + num$([L]ABREVNOLIG) + ")"
          ABFICSQDLIN = "[M:" + [L]ABFIC + "]SQDLIN(0..[M:" + [L]ABFIC + "]" + SNBLIG +  "-1)"
          SFORMULA = "find(" + [L]ABREVSQDLIN + "," +  [L]ABFICSQDLIN + ")"
          ABFICNOLIG = evalue([L]SFORMULA)-1
          If (evalue("[M:" + [L]ABFIC + "]" + SNBLIG) > 0) and ([L]ABFICNOLIG >= 0)
            If (evalue("dim(FULFIELD(" + num$([L]ABREVNOLIG) + "))") >= 0) and (evalue("dim([M:" + [L]ABFIC + "]" + [L]NOMZON + "(ABFICNOLIG))") >= 0)
              If evalue(FULFIELD + "(" + num$([L]ABREVNOLIG) + ")") <> evalue("[M:" + [L]ABFIC + "]" + [L]NOMZON + "(ABFICNOLIG)")
                Chgstl =FULFIELD + "(" + num$([L]ABREVNOLIG) + ")" With STYLE
              Else
                Chgstl =FULFIELD + "(" + num$([L]ABREVNOLIG) + ")" With ""
              Endif
            Endif
          Else
            Chgstl =FULFIELD + "(" + num$([L]ABREVNOLIG) + ")" With ""
          Endif
        Next ABREVNOLIG
   Next
   Filter [AMZ]

End

######################################################################################
#**
#* change style for selected grid in mask
#* @param ABREV   : screen with current revision
#* @param ABFIC   : screen with previous revision
#* @param REVNUM  : revision number
#* @param STYLE   : new style
#*!
Subprog CHNG_REV_GRID_STYLE(ABREV,ABFIC,REVNUM,BLKNUM, STYLE)

  Value    Char     ABREV
  Value    Char     ABFIC
  Value    Integer  REVNUM
  Value    Integer  BLKNUM
  Value    Char     STYLE

  Local    Char     NOMZON(GLONAVA)
  Local    Char     FULFIELD(250)
  Local   Integer   MA
  Local   Integer   NI
  Local   Char      SNBLIG(GLONAVA)

   Local File AMSKZON[AMZ]
   Gosub DEFVAR From WGOSQHREV
   For MA = 0 To NBMASK
    If ABMSK(MA) = [L]ABREV Then
      Gosub SETMASK From WGOSQHREV
      Break
    Endif
   Next MA

   Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF < 3  and [F:AMZ]NUMBLOC = BLKNUM Order By [F:AMZ]NUMLIG
   For [AMZ]
     SNBLIG = [F:AMZ]CODZON
   Next

   Filter [AMZ] Where [AMZ]CODMSK = [L]ABREV and [F:AMZ]CODTYP <> "ABS" and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM Order By [F:AMZ]NUMLIG
   For [AMZ]
        For NI = 0 To evalue("[M:" + [L]ABREV + "]" + SNBLIG + "-1")
          NOMZON = [F:AMZ]CODZON
          FULFIELD = "[M]" + [L]NOMZON
          If (evalue("[M:" + [L]ABFIC + "]" + SNBLIG) > 0)
            If (evalue("dim(FULFIELD(" + num$([L]NI) + "))") >= 0) and (evalue("dim([M:" + [L]ABFIC + "]" + [L]NOMZON + "(NI))") >= 0)
              If evalue(FULFIELD + "(" + num$([L]NI) + ")") <> evalue("[M:" + [L]ABFIC + "]" + [L]NOMZON + "(NI)")
                Chgstl =FULFIELD + "(" + num$([L]NI) + ")" With STYLE
              Else
                Chgstl =FULFIELD + "(" + num$([L]NI) + ")" With ""
              Endif
            Endif
          Else
            Chgstl =FULFIELD + "(" + num$([L]NI) + ")" With ""
          Endif
        Next ABREVNOLIG
   Next
   Filter [AMZ]

End

######################################################################################

