#<AdxTL>@(#)2.0.0.0 $Revision$ Economic reason code
########################################################################################################################
# Update: ANGRE - SAM # 111399 2015-12-21


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
      Endcase
  Endcase
Return

########################################################################################################################

$PROPERTIES
  Case [L]CURPRO
    When "LEG" : Gosub PROP_LEG
    When "TYP" : Gosub PROP_TYP
    When "COD" : Gosub PROP_COD
    When "DES" : Gosub PROP_DES
    When "TIT" : Gosub PROP_TIT
  Endcase
Return

$PROP_LEG
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.LEG = ""
    When "PROPAGATE"
        If this.LEG <> "GER" Then
            # set type to Not used
            this.TYP = 1
        Endif
    When "CONTROL"
        If this.LEG <> ""
            Gosub CONTROL_LEG From PBDBPGRP_CSTD
        Endif
  Endcase
Return

$PROP_TYP
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.TYP = 1
    When "CONTROL"
      If this.LEG = "GER" Then
        If this.TYP = 1 Then
          ASTATUS = fmet this.ASETERROR( "TYP", mess(393,107,1), [V]CST_AERROR )
                                               # "It is not permitted to set the type to 'Not used' for the German legislation"
        Endif
      Else
        If this.TYP <> 1 Then
          ASTATUS = fmet this.ASETERROR( "TYP", mess(394,107,1), [V]CST_AERROR )
                                               # "The type must be set to 'Not used' for all legislations except German one"
        Endif
      Endif
  Endcase
Return

$PROP_COD
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.COD = ""
  Endcase
Return

$PROP_DES
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.DES = ""
  Endcase
Return

$PROP_TIT
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.TIT = ""
  Endcase
Return

