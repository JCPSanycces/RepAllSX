#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISOHTR                                                     #
# Author : JUCON                                                              #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

####################################################################
$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK     : WOK     = [V]CST_AOK
  Local Integer WSTATUS : WSTATUS = [V]CST_AOK

  Case WCATACT
    When 1 :
      Case WPARCOD
        When "TENOR"  : Gosub TENOR_ISSUE
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
    When 2 :
      Case WPARCOD
        When "TENOR" : Gosub TENOR_RECEIPT
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
  Endcase

###########
#If WCATACT = 2
##  this.SOH.SOHNUM = ""
#      If WPARAM(6) <> ""
##        ASTATUS = fmet this.ASETERROR("", "JSON: "+WPARAM(6), [V]CST_AERROR)
#      Endif
#
#Endif
###########



  ARET_VALUE = WSTATUS
Return


################################################################################
$TENOR_ISSUE
  #
Return

################################################################################
$TENOR_RECEIPT
  ####################################
  #   HEADER
  ####################################
  this.E="E"    #Indicator header for import template model
  #1 - Control value to EDIFUNCTION property (only 9 and 5 are supported at the moment)
  Local Integer K, WSTAT # 112148
  Local Char WREST(250)  # 112148

  If this.EDIFUNCTION="": this.EDIFUNCTION="9": Endif
  Case this.EDIFUNCTION
    When "16":  K=1: WERR= mess(9,137,1)-mess(36,120,1)   #Proposal
    When "46":  K=1: WERR= mess(9,137,1)-mess(1,2258,1)   #Provisional
  Endcase
  If K=1
    WSTATUS = [V]CST_AERROR
  Endif

  #1.- Searching customer´s EDI code 110811_US8
  Local File EDIBPRPAR [EBP]
  Local Integer WFND

  If WSTATUS = [V]CST_AOK
  #X3-63072 Operational points in EDI  (JUOCN 04/12/2017)
    WFND=0
    Filter [EBP] Where PARCOD = WPARCOD and EDIORDCOD = this.IDBUYER #110811_US8
    Read [EBP]First
    If fstat <> [V]CST_AOK
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.IDBUYER #110811_US8
      Read [EBP] First
      If fstat = [V]CST_AOK: WFND=1: Endif
    Else : WFND=1
    Endif
    If WFND=1
      this.SOH.BPCORD = [F:EBP]BPANUM
      this.SOH.BPAORD = [F:EBP]BPAADD
      this.SOH.BPAADD = [F:EBP]BPAADD
      If this.SOH.C_BPCNAM<>null
        If this.SOH.C_BPCNAM.BPCNAM=""
          Local File BPCUSTOMER [BPC]
          Read [BPC]BPC0=this.SOH.BPCORD
          If fstat = [V]CST_AOK
            this.SOH.PTE=[F:BPC]PTE
            this.SOH.C_BPCNAM.BPCNAM=[F:BPC]BPCNAM
          Endif
          LogicClose File [BPC]
        Endif
      Endif
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif

  If WSTATUS = [V]CST_AOK # Filling delivery BP
    WFND=0
    #X3-63072 Operational points in EDI  (JUOCN 04/12/2017)
    Filter [EBP] Where PARCOD = WPARCOD and EDISDHCOD = this.EDIBPCCOD #110811_US8
    Read [EBP]First
    If fstat <> [V]CST_AOK
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD= this.EDIBPCCOD
      Read [EBP] First
      If fstat = [V]CST_AOK: WFND=1: Endif
    Else : WFND=1
    Endif
    If WFND=1
      this.SOH.BPAADD = [F:EBP]BPAADD
    Else
       WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif

  If WSTATUS = [V]CST_AOK # Filling BP bill-to customer
    #X3-67105 Operational points in EDI  (JUOCN 19/12/2017)
    WFND=0
    Filter [EBP] Where PARCOD = WPARCOD and EDIINVCOD = this.EDIBPCINV
    Read [EBP]First
    If fstat <> [V]CST_AOK
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPCINV
      Read [EBP] First
      If fstat = [V]CST_AOK: WFND=1: Endif
    Else : WFND=1
    Endif

    If WFND=1
      this.SOH.BPCINV = [F:EBP]BPANUM
      this.SOH.BPAINV = [F:EBP]BPAADD
      this.SOH.BPCPYR = this.SOH.BPCINV
      this.SOH.BPAPYR = this.SOH.BPAINV #110811_US8
      Local File BPCUSTOMER [BPC]
      Read [BPC]BPC0=this.SOH.BPCINV
      If fstat = [V]CST_AOK
        this.SOH.PTE=[F:BPC]PTE
      Endif
      LogicClose File [BPC]
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(128,2006,1) #Cannot find the bill-to customer code
    Endif
  Endif

  LogicClose File [EBP]

  #2.- Filling Company and site fields
  #Issue 110811_US8  : EDI code researsh algo
  If WSTATUS = [V]CST_AOK

    this.SOH.SALFCY = func TRTFUNEDI.ORD_EDICODE_SE(this.IDSELLER,WPARCOD,this.SOH.BPCORD,1) #110811_US8
    this.SOH.CPY = func TRTFUNEDI.ORD_EDICODE_SE(this.IDSELLER,WPARCOD,this.SOH.BPCORD,2) #110811_US8
#   this.SOH.PLISTC func TRTFUNEDI.ORD_EDICODE_SE(this.IDSELLER,WPARCOD,this.SOH.BPCORD,3)

    Local File FACILITY [FCY]
    Read [FCY]FCY0=this.SOH.SALFCY
    If fstat=[V]CST_AOK
      If [F:FCY]LEGCPY<> this.SOH.CPY
         WERR=mess(125,2006,1)   #Site does not belong to the company
         WSTATUS = [V]CST_AERROR
       Else
         this.SOH.LEG   =[F:FCY]LEG
       Endif
    Endif
    LogicClose File [FCY]

  Endif

  If WSTATUS = [V]CST_AOK
    If this.SOH.CPY=""
      WSTATUS = [V]CST_AERROR
      WERR = mess(126,2006,1) #Cannot find the site code
    Endif
  Endif
  #/110811_US8

# (X3-84850) Edi - CHECK FLOW By BP/COMPANY IN RECEIPT (JUCON 02/04/2018)
  If WSTATUS = [V]CST_AOK
    Local Integer WFLOK
    WFLOW=func EDIRUN_CSTD.TEST_EDIBPRCPY(this.SOH.BPCORD, this.SOH.CPY, WPARCOD, WCATCOD, [ETC]FLOCOD, [ETC]FLOREL)
    If WFLOW<>[V]CST_AINFO # If AINFO then valid flow
      Case WFLOW
        When 3: WERR=mess(41,2006,1)+"."-mess(4,2017,1)+":"- this.SOH.BPCORD+"/"+this.SOH.CPY # Invalid flow. Checking EDI flow and BPs/companies association
        When 4: WERR=mess(31,2006,1)+"."-mess(4,2017,1)+":"- this.SOH.BPCORD+"/"+this.SOH.CPY # Flow not defined. Checking EDI flow and BPs/companies association
      Endcase
      WSTATUS = [V]CST_AERROR
    Endif
  Endif

  If WSTATUS = [V]CST_AOK
    If WDUPLICATE=2 and this.EDIFUNCTION="7" and WTEST=1
      Local File EDICATL [ECAL]
      Local Char WDUPLIASORI(1)
      Read [ECAL]ECAL2=WCATCOD;this.SOH.LEG
      If fstat= [V]CST_AOK
        If [F:ECAL]DUPLICATE=2
          WDUPLIASORI = fmet this.ACTX.APARAM.AGETUSERVALNUM("DUPLIASORI")
          If WDUPLIASORI = 1
            WSTATUS = [V]CST_AERROR
            WERR = mess(145,2006,1)-this.SOH.CPY    #Duplicate not allowed for the company
          Endif
        Endif
      Endif
      LogicClose File [ECAL]
    Endif
  Endif
#110811_US9
  If WSTATUS = [V]CST_AOK
    Local Integer WOKK
    WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.SOH.SALFCY,WCATACT)

    If WOKK=0
      WSTATUS = [V]CST_AERROR
      WERR=mess(63,133,1) #Site not authorized
    Endif
  Endif
#/110811_US9

  #3.- Filling Sales order type
  If WSTATUS = [V]CST_AOK
    Local File TABSOHTYP [TSO]
    Filter [TSO] Where LEG=this.SOH.LEG and SOHCAT=1
    Read First
    If fstat=[V]CST_AOK
      this.EDISOHTYP=[F:TSO]SOHTYP
    Else
      Filter [TSO] Where LEG="" and SOHCAT=1
      Read First
      If fstat=[V]CST_AOK
        this.EDISOHTYP=[F:TSO]SOHTYP
      Endif
    Endif
    LogicClose File [TSO]
    If this.EDISOHTYP=""
      WSTATUS = [V]CST_AERROR
      WERR = mess(137,2006,1) #Cannot find sales order type
    Else
      this.SOH.SOHTYP=this.EDISOHTYP
    Endif
  Endif

  #4 - Formating date properties
  If WSTATUS = [V]CST_AOK
    If this.EDIORDDAT="": this.EDIORDDAT=date$: Endif
    this.SOH.ORDDAT    = format$("D:YYYYMMDD",left$(this.EDIORDDAT, 8))
    this.SOH.SHIDAT    = format$("D:YYYYMMDD",left$(this.EDISHIDAT, 8))
    this.SOH.DEMDLVDAT = format$("D:YYYYMMDD",left$(this.EDIDLVDAT, 8))
  Endif

  #5.- File type test
  If WSTATUS = [V]CST_AOK
    If WTEST=1 and this.EDIFLGTEST="1"
      WERR= mess(143,2006,1) #This file is for test
      WTEST=2
    Endif
  Endif


  # Filling BPTNUM code
  If WSTATUS = [V]CST_AOK
    Local File EDIBPRPAR [EBP]
    Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPTCOD
    Read First
    If fstat = [V]CST_AOK
      this.SOH.BPTNUM = [F:EBP]BPANUM
    Else
      WERR = mess(130,2006,1) #Cannot find the BP carrier code
    Endif
    LogicClose File [EBP]
  Endif

  #7.- Managing the EDIFUNCTION propierty
  If WSTATUS = [V]CST_AOK
    Local Char WPED(20)
    Local File SORDER [SOHX]
    Read[SOHX]SOH1=this.SOH.BPCORD;this.SOH.CUSORDREF
    If fstat = [V]CST_AOK
      WPED=[F:SOHX]SOHNUM
      Case this.EDIFUNCTION
        When "3" : WSTATUS = [V]CST_AERROR: WERR= mess(131,2006,1)- WPED  #Nothing to do. Cancellation of the sales order
        When "5" : this.SOH.SOHNUM=WPED  # Modification of this sales order
        When "6" : WSTATUS = [V]CST_AERROR: WERR= mess(132,2006,1)- WPED   #Nothing to do. Confirmation of the sales order
        When "9" :If WPED<>"" and WTEST=1: WSTATUS = [V]CST_AERROR: WERR= mess(6,159,1)-this.SOH.CUSORDREF-mess(134,2006,1)- WPED: Endif  #already in use
                   # else Original (default value). Nothing to do
        When "31": WSTATUS = [V]CST_AERROR: WERR= mess(135,2006,1)- WPED   #Nothing to do. Copy of the sales order
      Endcase
    Else
      If this.EDIFUNCTION="7" and WDUPLICATE=1  # If WDUPLICATE =2 is traited like original, so nothing to do
        WSTATUS = [V]CST_AERROR: WERR= mess(136,2006,1)-this.SOH.CUSORDREF  #Document is a duplicate. Original does not exist and duplicate flag not checked.
      Endif
    Endif
    LogicClose File [SOHX]
  Endif

  #transcodings

  Local Char WREP(20) : WREP = right$(this.AINF.NAMCLA,3)
  Local Char WNODE(20)
  Local Char WTYP(20)
  Local Integer WTAB
  Local Integer WSEQ
  Local File ASHWPAR [ASWP]

  #7- Transcoding EDIMDL property (in STD table 231)
  If WSTATUS = [V]CST_AOK
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIMDL"
    Read First
    If fstat=[V]CST_AOK
      WTYP  = this.EDIMDL
      If WTYP<>""
        WTAB  = val([F:ASWP]VALEUR)
        WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
        If WNODE=""
          WSTATUS = [V]CST_AERROR
          WERR = mess(140,2006,1) #Cannot find a correct delivery mode
        Else
          this.SOH.MDL= left$(WNODE,3)
        Endif
      Endif
    Endif
    Filter [ASWP]
  Endif

  LogicClose File [ASWP]

  #8. Checking CPY
  If WSTATUS = [V]CST_AOK
    If this.EDIFCYEEC<>""
      Local File COMPANY [CPY]
      Filter [FCY] Where EECNUM=this.EDIFCYEEC
      If fstat<>[V]CST_AOK
        WERR = mess(144,2006,1)+":"- this.EDIFCYEEC  #Cannot find a company with this EU VAT number
      Endif
    Endif
  Endif

# Filling BP address lines . Now not used. Pending CRUD method in class
#  If WSTATUS = [V]CST_AOK
#    If maxtab(this.SOH.C_BPCADDLIG)=1
#      For I=1 To 2
#        WPOS = fmet this.SOH.ADDLINE("C_BPCADDLIG", [V]CST_ALASTPOS)
#        this.SOH.C_BPCADDLIG(WPOS).BPCADDLIG=evalue(this.BPCADDLIG+num$(I))
#      Next
#    Endif
#  Endif

#  If WSTATUS = [V]CST_AOK
#    If maxtab(this.SOH.C_BPIADDLIG)=1
#      For I=1 To 2
#        WPOS = fmet this.SOH.ADDLINE("C_BPIADDLIG", [V]CST_ALASTPOS)
#        this.SOH.C_BPIADDLIG(WPOS).BPIADDLIG=evalue(this.BPIADDLIG+num$(I))
#      Next
#    Endif
#  Endif

  ##Header text
  #Filling properties for Notes file
  If WSTATUS = [V]CST_AOK   # Only 4 texts of head can be treated
    If this.SOH.R_NOTES <> null
      For J=1 To maxtab(this.SOH.R_NOTES)
        Case J
          When 1: this.IMP71 = seg$(this.SOH.R_NOTES(J).TEXT,1,70)
                  this.IMP72 = seg$(this.SOH.R_NOTES(J).TEXT,71,140)
                  this.IMP73 = seg$(this.SOH.R_NOTES(J).TEXT,141,210)
                  this.IMP74 = seg$(this.SOH.R_NOTES(J).TEXT,211,250)
          When 2: this.IMP75 = seg$(this.SOH.R_NOTES(J).TEXT,1,70)
                  this.IMP76 = seg$(this.SOH.R_NOTES(J).TEXT,71,140)
                  this.IMP77 = seg$(this.SOH.R_NOTES(J).TEXT,141,210)
                  this.IMP78 = seg$(this.SOH.R_NOTES(J).TEXT,211,250)
          When 3: this.IMP81 = seg$(this.SOH.R_NOTES(J).TEXT,1,70)
                  this.IMP82 = seg$(this.SOH.R_NOTES(J).TEXT,71,140)
                  this.IMP83 = seg$(this.SOH.R_NOTES(J).TEXT,141,210)
                  this.IMP84 = seg$(this.SOH.R_NOTES(J).TEXT,211,250)
          When 4: this.IMP85 = seg$(this.SOH.R_NOTES(J).TEXT,1,70)
                  this.IMP86 = seg$(this.SOH.R_NOTES(J).TEXT,71,140)
                  this.IMP87 = seg$(this.SOH.R_NOTES(J).TEXT,141,210)
                  this.IMP88 = seg$(this.SOH.R_NOTES(J).TEXT,211,250)
        Endcase
      Next
    Endif
  Endif

  ####################################
  #   LINES
  ####################################
  #Filling C_SOH.SOP collection
  If WSTATUS = [V]CST_AOK
    Local Integer WOK
    Local Char WITM(50)
    For I = 1 To maxtab(this.SOH.R_SOP)
      this.SOH.R_SOP(I).L="L"       #Indicator lines for import template model
      #Searching ITMREF
      Raz WITM  #X3-49995 (JUCON 11/10/17)
      If this.SOH.R_SOP(I).EANCOD<>"" #X3-49995 (JUCON 11/10/17)
        WITM = func TRTFUNEDI.ORD_ITMREF(this.SOH.R_SOP(I).EANCOD,1)
        If this.SOH.SOP(I).ITMDES = ""
          this.SOH.SOP(I).ITMDES = func TRTFUNEDI.ORD_ITMREF(this.SOH.R_SOP(I).EANCOD,2)
        Endif
      Endif #X3-49995 (JUCON 11/10/17)
      If WITM=""
        WITM = func TRTFUNEDI.ORD_ITMREFBPC(this.SOH.BPCORD,this.SOH.SOP(I).ITMREFBPC)
        If WITM=""
          WSTATUS = [V]CST_AERROR
          WERR = mess(142,2006,1) #Cannot find a product for this EANCODE
          Break
        Endif
      Endif
      this.SOH.SOP(I).ITMREF= WITM

      # Transcoding EDISAU  properties (in STD table 228)
      Local File ASHWPAR [ASWP]
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
      Read First
      If fstat=[V]CST_AOK
        WTYP  = this.SOH.R_SOP(I).EDISAU
        WTAB  = val([F:ASWP]VALEUR)
        WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
        If left$(WNODE,3) = ""
          this.SOH.SOP(I).SAU = this.SOH.R_SOP(I).EDISAU  #STD import will make the final control
        Else
          this.SOH.SOP(I).SAU = left$(WNODE,3)
        Endif
      Endif
      LogicClose File [ASWP]
# Issue 114721 : Feed GROPRI from BPCSALPRI (consumer price) if GROPRI is empty
      If this.SOH.SOP(I).GROPRI=0 and this.SOH.SOP(I).BPCSALPRI<>0
        this.SOH.SOP(I).GROPRI=this.SOH.SOP(I).BPCSALPRI
      Endif
#/ 114721

#      #   Formating devilery date in the lines
#      106776 New EDI fields
      this.SOH.SOP(I).SOPSOQ.DEMDLVDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIDLVDATLIN, 8))
      this.SOH.SOP(I).SOPSOQ.EXTDLVDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIEXTDLVDAT, 8))
      this.SOH.SOP(I).SOPSOQ.MAXDLVDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIMAXDLVDAT, 8))     # 106776
      this.SOH.SOP(I).SOPSOQ.USELIMDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIUSELIMDAT, 8))     # 106776

      ##Lines text
      #Filling properties for Notes line file
      this.SOH.R_SOP(I).IMP91 = seg$(this.SOH.R_SOP(I).TXTLIN,1,70)
      this.SOH.R_SOP(I).IMP92 = seg$(this.SOH.R_SOP(I).TXTLIN,71,140)
      this.SOH.R_SOP(I).IMP93 = seg$(this.SOH.R_SOP(I).TXTLIN,141,210)
      this.SOH.R_SOP(I).IMP94 = seg$(this.SOH.R_SOP(I).TXTLIN,211,250)

    Next
  Endif
  WREST=mess(280,143,1) # Displayed properties updated
  # Ini 112148
  If WSTATUS = [V]CST_AOK
    WREST=WREST-": OK"
    WSTAT=[V]CST_AINFO
  Else
    WREST=WREST-": KO"
    WSTAT=[V]CST_AERROR
  Endif
  Call ADDDIAGNOSE(this.ACTX,WREST,WSTAT) From ASYRASYNC
  Raz WREST
  # End 112148
Return

