#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0B 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CAMTBUDGET
mkstat = 0
zoncou = "CAMTBUDGET"
indice = 0
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU0B]CUR,GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]CAMTBUDGET : Endif

## Zone PBUSOR
mkstat = 0
zoncou = "PBUSOR"
indice = 0
WNUM = [M]PBUSOR
If varmode([M]PBUSOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUSOR" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]PBUSOR or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUSOR([M]PBUSOR) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUSOR" : GZNUM = 50781 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PBUSTARTDT
mkstat = 0
zoncou = "PBUSTARTDT"
indice = 0
WDATE = [M]PBUSTARTDT
If varmode([M]PBUSTARTDT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUSTARTDT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]PBUSTARTDT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUSTARTDT([M]PBUSTARTDT) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUSTARTDT" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PBUENDDT
mkstat = 0
zoncou = "PBUENDDT"
indice = 0
WDATE = [M]PBUENDDT
If varmode([M]PBUENDDT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PBUENDDT" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]PBUENDDT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PBUENDDT([M]PBUENDDT) From SUBPJBU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PBUENDDT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMBUD0B"
Return

