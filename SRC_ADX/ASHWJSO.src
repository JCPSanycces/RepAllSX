#**
#* PRO_ADD_LINK
#*!
$PRO_ADD_LINK
ISAMANLNK  = (JASWL.TYPLNK=1) & (JASWL.CMPLNK >=1 & JASWL.CMPLNK <=maxtab(ASWACTIONS))
ISAACTLNK  = (JASWL.TYPLNK=3)
ISATRALNK  = (JASWL.TYPLNK=4)
ISAFREELNK = (JASWL.TYPLNK=5) & JASWL.CMPLNK<>19
ISARPTLNK  = (JASWL.TYPLNK=6)   #104754/3
ISAHLPLNK  = (JASWL.CMPLNK=22) :#115007/1 help

If ISAMANLNK or ISAACTLNK or ISATRALNK or ISAFREELNK or ISARPTLNK
 JPRONAM = JASWL.CODLNK : Gosub PRO_ADD_START_OBJECT
 JTITLE  = JASWL.INTLNK : LOCALIAS = "link"+JASWL.ANCLNK+JASWL.CODLNK  :Gosub PRO_ADD_TITLE :#SAM 115576
 If ISAMANLNK
  #102203/5 target on links
  If JASWL.TARLNK>1 & FTARGET &  !find(JASWL.CODLNK,"$lookup")
   JPRONAM = '$target' :  JPROVAL = string$(JASWL.TARLNK=2,'blank')+string$(JASWL.TARLNK=3,'embedded')    : Gosub PRO_ADD_PROPERTY_TEXT
  Elsif JASWL.CMPLNK=22: #105007/1
   JPRONAM = '$target' :  JPROVAL = "help"    : Gosub PRO_ADD_PROPERTY_TEXT
  Elsif FTARGET &  !find(JASWL.CODLNK,"$lookup")
   JPRONAM = '$target' :  JPROVAL = func JSOVAR('TARGET')    : Gosub PRO_ADD_PROPERTY_TEXT
  Endif
  JPRONAM = '$type' :  JPROVAL = ASWACTIONS(JASWL.CMPLNK).MEDIA       : Gosub PRO_ADD_PROPERTY_TEXT

   #{ SAM 10966
   If ISAMANLNK & ASWACTIONS(JASWL.CMPLNK).PROLNK ="$excel"
    JPRONAM = '$confirm' :  JPROVAL = func APPEND_JSON_STRING(mess(236,124,1))      : Gosub PRO_ADD_PROPERTY_TEXT
    JPRONAM = '$officeAddinSetup' :  JPROVAL = "/msoffice/lib/general/addIn/SyracuseOfficeAddinsSetup.EXE"      : Gosub PRO_ADD_PROPERTY_TEXT
   Endif
   #SAM 10966 }

  If len(ASWACTIONS(JASWL.CMPLNK).MET)
   JPRONAM = '$method' :  JPROVAL = ASWACTIONS(JASWL.CMPLNK).MET : Gosub PRO_ADD_PROPERTY_TEXT
  Endif
  If ASWACTIONS(JASWL.CMPLNK).MET="DELETE"
   #122205
   JPRONAM = '$confirm' : JPROVAL = '{@mes124_209}' :
   Gosub PRO_ADD_PROPERTY_TEXT
   NBMES += 1 : TBLMESNUM(NBMES) = 209 : TBLMESCHP(NBMES) = 124 :#for localization
   #end 122205
  Endif
 Elsif ISAACTLNK
  #102203/5 target on links
  If JASWL.TARLNK>1 & FTARGET &  !find(JASWL.CODLNK,"$lookup")
   JPRONAM = '$target' :  JPROVAL = string$(JASWL.TARLNK=2,'blank')+string$(JASWL.TARLNK=3,'embedded')    : Gosub PRO_ADD_PROPERTY_TEXT
  Elsif FTARGET &  !find(JASWL.CODLNK,"$lookup")
   JPRONAM = '$target' :  JPROVAL = func JSOVAR('TARGET')    : Gosub PRO_ADD_PROPERTY_TEXT
  Endif
  JPRONAM = '$type'   :  JPROVAL = 'application/json;vnd.sage=syracuse' : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM = '$method' :  JPROVAL = 'POST'                               : Gosub PRO_ADD_PROPERTY_TEXT
  If dim(JASWL.FLGASYLNK)>0 & JASWL.FLGASYLNK>1
  JPRONAM = '$invocationMode' :  JPROVAL = 'async'                               : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM = '$capabilities' :  JPROVAL = 'abort'                               : Gosub PRO_ADD_PROPERTY_TEXT
  Endif
 Else
  JPRONAM = '$type' :  JPROVAL = 'application/json;vnd.sage=syracuse' : Gosub PRO_ADD_PROPERTY_TEXT
  #102203/5 target on links
  If JASWL.TARLNK>1
   JPRONAM = '$target' :  JPROVAL = string$(JASWL.TARLNK=2,'blank')+string$(JASWL.TARLNK=3,'embedded')    : Gosub PRO_ADD_PROPERTY_TEXT
  Else
   JPRONAM = '$target' :  JPROVAL = 'main'    : Gosub PRO_ADD_PROPERTY_TEXT
  Endif
 Endif

 JPRONAM = '$url'
 If !ISATRALNK & !ISAFREELNK & !ISARPTLNK & !ISAHLPLNK :#115007
  JPROVAL = '{$baseUrl}/'+JASWL.CLALNK
  JKEY    = func GET_REPKEYS(JASWL,ALIASSRC,ALIASDST,COLPRONBR)

  If ISAMANLNK
   If maxtab(JASWL.ATBKEY) & !find(JASWL.CODLNK,"$query","$lookup")
    JPROVAL += '('+JSQUOTE+JKEY+JSQUOTE+')'
   Endif

   If ASWACTIONS(JASWL.CMPLNK).MET="POST"
    If ASWACTIONS(JASWL.CMPLNK).PROLNK = "$create"
     JPROVAL += "/$template"
    Endif
    JPROVAL += "/$workingCopies?representation="
   Else
    JPROVAL += "?representation="
   Endif
   JPROVAL += JASWL.REPLNK+'.'+ ASWACTIONS(JASWL.CMPLNK).LNKTAR
  Else
   JPROVAL += '('+JSQUOTE+JKEY+JSQUOTE+')'
   JPROVAL += '/$services/'
   #NON c'est bien le lien cf ASYROPE
   #JPROVAL += JASWL.CODOPELNK
   JPROVAL += JASWL.CODLNK
   JPROVAL += '?representation='
   JPROVAL += JASWL.CODREP+'.'+func JSOVAR('FACET')

   If ISAACTLNK & maxtab(JASWL.ATBKEY) :#operations' parameters
    For JI=1 To maxtab(JASWL.ATBPAR)
     JPROVAL += '&'+JASWL.ATBPAR(JI).CODPAR +'={'+JASWL.ATBPAR(JI).CODPAR+'}'
    Next JI
   Endif:#operations' parameters
  Endif

  Raz LNKFILTER

  For JI=1 To maxtab(JASWL.ATBPAR)
   If    ISAMANLNK & (
&        ASWACTIONS(JASWL.CMPLNK).PROLNK= "$create" & JASWL.ATBPAR(JI).PARENT=2
&     or ASWACTIONS(JASWL.CMPLNK).PROLNK= "$edit"  & JASWL.ATBPAR(JI).PARENT=2
&     or ASWACTIONS(JASWL.CMPLNK).PROLNK= "$query"  & JASWL.ATBPAR(JI).PARENT=2
&     )
    #Entry parameters
    JPROVAL2 = '&'
    JPROVAL2 += JASWL.ATBPAR(JI).CODPAR
    JPROVAL2 += '='
    If len(JASWL.ATBPAR(JI).ALIAS)
     JPROVAL2 += '{'+JASWL.ATBPAR(JI).ALIAS+'}'
    Else
     If len(ctrans(JASWL.ATBPAR(JI).VALEUR,'"',''))
      JPROVAL2 += ctrans(JASWL.ATBPAR(JI).VALEUR,'"','')
     Else
      Raz JPROVAL2
     Endif
    Endif
    If len(JPROVAL2) : JPROVAL += JPROVAL2 : Endif
   Endif
   If    ISAMANLNK & len(JASWL.ATBPAR(JI).FILCODPAR) & (
&      ASWACTIONS(JASWL.CMPLNK).PROLNK= "$query"  & JASWL.ATBPAR(JI).PARFIL=2
&     or ASWACTIONS(JASWL.CMPLNK).PROLNK= "$lookup" & JASWL.ATBPAR(JI).PARFIL=2
&     )
    # GitHubIssue 1132 - 2013-04-30 by VPO : pb si pfiltre avec propriété
    If len(JASWL.ATBPAR(JI).ALIAS)
     #Filter parameters (properties)
     If len(LNKFILTER) : LNKFILTER += " and " : Endif
     LNKFILTER += "("
     LNKFILTER += JASWL.ATBPAR(JI).FILCODPAR
     LNKFILTER += " eq "
     LNKFILTER += func GET_SDATA_SEP(JASWL.ATBPAR(JI).TYPINT)
     LNKFILTER += '{'+JASWL.ATBPAR(JI).ALIAS+'}'
     LNKFILTER += func GET_SDATA_SEP(JASWL.ATBPAR(JI).TYPINT)
     LNKFILTER += ")"
    # GitHubIssue 1120 - 2013-04-30 by VPO : ne pas prendre pfiltre si pas de valeur
    Elsif len(JASWL.ATBPAR(JI).VALEUR)
     #Filter parameters
     If len(LNKFILTER) : LNKFILTER += " and " : Endif
     LNKFILTER += "("
     LNKFILTER += JASWL.ATBPAR(JI).FILCODPAR
     LNKFILTER += " eq "
     LNKFILTER += func GET_SDATA_SEP(JASWL.ATBPAR(JI).TYPINT)
     # GitHubIssue 1120 - 2013-04-30 by VPO : ne pas prendre pfiltre si pas de valeur
     If JASWL.ATBPAR(JI).VALEUR<>'""'
     LNKFILTER += JASWL.ATBPAR(JI).VALEUR
     Endif
     LNKFILTER += func GET_SDATA_SEP(JASWL.ATBPAR(JI).TYPINT)
     LNKFILTER += ")"
    Endif
   Endif
  Next JI
  If len(LNKFILTER)
   JPROVAL += "&where=" + LNKFILTER
  Endif
  #links for $wordreport and $wordmailmerge
  If ISAMANLNK
   Call SET_LNK_PARAMS(ASWACTIONS(JASWL.CMPLNK).PROLNK,JPROVAL)
  Endif :#links for $wordreport and $wordmailmerge

 Elsif ISAHLPLNK :#115007
  JPROVAL  = func JSOVAR('func ASHWJSO.GET_HELP_URL(PSYR.PREFIX)')
  JPROVAL += '/FCT/ASW_' + JASWL.CODREP
 Elsif ISATRALNK
  #It's url toward the transition client :
  JPROVAL  = func JSOVAR('func ASHWJSO.GET_TRANSITION_URL(PSYR.PREFIX)')
  JPROVAL += '/' + func JSOVAR('PSYR.URLX3')
  JPROVAL += JASWL.CODFNCLNK
  If JASWL.CMPLNK = 1 :#create
   JPROVAL += '/2//C/'
  Else
   JPROVAL += '/2//M/'
   JSEP    = ''
   #ATTENTION on doit mettre cle2+cle1+cle3+cle4.......
   #cas particulier pour objet combiné à 2 clés
   If maxtab(JASWL.ATBKEY)=2 & func SUBASW.IS_AFC_OBJ_GES3(DOSSIER,JASWL.CODFNCLNK)=1
    For JI=1 To maxtab(JASWL.ATBKEY)
      JPROVAL += JSEP+ func GET_REPKEY(JASWL.ATBKEY(JI),ALIASSRC,ALIASDST,COLPRONBR)
      JSEP        = '~'
    Next JI
   Else
    If maxtab(JASWL.ATBKEY)>1
     JI=2
     JPROVAL += JSEP+ func GET_REPKEY(JASWL.ATBKEY(JI),ALIASSRC,ALIASDST,COLPRONBR)
     JSEP     = '~'
    Endif
    For JI=1 To maxtab(JASWL.ATBKEY)
     If JI<>2
       JPROVAL += JSEP+ func GET_REPKEY(JASWL.ATBKEY(JI),ALIASSRC,ALIASDST,COLPRONBR)
       JSEP        = '~'
     Endif
    Next JI
   Endif
   #VPO ajout cas des param
   JSEP    = '~'
   For JI=1 To maxtab(JASWL.ATBPAR)
    JPROVAL += string$(JI=1,'/params')
    JPROVAL += JSEP+JASWL.ATBPAR(JI).CODPAR+'~'
    If len(JASWL.ATBPAR(JI).ALIAS)
     JPROVAL += '{'
     JPROVAL += num$(JASWL.ATBPAR(JI).ALIAS)
     JPROVAL += '}'
    Else
     # GitHubIssue 1120 - 2013-04-30 by VPO : ne pas prendre pfiltre si pas de valeur
     If JASWL.ATBPAR(JI).VALEUR<>'""'
     JPROVAL += JASWL.ATBPAR(JI).VALEUR
     Endif
    Endif
   Next JI
  Endif
 Elsif ISARPTLNK
  #It's url toward the transition client :
  JPROVAL  = func JSOVAR('func ASHWJSO.GET_TRANSITION_URL(PSYR.PREFIX)')
  JPROVAL += '/' + func JSOVAR('PSYR.URLX3')
  If JASWL.CMPLNK=21
   JPROVAL += "AIMPCRYSD"
  Else
   JPROVAL += "AIMPCRYS"
  Endif
  JPROVAL += JASWL.CODFNCLNK
  JPROVAL += '/2//M/'
  JSEP    = '~'
  JPROVAL += "/params"+JSEP+"CODLNK"+JSEP+JASWL.CODLNK+JSEP+'CODREP'+JSEP+ASHW.CODREP
  For JI=1 To maxtab(JASWL.ATBKEY)
   JPROVAL += JSEP+ "VALEUR"+num$(JI)+JSEP+func GET_REPKEY(JASWL.ATBKEY(JI),ALIASSRC,ALIASDST,COLPRONBR)
   JSEP        = '~'
  Next JI
 Elsif ISAFREELNK
  JPROVAL  = JASWL.FREELNK
 Endif

 Gosub PRO_ADD_PROPERTY_TEXT :#'$url'

 If ISAMANLNK & find(ASWACTIONS(JASWL.CMPLNK).PROLNK,"$wordreport","$wordmailmerge","$excel")
   #links for $wordreport and $wordmailmerge : add parameters :
   JPRONAM = '$parameters' : Gosub PRO_ADD_START_OBJECT
   JPRONAM = '$url'
   If ASWACTIONS(JASWL.CMPLNK).PROLNK = "$wordmailmerge"
    JPROVAL  = func JSOVAR('collaborationBaseUrl')
    JPROVAL += "/msoMailMergeDocSels/$template/$workingCopies?representation=msoMailMergeDocSel."
    JPROVAL += func JSOVAR('FACET')
    JPROVAL +=  "&role={$role}&where={$where}&filter={$filter}"
   Elsif ASWACTIONS(JASWL.CMPLNK).PROLNK = "$wordreport"
    JPROVAL  = func JSOVAR('collaborationBaseUrl')
    JPROVAL += "/msoReportModes/$template/$workingCopies?representation=msoReportMode."
    JPROVAL += func JSOVAR('FACET')
    JPROVAL +=  "&role={$role}&where={$where}&filter={$filter}&reportMode={reportMode}&doc_uuid={document}"
   Elsif ASWACTIONS(JASWL.CMPLNK).PROLNK = "$excel"
    JPROVAL  = func JSOVAR('collaborationBaseUrl')
    JPROVAL += "/msoExcelReportModes/$template/$workingCopies?representation=msoExcelReportMode."
    JPROVAL += func JSOVAR('FACET')
    JPROVAL +=  "&role={$role}&where={$where}&filter={$filter}&excelReportMode={excelReportMode}&doc_uuid={document}"
   Endif
   Gosub PRO_ADD_PROPERTY_TEXT :#'$url'
   JPRONAM = "$method" : JPROVAL = "POST" : Gosub PRO_ADD_PROPERTY_TEXT
   JPRONAM = '$properties' : Gosub PRO_ADD_START_OBJECT
   JPRONAM = 'dummy' : Gosub PRO_ADD_START_OBJECT
   Gosub PRO_ADD_END_OBJECT : #dummy
   JPRONAM = "$title"  : JPROVAL = "dummy" : Gosub PRO_ADD_PROPERTY_TEXT
   JPRONAM = "$type" : JPROVAL = "application/x-string" : Gosub PRO_ADD_PROPERTY_TEXT
   Gosub PRO_ADD_END_OBJECT : #$properties
   JPRONAM = "msoCurrentRepresentation"
   JPROVAL="{$representation}." + func JSOVAR('FACET')
   Gosub PRO_ADD_PROPERTY_TEXT

   Gosub PRO_ADD_END_OBJECT : #$parameters
 Endif :#links for $wordreport and $wordmailmerge

 If ISAACTLNK
  #parameters
  If maxtab(JASWL.ATBKEY) or maxtab(JASWL.ATBPAR)
   JPRONAM = '$parameters' : Gosub PRO_ADD_START_OBJECT



   For JI=1 To maxtab(JASWL.ATBPAR)
    JPRONAM = JASWL.ATBPAR(JI).CODPAR
    If len(JASWL.ATBPAR(JI).ALIAS)
     JPROVAL = '{'+JASWL.ATBPAR(JI).ALIAS+'}'
    Else
     JPROVAL = ctrans(JASWL.ATBPAR(JI).VALEUR,'"','')
    Endif
    Gosub PRO_ADD_PROPERTY_TEXT
   Next JI
   Gosub PRO_ADD_END_OBJECT : #$parameters
  Endif
 Endif :#ISAACTLNK
 Gosub PRO_ADD_END_OBJECT : #...CODLNK
Endif
Return

#**
#* PRO_GET_LINK_COND
#*!
$PRO_GET_LINK_COND
Raz CONDLINK
CONDLINK +=string$(JASWL.DETLNK=2,"d" )
CONDLINK +=string$(JASWL.EDILNK=2,"e" )
CONDLINK +=string$(JASWL.QRYLNK=2,"q" )
CONDLINK +=string$(JASWL.QRYLNK=2,"b" ) :#SAM 102169
CONDLINK +=string$(JASWL.LOKLNK=2,"l" )
CONDLINK +=string$(JASWL.SUMLNK=2,"s" )
Return

#**
#* PRO_UPD_LINKS_COND
#*!
$PRO_UPD_LINKS_COND
For LI = 1 To len(CONDLINK)
 ACHR = mid$(CONDLINK,LI,1)
 If !instr(1,CONDLINKS,ACHR)
  #update the links condition:
  CONDLINKS += ACHR
 Endif
Next LI
Return

#**
#* PRO_ADD_LINKS
#*!
$PRO_ADD_LINKS
#First compute the "$links condition:"
Raz CONDLINKS,LNKFADD

If LNKAFF(1) = 1
 MTASWK = maxtab(ASHW.ASWR(I).ASWK)
Else
 MTASWK = maxtab(ASHW.ASWK)
Endif

#Loop on links
For LJ=1 To MTASWK
 If LNKAFF(1) = 1
  JASWL = ASHW.ASWR(I).ASWK(LJ)
 Else
  JASWL = ASHW.ASWK(LJ)
 Endif

 If JASWL <> null

  ISALINK     = (JASWL.TYPLNK=1 & !find(JASWL.CMPLNK,17,18)) or (find(JASWL.TYPLNK,3,4,5,6)>0 & JASWL.CMPLNK<>19)
  LNKFADD(LJ) = ISALINK & (JASWL.ANCLNK = LNKANC) & find(JASWL.AFFLNK,LNKAFF)
  If LNKFADD(LJ)
   Gosub PRO_GET_LINK_COND
   Gosub PRO_UPD_LINKS_COND
  Endif
 Endif
Next LJ


# *** $links : {
If len(CONDLINKS)
 IFLINKS = 'If '+ func GET_CONDITION('(instr(1,"'+CONDLINKS+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 JSTATEMENT = IFLINKS : Gosub PRO_ST_IF

 JPRONAM = '$links' : Gosub PRO_ADD_START_OBJECT_COND

 #Loop on links
  For LJ=1 To MTASWK
   If LNKAFF(1) = 1
    JASWL = ASHW.ASWR(I).ASWK(LJ)
   Else
    JASWL = ASHW.ASWK(LJ)
   Endif
   If JASWL<>null & LNKFADD(LJ)
    Gosub PRO_GET_LINK_COND
    If len(CONDLINK)
     If len(CONDLINKS) <> len(CONDLINK)
      IFLINK = 'If '+ func GET_CONDITION('(instr(1,"'+CONDLINK+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
      JSTATEMENT = IFLINK : Gosub PRO_ST_IF
     Endif
     FTARGET=1 : Gosub PRO_ADD_LINK
     If len(CONDLINKS) <> len(CONDLINK)
      JSTATEMENT = IFLINK : Gosub PRO_ST_ENDIF
     Endif
    Endif
   Endif
  Next LJ
  Gosub PRO_ADD_END_OBJECT : #$links
 JSTATEMENT = IFLINKS : Gosub PRO_ST_ENDIF

Endif
# *** } $links
Return

#**
#* PRO_ADD_MENU_BINDS
#*!
$PRO_ADD_MENU_BINDS
Raz BINDS_CODE,BINDS_POS,BINDS_NBR

#1°) Define the list of binds :
For LJ=1 To maxtab(ASHW.ASWK)
 JASWL = ASHW.ASWK(LJ)
 If JASWL.MENLNK = CODMENU
  #Is it a page link ?
  #pour les binds , on prend tout les links/actions....
  #ISALINK     = (JASWL.TYPLNK=1 & !find(JASWL.CMPLNK,17,18)) or (find(JASWL.TYPLNK,3,4,5,6)>0)
  ISALINK     = 1
  #VPO 89774 If ISALINK & find(JASWL.AFFLNK,4,5) & JASWL.ANCLNK = ""
  #102203/5 target on links
  #SAM 108421 If JASWL.TARLNK<3 & ISALINK & JASWL.AFFLNK=4 & JASWL.ANCLNK = ""
  If JASWL.TARLNK<3 & ISALINK & JASWL.AFFLNK=4 & JASWL.ANCLNK = "" & JASWL.CODLNK <> "$abort"
   #Compute the condition of the link
   Gosub PRO_GET_LINK_COND
   If instr(1,CONDLINK,CONDMEN)
    #The links has to be displayed in this facet:
    BINDS_NBR += 1
    BINDS_CODE(BINDS_NBR)  = JASWL.CODLNK
    If ASHW.ASWFAC(AFAC).AFFLNKFAC = JASWL.AFFLNK & ASHW.ASWFAC(AFAC).LNKMENFAC = JASWL.CODLNK
     BINDS_POS(BINDS_NBR)  = 1
    Else
     #BINDS_POS(BINDS_NBR)  = 2
     BINDS_POS(BINDS_NBR)  = NUMMENU+LJ
    Endif

   Endif :#instr
  Endif :#ISALINK
 Endif:#JASWL.MENLNK
Next LJ

#2°) Sort the list:
Sorta BINDS_NBR BINDS_POS, BINDS_CODE  Order By BINDS_POS(indice+1)

 #3°) Add binds
For LJ=1 To BINDS_NBR
 JPRONAM = ''            : Gosub PRO_ADD_START_OBJECT
 JPRONAM = '$bind'    : JPROVAL = BINDS_CODE(LJ) : Gosub PRO_ADD_PROPERTY_TEXT
 If BINDS_POS(LJ) = 1
  #SAM 108421 JPRONAM="$style" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM="$kind" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT #SAM 108421

 Endif
 Gosub PRO_ADD_END_OBJECT :#""
Next LJ
Return

#**
#* PRO_ADD_ACTIONS
#*!
$PRO_ADD_ACTIONS
Local Char     IFACTIONS(250)

Raz CONDLINKS,LNKFADD

If LNKAFF(1) = 1
 MTASWK = maxtab(ASHW.ASWR(I).ASWK)
Else
 MTASWK = maxtab(ASHW.ASWK)
Endif

For LJ=1 To MTASWK
 If LNKAFF(1) = 1
  JASWL = ASHW.ASWR(I).ASWK(LJ)
 Else
  JASWL = ASHW.ASWK(LJ)
 Endif

 ISALINK    = (JASWL.TYPLNK=1 & !find(JASWL.CMPLNK,17,18)) or (find(JASWL.TYPLNK,3,4,5,6)>0 & JASWL.CMPLNK<>19)
 #LNKFADD(LJ) = !ISALINK & !len(JASWL.ANCLNK)
 If !ISALINK
  ISALINK  = ISALINK
 Endif
 LNKFADD(LJ) = !ISALINK &  (JASWL.ANCLNK = LNKANC) & JASWL.CMPLNK<>19
 LNKFADD(LJ) = LNKFADD(LJ) & JASWL.CODLNK <>"$abort" :#SAM 108421
 If LNKFADD(LJ)
  Gosub PRO_GET_LINK_COND
  Gosub PRO_UPD_LINKS_COND
 Endif
Next LJ

If len(CONDLINKS)
 #Generate the code
 IFACTIONS = 'If '+ func GET_CONDITION('(instr(1,"e",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 JSTATEMENT = IFACTIONS : Gosub PRO_ST_IF

 JPRONAM = '$actions' : Gosub PRO_ADD_START_OBJECT

 #Representation's actions
 For LJ=1 To MTASWK
  If LNKFADD(LJ)
   If LNKAFF(1) = 1
    JASWL = ASHW.ASWR(I).ASWK(LJ)
   Else
    JASWL = ASHW.ASWK(LJ)
   Endif
   Gosub PRO_GET_LINK_COND
   If instr(1,CONDLINK,"e")>0
    JPRONAM = JASWL.CODLNK : Gosub PRO_ADD_START_OBJECT :#$action
    #title
    JTITLE  = JASWL.INTLNK : LOCALIAS = "action"+JASWL.CODLNK : Gosub PRO_ADD_TITLE :#SAM 115576
    If ASHW.ASWFAC(2).AFFLNKFAC = JASWL.AFFLNK & ASHW.ASWFAC(2).LNKMENFAC = JASWL.CODLNK
     #SAM 108421 JPRONAM="$style" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT
     JPRONAM="$kind" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT : #SAM 108421
    Endif
    If JASWL.TYPLNK = 3
     JPRONAM="$method": JPROVAL="POST" :Gosub PRO_ADD_PROPERTY_TEXT
    Endif
    #attributes
    For K=1 To maxtab(JASWL.ATT)
     JPRONAM = JASWL.ATT(K).COD
     JPROVAL = num$(JASWL.ATT(K).ATT)
     Gosub PRO_ADD_PROPERTY
    Next K
    #parameters
    If maxtab(JASWL.ATBKEY) or maxtab(JASWL.ATBPAR)
     JPRONAM = '$parameters' : Gosub PRO_ADD_START_OBJECT
     For K=1 To maxtab(JASWL.ATBKEY)
      JPRONAM = 'key'+num$(K)
      If len(JASWL.ATBKEY(K).ALIAS)
       JPROVAL = '{'+JASWL.ATBKEY(K).ALIAS+'}'
      Else
       JPROVAL = ctrans(JASWL.ATBKEY(K).VALEUR,'"','')
      Endif
      If len(JPROVAL) : Gosub PRO_ADD_PROPERTY_TEXT : Endif
     Next K

     If maxtab(JASWL.ATBPAR)>0 & find(2,JASWL.ATBPAR(1..maxtab(JASWL.ATBPAR)).TYPAFF)
      JPRONAM = '$properties' : Gosub PRO_ADD_START_OBJECT
      For JI=1 To maxtab(JASWL.ATBPAR)
       If JASWL.ATBPAR(JI).TYPAFF=2
        JPRONAM = JASWL.ATBPAR(JI).CODPAR : Gosub PRO_ADD_START_OBJECT :#param...
        JPRONAM = '$type' : JPROVAL = func GET_JSON_TYPE(JASWL.ATBPAR(JI).TYPINT,JASWL.ATBPAR(JI).NOLIB) : Gosub PRO_ADD_PROPERTY_TEXT

        JPRONAM = '$isReadOnly' : JPROVAL ='false' : Gosub PRO_ADD_PROPERTY
        JTITLE = JASWL.ATBPAR(JI).DESPAR   : Gosub PRO_ADD_TITLE
        Gosub PRO_ADD_END_OBJECT : #param...
       Endif
      Next JI
      Gosub PRO_ADD_END_OBJECT : #$properties
     Endif

     For K=1 To maxtab(JASWL.ATBPAR)
      JPRONAM = JASWL.ATBPAR(K).CODPAR
      If len(JASWL.ATBPAR(K).ALIAS)
       JPROVAL = '{'+JASWL.ATBPAR(K).ALIAS+'}'
      Else
       JPROVAL = ctrans(JASWL.ATBPAR(K).VALEUR,'"','')
      Endif
      Gosub PRO_ADD_PROPERTY_TEXT
     Next K
     Gosub PRO_ADD_END_OBJECT : #$parameters
    Endif
    #links
    If maxtab(JASWL.ALNK)
     JPRONAM = '$links' : Gosub PRO_ADD_START_OBJECT
     JASWA = JASWL : #Keep memory of JASWL
     #SAM 108421 >
     If JASWL.CODLNK ="$save"
      For K=1 To maxtab(JASWL.ALNK)
       If JASWA.ALNK(K).CODLNK = "$details"
       JASWL = JASWA.ALNK(K)
       JASWL.CODLNK="$redirect"
       FTARGET=0
       Gosub PRO_ADD_LINK
       Endif
      Next K
      #SAM 108421 <
     Else
      For K=1 To maxtab(JASWL.ALNK)
       JASWL = JASWA.ALNK(K) : FTARGET=0 : Gosub PRO_ADD_LINK
      Next K
     Endif
     JASWL = JASWA: #Restore JASWL
     Gosub PRO_ADD_END_OBJECT : #$links
    Endif

    Gosub PRO_ADD_END_OBJECT : #$action
   Endif
 Endif
Next LJ

 Gosub PRO_ADD_END_OBJECT : #$actions
 JSTATEMENT = IFACTIONS : Gosub PRO_ST_ENDIF
Endif
Return

#**
#* PRO_ADD_LINKS_AND_ACTIONS
#*!
$PRO_ADD_LINKS_AND_ACTIONS
Gosub PRO_ADD_LINKS
Gosub PRO_ADD_ACTIONS
Return

#**
#* PRO_ADD_START_LAYOUT
#*!
$PRO_ADD_START_LAYOUT
JPRONAM = ''          : Gosub PRO_ADD_START_OBJECT
If LAYOUT_TITLE
 JTITLE = LAYOUT_TITLE : Gosub PRO_ADD_TITLE
#Else
# JPRONAM = '$title'    : JPROVAL = LAYOUT_CODE             : Gosub PRO_ADD_PROPERTY_TEXT
Endif
JPRONAM = '$category' : JPROVAL = LAYOUT_CATEGORY         : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$layout'   : Gosub PRO_ADD_START_OBJECT
JPRONAM = '$items'    : Gosub PRO_ADD_START_ARRAY_COND
Return

#**
#* PRO_ADD_START_OBJECT_COND
#*!
$PRO_ADD_START_OBJECT_COND
JSQ="'"
JNODEIF(JLEV)=1
JNODETYPE='{' : Gosub PRO_ADD_START_NODE
Return
#**
#* PRO_ADD_START_OBJECT
#*!
$PRO_ADD_START_OBJECT
JSQ="'"
JNODEIF(JLEV)=0
JNODETYPE='{' : Gosub PRO_ADD_START_NODE
Return


#**
#* PRO_ADD_START_ARRAY_COND
#*!
$PRO_ADD_START_ARRAY_COND
JNODEIF(JLEV)=1
JNODETYPE='[' : Gosub PRO_ADD_START_NODE
Return

#**
#* PRO_ADD_START_ARRAY
#*!
$PRO_ADD_START_ARRAY
JSQ="'"
JNODEIF(JLEV)=0
JNODETYPE='[' : Gosub PRO_ADD_START_NODE
Return

#**
#* PRO_ADD_START_NODE
#*!
$PRO_ADD_START_NODE
If len(JPRONAM) > 0
 JSTATEMENT = '"'+JPRONAM + '":'+JNODETYPE
Else
 JSTATEMENT = JNODETYPE
Endif

If JLEV>1 & JNODEIF(JLEV-1)=1
 Gosub PRO_ST_CLOSE
 Gosub PRO_ST_WCLOB
 JSTATEMENT   = "SEP("+num$(JLEV-1)+")+"+JSQ + JSTATEMENT
 JSTATEMENT += "' : SEP("+num$(JLEV-1)+")=','"
 Gosub PRO_ST_LINE
Elsif JNODEIF(JLEV)
 Gosub PRO_ST_CLOSE
 Gosub PRO_ST_WCLOB
 JSTATEMENT   = "'"+JSEP(JLEV) + JSTATEMENT
 JSTATEMENT += "' : SEP("+num$(JLEV)+")=''"
  Gosub PRO_ST_LINE
Else
 JSTATEMENT = JSEP(JLEV) + JSTATEMENT
 Gosub PRO_ST_APPEND
Endif

JSEP(JLEV)=','
JLEV     +=1
JSEP(JLEV)=''
Return

#**
#* PRO_ADD_SEPARATOR
#*!
$PRO_ADD_SEPARATOR
JSTATEMENT = ","
Gosub PRO_ST_APPEND
JSEP(JLEV)=''
Return

#**
#* PRO_ADD_END_OBJECT
#*!
$PRO_ADD_END_OBJECT
JNODETYPE='}' : Gosub PRO_ADD_END_NODE
Return


#**
#* PRO_ADD_END_ARRAY
#*!
$PRO_ADD_END_ARRAY
JNODETYPE=']' : Gosub PRO_ADD_END_NODE
Return

#**
#* PRO_ADD_END_NODE
#*!
$PRO_ADD_END_NODE
JSTATEMENT = JNODETYPE
Gosub PRO_ST_APPEND
JLEV        -=1
JSEP(JLEV)   =','
Return


#**
#* PRO_ADD_END_LAYOUT
#*!
$PRO_ADD_END_LAYOUT
Gosub PRO_ADD_END_ARRAY  : #$items
Gosub PRO_ADD_END_OBJECT : #$layout
Gosub PRO_ADD_END_OBJECT : #
Return

#**
#* JSOVAR
#*
#* @param V
#*!
Funprog JSOVAR(V)
Value Char V
End "'+"+V+"+'"



#**
#* GET_CONDITION
#*!
Funprog GET_CONDITION(CONDITION,CONDNBR,CONDTBL,BLOC)
Value Char CONDITION
Variable Integer CONDNBR
Variable  Char CONDTBL()(1..)
Variable Clbfile BLOC()

Local Integer I

I = find(CONDITION,CONDTBL)
If !I
 CONDNBR += 1 : I = CONDNBR :CONDTBL(CONDNBR) = CONDITION
 Call APPEND_STATEMENT(1   ,BLOC,left$('PC('+num$(CONDNBR)+')   ',7)+'= '+CONDITION+chr$(10))
Endif
End 'PC('+num$(I)+')'

#**
#* SHRINK_PROTOTYPE
#*
#* @param IN
#*!
Funprog SHRINK_PROTOTYPE(IN)
Variable Clbfile IN()

Local Clbfile TAG
Local Clbfile LINE,OUT
Local Integer LLEN:LLEN=0
Local Integer PPOS:PPOS=1
Local Integer PEOL,PTAG,PQUO

Local Clbfile IFSTATEMENT
Local Clbfile LASTLINE



While PPOS < len(IN)
 PEOL = instr(PPOS,IN, chr$(10))
 If !PEOL : PEOL = len(IN) : Endif

 Raz TAG
 PTAG = instr(PPOS,IN,":#")

 If PTAG & PTAG < PEOL
  TAG =  mid$(IN,PTAG+2,1)
 Endif
 If TAG="+"
  #line which can be concatenated :
  If len(LASTLINE)
   Append OUT,LASTLINE
   Raz LASTLINE,IFSTATEMENT
  Endif

  If LLEN > 0
   #Can we concatenate the line with the previous line :
   If (LLEN + (PTAG-PPOS)) < 250
    #YES=>
    #Add the right part of the line
    PQUO = instr(PPOS,IN,"'")
    LINE = mid$(IN,PQUO+1,PTAG-PQUO-2)
    LLEN += len(LINE)
    Append OUT,LINE
   Else
    #NO=>
    #1°) Close the previous line
    Append OUT,"'"+chr$(10)
    #2°) Add the 'left' part of the line to OUT
    LINE = mid$(IN,PPOS,PTAG-PPOS-1)
    LLEN = len(LINE)
    Append OUT,LINE
   Endif
  Else
   #Add the 'left' part of the line to OUT
   LINE=mid$(IN,PPOS,PTAG-PPOS-1)
   LLEN += len(LINE)
   Append OUT,LINE
  Endif
 Elsif TAG="I"
  If LLEN > 0
   #Close the last line if necessary
   Append OUT,"'"+chr$(10)
   LLEN = 0
  Endif
  If len(IFSTATEMENT)
    #Append the previous line and forget it :
    Append OUT,LASTLINE
  Endif

  #Keep memory of the current line and of the if statement
  LASTLINE    = mid$(IN,PPOS  ,PEOL+1-PPOS)
  IFSTATEMENT = mid$(IN,PTAG+2,PEOL-PTAG-1)
 Else
  If LLEN > 0
   #Close the last line if necessary
   Append OUT,"'"+chr$(10)
   LLEN = 0
  Endif

  LINE=mid$(IN,PPOS,PEOL+1-PPOS)
  If len(IFSTATEMENT) & !instr(1,LINE,IFSTATEMENT)
   #Append the previous line
   Append OUT,LASTLINE
   #Append the current line
   LINE=mid$(IN,PPOS,PEOL+1-PPOS)
   Append OUT,LINE
  Elsif !len(IFSTATEMENT)
   #Add the line to OUT
   Append OUT,LINE
  Endif
  Raz LASTLINE,IFSTATEMENT
 Endif

 #Next line
 PPOS =PEOL+1
Wend

If len(LASTLINE)
 Append OUT,LASTLINE
Endif

If LLEN > 0
 #Close the last line if necessary
 Append OUT,"'"+chr$(10)
Endif

End OUT

#**
#* UPDATE_URL_LOB
#*
#* @param URL
#* @param ACLAPARFLD
#*!
Subprog UPDATE_URL_LOB(_URL,_ACLAPARFLD)
Variable Char     _URL
Value Instance _ACLAPARFLD(1..) Using OBJECT

Local Integer I
Local Char    PARVAL(250)

Local Integer ACTXCOUNT,ACTXI
Local Char ACTXJSONAME(20)(1..)
Local Char ACTXX3NAME(50)(1..)
Call LOAD_ACTX_PROPERTIES([L]ACTXCOUNT,[L]ACTXJSONAME,[L]ACTXX3NAME)

For I=1 To maxtab(_ACLAPARFLD)
 If len(_ACLAPARFLD(I).ALIAS) > 0
  _URL += [V]CST_AURLSEPLOB+"{"
  _URL += _ACLAPARFLD(I).ALIAS
  _URL += "}"
 Else
#Issue2190
#  PARVAL     = ctrans(_ACLAPARFLD(I).VALEUR,'"','')
  PARVAL     = func ASHWVALLEC.FVALKEY(_ACLAPARFLD(I).VALEUR,_ACLAPARFLD(I).TYPINT)
  PARVAL     = ctrans(PARVAL,'"','')
  #NO: null value is correct
  #If len(PARVAL) > 0

   _URL += [V]CST_AURLSEPLOB
   ACTXI = find(PARVAL,ACTXX3NAME)
  If ACTXI
   _URL += "{" +[L]ACTXJSONAME(ACTXI) +  "}"
  Else
   _URL += PARVAL
  Endif
  #Endif
 Endif
Next I

End

#**
#* GET_TRANSITION_URL
#*
#* @param LBASEURL
#*!
Funprog GET_TRANSITION_URL(LBASEURL)
Value Char LBASEURL
Local Integer K
Local Char    BASEX3(250) , CLE(10)
BASEX3 = LBASEURL
CLE = "sdata"
K = instr(1,BASEX3,CLE)
If K
 BASEX3 = left$(BASEX3,K-1)+"trans"+right$(BASEX3,K+len(CLE))
Endif
End BASEX3

# X3PLAT-1475 Workflow link on representation
Funprog GET_SYRA_URL(LBASEURL)
Value Char LBASEURL
Local Integer K
Local Char    BASEX3(250) , CLE(10)
BASEX3 = LBASEURL
CLE = "trans"
K = instr(1,BASEX3,CLE)
If K
 BASEX3 = left$(BASEX3,K-1)+"sdata"+right$(BASEX3,K+len(CLE))
Endif
End BASEX3

#**
#* GET_HELP_URL
#*
#* @param LBASEURL
#*!
Funprog GET_HELP_URL(LBASEURL)
Value Char LBASEURL
Local Integer K
Local Char    BASEX3(250) , CLE(10)
BASEX3 = LBASEURL
CLE = "sdata"
K = instr(1,BASEX3,CLE)
If K
 BASEX3 = left$(BASEX3,K-1)+"help/{$actxLanIso}"+right$(BASEX3,K+len(CLE))
Endif
End BASEX3

#**
#* GET_REPKEYS
#*
#* @param ASWLNK
#*!
Funprog GET_REPKEYS(ASWLNK,ALIASSRC,ALIASDST,COLPRONBR)
Variable Instance ASWLNK Using C_ASWLNK
Variable Char ALIASSRC
Variable Char ALIASDST
Value Integer COLPRONBR


Local Integer I
Local Char REPKEYS(250)
Local Char SEP(1)

REPKEYS    = ''
For I=1 To maxtab(ASWLNK.ATBKEY)
 REPKEYS += SEP+ func GET_REPKEY(ASWLNK.ATBKEY(I),ALIASSRC,ALIASDST,COLPRONBR)
 SEP = '~'
Next I
End REPKEYS

#**
#* GET_REPKEY
#*
#* @param ASWPAR
#*!
Funprog GET_REPKEY(ASWPAR,ALIASSRC,ALIASDST,COLPRONBR)
Variable Instance ASWPAR Using C_ASWPAR
Variable Char ALIASSRC
Variable Char ALIASDST
Value Integer COLPRONBR


Local Char REPKEY(80)
If len(ASWPAR.ALIAS)
 REPKEY = '{'
 #108731
 #If len(ALIASDST) & len(ALIASSRC) & COLPRONBR=1
 #??If len(ALIASDST) & len(ALIASSRC) & COLPRONBR=1 & ALIASDST=num$(ASWPAR.LOO)
 If len(ALIASDST) & len(ALIASSRC) & COLPRONBR=1 & ASWPAR.ALIAS=ALIASSRC
  REPKEY += ALIASDST
 Else
  REPKEY += ASWPAR.ALIAS
 Endif
 REPKEY += '}'
Else
 REPKEY = num$(ASWPAR.VALEUR)
Endif
End REPKEY

#**
#* PRO_ST_WCLOB
#*!
$PRO_ST_WCLOB
Append BLOCS(BPROTO), string$(JPROIND-1," ")
Append BLOCS(BPROTO),"Append ASND.DATA,"
Return
#**
#*
#*!
$PRO_ST_APPEND
If JST_EXP <> "append" or (JST_LENGTH + len(JSTATEMENT)) >= 250
 #Close the previsous line
 Gosub PRO_ST_CLOSE
 Gosub PRO_ST_WCLOB
 Append BLOCS(BPROTO),"'"
 JST_LENGTH = 10 + JPROIND+  len("Append ASND.DATA,")
Endif
Append BLOCS(BPROTO),JSTATEMENT
JST_END = "'"+chr$(10)
JST_EXP = "append"
JST_LENGTH += len(JSTATEMENT)
Raz JSTATEMENT
Return

#**
#*
#*!
$PRO_ST_LINE
Append BLOCS(BPROTO),JSTATEMENT
Append BLOCS(BPROTO),chr$(10)
Raz JSTATEMENT
Return

#**
#* PRO_ST_IF
#*!
$PRO_ST_IF
If JST_EXP <> JSTATEMENT
 Gosub PRO_ST_CLOSE
 Append BLOCS(BPROTO), string$(JPROIND-1," ")
 Append BLOCS(BPROTO),JSTATEMENT
 Append BLOCS(BPROTO),chr$(10)
Else
 #We don't write the If... but we have to RAZ variables :
 Raz JST_END,JST_EXP
Endif
JPROIND += 1
Return


#**
#* PRO_ST_ELSE
#*!
$PRO_ST_ELSE
Gosub PRO_ST_CLOSE
JPROIND -= 1
Append BLOCS(BPROTO), string$(JPROIND-1," ")
Append BLOCS(BPROTO),"Else"
Append BLOCS(BPROTO),chr$(10)
JPROIND += 1
Return

#**
#* PRO_ST_ENDIF
#*!
$PRO_ST_ENDIF
Gosub PRO_ST_CLOSE
JPROIND -= 1
JST_EXP = JSTATEMENT
JST_END = string$(JPROIND-1," ")+ "Endif:#" + JST_EXP + chr$(10)
#108488 remove optimization : too dangerous
Gosub PRO_ST_CLOSE
Return

#**
#*
#*!
$PRO_ST_CLOSE
Append BLOCS(BPROTO), JST_END
Raz JST_END,JST_EXP,JST_LENGTH
Return


#**
#* GET_JSON_TYPE
#*
#* @param X3_TYPE
#*!
Funprog GET_JSON_TYPE(X3_TYPE,MNL)
Value Integer X3_TYPE,MNL

Local Char JSON_TYPE(80) : JSON_TYPE=""
Case  X3_TYPE
 When CST_ATYPTINYINT  : If MNL=1 : JSON_TYPE = func ASYRJSO.TYP('boolean') : Else : JSON_TYPE = func ASYRJSO.TYP('integer') : Endif
 When CST_ATYPSHORTINT : JSON_TYPE = func ASYRJSO.TYP('integer')
 When CST_ATYPINTEGER  : JSON_TYPE = func ASYRJSO.TYP('integer')
 When CST_ATYPDECIMAL  : JSON_TYPE = func ASYRJSO.TYP('decimal')
 When CST_ATYPFLOAT    : JSON_TYPE = func ASYRJSO.TYP('real')
 When CST_ATYPDOUBLE   : JSON_TYPE = func ASYRJSO.TYP('decimal')
 When CST_ATYPCHAR     : JSON_TYPE = func ASYRJSO.TYP('string')
 When CST_ATYPDATE     : JSON_TYPE = func ASYRJSO.TYP('date')
 When CST_ATYPBLOB     : JSON_TYPE = func ASYRJSO.TYP('binary')
 When CST_ATYPCLOB     : JSON_TYPE = func ASYRJSO.TYP('binary')
 When CST_ATYPUUID     : JSON_TYPE = func ASYRJSO.TYP('string')
 When CST_ATYPDATETIME : JSON_TYPE = func ASYRJSO.TYP('datetime')
 When CST_ATYPINSTANCE : JSON_TYPE = func ASYRJSO.TYP('object')
Endcase

End JSON_TYPE

#**
#* GET_SDATA_SEP
#*
#* @param X3_TYPE
#*!
Funprog GET_SDATA_SEP(X3_TYPE)
Value Integer X3_TYPE

Local Char SDATA_SEP(10) : SDATA_SEP=""
Local Char     JSQUOTE(10):JSQUOTE="'+"+'"'+"'"+'"'+"+'"

Case  X3_TYPE
 When CST_ATYPTINYINT      : SDATA_SEP = ""
 When CST_ATYPSHORTINT  : SDATA_SEP = ""
 When CST_ATYPINTEGER    : SDATA_SEP = ""
 When CST_ATYPDECIMAL    : SDATA_SEP = ""
 When CST_ATYPFLOAT        : SDATA_SEP =""
 When CST_ATYPDOUBLE     : SDATA_SEP =""
 When CST_ATYPCHAR         : SDATA_SEP = JSQUOTE
 # GitHubIssue 1132 - 2013-04-30 by VPO : pb si pfiltre avec date
 #When CST_ATYPDATE         : SDATA_SEP = ""
 When CST_ATYPDATE         : SDATA_SEP = "@"
 When CST_ATYPBLOB         : SDATA_SEP = ""
 When CST_ATYPCLOB         : SDATA_SEP = ""
 When CST_ATYPUUID          : SDATA_SEP = JSQUOTE
 When CST_ATYPDATETIME : SDATA_SEP = "@"
 When CST_ATYPINSTANCE : SDATA_SEP = ""
Endcase
End SDATA_SEP

#**
#* DEL_WJSO
#* Delete old treatments :
#* @param CODREP
#*!
Funprog DEL_WJSO(MACHINE,APPLI,CODREP)
Variable Char MACHINE()
Variable Char APPLI()
Value Char CODREP()

Local Integer CMD
Local Char    PREF_FROM(6)
Local Char    PREF_TO(6)

#Delete the current treatment
CMD=1 : PREF_FROM="" : Gosub CMD_WJSO
End ERROR

#**
#* SAVE_WJSO
#* Delete old treatments :
#* @param CODREP
#*!
Funprog SAVE_WJSO(MACHINE,APPLI,CODREP)
Variable Char MACHINE()
Variable Char APPLI()
Value Char CODREP()

Local Integer CMD
Local Char    PREF_FROM(6)
Local Char    PREF_TO(6)

#Copy the current treatment
CMD=2 :  PREF_FROM="" : PREF_TO="_old" : Gosub CMD_WJSO
End ERROR

#**
#* RESTORE_WJSO
#* Delete old treatments :
#* @param CODREP
#*!
Funprog RESTORE_WJSO(MACHINE,APPLI,CODREP)
Variable Char MACHINE()
Variable Char APPLI()
Value Char CODREP()

Local Integer CMD
Local Char    PREF_FROM(6)
Local Char    PREF_TO(6)

#Delete currents treatments :
CMD=1 :  PREF_FROM="" : PREF_TO="_old" : Gosub CMD_WJSO
#Copy 'old' treatments :
CMD=2 :  PREF_FROM="_old" : PREF_TO="" : Gosub CMD_WJSO
#Delete 'old' treatments :
CMD=1 :  PREF_FROM="_old" : PREF_TO="" : Gosub CMD_WJSO
End ERROR

#**
#* CMD_WJSO
#*!
$CMD_WJSO
Local Char    FILE_NAME(GDIMFIC)
Local Char    FILE_FROM(GDIMFIC)
Local Char    FILE_TO(GDIMFIC)
Local Integer ERROR

Local Char WCMDE(250)
WCMDE = adxmac(0)+'@lsadx -a '+nomap-' TRT src'
Local File (TRT(30)) From System WCMDE As [TRT_]

For [TRT_] Where  TRT=func APREFIXTRT.GET_PREFIX_JSO + CODREP+PREF_FROM or (pat(TRT,func APREFIXTRT.GET_PREFIX_JSO +"#" +CODREP+PREF_FROM) <> 0)
 FILE_FROM = filpath("TRT",[TRT_]TRT ,"src",APPLI,"",MACHINE)

 If filinfo(FILE_FROM,0)>=0
  Case CMD
   When 1 : #DELETE
    #Delete the src file
    Call _EFFACE(FILE_FROM,ERROR) From ASYRSYS
    #Delete the adx file
    FILE_FROM = filpath("TRT",[TRT_]TRT ,"adx",APPLI,"",MACHINE)
    Call _EFFACE(FILE_FROM,ERROR) From ASYRSYS
   When 2 : #COPY
    FILE_NAME = [TRT_]TRT
    If right$(FILE_NAME,len(FILE_NAME)-3)="_old" : FILE_NAME= left$(FILE_NAME,len(FILE_NAME)-4) : Endif
    FILE_TO      = filpath("TRT",FILE_NAME+PREF_TO      ,"src",APPLI,"",MACHINE)
    Call _COPIE(FILE_FROM,FILE_TO,ERROR) From ASYRSYS
  Endcase
 Endif
Next TRT_
Close Local File [TRT_]
Return

Subprog SET_LNK_PARAMS(_CODE,_URL)
Value Char _CODE
Variable Char _URL
If _CODE ="$wordreport"
 _URL += "&role={$role}&where={$where}&filter={$filter}&reportMode={reportMode}&doc_uuid={document}"
Elsif _CODE ="$excel" :#SAM 103087
 _URL += "&role={$role}&where={$where}&filter={$filter}&excelReportMode={excelReportMode}&doc_uuid={document}"
Elsif _CODE ="$wordmailmerge"
 _URL += "&role={$role}&where={$where}&filter={$filter}&createMode={creationMode}&doc_uuid={document}"
Endif
End

#**
#* LOAD_ACTX_PROPERTIES
#*
#* @param COUNT
#* @param JSONAME
#* @param X3NAME
#*!
Subprog LOAD_ACTX_PROPERTIES(COUNT,JSONAME,X3NAME)
Variable Integer COUNT
Variable Char JSONAME()(1..)
Variable Char X3NAME()(1..)
COUNT += 1 : JSONAME(COUNT)="$actxUser" : X3NAME(COUNT)="ACTX.USER"
COUNT += 1 : JSONAME(COUNT)="$actxLogin" : X3NAME(COUNT)="ACTX.LOGIN"
COUNT += 1 : JSONAME(COUNT)="$actxFolder" : X3NAME(COUNT)="ACTX.AFOLDER"
COUNT += 1 : JSONAME(COUNT)="$actxSolution" : X3NAME(COUNT)="ACTX.ASOLUTION"
COUNT += 1 : JSONAME(COUNT)="$actxLan"   : X3NAME(COUNT)="ACTX.LAN"
COUNT += 1 : JSONAME(COUNT)="$actxLanIso"   : X3NAME(COUNT)="ACTX.LANISO"
COUNT += 1 : JSONAME(COUNT)="$actxNbLeg"   : X3NAME(COUNT)="num$(ACTX.AFOLD.ANBLEG)"
COUNT += 1 : JSONAME(COUNT)="$actxLegCur"   : X3NAME(COUNT)="ACTX.AFOLD.ALEGCUR"

#- AFOLD.ANBLEG

End

#---------------------------------------------------------------------------------------------------#
$DECODE_CRITERIA
Local Char LIGNE(250)
Local Integer I,J,K
If ASHW.ACLA.TYPCLA=2

 Gosub DEFVAR From ASHWQRY
 Gosub LOAD_TABLE_FOR_QUERY  From ASHWQRY

 For K=1 To maxtab(ASHW.ACLA.ACLAK)
  OK = find(ASHW.ACLA.ACLAK(K).ABRLNK,WABRUSED(1..NBABRUSED))
  If OK
   For J=1 To maxtab(ASHW.ASWR)
    If   ASHW.ASWR(J).QRYPRO<>2 and  ASHW.ASWR(J).LOKPRO<>2
&   & ASHW.ACLA.ACLAK(K).ABRLNK=ASHW.ASWR(J).ABRTAB
&   & find(ASHW.ASWR(J).FLDCLA,ASHW.ACLA.ACLAK(K).INDEX)>0
     Gosub ADD_LOAD_PROPERTIES
    Endif
   Next
  Endif
 Next
 For J=1 To maxtab(ASHW.ASWR)
  If !find(ASHW.ASWR(J).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)
   If  ASHW.ASWR(J).QRYPRO=2 or ASHW.ASWR(J).LOKPRO=2
    Gosub ADD_LOAD_PROPERTIES
   Endif
  Endif
 Next
Endif
Return

#---------------------------------------------------------------------------------------------------#
$ADD_LOAD_PROPERTIES
LIGNE = 'NBPRO += 1 : T1(NBPRO) = "'+ASHW.ASWR(J).ALIAS+'"'
LIGNE+= ' : T0(NBPRO) = "[F:'
Case ASHW.ASWR(J).ACLAF.ATY.CODTYP
 When "AXX","AX1","AX2","AX3","ATX"
  LIGNE += ASHW.ASWR(J).ABRTXT+']TEXTE"'
  If ASHW.TYPMSKREP<>1
   Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), LIGNE)
  Endif
 When Default :
  If ASHW.ASWR(J).FLDCLA<>""
   LIGNE += ASHW.ASWR(J).ABRTAB+']'+ASHW.ASWR(J).FLDCLA+'"'
   If ASHW.TYPMSKREP<>1
    Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), LIGNE)
   Endif
   If dim(ASHW.ASWR(J).ACLAF.FLGBASFLD)>0
    Read [ATZ]CODZONE = ASHW.ASWR(J).TABTAB;ASHW.ASWR(J).FLDCLA
    If fstat
     ASHW.ASWR(J).ACLAF.FLGBASFLD=1
    Endif
   Endif
  Endif
Endcase
Return

