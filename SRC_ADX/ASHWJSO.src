#<AdxTL>@(#)3.0.0.0 $Revision$
Gosub TEST From ASHWVAL
End


#**
#* VALTRT_JSO : Write and validate a WMJSO treatment
#*!
Subprog VALTRT_JSO(DOSSIER,CODREP,ASHW,AERR)
Value Char    DOSSIER
Value Char    CODREP
Variable     Instance  ASHW  Using C_ASW
Variable     Instance  AERR(1..) Using C_AERROR

Local Integer OK
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Schar   IDENTTRT(30),IDENTSRH(30)
Local Char    MAGIC(80)
Local Clbfile CLOB,CLEFT,CRIGHT
Local Char    SEP(1)

Local Integer JPROIND:JPROIND=1

Local Integer JLEV: JLEV=0
Local Char    JSEP(1)(0..)
Local Integer JNODEIF(0..)
Local Integer NBLOC,TBLLOCIDX(1..)
Local Char    TBLLOCNAM(100)(1..) : #SAM 115576

Local Integer NBMES,TBLMESNUM(1..),TBLMESCHP(1..)
Local Char    GRPGRI(1)
Local Char    GRPALIAS(1)
Local Char    GRPPTH(1)
Local Char    TBLGRPPTH(250)(1..)
Local Integer TBLGRPMIN(1..)
Local Integer TBLGRPMAX(1..)
Local Char    TBLGRPCOND(80)(1..)
Local Char    NOMTRTSRH(250),SIDXTRT(2)
Local Char    STATEMENT(250)
Local Integer I,J,K,L
Local Integer IDXTRT : IDXTRT=1
Local Integer TRTMAXSIZE : TRTMAXSIZE = 32767
Local Integer PSL,PEL,PEF,PSP,POS,SLENGTH
Local Char      JST_END(250),JST_EXP(250)
Local Integer JST_LENGTH
Local Integer REPLEV : REPLEV=0
Local Integer COLPRONBR : COLPRONBR=0

Gosub DEFVAR From ASHWVALTRT

Local File ADOSSIER [ADS]
Local File =DOSSIER+".APLSTD"      [AST]

Local Instance ASWACTIONS(1..) Using C_ASWACTION
Call LOAD_ACTIONS(ASWACTIONS) From SUBASW_TOOL

#If toupper(GACTX.LOGIN)="EBOYARD"
# For J=1 To maxtab(ASHW.ACLAGRI)
#  For K=1 To min(20,maxtab(ASHW.ACLAGRI(J))) :#TODO : CODGRP is limited to 20 items
#   Break (len(ASHW.ACLAGRI(J).CODGRP(K))=0)
#   Call ECR_TRACE("ASHW.ACLAGRI("+num$(J)+").CODGRP("+num$(K)+"):"-ASHW.ACLAGRI(J).CODGRP(K)-"CRECLAGRP:"-num$(ASHW.ACLAGRI(J).CRECLAGRP(K)),0) From GESECRAN
#  Next K
# Next J
#Endif

Gosub DEF_VAR_BLOCS
Gosub DEF_VAR_LINK
Gosub DEF_VAR_JSON

Gosub LOAD_BLOCS
GRPGRI = ASHW.GRPGRI(1)

CONDNBR+=1
Call APPEND_CLASSE(DOSSIER,CODREP,ASHW,REPLEV,GRPGRI,GRPALIAS,GRPPTH,BLOCS,JPROIND,PRONBR,TBLPRO,TBLBLC,JLEV,JSEP,JNODEIF,NBLOC,TBLLOCIDX,TBLLOCNAM,CONDNBR,CONDTBL,0,0,TBLGRPPTH,TBLGRPMIN,TBLGRPMAX,
& TBLGRPCOND,
& ASWACTIONS ,JST_END,JST_EXP,JST_LENGTH,NBMES,TBLMESNUM,TBLMESCHP,COLPRONBR)
Gosub CLOSE_BLOCS

If maxtab(AERR)>0 : Goto FIN_VALTRT_JSO : Endif

#Append all blocs in one single treatment
For I=1 To NBLOCS
 Append CLOB,BLOCS(I)
Next I


#Split the treatment :
IDXTRT=1
SIDXTRT=''
While len(CLOB)  > 0
  PSL=1 : PEL=1 : PEF=0 : PSP = 0 : SLENGTH=0
  While PEL < len(CLOB)
   #Search the end of line
   PEL  = instr(PSL,CLOB,chr$(10))
   If !PEL : PEL = len(CLOB) : Endif
    #Does the line begin by Endif :
   POS = instr(PSL,CLOB,"Endif")
   If   POS=PSL
    #Yes : memorize its position :
    PEF = PEL
   Endif
   #Search '
   POS = instr(PSL,CLOB,"'")
   If POS & (POS < PEL)
    #The line contains a string :
    SLENGTH += (PEL-POS)
   Else : #108488
    SLENGTH += (PEL-PSL)+1
   Endif
   If  (SLENGTH > TRTMAXSIZE)
    #Too much string in the treatment = split!
    PSP = PEF
     #108488
     If !PSP
       PEF=instr(PSL,CLOB,chr$(10)+"Endif")
       PSP = PEF
       If PEF
        PSP=instr(PEF+5,CLOB,chr$(10))
       Endif
     Endif
    Break
   Endif
   PSL = PEL+1
  Wend
  If PSP
   #Split the trearment
   CLEFT = left$(CLOB,PSP)
   Append CLEFT, chr$(10) : #108488
   Append CLEFT, "Gosub APPEND_PROTOTYPE From " + func APREFIXTRT.GET_PREFIX_JSO + num$(IDXTRT+1)+ CODREP + chr$(10)
   Append CLEFT, "Return" + chr$(10)
   CRIGHT = "$APPEND_PROTOTYPE" + chr$(10)
   Append CRIGHT, right$(CLOB,PSP+1)
 Else
  CLEFT = CLOB
  Raz CRIGHT
 Endif

 NOMTRTSRH = func APREFIXTRT.GET_PREFIX_JSO + SIDXTRT+ CODREP
 MAGIC           = mess(77,133,1) : # Superviseur Adonix
 IDENTTRT      = "#"+NOMTRTSRH
 IDENTSRH     = "##"-"?IDENTQRY?"-"SEARCH ##"
 TITETA          = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
 Call STC_DEB([L]APPLI,[L]MACHINE,[L]NOMTRTSRH,[L]IDENTTRT,[L]CODREP,IDENTSRH,[L]MAGIC,[L]TITETA,"TRT") From ACLASUB
 Call TRT_FIN([L]CLEFT,[L]NOMTRTSRH,0,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB

 IDXTRT+=1
 SIDXTRT = num$(IDXTRT)
 #prepare next iteration :
 CLOB = CRIGHT
Wend
$FIN_VALTRT_JSO
If ASWACTIONS<>null
 FreeGroup ASWACTIONS
Endif
End

#**
#* APPEND_CLASSE
#*!
Subprog APPEND_CLASSE(DOSSIER,CODREP,ASHW,REPLEV,GRPGRI,GRPALIAS,GRPPTH,BLOCS,JPROIND,PRONBR,TBLPRO,TBLBLC,JLEV,JSEP,JNODEIF,NBLOC,TBLLOCIDX,TBLLOCNAM,CONDNBR,CONDTBL,COLMIN,COLMAX,TBLGRPPTH,TBLGRPMIN
& ,TBLGRPMAX
& ,TBLGRPCOND,ASWACTIONS,JST_END,JST_EXP,JST_LENGTH,NBMES,TBLMESNUM,TBLMESCHP,COLPRONBR)
Value Char            DOSSIER
Value Char            CODREP
Variable   Instance ASHW     Using C_ASW
Value      Integer    REPLEV
Value      Char       GRPGRI
Value      Char       GRPALIAS
Value      Char       GRPPTH
Variable   Clbfile    BLOCS()(1..)
Variable   Integer    JPROIND
Variable   Integer    PRONBR
Variable   Char       TBLPRO()(1..)
Variable   Char       TBLBLC()(1..)
Variable   Integer    JLEV
Variable   Char       JSEP()(0..)
Variable   Integer    JNODEIF(0..)
Variable   Integer    NBLOC
Variable   Integer    TBLLOCIDX(1..)
Variable Char TBLLOCNAM()(1..)
Variable   Integer    CONDNBR
Variable   Char       CONDTBL()(1..)
Value      Integer    COLMIN
Value      Integer    COLMAX
Variable   Char       TBLGRPPTH()(1..)
Variable   Integer    TBLGRPMIN(1..)
Variable   Integer    TBLGRPMAX(1..)
Variable   Char       TBLGRPCOND()(1..)
Variable   Instance   ASWACTIONS(1..) Using C_ASWACTION
Variable  Char JST_END
Variable  Char JST_EXP
Variable Integer JST_LENGTH
Variable Integer NBMES
Variable Integer TBLMESNUM(1..)
Variable Integer TBLMESCHP(1..)
Value Integer COLPRONBR

Local Char    SEP(1)
Local Integer KEYTYPE
Local Integer I,J,K,FJ,L,P,PC1,PC2
Local Char    CONDPRO(80),CONDPROST(80),CONDHIDDEN(80),CONDDISPLAYED(80),CONDEXCLUDED(80),CONDHIDST(80),ACHR(1)
Local Char    ALIASST(250)
Local Char    PTHSRH(250),PTHPRO(250)
Local Char    PROURLPRE(250),PROURLSUF(250),PROTYPE(100),PROKEY(250),PROVAL(250)
Local Integer PROLEN
Local Char    CAPABILITY(20)(1..4)

Local Integer COLNBR,CONDCOLIDX
Local Integer COLPRO(1..)
Local Char    CONDGRP(250)
Local Integer ISCOLLECTION,ISARRAY,ISARRAYOFITEMS,ISARRAYOFOBJECTS,ISOBJECT,CHECKCONDPRO

Local Integer CONDGRPTBLNBR
Local Integer CONDGRPTBLIDX
Local Integer CONDGRPTBLCOUNT(1..)
Local Char    CONDGRPTBLCOND(10)(1..)
Local Char    CONDGRPTLBSEP(1)

Local Integer DISPGRPTBLNBR
Local Integer DISPGRPTBLIDX
Local Integer DISPGRPTBLCOUNT(1..)
Local Char    DISPGRPTBLCOND(10)(1..)
Local Char    DISPGRPTLBSEP(1)

Local Char FMT(30)

Raz CONDGRPTBLNBR,CONDGRPTBLCOUNT,CONDGRPTBLCOND

Gosub DEF_VAR_BLOCS
Gosub DEF_VAR_LINK
Gosub DEF_VAR_JSON


REPLEV += 1
CONDCOLIDX = CONDNBR

ISCOLLECTION             = (len(GRPGRI)>0)
ISARRAY                      = ISCOLLECTION & !(COLMIN=1 & COLMAX=1)
ISARRAYOFITEMS       = ISARRAY
ISARRAYOFOBJECTS  = ISARRAY

If ISARRAY
##TODO For I=1 To maxtab(ASHW.ASWR)
##  If ASHW.ASWR(I).GRIPRO = GRPPTH or left$(ASHW.ASWR(I).GRIPRO,len(GRPPTH)+1) = GRPPTH+"."
##   #The property belongs to the collection
##   COLPRONBR += 1
##  Endif
## Next I
  ISARRAYOFITEMS       = ISARRAY   & (COLPRONBR=1)
  ISARRAYOFOBJECTS  = ISARRAY   & (COLPRONBR>1)
Endif


If ISARRAY
 #JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
 If ISARRAYOFOBJECTS
  JPRONAM = '$type'          : JPROVAL = "application/json"   : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM = '$instanceUrl' : JPROVAL =  '{$instanceUrl}/'+ GRPGRI + '('+JSQUOTE +'{$uuid}'+JSQUOTE + ')': Gosub PRO_ADD_PROPERTY_TEXT

  JPRONAM = '$properties'    : Gosub PRO_ADD_START_OBJECT_COND
 Endif
 #JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF

 Gosub PRO_ST_CLOSE
 JSTATEMENT = string$(JPROIND-1," ")+"SEP("+num$(JLEV-1)+")=''" : Gosub PRO_ST_LINE

Elsif !len(GRPGRI)
 JPRONAM = '$properties'    : Gosub PRO_ADD_START_OBJECT_COND
Endif

For I=1 To maxtab(ASHW.ASWR)
 PASWR = ASHW.ASWR(I)
 If ASHW.ASWR(I).GRIPRO = GRPPTH
  #The property belongs to the collection
  Raz ALIASST,ALIASDST,ALIASDST
  If len(GRPALIAS) :   ALIASSRC = ASHW.ASWR(I).ALIAS : Endif

  Raz CONDPRO :#is the property present in the collection ?
  CONDPRO +=string$(ASHW.ASWR(I).DETPRO=2,"d" )
  CONDPRO +=string$(ASHW.ASWR(I).EDIPRO=2,"e" )
  CONDPRO +=string$(ASHW.ASWR(I).QRYPRO=2,"qb")
  CONDPRO +=string$(ASHW.ASWR(I).LOKPRO=2,"l" )
  CONDPRO +=string$(ASHW.ASWR(I).SUMPRO=2,"s" )

  #Gestion LOB
  If find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)<>0
&  & find(19,ASHW.ASWR(I).ASWK(1..maxtab(ASHW.ASWR(I).ASWK)).CMPLNK)=0
   Raz CONDPRO
  Endif

  Raz CONDHIDDEN :#is the property hidden ?
  CONDHIDDEN +=string$(ASHW.ASWR(I).STADETPRO=2,"d" )
  CONDHIDDEN +=string$(ASHW.ASWR(I).STAEDIPRO=2,"e" )
  CONDHIDDEN +=string$(ASHW.ASWR(I).STAQRYPRO=2,"qb")
  CONDHIDDEN +=string$(ASHW.ASWR(I).STALOKPRO=2,"l" )
  CONDHIDDEN +=string$(ASHW.ASWR(I).STASUMPRO=2,"s" )

  Raz CONDDISPLAYED :#is the property displayed ?
  CONDDISPLAYED +=string$((ASHW.ASWR(I).DETPRO=2)&(ASHW.ASWR(I).STADETPRO<>2),"d" )
  CONDDISPLAYED +=string$((ASHW.ASWR(I).EDIPRO=2)&(ASHW.ASWR(I).STAEDIPRO<>2),"e" )
  CONDDISPLAYED +=string$((ASHW.ASWR(I).QRYPRO=2)&(ASHW.ASWR(I).STAQRYPRO<>2),"qb")
  CONDDISPLAYED +=string$((ASHW.ASWR(I).LOKPRO=2)&(ASHW.ASWR(I).STALOKPRO<>2),"l" )
  CONDDISPLAYED +=string$((ASHW.ASWR(I).SUMPRO=2)&(ASHW.ASWR(I).STASUMPRO<>2),"s" )

   If len(CONDDISPLAYED) = 6
    CONDDISPLAYED = '1'
   Else
    CONDDISPLAYED   = func GET_CONDITION('(instr(1,"'+CONDDISPLAYED+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
   Endif

  If len(CONDPRO) > 0
   #Is it a reference : ?
   Gosub SET_ISREFERENCE

   PRONBR+=1 : COLNBR+=1 : COLPRO(COLNBR) = PRONBR

   If len(CONDPRO) = 6
    CONDPRO = '1'
   Else
    CONDPRO   = func GET_CONDITION('(instr(1,"'+CONDPRO+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
    CONDPROST = 'If '+CONDPRO
    CHECKCONDPRO = 1
    If CHECKCONDPRO :JSTATEMENT = CONDPROST: Gosub PRO_ST_IF :Endif
   Endif

   #Update the presence condition of the collection :
   CONDGRPTBLIDX = find(CONDPRO,CONDGRPTBLCOND)
   If CONDGRPTBLIDX
    CONDGRPTBLCOUNT(CONDGRPTBLIDX) += 1
   Else
    CONDGRPTBLNBR += 1
    CONDGRPTBLCOND(CONDGRPTBLNBR)  = CONDPRO
    CONDGRPTBLCOUNT(CONDGRPTBLNBR) = 1
   Endif

   #Update the "displayed" condition of the collection :
   DISPGRPTBLIDX = find(CONDDISPLAYED,DISPGRPTBLCOND)
   If DISPGRPTBLIDX
    DISPGRPTBLCOUNT(DISPGRPTBLIDX) += 1
   Else
    DISPGRPTBLNBR += 1
    DISPGRPTBLCOND(DISPGRPTBLNBR)  = CONDDISPLAYED
    DISPGRPTBLCOUNT(DISPGRPTBLNBR) = 1
   Endif

   If !ISREFERENCE
    #it isn't a reference :
    #Compute the type of prototype
    Raz PROURLPRE
    If ASHW.ASWR(I).ACLAF.MENU = 1
     #It's a boolean
     PROTYPE =func ASYRJSO.TYP('boolean')
    Elsif len(ASHW.ASWR(I).UOMPRO)
     #It's a unit
      PROTYPE =func ASYRJSO.TYP('quantity')
    Else
     If ASHW.ASWR(I).ACLAF.CODTYP = "ATX"
      PROTYPE = func ASYRJSO.TYP('string')
     Else
      Case ASHW.ASWR(I).ACLAF.ATY.TYPTYP
      When [V]CST_ATYPBLOB:#Blob
       PROTYPE    = ASHW.ASWR(I).ACLAF.ATY.PROTYP
#       If ASHW.ASWR(I).ACLAF.ATY.PROTYP="text" | left$(ASHW.ASWR(I).ACLAF.ATY.PROTYP,5)="text/"
#        PROTYPE    = "application/x-document"
#       Endif
       PROURLPRE  = '{$baseUrl}/'+CST_AURLBLOB
      When [V]CST_ATYPCLOB:#Clob
       PROTYPE    = ASHW.ASWR(I).ACLAF.ATY.PROTYP
#       If !find(ASHW.ASWR(I).ACLAF.ATY.PROTYP,"text/rtf","text/html","text/plain")
#        PROTYPE    = "application/x-document"
#       Endif
       PROURLPRE  = '{$baseUrl}/'+CST_AURLCLOB
      When Default:
       PROTYPE = ASHW.ASWR(I).ACLAF.ATY.PROTYP
      Endcase
     Endif
    Endif
    #Compute the length of prototype
    PROLEN = 0
    If ASHW.ASWR(I).ACLAF.CODTYP = "ATX"
     PROLEN = GLONDES
    Elsif find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPSHORTINT,[V]CST_ATYPINTEGER,[V]CST_ATYPDECIMAL) & ASHW.ASWR(I).ACLAF.LONG
     PROLEN = ASHW.ASWR(I).ACLAF.LONG
     #120813
     If ASHW.ASWR(I).ACLAF.ATY.TYPTYP=[V]CST_ATYPDECIMAL
       PROLEN=1+int(ASHW.ASWR(I).ACLAF.LONG)+int(10* (ASHW.ASWR(I).ACLAF.LONG-int(ASHW.ASWR(I).ACLAF.LONG)))
     Endif
    Elsif find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPCHAR,25,26) & ASHW.ASWR(I).ACLAF.LON
     PROLEN = ASHW.ASWR(I).ACLAF.LON
    Endif

#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
#    Endif

     TBLPRO(PRONBR)=ASHW.ASWR(I).ALIAS : TBLBLC(PRONBR) = ASHW.ASWR(I).BLCPRO

    If  !ISARRAY or ISARRAYOFOBJECTS
     JPRONAM = ASHW.ASWR(I).ALIAS :  Gosub PRO_ADD_START_PROPERTY
    Endif
#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF
#    Endif

    #HACK for additionnal properties
    If CODREP="ACHGENVX3" and ASHW.ASWR(I).ALIAS="ADATEREF"
     JPRONAM = "$isPersistent"   : JPROVAL = 'false'  : Gosub PRO_ADD_PROPERTY
    Elsif CODREP="ACHGENVGX" and find(ASHW.ASWR(I).ALIAS,"AFCYREF","ADEPREF")
     JPRONAM = "$resetConnection"   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
    Endif
    Gosub PRO_ADD_ATTRIBUTES

    If find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB) & maxtab(ASHW.ASWR(I).ACLAF.ATYPPAR)>0
       JPRONAM = '$acceptedTypes'  : Gosub PRO_ADD_START_ARRAY_COND
       For L=1 To maxtab(ASHW.ASWR(I).ACLAF.ATYPPAR)
         JPROVAL=ASHW.ASWR(I).ACLAF.ATYPPAR(L).VALEUR : Gosub PRO_SET_PROPERTY_TEXT
         Raz JSTATEMENT
         If L>1
          JSTATEMENT = ","
         Endif
         JSTATEMENT += JPROVAL
         Gosub PRO_ST_APPEND
       Next L
       Gosub PRO_ADD_END_ARRAY  : #$enum
    Endif

    If len(PROURLPRE)
     JPRONAM    = '$url'
     #90394
     #PROURLPRE += '('+JSQUOTE+ASHW.ASWR(I).CLAPRO+"~"+ASHW.ASWR(I).ALIAS
     PROURLPRE += '('+JSQUOTE+ASHW.ASWR(I).CLAPRO+[V]CST_AURLSEPLOB

     PROURLSUF  = ""
     J=find(19,ASHW.ASWR(I).ASWK(1..maxtab(ASHW.ASWR(I).ASWK)).CMPLNK)
     If J
      Call UPDATE_URL_LOB(PROURLSUF,ASHW.ASWR(I).ASWK(J).ATBKEY)
      Call UPDATE_URL_LOB(PROURLSUF,ASHW.ASWR(I).ASWK(J).ATBPAR)
     Else
      Call UPDATE_URL_LOB(PROURLSUF,ASHW.ASWR(I).ACLAF.ATBKEY)
      Call UPDATE_URL_LOB(PROURLSUF,ASHW.ASWR(I).ACLAF.ATBPAR)
     Endif
     PROURLSUF += JSQUOTE+')'

     JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
      #90394
      #JPROVAL = PROURLPRE + "~{$uuid}" + PROURLSUF
      #JPROVAL = PROURLPRE +ASHW.ASWR(I).ALIAS + [V]CST_AURLSEPLOB + "{$trackingId}" + PROURLSUF
      #JPROVAL  = '{$instanceUrl}/' + ASHW.ASWR(I).ALIAS
      JPROVAL  = '{$instanceUrl}/' + ASHW.ASWR(I).ACLAF.FLDCLA
      Gosub PRO_ADD_PROPERTY_TEXT
     Gosub PRO_ST_ELSE
      #90394
      #JPROVAL = PROURLPRE + PROURLSUF
      JPROVAL = PROURLPRE +ASHW.ASWR(I).ACLAF.FLDCLA + PROURLSUF
      Gosub PRO_ADD_PROPERTY_TEXT
     JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
    Endif

    #{SAM120783
    If ASHW.ASWR(I).ACLAF.ATY.PROTYP = "text/rtf"
      JPRONAM = "$capabilities" : JPROVAL="raw" : Gosub PRO_ADD_PROPERTY_TEXT
    Endif
    #SAM120783}

    #US 91088/4
    If ASHW.ASWR(I).EDIPRO=2 : #108488
    If ASHW.ASWR(I).ACLAF.ATY.TYPTYP=[V]CST_ATYPCHAR
&    & (ASHW.ASWR(I).ACLAF.ATY.FORTYP<>"" | ASHW.ASWR(I).ACLAF.ATY.OPTION<>"" | ASHW.ASWR(I).ACLAF.ATY.LNGTYP>0)
     Call SETFMT("K",ASHW.ASWR(I).ACLAF.ATY.FORTYP,ASHW.ASWR(I).ACLAF.LON,ASHW.ASWR(I).ACLAF.ATY.OPTION,FMT) From ACLAVALTRT
#     If instr(1,[L]FMT,":")
#      [L]FMT=right$([L]FMT,instr(1,[L]FMT,":")+1)
#     Endif
     If [L]FMT<>""
    JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
       JPRONAM = '$x3Format' : JPROVAL = [L]FMT : Gosub PRO_ADD_PROPERTY_TEXT
    JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
     Endif
    Endif
    Endif
    #

    If PROLEN : JPRONAM = '$maxLength' : JPROVAL = num$(PROLEN) : Gosub PRO_ADD_PROPERTY : Endif
    If len(ASHW.ASWR(I).UOMPRO)=0
     Gosub PRO_ADD_SCALE
    Endif

    #Property's links and actions (1=property)
    LNKAFF(1)=1 :LNKAFF(2)=0 : LNKANC = ASHW.ASWR(I).CODPRO:  Gosub PRO_ADD_LINKS_AND_ACTIONS

    If ASHW.ASWR(I).ACLAF.MENU > 1
     JPRONAM = '$value' : Gosub PRO_ADD_START_OBJECT
     JPRONAM = '$type'  : JPROVAL =func ASYRJSO.TYP('integer') : Gosub PRO_ADD_PROPERTY_TEXT
     JPRONAM = '$enum'  : Gosub PRO_ADD_START_ARRAY
     For L=1 To len(mess(0,ASHW.ASWR(I).ACLAF.MENU,1))
      If mess(L,ASHW.ASWR(I).ACLAF.MENU,1) <> "#"
       MESNUM = L : MESCHP = ASHW.ASWR(I).ACLAF.MENU : Gosub PRO_ADD_ENUM_ITEM
       #JPRONAM = num$(L) : JPROVAL=mess(L,ASHW.ASWR(I).ACLAF.MENU,1)  :Gosub PRO_ADD_ENUM_ITEM
      Endif
     Next L
     Gosub PRO_ADD_END_ARRAY  : #$enum
     Gosub PRO_ADD_END_OBJECT : #$value
    Elsif len(ASHW.ASWR(I).UOMPRO)
     #It's a unit
     JPRONAM = '$value' : Gosub PRO_ADD_START_OBJECT
     JPRONAM = '$title'        : JPROVAL = '{$value} {$unit}' : Gosub PRO_ADD_PROPERTY_TEXT
     JPRONAM = '$type'        : JPROVAL = ASHW.ASWR(I).ACLAF.ATY.PROTYP : Gosub PRO_ADD_PROPERTY_TEXT
     Gosub PRO_ADD_SCALE

     Gosub PRO_ADD_END_OBJECT : #$value
     #Look for the ALIAS of the symbol property
     For J=1 To maxtab(ASHW.ASWR)
      If ASHW.ASWR(I).UOMPRO  = ASHW.ASWR(J).CODPRO
       JPRONAM = '$unit'  : JPROVAL = ASHW.ASWR(J).ALIAS + '_REF'  : Gosub PRO_ADD_PROPERTY_TEXT
      Endif
     Next J
    Endif

#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
#    Endif
    If  !ISARRAY or ISARRAYOFOBJECTS
     Gosub PRO_ADD_END_OBJECT : #ASHW.ASWR(I).ALIAS
    Endif
#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF
#    Endif

   Else
    #it is a reference :
    TBLPRO(PRONBR)=ASHW.ASWR(I).ALIAS +'_REF': TBLBLC(PRONBR) = ASHW.ASWR(I).BLCPRO

#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' :Gosub PRO_ST_IF
#    Endif
     If  !ISARRAY or ISARRAYOFOBJECTS
      #ASHW.ASWR(I).ALIAS ***>
      JPRONAM = ASHW.ASWR(I).ALIAS : Gosub PRO_ADD_START_OBJECT
      JPRONAM = '$type'          : JPROVAL = ASHW.ASWR(I).ACLAF.ATY.PROTYP       : Gosub PRO_ADD_PROPERTY_TEXT

      #US 91088/4
      If ASHW.ASWR(I).EDIPRO=2 : #108488
      If ASHW.ASWR(I).ACLAF.ATY.TYPTYP=[V]CST_ATYPCHAR
&      & (ASHW.ASWR(I).ACLAF.ATY.FORTYP<>"" | ASHW.ASWR(I).ACLAF.ATY.OPTION<>"" | ASHW.ASWR(I).ACLAF.ATY.LNGTYP>0)
       Call SETFMT("K",ASHW.ASWR(I).ACLAF.ATY.FORTYP,ASHW.ASWR(I).ACLAF.LON,ASHW.ASWR(I).ACLAF.ATY.OPTION,FMT) From ACLAVALTRT
  #     If instr(1,[L]FMT,":")
  #      [L]FMT=right$([L]FMT,instr(1,[L]FMT,":")+1)
  #     Endif
       If [L]FMT<>""
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
         JPRONAM = '$x3Format' : JPROVAL = [L]FMT : Gosub PRO_ADD_PROPERTY_TEXT
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
       Endif
      Endif
      Endif
      #

      If find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPSHORTINT,[V]CST_ATYPINTEGER,[V]CST_ATYPDECIMAL) & ASHW.ASWR(I).ACLAF.LONG
       JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ACLAF.LONG)        : Gosub PRO_ADD_PROPERTY
      Elsif find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPCHAR,25,26) & ASHW.ASWR(I).ACLAF.LON
       JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ACLAF.LON)        : Gosub PRO_ADD_PROPERTY
      Endif

      #76076/42 isExcluded au lieu de isHidden sur les prop des références
      #JPRONAM = func ASYRSUB.CODATT("H")   : JPROVAL = 'true'                     : Gosub PRO_ADD_PROPERTY
      JPRONAM = func ASYRSUB.CODATT("e")   : JPROVAL = 'true'                     : Gosub PRO_ADD_PROPERTY

       #HACK for additionnal properties
       If CODREP="ACHGENVGX" and find(ASHW.ASWR(I).ALIAS,"AFCYREF","ADEPREF")
        JPRONAM = "$resetConnection"   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
       Endif
      Gosub PRO_ADD_END_OBJECT : #ASHW.ASWR(I).ALIAS
      #ASHW.ASWR(I).ALIAS ***<

      #ASHW.ASWR(I).ALIAS +'_REF' ***>
      JPRONAM = ASHW.ASWR(I).ALIAS + '_REF' :  Gosub PRO_ADD_START_PROPERTY
     Else
      JNODEIF(JLEV-1)=0 :#one mandatory node
     Endif
#    If ISARRAY
#     JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' :Gosub PRO_ST_ENDIF
#    Endif

    PROTYPE  = func ASYRJSO.TYP('reference')
    Gosub PRO_ADD_ATTRIBUTES

    #97211: must have $maxLength on reference
    If ASHW.ASWR(I).EDIPRO=2 : #108488
      If find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPSHORTINT,[V]CST_ATYPINTEGER,[V]CST_ATYPDECIMAL) & ASHW.ASWR(I).ACLAF.LONG
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
       JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ACLAF.LONG)        : Gosub PRO_ADD_PROPERTY
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
      Elsif find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPCHAR,25,26) & ASHW.ASWR(I).ACLAF.LON
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
       JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ACLAF.LON)        : Gosub PRO_ADD_PROPERTY
      JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
      Endif
    Endif
    #

    JPRONAM = '$item' : Gosub PRO_ADD_START_OBJECT
    If find('$lookup',ASHW.ASWR(I).ASWK(1..maxtab(ASHW.ASWR(I).ASWK)).CODLNK)>0
     JPRONAM = '$url'
     FJ=-1
     For J=1 To maxtab(ASHW.ASWR(I).ASWK)
      If ASHW.ASWR(I).ASWK(J).CODLNK = '$lookup'
       JPROVAL = '{$baseUrl}/'+ASHW.ASWR(I).ASWK(J).CLALNK+'('+JSQUOTE+"{$key}"+JSQUOTE+')?representation='+ASHW.ASWR(I).ASWK(J).REPLNK+'.'+ASHW.ASWR(I).ASWK(J).CODLNK
       Gosub PRO_ADD_PROPERTY_TEXT

       PROVAL='' : PROKEY='' :SEP=''
       For K=1 To maxtab(ASHW.ASWR(I).ASWK(J).ATBKEY)
        PROKEY += SEP
        If len(ASHW.ASWR(I).ASWK(J).ATBKEY(K).ALIAS)
         #$key
         PROKEY += '{'
         #SAM 102293 PROKEY += ASHW.ASWR(I).ASWK(J).ATBKEY(K).CODPAR
         PROKEY += ASHW.ASWR(I).ASWK(J).ATBKEY(K).LOO
         PROKEY += '}'
         If num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).ALIAS) = ASHW.ASWR(I).ALIAS
          #$value
          #SAM 102293 ALIASDST = num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).CODPAR)
          ALIASDST = num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).LOO)
          PROVAL = '{'+ALIASDST+'}'
         Endif
        Else
         PROKEY += num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).VALEUR)
        Endif
        SEP='~'
       Next K

       JPRONAM = '$value'        : JPROVAL = PROVAL : Gosub PRO_ADD_PROPERTY_TEXT
       JPRONAM = '$key'          : JPROVAL = PROKEY : Gosub PRO_ADD_PROPERTY_TEXT
 #
 #      If ASHW.ASWR(I).ACLAF.ACHPSYM <> null
 #      JPRONAM = '$symbol'  : JPROVAL = '{'+ASHW.ASWR(I).ACLAF.ACHPSYM.CHPCHAR + '}' : Gosub PRO_ADD_PROPERTY_TEXT
 #      Endif

       JPRONAM = '$properties'   : Gosub PRO_ADD_START_OBJECT
       For K=1 To maxtab(ASHW.ASWR(I).ASWK(J).ATBKEY)
        #SAM 102293 JPRONAM = num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).CODPAR)   : Gosub PRO_ADD_START_OBJECT
        JPRONAM = num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).LOO)   : Gosub PRO_ADD_START_OBJECT
        JPRONAM = '$type'
        JPROVAL = func GET_JSON_TYPE(ASHW.ASWR(I).ASWK(J).ATBKEY(K).TYPINT,0) : Gosub PRO_ADD_PROPERTY_TEXT

        If ASHW.ASWR(I).ASWK(J).ATBKEY(K).MODPAR <> 1 :#1=Variable
         JPRONAM = func ASYRSUB.CODATT("R")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
        Endif

        If find(KEYTYPE,2,3,4,7,25,26) & ASHW.ASWR(I).ASWK(J).ATBKEY(K).LNG
         JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ASWK(J).ATBKEY(K).LNG) : Gosub PRO_ADD_PROPERTY
        Endif

        Gosub PRO_ADD_END_OBJECT : #....CODPAR
       Next K
 #       If ASHW.ASWR(I).ACLAF.ACHPSYM <> null
 #        JPRONAM = ASHW.ASWR(I).ACLAF.ACHPSYM.CHPCHAR   : Gosub PRO_ADD_START_OBJECT
 #        JPRONAM = '$type'   : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_ADD_PROPERTY_TEXT
 #        Gosub PRO_ADD_END_OBJECT
 #       Endif
       Gosub PRO_ADD_END_OBJECT : #$properties
       FJ=J
       Break
      Endif
     Next J
     #WARNING :  the link key depends on the number of properties in the collection !
     If FJ>-1
       #SRC<=>DST mapping :
       For K=1 To maxtab(ASHW.ASWR(I).ASWK(FJ).ATBKEY)
        #SAM 102293 JPRONAM = num$(ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).CODPAR)
        JPRONAM = num$(ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).LOO)
        #If len(ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).ALIAS) > 0
        If (len(ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).ALIAS) > 0)
         JPROVAL = '{'+ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).ALIAS+'}'
 #        If ISARRAY & (ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).ALIAS = ASHW.ASWR(I).ALIAS)
 #         JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
 #        Endif
         If !ISARRAY or ISARRAYOFOBJECTS
          Gosub PRO_ADD_PROPERTY_TEXT
         Endif
 #        If ISARRAY & (ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).ALIAS = ASHW.ASWR(I).ALIAS)
 #         JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF
 #        Endif
        Else
         JPROVAL = ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).VALEUR
         If find(ASHW.ASWR(I).ASWK(FJ).ATBKEY(K).TYPINT,2,3,5)
          #integer, decimal or caption
          Gosub PRO_ADD_PROPERTY
         Else
          Gosub PRO_ADD_PROPERTY_TEXT
         Endif
        Endif
       Next K
      #Links
      #Property'S LINKS (1=PROPERTY)
 #     If len(GRPALIAS)
 #      ALIASST = 'If (ALIAS="' + ASHW.ASWR(I).ALIAS + '" & (PC('+num$(CONDCOLIDX)+') = 1) ): LNKKEY="'+ALIASDST+'":Endif'
 #      If !instr(1,BLOCS(BKEYS),ALIASST)
 #       JKEYIND=2
 #       Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), ALIASST)
 #      Endif
 #     Endif

      #Property's links and actions:
      LNKAFF(1)=1 :LNKAFF(2)=0 : LNKANC = ASHW.ASWR(I).CODPRO: Gosub PRO_ADD_LINKS_AND_ACTIONS
     Else : #FJ>-1
      #Links
      #Property's links and actions (1=property)
      LNKAFF(1)=1 :LNKAFF(2)=0 : LNKANC = ASHW.ASWR(I).CODPRO:  Gosub PRO_ADD_LINKS_AND_ACTIONS
     Endif


    Else

     #no lookup, it's a unit reference
       PROVAL='' : PROKEY='' :SEP=''
       For K=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBKEY)
        PROKEY += SEP
        If len(ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS)
         #$key
         PROKEY += '{'
         PROKEY += ASHW.ASWR(I).ACLAF.ATBKEY(K).CODPAR
         PROKEY += '}'
         If num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS) = ASHW.ASWR(I).ALIAS
          #$value
          ALIASDST = num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).CODPAR)
          PROVAL = '{'+ALIASDST+'}'
         Endif
        Else
#Issue2190
#         PROKEY += num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).VALEUR)
         PROKEY += func ASHWVALLEC.FVALKEY(ASHW.ASWR(I).ACLAF.ATBKEY(K).VALEUR,ASHW.ASWR(I).ACLAF.ATBKEY(K).TYPINT)
        Endif
        SEP='~'
       Next K

       JPRONAM = '$value'        : JPROVAL = PROVAL : Gosub PRO_ADD_PROPERTY_TEXT
       JPRONAM = '$key'          : JPROVAL = PROKEY : Gosub PRO_ADD_PROPERTY_TEXT

       JPRONAM = '$properties'   : Gosub PRO_ADD_START_OBJECT
       For K=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBKEY)
        JPRONAM = num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).CODPAR)   : Gosub PRO_ADD_START_OBJECT
        JPRONAM = '$type'
        JPROVAL = func GET_JSON_TYPE(ASHW.ASWR(I).ACLAF.ATBKEY(K).TYPINT,0) : Gosub PRO_ADD_PROPERTY_TEXT

        ## JPRONAM = func ASYRSUB.CODATT("R")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY

        If find(KEYTYPE,2,3,4,7,25,26) & ASHW.ASWR(I).ACLAF.ATBKEY(K).LNG
         JPRONAM = '$maxLength'     : JPROVAL = num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).LNG) : Gosub PRO_ADD_PROPERTY
        Endif

        Gosub PRO_ADD_END_OBJECT : #....CODPAR
       Next K
 #       If ASHW.ASWR(I).ACLAF.ACHPSYM <> null
 #        JPRONAM = ASHW.ASWR(I).ACLAF.ACHPSYM.CHPCHAR   : Gosub PRO_ADD_START_OBJECT
 #        JPRONAM = '$type'   : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_ADD_PROPERTY_TEXT
 #        Gosub PRO_ADD_END_OBJECT
 #       Endif
       Gosub PRO_ADD_END_OBJECT : #$properties

       #SRC<=>DST mapping :
       For K=1 To maxtab(ASHW.ASWR(I).ACLAF.ATBKEY)
        JPRONAM = num$(ASHW.ASWR(I).ACLAF.ATBKEY(K).CODPAR)
        #If len(ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS) > 0
        If (len(ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS) > 0)
         JPROVAL = '{'+ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS+'}'
 #        If ISARRAY & (ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS = ASHW.ASWR(I).ALIAS)
 #         JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
 #        Endif
         If !ISARRAY or ISARRAYOFOBJECTS
          Gosub PRO_ADD_PROPERTY_TEXT
         Endif
 #        If ISARRAY & (ASHW.ASWR(I).ACLAF.ATBKEY(K).ALIAS = ASHW.ASWR(I).ALIAS)
 #         JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF
 #        Endif
        Else
#Issue2190
#         JPROVAL = ASHW.ASWR(I).ACLAF.ATBKEY(K).VALEUR
         JPROVAL = func ASHWVALLEC.FVALKEY(ASHW.ASWR(I).ACLAF.ATBKEY(K).VALEUR,ASHW.ASWR(I).ACLAF.ATBKEY(K).TYPINT)
         If find(ASHW.ASWR(I).ACLAF.ATBKEY(K).TYPINT,2,3,5)
          #integer, decimal or caption
          Gosub PRO_ADD_PROPERTY
         Else
          Gosub PRO_ADD_PROPERTY_TEXT
         Endif
        Endif
       Next K
      #Links
      #Property'S LINKS (1=PROPERTY)
 #     If len(GRPALIAS)
 #      ALIASST = 'If (ALIAS="' + ASHW.ASWR(I).ALIAS + '" & (PC('+num$(CONDCOLIDX)+') = 1) ): LNKKEY="'+ALIASDST+'":Endif'
 #      If !instr(1,BLOCS(BKEYS),ALIASST)
 #       JKEYIND=2
 #       Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), ALIASST)
 #      Endif
 #     Endif

      #Property's links and actions:
      LNKAFF(1)=1 :LNKAFF(2)=0 : LNKANC = ASHW.ASWR(I).CODPRO: Gosub PRO_ADD_LINKS_AND_ACTIONS

    Endif
    Gosub PRO_ADD_END_OBJECT : #$item
#   If ISARRAY: JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF : Endif
    If  !ISARRAY or ISARRAYOFOBJECTS
     Gosub PRO_ADD_END_OBJECT : #ASHW.ASWR(I).ALIAS+"_REF"
    Endif
#   If ISARRAY: JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF : Endif
    #ASHW.ASWR(I).ALIAS +'_REF' ***<

   Endif
   If CONDPRO = '1'
    JNODEIF(JLEV-1)=0 :#one mandatory node
   Else
    If CHECKCONDPRO :JSTATEMENT = CONDPROST: Gosub PRO_ST_ENDIF :Endif
   Endif
  Endif
 Endif
Next I

#Loop on collections :
#Built the list of collection to loop on
Local Integer GRPIDX,PROIDX
Local Integer GRPNBR : GRPNBR=0
Local Char    GRPNAM(80)(1..)
Local Char    GRPALIASTBL(80)(1..)
Local Char    GRPPTHTBL(80)(1..)
Local Integer GRPMIN(1..)
Local Integer GRPMAX(1..)
Local Integer GRPFLGAPD(1..)
Local Integer GRPFLGINS(1..)
Local Integer GRPFLGSUP(1..)
Local Integer GRPFLGTRI(1..)
Local Integer GRPTITLE(1..)
Local Integer GRPPRONBR(1..)
Local Char    GRPCOD(80)
Local Integer PC1,PC2
Local Integer ISUSED

Local Char    GRPGRIPAR(80),GRPPTHPAR(80)

GRPGRIPAR = GRPGRI
GRPPTHPAR = GRPPTH

If REPLEV=1
 GRPGRIPAR = ASHW.PTHGRI(1)
 GRPPTHPAR = ASHW.PTHGRI(1)
Endif

#Collections which belong to the current class:
#Loop on all paths
Local Char CODGRP(80)
Local Integer FCODGRP

For I=1 To maxtab(ASHW.PTHGRI)
 If instr(1,ASHW.PTHGRI(I),GRPPTHPAR+".") = 1
  CODGRP = right$(ASHW.PTHGRI(I),len(GRPPTHPAR)+2)
  If instr(1,CODGRP,".") = 0
   #This path belongs to GRPPTHPAR
   #check that the collection is used in the representation (ASHW.PTHGRI contains
   #all collections even those which are not used)
   ISUSED =0
   For J=1 To maxtab(ASHW.ASWR)
    ISUSED = instr(1,ASHW.ASWR(J).GRIPRO,ASHW.PTHGRI(I))
    Break (ISUSED>0)
   Next J
   If ISUSED
    GRPNBR+=1 : CONDTBL(CONDNBR) = 'PC('+num$(CONDNBR)+')'
    FCODGRP=0
    For J=1 To maxtab(ASHW.ACLAGRI)
     #107283
     #For K=1 To min(20,maxtab(ASHW.ACLAGRI(J))) :#TODO : CODGRP is limited to 20 items
     For K=1 To min(20,ASHW.ACLAGRI(J).NBRGRP) :#TODO : CODGRP is limited to 20 items
      Break (len(ASHW.ACLAGRI(J).CODGRP(K))=0)
      If CODGRP =  ASHW.ACLAGRI(J).CODGRP(K)
       FCODGRP = 1
       GRPPTHTBL(GRPNBR)= ASHW.PTHGRI(I)
       GRPALIASTBL(GRPNBR) = ctrans(GRPPTHTBL(GRPNBR),".","")
       GRPNAM(GRPNBR)   = ASHW.ACLAGRI(J).CODGRP(K)
       GRPTITLE(GRPNBR) = ASHW.ACLAGRI(J).INTGRP(K)
       GRPMAX(GRPNBR)   = ASHW.ACLAGRI(J).MAXGRP(K)
       Case ASHW.ACLAGRI(J).MINGRP(K)
        When 1 :GRPMIN(GRPNBR)   = 0
        When 2: GRPMIN(GRPNBR)   = 1
        When 3: GRPMIN(GRPNBR)   = GRPMAX(GRPNBR)
       Endcase
       GRPFLGAPD(GRPNBR)= (ASHW.ACLAGRI(J).FLGAPDGRP(K)=2)
       GRPFLGINS(GRPNBR)= (ASHW.ACLAGRI(J).FLGINSGRP(K)=2)
       GRPFLGSUP(GRPNBR)= (ASHW.ACLAGRI(J).FLGSUPGRP(K)=2)
       GRPFLGTRI(GRPNBR)= (ASHW.ACLAGRI(J).FLGTRIGRP(K)=2)
       GRPPRONBR(GRPNBR) = ASHW.ACLAGRI(J).NBRPROGRP(K)
       #107283
       #Break
       Break 2
      Endif
     Next K
    Next J
    If !FCODGRP
     GRPPTHTBL(GRPNBR)= ASHW.PTHGRI(I)
     GRPALIASTBL(GRPNBR) = ctrans(GRPPTHTBL(GRPNBR),".","")
     GRPNAM(GRPNBR)   = CODGRP
     GRPTITLE(GRPNBR) = 0
     GRPMIN(GRPNBR)   = 1
     GRPMAX(GRPNBR)   = 1
     GRPFLGAPD(GRPNBR)= 0
     GRPFLGINS(GRPNBR)= 0
     GRPFLGSUP(GRPNBR)= 0
     GRPFLGTRI(GRPNBR)= 0
     GRPPRONBR(GRPNBR) = 1
    Endif
   Endif
  Endif
 Endif
Next I
#******************************************************************************

If REPLEV=1
 #Representation's collection
 I=1
 While (len(ASHW.ALIASGRP(I))>0)
  If !instr(1,ASHW.CODGRP(I),".")
   GRPNBR+=1
   GRPNAM(GRPNBR)   = ASHW.ALIASGRP(I)
   GRPALIASTBL(GRPNBR) = ASHW.ALIASGRP(I)
   GRPPTHTBL(GRPNBR)= ASHW.ALIASGRP(I)
   GRPMIN(GRPNBR)   = ASHW.MINGRP(I)-1
   GRPMAX(GRPNBR)   = ASHW.MAXGRP(I)
   GRPFLGAPD(GRPNBR)= (ASHW.FLGAPDGRP(I)=2)
   GRPFLGINS(GRPNBR)= (ASHW.FLGINSGRP(I)=2)
   GRPFLGSUP(GRPNBR)= (ASHW.FLGSUPGRP(I)=2)
   GRPFLGTRI(GRPNBR)= (ASHW.FLGTRIGRP(I)=2)
   GRPTITLE(GRPNBR) = ASHW.INTGRP(I)
   GRPPRONBR(GRPNBR) = ASHW.NBRPROGRP(I)
  Endif
  I += 1
 Wend
Endif

For GRPIDX=1 To GRPNBR
 PRONBR+=1 : COLNBR+=1 : COLPRO(COLNBR) = PRONBR

 CONDNBR += 1
 CONDGRPTBLNBR += 1
 CONDGRPTBLCOND(CONDGRPTBLNBR)  = '(PC('+num$(CONDNBR)+')>0)'
 CONDGRPTBLCOUNT(CONDGRPTBLNBR) = 1

 ISOBJECT = (GRPMIN(GRPIDX)= 1 & GRPMAX(GRPIDX)=1)

 JSTATEMENT = 'If PC('+num$(CONDNBR)+')' : Gosub PRO_ST_IF
  If !ISOBJECT
    JPRONAM = GRPALIASTBL(GRPIDX) : Gosub PRO_ADD_START_OBJECT
    JPRONAM = '$type'          : JPROVAL = func ASYRJSO.TYP('array') : Gosub PRO_ADD_PROPERTY_TEXT

    If (GRPMAX(GRPIDX)-1)>0
     JPRONAM = '$maxItems'      : JPROVAL = num$(GRPMAX(GRPIDX))      : Gosub PRO_ADD_PROPERTY
    Endif
    If (GRPMIN(GRPIDX)-1)>0
     JPRONAM = '$minItems'      : JPROVAL = num$(GRPMIN(GRPIDX))   : Gosub PRO_ADD_PROPERTY
    Endif
#    Endif
   #$title and $shortTitle
   JTITLE  = GRPTITLE(GRPIDX) : LOCALIAS = "group"+GRPALIASTBL(GRPIDX) : Gosub PRO_ADD_TITLE : LOCALIAS = "group"+GRPALIASTBL(GRPIDX) :Gosub PRO_ADD_SHORTTITLE :#SAM 115576

   JSTATEMENT = 'If DC('+num$(CONDNBR)+')=0' : Gosub PRO_ST_IF
    JPRONAM = func ASYRSUB.CODATT("H")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
   JSTATEMENT = 'If DC('+num$(CONDNBR)+')=0' : Gosub PRO_ST_ENDIF

   JPRONAM = '$item'          : Gosub PRO_ADD_START_OBJECT
  Endif
  Call APPEND_CLASSE(DOSSIER,CODREP,ASHW,REPLEV,GRPNAM(GRPIDX),GRPALIASTBL(GRPIDX),GRPPTHTBL(GRPIDX),BLOCS,JPROIND,PRONBR,TBLPRO,TBLBLC,JLEV,JSEP,JNODEIF,NBLOC,TBLLOCIDX,TBLLOCNAM,CONDNBR,CONDTBL,
& GRPMIN(GRPIDX)
& ,GRPMAX(GRPIDX),TBLGRPPTH,TBLGRPMIN,TBLGRPMAX,TBLGRPCOND,ASWACTIONS,JST_END,JST_EXP,JST_LENGTH,NBMES,TBLMESNUM,TBLMESCHP,GRPPRONBR(GRPIDX))

  If !ISOBJECT
   Gosub PRO_ADD_END_OBJECT :#$item
    CAPABILITY(1) =string$(GRPFLGAPD(GRPIDX),"append" )
    CAPABILITY(2) =string$(GRPFLGINS(GRPIDX),"insert" )
    CAPABILITY(3) =string$(GRPFLGSUP(GRPIDX),"delete" )
    CAPABILITY(4) =string$(GRPFLGTRI(GRPIDX),"reorder")
    Raz JPROVAL
    SEP =''
    For K = 1 To 4
     If len(CAPABILITY(K))
      JPROVAL += SEP + CAPABILITY(K)
      SEP = ','
     Endif
    Next K
    If len(JPROVAL) > 0
     JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
      JPRONAM = "$capabilities" : Gosub PRO_ADD_PROPERTY_TEXT
     JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
    Endif
  Endif
  If !ISOBJECT : Gosub PRO_ADD_END_OBJECT :  Endif : #ALIAS
JSTATEMENT = 'If PC('+num$(CONDNBR)+')' : Gosub PRO_ST_ENDIF
Next GRPIDX

# ****  } $properties
#If ISARRAY
# JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_IF
#Endif

If !len(GRPGRI) or (ISARRAY & ISARRAYOFOBJECTS)
 Gosub PRO_ADD_END_OBJECT : #$properties
Endif

#If ISARRAY
# JSTATEMENT = 'If PC('+num$(CONDCOLIDX)+')>1' : Gosub PRO_ST_ENDIF
#Endif
# ****  } $properties


# *** $links : {
If len(GRPGRI)
 #collection's links and actions (2=collection's line 3=collection)
 #101876
 #LNKAFF(1)=2 :LNKAFF(2)=3 : LNKANC = GRPGRI: Gosub PRO_ADD_LINKS_AND_ACTIONS
 LNKAFF(1)=2 :LNKAFF(2)=3 : LNKANC = GRPPTH: Gosub PRO_ADD_LINKS_AND_ACTIONS
Else
 #record's links and actions (5=record):
 LNKAFF(1)=5 :LNKAFF(2)=0 : LNKANC = "":  Gosub PRO_ADD_LINKS
Endif

# *** } $links

If len(GRPGRI) & CONDCOLIDX
 If CONDGRPTBLNBR=0
  #No property found in the collection !
  CONDGRPTBLNBR = 1
  CONDGRPTBLCOND(1)  = '0'
  CONDGRPTBLCOUNT(1) = 1

  DISPGRPTBLNBR = 1
  DISPGRPTBLCOND(1)  = '0'
  DISPGRPTBLCOUNT(1) = 1
 Endif

 #Generate the code in charge of evaluating the presence condition of the collection :
 CONDGRPTLBSEP=''
 Call APPEND_STATEMENT(1,BLOCS(BJSON2),left$('PC('+num$(CONDCOLIDX)+')   ',7)+'= ')
 For CONDGRPTBLIDX=1 To CONDGRPTBLNBR
  Call APPEND_STATEMENT(1,BLOCS(BJSON2),CONDGRPTLBSEP)
  If CONDGRPTBLCOUNT(CONDGRPTBLIDX) > 1
   Call APPEND_STATEMENT(1,BLOCS(BJSON2),num$(CONDGRPTBLCOUNT(CONDGRPTBLIDX))+'*')
  Endif
  Call APPEND_STATEMENT(1,BLOCS(BJSON2),CONDGRPTBLCOND(CONDGRPTBLIDX))
  CONDGRPTLBSEP='+'
 Next CONDGRPTBLNBR
 Call APPEND_STATEMENT(1,BLOCS(BJSON2),':#'+GRPGRI+chr$(10))

 #Generate the code in charge of evaluating the "isDisplayed" condition of the collection :
 DISPGRPTLBSEP=''
 Call APPEND_STATEMENT(1,BLOCS(BJSON2),left$('DC('+num$(CONDCOLIDX)+')   ',7)+'= ')
 If DISPGRPTBLNBR
  For DISPGRPTBLIDX=1 To DISPGRPTBLNBR
   Call APPEND_STATEMENT(1,BLOCS(BJSON2),DISPGRPTLBSEP)
   If DISPGRPTBLCOUNT(DISPGRPTBLIDX) > 1
    Call APPEND_STATEMENT(1,BLOCS(BJSON2),num$(DISPGRPTBLCOUNT(DISPGRPTBLIDX))+'*')
   Endif
   Call APPEND_STATEMENT(1,BLOCS(BJSON2),DISPGRPTBLCOND(DISPGRPTBLIDX))
   DISPGRPTLBSEP='+'
  Next DISPGRPTBLNBR
  Call APPEND_STATEMENT(1,BLOCS(BJSON2),':#'+GRPGRI+chr$(10))
 Else
  Call APPEND_STATEMENT(1,BLOCS(BJSON2),'1:#'+GRPGRI+chr$(10))
 Endif


 #Memorize the group's condition number for $bind !
 GRPIDX = 1
 While GRPIDX>0
  If len(TBLGRPPTH(GRPIDX)) = 0
   TBLGRPPTH(GRPIDX)  = GRPPTH
   TBLGRPMIN(GRPIDX)  = COLMIN
   TBLGRPMAX(GRPIDX)  = COLMAX
   TBLGRPCOND(GRPIDX) = 'PC('+num$(CONDCOLIDX)+')'
   Break
  Endif
  GRPIDX += 1
 Wend

Endif

End

#**
#*
#*!
$SET_ISREFERENCE
FLOOKUP = 0
#106911 reference on a interface class has no PASWR.ACLAF.ATY.INDLIEN : check TYPSELSYR+CODCLA
#ISREFERENCE = (len(PASWR.ACLAF.ATY.INDLIEN)>0) & (!find(PASWR.ACLAF.ATY.FICLIEN,"ATEXTRA") )
ISREFERENCE = PASWR.ACLAF.ATY.TYPSELSYR=2 & len(PASWR.ACLAF.ATY.CODCLA)>0 & !find(PASWR.ACLAF.ATY.FICLIEN,"ATEXTRA")
If !ISREFERENCE : Return : Endif : #it's not a reference
If find(PASWR.CODPRO,ASHW.ASWR(1..maxtab(ASHW.ASWR)).UOMPRO)<>0
 #it's a reference (unit)
 Return
Else
 ISREFERENCE = ISREFERENCE & (PASWR.ACLAF.ATY.CODCLA<>ASHW.CODCLA or !find(PASWR.ACLAF.FLDCLA,ASHW.ACLA.ACLAI(1..ASHW.ACLA.NBCLEREF).CLEREF))
 For LJ=1 To maxtab(PASWR.ASWK)
  If PASWR.ASWK(LJ).TYPLNK=1 & ASWACTIONS(PASWR.ASWK(LJ).CMPLNK).PROLNK= "$lookup"
   FLOOKUP = 1
   Break
  Endif
 Next LJ
 ISREFERENCE = ISREFERENCE &FLOOKUP
Endif
Return

#**
#* APPEND_LINE
#*
#* @param INDENT
#* @param BLOC
#* @param LINE
#*!
Subprog APPEND_LINE(INDENT,INC,BLOC,LINE)
Variable Integer    INDENT
Value    Integer    INC
Variable Clbfile BLOC
Value    Clbfile    LINE
LINE += chr$(10)
Goto _APPEND_STATEMENT

Subprog APPEND_STATEMENT(INDENT,BLOC,LINE)
Value Integer    INDENT
Variable Clbfile BLOC
Value    Char    LINE
Local    Integer INC:INC=0

$_APPEND_STATEMENT
If INC < 0 : INDENT += INC : Endif
Append BLOC,string$(INDENT-1," ")+LINE
If INC > 0 : INDENT += INC : Endif
End
#**
#* DEF_VAR_BLOCS
#*!
$DEF_VAR_BLOCS
Local Integer NBLOCS : NBLOCS=0
Local Integer BPROTO
Local Integer BKEYS
Local Integer BKEYS
Local Integer BFILTER1,BFILTER2
Local Integer BJSON1,BJSON2
Local Integer JKEYIND

Instance PASWR Using C_ASWEXPPRO
Local Integer ISREFERENCE
Local Integer FLOOKUP

Local Char PROCST(80)(1..)
Local Integer NBCST

NBLOCS +=1 : BFILTER1    = NBLOCS
NBLOCS +=1 : BFILTER2    = NBLOCS
NBLOCS +=1 : BJSON1    = NBLOCS
NBLOCS +=1 : BJSON2    = NBLOCS
NBLOCS +=1 : BKEYS     = NBLOCS
NBLOCS +=1 : BPROTO   = NBLOCS

NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('string')      +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('integer')    +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('boolean')   +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('decimal')   +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('reference') +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('choice')     +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('array')       +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('date')        +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('datetime')  +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"' +func ASYRJSO.TYP('datetime')  +'"'
NBCST +=1 : PROCST(NBCST) = '"$type":"application/json"'
NBCST +=1 : PROCST(NBCST) = '"$type":"application/json;vnd.sage=syracuse"'
NBCST +=1 : PROCST(NBCST) = '"$isMandatory":true'
NBCST +=1 : PROCST(NBCST) = '"$isReadOnly":true'
NBCST +=1 : PROCST(NBCST) = '"$isHidden":true'
NBCST +=1 : PROCST(NBCST) = '"$capabilities":"sort,filter"'
NBCST +=1 : PROCST(NBCST) = '"$isExcluded":true'
NBCST +=1 : PROCST(NBCST) = '"$capabilities":"sort,filter,filter_upper"'
NBCST +=1 : PROCST(NBCST) = '"$capabilities":"sort,filter,filter_upper,localize"'
NBCST +=1 : PROCST(NBCST) = '"$capabilities":"sort"'

Return


$LOAD_BLOCS
Local Clbfile BLOCS(2)(1..NBLOCS)
Local Integer CONDNBR
Local Char    CONDTBL(80)(1..)
Local Integer PRONBR
Local Char    TBLBLC(20)(1..)
Local Char    TBLPRO(20)(1..)
Local Char    URLKEY(100)
Local Integer CONDI
Local Integer ICST
Local Char     ASHWDEVICE(20)
Local Integer FDEVICE
Local Integer ACTXCOUNT,ACTXI
Local Char ACTXJSONAME(20)(1..)
Local Char ACTXX3NAME(50)(1..)
Local Char PROTOTYPE_TAG(40)
Local Char ETAG(25)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Gosub BEGIN_FILTERS

Call APPEND_STATEMENT(1,BLOCS(BJSON1), "#"+string$(79,'-')+chr$(10))
Call APPEND_STATEMENT(1,BLOCS(BJSON1), "$GET_JSON_STRUCTURE"+chr$(10))
Call APPEND_LINE(JPROIND,0,BLOCS(BJSON1), "Local Integer PC(1..),DC(1..)")

CONDNBR+=1 : CONDTBL(CONDNBR)='1'
CONDNBR+=1 : CONDTBL(CONDNBR)='(instr(1,"qbl",AF)>0)'

For CONDI=1 To CONDNBR
Call APPEND_STATEMENT(1   ,BLOCS(BJSON1),left$('PC('+num$(CONDI)+')   ',7)+'= '+CONDTBL(CONDI)+chr$(10))
Next CONDI

#JKEYIND=1
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "#"+string$(78,'-')+"#")
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "Funprog GK(PC,ALIAS)")
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "Variable Integer PC(1..)")
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "Value Char  ALIAS")
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "Local Char LNKKEY(80)"+chr$(10))
#Call APPEND_LINE(JKEYIND,0,BLOCS(BKEYS), "LNKKEY=ALIAS:#Default value")


Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#"+string$(78,'-')+"#")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "# APPEND_PROTOTYPE" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#"+string$(78,'-')+"#")

Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Funprog APPEND_PROTOTYPE(ACTX,ASND,ARCV,PSYR,FACET)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Variable Instance ASND   Using C_ASYRSND" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Variable Instance ARCV   Using C_ASYRRCV " )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Variable Instance  PSYR  Using C_ASYR" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Value Char    FACET")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Integer ERROR : ERROR = [V]CST_AOK" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Integer IND   : IND = 0" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Char    SEP(1)(0..)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Char    AF(1) : AF = mid$(FACET,2,1)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Char TARGET(80)")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Char    CS(80)(1..)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Local Char DEVICE(20)")

Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'DEVICE = func ASYRMAIN.PARVAL(ARCV,"device")')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'If find(DEVICE,"","desktop","phone","tablet")=0')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), ' ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_UNSUPPORTED_MEDIA,mess(35,149,1))')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), ' End ERROR')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'Endif')
Case ASHW.TYPMSKREP
 When 1 : ASHWDEVICE='desktop' : FDEVICE=1
 When 2 : ASHWDEVICE='phone'   : FDEVICE=2
 When 3 : ASHWDEVICE='tablet'  : FDEVICE=3
Endcase
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'If (len(DEVICE) & DEVICE<>"'+ASHWDEVICE+'" & "'+ASHWDEVICE+'"<>"phone")')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO),
& ' ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(5,149,1),"'+CODREP+'",DEVICE))')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), ' End ERROR')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'Endif')

PROTOTYPE_TAG = num$(datetime$) + '-'
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'ETAG = func ASYRMAIN.HEADVAL(ARCV,"If-None-Match")')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'If ETAG = "'+PROTOTYPE_TAG+'"+ACTX.LAN')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), ' ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_MODIFIED,"")')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), ' End ERROR')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'Endif')

Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'ASND.HEADERCOD(1) = "ETag"')
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'ASND.HEADERVAL(1) = "'+PROTOTYPE_TAG+'"+ACTX.LAN')

Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Gosub $_APPEND_PROTOTYPE")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "End ERROR")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#"+string$(78,'-')+"#")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#$_APPEND_PROTOTYPE" )
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#"+string$(78,'-')+"#")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "$_APPEND_PROTOTYPE")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "If AF='e' : TARGET='blank'  : Endif")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Gosub GET_JSON_STRUCTURE")
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Raz ASND.DATA")

Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "#Constant strings::")
For ICST=1 To NBCST
 Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), 'CS('+num$(ICST)+')=' + "'"+PROCST(ICST) +"'")
Next ICST
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "")

URLKEY = '' : SEP=''
For I=1 To ASHW.NBRKEYREP
 URLKEY += SEP
 If ASHW.ASWKEY(I).ALIAS <> ""
  URLKEY += "{"+ASHW.ASWKEY(I).ALIAS+"}"
 Elsif find(left$(ASHW.ASWKEY(I).VALEUR,1),"'",'"')
  URLKEY += func ASYRJSO.PARAM(ASHW.ASWKEY(I).VALEUR)
 Else
  URLKEY += ASHW.ASWKEY(I).VALEUR
 Endif
 SEP      ="~"
Next I

JPRONAM = ''               : Gosub PRO_ADD_START_OBJECT

Call LOAD_ACTX_PROPERTIES([L]ACTXCOUNT,[L]ACTXJSONAME,[L]ACTXX3NAME)
For ACTXI=1 To ACTXCOUNT
 JPRONAM = [L]ACTXJSONAME(ACTXI)       : JPROVAL = func JSOVAR([L]ACTXX3NAME(ACTXI) ) : Gosub PRO_ADD_PROPERTY_TEXT
Next ACTXI

JPRONAM = '$device'        : JPROVAL = ASHWDEVICE  : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$baseUrl'       : JPROVAL = func JSOVAR('baseUrl') : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$baseType'      : JPROVAL = func JSOVAR('PSYR.CNTPRE+"."+nomap') : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$prototype'     : JPROVAL = '{$baseUrl}/$prototype('+JSQUOTE+'{$representation}.$thumb'+JSQUOTE+')' : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$representation': JPROVAL = CODREP : Gosub PRO_ADD_PROPERTY_TEXT
JPRONAM = '$repUrl'
JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
  JPROVAL = '{$baseUrl}/$workingCopies('+JSQUOTE+'{$trackingId}'+JSQUOTE+')' : Gosub PRO_ADD_PROPERTY_TEXT
Gosub PRO_ST_ELSE
  JPROVAL =  '{$baseUrl}/'+ASHW.CODCLA : Gosub PRO_ADD_PROPERTY_TEXT
JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
JPRONAM = '$instanceUrl' : JPROVAL =  '{$repUrl}/' +ASHW.ABRCLA :  Gosub PRO_ADD_PROPERTY_TEXT

JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_IF
 JPRONAM = '$url'           : JPROVAL = '{$baseUrl}/'+ASHW.CODCLA+"?representation="+CODREP+'.'+ func JSOVAR('FACET') : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$itemsPerPage'  : JPROVAL = '300' : Gosub PRO_ADD_PROPERTY
Gosub PRO_ST_ELSE
 JPRONAM = '$url'           : JPROVAL = '{$baseUrl}/'+ASHW.CODCLA+'('+JSQUOTE+"{$key}"+JSQUOTE+')?representation='+CODREP+'.'+ func JSOVAR('FACET') : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$key'           : JPROVAL=URLKEY : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$value'         : JPROVAL=URLKEY : Gosub PRO_ADD_PROPERTY_TEXT
JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_ENDIF

JTITLE = ASHW.INTREP : LOCALIAS=ASHW.CODREP+"$title": Gosub PRO_ADD_TITLE :#SAM 115576
JPRONAM = '$type'          : JPROVAL = '{$baseType}.'+CODREP+'.'+ func JSOVAR('FACET'): Gosub PRO_ADD_PROPERTY_TEXT

#108652/1 $x3FormatExt only for edit facet
If ASHW.ENAFAC(2)=2
 Local Char    PARAM(250),PARAM1(250)
 JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
 JPRONAM = '$x3FormatExt' : : Gosub PRO_ADD_START_OBJECT
 ## Paramètres adonix
 For I=1 To 30
  PARAM=func ADP_TOOL.GET_PARAM(DOSSIER, 1, "", "TUL"+format$("N0:##",I))
  If PARAM<>""
   #adxtul
   #adxtul(I-1) = left$(PARAM,1)
   JPRONAM = left$(PARAM,1) : : Gosub PRO_ADD_START_OBJECT
   J = instr(1,PARAM,":")
   If J
    #adxtuc(I-1) = right$(PARAM,J+1)
    PARAM1=right$(PARAM,J+1)
    #RAZ the json separator at each loop !
    JSEP(JLEV)=''
    JPRONAM = "stdType"  : Gosub PRO_ADD_START_ARRAY_COND
    JSTATEMENT=""
    For K=1 To len(PARAM1)
     JSTATEMENT +=JSEP(JLEV)+'"'+func ESCQUOTE(mid$(PARAM1,K,1))+'"' :#SAM120809
     JSEP(JLEV)=','
    Next K
    Gosub PRO_ST_APPEND
    Gosub PRO_ADD_END_ARRAY  : #stdType
    JSEP(JLEV)=','
    #adxtut(I-1) = seg$(PARAM,2,J-1)
    PARAM1=seg$(PARAM,2,J-1)
    JPRONAM = "chars"  : Gosub PRO_ADD_START_ARRAY_COND
    #RAZ the json separator at each loop !
    JSEP(JLEV)=''
    JSTATEMENT=""
    For K=1 To len(PARAM1)
     JSTATEMENT +=JSEP(JLEV)+'"'+mid$(PARAM1,K,1)+'"'
     JSEP(JLEV)=','
    Next K
    Gosub PRO_ST_APPEND
    Gosub PRO_ADD_END_ARRAY  : #chars
    JSEP(JLEV)=','
   Endif
   Gosub PRO_ADD_END_OBJECT : #adxtul
  Endif
 Next I
 Gosub PRO_ADD_END_OBJECT : #$x3FormatExt
 JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
Endif

JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_IF
 JPRONAM = '$properties'    : Gosub PRO_ADD_START_OBJECT
 JPRONAM = '$resources'     : Gosub PRO_ADD_START_OBJECT
 JPRONAM = '$type'          : JPROVAL = func ASYRJSO.TYP('array')    : Gosub PRO_ADD_PROPERTY_TEXT
 #102203/6 add quickedit in query if allowed (facet edit + behaviour)
 If ASHW.ENAFAC(2)=2 & ASHW.ENACOM(8)=2
  JSTATEMENT = 'If AF="q"' : Gosub PRO_ST_IF
  JPRONAM = '$capabilities' : JPROVAL = 'quickedit' : Gosub PRO_ADD_PROPERTY_TEXT
  JSTATEMENT = 'If AF="q"' : Gosub PRO_ST_ENDIF
 Endif
 #
 JPRONAM = '$item'          : Gosub PRO_ADD_START_OBJECT
 JPRONAM = '$url'           : JPROVAL = '{$baseUrl}/' +ASHW.CODCLA+'('+JSQUOTE+"{$key}"+JSQUOTE+')?representation='+CODREP+'.$queryItem' : Gosub PRO_ADD_PROPERTY_TEXT
 #SAM 106924 JPRONAM = '$type'          : JPROVAL = '{$baseType}.'+CODREP+'.$queryItem'     : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$type'          : JPROVAL = 'application/json;vnd.sage=syracuse'     : Gosub PRO_ADD_PROPERTY_TEXT
 JPROVAL = ASHW.TIT
 If len(JPROVAL) :  JPROVAL= '{'+JPROVAL+'}' : Endif
 JPRONAM = '$description'   : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$title'             : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$key'             : JPROVAL = URLKEY    : Gosub PRO_ADD_PROPERTY_TEXT
 JPRONAM = '$value'          : JPROVAL = URLKEY    : Gosub PRO_ADD_PROPERTY_TEXT
JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_ENDIF

Return

#**
#* CLOSE_BLOCS
#*!
$CLOSE_BLOCS
Local Integer ABLC,ASEC,APRO,AI
Local Char    ACHR(1)
Local Integer LAYOUT_TITLE
Local Char    LAYOUT_CODE(50)
Local Char    LAYOUT_CATEGORY(50)
Local Char    CODSEC(20)
Local Integer I,J,K,L

Call APPEND_STATEMENT(1,BLOCS(BJSON2), "Return"+chr$(10))

CODSEC          = ''

JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_IF
 Gosub PRO_ADD_END_OBJECT :#$item
 Gosub PRO_ADD_END_OBJECT :#$resources
 Gosub PRO_ADD_END_OBJECT : #$properties

 Gosub TRT_FILTERS

#*** } $filters
JSTATEMENT = 'If PC(2)' : Gosub PRO_ST_ENDIF



#***  $links and $actions
#4=page
#*!
LNKAFF(1)=4 :LNKAFF(2)=0 : LNKANC = "": Gosub PRO_ADD_LINKS_AND_ACTIONS
#*** } $links and $actions


#*** { $article
JPRONAM = '$article'  : Gosub PRO_ADD_START_OBJECT

#*** { $menus ---------------
Local Char     CONDMEN(10)
Local Char     IFMEN(250)
Local Integer AFAC

JPRONAM = '$menus' : Gosub PRO_ADD_START_OBJECT
JPRONAM = '$layout'  : Gosub PRO_ADD_START_OBJECT
JPRONAM = '$items'  : Gosub PRO_ADD_START_ARRAY

#The menu depends on the facet :
For AFAC=1 To 5
 #RAZ the json separator at each loop !
 JSEP(JLEV)=''

 CONDMEN =    mid$( "deqls", AFAC, 1)
 IFMEN = 'If '+ func GET_CONDITION('(instr(1,"'+CONDMEN+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 JSTATEMENT = IFMEN : Gosub PRO_ST_IF

 Gosub TRT_MENU_AFAC

 JSTATEMENT = IFMEN : Gosub PRO_ST_ENDIF
Next AFAC


Gosub PRO_ADD_END_ARRAY : #'$ITEMS
Gosub PRO_ADD_END_OBJECT :#$layout
Gosub PRO_ADD_END_OBJECT :#$menus
#*** } $menus ---------------

#*** { $layout
Local Char     CONDLAY(10)
Local Char     CONDSEC(10)(1..max(1,ASHW.ASWG.NBRSEC))
Local Char     CONDBLC(10)(1..max(1,ASHW.ASWG.NBRBLC))
Local Char     CONDBIND(10)(1..max(1,maxtab(ASHW.ASWR)))
Local Char     COLINBIND(250)(1..)
Local Integer  COLINBINDIDX
Local Integer  CONDIDX
Local Integer  CONDGRPIDX
Local Char     IFLAY(250),IFSEC(250),IFBLC(250),IFPRO(250)
Local Integer  MAXITEMS
Local Integer  BI,BJ,DPOS
Local Char     AGRIPRO(250)
Local Integer DPOS

 #Compute the conditions :
 Raz CONDLAY
 For ABLC=1 To ASHW.ASWG.NBRBLC
  For APRO=1 To maxtab(ASHW.ASWR)
   If ASHW.ASWR(APRO).BLCPRO = ASHW.ASWG.CODBLC(ABLC)
    #the property belongs to CODBLC
    CONDBIND(APRO)  = ""
#76076/42 isExcluded
#    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).DETPRO=2,"d" )
#    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).EDIPRO=2,"e" )
#    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).SUMPRO=2,"s" )
    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).DETPRO=2 & ASHW.ASWR(APRO).STADETPRO<>3,"d" )
    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).EDIPRO=2 & ASHW.ASWR(APRO).STAEDIPRO<>3,"e" )
    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).SUMPRO=2 & ASHW.ASWR(APRO).STASUMPRO<>3,"s" )
#layout for $edit, $details and $summary only :
#    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).QRYPRO=2,"qb")
#    CONDBIND(APRO) +=string$(ASHW.ASWR(APRO).LOKPRO=2,"l" )

    #=> update the BLOC presence condition :
    For AI = 1 To len(CONDBIND(APRO))
     ACHR = mid$(CONDBIND(APRO),AI,1)
     If !instr(1,CONDBLC(ABLC),ACHR)
      #update the bloc condition:
      CONDBLC(ABLC) += ACHR
      #search the section :
      ASEC = find(ASHW.ASWG.SECBLC(ABLC),ASHW.ASWG.CODSEC)
      If ASEC & !instr(1,CONDSEC(ASEC),ACHR)
       #update the section condition:
       CONDSEC(ASEC) += ACHR
       If !instr(1,CONDLAY,ACHR)
        #update the layout condition
        CONDLAY += ACHR
       Endif
      Endif
     Endif
    Next AI
    #does the property belongs to a collection ?
    CONDBIND(APRO)  = CONDBIND(APRO)
   Endif
  Next AP
 Next ABLC

 #Generate the code
If len(CONDLAY)
 IFLAY = 'If '+ func GET_CONDITION('(instr(1,"'+CONDLAY+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 JSTATEMENT = IFLAY : Gosub PRO_ST_IF
  JPRONAM = '$layout'   : Gosub PRO_ADD_START_OBJECT
  JPRONAM = '$items'    : Gosub PRO_ADD_START_ARRAY_COND

  For ASEC=1 To ASHW.ASWG.NBRSEC
   If len(CONDSEC(ASEC))
    If len(CONDSEC(ASEC)) < len(CONDLAY)
     IFSEC = 'If '+ func GET_CONDITION('(instr(1,"'+CONDSEC(ASEC)+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
     JSTATEMENT = IFSEC : Gosub PRO_ST_IF
    Endif
     LAYOUT_TITLE   = ASHW.ASWG.INTSEC(ASEC)
     LAYOUT_CODE    = ASHW.ASWG.CODSEC(ASEC)
     LAYOUT_CATEGORY='section'
     LOCALIAS = LAYOUT_CATEGORY+LAYOUT_CODE :#SAM 115576
     Gosub PRO_ADD_START_LAYOUT

     For ABLC =1 To ASHW.ASWG.NBRBLC
      If (ASHW.ASWG.SECBLC(ABLC) = ASHW.ASWG.CODSEC(ASEC)) & (len(CONDBLC(ABLC)))
       If len(CONDBLC(ABLC)) < len(CONDSEC(ASEC))
        IFBLC = 'If '+ func GET_CONDITION('(instr(1,"'+CONDBLC(ABLC)+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
        JSTATEMENT = IFBLC : Gosub PRO_ST_IF
       Endif
        LAYOUT_TITLE   = ASHW.ASWG.INTBLC(ABLC)
        LAYOUT_CODE    = ASHW.ASWG.CODBLC(ABLC)
        LAYOUT_CATEGORY ='block'
        Raz COLINBIND : COLINBINDIDX=0
        LOCALIAS = LAYOUT_CATEGORY+LAYOUT_CODE :#SAM 115576
        Gosub PRO_ADD_START_LAYOUT
        #loop on properties
        For APRO=1 To maxtab(ASHW.ASWR)
         #If len(CONDBIND(APRO)) & (ASHW.ASWR(APRO).BLCPRO = ASHW.ASWG.CODBLC(ABLC))
         If len(CONDBIND(APRO)) & (ASHW.ASWR(APRO).BLCPRO = ASHW.ASWG.CODBLC(ABLC))
          #The property belongs to the bloc:
          CONDGRPIDX = 0
          AGRIPRO = ASHW.ASWR(APRO).GRIPRO
          If len(ASHW.ASWR(APRO).GRIPRO)
           #The property belongs to a a collection
           #Compute the collection name
           AGRIPRO = ASHW.ASWR(APRO).GRIPRO
           DPOS  = instr(1,AGRIPRO,".")
           If DPOS
            DPOS  = instr(DPOS+1,AGRIPRO,".")
            #gitHub 1776 If DPOS : AGRIPRO = left$(AGRIPRO,DPOS-1) : Endif
           Endif

           #Look for the path of the main collection :
           BI = 1
           While len(TBLGRPPTH(BI))>0
            If TBLGRPPTH(BI) = AGRIPRO
             Break
            Endif
            BI += 1
           Wend
          Endif

          If !len(ASHW.ASWR(APRO).GRIPRO) or (len(ASHW.ASWR(APRO).GRIPRO) & TBLGRPMIN(BI) = 1 & TBLGRPMAX(BI) = 1)
           #$bind a simple property
           If len(CONDBIND(APRO)) < len(CONDBLC(ABLC))
            IFPRO = 'If '+ func GET_CONDITION('(instr(1,"'+CONDBIND(APRO)+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
            JSTATEMENT = IFPRO : Gosub PRO_ST_IF
           Endif

           JPROVAL = ASHW.ASWR(APRO).ALIAS

           PASWR   = ASHW.ASWR(APRO)
           Gosub SET_ISREFERENCE
           If ISREFERENCE
            #it's a reference
            JPROVAL += '_REF'
           Endif

           JPRONAM = ''       : Gosub PRO_ADD_START_OBJECT
           JPRONAM = '$bind'  : Gosub PRO_ADD_PROPERTY_TEXT
           Gosub PRO_ADD_END_OBJECT :#$bind

           If len(CONDBIND(APRO)) < len(CONDBLC(ABLC))
            JSTATEMENT = IFPRO : Gosub PRO_ST_ENDIF
           Else
            JNODEIF(JLEV-1)=0 :#one mandatory node
           Endif

          Else
           #$bind a collection :
           JPROVAL = ctrans(AGRIPRO,".","")
           If !find(JPROVAL,COLINBIND)
            COLINBINDIDX +=1 : COLINBIND(COLINBINDIDX) = JPROVAL

            If len(TBLGRPCOND(BI))
             IFPRO = 'If '+ TBLGRPCOND(BI)
            Else
             IFPRO = 'If 0'
            Endif
            JSTATEMENT = IFPRO : Gosub PRO_ST_IF
             JPRONAM = ''       : Gosub PRO_ADD_START_OBJECT
             JPRONAM = '$bind'  : Gosub PRO_ADD_PROPERTY_TEXT
             Gosub PRO_ADD_END_OBJECT :#$bind
            JSTATEMENT = IFPRO : Gosub PRO_ST_ENDIF
           Endif
          Endif

         Endif :#The property belongs to the bloc:
        Next APRO

        Gosub PRO_ADD_END_LAYOUT
        If len(CONDBLC(ABLC)) < len(CONDSEC(ASEC))
         JSTATEMENT = IFBLC : Gosub PRO_ST_ENDIF
        Endif
      Endif
     Next ABLC
    Gosub PRO_ADD_END_LAYOUT
    If len(CONDSEC(ASEC)) < len(CONDLAY)
     JSTATEMENT = IFSEC : Gosub PRO_ST_ENDIF
    Endif
   Endif
  Next ASEC

  Gosub PRO_ADD_END_ARRAY  : #$items
  Gosub PRO_ADD_END_OBJECT : #$layout
 JSTATEMENT = IFLAY : Gosub PRO_ST_ENDIF
Endif
Gosub PRO_ADD_END_OBJECT : #$article
#*** } $article

#*** { $localization
#*!
Local Integer AK,AL,AM
Local Char    TBLLOCSTR(50)(1..), LOCNAM(10) #SAM 115576 : TBLLOCNAM(10)(1..),


#107271 Read [ADS]DOSSIER=nomap
If func DOSSUB.FILL_ADS(nomap)

For AK=1 To [F:ADS]NBRLAN
 For AL=1 To NBLOC
  If TBLLOCIDX(AL)
   #SAM 115576 TBLLOCNAM(AL) ="@"+num$(TBLLOCIDX(AL))
   TBLLOCSTR(AL) =""
   Read [ATX]NUMERO = [F:ADS]LAN(AK-1);TBLLOCIDX(AL)
   If !fstat
    TBLLOCSTR(AL) = [F:ATX]TEXTE
   Else
    #Get the text in the default language if it wasn't translated:
    Read [ATX]NUMERO = [F:ADS]LANDEF;TBLLOCIDX(AL)
    If !fstat
     TBLLOCSTR(AL) = [F:ATX]TEXTE
    Endif
   Endif
  Endif
 Next AL

#SAM 117134 Sorta NBLOC TBLLOCNAM, TBLLOCSTR  Order By TBLLOCNAM(indice+1)


 JPROIND=1

 JSTATEMENT = 'If GACTX.LAN="'+[F:ADS]LAN(AK-1)+'"' : Gosub PRO_ST_IF

 JSEP(JLEV)=','
 JPRONAM = '$localization': Gosub PRO_ADD_START_OBJECT

 LOCNAM=""
 JPRONAM ="@0" : JPROVAL="" : Gosub PRO_ADD_PROPERTY_TEXT

 AM = len(BLOCS(BPROTO))
 For AL=1 To NBLOC
  If LOCNAM <> TBLLOCNAM(AL)
   JPRONAM = TBLLOCNAM(AL) : JPROVAL= func APPEND_JSON_STRING(TBLLOCSTR(AL)) : Gosub PRO_ADD_PROPERTY_TEXT
   LOCNAM = TBLLOCNAM(AL)

   If (len(BLOCS(BPROTO)) - AM) > TRTMAXSIZE
    #No more 32767 characters in the same "if endif" bloc in order to be able to split the treatment :
    Call APPEND_LINE(JPROIND,-1,BLOCS(BPROTO),'Endif')
    Call APPEND_LINE(JPROIND,1,BLOCS(BPROTO),STATEMENT)
    AM = len(BLOCS(BPROTO))
   Endif
  Endif
 Next AL

 #Messages :
 #NBMES TBLMESNUM TBLMESCHP
 For AL=1 To NBMES
  JPRONAM ='@mes'+num$(TBLMESCHP(AL)) + "_" +num$(TBLMESNUM(AL))
  Read [AST]CLE = TBLMESCHP(AL);TBLMESNUM(AL);[F:ADS]LAN(AK-1)
  #VPO
  #JPROVAL=[F:AST]LANMES
  JPROVAL=func APPEND_JSON_STRING([F:AST]LANMES)
  Gosub PRO_ADD_PROPERTY_TEXT

   If (len(BLOCS(BPROTO)) - AM) > TRTMAXSIZE
    #No more 32767 characters in the same "if endif" bloc in order to be able to split the treatment :
    Call APPEND_LINE(JPROIND,-1,BLOCS(BPROTO),'Endif')
    Call APPEND_LINE(JPROIND,1,BLOCS(BPROTO),STATEMENT)
    AM = len(BLOCS(BPROTO))
   Endif
 Next AL

 Gosub PRO_ADD_END_OBJECT : #$localization
 JSTATEMENT = 'If GACTX.LAN="'+[F:ADS]LAN(AK-1)+'"' : Gosub PRO_ST_ENDIF

Next AK

#*** } $localization
JPROIND=1
Gosub PRO_ADD_END_OBJECT : #

Endif

#CLOSE the last line :
Gosub PRO_ST_CLOSE
Call APPEND_LINE(JPROIND,0,BLOCS(BPROTO), "Return")

#Close the GK Funcprog
#JKEYIND=2
#Call APPEND_LINE(JKEYIND, 0,BLOCS(BKEYS), "End LNKKEY")

#Fix the PC(1..) bug !
#Set the max size of PC(1..) !

STATEMENT = "PC(1..),DC(1..)"
I = instr(1,BLOCS(BJSON1),STATEMENT)
If I
 CLEFT  = left$(BLOCS(BJSON1),I-1)
 CRIGHT = right$(BLOCS(BJSON1),I+len(STATEMENT))
 BLOCS(BJSON1)   = CLEFT
 Append BLOCS(BJSON1),"PC(1.."+num$(CONDNBR)+"),DC(1.."+num$(CONDNBR)+")"
 Append BLOCS(BJSON1),CRIGHT
Endif
Return

#**
#* BEGIN_FILTERS : Begin filters functions/load properties informations
#*!
$BEGIN_FILTERS
#*** { $filters (query, lookup and bulk facets) PC(2)=1
#*
Call APPEND_STATEMENT(1,BLOCS(BFILTER1), "#"+string$(79,'-')+chr$(10))
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), "Funprog GET_X3FILTER(CODE)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), "Value Char    CODE")
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), "Local Clbfile    X3FILTER")

Call APPEND_STATEMENT(1,BLOCS(BFILTER2), "#"+string$(79,'-')+chr$(10))
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), "Funprog GET_SDATAFILTER(CODE)" )
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), "Value Char    CODE")
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), "Local Char T0(30)(1..)")
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), "Local Char T1(30)(1..)")
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), "Local Integer NBPRO : NBPRO=0")

#96900 For mobility, we send the filters with exposed properties names instead of [F...] names
Gosub DECODE_CRITERIA

#97762
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), 'NBPRO += 1 : T0(NBPRO) = "[V]CST_ANO" : T1(NBPRO) = "false" '  )
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), 'NBPRO += 1 : T0(NBPRO) = "[V]CST_AYES" : T1(NBPRO) = "true" '  )
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER2), 'End TOSDATA(T0,T1,func GET_X3FILTER(CODE))'  )
Return

#**
#* TRT_FILTERS : Fill filters json and filters functions
#*!
$TRT_FILTERS

Call APPEND_LINE(JPROIND,1,BLOCS(BFILTER1), "Case  CODE")

Local Integer FFILTER : FFILTER=0
If ASHW.NBROPT
 For I=1 To ASHW.NBROPT
  #90872: ne pas mettre filtre obligatoire
  #If ASHW.ASWOPT(I).OPTOBY<>2
   If FFILTER=0
    JPRONAM = '$filters' : Gosub PRO_ADD_START_OBJECT
    FFILTER=1
   Endif
   JPRONAM = ASHW.ASWOPT(I).OPTCOD : Gosub PRO_ADD_START_OBJECT
   JPRONAM = '$title'             : JPROVAL = ""    : Gosub PRO_ADD_PROPERTY_TEXT
   JTITLE =  ASHW.ASWOPT(I).OPTLIB  : LOCALIAS = "filter"+ASHW.ASWOPT(I).OPTCOD :Gosub PRO_ADD_TITLE :#SAM 115576
   If ASHW.ASWOPT(I).OPTDEF= 2
    JPRONAM = '$isDefault' : JPROVAL ='true' : Gosub PRO_ADD_PROPERTY
   Endif
   If ASHW.ASWOPT(I).OPTOBY=2 : #For mandatory filters :
    JPRONAM = '$isMandatory' : JPROVAL ='true' : Gosub PRO_ADD_PROPERTY
    JPRONAM = '$isHidden'      : JPROVAL ='true' : Gosub PRO_ADD_PROPERTY
   Endif
   JPRONAM = '$where'
   JPROVAL = func JSOVAR('escJson(func '+func APREFIXTRT.GET_PREFIX_JSO + CODREP+'.GET_SDATAFILTER("'+ASHW.ASWOPT(I).OPTCOD+'"))')
   Gosub PRO_ADD_PROPERTY_TEXT
   Gosub PRO_ADD_END_OBJECT :#filter
  #Endif :#If ASHW.ASWOPT(I).OPTOBY<>2
  Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), 'When  "'+ASHW.ASWOPT(I).OPTCOD+'" : '  )
  Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), 'X3FILTER='+"'"+func ESCQUOTE(ASHW.ASWOPT(I).OPTCND)+"'"  )
 Next I
 If FFILTER>0
  Gosub PRO_ADD_END_OBJECT :#$filters
 Endif
Endif

Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), 'When  Default: X3FILTER="1=1"')
Call APPEND_LINE(JPROIND,-1,BLOCS(BFILTER1), "Endcase")
Call APPEND_LINE(JPROIND,0,BLOCS(BFILTER1), "End X3FILTER")
Return

#**
#* TRT_MENU_AFAC : Define menu for a facette AFAC
#*!
$TRT_MENU_AFAC
Local Integer AMEN
Local Char    AMENPAR(12)(1..)
Local Integer AMENNBR
Local Char    CODMENU(20)
Local Integer SUITEMENU
Local Char    BINDS_CODE(20)(1..)
Local Decimal BINDS_POS(1..),NUMMENU
Local Integer BINDS_NBR

 If ASHW.ASWFAC(AFAC).AFFLNKFAC | ASHW.ASWFAC(AFAC).LNKMENFAC=""
  #Add links first if the default item isn't a menu
  NUMMENU=1 : CODMENU = "" : Gosub PRO_ADD_MENU_BINDS
 Endif

 #Append "" as the main parent
 Raz AMENPAR,AMENNBR
 AMENNBR += 1 : AMENPAR(AMENNBR) = ""

 For AMEN = 1 To maxtab(ASHW.ASWFAC(AFAC).ASWMN)

  While AMENNBR & ASHW.ASWFAC(AFAC).ASWMN(AMEN).PARMENU <> AMENPAR(AMENNBR)
   AMENPAR(AMENNBR) = ""
   AMENNBR -= 1 : Gosub PRO_ADD_END_LAYOUT
  Wend

  #Loop on links
  If SUITEMENU & ASHW.ASWFAC(AFAC).ASWMN(AMEN).PARMENU=""
  #Add links after if the default item is a menu
  SUITEMENU=0
  NUMMENU=1 : CODMENU = "" : Gosub PRO_ADD_MENU_BINDS
  Endif

  #Create the item:
  JPRONAM = ''            : Gosub PRO_ADD_START_OBJECT
  JTITLE = ASHW.ASWFAC(AFAC).ASWMN(AMEN).LIBMENU: LOCALIAS="menu"+ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU : Gosub PRO_ADD_TITLE :#SAM115576
  If ASHW.ASWFAC(AFAC).LNKMENFAC = ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU
   #SAM 108421 JPRONAM="$style" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT
   JPRONAM="$kind" : JPROVAL = "main" : Gosub PRO_ADD_PROPERTY_TEXT : #SAM 108421
  Endif

  JPRONAM = '$CODMENU'  : JPROVAL = ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM = '$PARMENU'  : JPROVAL = ASHW.ASWFAC(AFAC).ASWMN(AMEN).PARMENU : Gosub PRO_ADD_PROPERTY_TEXT

  JPRONAM = '$category'  : JPROVAL = "menus" : Gosub PRO_ADD_PROPERTY_TEXT
  JPRONAM = '$isBoxCollapsable'  : JPROVAL ='true' : Gosub PRO_ADD_PROPERTY
  JPRONAM = '$opened'  : JPROVAL ='false' : Gosub PRO_ADD_PROPERTY

  JPRONAM = '$layout'  : Gosub PRO_ADD_START_OBJECT
  JPRONAM = '$items'  : Gosub PRO_ADD_START_ARRAY

  #Add links on menu
  NUMMENU=(10000*AMEN) : CODMENU = ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU : Gosub PRO_ADD_MENU_BINDS
  If ASHW.ASWFAC(AFAC).AFFLNKFAC=0 & ASHW.ASWFAC(AFAC).LNKMENFAC = ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU
  SUITEMENU=1
  Endif

  #Append the item as a parent for the following item:
  AMENNBR += 1 : AMENPAR(AMENNBR) = ASHW.ASWFAC(AFAC).ASWMN(AMEN).CODMENU
 Next AMEN

 If SUITEMENU
  #Add links after if the default item is a menu and the only one menu
  NUMMENU=1 : CODMENU = "" : Gosub PRO_ADD_MENU_BINDS
 Endif

 #Close layout(s)
 While AMENNBR & (AMENPAR(AMENNBR) <> "")
  AMENNBR -= 1 : Gosub PRO_ADD_END_LAYOUT
 Wend
Return


