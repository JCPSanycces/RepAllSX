If ASHW.ASWR(I).ACLAF.OBLIG=2
 JPRONAM = func ASYRSUB.CODATT("M")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
Endif

If len(CONDHIDDEN)
 CONDHIDST   = func GET_CONDITION('(instr(1,"'+CONDHIDDEN+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 CONDHIDST = 'If '+CONDHIDST
 If (len(CONDHIDDEN)<6) :JSTATEMENT = CONDHIDST: Gosub PRO_ST_IF :Endif
 JPRONAM = func ASYRSUB.CODATT("H")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
 If (len(CONDHIDDEN)<6) :JSTATEMENT = CONDHIDST: Gosub PRO_ST_ENDIF :Endif
Endif

#76076/42 isExcluded
Raz CONDEXCLUDED
CONDEXCLUDED +=string$(ASHW.ASWR(I).STADETPRO=3,"d" )
CONDEXCLUDED +=string$(ASHW.ASWR(I).STAEDIPRO=3,"e" )
CONDEXCLUDED +=string$(ASHW.ASWR(I).STAQRYPRO=3,"qb")
CONDEXCLUDED +=string$(ASHW.ASWR(I).STALOKPRO=3,"l" )
CONDEXCLUDED +=string$(ASHW.ASWR(I).STASUMPRO=3,"s" )

If len(CONDEXCLUDED)
 CONDHIDST   = func GET_CONDITION('(instr(1,"'+CONDEXCLUDED+'",AF)>0)',CONDNBR,CONDTBL,BLOCS(BJSON1))
 CONDHIDST = 'If '+CONDHIDST
 If (len(CONDEXCLUDED)<6) :JSTATEMENT = CONDHIDST: Gosub PRO_ST_IF :Endif
 JPRONAM = func ASYRSUB.CODATT("e")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
 If (len(CONDEXCLUDED)<6) :JSTATEMENT = CONDHIDST: Gosub PRO_ST_ENDIF :Endif
Endif

If ASHW.ASWR(I).TYPAFFPRO<>2
 JPRONAM = func ASYRSUB.CODATT("R")   : JPROVAL = 'true'  : Gosub PRO_ADD_PROPERTY
Endif


If !find(ASHW.ASWR(I).ACLAF.ATY.TYPTYP,[V]CST_ATYPBLOB,[V]CST_ATYPCLOB)  :#& len(ASHW.ASWR(I).GRIPRO)
 #The property isn't a CLOB or a BLOB

 If find(ASHW.ASWR(I).ACLAF.ATY.FICLIEN,"ATEXTRA")
   JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
    #87485/1 insensitive filters
    #JPRONAM = '$capabilities' : JPROVAL = 'sort,filter,localize' : Gosub PRO_ADD_PROPERTY_TEXT
    JPRONAM = '$capabilities' : JPROVAL = 'sort,filter,filter_upper,localize' : Gosub PRO_ADD_PROPERTY_TEXT
    JPRONAM = '$links' : Gosub PRO_ADD_START_OBJECT
    JPRONAM = '$localize' : Gosub PRO_ADD_START_OBJECT

    JPRONAM = '$type'   :  JPROVAL = 'application/json;vnd.sage=syracuse' : Gosub PRO_ADD_PROPERTY_TEXT

    JPRONAM = '$title'
    NBMES += 1
    TBLMESNUM(NBMES) = 232
    TBLMESCHP(NBMES) = 124
    JPROVAL = '{@mes'+num$(TBLMESCHP(NBMES)) + "_" +num$(TBLMESNUM(NBMES)) + '}'
    Gosub PRO_ADD_PROPERTY_TEXT

    JPRONAM = '$url'
    If len(ASHW.ASWR(I).PTRCLA)
     JPROVAL  = '{$instanceUrl}/'
    Else
     JPROVAL  = '{$repUrl}/'
    Endif
    If (len(GRPGRI)>0)& (COLMIN=1) & (COLMAX=1)
     JPROVAL  += GRPGRI + '/'
    Endif
    JPROVAL  +=ASHW.ASWR(I).ALIAS+'/$localize'
    Gosub PRO_ADD_PROPERTY_TEXT
    Gosub PRO_ADD_END_OBJECT : #$localize
    Gosub PRO_ADD_END_OBJECT : #$links
   Gosub PRO_ST_ELSE
    #87485/1 insensitive filters
    #JPRONAM = '$capabilities' : JPROVAL = 'sort,filter' : Gosub PRO_ADD_PROPERTY_TEXT
    If ASHW.ASWR(I).ACLAF.ATY.TYPTYP=[V]CST_ATYPCHAR | ASHW.ASWR(I).ACLAF.CODTYP = "ATX"
    JPRONAM = '$capabilities' : JPROVAL = 'sort,filter,filter_upper' : Gosub PRO_ADD_PROPERTY_TEXT
    Else
    JPRONAM = '$capabilities' : JPROVAL = 'sort,filter' : Gosub PRO_ADD_PROPERTY_TEXT
    Endif
   JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
 Elsif instr(1,ASHW.ASWR(I).CODPRO,".")
  # doesn't belong to the representation:
  If dim(ASHW.ASWR(I).ACLAF.FLGBASFLD)>0 & ASHW.ASWR(I).ACLAF.FLGBASFLD<>1

   #87485/1 insensitive filters
   #JPRONAM = '$capabilities' : JPROVAL = 'sort,filter' : Gosub PRO_ADD_PROPERTY_TEXT
   JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_IF
    #102160 : filter and filter_upper capabilities not supported in $edit facets
    JPRONAM = '$capabilities' : JPROVAL = 'sort' : Gosub PRO_ADD_PROPERTY_TEXT
   Gosub PRO_ST_ELSE
    If ASHW.ASWR(I).ACLAF.ATY.TYPTYP=[V]CST_ATYPCHAR | ASHW.ASWR(I).ACLAF.CODTYP = "ATX"
     JPRONAM = '$capabilities' : JPROVAL = 'sort,filter,filter_upper' : Gosub PRO_ADD_PROPERTY_TEXT
    Else
     JPRONAM = '$capabilities' : JPROVAL = 'sort,filter' : Gosub PRO_ADD_PROPERTY_TEXT
    Endif

   JSTATEMENT = 'If AF="e"' : Gosub PRO_ST_ENDIF
  Endif
 Endif
Endif

If ASHW.ASWR(I).ACLAF.ATY.FMTPROSYR>1
 JPRONAM = "$format"   : JPROVAL = func ASYRSUB.FMTPRO(ASHW.ASWR(I).ACLAF.ATY.FMTPROSYR)  : Gosub PRO_ADD_PROPERTY_TEXT
Endif
Return

