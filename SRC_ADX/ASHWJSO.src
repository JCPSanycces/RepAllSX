#**
#* PRO_ADD_PROPERTY
#*!
$PRO_ADD_PROPERTY
JSTATEMENT = '"'+JPRONAM + '":'+JPROVAL
JCST = find(JSTATEMENT,PROCST)
If JCST
 If len(JSEP(JLEV))
  JSTATEMENT = JSEP(JLEV)  : Gosub PRO_ST_APPEND
 Endif
 Gosub PRO_ST_CLOSE
 Gosub PRO_ST_WCLOB
 JSTATEMENT = " CS("+num$(JCST)+")" : Gosub PRO_ST_LINE
Else
 JSTATEMENT = JSEP(JLEV)+JSTATEMENT  : Gosub PRO_ST_APPEND
Endif
JSEP(JLEV)=','
Return

#**
#* PRO_ADD_ENUM_ITEM
#*!
$PRO_ADD_ENUM_ITEM
NBMES += 1
TBLMESNUM(NBMES) = MESNUM
TBLMESCHP(NBMES) = MESCHP

JSTATEMENT = JSEP(JLEV) +'{"$value":'+num$(MESNUM)
JSTATEMENT += ',"$title":"'
JSTATEMENT += '{@mes'+num$(MESCHP) + "_" +num$(MESNUM) + '}'
JSTATEMENT +='"}'
Gosub PRO_ST_APPEND
JSEP(JLEV)=','
Return

#**
#* ESCQUOTE
#*!
Funprog ESCQUOTE(_STR)
Value Clbfile      _STR

Local Clbfile JSTR
Local Integer I
Local Integer ILG

#2°) replace ' by "'+" + '"'+ "'" + '"' + "+'"
While len(_STR)
 I = instr(1,_STR,"'")
 If I
  Append JSTR, left$(_STR,I-1)
  Append JSTR, "'+"
  Append JSTR, '"'
  Append JSTR, "'"
  Append JSTR, '"'
  #VPO 90833
  ILG+=len(left$(_STR,I-1))+7
  If ILG+len(right$(_STR,I+1))>220
   Append JSTR, chr$(10)+"&"-"+'"
   ILG=4
  Else
   Append JSTR, "+'"
  Endif
  _STR   = right$(_STR,I+1)
 Else
  If len(_STR)>240
  Append JSTR, left$(_STR,219)
  Append JSTR, "'"
  Append JSTR, chr$(10)+"&"-"+'"
  Append JSTR, right$(_STR,220)
  Else
  Append JSTR, _STR
  Endif
  Raz _STR
 Endif
Wend
End JSTR

#**
#* APPEND_JSON_STRING
#*!
Funprog APPEND_JSON_STRING(_STR)
Value Char _STR

Local Clbfile JSTR

JSTR = func ESCQUOTE(escJson(_STR))
End JSTR


