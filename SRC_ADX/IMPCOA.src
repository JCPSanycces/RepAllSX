#<AdxTL>@(#)0.0.0.0 $Revision$

# Import du code plan
# L'objet COA déclare la table GCOA qui remplit automatiquement les masque COA0/COA1/COA2.
#  Une condition sur le COA2 - Compte divers - MAJ uniquement si Plan déjà existant.


$ACTION
 Case ACTION
  When "IMP_ZONE" : Gosub IMP_ZONE
 Endcase
Return


$IMP_ZONE
Case IMPZON
 When "ACCMIS"
  # Si l'import crée le Plan de compte, cela signifie qu'il n'y a pas de encore de compte donc pas d'import de "Compte Divers"
  If GREP="C" : [M]ACCMIS(nolign-1)="" : Endif
Endcase
Return

