#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXTRTRL","DEXTRTRL",4,"") From GTRAITE
End

#########################################
## Traitement des actions : EXTRTRL
#########################################
$ACTION
Case ACTION
 When "INIT"     : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "SORTIE"   : Gosub SORTIE
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "BOUTON"   : Gosub BOUTON :#81085
Endcase
Return

#########################################
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#83271
GCURLEG="FRA"
If dim([M:DIA]LEG)>0 : [M:DIA]LEG=GCURLEG : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
Affzo [DIA] : Setmok [DIA] With 0 :#83271
Call AFF_MEMO From DIVPAYE :#81085
Return

#########################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#81085
######################################################
$BOUTON
Case BOITE
When "DEXTRTRL", "GENTRL"
 Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
  Endcase
Endcase
Return

#########################################
$OUVRE
Local Char    CRITERE(250), CRITFCY(250)
Local Integer VOK, STAT, I
Local Char    COMPTEUR(GLONANM)
If clalev([F:TRH])=0   : Local File TIKRESHEA  [TRH]  : Endif
If clalev([F:TRL])=0   : Local File TIKRESLIG  [TRL]  : Endif
If clalev([F:CPY])=0   : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0   : Local File FACILITY   [FCY]  : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR   [HRCTR]: Endif
If clalev([F:ID])=0    : Local File EMPLOID    [ID]   : Endif
If clalev([F:TCA])=0   : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:FEL])=0   : Local File FILEDIL    [FEL]  : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA]: Endif
If clalev([F:HSP])=0   : Local File HISTOPAYE  [HSP]  : Endif
If clalev([F:VEP])=0   : Local File VALEMP     [VEP]  : Endif
If clalev([F:VLA])=0   : Local File VALEUR     [VLA]  : Endif
If clalev([F:FGR])=0   : Local File FACGROUP   [FGR]  : Endif
If clalev([F:FCY2])=0  : Local File FACILITY   [FCY2] : Endif
If clalev([F:CPY2])=0  : Local File COMPANY    [CPY2] : Endif

TIT = mess(200,10703,1) : # Extraction tickets restaurants
Local Mask EXTRTRL [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","trh") From GMEMO
#81085
#Raz [M:DIA]DINI
Call AFF_MEMO From DIVPAYE
Return

#########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 Gosub CTRL_EXISTE
 If VOK=2
  TMP = 1
  TRA = 1
 Else
  FIN=1
 Endif
Endif
Return

#########################################
$CTRL_EXISTE
VOK=2
CRITERE = 'DATTRE>=['+format$(GFMD,[M:DIA]DATSTR)+']'
CRITERE -= '& DATTRE<=['+format$(GFMD,[M:DIA]DATEND)+']'
If [M:DIA]ALLFCY<>2  : CRITERE -= '& FCY="'+[M:DIA]FCY+'"'        : Endif
If [M:DIA]ALLCPY<>2  : CRITERE -= '& CPY="'+[M:DIA]CPY+'"'        : Endif
If [M:DIA]MATDEB<>"" : CRITERE -= '& REFNUM>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE -= '& REFNUM<="'+[M:DIA]MATFIN+'"' : Endif

Filter [F:TRL] Where evalue(CRITERE)
Read [F:TRL]TRL0 Last
Filter [F:TRL]
If !fstat
 # Une commande existe déjà , voulez-vous poursuivre ?
 Call AVERTIR([F:TRL]CPY-":"-mess(204,10703,1)-"(n°"+[F:TRL]NUMTRE+")", VOK) From GESECRAN
Endif
Return

#########################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Gosub OUVRE From WPDEFTABLE

CRITERE = '[F:VEP]STA>1'

# Borne matricule
If [M:DIA]MATDEB<>"" : CRITERE -= '& [F:VEP]EMP>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE -= '& [F:VEP]EMP<="'+[M:DIA]MATFIN+'"' : Endif
# Borne date
CRITERE -= '& [F:VEP]STRDAT>=['+format$(GFMD,[M:DIA]DATSTR)+']'
CRITERE -= '& [F:VEP]ENDDAT<=['+format$(GFMD,[M:DIA]DATEND)+']'
# Service
If [M:DIA]ALLSRV<>2  : CRITERE -= '& [F:VEP]SRV="'+[M:DIA]SRV+'"'     : Endif
# Profil
If [M:DIA]ALLPRF<>2  : CRITERE -= '& [F:VEP]PRF="'+[M:DIA]PRF+'"'     : Endif

# Société
If [M:DIA]ALLCPY<>2
 CRITFCY = '[F:CPY2]CPY="'+[M:DIA]CPY+'"'
Else
 CRITFCY = '[F:CPY2]CPYLEGFLG=2' :# toutes sociétés = toutes sociétés juridique !
Endif
# Site
If [M:DIA]ALLFCY<>2  : CRITFCY -= '& [F:FCY2]FCY="'+[M:DIA]FCY+'"'     : Endif

# Population
If [M:DIA]POP<>""
 Link [VEP] With
&   [HRPOA]POA0 = [M:DIA]POP;[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& , [ID]ID0   = [F:VEP]EMP
& , [HRCTR]CTR0 = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& , [FCY]FCY0 = [F:VEP]FCY
&   As [LNK]
&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
Else
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [HRCTR]CTR0 = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& , [FCY]FCY0 = [F:VEP]FCY
&   As [LNK]
&   Where evalue(CRITERE)
Endif

 Link [FGR] With
&   [FCY2]FCY0 = [F:FGR]FCY
& , [CPY2]CPY0 = [F:FGR]CPY
&   As [LNK2]
&   Where evalue(CRITFCY) & [F:CPY2]TRECPY<>"" & [F:FCY2]TREFCY<>"" & [F:CPY2]LEG=GCURLEG :#83271


Call EXTRACTION(1)

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

Return

################################################################################
#
# Routines
#
################################################################################

Subprog EXTRACTION(TRA)
Value Integer TRA

Local Integer STAT,  NBLIG
Local Char    FEH([V]GLONADI)
Local Char    COMPTEUR(GLONANM)
Local Char    VCPT(GLONVCR)

[L]FEH="TRL"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
[L]EXTRACTION=1

Call DEBTRANS From GLOCK
Gosub TR_EXTRACT
End

#-------------------------------------------------------------------------------
$TR_EXTRACT
GOK = 1
Trbegin [TRH],[TRL]
For [LNK2]FGR0(1)
 VCPT=""
 NBLIG=0
 For [LNK2]FGR0
  #Parcours des bulletins de paie
  For [LNK]VEP6(2) Where FCY=[F:LNK2]FCY
   Call CONTROLE([F:VEP]EMP,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[M]CRI,[L]STAT,0) From DIVPAYE
   If [L]STAT
    GOK=1
    If VCPT=""
     Gosub AFFECT_CPT
     If !GOK : Break 2 : Endif
    Endif
    For [LNK]VEP6
     Raz [F:TRL]
     [L]NIVEAU = 0
     Gosub RAZVAR From =[L]FEHTRT
     NBLIG+=1
     Onerrgo ERREURWW
     Gosub EXTRACTION From =[L]FEHTRT
     Onerrgo
     Call ECR_TRACE([F:VEP]EMP-[F:ID]NAM-[F:ID]SRN-[F:VEP]BUL,0) From GESECRAN
     Onerrgo ERREURWW
     Gosub CONTROLE From =[L]FEHTRT
     Onerrgo
     Gosub MAJFIC From =[L]FEHTRT
     [F:TRL]NUMTRE=VCPT
     [F:TRL]LIG=NBLIG
     [F:TRL]DATTRE=[M:DIA]DATEND
     Write [TRL]
     If fstat
      GOK=0 : Call FSTA("TRL") From GLOCK
      Break 4
     Endif
    Next
   Endif
  Next
 Next
 If GOK<1 : Break : Endif
 #Si au moins 1 ligne-> création de l'entête
 If GOK & NBLIG :  Gosub TR_HEAD : Endif
Next
If   GOK<0 : Goto ROLL_TR_EXTRACT
Elsif !GOK : Goto AB_TR_EXTRACT
Endif
Commit
Return

#########################
$TR_HEAD
Raz [TRH]
[F:TRH]=[F:TRL]
[F:TRH]FLGTRE=1
If dim([F:TRH]CREDAT)>0 : [F:TRH]CREDAT = date$ : Endif
If dim([F:TRH]CREUSR)>0 : [F:TRH]CREUSR = GUSER : Endif
If dim([F:TRH]CRETIM)>0 : [F:TRH]CRETIM = time  : Endif
Write [TRH]
If fstat
 GOK=0 : Call FSTA("TRH") From GLOCK : Return
Endif
#Opération réalisée : No commande
Call ECR_TRACE(mess(3,10705,1)-":"-mess(62,10935,1)-VCPT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return

#########################
$AFFECT_CPT
GOK=1
#Read [TCA]TCA0 = 15 : # Module Admin des RH
#COMPTEUR = [F:TCA]CODNUM(5)
#If COMPTEUR=""
# # Compteur inexistant
# Call ECR_TRACE(mess(12,114,1)-COMPTEUR,1) From GESECRAN
# GOK = 0 : Return
#Endif
Call LECTCA(15,STAT) From SUBTCA
If !STAT
  Call ECR_TRACE(mess(12,114,1),1) From GESECRAN
  GOK = 0 : Return
Else
  COMPTEUR= [F:TCA]CODNUM(5)
Endif

Call NUMERO(COMPTEUR,"",datesyst,"",VCPT,STAT) From SUBANM
If STAT
 # Erreur sur compteur
 Call ECR_TRACE(mess(4,10702,1)-COMPTEUR,1) From GESECRAN
 GOK = 0 : Return
Endif
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(62,10935,1)-VCPT,0) From GESECRAN
Return

#########################
$ERREURWW
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
End

#########################
$AB_TR_EXTRACT
Rollback
Return

#########################
$ROLL_TR_EXTRACT
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_EXTRACT : Endif
Return

######################################################################################
## Etiquette Ecran EXTRTRL
######################################################################################
Subprog AS_DATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR = GMOIPAY : Endif
End

Subprog AS_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR = eomonth([M]DATSTR) : Endif
End

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
#If VALEUR = 2
#  GCURLEG = ''
#Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#If dim([F:CPY]LEG)>0
#  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
#  GCURLEG = [F:CPY]LEG
#Endif
End
######################################################################################

