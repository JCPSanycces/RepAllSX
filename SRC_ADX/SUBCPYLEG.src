  If dim([M:DCP]POSCTYCOD)   > 0 : Raz [M:DCP]POSCTYCOD   : Chgfmt [M:DCP]POSCTYCOD  With "-K:5X"   : Endif
  If dim([M:DCP]CTYNAM)      > 0 : Raz [M:DCP]CTYNAM      : Chgfmt [M:DCP]CTYNAM     With "-K:40X"  : Endif
  If dim([M:DCP]DADPOSCOD)   > 0 : Raz [M:DCP]DADPOSCOD   : Chgfmt [M:DCP]DADPOSCOD  With "-K:15X"  : Endif
  If dim([M:DCP]POSCTY)      > 0 : Raz [M:DCP]POSCTY      : Chgfmt [M:DCP]POSCTY     With "-K:15X"  : Endif
  If dim([M:DCP]DADCRN)      > 0 : Raz [M:DCP]DADCRN      : Chgfmt [M:DCP]DADCRN     With "-K:15X"  : Endif
