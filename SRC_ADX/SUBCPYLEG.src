  If dim([M:DCP]DADFCY)      > 0 : Raz [M:DCP]DADFCY      : Chgfmt [M:DCP]DADFCY     With "-K:5X"   : Endif
  If dim([M:DCP]DADCRN2)     > 0 : Raz [M:DCP]DADCRN2     : Chgfmt [M:DCP]DADCRN2    With "-K:15X"  : Endif
  If dim([M:DCP]ADDCPL2)     > 0 : Raz [M:DCP]ADDCPL2     : Chgfmt [M:DCP]ADDCPL2    With "-K:40X"  : Endif
  If dim([M:DCP]STREETNUM2)  > 0 : Raz [M:DCP]STREETNUM2  : Chgfmt [M:DCP]STREETNUM2 With "-K:4X"   : Endif
  If dim([M:DCP]ABC2)        > 0 : Raz [M:DCP]ABC2        : Chgfmt [M:DCP]ABC2       With "-K:1X"   : Endif
  If dim([M:DCP]STREET2)     > 0 : Raz [M:DCP]STREET2     : Chgfmt [M:DCP]STREET2    With "-K:40X"  : Endif
  If dim([M:DCP]POSCTYCOD2)  > 0 : Raz [M:DCP]POSCTYCOD2  : Chgfmt [M:DCP]POSCTYCOD2 With "-K:5X"   : Endif
  If dim([M:DCP]CTYNAM2)     > 0 : Raz [M:DCP]CTYNAM2     : Chgfmt [M:DCP]CTYNAM2    With "-K:15X"  : Endif
  If dim([M:DCP]DADPOSCOD2)  > 0 : Raz [M:DCP]DADPOSCOD2  : Chgfmt [M:DCP]DADPOSCOD2 With "-K:15X"  : Endif
  If dim([M:DCP]POSCTY2)     > 0 : Raz [M:DCP]POSCTY2     : Chgfmt [M:DCP]POSCTY2    With "-K:15X"  : Endif
