#FRLAA - 2016-06-06 - REQUIREMENT 114309 US 11 - START
$STYLE

Call DISPLAY_HIDE()
#HEGES - 2017-03-13 - X3-16387 - Start
#JASMI - 2017-04-19 - Issue 122550 - START
#If [M:CPY1]LEG = "BRI"
If GCURLEG = "BRI"
#JASMI - 2017-04-19 - Issue 122550 - END
  Chgtzn[M:CPY0]CPY With "Company ref."
  Chgtzn[M:CPY0]CPYNAM With "Company name"
Endif
#HEGES - 2017-03-13 - X3-16387 - End
Return


Subprog DISPLAY_HIDE()

#call automatic show/hide
  Call HIDE_ACTIVITYFIELDS From WOCPYHIDE
  Call SHOW_LEGACTCALLS From WOCPYSHOW

#show all SPECIFIC fields
  Gosub SHOW_ALL_SPECIFIC

#hide SPECIFIC fields
  Gosub HIDE_SPECIFIC

End

$SHOW_ALL_SPECIFIC
#show fields
If dim([M:CPY1]CPYLOG )>0 :   Chgfmt [M:CPY1]CPYLOG     With "+K:10X"   : Endif
If dim([M:CPY1]EECNUM )>0 :   Chgfmt [M:CPY1]EECNUM     With "+K:20X"   : Endif
If dim([M:BPA]XEXTNUM )>0 :   Chgfmt [M:BPA]XEXTNUM     With "+K:30X"  :   Endif

If dim([M:CPY1]RGCAMT )>0 :   Chgfmt [M:CPY1]RGCAMT     With "+Nz:13.0"   : Endif
If dim([M:CPY1]CRN )>0    :   Chgfmt [M:CPY1]CRN        With "+K:20X"     : Endif
If dim([M:CPY1]CPYLOG )>0 :   Chgfmt [M:CPY1]CPYLOG     With "+K:10X"   : Endif
If dim([M:BPA]XCODSEE )>0 :   Chgfmt [M:BPA]XCODSEE     With "+K:10X"     : Endif
Return

$HIDE_SPECIFIC
#KZA
If func DIVPAYE.IS_KZA(GCURLEG)
  If dim([M:CPY1]CPYLOG )>0 : Raz [M:CPY1]CPYLOG    :   Chgfmt [M:CPY1]CPYLOG     With "-K:10X"   : Endif
  If dim([M:CPY1]EECNUM )>0 : Raz [M:CPY1]EECNUM    :   Chgfmt [M:CPY1]EECNUM     With "-K:20X"   : Endif
  If dim([M:BPA]XEXTNUM )>0 : Raz [M:BPA]XEXTNUM    :   Chgfmt [M:BPA]XEXTNUM     With "-K:30X"   : Endif
Endif

#LIMAS - 2017-07-31 - X3-35355 - START
If func DIVPAYE.IS_KGH_LEG(GCURLEG) Then
