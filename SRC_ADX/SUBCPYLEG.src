Endif
#LIMAS - 2017-07-31 - X3-35355 - END

#Kenya
#ADNGO - 2017-08-24 - X3-53125 - START
If func DIVPAYE.IS_KKE_LEG(GCURLEG) Then
  If dim([M:CPY3]SCT1)>0  :   Raz [M:CPY3]SCT1   :   Chgfmt [M:CPY3]SCT1   With "-K:20X" : Endif
  If dim([M:CPY3]SCT2)>0  :   Raz [M:CPY3]SCT2  :   Chgfmt [M:CPY3]SCT2   With "-K:20X" : Endif
  #Parameter Block
  If dim([M:CPY3]DCLDIRBALPAY)>0  :  Raz [M:CPY3]DCLDIRBALPAY : Chgfmt [M:CPY3]DCLDIRBALPAY     With "-LA:1"   :  Endif
  If dim([M:CPY3]BDFECOCOD)>0     :  Raz [M:CPY3]BDFECOCOD    : Chgfmt [M:CPY3]BDFECOCOD        With "-K:10X"  :  Endif
  If dim([M:CPY3]SCINUM)>0        :  Raz [M:CPY3]SCINUM       :  Chgfmt [M:CPY3]SCINUM          With "-K:35X"  :  Endif
