  If WWSTN < 1 : WWSTN = 1 : Endif               # llc 11.01 USA
  If !pat(GVERSION,"1.5.*")
     # distinction exemplaires
     If [F:MWS]SBBFLG = 2
         WWSTN = 1
     Endif
  Endif

Else
  WWSTN      = [F:OPS]EXTWSTNBR
  If WWSTN < 1 : WWSTN = 1  : Endif              # llc 11.01 USA
Endif
End WWSTN

#############################################################################
Funprog OPE_GETWST()
# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
Local Char    XSBB(15)
Local Char    XSBBWST(GLONWST), XSBBWSTB(GLONWST)
Local Char    XWST(GLONWST)
Local Integer XIND, XINDB
Local Integer XWSTNBR
Local Integer K,L,M
# Issue 78437 - 2011-12-05 by VPO : gestion des distinctions
##Local Char    WWST    (GLONWST): # poste                            # distinction
Local Char    WWST(GLONWST)   : # poste                            # distinction

If find([F:OPS]OPSSTA,1,2)
  If [F:MFO]CPLWST = ""
    WWST     = [F:MFO]EXTWST
  Else
    WWST     = [F:MFO]CPLWST
  Endif
  If !pat(GVERSION,"1.5.*")
     # distinction exemplaires
     If [F:MWS]SBBFLG = 2
         If [F:MWS]WST <> XWST : Gosub SBB_EXTRACT : Endif
         XWST = [F:MWS]WST
         If [F:MFO]SCHSBB = ""
             # pseudo code sous-poste 0
             XIND = 0
         Else
             XIND = find([F:MFO]SCHSBB,XSBBT(0..NBSBB-1))
             If XIND = 0 : XSBB = "" : Else : XIND -= 1 : XSBB = XSBBT(XIND) : Endif
         Endif
         Gosub SBB_NAME
         WWST  = XSBBWST
     Endif
  Endif

Else
  WWST       = [F:OPS]EXTWST
Endif
End WWST

#############################################################################
Funprog OPE_GETWCR()
Local Char    WWST    (GLONWST): # poste                            # distinction

# Issue 78437 - 2011-12-05 by VPO : gestion des distinctions
##WWST = func PITMFG.OPE_GETWST()
If find([F:OPS]OPSSTA,1,2)
  If [F:MFO]CPLWST = ""
    WWST     = [F:MFO]EXTWST
  Else
    WWST     = [F:MFO]CPLWST
  Endif
Else
  WWST       = [F:OPS]EXTWST
Endif

# lecture poste pour centre de charge et type
Read [MWS]WST0=WWST;[F:OPS]MFGFCY
If !fstat
    End [F:MWS]WCR
Endif
End ""

#########################################################################
# distinction des exemplaires
$SBB_EXTRACT
# recherche des critères de distinction sur le poste
# Issue 78437 - 2011-12-05 by VPO : gestion des distinctions
##Filter [MFO2] Where MFGFCY = [F:OPS]MFGFCY &
Filter [MFO2] Where MFGFCY = [F:MWS]WCRFCY  &
&                   EXTWST = [F:MWS]WST     &
&                   SCHSBB <> ""
&               Order By Key MFO2(3)

NBSBB  = 0
XSBBT(NBSBB) = ""
NBSBB += 1
For [MFO2]
    If NBSBB >= [F:MWS]WSTNBR : Break : Endif
    XSBBT(NBSBB) = [F:MFO2]SCHSBB
    NBSBB       += 1
Next

Filter [MFO2]
Return
#########################################################################
# distinction des exemplaires
$SBB_NAME
If XIND = 0 : XSBBWST = XWST : Return : Endif
XSBBWST = format$("Kb:"+num$(GLONWST+1)+"X",XWST)+"-"-format$("N0:2",XIND)-format$("Kb:15X",XSBB)
Return

#############################################################################
Funprog OPE_GETWOPTIM
OPTIM=0
If find([F:OPS]OPSSTA,1,2)
    OPTIM=0
Else
    # recherche si optimisé
    # llc 10.02
    For [ORD]ORD0 Where WIPTYP = 5 & WIPNUM = [F:OPS]MFGNUM & WIPSTA = 3
        If [F:ORD]OPTFLG = 2 : OPTIM = 2 : Else : OPTIM = 0 : Endif
        Break
    Next
Endif
End num$(OPTIM)
