##################################################
If PITACH <>""
    Local Integer WPREACH : Raz WPREACH
    Local Char    WFICACHREF(GLONVCR+GLONITM+20)
    Local Char    OPTACH(200)
    Local Char    OPTACHTMP(200)
    OPTACH = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilach")
    OPTACHTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilachtmp")
