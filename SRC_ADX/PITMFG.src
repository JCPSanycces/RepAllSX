    Call READPIT(PITRSS,RWKNBZON,RWKNORECMES,RWKHEATYP,RWKHEADMES) From CONNECTFCT
    Local Char    RWKTABZON(GLONATB+GLONAVA+2)(1..RWKNBZON) : Raz RWKTABZON
