  Endif
  If [F:MFO]OPESTA = 4 :   WFRCSTRD   = WTRTDAT     : Endif    # llc 09.01 10262

Endif
If WFRCSTRD=[0/0/0]
    End "000000"
Endif
End WFRCSTRD

