    Call WRPIVOT_HEAD(PITITM,IWKNBZON,IWKTABZON,IWKTABABR,IWKZON,IWKWRK,IWKHEATYP,IWKHEADMES,WPREITM,OPTITM) From CONNECTFCT
Endif

