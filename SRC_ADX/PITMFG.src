#############################################################################
Funprog OPE_GETLABNBR()
WLAB=func PITMFG.OPE_GETLAB()
If find([F:OPS]OPSSTA,1,2)
  If WLAB = ""
    WLABN = 0
  Else
    WLABN = [F:MFO]EXTLABNBR
    If WLABN < 1 : WLABN = 1 : Endif             # llc 11.01
  Endif
Else
  If WLAB = ""
    WLABN = 0
  Else
    WLABN = [F:OPS]EXTLABNBR
    If WLABN < 1 : WLABN = 1 : Endif             # llc 11.01
  Endif
Endif
End WLABN

#############################################################################
Funprog OPE_GETWFRCSTRF
Local Decimal WFRCSTRF : Raz WFRCSTRF        : # Fraction de jour début forcé
Local Integer NBOPFC : Raz NBOPFC
Local Decimal WFRCSTRH                    : # Heure début forcé
Local Decimal WDAYCAP
Local Decimal WDAYFR
Local Integer NBJCAL   : NBJCAL=2000      : # dimension tables calendrier
Local Decimal WCAP (NBJCAL)               : # capacité journalière poste
Local Integer WNBR(NBJCAL)                : # nombre d'exemplaire
Local Integer WRET      : WRET = 0

If find([F:OPS]OPSSTA,1,2)
  WFRCSTRF   = 0
  WFRCSTRD   = [F:MFO]FRCSTRDAT
  If WFRCSTRD <> [0/0/0]
    NBOPFC     +=1
    WFRCHOU     = [F:MFO]FRCSTRHOU
    Call CONVHOU(WFRCHOU,WFRCSTRH) From JALLIBB
    Gosub CALDFR_FRC
    WFRCSTRF = WDAYFR
  Endif
Else
Endif
End num$(WFRCSTRF)

#########################################################################
# Calcul fraction début op forcée
$CALDFR_FRC
#     lecture poste
    ###Read [MWS]WST0=WWST(I);WMFGFCY
    ###If fstat : WTAB="MWS" : WCLE=WWST(I) : Goto AB_OPT : Endif

    #  (llc 08.00 v130) nouvelle gestion des capacités
    WRET    = 0
    Call LOACAPO(WFRCSTRD,WFRCSTRD,WCAP,WNBR,WRET) From JALLIBB


#    Call CALDFR(WFRCSTRH,WDAYCAP,WDAYFR) From JALLIBB
##    Call NEWCALDFR([F:MWS]WCRFCY,WFRCSTRH,WDAYCAP,WDAYFR,func PITMFG.OPE_GETWST()) From JALLIBB
#
    WDAYCAP = WCAP(0)
If pat(GVERSION,"1.5.*")
    Call NEWCALDFR([MWS]WCRFCY,WFRCSTRH,WDAYCAP,WDAYFR,func PITMFG.OPE_GETWST()) From JALLIBB
Else
    Call CALDFR([F:MWS]WCRFCY,WFRCSTRD,WFRCSTRH,WFRCHOU,WDAYCAP,WDAYFR,[F:MWS]WST) From JALLIBB
Endif
Return

