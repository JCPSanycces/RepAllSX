#############################################################################
Funprog OPE_OROGETOPETIM ()
WEXTTIMA = func OPE_GETOPETIM ()
WSETTIMA = func OPE_GETEXTSETTIM ()
##VPO 14/10/10 68142
If WEXTTIMA = 0 & WSETTIMA = 0
    WEXTTIMA = 0.0001
Endif
End WEXTTIMA

#############################################################################
Funprog OPE_GETOPETIM ()
If find([F:OPS]OPSSTA,1,2)
  If [F:MFO]CPLQTY <> 0
      WRATIO        = ([F:MFO]EXTQTY - [F:MFO]CPLQTY) / [F:MFO]EXTQTY
      WOPETIM    = [F:MFO]EXTOPETIM * WRATIO
  Else
      WOPETIM    = [F:MFO]EXTOPETIM - [F:MFO]CPLOPETIM
      If WOPETIM < 0 : WOPETIM = 0 : Endif       # llc 01.03
  Endif
#      convertit en H si nécessaire
  If [F:MFO]TIMUOMCOD = 2
    WOPETIM /= 60
  Endif
Else
  WOPETIM    = [F:OPS]EXTOPETIM
#      convertit en H si nécessaire
  If [F:OPS]TIMUOMCOD = 2
    WOPETIM /= 60
  Endif
Endif
WEXTTIMA = func TRTX3.ARRTYP("", "", "TIH", WOPETIM)    # llc 10.02 regroupement
End WEXTTIMA

#############################################################################
Funprog OPE_GETSTDSETTIM ()
WSETTIMSTD=0
# 5.04
If [F:MFO]SCHGRP <> "" : WSETTIMSTD = [F:MFO]STDSETTIM : Endif
WSETTIMSTDA = func TRTX3.ARRTYP("", "", "TIH", WSETTIMSTD)    # DLL 5.04
End WSETTIMSTDA

#############################################################################
Funprog OPE_GETEXTSETTIM ()
If find([F:OPS]OPSSTA,1,2)
  WSETTIM    = [F:MFO]EXTSETTIM - [F:MFO]CPLSETTIM
  If WSETTIM < 0 : WSETTIM = 0 : Endif           # llc 01.03
  If [F:MFO]CPLQTY <> 0
      WSETTIM    = 0                                # llc 11.01
  Endif
#      convertit en H si nécessaire
  If [F:MFO]TIMUOMCOD = 2
    WSETTIM /= 60
  Endif

Else
  WSETTIM    = [F:OPS]EXTSETTIM
#      convertit en H si nécessaire
  If [F:OPS]TIMUOMCOD = 2
    WSETTIM /= 60
  Endif
Endif
WSETTIMA = func TRTX3.ARRTYP("", "", "TIH", WSETTIM)    # llc 10.02 regroupement
End WSETTIMA

#############################################################################
Funprog OPE_GETPSPTIM()
If find([F:OPS]OPSSTA,1,2)
  If [F:MFO]PSPTIM > [F:MFO]WAITIM
      WPSPTIM    = [F:MFO]PSPTIM
  Else
      WPSPTIM    = [F:MFO]WAITIM
  Endif
Else
  If [F:OPS]PSPTIM > [F:OPS]WAITIM
      WPSPTIM    = [F:OPS]PSPTIM
  Else
      WPSPTIM    = [F:OPS]WAITIM
  Endif
Endif
WPSPTIMA = func TRTX3.ARRTYP("", "", "TIH", WPSPTIM)
End WPSPTIMA

#############################################################################
Funprog OPE_APSGETPSPTIM()
WPSPTIMA = func OPE_GETPSPTIM()
WPSPTIMA += ( func OPE_GETSCOLTI_REEL () * 24 ) # VPO 14/10/10 68142 on ajoute le delai de sst en heures
End WPSPTIMA

