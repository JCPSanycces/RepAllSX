##################################################
If PITORD <>""
    Local Integer WPREORD : Raz WPREORD
    Local Char    WFICORDREF(GLONVCR)
    Local Integer DWKNBZON        : Raz DWKNBZON
    Local Char    DWKNORECMES (50): Raz DWKNORECMES
    Local Integer DWKHEATYP       : Raz DWKHEATYP
    Local Char    DWKHEADMES (250): Raz DWKHEADMES

    Local Char    OPTORD(200)
    Local Char    OPTORDTMP(200)
    OPTORD = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilord")
    OPTORDTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilordtmp")
    Openo OPTORDTMP,0 Using [FPIV]
