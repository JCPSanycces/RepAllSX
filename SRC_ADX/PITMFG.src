    OPTPJT = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilpjt")
    OPTPJTTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilpjttmp")
