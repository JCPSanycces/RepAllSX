    Call READPIT(PITITM,IWKNBZON,IWKNORECMES,IWKHEATYP,IWKHEADMES) From CONNECTFCT

    Local Char    IWKTABZON(GLONATB+GLONAVA+2)(1..IWKNBZON) : Raz IWKTABZON
    Local Char    IWKTABABR(GLONABR)(1..IWKNBZON) : Raz IWKTABABR
    Local Char    IWKZON(GLONAVA)(1..IWKNBZON) : Raz IWKTABZON
    Local Char    IWKFRM(150)(1..IWKNBZON) : Raz IWKFRM
