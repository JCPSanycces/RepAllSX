##################################################
If PITRSS <>""
    Local Char    WFICEXTLAB(GLONWST)
    Local Char    WFICEQUNUM(GLONITM)
    Local Char    OPTRSS1(200)
    OPTRSS1 = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilrss1")
    Openo OPTRSS1 ,0 Using [RSS1]
    Openo Using [RSS1]
    Local Char    OPTRSS2(200)
    OPTRSS2 = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilrss2")
    Openo OPTRSS2 ,0 Using [RSS2]
    Openo Using [RSS2]

    Local Integer WPRERSS : Raz WPRERSS
