##################################################
If PITSTO <>""
    Local Integer WPRESTO : Raz WPRESTO
    Local Char    WFICSTOREF(GLONITM)
    Local Char    OPTSTO(200)
    Local Char    OPTSTOTMP(200)
    OPTSTO = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilsto")
    OPTSTOTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilstotmp")
    Openo OPTSTOTMP,0 Using [FPIV]
    Openo Using [FPIV]

    Local Integer TWKNBZON        : Raz TWKNBZON
    Local Char    TWKNORECMES (50): Raz TWKNORECMES
    Local Integer TWKHEATYP       : Raz TWKHEATYP
    Local Char    TWKHEADMES (250): Raz TWKHEADMES

    Call READPIT(PITSTO,TWKNBZON,TWKNORECMES,TWKHEATYP,TWKHEADMES) From CONNECTFCT
    Local Char    TWKTABZON(GLONATB+GLONAVA+2)(1..TWKNBZON) : Raz TWKTABZON
    Local Char    TWKTABABR(GLONABR)(1..TWKNBZON) : Raz TWKTABABR
    Local Char    TWKZON(GLONAVA)(1..TWKNBZON) : Raz TWKTABZON
    Local Char    TWKFRM(150)(1..TWKNBZON) : Raz TWKFRM
    Local Integer TWKWRK(1..TWKNBZON) : Raz TWKWRK
    Local Char    TWKVAL(255)(1..TWKNBZON) : Raz TWKVAL
    Local Char    TWKVALFIC(GLONAVA)(1..TWKNBZON) : Raz TWKVALFIC
    Call LOADPIVZON(PITSTO,TWKNBZON,TWKTABZON,TWKTABABR,TWKZON,TWKFRM,TWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITSTO,TWKNBZON,TWKTABZON,TWKTABABR,TWKZON,TWKWRK,TWKHEATYP,TWKHEADMES,WPRESTO,OPTSTO) From CONNECTFCT
Endif

##################################################

If CRITERE1 = "" : CRITERE1 = "1=1" : Endif
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif

# 05.05 30049
# analyse présence formule de sélection
If P_FORMULE <> ""
    Read [F:TFO]TFO0=10;P_FORMULE
    If !fstat
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif
fstat = 0
# s'il existe une formule on débranche sur un link
If FORMULE1 <> ""
    Link [OPS] With [MFG]MFG0~=[F:OPS]MFGNUM, [ITF]ITF0~=[F:MFG]ROUNUM;[F:MFG]MFGFCY, [ITM]ITM0~=[F:ITF]ITMREF As [OPX]
&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key OPS1(1)
    For [OPX]
       # ---- PE CHECKOPS
       GOK = 1
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
Else
    Filter [OPS] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT)
&               Order By Key OPS1(1)
    For [OPS]
       # ---- PE CHECKOPS
       GOK = 1
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
    Filter [OPS]
Endif

Gosub ECR_RSS_FILE
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$PROCESS_OF
Local Integer I,J,IS,JS,IP,JP,IPREC,ILK
Local Integer NBOP,NBOPR,DOPNT,NBOPNT,WPREC,WSUIV,WSPLSUIV
If [F:OPS]OPSSTA=4 : Return : Endif
If PITMFG<>"" : Call RAZVALPIVOT(PITMFG,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT : Endif
OK = 2
Raz [BPC]
If find([F:OPS]OPSSTA,1,2)
    If FORMULE1 = ""
        Read [MFG]MFG0=[F:OPS]MFGNUM
        If fstat : Goto NXT2 : Endif
    Endif
    #----------------------------------------------------------------------------------------------
    GPOINT = "OPTDATCONT"
    Gosub  ENTREE From EXEFNC
    If !GPE
        If [F:MFG]STRDAT < WSTRDAT | [F:MFG]ENDDAT > WENDDAT
          Goto NXT2
        Endif
    Endif

    For [MFI]MFI0 Where MFGNUM = [F:OPS]MFGNUM
                    Break
    Next
    If [F:MFI]BPCTYPDEN = 2 & [F:MFI]BPCNUM <> ""
        Read [BPC]BPC0=[F:MFI]BPCNUM
        If fstat : Raz [BPC] : Endif
    Endif
Else
    Read [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
    If fstat : Goto NXT2 : Endif
    If [F:SCH]OPESTRDAT = [0/0/0] : Goto NXT2 : Endif

    For [ORD]ORD3 Where STOFCY = [F:OPS]MFGFCY & VCRTYP = 11 & VCRNUM = [F:OPS]MFGNUM & WIPTYP = 5
        #----------------------------------------------------------------------------------------------
        GPOINT = "OPTDATCONT"
        Gosub  ENTREE From EXEFNC
        If !GPE
            If [F:ORD]STRDAT < WSTRDAT | [F:ORD]ENDDAT > WENDDAT
                OK = 0
            Endif
        Endif
    Next
Endif

If !OK : Goto NXT2 : Endif

##inutile
##Call EVALPIVOT(PITMFG,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT

# si formule, article déjà en ligne
If FORMULE1 = ""
    #   lecture article
    WITMREF=func MFG_GETITMREF([M]RELITM)
    If [F:ITM]ITMREF <> WITMREF ## [M:OPTK]ITMREF
      Read [ITM]ITM0=WITMREF
      If fstat : Raz [F:ITM] :  Endif
    Endif
    #   lecture article/site
    If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> [F:OPS]MFGFCY
        Read [ITF]ITF0=WITMREF;[F:OPS]MFGFCY
        If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If find([F:OPS]OPSSTA,1,2)
    Gosub SEL_OFCOMPL
    If OK = 1 : Goto NXT2 : Endif
Endif

Gosub TRTEXT

$NXT2
Return


########################################################################
# Sélections complémentaires
$SEL_OFCOMPL
OK=1
If !find([F:MFG]SCDFLG,2,4)
    # 11.05 33303
    WMESS   = mess(156,197,1)+" "+mess([F:OPS]OPSSTA,317,1)+" "+[F:OPS]MFGNUM+" "+mess(1,335,1)
    If P_TRACE1 = 2
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    Return
Endif
If [F:MFG]MFGTRKFLG > 4 : Return : Endif
If [F:MFG]CFMFLG <> 2
    WMESS   = mess(156,197,1)+" "+mess([F:OPS]OPSSTA,317,1)+" "+[F:OPS]MFGNUM+" "+
&             mess(182,197,1)
    If P_TRACE1 = 2
        Call ECR_TRACE(WMESS,1) From GESECRAN
    Endif
    Return
Endif
# FQ 65461 GA 07/2010
# réextraire les OF en cours d'optimisation: on renvoie une erreur ssi mode Simulation demandé
#If [F:MFG]OPTFLG = 2 & P_TRTMOD = 1
If [F:MFG]OPTFLG = 2 & P_TRTMOD = 2
    WMESS   = mess(156,197,1)+" "+mess([F:OPS]OPSSTA,317,1)+" "+[F:OPS]MFGNUM+" "+
&             mess(125,193,1)+"("+[F:MFG]OPTUSR+")"
    If P_TRACE1 = 2
        Call ECR_TRACE(WMESS,1) From GESECRAN
    Endif
    Return
Endif
OK=2

Return


########################################################################
# Traitement extraction
$TRTEXT
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub EXTRAC
Return

########################################################################
# Extraction
$EXTRAC
WMESS   = mess(156,197,1)+" "+mess([F:OPS]OPSSTA,317,1)+" "+[F:OPS]MFGNUM+" "+mess(214,197,1)
Trbegin [MFG]
CODRET = 0
Gosub LOAD_OPE
If CODRET : Goto AB_TRTEXT : Endif

# mise à jour OF pour statut "à l'étude" si mode mise à jour
If P_TRTMOD = 1 & [F:OPS]OPSSTA <> 3
# Issue 79892 - 2012-02-06 by VPO : Si aucune opération, l'OF ne passe pas à l'étude
  If NBOPR>0
    Readlock [MFG]MFG0=[F:OPS]MFGNUM
    If fstat=1 & !GSERVEUR
        WTAB="MFG"
        WCLE=[F:OPS]MFGNUM
        Goto ROL_TRTEXT
    Endif
    If fstat
        WTAB="MFG"
        WCLE=[F:OPS]MFGNUM
        Goto AB_TRTEXT
    Endif
    #Issue 117368 - 2016-06-26 by RBA : PE pour récuperer le n° de l'OF extrait pour optimisation, on peut récuperer [F:OPS]MFGNUM
    GPOINT = "GETMFGNUM"
    Gosub ENTREE From EXEFNC
    #/Issue 117368
    [F:MFG]OPTFLG = 2
    [F:MFG]OPTUSR = GUSER
    Rewrite [MFG]
    Unlock [MFG]
  Else
    WMESS=""
  Endif
Endif

# Issue 79892 - 2012-02-06 by VPO : Si aucune opération, l'OF ne passe pas à l'étude
If WMESS<>""
  # traces
  If P_TRACE1 = 2
      Call ECR_TRACE(WMESS,0) From GESECRAN
  Endif
  NBOF += 1
Endif

Commit
Raz fstat
Return

########################################################################
# Rollback
$ROL_TRTEXT
Rollback
Call ROLL From GLOCK
If GROLL
     If P_TRACE1 = 2
         Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
     Endif
Else Goto EXTRAC :Endif
Return

########################################################################
# Abandon
$AB_TRTEXT
Rollback
If P_TRACE1 = 2
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
Return

$LOAD_OPE
Local Integer NBOPMX   : NBOPMX=100       : # dimension tables op
Local Integer NBLKMX   : NBLKMX=100       : # dimension tables liens
Local Integer  WOPENUM (NBOPMX)           : # numéro oper    # FQ 70035 avant Shortint
Local Shortint WOPESPLNUM (NBOPMX)        : # fract. oper
Local Integer WOPESTA (NBOPMX)            : # état opération
Local Integer WSCDCOD (NBOPMX)            : # code jalonnement
Local Integer WWSTTYP (NBOPMX)            : # code sous-traitance
Local Integer WNEXOPEN (NBOPMX)           : # no op suivante
Local Integer WNEXSPLN (NBOPMX)           : # fract. op suivante (créé dans PG)
Local Integer WOPERG (NBOPMX)             : # rang op
Local Integer WOPETRT (NBOPMX)            : # ope traitée en classement
Local Decimal WSCDPCT (NBOPMX)            : # % chev
Local Decimal WPRPTIM (NBOPMX)            : # temps préparation
Local Decimal WSETTIM (NBOPMX)            : # temps réglage
Local Decimal WOPETIM (NBOPMX)            : # temps opératoire
Local Decimal WPSPTIM (NBOPMX)            : # temps post oper
Local Decimal WSCOLTI (NBOPMX)            : # délai sous-traitance en jours
Local Decimal WQTY (NBOPMX)               : # quantité restante

Local Integer  WCONOPENUM (NBLKMX)        : # numéro oper conditionnante # FQ 70035 avant Shortint
Local Shortint WCONOPSNUM (NBLKMX)        : # fract. oper conditionnante
Local Integer  WLNKOPENUM (NBLKMX)        : # numéro oper conditionnée   # FQ 70035 avant Shortint
Local Shortint WLNKOPSNUM (NBLKMX)        : # fract. oper conditionnée
Local Integer  WLNKTYP (NBLKMX)           : # type de lien
Local Decimal  WLNKTIM (NBLKMX)           : # temps du lien
Local Decimal  WLNKSCDCOD (NBLKMX)        : # code jalonnement           # llc 10.02

Local Char    WWST(GLONWST)   : # poste                            # distinction

Local Integer WMFGSTA : WMFGSTA = [F:OPS]OPSSTA

If find([F:OPS]OPSSTA,1,2)
    Gosub LOAD_OFFP
Else
    Gosub LOAD_OFS
Endif
Gosub CLAST_OPE
Return

#########################################################################
# chargement OF ferme ou planifié
$LOAD_OFFP
I=0
IPREC=-1
NBOPR=0
#NBOPFC=0
#   chargement des opérations en mémoire
Link [MFO] With [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&          As   [SCOP]
&          Where [F:MFO]MFGNUM = [F:OPS]MFGNUM
&          Order By Key MFO0
For [SCOP]
      If ID='ORP'
        # on garde les ope soldées
          If find([F:MFO]OPESTA, 6)     : Goto LEC_OPE_SUIV : Endif
      Else
          If find([F:MFO]OPESTA, 5, 6)     : Goto LEC_OPE_SUIV : Endif
      Endif
      # Issue 103317 - 2014-21-10 by RBA
      #If [F:MFO]CPLQTY > [F:MFO]EXTQTY : Goto LEC_OPE_SUIV : Endif
      #/Issue 103317 - 2014-21-10 by RBA
      WOPENUM(I)    = [F:MFO]OPENUM
      WOPESPLNUM(I) = [F:MFO]OPESPLNUM
      WOPESTA(I)    = [F:MFO]OPESTA
      NBOPR +=1

      If [F:MFO]CPLWST = ""
            WWST     = [F:MFO]EXTWST
      Else
            WWST     = [F:MFO]CPLWST
      Endif
      Raz [F:MWS]
      Read [MWS]WST0=WWST;[F:OPS]MFGFCY
      If fstat : WTAB="MWS" : WCLE=WWST : Goto AB_OPT : Endif

      #message avertissement si utilisation non unitaire de poste multi-exemplaire
      If [F:MFO]EXTWSTNBR>1
        Call ECR_TRACE(mess(60,7710,1)-"("+[F:MFO]MFGNUM+"/"+num$([F:MFO]OPENUM)+")",-1) From GESECRAN
      Endif


      WSETTIM(I)    = [F:MFO]EXTSETTIM - [F:MFO]CPLSETTIM
      If WSETTIM(I) < 0 : WSETTIM(I) = 0 : Endif           # llc 01.03
      If [F:MFO]CPLQTY <> 0
          WPRPTIM(I)    = 0
          WSETTIM(I)    = 0                                # llc 11.01
          WRATIO        = ([F:MFO]EXTQTY - [F:MFO]CPLQTY) / [F:MFO]EXTQTY
          WOPETIM(I)    = [F:MFO]EXTOPETIM * WRATIO
      Else
          WPRPTIM(I)    = [F:MFO]PRPTIM
          WOPETIM(I)    = [F:MFO]EXTOPETIM - [F:MFO]CPLOPETIM
          If WOPETIM(I) < 0 : WOPETIM(I) = 0 : Endif       # llc 01.03
      Endif
    #      convertit en H si nécessaire
      If [F:MFO]TIMUOMCOD = 2
        WSETTIM(I) /= 60
        WOPETIM(I) /= 60
      Endif

      If [F:MFO]PSPTIM > [F:MFO]WAITIM
          WPSPTIM(I)    = [F:MFO]PSPTIM
      Else
          WPSPTIM(I)    = [F:MFO]WAITIM
      Endif
      WSCOLTI(I)       = [F:MFO]SCOLTI

      # FQ 65461 GA 07/2010 trace "Opération avec durée nulle: non exportée"
      If ID='ORO' : #VPO 07/10/10 68015
          ## VPO 14/10/10 68142
          ##If WSETTIM(I)+WOPETIM(I)=0 :
          If WPRPTIM(I)+WSETTIM(I)+WOPETIM(I)+WPSPTIM(I)+WSCOLTI(I)=0 :
             Call ECR_TRACE(mess(82,7710,1)-"("+[F:MFO]MFGNUM+"/"+num$([F:MFO]OPENUM)+")",-1) From GESECRAN
             NBOPR -=1 : #VPO 07/10/10 68015
             Goto LEC_OPE_SUIV
          Endif
      Endif

      WQTY(I)       = [F:MFO]EXTQTY - [F:MFO]CPLQTY

    #
      WWSTTYP(I)    = [F:MWS]WSTTYP
      WSCDCOD(I)    = [F:SCH]SCDCOD

      # llc 12.01 11908
      # si chevauchement en qté ou temps et opération déja suivie au delà du seuil
      # de chevauchement, on force une synchro début

      If find(WSCDCOD(I),2,3,4)       # si chevauchement
        # Issue 101001 GA 10/2014
        #If [F:MFO]OPESTA > 3        # si opération au moins en cours
        If !find([F:MFO]OPESTA,5,6)  # operation is neither excluded, nor completed
            Case WSCDCOD(I)
              When 2:    If [F:MFO]CPLQTY    >= [F:SCH]LOTQTY * [F:SCH]SCDLOT : WSCDCOD(I) = 5 : Endif
              When 3:    If [F:MFO]CPLOPETIM >= [F:SCH]SCDTIM                 : WSCDCOD(I) = 5 : Endif
                         # Issue 101001 GA 10/2014 if less remaining time, operation must follow
                         If [F:MFO]EXTOPETIM-[F:MFO]CPLOPETIM <= [F:SCH]SCDTIM: WSCDCOD(I) = 1 : Endif
              When 4:    If [F:MFO]CPLQTY    >= [F:SCH]SCDQTY :                 WSCDCOD(I) = 5 : Endif
                         # Issue 101001 GA 10/2014 if launched remaining qty is smaller, operation must follow
                         If [F:MFO]EXTQTY-[F:MFO]CPLQTY <= [F:SCH]SCDQTY      : WSCDCOD(I) = 1 : Endif
            Endcase
        Endif
      Endif

    #      traitement particulier des op splittées
    #        rétablit SCDCOD sur op précédente (pour homogénéité)
      If I>0 & IPREC >=0
        If WOPENUM(I) = WOPENUM(IPREC)
          If WSCDCOD(IPREC) <> 8 : WSCDCOD(IPREC) = 8 : Endif
        Else
          If WSCDCOD(IPREC) = 8 : WSCDCOD(IPREC) = 1 : Endif
        Endif
      Endif
    #

    #     si sous traitance : SCDCOD imposé à 1 si différent de 8
      If WWSTTYP(I) = 3 & WSCDCOD(I) <> 8 : WSCDCOD(I) = 1 : Endif

    #     calcul % chev
    # llc 04.02 11908 + 13975
      Case WSCDCOD(I)
        When 1 :
          WSCDPCT(I) = 1.00
        When 2 :
            # llc 08.02 15420 (US detected)
            If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
                WSCDPCT(I) = 0
            Else
                WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
                If WNUM < 0 : WNUM = 0 : Endif
                 WSCDPCT(I) = WNUM + ((([F:SCH]LOTQTY * [F:SCH]SCDLOT) - [F:MFO]CPLQTY) / WQTY(I))
            Endif
        When 3 :
            # llc 08.02 15420 (US detected)
            If ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM) = 0
                WSCDPCT(I) = 0
            Else
                WNUM = ([F:SCH]SCDTIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM)
                If WNUM < 0 : WNUM = 0 : Endif
                WSCDPCT(I) = WNUM / ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM - [F:MFO]CPLSETTIM - [F:MFO]CPLOPETIM)
            Endif
        When 4 :
            # llc 08.02 15420 (US detected)
            If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | WQTY(I) = 0)
                WSCDPCT(I) = 0
            Else
                If ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM) = 0
                    WNUM = 0
                Else
                    WNUM = WSETTIM(I) / ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM)
                Endif
                If WNUM < 0 : WNUM = 0 : Endif
                WSCDPCT(I) = WNUM + (([F:SCH]SCDQTY- [F:MFO]CPLQTY) / WQTY(I))
            Endif
        When 5 :
          WSCDPCT(I) = 0
      Endcase

    #
    # llc 12.00 - en sequence obligatoirement
      If I > 0
        If WOPENUM(I-1) <> WOPENUM(I)
            WNEXOPEN(I-1) = WOPENUM(I)
            WNEXSPLN(I-1) = WOPESPLNUM(I)
        Endif
      Endif

      IPREC=I

      WNEXOPEN(I)   = [F:SCH]NEXOPENUM
    #      traitement particulier des op splittées
    #        redéfinit NEXOPENUM (décomposé en NEXOPEN et NEXSPLN)
      WNEXSPLN(I)   = 0
      If I>0
        If WOPENUM(I) = WOPENUM(I-1)
          WNEXOPEN(I-1) = WOPENUM(I)
          WNEXSPLN(I-1) = WOPESPLNUM(I)
        Endif
      Endif
    #
      I +=1
$LEC_OPE_SUIV                    # llc 11.01
Next

# llc 02.00 - en sequence obligatoirement        8103
If I > 0
    If WNEXOPEN(I-1) <> 0
        WNEXOPEN(I-1) = 0
    Endif
    # llc 04.01 (8950) code jalonnement dernière opération = successeur
    # 09.04 25289 sauf si //toutes opérations
    If WSCDCOD(I-1) <> 7 : WSCDCOD(I-1) = 1 : Endif
Endif

#
NBOP = I
Return

#########################################################################
# chargement OF suggéré
$LOAD_OFS

WMFGSTRDAT    = [F:MFG]STRDAT
WMFGENDDAT    = [F:MFG]ENDDAT
If PITMFG<>""
Call  SETVAL ("MFGHEAD","WMFGSTRDAT",WKNBZON,WKTABZON,WKVAL,WKVALFIC,vireblc(format$("D:YYYYMMDD",WMFGSTRDAT),1)) From CONNECTFCT
Call  SETVAL ("MFGHEAD","WMFGENDDAT",WKNBZON,WKTABZON,WKVAL,WKVALFIC,vireblc(format$("D:YYYYMMDD",WMFGENDDAT),1)) From CONNECTFCT
Endif
#   chargement des opérations en mémoire
Link [OPS2] With [SCH]SCH0=[F:OPS2]MFGNUM;[F:OPS2]OPENUM;[F:OPS2]OPESPLNUM
&          As   [SCOP]
&          Where [F:OPS2]MFGNUM = [F:OPS]MFGNUM
&          Order By Key OPS1

I=0
For [SCOP]
  WOPENUM(I)    = [F:OPS2]OPENUM
  WOPESPLNUM(I) = [F:OPS2]OPESPLNUM
  WOPESTA(I)    = [F:OPS2]OPESTA
#     récupère dates début et fin OF sur op
  If I = 0
    WMFGSTRDAT     = [F:OPS2]OPESTR
    WMFGENDDAT     = [F:OPS2]OPEEND
  Else
    If WMFGSTRDAT     > [F:OPS2]OPESTR : WMFGSTRDAT     = [F:OPS2]OPESTR : Endif
    If WMFGSTRDAT     < [F:OPS2]OPEEND : WMFGENDDAT     = [F:OPS2]OPEEND : Endif
  Endif
  If PITMFG<>""
  Call  SETVAL ("MFGHEAD","WMFGSTRDAT",WKNBZON,WKTABZON,WKVAL,WKVALFIC,vireblc(format$("D:YYYYMMDD",WMFGSTRDAT),1)) From CONNECTFCT
  Call  SETVAL ("MFGHEAD","WMFGENDDAT",WKNBZON,WKTABZON,WKVAL,WKVALFIC,vireblc(format$("D:YYYYMMDD",WMFGENDDAT),1)) From CONNECTFCT
  Endif

#      code sous-traitance positionné en fonction de poste principal
  Raz [F:MWS]
  Read [MWS]WST0=[F:OPS2]EXTWST;[F:OPS]MFGFCY
  If fstat : WTAB="MWS" : WCLE=[F:OPS]EXTWST : Goto AB_OPT : Endif

  #message avertissement si utilisation non unitaire de poste multi-exemplaire
  If [F:OPS2]EXTWSTNBR>1
    Call ECR_TRACE(mess(60,7710,1)-"("+[F:OPS2]MFGNUM+"/"+num$([F:OPS2]OPENUM)+")",-1) From GESECRAN
  Endif

  WPRPTIM(I)    = [F:OPS2]PRPTIM
  WSETTIM(I)    = [F:OPS2]EXTSETTIM
  WOPETIM(I)    = [F:OPS2]EXTOPETIM
#      convertit en H si nécessaire
  If [F:OPS2]TIMUOMCOD = 2
    WSETTIM(I) /= 60
    WOPETIM(I) /= 60
  Endif

  If [F:OPS2]PSPTIM > [F:OPS2]WAITIM
      WPSPTIM(I)    = [F:OPS2]PSPTIM
  Else
      WPSPTIM(I)    = [F:OPS2]WAITIM
  Endif
  WSCOLTI(I)    = [F:OPS2]SCOLTI


  # FQ 65461 GA 07/2010 trace "Opération avec durée nulle: non exportée"
  If ID='ORO' : #VPO 07/10/10 68015
      ## VPO 14/10/10 68142
      ##If WSETTIM(I)+WOPETIM(I)=0 :
      If WPRPTIM(I)+WSETTIM(I)+WOPETIM(I)+WPSPTIM(I)+WSCOLTI(I)=0 :
         Call ECR_TRACE(mess(82,7710,1)-"("+[F:OPS2]MFGNUM+"/"+num$([F:OPS2]OPENUM)+")",-1) From GESECRAN
         Goto LEC_OFS_SUIV
      Endif
  Endif


  WQTY(I)       = [F:OPS2]EXTQTY

  WWSTTYP(I)    = [F:MWS]WSTTYP
  WSCDCOD(I)    = [F:SCH]SCDCOD
  WNEXOPEN(I)   = [F:SCH]NEXOPENUM
 # llc 12.00 - en sequence obligatoirement
  If I > 0
      If WOPENUM(I-1) <> WOPENUM(I)
           WNEXOPEN(I-1) = WOPENUM(I)
           WNEXSPLN(I-1) = WOPESPLNUM(I)
       Endif
  Endif

#     si sous traitance : SCDCOD imposé à 1 si différent de 8
  If WWSTTYP(I) = 3 & WSCDCOD(I) <> 8 : WSCDCOD(I) = 1 : Endif

#     calcul % chev
# llc 04.02 13975 + 15420
  Case WSCDCOD(I)
    When 1 :
      WSCDPCT(I) = 1.00
    When 2 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
            WSCDPCT(I) = 0
        Else
            WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM + (([F:SCH]LOTQTY * [F:SCH]SCDLOT) / WQTY(I))
        Endif
    When 3 :
        If WSETTIM(I) = 0 & WOPETIM(I) = 0
            WSCDPCT(I) = 0        Else
            WSCDPCT(I) = [F:SCH]SCDTIM / (WSETTIM(I)+WOPETIM(I))
        Endif
    When 4 :
        If ((WSETTIM(I) = 0 & WOPETIM(I) = 0) | (WQTY(I) = 0))
            WSCDPCT(I) = 0
        Else
            WNUM = WSETTIM(I) / (WSETTIM(I) + WOPETIM(I))
            If WNUM < 0 : WNUM = 0 : Endif
            WSCDPCT(I) = WNUM + ([F:SCH]SCDQTY / WQTY(I))
        Endif
    When 5 :
      WSCDPCT(I) = 0
  Endcase

  I +=1
$LEC_OFS_SUIV
Next
# llc 02.00 - en sequence obligatoirement            8103
If I > 0
    If WNEXOPEN(I-1) <> 0
        WNEXOPEN(I-1) = 0
    Endif
    WSCDCOD(I-1) = 1        # llc 04.01 (8950) code jalonnement dernière opération = successeur
Endif

NBOP   = I
NBOPR  = I
#NBOPFC = 0

Return



##########################################################################
# établit l'ordre de consultation des opérations
$CLAST_OPE
#
If NBOPR <= 0 : Goto END_OPT : Endif
#
#    controle préalable pour op suivante splittée sans op principale
#
For I = 0 To NBOP-1
#
#     saute les op terminées
#
# llc 12.00 il ne faut pas sauter les opérations soldées
# If (WOPESTA(I) > 4 & WOPESTA(I) < 7) : Goto CONT_OPE_SUIV : Endif
  If (WOPESTA(I) = 6) : Goto CONT_OPE_SUIV : Endif
#
  If WNEXOPEN(I) <> 0 & WNEXSPLN(I) = 0
    For J = 0 To NBOP-1
      If WOPENUM(J) = WNEXOPEN(I)
        WNEXSPLN(I) = WOPESPLNUM(J)
        Break 1
      Endif
    Next J
  Endif
$CONT_OPE_SUIV
Next I
#
NBOPNT = NBOP - 1
If NBOPNT <= 0
  WOPERG(NBOPNT) = 0
  Goto CRE_LIENS
Endif
DOPNT = NBOPNT
WSUIV = 0
WSPLSUIV = 0
Raz WOPETRT(0..NBOPNT)
#
$CLAST_INIT
I = 0
#
$CLAST_SUITE
I += 1
If I > DOPNT + 1 : I = 1 : Endif
J = DOPNT + 1 - I
If (WNEXOPEN(J) <> WSUIV | (WNEXOPEN(J) = WSUIV & WNEXSPLN(J) <> WSPLSUIV))
  Goto CLAST_SUITE
Endif
WOPERG(NBOPNT) = J
WSUIV = WOPENUM(J)
WSPLSUIV = WOPESPLNUM(J)
WOPETRT(J) = 1
NBOPNT -= 1
If NBOPNT < 0 : Goto CRE_LIENS : Endif
If J <> DOPNT : Goto CLAST_SUITE : Endif
While WOPETRT(DOPNT) = 1
  DOPNT -= 1
Wend
#
Goto CLAST_INIT

#########################################################################
# Elaboration des liens de succession
$CRE_LIENS
#
NBLK = 0
For I = 0 To NBOP-1
  J = WOPERG(I)
  If ID='ORP'
      #on garde les ope soldées
      If WOPESTA(J)=6
        Goto LNK_OPE_SUIV
      Endif
  Else
      If WOPESTA(J) > 4 & WOPESTA(J) < 7
        Goto LNK_OPE_SUIV
      Endif
  Endif
  WLNKSCDCOD(NBLK) = WSCDCOD(J)                                # llc 10.02
  Case WSCDCOD(J)
    When 1
      IS = I
$LNK1_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7 : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315 + 09.04 25289
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK1_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 2
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
      If WSCDCOD(JS) = 6
        Goto LNK1_SUIV
      Endif
    When 2,3,4
      IS = I
$LNK2_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315  + 09.04 25289
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK2_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
#        WLNKTIM(NBLK) = WOPTTIM(J) * WSCDPCT(J)
        WLNKTIM(NBLK) = WSCDPCT(J) * 100
        WLNKTIM(NBLK) = ar2(WLNKTIM(NBLK))
        NBLK += 1
      Endif
      If WSCDCOD(JS) = 6
        Goto LNK2_SUIV
      Else
$LNK3_SUIV
        If WSCDCOD(JS) <> 1
          IS += 1
          If IS >= NBOP : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315
          If IS < NBOP
            JS = WOPERG(IS)
            Goto LNK3_SUIV
          Endif
        Else
          IS += 1
          If IS >= NBOP : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315
          If IS < NBOP
            JS = WOPERG(IS)
            WCONOPENUM(NBLK) = WOPENUM(J)
            WCONOPSNUM(NBLK) = WOPESPLNUM(J)
            WLNKOPENUM(NBLK) = WOPENUM(JS)
            WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
            WLNKTYP(NBLK) = 2
            WLNKTIM(NBLK) = 0
            NBLK += 1
          Endif
        Endif
      Endif
    When 5
      IS = I
$LNK4_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315 + 09.04 25289
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK4_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
$LNK5_SUIV
      If WSCDCOD(JS) <> 1
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315
        If IS < NBOP
          JS = WOPERG(IS)
          Goto LNK5_SUIV
        Endif
      Else
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315
        If IS < NBOP
          JS = WOPERG(IS)
          WCONOPENUM(NBLK) = WOPENUM(J)
          WCONOPSNUM(NBLK) = WOPESPLNUM(J)
          WLNKOPENUM(NBLK) = WOPENUM(JS)
          WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
          WLNKTYP(NBLK) = 2
          WLNKTIM(NBLK) = 0
          NBLK += 1
        Endif
      Endif
    When 6
      IS = I
$LNK6_SUIV
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315 + 09.04 25289
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK6_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 3
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
    When 7
      If I = 0
        IS = I
        IS += 1
        If IS >= NBOP : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315
        If IS < NBOP
          JS = WOPERG(IS)
          WCONOPENUM(NBLK) = WOPENUM(J)
          WCONOPSNUM(NBLK) = WOPESPLNUM(J)
          WLNKOPENUM(NBLK) = WOPENUM(JS)
          WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
          WLNKTYP(NBLK) = 1
          WLNKTIM(NBLK) = 0
          NBLK += 1
        Endif
      Else
        JP = WOPERG(0)
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JP)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JP)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
    When 8
#      If I > 0                                llc 02.01 8103
#        IP = I
#        IP -= 1
#        JP = WOPERG(IP)
#        WCONOPENUM(NBLK) = WOPENUM(JP)
#        WCONOPSNUM(NBLK) = WOPESPLNUM(JP)
#        WLNKOPENUM(NBLK) = WOPENUM(J)
#        WLNKOPSNUM(NBLK) = WOPESPLNUM(J)
#        WLNKTYP(NBLK) = 1
#        WLNKTIM(NBLK) = 0
#        NBLK += 1
#      Endif
      IS = I
      IS += 1
      If IS >= NBOP & WSCDCOD(JS) <> 7  : Goto LNK_OPE_SUIV : Endif             # llc - 07.02 15315 + 09.04 25289
      If IS < NBOP
        JS = WOPERG(IS)
        If WSCDCOD(JS) = 7
          Goto LNK1_SUIV
        Endif
        WCONOPENUM(NBLK) = WOPENUM(J)
        WCONOPSNUM(NBLK) = WOPESPLNUM(J)
        WLNKOPENUM(NBLK) = WOPENUM(JS)
        WLNKOPSNUM(NBLK) = WOPESPLNUM(JS)
        WLNKTYP(NBLK) = 1
        WLNKTIM(NBLK) = 0
        NBLK += 1
      Endif
  Endcase
#
$LNK_OPE_SUIV
#
Next I

$ECR_FILE
WMFGNUM=[F:OPS]MFGNUM
WMFGFCY=[F:OPS]MFGFCY
WOPSSTA=[F:OPS]OPSSTA

################################
# fichiers MFG
################################
If PITMFG<>""
#   Fichier en-tête OF
#     Ouverture du fichier OPTMFG en écriture
If WPREMFG = 0
  Openo OPTMFG,0 Using [FPIV]
  WPREMFG = 1
Else
  Openo OPTMFG Using [FPIV]
Endif

Call EVALPIVOT(PITMFG,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
#     fermeture du fichier en-tête OF
Openo Using [FPIV]
Endif

################################
# fichiers ITM
################################
If PITITM <>""
ECRITM=1
#   Fichier des articles
#     Ouverture du fichier OPTITM en écriture
If WPREITM = 0
  Openo OPTITMTMP,0 Using [FPIV]
  Wrseq func MFG_GETITMREF([M]RELITM) Using [FPIV]
  Openo Using [FPIV]
  Openo OPTITM,0 Using [FPIV]
  WPREITM = 1
Else
  Openi OPTITMTMP Using [FPIV]
  Rdseq WFICITMREF Using [FPIV]
  While fstat=0
        If WFICITMREF=func MFG_GETITMREF([M]RELITM)
            ECRITM=0
            Break
        Endif
        Rdseq WFICITMREF Using [FPIV]
  Wend
  Openi Using [FPIV]
  If ECRITM
      Openo OPTITMTMP Using [FPIV]
      Wrseq func MFG_GETITMREF([M]RELITM) Using [FPIV]
      Openo Using [FPIV]
      Openo OPTITM Using [FPIV]
  Endif
Endif

If ECRITM
    Call RAZVALPIVOT(PITITM,IWKNBZON,IWKVAL,IWKVALFIC) From CONNECTFCT

    Call EVALPIVOT(PITITM,IWKNBZON,IWKTABZON,IWKTABABR,IWKZON,IWKFRM,IWKWRK,IWKVAL,IWKVALFIC) From CONNECTFCT
    Call WRPIVOT(IWKNBZON,IWKTABZON,IWKTABABR,IWKZON,IWKFRM,IWKWRK,IWKVAL,IWKVALFIC) From CONNECTFCT
    #     fermeture du fichier articles
    Openo Using [FPIV]
Endif

Endif : #fsi PITITM <>""

################################
# fichiers BPC
################################
If PITBPC <>"" & [F:BPC]BPCNUM<>""
ECRBPC=1
#   Fichier des clients
#     Ouverture du fichier OPTBPC en écriture
If WPREBPC = 0
  Openo OPTBPCTMP,0 Using [FPIV]
  Wrseq [F:BPC]BPCNUM Using [FPIV]
  Openo Using [FPIV]
  Openo OPTBPC,0 Using [FPIV]
  WPREBPC = 1
Else
  Openi OPTBPCTMP Using [FPIV]
  Rdseq WFICBPCREF Using [FPIV]
  While fstat=0
        If WFICBPCREF=[F:BPC]BPCNUM
            ECRBPC=0
            Break
        Endif
        Rdseq WFICBPCREF Using [FPIV]
  Wend
  Openi Using [FPIV]
  If ECRBPC
      Openo OPTBPCTMP Using [FPIV]
      Wrseq [F:BPC]BPCNUM Using [FPIV]
      Openo Using [FPIV]
      Openo OPTBPC Using [FPIV]
  Endif
Endif

If ECRBPC
    Raz [BPA]
    If pat(GVERSION,"1.5.*")
      Read [BPA]BPA0=1;[F:BPC]BPCNUM;[F:BPC]BPAINV
    Else
      Read [BPA]BPA0=1;[F:BPC]BPCNUM;[F:BPC]BPAADD
    Endif
    Raz [CNT]
    If pat(GVERSION,"1.5.*")
       Read [CNT]CNT0=1;[F:BPC]BPCNUM
    Else
       Read [CNT]CNT0=1;[F:BPC]BPCNUM;[F:BPC]CNTNAM
    Endif
    Call RAZVALPIVOT(PITBPC,CWKNBZON,CWKVAL,CWKVALFIC) From CONNECTFCT

    Call EVALPIVOT(PITBPC,CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CWKNBZON,CWKTABZON,CWKTABABR,CWKZON,CWKFRM,CWKWRK,CWKVAL,CWKVALFIC) From CONNECTFCT
    #     fermeture du fichier clients
    Openo Using [FPIV]
Endif

Endif : #fsi PITBPC <>""

################################
# fichiers PJT
################################
If PITPJT <>"" & func PITMFG.MFG_GETPJT([M]PJTCOD) <>""
ECRPJT=1
#   Fichier des clients
#     Ouverture du fichier OPTPJT en écriture
If WPREPJT = 0
  Openo OPTPJTTMP,0 Using [FPIV]
  Wrseq func PITMFG.MFG_GETPJT([M]PJTCOD) Using [FPIV]
  Openo Using [FPIV]
  Openo OPTPJT,0 Using [FPIV]
  WPREPJT = 1
Else
  Openi OPTPJTTMP Using [FPIV]
  Rdseq WFICPJTREF Using [FPIV]
  While fstat=0
        If WFICPJTREF=func PITMFG.MFG_GETPJT([M]PJTCOD)
            ECRPJT=0
            Break
        Endif
        Rdseq WFICPJTREF Using [FPIV]
  Wend
  Openi Using [FPIV]
  If ECRPJT
      Openo OPTPJTTMP Using [FPIV]
      Wrseq func PITMFG.MFG_GETPJT([M]PJTCOD) Using [FPIV]
      Openo Using [FPIV]
      Openo OPTPJT Using [FPIV]
  Endif
Endif

If ECRPJT
    Raz [OPP]
    WFICPJTREF=func PITMFG.MFG_GETPJT([M]PJTCOD)
    Read [OPP]OPP0=WFICPJTREF
    Call RAZVALPIVOT(PITPJT,PWKNBZON,PWKVAL,PWKVALFIC) From CONNECTFCT

    Call EVALPIVOT(PITPJT,PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKFRM,PWKWRK,PWKVAL,PWKVALFIC) From CONNECTFCT
    Call WRPIVOT(PWKNBZON,PWKTABZON,PWKTABABR,PWKZON,PWKFRM,PWKWRK,PWKVAL,PWKVALFIC) From CONNECTFCT
    #     fermeture du fichier affaires
    Openo Using [FPIV]
Endif

Endif : #fsi PITPJT <>""

################################
# fichiers OPE
################################
If PITOPE<>""

#   Fichier des opérations
#     Ouverture du fichier OPTOPE en écriture
If WPREOPE = 0
  Openo OPTOPE,0 Using [FPIV]
  WPREOPE = 1
Else
  Openo OPTOPE Using [FPIV]
Endif

#     écriture des enregistrements opération
For I = 0 To NBOP-1
    J = WOPERG(I)
    If ID='ORP'
        #on garde les ope soldées
        If WOPESTA(J)=6
            Goto ECR_OPE_SUIV
        Endif
    Else
        If WOPESTA(J) > 4 & WOPESTA(J) < 7
            Goto ECR_OPE_SUIV
        Endif
    Endif
    Gosub READ_OPE
    Raz [F:SCH]
    Read [SCH]SCH0=WMFGNUM;WOPENUM(J);WOPESPLNUM(J)
    Raz [F:MWS]
    Read [MWS]WST0=WWST;WMFGFCY

    Call RAZVALPIVOT(PITOPE,OWKNBZON,OWKVAL,OWKVALFIC) From CONNECTFCT
    #on fixe 2=successeur et %=0
    Call  SETVAL ("OPERATIONS","WLNKTYP",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,"2") From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKTIM",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,"0") From CONNECTFCT
    ##For ILK = 0 To NBLK-1
    ##    If WLNKOPENUM(ILK)=WOPENUM(J) & WLNKOPSNUM(ILK)=WOPESPLNUM(J)
    ##        Call  SETVAL ("OPERATIONS","WLNKTYP",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,num$(WLNKTYP(ILK))) From CONNECTFCT
    ##        Call  SETVAL ("OPERATIONS","WLNKTIM",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,num$(WLNKTIM(ILK))) From CONNECTFCT
    ##        ##Break
    ##    Endif
    ##Next ILK
    For ILK = 0 To NBLK-1
        If WCONOPENUM(ILK)=WOPENUM(J) & WCONOPSNUM (ILK)=WOPESPLNUM(J)
            If WLNKSCDCOD(ILK)= 7 : #Parallèle ttes opé de l'ordre
                Call  SETVAL ("OPERATIONS","WLNKTYP",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,"4") From CONNECTFCT
                Call  SETVAL ("OPERATIONS","WLNKTIM",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,"0") From CONNECTFCT
            Else
                Call  SETVAL ("OPERATIONS","WLNKTYP",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,num$(WLNKTYP(ILK))) From CONNECTFCT
                Call  SETVAL ("OPERATIONS","WLNKTIM",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,num$(WLNKTIM(ILK))) From CONNECTFCT
            Endif
            Break
        Endif
    Next ILK

#    # Issue 82953 - 2012-15-06 by RBA
#    If ID='ORP' and  [F:MFO]OPESTA = 5
#       [F:MFO]CPLQTY = [F:MFO]EXTQTY
#    Endif
    # Issue 103317 - 2014-21-10 by RBA
    If ID='ORP' and  [F:MFO]OPESTA = 5 and [F:MFO]CPLQTY < [F:MFO]EXTQTY
       [F:MFO]CPLQTY = [F:MFO]EXTQTY
    Endif
    #/Issue 103317 - 2014-21-10 by RBA

    Call SETVAL("OPERATIONS","WFICTRTDAT",OWKNBZON,OWKTABZON,OWKVAL,OWKVALFIC,vireblc(format$("D:YYYYMMDDhhmm",WFICTRTDAT),1)) From CONNECTFCT
    Call EVALPIVOT(PITOPE,OWKNBZON,OWKTABZON,OWKTABABR,OWKZON,OWKFRM,OWKWRK,OWKVAL,OWKVALFIC) From CONNECTFCT
    Call WRPIVOT(OWKNBZON,OWKTABZON,OWKTABABR,OWKZON,OWKFRM,OWKWRK,OWKVAL,OWKVALFIC) From CONNECTFCT


###  Wrseq [M:OPTK]MFGNUM;WOPENUM(J);WOPESPLNUM(J);WWST(J);WLAB(J);WSCO(J);WSCHGRP(J);WOPELABC(J);WRMNQTY(J);
###&           WPRPTIMA;WSETTIMA;WSETTIMSTDA;WEXTTIMA;WPSPTIMA;WSCOLTI(J);WWSTN(J);WLABN(J);WOPESTR(J);WFRCSTRD(J);
###&           WFRCSTRA;WOPESTRD(J);WOPESTRA;WINFSTRD(J);WINFSTRA;WINFENDD(J);
###&           WINFENDA;WOPEENDD(J);WOPEENDA;WEXTDAT;WFLGMAJ

    If PITRSS<>""
        If [F:MFO]EXTLAB<>""
            ECRRSS1=1
            Openi OPTRSS1 Using [RSS1]
            Rdseq WFICEXTLAB Using [RSS1]
            While fstat=0
                If WFICEXTLAB=[F:MFO]EXTLAB
                    ECRRSS1=0
                    Break
                Endif
                Rdseq WFICEXTLAB Using [RSS1]
            Wend
            Openi Using [RSS1]
            If ECRRSS1
              Openo OPTRSS1 Using [RSS1]
              Wrseq [F:MFO]EXTLAB Using [RSS1]
              Openo Using [RSS1]
            Endif
        Endif

        If [F:MFO]EQUNUM<>""
            ECRRSS2=1
            Openi OPTRSS2 Using [RSS2]
            Rdseq WFICEQUNUM Using [RSS2]
            While fstat=0
                If WFICEQUNUM =[F:MFO]EQUNUM
                    ECRRSS2=0
                    Break
                Endif
                Rdseq WFICEQUNUM Using [RSS2]
            Wend
            Openi Using [RSS2]
            If ECRRSS2
              Openo OPTRSS2 Using [RSS2]
              Wrseq [F:MFO]EQUNUM Using [RSS2]
              Openo Using [RSS2]
            Endif
        Endif
    Endif
$ECR_OPE_SUIV
Next I

#     fermeture du fichier opérations
Openo Using [FPIV]
Endif

################################
# fichiers ORD
################################
If PITORD <>""
  If [F:MFI]VCRNUMORI<>""
    ECRORD=1
    #   Fichier des commandes
    #     Ouverture du fichier OPTORD en écriture
    If WPREORD = 0
      Openo OPTORDTMP,0 Using [FPIV]
      Wrseq [F:MFI]VCRNUMORI Using [FPIV]
      Openo Using [FPIV]
      Openo OPTORD,0 Using [FPIV]
      WPREORD = 1
    Else
      Openi OPTORDTMP Using [FPIV]
      Rdseq WFICORDREF Using [FPIV]
      While fstat=0
            If WFICORDREF=[F:MFI]VCRNUMORI
                ECRORD=0
                Break
            Endif
            Rdseq WFICORDREF Using [FPIV]
      Wend
      Openi Using [FPIV]
      If ECRORD
          Openo OPTORDTMP Using [FPIV]
          Wrseq [F:MFI]VCRNUMORI Using [FPIV]
          Openo Using [FPIV]
          Openo OPTORD Using [FPIV]
      Endif
    Endif

    If ECRORD
        Raz [SOH]
        Read [SOH]SOH0=[F:MFI]VCRNUMORI
        If !fstat
        Call RAZVALPIVOT(PITORD,DWKNBZON,DWKVAL,DWKVALFIC) From CONNECTFCT

        Call EVALPIVOT(PITORD,DWKNBZON,DWKTABZON,DWKTABABR,DWKZON,DWKFRM,DWKWRK,DWKVAL,DWKVALFIC) From CONNECTFCT
        Call WRPIVOT(DWKNBZON,DWKTABZON,DWKTABABR,DWKZON,DWKFRM,DWKWRK,DWKVAL,DWKVALFIC) From CONNECTFCT
        Endif
        #     fermeture du fichier commandes
        Openo Using [FPIV]
    Endif

  Endif : # fsi [F:MFI]VCRNUMORI<>""
Endif : #fsi PITORD <>""

################################
# fichiers BOM
################################
If PITBOM <>""
    Raz [ORD]
    ##VPO 14/12/09 60879 exporter les nomenclatures aussi pour les planifiés et suggérés
    # Issue 120645 - 2017-01-27 by RBA : PE pour modifier le filtrer sur la variable WIPTYP dans la variable CRITERE qui par défaut = 6 sur la requete des orders basées sur la liste d'OF.
#    If find(WMFGSTA,1,2)
#    ##Filter [ORD] Where WIPSTA=1 & WIPTYP=6 & STOFCY=WMFGFCY & VCRTYP=10 & VCRNUM=WMFGNUM
#    Filter [ORD] Where WIPSTA=WMFGSTA & WIPTYP=6 & STOFCY=WMFGFCY & VCRTYP=10 & VCRNUM=WMFGNUM Order By VCRNUM;ITMREF;VCRSEQ
#    Else
#    Filter [ORD] Where WIPSTA=WMFGSTA & WIPTYP=6 & STOFCY=WMFGFCY & VCRTYP=11 & VCRNUM=WMFGNUM Order By VCRNUM;ITMREF;VCRSEQ
#    Endif
    Local Char CRITWIPTYP(250) : CRITERE = "WIPTYP=6"
    GPOINT = "CRITORDBOM"
    Gosub  ENTREE From EXEFNC  # ex : CRITERE = "find(WIPTYP,6,9)"
    If find(WMFGSTA,1,2)
      Filter [ORD] Where WIPSTA=WMFGSTA & evalue(CRITERE) & STOFCY=WMFGFCY & VCRTYP=10 & VCRNUM=WMFGNUM Order By VCRNUM;ITMREF;VCRSEQ
    Else
      Filter [ORD] Where WIPSTA=WMFGSTA & evalue(CRITERE) & STOFCY=WMFGFCY & VCRTYP=11 & VCRNUM=WMFGNUM Order By VCRNUM;ITMREF;VCRSEQ
    Endif
    # /Issue 120645 - 2017-01-27 by RBA
    ECRBOM=1
    WVCRNUM=""
    WART=""
    For [ORD]
        If GRUBOMFLG=2
            If WVCRNUM<>[F:ORD]VCRNUM | WART<>[F:ORD]ITMREF
                If WVCRNUM<>""
                    # on sauve la ligne courante
                    [F:ORD_]=[F:ORD]
                    # on bascule la ligne de cumul
                    [F:ORD]=[F:ORDX]
                    # on ecrit la ligne
                    Gosub ECR_BOM_FILE
                    # on recup les lignes sauvegardees
                    [F:ORD]=[F:ORD_]
                Endif
                # on ecrase les lignes de cumul
                [F:ORDX]=[F:ORD]
            Else
                #on est sur article idem donc on ajoute la qty
                [F:ORDX]RMNEXTQTY+=[F:ORD]RMNEXTQTY
            Endif
            WVCRNUM=[F:ORD]VCRNUM : WART=[F:ORD]ITMREF
        Else
            Gosub ECR_BOM_FILE
        Endif
    Next
    If GRUBOMFLG=2 & WVCRNUM<>""
        # on sauve la ligne courante
        ##[F:ORD_]=[F:ORD]
        # on bascule la ligne de cumul
        [F:ORD]=[F:ORDX]
        # on ecrit la ligne
        Gosub ECR_BOM_FILE
    Endif
    Filter [ORD]
Endif : #fsi PITBOM <>""


################################
# fichiers ACH
################################
If PITACH <>""
    Raz [ORD]
    Raz [MFM]
    # Issue 117242 - 2016-06-28 by RBA : PE pour ajouter un filtre dans la variable CRITERE sur la requête des orders basées sur la liste d'OF. Les tables ORDERS [ORD] et MAGMAT [MFM] sont ouvertes.
    Local Char CRITERE(250) : CRITERE = "1=1"
    GPOINT = "CRITORD"
    Gosub  ENTREE From EXEFNC  # ex : CRITERE = "left$([ORD]ITMREF,3)<> 'EMB'"
    Link [ORD] With [MFM]MFM0~=WMFGNUM As [WPOF] Where (WIPSTA=1 or WIPSTA=2) & WIPTYP=2 & STOFCY=WMFGFCY & [ORD]ITMREF=[MFM]ITMREF & evalue(CRITERE)
#    # Issue 89047 - 2013-05-03 by RBA
##    Link [ORD] With [MFM]MFM0~=WMFGNUM As [WPOF] Where WIPSTA=1 & WIPTYP=2 & STOFCY=WMFGFCY & [ORD]ITMREF=[MFM]ITMREF
#    Link [ORD] With [MFM]MFM0~=WMFGNUM As [WPOF] Where (WIPSTA=1 or WIPSTA=2) & WIPTYP=2 & STOFCY=WMFGFCY & [ORD]ITMREF=[MFM]ITMREF
#    #/Issue 89047 - 2013-05-03 by RBA
    #/ Issue 117242
    For [WPOF]
        ECRACH=1
        #   Fichier des commandes
        #     Ouverture du fichier OPTACH en écriture
        If WPREACH = 0
          Openo OPTACHTMP,0 Using [FPIV]
          # Issue 76822 - 2011-10-04 by VPO : pb si code avec +sieurs lignes sur meme article
          # il faut donc la ligne dans la clé
          #Wrseq [F:ORD]VCRNUM+';'+[F:ORD]ITMREF Using [FPIV]
          # Issue 89047 - 2013-05-15 by RBA
          # Wrseq [F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+[F:ORD]ITMREF Using [FPIV]
          Wrseq [F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+num$([F:ORD]VCRSEQ)+';'+[F:ORD]ITMREF Using [FPIV]
          #/ Issue 89047 - 2013-05-15 by RBA
          Openo Using [FPIV]
          Openo OPTACH,0 Using [FPIV]
          WPREACH = 1
        Else
          Openi OPTACHTMP Using [FPIV]
          Rdseq WFICACHREF Using [FPIV]
          While fstat=0
                # Issue 76822 - 2011-10-04 by VPO : pb si code avec +sieurs lignes sur meme article
                # il faut donc la ligne dans la clé
                #If WFICACHREF=[F:ORD]VCRNUM+';'+[F:ORD]ITMREF
                # Issue 89047 - 2013-05-15 by RBA
                # If WFICACHREF=[F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+[F:ORD]ITMREF
                If WFICACHREF=[F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+num$([F:ORD]VCRSEQ)+';'+[F:ORD]ITMREF
                #/ Issue 89047 - 2013-05-15 by RBA
                    ECRACH=0
                    Break
                Endif
                Rdseq WFICACHREF Using [FPIV]
          Wend
          Openi Using [FPIV]
          If ECRACH
              Openo OPTACHTMP Using [FPIV]
              # Issue 76822 - 2011-10-04 by VPO : pb si code avec +sieurs lignes sur meme article
              # il faut donc la ligne dans la clé
              #Wrseq [F:ORD]VCRNUM+';'+[F:ORD]ITMREF Using [FPIV]
              # Issue 89047 - 2013-05-15 by RBA
              # Wrseq [F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+[F:ORD]ITMREF Using [FPIV]
              Wrseq [F:ORD]VCRNUM+';'+num$([F:ORD]VCRLIN)+';'+num$([F:ORD]VCRSEQ)+';'+[F:ORD]ITMREF Using [FPIV]
              #/ Issue 89047 - 2013-05-15 by RBA
              Openo Using [FPIV]
              Openo OPTACH Using [FPIV]
          Endif
        Endif
        If ECRACH
            Call RAZVALPIVOT(PITACH,AWKNBZON,AWKVAL,AWKVALFIC) From CONNECTFCT
            Call EVALPIVOT(PITACH,AWKNBZON,AWKTABZON,AWKTABABR,AWKZON,AWKFRM,AWKWRK,AWKVAL,AWKVALFIC) From CONNECTFCT
            Call WRPIVOT(AWKNBZON,AWKTABZON,AWKTABABR,AWKZON,AWKFRM,AWKWRK,AWKVAL,AWKVALFIC) From CONNECTFCT
            #     fermeture du fichier nomenclatures
            Openo Using [FPIV]
        Endif
    Next
    Filter [ORD]
Endif : #fsi PITACH <>""

################################
# fichiers STO
################################
If PITSTO <>""
    Raz [ITV]
    Raz [MFM]
    Link [ITV] With [MFM]MFM0~=WMFGNUM As [WSTO] Where [ITV]STOFCY=WMFGFCY & [ITV]ITMREF=[MFM]ITMREF
    For [WSTO]
        ECRSTO=1
        #   Fichier des commandes
        #     Ouverture du fichier OPTSTO en écriture
        If WPRESTO = 0
          Openo OPTSTOTMP,0 Using [FPIV]
          Wrseq [ITV]ITMREF Using [FPIV]
          Openo Using [FPIV]
          Openo OPTSTO,0 Using [FPIV]
          WPRESTO = 1
        Else
          Openi OPTSTOTMP Using [FPIV]
          Rdseq WFICSTOREF Using [FPIV]
          While fstat=0
                If WFICSTOREF=[ITV]ITMREF
                    ECRSTO=0
                    Break
                Endif
                Rdseq WFICSTOREF Using [FPIV]
          Wend
          Openi Using [FPIV]
          If ECRSTO
              Openo OPTSTOTMP Using [FPIV]
              Wrseq [ITV]ITMREF Using [FPIV]
              Openo Using [FPIV]
              Openo OPTSTO Using [FPIV]
          Endif
        Endif
        If ECRSTO
            If find("ITF",TWKTABABR(1..TWKNBZON)) : # il y a une colonne sur ITF
                # lecture article/site
                If [F:ITF]ITMREF <> [ITV]ITMREF | [F:ITF]STOFCY <> WMFGFCY
                    Read [ITF]ITF0=[ITV]ITMREF;WMFGFCY
                    If fstat : Raz [F:ITF] : Endif
                Endif
            Endif
            Call RAZVALPIVOT(PITSTO,TWKNBZON,TWKVAL,TWKVALFIC) From CONNECTFCT
            Call EVALPIVOT(PITSTO,TWKNBZON,TWKTABZON,TWKTABABR,TWKZON,TWKFRM,TWKWRK,TWKVAL,TWKVALFIC) From CONNECTFCT
            Call WRPIVOT(TWKNBZON,TWKTABZON,TWKTABABR,TWKZON,TWKFRM,TWKWRK,TWKVAL,TWKVALFIC) From CONNECTFCT
            #     fermeture du fichier nomenclatures
            Openo Using [FPIV]
        Endif
    Next
Endif : #fsi PITSTO <>""



################################
# fichiers LNK
################################
If PITLNK<>""
#   Fichier des liens de succession
#     Ouverture du fichier OPTLNK en écriture
If WPRELNK = 0
  Openo OPTLNK,0 Using [FPIV]
  WPRELNK = 1
Else
  Openo OPTLNK Using [FPIV]
Endif

#     écriture des enregistrements liens de succession
For ILK = 0 To NBLK-1

    Raz [F:MFO]
    If find(WOPSSTA,1,2)
        Read [MFO]MFO0=WMFGNUM;WCONOPENUM(ILK);WCONOPSNUM(ILK)
    Endif
    Raz [F:OPS2]
    Read [OPS2]OPS1=WMFGNUM;WCONOPENUM(ILK);WCONOPSNUM(ILK)
    If fstat
        If find(WOPSSTA,1,2)
            [F:OPS]=[F:MFO]
        Endif
    Else
        [F:OPS]=[F:OPS2]
    Endif
    Raz [F:SCH]
    Read [SCH]SCH0=WMFGNUM;WCONOPENUM(ILK);WCONOPSNUM(ILK)

    Call RAZVALPIVOT(PITLNK,LWKNBZON,LWKVAL,LWKVALFIC) From CONNECTFCT

    Call  SETVAL ("OPERATIONS","WLNKMFGNUM",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,WMFGNUM) From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKOPENUM",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,num$(WLNKOPENUM(ILK))) From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKOPSNUM",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,num$(WLNKOPSNUM(ILK))) From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKTYP",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,num$(WLNKTYP(ILK))) From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKTIM",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,num$(WLNKTIM(ILK))) From CONNECTFCT
    Call  SETVAL ("OPERATIONS","WLNKSCDCOD",LWKNBZON,LWKTABZON,LWKVAL,LWKVALFIC,num$(WLNKSCDCOD(ILK))) From CONNECTFCT

    Call EVALPIVOT(PITLNK,LWKNBZON,LWKTABZON,LWKTABABR,LWKZON,LWKFRM,LWKWRK,LWKVAL,LWKVALFIC) From CONNECTFCT
    Call WRPIVOT(LWKNBZON,LWKTABZON,LWKTABABR,LWKZON,LWKFRM,LWKWRK,LWKVAL,LWKVALFIC) From CONNECTFCT

###    Wrseq [M:OPTK]MFGNUM;WCONOPENUM(ILK);WCONOPSNUM(ILK);[M:OPTK]MFGNUM;WLNKOPENUM(ILK);WLNKOPSNUM(ILK);
### &           WLNKTYP(ILK);WLNKTIM(ILK);WLNKSCDCOD(ILK);WEXTDAT;WFLGMAJ
Next ILK

#     fermeture du fichier liens de succession
Openo Using [FPIV]

Endif : #fsi PITLNK<>""

################################
# fichiers RSS
################################
If PITRSS<>"" & PITOPE=""

For I = 0 To NBOP-1
    J = WOPERG(I)
    If ID='ORP'
        #on garde les ope soldées
        If WOPESTA(J)=6
            Goto ECR_RSS_SUIV
        Endif
    Else
        If WOPESTA(J) > 4 & WOPESTA(J) < 7
            Goto ECR_RSS_SUIV
        Endif
    Endif
    Gosub READ_OPE

    If PITRSS<>""
        If [F:MFO]EXTLAB<>""
            ECRRSS1=1
            Openi OPTRSS1 Using [RSS1]
            Rdseq WFICEXTLAB Using [RSS1]
            While fstat=0
                If WFICEXTLAB=[F:MFO]EXTLAB
                    ECRRSS1=0
                    Break
                Endif
                Rdseq WFICEXTLAB Using [RSS1]
            Wend
            Openi Using [RSS1]
            If ECRRSS1
              Openo OPTRSS1 Using [RSS1]
              Wrseq [F:MFO]EXTLAB Using [RSS1]
              Openo Using [RSS1]
            Endif
        Endif

        If [F:MFO]EQUNUM<>""
            ECRRSS2=1
            Openi OPTRSS2 Using [RSS2]
            Rdseq WFICEQUNUM Using [RSS2]
            While fstat=0
                If WFICEQUNUM =[F:MFO]EQUNUM
                    ECRRSS2=0
                    Break
                Endif
                Rdseq WFICEQUNUM Using [RSS2]
            Wend
            Openi Using [RSS2]
            If ECRRSS2
              Openo OPTRSS2 Using [RSS2]
              Wrseq [F:MFO]EQUNUM Using [RSS2]
              Openo Using [RSS2]
            Endif
        Endif
    Endif
$ECR_RSS_SUIV
Next I

Endif

$END_OPT
Return

$ECR_RSS_FILE
If PITRSS<>""

#     Ouverture du fichier OPTRSS en écriture
If WPRERSS = 0
 Openo OPTRSS,0 Using [FPIV]
 WPRERSS = 1
Else
 Openo OPTRSS Using [FPIV]
Endif

Raz [MWS]
Raz [ITM]
Openi OPTRSS1 Using [RSS1]
Rdseq WFICEXTLAB Using [RSS1]
While fstat=0
    Read [MWS]WST0=WFICEXTLAB;WMFGFCY
    If !fstat
      Call RAZVALPIVOT(PITRSS,RWKNBZON,RWKVAL,RWKVALFIC) From CONNECTFCT
      Call EVALPIVOT(PITRSS,RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKFRM,RWKWRK,RWKVAL,RWKVALFIC) From CONNECTFCT
      Call WRPIVOT(RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKFRM,RWKWRK,RWKVAL,RWKVALFIC) From CONNECTFCT
    Endif
    Rdseq WFICEXTLAB Using [RSS1]
Wend
Openi Using [RSS1]

Raz [MWS]
Raz [ITM]
Openi OPTRSS2 Using [RSS2]
Rdseq WFICEQUNUM Using [RSS2]
While fstat=0
    Read [ITM]ITM0=WFICEQUNUM
    If !fstat
      Call RAZVALPIVOT(PITRSS,RWKNBZON,RWKVAL,RWKVALFIC) From CONNECTFCT
      Call EVALPIVOT(PITRSS,RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKFRM,RWKWRK,RWKVAL,RWKVALFIC) From CONNECTFCT
      Call WRPIVOT(RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKFRM,RWKWRK,RWKVAL,RWKVALFIC) From CONNECTFCT
    Endif
    Rdseq WFICEQUNUM Using [RSS2]
Wend
Openi Using [RSS2]

#     fermeture du fichier
Openo Using [FPIV]


Endif

$END_RSS_OPT
Return

$ECR_BOM_FILE
    #   Fichier des commandes
    #     Ouverture du fichier OPTBOM en écriture
    If WPREBOM = 0
      Openo OPTBOM,0 Using [FPIV]
      WPREBOM = 1
    Else
      Openo OPTBOM Using [FPIV]
    Endif
    If ECRBOM
        Call RAZVALPIVOT(PITBOM,BWKNBZON,BWKVAL,BWKVALFIC) From CONNECTFCT
        Call EVALPIVOT(PITBOM,BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKFRM,BWKWRK,BWKVAL,BWKVALFIC) From CONNECTFCT
        Call WRPIVOT(BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKFRM,BWKWRK,BWKVAL,BWKVALFIC) From CONNECTFCT
        #     fermeture du fichier nomenclatures
    Endif
    Openo Using [FPIV]
Return

#########################################################################
# fin anormale :
#   rollback
#   écriture d'un message
$AB_OPT
CODRET = 1
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

$READ_OPE
    Raz [F:MFO]
    If find(WOPSSTA,1,2)
        Read [MFO]MFO0=WMFGNUM;WOPENUM(J);WOPESPLNUM(J)
        If [F:MFO]CPLWST = ""
            WWST     = [F:MFO]EXTWST
        Else
            WWST     = [F:MFO]CPLWST
        Endif
    Else
      WWST       = [F:OPS]EXTWST
    Endif
    Raz [F:OPS2]
    Read [OPS2]OPS1=WMFGNUM;WOPENUM(J);WOPESPLNUM(J)
    If fstat
        If find(WOPSSTA,1,2)
            [F:OPS]=[F:MFO]
        Endif
    Else
        [F:OPS]=[F:OPS2]
    Endif
Return

#############################################################################
#############################################################################
Funprog MFG_GETITMREF(WRELITM)
Value Integer WRELITM
#
Local Char VALEUR (250) : Raz VALEUR
If find([F:OPS]OPSSTA,1,2)
    Case WRELITM
        When 1: VALEUR  = [F:MFG]ROUNUM
        When 2: VALEUR  = [F:MFI]ITMREF
    Endcase
Else
    VALEUR=[F:SCH]ROUNUM
    If WRELITM = 2 : VALEUR = [F:ORD]ITMREF : Endif
Endif
End VALEUR

#############################################################################
Funprog MFG_GETITMOUT(WRELITM)
Value Integer WRELITM
#
Local Char VALEURINI (250) : Raz VALEURINI
Local Char VALEUR (250) : Raz VALEUR

# lecture longueur type de donnée
Read [ATY]CODTYP="ITM"
If !fstat
    WITMLON = [F:ATY]LNGTYP
Else
    WITMLON = 20
Endif
VALEURINI = func PITMFG.MFG_GETITMREF(WRELITM)
VALEUR=VALEURINI
WSPACE = (WITMLON - 3) - len(VALEURINI)
If WSPACE > 0
    Case [F:ITF]ABCCLS
        When 1: VALEUR  = VALEURINI+space$(WSPACE) + '"A"'
        When 2: VALEUR  = VALEURINI+space$(WSPACE) + '"B"'
        When 3: VALEUR  = VALEURINI+space$(WSPACE) + '"C"'
        When 4: VALEUR  = VALEURINI+space$(WSPACE) + '"D"'
    Endcase
Endif

End VALEUR

#############################################################################
#Issue 121488 - 2017-02-20 by RBA
Funprog MFG_GETMFGDES
If find([F:OPS]OPSSTA,1,2)
  If [F:MFI]MFGDES = ""
    End [F:OPS]MFGNUM-"/"-[F:MFI]ITMREF
  Else
    End [F:MFI]MFGDES
  Endif
Else #[F:OPS]OPSSTA = 3
  If dim ([M]RELITM) > 0
    End [F:OPS]MFGNUM-"/"-func MFG_GETITMREF([M]RELITM)
  Else
    End [F:OPS]MFGNUM-"/"
  Endif
Endif
End ""
#/Issue 121488 - 2017-02-20 by RBA
#Funprog MFG_GETMFGDES
#If [F:MFI]MFGDES = ""
#    End [F:OPS]MFGNUM-"/"-[F:MFI]ITMREF
#Else
#    End [F:MFI]MFGDES
#Endif
#End ""

#############################################################################
Funprog MFG_GETPJT(WPJTCOD)
Value Integer WPJTCOD
#
Local Char VALEUR (250) : Raz VALEUR
If find([F:OPS]OPSSTA,1,2)
    If [F:MFI]BPCTYPDEN = 2 & [F:MFI]BPCNUM <> ""
        VALEUR  = [F:BPC]BPCNAM
    Endif
    Case WPJTCOD
        When 1:        If [F:MFI]VCRNUMORI <> ""   : VALEUR = [F:MFI]VCRNUMORI   : Endif
                       If [F:MFI]PJT <> ""         : VALEUR = [F:MFI]PJT         : Endif
        When 2:        If [F:MFI]PJT <> ""         : VALEUR = [F:MFI]PJT         : Endif
                       If [F:MFI]VCRNUMORI <> ""   : VALEUR = [F:MFI]VCRNUMORI   : Endif
    Endcase
Else
    # 09.05 31913
    If [F:ORD]PJT <> ""
      VALEUR  = [F:ORD]PJT
    Endif
    If [F:ORD]VCRTYPORI <> 11 & [F:ORD]VCRNUMORI <> ""
      VALEUR  = [F:ORD]VCRNUMORI
    Endif
Endif
End VALEUR

