#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type 3 Ordonnancement OF
#                             4 Ordonnancement Opérations
#                             5 Ordonnancement Successions
#                             6 Ordonnancement Articles
###################################################
# Subprog TRT_OF remplace TRT_OF de FUNMOPT
######################################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables MFGWPIV devient WK
#                                                   OPEWPIV devient OWK
#                                                   LNKWPIV devient LWK
#                                                   ITMWPIV devient IWK
#                                                   BPCWPIV devient CWK
#                                                   PJTWPIV devient PWK
#                                                   ORDWPIV devient DWK
#                                                   BOMWPIV devient BWK
#                                                   ACHWPIV devient AWK
#                                                   RSSWPIV devient RWK
#                                                   STOWPIV devient TWK
######################################################################
$OUVTAB_OF
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif

If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif         # 05.05 30049
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:OPS2]) = 0 : Local File OPERATIONS  [OPS2] : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFO2]) = 0 : Local File MFGOPE      [MFO2] : Endif        # distinction
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif

If clalev([F:TUV])  = 0 : Local File TABUNAVAIL  [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR      [CPV]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif

# Ouverture des fichiers utilisés
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif
If clalev([F:DIH])  = 0 : Local File DIAHOU      [DIH]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif

If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif

If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:ATY])  = 0 : Local File ATYPE       [ATY]  : Endif
If clalev([F:BPC])  = 0 : Local File BPCUSTOMER  [BPC]  : Endif
If clalev([F:BPA])  = 0 : Local File BPADDRESS   [BPA]  : Endif
If clalev([F:CNT])  = 0 : Local File CONTACT     [CNT]  : Endif
If clalev ([F:PJA]) = 0 : Local File PARJAL      [PJA]  : Endif         # 06.06 31012

If clalev([F:OPP])  = 0 : Local File OPPOR       [OPP]  : Endif
If clalev([F:SOH])  = 0 : Local File SORDER      [SOH]  : Endif

If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORD_]) = 0 : Local File ORDERS      [ORD_] : Endif
If clalev([F:ORDX]) = 0 : Local File ORDERS      [ORDX] : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif

Return

######################################################################
Subprog TRT_OF(ID,CLETRT,PITMFG,PITOPE,PITLNK,PITITM,
&              PITBPC,PITPJT,PITORD,
&              PITBOM,GRUBOMFLG,PITACH,PITSTO,
&              PITRSS,
&              P_CRITERE1,P_CRITERE2,P_FORMULE,P_TRACE1,P_TRTMOD,WSTRDAT,WENDDAT,NBOF,OK)
Value Char ID()
Value Char CLETRT ()
Value Char PITMFG ()
Value Char PITOPE ()
Value Char PITLNK ()
Value Char PITITM ()
Value Char PITBPC ()
Value Char PITPJT ()
Value Char PITORD ()
Value Char PITBOM ()
Value Integer GRUBOMFLG
Value Char PITACH ()
Value Char PITSTO ()
Value Char PITRSS ()
Value Char P_CRITERE1 ()
Value Char P_CRITERE2 ()
Value Char P_FORMULE ()
Value Integer P_TRACE1
Value Integer P_TRTMOD
Variable Date     WSTRDAT
Variable Date     WENDDAT
Variable Integer NBOF
Variable Integer OK

Local Char WITMREF(GLONITM)

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID='ORP' | ID='ORO'
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Local Char     CRITERE1(255) : CRITERE1 = P_CRITERE1
Local Char     CRITERE2(255) : CRITERE2 = P_CRITERE2
Local Char     CUSFLT(255) : Raz CUSFLT
Local Char     FORMULE1(255) : Raz FORMULE1

##date et heure de lancement
Local Date WFICTRTDAT : WFICTRTDAT = date$

# distinction des exemplaires
Local Integer NBSBB : NBSBB = 0
Local Char    XSBBT(15)(100)
Local Char    XSBB(15)
Local Char    XSBBWST(GLONWST), XSBBWSTB(GLONWST)
Local Char    XWST(GLONWST)
Local Integer XIND, XINDB
Local Integer XWSTNBR
Local Integer K,L,M

Gosub OUVTAB_OF
Gosub OUVREPIVOT From CONNECTFCT

##################################################
If PITMFG<>""
    Local Integer WNBMFG  : Raz WNBMFG
    Local Integer WPREMFG : Raz WPREMFG
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES
    Local Integer WKHEATYP       : Raz WKHEATYP
    Local Char    WKHEADMES (250): Raz WKHEADMES

    Local Char    OPTMFG(200)
    OPTMFG = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilmfg")
    Call READPIT(PITMFG,WKNBZON,WKNORECMES,WKHEATYP,WKHEADMES) From CONNECTFCT

    Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITMFG,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITMFG,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREMFG,OPTMFG) From CONNECTFCT
Endif

##################################################
If PITOPE<>""
    Local Integer WPREOPE : Raz WPREOPE
    Local Integer OWKNBZON : Raz OWKNBZON
    Local Char    OWKNORECMES (50): Raz OWKNORECMES
    Local Integer OWKHEATYP : Raz OWKHEATYP
    Local Char    OWKHEADMES (250): Raz OWKHEADMES

    Local Char    OPTOPE(200)
    OPTOPE = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilope")
    Call READPIT(PITOPE,OWKNBZON,OWKNORECMES,OWKHEATYP,OWKHEADMES) From CONNECTFCT

    Local Char    OWKTABZON(GLONATB+GLONAVA+2)(1..OWKNBZON) : Raz OWKTABZON
    Local Char    OWKTABABR(GLONABR)(1..OWKNBZON) : Raz OWKTABABR
    Local Char    OWKZON(GLONAVA)(1..OWKNBZON) : Raz OWKTABZON
    Local Char    OWKFRM(150)(1..OWKNBZON) : Raz OWKFRM
    Local Integer OWKWRK(1..OWKNBZON) : Raz OWKWRK
    Local Char    OWKVAL(255)(1..OWKNBZON) : Raz OWKVAL
    Local Char    OWKVALFIC(GLONAVA)(1..OWKNBZON) : Raz OWKVALFIC
    Call LOADPIVZON(PITOPE,OWKNBZON,OWKTABZON,OWKTABABR,OWKZON,OWKFRM,OWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITOPE,OWKNBZON,OWKTABZON,OWKTABABR,OWKZON,OWKWRK,OWKHEATYP,OWKHEADMES,WPREOPE,OPTOPE) From CONNECTFCT
Endif

##################################################
If PITLNK <>""
    Local Integer WPRELNK : Raz WPRELNK
    Local Char    OPTLNK(200)
    OPTLNK = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"illnk")
    Local Integer LWKNBZON        : Raz LWKNBZON
    Local Char    LWKNORECMES (50): Raz LWKNORECMES
    Local Integer LWKHEATYP       : Raz LWKHEATYP
    Local Char    LWKHEADMES (250): Raz LWKHEADMES

    Call READPIT(PITLNK,LWKNBZON,LWKNORECMES,LWKHEATYP,LWKHEADMES) From CONNECTFCT
    Local Char    LWKTABZON(GLONATB+GLONAVA+2)(1..LWKNBZON) : Raz LWKTABZON
    Local Char    LWKTABABR(GLONABR)(1..LWKNBZON) : Raz LWKTABABR
    Local Char    LWKZON(GLONAVA)(1..LWKNBZON) : Raz LWKTABZON
    Local Char    LWKFRM(150)(1..LWKNBZON) : Raz LWKFRM
    Local Integer LWKWRK(1..LWKNBZON) : Raz LWKWRK
    Local Char    LWKVAL(255)(1..LWKNBZON) : Raz LWKVAL
    Local Char    LWKVALFIC(GLONAVA)(1..LWKNBZON) : Raz LWKVALFIC
    Call LOADPIVZON(PITLNK,LWKNBZON,LWKTABZON,LWKTABABR,LWKZON,LWKFRM,LWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITLNK,LWKNBZON,LWKTABZON,LWKTABABR,LWKZON,LWKWRK,LWKHEATYP,LWKHEADMES,WPRELNK,OPTLNK) From CONNECTFCT
Endif

##################################################
