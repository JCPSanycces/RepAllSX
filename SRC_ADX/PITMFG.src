    End "3"
Endif
End ""

#############################################################################
Funprog RSS_GETNBR
If [F:MWS]WST<>""
    End [F:MWS]WSTNBR
Else
    End 0 # "0"
Endif
End 0 # ""

#############################################################################
# FQ 65034 Accès aux Sections de la tale MFI                                #
# P_DIE
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog MFI_GETCCE(P_DIE)
Value    Char    P_DIE ()

Local Char WCCE(GLONCCE)

#WCCE = func PITCCE.CAL_GETCCE("MFI",P_DIE,10,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"")
WCCE = func PITCCE.CAL_GETCCE("MFI",P_DIE,0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"")

End WCCE
#############################################################################

#############################################################################
# FQ 65034 Accès aux Sections de la tale MFM                                #
# P_DIE
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog MFM_GETCCE(P_DIE)
Value    Char    P_DIE ()

Local Char WCCE(GLONCCE)

#WCCE = func PITCCE.CAL_GETCCE("MFM",P_DIE,10,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,"")
WCCE = func PITCCE.CAL_GETCCE("MFM",P_DIE,0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,"")

End WCCE
#############################################################################

#############################################################################
# FQ 65034 Accès aux Sections de la tale MFO                                #
# P_DIE
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
# P_CPLCLE
# - contient "EXTWST" si on veut la Section poste principal (par défaut),
# - contient "EXTLAB" sinon
#############################################################################
Funprog MFO_GETCCE(P_DIE,P_CPLCLE)
Value    Char    P_DIE ()
Value    Char    P_CPLCLE()

Local Char WCCE(GLONCCE)
Local Char WCPLCLE(GLONVCR)
If P_CPLCLE<>"" WCPLCLE=P_CPLCLE Else WCPLCLE="EXTWST" Endif

#WCCE = func PITCCE.CAL_GETCCE("MFO",P_DIE,10,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,WCPLCLE)
WCCE = func PITCCE.CAL_GETCCE("MFO",P_DIE,0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,WCPLCLE)

End WCCE
