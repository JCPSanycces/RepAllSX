    Call LOADPIVZON(PITRSS,RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKFRM,RWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITRSS,RWKNBZON,RWKTABZON,RWKTABABR,RWKZON,RWKWRK,RWKHEATYP,RWKHEADMES,WPRERSS,OPTRSS) From CONNECTFCT
