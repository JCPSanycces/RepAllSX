#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

####################################
## TYPAMT 0 Total gûˋnûˋral
##        1 Total site
##        2 Dûˋtail site+compte
##        3 Dûˋtail site+compte+tiers
##        4 Total compte
##        5 Dûˋtail analytique
####################################

$GENER
Local Integer INTERU
PMAX = dim([F:BAL]DEB)-1

####################################
# Boucle principale sur les cellules
####################################

Filter [TXD] Where TXSNAM=[F:TXS]TXSNAM
For [TXD]TXD1(2)   : # tableau+col
 IC = [F:TXD]COL-1   : # IC varie de -1 û  n-1  (col. 0 = intitulûˋ)
 If IC>=0
  Gosub SET_COL
  If GERR : GOK=0 : Break : Endif
 Endif
 For [TXD]TXD1    : # tableau+col+lig
  IL = [F:TXD]LIG    : # IL varie de 1 û  n
  Call AFF_BOITE(mess(139,111,1)-[F:TXS]TXSNAM,IC*[F:TXS]NBLIG+IL,INTERU) From GESECRAN
  If IC<0    : # intitulûˋ utile dans l'ûˋtat
   Gosub ECR_INTIT
   If GOK<1 : Break 2 : Endif
  Else
   Gosub TRT_FRM
   If GOK<1 : Break 2 : Endif
  Endif
 Next
Next
Filter [TXD]
Return

$ECR_INTIT
If RECALCUL : Return : Endif
Raz [F:TXM]
[F:TXM]TXSNAM  = [M]TXSNAM
[F:TXM]VERSION = [M]VERSION
[F:TXM]LIG = IL
[F:TXM]COL = 0
Call LECTEXTRA([F:TXM]AMTVAL,"TXSD","DES",[M]TXSNAM,num$(IL)) From ATEXTRA
[F:TXM]ACCINF = [F:TXD]FRM
Read [TXP]TXP0 = [M]TXSNAM;[M]VERSION;1
Call REMPLACE([F:TXM]ACCINF,1) From TXSCAL
Write [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return

$SET_COL

#
# Sociûˋtûˋ
#

SOC = [M]CPY(IC)
I = 1
While SOC=""
 # Pour les colonnes de calcul de cumuls, la sociûˋtûˋ n'est pas saisie,
 # donc on remonte dans les paramû´tres jusqu'û  ce qu'on en trouve une
 # (û  priori, les comparaisons de colonnes portent sur la meme sociûˋtûˋ...)
 If IC-I < 0 : Break : Endif
 SOC = [M]CPY(IC-I)
 I += 1
Wend

#
# Sites
#
Raz TSITE , NBSITE , TSOC , NBSOC , GROUPE , SOCJUR
If [M]FCY(IC)<>""
 NBSITE     = 1
 TSITE(1)   = [M]FCY(IC)
 I = find(TSITE(1),GSITE(1..GNBSITE))
 TSOCSIT(1) = GSOCSITE(I)
 NBSOC      = 1
 TSOC(1)    = GSOCSITE(I)
Else
 If SOC<>""
  If SOC<>[F:CPY]CPY
   Read [CPY]CPY0 = SOC
  Endif
  If [F:CPY]CPYLEGFLG=2   : # juridique
   For [FCY]FCY1 Where LEGCPY=SOC & FINFLG=2
    NBSITE += 1
    TSITE(NBSITE)   = [F:FCY]FCY
    TSOCSIT(NBSITE) = SOC
   Next
   NBSOC   = 1
   TSOC(1) = SOC
  Else
   For [FGR]FGR0 Where CPY=SOC
    NBSITE += 1
    TSITE(NBSITE) = [F:FGR]FCY
    I = find([F:FGR]FCY,GSITE(1..GNBSITE))
    TSOCSIT(NBSITE) = GSOCSITE(I)
    If !find(GSOCSITE(I),TSOC(1..NBSOC))
    #NBSOC commence û  1 et non pas 0 !
    #si NBSOC = 1 , non pris en compte dans le find
    #If !find(GSOCSITE(I),TSOC(1..NBSOC-1))
     NBSOC += 1
     TSOC(NBSOC) = GSOCSITE(I)
    Endif
   Next
  Endif
 Else
  For I=1 To GNBSITE
   TSITE(I) = GSITE(I)
   TSOCSIT(I) = GSOCSITE(I)
  Next I
  NBSITE = GNBSITE
  For I=1 To GNBSOC
   TSOC(I) = GSOC(I)
  Next I
  NBSOC = GNBSOC
 Endif
Endif

#
# Devises de sûˋlection et de restitution
#

DEVSEL = [M]CURSEL(IC)
DEVPRN = [M]CURPRN(IC)
If DEVPRN=""
 DEVPRN = [M]CURPRN(IC-1)
 [M]CURPRN(IC) = DEVPRN
Endif

Call LECTURE("TCU",DEVPRN,"") From CONTOBJ
AROPRN   = [F:TCU]CURRND
TYPCOURS = [M]TYPRAT(IC)

Return

#
# Traitement d'une ligne de formule
#

$TRT_FRM
Raz INDTXM, SIT_DEB, SIT_CDT, SAI_DEB, MTTMOD, ER, EXPL
FORMULE = vireblc([F:TXD]FRM,2)
If FORMULE=""
 # une cellule peut ne pas avoir de formule, mais peut contenir une valeur saisie
 If VALSAI(IL,IC+1)<>""
   Raz INDTXM, MTDEB, MTCDT, SAI_DEB, SITE, COMPTE, TIERS, SITINF, CPTINF, TRSINF
   Look [TXM]TXM0 = [M]TXSNAM;[M]VERSION;IL;IC+1;0
   If fstat
    TYPMONT = 0
    Gosub ECR_TXM
   Endif
 Endif
 Return
Endif

If RECALCUL
 # dans le cas du recalcul, il faut vûˋrifier si la formule contient une expression
 # de type cumul (ex: "6 L1") afin de savoir si on doit la traiter
 Gosub EVAL_FORM
 If !TYPCUMUL : Return : Endif  :# la formule ne contient aucune syntaxe de type cumul ("L" ou "R")
Endif

# LE calcul...

Gosub DEFVAR From SUBTXSB
MAXCOL = IC
MAXLIG = IL-1
LIGNE  = FORMULE
CALCUL = 1
Gosub TRT_LIGNE From SUBTXSB
If ER
 If GMESSAGE=""
  Gosub FIN_FORLIG From SUBTXSB
 Endif
 Call ECR_TRACE(mess(210,111,1)-num$(IL)-mess(187,111,1)-num$(IC+1)-":"-GMESSAGE,0) From GESECRAN
#               Ligne                    colonne
 NBERR += 1
 Raz GMESSAGE
Endif

#
# Ecriture des montants sites et total cellule
# On ne garde que les soldes crûˋditeurs ou dûˋbiteurs
#

If !DETDEL
 If CREDIT=2
  Delete [TXM] Where TXSNAM=[F:TXS]TXSNAM & VERSION=[M]VERSION & LIG=IL & COL=IC+1
&              & val(AMTVAL)*SIGN>=0
 Elsif DEBIT=2
  Delete [TXM] Where TXSNAM=[F:TXS]TXSNAM & VERSION=[M]VERSION & LIG=IL & COL=IC+1
&              & val(AMTVAL)*SIGN<=0
 Endif
Endif
MTDEB = sum(SIT_DEB)
MTCDT = sum(SIT_CDT)
Raz COMPTE, TIERS
Raz CPTINF, TRSINF
For I=1 To NBSITE
 SITE = TSITE(I) : Gosub EVAL_INFSIT
 MTDEB = SIT_DEB(I)
 MTCDT = SIT_CDT(I)
 If (MTDEB<>0 or MTCDT<>0)
  INDTXM += 1
  TYPMONT = 1
  Gosub ECR_TXM
  If GOK<1 : Break : Endif
 Endif
Next I
If GOK<1 : Return : Endif

#
# Total gûˋnûˋral pour la cellule ([F:TXM]IND=0)
#

Raz SITE, COMPTE, TIERS, INDTXM, SITINF, CPTINF, TRSINF
MTDEB = sum(SIT_DEB)
MTCDT = sum(SIT_CDT)
TYPMONT = 0
Gosub ECR_TXM
Return

#############################################################################################
## Aiguillage selon la fonction
#############################################################################################
$CALCUL
COLL   = ""
DETAIL = 0
DETDEL = 0
Case FONC
 When "C"                              : Gosub TRT_CPT From CALTBDGEN
 When "A","B"                          : Gosub TRT_BIL From CALTBDGEN
 When "H","I"                          : Gosub TRT_COL From CALTBDGEN
 When "NM","EM","PM","NQ","EQ","PQ"    : Gosub TRT_ANA From CALTBDANA
 When "UM","UQ"                        : Gosub TRT_ANA From CALTBDANA
 When "GM","GQ"                        : Gosub TRT_BUD From CALTBDBUD
 When "L"                              : Gosub TRT_SOM
 When "R"                              : Gosub TRT_EXP
Endcase
Return

#############################################################################################
## Etiquettes appelûˋes par SUBTXSB  (Fonctions diverses)
#############################################################################################

#
# Somme de colonnes
#

$TRT_SOM
If func SUBTXSB.EXISTE(AUTTAB)
 Call REPLACE(AUTTAB,AUTTAB) From SUBTXSB
Endif
Read [TXS2]TXS1 = AUTTAB
If fstat
 ER = 28 : ERARG = AUTTAB
 Return
Endif
If func SUBTXSB.EXISTE(AUTVER)
 Call REPLACE(AUTVER,AUTVER) From SUBTXSB
Endif
If AUTVER="#"
 Filter [TXW2] Where TXSNAM=AUTTAB Order By TXSNAM;GENDAT Desc;GENTIM Desc
 Read [TXW2] First
 Filter [TXW2]
 If fstat<=2
  AUTVER = [F:TXW2]VERSION
 Endif
Endif
Read [TXW2]TXW1 = AUTTAB;AUTVER
If fstat
 ER = 29 : ERARG = AUTTAB-AUTVER
 Return
Endif
If NOCOL=0
 NOCOL = IC+1
Endif
DEVCOL = [M]CURPRN(NOCOL-1)   : # Devise de la colonne parcourue
Filter [TXM2]
For [TXM2]TXM0 Where TXSNAM=AUTTAB & VERSION=AUTVER & LIG>=LIGDEB & LIG<=LIGFIN & COL=NOCOL
&                  & (TYPAMT=0 or TYPAMT=1)
 If [F:TXM2]TYPAMT=1
  ISITE = find([F:TXM2]FCY,TSITE(1..NBSITE))
  If ISITE
   If DEVCOL<>DEVPRN & TYPCOURS<>0
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTDEB),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]AMTDEB = num$(MTDES) : Endif
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTCDT),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]AMTCDT = num$(MTDES) : Endif
   Endif
   SIT_DEB(ISITE) += val([F:TXM2]AMTDEB)*SIGN
   SIT_CDT(ISITE) += val([F:TXM2]AMTCDT)*SIGN
  Endif
 Else
  If DEVCOL<>DEVPRN & TYPCOURS<>0
   MTDES = 0
   Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]UPDVAL),MTDES,STAT) From TRTDEV
   If !STAT : [F:TXM2]UPDVAL = num$(MTDES) : Endif
   MTDES = 0
   Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTVAL),MTDES,STAT) From TRTDEV
   If !STAT : [F:TXM2]AMTVAL = num$(MTDES) : Endif
  Endif
  If [M]CALCUL=2 & [F:TXM2]UPDVAL<>""
   MTTMOD = 1
   SAI_DEB += val([F:TXM2]UPDVAL)*SIGN
  Else
   SAI_DEB += val([F:TXM2]AMTVAL)*SIGN
   EXPL = 1
  Endif
 Endif
Next
If (sum(SIT_DEB)-sum(SIT_CDT))<>SAI_DEB
 MTTMOD = 1
Endif
Return

#
# Expression
#

$TRT_EXP
If [F:TXA]TXSNAM<>[M]TXSNAM | [F:TXA]NUMCOL<>IC+1
 Read [TXA]TXA0=[M]TXSNAM;IC+1
 If fstat : Return : Endif
Endif
If [F:TXA]COLNUM="" : # Calcul libre
 Gosub TRT1
Else                : # Calcul entre colonnes
 Gosub TRT2
Endif
Return

$TRT1
# Adaptation de la formule aux variables
Gosub ADAPT_FRM
If GERR : GOK = 0 : Return : Endif

# Cas trivial
If !instr(1,ZONE,"L(")
 Onerrgo ERR
 SIT_DEB(1) += evalue(ZONE)*SIGN
 Onerrgo
 Return
Endif

# Dûˋtail par site

Raz L, LC, L2, K, LIG
Filter [TXM2] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & COL>=1 & COL<=IC+1
&                 & (TYPAMT=0 or TYPAMT=1)
&  Order By Key CLE=TXSNAM;VERSION;FCY;LIG;COL
For [TXM2]CLE(3)
 MTTMOD = 0
 ISITE = find([F:TXM2]FCY,TSITE(1..NBSITE))
 For [TXM2]CLE
  DEVCOL = [M]CURPRN([F:TXM2]COL-1)   :# devise de la colonne lue
  If [F:TXM2]TYPAMT=1
   If DEVCOL<>DEVPRN & TYPCOURS<>0
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTDEB),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]AMTDEB = num$(MTDES) : Endif
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTCDT),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]AMTCDT = num$(MTDES) : Endif
   Endif
   L([F:TXM2]LIG,[F:TXM2]COL)  = val([F:TXM2]AMTDEB)
   LC([F:TXM2]LIG,[F:TXM2]COL) = val([F:TXM2]AMTCDT)
  Else    :# TYPAMT=0
   If DEVCOL<>DEVPRN & TYPCOURS<>0
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]UPDVAL),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]UPDVAL = num$(MTDES) : Endif
    MTDES = 0
    Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTVAL),MTDES,STAT) From TRTDEV
    If !STAT : [F:TXM2]AMTVAL = num$(MTDES) : Endif
   Endif
   MTTMOD = 1
   L2([F:TXM2]LIG,[F:TXM2]COL) = val([F:TXM2]AMTVAL)
   If [M]CALCUL=2 & [F:TXM2]UPDVAL<>""
    L2([F:TXM2]LIG,[F:TXM2]COL) = val([F:TXM2]UPDVAL)
   Endif
  Endif
 Next
 Onerrgo ERR
 If ISITE
  SIT_DEB(ISITE) += arr(evalue(ZONE),AROPRN)*SIGN
  Call AFFECT_L([F:TXS]NBLIG,IC+1,LC,L)
  SIT_CDT(ISITE) += arr(evalue(ZONE),AROPRN)*SIGN
 Endif
 If MTTMOD=1
  K = 1
  Call AFFECT_L([F:TXS]NBLIG,IC+1,L2,L)
  SAI_DEB += evalue(ZONE)*SIGN
  EXPL = 1
 Endif
 Onerrgo
 If ER : Break : Endif
Next

Filter [TXM2]
If K | (sum(SIT_DEB)-sum(SIT_CDT))<>SAI_DEB
 MTTMOD = 1
Endif
Return

Subprog AFFECT_L(LMAX,CMAX,ORG,DES)
Value Integer LMAX, CMAX
Value Decimal ORG(1..,1..)
Variable Decimal DES(1..,1..)
Local Integer I, J
Raz DES
For I=1 To LMAX
 For J=1 To CMAX
  DES(I,J) = ORG(I,J)
 Next J
Next I
End

$ADAPT_FRM
# On remplace les noms de variable par leur valeur
For J=0 To NBRVAR-1
 K = instr(1,ZONE,NOMVAR(J))
 While K
  If left$(VALVAR(J),1)="$"
   Gosub SET_VALVAR
  Else
   VARTMP(J) = VALVAR(J)
  Endif
  ZONE = left$(ZONE,K-1)+VARTMP(J)+right$(ZONE,K+len(NOMVAR(J)))
  K = instr(1,ZONE,NOMVAR(J))
 Wend
Next J
# Retraitement de la formule pour coller aux noms de variable dans le trt
# L3    devient L(3,IC) ligne 3, colonne courante
# L3(1) devient L(3,1)  ligne 3, colonne 1
# L(1)  devient L(IL,1) ligne courante, colonne 1
#
Raz Z2, REFC
I = 1
While I<=len(ZONE)
 If mid$(ZONE,I,2)="L("
  J = instr(I+2,ZONE,")")
  Z2 += "L("+num$(IL)+","+seg$(ZONE,I+2,J-1)+")"
  I = J+1
 Elsif mid$(ZONE,I,1)="L" & instr(1,"0123456789",mid$(ZONE,I+1,1))
  J = I
  Repeat
   J += 1
  Until J>len(ZONE) | !instr(1,"0123456789",mid$(ZONE,J,1))
  If mid$(ZONE,J,1)="("
   K = instr(J+1,ZONE,")")
   Z2 += "L("+seg$(ZONE,I+1,J-1)+","+seg$(ZONE,J+1,K-1)+")"
   I = K+1
  Else
   Z2 += "L("+seg$(ZONE,I+1,J-1)+","+num$(IC+1)+")"
   I = J
  Endif
 Else
  Z2 += mid$(ZONE,I,1)
  I  += 1
 Endif
Wend
ZONE = Z2
Return

$SET_VALVAR
# $TAB1.V1("L3(1)") = mtt ligne 3, col 1, de la version V1 du tableau TAB1
ZT = right$(VALVAR(J),2)
I = instr(1,ZT,".")
If I
 TABLEAU = left$(ZT,I-1) : ZT = right$(ZT,I+1)
Else   :# tableau courant
 TABLEAU = [M]TXSNAM
Endif
I = instr(1,ZT,"(")
If I
 VRSN = left$(ZT,I-1) : ZT = right$(ZT,I+1)
 If VRSN<>""
  Z2 = seg$(ZT,1,len(ZT)-1)
  Gosub TRT_VALVAR
  VARTMP(J) = num$(MT_TMP)
 Else
  ER = 10   :# Erreur de syntaxe
 Endif
Else
 ER = 10
Endif
Return

$TRT_VALVAR
Raz I, COL, LIG, PO, PF, BI, BS
Repeat
  I += 1
  CAR1 = mid$(Z2,I,1)
  If CAR1>='0' & CAR1<='9'
   If PO
    COL = COL*10+val(CAR1)
   Else
    LIG = LIG*10+val(CAR1)
   Endif
  Elsif CAR1='('
   PO += 1 : BS = LIG : LIG = 0   :# borne supûˋrieure
  Elsif CAR1=':'
   BI = LIG : LIG = 0   :# borne infûˋrieure
  Elsif CAR1=')'
   PF += 1
  Elsif CAR1<>'L'
   ER = 10
  Endif
Until I>=len(Z2)
If (!PO & !PF)
 BS = LIG
Elsif PO<>PF
 ER=10 : Return
Endif
NOCOL = COL
If !NOCOL : NOCOL=IC+1 : Endif
If !BI : BI = BS : Endif

DEVCOL = [M]CURPRN(NOCOL-1)   :# devise de la colonne parcourue
MT_TMP = 0
For [TXM2]TXM0 Where TXSNAM=TABLEAU & VERSION=VRSN & LIG>=BI & LIG<=BS & COL=NOCOL & IND=0
&                  & ACC="" & BPR="" & CCE1=""
 If DEVCOL<>DEVPRN & TYPCOURS<>0
  MTDES = 0
  Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]UPDVAL),MTDES,STAT) From TRTDEV
  If !STAT : [F:TXM2]UPDVAL = num$(MTDES) : Endif
  MTDES = 0
  Call CONVERT(DEVCOL,DEVPRN,DEVPRN,TYPCOURS,datesyst,val([F:TXM2]AMTVAL),MTDES,STAT) From TRTDEV
  If !STAT : [F:TXM2]AMTVAL = num$(MTDES) : Endif
 Endif
 If [M]CALCUL=2 & [F:TXM2]UPDVAL<>""
  #MTTMOD=1
  MT_TMP += val([F:TXM2]UPDVAL)*SIGN
 Else
  MT_TMP += val([F:TXM2]AMTVAL)*SIGN
 Endif
Next
Return


$TRT2
# Calcul entre colonnes
# Adaptation de la formule : L(2) devient L(IL,2) oû¿ IL = no de ligne courante
K = instr(1,ZONE,"L(")
While K
 ZONE = left$(ZONE,K+1)+num$(IL)+","+right$(ZONE,K+2)
 K = instr(K+2,ZONE,"L(")
Wend
#

Raz L, LC, L2, K
Filter [TXM2] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & LIG=IL & COL>=1 & COL<=IC
&                 & (TYPAMT=0 or TYPAMT=1)
&  Order By Key CLE=TXSNAM;VERSION;LIG;FCY;COL
For [TXM2]CLE(4)
 MTTMOD = 0
 ISITE = find([F:TXM2]FCY,TSITE(1..NBSITE))
 Raz L, LC, L2
 For [TXM2]CLE
   If [F:TXM2]TYPAMT=1
     L(IL,[F:TXM2]COL) = val([F:TXM2]AMTDEB)
     LC(IL,[F:TXM2]COL) = val([F:TXM2]AMTCDT)
   Else    : # typamt=0 correspond au mtt tous sites de la cellule
     MTTMOD=1
     L2(IL,[F:TXM2]COL) = val([F:TXM2]AMTVAL)
     If [M]CALCUL=2 & [F:TXM2]UPDVAL<>""
       L2(IL,[F:TXM2]COL) = val([F:TXM2]UPDVAL)
     Endif
   Endif
 Next
 Onerrgo ERR
 If ISITE
  SIT_DEB(ISITE) += arr(evalue(ZONE),AROPRN)*SIGN
  Call AFFECT_L([F:TXS]NBLIG,IC,LC,L)
  SIT_CDT(ISITE) += arr(evalue(ZONE),AROPRN)*SIGN
 Endif
 If MTTMOD=1
  K=1
  Call AFFECT_L([F:TXS]NBLIG,IC,L2,L)
  SAI_DEB += evalue(ZONE)*SIGN
  EXPL = 1
 Endif
 Onerrgo
 If ER : Break : Endif
Next
Filter [TXM2]
If K | (sum(SIT_DEB)-sum(SIT_CDT))<>SAI_DEB
 MTTMOD=1
Endif
Return

$ERR
ER = 1
ERARG = ZONE-"("+errmes$(errn)+")"
Resume

########################################################################################
## Sous-pro compta
########################################################################################
$SETREFGEN
If NUMREF=0
 NUMREF = [F:TXS]GENLEDTYP
 If NUMREF=0 : NUMREF = 2 : Endif
Endif
Return

$SETREFANA
If NUMREF=0
 NUMREF = [F:TXS]ANALEDTYP
 If NUMREF=0 : NUMREF = 2 : Endif
Endif
If BALANA=4
 # Recherche le type de rûˋfûˋrentiel "Partie Double" par rapport au rûˋfûˋrentiel gûˋnûˋral par dûˋfaut.
 NUMREF = 0
 For I=1 To NBSOC
  Call FLGDEM(TSOC(I),FLGDEM) From CPTDIV
  If FLGDEM=2
   Call LEDTYPDEM(TSOC(I),LSTTYPLED) From CPTDIV
   For I=1 To len(LSTTYPLED)
    J = val(mid$(LSTTYPLED,I,1))
    Call ORILEDTYP(TSOC(I),J,[L]ORITYP) From CPTDIV
    If [L]ORITYP= [F:TXS]GENLEDTYP
     NUMREF = J
     Break 2
    Endif
   Next
  Endif
 Next
 If NUMREF=0 : NUMREF = 4 : Endif
Endif
Return

#
# Exercices et Pûˋriodes
#

$SETEXE
For I=1 To NBSOC
 Call GETPERSOC(TSOC(I),NUMREF,[M]STRDAT(IC),EDEB,PDEB) From CPTSUB
 TEDEB(I) = EDEB
 TPDEB(I) = PDEB
 DAT_DEBEX = [F:PER]PERSTR
 Call GETPERSOC(TSOC(I),NUMREF,[M]ENDDAT(IC),EFIN,PFIN) From CPTSUB
 TEFIN(I) = EFIN
 TPFIN(I) = PFIN
 DAT_FINEX = [F:PER]PEREND
 Call NBPER(TSOC(I),NUMREF,TEFIN(I),NBPER) From CPTSUB
 Case [M]TYPMNT(IC)
  When 1 : # Tout
   If TPDEB(I)=1     : TPDEB(I) = 0       : Endif
   If TPFIN(I)=NBPER : TPFIN(I) = NBPER+1 : Endif
  When 2 : # Mvt + AN
   If TPDEB(I)=1     : TPDEB(I) = 0       : Endif
  When 3 : # Mvt + cloture
   If TPFIN(I)=NBPER : TPFIN(I) = NBPER+1 : Endif
  When 4 : # Mvt seuls
  When 5 : # AN seuls
   TEFIN(I) = TEDEB(I)
   TPFIN(I) = 0
   If TPDEB(I)=1     : TPDEB(I) = 0       : Endif
  When 6 : # Cloture seul
   TEDEB(I) = TEFIN(I)
   TPDEB(I) = NBPER+1
   If TPFIN(I)=NBPER : TPFIN(I) = NBPER+1 : Endif
 Endcase
Next I
Return

############################################################################################
## Sous-pro critû´res
############################################################################################
Subprog ADDCRIT(CRITERE,ICRIT,SUBCRIT)
Variable Char    CRITERE()(1..)
Variable Integer ICRIT
Value    Char    SUBCRIT
If ICRIT=1 & CRITERE(1)=""
 CRITERE(1) = SUBCRIT
Else
 If len(CRITERE(ICRIT))+len(SUBCRIT)>250-2
  ICRIT += 1
 Endif
 CRITERE(ICRIT) -= '&'-SUBCRIT
Endif
End

Subprog ADDJOK(CRITERE,ICRIT,ZONE,VALEUR)
Variable Char    CRITERE()(1..)
Variable Integer ICRIT
Value    Char    ZONE
Value    Char    VALEUR
Local Char    SUBCRIT(250) , ARG1(80) , ARG2(80)
Local Integer I , J , K , L , M
I = instr(1,VALEUR,"*")
J = instr(1,VALEUR,"?")
K = instr(1,VALEUR,"!")
L = instr(1,VALEUR,"#")
If I
 If J : I = min(I,J) : Endif
 If K : I = min(I,K) : Endif
 If L : I = min(I,L) : Endif
Elsif J
 I = J
 If K : I = min(I,K) : Endif
 If L : I = min(I,L) : Endif
Elsif K
 I = K
 If L : I = min(I,L) : Endif
Elsif L
 I = L
Endif
If I=0
 SUBCRIT = ZONE+'="'+VALEUR+'"'
Elsif I>1
 ARG1 = left$(VALEUR,I-1)
 ARG2 = left$(ARG1,I-2)+chr$(ascii(right$(ARG1,I-1))+1)
 SUBCRIT = ZONE+'>="'+ARG1+'" & '+ZONE+'<"'+ARG2+'"'
 If right$(VALEUR,I)<>"*"
  SUBCRIT -= '& pat('+ZONE+',"'+VALEUR+'")<>0'
 Endif
Elsif VALEUR<>"*"
 SUBCRIT = 'pat('+ZONE+',"'+VALEUR+'")<>0'
Endif
If SUBCRIT<>""
 Call ADDCRIT(CRITERE,ICRIT,SUBCRIT)
Endif
End

####################################################################################
## Sous-programmes d'ûˋcriture des rûˋsultats
####################################################################################

$ECR_TXM
Raz [F:TXM]
[F:TXM]TXSNAM  = [M]TXSNAM
[F:TXM]VERSION = [M]VERSION
[F:TXM]LIG = IL
[F:TXM]COL = IC+1
[F:TXM]IND = INDTXM
[F:TXM]AMTDEB = num$(MTDEB)
[F:TXM]AMTCDT = num$(MTCDT)
# <JFL 26/02/2007 - demande 39862 - Tableau de bord PE sur les signes>
Local Decimal DIFF
DIFF = MTDEB - MTCDT
GPOINT = "CALTBD" : Gosub ENTREE From EXEFNC
[F:TXM]AMTVAL = num$(DIFF)
# </JFL>

If TYPMONT=0
 #If ([M]CALCUL=2 & MTTMOD=1) | SAI_DEB<>0
 If ([M]CALCUL=2 & MTTMOD=1) | EXPL=1
  [F:TXM]AMTVAL = num$(SAI_DEB)
 Endif
 [F:TXM]UPDVAL = VALSAI(IL,IC+1)
Endif
[F:TXM]FCY    = SITE
[F:TXM]COA    = PLAN
[F:TXM]ACC    = COMPTE
[F:TXM]BPR    = TIERS
[F:TXM]FCYINF = SITINF
[F:TXM]ACCINF = CPTINF
[F:TXM]BPRINF = TRSINF
[F:TXM]TYPAMT = TYPMONT
Write [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return

####################################################################################
## Evaluation des libellûˋs
####################################################################################

$EVAL_INFSIT
SITINF = ""
If SITE="" : Return : Endif
If SITE<>[F:FCY]FCY
 Read [FCY]FCY0 = SITE
 If fstat
  Read [CPY]CPY0 = SITE
  If !fstat
   SITINF = [F:CPY]CPYNAM
  Endif
  Return
 Endif
Endif
If [F:TXS]FCYINF<>""
 If TRFCY
  Call LECTEXTRA(SITINF,"FACILITY",[F:TXS]FCYINF,SITE,"") From ATEXTRA
 Elsif MLFCY
  NOLIB = evalue("[F:FCY]"+[F:TXS]FCYINF)
  If NOLIB<>0 : SITINF = mess(NOLIB,MLFCY,1) : Endif
 Else
  SITINF = num$(evalue("[F:FCY]"+[F:TXS]FCYINF))
 Endif
Else
 SITINF = [F:FCY]FCYNAM
Endif
Return

$EVAL_INFACC
CPTINF = ""
If COMPTE="" : Return : Endif
If COMPTE<>[F:GAC]ACC or PLAN<>[F:GAC]COA
 Read [GAC]GAC0 = PLAN;COMPTE
 If fstat : Return : Endif
Endif
If [F:TXS]ACCINF<>""
 If TRACC
  Call LECTEXTRA(CPTINF,"GACCOUNT",[F:TXS]ACCINF,PLAN,COMPTE) From ATEXTRA
 Elsif MLACC
  NOLIB = evalue("[F:GAC]"+[F:TXS]ACCINF)
  If NOLIB<>0 : CPTINF = mess(NOLIB,MLACC,1) : Endif
 Else
  CPTINF = num$(evalue("[F:GAC]"+[F:TXS]ACCINF))
 Endif
Else
 Call LECTEXTRA(CPTINF,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Endif
Return

$EVAL_INFCCE
CCEINF = ""
If SECTION="" : Return : Endif
If SECTION<>[F:CCE]CCE or AXE<>[F:CCE]DIE
 Read [CCE]CCE0 = AXE;SECTION
 If fstat : Return : Endif
Endif
If [F:TXS]CCEINF<>""
 If TRCCE
  Call LECTEXTRA(CCEINF,"CACCE",[F:TXS]CCEINF,AXE,SECTION) From ATEXTRA
 Elsif MLCCE
  NOLIB = evalue("[F:CCE]"+[F:TXS]ACCINF)
  If NOLIB<>0 : CCEINF = mess(NOLIB,MLCCE,1) : Endif
 Else
  CCEINF = num$(evalue("[F:CCE]"+[F:TXS]CCEINF))
 Endif
Else
 Call LECTEXTRA(CCEINF,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
Endif
Return

$EVAL_INFBPR
TRSINF = ""
If TIERS="" : Return : Endif
If TIERS<>[F:BPR]BPRNUM
 Read [BPR]BPR0 = TIERS
 If fstat : Return : Endif
Endif
If [F:TXS]BPRINF<>""
 If TRBPR
  Call LECTEXTRA(TRSINF,"BPARTNER",[F:TXS]BPRINF,TIERS,"") From ATEXTRA
 Elsif MLBPR
  NOLIB = evalue("[F:BPR]"+[F:TXS]BPRINF)
  If NOLIB<>0 : TRSINF = mess(NOLIB,MLBPR,1) : Endif
 Else
  TRSINF = num$(evalue("[F:BPR]"+[F:TXS]BPRINF))
 Endif
Else
 TRSINF = [F:BPR]BPRNAM
Endif
Return

######################################################################################
## Recalcul des cumuls
######################################################################################
$EVAL_FORM
SAVFORMULE = FORMULE
TYPCUMUL = 0
While FORMULE<>""
 K = instr(1,FORMULE," ")
 If K
  EXPR = left$(FORMULE,K-1) : FORMULE = vireblc(right$(FORMULE,K+1),2)
 Else
  EXPR = FORMULE : FORMULE = ""
 Endif
 Gosub TRT_FORM
 If GOK<1 | TYPCUMUL : Break : Endif
Wend
FORMULE = SAVFORMULE
Return

$TRT_FORM
CAR = left$(EXPR,1)
If CAR="-"
 EXPR = right$(EXPR,2)
 Goto TRT_FORM
Endif
If find(CAR,"L","R")   :# syntaxe de type cumul
 TYPCUMUL = 1
 Delete [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & LIG=IL & COL=IC+1
 If fstat=1
  GOK=-1 : GLOCK="$TXSM"-[M]TXSNAM-[M]VERSION
 Endif
Endif
Return

