#<AdxTL>@(#)6.0.0.0 $Revision$
################################################################################################
# TRTSFIPOS : Paramétrage des eléménts de facturation  ( complément à SUBSFI )            V150 #
# - Saisie de la position des éléments de facturation dans les documents vente                 #
#----------------------------------------------------------------------------------------------#
# Traitement TRTSFIPOS / Action SAISFIPOS / Fenêtre ISFIPOS / Ecran SSFIPOS                    #
################################################################################################
$ACTION
#--- Actions liées à la fenêtre de saisie ISFIPOS
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : REP="M"
 When "AVANT_ENR"   : Gosub AVANT_ENR
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

################################################################################################
#----------------------------------------------------------------------------------------------#
# Chargement du masque SSFIPOS                                                                 #
#----------------------------------------------------------------------------------------------#
$DEBUT

# Gestion des positions en multi-société
Global  Integer G_CPY     : # flag multi-societe ( 0=gestion simple / 1=gestion multi-societes )
If dim([F:W09]DACBPC)>0 : G_CPY=1 : Endif
SAV_DEFAULT=dbgstr(2)

If !G_CPY
   Chgfmt [M]SOC With "-K: 1X" : Chgfmt [M]ZSOC With "-K: 1X"
Else
   If !clalev ([W09]) : Local File WCPYSFI [W09] : Endif   #CHECK IGNORE_LINE
   [M]SOC=[M:SFI1]SOC
   If [M]SOC=""
      If     GSOCIETE<>"" [M]SOC=GSOCIETE
        Else Call GETSOC(GFCYDEF(5)) From DEVSUB : [M]SOC=GSOCIETE
      Endif
   Endif
Endif

Gosub AFFICHAGE

Return

#----------------------------------------------------------------------------------------------#
# Ctrl avant d'enregistrer les positions :                                                     #
# Ctrl qu'il n'y a pas de trou dans les positions                                              #
# Ctrl qu'il n'y a pas de trou dans la chaine                                                  #
#----------------------------------------------------------------------------------------------#
$AVANT_ENR

# Si un élément est inactif ou non modifiable on vérifie qu'il n'a pas de position saisie
For I=0 To [M]NBFAC-1
    If [M]PROCOD(I)<>1 & sum([M]DACBPC(I),[M]DACORD(I),[M]DACDLV(I),[M]DACINV(I))<>0
        GMESSAGE= mess(195,197,1)-num$([M]INVDTA(I))-":"-mess(48,191,1) : GERR=1 : Break
    Endif
Next
If GERR=1 FOK=0 : Return : Endif

#  Eléments client
I=find(0, [M]INVDTACUS(0..[M]NBFACC-1))
If I GMESSAGE= mess(200,191,1)-mess(615,197,1)-num$(I) : GERR=1 : FOK=0 : Return : Endif

#  Eléments commande
I=find(0, [M]INVDTAORD(0..[M]NBFACO-1))
If I GMESSAGE= mess(201,191,1)-mess(615,197,1)-num$(I) : GERR=1 : FOK=0 : Return : Endif

#  Eléments livraison
I=find(0, [M]INVDTADLV(0..[M]NBFACD-1))
If I GMESSAGE= mess(202,191,1)-mess(615,197,1)-num$(I) : GERR=1 : FOK=0 : Return : Endif

#  Eléments facture
I=find(0, [M]INVDTAINV(0..[M]NBFACI-1))
If I GMESSAGE= mess(203,191,1)-mess(615,197,1)-num$(I) : GERR=1 : FOK=0 : Return : Endif

# ACA - 53327 - Si un élément n'est pas positionné sur la facture,
# il ne doit pas l'être sur le client, la commande ou la livraison
For I=0 To [M]NBFAC-1
    If [M]DACINV(I)=0 & sum([M]DACBPC(I),[M]DACORD(I),[M]DACDLV(I))<>0
        GMESSAGE= mess(195,197,1)-num$([M]INVDTA(I))-":"-mess(226,191,1) : GERR=1 : Break
    Endif
Next
If GERR=1 FOK=0 : Return : Endif

# ACA - 53327 - Si un élément est positionné sur la commande,
# il doit l'être sur la livraison
For I=0 To [M]NBFAC-1
    If [M]DACORD(I)<>0 & [M]DACDLV(I)=0
        GMESSAGE= mess(195,197,1)-num$([M]INVDTA(I))-":"-mess(227,191,1) : GERR=1 : Break
    Endif
Next
If GERR=1 FOK=0 : Return : Endif

# Bug 52410 : Contrôle de la position des éléments
Call OUVRE_TRACE (mess(768, 197,1)) From LECFIC

Local Integer W_BPC, W_MVT_SQH, W_MVT_SOH, W_MVT_SDH, W_MVT_SIV
Local Integer I, J
Gosub VERIF_MVT

For I=0 To [M]NBFAC-1
    Raz J
    # Contrôle position client
    If [M]DACBPC(I)<>0
        J = find([M]DACBPC(I),[M]YDACBPC(0..I-1),[M]YDACBPC(I+1..[M]NBFAC-1))
        If J
            # Elément déplacé qui va remplacer un autre élément
            If J>I J+= 1 Endif
            If W_BPC<>0
                GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(72,198,1)-num$([M]DACBPC(I))-":"-mess(765,197,1)
                GMESSAGE-= num$([M]INVDTA(J-1))-"("+[M]SHO(J-1)+")"
                Call ECR_TRACE (GMESSAGE,0) From GESECRAN
                W_BPC=2
            Endif
        Endif
    Elsif [M]YDACBPC(I)<>0
        # Elément supprimé du tableau
        If W_BPC<>0
            GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(72,198,1)-num$([M]YDACBPC(I))-":"-mess(767,197,1)
            Call ECR_TRACE (GMESSAGE,0) From GESECRAN
            W_BPC=2
        Endif
    Endif
    Raz J
    # Contrôle position commande
    If [M]DACORD(I)<>0
        J = find([M]DACORD(I),[M]YDACORD(0..I-1),[M]YDACORD(I+1..[M]NBFAC-1))
        If J
            # Elément déplacé qui va remplacer un autre élément
            If J>I J+= 1 Endif
            If W_MVT_SOH<>0 | W_MVT_SQH<>0
                GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(191,198,1)-num$([M]DACORD(I))-":"-mess(765,197,1)
                GMESSAGE-= num$([M]INVDTA(J-1))-"("+[M]SHO(J-1)+")"
                Call ECR_TRACE (GMESSAGE,0) From GESECRAN
                If W_MVT_SOH W_MVT_SOH=2 Endif
                If W_MVT_SQH W_MVT_SQH=2 Endif
            Endif
        Endif
    Elsif [M]YDACORD(I)<>0
        # Elément supprimé du tableau
        If W_MVT_SOH<>0 | W_MVT_SQH<>0
            GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(191,198,1)-num$([M]YDACORD(I))-":"-mess(767,197,1)
            Call ECR_TRACE (GMESSAGE,0) From GESECRAN
            If W_MVT_SOH W_MVT_SOH=2 Endif
            If W_MVT_SQH W_MVT_SQH=2 Endif
        Endif
    Endif

    Raz J
    # Contrôle position livraison
    If [M]DACDLV(I)<>0
        J = find([M]DACDLV(I),[M]YDACDLV(0..I-1),[M]YDACDLV(I+1..[M]NBFAC-1))
        If J
            # Elément déplacé qui va remplacer un autre élément
            If J>I J+= 1 Endif
            If W_MVT_SDH<>0
                GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(54,198,1)-num$([M]DACDLV(I))-":"-mess(765,197,1)
                GMESSAGE-= num$([M]INVDTA(J-1))-"("+[M]SHO(J-1)+")"
                Call ECR_TRACE (GMESSAGE,0) From GESECRAN
                W_MVT_SDH=2
            Endif
        Endif
    Elsif [M]YDACDLV(I)<>0
        # Elément supprimé du tableau
        If W_MVT_SDH<>0
            GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(54,198,1)-num$([M]YDACDLV(I))-":"-mess(767,197,1)
            Call ECR_TRACE (GMESSAGE,0) From GESECRAN
            W_MVT_SDH=2
        Endif
    Endif

    Raz J
    # Contrôle position facture
    If [M]DACINV(I)<>0
        J = find([M]DACINV(I),[M]YDACINV(0..I-1),[M]YDACINV(I+1..[M]NBFAC-1))
        If J
            # Elément déplacé qui va remplacer un autre élément
            If J>I J+= 1 Endif
            If W_MVT_SIV<>0
                GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(55,198,1)-num$([M]DACINV(I))-":"-mess(765,197,1)
                GMESSAGE-= num$([M]INVDTA(J-1))-"("+[M]SHO(J-1)+")"
                Call ECR_TRACE (GMESSAGE,0) From GESECRAN
                W_MVT_SIV=2
            Endif
        Endif
    Elsif [M]YDACINV(I)<>0
        # Elément supprimé du tableau
        If W_MVT_SIV<>0
            GMESSAGE = mess(195,197,1)-num$([M]INVDTA(I))-"("+[M]SHO(I)+") :"-mess(766,197,1)-mess(55,198,1)-num$([M]YDACINV(I))-":"-mess(767,197,1)
            Call ECR_TRACE (GMESSAGE,0) From GESECRAN
            W_MVT_SIV=2
        Endif
    Endif
Next

If W_MVT_SQH=2 Call ECR_TRACE (mess(761,197,1),0) From GESECRAN Endif
If W_MVT_SOH=2 Call ECR_TRACE (mess(762,197,1),0) From GESECRAN Endif
If W_MVT_SDH=2 Call ECR_TRACE (mess(763,197,1),0) From GESECRAN Endif
If W_MVT_SIV=2 Call ECR_TRACE (mess(764,197,1),0) From GESECRAN Endif
Raz GMESSAGE
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
If W_BPC=2 | W_MVT_SQH=2 | W_MVT_SOH=2 | W_MVT_SDH=2 | W_MVT_SIV=2
    Local Integer WRET : WRET=1
    Call OUINON(mess(205, 100,1), WRET) From GESECRAN
    If WRET=1 GERR=1 : FOK=0 : Return Endif
Endif
# Bug 52410

Return

# Vérification s'il existe des mouvements
$VERIF_MVT
# Vérification s'il existe des clients
Raz W_BPC
If clalev([F:BPC]) =0 Local File BPCUSTOMER [BPC]  : Endif
Filter [BPC]
If rowcount ([F:BPC])>0 W_BPC=1 Endif
Filter [BPC]

# Vérification s'il existe des devis
Raz W_MVT_SQH
If clalev([F:SQH]) =0 Local File SQUOTE [SQH]  : Endif
Filter [SQH]
If rowcount ([F:SQH])>0 W_MVT_SQH=1 Endif
Filter [SQH]

# Vérification s'il existe des commandes
Raz W_MVT_SOH
If clalev([F:SOH]) =0 Local File SORDER [SOH]  : Endif
Filter [SOH]
If rowcount ([F:SOH])>0 W_MVT_SOH=1 Endif
Filter [SOH]

# Vérification s'il existe des livraisons
Raz W_MVT_SDH
If clalev([F:SDH]) =0 Local File SDELIVERY [SDH] : Endif
Filter [SDH]
If rowcount ([F:SDH])>0 W_MVT_SDH=1 Endif
Filter [SDH]

# Vérification s'il existe des factures
Raz W_MVT_SIV
If clalev([F:SIV]) =0 Local File SINVOICEV [SIV] : Endif
Filter [SIV]
If rowcount ([F:SIV])>0 W_MVT_SIV=1 Endif
Filter [SIV]
Return

#----------------------------------------------------------------------------------------------#
# Enregistrer les positions dans les éléments de facturation                                   #
#----------------------------------------------------------------------------------------------#
$ENR

Call DEBTRANS From GLOCK

If G_CPY    Gosub TR_W09
  Else      Gosub TR_SFI
Endif
Return

#-----

$TR_W09
GOK=1
Trbegin [W09]
For I=0 To [M]NBFAC-1
    Readlock  [W09]CPY0=[M]SOC;[M]INVDTA(I)
    If fstat=1  GOK=-1 : GLOCK="$WCPYSFI"-[M]SOC+"("+[M]INVDTA(I)+")" : Goto ROLL_W09
    Elsif fstat GOK=0  : Call RSTA("W09",[M]INVDTA(I)) From GLOCK : Goto AB_W09 : Endif

    ### X3-56775 - Default value of an invoicing element in the sales documents
    If [M]DACBPC(I)=0 and [F:SFI]DACBPC<>0
      If clalev([F:BPC]) =0 Local File BPCUSTOMER [BPC]  : Endif
      Filter [BPC] Where INVDTA([F:SFI]DACBPC-1)=[M]INVDTA(I)
      For [BPC]
        Readlock Curr
        If fstat=1  GOK=-1 : GLOCK="$BPCUSTOMER"-[F:BPC]BPCNUM : Goto ROLL_W09
        Elsif fstat GOK=0  : Call RSTA("BPC",[F:BPC]BPCNUM) From GLOCK : Goto AB_W09 : Endif
        Raz [F:BPC]INVDTA([F:SFI]DACBPC-1),[F:BPC]INVDTAAMT([F:SFI]DACBPC-1)
        Rewrite [BPC]
        If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Goto AB_W09 : Endif
      Next
    Endif
    ### End X3-56775

    [F:W09]DACBPC=[M]DACBPC(I)
    [F:W09]DACORD=[M]DACORD(I)
    [F:W09]DACDLV=[M]DACDLV(I)
    [F:W09]DACINV=[M]DACINV(I)
    Rewrite [W09]
    If fstat GOK=0 : Call FSTA("W09") From GLOCK : Goto AB_W09 : Endif
Next

Commit
REP=""
Default File SAV_DEFAULT
Return

$ROLL_W09
Rollback : Call ROLL From GLOCK
If !GROLL Goto TR_W09 : Endif
Return

$AB_W09
Rollback
Return

#-----

$TR_SFI
GOK=1
Trbegin [SFI]
For I=0 To [M]NBFAC-1
    Readlock  [SFI]SFI0=[M]INVDTA(I)
    If fstat=1  GOK=-1 : GLOCK="$SFOOTINV"-[M]INVDTA(I) : Goto ROLL_SFI
    Elsif fstat GOK=0  : Call RSTA("SFI",[M]INVDTA(I)) From GLOCK : Goto AB_SFI : Endif

    ### X3-56775 - Default value of an invoicing element in the sales documents
    If [M]DACBPC(I)=0 and [F:SFI]DACBPC<>0
      If clalev([F:BPC]) =0 Local File BPCUSTOMER [BPC]  : Endif
      Filter [BPC] Where INVDTA([F:SFI]DACBPC-1)=[M]INVDTA(I)
      For [BPC]
        Readlock Curr
        If fstat=1  GOK=-1 : GLOCK="$BPCUSTOMER"-[F:BPC]BPCNUM : Goto ROLL_SFI
        Elsif fstat GOK=0  : Call RSTA("BPC",[F:BPC]BPCNUM) From GLOCK : Goto AB_SFI : Endif
        Raz [F:BPC]INVDTA([F:SFI]DACBPC-1),[F:BPC]INVDTAAMT([F:SFI]DACBPC-1)
        Rewrite [BPC]
        If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Goto AB_SFI : Endif
      Next
    Endif
    ### End X3-56775

    [F:SFI]DACBPC=[M]DACBPC(I)
    [F:SFI]DACORD=[M]DACORD(I)
    [F:SFI]DACDLV=[M]DACDLV(I)
    [F:SFI]DACINV=[M]DACINV(I)
    Rewrite [SFI]
    If fstat GOK=0 : Call FSTA("SFI") From GLOCK : Goto AB_SFI : Endif

Next

Commit
REP=""
Default File SAV_DEFAULT

Gosub AFFICHAGE
Return

$ROLL_SFI
Rollback : Call ROLL From GLOCK
If !GROLL Goto TR_SFI : Endif
Return

$AB_SFI
Rollback
Return

#----------------------------------------------------------------------------------------------#
# Abandon
#----------------------------------------------------------------------------------------------#

$ABA
Gosub DEBUT
REP = ""
Default File SAV_DEFAULT
Return

#----------------------------------------------------------------------------------------------#
# Chargement des tableaux des éléments par document                                            #
#----------------------------------------------------------------------------------------------#

$AFFICHAGE
# Chargement du tableau de saisie de la position des éléments
J_SOC=[M]SOC
Raz [M] : [M]SOC=J_SOC
nolign=1
Default File [SFI]
For [SFI]
    If G_CPY
       Read [W09]CPY0=[M]SOC;[F:SFI]SFINUM
       If !fstat : [F:SFI]=[F:W09] : Endif
    Endif
    If ([F]PROCOD=1 | sum([F]DACBPC,[F]DACORD,[F]DACDLV,[F]DACINV)<>0) &
&      ([F]INVFOOBRD=0 | sum([F]DACBPC,[F]DACORD,[F]DACDLV,[F]DACINV)<>0)
        [M]=[F]
        [M]INVDTA (nolign-1)= [F]SFINUM

        [M]YDACBPC (nolign-1)= [F]DACBPC
        [M]YDACORD (nolign-1)= [F]DACORD
        [M]YDACDLV (nolign-1)= [F]DACDLV
        [M]YDACINV (nolign-1)= [F]DACINV

        Call LECTEXTRA ([M]DES(nolign-1),"SFOOTINV","DESAXX",num$([F]SFINUM),"") From ATEXTRA
        Call LECTEXTRA ([M]SHO(nolign-1),"SFOOTINV","SHOAXX",num$([F]SFINUM),"") From ATEXTRA
        nolign+=1
        [M]NBFAC+=1
        If [M]NBFAC>=dim([M]INVDTA) Break Endif
    Endif
Next
# Chargement des tableaux des éléments par document
Gosub CHARGE_TABLEAUX
Affzo [M]1-99
Return


#----------------------------------------------------------- #
# Chargement des tableaux des éléments par document          #
#----------------------------------------------------------- #
$CHARGE_TABLEAUX

Raz [M]NBFACC, INVDTACUS, SHOCUS
Raz [M]NBFACO, INVDTAORD, SHOORD
Raz [M]NBFACD, INVDTADLV, SHODLV
Raz [M]NBFACI, INVDTAINV, SHOINV
For I=0 To [M]NBFAC-1
    # Eléments du client
    If [M]DACBPC(I)<>0
        [M]INVDTACUS([M]DACBPC(I)-1)=[M]INVDTA(I)
        [M]SHOCUS([M]DACBPC(I)-1)=[M]SHO(I)
    Endif
    If [M]NBFACC<[M]DACBPC(I) [M]NBFACC=[M]DACBPC(I) Endif

    # Eléments de la commande
    If [M]DACORD(I)<>0
        [M]INVDTAORD([M]DACORD(I)-1)=[M]INVDTA(I)
        [M]SHOORD([M]DACORD(I)-1)=[M]SHO(I)
    Endif
    If [M]NBFACO<[M]DACORD(I) [M]NBFACO=[M]DACORD(I) Endif

    # Eléments de la livraison
    If [M]DACDLV(I)<>0
        [M]INVDTADLV([M]DACDLV(I)-1)=[M]INVDTA(I)
        [M]SHODLV([M]DACDLV(I)-1)=[M]SHO(I)
    Endif
    If [M]NBFACD<[M]DACDLV(I) [M]NBFACD=[M]DACDLV(I) Endif

    # Eléments de la facture
    If [M]DACINV(I)<>0
        [M]INVDTAINV([M]DACINV(I)-1)=[M]INVDTA(I)
        [M]SHOINV([M]DACINV(I)-1)=[M]SHO(I)
    Endif
    If [M]NBFACI<[M]DACINV(I) [M]NBFACI=[M]DACINV(I) Endif
Next

While [M]NBFACC>0 & [M]INVDTACUS([M]NBFACC-1)=0  [M]NBFACC-=1  Wend
While [M]NBFACO>0 & [M]INVDTAORD([M]NBFACO-1)=0  [M]NBFACO-=1  Wend
While [M]NBFACD>0 & [M]INVDTADLV([M]NBFACD-1)=0  [M]NBFACD-=1  Wend
While [M]NBFACI>0 & [M]INVDTAINV([M]NBFACI-1)=0  [M]NBFACI-=1  Wend

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SSFIPOS) 24/02/2005 15:34:16 (LD)
######################################################################################

# ------------------------------ Position Client
Subprog AS_DACBPC(VALEUR)
Variable Decimal VALEUR
If ([M]PROCOD(nolign-1)<>1 & VALEUR=0) | ([M]INVFOOBRD(nolign-1)<>0 & VALEUR=0) : mkstat=2 : Endif
End
#-------------------------------
Subprog C_DACBPC(VALEUR)
Variable Decimal VALEUR
## ### X3-56775 - Default value of an invoicing element in the sales documents
If [M]DACBPC(nolign-1)=max([M]DACBPC) and VALEUR=0
  # Checking if it exists in the customers table
  Local Integer W_BPC :Raz W_BPC
  If clalev([F:BPC]) =0 Local File BPCUSTOMER [BPC]  : Endif
  Filter [BPC] Where INVDTA([M]DACBPC(nolign-1)-1)=[M]INVDTA(nolign-1)
  If rowcount ([F:BPC])>0 W_BPC=1 Endif
  Filter [BPC]
  If W_BPC=1
    Local Integer WRET : WRET=1
    Call OUINON(mess(280,191,1)+"\"+mess(205, 100,1), WRET) From GESECRAN
    If WRET=1
      mkstat=2: End
    Endif
  Endif
  End
Endif
## End x3-56775
If VALEUR=0  End Endif

If VALEUR>dim([M]INVDTACUS) mkstat=2 : GMESSAGE=mess(36,141,1) : End Endif
# On ctrle que l'élément saisi n'est pas déjà présent dans une autre position
Call UNICITE(VALEUR,[M]DACBPC(0..[M]NBFAC-1)) From OBJDIV
If mkstat=2 End Endif
End
# ------------------------------ Position Commande
Subprog AS_DACORD(VALEUR)
Variable Decimal VALEUR
If ([M]PROCOD(nolign-1)<>1 & VALEUR=0) | ([M]INVFOOBRD(nolign-1)<>0 & VALEUR=0) : mkstat=2 : Endif
End
#-------------------------------
Subprog C_DACORD(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 End Endif
If VALEUR>dim([M]INVDTAORD) mkstat=2 : GMESSAGE=mess(36,141,1) : End Endif
# On ctrle que l'élément saisi n'est pas déjà présent dans une autre position
Call UNICITE(VALEUR,[M]DACORD(0..[M]NBFAC-1)) From OBJDIV
If mkstat=2 End Endif
End

# ------------------------------ Position Livraison
Subprog AS_DACDLV(VALEUR)
Variable Decimal VALEUR
If ([M]PROCOD(nolign-1)<>1 & VALEUR=0) | ([M]INVFOOBRD(nolign-1)<>0 & VALEUR=0) : mkstat=2 : Endif
End
#-------------------------------
Subprog C_DACDLV(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 End Endif
If VALEUR>dim([M]INVDTADLV) mkstat=2 : GMESSAGE=mess(36,141,1) : End Endif
# On ctrle que l'élément saisi n'est pas déjà présent dans une autre position
Call UNICITE(VALEUR,[M]DACDLV(0..[M]NBFAC-1)) From OBJDIV
If mkstat=2 End Endif
End

# ------------------------------ Position Facture
Subprog AS_DACINV(VALEUR)
Variable Decimal VALEUR
If ([M]PROCOD(nolign-1)<>1 & VALEUR=0) | ([M]INVFOOBRD(nolign-1)<>0 & VALEUR=0) : mkstat=2 : Endif
End
#-------------------------------
Subprog C_DACINV(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 End Endif
If VALEUR>dim([M]INVDTAINV) mkstat=2 : GMESSAGE=mess(36,141,1) : End Endif
# On ctrle que l'élément saisi n'est pas déjà présent dans une autre position
Call UNICITE(VALEUR,[M]DACINV(0..[M]NBFAC-1)) From OBJDIV
If mkstat=2 End Endif
End

Subprog APRES_NBFAC
Gosub CHARGE_TABLEAUX
Affzo [M]1-99
End
