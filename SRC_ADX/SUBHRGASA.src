#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2017-03-30- US X3-11264 ST X3-25377- START

#CHECK IGNORE_SOURCE
#Traitement Compta X3: Utilisation partiel dans HRM -> Ne pas analyser
##########################################################################
# FQ92876-US2683 - Accounting interface

Local Integer OK2
Local Char DACDIA(GLONGDE)    : DACDIA="COL"
Local Char FCY(GLONFCY)       : FCY="ZCC1"
Local Char TYP(GLONGTE)       : TYP="FAD"
Local Date DAT                : DAT=date$
Local Integer STAT

Local Mask GACCENTFMT  [HRHAEF]
Local Mask VENTILE2    [VT2]

Call INIMSKFMT2(FCY,DACDIA,TYP,DAT,STAT)
End

####################################################################################
# Sous programme INIMSKFMT2... appelez uniquement ici, pour test.
####################################################################################
Subprog INIMSKFMT2(FCY,DACDIA,TYP,DAT,STAT)
Value Char       FCY()
Value Char       DACDIA()
Value Char       TYP()
Value Date       DAT
Variable Integer STAT

Local Integer TYPSAI : # Type saisie (1:Colonne 2:Ligne 3:Onglet)
Local Integer TST    : TST=1

Gosub DECLARE

Call LEC_GDE([L]DACDIA) From CPTLEC           # Lecture de Transaction de saisie
Call LEC_FCY([L]FCY) From CPTLEC              # Lecture du site
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC       # Lecture de la société juridique
Call LEC_GTE_LEG([F:CPY]LEG,[L]TYP) From CPTLEC  # Lecture du type de pièce
Call LEC_GCM([F:CPY]ACM) From CPTLEC          # Lecture du modèle comtpable
[L]TYPSAI = [F:GDE]TYPENT

Raz [M:HAEF]
[M:HAEF]CPY=[F:CPY]CPY
[M:HAEF]FCY=FCY
[M:HAEF]DACDIA=DACDIA
[M:HAEF]TYP=TYP
[M:HAEF]ACCDAT=DAT

# Passage par un tableau de référentiel... Référentiel "saisi" => tous les référentiels de la transaction
Raz GEN_NBRLED
For I=1 To [F:GDE]NBRLED
 GEN_LEDTYP(GEN_NBRLED) = [F:GDE]LEDTYP(I-1)  # Type de référentiel de la transaction
 GEN_NBRLED+=1
Next

Goto INIMSK
End

####################################################################################
# Sous programme INIMSKFMT2... appelez uniquement ici, pour test.
####################################################################################
Subprog INIMSKFMT(FCY,DACDIA,TYP,DAT,STAT)
Value Char       FCY()
Value Char       DACDIA()
Value Char       TYP()
Value Date       DAT
Variable Integer STAT

Local Integer TYPSAI : # Type saisie (1:Colonne 2:Ligne 3:Onglet)
Local Integer TST    : Raz TST

Gosub DECLARE

Call LEC_GDE([L]DACDIA) From CPTLEC          # Lecture de Transaction de saisie
Call LEC_FCY([L]FCY) From CPTLEC             # Lecture du site
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC      # Lecture de la société juridique
Call LEC_GCM([F:CPY]ACM) From CPTLEC         # Lecture du modèle comtpable
Call LEC_GTE_LEG([F:CPY]LEG,[L]TYP) From CPTLEC # Lecture du type de pièce
[L]TYPSAI = [F:GDE]TYPENT

Raz [M:HAEF]
[M:HAEF]FCY=[L]FCY
[M:HAEF]CPY=[F:CPY]CPY
[M:HAEF]TYP=[L]TYP
[M:HAEF]ACCDAT=[L]DAT
[M:HAEF]DACDIA=[L]DACDIA

# Passage par un tableau de référentiel... Référentiel "saisi" => tous les référentiels de la transaction
Raz GEN_NBRLED
For I=1 To [F:GDE]NBRLED
 GEN_LEDTYP(GEN_NBRLED) = [F:GDE]LEDTYP(I-1)  # Type de référentiel de la transaction
 GEN_NBRLED+=1
Next

Goto INIMSK
End

####################################################################################
# INIMSKFMT3 : Remplissage du masque de référence 'HRHAEF' en forçant le type
#              de saisie (colonne/ligne/onglet)
####################################################################################
Subprog INIMSKFMT3(FCY,TYPSAI,DACDIA,TYP,DAT,STAT)
Value Char       FCY()
Value Integer    TYPSAI
Value Char       DACDIA()
Value Char       TYP()
Value Date       DAT
Variable Integer STAT

Local Integer TST : Raz TST
Gosub DECLARE

Call LEC_GDE([L]DACDIA) From CPTLEC          # Lecture de Transaction de saisie
Call LEC_FCY([L]FCY) From CPTLEC             # Lecture du site
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC      # Lecture de la société juridique
Call LEC_GTE_LEG([F:CPY]LEG,[L]TYP) From CPTLEC # Lecture du type de pièce
Call LEC_GCM([F:CPY]ACM) From CPTLEC         # Lecture du modèle comtpable

Raz [M:HAEF]
[M:HAEF]CPY=[F:CPY]CPY
[M:HAEF]FCY=FCY
[M:HAEF]DACDIA=DACDIA
[M:HAEF]TYP=TYP
[M:HAEF]ACCDAT=DAT

For I=0 To len(mess(0,2644,1))-1
 [M:HAEF]RATDIVC(I) = [M:HAE1]RATDIV(I)
 [M:HAEF]RATMLTC(I) = [M:HAE1]RATMLT(I)
Next

# Passage par un tableau de référentiel... Tous les Référentiel "saisi" => tous les référentiels de la transaction
Raz GEN_NBRLED
For I=1 To len(mess(0,2644,1))
 Call LEDTYPAUT([M:HAEF]CPY,I,[L]AUT) From CPTDIV : # 1:Non 2:Oui
 If [L]AUT=1
  GEN_LEDTYP(GEN_NBRLED) = I
  GEN_NBRLED+=1
 Endif
Next


####################################################################################
$INIMSK
STAT = 0
Read [ATY]CODTYP="SAC"
TYPSAC="K:"+[F:ATY]FORTYP

# Maximun 10 Types de référentiels possibles.
# - Lecture des types de référentiels selon la transaction
# - Avec le site, lecture du modèle comptable associé à la société
#                 liste des référentiels avec Validation auto 'Non'
# - Avec le type de pièce, vérification que le Type de référentiel soit autorisé
#                           Champ AUZLED => M2647 (Non autorisé, Autorisé, Obligatoire)

[M:HAEF]TYPENT = [L]TYPSAI
[M:HAEF]GENLED = [F:GCM]GENLEDTYP
# 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
# Ces fichiers sont uniquement sous le dossier comptable X3
Gosub INIT_LOT_PAG_AUZLZD_PER From SUBHRGASA
If func TRTHRCPT.ISCPT
  [M:HAEF]EQL    = [F:GDE]FLGEQL
Else
  [M:HAEF]EQL    = 2 # Saisie équilibré
Endif
#END 92876 US2690
For I=0 To GEN_NBRLED-1

 IND = GEN_LEDTYP(I)-1      # Type de référentiel de la transaction

 Call LEDTYPAUT([M:HAEF]CPY,GEN_LEDTYP(I),[L]AUT) From CPTDIV : # 1:Non 2:Oui

 #If [F:GCM]LED(IND)<>"" & ([F:GCM]CFMAUT(IND)<>2 | [L]TYPSAI=3) #F59500
 If ([F:GCM]LED(IND)<>"" & [F:GCM]CFMAUT(IND)<>2 ) | [L]TYPSAI=3

  # Référentiel Non Automatique Autorisé ou Obligatoire (ou STD ou "Gestion par lot")
# 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
#  If  ([L]AUT=1 &[F:GTE]AUZLED(IND) > 1  & [F:GCM]CFMAUT(IND)<>2) or [L]TYPSAI=3 or [F:GDE]FLGLOT=2
  If  ([L]AUT=1 & WAUZLED(IND) > 1  & [F:GCM]CFMAUT(IND)<>2) or [L]TYPSAI=3 or WFLGLOT=2

   # Référentiel
   [M:HAEF]LEDTYP(NBLED)=GEN_LEDTYP(I)
   [M:HAEF]LED(NBLED) = [F:GCM]LED(IND)
   [M:HAEF]CUR(NBLED) = [F:GCM]CUR(IND)
   If [F:LED]LED<>[M:HAEF]LED(NBLED)
    Read [LED]LED0 = [M:HAEF]LED(NBLED)
    If fstat  : Raz [LED] :  Endif
   Endif

   # Code plan
   [M:HAEF]COA(NBLED) = [F:LED]COA
   If [F:COA]COA<>[M:HAEF]COA(NBLED)
    Read [COA]COA0 = [M:HAEF]COA(NBLED)
    If fstat  : Raz [COA] :  Endif
   Endif

   # Intitulé et Format évalués SAUF en Saisie par ligne
   If [L]TYPSAI<>2
    If !GIMPORT
     Call LECTEXTRA([M:HAEF]INTCOA(NBLED),"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
    Endif
    [M:HAEF]INTCOA(NBLED) = [M:HAEF]INTCOA(NBLED)

    If [F:COA]ACCFMT<>""
     If !instr(1,[F:COA]ACCFMT,"#")
      [M:HAEF]FMTCOA(NBLED)="K:"+[F:COA]ACCFMT
     Elsif instr(1,[F:COA]ACCFMT,"#")
      If [F:COA]ACCLEN<>0
       [M:HAEF]FMTCOA(NBLED)="K:"+num$([F:COA]ACCLEN)+"c"
      Else
       [M:HAEF]FMTCOA(NBLED)="K:"+mid$([F:COA]ACCFMT,1,len([F:COA]ACCFMT)-1)+"c"
      Endif
     Endif
    Else
     [M:HAEF]FMTCOA(NBLED)="K:20C"
    Endif

    [M:HAEF]FMTSAC(NBLED)=TYPSAC
    [M:HAEF]FMTCPA(NBLED)="K:15c"
   Endif

   # Axes... selon la saisie
   [M:HAEF]NBDIE(NBLED) = [F:LED]DIENBR
   For J=0 To [F:LED]DIENBR-1
    If [F:LED]DIE(J)<>""
     Assign "[M:HAEF]DIE"+num$(J+1)+"("+num$(NBLED)+")"  With [F:LED]DIE(J)
     If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
     If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
      [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
      [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
      Read [DIE]DIE0 = [F:LED]DIE(J)
      If fstat  : Raz [DIE] :  Endif
      If !GIMPORT
       Call LECTEXTRA([M:HAEF]INTDIE(NBDIE),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
      Endif
      If [F:DIE]CCEFMT<>""
       [M:HAEF]FMTDIE(NBDIE)="K:"+[F:DIE]CCEFMT
       If !TST
        If [L]TYPSAI=3
         Call FMTCCE(num$(I+2),J+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
        Elsif WFLGPAG=2 # 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
         Call FMTCCE("1",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
        Else
         Call FMTCCE("2",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
        Endif
       Endif
      Else
       [M:HAEF]FMTDIE(NBDIE)="K:10C"
       If !TST
        If [L]TYPSAI=3
         Call FMTCCE(num$(I+2),J+1,"K:15c",[F:DIE]DIE)
        Elsif WFLGPAG=2 # 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
         Call FMTCCE("1",NBDIE+1,"K:15c",[F:DIE]DIE)
        Else
         Call FMTCCE("2",NBDIE+1,"K:15c",[F:DIE]DIE)
        Endif
       Endif
      Endif
      NBDIE+=1
     Else
      # Cela signifie que sous un modèle comptable, des axes sont en doublon.
      If [L]TYPSAI=3
       If !TST
        Call FMTCCE(num$(I+2),J+1,"K:15c",[F:LED]DIE(J))
       Endif
      Endif
     Endif
    Endif
   Next

   # Format des Axes invisibles... uniquement en onglet
   If [L]TYPSAI=3
    For K=[F:LED]DIENBR+1 To GOPTCANA
     If !TST
      Call FMTCCE(num$(I+2),K,"-K:15c","")
     Endif
    Next
   Endif

   # Gestion des devises des référentiels potentiellement saisissables
   [M:HAEF]AUTC(IND)    = 1
   [M:HAEF]TYPC(IND)    = IND+1
   [M:HAEF]LEDC(IND)    = [F:GCM]LED(IND)
   [M:HAEF]CURC(IND)    = [F:GCM]CUR(IND)
   [M:HAEF]VCRRATC(IND) = [F:GCM]FLGVCRRAT(IND)

   NBLED += 1
  Endif
 Endif
Next
If STAT : End : Endif

#-- Pièces d'ànouveau et de clôture sont mono-référentiel. - déplacement en cours
# If [L]TYPSAI<>3 and [F:GDE]FLGLOT<>2
#  If [F:GTE]PER>1 & [L]NBLED>1 : STAT = 37 : End : Endif
# Endif

# Gestion des axes des référentiels générés mais non saisie.
For I=0 To dim([F:GCM]LED)-1
 If !find([F:GCM]LED(I),[M:HAEF]LED(0..[L]NBLED))
  If [F:LED]LED<>[F:GCM]LED(I)
   Read [LED]LED0 = [F:GCM]LED(I)
   If fstat  : Raz [LED] :  Endif
  Endif
  For J=0 To [F:LED]DIENBR-1
   If [F:LED]DIE(J)<>""
    If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
    If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
     [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
     [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
     Read [DIE]DIE0 = [F:LED]DIE(J)
     If fstat  : Raz [DIE] :  Endif
     If !GIMPORT
      Call LECTEXTRA([M:HAEF]INTDIE(NBDIE),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
     Endif
     If [F:DIE]CCEFMT<>""
      [M:HAEF]FMTDIE(NBDIE)="K:"+[F:DIE]CCEFMT
      If !TST
       If WFLGPAG=2 # 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
        Call FMTCCE("1",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
       Else
        Call FMTCCE("2",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
       Endif
      Endif
     Else
      [M:HAEF]FMTDIE(NBDIE)="K:10C"
      If !TST
       If WFLGPAG=2 # 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
        Call FMTCCE("1",NBDIE+1,"K:15c",[F:DIE]DIE)
       Else
        Call FMTCCE("2",NBDIE+1,"K:15c",[F:DIE]DIE)
       Endif
      Endif
     Endif
     NBDIE+=1
    Endif
   Endif
  Next
 Endif
Next

If ![L]NBLED : STAT = 36 : Endif

[M:HAEF]NBRL=9
[M:HAEF]NBRC=9
[M:HAEF]NBRLED = [L]NBLED
[M:HAEF]NBRAXI = [L]NBDIE


# Format des Comtpes invisibles
For I=NBLED To 9
 [M:HAEF]FMTCOA(I) = "-K:15X"
 [M:HAEF]FMTSAC(I) = "-K:15X"
 [M:HAEF]FMTCPA(I) = "-K:15X"
Next

# Format des Axes invisibles... uniquement en saisie ligne ou colonnes
For I=NBDIE To 19
 If !TST
  If WFLGPAG=2 # 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
   Call FMTCCE("1",I+1,"-K:15c",[F:DIE]DIE)
  Else
   Call FMTCCE("2",I+1,"-K:15c",[F:DIE]DIE)
  Endif
 Endif
 If [M:HAEF]FMTDIE(I)="" : [M:HAEF]FMTDIE(I) = "-K:15c" :  Endif
Next

# Gestion des devises des référentiels potentiellement générés
For I=0 To len(mess(0,2644,1))-1
 If WAUZLED(I)=3 & [F:GCM]LED(I) ="" : STAT=43 : Break : Endif
 If [F:GCM]LED(I)<>"" & WAUZLED(I)>1
  [M:HAEF]GENC(I)    = 2
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED(I)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]RNDOPT(I)  = [F:GCM]RNDOPTBAL(I)
 Endif
 # Mise à jour Exercice/période
# 92876 US2690 table PERIODE non défini dans HR
# [M:HAEF]FIY(I),[M:HAEF]PER(I) only ISCPT
If func TRTHRCPT.ISCPT
 Call GETPERSOC([F:CPY]CPY,I+1,[M:HAEF]ACCDAT,[M:HAEF]FIY(I),[M:HAEF]PER(I)) From CPTSUB
Endif
# WPER
 Case WPER
  When 1       :
  When 2       : [M:HAEF]PER(I)  = 0
  When Default : [M:HAEF]PER(I) += WPER-2
 Endcase
 # Mise à jour Equilibre
 If [F:LED]LED<>[F:GCM]LED(I)
  Read [LED]LED0 = [F:GCM]LED(I)
  If fstat  : Raz [LED] :  Endif
 Endif
 [M:HAEF]BAL(I) = [F:LED]BAL
 [M:HAEF]BALFCY(I) = [F:LED]FCYBAL
 [M:HAEF]MTC(I)    = [F:LED]MTCFLG
Next
If STAT : End : Endif

# Gestion des devises des référentiels "automatique"
[M:HAEF]FMTDOE = "-K:15X"
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]CFMAUT(I)=2 & [M:HAEF]LEDC([F:GCM]ORILEDTYP(I)-1)<>""
  [M:HAEF]AUTC(I)    = 2
  [M:HAEF]GENC(I)    = 1 #DdM53406
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED([F:GCM]ORILEDTYP(I)-1)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]DOELEDC(I) = [F:GCM]DOELED(I)
  If [F:GCM]DOELED(I) = 2 : [M:HAEF]FMTDOE = "K:15X" : Endif
 Endif
Next

#--- Stock des référentiels saisis puis générés
Raz GNBTYPLED, GTYPLED, GCODLED, GPLAN

For I=0 To [M:HAEF]NBRLED-1
 GNBTYPLED+=1
 GTYPLED(GNBTYPLED) = [M:HAEF]LEDTYP(I)
 GCODLED(GNBTYPLED) = [M:HAEF]LED(I)
 GPLAN(GNBTYPLED)   = [M:HAEF]COA(I)
Next

For I=0 To len(mess(0,2644,1))-1
 If !find(I+1,GTYPLED(1..GNBTYPLED)) & [M:HAEF]GENC(I)=2
  GNBTYPLED+=1
  GTYPLED(GNBTYPLED) = I+1
  GCODLED(GNBTYPLED) = [M:HAEF]LEDC(I)
  Call INDLED([M:HAEF]LEDC(I),"",IND,J) From CPTDIV
  GPLAN(GNBTYPLED) = GLEDCOA(IND)
 Endif
Next

#-- Pièces d'ànouveau et de clôture sont mono-référentiel
If GFONCTION<>"GESGAS"
 If [L]TYPSAI<>3 and WFLGLOT<>2
  If WPER>1 & GNBTYPLED>1 : STAT = 37 : End : Endif
 Endif
Else

Endif

End

Subprog FMTCCE(MSK,NBRDIE,FMTDIE,DIE)
Value Char MSK()
Value Integer NBRDIE
Value Char FMTDIE()
Value Char DIE()

Assign "[M:HAE"+MSK+"]DIE("+num$(NBRDIE-1)+")" With DIE

Case MSK
 When "1" :
    Case NBRDIE
      When  1 : Chgfmt [M:HAE1]CCE1  With FMTDIE
      When  2 : Chgfmt [M:HAE1]CCE2  With FMTDIE
      When  3 : Chgfmt [M:HAE1]CCE3  With FMTDIE
      When  4 : Chgfmt [M:HAE1]CCE4  With FMTDIE
      When  5 : Chgfmt [M:HAE1]CCE5  With FMTDIE
      When  6 : Chgfmt [M:HAE1]CCE6  With FMTDIE
      When  7 : Chgfmt [M:HAE1]CCE7  With FMTDIE
      When  8 : Chgfmt [M:HAE1]CCE8  With FMTDIE
      When  9 : Chgfmt [M:HAE1]CCE9  With FMTDIE
      When 10 : Chgfmt [M:HAE1]CCE10 With FMTDIE
      When 11 : Chgfmt [M:HAE1]CCE11 With FMTDIE
      When 12 : Chgfmt [M:HAE1]CCE12 With FMTDIE
      When 13 : Chgfmt [M:HAE1]CCE13 With FMTDIE
      When 14 : Chgfmt [M:HAE1]CCE14 With FMTDIE
      When 15 : Chgfmt [M:HAE1]CCE15 With FMTDIE
      When 16 : Chgfmt [M:HAE1]CCE16 With FMTDIE
      When 17 : Chgfmt [M:HAE1]CCE17 With FMTDIE
      When 18 : Chgfmt [M:HAE1]CCE18 With FMTDIE
      When 19 : Chgfmt [M:HAE1]CCE19 With FMTDIE
      When 20 : Chgfmt [M:HAE1]CCE20 With FMTDIE
    Endcase
 When "2" :
    Case NBRDIE
      When  1 : Chgfmt [M:HAE2]CCE1  With FMTDIE
      When  2 : Chgfmt [M:HAE2]CCE2  With FMTDIE
      When  3 : Chgfmt [M:HAE2]CCE3  With FMTDIE
      When  4 : Chgfmt [M:HAE2]CCE4  With FMTDIE
      When  5 : Chgfmt [M:HAE2]CCE5  With FMTDIE
      When  6 : Chgfmt [M:HAE2]CCE6  With FMTDIE
      When  7 : Chgfmt [M:HAE2]CCE7  With FMTDIE
      When  8 : Chgfmt [M:HAE2]CCE8  With FMTDIE
      When  9 : Chgfmt [M:HAE2]CCE9  With FMTDIE
      When 10 : Chgfmt [M:HAE2]CCE10 With FMTDIE
      When 11 : Chgfmt [M:HAE2]CCE11 With FMTDIE
      When 12 : Chgfmt [M:HAE2]CCE12 With FMTDIE
      When 13 : Chgfmt [M:HAE2]CCE13 With FMTDIE
      When 14 : Chgfmt [M:HAE2]CCE14 With FMTDIE
      When 15 : Chgfmt [M:HAE2]CCE15 With FMTDIE
      When 16 : Chgfmt [M:HAE2]CCE16 With FMTDIE
      When 17 : Chgfmt [M:HAE2]CCE17 With FMTDIE
      When 18 : Chgfmt [M:HAE2]CCE18 With FMTDIE
      When 19 : Chgfmt [M:HAE2]CCE19 With FMTDIE
      When 20 : Chgfmt [M:HAE2]CCE20 With FMTDIE
    Endcase
 When "3" :
    Case NBRDIE
      When  1 : Chgfmt [M:HAE3]CCE1  With FMTDIE
      When  2 : Chgfmt [M:HAE3]CCE2  With FMTDIE
      When  3 : Chgfmt [M:HAE3]CCE3  With FMTDIE
      When  4 : Chgfmt [M:HAE3]CCE4  With FMTDIE
