Subprog MSKABR(ZON,MSK)
Value Char    ZON()
Variable Char MSK()
##### BESPR 88747 7/10/13 # Intercompany enhancement
If GFONCTION="GESGIC" : MSK="GIC1" : End : Endif
#####
For K=0 To 2
 If evalue("dim([M:HAE"+num$(K)+"]"+ZON+")>0")
#JASMI - START
#  Case K
#   When 0 : MSK = "HRHAE0"
#   When 1 : MSK = "HRHAE1"
#   When 2 : MSK = "HRHAE2"
#  Endcase
  Case K
   When 0 : MSK = "HAE0"
   When 1 : MSK = "HAE1"
   When 2 : MSK = "HAE2"
  Endcase
#JASMI - END
  Break
 Endif
Next K
End

$DECLARE
# Utilisé par les Tiers...  Structure par rapport au modèle comptable de la Société
Global Integer GNBTYPLED                             : # Nb référentiels <> pour la société
Global Integer GTYPLED(1..10)                        : # Types référentiels géré par la société
Global Char    GCODLED(GLONLED)(1..10)               : # Réfrentiel (LED)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans de compte (COA)

Local Integer NBDIE     : Raz NBDIE # Nb Axes utilisés par la société et triés selon Transaction & Type de Pièce
Local Integer NBDIELED  : Raz NBDIELED
Local Integer NBLED     : Raz NBLED # Nb de référentiels
Local Integer IND,INDLED
Local Integer AUT, TYPREF
Local Integer I,J,K
Local Integer WACCNUM
Local Char    TYPSAC    : # Type du collectif
Local Char ABR          : # Abréviation

Local Integer GEN_NBRLED, GEN_LEDTYP(0..9)
# 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
# Ces fichiers sont uniquement sous le dossier comptable X3
If func TRTHRCPT.ISCPT
   If !clalev([F:GDE])  : Local File =GTABCPT+"GDIAENTRY"  [GDE] : Endif
   If !clalev([F:GTE])  : Local File =GTABCPT+"GTYPACCENT" [GTE] : Endif
   If !clalev([F:FIY])  : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
   If !clalev([F:PER])  : Local File =GTABCPT+"PERIOD"     [PER] : Endif
Endif
If !clalev([F:CPY])  : Local File =GTABCPT+"COMPANY"    [CPY] : Endif
If !clalev([F:FCY])  : Local File =GTABCPT+"FACILITY"   [FCY] : Endif
# 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
# Ces fichiers sont uniquement sous le dossier comptable X3
#  If !clalev([F:GTE])  : Local File =GTABCPT+"GTYPACCENT" [GTE] : Endif
If !clalev([F:GCM])  : Local File =GTABCPT+"GACM"       [GCM] : Endif
If !clalev([F:LED])  : Local File =GTABCPT+"GLED"       [LED] : Endif
If !clalev([F:COA])  : Local File =GTABCPT+"GCOA"       [COA] : Endif
If !clalev([F:DIE])  : Local File =GTABCPT+"GDIE"       [DIE] : Endif
If !clalev([F:ATY])  : Local File =GTABCPT+"ATYPE"      [ATY] : Endif

Return


####################################################################################
# INISTR   : Initialisation structure
####################################################################################
Subprog INISTR
Local Integer MAXLIG : MAXLIG=dim([M]FCYLIN)
Global Integer GNBSTR
Global Integer GSTRTYP(1..MAXLIG)
Global Char    GSTRIDT(5)(1..MAXLIG)
Global Char    GSTRLED(GLONLED)(1..MAXLIG)
Global Char    GSTRCOA(GLONCOA)(1..MAXLIG)
Global Char    GSTRACC(GLONGAC)(1..MAXLIG)
Local Integer I,J,K
Local Integer TYD
Local Char WLED(GLONLED), WCUR(GLONCUR)
TYD=[M:HAEF]NBRLED+1
Raz GNBSTR, GSTRTYP, GSTRIDT, GSTRLED, GSTRCOA, GSTRACC
Gosub SETNOL
Case [M:HAEF]TYPENT
 When 1
  # Saisie en colonne
  If TYD=1 : End : Endif
  For GNBSTR=1 To TYD-1
   GSTRTYP(GNBSTR) = evalue("[M:HAEF]LEDTYP("+num$(GNBSTR-1)+")")
   GSTRIDT(GNBSTR) = "1"
   GSTRLED(GNBSTR) = evalue("[M:HAEF]LED("+num$(GNBSTR-1)+")")
   Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
   GSTRCOA(GNBSTR) = GLEDCOA(I)
   GSTRACC(GNBSTR) = evalue("[M]ACC"+num$(GNBSTR)+"("+num$(NOL)+")")
  Next
 When 2
  # Saisie en ligne
  GNBSTR=1
  For K=0 To [M]NBLIG-1
   If [M]IDTLIN(NOL)=[M]IDTLIN(K)
    GSTRTYP(GNBSTR) = evalue("[M]LEDTYP("+num$(K)+")")
    GSTRIDT(GNBSTR) = evalue("[M]IDTLIN("+num$(K)+")")
    Call LECLED([M]CPY,GSTRTYP(GNBSTR),WLED,WCUR) From CPTDIV
    GSTRLED(GNBSTR) = WLED
    Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
    GSTRCOA(GNBSTR) = GLEDCOA(I)
    GSTRACC(GNBSTR) =  evalue("[M]ACC1("+num$(K)+")")
    GNBSTR+=1
   Endif
  Next
  # dans le cas d'une saisie en cours... [M]NBLIG n'est pas encore incrémenté
  If NOL=[M]NBLIG
#   If [M]IDTLIN(NOL)=[M]IDTLIN([M]NBLIG)
    GSTRTYP(GNBSTR) = evalue("[M]LEDTYP("+num$(NOL)+")")
    GSTRIDT(GNBSTR) = evalue("[M]IDTLIN("+num$(K)+")")
    Call LECLED([M]CPY,GSTRTYP(GNBSTR),WLED,WCUR) From CPTDIV
    GSTRLED(GNBSTR) = WLED
    Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
    GSTRCOA(GNBSTR) = GLEDCOA(I)
    GSTRACC(GNBSTR) =  evalue("[M]ACC1("+num$(NOL)+")")
    GNBSTR+=1
#  Endif
  Endif
Endcase
If GNBSTR>0 : GNBSTR-=1 : Endif

Raz [M]ACCDSP, [M]LEDDSP
For I=1 To GNBSTR
 For J=1 To GNBTYPLED
  If GSTRCOA(I)=GPLAN(J) & GSTRACC(I)<>"" & instr(1,[M]LEDDSP,GCODLED(J)+";")=0
   [M]ACCDSP += GSTRACC(I)  : [M]ACCDSP+=";"
   [M]LEDDSP += GCODLED(J)  : [M]LEDDSP+=";"
  Endif
 Next
Next
If len([M]ACCDSP)>1
 [M]LEDDSP = left$([M]LEDDSP,len([M]LEDDSP)-1)
 [M]ACCDSP = left$([M]ACCDSP,len([M]ACCDSP)-1)
Endif
End


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

# 92876 US2690 table GTYPACCENT de saisie non défini dans HR)
# Ces fichiers sont uniquement sous le dossier comptable X3
$INIT_LOT_PAG_AUZLZD_PER
Local Integer WFLGLOT,WFLGPAG
Local Integer WAUZLED(0..9) #Référentiel autorisé [F:GTE]AUZLED table GTYPACCENT champ AUZLED dim=10 M2647
Local Integer WPER # Période type de pièces [F:GTE]PER M621 1=Normale 2=A nouveaux 3=Clôture
If func TRTHRCPT.ISCPT
  WFLGLOT        = [F:GDE]FLGLOT
  WFLGPAG        = [F:GDE]FLGPAG
  For I=0 To dim([F:GTE]AUZLED)-1
    WAUZLED(I) = [F:GTE]AUZLED(I)
  Next
  WPER=[F:GTE]PER
Else
  WFLGLOT        = 1 # Saisie par lot
  WFLGPAG        = 2 # Flag une page
  WAUZLED(0)     = 3 # Obligatoire
  WAUZLED(1)     = 2 # Autorisé
  WPER           = 1 # Normale
Endif
Return

