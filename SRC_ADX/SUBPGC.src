#<AdxTL>@(#)10.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call OBJET("PGC",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
$ACTION
Case ACTION
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "FILTRE"       : Gosub FILTRE
 When "LIENS2"       : Gosub LIENS2
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "DEBUT_MOD"    : Gosub DEBUT_MOD
 When "INICRE"       : Gosub INICRE
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub SANS_GROUPE
 When "APRES_CRE"    : Gosub SANS_GROUPE
 When "RAZDUP"       : Gosub RAZDUP
 When "CHANGE"       : Gosub CHANGE
 When "VERF_ANU"     : Gosub VERF_ANU

 When "TIROIR"       : Gosub TIROIR
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
 When "PICKE"        : Gosub PICKE
 When "DEPICK"       : Gosub DEPICK
 When "FIN_PICK"     : Gosub FIN_PICK
 When "FIN_ACTION"   : Gosub FIN_ACTION

 When "SEL_TABLE"    : Gosub SEL_TABLE

 When default
Endcase
Return

#########################################################################
$OUVRE_BOITE
If clalev([F:CPG2])=0 : Local File CPYRAMIDG [CPG2] : Endif

Local Integer ILISCCE, ILISPC2
ILISCCE=find("CCE",OBJLIS)-1
ILISPC2=find("PC2",OBJLIS)-1
For I=0 To dim(FILPICK)-1
 FILPICK(I)="1=1"
Next I
Return

#########################################################################
$FILTRE
FILTSUP = "[F:CPG]TYP=2"
Return

#########################################################################
$APRES_CHOI
If find(REPONSE,GSTACRE,GSTAENR) & [M]NBRGRP=0 & [M]NBRCCE>0
 [M]NBRGRP=1
Endif
Return

#########################################################################
$LIENS2
If !GIMPORT : Gosub SANS_GROUPE : Endif
Call LECTURE("PYC",[M]PYR,"") From CONTOBJ
[M]AXE = [F:CPH]AXE
nolign = 0
For [F:CPC]CPC0 Where GRP=[M]GRP
 If nolign>=dim([M]CCE)
  Call ERREUR(mess(26,100,1)) From GESECRAN : Break
 Endif
 [M]CCE(nolign) = [F:CPC]CCE
 If [F:CPC]CCE<>"" & !instr(1,[F:CPC]CCE,"*") & !instr(1,[F:CPC]CCE,"?")
  Read [CCE]CCE0 = [M]AXE;[F:CPC]CCE
  [M]INTCCE(nolign) = [F:CCE]DES
 Endif
 nolign+=1
Next
[M]NBRCCE = nolign
For nolign=1 To [M]NBRGRP
 If [M]SUBGRP(nolign-1)<>""
  Read [CPG2]CPG0(1) = [M]SUBGRP(nolign-1)
  [M]INTGRP(nolign-1) = [F:CPG2]DES
 Endif
Next
Gosub AP_FILGAUCHE
Return

$SANS_GROUPE
If [M]NBRGRP=1 & [M]SUBGRP(0)=""
 [M]NBRGRP=0
Endif
Return

#########################################################################
$DEBUT_MOD
Delete [F:CPC] Where GRP=[M]GRP
If fstat=1 or fstat>5
 GOK=-1 : GLOCK="$CPC"-[M]GRP
 Return
Endif
Return

#########################################################################
$INICRE
[F:CPG]TYP = 2
Return

#########################################################################
$MODIF
For nolign=1 To [M]NBRCCE
 Raz [F:CPC]
 [F:CPC]    = [M]
 [F:CPC]LIN = nolign
 [F:CPC]EXPNUM = [C]EXPORT
 If REP="C" or REP="D"
  [F:CPC]CREDAT = date$
  [F:CPC]CREUSR = GUSER
 Else
  [F:CPC]UPDDAT = date$
  [F:CPC]UPDUSR = GUSER
 Endif
 Write [F:CPC]
 If fstat
  GOK=0 : Call FSTA("CPC") From GLOCK
  Break
 Endif
Next
Return

#########################################################################
$RAZDUP
Effzo [M]20-25
Return

#########################################################################
$CHANGE
For [CPG]CPG2 Where PYR=[F:CHGT]PYR & SUBGRP=OCODE
 [F:CPG]SUBGRP = NCODE
 Rewrite [CPG]
 If fstat
  GOK = 0 : Call FSTA("CPG") From GLOCK : Break
 Endif
Next
Return

#########################################################################
$VERF_ANU
For [CPG]CPG2 Where PYR=[F:ANU_]PYR & SUBGRP=CODE
 OK = 0
 If !GSERVEUR
  ERR = 1
  Call ERREUR(mess(22,115,1)-"CPYRAMIDG"+"\"+mess(55,123,1)-":"-[F:CPG]GRP+"\"+mess(1,115,1)) From GESECRAN
 # Clé présente sur le fichier
 Else
  GMESSAGE = mess(22,115,1)-"CPYRAMIDG"+"\"+mess(55,123,1)-":"-[F:CPG]GRP+"\"+mess(1,115,1)
 Endif
 Break
Next
Return

#########################################################################
$SEL_TABLE
Case TABLE
 When "PGCGRP"
  START = "GRP"
  OBJET = "PGC"
  CRITERE = "[F:CPG]PYR=[M]PYR & [F:CPG]GRP<>[M]GRP"
Endcase
Return

###############################################################################
############## GESTION des TITOIRS ############################################
###############################################################################
## $TIROIR       : remplissage du tiroir
## $FILGAUCHE    : Filtre pour les tiroirs
## $AP_FILGAUCHE : Rafraichissement des tiroirs
## $GAUCHE       : Contrôle sur le tiroir
## $PICKE        : Pick les éléments des tiroirs
## $DEPICK       : Depick les éléments des tiroirs
## $FIN_PICK     : Rafraichissement du tableau de saisie
## $FIN_ACTION 
###############################################################################
$TIROIR
Case currbox   
    When "GAU_CHE"+num$(ILISCCE)  : # Tiroir Sections
        ILIS=val(right$(currbox,8))
        Gosub REMP_LISGAU From GOBJSUB
    When "GAU_CHE"+num$(ILISPC2)  :  # Tiroir Groupes
        ILIS=val(right$(currbox,8))
        Gosub REMP_LISGAU From GOBJSUB
Endcase
Return

###############################################################################
$AP_FILGAUCHE
Case currbox
    
    When "GAU_CHE"+num$(ILISCCE)  : # Tiroir Sections
        If [M]NBRCCE>0
            For I=0 To [M]NBRCCE-1
                If [M]CCE(I)<>""
                    Read [CC1_]CCE0 =[M]AXE;[M]CCE(I)
                    If !fstat : Gosub REPICK From GOBJSUB
                    Else        Gosub DEPICK From GOBJSUB
                    Endif
                Endif
            Next I
        Endif

    When "GAU_CHE"+num$(ILISPC2)  :  # Tiroir Groupes
        If [M]NBRGRP>0
            For I=0 To [M]NBRGRP-1
                If [M]SUBGRP(I)<>""
                    Read [PC1_]CPG0(1) = [M]SUBGRP(I)
                    If !fstat : Gosub REPICK From GOBJSUB
                    Else        Gosub DEPICK From GOBJSUB
                    Endif
                Endif
            Next I
        Endif
Endcase
Read [CPG]CPG0(1) = [M]GRP
Return

#########################################################################
$FILGAUCHE
If ILIS
    Case ILIS
      When ILISCCE   : # Picking Sections analytiques
            FILGAUSUP = "AXI="+num$([M]AXE)
      When ILISPC2   : # Picking Groupes Sections analytiques
            FILGAUSUP = 'TYP=2 & PYR="'+[M]PYR+'" & GRP<>"'+[M]GRP+'" & LEV>'+num$([M]LEV)+'& LIN=1'
    Endcase
Endif
Return

#########################################################################
$PICKE
Case currbox

    When "GAU_CHE"+num$(ILISCCE)  :                 # Tiroir Sections
        If [M]NBRCCE<dim([M]CCE)
            OK = 0
            Case REP
                When "C","M","D" :  OK = 1
                When ""          :  If CLECUR & VERROU & ACTMOD & !GCONSULT : OK = 1 :  Endif
            Endcase
            If OK
                mkstat = 0
                nolign = [M]NBRCCE+1
                Read [CC1_]CCE0 = [F:CC1_]AXI;[F:CC1_]CCE
                Call C_CCE([F:CC1_]CCE)
                If mkstat : OK = 0 : Endif
           Endif
           If OK
                [M]CCE([M]NBRCCE)    = [F:CC1_]CCE
                [M]INTCCE([M]NBRCCE) = [F:CC1_]DES
                [M]NBRCCE += 1
                Affzo CCE(nolign-1),INTCCE(nolign-1)
                If REP="" : Gosub ENTRE_MODIF From GOBJSUB : Endif
           Endif
        Endif

    When "GAU_CHE"+num$(ILISPC2)  :                     # Tiroir Groupes
        If [M]NBRGRP<dim([M]SUBGRP)
           OK = 0
           Case REP
             When "C","M","D" : OK = 1
             When ""          : If CLECUR & VERROU & ACTMOD & !GCONSULT : OK = 1 : Endif
           Endcase
           If OK
                mkstat = 0
                nolign = [M]NBRGRP+1
                Read [PC1_]CPG0 = [F:PC1_]GRP;[F:PC1_]LIN
                Call C_SUBGRP([F:PC1_]GRP)
                If mkstat : OK = 0 : Endif
           Endif
           If OK
              [M]SUBGRP([M]NBRGRP)   = [F:PC1_]GRP
              [M]INTGRP([M]NBRGRP)   = [F:PC1_]DES
              [M]NBRGRP += 1
              Affzo SUBGRP(nolign-1),INTGRP(nolign-1)
              If REP=""  : Gosub ENTRE_MODIF From GOBJSUB  : Endif
           Endif
        Endif
Endcase
Return

#########################################################################
$DEPICK
Case currbox
    When "GAU_CHE"+num$(ILISCCE)  :                 # Tiroir Sections
          Read [CC1_]CCE0 = [F:CC1_]AXI;[F:CC1_]CCE
          For I=[M]NBRCCE-1 To 0 Step -1
            If [M]CCE(I)=[F:CC1_]CCE
                K=I+1 
                If K   : # Echéance en ligne K 
                    nolign=K : status=65
                    Dela K-1 [M]NBRCCE
                    [M]NBRCCE-=1 : OK=1
                Endif
            Endif
          Next I

    When "GAU_CHE"+num$(ILISPC2)  :                 # Tiroir Groupes
          Read [PC1_]CPG0 = [F:PC1_]GRP;[F:PC1_]LIN
          For I=[M]NBRGRP-1 To 0 Step -1
            If [M]SUBGRP(I)=[F:PC1_]GRP
                K=I+1 
                If K   : # Echéance en ligne K 
                    nolign=K : status=65
                    Dela K-1 [M]NBRGRP
                    [M]NBRGRP-=1 : OK=1
                Endif
            Endif
          Next I

Endcase
Return

#########################################################################
$FIN_PICK
Affzo [PGC]20-25
Return

###############################################################################
$FIN_ACTION
If find(currbox,"GAU_CHE"+num$(ILISCCE),"GAU_CHE"+num$(ILISPC2))
    Case REPONSE
        When GSTAFIN : Gosub TIROIR
        When GSTASUI,GSTAPRE,GSTAFIR,GSTALAS : Gosub TIROIR 
    Endcase
Endif
Return

####################################################################################
## Etiquettes du masque PGC
####################################################################################
Subprog AS_PYR(VALEUR)
Variable Char     VALEUR
# Modification pyramide impossible si
#  - le groupe contient des sous-groupes
#  - le groupe est lui-même sous-groupe
If clalev([F:CPG2])=0 : Local File CPYRAMIDG [CPG2] : Endif
If [M]GRP<>""
 If [M]NBRGRP>0 : mkstat=2 : End : Endif
 Read [F:CPG2]CPG2=VALEUR;[M]GRP
 If fstat=0 : mkstat=2 : End : Endif
Endif
End

Subprog AM_PYR(VALEUR)
Variable Char     VALEUR
# La nouvelle pyramide doit être du même axe si sections
If [M]NBRCCE>0 & [F:CPH]AXE<>[M]AXE 
 mkstat=1 : End
Endif 
[M]AXE = [F:CPH]AXE : Affzo [M]AXE
End

Subprog C_SUBGRP(VALEUR)
Variable Char     VALEUR
If clalev([F:CPG2])=0 : Local File CPYRAMIDG [CPG2] : Endif
If VALEUR=[M]GRP : mkstat=1 : End : Endif
If VALEUR=""
 If nolign<>1
  GMESSAGE = mess(10,123,1) : mkstat = 2 : # Zone obligatoire
 Endif
 End
Endif
Read [F:CPG2]CPG0(1)=VALEUR
If fstat
 GMESSAGE = mess(23,100,1) :# Fiche inexistante
 mkstat=1 : End
Else
 [M]INTGRP(nolign-1) = [F:CPG2]DES
Endif
If [F:CPG2]TYP=1
 GMESSAGE = mess(27,113,1) :# Groupe nature
 mkstat=1 : End
Endif
If [F:CPG2]PYR<>[M]PYR
 GMESSAGE = mess(29,113,1)-[F:CPG2]PYR :# Pyramide section
 mkstat=1 : End
Endif
# Le sous-goupe doit être d'un niveau supérieur
If [F:CPG2]LEV<=[M]LEV
 GMESSAGE = mess(31,113,1)-num$([F:CPG2]LEV) :# Groupe de niveau
 mkstat=1 : End
Endif
Call UNICITE(VALEUR,[M]SUBGRP(0..[M]NBRGRP-1)) From OBJDIV
If mkstat : End : Endif
# Le sous-groupe ne doit pas déjà avoir été regroupé dans un groupe
Read [F:CPG2]CPG2=[M]PYR;VALEUR
If fstat=0 & [F:CPG2]GRP<>[M]GRP
 GMESSAGE = VALEUR-mess(32,113,1)-[F:CPG2]GRP :# regroupé dans
 mkstat=1 : End
Endif
End

Subprog C_CCE(VALEUR)
Variable Char     VALEUR
Local Integer AXE : AXE = [M]AXE
If VALEUR<>""
 VALEUR = toupper(VALEUR)
 Gosub SETCCE
 If len(CCE)=len(VALEUR)
  Call CONTROLE("CCE","",CCE,num$(AXE),mkstat) From CONTOBJ
  If !mkstat : Gosub VERIF : Else : End : Endif
  If mkstat : End : Endif
  Call CONTEXE([F:CCE]ACS) From CPTSUB
  If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
  If !mkstat : VALEUR=CCE : Endif
 Else
  For [F:CCE]CCE0 Where AXI=AXE & pat([F:CCE]CCE,VALEUR)
   CCE = [F:CCE]CCE : Gosub VERIF
   If mkstat : Break : Endif
  Next
  If !mkstat : VALEUR = toupper(VALEUR) : Endif
 Endif
Endif
Call UNICITE(VALEUR,[M]CCE(0..[M]NBRCCE-1)) From OBJDIV
If !mkstat
 Read [CCE]CCE0 = [M]AXE;VALEUR
 If !fstat
      [M]INTCCE(nolign-1) = [F:CCE]DES
 Else Raz [M]INTCCE(nolign-1)
 Endif   
Endif
End

$SETCCE
Local Char CCE(GLONCCE)
Local Integer I, L, JOK
JOK = 0
For I=1 To len(VALEUR)
 If instr(1,"!#?*",mid$(VALEUR,I,1)) : JOK = 1 : Break: Else L+=1 : Endif
Next I
CCE=toupper(left$(VALEUR,L))
Return

$VERIF
Call UNICITE(VALEUR,[M]CCE(0..[M]NBRCCE-1)) From OBJDIV
If mkstat : End : Endif
# Contrôle que la section saisie n'a pas déjà été saisie dans un autre groupe 
# de la même pyramide
For [F:CPC]CPC1 Where PYR=[M]PYR & GRP<>[M]GRP
 If pat(CCE,[F:CPC]CCE)
  GMESSAGE = CCE-mess(32,113,1)-[F:CPC]GRP :# Regroupé dans
  mkstat=1 : Break
 Endif
Next
Return


Subprog C_LEV(VALEUR)
Variable Decimal  VALEUR
If VALEUR>=99 : mkstat=1 : End : Endif
End

Subprog AM_LEV(VALEUR)
Variable Decimal  VALEUR
# Le groupe ne doit pas être inclus dans un groupe de niveau supérieur
# ou égal.
If clalev([F:CPG2])=0 : Local File CPYRAMIDG [CPG2] : Endif
Read [F:CPG2]CPG2=[M]PYR;[M]GRP
If fstat=0 & [F:CPG2]LEV>=VALEUR
 # regroupé dans
 # Groupe de niveau
 Call ERREUR([M]GRP-mess(32,113,1)-[F:CPG2]GRP-":"-mess(31,113,1)-num$([F:CPG2]LEV)) From GESECRAN
 mkstat=2 : End
Endif
# Les sous-groupes ne doivent pas être de niveau inférieur ou égal.
For I=0 To [M]NBRGRP-1
 Read [F:CPG2]CPG0(1)=[M]SUBGRP(I)
 If [F:CPG2]LEV<=VALEUR
  # Groupe de niveau
  Call ERREUR([M]SUBGRP(I)-":"-mess(31,113,1)-num$([F:CPG2]LEV)) From GESECRAN
  mkstat=2 : Break
 Endif
Next
If mkstat : End : Endif
End
