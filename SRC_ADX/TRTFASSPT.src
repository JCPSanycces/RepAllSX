#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT"   : Gosub INIT
    When Default
  Endcase
Return

$INIT
Return


$ACTMET
  Case ACTMET
    When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
    When Default
  Endcase
Return

#========================================================================#
$CRITMEN
 # Autorisé si l'on est en mode visualisation
 # CRITMEN=' REP="" '

 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option
 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'W') ) Then
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif
Return


