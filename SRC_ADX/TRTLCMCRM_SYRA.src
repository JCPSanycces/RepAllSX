#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Gestion de la table LASTCUSMVT pour les informations de la CRM
##########################################################################################################
#
##########################################################################################################
Subprog LCM_MAJINFO(SZBPCNUM, IIFTYP, SZCPY, IMVTTYP, DTMVTDAT, SZVCRNUM, SZFCY, SZCUR, MTAMT, SMESSAGE, IERROR)
Value Char SZBPCNUM
Value Integer IIFTYP
Value Char SZCPY
Value Integer IMVTTYP
Value Date DTMVTDAT
Value Char SZVCRNUM
Value Char SZFCY
Value Char SZCUR
Value Decimal MTAMT
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer ITRAIT
Local Integer IBDEBTRANSFLG

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  If SZBPCNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File LASTCUSMVT [LCM]
  # ------------------------------------
  ITRAIT = 0
  Read [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY
  If fstat = 0 Then
    # L'enregistrement existe : On ne contrôle rien. C'est le travaille de l'appelant. Ici on enregistre ce qu'on nous dit
    If [F:LCM]MVTTYP = IMVTTYP and [F:LCM]MVTDAT = DTMVTDAT and [F:LCM]VCRNUM = SZVCRNUM and [F:LCM]CUR = SZCUR and [F:LCM]AMT = MTAMT Then
      ITRAIT = 0   # ... Sauf que là tout est pareil, on gagne du temps, on fait rien
    Else
      ITRAIT = 1   # Il faut remplacer
    Endif
  Else
    ITRAIT = 2     # Il faut créer
  Endif
  # ------------------------------------
  If ITRAIT = 0 Then
    End
  Endif
  # ------------------------------------
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  # ------------------------------------
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  # ------------------------------------
  If ITRAIT = 1 Then
    Readlock [LCM]LCM0=SZBPCNUM;IIFTYP;SZCPY
    If fstat <> 0 Then
      SMESSAGE = mess(439,177,1)
      IERROR = [V]CST_AYES
      End
    Endif
  Elsif ITRAIT = 2 Then
    Raz [F:LCM]
    [F:LCM]BPCNUM = SZBPCNUM
    [F:LCM]IFFTYP = IIFTYP
    [F:LCM]CPY = SZCPY
    [F:LCM]IFFFCY = SZFCY
  Endif
  [F:LCM]IFFFCY = SZFCY
  [F:LCM]MVTTYP = IMVTTYP
  [F:LCM]MVTDAT = DTMVTDAT
  [F:LCM]VCRNUM = SZVCRNUM
  [F:LCM]CUR = SZCUR
  [F:LCM]AMT = MTAMT
  If ITRAIT = 2 Then
    Write [LCM]
    If fstat <> 0 Then
      SMESSAGE = mess(440,177,1)
      IERROR = [V]CST_AYES
    Endif
  Else
    Rewrite [LCM]
    If fstat <> 0 Then
      SMESSAGE = mess(441,177,1)
      IERROR = [V]CST_AYES
    Endif
  Endif
  # ------------------------------------
  If IBDEBTRANSFLG = 0 Then
    If IERROR = [V]CST_AYES Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
#On a une donnée qui a été supprimé, on supprime de LCM
##########################################################################################################
Subprog LCM_DELINFO(SZBPCNUM, IIFTYP, SZCPY, SZFCY, IBSUPR, SMESSAGE, IERROR)
Value Char SZBPCNUM
Value Integer IIFTYP
Value Char SZCPY
Value Char SZFCY
Variable Integer IBSUPR
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBDEBTRANSFLG

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  IBSUPR = [V]CST_AFALSE
  # ------------------------------------
  If SZBPCNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File LASTCUSMVT [LCM]
  # ------------------------------------
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  # ------------------------------------
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  # ------------------------------------
  Delete [LCM] Where [F:LCM]BPCNUM = SZBPCNUM and [F:LCM]IFFTYP = IIFTYP and [F:LCM]CPY = SZCPY
  If !fstat Then
    If adxdlrec > 0 Then
      # la suppression a eu lieu
      IBSUPR = [V]CST_ATRUE
    Endif
  Else
    SMESSAGE = mess(443,177,1)
    IERROR = [V]CST_AYES
  Endif
  # ------------------------------------
  If IBDEBTRANSFLG = 0 Then
    If IERROR = [V]CST_AYES Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

###############################################################################################
# On a une donnée qui a été supprimé, on supprime de LCM
###############################################################################################
Subprog LCM_DELKEY(IMVTTYP, SZVCRNUM, IBSUPR, SMESSAGE, IERROR)
Value Integer IMVTTYP
Value Char SZVCRNUM
Variable Integer IBSUPR
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBDEBTRANSFLG

  # ------------------------------------
  # Note : Pas la peine de passer le site.
  # ====   On détruit un mouvement par l'identifiant de la pièce.
  #        Pas le tiers.
  #        Il pourrait donc y avoir deux lignes supprimées : une au niveau site, une au niveau société.
  # ------------------------------------
  Raz SMESSAGE
  IERROR = [V]CST_ANO
  IBSUPR = [V]CST_AFALSE
  # ------------------------------------
  Local File LASTCUSMVT [LCM]
  # ------------------------------------
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [LCM]
  Endif
  # ------------------------------------
  Delete [LCM] Where [F:LCM]MVTTYP = IMVTTYP  and [F:LCM]VCRNUM = SZVCRNUM
  If !fstat Then
    If adxdlrec > 0 Then
      #la suppression a eu lieu
      IBSUPR = [V]CST_ATRUE
    Endif
  Else
    SMESSAGE = mess(443,177,1)
    IERROR = [V]CST_AYES
  Endif
  If IBDEBTRANSFLG = 0 Then
    If IERROR = [V]CST_AYES Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
##########################################################################################################
#traitement de information premier contact pour un client et une société donnée
##########################################################################################################
Subprog LCM_BPRFIRSTCNT(SZBPRNUM, SZCPY, SZFCY, SMESSAGE, IERROR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBSUPR
Local Integer IIMVTTYP
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)
Local Char SZSITE(GLONFCY)
Local Char SZFCYTSK(GLONFCY)
Local Char SZFCYCLL(GLONFCY)
Local Char SZFCYBAP(GLONFCY)

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  # ------------------------------------
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File FACILITY [FCY]
  Local File TASK [TSK]
  Local File PHONECALL [CLL]
  Local File BAPPOINT [BAP]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [TSK] With [FCY]FCY0=[F:TSK]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK]TSKDON=2 and [F:TSK]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK]TSKSTR
  For [TSKF]
    DTTSK = [F:TSK]TSKSTR
    SZKEYTSK = [F:TSK]TSKNUM
    SZFCYTSK = [F:TSK]SALFCY
    DTDATE = DTTSK
    Break
  Next
  Filter [TSKF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [CLL] With [FCY]FCY0=[F:CLL]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL]CLLDON=2 and [F:CLL]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL]CLLDATX Asc; [F:CLL]CLLHOU Asc
  For [CLLF]
    DTCLL = [F:CLL]CLLDATX
    SZKEYCLL = [F:CLL]CLLNUM
    SZFCYCLL = [F:CLL]SALFCY
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTCLL < DTDATE) Then
      DTDATE = DTCLL
    Endif
    Break
  Next
  Filter [CLLF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [BAP] With [FCY]FCY0=[F:BAP]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP]APTDON=2 and [F:BAP]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  For [BAPF]
    DTBAP = [F:BAP]APTDATX
    SZKEYBAP = [F:BAP]APTNUM
    SZFCYBAP = [F:BAP]SALFCY
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTBAP < DTDATE) Then
      DTDATE = DTBAP
    Endif
    Break
  Next
  Filter [BAPF]
  # ------------------------------------
  # Note le min(DTTSK,DTCLL,DTBAP) ne fonctionne pas. Si une des date vaut [0/0/0] alors le min aussi et on va dans le Else !
  If DTDATE <> [00/00/00] Then
    If DTDATE = DTCLL Then
      SZKEY = SZKEYCLL
      SZSITE = SZFCYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        SZSITE = SZFCYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        SZSITE = SZFCYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO(SZBPRNUM, 1, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZSITE, "", 0, SMESSAGE, IERROR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 1, SZCPY, SZFCY, IBSUPR, SMESSAGE, IERROR)
  Endif
End

##########################################################################################################
#traitement de information dernier contact pour un client et une société donnée
##########################################################################################################
Subprog LCM_BPRLASTCNT(SZBPRNUM, SZCPY, SZFCY, SMESSAGE, IERROR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBSUPR
Local Integer IIMVTTYP
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)
Local Char SZSITE(GLONFCY)
Local Char SZFCYTSK(GLONFCY)
Local Char SZFCYCLL(GLONFCY)
Local Char SZFCYBAP(GLONFCY)

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  # ------------------------------------
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File FACILITY [FCY]
  Local File TASK [TSK]
  Local File PHONECALL [CLL]
  Local File BAPPOINT [BAP]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [TSK] With [FCY]FCY0=[F:TSK]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK]TSKDON=2 and [F:TSK]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK]TSKDAT Desc
  For [TSKF]
    DTTSK = [F:TSK]TSKDAT
    SZKEYTSK = [F:TSK]TSKNUM
    SZFCYTSK = [F:TSK]SALFCY
    Break
  Next
  Filter [TSKF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [CLL] With [FCY]FCY0=[F:CLL]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL]CLLDON=2 and [F:CLL]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL]CLLDATX Desc;[F:CLL]CLLHOU Desc
  For [CLLF]
    DTCLL = [F:CLL]CLLDATX
    SZKEYCLL = [F:CLL]CLLNUM
    SZFCYCLL = [F:CLL]SALFCY
    Break
  Next
  Filter [CLLF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [BAP] With [FCY]FCY0=[F:BAP]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP]APTDON=2 and [F:BAP]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP]APTDATX Desc; [F:BAP]APTHOU Desc
  For [BAPF]
    DTBAP = [F:BAP]APTDATX
    SZKEYBAP = [F:BAP]APTNUM
    SZFCYBAP = [F:BAP]SALFCY
    Break
  Next
  Filter [BAPF]
  # ------------------------------------
  DTDATE = max(DTTSK,DTCLL,DTBAP)
  If DTDATE <> [00/00/00] Then
    If DTDATE = DTCLL Then
      SZKEY = SZKEYCLL
      SZSITE = SZFCYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        SZSITE = SZFCYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        SZSITE = SZFCYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO (SZBPRNUM, 2, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZSITE, "", 0, SMESSAGE, IERROR)
  Else
    Call LCM_DELINFO (SZBPRNUM, 2, SZCPY, SZFCY, IBSUPR, SMESSAGE, IERROR)
  Endif
End

##########################################################################################################
#traitement de information prochain contact pour un client et une société donnée
##########################################################################################################
Subprog LCM_BPRNEXTCNT(SZBPRNUM, SZCPY, SZFCY, SMESSAGE, IERROR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBSUPR
Local Date DTTSK
Local Char SZKEYTSK(GLONVCR)
Local Date DTCLL
Local Char SZKEYCLL(GLONVCR)
Local Date DTBAP
Local Char SZKEYBAP(GLONVCR)
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZWHERE(250)
Local Char SZSITE(GLONFCY)
Local Char SZFCYTSK(GLONFCY)
Local Char SZFCYCLL(GLONFCY)
Local Char SZFCYBAP(GLONFCY)

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  IIMVTTYP = 0
  DTTSK = [00/00/00]
  Raz SZKEYTSK
  DTCLL = [00/00/00]
  Raz SZKEYCLL
  DTBAP = [00/00/00]
  Raz SZKEYBAP
  DTDATE = [00/00/00]
  Raz SZKEY
  # ------------------------------------
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File FACILITY [FCY]
  Local File TASK [TSK]
  Local File PHONECALL [CLL]
  Local File BAPPOINT [BAP]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [TSK] With [FCY]FCY0=[F:TSK]SALFCY As [TSKF] Where evalue(SZWHERE) and [F:TSK]TSKDON=1 and [F:TSK]TSKCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [TSKF] Order By [F:TSK]TSKSTR Asc
  For [TSKF]
    DTTSK = [F:TSK]TSKSTR
    SZKEYTSK = [F:TSK]TSKNUM
    SZFCYTSK = [F:TSK]SALFCY
    DTDATE = DTTSK
    Break
  Next
  Filter [TSKF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [CLL] With [FCY]FCY0=[F:CLL]SALFCY As [CLLF] Where evalue(SZWHERE) and [F:CLL]CLLDON=1 and [F:CLL]CLLCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [CLLF] Order By [F:CLL]CLLDATX Asc;[F:CLL]CLLHOU Asc
  For [CLLF]
    DTCLL = [F:CLL]CLLDATX
    SZKEYCLL = [F:CLL]CLLNUM
    SZFCYCLL = [F:CLL]SALFCY
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTCLL < DTDATE) Then
      DTDATE = DTCLL
    Endif
    Break
  Next
  Filter [CLLF]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [BAP] With [FCY]FCY0=[F:BAP]SALFCY As [BAPF] Where evalue(SZWHERE) and [F:BAP]APTDON=1 and [F:BAP]APTCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  Filter [BAPF] Order By [F:BAP]APTDATX Asc; [F:BAP]APTHOU Asc
  For [BAPF]
    DTBAP = [F:BAP]APTDATX
    SZKEYBAP = [F:BAP]APTNUM
    SZFCYBAP = [F:BAP]SALFCY
    If DTDATE = [00/00/00] or (DTDATE <> [00/00/00] and DTBAP < DTDATE) Then
      DTDATE = DTBAP
    Endif
    Break
  Next
  Filter [BAPF]
  # ------------------------------------
  # Note le min(DTTSK,DTCLL,DTBAP) ne fonctionne pas. Si une des date vaut [0/0/0] alors le min aussi et on va dans le Else !
  If DTDATE <> [00/00/00] Then
    If DTDATE = DTCLL Then
      SZKEY = SZKEYCLL
      SZSITE = SZFCYCLL
      IIMVTTYP = 14
    Else
      If DTDATE = DTTSK Then
        SZKEY = SZKEYTSK
        SZSITE = SZFCYTSK
        IIMVTTYP = 13
      Else
        SZKEY = SZKEYBAP
        SZSITE = SZFCYBAP
        IIMVTTYP = 15
      Endif
    Endif
    Call LCM_MAJINFO(SZBPRNUM, 3, SZCPY, IIMVTTYP, DTDATE, SZKEY, SZSITE, "", 0, SMESSAGE, IERROR)
  Else
    Call LCM_DELINFO(SZBPRNUM, 3, SZCPY, SZFCY, IBSUPR, SMESSAGE, IERROR)
  Endif
End

##########################################################################################################
#traitement de la dernière affaire pour un client et une société donnée
##########################################################################################################
Subprog LCM_BPRLASTOPP(SZBPRNUM, SZCPY, SZFCY, SMESSAGE, IERROR)
Value Char SZBPRNUM
Value Char SZCPY
Value Char SZFCY
Variable Char SMESSAGE
Variable Integer IERROR

Local Integer IBSUPR
Local Integer IIMVTTYP
Local Date DTDATE
Local Char SZKEY(GLONVCR)
Local Char SZCUR(GLONCUR)
Local Decimal MTAMT
Local Char SZWHERE(250)

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  # ------------------------------------
  IBSUPR = 0
  IIMVTTYP = 0
  DTDATE = [00/00/00]
  Raz SZKEY
  Raz SZCUR
  MTAMT = 0
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------
  If SZCPY = "" and SZFCY <> "" Then
    SZCPY = func CRMUTIL150_SYRA.GET_CPY_FROM_FCY(SZFCY)
  Endif
  # ------------------------------------
  If SZCPY = "" Then
    End
  Endif
  # ------------------------------------
  Local File FACILITY [FCY]
  Local File OPPOR [OPP]
  Local File OPPORCRM [OPPCRM]
  # ------------------------------------
  SZWHERE = "1=1"
  Link [OPP] With [FCY]FCY0=[F:OPP]SALFCY,
&                 [OPPCRM]OPPCRM0~=[F:OPP]OPPNUM
&              As [OPPF]
&              Where evalue(SZWHERE) and [F:OPP]OPPCMP=SZBPRNUM and [F:FCY]LEGCPY=SZCPY
  # ------------------------------------
  Filter [OPPF] Order By [F:OPPCRM]OPPREACDA Desc
  For [OPPF]
    DTDATE = [F:OPP]OPPDATOPN
    SZKEY = [F:OPP]OPPNUM
    SZCUR = [F:OPP]CUR
    MTAMT = [F:OPPCRM]OPPAMT
    Break
  Next
  Filter [OPPF]
  # ------------------------------------
  IIMVTTYP = 9
  If DTDATE <> [00/00/00] Then
    Call LCM_MAJINFO(SZBPRNUM, 13, SZCPY, IIMVTTYP, DTDATE, SZKEY, [F:OPP]SALFCY, SZCUR, MTAMT, SMESSAGE, IERROR)
  Else
    Call LCM_DELINFO(SZBPRNUM, 13, SZCPY, SZFCY, IBSUPR, SMESSAGE, IERROR)
  Endif
End

