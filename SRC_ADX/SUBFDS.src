#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet FDS
Raz GPILOBJ
Call OBJET("FDS",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "LIENS" : Gosub LIENS
Endcase
Return

$LIENS
If [M]TYPITT=1
 Grizo [M]RAT
Else
 Actzo [M]RAT
Endif
Return

######################################################################################

Subprog AM_TYPITT(VALEUR)
Variable Integer  VALEUR
If VALEUR=1
 Raz [M]RAT
 Grizo [M]RAT
Else
 Actzo [M]RAT
Endif
End
