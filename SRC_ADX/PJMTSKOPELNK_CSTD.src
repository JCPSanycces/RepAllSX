#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTSKOPELNK
# Issue X3-28737/X3-26991 - 2017-07-31 by FGR/TEJAC
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "ACONTROL"                  : Gosub ACONTROL                        From PJMTSKOPELNK_CSTD_EVENTS
      When "ADELETE_CONTROL_BEFORE"    : Gosub ADELETE_CONTROL_BEFORE          From PJMTSKOPELNK_CSTD_EVENTS
    Endcase
Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                     : Gosub SETERROR                        From PJMTSKOPELNK_CSTD_METHODS
    When "COPY"                         : Gosub COPY                            From PJMTSKOPELNK_CSTD_METHODS    # Issue X3-27611 - 2017-11-27 by FGR
    When "COPY_LOAD_PROPERTIES"         : Gosub COPY_LOAD_PROPERTIES            From PJMTSKOPELNK_CSTD_METHODS    # Issue X3-27611 - 2017-11-27 by FGR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "OPESPNUMLNK"                 : Gosub OPESPNUMLNK                   From PJMTSKOPELNK_CSTD_PROPERTIES
    When "OPELNKTYP"                   : Gosub OPELNKTYP                     From PJMTSKOPELNK_CSTD_PROPERTIES
    When "OPELNKCSTR"                  : Gosub OPELNKCSTR                    From PJMTSKOPELNK_CSTD_PROPERTIES
  Endcase
Return

