#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## ESSWRKCHD
# 2018-10-23 06:53:15 526


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(ESSWRKCHD,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Variable Integer ASTATUS

If ESSWRKCHD = null : End : Endif

Gosub _AVARIABLES From WMC00ESSWRKCHD

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_ESSWRKCHD

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(ESSWRKCHD,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Variable Integer ASTATUS

If ESSWRKCHD = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_ESSWRKCHD
Else
 Gosub ADELETE_ESSWRKCHD
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(ESSWRKCHD,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If ESSWRKCHD.ASTALIN = [V]CST_ANEWDEL : Return : Endif
ESSWRKCHD.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_ESSWRKCHD
Trbegin [F:EWCHD]
 Gosub ADELETE_ESSWRKCHD
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_ESSWRKCHD
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(ESSWRKCHD,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00ESSWRKCHD._MAJSQL_ESSWRKCHD(ESSWRKCHD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If ESSWRKCHD.snapshotEnabled=1
 [L]A_RETIK = ESSWRKCHD.revertUpdTick
Endif
[L]ASTATUS = max(fmet ESSWRKCHD.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



