#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Time entry validation
# Issue X3-85280 - 2018-04-20 by TEJAC/FGR
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FERME"        : Gosub FERME
    When "ABA"          : Gosub ABANDON
    When "SETBOUT"      : Gosub SETBOUT
    When "BOUTON"       : Gosub BOUTON
    When "ENR"          : Gosub ENR
  Endcase
Return

###################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
$DEBUT
  [M:PJT0]PTESTA = 2
  Affzo [M:PJT0]1-99
Return

###################################################################################################
$SETBOUT
  If [M:PJT1]NBLIG = 0 Then
    Call VIREBOUT(CHMEN,"2") From GOBJET
    Call VIREBOUT(CHMEN,"3") From GOBJET
    Call VIREBOUT(CHMEN,"4") From GOBJET
    Call VIREBOUT(CHMEN,"5") From GOBJET
    Call VIREBOUT(CHMEN,"6") From GOBJET
  Else
    # Disable SEARCH when grids loaded
    Call VIREBOUT(CHMEN,"1") From GOBJET
  Endif
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "1"       : Gosub SEARCH
    When "2"       : Gosub SELECT_ALL
    When "3"       : Gosub DESELECT_ALL
    When "4"       : Gosub VALIDATED
    When "5"       : Gosub CONTROLED
    When "6"       : Gosub APPROVED
  Endcase
Return

###################################################################################################
$ABANDON
  REP = AVOID.ACHAR
  GREP = REP
  Call RAZ_GRID_1_2()
Return

###################################################################################################
$FERME
  Raz [M:PJT0]
  Raz [M:PJT1]
  Raz [M:PJT2]
Return

###################################################################################################
$ENR
  GOK = 1
  Call SAVE_DECISION()
  If GOK > 0 Then
    Call RAZ_GRID_1_2()
    REP = AVOID.ACHAR
    GREP = REP
  Endif
Return

###################################################################################################
# Screens fields
###################################################################################################
# PJT0
###################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local File FACILITY [FCY]
  # -----------------------
  If VALEUR <> AVOID.ACHAR Then
    Read [FCY]FCY0=VALEUR
    If [F:FCY]LEGCPY <> [M:PJT0]CPY Then
      GMESSAGE = func AFNC.MES2(mess(1069,2260,1), VALEUR, [M:PJT0]CPY)
      mkstat = 2
      End
    Endif
  Endif
End

###################################################################################################
Subprog AM_CLB(VALEUR)
Variable Char    VALEUR()

  [M:PJT0]PTENAM = func OPPOR_CSTD_OUTTOOLS.GET_AUS_INTUSR(GACTX, VALEUR)
End

###################################################################################################
Subprog C_TEDATE(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [0/0/0] and VALEUR < [M:PJT0]TSDATE and [M:PJT0]TSDATE <> [0/0/0] Then
    GMESSAGE = func AFNC.MES1(mess(30,2260,1), format$(GFMDAT,[M:PJT0]TEDATE))
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog AS_PTESTA(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
  GMENLOC(5) = 1
End

###################################################################################################
# PJT1
###################################################################################################
Subprog AV_NBLIG

  # Issue X3-85289 - 2018-05-24 by SINGC
  If [M:PJT3]SEARCH <> [V]CST_AYES and [M:PJT1]CLB(nolign-1) <> AVOID.ACHAR and [M:PJT1]PTESEQ(nolign-1) > 0 Then
    Call LOAD_PTEVAL3([M:PJT1]CLB(nolign-1), [M:PJT1]PTESEQ(nolign-1))
  Endif
End

###################################################################################################
###################################################################################################
# Main actions
###################################################################################################
$SEARCH
  [M:PJT3]SEARCH = [V]CST_AYES         # Issue X3-85289 - 2018-05-24 by SINGC
  Call LOAD_SCREENS()
  # ----------------------------------
  # Issue X3-85289 - 2018-05-24 by SINGC : BEGIN
  Effzo [M:PJT3]5
  [M:PJT3]SEARCH = [V]CST_ANO
  If [M:PJT1]NBLIG > 0 Then
    Call LOAD_PTEVAL3([M:PJT1]CLB(0), [M:PJT1]PTESEQ(0))
  Endif
  # Issue X3-85289 - 2018-05-24 by SINGC : END
  # ----------------------------------
  REP = "M"
  GREP = REP
Return

###################################################################################################
$SELECT_ALL
  Call UPDATE_CHGSTA_VALUE([V]CST_AYES)
Return

###################################################################################################
$DESELECT_ALL
  Call UPDATE_CHGSTA_VALUE([V]CST_ANO)
Return

###################################################################################################
$VALIDATED
  Call UPDATE_STATUS(2)
Return

###################################################################################################
$CONTROLED
  Call UPDATE_STATUS(3)
Return

###################################################################################################
$APPROVED
  Call UPDATE_STATUS(4)
Return

###################################################################################################
###################################################################################################
# Subroutines
###################################################################################################
Subprog GET_FILTERS(SFILTER)
Variable Char SFILTER()(0..)

Local Integer NLIG

  Raz SFILTER
  NLIG = 0
  SFILTER(NLIG) = "[F:FCY]LEGCPY = [M:PJT0]CPY"
  If [M:PJT0]FCY <> AVOID.ACHAR Then
    NLIG += 1
    SFILTER(NLIG) -=  "and [F:PTED]FCY = [M:PJT0]FCY"
  Endif
  If [M:PJT0]CLB <> AVOID.ACHAR Then
    NLIG += 1
    SFILTER(NLIG) -= "and [F:PTED]CLB = [M:PJT0]CLB"
  Endif
  If [M:PJT0]OPPNUM <> AVOID.ACHAR Then
    NLIG += 1
    SFILTER(NLIG) -= "and [F:PTED]OPPNUM = [M:PJT0]OPPNUM"
  Endif
  If [M:PJT0]TSDATE <> [0/0/0] Then
    NLIG += 1
    SFILTER(NLIG) -= "and [F:PTED]PTEDAT >= [M:PJT0]TSDATE"
  Endif
  If [M:PJT0]TEDATE <> [0/0/0] Then
    NLIG += 1
    SFILTER(NLIG) -= "and [F:PTED]PTEDAT <= [M:PJT0]TEDATE"
  Endif
End

###################################################################################################
Subprog LOAD_HEADER()

  If [M:PJT1]NBLIG > 0 or [M:PJT2]NBLIG > 0 Then
    Diszo [M:PJT0]
  Else
    Actzo [M:PJT0]
  Endif
End

###################################################################################################
Subprog LOAD_SCREENS()

  Call LOAD_PTEVAL1()
  Call LOAD_PTEVAL2()
  Call LOAD_HEADER()
End

###################################################################################################
Subprog LOAD_PTEVAL1()

Local Char SFILTER(250)(0..)

  Local File PJMTIMEMP  [PTED]
  Local File FACILITY   [FCY]
  # ----------------------------------
  Effzo [M:PJT1]5
  Link [PTED] With [FCY]FCY0=[F:PTED]FCY
&               As [NEW]
&            Where [F:PTED]PTEVAL = [V]CST_AYES and [F:PTED]PTESTA = [M:PJT0]PTESTA
&     Order By Key KEY1=[F:PTED]PTEDAT;[F:PTED]CLB;[F:PTED]PTESEQ
  # ----------------------------------
  Call GET_FILTERS(SFILTER)
  Filter [NEW] Where evalue(SFILTER)
  nolign = 0
  For [NEW]KEY1
    If nolign >= dim([M:PJT1]PTEDAT) Then
      Call ERREUR(func AFNC.MES1(mess(1071,2260,1), num$(dim([M:PJT1]PTEDAT)))) From GESECRAN
      Break
    Endif
    nolign += 1
    [M:PJT1] = [F:PTED]
    [M:PJT1]PTESTAORI(nolign-1) = [M:PJT1]PTESTA(nolign-1)
  Next
  Filter [NEW]
  [M:PJT1]NBLIG = nolign
  Affzo [M:PJT1]5
  # ----------------------------------
End

###################################################################################################
Subprog LOAD_PTEVAL2()

Local Char SFILTER(250)(0..)

  Local File PJMTIMEMP  [PTED]
  Local File FACILITY   [FCY]
  # ----------------------------------
  Effzo [M:PJT2]5
  Link [PTED] With [FCY]FCY0=[F:PTED]FCY
&               As [NEW]
&            Where [F:PTED]PTEVAL = [V]CST_ANO
&     Order By Key KEY1=[F:PTED]PTEDAT;[F:PTED]CLB;[F:PTED]PTESEQ
  # ----------------------------------
  Call GET_FILTERS(SFILTER)
  Filter [NEW] Where evalue(SFILTER)
  nolign = 0
  For [NEW]KEY1
    If nolign >= dim([M:PJT2]PTEDAT) Then
      Call ERREUR(func AFNC.MES1(mess(1071,2260,1), num$(dim([M:PJT2]PTEDAT)))) From GESECRAN
      Break
    Endif
    nolign += 1
    [M:PJT2] = [F:PTED]
  Next
  Filter [NEW]
  [M:PJT2]NBLIG = nolign
  Affzo [M:PJT2]5
  # ----------------------------------
End

###################################################################################################
Subprog LOAD_PTEVAL3(SCLB, IPTESEQ)
Value Char SCLB()
Value Integer IPTESEQ

Local Integer NI

  # Issue X3-85289 - 2018-05-24 by SINGC
  Local File PJMTIMEMP  [PTED]
  # ----------------------------------
  Read [PTED]PTE0=SCLB;IPTESEQ
  Effzo [M:PJT3]5
  For NI = 0 To dim([F:PTED]DIE)-1
    If [F:PTED]DIE(NI) <> AVOID.ACHAR Then
      [M:PJT3]DIE(NI) = [F:PTED]DIE(NI)
      [M:PJT3]CCE(NI) = [F:PTED]CCE(NI)
    Else
      [M:PJT3]NBRDIE = NI
      Break
    Endif
  Next NI
  Affzo [M:PJT3]5
End

###################################################################################################
Subprog UPDATE_CHGSTA_VALUE(IVALUE)
Value Integer IVALUE

Local Integer NI

  For NI = 0 To [M:PJT1]NBLIG-1
    If IVALUE = [V]CST_AYES or IVALUE = [V]CST_ANO Then
      # Force to [V]CST_AYES or [V]CST_ANO
      [M:PJT1]CHGSTA(NI) = IVALUE
    Elsif IVALUE = 3 Then
      # To revert current value
      If [M:PJT1]CHGSTA(NI) = [V]CST_AYES Then
        [M:PJT1]CHGSTA(NI) = [V]CST_ANO
      Else
        [M:PJT1]CHGSTA(NI) = [V]CST_AYES
      Endif
    Endif
  Next NI
  Affzo [M:PJT1]1-99
End

###################################################################################################
Subprog UPDATE_STATUS(ISTATUS)
Value Integer ISTATUS

Local Integer NI

  For NI = 0 To [M:PJT1]NBLIG-1
    If [M:PJT1]CHGSTA(NI) = [V]CST_AYES Then
      # change the UI status
      [M:PJT1]PTESTA(NI) = ISTATUS
    Endif
    If [M:PJT1]PTESTA(NI) <> [M:PJT1]PTESTAORI(NI) Then
      Chgstl [M:PJT1]PTESTA(NI) With "PJMWARN1"
    Else
      Chgstl [M:PJT1]PTESTA(NI) With ""
    Endif
  Next NI
  Affzo [M:PJT1]1-99
End

###################################################################################################
Subprog RAZ_GRID_1_2()

  Actzo [M:PJT0]
  Effzo [M:PJT1]
  Effzo [M:PJT2]
  Affzo [M:PJT1]
  Affzo [M:PJT2]
End

###################################################################################################
Subprog SAVE_DECISION()

Local Instance ZPJMPTESTA Using C_TECPTESTA
Local Instance ZINSPJMTE Using C_PJMTIMEMPH
Local Integer NI
Local Integer IRET
Local Integer ICOUNT

  Call OUVRE_TRACE()
  # ----------------------------------
  Call ECR_TRACE(mess(1078,2260,1), 0)
  ICOUNT = 0
  For NI = 0 To [M:PJT1]NBLIG-1
    If [M:PJT1]PTESTA(NI) <> [M:PJT1]PTESTAORI(NI) Then
      If ZPJMPTESTA = null Then
        ZPJMPTESTA = NewInstance C_TECPTESTA AllocGroup null
      Endif
      IRET = fmet ZPJMPTESTA.TIMENT_ADD_LINE([M:PJT1]CLB(NI), [M:PJT1]PTESEQ(NI), [M:PJT1]PTESTA(NI))
      If IRET >= [V]CST_AERROR Then
        Call ECR_TRACE_DUMP_ERROR(ZPJMPTESTA)
        Break
      Else
        ICOUNT += 1
        Call ECR_TRACE(func AFNC.MES5(mess(1077,2260,1), [M:PJT1]CLB(NI),
&                                                        format$(GFMDAT,[M:PJT1]PTEDAT(NI)),
&                                                        num$([M:PJT1]PTESEQ(NI)),
&                                                        mess([M:PJT1]PTESTAORI(NI),2074,1),
&                                                        mess([M:PJT1]PTESTA(NI),2074,1)
&                                     ), 0)
      Endif
    Endif
  Next NI
  # ----------------------------------
  If IRET < [V]CST_AERROR Then
    If ZPJMPTESTA <> null Then
      ZINSPJMTE = NewInstance C_PJMTIMEMPH AllocGroup null
      IRET = fmet ZINSPJMTE.TIMENT_VALIDATION("", ZPJMPTESTA)
      If IRET >= [V]CST_AWARNING Then
        Call ECR_TRACE_DUMP_ERROR(ZINSPJMTE)
      Endif
    Endif
  Endif
  # ----------------------------------
  Call ECR_TRACE(string$(50,"-"), 0)
  Call ECR_TRACE(mess(1079,2260,1), 0)
  For NI = 0 To [M:PJT1]NBLIG-1
    If [M:PJT1]PTESTA(NI) = [M:PJT1]PTESTAORI(NI) Then
      Call ECR_TRACE(func AFNC.MES4(mess(1081,2260,1), [M:PJT1]CLB(NI),
&                                                      format$(GFMDAT,[M:PJT1]PTEDAT(NI)),
&                                                      num$([M:PJT1]PTESEQ(NI)),
&                                                      mess([M:PJT1]PTESTA(NI),2074,1)
&                                  ), 0)

    Endif
  Next NI
  # ----------------------------------
  Call ECR_TRACE(string$(50,"-"), 0)
  Call ECR_TRACE(mess(1080,2260,1), 0)
  For NI = 0 To [M:PJT2]NBLIG-1
    Call ECR_TRACE(func AFNC.MES4(mess(1081,2260,1), [M:PJT2]CLB(NI),
&                                                    format$(GFMDAT,[M:PJT2]PTEDAT(NI)),
&                                                    num$([M:PJT2]PTESEQ(NI)),
&                                                    mess([M:PJT2]PTESTA(NI),2074,1)
&                                ), 0)
  Next NI
  # ----------------------------------
  Call ECR_TRACE("", 0)
  If IRET >= [V]CST_AWARNING Then
    Call ECR_TRACE(mess(1083,2260,1), 1)
  Else
    Call ECR_TRACE(func AFNC.MES1(mess(1076,2260,1), num$(ICOUNT)), 0)
  Endif
  Call ECR_TRACE(string$(50,"-"), 0)
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  # ----------------------------------
  If ZPJMPTESTA <> null Then
    FreeGroup ZPJMPTESTA
    Raz ZPJMPTESTA
  Endif
  If ZINSPJMTE <> null Then
    FreeGroup ZINSPJMTE
    Raz ZINSPJMTE
  Endif
End

##########################################################################################################
Subprog OUVRE_TRACE()

  Call OUVRE_TRACE(mess(5,2269,1)) From LECFIC
  Call PRTSCR("PTEVAL0", "PJT0", "", 0, 1) From ATRTX3
  Call ECR_TRACE(string$(50,"-"), 0)
End

##########################################################################################################
Subprog ECR_TRACE_DUMP_ERROR(POOBJECT)
Variable Instance POOBJECT Using OBJECT

  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(POOBJECT) From SYRSTACKTOOLS
  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
End

##########################################################################################################
Subprog ECR_TRACE(TEX, ERR)
Value Char    TEX() : # Texte du message
Value Integer ERR

  If GTRACE <> AVOID.ACHAR Then
    Call ECR_TRACE (TEX, ERR) From GESECRAN
  Endif
End

##########################################################################################################
Funprog GET_KEYCONCAT_PJT1()

Local Char SARENDRE(GLONDCO)

  SARENDRE = func PJMTIMEMP_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PJT1]CLB(nolign-1),[M:PJT1]PTESEQ(nolign-1))
End SARENDRE

##########################################################################################################
Funprog GET_KEYCONCAT_PJT2()

Local Char SARENDRE(GLONDCO)

  SARENDRE = func PJMTIMEMP_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PJT2]CLB(nolign-1),[M:PJT2]PTESEQ(nolign-1))
End SARENDRE

