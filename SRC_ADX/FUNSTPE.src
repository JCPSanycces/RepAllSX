#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque STOCKPUE
############################################################
# Purge des numéros de série livrés
############################################################
$ACTION
Case ACTION
  When "EXEC"         : Gosub EXEC_PURSER
  When "TERMINE"      : Gosub TERMINE_PURSER
  When "INIT_DIA"     : Gosub INIT_DIA_PURSER
  When "OK"           : Gosub OK_PURSER
  When "END"          : Gosub END_PURSER
Endcase 
Return

#############################################################
$EXEC_PURSER
If [M:DIA]PURSERDAT <> [0/0/0]
  Gosub TRAITEMENT
Endif
Return
#############################################################
$TERMINE_PURSER
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_PURSER
Raz [M:DIA]
Local Char WPAR(05)
Call PARAM(VALEUR,"MARPURSER",WPAR) From ADOVAL
If val(WPAR) = 0
  WPAR = "12"
Endif
[M:DIA]DATREFMAX =addmonth(date$,val(WPAR)*-1)
[M:DIA]PURSERDAT = [M:DIA]DATREFMAX
[M:DIA]SIM    = 2   # hcb 040105 26446

Return
#############################################################
$OK_PURSER
FIN  = 1
Return
#############################################################
$END_PURSER
Raz [M:DIA]
FIN = 1
Return
############################################################
$TRAITEMENT
If GSERVEUR
  Onerrgo ERRBATCH
Endif
Local Integer I, NBSDH, NBPNH
Local File ITMFACILIT [ITF]
Local File STOSER     [STS]
Local File SDELIVERY  [SDH]
Local File PRETURN    [PNH]

If [M:DIA]SIM=1
     Call TEMPON (mess(397,197,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(397,197,1)) From LECFIC 
     Endif
Else Call TEMPON (mess(885,196,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(885,196,1)-":"-mess(397,197,1)) From LECFIC 
     Endif
Endif
#
Filter [ITF] Where STOFCY = [M:DIA]STOFCY 
&            Order By Key ITF1
For [ITF]
  Gosub PURSER
  Case GOK
    When  1 :
    When -1 :
      WMSG = mess(20,100,1)+" : "+[F:ITF]ITMREF
      Call ECR_TRACE(WMSG,1) From GESECRAN
    When Default : 
      Break
  Endcase
Next
Filter [ITF]
#
WMSG = mess(107,184,1)+" ("+format$("D:",[M:DIA]PURSERDAT)+")"
Call ECR_TRACE(WMSG,0) From GESECRAN

Close Local File [ITF]
Close Local File [STS]
Close Local File [SDH]
Close Local File [PNH]
Call TEMPOFF From GESECRAN
Return
############################################################
$PURSER
Trbegin [STS]
Call DEBTRANS From GLOCK
$PURSER1
GOK = 1
#
Filter [STS] Where ITMREF  = [F:ITF]ITMREF &
&                  STOFCY  = [F:ITF]STOFCY &
&                  ISSDAT <> [0/0/0]       &
&                  ISSDAT  < [M:DIA]PURSERDAT
&            Order By Key STS0
For [STS]
  I=0
  #MAE, bg 82301 
  NBSDH=0 
  NBPNH=0
# Transfert en cours ?
  If [F:STS]SDHTYP = 4
    Filter [SDH] Where SDHNUM = [F:STS]SDHNUM
&                Order By Key SDH0
    NBSDH=rowcount([SDH]) 
    Filter [SDH]
  Endif
  If [F:STS]SDHTYP = 8
    Filter [PNH] Where PNHNUM = [F:STS]SDHNUM
&                Order By Key PNH0
    NBPNH=rowcount([PNH]) 
    Filter [PNH]
  Endif
  If NBSDH = 0 & NBPNH = 0
    Readlock [STS] Curr
    Case fstat
      When 0 :
        If [M:DIA]SIM=1  
          Delete [STS]
          If fstat
            GOK = 0
            Call FSTA("STS") From GLOCK
            Break   
          Endif
        Endif
        WMSG = [F:STS]STOFCY-[F:STS]ITMREF-mess(397,197,1)-[F:STS]SERNUM+" "
        If [F:STS]SDHTYP <> 0
          WMSG += mess([F:STS]SDHTYP,701,1)-[F:STS]SDHNUM+" "
        Endif
        WMSG += num$([F:STS]ISSDAT)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      When 1 :
        GOK = -1
        Break
      When Default :
        GOK = 0
        Call FSTA("STS") From GLOCK
        Break   
    Endcase
  Endif
Next
Filter [STS] 
Case GOK
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If GROLL 
      Return 
    Else 
      Goto PURSER1
    Endif
  When 1 : 
    Commit
  When Default :
    Rollback
Endcase
Return
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
############################################################
# Actions écran STOCKPUE
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char WPAR(05)
Call PARAM(VALEUR,"MARPURSER",WPAR) From ADOVAL
If val(WPAR) = 0
  WPAR = "60"
Endif
[M:DIA]DATREFMAX =addmonth(date$,val(WPAR)*-1)
[M:DIA]PURSERDAT = [M:DIA]DATREFMAX
Affzo [M:DIA]PURSERDAT
End
############################################################
Subprog C_PURSERDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]DATREFMAX
  mkstat = 2
  GMESSAGE = mess(30,187,1)-num$([M:DIA]DATREFMAX)
Endif
End



