#<AdxTL>@(#)11.0.0.0 $Revision$
Local File AMSK [AMK]
Read [AMK]CODMSK = "AOB0"
Infbox num$([F:AMK]UPDFLG)
Call MAJ("AMK","AOB0","UPDFLG","5","","","","","","") From AWRKUPDOBJ
Read [AMK]CODMSK = "AOB0"
Infbox num$([F:AMK]UPDFLG)
End

#-------------------------------------------------------------------------------------#
# Ce traitement permet de mettre à jour les champs FLD1 à FLD4 de la table liée à
# l'objet ABREV avec les valeurs VALEUR1 à VALEUR4 uniquement si c'est objet n'est pas
# pas verrouillé sur la clé CLE
#-------------------------------------------------------------------------------------#

Subprog MAJ(ABREV,CLEOBJ,FLD1,VALEUR1,FLD2,VALEUR2,FLD3,VALEUR3,FLD4,VALEUR4)
Value    Char    ABREV
Value    Char    CLEOBJ
Value    Char    FLD1
Value    Char    VALEUR1
Value    Char    FLD2
Value    Char    VALEUR2
Value    Char    FLD3
Value    Char    VALEUR3
Value    Char    FLD4
Value    Char    VALEUR4

Local Char    PROGOBJ(GLONADC) , CLE(GLONID1)(1..16) , CHAINE(250)
Local Char    SYMBOLE(80) , POSTE(30) , USER(30) , ERM(250)
Local Char    NAMFLD(80) , VALFLD(80)
Local Integer I , J , K , ERN , NBCLE , VERROU

If FLD1=""
 ERM = mess(121,75,1) : # Champ non défini
Elsif ABREV=""
 ERM = mess(17,123,1) : # Table non définie
Elsif CLEOBJ=""
 ERM = mess(15,124,1)-ABREV
 ERM += "\"+mess(1,127,1) : # Clé incorrecte
Endif
If ERM<>"" : GOK = 0 : Goto ERR : Endif

PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
CHAINE = CLEOBJ
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
If TYPGES=2
 SYMBOLE = NOMFIC
Else
 Case NBCLE
  When 1
   SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1))
  When Default
   If TYPGES=3
    SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1)+"\"+CLE(2))
   Else
    SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(2)+"\"+CLE(1))
   Endif
   For I=3 To NBCLE
    SYMBOLE += "\"+CLE(I)
   Next I
 Endcase
Endif
Call DEBTRANS From GLOCK
Gosub VERROU
If !VERROU
 Call QUILOCKE(SYMBOLE,POSTE,USER) From OBJDIV
 # Fiche $1$ verrouillée dans l'objet $2$
 ERM = func AFNC.MES2(mess(83,143,1),right$(SYMBOLE,len(ABFIC)+1),ABREV)
 If USER<>""
  ERM = "\"+USER+"\"+POSTE
 Endif
 ERM += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
 GOK = -1 : Goto ERR
Endif
ABR = ABFIC
Gosub OUVFIC From =PROGOBJ
Gosub DEFAUT From =PROGOBJ
Raz [F]
Case NBCLE
 When 1
  Case evalue("type([F]"+CLEPRIM+")")
   When 1,2,4,5,6,7 : Assign "[F]"+CLEPRIM With val(CLE(1))
   When 3           : Assign "[F]"+CLEPRIM With evalue("["+CLE(1)+"]")
   When Default     : Assign "[F]"+CLEPRIM With CLE(1)
  Endcase
 When Default
  If TYPGES=3
   Case evalue("type([F]"+CLEPRIM+")")
    When 1,2,4,5,6,7 : Assign "[F]"+CLEPRIM With val(CLE(1))
    When 3           : Assign "[F]"+CLEPRIM With evalue("["+CLE(1)+"]")
    When Default     : Assign "[F]"+CLEPRIM With CLE(1)
   Endcase
   Case evalue("type([F]"+CLESEC(0)+")")
    When 1,2,4,5,6,7 : Assign "[F]"+CLESEC(0) With val(CLE(2))
    When 3           : Assign "[F]"+CLESEC(0) With evalue("["+CLE(2)+"]")
    When Default     : Assign "[F]"+CLESEC(0) With CLE(2)
   Endcase
  Else
   Case evalue("type([F]"+CLESEC(0)+")")
    When 1,2,4,5,6,7 : Assign "[F]"+CLESEC(0) With val(CLE(1))
    When 3           : Assign "[F]"+CLESEC(0) With evalue("["+CLE(1)+"]")
    When Default     : Assign "[F]"+CLESEC(0) With CLE(1)
   Endcase
   Case evalue("type([F]"+CLEPRIM+")")
    When 1,2,4,5,6,7 : Assign "[F]"+CLEPRIM With val(CLE(2))
    When 3           : Assign "[F]"+CLEPRIM With evalue("["+CLE(2)+"]")
    When Default     : Assign "[F]"+CLEPRIM With CLE(2)
   Endcase
  Endif
  For I=3 To NBCLE
   Case evalue("type([F]"+CLESEC(I-2)+")")
    When 1,2,4,5,6,7 : Assign "[F]"+CLESEC(I-2) With val(CLE(I))
    When 3           : Assign "[F]"+CLESEC(I-2) With evalue("["+CLE(I)+"]")
    When Default     : Assign "[F]"+CLESEC(I-2) With CLE(I)
   Endcase
  Next I
Endcase
Read [F] =
If fstat
 ERM = mess(56,123,1)-NOMFIC : # Table
 ERM += "\"+CLEOBJ-":"-mess(23,100,1) : # Fiche inexistante
 Gosub DEVERROU
 GOK = 0 : Goto ERR
Endif

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 Gosub MAJFLD
Endif

Gosub DEVERROU
End

#-------------#
$ERR
Call ECR_TRACE(ERM,1) From GESECRAN
End

#-------------#
$VERROU
Lock =SYMBOLE With lockwait=0
If !fstat
 VERROU = 1
Else
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL
  VERROU = 0
 Else
  Goto VERROU
 Endif
Endif
Return

#-------------#
$DEVERROU
If SYMBOLE<>""
 Unlock = SYMBOLE
Endif
Return

#-------------#
$TR1
Trbegin ADOVAL
 Gosub MAJFLD
 If GOK<0 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------#
$MAJFLD
Default File "["+ABR+"]"
Readlock [F] Curr
If fstat=1
 GOK=-1 : Call FSTA(ABR) From GLOCK : Return
Elsif fstat
 GOK=0 : Call FSTA(ABR) From GLOCK : Return
Endif
Onerrgo RIEN
For NAMFLD=FLD1,FLD2,FLD3,FLD4
 If NAMFLD<>""
  Case NAMFLD
   When FLD1 : VALFLD = VALEUR1
   When FLD2 : VALFLD = VALEUR2
   When FLD3 : VALFLD = VALEUR3
   When FLD4 : VALFLD = VALEUR4
  Endcase
  If evalue("dim([F:"+ABR+"]"+NAMFLD+")")>0
   If VALFLD = "" : VALFLD = '""' : Endif
   VALFLD = num$(evalue(VALFLD))
   Case evalue("type([F:"+ABR+"]"+NAMFLD+")")
    When 1,2,4,5,6,7,8,9 : Assign "[F:"+ABR+"]"+NAMFLD With val(VALFLD)
    When Default         : Assign "[F:"+ABR+"]"+NAMFLD With VALFLD
   Endcase
  Endif
 Endif
Next NAMFLD
Onerrgo
Rewrite [F]
If fstat
 GOK=0 : Call FSTA(ABR) From GLOCK : Return
Endif
Return

$RIEN
Resume

