#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################
#Mise à jour de la dimension maxi du code NCL
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTINCLMAX: DIMENSION OF 'NCL' ACTIVITY CODE") From LECFIC
 Call EXE_UTINCX(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTINCX(APPLI)
End


############################################################################
# Mise à jour des codes activités liés au nombre de colonnes de la liasse
############################################################################
Subprog EXE_UTINCX(APPLI)
Value Char    APPLI
Local Integer OK, WUPD

Call ECR_TRACE("UTINCX: Process Start on : "+APPLI,0) From GESECRAN

Local File ADOSACT  [XADA]
Local File =APPLI+".ACTIV" [XACV]
Trbegin [XACV]
GOK =1
Read [F:XACV]CODACT="NCL"
If !fstat 
 If [F:XACV]DIME  <15 : [F:XACV]DIME = 15 : Endif
 If [F:XACV]DIMFIL<15 : [F:XACV]DIMFIL = 15 : Endif
 Rewrite [F:XACV]
 If fstat
   GOK=0 : Call RSTA("XACV",[F:XACV]CODACT) From GLOCK
 Endif
Endif
If GOK=1 
 For [F:XACV]CODACT Where CODACT>="NC1" & CODACT<="NCF" & FLACT<>2
  [F:XACV]FLACT = 2
  Rewrite [F:XACV]
  If fstat
    GOK=0 : Call RSTA("XACV",[F:XACV]CODACT) From GLOCK : Break
  Endif
 Next
Endif
If GOK=1 
 Commit
Else
 Rollback
Endif

## mise à jour de la table ADOSACT pour ce dossier

Trbegin [XADA]
GOK=1
Read [F:XADA]ADA0=APPLI;"NCL"
If !fstat 
 If [F:XADA]DIME  <15 : [F:XADA]DIME = 15 : Endif
 Rewrite [F:XADA]
 If fstat
   GOK=0 : Call RSTA("XADA",[F:XADA]DOSSIER) From GLOCK
 Endif
Endif
If GOK=1 
 Filter [XADA] Where DOSSIER=APPLI & CODACT>="NC1" & CODACT<="NCF" & FLACT<>2
 For [F:XADA] 
  [F:XADA]FLACT = 2
  Rewrite [F:XADA]
  If fstat
    GOK=0 : Call RSTA("XADA",[F:XADA]DOSSIER) From GLOCK : Break
  Endif
 Next
 Filter [XADA]
Endif

If GOK=1 
 Commit
Else
 Rollback
Endif
Close Local File [XACV] , [XADA]

Call ECR_TRACE("UTINCX: Process End on : "+APPLI,0) From GESECRAN

End

