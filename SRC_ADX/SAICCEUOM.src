#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCCEUOM","SAICCEUOM","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
Local Char    AXCUR(GLONDIE)
Local Integer VERROU
Local Char    CLEDEB(20) , CLEFIN(20), CLECUR(20)
Local Char    CHAINE(30) , REP(1) , FILTRE(250)
Local Char    SYMBOLE(30)
Local Integer MAXLIG
If clalev([CCE])=0 : Local File CACCE   [CCE] : Endif
If clalev([DIE])=0 : Local File GDIE    [DIE] : Endif
If clalev([TUN])=0 : Local File TABUNIT [TUN] : Endif
Return

$DEBUT
MAXLIG = dim([M:CUO]SECTION)
REP = ""
Raz [M]
Read [DIE]DIE0 First
If !fstat : AXCUR = [F:DIE]DIE : Endif
Gosub PREMIER
Return

$FIN
Gosub DEVERROU
Return

$SETBOUT
Raz ETABOU
If REP="M"
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Else
 ETABOU(GPREM) = 1
 ETABOU(GDERN) = 1
 ETABOU(GSUIV) = 1
 ETABOU(GPREC) = 1
Endif
ETABOU(GBFIN) = 1
Call SETBOUT(ETABOU) From GESECRAN
Return

$APRES_MODIF
Case COUZON
 When "DIE" , "UOM" , "SECDEB" , "SECFIN"
  Gosub DEVERROU
  Case evalue("type([M]"+COUZON+")")
   When 1,2,4,5,6,7,8,9 : Assign "[M]"+COUZON With val(CZ)
   When Default         : Assign "[M]"+COUZON With CZ
  Endcase
  REP = ""
  AXCUR  = [M]DIE
  CLECUR = [M]UOM
  CLEDEB = [M]SECDEB
  CLEFIN = [M]SECFIN
  Gosub RELIT
  Gosub SETBOUT
 When Default
  If REP=""
   If VERROU
    REP = "M"
    Gosub SETBOUT
    Grizo DIE, UOM, SECDEB, SECFIN
   Else
    Gosub VERROU
    If !VERROU
     GERR = 1 : Return
    Else
     Gosub RELIT
     REP = "M"
     Gosub SETBOUT
     Grizo DIE, UOM, SECDEB, SECFIN
    Endif
   Endif
  Endif 
Endcase
Return

$ABANDON
Gosub RELIT
Gosub DEGRISE
REP = ""
Return

$PREMIER
Read [TUN]TUN0 First
Goto SUIVPREC

$DERNIER
Read [TUN]TUN0 Last
Goto SUIVPREC

$SUIVANT
Read [TUN]TUN0 > CLECUR
Goto SUIVPREC

$PRECEDENT
Read [TUN]TUN0 < CLECUR
Goto SUIVPREC

$SUIVPREC
If fstat<=2
 CLECUR = [F:TUN]UOM
 Gosub DEVERROU 
 Gosub LECTURE
Else
 GMESSAGE = mess(11,100,1) : GERR = 1
Endif
Return

$ENREG
Call DEBTRANS From GLOCK
Gosub TR1
REP = ""
Gosub DEGRISE
Return

$RELIT
$LECTURE
Gosub VERROU
Raz [M]
Gosub FILTRE
nolign = 0
For [CCE] Where evalue(FILTRE)
 J = find(CLECUR,[F:CCE]UOM(0..[F:CCE]UOMNBR-1))
 If J
  nolign += 1
  [M]SECTION(nolign-1) = [F:CCE]CCE
  Call LECTEXTRA([M]ZSECTION(nolign-1),"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  [M]QTY(nolign-1) = [F:CCE]QTY(J-1)
  If nolign>=MAXLIG
   CLEFIN = [F:CCE]CCE
   Break
  Endif
 Endif
Next
[M]NBLIG = nolign
[M]DIE = AXCUR
[M]UOM = CLECUR
Read [TUN]TUN0 = CLECUR
#[M]ZUOM = [F:TUN]UOMSHO # Adaptation V140 (CP:28/08/03)
Call LECTEXTRA([M]ZUOM,"TABUNIT","DESSHO",CLECUR,"") From ATEXTRA
[M]SECDEB = CLEDEB
[M]SECFIN = CLEFIN
Affzo
Return

$VERROU
SYMBOLE = "CCEUOM"-CLECUR
Lock = SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

$DEVERROU
If VERROU
 Unlock =SYMBOLE
Endif
Return

$FILTRE
#FILTRE = 'AXI='+num$(AXCUR)
#FILTRE ='1=1'
FILTRE = 'DIE="'+AXCUR+'"'
If CLEDEB<>"" : FILTRE -= '& CCE>="'+CLEDEB+'"' : Endif
If CLEFIN<>"" : FILTRE -= '& CCE<="'+CLEFIN+'"' : Endif
Return

$DEGRISE
Actzo DIE, UOM, SECDEB, SECFIN
Return

$TR1
GOK=1
Trbegin [CCE]
 Gosub FILTRE
 For [CCE] Where evalue(FILTRE) With Lock
  If fstat=1
   GOK=-1 : GLOCK = "$CACCE"-[F:CCE]CCE : Break
  Endif
  RW = 0
  I = find([F:CCE]CCE,[M]SECTION(0..[M]NBLIG-1))
  J = find(CLECUR,[F:CCE]UOM(0..[F:CCE]UOMNBR-1))
  If I
   If J
    If [F:CCE]QTY(J-1)<>[M]QTY(I-1)
     [F:CCE]QTY(J-1) = [M]QTY(I-1)
     RW = 1
    Endif
   Elsif [F:CCE]UOMNBR<dim([F:CCE]QTY)
    [F:CCE]UOM([F:CCE]UOMNBR) = CLECUR
    [F:CCE]QTY([F:CCE]UOMNBR) = [M]QTY(I-1)
    [F:CCE]UOMNBR += 1
    RW = 1
   Endif
  Else
   If J
    Dela J-1,1 [F:CCE]UOM,[F:CCE]QTY
    [F:CCE]UOMNBR -= 1
    RW = 1
   Endif
  Endif
  If RW
   Rewrite [CCE]
   If fstat
    GOK=0 : Call FSTA("CCE") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###################################################################
Subprog C_SECTION(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]SECTION(0..[M]NBLIG-1)) From OBJDIV
If (VALEUR<[M]SECDEB) or (VALEUR>[M]SECFIN & [M]SECFIN<>"")
 GMESSAGE = mess(101,105,1) : # Section en dehors des bornes
 mkstat = 2 : End
Endif
End

Subprog C_SECFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]SECDEB
 GMESSAGE = mess(202,100,1) : # Bornes incorrectes
 mkstat = 1 : End
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CCEUOM) 19-08-2006 14:04:34 (MB)
######################################################################################
Subprog AM_AXE(VALEUR)
Variable Integer VALEUR
End

Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_SECDEB(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_SECFIN(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

