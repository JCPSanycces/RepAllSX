#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:56"
A_USER  = "DOC"
A_STAMP = "20181109230556"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTAS0 [PJTA0]
Gosub HORODAT
Local Inpbox "PJMTAS0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA0] As [SIM_]
Grizo [PJTA0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTA0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMTAS0
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBPJTA
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16964,GBOUT1) From OBJDIV
Call TEXTE(55280,GBOUT3) From OBJDIV
Call IB_NBLIG
## Action STD
Call AS_NBLIG From SUBPJTA
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMTAS0
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1PJMTAS0
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMEVET
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMEVET"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMTAS"
 PARMSK(2) = [M:PJTA0]WRKTAS(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OEVENT","SUBPEV","") From GSAISIE
 ACTION = "BB1_NBLIG" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMACTSPLD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMACTSPLD"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB3_NBLIG" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = func PJMACTTAS.GET_PJMACTSPLD_ORI(nolign-1)
 PARMSK(2) = func PJMACTTAS.GET_PJMACTSPLD_COD(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OPJMACTSPLD","PJMACTSPLD","") From GSAISIE
 ACTION = "BB3_NBLIG" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ICO
Onevent INIT_AREA Call D_ICO(zc) From W1PJMTAS0
Return

Subprog D_ICO(VALEUR)
Variable Char    VALEUR()
If varinit([M]ICO,indice)=0
 VALEUR = "Folder.gif"
Endif
Gosub _AFF
End

$ON_EXPFLG
Onevent INIT_AREA Call D_EXPFLG(zc) From W1PJMTAS0
Return

Subprog D_EXPFLG(VALEUR)
Variable Decimal VALEUR
If varinit([M]EXPFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CMT1
Onevent INIT_AREA Call D_CMT1(zc) From W1PJMTAS0
Return

Subprog D_CMT1(VALEUR)
Variable Integer VALEUR
If varinit([M]CMT1,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CMT2
Onevent BEFORE_AREA Gosub AV_CMT2 From W1PJMTAS0
Return

$AV_CMT2
Chgfmt [M]CMT2(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CMT3
Onevent BEFORE_AREA Gosub AV_CMT3 From W1PJMTAS0
Return

$AV_CMT3
Chgfmt [M]CMT3(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CMT5
Return

$ON_CMT9
Onevent BEFORE_AREA Gosub AV_CMT9 From W1PJMTAS0
Return

$AV_CMT9
Chgfmt [M]CMT9(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CMT6
Onevent INIT_AREA Call D_CMT6(zc) From W1PJMTAS0
Return

Subprog D_CMT6(VALEUR)
Variable Integer VALEUR
If varinit([M]CMT6,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_WRKTAS
Return

$ON_AFFFCY
Return

$ON_OPPNUM
Return

$ON_XSL2
Onevent INIT_AREA Call D_XSL2(zc) From W1PJMTAS0
Return

Subprog D_XSL2(VALEUR)
Variable Clbfile VALEUR
If varinit([M]XSL2,indice)=0
 Call INIXSL(VALEUR,"ANOMV") From INTRUTILA
Endif
Gosub _AFF
End

$ON_CPY
Return

$ON_FINRSPFCY
Return

$CHG_STY
Return


