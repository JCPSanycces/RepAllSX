#<AdxTL>@(#)8.0.0.0 $Revision$
# Purge des configurations action SAICFGPUR 
############################################################
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE_PURGE
  When "DEBUT"          : Gosub DEBUT_PURGE
  When "APRES_MODIF"    : Gosub APRES_MODIF_PURGE
  When "SETBOUT"        : Gosub SETBOUT_PURGE
  When "BOUTON"         : Gosub BOUTON_PURGE
  When "AVANT_OK"       : Gosub AVOK_PURGE 
  When "OK"             : Gosub OK_PURGE
  When "EDI"            : Gosub EDI_PURGE
  When "END"            : Gosub END_PURGE
  When "FIN"            : Gosub FIN_PURGE
  When "FINSAI"         : Gosub FINSAI_PURGE
Endcase 
Return
############################################################
$OUVRE_PURGE
Call ACT_CFGUSR(GFONCTION,FIN) From CFGLIBD
If FIN = 1
  GERR = 1
  Goto OUVRE_PURGE_FIN
Endif
#
Local Char    Z_FIL(250)
Local Integer Z_I, Z_J, Z_K, Z_L
Local Decimal Z_CUM
Local Char    Z_MSG(120)
#
# Ouverture tables
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:CHH]) = 0 : Local File CFGHISHEA  [CHH] : Endif
If clalev([F:CFH]) = 0 : Local File CFGHIS     [CFH] : Endif
If clalev([F:CSC]) = 0 : Local File CFGSCE     [CSC] : Endif
If clalev([F:CQU]) = 0 : Local File CFGQST     [CQU] : Endif
If clalev([F:CSH]) = 0 : Local File CFGSHA     [CSH] : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL     [TCT] : Endif
If clalev([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITS]) = 0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITU]) = 0 : Local File ITMBPC     [ITU] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:CFB]) = 0 : Local File ITMBOMCFG  [CFB] : Endif
If clalev([F:ITC]) = 0 : Local File ITMCOST    [ITC] : Endif
#If clalev([F:ICW]) = 0 : Local File ITMCOSTW   [ICW] : Endif # inexistante en V6 - GA 05/2009 FQ 54328
#If clalev([F:INW]) = 0 : Local File ITCNATW    [INW] : Endif # inexistante en V6 - GA 08/2008
If clalev([F:MAW]) = 0 : Local File MATCSTW    [MAW] : Endif
#If clalev([F:ICP]) = 0 : Local File ITCCLCPRN  [ICP] : Endif # Supprimée en V6 - GA 09/2007
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:ITH]) = 0 : Local File ITMMVTHIS  [ITH] : Endif
If clalev([F:ITK]) = 0 : Local File ITMABCWRK  [ITK] : Endif
If clalev([F:ICN]) = 0 : Local File ITCNAT     [ICN] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif
If clalev([F:CBB]) = 0 : Local File CBLOB      [CBB] : Endif    # FQ 50444 GA 11/2008
If clalev([F:AOX]) = 0 : Local File AOBJTXT    [AOX] : Endif    # FQ 50444 GA 11/2008
If GMODU(8) = 2
  If clalev([F:TRO]) = 0 : Local File TABROUALT  [TRO]  : Endif
  If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH]  : Endif
  If clalev([F:ROO]) = 0 : Local File ROUOPE     [ROO]  : Endif
  If clalev([F:ROS]) = 0 : Local File ROUSCD     [ROS]  : Endif
Endif
$OUVRE_PURGE_FIN
Return
############################################################
$EDI_PURGE
Call PRTSCR("CFGPUR","CPU","",0,0) From ATRTX3
Return
############################################################
$DEBUT_PURGE
[M:CPU]REFDAT = date$
[M:CPU]FCYSEL = GFCYDEF(0)
Affzo [M:CPU]5-10
Gosub LOA_HIS
Return
############################################################
$APRES_MODIF_PURGE
Return
############################################################
$SETBOUT_PURGE
ETABOU(GEDIT) = 1
Return
############################################################
$BOUTON_PURGE
Case BOUT 
  When "a"
    For Z_I = 0 To [M:CPU]NBLIG-1
      If [M:CPU]STOFLG(Z_I) = 1
        [M:CPU]SELFLG(Z_I) = 2
      Endif
    Next Z_I
  When "b"
    For Z_I = 0 To [M:CPU]NBLIG-1
      [M:CPU]SELFLG(Z_I) = 1
    Next Z_I
Endcase
Affzo [M:CPU]15
Return
############################################################
$AVOK_PURGE
Z_J = 0
For Z_I = 0 To [M:CPU]NBLIG-1
  If [M:CPU]SELFLG(Z_I) = 2
    Z_J += 1
  Endif
Next Z_I
Z_K = 1
If Z_J <> 0
  Call AVERTIR(mess(130,188,1)-num$(Z_J)-mess(131,188,1),Z_K) From GESECRAN
  If Z_K = 1
    FIN = 0
  Endif
Endif
Return
############################################################
$OK_PURGE
If Z_K = 2
  If clalev ([F:ATB1]) = 0 : Local File ATABLE     [ATB1] : Endif
  If clalev ([F:ATZ1]) = 0 : Local File ATABZON    [ATZ1] : Endif
  If clalev ([F:ATI1]) = 0 : Local File ATABIND    [ATI1] : Endif
  If clalev ([F:ITM1]) = 0 : Local File ITMMASTER  [ITM1] : Endif
  If clalev ([F:BOH1]) = 0 : Local File BOM        [BOH1] : Endif
  If GMODU(8) = 2
    If clalev ([F:ROH1]) = 0 : Local File ROUTING    [ROH1] : Endif
  Endif
#
  Call OUVRE_TRACE(mess(129,188,1)) From LECFIC
  For Z_I = 0 To [M:CPU]NBLIG-1 
    If [M:CPU]SELFLG(Z_I) = 2
      Gosub TRT_EFFACEMENT
    Endif 
  Next Z_I
Endif
FIN = 1
Return
############################################################
$END_PURGE
If find(2,[M:CPU]SELFLG(0..[M:CPU]NBLIG-1))
  Z_I = 1
  Call AVERTIR(mess(51,100,1),Z_I) From GESECRAN
  If Z_I = 1
    FIN = 0
  Endif
Endif
Return
############################################################
$FIN_PURGE
Call IMPSCR From ATRTX3
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Return
############################################################
$FINSAI_PURGE
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
############################################################
$LOA_HIS
Effzo [M:CPU]15
Z_FIL = "SCENUM=[M:CPU]SCENUM"
If [M:CPU]REFDAT <> [0/0/0]
  Z_FIL += "&CFGDELDAT<=[M:CPU]REFDAT"
Endif
If [M:CPU]FCYSEL <> ""
  Z_FIL += "&FCY=[M:CPU]FCYSEL"
Endif  
#
[M:CPU]NBLIG = 0
Filter [CHH] Where evalue(Z_FIL)
&            Order By Key CHH0
For [CHH]
  If [M:CPU]NBLIG < dim([M:CPU]SELFLG)-1
    [M:CPU]NBLIG += 1
    nolign = [M:CPU]NBLIG
    [M:CPU] =  [F:CHH]
    Read [BPR]BPR0=[F:CHH]CFGBPRNUM
    If fstat
      Raz [F:BPR]
    Endif
    Read [ITM]ITM0=[F:CHH]ITMREF
    If fstat
      Raz [F:ITM]
    Endif
    [M:CPU]SELFLG (nolign-1) = 1
    #[M:CPU]ITMDES1(nolign-1) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CPU]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:CPU]STU    (nolign-1) = [F:ITM]STU
    [M:CPU]BPRNAM (nolign-1) = [F:BPR]BPRNAM
    Z_CUM = 0
    Filter [ITV] Where ITMREF = [F:CHH]ITMREF
&                Order By Key ITV0 
    For [ITV]
      Call STOITV("[F:ITV]",Z_L) From CFGLIBD
      Z_CUM = Z_L
      If Z_CUM <> 0
        Break
      Endif
    Next
    Filter [ITV]
    If Z_CUM = 0
      [M:CPU]STOFLG(nolign-1) = 1
    Else 
      [M:CPU]STOFLG(nolign-1) = 2
    Endif
  Else
    Break
  Endif
Next
Filter [CHH]
Affzo [M:CPU]15
nolign = 0
Return  
############################################################
$TRT_EFFACEMENT
Local Char     WFCY(GLONFCY)
Local Char     WCFG(20)
Local Char     WBPC(20)  
Local Shortint WALT
Local Integer OK
#
Call DEBTRANS From GLOCK
$TRT_EFFACEMENT1
Trbegin [CHH]
GOK = 1
OK  = 1
Readlock [CHH]CHH0=[M:CPU]CFGVCRNUM(Z_I)
Case fstat
  When 0 : 
    WFCY = [M:CPU]FCY(Z_I)
    WCFG = [M:CPU]CFGVCRNUM(Z_I)
    WBPC = [M:CPU]CFGBPRNUM(Z_I) 
    WALT = [M:CPU]BOMALT(Z_I)
    Call ANU_CONFIG(WFCY,WCFG,WBPC,WALT,1,OK) From SUBCFH
    If OK = 1 & GOK = 1
      Delete [CHH]
      If fstat
        GOK = 0
        Call FSTA("CHH") From GLOCK 
      Endif
      Filter [CFH] Where CFGVCRNUM = [F:CHH]CFGVCRNUM
&                  Order By Key CFH1 
      For [CFH]
        Readlock [CFH] Curr
        Case fstat
          When 1 :
            GOK = -1
          When 0 :
            Delete [CFH]
            If fstat
              GOK = 0
              Call FSTA("CFH") From GLOCK
              Break
            Endif
          When Default :
            GOK = 0
            Call FSTA("CFH") From GLOCK
            Break
        Endcase 
      Next 
      Filter [CFH]
    Endif
  When 1 :
    GOK = -1
  When Default :
    GOK = 0   
Endcase
#
$TRT_EFFACEMENT2
Case GOK 
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If GROLL
      Z_MSG = mess(20,100,1)-[M:CPU]CFGVCRNUM(Z_I)-[M:CPU]FCY(Z_I)-[M:CPU]ITMREF(Z_I)-
&             [M:CPU]ITMDES1(Z_I)
      Call ECR_TRACE(Z_MSG,1) From GESECRAN
    Else
      Goto TRT_EFFACEMENT1
    Endif  
  When 1 :
    Commit
    Z_MSG = [M:CPU]CFGVCRNUM(Z_I)-[M:CPU]FCY(Z_I)-[M:CPU]ITMREF(Z_I)-[M:CPU]ITMDES1(Z_I)-
&           mess(132,188,1)
    Call ECR_TRACE(Z_MSG,0) From GESECRAN
    [M:CPU]PROFLG(Z_I) = 2
    Affzo [M:CPU]PROFLG(Z_I)
  When Default :
    Rollback
    Z_MSG = mess(69,71,1)-[M:CPU]CFGVCRNUM(Z_I)-[M:CPU]FCY(Z_I)-[M:CPU]ITMREF(Z_I)-
&           [M:CPU]ITMDES1(Z_I)
    Call ECR_TRACE(Z_MSG,1) From GESECRAN
Endcase
Return
############################################################
Subprog AM_SCENUM(VALEUR)
Variable Char    VALEUR()
[M]SCENUM = VALEUR
Local Char    Z_FIL(250)
Local Integer Z_I, Z_J, Z_K, Z_L
Local Decimal Z_CUM
Local Char    Z_MSG(120)
Gosub LOA_HIS
End
############################################################
Subprog AM_FCYSEL(VALEUR)
Variable Char    VALEUR()
[M]FCYSEL = VALEUR
Local Char    Z_FIL(250)
Local Integer Z_I, Z_J, Z_K, Z_L
Local Decimal Z_CUM
Local Char    Z_MSG(120)
Gosub LOA_HIS
End
############################################################
Subprog AM_REFDAT(VALEUR)
Variable Date    VALEUR
[M]REFDAT = VALEUR
Local Char    Z_FIL(250)
Local Integer Z_I, Z_J, Z_K, Z_L
Local Decimal Z_CUM
Local Char    Z_MSG(120)
Gosub LOA_HIS
End
############################################################
Subprog AS_SELFLG(VALEUR)
Variable Integer VALEUR
If [M]STOFLG(nolign-1) = 2
  VALEUR = 1
  mkstat = 2
Endif
End

