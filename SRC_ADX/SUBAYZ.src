#<AdxTL>@(#)7.0.0.0 $Revision$  Gestion objet AYZ
#<AdxTL>@(#)7.0.0.0 $Revision$  Gestion objet AYZ
#Goto UPD
Call OBJET("AYZ",GBIDC1,GBIDC2) From GOBJET
End

$DEL
Local File AYTFRM [AYZ]
Trbegin [AYZ]
Delete [AYZ] Where FCYCOD="TEST1"
Commit
Infbox "Nbrec delete " - num$(adxdlrec)
End

$UPD
Local File AYTFRM [AYZ1]
Local File AYTFRM [AYZ]
Local Integer NB
Local Integer WI, RET
Local Mask AYZ1[AYZ1]
#bgaff
Trbegin [AYZ]
For [AYZ1]AYZ0 Where FCYCOD="FORMULAIRE" With Stability
    [F:AYZ]=[F:AYZ1]
    If(mod(WI,2)=0)
            [F:AYZ]FCYCOD="F1"
    Endif
    [F:AYZ]CREDAT=date$
    If dim([F:AYZ]CRETIM)>0 : [F:AYZ]CRETIM=time-WI : Endif   #RBU 93675
    Gosub INICRE
    Write [AYZ]
    WI+=1
    If WI>=50: Break : Endif
Next
Commit
Infbox "Nbrec creés" - num$(WI)
End

######################################################################################
## Xtend:  Gestion Formuliare Xtend
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "FILGAUCHE"      : Gosub FILGAUCHE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "OUVRE"          : Gosub OUVRE
 When "OUVRE_BOITE"    : Gosub OUVRE_BOITE

 When "APRES_CRE"      : If GWEBSERV: Call MESSAGE(mess(167,7900,1)) From GESECRAN : Endif
 When "APRES_MOD"      : If GWEBSERV: Call MESSAGE(mess(168,7900,1)) From GESECRAN : Endif
 When "AP_ANNULE"      : If GWEBSERV: Call MESSAGE(mess(169,7900,1)) From GESECRAN : Endif

 When Default
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), WFCYFLT(200) , WCPTAYT(GLONANM)
Local Integer WI, WRET
WFCYFLT = func SUBAYS.FILTFCY
Return

$OUVRE_BOITE
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char GBOXAY0(10), GBOXAY1(10)
GBOXAY0="GAU_CHE"+num$(find("AY0",OBJLIS(1..8)))
Return

$FILGAUCHE
#---------------------------------------------------------------#
If currbox=GBOXAY0
  FILGAUSUP(0)= WFCYFLT
  If FILTRE<>""    # liste principale
      FILGAUSUP(1)= "&" - FILTRE
  Endif
Endif
Return

#---------------------------------------------------------------#
$INICRE
# Code formulaire
WCPTAYT = func SUBTCA.NAMCPT(1,4)
If WCPTAYT="" : WCPTAYT = "AYT" : Endif
Call NUMERO(WCPTAYT, "", [F:AYZ]CREDAT, "", [F:AYZ]FRMCOD, RET) From SUBANM
 If RET<>0
  Gosub MESSAGE From SUBANM
  GOK =0 : Call ERREUR(MESSA) From GESECRAN  : Return
 Endif
[M]FRMCOD=[F:AYZ]FRMCOD : Affzo [M]FRMCOD
# Heure affichée
Local Integer HH, MM, SS
#HH = int([F:AYZ]CRETIM/3600) #RBU 93575
#MM = int(mod([F:AYZ]CRETIM,3600)/60)
#SS = mod([F:AYZ]CRETIM,60)
#[F:AYZ]CREHEURE=format$("N0:2",HH)+format$("N0:2",MM)+format$("N0:2",SS)
[F:AYZ]CREHEURE=format$("D:hhmmss",date$) #RBU 93575
[M]CREDAT    =[F:AYZ]CREDAT
[M]CREHEURE  =[F:AYZ]CREHEURE
Affzo [M]CREHEURE, CREDAT

$INIMOD
[F:AYZ]TYPBLB = 3
Return

######################################################################################
## Ecran AYZ1
######################################################################################
Subprog AS_CREDAT(VALEUR)
Variable Date    VALEUR
If(find(GREP,"C","D"))
 mkstat=2
Endif
End

Subprog AS_CREHEURE(VALEUR)
Variable Char    VALEUR()
If(find(GREP,"C","D"))
 mkstat=2
Endif
End


Subprog AS_FRMCOD(VALEUR)
Variable Char    VALEUR()
If GREP<>""
 mkstat=2
Endif
End


Subprog AS_STATUT(VALEUR)
Variable Integer VALEUR
For WI=3 To 19 :GMENLOC(WI)=1 : Next
End
