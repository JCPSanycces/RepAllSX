#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PTEVAL0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_FCY([M]FCY) From SUBPTEVAL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CLB
mkstat = 0
zoncou = "CLB"
indice = 0
WCHAR = [M]CLB
If varmode([M]CLB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLB" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PAUS","!",[M]CLB,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CLB" : GZNUM = 16058 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]CLB or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CLB([M]CLB) From SUBPTEVAL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CLB" : GZNUM = 16058 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PIM","!A",[M]OPPNUM,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 18260 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TSDATE
mkstat = 0
zoncou = "TSDATE"
indice = 0
If varmode([M]TSDATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TSDATE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TEDATE
mkstat = 0
zoncou = "TEDATE"
indice = 0
If varmode([M]TEDATE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TEDATE" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TEDATE([M]TEDATE) From SUBPTEVAL
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TEDATE" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PTESTA
mkstat = 0
zoncou = "PTESTA"
indice = 0
IMPENT = [M]PTESTA
If varinit([M]PTESTA,indice)=0
 IMPENT = 2
Endif
If varmode([M]PTESTA,indice)=0
 Call INICOMBO(2074) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PTESTA(IMPENT) From SUBPTEVAL
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2074,1))))
 Endif
 [M]PTESTA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTESTA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PTESTA(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PTESTA" : GZNUM = 1179 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "PTESTA" : GZNUM = 1179 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]PTESTA = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PTEVAL0"
Return

