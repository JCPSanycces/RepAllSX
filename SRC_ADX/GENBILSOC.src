#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Call GENBILSOC(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog GENBILSOC(APPLI)
Value Char APPLI

Local Clbfile CLOB(3)
Local Char    TEXTE(250)(1..100)
Local Char    TRAIT(250)(1..100)
Local Char    LIGNE(250)
Local Char    FICSRC(250)
Local Char    TETADO(80)
Local Integer I , J , K , SPA , OK , FLDEF , FLLIG

Local File =APPLI+".BILIND" [BIN]
Local File =APPLI+".ADOVAL" [ADW]

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"

FICSRC = filpath("TRT","WWBILSOC","src",APPLI)

adxifs = ""
adxirs = chr$(10)

Openo FICSRC , 0

Wrseq TETADO
Wrseq "#"
Wrseq "# Calcul du bilan social"
Wrseq "#"
Wrseq

Wrseq "$ACTION"
#Wrseq "Call ECR_TRACE(ACTION-INDICATEUR,0) From GESECRAN"
Wrseq "Case ACTION"
Wrseq ' When "LECTURE" : Gosub LECTURE'
Wrseq ' When "CALCUL"  : Gosub CALCUL'
Wrseq ' When "DIVISE"  : Gosub DIVISE'
Wrseq ' When "MOYENNE" : Gosub MOYENNE'
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq

For F=1 To 4
 Case F
  When 1 : Wrseq "$LECTURE"
  When 2 : Wrseq "$CALCUL"
  When 3 : Wrseq "$DIVISE"
  When 4 : Wrseq "$MOYENNE"
 Endcase
 Wrseq "Case INDICATEUR"
 Wrseq
 FLDEF = 1
 For [BIN]BIN0
  Case F
   When 1 : Setlob CLOB With [F:BIN]CND1
   When 2 : CLOB = [F:BIN]CLB2
   When 3 : CLOB = [F:BIN]CLB3
   When 4 : CLOB = [F:BIN]CLB4
  Endcase
  If len(CLOB)>0
   Case F
    When 1
     Setlob TEXTE(2..100) With CLOB
     TEXTE(1) = "OKIND = "
     Setlob CLOB With TEXTE
   Endcase
   Wrseq ' When "'+[F:BIN]COD+'" : #'-[F:BIN]DES
   FLDEF = 0
   FLLIG = 1
   If F=4
    Wrseq
    Wrseq "  MOYENNE = 1"
    FLLIG = 0
   Endif
   SPA  = 2
   Gosub ECRIT_CLOB
  Endif
 Next
 If FLDEF
  Wrseq " When default"
 Endif
 Wrseq "Endcase"
 If F=1
  Wrseq
  Wrseq "Case INDICATEUR"
  Wrseq ' When ';
  FLLIG = 0
  For [BIN]
   If len([F:BIN]CLB3)>0
    If FLLIG : Wrseq ","; : Endif
    Wrseq '"';[F:BIN]COD;'"';
    FLLIG = 1
   Endif
  Next
  # 53588
  If FLLIG=0
   Wrseq " default"
  Endif
  # fin 53588
  Wrseq
  Wrseq "  If OKIND : OKIND = 2 : Endif"
  Wrseq "Endcase"
 Endif
 Wrseq "Return"
 Wrseq
Next F

Openo
Call VALID("WWBILSOC",APPLI,OK)

If OK
 Trbegin [ADW]
  Update [ADW] Where CMP="" & FCY="" & PARAM="BILAN" With VALEUR="0"
 Commit
 If APPLI=nomap
  GBILOK = 0
 Endif
Endif
End

$ECRIT_CLOB
Setlob TEXTE With CLOB
I = 1
K = 1
Raz TRAIT
While TEXTE(I)<>""
 J = instr(1,TEXTE(I),chr$(10))
 If J
  LIGNE = left$(TEXTE(I),J-1)
  TEXTE(I) = right$(TEXTE(I),J+1)
  If right$(LIGNE,len(LIGNE))=chr$(13)
   LIGNE = left$(LIGNE,len(LIGNE)-1)
  Endif
  TRAIT(K) += LIGNE
  K += 1
  If TEXTE(I)=""
   I + = 1
  Endif
 Else
  LIGNE = TEXTE(I)
  If right$(LIGNE,len(LIGNE))=chr$(13)
   LIGNE = left$(LIGNE,len(LIGNE)-1)
  Endif
  TRAIT(K) += LIGNE
  I += 1
 Endif
Wend
While K>0 & vireblc(TRAIT(K),2)=""
 K -= 1
Wend
J = 1
While J<dim(TRAIT) & vireblc(TRAIT(J),2)=""
 J += 1
Wend
If FLLIG
 Wrseq
Endif
For I=J To K
 Wrseq space$(SPA);vireblc(format$("KT:250X",TRAIT(I)),1)
Next I
Wrseq
Return

##################################################################################
Subprog SETPAR
Local Integer VALPAR
VALPAR = 1
Goto MAJPAR

Subprog RAZPAR
Local Integer VALPAR
VALPAR = 0
Goto MAJPAR

$MAJPAR
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Call DEBTRANS From GLOCK
Gosub TR_PAR
GBILOK = VALPAR
End

$TR_PAR
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "";"";"BILAN"
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL BILAN" : Goto ROLL_PAR
 Elsif fstat
  Raz [F:ADW]
  [F:ADW]PARAM = "BILAN"
  [F:ADW]VALEUR = num$(VALPAR)
  Write [ADW]
 Elsif [F:ADW]VALEUR<>num$(VALPAR)
  [F:ADW]VALEUR = num$(VALPAR)
  Rewrite [ADW]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_PAR
 Endif
Commit
Return

$AB_PAR
Rollback
Return

$ROLL_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif

######################################################################################
Subprog VALID(PROG,DOSSIER,OK)
Value    Char    PROG
Value    Char    DOSSIER
Variable Integer OK

Local Integer STAT , SAVSEEK , LIGNE
Local Char    FICTRA(GDIMFIC) , REPERT(3)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Char    LIGTRT(250) , INDIC(10)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

SAVIFS = adxifs
SAVIRS = adxirs

If GTRACE<>""
 Openo
Endif
FICTRA = filpath("tmp",PROG,"tra",APPLI,"",MACHINE)
Openo FICTRA,0
Openo
ORDSYS(1) = "valtrt"-APPLI-PROG
ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
If STAT
 Call ECR_TRACE(mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+ORDSYS(1),1) From GESECRAN : # Erreur
Endif
If GTRACE<>""
 Openo filpath("TRA",GTRACE,"tra",nomap),-1
Endif

adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Rdseq MESSAGE(4)
Rdseq MESSAGE(5)
Openi

If MESSAGE(1)<>""
 LIGNE = 0
 For I=1 To len(MESSAGE(2))
  LIGNE = val(right$(MESSAGE(2),I))
  If LIGNE : Break : Endif
 Next I
 If LIGNE
  Openi filpath("TRT",PROG,"src")
  For I=1 To LIGNE
   Rdseq LIGTRT
   LIGTRT = vireblc(LIGTRT,2)
   If left$(LIGTRT,4) = "When"
    INDIC = vireblc(right$(LIGTRT,5),2)
    INDIC = seg$(INDIC,2,len(INDIC)-1)
   Endif
  Next I
  Openi
  MESSAGE(4) = mess(19,10716,1)-INDIC : # Indicateur
  MESSAGE(5) = LIGTRT
 Endif
 If GTRACE<>""
  Call ECR_TRACE(mess(20,123,1)-PROG,1) From GESECRAN : # Erreur en validation du traitement
  Call ECR_TRACE(MESSAGE(1),1) From GESECRAN
  Call ECR_TRACE(MESSAGE(2),1) From GESECRAN
  Call ECR_TRACE(MESSAGE(3),1) From GESECRAN
  If MESSAGE(4)<>""
   Call ECR_TRACE(MESSAGE(4),1) From GESECRAN
   Call ECR_TRACE(MESSAGE(5),1) From GESECRAN
  Endif
 Else
  If MESSAGE(4)<>""
   Call ECR_TRACE(mess(20,123,1)-PROG+"\"+MESSAGE(4)+"\"+MESSAGE(5),1) From GESECRAN
  Else
   Call ECR_TRACE(mess(20,123,1)-PROG+"\"+MESSAGE(2)+"\"+MESSAGE(3),1) From GESECRAN
  Endif
 Endif
 OK = 0
Else
 OK = 1
Endif
STAT = adxmpr
Onerrgo RIEN
adxmpr = STAT
Onerrgo
adxifs = SAVIFS
adxirs = SAVIRS
End

$RIEN
Resume

