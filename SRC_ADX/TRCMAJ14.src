#<AdxTL>@(#)9.0.0.0 $Revision$
#################################################################################
# TRCMAJ14 : M.a.j à effectuer lors du passage à la V140    Module Tronc commun #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#                                                                               #
#   - Table CONTACT  : Contact                                                  #
#           Modif. CNTNAM : Enlever les blancs avt de lancer la moulinette      #
#   - Table BPARTNER : Tiers                                                    #
#           Modif. CNTNAM : Remplacement Nom du contact par le Code du contact  #
#   - Table ITMMASTER : Article                                                 #
#   - Table ITMCATEG : catégorie article, reprise de l'ancienne TABITMCLS       #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#                                                                               #
#   - Table BPCUSTOMER Clients                                                  #
#           remplacement du type client "intra-societe" par "normal"            # 
#   - Table SPRICCONF  Paramétrage tarifs client                                #
#           le champ CRIITM contient le no ordre des critères liés a l'article  #
#           ( si les critères 1,3 et 4 sont concernés, CRIITM=134)              #    
#           le champ CRIBPR contient le no ordre des critères liés au client    # 
#   - Table SPRICLIST  Tarifs clients                                           #
#           nouveaux champs PLICRI3, PLICR4, PLICR5 chargés avec critères 3,4,5 #
#   - Table PPRICCONF  Paramétrage tarifs fournisseurs                          #
#           le champ CRIITM contient le no ordre des critères liés a l'article  #
#           ( si les critères 1,3 et 4 sont concernés, CRIITM=134)              #    
#           le champ CRIBPR contient le no ordre des critères fournisseur       # 
#   - Table PPRICLIST  Tarifs clients                                           #
#           nouveaux champs PLICRI3, PLICR4, PLICR5 chargés avec critères 3,4,5 #
#   - Table BPADDRESS  Adresses                                                 #
#           initialiser le nouveau champ BPAADDFLG                              #
#                                                                               #
#################################################################################


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################
Subprog ATRCMAJ14

Local Char WDOSSIER 

WDOSSIER=[F:ADS]DOSSIER  
##Call ECR_TRACE("Appli="+WDOSSIER-num$(filinfo(filpath("FIL","CONTACT","fde",WDOSSIER),0))
##& -num$(filinfo(filpath("FIL","BPARTNER","fde",WDOSSIER),0)),1) From GESECRAN

Local Integer WOUV_TRACE

If filinfo(filpath("FIL","CONTACT","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","BPARTNER","fde",WDOSSIER),0) < 0   End   Endif

If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ14 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local File =WDOSSIER+".CONTACT"    [CNT] 
Local File =WDOSSIER+".BPARTNER"   [BPR]
Local File =WDOSSIER+".CONTACT"    [CN2] Order By Key CLE = BPATYP;BPANUM;CNTNAM
Local File =WDOSSIER+".CONTACTCRM" [AIN] # FGR 28/08/2008 : X3SUIVI48777
Local File =WDOSSIER+".ITMMASTER"  [ITM]
Local File =WDOSSIER+".TABITMCLS"  [TCL]
Local File =WDOSSIER+".ITMCATEG"   [ITG]
Local File =WDOSSIER+".ITMFACILIT" [ITF]
Local File =WDOSSIER+".TABCOUAFF"  [TCA]

Gosub AV_CNT
Gosub AV_CNT_AIN # FGR 28/08/2008 : X3SUIVI48777
Gosub AV_BPR
Gosub AV_ITM
Gosub AV_ITG
#--- Demande 38118 - TS le 25.10.06
Gosub AV_ITF

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Close Local File [CNT]
Close Local File [BPR]
Close Local File [CN2]
Close Local File [AIN] # FGR 28/08/2008 : X3SUIVI48777
Close Local File [ITM]
Close Local File [TCL]
Close Local File [ITG]
Close Local File [ITF]
Close Local File [TCA]
End

#---------------------------------------------------------------------------------------#
#    ---> Concerne les contacts CONTACT                                                 #
#---------------------------------------------------------------------------------------#
# Suppression des blancs ds CNTNAM pr les moulinettes de remplacement CNTNAM par CCNCRM #
#---------------------------------------------------------------------------------------#
$AV_CNT

Call ECR_TIME("DOSMAJ14 Contact Process : Update CONTACT") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    LNUM(GLONBPA)
Local Char    LNAM(GLONNAM)
Local Integer LTYP, WMAJ
Local Char    CRITERE (90)

Raz NBENR, STOP
Raz CRITERE

$BOUCLE_CNT
If STOP=1
  STOP+=1 : CRITERE='BPATYP='+num$(LTYP)+'&BPANUM="'+LNUM+'"&CNTNAM>"'+LNAM+'"'
Elsif STOP=2
  STOP+=1 : CRITERE='BPATYP='+num$(LTYP)+'&BPANUM>"'+LNUM+'"'
Elsif STOP=3
  STOP=0 : CRITERE='BPATYP>'+num$(LTYP)
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [CNT]
For [CNT]CNT0 Where evalue(CRITERE) & CNTNAM<>""
    If [F:CNT]CNTNAM<>vireblc([F:CNT]CNTNAM,1)
        LNAM=[F:CNT]CNTNAM
        [F:CNT]CNTNAM=vireblc([F:CNT]CNTNAM,1)
        Rewrite [CNT]
        NBENR+=1
        If fstat
            Call ECR_TRACE("File CONTACT, Error ="-num$(fstat),1) From GESECRAN
        Else
            COMPTEUR += 1
            If COMPTEUR > GMAXUPDTRS
                LTYP=[F:CNT]BPATYP
                LNUM=[F:CNT]BPANUM
                STOP=1 : Break
            Endif
        Endif
    Endif
Next
Commit
If STOP : Goto BOUCLE_CNT : Endif

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return

######################################################################################
#---------------------------------------------------------------------------------------#
#    ---> Concerne les contacts CONTACT et CONTACTCRM                                   #
#---------------------------------------------------------------------------------------#
# FGR 28/08/2008 : X3SUIVI48777                                                         #
# En version 130 l'alimentation de CONTACTCRM dépendait du module "Action commerciale"  #
# A partir de la 140 CONTACTCRM est devenue une table "Superviseur". Elle doit donc     #
# toujours être alimentée.                                                              #
# Si en 130 le module "Action commerciale" n'était pas activé, cette table n'était pas  #
# alimentée. Normal.                                                                    #
# Ce traitement (ré)établi le lien si c'est nécessaire                                  #
#---------------------------------------------------------------------------------------#
$AV_CNT_AIN
  Call ECR_TIME("DOSMAJ14 Contact Process : Update CONTACTCRM") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    LNUM(GLONBPA)
Local Char    LNAM(GLONNAM)
Local Integer LTYP, WMAJ
Local Char    CRITERE (90)

  Raz NBENR
  If WNB_CONTACT > 0 Then
    Raz STOP
    Raz CRITERE
    #
    $BOUCLE_CNT_AIN
    #--------------
    If STOP = 1 Then
      STOP+=1 : CRITERE='BPATYP='+num$(LTYP)+'&BPANUM="'+LNUM+'"&CNTNAM>"'+LNAM+'"'
    Elsif STOP = 2 Then
      STOP+=1 : CRITERE='BPATYP='+num$(LTYP)+'&BPANUM>"'+LNUM+'"'
    Elsif STOP = 3 Then
      STOP=0 : CRITERE='BPATYP>'+num$(LTYP)
    Else
      CRITERE="1=1"
    Endif
    Raz COMPTEUR
    Trbegin [CNT], [AIN]
    #
    For [CNT]CNT0 Where evalue(CRITERE)
      If [F:CNT]CCNCRM <> "" Then
        Look [AIN]AIN0=[F:CNT]CCNCRM
      Endif
      If fstat or [F:CNT]CCNCRM = "" Then
        # C'est s'il n'existe pas qu'on fait quelque chose
        ##################################################
        Raz [F:AIN]
        [F:AIN]CNTNUM = [F:CNT]CCNCRM
        If [F:AIN]CNTNUM = "" Then
          Repeat
            [F:AIN]CNTNUM = func SUBAIN.COD([C]INTERLOC)
            [C]INTERLOC += 1
            Look [AIN]AIN0=[F:AIN]CNTNUM
          Until fstat
          # et dans ce cas on établi le lien avec le [CNT]
          [F:CNT]CCNCRM = [F:AIN]CNTNUM
          If dim([F:CNT]UPDDAT)>0 : [F:CNT]UPDDAT = date$ : Endif
          If dim([F:CNT]UPDUSR)>0 : [F:CNT]UPDUSR = GUSER : Endif
          If dim([F:CNT]UPDTIM)>0 : [F:CNT]UPDTIM = time  : Endif
          #
          Rewrite [CNT]
          If fstat Then
            Call ECR_TRACE("File CONTACT, Error ="-num$(fstat)-"("+[F:CNT]CCNCRM+")",1) From GESECRAN
          Endif
        Endif
        #
        [F:AIN]CNTTTL = [F:CNT]CNTCIV  # FGR 19/03/2009 : X3SUIVI53508 c'est [F:CNT]CNTCIV et pas [F:CNT]CNTTTL
        [F:AIN]CNTLNA = [F:CNT]CNTNAM  # FGR 19/03/2009 : X3SUIVI53508 c'est [F:CNT]CNTNAM et pas [F:CNT]CNTLNA
        [F:AIN]CNTFNA = [F:CNT]CNTCHN  # FGR 07/05/2009 : X3SUIVI55029 : FGR 19/03/2009 : X3SUIVI53508 c'est [F:CNT]CNTCHN et pas [F:CNT]CNTFNA
        [F:AIN]CNTMOB = [F:CNT]MOBTEL  # FGR 07/05/2009 : X3SUIVI55029 : FGR 19/03/2009 : X3SUIVI53508 c'est [F:CNT]MOBTEL et pas [F:CNT]CNTMOB
        [F:AIN]CNTBIR = [F:CNT]CNTBIR
       #[F:AIN]CRY    = [F:CNT]CNTCRY  # FGR 07/05/2009 : X3SUIVI55029 : FGR 19/03/2009 : X3SUIVI53508 [F:CNT]CNTCRY n'existe pas en 130 !
        [F:AIN]CNTFULNAM = func SUBAIN.CLE([F:AIN]CNTLNA, [F:AIN]CNTFNA)
        If dim([F:AIN]CREDAT)>0 : [F:AIN]CREDAT = date$ : Endif
        If dim([F:AIN]CREUSR)>0 : [F:AIN]CREUSR = GUSER : Endif
        If dim([F:AIN]CRETIM)>0 : [F:AIN]CRETIM = time  : Endif
        #
        Write [AIN]
        If fstat Then
          Call ECR_TRACE("File CONTACTCRM, Error ="-num$(fstat)-"("+[F:CNT]CCNCRM+")",1) From GESECRAN
        Else
          COMPTEUR += 1
          If COMPTEUR > GMAXUPDTRS Then
            LNAM = [F:CNT]CNTNAM
            LTYP = [F:CNT]BPATYP
            LNUM = [F:CNT]BPANUM
            STOP = 1
            Break
          Endif
        Endif
      Endif
    Next
    Commit
    If STOP : Goto BOUCLE_CNT_AIN : Endif
  Endif
  #
  Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return
######################################################################################

$AV_BPR
#-------------------------------------------------------------------------------#
#    ---> Concerne les tiers BPARTNER                                           #
#-------------------------------------------------------------------------------#
# Dans le champs CNTNAM : Remplacement du Nom du contact par le Code du contact #
#-------------------------------------------------------------------------------#

Call ECR_TIME("DOSMAJ14 Partner Process : Update BPARTNER") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ

Raz NBENR, STOP
Raz CLE1

Trbegin [BPR]
$BOUCLE_AV_BPR
Raz COMPTEUR
Raz STOP

For [BPR]BPR0 Where BPRNUM>=CLE1 & CNTNAM<>""
    WMAJ=0
    #Readlock [BPR]BPR0=[F:BPR]BPRNUM  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat 
    #    Call ECR_TRACE("File BPARTNER"-[F:BPR]BPRNUM-", Error ="-num$(fstat),1) From GESECRAN
    #Else
        If [F:CN2]CNTNAM<>[F:BPR]CNTNAM
            Read [F:CN2]CLE = 1;[F:BPR]BPRNUM;vireblc([F:BPR]CNTNAM,1)
            If fstat  
                Call ECR_TRACE("File CONTACT, Error ="-num$(fstat)-":"-[F:BPR]BPRNUM-[F:BPR]CNTNAM,1) From GESECRAN
                Raz [F:CN2]
            Endif
        Endif
#        Call ECR_TRACE([F:BPR]BPRNUM-"CNTNAM="-[F:BPR]CNTNAM-"CCNCRM="-[F:CN2]CCNCRM,0) From GESECRAN
        If [F:CN2]CCNCRM<>"" [F:BPR]CNTNAM = [F:CN2]CCNCRM : WMAJ=1 : Endif
        If WMAJ=1
            NBENR+=1

            Rewrite [BPR]
            If fstat
                Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
            Else
                COMPTEUR+=1
            Endif
        Else
            Unlock [BPR]
        Endif
    #Endif

    If COMPTEUR>GMAXUPDTRS 
        Commit
        Trbegin [BPR]
        CLE1=[F:BPR]BPRNUM : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_BPR : Endif
Commit
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return

$AV_ITM
#-------------------------------------------------------------------------------#
#    ---> Concerne les articles ITMMASTER                                       #
#-------------------------------------------------------------------------------#
# Initilisation de menus locaux                                                 #
#-------------------------------------------------------------------------------#

Call ECR_TIME("DOSMAJ14 Partner Process : Update ITMMASTER") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Integer CLE2, WMAJ
Local Char    ERR_TRA(120)

Raz NBENR, STOP
Raz CLE1

GOK = 1
Trbegin [ITM]
$BOUCLE_AV_ITM
Raz COMPTEUR
Raz STOP

For [ITM] Where ITMREF > CLE1

   [F:ITM]DACPUUCOE = 1
   [F:ITM]DACSAUCOE = 1
   [F:ITM]TRKCOD    = 1
   I = 0
   While I < dim([F:ITM]PCU) & [F:ITM]PCU(I) <> ""
      [F:ITM]DACPCUCOE(I) = 1
      [F:ITM]PCURUL(I)    = 1
      I += 1
   Wend
   # LOTMGTCOD : 1=Pas géré ; autres valeurs > 3 "lot obligatoire"
   If [F:ITM]LOTMGTCOD = 3
    # [F:ITM]LOTCOU = "LOT" # 
    # Chargement compteur général affecté aux Lots
    Call LECTCA(7,OK) From SUBTCA                                              
    If OK    = 1                                                      
#    If fstat = 0 
       [F:ITM]LOTCOU  = [F:TCA]CODNUM(7)
    Endif
   Endif
   If find([F:ITM]LOTMGTCOD,2,4)
      [F:ITM]LOTMGTCOD = 3
   Endif
   #MAE, bg 71926
   NBENR+=1
   Rewrite [ITM]
   If fstat
      # Trace : erreur d'écriture sur le fichier ITMMASTER
       ERR_TRA = "Write error on ITMMASTER :"-[F:ITM]ITMREF
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       GOK=0
       Break
   Else
       COMPTEUR += 1
   Endif
   If COMPTEUR>GMAXUPDTRS 
        Commit
        Trbegin [ITM]
        CLE1=[F:ITM]ITMREF : STOP=1 : Break 
    Endif
Next
If STOP Goto BOUCLE_AV_ITM : Endif
If GOK = 1
  Commit
Else
  Rollback
Endif
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return


###########################################################################
# reprise des catégories 130 (TCL) pour créer les catégories article v 140#
# au cas où elles n'aient pas été créées en avance de phase
###########################################################################
AV_ITG

Call ECR_TIME("DOSMAJ14 Partner Process : Update ITMCATEG") From DOSSUB

Local Char    ERR_TRA(120)

ERR_TRA = "Item Category processing for new table ITMCATEG"
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

GOK = 1
Trbegin [ITG]

For [TCL]
    Look [F:ITG]ITG1 = [F:TCL]TCLCOD;""
    If fstat
      Raz [F:ITG]
      [F:ITG] = [F:TCL]
      # reprise d'un éventuel article modèle...(dans ce cas initialiser DACPCU...) OU 
      # initialisation des menus locaux
      If [F:ITG]SALFLG=0 [F:ITG]SALFLG=1 Endif # au cas où
      [F:ITG]QUAFLG = 1
      [F:ITG]DACPUUCOE = 1
      [F:ITG]DACSAUCOE = 1
      [F:ITG]NEGSTO    = 1
      [F:ITG]LOTMGTCOD = 1
      [F:ITG]SERMGTCOD = 1
      [F:ITG]TRKCOD    = 1
      [F:ITG]EXYMGTCOD = 1
      [F:ITG]BRDCOD    = 1
      [F:ITG]RCPFLG    = 1
      [F:ITG]PRQFLG    = 1
      [F:ITG]ABCCLS    = 1

      If find([F:ITG]CLSTYP,6,8)                 
        [F:ITG]STOMGTCOD = 1 #  sous-traitance , générique
        [F:ITG]STDFLG    = 1
        [F:ITG]CUNCOD    = 3
        [F:ITG]STOCOD    = 3
        [F:ITG]GLOAAAFLG = 1
        [F:ITG]GLOQQQFLG = 1
        [F:ITG]GLORRRFLG = 1
      Else
        [F:ITG]STOMGTCOD = 2
        [F:ITG]STDFLG    = 3 # valeurs les plus courantes
        [F:ITG]CUNCOD    = 1
        [F:ITG]STOCOD    = 1
        [F:ITG]GLOAAAFLG = 2
        [F:ITG]GLOQQQFLG = 1
        [F:ITG]GLORRRFLG = 1
      Endif
      # code réception forcément à OUI pour art géré en stock ou Sous-traitance
      If [F:ITG]STOMGTCOD>1 | [F:ITG]CLSTYP=6 
        [F:ITG]RCPFLG    = 2 
      Endif
      [F:ITG]STDCSTUPD = 1
      [F:ITG]CUTCSTUPD = 1
      [F:ITG]BUDCSTUPD = 1
      [F:ITG]SIMCSTUPD = 1
      [F:ITG]MFGSHTCOD = 1
      [F:ITG]ITMTYP    = 1
      [F:ITG]LNDFLG    = 1
      [F:ITG]CTMFLG    = 1
      #[F:ITG]PFMCLCBAS = 1
      [F:ITG]UPDDAT    = [0/0/0]
      [F:ITG]UPDUSR    = ""
      [F:ITG]CREDAT = date$
      [F:ITG]CREUSR = GUSER
      [F:ITG]EXPNUM = [C]EXPORT

      Write [ITG]
      If fstat
       # Trace : erreur d'écriture sur le fichier ITMCATEG
        ERR_TRA = "Write error on ITMCATEG :"-[F:TCL]TCLCOD
        Call ECR_TRACE(ERR_TRA,1) From GESECRAN
        GOK=0
        Break
      Endif

    Endif
Next
If GOK = 1
  Commit
Else
  Rollback
Endif

#--- Demande 38118 - TS le 25.10.06
# Gestion des catégories d'emplacements dans ITG  
If GOK=1
   Local Char WTCLCOD : Raz WTCLCOD
   Trbegin [ITG]
   Filter [ITM] Order By Key CLE=TCLCOD
   For [ITM]
      For [ITF]ITF0 Where ITMREF=[F:ITM]ITMREF & LOCMGTCOD=2
         If [F:ITM]TCLCOD<>WTCLCOD
            Read [ITG]ITG0=[F:ITM]TCLCOD
            If !fstat & [F:ITG]LOCMGTCOD<>2
               [F:ITG]LOCMGTCOD=2
               [F:ITG]LOCDES(0)=1
               [F:ITG]LOCDES(1)=2
               [F:ITG]LOCDES(2)=3
               Rewrite [ITG]
               If fstat
                  # Trace : erreur d'écriture sur le fichier ITMCATEG
                  ERR_TRA = "Rewrite error on ITMCATEG :"-[F:TCL]TCLCOD
                  Call ECR_TRACE(ERR_TRA,1) From GESECRAN
                  GOK=0
                  Break 2
               Endif
            Endif
            WTCLCOD=[F:ITM]TCLCOD
         Endif
         Break
      Next
   Next
   Filter [ITM]
   If GOK = 1
      Commit
   Else
      Rollback
   Endif
Endif
#---

Return

#--- Demande 38118 - TS le 25.10.06
###########################################################################
# Récupération des (types d')emplacements dans ITF                        #
# Par défaut 1=réception, 2=stockage, 3=picking                           #
###########################################################################
AV_ITF

Call ECR_TIME("DOSMAJ14 Partner Process : Update ITMFACILIT") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1(20), CLE2(3)
Local Integer WMAJ
Local Char    CRITERE(150), ERR_TRA(120)

Raz NBENR, STOP
Raz CLE1, CLE2

Trbegin [ITF]
$BOUCLE_AV_ITF
If STOP=1
   CRITERE = 'ITMREF="'+CLE1+'" & STOFCY>"'+CLE2+'"'
   STOP=2
Elsif STOP=2
CRITERE = 'ITMREF>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz COMPTEUR

For [ITF] Where evalue(CRITERE)
   If [F:ITF]LOCMGTCOD=2
      [F:ITF]LOCNUM(0)=1
      [F:ITF]LOCNUM(1)=2
      [F:ITF]LOCNUM(2)=3
      [F:ITF]DEFLOCTYP(0)=[F:ITF]RCPLOCTYP
      [F:ITF]DEFLOC(0)   =[F:ITF]RCPLOC
      [F:ITF]DEFLOCTYP(1)=[F:ITF]STOLOCTYP
      [F:ITF]DEFLOC(1)   =[F:ITF]STOLOC
      [F:ITF]DEFLOC(2)   =[F:ITF]PICLOC
      #--- 51722
      If [F:ITF]DEFLOCTYP(0)="" [F:ITF]DEFLOCTYP(0)="*" Endif
      If [F:ITF]DEFLOCTYP(1)="" [F:ITF]DEFLOCTYP(1)="*" Endif
      [F:ITF]DEFLOCTYP(2)="*"
      #---
      Rewrite [ITF]
      If !fstat
         COMPTEUR += 1
      Endif
      If COMPTEUR>GMAXUPDTRS 
         Commit
         Trbegin [ITF]
         CLE1=[F:ITF]ITMREF : CLE2=[F:ITF]STOFCY : STOP=1 : Break 
     Endif
   Endif
Next
If STOP Goto BOUCLE_AV_ITF : Endif

Commit

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return
#---

#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################
Subprog TRCMAJ14

Local Char WDOSSIER 

WDOSSIER=[F:ADS]DOSSIER

Local Integer WOUV_TRACE

If filinfo(filpath("FIL","BPCUSTOMER","fde",WDOSSIER),0) < 0   End   Endif
If filinfo(filpath("FIL","SPRICCONF","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","SPRICLIST","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","PPRICCONF","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","PPRICLIST","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","OVERHEAD", "fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","BPADDRESS","fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","BPARTNER", "fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","COMPANY",  "fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","FACILITY", "fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","AUTILIS"  ,"fde",WDOSSIER),0)  < 0   End   Endif
If filinfo(filpath("FIL","GACCOUNT" ,"fde",WDOSSIER),0)  < 0   End   Endif

If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ14 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local File =WDOSSIER+".BPCUSTOMER"    [BPC]
Local File =WDOSSIER+".SPRICCONF"     [SPC]
Local File =WDOSSIER+".SPRICLIST"     [SPL]
Local File =WDOSSIER+".PPRICCONF"     [PPC]
Local File =WDOSSIER+".PPRICLIST"     [PPL]
Local File =WDOSSIER+".OVERHEAD"      [OVE]
Local File =WDOSSIER+".BPADDRESS"     [BPA]
Local File =WDOSSIER+".BPARTNER"      [BPR]
Local File =WDOSSIER+".COMPANY"       [CPY]
Local File =WDOSSIER+".FACILITY"      [FCY]
Local File =WDOSSIER+".AUTILIS"       [AUS]
Local File =WDOSSIER+".GACCOUNT"      [GAC]

Gosub AP_BPC
Gosub AP_SPC
Gosub AP_SPL
Gosub AP_PPC
Gosub AP_PPL
Gosub AP_OVE
Gosub AP_BPA

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Close Local File [BPC]
Close Local File [SPC]
Close Local File [SPL]
Close Local File [PPC]
Close Local File [PPL]
Close Local File [OVE]
Close Local File [BPA]
Close Local File [BPR]
Close Local File [CPY]
Close Local File [FCY]
Close Local File [AUS]
Close Local File [GAC]

End



#-------------------------------------------------------------------------------#
#    ---> Concerne les clients BPCUSTOMER                                       #
#-------------------------------------------------------------------------------#
# Remplacement du type client "intra-société" par "normal"                      #
#-------------------------------------------------------------------------------#
$AP_BPC

Call ECR_TIME("DOSMAJ14 Customer Process : Update BPCUSTOMER") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Char    CRITERE (90)

$BOUCLE_BPC
If STOP=1
  STOP=0 : CRITERE='BPCTYP=3 & BPCNUM>"'+CLE1+'"'
Else
  CRITERE="BPCTYP=3"
Endif

Raz COMPTEUR
Trbegin [BPC]
For [BPC]BPC0 Where evalue(CRITERE)
   If [F:BPC]BPCTYP=3
      [F:BPC]BPCTYP = 1
      NBENR+=1
      Rewrite [BPC]
      If fstat
         Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
      Else
#         Call ECR_TRACE("BPCUSTOMER="-[F:BPC]BPCNUM,1) From GESECRAN
         COMPTEUR += 1
         If COMPTEUR > GMAXUPDTRS
            CLE1=[F:BPC]BPCNUM
            STOP=1 : Break
         Endif
      Endif
   Endif
Next
Commit
If STOP : Goto BOUCLE_BPC : Endif

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return


#-------------------------------------------------------------------------------#
#    ---> Concerne le parametrage tarifs ventes SPRICCONF                       #
#-------------------------------------------------------------------------------#
# CRIITM = concatenation des no de criteres concernant l'article                #
# CRIBPR = concatenation des no de criteres concernant le client                #
#-------------------------------------------------------------------------------#
$AP_SPC

Call ECR_TIME("DOSMAJ14 Customer Prices Process 1 : Update SPRICCONF") From DOSSUB

Local Integer NBENR 

Local Integer IJL
Local Char    CRIITM_A (5), CRIBPR_A(5)

Trbegin [SPC]
  For [SPC]SPC0 
      Raz [F:SPC]CRIITM,[F:SPC]CRIBPR, CRIITM_A, CRIBPR_A
#     les champs de la table ITMBPC sont des critères articles et clients 
      For IJL=0 To dim([F:SPC]FIL)-1
          If find([F:SPC]FIL(IJL),"ITMMASTER","ITMSALES","ITMBPC") 
             CRIITM_A += num$(IJL+1) 
          Endif
          If find([F:SPC]FIL(IJL),"BPARTNER","BPCUSTOMER","BPCUSTMVT","BPDLVCUST","ITMBPC") 
             CRIBPR_A += num$(IJL+1) 
          Endif
      Next IJL
      [F:SPC]CRIITM=val(CRIITM_A) : [F:SPC]CRIBPR=val(CRIBPR_A)
      NBENR +=1 
      Rewrite [SPC]
      If fstat
         Call ECR_TRACE("File SPRICCONF, Error ="-num$(fstat),1) From GESECRAN
      Endif
  Next
Commit

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les lignes tarifs ventes SPRICLIST                           #
#-------------------------------------------------------------------------------#
# Chargement des 5 critères dans les champs PLICRI1 --> PLICRI5                 #
#-------------------------------------------------------------------------------#
$AP_SPL

Call ECR_TIME("DOSMAJ14 Customer Prices Process 2 : Update SPRICLIST") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Char    CLE2 (20)
Local Char    CLE3 (20)
Local Char    CRITERE (90)

Local Char     MANIP (250)
Local Integer  JLTST, JLCPT

Raz COMPTEUR, STOP
Raz CLE1, CLE2, CLE3

$BOUCLE_SPL 
If    STOP=1
   CRITERE = 'PLI="'+CLE1+'" & PLICRD="'+CLE2+'" & PLILIN>'+CLE3
   STOP=2
Elsif STOP=2
CRITERE = 'PLI="'+CLE1+'" & PLICRD>"'+CLE2+'"'
   STOP=3
Elsif STOP=3
CRITERE = 'PLI>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz COMPTEUR

Trbegin [SPL]
  For [SPL] SPL0 Where evalue(CRITERE)
    #Readlock [SPL] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #  Call ECR_TRACE("File SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
    #Else

      # éclatement des critères
      MANIP=[F:SPL]PLICRI : JLCPT=0
      While instr(1,MANIP,"~")
        JLTST=instr(1,MANIP,"~")
        JLCPT +=1
        Case JLCPT
          When 1 : [F:SPL]PLICRI1=left$(MANIP,JLTST-1)
          When 2 : [F:SPL]PLICRI2=left$(MANIP,JLTST-1)
          When 3 : [F:SPL]PLICRI3=left$(MANIP,JLTST-1)
          When 4 : [F:SPL]PLICRI4=left$(MANIP,JLTST-1)
          When 5 : [F:SPL]PLICRI5=left$(MANIP,JLTST-1)
        Endcase
        MANIP=(right$(MANIP,JLTST+1))
      Wend

      [F:SPL]UPDDAT=date$ : [F:SPL]UPDUSR=GUSER
      NBENR+=1
      Rewrite [SPL]
      If fstat
        Call ECR_TRACE("File SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif

      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS
        CLE1=[F:SPL]PLI : CLE2=[F:SPL]PLICRD : CLE3=num$([F:SPL]PLILIN) : STOP=1 : Break
      Endif
    #Endif
  Next
Commit

If STOP Goto BOUCLE_SPL : Endif

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return


#-------------------------------------------------------------------------------#
#    ---> Concerne le parametrage tarifs achats PPRICCONF                       #
#-------------------------------------------------------------------------------#
# CRIITM = concatenation des no de criteres concernant l'article                #
# CRIBPR = concatenation des no de criteres concernant le fournisseur           #
#-------------------------------------------------------------------------------#
$AP_PPC

Call ECR_TIME("DOSMAJ14 Supplier Prices Process 1 : Update PPRICCONF") From DOSSUB

Local Integer NBENR 

Local Integer IJL
Local Char    CRIITM_A (5), CRIBPR_A(5)

Trbegin [PPC]
  For [PPC]PPC0 
      Raz [F:PPC]CRIITM,[F:PPC]CRIBPR, CRIITM_A, CRIBPR_A
#     les champs de la table ITMBPS sont des critères articles et fournisseurs 
#     recherche des champs des tables ITMSALES, ITMBPC, BPCUSTOMER pour intersociété
      For IJL=0 To dim([F:PPC]FIL)-1
          If find([F:PPC]FIL(IJL),"ITMMASTER","ITMBPS","ITMSALES","ITMBPC") 
             CRIITM_A += num$(IJL+1) 
          Endif
          If find([F:PPC]FIL(IJL),"BPARTNER","BPSUPPLIER","ITMBPS","BPCUSTOMER","ITMBPC") 
             CRIBPR_A += num$(IJL+1) 
          Endif
      Next IJL
      [F:PPC]CRIITM=val(CRIITM_A) : [F:PPC]CRIBPR=val(CRIBPR_A)
      NBENR +=1 
      Rewrite [PPC]
      If fstat
         Call ECR_TRACE("File PPRICCONF, Error ="-num$(fstat),1) From GESECRAN
      Endif
  Next
Commit

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les lignes tarifs achats PPRICLIST                           #
#-------------------------------------------------------------------------------#
# Chargement des 5 critères dans les champs PLICRI1 --> PLICRI5                 #
#-------------------------------------------------------------------------------#
$AP_PPL

Call ECR_TIME("DOSMAJ14 Supplier Prices Process 1 : Update PPRICLIST") From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Char    CLE2 (20)
Local Char    CLE3 (20)
Local Char    CRITERE (90)

Local Char     MANIP (250)
Local Integer  JLTST, JLCPT

Raz COMPTEUR, STOP
Raz CLE1, CLE2, CLE3

$BOUCLE_PPL 
If    STOP=1
   CRITERE = 'PLI="'+CLE1+'" & PLICRD="'+CLE2+'" & PLILIN>'+CLE3
   STOP=2
Elsif STOP=2
CRITERE = 'PLI="'+CLE1+'" & PLICRD>"'+CLE2+'"'
   STOP=3
Elsif STOP=3
CRITERE = 'PLI>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz COMPTEUR

Trbegin [PPL]
  For [PPL] PPL0 Where evalue(CRITERE)
    #Readlock [PPL] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #  Call ECR_TRACE("File PPRICLIST"-[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
    #Else

      # éclatement des critères
      MANIP=[F:PPL]PLICRI : JLCPT=0
      While instr(1,MANIP,"~")
        JLTST=instr(1,MANIP,"~")
        JLCPT +=1
        Case JLCPT
          When 1 : [F:PPL]PLICRI1=left$(MANIP,JLTST-1)
          When 2 : [F:PPL]PLICRI2=left$(MANIP,JLTST-1)
          When 3 : [F:PPL]PLICRI3=left$(MANIP,JLTST-1)
          When 4 : [F:PPL]PLICRI4=left$(MANIP,JLTST-1)
          When 5 : [F:PPL]PLICRI5=left$(MANIP,JLTST-1)
        Endcase
        MANIP=(right$(MANIP,JLTST+1))
      Wend

      [F:PPL]UPDDAT=date$ : [F:PPL]UPDUSR=GUSER
      NBENR+=1
      Rewrite [PPL]
      If fstat
        Call ECR_TRACE("File PPRICLIST"-[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif

      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS
        CLE1=[F:PPL]PLI : CLE2=[F:PPL]PLICRD : CLE3=num$([F:PPL]PLILIN) : STOP=1 : Break
      Endif
    #Endif
  Next
Commit

If STOP Goto BOUCLE_PPL : Endif

Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN

Return

#-------------------------------------------------------------------------------#
#    ---> Concerne les descriptions de frais généraux  OVERHEAD                 #
#-------------------------------------------------------------------------------#
# Initialisation de la base pour formule (champ FORBASIS)                       #
#-------------------------------------------------------------------------------#
$AP_OVE

Call ECR_TIME("DOSMAJ14 Overhead Formula basis Process : Update FORBASIS") From DOSSUB

Local Integer NBENR 

Trbegin [OVE]
For [OVE] 
 If [F:OVE]FORBASIS = 0
  [F:OVE]FORBASIS = 1
  NBENR += 1
  Rewrite [OVE]
  If fstat
    Call ECR_TRACE("File OVERHEAD"-[F:OVE]OVECOD +", Error ="-num$(fstat),1) From GESECRAN
  Endif
 Endif
Next

Commit

Return


#-------------------------------------------------------------------------------#
#    ---> Concerne les adresses BPADDRESS                                       #
#-------------------------------------------------------------------------------#
# Initialisation de l'indicateur adresse par défaut BPAADDFLG                   #
#-------------------------------------------------------------------------------#
$AP_BPA
Call ECR_TIME("DOSMAJ14 Address Process : Update BPADDRESS") From DOSSUB
#-----
Local Char     CLE2(15), CLE3(3), CRITERE(60), WADR(3), WNUM(21)
Local Integer  COMPTEUR, STOP,    NBENR,       CLE1,    WFLAG
#-----
Raz CLE1, CLE2, CLE3, NBENR, STOP
#-----
$BOUCLE_BPA
If  STOP=1
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM="'+CLE2+'" & BPAADD>"'+CLE3+'"'
  STOP = 2
Elsif STOP=2
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM>"'+CLE2+'"'
  STOP = 3
Elsif STOP=3
  CRITERE = 'BPATYP>'+num$(CLE1)
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
#-----
Trbegin [BPA]
  For [BPA] BPA0 Where evalue(CRITERE)
    WNUM=num$([F:BPA]BPATYP)-[F:BPA]BPANUM-[F:BPA]BPAADD
    NBENR+=1
    Raz WADR
    Case [F:BPA]BPATYP
      When 1 : #----- Tiers -----#
        If [F:BPR]BPRNUM<>[F:BPA]BPANUM
          Read [BPR] BPR0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:BPR]BPAADD
      When 2 : #----- Société -----#
        If [F:CPY]CPY<>[F:BPA]BPANUM
          Read [CPY] CPY0=[F:BPA]BPANUM   : If fstat  Raz [F:CPY] : Endif
        Endif
        WADR=[F:CPY]BPAADD
      When 3 : #----- Site -----#
        If [F:FCY]FCY<>[F:BPA]BPANUM
          Read [FCY] FCY0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:FCY]BPAADD
      When 4 : #----- Utilisateur -----#
        If [F:AUS]USR<>[F:BPA]BPANUM
          Read [AUS] CODUSR=[F:BPA]BPANUM : If fstat  Raz [F:AUS] : Endif
        Endif
        WADR=[F:AUS]BPAADD
      When 5 : #----- Compte -----#
        If [F:GAC]ACC<>[F:BPA]BPANUM
          Read [GAC] GAC0=[F:BPA]BPANUM   : If fstat  Raz [F:GAC] : Endif
        Endif
        WADR=[F:GAC]BPAADD
    Endcase
    If [F:BPA]BPAADD=WADR  WFLAG=2  Else  WFLAG=1 : Endif
    #----- Mise à jour de l'indicateur "Adresse par défaut" -----#
    If [F:BPA]BPAADDFLG<>WFLAG
      COMPTEUR+=1
      #Readlock [BPA] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
      #If fstat 
      #  Call ECR_TRACE("File BPADDRESS"-WNUM+", Error ="-num$(fstat),1) From GESECRAN
      #Else
        [F:BPA]BPAADDFLG=WFLAG
        Rewrite [BPA]
        If fstat
          Call ECR_TRACE("File BPADDRESS, Error ="-num$(fstat),1) From GESECRAN
        #MAE, dm 70795, trace non necessaire et qui surcharge le fichier trace
        #Else
        #  Call ECR_TRACE(WNUM-"BPAADDFLG set to"-num$(WFLAG),0) From GESECRAN
        Endif
      #Endif
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS
        CLE1=[F:BPA]BPATYP : CLE2=[F:BPA]BPANUM : CLE3=[F:BPA]BPAADD : STOP=1 : Break
      Endif
    Endif
  Next
Commit
#-----
If STOP  Goto BOUCLE_BPA : Endif
Call ECR_TRACE("DOSMAJ14 : Processed records number :"-num$(NBENR),0) From GESECRAN
Return


