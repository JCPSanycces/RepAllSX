#<AdxTL>@(#)2.0.0.0 $Revision$
 Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = nomap
  PARBOUT(2) = GAYTFCYCOP
  PARBOUT(3) = ""
  PARBOUT(4) = ""
  PARBOUT(5) = "AYX"
  PARBOUT(6) = "AAUTOID"
  PARBOUT(7) = ""
  FLGEXE = 1
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AYTCOP","AYTCOP",3,"") From GTRAITE
End
######################################################################################
## Xtend: Gestion copie d'un objet Xtend
######################################################################################
##  Gestion Ecran
#    AYTCOP
#
##  Actions
#    AYTCOP       Copie d’un elt de type xtend
#
##  Gosub
#    COP_CTLFCY      Ctl sites
#    FCYREADORG      Lecture site origine (AYS1)
#    FCYREADDES      Lecture site destination (AYS2)
#    COPTEXTE        Copie des textes (toutes langues) - ne pas utiliser
#    MSGDESOBJ       Gestion message existence fiche destination
#
##  Subprog
#
#  Rq #*: déactivation code activité
######################################################################################
$ACTION
Case ACTION
  When "INIT"        : Gosub COP_INI
  When "INIT_DIA"    : Gosub COP_DIA
  When "CONTROLE"    : Gosub COP_CTL
  When "EXEC"        : Gosub COP_EXEC
  When "SORTIE"      : Gosub COP_SORTIE
  When "AS_FCYDES"   : Gosub AV_SITWEBDES
  When "AS_FCYORG"   : Gosub AV_SITWEBORG
Endcase
Return

######################################################################################
#    AYSCOP        Procédure de copie d’un elt de type xtend
#        Param(1)      Dossier origine
#        Param(2)      Site Xtend origine
#        Param(3)      Dossier destination
#        Param(4)      Site Xtend destination
#        Param(5)      Code Objet Xtend
#        Param(6)      Code elt Xtend
#        Param(7)      Code elt Xtend suplementaire (AYU)
# $$$$
######################################################################################
$AV_SITWEBDES
If [M]DOSDES<>nomap
 Local File =[M]DOSDES+".AYTFCY" [AYS]
Endif
Return

$AV_SITWEBORG
If [M]DOSORG<>nomap
 Local File =[M]DOSORG+".AYTFCY" [AYS]
Endif
Return
######################################################################################

$COP_INI
#-----------------------------
Local Char OBJCOD(GLONAOB) , ELTCOD(30), ELTCODSUP(30), WSTR1(200), WMSG(250)
Local Char     DES_ELTCOD(30)    # Dossier destination : code element (maj et minus )
Local Integer  DES_HASELT        # Dossier destination : Flag existence element dans dossier destination
Local Char FCYORG(GLONAYS), DOSORG(GDIMFIC)
Local Char FCYDES(GLONAYS), DOSDES(GDIMFIC)

Local Integer WI, RET, STAT   #, I , J , R , ERR , NBCLE
Local Char    PRGCOP(GLONADC) , PRGOBJ(GLONADC)
#* Local Char    WCODACT(GLONACV)

DOSORG     = PARAM(1)
FCYORG     = PARAM(2)
DOSDES     = PARAM(3)
FCYDES     = PARAM(4)
OBJCOD     = PARAM(5)
ELTCOD     = PARAM(6)
ELTCODSUP  = PARAM(7)

Return

$COP_DIA
#------------------------------
[M:DIA]OBJCOD    = OBJCOD
[M:DIA]ELTCOD    = ELTCOD
[M:DIA]ELTCODSUP = ELTCODSUP
#
[M:DIA]FCYORG=FCYORG
[M:DIA]DOSORG=DOSORG
Gosub  FCYREADORG      # classe AYS1
#* [M:DIA]CODACTORG=[F:AYS1]CODACT
#
[M:DIA]DOSDES=DOSDES
If [M:DIA]DOSDES=""
    If GDOSPATH<>""
        Call C_DOSSIER(GDOSPATH) From DOSCONT
        If mkstat
         mkstat = 0
        Else
         [M:DIA]DOSDES = GDOSPATH
        Endif
    Else
         [M:DIA]DOSDES = [M:DIA]DOSORG
    Endif
Endif
#
[M:DIA]FCYDES=FCYDES
If [M:DIA]FCYDES=""
  If GAYTFCYCOP=""
    [M:DIA]FCYDES=[M:DIA]FCYORG
  Else
    [M:DIA]FCYDES=GAYTFCYCOP
  Endif
Endif
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = [M:DIA]FCYDES : Gosub  FCYREADDES      # classe AYS2
If [M:DIA]OBJCOD <> "AYX"
 Call TITOBJ([M:DIA]OBJCOD,"",[M]DES) From CONTOBJ
Else
 [M]DES=mess(11,7910,1) : # TOKENS champs spéciaux
Endif
If  [M:DIA]OBJCOD = "AYS"        # Site
    [M:DIA]DES=[M:DIA]DES+":"-[M:DIA]FCYORG
Elsif [M:DIA]OBJCOD = "AYU"      # Par. avancés
    [M:DIA]DES=[M:DIA]DES+":"-[M:DIA]ELTCOD-"("+mess(val([M:DIA]ELTCODSUP),7910,1)+")"
Else
    [M:DIA]DES=[M:DIA]DES+":"-[M:DIA]ELTCOD
Endif
#
Return

$COP_CTL
#------------------------------
Call COP_CTLTRT([M:DIA]OBJCOD, PRGCOP, RET)
If RET=0
    Call ECR_TRACE(mess(27,7900,1)-PRGCOP-"-"-mess(12,139,1) ,1) From GESECRAN     # Copie non réalisée
    FIN=1
    Return
Endif
#
Gosub COP_CTLFCY
If RET=0 : SAI=1 : Return : Endif
TMP=1
TIT = mess(91,123,1)-[M]ELTCOD
If  [M:DIA]OBJCOD = "AYS" :  TIT = mess(91,123,1)-[M]FCYORG : Endif
Return

$COP_EXEC
#------------------------------
If [M]ALLSIT<>2
 Gosub TRTCOP From =PRGCOP
Else
 For [AYS2]
  FCYDES = [F:AYS2]FCYCOD
  Gosub TRTCOP From =PRGCOP
 Next AYS2
Endif
Return

$COP_SORTIE
#------------------------------
If clalev([F:AYS1]) : Close Local File [AYS1] : Endif
If clalev([F:AYS2]) : Close Local File [AYS2] : Endif
Return

$ERREUR
ERR = errn
Resume


######################################################################################
### Utilitaires - Gosub
######################################################################################

# Ctl sites
# $$$$
#------------------------------------------------------------#
$COP_CTLFCY
RET=1
# Relecture par sécurité
[L]DOSORG = [M:DIA]DOSORG : [L]FCYORG = [M:DIA]FCYORG : Gosub  FCYREADORG      # classe AYS1
If fstat
    Call ECR_TRACE(mess(19,7900,1)-[M:DIA]FCYORG,1) From GESECRAN : RET=0 : Return : Endif
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = [M:DIA]FCYDES : Gosub  FCYREADDES      # classe AYS2
If fstat and [M:DIA]OBJCOD <> "AYS"
    Call ECR_TRACE(mess(20,7900,1)-[L]FCYDES,1) From GESECRAN : RET=0 : Return : Endif

If [L]FCYORG=[L]FCYDES
    If [L]DOSORG=[L]DOSDES
        Call ECR_TRACE(mess(21,7900,1),1) From GESECRAN
        RET=0 : Return
    Endif
    Call DOSORGDES([L]DOSORG,[L]DOSDES) From DOSCONT
    If mkstat
        RET=0 : Return
    Endif
Endif
#
Return

# Lecture site origine (AYS1)
# $$$$
#------------------------------------------------------------#
$FCYREADORG
If clalev([F:AYS1]) : Close Local File [AYS1] : Endif
If DOSORG="" : fstat=5 : Return : Endif
If DOSORG<>nomap
    Local File =DOSORG+".AYTFCY"  [AYS1]
Else
    Local File AYTFCY [AYS1]
Endif
If FCYORG<>""
    Read [AYS1]AYS0 = [L]FCYORG
Else
    fstat=5  # <=> non trouvé
Endif
Return

# Lecture site destination (AYS2)
# $$$$
#------------------------------------------------------------#
$FCYREADDES
If dim([M]ALLSIT)>0 & [M]ALLSIT = 2 : Return : Endif
If clalev([F:AYS2]) : Close Local File [AYS2] : Endif
If DOSDES="" : fstat=5 : Return : Endif
If DOSDES<>nomap
    Local File =DOSDES+".AYTFCY"  [AYS2]
Else
    Local File AYTFCY [AYS2]
Endif
If FCYDES<>""
    Read [AYS2]AYS0 = [L]FCYDES
Else
    fstat=5  # <=> non trouvé
Endif
Return

# Gestion message existence fiche destination
# $$$$
#------------------------------------------------------------#
$MSGDESOBJ
DES_HASELT=(fstat=0)  # Retour de la lecture "AY[x]2"
If DES_HASELT
    If GACTION="AYTCOP"  # Message utilisateur en copie fiche par fiche
        If DES_ELTCOD=[L]ELTCOD
          OK=1 : Call AVERTIR([L]DOSDES-[L]FCYDES-[L]DES_ELTCOD-mess(22,100,1),OK) From GESECRAN
          If OK<>2 : OK = 0 : Endif
        Endif
    Endif
    #
Else
    Raz DES_ELTCOD
Endif
Return

######################################################################################
###     Utilitaires générations subprog et funprog
######################################################################################

# Set Update Time - for compatibility with V6 - 93575
Subprog  SET_UPDTIM(ABRFIC)
Value Char ABRFIC()

Local Char TMP_ABRFIC(10)
If instr(1,ABRFIC,"[")=0
  TMP_ABRFIC = "[F:"+ABRFIC+"]"
Else
  TMP_ABRFIC = ABRFIC
Endif

If evalue("dim("+TMP_ABRFIC+"UPDTIM)")>0
  Assign TMP_ABRFIC+"UPDTIM" With time
Endif

End


#------------------------------------------------------------#
# Existence prgrm copie par type d'objet
# $$$$
#------------------------------------------------------------#
Subprog COP_CTLTRT(OBJCOD, PRGCOP, RET)
Value     Char OBJCOD()    # Code objet Xtend (AYA, AYB...)
Variable  Char PRGCOP()    # Nom prgm de copie
Variable  Integer RET
Local Integer STAT
Raz PRGCOP : RET=1
PRGCOP = "SUB"+OBJCOD + "COP"    # Xtend -> prgrm copie suffixe COP
Call EXISTE_ADX("","",PRGCOP,STAT) From ORDSYS
If STAT=0 : RET=0 : Endif
End


# Copie des textes (toutes langues)  ne pas utiliser
# $$$$
#------------------------------------------------------------#
Subprog COPTEXTE(NUM1,NUM2)
Value    Integer NUM1
Variable Integer NUM2
Local Integer PREM, DERN, NUM3
Local Integer ASTATUS
Local Char MESSAGE(250)
NUM2 = 0 : NUM3 = 0
If NUM1=0 : End : Endif
Read [ATX1]NUMERO = GLANGUE;NUM1
If fstat : End : Endif
Gosub INIT_LANGS
# Issue 86467 - 2012-12-20 by VPO : on teste les dossiers de copie
Local Char VALEUR2(10)
If dim([M:DIA_]DOSDES)>0
  VALEUR2=func AFNC.PARAMDOS([M:DIA_]DOSDES,"TYPDOS")
Elsif dim([M]DOSDES)>0
  VALEUR2=func AFNC.PARAMDOS([M]DOSDES,"TYPDOS")
Endif

For [ATX2]TEXTE Where LAN=GLANGUE & TEXTE=[F:ATX1]TEXTE
 If vireblc(toupper(ctrans([F:ATX1]COMMENT)),2)=vireblc(toupper(ctrans([F:ATX2]COMMENT)),2)
  NUM2 = [F:ATX2]NUMERO
  Break
 Elsif NUM3=0
  NUM3 = [F:ATX2]NUMERO
 Endif
Next
NUM2=0
If NUM2=0 : NUM2 = NUM3 : Endif
If NUM2=0
 Lock [ATX2]
 If fstat
  GOK=-1 : GLOCK="$ATEXTE" : End
 Endif
 If dim([V]GADONIX)>0 & GADONIX<>2
  PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
 Else
  PREM = 0 : DERN = GMAXTXTSTD
 Endif
 If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(val(VALEUR2)-1,GLANGUE,LANGS,[F:ATX1]TEXTE, [F:ATX1]COMMENT,NUM2,MESSAGE)
  If ASTATUS<>[V]CST_AOK
   GMESSAGE=MESSAGE : GOK=0 : Return
  Endif
 Else
  Filter [ATX2] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
  Read [ATX2] Last
  Filter [ATX2]
  If fstat : NUM2 = PREM+1 : Else : NUM2 = [F:ATX2]NUMERO+1 : Endif
 Endif
 For [ATX1]DERNUM From NUM1 To NUM1        # toutes langues
  [F:ATX2] = [F:ATX1]
  [F:ATX2]NUMERO = NUM2
  Write [ATX2]
  If fstat
   GOK=0 : Call FSTA("ATX2") From GLOCK : Break
  Endif
  If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
   ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(val(VALEUR2)-1,[F:ATX2]NUMERO,[F:ATX2]LAN,[F:ATX2]TEXTE, [F:ATX2]COMMENT,[F:ATX2]LANORI,MESSAGE)
   If ASTATUS<>[V]CST_AOK
    GMESSAGE=MESSAGE : GOK=0 : Break
   Endif
  Endif
Next
 #
Endif
End

$INIT_LANGS
Local Char LANGS(3)(0..)
Local Integer NBLANGS
Local File ADOSSIER [ADS]
Local Integer AI
If func DOSSUB.FILL_ADS(nomap)
 For AI=0 To [F:ADS]NBRLAN-1
  LANGS(AI) = [F:ADS]LAN(AI)
  NBLANGS+=1
 Next AI
Endif
Return


######################################################################################
## Ecran AYTCOP
######################################################################################
Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_ACVAYT
GDOSPATH = VALEUR
End

Subprog C_FCYORG(VALEUR)
Variable Char    VALEUR()
End

$VERIF_ACVAYT
If VALEUR<>nomap
 Local File =VALEUR+".ACTIV" [ACV]
Endif
If !func AFNC.ACTIV("AYT")
 GMESSAGE = mess(85,115,1)-VALEUR-":"-mess(83,123,1)-"\ (AYT :"-mess(24,176,1)+")" : # Code activité INACTIF
 mkstat =2 : Return
Endif
Return

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_ACVAYT
End

Subprog C_FCYDES(VALEUR)
Variable Char    VALEUR()
GAYTFCYCOP = VALEUR
# Infos site
Local Char FCYDES(GLONAYS), DOSDES(GDIMFIC)
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = VALEUR : Gosub  FCYREADDES      # classe AYS2
End


Subprog AM_ALLSIT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 FCYDES = ""
 Affzo FCYDES
 Grizo FCYDES
Else
 Actzo FCYDES
Endif
End

