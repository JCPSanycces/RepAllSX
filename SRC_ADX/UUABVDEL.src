##################################################################################
# UUABVDEL                                                                       #
# Suppression de la règle de synchronisation  DEPRECPER                          #
# MDJ 06/05/2010 FQ64613 et 63341                                                #
##################################################################################
 Call OUVRE_TRACE("Test moulinette UUABVDEL") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE From LECFIC
End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","ABIREGORG","fde",PAPPLI),0)<=0
      End
Else
   Call EXE_UUABVDEL(PAPPLI)
Endif

End
##################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","ABIREGORG","fde",APPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif 
  Call EXE_UUABVDEL(APPLI)
End

End
 
#------ Suppression de la règle de synchronisation DEPRECPER ------#
Subprog EXE_UUABVDEL(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)
Local Integer OK

GOK =1

#-----
Call ECR_TRACE("UUABVDEL: Delete Synchonisation rule DEPRECPER from the ABV table "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ABV]) =0  Local File =LDOSSIER+".ABIREGORG"     [ABV] : Endif
If clalev([F:ABY]) =0  Local File =LDOSSIER+".ABIREGDES"     [ABY] : Endif
#-----------------------------------------------#
#   mise a jour tables ABIREGORG et ABIREGDES   #
#-----------------------------------------------#
Trbegin [ABV], [ABY]
 Delete [ABV] Where CODREG="DEPRECPER"
 If fstat
  GOK=0 
 Endif 
 Delete [ABY] Where CODREG="DEPRECPER"
 If fstat
  GOK=0 
Endif 


$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif

#----- Fin du traitement -----#
WMSG ="UUAABVDEL: end of process"
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [ABV],[ABY]
End


