 SAVACT = GACTION : GACTION = "STD"
 Call C_FILEXT([M]FILEXT) From SUBBAN
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FILEXT" : GZNUM = 8995 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BANFIL
mkstat = 0
zoncou = "BANFIL"
indice = 0
