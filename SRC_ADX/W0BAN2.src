## Zone NBSEC
mkstat = 0
zoncou = "NBSEC"
indice = 0
status = 1
zoncou = "NBSEC"
If varmode([M]NBSEC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBSEC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBSEC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBSEC = nolign
   status = 75
   Call SAI_NBSEC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
