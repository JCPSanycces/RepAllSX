If varinit([M]RECCPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]RECCPT,indice)=0
 [M]RECCPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RECCPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RECCPT(indice)
 Endif
Endif
