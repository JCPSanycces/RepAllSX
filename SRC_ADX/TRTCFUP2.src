#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Handling of CRITFUP2 mask : secondary criteria
##########################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(20)
GERR = 0
GPROG    = "TRTCFUP"
GTYPPROG = 4
GWINDOW  = "DFUP"
GWINCRIT = "CRITFUP"
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE
End

$ACTION
Return

Subprog C_ALLBPCGRU(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]BPCGRU
Else
 Effzo [M:CFP2]BPCGRU : Diszo [M:CFP2]BPCGRU
Endif
End

######################################################################################

Subprog C_ALLREP1(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]REPDEB1, REPFIN1
Else
 Effzo [M:CFP2]REPDEB1, REPFIN1 : Diszo [M:CFP2]REPDEB1, REPFIN1
Endif
End

######################################################################################

Subprog C_ALLREP2(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]REPDEB2, REPFIN2
Else
 Effzo [M:CFP2]REPDEB2, REPFIN2 : Diszo [M:CFP2]REPDEB2, REPFIN2
Endif
End

######################################################################################

Subprog C_REPFIN1(VALEUR)
Variable Char    VALEUR()
If [M:CFP2]REPDEB1="" and VALEUR=""
 mkstat=2
Endif
End

######################################################################################

Subprog C_REPFIN2(VALEUR)
Variable Char    VALEUR()
If [M:CFP2]REPDEB2="" and VALEUR=""
 mkstat=2
Endif
End

######################################################################################

Subprog C_ALLCLS(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]CLS
Else
 Effzo [M:CFP2]CLS : Diszo [M:CFP2]CLS
Endif
End

######################################################################################

Subprog C_ALLTSCCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]TSCCOD
Else
 Effzo [M:CFP2]TSCCOD : Diszo [M:CFP2]TSCCOD
Endif
End

######################################################################################

Subprog C_ALLBPCRSK(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M:CFP2]BPCRSKDEB, BPCRSKFIN
Else
 Effzo [M:CFP2]BPCRSKDEB, BPCRSKFIN : Diszo [M:CFP2]BPCRSKDEB, BPCRSKFIN
Endif
End

######################################################################################

Subprog C_BPCRSKFIN(VALEUR)
Variable Char    VALEUR()
If [M:CFP2]BPCRSKFIN="" and VALEUR=""
 mkstat=2
Endif
End

######################################################################################

Subprog C_TSCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer N

If VALEUR<>"" : End : Endif

# at least one of the fields must be set
If indice=dim([M:CFP2]TSCCOD)-1
 For N=0 To dim([M:CFP2]TSCCOD)-1
  If [M:CFP2]TSCCOD(N)<>"" : End : Endif
 Next

 # Mandatory value
 GMESSAGE = mess(33,7770,1)
 mkstat=2
Endif
End

######################################################################################

Subprog AS_BPCRSKDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPCRSK=2 : mkstat=1 : End : Endif
End

Subprog AS_BPCRSKFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPCRSK=2 : mkstat=1 : End : Endif
If VALEUR="" | VALEUR<[M]BPCRSKDEB : VALEUR=[M]BPCRSKDEB : Endif
End

Subprog AS_REPDEB1(VALEUR)
Variable Char    VALEUR()
If [M]ALLREP1=2 : mkstat=1 : End : Endif
End

Subprog AS_REPFIN1(VALEUR)
Variable Char    VALEUR()
If [M]ALLREP1=2 : mkstat=1 : End : Endif
If VALEUR="" | VALEUR<[M]REPDEB1 : VALEUR=[M]REPDEB1 : Endif
End

Subprog AS_REPDEB2(VALEUR)
Variable Char    VALEUR()
If [M]ALLREP2=2 : mkstat=1 : End : Endif
End

Subprog AS_REPFIN2(VALEUR)
Variable Char    VALEUR()
If [M]ALLREP2=2 : mkstat=1 : End : Endif
If VALEUR="" | VALEUR<[M]REPDEB2 : VALEUR=[M]REPDEB2 : Endif
End


######################################################################################

