#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA40   Création du paramètre LISMAT                               #
##########################################################################
# DM 90456 - 06.2013 by MM
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Creation LISMAT parameter") From LECFIC
    Call MAJ_UTIGPA40(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog MAJ_UTIGPA40(DOSSIER)
Value Char DOSSIER

  Call ECR_TRACE("UTIGPA40: Process Start on : "+DOSSIER,0) From GESECRAN

  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"LISMAT"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "LISMAT"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("LISMAT: can't create parameter",1) From GESECRAN
      Endif
  Endif
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTIGPA40 : finish",0) From GESECRAN
End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA40(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTIGPA40(APPLI)
End
