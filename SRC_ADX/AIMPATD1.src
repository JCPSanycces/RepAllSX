#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################
##  import /export avec le modèle ATDXLS          #######
##  cn 24/04/04 déclarer AST car ZAPLSTD (ZAS) utilisé ds modèle ZZAPLSTD
##   plus d'acces au spécifique ZAIMPATD1 dans le modèle
##########################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_INICRE"    : Gosub IMP_INICRE
 When "IMP_INIMOD"    : Gosub IMP_INIMOD
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CREMOD
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_CREMOD
 When "IMP_FERME"     : Gosub FERME
 When "EXPORT"        : Gosub EXPORT
 When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return


$OUVRE
Global Char SAVE_ZLAN(3)
Global Char TRAD(123)
#Global Char GIMP(255)(1..99)
If clalev([F:AST3])=0   : Local File APLSTD     [AST3]  : Endif
Return


$EXP_OUVRE
Global Integer LANOK
Global Char LANDEST(GLONLAN)

Call PARAMUTIL("LANTRA",LANDEST,"","") From SUBAUS : # Paramêtre utilisateur Langue de traduction

If clalev([F:AST2])=0   : Local File APLSTD     [AST2]  : Endif
If clalev([F:AST])=0    : Local File APLSTD     [AST]   : Endif
If clalev([F:AML])=0    : Local File AMENLOC    [AML]   : Endif
Return

$EXPORT
# l'action EXPORT est la SEULE appelée à chaque record en export
# il n'y en a pas d'autre
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="1"
Local Char LANG : LANG=LAN

# premier passage dans $EXPORT, on demande de saisir la langue de traduction
If !LANOK
    If !GSERVEUR : # Saisie de la langue uniquement en interactif
        Call SAICAR(LANDEST,mess(69,176,1),mess(66,176,1),"LAN",0,GLONLAN,"",LANOK) From GESECRAN
    Else
        LANOK=2 : # en batch l'export peut fonctionner avec la langue du paramètre utilisateur LANTRA
    Endif
Endif
# si réponse "Fin", on n'exporte rien
If LANOK<>2 : OK=0 : Return : Endif

GIMP(1)="" :  # en export laisser une colonne vide
GIMP(2)="" 

If [F:AML]MENLOC <> [F:AST]LANCHP
    Read [AML]MENLOC=[F:AST]LANCHP : # lecture Menu local / Chapître
    If fstat : Raz [F:AML] : Endif 
Endif
If LANDEST <> ''
    Read [F:AST2]CLE=[F:AST]LANCHP;[F:AST]LANNUM;LANDEST : # lecture en langue de traduction
    If fstat : Raz [F:AST2] : Endif 
Endif
Return

$EXP_ZONE
If EXPZON='[F:AST]LAN' & LANDEST <> ''
    [F:AST]LAN=LANDEST : # exporter la langue de traduction
Endif
If EXPZON='GIMP(1)+GIMP(2)'
    GIMP(1)=[F:AST]LANMES
    GIMP(2)=right$([F:AST]LANMES,(type(GIMP)-10)+1) : # GIMP trop court / à LANMES
    If [F:AML]MENLOCAL<>2 | [F:AST]LANNUM <> 0 | len([F:AST]LANMES) = len([F:AST2]LANMES)
       [F:AST]LANMES=[F:AST2]LANMES : # exporter la traduction si elle existe (sauf pour la ligne 0 des
#                                          menus locaux si les longueurs sont différentes)
    Endif
Endif
Return


$IMP_INICRE
[F:AST]LAN=[M:TRA2]ZLAN
[F:AST]LANCHP=[M:TRA2]LANCHP
[F:AST]LANNUM=[M:TRA2]LANNUM

If [M:TRA2]ZTEXTE<>""
   [F:AST]LANMES=[M:TRA2]ZTEXTE
Else
   [F:AST]LANMES=""
Endif
[F:AST]CREDAT  = date$  
[F:AST]UPDDAT  = date$ 
If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM  = time : Endif
If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM  = time : Endif
[F:AST]CREUSR  = GUSER 
[F:AST]UPDUSR  = GUSER
Return

$IMP_INIMOD
[F:AST]LAN=[M:TRA2]ZLAN

If [M:TRA2]ZTEXTE<>""
   [F:AST]LANMES=[M:TRA2]ZTEXTE
Else
   [F:AST]LANMES=""
Endif

If [F:AST]LAN <>"FRA"
  [F:AST]UPDDAT = date$ 
  If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM  = time : Endif
  [F:AST]UPDUSR = GUSER
Endif
Return


$FERME
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="0"
Local Char LANG : LANG=LAN
Return

$IMP_ZONE
Case IMPZON
    When "ZLAN"
         [M:TRA2]ZLAN=[F:AST]LAN
         GLANTRAD=[F:AST]LAN
         IMPMOD=1
         OK=0
    When "ZTEXTE"
     # en import récupérer la traduction de la variable LANMES
         [M:TRA2]ZTEXTE=[F:AST]LANMES
         IMPMOD=1
         OK=0
    When "LANNUM"
         [M:TRA2]LANNUM=[F:AST]LANNUM
         IMPMOD=1
         OK=0
Endcase
Return

$IMP_VERIF_CREMOD
If len([M:TRA2]ZTEXTE)=0
# On vérifie que le message français est non vide avant de rejeter une traduction vide (53304 - EL 09/03/2009)
   Read [F:AST3]LAN="FRA";[M:TRA2]LANCHP;[M:TRA2]LANNUM
   If !fstat & len([F:AST3]LANMES)>0
     OK=0
     GMESSAGE=mess(141,141,1)
   Endif
Endif
Return



