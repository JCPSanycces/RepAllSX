Call SRETIMOUT
End

Subprog SRETIMOUT

If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
#Read [DVA] DVA0 = "GUP";"GUP"
#If fstat
    Trbegin [DVA]
    Raz [F:DVA]
    [F:DVA]OBC = "GUP"
    [F:DVA]PARAM = "GUP"
    [F:DVA]INTX(0) += 1
    Write [DVA]
    If fstat
        Rollback
    Else
        Commit
    Endif
#Else
#    Readlock [DVA] DVA0 = "GUP";"GUP"
#    If !fstat
#        Trbegin [DVA]
#        [F:DVA]INTX(0) += 1
#        Rewrite [DVA]
#        If fstat
#            Rollback
#        Else
#            Commit
#        Endif
#    Endif
#Endif

#actihgup(0) = "TIMOUT"
Call TIMOUT From TIMOUT

End

