#** ####################################################################################################################
#*
#* Label      : action
#* Purpose    : standard entry point
#*
#*! ####################################################################################################################
$ACTION
  Case ACTION
    When "FIN"   : Gosub FIN
    When Default :
  Endcase
Return

#** ####################################################################################################################
#*
#* Label      : fin
#* Purpose    : will unlock the FAS1PAGE object
#*
#*! ####################################################################################################################
$FIN
  Unlock FAS1PAGE
Return

#** ####################################################################################################################
#*
#* SubProg    : IMPRIME
#* Purpose    : called just before the printing of the document by Crystal Reports
#*
#* Parameters :
#*   @param count  : value integer          - number of parameters
#*   @param params : variable char()(1 .. ) - parameters grid
#*
#*! ####################################################################################################################
Subprog IMPRIME(COUNT, PARAMS)
  Value Integer COUNT
  Variable Char PARAMS()(1 .. )
  Local Char PARAM(255)
  Local Char CPY(GLONCPY) : # FQ102999 5->GLONCPY
  Local Char FCY(GLONFCY) : # FQ102999 5->GLONFCY
  Local Date DATSTR
  Local Date DATEND
  Local Integer TYP
  Local Integer PLAN
  Local Integer N
  Local Integer I

  GOK = 0

  # lock the FAS1PAGE object
  Lock FAS1PAGE With lockwait = 3
  If fstat Then
    # message: Required resource is locked by another process
    Call ECR_TRACE(mess(00206,09137,1), 1) From GESECRAN
    End
  Endif

  CPY   = func GET_PARAM("cpy",  PARAMS, COUNT)
  PARAM  = func GET_PARAM("datstr", PARAMS, COUNT)
  DATSTR = gdat$(PARAM)
  PARAM  = func GET_PARAM("datend", PARAMS, COUNT)
  DATEND = gdat$(PARAM)
  PARAM  = func GET_PARAM("typper", PARAMS, COUNT)
  TYP = val(PARAM)

  # open tables
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS]) = 0 Then : Local File FISCYEAR [FIS] : Endif

  Link [CNX] With [FIS]FIY0 = [F:CNX]CPY;[F:CNX]CNX
&   As [LNK]
&   Where [F:CNX]CPY = [L]CPY
&   Order By [F:FIS]DATSTRFIY
  For [LNK]
    If TYP = 1 Then
      # fiscal year
      If [L]DATSTR = [F:FIS]DATSTRFIY and [L]DATEND = [F:FIS]DATENDFIY Then
        GOK = 1
      Endif
    Else
      # periods
      For I = 0 To [F:FIS]NBRPER
        If [L]DATSTR = [F:FIS]DATSTRPER(I) and [L]DATEND = [F:FIS]DATENDPER(I) Then
          GOK = 1
        Endif
      Next I
    Endif
  Next

  # close tables
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif
  If clalev([F:FIS]) <> 0 Then : Close Local File [FIS] : Endif

  If GOK = 0 Then
    Call ECR_TRACE(mess(1010,2299,1), 1) From GESECRAN
  Else
    Call EMPTY_TEMPORARY_TABLE()
    FCY   = func GET_PARAM("fcy",  PARAMS, COUNT)
    PARAM = func GET_PARAM("plan", PARAMS, COUNT)
    PLAN = val(PARAM)
    # check number of records
    N = func GET_RECORDS_COUNT(CPY, FCY, PLAN, TYP, DATSTR, DATEND)
    If N = 0 Then
      Call ECR_TRACE(mess(1009,2299,1), 1) From GESECRAN
      GOK = 0
    Else
      Call COLLECT_DATA(CPY, TYP, DATSTR, DATEND)
    Endif
  Endif
End

#** ####################################################################################################################
#*
#* FunProg    : get_param
#* Purpose    : obtain the value of a parameter
#* Return     : char() - empty if the parameter is missing
#*
#* Parameters :
#*   @param name   : value char()           - parameter name
#*   @param params : variable char()(1 .. ) - parameters grid
#*   @param count  : value integer          - number of parameters
#*
#*! ####################################################################################################################
Funprog GET_PARAM(NAME, PARAMS, COUNT)
  Value Char NAME()
  Variable Char PARAMS()(1 .. )
  Value Integer COUNT
  Local Integer N
  Local Integer I

  N = len(NAME)
  For I = 1 To COUNT
    If left$(PARAMS(I), N + 1) = (NAME + "=") Then
      End right$(PARAMS(I), N + 2)
    Endif
  Next
End ""

#** ####################################################################################################################
#*
#* SubProg    : collect_data
#* Purpose    : collects the data
#*
#* Parameters :
#*   @param company : value char()  - the company ID
#*   @param typper  : value integer - period type
#*   @param datstr  : value date    - start date
#*   @param datend  : value date    - end date
#*
#*! ####################################################################################################################
Subprog COLLECT_DATA(COMPANY, TYPPER, DATSTR, DATEND)
  Value Char COMPANY()
  Value Integer TYPPER
  Value Date DATSTR
  Value Date DATEND
  Local Integer I

  # open tables
  If clalev([F:T1PG]) = 0 Then : Local File TMPFAS1PAGE [T1PG] : Endif
  If clalev([F:FLUA]) = 0 Then : Local File FXDLIFL     [FLUA] : Endif
  If clalev([F:FLUB]) = 0 Then : Local File FXDLIFL     [FLUB] : Endif
  If clalev([F:FAS])  = 0 Then : Local File FXDASSETS   [FAS]  : Endif
  If clalev([F:DEP])  = 0 Then : Local File DEPREC      [DEP]  : Endif

  If TYPPER = 1 Then
    # fiscal year
    Filter [FLUA]
&     Where [F:FLUA]CPY       = COMPANY
&       and [F:FLUA]DPRPLN    = 1
&       and [F:FLUA]CODTXS    = ""
&       and [F:FLUA]FCYORI    = ""
&       and [F:FLUA]TXSCATORI = ""
&       and [F:FLUA]FIYSTRDAT = DATSTR
&       and [F:FLUA]FIYENDDAT = DATEND
&       and [F:FLUA]PERSTRDAT = [0/0/0]
&       and [F:FLUA]PERENDDAT = [0/0/0]
&     Order By [F:FLUA]AASREF
  Else
    # periods
    Filter [FLUA]
&     Where [F:FLUA]CPY       = COMPANY
&       and [F:FLUA]DPRPLN    = 1
&       and [F:FLUA]CODTXS    = ""
&       and [F:FLUA]FCYORI    = ""
&       and [F:FLUA]TXSCATORI = ""
&       and [F:FLUA]PERSTRDAT = DATSTR
&       and [F:FLUA]PERENDDAT = DATEND
&     Order By [F:FLUA]AASREF
  Endif

  Columns [FLUA] (AASREF)

  Call DEBTRANS() From GLOCK
  Trbegin [T1PG], [FLUA]
  # main loop
  For [FLUA]
    Raz [T1PG]
    [F:T1PG]CPY    = COMPANY
    [F:T1PG]AASREF = [F:FLUA]AASREF

    # collect data
    If TYPPER = 1 Then
      # fiscal year
      Link [FLUB] With [FAS]FAS1 = [F:FLUB]CPY;[F:FLUB]AASREF,
&                      [DEP]DEP0 = [F:FLUB]AASREF;[F:FLUB]DPRPLN;[F:FLUB]FIYENDDAT;[F:FLUB]FIYENDDAT
&       As [LNK]
&       Where [F:FLUB]CPY       = [F:T1PG]CPY
&         and [F:FLUB]AASREF    = [F:T1PG]AASREF
&         and [F:FLUB]CODTXS    = ""
&         and [F:FLUB]FCYORI    = ""
&         and [F:FLUB]TXSCATORI = ""
&         and [F:FLUB]FIYSTRDAT = DATSTR
&         and [F:FLUB]FIYENDDAT = DATEND
&         and [F:FLUB]PERSTRDAT = [0/0/0]
&         and [F:FLUB]PERENDDAT = [0/0/0]
&       Order By [F:FLUB]DPRPLN
    Else
      # periods
      Link [FLUB] With [FAS]FAS1 = [F:FLUB]CPY;[F:FLUB]AASREF,
&                      [DEP]DEP0 = [F:FLUB]AASREF;[F:FLUB]DPRPLN;[F:FLUB]FIYENDDAT;[F:FLUB]PERENDDAT
&       As [LNK]
&       Where [F:FLUB]CPY       = [F:T1PG]CPY
&         and [F:FLUB]AASREF    = [F:T1PG]AASREF
&         and [F:FLUB]CODTXS    = ""
&         and [F:FLUB]FCYORI    = ""
&         and [F:FLUB]TXSCATORI = ""
&         and [F:FLUB]PERSTRDAT = DATSTR
&         and [F:FLUB]PERENDDAT = DATEND
&       Order By [F:FLUB]DPRPLN
    Endif

    I = 0
    For [LNK]
      [F:T1PG]DPRPLN(I)    = [F:DEP]DPRPLN
      [F:T1PG]DPM(I)       = [F:DEP]DPM
      [F:T1PG]DPRDUR(I)    = [F:DEP]DPRDUR
      [F:T1PG]DPRRAT(I)    = [F:DEP]DPRRAT
      [F:T1PG]RSDVAL(I)    = [F:DEP]RSDVAL
      [F:T1PG]STRDPRDAT(I) = [F:DEP]STRDPRDAT
      [F:T1PG]ENDDPRDAT(I) = [F:DEP]ENDDPRDAT
      [F:T1PG]DPRBAS(I)    = [F:DEP]DPRBAS
      [F:T1PG]DPRCUM(I)    = [F:DEP]DPRCUM
      [F:T1PG]NBV(I)       = [F:DEP]NBV
      I += 1
      If I > 5 Then
        Break
      Endif
    Next

    [F:T1PG]CREUSR = GUSER
    [F:T1PG]CREDAT = date$

    Write [F:T1PG]
    If fstat <> 0 Then
      GOK = 0
      Call FSTA("T1PG") From GLOCK
      Break
    Endif
  Next
  If GOK = 0 Then
    Rollback
    # message: Rollback following error in transaction
    Call ECR_TRACE(mess(17,107,1), 1) From GESECRAN
  Else
    Commit
  Endif

  Columns [FLUA]

  Filter [FLUA]

  # close tables
  If clalev([F:T1PG]) <> 0 Then : Close Local File [T1PG] : Endif
  If clalev([F:FLUA]) <> 0 Then : Close Local File [FLUA] : Endif
  If clalev([F:FLUB]) <> 0 Then : Close Local File [FLUB] : Endif
  If clalev([F:FAS])  <> 0 Then : Close Local File [FAS]  : Endif
  If clalev([F:DEP])  <> 0 Then : Close Local File [DEP]  : Endif
End

#** ####################################################################################################################
#*
#* SubProg    : empty_temporary_table
#* Purpose    : clean-up the temporary table
#*
#*! ####################################################################################################################
Subprog EMPTY_TEMPORARY_TABLE()
  If clalev([F:T1PG]) = 0 Then : Local File TMPFAS1PAGE [T1PG] : Endif
  Trbegin [T1PG]
  Delete [T1PG] Where CREUSR = GUSER # and CREDAT < date$
  If fstat = 1 Then
    Rollback
    # message: Problem in deleting the temporary file
    Call ECR_TRACE(mess(155,197,1), 1) From GESECRAN
    #
    # no need to stop the process at this point
    #
  Else
    Commit
  Endif
  If clalev([F:T1PG]) <> 0 Then : Close Local File [T1PG] : Endif
End

#** ####################################################################################################################
#*
#* FunProg    : get_records_count
#* Purpose    : obtain the records count based on the current selection criteria
#* Return     : integer - records count
#*
#* Parameters :
#*   @param company : value char() - company name
#*   @param site    : value char() - company site
#*   @param plan    : value integer - the plan
#*   @param typper  : value integer - period type
#*   @param datstr  : value date   - start date
#*   @param datend  : value date   - end date
#*
#*! ####################################################################################################################
Funprog GET_RECORDS_COUNT(COMPANY, SITE, PLAN, TYPPER, DATSTR, DATEND)
  Value Char COMPANY()
  Value Char SITE()
  Value Integer PLAN
  Value Integer TYPPER
  Value Date DATSTR
  Value Date DATEND
  Local Integer RESULT

  # open tables
  If clalev([F:FLU]) = 0 Then : Local File FXDLIFL   [FLU] : Endif
  If clalev([F:FAS]) = 0 Then : Local File FXDASSETS [FAS] : Endif

  If SITE = "" Then
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  ""
&       and [F:FLU]FCYORI    =  ""
&       and [F:FLU]TXSCATORI =  ""
&     Order By [F:FLU]AASREF
  Else
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  ""
&       and [F:FLU]FCYORI    =  ""
&       and [F:FLU]TXSCATORI =  ""
&     Order By [F:FLU]AASREF
  Endif

  If TYPPER = 1 Then
    Filter [LNK]
&     Where [F:FLU]FIYSTRDAT = DATSTR
&       and [F:FLU]FIYENDDAT = DATEND
&       and [F:FLU]PERSTRDAT = [0/0/0]
&       and [F:FLU]PERENDDAT = [0/0/0]
  Else
    Filter [LNK]
&     Where [F:FLU]PERSTRDAT = DATSTR
&       and [F:FLU]PERENDDAT = DATEND
  Endif

  RESULT = rowcount([LNK])

  Filter [LNK]

  # close tables
  If clalev([F:FLU]) <> 0 Then : Close Local File [FLU] : Endif
  If clalev([F:FAS]) <> 0 Then : Close Local File [FAS] : Endif
End RESULT

