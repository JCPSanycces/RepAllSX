#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char    ACTMAS
Local Integer NUMACT
Local Integer ACTGESPLN

ACTMAS="TEST"
ACTGESPLN=1
TRTACTMAS="TRM"+ACTMAS

Call OBJET("MFS",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
#    GESTION DES ACTIONS METIER SUR LES OBJETS METIERS / TRAITEMENTS COMMUNS   #
#    ACTIONS MASSIVES - OBJETS MFS de visu/mise à jour du contenu de la table  #
#                       temporaire TRTMASFAS                                   #
#    GBN                                                                       #
#    Création le     : 11/12/2003                                              #
#    Modification V5 : 01/10/2007                                              #
################################################################################
# MDJ   09.02.2015  FQ100398  : Suppression site géographique
# MDJ   12.06.2013  FQ82871   : Adaptations pour Convergence (pcolor)
# MDJ   22.12.2010  FQ70141   : Vérification de sources (interne)
# GLE   07.09.2009  FQ57624   : Standard Edition
################################################################################

$ACTION

Case ACTION
 When "VARIANTE"    : Gosub VARIANTE
 When "OUVRE"       : Gosub OUVRE
 When "LIENS0"      : Gosub LIENS0
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "SETBOUT"     : Gosub SETBOUT
 When "ABANDON"     : Gosub ABANDON
 When "FIN"         : Gosub FIN
 When "EXEBOUT"     : Gosub BOUTON   # Fq-34831
 When Default       : ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Endcase
Return

########################################################################
$VARIANTE
 If [F:AWI]TRN<>ACTMAS
  OK=0
 Endif
Return

########################################################################
$OUVRE
 Local Char ORIACT
 If ACTGESPLN=2
  If !(clalev([F:TPF])) : Local File TMPPLNFAS [TPF] : Endif
 Endif
Return

########################################################################
$LIENS0
 # Ajouter critère pour complément de filtre dans TRTACTMAS
 Filter [MFS] Where (TRTNUM=NUMACT)
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return

########################################################################
$LIENS
 Local Char    MASQUE
 Local Integer RC

#--> Récupération du nom du masque d'abréviation MFS0 associé à la fenêtre GBOITE

 Call GET_MASQUE(GBOITE,MASQUE,RC) From SUBMAS

#--> En fonction du flag FLGMOD, on active ou on grise les zones saisissables de la ligne

 If [F:MFS]FLGMOD=G_NON
  Call AFFICHE_LIGNE("DISZO",MASQUE,"MFS0",1,nolign-1,RC) From SUBMAS
 Else
  Call AFFICHE_LIGNE("ACTZO",MASQUE,"MFS0",1,nolign-1,RC) From SUBMAS
 Endif

 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS

Return
########################################################################
$LIENS2
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
 Filter [MFS]

Return
########################################################################
$APRES_MODIF
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$AVANTBOUT
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$APRES_CHOI

 Case REPONSE
  When GSTAEND
   # GBN - 23/03/2004 - Pour que le message ne pollue plus la V2 du modèle tout en conservant le fonctionnement V1
   #Local Integer POK
   #Call OUINON ("Vous allez abandonner le traitement sans mise à jour.\Voulez-vous continuer ?",POK) From GESECRAN
   #Case POK
   # When 1
   #  REPONSE=0
   #  Return
   # When Default
   #Endcase
   ABANDON_TRT=1
   Return
  When GSTAENR
   If ACTGESPLN=G_OUI
     Call SAVE_PLAN()
   # Fq-34381
   Else
      If  ACTMAS =  "FASSPLM"     : Gosub ACTION From =TRTACTMAS : Endif
   #</Fq-34381
   Endif
  When GSTABOU+1
   GOK=1
   REPONSE=GSTAEND
   ABANDON_TRT=0
   Return
  When Default
   ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
 Endcase
Return
########################################################################
$INICRE
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$INIMOD
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$MODIF
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$APRES_MOD
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$SETBOUT

If GREP<>"" | REP<>""
 Call VIREBOUT (CHAINE, "V") From GOBJET                      : # Validation / Fin
 Disable GSTAEND
Else
 Enable GSTAEND
Endif
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS

Return
########################################################################
$ABANDON
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$FIN
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
########################################################################
$BOUTON
 #Infbox "BOUTON MFS"
 ORIACT="TRTOBJ" : Gosub ACTION From =TRTACTMAS
Return
##########################################################################
## Traitements appelés par Call ou Gosub
##########################################################################

#=========================================================================
#  Ce s/p permet d'enregistrer dans la table temporaire les modifications
#  effectuées dans le tableau par plan
#=========================================================================
Subprog SAVE_PLAN()

Local Integer SAV_NOLIGN
If !(clalev([F:TPF])) : Local File TMPPLNFAS [TPF] : Endif

If !([M:MFS0]NBPLN=0)
 SAV_NOLIGN=nolign
 Raz nolign
 For nolign=1 To [M:MFS0]NBPLN
  Read [TPF]TPF0=NUMACT;OBJREFPLN(nolign-1);DPRPLN(nolign-1)
  If !fstat
   #-----------------------------------------#
   # On appelle l'étiquette $SAVEPLN dans le #
   # traitement de l'action pour chaque enr  #
   # du tableau de plan afin que l'on puisse #
   # ecrire les lignes transférant les zones #
   # du tableau dans l'enregistrement de la  #
   # table temporaire par plan.              #
   #-----------------------------------------#
   [F:TPF]FLGERR=[M:MFS0]FLGERRPLN(nolign-1)
   [F:TPF]FLGMOD=[M:MFS0]FLGMODPLN(nolign-1)
   Gosub SAVEPLN From =TRTACTMAS
   #-----------------------------------------#
   Rewrite [TPF]
   # ? Qu'est ce-qu'on fait si ça se plante ??????
  Endif
 Next nolign
 nolign=SAV_NOLIGN
Endif

End
#=========================================================================
#  Ce s/p permet de charger les informations par plan du BCO sur lequel
#  on vient de cliquer.
#=========================================================================
Subprog LOAD_PLAN(PNOLIGN)
Value Integer PNOLIGN

Local Char    MASQUE
Local Integer RC
Local Char CRITSEL(255)
Local Integer SAV_NOLIGN
Local Integer ERR_PLN
If !(clalev([F:TPF])) : Local File TMPPLNFAS [TPF] : Endif

Call GET_MASQUE(GBOITE,MASQUE,RC) From SUBMAS

CRITSEL='TRTNUM=NUMACT & OBJREF=[M:MFS0]OBJREF(PNOLIGN-1)'
 Filter [TPF] Where evalue(CRITSEL)
 SAV_NOLIGN=nolign
 Raz nolign, ERR_PLN
 For [TPF]
  nolign+=1
  [M:MFS0]OBJREFPLN(nolign-1) = [F:TPF]OBJREF
  [M:MFS0]OBJREFDSP(0)        = [F:TPF]OBJREF
  [M:MFS0]FLGERRPLN(nolign-1) = [F:TPF]FLGERR
  If [F:TPF]FLGERR=2 : ERR_PLN=1 : Endif
  [M:MFS0]FLGMODPLN(nolign-1) = [F:TPF]FLGMOD
  [M:MFS0]DPRPLN(nolign-1)    = [F:TPF]DPRPLN
    #If GUSER="GBO" : Infbox "[F:TPF]FLGMOD"-num$([F:TPF]FLGMOD) : Endif # Tst
    #If GUSER="GBO" : Infbox "[F:TPF]FLGERR"-num$([F:TPF]FLGERR) : Endif # Tst
  #-> On active la ligne si le flag FLGMOD est à G_OUI
  If [F:TPF]FLGMOD=G_OUI
   Call AFFICHE_LIGNE("ACTZO",MASQUE,"MFS0",2,nolign-1,RC) From SUBMAS
  Endif
  #-----------------------------------------#
  # On appelle l'étiquette $LOADPLN dans le #
  # traitement de l'action pour chaque enr  #
  # de la table temporaire lu afin que l'on #
  # puisse écrire les lignes transférant les#
  # zones spécifiques à l'action de l'enr   #
  # dans le tableau de plan.                #
  #-----------------------------------------#
  Gosub LOADPLN From =TRTACTMAS
  #-----------------------------------------#
  #-> On grise la ligne si le flag FLGMOD est à G_NON
  If [F:TPF]FLGMOD=G_NON
   Call AFFICHE_LIGNE("DISZO",MASQUE,"MFS0",2,nolign-1,RC) From SUBMAS
  Endif
 Next
 #-> Demande MWA : ne pas afficher les plans si BCO en erreur
 #   -----------
 #   Si le BCO est en erreur et que au moins l'un des plan est en erreur
 #   on affiche le tableau des plans. Si aucun des plans est en erreur
 #   on affiche pas le tableau de plan
 #
 If [M:MFS0]FLGERR(PNOLIGN-1)=2
  If ERR_PLN=0
   Raz [M:MFS0]NBPLN
  Elsif ERR_PLN=1
   [M:MFS0]NBPLN=nolign
  Endif
 Elsif [M:MFS0]FLGERR(PNOLIGN-1)=1
  [M:MFS0]NBPLN=nolign
 Endif
 Affzo [M:MFS0]10
 nolign=SAV_NOLIGN
 Filter [TPF]
End

#=========================================================================
#  Ce s/p permet de rendre le nom du premier masque d'une fenêtre passée
#  en paramètre.
#=========================================================================
Subprog GET_MASQUE(PWIN,RMASK,RCOD)
Value    Char    PWIN
Variable Char    RMASK
Variable Integer RCOD

Raz RCOD
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif

Read [F:AWI]AWI0=PWIN
If fstat
 RCOD=1
 End
Endif
RMASK=[F:AWI]NOMMSK(0)

End

#=========================================================================
#  Ce s/p permet de rendre une ligne saisissable ou non saisissable en
#  fonction de la valeur de FLGMOD de l'enregistrement correspondant à la
#  ligne
#=========================================================================
Subprog AFFICHE_LIGNE(PTRT,PMASK,PCLASSE,PBLOC,PINDICE,RCOD)
Value    Char    PTRT
Value    Char    PMASK
Value    Char    PCLASSE
Value    Integer PBLOC
Value    Integer PINDICE
Variable Integer RCOD

Local Char    CLASSE           : CLASSE="[M:"+PCLASSE+"]"
Local Char    CHAMP(250)

If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

Filter [AMZ] Where (CODMSK=PMASK & NUMBLOC=PBLOC & CODTYP<>"ABS" & SAIAFF=1)
For [AMZ]
 Raz CHAMP
 CHAMP+=CLASSE+[F:AMZ]CODZON+"("+num$(PINDICE)+")"
 #-> On vérifie d'abord que le champ existe
 If evalue("dim("+CHAMP+")>0")
 #-> Puis on modifie son statut
  If PTRT="DISZO"
   Grizo =CHAMP
   Diszo =CHAMP
  Elsif PTRT="ACTZO"
   Actzo =CHAMP
  Endif
 Endif
Next
Filter [AMZ]
End

#---------------------------------------------------------------------
# Dans un tableau listant les BCO, recherche et suppression des lignes
# correspondant aux composants d'un BCO principal passé en paramétre
#---------------------------------------------------------------------
Subprog SUPPRIME_COMPO(PAASREF,RNBRCMPSUP)
Value Char PAASREF          # Référence du BCO principal dont il faut supprimer les composants
Variable Integer RNBRCMPSUP # Nombre de composants supprimés

Local Integer FIN    # Booléen de fin de recherche
Local Integer I_CMP  # Indice du composant trouvé

FIN         = 0
NBR_CMP_SUP = 0

Repeat
 I_CMP=find(PAASREF,[M:MFS0]CMP)
 If I_CMP=0
  FIN=1
 Else
  Dela I_CMP-1 [M:MFS0]NBOBJ
  [M:MFS0]NBOBJ-=1
  RNBRCMPSUP+=1
 Endif
Until FIN

End

##########################################################################
## Gestion du masque MFS0
##########################################################################

#=========================================================================
#  Actions champ sur les zones communes NBOBJ / CPY / OBJREF / AASDES1
#=========================================================================

#-> Tableau par bien comptable

Subprog AV_NBOBJ
 # Si l'action est gérée par plan, que l'on vient de changer de ligne et que le
 # nolign est bien dans le tableau, on sauve les infos du tableau par plan
 # de l'objet d'où l'on venait, pour afficher les infos par plan de l'objet
 # sur lequel on a cliqué

 If status=71
  Enable GSTAANU
 Endif

 If ACTGESPLN=G_OUI & (status=71 | status=75 | status=1 | status=31) & !(nolign>[M:MFS0]NBOBJ)
  Call SAVE_PLAN         # gbn - 27/04/04 - Sortie : on sauve les infos par plan avant changement de ligne
  Call LOAD_PLAN(nolign)
 Endif

 # Gbn - 060904 - Bug 24620
 If ACTGESPLN=G_OUI & status=65

  #If GUSER="GBO" : Infbox "nolign / [M:MFS0]NBOBJ"-num$(nolign)+"/"+num$([M:MFS0]NBOBJ) : Endif
  #If GUSER="GBO" : Infbox "[M:MFS0]OBJREF(nolign-1)"-[M:MFS0]OBJREF(nolign-1) : Endif
  #If GUSER="GBO" : Infbox "[M:MFS0]OBJREFDSP(0)"-[M:MFS0]OBJREFDSP(0) : Endif

  Call SAVE_PLAN
  If !(nolign>[M:MFS0]NBOBJ)
   Call LOAD_PLAN(nolign)
  Else
   Raz [M:MFS0]NBPLN
  Endif

 Endif

 Case ACTMAS
   When "FASTRF"      : Call AV_NBOBJ     From TRTFASTRF
   When "FASRVA"      : Call AV_NBOBJ_MFS From TRTFASRVA
   When "FASISS"      : Call AV_NBOBJ     From TRTFASISS
   When "FASSPLM"     : Call AV_NBOBJ_MFS From TRTFASSPLM
   When "FASTRFC"     : Call AV_NBOBJ_MFS From TRTFASTRFC
 Endcase

 Gosub CONDITIONNE_IAS_FASTRFCR From TRTFAS : # FQ57624
End
#===========================
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 If [M:MFS0]FLGERR(nolign-1)=2
  Chgstl NBOBJ(nolign-1)  With "AWARNHIGH"
  pcolor=GCOUL(1)  # Rouge
 Else
  Chgstl NBOBJ(nolign-1)  With ""
  pcolor=GCOUL(0)  # Normal
 Endif
End
#===========================
#-> Tableau par plan
Subprog AV_NBPLN
 If status=71
  Disable GSTAANU
 Endif
End

Subprog APRES_NBPLN
 If status=21
  Local Integer POK
  Call OUINON ("Voulez-vous enregistrer les modifications \apportées aux informations par plan",POK) From GESECRAN
  If POK=2
   Call SAVE_PLAN()
  Endif
 Endif
End
#===========================
Subprog AV_OBJREFDSP(VALEUR)
Variable Char    VALEUR()

 If [M:MFS0]FLGERR(find([M:MFS0]OBJREFDSP(0),[M:MFS0]OBJREF)-1)=2
  Local Integer I_ERRPLN
  #*Fq-82871
  #* - on garde les pcolor pour l'appli. C/S
  #* - on ajoute un chgstl pour Convergence
  If find(2,[M:MFS0]FLGERRPLN)
   Chgstl NBPLN(nolign-1)  With "AWARNHIGH"
   pcolor=GCOUL(1)  # Rouge
  Else
   Chgstl NBPLN(nolign-1)  With ""
   pcolor=GCOUL(0)  # Normal
  Endif
 Else
  Chgstl NBPLN(nolign-1)  With ""
  pcolor=GCOUL(0)  # Normal
 Endif
End
#===========================
Subprog AV_DPRPLN(VALEUR)
Variable Integer VALEUR

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 If [M:MFS0]FLGERRPLN(nolign-1)=2
  Chgstl NBPLN(nolign-1)  With "AWARNHIGH"
  pcolor=GCOUL(1)  # Rouge
 Else
  Chgstl NBPLN(nolign-1)  With ""
  pcolor=GCOUL(0)  # Normal
 Endif
End
#=========================================================================
#  Action champ sur les zones spécifiques aux actions massives
#=========================================================================
Subprog AV_AASDES1(VALEUR)
Variable Char    VALEUR()

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 Case ACTMAS
  When "TEST"
     Chgstl NBOBJ(nolign-1)  With "AWARNLOW"
     pcolor=GCOUL(3)  # Bleu
  When Default
 Endcase
End
