#<AdxTL>@(#)4.0.0.0 $Revision$
#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Lien dynamique
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTELTDLK [AYL1]
 Local File ATEXTE    [ATX1]
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTELTDLK"  [AYL1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".AYTLINES"   [AYN1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTELTDLK  [AYL2]
 Local File ATEXTE     [ATX2]
 Local File AYTLINES   [AYN2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTELTDLK"  [AYL2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".AYTLINES"   [AYN2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYL1]AYL0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYL1",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYL2]AYL0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYL2]DLKCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYL1], [ATX1], [AYN1] , [AXX1]
&              , [AYL2], [ATX2], [AYN2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYL2] , [ATX2], [AYN2]
 If DES_HASELT
     Delete [AYN2] Where FCYCOD=[L]FCYDES  & LINCODTYP=4 & LINCOD=toupper([L]DES_ELTCOD)
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLIN" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_COP
     Endif
     Delete [AYL2] Where FCYCOD=[L]FCYDES and DLKCOD=DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTDLK" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYL2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif
 #
 For [AYL1]AYL0 Where FCYCOD=[L]FCYORG & DLKCOD=[L]ELTCOD
  [F:AYL2] = [F:AYL1]
  [F:AYL2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTELTDLK","INTIT",[F:AYL1]FCYCOD,[F:AYL1]DLKCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYL2]UPDUSR = GUSER
  [F:AYL2]UPDDAT = date$
  # [F:AYL2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYL2") From AYTCOP # 93575
  [F:AYL2]BRWX3  = [F:AYL2]FCYCOD+"_"+[F:AYL2]DLKCOD
#*  [F:AYL2]CODACT = [L]ELTCODACT
  Write [AYL2]
  If fstat
   GOK=0 : Call FSTA("AYL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 #
 For [AYN1]AYN0 Where FCYCOD=[L]FCYORG & LINCODTYP=4 & LINCOD=toupper([L]ELTCOD)
  [F:AYN2] = [F:AYN1]
  [F:AYN2]FCYCOD = [L]FCYDES
  Write [AYN2]
  If fstat
   GOK=0 : Call FSTA("AYN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
