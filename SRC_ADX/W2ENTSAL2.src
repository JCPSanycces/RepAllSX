Call AM_WEXOEND3(zc)
If !mkstat & GOBJET
 zoncou = "WEXOEND3" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WEXOEND3(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_WEXOEND3(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WEXOEND3" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_WEXOCOD4
Onevent CONTROL Call C_WEXOCOD4(zc) From W2ENTSAL2
Onevent BEFORE_INPUT Call AS_WEXOCOD4(zc) From W2ENTSAL2
Onevent AFTER_CHANGE Gosub AMM_WEXOCOD4 From W2ENTSAL2
Return

Subprog AS_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9535,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WEXOCOD4(VALEUR) From SUBHRENT
If mkstat=2
 [M]WEXOCOD4(INDIC) = VALEUR
 Affzo WEXOCOD4(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WEXOCOD4(zc) From W2ENTSAL2
Onkey   2 Titled GBOUTS Call S_WEXOCOD4(zc) From W2ENTSAL2
Onkey 144 Titled GBOUTP Call P_WEXOCOD4(zc) From W2ENTSAL2
Onkey 146 Titled GBOUTA Call SA_WEXOCOD4(zc) From W2ENTSAL2
Gosub _AFF
End

Subprog C_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
## Action CONTEXO
Call CONTEXO(VALEUR) From SUBEXO
If mkstat : GERR = 1 : GZONE = "WEXOCOD4" : GZNUM = 0 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("EXO","!",VALEUR,num$(GCURLEG),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WEXOCOD4" : GZNUM = 0 : Endif
 If !mkstat
  ## Action STD
  Call C_WEXOCOD4(VALEUR) From SUBHRENT
  If mkstat : GERR = 1 : GZONE = "WEXOCOD4" : GZNUM = 0 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WEXOCOD4
Call AM_WEXOCOD4(zc)
If !mkstat & GOBJET
 zoncou = "WEXOCOD4" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WEXOCOD4(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WEXOCOD4" : GZNUM = 0 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWEXOCOD4)")>indice
 [M]WEXOCOD4(indice) = VALEUR
 Affzo ZWEXOCOD4(indice)
Endif
Gosub _AFF
End

Subprog S_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEXO
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEXO"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEXO","SUBEXO","SPEEXO") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
Call OBJET("EXO",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EXO"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEXOCOD4(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("EXO",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWEXOCOD4
Onevent BEFORE_AREA Gosub AV_ZWEXOCOD4 From W2ENTSAL2
Return

$AV_ZWEXOCOD4
Call LECTEXTRA(zc,"EXOPAY","DES",num$(GCURLEG),num$([M]WEXOCOD4(indice))) From ATEXTRA
Gosub _AFF
Return

