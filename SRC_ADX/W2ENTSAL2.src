#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_WMTH
Onevent AFTER_CHANGE Gosub AMM_WMTH From W2ENTSAL2
Return

$AMM_WMTH
Call AM_WMTH(zc)
If !mkstat & GOBJET
 zoncou = "WMTH" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WMTH(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_WMTH(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WMTH" : GZNUM = 45735 : Endif
Gosub _AFF
End

$ON_WCUR
Onevent BEFORE_INPUT Call AS_WCUR(zc) From W2ENTSAL2
Onevent CONTROL Call C_WCUR(zc) From W2ENTSAL2
Onevent AFTER_CHANGE Gosub AMM_WCUR From W2ENTSAL2
Return

Subprog AS_WCUR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3837,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WCUR(VALEUR) From SUBHRENT
If mkstat=2
 [M]WCUR(INDIC) = VALEUR
 Affzo WCUR(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WCUR(zc) From W2ENTSAL2
Onkey   2 Titled GBOUTS Call S_WCUR(zc) From W2ENTSAL2
Onkey 144 Titled GBOUTP Call P_WCUR(zc) From W2ENTSAL2
Onkey 146 Titled GBOUTA Call SA_WCUR(zc) From W2ENTSAL2
Gosub _AFF
End

Subprog C_WCUR(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCU","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "WCUR" : GZNUM = 1003259 : Endif
If !mkstat
 ## Action STD
 Call C_WCUR(VALEUR) From SUBHRENT
 If mkstat : GERR = 1 : GZONE = "WCUR" : GZNUM = 1003259 : Endif
Endif
Gosub _AFF
End

$AMM_WCUR
Call AM_WCUR(zc)
If !mkstat & GOBJET
 zoncou = "WCUR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WCUR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WCUR(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WCUR" : GZNUM = 1003259 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWCUR)")>indice
 [M]WCUR(indice) = VALEUR
 Affzo ZWCUR(indice)
Endif
Gosub _AFF
End

Subprog S_WCUR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCU"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_WCUR(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCU",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WCUR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCU"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WCUR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCU",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWCUR
Onevent BEFORE_AREA Gosub AV_ZWCUR From W2ENTSAL2
Return

$AV_ZWCUR
Call LECTEXTRA(zc,"TABCUR","INTDES",num$([M]WCUR(indice)),"") From ATEXTRA
Gosub _AFF
Return

