#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# IMPSOQ : Import Standard des Commandes Ouvertes
#          Export Standard des Commandes Ouvertes
#----------------------------------------------------------------------
#
#######################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
Endcase
Return

#######################################################################
#                        IMPORT
#######################################################################

$IMP_OUVRE
Local Integer TUNNEL
# --- Déclaration classe ecran pour les compléments --- #
Local Mask COMPDLIV [CPDL]

# --- Ouverture de SORDER et SORDERC avec autres abb
If !clalev([F:SOH1]) : Local File SORDER  [SOH1] : Endif
If !clalev([F:SOC1]) : Local File SORDERC [SOC1] : Endif

# --- Zones de reconnaissance ligne
Local  Integer I_SOHNUM, I_CUSORDREF, I_BPCORD, I_BPAADD, I_SOPLIN, I_ITMREF, I_ITMREFBPC
Local  Integer I_GIMP6, I_GIMP8
Global Integer G_IMPNUMLIG

Call TST_CHAMP("SOC","*6",I_GIMP6) From SUBIMPOBJ
Call TST_CHAMP("SOC","*8",I_GIMP8) From SUBIMPOBJ
Call TST_CHAMP("SOC","SOHNUM",I_SOHNUM) From SUBIMPOBJ
Call TST_CHAMP("SOH","CUSORDREF",I_CUSORDREF) From SUBIMPOBJ
Call TST_CHAMP("SOC","BPCORD",I_BPCORD) From SUBIMPOBJ
Call TST_CHAMP("SOC","BPAADD",I_BPAADD) From SUBIMPOBJ
Call TST_CHAMP("SOC","SOPLIN",I_SOPLIN) From SUBIMPOBJ
Call TST_CHAMP("SOC","ITMREF",I_ITMREF) From SUBIMPOBJ
Call TST_CHAMP("SOC","ITMREFBPC",I_ITMREFBPC) From SUBIMPOBJ
Call TST_CHAMP("SOQ","IMPNUMLIG",G_IMPNUMLIG) From SUBIMPOBJ : # no. ligne externe

# --- Test de présence des champs dans le paramétrage
Local Integer I_EARQTYCUS, I_EARDATCUS, I_QTY, I_DEMDLVDAT, I_CAD, I_STOFCY
Local Integer I_USEPLC, I_BPTNUM, I_MDL, I_DAYLTI, I_DLVPIO, I_PCK, I_PCKCAP
Global Integer I_DEMDLVREF : # necessaire car appel dans un call
Call TST_CHAMP("SOC","EARQTYCUS",I_EARQTYCUS) From SUBIMPOBJ
Call TST_CHAMP("SOC","EARDATCUS",I_EARDATCUS) From SUBIMPOBJ
Call TST_CHAMP("SOQ","QTY",I_QTY) From SUBIMPOBJ
Call TST_CHAMP("SOQ","DEMDLVREF",I_DEMDLVREF) From SUBIMPOBJ
Call TST_CHAMP("SOQ","DEMDLVDAT",I_DEMDLVDAT) From SUBIMPOBJ
Call TST_CHAMP("SOQ","CAD",I_CAD) From SUBIMPOBJ
Call TST_CHAMP("SOQ","STOFCY",I_STOFCY) From SUBIMPOBJ
Call TST_CHAMP("SOQ","USEPLC",I_USEPLC) From SUBIMPOBJ
Call TST_CHAMP("SOQ","BPTNUM",I_BPTNUM) From SUBIMPOBJ
Call TST_CHAMP("SOQ","MDL",I_MDL) From SUBIMPOBJ
Call TST_CHAMP("SOQ","DAYLTI",I_DAYLTI) From SUBIMPOBJ
Call TST_CHAMP("SOQ","DLVPIO",I_DLVPIO) From SUBIMPOBJ
Call TST_CHAMP("SOQ","PCK",I_PCK) From SUBIMPOBJ
Call TST_CHAMP("SOQ","PCKCAP",I_PCKCAP) From SUBIMPOBJ

Return


#######################################################################
### Des lecture d'un enregistrement 
$AP_IMPORT
Local Integer I1
Case IMPFIC
  When "SOC"
    If I_GIMP6
      I_BPCORD=1 
      I1=instr(1,GIMP(6),"~")
      If I1 [F:SOC]BPCORD=left$(GIMP(6),I1-1) Else [F:SOC]BPCORD=GIMP(6) Endif       
    Endif
    If I_GIMP8
      I_BPAADD=1
      I1=instr(1,GIMP(8),"~")
      If I1 [F:SOC]BPAADD=right$(GIMP(8),I1+1) Else [F:SOC]BPAADD=GIMP(8) Endif
    Endif
    If !I_SOPLIN
      If    I_CUSORDREF & I_BPCORD & I_BPAADD & I_ITMREFBPC
        Read [SOC1]SOC2=[F:SOC]CUSORDREF;[F:SOC]BPCORD;[F:SOC]BPAADD;[F:SOC]ITMREFBPC 
        If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
      Elsif I_CUSORDREF & I_ITMREFBPC
        Filter [SOC1] Where CUSORDREF=[F:SOC]CUSORDREF & ITMREFBPC=[F:SOC]ITMREFBPC
        Read [SOC1]SOC2 First 
        If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN: Endif
        Read [SOC1]SOC2 Next
        If !fstat & I_ITMREF
          Filter [SOC1] Where CUSORDREF=[F:SOC]CUSORDREF & ITMREFBPC=[F:SOC]ITMREFBPC
&                           & ITMREF=[F:SOC]ITMREF
          Read [SOC1]SOC2 First 
          If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
          Read [SOC1]SOC2 Next
          If !fstat
            # plusieurs lignes du même article sur ce contrat : reconnaissance impossible 
            OK=0 : Call ECR_TRACE(mess(179,192,1),0) From GESECRAN 
          Endif
        Endif
        Filter [SOC1] 
      Elsif I_BPCORD & I_BPAADD & I_ITMREFBPC
        Filter [SOC1] Where BPCORD=[F:SOC]BPCORD & BPAADD=[F:SOC]BPAADD & ITMREFBPC=[F:SOC]ITMREFBPC
        Read [SOC1]SOC1 First 
        If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
        Read [SOC1]SOC1 Next
        If !fstat & I_ITMREF
          Filter [SOC1] Where BPCORD=[F:SOC]BPCORD & BPAADD=[F:SOC]BPAADD & ITMREF=[F:SOC]ITMREF
&                           & ITMREFBPC=[F:SOC]ITMREFBPC
          Read [SOC1]SOC1 First 
          If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
          Read [SOC1]SOC1 Next
          If !fstat
            # plusieurs lignes du même article sur ce contrat : reconnaissance impossible 
            OK=0 : Call ECR_TRACE(mess(179,192,1),0) From GESECRAN 
          Endif
        Endif
        Filter [SOC1] 
      Elsif I_CUSORDREF & I_ITMREF
        Filter [SOC1] Where CUSORDREF=[F:SOC]CUSORDREF & ITMREF=[F:SOC]ITMREF
        Read [SOC1]SOC2 First 
        If !fstat : [F:SOC]SOHNUM=[F:SOC1]SOHNUM : [F:SOC]SOPLIN=[F:SOC1]SOPLIN: Endif
        Read [SOC1]SOC2 Next
        If !fstat
          # plusieurs lignes du même article sur ce contrat : reconnaissance impossible 
          OK=0 : Call ECR_TRACE(mess(179,192,1),0) From GESECRAN 
        Endif
        Filter [SOC1] 
      Elsif I_SOHNUM & I_ITMREF
        Filter [SOC1] Where SOHNUM=[F:SOC]SOHNUM & ITMREF=[F:SOC]ITMREF
        Read [SOC1]SOC0 First 
        If !fstat : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
        Read [SOC1]SOC0 Next
        If !fstat
          # plusieurs lignes du même article sur ce contrat : reconnaissance impossible 
          OK=0 : Call ECR_TRACE(mess(179,192,1),0) From GESECRAN 
        Endif
        Filter [SOC1] 
      Elsif I_SOHNUM & I_ITMREFBPC
        Filter [SOC1] Where SOHNUM=[F:SOC]SOHNUM & ITMREFBPC=[F:SOC]ITMREFBPC
        Read [SOC1]SOC0 First 
        If !fstat : [F:SOC]SOPLIN=[F:SOC1]SOPLIN : Endif
        Read [SOC1]SOC0 Next
        If !fstat
          # plusieurs lignes du même article sur ce contrat : reconnaissance impossible 
          OK=0 : Call ECR_TRACE(mess(179,192,1),0) From GESECRAN 
        Endif
        Filter [SOC1] 
      Endif
    Endif
  When "SOQ"
    If [F:SOQ]DEMSTA=4 : [F:SOQ]DEMSTA=2 : Endif 

Endcase

Return

#######################################################################
### Lecture d'un enregistrement
$IMPORT
Local Integer OKCHAMP
Local Integer I

Case IMPFIC
    When "SOH"

    When "SOC" : 
# ---------------------------------------------------#
#     Cumul A/R                                      #
# ---------------------------------------------------#
# ---------------------------------------------------#
#     Traitement de l'avance-retard                  #
# ---------------------------------------------------#
        If I_EARQTYCUS
            [M]EARQTYCUS = [F:SOC]EARQTYCUS
        Endif
        If I_EARDATCUS
            [M]EARDATCUS = [F:SOC]EARDATCUS
        Endif
    When "SOQ": 
# ---------------------------------------------------#
#     Demande de livraison                           #
# ---------------------------------------------------#

        Gosub IMP_DECLARE From TRTX3IMP
# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        ICLEPRIM (0) = "SOQSEQ"
        ICLEPRIM (1) = "IMPNUMLIG" : ICLEBRK(1)=1 
        ICLEPRIM (2) = "DEMDLVDAT"
        NBASTAB = "NBLIG"
        Gosub FORMAT_DEMDLVDAT
        Gosub RECHERCHE_LIGNE From TRTX3IMP
        If nolign=0 : G_NLDET=1 : Endif

#           --> Traitement de suppression d'une ligne 
        If I_QTY & [F:SOQ]QTY = 0 & nolign <> 0 
            status=65 
            # --> Contrôle de suppression de lignes
            Call C_NBLIG From W1SOQ1
            If mkstat OK=0 : Return : Endif
            Call AVANT_NBLIG From W1SOQ1
            Call APRES_NBLIG From W1SOQ1
            Return
        Endif
#           --> Nouvelle ligne à insérer : Recherche de l'insetion
        If nolign=0
            Gosub RECH_NUM_INSERT
            If OK=0 Call ECR_TRACE(mess(21,192,1),0) From GESECRAN : Endif
            If nolign <> 0 
                status = 72 
            Endif
        Endif
# ---------------------------------------------------#
#     Traitement de la fenetre de complément         #
# ---------------------------------------------------#
        Gosub TRT_COMPDLIV 
Endcase
Return




#######################################################################

$IMP_ZONE
Local Integer OKCHAMP : OKCHAMP = 0
Local Char    IMPZONMSK(20), IMPZONFIC(20)


# ------------------------------------------------------------#
# Traitement particulier après chargement de l'enr. importé   #
# ------------------------------------------------------------#
# --> Raz [F:SOQ]                                             #
#     Les zones paramétrées sont chargées                     #
#     Les zones non paramétrées sont vides                    #
#     En création [M] n'est pas chargée                       #
#     En modif.,  [M] est chargée avec l'enr à modifier       #
# ------------------------------------------------------------#
If IMPFIC = "SOC" Return : Endif

Case IMPZON
    When "XDLVDAT"
# ----------------------------------------- #
#       Nom différent entre [F] et [M]      #
#       Il faut charger la zone à la main   #
# ----------------------------------------- #
        Local Char WDLVDAT(10)
        Local Integer WWEE, WMOIS, WAN
        IMPZONFIC = "DEMDLVDAT"
#       On recherche si la zone est paramétrée
        I = find(IMPZONFIC,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
        If I <> 0
#           --> Demande journalière
            If [F:SOQ]CAD = 1
                WDLVDAT = format$("D:"+GFMDAT4,[F:SOQ]DEMDLVDAT)
            Endif
#           --> Demande hebdomadaire
            If [F:SOQ]CAD = 2 
                If [F:SOQ]WEE < 10
                    WDLVDAT = "00"+num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
                Else
                    WDLVDAT = "0" +num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
                Endif
            Endif
#           --> Demande mensuelle
            If [F:SOQ]CAD = 3
                If [F:SOQ]MON < 10
                   WDLVDAT = "0"+num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
                Else
                   WDLVDAT = num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
                Endif
            Endif

#           On charge la classe [M]
            IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"        
            If evalue (IMPZONMSK) <> WDLVDAT
                IMPMOD=1
                Assign IMPZONMSK With WDLVDAT
                [M]CAD (nolign-1) = [F:SOQ]CAD
            Endif
            OK=0
        Endif
# --------------------------------------------------------------- #
#               Mise a jour du no sequentiel                      #
#               de la ligne importee si ce no externe n'est       #
#               pas renseigné                                     #
#---------------------------------------------------------------- #
        If G_IMPNUMLIG : [M]IMPNUMLIG(nolign-1)=[F:SOQ]IMPNUMLIG : Endif
        If [M]IMPNUMLIG(nolign-1)=0 : [M]IMPNUMLIG(nolign-1)=nolign : Endif
    When "QTY"
            If I_DEMDLVREF [M]DEMDLVREF(nolign-1)=[F:SOQ]DEMDLVREF Endif 
#           texte detail ( sur QTY car le no de texte est initialise dans ITMREF )
#            If G_DET & [M:IET]INDLIG(2)>0
#              If GREP="C" | (GREP="M" & G_NLDET)
#                Local Char T_TXT (3) : T_TXT="DET"
#                Gosub ECR_TEXTE From TRTX3IMP
#              Endif 
#            Endif 
    When Default :
Endcase
Return


$RECH_NUM_INSERT
#   ------------------------------------------------------------------------   #
#   Recherche du numéro d'insertion                                            #
#   ------------------------------------------------------------------------   #
Local Integer I

For I=1 To [M]NBLIG
    If [F:SOQ]CAD <= [M]CAD(I-1)

#       Le cadencement doit être >= à celui de la ligne précédente
        If I > 1 & [F:SOQ]CAD < [M]CAD(I-2) 
            OK=0 : Break
        Endif

#       La date est inférieure à la précédente : C'est ok 
        If [F:SOQ]DEMDLVDAT < [M]DEMDLVDAT(I-1)
            nolign=I : Break
        Endif
    Endif
Next

Return


$FORMAT_DEMDLVDAT
#   ------------------------------------------------------------------------   #
#   Formattage de la date de demande de livraison en fonction du cadencement   #
#   ------------------------------------------------------------------------   #

If I_DEMDLVDAT
    If !I_CAD | [F:SOQ]CAD = 0
        [F:SOQ]CAD = 1
    Endif
#   --> Demande journalière
    If [F:SOQ]CAD = 1  
        [F:SOQ]DLVDAY = day([F:SOQ]DEMDLVDAT)
        [F:SOQ]MON    = month([F:SOQ]DEMDLVDAT)
        [F:SOQ]YEA    = year([F:SOQ]DEMDLVDAT)
    Endif
#   --> Demande hebdomadaire
    If [F:SOQ]CAD = 2 
        [F:SOQ]WEE = min(52,week([F:SOQ]DEMDLVDAT)) #Gbn-Fq79200
        [F:SOQ]YEA = year([F:SOQ]DEMDLVDAT)
        [F:SOQ]DEMDLVDAT = aweek([F:SOQ]WEE,[F:SOQ]YEA)
    Endif
#   --> Demande mensuelle
    If [F:SOQ]CAD = 3
        [F:SOQ]MON = month([F:SOQ]DEMDLVDAT)
        [F:SOQ]YEA = year([F:SOQ]DEMDLVDAT)
        [F:SOQ]DEMDLVDAT = gdat$(01, [F:SOQ]MON, [F:SOQ]YEA)

        #  Détermination du 1er jour du mois
        NOJOUR = dayn([F:SOQ]DEMDLVDAT)
        If NOJOUR > 4
           [F:SOQ]DEMDLVDAT += 8-NOJOUR
        Else
           [F:SOQ]DEMDLVDAT -= NOJOUR-1
        Endif    
    Endif
Endif
Return



$TRT_COMPDLIV
#     ---------------------------------------------------#
#     Traitement de la fenetre de complément             #
#     ---------------------------------------------------#

If nolign = 0 | status = 72 
#   Nouvelle ligne : initilialisation avec les zones de l'entête
    [M]YSTOFCY = [M]XSTOFCY
    [M]YUSEPLC = [M]XUSEPLC
    [M]YBPTNUM = [M]XBPTNUM
    [M]YMDL    = [M]XMDL
    [M]YDAYLTI = [M]XDAYLTI
    [M]YDLVPIO = [M]XDLVPIO
    [M]YPCK    = [M]XPCK
    [M]YPCKCAP = [M]XPCKCAP
Else
#   Modification de ligne : On reprend les valeurs de la ligne
    [M]YSTOFCY = [M]DSTOFCY (nolign-1)
    [M]YUSEPLC = [M]DUSEPLC (nolign-1)
    [M]YBPTNUM = [M]BPTNUM (nolign-1)
    [M]YMDL    = [M]MDL (nolign-1)
    [M]YDAYLTI = [M]DAYLTI (nolign-1)
    [M]YDLVPIO = [M]DLVPIO (nolign-1)
    [M]YPCK    = [M]PCK (nolign-1)
    [M]YPCKCAP = [M]PCKCAP (nolign-1)
Endif
If I_STOFCY
    If [F:SOQ]ALLQTY = 0 & [F:SOQ]SHTQTY = 0
        Call C_YSTOFCY([F:SOQ]STOFCY) From W1COMPDLIV
        If mkstat = 0 
            [M:CPDL]YSTOFCY = [F:SOQ]STOFCY
        Endif
    Endif
Endif
If I_USEPLC 
    [M:CPDL]YUSEPLC = [F:SOQ]USEPLC
Endif
If I_BPTNUM 
    Call C_YBPTNUM([F:SOQ]BPTNUM) From W1COMPDLIV
    If mkstat = 0 
        [M:CPDL]YBPTNUM = [F:SOQ]BPTNUM
    Endif
Endif
If I_MDL 
    Call C_YMDL([F:SOQ]MDL) From W1COMPDLIV
    If mkstat = 0 
        [M:CPDL]YMDL = [F:SOQ]MDL
    Endif
Endif
If I_DAYLTI 
    [M:CPDL]YDAYLTI = [F:SOQ]DAYLTI
Endif
If I_DLVPIO 
    [M:CPDL]YDLVPIO = [F:SOQ]DLVPIO
Endif
If I_PCK 
    Call C_YPCK([F:SOQ]PCK) From W1COMPDLIV
    If mkstat = 0 
        [M:CPDL]YPCK = [F:SOQ]PCK
    Endif
Endif
If I_PCKCAP 
    [M:CPDL]YPCKCAP = [F:SOQ]PCKCAP
Endif

Return

#######################################################################
#                        EXPORT
#######################################################################

#######################################################################

