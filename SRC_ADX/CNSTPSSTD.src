## Section automatically added (screen CRITTPS) 02/10/2017 10:33:54 (ADNGO)
######################################################################################
Subprog C_CODTIM(VALEUR)
Variable Char    VALEUR()
 #LIPET - X3-11390 - 20-01-2017 - START
If VALEUR<>""
 #LIPET - X3-11390 - 20-01-2017 - START
 #Call LECTURE("TIM",VALEUR,"") From CONTOBJ
 Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
 #LIPET - X3-11390 - 22-02-2017 - END
 [M]ALLCAT = 1  : [M]CATTIM = [F:TIM]CATTIM
 Grizo [M]20
 If [F:TIM]NATACT<>2
  Effzo [M]CODNAT : Grizo [M]CODNAT
 Else
  Actzo [M]CODNAT
 Endif
Else
 [M]ALLCAT = 2
 Actzo [M]ALLCAT
 Grizo CATTIM
 Actzo [M]CODNAT
Endif
Affzo [M]20
Affzo [M]CODNAT
 #LIPET - X3-11390 - 22-02-2017 - END
If [F:TIP]TIM <> VALEUR
  Raz [M:CNS2]
  Raz [M:CNS3]
Endif

End


