######################################################################################
Subprog C_CODNAT(VALEUR)
Variable Char    VALEUR()
 #LIPET - X3-11390 - 23-02-2017 - START
If VALEUR<>"" | [M]CODTIM <> ""
 [M]ALLCAT = 1 : [M]CATTIM = 1
 Grizo [M]20
Else
 [M]ALLCAT = 2
 Actzo [M]ALLCAT
 Grizo CATTIM
# Actzo [M]20
Endif
Affzo [M]20
 #LIPET - X3-11390 - 23-02-2017 - END
End


