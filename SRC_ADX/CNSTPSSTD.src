###FQ103970
# Compta V7 92876 format AXE old ML601 new DIE

Raz GTUNCPT
Local Char PARAM(10)(1..7)

Call GCONSULT("TPS","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT :#FQ103970
 When "FERME"      : Gosub FERME :#FQ103970
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "FIN_CRIT"   : Gosub FIN_CRIT
Endcase
Return

############################################
$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:TIP])=0 : Local File TIMEMP    [TIP] : Endif
If clalev([F:TIM])=0 : Local File TIMCOD    [TIM] : Endif
If clalev([F:ID])=0  : Local File EMPLOID   [ID]  : Endif
If clalev([F:GTC])=0 : Local File GTABACC    [GTC] : Endif
# fiche 66858 - SYMEU - V6.1 (07/09/2010)
#LIPET - X3-11390 - 20-01-2017 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR  [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR] : Endif
#LIPET - X3-11390 - 20-01-2017 - END
If clalev([F:TIG])=0 : Local File TIMREGUL  [TIG] : Endif :#FQ103970
If clalev([F:FCYL])=0 : Local File FACILITY  [FCYL] : Endif :#FQ103970 link FCY

Local Char CRITERE  (250)
Local Char CRITERE1  (250)
Local Char CRITERE2  (250)
Local Char OLDCRIT  (250)
Local Char OLDCRIT1  (250)
#LIPET - X3-11390 - 20-01-2017 - START
#Local Char DCLEMAT (GLONMAT),DCLEMATG (GLONMAT)
#Local Char FCLEMAT (GLONMAT),FCLEMATG (GLONMAT)
Local Char DCLEMAT (GLONEML),DCLEMATG (GLONEML)
Local Char FCLEMAT (GLONEML),FCLEMATG (GLONEML)
#LIPET - X3-11390 - 20-01-2017 - END
Local Date DCLEDAT, FCLEDAT, DCLEDATG, FCLEDATG
Local Integer DCLELIG, FCLELIG, DCLELIGG, FCLELIGG
Local Char    CRITEREG(250), CRITEREG1(250), CRITEREG2(250), CRITEREW(250) :#FQ103970
Local Integer I,K,NTAB,CTAB,J :#FQ103970
Local Integer OLDFLGREG :#FQ103970
Local Integer IL, WBREAK :#FQ103970
#LIPET - X3-11390 - 20-01-2017 - START
#Local Char WDCLEMAT (GLONMAT),WDCLEMATG (GLONMAT) :#FQ103970
#Local Char WFCLEMAT (GLONMAT),WFCLEMATG (GLONMAT) :#FQ103970
Local Char WDCLEMAT (GLONEML),WDCLEMATG (GLONEML) :#FQ103970
Local Char WFCLEMAT (GLONEML),WFCLEMATG (GLONEML) :#FQ103970
#LIPET - X3-11390 - 20-01-2017 - END
Local Date WDCLEDAT, WFCLEDAT, WDCLEDATG, WFCLEDATG :#FQ103970
Local Integer WDCLELIG, WFCLELIG, WDCLELIGG, WFCLELIGG :#FQ103970
#LIPET - X3-11390 - 20-01-2017 - START
#Local Char WCTRNUM(GLONCTR) :#FQ103970
Local Char WCTRNUM(GLONHRCTR) :#FQ103970
#LIPET - X3-11390 - 20-01-2017 - END
Local Char WAXE(GLONDIE) :#FQ103970
Local Integer DIE_INDEX, WOK :#FQ103970
Local Char WTAB(20) :#FQ103970
Local Char WMSK(20) :#FQ103970
Local Char WFLDCCE(20) :#FQ103970
Local Char WFLDDIE(20) :#FQ103970
Local Integer WNBR :#FQ103970
Local Integer WMAXTAB :#FQ103970

#LIPET - X3-11390 - 20-01-2017 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - X3-11390 - 20-01-2017 - END
If [M:CNS1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:CNS1]FCY,GUSRFCY(1..GNBAUZ))
 [M:CNS1]FCY=""
Endif
Default Mask [CNS1]
Gosub CRITENT From =PROGCNS
:#FQ103970
#----- Variables globales pour le multi-référenciels comptabilité -----#
GORITITCOL = 1
Gosub SAUV_GLOBAL_CPT From TRTHRCPT
Return


$DEB_CRIT
#LIPET - X3-11390 - 23-02-2017 - START
If [M:CTPS]CODTIM <> ""
  [M]ALLCAT = 1  : [M]CATTIM = [F:TIM]CATTIM
 Grizo [M]20
  If [F:TIM]NATACT<>2
  Effzo [M]CODNAT : Grizo [M]CODNAT
 Else
  Actzo [M]CODNAT
 Endif
Else
 Actzo CODNAT
 If [M]CODNAT <> ""
   Grizo [M]20
 Else
   #[M:CTPS]ALLCAT = 2
   Actzo [M]20
 Endif
Affzo [M]CODNAT
 If ALLCAT = 0 | ALLCAT = 2
 Grizo CATTIM
 Endif
 #[M:CTPS]ALLCAT = 2
  #Grizo [M]20
Endif

If [M:CTPS]TRI <> 1
  [M:CTPS]TRI = 2
Endif
#LIPET - X3-11390 - 23-22-2017 - END
#LIPET - X3-11390 - 20-01-2017 - START
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - X3-11390 - 20-01-2017 - END
#LIPET - X3-11390 - 10-02-2017 - START
Call C_LEG([M]LEG)
#LIPET - X3-11390 - 10-02-2017 - END
#JOJAC - X3-11390 - 2017-01-30 - START
#Call C_CODTIM([M]CODTIM)
#JOJAC - X3-11390 - 2017-01-30 - END
Return

############################################
$LECTURE
#FQ103970
Call VALDEF_FLD_ANA([M:CTPS]CPY) From SUBVEP

Gosub AFF_TITCOL
Diszo [CNS2]
#END FQ103970
#FQ103970

If [M:CTPS]FLGREG=2
  Gosub LECTURE_TIP_REG_TAB
Else
  Gosub LECTURE_TIP
  #LIPET - X3-11390 - 10-02-2017 - START
  Affzo [M:CNS3]
  #LIPET - X3-11390 - 10-02-2017 - END
Endif
Return

#FQ103970
$AFF_TITCOL
  Local Char BASPAG(10)

  If dim([M:CNS2]CCE1)>0 | dim([M:CNS2]CCE2)>0 | dim([M:CNS2]CCE3)>0 | dim([M:CNS2]CCE4)>0 | dim([M:CNS2]CCE5)>0
&  | dim([M:CNS2]CCE6)>0 | dim([M:CNS2]CCE7)>0 | dim([M:CNS2]CCE8)>0 | dim([M:CNS2]CCE9)>0
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1"+NOMMSK(1)
      Gosub CHG_FMT_CCE
  Endif
Return

#FQ103970
$CHG_FMT_CCE
  I=1
  Default Mask [CNS2]
  If [M:CNS2]NBLIG=0
   If GFMTDIE(1)<>""
    Chgfmt CCE1 With GFMTDIE(1)
   Else
    Chgfmt CCE1 With "-K:1X"
   Endif
   If GFMTDIE(2)<>""
    Chgfmt CCE2(indice) With GFMTDIE(2)
   Else
    Chgfmt CCE2(indice) With "-K:1X"
   Endif
   If GFMTDIE(3)<>""
    Chgfmt CCE3 With GFMTDIE(3)
   Else
    Chgfmt CCE3 With "-K:1X"
   Endif
   If GFMTDIE(4)<>""
    Chgfmt CCE4 With GFMTDIE(4)
   Else
    Chgfmt CCE4 With "-K:1X"
   Endif
   If GFMTDIE(5)<>""
    Chgfmt CCE5 With GFMTDIE(5)
   Else
    Chgfmt CCE5 With "-K:1X"
   Endif
   If GFMTDIE(6)<>""
    Chgfmt CCE6 With GFMTDIE(6)
   Else
    Chgfmt CCE6 With "-K:1X"
   Endif
   If GFMTDIE(7)<>""
    Chgfmt CCE7 With GFMTDIE(7)
   Else
    Chgfmt CCE7 With "-K:1X"
   Endif
   If GFMTDIE(8)<>""
    Chgfmt CCE8 With GFMTDIE(8)
   Else
    Chgfmt CCE8 With "-K:1X"
   Endif
   If GFMTDIE(9)<>""
    Chgfmt CCE9 With GFMTDIE(9)
   Else
    Chgfmt CCE9 With "-K:1X"
   Endif
#   If GFMTDIE(10)<>""
#    Chgfmt CCE10 With GFMTDIE(10)
#   Else
#    Chgfmt CCE10 With "-K:1X"
#   Endif
