######################################################################################
Subprog C_AXE(VALEUR)
Variable Char    VALEUR()
Local Char CPY_TIP(GLONCPY) :#FQ103970
If VALEUR="" : End : Endif
Read [CPY]CPY0 = [M]CPY
If fstat
 #LIPET - X3-11390 - 20-01-2017 - START
 #Call ERREUR(mess(65,702,1)) From GESECRAN : # Société inexistante
 Call ERREUR(mess(65,10702,1)) From GESECRAN : # Société inexistante
 #LIPET - X3-11390 - 20-01-2017 - END
 mkstat = 2 : End
Endif
If [F:CPY]CPYLEGFLG=2 : # Legal company
  [L]CPY_TIP = [M]CPY
Else
  Read [FGR]FGR0(1) = [M]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  [L]CPY_TIP = [F:FCY]LEGCPY
  Call LECTURE("CPY",[L]CPY_TIP,"") From CONTOBJ
Endif
Gosub LISTDIE From TPSSUB
If !find(VALEUR, WLSTDIE(1..WNBRDIE)) Then
 Call ERREUR(VALEUR-":"-mess(40,103,1)) From GESECRAN : # Axe incorrect
 mkstat = 2 : End
Endif
End

