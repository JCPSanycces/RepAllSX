Subprog AM_FLGGRA(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 2
  [M]FLGEXC(nolign-1) = "0"
 When Default
  [M]FLGEXC(nolign-1) = "1"
Endcase
End


