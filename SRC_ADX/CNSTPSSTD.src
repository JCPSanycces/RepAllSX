$LECTURE_TIP
OK=0
Gosub INI_CHARGE_TPS : #FQ103970
If WBREAK : Return : Endif
Raz WCTRNUM
OK=1 #FQ103970
Filter [F:LNK] Where evalue (CRITERE) & evalue (CRITERE1) & evalue (CRITERE2)
For [LNK]CLE # With Stability
  If [F:TIP]CTRNUM <> WCTRNUM
    Read[F:ID]ID0=[F:TIP]REFNUM
    Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIP]CTRNUM,"",OK,0) From DIVPAYE
  Endif
  WCTRNUM=[F:TIP]CTRNUM
  Gosub SAV_NBLU
  WOK=OK
  If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"") : #FQ103970
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIP]DIE(0..dim([F:TIP]DIE)-1))-1
   If [L]DIE_INDEX >=0 & [F:TIP]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIP]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
  Endif
  If WOK
   Gosub SAV_CLE_TIP #FQ103970
   If WBREAK : Break : Endif
  Endif
# Endif

Next
Filter [F:LNK]
#LIPET - X3-11390 - 10-02-2017 - START
#If CRITERE<>OLDCRIT | OLDFLGREG<>[M:CTPS]FLGREG
If CRITERE<>OLDCRIT | OLDFLGREG=[M:CTPS]FLGREG
#LIPET - X3-11390 - 10-02-2017 - END
 Gosub TOTAL
Endif
OLDCRIT=CRITERE
OLDCRIT1=CRITERE1
OLDECRAN=[M:CTPS]ECRAN
OLDFLGREG=[M:CTPS]FLGREG :#FQ103970
Affzo [M:CNS2]
#LIPET - X3-11390 - 10-02-2017 - START
Affzo [M:CNS3]
#LIPET - X3-11390 - 10-02-2017 - END
Return


$LECTURE_TIP_REG_TAB
OK=0
Gosub INI_CHARGE_TPS_TAB
If WBREAK : Return : Endif
Gosub MAJ_TAB_TIP_TAB
Gosub MAJ_TAB_TIG_TAB
Gosub TORDER_TAB
Gosub SAV_NBLU
For CTAB = 0 To NTAB
 If CTAB>MAXLIG : Break : Endif
 If [L]TCLETIP(CTAB) = 1
   Read[F:TIP]TIP1=[L]TCLEMAT(CTAB);[L]TCLEDAT(CTAB);[L]TCLELIG(CTAB)
   If !fstat
     Gosub SAV_CLE_TIP
     If WBREAK : Break : Endif
   Endif
 Endif
 If [L]TCLETIP(CTAB) = 2
   Read[F:TIG]TIG1=[L]TCLEMAT(CTAB);[L]TCLEDAT(CTAB);[L]TCLELIG(CTAB)
   If !fstat
     Gosub SAV_CLE_TIG
     If WBREAK : Break : Endif
   Endif
 Endif
Next
#LIPET - X3-11390 - 10-02-2017 - START
#If CRITERE<>OLDCRIT | OLDFLGREG<>[M:CTPS]FLGREG
If CRITERE<>OLDCRIT | OLDFLGREG=[M:CTPS]FLGREG
#LIPET - X3-11390 - 10-02-2017 - END
 Gosub TOTAL
Endif
OLDCRIT=CRITERE
OLDCRIT1=CRITERE1
OLDECRAN=[M:CTPS]ECRAN
OLDFLGREG=[M:CTPS]FLGREG :#FQ103970
Affzo [M:CNS2]
#LIPET - X3-11390 - 10-02-2017 - START
Affzo [M:CNS3]
#LIPET - X3-11390 - 10-02-2017 - END
If GOK<1 : Goto AB_TR1 : Endif
If adxlog
  Commit
Endif
Return

$AB_TR1
Rollback
Return

#FQ103970
$INI_CHARGE_TPS
WBREAK=0
#Il faut au mois une société et une période pour lancer une recherche
If [M:CNS1]DATDEB<>[0/0/0] & [M:CNS1]DATFIN<>[0/0/0]
 OK=1
Endif
If !OK or [M:CNS1]CPY="" : NBLU=0 : WBREAK=1: Return : Endif
Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
Gosub DEC_TAB_TIP_TIG : #FQ103970
If CHGPAG<0 : NOL = MAXLIG : Endif
Gosub CREER_FILTRE
Gosub CHG_PAGE
If CHGPAG=2 or CHGPAG=-2 : Raz [M:CNS2] : Endif
Gosub LIEN
Return

$INI_CHARGE_TPS_TAB
WBREAK=0
#Il faut au mois une société et une période pour lancer une recherche
If [M:CNS1]DATDEB<>[0/0/0] & [M:CNS1]DATFIN<>[0/0/0]
 OK=1
Endif
If !OK or [M:CNS1]CPY="" : NBLU=0 : WBREAK=1: Return : Endif
Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
Gosub DEC_TAB_TIP_TIG : #FQ103970
If CHGPAG<0 : NOL = MAXLIG : Endif
Gosub CREER_FILTRE
Gosub CHG_PAGE
If CHGPAG=2 or CHGPAG=-2 : Raz [M:CNS2] : Endif
Gosub LIEN
Return

#FQ103970
$SAV_NBLU
If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Raz [M:CNS2] : Endif
  NBLU=2
Endif
Return

#FQ103970
$SAV_CLE_TIP
WBREAK=0
If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Raz [M:CNS2] : Endif
  NBLU=2
Endif
If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : WBREAK=1 : Return : Endif
  NOL += 1
  If NOL = 0
   DCLEMAT  = [F:TIP]REFNUM
   DCLEDAT  = [F:TIP]STRDAT
   DCLELIG  = [F:TIP]LIG
   DCLELIGG = 0
  Endif
  FCLEMAT  = [F:TIP]REFNUM
  FCLEDAT  = [F:TIP]STRDAT
  FCLELIG  = [F:TIP]LIG
  If NOL=MAXLIG-1 : FCLELIGG = 0 : Endif
Else
  If NOL<=0 : RETOUR=2 : WBREAK=1  :  Return : Endif
  NOL-=1
  If NOL = MAXLIG-1
   FCLEMAT  = [F:TIP]REFNUM
   FCLEDAT  = [F:TIP]STRDAT
   FCLELIG  = [F:TIP]LIG
   FCLELIGG = 0
  Endif
  DCLEMAT  = [F:TIP]REFNUM
  DCLEDAT  = [F:TIP]STRDAT
  DCLELIG  = [F:TIP]LIG
  If NOL = 0 : DCLELIGG = 0 : Endif
Endif
nolign=NOL+1
[M:CNS2]=[F:TIP]
Gosub CHARGE_ANA
Return

#FQ103970
$SAV_CLE_TIG
WBREAK=0
If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Raz [M:CNS2] : Endif
  NBLU=2
Endif
If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : WBREAK=1 : Return : Endif
  NOL += 1
  If NOL = 0
   DCLEMATG  = [F:TIG]REFNUM
   DCLEDATG  = [F:TIG]STRDAT
   DCLELIGG  = [F:TIG]LIG
   DCLELIG   = 0
  Endif
  FCLEMATG  = [F:TIG]REFNUM
  FCLEDATG  = [F:TIG]STRDAT
  FCLELIGG  = [F:TIG]LIG
  If NOL=MAXLIG-1 : FCLELIG = 0 : Endif
Else
  If NOL<=0 : RETOUR=2 : WBREAK=1 : Return : Endif
  NOL-=1
  If NOL = MAXLIG-1
   FCLEMATG  = [F:TIG]REFNUM
   FCLEDATG  = [F:TIG]STRDAT
   FCLELIGG  = [F:TIG]LIG
   FCLELIG   = 0
  Endif
  DCLEMATG  = [F:TIG]REFNUM
  DCLEDATG  = [F:TIG]STRDAT
  DCLELIGG  = [F:TIG]LIG
  If NOL = 0  : DCLELIG = 0 : Endif
Endif
nolign=NOL+1
[M:CNS2]=[F:TIG]
Gosub CHARGE_ANA_REG
TTYPTIG(NOL)=1
Return

$FIN_CRIT
#LIPET - X3-11390 - 20-01-2017 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - X3-11390 - 20-01-2017 - END
Return

#FQ103970
$SETBOUT
Local Integer DECAL
If CHGPAG <0
  DECAL=MAXLIG-[M:CNS2]NBLIG
Endif
Chgstl [M:CNS2]NBLIG With ""

If [M:CTPS]FLGREG=2
  For IL=1 To MAXLIG
     If TTYPTIG(IL-1)
      Chgstl [M:CNS2]NBLIG(IL-1-DECAL) With "PLGCUR"
     Endif
  Next
Endif
Return

#FQ103970
$FERME
#----- Variables globales pour le multi-référenciels comptabilité -----#
GORITITCOL = 0
Gosub REST_GLOBAL_CPT From TRTHRCPT

#LIPET - X3-11390 - 20-01-2017 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - X3-11390 - 20-01-2017 - END
Return

#FQ103970
$DEC_TAB_TIP_TIG
Local Integer DIMTAB
DIMTAB=MAXLIG*2
Local Date    TCLEDAT(0..DIMTAB-1)
#LIPET - X3-11390 - 20-01-2017 - START
#Local Char    TCLEMAT(GLONMAT)(0..DIMTAB-1)
Local Char    TCLEMAT(GLONEML)(0..DIMTAB-1)
#LIPET - X3-11390 - 20-01-2017 - END
Local Integer TCLELIG(0..DIMTAB-1)
Local Integer TCLETIP(0..DIMTAB-1)
Local Integer TTYPTIG(0..MAXLIG-1)
Return


#FQ103970
$MAJ_TAB_TIG
Raz WCTRNUM
OK=1 #FQ103970
Filter [F:LNG] Where evalue (CRITEREG) & evalue (CRITEREG1) & evalue (CRITEREG2)
For [LNG]CLE # With Stability
  If [F:TIG]CTRNUM <> WCTRNUM
    Read[F:ID]ID0=[F:TIG]REFNUM
    Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIG]CTRNUM,"",OK,0) From DIVPAYE
  Endif
  WCTRNUM=[F:TIG]CTRNUM
  WOK=OK
  If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"")
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIG]DIE(0..dim([F:TIG]DIE)-1))-1
   If [L]DIE_INDEX >=0 & [F:TIG]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIG]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
  Endif
  If WOK
   NTAB+=1
   Raz [F:ARM]
   [F:ARM]USR    = GUSER
   [F:ARM]RPTCOD = "CNSTPSSTD"
   [F:ARM]NUMREQ = 1
   [F:ARM]NUMLIG = NTAB
   [F:ARM]CLEN1  = [F:TIG]LIG
   [F:ARM]CLEA1  = [F:TIG]REFNUM
   [F:ARM]CLED1  = [F:TIG]STRDAT
   [F:ARM]CLEN2  = 2
   Write [ARM]
   If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Return
   Endif
  Endif
Next
Filter [F:LNG]
Return

$MAJ_TAB_TIP_TAB
NTAB=0
Raz WCTRNUM
Raz [L]TCLEDAT(0..DIMTAB),[L]TCLEMAT(0..DIMTAB),[L]TCLELIG(0..DIMTAB),[L]TCLETIP(0..DIMTAB)
OK=1 #FQ103970
Filter [F:LNK] Where evalue (CRITERE) & evalue (CRITERE1) & evalue (CRITERE2)
For [LNK]CLE # With Stability
  If NTAB > MAXLIG : Break : Endif
  If [F:TIP]CTRNUM <> WCTRNUM
    Read[F:ID]ID0=[F:TIP]REFNUM
    Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIP]CTRNUM,"",OK,0) From DIVPAYE
  Endif
  WCTRNUM=[F:TIP]CTRNUM
  WOK=OK
  If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"")
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIP]DIE(0..dim([F:TIP]DIE)-1))-1
   If [L]DIE_INDEX >=0 & [F:TIP]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIP]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
  Endif
  If WOK
   Raz [L]TCLEDAT(NTAB),[L]TCLEMAT(NTAB),[L]TCLELIG(NTAB),[L]TCLETIP(NTAB)
   [L]TCLELIG(NTAB)  = [F:TIP]LIG
   [L]TCLEMAT(NTAB)  = [F:TIP]REFNUM
   [L]TCLEDAT(NTAB)  = [F:TIP]STRDAT
   [L]TCLETIP(NTAB)  = 1
   NTAB+=1
  Endif
Next
Filter [F:LNK]
Return

$MAJ_TAB_TIG_TAB
Raz WCTRNUM
OK=1 #FQ103970
Filter [F:LNG] Where evalue (CRITEREG) & evalue (CRITEREG1) & evalue (CRITEREG2)
For [LNG]CLE # With Stability
  If NTAB > DIMTAB : Break : Endif
  If [F:TIG]CTRNUM <> WCTRNUM
    Read[F:ID]ID0=[F:TIG]REFNUM
    Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIG]CTRNUM,"",OK,0) From DIVPAYE
  Endif
  WCTRNUM=[F:TIG]CTRNUM
  WOK=OK
  If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"")
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIG]DIE(0..dim([F:TIG]DIE)-1))-1
   If [L]DIE_INDEX >=0 & [F:TIG]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIG]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
  Endif
  If WOK
   Raz [L]TCLEDAT(NTAB),[L]TCLEMAT(NTAB),[L]TCLELIG(NTAB),[L]TCLETIP(NTAB)
   [L]TCLELIG(NTAB)  = [F:TIG]LIG
   [L]TCLEMAT(NTAB)  = [F:TIG]REFNUM
   [L]TCLEDAT(NTAB)  = [F:TIG]STRDAT
   [L]TCLETIP(NTAB)  = 2
   NTAB+=1
  Endif
Next
Filter [F:LNG]
Return

$TORDER_TAB
NTAB=max(0,NTAB)
#Sorta NTAB   [L]TCLEDAT,[L]TCLEMAT,[L]TCLELIG,[L]TCLETIP Order By [L]TCLEDAT(indice)
If [M:CTPS]TRI<>1 :# Tri par Matricule
 If CHGPAG>0
  Sorta NTAB   [L]TCLEDAT,[L]TCLEMAT,[L]TCLELIG,[L]TCLETIP Order By [L]TCLEMAT(indice),[L]TCLEDAT(indice)
 Else
  Sorta NTAB   [L]TCLEDAT,[L]TCLEMAT,[L]TCLELIG,[L]TCLETIP Order By [L]TCLEMAT(indice) , [L]TCLEDAT(indice) Desc
 Endif
Else
 If CHGPAG>0
  Sorta NTAB   [L]TCLEDAT,[L]TCLEMAT,[L]TCLELIG,[L]TCLETIP Order By [L]TCLEDAT(indice),[L]TCLEMAT(indice)
 Else
  Sorta NTAB   [L]TCLEDAT,[L]TCLEMAT,[L]TCLELIG,[L]TCLETIP Order By [L]TCLEDAT(indice),[L]TCLEMAT(indice) Desc
 Endif
Endif
Return

############################################
$CHARGE_ANA
#FQ103970
WTAB="[F:TIP]"
WMSK="[M:CNS2]"
WFLDCCE="CCE"
WFLDDIE="DIE"
Gosub CHARGE_ANA_MSK
Return

#FQ103970
$CHARGE_ANA_MSK
If GOPTCANA>0
  WMAXTAB=max(GNBDIE,GOPTCANA)
  #Pour ne récuperer que les sections des axes liées à la société
  For J=1 To WMAXTAB
    WNBR=find(evalue(WTAB+WFLDDIE+"(J-1)"),GDIE(1..GNBDIE))
    If WNBR
      Case J
       When 1,2,3,4,5,6,7,8,9
         If evalue("dim("+[L]WMSK+WFLDCCE+num$(J)+")")>0  : Assign [L]WMSK+WFLDCCE+num$(J)+"(nolign-1)" With evalue(WTAB+WFLDCCE+"(WNBR-1)") : Endif
       Endcase
    Endif
  Next J
Endif
Return

#FQ103970
$CHARGE_ANA_REG
WTAB="[F:TIG]"
WMSK="[M:CNS2]"
WFLDCCE="CCE"
WFLDDIE="DIE"
Gosub CHARGE_ANA_MSK
Return

$TOTAL
Raz [M:CNS3]
NBRTIM=0
OK=1 #FQ103970
# SEGAY 24/09/12 83141
# Filtre identique au détail
#For [LNK]CLE With Stability
Filter [F:LNK] Where evalue (CRITERE) & evalue (CRITERE1)
Raz WCTRNUM
For [LNK]CLE
 If [F:TIP]CTRNUM <> WCTRNUM
  Read[F:ID]ID0=[F:TIP]REFNUM #FQ103970
  Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIP]CTRNUM,"",OK,0) From DIVPAYE
 Endif
 WCTRNUM=[F:TIP]CTRNUM
 WOK=OK
 If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"") : #FQ103970
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIP]DIE(0..dim([F:TIP]DIE)-1))-1
   If [L]DIE_INDEX >=0 & [F:TIP]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIP]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
 Endif
 If WOK
  J=find([F:TIP]TIM,[M:CNS3]TOTTIM(0..NBRTIM))
  If !J
   [M:CNS3]TOTTIM(NBRTIM)=[F:TIP]TIM
   #LIPET - X3-11390 - 20-01-2017 - START
   #[M:CNS3]TOTDES(NBRTIM)=[F:TIM]DES
   Call LECTEXTRA([M:CNS3]TOTDES(NBRTIM),"TIMCOD","DES",GCURLEG,[M:CNS3]TOTTIM(NBRTIM)) From ATEXTRA
   #LIPET - X3-11390 - 20-01-2017 - END
   [M:CNS3]TOTDAY(NBRTIM)=[F:TIP]NBRDAY
   [M:CNS3]TOTHOU(NBRTIM)=[F:TIP]NBRHOU
   NBRTIM+=1
  Else
   [M:CNS3]TOTDAY(J-1)+=[F:TIP]NBRDAY
   [M:CNS3]TOTHOU(J-1)+=[F:TIP]NBRHOU
  Endif
 Endif
Next
Filter [LNK]
If [M:CTPS]FLGREG=2 : Gosub TOTAL_TIG : Endif : #FQ103970
[M:CNS3]NBLIG=NBRTIM
For I=0 To [M:CNS3]NBLIG-1
 If [M:CNS3]TOTTIM(I)=GTPSW
  [M:CNS3]FLGEXC(I) = "1"
  [M:CNS3]FLGGRA(I) = 1
 Else
  [M:CNS3]FLGEXC(I) = "0"
  [M:CNS3]FLGGRA(I) = 2
 Endif
Next I
Affzo [M:CNS3]
Return

#FQ103970
$TOTAL_TIG
Filter [F:LNG] Where evalue (CRITEREG) & evalue (CRITEREG1)
Raz WCTRNUM
OK=1 #FQ103970
For [LNG]CLE
 If [F:TIG]CTRNUM <> WCTRNUM
  Read[F:ID]ID0=[F:TIG]REFNUM #FQ103970
  Call CONTROLE([F:ID]REFNUM, [M:CNS1]DATDEB,[F:TIG]CTRNUM,"",OK,0) From DIVPAYE
 Endif
 WCTRNUM=[F:TIG]CTRNUM
 WOK=OK
 If OK & [L]WAXE>"" & ([M:CTPS]CCEDEB<>"" | [M:CTPS]CCEFIN<>"") : #FQ103970
   WOK=0
   [L]DIE_INDEX = find([L]WAXE,[F:TIG]DIE(0..dim([F:TIG]DIE)-1))-1
   If [L]DIE_INDEX >=0  & [F:TIG]CCE([L]DIE_INDEX)>=[M:CTPS]CCEDEB & [F:TIG]CCE([L]DIE_INDEX)<=[M:CTPS]CCEFIN
      WOK=1
   Endif
 Endif
 If WOK
  J=find([F:TIG]TIM,[M:CNS3]TOTTIM(0..NBRTIM))
  If !J
   [M:CNS3]TOTTIM(NBRTIM)=[F:TIG]TIM
   #LIPET - X3-11390 - 20-01-2017 - START
   #[M:CNS3]TOTDES(NBRTIM)=[F:TIM]DES
   Call LECTEXTRA([M:CNS3]TOTDES(NBRTIM),"TIMCOD","DES",GCURLEG,[M:CNS3]TOTTIM(NBRTIM)) From ATEXTRA
   #LIPET - X3-11390 - 20-01-2017 - END
   [M:CNS3]TOTDAY(NBRTIM)=[F:TIG]NBRDAY
   [M:CNS3]TOTHOU(NBRTIM)=[F:TIG]NBRHOU
   NBRTIM+=1
  Else
   [M:CNS3]TOTDAY(J-1)+=[F:TIG]NBRDAY
   [M:CNS3]TOTHOU(J-1)+=[F:TIG]NBRHOU
  Endif
 Endif
Next
Filter [LNG]
Return

########################################
$SET_ECRAN
If [M:CTPS]ECRAN=""
 Read [GTC]GTC0="TPS";"STD" :#écran par défaut
 If fstat
  Read [GTC]GTC0 First
 Endif
 If !fstat
  [M:CTPS]ECRAN=[F:GTC]COD
 Endif
Endif
Return

############################################
$CREER_FILTRE
CRITERE="1=1"
CRITERE1="1=1"
CRITERE2="1=1"

If [M:CNS1]FCY<>""
 CRITERE -= '& [F:TIP]FCY="'+[M:CNS1]FCY+'"'
Endif
If [M:CNS1]DATDEB<>[0/0/0]
 CRITERE -= '& [F:TIP]STRDAT>=['+num$([M:CNS1]DATDEB)+']'
Endif
If [M:CNS1]DATFIN<>[0/0/0]
 CRITERE -= '& [F:TIP]ENDDAT<=['+num$([M:CNS1]DATFIN)+']'
Endif
If [M:CNS1]SRV<>""
 CRITERE -= '& [F:TIP]SRV="'+[M:CNS1]SRV+'"'
Endif
If [M:CNS1]REFNUM<>""
 CRITERE -= '& [F:TIP]REFNUM="'+[M:CNS1]REFNUM+'"'
Endif
If [M:CTPS]CODTIM<>""
 CRITERE1 -= '& [F:TIP]TIM="'+[M:CTPS]CODTIM+'"'
Endif
If [M:CTPS]CODNAT<>""
 CRITERE1 -= '& [F:TIP]NATCOD="'+[M:CTPS]CODNAT+'"'
Endif
If [M:CTPS]ALLCAT=1
 CRITERE1 -= '& [F:TIM]CATTIM='+num$([M:CTPS]CATTIM)
Endif
CRITERE1 -= '& [F:FCYL]LEGCPY="'+[M:CNS1]CPY+'"' : #FQ103970

If [M:CTPS]FLGREG=2 : CRITEREG2="1=1" : Gosub CREER_FILTRE1_TIG Endif : #FQ103970
# Compta V7 92876 format AXE old ML601 new DIE
#FQ103970
[L]WAXE=[M:CTPS]AXE
If [L]WAXE<>""
  [L]CRITERE1 -= '&  find("'+[L]WAXE+'",[F:TIP]DIE(0..dim([F:TIP]DIE)-1))>0'
Endif
If dim([M:CTPS]BPCCPY)>=0 & [M:CTPS]BPCCPY<>""
 CRITERE1 -= '& [F:TIP]CPY="'+[M:CTPS]BPCCPY+'"'
Endif
If dim([M:CTPS]BPCNUM)>=0 & [M:CTPS]BPCNUM<>""
 CRITERE1 -= '& [F:TIP]BPCNUM="'+[M:CTPS]BPCNUM+'"'
Endif
If dim([M:CTPS]SOHNUM)>=0 & [M:CTPS]SOHNUM<>""
 CRITERE1 -= '& [F:TIP]SOHNUM="'+[M:CTPS]SOHNUM+'"'
Endif
If CRITERE=OLDCRIT & CRITERE1=OLDCRIT1 & OLDFLGREG=[M:CTPS]FLGREG
 Gosub FILTRE
 If [M:CTPS]FLGREG=2
    Gosub FILTRE_TIG
 Endif : #FQ103970
Endif

Return

#FQ103970
$CREER_FILTRE1_TIG
CRITEREG = CRITERE
Repeat
 K = instr(1,CRITEREG,"TIP]")
 If K
  CRITEREG = left$(CRITEREG,K-1)+"TIG]"+right$(CRITEREG,K+4)
 Endif
Until K=0
CRITEREG1 = CRITERE1
Repeat
 K = instr(1,CRITEREG1,"TIP]")
 If K
  CRITEREG1 = left$(CRITEREG1,K-1)+"TIG]"+right$(CRITEREG1,K+4)
 Endif
Until K=0
Return

############################################
$CHG_PAGE
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
Return

############################################
$LIEN
If [M:CTPS]TRI<>1 :# Tri par Matricule
 If CHGPAG>0
# SEGAY 24/09/12 83141
# CLE avec [TIP]LIG
#   Link [TIP] With [TIM]TIM0=[TIP]TIM As [LNK]
#&  Order By Key CLE=[TIP]REFNUM;[TIP]STRDAT
# Else
#   Link [TIP] With [TIM]TIM0=[TIP]TIM As [LNK]
#&  Order By Key CLE=[TIP]REFNUM Desc;[TIP]STRDAT Desc
# Endif
#LIPET - X3-11390 - 20-01-2017 - START
#   Link [TIP] With [TIM]TIM0=[TIP]TIM,
#&  [FCYL]FCY0 = [TIP]FCY
#&  As [LNK]
#&  Order By Key CLE=[TIP]REFNUM;[TIP]STRDAT;[TIP]LIG
# Else
#   Link [TIP] With [TIM]TIM0=[TIP]TIM,
#&  [FCYL]FCY0 = [TIP]FCY
#&  As [LNK]
#&  Order By Key CLE=[TIP]REFNUM Desc;[TIP]STRDAT Desc;[TIP]LIG Desc
# Endif
#Else
# If CHGPAG>0
#   Link [TIP] With [TIM]TIM0=[TIP]TIM,
#&  [FCYL]FCY0 = [TIP]FCY
#&  As [LNK]
#&  Order By Key CLE=[TIP]STRDAT;[TIP]REFNUM;[TIP]LIG
# Else
#   Link [TIP] With [TIM]TIM0=[TIP]TIM,
#&  [FCYL]FCY0 = [TIP]FCY
#&  As [LNK]
#&  Order By Key CLE=[TIP]STRDAT Desc;[TIP]REFNUM Desc;[TIP]LIG Desc
# Endif
#Endif
#If [M:CTPS]FLGREG=2 : Gosub LIEN_TIG : Endif : #FQ103970
   Link [TIP] With [TIM]TIM0= GCURLEG;[TIP]TIM,
&  [FCYL]FCY0 = [TIP]FCY
&  As [LNK]
&  Order By Key CLE=[TIP]REFNUM;[TIP]STRDAT;[TIP]LIG
 Else
   Link [TIP] With [TIM]TIM0= GCURLEG;[TIP]TIM,
&  [FCYL]FCY0 = [TIP]FCY
&  As [LNK]
&  Order By Key CLE=[TIP]REFNUM Desc;[TIP]STRDAT Desc;[TIP]LIG Desc
 Endif
Else
 If CHGPAG>0
   Link [TIP] With [TIM]TIM0= GCURLEG;[TIP]TIM,
&  [FCYL]FCY0 = [TIP]FCY
&  As [LNK]
&  Order By Key CLE=[TIP]STRDAT;[TIP]REFNUM;[TIP]LIG
 Else
   Link [TIP] With [TIM]TIM0= GCURLEG;[TIP]TIM,
&  [FCYL]FCY0 = [TIP]FCY
&  As [LNK]
&  Order By Key CLE=[TIP]STRDAT Desc;[TIP]REFNUM Desc;[TIP]LIG Desc
 Endif
Endif
If [M:CTPS]FLGREG=2 : Gosub LIEN_TIG : Endif : #FQ103970

#LIPET - X3-11390 - 20-01-2017 - END
Return

#FQ103970
$LIEN_TIG
#LIPET - X3-11390 - 20-01-2017 - START
#If [M:CTPS]TRI<>1 :# Tri par Matricule
# If CHGPAG>0
#   Link [TIG] With [TIM]TIM0=[TIG]TIM,
#&  [FCYL]FCY0 = [TIG]FCY
#&  As [LNG]
#&  Order By Key CLE=[TIG]REFNUM;[TIG]STRDAT;[TIG]LIG
# Else
#   Link [TIG] With [TIM]TIM0=[TIG]TIM,
#&  [FCYL]FCY0 = [TIG]FCY
#&  As [LNG]
#&  Order By Key CLE=[TIG]REFNUM Desc;[TIG]STRDAT Desc;[TIG]LIG Desc
# Endif
#Else
# If CHGPAG>0
#   Link [TIG] With [TIM]TIM0=[TIG]TIM,
#&  [FCYL]FCY0 = [TIG]FCY
#&  As [LNG]
#&  Order By Key CLE=[TIG]STRDAT;[TIG]REFNUM;[TIG]LIG
# Else
#   Link [TIG] With [TIM]TIM0=[TIG]TIM,
#&  [FCYL]FCY0 = [TIG]FCY
#&  As [LNG]
#&  Order By Key CLE=[TIG]STRDAT Desc;[TIG]REFNUM Desc;[TIG]LIG Desc
# Endif
#Endif
If [M:CTPS]TRI<>1 :# Tri par Matricule
 If CHGPAG>0
   Link [TIG] With [TIM]TIM0= GCURLEG;[TIG]TIM,
&  [FCYL]FCY0 = [TIG]FCY
&  As [LNG]
&  Order By Key CLE=[TIG]REFNUM;[TIG]STRDAT;[TIG]LIG
 Else
   Link [TIG] With [TIM]TIM0= GCURLEG;[TIG]TIM,
&  [FCYL]FCY0 = [TIG]FCY
&  As [LNG]
&  Order By Key CLE=[TIG]REFNUM Desc;[TIG]STRDAT Desc;[TIG]LIG Desc
 Endif
Else
 If CHGPAG>0
   Link [TIG] With [TIM]TIM0= GCURLEG;[TIG]TIM,
&  [FCYL]FCY0 = [TIG]FCY
&  As [LNG]
&  Order By Key CLE=[TIG]STRDAT;[TIG]REFNUM;[TIG]LIG
 Else
   Link [TIG] With [TIM]TIM0= GCURLEG;[TIG]TIM,
&  [FCYL]FCY0 = [TIG]FCY
&  As [LNG]
&  Order By Key CLE=[TIG]STRDAT Desc;[TIG]REFNUM Desc;[TIG]LIG Desc
 Endif
Endif
#LIPET - X3-11390 - 20-01-2017 - END
Return

############################################
$FILTRE
WFCLEMAT=FCLEMAT
WFCLELIG=FCLELIG
WFCLEDAT=FCLEDAT
WDCLEMAT=DCLEMAT
WDCLELIG=DCLELIG
WDCLEDAT=DCLEDAT
If [M:CTPS]FLGREG=2
 If DCLELIG = 0
   WDCLEMAT=DCLEMATG
   WDCLEDAT=DCLEDATG
 Endif
 If FCLELIG = 0
   WFCLEMAT=FCLEMATG
   WFCLEDAT=FCLEDATG
 Endif
Endif
CRITEREW=CRITERE2
Gosub FILTRE2 :#FQ103970
CRITERE2=CRITEREW
Return

#FQ103970
$FILTRE2
Case CHGPAG
 When 2 :#suite
    If [M:CTPS]TRI<>1 :# Tri par Matricule
       CRITEREW -= ' & ([F:TIP]REFNUM >="'+WFCLEMAT+'"'+
&                  ' & [F:TIP]LIG >'+num$(WFCLELIG) +
&                  ' & [F:TIP]STRDAT >=['+ format$(GFMD,WFCLEDAT)+'])'+
&                  ' | ([F:TIP]REFNUM >="'+WFCLEMAT+'"'+
&                  ' & [F:TIP]LIG <>'+num$(WFCLELIG) +
&                  ' & [F:TIP]STRDAT >['+ format$(GFMD,WFCLEDAT)+'])'+
&                  ' | [F:TIP]REFNUM >"'+WFCLEMAT+'"'

    Else
       CRITEREW -= ' & ([F:TIP]REFNUM >="'+WFCLEMAT+'"'+
&                  ' & [F:TIP]LIG >'+num$(WFCLELIG) +
&                  ' & [F:TIP]STRDAT >=['+ format$(GFMD,WFCLEDAT)+'])'+
&                  ' | ([F:TIP]REFNUM >="'+WFCLEMAT+'"'+
&                  ' & [F:TIP]LIG <>'+num$(WFCLELIG) +
&                  ' & [F:TIP]STRDAT >['+ format$(GFMD,WFCLEDAT)+'])'+
&                  ' | [F:TIP]STRDAT >['+ format$(GFMD,WFCLEDAT)+']'
    Endif
 When -2 :#retour
    If [M:CTPS]TRI<>1 :# Tri par Matricule
       CRITEREW -= ' & ([F:TIP]REFNUM <="'+WDCLEMAT+'"'+
&                  ' & [F:TIP]LIG <'+num$(WDCLELIG) +
&                  ' & [F:TIP]STRDAT <=['+ format$(GFMD,WDCLEDAT)+'])'+
&                  ' | ([F:TIP]REFNUM <="'+WDCLEMAT+'"'+
&                  ' & [F:TIP]LIG <>'+num$(WDCLELIG) +
&                  ' & [F:TIP]STRDAT <['+ format$(GFMD,WDCLEDAT)+'])'+
&                  ' | [F:TIP]REFNUM <"'+WDCLEMAT+'"'
    Else
       CRITEREW -= ' & ([F:TIP]REFNUM <="'+WDCLEMAT+'"'+
&                  ' & [F:TIP]LIG <'+num$(WDCLELIG) +
&                  ' & [F:TIP]STRDAT <=['+ format$(GFMD,WDCLEDAT)+'])'+
&                  ' | ([F:TIP]REFNUM <="'+WDCLEMAT+'"'+
&                  ' & [F:TIP]LIG <>'+num$(WDCLELIG) +
&                  ' & [F:TIP]STRDAT <['+ format$(GFMD,WDCLEDAT)+'])'+
&                  ' | [F:TIP]STRDAT <['+ format$(GFMD,WDCLEDAT)+']'
    Endif
Endcase
Return

#FQ103970
$CREER_FILTRE2_TIG
CRITEREG2 = CRITEREW
Repeat
 K = instr(1,CRITEREG2,"TIP]")
 If K
  CRITEREG2 = left$(CRITEREG2,K-1)+"TIG]"+right$(CRITEREG2,K+4)
 Endif
Until K=0
Return

#FQ103970
$FILTRE_TIG
WFCLEMAT=FCLEMATG
WFCLELIG=FCLELIGG
WFCLEDAT=FCLEDATG
WDCLEMAT=DCLEMATG
WDCLELIG=DCLELIGG
WDCLEDAT=DCLEDATG
If DCLELIGG = 0
   WDCLEMAT=DCLEMAT
   WDCLEDAT=DCLEDAT
Endif
If FCLELIGG = 0
   WFCLEMAT=FCLEMAT
   WFCLEDAT=FCLEDAT
Endif
CRITEREW=CRITEREG2
Gosub FILTRE2 :#FQ103970
Gosub CREER_FILTRE2_TIG

Return

###############################################################################
##              Etiquettes masque CONSTPS1 & CRITTPS                         ##
###############################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]FCY
 Affzo [M]FCY
 # Fiche 71002 - SYMEU - 14/02/2011 : màj du nom du site
 Raz [M]ZFCY : Affzo [M]ZFCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
#LIPET - X3-11390 - 26-01-2017 - START
If clalev([F:CPYL])=0 : Local File COMPANY   [CPYL] : Endif
If clalev([F:FCYL])=0 : Local File FACILITY  [FCYL] : Endif

#If VALEUR="" & [M]CPY=""
#  #VALEUR = GFCYDEF
#  Filter [FCYL] Where LEG = GCURLEG
#  Read [FCYL] First
#  Filter [FCYL]
#  VALEUR  = [FCYL]FCY
#Endif
#LIPET - X3-11390 - 26-01-2017 - END
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY=""
  GMESSAGE = mess(9,109,1) : # Vous devez saisir une société ou un site
  mkstat = 2
Endif
#LIPET - X3-11390 - 30-01-2017 - START
Filter [FCY] Where [F:FCY]FCY = VALEUR
Read [FCY] First
If !fstat
  If [F:FCY]LEGCPY <>[M:CNS1]CPY & [M:CNS1]CPY <> ""
  GMESSAGE = VALEUR-func AFNC.MES1(mess(171,104,1),[M:CNS1]CPY)
  mkstat=2
  Else
   If GCURLEG <> [F:FCY]LEG &  VALEUR <> "" & GCURLEG <> ""
   GMESSAGE=VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
   mkstat=2
   Endif
  Endif
Endif
Filter [FCY]
#LIPET - X3-11390 - 30-01-2017 - END
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [M]CPY<>[F:FCY]LEGCPY
  [M]CPY = [F:FCY]LEGCPY
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Affzo [M]CPY
  # Fiche 71002 - SYMEU - 14/02/2011 : màj du nom de la société
  [M]ZCPY = [F:CPY]CPYNAM : Affzo [M]ZCPY
 Endif
Endif
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,year(date$))
Endif
End

Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(31,12,year([M]DATDEB))
Endif
End

