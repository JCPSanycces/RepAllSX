 #LIPET - X3-11390 - 20-01-2017 - START
  GCURLEG = VALEUR
 #LIPET - X3-11390 - 20-01-2017 - END
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
#LIPET - X3-23355 - 27-01-2017 - START
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & [F:CPY]LEG <> GCURLEG
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
     mkstat=2
   Endif
Endif
Filter [CPY]
#LIPET - X3-23355 - 27-01-2017 - END
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
#LIPET - X3-23355 - 27-01-2017 - START
If VALEUR <> ""
  Filter [ID] Where [F:ID]REFNUM = VALEUR
  Read [ID] First
  If !fstat
   If [F:ID]CPY <> [M:CNS1]CPY & [M:CNS1]CPY <> ""
    GMESSAGE = VALEUR-mess(67,10717,1)-[M:CNS1]CPY
    mkstat=2
   Elsif [F:ID]FCY <> [M:CNS1]FCY & [M:CNS1]FCY <> ""
     GMESSAGE = VALEUR-mess(48,10702,1)-[F:ID]FCY
     mkstat=2
   Elsif [F:ID]SRV <> [M:CNS1]SRV & [M:CNS1]SRV <> ""
     GMESSAGE= VALEUR-mess(51,10702,1)-[F:ID]SRV
     mkstat=2
    Endif
   Endif
  Endif
Filter [ID]
#LIPET - X3-23355 - 27-01-2017 - END
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

#LIPET - X3-11390 - 20-01-2017 - START
If dim(VALEUR)>0 : GCURLEG = VALEUR : Endif
#LIPET - X3-11390 - 20-01-2017 - END
End


