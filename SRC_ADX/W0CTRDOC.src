#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTRDOC 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBDOCGEN
mkstat = 0
zoncou = "NBDOCGEN"
indice = 0
status = 1
zoncou = "NBDOCGEN"
If varmode([M]NBDOCGEN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBDOCGEN From CTRDOC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBDOCGEN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBDOCGEN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBDOCGEN
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBDOCGEN = nolign
   status = 75
   Call SAI_NBDOCGEN(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"
indice = 0
status = 1
zoncou = "NBCLC"
If varmode([M]NBCLC,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBCLC From CTRDOC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBCLC : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCLC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCLC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCLC = nolign
   status = 75
   Call SAI_NBCLC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBCLC From CTRDOC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBCLC" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBDOCGEN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBDOCGEN
mkstat = 0
zoncou = "NBDOCGEN"

## Zone SELFLG
mkstat = 0
zoncou = "SELFLG"
IMPENT = [M]SELFLG(indice)
If varinit([M]SELFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]SELFLG,indice)=0
 [M]SELFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SELFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SELFLG(indice)
 Endif
Endif
[M]SELFLG(indice) = IMPENT

## Zone ICODOC2
mkstat = 0
zoncou = "ICODOC2"
If varinit([M]ICODOC2,indice)=0
 [M]ICODOC2(indice) = 21
Endif
If varmode([M]ICODOC2,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ICODOC2([M]ICODOC2(indice)) From CTRDOC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ICODOC2(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ICODOC2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LEG1
mkstat = 0
zoncou = "LEG1"
If varinit([M]LEG1,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG1(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG2
mkstat = 0
zoncou = "LEG2"
If varinit([M]LEG2,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG2(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG3
mkstat = 0
zoncou = "LEG3"
If varinit([M]LEG3,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG3(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG4
mkstat = 0
zoncou = "LEG4"
If varinit([M]LEG4,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG4(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG5
mkstat = 0
zoncou = "LEG5"
If varinit([M]LEG5,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG5(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG6
mkstat = 0
zoncou = "LEG6"
If varinit([M]LEG6,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG6(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG7
mkstat = 0
zoncou = "LEG7"
If varinit([M]LEG7,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG7(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG8
mkstat = 0
zoncou = "LEG8"
If varinit([M]LEG8,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG8(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG9
mkstat = 0
zoncou = "LEG9"
If varinit([M]LEG9,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG9(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEG10
mkstat = 0
zoncou = "LEG10"
If varinit([M]LEG10,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG10(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBDOCGEN
mkstat = 0
zoncou = "NBDOCGEN"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBCLC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"
SAVACT = GACTION : GACTION = "STD"
Call C_NBCLC From CTRDOC
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBCLC" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone CLASPE
mkstat = 0
zoncou = "CLASPE"
WCHAR = [M]CLASPE(indice)
If varmode([M]CLASPE,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CLASPE([M]CLASPE(indice)) From CTRDOC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CLASPE(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLASPE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRCLC"
  Call CONTHRCLC([M]CLASPE(indice),GCURLEG,GSOCIETE) From SUBHRCLC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CLASPE([M]CLASPE(indice)) From CTRDOC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJW"
    PARAM(1) = "HRCLC"
    Local Char    VALEUR(250)
    VALEUR = [M]CLASPE(indice)
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
    [M]CLASPE(indice) = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CLASPE(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CLASPE([M]CLASPE(indice)) From CTRDOC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESCLA
mkstat = 0
zoncou = "DESCLA"
If varinit([M]DESCLA,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESCLA(indice),"CLACTR","DESCLA",[M]CLASPE(nolign-1),[M]LEG(nolign-1)) From ATEXTRA
 GACTION = SAVACT
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone ACTSELECT
mkstat = 0
zoncou = "ACTSELECT"
IMPENT = [M]ACTSELECT(indice)
If varinit([M]ACTSELECT,indice)=0
 IMPENT = 1
Endif
[M]ACTSELECT(indice) = IMPENT

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTRDOC"
Return

