#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char VALEUR(250) , PARAM(250)(1..20) # #
Call SAISIE_CHAR(VALEUR,PARAM,"ARECHMEN","ARECHMEN","SPEARECHMEN") From GSAISIE
End
########################################################################################
########################################################################################
$ACTION
Case ACTION
 When "DEBUT"           : Gosub DEBUT
 When "BOUTON"          : Gosub BOUTON
 When "FINSAI"          : Gosub FIN
Endcase
Return

###########################################################
###########################################################
$DEBUT
GBIDC1 = ""
[M:EXE2]RECHERCHE = PARAM(1)
If dim(GBIDRECH)>0 & GBIDRECH<>"" : [M:EXE2]RECHERCHE=GBIDRECH : Endif
[M:EXE2]SOUSMENU= val(PARAM(2))
If [M:EXE2]RECHERCHE<>""
 Call RCMEN([M:EXE2]RECHERCHE)
Endif 
Return

###########################################################

$BOUTON
Call RCMEN([M:EXE2]RECHERCHE)
Return

###########################################################

$FIN
If GBIDC1 <> "" & (GFONCTION ="ARECHMEN" or (GFONCTION="ADOTRT" & GADONIX=2))
 If dim(GGBOUTGLO)<0 : Gosub BOUTGLO From EXEFNC : Endif 
 If GNBMASKOUV<=0 : Gosub INITMEN  From EXEFNC : Endif
 Call EXEFNC(GBIDC1,GBIDC2) From EXEFNC
Endif
Return

########################################################################################
# recherche dans le menu X3 et affichage sur l'écran ZRCMEN
########################################################################################
Subprog RCMEN(RECHERCHE)
Value Char RECHERCHE() #texte de la recherche

Local Integer I, J , NBTOTMAX
Local Char    PROFIL(GLONAPM)
# on determine les mots de la recherche par un "split"
NBMOTMAX = 30 : # nombre maximum de mots dans la recherche
Local Char    TABSPLIT(255)(NBMOTMAX+1) : # mais on limite à NBMOTMAX+1 mots pour tester si il y a plus de NBMOTMAX mots   

# suppression des espaces consécutifs, et aux extrémités de la recherche
RECHERCHE = vireblc(vireblc(RECHERCHE,2),5)

# Suppresion caractere ' "
I =instr(1,RECHERCHE,"'")
While I>0
 J=1 
 RECHERCHE = left$(RECHERCHE,I-1)-right$(RECHERCHE,I+1)
 I =instr(1,RECHERCHE,"'")
Wend
If J
 [M]RECHERCHE = RECHERCHE
 Affzo [M]RECHERCHE
Endif

# empeche la recherche si le champ est vide
If(RECHERCHE="")
 End
Endif

#réinitialisation de l'affichage
[M:EXE2]NBLIG=0
Effzo [M:EXE2]ICONE
Effzo [M:EXE2]FONCMENU
Effzo [M:EXE2]CHEMIN
Effzo [M:EXE2]IDELEM
Effzo [M:EXE2]CHEMINTRI

#recherche du profil
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
Raz PROFIL
Read [AUS] CODUSR=GUSER
If [F:AUS]CODMET<>""
 Read [AME] AME0=[F:AUS]CODMET
 If !fstat
  PROFIL = [F:AME]PRFMEN
 Endif
Endif
If PROFIL=""
 PROFIL = [F:AUS]PRFMEN
Endif


#simplification de la recherche
RECHERCHE = tolower(ctrans(RECHERCHE))

NBMOT = func SPLIT(RECHERCHE," ",TABSPLIT)

# message d'erreur si le nombre de mots dans la recherche est trop grand
If NBMOT>NBMOTMAX
 Call ERREUR(mess(14,135,1)) From GESECRAN : # Trop de paramètres
 [M]RECHERCHE =  TABSPLIT(0)
  For I=1 To NBMOTMAX-1
   [M]RECHERCHE -=  TABSPLIT(I)
  Next
 Affzo [M]RECHERCHE
 NBMOT=NBMOTMAX
Endif

#construction des chaines de recherche utilisées par "evalue"
Local Integer ICHAIOU,ICHAIET
Local Char CHAINEOU(250)(0..NBMOTMAX)
Local Char CHAINEET(250)(0..NBMOTMAX)
CHAINEOU(0)="0"
CHAINEET(0)="1"

For I=0 To NBMOT-1
 MOT=TABSPLIT(I)
 If MOT<>""
  #chaine de recherche primaire sur un seul élément (OU)
  Call ADDCRIT(CHAINEOU,ICHAIOU,"CHAINEOU","pat(tolower(ctrans([ATX]TEXTE)),tolower(ctrans('*"+MOT+"*')))","|") From GOBJSUB

  #chaine de recherche sur la totalité du chemin (ET)
  Call ADDCRIT(CHAINEET,ICHAIET,"CHAINEET","pat(tolower(ctrans(XCHEMIN)),tolower(ctrans('*"+MOT+"*')))","&") From GOBJSUB

 Endif
Next

#determination du menu de depart (pour GETCHEMIN)
If !clalev([F:APF]) : Local File APROFIL [APF] : Endif
Filter [APF] Where CODPRF=PROFIL
For [APF]
 XMENDEP=[F:APF]MENDEP
 Break
Next
Filter [APF]
    
#ouverture et filtrage du menu
If !clalev([F:AMU]) : Local File AMENUSER [AMU] : Endif
If !clalev([F:ATX]) : Local File ATEXTE   [ATX] : Endif
Link [AMU] With [ATX]NUMERO=GLANGUE;[AMU]LIBMENU As [LIEN]
Filter [LIEN] Where evalue(CHAINEOU) & [AMU]CODPRF=PROFIL & [ATX]LAN=GLANGUE
#parcourt des éléments du menu

Onerrgo ERR
For [LIEN]
 #limite du tableau de résultat atteinte
 If [M:EXE2]NBLIG>=dim([M:EXE2]CHEMIN) : Break : Endif     
 Call AFFELEM(PROFIL,[AMU]NUMLIG,[AMU]CODMEN,[AMU]FONCTION,CHAINEET,XMENDEP)
Next
Filter [LIEN]
Onerrgo

#ajouté pour mettre les lignes vides à la fin lors du tri
For I=0 To dim([M:EXE2]CHEMINTRI)-1
 [M:EXE2]CHEMINTRI(I)="__________"
Next

#on rempli la colonne CHEMINTRI à partir de CHEMIN en supprimant les accents
For I=0 To [M:EXE2]NBLIG-1
 [M:EXE2]CHEMINTRI(I)=ctrans([M:EXE2]CHEMIN(I))
Next

#tri du tableau
Sorta [M:EXE2]CHEMINTRI,[M:EXE2]CHEMIN,[M:EXE2]FONCMENU,[M:EXE2]IDELEM,[M:EXE2]ICONE

#mise à jour de l'écran
Affzo [M:EXE2]

If [M:EXE2]NBLIG>=dim([M:EXE2]CHEMIN)
 # Trop de lignes ramenées par la recherche.\Nombre de lignes affichées au maximum :
 Call MESSAGE(mess(56,176,1)-num$(dim([M:EXE2]CHEMIN)) ) From GESECRAN
Endif

End

$ERR
Resume

########################################################################################
#affichage d'un élément de la recherche
########################################################################################
Subprog AFFELEM(XCODPRF,XNUMLIG,XCODMEN,XFONCTION,XCHAINEET,XMENDEP)
Value Char     XCODPRF()
Value Integer  XNUMLIG
Value Char     XCODMEN()
Value Char     XFONCTION()
Value Char     XCHAINEET()
Value Char     XMENDEP()

Local Char XCHEMIN(250)

If [M:EXE2]NBLIG>=dim([M:EXE2]CHEMIN) End Endif #limite du tableau de résultat atteinte
    
If(find(XNUMLIG,[M:EXE2]IDELEM)=0) 
 GBIDI3 = time
 XCHEMIN=func GETCHEMIN(XCODPRF,XNUMLIG,XMENDEP) #récupération du chemin complet de l'élément 
 If GBIDI3=0 : End : Endif
 If evalue(XCHAINEET)
  [M:EXE2]CHEMIN([M:EXE2]NBLIG)=XCHEMIN
  If XFONCTION <> "MENU"
   [M:EXE2]FONCMENU([M:EXE2]NBLIG)=XFONCTION #récupération du nom de la fonction de l'élément
  Else
   [M:EXE2]FONCMENU([M:EXE2]NBLIG)=XCODMEN
  Endif
   
  #récupération de l'identifiant de l'élément
  [M:EXE2]IDELEM([M:EXE2]NBLIG)=XNUMLIG
           
  #affichage de l'icône
  If XFONCTION <> "MENU"
   [M:EXE2]ICONE([M:EXE2]NBLIG)="11"
  Else
   [M:EXE2]ICONE([M:EXE2]NBLIG)="999"
  Endif
           
  #rafraichissement de l'affichage du résultat       
  [M:EXE2]NBLIG+=1
  If [M:EXE2]NBLIG>=dim([M:EXE2]CHEMIN) End Endif #limite du tableau de résultat atteinte  
   
  #affichage des sous éléments si la case est cochée
  If(XFONCTION="MENU" & [M:EXE2]SOUSMENU=2)
   Call AFFMENU(XCODPRF,XCODMEN,XMENDEP)
  Endif
 Endif
Endif
End

########################################################################################
#affichage des sous éléments d'un menu si la case est cochée
########################################################################################
Subprog AFFMENU(XCODPRF,XCODMEN,XMENDEP)
Value Char XCODPRF()
Value Char XCODMEN()
Value Char XMENDEP()
    
#parcourt des sous éléments du menu
Local File AMENUSER [AMU_] 
Filter [AMU_] Where CODPRF=XCODPRF & MENU=XCODMEN
For [AMU_]
 If [M:EXE2]NBLIG>=dim([M:EXE2]CHEMIN)-1 : Break  : Endif #limite du tableau de résultat atteinte  
  Call AFFELEM(XCODPRF,[AMU_]NUMLIG,[AMU_]CODMEN,[AMU_]FONCTION,"1",XMENDEP)
Next
Filter [AMU_]
End

########################################################################################
#récupération du chemin complet de l'élément du menu, de manière récursive
########################################################################################
Funprog GETCHEMIN(XCODPRF,XNUMLIG,XMENDEP)
Value Char    XCODPRF()
Value Integer XNUMLIG
Value Char    XMENDEP()

Local Char ME(GLONAFC) , FO(GLONAFC)
Local Char TEXTE(250)

If GBIDI3+30=time : GBIDI3=0 : End TEXTE : Endif

#récupération des information sur l'élément du menu
If !clalev([F:AMU2]) :  Local File AMENUSER [AMU2] : Endif
Read [AMU2]CODMEN=XCODPRF;XNUMLIG
ME=[F:AMU2]MENU
FO=[F:AMU2]FONCTION
Call TEXTE([F:AMU2]LIBMENU,TEXTE) From OBJDIV

#concaténation d'un chevron si'il s'agit d'un noeud
If FO="MENU"
 TEXTE=TEXTE-">"
Endif

#appel récursif, pour récupérer l'élement supérieur
If MENU<>XMENDEP
 XNUMLIG = 0
 Filter [AMU2] Where CODPRF=XCODPRF & CODMEN=ME
 For [AMU2]
  XNUMLIG=[F:AMU2]NUMLIG
 Next
 Filter [AMU2]
 If XNUMLIG=0 : End TEXTE : Endif
 TEXTE=func GETCHEMIN(XCODPRF,XNUMLIG,XMENDEP)-TEXTE
Endif
End TEXTE

########################################################################################
#gestion du clic sur les icones de gauche
########################################################################################
Subprog CL_ICONE(VALEUR)
Variable Char    VALEUR()
If [M:EXE2]ICONE(nolign-1) <> "999"
 #clic sur un élément de menu
  GBIDC1 = [M:EXE2]FONCMENU(nolign-1)
  GBIDC2 = ""
  mkstat = 1024+7
Else
 If [M:EXE2]SOUSMENU <> 2
  [M:EXE2]SOUSMENU = 2
  Call RCMEN([M:EXE2]RECHERCHE)
  Affzo  [M:EXE2]
 Endif
Endif
End

########################################################################################
#fonction de "split", séparation d'une chaine en fonction d'un séparateur
########################################################################################
Funprog SPLIT(CHAINE,SEPARATEUR,RETOUR)
Value Char CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()() #tableau de chaines de caractères où sont renvoyées les chaines découpées

Local Integer DEBUT , FIN , FINBOUCLE , NBMOT

DEBUT=1 #debut du mot
FIN=1 #fin du mot
FINBOUCLE=0 #sortie de boucle
NBMOT=0 #nombre de mot

#parcourt de la chaine
Repeat
 #recherche d'un mot
 FIN=instr(DEBUT,CHAINE,SEPARATEUR)
 If FIN=0
  FINBOUCLE=1
  FIN=len(CHAINE)+1
 Endif
 RETOUR(NBMOT)=seg$(CHAINE,DEBUT,FIN-1) #ajout du mot au retour
 DEBUT=FIN+len(SEPARATEUR)
 NBMOT+=1  
Until FINBOUCLE | NBMOT=dim(RETOUR)
End NBMOT

########################################################################################
#gestion de l'appuis sur la touche "entrée" pour le champ de recherche
########################################################################################
Subprog AM_RECHERCHE(VALEUR)
Variable Char    VALEUR()
Call RCMEN(VALEUR)
End

########################################################################################
#gestion de l'appuis sur la touche "entrée" pour la case à cocher
########################################################################################
Subprog AM_SOUSMENU(VALEUR)
Variable Integer VALEUR
If VALEUR <> [M:EXE2]SOUSMENU
 [M:EXE2]SOUSMENU=VALEUR
 Call RCMEN([M:EXE2]RECHERCHE)
Endif
End




