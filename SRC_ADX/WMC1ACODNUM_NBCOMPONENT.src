#<AdxTL>@(#)0.0.0.0 $Revision$Class Doc sequence numbers
# Supervisor
## ACLA-CLASSE ## ACODNUM_NBCOMPONENT
# 2018-11-06 07:00:50 094


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : POSTYP Component type ( Field Local menu number 47)
####################################################################

$SET_POSTYP
If [L]_AOLDVAL<>this.POSTYP
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_POSTYP
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.POSTYP
 Gosub PROPAGATE_POSTYP
Endif
Return

$INIT_POSTYP
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
[L]CURPRO = "POSTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.POSTYP=0 and fmet this.AGETATTRIBUTE("POSTYP","$isMandatory")="true"
 this.POSTYP = 1
Endif
Return
 
$CONTROL_POSTYP
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
[L]CURPRO = "POSTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_POSTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_POSTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_POSTYP
[L]CURPRO = "POSTYP"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.POSTYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_POSTYP
[L]CURPRO = "POSTYP"
If this.POSTYP<0 or this.POSTYP>len(mess(0,47,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"47 ->"-num$(this.POSTYP)-mess(99,123,1)):  Return : # Local menu "47 -> Invalid option
Endif
Return

$_AOTHERS_POSTYP
[L]CURPRO = "POSTYP"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_POSTYP
[L]CURPRO = "POSTYP"
Return

$PROPAGATE_POSTYP
this.isReadonly = 0
[L]CURPRO = "POSTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_POSTYP
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
[L]CURPRO = "POSTYP"
$_LNKPRO_POSTYP
Return


