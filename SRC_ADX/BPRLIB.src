#<AdxTL>@(#)8.0.0.0 $Revision$
###################################################################
# BPRLIB:                                                         #
# Fonctions unitaires d'accès / contrôle tables tiers             #
#           BPARTNER   BPR                                        #
#           BPSUPPLIER BPS                                        #
#           BPCUSTOMER BPC                                        #
#           BPADDRESS  BPA                                        #
#           BPDLVCUST  BPD                                        #
#                                                                 #
# BPRLIB.CTL_BPS_DOUFLG: Contrôle si fournisseur en litige        #
# BPRLIB.IS_BPS_ACTIVE : Contrôle si fournisseur actif BPS.ENAFLG #
# BPRLIB.IS_BPC_ACTIVE : Contrôle si client      actif BPS.BPCSTA #
#                                                                 #
# Subprog FIND_BPAADD ( LBPSNUM, LBPAADD )                        #
# Subprog FIND_BPDADD ( LBPSNUM, LBPAADD )                        #
# Subprog FIND_FCYADD ( LFCY   , LBPAADD )                        #
# Subprog FIND_SCOLOC ( LBPCNUM, LBPAADD, LLOC, LRCPFCY, LSTOFCY )#
#                                                                 #
# $READ_BPR            : Lecture BPR référence WBPRNUM            #
# $READ_BPS            : Lecture BPS référence WBPRNUM            #
# $READ_BPC            : Lecture BPC référence WBPRNUM            #
# $READ_BPD            : Lecture BPD références WBPRNUM WBPAADD   #
# $READ_BPA            : Lecture BPA références WBPRNUM WBPAADD   #
#                                                                 #
###################################################################
# Actions :
#     SELBPRSCO sélection d'un sous-traitant (prestataire)
###################################################################
# GA Mai 2006 adapté multi-société selon module Ventes
###################################################################

$ACTION
Case ACTION

 When "SEL_TABLE"    : Gosub SEL_TABLE

 When Default
Endcase
Return


################################################################################
## Action SELBPRSCO
################################################################################
$SEL_TABLE
Case TABLE
 When "SELBPRSCO"    : Gosub SELBPRSCO
Endcase
Return

$SELBPRSCO
# PARAM(1) Type de tiers
# PARAM(2) Options

If PARAM(1)="" : PARAM(1)="1=1" : Endif
CRITERE(1) = PARAM(1)
OPTIONS    = PARAM(2)
OBJET      = "BPR"
Return

###############################################################

Funprog CTL_BPS_DOUFLG(LBPSNUM)
Value Char LBPSNUM
Local Integer WOK : WOK=2
Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPSNUM

  #----- Contrôle si fournisseur en litige  -----#
  Gosub READ_BPS
  If [F:BPS]BPSNUM=""
    Call AVERTIR(mess(196,194,1),WOK) From GESECRAN
  Elsif [F:BPS]DOUFLG=2
    # Le fournisseur est en litige.
    Call AVERTIR(mess(4,194,1),WOK) From GESECRAN
  Elsif [F:BPS]DOUFLG=3                : # Bloquer la saisie
    GMESSAGE=LBPSNUM-" "-mess(4,194,1) : mkstat=1 : WOK=1
  Endif

End WOK

###############################################################

Funprog IS_BPS_ACTIVE(LBPSNUM)
Value Char LBPSNUM
Local Integer WOK : WOK=2
Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPSNUM

  #----- Contrôle si fournisseur actif  -----#
  Gosub READ_BPS
  If [F:BPS]BPSNUM=""
    Call AVERTIR(mess(196,194,1),WOK) From GESECRAN
  Elsif [F:BPS]ENAFLG<>2
    GMESSAGE=LBPSNUM-" "-mess(220,194,1) : mkstat=1 : WOK=1
  Endif

End WOK

##################################################################

Funprog IS_BPC_ACTIVE(LBPCNUM)
Value Char LBPCNUM
Local Integer WOK : WOK=2
Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPCNUM

  #----- Contrôle si client actif  -----#
  Gosub READ_BPC
  If [F:BPC]BPCNUM=""
    Call AVERTIR(mess(313,194,1),WOK) From GESECRAN
  Elsif [F:BPC]BPCSTA<>2
    GMESSAGE = LBPCNUM-" "-mess(4,119,1) : mkstat=1 : WOK=1 :
  Endif
End WOK


#########################################################################
## Adresse par défaut pour ce fournisseur ?
#########################################################################
Subprog FIND_BPAADD(LBPSNUM, LBPAADD )
Value    Char    LBPSNUM
Variable Char    LBPAADD

Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPSNUM
Local Char    WBPAADD (GLONBPD): WBPAADD = LBPAADD
Local Integer TROUVE : TROUVE = 0

If LBPAADD<>""
   Gosub READ_BPA
   If fstat : Raz LBPAADD Else TROUVE = 1 Endif
Endif

If TROUVE = 0
  #----- lecture fournisseur -----#
  Gosub READ_BPS
  #----- Recherche de l'adresse par défaut du fournisseur -----#
  If [F:BPS]BPSNUM<>""
      If [F:BPS]BPAADD <> ""
         LBPAADD = [F:BPS]BPAADD : TROUVE = 1
      Endif
  Endif
Endif

# Suite à recherche CCC: cette zone n'est plus mise à jour ....
#  If TROUVE = 0
#    If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif
#    #----- Recherche de l'adresse par défaut -----#
#    Filter [BPA] Where BPATYP=1 & BPANUM=LBPSNUM & BPAADDFLG=2
#      Read [BPA] First
#      If fstat : Raz [F:BPA] : Endif
#    Filter [BPA]
#    LBPAADD = [F:BPA]BPAADD
#  Endif

End

#########################################################################
## Adresse par défaut pour ce client livré           # FQ 54676 & 54554 #
#########################################################################
Subprog FIND_BPDADD(LBPCNUM, LBPDADD )
Value    Char    LBPCNUM
Variable Char    LBPDADD

Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPCNUM
Local Char    WBPAADD (GLONBPD): WBPAADD = LBPDADD
Local Integer TROUVE : TROUVE = 0

If LBPDADD<>""
   Gosub READ_BPA
   If fstat : Raz LBPDADD : Raz GMESSAGE Else TROUVE = 1 Endif
Endif

If TROUVE = 0
  #----- lecture client livré -----#
  Gosub READ_BPD
  #----- Recherche de l'adresse par défaut du client livré -----#
  If [F:BPD]BPCNUM<>""
      If [F:BPD]BPAADD <> ""
         LBPDADD = [F:BPD]BPAADD : TROUVE = 1
      Endif
  Endif
Endif

End


#########################################################################
## Adresse par défaut pour ce site ?
#########################################################################
Subprog FIND_FCYADD(LFCY, LBPAADD )
Value    Char    LFCY
Variable Char    LBPAADD

Local Integer TROUVE : TROUVE = 0

  If [F:FCY]FCY<>LFCY
     Read [F:FCY]FCY0=LFCY    : # V6 adresse par défaut du site
     If fstat Raz [F:FCY] Endif
  Endif
  If [F:FCY]BPAADD <> ""
     LBPAADD = [F:FCY]BPAADD : TROUVE = 1
  Endif

End


#########################################################################
## Emplacement de sous-traitance pour ce client/fournisseur ?
#########################################################################
Subprog FIND_SCOLOC(LBPCNUM, LBPAADD, LLOC, LRCPFCY, LSTOFCY)
Value    Char    LBPCNUM
Variable Char    LBPAADD
Variable Char    LLOC
Variable Char    LRCPFCY
Variable Char    LSTOFCY
#
Local Char    WBPRNUM (GLONBPR): WBPRNUM = LBPCNUM
Local Char    WBPAADD (GLONBPD): WBPAADD = LBPAADD
Local Char    WRCPFCY (GLONFCY): WRCPFCY = LRCPFCY # Issue 85539
Local Char    WSTOFCY (GLONFCY): WSTOFCY = LSTOFCY # Issue 85539
Local Integer TROUVE : TROUVE = 0

# Issue 85539 Site de réception déjà choisi: maj de l'adresse client livré
If WSTOFCY<>""
    If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif
    Filter [BPD] Where STOFCY=WSTOFCY
&                    & BPCNUM=WBPRNUM
    Read [BPD] First
    Filter [BPD]
   If !fstat
      WBPAADD=[F:BPD]BPAADD
      If [F:BPD]SCOLOC <> ""
          TROUVE = 1
          LLOC = [F:BPD]SCOLOC
          LBPAADD = [F:BPD]BPAADD
      Endif
   Endif
Endif

If TROUVE = 0 & WBPAADD=""
   Call FIND_BPAADD(WBPRNUM, WBPAADD)
   LBPAADD = WBPAADD
Endif

# Ctrl si le fournisseur est identifié comme client
#
# Recherche de l'emplacement du client livré
If TROUVE = 0 & WBPRNUM <> "" & WBPAADD <> ""
   Gosub READ_BPD
   If [F:BPD]SCOLOC <> ""
      TROUVE = 1
      LLOC = [F:BPD]SCOLOC
      # -----------------------------------------------
      # Site de réception du client livré
      # => Site de production (ordre de sous-traitance)
      # -----------------------------------------------
      # Issue 95308 GA 01/2014 adresse client livré détermine (écrase) le site de production
      If [F:BPD]RCPFCY<>"" # & LRCPFCY=""
         LRCPFCY= [F:BPD]RCPFCY
      Endif
      #
      # ----------------------------------------------------------------
      # Site d'expédition du client livré:
      # => Site de stockage des matières (emplacement de sous-traitance)
      # => Site de réception de l'article sous-traité (par défaut)
      # ----------------------------------------------------------------
      # Issue 95308 GA 01/2014 adresse client livré détermine (écrase) le site de réception
      If [F:BPD]STOFCY<>"" # & LSTOFCY=""
         LSTOFCY= [F:BPD]STOFCY
      Endif
   Endif
Endif
# Sinon, Recherche de l'emplacement du fournisseur
If TROUVE = 0
   If WBPRNUM <> ""
      Gosub READ_BPS
      If [F:BPS]BPSNUM<>"" & [F:BPS]LOC <> ""
         LLOC = [F:BPS]LOC
      Endif
   Endif
Endif
#
End


###############################################################

$READ_BPR
If dim(WBPRNUM)>0
  If clalev([F:BPR])   = 0 : Local File BPARTNER    [BPR]   : Endif
  If [F:BPR]BPRNUM <> WBPRNUM
     #If dim([F:BPR]WCPY)<=0
        Read [BPR] BPR0=WBPRNUM
        If fstat : Raz [F:BPR] : Endif
     #Else
     #   Read [BPR] BPR0=GSOCIETE;WBPRNUM
     #   If fstat : Raz [F:BPR] : Endif
     #Endif
  Endif
Else
  Call ECR_TRACE ("BPRLIB: Ligne BPR non lue !",0) From GESECRAN
Endif
Return

###############################################################

$READ_BPS
If dim(WBPRNUM)>0
  If clalev([F:BPS])   = 0 : Local File BPSUPPLIER    [BPS]   : Endif
  If [F:BPS]BPSNUM <> WBPRNUM
     #If dim([F:BPS]WCPY)<=0
        Read [BPS] BPS0=WBPRNUM
        If fstat : Raz [F:BPS] : Endif
     #Else
     #   Read [BPS] BPS0=GSOCIETE;WBPRNUM
     #   If fstat : Raz [F:BPS] : Endif
     #Endif
  Endif
Else
  Call ECR_TRACE ("Ligne BPS non lue !",0) From GESECRAN
Endif
Return

###############################################################

$READ_BPC
If dim(WBPRNUM)>0
  If clalev([F:BPC])   = 0 : Local File BPCUSTOMER    [BPC]   : Endif
  If [F:BPC]BPCNUM <> WBPRNUM
     #If dim([F:BPC]WCPY)<=0
        Read [BPC] BPC0=WBPRNUM
        If fstat : Raz [F:BPC] : Endif
     #Else
     #   Read [BPC] BPC0=GSOCIETE;WBPRNUM
     #   If fstat : Raz [F:BPC] : Endif
     #Endif
  Endif
Else
  Call ECR_TRACE ("Ligne BPC non lue !",0) From GESECRAN
Endif
Return

###############################################################
$READ_BPD              # Recherche du client livré par défaut
If dim(WBPRNUM)>0 & dim(WBPAADD)>0
  If clalev ([F:BPD])=0  Local File BPDLVCUST   [BPD] : Endif
  If clalev ([F:BPC])=0  Local File BPCUSTOMER  [BPC] : Endif
# Issue 85539 - 2012-11-02 by CCC : si l'adresse est renseignée on ne la modifie pas
#  If [F:BPC]BPCNUM <> WBPRNUM | WBPAADD=""
  If [F:BPC]BPCNUM <> WBPRNUM & WBPAADD=""
     Read [BPC]BPC0=WBPRNUM
     If fstat Raz [F:BPC] Endif
     # Issue X3-40501 - 2017-12-05 by MUARN : client livré par défaut
     #WBPAADD=[F:BPC]BPAADD
     WBPAADD=[F:BPC]BPDADD
  Endif
  If [F:BPD]BPCNUM <> WBPRNUM | [F:BPD]BPAADD <> WBPAADD
     #If dim([F:BPD]WCPY)<=0
        If WBPAADD<>""
           Read [BPD]BPD0=WBPRNUM;WBPAADD
           If fstat : Raz [F:BPD] : Endif
        Else
           Read [BPD]BPD0(1)=WBPRNUM
           If fstat : Raz [F:BPD] : Endif
           [G:BPD]currind=1 : [G:BPD]currlen=0 : # Réinitialisation clé par défaut
        Endif
     #Else
     #   Read [BPD] BPD0=GSOCIETE;WBPRNUM;WBPAADD
     #   If fstat : Raz [F:BPD] : Endif
     #Endif
  Endif
Else
  Call ECR_TRACE ("Ligne BPD non lue !",0) From GESECRAN
Endif
Return

###############################################################

$READ_BPA   : # Validité d'une adresse d'un tiers BPATYP=1 ou d'un site BPATYP=3
If dim(WBPRNUM)>0 & dim(WBPAADD)>0
  If clalev ([F:BPA])=0  Local File BPADDRESS [BPA] : Endif
  If [F:BPA]BPANUM <> WBPRNUM | [F:BPA]BPAADD <> WBPAADD
     #If dim([F:BPA]WCPY)<=0
        Read [BPA]BPA0=1;WBPRNUM;WBPAADD
        If fstat
          Read [BPA]BPA0=3;WBPRNUM;WBPAADD
          If fstat Raz [F:BPA] Endif
        Endif
     #Else
     #   Read [BPA] BPA0=GSOCIETE;1;WBPRNUM;WBPAADD
     #   If fstat : Raz [F:BPA] : Endif
     #Endif
  Endif
Else
  Call ECR_TRACE ("Ligne BPA non lue !",0) From GESECRAN
Endif
Return

