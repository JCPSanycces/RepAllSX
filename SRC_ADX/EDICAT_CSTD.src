#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
  Local Integer WNBERR : WNBERR = 0
  Local Char WERR(250) : WERR = ""
  Local Integer I, WOK

  If this.CATACT = 1 #issue
    For I = 1 To maxtab(this.ECAK)
      If this.ECAK(I) <> null
        Case this.ECAK(I).CODE
          When "BPANUM":
            If this.ECAK(I).FLD=""
              WNBERR=1
              #"Business partner must be defined"
              ASTATUS = fmet this.ECAK(I).ASETERROR("FLD", mess(5,2006,1), [V]CST_AWARNING)
            Else
              If func TEST_FLD(this.ECAK(I)) <> [V]CST_AOK
                WNBERR=1
              Endif
            Endif
          When "BPAADD":
            If this.ECAK(I).FLD=""
              WNBERR=+1
              #"Business partner address code must be defined"
              ASTATUS = fmet this.ECAK(I).ASETERROR("FLD", mess(4,2006,1), [V]CST_AWARNING)
            Else
              If func TEST_FLD(this.ECAK(I)) <> [V]CST_AOK
                WNBERR=1
              Endif
            Endif
          When "CPY"
            If (this.ECAK(I).FLD="")
              WNBERR=+1
              #"Company must be defined"
              ASTATUS = fmet this.ECAK(I).ASETERROR("FLD", mess(15,2006,1), [V]CST_AWARNING)
            Else
              If func TEST_FLD(this.ECAK(I)) <> [V]CST_AOK
                WNBERR=1
              Endif
            Endif
          When "FCY"
            If (this.ECAK(I).FLD="")
              WNBERR=+1
              #"Site code must be defined"
              ASTATUS = fmet this.ECAK(I).ASETERROR("FLD", mess(25,2006,1), [V]CST_AWARNING)
            Else
              If func TEST_FLD(this.ECAK(I)) <> [V]CST_AOK
                WNBERR=1
              Endif
            Endif
        Endcase
      Endif
    Next I
  Endif

  #si un legisltation exception a le meme duplicate flag que le duplicate flag en-tête, alors on supprime la ligne
  For I = 1 To maxtab(this.ECAL)
    If this.ECAL(I)<>null
&   and this.ECAL(I).ASTALIN <> [V]CST_ADEL
&   and this.ECAL(I).ASTALIN <> [V]CST_ANEWDEL
&   and this.ECAL(I).DUPLICATE = this.DUPLICATE
      #delete line
      WOK = fmet this.ADELLINE("ECAL", I)
    Endif
    #110811 New parameters to control authorizations
    If this.CATTYP<3
      Local Integer VALPARAM
      Case this.CATTYP
        When 1: VALPARAM= fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG ,this.ECAL(I).CODE,"EXDPURINV")
        When 2: VALPARAM= fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG ,this.ECAL(I).CODE,"EXDSALINV")
      Endcase
      If VALPARAM=1
        WNBERR=+1
        #"Prohibited for legislation"
        ASTATUS = fmet this.ECAL(I).ASETERROR("CODE", mess(18,127,1), [V]CST_AERROR)
        Break
      Endif
    Endif
    # End 110811
  Next I

  If WNBERR > 0
    this.VALID = [V]CST_ANO
    ARET_VALUE = [V]CST_AFALSE
  Else
    # Set Valid
    this.VALID = [V]CST_AYES
    ARET_VALUE = [V]CST_ATRUE
  Endif
Return

#********************************************************************
# Suprog GET_KEYS
#********************************************************************
# Get keys
#
#********************************************************************
Subprog GET_KEYS(WEDICAT)
Value Instance WEDICAT Using C_EDICAT
  Local Integer WPOS
  #110811_US11
  Local File EDICATREF [ECR]
  Read[ECR]ECR0=WEDICAT.CATTYP;WEDICAT.CATTRGTAB
  # 114061 US10
  If fstat=[V]CST_AOK
#    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD1
#    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD2
#    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD3
#    If [F:ECR]AUTCOD4<>""
#      WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD4
#      If [F:ECR]AUTCOD5<>""
#        WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD5
#      Endif
#    Endif
    #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    If [F:ECR]AUTCOD1<>""
      WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD1
      If [F:ECR]AUTCOD2<>""
        WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD2
        If [F:ECR]AUTCOD3<>""
          WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD3
          If [F:ECR]AUTCOD4<>""
            WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD4
            If [F:ECR]AUTCOD5<>""
              WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS): WEDICAT.ECAK(WPOS).CODE = [F:ECR]AUTCOD5
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS) : WEDICAT.ECAK(WPOS).CODE = "BPANUM"
    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS) : WEDICAT.ECAK(WPOS).CODE = "BPAADD"
    WPOS = fmet WEDICAT.ADDLINE("ECAK",[V]CST_ALASTPOS) : WEDICAT.ECAK(WPOS).CODE = "FCY"
  Endif
  #/114061 US10
  LogicClose File [ECR]
  #/110811 US11
End

#********************************************************************
# Funprog GET_DUPLICATE_FLG
#********************************************************************
#
#
#********************************************************************
Funprog GET_DUPLICATE_FLG(WCATCOD, WLEG)
Value Char WCATCOD
Value Char WLEG

  Local Integer WDUPLICATE_FLG : WDUPLICATE_FLG = [V]CST_ANO

  If WLEG <> "" and WCATCOD <> ""
    Local File EDICATL [ECAL]
    Read [ECAL]ECAL2 = WCATCOD;WLEG
    If !fstat
      WDUPLICATE_FLG = [ECAL]DUPLICATE
    Else
      Local File EDICAT [ECA]
      Read [ECA]ECA0 = WCATCOD
      If !fstat
        WDUPLICATE_FLG = [ECA]DUPLICATE
      Endif
      LogicClose File [ECA]
    Endif
    LogicClose File [ECAL]
  Endif
End WDUPLICATE_FLG

#********************************************************************
# Funprog CATCOD_IS_USED
#********************************************************************
#
#
#********************************************************************
Funprog CATCOD_IS_USED(WCATCOD)
Value Char WCATCOD

  Local Integer WOK  : WOK = [V]CST_AFALSE
  WERR = ""

  Local File EDIFLO [EFL]
  Filter [EFL] Where CATCOD=WCATCOD
  For [EFL]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EFL]

  Local File EDIPARTNERD [EPRD]
  Filter [EPRD] Where CATCOD=WCATCOD
  For [EPRD]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EPRD]

  Local File EDIBPRCPYD [EBCD]
  Filter [EBCD] Where CATCOD=WCATCOD
  For [EBCD]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EBCD]

  Local File EDIRUN [EDR]
  Filter [EDR] Where CATCOD=WCATCOD
  For [EDR]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EDR]

End WOK

#********************************************************************
# Funprog GET_FLGSYRA
#********************************************************************
# R&D needs to set if object is syracused with classes or not
#
#********************************************************************
Funprog GET_FLGSYRA(WCATTYP) # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
Value Integer WCATTYP
Local Integer WFLGSYRA
  Case WCATTYP
    When 1       : WFLGSYRA   = [V]CST_ANO  #Purchase invoice
    When 2       : WFLGSYRA   = [V]CST_ANO  #Sales invoice
    When 3       : WFLGSYRA   = [V]CST_ANO  #Purchase order
    When 4       : WFLGSYRA   = [V]CST_ANO  #Sales order
    When 5       : WFLGSYRA   = [V]CST_ANO  #Sales delivery
    When 6       : WFLGSYRA   = [V]CST_AYES #Intrasat // Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    When 7       : WFLGSYRA   = [V]CST_AYES #Sales delivery notification  : X3-7673 EDI improvements CRUD method for receipt
    When Default : WFLGSYRA   = [V]CST_ANO
  Endcase
End WFLGSYRA

#********************************************************************
# Funprog GET_CATTRGTAB
#********************************************************************
# R&D needs to set default table for the object
#
#********************************************************************
Funprog GET_CATTRGTAB(WCATTYP) # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
Value Integer WCATTYP
Local Char WCATTRGTAB(100)
  Case WCATTYP
    When 1       : WCATTRGTAB = "PINVOICE"    #Purchase invoice
    When 2       : WCATTRGTAB = "SINVOICEV"   #Sales invoice
    When 3       : WCATTRGTAB = "PORDER"      #Purchase order
    When 4       : WCATTRGTAB = "SORDER"      #Sales order
    When 5       : WCATTRGTAB = "SDELIVERY"   #Sales delivery
    When 6       : WCATTRGTAB = "EDIDEB"      #Intrasat //Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    When 7       : WCATTRGTAB = "SDELIVERYNO" #Sales delivery notification  : X3-7673 EDI improvements CRUD method for receipt
    When Default : WCATTRGTAB = ""
  Endcase
End WCATTRGTAB

#********************************************************************
# Funprog GET_DUPLICATE
#********************************************************************
#
#
#********************************************************************
Funprog GET_DUPLICATE(WCATTYP)
Value Integer WCATTYP
Local Integer WDUPLICATE
  Case WCATTYP
    When 1       : WDUPLICATE   = 2 #Purchase invoice
    When 2       : WDUPLICATE   = 2 #Sales invoice
    When 3       : WDUPLICATE   = 1 #Purchase order
    When 4       : WDUPLICATE   = 1 #Sales order
    When 5       : WDUPLICATE   = 1 #Sales delivery
    When 6       : WDUPLICATE   = 1 #Intrasat // US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    When 7       : WDUPLICATE   = 1 #Sales delivery notification
    When Default : WDUPLICATE   = 1
  Endcase
End WDUPLICATE

