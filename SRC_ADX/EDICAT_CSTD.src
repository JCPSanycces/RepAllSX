#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Class EDICAT                                                                #
# Author : RBA +JUCON                                                         #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADELETE_CONTROL_BEFORE" : Gosub ADELETE_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
      Endcase
    When "ECAD"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub ECAD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub ECAD_ADDLINE_AFTER
        When "ADELLINE_BEFORE"        : Gosub ECAD_ADELLINE_BEFORE
      Endcase
    When "ECAK"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub ECAK_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub ECAK_ADDLINE_AFTER
        When "ADELLINE_BEFORE"        : Gosub ECAK_ADELLINE_BEFORE
      Endcase
    When "ECAL"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub ECAL_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub ECAL_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"           : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CATCOD"
      Case [L]ARULE
        When "CONTROL"      : Gosub CATCOD_CONTROL
      Endcase
    When "CATTYP"
      Case [L]ARULE
        When "INIT"         : Gosub CATTYP_INIT
        When "PROPAGATE"    : Gosub CATTYP_PROPAGATE
      Endcase
    When "CATACT"
      Case [L]ARULE
        When "INIT"         : Gosub CATACT_INIT
        When "CONTROL"      : Gosub CATACT_CONTROL
        When "PROPAGATE"    : Gosub CATACT_PROPAGATE
      Endcase
    When "CATOPE" # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
      Case [L]ARULE
        When "INIT"         : Gosub CATOPE_INIT
        When "CONTROL"      : Gosub CATOPE_CONTROL
        When "PROPAGATE"    : Gosub CATOPE_PROPAGATE
      Endcase
    When "DUPLICATE"
      Case [L]ARULE
        When "INIT"         : Gosub DUPLICATE_INIT
        When "CONTROL"      : Gosub DUPLICATE_CONTROL
        When "PROPAGATE"    : Gosub DUPLICATE_PROPAGATE
      Endcase
    When "CATTRGTAB"
      Case [L]ARULE
        When "CONTROL"      : Gosub CATTRGTAB_CONTROL
        When "PROPAGATE"    : Gosub CATTRGTAB_PROPAGATE
      Endcase
    When "CODIND"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub CODIND_PROPAGATE
      Endcase
    When "FNC"            # Issue 110811 US9
      Case [L]ARULE
        When "PROPAGATE"    : Gosub FNC_PROPAGATE
      Endcase
    When "ECAD.FLD"
      Case [L]ARULE
        When "CONTROL"      : Gosub ECAD_FLD_CONTROL
        When "PROPAGATE"    : Gosub ECAD_FLD_PROPAGATE
      Endcase
    When "ECAD.FLDVAL1"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub ECAD_FLDVAL1_PROPAGATE
      Endcase
    When "ECAD.FLDVAL2"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub ECAD_FLDVAL2_PROPAGATE
      Endcase
    When "ECAD.OPERATOR"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub ECAD_OPERATOR_PROPAGATE
      Endcase
    When "ECAK.CODE"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub ECAK_CODE_PROPAGATE
      Endcase
    When "ECAK.FLD"
      Case [L]ARULE
        When "CONTROL"      : Gosub ECAK_FLD_CONTROL
      Endcase
    When "ECAL.CODE"
      Case [L]ARULE
        When "CONTROL"      : Gosub ECAL_CODE_CONTROL
      Endcase
    When "ECAL.DUPLICATE"
      Case [L]ARULE
        When "CONTROL"      : Gosub ECAL_DUPLICATE_CONTROL
      Endcase
  Endcase
Return


####################################################################

$CATCOD_CONTROL
  If this.CATCOD <> ""
    this.CATCOD = func EDILIBA.FORMATVAL("CATCOD", this.CATCOD)
  Endif
Return


####################################################################

$CATTYP_INIT
  this.CATTYP = 1
Return

$CATTYP_PROPAGATE
  this.FLGSYRA   = func GET_FLGSYRA(this.CATTYP) # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  this.CATTRGTAB = func GET_CATTRGTAB(this.CATTYP)
  this.DUPLICATE = func GET_DUPLICATE(this.CATTYP)

  this.CATOPE = 2 #by default

  #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  Call DELETELINES(this, "ECAD") From EDILIBA
  Call DELETELINES(this, "ECAK") From EDILIBA
  Call GET_KEYS(this)
Return


####################################################################

$CATACT_INIT
  this.CATACT = 1
Return

$CATACT_CONTROL
  #si il existe au moins un EDIPARTNER, au moins un Flux, au moins un Startup qui utilise le code, alors impossible de modifier
  Local Char WERR(250)
#  If num$(this.CREDATTIM)<>"0000-00-00T00:00:00Z"
#    Call GET_KEYS(this)
#  Endif
  If this.CATCOD <> ""  and this.CATACT <> this.snapshot.CATACT   #SAM 118799
    If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
      WERR = mess(9,123,1) #modification impossible
      ASTATUS = fmet this.ASETERROR("CATACT", WERR, [V]CST_AERROR)
      this.CATACT = this.snapshot.CATACT
    Endif
  Endif
Return

$CATACT_PROPAGATE
  Case this.CATACT
    When 1 : #issue
     #afficher les aut EDI
      Call GET_KEYS(this)
    When 2 : #Receive
     #supprimer les lignes filtres
     #supp les auto EDI
      Call DELETELINES(this, "ECAD") From EDILIBA
      Call DELETELINES(this, "ECAK") From EDILIBA
  Endcase
Return

# Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements

$CATOPE_INIT
  this.CATOPE = 2 #Create
Return

$CATOPE_CONTROL
  Local Char WERR(250)
  If (this.FLGSYRA <> [V]CST_AYES and this.CATOPE <> 2) or this.CATOPE = 1 or this.CATOPE = 4 #Read or Update
    WERR = mess(105,2006,1) #"Erreur valeur interdite"
    ASTATUS = fmet this.ASETERROR("CATOPE", WERR, [V]CST_AERROR)
  Endif

  If this.CATCOD <> ""  and this.CATACT <> this.snapshot.CATACT   #SAM 118799
    If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
      WERR = mess(9,123,1) #modification impossible
      ASTATUS = fmet this.ASETERROR("CATOPE", WERR, [V]CST_AERROR)
      this.CATOPE = this.snapshot.CATOPE
    Endif
  Endif
Return

$CATOPE_PROPAGATE
Return


####################################################################

$DUPLICATE_INIT
#  this.DUPLICATE = 1
  Case this.CATTYP
    When 1       : this.DUPLICATE = 2 #Purchase invoice
    When 2       : this.DUPLICATE = 2 #Sales invoice
    When Default : this.DUPLICATE = 1
  Endcase
Return

$DUPLICATE_CONTROL
Return

$DUPLICATE_PROPAGATE
  Local Char WERR(20)
  Local Integer I, WOK
  For I = 1 To maxtab(this.ECAL)
    If this.ECAL(I)<>null and this.ECAL(I).ASTALIN <> [V]CST_ADEL and this.ECAL(I).ASTALIN <> [V]CST_ANEWDEL
&   and this.ECAL(I).DUPLICATE = this.DUPLICATE
      WERR = mess(105,2006,1)
      ASTATUS = fmet this.ECAL(I).ASETERROR("DUPLICATE", WERR,[V]CST_AERROR)
    Else
      ASTATUS = fmet this.ECAL(I).ADELETEERROR("DUPLICATE")
    Endif
  Next I
Return

####################################################################

$CATTRGTAB_CONTROL
  #si il existe au moins un EDIPARTNER, au moins un Flux, au moins un Startup qui utilise le code, alors impossible de modifier
  Local Char WERR(250)
  If this.CATTRGTAB <> ""  and this.CATTRGTAB <> this.snapshot.CATTRGTAB  #SAM 118799
    If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
      WERR = mess(9,123,1) #modification impossible
      ASTATUS = fmet this.ASETERROR("CATTRGTAB", WERR, [V]CST_AERROR)
      this.CATTRGTAB = this.snapshot.CATTRGTAB
    Endif
  Endif
Return

$CATTRGTAB_PROPAGATE
  Local Integer WOK
  Local Char WERR(250)
  Local Integer I
  #Issue X3-51053 by RBA : WCODIND non existent variable on EDI categories function
  Local Char WCODIND(10) : WCODIND = ""

  If this.CATTRGTAB <> ""
    Call DELETELINES(this, "ECAD") From EDILIBA
#    Call DELETELINES(this, "ECAK") From EDILIBA
#    Local Char WCODIND(10) : WCODIND = ""   #Issue X3-51053 by RBA : WCODIND non existent variable on EDI categories function
    Local File ATABLE [ATB]
    Read [ATB]CODFIC = this.CATTRGTAB
    If !fstat
      Local File ATABIND [ATI]
      Filter [ATI] Where CODFIC = this.CATTRGTAB and [ATI]HOMONYM=[V]CST_ANO Order By NUMLIG Asc
      For [ATI]
#        this.CODIND = [ATI]CODIND
        WCODIND = [ATI]CODIND
        Break
      Next
      LogicClose File [ATI]

      For I = 1 To maxtab(this.ECAK)
        this.ECAK(I).CODFIC = this.CATTRGTAB
      Next I

#      If this.CATACT = 1 #Issue
#        Call GET_KEYS(this)
#      Endif
    Else
      #"Nonexistent table"
      ASTATUS = fmet this.ASETERROR("CATTRGTAB",mess(69,2006,1),[V]CST_AERROR)
    Endif
    LogicClose File [ATB]
  Endif

  this.CODIND = WCODIND
Return

####################################################################

$CODIND_PROPAGATE
  If this.CODIND = ""
    this.DESCRIPT = ""
  Else
#    Gosub GETVALCODIND
    Local File ATABIND [ATI]
    Read [ATI]CODIND = this.CATTRGTAB;this.CODIND
    If fstat
      this.DESCRIPT = ""
      #Nonexistent field
      ASTATUS = fmet this.ASETERROR("CODIND",mess(8,124,1),[V]CST_AERROR)
    Elsif [ATI]HOMONYM = [V]CST_AYES
      this.DESCRIPT = ""
      #"Index with homonyms is prohibited"
      ASTATUS = fmet this.ASETERROR("CODIND",mess(37,2006,1),[V]CST_AERROR)
    Else
      this.DESCRIPT = [ATI]DESCRIPT
    Endif
    LogicClose File [ATI]
  Endif
Return

####################################################################

# Issue 110811 US9 by CJ
$FNC_PROPAGATE
  If this.FNC <> ""
    this.FNC=toupper(this.FNC)
    Local File AFONCTION [AFC]
    Read [AFC]CODINT = this.FNC
    If fstat
      this.FNC = ""
      #Nonexistent function
      ASTATUS = fmet this.ASETERROR("FNC",mess(162,123,1),[V]CST_AERROR)
    Else
    Endif
    LogicClose File [AFC]
  Endif
Return
#/ Issue 110811 US9 by CJ

####################################################################

$ECAD_FLD_CONTROL
  If this.FLD <> ""
    this.FLD = toupper(this.FLD)
    #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = this.APARENT.CATTRGTAB;this.FLD
    If fstat
      #Nonexistent field
      ASTATUS = fmet this.ASETERROR("FLD",mess(8,124,1),[V]CST_AERROR)
    Endif
    LogicClose File [ATZ]
  Endif
Return

$ECAD_FLD_PROPAGATE
  If this.FLD <> ""
    #check if zone hasn't been set yet
    Local Integer I
    For I = 1 To maxtab(this.APARENT.ECAD)
      If this.APARENT.ECAD(I)<>null and this.APARENT.ECAD(I).ASTALIN <> [V]CST_ADEL and this.APARENT.ECAD(I).ASTALIN <> [V]CST_ANEWDEL
&       and this.APARENT.ECAD(I).FLD = this.FLD
&       and this.APARENT.ECAD(I).AORDER <> this.AORDER
        #This field has already been selected
        ASTATUS = fmet this.ASETERROR("FLD",mess(248,139,1) ,[V]CST_AERROR)
      Break
    Endif
    Next I
    Local Char WERR(250)
    If this.FLD <> ""  and this.FLD <> this.snapshot.FLD    #SAM 118799
      If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
        WERR = mess(9,123,1) #modification impossible
        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
        this.FLD = this.snapshot.FLD      #SAM 118799
      Endif
    Endif
  Endif
Return

####################################################################

$ECAD_OPERATOR_PROPAGATE
#    When 1 :
#     WOK = this.FLDVAL2 = ""
  Case this.OPERATOR
    When 2, 3, 4 :
      this.FLDVAL2 = ""
    Endcase
Return

####################################################################

$ECAD_FLDVAL1_PROPAGATE
  If this.FLDVAL1<>"" and this.UPDFLG=1
    WERR = mess(9,123,1) #modification impossible
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Endif
Return

$ECAD_FLDVAL2_PROPAGATE
  If this.FLDVAL2<>"" and this.UPDFLG=1
    WERR = mess(9,123,1) #modification impossible
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Endif
Return

####################################################################

$ECAK_FLD_CONTROL
  If this.FLD <> ""
    WOK = func TEST_FLD(this)
  Endif
Return

Funprog TEST_FLD(WOBJECT)
Variable Instance WOBJECT Using OBJECT
Local Char WCODTYP(8)
Local Integer WSTA : WSTA = [V]CST_AOK
Local Shortint WKO
  WOBJECT.FLD = toupper(WOBJECT.FLD)
  #check zone
    Local File ATABZON [ATZ]
    Read [ATZ]CODZONE = WOBJECT.APARENT.CATTRGTAB;WOBJECT.FLD
    If !fstat
      WCODTYP=[F:ATZ]CODTYP
      WKO=1
      #110811_US11 (CHECK_TYP)
      Case WOBJECT.CODE
        When "BPANUM":
          If WCODTYP="A" or WCODTYP="BPR" or WCODTYP="BPC" or WCODTYP="BPS" or WCODTYP="BPT" or WCODTYP="BPN"
            WKO=2
          Endif
        When "BPAADD":
          If WCODTYP="A" or WCODTYP="ADR" or WCODTYP="ADL" or WCODTYP="BPA" or WCODTYP="BPD"
            WKO=2
          Endif
        When "FCY":
          If WCODTYP="A" or WCODTYP="FCY"
            WKO=2
          Endif
        When Default #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
          WKO=2
      Endcase
      #/110811_US11
    Endif
    If WKO=1
       #Non valid field
      ASTATUS = fmet WOBJECT.ASETERROR("FLD",mess(7,09950,1) ,[V]CST_AWARNING)
      WSTA = [V]CST_AERROR
    Elsif WKO=0
      #Nonexistent field
      ASTATUS = fmet WOBJECT.ASETERROR("FLD",mess(8,124,1),[V]CST_AERROR)
      WSTA = [V]CST_AERROR
    Endif
#  Endif
  LogicClose File [ATZ]
End WSTA

####################################################################

$ECAK_CODE_PROPAGATE
  this.CODNAM = func EDILIBA.GET_CODNAM(this.CODE)
Return

####################################################################

$ECAL_CODE_CONTROL
  #si multi tester que c'est une leg qui appartient au dossier
  If this.CODE <> ""
    this.CODE = func EDILIBA.FORMATVAL("CODE", this.CODE)
    #tester l'existence de la leg dans le dossier
    Local Integer I, WFOUND : WFOUND = [V]CST_AFALSE
    Local Char WERR(100)
    Local File ADOSSIER [ADS]
    Read [ADS]DOSSIER = this.DOSSIER
    If !fstat
      For I = 0 To [ADS]NBLEG-1
        If [ADS]DOSLEG(I) =  this.CODE
          WFOUND = [V]CST_ATRUE
          Break
        Endif
      Next I
    Else
      #err
    Endif
    LogicClose File [ADS]
    If WFOUND = [V]CST_AFALSE
      WERR = mess(42,7770,1)
      ASTATUS = fmet this.ASETERROR("CODE", WERR,[V]CST_AERROR)
    Else
      #verifier que le code n'a pas déjà été mis
      #110811 US3 New parameters to control duplicate authorizations
      Local Integer VALPARAM
      Case this.APARENT.CATTYP
        When 1: VALPARAM= fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG ,this.CODE,"EXDPURINV")
        When 2: VALPARAM= fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG ,this.CODE,"EXDSALINV")
        When  Default: VALPARAM=2
      Endcase
      If VALPARAM=2
        For I = 1 To maxtab(this.APARENT.ECAL)
          If this.APARENT.ECAL(I)<>null and this.APARENT.ECAL(I).ASTALIN <> [V]CST_ADEL and this.APARENT.ECAL(I).ASTALIN <> [V]CST_ANEWDEL
&           and this.AORDER <> this.APARENT.ECAL(I).AORDER
&           and this.CODE = this.APARENT.ECAL(I).CODE
            WERR = mess(102,2006,1)
            ASTATUS = fmet this.ASETERROR("CODE", WERR,[V]CST_AERROR)
            Break
          Endif
        Next I
      Else
        WERR = mess(18,127,1)
        ASTATUS = fmet this.ASETERROR("CODE", WERR,[V]CST_AERROR)
      Endif
  #/ 110811 US3
    Endif
  Endif

Return

####################################################################

$ECAL_DUPLICATE_CONTROL
  Local Char WERR(100)
  If this.DUPLICATE = this.APARENT.DUPLICATE
    WERR = mess(105,2006,1)
    ASTATUS = fmet this.ASETERROR("DUPLICATE", WERR,[V]CST_AERROR)
  Endif
Return

#********************************************************************
# Method ECAD_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$ECAD_ADDLINE_BEFORE
  Local Char WERR(250)
  If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
    WERR = mess(9,123,1) #modification impossible mess(54,123,1) #suppression impossible
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Else
    If this.CATACT = 2 #receive
      WERR = mess(70,2006,1) #Entry not allowed upon receipt
      ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Endif
  Endif
Return

#********************************************************************
# Method ECAD_ADDLINE_AFTER
#********************************************************************
#
#********************************************************************
$ECAD_ADDLINE_AFTER

  #on ajoute une ligne
  this.OPERATOR = 1
  this.NUMLIN    = 1 + max(this.APARENT.ECAD(1..maxtab(this.APARENT.ECAD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.ECAD)
    If this.APARENT.ECAD(I) <> null
      If this.APARENT.ECAD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.ECAD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.ECAD(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ECAD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.ECAD)
        If this.APARENT.ECAD(I) <> null
          OFFSET_LINE = this.APARENT.ECAD(I).AORDER - this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.ECAD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ECAD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  this.CODFIC = this.APARENT.CATTRGTAB
  this.UPDFLG = [V]CST_AYES

Return

#********************************************************************
# Method ECAD_ADELLINE_BEFORE
#********************************************************************
#*
#*!
$ECAD_ADELLINE_BEFORE

  Local Char WERR(250)
  If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
    WERR = mess(9,123,1) #modification impossible mess(54,123,1) #suppression impossible
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Endif
Return

#********************************************************************
# Method ECAK_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$ECAK_ADDLINE_BEFORE
  Local Char WERR(250)
  If func CATCOD_IS_USED(this.CATCOD) = [V]CST_ATRUE
    WERR = mess(9,123,1) #modification impossible mess(54,123,1) #suppression impossible
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  Endif
Return

#********************************************************************
# Method ECAK_ADDLINE_AFTER
#********************************************************************
#
#********************************************************************
$ECAK_ADDLINE_AFTER
  #on ajoute une ligne
  this.NUMLIN    = 1 + max(this.APARENT.ECAK(1..maxtab(this.APARENT.ECAK)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.ECAK)
    If this.APARENT.ECAK(I) <> null
      If this.APARENT.ECAK(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.ECAK(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.ECAK(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ECAK(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.ECAK)
        If this.APARENT.ECAK(I) <> null
          OFFSET_LINE = this.APARENT.ECAK(I).AORDER - this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.ECAK(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ECAK(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  this.CODFIC = this.APARENT.CATTRGTAB

Return


