#<AdxTL>@(#)3.0.0.0 $Revision$
#######################################################################
# Suppression des enreg du fichier FILTDS
# MAj des champs suplémentaires
#######################################################################
Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIPRMTDS : Mise à jour du paramétrage de l'extraction DADS-U ") From LECFIC
 Call EXE_UTIPRMTDS(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End


#########################################################
# Maj norme 
#########################################################
Subprog EXE_UTIPRMTDS(APPLI)
Value Char    APPLI

Call ECR_TRACE("UTIPRMTDS : Process Start on : "+APPLI,0) From GESECRAN

Gosub MAJ_PRMTDS
Call ECR_TRACE("UTIPRMTDS: Process End on : "+APPLI,0) From GESECRAN

End


#########################################################
# MAJ de la table PRMTDS1
#########################################################
$MAJ_PRMTDS
Local File =APPLI+".PRMTDS0" [TD0B]
Local File =APPLI+".PRMTDS1" [TD1B]
Local File ="PAIE.PRMTDS1" [TD1]

Call ECR_TRACE("UTIPRMTDS : Mise à jour des données de la table PRMTDS1",0) From GESECRAN

Trbegin [TD1B]
GOK=1

#Niveau dossier
Delete  [F:TD1B] Where LEV=1
If ! fstat
 For [F:TD1]TD10 Where LEV=1
  [F:TD1B]=[F:TD1]
  Write [F:TD1B]
  If fstat : GOK=0 : Break : Endif
 Next
Endif

If GOK
 #Niveau société
 Delete  [F:TD1B] Where LEV=2
 If !fstat
  For [F:TD0B]TD00 Where LEV=2
   For [F:TD1]TD10 Where LEV=1
    [F:TD1B]=[F:TD1]
    [F:TD1B]CPY=[F:TD0B]CPY
    [F:TD1B]LEV=2
    Write [F:TD1B]
    If fstat : GOK=0 : Break 2 : Endif
   Next
  Next
 Endif
Endif

If !GOK 
 Call ECR_TRACE("Echec de la mise à jour des données de la table PRMTDS1",1) From GESECRAN
 Rollback 
Else 
 Call ECR_TRACE("Mise à jour des données de la table PRMTDS1 effectuée",0) From GESECRAN
 Commit 
Endif

Close Local File [TD0B],[TD1B],[TD1]
Return

###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="PAIE" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","PRMTDS0","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","PRMTDS1","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","PRMTDS1","fde","PAIE"),0)<=0 : End : Endif
Call EXE_UTIPRMTDS(APPLI)
End





