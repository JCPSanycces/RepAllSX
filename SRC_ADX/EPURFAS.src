#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End
################################################################################################
# HISTO = 1 => Historisation                                                                   #
#                                                                                              #
#              Les données passent d'APPLI vers HISAPL                                         #
#              Les données historisées sont supprimées d'APPLI                                 #
#              Uniquement des contrôles liés au dossier APPLI                                  #
#                                                                                               #
# OKEPU  = 1 => Epuration                                                                      #
#                                                                                              #
#    Soit Epuration seule (OKEPU=1 et HISTO=0)                                                 #
#              Les données sont supprimées d'APPLI                                             #
#              Uniquement des contrôles liés au dossier APPLI.                                 #
#                                                                                              #
#    Soit Epuration suite à l'historisation (OKEPU=1 et HISTO=1)                               #
#              L'historisation a fait les vérifications nécessaires (cf HISTO=1)               #
#              L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier. #
#                                                                                              #
################################################################################################
################################################################################################
# Modifications :
# -------------
# MWA - 13/03/2017 FQ121374 : Erreur lors de l'épuration d'un bien sorti non archivé
# MDJ   25.05.2016 116777    Si épuration seule ne pas ouvrir les tables du dossier historique
# MDJ   15.05.2012 FQ82211   suppression de gestion des evts des biens sortis
#####################################################################################################
# EPURFAS            Traitements des épurations    Module Immobilisations                           #
# --------------------------------------------------------------------------------------------------#
# Règles d'épuration/historisation                         GLE 31/01/2008                           #
#  1- FASISS      : Epuration des biens sortis d'actif                                              #
#  2- FASDEPCLO   : Epuration des amortissements des exercices clos                                 #
#  3- EVEFAS      : Epuration des événements "biens" hors dotations des exercices clos              #
#  4- EVELOF      : Epuration des événements "dépenses" des exercices clos                          #
# --------------------------------------------------------------------------------------------------#
#   Fonctions                                # Formules                  Param                      #
#   ===========                              ==========                  =========                  #
#   func EPURFAS.GETDATINF(PSOC,PCNX,PPARAM) # FASDEPCLO-EVEFAS-EVELOF     (CPY,contexte)           #
#   func EPURFAS.GETDATCLO_INF(PSOC,PCNX)    # EVEFAS                      (CPY,contexte)           #
#####################################################################################################
$ACTION
Case ACTION
  When "OUVRE"
    #-----------------------------------------#
    # Ouvertures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "FASISS"          : Gosub OUVRE_FASISS
      When "FASDEPCLO"       : Gosub OUVRE_FASDEPCLO
      When "EVEFAS"          : Gosub OUVRE_EVEFAS
      When "EVELOF"          : Gosub OUVRE_EVELOF
    Endcase

  When "FILTRE"
    #----------------------------------------------------------------------------#
    # Vérifications complémentaires si critères insuffisants (OK=0 pour refuser) #
    #----------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "FASISS"          : Gosub FILTRE_FASISS
      When "FASDEPCLO"       : Gosub FILTRE_FASDEPCLO
      When "EVEFAS"          : Gosub FILTRE_EVEFAS
      When "EVELOF"          : Gosub FILTRE_EVELOF
    Endcase

  When "EPURE"
    #-------------------------------------------------------------------------#
    # Suppressions enregistrements tables complémentaires non liées à l'objet #
    #-------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "FASISS"          : Gosub EPURE_FASISS
      When "FASDEPCLO"       : Gosub EPURE_FASDEPCLO
      When "EVEFAS"          : Gosub EPURE_EVEFAS
      When "EVELOF"          : Gosub EPURE_EVELOF
  Endcase

  When "HISTO"
    #--------------------------------------------------------------------------#
    # Historisation enregistrements tables complémentaires non liées à l'objet #
    #--------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "FASISS"          : Gosub HISTO_FASISS
      When "FASDEPCLO"       : Gosub HISTO_FASDEPCLO
      When "EVEFAS"          : Gosub HISTO_EVEFAS
      When "EVELOF"          : Gosub HISTO_EVELOF
    Endcase

  When "FERME"
    #-----------------------------------------#
    # Fermetures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "FASISS"          : Gosub FERME_FASISS
      When "FASDEPCLO"       : Gosub FERME_FASDEPCLO
      When "EVEFAS"          : Gosub FERME_EVEFAS
      When "EVELOF"          : Gosub FERME_EVELOF
    Endcase
Endcase

Return
####################################################
# FASISS : Epuration des biens sortis d'actif      #
# ------------------------------------------------ #
# Formule d'épuration FASISS :                     #
#    ISSDAT <>[0/0/0] & EXTISSFLG = G_NON          #
####################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_FASISS

#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:LOF])   Local File =[L]HISAPL+".LAYOUTFAS"   [LOF]  : Endif
    If (GPHY = G_OUI )
      If clalev([F:PHY]) =0   : Local File =HISAPL+".PHYELT"      [PHY]    : Endif : # Eléments physiques
      If clalev([F:PHYH]) =0  : Local File =HISAPL+".PHYELT"     [PHYH]    : Endif : # Eléments physiques
    Endif
  #----- Historisation -----#
  Else
    If !clalev([F:LOF])    Local File =[L]APPLI +".LAYOUTFAS"  [LOF]  : Endif
    If !clalev([F:LOFH])   Local File =[L]HISAPL+".LAYOUTFAS"   [LOFH]  : Endif
    If (GPHY = G_OUI )
      If clalev([F:PHY])  =0  : Local File =APPLI+".PHYELT"      [PHY]   : Endif : # Eléments physiques
      If clalev([F:PHYH]) =0  : Local File =HISAPL+".PHYELT"     [PHYH]    : Endif : # Eléments physiques
    Endif
  Endif
#----- Epuration sans historisation -----#
Else
  If !clalev([F:LOF])    Local File =APPLI +".LAYOUTFAS"  [LOF]  : Endif
  # Issue 116777  If !clalev([F:LOFH])   Local File =[L]HISAPL+".LAYOUTFAS"   [LOFH]  : Endif
  If (GPHY = G_OUI )
     If clalev([F:PHY])  =0  : Local File =APPLI+".PHYELT"      [PHY]    : Endif : # Eléments physiques
     # Issue 116777    If clalev([F:PHYH]) =0  : Local File =HISAPL+".PHYELT"     [PHYH]    : Endif : # Eléments physiques
  Endif
Endif
#----- Ouverture tables complémentaires -----#
If clalev([F:ADI])=0   : Local File ATABDIV      [ADI]  : Endif    # tables diverses


# Si GADONIX=2 GTEST est forcé à 1 (dossier développement), pas de delete
# Si GADONIX=1 GTEST est forcé à 0, delete
# Forcer GTEST à 0 pour que les delete se fassent
#GTEST=0
#Infbox(GTRACE-"GTEST="+num$(GTEST))

Local Integer IPARAM_ISS
IPARAM_ISS = GNBEXNOHIS

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
$FILTRE_FASISS

Case TABLE
  When "FXDASSETS"   : FILTSUP = ""
  When  Default      : FILTSUP = ""
Endcase

Return
#-------------------------------------------------------------------------------#
$FILTSUP_FASISS

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
# LAYOUTFAS [LOF] Dépenses rattachées aux biens comptables                #
# Nota : Les liens sur la table LAYOUTFAS étant de type "Autre", il est   #
#        nécessaire d'effectuer les suppressions manuellement             #
#-------------------------------------------------------------------------#
$HISTO_FASISS

 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Integer CPYFLGPER(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Integer RETOUR
 Local Integer I_CPY
 Local Integer I_CNX
 Local Integer NBR_CPY
 Local Integer N_EXE
 Local Date    CNXDATMAX
 Local Date    LWDAT
 Local Integer L1, L2, L3, L4, L5, L6
 Local Char    WCLE
  L2 = 0
  L3 = 0
  L4 = 0
  L5 = 0
  L6 = 0
#----- Récupération des dates de fin d'exercice courant de chaque contexte  -----#
Call GET_CPY_DAT([F:F1]CPY,CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
#===================================================================
# Récupération de la valeur du paramètre NBEXNOHIS du chapitre "AAS"
#
 If IPARAM_ISS > 0 Then
   N_EXE = IPARAM_ISS
 Else
  N_EXE = 3
 Endif

  If CPYSTRFIY(1) <> [0/0/0]
  CNXDATMAX = gdat$(day(CPYSTRFIY(1)), month(CPYSTRFIY(1)), year(CPYSTRFIY(1))-N_EXE)
  Endif

  For I_CNX=2 To G300MAX
  If CPYSTRFIY(I_CNX)<>[0/0/0]
   LWDAT = gdat$(day(CPYSTRFIY(I_CNX)), month(CPYSTRFIY(I_CNX)), year(CPYSTRFIY(I_CNX))-N_EXE)
   If LWDAT <  CNXDATMAX
      CNXDATMAX = LWDAT
   Endif
  Endif
  Next I_CNX

  If CNXDATMAX > [0/0/0]
    If [F:F1]ISSDAT <= [0/0/0] or [F:F1]ISSDAT >= CNXDATMAX
      OKHIS = 0 : Return
    Endif
  Endif
  #----------------------------------------------------------------------------#
  # Suppressions enregistrements tables complémentaires non liées à l'objet    #
  # -------------------------------------------------------------------------- #
  # [L2] LAYOUTFAS [LOF] Dépenses rattachées aux biens comptables              #
  # [L3] EVELOF [ELF] Evénements rattachés au dépenses du bien sorti d'actif   #
  # [L4] EVEFAS [EFS] Evénements rattachés au bien sorti d'actif               #
  # [L5] PHYELT [PHY] Eléménts physiques  rattachés au bien sorti d'actif      #
  # [L6] EVEPHY [EPH] Evénements s/Elt. Phy.rattachés au bien sorti d'actif    #
  # Nota : Les liens sur ces tables  étant de type "Autre", il est nécessaire  #
  #        d'effectuer les suppressions manuellement                           #
  #----------------------------------------------------------------------------#
  If OKHIS
    #>>>>>>> Traitement Réel
    If !SIMUL
      #-----<L2>  Dépenses rattachées aux biens sortis d'actif -----#
      For [LOF] Where AASREF=[F:F1]AASREF With Stability
        If (HISTO) Then : # FQ121374
          # Ecriture dans le dossier Historique
          [F:LOFH] = [F:LOF]
          If dim([F:LOFH]CREHISDAT)>0  [F:LOFH]CREHISDAT=date$    : Endif
          If dim([F:LOFH]CREHISUSR)>0  [F:LOFH]CREHISUSR=[V]GUSER : Endif
          Write [LOFH]
          If fstat
            Call ECR_TRACE("$LAYOUTFAS"-[F:LOF]CODLOF-mess(13,100,1),1) From GESECRAN
            OK=0 : Break
          Else
              WMESSAGE="------[LOFH]"-"("+num$(adxdlrec)+")"-mess(22,GML_MSGMIS,1)
              Call ECR_TRACE (WMESSAGE,0) From GESECRAN
          Endif
        Endif
        # Suppression du dossier applicatif
        Delete [LOF] Where AASREF=[F:F1]AASREF
        If fstat
          OKHIS = 0
          OKEPU = 0
          Call ECR_TRACE("$LAYOUTFAS"-[F:LOF]CODLOF-" "-[F:LOF]LINLOF-mess(10,100,1),1) From GESECRAN
          Break
        Endif
      Next
      #-----</L2>
      #-----<L5> Eléments physiques
      If (GPHY = G_OUI )
        For [PHY] Where (AASREF=[F:F1]AASREF and ISSDAT <> [0/0/0]) With Stability
        # 1---Ecriture dans le dossier Historique
        [F:PHYH] = [F:PHY]
        If dim([F:PHYH]CREHISDAT)>0  [F:PHYH]CREHISDAT=date$    : Endif
        If dim([F:PHYH]CREHISUSR)>0  [F:PHYH]CREHISUSR=[V]GUSER : Endif
        Write [PHYH]
        If fstat
          Call ECR_TRACE("$PHYELT"-[F:PHY]PHYREF-mess(13,100,1),1) From GESECRAN
           Break
        Else
            WMESSAGE="------[PHY]"-"("+num$(adxdlrec)+")"-mess(23,GML_MSGMIS,1)
            Call ECR_TRACE (WMESSAGE,0) From GESECRAN
        Endif
        # 2--- Suppression du dossier applicatif
        Delete [PHY] Where (AASREF=[F:F1]AASREF)
        If fstat
          OKHIS = 0
          OKEPU = 0
          Call ECR_TRACE("$PHYELT"-[F:PHY]PHYREF-mess(13,100,1),1) From GESECRAN
          Break
        Endif
          #-----</L5>  Eléments physiques
       Next
    Endif
    #>>>>>>>>>>>>> Simulation
    Else
      #-----<L2>  Dépenses rattachées aux biens sortis d'actif -----#
      For [LOF] Where AASREF=[F:F1]AASREF
          L2 +=1
          WMESSAGE=mess(22,GML_MSGMIS,1)+"------>"-"("+num$(L2)+")"
          Call ECR_TRACE (WMESSAGE,0) From GESECRAN
      Next       #-----</L2>
      #-----<L5> Eléments physiques
      If (GPHY = G_OUI )
        For [PHY] Where (AASREF=[F:F1]AASREF and ISSDAT <> [0/0/0])
          L5 +=1
          WMESSAGE=mess(23,GML_MSGMIS,1)+"------>"-"("+num$(L5)+")"
          Call ECR_TRACE (WMESSAGE,0) From GESECRAN
          #-----</L5>  Eléments physiques
       Next
       Endif
      #-----</L3>
    Endif
  Endif

Return
#----------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet    #
# -------------------------------------------------------------------------- #
# [L2] LAYOUTFAS [LOF] Dépenses rattachées aux biens comptables              #
# [L3] EVEFAS [EFS] Evénements rattachés au bien sorti d'actif               #
# [L4] EVELOF [ELF] Evénements rattachés au dépenses du bien sorti d'actif   #
# Nota : Les liens sur ces tables  étant de type "Autre", il est nécessaire  #
#        d'effectuer les suppressions manuellement                           #
#----------------------------------------------------------------------------#
$EPURE_FASISS

# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_FASISS
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Return
#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_FASISS

If clalev([F:LOF])  : Close Local File [LOF]   : Endif
If clalev([F:EFS])  : Close Local File [EFS]   : Endif   # Evénements sur bien comptable
If clalev([F:ELF])  : Close Local File [ELF]   : Endif   # Evénements sur dépenses
If clalev([F:EPH])  : Close Local File [EPH]   : Endif   # Evénements sur Eléments physiques

Return
#
#####################################################################
#                 Epuration des amortissements                      #
# ------------------------------------------------------------------#
# Sélection FASDEPCLO :  (DEPSTA=3)                                    #
#     &  (FIYENDDAT <=(func EPURFAS.GETDATINF(CPY,contexte, param)  #
#####################################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_FASDEPCLO

#----- Ouverture tables complémentaires -----#

#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:FIY])  Local File =[L]HISAPL+".FISCYEAR"  [FIY]  : Endif
  #----- Historisation -----#
  Else
    If !clalev([F:FIY])  Local File =[L]APPLI +".FISCYEAR"  [FIY]  : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  If !clalev([F:FIY])    Local File =[L]APPLI +".FISCYEAR"  [FIY]  : Endif
Endif

Local Integer IPARAM_CLO
IPARAM_CLO = GNBEXNOHIS

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
# Les enregistrements DEPREC ne peuvent être purgés que si :                    #
# - ils appartiennet à un exercice clos                                         #
# - que cet exercice clos est antérieur ou égal au dernier exercice clos -3     #
#-------------------------------------------------------------------------------#
$FILTRE_FASDEPCLO

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
$HISTO_FASDEPCLO

#* - la date de fin d'exercice doit être <= à la date de début de l'exercice clos
#* - x exercices du contexte du plan traité
# le nombre d'exercice à retrancher est issu du paramètre général NBEXNOHIS

  If [F:F1]FIYENDDAT > (func EPURFAS.GETDATINF([F:F1]CPY,[F:F1]CNX, IPARAM_CLO))
    OKHIS = 0
  Endif

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
#-------------------------------------------------------------------------#
$EPURE_FASDEPCLO

# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_FASDEPCLO
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Return
#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_FASDEPCLO

If clalev([F:FIY])   Close Local File [FIY]  : Endif

Return
######################################################################
#    Epuration des événements hors dotations des exercices clos      #
# -------------------------------------------------------------------#
# Sélection EVEFAS  :                                                #
#  EVTDAT > (func EPURFAS.GETDATCLO_SUP([F:F1]CPY,[F:F1]CNX)))       #
######################################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_EVEFAS
#----- Ouverture tables complémentaires -----#
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:HEAC])  Local File =[L]HISAPL+".EFASACT"       [HEAC]  : Endif
    If !clalev([F:HEAF])  Local File =[L]HISAPL+".EFASAFFAGE"    [HEAF]  : Endif
    If !clalev([F:HECH])  Local File =[L]HISAPL+".EFASCHGIMP"    [HECH]  : Endif
    If !clalev([F:HECN])  Local File =[L]HISAPL+".EFASCNL"       [HECN]  : Endif
    If !clalev([F:HECR])  Local File =[L]HISAPL+".EFASCRT"       [HECR]  : Endif
    If !clalev([F:HEIM])  Local File =[L]HISAPL+".EFASIML"       [HEIM]  : Endif
    If !clalev([F:HEIS])  Local File =[L]HISAPL+".EFASISS"       [HEIS]  : Endif
    If !clalev([F:HELN])  Local File =[L]HISAPL+".EFASLNKCNL"    [HELN]  : Endif
    If !clalev([F:HEMT])  Local File =[L]HISAPL+".EFASMTC"       [HEMT]  : Endif
    If !clalev([F:HERE])  Local File =[L]HISAPL+".EFASREEVAL"    [HERE]  : Endif
    If !clalev([F:HEVA])  Local File =[L]HISAPL+".EFASVATREG"    [HEVA]  : Endif
  #----- Historisation -----#
  Else
    # Dossier Historique
    If !clalev([F:HEAC])  Local File =[L]HISAPL+".EFASACT"       [HEAC]  : Endif
    If !clalev([F:HEAF])  Local File =[L]HISAPL+".EFASAFFAGE"    [HEAF]  : Endif
    If !clalev([F:HECH])  Local File =[L]HISAPL+".EFASCHGIMP"    [HECH]  : Endif
    If !clalev([F:HECN])  Local File =[L]HISAPL+".EFASCNL"       [HECN]  : Endif
    If !clalev([F:HECR])  Local File =[L]HISAPL+".EFASCRT"       [HECR]  : Endif
    If !clalev([F:HEIM])  Local File =[L]HISAPL+".EFASIML"       [HEIM]  : Endif
    If !clalev([F:HEIS])  Local File =[L]HISAPL+".EFASISS"       [HEIS]  : Endif
    If !clalev([F:HELN])  Local File =[L]HISAPL+".EFASLNKCNL"    [HELN]  : Endif
    If !clalev([F:HEMT])  Local File =[L]HISAPL+".EFASMTC"       [HEMT]  : Endif
    If !clalev([F:HERE])  Local File =[L]HISAPL+".EFASREEVAL"    [HERE]  : Endif
    If !clalev([F:HEVA])  Local File =[L]HISAPL+".EFASVATREG"    [HEVA]  : Endif
    # Dossier applicatif
    If !clalev([F:EAC])  Local File =[L]APPLI+".EFASACT"       [EAC]  : Endif
    If !clalev([F:EAF])  Local File =[L]APPLI+".EFASAFFAGE"    [EAF]  : Endif
    If !clalev([F:ECH])  Local File =[L]APPLI+".EFASCHGIMP"    [ECH]  : Endif
    If !clalev([F:ECN])  Local File =[L]APPLI+".EFASCNL"       [ECN]  : Endif
    If !clalev([F:ECR])  Local File =[L]APPLI+".EFASCRT"       [ECR]  : Endif
    If !clalev([F:EIM])  Local File =[L]APPLI+".EFASIML"       [EIM]  : Endif
    If !clalev([F:EIS])  Local File =[L]APPLI+".EFASISS"       [EIS]  : Endif
    If !clalev([F:ELN])  Local File =[L]APPLI+".EFASLNKCNL"    [ELN]  : Endif
    If !clalev([F:EMT])  Local File =[L]APPLI+".EFASMTC"       [EMT]  : Endif
    If !clalev([F:ERE])  Local File =[L]APPLI+".EFASREEVAL"    [ERE]  : Endif
    If !clalev([F:EVA])  Local File =[L]APPLI+".EFASVATREG"    [EVA]  : Endif
  Endif
#----- Epuration sans historisation -----#
Else
    If !clalev([F:EAC])  Local File =[L]APPLI+".EFASACT"       [EAC]  : Endif
    If !clalev([F:EAF])  Local File =[L]APPLI+".EFASAFFAGE"    [EAF]  : Endif
    If !clalev([F:ECH])  Local File =[L]APPLI+".EFASCHGIMP"    [ECH]  : Endif
    If !clalev([F:ECN])  Local File =[L]APPLI+".EFASCNL"       [ECN]  : Endif
    If !clalev([F:ECR])  Local File =[L]APPLI+".EFASCRT"       [ECR]  : Endif
    If !clalev([F:EIM])  Local File =[L]APPLI+".EFASIML"       [EIM]  : Endif
    If !clalev([F:EIS])  Local File =[L]APPLI+".EFASISS"       [EIS]  : Endif
    If !clalev([F:ELN])  Local File =[L]APPLI+".EFASLNKCNL"    [ELN]  : Endif
    If !clalev([F:EMT])  Local File =[L]APPLI+".EFASMTC"       [EMT]  : Endif
    If !clalev([F:ERE])  Local File =[L]APPLI+".EFASREEVAL"    [ERE]  : Endif
    If !clalev([F:EVA])  Local File =[L]APPLI+".EFASVATREG"    [EVA]  : Endif
Endif

Local Integer IPARAM_EFS
IPARAM_EFS = GNBEXNOHIS

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
# Les enregistrements EVENEMENTS ne peuvent être purgés que si :                #
# - leur date d'effet appartient à un exercice clos                                        #
#-------------------------------------------------------------------------------#
$FILTRE_EVEFAS

Case TABLE
 When  Default      : FILTSUP = ""
Endcase

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
$HISTO_EVEFAS

  If ([F:F1]EVTDAT > (func EPURFAS.GETDATCLO_SUP([F:F1]CPY,[F:F1]CNX)))
    OKHIS = 0
  Endif

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
#-------------------------------------------------------------------------#
$EPURE_EVEFAS

# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_EVEFAS
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Return
#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_EVEFAS

  If clalev([F:EAC])  Close Local File  [EAC]  : Endif
  If clalev([F:EAF])  Close Local File  [EAF]  : Endif
  If clalev([F:ECH])  Close Local File  [ECH]  : Endif
  If clalev([F:ECN])  Close Local File  [ECN]  : Endif
  If clalev([F:ECR])  Close Local File  [ECR]  : Endif
  If clalev([F:EIM])  Close Local File  [EIM]  : Endif
  If clalev([F:EIS])  Close Local File  [EIS]  : Endif
  If clalev([F:ELN])  Close Local File  [ELN]  : Endif
  If clalev([F:EMT])  Close Local File  [EMT]  : Endif
  If clalev([F:ERE])  Close Local File  [ERE]  : Endif
  If clalev([F:EVA])  Close Local File  [EVA]  : Endif

Return
######################################################################
#    Epuration des événements "Dépenses" des exercices clos          #
# -------------------------------------------------------------------#
# Sélection EVELOF  :                                                #
#     (EVTDAT<(func EPURFAS.GETDATINF(CPY,contexte,param)))          #
######################################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_EVELOF

#----- Ouverture tables complémentaires -----#
If clalev([F:LOF])=0   Local File LAYOUTFAS    [LOF]  : Endif   # Dépenses
If clalev([F:FIY])=0   Local File FISCYEAR     [FIY]  : Endif

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
# Les enregistrements DEPREC ne peuvent être purgés que si :                    #
# - ils appartiennet à un exercice clos                                         #
# - que cet exercice clos est antérieur ou égal au dernier exercice clos -3     #
#-------------------------------------------------------------------------------#
$FILTRE_EVELOF

Case TABLE
 When  Default      : FILTSUP = ""
Endcase

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
$HISTO_EVELOF

If ([F:F1]EVTDAT > (func EPURFAS.GETDATCLO_SUP([F:F1]CPY,[F:F1]CNX)))
  OKHIS = 0
Endif

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
#-------------------------------------------------------------------------#
$EPURE_EVELOF

# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_EVELOF
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Return
#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_EVELOF

If clalev([F:FIY])   Close Local File [FIY]  : Endif

Return
#**********************************************#
#                 FONCTIONS                    #
#**********************************************#
#################################################################################################
# Fonction :  GETDATINF(PSOC, PCNX, PPARAM)                                                     #
#  -> Récupère dans la formule d'histo/épuration la date permettant de filtrer les enreg DEPREC #
#     à traiter en fonction de chaque contexte                                                  #
#################################################################################################
Funprog GETDATINF(PSOC, PCNX, PPARAM)
Value Char    PSOC
Value Integer PCNX
Value Integer PPARAM
Local Date    DATINF
Local Date    DINF
Local Char    LSOC
Local Integer LCNX
Local Integer RCNX
Local Integer PRET
Local Integer N_EXE
Local Date    LCNXDAT(1..5)

LSOC=PSOC
LCNX=PCNX

#
# on récupère la date de fin du dernier exercice clos dans LCNXDAT(5)
#
Call GET_CNX_DAT(LSOC,LCNX,LCNXDAT,PRET) From GLOBIENS

#
# la formule va prendre en compte les enreg ayant FIYENDDAT <= LCNXDAT(5) - x ans
# x prend la valeur du paramètre NBEXNOHIS  si il est > 0, sinon x=3

#===================================================================
# Récupération de la valeur du paramètre NBEXNOHIS du chapitre "AAS"
#
#
  If PPARAM > 0 Then
    N_EXE= PPARAM
  Else
   N_EXE = 3
  Endif

  If LCNXDAT(5) <> [0/0/0]
    DATINF=LCNXDAT(5)
    DINF =  gdat$(day(DATINF), month(DATINF), year(DATINF)-N_EXE)
  Endif

End DINF
#==============
#################################################################################################
# Fonction :  GETDATEVE(PSOC, PCNX)                                                             #
#  -> Récupère dans la formule d'histo/épuration la date permettant de filtrer les enreg DEPREC #
#     à traiter en fonction de chaque contexte                                                  #
#################################################################################################
Funprog GETDATEVE(PSOC,PCNX)

Value Char    PSOC
Value Integer PCNX

Local Char    LSOC
Local Integer LCNX

Local Date    STRFIYCOU(1..G300MAX)      # Début d'exercice courant
Local Date    ENDFIYCOU(1..G300MAX)      # Fin d'exercice courant
Local Integer FLGPER(1..G300MAX)         # Exercice périodique ?
Local Date    STRPERCOU(1..G300MAX)      # Début de période courante
Local Date    ENDPERCOU(1..G300MAX)      # Fin de période courante
Local Date    STRPERCLO(1..G300MAX)      # Début de période précédente close
Local Date    ENDPERCLO(1..G300MAX)      # Fin de période précédente close
Local Integer PRET

Local Date DATEVE
Local Integer N_PER
Local Integer LCNX
Local Date LDATEVE


LSOC=PSOC
LCNX=PCNX
#
#
If LCNX <> 0
  Call GET_CPY_DAT(LSOC,LCNX,1,STRFIYCOU,ENDFIYCOU,FLGPER,STRPERCOU,ENDPERCOU,STRPERCLO,ENDPERCLO,PRET)
Endif

#===================================================================
# Récupération de la valeur du paramètre NBPENOHIS du chapitre "AAS"
#
Local Integer I_PARAM
IPARAM=GNBEXNOHIS

  If I_PARAM > 0 Then
    N_PER= I_PARAM
  Else
   N_PER = 1
  Endif

#
# la formule va prendre en compte les enreg ayant FIYENDDAT < STRPERCLO(LCNX)
If  STRPERCLO(LCNX) <> [0/0/0]
  LDATEVE = STRPERCLO(LCNX)
  If N_PER=1
    DATEVE= LDATEVE
  Else
    DATEVE =  gdat$(day(LDATEVE), month(LDATEVE), year(LDATEVE)-N_PER)
  Endif
Endif

End DATEVE
#==============
#################################################################################################
#---------------------------------------------------------------------#
# S/P de récupération des dates des contextes gérés pour une          #
# société et un contexte passés en paramétre et un nombre de périodes #
# à retrancher                                                        #
#---------------------------------------------------------------------#
Subprog GET_CPY_DAT(PCPY,PCNX,PNBPER,RSTRFIYCOU,RENDFIYCOU,RFLGPER,RSTRPERCOU,RENDPERCOU,RSTRPERCLO,RENDPERCLO,PRET)
Value    Char    PCPY           # Société passée en paramètre
Value    Integer PCNX           # Contexte passé en paramètre
Value    Integer PNBPER         # Nombre de périodes ou d'exercice à retrancher
Variable Date    RSTRFIYCOU(1..)     # Début d'exercice courant
Variable Date    RENDFIYCOU(1..)     # Fin d'exercice courant
Variable Integer RFLGPER(1..)        # Exercice périodique ?
Variable Date    RSTRPERCOU(1..)     # Début de période courante
Variable Date    RENDPERCOU(1..)     # Fin de période courante
Variable Date    RSTRPERCLO(1..)     # Début de période close
Variable Date    RENDPERCLO(1..)     # Fin de période close
Variable Integer PRET

If !clalev([F:FIY]) : Local File FISCYEAR [FIY] : Endif

 Filter [FIY] Where (CPY=PCPY & CNX=PCNX & STAFIY=GVML_TECOURA)
 Read [FIY]First
 If !fstat
   RSTRFIYCOU(PCNX)=[F:FIY]DATSTRFIY
   RENDFIYCOU(PCNX)=[F:FIY]DATENDFIY
   If [F:FIY]FLGPER=G_OUI
     RFLGPER(PCNX)=G_OUI
     If [F:FIY]INDCURPER <> 1
       RSTRPERCLO(PCNX)=[F:FIY]DATSTRPER([F:FIY]INDCURPER-PNBPER)
       RENDPERCLO(PCNX)=[F:FIY]DATENDPER([F:FIY]INDCURPER-PNBPER)
     Else
       Filter [FIY]
       Filter [FIY] Where (CPY=PCPY & CNX=PCNX & STAFIY=GVML_TEPREC)
       Read [FIY]Last
       If !fstat
         RSTRPERCLO(PCNX)=[F:FIY]DATSTRPER([F:FIY]INDCURPER)
         RENDPERCLO(PCNX)=[F:FIY]DATENDPER([F:FIY]INDCURPER)
       Endif
       Filter [FIY]
     Endif
   Endif
 Else
   RFLGPER(PCNX)=G_NON
   Raz RSTRPERCOU(PCNX)
   Raz RENDPERCOU(PCNX)
   Raz RSTRPERCLO(PCNX)
   Raz RENDPERCLO(PCNX)
 Endif
Filter [FIY]

End
#==============
#################################################################################################
# Fonction :  GETDATCLO_INF(PSOC, PCNX)                                                         #
#  -> Récupère dans la formule d'histo/épuration la date de début de l'exercice clos            #
#################################################################################################
Funprog GETDATCLO_INF(PSOC,PCNX)

Value Char    PSOC
Value Integer PCNX
Local Date    DATINF
Local Date    DATSUP
Local Char    LSOC
Local Integer LCNX
Local Integer RCNX
Local Integer PRET
Local Date    LCNXDAT(1..5)

LSOC=PSOC
LCNX=PCNX
#
# on récupère la date de fin du dernier exercice clos dans LCNXDAT(5)
#
Call GET_CNX_DATPREC(LSOC,LCNX,GVML_TEPREC,LCNXDAT,PRET)

#
# la formule va prendre en compte les enreg ayant FIYENDDAT >= LCNXDAT(1)
#
If LCNXDAT(1) <> [0/0/0]
  DATINF=LCNXDAT(1)
Endif


End DATINF
#==============
#################################################################################################
# Fonction :  GETDATCLO_SUP(PSOC, PCNX)                                                         #
#  -> Récupère dans la formule d'histo/épuration la date de fin de l'exercice clos              #
#################################################################################################
Funprog GETDATCLO_SUP(PSOC,PCNX)

Value Char    PSOC
Value Integer PCNX
Local Date    DATINF
Local Date    DATSUP
Local Char    LSOC
Local Integer LCNX
Local Integer RCNX
Local Integer PRET
Local Date    LCNXDAT(1..5)

LSOC=PSOC
LCNX=PCNX
#
# on récupère la date de fin du dernier exercice clos dans LCNXDAT(5)
#
Call GET_CNX_DATPREC(LSOC,LCNX,GVML_TEPREC,LCNXDAT,PRET)
#
# la formule va prendre en compte les enreg ayant FIYENDDAT <= LCNXDAT(2)
#
If LCNXDAT(2) <> [0/0/0]
  DATSUP=LCNXDAT(2)
Endif

End DATSUP
#==============
#---------------------------------------------------------------------
# Récupération des dates d'un contexte dans la variable dimensionnée
# PCNXDAT :
#
#  1 Date de début d'exercice clos
#  2 Date de fin d'exercice clos
#
#---------------------------------------------------------------------
Subprog GET_CNX_DATPREC(PCPY, PCNX, PEXE, PCNXDAT, PRET)
Value    Char    PCPY
Value    Integer PCNX
Value    Integer PEXE
Variable Date    PCNXDAT(1..5)
Variable Integer PRET

 If !(clalev([F:FIY])) : Local File FISCYEAR [FIY] : Endif
 Filter [FIY] Where CPY=PCPY & CNX=PCNX & STAFIY=PEXE
 Read [FIY]FIY0 Last : Filter [FIY]
 If fstat
  PRET=-1
  End
 Endif
 PCNXDAT(1)=[F:FIY]DATSTRFIY
 PCNXDAT(2)=[F:FIY]DATENDFIY
End
#==============

