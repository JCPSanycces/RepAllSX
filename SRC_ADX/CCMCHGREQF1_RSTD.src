#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation: CCMCHGREQF1 ...
# Based on standard Change Request Representation: CCMCHGREQ, but filtered on ~
# Change Request selected if logged-in user is an approver and @ status 'In Review' and
# approval status is still Pending.

$METHODS

  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
  Endcase

Return

$AQUERY_TRANS_AFTER

  ASTATUS = CST_AERROR
  If (this.CCMCR.CRSTATUS = 2)  # In Review
    If (clalev([CCMAPPR]) = 0) : Local File CCMAPPROVER [CCMAPPR] : Endif
    Filter [CCMAPPR] Where Key CCMAPPR1 = this.CCMCR.CRID;this.ACTX.USER
    For [CCMAPPR]
      If ([F:CCMAPPR]APPRSTAT = 1)
        ASTATUS = CST_AOK
        Break
      Endif
    Next
  Endif

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

