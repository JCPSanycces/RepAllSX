############################################################
############################################################
# Traçabilité amont sur les factures :
# Une facture peut avoir soit des réceptions, soit des commandes (ouvertes ou non) associées.
# 1. Recherche des réceptions (distinctes) : on parcourt les lignes de la facture.
# 2. Recherche des commandes ouvertes ou non (distinctes) : on parcourt les lignes de la facture.
Subprog FIND_TREE_AMONT_PIH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer WRET
Local Char    WLEG (20)
Local Char PTH_F(GLONVCR)
Local Integer PTH_L
Local Char POH_F(GLONVCR)
Local Integer POH_L
Local Char PIH_F(GLONVCR)
Local Integer PIH_L
Local Char SHH_F(GLONVCR)
Local Integer SHH_L

  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  If !clalev([F:TPV]) Then Local File TABPIVTYP [TPV] : Endif
  # -----------------------
  # Recherche des factures complémentaires
  #-- X3suivi 71937 - T249 : Multi-Leg--#
  #Read [F:TPV]TPV0=[F:PIH]PIVTYP
  Call GETLEG([F:PIH]CPY,"G",WLEG) From TRTLECLEG
  Call LEC_TPV_LEG(WLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG
  If [F:TPV]PIHTYP = 2 Then
    # Facture complémentaire : elle n'a en amont qu'une facture normale possible en amont
    # ---------------------------------------------------------------------
    If [M:PIV1]VCRTYPSEL = NUM_PIHC and [M:PIV1]VCRLINSEL > 0 Then
      Filter [F:PID] Where NUM=[F:PKW]VCRNUM and PIDLIN=[M:PIV1]VCRLINSEL
    Else
      Filter [F:PID] Where NUM=[F:PKW]VCRNUM
    Endif
    If rowcount([F:PID]) > 0 Then
      Raz PIH_F
      For [F:PID]
        # Facture
        #If [F:PID]NUMORI <> "" Then                       # FGR 27/02/2016 : X3SUIVI110325
        If [F:PID]NUMORI <> "" and [F:PID]TYPORI <> 6 Then # FGR 27/02/2016 : X3SUIVI110325
          PIH_F = [F:PID]NUMORI
          PIH_L = [F:PID]LINORI
          If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIV) = G_OUI Then
            Read [F:PIH]PIH0=PIH_F
            If !fstat Then
              Gosub WRITE_PKW1_PIH
              WK = 1
            Endif
          Endif
        Endif
        # -----------------------------------------------------------------
        # FGR 27/02/2016 : X3SUIVI110325 : (début) Ca c'était avant. Maintenant elle peut aussi avoir une expédition
        If [F:PID]NUMORI <> "" and [F:PID]TYPORI = 6 Then
          Filter [SHH] Where [F:SHH]SHIPNUM=[F:PID]NUMORI
          If rowcount([F:SHH]) > 0 Then
            # Expéditions
            Raz SHH_F
            For [F:SHH]
              If [F:SHH]SHIPNUM <> "" Then
                SHH_F = [F:SHH]SHIPNUM
                SHH_L = 0
                Gosub WRITE_PKW1_SHH
                WK = 1
              Endif
            Next
          Endif
          Filter [F:SHH]
        Endif
        # -----------------------
        # Recherche des commandes ouvertes ou non : On recherche toutes les commandes distinctes associées à la facture
        Raz POH_F
        If [F:PID]POHNUM <> "" Then
          POH_F = [F:PID]POHNUM
          POH_L = [F:PID]POPLIN
          If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIH) = G_OUI Then
            # Pour chacune de ces commandes, on récupère les infos
            Read [F:POH]POH0=POH_F
            If !fstat Then
              If [F:POH]POHTYP = 2 Then
                # Commande ouverte
                Read [F:POC]POC0=POH_F
                If !fstat Then
                  Gosub WRITE_PKW1_POC
                  WK = 1
                Endif
              Elsif [F:POH]POHTYP = 1 Then
                # Commande
                Gosub WRITE_PKW1_POH
                WK = 1
              Endif
            Endif
          Endif
        Endif
        # FGR 27/02/2016 : X3SUIVI110325 : (fin)
        # -----------------------------------------------------------------
      Next
    Endif
    # ---------------------------------------------------------------------
  Else
    # Facture achat (normale)
    # ---------------------------------------------------------------------
    # On recherche toutes les réceptions distinctes associées à la facture en parcourant les lignes de la facture
    If [M:PIV1]VCRTYPSEL = NUM_PIH and [M:PIV1]VCRLINSEL > 0 Then
      Filter [F:PID] Where [F:PID]NUM=[F:PKW]VCRNUM and [F:PID]PIDLIN=[M:PIV1]VCRLINSEL
    Else
      Filter [F:PID] Where [F:PID]NUM=[F:PKW]VCRNUM
    Endif
    If rowcount([F:PID])>0 Then
      Raz PTH_F
      For [F:PID]
        If [F:PID]PTHNUM <> "" Then
          PTH_F = [F:PID]PTHNUM
          PTH_L = [F:PID]PTDLIN
          If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIH) = G_OUI Then
            # Pour chacune de ces réceptions, on récupère les infos
            Read [F:PTH]PTH0=PTH_F
            If !fstat Then
              # Réception
              Gosub WRITE_PKW1_PTH
              WK = 1
            Endif
          Endif
        Endif
      Next
      # -----------------------
      # Recherche des commandes ouvertes ou non : On recherche toutes les commandes distinctes associées à la facture
      Raz POH_F
      For [F:PID]
        If [F:PID]POHNUM <> "" Then
          POH_F = [F:PID]POHNUM
          POH_L = [F:PID]POPLIN
          If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIH) = G_OUI Then
            # Pour chacune de ces commandes, on récupère les infos
            Read [F:POH]POH0=POH_F
            If !fstat Then
              If [F:POH]POHTYP = 2 Then
                # Commande ouverte
                Read [F:POC]POC0=POH_F
                If !fstat Then
                  Gosub WRITE_PKW1_POC
                  WK = 1
                Endif
              Elsif [F:POH]POHTYP = 1 Then
                # Commande
                Gosub WRITE_PKW1_POH
                WK = 1
              Endif
            Endif
          Endif
        Endif
      Next
    Endif
    Filter [F:PID]
    # ---------------------------------------------------------------------
  Endif
End

############################################################
# Traçabilité amont sur les avoirs
# Un avoir peut avoir soit des factures, soit des retours associés.
# 1. Recherche des factures (distinctes) : on part de la pièce d'origine.
# 2. Recherche des retours (distincts): on parcourt les lignes de l'avoir.
Subprog FIND_TREE_AMONT_PIV(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PIH_F(GLONVCR)
Local Char PNH_F(GLONVCR)
Local Integer PNH_L

  # Recherche d'une facture associée à l'avoir
  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_PIV and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where NUM=[F:PKW]VCRNUM and PIDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where NUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PID]) > 0 Then
    Raz PIH_F
    For [F:PID]
      # Facture
      If [F:PID]INVNUM <> "" Then
        PIH_F = [F:PID]INVNUM
        PIH_L = [F:PID]INVLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIV) = G_OUI Then
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # -----------------------
  # Recherche d'un retour
  If rowcount([F:PID]) > 0 Then
    # Retour
    Raz PNH_F
    For [PID]
      If [F:PID]PNHNUM <> "" Then
        PNH_F = [F:PID]PNHNUM
        PNH_L = [F:PID]PNDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIV) = G_OUI Then
          Read [F:PNH]PNH0=PNH_F
          If !fstat Then
            Gosub WRITE_PKW1_PNH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
End

############################################################
# Traçabilité amont sur les retours
# Un retour peut avoir des réceptions associées.
#    Recherche des réceptions (distinctes) : on parcourt les lignes du retour
Subprog FIND_TREE_AMONT_PNH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PTH_F(GLONVCR)
Local Integer PTH_L

  # Recherche d'une réception associée au retour
  If !clalev([F:PND]) Then Local File PRETURND [PND] Endif
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_PNH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PND] Where [F:PND]PNHNUM=[F:PKW]VCRNUM and [F:PND]PNDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PND] Where [F:PND]PNHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PND]) > 0 Then
    # Réception
    Raz PTH_F
    For [F:PND]
      If [F:PND]PTHNUM <> "" Then
        PTH_F = [F:PND]PTHNUM
        PTH_L = [F:PND]PTDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PND]PNDLIN, NUM_PNH) = G_OUI Then
          # Pour chacune de ces réceptions, on récupère les infos
          Read [F:PTH]PTH0=PTH_F
          If !fstat Then
            Gosub WRITE_PKW1_PTH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PND]
End

############################################################
# Traçabilité amont sur les réceptions
# Une réception peut avoir soit des demandes de livraisons, soit des commandes associées.
# 1. Recherche des demandes (distinctes) : on parcourt les lignes de réception.
# 2. Recherche des commandes (distinctes) : on parcourt les lignes de réception.
Subprog FIND_TREE_AMONT_PTH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char POH_F(GLONVCR)
Local Integer POH_L
Local Char POC_F(GLONVCR)
Local Integer POC_L
Local Char SHH_F(GLONVCR)
Local Integer SHH_L
Local Integer INO_SHD  # FGR 01/09/2016 : X3SUIVI118277 (fin)

  # Recherche des demandes
  If !clalev([F:PTD]) Then Local File PRECEIPTD [PTD] : Endif
  If !clalev([F:SHD]) Then Local File SHIPMENTD [SHD] : Endif  # FGR 01/09/2016 : X3SUIVI118277

  If !clalev([F:SHH]) Then Local File SHIPMENT  [SHH] : Endif  # FGR 01/09/2016 : X3SUIVI118277
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_PTH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PTD] Where PTHNUM=[F:PKW]VCRNUM and [F:PTD]PTDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PTD] Where PTHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PTD]) > 0 Then
    # Demande
    Raz POH_F
    Raz POC_F
    For [F:PTD]
      If [F:PTD]POHNUM <> "" Then
        If func CONSPITOOLS.VERIF_LINE([F:PTD]PTDLIN, NUM_PTH) = G_OUI Then
          # Pour chacune de ces demandes, on récupère les infos si elles existent
          Read [F:POH]POH0=[F:PTD]POHNUM
          If !fstat Then
            # -----------------------
            # Expédition  # FGR 01/09/2016 : X3SUIVI118277 (début)
            INO_SHD = [V]CST_ANO
            Filter [SHD] Where [F:SHD]POHNUM = [F:PTD]POHNUM and [F:SHD]POPLIN = [F:PTD]POPLIN
            For [SHD]
              SHH_F = [F:SHD]SHIPNUM
              SHH_L = 0

              If [F:SHH]SHIPNUM <> SHH_F
                Read [F:SHH]SHH0 = SHH_F
                If fstat : Raz [F:SHH] : Endif
              Endif

              Gosub WRITE_PKW1_SHH
              WK = 1
              INO_SHD = [V]CST_AYES
            Next
            Filter [SHD]
            # Expédition  # FGR 01/09/2016 : X3SUIVI118277 (fin)
            # -----------------------
            # Commande
            If INO_SHD = [V]CST_ANO Then
              # Slt s'il n'y a pas de réception
              If [F:POH]SOHCAT = 4 or [F:POH]POHTYP = 2 Then
                # Commande ouverte
                POC_F = [F:PTD]POHNUM
                POC_L = [F:PTD]POPLIN
                Read [F:POC]POC0=POC_F
                If !fstat Then
                  Gosub WRITE_PKW1_POC
                  WK = 1
                Endif
              Else
                # Commande
                POH_F = [F:PTD]POHNUM
                POH_L = [F:PTD]POPLIN
                Gosub WRITE_PKW1_POH
                WK = 1
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [F:PTD]
  Endif
End

############################################################
# Traçabilité amont sur les demandes de livraison
# Une demande de livraison peut avoir des demandes d'achat associées
#    Recherche des demandes d'achat (distinctes) : on interroge la
#    table des liens de demandes d'achat
Subprog FIND_TREE_AMONT_POC(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char    PSH_F(GLONVCR)
Local Integer PSH_L

  # Recherche des demandes Achat
  If !clalev([F:PSO]) Then Local File PREQUISO [PSO] : Endif
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_POC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PSO] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PSO] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PSO]) > 0 Then
    # Demandes achat
    Raz PSH_F
    For [F:PSO]
      If [F:PSO]PSHNUM <> "" Then
        PSH_F = [F:PSO]PSHNUM
        PSH_L = [F:PSO]PSDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PSO]POPLIN, NUM_POC) = G_OUI Then
          # Pour chacune de ces demandes, on récupère les infos
          Read [F:PSH]PSH0=PSH_F
          If !fstat Then
            Gosub WRITE_PKW1_PSH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PSO]
End

############################################################
# Traçabilité amont sur les commandes
# Une commande peut avoir soit des demandes d'achat, soit des appels d'offre associés.
# 1. Recherche des demandes Achat (distinctes) : on parcourt les liens des
#    demandes d'achat.
# 2. Recherche des appels d'offres (distincts) : on parcourt les quantités des commandes.
# 3. Recherche des ordres de sous-traitance (distincts) : on parcourt les
#    lignes de commande.
Subprog FIND_TREE_AMONT_POH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PSH_F(GLONVCR)
Local Integer PSH_L
Local Char PQH_F(GLONVCR)
Local Integer PQH_L
Local Char SCO_F(GLONVCR)
Local Integer SCO_L

  # On recherche toutes les demandes d'achats distinctes associées à la commande
  If !clalev([F:PSO]) Then Local File PREQUISO [PSO] : Endif
  If !clalev([F:POQ]) Then Local File PORDERQ [POQ] : Endif
  If !clalev([F:SCI]) Then Local File SCOITM  [SCI] : Endif
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PSO] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PSO] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PSO]) > 0 Then
    # Demandes achat
    Raz PSH_F
    For [F:PSO]
      If [F:PSO]PSHNUM <> "" Then
        PSH_F = [F:PSO]PSHNUM
        PSH_L = [F:PSO]PSDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PSO]POPLIN, NUM_POH) = G_OUI Then
          # Pour chacune de ces demandes, on récupère les infos
          Read [F:PSH]PSH0=PSH_F
          If !fstat Then
            Gosub WRITE_PKW1_PSH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PSO]
  # -----------------------
  # on recherche tous les appels d'offre
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:POQ] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:POQ] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:POQ]) > 0 Then
    # Appels d'offre
    Raz PQH_F
    For [F:POQ]
      If [F:POQ]PQHNUM <> "" Then
        PQH_F = [F:POQ]PQHNUM
        PQH_L = [F:POQ]PPDLIN
        If func CONSPITOOLS.VERIF_LINE([F:POQ]POPLIN, NUM_POH) = G_OUI Then
          # Pour chacun de ces appels d'offre, on récupère les infos
          Read [F:PQH]PQH0=PQH_F
          If !fstat Then
            Gosub WRITE_PKW1_PQH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:POQ]
  # -----------------------
  # on recherche tous les ordres de sous-traitance
  Link [F:POQ] With [F:SCI]SCI0=VCRNUMORI;VCRLINORI As [SC_] Where [F:POQ]POHNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:POQ]POPLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Ordres de sous-traitance
    Raz SCO_F
    For [F:SC_]
      If [F:SCI]SCONUM <> "" Then
        SCO_F = [F:SCI]SCONUM
        SCO_L = [F:SCI]SCILIN
        If func CONSPITOOLS.VERIF_LINE([F:SCI]POPLIN, NUM_POH) = G_OUI Then
          # Pour chacun de ces ordres de sous-traitance, on récupère les infos
          Read [F:SCO]SCO0=SCO_F
          If !fstat Then
            Gosub WRITE_PKW1_SCO
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
End

############################################################
# Traçabilité amont sur les demandes d'achat
# Une demande d'achat peut avoir des appels d'offre associés.
#    Recherche des appels d'offres (distincts) : on parcourt les lignes de
#    d'appels d'offre
Subprog FIND_TREE_AMONT_PSH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PQH_F(GLONVCR)
Local Integer PQH_L

  # On recherche tous les appels d'offre
  If !clalev([F:PSD]) Then Local File PREQUISD [PSD] : Endif
  # -----------------------
  If [M:PIV1]VCRTYPSEL = NUM_PSH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PSD] Where PSHNUM=[F:PKW]VCRNUM and PSDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PSD] Where PSHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PSD]) > 0 Then
    # Appels d'offre
    Raz PQH_F
    For [F:PSD]
      If [F:PSD]PQHNUM <> "" Then
        PQH_F = [F:PSD]PQHNUM
        PQH_L = [F:PSD]PPDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PSD]PSDLIN, NUM_PSH) = G_OUI Then
          # Pour chacun de ces appels d'offre, on récupère les infos
          Read [F:PQH]PQH0=PQH_F
          If !fstat Then
            Gosub WRITE_PKW1_PQH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PSD]
End

############################################################
# Traçabilité amont sur les appels d'offre
#  ==> Pas de traçabilité amont
Subprog FIND_TREE_AMONT_PQH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

End

############################################################
# Traçabilité amont sur les ordres de sous-traitance
#  ==> Pas de traçabilité amont
Subprog FIND_TREE_AMONT_SCO(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

End

############################################################
# Traçabilité amont sur les échéances
# Une échéance peut avoir des factures ou des avoir associés.
# 1. Recherche des factures/avoirs (distinctes) : on part de la pièce d'origine.
#
# Traçabilité amont sur les acomptes
# Un acompte peut avoir des commandes associées.
# 1. Recherche des commandes (distinctes) : on part de la pièce d'origine.
Subprog FIND_TREE_AMONT_DUD(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # --------------------------------------------------------------------------------------------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Normalement ce sous-programme n'est jamais appelé.
  # Mais pour mémoire, il appelle toujours CNSPIV2STD.FIND_TREE_AMONT_DUD
  # --------------------------------------------------------------------------------------------------------
  Call FIND_TREE_AMONT_DUD(INIV, WLEV, GCOMMIT) From CNSPIV2STD
End

############################################################
# Traçabilité amont sur les règlements
# Un reglement peut avoir des échéances ou acomptes.
Subprog FIND_TREE_AMONT_PYH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # --------------------------------------------------------------------------------------------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Normalement ce sous-programme n'est jamais appelé.
  # Mais pour mémoire, il appelle toujours CNSPIV2STD.FIND_TREE_AMONT_PYH
  # --------------------------------------------------------------------------------------------------------
  Call FIND_TREE_AMONT_PYH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité amont sur les conteneurs
# Une conteneur ne peut avoir que des commandes en amont
Subprog FIND_TREE_AMONT_CTRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char POH_F(GLONVCR)
Local Integer POH_L

  # On recherche tous les appels d'offre
  If !clalev([F:CTRD]) Then Local File CONTAINERD [CTRD] : Endif
  If !clalev([F:POH])  Then Local File PORDER     [POH] : Endif
  If !clalev([F:POQ])  Then Local File PORDERQ    [POQ] : Endif
  # -----------------------
  Link [F:POQ] With [F:CTRD]CTRD1=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ As [SC_] Where [F:CTRD]CTRNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_CTRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:CTRD]CTRLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Conteneurs
    Raz POH_F
    For [F:SC_]
      If [F:CTRD]POHNUM <> "" Then
        POH_F = [F:CTRD]POHNUM
        POH_L = [F:CTRD]POPLIN
        If func CONSPITOOLS.VERIF_LINE([F:CTRD]POPLIN, NUM_CTRH) = G_OUI Then
          # Pour chacun de ces commandes, on récupère les infos
          Read [F:POH]POH0=POH_F
          If !fstat Then
            Gosub WRITE_PKW1_POH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité amont sur les expéditions
# Une expédition peut avoir des conteneurs ou des commandes en amont
Subprog FIND_TREE_AMONT_SHH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char POH_F(GLONVCR)
Local Integer POH_L
Local Char CTRH_F(GLONVCR)
Local Integer CTRH_L

  If !clalev([F:SHD])  Then Local File SHIPMENTD  [SHD] : Endif
  If !clalev([F:CTRD]) Then Local File CONTAINERD [CTRD] : Endif
  If !clalev([F:POH])  Then Local File PORDER     [POH] : Endif
  If !clalev([F:POQ])  Then Local File PORDERQ    [POQ] : Endif
  # -----------------------
  # On recherche tous les containeurs
  Link [F:SHD] With [F:CTRD]CTRD0=[F:SHD]CTRNUM;[F:SHD]CTRLIN As [SC_] Where [F:SHD]SHIPNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_SHH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:SHD]SHIPLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Containeurs
    Raz CTRH_F
    For [F:SC_]
      If [F:CTRD]CTRNUM <> "" Then
        CTRH_F = [F:CTRD]CTRNUM
        CTRH_L = [F:CTRD]CTRLIN
        #If func CONSPITOOLS.VERIF_LINE([F:SHD]CTRLIN, NUM_SHH) = G_OUI Then  # Issue SAM116075 - 2016-12-07 by FGR : not in this case
          # Pour chacun de ces commandes, on récupère les infos
          Read [F:CTRH]CTRH0=CTRH_F
          If !fstat Then
            Gosub WRITE_PKW1_CTRH
            WK = 1
          Endif
        #Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
  # -----------------------
  Link [F:SHD] With [F:POQ]POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ As [SC_] Where [F:SHD]SHIPNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_SHH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:SHD]SHIPLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # commandes
    Raz POH_F
    For [F:SC_]
      If [F:SHD]POHNUM <> "" Then
        POH_F = [F:SHD]POHNUM
        POH_L = [F:SHD]POPLIN
        If func CONSPITOOLS.VERIF_LINE([F:SHD]POPLIN, NUM_SHH) = G_OUI Then
          # Pour chacun de ces commandes, on récupère les infos
          Read [F:POH]POH0=POH_F
          If !fstat Then
            Gosub WRITE_PKW1_POH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité amont sur les transports
# Un transport ne peut avoir que des expéditions en amont
Subprog FIND_TREE_AMONT_TRNP(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SHH_F(GLONVCR)
Local Integer SHH_L

  # On recherche toutes les expéditions
  # -----------------------
  Filter [SHH] Where [F:SHH]TRNNUM=[F:PKW]VCRNUM
  If rowcount([F:SHH]) > 0 Then
    # Expéditions
    Raz SHH_F
    For [F:SHH]
      If [F:SHH]SHIPNUM <> "" Then
        SHH_F = [F:SHH]SHIPNUM
        SHH_L = 0
        Gosub WRITE_PKW1_SHH
        WK = 1
      Endif
    Next
  Endif
  Filter [F:SHH]
End

############################################################
# Traçabilité aval sur les factures
# Une facture peut avoir soit des avoirs, soit des pièces associés.
# 1. Recherche des avoirs (distincts) : on interroge la table des avoirs.
# 2. Recherche des pièces (distinctes) : on parcourt les lignes de pièces.
# 3. Recherche des échéances (distinctes) : on parcourt les lignes échéances.
Subprog FIND_TREE_AVAL_PIH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PIV_F(GLONVCR)
Local Integer PIV_L
Local Char HAE_F(GLONVCR)
Local Integer HAE_L
# Issue 103476 - 2014-10-24 by SR
Local Char    HAE_T(GLONGTE)
Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char PIH_F(GLONVCR)
Local Integer PIH_L
Local Char LOF_F(GLONVCR)
Local Integer LOF_L

  # Recherche d'un avoir associé à la facture
  If !clalev([F:PIV]) Then Local File PINVOICEV [PIV] : Endif
  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  If !clalev([F:DAE]) Then Local File GACCENTRYD [DAE] : Endif
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # FGR 10/02/2012 X3SUIVI71269
  If !clalev([F:TPV]) Then Local File TABPIVTYP [TPV] : Endif
  If !clalev([F:PIVC]) Then Local File PINVOICEV [PIVC] : Endif
  If !clalev([F:PIDC]) Then Local File PINVOICED [PIDC] : Endif
  # ---------------------
  Read [PIH]PIH0=[F:PKW]VCRNUM

  #-- X3suivi 71937 - T249 : Multi-Leg--#
  #Read [F:TPV]TPV0=[F:PIH]PIVTYP
  Local Integer WRET
  Local Char    WLEG (20)
  Call GETLEG([F:PIH]CPY,"G",WLEG) From TRTLECLEG
  Call LEC_TPV_LEG(WLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG

  If [F:TPV]PIHTYP = 1 Then
    # Si c'est une facture normale on recherche d'éventuelles factures complémentaires
    # ---------------------------------------------
    Link [F:PIVC] With [F:TPV]TPV0=[F:PIVC]PIVTYP,
&                      [F:PIDC]PID0=[F:PIVC]NUM
&                 As [PVC]
&                 Where [F:TPV]PIHTYP = 2
&                   and [F:PIDC]TYPORI = 4 and [F:PIDC]NUMORI = [F:PKW]VCRNUM
    # ---------------------------------------------
    If [M:PIV1]VCRTYPSEL = NUM_PIH and [M:PIV1]VCRLINSEL > 0 Then
      Filter [F:PVC] Where [F:PID]PIDLIN=[M:PIV1]VCRLINSEL
    Endif
    If rowcount([F:PVC]) > 0 Then
      Raz PIH_F
      For [F:PVC]
        # Facture complémentaire
        If [F:PIVC]NUM <> "" Then
          PIH_F = [F:PIVC]NUM
          PIH_L = [F:PIDC]PIDLIN
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Next
    Endif
  Endif
  # ---------------------
  Link [F:PIV] With [F:PID]PID0=NUM As [PV] Where [F:PID]INVNUM=[F:PKW]VCRNUM and [F:PID]INVTYP=2
  If ([M:PIV1]VCRTYPSEL = NUM_PIH or [M:PIV1]VCRTYPSEL = NUM_PIHC) and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PV] Where [F:PID]PIDLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:PV]) > 0 Then
    Raz PIV_F
    For [F:PV]
      # Avoir
      If [F:PIV]NUM <> "" Then
        PIV_F = [F:PIV]NUM
        PIV_L = [F:PID]PIDLIN
        #If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIH) = G_OUI Then
          Read [F:PIH]PIH0=PIV_F
          If !fstat Then
            Gosub WRITE_PKW1_PIV
            WK = 1
          Endif
        #Endif
      Endif
    Next
  Endif
  # ---------------------
  # Recherche d'une pièce
  # FGR 18/03/2014 : X3SUIVI92483 (début)
  If !clalev([F:PIH]) Then Local File PINVOICE [PIH] : Endif
  Read [PIH]PIH0=[F:PKW]VCRNUM
  If fstat Then
    Raz [F:PIH]
  Endif
  # FGR 18/03/2014 : X3SUIVI92483 (fin)
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  #If ([M:PIV1]VCRTYPSEL = NUM_PIH or [M:PIV1]VCRTYPSEL = NUM_PIHC) and [M:PIV1]VCRLINSEL > 0 Then
  #  #Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL and TYP=[F:PIH]GTE  # FGR 18/03/2014 : X3SUIVI92483
  #Else
  #  #Filter [F:DAE] Where NUM=[F:PKW]VCRNUM
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:PIH]GTE                            # FGR 18/03/2014 : X3SUIVI92483
  #Endif
  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:PIH]GTE                            # FGR 18/03/2014 : X3SUIVI92483
  # FGR 18/03/2014 : X3SUIVI92483 (fin)
  If rowcount([F:DAE]) > 0 Then
    Raz HAE_F
    For [F:DAE]
      # Pièce
      If [F:DAE]NUM <> "" Then
        HAE_F = [F:DAE]NUM
        HAE_L = [F:DAE]LIN
        # Issue 103476 - 2014-10-24 by SR
        HAE_T = [F:DAE]TYP
        # Issue 103476 - 2014-10-24 by SR
        Filter [F:HAE] Where NUM=HAE_F & TYP = HAE_T
        For [F:HAE]
          Gosub WRITE_PKW1_HAE
          WK = 1
        Next
        Filter [F:HAE]
      Endif
    Next
  Endif
  Filter [F:DAE]
  # ---------------------
  # Recherche d'une échéance depuis facture
  Read [PIH]PIH0=[F:PKW]VCRNUM
  Filter [F:DUD] Where [F:DUD]TYP = [F:PIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    Raz NUM_F
    For [F:DUD]
      # échéance
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [F:DUD]
  # ---------------------
  # FGR 10/10/2012 : X3SUIVI81498 (début)
  If GMODU(14) = G_OUI Then
    If ([M:PIV1]VCRTYPSEL = NUM_PIH or [M:PIV1]VCRTYPSEL = NUM_PIHC) and [M:PIV1]VCRLINSEL > 0 Then
      Filter [F:PID] Where [F:PID]NUM=[F:PKW]VCRNUM and [F:PID]PIDLIN=[M:PIV1]VCRLINSEL
    Else
      Filter [F:PID] Where [F:PID]NUM=[F:PKW]VCRNUM
    Endif
    If rowcount([F:PID]) > 0 Then
      For [F:PID]
        Filter [LOF] Where [F:LOF]CPMCREORI = 1 and [F:LOF]CODLOF = [F:PID]NUM and [F:LOF]LIGORI = [F:PID]PIDLIN
        If rowcount([F:LOF]) > 0 Then
          Raz LOF_F
          For [F:LOF]
            LOF_F = [F:LOF]CODLOF
            LOF_L = [F:LOF]LINLOF
            Gosub WRITE_PKW1_LOF From CNSPIF2STD
          Next
        Endif
        Filter [LOF]
      Next
    Endif
    Filter [F:PID]
  Endif
  # FGR 10/10/2012 : X3SUIVI81498 (fin)
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les avoirs
# Un avoir peut avoir des pièces associées.
#    Recherche des pièces (distinctes) : on interroge les lignes de pièces
Subprog FIND_TREE_AVAL_PIV(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char HAE_F(GLONVCR)
Local Integer HAE_L
# Issue 103476 - 2014-10-24 by SR
Local Char    HAE_T(GLONGTE)
Local Integer DUD_ACCNUM
Local Integer DUD_DUDLIG

  # Recherche d'une pièce associée à l'avoir
  If !clalev([F:DAE]) Then Local File GACCENTRYD [DAE] : Endif
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # ---------------------
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  If !clalev([F:PIH]) Then Local File PINVOICE [PIH] : Endif
  Read [PIH]PIH0=[F:PKW]VCRNUM
  If fstat Then
    Raz [F:PIH]
  Endif
  # FGR 14/04/2014 : X3SUIVI92483 (fin)
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  #If [M:PIV1]VCRTYPSEL = NUM_PIV and [M:PIV1]VCRLINSEL > 0 Then
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL and TYP=[F:PIH]GTE  # FGR 14/04/2014 : X3SUIVI92483
  #Else
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:PIH]GTE                            # FGR 14/04/2014 : X3SUIVI92483
  #Endif
  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:PIH]GTE                            # FGR 14/04/2014 : X3SUIVI92483
  # FGR 14/04/2014 : X3SUIVI92483 (fin)
  If rowcount([F:DAE]) > 0 Then
    Raz HAE_F
    For [F:DAE]
      # Pièce
      If [F:DAE]NUM <> "" Then
        HAE_F = [F:DAE]NUM
        HAE_L = [F:DAE]LIN
        # Issue 103476 - 2014-10-24 by SR
        HAE_T = [F:DAE]TYP
        # FGR 14/04/2014 : X3SUIVI92483 (début)
        #If func CONSPITOOLS.VERIF_LINE([F:DAE]LIN, NUM_PIV) = G_OUI Then
        #  Read [F:HAE]HAE0=HAE_F
        #  If !fstat Then
        #    Gosub WRITE_PKW1_HAE
        #    WK = 1
        #  Endif
        #Endif
        # Issue 103476 - 2014-10-24 by SR
        Filter [F:HAE] Where NUM=HAE_F & TYP = HAE_T
        For [F:HAE]
          Gosub WRITE_PKW1_HAE
          WK = 1
        Next
        Filter [F:HAE]
        # FGR 14/04/2014 : X3SUIVI92483 (fin)
      Endif
    Next
  Endif
  Filter [F:DAE]
  # ---------------------
  # Recherche d'une échéance depuis avoir
  Read [PIH]PIH0=[F:PKW]VCRNUM
  Filter [F:DUD] Where [F:DUD]TYP = [F:PIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    Raz DUD_ACCNUM
    For [F:DUD]
      # échéance
      DUD_ACCNUM = [F:DUD]ACCNUM
      DUD_DUDLIG = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [F:DUD]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les retours
# Un retour peut avoir des avoirs associés.
#    Recherche des avoirs (distincte) : on parcourt les lignes des avoirs.
Subprog FIND_TREE_AVAL_PNH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char    PIV_F(GLONVCR)
Local Integer PIV_L

  # Recherche des avoirs associés au retour
  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_PNH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where PNHNUM=[F:PKW]VCRNUM and INVTYP=2 and PNDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where PNHNUM=[F:PKW]VCRNUM and INVTYP=2
  Endif
  If rowcount([F:PID]) > 0 Then
    Raz PIV_F
    For [F:PID]
      If [F:PID]NUM <> "" Then
        PIV_F = [F:PID]NUM
        PIV_L = [F:PID]PIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]PNDLIN, NUM_PNH) = G_OUI Then
          # Pour chacun de ces avoirs, on récupère les infos
          Read [F:PIH]PIH0=PIV_F
          If !fstat Then
            Gosub WRITE_PKW1_PIV
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les réceptions
# Une réception peut avoir soit des factures, soit des retours associés.
# 1. Recherche des factures (distinctes) : on interroge les lignes de facture.
# 2. Recherche des retours (distincts) : on parcourt les lignes de retour.
Subprog FIND_TREE_AVAL_PTH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PIH_F(GLONVCR)
Local Integer PIH_L
Local Char PNH_F(GLONVCR)
Local Integer PNH_L

  # Recherche d'une facture associée à la réception
  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  If !clalev([F:PND]) Then Local File PRETURND  [PND] Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_PTH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where PTHNUM=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5) and PTDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where PTHNUM=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5)
  Endif
  If rowcount([F:PID]) > 0 Then
    # Facture
    Raz PIH_F
    For [F:PID]
      If [F:PID]NUM <> "" Then
        PIH_F = [F:PID]NUM
        PIH_L = [F:PID]PIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]PTDLIN, NUM_PTH) = G_OUI Then
          # Pour chacune de ces factures, on récupère les infos
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
  # ---------------------
  # Recherche d'un retour
  If [M:PIV1]VCRTYPSEL = NUM_PTH and [M:PIV1]VCRLINSEL>0 Then
    Filter [F:PND] Where PTHNUM=[F:PKW]VCRNUM and PTDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PND] Where PTHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PND]) > 0 Then
    # Retour
    Raz PNH_F
    For [F:PND]
      If [F:PND]PNHNUM <> "" Then
        PNH_F = [F:PND]PNHNUM
        PNH_L = [F:PND]PNDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PND]PTDLIN, NUM_PTH) = G_OUI Then
          # Pour chacun de ces retours, on récupère les infos
          Read [F:PNH]PNH0=PNH_F
          If !fstat Then
            Gosub WRITE_PKW1_PNH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PND]
End

############################################################
# Traçabilité aval sur les demandes de livraison
# Une demande peut avoir des réceptions ou des factures associées.
# 1. Recherche des réceptions (distinctes) : on interroge les lignes de réception
# 2. Recherche des factures (distinctes) : on interroge les lignes de facture
Subprog FIND_TREE_AVAL_POC(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PTH_F(GLONVCR)
Local Integer PTH_L
Local Char PIH_F(GLONVCR)
Local Integer PIH_L

  # Recherche des réceptions associées à la demande
  If !clalev([F:PTD]) Then Local File PRECEIPTD [PTD] Endif
  If !clalev([F:PID]) Then Local File PINVOICED [PID] Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_POC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PTD] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PTD] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PTD]) > 0 Then
    # Livraison
    Raz PTH_F
    For [F:PTD]
      If [F:PTD]PTHNUM <> "" Then
        PTH_F = [F:PTD]PTHNUM
        PTH_L = [F:PTD]PTDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PTD]POPLIN, NUM_POC) = G_OUI Then
          Read [F:PTH]PTH0=PTH_F
          If !fstat Then
            Gosub WRITE_PKW1_PTH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PTD]
  # ---------------------
  # Recherche des factures associées à la demande
  If [M:PIV1]VCRTYPSEL = NUM_POC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PID]) > 0 Then
    # Livraison
    Raz PIH_F
    For [F:PID]
      If [F:PID]NUM <> "" Then
        PIH_F = [F:PID]NUM
        PIH_L = [F:PID]PIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]POPLIN, NUM_POC) = G_OUI Then
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les commandes
# Une commande peut avoir soit des réceptions, soit des factures associées.
# 1. Recherche des réceptions (distinctes) : on parcourt les lignes de réceptions.
# 2. Recherche des factures (distinctes), en parcourant les lignes de facture
Subprog FIND_TREE_AVAL_POH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer DUD_ACCNUM
Local Integer DUD_DUDLIG
Local Char PTH_F(GLONVCR)
Local Integer PTH_L
Local Char PIH_F(GLONVCR)
Local Integer PIH_L
Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char CTRH_F(GLONVCR)                                           # FGR 29/05/2015 : X3SUIVI104697
Local Integer CTRH_L                                                 # FGR 29/05/2015 : X3SUIVI104697
Local Char SHH_F(GLONVCR)                                            # FGR 29/05/2015 : X3SUIVI104697
Local Integer SHH_L                                                  # FGR 29/05/2015 : X3SUIVI104697

  # Recherche d'un acompte depuis commande
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  If !clalev([F:PTD]) Then Local File PRECEIPTD [PTD] : Endif
  If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  If !clalev([F:CTRD]) Then Local File CONTAINERD [CTRD] : Endif     # FGR 29/05/2015 : X3SUIVI104697
  If !clalev([F:SHD])  Then Local File SHIPMENTD  [SHD] : Endif      # FGR 29/05/2015 : X3SUIVI104697
  If !clalev([F:POQ])  Then Local File PORDERQ    [POQ] : Endif
  # ---------------------
  Filter [F:DUD] Where TYP = "*PO" & NUM=[F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    Raz DUD_ACCNUM
    For [F:DUD]
      # échéance
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [F:DUD]
  # -----------------------
  # FGR 29/05/2015 : X3SUIVI104697
  # On rechercher tous les containers
  Link [F:POQ] With [F:CTRD]CTRD1=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ As [SC_] Where [F:POQ]POHNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:POQ]POPLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Conteneurs
    Raz CTRH_F
    For [F:SC_]
      If [F:CTRD]CTRNUM <> "" Then
        CTRH_F = [F:CTRD]CTRNUM
        CTRH_L = [F:CTRD]CTRLIN
        If func CONSPITOOLS.VERIF_LINE([F:CTRD]CTRLIN, NUM_POH) = G_OUI Then
          # Pour chacun de ces Conteneurs, on récupère les infos
          Read [F:CTRH]CTRH0=CTRH_F
          If !fstat Then
            Gosub WRITE_PKW1_CTRH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
  # -----------------------
  # FGR 29/05/2015 : X3SUIVI104697
  # On rechercher toutes les expéditions
  Link [F:SHD] With [F:POQ]POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ As [SC_] Where [F:SHD]POHNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:POQ]POPLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Expéditions
    Raz SHH_F
    For [F:SC_]
      If [F:SHD]SHIPNUM <> "" Then
        SHH_F = [F:SHD]SHIPNUM
        SHH_L = [F:SHD]SHIPLIN
        If func CONSPITOOLS.VERIF_LINE([F:SHD]SHIPLIN, NUM_POH) = G_OUI Then
          # Pour chacun de ces expeditions, on récupère les infos
          Read [F:SHH]SHH0=SHH_F
          If !fstat Then
            Gosub WRITE_PKW1_SHH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
  # ---------------------
  # Recherche des réceptions associées à la commande
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PTD] Where POHNUM=[F:PKW]VCRNUM and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PTD] Where POHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PTD]) > 0 Then
    # Réception
    Raz PTH_F
    For [F:PTD]
      If [F:PTD]PTHNUM <> "" Then
        PTH_F = [F:PTD]PTHNUM
        PTH_L = [F:PTD]PTDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PTD]POPLIN, NUM_POH) = G_OUI Then
          Read [F:PTH]PTH0=PTH_F
          If !fstat Then
            Gosub WRITE_PKW1_PTH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PTD]
  # ---------------------
  # Recherche d'une facture
  If [M:PIV1]VCRTYPSEL = NUM_POH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where POHNUM=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5) and POPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where POHNUM=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5)
  Endif
  If rowcount([F:PID]) > 0 Then
    # Facture
    Raz PIH_F
    For [F:PID]
      If [F:PID]NUM <> "" Then
        PIH_F = [F:PID]NUM
        PIH_L = [F:PID]PIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]POPLIN, NUM_POH) = G_OUI Then
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité aval sur les conteneurs
# Une conteneur ne peut avoir que des expéditions
Subprog FIND_TREE_AVAL_CTRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SHH_F(GLONVCR)
Local Integer SHH_L

  If !clalev([F:CTRD]) Then Local File CONTAINERD [CTRD] : Endif
  If !clalev([F:SHD])  Then Local File SHIPMENTD  [SHD] : Endif
  # ---------------------
  # On rechercher toutes les expéditions
  Link [F:SHD] With [F:CTRD]CTRD0=[F:SHD]CTRNUM;[F:SHD]CTRLIN As [SC_] Where [F:CTRD]CTRNUM=[F:PKW]VCRNUM
  If [M:PIV1]VCRTYPSEL = NUM_CTRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SC_] Where [F:CTRD]CTRLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SC_]) > 0 Then
    # Expéditions
    Raz SHH_F
    For [F:SC_]
      If [F:SHD]SHIPNUM <> "" Then
        SHH_F = [F:SHD]SHIPNUM
        SHH_L = [F:SHD]SHIPLIN
        If func CONSPITOOLS.VERIF_LINE([F:SHD]SHIPLIN, NUM_CTRH) = G_OUI Then
          # Pour chacun de ces expéditions, on récupère les infos
          Read [F:SHH]SHH0=SHH_F
          If !fstat Then
            Gosub WRITE_PKW1_SHH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SC_]
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité aval sur les Expéditions
# Une Expéditions ne peut avoir qu'un transport
Subprog FIND_TREE_AVAL_SHH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char TRNP_F(GLONVCR)
Local Integer TRNP_L
Local Char PIH_F(GLONVCR)    # FGR 27/02/2016 : X3SUIVI110325
Local Integer PIH_L          # FGR 27/02/2016 : X3SUIVI110325
Local Char PTH_F(GLONVCR)    # FGR 01/09/2016 : X3SUIVI118277
Local Integer PTH_L          # FGR 01/09/2016 : X3SUIVI118277

  Local File SHIPMENT [SHH]  # On l'ouvre en local pour ne pas risque de polluer celui plus haut
  Local File SHIPMENTD [SHD] # FGR 01/09/2016 : X3SUIVI118277
  Local File PRECEIPTD [PTD] # FGR 01/09/2016 : X3SUIVI118277
  Local File PINVOICED [PID]
  # ---------------------
  # On rechercher toutes le transport
  Read [SHH]SHH0=[F:PKW]VCRNUM
  If [F:SHH]TRNNUM <> "" Then
    TRNP_F = [F:SHH]TRNNUM
    Read [F:TRNP]TRNP0=TRNP_F
    If !fstat Then
      Gosub WRITE_PKW1_TRNP
      WK = 1
    Endif
  Endif
  # ---------------------
  # Les réceptions rattachée a la même commande que l'expédition
  # FGR 01/09/2016 : X3SUIVI118277 (début)
  Filter [SHD] Where [F:SHD]SHIPNUM = [F:PKW]VCRNUM and [F:SHD]POHNUM <> ""
  For [SHD]
    Filter [PTD] Where [F:PTD]POHNUM = [F:SHD]POHNUM and [F:PTD]POPLIN = [F:SHD]POPLIN
    For [PTD]
      PTH_F = [F:PTD]PTHNUM
      PTH_L = [F:PTD]PTDLIN
      # Pour chacune de ces réceptions, on récupère les infos
      Read [F:PTH]PTH0=PTH_F
      If !fstat Then
        # Réception
        Gosub WRITE_PKW1_PTH
        WK = 1
      Endif
    Next
    Filter [PTD]
  Next
  Filter [SHD]
  # FGR 01/09/2016 : X3SUIVI118277 (fin)
  # ---------------------
  # FGR 27/02/2016 : X3SUIVI110325 (début)
  # On recherche les factures comlémentaires
  If [M:PIV1]VCRTYPSEL = NUM_SHH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PID] Where NUMORI=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5) and PIHTYP = 2 and LINORI=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PID] Where NUMORI=[F:PKW]VCRNUM and (INVTYP=1 or INVTYP=5) and PIHTYP = 2
  Endif
  If rowcount([F:PID]) > 0 Then
    # Facture
    Raz PIH_F
    For [F:PID]
      If [F:PID]NUM <> "" Then
        PIH_F = [F:PID]NUM
        PIH_L = [F:PID]PIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PID]LINORI, NUM_SHH) = G_OUI Then
          Read [F:PIH]PIH0=PIH_F
          If !fstat Then
            Gosub WRITE_PKW1_PIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PID]
  # FGR 27/02/2016 : X3SUIVI110325 (fin)
  # ---------------------
End

############################################################
# FGR 29/05/2015 : X3SUIVI104697
# Traçabilité aval sur les Transport
# Il n'y a rien sous les transports
Subprog FIND_TREE_AVAL_TRNP(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

End

############################################################
# Traçabilité aval sur les demandes d'achats
# Une demande d'achat peut avoir soit des commandes soit des demandes de livraisons associées.
# 1. Recherche des commandes (distinctes) : on parcourt la table des liens
#    Demande/commande.
# 2. Recherche des demandes de livraison (distinctes) : on parcourt la
#    table des liens Demande/commande
Subprog FIND_TREE_AVAL_PSH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char POH_F(GLONVCR)
Local Integer POH_L

  # Recherche des commandes associées à la demande d'achat
  If !clalev([F:PSO]) Then Local File PREQUISO [PSO] : Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_PSH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PSO] Where PSHNUM=[F:PKW]VCRNUM and PSDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PSO] Where PSHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PSO]) > 0 Then
    Raz POH_F
    For [F:PSO]
      If [F:PSO]POHNUM <> "" Then
        POH_F = [F:PSO]POHNUM
        POH_L = [F:PSO]POPLIN
        If func CONSPITOOLS.VERIF_LINE([F:PSO]PSDLIN, NUM_PSH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:POH]POH0=POH_F
          If !fstat Then
            If [F:POH]POHTYP = 2 Then
              # Commande ouverte
              Read [F:POC]POC0=POH_F
              If !fstat Then
                Gosub WRITE_PKW1_POC
                WK = 1
              Endif
            Elsif [F:POH]POHTYP = 1 Then
              # Commande
              Gosub WRITE_PKW1_POH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PSO]
End

############################################################
# Traçabilité aval sur les appels d'offre
# Un appel d'offre peut avoir soit des demandes d'achat, soit des commandes associées.
# 1. Recherche des demandes d'achats (distinctes) : on parcourt les lignes de
#    demandes d'achat.
# 2. Recherche des commandes (distinctes) : on parcourt les lignes de commandes.
Subprog FIND_TREE_AVAL_PQH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PSH_F(GLONVCR)
Local Integer PSH_L
Local Char POH_F(GLONVCR)
Local Integer POH_L

  # Recherche des demandes d'achat associées à l'appel d'offre
  If !clalev([F:PSD]) Then Local File PREQUISD [PSD] Endif
  If !clalev([F:POQ]) Then Local File PORDERQ [POQ] Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_PQH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PSD] Where PQHNUM=[F:PKW]VCRNUM and PPDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PSD] Where PQHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PSD]) > 0 Then
    # Demandes d'achat
    Raz PSH_F
    For [F:PSD]
      If [F:PSD]PSHNUM <> "" Then
        PSH_F = [F:PSD]PSHNUM
        PSH_L = [F:PSD]PSDLIN
        If func CONSPITOOLS.VERIF_LINE([F:PSD]PPDLIN, NUM_PQH) = G_OUI Then
          Read [F:PSH]PSH0=PSH_F
          If !fstat Then
            Gosub WRITE_PKW1_PSH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PSD]
  # ---------------------
  # Recherche des commandes
  If [M:PIV1]VCRTYPSEL = NUM_PQH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:POQ] Where PQHNUM=[F:PKW]VCRNUM and PPDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:POQ] Where PQHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:POQ]) > 0 Then
    # Commandes
    Raz POH_F
    For [F:POQ]
      If [F:POQ]POHNUM <> "" Then
        POH_F = [F:POQ]POHNUM
        POH_L = [F:POQ]POPLIN
        If func CONSPITOOLS.VERIF_LINE([F:POQ]PPDLIN, NUM_PQH) = G_OUI Then
          Read [F:POH]POH0=POH_F
          If !fstat Then
            Gosub WRITE_PKW1_POH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:POQ]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les ordres de sous-traitance
# Un order de sous-traitance peut avoir des commandes associées
# 1. Recherche des commandes (distinctes) : on interroge les lignes de commandes.
Subprog FIND_TREE_AVAL_SCO(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char POH_F(GLONVCR)
Local Integer POH_L

  # Recherche des commandes
  If !clalev([F:POQ]) Then Local File PORDERQ [POQ] Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_SCO and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:POQ] Where VCRNUMORI=[F:PKW]VCRNUM and VCRLINORI=[M:PIV1]VCRLINSEL
  Else
    Filter [F:POQ] Where VCRNUMORI=[F:PKW]VCRNUM
  Endif
  If rowcount([F:POQ]) > 0 Then
    # Commandes
    Raz POH_F
    For [F:POQ]
      If [F:POQ]POHNUM <> "" Then
        POH_F = [F:POQ]POHNUM
        POH_L = [F:POQ]POPLIN
        If func CONSPITOOLS.VERIF_LINE([F:POQ]VCRLINORI, NUM_SCO) = G_OUI Then
          Read [F:POH]POH0=POH_F
          If !fstat Then
            Gosub WRITE_PKW1_POH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:POQ]
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("PUR7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("PUR7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("PUR7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
End

############################################################
# Traçabilité aval sur les échéances/acomptes
# Une échéance peut avoir des reglements
# 1. Recherche des reglements (distincts) : on interroge la table des reglements.
Subprog FIND_TREE_AVAL_DUD(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PYH_F(GLONVCR)
Local Integer PYH_L
Local Integer IPOSSLASH
Local Integer ITRDUDNUM
Local Integer ITRDUDLIG

  # Recherche des règlements
  # ---------------------
  IPOSSLASH = instr(1, [F:PKW]VCRNUM, "/")
  ITRDUDNUM = val(seg$([F:PKW]VCRNUM, 1, IPOSSLASH-1))
  ITRDUDLIG = val(seg$([F:PKW]VCRNUM, IPOSSLASH+1, len([F:PKW]VCRNUM)))
  # ---------------------
  # Recherche d'une ligne de règlement associée au à l'échéance
  If ([M:PIV1]VCRTYPSEL = NUM_DUD or [M:PIV1]VCRTYPSEL = NUM_DUDA) and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PYD] Where DUDNUM = ITRDUDNUM and DUDLIG = ITRDUDLIG and LIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PYD] Where DUDNUM = ITRDUDNUM and DUDLIG = ITRDUDLIG
  Endif
  If rowcount([F:PYD]) > 0 Then
    Raz PYH_F
    For [F:PYD]
      If [F:PYD]NUM <> "" Then
        PYH_F = [F:PYD]NUM
        PYH_L = [F:PYD]LIN
        If func CONSPITOOLS.VERIF_LINE([F:PYD]LIN, NUM_PYH) = G_OUI Then
          Read [F:PYH]PYH0=PYH_F
          If !fstat Then
            Gosub WRITE_PKW1_PYH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PYD]
End

############################################################
