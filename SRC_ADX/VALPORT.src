#<AdxTL>@(#)6.0.0.0 $Revision$
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
# Issue X3-69581 - 2017-12-27 by FHA
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"VALPORT"
 GFONCTION="VALPORT" : Call AUTORIS From EXEFNC
Endif
GACTION = "VALPORT"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","VALPORT","DVALPORT",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####
$INIT
#####
Onerrgo CHUT From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY]    : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]    : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY]    : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC]    : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif

# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return

#########
$CONTROLE
#########
If GSERVEUR : [M:DIA]TRCFLG=2 : Endif
TMP=1 : TIT="V"
Return

#####
$EXEC
#####
Onerrgo ERREUR From GESECRAN
If clalev([F:PYH])=0 : Local File PAYMENTH    [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP   [TPY] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER    [BPR] : Endif
If clalev([F:BAN])=0 : Local File BANK        [BAN] : Endif
If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GRA])=0 : Local File GRPAUTACE   [GRA] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT   [MVC] : Endif
If clalev([F:MVS])=0 : Local File BPSUPPMVT   [MVS] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:TPY2])=0: Local File TABPAYTYP  [TPY2] : Endif
Gosub OUVRE
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char    PARAM2(10), DEV2(GLONCUR), SEP(3), DEVSOC(GLONCUR)
Local Char    DESDEF(30), CRITERE(250), CRITSPE(250), ERR(1)
Local Char    SITE(GLONFCY)
Local Char    GRPPCE(GLONGRA), PCEAUTO(GLONGAU)

Local Char     MESSA(250)                    : # Messages
Local Char     TMESSAGE(250)(1..50)          : # contient les no pièces créées ou message d'erreur
Local Char     TMESSA(250)(1..50)            : # contient les no pièces créées par l'appel du VALPCE
Local Char     NUMERO(GLONVCR)               : # Numéro de règlement
Local Char     ABR(3)                        : # Abréviation fichier
Local Char     NUMBOR(GLONVCR)               : # Numéro de bordereau
Local Char     SITE(GLONFCY)                 : # Site
Local Char     JOURNAL(GLONJOU)              : # Journal
Local Char     TYPPCE(GLONGTE)               : # Type de pièce
Local Char     NUMPCE(GLONVCR)               : # Numéro de pièce
 #*X3-39795 Local Char TZONE(10)(1..3)   : # Table des zones à forcer
 #*X3-39795 Local Char TVAL(30)(1..3)    : # Table des valeurs des zones à forcer
Local Char     TZONE(10)(1..10)              : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char     TVAL(30)(1..10)               : # Table of values for zones to be forced         #*X3-39795
Local Char     COMPTE(GLONGAC)               : # Comptes
Local Integer  INDPCE                        : # Indice pièce auto
Local Integer  NBPLAN                        : # Nombre de codes plans
Local Integer  REFTYP(1..len(mess(0,2644,1))): # Type référentiels
Local Integer  STAT, NOL, OK, I, NBREG, MAXLIG, T : # Variables diverses
Local Integer  TYP_DEVAL                     : # Type dévalorisation 1:Espagne 2:Portugal

Local Char     PLAN(GLONCOA)(1..len(mess(0,2644,1)))  : # Codes plans
Local Char     X_ACC1(GLONGAC)(1..len(mess(0,2644,1))): # Comptes d'effets mouvementés par référentiel
Local Char     X_ACC2(GLONGAC)(1..len(mess(0,2644,1))): # Comptes dettes pour effets mouvementés par référentiel
Local Integer  X_ACCNUM1(1..len(mess(0,2644,1))): # Accnums comptes d'effets mouvementés par référentiel
Local Integer  X_ACCNUM2(1..len(mess(0,2644,1))): # Accnums comptes dettes pour effets mouvementés par référentiel

Local Decimal AMTIPT(1..2), MONTEXT, MONTANT
Local Libelle TEST

Global Integer GCAS : GCAS = 1

TEST = 0
SEP=", "

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call TITAWI(BCRIT,CRITERE) From OBJDIV
 Call OUVRE_TRACE(CRITERE) From LECFIC
Endif

# Constitution du filtre de sélection
CRITERE = "STAFLG(2)=2 & STAFLG(8)=2 & STAFLG(9)<>2"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]DUDDAT<>[0/0/0]
 CRITERE -= '& DUDDAT<=['+format$(GFMD,[M:DIA]DUDDAT)+']'
Endif
If dim([M:DIA]LEG)>0 and [M:DIA]LEG<>""     :#X3-69581 testing LEG fld's presence
  GCURLEG=[M:DIA]LEG #X3-41685
Endif

#################### Point d'entrée FILTRE ####################
Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC

If [L]CRITSPE="" : [L]CRITSPE="1=1" : Endif

DESDEF=mess(27,117,1)
If [M:DIA]ALLTYP=2
# Filter [TPY2] Where (LEG=GCURLEG | GCURLEG="") Order By Key CLE=PAYTYP Asc; LEG Desc #X3-41685 Issue LEG="" ==> GCURLGEG=""
 Filter [TPY2] Where (LEG=GCURLEG | LEG="") Order By Key CLE=PAYTYP Asc; LEG Desc      #X3-69581 cancelling X3-41685: GCURLGEG="" ==> LEG=""
 For [TPY2]CLE(1)
  If [F:TPY2]ENAFLG=2 & (([F:TPY2]STA3=2 & [F:TPY2]UPDBIL>1) | [F:TPY2]AUTACE10<>"")
   Call CONTEXE([F:TPY2]ACS) From CPTSUB # Droits Utilisateurs
   If !mkstat : OK=1 : Else mkstat=0 : OK=0 : GMESSAGE="" : Endif
   If OK
    If [F:TPY]PAYTYP<>[F:TPY2]PAYTYP | [F:TPY]LEG<>[F:TPY2]LEG
     Read [TPY]TPY0 = [F:TPY2]PAYTYP;[F:TPY2]LEG
    Endif
    Filter [PYH] Where PAYTYP=[F:TPY]PAYTYP & evalue(CRITERE) & evalue(CRITSPE)
&                Order By Key CLE = CPY;NUM
    Gosub DEVAL
   Endif
  Endif
 Next
Else
 Call LEC_TPY_LEG(GCURLEG,[M:DIA]TYP) From CPTLEC
 Filter [PYH] Where PAYTYP=[M:DIA]TYP & evalue(CRITERE) & evalue(CRITSPE)
&             Order By Key CLE = CPY;NUM
 Gosub DEVAL
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
 TRA=1
Endif

Return

$DEVAL

For [PYH]CLE(1)
 # If all cpy then should take care of legislation : cpy leg = screen leg
 If [M:DIA]ALLCPY=2
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  If [F:CPY]LEG <> GCURLEG : Goto NEXT_PYHCPY : Endif      :#X3-69581 Resuming next Cpy there may be others
 Endif
 I=find([F:PYH]CPY,GSOC(1..GNBSOC))
 If I : DEVSOC=GDEVSOC(I)
 Else : MESSA="CPY\"+[F:PYH]CPY : GOK=0 : Goto NEXT_PYHCPY :#X3-69581 If company exist anymore Resuming next Cpy
 Endif
 Call SETPLAN3([F:PYH]CPY,NBPLAN,PLAN,REFTYP) From CPTDIV
 For [PYH]CLE
  # Règlement
  If GTRACE<>""
   GMESSAGE=[F:PYH]PAYTYP+SEP
   If [F:PYH]BPR<>"" : GMESSAGE+=[F:PYH]BPR : Else GMESSAGE+=[F:PYH]ACC : Endif
   GMESSAGE+=SEP+[F:PYH]FCY+SEP+format$("D:"+GFMDAT,[F:PYH]DUDDAT)+SEP+num$([F:PYH]AMTNYTBIL)-DEVSOC
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-GMESSAGE,0) From GESECRAN
   GMESSAGE=""
  Endif
  NUMERO = [F:PYH]NUM
  CRIT="[F:TB0]NUM='"+NUMERO+"'"
  GOK=1 : Gosub TRAITEMENT
  If GOK<1
   If GTRACE<>""
    GERR=1 : If GMESSAGE="" : GMESSAGE=MESSA : Endif
   Endif
   Break 2
  Endif
  If GOK=1 : NBREG += 1 : Endif
 Next : # [PYH]
$NEXT_PYHCPY             :#X3-69581 Resuming next Cpy
Next
Return

$TRAITEMENT
GOK = 1
## Eventuellement génération d'une pièce de dévalorisation portefeuille (cas du Portugal et de l'Espagne)
## MAJ de PAYMENTH + du portefeuille dans les mouvements client et fournisseurs
GRPPCE = evalue("[F:TPY]AUTACE"+num$([M:DIA]ACCSTA))
If GRPPCE<>""
 Read [GRA]GRA0 = GRPPCE
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub TRANSAC
  If GOK<1 : Return : Endif
 Endif
Else
 Call DEBTRANS From GLOCK
 Gosub TRANSAC
 If GOK<1 : Return : Endif
Endif
Return


$TRANSAC
Trbegin [PYH], [PAN], [MVC]
 INDPCE = 0

 If GRPPCE<>""
  While [F:GRA]CODACE(INDPCE)<>""

   Filter [PAN] Where NUM=NUMERO & TYPNUM=3 & (STA=10 | STA=-10) & ACCSTA=9 & RVSACCNUM=0
   Read [PAN]PAN0 First
   Filter [PAN]
   If !fstat
    If [F:PAN]STA = -10
     TYP_DEVAL = 1 : # Dévalorisation portefeuille Espagne
    Elsif [F:PAN]STA = 10
     TYP_DEVAL = 2 : # Dévalorisation portefeuille Portugal
    Endif
   Endif

   PCEAUTO = [F:GRA]CODACE(INDPCE)

   Call LECTURE("GAU",PCEAUTO,"") From CONTOBJ
   Gosub VAL_IMPOSE
   If STAT
    Call ECR_TRACE(TMESSA(1),1) From GESECRAN
    GOK = 0 : Break
   Endif
   TZONE(5)= "ORIGIN" : TVAL(5)= "2"            #Automatic loading  #*X3-39795
   TZONE(6)= "ORICOD" : TVAL(6)= PCEAUTO                            #*X3-39795
   Call VALPCE4(PCEAUTO,CRIT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
   If STAT
    Call ECR_TRACE(MESSA,1) From GESECRAN
    GOK = 0 : Break
   Elsif GTRACE<>"" & [M:HAE2]NBLIG>0
    # Création pièce
    Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
   Endif
   If [M:HAE2]NBLIG>0
    Gosub MAJPAN
    If GOK<1 : Break : Endif
    Gosub LETTRAGE
   Endif
   INDPCE += 1
  Wend
  If GOK<0   : Goto ROLL_TRANSAC
  Elsif !GOK : Goto AB_TRANSAC
  Endif
 Endif
 Gosub MAJPYH
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
 Gosub PORTEF
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
Commit
Return

$AB_TRANSAC
Rollback
Return

$ROLL_TRANSAC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRANSAC : Endif
Return

$MAJPAN
Case TYP_DEVAL
 When 1
  Raz [F:PAN]
  [F:PAN]TYPNUM=3
  [F:PAN]NUM=[F:PYH]NUM
  [F:PAN]STA=10
  ## On veut stocker dans [F:PAN]ACCNUM le numéro interne correspondant au compte d'effets mouvementé
  ## pour le référentiel général principal dans la pièce de dévalorisation du portefeuille.
  ## Rappel : le compte d'effet est mouvementé en premier....
  For NOL=0 To [M:HAEW]NB-1
   If [M:HAEW]LEDTYP(NOL)=REFTYP(1)
    [F:PAN]ACCNUM=[M:HAEW]ACCNUM(NOL)
    Break
   Endif
  Next
  [F:PAN]ACCSTA=10
  [F:PAN]CPTBAN=2
  Case [F:GAU]TYPVCR
   When 9 : # Dévalorisation portefeuille
    [F:PAN]TYPVCR = "H"
  Endcase
  Write [PAN]
  If fstat
   GOK=0 : Call FSTA("PAN") From GLOCK
   If GTRACE<>""
    MESSA="PAN\"+num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA)-num$([F:PAN]ACCNUM)
   Endif
  Endif
 When 2
  Raz [F:PAN]
  [F:PAN]TYPNUM=3
  [F:PAN]NUM=[F:PYH]NUM
  [F:PAN]STA=10
  For NOL=0 To [M:HAEW]NB-1
   If [M:HAEW]LEDTYP(NOL)=REFTYP(1)
    [F:PAN]ACCNUM=[M:HAEW]ACCNUM(NOL)
    Break
   Endif
  Next
  [F:PAN]ACCSTA=10
  [F:PAN]CPTBAN=2
  Case [F:GAU]TYPVCR
   When 9 : # Dévalorisation portefeuille
    [F:PAN]TYPVCR = "H"
  Endcase
  Write [PAN]
  If fstat
   GOK=0 : Call FSTA("PAN") From GLOCK
   If GTRACE<>""
    MESSA="PAN\"+num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA)-num$([F:PAN]ACCNUM)
   Endif
  Endif
 Return
Endcase
Return

$LETTRAGE
Case TYP_DEVAL
 When 1
  Gosub LETTRAGE_ES
 When 2
  Gosub LETTRAGE_PT
Endcase
Return

## 2 comptes à lettrer : Effets à l'escompte, et compte de dettes pour effets
$LETTRAGE_PT
Gosub RECH_ACCNUMPT
For IREF=1 To NBPLAN
 For TYPCPT = 1 To 2 :  # TYPCPT=1=Compte d'effets  TYPCPT=2=Compte dettes pour effets
  Gosub LET_DIF
 Next
Next
Return


## 2 comptes à lettrer : Effets à l'escompte (mouvementé lors de l'étape de remise intermédiaire) et compte
## de dettes pour effets (mouvementé lors de la remise en banque)
$LETTRAGE_ES
Gosub RECH_ACCNUMES
For IREF=1 To NBPLAN
 For TYPCPT = 1 To 2 :  # TYPCPT=1=Compte d'effets  TYPCPT=2=Compte dettes pour effets
  Gosub LET_DIF
 Next
Next
Return

$LET_DIF
[L]COMPTE = evalue("X_ACC"+num$(TYPCPT)+"("+num$(IREF)+")")
Call LECTURE("GAC",[L]COMPTE,PLAN(IREF)) From CONTOBJ
If [F:GAC]MTC=2
 XNBLET     = 2
 XACCNUM(1) = evalue("X_ACCNUM"+num$(TYPCPT)+"("+num$(IREF)+")")
 XDUDLIG(1) = 1
 For NOL=0 To [M:HAEW]NB-1
  If [M:HAEW]LEDTYP(NOL)=REFTYP(IREF) & [M:HAEW]COA(NOL)=PLAN(IREF) & [M:HAEW]ACC(NOL)=[L]COMPTE
   XACCNUM(2) = [M:HAEW]ACCNUM(NOL)
   XDUDLIG(2) = 1
   XAMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
   XAMTIPT(2) = XAMTIPT(1)
   Break
  Endif
 Next
 Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPT,2) From CPTLET
 If GOK<1 : Return : Endif
Endif
Return


$MAJPYH
Update [PYH] Where NUM=[L]NUMERO With STAFLG(9)=2, STA=10
If fstat=1
 GOK = -1 : GLOCK = "$PAYMENTH"-NUMERO : Return
Elsif fstat
 GOK = 0 : Call FSTA("PYH") From GLOCK : Return
Endif
Return

$PORTEF
Local Decimal WAMT
Local Integer WIFFTYP
Local Char DEVLED(GLONCUR)

Call GETDEV([F:PYH]FCY) From DEVSUB
Raz WAMT
If [F:PYH]AMTNYTBIL<>0  # Le champ AMTNYTBIL est en devise de référentiel
 Call SETCUR(1,[F:PYH]CPY,DEVLED) From CPTDIV
 Call COURMNT(DEVLED,[F:PYH]CUR,DEVLED,0,[F:PYH]ACCDAT,1,[F:PYH]AMTNYTBIL,WAMT,0,STAT) From TRTDEV
 If STAT
  # Pas de cours
  Call ECR_TRACE(mess(4,109,1)-DEVLED-"=>"-[F:PYH]CUR,1) From GESECRAN
 Else
  GPOINT = "BEFUPDMVT" : Gosub ENTREE From EXEFNC
  If [F:PYH]BPRTYP=1 & [F:PYH]SNS<>1 : # Recette client
   Call MAJMVC([F:PYH]BPR,[F:PYH]CUR,0,0,[F:PYH]ACCDAT,[F:PYH]NUM,[F:PYH]FCY,WAMT,[F:PYH]AMTCUR,"-","M","",[F:TPY]UPDBIL) From TRTBPMVT

  Elsif [F:PYH]BPRTYP=2 & [F:PYH]SNS=1 : # Dépense fournisseur
   WIFFTYP = [F:TPY]UPDBIL+6
   WAMT*=-1
   Call MAJENC_BPS([F:PYH]BPR,WIFFTYP,[F:PYH]FCY,[F:PYH]CUR,0,[F:PYH]ACCDAT,[F:PYH]NUM,WAMT,0,[F:PYH]AMTCUR) From TRTBPMVT
  Endif

 Endif
Endif
Return

$VAL_IMPOSE
If [F:PYH]FRMNUM = "" : SITE = [F:PYH]FCY
Else                  : SITE = [F:PYH]FRMFCY
Endif
Call GETSOC([L]SITE) From DEVSUB
If clalev([F:TB0])=0 :  Local File PAYMENTH   [TB0] : Endif
Call LECTURE("BAN",[F:PYH]BAN,"") From CONTOBJ
Read [TB0]PYH0 = [F:PYH]NUM
##############################################################################################
# 1°) JOURNAL : # Recherche journal définie avec SRD/CB le 31/10/02
# - La pièce sera générée sur le journal de la pièce auto
[L]JOURNAL = ""
Call EVAL_CHAR([L]JOURNAL,"JOU",1,0,"",STAT) From CPTAUTO
# - Si pas de journal associé à la pièce auto, on prend le journal associé au type de journal
#   de l'étape de comptabilisation courante paramétré dans la table de la banque
If [L]JOURNAL = ""
 Call LECTURE("BAN",[F:PYH]BAN,"") From CONTOBJ
 If fstat=0 & evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))<>len(mess(0,660,1)) : # aucun
  T=find(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA)),[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
  If T : [L]JOURNAL = [F:BAN]JOU(T-1) : Endif
 Endif
Endif
# - Si pas de journal trouvé, on prend le journal paramétré dans le paramètre JOUPAY[X],
#   [X] correspondant au type de journal de l'étape de comptabilisation courante
If [L]JOURNAL = ""
 Call PARAM(SITE,"JOUPAY"+num$(evalue("[F:TPY]JOU"+num$([M:DIA]ACCSTA))),[L]JOURNAL) From ADOVAL
Endif
# - Si pas de journal trouvé, on prend le journal par défaut du type de pièce
If [L]JOURNAL = ""
 Call EVAL_CHAR([L]TYPPCE,"GTE",1,0,"",STAT) From CPTAUTO
 If [L]TYPPCE<>""
  Call LEC_GTE_LEG(GCURLEG,[L]TYPPCE) From CPTLEC
  If !fstat
   [L]JOURNAL = [F:GTE]DEFJOU
  Endif
 Endif
Endif
If [L]JOURNAL=""
 STAT = 1 : TMESSA(1) = PCEAUTO-":"-mess(53,141,1) : # Journal non défini
 Return
Else
 STAT = 0
Endif
TZONE(1) = "JOU" : TVAL(1) = [L]JOURNAL
####################################################################################################
# 2°) REFINT : Référence interne de la pièce (sert notamment pour les zooms règlements). On l'initialise
# comme ne 130 par 'PYH [No règlt]' lorsque la pièce concerne qu'un règlement
# Lorsque la pièce concerne X règlements (validation  groupée d'un bordereau), ce champ est laissé
# à vide comme en 130..)
TZONE(2) = "REFINT" : TVAL(2) = "PYH"-NUMERO
Close File [TB0]
# DBA le 06/03/03 : type d'échéance (3=règlement)
TZONE(3) = "TYPDUD" : TVAL(3)="3"
Return


$RECH_ACCNUMPT
# On stocke dans LETACCNUM l'accnum correspondant au compte d'effets escomptés mouvementé dans l'étape de remise en banque
# On stocke dans LETACCNUM2 l'accnum correspondant au compte de dettes pour effets mouvementé dans l'étape de remise en banque
# L'accnum du compte de dettes pour effets est stocké dans PAYACCNUM
## 1/ On s'occupe d'abord du compte de dettes pour d'effets
Raz X_ACC1, X_ACCNUM1, X_ACC2, X_ACCNUM2
Filter [PAN2] Where NUM=[F:PYH]NUM & TYPNUM=3 & ACCSTA=9 & STA=10 & RVSACCNUM=0
Read [PAN2]PAN0 First
Filter [PAN2]
For IREF=1 To NBPLAN
 If IREF = 1 : # Référentiel général principal
  LETACCNUM2 = [F:PAN2]ACCNUM
  Read [DAE5]DAE2 = [L]LETACCNUM2
  If !fstat
   TYPPCE = [F:DAE5]TYP : NUMPCE = [F:DAE5]NUM
   [L]X_ACC2(1)    = [F:DAE5]ACC
   [L]X_ACCNUM2(1) = [L]LETACCNUM2
  Else
   Read [DAT5]DAT1 = [L]LETACCNUM2
   If !fstat
    TYPPCE = [F:DAT5]TYP : NUMPCE = [F:DAT5]NUM
    [L]X_ACC2(1) = [F:DAT5]ACC
    [L]X_ACCNUM2(1) = [L]LETACCNUM2
   Endif
  Endif
 Else : # Les autres référentiels saisissables....
  Filter [DAE7] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAE5]IDTLIN
  Read [DAE7] First
  Filter [DAE7]
  If !fstat
   [L]X_ACC2(IREF)    = [F:DAE7]ACC
   [L]X_ACCNUM2(IREF) = [F:DAE7]ACCNUM
  Else
   Filter [DAT7] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAT5]IDTLIN
   Read [DAT7] First
   Filter [DAT7]
   If !fstat
    [L]X_ACC2(IREF)    = [F:DAT7]ACC
    [L]X_ACCNUM2(IREF) = [F:DAT7]ACCNUM
   Endif
  Endif
 Endif
Next
## 2/ On s'occupe maintenant du compte d'effets
For IREF=1 To NBPLAN
 If IREF = 1 : # Référentiel général principal
  LETACCNUM2 = [F:PAN2]ACCNUM
  For [DAE5] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=IREF & ACCNUM<>[L]LETACCNUM2
   ## La pièce auto de remise effets à l'escompte génère deux lignes. Donc pour le même référentiel,
   ## et pour un accnum différent, on tombe forcément sur le compte d'effets...
   [L]X_ACC1(1)    = [F:DAE5]ACC
   [L]X_ACCNUM1(1) = [F:DAE5]ACCNUM
   Break
  Next
  For [DAT5] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=IREF & ACCNUM<>[L]LETACCNUM2
   [L]X_ACC1(1)    = [F:DAT5]ACC
   [L]X_ACCNUM1(1) = [F:DAT5]ACCNUM
   Break
  Next
 Else : # Les autres référentiels saisissables....
  Filter [DAE7] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAE5]IDTLIN
  Read [DAE7] First
  Filter [DAE7]
  If !fstat
   [L]X_ACC1(IREF)    = [F:DAE7]ACC
   [L]X_ACCNUM1(IREF) = [F:DAE7]ACCNUM
  Else
   Filter [DAT7] Where TYP=[L]TYPPCE & NUM=[L]NUMPCE & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAT5]IDTLIN
   Read [DAT7] First
   Filter [DAT7]
   If !fstat
    [L]X_ACC1(IREF)    = [F:DAT7]ACC
    [L]X_ACCNUM1(IREF) = [F:DAT7]ACCNUM
   Endif
  Endif
 Endif
Next
Return


$RECH_ACCNUMES
# On stocke dans LETACCNUM l'accnum correspondant au compte d'effets escomptés mouvementé dans l'étape de remise intermédiaire
# On stocke dans LETACCNUM2 l'accnum correspondant au compte de dettes pour effets mouvementé dans l'étape de remise en banque
# L'accnum du compte de dettes pour effets est stocké dans PAYACCNUM
## 1/ On s'occupe d'abord du compte d'effets
Raz X_ACC1, X_ACCNUM1, X_ACC2, X_ACCNUM2
Filter [PAN2] Where NUM=[F:PYH]NUM & TYPNUM=3 & STA=8 & CPTBAN=2 & RVSACCNUM=0
Read [PAN2]PAN0 First
Filter [PAN2]
For IREF=1 To NBPLAN
 If IREF = 1 : # Référentiel général principal
  LETACCNUM = [F:PAN2]ACCNUM
  Read [DAE5]DAE2 = [L]LETACCNUM
  If !fstat
   [L]X_ACC1(1)    = [F:DAE5]ACC
   [L]X_ACCNUM1(1) = [L]LETACCNUM
  Else
   Read [DAT5]DAT1 = [L]LETACCNUM
   If !fstat
    [L]X_ACC1(1) = [F:DAT5]ACC
    [L]X_ACCNUM1(1) = [L]LETACCNUM
   Endif
  Endif
 Else : # Les autres référentiels saisissables....
  Filter [DAE7] Where TYP=[F:DAE5]TYP & NUM=[F:DAE5]NUM & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAE5]IDTLIN
  Read [DAE7] First
  Filter [DAE7]
  If !fstat
   [L]X_ACC1(IREF)    = [F:DAE7]ACC
   [L]X_ACCNUM1(IREF) = [F:DAE7]ACCNUM
  Else
   Filter [DAT7] Where TYP=[F:DAT5]TYP & NUM=[F:DAT5]NUM & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAT5]IDTLIN
   Read [DAT7] First
   Filter [DAT7]
   If !fstat
    [L]X_ACC1(IREF)    = [F:DAT7]ACC
    [L]X_ACCNUM1(IREF) = [F:DAT7]ACCNUM
   Endif
  Endif
 Endif
Next
## 2/ On s'occupe maintenant du compte de dettes pour effets
Filter [PAN2] Where NUM=[F:PYH]NUM & TYPNUM=3 & STA=-10 & ACCSTA=9 & CPTBAN=2 & RVSACCNUM=0
Read [PAN2]PAN0 First
Filter [PAN2]
If [F:PAN2]ACETYP=1 | [F:PAN2]ACETYP=0
 [L]LETACCNUM2 = [F:PAN2]ACCNUM
 Gosub RECH_ACCNUM
Elsif [F:PAN2]ACETYP = 2 | [F:PAN2]ACETYP = 3
 # Une pièce pour plusieurs règlements, l'ACCNUM est récupéré sous la table PAYACCNUMD
 Read [DAE5]DAE2 = [F:PAN2]ACCNUM
 If !fstat
  Filter [PMD] Where NUM=[F:PYH]NUM & ACCSTA=9 & RVSACCNUM=0 & TYP=[F:DAE5]TYP & VCRNUM=[F:DAE5]NUM & SNS=[F:DAE5]SNS
 Else
  Read [DAT5]DAT1 =[F:PAN2]ACCNUM
  Filter [PMD] Where NUM=[F:PYH]NUM & ACCSTA=9 & RVSACCNUM=0 & TYP=[F:DAT5]TYP & VCRNUM=[F:DAT5]NUM & SNS=[F:DAT5]SNS
 Endif
 Read [PMD]PMD0 First
 Filter [PMD]
 If !fstat
  [L]LETACCNUM2 = [F:PMD]ACCNUM
  Gosub RECH_ACCNUM
 Endif
Endif
Return

$RECH_ACCNUM
For IREF=1 To NBPLAN
 If IREF = 1 : # Référentiel général principal
  Read [DAE5]DAE2 = [L]LETACCNUM2
  If !fstat
   [L]X_ACC2(1)    = [F:DAE5]ACC
   [L]X_ACCNUM2(1) = [L]LETACCNUM2
  Else
   Read [DAT5]DAT1 = [L]LETACCNUM2
   If !fstat
    [L]X_ACC2(1) = [F:DAT5]ACC
    [L]X_ACCNUM2(1) = [L]LETACCNUM2
   Endif
  Endif
 Else : # Les autres référentiels saisissables....
  Filter [DAE7] Where TYP=[F:DAE5]TYP & NUM=[F:DAE5]NUM & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAE5]IDTLIN
  Read [DAE7] First
  Filter [DAE7]
  If !fstat
   [L]X_ACC2(IREF)    = [F:DAE7]ACC
   [L]X_ACCNUM2(IREF) = [F:DAE7]ACCNUM
  Else
   Filter [DAT7] Where TYP=[F:DAT5]TYP & NUM=[F:DAT5]NUM & LEDTYP=REFTYP(IREF) & IDTLIN=[F:DAT5]IDTLIN
   Read [DAT7] First
   Filter [DAT7]
   If !fstat
    [L]X_ACC2(IREF)    = [F:DAT7]ACC
    [L]X_ACCNUM2(IREF) = [F:DAT7]ACCNUM
   Endif
  Endif
 Endif
Next
Return


########
$TERMINE
########
If GSERVEUR : Return : Endif
If !NBREG : # Aucun règlement traité
 GERR=2 : GMESSAGE=mess(2,117,1)
Elsif [M:DIA]TRCFLG<>2
 # NBREG règlement(s) traité(s)
 GERR=2 : GMESSAGE=num$(NBREG)-mess(28,117,1)
Endif
Return

# Pour spécifiques Espagne et Portugal
$OUVRE
If !clalev([F:PAN])  : Local File PAYACCNUM  [PAN]   : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]   : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]   : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]   : Endif
If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]   : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]   : Endif
If !clalev([F:CAC])  : Local File GACCCODE   [CAC]   : Endif
If !clalev([F:GAU])  : Local File GAUTACE    [GAU]   : Endif
If !clalev([F:GAD])  : Local File GAUTACED   [GAD]   : Endif
If !clalev([M:HAE0]) : Local Mask GACCENT0   [HAE0]  : Endif
If !clalev([M:HAE1]) : Local Mask GACCENT1   [HAE1]  : Endif
If !clalev([M:HAE2]) : Local Mask GACCENT2   [HAE2]  : Endif
If !clalev([M:VTL])  : Local Mask VENTILE    [VTL]   : Endif
If !clalev([M:VT2])  : Local Mask VENTILE2   [VT2]   : Endif
If !clalev([M:HAEF]) : Local Mask GACCENTFMT [HAEF]  : Endif
If !clalev([M:HAEW]) : Local Mask GACCENTW   [HAEW]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]   : Endif
If clalev([F:PAN2])=0 : Local File PAYACCNUM  [PAN2] : Endif
If clalev([F:DAE5])=0 : Local File GACCENTRYD [DAE5] : Endif
If clalev([F:DAT5])=0 : Local File GACCTMPD   [DAT5] : Endif
If clalev([F:DAE7])=0 : Local File GACCENTRYD [DAE7] : Endif
If clalev([F:DAT7])=0 : Local File GACCTMPD   [DAT7] : Endif
If clalev([F:PMD])=0  : Local File PAYACCNUMD [PMD]  : Endif
Local Char TYPPCE(GLONGTE)
Local Char NUMPCE(GLONVCR)

Default Mask [HAE0] : Default Mask [HAE1] : Default Mask [HAE2]

Local Integer MAXECT, NPCE
MAXECT=max(100,dim([M:HAE2]ACC)) : NPCE=10
Local Char    LETTRE(30)(MAXECT), TYPPCE(GLONGTE)(NPCE), NUMPCE(GLONVCR)(NPCE)
Local Libelle STACUR
Local Integer XNBLET, XACCNUM(1..10), XDUDLIG(1..10), LETACCNUM, LETACCNUM2
Local Decimal XAMTIPT(1..10)
Return

###################################
## Etiquettes de l'écran VALPORT ##
###################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Local Integer ISITE
If [M]ALLCPY = 2 : mkstat = 1 : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 1 : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat | !(([F:TPY]STA3=2 & [F:TPY]UPDBIL>1) | [F:TPY]AUTACE10<>"")
 # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

########################################
Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If GBIDC1<>""
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP
 If dim(ZTYP)>0 : Affzo ZTYP : Endif
 Grizo ALLTYP, TYP
Else
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
End

######################################################################################

