#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GTC",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------#
$ACTION
Case ACTION
 When "LIBEL"     : Gosub LIBEL
 When "SETBOUT"   : If func OK_FINANCE : Gosub SETBOUT    : Endif
 When "ANNULE"    : If func OK_FINANCE : Gosub ANNULE     : Endif
 When "AP_CHANGE" : If func OK_FINANCE : Gosub AP_CHANGE  : Endif
 When "APRES_CRE" : If func OK_FINANCE : Gosub VALID      : Endif
 When "APRES_MOD" : If func OK_FINANCE : Gosub VALID      : Endif
 When "VALID"     : If func OK_FINANCE2([L]APPLI)
                     Gosub VALIDATION
                    Elsif find (CONSCOD,"CPT","SEC","NAT")
                     Raz CONSCOD
                    Endif
 When "TRCOP"     : If func OK_FINANCE : Gosub TRTCOP     : Endif
 When "OUVRE"     : If func OK_FINANCE : Gosub OUVRE      : Endif
 When "RAZCRE"    : If func OK_FINANCE : Raz [M:GRS] : Raz [F:GTC3] : Endif
Endcase
Return

#-----------------------------#
$LIBEL
If [M]CNSCOD="SMJ" | [M]CNSCOD="SMV"
   If GFCY <> GFCYDEF(7)
      GFCY =  GFCYDEF(7)
      Call GETCPY(GFCY,"",0,"") From TRTX3CPT
   Endif
   Case [F:AMZ]CODZON
        When "CCE1"
             [M]INTITFLD(NOL) = GCOLDIE(1)
        When "CCE2"
             [M]INTITFLD(NOL) = GCOLDIE(2)
        When "CCE3"
             [M]INTITFLD(NOL) = GCOLDIE(3)
        When "CCE4"
             [M]INTITFLD(NOL) = GCOLDIE(4)
        When "CCE5"
             [M]INTITFLD(NOL) = GCOLDIE(5)
        When "CCE6"
             [M]INTITFLD(NOL) = GCOLDIE(6)
        When "CCE7"
             [M]INTITFLD(NOL) = GCOLDIE(7)
        When "CCE8"
             [M]INTITFLD(NOL) = GCOLDIE(8)
        When "CCE9"
             [M]INTITFLD(NOL) = GCOLDIE(9)
        When "CCE10"
             [M]INTITFLD(NOL) = GCOLDIE(10)
        When "CCE11"
             [M]INTITFLD(NOL) = GCOLDIE(11)
        When "CCE12"
             [M]INTITFLD(NOL) = GCOLDIE(12)
        When "CCE13"
             [M]INTITFLD(NOL) = GCOLDIE(13)
        When "CCE14"
             [M]INTITFLD(NOL) = GCOLDIE(14)
        When "CCE15"
             [M]INTITFLD(NOL) = GCOLDIE(15)
        When "CCE16"
             [M]INTITFLD(NOL) = GCOLDIE(16)
        When "CCE17"
             [M]INTITFLD(NOL) = GCOLDIE(17)
        When "CCE18"
             [M]INTITFLD(NOL) = GCOLDIE(18)
        When "CCE19"
             [M]INTITFLD(NOL) = GCOLDIE(19)
        When "CCE20"
             [M]INTITFLD(NOL) = GCOLDIE(20)
   Endcase
Elsif [M]CNSCOD="BLA"
 Case left$([F:AMZ]CODZON,3)
  When "COM" : [M]INTITFLD(NOL) = mess(25,109,1)+right$([F:AMZ]CODZON,7) : # Compte
  When "SIT" : [M]INTITFLD(NOL) = mess(29,109,1)                         : # Site
  When "LIB" : [M]INTITFLD(NOL) = mess(30,109,1)+right$([F:AMZ]CODZON,4) : # Intitulé
  When "COL" : [M]INTITFLD(NOL) = mess(50,104,1)+right$([F:AMZ]CODZON,4) : # Montant
 Endcase
Elsif [M]CNSCOD="CSG"                                                 # hcb 74795 deb
 Case [F:AMZ]CODZON
      When "SDHNUM" : [M]INTITFLD(NOL) = mess(2,176,1)                  : # Numéro document
 Endcase                                                              # hcb 74795 fin

Elsif find([M]CNSCOD,"CPT","NAT","SEC")
 Read [GTC3]GTC3= [M]CNSCOD;[M]COD
 If !fstat
  [M:GRS] = [F:GTC3]
 Endif
Endif
Return

#-----------------------------#
$SETBOUT
If CLECUR & find([M]CNSCOD,"CPT","NAT","SEC")
 CHMEN +="4"
Endif
Return

#-----------------------------#
$OUVRE
If clalev([GTC3])=0 : Local File GTABACC3 [GTC3] : Endif
If clalev([GRS])=0  : Local Mask GRASOL [GRS]    : Endif
Return

#-----------------------------#
$ANNULE
If find([M]CNSCOD,"CPT","SEC","NAT")
 Call DELMSK("WM"+SUPP+CODE+"SOL",[L]APPLI) From MSKDIV
 If GOK<1 : Return : Endif
Endif
Return

#-----------------------------#
$AP_CHANGE
If find([M]CNSCOD,"CPT","SEC","NAT")
 Call TR_DELMSK("WM"+SUPP(0)+OCODE+"SOL",[L]APPLI) From MSKDIV
 If GOK<1 : Return : Endif
Endif
Return

#-----------------------------#
$VALID
[M:GRS]CNSCOD = [M:GTC1]CNSCOD
[M:GRS]COD = [M:GTC1]COD
Call DEBTRANS From GLOCK
Gosub TR1 From SAIGRASOL
If [F:GTC]ENAFLG<>2 & find([F:GTC]CNSCOD,"CPT","SEC","NAT")
 Call DELMSK("WM"+[F:GTC]CNSCOD+[F:GTC]COD+"SOL",nomap) From MSKDIV
Endif
Return

#-----------------------------#
$VALIDATION
If find(CNS,"CPT","SEC","NAT")
 Local Char MSKREF2(GLONAMK)
 If clalev([GTC3])=0 : Local File =APPLI+".GTABACC3" [GTC3] : Endif
 Read [GTC3]GTC3=CNS;COD
 If !fstat
  MSKREF2 = [F:AWI]NOMMSK(1)
  If MSKREF2<>""
   MASKD2 = "WM"+CNS+COD+"_"+num$(2)
   Gosub TR1
  Endif
 Endif
Endif
Return

$TR1
GOK=1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2]
 Call DELMSK(MASKD2,APPLI) From MSKDIV
 Read [AMK]CODMSK = MSKREF2
 [F:AMK2] = [F:AMK]
 [F:AMK2]CODMSK = MASKD2
 NCOL = find("NBLIG",[F:AMK2]BASPAG(0..dim([F:AMK2]BASPAG)-1))
 If !NCOL
  NCOL = find(1,[F:AMK2]TYPBLOC(0..dim([F:AMK2]TYPBLOC)-1))
 Endif
 If NCOL
  [F:AMK2]BLOCTYPT(NCOL-1) = [F:GTC3]REPGRAS
  [F:AMK2]BLOCTYPG(NCOL-1) = [F:GTC3]TYPGRAS
  [F:AMK2]BLOCPOSG(NCOL-1) = [F:GTC3]POSGRAS
  [F:AMK2]BLOCGDEF(NCOL-1) = [F:GTC3]DEFGRAS
  [F:AMK2]BLOCAFFD(NCOL-1) = [F:GTC3]AFFGRAS
  [F:AMK2]BLOCREPD(NCOL-1) = [F:GTC3]FSHGRAS
  [F:AMK2]ACTBLOC(NCOL-1)  = ""
 Endif
 [F:AMK2]MDL = 1
 Write [AMK2]
 If fstat
  GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
 Endif
 For [AMZ]CODZON Where CODMSK=MSKREF2
  [F:AMZ2] = [F:AMZ]
  [F:AMZ2]CODMSK = MASKD2
  If [F:AMK2]BLOCTYPT(NCOL-1)>1
   # 1 = Solde en devise de référentiel
   # 2 = Mvts et soldes en devise de référentiel
   # 3 = Soldes en devise de transaction
   # 4 = Mvts et soldes en devise de transaction
   OK = 0
   Case CNS
    When "CPT"
     If ( find([F:AMZ]CODZON,"SOLDEB","SOLCRE") & find([F:GTC3]TYPAMT,3,4) )
&     | ( find([F:AMZ]CODZON,"TOTDEB","TOTCRE") & [F:GTC3]TYPAMT=4 )
&     | ( find([F:AMZ]CODZON,"CTVSOLDEB","CTVSOLCRE") & find([F:GTC3]TYPAMT,1,2) )
&     | ( find([F:AMZ]CODZON,"CTVTOTDEB","CTVTOTCRE") & [F:GTC3]TYPAMT=2 )
      OK = 1
     Endif
    When Default
     If ( find([F:AMZ]CODZON,"SOLDEB","SOLCRE") & ([F:GTC3]TYPAMT2=1 | [F:GTC3]TYPAMT2=2) )
&     | ( find([F:AMZ]CODZON,"TOTDEB","TOTCRE") & [F:GTC3]TYPAMT2=2 )
      OK = 1
     Endif
   Endcase
   If OK
    [F:AMZ2]CHPARG = "G01:VALUE"
    [F:AMZ2]CHREPR = 1
   Endif
  Endif
  # Mettre le champ Date en invisible
  If [F:AMZ2]CODTYP="D"
   [F:AMZ2]SAIAFF = 3
  Endif
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
  # Ajout du champ libellé qui doit être alphanumérique => création de LIBDAT
  If [F:AMZ2]CODTYP="D"
   [F:AMZ2] = [F:AMZ]
   [F:AMZ2]CODMSK = MASKD2
   [F:AMZ2]CODZON = "LIBDAT"
   [F:AMZ2]CODTYP = "A"
   [F:AMZ2]LONG = 10
   [F:AMZ2]VALDEF = 'format$("D:"+GFMDAT,[M]DAT(nolign-1))'
   [F:AMZ2]CHPARG = "G03:LIB"
   Write [AMZ2]
   If fstat
    GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [AMA] Where TYPAFF=1 & CODAFF=MSKREF2
  [F:AMA2] = [F:AMA]
  [F:AMA2]CODAFF = MASKD2
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [AMP] Where TYPAFF=1 & CODAFF=MSKREF2
  [F:AMP2] = [F:AMP]
  [F:AMP2]CODAFF = MASKD2
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-----------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File GTABACC3 [GTC3]
Else
 Local File =[M]DOSORG+".GTABACC3"  [GTC3]
Endif
If [M]DOSDES=nomap
 Local File GTABACC3 [GTC4]
Else
 Local File =[M]DOSDES+".GTABACC3"  [GTC4]
Endif
Delete [GTC4] Where evalue(CRITERE)
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".GTABACC3" : Return
Elsif fstat>5
 GOK = 0 : Call RSTA("GTC4","") From GLOCK : Return
Endif
For [GTC3] Where evalue(CRITERE)
 [F:GTC4] = [F:GTC3]
 If dim([F:GTC4]UPDUSR)>0 : [F:GTC4]UPDUSR = GUSER : Endif
 If dim([F:GTC4]UPDDAT)>0 : [F:GTC4]UPDDAT = date$ : Endif
 If dim([F:GTC4]UPDTIM)>0 : [F:GTC4]UPDTIM = time : Endif
 Write [GTC4]
 If fstat
  GOK = 0 : Call FSTA("GTC4") From GLOCK : Break
 Endif
Next
Close Local File [GTC3], [GTC4]
Return

Funprog OK_FINANCE
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS]  : Endif
Read [F:ADS]DOSSIER=nomap
If !fstat & [F:ADS]MODULE(1)=2
 End 1
Else
 End 0
Endif
End

Funprog OK_FINANCE2(APPLI)
Value Char APPLI()
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS]  : Endif
Read [F:ADS]DOSSIER=[L]APPLI
If !fstat & [F:ADS]MODULE(1)=2
 End 1
Else
 End 0
Endif
End
