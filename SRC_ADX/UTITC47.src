#<AdxTL>@(#)5.0.0.0 $Revision$
##############################################################################
# UTITC47 : Control of subcontracting BOMs using UOM          Module TC      #
##############################################################################
# GA 31/01/13                                                 Bug 87021      #
##############################################################################

Call MAJ_UTITC47
End

##################################
Subprog MAJ_UTITC47
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTITC47([L]DOSSIER)
Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTITC47(DOSSIER)
Value Char DOSSIER
Call OUVRE_TRACE("UTITC47: Control of subcontracting BOMs using UOM") From LECFIC
Call ECR_TRACE("UTITC47 : Control of subcontracting BOMs using UOM Start on :"-[L]DOSSIER,0) From GESECRAN

Gosub CTL_BOMSTUCOE

Call ECR_TRACE("UTITC47 : Process End on :"-[L]DOSSIER,0) From GESECRAN
End

$CTL_BOMSTUCOE
Local File =DOSSIER+".BOMD"       [BOD]
Local File =DOSSIER+".BOM"        [BOH]
Local File =DOSSIER+".ITMMASTER"  [ITM]

Local Integer  WSIMFLG, WBOMALTTYP,WCPT
WBOMALTTYP=3 : WSIMFLG=2 : WCPT=0
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Trbegin [BOD]

Filter [BOH] Where BOMALTTYP=WBOMALTTYP
For [BOH]
   If [F:ITM]ITMREF<>[F:BOH]ITMREF
      Read [ITM]ITM0=[F:BOH]ITMREF : If fstat : Raz [F:ITM] : Endif
   Endif
   For [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALTTYP=[F:BOH]BOMALTTYP & BOMALT=[F:BOH]BOMALT & CPNTYP=7
       If dim([F:BOD]BOMUOM)>0 & [F:BOD]BOMSTUCOE=0
          If [F:BOD]BOMSTUCOE= 0 [F:BOD]BOMSTUCOE=1 : [F:BOD]BOMQTY=1 Endif
          If [F:BOD]BOMUOM="" [F:BOD]BOMUOM=[F:ITM]STU Endif
          Call ECR_TRACE("BOMD with Service not using BOMSTUCOE ="-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-[F:BOD]CPNITMREF-[F:ITM]STU-num$([F:BOD]BOMSTUCOE),0) From GESECRAN
          [F:BOD]UPDDAT=date$
          [F:BOD]UPDUSR=GUSER
          Rewrite [F:BOD]
      Elsif dim([F:BOD]BOMUOM)>0 & [F:BOD]LIKQTY=[F:BOD]BOMQTY & [F:BOD]BOMSTUCOE<>1
          If [F:BOD]BOMUOM<>[F:ITM]STU
             Call ECR_TRACE("BOMD with Service using UOM ="-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-[F:BOD]CPNITMREF-[F:BOD]BOMUOM-[F:ITM]STU,0) From GESECRAN
          Else
             Call ECR_TRACE("BOMD with Service using BOMSTUCOE ="-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-[F:BOD]CPNITMREF-[F:ITM]STU-num$([F:BOD]BOMSTUCOE),0) From GESECRAN
          Endif
          [F:BOD]BOMQTY = [F:BOD]BOMSTUCOE
          [F:BOD]BOMSTUCOE = arr([F:BOD]LIKQTY / [F:BOD]BOMQTY,10^-6)
          [F:BOD]UPDDAT=date$
          [F:BOD]UPDUSR=GUSER
          Rewrite [F:BOD]
          WCPT+=1
       Endif
   Next
Next
If WCPT>0
   Call ECR_TRACE("BOMD: Service using UOM lines updated ="-num$(WCPT),0) From GESECRAN
Endif

If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Simulation mode: Upgrade Rollbacked !!!",0) From GESECRAN
Else
   Commit
   Call ECR_TRACE("Real mode: Upgrade commited !!!",0) From GESECRAN
Endif

Close Local File [BOD]
Close Local File [BOH]
Close Local File [ITM]
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTITC47(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTITC47(APPLI)
End
