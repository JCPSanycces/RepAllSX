#<AdxTL>@(#)11.0.0.0 $Revision$
#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Paramétrage avancé
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD        Cle primaire:     Code de l'objet Xtend
#        ELTCODSUP     Cle secvondaire:  Type de l'objet Xtend (menu 7910)
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTADVPAR [AYU1]
Else
 Local File =[L]DOSORG+".AYTADVPAR"  [AYU1]
Endif
If [L]DOSDES=nomap
 Local File AYTADVPAR [AYU2]
Else
 Local File =[L]DOSDES+".AYTADVPAR"  [AYU2]
Endif

Read [AYU1]AYU0(3) = [L]FCYORG;val([L]ELTCODSUP);[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYU",[L]FCYORG-[L]ELTCOD-"~"-[L]ELTCODSUP) From GLOCK
  Goto FINALLY
Endif

Read [AYU2]AYU0(3) = [L]FCYDES;val([L]ELTCODSUP);[L]ELTCOD
DES_ELTCOD=[L]ELTCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYU1]
&              , [AYU2]
Return

$TR_COP
GOK = 1
Trbegin [AYU2]
 If DES_HASELT
     Delete [AYU2] Where FCYCOD=[L]FCYDES and OBJTYP=val([L]ELTCODSUP) and OBJCOD=[L]ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTSPE" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYU2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif

 For [AYU1]AYU0 Where FCYCOD=[L]FCYORG and OBJTYP=val([L]ELTCODSUP) and OBJCOD=[L]ELTCOD
  [F:AYU2] = [F:AYU1]
  [F:AYU2]FCYCOD = [L]FCYDES
  If OBJTYP=2   # Cas particulier du Site
    [F:AYU2]OBJCOD=[L]FCYDES
  Endif
  If GOK<1 : Break : Endif
  [F:AYU2]UPDUSR = GUSER
  [F:AYU2]UPDDAT = date$
  # [F:AYU2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYU2") From AYTCOP # 93575
  Write [AYU2]
  If fstat
   GOK=0 : Call FSTA("AYU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
