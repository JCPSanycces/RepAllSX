#<AdxTL>@(#)9.0.0.0 $Revision$
Raz [V]GPILOBJ
Call OBJET("VAC",GBIDC1,GBIDC2) From GOBJET
End

##############################################################################

$LIGNES
If !(SAVREP="" & GOK) : Return : Endif

# normalement !VERROU, sinon on n'a rien pu modifier sur les lignes
# si dim([L]MLOCK)>0 & MLOCK, on est déjà en modif (SAVREP="M")
# sinon il faut entrer en modif

REP = "M" : GREP = "M"
Gosub SETNOK From GOBJSUB
Gosub GRISE_CLE From =WINPROG
ACTION = "GRISE" : Gosub ACTION From GOBJSUB
Return

##############################################################################

$VERROU
OK=1
If [L]VERROU : Return : Endif

If dim([L]MLOCK)>0 & MLOCK
 Gosub VERROU From MLOCK
 If !VERROU
  Call ERREUR(GMESSAGE) From GESECRAN : GMESSAGE=""
  OK=0 : Return
 Endif
 OK=2
Else
 Gosub VERROU From GOBJET
 If ![L]VERROU
  # Modification en cours sur un autre poste
  Call ERREUR(mess(10,100,1)) From GESECRAN
  OK=0 : Return
 Endif
 OK=2
Endif
If OK=2
 Gosub RELIT From GOBJSUB
 Gosub SETBOUT From GOBJSUB
Endif
Return

##############################################################################

$MSGVERROU
OK=0
# OK=(dim([L]MACTION)>0)
Return

##############################################################################

$DEB_PICK
#If !VERROU
# OK=0 : GMESSAGE=mess(10,100,1) : # Modif en cours sur un autre poste
If   ![L]CLECUR & [L]REP<>"C" & !instr(1,[L]CHAINE,"C")
 OK=0 : GMESSAGE=mess(7,123,1) : # Création impossible
Elsif [L]CLECUR & [L]REP<>"M" & !instr(1,[L]CHAINE,"M")
 OK=0 : GMESSAGE=mess(9,123,1) : # Modification impossible
Elsif [L]CLECUR & !VERROU
 Gosub VERROU From GOBJET
 If !VERROU
  OK=0 : GMESSAGE=mess(10,100,1) : # Modif en cours sur un autre poste
 Else
  AFFICHE=0 : Gosub RELIT From GOBJSUB
  Gosub SETBOUT From GOBJSUB
  If (CLECUR & !instr(1,[L]CHAINE,"M")) or (!CLECUR & !instr(1,[L]CHAINE,"C"))
   Gosub DEVERROU From GOBJET
   AFFICHE=1 : Gosub AFFZONE From GOBJSUB
   If [L]CLECUR & !instr(1,[L]CHAINE,"M")
    GERR=1 : GMESSAGE=mess(9,123,1) : # Modification impossible
   Elsif ![L]CLECUR & !instr(1,[L]CHAINE,"C")
    GERR=1 : GMESSAGE=mess(7,123,1) : # Création impossible
   Endif
   OK=0
  Else
   OK=1
  Endif
 Endif
Endif
If OK & [L]REP=""
 If CLECUR : REP="M" : GREP="M"
 Else      : REP="C" : GREP="C"
 Endif
 Gosub SETNOK From GOBJSUB
 Gosub GRISE_CLE From =WINPROG
 ACTION = "GRISE" : Gosub ACTION From GOBJSUB
Endif
Return

$FIN_PICK
# Return
If !AFFICHE
 AFFICHE=1 : Gosub AFFZONE From GOBJSUB : OK=0
Endif
Return

###################################################
#
# Sous - programmes
#
###################################################

Subprog SUBSYM(CH1,I,CH2)
Value    Char CH1
Value    Integer I
Variable Char CH2
Local Integer J

J=instr(1,CH1,"\")
If I=1
 If !J : CH2=CH1
 Else  : CH2=left$(CH1,J-1)
 Endif
Else
 Call SUBSYM(right$(CH1,J+1),I-1,CH2)
Endif
End

####################################################

Subprog DELOCKBUT(RACINE,EXCEPT)
Value Char RACINE, EXCEPT

Local File APLLCK [LKK]
Trbegin [LKK]
#Delete [LKK] Where LCKPID=adxuid(2) & left$(LCKSYM,len([L]RACINE))=[L]RACINE
#&                & LCKSYM<>[L]EXCEPT
For [LKK] Where LCKPID=adxuid(2) & left$(LCKSYM,len([L]RACINE))=[L]RACINE
&                & LCKSYM<>[L]EXCEPT
 Delete [LKK] Curr
Next LKK
Commit
Close Local File [LKK]
End


####################################################

Subprog TESTLOCK(SYMBOLE,VERROU)
Value    Char    SYMBOLE
Variable Integer VERROU

Local File APLLCK [LKK]
Read [LKK]LCKCLE = SYMBOLE;0
If !fstat & [F:LKK]LCKPID=adxuid(2)
 VERROU = 1
Else
 VERROU=0
Endif
Close Local File [LKK]
End


####################################################

Subprog VERFLOCK(SYMBOLE)
Value    Char    SYMBOLE()

GLOCK=""
Local File =adxtlk [ALK]
For [ALK] Where left$(LCKSYM,len([L]SYMBOLE))=[L]SYMBOLE & [F:ALK]LCKPID<>adxuid(2)
 If dim([L]NBUSR)<0
  Local Integer I , NBUSR
  Local Char TBUSR(12)(1..2000) , PROCESS(20)
  If func ASESSIONS.ISMNGSESSIONS
   Call LIST_UID(TBUSR,NBUSR) From ASESSIONS
  Else
   Local Char SID(12) , SCLI(80) , SUSR(30) , SUID(12)
   Local File (SID,SCLI,SUSR,SUID) From System adxmac(0)+"@psadx -ig" As [SYS_]
   NBUSR = 0
   For [SYS_]
    NBUSR += 1 : TBUSR(NBUSR) = [F:SYS_]SUID
   Next SYS_
   Close Local File [SYS_]
  Endif
 Endif
 PROCESS = num$([F:ALK]LCKPID)
 For I=1 To NBUSR
  If TBUSR(I)=PROCESS
   GLOCK="%"+[F:ALK]LCKSYM : Break (2)
  Endif
 Next I
Next
End

