#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
 When "EXPORT" : Gosub EXPORT
 When Default
Endcase
Return

$EXPORT
# Décomposition de la nature transaction
GIMP(1)=mid$([F:DEB]EECNAT,2,1)
GIMP(2)=mid$([F:DEB]EECNAT,3,1)
If dim(GDEBGBR)>0 & GDEBGBR=1
   GIMP(1)=left$([F:DEB]EECNAT,1)
   GIMP(2)=mid$([F:DEB]EECNAT,2,1)
Endif
# Condition de livraison = Incoterm + Lieu de transport
GIMP(3)=[F:DEB]EECICT+num$([F:DEB]EECLOC)
Return
