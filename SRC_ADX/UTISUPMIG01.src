#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTISUPMIG01 Reprise de CONTACTCRM.CNTMOB dans CONTACT.MOB    Module Sup#
#                                                                        #
##########################################################################
# FGR 27/01/2012 : X3SUIVI78316
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat THEN
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_SUPMIG01(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_SUPMIG01(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE

  IERR = 0
  Call ECR_TRACE("SUPMIG01: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # ------------------------------------------------------------------------
  If filinfo(filpath("FIL", "CONTACT", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".CONTACT" [CNT] Where MOB = ""
  #
  If filinfo(filpath("FIL", "CONTACTCRM", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".CONTACTCRM" [AIN]
  # ------------------------------------------------------------------------
  IUPDATE = 0
  If rowcount([F:CNT]) > 0 Then
    Raz [F:AIN]
    Trbegin [CNT]
    For [CNT]CNT1
      If [F:CNT]MOB = "" Then
        # --------------------------
        If [F:AIN]CNTNUM <> [F:CNT]CCNCRM Then
          Read [F:AIN]AIN0=[F:CNT]CCNCRM
          If fstat Then
            Raz [F:AIN]
          Endif
        Endif
        # --------------------------
        If [F:AIN]CNTMOB <> "" Then
          [F:CNT]MOB = [F:AIN]CNTMOB
          Rewrite [F:CNT]
          If fstat Then
            Call ECR_TRACE("File CONTACT : " - num$([F:CNT]BPATYP) - [F:CNT]BPANUM - [F:CNT]CCNCRM + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
          IUPDATE += 1
        Endif
        # --------------------------
      Endif
    Next
    If IERR = 0 Then
      Commit
      Call ECR_TRACE(num$(IUPDATE) - "contacts updated", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("Error during the process. No contact updated", 0) From GESECRAN
    Endif
  Endif
  Close Local File [CNT]
  Close Local File [AIN]
  # ------------------------------------------------------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat THEN
    Raz [F:ADS]
  Endif
  Call MAJ_SUPMIG01(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  Call MAJ_SUPMIG01(APPLI)
End



