#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "LIENS"         : Gosub LIENS
  When "MODIF"         : Gosub MODIF
  When "CREATION"      : Gosub CREATION
  When "FILTRE"        : Gosub FILTRE
  When "ANNULE"        : Gosub ANNULE
  Endcase

Return

$OUVRE
  If clalev([F:CTRNA]) = 0 : Local File EMPLOCTRNA [CTRNA] : Endif

Return

$LIENS
  If GCURLEG<>"USA" : Return : Endif

  Read [CTRNA]CTRNA0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
  If fstat = 0
    [M:CTR5] = [F:CTRNA]
    [M:CTR1] = [F:CTRNA]
    [M:CTR4] = [F:CTRNA]
  Endif

Return

$MODIF
$CREATION
  If GCURLEG<>"USA" : Return : Endif

  Delete [CTRNA] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
  If fstat = 1
    GOK = -1
    GLOCK = "$CTRNA" - [M]CTRNUM - [M]REFNUM - [M]CTRDAT
    Return
  Elsif fstat>5
    GOK = 0
    Call RSTA("CTRNA", [M]REFNUM - [M]CTRNUM - [M]CTRDAT) From GLOCK
    Return
  Endif

  [F:CTRNA] = [M:CTR0]
  [F:CTRNA] = [M:CTR5]
  [F:CTRNA] = [M:CTR1]#FRLAA - 2015-03-25 - REQUIREMENT 104631 US 3195
  [F:CTRNA] = [M:CTR4]

  Write [CTRNA]
  If fstat
    GOK = 0 : Return
  Endif

Return

$ANNULE
 Delete [CTRNA] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("CTRNA",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
 Endif

Return

$FILTRE
  If GCURLEG<>"USA" : Return : Endif

  If clalev([F:CTRNA]) = 0 : Local File EMPLOCTRNA [CTRNA] : Endif
  If [F:HRCTR]REFNUM <> [F:CTRNA]REFNUM or [F:HRCTR]CTRNUM <> [F:CTRNA]CTRNUM or [F:HRCTR]CTRDAT <> [F:CTRNA]CTRDAT
    If dim([M]CTRNUM)>0 & dim([M]REFNUM)>0 & dim([M]CTRDAT)>0 Then
      Read [CTRNA]CTRNA0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
    Endif
  Endif

Return

