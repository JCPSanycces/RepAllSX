#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## ACLA-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 121

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "LINES"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("BSICODTC","$namProParent","BSICODTC")
    this.BSICODTC = this.APARENT.BSICODTC
    [L]ASTATUS = fmet this.ASETATTRIBUTE("BAN","$namProParent","BAN")
    this.BAN = this.APARENT.BAN
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "BSICODTC" : Gosub PRO_BSICODTC
 When "BAN" : Gosub PRO_BAN
Endcase
Return

#-------------------------------------------------------#
$PRO_BSICODTC
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.LINES)
   If this.LINES([L]ALINE)<>null
    this.LINES([L]ALINE).BSICODTC = this.BSICODTC
   Endif
  Next
Endcase
Return

#-------------------------------------------------------#
$PRO_BAN
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.LINES)
   If this.LINES([L]ALINE)<>null
    this.LINES([L]ALINE).BAN = this.BAN
   Endif
  Next
Endcase
Return



