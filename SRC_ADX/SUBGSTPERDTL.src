#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Handling of screen GSTPERDTL : GST reporting periods preview details (for Australian GST reporting)
# Author : Bader
# History:
# 2018-02-26 Bader check for screen overflow
# 2018-03-06 Bader use table DCLVATBOXDBD instead of GSTDTL
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
Endcase
Return


#######################################################################################
$OUVRE
#If !clalev([F:GSTD])  Local File GSTDTL   [GSTD] Endif
If !clalev([F:DLVBD]) Local File DCLVATBOXDBD   [DLVBD] Endif
If !clalev([F:SIH])   Local File SINVOICE [SIH] Endif
If !clalev([F:PIH])   Local File PINVOICE [PIH] Endif

#Local Char PCPY(GLONCPY), PGSTPERCOD(10), PTYP(5)
Local Char PCPY(GLONCPY), PTYP(5)
Local Integer PGSTPERCOD
PCPY        = PARAM(1)
PGSTPERCOD  = val(PARAM(2))
PTYP        = PARAM(3)
Return


#######################################################################################
$DEBUT
Local Integer MAXLINES, OVERFLOW
Raz [M:GSTPD]
Filter [F:DLVBD] Where NUMRPT = [L]PGSTPERCOD and CPY = [L]PCPY and VATBOX = [L]PTYP
[L]MAXLINES = dim([M:GSTPD]LIN)
Raz [L]OVERFLOW
[S]nolign = 0
For [F:DLVBD]
    If nolign >= [L]MAXLINES   # check for screen overflow
      [L]OVERFLOW = 1
      Break
    Endif
    [S]nolign += 1
    [M:GSTPD] = [F:DLVBD]
Next
[M:GSTPD]NBLIG = nolign
If [L]OVERFLOW
    Infbox mess(56,176,1)-num$([L]MAXLINES)
Endif
Filter [F:DLVBD]
Affzo [M:GSTPD]
Return


