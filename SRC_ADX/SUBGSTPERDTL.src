######################################################################################
Subprog IB_NBLIG
GBOUT1 = mess(1,267,1)+"/"+mess(2,267,1)
GBOUT2 = mess(8,2684,1)
End


######################################################################################
Subprog B1_NBLIG
Local Char VALC1(20), VALC2(20), VALC3(20)
[L]VALC3 = ""
[L]VALC2 = [M:GSTPD]NUM(nolign-1)
# first try to find BIC/SIH invoice
Call LECTURE("BIC", [L]VALC2, "") From CONTOBJ
If fstat = 0 Then
    If [F:SIH]ORIMOD = 3 Then
        [L]VALC1 = "BIC"
    Else
        [L]VALC1 = "SIH"
    Endif
Else      # not found > try to find BIS/PIH invoice
    Call LECTURE("BIS", [L]VALC2, "") From CONTOBJ
    If fstat = 0 Then
        If [F:PIH]ORIMOD = 3 Then
            [L]VALC1 = "BIS"
        Elsif [F:PIH]ORIMOD = 6
            [L]VALC1 = "PIH"
        Endif
    Else
        Infbox mess(53,7999,1)-"("+[L]VALC2-mess(40,9016,1)+")"
    Endif
Endif
If fstat = 0 Call OBJET([L]VALC1, [L]VALC2, [L]VALC3) From GOBJET Endif
End


######################################################################################
Subprog B2_NBLIG
Local Char VALC1(20), VALC2(20), VALC3(20)
[L]VALC2 = [M:GSTPD]NUM(nolign-1)
[L]VALC1 = "GAS"
# first try to find BIC/SIH invoice
Call LECTURE("BIC", [L]VALC2, "") From CONTOBJ
If fstat = 0 Then
    [L]VALC3 = [F:SIH]GTE
Else      # not found > try to find BIS/PIH invoice
    Call LECTURE("BIS", [L]VALC2, "") From CONTOBJ
    If fstat = 0 Then
        [L]VALC3 = [F:PIH]GTE
    Else
        If !clalev ([F:HAE]) : Local File GACCENTRY [HAE] : Endif
        Filter [F:HAE] Where NUM = [L]VALC2
        Read [F:HAE] First
        If fstat = 0
            [L]VALC3 = [F:HAE]TYP
        Endif
        Filter [F:HAE]
    Endif
Endif
If fstat = 0 Call OBJET([L]VALC1, [L]VALC2, [L]VALC3) From GOBJET Endif
End


######################################################################################

