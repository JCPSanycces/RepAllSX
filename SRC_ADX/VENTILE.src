#
# Issue X3-57738 - 2017-10-18 by CBO : Year end interface - Forced ledger amount on analytical table
#

##########################################################################################
####  Subprog ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVA)
####  Subprog CHARGE_VTE(RPA,UOM,CNA,ACC)
##########################################################################################
Subprog ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVA)
Variable Decimal PTV()
Variable Decimal PTF()
Value    Integer NBPTV
Value    Integer PTVD
Value    Integer PTVA
Local Integer I

# Issue X3-57738
If GFONCTION = "FIYEND"
  Dela PTVD,PTVA,[M:VT2]PTVENT [M:VT2]TBAMT,[M:VT2]TBAMTLED,[M:VT2]TBQTY
&   ,[M:VT2]TBCCE1,[M:VT2]TBCCE2,[M:VT2]TBCCE3,[M:VT2]TBCCE4,[M:VT2]TBCCE5
&   ,[M:VT2]TBCCE6,[M:VT2]TBCCE7,[M:VT2]TBCCE8,[M:VT2]TBCCE9,[M:VT2]TBCCE10
&   ,[M:VT2]TBCCE11,[M:VT2]TBCCE12,[M:VT2]TBCCE13,[M:VT2]TBCCE14,[M:VT2]TBCCE15
&   ,[M:VT2]TBCCE16,[M:VT2]TBCCE17,[M:VT2]TBCCE18,[M:VT2]TBCCE19,[M:VT2]TBCCE20
Else
  Dela PTVD,PTVA,[M:VT2]PTVENT [M:VT2]TBAMT,[M:VT2]TBQTY
&   ,[M:VT2]TBCCE1,[M:VT2]TBCCE2,[M:VT2]TBCCE3,[M:VT2]TBCCE4,[M:VT2]TBCCE5
&   ,[M:VT2]TBCCE6,[M:VT2]TBCCE7,[M:VT2]TBCCE8,[M:VT2]TBCCE9,[M:VT2]TBCCE10
&   ,[M:VT2]TBCCE11,[M:VT2]TBCCE12,[M:VT2]TBCCE13,[M:VT2]TBCCE14,[M:VT2]TBCCE15
&   ,[M:VT2]TBCCE16,[M:VT2]TBCCE17,[M:VT2]TBCCE18,[M:VT2]TBCCE19,[M:VT2]TBCCE20
Endif
[M:VT2]PTVENT -= PTVA
For I=0 To NBPTV-1
 If PTV(I) > PTVD
  PTV(I) -= PTVA : PTF(I) -= PTVA
 Endif
Next I
End

##########################################################################################
Subprog CHARGE_VTE(RPA,UOM)
Value Char    RPA() :     # Code répartition
Value Char    UOM() :     # Unité d'oeuvre
#Value Char    LED() :     # Liste codes référentiels séparés par des ;
#Value Char    ACC() :     # Liste des Comptes séparé par des ;
#Value Char    DIE() :     # Liste des Axes séparé par des ;

Local Integer I, J, K
Goto VTE

##########################################################################################
Subprog CHARGE_VTE_STR(RPA,UOM,LED,ACC,DIE)
Value Char    RPA() :     # Code répartition
Value Char    UOM() :     # Unité d'oeuvre
Value Char    LED() :     # Liste codes référentiels séparés par des ;
Value Char    ACC() :     # Liste des Comptes séparé par des ;
Value Char    DIE() :     # Liste des Axes séparé par des ;

Local Integer I, J, K, IND, NBAXE
Local Char    WDIE(GLONDIE)

Raz [M:VTL]LED, [M:VTL]ACC, [M:VTL]DIE
[M:VTL]BAS = 0

# Raz [M:VTL]  #Ajouter le 08/04/09
# F56965 : Pas de Raz du masque car les zones du masque TOTREP & QTOTREP sont initialisées avant l'appel.

## Identifie le nombre de référentiel à gérer
I = instr(1,[L]LED,";")
If !I
 [M:VTL]NBLED  = 1
 [M:VTL]LED(0) = [L]LED
 [M:VTL]ACC(0) = [L]ACC
Else
 Raz [M:VTL]NBLED
 While [L]LED<>""
  I = instr(1,[L]LED,";")
  J = instr(1,[L]ACC,";")
  If I
   [M:VTL]LED([M:VTL]NBLED) = left$([L]LED,I-1) : [L]LED = vireblc(right$(LED,I+1),2)
   [M:VTL]ACC([M:VTL]NBLED) = left$([L]ACC,J-1) : [L]ACC = vireblc(right$(ACC,J+1),2)
  Else
   [M:VTL]LED([M:VTL]NBLED) = [L]LED : [L]LED = ""
   [M:VTL]ACC([M:VTL]NBLED) = [L]ACC : [L]ACC = ""
  Endif
  [M:VTL]NBLED += 1
 Wend
Endif

## Identifie le nombre des axes à gérer
Raz [L]NBAXE
I = instr(1,[L]DIE,";")
If I
 While [L]DIE<>""
  I = instr(1,[L]DIE,";")
  If I
   [M:VTL]DIE([L]NBAXE) = left$([L]DIE,I-1) : [L]DIE = vireblc(right$(DIE,I+1),2)
  Else
   [M:VTL]DIE([L]NBAXE) = [L]DIE : [L]DIE = ""
  Endif
  If !GIMPORT
   Call LECTEXTRA([M:VTL]INTDIE([L]NBAXE),"GDIE","COLHEA",[M:VTL]DIE([L]NBAXE),"") From ATEXTRA
  Endif
  Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
  [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
  [L]NBAXE += 1
 Wend
Else
 For I=1 To [M:VTL]NBLED
  Call INDLED([M:VTL]LED(I-1),"",IND,K) From CPTDIV
  If IND
   For J=1 To GLEDDIENBR(IND)
    WDIE = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
    If !find(WDIE,[M:VTL]DIE(0..[L]NBAXE-1))
     [M:VTL]DIE([L]NBAXE) = WDIE
     If !GIMPORT
      Call LECTEXTRA([M:VTL]INTDIE([L]NBAXE),"GDIE","COLHEA",[M:VTL]DIE([L]NBAXE),"") From ATEXTRA
     Endif
     Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
     [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
     [L]NBAXE+=1
    Endif
   Next
  Endif
 Next
Endif
[M:VTL]NBAXE=[L]NBAXE
Goto VTE

$VTE
Local Decimal SUMP , SUMPOI , AROQTE
Local Integer SUIVI
Local Char    WAXE(GLONDIE)(1..1)

If !clalev([F:DSP]) : Local File =GTABCPT+"CADSP" [DSP] : Endif
If !clalev([F:TUN]) : Local File TABUNIT [TUN] : Endif

Call LEC_TUN([L]UOM) From CPTLEC
AROQTE = 10^(-[F:TUN]UOMDEC)

Raz SUMPOI, SUMP
Raz I
For [DSP]DSP0 Where DSP=[L]RPA
 I += 1
 For J=1 To [M:VTL]NBAXE
  Assign "[M:VTL]CCE"+num$(J)+"("+num$(I-1)+")" With ""  # Lien 56965
  For K=1 To [F:DSP]NBRDIE : # dim([F:DSP]DIE)
   If evalue("[F:DSP]DIE("+num$(K-1)+")")=evalue("[M:VTL]DIE("+num$(J-1)+")") : Break : Endif
  Next K
  If K<=[F:DSP]NBRDIE
   ## On regarde si les comptes ont un suivi sur cet axe
   If dim(GSTRTYP)>0 & dim(GNBSTR)>0 & dim(GSTRCOA)>0 & dim(GSTRACC)>0 & GNBSTR>0
    WAXE = evalue("[F:DSP]DIE("+num$(K-1)+")")
    Call SUIVI_ANA(GSOCIETE,GSTRTYP,GNBSTR,GSTRCOA,GSTRACC,WAXE,1,SUIVI) From CPTDIV
   Else
    SUIVI=1 :# On force l'initialisation des sections (65977)
   Endif
   If SUIVI
    Assign "[M:VTL]CCE"+num$(J)+"("+num$(I-1)+")" With evalue("[F:DSP]CCE"+num$(K))
   Endif
  Endif
 Next J
 [M:VTL]PRC(I-1) = [F:DSP]COE
 SUMPOI += [F:DSP]COE
 [M:VTL]BAS += 1
 If I>=GMAXVANA : Break : Endif
Next

# Demande de point d'entrée 23290 pour prendre en compte le contexte d'appel
GPOINT = "MAJDSP" : Gosub ENTREE From EXEFNC

If SUMPOI<>0
 For I=0 To [M:VTL]BAS-1
  [M:VTL]AMT(I) = arr([M:VTL]TOTREP*(SUMP+[M:VTL]PRC(I))/SUMPOI,[F:TCU]CURRND)
&            -arr([M:VTL]TOTREP*SUMP/SUMPOI,[F:TCU]CURRND)
  [M:VTL]QTY(I) = arr([M:VTL]QTOTREP*(SUMP+[M:VTL]PRC(I))/SUMPOI,AROQTE)
&            -arr([M:VTL]QTOTREP*SUMP/SUMPOI,AROQTE)
  SUMP += [M:VTL]PRC(I)
  If [M:VTL]TOTREP<>0
   [M:VTL]PRC(I) = ar2([M:VTL]AMT(I)*100/[M:VTL]TOTREP)
  Endif
 Next I
Endif
End

