#<AdxTL>@(#)7.0.0.0 $Revision$
#############################################
##  Default dimension integration
#############################################

$SECTION
## Only imported in a X3 folder 
Gosub TSTSUP
If !OK
 Gosub FIN_OBJ From PATCH
 Goto FIN_GAU
Endif

Call DEBTRANS From GLOCK
Gosub TR_CDE

FIN_GAU
Close Local File [CDE], [DIE], [CDE1]
Return

$TSTSUP
OK = 0
If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0)>=0
 Local File =APPLI+".CACCEDEF" [CDE]  : # This class contains imported records
 Local File =APPLI+".CACCEDEF" [CDE1] : # This class contains records to write or rewrite
 Local File =APPLI+".GDIE"     [DIE]
Endif
# Integration in a X3 folder
If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>=0
 OK = 1 : Return
Endif
# Integration in a test folder
Read [ADW]ADW0 = "";"";"TEST"
If !fstat & val([F:ADW]VALEUR)=2
 OK = 1 : Return
Endif
# Integration if the patch's name begins with "src"
If pat(toupper(TRAIT(P)),"SRC*")
 OK = 1 : Return
Endif
# Si l'objet est spécifique on intègre
If find(left$(NOMOBJ,1),"X","Y","Z")
 OK = 1 : Return
Endif
Return

$TR_CDE
Trbegin [CDE]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Normal end
    Break
   When 3 : 
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "DIV"   : Gosub CDE
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit

Gosub SAV_OPENI From PATCH
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Gosub REST_OPENI From PATCH
Return

$ABORT
Rollback
Return

$CDE
FICHIER = "CACCEDEF" : ABR = "CDE"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = [F:CDE]MODULE
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
Read [CDE1]CDE0=[F:CDE]COD;[F:CDE]CPY
If fstat
 NEWOBJ = 1
Else
 NEWOBJ = 0
Endif

If NEWOBJ
 Raz [F:CDE1]
 [F:CDE1]COD = [F:CDE]COD
 For J=0 To dim([F:CDE]DIE)-1
  Raz [F:CDE1]DIE(J)
  Assign "[F:CDE1]CCE"+num$(J+1)+"("+num$(0)+")" With 0
  Assign "[F:CDE1]CCE"+num$(J+1)+"("+num$(1)+")" With 0
  Assign "[F:CDE1]CCE"+num$(J+1)+"("+num$(2)+")" With 0
  Assign "[F:CDE1]CCE"+num$(J+1)+"("+num$(3)+")" With 0
  Assign "[F:CDE1]CCE"+num$(J+1)+"("+num$(4)+")" With 0
 Next
 For J=0 To dim([F:CDE]DIE)-1
  If [F:CDE]DIE(J)<>""
   Read [DIE]DIE0 = [F:CDE]DIE(J)
   If !fstat
    [F:CDE1]DIE([F:CDE1]NBRDIE) = [F:CDE]DIE(J)  
    For K=0 To dim([F:CDE]CCE1)-1
     Assign "[F:CDE1]CCE"+num$([F:CDE1]NBRDIE+1)+"("+num$(K)+")" With evalue("[F:CDE]CCE"+num$(J+1)+"("+num$(K)+")")
    Next
    [F:CDE1]NBRDIE += 1
   Endif
  Endif
 Next 
[F:CDE1]NBLIG=[F:CDE]NBLIG
 Gosub COPY_FIELD
 Write [CDE1]
Else
 # We don't change the dimension views and the dimension types
 Gosub COPY_FIELD
 Rewrite [CDE1]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "CACCEDEF"-[F:CDE]COD : Return
Endif
Return

$COPY_FIELD
[F:CDE1]CPY    = [F:CDE]CPY
[F:CDE1]DES    = [F:CDE]DES
[F:CDE1]DESSHO = [F:CDE]DESSHO
[F:CDE1]MODULE = [F:CDE]MODULE
For K=0 To dim([F:CDE]FLD)-1
 [F:CDE1]FLD(K)= [F:CDE]FLD(K)
Next
Return
