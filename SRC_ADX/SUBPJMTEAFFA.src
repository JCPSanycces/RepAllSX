  #&                                                              [M:PTEAFF]OPPNUM(nolign-1),
  #&                                                              [M:PTEAFF]PTEDAT(nolign-1),
  #&                                                              [M:PTEAFF]PTESEQ(nolign-1))
  SARENDRE = func PJMTIMEMP_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PTEH]CLB, [M:PTEAFF]PTESEQ(nolign-1))
  # Issue X3-69372 - 2018-04-20 by FGR : END
