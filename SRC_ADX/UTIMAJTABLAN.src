#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Modify all records of TABLAn where ISOLAN contains _ by -
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Modify all records of TABLAn where ISOLAN contains _ by -") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File TABLAN [TLA]
Else
 Local File =DOSSIER+".TABLAN" [TLA]
Endif

Gosub MAJTABLAN

Close Local File [TLA]
End

#----------------------------------------------------------------------------------------#
$MAJTABLAN
Local Integer POS
Trbegin [TLA]
 For [TLA] Where pat([TLA]LANISO,"*_*")>0
  POS = instr(1,[TLA]LANISO,"_")
  If POS>0
   [F:TLA]LANISO = left$([TLA]LANISO,POS-1)+"-"+right$([TLA]LANISO,POS+1)
   Rewrite [F:TLA]
   If fstat
    Call ERREUR("TLA"-[F:TLA]LAN,2) From DOSDIC
   Endif
  Endif
 Next
Commit
Return

#----------------------------------------------------------------------------------------#
