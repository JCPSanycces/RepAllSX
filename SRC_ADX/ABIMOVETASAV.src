#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIMOVETA","ABIMOVETA",3,"") From GTRAITE
End

##############################################################################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "INIT_DIA"     : Gosub INIT_DIA
 When "EXEC"         : Gosub EXEC
Endcase
Return

$INIT
Local File ABIDATWRH [ABW]
Local File ABIDATMRT [ABM]
Local Integer STAT
Return

$INIT_DIA
If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif
[M]DATAW="ZDATAW"
[M]DATAM="ZUSER"
Return

$EXEC
If GINFO
 Call OUVRE_VLC(mess(137,148,1),"","") From GESECRAN   : # Mise en livraison
Endif
Call MOVETA(nomap,[M:DIA]DATAW,[M:DIA]DATAM,[M:DIA]LAN,[M:DIA]SIMU,STAT)
If GINFO
 Call FERME_VLC From GESECRAN
Endif
TRA=1
Return

Subprog MOVETA(APPLI,DATAW,DATAM,DATALAN,SIMU,STAT)
Value Char       APPLI
Value Char       DATAW
Value Char       DATAM
Value Char       DATALAN
Value Integer    SIMU
Variable Integer STAT
# Variable Locales
Local Char    LIGNE(250),PORT(250),SERVEUR(250)
Local Integer OK,ERR
#
If !GSERVEUR
 Call OUVRE_TRACE(mess(137,148,1)) From LECFIC : # Mise en livraison
Else
 Call ECR_TRACE(mess(137,148,1),0) From GESECRAN
Endif
OK =1
Gosub OUVRE_TABLE From ABICREUNV                 : # Ouverture tables
If OK=0 : Goto ERREUR : Endif
Gosub DECLARE                                    : # Declaration variables
If OK=0 : Goto ERREUR : Endif
Gosub CREE_TOOL                                  : # CRéATION du fichier Tool
If OK=0 : Goto ERREUR : Endif
BALISE = 1 : OK =1
Gosub CRE_LIST_ETA From SUBATV2                  : # Mise en variable des etats du refrentiel
Gosub LISTE_SOLUTION                             : # Liste  des etats du repertoire lan de la solution
If [L]I_NBETAT =0
 Call ECR_TRACE(mess(92,148,1),0) From GESECRAN  : #  : Aucun états trouvés dans l'Infoview
Else
 Gosub LISTE_ALL                                  : # Liste  des etats du repertoire ALL de la livraison
 Gosub LISTE_DOSSIER_UNV                         : # Mis ene variable des univers
 Gosub FIND_DOSSIER_UNV                           : # recup des id et cuid des repertoires ALL et SOL des univers.
 If OK=0 : Goto ERREUR : Endif
 Gosub LISTE_MOUVEMENTS
 If SIMU <> 2
  Call OUINON("Voulez_vous mettre a jour le réfenretiel ?",GBIDI1) From GESECRAN
  If GBIDI1<>2 : Goto FIN : Endif
 Endif
 If SIMU<>2
  Gosub MOVE_ETAT                                  : # Deplacement des etats et univers
  If OK=0 : Goto ERREUR : Endif
 Endif
Endif
$FIN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$ERREUR
End
Gosub COP_FICHIER From SUBATV2
Gosub EFF_FICHIER From SUBATV2
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$ERREURS
ER = errn
If GTRACE
 Call ECR_TRACE(errm-errmes$(errn),errn) From GESECRAN
Endif
Goto ERREUR


#------------------------------------------------------------------------------------#
#  Creation de la liste des mouvements a faire (sas, mov ou cop) des états ou univers
#------------------------------------------------------------------------------------#
$LISTE_MOUVEMENTS
Call ECR_TRACE("",0) From GESECRAN
Local Char     MOV_COD(3)(1..100)
Local Char     MOV_TYP(3)(1..100)
Local Char     MOV_OBJID(60)(1..100)
Local Char     MOV_DOSIDDES(20)(1..100)
Local Char     MOV_OBJNAM(80)(1..100)
Local Integer  NBMOV

# 1) Copies des états de FRA vers ALL
Raz NBMOV
For I=1 To [L]I_NBETAT
 [L]NBMOV+=1
 [L]MOV_TYP(NBMOV)      = "e"
 [L]MOV_COD(NBMOV)      = "sas"
 [L]MOV_OBJID(NBMOV)    = [L]I_ETATID(I)
 [L]MOV_DOSIDDES(NBMOV) = [L]A_DOSETATID_ALL
 [L]MOV_OBJNAM(NBMOV)   = [L]I_ETAT(I)
Next I

# 2 ) Suppression des états obsoletes
For I=1 To [L]A_NBETAT
 EXISTE = 0
 For J=1 To [L]I_NBETAT
  If [L]I_ETAT(J)=[L]A_ETAT(I)
   EXISTE = 1
   Break
  Endif
 Next
 If !EXISTE
  [L]NBMOV+=1
  [L]MOV_TYP(NBMOV)      = "e"
  [L]MOV_COD(NBMOV)      = "del"
  [L]MOV_OBJID(NBMOV)    = [L]A_ETATID(I)
  [L]MOV_DOSIDDES(NBMOV) = "0"
  [L]MOV_OBJNAM(NBMOV)   = [L]A_ETAT(I)
 Endif
Next

## Resume
Call ECR_TRACE("Résumé des mouvements à faire :",0) From GESECRAN
For I=1 To NBMOV
 Call ECR_TRACE(space$(3)+"-"-[L]MOV_TYP(I) -"//"-[L]MOV_COD(I)-"//"-[L]MOV_OBJID(I)-"//"-[L]MOV_DOSIDDES(I)-"//"-[L]MOV_OBJNAM(I),0) From GESECRAN
Next


Return

#------------------------------------------------------------------------------------#
#  DEPLACEMENT DES ETATS ET UNIVERS
#------------------------------------------------------------------------------------#
$MOVE_ETAT
FICETAPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier ImpBiar
Onerrgo ERREURS

Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+FICETAPRO , 0  Using [D1]
Iomode adxifs  ""  Using [D1]
Iomode adxirs  chr$(13)+chr$(10)  Using [D1]
Iomode adxium  GUTF8  Using [D1]

For I=1 To NBMOV
 Wrseq [L]MOV_TYP(I)+";"+[L]MOV_COD(I)+";"+[L]MOV_OBJID(I)+";"+[L]MOV_DOSIDDES(I)+";"+[L]MOV_OBJNAM(I) Using [D1]
Next

Openo Using [E1]
Openo Using [D1]

If SIMU = 2 : Goto TRACES : Endif

ORDRE = ''+chr$(10)
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+IMPCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'ImpBiar_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.err"'

ORDSYS(1) = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3Imp_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE) From SUBATV2
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3Imp_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)  From SUBATV2
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)  From SUBATV2
Endif
If GINFO
 Call AFF_VLC(mess(138,148,1),"") From GESECRAN  : # Déplacement des états et univers dans le répertoire de livraison
Endif
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS
If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out',OUT) From SUBATV2
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'ImpBiar_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

If filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.err',7)>0
 If GTRACE <> ""
  Call ECR_TRACE('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1),1) From GESECRAN
 Else
  Call ERREUR('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

Return

$TRACES
Return

#------------------------------------------------------------------------------------#
# recup des id et cuid des repertoires ALL et SOL des univers.
#------------------------------------------------------------------------------------#
$FIND_DOSSIER_UNV
### Calcul du cuid du folder d'univers de destination
N=find(GREPBI,U_DOSSIER(1..U_NBDOS))
If N = 0 : Return : Endif
A_UNVDOSID_0 = U_DOS_ID(N)
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPSOLIND & U_DOS_P_ID(J) =A_UNVDOSID_0
  A_UNVDOSID_1 = U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = GREPBOPROD & U_DOS_P_ID(I) =  A_UNVDOSID_1
   A_UNVDOSID_2 = U_DOS_ID(I)
  Break
 Endif
Next I
For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = "ALL" & U_DOS_P_ID(K) = A_UNVDOSID_2
  A_UNVDOSCUID_ALL = U_DOS_CUID(K)
  A_UNVDOSID_ALL = U_DOS_ID(K)
  Break
 Endif
Next K
If A_UNVDOSCUID_ALL =""
 OK = 0
 Call ECR_TRACE("ALL"-mess(125,148,1)-": KO",0) From GESECRAN
 Return
Endif

### Calcul du cuid du folder d'univers origine
N=find("Universes",U_DOSSIER(1..U_NBDOS))
If N = 0 : Return : Endif
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPBI  & U_DOS_P_ID(J) = U_DOS_ID(N)
  I_UNVDOSID_0 = U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GINSTID  & U_DOS_P_ID(J) = I_UNVDOSID_0
  I_UNVDOSID_1= U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = [L]DATAW  & U_DOS_P_ID(J) = I_UNVDOSID_1
  I_UNVDOSID_2=U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = [L]DATALAN & U_DOS_P_ID(I) = I_UNVDOSID_2
  I_UNVDOSCUID_SOL = U_DOS_CUID(I)
  I_UNVDOSID_SOL   = U_DOS_ID(I)
  Break
 Endif
Next I
If I_UNVDOSCUID_SOL=""
 OK = 0
 Call ECR_TRACE(GREPBI-mess(125,148,1)-": KO",0) From GESECRAN
 Return
Endif
Return

#------------------------------------------------------------------------------------#
# Mis ene variable des univers
#------------------------------------------------------------------------------------#
$LISTE_DOSSIER_UNV
BALISE = 1 : OK =1
Gosub LIT_TOOL From ABIMAP

If filinfo([L]FICHIER,7)<0
 OK =0
Endif
OK = 1
DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(0,CLOB,'Folder CUID="')
While DEB>0
 U_NBDOS +=1

 FIN = instr(DEB+13,CLOB,'"')
 U_DOS_CUID(U_NBDOS) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(FIN,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 U_DOS_ID(U_NBDOS) = seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(FIN,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 U_DOSSIER(U_NBDOS) = seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(FIN,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_DOS_P_ID(U_NBDOS) = seg$(CLOB,DEB+10,FIN-1)

 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend
Return

#------------------------------------------------------------------------------------#
# Liste  des etats du repertoire ALL de la livraison
#------------------------------------------------------------------------------------#
$LISTE_ALL
N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
A_DOSETATID_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = A_DOSETATID_0
  A_DOSETATID_1 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = A_DOSETATID_1
  A_DOSETATID_2 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "ALL" & [L]DOS_P_ID(I) = A_DOSETATID_2
  A_DOSETATID_ALL = [L]DOS_ID(I)
  Break
 Endif
Next I
J=0
Call ECR_TRACE(func AFNC.MES2(mess(164,148,1),"ALL",[L]DATAM)-":",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_ID(I) = A_DOSETATID_ALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT)
   J+=1
  [L]A_ETAT(J)      = [L]ETAT(I)
  [L]A_ETATID(J)    = [L]ETAT_ID(I)
  [L]A_ETATFID(J)   = [L]ETAT_F_ID(I)
  [L]A_ETATUNV(J)   = [L]ETAT_UNV(I)
  [L]A_ETATUNVID(J)  = [L]ETAT_UNVID(I)
  [L]A_ETATCUID(J)  = [L]ETAT_CUID(I)
  Call ECR_TRACE(" -"-[L]A_ETAT(J)-"("-[L]A_ETATCUID(J)-"-"-[L]A_ETATID(J)-")",0) From GESECRAN
 Endif
Next I
[L]A_NBETAT = J
Return
Return

#------------------------------------------------------------------------------------#
# Liste  des etats du repertoire lan de la solution
#------------------------------------------------------------------------------------#
$LISTE_SOLUTION
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBI & [L]DOS_P_ID(I) = "0"
  I_DOSETATID_0 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GINSTID & [L]DOS_P_ID(I) = I_DOSETATID_0
  I_DOSETATID_1 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = [L]DATAW  & [L]DOS_P_ID(I) = I_DOSETATID_1
  I_DOSETATID_2 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = [L]DATALAN & [L]DOS_P_ID(I) = I_DOSETATID_2
  I_DOSETATID_SOL = [L]DOS_ID(I)
 Endif
Next I
J=0
Call ECR_TRACE(func AFNC.MES2(mess(164,148,1),[L]DATALAN,[L]DATAM)-":",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_ID(I) = I_DOSETATID_SOL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT)
  J+=1
  [L]I_ETAT(J)      = [L]ETAT(I)
  [L]I_ETATID(J)    = [L]ETAT_ID(I)
  [L]I_ETATFID(J)   = [L]ETAT_F_ID(I)
  [L]I_ETATUNV(J)   = [L]ETAT_UNV(I)
  [L]I_ETATUNVID(J)  = [L]ETAT_UNVID(I)
  [L]I_ETATCUID(J)  = [L]ETAT_CUID(I)
  Call ECR_TRACE(" -"-[L]I_ETAT(J)-"("-[L]I_ETATCUID(J)-"-"-I_ETATID(J)-")",0) From GESECRAN
 Endif
Next I
[L]I_NBETAT = J
Return

#------------------------------------------------------------------------------------#
# Création du fichier descriptif du refrentiel BO
#------------------------------------------------------------------------------------#
$CREE_TOOL
[M:ATV2]DATAW    = [L]DATAW
[M:ATV2]LANGORI  = "FRA"
[M:ATV2]LANGDES  = "FRA"
[M:ATV2]DATAMORI = [L]DATAM
[M:ATV2]LANGDES  = GLANGUE
[M:ATV2]LANGORI  = GLANGUE
WEBILIST = "TRUE"
WEBIUNV  = "TRUE"
SOLCREA  = "FALSE"
UNIVLIST = "TRUE"
REPBIS   = GREPBI      : # Critere repertoire de recherche niveau 1
REPBIS21 = GREPSOLIND  : # Critere repertoire de recherche niveau 2
REPBIS22 = GINSTID     : # Critere repertoire de recherche niveau 2
IMPORT   = GREPBI
Gosub CRE_PARAM From SUBATV2
Gosub CRE_DOCLISTFILT From SUBATV2
If !OK
 Return
Endif
Call ECR_TRACE("Creation of description of Bi referentiel :",0) From GESECRAN
Gosub GENE_TOOL From SUBATV2
Call ECR_TRACE("",0) From GESECRAN
If !OK
 Return
Elsif filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 OK =0
 Call ECR_TRACE("|"+[M:ATV2]FICTOOL+"|"-":"-mess(101,100,1),1) From GESECRAN
 Return
Endif
Return

$DECLARE
If clalev([M:ATV2])=0 : Local Mask ATV2                [ATV2] : Endif
Gosub INIT_SOLUTION From SUBATV2
Gosub DECLARE_VARIABLE From SUBATV2
Local Integer BALISE
Local Char FICETAPRO(GDIMFIC) : # Fichier propriete move eta

## Tableau etats de FRA
Local Char    I_ETAT(80)(1..500)
Local Char    I_ETATFID(20)(1..500)
Local Char    I_ETATID(20)(1..500)
Local Char    I_ETATUNV(10)(1..500)
Local Char    I_ETATUNVID(20)(1..500)
Local Char    I_ETATCUID(50)(1..500)
Local Integer I_NBETAT
Local Char    I_DOSETATID_0(80),I_DOSETATID_1(80),I_DOSETATID_2(80),I_DOSETATID_SOL(80)

## Tableau etats de ALL
Local Char    A_ETAT(80)(1..500)
Local Char    A_ETATFID(20)(1..500)
Local Char    A_ETATID(20)(1..500)
Local Char    A_ETATUNV(10)(1..500)
Local Char    A_ETATUNVID(20)(1..500)
Local Char    A_ETATCUID(50)(1..500)
Local Integer A_NBETAT
Local Char    A_DOSETATID_0(80),A_DOSETATID_1(80),A_DOSETATID_2(80),A_DOSETATID_ALL(80)

### tableau des dossiers d'univers
Local Char    U_DOSSIER(80)(0..100)
Local Char    U_DOS_ID(20)(0..100)
Local Char    U_DOS_CUID(50)(0..100)
Local Char    U_DOS_P_ID(20)(0..100)
Local Integer U_NBDOS

## recup des id et cuid des repertoires ALL et SOL des univers.
Local Char A_UNVDOSID_0(80),A_UNVDOSID_1(80),A_UNVDOSID_2(80),A_UNVDOSID_ALL(80),A_UNVDOSCUID_ALL(80)
Local Char I_UNVDOSID_0(80),I_UNVDOSID_1(80),I_UNVDOSID_2(80),I_UNVDOSID_SOL(80),I_UNVDOSCIID_SOL(80)
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran ABIMOVETA) 19/02/2009 10:09:37 (CCL)
######################################################################################
Subprog D_DATAW(VALEUR)
Variable Char    VALEUR()
Local Integer I
For [ABW]
 I+=1
Next
If I=1
 VALEUR = [F:ABW]COD
Endif
End

Subprog C_DATAM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Read [F:ABW]ABW0 = [M:DIA]DATAW
If !fstat
 For I=0 To [F:ABW]NBRABM-1
  If VALEUR= [F:ABW]CODABM(I)
   OK=1
   Break
  Endif
 Next I
Endif
If !OK
 GMESSAGE =mess(40,148,1) : # Datamart non présent dans le datawarehouse
 mkstat = 2 : End
Endif
End
