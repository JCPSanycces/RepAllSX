#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
# UTICPT45                                                     Module CPT   #
#                                                                           #                     
#  Demande 70055                                                            #                     
#    La table AUTILIS, le champ CCE assossié au code activité               #                    
#    de dimentionnement ANA avait une valeur 1 (à tort) dnas le champ DIME  #
#    Moulinette de RAZ du champ DIME                                        #   
#############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTICPT45(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT45(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT45 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ATZ])  =0  Local File =DOSSIER+".ATABZON"   [ATZ] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ATZ]

For [ATZ] Where CODFIC="AUTILIS" & CODACT="ANA" & DIME<>0
 Readlock [ATZ] Curr    
 If !fstat
  # --- alimentation des champs et réécriture enreg
  [F:ATZ]DIME = 0 
  Rewrite [F:ATZ]
  If !fstat COMPTEUR += 1 Endif
 Endif
Next

Commit

Close Local File [ATZ]

Call ECR_TRACE("UTICPT45 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","ATABZON","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT45(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If filinfo(filpath("FIL","ATABZON","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT45(APPLI)
End

