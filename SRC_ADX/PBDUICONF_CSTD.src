$CLEAR_LINES
  Local Integer I
  For [L]I = 1 To maxtab(this.LINES)
    If this.LINES([L]I) <> null Then
      ASTATUS = fmet this.ADELLINE("LINES", [L]I)
    Endif
  Next [L]I
Return

