########################################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_BEFORE" : Gosub METH_AINSERT_BEFORE
      Endcase
  Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



# SAM # 111399  Moved content from $METHODS to $EVENTS
$METHODS
#  Case [L]CURPTH
#    When ""
#      Case [L]ACTION
#        When "AINSERT_BEFORE" : Gosub METH_AINSERT_BEFORE
#      Endcase
#  Endcase
Return

$METH_AINSERT_BEFORE
  Local Integer I
  Local Integer J
  [L]J = 1
  For [L]I = 1 To maxtab(this.LINES)
    If this.LINES([L]I) <> null and this.LINES([L]I).ASTALIN = [V]CST_ANEW Then
      this.LINES([L]I).LIN = [L]J
      [L]J += 1
    Endif
  Next [L]I
Return

########################################################################################################################
# Properties ###########################################################################################################

$PROPERTIES
  Case [L]CURPRO
    When "LEG" : Gosub PROP_LEG
  Endcase
Return

$PROP_LEG
  Case [L]ARULE
    When "CONTROL"
      Local File ATABDIV [ADI]
      Read [F:ADI]CODE = 909;this.LEG
      If fstat <> 0 Then
        # the legislation does not exist
        # $1$ is not a valid legislation.
        ASTATUS = fmet this.ASETERROR("LEG", func AFNC.MES1(mess(345,107,1), this.LEG), [V]CST_AERROR)
      Else
        # check whether the parameter 'PAYBALDCL' is set for the given legislation
        If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG, this.LEG, "PAYBALDCL") <> 2 Then
          # $1$ is not a valid legislation in this context. Please check parameter '$2$'.
          ASTATUS = fmet this.ASETERROR("LEG", func AFNC.MES2(mess(346,107,1), this.LEG, "PAYBALDCL"), [V]CST_AERROR)
        Endif
      Endif
      If this.ASTALIN = [V]CST_ANEW Then
#        Local Instance UICONF Using C_PBDUICONF
#        [L]UICONF = NewInstance C_PBDUICONF
#        ASTATUS = fmet [L]UICONF.AREAD(this.LEG)
#        If ASTATUS < [V]CST_AERROR Then
#          ASTATUS = fmet this.ASETERROR("LEG", "The legislation is defined already. Please edit existing record.", [V]CST_AERROR)
#        Endif
#        FreeInstance [L]UICONF
        Local File PBDUICONF [PBDUIC]
        Read [F:PBDUIC]PBDUIC0 = this.LEG
        If fstat = 0 Then
          # The legislation is defined already. Please edit existing record.
          ASTATUS = fmet this.ASETERROR("LEG", mess(391,107,1), [V]CST_AERROR)
        Endif
      Endif
    When "PROPAGATE"
      Gosub CLEAR_LINES
      Gosub LOAD_LINES
  Endcase
Return

########################################################################################################################

$LOAD_LINES
# 2015-09-11 DNE MODIF BEGIN
    Local Integer I
    Local File ATEXTRA [AXXADI]
    Local File ATEXTRA [AXXPBD]
    Local File ATABDIV [ADI] Where [F:ADI]NUMTAB = 323 and [F:ADI]LEG = this.LEG

    Trbegin ATEXTRA [AXXPBD]
    For [F:ADI]CODE

        # Add new line.
        [L]I = fmet this.ADDLINE("LINES", [V]CST_ALASTPOS)
        If [L]I < 0 Then
            ASTATUS = fmet this.ASETERROR("LINES", func AFNC.MES2(mess(266,133,1), "LINES", "PBDUICONF"), [V]CST_AERROR) # Insertion impossible in the $1$ collection of the $2$ class'"
            Break
        Endif

        # Fill line fields (except description field for it is translateable).
        this.LINES([L]I).LIN = [L]I
        this.LINES([L]I).FLD = [F:ADI]A1
        this.LINES([L]I).ADI323 = [F:ADI]CODE
        this.LINES([L]I).ORDPAY = [L]I
        this.LINES([L]I).ORDITM = [L]I
        this.LINES([L]I).GRPBYS = [V]CST_ANO

        # Create translateable texts by copying from ATABDIV related texts in ALL languages.
        Filter [F:AXXADI] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and IDENT1 = num$([F:ADI]NUMTAB) and IDENT2 = [F:ADI]CODE
        For [F:AXXADI]AXX0
            # Get text in current language.
            If this.ACTX.LAN = [F:AXXADI]LANGUE
                this.LINES([L]I).DES = [F:AXXADI]TEXTE
            Else
                Read [F:AXXPBD]AXX0 = "PBDUICONFD"; "DES"; [F:AXXADI]LANGUE; this.LEG; num$([L]I)
                [F:AXXPBD]       = [F:AXXADI]
                [F:AXXPBD]CODFIC = "PBDUICONFD"
                [F:AXXPBD]ZONE   = "DES"
                [F:AXXPBD]IDENT1 = this.LEG
                [F:AXXPBD]IDENT2 = num$([L]I)
                If fstat
                    Write [F:AXXPBD]
                Else
                    Rewrite [F:AXXPBD]
                Endif
            Endif
        Next
        Filter [F:AXXADI]
    Next
    Commit
