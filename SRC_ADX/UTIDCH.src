#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################
# Mise à jour des nouveaux champs pour la gestion des heures supp (LOI TEPA)   #
################################################################################

#########################
Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIDCH: Mise à jour paramétrage des charges (LOI TEPA)") From LECFIC
 Call EXE_UTIDCH(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################
Subprog EXE_UTIDCH(APPLI)
Value Char APPLI
Local Integer OK ,I, INDARR
Call ECR_TRACE("UTIDCH: Process Start on : "+APPLI,0) From GESECRAN
Local File =APPLI+".DECCHARGE" [DCH]
Call DEBTRANS From GLOCK
Gosub TR1
Call ECR_TRACE("UTIDCH: Process End on : "+APPLI,0) From GESECRAN
Close Local File [DCH]
End


#########################
$TR1
Trbegin [DCH]
GOK = 1
For [F:DCH]DCH0
 If dim([F:DCH]FLGQTY) <= 0 : Break : Endif
 I=0
 While[F:DCH]CODRUB(I)<>"" 
  [F:DCH]FLGQTY(I)=1
  I+=1
 Wend
 Rewrite [F:DCH]
 If fstat
  GOK = 0 : Call FSTA("DCH") From GLOCK : Break
 Endif
Next
If GOK<0 : Goto ROLL_TR1
Elsif GOK=0 : Gosub AB_TR1
Endif
Commit
Return

#########################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################
$AB_TR1
Rollback
Return

#########################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","DECCHARGE","fde",APPLI),0)<=0 : End : Endif  
Call EXE_UTIDCH(APPLI)
End





