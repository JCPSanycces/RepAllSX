#<AdxTL>@(#)3.0.0.0 $Revision$
#Special product
$ACTION
If WPRODUIT<>0 : # X3
 Return
Endif
Case ACTION
 When "OPEN_FILE" : Gosub OPEN_FILE
 When "NUM1_NIVRAZ" : Gosub NUM1_NIVRAZ
 When "NUMERO_PREC_NIVRAZ" : Gosub NUMERO_PREC_NIVRAZ
 When "ATTRIB_NUMERO" : Gosub ATTRIB_NUMERO
Endcase
Return

$OPEN_FILE
Local Char GCM(10)
Local Integer WFLGGCM : WFLGGCM=0
If ACTX.AFOLDER=nomap
 Local File COMPANY [CPY]
Else
 Local File =ACTX.AFOLDER+".COMPANY" [CPY]
Endif
If dim([F:CPY]ACM)>0 : WFLGGCM=1 : Endif
If ACTX.AFOLDER=nomap
 Local File PERIOD [PER]
Else
 Local File =ACTX.AFOLDER+".PERIOD" [PER]
Endif
Return

$SETSOC
#If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
#If [F:FCY]FCY<>SITE  : Read [FCY]FCY0 = SITE : Endif
#SOC = [F:FCY]LEGCPY
SOC=fmet ACTX.ACACHE.AFCY.AGETVALCHAR(SITE, "LEGCPY")
# V150
#If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
#If [F:CPY]CPY<>SOC  : Read [CPY]CPY0 = SOC : Endif
#If dim([F:CPY]ACM)>0 : GCM = [F:CPY]ACM : Endif
If WFLGGCM
 GCM=fmet ACTX.ACACHE.ACPY.AGETVALCHAR(SOC, "ACM")
Endif
Return

$ATTRIB_NUMERO
Case [F:ANM]POSTYP(I)
  When 10 : # Exercice
     Local Decimal PER , EXE : Raz PER , EXE
     Gosub SETSOC
     #K = find(GCM,GGCM(1..GGCMNBR))
     If WFLGGCM
      K = fmet ACTX.ACACHE.GGCM.AGETINDEX(GCM)
     Else
      K = [V]CST_ANOTDEFINED
     Endif
     #If K
     If K<>[V]CST_ANOTDEFINED
      #CHECK UNUSED_BEGIN
      If dim([L]LEDTYP)>0 and [L]LEDTYP>0
       Call GETPERSOC(ACTX,SOC,[L]LEDTYP,DAT,EXE,PER) From CPTSUB_SYRA
#      Elsif dim(GLEDTYPGEN)>0
#       Call GETPERSOC(SOC,GLEDTYPGEN(K),DAT,EXE,PER) From CPTSUB
#      Else
#       Call GETPERSOC(SOC,DAT,EXE,PER) From CPTSUB
      Else
       Call GETPERSOC(ACTX,SOC,fmet ACTX.ACACHE.GGCM.AGETVALNUM(GCM, "LEDTYPGEN"),DAT,EXE,PER) From CPTSUB_SYRA
      Endif
      #CHECK UNUSED_END
     Endif
     If EXE>0
      VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",EXE)
     Else
      STAT = 3 : Return
     Endif
  When 11 : # Période
     Local Decimal PER , EXE : Raz PER , EXE
     Gosub SETSOC
     #K = find(GCM,GGCM(1..GGCMNBR))
     If WFLGGCM
      K = fmet ACTX.ACACHE.GGCM.AGETINDEX(GCM)
     Else
      K = [V]CST_ANOTDEFINED
     Endif
     #If K
     If K<>[V]CST_ANOTDEFINED
      #CHECK UNUSED_BEGIN
      If dim([L]LEDTYP)>0 and [L]LEDTYP>0
       Call GETPERSOC(ACTX,SOC,[L]LEDTYP,DAT,EXE,PER) From CPTSUB_SYRA
#      Elsif dim(GLEDTYPGEN)>0
#       Call GETPERSOC(SOC,GLEDTYPGEN(K),DAT,EXE,PER) From CPTSUB
#      Else
#       Call GETPERSOC(SOC,DAT,EXE,PER) From CPTSUB
      Else
       Call GETPERSOC(ACTX,SOC,fmet ACTX.ACACHE.GGCM.AGETVALNUM(GCM, "LEDTYPGEN"),DAT,EXE,PER) From CPTSUB_SYRA
      Endif
      #CHECK UNUSED_END
     Endif
     If EXE>0
      VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",PER)
     Else
      STAT = 3 : Return
     Endif
Endcase
Return

$NUM1_NIVRAZ
Case [F:ANM]NIVRAZ
 When 4
    Local Decimal EXE : Raz EXE
    Gosub SETSOC
    #K = find(GCM,GGCM(1..GGCMNBR))
    If WFLGGCM
     K = fmet ACTX.ACACHE.GGCM.AGETINDEX(GCM)
    Else
     K = [V]CST_ANOTDEFINED
    Endif
    #If K
    If K<>[V]CST_ANOTDEFINED
     #CHECK UNUSED_BEGIN
     If dim([L]LEDTYP)>0 and [L]LEDTYP>0
      Call GETEXE(ACTX,SOC,[L]LEDTYP,DAT,EXE) From CPTSUB_SYRA
#     Elsif dim(GLEDTYPGEN)>0
#      Call GETEXE(SOC,GLEDTYPGEN(K),DAT,EXE) From CPTSUB
#     Else
#      Call GETEXE(SOC,DAT,EXE) From CPTSUB
     Else
      Call GETEXE(ACTX,SOC,fmet ACTX.ACACHE.GGCM.AGETVALNUM(GCM, "LEDTYPGEN"),DAT,EXE) From CPTSUB_SYRA
     Endif
     #CHECK UNUSED_END
    Endif
    If EXE>0
     PERIODE = EXE
    Else
     STAT = 3 : Return
    Endif
 When 5
    Local Decimal EXE , PER : Raz EXE , PER
    Gosub SETSOC
    #K = find(GCM,GGCM(1..GGCMNBR))
    If WFLGGCM
     K = fmet ACTX.ACACHE.GGCM.AGETINDEX(GCM)
    Else
     K = [V]CST_ANOTDEFINED
    Endif
    #If K
    If K<>[V]CST_ANOTDEFINED
     #CHECK UNUSED_BEGIN
     If dim([L]LEDTYP)>0 and [L]LEDTYP>0
      Call GETPERSOC(ACTX,SOC,[L]LEDTYP,DAT,EXE,PER) From CPTSUB_SYRA
#     Elsif dim(GLEDTYPGEN)>0
#      Call GETPERSOC(SOC,GLEDTYPGEN(K),DAT,EXE,PER) From CPTSUB
#     Else
#      Call GETPERSOC(SOC,DAT,EXE,PER) From CPTSUB
     Else
      Call GETPERSOC(ACTX,SOC,fmet ACTX.ACACHE.GGCM.AGETVALNUM(GCM, "LEDTYPGEN"),DAT,EXE,PER) From CPTSUB_SYRA
     Endif
     #CHECK UNUSED_END
    Endif
    If EXE>0
     PERIODE = 100*EXE+PER
    Else
     STAT = 3 : Return
    Endif
Endcase

Return

$NUMERO_PREC_NIVRAZ
Case [F:ANM]NIVRAZ
 When 4
    Local Decimal EXE : Raz EXE
    Gosub SETSOC
    #K = find(GCM,GGCM(1..GGCMNBR))
    If WFLGGCM
     K = fmet ACTX.ACACHE.GGCM.AGETINDEX(GCM)
    Else
     K = [V]CST_ANOTDEFINED
    Endif
    #If K
    If K<>[V]CST_ANOTDEFINED
     #CHECK UNUSED_BEGIN
#     If dim(GLEDTYPGEN)>0
#      Call GETEXE(SOC,GLEDTYPGEN(K),DAT,EXE) From CPTSUB
#     Else
#      Call GETEXE(SOC,DAT,EXE) From CPTSUB
#     Endif
      Call GETEXE(ACTX,SOC,fmet ACTX.ACACHE.GGCM.AGETVALNUM(GCM, "LEDTYPGEN"),DAT,EXE) From CPTSUB_SYRA
     #CHECK UNUSED_END
    Endif
    If EXE>0
     PERIODE = EXE
    Else
     STAT = 3 : Return
    Endif
Endcase

Return
