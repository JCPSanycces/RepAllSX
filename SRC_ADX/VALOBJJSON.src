#<AdxTL>@(#)1.0.0.0 $Revision$
# VALOBJJSON    :   Valideur json des objets

Local Char   OBJET(GLONAOB)
Local Char   APPLI(10)
APPLI=nomap

Local Integer OK
#OBJET = "CPY"
OBJET = "AQFC0"
GTRACE = ""

Call VALID(OBJET,APPLI,1,OK) From VALOBJ
Gosub JSON_VISU
End


#  Create the json associated to a window




$JSON
#If nomap<>"SUPERV" : Return : Endif
Local Char JSONPROP(250),JSONVALUE(250)
Local Integer NBITEM,NBLAYOUT,NBLL,INJ,RGJ
Local Char LETW,VALL1(250)

#Local Char LISTMASK(250)
#LISTMASK=":ZZM:AMK:"
#If instr(1,LISTMASK,":"+OBJET+":")<=0 : Return : Endif
# Ouverture du fichier json

Call NAMEFIC(APPLI,"OBJTJ","",OBJET,WE_NOMFIC) From INTRUTILA
Openo WE_NOMFIC,0 Using [JSO_]
Iomode adxifs "" Using [JSO_]
Iomode adxirs chr$(10) Using [JSO_]
Iomode adxium GUTF8 Using [JSO_]


Gosub JSON_INITLOC From VALWINJSON : HLOCAL="O-"+OBJET+"-"


# Ecriture entête
Wrseq '{'  Using [JSO_]


Gosub OBJ_FIELD
Wrseq "},"  Using [JSO_]
Gosub OBJ_LAYOUT
Wrseq "},"  Using [JSO_]

# Ecritures des localisations
Gosub JSON_LOCALIZ From VALWINJSON
Gosub JSON_HLOCALIZMSK From VALMSKJSON

# Fermeture fichier
Wrseq "}"  Using [JSO_]
Openo Using [JSO_]


Return


$OBJ_LAYOUT
 Wrseq '"$layout": {'  Using [JSO_]
 JSONPROP="$bind" : JSONVALUE="b$x$" : Gosub ADDJSONPROPV From VALMSKJSON
# JSONPROP="$selectMode" : JSONVALUE="false" : Gosub ADDJSONPROPV From VALMSKJSON
# JSONPROP="$format" : JSONVALUE="xflgrid" : Gosub ADDJSONPROPV From VALMSKJSON
 JSONPROP="$isEditMode" : JSONVALUE="false" : Gosub ADDJSONPROP From VALMSKJSON
# JSONPROP="$selectMode" : JSONVALUE="row" : Gosub ADDJSONPROP From VALMSKJSON
# JSONPROP="$isFusion" : JSONVALUE="true" : Gosub ADDJSONPROP From VALMSKJSON

Return


$ADDPNEXT
 Wrseq '"$links": {'  Using [JSO_]
 Wrseq '"$next": {'  Using [JSO_]
 Wrseq '"$title":"mynext",'  Using [JSO_]
 Wrseq '"$url": "leftList-Next",'  Using [JSO_]
 Wrseq '"$type": "application/json"'  Using [JSO_]
 Wrseq '},'  Using [JSO_]
 Wrseq '"$previous": {'  Using [JSO_]
 Wrseq '"$title":"myprev",'  Using [JSO_]
 Wrseq '"$url": "leftList-Prev",'  Using [JSO_]
 Wrseq '"$type": "application/json"'  Using [JSO_]
 Wrseq '      }'  Using [JSO_]
 Wrseq '},'  Using [JSO_]
Return

$OBJ_FIELD
 Wrseq '"$properties":{'  Using [JSO_]
 JSONPROP="$type" : JSONVALUE="application/x-array" : Gosub ADDJSONPROPV From VALMSKJSON
 #"$capabilities": "sort,filter", si au moins une colonne avec tri/sélection
 For WE_COU=1 To AOB_NBSEL
  If AOB_SELNOLIB(WE_COU)=0
    JSONPROP="$capabilities" : JSONVALUE= "sort,filter" : Gosub ADDJSONPROPV From VALMSKJSON
    Break
  Endif
 Next WE_COU
 JSONPROP="$isFieldPager" : JSONVALUE= "true" : Gosub ADDJSONPROPV From VALMSKJSON

 Wrseq '"$item": {'  Using [JSO_]
 #JSONPROP="$isFusion" : JSONVALUE="true" : Gosub ADDJSONPROPV From VALMSKJSON

 Wrseq '"$properties": {'  Using [JSO_]
 For WE_COU=1 To AOB_NBSEL
    Wrseq '"b$x$'+num$(WE_COU)+'": {' Using [JSO_]

# Intitulé du champ
    If AOB_SELZON(WE_COU)=""
      WE_NTEXKEY="O_"+OBJET + "_"+ "COL_"+num$(WE_COU)
    Else
       # Issue X3-45181 - 2017-11-07 by CCC : different objets/browser can use the same table => need to distinguish them
       #                                      X3-63778 : don't change AOB_SELABR (in VALOBJLEC) as it is used elsewhere
       #WE_NTEXKEY="O_"+AOB_SELABR(WE_COU) + "_"+ AOB_SELZON(WE_COU)
       WE_NTEXKEY="O_"+OBJET+"_"+AOB_SELABR(WE_COU) + "_"+ AOB_SELZON(WE_COU)
    Endif
    WE_NTEX=AOB_SELINT(WE_COU)  : WE_CAPDEF="" :  WE_LCH=0
    WE_INTEV="" : WE_FORCE=0 : Gosub JSON_ADDNLOC From VALWINJSON
    JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV From VALMSKJSON

#    If AOB_SELNOLIB(WE_COU)=0
      JSONPROP="$capabilities" : JSONVALUE= "sort,filter" : Gosub ADDJSONPROPV From VALMSKJSON
#    Endif

    If AOB_SELLNG(WE_COU)<>0
#     Wrseq '"$constraints": {' Using [JSO_]
     JSONPROP="$maxLength" : JSONVALUE=num$(AOB_SELLNG(WE_COU)) : Gosub ADDJSONPROPNV From VALMSKJSON
#     Wrseq '},' Using [JSO_]
    Endif
#    If AOB_SELNOLIB(WE_COU)<>0
#      JSONPROP="$mnu" : JSONVALUE=num$(AOB_SELNOLIB(WE_COU)) : Gosub ADDJSONPROPV From VALMSKJSON
#      JSONPROP="$format" : JSONVALUE="$combo" : Gosub ADDJSONPROPV From VALMSKJSON
#    Endif

    Case AOB_SELTYPTYP(WE_COU)
      When 1       : If AOB_SELNOLIB(WE_COU)<>0
                       #JSONVALUE="application/x-choice"   : # Menu local
                       JSONVALUE="application/x-string"     : # On ne sait pas le gérer
                     Else
                       JSONVALUE="application/x-integer"  : # Integer
                     Endif
      When 2,3     : JSONVALUE="application/x-integer"    : # Entier court et long
      When 4       : JSONVALUE="application/x-decimal"    : # Décimal
      When 5       : JSONVALUE="application/x-real"       : # Flottant
      When 6       : JSONVALUE="application/x-real"       : # Double
      When 7       : JSONVALUE="application/x-string"     : # Alphanumérique
      When 8       : JSONVALUE="application/x-date"       : # Date
      When 9       : JSONVALUE="application/octet-stream" : # Blob
      When 10      : JSONVALUE="application/octet-stream" : # Clob
      When Default : JSONVALUE="application/x-string"
     Endcase
     If AOB_SELTYP(WE_COU)="ATX"      : #  Pour traiter cas particulier des textes
       JSONVALUE="application/x-string"
     Endif

    JSONPROP="$type"  : Gosub ADDJSONPROP From VALMSKJSON
    If WE_COU=AOB_NBSEL
      Wrseq '}' Using [JSO_]
    Else
      Wrseq '},' Using [JSO_]
    Endif
  Next WE_COU
  Wrseq '}' Using [JSO_]
  Wrseq '}' Using [JSO_]
Return





$JSON_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+"ALL"+AASEP+"OBJTJ"
  URL+=+AASEP+"OBJ_"+OBJET+".json"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return

