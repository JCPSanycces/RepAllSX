#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTION  : TRTTDUVAR  : Action traitement de variation de capacité des #
# postes                                                                #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub ENREGISTRE
 When "ABA"        : Gosub ABORT
 When "FIN"        : Gosub FIN
 When Default
Endcase


Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$INIT
Case GACTION
 When "TRTTDUVAR"  : Gosub INI_TRTTDUVAR
Endcase
Return


#########################################################################
$INI_TRTTDUVAR

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:MWS]) = 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR [CPV]      : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY]    : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR   [TFO]    : Endif

Return

#########################################################################
$INIT_DIA


Raz [M:DIA]
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
[M:DIA]WCRFCY = GFCY
Gosub CHARG_PARAM                 # mm 12.02

Return

#########################################################################
$TERMINE

TRA=1
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return


#########################################################################
$SETBOUT

Raz ETABOU
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
Return


#########################################################################
$OUVRE

Local Char     CRITERE(250), CRITERE1(250)
Local Char     WMESS1(80), WCLE(80)
Local Integer  I , J
Local Integer  NBMODIF, OK
Global Char        FORMULE1(255)
Local Mask     TDUVAR3[TUV3]
# X3-25610 - STWIL - Create local work center range
Local Char     WSTSTA(GLONWST)
Local Char     WSTEND(GLONWST)

Gosub SEL_MWS
Return


#########################################################################
$SEL_MWS
#--> critères de saisie
CRITERE = "1=1"

# site
If [M:DIA]WCRFCY <> ""
   CRITERE -= '& [F:MWS]WCRFCY = "'+[M:DIA]WCRFCY+'"'
Endif

# centre
If [M:DIA]WCRDEB <> ""
   CRITERE -= '& [F:MWS]WCR >="'+[M:DIA]WCRDEB+'"'
Endif
If [M:DIA]WCRFIN <> ""
   CRITERE -= '& [F:MWS]WCR <="'+[M:DIA]WCRFIN+'"'
Endif

CRITERE1 = "1=1"

# type poste
If [M:DIA]WSTTYPDEB <> 0
   CRITERE1 -= '& [F:MWS]WSTTYP >='+num$([M:DIA]WSTTYPDEB)
Endif
If [M:DIA]WSTTYPFIN <> 0
   CRITERE1 -= '& [F:MWS]WSTTYP <='+num$([M:DIA]WSTTYPFIN)
Endif

# poste
If [M:DIA]WSTDEB <> ""
   CRITERE1 -= '& [F:MWS]WST >="'+[M:DIA]WSTDEB+'"'
Endif
If [M:DIA]WSTFIN <> ""
   CRITERE1 -= '& [F:MWS]WST <="'+[M:DIA]WSTFIN+'"'
Endif


Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=9;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return



#########################################################################
$DEBUT

Local Char    TIT(50) :  TIT =  mess(234,195,1)

Default File [MWS]
Default Mask [TUV2]

Local Integer WMAX : WMAX = dim([M:TUV2]WST)     # llc 04.03 17909
Local Integer WMAXVAR                            # 19593 10.03 MM
Gosub LIRE
If [M:TUV2]NBLIG=0
    GERR=2 : GMESSAGE=mess(358,197,1)
    FIN=1
Endif

Return

#########################################################################
$LIRE
REP=""
Raz [M:TUV2]
nolign=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

[M]WCRFCY = [M:DIA]WCRFCY
Call LECTURE("FCY",[M]WCRFCY,"") From CONTOBJ
[M]FCYDES = [F:FCY]FCYNAM

# 19593 10.03 MM
# purge des variations
If [M:DIA]VREMOVE=2

Link [CPV] With [MWS]WST0=WST;WCRFCY As [CPVW] Where evalue(CRITERE) & evalue (CRITERE1) & evalue(FORMULE1)
&          Order By Key KEY1= [CPV]WST;[MWS]WCRFCY
For [CPVW]
     I=0
     WMAXVAR = dim([F:CPV]STRDAT(I))
     While [F:CPV]STRDAT(I)<> [0/0/0]
        nolign+=1
        If nolign=WMAX : Break : Endif
        [M:TUV2]WCRFCY               = [F:MWS]WCRFCY
        [M:TUV2]WCR(nolign-1)        = [F:MWS]WCR
        [M:TUV2]WST(nolign-1)        = [F:CPV]WST
#        [M:TUV2]WSTDES(nolign-1)     = [F:MWS]WSTDES
        #LECTURE du libellé traduisible
        Call LECTEXTRA([M:TUV2]WSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        [M:TUV2]WSTTYP(nolign-1)     = [F:MWS]WSTTYP
        [M:TUV2]STRDAT(nolign-1)     = [F:CPV]STRDAT(I)
        [M:TUV2]ENDDAT(nolign-1)     = [F:CPV]ENDDAT(I)
        [M:TUV2]CODVAR(nolign-1)     = [F:CPV]CODVAR(I)
        [M:TUV2]VARTWD(nolign-1)     = [F:CPV]TWD(I)
        [M:TUV2]VARWSTNBR(nolign-1)  = [F:CPV]WSTNBR(I)
        [M:TUV2]VARWSTNBR(nolign-1)  = [F:CPV]WSTNBR(I)
        [M:TUV2]VARTEX(nolign-1)     = [F:CPV]VARTEX(I)
        I+=1
        If I= WMAXVAR : Break : Endif
      Wend
Next

Else
Filter [MWS] Where evalue (CRITERE) & evalue (CRITERE1)  & evalue(FORMULE1) Order By Key WST0
For [MWS]
  nolign+=1
  If nolign = WMAX : Break : Endif    # llc 04.03 17909
  [M:TUV2] = [F]

  [M:TUV2]STRDAT(nolign-1) =[M:DIA]VSTRDAT
  [M:TUV2]ENDDAT(nolign-1) =[M:DIA]VENDDAT
  [M:TUV2]CODVAR(nolign-1) =[M:DIA]VCODVAR
  [M:TUV2]VARTWD(nolign-1) =[M:DIA]VVARTWD
  [M:TUV2]VARWSTNBR(nolign-1)=[M:DIA]VVARWSTNBR
  [M:TUV2]VARTEX(nolign-1) =""

  # repérage des périodes de variations de capacité chevauchantes.
  # en cas de chevauchement de périodes , on fait passer FWRITE à 1
  Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
  If !fstat
      I=0
      WMAXVAR = dim([F:CPV]STRDAT(I))
      While [F:CPV]STRDAT(I)<> [0/0/0]
       If (([F:CPV]STRDAT(I)<[M:TUV2]STRDAT(nolign-1)) & ([F:CPV]ENDDAT(I)<[M:TUV2]STRDAT(nolign-1)))
&         |(([F:CPV]STRDAT(I)>[M:TUV2]ENDDAT(nolign-1)) & ([F:CPV]ENDDAT(I)>[M:TUV2]ENDDAT(nolign-1)))
           I+=1
       Else
           [M:TUV2]FWRITE(nolign-1)=1 : Break
       Endif
       If I= WMAXVAR : Break : Endif
      Wend
  Endif

Next
Filter [MWS]
Endif

If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif   # llc 04.03 17909

[M:TUV2]NBLIG = nolign
Affzo [M:TUV2]

    # X3-25610 - STWIL - Set work center range
    If nolign > 0
        [L]WSTSTA = [M:TUV2]WST(0)
        [L]WSTEND = [M:TUV2]WST(nolign - 1)
    Endif

Return

#########################################################################
$APRES_MODIF

REP="M"
Gosub SETBOUT

Return

#########################################################################
$ENREGISTRE
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif


Gosub MODIF
FIN=1
If func AFNC.ACTIV("POPS") = 0
    GERR=2
    GMESSAGE=mess(363,197,1)
Endif

Return

#########################################################################
$MODIF
# Enregistrement des modifications

Call TEMPON("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MODMWS
If !NBMODIF
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

    # X3-25610 - STWIL - Prompt user to recalculate loads and reschedule
    If NBMODIF
        # Turn off the previous in progress message
        Call TEMPOFF From GESECRAN
        Call OUINON(mess(257,190,1),OK) From GESECRAN
        If OK = 2
            # Set the calulation in progress message
            Call TEMPON("C") From GESECRAN
            # User wants to recalculate loads and schedules
            Call JALFCY([M:DIA]WCRFCY, [L]WSTSTA, [L]WSTEND, 2) From JALLIBD

            # We also need to recalculate the loads
            Call JALFCYB([M:DIA]WCRFCY, date$, "", "", 1) From JALLIBD
        Endif
    Endif

Call TEMPOFF From GESECRAN
Return

#########################################################################
$MODMWS
If [M:DIA]VREMOVE =2
    Gosub PURCPV
Else
    Gosub MAJMWS
Endif
If NBMODIF
    WMESS1=num$(NBMODIF)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif
Return

#########################################################################
$PURCPV

NBMODIF=0

Call DEBTRANS From GLOCK
GOK=1
Trbegin [MWS]
Filter [MWS] Where evalue (CRITERE) & evalue (CRITERE1) & evalue(FORMULE1)  Order By Key WST0
    For [MWS]
         Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
         If !fstat
             WMAXVAR = dim([F:CPV]STRDAT(I))

             #Purge des variations de capacité du poste
             I=0
             While [F:CPV]STRDAT(I)<>[0/0/0]
                [F:CPV]STRDAT(I)     = [0/0/0]
                [F:CPV]ENDDAT(I)     = [0/0/0]
                [F:CPV]CODVAR(I)     = ""
                [F:CPV]TWD(I)        = ""
                [F:CPV]WSTNBR(I)     = 0
                [F:CPV]VARTEX(I)     = ""
                [F:CPV]UPDDAT        = date$
                [F:CPV]UPDUSR        = GUSER
                [F:CPV]EXPNUM        = [C]EXPORT
                Rewrite [CPV]
                If fstat
                    GOK = 0: Call FSTA("CPV") From GLOCK
                    Goto AB_MOD
                Endif
                I+=1
                If I= WMAXVAR : Break : Endif
             Wend

             # Report du contenu du tableau [TUV2] dans la table CAPVAR
             J=0
             For nolign=1 To [M:TUV2]NBLIG
                If [M:TUV2]WST(nolign-1)=[F:CPV]WST
                    [F:CPV]STRDAT(J)=[M:TUV2]STRDAT(nolign-1)
                    [F:CPV]ENDDAT(J)=[M:TUV2]ENDDAT(nolign-1)
                    [F:CPV]CODVAR(J)=[M:TUV2]CODVAR(nolign-1)
                    [F:CPV]TWD(J)   =[M:TUV2]VARTWD(nolign-1)
                    [F:CPV]WSTNBR(J)=[M:TUV2]VARWSTNBR(nolign-1)
                    [F:CPV]VARTEX(J)=[M:TUV2]VARTEX(nolign-1)
                    Rewrite [CPV]
                    If fstat
                        GOK = 0: Call FSTA("CPV") From GLOCK
                        Goto AB_MOD
                    Endif
                    J+=1
                Endif
            Next nolign

            If I<>J
                 WMESS1=mess(4,2302,1)-[F:CPV]WST-"/"-[F:CPV]WCRFCY-":"-mess(197,190,1)
                 Call ECR_TRACE(WMESS1,0) From GESECRAN
                 NBMODIF+=1
            Else
                WMESS1=mess(4,2302,1)-[F:CPV]WST-"/"-[F:CPV]WCRFCY-":"-mess(371,197,1)
                Call ECR_TRACE(WMESS1,0) From GESECRAN
            Endif
        Endif
    Next
Filter [MWS]

If  GOK = 1 : Commit : Endif

Return
#########################################################################
$MAJMWS

NBMODIF=0

Call DEBTRANS From GLOCK
GOK=1
Trbegin [CPV]
    For nolign=1 To [M:TUV2]NBLIG
        Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
        If fstat<>0  & fstat<>5 : Goto NXTMWS2 : Endif

        If [M:TUV2]SURCHAFLG=1
        # Surcharge non autorisée
           If fstat=0
                # Si FWRITE=1, il y a chevauchement
                If [M:TUV2]FWRITE(nolign-1)=1
                   WMESS1=[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)-mess(142,193,1)
                   Call ECR_TRACE(WMESS1,0) From GESECRAN
                   Goto NXTMWS2
                Else
                   Gosub MAJ_ENR_CPV
                Endif
           Elsif fstat=5
                Gosub CRE_ENR_CPV
           Endif
       Elsif [M:TUV2]SURCHAFLG=2
           If [M:TUV2]FWRITE(nolign-1)<>1
                If fstat=0   Gosub MAJ_ENR_CPV
                Elsif fstat=5  Gosub CRE_ENR_CPV : Endif
           Else
                # Traitement des chevauchements de période
                If fstat=0  : Gosub TRT_OVERLAP :  Endif

           Endif
       Endif
   $NXTMWS2
   Next nolign

If  GOK = 1 : Commit : Endif

Return
#########################################################################
# MAJ CAPVAR : ajout d'une nouvelle variation de capacité,
# pour un poste de charge donné.
$MAJ_ENR_CPV

Readlock [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
If fstat = 1
    GOK = -1:GLOCK="$CAPVAR"+[M:TUV2]WST(nolign-1)
    Goto ROLL_MODMWS
Endif
If fstat
    WCLE = [M:TUV2]WST(nolign-1)-[M:TUV2]WCRFCY
    GOK = 0 :Call RSTA("CPV", WCLE) From GLOCK
    Goto AB_MOD
Endif

I = 0
# positionnemment derrière la dernière variation saisie
WMAXVAR = dim([F:CPV]STRDAT(I))
While [F:CPV]STRDAT(I)<>[0/0/0]
    I+=1
    If I= WMAXVAR : Break: Endif
Wend

If I= WMAXVAR
    WMESS1=[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)-":"-mess(195,190,1)-[M:TUV2]WST(nolign-1)-mess(1,333,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    WMESS1=mess(196,190,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Return
Endif

[F:CPV]STRDAT(I) = [M:TUV2]STRDAT(nolign-1)
[F:CPV]ENDDAT(I) = [M:TUV2]ENDDAT(nolign-1)
[F:CPV]CODVAR(I) = [M:TUV2]CODVAR(nolign-1)
[F:CPV]TWD(I)    = [M:TUV2]VARTWD(nolign-1)
[F:CPV]WSTNBR(I) = [M:TUV2]VARWSTNBR(nolign-1)
[F:CPV]VARTEX(I) = [M:TUV2]VARTEX(nolign-1)
[F:CPV]UPDDAT    = date$
[F:CPV]UPDUSR    = GUSER
[F:CPV]EXPNUM    = [C]EXPORT
Rewrite [CPV]
If fstat
    GOK = 0: Call FSTA("CPV") From GLOCK
    Goto AB_MOD
Endif


NBMODIF +=1
WMESS1=mess(52,197,1)-[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)
Call ECR_TRACE(WMESS1,0) From GESECRAN

Return
#########################################################################
# Création d'un nouvel enregistrement dans CAPVAR
$CRE_ENR_CPV

Raz [CPV]
WMESS1=mess(52,197,1)-[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)
Call ECR_TRACE(WMESS1,0) From GESECRAN

[F:CPV]WST       = [M:TUV2]WST(nolign-1)
[F:CPV]WCRFCY    = [M:TUV2]WCRFCY
[F:CPV]STRDAT(0) = [M:TUV2]STRDAT(nolign-1)
[F:CPV]ENDDAT(0) = [M:TUV2]ENDDAT(nolign-1)
[F:CPV]CODVAR(0) = [M:TUV2]CODVAR(nolign-1)
[F:CPV]TWD(0)    = [M:TUV2]VARTWD(nolign-1)
[F:CPV]WSTNBR(0) = [M:TUV2]VARWSTNBR(nolign-1)
[F:CPV]VARTEX(0) = [M:TUV2]VARTEX(nolign-1)
[F:CPV]CREDAT    = date$
[F:CPV]CREUSR    = GUSER
[F:CPV]EXPNUM    = [C]EXPORT
Write [CPV]
If fstat
    GOK = 0: Call FSTA("CPV") From GLOCK
    Goto AB_MOD
Endif

NBMODIF +=1
Return

#########################################################################
# Demande n° 19593 10.03 MM
# Modification des dates de début/fin d'une variation existante
# en cas de chevauchement de période
$TRT_OVERLAP
Local Integer WNEWLIN  : WNEWLIN = 0
Raz [M:TUV3]

Readlock [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
If fstat = 1
    GOK = -1:GLOCK="$CAPVAR"+[M:TUV2]WST(nolign-1)
    Goto ROLL_MODMWS
Endif
If fstat
    WCLE = [M:TUV2]WST(nolign-1)-[M:TUV2]WCRFCY
    GOK = 0 :Call RSTA("CPV", WCLE) From GLOCK
    Goto AB_MOD
Endif

# Sauvegarde dans le tableau [TUV3] des variations de capacité
# existantes, à l'exclusion de celles qui précèdent la nouvelle variation
J=0
I=0
[M:TUV3]NBLIG=0
WMAXVAR = dim([F:CPV]STRDAT(I))
While [F:CPV]STRDAT(I)<>[0/0/0]
    If [M:TUV2]STRDAT(nolign-1)>[F:CPV]ENDDAT(I): Goto WWEND
    Else
        [M:TUV3]STRDAT(J)  = [F:CPV]STRDAT(I)
        [M:TUV3]ENDDAT(J)  = [F:CPV]ENDDAT(I)
        [M:TUV3]CODVAR(J)  = [F:CPV]CODVAR(I)
        [M:TUV3]TWD(J)     = [F:CPV]TWD(I)
        [M:TUV3]WSTNBR(J)  = [F:CPV]WSTNBR(I)
        [M:TUV3]VARTEX(J)  = [F:CPV]VARTEX(I)
        J +=1

        [M:TUV3]NBLIG       += 1
        [F:CPV]STRDAT(I)     = [0/0/0]
        [F:CPV]ENDDAT(I)     = [0/0/0]
        [F:CPV]CODVAR(I)     = ""
        [F:CPV]TWD(I)        = ""
        [F:CPV]WSTNBR(I)     = 0
        [F:CPV]VARTEX(I)     = ""
        [F:CPV]UPDDAT        = date$
        [F:CPV]UPDUSR        = GUSER
        [F:CPV]EXPNUM        = [C]EXPORT
        Rewrite [CPV]
        If fstat
            GOK = 0: Call FSTA("CPV") From GLOCK
            Goto AB_MOD
        Endif
    Endif
$WWEND
I+=1
If I= WMAXVAR : Break : Endif
Wend

# on stocke dans [M:TUV3]NBLINE le nombre de variations de capacité encore présentes dans CAPVAR
J=0
While [F:CPV]STRDAT(J)<>[0/0/0]
J+= 1
If J= WMAXVAR : Break : Endif
Wend
[M:TUV3]NBLINE= J


If I= WMAXVAR
    WMESS1=[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)-":"-mess(195,190,1)-[M:TUV2]WST(nolign-1)-mess(1,333,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    WMESS1=mess(196,190,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    For I=0 To [M:TUV3]NBLIG-1
    If [M:TUV3]STRDAT(I)<>[0/0/0]
        [F:CPV]STRDAT([M:TUV3]NBLINE)     = [M:TUV3]STRDAT(I)
        [F:CPV]ENDDAT([M:TUV3]NBLINE)     = [M:TUV3]ENDDAT(I)
        [F:CPV]CODVAR([M:TUV3]NBLINE)     = [M:TUV3]CODVAR(I)
        [F:CPV]TWD([M:TUV3]NBLINE)        = [M:TUV3]TWD(I)
        [F:CPV]WSTNBR([M:TUV3]NBLINE)     = [M:TUV3]WSTNBR(I)
        [F:CPV]VARTEX([M:TUV3]NBLINE)     = [M:TUV3]VARTEX(I)
        [M:TUV3]NBLINE+=1
        Rewrite [CPV]
        If fstat
            GOK = 0: Call FSTA("CPV") From GLOCK
            Goto AB_MOD
        Endif
    Endif
    Next I
    Return
Endif

# Modification des variations de capacité existantes
For I=0 To [M:TUV3]NBLIG-1

    # cas particulier : les dates debut et fin de l'ancienne et de la nouvelle
    # variation de capacité sont identiques
    If ([M:TUV2]STRDAT(nolign-1)=[M:TUV3]STRDAT(I)) & ([M:TUV2]ENDDAT(nolign-1)=[M:TUV3]ENDDAT(I))
        Dela I,1,I [M:TUV3]NBLIG
        Goto NEXTI
    Endif

    If ([M:TUV2]STRDAT(nolign-1)>=[M:TUV3]STRDAT(I)) & ([M:TUV2]STRDAT(nolign-1)<[M:TUV3]ENDDAT(I))
        # débordement à droite
        If [M:TUV2]ENDDAT(nolign-1)>[M:TUV3]ENDDAT(I)
            If [M:TUV2]STRDAT(nolign-1) = [M:TUV3]STRDAT(I)
                   Dela I,1,I [M:TUV3]NBLIG
            Else
                [M:TUV3]ENDDAT(I) = [M:TUV2]STRDAT(nolign-1)-1
                [M:TUV3]UPDDAT    = date$
                [M:TUV3]UPDUSR    = GUSER
                [M:TUV3]EXPNUM    = [C]EXPORT
            Endif
            Goto NEXTI
        Else
        # Période de la nouvelle variation à l'intérieur d'une ancienne
          Local Date WSTRDAT : WSTRDAT =[M:TUV3]STRDAT(I)

            # Décalage du début de l'ancienne variation de capacité
            If [M:TUV2]ENDDAT(nolign-1)<[M:TUV3]ENDDAT(I)
                [M:TUV3]STRDAT(I) =[M:TUV2]ENDDAT(nolign-1)+1
                [M:TUV3]UPDDAT    = date$
                [M:TUV3]UPDUSR    = GUSER
                [M:TUV3]EXPNUM    = [C]EXPORT
            Endif

            If [M:TUV2]STRDAT(nolign-1)> WSTRDAT
                # écriture du début de l'ancienne variation de capacité
                [M:TUV3]NBLIG +=1
                WNEWLIN +=1
                Insa [M:TUV3]NBLIG-1,1,[M:TUV3]NBLIG-1 [M:TUV3]NBLIG
                [M:TUV3]STRDAT([M:TUV3]NBLIG-1)     = WSTRDAT
                [M:TUV3]ENDDAT([M:TUV3]NBLIG-1)     = [M:TUV2]STRDAT(nolign-1)-1
                [M:TUV3]CODVAR([M:TUV3]NBLIG-1)     = [M:TUV3]CODVAR(I)
                [M:TUV3]TWD([M:TUV3]NBLIG-1)        = [M:TUV3]TWD(I)
                [M:TUV3]WSTNBR([M:TUV3]NBLIG-1)     = [M:TUV3]WSTNBR(I)
                [M:TUV3]VARTEX([M:TUV3]NBLIG-1)     = [M:TUV3]VARTEX(I)
            Endif

            If [M:TUV2]ENDDAT(nolign-1)= [M:TUV3]ENDDAT(I)
                Dela I,1,I [M:TUV3]NBLIG
            Endif
        Goto NEXTI
        Endif
    Elsif [M:TUV2]STRDAT(nolign-1)=[M:TUV3]ENDDAT(I)
      If [M:TUV3]STRDAT(I)<[M:TUV3]ENDDAT(I)
        [M:TUV3]ENDDAT(I) = [M:TUV2]STRDAT(nolign-1)-1
        [M:TUV3]UPDDAT    = date$
        [M:TUV3]UPDUSR    = GUSER
        [M:TUV3]EXPNUM    = [C]EXPORT
        Goto NEXTI
      Else
        Dela I,1,I [M:TUV3]NBLIG
      Endif
    Endif

    If ([M:TUV2]ENDDAT(nolign-1)>[M:TUV3]STRDAT(I)) & ([M:TUV2]ENDDAT(nolign-1)<=[M:TUV3]ENDDAT(I))
       # débordement à gauche
        If [M:TUV2]STRDAT(nolign-1)<[M:TUV3]STRDAT(I)
           If [M:TUV3]ENDDAT(I)= [M:TUV2]ENDDAT(nolign-1)
                        Dela I,1,I [M:TUV3]NBLIG
           Else
                [M:TUV3]STRDAT(I) = [M:TUV2]ENDDAT(nolign-1)+1
                [M:TUV3]UPDDAT    = date$
                [M:TUV3]UPDUSR    = GUSER
                [M:TUV3]EXPNUM    = [C]EXPORT
           Endif
        Endif
        Goto NEXTI
    Elsif [M:TUV2]ENDDAT(nolign-1)=[M:TUV3]STRDAT(I)
        If [M:TUV3]ENDDAT(I)>[M:TUV3]STRDAT(I)
            [M:TUV3]STRDAT(I) = [M:TUV2]ENDDAT(nolign-1)+1
            [M:TUV3]UPDDAT    = date$
            [M:TUV3]UPDUSR    = GUSER
            [M:TUV3]EXPNUM    = [C]EXPORT
        Else
            Dela I,1,I [M:TUV3]NBLIG
        Endif
        Goto NEXTI
    Endif

    # débordement des 2 côtés
    If ([M:TUV2]STRDAT(nolign-1)<[M:TUV3]STRDAT(I)) & ([M:TUV2]ENDDAT(nolign-1)>[M:TUV3]ENDDAT(I))
        Dela I,1,I [M:TUV3]NBLIG
    Endif
$NEXTI
Next I

I+=WNEWLIN
# écriture de la nouvelle variation de capacité
[M:TUV3]STRDAT(I)     = [M:TUV2]STRDAT(nolign-1)
[M:TUV3]ENDDAT(I)     = [M:TUV2]ENDDAT(nolign-1)
[M:TUV3]CODVAR(I)     = [M:TUV2]CODVAR(nolign-1)
[M:TUV3]TWD(I)        = [M:TUV2]VARTWD(nolign-1)
[M:TUV3]WSTNBR(I)     = [M:TUV2]VARWSTNBR(nolign-1)
[M:TUV3]VARTEX(I)     = [M:TUV2]VARTEX(nolign-1)
[M:TUV3]UPDDAT        = date$
[M:TUV3]UPDUSR        = GUSER
[M:TUV3]EXPNUM        = [C]EXPORT
[M:TUV3]NBLIG         +=1

Sorta [M:TUV3]NBLIG [M:TUV3]NBLIG  Order By [M:TUV3]STRDAT(indice)

# Report dans la table CAPVAR du contenu du tableau [TUV3]
For I=0 To [M:TUV3]NBLIG-1
    If [M:TUV3]STRDAT(I)<>[0/0/0]
        [F:CPV]STRDAT([M:TUV3]NBLINE)     = [M:TUV3]STRDAT(I)
        [F:CPV]ENDDAT([M:TUV3]NBLINE)     = [M:TUV3]ENDDAT(I)
        [F:CPV]CODVAR([M:TUV3]NBLINE)     = [M:TUV3]CODVAR(I)
        [F:CPV]TWD([M:TUV3]NBLINE)        = [M:TUV3]TWD(I)
        [F:CPV]WSTNBR([M:TUV3]NBLINE)     = [M:TUV3]WSTNBR(I)
        [F:CPV]VARTEX([M:TUV3]NBLINE)     = [M:TUV3]VARTEX(I)
        [F:CPV]UPDDAT        = date$
        [F:CPV]UPDUSR        = GUSER
        [F:CPV]EXPNUM        = [C]EXPORT
        [M:TUV3]NBLINE+=1
        Rewrite [CPV]
        If fstat
            GOK = 0: Call FSTA("CPV") From GLOCK
            Goto AB_MOD
        Endif
    Endif
Next I


WMESS1=mess(52,197,1)-[M:TUV2]WCRFCY-"/"-[M:TUV2]WST(nolign-1)
Call ECR_TRACE(WMESS1,0) From GESECRAN

NBMODIF +=1

Return

#########################################################################
$ABORT
Raz [M:TUV2]
Affzo [M:TUV2]
Gosub LIRE
Return

#########################################################################
$FIN
If dim(FORMULE1)>0 : Kill  FORMULE1  : Endif
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3

Return

#########################################################################
$ROLL_MODMWS
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : End
Else Goto MAJMWS : Endif

#########################################################################
$AB_MOD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
# mm 12.02
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

