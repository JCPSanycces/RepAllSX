########################################
Subprog AM_WCRDEB(VALEUR)
Variable Char    VALEUR()
If [M]WCRFIN="" : [M]WCRFIN = VALEUR : Endif
If [M]WCRFIN < VALEUR : [M]WCRFIN = VALEUR : Endif

End

########################################
Subprog AM_WSTTYPDEB(VALEUR)
Variable Integer VALEUR
If VALEUR<> 0 : [M]WSTTYPFIN = VALEUR : Endif
End

########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If [M]WSTFIN="" : [M]WSTFIN = VALEUR : Endif
If [M]WSTFIN < VALEUR : [M]WSTFIN = VALEUR : Endif

End

########################################
Subprog C_WSTTYPFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]WSTTYPDEB : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_VSTRDAT(VALEUR)
Variable Date    VALEUR

If [M]VENDDAT=[0/0/0] : [M]VENDDAT= VALEUR  : Endif
If [M]VENDDAT< VALEUR : [M]VENDDAT = VALEUR : Endif

End
########################################
Subprog C_VENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]VSTRDAT : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End


########################################
Subprog C_VCODVAR(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:DIA]VSTRDAT<>[0/0/0]
    GERR=1 : mkstat =2 : GMESSAGE = mess(10,123,1)
Endif
End

########################################
Subprog C_VVARTWD(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:DIA]VSTRDAT<>[0/0/0]
    GERR=1 : mkstat =2 : GMESSAGE = mess(10,123,1)
Endif

End


########################################
# Demande n° 19593 10.03 MM
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR


If VALEUR > [M]ENDDAT(nolign-1)
    mkstat=1 : GMESSAGE=mess(90,121,1) : VALEUR = [M]STRDAT(nolign-1)
Endif


# La modif de la date provoque un chevauchement ?
If [M:TUV2]FWRITE(nolign-1)=0
    Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
    WMAXVAR = dim([F:CPV]STRDAT(I))
    If !fstat
        I=0
        While [F:CPV]STRDAT(I)<> [0/0/0]
            If (VALEUR >=[F:CPV]STRDAT(I) & VALEUR <=[F:CPV]ENDDAT(I))
                # il y a chevauchement
                If [M]IOVERLAP(nolign-1)=0 : [M]IOVERLAP(nolign-1) =1 : Endif
                If [M]IOVERLAP(nolign-1)=2 : [M]IOVERLAP(nolign-1) =3 : Endif
                [M:TUV2]FWRITE(nolign-1)=1
                Break
            Endif
            I+=1
            If I=WMAXVAR : Break : Endif
        Wend
    Endif
Elsif [M:TUV2]FWRITE(nolign-1)=1
# La modif de la date annule le chevauchement ?
    Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
    WMAXVAR = dim([F:CPV]STRDAT(I))
    If !fstat
        I=0
        While [F:CPV]STRDAT(I)<>[0/0/0]
          If [M:TUV2]ENDDAT(nolign-1)>=[F:CPV]STRDAT(I)
            If VALEUR>[F:CPV]STRDAT(I) & VALEUR>[F:CPV]ENDDAT(I)    # il n'y a pas chevauchement
                I+=1
                If I=WMAXVAR : Break : Endif
            Else End Endif
          Else
            I+=1
            If I=WMAXVAR : Break : Endif
          Endif
        Wend
        [M:TUV2]FWRITE(nolign-1)=0
        If [M]IOVERLAP(nolign-1)<>0 : [M]IOVERLAP(nolign-1)=0  : Endif
    Endif
Endif

End

########################################
# Demande n° 19593 10.03 MM
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

If VALEUR < [M]STRDAT(nolign-1)
    mkstat=1 : GMESSAGE= mess(90,121,1) : VALEUR = [M]ENDDAT(nolign-1)
Endif


# La modif de la date provoque un chevauchement ?
If [M:TUV2]FWRITE(nolign-1)=0
    Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
    WMAXVAR = dim([F:CPV]STRDAT(I))
    If !fstat
        I=0
        While [F:CPV]STRDAT(I)<> [0/0/0]
            If (VALEUR >=[F:CPV]STRDAT(I) & VALEUR <=[F:CPV]ENDDAT(I))
            # il y a chevauchement
                If [M]IOVERLAP(nolign-1)=0 : [M]IOVERLAP(nolign-1) =2 : Endif
                If [M]IOVERLAP(nolign-1)=1 : [M]IOVERLAP(nolign-1) =3 : Endif
                [M:TUV2]FWRITE(nolign-1)=1
                Break
            Endif
            I+=1
            If I=WMAXVAR : Break : Endif
        Wend
    Endif
Elsif [M:TUV2]FWRITE(nolign-1)=1
# La modif de la date annule le chevauchement ?
    Read [CPV]CPV0=[M:TUV2]WST(nolign-1);[M:TUV2]WCRFCY
    WMAXVAR = dim([F:CPV]STRDAT(I))
    If !fstat
        I=0
        While [F:CPV]STRDAT(I)<> [0/0/0]
          If [M:TUV2]STRDAT(nolign-1) <=[F:CPV]ENDDAT(I)
            If VALEUR <[F:CPV]STRDAT(I) & VALEUR < [F:CPV]ENDDAT(I)         # il n'y a pas chevauchement
                I+=1
                If I=WMAXVAR : Break : Endif
            Else : End : Endif
          Else
            I+=1
            If I=WMAXVAR : Break : Endif
          Endif
        Wend
        [M:TUV2]FWRITE(nolign-1)=0
        If [M]IOVERLAP(nolign-1)<>0 : [M]IOVERLAP(nolign-1)=0  : Endif
    Endif
Endif



End

########################################
# mm 12.02
Subprog AM_WCRFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM
Endif
End

