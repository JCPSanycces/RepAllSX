#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Copie écran LECFIC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Copy LECFIC mask") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub COPMSK
End

#-------------------#
$COPMSK

Local Integer I , VALMOD(20)

If DOSSIER=GDOSX3
 Return
Endif
If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

Call ECR_TRACE("Update LECFIC mask:"-time$,0) From GESECRAN

Call COPOBJ(GDOSX3,DOSSIER,"AMK","LECFIC","","","") From ACOPIE

# Validation de l'écran

#Call VALID_TRT(DOSSIER,0,"","","","","","","LECFIC","LECFIC","","","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(DOSSIER,0,"","","","","","","LECFIC","LECFIC","","","","","","","","","","","","",VALMOD) From VALDICO

Return
