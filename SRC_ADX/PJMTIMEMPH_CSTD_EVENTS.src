#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMPH
###################################################################################################
# EVENTS
###################################################################################################
$AREAD_AFTER
  # Issue X3-94962 - 2018-06-20 by FGR
  Local File PJMTIMEMP [PTE]
  # ------------------------------------
  this.TCHPTESEQ = 0
  Filter [PTE] Where [F:PTE]CLB = this.CLB Order By Key KEY0=[F:PTE]CLB;[F:PTE]PTESEQ Desc
  For [PTE]KEY0
    this.TCHPTESEQ = [F:PTE]PTESEQ
    Break
  Next
  Filter [PTE]
Return

###################################################################################################
$ACONTROL
  Local File PJMAUS [PAUS]
  # ------------------------------------
  # 1) The user has to be authorised for PJM
  Read [PAUS]PAUS=this.ACTX.USER
  If !fstat Then
    If [F:PAUS]ENAFLG = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(221,2260,1), this.ACTX.USER),[V]CST_AERROR))
    Else
      If [F:PAUS]PAUSPA <> [V]CST_AYES and [F:PAUS]PAUSTT <> [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(222,2260,1), this.ACTX.USER),[V]CST_AERROR))
      Endif
    Endif
  Else
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(221,2260,1), this.ACTX.USER),[V]CST_AERROR))
  Endif
Return

###################################################################################################
$TIMENT_ADELLINE_BEFORE
  If this.ASTALIN = [V]CST_ADEL Then
    If this.snapshot.TIMENT([L]ALINE).PTESTA <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(338,2260,1), mess(this.TIMENT([L]ALINE).PTESTA,2074,1)), [V]CST_AERROR))
    Endif
  Endif
  If this.TIMENT([L]ALINE).PTESTA <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(338,2260,1), mess(this.TIMENT([L]ALINE).PTESTA,2074,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$TIMENT_ADDLINE_AFTER
  # Issue X3-94962 - 2018-06-20 by FGR : BEGIN
  #IPTESEQ = max(this.APARENT.TIMENT(1..maxtab(this.APARENT.TIMENT)).PTESEQ)
  #IPTESEQ += 10
  #this.PTESEQ = IPTESEQ
  this.APARENT.TCHPTESEQ += 10
  this.PTESEQ = this.APARENT.TCHPTESEQ
  # Issue X3-94962 - 2018-06-20 by FGR : END
Return

###################################################################################################
$TIMENT_AINSERT_AFTER
  # Issue X3-111733 - 2018-10-08 by FGR : BEBIN : Move from PJMTIMEMP level
  [L]ASTATUS = max([L]ASTATUS, fmet this._PJM_TASK_TIMEENTRY(this.APARENT))
Return

###################################################################################################
$TIMENT_AUPDATE_AFTER
  # Issue X3-111733 - 2018-10-08 by FGR : BEBIN : Move from PJMTIMEMP level
  [L]ASTATUS = max([L]ASTATUS, fmet this._PJM_TASK_TIMEENTRY(this.APARENT))
Return

###################################################################################################
$TIMENT_ADELETE_AFTER
  # Issue X3-111733 - 2018-10-08 by FGR : BEBIN : Move from PJMTIMEMP level
  [L]ASTATUS = max([L]ASTATUS, fmet this._PJM_TASK_TIMEENTRY(this.APARENT))
Return

