#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################################
# UTICLMAn 
# Utility program for patches for cloud manager profil
#
################################################################################
End
#######################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(FOLDERNAME)
Value Char FOLDERNAME
  Call ECR_TRACE("UTICLMAN : Update profil for customer administrator for Folder "+FOLDERNAME,0) From GESECRAN
# ici il faut ouvrir les tables dans le dossier à patcher sinon ne marche pas
#
If clalev([F:AFT])   = 0 : Local File =FOLDERNAME+".AFCTFCT"   [AFT]  : Endif
If clalev([F:AFF])   = 0 : Local File =FOLDERNAME+".AFCTFCY"   [AFF]  : Endif
If clalev([F:AFC])   = 0 : Local File =FOLDERNAME+".AFONCTION" [AFC]  : Endif
If clalev([F:AFP1])  = 0 : Local File =FOLDERNAME+".AFCTPRF"   [AFP1] : Endif
If clalev([F:FCY])   = 0 : Local File =FOLDERNAME+".FACILITY"  [FCY]  : Endif
If clalev([F:FGRA])  = 0 : Local File =FOLDERNAME+".FACGROUP"  [FGRA] : Endif

  # Update AFCTFCY (AFF) records for CLMAN based on AFCTPRF (AFP) records
  Call MAJAFF("CLMAN") From SUBAFP1

  Call ECR_TRACE("UTICLMAN : end process ",0) From GESECRAN

End






