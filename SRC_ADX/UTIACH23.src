#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIACH23      Utilitaire de remplissage du numéro         Module ACHAT #
#               d'engagement sur les lignes de                           #
#               factures d'achat                              17/09/2010 #
# ---------------------------------------------------------------------- #
#   Charger dans l'enregistrement PINVOICED le champ suivant :           #
#     [F:PID]CMMNUM                                                      #
##########################################################################


Call MAJ_UTIACH23
End


Subprog MAJ_UTIACH23
Local Char DOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle WSIMUL  : WSIMUL=0     : # 0=normale, 1=simulation (pas de màj)
DOSSIER=nomap
#--- Issue 108760 by TS
#Call SAIDOS(DOSSIER,"UTIACH23 - Màj no engagement sur lignes facture PINVOICED") From SAIDOS
Call SAIDOSHIS(DOSSIER,"UTIACH23 - Màj no engagement sur lignes facture PINVOICED") From SAIDOSHIS
#---
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH23 : Màj no engagement sur lignes facture PINVOICED") From LECFIC
  Call ECR_TIME("UTIACH23 : Starting process on folder "+DOSSIER) From DOSSUB
  Call EXE_UTIACH23(DOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH23(DOSSIER,WTRACE,WSIMUL)
Value Char     DOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL
#----- Variables locales -----#
Local Char     WMSG(90)
Local Integer  NBENR, NBCOR, NBPIH, NBPOH, NBPOQ, NBCMM
Local Char     CLE1(GLONPIH)
Local Integer  CLE2
Local Char     CRITERE(150)
Local Integer  COMPTEUR, STOP
Local Char     WCMMNUM(GLONVCR)
Local Decimal  WAMTCUR
Local Char     WPIHNUM(GLONPIH)
Local Integer  WPIDLIN
# Issue 74046 - 2011-05-26 by VPO : pb valeur du code activité sur le dossier
#Local Char     WTAB_CMMNUM(GLONVCR)(max(func AFNC.ACTIV("PIH"),100))
Local Char     WTAB_CMMNUM(GLONVCR)(max(func AFNC.ACTIVDOS(DOSSIER,"PIH"),100))
Local Integer  WTAB_NBLIG
# Issue 74046 - 2011-05-26 by VPO : pb valeur du code activité sur le dossier
#Local Char     WTAB_CMMNUM2(GLONVCR)(max(func AFNC.ACTIV("POH"),100))
Local Char     WTAB_CMMNUM2(GLONVCR)(max(func AFNC.ACTIVDOS(DOSSIER,"POH"),100))
Local Integer  WTAB_NBLIG2
Local Libelle  WFLAG
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif
#----- Ouverture des tables -----#
If !clalev([F:PIH])  Local File =DOSSIER+".PINVOICE"  [PIH]  : Endif
If !clalev([F:PID])  Local File =DOSSIER+".PINVOICED" [PID]  : Endif
If !clalev([F:POH])  Local File =DOSSIER+".PORDER"    [POH]  : Endif
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ]  : Endif
If !clalev([F:POP])  Local File =DOSSIER+".PORDERP"   [POP]  : Endif
If !clalev([F:CMM])  Local File =DOSSIER+".GCOMMIT"   [CMM]  : Endif
If !clalev([F:CMD])  Local File =DOSSIER+".GCOMMITD"  [CMD]  : Endif
If !clalev([F:CMM2]) Local File =DOSSIER+".GCOMMIT"   [CMM2] : Endif
If !clalev([F:CMD2]) Local File =DOSSIER+".GCOMMITD"  [CMD2] : Endif
# Issue 79435 - 2012-01-20 by VPO : perf
#Link [CMD2] With [CMM2] CMM0=[F:CMD2]NUM As [CMX2]
Link [CMM2] With [CMD2] CMD0~=[F:CMM2]NUM As [CMX2]
#----- Début du traitement -----#
Gosub TRT_PINVOICED
#----- Fin du traitement -----#
$FIN_UTIACH23
If WTRACE
  If WTRACE=2
    If WSIMUL
      Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
    Else
      Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
    Endif
  Endif
  #-----
  WMSG ="Nbre d'entêtes fact introuvables ..:"-num$(NBPIH)
  Call ECR_TRACE(WMSG,0) From GESECRAN
  WMSG ="Nombre de commandes introuvables ..:"-num$(NBPOH)
  Call ECR_TRACE(WMSG,0) From GESECRAN
  WMSG ="Nombre de lignes cde introuvables .:"-num$(NBPOQ)
  Call ECR_TRACE(WMSG,0) From GESECRAN
  WMSG ="Nombre d'engagements introuvables .:"-num$(NBCMM)
  Call ECR_TRACE(WMSG,0) From GESECRAN
  #-----
  WMSG ="UTIACH23 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Close Local File [PIH], [PID], [POH], [POQ], [F:POP], [CMM], [CMD], [CMX2], [CMM2], [CMD2]
End


#------------#
# Traitement #
#------------#
$TRT_PINVOICED
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, NBENR, NBCOR, NBPIH, NBPOH, NBPOQ, NBCMM, STOP
Raz WPIHNUM, [F:POH]
#-----
$BOUCLE_PID
If STOP=1
  STOP=2 : CRITERE ='NUM="'+CLE1+'"'+' & PIDLIN>'+num$(CLE2)
Elsif STOP=2
  STOP=0 : CRITERE ='NUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PID]
  For [PID] PID0 Where evalue(CRITERE) & POHNUM<>"" & CMMNUM=""
    #-----
    Raz WFLAG
    NBENR+=1
    #----- Effacement des numéros d'engagement pris si autre facture -----#
    If [F:PID]NUM<>WPIHNUM
      Raz WTAB_CMMNUM, WTAB_NBLIG
    Endif
    #-----
    WPIHNUM=[F:PID]NUM
    WPIDLIN=[F:PID]PIDLIN
    #----- Lecture entête de facture -----#
    If [F:PIH]NUM<>[F:PID]NUM
      Read [PIH] PIH0=[F:PID]NUM
      If fstat
        NBPIH+=1
        If WTRACE=2
          WMSG=[F:PID]NUM-"Facture introuvable !"
          Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
        Goto SUITE_PID
      Endif
    Endif
    #----- Lecture entête de commande -----#
    If [F:POH]POHNUM<>[F:PID]POHNUM
      Read [POH] POH0=[F:PID]POHNUM
      If fstat
        NBPOH+=1
        If WTRACE=2
          WMSG=[F:PID]POHNUM-mess(359,197,1)
          Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
        Raz [F:POH]
        Goto SUITE_PID
      Else
        #----- Chargement des numéros d'engagement des lignes de la commande -----#
        Raz WTAB_CMMNUM2, WTAB_NBLIG2
        For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
          If [F:POQ]CMMNUM<>""
            WTAB_CMMNUM2(WTAB_NBLIG2)=[F:POQ]CMMNUM : WTAB_NBLIG2+=1
          Endif
        Next
      Endif
    Endif
    #----- Lecture ligne de commande -----#
    Read [POQ] POQ0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
    If fstat
      NBPOQ+=1
      If WTRACE=2
        WMSG=[F:PID]POHNUM-num$([F:PID]POPLIN)-num$([F:PID]POQSEQ)-mess(360,197,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Elsif [F:POQ]CMMNUM<>""
      WCMMNUM=[F:POQ]CMMNUM
      #----- Lecture ligne prix de commande -----#
      If [F:POQ]POHTYP=1
        Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
        If fstat Raz [F:POP] : Endif
      Else
        Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                          POPDAT>=[F:POQ]DEMRCPDAT
        Read [POP] POP1 First
        If fstat : Raz [F:POP] : Endif
        Filter [POP]
      Endif
      #-----
      WAMTCUR=-[F:PID]QTYBUDLIN*[F:POP]NETPRI/[F:POQ]UOMPUUCOE
      Call ARRDEV(WAMTCUR,[F:POH]CUR) From TRTDIV
      #-----
      Read [CMM] CMM0=[F:POQ]CMMNUM
      If fstat
        NBCMM+=1
        If WTRACE=2
          WMSG=[F:POQ]CMMNUM-"Engagement introuvable !"
          Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
      Else
        If [F:PIH]STA=3
          #----- Recherche engagements pointés par la facture -----#
          #----- Recherche engagements pointés par la facture -----#
          # Issue 79435 - 2012-01-20 by VPO : perf : ajout hint key CMM1
          For [CMX2] Hint Key CMM1 Where [F:CMM2]TYP   =[F:CMM]TYP
&                        & [F:CMM2]FCY   =[F:CMM]FCY
&                        & [F:CMM2]BPR   =[F:CMM]BPR
&                        & [F:CMM2]CUR   =[F:CMM]CUR
&                        & [F:CMM2]NUMREF=[F:PID]NUM
&                        & [F:CMM2]TYPORG=[F:CMM]TYPORG
&                        & [F:CMM2]NUMORG=[F:CMM]NUMORG
&                        & [F:CMD2]AMTCUR=WAMTCUR
            If find([F:CMM2]NUM,WTAB_CMMNUM (0..WTAB_NBLIG ))=0
&            & find([F:CMM2]NUM,WTAB_CMMNUM2(0..WTAB_NBLIG2))=0
              WTAB_CMMNUM(WTAB_NBLIG)=[F:CMM2]NUM : WTAB_NBLIG+=1
              WCMMNUM=[F:CMM2]NUM
              WFLAG=1
              Break
            Endif
          Next
        Endif
        #-----
      Endif
      #----- Mise à jour de la ligne de facture si nécessaire -----#
      COMPTEUR+=1
      Update [PID] Where NUM=WPIHNUM & PIDLIN=WPIDLIN
&                  With CMMNUM=WCMMNUM
      If fstat
        WMSG=mess(13,100,1)-"PINVOICED"-WPIHNUM-num$(WPIDLIN)
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
      Elsif WFLAG
        NBCOR+=1
        If WTRACE=2
          WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"CMMNUM ="-WCMMNUM
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
      Endif
      #-----
    Else
      NBENR-=1 : # Ligne commande sans engagement !
    Endif
    #-----
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN
      STOP=1 : Break
    Endif
    #-----
$SUITE_PID
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_PID : Endif
#-----
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(DOSSIER)=0 : End : Endif
#---
#ssi modules achats et compta
If [F:ADS]MODULE(5)=2 & [F:ADS]MODULE(1)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","PINVOICED","fde",DOSSIER),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(DOSSIER,"PINVOICED") : End : Endif                  : # For Archive folder
  #---
  Call ECR_TRACE("UTIACH23 : Màj no engagement sur lignes facture PINVOICED",0) From GESECRAN
  Call EXE_UTIACH23(DOSSIER,1,0)
Endif
#-----
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
#ssi modules achats et compta
If [F:ADS]MODULE(5)=2 & [F:ADS]MODULE(1)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","PINVOICED","fde",DOSSIER),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(DOSSIER,"PINVOICED") : End : Endif                  : # For Archive folder
  #---
  Call ECR_TRACE("UTIACH23 : Màj no engagement sur lignes facture PINVOICED",0) From GESECRAN
  Call EXE_UTIACH23(DOSSIER,1,0)
Endif
#-----
End

