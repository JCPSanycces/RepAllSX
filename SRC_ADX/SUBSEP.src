#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

######################################################################################
$INIT
Local Mask SEP1 [DIA]
If !clalev([F:SEP]) : Local File SEPAR [SEP] : Endif
Lock [SEP]
If fstat
  GBIDI1 = 1 : # Lock out other users
  GCONSDIA = 1
Else
  GBIDI1 = 0
  GCONSDIA = 0
Endif
Read [SEP]SEP0 First
If fstat
  Raz [M:DIA]
Else
  [M:DIA] = [F:SEP]
Endif
If [M:DIA]VTURL="" : [M:DIA]VTURL = "https://www.SagePayments.net/VirtualTerminal/" : Endif   # 101091.n
If [M:DIA]POLL=0   : [M:DIA]POLL   = 60                                             : Endif   # 101091.n

# 109235.sn
If [M:DIA]USEPRDURL=0 : [M:DIA]USEPRDURL=1  : Endif

Call UPDATE_SPURL([M:DIA]USEPRDURL)
# 109235.en

Return

######################################################################################
$EXEC
If !GBIDI1
  Call DEBTRANS From GLOCK
  Gosub TR1
Endif
Return

######################################################################################
$TR1
GOK = 1
Trbegin [SEP]
Readlock [SEP]SEP0 First
If fstat=1
  GOK = -1 : GLOCK = "$SEPAR" : Goto ROLL_TR1
Endif
[F:SEP] = [M:DIA]
# Default Virtual payment terminal URL, Application ID, and Poll duration
If [F:SEP]JAVSRV=""   : [F:SEP]JAVSRV = "SEPAR"                                                : Endif  # 101091.n
If [F:SEP]POLL=0      : [F:SEP]POLL   = 60                                                     : Endif
If [F:SEP]USEPRDURL=0 : [F:SEP]USEPRDURL=1                                                     : Endif # 109235.n

If fstat
  Write [SEP]
Else
  Rewrite [SEP]
Endif
If fstat
  GOK = 0 : Call FSTA("SEP") From GLOCK : Goto AB_TR1
Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################
$SORTIE
If !GBIDI1
  Read [SEP]SEP0 First                                               # 105786.sn
  If fstat
    [M:DIA]VTURL = "https://www.SagePayments.net/VirtualTerminal/"
    [M:DIA]POLL   = 60
    Gosub EXEC
  Endif                                                              # 105786.en
  Unlock [SEP]
Endif
Raz GBIDI1
Raz GCONSDIA
Return

######################################################################################
Subprog DEFAULT_RECORD()                                             # 105786.sn
  Gosub INIT
  Gosub EXEC
End                                                                  # 105786.en

