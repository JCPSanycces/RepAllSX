######################################################################################
Subprog C_VTURL(VALEUR)
Variable Char VALEUR()

If VALEUR =""
  Diszo [M:DIA]VTBUT
Else
  Call VALIDATE_URL(VALEUR) # 109235.n
Endif

End

######################################################################################
Subprog CL_VTBUT(VALEUR)
Variable Char VALEUR()

Call OPEN_URL([M:DIA]VTURL) # 109235.n

End

######################################################################################
Subprog C_SPURL(VALEUR)
Variable Char VALEUR()

If VALEUR =""
  Diszo [M:DIA]SPBUT
Else
  Call VALIDATE_URL(VALEUR) # 109235.n
Endif

End

######################################################################################
Subprog CL_SPBUT(VALEUR)
Variable Char VALEUR()

Call OPEN_URL([M:DIA]SPURL) # 109235.n

End

######################################################################################
# 109235.sn
# Sage Pay URL field will be updated based in URL Type.
Subprog C_USEPRDURL(VALEUR)
Variable Integer VALEUR

Raz [M:DIA]SPURL
Call UPDATE_SPURL(VALEUR)
Affzo [M:DIA]SPURL

End
# 109235.en

# 109235.sn
# Ensure that URL starts with HTTP or HTTPS
######################################################################################
Subprog VALIDATE_URL(URL)
Value Char URL

ILOC = instr(1, toupper(URL), "HTTP://")
If ILOC <> 1
  ILOC = instr(1, toupper(URL), "HTTPS://")
  If ILOC <> 1
    #URL must begin with HTTP:// or HTTPS://
    GMESSAGE = mess(57,2092,1)
    mkstat = 2 : End
  Endif
Endif

End
# 109235.en

# 109235.sn
# Launch URL
######################################################################################
Subprog OPEN_URL(URL)
Value Char URL
Local Integer ILOC
Local Char PARSEDURL(250), PREFIX(8)

PARSEDURL = URL

ILOC = instr(1, PARSEDURL, "://")
PREFIX = toupper(left$(PARSEDURL,ILOC-1))
PARSEDURL = right$(PARSEDURL,ILOC+3)

Local Char RETOUR (250) : Raz RETOUR
Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+chr$(1) + PREFIX,
& "UILocalFile="+ chr$(1) + PARSEDURL

End
# 109235.en

# 109235.sn
# Sage Pay URL field will be updated based in URL Type.
######################################################################################
Subprog UPDATE_SPURL(URLTYPE)
Value Integer URLTYPE

If URLTYPE = 1
  [M:DIA]SPURL = "https://test.sagepay.com/mysagepay"
Else
  [M:DIA]SPURL = "https://live.sagepay.com/mysagepay"
Endif
End
# 109235.en

