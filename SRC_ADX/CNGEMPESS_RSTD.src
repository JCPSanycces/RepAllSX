#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CNGEMPESS
$EVENTS
Return

$METHODS
Case [L]CURPTH
   When ""
    Case [L]ACTION
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return


$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return



$AQUERY_CRITERIA_AFTER

Local Integer FYEAR
Local Char VREFNUM(GLONMAT)
Local Date NOWDATE : NOWDATE = date$
Local Char FULLFORMDATE(10)

FULLFORMDATE = num$(year(date$))+"-"+num$(month(date$))+"-"+num$(day(date$))

VREFNUM = func GET_INIT_REFNUM()
If VREFNUM = AVOID.ACHAR : Return : Endif
If func AFNC.ACTIV("KSA")>0
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and EMPLEASTR le @"+FULLFORMDATE+"@ and EMPLEAEND ge @"+FULLFORMDATE+"@"
  Else
    PQRY.QWHERE = "EMPLEASTR le @"+FULLFORMDATE+"@ and EMPLEAEND ge @"+FULLFORMDATE+"@"
  Endif
Else
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and YEA eq "+num$(year(date$))
  Else
    PQRY.QWHERE = "YEA eq "+num$(year(date$))
  Endif
Endif

Return

Funprog GET_INIT_REFNUM
Local Integer INITRESULT
Local Char REFNUM_RETURN(GLONMAT)

Local Instance I_CNGEMPESS Using C_CNGEMPESS
If (I_CNGEMPESS <> null) : FreeGroup I_CNGEMPESS : Endif
I_CNGEMPESS = NewInstance C_CNGEMPESS AllocGroup null

INITRESULT = fmet I_CNGEMPESS.AINIT()
If INITRESULT = [V]CST_AOK
  REFNUM_RETURN = fmet I_CNGEMPESS.ACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Endif
End REFNUM_RETURN

