#<AdxTL>@(#)9.0.0.0 $Revision$
#---------------------------------------------------#
# LIGNES BUDGÉTAIRES POUR LES BUDGETS OPÉRATIONNELS
# Check if INDENT>0 & INDENV>0 if we come from CNSGDDSTD : In CNSGDDSTD, inquiry of GDD company with level 4/5
# then change the company with a non GDD company and go on a line to run TRTBUL.
#---------------------------------------------------#
Local Char PARAM(10)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"BUDLIG","TRTBUL","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_ENR"    : Gosub AVANT_ENR
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When Default
Endcase
Return

$OUVRE
#03/03/08 : Gestion des approbations
Global Char GAPPNIV(3)
Local Mask BUDLIG [BUDL]
Local Char    ENVELOPPE(GLONENV),SOCIETE(GLONCPY),ENVCUR(GLONENV)
Local Integer EXOCUR
Local Integer VERROU
Local Char    SYMBOLE(30)
Local Integer AX
Local Integer INDENT, INDENV, INDCCE3 : # Index of each dimension in the ledger

#Tables utiles
If !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If !clalev([F:BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([F:BUV]) : Local File BUDVER     [BUV] : Endif
If !clalev([F:BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([F:BUA]) : Local File BUDPURAUD  [BUA] : Endif
If !clalev([F:ENT]) : Local File ENTITE     [ENT] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([F:ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([F:LED]) : Local File GLED       [LED] : Endif
If !clalev([F:GCM]) : Local File GACM       [GCM] : Endif
If !clalev([F:DIE]) : Local File GDIE       [DIE] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif

Raz [M:BUDL]
Actzo [M:BUDL]NBLIG
Return

$DEBUT
Local Mask [M:BUDL]
REP = ""
#Chargement des paramètres
If PARAM(1)<>"" & PARAM(2)<>""
 ENVCUR = PARAM(1)
 EXOCUR = val(PARAM(2))
 Read [ENF]ENF0 = PARAM(1);val(PARAM(2))
 If fstat
  #Le budget exercice (ou ventilation de l'enveloppe sur l'exercice) doit exister
  GMESSAGE=mess(122,108,1)
  FIN=1
 Endif
 If val(PARAM(3))<>0
  Read [BUD]BUD1 = val(PARAM(3))
  If fstat
   #Ligne inexistante
   GMESSAGE=mess(139,105,1)
   FIN=1
  Endif
 Endif
 Call CHARGE_CHP(PARAM(1),val(PARAM(2)),val(PARAM(3)))
 Affzo [M]
Endif
Return

$FIN
# Si appel de la fonction "lignes budgétaires" à partir du menu alors il faut poser verrou
# Si appel de la fonction "lignes budgétaires" à partir de la gestion des enveloppes, alors le verrou est déjà posé
If GFONCTION1="BUDLIG"
 Gosub DEVERROU
Endif
# Si appel de la fonction "lignes budgétaires" à partir de la gestion des enveloppes, il faut repasser dans le SETBOUT
# de la gestion des enveloppes
If dim(GCHKBUD)>0 & GCHKBUD=1 : mkstat=4 : Endif
Return

$SETBOUT
Raz ETABOU
If REP="M"
 Local Integer OKACC
 Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
 If OKACC
  ETABOU(GENRE) = 1
  ETABOU(GABAN) = 1
 Endif
Endif
ETABOU(GBFIN) = 1
Call SETBOUT(ETABOU) From GESECRAN
Return

$ABANDON
Gosub RELIT
Gosub DEGRISE
REP = ""
Return

$RELIT
Gosub VERROU
Call CHARGE_CHP(ENVCUR,EXOCUR,0)
Affzo [M]
Return

$DEGRISE
Actzo ENV,FIY
Return


$AVANT_ENR
#Si il existe une révision en cours sur l'enveloppe sur le budget pas de modification possible
Local Integer BRV : BRV=1
For [BRV]BRV0 Where STA=2
 If [F:BRV]TYP=1 & [F:BRV]ENV=[M:BUDL]ENV & [F:BRV]FIY=0 & [F:BRV]ACCNUM=0 : BRV=0 : Break : Endif
 If [F:BRV]TYP=2 & [F:BRV]ENV=[M:BUDL]ENV & [F:BRV]FIY=[M:BUDL]FIY & [F:BRV]ACCNUM=0 : BRV=0 : Break : Endif
Next
If !BRV
 #Objet de l'enveloppe en cours de révision. Modification impossible.
 GERR=1
 GMESSAGE=mess(181,108,1)
 FOK=0
Endif
Return

$APRES_MODIF
Case COUZON
 When "ENV", "FIY"
  If GFONCTION1="BUDLIG" : Gosub DEVERROU : Endif
  Case evalue("type([M]"+COUZON+")")
   When 1,2,4,5,6,7,8,9 : Assign "[M]"+COUZON With val(CZ)
   When Default         : Assign "[M]"+COUZON With CZ
  Endcase
  REP = ""
  ENVCUR = [M]ENV
  EXOCUR = [M]FIY
  Gosub RELIT
  Gosub SETBOUT
 When Default
  If REP=""
   If GFONCTION1="BUDLIG"
    If VERROU
     REP = "M"
     Gosub SETBOUT
     Grizo ENV,FIY
    Else
     Gosub VERROU
     If !VERROU
      # Modification en cours sur un autre poste
      GERR = 1 : GMESSAGE = mess(10,100,1) : FOK=0 : Return
     Else
      Gosub RELIT
      REP = "M"
      Gosub SETBOUT
      Grizo ENV,FIY
     Endif
    Endif
   Else
    Gosub RELIT
    REP = "M"
    Gosub SETBOUT
    Grizo ENV, FIY
   Endif
  Endif
Endcase
Return

$VERROU
SYMBOLE = "ENV"+ENVCUR
Lock = SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

$DEVERROU
If VERROU
 Unlock =SYMBOLE
Endif
Return

$ENREG
Call DEBTRANS From GLOCK
Gosub TR1
REP = ""
Gosub DEGRISE
# Si appel de la fonction "lignes budgétaires" à partir de la gestion des enveloppes, GCHKBUD existe
# Elle permet de repasser dans le SETBOUT de la gestion des enveloppes
If dim(GCHKBUD)>0 : GCHKBUD=1 : Endif
Return

$TR1
GOK=1
Trbegin [BUD]

 # Suppression dans [BUD] des lignes effacées dans le tableau
 For nolign=1 To [M]NBDEL
  Delete [BUD] Where ACCNUM=[M]ACCNUMDEL(nolign-1)
  If fstat
   GOK=0 : Call FSTA("BUD") From GLOCK : Break
  Endif
 Next
 If !GOK : Goto AB_TR1 : Endif

 Call GETGDDINDDIE([M]CPY,[M]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD

 #Création/modif des lignes de budget
 For nolign=1 To [M]NBLIG
  Readlock [BUD]BUD1 = [M]ACCNUM(nolign-1)
  If fstat=1
   GOK = -1
   GLOCK = "$BUD"-num$([M]LEDTYP)-[M]BUD-[M]CPY-[M]FCY-num$([M]FIY)-"1"-[M]ACC(nolign-1)-[M]CCE1(nolign-1)-[M]CCE2-[M]CCE3(nolign-1)
   Break
  Elsif fstat
   #Nouvel enregistrement de la table BUD [BUD]
   Raz [F:BUD]
   [F:BUD]ACCNUM = uniqid([F:BUD])
   [F:BUD]BUD    = [M]BUD
   [F:BUD]CPY    = [M]CPY
   [F:BUD]FCY    = [M]FCY
   [F:BUD]FIY    = [M]FIY
   [F:BUD]LEDTYP = [M]LEDTYP
   [F:BUD]LED    = [M]LED
   [F:BUD]CUR    = [M]CUR
   [F:BUD]COA    = [M]COA
   If INDENT>0
    Assign "[F:BUD]DIE"+num$(INDENT) With [M]DIE(0)
    Assign "[F:BUD]CCE"+num$(INDENT) With [M]CCE1(nolign-1)
   Endif
   If INDENV>0
    Assign "[F:BUD]DIE"+num$(INDENV) With [M]DIE(1)
    Assign "[F:BUD]CCE"+num$(INDENV) With [M]CCE2(nolign-1)
   Endif
   If INDCCE3>0
    Assign "[F:BUD]DIE"+num$(INDCCE3) With [M]DIE(2)
    Assign "[F:BUD]CCE"+num$(INDCCE3) With [M]CCE3(nolign-1)
   Endif
   [F:BUD]VER    = "1"
   [F:BUD]ACC    = [M]ACC(nolign-1)
   [F:BUD]TEX    = [M]TEX(nolign-1)
   [F:BUD]AMT(0) = [M]AMT(nolign-1)
   [F:BUD]AMTATT = [M]AMTATT(nolign-1)
   [F:BUD]STA    = [M]STA(nolign-1)
   [F:BUD]LOT    = [M]LOT(nolign-1)
   [F:BUD]CREDAT = date$
   [F:BUD]CREUSR = GUSER
   Write [BUD]
   [M]ACCNUM(nolign-1)=[F:BUD]ACCNUM
  Else
   [F:BUD]CUR    = [M]CUR
   [F:BUD]ACC    = [M]ACC(nolign-1)
   [F:BUD]TEX    = [M]TEX(nolign-1)
   If INDENT>0
    Assign "[F:BUD]CCE"+num$(INDENT) With [M]CCE1(nolign-1)
   Endif
   If INDCCE3>0
    Assign "[F:BUD]CCE"+num$(INDCCE3) With [M]CCE3(nolign-1)
   Endif
   [F:BUD]AMT(0) = [M]AMT(nolign-1)
   [F:BUD]AMTAPP = [M]AMTAPP(nolign-1)
   [F:BUD]AMTATT = [M]AMTATT(nolign-1)
   [F:BUD]STA    = [M]STA(nolign-1)
   [F:BUD]LOT    = [M]LOT(nolign-1)
   [F:BUD]UPDDAT = date$
   [F:BUD]UPDUSR = GUSER
   Rewrite [BUD]
  Endif
  If fstat
   GOK=0 : Call FSTA("BUD") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#####
$SEL_LISTE
Case LISTE
 When "SELLOT" : Gosub S_LOT
Endcase
Return

$S_LOT
If !clalev([F:PJL]) : Local File PRJLOT [PJL] : Endif
Local Char TEXTE(GLONDES)(1..200,1..4)
TIT = mess(10,16,1) :# Choix
TIT(1)=mess(23,107,1) :# Lot
TIT(2)=mess(30,109,1) :# Intitulé
TIT(3)=mess(50,104,1) :# Montant
TIT(4)=mess(80,7771,1) :# Projet
For [PJL]PJL0 Where PRJ=PARAM(1)
 NBTEX += 1
 TEX(NBTEX)   = [F:PJL]LOT
 TEXTE(NBTEX,1) = [F:PJL]LOT
 TEXTE(NBTEX,2) = [F:PJL]DESLOT
 TEXTE(NBTEX,3) = num$([F:PJL]AMTLOT)
 TEXTE(NBTEX,4) = [F:PJL]PRJ
Next
Return


##########################################################
Subprog CHARGE_CHP(ENVELOPPE,EXERCICE,NUMERO)
Value Char    ENVELOPPE()
Value Integer EXERCICE
Value Integer NUMERO

Local Mask BUDLIG

#Enveloppe - Exercice
[M]ENV = ENVELOPPE
[M]FIY = EXERCICE

#Code budget et projet
Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
[M]BUD = [F:ENV]BUD
[M]PRJ = [F:ENV]PRJ
[M]CUR = [F:ENV]CURENV

#Code budget
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ

#Type de référentiel
Case [F:BUP]LEV
 When 1 : #Niveau societe
  [M]CPY=[F:ENV]FCY
  SOCIETE =[F:ENV]FCY
 When 2 : #Niveau site
  Call LECTURE("FCY",[F:ENV]FCY,"") From CONTOBJ
  [M]FCY=[F:ENV]FCY
  [M]CPY=[F:FCY]LEGCPY
  SOCIETE=[F:FCY]LEGCPY
Endcase

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ

Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
[M]LEDTYP = [F:GCM]ANALEDTYP
[M]LED    = [F:GCM]LED([M]LEDTYP-1)

#Axes et sections
For I=0 To 2 # (Dim Zone DIE From table BUDPAR)-1
 [M]DIE(I)=[F:BUP]DIE(I)
Next

# 3ème section
Local Char FMT
If [F:BUP]DIE(2)<>""
 Call GLOBVAR From SETGLBDIE
 Call INICCEFMT([F:BUP]DIE(2)) From SETGLBDIE
 Call LECTURE("DIE",[F:BUP]DIE(2),"") From CONTOBJ
 Local Char DESDIE3(GLONAX1)
 Call LECTEXTRA(DESDIE3,"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
 Titcol [M]NBLIG DESDIE3 For CCE3
 FMT = "K:"+GCCEFMT
 [M]FMTCCE3=FMT
Else
 FMT = "-K:10"
 [M]FMTCCE3=FMT
Endif
Chgfmt [M]CCE3 With [M]FMTCCE3

#Plan de compte
[M]COA= [F:BUP]COA

#Intitulé exercice
Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;EXERCICE
If !fstat
 If [F:FIY]DESSHO<>""
  [M]EXEINFO  = [F:FIY]DESSHO
 Else
  Raz [M]EXEINFO
 Endif
 [M]FIYSTR=[F:FIY]FIYSTR
 [M]FIYEND=[F:FIY]FIYEND
Endif

#Info
Call SETGLBAPP(SOCIETE,GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
#Call LECTURE("ENF",ENVELOPPE,num$(EXERCICE)) From CONTOBJ
Read [ENF]ENF0= ENVELOPPE;EXERCICE
If ! fstat
 [M]AMTBUDFIY = [F:ENF]AMTBUDFIY
 [M]AMTAPPFIY = [F:ENF]AMTAPPFIY
 [M]AMTRESFIY = [F:ENF]AMTRESFIY
Endif
#Grizage (hors budget)
If [F:ENV]EXTBUD=2
 Grizo [M]AMT,AMTATT
Else
 Actzo [M]
Endif
#Chargement des lignes de budget
Raz [M:BUDL]NBLIG
Raz [M:BUDL]ACCNUM
Raz [M:BUDL]ACC
Raz [M:BUDL]CCE1
Raz [M:BUDL]CCE2
Raz [M:BUDL]CCE3
Raz [M:BUDL]LOT
Raz [M:BUDL]STA
Raz [M:BUDL]APPDAT
Raz [M:BUDL]AMT
Raz [M:BUDL]AMTAPP
Raz [M:BUDL]AMTATT
#NB: Suis obligé de faire plusieur Raz sinon
#    il me Raz les champs de même nom des ecrans appelant celui-ci
Gosub LOAD_LIG
Gosub INFO_MONTANT

Affzo [M]
End

#####
$LOAD_LIG
Local Integer NOL
Local Integer INDENT, INDENV, INDCCE3 : # Index of each dimension in the ledger
Call GETGDDINDDIE([M]CPY,[M]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD
Gosub CRITBUD
NOL=0
For [BUD]BUD0 Where evalue(CRITBUD)
 [M]ACC(NOL)    = [F:BUD]ACC
 [M]TEX(NOL)    = [F:BUD]TEX
 If INDENT>0  : [M]CCE1(NOL) = evalue("[F:BUD]CCE"+num$(INDENT))  : Endif
 If INDENV>0  : [M]CCE2(NOL) = evalue("[F:BUD]CCE"+num$(INDENV))  : Endif
 If INDCCE3>0 : [M]CCE3(NOL) = evalue("[F:BUD]CCE"+num$(INDCCE3)) : Endif
 [M]AMT(NOL)    = [F:BUD]AMT(0)
 [M]AMTAPP(NOL) = [F:BUD]AMTAPP
 [M]AMTATT(NOL) = [F:BUD]AMTATT
 [M]STA(NOL)    = [F:BUD]STA
 [M]LOT(NOL)    = [F:BUD]LOT
 #Champ informatifs justes affichées
 [M]ACCNUM(NOL)    = [F:BUD]ACCNUM
 [M]APPDAT(NOL)    = [F:BUD]APPDAT
 [M]AMTCMM(NOL)    = [F:BUD]AMTCMM
 [M]AMTCMMPRP(NOL) = [F:BUD]AMTCMMPRP
 [M]AMTREA(NOL)    = [F:BUD]AMTREA
 [M]TOTREA(NOL)    = [F:BUD]AMTREA+[F:BUD]AMTCMMPRP+[F:BUD]AMTCMM
 If func AFNC.ACTIV("SVC")
  [M]AMTCCA(NOL)    = [F:BUD]AMTCCA
 Endif
 [M]AMTCAP(NOL)    = [F:BUD]AMTCAP
 [M]AMTFAS(NOL)    = [F:BUD]AMTFAS
 [M]REVDAT(NOL)    = [F:BUD]REVDAT
 ###
 NOL+=1
Next
[M]NBLIG=NOL
Gosub GESAFFZON
Return

#####
$CRITBUD
# BUD0 => LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9
Local Char CRITBUD(250)
If INDENV>0
 CRITBUD ='LEDTYP='+num$([M]LEDTYP)-'& BUD="'+[M]BUD+'" & FIY='+num$([M]FIY)-'& VER="1" & CCE'+num$(INDENV)+'="'+[M]ENV+'"'
Endif
If NUMERO<>0
 CRITBUD -='& ACCNUM='+num$(NUMERO)
Endif
Return

#####
$GESAFFZON
For I=0 To [M:BUDL]NBLIG-1
 If [M:BUDL]STA(I)<>1
  Diszo [M:BUDL]ACC(I),CCE1(I),AMT(I),LOT(I),CCE3(I)
  Affzo [M:BUDL]
 Else
  Actzo [M:BUDL]ACC(I),CCE1(I),AMT(I),LOT(I),CCE3(I)
  Affzo [M:BUDL]
 Endif
Next
Return

#####
$INFO_MONTANT
Local Decimal AMT_VL, AMT_PREENG, AMT_ENG, AMT_REAK
AMT_VL=0
AMT_PREENG=0
AMT_ENG=0
AMT_REA=0
For I=0 To [M:BUDL]NBLIG-1
 AMT_VL += [M:BUDL]AMT(I)
 AMT_PREENG += [M:BUDL]AMTCMMPRP(I)
 AMT_ENG += [M:BUDL]AMTCMM(I)
 AMT_REA += [M:BUDL]AMTREA(I)
Next
[M:BUDL]AMTENF = [M:BUDL]AMTBUDFIY
[M:BUDL]AMTRES = [M:BUDL]AMTRESFIY
[M:BUDL]SOLDE  = [M:BUDL]AMTENF-[M:BUDL]AMTRES
[M:BUDL]VL     = AMT_VL
[M:BUDL]RAVB   = [M:BUDL]SOLDE-[M:BUDL]VL
[M:BUDL]VL_PREENG = AMT_PREENG
[M:BUDL]VL_ENG    = AMT_ENG
[M:BUDL]VL_REA    = AMT_REA
[M:BUDL]TOT_USED  = AMT_PREENG+AMT_ENG+AMT_REA
[M:BUDL]RAVL   = AMT_VL-(AMT_REA+AMT_ENG+AMT_PREENG)
Affzo [M:BUDL]
Return


######################################################################################
## Etiquette de l'écran BUDL - 04/03/2008
######################################################################################

#---------#
# En-tête #
#---------#

Subprog AM_ENV(VALEUR)
Variable Char    VALEUR()
If [F:ENV]ACS<>""
 Local Integer OKACC
 Call CONSACC([F:ENV]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat = 2 : End
 Endif
Endif

If [M]FIY<>0
 Read [ENF]ENF0 = VALEUR;[M]FIY
 If fstat
  Filter [ENF] Where ENV=VALEUR
  Read [ENF]ENF0 First
  If !fstat
   [M]FIY=[F:ENF]FIYNUM
   Call CHARGE_CHP(VALEUR,[F:ENF]FIYNUM,0)
  Endif
  Filter[ENF]
 Elsif !fstat
  Call CHARGE_CHP(VALEUR,[M]FIY,0)
 Endif
Else
  Filter [ENF] Where ENV=VALEUR
  Read [ENF] First
  If !fstat
   [M]FIY=[F:ENF]FIYNUM
  Endif
 Filter [ENF]
 Call CHARGE_CHP(VALEUR,[M]FIY,0)
Endif
End

Subprog C_FIY(VALEUR)
Variable Decimal VALEUR
Read [ENF]ENF0 = [M]ENV;VALEUR
If fstat
 # Exercice incorrect
 GMESSAGE=mess(52,116,1)
 mkstat=2
Endif
End

Subprog AM_FIY(VALEUR)
Variable Decimal VALEUR
Read [ENF]ENF0 = [M]ENV;VALEUR
If !fstat
 Call CHARGE_CHP([M]ENV,VALEUR,0)
Endif
End

#---------#
#  Ligne  #
#---------#

Subprog IB_NBLIG
If [M]STA(nolign-1)<>1
 Raz GBOUT1
Endif
Filter [BRV] Where TYP=3 & ENV=[M]ENV & FIY=[M]FIY & ACC=[M]ACC(nolign-1) & ACCNUM=[M]ACCNUM(nolign-1)
Look [BRV]BRV0 First
If fstat
 Raz GBOUT2
Endif
Filter [BRV]


#Détail des achats/Purchase detail
Local Char CRITBUA(250),CRITBUAB(250)
CRITBUA ='BUD="'+[M]BUD+'"'
CRITBUA -='& CPY="'+[M]CPY+'"'-'& FIY='+num$([M]FIY)
CRITBUA -='& find("'+[M]ACC(nolign-1)+'",[F:BUA]ACC(0..9))'
If [M]FCY<>""
 CRITBUA -='& FCY="'+[M]FCY+'"'
Endif
#Entité
CRITBUAB -='find("'+[M]DIE(0)+'",[F:BUA]DIE(0..8))'
CRITBUAB -='& find("'+[M]CCE1(nolign-1)+'",[F:BUA]CCE(0..8))'
#Enveloppe
CRITBUAB -='& find("'+[M]DIE(1)+'",[F:BUA]DIE(0..8))'
CRITBUAB -='& find("'+[M]ENV+'",[F:BUA]CCE(0..8))'
#3ème section
If [M]DIE(2)<>""
 CRITBUAB -='& find("'+[M]DIE(2)+'",[F:BUA]DIE(0..8))'
 CRITBUAB -='& find("'+[M]CCE3(nolign-1)+'",[F:BUA]CCE(0..8))'
Endif

Filter [BUA] Where evalue(CRITBUA) & evalue(CRITBUAB)
Look [BUA]BUA0 First
If fstat
 Raz GBOUT4
Endif
Filter [BUA]
End

Subprog C_NBLIG
#Suppression de la ligne (ssi status<>approuvé)
If status=65
 If [M]STA(nolign-1)<>3
  If [M]ACCNUM(nolign-1)<>0
   If [M]NBDEL=dim([M]ACCNUMDEL)
    # Annulation impossible : tableau plein
    GMESSAGE=mess(48,111,1)
    mkstat = 2 : End
   Endif
   [M]ACCNUMDEL([M]NBDEL)=[M]ACCNUM(nolign-1)
   [M]NBDEL +=1
  Endif
  Raz [M:BUDL]AMT(nolign-1),AMTAPP(nolign-1),AMTCMMPRP(nolign-1),AMTCMM(nolign-1),AMTREA(nolign-1),AMTCCA(nolign-1),AMTCAP(nolign-1),AMTFAS(nolign-1)
  Gosub INFO_MONTANT
 Else
  #On ne peut pas supprimer une ligne approuvée
  GMESSAGE=mess(131,108,1)
  mkstat=1
 Endif
Endif
End

Subprog AM_NBLIG
Gosub INFO_MONTANT
End

# Permet de definir un site epour le controle sur compte meme si e budget n'est pas définit au niveau site
$SETSOC
Case [F:BUP]LEV
 When 1 : #Niveau societe
  GSOCIETE = [F:ENV]FCY
 When 2 : #Niveau site
  Call LECTURE("FCY",[F:ENV]FCY,"") From CONTOBJ
  GSOCIETE = [F:FCY]LEGCPY
Endcase
Return

#------------------------ Compte -------------------------------------

Subprog AM_ACC(VALEUR)
Variable Char    VALEUR()
Raz [M]TEX(nolign-1)
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
#Ctrl que la nature budgétaire est bien suivie sur les axe entité et enveloppe du code budget
Call LECTURE("ENV",[M]ENV,"") From CONTOBJ
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
Local Char AXE_ENT(GLONDIE),AXE_ENV(GLONDIE)

AXE_ENT="" : AXE_ENV=""

For I=0 To dim([F:BUP]DIE)-1
 Call LECTURE("DIE",[F:BUP]DIE(I),"") From CONTOBJ
 If [F:DIE]ENT=2 : AXE_ENT=[F:BUP]DIE(I) : Endif
 If [F:DIE]ENV=2 : AXE_ENV=[F:BUP]DIE(I) : Endif
Next

Read [GAC]GAC0 = [M]COA;VALEUR
If !fstat
 If !find(AXE_ENT,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) | !find(AXE_ENV,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  #Le compte budgétaire n'est pas suivi sur les axes 'Entité' et 'Enveloppe' du code budget
  GMESSAGE = mess(121,108,1)
  mkstat=2
 Endif
Endif

Gosub SETSOC
If [F:GAC]FCY<>""
 Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[F:ENV]FCY,GSOCIETE,VALEUR) From CFYSUB
 If mkstat=2 : End : Endif
Endif
Call CONTACC([M]LEDTYP,[M]COA,VALEUR,"","",[M]FIYEND) From CPTCNT
End

Subprog AS_TEX(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ACC(nolign-1)<>""
 Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",[M]COA,[M]ACC(nolign-1)) From ATEXTRA
Endif
End


#------------------------ Sections -------------------------------------

Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""

 #Contrôle d'unicité ici ssi pas de 3ème axe
 If [M]DIE(2)=""
  For I=0 To [M]NBLIG-1
   If I<>(nolign-1) & ACC(I)=ACC(nolign-1) & CCE1(I)=VALEUR
    #Ligne déjà définie pour cette nature et cette entité destinatrice
    GMESSAGE=mess(199,108,1)
    mkstat=2 : Break
   Endif
  Next
 Endif

 Call LECTURE("ENV",[M]ENV,"") From CONTOBJ
 Call LECTURE("ENT",VALEUR,"") From CONTOBJ
 If [F:ENT]CPY<>"" & [F:ENT]CPY<>[F:ENV]SOCIETE
  #Entité incompatible car rattachée à une société différente de celle de l'enveloppe
  GMESSAGE=mess(145,108,1)
  mkstat=2
 Endif
Endif
Gosub SETSOC
Call LEC_CCE(VALEUR,[M]DIE(0)) From CPTLEC
AX=1 : Gosub CTLCCE
End

Subprog D_CCE2(VALEUR)
Variable Char    VALEUR()
VALEUR=[M]ENV
End

Subprog AS_CCE3(VALEUR)
Variable Char    VALEUR()
If [M]DIE(2)=""
 Diszo [M]CCE3(nolign-1)
Else
 Actzo [M]CCE3(nolign-1)
Endif
End

Subprog C_CCE3(VALEUR)
Variable Char    VALEUR()
# 82645 Rendre la saisie du troisième axe obligatoire si renseignée dans le code budget
If [M]DIE(2)<>"" & VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
Endif
Gosub SETSOC
Call LEC_CCE(VALEUR,[M]DIE(2)) From CPTLEC
AX=3 : Gosub CTLCCE
If mkstat=2 : End : Endif

# Contrôle d'unicité
If [M]DIE(2)<>""
 For I=0 To [M]NBLIG-1
  If I<>(nolign-1) & ACC(I)=ACC(nolign-1) & CCE1(I)=CCE1(nolign-1) & CCE3(I)=VALEUR
   #Ligne déjà définie pour cette nature et cette entité destinatrice
   GMESSAGE=mess(199,108,1)
   mkstat=2 : Break
  Endif
 Next
Endif
End

$CTLCCE
 Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[F:ENV]FCY,GSOCIETE,VALEUR) From CFYSUB
 If mkstat=2 : Return : Endif
 Call CONTCCE(VALEUR,[M]LED,[M]DIE(AX-1),"",[M]FIYEND,
&                    [M]ACC(nolign-1),[M]DIE,"[M]CCE#",nolign-1) From CPTCNT
Return


Subprog D_STA(VALEUR)
Variable Integer VALEUR
Case GAPPNIV
 When "211","221","221","121"
  VALEUR = [F:ENF]STAFIY
  If [F:ENF]STAFIY>=3
   [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
   [M]APPDAT(nolign-1)=date$
  Endif
Endcase
End

Subprog C_AMT(VALEUR)
Variable Decimal VALEUR
 Call LECTURE("ENV",[M]ENV,"") From CONTOBJ
 If VALEUR=0 & [F:ENV]EXTBUD<>2
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
 If VALEUR>0 & [F:ENV]EXTBUD=2 & [M:ENV1]EXTBUD=1
  #Vous devez enregistrer l'enveloppe avant de modifier la ligne en cas de mise en budget
  GMESSAGE=mess(269,108,1)
  VALEUR=0
  mkstat=2 : End
 Endif
 Local Decimal SOMAMT
 [M]AMT(nolign-1)=VALEUR
 SOMAMT=0
 For I=0 To [M]NBLIG
  SOMAMT += [M]AMT(I)
 Next
 If SOMAMT>[M]AMTBUDFIY-[M]AMTRESFIY
  VALEUR=[M]AMTBUDFIY-[M]AMTRESFIY-(SOMAMT-VALEUR)
  #La somme des montants des lignes budgétaire ne doit pas dépasser le montant disponible du budget exercice
  GMESSAGE=mess(133,108,1)
  mkstat=2
 Endif
 #init AMTAPP selon paramètre GAPPNIV
 Case GAPPNIV
  When "211","221","221","121"
   If [F:ENF]STAFIY>=3
    [M]AMTAPP(nolign-1)=VALEUR
   Endif
Endcase
End

Subprog AM_AMT(VALEUR)
Variable Decimal VALEUR
[M:BUDL]AMT(nolign-1)=VALEUR
Gosub INFO_MONTANT
End



Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]PRJ=""
 Diszo [M]LOT(nolign-1)
Else
 Actzo [M]LOT(nolign-1)
Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:PJL]) : Local File PRJLOT [PJL] : Endif
Local Char LISTELOT(5)(1..10)
I=1
For [PJL]PJL0 Where PRJ=[M]PRJ
 LISTELOT(I)  = [F:PJL]LOT
 I+= 1
Next
If !find(VALEUR,LISTELOT(1..I))
 #Ce lot n'existe pas dans le projet de l'enveloppe
 GMESSAGE = mess(132,108,1)
 mkstat = 2
Endif
End

