#<AdxTL>@(#)2.0.0.0 $Revision$
#####################################################################################################################################
#                                                                                                                                   #
#----------------------------- Gestion de mise à jour automatique des sections------------------------------------------------------#
#
#
# ANU_CCE(APPLI,ABREV2,CODE,SUPP,OK)
#  => Annulation de sections
#
#
# CHG_CCE(APPLI,ABREV2,OCODE,OSUPP,NCODE,NSUPP,OK)
#  => Changement de clé
#
#
# CRE_CCE(APPLI,TYP,CODE,SUPP,OK)
#  => Création de sections
#
#
# Ces programmes sont appelés à ce stade sous la création et suppression de Tiers - Localisation Russe (code activité KRU)
#
#
#####################################################################################################################################

Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CCE",GBIDC1,GBIDC2) From  GOBJET
End

####################################################
Subprog ANU_CCE(APPLI,ABREV2,CODE,SUPP,OK)
####################################################
Value    Char    APPLI()
Value    Char    ABREV2()
Value    Char    CODE()
Value    Char    SUPP()
Variable Integer OK

If clalev([F:DIE]) = 0 : Local File GDIE       [DIE] : Endif
If clalev([F:CCE]) = 0 : Local File CACCE      [CCE] : Endif

For [DIE] Where CCECRE=ABREV2
 For [CCE] Where [F:CCE]DIE=[F:DIE]DIE and [F:CCE]CCE=CODE
  Call ANUCOD("CCE",[F:CCE]CCE,[F:CCE]DIE,OK) From GOBJACT
  If !OK : Break 2 : Endif
  Call ANNULE("CCE",[F:CCE]CCE,[F:CCE]DIE) From GOBJTXT
  Call ANNULE("CCE",[F:CCE]CCE,[F:CCE]DIE) From SUBALI
 Next
Next

End

#N'est plus utilisé car chgmt clé géré par le superviseur car texte traduisible
#dans SUBCCE appel aux CHGTEXTRA etc..
#CHECK IGNORE_BEGIN
####################################################
Subprog CHG_CCE(APPLI,ABREV2,OCODE,OSUPP,NCODE,NSUPP,OK)
####################################################
Value    Char    APPLI()
Value    Char    ABREV2()
Value    Char    OCODE()
Value    Char    OSUPP()(1..)
Value    Char    NCODE()
Value    Char    NSUPP()(1..)
Variable Integer OK

If clalev([F:DIE]) = 0 : Local File GDIE       [DIE] : Endif

For [DIE] Where CCECRE=ABREV2 & CCE=CODE
 Call CHGCOD("CCE",[F:DIE]CCE,[F:DIE]DIE,OK) From GOBJACT
 If !OK : Break : Endif
 Call CHANGE("CCE","CCE",OCLECUR1,OCLECUR2,CLECUR1,CLECUR2) From GOBJTXT
 Call CHANGE("CCE",OCLECUR1,OCLECUR2,CLECUR1,CLECUR2) From SUBALI
Next

End
#CHECK IGNORE_END


####################################################
Subprog CRE_CCE(APPLI,TYP,CODE,SUPP,OK)
####################################################
Value    Char    APPLI()
Value    Char    TYP()
Value    Char    CODE()
Value    Char    SUPP()
Variable Integer OK

Local Char    OCODE(250), NCODE(250), TEXTE(250), ACTION(15)
Local Char    OFMT(250), NFMT(250), FMT2(250), NOMDOS(20)(1..255)
Local Integer OK, I , NDOS, LG , OKTRT
Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Integer PSUB , PSPE , PSPV , PSTD
Local Char    SVSUPP(250), SAVFONC(GLONAFC) , IDENT(250), OIDENT(250), DEFMSK(250)
Local Char    ABREV(GLONAOB)
Local Char    SUPP(250)(16), SVSUPP(250)
Local Char    PCLE1(250), PCLE2(250) , NEWCOD(250)
Local Integer SILENCE
Local Char    WCCE(GLONCCE)

Call SETPROG(TYP,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
If APPLI<>""
 Call EXISTE_ADX("",APPLI,PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  PROGOBJ = APPLI+"."+PROGOBJ
 Endif
Endif

I = dim(NOMDOS)
If APPLI<>""
 NDOS = 1 : NOMDOS(NDOS) = APPLI
 Local File =APPLI+".ADOVAL" [ADWX]
 Read [ADWX]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADWX]VALEUR<>""
  NDOS += 1 : NOMDOS(NDOS) = [F:ADWX]VALEUR
 Endif
 Close Local File [ADWX]
Else
 NDOS = 1 : NOMDOS(NDOS) = nomap(0)
 If GDOSH<>""
  NDOS += 1 : NOMDOS(NDOS) = GDOSH
 Endif
Endif

If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif

If APPLI<>""
 Local File =APPLI+".AOBJET" [AOB_] , =APPLI+".ATABLE" [ATB_] , =APPLI+".ATABZON" [ATZ_]
&         , =APPLI+".ATEXTE" [ATX] , =APPLI+".ATEXTRA" [AXX]
Else
 Local File AOBJET [AOB_] , ATABLE [ATB_] , ATABZON [ATZ_] , ATEXTE [ATX] , ATEXTRA [AXX]
Endif

ABREV = TYP
Read [AOB_]ABREV = TYP
If fstat : FIN=1 : End : Endif
Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : FIN=1 : End : Endif

Gosub NOMFIC From =PROGOBJ
Gosub TIT    From =PROGOBJ
Gosub SETCLE From =PROGOBJ

If APPLI<>""
 Local File =APPLI+"."+NOMFIC [CR__]
 Local File =APPLI+"."+NOMFIC
Else
 Local File =NOMFIC [CR__]
 Gosub OUVFIC From =PROGOBJ
Endif

If clalev([F:DIE]) = 0 : Local File GDIE                 [DIE] : Endif
If clalev([F:CCE]) = 0 : Local File =GTABCPT+"CACCE"     [CCE] : Endif

Assign "[F:CR__]"+CLEPRIM With CODE
Read [F:CR__] =
If fstat : OK = 0 : End : Endif


$TR1
OK = 1
For [DIE] Where CCECRE=TYP

 Call INICCEFMT([F:DIE]DIE) From SETGLBDIE
 WCCE = vireblc(format$(GCCEFMT,CODE),2)
 If WCCE<>""

  Read [F:CCE]CCE0 = [F:DIE]DIE;CODE
  If fstat

  Raz [F:CCE]
  [F:CCE]DIE = [F:DIE]DIE
  [F:CCE]CCE = WCCE
  If dim([F:CR__]DES)>1
   [F:CCE]DES = [F:CR__]DES
  Endif
  If dim([F:CR__]DESSHO)>1
   [F:CCE]DESSHO = [F:CR__]DESSHO
  Endif

  If TYP="BPR"
   [F:CCE]DES = [F:CR__]BPRNAM
   [F:CCE]DESSHO = [F:CR__]BPRSHO
  Elsif TYP="BPS"
   [F:CCE]DES = [F:CR__]BPSNAM
   [F:CCE]DESSHO = [F:CR__]BPSSHO
  Elsif TYP="BPC"
   [F:CCE]DES = [F:CR__]BPCNAM
   [F:CCE]DESSHO = [F:CR__]BPCSHO
  Endif

  [F:CCE]ENAFLG = 2

  If dim([F:CCE]BUDTRK)>0 : [F:CCE]BUDTRK = 1         : Endif
  If dim([F:CCE]IPT)>0    : [F:CCE]IPT    = 2         : Endif
  If dim([F:CCE]CREDAT)>0 : [F:CCE]CREDAT = date$     : Endif
  If dim([F:CCE]CREUSR)>0 : [F:CCE]CREUSR = GUSER     : Endif
  If dim([F:CCE]EXPNUM)>0 : [F:CCE]EXPNUM = [C]EXPORT : Endif
  Write [CCE]
  If fstat
   GOK = 0 : Call FSTA("CCE") From GLOCK : Break
  Endif
  Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  If GOK<1 : Break : Endif
  Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  If GOK<1 : Break : Endif
  Call CRECCE([F:CCE]DIE,[F:CCE]CCE) From LIENPYRCCE
  If GOK<1 : Break : Endif
 Endif
Endif
Next

If GOK<=0 : OK = 0 : Endif

End

