#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRCAN
######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRCAN) 14/08/2015 09:20:31 (JML)
######################################################################################
$ACTION
Case ACTION
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "RAZCRE"      : Gosub RAZCRE
 When Default
Endcase
Return

######################################################################################
$CREATION
$MODIF
Gosub TEXTRA
Return
######################################################################################
$OUVRE
 #LIPET - 2017-11-02 - X3-29539 - START
 If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
 If dim([F:HRCAN]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
 #LIPET - 2017-11-02 - X3-29539 - END
Return
######################################################################################
$FERME
#LIPET - 2017-05-19 - X3-29539 - START
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 2017-05-19 - X3-29539 - END
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRCAN) : Endif
  VCOD = CLE1
Return
######################################################################################
$LIENS
GCURLEG = [F:HRCAN]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([F:HRCAN]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"HRCATACTION","DES",GCURLEG,[M]CANCOD) From ATEXTRA

Return

$RAZCRE
  GCURLEG=""
Return
######################################################################################
#ADNGO - 2017-11-16 - START
$SEL_TABLE
  Case TABLE
  When "SELHRCAN"
    If clalev ([F:HRCAN])=0 : Local File HRCATACTION [HRCAN] : Endif
    Filter [F:HRCAN]
    OBJET="HRCAN"
    If GCURLEG<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCAN]LEG="'+GCURLEG+'" | [F:HRCAN]LEG="")',"&") From GOBJSUB
    Endif
  Endcase
Return
#ADNGO - 2017-11-16 - END

$ANNULE
Call SUPTEXTRA("HRCATACTION","DES",SUPP,[L]CODE) From ATEXTRA
Return

######################################################################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA

If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRCATACTION","DES",CLECUR1,"","HRCATACTION","DES",GCURLEG,[F:HRCAN]CANCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"HRCATACTION","DES",GCURLEG,[F:HRCAN]CANCOD) From ATEXTRA

Return

######################################################################################
$AP_CHANGE
Call CHGTEXTRA("HRCATACTION","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return
######################################################################################

Subprog TUNHRCAN(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONHRCAN)
   TOKILL = 1
  Endif

  If clalev([F:HRCAN])=0 : Local File HRCATACTION [HRCAN] : Endif

  VCOD = COD

  If VCOD="" & GCURLEG <> "" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRCAN] Where LEG=GCURLEG
  Read [F:HRCAN] First
  Filter [HRCAN]
  If !fstat : VCOD=[F:HRCAN]CANCOD : Endif
  Else
   Read [HRCAN]HRCAN0 = GCURLEG;VCOD
  Endif
  If GCURLEG <> "" Then
    Call OBJET("HRCAN",VCOD,GCURLEG) From GOBJET
  Else
    Call OBJET("HRCAN",VCOD,"") From GOBJET
  Endif
  COD = VCOD

  If TOKILL : Kill VCOD : Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-05-19 - X3-29539 - START
  GCURLEG = VALEUR
#LIPET - 2017-05-19 - X3-29539 - END
End


######################################################################################


##################################################
Subprog CONTHRCAN(COD)
Variable Char    COD
If GFONCTION = "GESHRCAN" | COD="" : End : Endif

  If clalev([F:HRCAN])=0 : Local File HRCATACTION   [HRCAN] : Endif

  If COD <> ""
    Filter [F:HRCAN] Where CANCOD=[L]COD
    Read [F:HRCAN] First
    Filter [F:HRCAN]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Read [F:HRCAN]HRCAN0 = GCURLEG;[L]COD
        If fstat
          Filter [F:HRCAN] Where CANCOD=[L]COD & LEG=GCURLEG
          Read [F:HRCAN] First
          Filter [F:HRCAN]
          If [F:HRCAN]LEG<>"" & GCURLEG <> ""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRCAN]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:HRCAN]
End

