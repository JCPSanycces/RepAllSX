#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMSALITMD
###################################################################################################
# EVENTS
###################################################################################################
$ACONTROL
Local Char SMESSAGE(250)
Local Integer IRET

  #--------------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  #--------------------------
  # FGR Control of SAU linked to ITMREF possible values
  [L]ASTATUS = fmet this.UOM_CONTROL()
  #--------------------------
  If func ASYRFNC.ACTIV("ECC") = [V]CST_ATRUE Then
    IRET = func STKSOR_SYRA.STKCTRECC(this.ACTX, this.ITMREF, this.ECCVALMAJ, this.ECCVALMIN, "", 4, SMESSAGE)
    If IRET <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ECCVALMIN", SMESSAGE, IRET))
    Endif
  Endif
  #--------------------------
Return

###################################################################################################
$AINSERT_CONTROL_BEFORE
  If this.ORI = 1 Then
    If this.QTYSTU = 0 Then
      this.QTYSTU = this.QTY
    Endif
    If this.STU = AVOID.ACHAR Then
      this.STU = this.SAU
    Endif
  Endif
  #--------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  #--------------------------
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  If this.ITMREF = this.snapshot.ITMREF Then
    If this.snapshot.SAU <> this.SAU Then
      If this.QTY = this.snapshot.QTY Then
        [L]ASTATUS = fmet this.QTY_CONVERT()
      Endif
    Endif
  Endif
  #--------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  #--------------------------
Return

###################################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL)
    Return
  Endif
Return

