#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENEMPTMP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:24"
A_USER  = "DOC"
A_STAMP = "20181109230424"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "BPAG"
  If [M]BPAG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENEMPTMP [DIC]
Gosub HORODAT
Local Inpbox "GENEMPTMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIC] As [SIM_]
Grizo [DIC]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIC]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=88 : Y1(0)=5 : Y2(0)=23
Return

$ON_PRDFRM
Onevent BEFORE_AREA Gosub AV_PRDFRM From W1GENEMPTMP
Return

$AV_PRDFRM
Chgfmt [M]PRDFRM(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_PRDUTL
Onevent BEFORE_AREA Gosub AV_PRDUTL From W1GENEMPTMP
Return

$AV_PRDUTL
Chgfmt [M]PRDUTL(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATPAY
Onevent BEFORE_AREA Gosub AV_DATPAY From W1GENEMPTMP
Return

$AV_DATPAY
Chgfmt [M]DATPAY(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_TOTTYP
Onevent INIT_AREA Call D_TOTTYP(zc) From W1GENEMPTMP
Onevent BEFORE_INPUT Call AS_TOTTYP(zc) From W1GENEMPTMP
Onevent CONTROL Call C_TOTTYP(zc) From W1GENEMPTMP
Return

Subprog D_TOTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TOTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TOTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10344) From COMBOS
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10344,1))))
Endif
If !mkstat
 Discombo 0 From TOTTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TOTTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TOTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_TOTTYPELM
Onevent INIT_AREA Call D_TOTTYPELM(zc) From W1GENEMPTMP
Onevent BEFORE_INPUT Call AS_TOTTYPELM(zc) From W1GENEMPTMP
Onevent CONTROL Call C_TOTTYPELM(zc) From W1GENEMPTMP
Return

Subprog D_TOTTYPELM(VALEUR)
Variable Integer VALEUR
If varinit([M]TOTTYPELM,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TOTTYPELM(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10355) From COMBOS
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10355,1))))
Endif
If !mkstat
 Discombo 0 From TOTTYPELM(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TOTTYPELM(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TOTTYPELM(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_FLGFRM
Onevent INIT_AREA Call D_FLGFRM(zc) From W1GENEMPTMP
Onevent BEFORE_INPUT Call AS_FLGFRM(zc) From W1GENEMPTMP
Return

Subprog D_FLGFRM(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGFRM,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGFRM(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


