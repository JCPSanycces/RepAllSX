#<AdxTL>@(#)6.0.0.0 $Revision$
#################################################################
# Etiquette masque DUDATMGT1
#################################################################

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
# bug 12539 (CP:22/01/02)
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [F:CPY]CPYLEGFLG<>2
 mkstat=2 : GMESSAGE=mess(130,121,1)   :# Société non juridique
Endif
Local Char DEVLED(GLONCUR)
Call SETMAINREF(VALEUR,GTYPGEN,GTYPANA) From CPTDIV
Call LECMAINPLAN(GTYPGEN,VALEUR,[M]COA) From CPTDIV
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 1 : End : Endif
End

Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPSAC, SAC, SACACC : Grizo GRPSAC, SAC
Else
 Actzo GRPSAC
 If [M]GRPSAC<>"" : Grizo SAC : Else : Actzo SAC : Endif
Endif
End

Subprog AS_GRPSAC(VALEUR)
Variable Char     VALEUR
If [M:DDM]ALLSAC=2
 mkstat = 1 : End
Else
 Local Char DEVLED(GLONCUR)
 Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call LECMAINPLAN(GTYPGEN,[M]CPY,[M]COA) From CPTDIV
Endif
End

Subprog C_GRPSAC(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Effzo SAC, SACACC : Grizo SAC
Else
 Actzo SAC
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char     VALEUR
If [M:DDM]ALLSAC = 2 | [M:DDM]GRPSAC<>""
 mkstat=1 : End
Else
 Local Char DEVLED(GLONCUR)
 Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call LECMAINPLAN(GTYPGEN,[M]CPY,[M]COA) From CPTDIV
Endif
End

Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()
Read [GAC]GAC1 = [M]COA;VALEUR
If !fstat
 [M:DDM]SACACC=[F:GAC]ACC
Else
 Raz [M:DDM]SACACC
Endif
End

Subprog C_ALLBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BPRDEB, BPRFIN : Grizo BPRDEB, BPRFIN
Else
 Actzo BPRDEB, BPRFIN
Endif
End

Subprog AS_BPRDEB(VALEUR)
Variable Char    VALEUR()
If [M:DDM]ALLBPR=2
 mkstat = 1 : End
Endif
End

Subprog AS_BPRFIN(VALEUR)
Variable Char    VALEUR()
If [M:DDM]ALLBPR=2
 mkstat = 1 : End
Endif
If VALEUR="" | VALEUR<[M:DDM]BPRDEB : VALEUR=[M:DDM]BPRDEB : Endif
End

Subprog C_ALLPYRBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo PYRBPRDEB, PYRBPRFIN : Grizo PYRBPRDEB, PYRBPRFIN
Else
 Actzo PYRBPRDEB, PYRBPRFIN
Endif
End

Subprog AS_PYRBPRDEB(VALEUR)
Variable Char    VALEUR()
If [M:DDM]ALLPYRBPR=2
 mkstat = 1 : End
Endif
End

Subprog C_BPRDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]BPRDEB & [M]BPRFIN=""
 [M]BPRFIN = VALEUR
Endif
End

Subprog C_PYRBPRDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]PYRBPRDEB & [M]PYRBPRFIN=""
 [M]PYRBPRFIN = VALEUR
Endif
End

Subprog AS_PYRBPRFIN(VALEUR)
Variable Char    VALEUR()
If [M:DDM]ALLPYRBPR=2
 mkstat = 1 : End
Endif
If VALEUR="" | VALEUR<[M:DDM]PYRBPRDEB : VALEUR=[M:DDM]PYRBPRDEB : Endif
End

Subprog C_ALLPAM(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo PAM : Grizo PAM
Else
 Actzo PAM
Endif
End

Subprog AS_PAM(VALEUR)
Variable Char     VALEUR
If [M:DDM]ALLPAM=2
 mkstat = 1 : End
Endif
If [F:CPY]CPY<>[M]CPY : Read [CPY]CPY0=[M]CPY : Endif
GCURLEG = [F:CPY]LEG
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPCUR, CUR : Grizo GRPCUR, CUR
Else
 Actzo GRPCUR
 If [M]GRPCUR<>"" : Grizo CUR : Else : Actzo CUR : Endif
Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char     VALEUR
If [M:DDM]ALLCUR=2
 mkstat=1 : End
Endif
End

Subprog C_GRPCUR(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Effzo CUR : Grizo CUR
Else
 Actzo CUR
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
If [M:DDM]ALLCUR=2 | [M:DDM]GRPCUR<>""
 mkstat=1 : End
Endif
End

Subprog AS_FUPLEVEND(VALEUR)
Variable Decimal  VALEUR
VALEUR=[M]FUPLEVSTR
End

Subprog C_FUPLEVEND(VALEUR)
Variable Decimal  VALEUR
If VALEUR<[M]FUPLEVSTR
 mkstat=2
Endif
End

Subprog D_FLGPAZEND(VALEUR)
Variable Integer  VALEUR
VALEUR=len(mess(0,510,1))
End

Subprog C_FLGPAZEND(VALEUR)
Variable Integer  VALEUR
If VALEUR<[M]FLGPAZSTR
 mkstat=2
Endif
End

Subprog AS_ECRAN(VALEUR)
Variable Char    VALEUR()
If GFLAG<>""
 VALEUR = GFLAG : mkstat = 2 : End
Endif

End

Subprog D_DEPDAT(VALEUR)
Variable Date    VALEUR
VALEUR=datesyst
End

Subprog C_DEPDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [00/00/00]
 Effzo DEPNBJ : Grizo DEPNBJ
Else
 Actzo DEPNBJ
Endif
End

Subprog AS_DEPNBJ(VALEUR)
Variable Decimal VALEUR
If DEPDAT <> [00/00/00] : mkstat = 2 : Endif
End

Subprog C_DEPNBJ(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & DEPDAT = [00/00/00]
 DEPDAT = datesyst
 Affzo DEPDAT
Elsif DEPDAT <> [00/00/00]
 VALEUR = 0
Endif
End

Subprog C_FUPLEVZERO(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz FUPLEVSTR, FUPLEVEND
 Grizo FUPLEVSTR, FUPLEVEND
Else
 Actzo FUPLEVSTR, FUPLEVEND
Endif
End

Subprog AM_FUPFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 # si Echéances à relancer = Non, griser la coche "Echéances jamais relancées", début, fin
 Raz [M:DDM]FUPLEVZERO, FUPLEVSTR, FUPLEVEND
 Grizo [M:DDM]FUPLEVZERO, FUPLEVSTR, FUPLEVEND
Else
 Actzo [M:DDM]FUPLEVZERO, FUPLEVSTR, FUPLEVEND
Endif
End

