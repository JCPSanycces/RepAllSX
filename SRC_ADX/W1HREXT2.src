$ON_PARTYP
Onevent CONTROL Call C_PARTYP(zc) From W1HREXT2
Onevent BEFORE_INPUT Call AS_PARTYP(zc) From W1HREXT2
Return

Subprog AS_PARTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PARTYP(zc) From W1HREXT2
Onkey 144 Titled GBOUTP Call P_PARTYP(zc) From W1HREXT2
Onkey 146 Titled GBOUTA Call SA_PARTYP(zc) From W1HREXT2
Gosub _AFF
End

Subprog C_PARTYP(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ATY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PARTYP" : GZNUM = 680 : Endif
Gosub _AFF
End

Subprog S_PARTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PARTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PARTYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

