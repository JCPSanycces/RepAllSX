#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:37"
A_USER  = "DOC"
A_STAMP = "20181109230437"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "PARNBR"
  If [M]PARNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HREXT2 [HREXT2]
Gosub HORODAT
Local Inpbox "HREXT2" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXT2] As [SIM_]
Grizo [HREXT2]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXT2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_PARDTALVL
Onevent BEFORE_INPUT Call AS_PARDTALVL(zc) From W1HREXT2
Onevent INIT_AREA Call D_PARDTALVL(zc) From W1HREXT2
Onevent CONTROL Call C_PARDTALVL(zc) From W1HREXT2
Return

Subprog D_PARDTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]PARDTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PARDTALVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11677) From COMBOS
## Action STD
Call AS_PARDTALVL(VALEUR) From SUBHREXT
If mkstat=2
 [M]PARDTALVL(INDIC) = VALEUR
 Affzo PARDTALVL(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11677,1))))
Endif
If !mkstat
 Discombo 0 From PARDTALVL(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From PARDTALVL(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_PARDTALVL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PARDTALVL" : GZNUM = 5230 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_PARDTACLC
Onevent BEFORE_INPUT Call AS_PARDTACLC(zc) From W1HREXT2
Onevent CONTROL Call C_PARDTACLC(zc) From W1HREXT2
Return

Subprog AS_PARDTACLC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]PARDTACLC(INDIC) = VALEUR
  Affzo PARDTACLC(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_PARDTACLC(zc) From W1HREXT2
Onkey 130 Titled GBOUT2 Call B2_PARDTACLC(zc) From W1HREXT2
Onkey 131 Titled GBOUT3 Call B3_PARDTACLC(zc) From W1HREXT2
Gosub _AFF
End

Subprog C_PARDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRCONT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFRCONT"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PARDTACLC" : GZNUM = 1261 : Endif
Endif
Gosub _AFF
End

Subprog B1_PARDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"","","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_PARDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_PARDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

