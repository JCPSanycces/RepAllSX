#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion objet N4H
#--------------------------------------------
# SUBN4H : Gestion des tables de codage N4DS
#--------------------------------------------
Call OBJET("N4H", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

$ACTION
Case ACTION
    When "OUVRE"
        Gosub OUVRE
    When "LIENS"
        Gosub LIENS
    When "CREATION"
        Gosub CREATION
    When "MODIF"
        Gosub MODIF
 When Default
Endcase
Return

$OUVRE
If not clalev([F:N4H]) : Local File N4DSTABH [N4H] : Endif
If not clalev([F:N4D]) : Local File N4DSTABD [N4D] : Endif
Return

$CREATION
Gosub ECRIRE_N4D
Return

$MODIF
Gosub EFFACE_N4D
Gosub ECRIRE_N4D
Return

$LIENS
Effzo [M]10
nolign = 0
For [F:N4D]N4D0 Where [F:N4D]N4HCOD = [M]N4HCOD & [F:N4D]VER = [M]VER
    nolign += 1
    [M] = [F:N4D]
Next
[M]NBLIG = nolign
Affzo [M]
Return

$EFFACE_N4D
Delete [F:N4D] Where [F:N4D]N4HCOD = [M]N4HCOD & [F:N4D]VER = [M]VER
Return

$ECRIRE_N4D
For nolign = 1 To [M]NBLIG
    Raz [F:N4D]
    [F:N4D] = [M]
    [F:N4D]NUMLIG = nolign
    Write [F:N4D]
Next
Return


#---------------------------------------------
# TRTCOP : Bouton copie vers un autre dossier
#---------------------------------------------
$TRTCOP

Local File =[M]DOSORG+".N4DSTABH" [N4H1]
Local File =[M]DOSORG+".N4DSTABD" [N4D1]

Local File =[M]DOSDES+".N4DSTABH" [N4H2]
Local File =[M]DOSDES+".N4DSTABD" [N4D2]

Local Char CRIN4H(250)
Local Integer COPIECOMPLETE
[L]CRIN4H = "N4HCOD = TABLE & VER=TABLE2"

Call DEBTRANS From GLOCK
If [V]GADONIX = 2
 Call OUINON(func AFNC.MES1(mess(2,721,1),[L]TABLE-[L]TABLE2),[L]COPIECOMPLETE) From GESECRAN
 #                          Copier toutes les fiches de l'EDI $1$
    If [L]COPIECOMPLETE = 2
        [L]CRIN4H = "1"
    Endif
Endif
Gosub TR_COP
Kill [L]COPIECOMPLETE, [L]CRIN4H
Close Local File [N4H1], [N4D1], [N4H2], [N4D2]
Return

$TR_COP
GOK = 1
Trbegin [N4H1], [N4H2], [N4D1], [N4D2]

Delete [N4H2] Where evalue([L]CRIN4H)
If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".N4DSTABH" : Goto ROLL_TR_COP
Elsif fstat>5
    GOK = 0 : Call RSTA("N4H2","") From GLOCK : Goto AB_TR_COP
Endif

Delete [N4D2] Where evalue([L]CRIN4H)
If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".N4DSTABD" : Goto ROLL_TR_COP
Elsif fstat>5
    GOK = 0 : Call RSTA("N4D2","") From GLOCK : Goto AB_TR_COP
Endif

For [N4H1] Where evalue([L]CRIN4H)
    [F:N4H2] = [F:N4H1]
    If dim([F:N4H2]UPDUSR)>0 : [F:N4H2]UPDUSR = GUSER : Endif
    If dim([F:N4H2]UPDDAT)>0 : [F:N4H2]UPDDAT = date$ : Endif
    If dim([F:N4H2]UPDTIM)>0 : [F:N4H2]UPDTIM = time : Endif
    Write [F:N4H2]
    If fstat
        GOK = 0 : Call FSTA("N4H2") From GLOCK : Break
    Endif
    For [F:N4D1] Where [F:N4D1]N4HCOD = [F:N4H1]N4HCOD & [F:N4D1]VER = [F:N4H1]VER
        [F:N4D2] = [F:N4D1]
        If dim([F:N4D2]UPDUSR)>0 : [F:N4D2]UPDUSR = GUSER : Endif
        If dim([F:N4D2]UPDDAT)>0 : [F:N4D2]UPDDAT = date$ : Endif
        If dim([F:N4D2]UPDTIM)>0 : [F:N4D2]UPDTIM = time : Endif
        Write [F:N4D2]
        If fstat
            GOK = 0 : Call FSTA("N4D2") From GLOCK : Break
        Endif
    Next
Next
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return
#------------------------------------------------------------- ECRAN --------------------------------------------------------------

Subprog AS_VAL1(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR=[M]CMP1(nolign-1) : Endif
End
