#<AdxTL>@(#)10.0.0.0 $Revision$
Call CNVDIV
End

##############################################################
Subprog CNVDIV
Local Integer OK
Local Char    WCHP(12)(1..20)
Local Integer WARR(1..20)

Gosub OUVRE 

Read [TCY]TCY0 = GPAYS
If fstat
 Read [TCY]TCY0 = ""
Endif
If fstat=0
 GLOCALDEV = [F:TCY]CUR
Else
 GLOCALDEV = "FRF"
Endif

Local Mask CNVDIV [DIA] 
Raz [M]

###DBA le 01/08/04 : Passage V140
###OK = 2 : Call DIALOD(OK,mess(70,115,1)) From GESECRAN
Local Char WIN (GLONFEN)
WIN="DCNVDIV"
OK=2 : Call DIALWIN(OK,mess(70,115,1),WIN) From GESECRAN
###

# Conversion zones diverses
If OK<>2 | [M]NBLIG=0 : Goto FIN : Endif

If [M]TRACE=2
 Call OUVRE_TRACE(mess(70,115,1)) From LECFIC
Endif
Call TEMPON("V") From GESECRAN

For I=0 To [M]NBLIG-1
 WCHP(1) = [M]FLD(I)
 WARR(1) = 0
 Call CNVDIV2([M]SOCIETE,[M]DEVCUR,[M]DEVDES,[M]TBL(I),WCHP,1,[M]CPYFLD(I)
&            ,[M]FCYFLD(I),[M]DATFLD(I),[M]CURFLD(I),[M]DATPAS,[M]FILTRE(I),WARR)
Next I

Call TEMPOFF From GESECRAN 
If [M]TRACE=2
 Call FERME_TRACE From LECFIC 
 Call LEC_TRACE From LECFIC
Endif

$FIN
End
 
$OUVRE 
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE  [TCH] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
Return 
 
#########################################################################################
Subprog CNVDIV2(SOCIETE,DEVCUR,DEVDES,TBL,WCHP,NBRCHP,CPY,FCY,DAT,CUR,DATPAS,FILTRE,WARR)

Value Char     SOCIETE     : # Code société
Value Char     DEVCUR      : # Code devise courante
Value Char     DEVDES      : # Code devise destination
Value Char     TBL         : # Code de table
Value Char     WCHP()(1..) : # Codes des champs à convertir
Value Integer  NBRCHP      : # Nombre de champs à convertir
Value Char     CPY         : # Code du champs société
Value Char     FCY         : # Code du champs site
Value Char     DAT         : # Code du champs date
Value Char     CUR         : # Code du champs devise
Value Date     DATPAS      : # Date de passage à l'euro
Value Char     FILTRE      : # Critères de sélection
Value Integer  WARR(1..)   : # Nombre de décimales par code champ (à préciser pour forcer l'arrondi)

Gosub OUVRE

Local Integer  OK, I, J, K, TYP, DIME, SPSTAT, ERR
Local Integer  TYPCUR, ISITE
Local Char     VALPAR(20)
Local Decimal  WMONT
Local Date     WDAT
Local Integer  ARRODEC
Local Integer  NBTRN

Call PARAM("","CHGTYP",[L]VALPAR) From ADOVAL
[L]TYPCUR = val([L]VALPAR)
If [L]TYPCUR=0 : [L]TYPCUR = 1 : Endif

Raz ERR
Onerrgo NERR
Local File =[L]TBL [AA_], =[L]TBL [AA2_], =[L]TBL [AA3_]
Onerrgo ERR From CNVEURO : # mb 27.8.1
If ERR
 If GTRACE<>""
  Call ECR_TRACE(mess(12,100,1)-[L]TBL,0) From GESECRAN : # Erreur d'accés sur le fichier
 Endif
 End
Endif

## On veut absolument qu'oracle fasse un tri

Local Char INDEX(80)(1..100) , CHAMP(10) , CHAINE(80)

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif

K=0
For [ATI]CODIND Where CODFIC=[L]TBL
 K += 1
 [L]CHAINE = [F:ATI]DESCRIPT
 While [L]CHAINE<>""
  I = instr(1,[L]CHAINE,"+")
  J = instr(1,[L]CHAINE,"-")
  If I & J     : I = min(I,J)
  Elsif J & !I : I = J
  Endif
  If I
   [L]CHAMP = left$([L]CHAINE,I-1)
   [L]CHAINE = right$([L]CHAINE,I+1)
  Else
   [L]CHAMP = [L]CHAINE
   [L]CHAINE = ""
  Endif
  If !find([L]CHAMP,[L]INDEX(1..K))
   K += 1 : [L]INDEX(K) = [L]CHAMP
  Endif
 Wend
Next
[L]CHAMP = ""
For [ATZ]CODZONE Where CODFIC=[L]TBL
 If !find([F:ATZ]CODZONE,[L]INDEX(1..K))
  [L]CHAMP = [F:ATZ]CODZONE
  Break
 Endif
Next

If [L]CHAMP<>""
 Filter [AA2_] Order By Key CLE=evalue([L]CHAMP)
Endif

##

NBTRN = 0

For [AA2_]
 Default File [AA2_]
 [L]OK = 1
 If [L]SOCIETE<>"" & [L]CPY<>"" & evalue("[F:AA2_]"+[L]CPY)<>[L]SOCIETE
  [L]OK = 0
 Elsif [L]SOCIETE<>"" & [L]FCY<>""
  [L]ISITE   = find(evalue("[F:AA2_]"+[L]FCY),GSITE(1..GNBSITE))
  If [L]ISITE=0
   [L]OK = 0
  Elsif GSOCSITE([L]ISITE)<>[L]SOCIETE
   [L]OK = 0
  Endif
 Endif
 If [L]CUR<>"" & evalue("[F:AA2_]"+[L]CUR)<>DEVCUR
  [L]OK = 0
 Endif
 If [L]FILTRE<>"" & evalue([L]FILTRE)=0
  [L]OK = 0
 Endif

 If [L]OK
  Gosub MAJFIC
  If GOK<1 : Break : Endif
 Endif
Next

If NBTRN>0
 If GOK<1
  Rollback
  Goto FIN_CNVDIV
 Else
  Commit
 Endif
Else
 Goto FIN_CNVDIV
Endif 

If GTRACE<>""
 Call ECR_TRACE(mess(71,115,1)-string$(SOCIETE<>"",mess(2,116,1)+":"+SOCIETE)-format$("D:"+GFMDAT,date$)-time$
&             -mess(56,123,1)+":"+TBL+"/"+sigma(I=1,[L]NBRCHP,WCHP(I)+" "),0)  From GESECRAN
Endif

$FIN_CNVDIV
Close Local File [AA_], [AA2_], [AA3_]
End

$NERR
ERR = errn
Resume

$MAJFIC
Default File [AA2_]
NBTRN += 1
If NBTRN=1
 Call DEBTRANS From GLOCK
 GOK = 1
 Trbegin [AA2_], [AA3_]
Elsif NBTRN>500
 Commit
 NBTRN = 0
 Goto MAJFIC
Endif

Readlock [AA2_] Curr
If fstat
 GOK = 0 : Call RSTA("AA2_","") From GLOCK : Goto AB_TR1
Endif
If [L]DAT<>""
 WDAT = evalue("[F:AA2_]"+[L]DAT)
Else
 WDAT = DATPAS
Endif
For K=1 To [L]NBRCHP
 [L]TYP = evalue("type([F:AA2_]"+[L]WCHP(K)+")")
 [L]DIME = evalue("dim([F:AA2_]"+[L]WCHP(K)+")")
 For I=0 To [L]DIME-1
  If find([L]TYP,1,2,4,5,6,7,8,9)
   WMONT = evalue("[F:AA2_]"+[L]WCHP(K)+"("+num$(I)+")")
  Elsif !find([L]TYP,3)
   WMONT = val(evalue("[F:AA2_]"+[L]WCHP(K)+"("+num$(I)+")"))
  Endif
  WMONT = evalue("[F:AA2_]"+[L]WCHP(K)+"("+num$(I)+")")
  ARODEC = WARR(K)
  Call CONVERT3(DEVCUR,DEVDES,DEVDES,[L]TYPCUR,WDAT,ARODEC,WMONT,WMONT,SPSTAT) From TRTDEV
  If find([L]TYP,1,2,4,5,6,7,8,9)
   Assign "[F:AA2_]"+WCHP(K)+"("+num$(I)+")" With WMONT
  Elsif !find([L]TYP,3)
   Assign "[F:AA2_]"+WCHP(K)+"("+num$(I)+")" With num$(WMONT)
  Endif
 Next I
Next K
If [L]CUR<>""
 Assign "[F:AA2_]"+[L]CUR With DEVDES
Endif
Rewrite [AA2_]
If fstat
 [F:AA3_] = [F:AA2_]
 Delete [AA3_] =
 If fstat
  GOK=0 : Call FSTA("AA3_") From GLOCK : Goto AB_TR1
 Endif
 Rewrite [AA2_]
 If fstat
  GOK=0 : Call FSTA("AA2_") From GLOCK : Goto AB_TR1
 Endif
Endif
Return

$AB_TR1
Return

###############################################################
Subprog AM_SOCIETE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [CPY]CPY0 = VALEUR
 [M]DEVCUR = [F:CPY]ACCCUR
Endif
End

Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEVCUR
 mkstat = 2
Endif
End

Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
Gosub SELZONE
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 GMESSAGE = mess(8,124,1) : mkstat = 2 : End
# Zone inexistante
Endif
End

Subprog S_DATFLD(VALEUR)
Variable Char    VALEUR()
Gosub SELZONE
End

Subprog C_DATFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
If VALEUR="" : End : Endif
TYPZ = 8 : # Date
Gosub VERFZONE
End

Subprog AS_CPYFLD(VALEUR)
Variable Char    VALEUR()
If [M]SOCIETE="" : mkstat = 1 : End : Endif
End

Subprog S_CPYFLD(VALEUR)
Variable Char    VALEUR()
Gosub SELZONE
End

Subprog C_CPYFLD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer TYPZ
TYPZ = 7 : # Alpha
Gosub VERFZONE
End

Subprog AS_FCYFLD(VALEUR)
Variable Char    VALEUR()
If [M]SOCIETE="" : mkstat = 1 : End : Endif
End

Subprog S_FCYFLD(VALEUR)
Variable Char    VALEUR()
Gosub SELZONE
End

Subprog C_FCYFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
If [M]SOCIETE<>"" & [M]CPYFLD(nolign-1)="" & VALEUR="" 
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Elsif VALEUR=""
 End
Endif
TYPZ = 7 : # Alpha
Gosub VERFZONE
End

Subprog S_CURFLD(VALEUR)
Variable Char    VALEUR()
Gosub SELZONE
End

Subprog C_CURFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
TYPZ = 7 : # Alpha
Gosub VERFZONE
End

$VERFZONE
Local Integer I , OK
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 GMESSAGE = mess(8,124,1) : mkstat = 2 : End
# Zone inexistante
Else
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP<>TYPZ
  GMESSAGE = mess(10,124,1) : mkstat = 2 : End
# Zone de type incorrect
 Endif
Endif
Return

$SELZONE
Filter [ATZ] Where CODFIC = [M]TBL(nolign-1)
Call SELECT("ATZ","",VALEUR,"") From SELOBJ
If status<>7
 VALEUR = [F:ATZ]CODZONE
Endif
Filter [ATZ]
End

