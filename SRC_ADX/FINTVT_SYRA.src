#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-16347
##############################################################################################################
# ROUTINES ABOUT TAXES CODES
##############################################################################################################
# CTL_TAX       : Controls that the taxes code is authorized or forbidden according to the account setup.
# CTL_TAX_TAB   : Controls that the taxes code is athorized or not according to the setup of each account of an array.
#
##############################################################################################################

#####################################################################################################################
## _CTL_TAX
#####################################################################################################################
#**
#* Controls that the taxes code is authorized or forbidden according to the account setup.
#**
#*
#* @param ACTX    Context
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param TAX     Taxes code
#* @param ERRMES  Error message
#*!
Funprog CTL_TAX(ACTX,COA,ACC,TAX,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char  COA()     : # Chart of accounts
Value    Char  ACC()     : # Accounts
Value    Char  TAX()     : # Taxes code
Variable Char  ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Integer B_GAAFND

  If(COA<>"" and ACC<>"" and TAX<>"")Then
    If adxtyp=33 | !clalev([F:COA]) : Local File GCOA    [COA] : Endif
    Call LEC_COA(COA) From CPTLEC
    If [F:COA]TAXMGT = 2
      If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT    [GAC] : Endif
      Call LEC_GAC(ACC,COA) From CPTLEC
      If fstat
        ERRMES= ACC-"("+COA+")"-mess(38,106,1)
        [L]ASTATUS=[V]CST_AERROR
      Else
        If [F:GAC]TYPVATCTL=2 or [F:GAC]TYPVATCTL=3
          If adxtyp=33 | !clalev([F:GAA]) : Local File GACCOUNTA      [GAA] : Endif
          Call LEC_GAA(ACC,COA) From CPTLEC
          If fstat : B_GAAFND = 0 : Else : B_GAAFND = 1 Endif
          If B_GAAFND and [F:GAC]TYPVATCTL=2 : # Authorized
            If find(TAX,[F:GAA]VATCTL)=0
              ERRMES= func ASYRFNC.MES3(mess(216,105,1), TAX, ACC, COA)
              [L]ASTATUS=[V]CST_AERROR
            Endif
          Endif
          If B_GAAFND and [F:GAC]TYPVATCTL=3 : # Forbidden
            If find(TAX,[F:GAA]VATCTL)> 0
              ERRMES= func ASYRFNC.MES3(mess(216,105,1), TAX, ACC, COA)
              [L]ASTATUS=[V]CST_AERROR
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

End [L]ASTATUS

#####################################################################################################################
## CTL_TAX_TAB
#####################################################################################################################
#**
#* Controls that the taxes code is authorized or forbidden according to the account setup.
#**
#*
#* @param ACTX    Context
#* @param NBR     Number of accounts to be controlled
#* @param LEDCOD  Array of Ledger codes
#* @param COA     Array of Chart of accounts
#* @param ACC     Array of Accounts
#* @param TAX     Taxes code
#* @param ERRMES  Error message
#*!
Funprog CTL_TAX_TAB(ACTX,NBR,LEDCOD,COA,ACC,TAX,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  NBR           : # Number of accounts to be controlled
Value    Char     LEDCOD()(1..) : # Array of Ledger code
Value    Char     COA()(1..)    : # Array of Chart of accounts
Value    Char     ACC()(1..)    : # Array of Accounts
Value    Char     TAX()         : # Taxes code
Variable Char     ERRMES()      : # Error message

Local Integer ASTATUS

  Local Integer   INDLED
  Local Integer   L_NBR
  If (NBR > dim(LEDCOD,0)) : L_NBR = dim(LEDCOD,0)   : Else : L_NBR = NBR : Endif
  For INDLED = 1 To L_NBR
    If func FINTVT_SYRA.CTL_TAX(GACTX,COA(INDLED),ACC(INDLED),TAX,GMESSAGE)>=[V]CST_AERROR
      ERRMES=GMESSAGE
      [L]ASTATUS=[V]CST_AERROR
      Break
    Endif
  Next
End [L]ASTATUS

