#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_LMRNG UTI process                                   PAY Module
#                 Migration To U12 - Vnext version
#
# ==>  Update LOCAL MENU ranges to the 10 000 range
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Sync Local Menus between daughter folder and reference folder") From LECFIC

  Call AMAJ_EMHRMAJ90_LMRNG(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog AMAJ_EMHRMAJ90_LMRNG(LDOSSIER)
Value Char LDOSSIER
#declare variables and initialize
  Onerrgo CYCLECHECKERROR

  Local Char      RDOSSIER(30) : RDOSSIER = nomap             #current reference folder
  Local Char      DOSLEGMIG(5)                                #for folder name return by get leg function
  Local Char      MENUNAME(GLONATB)(1..)                      #array for local menu table name, datatype ATB(Tables)
  Local Char      MENUPARAM(30)(1..)                          #array for local menu table parameter name
  Local Integer   STAT :STAT = 1                              #for writing to the log file in subprog MIGRATE_TABLE
  Local Integer   NRBREC, I, NBRTAB                           #number of records, index for array management, number of tables
  Local Char      MSG(200)                                    #not seeing where this getting used
  Local Char      THISPROC(20) : THISPROC = 'EMHRMAJ90_LMRNG'  #for passing duing subprogram calls
  Local Integer   TRACE                                       #for "onerrgo" exception handling
                  TRACE = 0                                   #initialize
  Local Integer   MENUARRAY(1..)
  Local Integer   U9MENUARRAY(1..)
  Local Integer   V12MENUARRAY(1..)
  Local Integer   COUNTER

#begin migration tasks
  #raise dialog box to enter the folder name to migrate from

  #Call SAIDOS(LDOSSIER,"") From SAIDOS

  If LDOSSIER <> "" and RDOSSIER <> "" #yes, you have access to the daughter and reference folder

    #check if folder table file is not open, then open
    If clalev([F:ADS]) = 0  :Local File ADOSSIER [ADS] :Endif
    #Read the Folder table where folder = current folder (nomap)
    Read [ADS] DOSSIER=[L]LDOSSIER
    #if the read is successful, reset the table class for re-use
    If fstat :Raz [F:ADS] :Endif

    Call TEMPON("O") From GESECRAN
    Call ECR_TRACE("EMHRMAJ90_LMRNG: Sync of local menu ranges between reference folder and daughter folder",0) From GESECRAN
    Call ECR_TRACE("EMHRMAJ90_LMRNG: Start of process on : "+LDOSSIER,0) From GESECRAN
    #gets the folder legislation
    DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

    #Main process of iterating through the local menus in current folder
    #and check reference folder to sync
#    Gosub DEFINE_LOCAL_MENUS_10000
    Gosub DEFINE_LOCAL_MENUS_CHANGED

#    Gosub PROCESS_LOCAL_MENUS

#    Gosub UPDATE_TABLE_REFERENCES_10000
    Gosub UPDATE_TABLE_REFERENCES_CHANGED

#    Gosub UPDATE_SCREEN_REFERENCES_10000
    Gosub UPDATE_SCREEN_REFERENCES_CHANGED

    Call ECR_TRACE(THISPROC +" : Completed Local Menu sync process",0) From GESECRAN

  Endif

End #end migration main function process ###########################################################################################

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_LMRNG: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$PROCESS_LOCAL_MENUS

  #open the local menu header messages table for reading
  If clalev([F:WAML])  = 0 :Local File =LDOSSIER+"."+"AMENLOC" [WAML]  :Endif
  #open the local menu's messages table for reading
  If clalev([F:WAST])  = 0 :Local File =LDOSSIER+"."+"APLSTD"  [WAST]  :Endif
  #open the parameter values to get the local menu related to the parameter name
  If clalev([F:WADW])  = 0 :Local File =LDOSSIER+"."+"ADOVAL"  [WADW]  :Endif


  #open the local menu header messages table for reading
  If clalev([F:R_AML])  = 0 :Local File AMENLOC [R_AML]  :Endif
  #open the local menu's messages table for reading
  If clalev([F:R_AST])  = 0 :Local File APLSTD [R_AST]  :Endif
  #open the parameter values to get the local menu related to the parameter name
  If clalev([F:R_ADW])  = 0 :Local File ADOVAL [R_ADW]  :Endif

  Local Integer TEMPLOC

  For [WAML]
    If [F:WAML]AUZMOD = 2
      TEMPLOC = [F:WAML]MENLOC

      If [F:WAML]MENLOC > 300 and [F:WAML]MENLOC < 900
        TEMPLOC = [F:WAML]MENLOC + 10000
      Endif

      #Call ECR_TRACE(THISPROC +" : TEMPLOC (" + num$(TEMPLOC) + ")",0) From GESECRAN

      Filter [F:R_AML] Where MENLOC = TEMPLOC and MODULE = [F:WAML]MODULE
      Read [F:R_AML] First

      If !fstat
#        Filter [F:WAST] Where LANCHP = TEMPLOC
        Filter [F:WAST] Where LANCHP = [F:WAML]MENLOC
        For [F:WAST]
          Filter [F:R_AST] Where LANCHP = TEMPLOC and LANNUM = [F:WAST]LANNUM
          Read [F:R_AST] First

          If fstat > 0 #not found, need to add to reference folder, because it is custom entry
            Call ECR_TRACE(THISPROC+" : Added to local menu ("+num$([F:WAST]LANCHP)+") a entry ["+num$([F:WAST]LANNUM)+" = "+num$([F:WAST]LANMES)+"]",0) From GESECRAN
            [F:R_AST] = [F:WAST]
            Write [F:R_AST]
          Endif
        Next
      Endif
    Endif
  Next

  Filter [F:WAST]
  Filter [F:WAML]

  #clear the local menu entries on daughter folder to ensure that
  # the folder is updated with the latest version
  Call ECR_TRACE("EMHRMAJ90_LMRNG: Cleared Local Menu Entries : "+LDOSSIER,0) From GESECRAN
  Delete [F:WAST] Where [F:WAST]LANCHP < 159 | ([F:WAST]LANCHP > 169 & [F:WAST]LANCHP < 1000) | ([F:WAST]LANCHP > 1999 & [F:WAST]LANCHP < 3401) | ([F:WAST]LANCHP > 3500 & [F:WAST]LANCHP < 3721) | ([F:
& WAST]LANCHP > 7699 & [F:WAST]LANCHP < 12500)

  #clear the local menu headers
  Call ECR_TRACE("EMHRMAJ90_LMRNG: Cleared Local Menu Headers : "+LDOSSIER,0) From GESECRAN
  Delete [F:WAML] Where [F:WAML]MENLOC < 159 | ([F:WAML]MENLOC > 169 & [F:WAML]MENLOC < 1000) | ([F:WAML]MENLOC > 1999 & [F:WAML]MENLOC < 3401) | ([F:WAML]MENLOC > 3500 & [F:WAML]MENLOC < 3721) | ([F:
& WAML]MENLOC > 7699 & [F:WAML]MENLOC < 12500)

  #close the migration local menu header and messages table used for reading and writing
  LogicClose File [F:WAML]
  LogicClose File [F:WAST]
  LogicClose File [F:WADW]

  #Resets global variables to release memory
  Call DEBTRANS From GLOCK

Return #end PROCESS_LOCAL_MENUS#############################################################################################################

