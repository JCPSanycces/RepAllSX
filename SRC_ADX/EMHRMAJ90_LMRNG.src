$UPDATE_TABLE_REFERENCES_10000
  If clalev([F:YTBZ]) = 0 :Local File =LDOSSIER+".ATABZON" [YTBZ] : Endif

  For COUNTER = 1 To maxtab(MENUARRAY)
    If MENUARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating ATABZON on Local Menu number : " + num$(MENUARRAY(COUNTER) + 10000),0) From GESECRAN
      Update [F:YTBZ] Where [F:YTBZ]NOLIB = MENUARRAY(COUNTER) & ([F:YTBZ]CODTYP = "M" | [F:YTBZ]CODTYP = "MM") With [F:YTBZ]NOLIB = MENUARRAY(COUNTER) + 10000
    Endif
  Next
  Close File [F:YTBZ]
Return

$UPDATE_SCREEN_REFERENCES_10000
  If clalev([F:YAMSK]) = 0 :Local File =LDOSSIER+".AMSKZON" [YAMSK] : Endif

  For COUNTER = 1 To maxtab(MENUARRAY)
    If MENUARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating AMSKZON on Local Menu number : " + num$(MENUARRAY(COUNTER) + 10000),0) From GESECRAN
      Update [F:YAMSK] Where [F:YAMSK]NOLIB = MENUARRAY(COUNTER) & ([F:YAMSK]CODTYP = "M" | [F:YAMSK]CODTYP = "MM") With [F:YAMSK]NOLIB = MENUARRAY(COUNTER) + 10000
    Endif
  Next
  Close File [F:YAMSK]
Return


$UPDATE_TABLE_REFERENCES_CHANGED
If clalev([F:YTBZ]) = 0 :Local File =LDOSSIER+".ATABZON" [YTBZ] : Endif

  For COUNTER = 1 To maxtab(U9MENUARRAY)
    If U9MENUARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating ATABZON on Local Menu number : " + num$(U9MENUARRAY(COUNTER)) + " to " + num$(V12MENUARRAY(COUNTER)),0) From GESECRAN
      Update [F:YTBZ] Where [F:YTBZ]NOLIB = U9MENUARRAY(COUNTER) & ([F:YTBZ]CODTYP = "M" | [F:YTBZ]CODTYP = "MM") With [F:YTBZ]NOLIB = V12MENUARRAY(COUNTER)
    Endif
  Next
  Close File [F:YTBZ]
Return

$UPDATE_SCREEN_REFERENCES_CHANGED
  If clalev([F:YAMSK]) = 0 :Local File =LDOSSIER+".AMSKZON" [YAMSK] : Endif

  For COUNTER = 1 To maxtab(U9MENUARRAY)
    If U9MENUARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating AMSKZON on Local Menu number : " + num$(U9MENUARRAY(COUNTER)) + " to " + num$(V12MENUARRAY(COUNTER)),0) From GESECRAN
      Update [F:YAMSK] Where [F:YAMSK]NOLIB = U9MENUARRAY(COUNTER) & ([F:YAMSK]CODTYP = "M" | [F:YAMSK]CODTYP = "MM") With [F:YAMSK]NOLIB = V12MENUARRAY(COUNTER)
    Endif
  Next
  Close File [F:YAMSK]
Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_LMRNG(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call AMAJ_EMHRMAJ90_LMRNG(APPLI)
End

