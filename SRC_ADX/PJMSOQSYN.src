#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# ACTION - PJMSOQSYN
###################################################################################################
# Reporting Extracts
###################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"  :  Gosub INIT_DIA
    When "CONTROL"   :  Gosub CONTROL
    When "EXEC"      :  Gosub EXEC
    When "SORTIE"    :  Gosub SORTIE
    When Default
  Endcase
Return

###################################################################################################
$INIT_DIA
Local Instance ZPJMSOQQTY Using C_TECSOQITM
Local Instance ZINSPJM Using C_OPPOR

  [M:DIA]ALLCPY    = [V]CST_AYES
  [M:DIA]ALLPRJ    = [V]CST_AYES
  [M:DIA]SIMUL     = [V]CST_AYES
  [M:DIA]LOGFILE   = [V]CST_AYES
  Affzo [M:DIA]1-99
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

###################################################################################################
$CONTROL
Return

###################################################################################################
$EXEC
Local Char CRITERE(250)(10)
Local Integer ICRITERE
Local Integer IPJMRET
Local Integer IPJMIDX        # Issue X3-107006 - 2018-08-31 by FGR

  #--------------------------------
  Local File OPPOR [OPP]
  Local File OPPORPJM [OPPPJM]
  Local File PIMPL [PIM]
  Local File PJMTSKITM [JTT]
  #--------------------------------
  Link [PIM] With [OPPPJM]OPPPJM0=[F:PIM]OPPNUM,
&                 [OPP]OPP0=[F:PIM]OPPNUM
&              As [NEW]
&              Where ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)
&              Order By Key KEY1=[F:PIM]CPY;[F:PIM]OPPNUM
  #--------------------------------
  Raz CRITERE
  ICRITERE = 0
  #Set Criteria Values
  #-------------------
  CRITERE(ICRITERE) -= "([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3)"
  If [M:DIA]CPY <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]CPY = [M:DIA]CPY"
  Endif
  If [M:DIA]OPPNUMF <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPNUM >= [M:DIA]OPPNUMF"
  Endif
  If [M:DIA]OPPNUMT <> "" Then
    CRITERE(ICRITERE) -= "and [F:PIM]OPPNUM <= [M:DIA]OPPNUMT"
  Endif
  ICRITERE += 1
  CRITERE(ICRITERE) -= "and ([F:PIM]PIMSTA = [V]CST_AYES)"
  CRITERE(ICRITERE) += "and ([F:PIM]OPPSTATE <> 4 and [F:PIM]OPPSTATE <> 9)"
  #--------------------------------
  If [M:DIA]SIMUL = [V]CST_AYES Then
    Trbegin [OPP]
  Endif
  #--------------------------------
  Gosub OUVRE_TRACE
  #--------------------------------
  Filter [F:NEW] Where evalue(CRITERE)
  For [NEW]KEY1
    #--------------------------------
    Gosub ECR_TRACE_OPPNUM
    #--------------------------------
    # Load product list
    For [JTT] Where [F:JTT]OPPNUM = [F:PIM]OPPNUM
      #--------------------------------
      If ZPJMSOQQTY = null Then
        ZPJMSOQQTY = NewInstance C_TECSOQITM AllocGroup null
      Endif
      # Issue X3-107006 - 2018-08-31 by FGR : BEGIN
      #IPJMRET = fmet ZPJMSOQQTY.SOQ_ADD_LINE(func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(ZPJMSOQQTY.ACTX, [F:JTT]OPPNUM, [F:JTT]TASCOD), [F:JTT]ITMREF)
      IPJMRET = fmet ZPJMSOQQTY.SOQ_ADD_LINE(func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(ZPJMSOQQTY.ACTX, [F:JTT]OPPNUM, [F:JTT]TASCOD), [F:JTT]ITMREF,
&                                            AVOID.ACHAR, 0, 0, IPJMIDX)
      # Issue X3-107006 - 2018-08-31 by FGR : END
      If IPJMRET >= [V]CST_AERROR Then
        Gosub OUVRE_TRACE_ERROR
        Gosub ECR_TRACE_DUMP_ERROR_ZPJMSOQQTY
      Endif
    Next
    #--------------------------------
    If ZPJMSOQQTY <> null Then
      ZINSPJM = NewInstance C_OPPOR AllocGroup null
      IPJMRET = fmet ZINSPJM.PJM_TASK_RITT_SOQQTY("", ZPJMSOQQTY)
      If IPJMRET >= [V]CST_AERROR Then
        Gosub OUVRE_TRACE_ERROR
        Gosub ECR_TRACE_DUMP_ERROR_ZINSPJM
      Else
        Call ECR_TRACE(string$(10," ") + mess(497,2260,1), 0)
      Endif
    Else
      Call ECR_TRACE(string$(10," ") + mess(496,2260,1), 0)
    Endif
    #--------------------------------
    If ZINSPJM <> null Then
      FreeGroup ZINSPJM
      Raz ZINSPJM
    Endif
    If ZPJMSOQQTY <> null Then
      FreeGroup ZPJMSOQQTY
      Raz ZPJMSOQQTY
    Endif
    #--------------------------------
  Next
  Filter [F:NEW]
  #--------------------------------
  If [M:DIA]SIMUL = [V]CST_AYES Then
    Rollback
  Endif
  #--------------------------------
  Call ECR_TRACE(string$(50,"-"), 0)
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #--------------------------------
Return

###################################################################################################
$SORTIE
  If ZPJMSOQQTY <> null Then
    FreeGroup ZPJMSOQQTY
    Raz ZPJMSOQQTY
  Endif
  If ZINSPJM <> null Then
    FreeGroup ZINSPJM
    Raz ZINSPJM
  Endif
Return

###################################################################################################
# Gestion du masque PJMSOQSYN
###################################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

###################################################################################################
Subprog AM_ALLPRJ(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]OPPNUMF
    Grizo [M:DIA]OPPNUMT
  Else
    Actzo [M:DIA]OPPNUMF
    Actzo [M:DIA]OPPNUMT
  Endif
End

###################################################################################################
Subprog C_OPPNUMF(VALEUR)
Variable Char    VALEUR()
End

###################################################################################################
Subprog AM_OPPNUMF(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]OPPNUMT = AVOID.ACHAR or [M:DIA]OPPNUMT < VALEUR Then
    [M:DIA]OPPNUMT = VALEUR
    Affzo [M:DIA]OPPNUMT
  Endif
End

###################################################################################################
Subprog C_OPPNUMT(VALEUR)
Variable Char    VALEUR()
End

###################################################################################################
Subprog AM_SIMUL(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    [M:DIA]LOGFILE = [V]CST_AYES
    Affzo [M:DIA]LOGFILE
  Endif
End

###################################################################################################
# Sous-programmes divers
###################################################################################################
$OUVRE_TRACE
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call OUVRE_TRACE(mess(494,2260,1)) From LECFIC
    Call PRTSCR("PJMSOQSYN", "DIA", "", 0, 1) From ATRTX3
    Call ECR_TRACE(string$(50,"-"), 0)
  Endif
Return

###################################################################################################
$OUVRE_TRACE_ERROR
  If [M:DIA]LOGFILE = [V]CST_ANO Then
    [M:DIA]LOGFILE = [V]CST_AYES
    Gosub OUVRE_TRACE
  Endif
Return

###################################################################################################
$ECR_TRACE_OPPNUM
  If [M:DIA]LOGFILE = [V]CST_AYES Then
    Call ECR_TRACE(mess(136,2260,1) - ":" - [F:PIM]OPPNUM, 0)
  Endif
Return

###################################################################################################
$ECR_TRACE_DUMP_ERROR_ZINSPJM
  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(ZINSPJM) From SYRSTACKTOOLS
  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
Return

###################################################################################################
$ECR_TRACE_DUMP_ERROR_ZPJMSOQQTY
  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(ZPJMSOQQTY) From SYRSTACKTOOLS
  Call ECR_TRACE(string$(10," ") + string$(40,"-"), 0)
Return

###################################################################################################
Subprog ECR_TRACE(TEX, ERR)
Value Char    TEX() : # Texte du message
Value Integer ERR

  If GTRACE <> AVOID.ACHAR Then
    If [M:DIA]LOGFILE = [V]CST_AYES Then
      Call ECR_TRACE (TEX, ERR) From GESECRAN
    Endif
  Endif
End

