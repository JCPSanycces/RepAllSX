#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIVEN17     Utilitaire de migration du module ventes     Module VENTE #
#              Initialization new fields for development exigence 87923  #
#                SDD management                                          #
#                Init. new field UMRNUMCOD in SALTRS                     #
##########################################################################


Call MAJ_UTIVEN17
End

Subprog MAJ_UTIVEN17
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVEN17 - Init new fields for SDD management") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN17 : Init new fields for SDD management") From LECFIC
  Call EXE_UTIVEN17(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVEN17(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIVEN17 : Start folder's process"-DOSSIER) From DOSSUB
#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Begin update SALTRS -----#
Gosub TRT_SLT
#----- End update SALTRS   -----#

$FIN_UTIVEN17
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIVENV17 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Init new fields in sales transactions                                       #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Sales transactions                                             #
#   UMRNUMCOD    Référence mandat                                               #
#-------------------------------------------------------------------------------#
$TRT_SLT
Local Shortint INDIC

If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0)<=0  : Return : Endif

Call ECR_TIME("UTIVEN17 Sales Transactions Process : Update SALTRS") From DOSSUB

Local File =DOSSIER+".SALTRS"    [SLT]

Gosub TXNFAC

Close Local File [SLT]

Return
#-------------------------------------------------------------------------------#
# Transaction for invoices                                                      #
#-------------------------------------------------------------------------------#
$TXNFAC
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=5
    Raz INDIC
    If dim([F:SLT]UMRNUMCOD)>0                  : # Référence mandat
      If !find([F:SLT]UMRNUMCOD,1,2,3)
          If dim([F:SLT]PTECOD)>0 & find([F:SLT]PTECOD,1,2,3)
              [F:SLT]UMRNUMCOD=[F:SLT]PTECOD    : # Same value as Payment terms
          Else
              [F:SLT]UMRNUMCOD=3                : # invisible
          Endif
          INDIC=1
      Endif
    Endif
    If INDIC=1
      Rewrite [SLT]
      If fstat
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit

Return
#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call EXE_UTIVEN17(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif
Call EXE_UTIVEN17(APPLI)
End
