#<AdxTL>@(#)0.0.0.0 $Revision$

########################################
## Pagination des variables
########################################
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SETBOUT"      : Gosub SETBOUT
 When "ENR"          : Gosub ENREGISTRE
 When "ABA"          : Gosub ABANDON
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "SETBOUT"      : Gosub SETBOUT
Endcase
Return

$DEBUT
If clalev([F:VRA])=0 : Local File VARIA   [VRA] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

If GCURLEG="" & (GNBLEG = 1 | GLEGFIL="")
  GCURLEG = GDOSLEG
Else If GCURLEG="" : Endif
 GCURLEG=GLEGFIL
Endif

[M:DIA]TYP = 5 : # Niv salarié

#JOJAC - 2016-03-18 REQ114309 US 62 - START
#Filter [ADI] Where NUMTAB=10337 & LEG = GCURLEG
#Read [ADI]CODE First
#Filter [ADI]
#[M:DIA]PAG = [F:ADI]CODE
#Gosub CHARGE_PAG
Raz [M:DIA]LEG
#JOJAC - 2016-03-18 REQ114309 US 62 - END
Return

$SETTAB
Case [M:DIA]TYP
 When 2 : [M:DIA]NUMTAB = 10334
 When 3 : [M:DIA]NUMTAB = 10335
 When 4 : [M:DIA]NUMTAB = 10336
 When 5 : [M:DIA]NUMTAB = 10337
Endcase
Return


$CHARGE_LEG
If clalev([F:VRA])=0 : Local File VARIA   [VRA] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

Case [M:DIA]TYP
 When 2 : [M:DIA]NUMTAB = 10334
 When 3 : [M:DIA]NUMTAB = 10335
 When 4 : [M:DIA]NUMTAB = 10336
 When 5 : [M:DIA]NUMTAB = 10337
Endcase


Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB & LEG=GCURLEG
Read [ADI]CODE First
Filter [ADI]
[M:DIA]PAG = [F:ADI]CODE
Return


$CHARGE_PAG
Local Char CRIT(80)
Gosub SETTAB
Case [M:DIA]TYP
 When 2
  CRIT = 'LEG=GCURLEG & FLGFDR=2 & PAGFDR="'+[M:DIA]PAG+'"'
 When 3
  CRIT = 'LEG=GCURLEG & FLGCPY=2 & PAGCPY="'+[M:DIA]PAG+'"'
 When 4
  CRIT = 'LEG=GCURLEG & FLGFCY=2 & PAGFCY="'+[M:DIA]PAG+'"'
 When 5
  CRIT = 'LEG=GCURLEG & FLGEMP=2 & PAGEMP="'+[M:DIA]PAG+'"'
Endcase
Raz [M:DIA]VRACOD,RANG
nolign = 0
For [VRA]VRA0 Where evalue(CRIT)
 nolign += 1
 [M:DIA] = [F:VRA]
 [M:DIA]VRACOD(nolign-1) = [F:VRA]COD
 Case [M:DIA]TYP
  When 2 : [M:DIA]RANG(nolign-1) = [F:VRA]ROWFDR
  When 3 : [M:DIA]RANG(nolign-1) = [F:VRA]ROWCPY
  When 4 : [M:DIA]RANG(nolign-1) = [F:VRA]ROWFCY
  When 5 : [M:DIA]RANG(nolign-1) = [F:VRA]ROWEMP
 Endcase
Next
[M:DIA]NBVRA = nolign
Sorta [M:DIA]NBVRA [M:DIA]NBVRA Order By [M:DIA]RANG(indice)
Affzo [DIA]
GREP = ""
Actzo [DIA]TYP,PAG
Return

$APRES_MODIF
Case COUZON
 When "TYP"
  [M:DIA]TYP = val(CZ)
  Gosub SETTAB
  Read [ADI]CODE = [M:DIA]NUMTAB;[M:DIA]PAG
  Filter [ADI]
  If fstat
   Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB & LEG=GCURLEG
   Read [ADI]CODE First
   [M:DIA]PAG = [F:ADI]CODE
  Endif
  Gosub CHARGE_PAG
 When "PAG"
  Gosub CHARGE_PAG
 When "LEG"
  Gosub CHARGE_LEG
  Gosub CHARGE_PAG
# When "NBVRA"
 When Default
#JOJAC - 2016-04-04 REQ114309 US 62 - START
  #Grizo [DIA]TYP,PAG
#JOJAC - 2016-04-04 REQ114309 US 62 - END
  GREP = "M"
Endcase
Return

$SETBOUT
Raz ETABOU, ETAMEN
If GREP=""
 CHBOU = "<>"
Else
 CHBOU = "EA"
 STADEF = GSTAENR
Endif
ETABOU(GBFIN) = 1
Gosub SET_BOUT_STD From GSAISIE


Return

$SUIVANT
Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB & CODE>[M:DIA]PAG
Read [ADI]CODE First
If fstat<=2
 [M:DIA]PAG = [F:ADI]CODE
Else
 If [M:DIA]TYP=len(mess(0,10339,1))
  [M:DIA]TYP = 2
 Else
  [M:DIA]TYP += 1
 Endif
 Gosub SETTAB
 Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB
 Read [ADI]CODE First
 [M:DIA]PAG = [F:ADI]CODE
Endif
Filter [ADI] #else, error if we type in a new LEG
Gosub CHARGE_PAG
Return

$PRECEDENT
Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB & CODE<[M:DIA]PAG
Read [ADI]CODE Last
If fstat<=2
 [M:DIA]PAG = [F:ADI]CODE
Else
 If [M:DIA]TYP=2
  [M:DIA]TYP = len(mess(0,10339,1))
 Else
  [M:DIA]TYP -= 1
 Endif
 Gosub SETTAB
 Filter [ADI] Where NUMTAB=[M:DIA]NUMTAB
 Read [ADI]CODE Last
 [M:DIA]PAG = [F:ADI]CODE
Endif
Filter [ADI] #else, error if we type in a new LEG
Gosub CHARGE_PAG
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Sorta [M:DIA]NBVRA [M:DIA]NBVRA Order By [M:DIA]RANG(indice)
 Affzo [DIA]
 GREP = ""
Endif
Return

$ABANDON
Gosub CHARGE_PAG
Return

$TR1
GOK = 1
Trbegin [VRA]
 Case [M:DIA]TYP
  When 2
   Update [VRA] Where FLGFDR=2 & LEG=GCURLEG & PAGFDR=[M:DIA]PAG With FLGFDR=1 , PAGFDR="" , ROWFDR=0
  When 3
   Update [VRA] Where FLGCPY=2 & LEG=GCURLEG & PAGCPY=[M:DIA]PAG With FLGCPY=1 , PAGCPY="" , ROWCPY=0
  When 4
   Update [VRA] Where FLGFCY=2 & LEG=GCURLEG & PAGFCY=[M:DIA]PAG With FLGFCY=1 , PAGFCY="" , ROWFCY=0
  When 5
   Update [VRA] Where FLGEMP=2 & LEG=GCURLEG & PAGEMP=[M:DIA]PAG With FLGEMP=1 , PAGEMP="" , ROWEMP=0
 Endcase
 For I=1 To [M:DIA]NBVRA
  Readlock [VRA]VRA0 = GCURLEG;[M:DIA]VRACOD(I-1)
  If fstat=1
   GOK = -1 : GLOCK = "$VARIA"-[M:DIA]VRACOD(I-1) : Break
  Elsif fstat
   GOK = 0 : Call RSTA("VRA",[M:DIA]VRACOD(I-1)) From GLOCK : Break
  Endif
  Case [M:DIA]TYP
   When 2
    [F:VRA]FLGFDR = 2
    [F:VRA]PAGFDR = [M:DIA]PAG
    [F:VRA]ROWFDR = [M:DIA]RANG(I-1)
   When 3
    [F:VRA]FLGCPY = 2
    [F:VRA]PAGCPY = [M:DIA]PAG
    [F:VRA]ROWCPY = [M:DIA]RANG(I-1)
   When 4
    [F:VRA]FLGFCY = 2
    [F:VRA]PAGFCY = [M:DIA]PAG
    [F:VRA]ROWFCY = [M:DIA]RANG(I-1)
   When 5
    [F:VRA]FLGEMP = 2
    [F:VRA]PAGEMP = [M:DIA]PAG
    [F:VRA]ROWEMP = [M:DIA]RANG(I-1)
  Endcase
  Rewrite [VRA]
  If fstat
   GOK = 0 : Call FSTA("VRA") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
End

