#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################
# UTITC58  Migration of Notes description from A type field to ATEXTRA AX2  SAM # 99384  #
# FGR :  April 2014                                                                      #
##########################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC58(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC58(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

  Call ECR_TRACE("UTITC58: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AOBJET"  [AOB]
  IERR = 0
  #------------------------------------------------------------
  WOBJET="NTG"
  Read [AOB]ABREV=WOBJET
  If !fstat Then
    Trbegin [AOB]
    [F:AOB]SELCLE = ""
    Rewrite [AOB]
    If fstat Then
      GOK = 0
      Call ECR_TRACE(mess(92,75,1) - mess(658,182,1)) From GESECRAN
      Call FSTA("AOB") From GLOCK
      Rollback
    Else
      Commit
      #Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
    Endif
  Endif
  #------------------------------------------------------------
  Close Local File [AOB]
  Call ECR_TRACE("UTITC58: Process on :" - DOSSIER - "finished",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC58(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTITC58(APPLI)
End
