#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
#   Renouvellement manuel d'un contrat de service                      Module CRM          5 octobre 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
   Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) = Code contrat de service
  #PARAM(2) = Contexte appelant (CON = Contrat de service)
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:CONR]CONENDDAT >= date$ Then
    ETABOU(GSPE2) = 0
  Else
    ETABOU(GSPE2) = 1
  Endif
  If [M:CONR]REWDON Then
    ETABOU(GSPE1) = 0
  Else
    ETABOU(GSPE1) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CONR]REWDON = 0
  [M:CONR]CONNUM = PARAM(1)
  Read [CON]CON0=[M:CONR]CONNUM
  If fstat Then
    #Erreur lors de la lecture du contrat de service. Renouvellement abandonné.
    GMESSAGE = mess(353,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If [F:CON]MANREWFLG = 2 Then
    #Une demande de renouvellement a déjà été enregistrée pour ce contrat. Accès refusé.
    GMESSAGE = mess(364,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  Gosub LOADCONA
  Affzo [M:CONR]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CONR]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      If PARAM(2) = "CON" Then
        Gosub ONREW
      Endif
    When "B"
      Gosub ONTODAY
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Chargement de l'écran
$LOADCONA
  [M:CONR]RREWFRY = [F:CON]REWFRY
  [M:CONR]RREWFRYBAS = [F:CON]REWFRYBAS
  [M:CONR]RCONREW = [F:CON]CONREW
  [M:CONR]CONENDDAT = [F:CON]CONENDDAT
  [M:CONR]RCUR = [F:CON]CUR
  If [F:CON]CONENDDAT < date$ Then
    [M:CONR]RCONSTRDAT = date$
    Call SETENDDAT([M:CONR]RCONSTRDAT, [M:CONR]RREWFRY, [M:CONR]RREWFRYBAS, [M:CONR]RCONENDDAT) From SUBCOND
  Else
    [M:CONR]RCONSTRDAT = [F:CON]CONENDDAT + 1
    Call SETENDDAT([M:CONR]RCONSTRDAT, [M:CONR]RREWFRY, [M:CONR]RREWFRYBAS, [M:CONR]RCONENDDAT) From SUBCOND
  Endif
  If [F:CON]CONCAT = 1 Then
    [M:CONR]RCONAMT = 0
    Grizo [M:CONR]RCONAMT
  Else
    [M:CONR]RCONAMT = [F:CON]CONAMT
    Actzo [M:CONR]RCONAMT
  Endif
Return

##########################################################################################################
# Traitement du bouton Renouveler le contrat.
$ONREW
Local Integer ISCONAOK
Local Integer IRVAFLG
Local Date DNDAT

  If [F:CON]CONCAT = 1 Then
    Gosub REWNOW
  Else
    If [F:CON]NEXINVDAT = [00/00/00] Then
      Gosub REWNOW
    Else
      Gosub REWBYINV
    Endif
  Endif
  If !GERR Then
    [M:CONR]REWDON = 1
  Endif
Return

##########################################################################################################
# Renouvelle le contrat maintenant.
###############################################################
$REWNOW
Local Integer IENDDATCTL
Local Integer IC
Local Date DOLDCONSTR
Local Date DOLDCONEND

  # FGR 29/04/2011 : X3SUIVI63021 : Tout un contrat dans une même transaction et gestion des erreurs
  IC = 0
  IENDDATCTL = 0
  #Mémorise l'ancienne date de début et de fin du contrat
  DOLDCONSTR = [F:CON]CONSTRDAT
  DOLDCONEND = [F:CON]CONENDDAT
  #
  Call DEBTRANS From GLOCK
  Trbegin [CON]
  #
  Read [CON]CON0=[M:CONR]CONNUM
  If fstat Then
    #Le renouvellement du contrat de service a échoué. Transaction abandonnée.
    GMESSAGE = mess(363,182,1)
    GERR = 1
    Rollback
    Return
  Endif
  If [M:CON4]CONENDDAT > date$ Then
    IENDDATCTL = 1
  Endif
  [M:CON4]CONSTRDAT = [M:CONR]RCONSTRDAT
  Call SETENDDAT([M:CONR]RCONSTRDAT, [M:CONR]RREWFRY, [M:CONR]RREWFRYBAS, [M:CON4]CONENDDAT) From SUBCOND
  [M:CON4]REWFRY = [M:CONR]RREWFRY
  [M:CON4]REWFRYBAS = [M:CONR]RREWFRYBAS
  [M:CON4]CONREW = [M:CONR]RCONREW
  [M:CON4]CONAMT = [M:CONR]RCONAMT
  [M:CON2]LASINVDAT = [00/00/00]
  Call CPTCONINF From SUBCONB1
  If [M:CON4]RVAFRY <> 0 Then
    If [M:CON4]RVAFRYBAS > 0 Then
      If [M:CON4]RVAFRYBAS <> 6 Then
        If [M:CON4]RVAMET = 2 Then
          If [M:CON4]RVASSP = 1 Then
            If [F:CON]CONBASIDX <> "" Then
              [M:CON2]NEXINVAMT = 0
            Endif
          Endif
          If [M:CON4]RVASSP = 2 Then
            If [M:CON4]CONBASFOR <> "" Then
              [M:CON2]NEXINVAMT = 0
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  [F:CON] = [M:CON0]
  [F:CON] = [M:CON1]
  [F:CON] = [M:CON4]
  [F:CON] = [M:CON8]
  [F:CON] = [M:CONG]
  [F:CON] = [M:CON2]
  [F:CON] = [M:CON5]
  # FGR 17/07/2008 : X2SUIVI48385 Pour ajout d'un point d'entrée
  Gosub PE_RENCONSER From TRTCRMPE
  # Note FGR : Comme dans le PE on est susceptible de créer un enregistrement dans une table
  #            Je test si GERR<>1 pour détecter qu'il n'y a pas eu d'erreur et réécrire [CON]
  #            C'est celui qui fait le PE qui a la charge du Rollback
  If GERR <> 1 Then
    Rewrite [CON]
    If fstat Then
      #Le renouvellement du contrat de service a échoué. Transaction abandonnée.
      GMESSAGE = mess(363,182,1)
      GERR = 1
      Rollback
      Return                  # FGR 29/04/2011 : X3SUIVI63021
    Endif
  Endif
  #Calcul le numéro d'enregistrement du nouvel historique.
  While 1
    Read [CRE]CRE1=[M:CONR]CONNUM;IC
    If fstat
      Break
    Endif
    IC += 1
  Wend
  #Ajoute un historique de renouvellement au contrat
  If GREWHISMOD = 1 Then
    #Avec l'ancienne période
    Call SAVEREW([M:CONR]CONNUM, IC, DOLDCONSTR, DOLDCONEND) From SUBCONB1
  Else
    #Avec la nouvelle période
    Call SAVEREW([M:CONR]CONNUM, IC, [M:CONR]RCONSTRDAT, [M:CONR]RCONENDDAT) From SUBCONB1
  Endif
  # -------------------------------------
  # FGR 29/04/2011 : X3SUIVI63021 (début)
  If GERR <> 0 Then
    Rollback
    Return
  Else
    Commit
  Endif
  # FGR 29/04/2011 : X3SUIVI63021 (fin)
  # -----------------------------------
  # Chargement du tableau des renouvellements
  Call LOADREW From SUBCONB1
  Affzo [M:CON0]1-99
  Affzo [M:CON1]1-99
  Affzo [M:CON4]1-99
  Affzo [M:CON8]1-99
  Affzo [M:CONG]1-99
  Affzo [M:CON2]1-99
  Affzo [M:CON5]1-99
Return

##########################################################################################################
# Flag le contrat comme à renouveler par la dernière facture
###############################################################
$REWBYINV
  Call DEBTRANS From GLOCK
  Trbegin [CON]
  Read [CON]CON0=[M:CONR]CONNUM
  If fstat Then
    #Le renouvellement du contrat de service a échoué. Transaction abandonnée.
    GMESSAGE = mess(363,182,1)
    GERR = 1
    Rollback
    Return
  Endif
  [F:CON]DSYWND = 1
  [F:CON]MANREWFLG = G_OUI
  # -------------------------------------
  # FGR 27/06/2011 : X3SUIVI74226 (début)
  [F:CON]MANREWFRY = [M:CONR]RREWFRY
  [F:CON]MANREWFRYBAS = [M:CONR]RREWFRYBAS
  [F:CON]MANCONREW = [M:CONR]RCONREW
  [F:CON]MANCONSTRDAT = [M:CONR]RCONSTRDAT
  [F:CON]MANCONENDDAT = [M:CONR]RCONENDDAT
  # FGR 27/06/2011 : X3SUIVI74226 (fin)
  # -------------------------------------
  [F:CON]MANREWAMT = [M:CONR]RCONAMT
  # FGR 17/07/2008 : X2SUIVI48385 Pour ajout d'un point d'entrée
  Gosub PE_RENCONSER From TRTCRMPE
  # Note FGR : Comme dans le PE on est susceptible de créer un enregistrement dans une table
  #            Je test si GERR<>1 pour détecter qu'il n'y a pas eu d'erreur et réécrire [CON]
  #            C'est celui qui fait le PE qui a la charge du Rollback
  If GERR <> 1 Then
    Rewrite [CON]
    If fstat Then
      #Le renouvellement du contrat de service a échoué. Transaction abandonnée.
      GMESSAGE = mess(363,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Commit
    Endif
    [M:CON4]MANREWFLG = G_OUI
    # -------------------------------------
    # FGR 27/06/2011 : X3SUIVI74226 (début)
    [M:CON4]MANREWFRY = [F:CON]MANREWFRY
    [M:CON4]MANREWFRYBAS = [F:CON]MANREWFRYBAS
    [M:CON4]MANCONREW = [F:CON]MANCONREW
    [M:CON4]MANCONSTRDAT = [F:CON]MANCONSTRDAT
    [M:CON4]MANCONENDDAT = [F:CON]MANCONENDDAT
    [M:CON4]MANREWAMT = [F:CON]MANREWAMT
    # FGR 27/06/2011 : X3SUIVI74226 (fin)
    # -------------------------------------
    [M:CON4]REWWRN = mess(365,182,1)  #Prochain renouvellement accepté.
    Affzo [M:CON4]1-99
  Endif
Return

##########################################################################################################
# Traitement du bouton Date du jour
$ONTODAY
  [M:CONR]RCONSTRDAT = date$
  Call SETENDDAT([M:CONR]RCONSTRDAT, [M:CONR]RREWFRY, [M:CONR]RREWFRYBAS, [M:CONR]RCONENDDAT) From SUBCOND
  Affzo [M:CONR]1-99
Return
