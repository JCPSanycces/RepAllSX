###########################################################################################
# SRETURN_PROPERTIES : Sous-prog gestion propriétés la classe SRETURN : Retour Client     #
###########################################################################################
End
# ----------------------- CPY --------------------------------------
$CPY
Case [L]ARULE
  When "PROPAGATE" : Gosub PROPAGATE_CPY
  When Default     : Return
Endcase

Return


$PROPAGATE_CPY

Local Integer WI

  If this.CPY<>""
      Local File COMPANY [CPY]
      Read [F:CPY]CPY0=this.CPY
      If fstat Raz [F:CPY] : Endif
      this.LEG = [F:CPY]LEG
      Close Local File [CPY]
  Endif

Return

