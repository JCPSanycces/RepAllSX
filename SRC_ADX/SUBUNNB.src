#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet UNNB
######################################################################################
## Etiquette ajoutée par le superviseur (Objet UNNB) 24/03/2017 13:31:24 (MAE)
######################################################################################
$ACTION
Case ACTION
  When "SETBOUT" : Gosub SETBOUT
  When "INICRE"   Gosub INICRE
  When "INIMOD"   Gosub INICRE
  When "ANNULE"   Gosub ANNULE
  When "LIENS"    Gosub LIENS
  When "CHANGE" : Call CHANGE_AXX ("TABUNNBR", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return

$INICRE
    Call MAJTEXTRA([M:UN1]UNSHOAXX,"TABUNNBR","UNSHOAXX",num$([M:UN1]UNNBR),"") From ATEXTRA
Return

$LIENS
Call LECTEXTRA([M:UN1]UNSHOAXX,"TABUNNBR","UNSHOAXX",num$([M:UN1]UNNBR),"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="TABUNNBR" & ZONE="UNSHOAXX" & IDENT1= num$([M:UN1]UNNBR)
Return

############################################################
$SETBOUT
#Call VIREBOUT(CHAINE,"DH") From GOBJET
Return
############################################################
Subprog C_UNNBR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]UNNBR) From OBJDIV
End
############################################################
Subprog AV_UNSHOAXX(VALEUR)
Variable Char     VALEUR
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran UNNB1) 31/03/2017 08:26:18 (MAE)
######################################################################################
Subprog AM_UNNBR(VALEUR)
Variable Char    VALEUR()
Local Char XVALEUR(4)
XVALEUR = ctrans(VALEUR,sigma(I=1,47,chr$(I))+sigma(I=58,255,chr$(I)),"")
If VALEUR <> XVALEUR
  GMESSAGE = mess(38,148,1) : mkstat = 2 : End
Endif
If len(VALEUR) <> 4
  VALEUR = string$(4-len(VALEUR),"0")+VALEUR
Endif
End


######################################################################################

