#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLSAL01   Contrôle Pre-migration Devis                Module Ventes #
#                                                                          #
# Toutes versions :                                                        #
# ---------------                                                          #
# SQUOTE  without SQUOTED                                                  #
# SQUOTED without SQUOTE                                                   #
# SQUOTED with SALFCY different from SQUOTE                                #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLSAL01") From LECFIC
  Endif

  Call MAJ_UUMGCTLSAL01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLSAL01(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(4)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLSAL01 Sales Quote Process : SQUOTE-D") From DOSSUB
Call ECR_TRACE("UUMGCTLSAL01 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1
Gosub CTL2
Gosub CTL3

$FIN
Call ECR_TIME("UUMGCTLSAL01 : Sales Quote Process END.") From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTED") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SQH.SQHNUM_0 FROM "-DOSSIER+".SQUOTE SQH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SQUOTED SQD WHERE SQH.SQHNUM_0=SQD.SQHNUM_0) "
REQSQL(2)="ORDER BY SQH.SQHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SQUOTE without SQUOTED",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSQHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SQHNUM="-[BXX]VSQHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTED") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SQD.SQHNUM_0,SQD.SQDLIN_0 FROM "-DOSSIER+".SQUOTED SQD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SQUOTE SQH WHERE SQH.SQHNUM_0=SQD.SQHNUM_0) "
REQSQL(2)="ORDER BY SQD.SQHNUM_0,SQD.SQDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SQUOTED without SQUOTE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSQHNUM(50),Integer VSQDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SQHNUM/SQDLIN="-[BXX]VSQHNUM+'/'+num$([BXX]VSQDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

###################################################################################
$CTL3
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTE")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SQUOTED") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SQD.SQHNUM_0,SQD.SQDLIN_0 FROM "-DOSSIER+".SQUOTED SQD "
REQSQL(1)="WHERE SQD.SALFCY_0<>(SELECT SQH.SALFCY_0 FROM"-DOSSIER+".SQUOTE SQH WHERE SQH.SQHNUM_0=SQD.SQHNUM_0) "
REQSQL(2)="ORDER BY SQD.SQHNUM_0,SQD.SQDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SQUOTED with SALFCY different from SQUOTE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSQHNUM(50),Integer VSQDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SQHNUM/SQDLIN="-[BXX]VSQHNUM+'/'+num$([BXX]VSQDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif

Return
###################################################################################

