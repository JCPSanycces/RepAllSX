#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "IMPORT"        : Gosub IMPORT
  When "IMP_OUVRE"     : Gosub OUVRE
Endcase
Return



$IMPORT
Local Integer NOFORBANK
Local Integer BIDLENGTH
Local Char    BID(5)
Local Char PAB(30)
Local Char BIC(30)
Local Char    ID(1)

  COUNT = COUNT + 1
  If  left$(GIMP(1), 1) = '"'
    [M:ABN1]CRY = "AT"

    BID = mid$(GIMP(1), 2, len(GIMP(1)) -2)
    PAB = mid$(GIMP(2), 2, len(GIMP(2)) -2)
    BIC = mid$(GIMP(3), 2, len(GIMP(3)) -2)
    #set leading zeros
    For BIDLENGTH = len(BID) + 1 To 5
      BID = "0"+BID
    Next

    [M:ABN1]BAN = BID
    [M:ABN1]PAB = PAB
    [M:ABN1]BIC = BIC
  Else
    OK = 0
    NBERR -= 1
  Endif
Return

$OUVRE
Local Integer NBDROP_
Local Integer COUNT
# delete all existing AT postcodes
  Filter [F:ABN] Where CRY="AT"
  NBDROP_=rowcount([F:ABN])
  Filter [F:ABN]
  Trbegin [F:ABN]
  Delete [F:ABN] Where CRY="AT"
  If fstat=0
    Call ECR_TRACE(func AFNC.MES1( mess(19,3648,1), num$(NBDROP_)), 0) From GESECRAN
    Commit
  Else
    Call ECR_TRACE(mess(20,3648,1), 1) From GESECRAN
    GOK = -1
    Rollback
  Endif
Return

