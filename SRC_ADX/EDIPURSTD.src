######################################################################################

Subprog AS_NUMBATCHFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR = ""
    VALEUR = [M]NUMBATCHDEB
  Endif
End

Subprog C_NUMBATCHFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR<[M]NUMBATCHDEB
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
End

Subprog AS_CREDATFIN(VALEUR)
Variable Date    VALEUR
  If VALEUR = [0/0/0]
    VALEUR = [M]CREDATDEB
  Endif
End

Subprog C_CREDATFIN(VALEUR)
Variable Date    VALEUR
  If VALEUR<[M]CREDATDEB
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
End

Subprog AS_PARCODFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR = ""
    VALEUR = [M]PARCODDEB
  Endif
End

Subprog C_PARCODFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR<[M]PARCODDEB
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
End

Subprog AS_CATCODFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR = ""
    VALEUR = [M]CATCODDEB
  Endif
End

Subprog C_CATCODFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR<[M]CATCODDEB
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
End

######################################################################################

Funprog TEST_STA(WSTA2, WSTA3, WSTA4, WERR)
Value Integer WSTA2
Value Integer WSTA3
Value Integer WSTA4
Variable Char WERR
  Local Integer WOK
  WOK = [V]CST_ATRUE
  WERR = ""
  If WSTA2 = [V]CST_ANO and WSTA3 = [V]CST_ANO and WSTA4 = [V]CST_ANO
    WOK = [V]CST_AFALSE
    WERR = mess(175,2006,1) #"Selectionner au moins un status"
  Endif
End WOK

######################################################################################

Funprog TEST_TESTFLG(WTESTFLGYES, WTESTFLGNO, WERR, WLAN)
Value Integer WTESTFLGYES
Value Integer WTESTFLGNO
Variable Char WERR
Value Char WLAN
  Local Integer WOK
  WOK = [V]CST_ATRUE
  WERR = ""
  If WTESTFLGYES = [V]CST_ANO and WTESTFLGNO = [V]CST_ANO
    WOK = [V]CST_AFALSE
    Call TEXTELAN(1485,WERR,WLAN) From OBJDIV #Test
    WERR = mess(175,2006,1)-"("+WERR+")" #"Selectionner au moins un status (test)"
  Endif
End WOK

######################################################################################

Funprog GET_DATEDEB()
  Local Date WDATEDEB
#  Local Date WDATEFIN
#  WDATEFIN = date$ - val(format$("D:2D",date$))
#  WDATEDEB = format$("D:2Y2M",WDATEFIN)+"01"
  WDATEDEB = [0/0/0]
End WDATEDEB

######################################################################################

Funprog GET_DATEFIN()
  Local Date WDATEFIN
#  Local Date DATETEST : DATETEST = date$ +30
#  WDATEFIN = DATETEST - val(format$("D:2D",DATETEST)) - 60
  WDATEFIN = date$ - val(format$("D:2D",date$)) - 60
End WDATEFIN

