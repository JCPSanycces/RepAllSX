#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque DIA

######################################################################################
## Etiquette ajoutée par le superviseur (écran DIA) 29/02/2016 16:43:25 (RBA)
######################################################################################

$ACTION
  Case ACTION
    When "INIT_DIA"     : Gosub INIT_DIA
    When "CONT_BATCH"   : Gosub CONT_BATCH
    When "EXEC"         : Gosub EXEC
    When Default
  Endcase
Return

######################################################################################

$INIT_DIA
  Gosub OUVRE From GIMPOBJ
  [M:DIA]TESTFLGYES = [V]CST_AYES
  [M:DIA]TESTFLGNO  = [V]CST_ANO
  [M:DIA]STA2       = [V]CST_ANO
  [M:DIA]STA3       = [V]CST_ANO
  [M:DIA]STA4       = [V]CST_ANO
  [M:DIA]CREDATDEB  = func GET_DATEDEB()
  [M:DIA]CREDATFIN  = func GET_DATEFIN()
Return

######################################################################################

$CONT_BATCH
  Local Char WLAN(3) : WLAN=GLANGUE

  #test : at least one status is checked
  Local Char WERR(250)
  If func TEST_TESTFLG([M:DIA]TESTFLGYES, [M:DIA]TESTFLGNO, WERR, WLAN) = [V]CST_AFALSE
    GMESSAGE = WERR
    GERR = 1
  Endif
  If func TEST_STA([M:DIA]STA2, [M:DIA]STA3, [M:DIA]STA4, WERR) = [V]CST_AFALSE
    GMESSAGE = WERR
    GERR = 1
  Endif
Return

######################################################################################

$EXEC
  Local Integer WOK
  Local Char WTRACEFILE(100), WERR(250), WERR1(250), WERR2(250)

  Local Integer ANOWRITE
  ANOWRITE = 1
  Global Instance MYEDIPURGE Using C_EDIPURGE
  MYEDIPURGE = NewInstance C_EDIPURGE AllocGroup null

  MYEDIPURGE.NUMBATCHDEB = [M:DIA]NUMBATCHDEB
  MYEDIPURGE.NUMBATCHFIN = [M:DIA]NUMBATCHFIN
  MYEDIPURGE.PARCODDEB   = [M:DIA]PARCODDEB
  MYEDIPURGE.PARCODFIN   = [M:DIA]PARCODFIN
  MYEDIPURGE.CATCODDEB   = [M:DIA]CATCODDEB
  MYEDIPURGE.CATCODFIN   = [M:DIA]CATCODFIN
  MYEDIPURGE.CREDATDEB   = [M:DIA]CREDATDEB
  MYEDIPURGE.CREDATFIN   = [M:DIA]CREDATFIN
  MYEDIPURGE.TESTFLGNO   = [M:DIA]TESTFLGNO
  MYEDIPURGE.TESTFLGYES  = [M:DIA]TESTFLGYES
  MYEDIPURGE.STA2        = [M:DIA]STA2
  MYEDIPURGE.STA3        = [M:DIA]STA3
  MYEDIPURGE.STA4        = [M:DIA]STA4

  Local Char WLAN(3) : WLAN=GLANGUE

  WOK = fmet MYEDIPURGE.MET_PURGE(WTRACEFILE)
  If WOK > 0
    #errors
    WERR = mess(177,2006,1) #EDI purge process terminated with warnings
    Call ECR_TRACE(WERR,[V]CST_AERROR) From GESECRAN
  Else
    WERR = mess(176,2006,1) #EDI purge process terminated successfuly
    Call ECR_TRACE(WERR,[V]CST_AOK) From GESECRAN
  Endif
  If WTRACEFILE = ""
    Call TEXTELAN(22703,WERR1,WLAN) From OBJDIV #Log file
    Call TEXTELAN(7243,WERR2,WLAN) From OBJDIV #Error
    WERR = WERR1+":"-WERR2
    Call ECR_TRACE(WERR,[V]CST_AERROR) From GESECRAN
  Else
    Call TEXTELAN(22703,WERR,WLAN) From OBJDIV #Log file
    Call ECR_TRACE(WERR+":"-WTRACEFILE+".tra",[V]CST_AOK) From GESECRAN
  Endif

  If (MYEDIPURGE <> null) : FreeGroup MYEDIPURGE : Endif
  Kill MYEDIPURGE


