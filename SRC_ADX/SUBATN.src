#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ATN",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "SEL_LISTE" : Gosub SEL_LISTE 
Endcase
Return

$LIENS
Call TEXTE([F:ATN]DES,[M]ZDES) From OBJDIV
Gosub GRISE_COP
Gosub GRISE_OBJ
Gosub GRISE_TBL
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Else
 CHMEN += "1"
Endif
Return

#------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "ASELAT1" : Gosub SELAT1
Endcase
Return

$SELAT1
Local Integer NOTEX
Local Char    PROGOBJ(GLONADC) , OBJET(GLONAOB)
Local Char    TEX(GLONAT1)(1..200) , TEXTE(GLONDES)(1..200,1..2) , TIT(GLONDES)(3)
OBJET = PARAM(1)
If OBJET="" & dim([M:AON1]ABREV)>0
 OBJET = [M:AON1]ABREV
Endif
PROGOBJ = "WO"+OBJET
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
NBTEX = 0
For [AWI]AWI1 Where OBJ=OBJET & ENAFLG=2 & MDL<>2
 OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK & [F:AWI]TRN<>""
  NBTEX += 1
  TEX(NBTEX) = [F:AWI]TRN
  Call TITTRN(TEXTE(NBTEX,1),TEXTE(NBTEX,2)) From =PROGOBJ
  If TEXTE(NBTEX,2)="" & dim([F:AWI]LIBEL)>0 & [F:AWI]LIBEL<>""
   TEXTE(NBTEX,2) = [F:AWI]LIBEL
  Endif
 Endif
Next AWI
TIT = mess(3,126,1) : # Choix transaction
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Return

#------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File ATRANSAC [ATN1]
 Local File ATEXTE   [ATX1]
Else 
 Local File =[M]DOSORG+".ATRANSAC" [ATN1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1]
Endif 
If [M]DOSDES=nomap 
 Local File ATRANSAC [ATN2] 
 Local File ATEXTE   [ATX2] 
Else 
 Local File =[M]DOSDES+".ATRANSAC" [ATN2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ATN1], [ATN2] , [ATX1] , [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ATN2]
 Delete [ATN2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTION" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACT2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ATN1] Where COD=TABLE
  [F:ATN2] = [F:ATN1]
  Call COPTEXTE([F:ATN1]DES,[F:ATN2]DES) From OBJDIV
  If dim([F:ATN2]UPDUSR)>0 : [F:ATN2]UPDUSR = GUSER : Endif
  If dim([F:ATN2]UPDDAT)>0 : [F:ATN2]UPDDAT = date$ : Endif
  Write [ATN2]
  If fstat
   GOK=0 : Call FSTA("ATN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


###################################################
## Ecran ATN1
###################################################
Subprog C_FLDCOD(VALEUR)
Variable Char VALEUR()
Read [ATZ]CODZONE = [M]TBL;VALEUR
If fstat
 GMESSAGE = mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Endif
End

Subprog C_CODTRT(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If VALEUR<>"" & GADONIX=2
 Call CHERCHE("Subprog GENDOS",VALEUR,ER,GMESSAGE)
 If ER : mkstat = 1 : End : Endif
Endif
End

Subprog C_OBJGES(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Read [AOB]ABREV = VALEUR
If [F:AOB]TYPGES>3
 GMESSAGE = mess(42,115,1) : # Type d'objet incorrect
 mkstat = 2 : End
Endif
Read [ATN]ATN1=VALEUR
If !fstat & [F:ATN]COD<>[M]COD
 GMESSAGE = VALEUR-":"-mess(119,139,1)-[F:ATN]COD : # Objet déjà utilisé dans un autre type de transaction
Endif
End

Subprog C_COP(VALEUR)
Value Integer VALEUR
Local Integer ER
If VALEUR=2 & GADONIX=2
 Call CHERCHE("$TRTCOP",[M]CODTRT,ER,GMESSAGE)
 If ER : mkstat = 1 : End : Endif
Endif
[M]COP = VALEUR
Gosub GRISE_COP
End

$GRISE_COP
If [M]COP<>2
 Effzo OBJ,TBL,FLDCOD,CND
 Grizo OBJ,TBL,FLDCOD,CND
Else
 Actzo OBJ,TBL,FLDCOD,CND
Endif
Return

Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("AOB",VALEUR,"") From CONTOBJ
 If [M]OBJGES<>""
  Read [ATB]CODFIC = [F:AOB]NOMFIC
  If fstat or [F:ATB]INTIT="" 
   # Le champ "Champ intitulé" de cette table n'est pas renseigné
   GMESSAGE = [F:AOB]NOMFIC-":"-mess(118,139,1)
   mkstat = 2 : End
  Endif
 Endif
 [M]TBL = [F:AOB]NOMFIC
 Affzo TBL
Endif
[M]OBJ = VALEUR
End

$GRISE_OBJ
If [M]OBJ<>"" or [M]COP<>2
 Grizo TBL
Else
 Actzo TBL
Endif
Return

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If [M]OBJGES<>""
  Read [ATB]CODFIC = VALEUR
  If fstat or [F:ATB]INTIT="" 
   # Le champ "Champ intitulé" de cette table n'est pas renseigné
   GMESSAGE = VALEUR-":"-mess(118,139,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
[M]TBL = VALEUR
Gosub GRISE_TBL
End

$GRISE_TBL
If [M]TBL=""
 Effzo FLDCOD,CND
 Grizo FLDCOD,CND
Else
 Actzo FLDCOD,CND
Endif
Return

Subprog CHERCHE(ETQ,PRG,ER,ERMES)
Value Char ETQ , PRG
Variable Integer ER
Variable Char    ERMES
Local Char    TRAIT(GDIMFIC) , LIGNE(255)
Local Integer OK , OKTRT
Raz ER , ERMES
If PRG="" : End : Endif
TRAIT  = filpath("TRT",PRG,"src")
If filinfo(TRAIT,0)<0
 Call EXISTE_ADX("","",PRG,OKTRT) From ORDSYS
 If !OKTRT
  ERMES = "|"+TRAIT-":"-mess(90,123,1) : # Traitement inexistant
  ER = 1
 Endif
 End
Else
 OK = 0
 Openi TRAIT Using [TTT]
 Iomode adxifs "" Using [TTT]
 Iomode adxirs chr$(10) Using [TTT]
 Rdseq LIGNE Using [TTT]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  If left$(LIGNE,len(ETQ))=ETQ
   OK = 1 : Break
  Endif
  Rdseq LIGNE Using [TTT]
 Wend
 If !OK
  # L'étiquette $1$ n'existe pas dans le traitement $2$
  ERMES = func AFNC.MES2(mess(4,143,1),'"'+ETQ+'"',PRG)
  ER = 2 : End
 Endif
Endif
End
