#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:26"
A_USER  = "DOC"
A_STAMP = "20181109230426"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "VLYNBR"
  If [M]VLYNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENHREXT4 [HREXE4]
Gosub HORODAT
Local Inpbox "GENHREXT4" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE4] As [SIM_]
Grizo [HREXE4]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXE4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_VLYDTALVL
Onevent INIT_AREA Call D_VLYDTALVL(zc) From W1GENHREXT4
Onevent BEFORE_INPUT Call AS_VLYDTALVL(zc) From W1GENHREXT4
Return

Subprog D_VLYDTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]VLYDTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_VLYDTALVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

