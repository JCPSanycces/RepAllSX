#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SRV1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "SRV"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBSRV
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"SERVICE","DES",[M]COD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DES,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DES" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DESSHO
mkstat = 0
zoncou = "DESSHO"
indice = 0
If varinit([M]DESSHO,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESSHO,"SERVICE","DESSHO",[M]COD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESSHO,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESSHO" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
If varinit([M]ACCCOD,indice)=0
 SAVACT = GACTION : GACTION = "INITACCCOD"
 Call INITACCCOD([M]ACCCOD,28) From TRTX3
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ACCCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTCAC"
  Call CONTCAC([M]ACCCOD,"28") From SUBCAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CAC","!",[M]ACCCOD,"28",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CODACC
mkstat = 0
zoncou = "CODACC"
indice = 0
If varmode([M]CODACC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACC" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACC,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACC" : GZNUM = 71 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTACC"
  Call CONTACC([M]CODACC) From SUBACS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODACC" : GZNUM = 71 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone TRESRV2
mkstat = 0
zoncou = "TRESRV2"
indice = 0
If varmode([M]TRESRV2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRESRV2" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone TRESRV
mkstat = 0
zoncou = "TRESRV"
indice = 0
If varmode([M]TRESRV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRESRV" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"
indice = 0
status = 1
zoncou = "NBRCHEF"
If varinit([M]NBRCHEF,indice)=0
 [M]NBRCHEF = len(mess(0,50,1))
Endif
If varmode([M]NBRCHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCHEF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCHEF
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCHEF = nolign
   status = 75
   Call SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 6
####################################
IMPTBL = 1

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"
indice = 0
status = 1
zoncou = "NBRCCE"
If varmode([M]NBRCCE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCCE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCCE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCCE = nolign
   status = 75
   Call SAI_NBRCCE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

## Zone RESPO
mkstat = 0
zoncou = "RESPO"
IMPENT = [M]RESPO(indice)
If varinit([M]RESPO,indice)=0
 IMPENT = nolign
Endif
[M]RESPO(indice) = IMPENT

## Zone CHEF
mkstat = 0
zoncou = "CHEF"
If varmode([M]CHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHEF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]CHEF(indice),"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]CHEF(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CHEFNAM
mkstat = 0
zoncou = "CHEFNAM"
SAVACT = GACTION : GACTION = "STD"
Call AV_CHEFNAM([M]CHEFNAM(indice)) From SUBSRV
GACTION = SAVACT
If mkstat=1 : Raz [M]CHEFNAM(indice) : Endif

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

End

####################################
## Bloc tableau 6
####################################
Subprog SAI_NBRCCE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"

## Zone DIE
mkstat = 0
zoncou = "DIE"
If varmode([M]DIE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DIE" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("DIE","!",[M]DIE(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DIE" : GZNUM = 29327 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CCE
mkstat = 0
zoncou = "CCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("CCE","!",[M]CCE(indice),num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CNTCCE"
   Call SECTION([M]CCE(indice),1,"",[0/0/0],[M]DIE(nolign-1)) From SUPCPT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SRV1"
Return

