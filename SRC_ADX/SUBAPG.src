#<AdxTL>@(#)93.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call OBJET("APG",GBIDC1,GBIDC2) From GOBJET 
End 
 
 
$ACTION
Case ACTION
 When "DEFBOUT"   : Gosub DEFBOUT 
 When "SETBOUT"   : Gosub SETBOUT 
 When "EXEBOUT"   : Gosub EXEBOUT 
 When "FILTRE"    : Gosub FILTRE
Endcase
Return
  
$FILTRE 
FILTSUP = "AUTO<>2" 
Return 

$DEFBOUT 
NBTEX += 1 
TEX(NBTEX) = "MAJ" 
CBOUT(NBTEX) = "a" 
Return 
 
$SETBOUT 
If GREP<>"" 
  Call VIREBOUT(CHAINE,"a") From GOBJET 
Endif 
Return 
 
$EXEBOUT 
Case REP 
 When "a" : Gosub MAJTAB 
Endcase 
Return 
 
$MAJTAB 
Local Integer NBTRAIT , STAT , DEFMOD
Local Char    TRAIT(10)(1..6000)  
DEFMOD = 0 
#Call TEMPON("V") From GESECRAN 
Call OUVRE_TRACE("Mise à jour table des traitements") From LECFIC 
Call SYSTEME2(adxmac(0),'lsadx -a'-nomap-'TRT src',"",NBTRAIT,TRAIT) From ORDSYS 
Call ECR_TRACE("Il y a"-num$(NBTRAIT)-"traitements",0) From GESECRAN  
Filter [APG]
Gosub VIRE_ANCIEN  : # Verif s'il y a eu des suppressions
Gosub CREE_NOUVEAU : # Catalogue des nouveaux traitements  
Gosub LEC_MSK      : # Affectation d'après les masques 
Gosub LEC_OBJ      : # Affectation depuis les objets
Gosub LEC_FNC      : # Affecation depuis les fonctions  
Gosub LEC_ACT      : # Affectation depuis les actions 
Gosub LEC_SPG      : # Affectation depuis les sous_programmes 
Gosub LEC_REP      : # Affectation depuis les états
Gosub LEC_CNS      : # Affectation depuis les consultations
Gosub LEC_XREF     : # Affectation depuis les références croisées 
# Petit comptage final 
NBX = 0 
For [APG]APG0 Where MODULE=DEFMOD 
 NBX += 1 
Next 
Call ECR_TRACE("Il reste"-num$(NBX)-"traitements non affectés",0) From GESECRAN
#Call TEMPOFF  From GESECRAN 
Call FERME_TRACE From LECFIC  
Gosub RELIT From GOBJSUB 
Call LEC_TRACE from LECFIC 
Return 
  
$VIRE_ANCIEN 
For [APG]APG0 
 If filinfo(filpath("TRT",[F:APG]PRG,"src"),0)<0 
  Call ECR_TRACE([F:APG]PRG-"traitement supprimé",0) From GESECRAN 
  Trbegin [APG] 
   Delete [APG] 
  Commit 
 Endif 
Next 
Return 

$CREE_NOUVEAU 
Local Integer INTERRUPT , NBW , NBX , NBY , NBZ , NBB , NBOK 
Raz NBW , NBX , NBY , NBZ , NBB , NBOK
Call OUVRE_BOITE("Traitements",NBTRAIT) From GESECRAN
For I=1 To NBTRAIT
 Call AFF_BOITE("Traitement"-TRAIT(I),I,INTERRUPT) From GESECRAN
 If filinfo(filpath("TRT",TRAIT(I),"adx"),0)<0 
  Call ECR_TRACE(TRAIT(I)-"source non compilé",0) From GESECRAN 
 Endif 
 OK = 1 
 OK *= TRAIT(I)<"W" 
 OK *= TRAIT(I) = toupper(TRAIT(I)) 
 If OK 
  NBOK += 1 
  DATMOD = [01/01/1970] + filinfo(filpath("TRT",TRAIT(I),"src"),9)/(3600*24) 
  Read [APG]APG0 = TRAIT(I) 
  If fstat 
   Call DEBTRANS From GLOCK 
   Gosub TR1 
   If GOK=1 
    Call ECR_TRACE (TRAIT(I)-"Nouveau traitement",0) From GESECRAN 
   Endif 
  Elsif DATMOD>[F:APG]UPDDAT 
   Trbegin [APG] 
    [F:APG]UPDDAT = DATMOD 
    [F:APG]DERDAT = date$
    Rewrite [APG] 
   Commit
  Endif  
 Else 
  Case left$(TRAIT(I),1) 
   When "W" : NBW += 1 
   When "X" : NBX += 1 
   When "Y" : NBY += 1 
   When "Z" : NBZ += 1 
   When Default : NBB += 1 
  Endcase 
 Endif
Next I 
Call FERME_BOITE From GESECRAN 
If NBW 
 Call ECR_TRACE("Il y a"-num$(NBW)-"traitements commençant par W",0) From GESECRAN 
Endif 
If NBX 
 Call ECR_TRACE("Il y a"-num$(NBX)-"traitements commençant par X",0) From GESECRAN 
Endif
If NBY 
 Call ECR_TRACE("Il y a"-num$(NBY)-"traitements commençant par Y",0) From GESECRAN 
Endif 
If NBZ 
 Call ECR_TRACE("Il y a"-num$(NBZ)-"traitements commençant par Z",0) From GESECRAN 
Endif 
If NBB 
 Call ECR_TRACE("Il y a"-num$(NBB)-"traitements bizarres",0) From GESECRAN 
Endif 
Call ECR_TRACE("Il y a"-num$(NBOK)-"traitements catalogués",0) From GESECRAN 
Return 
 
$TR1 
GOK = 1 
Trbegin [APG] 
 Raz [F:APG] 
 [F:APG]PRG    = TRAIT(I) 
 [F:APG]MODULE = DEFMOD
 [F:APG]AUTO   = 1 
 Onerrgo RIEN : # filcom plante dans certains cas
 [F:APG]INTIT  = filcom("TRT",TRAIT(I),"src")  
 Onerrgo
 [F:APG]APPLI  = nomap 
 [F:APG]REFDAT = date$ 
 [F:APG]UPDDAT = DATMOD
 [F:APG]LIEN   = "" 
 [F:APG]DERDAT = date$  
 Write [APG] 
 If fstat 
  GOK = 0 : Call FSTA("APG") From GLOCK : Goto AB_TR1 
 Endif 
Commit 
Return 
 
$AB_TR1 
Rollback 
Return 
 
 
$RIEN 
Resume 

 
$LEC_MSK 
Local Integer INTERRUPT 
Local File AMSK [AMK] 
Call OUVRE_BOITE("",nbrecord([AMK])) From GESECRAN 
I = 0 
For [AMK] Where CODMSK<"W" 
 I += 1 
 Call AFF_BOITE("Masque"-[F:AMK]CODMSK,I,INTERRUPT) From GESECRAN 
 Read [APG]APG0 = [F:AMK]TRTAUTO 
 If fstat 
  Call ECR_TRACE("Masque"-[F:AMK]CODMSK-"traitement auto inexistant :"-[F:AMK]TRTAUTO,0) From GESECRAN 
 Else 
  If [F:APG]AUTO<>2 or [F:APG]MODULE<>[F:AMK]MODULE 
   Trbegin [APG] 
    [F:APG]AUTO   = 2 
    [F:APG]MODULE = [F:AMK]MODULE 
    [F:APG]LIEN   = "MSK"-[F:AMK]CODMSK
    [F:APG]DERDAT = date$ 
    Rewrite [APG] 
   Commit 
  Endif 
 Endif 
 Read [APG]APG0 = [F:AMK]TRTSPE 
 If !fstat 
  Call ECR_TRACE("Masque"-[F:AMK]CODMSK-"traitement spécifique existant :"-[F:AMK]TRTSPE,0) From GESECRAN 
 Endif 
 Read [APG]APG0 = [F:AMK]TRTSTD 
 If fstat 
  Call ECR_TRACE("Masque"-[F:AMK]CODMSK-"traitement standard inexistant :"-[F:AMK]TRTSTD,0) From GESECRAN 
 Else 
  If [F:APG]AUTO=2 or [F:APG]MODULE<>[F:AMK]MODULE 
   Trbegin [APG] 
    [F:APG]AUTO = 1 
    [F:APG]MODULE = [F:AMK]MODULE 
    [F:APG]LIEN   = "MSK"-[F:AMK]CODMSK
    [F:APG]DERDAT = date$ 
    Rewrite [APG] 
   Commit 
  Endif 
 Endif 
Next 
Call FERME_BOITE From GESECRAN 
Close Local File [AMK] 
Return 
 
$LEC_OBJ 
Local Integer INTERRUPT 
Local File AOBJET [AOB] 
Call OUVRE_BOITE("",nbrecord([AOB])) From GESECRAN 
I = 0 
For [AOB] Where ABREV<"W"
 I += 1 
 Call AFF_BOITE("Objet"-[F:AOB]ABREV,I,INTERRUPT) From GESECRAN 

 Read [APG]APG0 = "GES"+[F:AOB]ABREV 
 If fstat 
  Call ECR_TRACE("Objet"-[F:AOB]ABREV-"traitement inexistant : GES"+[F:AOB]ABREV,0) From GESECRAN 
 Elsif [F:APG]AUTO<>2 or [F:APG]MODULE<>[F:AOB]MODULE 
  Trbegin [APG] 
   [F:APG]MODULE = [F:AOB]MODULE 
   [F:APG]AUTO   = 2 
   [F:APG]LIEN   = "OBJ"-[F:AOB]ABREV
   [F:APG]DERDAT = date$ 
  Rewrite [APG] 
  Commit 
 Endif 

 Read [APG]APG0 = "IMP"+[F:AOB]ABREV 
 If fstat = 0
    If  [F:APG]MODULE<>[F:AOB]MODULE 
      Trbegin [APG] 
      [F:APG]MODULE = [F:AOB]MODULE 
      [F:APG]LIEN   = "OBJ"-[F:AOB]ABREV
      [F:APG]DERDAT = date$ 
      Rewrite [APG] 
      Commit 
   Endif
 Endif 
Next 
Close Local File [AOB] 
Call FERME_BOITE From GESECRAN 
Return 
 
$LEC_FNC 
Local Integer INTERRUPT 
Local File AFONCTION [AFC] 
Call OUVRE_BOITE("",nbrecord([AFC])) From GESECRAN 
I = 0 
For [AFC] Where CODINT<"W" 
 I += 1 
 Call AFF_BOITE("Fonction"-[F:AFC]CODINT,I,INTERRUPT) From GESECRAN 
 If [F:AFC]TYPTRAIT=1 
  Read [APG]APG0 = [F:AFC]TRAIT 
  If fstat 
   Call ECR_TRACE("Fonction"-[F:AFC]CODINT-"traitement inexistant :"-[F:AFC]TRAIT,0) From GESECRAN 
  Elsif [F:APG]MODULE<>[F:AFC]MODULE 
   Trbegin [APG] 
    [F:APG]MODULE = [F:AFC]MODULE 
    [F:APG]LIEN   = "FNC"-[F:AFC]CODINT
    [F:APG]DERDAT = date$ 
    Rewrite [APG] 
   Commit 
  Endif 
 Endif 
Next 
Close local File [AFC] 
Call FERME_BOITE From GESECRAN 
Return 
   
$LEC_ACT 
Local Integer INTERRUPT  
Local File ACTION [ACT]  
Call OUVRE_BOITE("",nbrecord([ACT])) From GESECRAN  
I = 0  
For [ACT] Where ACTION<"W"  
 I += 1  
 Call AFF_BOITE("Action"-[F:ACT]ACTION,I,INTERRUPT) From GESECRAN  
 If [F:ACT]CODTRT<>"" 
  Read [APG]APG0 = [F:ACT]CODTRT 
  If fstat  
   Call ECR_TRACE("Action"-[F:ACT]ACTION-"traitement inexistant :"-[F:ACT]CODTRT,0) From GESECRAN  
  Elsif [F:APG]MODULE<>[F:ACT]MODULE  
   Trbegin [APG]  
    [F:APG]MODULE = [F:ACT]MODULE 
    [F:APG]LIEN   = "ACT"-[F:ACT]ACTION
    [F:APG]DERDAT = date$ 
    Rewrite [APG]  
   Commit  
  Endif  
 Endif  
Next  
Close local File [ACT]  
Call FERME_BOITE From GESECRAN  
Return  
  
  
$LEC_SPG 
Return : # C'est dommage on n'a pas mis module dans cette table 
Local Integer INTERRUPT  
Local File ASUBPROG [ASU] 
Call OUVRE_BOITE("",nbrecord([ASU])) From GESECRAN  
I = 0  
For [ASU]ASU0(1) Where PRG<"W"  
 I += 1  
 Call AFF_BOITE("Sprog"-[F:ASU]PRG,I,INTERRUPT) From GESECRAN  
 If 1=1  
  Read [APG]APG0 = [F:ASU]PRG 
  If fstat  
   Call ECR_TRACE("Sprog"-[F:ASU]PRG-"traitement inexistant :"-[F:ASU]PRG,0) From GESECRAN  
  Elsif [F:APG]MODULE<>[F:ASU]MODULE  
   Trbegin [APG]  
    [F:APG]MODULE = [F:ASU]MODULE  
    [F:APG]DERDAT = date$ 
    Rewrite [APG]  
   Commit  
  Endif  
 Endif  
Next  
Close local File [ASU]  
Call FERME_BOITE From GESECRAN  
Return  
  
   
$LEC_REP 
Local Integer INTERRUPT  
Local File AREPORT [ARP]  
Call OUVRE_BOITE("",nbrecord([ARP])) From GESECRAN  
I = 0  
For [ARP] Where RPTCOD <"X"  
 I += 1  
 Call AFF_BOITE("Etat"-[F:ARP]RPTCOD,I,INTERRUPT) From GESECRAN  
 If [F:ARP]TRTINI<>"" 
  Read [APG]APG0 = [F:ARP]TRTINI 
  If fstat  
   Call ECR_TRACE("Etat"-[F:ARP]RPTCOD-"traitement inexistant :"-[F:ARP]TRTINI,0) From GESECRAN  
  Elsif [F:APG]MODULE=0  
   Trbegin [APG]  
    [F:APG]MODULE = [F:ARP]MODULE 
    [F:APG]LIEN   = "REP"-[F:ARP]RPTCOD
    [F:APG]DERDAT = date$ 
    Rewrite [APG]  
   Commit  
  Endif  
 Endif  
Next  
Close local File [ARP]  
Call FERME_BOITE From GESECRAN  
Return  
 
$LEC_CNS
Local Integer INTERRUPT 
Local File ACONSULT [ACN] 
Call OUVRE_BOITE("",nbrecord([ACN])) From GESECRAN 
I = 0 
For [ACN] Where COD <"W" 
 I += 1 
 Call AFF_BOITE("Consultation"-[F:ACN]COD,I,INTERRUPT) From GESECRAN 
  
  Read [APG]APG0 = [F:ACN]PRGSTD 
  If fstat 
   Call ECR_TRACE("Consultation"-[F:ACN]COD-"traitement inexistant :"-[F:ACN]PRGSTD,0) From GESECRAN 
  Elsif [F:APG]MODULE<>[F:ACN]MODULE 
   Trbegin [APG] 
    [F:APG]MODULE = [F:ACN]MODULE 
    [F:APG]LIEN   = "CNS"-[F:ACN]COD
    [F:APG]DERDAT = date$ 
    Rewrite [APG] 
   Commit 
  Endif 
  
Next 
Close local File [ACN] 
Call FERME_BOITE From GESECRAN 
Return 


$LEC_XREF 
Call TEMPON("Références croisées") From GESECRAN 
# Pour être prudent on ne tente que les programmes non affectés  
# on ne traite pas non plus le problème de récursivité 
# au bout de 2 ou  3 mises à jour ça devrait aller....
Local File XXREF [XXR] , APROG [APG1] 
For [APG]APG0 Where AUTO=1 & MODULE=DEFMOD 
 For [XXR]XXR1 Where TRAIT=[F:APG]PRG 
  Read [APG1]APG0 = [F:XXR]APPEL 
  If !fstat & [F:APG1]MODULE<>DEFMOD 
   Trbegin [APG] 
    [F:APG]MODULE = [F:APG1]MODULE 
    [F:APG]LIEN   = "TRT"-[F:XXR]APPEL
    [F:APG]DERDAT = date$ 
    Rewrite [APG] 
   Commit 
   Break 
  Endif 
 Next 
Next 
Close local File [XXR] , [APG1] 
Local File XXREF1 [XXF] , APROG [APG1]  
For [APG]APG0 Where AUTO=1 & MODULE=DEFMOD  
 For [XXF]XXF1 Where TRAIT=[F:APG]PRG  
  Read [APG1]APG0 = [F:XXF]APPEL  
  If !fstat & [F:APG1]MODULE<>DEFMOD  
   Trbegin [APG]  
    [F:APG]MODULE = [F:APG1]MODULE 
    [F:APG]LIEN   = [F:XXF]APPEL
    [F:APG]DERDAT = date$ 
    Rewrite [APG]  
   Commit  
   Break  
  Endif  
 Next  
Next  
Close local File [XXF] , [APG1]  
Call TEMPOFF From GESECRAN 
Return
