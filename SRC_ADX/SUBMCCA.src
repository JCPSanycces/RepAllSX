#<AdxTL>@(#)11.0.0.0 $Revision$
$INIT_DIA
If GACTION="TRTMFCCLC"
    If [M:MCC0]STOFCY=""
       Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
       [M:MCC0]STOFCY    = GFCY         # site pour GP
    Endif
    [M:MCC0]SLTOVECOL = GOVECOLMFC
    [M:MCC0]FLXBUD    = 1
Elsif GACTION="TRTSCCCLC"
    If [M:MCC0]STOFCY=""
       Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
       [M:MCC0]STOFCY    = GFCY         # site pour Achats
    Endif
    [M:MCC0]SLTOVECOL = GOVECOLSCO
    [M:MCC0]FLXBUD    = 1
Endif
Raz [M]FILMFI,[M]FILMFG
Return

$INIT
Local Integer IND_TYP  # indice du type de coût (v140)
Local Char    TBPAR(10)(1..50),TBVAL(30)(1..50) # pour impression

If !clalev([F:FCY]) Local File FACILITY    [FCY] Endif
If !clalev([F:ITG]) Local File ITMCATEG    [ITG] Endif
If !clalev([F:ITM]) Local File ITMMASTER   [ITM] Endif
If !clalev([F:ITF]) Local File ITMFACILIT  [ITF] Endif
If !clalev([F:STJ]) Local File STOJOU      [STJ] Endif
If !clalev([F:ITC]) Local File ITMCOST     [ITC] Endif
If !clalev([F:ITV]) Local File ITMMVT      [ITV] Endif # pour les valorisations
If !clalev([F:MFC]) Local File MFGCOST     [MFC] Endif
If !clalev([F:MCN]) Local File MFCNAT      [MCN] Endif # détail de nature FG
If !clalev([F:MCC]) Local File MFCMAT      [MCC] Endif # détail matières
If !clalev([F:MCW]) Local File MFCWST      [MCW] Endif # détail opérations

Local Integer LMCC_FILE, LSCC_FILE,LDOCTYP
Raz LMCC_FILE, LSCC_FILE
# Issue 120944 - 2017-01-26 by CCC : Open all necessary files in all cases
If !find(GACTION,"TRTMFCCLC","TRTSCCCLC")
    # CCC (2010-02-01) Bug 62129 : Dans la cas d'un lancement par l'action, on force l'ouverture des fichiers
    If PARAM(14)="10"
        LMCC_FILE = 1
    Else
        LSCC_FILE = 1
    Endif
Endif

# Issue 121797 - 2017-03-09 by ERMIL : Ensure all files are opened regardless of where called
LDOCTYP = val(PARAM(14))
If LDOCTYP=0
  If dim(PROG)
    Case PROG
      When "SUBMCC" : LDOCTYP=10
      When "SUBSCC" : LDOCTYP=36
    Endcase
  Endif
Endif
# End issue 121797

# Depending on the type of document (10=WO , 36=EO), opening of useful tables
Case LDOCTYP # 121797 - changed from PARAM(14) to new integer variable
    When 10 :
                If !clalev([F:MFG]) | LMCC_FILE : Local File MFGHEAD     [MFG] : Endif
                If !clalev([F:MFI]) | LMCC_FILE : Local File MFGITM      [MFI] : Endif
                If !clalev([F:MFI2])            : Local File MFGITM     [MFI2] : Endif # lecture sous-produit
                If !clalev([F:MFIO])            : Local File MFGITM     [MFIO] : Endif
                If !clalev([F:MKI])             : Local File MFGITMTRK   [MKI] : Endif
                If !clalev([F:MFM])             : Local File MFGMAT      [MFM] : Endif
                If !clalev([F:MKM])             : Local File MFGMATTRK   [MKM] : Endif
                If !clalev([F:MFO])             : Local File MFGOPE      [MFO] : Endif
                If !clalev([F:MKO])             : Local File MFGOPETRK   [MKO] : Endif
                If !clalev([F:MKO2])            : Local File MFGOPETRK  [MKO2] : Endif # recherche pour éviter de recompter les fixes
                If !clalev([F:MWC])             : Local File WORKCOST    [MWC] : Endif
                If !clalev([F:MWS])             : Local File WORKSTATIO  [MWS] : Endif
    When 36 :
                If !clalev([F:SCO]) | LSCC_FILE : Local File SCOHEAD     [SCO] : Endif
                If !clalev([F:SCI]) | LSCC_FILE : Local File SCOITM      [SCI] : Endif
                If !clalev([F:SCM]) | LSCC_FILE : Local File SCOMAT      [SCM] : Endif
                If !clalev([F:SCS]) | LSCC_FILE : Local File SCOSRV      [SCS] : Endif
                If !clalev([F:SCIO])| LSCC_FILE : Local File SCOITM     [SCIO] : Endif
Endcase

# V6 Tarif achat (sous-traitance)
If clalev ([F:BPR])=0  Local File BPARTNER  [BPR] : Endif
If clalev ([F:BPD])=0  Local File BPDLVCUST [BPD] : Endif
If clalev ([F:BPS])=0  Local File BPSUPPLIER[BPS] : Endif
If clalev ([F:BPA])=0  Local File BPADDRESS [BPA] : Endif

If !clalev([F:BOH]) Local File BOM         [BOH] Endif
If !clalev([F:BOD]) Local File BOMD        [BOD] Endif # pour que les formules passent mais pas de sens pour mat rajoutée
If !clalev([F:ITB]) Local File ITMBOM      [ITB] Endif
If !clalev([F:TCU]) Local File TABCUR      [TCU] Endif
If !clalev([F:TUN]) Local File TABUNIT     [TUN] Endif
If !clalev([F:OVE]) Local File OVERHEAD    [OVE] Endif
If !clalev([F:TFO]) Local File TABFOR      [TFO] Endif

If !clalev([M:SDP]) : Local Mask SAIDECPRI : Endif
If !clalev([F:SJV]) : Local File STOJOUVAL : Endif
If !clalev([M:CTP]) : Local Mask CLCCSTPAR : Endif
If !clalev([M:CST]) : Local Mask CLCCST   : Endif

Local Integer TRA_APPEL    :# trace dans la fct appelante
If GTRACE <> ""
   TRA_APPEL = 1
Endif
Return

$AVANT_PAR

Local Integer LCLCTHELNC
Local Integer LNBCLC
If dim(GMCCTRA)<=0
    Global Integer GMCCTRA
Endif
# Issue 89622 - 2013-06-05 by CCC
#Raz GMCCTRA
GMCCTRA =2

# changement de boîte de critères
# ou différencier par un paramètre supplémentaire
Case GFONCTION
 When "CALMFGCOST"
   TIT = mess(80,195,1)  :# Calcul prix de revient, Mask MFCCLC0
   BCRIT = "DMFCCLC"

 When "CALSCOCOST"
   TIT = mess(80,195,1)  :# Calcul prix de revient ordre de sous-traitance, Mask SCCCLC0
   BCRIT = "DSCCCLC"

 When "FUNWIPMFC"    : # CCC (02/05/05) DM 30042
    If !clalev([M:MCC0])
        # ouvrir le masque et le précharger
        Local Mask MFCCLC0 [MCC0]  # mettre autre abv et laisser [M] dans tout le prog
    Endif
    # vider BCRIT pour que la boite ne s'ouvre pas
    BCRIT = ""
    [M:MCC0]STOFCY    = PARAM(1)
    [M:MCC0]VCRNUM    = PARAM(2)
    [M]MFGTYP    = 2         # OF clos
    [M]MAJ       = val(PARAM(4))
    [M]SLTOVECOL = val(PARAM(5))
    [M]ORIDEVCLC = val(PARAM(6))
    [M]FLXBUD    = val(PARAM(7))
    [M]MFCTYP    = val(PARAM(8))
    [M]PRNCOD    = max(1,val(PARAM(9)))  # toujours créer la table MCP mais pas de call ETAT si trt de masse
    GMCCTRA      = val(PARAM(13))

 When Default
   ## autres cas : contexte Import, saisie OF, génération..
    # PARAM(12)="2" depuis trt automatique générant des OF en masse [M:MFGK]AUTOTRT
    # PARAM(12)="4" depuis bouton de la gestion d'OF
#non# PARAM(12)="1" depuis bouton Créer de la gestion d'OF
#non# PARAM(12)="3" depuis bouton Enreg de la gestion d'OF
   ## ATTENTION  appel depuis fonction ayant déjà un mask DIA (FUNMAUTR...) > ouvrir sous autre abv
   If !clalev([M:MCC0])
      # ainsi on ne passe ici qu'avant le 1er calcul
      # vider BCRIT pour que la boite ne s'ouvre pas
      BCRIT = ""

      # ouvrir le masque et le précharger
      Case val(PARAM(14))
        When 10 :
          Local Mask MFCCLC0 [MCC0]
          TIT = mess(239,195,1) :# Calcul coût prévisionnel d'OF
        When 36 :
          Local Mask SCCCLC0 [MCC0]
          TIT = mess(292,195,1) :# Calcul coût prévisionnel de sous-traitance
        When Default
          Return
      Endcase
      # rajout pour coût prévisionnel de lancement depuis les OF (03/12/01)
      If PARAM(1) <> ""
        [M:MCC0]STOFCY  = PARAM(1)
      Endif
      [M:MCC0]VCRNUM    = PARAM(2)
      [M:MCC0]VCRTYP    = val(PARAM(14))
      [M:MCC0]MFGTYP    = 1  # jamais OF clos !
      [M:MCC0]PRNCOD    = max(1,val(PARAM(9)))
      [M:MCC0]MAJ       = max(val(PARAM(4)),2) # màj par défaut
      [M:MCC0]SLTOVECOL = GOVECOLMFC
      [M:MCC0]MFCTYP    = 1
      LCLCTHELNC=1 # (re)calcul des 2 premiers coûts prévisionnels
      If PARAM(12) = "4"     # appel depuis bouton de la gestion d'OF
        Call CTL_COUTP([M:MCC0]STOFCY,[M:MCC0]VCRTYP,[M:MCC0]VCRNUM,[M:MCC0]MFCTYP)
      Endif
      Case   [M:MCC0]MFCTYP
        When 1 : [M:MCC0]ORIDEVCLC = 1  # standard
                 [M:MCC0]FLXBUD    = 1
        When 2 : [M:MCC0]ORIDEVCLC = 2  # données de l'OF
                 [M:MCC0]FLXBUD    = 1
        When 3 : [M:MCC0]ORIDEVCLC = 2  # données de l'OF
                 [M:MCC0]FLXBUD    = 2  # budget flexible
      Endcase
      GMCCTRA      = val(PARAM(13))

   Endif
Endcase
Return

$CONTROLE
If !clalev([M:MCC0]) | !find([M:MCC0]VCRTYP,10,36)
    FIN=1
    Return
Endif
# Après préchargement et controle : sortie éventuelle par le biais d'MFCTYP
# dans le cas où l'utilisateur a répondu Non (Btn Gestion OF)
If GFONC1="GESMFG" & [M:MCC0]MFCTYP = 0
  FIN = 1
  Return
Endif

TMP = 0
Return

##############################################################
# 1- Transférer les paramètres des écrans MFCCLC0 dans CLCCSTPAR
# 2- Lancer le chargement des info (mat, mac, lab, sco)
# 3- Lancer le calcul
# 4- Enregistrer dans MFGCOST, MFCNAT, MFCMAT, MFCWST
# 5- Lancer l'impression si nécessaire
##############################################################
$EXEC

If !clalev([M:CTP])  : Local Mask CLCCSTPAR [CTP]  : Endif
If !clalev([M:CST0]) : Local Mask CLCCST0   [CST0] : Endif
If !clalev([M:CST])  : Local Mask CLCCST    [CST]  : Endif

Local Char    LCRITMFG(250), LCRITMFI(250)
Local Integer LRET, I, J
Local Integer LYEA
Local Integer WDIM
## GH 19/03/2014 bug 97454
#Local Integer WADXUID(1..500)
WDIM = nbruser+10 : # GH 28/01/2016 +10 for security
If WDIM<1 : WDIM = 500 : Endif
Local Integer WADXUID(1..WDIM)
WDIM = 0
##
Local Integer NOFIL
Local Integer LTRANSAC

If clalev([M:MCC0]) : Default Mask [MCC0] : Endif

If !GSERVEUR
   # v 140 : au 2è passage, la trace est déjà ouverte
   If TRA_APPEL = 0 & GTRACE="" & GMCCTRA>=2
     Call OUVRE_TRACE(TIT) From LECFIC
     If [M]MFCTYP < 4
       #If GFONCTION="CALSCOCOST"  # Issue 102605 GA 12/2014
       If GFONCTION="CALSCOCOST" | [M:MCC0]VCRTYP=36
         ERR_TRA = mess(292,195,1) :# V6 Calcul coût prévisionnel d'ordre de sous-traitance
       Else
         ERR_TRA = mess(239,195,1) :# Calcul coût prévisionnel d'OF
       Endif
       Call ECRTRACE(ERR_TRA,0)
     Endif
   Endif
Endif

# Issue 90053 - 2013-08-05 by CCC
# PE pour conditionner l'exécution de la purge suite à des pb de performances
If adxlog<>1
    Trbegin [MFC]
    LTRANSAC=1
Endif
Local Integer WDELTMP : [L]WDELTMP=1
GPOINT="DELTMPMCP" : Gosub ENTREE From EXEFNC
If [L]WDELTMP=1
    Call UIDADX(WADXUID,WDIM) From TRTX3

    Delete [MFC] Where UID<>0 & !find(UID,WADXUID(1..WDIM))
    Delete [MCN] Where UID<>0 & !find(UID,WADXUID(1..WDIM))
    Delete [MCC] Where UID<>0 & !find(UID,WADXUID(1..WDIM))
    Delete [MCW] Where UID<>0 & !find(UID,WADXUID(1..WDIM))
Endif
If LTRANSAC
    Commit
    Raz LTRANSAC
Endif

# GH 19/03/2014 bug 86229
#Update [MFC] Where STOFCY=[M:MCC0]STOFCY
#&                & PRNUID=adxuid(1)
#&             With PRNUID=0
GOK = 1

# QTYxxx : 1=std ; 2=théorique ; 3=réel
# CSTxxx : <3=GVLTCSTMAT ou GVLTCSTSEM ; 3=prix mouvement
# PROCPLEXT : 2 --> QTYMAT *= CPLQTYITM/EXTQTYITM
# Paramètres    MFCTYP     QTYITMTYP  QTYMATTYP  QTYOPETYP  CSTMATTYP  CSTOPETYP  PROCPLEXT
# Théorique     1          2          1          1          1          <3         1
# Lancement     2          2          2          2          2          <3         1
# Prod prév     3          3          2          2          2          <3         2
# Prod réa      6          3          3          3          3          3          1
# Issue 85341 - 2013-08-20 by CCC : "Budget flexible" => prix réels + qté prévue selon qté produite
## PRF2          5          2          1 ou 2     1 ou 2     3          3          1
# PRF2          5          3          1 ou 2     1 ou 2     3          3          2

LNBCLC = 1
If ([M:MCC0]MFCTYP=3)
    LNBCLC=2
Elsif LCLCTHELNC=1    # Si calcul du théorique et du lancement
    LNBCLC=2
Endif

[M:CTP]PRNNUM = uniqid([F:MFC]) : # GH 19/03/2014 bug 89229
For J=1 To LNBCLC

    I=[M:CTP]PRNNUM  : # GH 19/03/2014 bug 86229
    Raz [M:CTP], [M:CST]
    [M:CTP]PRNNUM=I  : # GH 19/03/2014 bug 86229

    # Alimentation de CLCCSTPAR [CTP]
    [M:CST0]AFFZON = 1    # Pas d'affichage des zones
    [M:CST0]STOFCY = [M:MCC0]STOFCY    # site

    [M:CTP]TYPCST = 2     # Coût prévisionnel
    [M:CTP]VCRTYP = [M:MCC0]VCRTYP    # Calcul d'un coût prévi d'OF
    [M:CTP]FXDCSTDSP = 2    # Pas de répartition des fixes au prorata (paramètre utile uniquement pour ITC)
    [M:CTP]SLTOVECOL = [M:MCC0]SLTOVECOL
    [M:CTP]MFCTYP = [M:MCC0]MFCTYP
    [M:CTP]CLCDAT = date$
    Case GMCCTRA
        When 0 : [M:CTP]TRANIV = 0   # aucune trace concernant les calculs
        When 1 : [M:CTP]TRANIV = -1   # Messages d'erreurs à l'écran
        When 3 : [M:CTP]TRANIV = 1   # Erreurs en trace
        When Default : [M:CTP]TRANIV = 2   # Trace tout
    Endcase

    Case [M:MCC0]MFCTYP
        When 1:
            [M:CTP]QTYITMTYP=2
            [M:CTP]QTYMATTYP=1
            [M:CTP]QTYOPETYP=1
            [M:CTP]CSTMATTYP=1
            [M:CTP]CSTOPETYP=1
            [M:CTP]PROCPLEXT=1
        When 2:
            [M:CTP]QTYITMTYP=2
            [M:CTP]QTYMATTYP=2
            [M:CTP]QTYOPETYP=2
            [M:CTP]CSTMATTYP=2
            [M:CTP]CSTOPETYP=2
            [M:CTP]PROCPLEXT=1
        When 3:
            [M:CTP]QTYITMTYP=3
            [M:CTP]QTYMATTYP=2
            [M:CTP]QTYOPETYP=2
            [M:CTP]CSTMATTYP=2
            [M:CTP]CSTOPETYP=2
            [M:CTP]PROCPLEXT=2
        When 5:
            # Issue 85341 - 2013-08-20 by CCC : "Budget flexible" => prix réels + qté prévue selon qté produite
            #[M:CTP]QTYITMTYP=2
            [M:CTP]QTYITMTYP=3
            [M:CTP]QTYMATTYP=[M:MWF0]ORIDEVCLC
            [M:CTP]QTYOPETYP=[M:MWF0]ORIDEVCLC
            [M:CTP]CSTMATTYP=3
            [M:CTP]CSTOPETYP=3
            # Issue 85341 - 2013-08-20 by CCC : "Budget flexible" => prix réels + qté prévue selon qté produite
            #[M:CTP]PROCPLEXT=1
            [M:CTP]PROCPLEXT=2
        When 6:
            [M:CTP]QTYITMTYP=3
            [M:CTP]QTYMATTYP=3
            [M:CTP]QTYOPETYP=3
            [M:CTP]CSTMATTYP=3
            [M:CTP]CSTOPETYP=3
            [M:CTP]PROCPLEXT=1

    Endcase


    # Filtre sur MFI au lancement du calcul et ...
    # On valorise l'encours même s'il n'y a pas eu de déclaration de prod

    Case [M:MCC0]VCRTYP
        When 10 :
           LCRITMFG = "MFGFCY='"+[M]STOFCY+"'"
           If [M]VCRNUM<>""
               LCRITMFG-= "& MFGNUM='"+[M]VCRNUM+"'"
               # le critère Ordre clos ne joue que sur la selection/contrôle d'un OF
               If [M]MFGTYP = 2
                 LCRITMFG-= "& MFGSTA=4"
               Else
                 LCRITMFG-= "& MFGSTA<4"
               Endif
            Endif

            NOFIL=([M]FILMFG="")
            If NOFIL : [M]FILMFG="1=1" : Endif

            If [M]FILMFI=""
               If [M]MFITRKFLG<>2 & find([M]MFCTYP,1,2)
                  LCRITMFG-= "& MFGTRKFLG<6"
               Endif
               For [MFG] Where evalue([L]LCRITMFG) & evalue([M]FILMFG)
                    For [MFIO] Where MFGNUM=[F:MFG]MFGNUM
                        Call TRT_MFG
                        If GOK = 0 : Break 2 : Endif
                        Break
                    Next
               Next
            Else
                LCRITMFI = LCRITMFG
                If [M]MFITRKFLG <> 2 & find([M]MFCTYP,1,2)
                   LCRITMFG = "MFGTRKFLG<6"
                Else
                   LCRITMFG = "1=1"
                Endif
                For [MFIO]MFI0(1) Where evalue([L]LCRITMFI) & evalue([M]FILMFI)
                    For [MFG] Where MFGNUM=[F:MFIO]MFGNUM & evalue([L]LCRITMFG) & evalue([M]FILMFG)
                        Call TRT_MFG
                        If GOK = 0 : Break 2 : Endif
                    Next
                Next
                [G:MFIO]currlen=0
            Endif

            If NOFIL : [M]FILMFG="" : Endif

        When 36 :
            LCRITMFI = "PRHFCY='"+[M]STOFCY+"'"
            LCRITMFG = ""
            If [M]VCRNUM<>""
               # le critère Ordre clos ne joue que sur la selection/contrôle d'un EO
               If [M]MFGTYP = 2
                 LCRITMFG-= "& SCOSTA=4"
               Else
                 LCRITMFG-= "& SCOSTA<4"
               Endif
               If [M]FILMFI="" : LCRITMFG-= "& SCONUM='"+[M]VCRNUM+"'"
               Else            : LCRITMFI-= "& SCONUM='"+[M]VCRNUM+"'"
               Endif
            Endif
            If [M]SCOTRKFLG<>2 & find([M:MCC0]MFCTYP,1,2)
               LCRITMFG-= "& SCOTRKFLG<6"
            Endif
            If LCRITMFG="" : LCRITMFG="1=1" : Elsif left$(LCRITMFG,3)=" & " : LCRITMFG=right$(LCRITMFG,4) : Endif

            NOFIL=([M]FILMFG="")
            If NOFIL : [M]FILMFG="1=1" : Endif

            If [M]FILMFI=""
                For [SCO] Where evalue([L]LCRITMFG) & evalue([M]FILMFG)
                    For [SCIO] Where SCONUM=[F:SCO]SCONUM & evalue([L]LCRITMFI)
                        Call TRT_MFG
                        If GOK = 0 : Break 2 : Endif
                        Break
                    Next
                Next
            Else
               For [SCIO]SCI0(1) Where evalue([L]LCRITMFI) & evalue([M]FILMFI)
                    For [SCO] Where SCONUM=[F:SCIO]SCONUM & evalue([L]LCRITMFG) & evalue([M]FILMFG)
                        Call TRT_MFG
                        If GOK = 0 : Break 2 : Endif
                    Next
                Next
                [G:SCIO]currlen=0
            Endif

            If NOFIL : [M]FILMFG="" : Endif
    Endcase

    If [M:MCC0]MFCTYP=3
        [M:MCC0]MFCTYP=6
    Elsif [M:MCC0]MFCTYP=6
        [M:MCC0]MFCTYP=3
    Endif

    If LCLCTHELNC
        If [M:MCC0]MFCTYP=1
            [M:MCC0]MFCTYP=2
        Elsif [M:MCC0]MFCTYP=2
            [M:MCC0]MFCTYP=1
        Endif
    Endif
Next

If TRA_APPEL=0
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
Return

#####################################################
$TERMINE
If !GSERVEUR
# Case GFONCTION
#     When "CALMFGCOST", "CALSCOCOST", "GESMFG"
       If  [M:MCC0]PRNCOD > 1
           TBPAR(1) = "site"  : TBVAL(1) = [M:MCC0]STOFCY
           TBPAR(2) = "usr"   : TBVAL(2) = GUSER
           TBPAR(3) = "vcrtyp" : TBVAL(3) = num$([M:MCC0]VCRTYP)
           TBPAR(4) = "vcrnumdeb" : TBVAL(4) = [M:MCC0]VCRNUM
           If [M:MCC0]VCRNUM <> ""
             TBPAR(5) = "vcrnumfin" : TBVAL(5) = [M:MCC0]VCRNUM # un seul OF à éditer
           Else
             TBPAR(5) = "vcrnumfin" : TBVAL(5) = "ZZZZZZZZZZZZZZZ" #pour avoir les récap
           Endif
           If LCLCTHELNC=1
               # Issue 75633 - 2011-10-04 by CCC : On lance par défaut l'impression des 2 types de coûts qui ont été calculés
               TBPAR(6) = "mfctypdeb" : TBVAL(6) = "1"
               TBPAR(7) = "mfctypfin" : TBVAL(7) = "2"
           Else
               TBPAR(6) = "mfctypdeb" : TBVAL(6) = num$([M:MCC0]MFCTYP)
               TBPAR(7) = "mfctypfin" : TBVAL(7) = num$([M:MCC0]MFCTYP)
           Endif
           TBPAR(8) = "affdet"    : TBVAL(8) = num$(4-[M:MCC0]PRNCOD)
           TBPAR(9) = "uid"       : TBVAL(9) = num$(adxuid(1)*([M:MCC0]MAJ<>2))
           TBPAR(10)= "prnuid"    : TBVAL(10)= num$([M:CTP]PRNNUM) : # GH 19/03/2014 bug 86229 num$(adxuid(1))
           If [M:MCC0]VCRTYP=36
               # Lancement du code état SCOCOST qui utilise l'état MFGCOST
               Call ETAT("SCOCOST",GFONCTION,TBPAR,TBVAL)  From ETAT
           Else
               Call ETAT("MFGCOST",GFONCTION,TBPAR,TBVAL)  From ETAT
           Endif
       Endif
# Endcase
Endif
# CCC (2010-02-01) Bug 62129
If LMCC_FILE=1
    Close Local File [MFG]
    Close Local File [MFI]
Elsif LSCC_FILE=1
    Close Local File [SCO]
    Close Local File [SCI]
    Close Local File [SCIO]
    Close Local File [SCS]
    Close Local File [SCM]
Endif
Return

######################################################################################
# Appelée en suppression d'OF (SUBMFGA.$ANNULE)
# Les contrôles ont dû être fait avant
$ANNULE
If !clalev([F:MFC]) : Local File MFGCOST [MFC] : Endif
If !clalev([F:MCN]) : Local File MFCNAT  [MCN] : Endif
If !clalev([F:MCC]) : Local File MFCMAT  [MCC] : Endif
If !clalev([F:MCW]) : Local File MFCWST  [MCW] : Endif
If !clalev([F:MWH]) : Local File MFGWIP  [MWH] : Endif
If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif
If clalev([M:MFG0]) & [M:MFG0]MFGNUM<>""
    Delete [MFC] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
    Delete [MCN] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
    Delete [MCC] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
    Delete [MCW] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
    Delete [MWH] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
    Delete [MWI] Where VCRNUM = [M:MFG0]MFGNUM & VCRTYP=10
Elsif clalev([F:MFG]) & [F:MFG]MFGNUM<>""
    Delete [MFC] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
    Delete [MCN] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
    Delete [MCC] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
    Delete [MCW] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
    Delete [MWH] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
    Delete [MWI] Where VCRNUM = [F:MFG]MFGNUM & VCRTYP=10
Endif
Return

######################################################################################
# Appelée en suppression d'EO (SUBSCOA.$ANNULE)
# Les contrôles ont dû être fait avant
$ANNULE_EO
If !clalev([F:MFC]) : Local File MFGCOST [MFC] : Endif
If !clalev([F:MCN]) : Local File MFCNAT  [MCN] : Endif
If !clalev([F:MCC]) : Local File MFCMAT  [MCC] : Endif
If !clalev([F:MCW]) : Local File MFCWST  [MCW] : Endif
If !clalev([F:MWH]) : Local File MFGWIP  [MWH] : Endif
If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif
Delete [MFC] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Delete [MCN] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Delete [MCC] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Delete [MCW] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Delete [MWH] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Delete [MWI] Where VCRNUM = [M:SCO0]SCONUM & VCRTYP=36
Return


#-----------------------------------------------------------------------------#
# sous-pro de contrôle avant calcul
# servira en appel depuis le bouton en gestion d'OF
# W_FCY    Site
# W_MFGNUM N° ordre
# W_TYP    Type de cout prévisionnel : servira à alimenter le paramètre MFCTYP
#-----------------------------------------------------------------------------#
Subprog CTL_COUTP(W_FCY,W_VCRTYP,W_MFGNUM,W_TYP)
Value     Char    W_FCY
Value     Integer W_VCRTYP
Value     Char    W_MFGNUM
Variable  Integer W_TYP

Local     Integer IND_TYP, REP
Local Char LMES1(250), LMES2(250)

Case W_VCRTYP
    When 10 :
        If !clalev([F:MFG]) Local File MFGHEAD     [MFG] Endif
        If [F:MFG]MFGNUM <> W_MFGNUM
          Read [MFG]MFG0 = W_MFGNUM
        Endif
        LTRKFLG = [F:MFG]MFGTRKFLG
        LMES1 = mess(103,193,1)
        LMES2 = mess(212,193,1)
    When 36 :
        If !clalev([F:SCO]) Local File SCOHEAD     [SCO] Endif
        If [F:SCO]SCONUM <> W_MFGNUM
          Read [SCO]SCO0 = W_MFGNUM
        Endif
        LTRKFLG = [F:SCO]SCOTRKFLG
        LMES1 = mess(413,194,1)
        LMES2 = mess(414,194,1)
Endcase

If !clalev([F:MFC]) Local File MFGCOST     [MFC] Endif

  # ce cas peut arriver si on n'a pas calculé les 2 premiers CP au préalable
  If LTRKFLG = 5 & W_TYP < 3
      GMESSAGE = LMES1+"\" # "Ordre déjà soldé!"
      # demander confirmation
      REP = 2
      Call OUINON(GMESSAGE+mess(213,193,1),REP) From GESECRAN
      # Voulez-vous recalculer ces coûts prévisionnels ?
      If REP < 2 W_TYP=0 Endif # cas d'import Modif d'OF : 'Oui' présumé !
  Endif

  If LTRKFLG < 5 & W_TYP > 2
    GMESSAGE = LMES2+"\" # "Ordre pas encore soldé!"
    GMESSAGE += mess(209,193,1)+"\" # "Le coût prévisionnel théorique est déjà calculé."
    GMESSAGE += mess(210,193,1)+"\" # "Le coût prévisionnel de lancement est déjà calculé."
    REP = 2
    Call OUINON(GMESSAGE+mess(213,193,1),REP) From GESECRAN
    # Voulez-vous recalculer ces coûts prévisionnels ? si oui positionner typ à 1
    # selon reponse positionner W_TYP (0 entrainera l'interruption de l'appel du calcul)
    #                           FIN=1 possible en CONTROLE seulement !
    If REP < 2
      W_TYP = 0
    Else
      W_TYP = 1 # pour recalculer à partir du CPT >> vérifier s'il y a eu des MKI valorisés au CPx
    Endif
  Endif
  Raz GMESSAGE # pour pas qu'il soit interprété plus tard
End


##########################################################
Subprog TRT_MFG
Local Integer I, LRET
Local Integer LTRANSAC

For I=10 To 60 Step 5
    Call EFFZOCST(I) From TRTCST
Next

Call CLCMFC([M:MCC0]MFCTYP,LRET) From SUBMCCB

If LRET : End : Endif

If [M:MCC0]MAJ=2
    If adxlog<>1
        Trbegin [MFC]
        LTRANSAC=1
    Endif
    # Issue 92185 - 2013-12-11 by CCC : On n'efface les enreg avec UID=0 que si MAJ et dans la même transaction que l'update
    Delete [MFC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=0 & MFCTYP=[M:MCC0]MFCTYP
    Delete [MCN] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=0 & MFCTYP=[M:MCC0]MFCTYP
    Delete [MCC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=0 & MFCTYP=[M:MCC0]MFCTYP
    Delete [MCW] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=0 & MFCTYP=[M:MCC0]MFCTYP

    Update [MFC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=[M:MCC0]MFCTYP
&                With  UID=0
    Update [MCN] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=[M:MCC0]MFCTYP
&                With  UID=0
    Update [MCC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=[M:MCC0]MFCTYP
&                With  UID=0
    Update [MCW] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=[M:MCC0]MFCTYP
&                With  UID=0
    If LTRANSAC=1
        Commit
    Endif
Endif

End

Subprog ECRTRACE(PMSG,PERR)
Value Char PMSG
Value Integer PERR
If GMCCTRA=2
    Call ECR_TRACE(PMSG,PERR) From GESECRAN
Endif
End

