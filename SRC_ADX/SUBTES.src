#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier TABEXPENS
################################################################################
##############     Définition des codes Frais (Module FRAIS)     ###############
################################################################################

Raz GBIDC1
Call OBJET("TES",GBIDC1,"1") From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "SEL_TABLE" : Gosub SEL_TABLE
 When Default
Endcase
Return


$OUVRE
If !clalev([F:CCE2]) : Local File CACCE    [CCE2] : Endif
If !clalev([F:GAC])  : Local File GACCOUNT [GAC]  : Endif
If !clalev([F:CAC])  : Local File GACCCODE [CAC]  : Endif

If clalev([F:CDI])=0 : Local File CADIEDEF   [CDI] : Endif
Local Integer NUMDIE
NUMDIE = 7 : # Rang dans le menu 2230
Read [CDI]CDI0 = NUMDIE
Return

$INICRE
$INIMOD
If dim([F:TES]DES)>0
 [F:TES]DES = [M:TES0]DESTRA
Endif
Return

$LIENS
Call LECTEXTRA([M:TES0]DESTRA,"TABEXPENS","DESTRA",[M:TES0]CODEXP,"") From ATEXTRA
Call LECTEXTRA([M:TES0]SHOTRA,"TABEXPENS","SHOTRA",[M:TES0]CODEXP,"") From ATEXTRA
Gosub INIDIE
Gosub GRISE
Return

$GRISE
Case [M:TES0]TYPVLT
 When 1
  Effzo [M:TES0]VLTDEFPAR :  Grizo [M:TES0]VLTDEFPAR
  Effzo [M:TES0]VLTPFDPAR :  Grizo [M:TES0]VLTPFDPAR
  Actzo [M:TES0]VLTDEFUNI
  Actzo [M:TES0]VLTPFDUNI
 When 2
  Effzo [M:TES0]VLTDEFUNI :  Grizo [M:TES0]VLTDEFUNI
  Effzo [M:TES0]VLTPFDUNI :  Grizo [M:TES0]VLTPFDUNI
  Actzo [M:TES0]VLTDEFPAR
  Actzo [M:TES0]VLTPFDPAR
 When Default
  Effzo [M:TES0]VLTDEFPAR :  Grizo [M:TES0]VLTDEFPAR
  Effzo [M:TES0]VLTPFDPAR :  Grizo [M:TES0]VLTPFDPAR
  Effzo [M:TES0]VLTDEFUNI :  Grizo [M:TES0]VLTDEFUNI
  Effzo [M:TES0]VLTPFDUNI :  Grizo [M:TES0]VLTPFDUNI
Endcase
Return

$RAZCRE
Gosub INIDIE
If dim([M:TES0]DIE)>0 : Affzo [M:TES0]DIE : Endif
Return

$INIDIE
If dim([M:TES0]DIE)<=0 : Return : Endif
Raz [M:TES0]DIE
Raz [M:TES0]CCE
[M:TES0]NBRCCE = [F:CDI]NBRDIE
For I=0 To [F:CDI]NBRDIE-1
 [M:TES0]DIE(I) = [F:CDI]DIE(I)
 For J=0 To dim([F:TES]DIE)-1
  If [F:TES]DIE(J)=[F:CDI]DIE(I)
   [M:TES0]CCE(I) = [F:TES]CCE(J)
   Break
  Endif
 Next J
Next I
Return

$SEL_LISTE
If clalev([F:AXX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR  [ADP] : Endif

Filter [ADP] Where CHAPITRE="TRS" and left$(PARAM,6)="EXPAMT"

For [ADP]
 Read [ATX]NUMERO=GLANGUE;[F:ADP]NAM
 NBTEX += 1
 TEX(NBTEX)   = [F:ADP]PARAM
 TEXTE(NBTEX) = [F:ATX]TEXTE
Next

TIT = mess(174,100,1) # Paramètres
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABEXPENS","DESTRA",CLECUR1,"","TABEXPENS","DESTRA",[M:TES0]CODEXP,"")  From ATEXTRA
 Call DUPTEXTRA("TABEXPENS","SHOTRA",CLECUR1,"","TABEXPENS","SHOTRA",[M:TES0]CODEXP,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:TES0]DESTRA,"TABEXPENS","DESTRA",[M:TES0]CODEXP,"") From ATEXTRA
Call MAJTEXTRA([M:TES0]SHOTRA,"TABEXPENS","SHOTRA",[M:TES0]CODEXP,"") From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("TABEXPENS","DESTRA",[M:TES0]CODEXP,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("TABEXPENS","SHOTRA",[M:TES0]CODEXP,"",NCODE,"") From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("TABEXPENS","DESTRA",[M:TES0]CODEXP,"") From ATEXTRA
Call SUPTEXTRA("TABEXPENS","SHOTRA",[M:TES0]CODEXP,"") From ATEXTRA
Return


$SEL_TABLE
Case COUZON
 When "PCCCOD" : Gosub SELPCC
Endcase
Return

$SELPCC
If  [M:TES0]GFY=""
 OBJET="PJCC"
Else
 If clalev([F:PJCC])=0 : Local File PJMCOSTCTR [PJCC] : Endif
 If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
 If clalev([F:AX3])=0  : Local File ATEXTRA    [AX3]  : Endif
 Local Integer I, J
 Gosub OUVRE_LISTE From WOPJCC
 Call TITOBJ("PJCC","!",TIT(0)) From CONTOBJ
 TIT(0)  = mess(12,123,1)-TIT(0)
 For I=1 To NBSEL
  If J<dim(COL) & I<=dim(SELEXP)
   J += 1
   If SELEXP(I)<>""
    COL(J) = SELEXP(I)
   Else
    COL(J) = SELZON(I)
   Endif
   TIT(J) = SELLIB(I)
   If left$(SELFMT(I),2)="LA"
    COL(J) = "mess("+COL(J)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
   If dim(SELFOR)>0
    FMTCOL(J) = SELFOR(I)
   Endif
  Endif
 Next I
 NBCOL = J
 START  = "[F:PJCC]PCCCOD"
 ORDRE  = "[F:PJCC]PCCCOD"
 OBJET  = ""
 Link [PJCC] With [F:FGR]FGR1(0)=[F:PJCC]PCCFCY,
& [AX3]AXX0="PJMCOSTCTR";"DESAXX";GLANGUE;[F:PJCC]PCCCOD;""
& As [LNK]
& Where (([F:PJCC]PCCFCY="")| ([F:FGR]CPY=[M:TES0]GFY)) & [F:PJCC]ENAFLG=2
 Default File [LNK]
 DEFPAG = 1
Endif
Return

################################################################################
##                       Etiquettes de l'écran TES0                           ##
################################################################################
Subprog D_VAT(VALEUR)
Variable Char    VALEUR()
Local Char PLAN(GLONCOA)
Call LECMAINPLAN(1,GDEFSOC,PLAN) From CPTDIV
Call LECTURE("CAC",[M]ACCCOD,"20~"+PLAN) From CONTOBJ
Call LECTURE("GAC",[F:CAC]ACC(0),PLAN) From CONTOBJ
VALEUR=[F:GAC]VAT
End

Subprog C_PCCCOD(VALEUR)
Variable Char    VALEUR()
If clalev([F:PJCC])=0 : Local File PJMCOSTCTR [PJCC] : Endif
Read [PJCC]PCC0=VALEUR
If !fstat
 Call COMPAT([M:TES0]GFY,[F:PJCC]PCCFCY,VALEUR) From CFYSUB
Endif
End

Subprog AS_VLTUNT(VALEUR)
Variable Decimal VALEUR
If [M:TES0]TYPVLT<>1 : mkstat=1 : Endif
End

Subprog AS_VLTUSR(VALEUR)
Variable Char    VALEUR()
If [M:TES0]TYPVLT<>2 : mkstat=1 : Endif
End


Subprog C_NBRCCE
Local Integer AXI
If adxgtb=2  :# Sortie du tableau
 If clalev([F:CAZ])=0 : Local File CAAUZ [CAZ] : Endif
 For AXE=1 To GOPTCANA
  If [M]CCE(AXE-1)<>""
   nolign=AXE
   Call C_CCE([M]CCE(AXE-1))
  If mkstat
   Break
  Else :# Contrôle interdiction section/section
   Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ
    For I=AXE+1 To GOPTCANA
     If [M]CCE(I-1)<>""
      Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
      Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
      If !fstat
       # Interdit avec la section
       GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
       mkstat = 1 : Break 2
      Endif
     Endif
    Next
   Endif
  Endif
 Next
Endif
End

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
If [M]INICCE(nolign-1) = 2
 mkstat=1  : End
Endif
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call LECTURE("CCE",VALEUR,[M:TES0]DIE(nolign-1)) From CONTOBJ
Call CONTEXE([F:CCE]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
If [F:CCE]IPT<>2
 # Section non imputable
 GMESSAGE = VALEUR-mess(24,106,1) : mkstat = 1 : End
Endif
Call CTLVLYDAT(date$,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
End

Subprog C_TYPVLT(VALEUR)
Variable Integer VALEUR
[M:TES0]TYPVLT=VALEUR
Gosub GRISE
End

Subprog C_VLTDEFPAR(VALEUR)
Variable Char    VALEUR()
Call CTLPAR(VALEUR)
End

Subprog C_VLTPFDPAR(VALEUR)
Variable Char    VALEUR()
Call CTLPAR(VALEUR)
End

Subprog CTLPAR(WPARAM)
Value Char WPARAM()
If clalev([F:ADP])=0 : Local File ADOPAR  [ADP] : Endif
Read [ADP]ADP1 = WPARAM
If fstat | left$(WPARAM,6)<>"EXPAMT"
 # Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

