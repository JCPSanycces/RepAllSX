#<AdxTL>@(#)8.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Integer I , K , L , OK
Local Char PARAM

If clalev([M:WPRT]) = 0 : Local Mask IWEIPRT [WPRT] : Endif
# 53737 mm 07.08
Local Char LPAR(250)
# 90424 mm 12.2013
# Recherche du dossier où se trouve l'état WNOMETAT
Local Char WNOMETAT(GLONACR)

Call GETPARAM("__REPORT",NBPAR,PARAMETRE,LPAR) From ETAT
WNOMETAT = left$(LPAR,len(LPAR)-4) : # nom de l'état CR sans .rpt

Gosub DOSRPT From DOSFAB

If DOSSIER=""
    End
Endif
LPAR = DOSSIER+";"+CLISERV+";"+num$(adxtcp)
Call SETPARAM("__APPRPT",NBPAR,PARAMETRE,LPAR) From ETAT


End

######################################

$ACTION
Case ACTION
 When "SAISIE"            : Gosub SAISIE
 When "IMPRIMANTE"        : Gosub IMPRIMANTE
Endcase
Return


##################################
$SAISIE
#pour ne pas ouvrir la fenetre de parametre

If GFONC1 = "FUNSCA"  [M:RPT]IMPRIME = 2
                      [M:RPT]SERVEUR = [F:ARP]PRTSRV
                      OK = 0
Endif
Return

######################################
$IMPRIMANTE
Local Integer LTYPETA : LTTYPETA = 2
#Gosub IMPRIMANTE From SCALEXCHAN
#il faut retrouver le paramètre porteur du nom de l'imprimante pour le surcharger
#Local Integer I
#For I = 1 To NBPAR
#    If left$(PARAMETRE(I),13)="_PrinterName="
#       PARAMETRE(I) = "_PrinterName="+chr$(1)+GDEFIMP
#       Break
#    Endif
#Next I
Return
