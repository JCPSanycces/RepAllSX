##########################################################################
# UTITC05   Les tables LASTCUSMVT et LASTSUPMVT deviennent     Module TC #
#           gérées au niveau SITE                                        #
##########################################################################
# FGR 14/08/2009 : X3SUIVI57005
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat THEN
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC05(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC05(DOSSIER)
Value Char DOSSIER

Local Integer IBERROR

  Call ECR_TRACE("UTITC05: Process Start on : "+DOSSIER, 0) From GESECRAN
  # Traitement table LASTCUSMVT
  Call ALIMENTE_LCM (DOSSIER, 2, "", 2, "", IBERROR) From FUNCRMLCM
  # (DEBUT)-------------------------------------------------------------------------------------------------------
  # FGR 19/08/2009 : LD/MBT : Ces S/P n'existent pas sur X3INDV6. Je ne comprends pas pourquoi ils sont différents
  #                           sur les deux environnements ?
  #                           Pour mon patch je les mets en commentaire.
  #Call AP_MVC From TRC1MAJ30 : # Mvts clients
  # Traitement table LASTSUPMVT
  #Call AP_MVS From TRC1MAJ30 : # Mvts fournisseurs
  # (FIN)---------------------------------------------------------------------------------------------------------
  #
  Call ECR_TRACE("UTITC05 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat THEN
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC05(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTITC05(APPLI)
End

