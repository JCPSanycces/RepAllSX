#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:47"
A_USER  = "DOC"
A_STAMP = "20181109230347"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRCHEF"
  If [M]NBRCHEF=0
  Endif
 When "NBRRPL"
  If [M]NBRRPL=0
  Endif
 When "NBRPOP"
  If [M]NBRPOP=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR6 [CTR6]
Gosub HORODAT
Local Inpbox "CTR6" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR6] As [SIM_]
Grizo [CTR6]5
Grizo [CTR6]10
Grizo [CTR6]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=12
X1(1)=1 : X2(1)=88 : Y1(1)=13 : Y2(1)=17
X1(2)=1 : X2(2)=88 : Y1(2)=18 : Y2(2)=22
Return

$ON_NBRCHEF
Onevent INIT_AREA Call D_NBRCHEF From W1CTR6
Return

Subprog D_NBRCHEF
Local Decimal BASPAG
If varinit([M]NBRCHEF)=0
 [M]NBRCHEF = len(mess(0,50,1))
Endif
Gosub _AFF
End

$ON_RESPO
Onevent INIT_AREA Call D_RESPO(zc) From W1CTR6
Return

Subprog D_RESPO(VALEUR)
Variable Integer VALEUR
If varinit([M]RESPO,indice)=0
 VALEUR = nolign
Endif
Gosub _AFF
End

$ON_CHEFCTR
Onevent CONTROL Call C_CHEFCTR(zc) From W1CTR6
Onevent BEFORE_INPUT Call AS_CHEFCTR(zc) From W1CTR6
Return

Subprog AS_CHEFCTR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CHEFCTR(zc) From W1CTR6
Onkey   2 Titled GBOUTS Call S_CHEFCTR(zc) From W1CTR6
Onkey 144 Titled GBOUTP Call P_CHEFCTR(zc) From W1CTR6
Onkey 146 Titled GBOUTA Call SA_CHEFCTR(zc) From W1CTR6
Gosub _AFF
End

Subprog C_CHEFCTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
  If !mkstat
   ## Action STD
   Call C_CHEFCTR(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
   If !GWEBSERV
    If !mkstat
     ## Action CONTEMP
     Local Char    PARMSK(250)(1..20) , SAVACT(20)
     SAVACT = GACTION : GACTION = "CONTEMP"
     PARMSK(1) = ""
     PARMSK(2) = ""
     PARMSK(3) = ""
     PARMSK(4) = ""
     PARMSK(5) = ""
     PARMSK(6) = ""
     Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
    Endif
   Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CHEFCTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMPACS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPACS"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMPACS","SELMAT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CHEFCTR(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CHEFCTR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CHEFCTR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_NAMCHEF
Onevent BEFORE_AREA Gosub AV_NAMCHEF From W1CTR6
Return

$AV_NAMCHEF
## Action STD
Call AV_NAMCHEF(zc) From SUBCTR
Gosub _AFF
Return

$ON_RPL
Onevent CONTROL Call C_RPL(zc) From W1CTR6
Onevent BEFORE_INPUT Call AS_RPL(zc) From W1CTR6
Return

Subprog AS_RPL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_RPL(zc) From W1CTR6
Onkey 144 Titled GBOUTP Call P_RPL(zc) From W1CTR6
Onkey 146 Titled GBOUTA Call SA_RPL(zc) From W1CTR6
Gosub _AFF
End

Subprog C_RPL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = GCURLEG
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
  If !mkstat
   ## Action STD
   Call C_RPL(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_RPL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_RPL" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_RPL" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_RPL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_RPL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_NAMSUPPL
Onevent BEFORE_AREA Gosub AV_NAMSUPPL From W1CTR6
Return

$AV_NAMSUPPL
## Action STD
Call AV_NAMSUPPL(zc) From SUBCTR
Gosub _AFF
Return

$ON_NBRPOP
Onevent BEFORE_AREA Call AV_NBRPOP From W1CTR6
Onevent BEFORE_INPUT Call AS_NBRPOP From W1CTR6
Onevent CONTROL Call C_NBRPOP From W1CTR6
Onevent AFTER_LINE Call APRES_NBRPOP From W1CTR6
Return

Subprog AV_NBRPOP
Local Decimal BASPAG
## Action STD
Call AV_NBRPOP From SUBCTR
Gosub _AFF
End

Subprog AS_NBRPOP
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRPOP From SUBCTR
Gosub _AFF
End

Subprog C_NBRPOP
Local Decimal BASPAG
## Action STD
Call C_NBRPOP From SUBCTR
If mkstat : GERR = 1 : GZONE = "NBRPOP" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog APRES_NBRPOP
Local Decimal BASPAG
## Action STD
Call APRES_NBRPOP From SUBCTR
If mkstat : End : Endif
Gosub _AFF
End

$ON_POP
Onevent CONTROL Call C_POP(zc) From W1CTR6
Onevent BEFORE_INPUT Call AS_POP(zc) From W1CTR6
Onevent AFTER_CHANGE Gosub AMM_POP From W1CTR6
Return

Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45582,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_POP(VALEUR) From SUBCTR
If mkstat=2
 [M]POP(INDIC) = VALEUR
 Affzo POP(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_POP(zc) From W1CTR6
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1CTR6
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1CTR6
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1CTR6
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("POP","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action STD
   Call C_POP(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_POP
Call AM_POP(zc)
If !mkstat & GOBJET
 zoncou = "POP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POP(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPOP)")>indice
 [M]POP(indice) = VALEUR
 Affzo ZPOP(indice)
Endif
Gosub _AFF
End

Subprog S_POP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOP"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOP","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_POP(VALEUR)
Variable Char    VALEUR()
Call OBJET("POP",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_POP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPOP
Onevent BEFORE_AREA Gosub AV_ZPOP From W1CTR6
Return

$AV_ZPOP
If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif
Call LECTURE("POP",num$([M]POP(indice)),"") From CONTOBJ
zc = [F:HRPOP]DES
Gosub _AFF
Return

$ON_MAJTYP
Onevent INIT_AREA Call D_MAJTYP(zc) From W1CTR6
Return

Subprog D_MAJTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]MAJTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_LISTHIERAR
Onevent BEFORE_AREA Gosub AV_LISTHIERAR From W1CTR6
Return

$AV_LISTHIERAR
## Action STD
Call AV_LISTHIERAR(zc) From SUBCTR
Gosub _AFF
Return

$CHG_STY
Return


