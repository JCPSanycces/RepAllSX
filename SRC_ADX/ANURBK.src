#<AdxTL>@(#)190.0.0.0 $Revision$
# LS Utilitaire de suppression d'un relevé bancaire de la table RELBANK
# 8 juin 1998

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ANURBK","FANURBK",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$OUVRE
If clalev([F:RBK])=0  : Local File RELBANK    [RBK]  : Endif
If clalev([F:RBKF])=0 : Local File RELBANK    [RBKF] : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If clalev([F:RBR])=0  : Local File RELBANKREM [RBR]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
TMP = 1
Return

$EXEC
Gosub VERROU
If GERR : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBCHK
If GOK=1
 # Relevé effacé
 GERR = 2 : GMESSAGE = mess(35,120,1)
Endif
FIN = 1
Return

$TR1
GOK = 1
Trbegin [RBK]
 GCLE = [M:DIA]BAN - num$([M:DIA]RBKNUM)
 Delete [RBK] Where BAN=[M:DIA]BAN & RBKNUM=[M:DIA]RBKNUM
 If fstat = 1
  GOK = -1
  GLOCK = "$RELBANK"-GCLE
  Goto ROLL_TR1
 Elsif fstat > 5
  GOK = 0
  Call RSTA("RBK",GCLE) From GLOCK
  Goto AB_TR1
 Endif
  
 # <PP 24/10/02> Intégration développement Emmanuel LATOUR
 # Annulation des commentaires associés à un relevé en cas d'annulation de celui-ci
 GCLE = [M:DIA]BAN - [M:DIA]RBKNUM
 Delete [RBR] Where BAN=[M:DIA]BAN & RBKNUM=[M:DIA]RBKNUM
 If fstat = 1
  GOK = -1 : GLOCK = "$RELBANKREM"-GCLE : Goto ROLL_TR1
 Elsif fstat > 5
  GOK = 0 : Call RSTA("RBR",GCLE) From GLOCK : Goto AB_TR1
 Endif

 GPOINT = "ANURBK" : Gosub ENTREE From EXEFNC
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return
Else Goto TR1
Endif
Return

$VERROU
SYMBCHK ="AUTCHK"+"\"+[M:DIA]BAN
Lock =SYMBCHK
If fstat
 # Compte en cours de pointage
 GERR = 1 : GMESSAGE = mess(23,120,1)
 Unlock =SYMBCHK
 Return
Endif
Return

$SORTIE
Return


######################################################################################################
## Etiquettes masque ANURBK
######################################################################################################

Subprog AS_BAN(VALEUR) 
Variable Char    VALEUR() 
If VALEUR="" 
 Call BANDEF(VALEUR) From SUBCHK 
Endif 
End 

Subprog C_BAN(VALEUR)
Variable Char   VALEUR()
# Contrôle accés à la fonction
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 #V ous n'avez pas accés à la banque
 GMESSAGE = mess(25,120,1)-" "-VALEUR
 mkstat = 2 : End
Endif
# Recherche du compte banque
Read [BAN]BAN0 = VALEUR
If !fstat
 [M]BANACC = [F:BAN]BANACC
 Call LECMAINPLAN(1,[F:BAN]CPY,[M]COA) From CPTDIV
Endif
End

Subprog C_RBKNUM(VALEUR)
Variable Char    VALEUR()
Look [RBK]RBK2=[M]BAN;VALEUR
If fstat
 # Relevé inexistant sur cette banque
 GMESSAGE = mess(33,120,1)
 mkstat = 2 : End
Endif
Filter [RBK] Where BAN=[M]BAN & RBKNUM=VALEUR & RECTYP=2 & CHK<>"" & CHK<>"*"
Read [RBK]RBK0 First
Filter [RBK]
If !fstat
 # Relevé pointé
 GMESSAGE = mess(34,120,1)
 mkstat = 2 : End
Endif
End

$SEL_TABLE
Local Integer MAXFIC
MAXFIC = 1000
Local Char    WRBK(GLONVCR)(1..MAXFIC) 
Local Date    WDAT1(1..MAXFIC), WDAT2(1..MAXFIC)
Local File   (Char RBKNUM(GLONVCR) , Date OPEDAT1 , Date OPEDAT2)
&     From   Variable WRBK , WDAT1 , WDAT2 As [FIC]
TIT = mess(12,123,1)-mess(42,117,1)  :# Choix relevé
NBCOL  = 1 : COL(NBCOL) = "[F:FIC]RBKNUM"  : COLTYP(NBCOL) = type([F:FIC]RBKNUM)  : TIT(NBCOL) = mess(46,120,1) : # Relevé no
NBCOL += 1 : COL(NBCOL) = "[F:FIC]OPEDAT1" : COLTYP(NBCOL) = type([F:FIC]OPEDAT1) : TIT(NBCOL) = mess(94,100,1) : # Du
NBCOL += 1 : COL(NBCOL) = "[F:FIC]OPEDAT2" : COLTYP(NBCOL) = type([F:FIC]OPEDAT2) : TIT(NBCOL) = mess(95,100,1) : # Au
Filter [RBK] Where BAN=[M:DIA]BAN & (RECTYP=1 | RECTYP=3)

NBFIC = 0
For [RBK]RBK0(2)
 NBFIC += 1
 WRBK(NBFIC)  = [F:RBK]RBKNUM
 For [RBK]RBK0(3)
  If [F:RBK]RECTYP=1
   WDAT1(NBFIC) = [F:RBK]OPEDAT 
  Else 
   WDAT2(NBFIC) = [F:RBK]OPEDAT
  Endif 
 Next
Next
Filter [RBK]
For I=NBFIC+1 To MAXFIC
 WRBK(I) = chr$(255)
Next I
adxmxl = NBFIC
Default File [FIC]
ORDRE="RBKNUM"
Return

