#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:42"
A_USER  = "DOC"
A_STAMP = "20181109230442"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRCTRSA"
  If [M]NBRCTRSA=0
  Endif
 When "NBRCTRAFR"
  If [M]NBRCTRAFR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT5 [EMP5]
Gosub HORODAT
Local Inpbox "HRMAT5" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP5] As [SIM_]
Grizo [EMP5]5
Grizo [EMP5]10
Grizo [EMP5]15
Grizo [EMP5]20
Grizo [EMP5]25
Grizo [EMP5]30
Grizo [EMP5]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP5]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=110 : Y1(0)=1 : Y2(0)=9
X1(1)=1 : X2(1)=110 : Y1(1)=10 : Y2(1)=10
X1(2)=1 : X2(2)=110 : Y1(2)=11 : Y2(2)=11
X1(3)=1 : X2(3)=54 : Y1(3)=12 : Y2(3)=14
X1(4)=1 : X2(4)=54 : Y1(4)=15 : Y2(4)=18
X1(5)=1 : X2(5)=54 : Y1(5)=19 : Y2(5)=21
X1(6)=1 : X2(6)=54 : Y1(6)=22 : Y2(6)=24
Return

$ON_RSAID
Onevent CONTROL Call C_RSAID(zc) From W1HRMAT5
Return

Subprog C_RSAID(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_RSAID(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "RSAID" : GZNUM = 55146 : Endif
Gosub _AFF
End

$ON_ETHGRP
Onevent INIT_AREA Call D_ETHGRP(zc) From W1HRMAT5
Onevent BEFORE_INPUT Call AS_ETHGRP(zc) From W1HRMAT5
Return

Subprog D_ETHGRP(VALEUR)
Variable Integer VALEUR
If varinit([M]ETHGRP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ETHGRP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

