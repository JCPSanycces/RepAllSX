#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
################################################################################
$ACTION

Case ACTION
  When "OUVRE"            : Gosub OUVRE
  When "FILTRE"           : Gosub FILTRE
  When "STYLE"            : Gosub STYLE
  When "CREATION"         : Gosub CREATION
  When "APRES_CRE"        : Gosub APRES_CRE
  When "LIENS"            : Gosub LIENS
  When "MODIF"            : Gosub MODIF
  When "APRES_MOD"        : Gosub APRES_MOD
  When "ANNULE"           : Gosub ANNULE
  When "DEFLIG"           : Gosub DEFLIG
  When "INICRE_LIG"       : Gosub INI_LIG
  When "INICRE"           : Gosub INICRE
  When "INIMOD_LIG"       : Gosub INI_LIG
  When "EXEBOUT"          : Gosub EXEBOUT
  When "SETBOUT"          : Gosub SETBOUT
  When "LIENS_LIG"        : Gosub LIENS_LIG
  When "VERIF_CRE"        : Gosub VERIF_CRE
  When "VERIF_MOD"        : Gosub VERIF_MOD
  When Default
Endcase

Return
################################################################################
################################################################################
$OUVRE

If !clalev([F:CPY])  : Local File COMPANY  [CPY]  : Endif
If !clalev([F:CSRL]) : Local File CSFRESL  [CSRL] : Endif
If !clalev([F:CWL])  : Local File CSFPARL  [CWL]  : Endif
If !clalev([F:FCY])  : Local File FACILITY [FCY]  : Endif

Local Char    COUNTER
Local Char    NUM, MESSA(250)
Local Integer STAT, I

Gosub DECLARE From TABLEAUX

Return
################################################################################
################################################################################
$FILTRE

Default File [CSRH]

Return
################################################################################
################################################################################
$STYLE

Chgstl [M:CSRH1]AMTN  With "TDB00"
Chgstl [M:CSRH1]AMTN1 With "TDB00"

For I = 0 To [M:CSRH1]NBLIG
  If [M:CSRH1]USRFLG(I) = 2
    Chgstl [M:CSRH1]AMTN(I) With "TDBRED"
  Endif
  If [M:CSRH1]USRFLG1(I) = 2
    Chgstl [M:CSRH1]AMTN1(I) With "TDBRED"
  Endif
Next

Return
################################################################################
################################################################################
$INICRE

[L]COUNTER = ""
Call LECTURE("TCA","","2") From CONTOBJ
If !fstat : [L]COUNTER = [F:TCA]CODNUM(3) : Endif
If [L]COUNTER = "" : [L]COUNTER = "CSF" : Endif

Call NUMERO([L]COUNTER,"",[0/0/0],"",[L]NUM,[L]STAT) From SUBANM
If [L]STAT
 # Problème lors de la récupération du compteur
 [L]MESSA = [L]COUNTER
 OK = 0 : Call ERREUR(mess(60,199,1)-[L]MESSA) From GESECRAN
 Return
Endif
[F:CSRH]NUMRPT  = val([L]NUM)
[M:CSRH0]NUMRPT = val([L]NUM)

Affzo [M:CSRH0]NUMRPT

Return
################################################################################
################################################################################
$CREATION

Gosub CREATION From TABLEAUX
If GOK < 1  Return  Endif

Return
################################################################################
################################################################################
$APRES_CRE

# -- Rechargement des indicateurs UPDFLG et CREFLG #
Gosub LIENS From TABLEAUX

Return
################################################################################
################################################################################
$LIENS
# -- Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX

If [M:CSRH0]ALLFCY = 2
  Diszo [M:CSRH0]FCY
  Affzo [M:CSRH0]FCY
Endif

Return
################################################################################
################################################################################
$MODIF

Gosub MODIF From TABLEAUX
If GOK < 1  Return  Endif

Return
################################################################################
################################################################################
$APRES_MOD

# -- Rechargement des indicateurs UPDFLG et CREFLG #
Gosub LIENS From TABLEAUX

Gosub STYLE

Return
################################################################################
################################################################################
$ANNULE

Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK < 1  Return  Endif

Return
################################################################################
################################################################################
$DEFLIG

#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#

Default Mask [CSRH1]
Default File [CSRL]

CRIT   = '[F:CSRL]NUMRPT='+num$([M:CSRH0]NUMRPT)
FICLIG = "CSFRESL" : ABLIG = "CSRL"
ZONLIG = "NUMLIN"

Return
################################################################################
################################################################################
$INI_LIG

# -- alim no commande
[F:CSRL]NUMRPT = [F:CSRH]NUMRPT

If [M:CSRH1]USRFLG(nolign-1) = 2
  [F:CSRL]AMTLED1N = [M:CSRH1]AMTN(nolign-1)
Else
  [F:CSRL]AMTLEDN = [M:CSRH1]AMTN(nolign-1)
Endif

If [M:CSRH1]USRFLG1(nolign-1) = 2
  [F:CSRL]AMTLED1N1 = [M:CSRH1]AMTN1(nolign-1)
Else
  [F:CSRL]AMTLEDN1 = [M:CSRH1]AMTN1(nolign-1)
Endif

Return
################################################################################
################################################################################
$LIENS_LIG

If [M:CSRH1]USRFLG(nolign-1) = 2
  [M:CSRH1]AMTN(nolign-1) = [F:CSRL]AMTLED1N
Else
  [M:CSRH1]AMTN(nolign-1) = [F:CSRL]AMTLEDN
Endif

If [M:CSRH1]USRFLG1(nolign-1) = 2
  [M:CSRH1]AMTN1(nolign-1) = [F:CSRL]AMTLED1N1
Else
  [M:CSRH1]AMTN1(nolign-1) = [F:CSRL]AMTLEDN1
Endif

Return
################################################################################
################################################################################
$EXEBOUT

Case BOUT
  When "B"
    Gosub RELIT From GOBJSUB
Endcase

Return
################################################################################
################################################################################
$SETBOUT

If GREP <> "" | !CLECUR
  Call  VIREBOUT(CHAINE,"B")  From GOBJET
Endif

Return
################################################################################
################################################################################
$VERIF_CRE

Gosub VERIF_COM

Return
################################################################################
################################################################################
$VERIF_MOD

Gosub VERIF_COM

Return
################################################################################
################################################################################
$VERIF_COM

Local Decimal CTRAMT0
Local Decimal CTRAMT1

[L]CTRAMT0 = [M:CSRH1]STRAMT0 + [M:CSRH1]RATDEV0 - [M:CSRH1]ENDAMT0
[L]CTRAMT1 = [M:CSRH1]STRAMT1 + [M:CSRH1]RATDEV1 - [M:CSRH1]ENDAMT1

For I = 0 To [M:CSRH1]NBLIG-1
  Read [F:CWL]CWL0 = [M:CSRH0]CODANY;[M:CSRH1]LIG(I)
  If !fstat & [F:CWL]COD2<> "" & !pat([F:CWL]ORIFRM,"*L*")
    [L]CTRAMT0 += [M:CSRH1]AMTN(I)
    [L]CTRAMT1 += [M:CSRH1]AMTN1(I)
  Endif

Next

If [L]CTRAMT0 <> 0
  Call ECR_TRACE(mess(167,104,1) -"(N)",1) From GESECRAN
Else
  If [L]CTRAMT1 <> 0
   Call ECR_TRACE(mess(167,104,1) -"(N-1)",1) From GESECRAN
  Endif
Endif

Return
################################################################################
################################################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
    Raz [M:CSRH0]FCY
    Diszo [M:CSRH0]FCY
Else
    Actzo [M:CSRH0]FCY
Endif

Affzo [M:CSRH0]FCY

End
################################################################################
################################################################################

######################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
#If [F:CPY]CPYLEGFLG<>2
# mkstat=2 : GMESSAGE=mess(130,121,1)   :# Société non juridique
#Endif
End

######################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR # FGR 01/02/2010 : X3SUIVI60986

Call INIALLFCY(VALEUR,[L]CPY) From CPTTRT
End

######################################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End
######################################################################################
######################################################################################
Subprog AM_AMTN(VALEUR)
Variable Decimal VALEUR

[M:CSRH1]USRFLG(nolign-1) = 2
[M:CSRH1]UPDFLG(nolign-1) = 1

End
######################################################################################
######################################################################################
Subprog AM_AMTN1(VALEUR)
Variable Decimal VALEUR

[M:CSRH1]USRFLG1(nolign-1) = 2
[M:CSRH1]UPDFLG(nolign-1) = 1

End
######################################################################################
######################################################################################
Subprog AM_CODANY(VALEUR)
Variable Char    VALEUR()

#If !clalev([F:CSF]) : Local File CSFPARH [F:CSF] : Endif
#If [F:CSF]CODANY <> VALEUR
#  Read [F:CSF]CWH0 = VALEUR
#  If fstat : Raz [F:CSF] : Endif
#Endif
#
#[M:CSRH0]CPY = [F:CSF]CPY
#Affzo [M:CSRH0]CPY

End
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If [F:CPY]CPY <> VALEUR
  Read [F:CPY]CPY0 = VALEUR
Endif

If [F:CPY]CPYLEGFLG = 2
  Diszo [M:CSRH0]BETCPYDET
Else
  Actzo [M:CSRH0]BETCPYDET
Endif

Affzo [M:CSRH0]BETCPYDET

End
######################################################################################
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

If [M:CSRH0]ALLFCY <> 2 & VALEUR = ""
  GMESSAGE = mess(10,123,1)
  mkstat = 2
Endif

End
######################################################################################
######################################################################################
