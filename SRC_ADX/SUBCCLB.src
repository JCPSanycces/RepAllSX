#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FILTRE"     : Gosub FILTRE
 When "AS_TYP"     : Gosub AS_TYP
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
#JASMI - 2017-01-04 - JIRA X3-11745 - START
 When "FILGAUCHE"  : Gosub FILGAUCHE
#JASMI - 2017-01-04 - JIRA X3-11745 - END
Endcase
Return

$FILTRE
Return


$AS_TYP
#DIRAS - 2017-01-18 - START
If GMODU(15)<>2 #Module PAYROLL inactive
  DEB=27 : FIN=35
  For I=DEB To FIN
    GMENLOC(I)=1
  Next
Else
  If GMODU(2)<>2 #Module FINANCIALS inactive
    DEB=1 : FIN=6
    For I=DEB To FIN
      GMENLOC(I)=1
    Next

    DEB=11 : FIN=12
    For I=DEB To FIN
      GMENLOC(I)=1
    Next

    DEB=14 : FIN=26
    For I=DEB To FIN
      GMENLOC(I)=1
    Next
  Endif
Endif
#DIRAS - 2017-01-18 - END
Return


$SEL_LISTE
# Local menu 2820 stores the specific texts of accounting code lines entered by the partners
If CHAP=853
 For [AST]CLE Where LANCHP=2820 & LAN=GLANGUE & LANNUM<>0
  If NBTEX+1>dim(TEX)-1 : Break : Endif
  NBTEX +=1
  TEX(NBTEX)   = num$([F:AST]LANNUM)
  TEXTE(NBTEX) ="/ "+num$([F:AST]LANNUM)+"/ "+[F:AST]LANMES
 Next AST
Endif
Return

$VERF_LISTE
# the first character "/" identifies the specific texts of accounting code lines
If dim([M]TXT)>0 & dim([M]ATXT)>0 & left$(TEXTE(CHOIX),1)="/"
 [M]ATXT(NOL)   = mess(val(VALEUR),2820,1)
 [M]OTHPPU(NOL) = 2
 Affzo [M]ATXT(NOL)
Endif
Return

#DIRAS - 2017-01-18 - START
$FILGAUCHE
If GMODU(15)<>2 #Module PAYROLL inactive
  FILGAUCHE ="TYP<27 | TYP>35" : ##
Else
  If GMODU(2)<>2 #Module FINANCIALS inactive
    FILGAUCHE ="(TYP>=7&TYP<=10)|(TYP=13)|(TYP>=27)"
  Endif
Endif
Return
#DIRAS - 2017-01-18 - END

