###############################################################################

#**************************************************************************************
#* OPE_READ
#* Operation used to flag as read.
#*
#* @key      CHRONO  - Sequence number of the workflow record
#* @key      DEST    - User who will be able to read the record
#*
#* @return   ARET_VALUE
#*
#**************************************************************************************
#*!
$OPE_READ
  Local Char     WERR(255)
  Local Integer  WRET
  Local Instance AWH Using C_TCAWRKHISSUI
  #> Acknowledgment action
  #  ---------------------
  AWH = NewInstance With C_TCAWRKHISSUI
  WRET = fmet AWH.AREAD(DEST,CHRONO)
  If WRET <> 0 Then
#    WERR = "L’enregistrement de suivi n’existe pas"+"."-"Clé"- DEST - CHRONO
    WERR = mess(1,2100,1)+"."- mess(55,123,1) - DEST - CHRONO
    [L]ARET_VALUE = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Else
    AWH.FLGSIG = 4 # Visé
    AWH.USRSIG = AWH.ACTX.USER
    AWH.MAISIG = ""
    AWH.DATSIG = date$
    AWH.TIMSIG = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
    WRET = fmet AWH.AUPDATE()
    If WRET <> 0 Then
#      WERR = "Problème en mise à jour de l’enregistrement de suivi pour le document"-AWH.CLEDEC+"." - "Clé" - DEST - CHRONO
      WERR = func ASYRFNC.MES1(mess(2,2100,1),AWH.CLEDEC) +"." - mess(55,123,1) - DEST - CHRONO
      [L]ARET_VALUE = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Endif
  Endif
  If WRET=0
#    WERR = "Enregistrement de suivi visé pour le document"-AWH.CLEDEC+"." - "Clé" - DEST - CHRONO
    WERR = func ASYRFNC.MES1(mess(3,2100,1),AWH.CLEDEC) +"." -  mess(55,123,1) - DEST - CHRONO
    [L]ARET_VALUE = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
  Endif
  FreeInstance AWH
Return

###############################################################################

#**************************************************************************************
#* OPE_SIGNACTION
#* Operation used to sign documents. Two actions are avalaible : validation or reject
#* The operation create a lka file in the folder build with WRKTMPDIR and WRKTMPMAC
#* parameters and solution and current folder name.
#*
#* @key      CHRONO  - Sequence number of the workflow record
#* @key      DEST    - User who will be able to read the record
#*
#* @param    PACTION - VAL or REJ or CAN
#* @param    PEMAIL  - Email adress coming from the user profile (user who sign)
#*
#* @return   ARET_VALUE
#*
#**************************************************************************************
#*!
$OPE_SIGNACTION
  Local Char    ERM(255)
  Local Integer ERN
  Local Char CLEDEC(100)
  Local Char LNKHTP(10)

  Local Char    LACTVAL(3)      : LACTVAL    = "VAL"
  Local Char    LACTREJ(3)      : LACTREJ    = "REJ"
  Local Char    LACTCAN(3)      : LACTCAN    = "CAN"
  Local Char    LEXTFIL(3)      : LEXTFIL    = "lka"

  Local File AWRKHISSUI [AWS_]
  Read [F:AWS_]AWS0 = CHRONO;DEST
  If !fstat
    CLEDEC = [F:AWS_]CLEDEC
    If [AWS_]EMAIL = ""
#       ERM = "Erreur lors de la création du fichier de signature. Document n° CLEDEC non signé. Enregistrement de suivi n° CHRONO / DEST : Email non renseigné"
       ERM = mess(4,2100,1) + "." - func ASYRFNC.MES1(mess(7,2100,1),CLEDEC) + "." - func ASYRFNC.MES1(mess(8,2100,1),CHRONO-"/"-DEST) -":"-mess(38,143,1)
       Goto SIGNACTION_WARNING
    Endif

    If PACTION = LACTCAN # If "CANcel" action, FLGSIG have to be equal 5
      If [F:AWS_]FLGSIG <> 5
#        ERM = "Erreur lors de l’annulation de signature du document n° CLEDEC. Enregistrement de suivi n° CHRONO / PEMAIL non signé"
        ERM = func ASYRFNC.MES1(mess(5,2100,1),CLEDEC) + "." - func ASYRFNC.MES1(mess(9,2100,1),CHRONO-"/"-PEMAIL)
        Goto SIGNACTION_ERROR
      Endif
    Endif

    #US X3-23534 by RBA 02-24-2017 SAM 121701
    # Si la signature de ce chrono a déclenché une autre signature,
    # on vérifie que cette signature n'a pas été signée (pas visée)
    Local Char    WCHRREF(GLONVCR)
    If [AWS_]NUMORG <> ""
      WCHRREF = [AWS_]NUMORG          : # Chrono de l'évènement principal
    Else
      WCHRREF = [AWS_]CHRONO
    Endif
    Local Integer K
    K = 1
    Local File AWRKHISSUI [AWS_2]
    For [AWS_2]AWS1 Where [AWS_2]NUMORG = WCHRREF & [AWS_2]CHRONO > [AWS_]CHRONO
      If [AWS_2]DATSIG = [AWS_]DATSIG & [AWS_2]TIMSIG >= [AWS_]TIMSIG & [AWS_2]FLGSIG & [AWS_2]FLGSIG<>4
        K = 0 : Break
      Elsif [AWS_2]DATSIG > [AWS_]DATSIG & [AWS_2]FLGSIG<>4
        K = 0 : Break
      Endif
    Next AWS2
    Close File [AWS_2]
    If !K
      # Annulation impossible\Chrono déjà signé
      ERM = ERM-mess(49,117,1)+"\"+[AWS_]CHRONO-mess(127,75,1)
      Goto SIGNACTION_ERROR
    Endif
    #/US X3-23534 by RBA 02-24-2017 SAM 121701

    #US X3-26999 by RBA 04-06-2017 SAM 122426
    Gosub SIGNACTION_CLASSIC
##  recherche du jeton
#   Local File AWRKHISDES [AWO_]
#   Read [F:AWO_]AWO0 = CHRONO;PEMAIL
#   If fstat
##    ERM = "Erreur lors de la signature du document n° CLEDEC. Il n’y a pas d’enregistrement de suivi à traiter CHRONO / PEMAIL"
#     ERM = func ASYRFNC.MES1(mess(6,11672,1),CLEDEC) +"."- mess(12,11672,1) - CHRONO-"/"-PEMAIL
#     Goto SIGNACTION_WARNING
#   Else
#     LNKHTP = [F:AWO_]LNKHTP
#   Endif
#   LogicClose File [AWO_]
#   #creation fichier lka
#   Gosub SIGNACTION_FILE
    #/US X3-26999 By RBA 04-06-2017 SAM 122426
  Endif

  LogicClose File [AWS_]
Return

###############################################################################

$SIGNACTION_MSG
  ###########status message
  If ERM = ""
#    ERM = "Signature du document n° CLEDEC effectuée. Enregistrement de suivi n° CHRONO/PEMAIL mis à jour"
    ERM = func ASYRFNC.MES1(mess(13,2100,1),CLEDEC) + "." - func ASYRFNC.MES1(mess(10,2100,1),CHRONO +"/"+ PEMAIL)
    ARET_VALUE  = [V]CST_AINFO
  Endif

  Case PACTION
    When LACTVAL : ASTATUS = fmet this.ASETERROR ("", mess(71,75,1)  - ":" - ERM, ARET_VALUE)   #Signature
    When LACTREJ : ASTATUS = fmet this.ASETERROR ("", mess(165,154,1)- ":" - ERM, ARET_VALUE)   #Refus
    When LACTCAN : ASTATUS = fmet this.ASETERROR ("", mess(158,75,1) - ":" - ERM, ARET_VALUE)   #Annulation signature
  Endcase
Return

###############################################################################

$SIGNACTION_FILE
  #############folder & file
  Local Char    LWRKRMTDIR(255) : LWRKRMTDIR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"WRKRMTDIR")
  Local Char    LWRKRMTMAC(255) : LWRKRMTMAC = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"WRKRMTMAC")

  Local Char    LFOLDER(50)     : LFOLDER    = this.ACTX.AFOLDER
  Local Char    LSOLUTION(50)   : LSOLUTION  = this.ACTX.ASOLUTION

  Local Char    RACINE(255)     : RACINE     = vireblc(LWRKRMTDIR,2) # Chemin serveur

  Local Char    REPERT(255)
  Local Char    FICHIER(255)
  Local Char    FICHIERINV(255)

  # Répertoire des fichiers liens actions
  Onerrgo SIGNACTION_ERRFIC
  REPERT     = RACINE+"/"+LSOLUTION+LFOLDER
  FICHIER    = filpath("","","","","",LWRKRMTMAC)
#  FICHIER = filpath("","","","","","LWRKRMTMAC")
  If ERN
#    ERM = "Erreur lors de la création du fichier de signature. Document n° CLEDEC non signé - LWRKRMTMAC : Serveur inaccessible"
    ERM = mess(4,2100,1) + "."- func ASYRFNC.MES1(mess(7,2100,1),CLEDEC) - "-" - LWRKRMTMAC-":" - mess(14,2100,1)
  Else
    FICHIER = filpath(REPERT,"","","","",LWRKRMTMAC)
    If ERN
#      ERM = Erreur lors de la création du fichier de signature. Document n° CLEDEC non signé - REPERT : Répertoire inaccessible"
      ERM = mess(4,2100,1)+"."- func ASYRFNC.MES1(mess(7,2100,1),CLEDEC) - "-" - REPERT-":" - mess(147,141,1)
    Else
      K = filinfo(FICHIER,0)
    Endif
  Endif
  Onerrgo

  If ERN
    STAT = 1
    Goto SIGNACTION_ERROR
  Elsif K < 0
#    ERM = "Erreur lors de la création du fichier de signature. Document n° CLEDEC non signé - FICHIER : Répertoire inexistant"
    ERM = mess(4,2100,1) + "." - func ASYRFNC.MES1(mess(7,2100,1),CLEDEC) - "-" - FICHIER-":" - mess(86,133,1)
    STAT = 1
    Goto SIGNACTION_ERROR
  Endif

  #test fichier inverse ou CAN deja créé
  Case PACTION
    When LACTVAL : FICHIERINV = FICHIER+"\"+CHRONO+"-"+LACTREJ+"."+LEXTFIL
    When LACTREJ : FICHIERINV = FICHIER+"\"+CHRONO+"-"+LACTVAL+"."+LEXTFIL
    When LACTCAN : FICHIERINV = FICHIER+"\"+CHRONO+"-"+LACTCAN+"."+LEXTFIL
  Endcase
  FICHIER = FICHIER+"\"+CHRONO+"-"+PACTION+"."+LEXTFIL

  #> Check if file exists
  If filinfo(FICHIER,7)>0
#   ERM = "Erreur lors de la création du fichier de signature. Enregistrement de suivi n° CHRONO / PEMAIL déjà en cours de traitement"
   ERM = mess(4,2100,1) + "."- func ASYRFNC.MES1(mess(15,2100,1),CHRONO-"/"-PEMAIL)
   Goto SIGNACTION_WARNING
  Else
   If filinfo(FICHIERINV,7)>0
#    ERM = "Erreur lors de la création du fichier de signature. Enregistrement de suivi n° CHRONO / PEMAIL déjà en cours de traitement"
    ERM = mess(4,2100,1) + "."- func ASYRFNC.MES1(mess(15,2100,1),CHRONO-"/"-PEMAIL)
    Goto SIGNACTION_WARNING
   Endif
  Endif

  #> File creation
  Openo FICHIER,0 Using [_LKA]
  Wrseq "K="+LNKHTP Using [_LKA]
  Openo Using [_LKA]
  Goto SIGNACTION_INFO
Return

###############################################################################

#**************************************************************************************
#* Error on file creation
#**************************************************************************************!
$SIGNACTION_ERRFIC
  ERN = errn

#  ERM -="Erreur lors de la création du fichier de signature"+"."- "Document" - CLEDEC -"non signé"
  ERM -= mess(4,2100,1) + "." - func ASYRFNC.MES1(mess(7,2100,1),CLEDEC)
  ERM -= errp                #nom du script
  ERM -= "("+num$(errl)+")"  #n° de ligne dans le script
  #ERM -= num$(ERN)          #n° technique d'erreur
  ERM -= errmes$(abs(ERN))   #message technique d'erreur
  ERM -= errm                #ce qui pose probleme
  ERM = ""
Resume

###############################################################################

#**************************************************************************************
#* Error management : Information
#**************************************************************************************!
$SIGNACTION_INFO
  ARET_VALUE   = [V]CST_AINFO
  Gosub SIGNACTION_MSG
Return

###############################################################################

#**************************************************************************************
#* Error management : Warning
#**************************************************************************************!
$SIGNACTION_WARNING
  ARET_VALUE  = [V]CST_AWARNING
  Gosub SIGNACTION_MSG
Return

###############################################################################

#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
$SIGNACTION_ERROR
  ARET_VALUE  = [V]CST_AERROR

  # Free ETNA gateway
  FreeInstance MYGATE #X3-63258_Signature_using_ETNA_gateway

  Gosub SIGNACTION_MSG
Return


###############################################################################
#US X3-26999 by RBA 04-06-2017 SAM 122426
#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
#*
#*!
$SIGNACTION_CLASSIC
  Local Integer RETMETH  : RETMET  = [V]CST_AERROR
  Local Integer RETVAL   : RETVAL  = [V]CST_AERROR
  Local Char WERR(250)   : WERR    = ""

  Local Char WCHRONO(20) : WCHRONO = CHRONO
  Local Char WDEST(80)   : WDEST   = DEST
  Local Char WACTION(3)  : WACTION = PACTION
  Local Char WMAIL(250)  : WEMAIL  = PEMAIL

# test GUSER = DEST
  #If GACTX.USER <> WDEST #X3-63258_Signature_using_ETNA_gateway
  If this.ACTX.USER <> WDEST
    # Handle the error and exit
    ERM = mess(46,154,1)-":"-WDEST #Signataire attendu
    Goto SIGNACTION_ERROR
  Endif

# Instanciate ETNA gateway
  Local Instance MYGATE Using C_AGATEWAYETNA
  MYGATE = NewInstance C_AGATEWAYETNA AllocGroup null

# Send parameters to the gateway structure and handle the errors
  If fmet MYGATE.ASETVALCHAR("WCHRONO",WCHRONO)=[V]CST_AOK
    If fmet MYGATE.ASETVALCHAR("WDEST",WDEST)=[V]CST_AOK
      If RETVAL = fmet MYGATE.ASETVALCHAR("WACTION",WACTION)=[V]CST_AOK
        RETVAL = fmet MYGATE.ASETVALCHAR("WEMAIL",WEMAIL)
      Endif
    Endif
  Endif
  If RETVAL=[V]CST_AERROR
    # Handle the error and exit
    ERM = mess(204,196,1) #"Erreur dans le code paramètre"
    Goto SIGNACTION_ERROR
  Endif

# Call the ARPC method
  RETVAL = fmet MYGATE.ARPC("TCWCOM_OPERATIONS","GAT_SIGNATION_CLASSIC")
  If RETVAL=[V]CST_AERROR
    # Handle the error and exit
    ERM = "ARPC"-mess(7,21,1)#+":"-num$(RETVAL) #ARPC Erreur:xxx
    Goto SIGNACTION_ERROR
  Endif

# Check if it was successful
  RETVAL = fmet MYGATE.AGETVALINTEGER("RETMETH", RETMETH)
  RETVAL = fmet MYGATE.AGETVALCHAR("WERR", WERR)

# Free ETNA gateway
  FreeInstance MYGATE

# Display error or succes message depending of ARPC method call result
  Case RETMETH
    When [V]CST_AOK    : ERM = ""   : Goto SIGNACTION_INFO
    When [V]CST_AERROR : ERM = WERR : Goto SIGNACTION_ERROR
  Endcase
Return

###############################################################################

$GATEWAYS
  Case AGATEWAY:
    When "GAT_SIGNATION_CLASSIC" Gosub GAT_SIGNATION_CLASSIC
  Endcase
Return

###############################################################################

$GAT_SIGNATION_CLASSIC
  Local Integer RETMETH  : RETMET  = [V]CST_AERROR
  Local Integer RETVAL   : RETVAL  = [V]CST_AERROR
  Local Char WERR(250)   : WERR = ""

  Local Char WCHRONO(20)
  Local Char WDEST(80)
  Local Char WACTION(3)
  Local Char WEMAIL(250)

# Get parameters from the gateway structure and handle the errors
  If fmet this.AGETVALCHAR("WCHRONO", WCHRONO) = [V]CST_AOK
    If fmet this.AGETVALCHAR("WDEST", WDEST) = [V]CST_AOK
      If RETVAL = fmet this.AGETVALCHAR("WACTION", WACTION) = [V]CST_AOK
        RETVAL = fmet this.AGETVALCHAR("WEMAIL", WEMAIL)
      Endif
    Endif
  Endif
  If RETVAL=[V]CST_AERROR
    # Handle the error and exit
    WERR    = "GATEWAY"-mess(7,21,1) #GATEWAY Error"
    RETVAL  = fmet this.ASETVALCHAR("WERR", WERR)
    RETMETH = [V]CST_AERROR
    RETVAL  = fmet this.ASETVALINTEGER("RETMETH", RETMETH)
    Return
  Endif

# Call the classic signature function and handle the errors
  RETMETH = func MY_SIGWRK(WCHRONO, WDEST, WACTION, WEMAIL)
  If RETMETH = [V]CST_AERROR #error
    WERR = mess(139,199,1) #Echec du traitement
  Endif

  # Send result parameters to the gateway structure
  RETVAL = fmet this.ASETVALCHAR("WERR", WERR)
  RETVAL = fmet this.ASETVALINTEGER("RETMETH", RETMETH)
Return

###############################################################################

Funprog MY_SIGWRK(WCHRONO, WDEST, WACTION, WEMAIL)
Value Char WCHRONO
Value Char WDEST
Value Char WACTION
Value Char WEMAIL

  Local Integer WOK : WOK = [V]CST_AERROR
  Local Char    PARAM(250)(1..7)
  Local Char    VALWRK(10)
  Local Char    SPEWRK(GLONADC)

  # A utiliser dans le texte du workflow
  GSERVEUR = [V]CST_ATRUE
  GUSER    = WDEST
  GNOMUSER = WEMAIL

  PARAM(1) = WCHRONO
  PARAM(2) = WDEST
  PARAM(3) = WDEST
  PARAM(4) = WEMAIL
  PARAM(5) = WACTION
  PARAM(6) = "-1" #simule le mode batch

  Call TRTSPE(nomap,"SIGWRK",SPEWRK) From SUBACT
  Call TRAITE_CHAR(VALWRK,PARAM,"","SAIWRKSIG","",5,SPEWRK) From GTRAITE : # Signature action
  If val(PARAM(6)) = 1
    WOK = [V]CST_AOK #success !!
  Endif
End WOK
#/US X3-26999 by RBA 04-06-2017 SAM 122426

