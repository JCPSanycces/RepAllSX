#<AdxTL>@(#)0.0.0.0 $Revision$
Call PARCLI("UserNameEx",GBIDC1) From GLOBVAR
Infbox GBIDC1
Call PARCLI("NameDnsDomain",GBIDC1) From GLOBVAR
Infbox GBIDC1
End
AAUSER = "cclement"
APASSWD = ""
#Dbgaff
Call SSO(AAUSER,APASSWD,MESSAG,1,SSOTYP,AERR)
Infbox "user="+AAUSER-"psswd="+APASSWD-"message="+MESSAG-"typ="+num$(SSOTYP)-"err="+num$(AERR)
End

#---------------------------------------------------------------------------#
# Vérification de l'existence d'un utilisateur dans l'Active Directory
#---------------------------------------------------------------------------#

Subprog SSO(AAUSER,APASSWD,MESSAG,TYPCON,SSOTYP,AERR)
Variable Char    AAUSER  : # Code utilisateur
Variable Char    APASSWD : # Mot de passe en clair
Variable Char    MESSAG  : # Message anomalie
Value    Integer TYPCON  : # Type de connexion 1=Standard, 2=Ntlm, 3=SSOsage
Variable Integer SSOTYP  : # 2 = mot de passe non contrôlé par X3
Variable Integer AERR    : # >0 = accès refusé

Local Integer I , J , PORT , ER , ESSAI , OPTMAJ
Local Char    USER(50) , USRCLI(50) , ADDN(250) , CHAINE(250)
Local Char    ANAME(250) , IDAD(250) , PASAD(250) , USRAD(30)

If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:ANU])=0 : Local File ANNUAIRE [ANU] : Endif

Raz AERR , MESSAG , ESSAI

SSOTYP = 1

Call PARAM("","SSOMAJ",CHAINE) From ADOVAL
OPTMAJ = val(CHAINE)-1

# Compte réseau de connexion
If TYPCON<>2
 Call PARCLI("UserName",USRCLI) From GLOBVAR
 AAUSER = toupper(USRCLI)
Endif

USER = vireblc(AAUSER,2)
I = instr(1,USER,"@")
If I : USER = left$(USER,I-1) : Endif
I = instr(1,USER,"\")
If I : USER = right$(USER,I+1) : Endif

Read [AUS]LOGIN=toupper(USER)
If fstat
 MESSAG = USER-":"-mess(60,130,1) : # Code utilisateur inexistant dans l'application courante
 AERR = 2 : Goto FIN
Endif

Call VERIF(0,"",PORT,AERR,MESSAG)
If AERR : Goto FIN : Endif

IDAD  = [F:ANU]CONNEC : # DistinguishedName base ldap
PASAD = [F:ANU]PASSE  : # Mot de passe cryté base ldap
ADDN  = vireblc(evalue("[F:AUS]"+[F:ANU]CODFLD(find(1,[F:ANU]TYPFLD)-1)),2) : # DistinguishedName utilisateur

$ESSAI
Gosub MAJ
If AERR
 If !ESSAI & !GWEBSERV : # Premier essai (le mot de passe référencé dans l'annuaire est peut-être périmé)
  ESSAI += 1
  AERR = 0
  Gosub SAICON : # On va essayer de se connecter avec un autre user et mot de passe dans la base ldap
  If AERR : Goto FIN : Endif
  ADDN = ""
  Goto ESSAI
 Else
  Goto FIN
 Endif
Endif
If ADDN=""
 Read [AUS]LOGIN=toupper(USER)
 ADDN = vireblc(evalue("[F:AUS]"+[F:ANU]CODFLD(find(1,[F:ANU]TYPFLD)-1)),2)
 If ADDN=""
  MESSAG = func AFNC.MES(mess(62,130,1),[F:AUS]USR) : # Identificateur unique non renseigné pour l'utilisateur #
  AERR = 2 : Goto FIN
 Endif
Endif

Call PARAM("","SSOPASSWD",CHAINE) From ADOVAL
If val(CHAINE)=1 : # Mot de passe non contrôlé
 Goto FORCE
Endif

#If TYPCON=2 & !GWEBSERV # &!GBROWS : # Ntlm (il faut saisir le mot de passe X3)   Aussi en Web
If TYPCON=2 & !GWEBSERV  : # Ntlm (il faut saisir le mot de passe X3)
 Call PASSE(tolower(USER),APASSWD) From ASSOPASX3
 If mkstat
  MESSAG = mess(97,130,1) : # Connexion abandonnée
  AERR = 2 : Goto FIN
 Endif  
Endif

# Le mot de passe sera contrôlé dans GESUSER
password = APASSWD

AAUSER = USER

#----------------#
$FIN
Close Local File [AUS] , [ANU]
End

#----------------#
$SAICON
USRAD = tolower(USER)
Call PASSE(USRAD,PASAD) From ASSOPASWEB : # Saisie utilisateur et mot de passe réseau
If mkstat or USER=""
 AERR = 2
 MESSAG = mess(97,130,1) : # Connexion abandonnée
Else
 Read [AUS]LOGIN=toupper(USRAD)
 IDAD = vireblc(evalue("[F:AUS]"+[F:ANU]CODFLD(find(1,[F:ANU]TYPFLD)-1)),2) : # DistinguishedName
 If IDAD=""
  # Utilisateur jamais connecté, aucune chance
 Endif
 PASAD = XCRYPT(PASAD) : # Mot de passe Crypté
Endif
Return

#----------------#
$FORCE
AERR = 0
SSOTYP = 2
APASSWD = [F:AUS]NEWPAS : # Mot de passe de la fiche utilisateur
If APASSWD<>""
 Call VARPSE(APASSWD) From GESUSER
Endif
password = APASSWD
Goto FIN

#----------------#
$MAJ
Call MAJUSR('[F:AUS]USR="'+[F:AUS]USR+'"',0,0,"",IDAD,PASAD,OPTMAJ,AERR,MESSAG) From ASSOMAJ
If AERR & AERR<>4
 MESSAG = mess(63,130,1)+"\"+MESSAG : # Mise à jour utilisateur impossible
Endif
Return

#----------------------------------------------------------------------#
Subprog OUVRE(SERV1,PORT,IDAD,PASAD,AERR,MESSAG)
Value Char SERV1
Value Integer PORT
Value Char IDAD , PASAD
Variable Integer AERR
Variable Char MESSAG
Raz AERR , MESSAG
Onerrgo ERR_CONNECT
OPLDAP SERV1,PORT,IDAD,PASAD Using [ALDP]
Onerrgo 
If AERR & clalev([F:ANU])>0 : # Connexion sur le serveur secondaire
 If vireblc([F:ANU]SERV2,2)<>""
  Raz AERR , MESSAG
  Onerrgo ERR_CONNECT
  OPLDAP [F:ANU]SERV2,PORT,IDAD,PASAD Using [ALDP]
  Call TRACE_ESPION("CONNECT","OPLDAP/2",[F:ANU]SERV2+"/"+num$(PORT)-"user="+IDAD-"passwd="+PASAD-"Erreur="+num$(AERR)) From ESPION
  Onerrgo
 Endif
Endif
End

#----------------------------------------------------------------------#
Subprog FERME
Onerrgo ERR_FERME
CLLDAP Using [ALDP]
Onerrgo
End

#----------------------------------------------------------------------#
Subprog VERIF(FORCE,DOMAINE,PORT,AERR,MESSAG)
Value    Integer FORCE
Value    Char    DOMAINE
Variable Integer PORT
Variable Integer AERR
Variable Char MESSAG
Local Char DIRECT(GLONANU) , FLD(GLONAVA) , PREF(10) , TRTANU(GLONADC)
Local Char DOMUSR(250) , CHAINE(80)
Local Integer I , OKTRT , NBDIR , TRACE
If clalev([F:ANU])=0 : Local File ANNUAIRE [ANU] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
TRACE = 0
Call TRACE("domaine="+DOMAINE-"GBROWS="+num$(GBROWS),TRACE)
# Recherche du domaine
If !FORCE
 If GBROWS
  If dim(GSSODOM)>0 : DOMAINE = GSSODOM : Call TRACE("GSSODOM="+GSSODOM,TRACE) : Endif
 Else
  Call PARCLI("UserNameEx",DOMAINE) From GLOBVAR
  Call TRACE("UserNameEx="+DOMAINE,TRACE)
  #Call PARCLI("NameDnsDomain",DOMAINE) From GLOBVAR
  I = instr(1,DOMAINE,"\")
  If I
   DOMAINE = left$(DOMAINE,I-1)
  Endif
 Endif
Endif
Call TRACE("[F:AUS]USR="+[F:AUS]USR-"newDOMAINE="+DOMAINE,TRACE)
If DOMAINE<>"" & [F:AUS]USR<>""
 Call PARAMUTIL("SSODOMAIN",DOMUSR,[F:AUS]USR,"") From SUBAUS
 Call TRACE("DOMUSR="+DOMUSR,TRACE)
 If DOMUSR<>"" & toupper(DOMUSR)<>toupper(DOMAINE)
  # L'utilisateur $1$/$2$ n'est habilité que sur le domaine $3$
  MESSAG = func AFNC.MES3(mess(105,130,1),DOMAINE,[F:AUS]LOGIN,DOMUSR)
  AERR = 3 : End
 Endif
Endif
NBDIR = 0
If DOMAINE<>"" & dim([F:ANU]DOMAIN)>0
 CHAINE = DOMAINE
 I = instr(1,CHAINE,".")
 If I
  CHAINE = left$(CHAINE,I-1)
 Endif
 For [ANU]ANU0 Where ENAFLG=2
  If find(toupper([F:ANU]DOMAIN),CHAINE,[L]DOMAINE)  
   NBDIR += 1
   If NBDIR=1 : DIRECT = [F:ANU]COD : Endif
  Endif
 Next ANU
Endif
Call TRACE("DIRECT="+DIRECT,TRACE)
# mb 24.6.13 demande 89958 Un utilisateur référencé dans un domaine ne peut
# se connecter que dans le LDAP de son domaine
If DIRECT="" & DOMAINE=""
 Call PARAM("","SSODIRECT",DIRECT) From ADOVAL : # Obsolète
 Call TRACE("SSODIRECT="+DIRECT,TRACE)
 If DIRECT=""
  If dim([F:ANU]DOMAIN)>0
   For [ANU]ANU0 Where DOMAIN="" & ENAFLG=2
    NBDIR += 1
    If NBDIR=1 : DIRECT = [F:ANU]COD : Endif
   Next ANU
  Else   
   For [ANU]ANU0 Where ENAFLG=2
    NBDIR += 1
    If NBDIR=1 : DIRECT = [F:ANU]COD : Endif
   Next ANU
  Endif
 Else
  NBDIR = 1
 Endif
Endif
MESSAG = ""
Call TRACE("newDIRECT="+DIRECT,TRACE)
If DIRECT=""
 If DOMAINE<>""
  MESSAG = func AFNC.MES1(mess(103,130,1),DOMAINE) : # Annuaire introuvable sur le domaine $1$
 Else
  MESSAG = mess(64,130,1) : # Annuaire non paramétré
 Endif
Else
 Read [ANU]ANU0=DIRECT
 If fstat
  MESSAG = DIRECT-":"-mess(65,130,1) : # Annuaire inexistant
 Endif
Endif
If MESSAG<>""
 AERR = 3 : End
Endif
Call SET_PREF(PREF) From SUBANU
TRTANU = PREF+DIRECT
Call EXISTE_ADX("","",TRTANU,OKTRT) From ORDSYS
If !OKTRT
 MESSAG = DIRECT-":"-mess(73,130,1) : # Annuaire non validé
 AERR = 3 : End
Endif
If vireblc([F:ANU]SERV1,2)="" 
 MESSAG = mess(100,130,1)-":"-mess(66,130,1) : # Le Serveur Active Directory n'est pas renseigné
 AERR = 3 : End
Endif
I = find(1,[F:ANU]TYPFLD)
If I=0
 MESSAG = mess(100,130,1)-":"-mess(67,130,1) : # Identificateur unique non paramétré dans l'annuaire
 AERR = 3 : End
Endif
FLD = [F:ANU]CODFLD(I-1)
If evalue("dim([F:AUS]"+FLD+")")<0
 MESSAG = mess(100,130,1)-DIRECT+"\"+FLD-":"-mess(41,100,1) : # Champ inexistant
 AERR = 3 : End
Endif
If vireblc([F:ANU]CONNEC,2)="" 
 MESSAG = mess(100,130,1)-DIRECT-":"-mess(68,130,1) : # Identificateur unique de recherche non renseigné
 AERR = 3 : End
Endif
If vireblc([F:ANU]PARAM1,2)="" 
 MESSAG = mess(100,130,1)-DIRECT-":"-mess(69,130,1) : # La base de recherche n'est pas renseigné
 AERR = 3 : End
Endif
PORT = 389
If [F:ANU]PORT<>0 : PORT = [F:ANU]PORT : Endif
End

#------------------------------#
Subprog TRACE(MESSAGE,TRACE)
Value Char    MESSAGE
Value Integer TRACE
If TRACE
 Openo filpath("TRA","connectSSO","tra") Using [LOG_]
 Iomode adxifs "" Using [LOG_]
 Iomode adxirs chr$(10) Using [LOG_]
 Iomode adxium 0 Using [LOG_]
 Wrseq date$-time$-MESSAGE Using [LOG_]
 Openo Using [LOG_]
Endif
End

#-----------------#
$ERR_CONNECT
AERR = 4
ER = errn
MESSAG = mess(70,130,1) : # Utilisateur ou mot de passe incorrect
MESSAG += "\("+mess(6,123,1)-num$(ER)-errmes$(ER)-errm+")"
Resume

#-----------------#
$ERR_FERME
MESSAG = mess(71,130,1) : # Erreur déconnexion de l'Active Directory
AERR = 2
Resume

#-----------------------------------------------------------------#
#  Pour connexion de type SSO (ancienne version) OPAC
#  On transmet AKEY 
#  on retourne AAUSER  : User X3
#              APASSWD : Mot de passe
#              AERR    : Code retour     0,1 OK
#                                        2   Erreur
#-----------------------------------------------------------------#

Subprog SSOPAC(AKEY,AAUSER,APASSWD,AERR)
Value Char AKEY
Variable Char AAUSER
Variable Char APASSWD
Variable Integer AERR

Local Integer POS
POS=instr(1,AKEY,"~")
If POS=0
  AERR=2
Else
  AAUSER=toupper(left$(AKEY,POS-1))
  APASSWD=right$(AKEY,POS+1)
  AERR=1
Endif

End

