# Superviseur
## CRUD-CLASSE ## CCMCRORIGS
# 2018-10-19 07:50:19 679


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGS

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_CCMCRORIGS

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGS
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
CCMCRORIGS.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_CCMCRORIGS
Else
 Gosub AUPDATE_CCMCRORIGS
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = CCMCRORIGS.freeSnapshot
CCMCRORIGS.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If CCMCRORIGS.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGS.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(CCMCRORIGS.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGS.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(CCMCRORIGS.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGS.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_CCMCRORIGS
Trbegin [F:CCMCROS]
 Gosub AUPDATE_CCMCRORIGS
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_CCMCRORIGS
[L]A_ASTALIN = CCMCRORIGS.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGS._MAJSQL_CCMCRORIGS(CCMCRORIGS))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = CCMCRORIGS.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If CCMCRORIGS.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGS.revertUpdTick
Endif

[L]ASTATUS = max(fmet CCMCRORIGS.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(CCMCRORIGS.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGS.ASTALIN = [V]CST_ALL
Endif
Return



