#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL03   Pre-migration commandes ouvertes            Module Ventes #
# Gestion des infos douanières                                             #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL03") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End
###################################################################################
Subprog MAJ_UUMGPRESAL03(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL02",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL03",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL03 Sales Order Process : Update SORDERC") From DOSSUB
Call ECR_TRACE("UUMGPRESAL03 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
#EXE_SQL = 1

# Passage en V6
If VERSION<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table S0H
  # ----------------------------------------
  Gosub ADDCOL60
  If ERR : Goto FIN_SOC : Endif
Endif

If EXE_SQL
  Gosub TRT_SQL_SOC
Else

  Gosub TRT_X3_SOC
Endif

# Passage en V6
If VERSION<GMIGX3VER60
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"SORDERC",ERR) From TRTMIG
  If ERR : Goto FIN_SOC : Endif
Endif

$FIN_SOC
Call ECR_TIME("UUMGPRESAL03 Sales Order Process END.") From DOSSUB
End

##########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V6
# ----------------------------------------
# 1- ajouter les colonnes dans la table SOH
# 2- ajouter un index unique
# ----------------------------------------
$ADDCOL60

# 1- ajouter les colonnes dans la table SOC
# ----------------------------------------
If GACTDEB=2
  # Ajout du champ BPIEECNUM  : Identification CEE
  Call MIGADDCOL (DOSSIER,"SORDERC","BPIEECNUM","A",20,1,ERR) From TRTMIG
  If ERR : Return : Endif

  # Ajout du champ EECLOC : Lieu de transport CEE
  If clalev([F:ATZ1])=0 : Local File =DOSSIER+".ATABZON" [ATZ1] : Endif
  If clalev([F:ATZ2])=0 : Local File =DOSSIER+".ATABZON" [ATZ2] : Endif
  # Ajout du champ EECLOC : Lieu de transport CEE
  Read [ATZ2]CODZONE="SORDERC";"EECLOC"
  If fstat : #il faut ajouter la zone
      Filter [ATZ1] Where CODFIC="SORDERC"
      Read [ATZ1]NUMLIG Last
      Filter [ATZ1]
      Trbegin [ATZ2]
      Raz [F:ATZ2]
      [F:ATZ2]NUMLIG=[F:ATZ1]NUMLIG+1
      [F:ATZ2]CODFIC="SORDERC"
      [F:ATZ2]CODZONE="EECLOC"
      [F:ATZ2]CODACT="MIG"
      [F:ATZ2]CODTYP="M"
      [F:ATZ2]LONG=15
      [F:ATZ2]NOLIB=236
      [F:ATZ2]DIME=1
      [F:ATZ2]OBLIG=1
      [F:ATZ2]ZERO=1
      #texte 8713 : Interne X3
      [F:ATZ2]NOCOURT=8713
      [F:ATZ2]NOLONG=8713
      [F:ATZ2]NOABREG=8713
      Write [ATZ2]
      If fstat
        Call ECR_TRACE("File ATABZON"-[F:ATZ2]CODFIC-[F:ATZ2]CODZONE+", Error ="-num$(fstat),1) From GESECRAN
        Rollback
        Return
      Else
        Commit
      Endif
  Endif
Endif

# Ajout du champ EECICT : Incoterm
Call MIGADDCOL (DOSSIER,"SORDERC","EECICT","A",20,1,ERR) From TRTMIG
If ERR : Return : Endif

#2- ajouter un index unique
#--------------- INDEX ADDITION  ----------#
Call MIGINDCRE (DOSSIER,"SORDERC","BPCORD+BPAADD+SOHNUM+SOPLIN","","",0,ERR) From TRTMIG
If ERR : Return : Endif

Return

########################################################################
$TRT_X3_SOC

# Passage en V6
If VERSION<GMIGX3VER60
  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_SOC_60
Endif

Return
############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête devis : SORDERC                                                   #
# ---------------------                                                    #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_SOC_60

Call ECR_TIME("UUMGPRESAL03 : Avant traitement SOC ")  From DOSSUB


# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:SOC]) : Close File [SOC] : Endif
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"      [SOH]  : Endif
If clalev([F:SOC])  = 0 : Local File =DOSSIER+".SORDERC"     [SOC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif
# Issue 78997
If [F:ADS]MODULE(5)=2
    If clalev([F:POC])  = 0 : Local File =DOSSIER+".PORDERC" [POC]  : Endif
Endif
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"  [BPS]  : Endif
# Issue 78997

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1, ACLE2, ACLE3
Local Integer ACLE4
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SOC
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:SOC]BPCORD=ACLE1 & [F:SOC]BPAADD=ACLE2 & [F:SOC]SOHNUM=ACLE3 & [F:SOC]SOPLIN>ACLE4"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:SOC]BPCORD=ACLE1 & [F:SOC]BPAADD=ACLE2 & [F:SOC]SOHNUM>ACLE3"
Elsif STOP=3
 STOP = 4
 CRITERE  = "[F:SOC]BPCORD=ACLE1 & [F:SOC]BPAADD>ACLE2"
Elsif STOP=4
 STOP = 0
 CRITERE  = "[F:SOC]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

Trbegin [SOC]
GOK = 1

For [SOC]MIG Where evalue(CRITERE)

  If (dim([F:SOC]BPIEECNUM)<0 | [F:SOC]BPIEECNUM<>'') & [F:SOC]EECICT<>'' & (dim([F:SOC]EECLOC)<0 | [F:SOC]EECLOC<>0)
      Goto SUITE_LOOP_SOC
  Endif
  # Issue 78997
  If [F:SOH]SOHNUM<>[F:SOC]SOHNUM
    Read [F:SOH]SOH0 = [F:SOC]SOHNUM : If fstat Raz [SOH] Endif
  Endif
  # Issue 78997

  # --- alimentation des champs
  Gosub RECUP_BPR_SOC
  # --- alimentation des champs
  Gosub RECUP_BPD_SOC
  # Issue 78997 : Si cde inter-site, alimentation des champs à partir de la cde d'achat
  If [F:ADS]MODULE(5)=2 & [F:SOH]BETFCY=2 & [F:SOH]ORIFCY<>"" & [F:SOH]ORIFCY<>[F:SOH]SALFCY
    Gosub RECUP_POC_SOC
  Endif

  Rewrite [F:SOC]
  If fstat
    Call ECR_TRACE("File SORDERC(SOHNUM/SOPLIN)"-[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)+", ERROR ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SOC]BPCORD
    ACLE2 = [F:SOC]BPAADD
    ACLE3 = [F:SOC]SOHNUM
    ACLE4 = [F:SOC]SOPLIN
    STOP=1
    Break
  Endif

$SUITE_LOOP_SOC
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_SOC
  Endif
Endif

$FIN_X3_SOC
Gosub UNSET_FIRST From TRTFIRST

Close Local File [SOH], [SOC], [BPR], [BPD], [BPS]    : # Bug 78997
If [F:ADS]MODULE(5)=2                                 : # Bug 78997
  Close Local File [POC]                              : # Bug 78997
Endif                                                 : # Bug 78997

Call ECR_TIME("UUMGPRESAL03 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
Return

########################################################################
$RECUP_BPD_SOC

#   Alimentation incoterm si cde ouverte non inter-site         : # Issue 78997
#   Alimentation lieu de transport CEE dans tous les cas        : # Issue 78997
#     If [F:SOC]EECICT="" | (GACTDEB=2 & [F:SOC]EECLOC=0)
      If (([F:SOC]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY))
&       | (GACTDEB=2 & [F:SOC]EECLOC=0))                        : # Issue 78997
          # --- Alimentation incoterm, lieu de transport CEE
          If [F:BPD]BPCNUM<>[F:SOC]BPCORD | [F:BPD]BPAADD<>[F:SOC]BPAADD
              Read [F:BPD]BPD0 = [F:SOC]BPCORD;[F:SOC]BPAADD : If fstat Raz [BPD] Endif
          Endif
          # Issue 78997
          #If [F:SOC]EECICT="" [F:SOC]EECICT=[F:BPD]EECICT Endif
          If [F:SOC]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY)
          # Issue 78997
            [F:SOC]EECICT=[F:BPD]EECICT
          Endif
          If GACTDEB=2 & [F:SOC]EECLOC=0 [F:SOC]EECLOC=[F:BPD]EECLOC Endif
      Endif

Return

# Issue 78997
######################################################################################
# Si cde ouverte inter-site alimentation des champs à partir de la cde ouverte achat #
######################################################################################
$RECUP_POC_SOC

     If [F:SOC]EECICT=""
         # Alimentation incoterm à partir de la cde ouverte d'achat
         If [F:POC]POHNUM<>[F:SOC]CUSORDREF | [F:POC]POPLIN<>[F:SOC]SOPLIN
            Read [F:POC]POC0 = [F:SOC]CUSORDREF;[F:SOC]SOPLIN : If fstat Raz [POC] Endif
         Endif
         [F:SOC]EECICT=[F:POC]EECICT2
         If [F:SOC]EECICT=""
             # Alimentation incoterm à partir du fournisseur
             If [F:BPS]BPSNUM<>[F:POC]BPSNUM
                Read [F:BPS]BPS0 = [F:POC]BPSNUM : If fstat Raz [BPS] Endif
             Endif
             [F:SOC]EECICT=[F:BPS]EECICT
         Endif
     Endif

Return
# Issue 78997

########################################################################
$RECUP_BPR_SOC

      If GACTDEB=2 & [F:SOC]BPIEECNUM=""
          # --- Alimentation n° d'identification CEE
          # Issue 78997
          #If [F:SOH]SOHNUM<>[F:SOC]SOHNUM
          #    Read [F:SOH]SOH0 = [F:SOC]SOHNUM : If fstat Raz [SOH] Endif
          #Endif
          # Issue 78997
          If [F:SOH]BPCINV<>""
              If [F:BPR]BPRNUM<>[F:SOH]BPCINV
                  Read [F:BPR]BPR0 = [F:SOH]BPCINV : If fstat Raz [BPR] Endif
              Endif
              [F:SOC]BPIEECNUM=[F:BPR]EECNUM
          Endif
      Endif

Return
########################################################################
$TRT_SQL_SOC

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SOC]) : Close File [SOC] : Endif
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"      [SOH]  : Endif
If clalev([F:SOC])  = 0 : Local File =DOSSIER+".SORDERC"     [SOC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SOC]
GOK = 1

Gosub TRT_SQL1_SOC

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SOC]
Return
########################################################################
$TRT_SQL1_SOC
Return

