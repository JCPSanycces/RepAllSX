#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "CONT1" : Gosub CONT1
 When "CONT2" : Gosub CONT2
 K = find("tri",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If [M:RPT]PARCOD(nolign-1)="rgndeb"
  If K & [M:RPT]VALEUR1(K-1)=mess(1,10321,1) :# Sélection par code ->pas de controle sur les rangs
    End
  Endif
 Elsif [M:RPT]PARCOD(nolign-1)="rubdeb"
  If K & [M:RPT]VALEUR1(K-1)=mess(2,10321,1) :# Sélection par rang ->pas de controle sur les codes
    End
  Endif
 Endif
Endcase
Return

$CONT1
Local Integer K
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Case [M:RPT]PARCOD(nolign-1)
 When "rubdeb"
  K = find("rngdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   #58774
   #Read [RUB]RUB0=VALPAR
   Read [RUB]RUB0=GCURLEG;VALEUR
   If !fstat
    [M:RPT]VALEUR1(K-1)=num$([F:RUB]ROW)
    [M:RPT]VALINT1(K-1)=num$([F:RUB]ROW)
    Affzo [M:RPT]VALEUR1(K-1)
   Endif
  Endif
 When "rngdeb"
  K = find("rubdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   #58774
   #Read [RUB]RUB1=val(VALPAR)
   Read [RUB]RUB1=GCURLEG;val(VALEUR)
   If !fstat
    [M:RPT]VALEUR1(K-1)=[F:RUB]COD
    [M:RPT]VALINT1(K-1)=[F:RUB]COD
    Affzo [M:RPT]VALEUR1(K-1)
   Endif
  Endif
Endcase
Return

$CONT2
Local Integer K
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Case [M:RPT]PARCOD(nolign-1)
 When "rubdeb"
  K = find("rngdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   #58774
   #Read [RUB]RUB0=VALPAR
   Read [RUB]RUB0=GCURLEG;VALEUR
   If !fstat
    [M:RPT]VALEUR2(K-1)=num$([F:RUB]ROW)
    [M:RPT]VALINT2(K-1)=num$([F:RUB]ROW)
    Affzo [M:RPT]VALEUR2(K-1)
   Endif
  Endif
 When "rngdeb"
  K = find("rubdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   #58774
   #Read [RUB]RUB1=val(VALPAR)
   Read [RUB]RUB1=GCURLEG;val(VALEUR)
   If !fstat
    [M:RPT]VALEUR2(K-1)=[F:RUB]COD
    [M:RPT]VALINT2(K-1)=[F:RUB]COD
    Affzo [M:RPT]VALEUR2(K-1)
   Endif
  Endif
Endcase
Return


Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

