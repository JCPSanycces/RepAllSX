#<AdxTL>@(#)2.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : BRV
#   Fonction : GESBRV - Liste des révisions
#   Action   : GOBJET
#   Ecran concerné : BRV1
#   Description : Définie les révisions passées. La fonction est utilisé
#                 pour lister les demandes de révisions, sorte de consultation
#                 bis des révisions.
#
#--------------------------------------------------------------------------

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "DROIT"    : Gosub DROIT
 When "FILTRE"   : Gosub FILTRE
 When Default
Endcase
Return

$OUVRE
If !clalev([BRV]) : Local File BUDREV    [BRV] : Endif
If !clalev([BVD]) : Local File BUDREVDET [BVD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY    [ENF] : Endif
If !clalev([BUD]) : Local File BUD       [BUD] : Endif
Local Mask BRV1 [BRV1]
Local Integer OKACS
Local Integer INDENV, INDENT, INDCCE3
Return

$DROIT
# Code accès
fstat = 0
If [F:ENV]ENV<>[F:BRV]ENV
 Read [ENV]ENV0 = [F:BRV]ENV
Endif
If !fstat & [F:ENV]ACS<>""
 Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
 If !OKACS
  GMESSAGE = mess(4,104,1)
  CLECUR = 0 : Return
 Endif
Endif
Return


$FILTRE
FILTSUP= '(GUSRACS=2 | [F:ENV]ACS="" | num$([F:ACC]CONSUL)="2")'
Return

$LIENS
Read [BRV]BRV0 = [F:BRV]NUM
If !fstat
 If [F:BRV]TYP=4
  Filter [BVD] Where NUMREV=[F:BRV]NUM
  I=0
  For [BVD]BVD0
   [M:BRV1]LTYP(I)    =[F:BVD]TYP
   [M:BRV1]LENV(I)    =[F:BVD]ENV
   [M:BRV1]LFIY(I)    =[F:BVD]FIY
   [M:BRV1]LACC(I)    =[F:BVD]ACC
   [M:BRV1]LAMT(I)    =[F:BVD]AMT
   [M:BRV1]LAMT(I)    =[F:BVD]AMT
   [M:BRV1]LAMTASK(I) =[F:BVD]AMTASK
   [M:BRV1]LAMTPRS(I) =[F:BVD]AMTPRS
   [M:BRV1]LAMTPNV(I) =[F:BVD]AMTPNV
   [M:BRV1]LAMTRAL(I) =[F:BVD]AMTRAL
   If [F:BVD]TYP=3
    Call LEC_ENV([F:BVD]ENV) From CPTLEC
    Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
    Read [BUD]BUD1=[F:BVD]ACCNUM
    If !fstat
     [M:BRV1]ENTDEN(I)=evalue('[F:BUD]CCE'+num$(INDENT))
    Endif
   Endif
   I+=1
  Next
  [M:BRV1]NBLIG=I
  Affzo [M:BRV1]
  Gosub COLORIZE
 Endif
Endif
Return

$COLORIZE
For I=0 To [M]NBLIG-1
 Chgstl [M]NBLIG(I) With "GDD"+num$([M]LTYP(I))
Next
Affzo [M]
Return
######################################################################################

