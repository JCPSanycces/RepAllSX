#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGCTLXXX00   Contrôle Pre-migration                      Module XX     #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLXXX00") From LECFIC
  Endif
  Call MAJ_UUMGCTLXXX00(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLXXX00(DOSSIER)
Value Char DOSSIER

#Cas1 Pas de controle sur dossier histo
#If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

If [F:ADS]MODULE(N)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLXXX00 Purchase Requests Process : PREQUIS-D") From DOSSUB
Call ECR_TRACE("UUMGCTLXXX00 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  Call ECR_TRACE("UUMGCTLXXX00 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3


Local Integer ERR,COMPTEUR


Gosub CTL1
Gosub CTL2

$FIN
Call ECR_TIME("UUMGCTLXXX00 : Purchase Requests Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

#Cas 2 pas de controle sur les vues
If func DOSVUE.ISVIEW(DOSSIER,"PREQUIS") : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PREQUISD") : Return : Endif

REQSQL(0)="SELECT PSH.PSHNUM_0 FROM "-DOSSIER+".PREQUIS PSH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PREQUISD PSD WHERE PSH.PSHNUM_0=PSD.PSHNUM_0) "
REQSQL(2)="ORDER BY PSH.PSHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PREQUIS without PREQUISD",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PSHNUM="-[BXX]VPSHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

#Cas 2 pas de controle sur les vues
If func DOSVUE.ISVIEW(DOSSIER,"PREQUIS") : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PREQUISD") : Return : Endif

REQSQL(0)="SELECT PSD.PSHNUM_0,PSD.PSDLIN_0 FROM "-DOSSIER+".PREQUISD PSD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PREQUIS PSH WHERE PSH.PSHNUM_0=PSD.PSHNUM_0) "
REQSQL(2)="ORDER BY PSD.PSHNUM_0,PSD.PSDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PREQUISD without PREQUIS",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSHNUM(50),Integer VPSDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PSHNUM/PSDLIN="-[BXX]VPSHNUM+'/'+num$([BXX]VPSDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


