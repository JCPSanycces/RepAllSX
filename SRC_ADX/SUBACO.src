#<AdxTL>@(#)12.0.0.0 $Revision$
Call OBJET("ACO",GBIDC1,GBIDC2) From GOBJET
End

####################
$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
Endcase
Return

########################################
# Action Gtraite ACODIF (Signification)
########################################
$INIT_DIA
Local Char    COD(3)(1..3)
Local File ACODIF [ACO]
Raz [M]
[M]CODE = VALEUR
If find(left$([M]CODE,2),"X_","Y_","Z_")
 [M]CODE = right$([M]CODE,3)
Endif
COD(1) = left$([M]CODE,3)
COD(2) = mid$([M]CODE,4,3)
COD(3) = mid$([M]CODE,7,3)
For I=1 To 3
 If COD(I)<>""
  Read [ACO]ACO0 = COD(I)
  If !fstat
   [M]FRANCAIS += [F:ACO]FREDES+" / "
   [M]ANGLAIS  += [F:ACO]ENGDES+" / "
  Else
   [M]FRANCAIS += "<"+COD(I)+"> "
   [M]ANGLAIS  += "<"+COD(I)+"> "
  Endif
 Endif
Next I
Return

########################################
# Action Seltable SELACO (Codification)
########################################
$SEL_TABLE
Local Char CODIF(30)
CODIF = VALEUR
OBJET = "ACO"
OPTIONS = "|"
ORDRE = "ABB"
START = 'ABB'
Return

$FIN_TABLE
If !find(GSTATUT,GSTAESC,0)
 If VALEUR<>""
  VALEUR = CODIF + VALEUR
 Else
  VALEUR = CODIF
 Endif
Endif
mkstat = 2
Return

########################################
Subprog C_ABB(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]ABB) From OBJDIV
End

Subprog B1_BASTAB
End

Subprog B2_BASTAB
End

Subprog B3_BASTAB
End
