#**
#* Label for getting the availalbe variable rank number for the record
#* @param VREFNUM Local Char(15), contains the employee code
#* @param VCTRNUM Local Char(20), contains the contract number
#* @param VCTRDAT Local Date, contains the contract date
#* @param VEPATYP Local Char(30), contains the payment type
#* @return WRET Local Integer
#*!
Funprog GET_EPAVAR_RANK(VREFNUM,VCTRNUM,VCTRDAT,VEPATYP)
Value Char VREFNUM, VCTRNUM, VEPATYP
Value Date VCTRDAT
Local Integer WRET, I, ADDARRAY,FOUNDRANK,MAXEPA
WRET = 0 : FOUNDRANK = 1

#Getting the maximum number of payments permitted for the payment type
MAXEPA = func EPAFUNCTIONS.GETVARIABLE_RANK(VEPATYP)
###Call DEBUG_TRACE(1, "EPA", "MAXEPA: " + num$(MAXEPA)) From DEBUGTRACE
If MAXEPA = 0 : End WRET : Endif

Local Integer HEARNKPAR(1..MAXEPA)
Local File EPAHEADER      [EPA1]
Local File EPADETAILS     [EPAD1]


Link [EPA1] With [EPAD1]EPADET0 = [F:EPA1]LEG;[F:EPA1]EPACOD
&                  As [EPAJT]
&                  Where [F:EPA1]REFNUM = VREFNUM & [F:EPA1]CTRNUM = VCTRNUM & [F:EPA1]CTRDAT = VCTRDAT & [F:EPAD1]EPATYP = VEPATYP

#Check for available heading rank
ADDARRAY = 0
For [EPAJT]
  ADDARRAY+=1
  If ADDARRAY > MAXEPA : Break : Endif
  HEARNKPAR(ADDARRAY) = [F:EPAD1]HEARNK
Next

For I = 1 To MAXEPA
  FOUNDRANK = find(I, HEARNKPAR)
  If FOUNDRANK = 0 : WRET = I : Break : Endif
Next

###Call DEBUG_TRACE(1, "EPA", "WRET: " + num$(WRET)) From DEBUGTRACE

End WRET

#**
#* Label for getting the maximum number of payment types for the payment type
#* @param PEPATYP Local Char(30), contains the payment type code
#* @return WRET Local Integer
#*!
Funprog GETVARIABLE_RANK(PEPATYP)
Value Char PEPATYP
Local Integer WRET

#Get the maximum number of payments for this type
Local File  EPATYP   [EPATYP]
Filter [F:EPATYP] Where EPATYP = PEPATYP
Read [EPATYP] First
If fstat = [V]CST_AOK
  WRET = [F:EPATYP]MAXEPA
Endif
End WRET

#**
#* Label for getting the variable ranges for payment type
#* @param VEPATYP Local Char(30), contains the payment type code
#* @param VREFNUM Local Char(15), contains the employee code
#* @param VCTRNUM Local Char(20), contains the contract number
#* @param VCTRDAT Local Date, contains the contract date
#* @return WRET Local Integer
#*!
Funprog GETVARIABLE(VEPATYP,VREFNUM,VCTRNUM,VCTRDAT)
Value Char VEPATYP, VREFNUM, VCTRNUM
Value Date VCTRDAT
Value Integer VTYP
Local Integer WRET : WRET = 0

Local File EPASETVAR  [EPASLV]
Local File EMPLOCTR   [CTR]
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File POPULA     [POA]

Filter [F:HRCTR] Where REFNUM = VREFNUM and CTRNUM = VCTRNUM and CTRDAT = VCTRDAT
Read [CTR] First
If fstat <> [V]CST_AOK: End WRET : Endif

##Call DEBUG_TRACE(1, "EPA", "Read [CTR] First fstat: " + num$(fstat)) From DEBUGTRACE
##Call DEBUG_TRACE(1, "EPA", "VEPATYP: " + num$(VEPATYP)) From DEBUGTRACE

Filter [F:EPASLV] Where EPATYP = VEPATYP

For [EPASLV]EPASLV0

  ##Call DEBUG_TRACE(1, "EPA", "[F:EPASLV]REFNUM: " + num$([F:EPASLV]REFNUM)) From DEBUGTRACE

  #Employee
  If [F:HRCTR]REFNUM = [F:EPASLV]REFNUM
  ##Call DEBUG_TRACE(1, "EPA", "Employee") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Contract
  If [F:HRCTR]CTRNUM = [F:EPASLV]CTRNUM
  ##Call DEBUG_TRACE(1, "EPA", "Contract") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Service - Department
  If [F:HRCTR]ETRSRV = [F:EPASLV]SERVICE
  ##Call DEBUG_TRACE(1, "EPA", "Service") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Profile
  If [F:HRCTR]PROPRF = [F:EPASLV]PRFCOD
  ##Call DEBUG_TRACE(1, "EPA", "Profile") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Collective agreement
  If [F:HRCTR]CLLCVT = [F:EPASLV]CLLCVT
  ##Call DEBUG_TRACE(1, "EPA", "Collective agreement") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Site
  If [F:HRCTR]ETRFCY = [F:EPASLV]FCY
  ##Call DEBUG_TRACE(1, "EPA", "Site") From DEBUGTRACE
  WRET = [F:EPASLV]LIGNBR
  Endif

  #Company
   ##Call DEBUG_TRACE(1, "EPA", "[F:HRCTR]ETRFCY: " + num$([F:HRCTR]ETRFCY)) From DEBUGTRACE
  Filter [F:FCY] Where FCY = [F:HRCTR]ETRFCY
  Read [FCY] First
  If fstat = [V]CST_AOK
     ##Call DEBUG_TRACE(1, "EPA", "Company") From DEBUGTRACE
    If [F:FCY]LEGCPY = [F:EPASLV]CPY
      WRET = [F:EPASLV]LIGNBR
    Endif
  Endif

  #Population
  Filter [F:POA] Where REFNUM = [F:HRCTR]REFNUM
  For [POA]POA0
    If [F:POA]COD = [F:EPASLV]POP
      WRET = [F:EPASLV]LIGNBR
    Endif
  Next

  #Matching criteira
  #Get Folder level
  If [F:EPASLV]LEV = 1
    WRET = [F:EPASLV]LIGNBR
  Endif
Next
End WRET

#**
#* Label for getting the variable ranges for payment type
#* @param WCONTAINER Local Instance, contains the collection instance class
#* @param PVARLIG Local Integer, contains the line number from the variable setting
#* @param VEPATYP Local Char(30), contains the payment type code
#* @param VINDEX Local Integer, contains the INDEX of the collection where the update must be done
#* @return WRET Local Integer
#*!
Funprog ASSIGN_VARIABLES(WCONTAINER,PVARLIG,VINDEX)
Variable Instance WCONTAINER Using C_EPAHEADER
Value Integer PVARLIG,VINDEX
Local Integer INDEX,WRET
INDEX = 1
WRET = 0

##Call DEBUG_TRACE(1, "EPA", "ASSIGN_VARIABLES: PVARLIG " + num$(PVARLIG)) From DEBUGTRACE

Local File EPASETVAR  [EPASLV]
Filter [F:EPASLV] Where EPATYP = WCONTAINER.EPADETAILS.EPATYP and LIGNBR = PVARLIG
Read [EPASLV] First
If fstat = [V]CST_AOK
  WRET = 1
  WCONTAINER.EPADETAILS(INDEX).EPAVARINS         =   [F:EPASLV]INSVAR
  WCONTAINER.EPADETAILS(INDEX).EPAVARBAL         =   [F:EPASLV]BALVAR
  WCONTAINER.EPADETAILS(INDEX).EPAVARADM         =   [F:EPASLV]ADMVAR
  WCONTAINER.EPADETAILS(INDEX).EPAVARADDPAY      =   [F:EPASLV]ADDPAYVAR
Endif
End WRET

#FRLAA 2018-06-25 X3-89704 - START
#Funprog CALC_EPA(VEMOIPAY,VBALPAY, VMTHINSPAY, VVMTHINSFIX, VVADMFIX, VADMCOSTPAY, VADDPAY, VPAYVAL, VTOTPAY, VEPACOD, VREFNUM,VCTRNUM, VCTRDAT, VPERCOUNT, ADMCOSTSPD, INSSPD,BALFLG,VLEG)
Funprog CALC_EPA(VURMOIPAY,VEMOIPAY,VBALPAY, VMTHINSPAY, VVMTHINSFIX, VVADMFIX, VADMCOSTPAY, VADDPAY, VPAYVAL, VTOTPAY, VEPACOD, VREFNUM,VCTRNUM, VCTRDAT, VPERCOUNT, ADMCOSTSPD, INSSPD,BALFLG,
& CTR_PAYADM,CTR_PAYINS,CTR_PAYADD,VLEG)
Value Date VURMOIPAY
Variable Decimal CTR_PAYINS, CTR_PAYADM,CTR_PAYADD
Value Char VEPACOD,VREFNUM,VCTRNUM,VLEG
#FRLAA 2018-06-25 X3-89704 - END
Value Date VEMOIPAY,VCTRDAT
#Value Char VEPACOD,VREFNUM,VCTRNUM,VLEG #FRLAA 2018-06-25 X3-89704
Value Integer VPERCOUNT,BALFLG
Variable Decimal VVADMFIX
Value Decimal VVMTHINSFIX
Variable Decimal VBALPAY, VMTHINSPAY, VADMCOSTPAY, VADDPAY, VPAYVAL, VTOTPAY,ADMCOSTSPD, INSSPD
Local Integer PINSFLGRET,PADMFLGRET,PWRITEFLGRET,PRANKNBR, PINSBAL, WRET
Local Decimal PADDPAYRET,PAYINS,PAYADM,PAYADD,PAYTOTINS
Local Decimal PAYINSPREV,PAYADMPREV,PAYADDPREV,PAYTOTINSPREV
Local Decimal PAYTOTDIFF,INSDIFF,ADMDIFF
Local Decimal MTHINSFIX, BALFIX,ADMFIX
Local Decimal ADMTYP,ADDRATE
Local Decimal ADMCHECK


#FRLAA 2018-06-25 X3-89704 - START
Local Decimal CTRPAYINS, CTRPAYADM,CTRPAYADD
Local Decimal CTR_PAYTOTINS
Raz CTR_PAYINS, CTR_PAYADM,CTR_PAYADD
#FRLAA 2018-06-25 X3-89704 - END

#Get the suspension settings for the period
PWRITEFLGRET = func EPAFUNCTIONS.GET_SUSPENSION(VEMOIPAY, VEPACOD, PINSFLGRET,PADMFLGRET)

#Get the additional payments for the period
VADDPAY = func EPAFUNCTIONS.GET_ADDITIONAL(VEMOIPAY, VEPACOD)

#Get the actual payroll payments
#If PRANKNBR is 0, there will not be any payments to show and will only cause admcost to accumulate but we will let the simulation continue
PRANKNBR = func EPAFUNCTIONS.GET_TOTPAYROLL(VREFNUM, VCTRNUM, VCTRDAT, VEMOIPAY, VEPACOD, PAYINS, PAYADM, PAYADD, PAYTOTINS)

#FRLAA 2018-06-25 X3-89704 - START
#Getting all current contract values with the same Chrono in the same month
PRANKNBR = func EPAFUNCTIONS.GET_TOTPAYROLL_CURMULTI(VURMOIPAY,VREFNUM, VCTRNUM, VCTRDAT, VEMOIPAY, VEPACOD, CTRPAYINS, CTRPAYADM, CTRPAYADD, CTR_PAYTOTINS)
#FRLAA 2018-06-25 X3-89704 - END

#Get the actual payments for the previous payroll period to check if the raised liability has been paid - else we will add it to the current payment liability
#The function GET_TOTPAYROLL_PREV does in some instances the same as function GET_TOTPAYROLL but it must function on its own and not depend on the result(s) of other functions!
#The function can also only be called from the second period. there will not be any previous value in the first month.
If VPERCOUNT > 1
 PRANKNBR = func EPAFUNCTIONS.GET_TOTPAYROLL_PREV(VREFNUM, VCTRNUM, VCTRDAT, VEMOIPAY, VEPACOD, PAYINSPREV, PAYADMPREV, PAYADDPREV, PAYTOTINSPREV)
 ###Call DEBUG_TRACE(1, "EPA", "PRANKNBR: " + num$(PRANKNBR)) From DEBUGTRACE
  #After getting the current previous payments, the difference between the payments and liability
  #In the first period, these values will all be 0, as the liability has not been raised yet, neither has the actual previous payment been stored
  If VADMCOSTPAY<>PAYADMPREV
    ADMDIFF     = VADMCOSTPAY-PAYADMPREV
  Endif
  If VVMTHINSFIX<>PAYINSPREV
    INSDIFF     = VVMTHINSFIX-PAYINSPREV
  Endif
  PAYTOTDIFF  = PAYTOTDIFF+ADMDIFF+INSDIFF
  #Store the administration cost difference to the running total
  #VADMCOSTPAY +=ADMDIFF

  #Store the difference only for fixed deductions
  If BALFLG <> 2
    VMTHINSPAY += INSDIFF
  Endif
  ###Call DEBUG_TRACE(1, "EPA", "ADMDIFF: " + num$(ADMDIFF)) From DEBUGTRACE
  ###Call DEBUG_TRACE(1, "EPA", "INSDIFF: " + num$(INSDIFF)) From DEBUGTRACE
  ###Call DEBUG_TRACE(1, "EPA", "PAYTOTDIFF: " + num$(PAYTOTDIFF)) From DEBUGTRACE
Endif

#Calculate the balance if the payment is linked to a balance
#This calculation is needed before calculating the admin cost
If BALFLG = 2
  If ar2(VBALPAY) <> 0
    VBALPAY -= (PAYINSPREV+PAYADDPREV)
  Endif
Endif

###Call DEBUG_TRACE(1, "EPA", "VBALPAY: " + num$(VBALPAY)) From DEBUGTRACE

#Calculate the admin cost
Local File EPADETAILS [EPADET]
Filter [EPADET] Where EPACOD = VEPACOD
Read [EPADET] First
If !fstat
  ADMTYP       = [F:EPADET]ADMCST
  ADDRATE     = [F:EPADET]ADMVAL
Endif

ADMFIX = func EPAFUNCTIONS.ADMCOST(VEMOIPAY,VREFNUM,VCTRNUM,VCTRDAT,ADDRATE,ADMTYP,VVMTHINSFIX,VBALPAY,BALFLG,VLEG)
VVADMFIX = ADMFIX
###Call DEBUG_TRACE(1, "EPA", "VVADMFIX: " + num$(VVADMFIX)) From DEBUGTRACE
#Need to sore the value for the first month as the value gets calculated in the function and not received as a parameter
If VPERCOUNT = 0
  VADMCOSTPAY = ADMFIX
Else
  VADMCOSTPAY=ADMFIX+ADMDIFF
Endif

#Applying suspensionon admincost
If BALFLG = 2
  If PADMFLGRET = 2
    #Write-off
    If PWRITEFLGRET = 2
      ADMCOSTSPD += 0
      VADMCOSTPAY = 0
    Else
      ADMCOSTSPD += VADMCOSTPAY
      VADMCOSTPAY = 0
    Endif
    #Check the balance
    If ar2(VBALPAY)<=0
      VADMCOSTPAY += ADMCOSTSPD
      ADMCOSTSPD = 0
    Endif
  Else
    VADMCOSTPAY += ADMCOSTSPD
    ADMCOSTSPD = 0
  Endif
Else
  If PADMFLGRET = 2
    If PWRITEFLGRET = 2
      ADMCOSTSPD += 0
      VADMCOSTPAY = 0
    Else
      ADMCOSTSPD += VADMCOSTPAY
      VADMCOSTPAY = 0
    Endif
  Else
    VADMCOSTPAY += ADMCOSTSPD
    ADMCOSTSPD = 0
  Endif
Endif

#Installment
#Be careful here, we need to check if there is a balance first, if there is a balance, the suspension will only apply on a write-off
#If it is a fixed deductions, we need to apply the suspension and keep the value in memory
If PINSFLGRET = 2
  If PWRITEFLGRET = 2
    INSSPD += 0
  Else
    If BALFLG = 2
      #Reducing balance apply, no need to store the suspended amount
      INSSPD +=0
    Else
      #Fixed deduction, need to store the suspended value
      #The first time we suspend we suspend the full installemnt and any payment corrections
      If INSSPD > 0
        INSSPD += VVMTHINSFIX
      Else
        INSSPD += VMTHINSPAY
      Endif
    Endif
  Endif
  VMTHINSPAY = 0
Else
  If BALFLG <> 2
   VMTHINSPAY += INSSPD
   Else
    VMTHINSPAY=VVMTHINSFIX
   Endif
  INSSPD = 0
Endif


#We need to check if there is a reducing balance - if it is a fixed installment we let the calculation continue, else we need to handle the balance
If BALFLG = 2
  #Check balance and admin values
  If ar2(VBALPAY+VADMCOSTPAY) = 0  : End 1 : Endif
  If ar2(VBALPAY) <= 0 #The payments theoretically done - we need to make sure there are no suspended admcosts
    #First, we might have to make corrections on over payments
    #Add the negative value against the installment as a refund
    VMTHINSPAY = VBALPAY
    #Set the balance to zero - correction done
    VBALPAY = 0
  Elsif VBALPAY > 0 and VMTHINSPAY > VBALPAY
    VMTHINSPAY = VBALPAY
  Endif
Endif

If VMTHINSPAY < 0
  VADMCOSTPAY = 0
Endif

VPAYVAL = PAYINS+PAYADM+PAYADD
VTOTPAY = VADMCOSTPAY+VMTHINSPAY+VADDPAY

CTR_PAYINS=CTRPAYINS
CTR_PAYADM=CTRPAYADM
CTR_PAYADD=CTRPAYADD

End WRET

#**
#* Label for getting the suspension settings for the period - GMOIPAY
#* @param VMOIPAY Local date, contains the current payroll paymonth
#* @param VEPACOD Local Char(30), contains the unique payment code for the employee
#* @param VINSFLG Local Integer, returns the suspension status of the installment amount for the period
#* @param VADMFLG Local Integer, returns the suspension status of the administration amount for the period
#* @return WRET Local Integer,returns the suspension status of the write-off for the period
#*!
Funprog GET_SUSPENSION(VMOIPAY,VEPACOD,VINSFLG,VADMFLG)
Variable Integer VINSFLG,VADMFLG
Value Date VMOIPAY
Value Char VEPACOD
Local Integer WRET, VWRITEFLG
Local File EPASUSPEND [EPASPD]

Filter [F:EPASPD] Where EPACOD = VEPACOD
For [EPASPD]EPASPD0
  If VMOIPAY <= eomonth([F:EPASPD]DATFINSPD) and VMOIPAY >= [F:EPASPD]DATDEBSPD
    #Suspension setting found
    #Check which setting(s) and apply to the variables
    If [F:EPASPD]ACPFLG = 2
      #The suspension is accepted - apply settings
      If VINSFLG <> 2     : VINSFLG     = [F:EPASPD]INSFLG      : Endif
      If VADMFLG <> 2     : VADMFLG     = [F:EPASPD]ADMCSTFLG   : Endif
      If VWRITEFLG <> 2   : VWRITEFLG   = [F:EPASPD]WROFLG      : Endif
      WRET      = VWRITEFLG
    Endif
  Endif
Next

End WRET

#**
#* Label for getting the additional payments for the period - GMOIPAY
#* @param VMOIPAY Local date, contains the current payroll paymonth
#* @param VEPACOD Local Char(30), contains the unique payment code for the employee
#* @return ADDPAY Local decimal
#*!
Funprog GET_ADDITIONAL(VMOIPAY,VEPACOD)
Value Date VMOIPAY
Value Char VEPACOD
Local Decimal ADDPAY
Local File EPAADDPAY  [EPAADP]

#Checking if there are any additional payments for the period
Filter [F:EPAADP] Where EPACOD = VEPACOD
For [EPAADP]EPAADP0
  If VMOIPAY <= eomonth([F:EPAADP]DATFIN) and VMOIPAY >= [F:EPAADP]DATDEB
    ADDPAY  += [F:EPAADP]AMT
  Endif
Next

End ADDPAY

Funprog GET_TOTPAYROLL(FREFNUM,FCTRNUM,FCTRDAT,PAYMON,FEPACOD,FPAYINS,FPAYADM,FPAYADD,FPAYTOTINS)
Value Char FREFNUM,FCTRNUM,FEPACOD
Variable Decimal FPAYTOTINS,FPAYINS,FPAYADM,FPAYADD
Value Date FCTRDAT,PAYMON
Local Char VAR_INS(GLONVRA),VAR_BAL(GLONVRA), VAR_ADM(GLONVRA), VAR_ADDPAY(GLONVRA)
Local Integer RNKNBR


#Get the variable code(s)
RNKNBR = func EPAFUNCTIONS.RET_EPA_VARIABLES(VAR_INS, VAR_BAL, VAR_ADM, VAR_ADDPAY, FEPACOD)
If RNKNBR = 0
  #Can't continue no variable range
  End RNKNBR
Endif


#Getting the Payroll payments from the variable table
Local File VALEMP [VEP]
Local File VALEUR [VLA]

#FRLAA 2018-06-25 X3-89704 - START
#Filter [F:VEP] Where EMP=FREFNUM & CTRNUM=FCTRNUM & CTRDAT = FCTRDAT & eomonth(PYRMON) = eomonth(PAYMON)
Filter [F:VEP] Where EMP=FREFNUM & CTRNUM=FCTRNUM & eomonth(PYRMON) = eomonth(PAYMON)
#FRLAA 2018-06-25 X3-89704 - END
Read [VEP]VEP0 First
If !fstat
  Filter [F:VLA] Where EMP = FREFNUM & BUL = [F:VEP]BUL & TYP = 4  & DAT = [F:VEP]PYRDAT
  For [F:VLA]VLA0
    If VAR_INS <>""     : If [F:VLA]VARCOD = VAR_INS+num$(RNKNBR)       : FPAYINS     = [F:VLA]VARVAL : Endif : Endif
    If VAR_ADM <>""     : If [F:VLA]VARCOD = VAR_ADM+num$(RNKNBR)      : FPAYADM     = [F:VLA]VARVAL : Endif : Endif
    If VAR_ADDPAY <>""  : If [F:VLA]VARCOD = VAR_ADDPAY+num$(RNKNBR)   : FPAYADD     = [F:VLA]VARVAL : Endif : Endif
  Next
Endif
Filter [F:VLA]
FPAYTOTINS     =  FPAYINS+FPAYADM+FPAYADD
End RNKNBR

Funprog GET_TOTPAYROLL_PREV(FREFNUM,FCTRNUM,FCTRDAT,PAYMON,FEPACOD,FPAYINSPREV,FPAYADMPREV,FPAYADDPREV,FPAYTOTINSPREV)
Value Char FREFNUM,FCTRNUM,FEPACOD
Variable Decimal FPAYTOTINSPREV,FPAYINSPREV,FPAYADMPREV,FPAYADDPREV
Value Date FCTRDAT,PAYMON
Local Char VAR_INS(GLONVRA),VAR_BAL(GLONVRA), VAR_ADM(GLONVRA), VAR_ADDPAY(GLONVRA)
Local Integer RNKNBR


#Get the variable code(s)
RNKNBR = func EPAFUNCTIONS.RET_EPA_VARIABLES(VAR_INS, VAR_BAL, VAR_ADM, VAR_ADDPAY, FEPACOD)
If RNKNBR = 0
  #Can't continue no variable range
  End RNKNBR
Endif


#Getting the Payroll payments from the variable table
Local File VALEMP [VEP]
Local File VALEUR [VLA]

#FRLAA 2018-06-25 X3-89704 - START
Filter [F:VEP] Where EMP=FREFNUM & CTRNUM=FCTRNUM & eomonth(PYRMON) = eomonth(addmonth(PAYMON,-1))
#Filter [F:VEP] Where EMP=FREFNUM & CTRNUM=FCTRNUM & CTRDAT = FCTRDAT & eomonth(PYRMON) = eomonth(addmonth(PAYMON,-1))
#FRLAA 2018-06-25 X3-89704 - END
Read [VEP]VEP0 First
If !fstat
  Filter [VLA] Where EMP = FREFNUM & BUL = [F:VEP]BUL & TYP = 4  & DAT = [F:VEP]PYRDAT
  For [F:VLA]VLA0
    If VAR_INS <>""     : If [F:VLA]VARCOD = VAR_INS+num$(RNKNBR)     : FPAYINSPREV     = [F:VLA]VARVAL : Endif : Endif
    If VAR_ADM <>""     : If [F:VLA]VARCOD = VAR_ADM+num$(RNKNBR)     : FPAYADMPREV     = [F:VLA]VARVAL : Endif : Endif
    If VAR_ADDPAY <>""  : If [F:VLA]VARCOD = VAR_ADDPAY+num$(RNKNBR)  : FPAYADDPREV     = [F:VLA]VARVAL : Endif : Endif
  Next
Endif
###Call DEBUG_TRACE(1, "EPA", "Read [VEP]VEP0 First fstat: " + num$(fstat)) From DEBUGTRACE
Filter [F:VLA]
FPAYTOTINSPREV     =  FPAYINSPREV+FPAYADMPREV+FPAYADDPREV
End RNKNBR

#FRLAA 2018-06-25 X3-89704 - START
Funprog GET_TOTPAYROLL_CURMULTI(PURMOIPAY,FREFNUM,FCTRNUM,FCTRDAT,PAYMON,FEPACOD,C_FPAYINS,C_FPAYADM,C_FPAYADD,C_FPAYTOTINS)
Value Char FREFNUM,FCTRNUM,FEPACOD
Variable Decimal C_FPAYTOTINS,C_FPAYINS,C_FPAYADM,C_FPAYADD
Value Date FCTRDAT,PAYMON, PURMOIPAY
Local Char VAR_INS(GLONVRA),VAR_BAL(GLONVRA), VAR_ADM(GLONVRA), VAR_ADDPAY(GLONVRA)
Local Integer RNKNBR

If eomonth(PURMOIPAY) <> eomonth(PAYMON)
 End RNKNBR
Endif
#Get the variable code(s)
RNKNBR = func EPAFUNCTIONS.RET_EPA_VARIABLES(VAR_INS, VAR_BAL, VAR_ADM, VAR_ADDPAY, FEPACOD)
If RNKNBR = 0
  #Can't continue no variable range
  End RNKNBR
Endif


#Getting the Payroll payments from the variable table
Local File VALEMP [VEP]
Local File VALEUR [VLA]


Filter [F:VEP] Where EMP=FREFNUM & CTRNUM=FCTRNUM & CTRDAT < FCTRDAT & eomonth(PYRMON) = eomonth(PAYMON)
For [F:VEP]VEP0
    Filter [F:VLA] Where EMP = FREFNUM & BUL = [F:VEP]BUL & TYP = 4  & DAT = [F:VEP]PYRDAT
    For [F:VLA]VLA0
      If VAR_INS <>""     : If [F:VLA]VARCOD = VAR_INS+num$(RNKNBR)       : C_FPAYINS     = C_FPAYINS+[F:VLA]VARVAL : Endif : Endif
      If VAR_ADM <>""     : If [F:VLA]VARCOD = VAR_ADM+num$(RNKNBR)       : C_FPAYADM     = C_FPAYADM+[F:VLA]VARVAL : Endif : Endif
      If VAR_ADDPAY <>""  : If [F:VLA]VARCOD = VAR_ADDPAY+num$(RNKNBR)    : C_FPAYADD     = C_FPAYADD+[F:VLA]VARVAL : Endif : Endif
    Next
  Filter [F:VLA]
Next

C_FPAYTOTINS     =  C_FPAYINS+C_FPAYADM+C_FPAYADD
Filter [F:VEP]
End RNKNBR
#FRLAA 2018-06-25 X3-89704 - END

Funprog RET_EPA_VARIABLES(SVARINS,SVARBAL,SVARADM,SVARADDPAY,SEPACOD)
Variable Char SVARINS,SVARBAL,SVARADM,SVARADDPAY,SEPACOD
Local Integer RANKNBR
Local File EPADETAILS [EPADET2]
Filter [EPADET2] Where EPACOD = SEPACOD
Read [EPADET2] First
If !fstat
  SVARINS       = [F:EPADET2]EPAVARINS
  SVARBAL       = [F:EPADET2]EPAVARBAL
  SVARADM       = [F:EPADET2]EPAVARADM
  SVARADDPAY    = [F:EPADET2]EPAVARADDPAY
  RANKNBR       = [F:EPADET2]HEARNK
Endif
End RANKNBR




$INI_VARIABLES
Return

$OPEN_TABLES
Local File EMPLOCTR       [CTR1]
Local File FACILITY       [FCY1]
If clalev([F:HRLSET])   = 0 : Local File HRLSETTING     [HRLSET]          : Endif
If clalev([F:HSP])      = 0 : Local File HISTOPAYE      [HSP]             : Endif
If clalev([F:VEP])      = 0 : Local File VALEMP         [VEP]             : Endif
If clalev([F:HRLHEA])   = 0 : Local File HRLHEADER      [HRLHEA]          : Endif
If clalev([F:HRLDET])   = 0 : Local File HRLDETAILS     [HRLDET]          : Endif
If clalev([F:HRLGPP])   = 0 : Local File HRLGENPAY      [HRLGPP]          : Endif
If clalev([F:EPASPD])   = 0 : Local File EPASUSPEND   [EPASPD]          : Endif
If clalev([F:HRLADP])   = 0 : Local File HRLOAADDPAY    [HRLADP]          : Endif
If clalev([F:VLA])      = 0 : Local File VALEUR         [VLA]             : Endif
Return

Funprog GET_INSTALLMENT(PEPACOD, VMTHINSFIX, VBALFIX)
Value Char PEPACOD
Variable Decimal VMTHINSFIX, VBALFIX
Local Integer WRET
Local File EPADETAILS [EPADET]
Filter [EPADET] Where EPACOD = PEPACOD
Read [EPADET] First
If !fstat
  WRET = 1
  VMTHINSFIX      = [F:EPADET]MTHINS
  VBALFIX         = [F:EPADET]EPABAL
Endif

End WRET


Funprog ADMCOST(PAYDAT,VREFNUM,VCTRNUM,VCTRDAT,ADDRATE2,ADMTYP,MTHINS,VBALPAY,VBALFLG,VLEG)
Value Date PAYDAT,VCTRDAT
Value Char VREFNUM,VCTRNUM,VLEG
Value Integer ADMTYP,VBALFLG
Value Decimal ADDRATE2,MTHINS,VBALPAY
Local Char VCPY(GLONCPY),VFCY(GLONFCY)
Local Decimal ADMCOSTRET, TOTADMRATE
Local Integer TYPVAL

#Call DEBUG_TRACE(1, "EPA", "VCTRNUM: " + num$(VCTRNUM)) From DEBUGTRACE
#Call DEBUG_TRACE(1, "EPA", "VCTRDAT: " + num$(VCTRDAT)) From DEBUGTRACE

#Calculating the administration cost for the period
If ADMTYP < 2 : End 0 : Endif                 #Without

#If the payment is linked to a balance, check if the balance value
If ((VBALFLG = 2) and (ar2(VBALPAY)) = 0)
  #No admin cost must be calculated
  End 0
Endif

#Store VCPY and VFCY
Local File EMPLOCTR [HRCTR1]
Read [HRCTR1]CTR0 = VREFNUM;VCTRNUM;VCTRDAT
If !fstat
  VFCY = [F:HRCTR1]ETRFCY
  If VFCY <> ""
    Local File FACILITY [FCY1]
    Read [FCY1]FCY0 = VFCY
    If !fstat
      VCPY = [F:FCY1]LEGCPY
    Endif
  Endif
Endif

If ADMTYP = 2
  TYPVAL = 7
Elsif ADMTYP = 3
  TYPVAL = 5
Else
  TYPVAL = 0
Endif

####Call DEBUG_TRACE(1, "EPA", "TYPVAL: " + num$(TYPVAL)) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "eomonth(PAYDAT): " + num$(eomonth(PAYDAT))) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "VLEG: " + num$(VLEG)) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "VCPY: " + num$(VCPY)) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "VFCY: " + num$(VFCY)) From DEBUGTRACE

TOTADMRATE = func EPAFUNCTIONS.GET_RATE(TYPVAL,eomonth(PAYDAT),VLEG, VCPY,VFCY)

####Call DEBUG_TRACE(1, "EPA", "TOTADMRATE: " + num$(TOTADMRATE)) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "ADDRATE2: " + num$(ADDRATE2)) From DEBUGTRACE
####Call DEBUG_TRACE(1, "EPA", "MTHINS: " + num$(MTHINS)) From DEBUGTRACE

TOTADMRATE += ADDRATE2



If ADMTYP = 2                                                  #Fixed amount
  If MTHINS > 0 and TOTADMRATE > 0
    ADMCOSTRET = MTHINS*TOTADMRATE/100
  Endif
Elsif ADMTYP = 3
  If TOTADMRATE > 0
    ADMCOSTRET = TOTADMRATE
  Else
    ADMCOSTRET = 0
  Endif
Endif

####Call DEBUG_TRACE(1, "EPA", "ADMCOSTRET: " + num$(ADMCOSTRET)) From DEBUGTRACE

End ADMCOSTRET

Funprog GET_RATE(RATETYP,FORDATE,VLEG,VCPY,VFCY)
Value Integer RATETYP
Value Date FORDATE
Value Char VCPY,VFCY,VLEG
Local Decimal EPARAT
If FORDATE = [00/00/00] : FORDATE = GMOIPAY : Endif
Local File EPARATD [EPARATD]
If RATETYP =0 : End 0 : Endif

#Getting the standard rates for each type
#Checking the criteria first
If VFCY <> ""
  Filter [F:EPARATD] Where LEG = VLEG and FCY = VFCY and EPARATTYP = RATETYP and EFFDAT < eomonth(FORDATE) Order By Key EPARATD1  = EFFDAT Desc
  Read [EPARATD] First
  If !fstat
    EPARAT = [F:EPARATD]EPARATVAL
    End EPARAT
  Endif
Endif
Filter [F:EPARATD]

If VCPY <> ""
  Filter [F:EPARATD] Where LEG = VLEG and CPY = VCPY and EPARATTYP = RATETYP and EFFDAT < eomonth(FORDATE) Order By Key EPARATD1  = EFFDAT Desc
  Read [EPARATD] First
  If !fstat
    EPARAT = [F:EPARATD]EPARATVAL
    End EPARAT
  Endif
Endif
Filter [F:EPARATD]

Filter [F:EPARATD] Where LEG = VLEG and CPY = "" and FCY = "" and EPARATTYP = RATETYP and EFFDAT < eomonth(FORDATE) Order By Key EPARATD1  = EFFDAT Desc
Read [EPARATD] First
If !fstat
  EPARAT = [F:EPARATD]EPARATVAL
Endif

End EPARAT


Funprog EPAPAYPLAN(VMOIPAY,VFILTER)
Value Date VMOIPAY
Value Char VFILTER
Local Date EMOIPAY
Local Decimal BALPAY, MTHINSPAY, ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY,ADMSPD,INSSPD,MTHINSFIX,ADMFIX
Local Char REFNUM(GLONEML), CTRNUM(GLONHRCTR), EPACOD(GLONEPA), LEG(20)
Local Date CTRDAT
Local Integer PERCOUNT,BALFLG, ERROR_COUNT,RECORDSCREATE
Local Decimal PCTR_PAYADM,PCTR_PAYINS,PCTR_PAYADD #FRLAA 2018-06-25 X3-89704

#####Call DEBUG_TRACE(1, "EPA", "Test") From DEBUGTRACE

If clalev([F:EPAHEA])     = 0 : Local File EPAHEADER        [EPAHEA]          : Endif
If clalev([F:EPADET])     = 0 : Local File EPADETAILS       [EPADET]          : Endif
If clalev([F:EPASPD])     = 0 : Local File EPASUSPEND       [EPASPD]          : Endif
If clalev([F:EPAADP])     = 0 : Local File EPAADDPAY        [EPAADP]          : Endif
If clalev([F:HRCTR])        = 0 : Local File EMPLOCTR         [HRCTR]          : Endif
If clalev([F:EPAGPP])     = 0 : Local File EPAGENPAY        [EPAGPP]          : Endif
If clalev([F:FCY])        = 0 : Local File FACILITY         [FCY]             : Endif

#Opening the trace file
TIT = mess(0004,10661,1) - num$(VMOIPAY)
Call OUVRE_TRACE(TIT) From LECFIC

#Setting the heading
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

#Clear the temp table
Lock [EPAGPP]
If fstat=0
  Delete [EPAGPP] Where EPACOD >= ""
  Unlock [EPAGPP]
Endif

#Transaction start on EPAGPP
Trbegin [EPAGPP]
#####Call DEBUG_TRACE(1, "EPA", "Trbegin [EPAGPP]") From DEBUGTRACE
#####Call DEBUG_TRACE(1, "EPA", "VFILTER: " + num$(VFILTER)) From DEBUGTRACE
#Loop through all the active loans
Link [EPAHEA] With  [EPADET]EPADET0   = [F:EPAHEA]LEG;[F:EPAHEA]EPACOD,
&                   [HRCTR]CTR0       = [F:EPAHEA]REFNUM;[F:EPAHEA]CTRNUM;[F:EPAHEA]CTRDAT,
&                   [FCY]FCY0         = [F:HRCTR]ETRFCY
&                  As [EPAC]
&                  Where [F:EPADET]STRDAT <= eomonth(VMOIPAY) and evalue(VFILTER) and [F:EPADET]MTHINS <> 0


For [EPAC]
  #Assign all the variables for the calculation function
  #####Call DEBUG_TRACE(1, "EPA", "[F:EPAHEA]REFNUM: " + num$([F:EPAHEA]REFNUM)) From DEBUGTRACE
  BALFLG      = [F:EPADET]BALFLG
  BALPAY      = [F:EPADET]EPABAL
  REFNUM      = [F:EPAHEA]REFNUM
  CTRNUM      = [F:EPAHEA]CTRNUM
  CTRDAT      = [F:EPAHEA]CTRDAT
  EPACOD      = [F:EPAHEA]EPACOD
  MTHINSFIX   = [F:EPADET]MTHINS
  MTHINSPAY   = MTHINSFIX
  PERCOUNT    = 1
  LEG         = [F:EPAHEA]LEG

  Raz ADMCOSTPAY
  Raz ADDPAY
  Raz ADMSPD
  Raz INSSPD

  #Set EMOIPAY (Start date of the payment) to the end of the month and start the loop
  EMOIPAY = eomonth([F:EPADET]STRDAT)

  #Start the calculations
  While EMOIPAY <= eomonth(VMOIPAY)
  #FRLAA 2018-06-25 X3-89704 - START
  If func EPAFUNCTIONS.CALC_EPA(VMOIPAY,EMOIPAY, BALPAY, MTHINSPAY, MTHINSFIX, ADMFIX,ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY, EPACOD, REFNUM, CTRNUM, CTRDAT, PERCOUNT, ADMSPD, INSSPD, BALFLG,PCTR_PAYADM
& ,PCTR_PAYINS,PCTR_PAYADD,LEG) <> 1
    #If func EPAFUNCTIONS.CALC_EPA(EMOIPAY, BALPAY, MTHINSPAY, MTHINSFIX, ADMFIX,ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY, EPACOD, REFNUM, CTRNUM, CTRDAT, PERCOUNT, ADMSPD, INSSPD, BALFLG, LEG) <> 1
    #FRLAA 2018-06-25 X3-89704 - END
      If eomonth(EMOIPAY) = eomonth(VMOIPAY)
        #Write the transaction
        Gosub WRITE_EPA
        Break
      Endif
    Endif
    EMOIPAY = eomonth(addmonth(EMOIPAY,1))
    PERCOUNT += 1
  Wend
Next

#Manage the write to the database
Gosub MANAGE_TRN

#Adding all the variables in the temp table to the variable
ERROR_COUNT = 0
#####Call DEBUG_TRACE(1, "EPA", "Gosub SAUVE_VALEURS") From DEBUGTRACE
Gosub SAUVE_VALEURS

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End ERROR_COUNT

$WRITE_EPA
#Check the returned values and make sure that a variable exist for the transaction - else handle the error
#Balance
Call ECR_TRACE(num$(EPACOD),0) From GESECRAN

#Reset the values to zero
If [F:EPAHEA]ACTFLG = 1
  BALPAY = 0
  MTHINSPAY = 0
  ADMCOSTPAY = 0
  ADDPAY = 0
Endif

#If BALPAY <> 0
  #Check the variable
  If [F:EPADET]EPAVARBAL <> ""
    Gosub WRITE_EPA_FIXED
    [F:EPAGPP]EPAVAR = [F:EPADET]EPAVARBAL+num$([F:EPADET]HEARNK)
    [F:EPAGPP]TYP    = 3
    [F:EPAGPP]TYPVAL = BALPAY
    Gosub WRITE_INSTRUCT
  Else
    Call ECR_TRACE(mess(00006,10661,1) -":"-num$(EPACOD) - "-" - num$(mess(00003,10662,1)),0) From GESECRAN
  Endif
#Endif

#Installment
#If MTHINSPAY <> 0
  #Check the variable
  If [F:EPADET]EPAVARINS <> ""
    Gosub WRITE_EPA_FIXED
    [F:EPAGPP]EPAVAR = [F:EPADET]EPAVARINS+num$([F:EPADET]HEARNK)
    [F:EPAGPP]TYP    = 1
    #FRLAA X3-89704 2018-06-26 - START
    [F:EPAGPP]TYPVAL = MTHINSPAY-PCTR_PAYINS
    #[F:EPAGPP]TYPVAL = MTHINSPAY
    #FRLAA X3-89704 2018-06-26 - END
    Gosub WRITE_INSTRUCT
  Else
    Call ECR_TRACE(mess(00006,10661,1) -":"-num$(EPACOD) - "-" - num$(mess(00001,10662,1)),0) From GESECRAN
  Endif
#Endif

#Administration cost
#If ADMCOSTPAY <> 0
  #Check the variable
  If [F:EPADET]EPAVARADM <> ""
    Gosub WRITE_EPA_FIXED
    [F:EPAGPP]EPAVAR = [F:EPADET]EPAVARADM+num$([F:EPADET]HEARNK)
    [F:EPAGPP]TYP    = 2
    #FRLAA X3-89704 2018-06-26 - START
    [F:EPAGPP]TYPVAL = ADMCOSTPAY-PCTR_PAYADM
    #[F:EPAGPP]TYPVAL = ADMCOSTPAY
    #FRLAA X3-89704 2018-06-26 - END
    Gosub WRITE_INSTRUCT
  Else
    Call ECR_TRACE(mess(00006,10661,1) -":"-num$(EPACOD) - "-" - num$(mess(00002,10662,1)),0) From GESECRAN
  Endif
#Endif

#Additional payments
#If ADDPAY <> 0
  #Check the variable
  If [F:EPADET]EPAVARADDPAY <> ""
    Gosub WRITE_EPA_FIXED
    [F:EPAGPP]EPAVAR = [F:EPADET]EPAVARADDPAY+num$([F:EPADET]HEARNK)
    [F:EPAGPP]TYP    = 4
    #FRLAA X3-89704 2018-06-26 - START
    [F:EPAGPP]TYPVAL = ADDPAY-PCTR_PAYADD
    #[F:EPAGPP]TYPVAL = ADDPAY
    #FRLAA X3-89704 2018-06-26 - END
    Gosub WRITE_INSTRUCT
  Else
    Call ECR_TRACE(mess(00006,10661,1) -":"-num$(EPACOD) - "-" - num$(mess(00004,10662,1)),0) From GESECRAN
  Endif
#Endif



Return

$WRITE_EPA_FIXED
#Write the fixed values
Raz [EPAGPP]
[F:EPAGPP]REFNUM      = REFNUM
[F:EPAGPP]CTRNUM      = CTRNUM
[F:EPAGPP]CTRDAT      = CTRDAT
[F:EPAGPP]EPACOD      = EPACOD
[F:EPAGPP]PAYMON      = VMOIPAY
[F:EPAGPP]LEG         = LEG
Return

$WRITE_INSTRUCT
Write [EPAGPP]
If fstat
  ERROR_COUNT = 1
Else
  RECORDSCREATE +=1
Endif
Return

$MANAGE_TRN
If ERROR_COUNT = 1
  Rollback
Else
  #Commit if all write statements successful
  Call ECR_TRACE(mess(00103,00133,1) -":"-num$(RECORDSCREATE),0) From GESECRAN
  Commit
Endif
Return

$SAUVE_VALEURS
GOK=1
 If clalev([F:VEP])=0   : Local File VALEMP     [VEP]   : Endif
 If clalev([F:VEP2])=0  : Local File VALEMP     [VEP2]  : Endif
 If clalev([F:VLA]) = 0 : Local File VALEUR     [VLA]   : Endif

 Trbegin [VLA]
 Filter [F:EPAGPP]
 #FRLAA - 2016-01-11 US tbc
 #####Call DEBUG_TRACE(1, "EPA", "Filter [F:EPAGPP]") From DEBUGTRACE
 For [EPAGPP]EPAGPP0 Where EPAVAR <> ""
  #Checking the status of the payslip before moving the file - skip
  #####Call DEBUG_TRACE(1, "EPA", "EMP: " + num$([F:EPAGPP]REFNUM)) From DEBUGTRACE
  #####Call DEBUG_TRACE(1, "EPA", "[F:EPAGPP]CTRNUM: " + num$([F:EPAGPP]CTRNUM)) From DEBUGTRACE
  #####Call DEBUG_TRACE(1, "EPA", "[F:EPAGPP]CTRDAT: " + num$([F:EPAGPP]CTRDAT)) From DEBUGTRACE
  #####Call DEBUG_TRACE(1, "EPA", "eomonth([F:EPAGPP]PAYMON): " + num$(eomonth([F:EPAGPP]PAYMON))) From DEBUGTRACE
  Filter [F:VEP] #FRLAA 2018-06-25 X3-89704
  Filter [F:VEP] Where EMP=[F:EPAGPP]REFNUM & CTRNUM=[F:EPAGPP]CTRNUM & CTRDAT=[F:EPAGPP]CTRDAT & eomonth(PYRMON) = eomonth([F:EPAGPP]PAYMON)
  Read [VEP]VEP0 First

  If fstat>2 or [F:VEP]PST>1 or [F:VEP]RVS=2 or [F:VEP]FLGLOCK=2
    Filter [VEP]
    #####Call DEBUG_TRACE(1, "EPA", "#Skip transaction: " + num$(fstat)) From DEBUGTRACE
    #Skip transaction
  Else
    #FRLAA 2018-06-25 X3-89704 - START
    #Filter [VLA] Where TYP = 4 & REFNUM = [F:EPAGPP]REFNUM & DAT = [F:VEP]PYRDAT & VARCOD = [F:EPAGPP]EPAVAR & BUL = [F:VEP]BUL
    Filter [VLA] Where TYP = 4 & EMP = [F:EPAGPP]REFNUM & DAT = [F:VEP]PYRDAT & VARCOD = [F:EPAGPP]EPAVAR & BUL = [F:VEP]BUL
    #FRLAA 2018-06-25 X3-89704 - END
    Read [VLA] First
    Filter [F:VLA] #FRLAA 2018-06-25 X3-89704
    If fstat = 0
      Call ECR_TRACE("Updating: " + num$([F:EPAGPP]REFNUM)+"-"+num$([F:VEP]BUL)+"-"+num$([F:EPAGPP]EPAVAR),0) From GESECRAN
      [F:VLA]VARVAL=[F:EPAGPP]TYPVAL
      Rewrite [F:VLA]
    Else
     If [F:EPAGPP]TYPVAL > 0
       Call ECR_TRACE("Creating: " + num$([F:EPAGPP]REFNUM)+"-"+num$([F:VEP]BUL)+"-"+num$([F:EPAGPP]EPAVAR),0) From GESECRAN
       Raz [F:VLA]
       [F:VLA]TYP    = 4
       [F:VLA]BUL    = [F:VEP]BUL
       [F:VLA]EMP    = [F:EPAGPP]REFNUM
       #[F:VLA]FCY    = [F:EPAGPP]FCY
       #[F:VLA]LEG    = [F:EPAGPP]LEG
       #FRLAA correction 2017/05/11 - start
       [F:VLA]DAT    = [F:VEP]PYRDAT
       #[F:VLA]DAT    = [F:EPAGPP]PAYMON
       #FRLAA correction 2017/05/11 - end
       [F:VLA]VARCOD = [F:EPAGPP]EPAVAR
       [F:VLA]VARVAL = [F:EPAGPP]TYPVAL
       Write [F:VLA]
     Else
      fstat = 0
     Endif
    Endif
    If fstat<>0
     GOK = 0 : Call FSTA("VLA") From GLOCK : Break
    Endif
    Readlock [VEP2]VEP5=[F:VEP]BUL
    If !fstat
     [F:VEP2]STA = 1
     Rewrite [F:VEP2]
    Endif
    If fstat<>0
     GOK = 0 : Call FSTA("VEP2") From GLOCK : Break
    Endif
  Endif
Next

  #####Call DEBUG_TRACE(1, "EPA", "GOK: " + num$(GOK)) From DEBUGTRACE
 If GOK<1
  Goto AB_TR :  Return
 Endif
Commit
Return

$AB_TR
Rollback
Return

#FRLAA 2018-06-25 X3-89704 - START
$EPAUPDATE
If clalev([F:EPAHEA])     = 0 : Local File EPAHEADER        [EPAHEA]          : Endif
Update [EPAHEA] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT<[M:CTR0]CTRDAT & ACTFLG = 2
&                With CTRDAT=[M:CTR0]CTRDAT
If fstat
 GOK = 0 : Call FSTA("EPAHEA") From GLOCK : Return
Endif
Return
#FRLAA 2018-06-25 X3-89704 - END

#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - END

