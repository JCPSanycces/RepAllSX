#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_CNTTYP
Onevent INIT_AREA Call D_CNTTYP(zc) From W2HRMAT1
Onevent BEFORE_INPUT Call AS_CNTTYP(zc) From W2HRMAT1
Return

Subprog D_CNTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CNTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CNTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CRYCNT
Onevent CONTROL Call C_CRYCNT(zc) From W2HRMAT1
Onevent BEFORE_INPUT Call AS_CRYCNT(zc) From W2HRMAT1
Onevent AFTER_CHANGE Gosub AMM_CRYCNT From W2HRMAT1
Onevent INIT_AREA Call D_CRYCNT(zc) From W2HRMAT1
Return

Subprog D_CRYCNT(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRYCNT,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_CRYCNT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRYCNT(zc) From W2HRMAT1
Onkey   2 Titled GBOUTS Call S_CRYCNT(zc) From W2HRMAT1
Onkey 144 Titled GBOUTP Call P_CRYCNT(zc) From W2HRMAT1
Onkey 146 Titled GBOUTA Call SA_CRYCNT(zc) From W2HRMAT1
Gosub _AFF
End

Subprog C_CRYCNT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRYCNT" : GZNUM = 263 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TCY","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRYCNT" : GZNUM = 263 : Endif
Endif
Gosub _AFF
End

$AMM_CRYCNT
Call AM_CRYCNT(zc)
If !mkstat & GOBJET
 zoncou = "CRYCNT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRYCNT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCRYCNT)")>indice
 [M]CRYCNT(indice) = VALEUR
 Affzo ZCRYCNT(indice)
Endif
Gosub _AFF
End

Subprog S_CRYCNT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRYCNT(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CRYCNT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRYCNT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCRYCNT
Onevent BEFORE_AREA Gosub AV_ZCRYCNT From W2HRMAT1
Return

$AV_ZCRYCNT
Call LECTEXTRA(zc,"TABCOUNTRY","CRYDES",num$([M]CRYCNT(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TELCNT
Onevent BEFORE_AREA Gosub AV_TELCNT From W2HRMAT1
Onevent CONTROL Call C_TELCNT(zc) From W2HRMAT1
Onevent AFTER_CHANGE Gosub AMM_TELCNT From W2HRMAT1
Return

$AV_TELCNT
## Action FMTTELPAY
Call FMTTELPAY([M]CRYCNT(nolign-1)) From TRTDIV
## Action STD
Call AV_TELCNT(zc) From SUBEML2
If GFMT<>""
 Chgfmt [M]TELCNT(indice) With "K:"+GFMT
Else
 Chgfmt [M]TELCNT(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_TELCNT(VALEUR)
Variable Char    VALEUR()
## Action ACNTTEL
Call CONTTEL(VALEUR,[M]CRYCNT(nolign-1)) From CONTNUM
If mkstat : GERR = 1 : GZONE = "TELCNT" : GZNUM = 289 : Endif
Gosub _AFF
End

$AMM_TELCNT
Call AM_TELCNT(zc)
If !mkstat & GOBJET
 zoncou = "TELCNT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TELCNT(VALEUR)
Variable Char    VALEUR()
## Action ACNTTELMOD
Call CONTTELMOD(VALEUR,[M]CRYCNT(nolign-1)) From CONTNUM
If mkstat : GERR = 1 : GZONE = "TELCNT" : GZNUM = 289 : Endif
Gosub _AFF
End

$ON_MOBCNT
Onevent BEFORE_AREA Gosub AV_MOBCNT From W2HRMAT1
Onevent CONTROL Call C_MOBCNT(zc) From W2HRMAT1
Onevent AFTER_CHANGE Gosub AMM_MOBCNT From W2HRMAT1
Return

$AV_MOBCNT
## Action FMTTELPAY
Call FMTTELPAY([M]CRYCNT(nolign-1)) From TRTDIV
If GFMT<>""
 Chgfmt [M]MOBCNT(indice) With "K:"+GFMT
Else
 Chgfmt [M]MOBCNT(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_MOBCNT(VALEUR)
Variable Char    VALEUR()
## Action ACNTTEL
Call CONTTEL(VALEUR,[M]CRYCNT(nolign-1)) From CONTNUM
If mkstat : GERR = 1 : GZONE = "MOBCNT" : GZNUM = 9564 : Endif
Gosub _AFF
End

$AMM_MOBCNT
Call AM_MOBCNT(zc)
If !mkstat & GOBJET
 zoncou = "MOBCNT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MOBCNT(VALEUR)
Variable Char    VALEUR()
## Action ACNTTELMOD
Call CONTTELMOD(VALEUR,[M]CRYCNT(nolign-1)) From CONTNUM
If mkstat : GERR = 1 : GZONE = "MOBCNT" : GZNUM = 9564 : Endif
Gosub _AFF
End

$CHG_STY
Return


