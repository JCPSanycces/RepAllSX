#<AdxTL>@(#)8.0.0.0 $Revision$
Call PATCH(nomap)
End


Subprog PATCH(APPLI)
Value Char APPLI
If GTYPDBA<>2 : End : Endif : # Que sous SQL
Local File =APPLI+".ATABLE" [ATBX]
If dim([F:ATBX]AUDCRE)>0 & dim([F:ATBX]AUDBI)>0
 For [ATBX] Where [F:ATBX]AUDBI=2 or [F:ATBX]AUDCRE=2 or [F:ATBX]AUDUPD=2 or [F:ATBX]AUDDEL=2
  If GTRACE<>""
   Call ECR_TRACE("Update trigger"-[F:ATBX]CODFIC,0) From GESECRAN
  Endif
  Call MAJTRIG([F:ATBX]CODFIC,APPLI) From VALDIC
 Next ATBX
Endif
Close Local File [ATBX]
End
