#<AdxTL>@(#)3.0.0.0 $Revision$
#################################################
# NETSTO4: Details Netvibes pour le code STO4   #
#             Articles avec indicateurs stock   #
#################################################


#------------#
# Pour tests #
#------------#
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
#-----
Local Char    WMSG(250)
Local Char    COD_OBJ(GLONAOB)
Local Char    CLE_LEC(GLONBPS)
Local Char    CHAMPS_LUS(50)(1..8)
Local Blbfile BLOB_LUS(1)
Local Date DATMIN : DATMIN=date$-28
Local Date DATMAX : DATMAX=date$
#-----
COD_OBJ="STO4"
CLE_LEC="ATS-BOI"
Gosub LECTURE
#-----
WMSG ="Aticle      ="-WWKEYS-+"\"
WMSG+="Consommation ="-CHAMPS_LUS(7)+"\"
WMSG+="Pour la période du"-num$(DATMIN)-"au"-num$(DATMAX)
Call MESSAGE(WMSG) From GESECRAN
#-----
End


#############################################
$ACTION
Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################


#-------------------------------------------------------#
# Sous-programme de description du web service de liste #
#-------------------------------------------------------#
$DESC_LISTE
Return


#---------------------------------------------------------#
# Sous-programme de description du web service de lecture #
#---------------------------------------------------------#
$DESC_LEC
#-----
CODE_CHAMPS(7) ="CONSOM"
#-----
#INTIT_CHAMPS(7)=mess(373,184,1) : # consommation
#-----
TYPE_CHAMPS(7) =4
#-----
LEN_CHAMPS(7)  =9.2
#-----
Return


#-------------------------#
# Sous-programme de liste #
# ----------------------- #
# CHP1 () (1..)   STOFCY  #
# CHP2 () (1..)   ITMREF  #
# CHP3 () (1..)   ITMDES1 #
# CHP4 () (1..)   STU     #
# CHP5 () (1..)   PHYSTO  #
# CHP6 () (1..)   ORDSTO  #
# CHP7 () (1..)   SALSTO  #
# CHP8 () (1..)   REOTSD  #
# CHP9 () (1..)           #
#-------------------------#
$LISTE
#----- Table ITMFACILIT
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
#----- Table ITMMVT
If clalev([F:ITV])=0 : Local File ITMMVT[ITV] : Endif
#-----
Local Decimal P
Local Integer I_E
#-----
For I_E=1 To NB_LIG
    If [F:ITV]STOFCY <> CHP1(I_E)  | [F:ITV]ITMREF <> CHP2(I_E)  
       Read [ITV]ITV0=CHP2(I_E);CHP1(I_E)
    Endif
    If [F:ITF]STOFCY <> CHP1(I_E)  | [F:ITF]ITMREF <> CHP2(I_E)  
       Read [ITF]ITF0=CHP2(I_E);CHP1(I_E) 
    Endif
    Raz P
    P+=CHP5(I_E)+CHP6(I_E) 
    If P > CHP7(I_E)  
       P-=CHP7(I_E)
    Else
       Raz P
    Endif
    If CHP8(I_E) < P 
       CHP9(I_E)="green"
    Else
       CHP9(I_E)="red"
    Endif
Next I_E
#-----
Return

#--------------------------------------------#
# Sous-programme de rafraichissement favoris #
#--------------------------------------------#
$RAFRAICHIR
Gosub LISTE
Return


#----------------------------------#
# Sous-programme de lecture détail #
#----------------------------------#
$LECTURE
#-----
# 28 = 4 semaines * 7 jours
#-----
Local Date DATMIN : DATMIN=date$-28
Local Date DATMAX : DATMAX=date$
#----- Consommation des 4 dernieres semaines -----#
CHAMPS_LUS(7)=num$(func TRTX3FNC.GETCONSOM(WWKEYS,DATMIN,DATMAX))
Return



