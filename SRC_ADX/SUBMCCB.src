#&                                                 & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
#&                                                 & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
#&                                                 & [M:CST]MLNK(indcum)=0) * [M:CST]MOVEMACCST(indcum)) * LCOE0
#        [F:MCC]OVELABCST+= sigma(0,[M:CST]NBMAT-1, ([M:CST]MATREF(indcum)=[M:CST]MATREF(I)
#&                                                 & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
#&                                                 & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
#&                                                 & [M:CST]MLNK(indcum)=0) * [M:CST]MOVELABCST(indcum)) * LCOE0
#        [F:MCC]OVESCOCST+= sigma(0,[M:CST]NBMAT-1, ([M:CST]MATREF(indcum)=[M:CST]MATREF(I)
#&                                                 & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
#&                                                 & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
#&                                                 & [M:CST]MLNK(indcum)=0) * [M:CST]MOVESCOCST(indcum)) * LCOE0
        For K=0 To [M:CST]NBMAT-1
            If [M:CST]MATREF(K)=[M:CST]MATREF(I)
&            & [M:CST]MECCVALMAJ(K)=[M:CST]MECCVALMAJ(I)
&            & [M:CST]MECCVALMIN(K)=[M:CST]MECCVALMIN(I)
                # Issue X3-33390/122498 - 2017-04-17 by ERMIL : Wrong link field used during performance enhancement from above.
                #If [M:CST]MLNK(K)=[M:CST]MLNK(PIND)
                If [M:CST]MLNK(K)=[M:CST]ILNK(PIND)
                  For J=0 To GACTMAT-1
                      [F:MCC]MATCST(J) += [M:CST]MMATCST(K*GACTMAT+J) / LCOELNK
                   Next J
                   For J=0 To GACTMAC-1
                      [F:MCC]MACCST(J) += [M:CST]MMACCST(K*GACTMAC+J) / LCOELNK
                   Next J
                   For J=0 To GACTLAB-1
                      [F:MCC]LABCST(J) += [M:CST]MLABCST(K*GACTLAB+J) / LCOELNK
                   Next J
                   [F:MCC]SCOCST    += [M:CST]MSCOCST(K) / LCOELNK
                   [F:MCC]INVDTACST += [M:CST]MINVDTA(K) / LCOELNK
                   [F:MCC]OVEMATCST += [M:CST]MOVEMATCST(K) / LCOELNK
                   [F:MCC]OVEMACCST += [M:CST]MOVEMACCST(K) / LCOELNK
                   [F:MCC]OVELABCST += [M:CST]MOVELABCST(K) / LCOELNK
                   [F:MCC]OVESCOCST += [M:CST]MOVESCOCST(K) / LCOELNK
                Elsif [M:CST]MLNK(K)=0
                   For J=0 To GACTMAT-1
                      [F:MCC]MATCST(J) += [M:CST]MMATCST(K*GACTMAT+J) * LCOE0
                   Next J
                   For J=0 To GACTMAC-1
                      [F:MCC]MACCST(J) += [M:CST]MMACCST(K*GACTMAC+J) * LCOE0
                   Next J
                   For J=0 To GACTLAB-1
                      [F:MCC]LABCST(J) += [M:CST]MLABCST(K*GACTLAB+J) * LCOE0
                   Next J
                   [F:MCC]SCOCST    += [M:CST]MSCOCST(K) * LCOE0
                   [F:MCC]INVDTACST += [M:CST]MINVDTA(K) * LCOE0
                   [F:MCC]OVEMATCST += [M:CST]MOVEMATCST(K) * LCOE0
                   [F:MCC]OVEMACCST += [M:CST]MOVEMACCST(K) * LCOE0
                   [F:MCC]OVELABCST += [M:CST]MOVELABCST(K) * LCOE0
                   [F:MCC]OVESCOCST += [M:CST]MOVESCOCST(K) * LCOE0
                Endif
            Endif
        Next

        [F:MCC]VLTTOT = sum([F:MCC]MATCST)+sum([F:MCC]MACCST)+sum([F:MCC]LABCST)
&                     + [F:MCC]SCOCST+[F:MCC]INVDTACST+[F:MCC]OVEMATCST+[F:MCC]OVEMACCST+[F:MCC]OVELABCST+[F:MCC]OVESCOCST

        If LEXI
            Rewrite [MCC]
        Else
            [F:MCC]CREDAT=date$
            [F:MCC]CREUSR=GUSER
            Write [MCC]
        Endif
        If fstat
            PRET=1 : Break
        Endif
    Endif
  Endif
Next

If LTRANSAC
    If PRET
        Rollback
    Else
        Commit
    Endif
Endif
If PRET
    ERR_TRA = mess(14,100,1) - [F:MCC]ITMREF - mess(35,197,1)+":"+[F:MCC]MATREF
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    End
Endif

End

###############################################################################
# Enregistrement du détail des opérations (machine, main d'oeuvre et sous-traitance)
###############################################################################
Subprog SAVMCW(PIND,PITM,PYEA,PTYP,PRET)
Value Integer PIND
Value Char    PITM
Value Integer PYEA
Value Integer PTYP
Variable Integer PRET

If !clalev([F:MCW]) : Local File MFCWST [MCW] : Endif

Local Integer I, LEXI
Local Decimal LQTYLIN, LQTYTOT, LCOE

LQTYLIN = func TRTCST.SUMQTY("P",[M:CST]ILNK(PIND))
LQTYTOT = func TRTCST.SUMQTY("P",0)
If LQTYTOT=0
    LCOE = 1
Else
    LCOE = LQTYLIN/LQTYTOT
Endif

Local Integer LTRANSAC : LTRANSAC=0
If adxlog<>1
    LTRANSAC = 1
    Call DEBTRANS From GLOCK
    Trbegin [MCW]
Endif

For I=0 To [M:CST]NBWST-1
    If !find([M:CST]WST(I),[M:CST]WST(0..I-1))
&    & ([M:CST]WLNK(I)=[M:CST]WLNK(PIND) | [M:CST]WLNK(I)=0)
        Readlock [F:MCW]MCW0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]WST(I);adxuid(1)
        If !fstat
            LEXI=1
        Else
            LEXI=0
            Raz [F:MCW]
            [F:MCW]STOFCY = [M:CST0]STOFCY
            [F:MCW]ITMREF = PITM
            [F:MCW]YEA    = PYEA
            [F:MCW]VCRTYP = [M:CTP]VCRTYP
            [F:MCW]VCRNUM = [M:CTP]VCRNUM
            [F:MCW]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCW]MFCTYP = PTYP
            [F:MCW]WST    = [M:CST]WST(I)
            [F:MCW]UID    = adxuid(1)
        Endif

        [F:MCW]WSTTYP = [M:CST]WSTTYP(I)
        [F:MCW]BRDCOD = [M:CST]WBRDCOD(I)
        [F:MCW]WCSTTYP = [M:CST]WCSTTYP(I)
        [F:MCW]RATCOD = [M:CST]WRATCOD(I)
        [F:MCW]SETCST = [M:CST]WSETCST(I)
        [F:MCW]SETTIM = sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]WSETTIM(indcum))
        [F:MCW]SETTIM+= sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=0) * [M:CST]WSETTIM(indcum)) * LCOE
        [F:MCW]OPECST = [M:CST]WOPECST(I)
        [F:MCW]OPETIM = sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]WOPETIM(indcum))
        [F:MCW]OPETIM+= sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=0) * [M:CST]WOPETIM(indcum)) * LCOE
        [F:MCW]SETAMT = sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]WSETAMT(indcum))
        [F:MCW]SETAMT+= sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=0) * [M:CST]WSETAMT(indcum)) * LCOE
        [F:MCW]OPEAMT = sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]WOPEAMT(indcum))
        [F:MCW]OPEAMT+= sigma(0,[M:CST]NBWST-1,([M:CST]WST(indcum)=[M:CST]WST(I) & [M:CST]WLNK(indcum)=0) * [M:CST]WOPEAMT(indcum)) * LCOE

        # !!! On n'enregistre les FG d'une même opération qu'une fois
        If [M:CST]WLNK(I)=0 | !sigma(0,[M:CST]NBFGWST-1,[M:CST]OWST(indcum)=[M:CST]WST(I) & [M:CST]WOLNK(indcum)=[M:CST]WLNK(I))
            [F:MCW]OVEAMT = sigma(0,[M:CST]NBFGWST-1,([M:CST]WFXDAMT(indcum)+[M:CST]WVARAMT(indcum))
&                                                   *(  [M:CST]OWST(indcum)=[M:CST]WST(I)
&                                                     & [M:CST]WOLNK(indcum)=[M:CST]WLNK(I)) )
            [F:MCW]OVEAMT = sigma(0,[M:CST]NBFGWST-1,([M:CST]WFXDAMT(indcum)+[M:CST]WVARAMT(indcum))
&                                                   *(  [M:CST]OWST(indcum)=[M:CST]WST(I)
&                                                     & [M:CST]WLNK(I)=0) ) * LCOE

        Endif
        If LEXI
            Rewrite [MCW]
        Else
            Write [MCW]
        Endif
        If fstat
            PRET=1 : Break
        Endif
    Endif
Next

If LTRANSAC
    If PRET
        Rollback
        End
    Else
        Commit
    Endif
Endif
If PRET
    ERR_TRA = mess(14,100,1) - [F:MCW]ITMREF - mess(570,197,1)+":"+[F:MCW]WST
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    End
Endif

If LTRANSAC
    Trbegin [MCW]
Endif

For I=0 To [M:CST]NBSCO-1
    If !find([M:CST]SCOWST(I),[M:CST]SCOWST(0..I-1))
&    & ([M:CST]SLNK(I)=[M:CST]SLNK(PIND) | [M:CST]SLNK(I)=0)
        Readlock [F:MCW]MCW0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]SCOWST(I);adxuid(1)
        If !fstat
            LEXI=1
        Else
            LEXI=0
            Raz [F:MCW]
            [F:MCW]STOFCY = [M:CST0]STOFCY
            [F:MCW]ITMREF = PITM
            [F:MCW]YEA    = PYEA
            [F:MCW]VCRTYP = [M:CTP]VCRTYP
            [F:MCW]VCRNUM = [M:CTP]VCRNUM
            [F:MCW]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCW]MFCTYP = PTYP
            [F:MCW]WST    = [M:CST]SCOWST(I)
            [F:MCW]UID    = adxuid(1)
        Endif

        [F:MCW]WSTTYP = 3
        [F:MCW]BRDCOD = [M:CST]SBRDCOD(I)
        [F:MCW]WCSTTYP = [M:CST]SCSTTYP(I)
        [F:MCW]RATCOD = [M:CST]SRATCOD(I)
        [F:MCW]SETCST = [M:CST]SSETCST(I)
        [F:MCW]SETTIM = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]SSETTIM(indcum))
        [F:MCW]SETTIM+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]SSETTIM(indcum)) * LCOE
        [F:MCW]OPECST = [M:CST]SOPECST(I)
        [F:MCW]OPETIM = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]SOPETIM(indcum))
        [F:MCW]OPETIM+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]SOPETIM(indcum)) * LCOE
        [F:MCW]SETAMT = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]SSETAMT(indcum))
        [F:MCW]SETAMT+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]SSETAMT(indcum)) * LCOE
        [F:MCW]OPEAMT = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]SOPEAMT(indcum))
        [F:MCW]OPEAMT+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]SOPEAMT(indcum)) * LCOE
        [F:MCW]SCOITMREF = [M:CST]SCOITMREF(I)
        [F:MCW]CSTCOD = [M:CST]SCSTCOD(I)
# Issue 87944 - 2013-02-11 by CCC : PRISCO est exprimé dans l'unité du service
#        # Issue 76125
#        # Les prix sur chaque ligne correspondent au montant de la ligne divisé par la quantité totale produite
#        [F:MCW]PRISCO = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]PRISCO(indcum))
#        [F:MCW]PRISCO+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]PRISCO(indcum)) * LCOE
#
#        If [M:CST]SCOEQTY(I)<>0
#            [F:MCW]PRISCO /= [M:CST]SCOEQTY(I)
#        Endif
#
#        [F:MCW]QTY   += func TRTCST.SUMQTY("P", [M:CST]SLNK(I)) * [M:CST]SCOEQTY(I)
#        [F:MCW]AMTSCO = [F:MCW]PRISCO * [F:MCW]QTY
        [F:MCW]AMTSCO = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND))
&                                             * [M:CST]PRISCO(indcum)
&                                             * ([M:CST]SQTYSCOITM(indcum)+([M:CST]SQTYSCOITM(indcum)=0)))
        [F:MCW]AMTSCO+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0)
&                                             * [M:CST]PRISCO(indcum)
&                                             * ([M:CST]SQTYSCOITM(indcum)+([M:CST]SQTYSCOITM(indcum)=0))) * LCOE

        [F:MCW]QTY = sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]SQTYSCOITM(indcum))
        [F:MCW]QTY+= sigma(0,[M:CST]NBSCO-1,([M:CST]SCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SLNK(indcum)=0) * [M:CST]SQTYSCOITM(indcum)) * LCOE

        If [F:MCW]QTY=0
            [F:MCW]PRISCO=0
        Else
            [F:MCW]PRISCO = [F:MCW]AMTSCO / [F:MCW]QTY
        Endif

        Case [F:MCW]VCRTYP
            When 10 : Filter [MFO] Where MFGNUM=[F:MCW]VCRNUM
&                                      & EXTWST=[F:MCW]WST
                      Read [MFO] First
                      Filter [MFO]
                      [F:MCW]UOM    = [F:MFO]OPEUOM
            When 36 : [F:MCW]UOM    = [F:SCS]SCOPUU
        Endcase

        # !!! On n'enregistre les FG d'une même opération qu'une fois
        If [M:CST]SLNK(I)=0 | !sigma(0,[M:CST]NBFGSCO-1,[M:CST]OSCOWST(indcum)=[M:CST]SCOWST(I) & [M:CST]SOLNK(indcum)=[M:CST]SLNK(I))
            [F:MCW]OVEAMT = sigma(0,[M:CST]NBFGSCO-1,([M:CST]SFXDAMT(indcum)+[M:CST]SVARAMT(indcum))
&                                                   *(  [M:CST]OSCOWST(indcum)=[M:CST]SCOWST(I)
&                                                     & [M:CST]SLNK(I)=0) ) * LCOE
        Endif
        If LEXI
            Rewrite [MCW]
        Else
            Write [MCW]
        Endif
        If fstat
            PRET=1 : Break
        Endif
    Endif
Next
If LTRANSAC
    If PRET
        Rollback
    Else
        Commit
    Endif
Endif
If PRET
    ERR_TRA = mess(14,100,1) - [F:MCW]ITMREF - mess(570,197,1)+":"+[F:MCW]WST
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    End
Endif
End

