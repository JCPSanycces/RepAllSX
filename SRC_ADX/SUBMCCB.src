#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################
# Charge, calcule et enregistre un coût prévisionnel
# en se basant sur les paramètres renseignés dans [M:CTP]
#######################################################
Subprog CLCMFC(PMFCTYP,PRET)
Value Integer PMFCTYP
Variable Integer PRET

Local Integer LYEA, I
Raz [M:CST]
Case [M:CTP]VCRTYP
    When 10 :
        [M:CTP]VCRNUM = [F:MFG]MFGNUM
        If [F:MFG]MFGSTA >= 4
            LYEA = year([F:MFG]CLODAT)   : # date de cloture si l'OF est clos (09/03/01)
            [M:CTP]CLCDAT= [F:MFG]CLODAT
        Else
            # OF non suivi date$ pour pouvoir lire les coûts 13402  (19/06/02)
            If [F:MFG]TRKFIRST = [0/0/0]
                LYEA = year(date$)
                [M:CTP]CLCDAT = date$
            Else
                LYEA = year([F:MFG]TRKFIRST) : # date de 1er suivi si l'OF n'est pas clos
                [M:CTP]CLCDAT = [F:MFG]TRKFIRST
            Endif
        Endif
        Call LOADMFG(1,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
        Call LOADMFG(2,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
        Call LOADMFG(3,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
    When 36 :
        [M:CTP]VCRNUM = [F:SCO]SCONUM
        If [F:SCO]SCOSTA >= 4
            LYEA = year([F:SCO]CLODAT)   : # date de cloture si l'OS est clos
            [M:CTP]CLCDAT= [F:SCO]CLODAT
        Else
            LYEA = year(date$)
            [M:CTP]CLCDAT = date$
        Endif
        Call LOADSCO(1,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
        Call LOADSCO(2,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
        Call LOADSCO(3,PRET) From SUBCSTB
        If PRET
            Call ECR_TRACE([M:CTP]VCRNUM-":"-GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            End
        Endif
Endcase

Local Integer LTRANSAC : LTRANSAC=0
If adxlog<>1
    LTRANSAC = 1
    Call DEBTRANS From GLOCK
    Trbegin [MFC]
Endif

# Issue 92185 - 2013-12-11 by CCC : On n'efface les enreg avec UID=0 que si MAJ
#Delete [MFC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & find(UID,0,adxuid(1)) & MFCTYP=PMFCTYP
#Delete [MCN] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & find(UID,0,adxuid(1)) & MFCTYP=PMFCTYP
#Delete [MCC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & find(UID,0,adxuid(1)) & MFCTYP=PMFCTYP
#Delete [MCW] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & find(UID,0,adxuid(1)) & MFCTYP=PMFCTYP
Delete [MFC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=PMFCTYP
Delete [MCN] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=PMFCTYP
Delete [MCC] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=PMFCTYP
Delete [MCW] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & UID=adxuid(1) & MFCTYP=PMFCTYP

[M:CTP]NIV=1
Call CLCCST  From TRTCST
For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)<>2 & !find([M:CST]ILNK(I),[M:CST]ILNK(0..I-1))
        Call SAVMFC(I,[M:CST]ITMREF(I),LYEA,PMFCTYP,PRET) From SUBMCCB
        If PRET : Break : Endif
    Endif
Next

If PRET : End : Endif

[M:CTP]NIV=2
Call CLCCST  From TRTCST
For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)<>2 & !find([M:CST]ILNK(I),[M:CST]ILNK(0..I-1))
        Call SAVMFC(I,[M:CST]ITMREF(I),LYEA,PMFCTYP,PRET) From SUBMCCB
        If PRET : Break : Endif
        Call SAVMCN(I,[M:CST]ITMREF(I),LYEA,PMFCTYP,PRET) From SUBMCCB
        If PRET : Break : Endif
        Call SAVMCC(I,[M:CST]ITMREF(I),LYEA,PMFCTYP,PRET) From SUBMCCB
        If PRET : Break : Endif
        Call SAVMCW(I,[M:CST]ITMREF(I),LYEA,PMFCTYP,PRET) From SUBMCCB
        If PRET : Break : Endif
    Endif
Next

If LTRANSAC
    Commit
Endif

End

###################################################################
# Sauvegarde du coût global pour un article (=> pour une ligne d'ordre)
###################################################################
Subprog SAVMFC(PIND,PITM,PYEA,PTYP,PRET)
Value Integer PIND
Value Char    PITM
Value Integer PYEA
Value Integer PTYP
Variable Integer PRET

Local Integer LEXI, IT_BRD
Local Integer LTRANSAC : LTRANSAC=0
Local Decimal LQTY
If adxlog<>1
    LTRANSAC = 1
    Call DEBTRANS From GLOCK
    Trbegin [MFC]
Endif

Case [M:CTP]VCRTYP
    When 10 :
        Read [MFG]MFG0=[M:CTP]VCRNUM
        Read [MFI]MFI0=[M:CTP]VCRNUM;[M:CST]ILNK(PIND)
    When 36 :
        Read [SCO]SCO0=[M:CTP]VCRNUM
        Read [SCI]SCI0=[M:CTP]VCRNUM;[M:CST]ILNK(PIND)
Endcase
Readlock [MFC]MFC0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;adxuid(1)
If fstat = 1
    ERR_TRA = mess(14,100,1)-"fstat="+num$(fstat) - [M:CTP]VCRNUM-PITM
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    PRET=1
    Goto FIN
Elsif !fstat
    LEXI = 1
Elsif fstat
    LEXI = 0
    Raz [F:MFC]  # Issue X3-106417 - 2018-09-10 by ERMIL : Clear previous values if new record
Endif

[F:MFC]STOFCY  = [M:CST0]STOFCY
[F:MFC]ITMREF  = PITM
[F:MFC]YEA     = PYEA
[F:MFC]VCRTYP  = [M:CTP]VCRTYP
[F:MFC]VCRNUM  = [M:CTP]VCRNUM
[F:MFC]VCRLIN  = [M:CST]ILNK(PIND)
[F:MFC]MFCTYP  = PTYP
[F:MFC]UID     = adxuid(1)
[F:MFC]MFCDAT  = date$
## GH 19/03/2014 bug 86229
# [F:MFC]PRNUID  = adxuid(1)
If [M:CTP]PRNNUM=0
   [M:CTP]PRNNUM = uniqid([F:MFC])
Endif
[F:MFC]PRNUID  = [M:CTP]PRNNUM
##
Case [M:CTP]VCRTYP
    When 10 :
        [F:MFC]PJT       = [F:MFI]PJT
        [F:MFC]BOMALT    = [F:MFI]BOMALT
        [F:MFC]BOMALTTYP = 2
        [F:MFC]ROUALT    = [F:MFG]ROUALT
    When 36 :
        [F:MFC]PJT       = [F:SCI]PJT
        [F:MFC]BOMALT    = [F:SCI]BOMALT
        [F:MFC]BOMALTTYP = 3
        [F:MFC]ROUALT    = 0
Endcase
[F:MFC]SLTOVECOL = [M:CTP]SLTOVECOL
[F:MFC]SLTMATCST = GVLTMATEXT+([M:CTP]CSTMATTYP=3)*(5-GVLTMATEXT) # GVLTMATEXT ou prix mouvement (ml. 329)

# Issue 81343 - 2012-04-04 by CCC : GMFCRAT* n'ont de sens que pour un OF
If [F:MFC]VCRTYP=10
    If [M:CTP]CSTOPETYP<3
        [F:MFC]VLTCCERAT = GMFCRATEXT
    Else
        [F:MFC]VLTCCERAT = GMFCRATCPL
    Endif
Endif

[F:MFC]SLTSEMCST = GVLTSEMEXT+([M:CTP]CSTMATTYP=3)*(5-GVLTSEMEXT) # GVLTSEMEXT ou prix mouvement (ml. 329)
#[F:MFC]MFCSEMBRD : ne sert à rien puisqu'on a le mono et le multi-niveau dans l'enreg
[F:MFC]QTYSTU    = func TRTCST.SUMQTY("P", [M:CST]ILNK(PIND))

# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#LQTY = [M:CST]IQTYSTU(PIND)
LQTY = [F:MFC]QTYSTU
If LQTY = 0 : LQTY=1 : Endif

# ramener les montants à un cout unitaire par rapport à la qté prévue (CPT/CPL), réalisée (CPP)
If [M:CTP]NIV=1
    Raz [F:MFC]MATLEV0
Endif
For IT_BRD=0 To GACTMAT-1
    If [M:CTP]NIV=1
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]MATCST(IT_BRD) = ([M:CST]IMATCST(PIND*GACTMAT+IT_BRD)+[M:CST]ISMATCST(PIND*GACTMAT+IT_BRD))/ LQTY
        [F:MFC]MATCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                     * ([M:CST]IMATCST(indcum*GACTMAT+IT_BRD)+[M:CST]ISMATCST(indcum*GACTMAT+IT_BRD)))/ LQTY
        [F:MFC]MATCST(IT_BRD) = arr([F:MFC]MATCST(IT_BRD),10^-GDECPRI)
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]BPSMATCST(IT_BRD) = [M:CST]ISMATCST(PIND*GACTMAT+IT_BRD)/ LQTY
        [F:MFC]BPSMATCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                        * ([M:CST]ISMATCST(indcum*GACTMAT+IT_BRD)))/ LQTY
        [F:MFC]BPSMATCST(IT_BRD) = arr([F:MFC]BPSMATCST(IT_BRD),10^-GDECPRI)
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]MATLEV0 += [M:CST]IMATLEV0(PIND*GACTMAT+IT_BRD)/ LQTY
        [F:MFC]MATLEV0 += sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                               * ([M:CST]IMATLEV0(indcum*GACTMAT+IT_BRD)))/ LQTY
    Else
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
## Issue 78112 - 2012-02-13 by CCC : Ajout de la matière fournie dans le coût matière multi-niveaux
##        [F:MFC]MATCPNCST(IT_BRD) = [M:CST]IMATCST(PIND*GACTMAT+IT_BRD)/ LQTY
#        [F:MFC]MATCPNCST(IT_BRD) = ([M:CST]IMATCST(PIND*GACTMAT+IT_BRD)+[M:CST]ISMATCST(PIND*GACTMAT+IT_BRD))/ LQTY
        [F:MFC]MATCPNCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                        * ([M:CST]IMATCST(indcum*GACTMAT+IT_BRD)+[M:CST]ISMATCST(indcum*GACTMAT+IT_BRD)))/ LQTY
        [F:MFC]MATCPNCST(IT_BRD) = arr([F:MFC]MATCPNCST(IT_BRD),10^-GDECPRI)
    Endif
Next
[F:MFC]MATLEV0 = arr([F:MFC]MATLEV0,10^-GDECPRI)

For IT_BRD=0 To GACTMAC-1
    If [M:CTP]NIV=1
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]MACCST(IT_BRD) = ([M:CST]IFMACCST(PIND*GACTMAC+IT_BRD)+[M:CST]IMACCST(PIND*GACTMAC+IT_BRD))/ LQTY
        [F:MFC]MACCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                     * ([M:CST]IFMACCST(indcum*GACTMAC+IT_BRD)+[M:CST]IMACCST(indcum*GACTMAC+IT_BRD)))/ LQTY
        [F:MFC]MACCST(IT_BRD) = arr([F:MFC]MACCST(IT_BRD),10^-GDECPRI)
    Else
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]MACCPNCST(IT_BRD) = ([M:CST]IFMACCST(PIND*GACTMAC+IT_BRD)+[M:CST]IMACCST(PIND*GACTMAC+IT_BRD))/ LQTY
        [F:MFC]MACCPNCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                        * ([M:CST]IFMACCST(indcum*GACTMAC+IT_BRD)+[M:CST]IMACCST(indcum*GACTMAC+IT_BRD)))/ LQTY
        [F:MFC]MACCPNCST(IT_BRD) = arr([F:MFC]MACCPNCST(IT_BRD),10^-GDECPRI)-[F:MFC]MACCST(IT_BRD)
    Endif
Next
For IT_BRD=0 To GACTLAB-1
    If [M:CTP]NIV=1
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]LABCST(IT_BRD) = ([M:CST]IFLABCST(PIND*GACTLAB+IT_BRD)+[M:CST]ILABCST(PIND*GACTLAB+IT_BRD))/ LQTY
        [F:MFC]LABCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                     * ([M:CST]IFLABCST(indcum*GACTLAB+IT_BRD)+[M:CST]ILABCST(indcum*GACTLAB+IT_BRD)))/ LQTY
        [F:MFC]LABCST(IT_BRD) = arr([F:MFC]LABCST(IT_BRD),10^-GDECPRI)
    Else
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#        [F:MFC]LABCPNCST(IT_BRD) = ([M:CST]IFLABCST(PIND*GACTLAB+IT_BRD)+[M:CST]ILABCST(PIND*GACTLAB+IT_BRD))/ LQTY
        [F:MFC]LABCPNCST(IT_BRD) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                                        * ([M:CST]IFLABCST(indcum*GACTLAB+IT_BRD)+[M:CST]ILABCST(indcum*GACTLAB+IT_BRD)))/ LQTY
        [F:MFC]LABCPNCST(IT_BRD) = arr([F:MFC]LABCPNCST(IT_BRD),10^-GDECPRI)-[F:MFC]LABCST(IT_BRD)
    Endif
Next

  # JIRA X3-28432.sn MJH
  Local Decimal LSCOCST
  Raz LSCOCST
  ## Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
  For I = 0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)<>2 and [M:CST]ILNK(I) = [M:CST]ILNK(PIND)
      LSCOCST +=  [M:CST]IFSCOCST(I)+[M:CST]ISCOCST(I)
    Endif
  Next


  Local Decimal LSCOQTY
  Raz LSCOQTY
  For I = 0 To [M:CST]NBSCO-1
    If [M:CST]PRISCO(I) <> 0
      #Both IFSCOCST and SQTYSCOITM have the subcontract coefficient included, having both causes the coefficient to be lost
      # When we calculate SCOCST
      If dim([F:MFO]OPESTUCOE) > 0 and [F:MFO]OPESTUCOE <> 0
        LSCOQTY += [M:CST]SQTYSCOITM(I) / [F:MFO]OPESTUCOE#X3-80596 MJH - 30 March 2018
      Elsif dim([F:SCS]OPESTUCOE) > 0 and [F:SCS]OPESTUCOE <> 0
        LSCOQTY += [M:CST]SQTYSCOITM(I) / (1/[F:SCS]OPESTUCOE) #MJH X3-90657
      Elsif [M:CST]SCOEQTY(I) <> 0
        LSCOQTY += [M:CST]SQTYSCOITM(I) / sigma(0,[M:CST]NBSCO-1,[M:CST]SCOEQTY(indcum)) #MJH X3-90657
      Else
        LSCOQTY += [M:CST]SQTYSCOITM(I)
      Endif
    Endif
  Next

  If LSCOQTY <> 0
    If [M:CTP]NIV=1
      [F:MFC]SCOCST    = arr(LSCOCST / LSCOQTY,10^-GDECPRI)
    Else
      [F:MFC]SCOCPNCST = arr(LSCOCST / LSCOQTY,10^-GDECPRI)-[F:MFC]SCOCST
    Endif
  Endif
  # JIRA X3-28432.en MJH

# JIRA X3-28432.so MJH
#If [M:CTP]NIV=1
## Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
##    [F:MFC]SCOCST = ([M:CST]IFSCOCST(PIND)+[M:CST]ISCOCST(PIND))/ LQTY
#    [F:MFC]SCOCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
#&                                         * ([M:CST]IFSCOCST(indcum)+[M:CST]ISCOCST(indcum)))/ LQTY
#
#    [F:MFC]SCOCST = arr([F:MFC]SCOCST,10^-GDECPRI)
#Else
## Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
##    [F:MFC]SCOCPNCST = ([M:CST]IFSCOCST(PIND)+[M:CST]ISCOCST(PIND))/ LQTY
#    [F:MFC]SCOCPNCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
#&                                            * ([M:CST]IFSCOCST(indcum)+[M:CST]ISCOCST(indcum)))/ LQTY
#
#    [F:MFC]SCOCPNCST = arr([F:MFC]SCOCPNCST,10^-GDECPRI)-[F:MFC]SCOCST
#Endif
# JIRA X3-28432.eo MJH

If [M:CTP]NIV=1
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#    [F:MFC]INVDTACST = ([M:CST]IFINVDTA(PIND)+[M:CST]IINVDTA(PIND))/ LQTY
    [F:MFC]INVDTACST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IFINVDTA(indcum)+[M:CST]IINVDTA(indcum)))/ LQTY
    [F:MFC]INVDTACST = arr([F:MFC]INVDTACST,10^-GDECPRI)
Else
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#    [F:MFC]INVDTACPN = ([M:CST]IFINVDTA(PIND)+[M:CST]IINVDTA(PIND))/ LQTY
    [F:MFC]INVDTACPN = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IFINVDTA(indcum)+[M:CST]IINVDTA(indcum)))/ LQTY
    [F:MFC]INVDTACPN = arr([F:MFC]INVDTACPN,10^-GDECPRI)-[F:MFC]INVDTACST
Endif

If [M:CTP]NIV=1
# Issue 103901 - 2014-11-10 by CCC : cumulate all lines for a same product
#    [F:MFC]OVEMATCST = ([M:CST]IOVEMATCST(PIND) + [M:CST]IFOMATCST(PIND)) / LQTY
#    [F:MFC]OVEMACCST = ([M:CST]IOVEMACCST(PIND) + [M:CST]IFOMACCST(PIND)) / LQTY
#    [F:MFC]OVELABCST = ([M:CST]IOVELABCST(PIND) + [M:CST]IFOLABCST(PIND)) / LQTY
#    [F:MFC]OVESCOCST = ([M:CST]IOVESCOCST(PIND) + [M:CST]IFOSCOCST(PIND)) / LQTY
    [F:MFC]OVEMATCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IOVEMATCST(indcum) + [M:CST]IFOMATCST(indcum))) / LQTY
    [F:MFC]OVEMACCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IOVEMACCST(indcum) + [M:CST]IFOMACCST(indcum))) / LQTY
    [F:MFC]OVELABCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IOVELABCST(indcum) + [M:CST]IFOLABCST(indcum))) / LQTY
    [F:MFC]OVESCOCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMTYP(indcum)<>2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND))
&                                            * ([M:CST]IOVESCOCST(indcum) + [M:CST]IFOSCOCST(indcum))) / LQTY

    [F:MFC]OVEMATCST = arr([F:MFC]OVEMATCST,10^-GDECPRI)
    [F:MFC]OVEMACCST = arr([F:MFC]OVEMACCST,10^-GDECPRI)
    [F:MFC]OVELABCST = arr([F:MFC]OVELABCST,10^-GDECPRI)
    [F:MFC]OVESCOCST = arr([F:MFC]OVESCOCST,10^-GDECPRI)

Else
    # Les FG composants sont ceux qui n'avaient pas été pris en compte lors du calcul mono-niveau
    [F:MFC]OVEMATCPN = [M:CST]IOVEMATCST(PIND) - ([F:MFC]OVEMATCST*LQTY)
    [F:MFC]OVEMACCPN = [M:CST]IOVEMACCST(PIND) - ([F:MFC]OVEMACCST*LQTY)
    [F:MFC]OVELABCPN = [M:CST]IOVELABCST(PIND) - ([F:MFC]OVELABCST*LQTY)
    [F:MFC]OVESCOCPN = [M:CST]IOVESCOCST(PIND) - ([F:MFC]OVESCOCST*LQTY)
    [F:MFC]OVECPNCST = [F:MFC]OVEMATCPN+[F:MFC]OVEMACCPN+[F:MFC]OVELABCPN+[F:MFC]OVESCOCPN

    [F:MFC]OVEMATCPN = arr([F:MFC]OVEMATCPN / LQTY,10^-GDECPRI)
    [F:MFC]OVEMACCPN = arr([F:MFC]OVEMACCPN / LQTY,10^-GDECPRI)
    [F:MFC]OVELABCPN = arr([F:MFC]OVELABCPN / LQTY,10^-GDECPRI)
    [F:MFC]OVESCOCPN = arr([F:MFC]OVESCOCPN / LQTY,10^-GDECPRI)
    [F:MFC]OVECPNCST = arr([F:MFC]OVECPNCST / LQTY,10^-GDECPRI)
Endif

If [M:CTP]NIV=1
    [F:MFC]MATTOT = sum([F:MFC]MATCST)    # Les matières fournies par le sous-traitant sont incluses dans MATCST
    [F:MFC]MACTOT = sum([F:MFC]MACCST)
    [F:MFC]LABTOT = sum([F:MFC]LABCST)
    [F:MFC]SCOTOT = [F:MFC]SCOCST
    [F:MFC]INVDTATOT = [F:MFC]INVDTACST
    [F:MFC]CSTTOT = [F:MFC]MATTOT+[F:MFC]MACTOT+[F:MFC]LABTOT+[F:MFC]SCOTOT+[F:MFC]INVDTATOT
    [F:MFC]OVETOT = [F:MFC]OVEMATCST+[F:MFC]OVEMACCST+[F:MFC]OVELABCST+[F:MFC]OVESCOCST
Endif

[F:MFC]CREDAT  = date$
[F:MFC]CREUSR  = GUSER
[F:MFC]EXPNUM  = [C]EXPORT

If LEXI
    Rewrite [MFC]
Else
    Write [MFC]
Endif

If fstat
    GOK = 0
Endif

$FIN

If LTRANSAC
    If GOK & !PRET
        Commit
    Else
        Rollback
    Endif
Endif
If !GOK | PRET
    ERR_TRA = mess(14,100,1) - PITM
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
Endif
End

###################################################################
# Sauvegarde des natures de FG pour un article (=> pour une ligne d'ordre)
###################################################################
Subprog SAVMCN(PIND,PITM,PYEA,PTYP,PRET)
Value Integer PIND
Value Char    PITM
Value Integer PYEA
Value Integer PTYP
Variable Integer PRET

Local Integer I, J, LEXI
Local Decimal LQTYLIN, LQTYTOT
Local Decimal LCOE
If !clalev([F:MCN]) : Local File MFCNAT [MCN] : Endif

LQTYLIN = func TRTCST.SUMQTY("P",[M:CST]ILNK(PIND))
LQTYTOT = func TRTCST.SUMQTY("P",0)

# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
Local Decimal LCOE, LCOE0
LCOE = LQTYLIN
If LQTYLIN = 0
    LCOE = 1
Endif

LCOE0 = LQTYTOT
If LQTYTOT = 0
    LCOE0 = 1
    # Issue 93217 - 2013-10-04 by CCC : Multi-product WO case
    If [M:CTP]VCRTYP=10
        If clalev([F:MFIX])=0 : Local File MFGITM [MFIX] : Endif
        Filter [MFIX] Where MFGNUM=[M:CTP]VCRNUM
&                         & ITMTYP<>2
        LCOE0 = rowcount([F:MFIX])
        Filter [MFIX]
        If LCOE0=0
            LCOE0 = 1
        Endif
    Endif
Endif


Local Integer LTRANSAC : LTRANSAC=0
If adxlog<>1
    LTRANSAC = 1
    Call DEBTRANS From GLOCK
    Trbegin [MCN]
Endif

# On récupère les natures de FG des composants --> nature ZZZ
For I=0 To [M:CST]NBMAT-1
    If [M:CST]MLNK(I)=0 | [M:CST]MLNK(I)=[M:CST]ILNK(PIND)
        Readlock [F:MCN]MCN0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;"ZZZ";adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            Raz [F:MCN]
            [F:MCN]STOFCY = [M:CST0]STOFCY
            [F:MCN]ITMREF = PITM
            [F:MCN]VCRTYP = [M:CTP]VCRTYP
            [F:MCN]VCRNUM = [M:CTP]VCRNUM
            [F:MCN]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCN]MFCTYP = PTYP
            [F:MCN]OVENAT = "ZZZ"
            [F:MCN]UID    = adxuid(1)
            [F:MCN]CPLQTY = LQTYLIN
        Endif
        [F:MCN]YEA    = PYEA
# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
#        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]MLNK(I)=0
                For J=0,6    # Total & FG entrée matière
#                    [F:MCN]NATAMTSSE(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))/LQTYTOT
                    [F:MCN]NATAMTSSE(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))/LCOE0
                Next
            Else
                For J=0,6    # Total & FG entrée matière
#                    [F:MCN]NATAMTSSE(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))/LQTYLIN
                    [F:MCN]NATAMTSSE(J) += sum([M:CST]MOVEMATCST(I),[M:CST]MOVEMACCST(I),[M:CST]MOVELABCST(I),[M:CST]MOVESCOCST(I))/LCOE
                Next
            Endif
#        Endif
        If [F:MCN]NATAMTSSE<>0
            If LEXI
                Rewrite [MCN]
            Else
                Write [MCN]
            Endif
            If fstat
                PRET=1 : Break
            Endif
        Endif
    Endif
Next

For I=0 To [M:CST]NBFGMAT-1
    If [M:CST]MOLNK(I)=0 | [M:CST]MOLNK(I)=[M:CST]ILNK(PIND)
        Readlock [F:MCN]MCN0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]NATMAT(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            Raz [F:MCN]
            [F:MCN]STOFCY = [M:CST0]STOFCY
            [F:MCN]ITMREF = PITM
            [F:MCN]VCRTYP = [M:CTP]VCRTYP
            [F:MCN]VCRNUM = [M:CTP]VCRNUM
            [F:MCN]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCN]MFCTYP = PTYP
            [F:MCN]OVENAT = [M:CST]NATMAT(I)
            [F:MCN]UID    = adxuid(1)
            [F:MCN]CPLQTY = LQTYLIN
        Endif
        [F:MCN]YEA    = PYEA
# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
#        If LQTYLIN<>0 & LQTYTOT<>0 & [M:CST]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
        If [M:CST]CLCLEV(I)=2    # Dans le cas des PRF on ne doit avoir que CLCLEV=2...
            If [M:CST]MOLNK(I)=0
#                [F:MCN]NATAMTLEV(0) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LQTYTOT
#                [F:MCN]NATAMTLEV([M:CST]MOVETYP(I)) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LQTYTOT
                [F:MCN]NATAMTLEV(0) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LCOE0
                [F:MCN]NATAMTLEV([M:CST]MOVETYP(I)) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LCOE0
            Else
#                [F:MCN]NATAMTLEV(0) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LQTYLIN
#                [F:MCN]NATAMTLEV([M:CST]MOVETYP(I)) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LQTYLIN
                [F:MCN]NATAMTLEV(0) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LCOE
                [F:MCN]NATAMTLEV([M:CST]MOVETYP(I)) += ([M:CST]MVARAMT(I) + [M:CST]MFXDAMT(I)) / LCOE
            Endif
        Endif
        If [F:MCN]NATAMTLEV<>0
            If LEXI
                Rewrite [MCN]
            Else
                Write [MCN]
            Endif
            If fstat
                PRET=1 : Break
            Endif
        Endif
    Endif
Next


For I=0 To [M:CST]NBFGITM-1
    If [M:CST]IOLNK(I)=0 | [M:CST]IOLNK(I)=[M:CST]ILNK(PIND)
        Readlock [F:MCN]MCN0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]NATITM(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            Raz [F:MCN]
            [F:MCN]STOFCY = [M:CST0]STOFCY
            [F:MCN]ITMREF = PITM
            [F:MCN]VCRTYP = [M:CTP]VCRTYP
            [F:MCN]VCRNUM = [M:CTP]VCRNUM
            [F:MCN]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCN]MFCTYP = PTYP
            [F:MCN]OVENAT = [M:CST]NATITM(I)
            [F:MCN]UID    = adxuid(1)
            [F:MCN]CPLQTY = LQTYLIN
        Endif
        [F:MCN]YEA    = PYEA
# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
#        If LQTYLIN<>0 & LQTYTOT<>0
            J=[M:CST]IOVETYP(I)
            If J=2 : J=1 : Endif
            If [M:CST]IOLNK(I)=0
#                [F:MCN]NATAMTLEV(0) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LQTYTOT
#                [F:MCN]NATAMTLEV(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LQTYTOT
                [F:MCN]NATAMTLEV(0) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LCOE0
                [F:MCN]NATAMTLEV(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LCOE0
            Else
#                [F:MCN]NATAMTLEV(0) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LQTYLIN
#                [F:MCN]NATAMTLEV(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LQTYLIN
                [F:MCN]NATAMTLEV(0) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LCOE
                [F:MCN]NATAMTLEV(J) += ([M:CST]IVARAMT(I) + [M:CST]IFXDAMT(I)) / LCOE
            Endif
#        Endif
        If [F:MCN]NATAMTLEV<>0
            If LEXI
                Rewrite [MCN]
            Else
                Write [MCN]
            Endif
            If fstat
                PRET=1 : Break
            Endif
        Endif
    Endif
Next

For I=0 To [M:CST]NBFGWST-1
    If [M:CST]WOLNK(I)=0 | [M:CST]WOLNK(I)=[M:CST]ILNK(PIND)
        Readlock [F:MCN]MCN0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]NATWST(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            Raz [F:MCN]
            [F:MCN]STOFCY = [M:CST0]STOFCY
            [F:MCN]ITMREF = PITM
            [F:MCN]VCRTYP = [M:CTP]VCRTYP
            [F:MCN]VCRNUM = [M:CTP]VCRNUM
            [F:MCN]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCN]MFCTYP = PTYP
            [F:MCN]OVENAT = [M:CST]NATWST(I)
            [F:MCN]UID    = adxuid(1)
            [F:MCN]CPLQTY = LQTYLIN
        Endif
        [F:MCN]YEA    = PYEA
# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
#        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]WOLNK(I)=0
#                [F:MCN]NATAMTLEV(0) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LQTYTOT
#                [F:MCN]NATAMTLEV([M:CST]WOVETYP(I)) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LQTYTOT
                [F:MCN]NATAMTLEV(0) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LCOE0
                [F:MCN]NATAMTLEV([M:CST]WOVETYP(I)) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LCOE0
            Else
#                [F:MCN]NATAMTLEV(0) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LQTYLIN
#                [F:MCN]NATAMTLEV([M:CST]WOVETYP(I)) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LQTYLIN
                [F:MCN]NATAMTLEV(0) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LCOE
                [F:MCN]NATAMTLEV([M:CST]WOVETYP(I)) += ([M:CST]WVARAMT(I) + [M:CST]WFXDAMT(I)) / LCOE
            Endif
#        Endif
        If [F:MCN]NATAMTLEV<>0
            If LEXI
                Rewrite [MCN]
            Else
                Write [MCN]
            Endif
            If fstat
                PRET=1 : Break
            Endif
        Endif
    Endif
Next
For I=0 To [M:CST]NBFGSCO-1
    If [M:CST]SOLNK(I)=0 | [M:CST]SOLNK(I)=[M:CST]ILNK(PIND)
        Readlock [F:MCN]MCN0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]NATSCO(I);adxuid(1)
        If !fstat
            LEXI = 1
        Else
            LEXI = 0
            Raz [F:MCN]
            [F:MCN]STOFCY = [M:CST0]STOFCY
            [F:MCN]ITMREF = PITM
            [F:MCN]YEA    = PYEA
            [F:MCN]VCRTYP = [M:CTP]VCRTYP
            [F:MCN]VCRNUM = [M:CTP]VCRNUM
            [F:MCN]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCN]MFCTYP = PTYP
            [F:MCN]OVENAT = [M:CST]NATSCO(I)
            [F:MCN]UID    = adxuid(1)
            [F:MCN]CPLQTY = LQTYLIN
        Endif
# Issue 87714 - 2013-02-08 by CCC : qté produite nulle
#        If LQTYLIN<>0 & LQTYTOT<>0
            If [M:CST]SOLNK(I)=0
#                [F:MCN]NATAMTLEV(0) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LQTYTOT
#                [F:MCN]NATAMTLEV([M:CST]SOVETYP(I)) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LQTYTOT
                [F:MCN]NATAMTLEV(0) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LCOE0
                [F:MCN]NATAMTLEV([M:CST]SOVETYP(I)) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LCOE0
            Else
#                [F:MCN]NATAMTLEV(0) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LQTYLIN
#                [F:MCN]NATAMTLEV([M:CST]SOVETYP(I)) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LQTYLIN
                [F:MCN]NATAMTLEV(0) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LCOE
                [F:MCN]NATAMTLEV([M:CST]SOVETYP(I)) += ([M:CST]SVARAMT(I) + [M:CST]SFXDAMT(I)) / LCOE
            Endif
#        Endif
        If [F:MCN]NATAMTLEV<>0
            If LEXI
                Rewrite [MCN]
            Else
                Write [MCN]
            Endif
            If fstat
                PRET=1 : Break
            Endif
        Endif
    Endif
Next

If LTRANSAC
    If PRET
        Rollback
    Else
        Commit
    Endif
Endif
If PRET
    ERR_TRA = mess(14,100,1) - [F:MCN]ITMREF - mess(309,197,1)+":"+[F:MCN]OVENAT
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
Endif

End

###############################################################################
# Enregistrement du détail des matières et sous-produits
###############################################################################
Subprog SAVMCC(PIND,PITM,PYEA,PTYP,PRET)
Value Integer PIND
Value Char    PITM
Value Integer PYEA
Value Integer PTYP
Variable Integer PRET

If !clalev([F:MCC]) : Local File MFCMAT [MCC] : Endif

Local Integer I, J, K, LEXI
Local Decimal LQTYLIN, LQTYTOT
Local Decimal LCOE0, LCOELNK

Raz PRET
LQTYLIN = func TRTCST.SUMQTY("P",[M:CST]ILNK(PIND))
LQTYTOT = func TRTCST.SUMQTY("P",0)

Local Integer LTRANSAC : LTRANSAC=0
If adxlog<>1
    LTRANSAC = 1
    Call DEBTRANS From GLOCK
    Trbegin [MCC]
Endif

For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)=2 & !find([M:CST]ITMREF(I),[M:CST]ITMREF(0..I-1))
&    & find([M:CST]ILNK(I),[M:CST]ILNK(PIND),0) : # & ([M:CST]ILNK(I)=[M:CST]ILNK(PIND) | [M:CST]ILNK(I)=0)
        Readlock [F:MCC]MCC0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]ITMREF(I);[M:CST]IECCVALMAJ(I);[M:CST]IECCVALMIN(I);adxuid(1)
        If !fstat
            LEXI=1
            # Issue 119469 GH 04/11/16 - performance enhancement
            Raz [F:MCC]SCOCST, [F:MCC]INVDTACST, [F:MCC]OVEMATCST, [F:MCC]OVEMACCST, [F:MCC]OVELABCST, [F:MCC]OVESCOCST
            Raz [F:MCC]MATCST
            Raz [F:MCC]MACCST
            Raz [F:MCC]LABCST
        Else
            LEXI=0
            Raz [F:MCC]
            [F:MCC]STOFCY = [M:CST0]STOFCY
            [F:MCC]ITMREF = PITM
            [F:MCC]VCRTYP = [M:CTP]VCRTYP
            [F:MCC]VCRNUM = [M:CTP]VCRNUM
            [F:MCC]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCC]MFCTYP = PTYP
            [F:MCC]MATREF = [M:CST]ITMREF(I)
            [F:MCC]ECCVALMAJ = [M:CST]IECCVALMAJ(I)
            [F:MCC]ECCVALMIN = [M:CST]IECCVALMIN(I)
            [F:MCC]UID    = adxuid(1)
            [F:MCC]YEA    = PYEA
            [F:MCC]CPNTYP = 4    # Sous-produit

            # Issue 119469 GH 04/11/16 - performance enhancement
            #[F:MCC]QTYSTU = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IQTYSTU(indcum))
            #If LQTYTOT<>0
            #    [F:MCC]QTYSTU += sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(indcum)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IQTYSTU(indcum))*LQTYLIN / LQTYTOT
            #Endif
            For K=0 To [M:CST]NBITM-1
              If [M:CST]ITMREF(K)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(K)=2
                 If [M:CST]ILNK(K)=[M:CST]ILNK(PIND)
                    [F:MCC]QTYSTU += [M:CST]IQTYSTU(K)
                 Elsif [M:CST]ILNK(K)=0 & LQTYTOT<>0
                    [F:MCC]QTYSTU += [M:CST]IQTYSTU(K) * LQTYLIN / LQTYTOT
                 Endif
              Endif
            Next

            [F:MCC]STU    = [M:CST]ISTU(I)
            [F:MCC]BRDCOD = [M:CST]IBRDCOD(I)
            [F:MCC]CSTCOD = [M:CST]ICSTCOD(I)
        Endif

        LCOELNK = [F:MCC]QTYSTU
        If LCOELNK = 0 : LCOELNK=1 : Endif
        If LQTYTOT=0
            LCOE0=1
        Else
            LCOE0   = LQTYLIN / (LQTYTOT * LCOELNK)
        Endif

# Issue 119469 GH 04/11/16 - performance enhancement
#        For J=0 To GACTMAT-1
#            [F:MCC]MATCST(J) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IMATCST(indcum*GACTMAT+J))
#&                            / LCOELNK
#            [F:MCC]MATCST(J)+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IMATCST(indcum*GACTMAT+J)) * LCOE0
#        Next
#        For J=0 To GACTMAC-1
#            [F:MCC]MACCST(J) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IMACCST(indcum*GACTMAC+J))
#&                            / LCOELNK
#            [F:MCC]MACCST(J)+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IMACCST(indcum*GACTMAC+J)) * LCOE0
#        Next
#        For J=0 To GACTLAB-1
#            [F:MCC]LABCST(J) = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]ILABCST(indcum*GACTLAB+J))
#&                            / LCOELNK
#            [F:MCC]LABCST(J)+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]ILABCST(indcum*GACTLAB+J)) * LCOE0
#        Next
#
#        [F:MCC]SCOCST    = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]ISCOCST(indcum)) / LCOELNK
#        [F:MCC]INVDTACST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IINVDTA(indcum)) / LCOELNK
#        [F:MCC]OVEMATCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IOVEMATCST(indcum)) / LCOELNK
#        [F:MCC]OVEMACCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IOVEMACCST(indcum)) / LCOELNK
#        [F:MCC]OVELABCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IOVELABCST(indcum)) / LCOELNK
#        [F:MCC]OVESCOCST = sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]IOVESCOCST(indcum)) / LCOELNK
#
#        [F:MCC]SCOCST   += sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]ISCOCST(indcum)) * LCOE0
#        [F:MCC]INVDTACST+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IINVDTA(indcum)) * LCOE0
#        [F:MCC]OVEMATCST+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IOVEMATCST(indcum)) * LCOE0
#        [F:MCC]OVEMACCST+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IOVEMACCST(indcum)) * LCOE0
#        [F:MCC]OVELABCST+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IOVELABCST(indcum)) * LCOE0
#        [F:MCC]OVESCOCST+= sigma(0,[M:CST]NBITM-1, ([M:CST]ITMREF(indcum)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(I)=2 & [M:CST]ILNK(indcum)=0) * [M:CST]IOVESCOCST(indcum)) * LCOE0
#        If [M:CST]ITMTYP(I)=2 :  # already verified before, [M:CST]ITMTYP(indcum)=2 should have been tested
           For K=0 To [M:CST]NBITM-1
             If [M:CST]ITMREF(K)=[M:CST]ITMREF(I) & [M:CST]ITMTYP(K)=2
                If [M:CST]ILNK(K)=[M:CST]ILNK(PIND)
                  For J=0 To GACTMAT-1
                      [F:MCC]MATCST(J) += [M:CST]IMATCST(K*GACTMAT+J) / LCOELNK
                   Next J
                   For J=0 To GACTMAC-1
                      [F:MCC]MACCST(J) += [M:CST]IMACCST(K*GACTMAC+J) / LCOELNK
                   Next J
                   For J=0 To GACTLAB-1
                      [F:MCC]LABCST(J) += [M:CST]ILABCST(K*GACTLAB+J) / LCOELNK
                   Next J
                   [F:MCC]SCOCST    += [M:CST]ISCOCST(K) / LCOELNK
                   [F:MCC]INVDTACST += [M:CST]IINVDTA(K) / LCOELNK
                   [F:MCC]OVEMATCST += [M:CST]IOVEMATCST(K) / LCOELNK
                   [F:MCC]OVEMACCST += [M:CST]IOVEMACCST(K) / LCOELNK
                   [F:MCC]OVELABCST += [M:CST]IOVELABCST(K) / LCOELNK
                   [F:MCC]OVESCOCST += [M:CST]IOVESCOCST(K) / LCOELNK
                Elsif [M:CST]ILNK(K)=0
                   For J=0 To GACTMAT-1
                      [F:MCC]MATCST(J) += [M:CST]IMATCST(K*GACTMAT+J) * LCOE0
                   Next J
                   For J=0 To GACTMAC-1
                      [F:MCC]MACCST(J) += [M:CST]IMACCST(K*GACTMAC+J) * LCOE0
                   Next J
                   For J=0 To GACTLAB-1
                      [F:MCC]LABCST(J) += [M:CST]ILABCST(K*GACTLAB+J) * LCOE0
                   Next J
                   [F:MCC]SCOCST    += [M:CST]ISCOCST(K) * LCOE0
                   [F:MCC]INVDTACST += [M:CST]IINVDTA(K) * LCOE0
                   [F:MCC]OVEMATCST += [M:CST]IOVEMATCST(K) * LCOE0
                   [F:MCC]OVEMACCST += [M:CST]IOVEMACCST(K) * LCOE0
                   [F:MCC]OVELABCST += [M:CST]IOVELABCST(K) * LCOE0
                   [F:MCC]OVESCOCST += [M:CST]IOVESCOCST(K) * LCOE0
                Endif
             Endif
           Next
#       Endif

        [F:MCC]VLTTOT = sum([F:MCC]MATCST)+sum([F:MCC]MACCST)+sum([F:MCC]LABCST)
&                     + [F:MCC]SCOCST+[F:MCC]INVDTACST+[F:MCC]OVEMATCST+[F:MCC]OVEMACCST+[F:MCC]OVELABCST+[F:MCC]OVESCOCST
        If LEXI
            Rewrite [MCC]
        Else
            Write [MCC]
        Endif
        If fstat
            PRET=1 : Break
        Endif
    Endif
Next

If LTRANSAC
    If PRET
        Rollback
    Else
        Commit
    Endif
Endif
If PRET
    ERR_TRA = mess(14,100,1) - [F:MCC]ITMREF - mess(4,438,1)+":"+[F:MCC]MATREF
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    End
Endif

If LTRANSAC
    Trbegin [MCC]
Endif

For I=0 To [M:CST]NBMAT-1
  If find([M:CST]MLNK(I),[M:CST]ILNK(PIND),0)
    If !sigma(0,I-1,[M:CST]MATREF(indcum)=[M:CST]MATREF(I)
&                 & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
&                 & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
&                 & ([M:CST]MLNK(indcum)=[M:CST]ILNK(PIND) | [M:CST]MLNK(indcum)=0))
#&    & ([M:CST]MLNK(I)=[M:CST]ILNK(PIND) | [M:CST]MLNK(I)=0)
        Readlock [F:MCC]MCC0=[M:CST0]STOFCY;PITM;[M:CTP]VCRTYP;[M:CTP]VCRNUM;[M:CST]ILNK(PIND);PTYP;[M:CST]MATREF(I);[M:CST]MECCVALMAJ(I);[M:CST]MECCVALMIN(I);adxuid(1)
        If !fstat
            LEXI=1
            # Issue 119469 GH 04/11/16 - performance enhancement
            Raz [F:MCC]QTYSTU
            Raz [F:MCC]SCOCST, [F:MCC]INVDTACST, [F:MCC]OVEMATCST, [F:MCC]OVEMACCST, [F:MCC]OVELABCST, [F:MCC]OVESCOCST
            Raz [F:MCC]MATCST
            Raz [F:MCC]MACCST
            Raz [F:MCC]LABCST
        Else
            LEXI=0
            Raz [F:MCC]
            [F:MCC]STOFCY = [M:CST0]STOFCY
            [F:MCC]ITMREF = PITM
            [F:MCC]VCRTYP = [M:CTP]VCRTYP
            [F:MCC]VCRNUM = [M:CTP]VCRNUM
            [F:MCC]VCRLIN = [M:CST]ILNK(PIND)
            [F:MCC]MFCTYP = PTYP
            [F:MCC]MATREF = [M:CST]MATREF(I)
            [F:MCC]ECCVALMAJ = [M:CST]MECCVALMAJ(I)
            [F:MCC]ECCVALMIN = [M:CST]MECCVALMIN(I)
            [F:MCC]UID    = adxuid(1)
        Endif
        [F:MCC]SCOFLG = max(1,[M:CST]SCOFLG(I))
        [F:MCC]YEA    = PYEA
        [F:MCC]CPNTYP = 1

# Issue 119469 GH 04/11/16 - performance enhancement
#        [F:MCC]QTYSTU = sigma(0,[M:CST]NBMAT-1, ([M:CST]MATREF(indcum)=[M:CST]MATREF(I)
#&                                              & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
#&                                              & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
#&                                              & [M:CST]MLNK(indcum)=[M:CST]ILNK(PIND)) * [M:CST]MQTYSTU(indcum))
#        If LQTYTOT<>0
#            [F:MCC]QTYSTU += sigma(0,[M:CST]NBMAT-1, ([M:CST]MATREF(indcum)=[M:CST]MATREF(I)
#&                                                   & [M:CST]MECCVALMAJ(indcum)=[M:CST]MECCVALMAJ(I)
#&                                                   & [M:CST]MECCVALMIN(indcum)=[M:CST]MECCVALMIN(I)
#&                                                   & [M:CST]MLNK(indcum)=0) * [M:CST]MQTYSTU(indcum))*LQTYLIN / LQTYTOT
#        Endif
        For K=0 To [M:CST]NBMAT-1
            If [M:CST]MATREF(K)=[M:CST]MATREF(I)
&            & [M:CST]MECCVALMAJ(K)=[M:CST]MECCVALMAJ(I)
&            & [M:CST]MECCVALMIN(K)=[M:CST]MECCVALMIN(I)
               If [M:CST]MLNK(K)=[M:CST]ILNK(PIND)
                  [F:MCC]QTYSTU += [M:CST]MQTYSTU(K)
               Elsif [M:CST]MLNK(K)=0 & LQTYTOT<>0
                  [F:MCC]QTYSTU += [M:CST]MQTYSTU(K) * LQTYLIN / LQTYTOT
               Endif
            Endif
        Next

        [F:MCC]STU    = [M:CST]MSTU(I)
        [F:MCC]BRDCOD = [M:CST]MBRDCOD(I)
        [F:MCC]CSTCOD = [M:CST]MCSTCOD(I)

        LCOELNK = [F:MCC]QTYSTU
        If LCOELNK = 0 : LCOELNK=1 : Endif
        If LQTYTOT=0
            LCOE0=1
        Else
            LCOE0   = LQTYLIN / (LQTYTOT * LCOELNK)
        Endif

# Issue 119469 GH 04/11/16 - performance enhancement
#        For J=0 To GACTMAT-1
#            [F:MCC]MATCST(J) = sigma(0,[M:CST]NBMAT-1, ([M:CST]MATREF(indcum)=[M:CST]MATREF(I)
