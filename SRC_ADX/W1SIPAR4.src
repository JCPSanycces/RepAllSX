Subprog B1_VACBPS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNTVB
 Call TUNTVB(VALEUR,GCURLEG) From SUBTVB
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_VACBPS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TVB"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_VACBPS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TVB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZVACBPS
Onevent BEFORE_AREA Gosub AV_ZVACBPS From W1SIPAR4
Return

$AV_ZVACBPS
Call LECTEXTRA(zc,"TABVACBPR","SHOAXX",num$([M]VACBPS(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_FOUEXI
Onevent INIT_AREA Call D_FOUEXI(zc) From W1SIPAR4
Return

Subprog D_FOUEXI(VALEUR)
Variable Integer VALEUR
If varinit([M]FOUEXI,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_VATADD
Return

$CHG_STY
Return


