#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTITRS16   UTI process                                    Module TRS   #
#            correction utility
#    TRS for module :  must be replaced (GPA ACH STO ...)
#    16  number of sequence : must be replaced (01 02 ...)
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS16(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS16(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS16 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:HMD])  =0  Local File =DOSSIER+".HISTOMDT"  [HMD] : Endif
If clalev([F:ADI])  =0  Local File =DOSSIER+".ATABDIV"   [ADI] : Endif

If clalev([F:AXX16])>0 Close Local File [AXX16] : Endif
Local File =DOSSIER+".ATEXTRA"   [AXX16]


WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [HMD]

Update [HMD] Where SEQTYP="FNAL" With SEQTYP="FNA"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [HMD] Where SEQTYP="FRST" With SEQTYP="FRS"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [HMD] Where SEQTYP="OOFF" With SEQTYP="OOF"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [HMD] Where SEQTYP="RCUR" With SEQTYP="RCU"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Call ECR_TRACE("UTITRS16 : HISTOMDT "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

WCOMPTEUR = 0
Update [ADI] Where NUMTAB=330  & CODE="FNAL" With CODE="FNA"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [ADI] Where NUMTAB=330  & CODE="FRST" With CODE="FRS"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [ADI] Where NUMTAB=330  & CODE="OOFF" With CODE="OOF"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [ADI] Where NUMTAB=330  & CODE="RCUR" With CODE="RCU"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Call ECR_TRACE("UTITRS16 : ATABDIV-330 (CODE) "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

WCOMPTEUR = 0
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="330" & IDENT2="FNAL"  With IDENT2="FNA"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="330" & IDENT2="FRST"  With IDENT2="FRS"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="330" & IDENT2="OOFF"  With IDENT2="OOF"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="330" & IDENT2="RCUR"  With IDENT2="RCU"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="330" & IDENT2="FNAL"  With IDENT2="FNA"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="330" & IDENT2="FRST"  With IDENT2="FRS"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="330" & IDENT2="OOFF"  With IDENT2="OOF"
If !fstat : WCOMPTEUR+=adxuprec : Endif
Update [AXX16] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="330" & IDENT2="RCUR"  With IDENT2="RCU"
If !fstat : WCOMPTEUR+=adxuprec : Endif

Call ECR_TRACE("UTITRS16 : ATEXTRA "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

WCOMPTEUR = 0
Filter [ADI] Where NUMTAB=330 & A1=""
For [ADI]
 Case [F:ADI]CODE
  When "FNA","FNAL" : [F:ADI]A1 = "FNAL"
  When "FRS","FRST" : [F:ADI]A1 = "FRST"
  When "OOF","OOFF" : [F:ADI]A1 = "OOFF"
  When "RCU","RCUR" : [F:ADI]A1 = "RCUR"
 Endcase
 Rewrite [F:ADI]
 If !fstat WCOMPTEUR += 1 Endif
Next
Filter [ADI]
Call ECR_TRACE("UTITRS16 : ATABDIV-330 (A1) "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN


Commit

Close Local File [HMD]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS16 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If filinfo(filpath("FIL","HISTOMDT","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS16(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If filinfo(filpath("FIL","HISTOMDT","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS16(APPLI)
End

