#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: COFA
# Description : Certificate of Analysis Report Preprocessor
# Author      : Ron Halcrow
# Date        : November 18th, 2013
####################################################################################

$ACTION
Case ACTION
   When Default  :
Endcase
Return

###########################################################################
$FIN

Return

###########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End


###########################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

# Based on the parameters passed (report selection criteria), create the information
# to filter on.
[L]CRITERE = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
   [L]PARAM  = left$([L]PARAMETRE(I),J-1)
   [L]VALEUR = right$([L]PARAMETRE(I),J+1)
   Case [L]PARAM
      When "X3ETA"     : [L]ETAT     = [L]VALEUR
      When "__REQUETE" : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"   : SITEMIN     = [L]VALEUR
      When "sitefin"   : SITEMAX     = [L]VALEUR
      When "sdhdeb"    : [L]CRITERE -= "& SDHNUM>='"+[L]VALEUR+"'"
      When "sdhfin"    : [L]CRITERE -= "& SDHNUM<='"+[L]VALEUR+"'"
      When "itmrefdeb" : ITMREFMIN   = [L]VALEUR
      When "itmreffin" : ITMREFMAX   = [L]VALEUR
      When "lotdeb"    : LOTMIN      = [L]VALEUR
      When "lotfin"    : LOTMAX      = [L]VALEUR
   Endcase
 Endif
Next

Trbegin [CAW]
Delete [F:CAW] Where COFAUID = adxuid(1) or CREDAT < date$-1
Commit

Filter [F:SDH] Where evalue([L]CRITERE)

For [SDH]
    Case [F:SDH]CFMFLG
            When 2       : # Shipment Validated
                           Gosub ADD_XAN_V
            When Default : # Shipmnet NOT Validated
                           Gosub ADD_XAN_NV
    Endcase
Next
Filter [SDH]

End

####################################################
$ADD_XAN_NV
# Shipment NOT validated.
Filter [F:SDD] Where SDHNUM = [F:SDH]SDHNUM
For [SDD]
    # Check if the item is in the specified range
    If ([F:SDD]ITMREF < ITMREFMIN | [F:SDD]ITMREF > ITMREFMAX) : Goto SDD_NEXT : Endif

    # Check Item if it is lot managed and QC managed
    Read [F:ITM]ITM0 = [F:SDD]ITMREF
    If fstat : Goto SDD_NEXT : Endif
    If [F:ITM]LOTMGTCOD = 1 : Goto SDD_NEXT : Endif : # Item not lot managed no COFA

    # Issue X3-69499 - 2018-05-18 by TS
    If [F:SDD]LINCFMFLG=2

        Filter [STJ] Where ITMREF=[F:SDD]ITMREF & STOFCY=[F:SDD]STOFCY & VCRNUM=[F:SDD]SDHNUM & VCRLIN=[F:SDD]SDDLIN & VCRTYP=4
        For [STJ]

            If ([F:STJ]LOT < LOTMIN | [F:STJ]LOT > LOTMAX) : Goto STJ_NEXT2 : Endif

            If [F:STJ]LOT <> ""
                Filter [QLD] Where ITMREF=[F:STJ]ITMREF & LOT=[F:STJ]LOT & ([F:QLD]STOFCY >= SITEMIN & [F:QLD]STOFCY <= SITEMAX)

                Read [F:QLD] Last
                If !fstat
                    # Add COFAWRK record
                    Trbegin [CAW]
                    Raz [F:CAW]
                    [F:CAW]SDHNUM  = [F:SDD]SDHNUM
                    [F:CAW]SDDLIN  = [F:SDD]SDDLIN
                    [F:CAW]ITMREF  = [F:STJ]ITMREF
                    [F:CAW]LOT     = [F:STJ]LOT
                    [F:CAW]VCRNUM  = [F:QLD]VCRNUM
                    [F:CAW]VCRLIN  = [F:QLD]VCRLIN
                    [F:CAW]COFAUID = adxuid(1)
                    [F:CAW]CREUSR  = GUSER
                    [F:CAW]CREDAT  = date$
                    Write [CAW]
                    If fstat
                        Rollback
                    Else
                        Commit
                    Endif
                Endif
                Filter [QLD]
            Endif
        $STJ_NEXT2
        Next
        Filter [STJ]

    Else
    # End issue X3-69499 - 2018-05-18 by TS

        Link [STA] With [STO]STO0=STOFCY;STOCOU As [LNK]
&                Where [F:STA]VCRNUM = [F:SDD]SDHNUM
&                  and [F:STA]VCRLIN = [F:SDD]SDDLIN
&                  and [F:STA]STOFCY = [F:SDD]STOFCY
&                Order By [F:STO]LOT
        For [LNK]
            If ([F:STO]LOT < LOTMIN | [F:STO]LOT > LOTMAX) : Goto LNK_NEXT : Endif

            Filter [QLD] Where ITMREF=[F:STO]ITMREF & LOT=[F:STO]LOT & ([F:QLD]STOFCY >= SITEMIN & [F:QLD]STOFCY <= SITEMAX)

            Read [F:QLD] Last
            If !fstat
                Trbegin [CAW]
                # Add a record to COFAWRK
                Raz [F:CAW]
                [F:CAW]SDHNUM  = [F:SDD]SDHNUM
                [F:CAW]SDDLIN  = [F:SDD]SDDLIN
                [F:CAW]ITMREF  = [F:STO]ITMREF
                [F:CAW]LOT     = [F:STO]LOT
                [F:CAW]VCRNUM  = [F:QLD]VCRNUM
                [F:CAW]VCRLIN  = [F:QLD]VCRLIN
                [F:CAW]COFAUID = adxuid(1)
                [F:CAW]CREUSR  = GUSER
                [F:CAW]CREDAT  = date$
                Write [CAW]
                If fstat
                    Rollback
                Else
                    Commit
                Endif
            Endif
            Filter [QLD]
        $LNK_NEXT
        Next

    # Issue X3-69499 - 2018-05-18 by TS
    Endif


$SDD_NEXT
Next
Filter [SDD]

Return

####################################################
$ADD_XAN_V
# Shipment validated. To find lot must filter STOJOU records
# vcrtyp = 4

Filter [SDD] Where SDHNUM = [F:SDH]SDHNUM
For [SDD]
    # Check if the item is in the specified range
    If ([F:SDD]ITMREF < ITMREFMIN | [F:SDD]ITMREF > ITMREFMAX) : Goto SDD_NEXT2 : Endif

    # Check Item if it is lot managed and QC managed
    Read [F:ITM]ITM0 = [F:SDD]ITMREF
    If fstat : Goto SDD_NEXT2 : Endif
    If [F:ITM]LOTMGTCOD = 1 : Goto SDD_NEXT2 : Endif : # Item not lot managed, no COFA

    Filter [STJ] Where ITMREF=[F:SDD]ITMREF & STOFCY=[F:SDD]STOFCY & VCRNUM=[F:SDD]SDHNUM & VCRLIN=[F:SDD]SDDLIN & VCRTYP=4
    For [STJ]

        If ([F:STJ]LOT < LOTMIN | [F:STJ]LOT > LOTMAX) : Goto STJ_NEXT : Endif

       If [F:STJ]LOT <> ""
            Filter [QLD] Where ITMREF=[F:STJ]ITMREF & LOT=[F:STJ]LOT & ([F:QLD]STOFCY >= SITEMIN & [F:QLD]STOFCY <= SITEMAX)

            Read [F:QLD] Last
            If !fstat
                # Add COFAWRK record
                Trbegin [CAW]
                Raz [F:CAW]
                [F:CAW]SDHNUM  = [F:SDD]SDHNUM
                [F:CAW]SDDLIN  = [F:SDD]SDDLIN
                [F:CAW]ITMREF  = [F:STJ]ITMREF
                [F:CAW]LOT     = [F:STJ]LOT
                [F:CAW]VCRNUM  = [F:QLD]VCRNUM
                [F:CAW]VCRLIN  = [F:QLD]VCRLIN
                [F:CAW]COFAUID = adxuid(1)
                [F:CAW]CREUSR  = GUSER
                [F:CAW]CREDAT  = date$
                Write [CAW]
                If fstat
                    Rollback
                Else
                    Commit
                Endif
            Endif
            Filter [QLD]
        Endif
$STJ_NEXT
    Next
    Filter [STJ]

$SDD_NEXT2
Next
Filter [SDD]

Return

###########################################################################
$OUVRE

If !clalev([F:CAW]) : Local File COFAWRK        [CAW] : Endif
If !clalev([F:SDH]) : Local File SDELIVERY      [SDH] : Endif
If !clalev([F:SDD]) : Local File SDELIVERYD     [SDD] : Endif
If !clalev([F:STA]) : Local File STOALL         [STA] : Endif
If !clalev([F:STO]) : Local File STOCK          [STO] : Endif
If !clalev([F:STJ]) : Local File STOJOU         [STJ] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER      [ITM] : Endif
If !clalev([F:QLD]) : Local File STOQLYD        [QLD] : Endif

Return


###########################################################################
$DECLARE

Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15)
Local Char    SITEMIN(GLONFCY),SITEMAX(GLONFCY)
Local Char    ITMREFMIN(GLONITM), ITMREFMAX(GLONITM)
Local Char    LOTMIN(GLONLOT), LOTMAX(GLONLOT)
Local Integer NUMREQ

Return

