#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TTN1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TNHTYP
mkstat = 0
zoncou = "TNHTYP"
indice = 0
If varmode([M]TNHTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TNHTYP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TNHTYP,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TNHTYP" : GZNUM = 680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTTTN"
  Call CONTTTN([M]TNHTYP,"","TTN1","TNHTYP","","","") From SUBTTN
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TNHTYP" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]TNHTYP
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]TNHTYP = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TNHTYP" : GZNUM = 680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJW"
    PARAM(1) = "TTN"
    Local Char    VALEUR(250)
    VALEUR = [M]TNHTYP
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
    [M]TNHTYP = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "TNHTYP" : GZNUM = 680 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTLEG"
    Call CONTLEG([M]LEG) From SUBADI
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_LEG([M]LEG) From SUBTTN
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]LEG or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_LEG([M]LEG) From SUBTTN
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"TABTNHTYP","DESAXX",[M:TTN1]TNHTYP,[M:TTN1]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"TABTNHTYP","SHOAXX",[M:TTN1]TNHTYP,[M:TTN1]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]SHOAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SHOAXX" : GZNUM = 4010 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone GFY
mkstat = 0
zoncou = "GFY"
indice = 0
WCHAR = [M]GFY
If varmode([M]GFY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GFY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!",[M]GFY,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GFY" : GZNUM = 616 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTGRPLEG"
  Call CTLGFYLEG([M]GFY,string$(GLEGACT=1,GDOSLEG)+string$(GLEGACT=2,[M:TTN1]LEG),"TTN1","GFY") From TRTVENCTL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GFY" : GZNUM = 616 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_GFY([M]GFY) From SUBTTN
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GFY" : GZNUM = 616 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]GFY or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_GFY([M]GFY) From SUBTTN
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "GFY" : GZNUM = 616 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone MANCOU
mkstat = 0
zoncou = "MANCOU"
indice = 0
IMPENT = [M]MANCOU
If varinit([M]MANCOU,indice)=0
 IMPENT = 1
Endif
If varmode([M]MANCOU,indice)=0
 [M]MANCOU(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MANCOU" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MANCOU(indice)
 Endif
Endif
[M]MANCOU = IMPENT

## Zone DATUPDFLG
mkstat = 0
zoncou = "DATUPDFLG"
indice = 0
IMPENT = [M]DATUPDFLG
If varinit([M]DATUPDFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]DATUPDFLG,indice)=0
 [M]DATUPDFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATUPDFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DATUPDFLG(indice)
 Endif
Endif
[M]DATUPDFLG = IMPENT

## Zone CODNUM
mkstat = 0
zoncou = "CODNUM"
indice = 0
If varmode([M]CODNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODNUM" : GZNUM = 771 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("ANM","",[M]CODNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CODNUM" : GZNUM = 771 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CODNUM([M]CODNUM) From SUBTTN
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODNUM" : GZNUM = 771 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CODNUMEND
mkstat = 0
zoncou = "CODNUMEND"
indice = 0
If varmode([M]CODNUMEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODNUMEND" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ANM","!",[M]CODNUMEND,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODNUMEND" : GZNUM = 1004273 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CODNUMEND([M]CODNUMEND) From SUBTTN
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODNUMEND" : GZNUM = 1004273 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone RECTYP
mkstat = 0
zoncou = "RECTYP"
indice = 0
IMPENT = [M]RECTYP
If varinit([M]RECTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RECTYP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RECTYP(IMPENT) From SUBTTN
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]RECTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RECTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RECTYP(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "RECTYP" : GZNUM = 7515 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]RECTYP = IMPENT

## Zone SAFTTRNTYP
mkstat = 0
zoncou = "SAFTTRNTYP"
indice = 0
IMPENT = [M]SAFTTRNTYP
If varinit([M]SAFTTRNTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]SAFTTRNTYP,indice)=0
 Call INICOMBO(2046) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SAFTTRNTYP(IMPENT) From SUBTTN
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2046,1))))
 Endif
 [M]SAFTTRNTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SAFTTRNTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SAFTTRNTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SAFTTRNTYP" : GZNUM = 52667 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SAFTTRNTYP = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TTN1"
Return

