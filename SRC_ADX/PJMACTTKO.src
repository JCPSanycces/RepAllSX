#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMACTTKO
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"             : Gosub OUVRE
    When "DEBUT"             : Gosub DEBUT
    When "FIN"               : Gosub FIN
    When "AVANT_BOUTON"      : Gosub AVANT_BOUTON          # Issue X3-99928 - 2018-07-19 by ALMON
    When "SETBOUT"           : Gosub SETBOUT
    When "BOUTON"            : Gosub BOUTON
    When "APRES_MODIF"       : Gosub APRES_MODIF
    When "ENR"               : Gosub ENR
    When "ABA"               : Gosub ABANDON
    When "NEW"               : Gosub NEW
    When "SUP"               : Gosub SUP
    When "SUI"               : Gosub SUI
    When "PRE"               : Gosub PRE
    When "LAS"               : Gosub LAS
    When "FIR"               : Gosub FIR
    When "AP_CHOIX"          : Gosub AP_CHOIX
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

##########################################################################################################
$DEBUT
Local Integer NCOLTKO
Local Integer NTASLIN
Local Char SVRTKOREP(type(REP)-10)

  # -------------------------------
  # Carreful : previous screen is in update mode (GREP="M").
  # So this one have to copy values in classes.
  # But "Save" action will be done on the previous screen.
  # Consequency, before go back to the previous screen, it will be necessary to reload it from the class
  # (probably in "END" actions).
  # "ENR" action will not save in tables, but only copy values from the screen in classes
  #      => maybe it would be better to use another button for that : OK ?
  # "ABA" will reload values in the screen from the class
  # Navigation ("SUP", "SUI", "PRE", "LAS", "FIR" actions) will move on the lines of the operations classes
  # -------------------------------
  NCOLTKO = val(PARAM(1))
  NTASLIN = val(PARAM(2))
  # -------------------------------
  # Copy the previous screen in the class.
  # This one will work with the class : so class have to have all last values.
  Call COPY_SCREEN_TO_CLASS() From PJMACTTAS
  Call LOAD_SCREEN(NTASLIN, NCOLTKO)
  # -------------------------------
Return

##########################################################################################################
$FIN
Local Char STUNTAS(GLONTAC)

  If REP <> AVOID.ACHAR Then
    GMESSAGE = mess(162,2260,1)
    GERR = 1
    FIN = 0
    BOX = 0
    Return
  Endif
  STUNTAS = [M:PJTA0A]TASCOD # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Gosub LOAD_PAGE From PJMACTTAS
Return

##########################################################################################################
$AVANT_BOUTON
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "1"
      # "Change status"
      If func SUBPJMA.GET_AUTHORIZATION("O") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

##########################################################################################################
$SETBOUT
  If REP <> AVOID.ACHAR Then
    Call VIREBOUT(CHMEN,"1") From GOBJET
    Call VIREBOUT(CHMEN,"*") From GOBJET
  Endif
  # -------------------------------
  CHBOU += "N"     # To not deactive "New" button
  If fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO_EXISTING() = [V]CST_AYES Then
    CHBOU += "S"   # To not deactive "Delete" button
    CHBOU += "0"   # To not deactive "First" button
    CHBOU += "9"   # To not deactive "Last" button
    CHBOU += "<"   # To not deactive "Back" button
    CHBOU += ">"   # To not deactive "Next" button
  Endif
  # -------------------------------
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "1"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call LOAD_SCREEN(NTASLIN, NCOLTKO)
    When Default
  Endcase
Return

##########################################################################################################
$APRES_MODIF
  REP = "M"
Return

##########################################################################################################
$ENR
Local Integer MY_STATUS

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # --------------------------------
  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      GERR = 1
      REP = "M"
      Return
    Endif
  Endif
  Gosub RELIT_GZINSPJM From SUBPJMA
  # --------------------------------
  Call LOAD_SCREEN(NTASLIN, NCOLTKO)
  Raz REP
  Raz SVRTKOREP
  # --------------------------------
Return

##########################################################################################################
$ABANDON
  NCOLTKO = val(PARAM(1))
  Gosub RELIT_GZINSPJM From SUBPJMA    # Reload the project
  Call LOAD_SCREEN(NTASLIN, NCOLTKO)   # Display the current operation
  Raz REP
  Raz SVRTKOREP
Return

##########################################################################################################
$NEW
Local Integer ILINE

  ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).ADDLINE("RTKO", [V]CST_ALASTPOS)
  If ILINE = [V]CST_ANOTDEFINED Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    NCOLTKO = ILINE
    Call LOAD_SCREEN(NTASLIN, NCOLTKO)
    REP = "M"
  Endif
Return

##########################################################################################################
$SUP
Local Integer IRET

  IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).ADELLINE("RTKO", GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    If REP = AVOID.ACHAR Then
      REP = "M"
    Endif
    SVRTKOREP = REP
    If fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO_EXISTING() = [V]CST_AYES Then
      Gosub FIR
    Else
      Effzo [M:PJTAC0]
      Effzo [M:PJTAC0A]      # Issue X3-99916 - 2018-07-12 by FGR
      Effzo [M:PJTAC0B]      # Issue X3-99916 - 2018-07-12 by FGR
      Effzo [M:PJTAC0C]      # Issue X3-99916 - 2018-07-12 by FGR
      Effzo [M:PJTAC0D]      # Issue X3-99916 - 2018-07-12 by FGR
      Effzo [M:PJTAC1]
      Effzo [M:PJTAC2]       # Issue X3-99916 - 2018-07-12 by FGR : was missing
      [M:PJTAC0]TASLIN = NTASLIN
    Endif
  Endif
Return

##########################################################################################################
$SUI
Local Integer NI

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  For NI = [M:PJTAC0]COLLIN+1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO)
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO <> null and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NCOLTKO = NI
      Call LOAD_SCREEN(NTASLIN, NCOLTKO)
      Break
    Endif
  Next NI
  REP = SVRTKOREP
Return

##########################################################################################################
$PRE
Local Integer NI

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  For NI = [M:PJTAC0]COLLIN-1 To 1 Step -1
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO <> null and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NCOLTKO = NI
      Call LOAD_SCREEN(NTASLIN, NCOLTKO)
      Break
    Endif
  Next NI
  REP = SVRTKOREP
Return

##########################################################################################################
$LAS
Local Integer NI

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  For NI = maxtab(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO) To 1 Step -1
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO <> null and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NCOLTKO = NI
      Call LOAD_SCREEN(NTASLIN, NCOLTKO)
      Break
    Endif
  Next NI
  REP = SVRTKOREP
Return

##########################################################################################################
$FIR
Local Integer NI

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO)
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO <> null and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NCOLTKO = NI
      Call LOAD_SCREEN(NTASLIN, NCOLTKO)
      Break
    Endif
  Next NI
  REP = SVRTKOREP
Return

##########################################################################################################
$AP_CHOIX
  If find(REPONSE, GSTAEND) Then
    If REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      Return
    Endif
  Elsif find(REPONSE, GSTANEW) Then
    # To deactivate the question to lost current not updated information
    SVRTKOREP = REP
    Raz REP
  Elsif find(REPONSE, GSTASUI, GSTAPRE, GSTAFIR, GSTALAS) Then
    If REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      SVRTKOREP = REP
      Raz REP
      Return
    Endif
  Endif
Return

##########################################################################################################
# SUBROUTINES / FUNCTIONS
##########################################################################################################
Subprog LOAD_SCREEN(ITASLIN, ICOLLIN)
Value Integer ITASLIN
Value Integer ICOLLIN

  Raz [M:PJTAC0]
  Raz [M:PJTAC0A]  # Issue X3-99916 - 2018-07-12 by FGR
  Raz [M:PJTAC0B]  # Issue X3-99916 - 2018-07-12 by FGR
  Raz [M:PJTAC0C]  # Issue X3-99916 - 2018-07-12 by FGR
  Raz [M:PJTAC0D]  # Issue X3-99916 - 2018-07-12 by FGR
  Raz [M:PJTAC1]
  Raz [M:PJTAC2]
  [M:PJTAC0]TASLIN = ITASLIN
  # -----------------------------
  Call SHOW_RTKO_LINE(ICOLLIN)
  Call LOAD_AFFECTATION()
  Call LOAD_LINKS()
  # -----------------------------
  Affzo [M:PJTAC0]1-99
  Affzo [M:PJTAC0A]1-99      # Issue X3-99916 - 2018-07-12 by FGR
  Affzo [M:PJTAC0B]1-99      # Issue X3-99916 - 2018-07-12 by FGR
  Affzo [M:PJTAC0C]1-99      # Issue X3-99916 - 2018-07-12 by FGR
  Affzo [M:PJTAC0D]1-99      # Issue X3-99916 - 2018-07-12 by FGR
  Affzo [M:PJTAC1]1-99
  Affzo [M:PJTAC2]1-99
End

##########################################################################################################
Subprog LOAD_AFFECTATION()

Local Integer NI

  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT)
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI) <> null
&      and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_RAFFT_LINE(NI)
    Endif
  Next NI
  [M:PJTAC1]NBAFFECT = nolign
End

##########################################################################################################
Subprog LOAD_LINKS()

Local Integer NI

  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK)
    If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI) <> null and
&      find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_OPLNK_LINE(NI)
    Endif
  Next NI
  [M:PJTAC2]NBPJTAC2 = nolign
End

##########################################################################################################
Subprog SHOW_RTKO_LINE(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJTAC0] With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(VNLINE)
  SetInstance [M:PJTAC0A] With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(VNLINE)        # Issue X3-99916 - 2018-07-12 by FGR
  SetInstance [M:PJTAC0B] With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(VNLINE)        # Issue X3-99916 - 2018-07-12 by FGR
  SetInstance [M:PJTAC0C] With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(VNLINE)        # Issue X3-99916 - 2018-07-12 by FGR
  SetInstance [M:PJTAC0D] With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO(VNLINE)        # Issue X3-99916 - 2018-07-12 by FGR
  [M:PJTAC0]COLLIN = VNLINE   # Line index in the collection
   # ------------------------------------
  If [M:PJTAC0A]EXTWST <> AVOID.ACHAR Then                                               # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
    Call LECTEXTRA([M:PJTAC0A]WSTDES, "WORKSTATIO", "WSTDESAXX", [M:PJTAC0A]EXTWST, [M:PJTAC0]TASFCY) From ATEXTRA      # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
  Endif
  If [M:PJTAC0A]EXTLAB <> AVOID.ACHAR Then                                               # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
    Call LECTEXTRA([M:PJTAC0A]LABWSTDES, "WORKSTATIO", "WSTDESAXX", [M:PJTAC0A]EXTLAB, [M:PJTAC0]TASFCY) From ATEXTRA   # Issue X3-99916 - 2018-07-12 by FGR : not [M:PJTAC0] from now
  Endif
  # ------------------------------------
  Call CHGTZN_OPECST() From SUBPJTAC
  Call CHGTZN_OPECST2() From SUBPJTAC
  # ------------------------------------
End

##########################################################################################################
Subprog SHOW_RAFFT_LINE(VNLINE)
Value Integer VNLINE

Local Char KEYCONCAT(250)
Local Integer IPOANUM

  SetInstance [M:PJTAC1]55 With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(VNLINE)
  [M:PJTAC1]COLLIN(nolign-1) = VNLINE     # Line index in the collection
  # ------------------------------------
  KEYCONCAT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(VNLINE).KEYCONCAT
  IPOANUM = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).RAFFT(VNLINE).POANUM
  [M:PJTAC1]BTNDES(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                                        func PJMOPEAFF_CSTD_PROGS.POALGDES_EXIST(GZINSPJM.ACTX, KEYCONCAT, IPOANUM) = [V]CST_AYES or
&                                                                        func PJMOPEAFF_CSTD_PROGS.POALGCOM_EXIST(GZINSPJM.ACTX, KEYCONCAT, IPOANUM) = [V]CST_AYES)
  # ------------------------------------
End

##########################################################################################################
Subprog SHOW_OPLNK_LINE(VNLINE)
Value Integer VNLINE

Local Integer ILINE

  SetInstance [M:PJTAC2]5 With GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).OPLNK(VNLINE)
  [M:PJTAC2]COLLIN(nolign-1) = VNLINE
  # ------------------------------------
  If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(VNLINE).OPENUMLNK > 0 and GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(VNLINE).OPESPNUMLNK > 0 Then
    ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO_GET_INDEX(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(VNLINE).OPENUMLNK,
&                                                                    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(VNLINE).OPESPNUMLNK)
    [M:PJTAC2]COLLINLNK(nolign-1) = ILINE
    [M:PJTAC2]STRDAT(nolign-1) = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC2]COLLINLNK(nolign-1)).OPESTR
    [M:PJTAC2]ENDDAT(nolign-1) = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC2]COLLINLNK(nolign-1)).OPEEND
    [M:PJTAC2]OPEDESLNK(nolign-1) = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC2]COLLINLNK(nolign-1)).ROODESAXX # Issue X3-69355 - 2017-12-21 by FGR
  Endif
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer ASTATUS
Local Integer ILINE
Local Integer NI

  # Lignes affectation utilisateurs
  # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT)
    If GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI) <> null
&      and find(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI).AUUID), [M:PJTAC1]AUUID(0..[M:PJTAC1]NBAFFECT-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:PJTAC1]COLLIN(0..[M:PJTAC1]NBAFFECT-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).ADELLINE("RAFFT",GZINSPJM.PJM(1).TAS([M:PJTAC0]TASLIN).RTKO([M:PJTAC0]COLLIN).RAFFT(NI).AORDER)
        If [L]ASTATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ----------------------------------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK)
    If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI) <> null
&      and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI).AUUID), [M:PJTAC2]AUUID(0..[M:PJTAC2]NBPJTAC2-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:PJTAC2]COLLIN(0..[M:PJTAC2]NBPJTAC2-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).ADELLINE("OPLNK",GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTAC0]COLLIN).OPLNK(NI).AORDER)
        If [L]ASTATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  # ----------------------------------------------------------
End

