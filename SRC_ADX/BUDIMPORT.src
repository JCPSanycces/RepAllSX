#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("BUD") From GIMPOBJ
End

$ACTION
# It is a special import
# BUDIMPORT screen is related to BUDIMPORT script

Return

#################################################################
$OUVRE
Local Mask BUDIMPORT    [BUD1]

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY]  : Endif
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:CYM])=0  : Local File GCCEPYM    [CYM]  : Endif
If clalev([F:BUD2])=0 : Local File BUD        [BUD2] : Endif
If clalev([F:BUD3])=0 : Local File BUD        [BUD3] : Endif

Local Char    MESSA(250)
Local Char    NUMCPT (GLONVCR)          : # No pour compteur d'OD budgétaires
Local Integer NBAXE, STA, MODIF
Local Integer I, INDAXE
Local Integer IND, INDPYM
Local Char    LEDCOD(GLONLED), LEDCUR(GLONCUR), WDIE(GLONDIE), WCCE(GLONCCE)
Local Char    KEYBUD (250)

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Char    ERRMES(250)
Return

#################################################################
$RAZCRE
Raz [BUD1]
Return

#################################################################
$SAIMSK

[M:BUD1]      = [F:BUD]

Call LEC_BUP([M:BUD1]BUD) From CPTLEC
[F:BUD]COA  = [F:BUP]COA
[M:BUD1]COA  = [F:BUP]COA

#Dimension Type + Dimension
For IND= 1 To 9
 Assign "[F:BUD]DIE"+num$(IND) With ""
 Assign "[F:BUD]CCE"+num$(IND) With ""
Next
[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[F:BUD]CPY,[F:BUD]LEDTYP,LEDCOD,LEDCUR,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : Return  : Endif
Call LEC_LED(LEDCOD) From CPTLEC
For IND= 1 To 9
 WDIE = evalue("[M:BUD1]DIE"+num$(IND))
 INDAXE = find(WDIE,[F:LED]DIE)
 INDPYM = find (WDIE,[F:BUP]DIE(0..dim([F:BUP]DIE)-1))
 If INDAXE & INDPYM
  Assign "[F:BUD]DIE"+num$(INDAXE) With WDIE
  Assign "[F:BUD]CCE"+num$(INDAXE) With evalue("[M:BUD1]CCE"+num$(IND))
 Endif
Next
For IND= 1 To 9
 Assign "[M:BUD1]DIE"+num$(IND) With evalue("[F:BUD]DIE"+num$(IND))
 Assign "[M:BUD1]CCE"+num$(IND) With evalue("[F:BUD]CCE"+num$(IND))
Next
#

If [F:BUP]LEV = 1
 # Definition level : Company
 If [F:BUD]CPY="" & [F:BUD]FCY<>""
  Call LEC_FCY([F:BUD]FCY) From CPTLEC
  [F:BUD]CPY  = [F:FCY]LEGCPY
  [M:BUD1]CPY = [F:FCY]LEGCPY
 Endif
 [F:BUD]FCY  = ""
 [M:BUD1]FCY = ""
Else
 # Definition level : Site
 If [F:BUD]CPY<>"" & [F:BUD]FCY=""
  Call LEC_CPY([F:BUD]CPY) From CPTLEC
  [F:BUD]FCY  = [F:CPY]MAIFCY
  [M:BUD1]FCY = [F:CPY]MAIFCY
 Endif
Endif
[M:BUD1]NBPER = dim([M]AMT)

[F:BUD]LED = [F:LED]LED  :  [M:BUD1]LED  = [F:LED]LED
[F:BUD]CUR = [F:BUP]CUR  :  [M:BUD1]CUR  = [F:BUP]CUR
Call LEC_GAC([F:BUD]ACC,[F:BUD]COA) From CPTLEC
[F:BUD]UOM = [F:GAC]UOM  :  [M:BUD1]UOM  = [F:GAC]UOM

If PSPE
 ACTION = "IMPORT" : Gosub ACTION From =PROGSPE
Endif
Return

#################################################################
$VALID

If [M:BUD1]NBPER = 0 : Return : Endif
Raz STA, MESSA, MODIF
Gosub CONTROLE
Call LEC_BUP([M:BUD1]BUD) From CPTLEC
KEYBUD = num$([M]LEDTYP)-[M]BUD-[M]CPY-[M]FCY-num$([M]FIY)-[M]VER-[M]ACC-[M]CCE1-[M]CCE2-[M]CCE3-
&           [M]CCE4-[M]CCE5-[M]CCE6-[M]CCE7-[M]CCE8-[M]CCE9
If STA
 Gosub MESSAGE
 Call TRACE(2,KEYBUD-"=>"-MESSA-"("+num$(STA)+")") From SUBIMPOBJ
 GOK = 0
 Return
Endif
If [F:BUP]BUPODS = 3
 Gosub SAV_AMT
Endif
Gosub EFFBUD
If !GOK : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR1
KEYBUD = num$([F:BUD]LEDTYP)-[F:BUD]BUD-[F:BUD]CPY-[F:BUD]FCY-num$([F:BUD]FIY)-[F:BUD]VER-[F:BUD]ACC-[F:BUD]CCE1-[F:BUD]CCE2-[F:BUD]CCE3-
&           [F:BUD]CCE4-[F:BUD]CCE5-[F:BUD]CCE6-[F:BUD]CCE7-[F:BUD]CCE8-[F:BUD]CCE9
If STA
 Call TRACE(2,KEYBUD-"=>"-MESSA-"("+num$(STA)+")") From SUBIMPOBJ
 GOK = 0
Elsif MODIF
 Call TRACE(1,KEYBUD) From SUBIMPOBJ
 NBMOD += 1 : GOK = 1
Else
 Call TRACE(0,KEYBUD) From SUBIMPOBJ
 NBCRE += 1 : GOK = 1
Endif
Return

$TR1
GOK = 1
Trbegin [BUD]
 Raz [F:BUD]
 Call LEC_BUP([M:BUD1]BUD) From CPTLEC
 [F:BUD]       = [M:BUD1]
 If [F:BUP]DIVAMT<>0 & [F:BUP]DIVAMT<>1
  For I=0 To [M:BUD1]NBPER-1
   [F:BUD]AMT(I) = [F:BUD]AMT(I)*[F:BUP]DIVAMT
  Next
 Endif
 Gosub INICRE
 [F:BUD]ACCNUM = uniqid([F:BUD])
 Write [BUD]
 If fstat
  GOK=0 : Call FSTA("BUD") From GLOCK : Goto AB_TR1
 Endif
 If [F:BUP]BUPODS=3      : # Create of budget adjustments
  If [F:BUP]LEV = 2 : # Definition level : Site
   Call LEC_FCY([F:BUD]FCY) From CPTLEC
  Else
   Call LEC_CPY([F:BUD]CPY) From CPTLEC
   Call LEC_FCY([F:CPY]MAIFCY) From CPTLEC
  Endif
  #
  NUMCPT=""
  Gosub CREEBDO From MAJBDO
  If GOK=0 : Goto AB_TR1 : Endif
 Endif
Commit
Return

$AB_TR1
Rollback
If STA = 0
 STA = 20 : Gosub MESSAGE
Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$INICRE
If dim([F:BUD]CREDAT)>0 : [F:BUD]CREDAT = date$ : Endif
If dim([F:BUD]CREUSR)>0 : [F:BUD]CREUSR = GUSER : Endif
Return

$SAV_AMT
Local Decimal XAMTBUD(0..dim([F:BUD]AMT)-1)
Local Decimal XQTYBUD(0..dim([F:BUD]AMT)-1)
Local Integer X
Raz XAMTBUD, XQTYBUD

Read [BUD2]BUD0 = [M]LEDTYP;[M]BUD;[M]CPY;[M]FCY;[M]FIY;[M]VER;[M]ACC;[M]CCE1;[M]CCE2;[M]CCE3;[M]CCE4;[M]CCE5;[M]CCE6;[M]CCE7;[M]CCE8;[M]CCE9
If !fstat
 For X=0 To dim([F:BUD2]AMT)-1
  XAMTBUD(X) = [F:BUD2]AMT(X)
  XQTYBUD(X) = [F:BUD2]QTY(X)
 Next
Endif
Return

$EFFBUD
Read [BUD2]BUD0 = [M]LEDTYP;[M]BUD;[M]CPY;[M]FCY;[M]FIY;[M]VER;[M]ACC;[M]CCE1;[M]CCE2;[M]CCE3;[M]CCE4;[M]CCE5;[M]CCE6;[M]CCE7;[M]CCE8;[M]CCE9
If !fstat
 MODIF = 1
 Call DEBTRANS From GLOCK
 Gosub TR_ANNUL
Endif
Return

$TR_ANNUL
GOK = 1
Trbegin [BUD]
 Delete [BUD] Where BUD=[F:BUD2]BUD & CPY=[F:BUD2]CPY & FCY=[F:BUD2]FCY & FIY=[F:BUD2]FIY
&                 & VER=[F:BUD2]VER & ACC=[F:BUD2]ACC & CCE1=[F:BUD2]CCE1 & CCE2=[F:BUD2]CCE2 & CCE3=[F:BUD2]CCE3 & CCE4=[F:BUD2]CCE4
&                 & CCE5=[F:BUD2]CCE5 & CCE6=[F:BUD2]CCE6 & CCE7=[F:BUD2]CCE7 & CCE8=[F:BUD2]CCE8 & CCE9=[F:BUD2]CCE9
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("BUD","") From GLOCK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return


########################################################################
$CONTROLE

INDDIE=0
If [F:BUP]DIE(0)<>"" : INDDIE=1 : Endif
If [F:BUP]DIE(1)<>"" : INDDIE=2 : Endif
If [F:BUP]DIE(2)<>"" : INDDIE=3 : Endif
If [F:BUP]DIE(3)<>"" : INDDIE=4 : Endif
If [F:BUP]DIE(4)<>"" : INDDIE=5 : Endif
If [F:BUP]DIE(5)<>"" : INDDIE=6 : Endif
If [F:BUP]DIE(6)<>"" : INDDIE=7 : Endif
If [F:BUP]DIE(7)<>"" : INDDIE=8 : Endif
If [F:BUP]DIE(8)<>"" : INDDIE=9 : Endif

## Budget
Call CONTROLE("BUP","",[M]BUD,"",mkstat) From CONTOBJ
If mkstat : MESSA = "BUD"-[M]BUD : STA = 99 : Return : Endif
If [F:BUP]GDDFLG=2
 MESSA = "BUD"-[M]BUD-mess(289,108,1) : STA = 99 : Return
Endif
[L]ASTATUS = func FINMIS_SYRA.CTL_EXE(GACTX,[F:BUP]ACS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : MESSA = "BUD"-[M]BUD : GMESSAGE = ERRMES :STA = 99 : Return : Endif
[L]ASTATUS = func FINMIS_SYRA.CTL_ACS(GACTX,[F:BUP]ACS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : MESSA = "BUD"-[M]BUD : GMESSAGE=ERRMES:  STA = 99 : Return : Endif

## Company
Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
If mkstat : MESSA = "CPY"-[M]CPY : STA = 99 : Return : Endif

## Site
If [F:BUP]LEV = 2 : # Definition level : Site
 Call CONTROLE("FCY","C",[M]FCY,"",mkstat) From CONTOBJ
 If mkstat : MESSA = "FCY"-[M]FCY : STA = 99 : Return : Endif

 If [M]CPY<>"" & [M]FCY<>""
  Call LEC_FCY([M]FCY) From CPTLEC
  If [F:FCY]LEGCPY<>[M]CPY
   MESSA = func AFNC.MES1(mess(171,104,1),[F:FCY]LEGCPY) : STA = 99 : Return
  Endif
 Endif
Endif

## Fiscalyear
Call C_FIY([M]BUD,[F:BUD]LEDTYP,[M]FIY) From BUDIMPORT
If mkstat : MESSA = "FIY"-num$([M]FIY) : STA = 99 : Return : Endif

## Version
Call CONTROLE("BUV","",[M]VER,[M]BUD,mkstat) From CONTOBJ
If mkstat : MESSA = "BUV"-[M]VER : STA = 99 : Return : Endif
If [F:BUV]STA=2
 GMESSAGE = mess(58,109,1)
 MESSA = "VER"-num$([M]VER) : STA = 99 : Return
Endif

## Account / Account pyramid
Call C_ACC([M]ACC)
If mkstat
 If [F:BUP]PYMACC = "" : MESSA = "ACC"-[M]ACC
 Else MESSA = "GRY"-[M]ACC
 Endif
 STA = 99 : Return
Endif

## Dimension / Dimension pyramid
Call LEC_BUP([M:BUD1]BUD) From CPTLEC
For IND=1 To INDDIE
 WDIE = evalue("[F:BUP]DIE("+num$(IND-1)+")")
 If WDIE<>""
  INDAXE = find(WDIE,[F:LED]DIE)
  If INDAXE
   WCCE = evalue("[M:BUD1]CCE"+num$(INDAXE))
   Call ="C_CCE"+num$(INDAXE) With  WCCE,IND From BUDIMPORT
   If mkstat : MESSA = "CCE"+num$(INDAXE)-WCCE : STA = 99 : Break : Endif
  Else
   MESSA = "CCE"+num$(IND) : NBAXE = IND : STA = 1 : Break
  Endif
 Endif
Next
If STA : Return : Endif
Return


############################################################################
# Fiscalyear control
Subprog C_FIY(BUD,LED,VALEUR)
Variable Char     BUD
Variable Libelle  LED
Variable Decimal  VALEUR
If clalev([F:FIY])=0
 Local File FISCALYEAR [FIY]
Endif
If clalev([F:BUP])=0
 Local File BUDPAR [BUP]
Endif
Raz fstat
If [M]CPY<>[F:FIY]CPY | LED<>[F:FIY]LEDTYP | VALEUR<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = [M]CPY;LED;VALEUR
Endif
If fstat
 GMESSAGE = mess(52,116,1)
 mkstat = 2 : End
Endif
Call LEC_BUP(BUD) From CPTLEC
##
If ([F:BUP]VLYSTR>[F:FIY]FIYSTR)
& |([F:BUP]VLYEND<>[0/0/0] & [F:BUP]VLYEND<[F:FIY]FIYEND)
 GMESSAGE = mess(31,108,1)
 mkstat = 2 : End
Endif
End

##########################################################################
# Account control
Subprog C_ACC(VALEUR)
Variable Char    VALEUR()

Local Char    SECNAT(20) : # Value of account/dimension
Local Integer OK , IND

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Char    ERRMES(250)

Call LEC_BUP([M:BUD1]BUD) From CPTLEC
If [F:BUP]PYMACC=""
 Call CONTROLE("GAC","",VALEUR,[M]COA,mkstat) From CONTOBJ
 If mkstat : End : Endif

 [L]ASTATUS = func FINMIS_SYRA.CTL_EXE(GACTX,[F:GAC]ACS,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : GMESSAGE=VALEUR-ERRMES : mkstat=2 : End : Endif

 If [F:GAC]BUDTRK <> 2
  GMESSAGE = mess(4,103,1)
  mkstat = 2 : End
 Endif

 Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M]FCY,[M]CPY,VALEUR) From CFYSUB
 If mkstat : End : Endif

 If [M]CPY<>[F:FIY]CPY | [M]LEDTYP<>[F:FIY]LEDTYP | [M]FIY<>[F:FIY]FIYNUM
  Read [FIY]FIY0 = [F:FIY]CPY;[M]LEDTYP;[M]FIY
 Endif
 If [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND<[FIY]FIYSTR
& | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[FIY]FIYEND
   GMESSAGE = mess(6,103,1)
   mkstat=2 : End
 Endif

 IND = 0
 SECNAT = VALEUR
 Gosub AUTSECNAT
 If !OK : mkstat = 2 : End : Endif

Else
 Filter [GRY] Where PYM = [F:BUP]PYMACC
 Call CONTROLE("GRY","",VALEUR,[F:BUP]PYMACC,mkstat) From CONTOBJ
 If mkstat : End : Endif
 Filter [GRY]

 If [F:GRY]BUDTRK<> 2
  GMESSAGE = mess(26,103,1)
  mkstat = 2 : End
 Endif

 If [F:GRY]LEV<>[F:BUP]PYMACCLEV
  GMESSAGE = mess(31,103,1)
  mkstat=2 : End
 Endif
Endif
End

$AUTSECNAT
OK = 1
If !clalev([F:CCE2]) : Local File CACCE [CCE2] : Endif
If !clalev([F:AUZ])  : Local File CAAUZ [AUZ]  : Endif

If IND=0 & [F:GAC]AUZ<>""

 # Account
 Local Integer SECTYP , AXI
 Local Char    SECTION(GLONCCE)
 Local Char    DIE(GLONDIE)

 For SECTYP=1 To 9
  SECTION = ""
  Case SECTYP
   When 1 : If dim([M]CCE1)=1 : SECTION = [M]CCE1 : DIE = [M]DIE1 : Endif
   When 2 : If dim([M]CCE2)=1 : SECTION = [M]CCE2 : DIE = [M]DIE2 : Endif
   When 3 : If dim([M]CCE3)=1 : SECTION = [M]CCE3 : DIE = [M]DIE3 : Endif
   When 4 : If dim([M]CCE4)=1 : SECTION = [M]CCE4 : DIE = [M]DIE4 : Endif
   When 5 : If dim([M]CCE5)=1 : SECTION = [M]CCE5 : DIE = [M]DIE5 : Endif
   When 6 : If dim([M]CCE6)=1 : SECTION = [M]CCE6 : DIE = [M]DIE6 : Endif
   When 7 : If dim([M]CCE7)=1 : SECTION = [M]CCE7 : DIE = [M]DIE7 : Endif
   When 8 : If dim([M]CCE8)=1 : SECTION = [M]CCE8 : DIE = [M]DIE8 : Endif
   When 9 : If dim([M]CCE9)=1 : SECTION = [M]CCE9 : DIE = [M]DIE9 : Endif
  Endcase
  If SECTION<>""
   Read [CCE2]CCE0 = DIE;SECTION
   If [F:CCE2]AUZ<>""
    Look [AUZ]CAZ0 = 2;[F:GAC]AUZ;[F:CCE2]AUZ
    If !fstat
     GMESSAGE = SECNAT-mess(26,106,1)-[F:CCE2]CCE
     OK = 0 : Break
    Endif
   Endif
  Endif
 Next SECTYP
Endif
Return

##########################################################################
# Dimension control
Subprog C_CCE1(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 1 : Gosub C_CCE
End

Subprog C_CCE2(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 2 : Gosub C_CCE
End

Subprog C_CCE3(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 3 : Gosub C_CCE
End

Subprog C_CCE4(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 4 : Gosub C_CCE
End

Subprog C_CCE5(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 5 : Gosub C_CCE
End

Subprog C_CCE6(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 6 : Gosub C_CCE
End

Subprog C_CCE7(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 7 : Gosub C_CCE
End

Subprog C_CCE8(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 8 : Gosub C_CCE
End

Subprog C_CCE9(VALEUR,INDBUP)
Variable Char     VALEUR
Variable Integer  INDBUP
Local Integer IND
IND = 9 : Gosub C_CCE
End

$C_CCE
Local Char    SVG_VALEUR(max(GLONBCC,GLONDIE)), DIE(GLONDIE)
Local Integer OK, AXI

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Char    ERRMES(250)

Case IND
 When 1 : DIE = [M]DIE1
 When 2 : DIE = [M]DIE2
 When 3 : DIE = [M]DIE3
 When 4 : DIE = [M]DIE4
 When 5 : DIE = [M]DIE5
 When 6 : DIE = [M]DIE6
 When 7 : DIE = [M]DIE7
 When 8 : DIE = [M]DIE8
 When 9 : DIE = [M]DIE9
Endcase

Call LEC_BUP([M:BUD1]BUD) From CPTLEC

If [F:BUP]PYMCCE(INDBUP-1)=""
 Call CONTROLE("CCE","",VALEUR,DIE,mkstat) From CONTOBJ
 If mkstat : Return  : Endif

 [L]ASTATUS = func FINMIS_SYRA.CTL_EXE(GACTX,[F:CCE]ACS,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : GMESSAGE = VALEUR-ERRMES : mkstat=2 : Return : Endif

 If [F:CCE]BUDTRK <> 2
  GMESSAGE = mess(5,103,1)
  mkstat=2 : Return
 Endif

 Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M]FCY,[M]CPY,VALEUR) From CFYSUB
 If mkstat : Return : Endif

 If [M]CPY<>[F:FIY]CPY | [M]LEDTYP<>[F:FIY]LEDTYP | [M]FIY<>[F:FIY]FIYNUM
  Read [FIY]FIY0 = [F:FIY]CPY;[M]LEDTYP;[M]FIY
 Endif

 If [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[FIY]FIYSTR
& | [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[FIY]FIYEND

  GMESSAGE = mess(7,103,1)
  mkstat=2 : Return
 Endif

 SVG_VALEUR = VALEUR
 Gosub AUTSECSEC
 If !OK : mkstat = 2 : Return : Endif

Else

 Filter [CRY]
 Call CONTROLE("CRY","",VALEUR,[F:BUP]PYMCCE(INDBUP-1),mkstat) From CONTOBJ
 If mkstat : Return : Endif

 If [F:CRY]BUDTRK<> 2
  GMESSAGE = mess(27,103,1)
  mkstat = 2 : Return
 Endif

 If  [F:CRY]LEV<>[F:BUP]PYMCCELEV(INDBUP-1)
  GMESSAGE = mess(32,103,1)
  mkstat=2 : Return
 Endif
Endif
Return

$AUTSECSEC
OK=1
If [F:CCE]AUZ<>""
 If clalev([F:CCE2])=0 : Local File CACCE [CCE2] : Endif
 If clalev([F:AUZ])=0  : Local File CAAUZ [AUZ]  : Endif
 Local Integer SECTYP , AXI
 Local Char    SECTION(GLONCCE)
 Local Char    DIE(GLONDIE)

 For SECTYP=1 To 9
  If SECTYP<>IND
   SECTION = ""
   Case SECTYP
    When 1 : If dim([M]CCE1)=1 : SECTION = [M]CCE1 : DIE = [M]DIE1 : Endif
    When 2 : If dim([M]CCE2)=1 : SECTION = [M]CCE2 : DIE = [M]DIE2 : Endif
    When 3 : If dim([M]CCE3)=1 : SECTION = [M]CCE3 : DIE = [M]DIE3 : Endif
    When 4 : If dim([M]CCE4)=1 : SECTION = [M]CCE4 : DIE = [M]DIE4 : Endif
    When 5 : If dim([M]CCE5)=1 : SECTION = [M]CCE5 : DIE = [M]DIE5 : Endif
    When 6 : If dim([M]CCE6)=1 : SECTION = [M]CCE6 : DIE = [M]DIE6 : Endif
    When 7 : If dim([M]CCE7)=1 : SECTION = [M]CCE7 : DIE = [M]DIE7 : Endif
    When 8 : If dim([M]CCE8)=1 : SECTION = [M]CCE8 : DIE = [M]DIE8 : Endif
    When 9 : If dim([M]CCE9)=1 : SECTION = [M]CCE9 : DIE = [M]DIE9 : Endif
   Endcase
   If SECTION<>""
    Read [CCE2]CCE0 = DIE;SECTION
    If [F:CCE2]AUZ<>""
     Look [AUZ]CAZ0 = 1;[F:CCE]AUZ;[F:CCE2]AUZ
     If !fstat
      GMESSAGE = SVG_VALEUR-mess(26,106,1)-[F:CCE2]CCE
      OK = 0 : Break
     Endif
    Endif
   Endif
  Endif
 Next SECTYP
Endif
Return

##########################################################################
$MESSAGE
Case STA
 When  1
  MESSA = MESSA-":"-mess(34,108,1)-num$(NBAXE)
 When 20
  MESSA = mess(18,114,1)
 When 99
  If MESSA<>""
   MESSA = MESSA-":"-GMESSAGE
  Else
   MESSA = GMESSAGE
  Endif
Endcase
Return

