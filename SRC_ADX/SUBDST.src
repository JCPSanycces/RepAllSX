#<AdxTL>@(#)6.0.0.0 $Revision$
#######################################################################
# SUBDST : Transactions de saisie des axes analytiques   MBT 13/06/06 #
#---------------------------------------------------------------------#
# Gestion de l'écran (actions sur champ) :                            #
#   DIESCRTRS  [M:DST]                                                #
#   DIESCRTRS3 [M:DST]                                                #
# Table mise à jour :                                                 #
#   DIETRS [F:DTR] Table complément transaction pour axes analytiques #
#   Clé d'accès:                                                      #
#   - ABRFIC abréviation table des transactions de saisie             #
#     "PTR" = Transactions achats                                     #
#     "SLT" = Transactions ventes                                     #
#     "HTR" = Transactions Support client(CRM)                        #
#     "SRT" = Transactions stocks                                     #
#     "MTS" = Transactions GPAO                                       #
#     "BTS" = Transactions plans                                      #
#   - DTRTYP type de transaction pour <ABRFIC>                        #
#   - DTRNUM code de transaction pour <ABRFIC>                        #
# Action SELDIEGRP pré-chargement des axes avec gestion écran DIEGRP  #
#######################################################################

#-------------------------------------------------#
# Action SELDIEGRP, fenêtre DDIEGRP, écran DIEGRP #
# Pré-chargement automatique des axes du dossier  #
#       avec Choix d'un groupe de site            #
#-------------------------------------------------#
$ACTION
Case ACTION
  When "OUVRE"
    Case GACTION
      When "SELDIEGRP" : Gosub OUVRE_DIEGRP
    Endcase
  When "OK"
    Case GACTION
      When "SELDIEGRP" : Gosub OK_DIEGRP
    Endcase
Endcase
Return

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_DIEGRP
Local Integer WCHOIX : WCHOIX=val(PARAM(1))
Local Integer I
Local Integer WMAJFLG
#-----
If !clalev([F:AGC])  Local File AGRPCPY  [AGC] : Endif    # Groupe de sociétés
If !clalev([F:AGF])  Local File AGRPFCY  [AGF] : Endif    # Groupe de sites
If !clalev([F:FGR])  Local File FACGROUP [FGR] : Endif    # Regroupement de sites
If !clalev([F:CPY])  Local File COMPANY  [CPY] : Endif    # Sociétés
If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif    # Sites
If !clalev([F:DIE])  Local File GDIE     [DIE] : Endif    # Axes
Return

#-----
$OK_DIEGRP
#----- Pré-chargement de tous les axes -----#
If [M:DIA]DIEAGF=""
  For [DIE] DIE0
    Case WCHOIX
      When 2
        If !find([F:DIE]DIE,[M:DST]DIE2(0..[M:DST]NBDIE2-1))
          [M:DST]DIE2   ([M:DST]NBDIE2)=[F:DIE]DIE
          [M:DST]CCECOD2([M:DST]NBDIE2)=1
          [M:DST]NBDIE2+=1 : WMAJFLG=1
          If [M:DST]NBDIE2>dim([M:DST]DIE2)-1 : Break : Endif
        Endif
      When 3
        If !find([F:DIE]DIE,[M:DST]DIE3(0..[M:DST]NBDIE3-1))
          [M:DST]DIE3   ([M:DST]NBDIE3)=[F:DIE]DIE               : # GA 12/2008 avant DIE2
          [M:DST]CCECOD3([M:DST]NBDIE3)=1
          [M:DST]NBDIE3+=1 : WMAJFLG=1
          If [M:DST]NBDIE3>dim([M:DST]DIE3)-1 : Break : Endif
        Endif
      When Default
        If !find([F:DIE]DIE,[M:DST]DIE(0..[M:DST]NBDIE-1))
          [M:DST]DIE   ([M:DST]NBDIE)=[F:DIE]DIE
          [M:DST]CCECOD([M:DST]NBDIE)=1
          [M:DST]NBDIE+=1 : WMAJFLG=1
          If [M:DST]NBDIE>dim([M:DST]DIE)-1 : Break : Endif
        Endif
    Endcase
  Next
#----- Pré-chargement axes groupe de société -----#
Elsif [F:AGF]FLGCPY=2
  For [AGC] AGC0 Where GRP=[M:DIA]DIEAGF
    If [F:CPY]CPY<>[F:AGC]CPY
      Read [CPY] CPY0=[F:AGC]CPY : If fstat  Raz [F:CPY] : Endif
    Endif
    For I=0 To dim([F:CPY]DIE)-1
      If [F:CPY]DIE(I)<>""
        Case WCHOIX
          When 2
            If !find([F:CPY]DIE(I),[M:DST]DIE2(0..[M:DST]NBDIE2-1))
              [M:DST]DIE2   ([M:DST]NBDIE2)=[F:CPY]DIE(I)
              [M:DST]CCECOD2([M:DST]NBDIE2)=1
              [M:DST]NBDIE2+=1 : WMAJFLG=1
              If [M:DST]NBDIE2>dim([M:DST]DIE2)-1 : Break 2 : Endif
            Endif
          When 3
            If !find([F:CPY]DIE(I),[M:DST]DIE3(0..[M:DST]NBDIE3-1))
              [M:DST]DIE3   ([M:DST]NBDIE3)=[F:CPY]DIE(I)
              [M:DST]CCECOD3([M:DST]NBDIE3)=1
              [M:DST]NBDIE3+=1 : WMAJFLG=1
              If [M:DST]NBDIE3>dim([M:DST]DIE3)-1 : Break 2 : Endif
            Endif
          When Default
            If !find([F:CPY]DIE(I),[M:DST]DIE(0..[M:DST]NBDIE-1))
              [M:DST]DIE   ([M:DST]NBDIE)=[F:CPY]DIE(I)
              [M:DST]CCECOD([M:DST]NBDIE)=1
              [M:DST]NBDIE+=1 : WMAJFLG=1
              If [M:DST]NBDIE>dim([M:DST]DIE)-1 : Break 2 : Endif
            Endif
        Endcase
      Endif
    Next
  Next
#----- Pré*chargement axes groupe de sites -----#
Else
  For [FGR] FGR0 Where CPY=[M:DIA]DIEAGF
    If [F:FCY]FCY<>[F:FGR]FCY
      Read [FCY] FCY0=[F:FGR]FCY : If fstat  Raz [F:FCY] : Endif
    Endif
    For I=0 To dim([F:FCY]DIE)-1
      If [F:FCY]DIE(I)<>""
        Case WCHOIX
          When 2
            If !find([F:FCY]DIE(I),[M:DST]DIE2(0..[M:DST]NBDIE2-1))
              [M:DST]DIE2   ([M:DST]NBDIE2)=[F:FCY]DIE(I)
              [M:DST]CCECOD2([M:DST]NBDIE2)=1
              [M:DST]NBDIE2+=1 : WMAJFLG=1
              If [M:DST]NBDIE2>dim([M:DST]DIE2)-1 : Break 2 : Endif
            Endif
          When 3
            If !find([F:FCY]DIE(I),[M:DST]DIE3(0..[M:DST]NBDIE3-1))
              [M:DST]DIE3   ([M:DST]NBDIE3)=[F:FCY]DIE(I)
              [M:DST]CCECOD3([M:DST]NBDIE3)=1
              [M:DST]NBDIE3+=1 : WMAJFLG=1
              If [M:DST]NBDIE3>dim([M:DST]DIE3)-1 : Break 2 : Endif
            Endif
          When Default
            If !find([F:FCY]DIE(I),[M:DST]DIE(0..[M:DST]NBDIE-1))
              [M:DST]DIE   ([M:DST]NBDIE)=[F:FCY]DIE(I)
              [M:DST]CCECOD([M:DST]NBDIE)=1
              [M:DST]NBDIE+=1 : WMAJFLG=1
              If [M:DST]NBDIE>dim([M:DST]DIE)-1 : Break 2 : Endif
            Endif
        Endcase
      Endif
    Next
  Next
Endif
#-----
Affzo [M:DST]
If WMAJFLG  mkstat=4 : Endif
Return


#-----------------------------------------------------#
# Après modification du mode saisie de la répartition #
#-----------------------------------------------------#
Subprog AM_DSPCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=3
  [M:DST]DSPSCR=1
  If !GIMPORT  Affzo [DST]DSPSCR : Grizo [DST]DSPSCR : Endif
Elsif !GIMPORT
  Actzo [DST]DSPSCR
Endif
End


#------------------------------------------------------#
# Avant saisie du code tableau-fiche de la répartition #
#------------------------------------------------------#
Subprog AS_DSPSCR(VALEUR)
Variable Integer VALEUR
If [M:DST]DSPCOD=3  VALEUR=1 : mkstat=2 : Endif
End


#--------------------#
# Avant saisie NBDIE #
#--------------------#
Subprog AS_NBDIE
End


#---------------------#
# Avant saisie NBDIE2 #
#---------------------#
Subprog AS_NBDIE2
End


#---------------------#
# Avant saisie NBDIE3 #
#---------------------#
Subprog AS_NBDIE3
End


#--------------------------#
# Contrôle saisie code axe #
#--------------------------#
Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DST]DIE(0..[M:DST]NBDIE-1)) From OBJDIV
End


#--------------------------#
# Contrôle saisie code axe #
#--------------------------#
Subprog C_DIE2(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DST]DIE2(0..[M:DST]NBDIE2-1)) From OBJDIV
End

#--------------------------#
# Contrôle saisie code axe #
#--------------------------#
Subprog C_DIE3(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DST]DIE3(0..[M:DST]NBDIE3-1)) From OBJDIV
End


#----------------------#
# Avant saisie du mode #
#----------------------#
Subprog AS_CCECOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Enlever l'option "Invisible"
# BRBAN 105200 US1
If GFONCTION='GESSLA'
  Gosub HIDE_ENTER From TRTINVCAN
Endif
#-
End


#-------------------------------------------------------#
# Après modification du mode saisie de l'axe analytique #
#-------------------------------------------------------#
Subprog AM_CCECOD(VALEUR)
Variable Integer VALEUR
End


#----------------------#
# Avant saisie du mode #
#----------------------#
Subprog AS_CCECOD2(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Enlever l'option "Invisible"
# BRBAN 105200 US1
If GFONCTION='GESSLA'
  Gosub HIDE_ENTER From TRTINVCAN
Endif
#-
End


#-------------------------------------------------------#
# Après modification du mode saisie de l'axe analytique #
#-------------------------------------------------------#
Subprog AM_CCECOD2(VALEUR)
Variable Integer VALEUR
End


#----------------------#
# Avant saisie du mode #
#----------------------#
Subprog AS_CCECOD3(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Enlever l'option "Invisible"
# BRBAN 105200 US1
If GFONCTION='GESSLA'
  Gosub HIDE_ENTER From TRTINVCAN
Endif
#-
End


#-------------------------------------------------------#
# Après modification du mode saisie de l'axe analytique #
#-------------------------------------------------------#
Subprog AM_CCECOD3(VALEUR)
Variable Integer VALEUR
End


################################################################
# Traitement des axes analytiques et de l'onglet DIESCRTRS     #
# ------------------------------------------------------------ #
# Doivent être chargés :                                       #
#  [L]WDIE_ABRFIC abréviation table des transactions de saisie #
#     "PTR" = Transactions achats                              #
#     "SLT" = Transactions ventes                              #
#     "HTR" = Transactions Support client(CRM)                 #
#     "SRT" = Transactions stocks                              #
#     "MTS" = Transactions GPAO                                #
#     "BTS" = Transactions plans                               #
#                                                              #
#  [L]WDIE_DTRTYP type de transaction (1 à ..)                 #
################################################################
$TRT_DIETRS
#-----
Case ACTION
  When "OUVRE"     : Gosub OUVRE_DIETRS
  When "AFFMASK"   : Gosub INVISIBLE
  When "LIENS"     : Gosub LIENS_DIETRS
  When "RAZCRE"    : Gosub RAZCR_DIETRS
  When "CREATION"  : Gosub CREAT_DIETRS
  When "MODIF"     : Gosub MODIF_DIETRS
  When "ANNULE"    : Gosub ANNUL_DIETRS
Endcase
Return


#####################################################################
# Ouverture de la table transaction saisie analytique si nécessaire #
#####################################################################
$OUVRE_DIETRS
#-----
If !clalev([F:DTR])
  If dim(APPLI)>0 & APPLI<>""
    Local File =APPLI+".DIETRS" [DTR]
  Else
    Local File DIETRS  [DTR]
  Endif
Endif
If GOPTCANA>0
  If !clalev([F:DIE])
    If dim(APPLI)>0 & APPLI<>""
      Local File =APPLI+".GDIE"   [DIE]
    Else
      Local File GDIE  [DIE]
    Endif
  Endif
Endif
#-----
Local Char    WDIE_DTRNUM(GLONTRS) : # Code de la transaction en cours
Local Integer WDIE_INDICE          : # Indice pour chargement/déchargement axes
#-----
Return


#############################################################################
# Lecture du paramétrage des axes analytiques et chargement du masque écran #
# ------------------------------------------------------------------------- #
#           Table DIETRS [F:DTR] ---> écran DIESCRTRS [M:DST]               #
#############################################################################
$LIENS_DIETRS
#-----
Gosub RAZCR_DIETRS : # Initialisation de l'onglet "Sections"
#-----
If GOPTCANA=0  Gosub GRISAGE : Return : Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Read [DTR] DTR0=[L]WDIE_ABRFIC;[L]WDIE_DTRTYP;[L]WDIE_DTRNUM;0;0
If !fstat
  [M:DST]HEACCECOD=[F:DTR]HEACCECOD
  [M:DST]DSPCOD   =[F:DTR]DSPCOD
  [M:DST]DSPSCR   =[F:DTR]DSPSCR
  [M:DST]STOCCECOD=[F:DTR]STOCCECOD
  [M:DST]CCESCR   =[F:DTR]CCESCR
  [M:DST]CCESCR2  =[F:DTR]CCESCR2
  [M:DST]CCESCR3  =[F:DTR]CCESCR3
Endif
#-----
For [DTR] DTR0 Where ABRFIC=[L]WDIE_ABRFIC
&                  & DTRTYP=[L]WDIE_DTRTYP
&                  & DTRNUM=[L]WDIE_DTRNUM
&                  & DTRTNU>0
  Case [F:DTR]DTRTNU
    When 2
      [M:DST]DIE2   ([M:DST]NBDIE2)=[F:DTR]DIE
      [M:DST]CCECOD2([M:DST]NBDIE2)=[F:DTR]CCECOD
      [M:DST]NBDIE2+=1
    When 3
      [M:DST]DIE3   ([M:DST]NBDIE3)=[F:DTR]DIE
      [M:DST]CCECOD3([M:DST]NBDIE3)=[F:DTR]CCECOD
      [M:DST]NBDIE3+=1
    When Default
      [M:DST]DIE   ([M:DST]NBDIE)=[F:DTR]DIE
      [M:DST]CCECOD([M:DST]NBDIE)=[F:DTR]CCECOD
      [M:DST]NBDIE+=1
  Endcase
Next
#-----
Gosub GRISAGE : # Grisage des champs de l'onglet "Sections" suivant le contexte
#-----
Return


################################################################
# Initialisation des champs écran en début de création ou lien #
################################################################
$RAZCR_DIETRS
#-----
[M:DST]HEACCECOD=3
[M:DST]DSPCOD   =1
[M:DST]DSPSCR   =1
[M:DST]STOCCECOD=3
[M:DST]CCESCR   =1
[M:DST]CCESCR2  =1
[M:DST]CCESCR3  =1
Raz [M:DST]NBDIE, [M:DST]NBDIE2, [M:DST]NBDIE3
#-----
If ACTION="RAZCRE"
  Gosub GRISAGE : # Grisage des champs de l'onglet "SECTIONS" suivant le contexte
Endif
Affzo [M:DST]
#-----
Return


######################################################################
# Création paramètrage des axes analytique à partir du masque écran  #
# ------------------------------------------------------------------ #
#        Ecran DIESCRTRS [M:DST] ---> table DIETRS [F:DTR]           #
######################################################################
$CREAT_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Raz [F:DTR]
[F:DTR]=[M:DST]
[F:DTR]ABRFIC=[L]WDIE_ABRFIC
[F:DTR]DTRTYP=[L]WDIE_DTRTYP
[F:DTR]DTRNUM=[L]WDIE_DTRNUM
[F:DTR]DIE   =""
[F:DTR]CCECOD=0
Write [DTR]
If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Return : Endif
#----- Ne pas écrire des enregistrements inutiles si écran DIESCRTRS0 -----#
If [L]WDIE_ABRFIC="SRT" & [L]WDIE_DTRTYP=5  Return : Endif
#-----
If [M:DST]NBDIE>0
  For [L]WDIE_INDICE=0 To [M:DST]NBDIE-1
    [F:DTR]DTRTNU=1
    [F:DTR]DTRLIN=[L]WDIE_INDICE+1
    [F:DTR]DIE   =[M:DST]DIE    ([L]WDIE_INDICE)
    [F:DTR]CCECOD=[M:DST]CCECOD ([L]WDIE_INDICE)
    Write [DTR]
    If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Break : Endif
  Next [L]WDIE_INDICE
Endif
#-----
If [M:DST]NBDIE2>0
  For [L]WDIE_INDICE=0 To [M:DST]NBDIE2-1
    [F:DTR]DTRTNU=2
    [F:DTR]DTRLIN=[L]WDIE_INDICE+1
    [F:DTR]DIE   =[M:DST]DIE2   ([L]WDIE_INDICE)
    [F:DTR]CCECOD=[M:DST]CCECOD2([L]WDIE_INDICE)
    Write [DTR]
   If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Break : Endif
  Next [L]WDIE_INDICE
Endif
#-----
If [M:DST]NBDIE3>0
  For [L]WDIE_INDICE=0 To [M:DST]NBDIE3-1
    [F:DTR]DTRTNU=3
    [F:DTR]DTRLIN=[L]WDIE_INDICE+1
    [F:DTR]DIE   =[M:DST]DIE3   ([L]WDIE_INDICE)
    [F:DTR]CCECOD=[M:DST]CCECOD3([L]WDIE_INDICE)
    Write [DTR]
    If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Break : Endif
  Next [L]WDIE_INDICE
Endif
#-----
Return


#########################################################################
# Mise à jour paramètrage des axes analytique à partir du masque écran  #
# --------------------------------------------------------------------- #
#         Ecran DIESCRTRS [M:DST] ---> table DIETRS [F:DTR]             #
#########################################################################
$MODIF_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#-----
Gosub ANNUL_DIETRS : If GOK<1  Return : Endif : # Suppression ancien paramétrage
#-----
Gosub CREAT_DIETRS : If GOK<1  Return : Endif : # Enregistrement nouveau paramétrage
#-----
Return


###################################################
# Suppression du paramètrage des axes analytiques #
###################################################
$ANNUL_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#----- Les variables locales sont perdues lorsque l'on vient du S/P ANUCOD -----#
If dim([L]WDIE_DTRTYP)<1
  Local Integer WDIE_DTRTYP
  Case [L]WDIE_ABRFIC
    When "PTR" : [L]WDIE_DTRTYP=[F:PTR]PTRTYP
    When "SLT" : [L]WDIE_DTRTYP=[F:SLT]STRTYP
    When "HTR" : [L]WDIE_DTRTYP=[F:HTR]HTRTYP
    When "SRT" : [L]WDIE_DTRTYP=[F:SRT]SRTTYP
    When "MTS" : [L]WDIE_DTRTYP=[F:MTS]MTSTYP
    When "BTS" : [L]WDIE_DTRTYP=[F:BTS]BTSTYP
  Endcase
Endif
If dim([L]WDIE_DTRNUM)<1
  Local Char    WDIE_DTRNUM(GLONTRS)
Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Delete [DTR] Where ABRFIC=[L]WDIE_ABRFIC
&                & DTRTYP=[L]WDIE_DTRTYP
&                & DTRNUM=[L]WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$DIETRS"-[L]WDIE_ABRFIC-num$([L]WDIE_DTRTYP)-[L]WDIE_DTRNUM : Return
Endif
#-----
Return


#------------------------------------------------------------#
# Grisage des champs non actifs suivant types de transaction #
#------------------------------------------------------------#
$GRISAGE
#-----
If GOPTCANA=0
  Grizo [DST]1-99 : Return
Else
  Actzo [DST]1-99
  If [M:DST]DSPCOD=3  Grizo [DST]DSPSCR : Endif
Endif
#-----
Return


#------------------------------------------#
# Rendre invisible les champs non utilisés #
#------------------------------------------#
$INVISIBLE
#-----
Case [L]WDIE_ABRFIC
  When "PTR"
    Case [L]WDIE_DTRTYP
      When 1,2,9   : Chgfmt [M:DST]HEACCECOD With "-N:1#"
                     Chgfmt [M:DST]DSPCOD    With "-N:1#"
                     Chgfmt [M:DST]DSPSCR    With "-N:1#"
                     Chgfmt [M:DST]STOCCECOD With "-N:1#"
      When 3,4,5   : Chgfmt [M:DST]STOCCECOD With "-N:1#"
                    #Chgfmt [M:DST]DSPCOD    With "-N:1#"
                    #Chgfmt [M:DST]DSPSCR    With "-N:1#"
      When 6       :#Chgfmt [M:DST]DSPCOD    With "-N:1#"
                    #Chgfmt [M:DST]DSPSCR    With "-N:1#"
      When 7       : Chgfmt [M:DST]DSPCOD    With "-N:1#"
                     Chgfmt [M:DST]DSPSCR    With "-N:1#"
                     Chgfmt [M:DST]STOCCECOD With "-N:1#"
      When 8       : Chgfmt [M:DST]STOCCECOD With "-N:1#"
    Endcase
  When "SLT"
    Case [L]WDIE_DTRTYP
      When 1,2,3     : Chgfmt [M:DST]DSPCOD    With "-N:1#"
                       Chgfmt [M:DST]DSPSCR    With "-N:1#"
                       Chgfmt [M:DST]STOCCECOD With "-N:1#"
      When 4,5,6,7,8 : Chgfmt [M:DST]DSPCOD    With "-N:1#"
                       Chgfmt [M:DST]DSPSCR    With "-N:1#"
    Endcase
  When "HTR"
    Case [L]WDIE_DTRTYP
        When 2
            Chgfmt [M:DST]DSPCOD    With "-N:1#"
            Chgfmt [M:DST]DSPSCR    With "-N:1#"
            Chgfmt [M:DST]STOCCECOD With "-N:1#"
        When 3
            Chgfmt [M:DST]HEACCECOD With "-N:1#"
            Chgfmt [M:DST]DSPCOD    With "-N:1#"
            Chgfmt [M:DST]DSPSCR    With "-N:1#"
            Chgfmt [M:DST]STOCCECOD With "-N:1#"
    Endcase
  When "SRT"
    Chgfmt [M:DST]DSPCOD    With "-N:1#"
    Chgfmt [M:DST]DSPSCR    With "-N:1#"
    Case [L]WDIE_DTRTYP
        When 5
            Chgfmt [M:DST]HEACCECOD With "-N:1#"
    Endcase
  When "MTS"
    Chgfmt [M:DST]HEACCECOD With "-N:1#"
    Chgfmt [M:DST]DSPCOD    With "-N:1#"
    Chgfmt [M:DST]DSPSCR    With "-N:1#"
    Chgtbk [M:DST]10 With ""
    Chgtbk [M:DST]20 With ""
    Chgtbk [M:DST]30 With ""
    Case [L]WDIE_DTRTYP
        When 1
            Chgfmt [M:DST]STOCCECOD With "-N:1#"
        When 2
            Chgtbk [M:DST]15 With mess(224,190,1)
            Chgtbk [M:DST]25 With mess(225,190,1)
            Chgtbk [M:DST]35 With mess(226,190,1)
    Endcase
  When "BTS"
    Chgtbk [M:DST]10 With ""
    Chgfmt [M:DST]HEACCECOD With "-N:1#"
    Chgfmt [M:DST]DSPCOD    With "-N:1#"
    Chgfmt [M:DST]DSPSCR    With "-N:1#"
    Case [L]WDIE_DTRTYP
        When 51,52,53,60,65,66,90
            Chgfmt [M:DST]STOCCECOD With "-N:1#"
    Endcase
Endcase
#-----
Return


#-----------------------------------#
# Chargement code de la transaction #
#-----------------------------------#
$CODETRANSACT
#-----
Case [L]WDIE_ABRFIC
  When "PTR" : [L]WDIE_DTRNUM=[F:PTR]PTRNUM
  When "SLT" : [L]WDIE_DTRNUM=[F:SLT]STRNUM
  When "HTR" : [L]WDIE_DTRNUM=[F:HTR]HTRNUM
  When "SRT" : [L]WDIE_DTRNUM=[F:SRT]SRTNUM
  When "MTS" : [L]WDIE_DTRNUM=[F:MTS]MTSNUM
  When "BTS" : [L]WDIE_DTRNUM=[F:BTS]BTSNUM
Endcase
#-----
Return


######################################################################
# COPDIETRS : S/P de copie du paramètrage de saisie     MBT 15/06/06 #
#                 des axes analytiques                               #
# ------------------------------------------------------------------ #
# Subprog COPDIETRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)            #
#   WDIE_ABRFIC : Abréviation de la table des transactions de saisie #
#     "PTR" = Transactions achats                                    #
#     "SLT" = Transactions ventes                                    #
#     "HTR" = Transactions Support client(CRM)                       #
#     "SRT" = Transactions stocks                                    #
#     "MTS" = Transactions GPAO                                      #
#     "BTS" = Transactions plans                                     #
#                                                                    #
#   WDIE_DTRTYP : Type de transaction (1 à ..)                       #
#                                                                    #
#   WDIE_DTRNUM : Code de la transaction à copier                    #
######################################################################
Subprog COPDIETRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)
Value Char    WDIE_ABRFIC
Value Integer WDIE_DTRTYP
Value Char    WDIE_DTRNUM
#-----
Delete [DTR2] Where ABRFIC=WDIE_ABRFIC
&                 & DTRTYP=WDIE_DTRTYP
&                 & DTRNUM=WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$"+[M]DOSDES+".DIETRS"-num$(WDIE_DTRTYP)-WDIE_DTRNUM : End
Elsif fstat
  GOK= 0 : Call RSTA("DTR2",num$(WDIE_DTRTYP)-WDIE_DTRNUM) From GLOCK  : End
Endif
For [DTR1] DTR0 Where ABRFIC=WDIE_ABRFIC
&                   & DTRTYP=WDIE_DTRTYP
&                   & DTRNUM=WDIE_DTRNUM
  [F:DTR2]=[F:DTR1]
  If dim([F:DTR2]UPDUSR)>0  [F:DTR2]UPDUSR=GUSER : Endif
  If dim([F:DTR2]UPDDAT)>0  [F:DTR2]UPDDAT=date$ : Endif
  Write [DTR2]
  If fstat  GOK=0 : Call FSTA("DTR2") From GLOCK : Break : Endif
Next
#-----
End
