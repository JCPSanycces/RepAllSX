#<AdxTL>@(#)9.0.0.0 $Revision$
GBIDC1 = "ADMIN"
GBIDC2 = "0"
GPILOBJ = 0
Call OBJET("APM",GBIDC1,GBIDC2) From GOBJET 
End 
 
#######################################################################
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAPMB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "RAZCRE"     : Call SET_FORMAT("")
 When "ANNULE"     : Gosub ANNULE
 When "FILTRE"     : Gosub FILTRE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "LIENS"      : Gosub LIENS
 When "AFFMASK"    : Gosub AFFMASK
 When "APRES_CRE"  : Gosub VALMENU : Gosub RAZPICK
 When "APRES_MOD"  : Gosub VALMENU : Gosub RAZPICK
 When "ABANDON"    : Gosub ABANDON
 When "TIROIR"     : Gosub TIROIR
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE

 When "DEB_PICK"    : Gosub DEB_PICK
 When "FIN_PICK"    : Gosub FIN_PICK
 When "PICKE"       : Gosub PICKING
 When "DEPICK"      : Gosub DEPICK
 When "FILGAUCHE"   : Gosub FILGAUCHE

 When "SEL_TABLE"
  Case TABLE
   When "CODMENS"   : Gosub SEL_CODMENS
  Endcase
 When "INIT"
  Case GACTION
   When "APMSYS"    : Gosub INIT_ZLIBMENUS
  Endcase
 When "INIT_DIA"
  Case GACTION
   When "APMSYS"    : Gosub DIA_ZLIBMENUS
  Endcase
 When "CONTROLE"
  Case GACTION
   When "APMSYS"    : Gosub CONT_ZLIBMENUS
  Endcase
 When "EXEC"
  Case GACTION
   When "APMVERF"   : Gosub EXEC_CONTMEN
  Endcase
Endcase
If PSUBB
 Gosub ACTION From SUBAPMB
Endif
Return

$ACTIONB
If dim([L]PSUBNB)<=0
 Local Integer PSUBNB
 Call EXISTE_ADX("","","SUBAPNB",PSUBNB) From ORDSYS
Endif
If [L]PSUBNB>0
 Gosub ACTION From SUBAPNB
Endif
Return

###################################################################
$OUVRE
If clalev([F:AMU2])=0 : Local File   AMENUSER [AMU2] : Endif
Global Integer FENLIG
Local Mask APM9 [APM9]
# Fichiers utilisés pour le picking
If clalev([F:AFC0])  = 0  : Local File AFONCTION [AFC0] : Endif
If clalev([F:AFC1])  = 0  : Local File AFONCTION [AFC1] : Endif
If clalev([F:AUS])   = 0  : Local File AUTILIS   [AUS]  : Endif

### Pour la liste hierarchisé : explorateur menu
Local Integer NBMENU,NBPAR,K,L,M,N,P

Filter [F:AMU2] Where CODPRF = GSUPER
NBMENU  = rowcount([F:AMU2])+100
Filter [F:AMU2]

Local Integer  WMEN1(1..NBMENU) , WMEN2(1..NBMENU) , WMEN3(1..NBMENU)
&            , WMEN4(1..NBMENU) , WMEN5(1..NBMENU)
Local Char  WDESMEN1(50)(1..NBMENU) ,WDESMEN2(50)(1..NBMENU) , WDESMEN3(50)(1..NBMENU)
&         , WDESMEN4(50)(1..NBMENU) ,WDESMEN5(50)(1..NBMENU)
Local File (Integer MEN1 , Integer MEN2, Integer MEN3, Integer MEN4, Integer MEN5
&         , Char DESMEN1(50) , Char DESMEN2(50), Char DESMEN3(50)
&         , Char DESMEN4(50) , Char DESMEN5(50))
&           From Variable WMEN1 , WMEN2 , WMEN3 , WMEN4 , WMEN5 
&         , WDESMEN1, WDESMEN2, WDESMEN3, WDESMEN4, WDESMEN5 As [AAMU]
&           Order By MEN1;MEN2;MEN3;MEN4;MEN5
Return

$CREATION
$MODIF
Call MAJTEXTRA([M]INTPRF,"APROFIL","INTPRF","0",[M]CODPRF) From ATEXTRA
Return

$REMPLIT
If clalev([F:AMU1])=0 : Local File   AMENUSER [AMU1] : Endif
If clalev([F:AMU2])=0 : Local File   AMENUSER [AMU2] : Endif
If clalev([F:AMU3])=0 : Local File   AMENUSER [AMU3] : Endif
If clalev([F:AMU4])=0 : Local File   AMENUSER [AMU4] : Endif
If clalev([F:AMU5])=0 : Local File   AMENUSER [AMU5] : Endif

Raz WMEN1,WMEN2,WMEN3,WMEN4,WMEN5,WDESMEN1,WDESMEN2,WDESMEN3,WDESMEN4,WDESMEN5

Case currbox
 When BOXPAR
  J=0
  Filter [AMU1] Where CODPRF = [M:APM1]CODPRF & MENU = [M:APM1]MENDEP
  For [AMU1]MENCOD
   J+=1
   WMEN1(J) = [F:AMU1]NUMLIG
   If [AMU1]CODMEN <> "" 
    If [AMU1]INTIT <> "" :  WDESMEN1(J) = mess(2,13,1)-[F:AMU1]CODMEN-"("+[AMU1]INTIT+")"
    Else WDESMEN1(J) = mess(2,13,1)-[F:AMU1]CODMEN-"("+func AFNC.TEXTE([F:AMU1]LIBMENU)+")" 
    Endif   
    Filter [AMU2] Where CODPRF = [M:APM1]CODPRF & MENU = [F:AMU1]CODMEN
    I =0
    For [AMU2]MENCOD
     I +=1
     If I>1 :  J += 1 : Endif
     WMEN1(J) = [F:AMU1]NUMLIG
     WMEN2(J) = [F:AMU2]NUMLIG
     If [AMU2]CODMEN <> "" 
      If [AMU2]INTIT <> "" :  WDESMEN2(J) = mess(2,13,1)-[AMU2]CODMEN-"("+[F:AMU2]INTIT+")"
      Else : WDESMEN2(J) = mess(2,13,1)-[F:AMU2]CODMEN-"("+func AFNC.TEXTE([F:AMU2]LIBMENU)+")" 
      Endif      
      Filter [AMU3] Where CODPRF = [M:APM1]CODPRF & MENU = [F:AMU2]CODMEN
      L=0
      For [AMU3]MENCOD
       L +=1
       If L>1 :  J += 1 : Endif
       WMEN1(J) = [F:AMU1]NUMLIG
       WMEN2(J) = [F:AMU2]NUMLIG 
       WMEN3(J) = [F:AMU3]NUMLIG
       If [AMU3]CODMEN <> "" 
        If [AMU3]INTIT <> "" :  WDESMEN3(J) = mess(2,13,1)-[AMU3]CODMEN-"("+[F:AMU3]INTIT+")"
        Else : WDESMEN3(J) = mess(2,13,1)-[F:AMU3]CODMEN-"("+func AFNC.TEXTE([F:AMU3]LIBMENU)+")" 
        Endif      
        Filter [AMU4] Where CODPRF = [M:APM1]CODPRF & MENU = [F:AMU3]CODMEN
        M=0
        For [AMU4]MENCOD
         M +=1
         If M>1 :  J += 1 : Endif
         WMEN1(J) = [F:AMU1]NUMLIG
         WMEN2(J) = [F:AMU2]NUMLIG 
         WMEN3(J) = [F:AMU3]NUMLIG 
         WMEN4(J) = [F:AMU4]NUMLIG
         If [AMU4]CODMEN <> "" 
          If [AMU4]INTIT <> "" :  WDESMEN4(J) = mess(2,13,1)-[AMU4]CODMEN-"("+[F:AMU4]INTIT+")"
          Else  : WDESMEN4(J) = mess(2,13,1)-[F:AMU4]CODMEN-"("+func AFNC.TEXTE([F:AMU4]LIBMENU)+")" 
          Endif          
          Filter [AMU5] Where CODPRF = [M:APM1]CODPRF & MENU = [F:AMU4]CODMEN
          N=0
          For [AMU5]MENCOD
           N +=1
           If N>1 :  J += 1 : Endif
           WMEN1(J) = [F:AMU1]NUMLIG
           WMEN2(J) = [F:AMU2]NUMLIG
           WMEN3(J) = [F:AMU3]NUMLIG
           WMEN4(J) = [F:AMU4]NUMLIG 
           WMEN5(J) = [F:AMU5]NUMLIG
           If [AMU5]CODMEN <> ""           
            If [AMU5]INTIT <> "" :  WDESMEN5(J) = mess(2,13,1)-[AMU5]CODMEN-"("+[F:AMU5]INTIT+")"
            Else : WDESMEN5(J) = mess(2,13,1)-[F:AMU5]CODMEN-"("+func AFNC.TEXTE([F:AMU5]LIBMENU)+")" 
            Endif 
           Else
            If [AMU5]INTIT <> "" :  WDESMEN5(J) = [AMU5]FONCTION-"("+[F:AMU5]INTIT+")"
            Else : WDESMEN5(J) = [F:AMU5]FONCTION-"("+func AFNC.TEXTE([F:AMU5]LIBMENU)+")" 
            Endif
           Endif
          Next AMU5
          Filter [AMU5]
         Else 
          If [AMU4]INTIT <> "" :  WDESMEN4(J) = [AMU4]FONCTION-"("+[F:AMU4]INTIT+")"
          Else : WDESMEN4(J) = [F:AMU4]FONCTION-"("+func AFNC.TEXTE([F:AMU4]LIBMENU)+")"
          Endif        
        Endif
        Next AMU4
        Filter [AMU4]
       Else 
        If [AMU3]INTIT <> "" :  WDESMEN3(J) = [AMU3]FONCTION-"("+[F:AMU3]INTIT+")"
        Else : WDESMEN3(J) = [F:AMU3]FONCTION-"("+func AFNC.TEXTE([F:AMU3]LIBMENU)+")" 
        Endif       
       Endif
       Next AMU3
       Filter [AMU3] 
     Else 
      If [AMU2]INTIT <> "" :  WDESMEN2(J) = [AMU2]FONCTION-"("+[F:AMU2]INTIT+")"
      Else : WDESMEN2(J) = [F:AMU2]FONCTION-"("+func AFNC.TEXTE([F:AMU2]LIBMENU)+")" 
      Endif
    Endif
    Next AMU2
    Filter [AMU2]
   Else 
    If [AMU1]INTIT <> "" :  WDESMEN1(J) = [AMU1]FONCTION-"("+[F:AMU1]INTIT+")"
    Else : WDESMEN1(J) = [F:AMU1]FONCTION-"("+func AFNC.TEXTE([F:AMU1]LIBMENU)+")" 
    Endif   
  Endif
  Next AMU1
  Filter [AMU1]
 #####
 For I=1 To max(dim(WMEN1))
 If WMEN1(I) = 0 : WMEN1(I) = 9999999 : Endif
 If WMEN2(I) = 0 : WMEN2(I) = 9999999 : Endif
 If WMEN3(I) = 0 : WMEN3(I) = 9999999 : Endif
 If WMEN4(I) = 0 : WMEN4(I) = 9999999 : Endif
 If WMEN5(I) = 0 : WMEN5(I) = 9999999 : Endif
 Next I
 adxmxl = J
 Filter [AAMU] Order By MEN1;MEN2;MEN3;MEN4;MEN5
 Fillbox [APM1] GAU_CHE2 
 Filter [AAMU]
Endcase
Return

$TIROIR
If currbox<>BOXCURR
 Gosub REMPLIT
Endif
Return

$FILTRE
FILTSUP = "[F]MODULE=0"
Return

$FILGAUCHE
If ILIS=1
 FILGAUSUP += '[F:AFC]TYPTRAIT<>2 & [F:AFC]MENU<>""'
Endif
Return

$SETBOUT
Filter [AFC]
If [M:APM1]CODPRF=GSUPER
 Call VIREBOUT(CHAINE,"AM") From GOBJET
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$OUVRE_BOITE
Global Char BOXPAR(10)
BOXPAR = "GAU_CHE"+num$(find("AM0",OBJLIS(1..dim(OBJLIS)-1)))
Return

$LIENS
Gosub AFFMASK
If currbox =  BOXPAR : Gosub REMPLIT : Endif
Return

$ANNULE
Local Integer STAT
Delete [AMU] Where CODPRF=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("AMU",[L]CODE) From GLOCK : Return : Endif
Call SUPPROF(nomap,[L]CODE) From INTRUTILB
Return

$DEB_PICK
If find([M:APM1]CODPRF,GSUPER,"")
 OK = 0
Endif
Return

$DEPICK
NOL = find([F:AFC]CODINT,[M:APM1]FONCTIONS(0..[M:APM1]NBFONCS-1))
If NOL>0
 Dela NOL-1,1,[M:APM1]NBFONCS-1 [M:APM1]NBFONCS
 [M:APM1]NBFONCS -= 1
Else
 OK = 0
Endif
Return

$FIN_PICK
Affzo [APM1]15
Return

$PICKING
Case currbox
 When "GAU_CHE"+num$(find("AF0",[L]OBJLIS(1..8)))

  If find([F:AFC]CODINT,[M:APM1]FONCTIONS(0..[M:APM1]NBFONCS-1))
   OK = 0 : Return
  Endif

## Controle sur la dimension du tableau
  If [M:APM1]NBFONCS + 1 > dim([M:APM1]FONCTIONS)
   GERR = 1 : GMESSAGE = mess(26,100,1) : # Tableau plein
   OK = 0 : FIN = 1
   Return
  Endif

## Controle d'insertion
  If [M:APM1]LIG=0
   NOL = [M:APM1]NBFONCS
  Else
   NOL = [M:APM1]LIG-1
  Endif
  nolign = NOL+1
  If NOL < [M:APM1]NBFONCS 
   Insa NOL,1, [M:APM1]NBFONCS [M:APM1]FONCTIONS,[M:APM1]TYPFCTS,[M:APM1]CODMENS,
&                              [M:APM1]LIBMENUS,[M:APM1]ZLIBMENUS,[M:APM1]ORDSYSS
  Endif
  [M:APM1]NBFONCS += 1

## Remplissage du tableau
  Read [AFC]CODINT =
  [M:APM1]FONCTIONS(NOL) = [F:AFC]CODINT
  [M:APM1]CODMENS(NOL) = ""
  Read [ATX]NUMERO = GLANGUE;[F:AFC]LIBMENU
  If !fstat
   [M:APM1]ZLIBMENUS(NOL) = [F:ATX]TEXTE
  Else
   [M:APM1]ZLIBMENUS(NOL) = ""
  Endif

## Contrôle des champs du tableau 
  Call AM_FONCTIONS([M:APM1]FONCTIONS(NOL))
  If mkstat : Goto ERR_PICK : Endif
  Call C_CODMENS([M:APM1]CODMENS(NOL))
  If mkstat : Goto ERR_PICK : Endif
  Call C_ZLIBMENUS([M:APM1]ZLIBMENUS(NOL))
  If mkstat : Goto ERR_PICK : Endif
Endcase
Return

$ERR_PICK
Dela NOL,1,[M:APM1]NBFONCS [M:APM1]FONCTIONS,[M:APM1]TYPFCTS,[M:APM1]CODMENS,
&                          [M:APM1]LIBMENUS,[M:APM1]ZLIBMENUS,[M:APM1]ORDSYSS
[M:APM1]NBFONCS -= 1
OK = 0
Return    

$ABANDON
Gosub RAZPICK
Return

$RAZPICK
For I=0 To [M:APM1]NBFONCS-1
 Read [AFC]CODINT = [M:APM1]FONCTIONS(I)
 Gosub DEPICK From GOBJSUB
Next I
Return

$AFFMASK
Onerrgo
If [M:APM1]CODPRF<>"" & find(GREP,"C","D")=0
 Call TEMPON("L") From GESECRAN
 nolign = 0
 For [AMU]CODMEN Where CODPRF=[M:APM1]CODPRF
  nolign += 1
  [M:APM9] = [F:AMU]
  Read [AFC]CODINT = [F:AMU]FONCTION
  [M:APM9]FONCTION(nolign-1) = [F:AFC]CODEXT
  Case [F:AFC]TYPTRAIT
   When 1 : [M:APM9]TYPFCT(nolign-1) = [F:AFC]TYP
   When 2 : [M:APM9]TYPFCT(nolign-1) = 4
  Endcase    
 Next
 Call TEMPOFF From GESECRAN
 [M:APM9]NBFONC = nolign
 [M:APM1]MENUS  = [M:APM1]MENDEP
 [M:APM1]MENUSA = [M:APM1]MENDEP
 Call A_PAGE1([M:APM1]MENDEP)
Endif
Return

$INICRE
$INIMOD
Delete [AMU] Where CODPRF=[M:APM1]CODPRF
If fstat=1
 GOK=-1 : GLOCK="$AMENUSER"-[M:APM1]CODPRF : Goto FIN_ECR
Elsif fstat>5
 GOK=0 : Call RSTA("AMU",[M:APM1]CODPRF) From GLOCK : Goto FIN_ECR
Endif
NOL = 0
For nolign=1 To [M:APM9]NBFONC
 If [M:APM9]FONCTION(nolign-1)<>""
  NOL += 1
  [F:AMU] = [M:APM1]
  [F:AMU] = [M:APM9]
  Read [AFC]CODEXT = [M:APM9]FONCTION(nolign-1)
  [F:AMU]FONCTION = [F:AFC]CODINT
  [F:AMU]CODPRF   = [M:APM1]CODPRF
  [F:AMU]NUMLIG   = NOL
  [F:AMU]INTIT    = [M:APM9]INTIT(nolign-1)
  Write [AMU]
  If fstat
   GOK=0 : Call FSTA("AMU") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK<1 : Goto FIN_ECR : Endif
[F:APF]MODULE = 0

$FIN_ECR
Return

$VALMENU
Call TEMPON("E") From GESECRAN
Call VALPROFAPP([M:APM1]CODPRF,nomap) From VALMENU
Call TEMPOFF From GESECRAN
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File APROFIL  [APF1]
 Local File AMENUSER [AMU1]
Else 
 Local File =[M]DOSORG+".APROFIL"  [APF1]
 Local File =[M]DOSORG+".AMENUSER" [AMU1]
Endif 
If [M]DOSDES=nomap 
 Local File APROFIL  [APF2]
 Local File AMENUSER [AMU2]
Else 
 Local File =[M]DOSDES+".APROFIL"  [APF2]
 Local File =[M]DOSDES+".AMENUSER" [AMU2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [APF1], [AMU1], [APF2], [AMU2]
Return

$TR_COP
GOK = 1
Trbegin [APF2], [AMU2]
 Delete [APF2] Where CODPRF=TABLE & MODULE=0
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APROFIL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("APF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AMU2] Where CODPRF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMENUSER" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMU2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [APF1]CODPRF Where CODPRF=TABLE & MODULE=0
  [F:APF2] = [F:APF1]
  If dim([F:APF2]UPDUSR)>0 : [F:APF2]UPDUSR = GUSER : Endif
  If dim([F:APF2]UPDDAT)>0 : [F:APF2]UPDDAT = date$ : Endif
  Write [APF2]
  If fstat
   GOK=0 : Call FSTA("APF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AMU1]CODMEN Where CODPRF=TABLE
  [F:AMU2] = [F:AMU1]
  Write [AMU2]
  If fstat
   GOK=0 : Call FSTA("AMU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################
Subprog INS_MENU(VALEUR)
Variable Char VALEUR()
Local Char    MENUS(10)(500), LISMEN(30)(1..[M:APM9]NBFONC+1)
Local Char    EXTMEN(10), EXTEDT(10), LKFONC(30)
Local Integer IMEN, JMEN, I, NOL
NOL = [M:APM9]NBFONC
If VALEUR<>"" & status<>7
 Look [AFC]MENU(1) = VALEUR
 If !fstat
  Call TEMPON("L") From GESECRAN
  For IMEN=1 To [M:APM9]NBFONC
   LISMEN(IMEN)=vireblc([M:APM9]MENU(IMEN-1)-[M:APM9]FONCTION(IMEN-1)-[M:APM9]CODMEN(IMEN-1),2)
  Next IMEN
  Raz MENUS
  MENUS(0)=VALEUR
  Read [AFC]CODINT="MENU"    : EXTMEN=[F:AFC]CODEXT
  Read [AFC]CODINT="EDITION" : EXTEDT=[F:AFC]CODEXT
  JMEN=0 : IMEN=0
  While MENUS(IMEN)<>""
   For [AFC]MENU Where MENU=[L]MENUS(IMEN)
    If [M:APM9]NBFONC>=dim([M:APM9]MENU) : Break : Endif
    Case [F:AFC]TYPTRAIT
     When 2       : LKFONC=EXTMEN-[F:AFC]TRAIT
     When Default : LKFONC=[F:AFC]CODEXT
    Endcase
    If !find(vireblc([F:AFC]MENU-LKFONC,2),LISMEN)
     Insa NOL,1,[M:APM9]NBFONC [M:APM9]CODMEN,[M:APM9]FONCTION
&     ,[M:APM9]LIBMENU,[M:APM9]MENU,[M:APM9]NUMLI2
&     ,[M:APM9]ORDSYS,[M:APM9]TYPFCT,[M:APM9]INTIT
     [M:APM9]NBFONC += 1
     [M:APM9]MENU(NOL)     = [F:AFC]MENU
     [M:APM9]FONCTION(NOL) = [F:AFC]CODEXT
     Case [F:AFC]TYPTRAIT
      When 1 : [M:APM9]TYPFCT(NOL)   = [F:AFC]TYP
      When 2 : [M:APM9]TYPFCT(NOL)   = 4
     Endcase    
     [M:APM9]LIBMENU(NOL)  = [F:AFC]LIBMENU 
     Call TEXTE([F:AFC]LIBMENU,[M:APM9]INTIT(NOL)) From OBJDIV
     If [F:AFC]TYPTRAIT=2
      [M:APM9]CODMEN(NOL) = [F:AFC]TRAIT
      [M:APM9]FONCTION(NOL)=EXTMEN
     Endif
     NOL += 1
    Endif
    If [F:AFC]TYPTRAIT=2
     JMEN += 1 : MENUS(JMEN)=[F:AFC]TRAIT
    Endif
   Next
   MENUS(IMEN)=""
   IMEN += 1
  Wend
  Call TEMPOFF From GESECRAN
 Endif
Endif
End

Subprog A_PAGE1(CODE)
Value Char CODE()
Local Integer NOL, I
Raz GMODIF, NOL, I
Effzo [APM1]15
K=0
While I<=[M:APM9]NBFONC-1
 If [M:APM9]MENU(I) = [L]CODE
  [M:APM1]LIBMENUS(NOL)  = [M:APM9]LIBMENU(I) 
  If [M:APM1]LIBMENUS(NOL)<>0
   Call TEXTE([M:APM1]LIBMENUS(NOL),[M:APM1]ZLIBMENUS(NOL)) From OBJDIV
  Else 
   [M:APM1]ZLIBMENUS(NOL) = [M:APM9]INTIT(I) 
  Endif 
  [M:APM1]FONCTIONS(NOL) = [M:APM9]FONCTION(I)
  [M:APM1]CODMENS(NOL)   = [M:APM9]CODMEN(I)
  [M:APM1]TYPFCTS(NOL)   = [M:APM9]TYPFCT(I)
  [M:APM1]ORDSYSS(NOL)   = [M:APM9]ORDSYS(I)
  NOL+=1
 Endif
 I += 1
Wend
[M:APM1]NBFONCS = NOL
Affzo [APM1]15
End

Subprog AF_FENS(FCTS)
Value Char FCTS()
Local Integer I, CAS
Gosub SETNOL 
Read [AFC]CODEXT = FCTS
If [M:APM1]OTYP<>[M:APM1]TYPFCTS(NOL)
 [M:APM1]OTYP = [M:APM1]TYPFCTS(NOL)
Endif
If [F:AFC]TYPTRAIT=2
 NOL2=0
 I=find([M:APM1]CODMENS(NOL),[M:APM9]MENU(0..[M:APM9]NBFONC-1))-1
 If I>=0
  While I<[M:APM9]NBFONC & [M:APM9]MENU(I)=[M:APM1]CODMENS(NOL)
   If NOL2>=dim([M:APM1]LMENU)-1 : Break : Endif 
   If [M:APM9]LIBMENU(I)<>0
    Call TEXTE([M:APM9]LIBMENU(I),[M:APM1]LMENU(NOL2)) From OBJDIV 
   Else 
    [M:APM1]LMENU(NOL2) = [M:APM9]INTIT(I) 
   Endif
   If [M:APM9]TYPFCT(I) = 4 : [M:APM1]LMENU(NOL2)+="..." : Endif
   NOL2 += 1 : I+=1
  Wend
 Endif
 [M:APM1]NBLIG = NOL2
 Affzo LMENU
Else
 Effzo LMENU
Endif
End

Subprog SAUV_MENU(MENCOU)
Value Char MENCOU()
Local Integer I, J, NOL2
GMODIF=0
I=find(MENCOU,[M:APM9]MENU(0..[M:APM9]NBFONC-1))-1
If I>=0
 J=I
 While J<[M:APM9]NBFONC-1 & [M:APM9]MENU(J+1)=MENCOU
  J+=1
 Wend
 Dela I,J-I+1,[M:APM9]NBFONC [M:APM9]CODMEN,[M:APM9]FONCTION
& ,[M:APM9]LIBMENU,[M:APM9]MENU,[M:APM9]NUMLI2
& ,[M:APM9]ORDSYS,[M:APM9]TYPFCT,[M:APM9]INTIT
 [M:APM9]NBFONC -= (J-I+1)
Endif
If [M:APM1]NBFONCS<>0
 NOL2 = [M:APM9]NBFONC
 For I = 0 To [M:APM1]NBFONCS-1
  [M:APM9]MENU(NOL2)     = MENCOU
  [M:APM9]LIBMENU(NOL2)  = [M:APM1]LIBMENUS(I) 
  [M:APM9]INTIT(NOL2)    = [M:APM1]ZLIBMENUS(I)
  [M:APM9]FONCTION(NOL2) = [M:APM1]FONCTIONS(I)
  [M:APM9]CODMEN(NOL2)   = [M:APM1]CODMENS(I)
  [M:APM9]ORDSYS(NOL2)   = [M:APM1]ORDSYSS(I)
  [M:APM9]TYPFCT(NOL2)   = [M:APM1]TYPFCTS(I)
  NOL2 += 1
 Next I
Endif
[M:APM9]NBFONC += [M:APM1]NBFONCS
End

## SUP_MENU : suppression de l'arboresence (les fonctions menu en destination)
Subprog SUP_MENU
Local Integer I, J, K, IMEN, JMEN, OK, NOL
Local Char MENU(10)(500), LKMENU(10)
Call TEMPON("O") From GESECRAN
If status=65 : nolign1=nolign : Endif
For NOL=nolign-1 To nolign1-1
If [M:APM1]TYPFCTS(NOL)=4
    ## Contrôle si le menu existe plusieurs fois (I sera > 0)
    I=0
    For J=0 To 1
        I=find([M:APM1]CODMENS(NOL),[M:APM9]CODMEN(I..[M:APM9]NBFONC-1))
    Next J
    ## Contrôle si le menu existe dans le chemin de l'arborescence (I sera = 1)
    If instr(1,"/"+[M:APM1]MENUS+"/","/"+[M:APM1]CODMENS(NOL))<> 0 : I = 1 : Endif
    
    OK=0
    If I<>0
        Call AVERTIR(mess(23,130,1)-[M:APM1]CODMENS(NOL),OK) From GESECRAN
    Endif
    If !OK
        IMEN=0 : JMEN=0
        MENU(0)=[M:APM1]CODMENS(NOL)
        While MENU(JMEN)<>""
            I=find(MENU(JMEN),[M:APM9]MENU(0..[M:APM9]NBFONC-1))-1
            If I>=0
                J=I
                While J<=[M:APM9]NBFONC-1 & [M:APM9]MENU(J)=MENU(JMEN)
                    If [M:APM9]TYPFCT(J)=4
                        ## Contrôle si le menu existe plusieurs fois (I1 sera > 0)
                        I1=0
                        For J1=0 To 1
                            I1=find([M:APM9]CODMEN(J),[M:APM9]CODMEN(I1..[M:APM9]NBFONC-1))
                        Next J1
                        If I1=0
                            IMEN+=1
                            MENU(IMEN) = [M:APM9]CODMEN(J)
                        Endif
                    Endif
                J+=1
                Wend
                Dela I,J-I,[M:APM9]NBFONC [M:APM9]CODMEN,[M:APM9]FONCTION
&                     ,[M:APM9]LIBMENU,[M:APM9]MENU,[M:APM9]NUMLI2
&                     ,[M:APM9]ORDSYS,[M:APM9]TYPFCT,[M:APM9]INTIT
                [M:APM9]NBFONC -= (J-I)
            Endif
            JMEN+=1
        Wend
    Endif
Endif
Next NOL
Call TEMPOFF From GESECRAN
End
 
#### Contrôle des menus 

$EXEC_CONTMEN
Local Integer  I, J
Local Shortint NB : NB=500
Local Integer  NBMEN, FLMEN(NB)
Local Char     TBMEN(10)(NB), MENCOU(80), LIBM(30), MESSA(80)
PARAM(1) = "0"
If GMODIF
 MENCOU = [M:APM1]MENUS
 If instr(1,MENCOU,"/")<>0
  Repeat
   MENCOU = right$(MENCOU,instr(1,MENCOU,"/")+1)
  Until instr(1,MENCOU,"/")=0
 Endif
 Call SAUV_MENU(MENCOU)
Endif
If [M:APM9]NBFONC=0
 GERR = 1 : GMESSAGE = mess(126,124,1) : # Il faut au moins une fonction
 FIN = 1 : Return
Endif
NBMEN=1 : TBMEN(1)=[M:APM9]MENU(0) : FLMEN(1)=1
For I=0 To [M:APM9]NBFONC-1
 If !find([M:APM9]MENU(I),TBMEN(1..NBMEN))
  If NBMEN+1=dim(TBMEN)
   GERR = 1 : GMESSAGE = mess(26,100,1) : # Tableau plein
   Break
  Else
   NBMEN += 1 : TBMEN(NBMEN)=[M:APM9]MENU(I) : FLMEN(NBMEN)=1
  Endif
 Endif
Next I
If GERR : FIN = 1 : Return : Endif
J=find([M:APM1]MENDEP,TBMEN(1..NBMEN))
If J=0 
 GERR = 1 : GMESSAGE = mess(7,130,1)-[M:APM1]MENDEP : FIN = 1 : Return 
 # Menu non défini
Else
 FLMEN(J)=0
Endif
TRA=0 

If 1=0
 Call OUVRE_TRACE("") From LECFIC
 TRA = 1
 For I=0 To [M:APM9]NBFONC-1
  Call ECR_TRACE(num$(I)-[M:APM9]FONCTION(I)-[M:APM9]CODMEN(I)-num$([M:APM9]TYPFCT(I)),0) From GESECRAN
 Next I
Endif

For I=0 To [M:APM9]NBFONC-1
 If [M:APM9]TYPFCT(I)=4
  J=find([M:APM9]CODMEN(I),TBMEN(1..NBMEN))
  If J=0 
   If [M:APM9]LIBMENU(I)<>0
    Call TEXTE([M:APM9]LIBMENU(I),LIBM) From OBJDIV 
   Else 
    LIBM = [M:APM9]INTIT(I) 
   Endif 
   MESSA =  mess(7,130,1)-[M:APM9]MENU(I)+"/"+[M:APM9]CODMEN(I) : #  Menu non défini 
   MESSA += " ("+LIBM+")"
   Gosub TRACE
  Else
   FLMEN(J)=0
  Endif
 Endif
Next I
For I=1 To NBMEN
 If FLMEN(I)=1
  MESSA = mess(8,130,1)-TBMEN(I) : # Menu non accessible 
  Gosub TRACE 
 Endif 
Next I
If TRA
    Call FERME_TRACE From LECFIC 
Endif 
PARAM(1) = "1"
Return
 
$TRACE 
If !TRA
    Call OUVRE_TRACE(mess(9,16,1)) From LECFIC : # Contrôle
     TRA=1 
Endif 
Call ECR_TRACE(MESSA,1) From GESECRAN 
Return 

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

#########################################################################
$SEL_CODMENS
Gosub SETNOL
Case [M:APM1]FONCTIONS(NOL)
 When "AIMP" : # Impression
  OBJET = "ARP"
 When "MENU" : # Menu
  CRITERE = "TYPTRAIT=2"
  OBJET = "AFC"
 When "GESADI","GESADV"
  OBJET = "ADV"
 When "GESAWV"
  OBJET = "AWV"
 When "AMIEXE"
  OBJET = "AMI"
 When "EXEALH"
  OBJET = "ALH"
 When Default
  Local Char SAVACT(20)
  SAVACT = ACTION
  ACTION  = "SEL_CODMENS" : Gosub ACTIONB
  ACTION  = SAVACT
  If NBCOL>0 or OBJET<>"" : Return : Endif
  Call LECTURE("AFC",[M:APM1]FONCTIONS(NOL),"") From CONTOBJ
  If [F:AFC]ACTION<>""
   If clalev([F:ACT])=0 : Local File ACTION  [ACT] : Endif
   Read [ACT]ACTION = [F:AFC]ACTION 
   Case [F:ACT]TYP
    When 1 : # Objet
     If clalev([F:AWI1])=0 : Local File AWINDOW [AWI1] : Endif
     If clalev([F:ATZ1])=0 : Local File ATABZON [ATZ1] : Endif
     Default File [AWI1]
     TIT(0) = mess(3,126,1) : # Choix transaction
     CRITERE = 'OBJ="'+seg$([F:AFC]VALPAR(0),2,len([F:AFC]VALPAR(0))-1)+'"'+' & TRN <> ""'              
     ORDRE   = "TRN"
     START   = "TRN"
     NBCOL = 0
     NBCOL += 1 : COL(NBCOL) = "[F:AWI1]TRN"    : Gosub TEXTE
     NBCOL += 1 : COL(NBCOL) = "[F:AWI1]LIBEL"  : Gosub TEXTE
    When 2 : # Consultation
     If clalev([F:GTC])=0 : Local File GTABACC [GTC] : Endif
     OBJET = "GTC"
     CRITERE = 'CNSCOD="'+[F:ACT]PARAM1+'"'
   Endcase
  Else
   OK = 0
  Endif
Endcase
Return

$TEXTE
Read [ATZ1]CODZONE = "AWINDOW";right$(COL(NBCOL),instr(1,COL(NBCOL),"]")+1)
Call TEXTE([F:ATZ1]NOCOURT,TIT(NBCOL)) From OBJDIV  
Return

#########################################################################
# Etiquettes des masques APM1
#########################################################################

Subprog D_MODULE(VALEUR)
Variable Integer  VALEUR
VALEUR = 0
End

Subprog AS_MENDEP(VALEUR)
Variable Char VALEUR()
If [M:APM1]NBFONCS=0 & instr(1,[M:APM1]MENUS,"/")=0 : Raz [M:APM9]NBFONC : Endif
If [M:APM9]NBFONC=0 & [M:APM1]NBFONCS=0 & inpmode=2
 VALEUR="GENE"
Else
 mkstat=2
Endif
End

Subprog AP_MENDEP(VALEUR)
Variable Char VALEUR() 
If VALEUR<>""
 Call INS_MENU(VALEUR)
 If [M:APM9]NBFONC=0
  GERR = 1 : GMESSAGE = mess(7,130,1)-VALEUR : mkstat=2 : End : # Menu non défini
 Endif
Else
 mkstat = 2
Endif
[M:APM1]MENUS   = VALEUR
[M:APM1]MENUSA  = VALEUR
Call A_PAGE1(VALEUR)
mkstat=0
End

Subprog AM_FONCTIONS(VALEUR)
Variable Char VALEUR()
GMODIF=1
Read [AFC]CODEXT = VALEUR
If fstat<>0 | ([F:AFC]TYPTRAIT=2 & [F:AFC]CODINT<>"MENU")
 GERR = 1 : GMESSAGE = mess(2,130,1) : mkstat=2 : End : # Code fonction inexistant
Else
 Case [F:AFC]TYPTRAIT
  When 1 : [M:APM1]TYPFCTS(nolign-1)   = [F:AFC]TYP
  When 2 : [M:APM1]TYPFCTS(nolign-1)   = 4
 Endcase
 If [F:AFC]ACTION="EXESYS"
  TYPFCTS(nolign-1) = 6
 Endif    
Endif
Call SET_FORMAT(VALEUR)
End

Subprog SET_FORMAT(FONCTION)
Value Char FONCTION
If FONCTION="" | nolign<1
 [M]FORMAT = "10B"
Else
 Case [M:APM1]TYPFCTS(nolign-1)
  When 0 : [M]FORMAT = "10B"
  When 4 : [M]FORMAT = "5B" : # menu
  When Default
   Case FONCTION
    When "AIMP"    : [M]FORMAT = num$(GLONARP)+"c"
    When "ADPVAL"  : [M]FORMAT = num$(GLONADP)+"d"
    When "SYSTEME" : [M]FORMAT = "10x"
    When "GIMPOBJ" : [M]FORMAT = num$(GLONAOE)+"x"
    When "GEXPOBJ" : [M]FORMAT = num$(GLONAOE)+"x"
    When "GESADI"  : [M]FORMAT = num$(GLONADI)+"x"
    When Default   : [M]FORMAT = "10B"
   Endcase
 Endcase
Endif
End

Subprog AV_CODMENS(VALEUR)
Variable Char    VALEUR()
Call SET_FORMAT([M:APM1]FONCTIONS(nolign-1))
End

Subprog AS_CODMENS(VALEUR)
Variable Char VALEUR()
Read [AFC]CODEXT=[M:APM1]FONCTIONS(nolign-1)
If [F:AFC]AIDE<>0
 Local Char INFO(50)
 Call TEXTE([F:AFC]AIDE,INFO) From OBJDIV
 Inftxt INFO At 2
Endif
End

Subprog C_CODMENS(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Case [M:APM1]TYPFCTS(NOL)
 When 4
  If find(VALEUR,"","MENU") : mkstat=1 : End
  Elsif instr(1,"/"+[M:APM1]MENUS+"/","/"+VALEUR+"/")<>0
   GMESSAGE = mess(3,130,1) : # Menu déjà utilisé dans le chemin d'accès
   mkstat=2 : End
  Endif
Endcase
End

Subprog AM_CODMENS(VALEUR)
Variable Char VALEUR()
GMODIF = 1
Gosub SETNOL
If [M:APM1]TYPFCTS(NOL)=4
 Local Integer OK
 Gosub SETNOL
 OK=1
 For I=0 To [M:APM1]NBFONCS-1
  If [M:APM1]TYPFCTS(I)=4 & [M:APM1]CODMENS(I)=VALEUR & NOL<>I
   OK=0 : Break
  Endif
 Next I
 If find(VALEUR,[M:APM9]MENU(0..[M:APM9]NBFONC-1))
  OK=0
 Endif
 If !OK
  Call AVERTIR(mess(9,130,1),OK) From GESECRAN : # Menu déjà utilisé
  If OK=1 : mkstat=1 : Endif
 Endif
 Read [AFC]CODINT=VALEUR
 If fstat: Read [AFC]CODINT=[M:APM1]FONCTIONS(NOL) : Endif
Endif
End

######################### Variable de bas de tableau 

Subprog AS_NBFONCS
GSTATUT = 0
If nolign>dim([M:APM1]FONCTIONS) : End : Endif : # mb 17.12.3 bug 20505 jc a dit non !
[M:APM1]LIG = nolign
# Raffraichissement fenêtre de droite (liste du menu)
If nolign<>FENLIG & nolign<=dim([M:APM1]FONCTIONS)
 FENLIG = nolign
 Call AF_FENS([M:APM1]FONCTIONS(nolign-1))
Endif
End

Subprog AVANT_NBFONCS
[M:APM1]LIG = nolign
If FENLIG<>nolign
 FENLIG = nolign
 Call AF_FENS([M:APM1]FONCTIONS(nolign-1))
Endif
End

Subprog C_NBFONCS
Local Integer OK
Case status
 When 65,68,83
  GMODIF=1 : Call SUP_MENU
Endcase
End

Subprog B3_NBFONCS 
# Origine
Local Char    MENORG(80), MENCOU(80) 
Local Integer K
Gosub SETNOL
MENCOU = [M:APM1]MENUS
K = instr(1,MENCOU,"/") 
If K=0 : End : Endif
Repeat
 MENCOU = right$(MENCOU,K+1)
 K = instr(1,MENCOU,"/") 
Until K=0
[M:APM1]MENUS = left$([M:APM1]MENUS,instr(1,[M:APM1]MENUS,MENCOU)-2)
MENORG   = [M:APM1]MENUS
K = instr(1,MENORG,"/") 
If K<>0
 Repeat
  MENORG = right$(MENORG,K+1)
  K = instr(1,MENORG,"/") 
 Until K = 0
Endif
If GMODIF : Call SAUV_MENU(MENCOU) : Endif
Call A_PAGE1(MENORG)
[M:APM1]MENUSA = [M:APM1]MENUS
Affzo [APM1]MENUSA
FENLIG = NOL+1 : Call AF_FENS([M:APM1]FONCTIONS(NOL)) 
mkstat = 1
nolign = NOL+1
End

Subprog B4_NBFONCS
Local Char    MENCOU(80) 
Local Integer K
Gosub SETNOL
If [M:APM1]FONCTIONS(NOL)="MENU"
 MENCOU = [M:APM1]MENUS
 K = instr(1,MENCOU,"/") 
 If K<>0
  Repeat
   MENCOU = right$(MENCOU,K+1)
   K = instr(1,MENCOU,"/") 
  Until K = 0
 Endif
 If len([M:APM1]MENUS)<>0
  [M:APM1]MENUS += "/"
 Endif
 [M:APM1]MENUS += [M:APM1]CODMENS(NOL)
 If GMODIF : Call SAUV_MENU(MENCOU) : Endif
 Call A_PAGE1([M:APM1]CODMENS(NOL))
 FENLIG = NOL+1 : Call AF_FENS([M:APM1]FONCTIONS(NOL)) 
 [M:APM1]MENUSA = [M:APM1]MENUS
 Affzo [APM1]MENUSA 
Endif
mkstat = 1
nolign = NOL+1
End

Subprog AS_ZLIBMENUS(VALEUR)
Variable Char VALEUR
If VALEUR = "" & GMODIF = 1
 Call TEXTE([F:AFC]LIBMENU,VALEUR) From OBJDIV
Endif
End
 
Subprog C_ZLIBMENUS(VALEUR)
Variable Char VALEUR
Gosub SETNOL 
Read [ATX]TEXTE = GLANGUE;VALEUR
If !fstat
 [M:APM1]LIBMENUS(NOL) = [F:ATX]NUMERO
Else
 [M:APM1]LIBMENUS(NOL) = 0
Endif
GMODIF=1
If [M:APM1]FONCTIONS(NOL)<>"" & [M:APM1]TYPFCTS(NOL)=4
 Read [AFC]CODINT = [M:APM1]CODMENS(NOL)
 If !fstat & !find([M:APM1]CODMENS(NOL),[M:APM9]MENU(0..[M:APM9]NBFONC-1))
  Call INS_MENU([M:APM1]CODMENS(NOL))
 Endif
Endif
End

$INIT_ZLIBMENUS
Gosub SETNOL
If [M:APM1]FONCTIONS(NOL)="" or [M:APM1]TYPFCTS(NOL)<>6
 FIN = 1
Endif
Return

$DIA_ZLIBMENUS
[M:DIA]ORDSYS = [M:APM1]ORDSYSS(NOL)
Return

$CONT_ZLIBMENUS
[M:APM1]ORDSYSS(NOL) = [M:DIA]ORDSYS
Return






