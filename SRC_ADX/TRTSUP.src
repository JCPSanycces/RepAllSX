#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque TRTSUP
#MIPEA SOURCE REMERGE
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Already done by DBA
###################################################################################################################

#** V8 : Waiting Time Mangement **#
#*********************************#

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTSUP","TRTSUP",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTSUP
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE From TRTAUT     :#86255

#JOJAC - 2016-08-10 - X3PEOP-854 - START
 #ADNGO - 2016-08-08 - X3PEOP-853 - START
 #When "DEBUT"       : Affzo [DIA]: Setmok [DIA] With 0
 #ADNGO - 2016-08-08 - X3PEOP-853 - END
 #JOJAC - 2016-08-10 - X3PEOP-854 - END

 When "EXEC"        : Gosub EXEC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 :# GOK = 0
 When "DEBUT"       : Gosub DEBUT From TRTAUT     :#86255
 When "BOUTON"      : Gosub BOUTON From TRTAUT    :#86255
 When "SORTIE"      : Gosub SORTIE From TRTAUT    :#86255
Endcase
Return


#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Local Char    VALPAR(10) , MATRI(GLONEML)
Local Integer NBPCE
Local Date    DATPAYE , DATMAT

Gosub OUVFIC

TIT = mess(16,10703,1)     : # Suppression des bulletins de paye

#86255
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Local Mask TRTSUP [DIA]
Raz [M:DIA]
[M:DIA]DATPAYSTR  = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]DATPAYEND  = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
DATPAYE           = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
[M:DIA]FLGLOCK=len(mess(0,10872,1)) : # Verrouillé US 2022 65062

Call LECMEMO("STD","[M:DIA]","sup") From GMEMO

#86255
Call AFF_MEMO From DIVPAYE
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:CRB])=0 : Local File CALRUB     [CRB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:CUM])=0 : Local File CUMUL      [CUM] : Endif
If clalev([F:HRSDP])=0 : Local File SOLDPAY    [HRSDP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:BCB])=0 : Local File BCLOB      [BCB] : Endif
If clalev([F:VAN])=0 : Local File VALANA     [VAN] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If GINTMT=1
 If clalev([F:PSN])=0 : Local File PRESTATION [PSN] : Endif
Endif
If clalev([F:MAL])=0 : Local File MALADIE    [MAL] : Endif
If clalev([F:HRTAT])=0 : Local File TABAT      [HRTAT] : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:TIM])=0  : Local File TIMCOD     [TIM] : Endif
#**If clalev([F:CNG])=0  : Local File CNGCPY     [CNG] : Endif
#**If clalev([F:CNE])=0  : Local File CNGEMP     [CNE] : Endif
#**If clalev([F:TIC])=0  : Local File TIMCNG     [TIC] : Endif
#**
#*!
If clalev([F:TIM])=0  : Local File TIMCOD     [TIM] : Endif
If clalev([F:CNG])=0  : Local File CNGCPY     [CNG] : Endif
If clalev([F:CNE])=0  : Local File CNGEMP     [CNE] : Endif
If clalev([F:TIC])=0  : Local File TIMCNG     [TIC] : Endif
#LIPET - 2017-05-20 - END
###**72216
If clalev([F:HRHSR])=0  : Local File HISTOREGUL [HRHSR] : Endif

Gosub OUVRE From WPDEFTABLE
#ADNGO - 2016-08-08 - X3PEOP-853 - START
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
#ADNGO - 2016-08-08 - X3PEOP-853 - END
Return

#######################################################
## Prise en compte des critères
#######################################################
$EXEC
Local Integer NOK , ANUSAI

#ADNGO - 2016-08-08 - X3PEOP-853 - START
#Attention car en réalité limite superv à 50 caract !(Cf. table APLLCK)
#ADNGO - 2016-08-08 - X3PEOP-853 - END

Local Char    SYMBOLE(80)

#ADNGO - 2016-08-08 - X3PEOP-853 - START
Local Char    SYMBCTR(80) :#92316
#ADNGO - 2016-08-08 - X3PEOP-853 - END

Local Date    DATPAY
Local Integer OKC , OKPAY
Local Char    CRITVEP(250)
Local Char    BULLETIN(GLONVCR)
Local Char    CRITERE_LOCK(GDIMFIC) : # Verrouillé US 2022 65062

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# mise en place du filtre sur la table des salariés

#86255
CRITERE = '[F:CPY]LEG="'+GCURLEG+'"'
CRITERE -= '& [F:ID]ENAFLG=2 & [F:ID]FLGPAY=2'
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

CRITVEP = 'PYRDAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
CRITVEP -= '& PYRDAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
CRITVEP -= '& PST=1'  : # Comptabilisée
CRITVEP -= '& RVS<>2' : # Pas d'extourne
If [M:DIA]ENAFLG=1 :# Ne pas recalculer les bulletins déjà calculer
 CRITVEP -= '& STA=1'
Endif

If [M:DIA]ALLFCY<>2
 CRITERE -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"' :# site
 CRITVEP -= '& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLSRV<>2
 CRITERE -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"' :# service
 CRITVEP -= '& SRV="'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2
 CRITERE -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"' :# profil
 CRITVEP -= '& PRF="'+[M:DIA]PRF+'"'
Endif

#ADNGO - 2016-08-08 - X3PEOP-853 - START

If [M:DIA]ALLFCY<>2
 CRITVEP -= '& FCY="'+[M:DIA]FCY+'"'
Endif

#ADNGO - 2016-08-08 - X3PEOP-853 - END

# Verrouillé US 2022 65062
[L]CRITERE_LOCK = "1=1"  : If [M:DIA]FLGLOCK<>len(mess(0,10872,1)) Then [L]CRITERE_LOCK += "& [F:VEP]FLGLOCK="+num$([M:DIA]FLGLOCK) : Endif

If [M:DIA]POP<>""
#86255
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY,
&    [HRPOA]POA0= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&   As [LNK]
&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&   [ID]ID0 = [F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE)
Endif


ANUSAI = ([M:DIA]ANUSAI=2)
Gosub DEFSOL

For [LNK]
 Gosub SALARIE
Next

If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(num$(NBPCE)-mess(17,10703,1),0) From GESECRAN : # Bulletin(s) supprimé(s)
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

###########################################################################
# Critères pour supprimer un bulletin :
## - On doit pouvoir verrouiller le symbole VEP
## - Avoir accès au code d'accès en exécution
## - Avoir droit à la fonction pour le site du salarié
## - L'entête du bulletin doit correspondre aux critères de sélection
## - Le bulletin ne doit pas être comptabilisé
## - L'état du bulletin doit valoir "saisi" ou si demandé, "calculé" ou "imprimé"
## - Le bulletin doit être dans la borne des dates de début et de fin
## - Si le bulletin concerne un intermittent, le contrat lié ne doit pas être en cours de modification :#92316
###########################################################################
$SALARIE
#86255
For [VEP] Where EMP=[F:ID]REFNUM  & evalue(CRITVEP) & CTRNUM=[HRCTR]CTRNUM & CTRDAT=[HRCTR]CTRDAT & evalue([L]CRITERE_LOCK) : # Verrouillé US 2022 65062
 Call CONTROLE([F:VEP]EMP,[F:VEP]CTRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKC,0) From DIVPAYE
 If OKC
  BULLETIN = [F:VEP]BUL
  OKPAY=1
#ADNGO 2016-08-08 - X3PEOP-853 - START

 If [M:DIA]ALLCPY<>2   :# société
   Read [FCY]FCY0 = [F:VEP]FCY
   If fstat | [F:FCY]LEGCPY<>[M:DIA]CPY
    OKPAY = 0
   Endif
 Endif
 If OKPAY

#ADNGO - 2016-08-08 - X3PEOP-853 - END
  # Verrou
  Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
  Lock =SYMBOLE
  If fstat
   Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
   OKPAY = 0
  Endif
 Endif

#JOJAC - 2016-08-10 - X3PEOP-854 - START
 #92316
  If OKPAY & GINTMT & [F:ID]FLGINT=2
   SYMBCTR = func TRTSUP.CTRSYMBOLE
   Lock =SYMBCTR
   If fstat
    Call ECR_TRACE([F:CTR]CTRNUM-":"-mess(10,100,1),1) From GESECRAN
    OKPAY = 0
   Endif
  Endif
  #end 92316
#JOJAC - 2016-08-10 - X3PEOP-854 - END

  If OKPAY
   Call DEBTRANS From GLOCK
   Gosub SUPPR_LIGNES
   If GOK=1
    Call ECR_TRACE([F:ID]REFNUM-":"-mess(16,10703,1)-BULLETIN,0) From GESECRAN
    #Suppression des bulletins de paye
    NBPCE += 1
   Endif
  Endif
  Unlock =SYMBOLE

  #ADNGO - 2016-08-08 - X3PEOP-853 - START
   Unlock =SYMBCTR :#92316
  #ADNGO - 2016-08-08 - X3PEOP-853 - END

 Endif
Next
Return

###########################################################################
# Suppression des bulletins
###########################################################################
$SUPPR_LIGNES
GOK = 1
Trbegin [HSP]
 Gosub ANUPAY
 If   GOK<0 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ANUPAY
GPOINT = "ANULPAI" : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

## Solde des paiements
Gosub MAJSOL
If GOK<1 : Return : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#** Gosub MAJCNG
#** If GOK<1 : Return : Endif
#**
#*!
 Gosub MAJCNG
 If GOK<1 : Return : Endif
#LIPET - 2017-05-20 - END
## Cumuls rubriques
Gosub MAJCUM
If GOK<1 : Return : Endif

## Historique
Delete [HSP] Where BUL=BULLETIN
If fstat
 GOK = -1 : GLOCK = "$HISTOPAYE" : Return
Endif

###**72216
## Historique des réguls
#On supprime le détail des réguls de paie qui sera recréé lors d'un nouveau calcul
#La suppression du détail des réguls de rétro est faite uniquement en suppression du bulletin (pas en annulation de calcul)
#et est gérée dans le subprog UNSET_BULREC() de TRTRETVAL, appelé plus bas...
Delete [HRHSR] Where BUL=BULLETIN & RETNUM=""
If fstat
 GOK = -1 : GLOCK = "$HISTOREGUL" : Return
Endif
 # SEGAY  US 2331-88174 BULDEM
Gosub INIT_ISDEMAT From SUBVEP

 ##PEVAN 2017-09-05 X3-39461 START
 If func AFNC.ACTIV("GLM")
   If clalev([F:HRACCR]) = 0: Local File HRLVEACCRU [HRACCR] : Endif
   If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
   For [HRACCR] Where [HRACCR]LVEACCPRD = BULLETIN and [HRACCR]LVEACCLST <> ""
    Filter [HRLSTH] Where [HRLSTH]COD = [HRACCR]LVEACCLST
    Read [HRLSTH] First
    If fstat = 0
      If [HRLSTH]LVEACCOPT = 1 | [HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 4 | [HRLSTH]LVEACCOPT = 5
        Delete [HRACCR]
      Endif
    Endif
    Filter [HRLSTH]
   Next
   Filter [HRACCR]
 Endif
 ##PEVAN 2017-09-05 X3-39461 END

If ANUSAI
 ## Valeurs
 Delete [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=[F:VEP]EMP & DAT=[F:VEP]PYRDAT & BUL=BULLETIN
 If fstat
 GOK = -1 : GLOCK = "$VALEUR" : Return
 Endif
 ## Imputations analytiques
 Delete [VAN] Where EMP=[F:VEP]EMP & PYRDAT=[F:VEP]PYRDAT & BUL=BULLETIN
 If fstat
  GOK = -1 : GLOCK = "$VALANA" : Return
 Endif
 ## Texte des bulletins
 #  Delete [ACB] Where IDENT1=[F:VEP]EMP & IDENT2=[F:VEP]PYRDAT
 Delete [BCB] Where IDENT2=[F:VEP]BUL
 If fstat
  GOK = -1 : GLOCK = "$BCLOB" : Return
 Endif
 #LIPET - 2017-05-20 - START
 #** V7 : Waiting Time Mangement **#
 #**If GTPS
 #**  ## Bulletin calendrier
 #**  If clalev([F:BUL])=0 : Local File BULCAL     [BUL] : Endif
 #**  Delete [BUL] Where REFNUM=[F:VEP]EMP & PYRDAT=[F:VEP]PYRDAT & BUL=BULLETIN
 #**  If fstat
 #**   GOK = -1 : GLOCK = "$BULCAL" : Return
 #**  Endif
 #**
 #** ## Régulariations issues des demandes de congé passées
 #** If clalev([F:TIG])=0 : Local File TIMREGUL   [TIG] : Endif  #**Update [TIG] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & DATBUL=[F:VEP]PYRDAT & FLGBUL=2 With DATBUL=[0/0/0]
 #** If fstat
 #**  GOK = -1 : GLOCK = "$TIMREGUL" : Return
 #** Endif
 #**Endif
 #**
 #*!
 If GTPS
   ## Bulletin calendrier
   If clalev([F:BUL])=0 : Local File BULCAL     [BUL] : Endif
   Delete [BUL] Where REFNUM=[F:VEP]EMP & PYRDAT=[F:VEP]PYRDAT & BUL=BULLETIN
   If fstat
    GOK = -1 : GLOCK = "$BULCAL" : Return
   Endif

  ## Régulariations issues des demandes de congé passées
  If clalev([F:TIG])=0 : Local File TIMREGUL   [TIG] : Endif  #Update [TIG] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & DATBUL=[F:VEP]PYRDAT & FLGBUL=2 With DATBUL=[0/0/0]
  #JOJAC - 2017-10-30 - X3-15908 - START
  Update [TIG] Where REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & DATBUL=[F:VEP]PYRDAT & [F:TIG]BUL=[F:VEP]BUL With [F:TIG]DATBUL=[0/0/0], [F:TIG]BUL=""
  #JOJAC - 2017-10-30 - X3-15908 - START
  If fstat
   GOK = -1 : GLOCK = "$TIMREGUL" : Return
  Endif
 Endif
 #LIPET - 2017-05-20 - END
 ## Extourne ??
 If [F:VEP]RVS=2
  Local Date DATORG
  Local Char MATORG(GLONEML)
  Local Char BULORG(GLONVCR)
  DATORG = [F:VEP]ORIDAT
  MATORG = [F:VEP]EMP
  BULORG = [F:VEP]ORIBUL
  Update [VEP] Where BUL=BULORG With RVSDAT=[0/0/0]
  If fstat=1
   GOK = -1 : GLOCK = "$VALEMP"-MATORG : Return
  Endif
 Endif
 ## Déflag des lignes de prestation
 #56772
 If GINTMT=1
  If [F:ID]FLGINT=2 : # Pour ne pas perdre du temps
   Update [PSN] Where BUL=[F:VEP]BUL With BUL=""
   If fstat=1
    GOK = -1 : GLOCK = "$PRESTATION"-[F:VEP]BUL : Return
   Elsif fstat
    GOK = 0 : Call FSTA("PSN") From GLOCK : Return
   Endif
  Endif
 Endif
 ## Raz de la zone bulletin des attestations AT et Maladie
 Update [HRTAT] Where BUL=[F:VEP]BUL With BUL="", STAATT=2
 If fstat=1
  GOK = -1 : GLOCK = "$TABAT"-[F:VEP]BUL : Return
 Elsif fstat
  GOK = 0 : Call FSTA("HRTAT") From GLOCK : Return
 Endif
 Update [MAL] Where BUL=[F:VEP]BUL With BUL="", STAATT=2
 If fstat=1
  GOK = -1 : GLOCK = "$MALADIE"-[F:VEP]BUL : Return
 Elsif fstat
  GOK = 0 : Call FSTA("MAL") From GLOCK : Return
 Endif

 Call UNSET_BULPP([F:VEP]EMP, [F:VEP]CTRNUM, [F:VEP]BUL) From TRTPREPAY
 If [V]GOK < 1 : Return : Endif

 Call UNSET_BULREC([F:VEP]BUL) From TRTRETVAL
 If [V]GOK < 1 : Return : Endif

 ## En-tête de paye
 Delete [VEP] Curr
 If fstat
  GOK = -1 : GLOCK = "$VALEMP"-[F:VEP]BUL : Return
 Endif
Else
 [F:VEP]STA = 1
 If [L]WISDEMAT : [F:VEP]FLGDEMAT=1 : Endif :#88174 BULDEM
 Rewrite [VEP]
 If fstat
  GOK = 0 : Call FSTA("VEP") From GLOCK : Return
 Endif
Endif
Return

$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto SUPPR_LIGNES : Endif

$DEFSOL
Local Char    PAYACPT1(GLONRUB) , PAYACPT2(GLONRUB) , PAYACPT3(GLONRUB) , PAYNET(GLONRUB)(1..5)
Local Integer RGACPT ,RGACPT2 ,RGACPT3 , RGNET(1..5)
Local Char    RUBCUM(GLONRUB)(1..200) , CUMCUM(GLONCUM)(1..200)
Local Integer NRUBCUM , NCUMCUM , RUBCUMN(1..200) , CUMCUMN(1..200) , STACUM

#ADNGO - 2016-08-08 - X3PEOP-853 - START
Local Char    RUBCUM(GLONRUB)(1..1000) , CUMCUM(GLONCUM)(1..1000)
Local Integer NRUBCUM , NCUMCUM , RUBCUMN(1..1000) , CUMCUMN(1..1000) , STACUM
#ADNGO - 2016-08-08 - X3PEOP-853 - END

Call PARAM(GCURLEG,"PAYACPT1",PAYACPT1) From ADOVAL
Call PARAM(GCURLEG,"PAYACPT2",PAYACPT2) From ADOVAL
Call PARAM(GCURLEG,"PAYACPT3",PAYACPT3) From ADOVAL
If PAYACPT1<>""
 Read [RUB]RUB0 = GCURLEG;PAYACPT1
 RGACPT = [F:RUB]ROW
Endif
If PAYACPT2<>""
 Read [RUB]RUB0 = GCURLEG;PAYACPT2
 RGACPT2 = [F:RUB]ROW
Endif
If PAYACPT3<>""
 Read [RUB]RUB0 = GCURLEG;PAYACPT3
 RGACPT3 = [F:RUB]ROW
Endif
For I=1 To 5
 Call PARAM(GCURLEG,"PAYNET"+num$(I),PAYNET(I)) From ADOVAL
 If PAYNET(I)<>""
  Read [RUB]RUB0 = GCURLEG;PAYNET(I)
  RGNET(I) = [F:RUB]ROW
 Endif
Next I
NRUBCUM = 0
For [RUB] Where CUMNUMADI<>""
 NRUBCUM += 1
 RUBCUM(NRUBCUM)  = [F:RUB]COD
 RUBCUMN(NRUBCUM) = val(right$([F:RUB]CUMNUMADI,len([F:RUB]CUMNUMADI)))
Next
NCUMCUM = 0
For [CUM] Where CUMNUMADI<>""
 NCUMCUM += 1
 CUMCUM(NCUMCUM)  = [F:CUM]CUMCOD
 CUMCUMN(NCUMCUM) = val(right$([F:CUM]CUMNUMADI,len([F:CUM]CUMNUMADI)))
Next
Return

$MAJSOL
Readlock [HRSDP]SDP0 = [F:VEP]EMP;[F:VEP]CTRNUM
If fstat=1
 GOK = -1 : GLOCK = "$SOLDPAY"-[F:VEP]EMP-[F:VEP]CTRNUM : Return
Elsif !fstat
 If PAYACPT1<>""
  Read [HSP]HSP3 = [F:VEP]BUL;PAYACPT1;1
  If !fstat
   [F:HRSDP]BNCPOA -= [F:HSP]AMT
  Endif
 Endif
 If PAYACPT2<>""
  Read [HSP]HSP3 = [F:VEP]BUL;PAYACPT2;1
  If !fstat
   [F:HRSDP]BNCPOA2 -= [F:HSP]AMT
  Endif
 Endif
 #DBA : Gestion des reports d'acomptes
 If PAYACPT3<>""
  Read [HSP]HSP3 = [F:VEP]BUL;PAYACPT3;1
  If !fstat
   [F:HRSDP]BNCPOA += [F:HSP]AMT
  Endif
 Endif
 For I=1 To 5
  If PAYNET(I)<>""
   Read [HSP]HSP3 = [F:VEP]BUL;PAYNET(I);1
   If !fstat
    Case I
     When 1 : [F:HRSDP]BNC1 -= [F:HSP]AMT
     When 2 : [F:HRSDP]BNC2 -= [F:HSP]AMT
     When 3 : [F:HRSDP]BNC3 -= [F:HSP]AMT
     When 4 : [F:HRSDP]BNC4 -= [F:HSP]AMT
     When 5 : [F:HRSDP]BNC5 -= [F:HSP]AMT
    Endcase
   Endif
  Endif
 Next I
 Rewrite [HRSDP]
 If fstat
  GOK = 0 : Call FSTA("HRSDP") From GLOCK : Return
 Endif
Endif
Return

###DBA le 15/09/05
############################################
### Mise à jour des congés par employé
############################################
$MAJCNG
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Call LECTURE("FCY",[F:VEP]FCY,"") From CONTOBJ
#**For [F:TIM]TIM0 Where CATTIM=3
#** Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[F:TIM]COD & STRPER<=[F:VEP]PYRDAT & ENDPER>=[F:VEP]PYRDAT
#** Read[F:CNG]CNG0 First
#** Filter [F:CNG]
#** If !fstat
#**  Readlock [F:CNE]CNE0 = [F:CNG]YEA;[F:VEP]EMP;[F:VEP]CTRNUM;[F:TIM]COD
#**  If fstat=1
#**   GOK = -1 : GLOCK = "$CNGEMP"-num$([F:CNG]YEA)-[F:VEP]EMP-[F:TIM]COD : Break
#**  Elsif !fstat
#**   If [F:CNG]CUM<>""
#**    Read [HSP]HSP3 = [F:VEP]BUL;[F:CNG]CUM;6
#**    If !fstat
#**     [F:CNE]NBRDAY -= [F:HSP]AMT
#**     Rewrite [F:CNE]
#**     If fstat
#**       GOK = 0 : Call FSTA("CNE") From GLOCK : Break
#**     Endif
#**    Endif
#**   Endif
#**  Endif
#** Endif
#**Next
#**If GOK<1 : Return : Endif
#**
#*!
Call LECTURE("FCY",[F:VEP]FCY,"") From CONTOBJ
For [F:TIM]TIM0 Where CATTIM=3
 Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[F:TIM]COD & STRPER<=[F:VEP]PYRDAT & ENDPER>=[F:VEP]PYRDAT
 Read[F:CNG]CNG0 First
 Filter [F:CNG]
 If !fstat
  Readlock [F:CNE]CNE0 = [F:CNG]YEA;[F:VEP]EMP;[F:VEP]CTRNUM;[F:TIM]COD
  If fstat=1
   GOK = -1 : GLOCK = "$CNGEMP"-num$([F:CNG]YEA)-[F:VEP]EMP-[F:TIM]COD : Break
  Elsif !fstat
   If [F:CNG]CUM<>""
    Read [HSP]HSP3 = [F:VEP]BUL;[F:CNG]CUM;6
    If !fstat
     [F:CNE]NBRDAY -= [F:HSP]AMT
     Rewrite [F:CNE]
     If fstat
       GOK = 0 : Call FSTA("CNE") From GLOCK : Break
    Endif
    Endif
   Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif
#LIPET - 2017-05-20 - END
Return

$MAJCUM
