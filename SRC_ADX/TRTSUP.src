## Sélection matricule
$SEL_TABLE
Case TABLE
 When "SELEMP"
  OBJET   = "EML"
  CRITERE = "ENAFLG=1"
Endcase
Return

#------------------------------------------------------------------------------------------------
# Annulation d'un bulletin
#------------------------------------------------------------------------------------------------
# => Réutilisation de l'ANUPAY de la fonction TRTSUP pour l'utiliser en annulation en masse
#    depuis la rétroactivité (ou autre ... ).
#------------------------------------------------------------------------------------------------
Subprog ANNULE_BULLETIN(BULLETIN, ANUSAI, STAT)
Value Char BULLETIN()
Value Integer ANUSAI
Variable Integer STAT

#---------------------------------------------------------------------------------------
# Déclarations nécessaires pour réutiliser le "ANUPAY"
# => I, il en faut toujours un ^^
# => Les tables qui vont bien (OUVFIC devrait nous le faire)
# => Une variable BULLETIN contenant le numéro de bulletin, on la récupère en paramétre
# => Une variable ANUSAI pour annuler ou non les saisies, idem
# => Les paramètres mis en place par le "DEFSOL"
#---------------------------------------------------------------------------------------
Local Integer I
Gosub OUVFIC From TRTSUP
Gosub DEFSOL From TRTSUP

# Pour controle de chronologie
If not clalev([F:VEP2]) : Local File VALEMP [VEP2] : Endif

#---------------------------------------------------------------------------------------
# Nos variables purement locales
#---------------------------------------------------------------------------------------
Local Integer OK, TRANSACTION_LOCALE, OKC, OKPAY, OK_ANNULE
#Attention car en réalité limite superv à 50 caract !(Cf. table APLLCK)
Local Char SYMBOLE(80), CRITERE_VEP(250)

#---------------------------------------------------------------------------------------
# Quels sont les critères qui permettent de supprimer "sans risque" un bulletin ?
#---------------------------------------------------------------------------------------
Raz [L]CRITERE_VEP
If vireblc([L]CRITERE_VEP,4) <> "" : [L]CRITERE_VEP -= "&" : Endif
[L]CRITERE_VEP -= "[F:VEP]PST = 1"    : # Non comptabilisé

[L]TRANSACTION_LOCALE = 1            : # Démarrage de la transaction dans notre petit sous-programme ?

If not(adxlog)
    Call DEBTRANS From GLOCK
    Trbegin [VEP]
    [L]TRANSACTION_LOCALE = 2        : # Oui, on a été appelé sans transaction
Endif

Repeat
    [V]GOK = 1 : [L]OK = 2

    Readlock [F:VEP]VEP5 = [L]BULLETIN
    If fstat = 1
        [V]GOK = -1
        [V]GLOCK = "$VALEMP"
    Elsif fstat <> 0
        [V]GOK = 0
        Call RSTA("VEP", [L]BULLETIN) From GLOCK
    Endif
    If [V]GOK = 1 & evalue([L]CRITERE_VEP)

        # Est ce que ce bulletin est bien le "dernier" du salarié / contrat
        # => Contrôle à l'identique de ce qui est fait en suppression depuis GESVEP
        #    voir pour faire un subprog AUTORISE_ANNULE(BULLETIN) générique ?

        [L]OK_ANNULE = 2

        Filter [F:VEP2] Where [F:VEP2]EMP = [F:VEP]EMP & [F:VEP2]CTRNUM = [F:VEP]CTRNUM
        Read [F:VEP2]VEP0 Last
        Filter [F:VEP2]
        If fstat<=2 & ([F:VEP2]BUL <> [F:VEP]BUL
&       | [F:VEP]FLGLOCK=2)   : # Verrouillé US 2022 65062
            [L]OK_ANNULE = 1
            #ADNGO - 2016-08-08 - X3PEOP-853 - START
            [V]GOK = -1 :#80366
            #ADNGO - 2016-08-08 - X3PEOP-853 - END
            If [F:VEP2]BUL <> [F:VEP]BUL
            # MESSTAG : Opération impossible : ce bulletin n'est pas le dernier.
              Call ECR_TRACE([L]BULLETIN-mess(214,703,1), 1) From GESECRAN
            Endif
            If [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
              # MESSAGE : Opération impossible : ce bulletin est verrouillé.
              #              Call ECR_TRACE([L]BULLETIN-mess(224,703,1), 1) From GESECRAN
              Call ECR_TRACE([F:VEP]EMP-"("+mess(6,10506,1)-[F:VEP]CTRNUM-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1),0) From GESECRAN
            Endif
            [V]GOK = -1 :#80366
        Endif

        If [L]OK_ANNULE = 2
            ##**82073
            #[L]SYMBOLE = "VEP"+format$("D:"+GFMDAT4,[F:VEP]PYRDAT)+"\"+[F:VEP]EMP+"\"+[F:VEP]CTRNUM
            Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
            Lock =[L]SYMBOLE
            If fstat <> 0
                [V]GOK = -1
                [V]GLOCK = "%" + [L]SYMBOLE
                # mess(10,100,1) : Modification en cours sur un autre poste
                Call ECR_TRACE([F:VEP]EMP-":"-mess(10,100,1),1) From GESECRAN
            Endif

            If [V]GOK = 1
                Call CONTROLE([F:VEP]EMP, datesyst, [F:VEP]CTRNUM,"", [L]OKC, 0) From DIVPAYE
                If [L]OKC
                    Gosub ANUPAY From TRTSUP
                    If [V]GOK = 1
                        # mess(16,10703,1) : Suppression des bulletins de paie
                        Call ECR_TRACE([F:VEP]EMP-":"-mess(16,10703,1)-[L]BULLETIN,0) From GESECRAN
                    Endif
                Endif
            Endif

            Unlock =[L]SYMBOLE

        Endif

    Endif

    If [L]TRANSACTION_LOCALE = 2
        If [V]GOK = 1
            Commit
        Else
            Rollback
            If [V]GOK = -1
                Call ROLL From GLOCK
                If not [V]GROLL : [L]OK = 1 : Endif
            Endif
        Endif
    Endif
Until [L]OK = 2

End

#ADNGO - 2016-08-08 - X3PEOP-853 - START
#92316
Funprog CTRSYMBOLE ()
Local Char SYMB (80)
Default File [CTR]
SYMB = "CTR"+[F]CTRNUM+"\"+[F]REFNUM+"\"+format$("D:"+GFMDAT4,[F]CTRDAT)
End SYMB
#end 92316
#ADNGO - 2016-08-08 - X3PEOP-853 - END

