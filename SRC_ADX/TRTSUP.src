Readlock [EPC]EPC0 = [F:VEP]EMP;[F:VEP]CTRNUM
If fstat=-1
 GOK = -1 : GLOCK = "$EMPLOCUM"-[F:VEP]EMP-[F:VEP]CTRNUM : Return
Elsif fstat
 STACUM = fstat
 If STACUM
  Raz [F:EPC]
  [F:EPC]REFNUM = [F:VEP]EMP
  [F:EPC]CTRNUM = [F:VEP]CTRNUM
 Endif

