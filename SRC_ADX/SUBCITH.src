# Gestion du masque CPTITH


Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif

End

Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If [M]TOUSITE = 2 Raz VALEUR : mkstat = 1 Endif

End

Subprog AM_TOUSITE(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 
   Raz   [M]STOFCY
   Raz   [M]ITMREFSTR
   Raz   [M]ITMREFEND
   Affzo [M]STOFCY
   Affzo [M]ITMREFSTR
   Affzo [M]ITMREFEND
Else
  [M]STOFCY = GFCYDEF(7)
Endif
End

Subprog AS_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]TOUSITE = 2 Raz VALEUR : mkstat = 1 Endif

End

Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If [M]TOUSITE = 2 Raz VALEUR : mkstat = 1 Endif

End



