############################################################
Subprog AS_CSTCOD(VALEUR)
Variable Integer VALEUR

GMENLOC(7) = 1    # Prix ordre
GMENLOC(12)= 1    # Prix tarif (issue 76982)
#GMENLOC(13)= 1    # Secondary issue method (issue X3-72887)

# If ACCDATFLG is true, only allow Primary and Secondary valuation method
#If [M:SVAL]ACCDATFLG = 2
#  GMENLOC(1) = 1
#  GMENLOC(2) = 1
#  GMENLOC(3) = 1
#  GMENLOC(4) = 1
#  GMENLOC(5) = 1
#  GMENLOC(6) = 1
#  GMENLOC(7) = 1
#  GMENLOC(8) = 1
#  GMENLOC(10)= 1
#  GMENLOC(11)= 1
#Else
#  GMENLOC(13) = 1    # Secondary issue method.

  If [M:SVAL]REFDAT <> date$ & [M:SVAL]REFDAT<>[0/0/0]    # Si REFDAT=[0/0/0] on est en saisi des paramètres batch
    GMENLOC(3) = 1    # Dernier prix
# Issue 72060 - 2012-06-01 by CCC : Etat valo FIFO à date
#    GMENLOC(5) = 1    # Prix FIFO
    GMENLOC(8) = 1    # Prix LIFO
    If [M:SVAL]ACCDATFLG <> 2
      GMENLOC(9) = 1    # Méthode article
    Endif
    GMENLOC(10) = 1    # Prix budget
    GMENLOC(11) = 1    # Prix simulé
    # Issue 69597 - 2011-01-11 by CCC : Autoriser PM lot si Etat à date du jour
    GMENLOC(6) = 1    # PM lot
  Endif
#Endif

End

############################################################
Subprog AM_CSTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=4 & dim([M]PMP2)>0
    Actzo [M]PMP2
Else
    Grizo [M]PMP2
    [M]PMP2=1
Endif
# Issue 69597 - 2011-01-11 by CCC : Le PM Lot impose un état détaillé
If VALEUR=6
    [M:SVAL]DETFLG = 2
    Grizo [M:SVAL]DETFLG
    Affzo [M:SVAL]DETFLG
    If [M:SVAL]REFDAT<>[0/0/0]
        [M:SVAL]REFDAT = date$
    Endif
Elsif [M:SVAL]REFDAT = date$
&   | [M:SVAL]REFDAT = [0/0/0]
    Actzo [M:SVAL]DETFLG
Endif

If find(VALEUR,3,6,8,10,11)
  [M:SVAL]REFDAT = date$
  Grizo [M:SVAL]REFDAT
Else
  Actzo [M:SVAL]REFDAT
Endif

#X3-63842
Case VALEUR
  When 9
    Actzo [M:SVAL]ACCDATFLG
    If [M:SVAL]ACCDATFLG = 2
      [M:SVAL]AMTDEVFLG = 2

      Actzo [M:SVAL]STRDAT
      Affzo [M:SVAL]AMTDEVFLG, STRDAT
      Diszo [M:SVAL]AMTDEVFLG, AMTDEVDAT
    Else
      Effzo [M:SVAL]STRDAT
      Diszo [M:SVAL]STRDAT
    Endif
  When 13
    [M:SVAL]ACCDATFLG = 2
    [M:SVAL]AMTDEVFLG = 2

    Actzo [M:SVAL]STRDAT
    Affzo [M:SVAL]AMTDEVFLG, STRDAT
    Diszo [M:SVAL]AMTDEVFLG, AMTDEVDAT, ACCDATFLG
  When Default
    If [M:SVAL]DETFLG = 2
      Effzo [M:SVAL]ACCDATFLG
      Diszo [M:SVAL]ACCDATFLG
    Else
      Actzo [M:SVAL]ACCDATFLG
    Endif
    Effzo [M:SVAL]STRDAT
    Diszo [M:SVAL]STRDAT
Endcase
[M:SVAL]CSTCOD = VALEUR
Call AM_ACCDATFLG([M:SVAL]ACCDATFLG)
Affzo [M:SVAL]ACCDATFLG

End
############################################################
Subprog AS_RPTCUR(VALEUR)
Variable Integer VALEUR
If GLOCALDEV = GSYSCUR
  mkstat = 2
Endif
End
############################################################
Subprog C_REFDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > date$ | !GBATCH & VALEUR=[0/0/0]
    mkstat = 2
    End
Endif

#X3-63842 we dont want to control these fields if we are using the new report
If [M:SVAL]ACCDATFLG = 2 and find([M:SVAL]CSTCOD,9,13)
  End
Endif

If VALEUR < date$ and find([M:SVAL]CSTCOD,3,6,8,10,11)

    GOK = 0
    GMESSAGE='Date range not allowed for this costing mode'
    mkstat = 2
    End
Endif

If VALEUR <> date$
& & !(GBATCH & VALEUR=[0/0/0])
  [M]DETFLG = 1
  Affzo [M]DETFLG
  Grizo [M]DETFLG
  [M]TOTLOTFLG = 1
  [M]TOTITMFLG = 1
  Grizo [M]TOTLOTFLG,TOTITMFLG
# CCC (23/05/06) Bug 36310
#  [M]AAASTA = 2
#  [M]QQQSTA = 2
#  [M]RRRSTA = 2
#  [M]TRAFLG = 2
#  Grizo [M:SVAL]AAASTA,QQQSTA,RRRSTA,TRAFLG
Else
  Actzo [M]DETFLG
  Actzo [M]TOTLOTFLG,TOTITMFLG
  Actzo [M:SVAL]AAASTA,QQQSTA,RRRSTA
  # Issue 76149 - 2011-09-09 by CCC
  If GWRHACT=2
      If [M:SVAL]TOTWRHFLG<>2
          Actzo [M:SVAL]TRAFLG
      Else
          [M:SVAL]TRAFLG=1
          Grizo [M:SVAL]TRAFLG
      Endif
  Endif
Endif
End

############################################################
# Calcule de la valeur PMP du stock à date
# en partant de la valeur de la dernière sortie
############################################################
# PQTY doit contenir la quantité actuelle
############################################################
Subprog CLCPMP2(PFCY,PITM,PFILSTJWRH,PDAT,PQTY,PAMT,PPRI,PRET)
Value Char PFCY
Value Char PITM
Value Char PFILSTJWRH
Value Date PDAT
Variable Decimal PQTY
Variable Decimal PAMT
Variable Decimal PPRI
Variable Integer PRET

Local Decimal LAMTE, LQTYE
Local Char LITM(GLONITM),LFCY(GLONFCY)

Raz PRET, PAMT, PPRI

# Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
# On parcourt tous les mouvements jusqu'à la 1ère sortie avant PDAT afin de recalculer la quantité à date
# Dès qu'on a CREDAT<=PDAT on calcule le montant et la quantité entrée
Filter [STJ] Where STOFCY = PFCY
&                & OWNER  = PFCY
&                & ITMREF = PITM
&                & evalue(PFILSTJWRH)
&                & UPDCOD = 2
&            Order By Key XTJ=CREDAT Desc;CRETIM Desc;IPTDAT Desc;MVTSEQ;MVTIND
For [STJ]XTJ
    If [F:STJ]CREDAT<=PDAT
        LSENS = func STKLIB.SENSTRS([F:STJ]TRSTYP)
        # CCC (2010-01-13) Bug 57684 : Sauter les mouvements de sortie non valorisés au PMP
        #If [F:STJ]REGFLG=1 & (LSENS=2 | LSENS=3 & [F:STJ]ACTQTY<0 & [F:STJ]PRINAT=5)
        If [F:STJ]REGFLG=1 & (LSENS=2 | LSENS=3 & [F:STJ]ACTQTY<0) & [F:STJ]PRINAT=5
            #If [F:STJ]PRINAT<>5
            #    # Erreur, il faut que la sortie ait été valorisée au PMP
            #    PRET = 1
            #    Raz PQTY,LQTYE,PAMT,LAMTE
            #Else
                If PQTY>0
                    PAMT = [F:STJ]PRIORD * PQTY
                Elsif PQTY+LQTYE=0
                    PPRI = [F:STJ]PRIORD
                    Raz PQTY, PAMT
                    Raz LAMTE, LQTYE
                Endif
            #Endif
            Break
        Endif
        # Pour les entrées on cumule les quantités et montants afin de pouvoir recalculer le PMP
        LQTYE += [F:STJ]ACTQTY
        LAMTE += [F:STJ]VARORD
    Endif
    PQTY -= [F:STJ]ACTQTY
Next
Filter [STJ]
If PRET | PQTY+LQTYE<=0
    Raz PQTY, PAMT
Else
    PQTY+=LQTYE
    PAMT+=LAMTE
    PPRI = PAMT/PQTY
Endif
End

############################################################
# Issue 121652 - 2017-03-13 MJH. added PACCFLG
Funprog CALAMTDEV( PITM, PFCY, PDATDEB, PDATFIN, PACCFLG )
Value Char PITM   # FGR 18/01/2010 : X3SUIVI60986
Value Char PFCY   # FGR 18/01/2010 : X3SUIVI60986
Value Date PDATDEB
Value Date PDATFIN
Value Integer PACCFLG

Local Decimal LAMTDEV
Local Date    LDAT1, LDAT2
If PDATDEB>PDATFIN
    End 0
Endif

# Issue 121652.s - 2017-03-13 MJH. Initializing DATE_SOURCE based on if we are using accounting date or not.
Local Char DATE_SOURCE(6)
If PACCFLG = 1
  DATE_SOURCE = "ACCDAT"
Else
  DATE_SOURCE = "IPTDAT"
# Issue 121652.e

  # If using accounting date we cant look at history because it only has information using IPTDAT
  #This can cause using Accounting date to be slower with large data sets.
  If clalev([F:ITH]) = 0 : Local File ITMMVTHIS  [ITH] : Endif

  Columns [ITH] (PERSTR,PEREND,AMTDEV)
  Filter [ITH] Where ITMREF  = PITM
&                  & STOFCY  = PFCY
&                  & PERSTR >= PDATDEB
&                  & PEREND <= PDATFIN
  For [ITH]
      If LDAT1=[00/00/00]
          LDAT1=[ITH]PERSTR
      Endif
      LDAT2=[ITH]PEREND
      LAMTDEV+=[ITH]AMTDEV
  Next
  Filter [ITH]
  Columns [ITH]
Endif

# Issue 89156 - 2013-05-27 by CCC
If LDAT2=[0/0/0]
    # Pas d'enreg ITH trouvé, il faut parcourir les mouvements sur la période [PDATDEB,PDATFIN]
    Columns [STJ] (AMTDEV)
    # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
    # Issue 121652 - 2017-03-13 MJH. changed 'IPTDAT' to 'evalue(DATE_SOURCE)'
    For [STJ] Where STOFCY = PFCY
&                 & OWNER  = PFCY
&                 & UPDCOD = 2
&                 & ITMREF = PITM
&                 & evalue(DATE_SOURCE) >= PDATDEB
&                 & evalue(DATE_SOURCE) <= PDATFIN
&                 & AMTDEV <>0
        LAMTDEV += [STJ]AMTDEV
    Next
    Columns [STJ]
Else
    # Enreg ITH trouvé, il faut parcourir les mouvements sur les périodes [PDATDEB,LDAT1[ et ]LDAT2,PDATFIN]
    If LDAT1 <> PDATDEB
        Columns [STJ] (AMTDEV)
        # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
        # Issue 121652 - 2017-03-13 MJH. changed 'IPTDAT' to 'evalue(DATE_SOURCE)'
        For [STJ] Where STOFCY = PFCY
&                     & OWNER  = PFCY
&                     & UPDCOD = 2
&                     & ITMREF = PITM
&                     & evalue(DATE_SOURCE) >= PDATDEB
&                     & evalue(DATE_SOURCE) < LDAT1
&                     & AMTDEV <>0
            LAMTDEV += [STJ]AMTDEV
        Next
        Columns [STJ]
    Endif
    If LDAT2 <> PDATFIN
        Columns [STJ] (AMTDEV)
        # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
        # Issue 121652 - 2017-03-13 MJH. changed 'IPTDAT' to 'evalue(DATE_SOURCE)'
        For [STJ] Where STOFCY  = PFCY
&                     & OWNER  = PFCY
&                     & UPDCOD  = 2
&                     & ITMREF  = PITM
&                     & evalue(DATE_SOURCE)  > LDAT2
&                     & evalue(DATE_SOURCE) <= PDATFIN
&                     & AMTDEV <> 0
            LAMTDEV += [STJ]AMTDEV
        Next
        Columns [STJ]
    Endif
Endif

End LAMTDEV


#############################################################
# MAJCUM : Mise à jour de totaux
#############################################################
$MAJCUM
Local Integer I
#------- Acheteur ------------#
If [F:ITF]BUY<>""
    Readlock [SVC]SVC0=num$(adxuid(1));[F:STV]STOFCY;[F:ITM]TCLCOD;0;"";[F:ITF]BUY
    If fstat
        Raz [F:SVC]

        [F:SVC]PRONUM    = num$(adxuid(1))
        [F:SVC]STOFCY    = [F:STV]STOFCY
        [F:SVC]TCLCOD    = [F:ITM]TCLCOD
        [F:SVC]BUY       = [F:ITF]BUY
        [F:SVC]AMT       = [F:STV]AMT
        [F:SVC]AMTDEV    = [F:STV]AMTDEV
        [F:SVC]AMTDEVDAT = [F:STV]AMTDEVDAT
        [F:SVC]CUR       = [F:STV]CUR
        [F:SVC]CREUSR    = GUSER
        [F:SVC]CREDAT    = date$
        LSAVITM=[F:STV]ITMREF
        Write [SVC]
    Else
        [F:SVC]AMT   += [F:STV]AMT
        If [F:STV]ITMREF<>LSAVITM
            LSAVITM=[F:STV]ITMREF
            [F:SVC]AMTDEV+= [F:STV]AMTDEV
        Endif
        Rewrite [SVC]
    Endif
Endif
#----------- Famille stat ------------#
For I=0 To dim([ITM]TSICOD)-1
    If [F:ITM]TSICOD(I)<>""
        Readlock [SVC]SVC0=num$(adxuid(1));[F:STV]STOFCY;[F:ITM]TCLCOD;I+20;[F:ITM]TSICOD(I);""
        If fstat
            Raz [F:SVC]
            [F:SVC]PRONUM    = num$(adxuid(1))
            [F:SVC]STOFCY    = [F:STV]STOFCY
            [F:SVC]TCLCOD    = [F:ITM]TCLCOD
            [F:SVC]TSINUM    = I+20    # 20= 1ère table diverse des fam stat
            [F:SVC]TSICOD    = [F:ITM]TSICOD(I)
            [F:SVC]AMT       = [F:STV]AMT
            [F:SVC]AMTDEV    = [F:STV]AMTDEV
            [F:SVC]AMTDEVDAT = [F:STV]AMTDEVDAT
            [F:SVC]CUR       = [F:STV]CUR
            [F:SVC]CREUSR    = GUSER
            [F:SVC]CREDAT    = date$
            LSAVITM=[F:STV]ITMREF
            LSAVFCY=[F:STV]STOFCY
            Write [SVC]
        Else
            [F:SVC]AMT   += [F:STV]AMT
            If [F:STV]ITMREF<>LSAVITM
                LSAVITM=[F:STV]ITMREF
                [F:SVC]AMTDEV+= [F:STV]AMTDEV
            Endif
            Rewrite [SVC]
        Endif
    Endif
Next

Return

##########################################################################

##########################################################################
Subprog C_AMTDEVFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
  #X3-63842 Only assign if not using new report
    If [M:SVAL]ACCDATFLG <> 2 and find([M:SVAL]CSTCOD,9,13)
      [M:SVAL]AMTDEVDAT=date$
    Endif
    Actzo [M:SVAL]AMTDEVDAT
  Else
    Raz [M:SVAL]AMTDEVDAT
    Diszo [M:SVAL]AMTDEVDAT
  Endif
  Affzo [M:SVAL]AMTDEVDAT
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 03/01/2011 15:52:30 (CCC)
######################################################################################
Subprog AM_AMTDEVFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    If dim([M:SVAL]TOTWRHFLG)>0
        [M:SVAL]TOTWRHFLG=1
        Grizo [M:SVAL]TOTWRHFLG
        Affzo [M:SVAL]TOTWRHFLG
    Endif
    Actzo [M:SVAL]TRAFLG  # Au cas où il aurait été grisé par TOTWRHFLG
Else
    If dim([M:SVAL]TOTWRHFLG)>0
        Actzo [M:SVAL]TOTWRHFLG
    Endif
Endif
End

