##########################################################################
## Etiquette ajoutée par le superviseur 05/03/2004 16:31:08 (CCC)
##########################################################################
Subprog C_DETFLG(VALEUR)
Variable Integer VALEUR
    If VALEUR<>2
        Effzo [M:SVAL]TOTLOTFLG, TOTITMFLG, TOTVERFLG
        Grizo [M:SVAL]TOTLOTFLG, TOTITMFLG, TOTVERFLG
    Else
        Actzo [M:SVAL]TOTLOTFLG, TOTITMFLG
        If find([M:SVAL]CSTCOD,9,13) and [M:SVAL]ACCDATFLG = 2
          Actzo [M:SVAL]TOTVERFLG
        Else
          Diszo [M:SVAL]TOTVERFLG
        Endif
    Endif
End


