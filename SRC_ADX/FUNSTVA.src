######################################################################################
Subprog AM_ACCSTR(VALEUR)
Variable Char    VALEUR()
  If [M:SVAL]ACCSTR = [M:SVAL]ACCEND | VALEUR > [M:SVAL]ACCEND
    [M:SVAL]ACCEND = VALEUR
    Affzo [M:SVAL]ACCEND
  Endif
End

