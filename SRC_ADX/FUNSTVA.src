##########################################################################
Subprog C_STOFCYSTR(VALEUR)
Variable Char    VALEUR()
Local Integer LOK
Gosub VERIF_FCY
End

Subprog C_STOFCYEND(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_FCY
End


##########################################################################
$VERIF_FCY
Look [FCY]FCY1=[M:SVAL]CPY;VALEUR
If fstat
    GMESSAGE = mess(412,199,1)
    mkstat=2
