#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH_VALSTO
  When "INIT"           : Gosub INIT_VALSTO
  When "CONTROLE"       : Gosub CONTROLE_VALSTO
  When "EXEC"           : Gosub EXEC_VALSTO
  When "TERMINE"        : Gosub TERMINE_VALSTO
  When "INIT_DIA"       : Gosub INIT_SVAL_VALSTO
  When "OUVRE"          : Gosub OUVRE_VALSTO
  When "DEBUT"          : Gosub DEBUT_VALSTO
  When "OK"             : Gosub OK_VALSTO
  When "END"            : Gosub END_VALSTO
  When "BOUTON"         : Gosub BOUTON
Endcase
Return
#############################################################
$OUVRE_BATCH_VALSTO
Gosub OPEN_FILE
Return
#############################################################
$INIT_VALSTO
Gosub OPEN_FILE
Local Mask STOVAL [SVAL]
# Issue 79491 - 2012-02-08 by CCC : L'initialisation des champs doit être faite en INIT_DIA
[M:SVAL]NPRNAM = "STOCK12G"
[M:SVAL]AAASTA = 2
[M:SVAL]QQQSTA = 2
[M:SVAL]RRRSTA = 2
[M:SVAL]ACCDATFLG = 1   # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
[M:SVAL]CSTCOD = 9 #X3-63842 Default cost method to primary
Call LECMEMO("STD","[M:SVAL]","stva") From GMEMO
Return
#############################################################
$CONTROLE_VALSTO
Return
#############################################################
$EXEC_VALSTO
    If [M:SVAL]CPY <> ""
      Gosub TRAITEMENT
    Endif
Return
#############################################################
$TERMINE_VALSTO
Return
#############################################################
$INIT_SVAL_VALSTO
Raz [M:SVAL]
# Issue 73450 - 2011-05-17 by CCC : L'initialisation des champs doit être faite en INIT_DIA
# En paramétrage batch, les valeurs sont chargées juste après
[M:SVAL]NPRNAM = "STOCK12G"
[M:SVAL]AAASTA = 2
[M:SVAL]QQQSTA = 2
[M:SVAL]RRRSTA = 2
[M:SVAL]ACCDATFLG = 1       # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
Call LECMEMO("STD","[M:SVAL]","stva") From GMEMO
Return
#############################################################
$OUVRE_VALSTO

Return
#############################################################
$DEBUT_VALSTO
# Issue 73450 - 2011-05-17 by CCC : L'initialisation des champs doit être faite en INIT_DIA
#Raz [M:SVAL]
#[M:SVAL]NPRNAM = "STOCK12G"
#[M:SVAL]AAASTA = 2
#[M:SVAL]QQQSTA = 2
#[M:SVAL]RRRSTA = 2
#Call LECMEMO("STD","[M:SVAL]","stva") From GMEMO
If [M:SVAL]AMTDEVFLG<>2
    Diszo [M:SVAL]AMTDEVDAT
Else
    Actzo [M:SVAL]AMTDEVDAT
Endif
If [M:SVAL]ACCDATFLG<>2
    Diszo [M:SVAL]STRDAT, ACCSTR, ACCEND, TOTACCCOD, TOTVERFLG
    Actzo [M:SVAL]BUYSTR, BUYEND, TOTBUYFLG, TSICODSTR, TSICODEND, TOTTSIFLG
Else
    Actzo [M:SVAL]STRDAT, ACCSTR, ACCEND, TOTACCCOD
    Diszo [M:SVAL]BUYSTR, BUYEND, TOTBUYFLG, TSICODSTR, TSICODEND, TOTTSIFLG
    If [M:SVAL]DETFLG=2
      Actzo [M:SVAL]TOTVERFLG
    Else
      Diszo [M:SVAL]TOTVERFLG
    Endif
Endif
If !GBATCH
    Grizo [M:SVAL]30
Else
    Call C_NPRDEN([M:SVAL]NPRDEN)   # Issue 73450 - 2011-05-17 by CCC
Endif
Affzo [M:SVAL]
Setmok [M:SVAL] With 0

Return
#############################################################
$OK_VALSTO
FIN  = 1
Return
#############################################################
$END_VALSTO
Raz [M:SVAL]
FIN = 1
Return
#############################################################
$BOUTON
  Case BOUT
    When "r"  # Recall memo
      Call AM_ACCDATFLG([M]ACCDATFLG)
      Call AM_CPY([M]CPY)
  Endcase
Return
#############################################################
$TRAITEMENT
Local Char     WFIL(250)
Local Char     WFILFCY(250)
Local Char     WFILITM(250)
Local Char     WFILITF(250)
Local Char     WFILTSI(250)
Local Char     WFILSTO(250)(3),WSTR(250)
Local Char     WFILITW(250)(3)
Local Char     WMSG(80)
Local Char     WFCY(GLONFCY)
Local Char     WITM(GLONITM)
Local Char     WLOT(GLONLOT)
Local Char     WDMY(1)
Local Char     WCUR(3)
Local Date     WDAT
Local Integer  WCSTCOD
Local Decimal  WQTE(4)    # 0:Total ; 1:statut A ; 2:Q ; 3:R
Local Decimal  WQTF, WQTY, WQTYRCP, WQTYISS, WQTYCHG
Local Decimal  WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG, WAMTTRA
Local Decimal  WCOU, WCRS, WPOT, WACT, WCOE, WCOF
Local Integer  WRET
Local Integer  WMAX : WMAX = GMAXUPDTRS # Issue 91102 - 2013-08-05 by CCC
Local Integer  WCPT
Local Char     WPCU(GLONUOM)
Local Integer  ICRIT
Local Char     LFILSTJWRH(250)
# contient le précédent article pour éviter de cumuler plusieurs fois
# l'amtdev d'un même article-site sur la catégorie site
# (toutes les lignes de STV d'un même article site ont le même montant AMTDEV)
Local Char     LSAVITM(GLONITM) : Raz LSAVITM
#
Local Integer  WUOMI
Local Char     WUOMV(GLONUOM)(300)
Local Integer  WUOMD(300)
#
Local Integer  I, J, K, L, M, N
# Chargement paramètres ETAT
Local  Char    WETATP(10)(45)
Local Char     WETATV(10)(45)
#

If [M:SVAL]REFDAT = [0/0/0]
    [M:SVAL]REFDAT = date$
Endif

Gosub PUR_STV
Gosub TRT_INI
If !GSERVEUR
    Call OUVRE_TRACE("FUNSTVA"-mess(49,200,1)-num$([M:SVAL]REFDAT)) From LECFIC
Endif

Gosub TRT_FUNSTVA

If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
Return
###########################################################
$TRT_FUNSTVA
Local Integer LNBITF
Local Integer LACCFLG : LACCFLG=0
Local Char LACCIFA(3)
# CCC (27/07/06) Demande 37152
#   La variable WFBDVLT (méthode interdite pour un état à date) peut être modifée dans le PE REAART
Local Integer WFBDVLT(10)
Raz WFBDVLT
WFBDVLT(0)=3
WFBDVLT(1)=5
WFBDVLT(2)=8

# Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOVALWRK","CST") From STKVALECR

#Filter Site
WFILFCY = "FCY>=[M:SVAL]STOFCYSTR"
If [M:SVAL]STOFCYEND<>""
    WFILFCY+="&FCY<=[M:SVAL]STOFCYEND"
Endif
If [M:SVAL]CPY<>""
    WFILFCY+="&LEGCPY=[M:SVAL]CPY"
Endif

For [FCY] Where evalue(WFILFCY)
    # CCC (07/07/05) Bug 31195
    Raz WITM

    # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
    LACCFLG = 0
    If [M:SVAL]ACCDATFLG=2
        Call PARAM([F:FCY]FCY,"ACCIFA",LACCIFA) From ADOVAL
        If val(LACCIFA)>1
            LACCFLG = 1
        Endif
    Endif

    $TRTITF
    Trbegin [STV]
    Raz WCPT
    Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&              As   [LNK]
&              Where STOFCY = [F:FCY]FCY
&                  & ITMREF>WITM
&                  & evalue(WFILITF)
&                  & evalue(WFILITM)
&                  & evalue(WFILTSI)
    For [LNK]
      LNBITF += 1
      GPOINT = "REAART"              #hcb 210105  27552
      GPE    = 0                     #hcb 210105  27552
      Gosub  ENTREE From EXEFNC      #hcb 210105  27552
      If GPE = 0                     #hcb 210105  27552
         Gosub TRT_ARTICLE
         WCPT += 1
         If WCPT >= WMAX
            WITM = [F:ITF]ITMREF
            Break
         Endif
      Endif                          #hcb 210105  27552
    Next

    Commit
    If WCPT >= WMAX
        Goto $TRTITF
    Endif
Next

#---- Impression ----#
If LNBITF>0
  Gosub CHARG_PARAM_ETAT
  Gosub GET_REPORT_NAME
  If !GSERVEUR
    Call ETAT([M:SVAL]NPRNAM,GFONCTION,WETATP,WETATV) From ETAT
  Else
    # Issue 71923 - 2011-03-11 by CCC : Impression dans un fichier
    # Ouverture des masques pour lancement impression
    # AIMP1 doit être ouvert en dernier pour être le masque par défaut
    If clalev([M:AIP])=0 : Local Mask AIMP0    [AIP] : Raz [M:AIP] : Endif
    If clalev([M:RPT])=0 : Local Mask AIMP1    [RPT] : Endif
    Raz [M:RPT]
    [M:RPT]FICHIER = [M:SVAL]FICHIER
    Call ETATDIFF([M:SVAL]NPRNAM,[M:SVAL]NPRDEN,GLANGUE,GTRACE<>"","",WETATP,WETATV,[0/0/0],"") From AIMP3
  Endif
Else
    Call ERREUR(mess(114,184,1)) From GESECRAN
    SAI = 1
Endif
Return
###########################################################
$TRT_ARTICLE
Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
If fstat
  Raz [F:ITV]
Endif
# CCC (2009-04-10) Bug 54426 : On se positionne sur la méthode de valo dans tous les cas car on s'en sert plus tard pour savoir si la régul de sortie est active
If [F:TCM]VLTCOD = "" | [F:TCM]VLTCOD<>[F:ITF]VLTCOD
    Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM]
    [F:ITF]VLTCOD = [F:TCM]VLTCOD    # Pour éviter une relecture ensuite si [f:itf]vltcod=""
Endif
# Filter on valuation method (can't be included in WFILITF)
If [M:SVAL]VLTSTR <> "" | [M:SVAL]VLTEND <> ""
  If [M:SVAL]ACCDATFLG = 1
    # If not in acct date mode, just filter on current VLTCOD
    If [F:TCM]VLTCOD<[M:SVAL]VLTSTR | [F:TCM]VLTCOD>[M:SVAL]VLTEND
        Return
    Endif
  Else
    # If in acct date mode, check on history too if applicable
    Local Integer VLTFOUND
    For I = dim([F:ITF]VLTCODHIS)-1 To 0 Step -1
      If [F:ITF]VLTCODHIS(I)>=[M:SVAL]VLTSTR | [F:ITF]VLTCODHIS(I)<=[M:SVAL]VLTEND
        If [F:ITF]VLTCODDAT(I) >= gdatetime$(format$("DZ:YYYY[-]MM[-]DD",[M]STRDAT)+"T00:00:00Z")
          VLTFOUND = 1
          Break
        Endif
      Endif
    Next
    If [F:TCM]VLTCOD>=[M:SVAL]VLTSTR | [F:TCM]VLTCOD<=[M:SVAL]VLTEND
      VLTFOUND = 1
    Endif
    If !VLTFOUND : Return : Endif
  Endif
Endif

#If primary or secondary method
If find([M:SVAL]CSTCOD,9,13)
  WCSTCOD = [F:TCM]ISSVLTCOD
  If [M]REFDAT<>date$ & find(WCSTCOD,WFBDVLT) & [M:SVAL]ACCDATFLG<>2
    Return
  Endif
Else
    WCSTCOD = [M:SVAL]CSTCOD
Endif

If [M:SVAL]ACCDATFLG = 2 and find([M:SVAL]CSTCOD,9,13)
  # If ACCDATFLG is yes - we use the new Point in Time tables for the report
  Gosub PIT_VALUATION_REPORT From FUNSTVAPIT
Elsif [M:SVAL]DETFLG = 1
  If GWRHACT=2
    Raz [F:ITW]
  Endif
  Gosub ETAT_GLOBAL
  If GWRHACT=2 & [M:SVAL]TOTWRHFLG=2 & [M:SVAL]TRAFLG<>2
# Issue 83575 - 2012-08-13 by CCC
# 118413.n 2016-09-28 MJH
#        For [ITW] Where evalue(WFILITW) # 118413.o
    For [ITW] Where ITMREF = [F:ITF]ITMREF
&                 & STOFCY = [F:ITF]STOFCY
      Gosub ETAT_GLOBAL
    Next
  Endif
Else
  Gosub ETAT_DETAIL
Endif
Return
###########################################################
$ETAT_GLOBAL
Local Char REQ(250)(6) : # LDAT(250) : # GH 02/05/2016 bug 115120 : # performance optimisation
Local Integer IREQ

Raz WQTE, WQTF, WQTYRCP, WQTYISS, WQTYCHG, WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG, WAMTTRA
Raz WRET
#
Raz [F:STO]
If GWRHACT=2 & [M:SVAL]TOTWRHFLG=2
    For [STO] Where ITMREF=[F:ITF]ITMREF
&                 & STOFCY=[F:ITF]STOFCY
&                 & WRH=[F:ITW]WRH
&                 & evalue(WFILITW)
        Case left$([F:STO]STA,1)
            When "A" : WQTE(1) += [F:STO]QTYSTUACT
            When "Q" : WQTE(2) += [F:STO]QTYSTUACT
            When "R" : WQTE(3) += [F:STO]QTYSTUACT
        Endcase
    Next
    WQTE(0) = sum(WQTE(1..3))
    LFILSTJWRH="WRH='"+[F:ITW]WRH+"'"
Else
# Issue 83575 - 2012-08-13 by CCC
    If dim([M:SVAL]WRHSTR)<=0 | [M:SVAL]WRHSTR="" & [M:SVAL]WRHEND=""
        WQTE(1) = [F:ITV]PHYSTO + [F:ITV]PLFPHYSTO + [F:ITV]BPRPHYSTO + [F:ITV]SCOPHYSTO
        WQTE(2) = [F:ITV]CTLSTO + [F:ITV]PLFCTLSTO + [F:ITV]BPRCTLSTO + [F:ITV]SCOCTLSTO
        WQTE(3) = [F:ITV]REJSTO + [F:ITV]PLFREJSTO + [F:ITV]BPRREJSTO + [F:ITV]SCOREJSTO
        WQTE(0) = sum(WQTE(1..3))
        LFILSTJWRH="1=1"
    Else
        For [STO] Where evalue(WFILITW)
            Case left$([F:STO]STA,1)
                When "A" : WQTE(1) += [F:STO]QTYSTUACT
                When "Q" : WQTE(2) += [F:STO]QTYSTUACT
                When "R" : WQTE(3) += [F:STO]QTYSTUACT
            Endcase
        Next
        WQTE(0) = sum(WQTE(1..3))
        LFILSTJWRH=WFILITW
    Endif
Endif

If [M:SVAL]TRAFLG  = 2
    # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
    If LACCFLG<>0
# GH 02/05/2016 bug 115120 : # performance optimisation
