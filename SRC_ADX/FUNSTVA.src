############################################################
Subprog AM_STOFCYSTR(VALEUR)
Variable Char    VALEUR()
If [M:SVAL]STOFCYSTR = [M:SVAL]STOFCYEND | VALEUR > [M:SVAL]STOFCYEND
    [M:SVAL]STOFCYEND = VALEUR
    Affzo [M:SVAL]STOFCYEND
Endif

If dim([M:SVAL]WRHSTR)>0 and [M:SVAL]ACCDATFLG = [V]CST_ANO
    If VALEUR="" | VALEUR<>[M]STOFCYEND | [F:FCY]WRHGES<>2
       Effzo [M]WRHEND, WRHSTR
       Diszo [M]WRHEND, WRHSTR
    Else
       Actzo [M]WRHEND, WRHSTR
    Endif
Endif
End

