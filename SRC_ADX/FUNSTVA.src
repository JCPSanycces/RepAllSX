#        Call ADDCRIT(REQ, IREQ, "",        "and SDH.BETFCY_0    =2", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and SDH.BETCPY_0    =1", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and STJ.ACCDAT_0    <="+LDAT, " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and STJ.NUMVCR_0    <>' '", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and STJ.OWNER_0     =STJ.STOFCY_0", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and STJ.ITMREF_0    ='"+[F:ITF]ITMREF+"'", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        "and (", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",          "not EXISTS", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",          "(SELECT 1", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",          "From SRETURND SRD", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",          "Where SRD.SRHNUM_0=STJ.VCRNUM_0", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",            "and SRD.SRDLIN_0=STJ.VCRLIN_0", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",            "and SRD.PNHNUM_0<>' ')", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",          ")", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",        ")", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",   "GROUP By STJS.VCRNUM_0, STJS.VCRLIN_0", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",   "HAVING sum(ACTQTY_0)<0", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",   ") STJQ", " ") From GOBJSUB
#        For (Decimal QTY, Decimal AMT) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
#            WQTF+=[F:SQLX]QTY
#            WAMTTRA+=[F:SQLX]AMT
#        Next
#        #Call ECR_TRACE(num$(IREQ)-num$(len(REQ(IREQ)))-"LIVRAISONS Inter-SITES SANS RECEPTION OU RETOUR : WQTF="+num$(WQTF)-"WAMTTRA="+num$(WAMTTRA),-1) From GESECRAN

# Issue X3-60313 - 2017-10-20 by ERMIL : performance enhancements
#        #  LIVRAISONS INTER-SITES SANS/AVEC RECEPTION OU RETOUR CLIENT
#        Filter [SRD]  Where PNHNUM<>""
#        Filter [SDH]  Where BETFCY=2 & BETCPY=1
#        For [STJ]STJ1(3) Where STOFCY=[F:ITF]STOFCY & VCRTYP=4
#&                            & ITMREF=[F:ITF]ITMREF & VCRTYPORI<>36 & UPDCOD=2 & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
#            Look [SDH]SDH0 = [F:STJ]VCRNUM
#            If !fstat
#               For [STJ]STJ1(4)
#                   QTYS=0 : AMT=0
#                   For [STJ]STJ1
#                       QTYS+=[F:STJ]ACTQTY
#                       AMT -=[F:STJ]VARVAL
#                   Next
#
#                   If QTYS<0
#                      QTYP=0
#                      # ne pas ajouter & STOFCY=[F:ITF]STOFCY
#                      For [STJ2]STJ1(4) Where find(VCRTYP,6,13)<>0
#&                                           & ITMREF=[F:ITF]ITMREF & OWNER=STOFCY & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
#&                                           & VCRTYPORI=4 & VCRNUMORI=[F:STJ]VCRNUM & VCRLINORI=[F:STJ]VCRLIN
#                           Look [SRD]SRD0 = [F:STJ2]VCRNUM;[F:STJ2]VCRLIN
#                           If fstat>2
#                              For [STJ2]STJ1
#                                  QTYP+= [F:STJ2]ACTQTY
#                              Next
#                           Endif
#                      Next
#
#                      QTYS   = -QTYS
#                      WQTF   += QTYS-QTYP
#                      WAMTTRA+= AMT*(QTYS-QTYP)/QTYS
#                      #Call ECR_TRACE([F:STJ]STOFCY-num$([F:STJ]VCRTYP)-[F:STJ]VCRNUM-num$([F:STJ]VCRLIN)-':'-num$(QTYS-QTYP)-num$(AMT*(QTYS-QTYP)/QTYS)-num$(QTYP),0) From GESECRAN
#                   Endif
#              Next
#           Endif
#        Next
#        Filter [SRD]
#        Filter [SDH]

        Columns [STJ2] (VCRNUM,VCRLIN,ACTQTY)
        Filter [SRD]  Where PNHNUM<>""
        Link [STJ] With [SDH]SDH0 ~= [F:STJ]VCRNUM As [STJLNKD]
&       Where [F:STJ]STOFCY=[F:ITF]STOFCY & [F:STJ]VCRTYP=4 & [F:STJ]ITMREF=[F:ITF]ITMREF & [F:STJ]VCRTYPORI<>36 & [F:STJ]UPDCOD=2 & [F:STJ]NUMVCR<>"" & [F:STJ]ACCDAT<=[M:SVAL]REFDAT
&           & [F:SDH]BETFCY=2 & [F:SDH]BETCPY=1
        Columns [STJLNKD] ([F:STJ]ACTQTY, [F:STJ]VARVAL, [F:STJ]VCRNUM, [F:STJ]VCRLIN)
        For [STJLNKD]STJ1(3)
          For [STJLNKD]STJ1(4)
            QTYS=0 : AMT=0
            For [STJLNKD]STJ1
              QTYS+=[F:STJ]ACTQTY
              AMT -=[F:STJ]VARVAL
            Next
            If QTYS<0
              QTYP=0
              # ne pas ajouter & STOFCY=[F:ITF]STOFCY
              For [STJ2]STJ1(4) Where find(VCRTYP,6,13)<>0
&                                   & ITMREF=[F:ITF]ITMREF & OWNER=STOFCY & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
&                                   & VCRTYPORI=4 & VCRNUMORI=[F:STJ]VCRNUM & VCRLINORI=[F:STJ]VCRLIN
                Look [SRD]SRD0 = [F:STJ2]VCRNUM;[F:STJ2]VCRLIN
                If fstat>2
                  For [STJ2]STJ1
                    QTYP+= [F:STJ2]ACTQTY
                  Next
                Endif
              Next

              QTYS   = -QTYS
              WQTF   += QTYS-QTYP
              WAMTTRA+= AMT*(QTYS-QTYP)/QTYS
              #Call ECR_TRACE([F:STJ]STOFCY-num$([F:STJ]VCRTYP)-[F:STJ]VCRNUM-num$([F:STJ]VCRLIN)-':'-num$(QTYS-QTYP)-num$(AMT*(QTYS-QTYP)/QTYS)-num$(QTYP),0) From GESECRAN
            Endif
          Next
        Next
        Columns [STJLNKD]
        Filter [SRD]
        Columns [STJ2]
# End issue X3-60313

