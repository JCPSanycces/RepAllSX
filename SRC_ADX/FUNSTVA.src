######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 30/11/2005 17:50:20 (CCC)
##########################################################################
Subprog C_NPRDEN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:AIM])=0 : Local File APRINTER  [AIM] : Endif
 If clalev([F:AID])=0 : Local File APRINTDES [AID] : Endif
 Gosub GET_REPORT_NAME
 Call AIMCONT(VALEUR,[M:SVAL]NPRNAM,GBATCH<>0) From IMPRIME
 If mkstat : End : Endif
 [M:SVAL]NPRSRV     = [F:AIM]PRTSRV
 [M:SVAL]NPRIMP     = [F:AIM]PRTNAM
 [M:SVAL]PRTPOR     = [F:AIM]PRTPOR
 [M:SVAL]PRTDRV     = [F:AIM]PRTDRV
 Raz [M]PRTDES
 For [AID]AID0 Where COD=[F:AIM]COD
  [M]PRTDES([F:AID]NUM-1)  = [F:AID]PRTDES
 Next
 Affzo [M:SVAL]NPRSRV,NPRIMP
 Diszo [M:SVAL]NPRSRV,NPRIMP
 If [F:AIM]PRT=4
    Actzo [M:SVAL]FICHIER
 Else
    Raz [M:SVAL]FICHIER
    Diszo [M:SVAL]FICHIER
 Endif
Else
 Actzo [M:SVAL]NPRSRV,NPRIMP
Endif
End




######################################################################################
Subprog AM_PMP2(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M]AMTDEVFLG=1
    [M]AMTDEVDAT=[0/0/0]
    Grizo [M]AMTDEVFLG,AMTDEVDAT
Else
    Actzo [M]AMTDEVFLG,AMTDEVDAT
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 03/01/2011 09:55:56 (CCC)
######################################################################################
Subprog AS_WRHEND(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
  VALEUR = [M]WRHSTR
Endif

End

######################################################################################


######################################################################################
Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
If [M:SVAL]WRHSTR = [M:SVAL]WRHEND | VALEUR > [M:SVAL]WRHEND
    [M:SVAL]WRHEND = VALEUR
    Affzo [M:SVAL]WRHEND
Endif
[M:SVAL]WRHSTR=VALEUR
Gosub AFF_TRAFLG

End

######################################################################################
Subprog AM_WRHEND(VALEUR)
Variable Char    VALEUR()
[M:SVAL]WRHEND=VALEUR
Gosub AFF_TRAFLG

End

$AFF_TRAFLG
If [M:SVAL]WRHSTR="" & [M:SVAL]WRHEND="" & [M:SVAL]TOTWRHFLG<>2
    Actzo [M:SVAL]TRAFLG
Else
    [M:SVAL]TRAFLG=1
    Grizo [M:SVAL]TRAFLG
    Affzo [M:SVAL]TRAFLG
Endif
Return

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 03/01/2011 15:44:07 (CCC)
######################################################################################
Subprog AM_TOTWRHFLG(VALEUR)
Variable Integer VALEUR
[M:SVAL]TOTWRHFLG=VALEUR
Gosub AFF_TRAFLG
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 11/03/2011 11:09:06 (CCC)
######################################################################################
Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
If !instr(1,VALEUR,"/") & !instr(1,VALEUR,"\")
 GMESSAGE = mess(160,100,1) : # Le chemin doit être indiqué en absolu
 mkstat = 1 : End
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 17/05/2011 11:53:48 (CCC)
######################################################################################
# Issue 73450 - 2011-05-17 by CCC : En paramétrage batch, il ne faut pas forcer la valeur et conserver la valeur nulle
Subprog D_REFDAT(VALEUR)
Variable Date    VALEUR
  If !GBATCH : VALEUR=date$ : Endif
End

######################################################################################
# Calcule la valeur FIFO d'un article-site en se basant sur les mouvements
Subprog CLCFIFO2(PITM, PFCY, PQTY0, PAMT, PRET)
Value Char PITM
Value Char PFCY
Value Decimal PQTY0
Variable Decimal PAMT
Variable Integer PRET

Local Decimal LQTY, LAMT, LQTYDOC, LAMTDOC, LSCOTOT
Local Decimal LQTYPID, LAMTPID
Local Decimal LQTYOFF
Local Char REQ(250)(3)
Local Integer IREQ, LRET
Local Char LMES(250), LMESINV(250)
Local Integer LLINTYP

If !clalev([F:MFC]) : Local File MFGCOST     [MFC] : Endif
If !clalev([F:BPS]) : Local File BPSUPPLIER  [BPS] : Endif
If !clalev([F:SCO]) : Local File SCOHEAD     [SCO] : Endif
If !clalev([F:SCI]) : Local File SCOITM      [SCI] : Endif
If !clalev([F:PIH]) : Local File PINVOICE    [PIH] : Endif
If !clalev([F:PID]) : Local File PINVOICED   [PID] : Endif
If !clalev([F:PID2]): Local File PINVOICED   [PID2]: Endif
If !clalev([F:PTD]) : Local File PRECEIPTD   [PTD] : Endif

LQTY = PQTY0
Raz PRET, PAMT, LAMT

Raz REQ, IREQ
Call ADDCRIT(REQ, IREQ, "", "SELECT STJ.*", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "From", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "(SELECT min(CREMVTDAT_0) DAT, min(CREMVTTIM_0) TIM, min(CREMVTSEQ_0) SEQ,", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "sum(ACTQTY_0) QTY, sum(VARORD_0) VAL,", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "VCRTYP_0, VCRNUM_0, VCRLIN_0, TRSTYP_0, VCRTYPORI_0, VCRNUMORI_0, VCRLINORI_0,", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "max(VCRTYPREG_0) TYPR, max(VCRNUMREG_0) NUMR, max(VCRLINREG_0) LINR", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "From STOJOU", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "Where ITMREF_0='"+PITM+"'", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "and STOFCY_0  ='"+PFCY+"'", " ") From GOBJSUB
# Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
Call ADDCRIT(REQ, IREQ, "", "and OWNER_0  ='"+PFCY+"'", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "GROUP By IPTDAT_0, VCRTYP_0, VCRNUM_0, VCRLIN_0, TRSTYP_0, VCRTYPORI_0, VCRNUMORI_0, VCRLINORI_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", ") STJ", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "Where STJ.QTY>0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "Order By STJ.DAT Desc, STJ.TIM Desc, STJ.SEQ Desc", " ") From GOBJSUB

Call ECRTRACE("ITMREF="+PITM-"Qty="+num$(PQTY0),-1)

For (Date CREMVTDAT,Char CREMVTTIM, Integer CREMVTSEQ, Decimal ACTQTY, Decimal VARORD, Integer VCRTYP,
&    Char VCRNUM,Integer VCRLIN,Integer TRSTYP,Integer VCRTYPORI,Char VCRNUMORI,Integer VCRLINORI,
&    Integer VCRTYPREG, Char VCRNUMREG, Integer VCRLINREG) From num$(GTYPDBA*2+1) Sql REQ As [STJX]
    LQTYDOC = [F:STJX]ACTQTY
    LAMTDOC = [F:STJX]VARORD
    Raz LMES, LMESINV
    If LQTYDOC>0
        If nomap="JUKEN"
            Raz LQTYPID, LAMTPID
            If [F:STJX]VCRTYP=6 & [F:STJX]TRSTYP=3
                If [F:STJX]VCRTYPORI=36
                    LLINTYP=2
                Else
                    LLINTYP=1
                Endif
                # trouver le prix facture du service
                Filter [PID] Where PTHNUM=[F:STJX]VCRNUM
&                                & PTDLIN=[F:STJX]VCRLIN
&                                & LINTYP=LLINTYP
&                                & INVTYP=1
&                                & ITMREF = PITM
                Look [PID] First
                If fstat
                    If [F:STJX]VCRTYPORI=14
                        Filter [PID] Where POHNUM=[F:STJX]VCRNUMORI
&                                        & POPLIN=[F:STJX]VCRLINORI
&                                        & PTHNUM="" & PTDLIN=0
&                                        & LINTYP=LLINTYP
&                                        & INVTYP=1
&                                        & ITMREF = PITM
                        Look [PID] First
                    Else
                        Read [PTD]PTD0=[F:STJX]VCRNUM;[F:STJX]VCRLIN
                        Filter [PID] Where POHNUM=[F:PTD]POHNUM
&                                        & POPLIN=[F:PTD]POPLIN
&                                        & PTHNUM="" & PTDLIN=0
&                                        & LINTYP=LLINTYP
&                                        & INVTYP=1
&                                        & ITMREF = PITM
                        Look [PID] First
                    Endif
                    If fstat
                        Filter [PID] Where NUM=[F:STJX]VCRNUMREG
&                                        & PIDLIN=[F:STJX]VCRLINREG
&                                        & LINTYP=LLINTYP
&                                        & INVTYP=1
&                                        & ITMREF = PITM
                    Endif
                Endif
                LMESINV= "( invoice :"
                For [PID]
                    If [F:PIH]NUM<>[F:PID]NUM
                        Read [PIH]PIH0=[F:PID]NUM
                    Endif
                    If [F:STJX]VCRTYPORI=36
                        Read [PID2]PID0=[F:PID]NUM;[F:PID]PIDLIN
                        Read [PID2]PID0 Next
                    Else
                        [F:PID2] = [F:PID]
                    Endif
                    If [F:STJX]VCRTYPORI<>36 | [F:PID2]LINTYP=3
                        If [F:BPS]BPSNUM<>[F:PID]BPSNUM
                            Read [BPS]BPS0=[F:PID]BPSNUM
                        Endif
                        If [F:PIH]CUR<>GLOCALDEV
                            LMES = "convert :"-num$([F:PID2]NETPRI)-[F:PIH]CUR
#                            Call CONVERT2([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[F:PID2]RCPDAT,
#&                                         [F:PID2]NETPRI,[F:PID2]CPR,LRET) From TRTDEV
                            [F:PID2]CPR = [F:PID2]NETPRI * [F:PIH]RATMLT

                            LMES -= num$([F:PID2]CPR)-GLOCALDEV
                            #Call ECR_TRACE(LMES,0) From GESECRAN
                        Else
                            [F:PID2]CPR = [F:PID2]NETPRI
                        Endif
                        LQTYPID+=[F:PID]QTYSTU
                        LAMTPID+=[F:PID2]CPR*[F:PID]QTYSTU
                        LMESINV-= [F:PID]NUM-num$([F:PID]PIDLIN)+";"
                    Endif
                Next
                If LQTYPID=0
                    LMESINV-= "nil)"
                Else
                    LMESINV-= ")"
                Endif
                Filter [PID]

                If [F:STJX]VCRTYPORI=36
                    Raz [F:MFC]
                    Read [MFC]MFC0=PFCY;PITM;[F:STJX]VCRTYPORI;[F:STJX]VCRNUMORI;[F:STJX]VCRLINORI;2;0
                    Read [SCO]SCO0=[F:STJX]VCRNUMORI
                    If [F:BPS]BPSNUM<>[F:SCO]BPRNUM
                        Read [BPS]BPS0=[F:SCO]BPRNUM
                    Endif
                    Filter [SCI] Where SCONUM=[F:SCO]SCONUM and PJT='CONVERTED By SPE'
                    Look [SCI] First
                    Filter [SCI]
                    If fstat
                        Call CONVERT2([F:BPS]CUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[F:SCO]ORDDAT,
&                                     [F:MFC]SCOTOT,LSCOTOT,LRET) From TRTDEV
                    Else
                        LSCOTOT = [F:MFC]SCOTOT
                    Endif
                    If !LRET
                        If LQTYDOC>=LQTYPID
                            LAMTDOC = ([F:MFC]CSTTOT+[F:MFC]OVETOT-[F:MFC]SCOTOT+LSCOTOT)*(LQTYDOC-LQTYPID)+([F:MFC]CSTTOT+[F:MFC]OVETOT-[F:MFC]SCOTOT)*LQTYPID+LAMTPID
                            #Call ECRTRACE("SCOTOT "+num$([F:MFC]SCOTOT)+" --> "+num$(LSCOTOT)+"( lqtydoc="+num$(LQTYDOC)+" LQTYPID="+num$(LQTYPID)+" LAMTPID="+num$(LAMTPID)+")",1)
                        Else
                            LAMTDOC = ([F:MFC]CSTTOT+[F:MFC]OVETOT-[F:MFC]SCOTOT+LSCOTOT)*LQTYDOC
                            Call ECRTRACE("Invoiced qty ("+num$(LQTYPID)+") > Received qty("+num$(LQTYDOC)+")",1)
                        Endif
                    Endif
                Elsif [F:STJX]VCRTYPREG=17 & LQTYPID>0
    #                Raz [F:PID]
    #                Read [PID]PID0=[F:STJX]VCRNUMREG;[F:STJX]VCRLINREG
                    LAMTDOC = LQTYDOC*LAMTPID/LQTYPID
                Endif
            Elsif [F:STJX]VCRTYP=9
                LQTYOFF += LQTYDOC
                Call ECRTRACE(mess([F:STJX]VCRTYP,701,1)-[F:STJX]VCRNUM-num$([F:STJX]VCRLIN)-mess([F:STJX]TRSTYP,704,1)-": QTY="+num$(LQTYDOC),0)
                Goto NEXT_STJX
            Endif
            If LQTYOFF>0
                LAMTDOC*=(1+LQTYOFF/LQTYDOC)
                LQTYDOC+=LQTYOFF
                LQTYOFF=0
            Endif
        Endif
        If LQTYDOC<LQTY
#            Call
# ECRTRACE(mess([F:STJX]VCRTYP,701,1)-[F:STJX]VCRNUM-num$([F:STJX]VCRLIN)-mess([F:STJX]TRSTYP,704,1)-num$(LQTYDOC)+"(/"+num$([F:STJX]ACTQTY)+")"-num$(LAMTDOC)+"(/"+num$([F:STJX]VARORD)+")",0)
            LMES = mess([F:STJX]VCRTYP,701,1)-[F:STJX]VCRNUM-num$([F:STJX]VCRLIN)-mess([F:STJX]TRSTYP,704,1)
            Call ECRTRACE(LMES,0)
            If [F:STJX]VCRTYPORI=36
                Call ECRTRACE("    ("+mess([F:STJX]VCRTYPORI,701,1)-[F:STJX]VCRNUMORI+")"-num$(LAMTDOC)+"/"+num$(LQTYDOC)+"="+num$(LAMTDOC/LQTYDOC),0)
            Endif
            If LMESINV<>""
                Call ECRTRACE("    "+LMESINV,0)
            Endif
            LAMT+=LAMTDOC
            LQTY-=LQTYDOC
        Else
#            Call
# ECRTRACE(mess([F:STJX]VCRTYP,701,1)-[F:STJX]VCRNUM-num$([F:STJX]VCRLIN)-mess([F:STJX]TRSTYP,704,1)-num$(LQTY)+"(/"+num$([F:STJX]ACTQTY)+")"-num$(LAMTDOC*LQTY/LQTYDOC)+"(/"+num$([F:STJX]VARORD)+")",0
#)
            LMES=mess([F:STJX]VCRTYP,701,1)-[F:STJX]VCRNUM-num$([F:STJX]VCRLIN)-mess([F:STJX]TRSTYP,704,1)
            Call ECRTRACE(LMES,0)
            If [F:STJX]VCRTYPORI=36
                Call ECRTRACE("    ("+mess([F:STJX]VCRTYPORI,701,1)-[F:STJX]VCRNUMORI+")"-num$(LAMTDOC)+"/"+num$(LQTYDOC)+"="+num$(LAMTDOC/LQTYDOC),0)
            Endif
            If LMESINV<>""
                Call ECRTRACE("    "+LMESINV,0)
            Endif
            LAMT+=LAMTDOC*LQTY/LQTYDOC
            LQTY=0
            Break
        Endif
    Endif
    $NEXT_STJX
Next
If LQTY<>0
    PRET = 1
Endif
PAMT = LAMT
End

Subprog ECRTRACE(TXT,ERR)
Value Char TXT
Value Integer ERR
If nomap="JUKEN" & GTRACE<>""
    Call ECR_TRACE(TXT,ERR) From GESECRAN
Endif
End


Subprog CLCFIFO(PFCY,PITM,PFILSTJWRH,PDAT,PACCFLG,PQTY,PAMT,PPRI,PRET)
Value Char PFCY
Value Char PITM
Value Char PFILSTJWRH
Value Date PDAT
Value Integer PACCFLG
Variable Decimal PQTY()
Variable Decimal PAMT
Variable Decimal PPRI
Variable Integer PRET

Local Decimal LAMTE, LQTYE
Local Char REQ(250)(5), LSTA(1), LDAT(250)
Local Integer IREQ, I

Raz PRET, PAMT, PPRI

GPOINT="FIFODAT"
Gosub ENTREE From EXEFNC

# Issue 89144 - 2013-05-28 by CCC : Par défaut on lit selon IPTDAT
#If dim(WFIFODAT)>0 & WFIFODAT="I"
If dim(WFIFODAT)>0 & WFIFODAT="C"
    # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
    Filter [STJ] Where ITMREF=PITM
&                    & STOFCY=PFCY
&                    & OWNER =PFCY
&                    & UPDCOD=2
&                    & evalue(PFILSTJWRH)
&                Order By Key STJX=STOFCY;UPDCOD;ITMREF;CREDAT Desc;CRETIM Desc;IPTDAT Desc;MVTSEQ;MVTIND
Elsif PACCFLG<>0    # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
    Raz I, LDAT
    Case GTYPDBA
        When 1 : LDAT="TO_DATE('"+format$("D:DD[/]MM[/]YYYY",[M:SVAL]REFDAT)+"','DD/MM/YYYY')"
        When 2 : LDAT="CONVERT(datetime,'"+format$("D:YYYYMMDD",[M:SVAL]REFDAT)+"',112)"
    Endcase

    For LSTA="A","Q","R"
        I+=1
        Raz REQ, IREQ

        Call ADDCRIT(REQ, IREQ, "", "SELECT sum(ACTQTY_0) From STOJOU STJ", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "", "Where ITMREF_0='"+PITM+"'", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",   "and STOFCY_0='"+PFCY+"'", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",   "and UPDCOD_0=2", " ") From GOBJSUB

        #X3-89541 MJH Remove [F:STJ]NUMVCR<>"" and add [F:STJ]AGGIFAFLG=2 & [F:STJ]ENTCOD<>''
#        Call ADDCRIT(REQ, IREQ, "",   "and NUMVCR_0=' '", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",   "and AGGIFAFLG_0<>2", " ") From GOBJSUB
#        Call ADDCRIT(REQ, IREQ, "",   "and ENTCOD_0<>''", " ") From GOBJSUB

        Call ADDCRIT(REQ, IREQ, "",   "and SUBSTR"+string$(GTYPDBA=2,"ING")+"(STA_0,1,1)='"+LSTA+"'", " ") From GOBJSUB
        # If ACCDAT=[0/0/0] it can be because of reverse movement although new movement has been accounted before REFDAT
        # This kind of movement musn't decrease quantity. It has to be taken into account as if it has been accounted.
        Call ADDCRIT(REQ, IREQ, "",   "and ( VARVAL_0  <>0 or VARORD_0 <>0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",     "or not EXISTS (", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "SELECT 1", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "From STOJOU STJ2", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "Where", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",             "STJ.STOFCY_0   = STJ2.STOFCY_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.ITMREF_0   = STJ2.ITMREF_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.UPDCOD_0   = STJ2.UPDCOD_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.IPTDAT_0   = STJ2.IPTDAT_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.VCRTYP_0   = STJ2.VCRTYP_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.VCRNUM_0   = STJ2.VCRNUM_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.VCRLIN_0   = STJ2.VCRLIN_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.MVTSEQ_0   > STJ2.MVTSEQ_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         "and STJ2.ACCDAT_0 <="+LDAT, " ") From GOBJSUB
        # to be sure that STJ2.ACCDAT is different than [0/0/0]
        Call ADDCRIT(REQ, IREQ, "",         "and STJ.ACCDAT_0   < STJ2.ACCDAT_0", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",         ")", " ") From GOBJSUB
        Call ADDCRIT(REQ, IREQ, "",       ")", " ") From GOBJSUB

        For (Decimal QTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
            PQTY(0) -= [F:SQLX]QTY
            PQTY(I) -= [F:SQLX]QTY
        Next
    Next

    #X3-89541 MJH Remove [F:STJ]NUMVCR<>"" and add [F:STJ]AGGIFAFLG=2 & [F:STJ]ENTCOD<>''
    Filter [STJ] Where ITMREF=PITM
&                    & STOFCY=PFCY
&                    & OWNER =PFCY
&                    & UPDCOD=2
&                    & AGGIFAFLG=2
&                    & [F:STJ]ENTCOD<>''
&                Order By Key STJX=STOFCY;ITMREF;ACCDAT Desc;IPTDAT Desc;CREMVTDAT Desc;CREMVTTIM Desc;CREMVTSEQ Desc;MVTSEQ;MVTIND
# Issue 106717 - 2015-03-24 by CCC : For a same ACCDAT, use creation order of document, not creation order of movement
#&                Order By Key STJX=STOFCY;UPDCOD;ITMREF;ACCDAT Desc;CREDAT Desc;CRETIM Desc;IPTDAT Desc;MVTSEQ;MVTIND

Else
    # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
    Filter [STJ] Where ITMREF=PITM
&                    & STOFCY=PFCY
&                    & OWNER =PFCY
&                    & UPDCOD=2
&                    & evalue(PFILSTJWRH)
&                Order By Key STJX=STOFCY;ITMREF;IPTDAT Desc;CREMVTDAT Desc;CREMVTTIM Desc;CREMVTSEQ Desc;MVTSEQ;MVTIND
# Issue 106717 - 2015-03-24 by CCC : For a same ACCDAT, use creation order of document, not creation order of movement
#&                Order By Key STJ0
Endif

For [STJ]
    # Issue 105025 - 2015-02-05 by CCC : do not take into account internal movements (see STKVALMAJ2.MAJFIFO)
    # Issue X3-86672 - 2018-05-03 by ERMIL : Handle value change transactions
    # Issue X3-91315 - 2018-06-06 by MIHAL : Handle NULAMTIFA = NO for lines that have stock movement but no cost.
    If  (find([F:STJ]TRSTYP,13,14,23) | find(func STKLIB.SENSTRS([F:STJ]TRSTYP),-2,-1,1,2))
&     & !find([F:STJ]TRSTYP,16,32)
&     & [F:STJ]VCRTYP<>35

        If  (dim(WFIFODAT)>0 & WFIFODAT="C") & [F:STJ]CREDAT>[M:SVAL]REFDAT
&        | !(dim(WFIFODAT)>0 & WFIFODAT="C") & PACCFLG<>0
&                                            & ([F:STJ]ACCDAT>[M:SVAL]REFDAT
&                                               | ([F:STJ]AGGIFAFLG=2 & [F:STJ]ENTCOD<>'' & [F:STJ]ACCDAT = [0/0/0] & [F:STJ]IPTDAT > [M:SVAL]REFDAT)
&                                              )
&        | !(dim(WFIFODAT)>0 & WFIFODAT="C" | PACCFLG<>0)
&          & ( [F:STJ]IPTDAT>[M:SVAL]REFDAT
&            | ( ([F:TCM]ISSVLTCOD<>5 | [F:TCM]PRIREGS<>2)
&              & ([F:STJ]CREDAT > [M:SVAL]REFDAT & ([F:STJ]PRIREGFLG=2 | [F:STJ]TRSTYP=23))
&              )
&            )
            PQTY(find(left$([F:STJ]STA,1),"A","Q","R")) -= [F:STJ]ACTQTY
            PQTY(0) -= [F:STJ]ACTQTY
        # Issue 106717 - 2015-03-24 by CCC : take into account entries of inter-sites transfers
        #Elsif find(func STKLIB.SENSTRS([F:STJ]TRSTYP),1,-2) | [F:STJ]TRSTYP=13 & [F:STJ]ACTQTY>0
        Elsif find(func STKLIB.SENSTRS([F:STJ]TRSTYP),1,-2) | find([F:STJ]TRSTYP,13,14) & [F:STJ]ACTQTY>0
            If [F:STJ]PRIREGFLG=2
&            | [F:STJ]VARORD<>[F:STJ]AMTORD & [F:STJ]PRINAT>3
&            | [F:STJ]PRINAT=0  # Issue 93709 - 2013-10-22 by CCC : avoid reverse transaction created by issue adjustment
                [F:STJ]ACTQTY=0
            Else
                Gosub STJVARORD # Ajoute les mnt de régul
                If LQTYE+[F:STJ]ACTQTY>PQTY(0)
                    [F:STJ]VARORD*=(PQTY(0)-LQTYE)/[F:STJ]ACTQTY
                    [F:STJ]ACTQTY=PQTY(0)-LQTYE
                Endif
                LQTYE += [F:STJ]ACTQTY
                LAMTE += [F:STJ]VARORD
            Endif
            If LQTYE=PQTY(0)
                Break
            Endif
        # Issue X3-86672 - 2018-05-03 by ERMIL : Handle value change transactions
        Elsif [F:STJ]TRSTYP=23
            LAMTE += [F:STJ]VARORD
        Endif
    Endif
Next
Filter [STJ]
If PQTY(0)<>0
    PAMT=LAMTE
    PPRI=LAMTE/PQTY(0)
Endif
End

$STJVARORD
If [F:STJ]ACTQTY=0 : Return : Endif
# Q= qté tot du doc
# M= montant total des régul avant la date de ref
Raz REQ
REQ(0)="SELECT SUM(ACTQTY_0) Q, SUM(CASE WHEN (PRIREGFLG_0=2 or AMTORD_0<>VARORD_0) "
If (dim(WFIFODAT)>0 & WFIFODAT="C") | PACCFLG<>0
    If (dim(WFIFODAT)>0 & WFIFODAT="C")
      REQ(0)+= " AND CREDAT_0<="
    Else
      REQ(0)+= " AND NUMVCR_0<>' ' AND ACCDAT_0<="
    Endif

    Case GTYPDBA
        When 1 : REQ(0)+= "TO_DATE('"+format$("D:DD[/]MM[/]YYYY",[M:SVAL]REFDAT)+"','DD/MM/YYYY')"
        When 2 : REQ(0)+= "CONVERT(datetime,'"+format$("D:YYYYMMDD",[M:SVAL]REFDAT)+"',112)"
    Endcase
Endif
REQ(0)+= " THEN VARORD_0 ELSE 0 END) M FROM STOJOU STJ"
REQ(1) =" WHERE ITMREF_0='"+[F:STJ]ITMREF+"' AND STOFCY_0='"+[F:STJ]STOFCY+"' AND UPDCOD_0=2"
REQ(1)+=" AND VCRNUM_0='"+[F:STJ]VCRNUM+"' AND VCRTYP_0="+num$([F:STJ]VCRTYP)+" AND VCRLIN_0="+num$([F:STJ]VCRLIN)
For (Decimal ACTQTYTOT, Decimal VARORD) From num$(GTYPDBA*2+1) Sql REQ As [STJX]
    If [F:STJX]ACTQTYTOT=0 : Break : Endif
    [F:STJ]VARORD += [F:STJX]VARORD*[F:STJ]ACTQTY/[F:STJX]ACTQTYTOT
Next
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 23/01/2015 10:29:02 (CCC)
######################################################################################
# Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
Subprog AM_ACCDATFLG(VALEUR)
Variable Integer VALEUR
Local Integer LCSTCOD

If VALEUR=2 and find([M:SVAL]CSTCOD,9,13)
    [M:SVAL]AAASTA=2
    [M:SVAL]QQQSTA=2
    [M:SVAL]RRRSTA=2
    Diszo [M:SVAL]AAASTA,QQQSTA,RRRSTA
    If GWRHACT=2
        [M:SVAL]WRHSTR=""
        [M:SVAL]WRHEND=""
        [M:SVAL]TOTWRHFLG=1
        Diszo [M:SVAL]WRHSTR,WRHEND,TOTWRHFLG
        Gosub AFF_TRAFLG #MJH X3-108774. update transfered flag after warehouse changes
    Endif

    Actzo [M:SVAL]ACCSTR, ACCEND, TOTACCCOD
    If [M:SVAL]DETFLG=2
      Actzo [M:SVAL]TOTVERFLG
    Else
      Diszo [M:SVAL]TOTVERFLG
    Endif

    #Buyer and groups are not relevant for PIT
    Effzo [M:SVAL]BUYSTR, BUYEND, TOTBUYFLG, TSICODSTR, TSICODEND, TOTTSIFLG
    Diszo [M:SVAL]BUYSTR, BUYEND, TOTBUYFLG, TSICODSTR, TSICODEND, TOTTSIFLG

    #X3-63842
    #The start date field is only available if Primary or secondary issue method is
    #selected as the Costing method and Accounting date is selected, otherwise greyed out.
    If find([M:SVAL]CSTCOD,9,13)
      Actzo [M:SVAL]STRDAT
      [M:SVAL]STRDAT = [M:SVAL]REFDAT
      [M:SVAL]AMTDEVFLG = 2
      Affzo [M:SVAL]AMTDEVFLG, STRDAT
      Diszo [M:SVAL]AMTDEVFLG, AMTDEVDAT
    Else
      Diszo [M:SVAL]STRDAT
      Actzo [M:SVAL]AMTDEVFLG, AMTDEVDAT
    Endif
Else
    Actzo [M:SVAL]AAASTA,QQQSTA,RRRSTA
    If GWRHACT=2
        Actzo [M:SVAL]WRHSTR,WRHEND,TOTWRHFLG
    Endif

    #X3-63842
    Effzo [M:SVAL]STRDAT, ACCSTR, ACCEND, TOTACCCOD, TOTVERFLG
    Diszo [M:SVAL]STRDAT, ACCSTR, ACCEND, TOTACCCOD, TOTVERFLG
    Actzo [M:SVAL]AMTDEVFLG, AMTDEVDAT, BUYSTR, BUYEND, TOTBUYFLG, TSICODSTR, TSICODEND, TOTTSIFLG
Endif
Affzo [M:SVAL]AAASTA,QQQSTA,RRRSTA
If GWRHACT=2
    Affzo [M:SVAL]WRHSTR,WRHEND,TOTWRHFLG
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOVAL) 23/01/2015 10:31:34 (CCC)
######################################################################################
Subprog AM_DETFLG(VALEUR)
Variable Integer VALEUR
#X3-63842 No longer needed ... actually it is
If VALEUR=2 and !find([M:SVAL]CSTCOD,9,13)
    [M:SVAL]ACCDATFLG=1
    Call AM_ACCDATFLG([M:SVAL]ACCDATFLG)
    Diszo [M:SVAL]ACCDATFLG
Elsif [M:SVAL]CSTCOD <> 13
    Actzo [M:SVAL]ACCDATFLG
Endif
Affzo [M:SVAL]ACCDATFLG
End

######################################################################################

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR > date$ or (VALEUR=[0/0/0] and [M:SVAL]ACCDATFLG = 2 and find([M:SVAL]CSTCOD,9,13) )
    mkstat = 2
    End
  Endif


  If [M:SVAL]ACCDATFLG = 2 and VALEUR <> [0/0/0]
    [M:SVAL]AMTDEVFLG = 2
    Diszo [M:SVAL]AMTDEVFLG, AMTDEVDAT
    Affzo [M:SVAL]AMTDEVFLG, AMTDEVDAT
  Else
    Actzo [M:SVAL]AMTDEVFLG, AMTDEVDAT
  Endif
End

