######################################################################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()

VALEUR = GDEFSOC
Call AM_CPY(VALEUR)

End
##########################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

Local Char LACCIFA(3)

# Get currency
If find(VALEUR,GSOC(1..GNBSOC))
    GLOCALDEV = GDEVSOC(find(VALEUR,GSOC(1..GNBSOC)))
Endif
If GLOCALDEV<>GSYSCUR
    Actzo [M]RPTCUR
Else
    Diszo [M]RPTCUR
Endif

# Issue 100246 - 2015-02-12 by CCC :  allow (or not) to choose "Accounting date" criteria
For [FCY] Where LEGCPY=VALEUR
    Call PARAM([F:FCY]FCY,"ACCIFA",LACCIFA) From ADOVAL
    If val(LACCIFA)>1
        Break
    Endif
Next

#If val(LACCIFA)>1
#    LNEWVAL=2
#    Actzo [M:SVAL]ACCDATFLG
#Else
#    LNEWVAL=1
#    Diszo [M:SVAL]ACCDATFLG
#Endif
#If [M:SVAL]ACCDATFLG<>LNEWVAL
#    [M:SVAL]ACCDATFLG=LNEWVAL
#    Call AM_ACCDATFLG([M:SVAL]ACCDATFLG)
#    Affzo [M:SVAL]ACCDATFLG
#Endif

End

