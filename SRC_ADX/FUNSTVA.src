# Issue X3-60313 - 2017-10-20 by ERMIL : performance enhancements
#        #  RETOUR FOURNISSEUR INTER-SITES SANS/AVEC RETOUR CLIENT
#        Columns [STJ2] (ACTQTY)
#        Columns [SRD] (STOFCY, SRHNUM, SRDLIN)
#        Filter [PNH]  Where BETFCY=2 & BETCPY=1
#        For [STJ]STJ1(3) Where STOFCY=[F:ITF]STOFCY & VCRTYP=8
#&                            & ITMREF=[F:ITF]ITMREF & VCRTYPORI<>36 & UPDCOD=2  & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
#            Look [PNH]PNH0 = [F:STJ]VCRNUM
#            If !fstat
#               For [STJ]STJ1(4)
#                   QTYS=0 : AMT=0
#                   For [STJ]STJ1
#                       QTYS+=[F:STJ]ACTQTY
#                       AMT -=[F:STJ]VARVAL
#                   Next
#
#                   If QTYS<0
#                      QTYP=0
#                      For [SRD] Where PNHNUM=[F:STJ]VCRNUM & PNDLIN=[F:STJ]VCRLIN
#                          For [STJ2]STJ1 Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN
#&                                            & ITMREF=[F:ITF]ITMREF & STOFCY=OWNER & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
#                              QTYP+= [F:STJ2]ACTQTY
#                          Next
#                      Next
#
#                      QTYS   = -QTYS
#                      WQTF   += QTYS-QTYP
#                      WAMTTRA+= AMT*(QTYS-QTYP)/QTYS
#                      #Call ECR_TRACE([F:STJ]STOFCY-num$([F:STJ]VCRTYP)-[F:STJ]VCRNUM-num$([F:STJ]VCRLIN)-':'-num$(QTYS-QTYP)-num$(AMT*(QTYS-QTYP)/QTYS)-num$(QTYP),0) From GESECRAN
#                   Endif
#               Next
#            Endif
#        Next
#        Filter [PNH]
#        Columns [STJ2] : Raz [F:STJ2]
#        Columns [SRD]  : Raz [F:SRD]

        #  RETOUR FOURNISSEUR INTER-SITES SANS/AVEC RETOUR CLIENT
        Columns [STJ2] (ACTQTY)
        Columns [SRD] (STOFCY, SRHNUM, SRDLIN)
        Link [STJ] With [PNH]PNH0 ~= [F:STJ]VCRNUM As [STJLNKP]
&       Where [F:STJ]STOFCY=[F:ITF]STOFCY & [F:STJ]VCRTYP=8 & [F:STJ]ITMREF=[F:ITF]ITMREF & [F:STJ]VCRTYPORI<>36 & [F:STJ]UPDCOD=2 & [F:STJ]NUMVCR<>"" & [F:STJ]ACCDAT<=[M:SVAL]REFDAT
&           & [F:PNH]BETFCY=2 & [F:PNH]BETCPY=1
        Columns [STJLNKP] ([F:STJ]ACTQTY, [F:STJ]VARVAL, [F:STJ]VCRNUM, [F:STJ]VCRLIN)
        For [STJLNKP]STJ1(3)
          For [STJLNKP]STJ1(4)
            QTYS=0 : AMT=0
            For [STJLNKP]STJ1
              QTYS+=[F:STJ]ACTQTY
              AMT -=[F:STJ]VARVAL
            Next
            If QTYS<0
              QTYP=0
              For [SRD] Where PNHNUM=[F:STJ]VCRNUM & PNDLIN=[F:STJ]VCRLIN
                For [STJ2]STJ1 Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN
&                                  & ITMREF=[F:ITF]ITMREF & STOFCY=OWNER & NUMVCR<>"" & ACCDAT<=[M:SVAL]REFDAT
                  QTYP+= [F:STJ2]ACTQTY
                Next
              Next

              QTYS   = -QTYS
              WQTF   += QTYS-QTYP
              WAMTTRA+= AMT*(QTYS-QTYP)/QTYS
              #Call ECR_TRACE([F:STJ]STOFCY-num$([F:STJ]VCRTYP)-[F:STJ]VCRNUM-num$([F:STJ]VCRLIN)-':'-num$(QTYS-QTYP)-num$(AMT*(QTYS-QTYP)/QTYS)-num$(QTYP),0) From GESECRAN
            Endif
          Next
        Next
        Columns [STJLNKP]
        Columns [SRD]
# End issue X3-60313

        #Call ECR_TRACE([F:ITF]STOFCY-num$([F:ITF]ITMREF)-':'-num$(WQTF)-num$(WAMTTRA),0) From GESECRAN
    Else
        WQTF = [F:ITV]TRASTO
        WAMTTRA = [F:ITV]TRAAMT
        # Recherche des réceptions liées à une livraison
        Link [PTD] With [SDD]SDD0~=[F:PTD]SDHNUM;[F:PTD]SDDLIN
&                    As [PTDX]
&                 Where [F:PTD]RCPDAT>[M:SVAL]REFDAT
&                     & [F:SDD]STOFCY=[F:ITV]STOFCY
&                     & [F:PTD]ITMREF=[F:ITV]ITMREF
&                     & [F:PTD]SDHNUM<>""
        For [PTDX] reckey
            For [STJ] reckey Where STOFCY=[F:PTD]PRHFCY & VCRTYP=6 & VCRNUM=[F:PTD]PTHNUM & VCRLIN=[F:PTD]PTDLIN & VCRNUMORI<>"" & ITMREF=[F:ITV]ITMREF & UPDCOD=2
&                         & [F:STJ]OWNER=[F:STJ]STOFCY     # Issue 93606 & 102008 - 2013-11-04 by CCC
                WQTF += [F:STJ]ACTQTY
                Call VALVCR2([F:ITV]STOFCY,[F:STJ]VCRTYPORI,[F:STJ]VCRNUMORI,[F:STJ]VCRLINORI,GBIDD1,GBIDD2,WRET) From STKVAL
                If GBIDD2<>0
                    WAMTTRA += GBIDD1*[F:STJ]ACTQTY/GBIDD2
                Endif
            Next
        Next

        # Recherche des retours de livraisons sans retour de réception
        Link [SRD] With [SRH]SRH0~=[F:SRD]SRHNUM,
&                       [SDD]SDD0~=[F:SRD]SDHNUM;[F:SRD]SDDLIN
&                    As [SRDX]
&                  Where [F:SRH]BETFCY=2
&                      & [F:SRD]RTNDAT>[M:SVAL]REFDAT
&                      & [F:SDD]STOFCY=[F:ITV]STOFCY
&                      & [F:SRD]PNDLIN=0
&                      & [F:SRD]ITMREF=[F:ITV]ITMREF
&                      & [F:SRD]SDHNUM<>""
        Columns [SRDX] ([SRD]SRHNUM,[SRD]SRDLIN,[SRD]SDDLIN,[SRD]SDHNUM,[SRD]STOFCY,
&                       [SRD]RTNDAT,[SRD]PNDLIN,[SRD]ITMREF,[SDD]STOFCY,[SRH]BETFCY)
        For [SRDX] reckey
            For [STJ] Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN & VCRNUMORI<>"" & ITMREF=[F:ITV]ITMREF & UPDCOD=2
&                         & [F:STJ]OWNER=[F:STJ]STOFCY     # Issue 93606 & 102008 - 2013-11-04 by CCC
                WQTF += [F:STJ]ACTQTY
                Call VALVCR2([F:ITV]STOFCY,[F:STJ]VCRTYPORI,[F:STJ]VCRNUMORI,[F:STJ]VCRLINORI,GBIDD1,GBIDD2,WRET) From STKVAL
                If GBIDD2<>0
                    WAMTTRA += GBIDD1*[F:STJ]ACTQTY/GBIDD2
                Endif
            Next
        Next
        Close Local File [SRDX]

        # Recherche des retours de livraisons liés à un retour de réception
        Link [SRD] With [SRH]SRH0~=[F:SRD]SRHNUM,
&                       [PND]PND0~=[F:SRD]PNHNUM;[F:SRD]PNDLIN
&                    As [SRDX]
&                  Where [F:SRH]BETFCY=2
&                      & [F:PND]PNHFCY=[F:ITV]STOFCY
&                      & [F:SRD]PNDLIN<>0
&                      & [F:SRD]RTNDAT>[M:SVAL]REFDAT
&                      & [F:SRD]ITMREF=[F:ITV]ITMREF
&                      & [F:SRD]PNHNUM<>""
        Columns [SRDX] ([SRD]SRHNUM,[SRD]SRDLIN,[SRD]PNHNUM,[SRD]STOFCY,[SRD]RTNDAT,
&                       [SRD]PNDLIN,[SRD]ITMREF,[PND]PNDLIN,[PND]PNHFCY,[PND]PNHNUM,[SRH]BETFCY)
        For [SRDX]
            For [STJ] Where STOFCY=[F:SRD]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN & VCRNUMORI<>"" & ITMREF=[F:ITV]ITMREF & UPDCOD=2
&                         & [F:STJ]OWNER=[F:STJ]STOFCY     # Issue 93606 & 102008 - 2013-11-04 by CCC
                WQTF += [F:STJ]ACTQTY
                Call VALVCR2([F:ITV]STOFCY,8,[F:PND]PNHNUM,[F:PND]PNDLIN,GBIDD1,GBIDD2,WRET) From STKVAL
                If GBIDD2<>0
                    WAMTTRA += GBIDD1*[F:STJ]ACTQTY/GBIDD2
                Endif
            Next
        Next
        Close Local File [SRDX]

        # Recherche des livraisons inter-sites
        Raz REQ
        REQ(0) = "SELECT SDD.SDHNUM_0, SDD.SDDLIN_0"
        REQ(0)+= " From SDELIVERYD SDD, SDELIVERY SDH"
        REQ(0)+= " Where SDD.SDHNUM_0=SDH.SDHNUM_0"
        REQ(1) = " and SDH.BETFCY_0=2"
# hcb 75816 et 75531   caractere ' supprimé devant l instruction CONVERT
        Case GTYPDBA
            When 1 : REQ(1)+=" and SDD.SHIDAT_0>TO_DATE('"+format$("D:DD[/]MM[/]YYYY",[M:SVAL]REFDAT)+"','DD/MM/YYYY')" # Issue 76447 - 2011-09-22 by CCC : ajout du format pour l'instruction to_date
            When 2 : REQ(1)+=" and SDD.SHIDAT_0>CONVERT(datetime,'"+format$("D:YYYYMMDD",[M:SVAL]REFDAT)+"',112)"
        Endcase

        REQ(1)+= " and SDD.STOFCY_0='"+[F:ITV]STOFCY+"'"
        REQ(1)+= " and SDD.ITMREF_0='"+[F:ITV]ITMREF+"'"
        For (Char SDHNUM, Integer SDDLIN) From num$(GTYPDBA*2+1) Sql REQ As [SDDX]
            For [STJ] Where STOFCY=[F:ITV]STOFCY & VCRTYP=4 & VCRNUM=[F:SDDX]SDHNUM & VCRLIN=[F:SDDX]SDDLIN & ITMREF=[F:ITV]ITMREF & UPDCOD=2
&                         & [F:STJ]OWNER=[F:STJ]STOFCY     # Issue 93606 & 102008 - 2013-11-04 by CCC
                WQTF += [F:STJ]ACTQTY
                WAMTTRA += [F:STJ]VARVAL    # CCC (15/05/08) Bug 47042
            Next
        Next

        # Recherche des retours de réceptions inter-sites
        Link [PND] With [PNH]PNH0~=[F:PND]PNHNUM
&                  As [PNDX]
&                  Where [PNH]PNHFCY = [F:ITV]STOFCY
&                      & [PNH]BETFCY = 2
&                      & [PND]RTNDAT>[M:SVAL]REFDAT
&                      & [PND]ITMREF=[F:ITV]ITMREF
&                      & [PND]PNHFCY = [F:ITV]STOFCY
        Columns [PNDX] ([PND]PNHNUM,[PND]PNDLIN,[PND]PNHFCY,[PND]RTNDAT,[PND]ITMREF,[PND]PNDLIN,
&                       [PNH]PNHFCY,[PNH]PNHNUM,[PNH]BETFCY)
        For [PNDX]
            For [STJ] Where STOFCY=[F:ITV]STOFCY & VCRTYP=8 & VCRNUM=[F:PNH]PNHNUM & VCRLIN=[F:PND]PNDLIN & ITMREF=[F:ITV]ITMREF & UPDCOD=2
&                         & [F:STJ]OWNER=[F:STJ]STOFCY     # Issue 93606 & 102008 - 2013-11-04 by CCC
                WQTF += [F:STJ]ACTQTY
                WAMTTRA += [F:STJ]VARVAL
            Next
        Next
        Close Local File [PNDX]
    Endif
Endif

If  [M:SVAL]REFDAT <> date$
& | LACCFLG<>0      # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria

    If dim([M]PMP2)>0 & WCSTCOD=4 & [M]PMP2=2    # CCC (07/06/07) DM 41693
        Call CLCPMP2([F:ITF]STOFCY, [F:ITF]ITMREF, LFILSTJWRH, [M:SVAL]REFDAT, WQTE, WAMT, WCOU, WRET)
        If WRET
            # Erreur
            Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-": CLCPMP2 --> "-num$(WRET),1) From GESECRAN
            Return
        Endif
    Elsif [M:SVAL]CSTCOD=5
        Call CLCFIFO([F:ITF]STOFCY, [F:ITF]ITMREF, LFILSTJWRH, [M:SVAL]REFDAT, LACCFLG, WQTE, WAMT, WCOU, WRET)
        If WRET
            # Erreur
            Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-": CLCFIFO --> "-num$(WRET),1) From GESECRAN
            Return
        Endif
    Else
        If LACCFLG<>0   # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
            Filter [STJ] Where STOFCY = [F:ITF]STOFCY &
&                              OWNER  = [F:ITF]STOFCY &
&                              UPDCOD = 2             &
&                              ITMREF = [F:ITF]ITMREF &
&                              evalue(LFILSTJWRH)     &
&                              (ACCDAT=[0/0/0] | ACCDAT > [M:SVAL]REFDAT)
        Else
            # Avec la régul de sortie, c'est uniquement la date d'imputation qui compte
            If [F:TCM]PRIREGS<>2
                # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
                # CCC (2010-01-22) Bug 61872 : Tenir compte des changements de valeur en date de création
                Filter [STJ] Where STOFCY = [F:ITF]STOFCY &
&                              OWNER  = [F:ITF]STOFCY &
&                              UPDCOD = 2             &
&                              ITMREF = [F:ITF]ITMREF &
&                              evalue(LFILSTJWRH)     &
&                              (IPTDAT > [M:SVAL]REFDAT | (CREDAT > [M:SVAL]REFDAT & (PRIREGFLG=2 | TRSTYP=23)) )
&                        Order By Key STJ0
            Else
                # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
                Filter [STJ] Where STOFCY = [F:ITF]STOFCY &
&                              OWNER  = [F:ITF]STOFCY &
&                              UPDCOD = 2             &
&                              ITMREF = [F:ITF]ITMREF &
&                              evalue(LFILSTJWRH)     &
&                              IPTDAT > [M:SVAL]REFDAT
&                        Order By Key STJ0
            Endif
        Endif
        For [STJ]
            GPE    = 0
            # If ACCDAT=[0/0/0] it can be because of reverse movement although new movement has been accounted before REFDAT
            # This kind of movement musn't decrease quantity. It has to be taken into account as if it has been accounted.
            If LACCFLG & [F:STJ]ACCDAT=[0/0/0] & [F:STJ]AGGIFAFLG=2 & [F:STJ]VARORD=0 & [F:STJ]VARVAL=0
                Filter [STJ2] Where STOFCY = [F:STJ]STOFCY
&                                     & UPDCOD = 2
&                                     & ITMREF = [F:STJ]ITMREF
&                                     & IPTDAT = [F:STJ]IPTDAT
&                                     & VCRTYP = [F:STJ]VCRTYP
&                                     & VCRNUM = [F:STJ]VCRNUM
&                                     & VCRLIN = [F:STJ]VCRLIN
&                                     & MVTSEQ < [F:STJ]MVTSEQ
&                                     & ACCDAT<= [M:SVAL]REFDAT
&                                     & ACCDAT<> [0/0/0]
                Look [STJ2] First
                Filter [STJ2]
                If !fstat
                    GPE=1
                Endif
            Endif

            #X3-89541.sn MJH. When NULAMTIFA is set to NO, records with 0 cost will not be posted to the
            # journal but still have valid quantities. These need to be accounted for in the report.
            # When NULAMTIFA is set to YES, they will already be included in the report so there is
            # no need to check NULAMTIFA here.
            If LACCFLG and [F:STJ]AGGIFAFLG=2 and [F:STJ]ENTCOD<>'' and [F:STJ]IPTDAT <= [M:SVAL]REFDAT
&           and [F:STJ]VARVAL = 0 and [F:STJ]QTYSTU <> 0
              GPE=1
            Endif

            If GPE=0
                GPOINT = "REASTJ"
                Gosub ENTREE From EXEFNC
            Endif
            If GPE = 0
                Case abs(func STKLIB.SENSTRS([F:STJ]TRSTYP))
                  When 1, -2 :
                      # CCC (2009-10-12) Bug 58655 : On fait la somme algébrique des quantités de tous les mouvements
                      #WQTYRCP += [F:STJ]ACTQTY*([F:STJ]PRIREGFLG<>2) # On ne prend pas en compte la quantité des mouvements de régul
                      WQTYRCP += [F:STJ]ACTQTY
                      WVALRCP += [F:STJ]VARVAL
                      WORDRCP += [F:STJ]VARORD
                  When 2, -1 :
                      WQTYISS -= [F:STJ]ACTQTY#*([F:STJ]PRIREGFLG<>2)
                      WVALISS -= [F:STJ]VARVAL
                      WORDISS -= [F:STJ]VARORD
                  When Default :
                      If [F:STJ]TRSTYP=13
                          If [F:STJ]QTYSTU>0
                              WQTYRCP += [F:STJ]ACTQTY
                              WVALRCP += [F:STJ]VARVAL
                              WORDRCP += [F:STJ]VARORD
                          Else
                              WQTYISS -= [F:STJ]ACTQTY
                              WVALISS -= [F:STJ]VARVAL
                              WORDISS -= [F:STJ]VARORD
                          Endif
                      Else
                          WQTYCHG += [F:STJ]ACTQTY
                          WORDCHG += [F:STJ]VARORD
                          WVALCHG += [F:STJ]VARVAL
                      Endif
                Endcase
                WQTE(find(left$([F:STJ]STA,1),"A","Q","R")) -= [F:STJ]ACTQTY#*([F:STJ]PRIREGFLG<>2)
            Endif
        Next
        Filter [STJ]
    Endif
Endif
If [M:SVAL]REFDAT <> date$ & dim([M]PMP2)>0 & [M]PMP2=2
# Issue 74514 - 2011-07-12 by CCC
#    WAMT += WAMTTRA
Else
    # Issue 89380 - 2013-05-28 by CCC : Prise en compte des statuts si FIFO à date
    If WCSTCOD=5 & [M:SVAL]REFDAT<>date$
        # Tout est déjà calculé
    Else
        # CCC (2009-04-10) Bug 54426 : Utiliser la base montant plutôt que le PMP pour éviter les problèmes d'arrondis
        If WCSTCOD=4
            If [F:ITV]AVCBASQTY<>0
    # Issue 74514 - 2011-07-12 by CCC
    #            WAMT = [F:ITV]AVCBASAMT*WQTE/[F:ITV]AVCBASQTY + WAMTTRA
                WAMT = [F:ITV]AVCBASAMT*WQTE/[F:ITV]AVCBASQTY
            Endif
        Elsif WCSTCOD=5 & dim([M:SVAL]PMP2)>0 & [M:SVAL]PMP2=2
            Call CLCFIFO2([F:ITM]ITMREF, [F:ITF]STOFCY, WQTE(0), WAMT, WRET)
            If WRET>0
                Call ECR_TRACE([F:ITF]ITMREF-[F:ITF]STOFCY-": CLCFIFO2 error="+num$(WRET),1) From GESECRAN
            Endif
        Else
            #MJH 120183.sn
            If WCSTCOD=6
              WCOU = func STKVAL.GLOBAL_LOT_PRI([F:ITF]ITMREF,[F:ITF]STOFCY)
            Else
            # CCC (30/08/05) Bug 31836 : remplacement de date$ par [M]REFDAT
              Call GETPRI([F:ITM]ITMREF,"","",[F:ITF]STOFCY,[M]REFDAT,WQTE,"","",WCSTCOD,WCOU,WRET) From STKVAL##MJH 120183.origional
            Endif##MJH 120183.en

            If WRET
                Case WRET
                    When 1:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(373,199,1)-mess(WCSTCOD,480,1),1) From GESECRAN
                    When 2:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(248,197,1),1) From GESECRAN
                    When 5:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(34,196,1),1) From GESECRAN
                Endcase
                Raz WCOU
            Endif
            # Issue 72984 - 2011-04-04 by CCC
            If find(WCSTCOD,1,2)
                WAMT = WQTE(0)*WCOU
                WAMTTRA = WQTF*WCOU
            Else
    # Issue 74514 - 2011-07-12 by CCC
    #            WAMT = WQTE(0)*WCOU+WAMTTRA
                WAMT = WQTE(0)*WCOU
            Endif
        Endif
        WQTE(0) += WQTYISS-WQTYRCP-WQTYCHG
        Case [M]CSTCOD
            When 1, 2 :
                WAMT += (WQTYISS-WQTYRCP-WQTYCHG)*WCOU
            When 7 :
                WAMT += WVALISS-WVALRCP-WVALCHG
            When Default :
                WAMT += WORDISS-WORDRCP-WORDCHG
        Endcase
    Endif
    If WQTE(0)<>0
        WAMT = (([M:SVAL]AAASTA=2)*WQTE(1)+([M:SVAL]QQQSTA=2)*WQTE(2)+([M:SVAL]RRRSTA=2)*WQTE(3))*WAMT/WQTE(0)
    Else
        WAMT = 0
    Endif
    WQTE(0) = ([M:SVAL]AAASTA=2)*WQTE(1)+([M:SVAL]QQQSTA=2)*WQTE(2)+([M:SVAL]RRRSTA=2)*WQTE(3)
Endif

# Issue 74514 - 2011-07-12 by CCC
WAMT += WAMTTRA

Raz [F:STV]
If [M:SVAL]AMTDEVDAT<>[00/00/00]
    [F:STV]AMTDEVDAT  = [M:SVAL]AMTDEVDAT
    # Issue 121652.s - 2017-03-13 MJH added LACCFLG
    [F:STV]AMTDEV     = func CALAMTDEV([F:ITF]ITMREF,[F:ITF]STOFCY,[M:SVAL]AMTDEVDAT, [M:SVAL]REFDAT, LACCFLG)
Endif
#---- On affiche même les stocks négatifs à date ----#
If WQTE+WQTF <> 0 | [F:STV]AMTDEV<>0
    [F:STV]PRONUM     = num$(adxuid(1))
    [F:STV]ITMREF     = [F:ITF]ITMREF
    [F:STV]STOFCY     = [F:ITF]STOFCY
    If GWRHACT=2
        [F:STV]WRH        = [F:ITW]WRH
    Endif
    [F:STV]STOCOU     = [F:STO]STOCOU # Ce chrono sera utile dans le cas d'un état par dépôt pour différencier chaque ligne dans STV
    #[F:STV]ITMDES1    = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:STV]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [F:STV]PCU        = [F:ITM]STU
    [F:STV]QTYPCU     = WQTE + WQTF
    [F:STV]STU        = [F:ITM]STU
    [F:STV]QTYSTU     = WQTE + WQTF
    [F:STV]QTYSTURCP  = WQTYRCP
    [F:STV]QTYSTUISS  = -WQTYISS  # Les quantités sorties sont négatives dans le stojou
    J = find([F:ITM]STU,WUOMV(0..WUOMI-1))
    If J <> 0
        [F:STV]STUDEC = WUOMD(J-1)
        [F:STV]PCUDEC = WUOMD(J-1)
    Endif
    [F:STV]CSTCOD     = WCSTCOD

    [F:STV]CUR        = WCUR
    #
    WFCY              = [F:ITF]STOFCY
    WLOT              = ""
    WDAT              = [M:SVAL]REFDAT
    If (WQTE+WQTF)=0
        WCOU=0
    Else
        WCOU = WAMT/(WQTE+WQTF)
    Endif
    If [M:SVAL]RPTCUR = 2
        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WCOU,[F:STV]CST,WRET) From TRTDEV
        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WAMT,[F:STV]AMT,WRET) From TRTDEV
        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WORDRCP,[F:STV]AMTRCP,WRET) From TRTDEV
        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WORDISS,[F:STV]AMTISS,WRET) From TRTDEV
    Else
        # Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
        #[F:STV]CST      = WCOU
        [F:STV]CST      = arr(WCOU,GRNDVAL)
        [F:STV]AMT      = WAMT
        [F:STV]AMTRCP   = WORDRCP
        [F:STV]AMTISS   = WORDISS
    Endif
  [F:STV]CREUSR     = GUSER
  [F:STV]CREDAT     = date$
  [F:STV]REFDAT     = [M:SVAL]REFDAT
  GPOINT = "BEFWRISTV"
  Gosub ENTREE From EXEFNC
  Write [STV]
  If fstat
    Call FSTA("STV") From GLOCK
  Endif
  Gosub MAJCUM
Endif
Return

###########################################################
$ETAT_DETAIL
#
Local Decimal LAMTDEV

Raz WQTY    # CCC (20/10/05) Bug 32735
Raz WRET
Raz [F:STV]

If [M:SVAL]AMTDEVDAT<>[00/00/00]
    # Issue 121652.s - 2017-03-13 MJH added LACCFLG
    LAMTDEV = func CALAMTDEV([F:ITF]ITMREF,[F:ITF]STOFCY,[M:SVAL]AMTDEVDAT, [M:SVAL]REFDAT, LACCFLG )
Else
    Raz LAMTDEV
Endif

# Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
#------------- Calcul des montants et des sous-totaux --------#
WFCY              = [F:ITF]STOFCY
WDAT              = [M:SVAL]REFDAT
If WCSTCOD<>6
  # Issue 121551 - 2017-02-15 by ERMIL : Pass a -99 for QTY for FIFO and LIFO, if we pass 0 - no price returned.
  If find([L]WCSTCOD,5,8)
    Call GETPRI([F:ITF]ITMREF,"","",WFCY,WDAT,-99,"","",WCSTCOD,WCOU,WRET) From STKVAL
  Else
    Call GETPRI([F:ITF]ITMREF,"","",WFCY,WDAT,WQTY,"","",WCSTCOD,WCOU,WRET) From STKVAL
  Endif
    If WRET
        Case WRET
            When 1:
                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(373,199,1)-mess(WCSTCOD,480,1),1) From GESECRAN
            When 2:
                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(248,197,1),1) From GESECRAN
            When 5:
                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(34,196,1),1) From GESECRAN
        Endcase
        Raz WCOU
    Elsif [M:SVAL]RPTCUR = 2
        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WCOU,WCOU,WRET) From TRTDEV
    Endif
Endif

Filter [SLF] Where ITMREF = [F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY & AVCBASQTY>0
&            Order By Key SLF0
For [SLF]
    Read [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
    Filter [STO] Where evalue(WFILSTO)
&                Order By Key STO3
    For [STO]STO3
        Raz [F:STV]
        Raz WQTYRCP, WQTYISS, WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG
        [F:STV]PRONUM     = num$(adxuid(1))
        [F:STV]ITMREF     = [F:ITF]ITMREF
        [F:STV]STOFCY     = [F:ITF]STOFCY
        [F:STV]LOT        = [F:SLF]LOT
        [F:STV]SLO        = [F:STL]SLO
        #[F:STV]ITMDES1    = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:STV]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [F:STV]STOCOU     = [F:STO]STOCOU
        [F:STV]STA        = [F:STO]STA
        If dim([M:SVAL]TOTWRHFLG)>0
            # Le dépôt n'est alimenté que si /s-total par dépôt sinon, un article présent sur plusieurs dépôts
            # se retrouverait avec des lignes éparpillées sur l'état
            [F:STV]WRH        = string$([M:SVAL]TOTWRHFLG=2,[F:STO]WRH)
        Endif

        [F:STV]LOC        = [F:STO]LOC
        [F:STV]PCU        = [F:STO]PCU
        J = find([F:STV]PCU,WUOMV(0..WUOMI-1))
        If J <> 0
          [F:STV]PCUDEC = WUOMD(J-1)
        Endif
        [F:STV]QTYPCU     = [F:STO]QTYPCU
        [F:STV]STU        = [F:ITM]STU
        J = find([F:STV]STU,WUOMV(0..WUOMI-1))
        If J <> 0
          [F:STV]STUDEC = WUOMD(J-1)
        Endif
        # Issue 114351 - 2016-05-25 by CCC : use active quantity
        #[F:STV]QTYSTU     = [F:STO]QTYSTU
        [F:STV]QTYSTU     = [F:STO]QTYSTUACT
        [F:STV]POT        = [F:STL]POT
        [F:STV]ACT        = [F:STL]ACT
        [F:STV]CSTCOD     = WCSTCOD
        [F:STV]AMTDEV     = LAMTDEV
        [F:STV]AMTDEVDAT  = [M:SVAL]AMTDEVDAT
        [F:STV]CUR        = WCUR
        [F:STV]REFDAT     = [M:SVAL]REFDAT
        [F:STV]CREUSR     = GUSER
        [F:STV]CREDAT     = date$

        If WCSTCOD=6
            Call GETPRI([F:ITF]ITMREF,"","",[F:ITF]STOFCY,WDAT,WQTY,[F:SLF]LOT,[F:SLF]SLO,WCSTCOD,WCOU,WRET) From STKVAL
            If WRET
                Case WRET
                    When 1:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(373,199,1)-mess(WCSTCOD,480,1),1) From GESECRAN
                    When 2:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(248,197,1),1) From GESECRAN
                    When 5:
                        Call ECR_TRACE ([F:ITF]ITMREF-"-"-[F:ITF]STOFCY-":"-mess(34,196,1),1) From GESECRAN
                Endcase
                Raz WCOU
            Endif
            If [M:SVAL]RPTCUR = 2
                Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WCOU,WCOU,WRET) From TRTDEV
            Endif
# Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
#            [F:STV]CST        = WCOU
#            [F:STV]AMT        = arr(([F:STV]QTYSTU*[F:STV]CST),10^-[F:TCU]DECNBR)
        Endif

        # Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
        # Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
        #[F:STV]CST       = WCOU
        [F:STV]CST        = arr(WCOU,GRNDVAL)
        [F:STV]AMT        = arr(([F:STV]QTYSTU*[F:STV]CST),10^-[F:TCU]DECNBR)
        Gosub MAJCUM

        GPOINT = "BEFWRISTV"
        Gosub ENTREE From EXEFNC
        Write [STV]
        If fstat
            Call FSTA("STV") From GLOCK
        Endif

        WQTY += [F:STV]QTYSTU
        WCPT += 1
# Ne pas faire de commit, sinon [LNK] est fermé !!
#        If WCPT>=WMAX
#            Commit
#            Trbegin [STV]
#            Raz WCPT
#        Endif
    Next
    Filter [STO]
Next
Filter [SLF]

If [M:SVAL]TRAFLG=2 & [F:ITV]TRASTO<>0
    Raz [F:STV]
    Raz WQTYRCP, WQTYISS, WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG
    [F:STV]PRONUM     = num$(adxuid(1))
    [F:STV]ITMREF     = [F:ITF]ITMREF
    [F:STV]STOFCY     = [F:ITF]STOFCY
    #[F:STV]ITMDES1    = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:STV]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [F:STV]LOT        = ""
    [F:STV]STOCOU     = 0
    [F:STV]PCU        = [F:ITM]STU    # Renseigner PCU pour le lien dans l'état crystal
    [F:STV]STU        = [F:ITM]STU
    [F:STV]STA        = "TRA"
    J = find([F:STV]STU,WUOMV(0..WUOMI-1))
    If J <> 0
      [F:STV]STUDEC = WUOMD(J-1)
    Endif
    [F:STV]QTYSTU     = [F:ITV]TRASTO
    [F:STV]CSTCOD     = WCSTCOD

    # Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
    If find(WCSTCOD,1,2)<>0
        # Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
        #[F:STV]CST       = WCOU
        [F:STV]CST        = arr(WCOU,GRNDVAL)
        [F:STV]AMT        = arr(([F:STV]QTYSTU*[F:STV]CST),10^-[F:TCU]DECNBR)
    Else
        [F:STV]AMT        = arr([F:ITV]TRAAMT,10^-[F:TCU]DECNBR)
        # Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
        #[F:STV]CST       = arr([F:STV]AMT/[F:STV]QTYSTU,10^-[F:TCU]DECNBR)
        [F:STV]CST        = arr([F:STV]AMT/[F:STV]QTYSTU,GRNDVAL)
    Endif

    [F:STV]AMTDEV     = LAMTDEV
    [F:STV]AMTDEVDAT  = [M:SVAL]AMTDEVDAT
    [F:STV]CUR        = WCUR
    [F:STV]REFDAT     = [M:SVAL]REFDAT
    [F:STV]CREUSR     = GUSER
    [F:STV]CREDAT     = date$

    GPOINT = "BEFWRISTV"
    Gosub ENTREE From EXEFNC
    Write [STV]
    If fstat
        Call FSTA("STV") From GLOCK
    Endif

    WCPT += 1
Endif

If [F:STV]ITMREF="" & LAMTDEV<>0
    Raz [F:STV]
    Raz WQTYRCP, WQTYISS, WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG
    [F:STV]PRONUM     = num$(adxuid(1))
    [F:STV]ITMREF     = [F:ITF]ITMREF
    [F:STV]STOFCY     = [F:ITF]STOFCY
    #[F:STV]ITMDES1    = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:STV]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [F:STV]LOT        = ""
    [F:STV]STOCOU     = 0
    [F:STV]PCU        = [F:ITM]STU    # Renseigner PCU pour le lien dans l'état crystal
    [F:STV]STU        = [F:ITM]STU
    [F:STV]STA        = ""
    J = find([F:STV]STU,WUOMV(0..WUOMI-1))
    If J <> 0
      [F:STV]STUDEC = WUOMD(J-1)
    Endif
    [F:STV]QTYSTU     = 0
    [F:STV]CSTCOD     = WCSTCOD

    [F:STV]AMT        = 0
    # Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
    If find(WCSTCOD,1,2)<>0
        # Issue 89373 - 2017-02-17 by ERMIL : Round unit price field to table precision.
        #[F:STV]CST       = WCOU
        [F:STV]CST        = arr(WCOU,GRNDVAL)
    Else
        [F:STV]CST        = 0
    Endif

    [F:STV]AMTDEV     = LAMTDEV
    [F:STV]AMTDEVDAT  = [M:SVAL]AMTDEVDAT
    [F:STV]CUR        = WCUR
    [F:STV]REFDAT     = [M:SVAL]REFDAT
    [F:STV]CREUSR     = GUSER
    [F:STV]CREDAT     = date$

    GPOINT = "BEFWRISTV"
    Gosub ENTREE From EXEFNC
    Write [STV]
    If fstat
        Call FSTA("STV") From GLOCK
    Endif

    WCPT += 1
Endif

# Issue 118265 - 2016-11-08 by CCC : Calculation of CST & AMT before write to avoid rewrite
##------------- Calcul des montants et des sous-totaux --------#
#WFCY              = [F:ITF]STOFCY
#WDAT              = [M:SVAL]REFDAT
#If WCSTCOD<>6
#    Call GETPRI([F:ITF]ITMREF,"","",WFCY,WDAT,WQTY,"","",WCSTCOD,WCOU,WRET) From STKVAL
#    If WRET
#        Case WRET
#            When 1:
#                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(373,199,1)-mess(WCSTCOD,480,1),1) From GESECRAN
#            When 2:
#                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(248,197,1),1) From GESECRAN
#            When 5:
#                Call ECR_TRACE ([F:ITF]ITMREF-"-"-WFCY-":"-mess(34,196,1),1) From GESECRAN
#        Endcase
#        Raz WCOU
#    Elsif [M:SVAL]RPTCUR = 2
#        Call CONVERT(GLOCALDEV,GSYSCUR,GLOCALDEV,1,datesyst,WCOU,WCOU,WRET) From TRTDEV
#    Endif
#Endif
#
#For [STV] Where CREUSR = GUSER
#&             & PRONUM = num$(adxuid(1))
#&             & ITMREF = [F:ITF]ITMREF
#&             & STOFCY = [F:ITF]STOFCY
#&             & (STA    <>"TRA" or find(WCSTCOD,1,2))   # Issue 90400 - 2013-08-07 by CCC
#    If WCSTCOD<>6
#        [F:STV]CST        = WCOU
#        [F:STV]AMT        = arr(([F:STV]QTYSTU*[F:STV]CST),10^-[F:TCU]DECNBR)
#        Rewrite [STV]
#    Endif
#    Gosub MAJCUM
#    WCPT += 1
## Ne pas faire de commit, sinon [LNK] est fermé !!
##    If WCPT>=WMAX
##        Commit
##        Trbegin [STV]
##        Raz WCPT
##    Endif
#Next
Return

###########################################################
$OPEN_FILE
If clalev([F:FCY]) = 0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT      [TUN] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR       [TCU] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG     [ITG] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER    [ITM] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT       [ITV] : Endif
If clalev([F:ITH]) = 0 : Local File ITMMVTHIS    [ITH] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT   [ITF] : Endif
If clalev([F:ITC]) = 0 : Local File ITMCOST      [ITC] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT       [STL] : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY    [SLF] : Endif
If clalev([F:STO]) = 0 : Local File STOCK        [STO] : Endif
If clalev([F:STP]) = 0 : Local File STOCOST      [STP] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU       [STJ] : Endif
If clalev([F:STJ2])= 0 : Local File STOJOU       [STJ2]: Endif
If clalev([F:STV]) = 0 : Local File STOVALWRK    [STV] : Endif
If clalev([F:SVC]) = 0 : Local File STOVALCUM    [SVC] : Endif
If clalev([F:TCM]) = 0 : Local File TABCOSTMET   [TCM] : Endif
If clalev([F:PTH]) = 0 : Local File PRECEIPT     [PTH] : Endif
If clalev([F:PTD]) = 0 : Local File PRECEIPTD    [PTD] : Endif
If clalev([F:SDH]) = 0 : Local File SDELIVERY    [SDH] : Endif
If clalev([F:SDD]) = 0 : Local File SDELIVERYD   [SDD] : Endif
If clalev([F:SRH]) = 0 : Local File SRETURN      [SRH] : Endif
If clalev([F:SRD]) = 0 : Local File SRETURND     [SRD] : Endif
If clalev([F:PNH]) = 0 : Local File PRETURN      [PNH] : Endif
If clalev([F:PND]) = 0 : Local File PRETURND     [PND] : Endif
If clalev([F:BPR]) = 0 : Local File BPARTNER     [BPR] : Endif
If clalev([F:PID]) = 0 : Local File PINVOICED    [PID] : Endif
If clalev([F:ITCP])= 0 : Local File ITMCOSTPIT   [ITCP]: Endif
If clalev([F:ITVP])= 0 : Local File ITMMVTPIT    [ITVP]: Endif
If clalev([F:STPP])= 0 : Local File STOCOSTPIT   [STPP]: Endif
If clalev([F:SLFP])= 0 : Local File STOLOTFCYPIT [SLFP]: Endif
If clalev([F:PER]) = 0 : Local File PERIOD       [PER] : Endif
If clalev([F:SMC]) = 0 : Local File STOMVTCOST   [SMC] : Endif
If clalev([F:CGVD])= 0 : Local File CGVDET       [CGVD]: Endif
If GWRHACT=2
    If clalev([F:ITW]) = 0 : Local File ITMWRH [ITW] : Endif
Endif
Return
###########################################################
$PUR_STV
Trbegin [STV]
Delete [STV] Where CREUSR = GUSER & CREDAT < date$
fstat = 0
Delete [SVC] Where CREUSR = GUSER & CREDAT < date$
fstat = 0
Delete [STV] Where PRONUM = num$(adxuid(1))
fstat = 0
Delete [SVC] Where PRONUM = num$(adxuid(1))
fstat = 0
Commit
Return

###########################################################
$TRT_INI
Local Char WSTA(3) : Raz WSTA

If [M:SVAL]RPTCUR = 2
  WCUR = GSYSCUR
Else
  WCUR = GDEVSOC(find([M:SVAL]CPY,GSOC(1..GNBSOC)))
Endif
Read [TCU]TCU0=WCUR
If fstat
  Raz [F:TCU]
Endif
# Lecture unités de mesure
WUOMI = 0
Filter [TUN]
For [TUN]
  If WUOMI < dim(WUOMV)-1
    WUOMV(WUOMI) = [F:TUN]UOM
    WUOMD(WUOMI) = [F:TUN]UOMDEC
    WUOMI += 1
  Else
    Break
  Endif
Next
Filter [TUN]
# Génération des filtres
# Filtre [ITF]
WFILITF = "STOMGTCOD>1"    # On ne prend en compte que les articles gérés en stock
If [M:SVAL]ITMREFSTR <> "" | [M:SVAL]ITMREFEND <> ""
  WFILITF += "&[F:ITF]ITMREF>=[M:SVAL]ITMREFSTR & [F:ITF]ITMREF<=[M:SVAL]ITMREFEND"
Endif
If [M:SVAL]BUYSTR <> "" | [M:SVAL]BUYEND <> ""
  WFILITF += "&[F:ITF]BUY>=[M:SVAL]BUYSTR & [F:ITF]BUY <=[M:SVAL]BUYEND"
Endif
#Filtre [ITM]
WFILITM = "1=1"
If [M:SVAL]TCLCODSTR <> "" | [M:SVAL]TCLCODEND <> ""
  WFILITM += "&[F:ITM]TCLCOD>=[M:SVAL]TCLCODSTR & [F:ITM]TCLCOD<=[M:SVAL]TCLCODEND"
Endif
If [M:SVAL]ACCSTR <> "" | [M:SVAL]ACCEND <> ""
  WFILITM += "&[F:ITM]ACCCOD>=[M:SVAL]ACCSTR & [F:ITM]ACCCOD<=[M:SVAL]ACCEND"
Endif
WFILTSI = "1=1"
If dim([M:SVAL]TSICODSTR) > 0
  For I = 0 To dim([M:SVAL]TSICODSTR)-1
    If [M:SVAL]TSICODSTR(I) <> "" | [M:SVAL]TSICODEND(I) <> ""
       WFILTSI += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:SVAL]TSICODSTR(I)+
&      "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:SVAL]TSICODEND(I)+"'"
    Endif
  Next I
Endif
# Filtre [STO]
Raz ICRIT
# Issue 97591 - 2014-03-24 by CCC : filter by owner
#WFILSTO(0) =  "[F:STO]ITMREF=[F:ITF]ITMREF&[F:STO]STOFCY=[F:ITF]STOFCY"
WFILSTO(0) =  "[F:STO]ITMREF=[F:ITF]ITMREF&[F:STO]STOFCY=[F:ITF]STOFCY&find(OWNER,[F:ITF]STOFCY,'')<>0"
Call ADDCRIT(WFILSTO,ICRIT,"WFILSTO","[F:STO]QTYSTU>0","&") From GOBJSUB
Call ADDCRIT(WFILSTO,ICRIT,"WFILSTO","[F:STO]LOT=[F:SLF]LOT&[F:STO]SLO=[F:SLF]SLO","&") From GOBJSUB
If !([M:SVAL]AAASTA = 2 & [M:SVAL]QQQSTA = 2 & [M:SVAL]RRRSTA = 2)
  WSTR += "&find(left$([F:STO]STA,1),''"
  If [M:SVAL]AAASTA = 2
    WSTA+="A"
    WSTR += ",'A'"
  Endif
  If [M:SVAL]QQQSTA = 2
    WSTA+="Q"
    WSTR += ",'Q'"
  Endif
  If [M:SVAL]RRRSTA = 2
    WSTA+="R"
    WSTR += ",'R'"
  Endif
  WSTR += ")"
Else
  WSTA="AQR"
Endif
Call ADDCRIT(WFILSTO,ICRIT,"WFILSTO",WSTR,"&") From GOBJSUB
# Issue 83575 - 2012-08-13 by CCC : Filtrer selon les bornes saisies
If dim([M:SVAL]WRHSTR)>0 & [M:SVAL]WRHSTR<>""
    Call ADDCRIT(WFILSTO,ICRIT,"WFILSTO","[F:STO]WRH>='"+[M:SVAL]WRHSTR+"'","&") From GOBJSUB
Endif
If dim([M:SVAL]WRHEND)>0 & [M:SVAL]WRHEND<>""
    Call ADDCRIT(WFILSTO,ICRIT,"WFILSTO","[F:STO]WRH<='"+[M:SVAL]WRHEND+"'","&") From GOBJSUB
Endif

Raz ICRIT
# Issue 97591 - 2014-03-24 by CCC : filter by owner
#WFILITW(0) =  "ITMREF=[F:ITF]ITMREF&STOFCY=[F:ITF]STOFCY"
WFILITW(0) =  "ITMREF=[F:ITF]ITMREF&STOFCY=[F:ITF]STOFCY&find(OWNER,[F:ITF]STOFCY,'')<>0"
If dim([M:SVAL]WRHSTR)>0 & [M:SVAL]WRHSTR<>""
    Call ADDCRIT(WFILITW,ICRIT,"WFILITW","WRH>='"+[M:SVAL]WRHSTR+"'","&") From GOBJSUB
Endif
If dim([M:SVAL]WRHEND)>0 & [M:SVAL]WRHEND<>""
    Call ADDCRIT(WFILITW,ICRIT,"WFILITW","WRH<='"+[M:SVAL]WRHEND+"'","&") From GOBJSUB
Endif
Return

############################################################
$CHARG_PARAM_ETAT
  WETATP(0) = "User"
  WETATP(1) = "Process"
  WETATP(2) = "stofcydeb"
  WETATP(3) = "stofcyfin"
  WETATP(4) = "tclcoddeb"
  WETATP(5) = "tclcodfin"
  WETATP(6) = "itmrefdeb"
  WETATP(7) = "itmreffin"
  WETATP(8) = "vltdeb"
  WETATP(9) = "vltfin"
  WETATP(10)= "buydeb"
  WETATP(11)= "buyfin"
  WETATP(12)= "stat1deb"
  WETATP(13)= "stat1fin"
  WETATP(14)= "stat2deb"
  WETATP(15)= "stat2fin"
  WETATP(16)= "stat3deb"
  WETATP(17)= "stat3fin"
  WETATP(18)= "stat4deb"
  WETATP(19)= "stat4fin"
  WETATP(20)= "stat5deb"
  WETATP(21)= "stat5fin"
  WETATP(22)= "aaasta"
  WETATP(23)= "qqqsta"
  WETATP(24)= "rrrsta"
  WETATP(25)= "traflg"
  WETATP(26)= "totfcy"
  WETATP(27)= "tottcl"
  WETATP(28)= "totitm"
  WETATP(29)= "totlot"
  WETATP(30)= "totbuy"
  WETATP(31)= "totstat1"
  WETATP(32)= "totstat2"
  WETATP(33)= "totstat3"
  WETATP(34)= "totstat4"
  WETATP(35)= "totstat5"
  WETATP(36)= "totwrh"
  #New PIT parameters
  WETATP(37)= "totacc"
  WETATP(38)= "accdeb"
  WETATP(39)= "accdeb"
  WETATP(40)= "primth"
  WETATP(41)= "cpycur"
  WETATP(42)= "totver"
  WETATP(43)= "datdeb"
  WETATP(44)= "datfin"


  WETATV(0) = GUSER
  WETATV(1) = num$(adxuid(1))
  WETATV(2) = [M:SVAL]STOFCYSTR
  WETATV(3) = [M:SVAL]STOFCYEND
  WETATV(4) = [M:SVAL]TCLCODSTR
  WETATV(5) = [M:SVAL]TCLCODEND
  WETATV(6) = [M:SVAL]ITMREFSTR
  WETATV(7) = [M:SVAL]ITMREFEND
  WETATV(8) = [M:SVAL]VLTSTR
  WETATV(9) = [M:SVAL]VLTEND
  WETATV(10)= [M:SVAL]BUYSTR
  WETATV(11)= [M:SVAL]BUYEND
  If dim([M:SVAL]TSICODSTR)<1
       WETATV(12)= ""
       WETATV(13)= ""
  Else WETATV(12)= [M:SVAL]TSICODSTR(0)
       WETATV(13)= [M:SVAL]TSICODEND(0)
  Endif
  If dim([M:SVAL]TSICODSTR)<2
       WETATV(14)= ""
       WETATV(15)= ""
  Else WETATV(14)= [M:SVAL]TSICODSTR(1)
       WETATV(15)= [M:SVAL]TSICODEND(1)
  Endif
  If dim([M:SVAL]TSICODSTR)<3
       WETATV(16)= ""
       WETATV(17)= ""
  Else WETATV(16)= [M:SVAL]TSICODSTR(2)
       WETATV(17)= [M:SVAL]TSICODEND(2)
  Endif
  If dim([M:SVAL]TSICODSTR)<4
       WETATV(18)= ""
       WETATV(19)= ""
  Else WETATV(18)= [M:SVAL]TSICODSTR(3)
       WETATV(19)= [M:SVAL]TSICODEND(3)
  Endif
  If dim([M:SVAL]TSICODSTR)<5
       WETATV(20)= ""
       WETATV(21)= ""
  Else WETATV(20)= [M:SVAL]TSICODSTR(4)
       WETATV(21)= [M:SVAL]TSICODEND(4)
  Endif
  WETATV(22)= num$([M:SVAL]AAASTA)
  WETATV(23)= num$([M:SVAL]QQQSTA)
  WETATV(24)= num$([M:SVAL]RRRSTA)
  WETATV(25)= num$([M:SVAL]TRAFLG)
  WETATV(26)= num$([M:SVAL]TOTFCYFLG)
  WETATV(27)= num$([M:SVAL]TOTTCLFLG)
  WETATV(28)= num$([M:SVAL]TOTITMFLG)
  WETATV(29)= num$([M:SVAL]TOTLOTFLG)
  WETATV(30)= num$([M:SVAL]TOTBUYFLG)
  If dim([M:SVAL]TOTTSIFLG)<1
       WETATV(31)= "0"
  Else WETATV(31)= num$([M:SVAL]TOTTSIFLG(0))
  Endif
  If dim([M:SVAL]TOTTSIFLG)<2
       WETATV(32)= "0"
  Else WETATV(32)= num$([M:SVAL]TOTTSIFLG(1))
  Endif
  If dim([M:SVAL]TOTTSIFLG)<3
       WETATV(33)= "0"
  Else WETATV(33)= num$([M:SVAL]TOTTSIFLG(2))
  Endif
  If dim([M:SVAL]TOTTSIFLG)<4
       WETATV(34)= "0"
  Else WETATV(34)= num$([M:SVAL]TOTTSIFLG(3))
  Endif
  If dim([M:SVAL]TOTTSIFLG)<5
       WETATV(35)= "0"
  Else WETATV(35)= num$([M:SVAL]TOTTSIFLG(4))
  Endif
  If dim([M:SVAL]TOTWRHFLG)<=0
       WETATV(36)= "0"
  Else WETATV(36)= num$([M:SVAL]TOTWRHFLG)
  Endif

  #New PIT parameters
  If dim([M:SVAL]TOTACCCOD)<=0
       WETATV(37)= "0"
  Else WETATV(37)= num$([M:SVAL]TOTACCCOD)
  Endif
  WETATV(38)= [M:SVAL]ACCSTR
  WETATV(39)= [M:SVAL]ACCEND
  WETATV(40)= mess([M:SVAL]CSTCOD,480,1)
  WETATV(41)=WCUR
  If dim([M:SVAL]TOTVERFLG)<=0
       WETATV(42)= "0"
  Else WETATV(42)= num$([M:SVAL]TOTVERFLG)
  Endif
  WETATV(43)= [M:SVAL]STRDAT
  WETATV(44)= [M:SVAL]REFDAT
Return

$GET_REPORT_NAME

  If [M:SVAL]ACCDATFLG = [V]CST_AYES and find([M:SVAL]CSTCOD,9,13)
    If [M:SVAL]DETFLG = [V]CST_AYES
      [M:SVAL]NPRNAM = "STOCK12PD"
    Else
      [M:SVAL]NPRNAM = "STOCK12PG"
    Endif
  Else
    If [M:SVAL]DETFLG = [V]CST_AYES
      [M:SVAL]NPRNAM = "STOCK12D"
    Else
      [M:SVAL]NPRNAM = "STOCK12G"
    Endif
  Endif

Return

