#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# IMPPROJET : traitement correspondant au modèle d'import / export PROJET
#             (projets des budgets opérationnels)
# - 19/09/2008 : SYMEU
##########################################################################
$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
Endcase
Return


$IMPORT

Local Integer NOL
Gosub IMP_DECLARE From TRTX3IMP

Case IMPFIC
    When "PJL" : # PRJLOT : Lots projet
        ICLEPRIM (0) = "[F:PJL]LOT"
        TPRIM (0) = "LOT"
        NBASTAB = "NBLOT"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
        # C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBLOT 
            nolign=NOL+1
            [M]NBLOT+=1
        Endif
Endcase

Return
