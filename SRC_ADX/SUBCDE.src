$AS_CCE
Local Integer I
For I=1 To len(mess(0,693,1))-1
 #If [M]FLD(I-1)="" or I=13 ## SAM 88426 Factoring Management
 If [M]FLD(I-1)=""          ## SAM 88426
  GMENLOC(I) = 1
 Endif
Next I

#JOJAC - X3-11234 - 2017-02-28 - START
#if module Finance de-activated and module HR activated hide local menu items 693 applicable to finance module
If GMODU(2)<>2
  If GMODU(15)=2
    For I = 1 To 25
      If I <> 7 & I <> 8 & I <> 9
        GMENLOC(I)=1
      Endif
    Next
  Endif
Else
#if HR module inactive hide local menu items 693 applicable to HR module
  For I = 26 To 33
    GMENLOC(I)=1
  Next
Endif
#JOJAC - X3-11234 - 2017-02-28 - START
End

