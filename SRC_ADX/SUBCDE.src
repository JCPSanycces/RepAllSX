#######################################################
# Vérification de l'axe /t à la société si renseignée #
#######################################################
Subprog VERIFDIECPY(VALEUR)
Variable Char VALEUR()
If !find(VALEUR,[M:CDE0]DIELIST(0..dim([M]DIE)-1))
 # Axe incompatible avec cette société
 GMESSAGE = mess(94,103,1)
 mkstat=2 : End
Endif
End

####################################################
# Vérification de la société /t au axe du tableau  #
####################################################
Subprog VERIFCPYDIE(SOCIETE)
Value Char SOCIETE
Local Integer CPYOK
CPYOK=1
Local Char CPYDIELIST(GLONDIE)(0..dim([M]DIE)-1)
Local Integer INDEX
INDEX=0
Call LECTURE("CPY",SOCIETE,"")     From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
For I=0 To dim([F:GCM]LED)-1
 If [F:GCM]LED(I)<>""
  Call LECTURE("LED",[F:GCM]LED(I),"") From CONTOBJ
  For J=0 To [F:LED]DIENBR-1
   If !find([F:LED]DIE(J),CPYDIELIST(0..dim([M]DIE)-1))
    CPYDIELIST(INDEX) = [F:LED]DIE(J)
    INDEX += 1
   Endif
   If INDEX>=dim([M]DIE) : Break : Endif
  Next J
 Endif
Next I
For I=0 To [M]NBRDIE-1
 If !find([M]DIE(I),CPYDIELIST(0..dim([M]DIE)-1)) : CPYOK=0 : Break : Endif
Next
If !CPYOK
 # Un ou plusieurs axe(s) du tableau sont incompatible(s) avec cette société
 GMESSAGE = mess(97,103,1)
 mkstat=2 : End
Endif
End


######################################################################
# Traitement de la copie d'une section par defaut
# TABLE = Clé de l'enregistrement à copier
#         (si la cle est numerique val(TABLE))
######################################################################
$TRTCOP
Local Integer OK
If [M]DOSORG=nomap
 Local File CACCEDEF [CDE1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".CACCEDEF" [CDE1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File CACCEDEF [CDE2]
 Local File GDIE     [DIE2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".CACCEDEF" [CDE2]
 Local File =[M]DOSDES+".GDIE"     [DIE2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif

Look [CDE2]CDE0=TABLE
If !fstat
 OK= 1 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
 If OK=1 : Return : Endif
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [CDE1], [CDE2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK=1
Trbegin [CDE2]
 Read [CDE1]CDE0=TABLE
 If !fstat
  Readlock [CDE2]CDE0=TABLE
  If fstat=1
   GOK=-1 : GLOCK="$CACCEDEF"-TABLE : Goto ROLL_TR_COP
  Elsif fstat
   [F:CDE2]=[F:CDE1]
   ## On s'attache à ne copier que le paramètrage des axes analytiques qui existent dans le dossier de destination
   Local Integer I, J
   For J=0 To dim([F:CDE2]DIE)-1
    Raz [F:CDE2]DIE(J), [F:CDE2]NBRDIE
    Assign "[F:CDE2]CCE"+num$(J+1)+"("+num$(0)+")" With 0
    Assign "[F:CDE2]CCE"+num$(J+1)+"("+num$(1)+")" With 0
    Assign "[F:CDE2]CCE"+num$(J+1)+"("+num$(2)+")" With 0
    Assign "[F:CDE2]CCE"+num$(J+1)+"("+num$(3)+")" With 0
    Assign "[F:CDE2]CCE"+num$(J+1)+"("+num$(4)+")" With 0
   Next
   For J=0 To dim([F:CDE1]DIE)-1
    If [F:CDE1]DIE(J)<>""
     Read [DIE2]DIE0 = [F:CDE1]DIE(J)
     If !fstat
      [F:CDE2]DIE([F:CDE2]NBRDIE) = [F:CDE1]DIE(J)
      For I=0 To dim([F:CDE1]CCE1)-1
       Assign "[F:CDE2]CCE"+num$([F:CDE2]NBRDIE+1)+"("+num$(I)+")" With evalue("[F:CDE1]CCE"+num$(J+1)+"("+num$(I)+")")
      Next
      [F:CDE2]NBRDIE += 1
     Endif
    Endif
   Next
   Call COPTEXTRA("CACCEDEF","DESTRA",TABLE,CPY) From ATEXTRA
   Call COPTEXTRA("CACCEDEF","SHOTRA",TABLE,CPY) From ATEXTRA
   Write [CDE2]
   If fstat
    GOK=0 : Call FSTA("CDE2") From GLOCK : Goto AB_TR_COP
   Endif
  Else
   For J=0 To dim([F:CDE2]FLD)-1
    [F:CDE2]FLD(J)= [F:CDE1]FLD(J)
   Next
   [F:CDE2]MODULE = [F:CDE1]MODULE
   [F:CDE2]DES    = [F:CDE1]DES
   [F:CDE2]DESSHO = [F:CDE1]DESSHO
   [F:CDE2]CPY    = [F:CDE1]CPY
   Call COPTEXTRA("CACCEDEF","DESTRA",TABLE,CPY) From ATEXTRA
   Call COPTEXTRA("CACCEDEF","SHOTRA",TABLE,CPY) From ATEXTRA
   Rewrite [CDE2]
   If fstat
    GOK=0 : Call FSTA("CDE2") From GLOCK : Goto AB_TR_COP
   Endif
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If !GROLL Goto TR_COP : Endif
Return


#####################################################################################################
## Initialisation sections à partir du code section par défaut défini dans CODE passé en paramètre
#####################################################################################################
Subprog INISEC(VALEUR,CODE,CAXE)
Variable Char    VALEUR()
Value    Char    CODE
Value    Char    CAXE
Local Integer I, TAB, ISOC, D, RELIT, IND, INDAXE, INDAXE2, XX, XY
Local Char    AXE(GLONDIE), IDENT(30), IDENT2(30), SITE(GLONFCY), ZONE(10), ABREV(GLONABR), WABREV(15), OLDID(30), OLDID2(30), WAXE(GLONDIE), WCCE(GLONCCE)
Local Char FLDCCE(GLONAVA)
AXE  = CAXE
If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
Call LECTURE("CDE",GSOCIETE,CODE) From CONTOBJ
If fstat
 Call LECTURE("CDE","",CODE) From CONTOBJ
Endif
If !fstat
 VALEUR = "" : D=len(mess(0,693,1))
 INDAXE = find(AXE,[F:CDE]DIE(0..dim([F:CDE]DIE)-1))
 If INDAXE
  For I=1 To [F:CDE]NBLIG

   TAB = evalue("[F:CDE]CCE"+num$(INDAXE)+"("+num$(I-1)+")")

   GPOINT="INISEC" : Gosub ENTREE From EXEFNC
   If VALEUR<>""  : Break : Endif

   Gosub IDENT From SUBCDEB

   If VALEUR<>"" : Break : Endif
  Next I
 Endif
Endif
End
######################################################################################


##################################################
## Gestion type de données CDE
##################################################
Subprog SELCDE(COD,CPY)
Variable Char    COD()
Value    Char    CPY
Local Char PARMSK(30)(1..10)
If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif
 PARMSK(1) = CPY
 Call S_LIS_CHAR(COD,PARMSK,"SELCDE","SUBCDE","") From GACTION
End

$SEL_LISTE
Case LISTE
 When "SELCDE"

  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
  Local Char CPY(GLONCPY)
  If find(PARAM(1),GSITE(1..GNBSITE))
   Call LEC_FCY(PARAM(1)) From CPTLEC
   Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  Else
   Call LEC_CPY(PARAM(1)) From CPTLEC
  Endif
  If [F:CPY]CPYLEGFLG=2
   [L]CPY = [F:CPY]CPY
  Else
   [L]CPY=""
  Endif
  Local Char TEXTE(GLONDES)(1..300,1..2)
  NBTEX = 0
  For [CDE]CDE0(1) Where CPY=[L]CPY or CPY=""
   NBTEX += 1
   TEX(NBTEX)     = [F:CDE]COD
   TEXTE(NBTEX,1) = [F:CDE]COD
   TEXTE(NBTEX,2) = [F:CDE]DES
  Next
  TIT(0) = mess(12,123,1)  # Choix
  Call TITOBJ("CDE","",TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  TIT(2) = mess(82,123,1)  # Intitulé
Endcase
Return


##################################################
Subprog IB_COD
If GFONCTION = "GESCDE" : GBOUT1="" : End : Endif
End

## Tunnel section par défaut
Subprog TUNCDE(COD,CPY)
Variable Char    COD()
Value    Char    CPY
Call OBJET_CHAR(CPY,"CDE",COD) From GOBJET
End

## Contrôle section par défaut
Subprog CONTCDE(COD,CPY)
Variable Char    COD()
Value    Char    CPY
If GFONCTION = "GESCDE" | COD="" : End : Endif
If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif
fstat=0
If CPY<>""
 Read [CDE]CDE0 = COD;CPY
 If fstat
  Read [CDE]CDE0(1) = COD
 Endif
Else
 Filter [CDE] Where COD=[L]COD
 Read  [CDE]CDE0 First
Endif

If fstat
 ## Fiche inexistante
 GMESSAGE = mess(23,100,1)
 mkstat = 2
Endif
Filter [CDE]
End

