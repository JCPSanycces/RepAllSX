#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CDE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
Endcase
Return

$OUVRE
If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif
If clalev([F:LED]) = 0 : Local File GLED [LED] : Endif
If clalev([F:GCM]) = 0 : Local File GACM [GCM] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
Local Char INTIT(250)
Local Char SOCIETE(GLONCPY)
Local Integer DIENUM
Return

$INICRE
$INIMOD
If dim([F:CDE]DES)>0
 [F:CDE]DES = [M:CDE0]DESTRA
Endif
Return

$LIENS
Call LECTEXTRA([M:CDE0]DESTRA,"CACCEDEF","DESTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
Call LECTEXTRA([M:CDE1]SHOTRA,"CACCEDEF","SHOTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
[M:CDE2]NBFLD=len(mess(0,693,1))-1
Gosub INIFMT_CCE
zoncou="NBLIG"
Gosub CHG_FMT From W1CDE1
Gosub AFFDIE
SOCIETE = [M]CPY
Gosub CHARGE_DIELIST
Return

$VERIF_CRE
Gosub VERIF
Return

$VERIF_MOD
Gosub VERIF
Return

$VERIF
OK=1
If [M]NBRDIE=0
 # Au moins un axe doit être renseigné
 OK = 0 :  GMESSAGE = mess(135,107,1) : Return
Endif
If !OK : Return : Endif
If [M]NBLIG=0
 # Au moins une règle d'affectation doit être définie
 OK = 0 :  GMESSAGE = mess(136,107,1) : Return
Endif
If !OK : Return : Endif
If [M]CPY<>""
 Call VERIFCPYDIE([M]CPY)
 If mkstat : Return : Endif
Endif
Return

$RAZCRE
[M:CDE2]NBFLD=len(mess(0,693,1))-1
[M:CDE1]NBRDIE=0
[M:CDE1]NBLIG=0
INTIT=""
FMT="-K:10X"
For N=1 To 20
 Gosub INTIT_CCE
Next
zoncou="NBLIG" # nécessaire pour déclencher l'affichage/masquage des colonnes dans $CHG_FMT From W1GDA1
Gosub CHG_FMT From W1CDE1

[M:CDE1]NBLIG=1
Affzo [M:CDE1]
[M:CDE1]NBLIG=0

Affzo [M:CDE1]
Affzo [M:CDE2]
Return

$INIFMT_CCE
[L]DIENUM=[M]NBRDIE
# affichage des colonnes
For N=1 To [L]DIENUM
 If [M]DIE(N-1)<>""
  # lecture du format
  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
  FMT = "K:"+GCCEFMT
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
 Else
  INTIT = ""
  FMT="-K:10X"
 Endif
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]DIENUM+1 To 20
 Gosub INTIT_CCE
Next
Return

$AFFDIE
Local Char INTIT(250)
# affichage des colonnes
For N=1 To [L]DIENUM
 # lecture du format
 If status=65 and N>=nolign # annulation d'une ligne
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N),"") From ATEXTRA
  Call INICCEFMT([M]DIE(N)) From SETGLBDIE
 Elsif (status=71 or status=73) and N>=nolign # ajout/insertion d'une ligne
  If N-1>=0 #and N<>nolign
   Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Else
   INTIT=""
  Endif
  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
 Else
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
 Endif
 If GCCEFMT<>"" : FMT = "K:"+GCCEFMT : Else FMT="-K:10X" : Endif
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]DIENUM+1 To 20
 Gosub INTIT_CCE
Next
Return

$INTIT_CCE
If INTIT=""
 For L=0 To [M:CDE1]NBLIG-1
  Assign "[M:CDE1]CCE"+num$(N)+"("+num$(L)+")" With 0
 Next
Endif
Case N
 When 1  : Titcol [M:CDE1]NBLIG INTIT For CCE1
 When 2  : Titcol [M:CDE1]NBLIG INTIT For CCE2
 When 3  : Titcol [M:CDE1]NBLIG INTIT For CCE3
 When 4  : Titcol [M:CDE1]NBLIG INTIT For CCE4
 When 5  : Titcol [M:CDE1]NBLIG INTIT For CCE5
 When 6  : Titcol [M:CDE1]NBLIG INTIT For CCE6
 When 7  : Titcol [M:CDE1]NBLIG INTIT For CCE7
 When 8  : Titcol [M:CDE1]NBLIG INTIT For CCE8
 When 9  : Titcol [M:CDE1]NBLIG INTIT For CCE9
 When 10 : Titcol [M:CDE1]NBLIG INTIT For CCE10
 When 11 : Titcol [M:CDE1]NBLIG INTIT For CCE11
 When 12 : Titcol [M:CDE1]NBLIG INTIT For CCE12
 When 13 : Titcol [M:CDE1]NBLIG INTIT For CCE13
 When 14 : Titcol [M:CDE1]NBLIG INTIT For CCE14
 When 15 : Titcol [M:CDE1]NBLIG INTIT For CCE15
 When 16 : Titcol [M:CDE1]NBLIG INTIT For CCE16
 When 17 : Titcol [M:CDE1]NBLIG INTIT For CCE17
 When 18 : Titcol [M:CDE1]NBLIG INTIT For CCE18
 When 19 : Titcol [M:CDE1]NBLIG INTIT For CCE19
 When 20 : Titcol [M:CDE1]NBLIG INTIT For CCE20
Endcase
If FMT<>"" and N<=20 : Assign "[M:CDE1]FMTCCE"+num$(N) With FMT : Endif
Return


# décalage des valeurs des champs CCEx du 2e tableau vers la gauche ou la droite
# SENS : 1 = gauche, 2 = droite
Subprog DECALE(NBLIG,CHAMP,SENS)
Value Integer NBLIG
Value Char CHAMP
Value Integer SENS
Local Integer L, N

If SENS=1
 For L=0 To [M]NBLIG-1
  For N=nolign+1 To [L]NBLIG  # décalage des valeurs vers la gauche
   Assign "[M:CDE1]"+[L]CHAMP+num$(N-1)+"("+num$(L)+")" With evalue("[M]"+[L]CHAMP+num$(N)+"("+num$(L)+")")
  Next
 Next
Elsif SENS=2
 For L=0 To [M]NBLIG-1
  For N=[L]NBLIG To nolign Step -1 # décalage des valeurs vers la droite
   Assign "[M:CDE1]"+[L]CHAMP+num$(N+1)+"("+num$(L)+")" With evalue("[M]"+[L]CHAMP+num$(N)+"("+num$(L)+")")
  Next
  Assign "[M:CDE1]"+[L]CHAMP+num$(nolign)+"("+num$(L)+")" With 1
 Next
Endif
End

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("CACCEDEF","DESTRA",CLECUR2,CLECUR1,"CACCEDEF","DESTRA",[M:CDE0]COD,[M:CDE0]CPY)  From ATEXTRA
 Call DUPTEXTRA("CACCEDEF","SHOTRA",CLECUR2,CLECUR1,"CACCEDEF","SHOTRA",[M:CDE0]COD,[M:CDE0]CPY)  From ATEXTRA
Endif
Call MAJTEXTRA([M:CDE0]DESTRA,"CACCEDEF","DESTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
Call MAJTEXTRA([M:CDE1]SHOTRA,"CACCEDEF","SHOTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("CACCEDEF","DESTRA",[M:CDE0]COD,[M:CDE0]CPY,[M:CDE0]COD,NCODE) From ATEXTRA
Call CHGTEXTRA("CACCEDEF","SHOTRA",[M:CDE0]COD,[M:CDE0]CPY,[M:CDE0]COD,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("CACCEDEF","DESTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
Call SUPTEXTRA("CACCEDEF","SHOTRA",[M:CDE0]COD,[M:CDE0]CPY) From ATEXTRA
Return


#################################################################################
## Etiquettes du masque CDE0, CDE1, CDE2
#################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
SOCIETE = VALEUR
If SOCIETE<>""
 Gosub CHARGE_DIELIST
Else
 Raz [M:CDE0]DIELIST
Endif
End

$CHARGE_DIELIST
If SOCIETE<>""
 Local Integer INDEX
 INDEX=0
 Call LECTURE("CPY",SOCIETE,"")     From CONTOBJ
 Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
 For I=0 To dim([F:GCM]LED)-1
  If [F:GCM]LED(I)<>""
   Call LECTURE("LED",[F:GCM]LED(I),"") From CONTOBJ
   For J=0 To [F:LED]DIENBR-1
    If !find([F:LED]DIE(J),[M]DIELIST(0..dim([M]DIE)-1))
     [M]DIELIST(INDEX) = [F:LED]DIE(J)
     INDEX += 1
    Endif
    If INDEX>=dim([M]DIE) : Break : Endif
   Next J
  Endif
 Next I
Else
 Raz [M:CDE0]DIELIST
Endif
Return

Subprog AVANT_NBRDIE
[M:CDE1]ODIE = [M:CDE1]DIE(nolign-1)
End

Subprog APRES_NBRDIE
Local Integer DIENUM
Local Integer NOLI
If status=65 # annulation de ligne
 Call DECALE([M]NBRDIE, "CCE", 1)
 [L]DIENUM=[M]NBRDIE-1
 Gosub AFFDIE
 Affzo
Elsif find(status,1,71) # ajout/insertion ou modif de ligne
 If [M]ODIE='' # ajout/insertion de ligne
  Call DECALE([M]NBRDIE, "CCE", 2)
  If nolign>[M]NBRDIE
   [L]DIENUM=[M]NBRDIE+1
  Else
   [L]DIENUM=[M]NBRDIE
  Endif
  Gosub AFFDIE
  zoncou = "NBLIG"
  Gosub CHG_FMT From W1CDE1
  For NOLI=0 To [M]NBLIG-1
   Assign "[M]CCE"+num$(nolign)+"("+num$(NOLI)+")" With len(mess(0,693,1))
  Next
 Else # modif de ligne
  [L]DIENUM=[M]NBRDIE
  Gosub AFFDIE
 Endif
 Affzo
Endif
End

Subprog B1_NBRDIE
Local Integer DIENUM, OLDNUM
Local Integer I,J
[L]OLDNUM=[M]NBRDIE
Call DIELOAD([M:CDE0]CPY) From CPTBOUT
[L]DIENUM=[M]NBRDIE
Gosub AFFDIE
zoncou = "NBLIG"
Gosub CHG_FMT From W1CDE1
# Initialisation des sections - F58408
For I=0 To [M]NBLIG-1
 For J=[L]OLDNUM+1 To[M]NBRDIE
  Assign "[M]CCE"+num$(J)+"("+num$(I)+")" With len(mess(0,693,1))
 Next
Next
#
Affzo
mkstat = 4
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
If [M:CDE0]CPY<>"" : Call VERIFDIECPY(VALEUR) : Endif
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
End

Subprog AM_DIE(VALEUR)
Variable Char    VALEUR()
If [M]CPY<>"" : Call VERIFDIECPY(VALEUR) : Endif
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
If [M]ODIE<>""
 Case nolign
  When 1  : Raz [M]CCE1
  When 2  : Raz [M]CCE2
  When 3  : Raz [M]CCE3
  When 4  : Raz [M]CCE4
  When 5  : Raz [M]CCE5
  When 6  : Raz [M]CCE6
  When 7  : Raz [M]CCE7
  When 8  : Raz [M]CCE8
  When 9  : Raz [M]CCE9
  When 10 : Raz [M]CCE10
  When 11 : Raz [M]CCE11
  When 12 : Raz [M]CCE12
  When 13 : Raz [M]CCE13
  When 14 : Raz [M]CCE14
  When 15 : Raz [M]CCE15
  When 16 : Raz [M]CCE16
  When 17 : Raz [M]CCE17
  When 18 : Raz [M]CCE18
  When 19 : Raz [M]CCE19
  When 20 : Raz [M]CCE20
 Endcase
Endif
End

