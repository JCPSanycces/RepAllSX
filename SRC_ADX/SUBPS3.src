#<AdxTL>@(#)4.0.0.0 $Revision$
Local File ATEXTRA
Raz GPILOBJ,GNBMASKOUV
Call OBJET("PS2",GBIDC1,GBIDC2) From GOBJET
End
############################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "CREATION"      : Gosub CREATION
 When "MODIF"         : Gosub MODIF
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "APRES_CRE"     : Gosub APRES_CRE
 When "APRES_MOD"     : Gosub APRES_MOD
 When "INICRE"        : Gosub INICRE
 When "LIENS"         : Gosub LIENS
 When "SETBOUT"       : Gosub SETBOUT
 When "EXEBOUT"       : Gosub EXEBOUT
 When "ANNULE"        : Gosub ANNULE
 When "CHANGE"        : Gosub CHANGE
 When "AV_ANNULE"     : Gosub AV_ANNULE
 When "AP_ANNULE"     : Gosub AP_ANNULE
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When "VERF_LISTE"    : Gosub VERF_LISTE
Endcase
Return

############################################################
$OUVRE
Local Char DECLENCHE(GLONPS1)
Read [ACN]ACN0 = "STA"
Return

# Added by Dom Nov 25, 2011 for Syracuse
Funprog PREFIX_TRT_PROTO
Gosub PREFIXE
End "W"+LETTRE+PFIX3

$PREFIXE
Local Char LETTRE(1) , PFIX1(3) , PFIX2(3), PFIX3(3)
LETTRE = "M"
PFIX1  = "STT"
PFIX2  = "STA"
PFIX3  = "STS"
Return

############################################################
$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
If CLECUR
 Local Integer OKACC
 Call LECACC([F:PS2]ACS,OKACC) From SUBACS
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Endif
Endif
Return

############################################################
$INICRE
Raz [F:PS2]LSTDAT
Effzo [M:PS21]LSTDAT
Return

############################################################
$EXEBOUT
Case REP
 When "1" : Gosub VALID
Endcase
Return

############################################################
$VALID
Call LECTURE("PS2",[M]COD,"") From CONTOBJ
Call TEMPON("V") From GESECRAN
If DECLENCHE<>"" & DECLENCHE<>[M]RLG
 Call MAJTRT2(DECLENCHE,nomap,0)
 DECLENCHE = [M]RLG
Endif
Call MAJTRT1([M]COD,nomap,0)
Call MAJTRT2([M]RLG,nomap,0)
Call MAJTRT3([M]COD,nomap,0)
Call TEMPOFF From GESECRAN
If GERR & dim([M:PS21]ENAFLG)>0
 Read [PS2]PS20 = CLECUR1
 [M]ENAFLG = [F:PS2]ENAFLG
 Affzo [PS21]ENAFLG
Endif
Return

############################################################
$APRES_CRE
DECLENCHE = ""
Gosub VALID
Return

############################################################
$APRES_MOD
Gosub VALID
Return

############################################################
$AV_ANNULE
Local Char DECLENCHE(GLONPS1)
DECLENCHE = [F:PS2]RLG
Return

############################################################
$AP_ANNULE
Local Char FIC1(250) , NOMTRT(GLONADC)
Local Integer SYSTA
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+CODE
FIC1 = filpath("TRT",NOMTRT,"src",[L]APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
Call EFFACE_ADX("",[L]APPLI,NOMTRT,SYSTA) From ORDSYS
Call MAJTRT2(DECLENCHE,nomap,0)
Return

############################################################
$AP_CHANGE
Local Char FIC1(250) , NOMTRT(GLONADC)
Local Integer SYSTA
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+OCODE
FIC1 = filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
Call EFFACE_ADX("",APPLI,NOMTRT,SYSTA) From ORDSYS
Call MAJTRT1(NCODE,APPLI,0)
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
Read [PS2]PS20=NCODE
If !fstat
 Call MAJTRT2([F:PS2]RLG,APPLI,0)
Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="PARSTA2" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Delete [AXX] Where CODFIC="PARSTALIG" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="PARSTA2" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA PARSTA2"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="PARSTALIG" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA PARSTALIG"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

########################################
$LIENS
Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
DECLENCHE = [F:PS2]RLG
Read [ATB]CODFIC = [F:PS1]RLGTBL
[M]NBABR = 1
[M]ABREV(1) = [F:ATB]ABRFIC
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]ABRLNK<>""
  ABR = [F:PS1]ABRLNK
 Else
  Read [ATB]CODFIC = [F:PS1]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
For I=0 To [F:PS2]NBRFLD-1
 [M]FLDNUM(I) = I+1
 If [F:PS2]TBLABR<>""
  ABR = [F:PS2]TBLABR
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
nolign = 0
For [PSL] Where COD=[F:PS2]COD
 nolign += 1
 [M:PS22] = [F:PSL]
 If [M:PS22]VARNAM(nolign-1)<>""
  I = find([M:PS22]VARNAM(nolign-1),[F:PS1]VARNAM)
  If I
   Call LECTEXTRA([M:PS22]AMTDES(nolign-1),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
  Endif
  [M:PS22]NUMVAR(nolign-1) = 0
 Else
  [M:PS22]NUMVAR(nolign-1) = nolign
  Call LECTEXTRA([M:PS22]AMTDES(nolign-1),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(nolign)) From ATEXTRA
 Endif
Next
[M:PS22]NBRAMT = nolign
For I=0 To [M]NBRFRM-1
 [M]NUMFRM(I) = I+1
Next
Call GRISE_PERTYP([F:PS2]PERPRG)
Call GRISE_UPDLEV([F:PS2]RLG)
Return

########################################
$CREATION
For nolign=1 To [M]NBRAMT
 [F:PSL] = [M:PS22]
 [F:PSL]COD = [F:PS2]COD
 [F:PSL]NUMLIG = nolign
 Write [PSL]
 If fstat
  GOK=0 : Call FSTA("PSL") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Call MAJTEXTRA([M:PS20]INTIT,"PARSTA2","INTIT",[M:PS20]COD,"") From ATEXTRA
Call MAJTEXTRA([M:PS20]INTSHO,"PARSTA2","INTSHO",[M:PS20]COD,"") From ATEXTRA

# Duplication
If GREP ="D"
 For I=0 To [M:PS22]NBRFLD-1
  Call DUPTEXTRA("PARSTA2","FLDINTIT",CLECUR1,num$([M]FLDNUM(I)),"PARSTA2","FLDINTIT",[M:PS20]COD,num$(I+1)) From ATEXTRA
 Next I
 For I=0 To [M:PS23]NBRFRM-1
  Call DUPTEXTRA("PARSTA2","INTITFRM",CLECUR1,num$([M]NUMFRM(I)),"PARSTA2","INTITFRM",[M:PS20]COD,num$(I+1)) From ATEXTRA
 Next I
 For I=0 To [M:PS22]NBRAMT-1
  If [M:PS22]VARNAM(I)=""
   Call DUPTEXTRA("PARSTALIG","INTITVAR",CLECUR1,num$([M]NUMVAR(I)),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(I+1)) From ATEXTRA
  Endif
 Next I
 Return
Endif

# Sauvegarde des textes avant modif (intitulés des champs)
For I=0 To [M:PS22]NBRFLD-1
 If [M]FLDNUM(I)<>0
  Call DUPTEXTRA("PARSTA2","FLDINTIT",[M:PS20]COD,num$([M]FLDNUM(I)),"PARSTA2","FLDINTIT"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des champs)
Delete [AXX] Where CODFIC="PARSTA2" & ZONE="FLDINTIT" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des champs)
Update [AXX] Where CODFIC="PARSTA2" & ZONE="FLDINTIT" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des champs)
For I=0 To [M:PS22]NBRFLD-1
 Call MAJTEXTRA([M:PS22]FLDINTIT(I),"PARSTA2","FLDINTIT",[M:PS20]COD,num$(I+1)) From ATEXTRA
 [M:PS22]FLDNUM(I) = I+1
Next I

# Sauvegarde des textes avant modif (intitulés des colonnes)
For I=0 To [M:PS23]NBRFRM-1
 If [M]NUMFRM(I)<>0
  Call DUPTEXTRA("PARSTA2","INTITFRM",[M:PS20]COD,num$([M]NUMFRM(I)),"PARSTA2","INTITFRM"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des colonnes)
Delete [AXX] Where CODFIC="PARSTA2" & ZONE="INTITFRM" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des colonnes)
Update [AXX] Where CODFIC="PARSTA2" & ZONE="INTITFRM" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des colonnes)
For I=0 To [M:PS23]NBRFRM-1
 Call MAJTEXTRA([M:PS23]INTITFRM(I),"PARSTA2","INTITFRM",[M:PS20]COD,num$(I+1)) From ATEXTRA
 [M:PS23]NUMFRM(I) = I+1
Next I

# Sauvegarde des textes avant modif (intitulés des variables)
For I=0 To [M:PS22]NBRAMT-1
 If [M]NUMVAR(I)<>0
  Call DUPTEXTRA("PARSTALIG","INTITVAR",[M:PS20]COD,num$([M]NUMVAR(I)),"PARSTALIG","INTITVAR"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des variables)
Delete [AXX] Where CODFIC="PARSTALIG" & ZONE="INTITVAR" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTALIG"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des variables)
Update [AXX] Where CODFIC="PARSTALIG" & ZONE="INTITVAR" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTALIG"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des variables)

For I=0 To [M:PS22]NBRAMT-1
 If [M:PS22]VARNAM(I)=""
  Call MAJTEXTRA([M:PS22]AMTDES(I),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(I+1)) From ATEXTRA
  [M:PS22]NUMVAR(I) = I+1
 Endif
Next I
Return

########################################
$MODIF
Delete [PSL] Where COD=[F:PS2]COD
If fstat=1
 GOK=-1 : Call RSTA("PSL",[F:PS2]COD) From GLOCK
Else
 Gosub CREATION
Endif
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]NBRFRM=0
 [M]NBRFRM = [M]NBRAMT
 For I=0 To [M]NBRAMT-1
  [M]INTITFRM(I) = [M]AMTDES(I)
  [M]AMTFRM(I) = "C"+num$(I+1)
  [M]CUMFRM(I) = 1
 Next I
 Affzo NBRFRM, INTITFRM, AMTFRM, CUMFRM
Endif
Return

############################################################
$SEL_LISTE
Case LISTE
 When "PS2SELVAR"
  Call LECTURE("PS1",PARAM(1),"") From CONTOBJ
  For I=1 To [F:PS1]NBRVAR
   TEX(I)   = [F:PS1]VARNAM(I-1)
   TEXTE(I) = format$("K:11X",[F:PS1]VARNAM(I-1))+func AFNC.TEXTRA("PARSTA1","VARINTIT",[F:PS1]COD,num$(I))
  Next I
  NBTEX = [F:PS1]NBRVAR
 When "PS2SELFRM"
  Local Char OVAL(80) : OVAL = VALEUR
  NBTEX = 0
  For I=1 To [M]NBRAMT
   NBTEX += 1
   TEX(NBTEX) = "C"+num$(I)
   TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)
  Next I
  For I=1 To [M]NBRAMT
   If [M]FRTFLG(I-1)=2
    NBTEX += 1
    TEX(NBTEX) = "P"+num$(I)
    TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(102,126,1) : # (prévisions)
   Endif
  Next I
  For I=1 To [M]NBRAMT
   NBTEX += 1
   TEX(NBTEX) = "CC"+num$(I)
   TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(103,126,1) : # (n-1)
  Next I
  For I=1 To [M]NBRAMT
   If [M]FRTFLG(I-1)=2
    NBTEX += 1
    TEX(NBTEX) = "PP"+num$(I)
    TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(104,126,1) : # (prévisions n-1)
   Endif
  Next I
Endcase
Return

############################################################
$VERF_LISTE
Case LISTE
 When "PS2SELFRM"
  VALEUR = OVAL+VALEUR
Endcase
mkstat = 2
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File PARSTA2   [PS21]
 Local File PARSTALIG [PSL1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".PARSTA2"   [PS21]
 Local File =[M]DOSORG+".PARSTALIG" [PSL1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File PARSTA2   [PS22]
 Local File PARSTALIG [PSL2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".PARSTA2"   [PS22]
 Local File =[M]DOSDES+".PARSTALIG" [PSL2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Local Integer I
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [PS21] , [PS22] , [PSL1] , [PSL2], [AXX1] , [AXX2] , [ADS1] , [ADS2]
Return

$TR_COP
GOK = 1
Trbegin [PS22]
 Delete [PS22] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PARSTA2" : Goto ROLL_TR_COP
 Endif
 Delete [PSL2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PARSTALIG" : Goto ROLL_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="PARSTA2" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="PARSTALIG" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [PS21]PS20 Where COD=TABLE
  [F:PS22] = [F:PS21]
  Call COPTEXTRA("PARSTA2","INTIT",[F:PS22]COD,"") From ATEXTRA
  Call COPTEXTRA("PARSTA2","INTSHO",[F:PS22]COD,"") From ATEXTRA
  For I=1 To [F:PS22]NBRFLD
   Call COPTEXTRA("PARSTA2","FLDINTIT",[F:PS22]COD,num$(I)) From ATEXTRA
  Next I
  For I=1 To [F:PS22]NBRFRM
   Call COPTEXTRA("PARSTA2","INTITFRM",[F:PS22]COD,num$(I)) From ATEXTRA
  Next I
  If dim([F:PS22]UPDUSR)>0 : [F:PS22]UPDUSR = GUSER : Endif
  If dim([F:PS22]UPDDAT)>0 : [F:PS22]UPDDAT = date$ : Endif
  Write [PS22]
  If fstat
   GOK=0 : Call FSTA("PS22") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 I = 0
 For [PSL1]PSL0 Where COD=TABLE
  I += 1
  [F:PSL2] = [F:PSL1]
  If [F:PSL2]VARNAM=""
   Call COPTEXTRA("PARSTALIG","INTITVAR",[F:PS22]COD,num$(I)) From ATEXTRA
  Endif
  Write [PSL2]
  If fstat
   GOK=0 : Call FSTA("PSL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
If APPLI=GDOSX3 : End : Endif
# Validation transactions depuis génération des patchs
Call GENDOS(APPLI)
End

#########################################################
## Pg de mise à jour globale
#########################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer OK, I
If clalev([F:PS1])=0  : Local File =APPLI+".PARSTA1"    [PS1]  : Endif
If clalev([F:PS2])=0  : Local File =APPLI+".PARSTA2"    [PS2]  : Endif
If clalev([F:PSL])=0  : Local File =APPLI+".PARSTALIG"  [PSL]  : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"     [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"    [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File =APPLI+".ATABIND"    [ATI]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"      [ATY]  : Endif
If clalev([F:PS22])=0 : Local File =APPLI+".PARSTA2"    [PS22] : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"     [AOB]  : Endif
If clalev([F:SAT])=0  : Local File =APPLI+".STAT"       [SAT]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"      [ACV]  : Endif

For [PS22]
 Call ECR_TRACE([F:PS22]COD,0) From GESECRAN
 Read [PS2]PS20=[F:PS22]COD
 Call MAJTRT1([F:PS22]COD,APPLI,1)
 Call MAJTRT2([F:PS22]RLG,APPLI,1)
Next PS22
Close Local File
End

#-------------------------------------------------------#
# Pg de mise à jour
#-------------------------------------------------------#

## Traitement associé au code

Subprog MAJTRT1(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

Local Integer I , J , K , K1 , K2 , C , NBFIC , STAT , OKVAL
Local Char    TBFIC(GLONATB)(1..30) , ABFIC(GLONABR)(0..30) , MESSAGE(250)
Local Char    CLFIC(GLONATB)(0..30) , LNKFIC(80)(0..30) , TBAFIC(30)(1..30)
Local Integer LIEN(1..30)
Local Integer FLLIEN
Local Char    EXPLIEN(250) , CHAINE(250) , SCHAINE(250) , TEXTE(30)
Local Char    NOMTRT(GLONADC) , FICTRT(250)
Local Char    CLE(17)(1..16) , DESCLE(250) , CHTEST(250)
Local Char    ABR(GLONABR)
Local Integer NBCLE
Local Char    MAGIC(80)
Local Char    CLE(GLONID1)(1..16)
Local Integer MAXCRI : MAXCRI = dim([F:PS2]TBL)
Local Char    INTIT(80)(MAXCRI) , INTFIC(GLONATB)(MAXCRI) , INTABR(5)(MAXCRI)
Local Char    INTLIEN(250)(MAXCRI) , INTCLE(GLONANX)(MAXCRI)
Local Char    INTTYP(5)(MAXCRI)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Integer TT , OKZOOM , SPA
Local Char    OBJET(GLONAOB) , TABLE(GLONATB) , ACTION(20) , OBJET2(GLONAOB)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:PS1])=0 : Local File PARSTA1    [PS1] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2    [PS2] : Endif
If clalev([F:PSL])=0 : Local File PARSTALIG  [PSL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:SAT])=0 : Local File STAT       [SAT] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR    [AMP] : Endif

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+CODE
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
Endif

OKVAL = 1
Gosub TRT_INI1
If !OKVAL
 Call ECR_TRACE(MESSAGE,-1) From GESECRAN
 Gosub DESACTIVE
Else
 Gosub TRT_DEB1
 Gosub ETIQUETTE1
 Gosub TRT_FIN1
 If !OKVAL
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  Gosub DESACTIVE
 Else
  Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

#--------------------------------------------------------------#
## Désactivation d'une stat en erreur
#--------------------------------------------------------------#

$DESACTIVE
If !adxlog
 Gosub TR_STAT
Else
 Gosub MAJ_STAT
Endif
If GOK=1
 Call ECR_TRACE(CODE-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
 GERR = 1
Endif
Return

$TR_STAT
GOK=1
Trbegin [PS2]
 Gosub MAJ_STAT
 If GOK<0 : Goto AB_TR_STAT : Endif
Commit
Return

$AB_TR_STAT
Rollback
Return

$MAJ_STAT
Readlock [PS2]PS20 = CODE
If fstat=1
 GOK = -1 : GLOCK = "$PARSTA2"
Else
 [F:PS2]ENAFLG = 1
 Rewrite [PS2]
 If fstat
  GOK = 0 : Call FSTA("PS2") From GLOCK
 Endif
Endif
Return

#-------------------------------------------------------#
$TRT_DEB1
Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(6,124,1)-CODE : # Mise à jours statistique
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN1
Wrseq
Openo
Return

#-------------------------------------------------------#
$TRT_INI1

Read [PS2]PS20 = CODE
Read [PS1]PS10 = [F:PS2]RLG
If fstat
 MESSAGE = [F:PS2]RLG-":"-mess(62,126,1) : # Déclencheur statistique
 OKVAL = 0 : Return
Endif

# Recherche des tables à ouvrir

NBFIC = 0
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]TBL(I)<>[F:PS1]RLGTBL
  If [F:PS1]ABRLNK(I)<>""
   ABR = [F:PS1]ABRLNK(I)
  Else
   Read [ATB]CODFIC = [F:PS1]TBL(I)
   If fstat
    MESSAGE = [F:PS1]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  If !find(ABR,ABFIC(1..NBFIC))
   NBFIC += 1
   TBFIC(NBFIC)  = [F:PS1]TBL(I)
   LNKFIC(NBFIC) = [F:PS1]EXPLNK(I)
   ABFIC(NBFIC)  = ABR
   CLFIC(NBFIC)  = [F:PS1]CLELNK(I)
   TBAFIC(NBFIC) = [F:PS1]TBL(I)+"~"+ABR
  Endif
 Endif
Next I
If !OKVAL : Return : Endif
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBL(I)<>[F:PS1]RLGTBL
  If [F:PS2]TBLABR(I)<>""
   ABR = [F:PS2]TBLABR(I)
  Else
   Read [ATB]CODFIC = [F:PS2]TBL(I)
   If fstat
    MESSAGE = [F:PS2]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  If !find(ABR,ABFIC(1..NBFIC))
   NBFIC += 1
   TBFIC(NBFIC)  = [F:PS2]TBL(I)
   ABFIC(NBFIC)  = ABR
   LNKFIC(NBFIC) = ""
   TBAFIC(NBFIC) = [F:PS2]TBL(I)+"~"+ABR
  Endif
 Endif
Next I
If !OKVAL : Return : Endif
For I=0 To [F:PS2]NBRFLD-1
 Read [ATZ]CODZONE = [F:PS2]TBL(I);[F:PS2]FLDNAM(I)
 If fstat
  # Champ $1$ inexistant dans la table $2$
  MESSAGE = func AFNC.MES2(mess(222,115,1),[F:PS2]FLDNAM(I),[F:PS2]TBL(I))
  OKVAL = 0 : Break
 Endif
 If [F:ATZ]LIEN<>""
  If [F:PS2]TBLABR(I)<>""
   ABR = [F:PS2]TBLABR(I)
  Else
   Read [ATB]CODFIC = [F:PS2]TBL(I)
   If fstat
    MESSAGE = [F:PS2]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  J = find([F:ATZ]LIEN+"~"+ABR,TBAFIC(1..NBFIC))
  If [F:ATZ]LIEN<>[F:PS1]RLGTBL & J=0
   If [F:ATZ]EXPLIEN=""
    INTLIEN(I) = "[F:"+ABR+"]"+[F:PS2]FLDNAM(I)
    If [F:PS2]FLDIND(I)<>0
     INTLIEN(I) += "("+num$([F:PS2]FLDIND(I))+")"
    Endif
   Else
    CHAINE = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
    INTLIEN(I) = ""
    While CHAINE<>""
     J = instr(1,CHAINE,";")
     If J
      SCHAINE = left$(CHAINE,J-1) : CHAINE = right$(CHAINE,J+1)
     Else
      SCHAINE = CHAINE : CHAINE = ""
     Endif
     If SCHAINE>="A" & left$(SCHAINE,1)<="Z"
      SCHAINE = "[F:"+ABR+"]"+SCHAINE
     Endif
     Repeat
      J = instr(1,SCHAINE,"indice")
      If J
       SCHAINE = left$(SCHAINE,J-1)+num$([F:PS2]FLDIND(I))+right$(SCHAINE,J+6)
      Endif
     Until J=0
     If INTLIEN(I)<>"" : INTLIEN(I) += ";" : Endif
     INTLIEN(I) += SCHAINE
    Wend
   Endif
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    MESSAGE = [F:ATZ]LIEN-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Else
    INTABR(I) = [F:ATB]ABRFIC
   Endif
  Else
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    MESSAGE = [F:ATZ]LIEN-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Else
    If ABFIC(J)<>""
     INTABR(I) = ABFIC(J)
    Else
     INTABR(I) = [F:ATB]ABRFIC
    Endif
   Endif
  Endif
  Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
  INTFIC(I) = [F:ATB]CODFIC
  INTCLE(I) = [F:ATI]CODIND
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  INTFIC(I) = [F:PS2]TBL(I)
  If [F:PS2]TBLABR(I)<>""
   INTABR(I) = [F:PS2]TBLABR(I)
  Else
   INTABR(I) = [F:ATB]ABRFIC
  Endif
 Endif
 If [F:ATZ]NOLIB<>0 : # mb 13.11.02 bug 16358
  INTIT(I) = "mess([F:"+INTABR(I)+"]"+[F:ATZ]CODZONE+","+num$([F:ATZ]NOLIB)+",1)"
 Elsif [F:ATB]INTIT<>""
  Read [ATZ]CODZONE = [F:ATB]CODFIC;[F:ATB]INTIT
  INTIT(I) = "[F:"+INTABR(I)+"]"+[F:ATB]INTIT
 Elsif [F:ATB]INTITC<>""
  Read [ATZ]CODZONE = [F:ATB]CODFIC;[F:ATB]INTITC
  INTIT(I) = "[F:"+INTABR(I)+"]"+[F:ATB]INTITC
 Endif
 INTTYP(I) = [F:ATZ]CODTYP
Next I
If !OKVAL : Return : Endif
For I=1 To NBFIC
 If ABFIC(I)=""
  Read [ATB]CODFIC = TBFIC(I)
  If fstat
   MESSAGE = TBFIC(I)-":"-mess(124,124,1) : # Table inexistante
   OKVAL = 0 : Break
  Endif
  ABFIC(I) = [F:ATB]ABRFIC
 Endif
 If CLFIC(I)=""
  Read [ATI]NUMLIG(2) = TBFIC(I);1
  CLFIC(I) = [F:ATI]CODIND
 Endif
Next I
Read [ATB]CODFIC = [F:PS1]RLGTBL
If fstat
 MESSAGE = [F:PS1]RLGTBL-":"-mess(124,124,1) : # Table inexistante
 OKVAL = 0 : Return
Endif
ABFIC(0) = [F:ATB]ABRFIC
Read [ATI]NUMLIG(2) = [F:PS1]RLGTBL;1
CLFIC(0) = [F:ATI]CODIND
Return

#-------------------------------------------------------#
$ETIQUETTE1

Wrseq "Subprog MAJSTA(SIGN)"
Wrseq "Value Integer SIGN"
Wrseq
Wrseq "Local Char    CRIT1(20) , CRIT2(20) , CRIT3(20) , CRIT4(20)"
Wrseq "Local Char    CRIT5(20) , CRIT6(20) , CRIT7(20) , CRIT8(20)"
Wrseq "Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY) , VALPAR(10)"
Wrseq "Local Char    INTIT(50)(1.."+num$(MAXCRI)+")"
Wrseq "Local Date    DAT"
Wrseq "Local Decimal MONTANT(1..10)"
Wrseq "Local Integer ISITE , ISOC , STAT , COURTYP"
Wrseq

# Ouverture des fichiers

Wrseq "Gosub OUVRE"
Wrseq

# Société, site

Case [F:PS2]UPDLEV
 When 1 : # Dossier
  Wrseq 'SOCIETE = ""'
  Wrseq 'SITE    = ""'
 When 2
  Gosub SETSOC
  Wrseq 'SITE    = ""'
 When 3
  Gosub SETSOC
  Wrseq 'SITE    = [F:'+[F:PS1]FCYTBL+"]"+[F:PS1]FCYFLD
Endcase
Wrseq

# Etablissement des liens

Wrseq "Gosub LIENS"

# Date de validité

VARIA = "[F:"+ABFIC(0)+"]"+[F:PS1]DATFLD
If [F:PS2]VLYSTR<>[0/0/0]
 Wrseq "If "+VARIA+"<["+format$(GFMD,[F:PS2]VLYSTR)+"] : End : Endif"
Endif
If [F:PS2]VLYEND<>[0/0/0]
 Wrseq "If "+VARIA+">["+format$(GFMD,[F:PS2]VLYEND)+"] : End : Endif"
Endif
Wrseq

# Critères de déclenchement

For I=0 To dim([F:PS1]CRI)-1
 If [F:PS1]CRI(I)<>""
  Wrseq "If !("+vireblc(format$("KT:255X",[F:PS1]CRI(I)),2)+")"
  Wrseq " End"
  Wrseq "Endif"
 Endif
Next I
For I=0 To dim([F:PS2]CRI)-1
 If [F:PS2]CRI(I)<>""
  Wrseq "If !("+vireblc(format$("KT:255X",[F:PS2]CRI(I)),2)+")"
  Wrseq " End"
  Wrseq "Endif"
 Endif
Next I
Wrseq

# Evaluation des critères

Wrseq 'Raz CRIT1 , CRIT2 , CRIT3 , CRIT4 , CRIT5 , CRIT6 , CRIT7 , CRIT8'
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBL(I)=[F:PS1]RLGTBL
  ABR = ABFIC(0)
 Elsif [F:PS2]TBLABR(I)<>""
  ABR = [F:PS2]TBLABR(I)
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 VARIA = "[F:"+ABR+"]"+[F:PS2]FLDNAM(I)
 If [F:PS2]FLDIND(I)<>0
  VARIA += "("+num$([F:PS2]FLDIND(I))+")"
 Endif
 Read [ATZ]CODZONE = [F:PS2]TBL(I);[F:PS2]FLDNAM(I)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 Wrseq 'CRIT'+num$(I+1)+' = ';
 Case [F:PS2]FLDTYP(I)
  When 1,2,3,4,5,6
   Wrseq 'num$('+VARIA+')'
  When 7
   Wrseq 'mid$('+VARIA+','+num$([F:PS2]FLDPOS(I))+','+num$([F:PS2]FLDLON(I))+')'
  When 8
   Wrseq 'format$("D:YYYYMMDD",'+VARIA+')'
 Endcase
Next I
For I=[F:PS2]NBRFLD+1 To MAXCRI
 Wrseq "CRIT"+num$(I)+' = "$$$"'
Next I
Wrseq

# Evaluation des intitulés

For I=0 To [F:PS2]NBRFLD-1
 If INTIT(I)<>""
  SPA = 0
  If INTLIEN(I)<>""
   Wrseq 'Read ['+INTABR(I)+']'+INTCLE(I)+' = '+INTLIEN(I)
   Wrseq 'If fstat'
   Wrseq ' INTIT('+num$(I+1)+') = "'+mess(167,123,1)+'"' : # Divers
   Wrseq 'Else'
   SPA = 1
  Endif
  Case INTTYP(I)
   When "ATX"
    Wrseq space$(SPA);'If '+INTIT(I)+'=0'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = "'+mess(167,123,1)+'"' : # Divers
    Wrseq space$(SPA);'Else'
    Wrseq space$(SPA);' Call TEXTE('+INTIT(I)+',INTIT('+num$(I+1)+')) From OBJDIV'
    Wrseq space$(SPA);'Endif'
   When "AXX","AX1","AX2","AX3"
    Wrseq space$(SPA);'Read [AXX]AXX0 = "'+INTFIC(I)+'";"'+right$(INTIT(I),instr(1,INTIT(I),"]")+1)+'";GLANGUE';
    Read [ATI]NUMLIG(2) = INTFIC(I);1
    CHAINE = [F:ATI]DESCRIPT
    If INTFIC(I)=[F:PS1]RLGTBL
     ABR = ABFIC(0)
    Else
     Read [ATB]CODFIC = INTFIC(I)
     ABR = [F:ATB]ABRFIC
    Endif
    Raz CLE, NBCLE
    While CHAINE<>""
     K = instr(1,CHAINE,"+")
     J = instr(1,CHAINE,"-")
     If K & J
      K = min(K,J)
     Elsif J & !K
      K = J
     Endif
     NBCLE += 1
     If K
      CLE(NBCLE) = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      CLE(NBCLE) = CHAINE
      CHAINE = ""
     Endif
    Wend
    Wrseq ";num$([F:"+ABR+"]"+CLE(1)+")";
    For K=2 To NBCLE
     If CHAINE=""
      CHAINE += ";"
     Elsif len(CHAINE)>200
      Wrseq CHAINE;
      CHAINE = '+"~"+'
     Else
      CHAINE += '+"~"+'
     Endif
     CHAINE += "num$([F:"+ABR+"]"+CLE(K)+")"
    Next K
    Wrseq CHAINE
    Wrseq space$(SPA);'If fstat'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = "'+mess(167,123,1)+'"' : # Divers
    Wrseq space$(SPA);'Else'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = [F:AXX]TEXTE'
    Wrseq space$(SPA);'Endif'
   When Default
    Wrseq space$(SPA);'INTIT('+num$(I+1)+') = '+INTIT(I)
  Endcase
  If SPA
   Wrseq 'Endif'
  Endif
 Endif
Next I
Wrseq

# Evaluation de la date

VARIA = "[F:"+[F:PS1]DATTBL+"]"+[F:PS1]DATFLD
Wrseq "If "+VARIA+"=[0/0/0] : End : Endif"
If [F:PS2]PERPRG<>""
 Wrseq "DAT = ";VARIA
 Wrseq "Call CADRE(DAT) From ";[F:PS2]PERPRG
Else
 Case [F:PS2]PERTYP
  When 1 : # Jour
   Wrseq "DAT = ";VARIA
  When 2 : # Semaine
   Wrseq "DAT = aweek(week("+VARIA+"),year("+VARIA+"))"
  When 3 : # Quinzaine
   Wrseq "If day("+VARIA+")>15"
   Wrseq " DAT = gdat$(16,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Else"
   Wrseq " DAT = gdat$(1,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Endif"
  When 4 : # Mois
   Wrseq "DAT = gdat$(1,month("+VARIA+"),year("+VARIA+"))"
  When 5 : # Trimestre
   Wrseq "DAT = gdat$(1,3*int((month("+VARIA+")-1)/3)+1,year("+VARIA+"))"
  When 6 : # Année
   Wrseq "DAT = gdat$(1,1,year("+VARIA+"))"
  When 7 : # Décade
   Wrseq "If day("+VARIA+")>20"
   Wrseq " DAT = gdat$(21,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Elsif day("+VARIA+")>10"
   Wrseq " DAT = gdat$(11,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Else"
   Wrseq " DAT = gdat$(01,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Endif"
 Endcase
Endif
Wrseq

# Evaluation des montants

Wrseq "Raz MONTANT"
I = 1
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]AMTFOR<>""
  Wrseq "MONTANT("+num$(I)+") = "+vireblc(format$("KT:255X",[F:PSL]AMTFOR),2)
 Endif
 I += 1
Next
Wrseq

# Conversion en devise

Wrseq "Gosub CONV_DEVISE"
Wrseq

# Mise à jour du fichier STAT

Wrseq 'Call MAJSTA(SIGN,"'+[F:PS2]UPDCOD+'",SOCIETE,SITE,CRIT1,CRIT2,CRIT3,CRIT4,CRIT5,CRIT6,CRIT7,CRIT8,'
Wrseq '&           INTIT,DAT,MONTANT,'+num$([F:PS2]NBRFLD)+') From SUBPS2'

Wrseq
Wrseq "End"
Wrseq

# Ouverture des fichiers avant un zoom : # mb 30.11.4 bug 27469

Wrseq "$OUVRE"
For I=1 To NBFIC
 Wrseq "If clalev([F:"+ABFIC(I)+"])=0 : Local File "+TBFIC(I)+" ["+ABFIC(I)+"] : Endif"
Next I
For I=0 To [F:PS2]NBRFLD-1
 # If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTFIC(I),TBFIC(1..NBFIC)) :  # bug 46056
 If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTABR(I),ABFIC(1..NBFIC))
  Wrseq "If clalev([F:"+INTABR(I)+"])=0 : Local File "+INTFIC(I)+" ["+INTABR(I)+"] : Endif"
 Endif
Next I
I =  find("AXX",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX1",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX2",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX3",INTTYP(0..[F:PS2]NBRFLD-1))
If I
 Wrseq "If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif"
Endif
Wrseq "Return"
Wrseq

# Fermeture des fichiers après un Zoom : # mb 28.5.1 bug 9275

Wrseq "$FERME"
For I=1 To NBFIC
 Wrseq "If clalev([F:"+ABFIC(I)+"])>0 : Close Local File ["+ABFIC(I)+"] : Endif"
Next I
For I=0 To [F:PS2]NBRFLD-1
 If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTABR(I),ABFIC(1..NBFIC))
  Wrseq "If clalev([F:"+INTABR(I)+"])>0 : Close Local File ["+INTABR(I)+"] : Endif"
 Endif
Next I
Wrseq "If clalev([F:"+ABFIC(0)+"])>0 : Close Local File ["+ABFIC(0)+"] : Endif"
I =  find("AXX",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX1",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX2",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX3",INTTYP(0..[F:PS2]NBRFLD-1))
If I
 Wrseq "If clalev([F:AXX])>0 : Close Local File [AXX] : Endif"
Endif
Wrseq "Return"
Wrseq

# Sous-programmes d'établissement des zooms
Wrseq "$ZOOM"
Wrseq "Raz [M]OBJBOU, OBJCLE, OBJSEC"
For I=1 To [F:PS2]NBRFLD
 Read [ATZ]CODZONE = [F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:PS2]FLDPOS(I-1)=1 & [F:PS2]FLDLON(I-1)=[F:PS2]FLDLNG(I-1)
  OKZOOM = 0
  If [F:ATY]OBJLIEN<>"" | [F:ATY]CODTYP ="VCR"
   SCHAINE = ""
   CHAINE = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
   If CHAINE<>""
    J = instr(1,CHAINE,";")
    If J
     SCHAINE = left$(CHAINE,J-1)
     CHAINE  = right$(CHAINE,J+1)
     If !instr(1,CHAINE,";") & left$(SCHAINE,1)<"A"
      OKZOOM = 1
     Endif
    Elsif [F:ATY]CODTYP = "VCR"
     OKZOOM = 1
    Endif
   Else
    OKZOOM = 1
    CHAINE = [F:PS2]FLDNAM(I-1)
    If [F:PS2]FLDIND(I-1)>0 : CHAINE += "("+num$([F:PS2]FLDIND(I-1))+")" : Endif
   Endif
  Endif
  If OKZOOM
   Repeat
    J = instr(1,SCHAINE,"indice")
    If J
     SCHAINE = left$(SCHAINE,J-1)+num$([F:PS2]FLDIND(I-1))+right$(SCHAINE,J+6)
    Endif
   Until J=0
   If SCHAINE<>""
    SCHAINE = 'num$('+SCHAINE+')'
   Else
    SCHAINE = '""'
   Endif
   CHAINE = "[M:STA2]CLE(max(0,nolign-1))"
   If [F:ATY]CODTYP ="VCR"
    Read [AMP]CODPAR = 2;[F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1);"VCROBJ"
    If !fstat
     Onerrgo
     OBJET2 = evalue([F:AMP]VALPAR)
     Onerrgo
    Endif
   Else
    OBJET2 = [F:ATY]OBJLIEN
   Endif
   Read [AOB]ABREV = OBJET2
   If !fstat
    Wrseq 'If [M:STA1]NIVEAU='+num$(I)
    Wrseq ' Call TEXTE('+num$([F:AOB]LIBEL)+',GBOUT7) From OBJDIV'
    Wrseq ' [M]OBJBOU = "'+OBJET2+'"'
    Wrseq ' [M]OBJCLE = '+CHAINE
    Wrseq ' [M]OBJSEC = '+SCHAINE
    Wrseq 'Endif'
   Endif
  Endif
 Endif
Next I
Wrseq "Return"
Wrseq

# Sous-programme d'établissement des liens

Wrseq "$LIENS"
Raz LIEN
If NBFIC>0
 Wrseq "indice=0"
Endif

$LIEN
FLLIEN = 0
For I=1 To NBFIC
 If LIEN(I)=0
  If LNKFIC(I)<>""
   [F:ATZ]LIEN = TBFIC(I)
   ABL = ABFIC(0)
   ABR = ABFIC(I)
   Gosub SET_LIEN
  Else
   Read [ATZ]LIEN(2) = TBFIC(I);[F:PS1]RLGTBL
   If fstat=0
    ABL = ABFIC(0)
    ABR = ABFIC(I)
    Gosub SET_LIEN
   Else
    Read [ATZ]LIEN(2) = [F:PS1]RLGTBL;TBFIC(I)
    If fstat=0
     ABL = ABFIC(I)
     ABR = ABFIC(0)
     Gosub SET_LIEN_INV
    Else
     For J=1 To NBFIC
      If LIEN(J)=1
       Read [ATZ]LIEN(2) = TBFIC(I);TBFIC(J)
       If fstat=0
        ABL = ABFIC(J)
        ABR = ABFIC(I)
        Gosub SET_LIEN
        Break
       Else
        Read [ATZ]LIEN(2) = TBFIC(J);TBFIC(I)
        If fstat=0
         ABL = ABFIC(J)
         ABR = ABFIC(I)
         Gosub SET_LIEN_INV
         Break
        Endif
       Endif
      Endif
     Next J
    Endif
   Endif
  Endif
 Endif
Next I
If sum(LIEN(1..NBFIC))<>NBFIC
 If FLLIEN
  Goto LIEN
 Else
  OKVAL = 0 : MESSAGE = mess(7,124,1) : # Liens impossible
  Return
 Endif
Endif

Wrseq "Return"
Wrseq

# Conversion en devise

Wrseq "$CONV_DEVISE"
If [F:PS2]UPDLEV=1
 CHAINE = "GSYSCUR"
Else
 CHAINE = "GDEVSOC(ISOC)"
Endif
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]CNV=2
  Wrseq 'Call PARAM(SITE,"CHGTYP",VALPAR) From ADOVAL'
  Wrseq 'COURTYP = val(VALPAR)'
  Wrseq 'If COURTYP=0 : COURTYP = 1 : Endif'
  Break
 Endif
Next
I = 1
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]CNV=2 and [F:PSL]DEVORG<>"" and [F:PSL]DEVDES<>""
  Wrseq "Call CONVERT("+vireblc(format$("KT:80X",[F:PSL]DEVORG),2)
&                  +","+vireblc(format$("KT:80X",[F:PSL]DEVDES),2)
&                  +","+CHAINE
&                  +","+"COURTYP"
&                  +","+"[F:"+[F:PS1]DATTBL+"]"+[F:PS1]DATFLD
&                  +","+"MONTANT("+num$(I)+")"
&                  +","+"MONTANT("+num$(I)+")"
&                  +","+"STAT) From TRTDEV"
 Endif
 I += 1
Next
Wrseq "Return"
Wrseq
Return

#-------------------------------------------------------#
$SET_LIEN
If CLFIC(I)<>""
 Read [ATI]CODIND = TBFIC(I);CLFIC(I)
 If fstat
  Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
 Endif
Else
 Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
Endif
DESCLE = [F:ATI]DESCRIPT
C = 0
While DESCLE<>""
 C += 1
 K1 = instr(1,DESCLE,"+")
 K2 = instr(1,DESCLE,"-")
 If K1 & K2     : K1 = min(K1,K2)
 Elsif K2 & !K1 : K1 = K2
 Endif
 If K1
  CLE(C) = left$(DESCLE,K1-1) : DESCLE = right$(DESCLE,K1+1)
 Else
  CLE(C) = DESCLE : DESCLE = ""
 Endif
 CLE(C) = "[F:"+ABR+"]"+CLE(C)
Wend
Read [ATB]CODFIC = TBFIC(I)
If LNKFIC(I)<>""
 CHAINE = LNKFIC(I)
Else
 CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
Endif
CHTEST = ""
C = 0
If CHAINE=""
 EXPLIEN = "[F:"+ABL+"]"+[F:ATZ]CODZONE
 CHTEST = CLE(1)+"<>"+EXPLIEN
Else
 EXPLIEN = ""
 While CHAINE<>""
  C += 1
  K = instr(1,CHAINE,";")
  If K
   SCHAINE = left$(CHAINE,K-1) : CHAINE = right$(CHAINE,K+1)
  Else
   SCHAINE = CHAINE : CHAINE = ""
  Endif
  If EXPLIEN<>"" : EXPLIEN += ";" : Endif
  If left$(SCHAINE,1)>="A" & left$(SCHAINE,1)<="Z"
   Read [ATZ]CODZONE = [F:ATB]ABRFIC;SCHAINE
   If !fstat
    SCHAINE = "[F:"+ABL+"]"+SCHAINE
   Endif
  Endif
  EXPLIEN += SCHAINE
  If CHTEST<>"" : CHTEST += " | " : Endif
  CHTEST += CLE(C)+"<>"+SCHAINE
 Wend
Endif
If CHTEST<>"" : Wrseq "If "+CHTEST : Endif
Wrseq space$(CHTEST<>"");"Read ["+ABFIC(I)+"]"+CLFIC(I)+" = "+EXPLIEN
Wrseq space$(CHTEST<>"");"If fstat : Raz [F:"+ABFIC(I)+"] : Endif"
If CHTEST<>"" : Wrseq "Endif" : Endif
FLLIEN = 1
LIEN(I) = 1
Return

#----------------------------------#
$SET_LIEN_INV
Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
Read [ATB]CODFIC = [F:ATZ]CODFIC
DESCLE = [F:ATI]DESCRIPT
C = 0
While DESCLE<>""
 C += 1
 K1 = instr(1,DESCLE,"+")
 K2 = instr(1,DESCLE,"-")
 If K1 & K2     : K1 = min(K1,K2)
 Elsif K2 & !K1 : K1 = K2
 Endif
 If K1
  CLE(C) = left$(DESCLE,K1-1) : DESCLE = right$(DESCLE,K1+1)
 Else
  CLE(C) = DESCLE : DESCLE = ""
 Endif
 CLE(C) = "[F:"+ABR+"]"+CLE(C)
Wend
Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
Read [ATB]CODFIC = [F:ATZ]LIEN
CHAINE = [F:ATI]DESCRIPT
CHTEST = ""
C = 0
EXPLIEN = ""
While CHAINE<>""
 C += 1
 K = instr(1,CHAINE,"+")
 L = instr(1,CHAINE,"-")
 If    K & L  : K = min(K,L)
 Elsif L & !K : K = L
 Endif
 If K
  SCHAINE = left$(CHAINE,K-1) : CHAINE = right$(CHAINE,K+1)
 Else
  SCHAINE = CHAINE : CHAINE = ""
 Endif
 If EXPLIEN<>"" : EXPLIEN += ";" : Endif
 If left$(SCHAINE,1)>="A" & left$(SCHAINE,1)<="Z"
  SCHAINE = "[F:"+ABL+"]"+SCHAINE
 Endif
 EXPLIEN += SCHAINE
 If CHTEST<>"" : CHTEST += " | " : Endif
 CHTEST += CLE(C)+"<>"+SCHAINE
Wend
Wrseq "If "+CHTEST
Wrseq " Read ["+ABFIC(I)+"]"+CLFIC(I)+"("+num$(C)+") = "+EXPLIEN
Wrseq " If fstat : Raz [F:"+ABFIC(I)+"] : Endif"
Wrseq "Endif"
FLLIEN = 1
LIEN(I) = 1
Return

#----------------------#
$SETSOC
If [F:PS1]CPYFLD<>""
 Wrseq 'SOCIETE = [F:'+[F:PS1]CPYTBL+"]"+[F:PS1]CPYFLD
Else
 Wrseq 'SITE    = [F:'+[F:PS1]FCYTBL+"]"+[F:PS1]FCYFLD
 Wrseq 'ISITE   = find(SITE,GSITE(1..GNBSITE))'
 Wrseq 'If !ISITE : End : Endif'
 Wrseq 'SOCIETE = GSOCSITE(ISITE)'
Endif
Wrseq 'ISOC    = find(SOCIETE,GSOC(1..GNBSOC))'
Wrseq 'If !ISOC : End : Endif'
Return

#-------------------------------------------------------#
# Traitement de mise à jour pour un code déclenchant
#-------------------------------------------------------#

Subprog MAJTRT2(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

Local Integer STAT
Local Char    NOMTRT(GLONADC) , FICTRT(GDIMFIC) , MAGIC(80)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:PS1])=0 : Local File =APPLI+".PARSTA1" [PS1] : Endif
If clalev([F:PS2])=0 : Local File =APPLI+".PARSTA2" [PS2] : Endif

Read [PS1]PS10 = CODE

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX1+CODE
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
Endif

Gosub TRT_DEB2
Gosub ETIQUETTE2
Gosub TRT_FIN2

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

#-------------------------------------------------------#
$TRT_DEB2
Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(6,124,1)-CODE : # Mise à jours statistique
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN2
Wrseq
Openo
Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQUETTE2
Wrseq "Subprog MAJSTA(SIGN)"
Wrseq "Value Integer SIGN"
For [PS2] Where RLG=[F:PS1]COD & TYP=1 & ENAFLG=2
 Wrseq "Call MAJSTA(SIGN) From W"+LETTRE+PFIX2+[F:PS2]COD
 Wrseq "If GOK<1 : End : Endif"
Next
Wrseq "End"
Wrseq
Return

#####################################################################
Subprog MAJSTA(SIGN,CODE,SOCIETE,SITE
&             ,CRIT1,CRIT2,CRIT3,CRIT4,CRIT5,CRIT6,CRIT7,CRIT8
&             ,INTIT,DAT,MONTANT,NIVCUM)
Value Integer SIGN
Value Char    CODE
Value Char    SOCIETE
Value Char    SITE
Value Char    CRIT1
Value Char    CRIT2
Value Char    CRIT3
Value Char    CRIT4
Value Char    CRIT5
Value Char    CRIT6
Value Char    CRIT7
Value Char    CRIT8
Value Char    INTIT()(1..)
Value Date    DAT
Value Decimal MONTANT(1..)
Value Integer NIVCUM

GPOINT = "DEBMAJSTA" : Gosub ENTREE From EXEFNC

Local Integer OK , I , MAXCRI
Local Char    DESIG(50)
OK = 0
For I=1 To min(dim(MONTANT),dim([F:SAT]AMT))
 If MONTANT(I)<>0 : OK = 1 : Break : Endif
Next I
If !OK : End : Endif : # C'est pas la peine de créer des enregs à 0
If clalev([F:SAT])=0 : Local File STAT    [SAT] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
MAXCRI = dim([F:PS2]TBL)
DESIG = INTIT(NIVCUM)
Gosub NIVSTA
If NIVCUM>7
 DESIG = INTIT(7) : CRIT8 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>6
 DESIG = INTIT(6) : CRIT7 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>5
 DESIG = INTIT(5) : CRIT6 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>4
 DESIG = INTIT(4) : CRIT5 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>3
 DESIG = INTIT(3) : CRIT4 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>2
 DESIG = INTIT(2) : CRIT3 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>1
 DESIG = INTIT(1) : CRIT2 = "$$$" : Gosub NIVSTA
Endif
End

$NIVSTA
Case MAXCRI
 When 1 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1
 When 2 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2
 When 3 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3
 When 4 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4
 When 5 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5
 When 6 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6
 When 7 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6;CRIT7
 When 8 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6;CRIT7;CRIT8
Endcase
If fstat=1
 GOK = -1 : GLOCK="$STAT"-CODE : Return
Elsif fstat
 Raz [F:SAT]
 [F:SAT]COD  = CODE
 [F:SAT]CPY  = SOCIETE
 [F:SAT]FCY  = SITE
 For I=1 To MAXCRI
  Case I
   When 1 : [F:SAT]CRI1 = CRIT1 : [F:SAT]DES1 = INTIT(1)
   When 2 : [F:SAT]CRI2 = CRIT2 : [F:SAT]DES2 = INTIT(2)
   When 3 : [F:SAT]CRI3 = CRIT3 : [F:SAT]DES3 = INTIT(3)
   When 4 : [F:SAT]CRI4 = CRIT4 : [F:SAT]DES4 = INTIT(4)
   When 5 : [F:SAT]CRI5 = CRIT5 : [F:SAT]DES5 = INTIT(5)
   When 6 : [F:SAT]CRI6 = CRIT6 : [F:SAT]DES6 = INTIT(6)
   When 7 : [F:SAT]CRI7 = CRIT7 : [F:SAT]DES7 = INTIT(7)
   When 8 : [F:SAT]CRI8 = CRIT8 : [F:SAT]DES8 = INTIT(8)
  Endcase
 Next I
 [F:SAT]DAT  = DAT
 Gosub CUMSTA
 Write [SAT]
Else
 Gosub CUMSTA
 Rewrite [SAT]
Endif
If fstat
 GOK = 0 : Call FSTA("SAT") From GLOCK : Return
Endif
Return

$CUMSTA
For I=1 To min(dim(MONTANT),dim([F:SAT]AMT))
 [F:SAT]AMT(I-1) += SIGN*MONTANT(I)
Next I
GPOINT = "MAJSTA" : Gosub ENTREE From EXEFNC
Return

################################################################
## Mise à jour en temps réel                                  ##
################################################################
Subprog VALSTA(CODE,SIGN)
Value Char    CODE
Value Integer SIGN
Local Integer OKTRT
Local Char NOMTRT(GLONADC)
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX1+CODE
Call EXISTE_ADX("","",NOMTRT,OKTRT) From ORDSYS
If OKTRT>0
 If clalev([F:SAT])=0 : Local File STAT [SAT] : Endif
 Call MAJSTA(SIGN) From =NOMTRT
Endif
End

################################################################
## Mise à jour en batch                                       ##
################################################################
Subprog VALBATCH(CODE,SOCIETE,SITE,DAT1,DAT2,CAS)
Value Char    CODE
Value Char    SOCIETE
Value Char    SITE
Value Date    DAT1
Value Date    DAT2
Value Integer CAS

Local Integer I
Local Date    DATDEB , DATFIN , DATMAX
Local Char    NOMTRT(GLONADC) , CRITERE(250) , CRITEFF(250) , SCRITERE(250)
Local Char    MAJCOD(10)

If GTRACE<>""
 # Validation statistiques du au
 MESSA = mess(11,124,1)-CODE-SOCIETE-SITE-mess(94,100,1)-format$("D:"+GFMDAT4,DAT1)-mess(95,100,1)-format$("D:"+GFMDAT4,DAT2)
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif

Gosub PREFIXE

If clalev([F:PS1])=0 : Local File PARSTA1    [PS1] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2    [PS2] : Endif
If clalev([F:SAT])=0 : Local File STAT       [SAT] : Endif
If clalev([F:SAP])=0 : Local File STATPRV    [SAP] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif

Read [PS2]PS20 = CODE
MAJCOD = [F:PS2]UPDCOD

DATDEB = DAT1
DATFIN = DAT2

# Effacement
If CAS = 1
 CRITEFF = 'COD="'+MAJCOD+'"'
 If DATDEB<>[0/0/0]
  CRITEFF -= "& DAT>=["+format$(GFMD,DATDEB)+"]"
 Endif
 If DATFIN<>[0/0/0]
  CRITEFF -= "& DAT<=["+format$(GFMD,DATFIN)+"]"
 Endif
 If SOCIETE<>""
  CRITEFF -= '& CPY="'+SOCIETE+'"'
 Endif
 If SITE<>""
  CRITEFF -= '& FCY="'+SITE+'"'
 Endif
 Trbegin [SAT] , [PS2]
  For [SAT]SAT0 Where evalue(CRITEFF)
   [F:SAP] = [F:SAT]
   Read [SAP]SAP0 =
   If !fstat
    Raz [F:SAT]AMT
    Rewrite [SAT]
   Else
    Delete [SAT]SAT0 Curr
   Endif
   If fstat=1
    GOK=-1 : GLOCK="$STAT"-CODE : Rollback : Break
   Endif
  Next SAT
  DATMAX = [0/0/0]
 Commit
Endif

# Regénération de tous les codes actifs ayant le même UPDCOD

Filter [PS2] Where ENAFLG=2 & UPDCOD=MAJCOD
Read [PS2]PS20 First
While fstat<=2

 Read [PS1]PS10 = [F:PS2]RLG
 NOMTRT = "W"+LETTRE+PFIX2+[F:PS2]COD

# Ouverture des fichiers

 Gosub OUVRE From =NOMTRT

# Critère de parcours

 CRITERE = ""
 If DATDEB<>[0/0/0]
  CRITERE = [F:PS1]DATFLD+">=["+format$(GFMD,DATDEB)+"]"
 Endif
 If DATFIN<>[0/0/0]
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]DATFLD+"<=["+format$(GFMD,DATFIN)+"]"
 Endif
 If SOCIETE<>"" & [F:PS1]CPYFLD<>""
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]CPYFLD+'="'+SOCIETE+'"'
 Endif
 If SITE<>"" & [F:PS1]FCYFLD<>""
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]FCYFLD+'="'+SITE+'"'
 Endif

# Mise à jour

 Call DEBTRANS From GLOCK
 If SOCIETE<>"" & [F:PS1]CPYFLD="" & SITE="" & [F:PS1]FCYFLD<>"" : # mb 7.10.2 bug 15982
  For I=1 To GNBSITE
   If GSOCSITE(I)=SOCIETE
    SCRITERE = CRITERE
    If SCRITERE<>"" : SCRITERE += " & " : Endif
    SCRITERE += [F:PS1]FCYFLD+'="'+GSITE(I)+'"'
    Call TR1(SCRITERE,NOMTRT)
   Endif
  Next
 Else
  If CRITERE="" : CRITERE = "1=1" : Endif
  Call TR1(CRITERE,NOMTRT)
 Endif

 Read [PS2]PS20 Next
Wend
Filter [PS2]
End

Subprog TR1(CRITERE,NOMTRT)
Value Char CRITERE
Value Char NOMTRT
Local Date DATMAX
Gosub TR2
End

$TR2
GOK = 1
DATMAX = [F:PS2]LSTDAT
Trbegin [SAT] , [PS2]
 Local File =[F:PS1]RLGTBL : # Fichier par défaut
 For [F] Where evalue(CRITERE)
  Call MAJSTA(+1) From =NOMTRT
  If GOK<1 : Break : Endif
  DATMAX = max(DATMAX,evalue("[F]"+[F:PS1]DATFLD))
 Next
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 [F:PS2]LSTDAT = DATMAX
 Rewrite [PS2]
 If fstat
  GOK=0 : Call FSTA("PS2") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

########################################
## Ecran PS20                         ##
########################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
[M:PS21]UPDCOD = VALEUR : Affzo [PS21]UPDCOD
End

########################################
## Ecran PS21                         ##
########################################
Subprog AS_CRI(VALEUR)
Variable Char    VALEUR()
If indice>0 & [M]CRI(indice-1)=""
 mkstat = 1 : End
Endif
End

Subprog C_CRI(VALEUR)
Variable Char    VALEUR()
Gosub C_FORMULE
End

Subprog AS_UPDLEV(VALEUR)
Variable Integer VALEUR
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If [F:PS1]CPYFLD="" & [F:PS1]FCYFLD=""
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog C_UPDLEV(VALEUR)
Variable Integer VALEUR
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR=3 & [F:PS1]FCYFLD=""
 GMESSAGE = mess(123,123,1) : mkstat = 2 : # Un champ site doit être défini
Endif
End

Subprog IB_RLG
End

Subprog AM_RLG(VALEUR)
Variable Char VALEUR
Call LECTURE("PS1",VALEUR,"") From CONTOBJ
Read [ATB]CODFIC = [F:PS1]RLGTBL
[M]NBABR = 1
[M]ABREV(1) = [F:ATB]ABRFIC
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]ABRLNK<>""
  ABR = [F:PS1]ABRLNK
 Else
  Read [ATB]CODFIC = [F:PS1]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBLABR<>""
  ABR = [F:PS2]TBLABR
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
Call GRISE_UPDLEV(VALEUR)
End

Subprog GRISE_UPDLEV(VALEUR)
Value Char VALEUR
Call LECTURE("PS1",VALEUR,"") From CONTOBJ
If [F:PS1]CPYFLD="" & [F:PS1]FCYFLD=""
 [M:PS21]UPDLEV = 1
 Affzo [PS21]UPDLEV
 Grizo [PS21]UPDLEV
Else
 Actzo [PS21]UPDLEV
Endif
End

Subprog C_PERPRG(VALEUR)
Variable Char    VALEUR()
Call GRISE_PERTYP(VALEUR)
End

Subprog GRISE_PERTYP(VALEUR)
Value Char VALEUR
If VALEUR<>""
 Effzo [PS21]PERTYP
 Grizo [PS21]PERTYP
Else
 Actzo [PS21]PERTYP
Endif
End

########################################
## Ecran PS22                         ##
########################################
Subprog C_FLDNAM(VALEUR)
Variable Char    VALEUR()
Local Decimal LONGUEUR
Local Integer OK
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 Call ERREUR(mess(9,124,1)) From GESECRAN : # Champ inexistant
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 LONGUEUR = 20
Elsif [F:ATY]LNGTYP<>0
 LONGUEUR = [F:ATY]LNGTYP
Else
 LONGUEUR = [F:ATZ]LONG
Endif
If LONGUEUR>20
 OK = 1
 Call AVERTIR(mess(2,124,1),OK) From GESECRAN : # Champ trop long
 If OK<>2 : mkstat = 2 : End : Endif
 LONGUEUR = 20
Endif
[M]FLDLNG(nolign-1) = LONGUEUR
[M]FLDTYP(nolign-1) = [F:ATY]TYPTYP
If VALEUR<>[M]FLDNAM(nolign-1)
 Call TEXTE([F:ATZ]NOCOURT,[M]FLDINTIT(nolign-1)) From OBJDIV
Endif
End

Subprog AS_FLDIND(VALEUR)
Variable Decimal VALEUR
Gosub DIMMAX
If DIMMAX<2 : mkstat=1 : End : Endif
End

$DIMMAX
Local Integer DIMMAX
Read [ATZ]CODZONE = [M]TBL(nolign-1);[M]FLDNAM(nolign-1)
DIMMAX = 0
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If [F:ACV]DIME<>0 : DIMMAX = [F:ACV]DIME : Endif
Endif
If DIMMAX=0
 DIMMAX = [F:ATZ]DIME
Endif
Return

Subprog C_FLDIND(VALEUR)
Variable Decimal VALEUR
Gosub DIMMAX
If VALEUR>=DIMMAX : mkstat = 1 : End : Endif
End

Subprog AS_FLDPOS(VALEUR)
Variable Decimal VALEUR
If [M]FLDTYP(nolign-1)<>7
 mkstat = 1 : End
Elsif VALEUR=0
 VALEUR = 1
Endif
End

Subprog C_FLDPOS(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>[M]FLDLNG(nolign-1)
 mkstat = 1 : End
Endif
End

Subprog AS_FLDLON(VALEUR)
Variable Decimal VALEUR
If [M]FLDTYP(nolign-1)<>7
 VALEUR = [M]FLDLNG(nolign-1)
 mkstat = 2 : End
Elsif VALEUR=0
 VALEUR = [M]FLDLNG(nolign-1)
Endif
End

Subprog C_FLDLON(VALEUR)
Variable Decimal VALEUR
If VALEUR<>int(VALEUR) or VALEUR<1 or VALEUR+[M]FLDPOS(nolign-1)-1>[M]FLDLNG(nolign-1)
 mkstat = 1 : End
Endif
End

Subprog D_TBL(VALEUR)
Variable Char    VALEUR()
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
VALEUR = [F:PS1]RLGTBL
End

Subprog AS_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer I , J
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
I = 0 : [M]TABFIL(I) = [F:PS1]RLGTBL
For J=1 To [F:PS1]NBRTBL
 K = 1
 For T=0 To I
  If [F:PS1]TBL(J-1)=[M]TABFIL(T) & [F:PS1]ABRLNK(J-1)=[M]ABRFIL(T)
   K = 0 : Break
  Endif
 Next T
 If K
  I += 1 : [M]TABFIL(I) = [F:PS1]TBL(J-1) : [M]ABRFIL(I) = [F:PS1]ABRLNK(J-1)
 Endif
Next J
End

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR=[F:PS1]RLGTBL : End : Endif
If find(VALEUR,[F:PS1]TBL(0..[F:PS1]NBRTBL-1)) : End : Endif
Read [ATZ]LIEN(2) = VALEUR;[F:PS1]RLGTBL
If fstat
 Read [ATZ]LIEN(2) = [F:PS1]RLGTBL;VALEUR
 If fstat
  For NOL=0 To [F:PS1]NBRTBL-1
   Read [ATZ]LIEN(2) = VALEUR;[F:PS1]TBL(NOL)
   If fstat=0
    OK = 1 : Break
   Else
    Read [ATZ]LIEN(2) = [F:PS1]TBL(NOL);VALEUR
    If fstat=0 : OK = 1 : Break : Endif
# X3BY contrôles supplémentaires sur la clé
   Endif
  Next NOL
  If !OK
   GMESSAGE = mess(1,124,1)-[F:PS1]RLGTBL : mkstat = 2 : End
#  Pas de lien vers la table
  Endif
 Endif
Endif
End

Subprog C_VARNAM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR<>""
 Local Integer I
 I = find(VALEUR,[F:PS1]VARNAM(0..[F:PS1]NBRVAR-1))
 If I=0
  GMESSAGE = mess(3,124,1) : mkstat = 2 : End
# Variable non définie
 Else
  Call LECTEXTRA([M]AMTDES(nolign-1),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
  [M]AMTFOR(nolign-1) = [F:PS1]VARFOR(I-1)
  If [F:PS1]VARCUR(nolign-1)<>""
   [M]CNV(nolign-1)    = 2
   [M]DEVORG(nolign-1) = [F:PS1]VARCUR(I-1)
  Else
   [M]CNV(nolign-1)    = 1
  Endif
  Affzo AMTDES(nolign-1) , AMTFOR(nolign-1) , CNV(nolign-1) , DEVORG(nolign-1)
 Endif
Endif
End

Subprog C_NBRFLD
Local Char ABR(4)
If status<7
 For I=0 To [M]NBRFLD-1
  If [M]TBLABR(I)<>""
   ABR = [M]TBLABR(I)
  Else
   Read [ATB]CODFIC = [M]TBL(I)
   ABR  = [F:ATB]ABRFIC
  Endif
  If !find(ABR,[M]ABREV(1..[M]NBABR))
   [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
  Endif
 Next I
Endif
End

Subprog AS_AMTDES(VALEUR)
Variable Char    VALEUR()
If [M]VARNAM(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog AS_AMTFOR(VALEUR)
Variable Char    VALEUR()
If [M]VARNAM(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog C_AMTFOR(VALEUR)
Variable Char    VALEUR()
Gosub C_FORMULE
End

$C_FORMULE
Local Integer I , J , K
Local Char    ABR(10)
I=0

$CONTFORM
J = instr(I+1,VALEUR,"[")
If J
 K = instr(J+1,VALEUR,"]")
 If K
  ABR = seg$(VALEUR,J+1,K-1)
  If !instr(1,ABR,"/")
   If left$(ABR,2)="F:"
    ABR = right$(ABR,3)
   Endif
   If !find(ABR,[M]ABREV(1..[M]NBABR))
    GMESSAGE = ABR-mess(5,124,1) : mkstat = 2 : End
#    Table non accessible
   Endif
  Endif
  I = K
  Goto CONTFORM
 Endif
Endif
Return

Subprog AS_DEVORG(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)<>2
 mkstat = 1 : End
Endif
End

Subprog C_DEVORG(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)=2 and VALEUR=""
 mkstat = 2 : GMESSAGE = mess(10,123,1) : End
Endif
End

Subprog AS_DEVDES(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)<>2
 mkstat = 1 : End
Endif
End

Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)=2 and VALEUR=""
 mkstat = 2 : GMESSAGE = mess(10,123,1) : End
Endif
End

Subprog AS_AMTFRM(VALEUR)
Variable Char    VALEUR()
Local Integer I
GFRMNB = 0
For I=1 To [M]NBRAMT
 GFRMNB += 1
 GFRMVAR(GFRMNB) = "C"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)
Next I
For I=1 To [M]NBRAMT
 If [M]FRTFLG(I-1)=2
  GFRMNB += 1
  GFRMVAR(GFRMNB) = "P"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(102,126,1) : # (prévisions)
 Endif
Next I
For I=1 To [M]NBRAMT
 GFRMNB += 1
 GFRMVAR(GFRMNB) = "CC"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(103,126,1) : # (n-1)
Next I
For I=1 To [M]NBRAMT
 If [M]FRTFLG(I-1)=2
  GFRMNB += 1
  GFRMVAR(GFRMNB) = "PP"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(104,126,1) : # (prévisions n-1)
 Endif
Next I
End

Subprog C_AMTFRM(VALEUR)
Variable Char    VALEUR()
Default [L]
If [M]NBRAMT>0
 Local Decimal C1, CC1 : C1 = 1 : CC1 = 1
 If [M]FRTFLG(0)=2 : Local Decimal P1, PP1 : P1 = 1 : PP1 = 1 : Endif
Endif
If [M]NBRAMT>1
 Local Decimal C2, CC2 : C2 = 1 : CC2 = 1
 If [M]FRTFLG(1)=2 : Local Decimal P2, PP2 : P2 = 1 : PP2 = 1 : Endif
Endif
If [M]NBRAMT>2
 Local Decimal C3, CC3 : C3 = 1 : CC3 = 1
 If [M]FRTFLG(2)=2 : Local Decimal P3, PP3 : P3 = 1 : PP3 = 1 : Endif
Endif
If [M]NBRAMT>3
 Local Decimal C4, CC4 : C4 = 1 : CC4 = 1
 If [M]FRTFLG(3)=2 : Local Decimal P4, PP4 : P4 = 1 : PP4 = 1 : Endif
Endif
If [M]NBRAMT>4
 Local Decimal C5, CC5 : C5 = 1 : CC5 = 1
 If [M]FRTFLG(4)=2 : Local Decimal P5, PP5 : P5 = 1 : PP5 = 1 : Endif
Endif
If [M]NBRAMT>5
 Local Decimal C6, CC6 : C6 = 1 : CC6 = 1
 If [M]FRTFLG(5)=2 : Local Decimal P6, PP6 : P6 = 1 : PP6 = 1 : Endif
Endif
If [M]NBRAMT>6
 Local Decimal C7, CC7 : C7 = 1 : CC7 = 1
 If [M]FRTFLG(6)=2 : Local Decimal P7, PP7 : P7 = 1 : PP7 = 1 : Endif
Endif
If [M]NBRAMT>7
 Local Decimal C8, CC8 : C8 = 1 : CC8 = 1
 If [M]FRTFLG(7)=2 : Local Decimal P8, PP8 : P8 = 1 : PP8 = 1 : Endif
Endif
If [M]NBRAMT>8
 Local Decimal C9, CC9 : C9 = 1 : CC9 = 1
 If [M]FRTFLG(8)=2 : Local Decimal P9, PP9 : P9 = 1 : PP9 = 1 : Endif
Endif
If [M]NBRAMT>9
 Local Decimal C10, CC10 : C10 = 1 : CC10 = 1
 If [M]FRTFLG(9)=2 : Local Decimal P10, PP10 : P10 = 1 : PP10 = 1 : Endif
Endif
Onerrgo ERRFRM
X = evalue(VALEUR)
Onerrgo
End

$ERRFRM
GMESSAGE = VALEUR+"\"+errmes$(errn)+"\"+errm
mkstat = 2
Resume

#
# Generation of the program that returns the JSON prototype
# Written by DOM
#

Subprog MAJTRT3(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

# Local variables
Local Char    MAGIC(80)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Char    NOMTRT(GLONADC) , FICTRT(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Integer OKVAL
Local Char    MESSAGE(250)

Local Integer I , J , K , K1 , K2 , C , NBFIC , STAT
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

  If not clalev([PS1]) : Local File PARSTA1 : Endif
  If not clalev([PS2]) : Local File  PARSTA2 : Endif
  If not clalev([PSL]) : Local File  PARSTALIG : Endif
  If not clalev([AXX]) : Local File ATEXTRA : Endif
  If not clalev([ATB]) : Local File ATABLE : Endif
  If not clalev([ATB1]): Local File ATABLE [ATB1] : Endif
  If not clalev([ATZ]) : Local File ATABZON : Endif
  If not clalev([ATZ1]): Local File ATABZON [ATZ1]: Endif
  If not clalev([ATY]) : Local File ATYPE : Endif
  If not clalev([ATY1]): Local File ATYPE [ATY1] : Endif
  If not clalev([AOB]) : Local File AOBJET : Endif
  If not clalev([ATI]) : Local File ATABIND : Endif
  If not clalev([ATX]) : Local File ATEXTE : Endif
  If not clalev([ACV]) : Local File ACTIV : Endif
  If not clalev([AST]) : Local File APLSTD: Endif

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX3+CODE
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8


If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
Endif

Read [PS2]PS20=CODE

OKVAL = 1
Gosub GENETRT3
If !OKVAL
 Call ECR_TRACE(MESSAGE,-1) From GESECRAN
 Gosub DESACTIVE
Else
 Openo
 If !OKVAL
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  Gosub DESACTIVE
 Else
  Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
 Endif
Endif
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

 Goto PADBG
# Debug
  If OKVAL and STAT
     dbgmode=1 : Dbgaff
     Local Instance  REP      Using C_AREPENT
     Local Instance  PSYR     Using C_ASYR
     PSYR= NewInstance With C_ASYR
     PSYR.PREFIX="http://ici_url_test"
     Local Clbfile   WCLOB(6)
     Local Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
     ACTX = NewInstance With =[V]CST_C_NAME_CLASS_CONTEXT
     # nouveau moyen d'init context
     Local Integer ASTATUS
     [L]ASTATUS = fmet ACTX.ACTX_INIT_LAN(nomap,"FRA",adxusr)
#     ACTX.USER = GUSER
#     ACTX.LAN = "FRA"
#     ACTX.LANDEF = "FRA"
     Call PROTO_JSON(ACTX,REP,PSYR,WCLOB) From =NOMTRT
     Openo "#@D:\temp\proto.json",0
     Wrseq WCLOB
     Openo
  Endif
$PADBG

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

$GENETRT3

# Statistical lines and statistical table must be online
  If clalev([F:PSL])=0 : Local File PARSTALIG : Endif
  If clalev([F:SAT])=0 : Local File STAT : Endif

# Local variables declaration
  Local Char KEYTEMP(GLONAVA),CLE1(200),CLE2(200),MAGIC(100)
  Local Integer I,J,K,LENTEMP
  Local Integer NOABREV
  Local Integer IFTOTAL, IFPREVIOUS, IFBUDGET
  Local Char Q(1) : Q="'"
  Local Char DQ(1) : DQ='"'
  Local Char QDQ(2): QDQ=Q+DQ
  Local Char DQQ(2): DQQ=DQ+Q
  Local Char QDQQ(3) : QDQQ=Q+DQQ
  Local Char CRIT_STA(250)

# If NOABREV is set to 1, the variable names aren't prefixed by the abbreviation of the table,
# except if the abbrevations are given in the statistical definition
  NOABREV=1

# Miscellaneous variables
  Local Char ABVTAB(GLONABV)
  Local Integer FIRST_FLD,NB_FLD,FOUND
  Local Char FLDTEMP(GLONABV+GLONAVA+1),PROPTEMP(250), HIERTEMP(250), HIER_TEMP(250)

# Variables used for generation
  Local Char HIERARCHY(100)(1..[PS2]NBRFLD), PROPERTIES(100)(1..[PS2]NBRFLD), FIELDNAME(100)(1..[PS2]NBRFLD), HIERNAME(100)(1..[PS2]NBRFLD)
  Local Char FIELDFORM(100)(1..[PS2]NBRFLD),KEYTYP(100)(1..[PS2]NBRFLD), KEYFLD(100)(1..[PS2]NBRFLD), KEYLINK(100)(1..[PS2]NBRFLD)
  Local Char KEYEXPR(100)(1..[PS2]NBRFLD)
  Local Integer FIRSTFLD(1..[PS2]NBRFLD),NBFLD(1..[PS2]NBRFLD),KEYLENGTH(1..[PS2]NBRFLD), FIELDLEN(1..[PS2]NBRFLD), INTOBJ(1..[PS2]NBRFLD)

# Variables used during link analysis
  Local Char CODTYPE(10)
  Local Integer TYPLEN
  Local Integer TABNUMB
  Local Char CLASSCODE(20)
  Local Char REPCODE(20)
  Local Char MAINTABLE(20)
  Local Char MAINKEYFIELD(20)
  Local  Integer FLDLABEL
  Local Char LINKEXPR(200)
  Local Integer OKPR

# Variables used for storing statistical lines definition
  Local Libelle FRTFLG(1..[PS2]NBRFRM)
  Local Integer NBRAMT

  NBRAMT=0
  For [PSL]PSL0 Where COD=[PS2]COD
    I=[PSL]NUMLIG
    FRTFLG(I)=[PSL]FRTFLG
    NBRAMT=max(NBRAMT,I)
  Next

# Miscellaneous assignments
  MAGIC  = mess(77,133,1) : # Adonix Supervisor

    If clalev([F:ATB])=0 : Local File ATABLE  : Endif
    If clalev([F:ATZ])=0 : Local File ATABZON : Endif
    If clalev([F:ATY])=0 : Local File ATYPE   : Endif

# Statistic code analysis : PS2 is on line
  FIRST_FLD=1 : NB_FLD=0 : FOUND=0
  K=1 : PROPTEMP="" : HIERTEMP=""
  For I=1 To [PS2]NBRFLD
    ABVTAB=[PS2]TBLABR(I-1)
    If ABVTAB="" and NOABREV=0
        Read [ATB]CODFIC=[PS2]TBL(I-1)
        If fstat=0
            ABVTAB=[ATB]ABRFIC
        Else
            ABVTAB=""
        Endif
    Endif
    FLDTEMP=toupper(ABVTAB)+string$(ABVTAB<>"","_")+toupper([PS2]FLDNAM(I-1))+string$([PS2]FLDIND(I-1)<>0,"_"+num$([PS2]FLDIND(I-1)))
#   FLDTEMP=func CAMELCASE(func CAMELCASE("",ABVTAB),[PS2]FLDNAM(I-1))+string$([PS2]FLDIND(I-1)<>0,"_"+num$([PS2]FLDIND(I-1)))

    # If a field group has been created, use it to define "real" hierarchies
    If (I>1 and (dim([PS2]FLDGRP)<0 or [PS2]FLDGRP(I-1)="" or [PS2]FLDGRP(I-2)<>[PS2]FLDGRP(I-1)))
        HIERARCHY(K)=HIER_TEMP
        PROPERTIES(K)=PROPTEMP
        HIERNAME(K)=HIERTEMP
        FIRSTFLD(K)=FIRST_FLD
        NBFLD(K)=NB_FLD
        PROPTEMP=""
        HIERTEMP=""
        FIRST_FLD=I
        NB_FLD=0
        K+=1
    Endif
    PROPTEMP+=string$(PROPTEMP<>"","/")+FLDTEMP
    NB_FLD+=1
    FIELDNAME(I)=FLDTEMP

    Read [ATZ]CODZONE=[PS2]TBL(I-1);[PS2]FLDNAM(I-1)
    If fstat=0
        TABNUMB=[ATZ]NOLIB
        CODTYPE=[ATZ]CODTYP
        Call GET_PAR_TYPE(CODTYPE,TYPLEN,TABNUMB,CLASSCODE,REPCODE,MAINTABLE,MAINKEYFIELD,FLDLABEL,LINKEXPR,OKPR)
        FIELDFORM(I)=string$(CODTYPE="M" and TABNUMB>1,"LA"+num$(TABNUMB)+":"+num$(TYPLEN)+"X")
        If OKPR=0
            Read [ATY]CODTYP=CODTYPE
            KEYTYP(I)=func TYPZON([ATY]TYPTYP,TABNUMB)
            KEYLENGTH(I)=TYPLEN
            KEYFLD(I)=MAINKEYFIELD
            KEYLINK(I)=toupper(REPCODE)
            KEYEXPR(I)=LINKEXPR
            INTOBJ(I)=FLDLABEL
        Else
            KEYTYP(I)=func TYPZON([ATY]TYPTYP,[ATZ]NOLIB)
            KEYLINK(I)=string$([ATZ]NOLIB>1,"~"+num$([ATZ]NOLIB))
        Endif
        FIELDLEN(I)=[PS2]FLDLON(I-1)
    Else
        KEYTYP(I)=func TYPZON([ATY]TYPTYP,[ATZ]NOLIB)
    Endif
#   KEYLINK(I)="" : # Disables the links

    If HIERTEMP=""
        HIER_TEMP="func T(L,P,'"+[PS2]COD+"',F,"+num$(I)+")"
    Else
        HIER_TEMP+="+'/'+func T(L,P,'"+[PS2]COD+"',F,"+num$(I)+")"
    Endif
    HIERTEMP+=string$(HIERTEMP<>"","_")+FLDTEMP

    If I=[PS2]NBRFLD
        HIERARCHY(K)=HIER_TEMP
        PROPERTIES(K)=PROPTEMP
        HIERNAME(K)=HIERTEMP
        FIRSTFLD(K)=FIRST_FLD
        NBFLD(K)=NB_FLD
    Endif
  Next I

# Set IFTOTAL to 1 if aggregated amounts are required
  IFTOTAL=0
  For I=0 To [PS2]NBRFRM-1
    If [PS2]CUMFRM(I)>2
        IFTOTAL=1
        Break
    Endif
  Next I

# Set IFPREVIOUS to 1 if amount of previous period are required
  IFPREVIOUS=sigma(0,[PS2]NBRFRM-1,pat(" "+ctrans([PS2]AMTFRM(indcum),",+-/*^()[]",space$(10))+" ","* CC# *")
&                                 +pat(" "+ctrans([PS2]AMTFRM(indcum),",+-/*^()[]",space$(10))+" ","* PP# *"))<>0

# Set IFBUDGET to 1 if budgets are required
  IFBUDGET=sigma(1,[PS2]NBRFRM,[L]FRTFLG(indcum)>1)<>0

# Header generation
  Local Char APWCB(20)
  APWCB=" Append WCLOB,'"
  Openo FICTRT , 0
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq "#"-MAGIC
  Wrseq "#"-mess(6,124,1)-[PS2]COD-format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",date$) : # Statistic structure filling

  Wrseq "Local Char NOMTRT : NOMTRT=trtcou"
  Wrseq "  dbgmode=1 : Dbgaff"
# Wrseq "  Local Instance REP  Using C_AREPENT"
  Wrseq "  Local Instance PSYR Using C_ASYR"
  Wrseq "  PSYR= NEWINSTANCE With C_ASYR"
  Wrseq '  PSYR.PREFIX="http://ici_url_test"'
  Wrseq "  Local Clbfile   WCLOB(6)"
  Wrseq "  Local Instance ACTX Using "+[V]CST_C_NAME_CLASS_CONTEXT
  Wrseq "  ACTX = NewInstance With "+[V]CST_C_NAME_CLASS_CONTEXT
  # nouveau moyen d'init contexte
  Wrseq "  Local Integer ASTATUS"
  Wrseq '  [L]ASTATUS = fmet ACTX.ACTX_INIT_LAN(nomap,"FRA",adxusr)'
#  Wrseq "  ACTX.USER = GUSER"
#  Wrseq '  ACTX.LAN = "FRA"'
#  Wrseq '  ACTX.LANDEF = "FRA"'
  Wrseq "  Call PROTO_JSON(ACTX,PSYR,WCLOB) From =NOMTRT"
  Wrseq '  Openo "#@D:\temp\proto.json",0'
  Wrseq "  Wrseq WCLOB"
  Wrseq "  Openo"
  Wrseq '  WCLOB=""'
  Wrseq "  Gosub GET"
  Wrseq '  Openo "#@D:\temp\data.json",0'
  Wrseq '  Wrseq WCLOB'
  Wrseq '  Openo'
  Wrseq "End"
  Wrseq

  Wrseq "#"
  Wrseq "# Send the JSON prototype"
  Wrseq "#"
  Wrseq "Subprog PROTO_JSON(ACTX,PSYR,WCLOB)"
  Wrseq "Variable INSTANCE  ACTX Using "+[V]CST_C_NAME_CLASS_CONTEXT
  # Wrseq "Variable INSTANCE  REP      Using C_AREPENT"
  Wrseq "Variable INSTANCE  PSYR     Using C_ASYR"
  Wrseq "Variable Clbfile   WCLOB"

  Wrseq
  Wrseq "# Miscellaneous declarations"
  Wrseq "Local Char P(10) : P='PARSTA2'"
  Wrseq "Local Char F(10) : F='FLDINTIT'"

  Wrseq "Local Char L(10) : L=ACTX.LAN"
  Wrseq "Local Integer FIRST_E"
  Wrseq ""
  Wrseq "#"
  Wrseq "# Detail of the intermediate parameters computed during program generation"
  Wrseq "#"
  Wrseq "# Number of fields="+num$([PS2]NBRFLD)
  For I=1 To [PS2]NBRFLD
    Wrseq "# Fieldname("+num$(I)+")='"+FIELDNAME(I)+"'"
    Wrseq "# Fielform("+num$(I)+")='"+FIELDFORM(I)+"'"
    Wrseq "# Keytyp("+num$(I)+")='"+KEYTYP(I)+"'"
    If clalev([F:ATX])=0 : Local File ATEXTRA : Endif
    Wrseq "# Keylength("+num$(I)+")="+num$(KEYLENGTH(I))
    Wrseq "# Keylink("+num$(I)+")='"+KEYLINK(I)+"'"
    Wrseq "# Keyexpr("+num$(I)+")='"+KEYEXPR(I)+"'"
    Read [ATX]NUMERO='FRA';INTOBJ(I)
    Wrseq "# Intobj("+num$(I)+")="+num$(INTOBJ(I))-'"'+[ATX]TEXTE+'"'
  Next I
  Wrseq "#"
  Wrseq "# Number of hierarchies="+num$(K)
  For I=1 To K
    Wrseq "# Hierarchy("+num$(I)+")='"+HIERARCHY(I)+"'"
    Wrseq "# Hiername("+num$(I)+")='"+HIERNAME(I)+"'"
    Wrseq "# Properties("+num$(I)+")='"+PROPERTIES(I)+"'"
    Wrseq "# Firstfld("+num$(I)+")="+num$(FIRSTFLD(I))
    Wrseq "# Nbfld("+num$(I)+")="+num$(NBFLD(I))
  Next I
  Wrseq

  Wrseq "# Verify that ATEXTRA and APLSTD are opened"
  Wrseq "  If not clalev([ATX]) : Local File ATEXTRA : Endif"
  Wrseq "  If not clalev([AST]) : Local File APLSTD : Endif"
  Wrseq

  Wrseq APWCB+'{"$baseUrl":"'+Q+'+PSYR.PREFIX+'+Q+'","$url":"{$baseUrl}/stats('+Q+"+"+DQQ+tolower([PS2]COD)+"')?representation=$cube('dom')&role={$role}"+DQ+'+'+QDQ+",'"
  Wrseq APWCB+'"$title":"'+Q+'+func T(L,"PARSTA2","'+[PS2]COD+'","INTIT",0)+'+QDQ+",'"
  Wrseq APWCB+'"$type":"application/json; vnd.sage=syracuse.presentation=x3.erp.superv/stat('+Q+"+"+DQ+tolower([PS2]COD)+"')"+DQ+"+"+QDQ+",'"
  Wrseq APWCB+'"$methods":"GET","codeStat":"'+Q+"+"+Q+[PS2]COD+'",'+Q
  Wrseq APWCB+'"$properties":{"$resources":{"$type":"application/x-array","$provType":"PORTALSTA","$item":{"$type":"application/json",'+"'"
  Wrseq APWCB+'"$url":"{$baseUrl}/stats('+Q+"+"+DQQ+tolower([PS2]COD)+"')?representation=$cube('"+tolower([PS2]COD)+"')&role={$role}"+'"+'+QDQ+",'"
  Wrseq APWCB+'"$title":"'+Q+'+func T(L,"PARSTA2","'+[PS2]COD+'","INTIT",0)+'+Q+'",'+Q
  Wrseq APWCB+'"$properties":{'+Q

# Date field (constant)
  Wrseq APWCB+'"dateStat":{"$type":"application/x-date","$capabilities":"sort,filter"},'+Q

# Loop on fields
  For I=1 To [PS2]NBRFLD
     Wrseq APWCB+'"'+FIELDNAME(I)+'":{"$title":"'+Q+'+func T(L,"PARSTA2","'+[PS2]COD+'","FLDINTIT",'+num$(I)+')'+"+"+Q+'","$type":"'+Q
     If left$(KEYLINK(I),1)="~" : # Local menu
        Wrseq APWCB+KEYTYP(I)+'",'+Q
#       Wrseq APWCB+'"$value":{"$type":"application/x-integer","$constraints":{"$enum":['+Q
        Wrseq APWCB+'"$value":{"$type":"application/x-integer","$enum":['+Q
        Wrseq "  FIRST_E=0"
        Wrseq "  For [AST]LAN Where LAN=L and LANCHP="+right$(KEYLINK,2)+" and LANNUM>0"
        Wrseq "    If FIRST_E>0 : "+APWCB+",' : Endif"
        Wrseq "    FIRST_E+=1"
        Wrseq "  "+APWCB+'{"$value":'+Q+"+num$(FIRST_E)+','"
        Wrseq "  "+APWCB+'"$title":"'+Q+"+[AST]LANMES+"+QDQ+"}"+Q
        Wrseq "  Next"
#       Wrseq APWCB+']}},'+Q
        Wrseq APWCB+']},'+Q
     Elsif KEYLINK(I)<>""
         Wrseq APWCB+'application/x-reference","$url":"{$baseUrl}/'+KEYLINK(I)+Q+"+"+DQ
&               +"('{$key}')?representation="+KEYLINK(I)+'.$thumb&role={$role}"'+"+"+QDQ+",'"
         Wrseq APWCB+'"$capabilities":"sort,filter","$value":"{'+KEYFLD(I)+'}",'+Q
         Wrseq APWCB+'"$links":{"$details":{"$type":"application/json;vnd.sage=syracuse","$url":'+Q
         Wrseq APWCB+'"{$baseUrl}/'+KEYLINK(I)+"("+Q+"+"+DQ+"'{$key}')?representation="+KEYLINK(I)+'.$details&role={$role}"+'+QDQQ
         Wrseq APWCB+'}},'+Q : # Ferme "$links" : { "$details" : {
         Wrseq APWCB+'"$properties":{"'+KEYFLD(I)+'":{"$ismandatory":true,"$type":"'+KEYTYP(I)+'",'+Q
         Wrseq APWCB+'"$maxLength":'+num$(KEYLENGTH(I))+Q
         Wrseq APWCB+'}},'+Q : # Ferme "$" : { "champ" : {
    Else
         Wrseq APWCB+KEYTYP(I)+'",'+Q
    Endif
    Wrseq APWCB+'"$maxLength":'+num$(FIELDLEN(1))+',"$capabilities":"sort,filter","$isHidden":false,"$isParameter":true},'+Q
  Next I

# Add the company and facility parameter
  If [PS2]UPDLEV=3
    Wrseq APWCB+'"FACILITY":{"$type":"application/x-reference","$url":'+Q
    Wrseq APWCB+'"{$baseUrl}/FACILITY('+Q+"+"+DQ+"'{$key}')?representation=FACILITY"+'.$details&role={$role}"+'+Q+'","$isParameter":true},'+Q
  Endif
  If [PS2]UPDLEV>=2
    Wrseq APWCB+'"COMPANY":{"$type":"application/x-reference","$url":'+Q
    Wrseq APWCB+'"{$baseUrl}/COMPANY('+Q+"+"+DQ+"'{$key}')?representation=COMPANY"+'.$details&role={$role}"+'+Q+'","$isParameter":true},'+Q
  Endif

  Wrseq APWCB+'"DATBEG1":{"$type":"application/x-date","$title":'+Q
  Wrseq APWCB+'"","$isParameter":true},'+Q
  Wrseq APWCB+'"DATEND1":{"$type":"application/x-date","$title":'+Q
  Wrseq APWCB+'"","$isParameter":true},'+Q
  If IFPREVIOUS
    Wrseq APWCB+'"DATBEG2":{"$type":"application/x-date","$title":'+Q
    Wrseq APWCB+'"","$isParameter":true},'+Q
    Wrseq APWCB+'"DATEND2":{"$type":"application/x-date","$title":'+Q
    Wrseq APWCB+'"","$isParameter":true},'+Q
  Endif

# Loop on numeric values
  For I=1 To [PS2]NBRFRM
      Wrseq APWCB+'"amount'+num$(I)+'":{"$type":"application/x-decimal","$title":"'+Q
&         +'+func T(ACTX.LAN,"PARSTA2","'+[PS2]COD+'","INTITFRM",'+num$(I)+")+'"+DQ+'}'+string$(I<[PS2]NBRFRM,',')+Q
  Next I
  Wrseq APWCB+'}},'+Q : # Closes the deepest level of '$' and "$item"

# Let's start cube
  Wrseq APWCB+'"$cube":{"$mode":"table","$title":"'+Q+'+func T(L,"PARSTA2","'+[PS2]COD+'","INTSHO",0)+'+Q+'",'+Q
  Wrseq APWCB+'"$displaysOneMeasure":true,'+'"$hierarchies":{'+Q

# Loop on hierarchies
  For I=1 To K
    Wrseq APWCB+'"'+HIERNAME(I)+'":{'+Q
    Wrseq APWCB+'"$title":"'+Q+"+"+HIERARCHY(I)+"+"+Q+'","$properties":['+Q
    For J=FIRSTFLD(I) To FIRSTFLD(I)+NBFLD(I)-1
        Wrseq APWCB+'"'+FIELDNAME(J)+'"'+string$(J<FIRSTFLD(I)+NBFLD(I)-1,',')+Q
    Next J
    Wrseq APWCB+"]},"+Q
  Next K

# The date hierarchy, then close $hierarchies, and start measures
  Wrseq APWCB+'"date":{"properties":["dateStat"],"periods":"YSQMD"}'
&            +'},'
&            +'"$measures":{'+Q

# Loop on measures : no comma after the last one
  Wrseq APWCB+sigma(1,[PS2]NBRFRM,'"amount'+num$(indcum)+'":{}'+string$(indcum<[PS2]NBRFRM,","))+Q

# Closes '$measures', then '$cube', then starts axes and the first axis with its hierarchies
  Wrseq APWCB+'}},'+'"$axes":[{"$title":"'+Q+"+"+HIERARCHY(1)+"+"+Q+'","$hierarchies":['+Q

# Loop on hierarchies
  For I=1 To K
      Wrseq APWCB+'["'+HIERNAME(I)+'",'+num$(I=1)+',0]'+string$(I<K,",")+Q
  Next I
  Wrseq APWCB+']},'+Q : # Closes $hierarchies and then axis #1

# Measures in axis, the close axes, then the default slicer, finally close everything
  Wrseq APWCB+'{"$title":"Measures","$hierarchies":[["$measures"]]}],'
&            +'"$slicer":{"$title":"'+HIERNAME(1)+'","$hierarchies":[["'+HIERNAME(1)+'",1,0]]}'
&            +'}}}'+Q : # Ferme { ... "$" : { ..."$resources" : { ...
  Wrseq "End"
  Wrseq
  Wrseq "#"
  Wrseq "# Miscellaneous subprograms"
  Wrseq "#"
  Wrseq
  Wrseq "# Get a translatable text and transcode backshlashes and double quotes"
  Wrseq
  Wrseq "Funprog T(LANGUE,TABLE,CLE,CHAMP,INDEX)"
  Wrseq "Value Char LANGUE(),TABLE(),CHAMP(),CLE()"
  Wrseq "Value Integer INDEX"
  Wrseq "Local Integer I,J,IM"

  Wrseq "  Read [AXX]AXX0=TABLE;CHAMP;LANGUE;CLE;string$(INDEX<>0,num$(INDEX))"
  Wrseq '  If fstat : End "" : Endif'
  Wrseq "  IM=len([AXX]TEXTE)"
  Wrseq '  J=instr(1,[AXX]TEXTE,"\")'+" : I=instr(1,[AXX]TEXTE,'"+DQ+"')"
  Wrseq "  I=min(I+(I=0)*(IM+1),J+(J=0)*(IM+1))"
  Wrseq "  While I<=IM"
  Wrseq "    If I=J"
  Wrseq "        [AXX]TEXTE=left$([AXX]TEXTE,I-1)+'\\'+right$([AXX]TEXTE,I+1)"
  Wrseq "    Else"
  Wrseq "        [AXX]TEXTE=left$([AXX]TEXTE,I-1)+'\"+DQ+"'+right$([AXX]TEXTE,I+1)"
  Wrseq "    Endif"
  Wrseq "    IM+=1"
  Wrseq "    I+=2"
  Wrseq '    J=instr(I,[AXX]TEXTE,"\") : I=instr(I,[AXX]TEXTE,'+QDQQ+")"
  Wrseq "    I=min(I+(I=0)*(IM+1),J+(J=0)*(IM+1))"
  Wrseq "  Wend"
  Wrseq "End [AXX]TEXTE"
  Wrseq
  Wrseq
  Wrseq "#"
  Wrseq "# Get the data for a statistical code"
  Wrseq "#"
  Wrseq "$GET"
  Wrseq "Local Integer IF_AXES,IF_SLICER,I,J,K,L,M,P"
  If [PS2]UPDLEV>=2
    Wrseq "Local Char CPY_FCY_FILTER(250)"
    Wrseq "Local Integer IF_COMPANY"
    Wrseq "Local Char DEF_COMPANY("+num$(GLONCPY)+")"
    If [PS2]UPDLEV=3
      Wrseq "Local Integer IF_FACILITY"
      Wrseq "Local Char DEF_FACILITY("+num$(GLONFCY)+")"
    Endif
  Endif
  Wrseq "Local Char ERRCODE(250)"
  Wrseq "Local Integer NBFLD(1.."+num$(K)+")"
  Wrseq "Local Char KEY_VALUES(40)(1..16)"
  Wrseq "Local Clbfile AXES(2),SLICER(2)"
  Wrseq "Local Clbfile FIRST_MEMBERS(3)"
  For I=1 To [PS2]NBRFLD
    Wrseq 'Local Char DEF_'+FIELDNAME(I)+'(250)'
    Wrseq "Local Integer IF_"+FIELDNAME(I)
  Next I

# Declaration of variables used for calculation
  Wrseq "Local Decimal ";
  For I=1 To NBRAMT
    Wrseq string$(I>1,", ")+"C"+num$(I);
    Wrseq string$([L]FRTFLG(I)=2,", P"+num$(I));

    If IFTOTAL
      Wrseq ", TC"+num$(I);
      Wrseq string$([L]FRTFLG(I)=2,", TP"+num$(I));
    Endif
    If IFPREVIOUS
      Wrseq ", CC"+num$(I);
      Wrseq string$([L]FRTFLG(I)=2,", PP"+num$(I));
      If IFTOTAL
        Wrseq ", TCC"+num$(I);
        Wrseq string$([L]FRTFLG(I)=2,", TPP"+num$(I));
      Endif
    Endif
  Next I

  # Including the progressive cumulated value (only for 2 types of cumulated values)
  For I=1 To [PS2]NBRFRM
    If find([PS2]CUMFRM(I-1),2,4)
        Wrseq ", CPR"+num$(I);
    Endif
  Next I

  Wrseq

  Wrseq "Local Integer DEBUT"
  Wrseq "Local Date DATBEG1,DATEND1"
  Wrseq "Local Integer IF_DATBEG1,IF_DATEND1"
  Wrseq "Local Integer NB_DIAGNOSES"
  Wrseq "Local Char DIAGNOSES(250)(1..)"
  If IFPREVIOUS
    Wrseq "Local Date DATBEG2,DATEND2"
    Wrseq "Local Integer IF_DATBEG2,IF_DATEND2"
  Endif
  Wrseq
  For I=1 To K
    Wrseq "  NBFLD("+num$(I)+")="+num$(NBFLD(I))
  Next I
  Wrseq "  WCLOB='{'"
  Wrseq
  Wrseq "# Analyze axes and slicers"
  Wrseq "  For I=1 To MAXTAB(ARCV.PARAMCOD)"
  Wrseq "      Case ARCV.PARAMCOD(I)"
  Wrseq "        When '$axes'"
  Wrseq "          Call URLJS(ARCV.PARAMVAL(I),AXES,ERRCODE) From ASYRPRO"
  Wrseq "          IF_AXES=1"
  Wrseq "        When '$slicer'"
  Wrseq "          Call URLJS(ARCV.PARAMVAL(I),SLICER,ERRCODE) From ASYRPRO"
  Wrseq "          IF_SLICER=1"
  If [PS2]UPDLEV=3
    Wrseq "        When 'FACILITY'"
    Wrseq "          DEF_FACILITY=ARCV.PARAMVAL(I)"
    Wrseq "          IF_FACILITY=1"
  Endif
  If [PS2]UPDLEV>=2
    Wrseq "      When 'COMPANY'"
    Wrseq "          DEF_COMPANY=ARCV.PARAMVAL(I)"
    Wrseq "          IF_COMPANY=1"
  Endif
  For I=1 To [PS2]NBRFLD
    Wrseq "      When '"+FIELDNAME(I)+"'"
    Wrseq "          DEF_"+FIELDNAME(I)+"=ARCV.PARAMVAL(I)"
    Wrseq "          IF_"+FIELDNAME(I)+"=1"
  Next I
  Wrseq "      When 'DATBEG1'"
  Wrseq "          DATBEG1=func DATVAL(ARCV.PARAMVAL(I))"
  Wrseq "          IF_DATBEG1=1"
  Wrseq "      When 'DATEND1'"
  Wrseq "          DATEND1=func DATVAL(ARCV.PARAMVAL(I))"
  Wrseq "          IF_DATEND1=1"
  If IFPREVIOUS
    Wrseq "      When 'DATBEG2'"
    Wrseq "          DATBEG2=func DATVAL(ARCV.PARAMVAL(I))"
    Wrseq "          IF_DATBEG2=1"
    Wrseq "      When 'DATEND2'"
    Wrseq "          DATEND2=func DATVAL(ARCV.PARAMVAL(I))"
    Wrseq "          IF_DATEND2=1"
  Endif
  Wrseq "      Endcase"
  Wrseq "  Next I"
  Wrseq
  Wrseq "# Default values for dates if not given, with consistency control"
  Wrseq "  If IF_DATBEG1=0"
  Wrseq "    DATBEG1=gdat$(Func AFNC.PARAMUTIL('DATSTADEB','',''))"
  Wrseq "    NB_DIAGNOSES+=1"
  Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Default start date used: '+format$('D:YYYY[-]MM[-]DD',DATBEG1)"
  Wrseq "  Endif"
  Wrseq "  If IF_DATEND1=0"
  Wrseq "    DATEND1=gdat$(Func AFNC.PARAMUTIL('DATSTAFIN','',''))"
  Wrseq "    NB_DIAGNOSES+=1"
  Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Default end date used: '+format$('D:YYYY[-]MM[-]DD',DATEND1)"
  Wrseq "  Endif"
  Wrseq "  If DATBEG1=[0/0/0]"
  Wrseq "    If DATEND1=[0/0/0]"
  Wrseq "      DATBEG1=gdat$(1,1,year(date$))"
  Wrseq "      DATEND1=gdat$(31,12,year(date$))"
  Wrseq "      NB_DIAGNOSES+=1"
  Wrseq "      DIAGNOSES(NB_DIAGNOSES)='Period set by default from '+format$('D:YYYY[-]MM[-]DD',DATBEG1)+' to '+format$('D:YYYY[-]MM[-]DD',DATEND1)"
  Wrseq "    Else"
  Wrseq "      DATEND1=Func DATEN(DATEND1,"+num$([PS2]PERTYP)+")"
  Wrseq "      DATBEG1=Func DATBG(DATEND1,"+num$([PS2]PERTYP)+")"
  Wrseq "      NB_DIAGNOSES+=1"
  Wrseq "      DIAGNOSES(NB_DIAGNOSES)='Start date set by default to '+format$('D:YYYY[-]MM[-]DD',DATBEG1)"
  Wrseq "    Endif"
  Wrseq "  Else"
  Wrseq "    DATBEG1=Func DATBG(DATBEG1,"+num$([PS2]PERTYP)+")"
  Wrseq "    If DATEND1=[0/0/0]"
  Wrseq "      DATEND1=Func DATEN(DATBEG1,"+num$([PS2]PERTYP)+")"
  Wrseq "      NB_DIAGNOSES+=1"
  Wrseq "      DIAGNOSES(NB_DIAGNOSES)='End date set by default to '+format$('D:YYYY[-]MM[-]DD',DATEND1)"
  Wrseq "    Else"
  Wrseq "      DATEND1=Func DATEN(DATEND1,"+num$([PS2]PERTYP)+")"
  Wrseq "    Endif"
  Wrseq "  Endif"
  Wrseq
  If IFPREVIOUS
    Wrseq "# Consistency rules : the second period must be before the first period"
    Wrseq "  If IF_DATBEG2=0 or DATBEG2>DATBEG1"
    Wrseq "    Call ADC("+num$([PS2]PERTYP)+",DATBEG1,DATBEG2,Func DCL(DATBEG1,DATEND1+1,"+num$([PS2]PERTYP)+"))"
    Wrseq "    DATBEG2=Func DATBG(DATBEG2,"+num$([PS2]PERTYP)+")"
    Wrseq "    DATEND2=DATBEG1-1"
    Wrseq "    NB_DIAGNOSES+=1"
    Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Previous period set by default from '+format$('D:YYYY[-]MM[-]DD',DATBEG2)+' to '+format$('D:YYYY[-]MM[-]DD',DATEND2)"
    Wrseq "  Elsif IF_DATEND2=0 or DATEND2<DATBEG2"
    Wrseq "    DATEND2=DATBEG1-1"
    Wrseq "    NB_DIAGNOSES+=1"
    Wrseq "    DIAGNOSES(NB_DIAGNOSES)='End of previous period set by default to '+format$('D:YYYY[-]MM[-]DD',DATEND2)"
    Wrseq "  Endif"
    Wrseq
  Endif
  Wrseq "# JSON analysis to find out the level (variable L)"
  Wrseq " If IF_AXES=0"
  Wrseq "    L=1"
  Wrseq " Else"
  Wrseq "    K=0"
  Wrseq "    L=0"
  Wrseq "    M=1"
  Wrseq "    P0=0 : P1=0"
  Wrseq "    I=instr(1,AXES,'"+'"$hierarchies"'+"')"
  Wrseq "    If I=0 : Return : Endif : # Error found"
  Wrseq "    J=instr(I,AXES,'[')"
  Wrseq "    If J=0 : Return : Endif : # Error found"
  Wrseq "    While P0=0 and I<>0"
  Wrseq "        I=instr(J+1,AXES,'[')"
  Wrseq "        Break (I=0)"
  Wrseq "        I=instr(I+1,AXES,'"+DQ+"')"
  Wrseq "        Break (I=0)"
  Wrseq "        I=instr(I+1,AXES,'"+DQ+"')"
  Wrseq '        While I>1 and mid$(AXES,I-1,1)="\"'
  Wrseq "            I=instr(I+1,AXES,'"+DQ+"')"
  Wrseq "        Wend"
  Wrseq "        Break (I=0)"
  Wrseq "        I=instr(I+1,AXES,',')"
  Wrseq "        Break (I=0)"
  Wrseq "        J=instr(I+1,AXES,',') : K=instr(I+1,AXES,']')"
  Wrseq "        If J=0"
  Wrseq "            J=K : P1=0"
  Wrseq "        Elsif J<K"
  Wrseq "            P1=val(mid$(AXES,J+1,K-J-1))"
  Wrseq "        Else"
  Wrseq "            J=min(J,K)"
  Wrseq "            P1=0"
  Wrseq "        Endif"
  Wrseq "        P0=val(mid$(AXES,I+1,J-I-1))"
  Wrseq "        Break (J=0)"
  Wrseq "        If P0=0"
  Wrseq "            I=instr(J,AXES,'[')"
  Wrseq "            L+=NBFLD(M)"
  Wrseq "            M+=1"
  Wrseq "        Else"
  Wrseq "            L+=P0+P1"
  Wrseq "        Endif"
  Wrseq "    Wend"
  Wrseq
  Wrseq "    I=instr(1,AXES,'"+DQ+"$members"+DQ+"')"
  Wrseq "    If I"
  Wrseq "        K=0"
  Wrseq "        I+=len('"+DQ+"$members"+DQ+"')"
  Wrseq "        While K<=L-1"
  Wrseq "            J=instr(I+1,AXES,'"+DQ+"')+1"
  Wrseq "            I=instr(J,AXES,'"+DQ+"')"
  Wrseq "            Break (I=0) or (J=1)"
  Wrseq "            KEY_VALUES(K+1)=mid$(AXES,J,I-J)"
  Wrseq "            K+=1"
  Wrseq "        Wend"
  Wrseq "    Endif"
  Wrseq "  Endif"
  Wrseq
  Wrseq "# Prepare the header in order to define the criteria hidden and visible"
  Wrseq "  APPEND WCLOB,'"+DQ+'$":{"$resources":{"$item":{"$properties":{'+Q
  For I=1 To [PS2]NBRFLD
  Wrseq "  APPEND WCLOB,'"+string$(I>1,',')+'"'+FIELDNAME(I)+'":{"$isHidden":'+Q+"+string$(L="+num$(I)+',"false")'
&                      +"+string$(L<>"+num$(I)+',"true")+"}"'
  Next I
  Wrseq "  APPEND WCLOB,'}}'"
  Wrseq "  If IF_AXES"
  Wrseq "    APPEND WCLOB,',"+DQ+'$axes":'+Q
  Wrseq "    APPEND WCLOB,AXES"
  Wrseq "  Endif"
  Wrseq "  If IF_SLICER"
  Wrseq "    APPEND WCLOB,',"+DQ+'$slicer":'+Q
  Wrseq "    APPEND WCLOB,SLICER"
  Wrseq "  Endif"
  Wrseq "  APPEND WCLOB,'}}'"
  Wrseq
  Wrseq "# Set the first members values"
  Wrseq '  FIRST_MEMBERS=""'
  Wrseq '  While 1=1'
  For I=1 To [PS2]NBRFLD
    Wrseq "    Break L="+num$(I)
    K=0
    If left$(FIELDFORM(I),2)="LA"
      K=instr(1,FIELDFORM(I),":")
      If K
        K=val(mid$(FIELDFORM(I),3,K-3))
      Else
        K=val(right$(FIELDFORM(I),3))
      Endif
    Endif
    If KEYLINK(I)<>""
        Wrseq "    APPEND FIRST_MEMBERS,'"+'{"'+KEYFLD(I)+'":"'+Q+"+func STRG(KEY_VALUES("+num$(I)+'))+'+Q+'"},'+Q
    Else
        Wrseq "    APPEND FIRST_MEMBERS,'"+DQ+FIELDNAME(I)+'":"'+Q+"+func STRG(KEY_VALUES("+num$(I)+'))+'+Q+'",'+Q
    Endif
    If K
        Wrseq "    For P=1 To len(mess(0,"+num$(K)+",1))"
        Wrseq "        Break vireblc(KEY_VALUES("+num$(I)+"),2)=vireblc(mess(P,"+num$(K)+",1),2)"
        Wrseq "    Next P"
        Wrseq "    KEY_VALUES("+num$(I)+")=num$(P)"
    Endif
  Next I
  Wrseq "    Break"
  Wrseq "  Wend"
  Wrseq
  Wrseq "# Call TRACE('Level found after analysis='+num$(L)) From ASYRCOM"
  Wrseq "# Call TRACE('Values ="+Q+"+sigma(1,L,"+DQQ+DQ+"+string$(indcum<>L,KEY_VALUES(indcum))+"+DQQ+DQ+'+string$(indcum<L-1,","))) From ASYRCOM'
  Wrseq
  If [PS2]UPDLEV=3
    Wrseq "# Company and facility filter"
    Wrseq "  If IF_COMPANY"
    Wrseq "    CPY_FCY_FILTER='CPY="+DQQ+"+DEF_COMPANY+"+QDQQ
    Wrseq "  Endif"
    Wrseq "  If IF_FACILITY"
    Wrseq "    CPY_FCY_FILTER+=string$(FCY_CPY_FILTER<>'','&')+'FCY="+DQQ+"+DEF_FACILITY+"+QDQQ
    Wrseq "  Endif"
    Wrseq "  CPY_FCY_FILTER+=string$(CPY_FCY_FILTER='','1=1')"
  Elsif [PS2]UPDLEV=2
    Wrseq "# Company filter"
    Wrseq "  If IF_COMPANY"
    Wrseq "    CPY_FCY_FILTER='CPY="+DQQ+"+DEF_COMPANY+"+QDQQ
    Wrseq "  Else"
    Wrseq "    CPY_FCY_FILTER='1=1'"
    Wrseq "  Endif"
  Endif
  Wrseq
  Wrseq "# Database access"
  Wrseq
  If IFBUDGET
    Wrseq "  If not clalev([SAT]) : Local File STAT : Endif"
    Wrseq "  If not clalev([SAP]) : Local File STATPRV : Endif"
  Endif
  Wrseq "  If not clalev([SAPT])"
  If IFBUDGET
    Wrseq "    Link [SAT] With [SAP]SAP0=[SAT]COD;[SAT]FCY;[SAT]FCY;[SAT]DAT";
    I=1
    While evalue("dim([SAT]CRI"+num$(I)+")")>0
        Wrseq ";[SAT]CRI"+num$(I);
        I+=1
    Wend
    Wrseq " As [SAPT]";
  Else
    Wrseq "  Local File STAT [SAPT]";
  Endif
  If [PS2]UPDLEV>=2
    Wrseq " Where evalue(CPY_FCY_FILTER)"
  Else
    Wrseq
  Endif
  Wrseq "  Endif"
  Wrseq

# If a total is required, a first loop must be generated
  If IFTOTAL
     Wrseq "# Compute the totals and budget totals if needed"
     Wrseq "  Raz "+sigma(1,[PS2]NBRFRM,"TC"+num$(indcum)+string$(indcum<[PS2]NBRFRM,", "));
     If IFBUDGET
       For I=1 To [PS2]NBRFRM
         If [L]FRTFLG(I)>1 : Wrseq ", TP"+num$(I); : Endif
       Next I
     Endif
     Wrseq
     Wrseq "  Case L"
     Wrseq "    When 1"
     Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG1 & DAT<=DATEND1 & CRI1<>'$$$' & CRI2='$$$'"
     For I=1 To [PS2]NBRFRM
        Wrseq "        TC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")"
        If [L]FRTFLG(I)>1
           Wrseq "        TP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")"
        Endif
     Next I
     Wrseq "      Next"

     For I=2 To [PS2]NBRFLD
       Wrseq "    When "+num$(I)
       Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG1 & DAT<=DATEND1 &";
       For J=1 To I-1
          Wrseq " CRI"+num$(J)+"=KEY_VALUES("+num$(J)+") &";
       Next J
       Wrseq " CRI"+num$(I)+"='$$$'"
       For J=1 To [PS2]NBRFRM
         Wrseq "        TC"+num$(J)+"+=[SAPT]AMT("+num$(J-1)+")"
         If [L]FRTFLG(J)>1
             Wrseq "        TP"+num$(J)+"+=[SAP]AMT("+num$(J-1)+")"
         Endif
       Next J
       Wrseq "      Next"
     Next I
     Wrseq "  Endcase"
     Wrseq
  Endif

  If IFPREVIOUS
     Wrseq "# Compute the totals and budget totals for the previous period if needed"
     Wrseq "  Raz "+sigma(1,[PS2]NBRFRM,"TCC"+num$(indcum)+string$(indcum<[PS2]NBRFRM,", "));
     For I=1 To [PS2]NBRFRM
        If [L]FRTFLG(I)>1 : Wrseq ", TPP"+num$(I); : Endif
     Next I
     Wrseq
     Wrseq "  Case L"
     Wrseq "    When 1"
     Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG2 & DAT<=DATEND2 & CRI1<>'$$$' & CRI2='$$$'"
     For I=1 To [PS2]NBRFRM
       Wrseq "        TCC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")"
       If [L]FRTFLG(I)>1
           Wrseq "        TPP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")"
       Endif
     Next I
     Wrseq "      Next"
     For I=2 To [PS2]NBRFLD
       Wrseq "    When "+num$(I)
       Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG2 & DAT<=DATEND2 &";
       For J=1 To I-1
         Wrseq " CRI"+num$(J)+"=KEY_VALUES("+num$(J)+") &";
       Next J
       Wrseq " CRI"+num$(I)+"='$$$'"
       For J=1 To [PS2]NBRFRM
         Wrseq "        TCC"+num$(J)+"+=[SAPT]AMT("+num$(J-1)+")"
         If [L]FRTFLG(J)>1
             Wrseq "        TPP"+num$(J)+"+=[SAP]AMT("+num$(J-1)+")"
         Endif
       Next J
       Wrseq "      Next"
     Next I
     Wrseq "  Endcase"
  Endif

  Wrseq
  Wrseq "# Compute the detail calculation"
  Wrseq "  Case L"
  CRIT_STA=""
  For I=1 To [PS2]NBRFLD
    Wrseq "    When "+num$(I)
    If len(CRIT_STA)>50
        Wrseq "      Filter [SAPT] Where COD='"+[PS2]COD+"'"
&             +CRIT_STA
        Wrseq "&                         & CRI"+num$(I)+"<>'$$$'"+string$(I<[PS2]NBRFLD," & CRI"+num$(I+1)+"='$$$'")
    Else
        Wrseq "      Filter [SAPT] Where COD='"+[PS2]COD+"'"
&             +" & CRI"+num$(I)+"<>'$$$'"+string$(I<[PS2]NBRFLD," & CRI"+num$(I+1)+"='$$$'")+CRIT_STA
    Endif
    CRIT_STA+=" & CRI"+num$(I)+"=KEY_VALUES("+num$(I)+")"
    Wrseq "&                  Order By Key CLE=CRI"+num$(I)
  Next I
  Wrseq "  Endcase"
  Wrseq

# Init of cumulative values
  Wrseq "  Raz DEBUT"+sigma(1,[PS2]NBRFRM,string$(find([PS2]CUMFRM(indcum-1),2,4)<>0,", CPR"+num$(indcum)))

  Wrseq
  Wrseq "# Main loop"
  If IFPREVIOUS
      Wrseq "  For [SAPT]CLE(1)  Where DAT>=min(DATBEG1,DATBEG2) and DAT<=max(DATEND1,DATEND2)"
  Else
      Wrseq "  For [SAPT]CLE(1)  Where DAT>=DATBEG1 and DAT<=DATEND1"
  Endif

  Wrseq "    Raz "+sigma(1,[PS2]NBRFRM,"C"+num$(indcum)+string$(indcum<[PS2]NBRFRM,", "));
  If IFBUDGET
      For I=1 To [PS2]NBRFRM
          If [L]FRTFLG(I)>1
              Wrseq ", P"+num$(I);
          Endif
      Next I
  Endif
  If IFPREVIOUS
      Wrseq sigma(1,[PS2]NBRFRM,", CC"+num$(indcum));
      If IFBUDGET
          For I=1 To [PS2]NBRFRM
              If [L]FRTFLG(I)>1
                  Wrseq ", PP"+num$(I);
              Endif
          Next I
      Endif
  Endif
  Wrseq

  Wrseq "    For [SAPT]CLE"
  If IFPREVIOUS
      Wrseq "      If [SAPT]DAT>=DATBEG1 & DAT<=DATEND1"
      For I=1 To [PS2]NBRFRM
          Wrseq "          C"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")"
          If [L]FRTFLG(I)>1
              Wrseq "          P"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")"
          Endif
      Next I
      Wrseq "      Elsif [SAPT]DAT>=DATBEG2 & DAT<=DATEND2"
      For I=1 To [PS2]NBRFRM
          Wrseq "          CC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")"
          If [L]FRTFLG(I)>1
              Wrseq "          PP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")"
          Endif
      Next I
      Wrseq "      Endif"
  Else
      For I=1 To [PS2]NBRFRM
          Wrseq "      CC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")"
          If [L]FRTFLG(I)>1
              Wrseq "          PP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")"
          Endif
      Next I
  Endif
  Wrseq "    Next"

  Wrseq
  Wrseq "    If DEBUT"
  Wrseq "        APPEND WCLOB,"+'",{"'
  Wrseq "    Else"
  Wrseq "        APPEND WCLOB,',"+'"$resources":[{'+Q
  Wrseq "        DEBUT=1"
  Wrseq "    Endif"
  Wrseq "    APPEND WCLOB,'"+DQ+'level":'+Q+"+num$(L)+','"
  Wrseq "    APPEND WCLOB, FIRST_MEMBERS"
  Wrseq
  Wrseq "    Case L"
  For I=1 To [PS2]NBRFLD
    Wrseq "      When "+num$(I)
    If left$(FIELDFORM(I),2)="LA"
        If KEYLINK(I)<>""
            Wrseq "         APPEND WCLOB,"+QDQQ+"+func STRG('"+FIELDNAME(I)+"')+"+QDQ+':{"lannum":"'+Q
            Wrseq "&                     +func STRG(vireblc(format$("+DQ+FIELDFORM(I)+DQ+",[SAPT]CRI"+num$(I)+"),2))+'"+DQ+"},'"
        Else
            Wrseq "         APPEND WCLOB,"+QDQQ+"+func STRG('"+FIELDNAME(I)+Q+')+'+Q+'":"'+Q
            Wrseq "&                     +func STRG(vireblc(format$("+DQ+FIELDFORM(I)+DQ+",[SAPT]CRI"+num$(I)+"),2))+'"+DQ+",'"
        Endif
    Else
        If KEYLINK(I)<>""
            Wrseq "         APPEND WCLOB,'"+DQ+"'+func STRG('"+FIELDNAME(I)+Q+')'+"+'"+':{"'+KEYFLD(I)+'":"'+Q
        Else
            Wrseq "         APPEND WCLOB,'"+DQ+"'+func STRG('"+FIELDNAME(I)+Q+")+'"+'":"'+Q
        Endif
        If FIELDFORM(I)<>""
            Wrseq "         APPEND WCLOB,func STRG(vireblc(format$('"+FIELDFORM(I)+"',[SAPT]CRI"+num$(I)+")),2)+"+QDQ
&                   +string$(KEYLINK(I)<>"","}")+","+Q
        Else
            Wrseq "         APPEND WCLOB,func STRG([SAPT]CRI"+num$(I)+")+"+QDQ+string$(KEYLINK(I)<>"","}")+","+Q
        Endif
    Endif

    Wrseq "         APPEND WCLOB,'"+'"$uuid":"'+Q+'+num$([SAPT]AUUID)+'+Q+'",'+Q
    Wrseq "         APPEND WCLOB,'"+DQ+'$title":"'+Q
    Wrseq "         APPEND WCLOB,func STRG([SAPT]DES"+num$(I)+")+"+QDQ+",'"
  Next I
  Wrseq "    Endcase"
  Wrseq
  For I=1 To [PS2]NBRFRM
    Case [PS2]CUMFRM(I-1)
        When 1 : Wrseq "    APPEND WCLOB,'"+'"amount'+num$(I)+'":'+Q+"+num$("+[PS2]AMTFRM(I-1)+")"+string$(I<[PS2]NBRFRM,'+","')
        When 2 : Wrseq "    CPR"+num$(I)+"+="+[PS2]AMTFRM(I-1)
                 Wrseq "    APPEND WCLOB,'"+'"amount'+num$(I)+'":'+Q+"+num$(CPR"+num$(I)+")"+string$(I<[PS2]NBRFRM,'+","')
        When 3 : Wrseq "    APPEND WCLOB,'"+'"amount'+num$(I)+'":'+Q+"+num$(100*(func D("+[PS2]AMTFRM(I-1)+","+func REP_FRM([PS2]AMTFRM(I-1))+")))"
&                      +string$(I<[PS2]NBRFRM,'+","')
        When 4 : Wrseq "    CPR"+num$(I)+"+="+[PS2]AMTFRM(I-1)
                 Wrseq "    APPEND WCLOB,'"+'"amount'+num$(I)+'":'+Q+"+num$(100*func D(CPR"+num$(I)+","+func REP_FRM([PS2]AMTFRM(I-1))+"))"
&                      +string$(I<[PS2]NBRFRM,'+","')
    Endcase
  Next
  Wrseq '    APPEND WCLOB,"}"+chr$(13)+chr$(10)'
  Wrseq "  Next"
  Wrseq "  If DEBUT"
  Wrseq '    APPEND WCLOB,"]"'
  Wrseq '  Endif'
  Wrseq
  Wrseq '  If NB_DIAGNOSES'
  Wrseq "    APPEND WCLOB,',"+DQ+'$diagnoses":['+Q
  Wrseq '    For I=1 to NB_DIAGNOSES'
  Wrseq '      APPEND WCLOB,'+Q+'{"severity":"warning","message":"'+Q+"+DIAGNOSES(I)+"+Q+'"}'+Q+"+string$(I<NB_DIAGNOSES,',')"
  Wrseq '    NEXT I'
  Wrseq '    APPEND WCLOB,"]"'
  Wrseq '  Endif'
  Wrseq '  APPEND WCLOB,"}"'
  Wrseq '  Return'
  Wrseq
  Wrseq '# Some libraries that have been including in order to have an autonomous program'
  Wrseq
  Wrseq '# Add the backshlash escaping character on string constants'
  Wrseq 'Funprog STRG(CHAINE)'
  Wrseq 'Value Char CHAINE'
  Wrseq 'Local Char RESULT(250)'
  Wrseq 'Local Integer POS1,POS2'
  Wrseq 'POS2=1'
  Wrseq 'POS1=instr(POS2,CHAINE,'+QDQQ+')'
  Wrseq 'While POS1<>0'
  Wrseq '    RESULT+=mid$(CHAINE,POS2,POS1-POS2)+'+Q+'\"'+Q
  Wrseq '    POS2=POS1+1'
  Wrseq '    POS1=instr(POS2,CHAINE,'+Q+'"'+Q+")"
  Wrseq 'Wend'
  Wrseq 'End RESULT+right$(CHAINE,POS2)'
  Wrseq
  Wrseq '# Divide A per B but return A if B is null'
  Wrseq 'Funprog D(A,B)'
  Wrseq 'Value Decimal A,B'
  Wrseq '  If B=0'
  Wrseq '    End A'
  Wrseq '  Endif'
  Wrseq 'End A/B'
  Wrseq
  Wrseq '# Returns the date value from a chain normalized date (null date sent if any format mismatch)'
  Wrseq 'Funprog DATVAL(C)'
  Wrseq 'Value Char C'
  Wrseq 'Local Integer IDT'
  Wrseq '  IDT=instr(1,DATVAL,"T")'
  Wrseq '  If IDT'
  Wrseq '    C=vireblc(left$(C,IDT-1),4)'
  Wrseq '  Endif'
  Wrseq '  If pat(C,"####-##-##")'
  Wrseq '    End gdat$(right$(C,9),mid$(C,6,2),left$(C,4))'
  Wrseq '  Endif'
  Wrseq ' End [0/0/0]'
  Wrseq
  Wrseq '# Compute the begin of the period'
  Wrseq 'Funprog DATBG(D,P)'
  Wrseq 'Value Date D'
  Wrseq 'Value Integer P'
  Wrseq 'Case P'
  Wrseq '  When 1 : End D'
  Wrseq '  When 2 : End D-dayn(D)+1'
  Wrseq '  When 3 : End gdat$(1+15*(day(D)>=16),month(D),year(D))'
  Wrseq '  When 4 : End gdat$(1,month(D),year(D))'
  Wrseq '  When 5 : End gdat$(1,1+int((month(D)-1)/3),year(D))'
  Wrseq '  When 6 : End gdat$(1,1,year(D))'
  Wrseq '  When 7 : End gdat$(1+10*(day(D)>=11)+10*(day(D)>=21),month(D),year(D))'
  Wrseq 'Endcase'
  Wrseq 'End [0/0/0]'
  Wrseq
  Wrseq '# Compute the end of the period'
  Wrseq 'Funprog DATEN(D,P)'
  Wrseq 'Value Date D'
  Wrseq 'Value Integer P'
  Wrseq '  Case P'
  Wrseq '    When 1 : End D'
  Wrseq '    When 2 : End D-dayn(D)+7'
  Wrseq '    When 3 : If day(D)>=16'
  Wrseq '             End eomonth(D)'
  Wrseq '           Else End gdat$(15,month(D),year(D))'
  Wrseq '           Endif'
  Wrseq '    When 4 : End eomonth(D)'
  Wrseq '    When 5 : End eomonth(gdat$(1,3+int((month(D)-1)/3),year(D)))'
  Wrseq '    When 6 : End gdat$(31,12,year(D))'
  Wrseq '    When 7 : If day(D)>=21'
  Wrseq '               End eomonth(D)'
  Wrseq '             Elsif day(D)>=11'
  Wrseq '               End gdat$(20,month(D),year(D))'
  Wrseq '             Else End gdat$(10,month(D),year(D))'
  Wrseq '             Endif'
  Wrseq '  Endcase'
  Wrseq 'End [0/0/0]'
  Wrseq
  Wrseq '# Compute the number of periods between 2 dates'
  Wrseq 'Funprog DCL(DAT1,DAT2,PERTYP)'
  Wrseq 'Value    Date    DAT1'
  Wrseq 'Value    Date    DAT2'
  Wrseq 'Value    Integer PERTYP'
  Wrseq '  Case PERTYP'
  Wrseq '    When 1 : End DAT1-DAT2'
  Wrseq '    When 2 : End (DAT1-DAT2)/7'
  Wrseq '    When 3 : End 24*(year(DAT1)-year(DAT2))+2*(month(DAT1)-month(DAT2))+(day(DAT2)<day(DAT1))-(day(DAT2)>day(DAT1))'
  Wrseq '    When 4 : End 12*(year(DAT1)-year(DAT2))+(month(DAT1)-month(DAT2))'
  Wrseq '    When 5 : End 4*(year(DAT1)-year(DAT2))+(month(DAT1)-month(DAT2))/3'
  Wrseq '    When 6 : End year(DAT1)-year(DAT2)'
  Wrseq '    When 7 : End 36*(year(DAT1)-year(DAT2))+3*(month(DAT1)-month(DAT2))'
  Wrseq '&              + min(2,int((day(DAT1)-1)/10))-min(2,int((day(DAT2)-1)/10))'
  Wrseq '  Endcase'
  Wrseq 'End 0'
  Wrseq
  Wrseq '# Shift a date by a given number of periods (positive or negative)'
  Wrseq 'Subprog ADC(PERTYP,DAT1,DAT2,DECAL)'
  Wrseq 'Value    Integer PERTYP'
  Wrseq 'Value    Date    DAT1'
  Wrseq 'Variable Date    DAT2'
  Wrseq 'Value    Integer DECAL'
  Wrseq '  Case PERTYP'
  Wrseq '    When 1 : DAT2 = DAT1+DECAL'
  Wrseq '    When 2 : DAT2 = DAT1+7*DECAL'
  Wrseq '    When 3 : DAT2 = addmonth(DAT1,fix(DECAL/2))'
  Wrseq '             If day(DAT2)>15'
  Wrseq '               DAT2 = eomonth(DAT2)'
  Wrseq '             Endif'
  Wrseq '             Case mod(DECAL,2)'
  Wrseq '               When 1'
  Wrseq '                 If day(DAT2)<16'
  Wrseq '                   DAT2 = eomonth(DAT2)'
  Wrseq '                 Else'
  Wrseq '                   DAT2 = eomonth(DAT2)+15'
  Wrseq '                 Endif'
  Wrseq '               When -1'
  Wrseq '                 If DAT2=eomonth(DAT2)'
  Wrseq '                    DAT2 = gdat$(15,month(DAT2),year(DAT2))'
  Wrseq '                 Else'
  Wrseq '                    DAT2 = eomonth(addmonth(DAT2,-1))'
  Wrseq '                 Endif'
  Wrseq '             Endcase'
  Wrseq '    When 4 : DAT2 = addmonth(DAT1,DECAL)'
  Wrseq '    When 5 : DAT2 = addmonth(DAT1,3*DECAL)'
  Wrseq '    When 6 : DAT2 = addmonth(DAT1,12*DECAL)'
  Wrseq '    When 7 : DAT2 = addmonth(DAT1,fix(DECAL/3))'
  Wrseq '             Case mod(DECAL,3)'
  Wrseq '               When 0'
  Wrseq '               When 1'
  Wrseq '                 Case day(DAT2)'
  Wrseq '                   When 10      : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))'
  Wrseq '                   When 20      : DAT2 = eomonth(DAT2)'
  Wrseq '                   When Default : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))'
  Wrseq '                 Endcase'
  Wrseq '               When -1'
  Wrseq '                 Case day(DAT2)'
  Wrseq '                   When 10      : DAT2 = eomonth(addmonth(DAT2,-1))'
  Wrseq '                   When 20      : DAT2 = gdat$(10,month(DAT2),year(DAT2))'
  Wrseq '                   When Default : DAT2 = gdat$(20,month(DAT2),year(DAT2))'
  Wrseq '                 Endcase'
  Wrseq '               When 2'
  Wrseq '                 Case day(DAT2)'
  Wrseq '                   When 10      : DAT2 = eomonth(DAT2)'
  Wrseq '                   When 20      : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))'
  Wrseq '                   When Default : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))'
  Wrseq '                 Endcase'
  Wrseq '               When -2'
  Wrseq '                 Case day(DAT2)'
  Wrseq '                   When 10      : DAT2 = gdat$(20,month(DAT2)-1,year(DAT2))'
  Wrseq '                   When 20      : DAT2 = eomonth(addmonth(DAT2,-1))'
  Wrseq '                   When Default : DAT2 = gdat$(10,month(DAT2),year(DAT2))'
  Wrseq '                 Endcase'
  Wrseq '             Endcase'
  Wrseq '  Endcase'
  Wrseq 'End'
  Openo
Return

# Replace in a formula the Ci, CCi, Pi, PPi, by Tci, TCCi, TPi, TPPi in order to get the formula to be used for total
Funprog REP_FRM(FORMU)
Value Char FORMU()
Local Integer II
Local Char CHAINE(255)
  II=1
  While II<=len(FORMU)
    If (mid$(FORMU,II,2)="CC" or mid$(FORMU,II,2)="PP") and (mid$(FORMU,II+2,1)>="1") and (mid$(FORMU,II+2,1)<="9")
        CHAINE+="T"+mid$(FORMU,II,3)
        II+=3
    Elsif (mid$(FORMU,II,1)="C" or mid$(FORMU,II,1)="P") and (mid$(FORMU,II+1,1)>="1") and (mid$(FORMU,II+1,1)<="9")
        CHAINE+="T"+mid$(FORMU,II,2)
        II+=2
    Else
        While II<=len(FORMU) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",toupper(mid$(FORMU,II,1)))<>0
            CHAINE+=mid$(FORMU,II,1)
            II+=1
        Wend
        If II<=len(FORMU)
            CHAINE+=mid$(FORMU,II,1)
            II+=1
        Endif
    Endif
  Wend
End CHAINE

Subprog GET_PAR_TYPE(CODTYP,TYPLEN,TABNUMB,CLASSCODE,REPCODE,MAINTABLE,MAINKEYFIELD,FLDLABEL,LINKEXPR,OK)
 Value Char CODTYP()
 Variable Integer TYPLEN
 Value Integer TABNUMB
 Variable Char CLASSCODE()
 Variable Char REPCODE()
 Variable Char MAINTABLE()
 Variable Char MAINKEYFIELD()
 Variable Integer FLDLABEL
 Variable Char LINKEXPR()
 Variable Integer OK

 Local Integer M,N,FOUND,NOLINK

  NOLINK=0 : # Enable the links for the moment

  If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
  If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
  If clalev([F:ATI])=0  : Local File ATABIND    [ATI]  : Endif
  If clalev([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
  If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
  If clalev([F:ADV])=0  : Local File ATABTAB    [ADV]  : Endif
  If clalev([F:ACLA])=0 : Local File ACLASSE    [ACLA] : Endif
  If clalev([F:ASW])=0  : Local File ASHW       [ASW]  : Endif

  OK=0

  Read [ATY]CODTYP=[L]CODTYP
  If fstat : OK=1 : End : Endif : # Error management has to be improved

# Find the length necessary to display the value
  If [ATY]CODTYP="M" and TABNUMB<>0
    # Modification : this is no more a link but an enumeration
    CLASSCODE="" : MAINTABLE="" : REPCODE="" : MAINKEYFIELD="" : FLDLABEL=0 : LINKEXPR=""
    OK=2
    End
    # The old previous code is still here
    M=0 : For N=1 To len(mess(0,TABNUMB,1)) : M=max(M,len(mess(N,TABNUMB,1))) : Next N
    TYPLEN=M
    If NOLINK : CLASSCODE="" : Goto NOLINK : Endif : # Added in order to disable the links
    CLASSCODE="APLSTD"
    MAINTABLE="APLSTD"
    REPCODE="APLSTD"
    MAINKEYFIELD="LANNUM"
    FLDLABEL=776 : # Message, a changer plus tard
    LINKEXPR=num$(TABNUMB)+"~{LANNUM}"
    End
  Elsif [ATY]CODTYP="ADI" and TABNUMB<>0
    Read [ADV]CODE=TABNUMB
    If fstat=0
        TYPLEN=[ADV]LNG
    Else
        TYPLEN= GLONADI
    Endif
    If NOLINK : CLASSCODE="" : Goto NOLINK : Endif : # Added in order to disable the links
    CLASSCODE="ATABDIV"
    MAINTABLE="ATABDIV"
    REPCODE="ATABDIV"
    MAINKEYFIELD="CODE"
    FLDLABEL=5096 : # Code, a changer plus tard
    LINKEXPR=num$(TABNUMB)+"~{CODE}"
    End
  Elsif [ATY]LNGTYP
    TYPLEN=[ATY]LNGTYP
  Endif

# Is there a class (Syracuse) ?
  CLASSCODE=""
  If [ATY]CODCLA<>"" and NOLINK=0 : # Added in order to disable the links
    Read [ACLA]ACLA0=[ATY]CODCLA
    If fstat=0
        CLASSCODE=[ATY]CODCLA
    Else
        OK=2
    Endif
  Endif
$NOLINK
  If CLASSCODE=""
    Raz MAINTABLE, MAINKEYFIELD, FLDLABEL, LINKEXPR, REPCODE
    End
  Endif

# Search a suitable main representation if any exists
  FOUND=0
  For [ASW] Where CODCLA=[ATY]CODCLA and TYPREP=1
    FOUND=1
    Break
  Next
  If FOUND
    REPCODE=[ASW]CODCLA
  Else
    REPCODE="" : End
  Endif

# Search the main table
  If [ACLA]TABREF<>""
    MAINTABLE=[ACLA]TABREF
  Else
    MAINTABLE="" : End
  Endif

# Get the key
  FOUND=0
  For [ATI] Where CODFIC=MAINTABLE and NUMLIG=1
    FOUND=1
    Break
  Next
  If FOUND
    # Is it a composite key ? If yes, stop (for the moment)
    If pat(vireblc([ATI]DESCRIPT,2),"?*+?*") or pat(vireblc([ATI]DESCRIPT,2),"?*-?*")
        OK=3 : End
    Endif
    Read [ATZ]CODZONE=MAINTABLE;vireblc([ATI]DESCRIPT,2)
    If fstat=0
        MAINKEYFIELD=toupper([ATZ]CODZONE)
        FLDLABEL=[ATZ]NOCOURT
        LINKEXPR="{"+MAINKEYFIELD+"}"
    Else
        OK=4
        End
    Endif
  Else
    OK=5
    End
  Endif
End

# Returns an HTML type
Funprog TYPZON(TYP,MENL)
Value Libelle TYP
Value Shortint MENL
 Case TYP
    When 1       : End string$(MENL=1,"application/x-boolean")+string$(MENL<>1,"application/x-choice")
    When 1,2,3   : End "application/x-integer"
    When 4,5,6   : End "application/x-decimal"
    When 7       : End "application/x-string"
    When 8       : End "application/x-date"
    When 10      : End "text/plain"
 Endcase
End "application/octet-stream"

$GET
Openo "/home/dbopp/trace.tra",0 Using [TRC]
Wrseq "REPRESENTATION="+REPRESENTATION Using [TRC]
Wrseq "TRT="+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1) Using [TRC]
Wrseq "PREFIX="+func PREFIX_TRT_PROTO+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1) Using [TRC]
Openo Using [TRC]
Gosub GET From =func PREFIX_TRT_PROTO+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1)

# Prepare response
ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+REPRESENTATION
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRESENTATION+"."+TYPE_REPRES
ASND.DATA     = WCLOB
Return
