# < DEBUG> ######################################################################################################
Local Char PARAM(10)(1..10)
Call GCONSULT( "RSG", "", PARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################


#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher. (Does nothing at the moment.)
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#** #############################################################################################################

$ACTION
Return



#** #############################################################################################################
#*
#*Procedure:   IMPRIME
#*
#* Purpose:    Handler for the report preprocess.
#*
#*
#* Parameters:
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#** #############################################################################################################
#*!

Subprog IMPRIME( NBPAR, PARAMETRE )
Variable Integer NBPAR
Variable Char PARAMETRE()(1..)
    Local Char     PARAM(30), PARAMR(255) # Parameter variables for GET/SETPARAM
    Local Char     REPCODE(255)           # Report code
    Local Integer  NUMREQ                 # Report data ID (for AREPORTM)
    Local Integer  DOTPOS                 # Position of the dot in the report name.
    Local Integer  GRPERRWARN             # Error/warning group for Crystal Reports
    Local Char     GRPERRWARNTXT(40)      # Error/warning group text for Crystal Reports

    # Leave if the CONSRSG/DCLVATGER2 function is not active for we need a lot of
    # data from masks [M:RSGx].
    If !clalev([M:RSG0])
        GOK = 0 # Cancel printing.
        End
    Endif

    # Get the report code from report name.
    Call GETPARAM( "__REPORT", NBPAR, PARAMETRE, PARAMR ) From ETAT
    DOTPOS = instr( 1, PARAMR, "." )
    If DOTPOS : REPCODE = left$( PARAMR, DOTPOS - 1 )  : Endif

    # Get the report ID for the selection using AREPORTM.NUMREQ.
    Call GETPARAM( "__REQUETE", NBPAR, PARAMETRE, PARAMR ) From ETAT
    NUMREQ = val(PARAMR)

    # Fill the numedt parameter.
    PARAMR = num$(NUMREQ)
    Call SETPARAM( "numedt", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the company parameter (for information on 1st page only).
    PARAMR = [M:RSG0]CPY
    Call SETPARAM( "societe", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the site parameter (for information on 1st page only).
    PARAMR =[M:RSG0]FCYLIN
    Call SETPARAM( "site", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the currency parameter(for information on 1st page only).
    PARAMR = [M:RSG0]CUR
    Call SETPARAM( "cur", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the legislation parameter.
    PARAMR =[M:RSG0]LEG
    Call SETPARAM( "leg", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the start date parameter (for information on 1st page only).
    PARAMR = [M:RSG0]DATDEB
    Call SETPARAM( "datdeb", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Fill the end date parameter (for information on 1st page only).
    PARAMR = [M:RSG0]DATFIN
    Call SETPARAM( "datfin", NBPAR, PARAMETRE, PARAMR ) From ETAT

    # Write data from grid to AREPORTM table.
    Gosub FILL_AREPORTM
End



#** #############################################################################################################
#*
#* Sub chunk:  FILL_AREPORTM
#*
#* Purpose:    Copies data from the grid in mask [M:RSG1] to the AREPORTM table for to print them.
#*
#** #############################################################################################################

$FILL_AREPORTM
    Local Integer I : I = 0
    Local Integer RBULLET(127..129) : RBULLET(127) = 2 : RBULLET(128) = 0 : RBULLET(129) = 1    # Bullet array: icon no. |-> 0..2

    If !clalev([F:ARM])  : Local File AREPORTM [ARM]  :  Endif

    Call DEBTRANS From GLOCK
    Trbegin [ARM]

    # Decide if we want grouped or detail data by the ending of the report name.
    If right$( REPCODE, len(REPCODE) - 2 ) = "VAL"
        Gosub FILL_AREPORTM_DOCUMENTS
    Else
        Gosub FILL_AREPORTM_RESULT
    Endif

    If GOK < 1
        Rollback
    Else
        Commit
    Endif
Return


$FILL_AREPORTM_RESULT
    If clalev([F:RSLG1])=0 : Local File RSLINESGER1 [RSLG1] : Endif

    Filter [RSLG1] Where USERID = func CNSRSGSTDLIB.GETUSERID() Order By Key RSLG2

    For [F:RSLG1]
        I += 1
        Raz [F:ARM]
        [F:ARM]RPTCOD = REPCODE
        [F:ARM]USR    = GUSER
        [F:ARM]CREDAT = date$
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = I
        [F:ARM]CLEMD1 = [F:RSLG1]AMTTRN
        [F:ARM]CLEA1  = [F:RSLG1]FLG
        [F:ARM]CLEA2  = [F:RSLG1]TAX
        [F:ARM]CLEA3  = [F:RSLG1]GEREECNUM
        [F:ARM]CLEA4  = [F:RSLG1]TRNTYP
        [F:ARM]CLEN3  = RBULLET( val( [F:RSLG1]FLG ) )
        Write [ARM]
        If fstat
            GOK = 0
            Break
        Endif
    Next

    Filter [RSLG1]
Return


$FILL_AREPORTM_DOCUMENTS
    If clalev([F:RSLG2])=0 : Local File RSLINESGER2 [RSLG2] : Endif

    Filter [RSLG2] Where USERID = func CNSRSGSTDLIB.GETUSERID() Order By Key RSLG3

    For [F:RSLG2]
        I += 1

        # Create error/warning group for Crystal Reports
        If [F:RSLG2]GEREECNUM = ""
            GRPERRWARN = 20
            GRPERRWARNTXT = mess(290,107,1) # "Customers without EU VAT ID"
        Elsif [F:RSLG2]VACBPR <> [F:RSLG2]VACBPRRSP
            GRPERRWARN = 30
            GRPERRWARNTXT = mess(291,107,1) # "Customers with nonmatching tax rule"
        Elsif [F:RSLG2]CAT <> 1
            GRPERRWARN = 40
            GRPERRWARNTXT = mess(292,107,1) # "Accounting documents with wrong category"
        Elsif [F:RSLG2]STA <> 2
            GRPERRWARN = 50
            GRPERRWARNTXT = mess(293,107,1) # "Accounting documents with wrong status"
# 2014-03-11 DNE MODIF INSERT
        Elsif RBULLET( val( [F:RSLG2]FLG ) ) = 2
            GRPERRWARN = 10
            GRPERRWARNTXT = mess(7,21,1)    # "Error"
        Elsif RBULLET( val( [F:RSLG2]FLG ) ) = 1
            GRPERRWARN = 90
            GRPERRWARNTXT = mess(7,21,1)    # "Warning"
# 2014-03-11 DNE MODIF END
        Else
            GRPERRWARN = 99
            GRPERRWARNTXT = mess(305,107,1) # "Correct accounting documents"
        Endif

        # Write data to AREPORTM table.
        Raz [F:ARM]
        [F:ARM]RPTCOD = REPCODE
        [F:ARM]USR    = GUSER
        [F:ARM]CREDAT = date$
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMCOP = 1
        [F:ARM]NUMLIG = I
        [F:ARM]CLEA1  = [F:RSLG2]OFFACC
        [F:ARM]CLEA2  = [F:RSLG2]TAX
        [F:ARM]CLEA3  = [F:RSLG2]GEREECNUM
        [F:ARM]CLEA4  = [F:RSLG2]TRNTYP
        [F:ARM]CLEA5  = [F:RSLG2]OFFACC
        [F:ARM]CLEA6  = [F:RSLG2]TYP
        [F:ARM]CLEA7  = [F:RSLG2]NUM
        [F:ARM]CLEA8  = [F:RSLG2]VACBPRRSP
        [F:ARM]CLEA9  = [F:RSLG2]CRY
        [F:ARM]CLEA10 = [F:RSLG2]VACBPR
        [F:ARM]CLEA11 = GRPERRWARNTXT
        [F:ARM]CLEN1  = [F:RSLG2]CAT
        [F:ARM]CLEN2  = [F:RSLG2]STA
        [F:ARM]CLEN3  = RBULLET( val( [F:RSLG2]FLG ) )
        [F:ARM]CLEMD1 = [F:RSLG2]AMTTRN
        [F:ARM]CLEMD3 = GRPERRWARN
        Write [ARM]
        If fstat
            GOK = 0
            Break
        Endif
    Next
Return
