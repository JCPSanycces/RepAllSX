#<AdxTL>@(#)12.0.0.0 $Revision$
Call GENSAI(nomap)
End

$ACTION
Case ACTION
 When "INIT" : TIT = mess(17,10702,1)
 When "EXEC" : Call GENSAI(nomap)
Endcase
Return

###########################################
## Génération écrans saisie de valeurs
###########################################
Subprog GENDOS(APPLI)
Value Char APPLI
Call GENSAI(APPLI)
End

Subprog GENSAI(APPLI)
Value Char APPLI
Local Integer FLDOS , FLSOC , FLSIT , FLSAL
FLDOS = 1 : FLSOC = 1 : FLSIT = 1 : FLSAL = 1
Goto GEN

Subprog GENDOSS(APPLI)
Value Char APPLI
Local Integer FLDOS , FLSOC , FLSIT , FLSAL
FLDOS = 1 : FLSOC = 0 : FLSIT = 0 : FLSAL = 0
Goto GEN

Subprog GENSOC(APPLI)
Value Char APPLI
Local Integer FLDOS , FLSOC , FLSIT , FLSAL
FLDOS = 0 : FLSOC = 1 : FLSIT = 0 : FLSAL = 0
Goto GEN

Subprog GENSIT(APPLI)
Value Char APPLI
Local Integer FLDOS , FLSOC , FLSIT , FLSAL
FLDOS = 0 : FLSOC = 0 : FLSIT = 1 : FLSAL = 0
Goto GEN

Subprog GENSAL(APPLI)
Value Char APPLI
Local Integer FLDOS , FLSOC , FLSIT , FLSAL
FLDOS = 0 : FLSOC = 0 : FLSIT = 0 : FLSAL = 1
Goto GEN

$GEN
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSK"     [AMK2]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKZON"  [AMZ2]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKACT"  [AMA2]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".AMSKPAR"  [AMP2]
Local File =APPLI+".ATABDIV"  [ADI]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".AMOTCLE"  [AMC2]

Local File ADOSSIER [ADS]

Local Integer I , J , K, OK
Local Integer NBCOD , TABLE , LANCUR
Local Integer DEB , FIN , REF , MAXI
Local Char    RACINE(10) , SAVLAN(5)
Local Char    CODE(3)(1..12)
Local Integer DECIM(1..12) , NBDEC
Local Char    MSKREF(10) , MSKDES(10) , ABRWEB(5) , OBJET(3)

If FLDOS : Gosub DOSSIER : Endif
If FLSIT : Gosub SITE    : Endif
If FLSOC : Gosub SOCIETE : Endif
If FLSAL : Gosub SALARIE : Endif
End

## Saisie variables dossier

$DOSSIER
OBJET  = "VFD"
MSKREF = "VLR1"
RACINE = "VFD"
TABLE  = 10334
DEB    = 1
FIN    = 12
MAXI   = 12
Gosub GENERE
Return

## Saisie variables site

$SITE
OBJET  = "VFC"
MSKREF = "VLR1"
RACINE = "VFC"
TABLE  = 10336
DEB    = 1
FIN    = 12
MAXI   = 12
Gosub GENERE
Return

## Saisie variables société

$SOCIETE
OBJET  = "VCP"
MSKREF = "VLR1"
RACINE = "VCP"
TABLE  = 10335
DEB    = 1
FIN    = 12
MAXI   = 12
Gosub GENERE
Return

## Saisie variables salarié

$SALARIE
OBJET  = "VEP"
MSKREF = "VLR2"
RACINE = "VEP"
TABLE  = 10337
DEB    = 2
FIN    = 13
MAXI   = 12
Gosub GENERE
Return

$GENERE
## Effacement des écrans
For I=DEB To FIN
 Call TR_DELMSK(RACINE+num$(I),APPLI) From MSKDIV
Next I

## Lecture table diverse

NBCOD = 0
For [ADI]CODE Where NUMTAB=TABLE & LEG=GCURLEG
 NBCOD += 1
 CODE(NBCOD)  = [F:ADI]CODE
 DECIM(NBCOD) = [F:ADI]N1
 If NBCOD>=MAXI : Break : Endif
Next
NECRAN = NBCOD

## Création des écrans
If NECRAN
 K = 0
 For I=DEB To (DEB-1)+NECRAN
  MSKDES = RACINE+num$(I)
  ABRWEB = mid$("ABCDEFGHIJKLM",I,1)+RACINE
  K += 1
  NBDEC  = DECIM(K)
  Gosub COPIE_ECRAN
  If GOK<1 : Break : Endif
 Next I
 If GOK<1 : Return : Endif

 ## Validation des écrans
 Read [ADS]DOSSIER = APPLI
 For I=DEB To (DEB-1)+NECRAN
  Call VALID(RACINE+num$(I),APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
 Next I
Else
 GMESSAGE=GCURLEG-':'-mess(139,133,1) #: Il n'y a pas d'onglet visible
 GOK=0 : Return
Endif

## Modification de la fenêtre
Gosub MAJ_WIN
If GOK<1 : Return : Endif

## Validation fenêtre
Call VALID("O"+OBJET,APPLI,1,GOK) From VALWIN
If GOK<1 : Return : Endif
Return

###############################################
$MAJ_WIN
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [AWI]
 Readlock [AWI]AWI0 = "O"+OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$AWINDOW"-"O"+OBJET : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("AWI","O"+OBJET) From GLOCK : Goto AB_TR2
 Endif
 [F:AWI]NBMSK = (DEB-1)+NECRAN
 Raz [F:AWI]NOMMSK
 For I=1 To (DEB-1)+NECRAN
  [F:AWI]NOMMSK(I-1) = RACINE+num$(I)
  [F:AWI]ROWMSK(I-1) = 5*I
  [F:AWI]FLGMSK(I-1) = 2
  If I>DEB-1
   [F:AWI]INTFOLD(I-1) = "TITFOLD("+num$(I-DEB+1)+")"
  Endif
 Next I
 If OBJET="VEP"
  Read [ACV]CODACT = "VEP"
  If !fstat & [F:ACV]FLACT=2
   [F:AWI]NOMMSK([F:AWI]NBMSK) = "VEPX"
   [F:AWI]FLGMSK([F:AWI]NBMSK) = 2
   [F:AWI]INTFOLD([F:AWI]NBMSK) = "TITFOLD("+num$([F:AWI]NBMSK)+")"
   [F:AWI]ROWMSK([F:AWI]NBMSK) = 95
   [F:AWI]NBMSK += 1
  Endif
 Endif
 Rewrite [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###############################################
$COPIE_ECRAN
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [AMK2],[AMZ2],[AMA2],[AMP2],[AMC2]
 Read [AMK]CODMSK = MSKREF
 If fstat
  GOK = 0 : Call RSTA("AMK",MSKREF) From GLOCK : Goto AB_TR1
 Endif
 [F:AMK2] = [F:AMK]
 [F:AMK2]CODMSK = MSKDES
 If I<10
  [F:AMK2]ABRMSK = MSKDES
 Else
  [F:AMK2]ABRMSK = RACINE+mid$("ABCD",I-9,1)
 Endif
 [F:AMK2]TRTSTD = "SUB"+OBJET
 [F:AMK2]TRTSPE = "SPE"+OBJET
 [F:AMK2]MDL    = 1
 Write [AMK2]
 If fstat
  GOK = 0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
 Endif
 For [AMZ]CODE Where CODMSK=MSKREF
  [F:AMZ2] = [F:AMZ]
  [F:AMZ2]CODMSK = MSKDES

  # ATTENTION il faut inserer dans AMOTCLE si n'existe pas déjà
  # 94033 : manque le pousse de ces modifs !
  Read [AMC2]AMC0=2;MSKDES;[F:AMZ]CODZON
  If fstat
    Raz [F:AMC2]
    [F:AMC2]TYPZON=2
    [F:AMC2]IDENT1=MSKDES
    [F:AMC2]IDENT2=[F:AMZ]CODZON
    [F:AMC2]MOTCLE="SAI"+[F:AMZ]CODZON
    Write [AMC2]
    If fstat
     GOK = 0 : Call FSTA("AMC2") From GLOCK : Goto AB_TR1
    Endif
  Elsif [F:AMC2]MOTCLE<>"SAI"+[F:AMZ]CODZON
    [F:AMC2]MOTCLE="SAI"+[F:AMZ]CODZON
    Rewrite [AMC2]
    If fstat
     GOK = 0 : Call FSTA("AMC2") From GLOCK : Goto AB_TR1
    Endif
  Endif
  #Finmodif

  If [F:AMZ]CODZON = "VALEUR"
   Case NBDEC
    When 0       : [F:AMZ2]CODTYP = "VL0"
    When 1       : [F:AMZ2]CODTYP = "VL1"
    When 2       : [F:AMZ2]CODTYP = "VL2"
    When 3       : [F:AMZ2]CODTYP = "VL3"
    When 4       : [F:AMZ2]CODTYP = "VL4"
    When 5       : [F:AMZ2]CODTYP = "VL5"
    When Default : [F:AMZ2]CODTYP = "VL2"
   Endcase
  Endif
  Write [AMZ2]
  If fstat
   GOK = 0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AMA] Where TYPAFF=1 & CODAFF=MSKREF
  [F:AMA2] = [F:AMA]
  [F:AMA2]CODAFF = MSKDES
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If   GOK<1 : Goto AB_TR1 : Endif
 For [AMP] Where TYPAFF=1 & CODAFF=MSKREF
  [F:AMP2] = [F:AMP]
  [F:AMP2]CODAFF = MSKDES
  # Pour gérer VEP1, VEP2 .. dans le passage du paramètre ZONE
  If [F:AMP]CODZON="TBL" & [F:AMP]CODPAR="ZONE"
#JASMI - START
#   VALPAR=left$(VALPAR,7)+num$(I)+right$(VALPAR,8)
   [F:AMP2]VALPAR=left$([F:AMP]VALPAR,7)+num$(I)+right$([F:AMP]VALPAR,8)
#JASMI - END
  Endif
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If   GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

