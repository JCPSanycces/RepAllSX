#<AdxTL>@(#)11.0.0.0 $Revision$
## Epurations comptables Version V130 (cf HISTOCPT pour la version V140)

$ACTION
Case ACTION
 When "OUVRE_EPURE"    : Gosub OUVRE
 When "FERME_EPURE"    : Gosub FERME
 When "VERF_EPURE"     : Gosub VERIF
 When "EPURE"          : Gosub EPURE
Endcase
Return


$OUVRE
Case [F:AEP]COD
 When "BALANCE" , "BALANA" , "GCOMMIT": # Balances
  If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
 When "GACCENTRY" : # Pièces comptables
  If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
  If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
  If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
  If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
  If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
  If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
Endcase
Return

$FERME
Case [F:AEP]COD
 When "GACCENTRY" , "BALANCE" , "BALANA" , "GCOMMIT" : # Pièces comptables et balances
  If clalev([F:FIY])>0 : Close Local File [FIY] : Endif
Endcase 
Return

$VERIF
Case [F:AEP]COD
 When "GACCENTRY" , "BALANCE" , "BALANA" , "GCOMMIT" : # Pièces comptables et balances
  Read [FIY]FIY0 = [F:WWW]CPY;[F:WWW]FIY
# DBA le 14/03/03 : Sugg 15007 
# Exercice complètement Fermé 
# If fstat or [F:FIY]FIYSTA<3
  If fstat or [F:FIY]FIYSTA<4
   OK = 0
  Endif
Endcase
If OK & [F:AEP]COD="GACCENTRY"
 For [DAE]DAE0 Where TYP=[F:WWW]TYP & NUM=[F:WWW]NUM
  If [F:DAE]ACC<>""
   Read [GAC]GAC0 = [F:DAE]ACC
   If [F:GAC]MTC=2
    # On n'épure pas si la pièce comporte :
    # - une ligne d'écriture non lettrée sur un compte lettrable
    # - ou une ligne d'écriture lettrée en miniscule
    # - ou une écriture lettrée avec une pièce dont la date est supérieure à la date d'épuration 
    If [F:DAE]MTC<"A" or [F:DAE]MTC>"ZZZZZ" or [F:DAE]MTCDATMAX>[M:DIA]DAT
     OK = 0
     # Si on trouve sur la pièce à conserver des lignes lettrées en majuscule et avec une date maximale
     # de lettrage inférieure ou égale à la date jusqu'à laquelle on épure, on met à 1 le champ FLGMTC  
     For [DAE2]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIG<>[F:DAE]LIN & MTC<>""
      If [F:DAE2]MTC>"A" & [F:DAE2]MTC<"ZZZZZ" & [F:DAE2]MTCDATMAX<=[M:DIA]DAT
       [F:DAE2]FLGMTC = 1
       Rewrite [DAE2]
       If fstat
        Call ECR_TRACE(mess(13,100,1)-"GACCENTRYD [DAE2]"-mess(12,107,1)-[F:DAE2]TYP-[F:DAE2]NUM-tolower(mess(3,61,1))-num$([F:DAE2]LIN),1) From GESECRAN
       Endif
      Endif
     Next
     If OK = 0 : Break : Endif  
    Endif
   Endif
  Endif
 Next
Endif
Return

$EPURE
Case [F:AEP]COD
 When "GACCENTRY": 
  # Si la pièce est à épurer, on epure ses échéances 
  # à moins que ce soit une facture
  Delete [DUD] Where TYP=[F:WWW]TYP & NUM=[F:WWW]NUM & TYPDUD<>2
  If fstat=1
   GOK = -1 : GLOCK = "$GACCDUDATE"-[F:WWW]ACCNUM : Return
  Endif
Endcase
Return



