#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIACH34 : Utilitaire de rectification LIKQTYCOE        Module Achats  #
##########################################################################
#   Achats de sous-traitance                                             #
##########################################################################

Call MAJ_UTIACH34
End

##################################
Subprog MAJ_UTIACH34
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTIACH34([L]DOSSIER)
Endif
End

##################################
Subprog EXE_UTIACH34(DOSSIER)
Value Char DOSSIER

Local Integer LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH34 : Rectification des Commandes sur EO avec données manquantes") From LECFIC
Call ECR_TRACE("UTIACH34 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

# Traitement des EO
If GMODU(6)=2 : # Module Achat actif
  Gosub TRT_POQ_EO
Endif


$FIN_UTIACH34
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
$TRT_POQ_EO

Local File =DOSSIER+".SCOHEAD"    [SCO]
Local File =DOSSIER+".SCOITM"     [SCI]
Local File =DOSSIER+".SCOMAT"     [SCM]
Local File =DOSSIER+".SCOSRV"     [SCS]
Local File =DOSSIER+".SCOTRK"     [SCK]    # FQ 79859
Local File =DOSSIER+".PORDERQ"    [POQ]    # FQ 79859 & 84500
Local File =DOSSIER+".PRECEIPTD"  [PTD]    # FQ 79859 & 84500
Local File =DOSSIER+".ORDERS"     [ORD]    # FQ 79859 & 84500

Local File =DOSSIER+".FACILITY"   [FCY]    # Issue 86974
Local File =DOSSIER+".ITMFACILIT" [ITF]
Local File =DOSSIER+".ITMMASTER"  [ITM]
Local File =DOSSIER+".ITMBPS"     [ITP]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPDLVCUST"  [BPD]

Local Mask =DOSSIER+".ORDK"       [ORDK]

Local Char     WSCONUM(GLONVCR),WBPRNUM(GLONBPR)
Local Integer  WSIMFLG, IPOQ
Local Shortint STAT : STAT=0

WSIMFLG=2
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
If WSIMFLG=2
   Call ECR_TRACE("Correction des données EO"-mess(6,115,1),0) From GESECRAN
Else
   Call ECR_TRACE("Correction des données EO",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

Trbegin [POQ]

Filter [POQ] Where VCRTYPORI=36 & LINTYP>2 & LINCLEFLG<>2 & LIKQTYCOE=0
For [POQ]
    Read [SCI]SCI0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI
    If fstat
       Call ECR_TRACE([F:POQ]POHNUM-num$([F:POQ]POPLIN)-"SCOITM Ligne manquante anomalie trouvée: EO"-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI),1) From GESECRAN
       Goto NEXT_POQ
    Endif
    Case [F:POQ]LINTYP
        When 3 :
            Read [SCS]SCS0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI;[F:POQ]VCRSEQORI
            If fstat Raz [F:SCS] Endif
            If [F:SCS]STRQTYCOD=1 # Qté proportionnelle
               [F:POQ]LIKQTYCOE=arr([F:SCS]EXTQTY/[F:SCI]EXTQTY,10^-6)
            Endif
        When 4 :
            Read [SCM]SCM0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI;[F:POQ]VCRSEQORI
            If fstat Raz [F:SCM] Endif
            If [F:SCM]LIKQTYCOD=1 # Qté proportionnelle
               [F:POQ]LIKQTYCOE=arr([F:SCM]RETQTY/[F:SCI]EXTQTY,10^-6)
            Endif
    Endcase
    If [F:POQ]LIKQTYCOE<>0
       Call ECR_TRACE([F:POQ]POHNUM-num$([F:POQ]POPLIN)-"Commande complétée surl'EO"-[F:POQ]VCRNUMORI-num$([F:POQ]VCRLINORI),-1) From GESECRAN
       [F:POQ]UPDUSR=GUSER
       [F:POQ]UPDDAT=date$
       Rewrite [F:POQ]
       IPOQ+=1
    Endif

$NEXT_POQ
Next

Filter [POQ]

If IPOQ=0
   Call ECR_TRACE("PORDERQ Aucune anomalie trouvée: LIKQTYCOE",0) From GESECRAN
Else
   Call ECR_TRACE(num$(IPOQ)-"lignes PORDERQ complétées LIKQTYCOE",0)  From GESECRAN
Endif
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

$FIN_UTIACH34_EO
Close Local File [SCO]
Close Local File [SCI]
Close Local File [SCM]
Close Local File [SCS]
Close Local File [SCK]
Close Local File [POQ]
Close Local File [PTD]
Close Local File [ORD]

Close Local File [FCY]
Close Local File [ITM]
Close Local File [ITF]
Close Local File [ITP]
Close Local File [BPR]
Close Local File [BPS]
Return

#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#----------------------------------------------------------------------#
$CHARG_PARAM
Local  Char     PARAM2(10)
If [F:ADS]MODULE(1) = 2  # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT
Endif
Call GLOBVAR(GFCY)    From WWGLOBACH
Raz GMESSAGE
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH34(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH34(APPLI)
End

#######################################################################
