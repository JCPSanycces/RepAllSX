#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AGATEWAY
$METHODS
 Case AMETHOD
  When "ASETVALTINYINT": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALTINYINT": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALSHORTINT": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALSHORTINT": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALINTEGER": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALINTEGER": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALDECIMAL": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALDECIMAL": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALCHAR": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALCHAR": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALDATE": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALDATE": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALBLBFILE": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALBLBFILE": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALCLBFILE": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALCLBFILE": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALUUIDENT": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALUUIDENT": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALDATETIME": Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALDATETIME": Gosub GETPARAMETER From ASYRGATEWAY
  When "ASETVALINST":Gosub SETPARAMETER From ASYRGATEWAY
  When "AGETVALINST":Gosub GETPARAMETER From ASYRGATEWAY
  When 'ARPC' : Gosub ARPC
 Endcase
Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
    Endcase
Endcase
Return


$OPERATIONS
Case [L]AOPERATION
Endcase
Return

$ARPC
#Local Char ASYRMODULE(250)
#If func ASYRFNC.IS_UPDATE_MONGO>0
# ASYRMODULE="etna-supervisor/lib/gateway"
# Gosub ARPC1 From ASYRGATEWAY
#Else
 Gosub ARPC2 From ASYRGATEWAY
#Endif
Return

