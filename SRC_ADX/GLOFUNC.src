################################################################################
# Cette fonction convertit une chaine de caractères en décimal, comme la fonction
# L4G val(), mais avec la possibilité d'indiquer le caractère servant de séparateur
# décimal (la fonction val() ne prend en compte que le point).
#
# Ex : MONNUM = func GLOFUNC.VAL2("123,456",",")
#
Funprog VALSEP(CHAINE, SEP)

Value Char CHAINE : # Chaine de caractère à convertir
Value Char SEP    : # Caractère séparateur décimal

Local Decimal VALRET

  If instr(1,CHAINE,SEP)
    CHAINE = left$(CHAINE,instr(1,CHAINE,SEP)-1)+"."+right$(CHAINE,instr(1,CHAINE,SEP)+1)
  Endif

End val(CHAINE)

################################################################################
# Cette fonction renvoie un texte traductible en s'appuyant sur le sous-programme
# LECTEXTRA
#
# Ex : MACHAINE = func GLOFUNC.LIRE_TEXTRA("TABCOUNTRY","CPYDES",[F:TCY]CRY,"")
#
Funprog LIRE_TEXTRA(TABLE, CHAMP, CLE1, CLE2)
Value Char TABLE    : # nom de la table
Value Char CHAMP    : # nom du champ
Value Char CLE1     : # critère 1
Value Char CLE2     : # critère 2

Local Char VALRET(255)

  Call LECTEXTRA(VALRET,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA

End VALRET

################################################################################
# Cette fonction teste l'unicité dans une variable dimensionnée, en remplacement
# de l'instruction 'uni' qui provoque des "Signal débordement adressage"
#
Funprog UNICITE(PVAR)
Value Char PVAR()(1..) : # variable dimensionnée

Local Integer N_I, N_J
Local Integer RESULT

RESULT = 0

For N_I = 1 To dim(PVAR)
  If N_I = dim(PVAR) : Break : Endif

  If PVAR(N_I) <> ""
    For N_J = N_I + 1 To dim(PVAR)
      If PVAR(N_I) = PVAR(N_J)
        RESULT = N_J
        Break 2
      Endif
    Next N_J
  Endif
Next N_I

End RESULT

################################################################################
# Cette fonction récupère les noms de machine et d'instance SQL-Server
#
Subprog SQLINST(SRVMAC, INST, ERR)
Variable Char    SRVMAC
Variable Char    INST
Variable Integer ERR

Local Char SQLREQ (250)

Onerrgo ERR_SQL

Raz SQLREQ
SQLREQ(0) = "select "
SQLREQ(0) += "CAST(SERVERPROPERTY('MachineName') AS varchar(50)),"
SQLREQ(0) += "CAST(SERVERPROPERTY('InstanceName') AS varchar(50)),"
SQLREQ(0) += "CAST(SERVERPROPERTY('Collation') AS varchar(50)),"
SQLREQ(0) += "cast(replace(@@VERSION,char(10),char(13)+char(10)) as varchar(250))"

For (Char VSRVMAC(50),Char VSRVINS(50),Char VSRVTRI(50),
&    Char VERSION(250)) From '5' Sql SQLREQ As [BXX]
    SRVMAC = [BXX]VSRVMAC
    INST   = [BXX]VSRVINS
    Break
Next
End

$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End

################################################################################
# Cette fonction construit un nom de fichier à partir d'un répertoire + nom
#
Funprog GETNOMFIC(PREP, PFIC)
Value Char PREP
Value Char PFIC

Local Char NOMFIC(255)

  If (right$(PREP,len(PREP)) <> "\") and (seg$(PREP,2,3) = ":\" or seg$(PREP,1,1) = "\")
    PREP += "\"
  Elsif right$(PREP,len(PREP)) <> "/"
    PREP += "/"
  Endif

  NOMFIC = PREP + PFIC
End NOMFIC


################################################################################ FQ59900
# Cette fonction retourne le nombre d'occurence d'une table diverse
#
Funprog GET_ADI_RWCNT(PNUMTAB)
Value Shortint PNUMTAB
Local Integer  RNUM

  If !clalev([WADI]) : Local File ATABDIV [WADI] : Endif

  Filter [WADI] Where NUMTAB=PNUMTAB
  RNUM = rowcount([WADI])
  Filter [WADI]
End RNUM

# FQ66894
#**
#* Retourne une chaine dont les caractères au rang n sont modifiés par la valeur passée en paramètre
#*
#* Exemple : SETRNGSTR("1234567890",5,"AB") renvoie "1234AB7890"
#*
#* @param PCHAINE : Chaine à modifier
#* @param PRANG   : Rang à partir duquel les caractères sont modifiés
#* @param PCHAR   : caractères mis dans la chaine au rang n
#*!
Funprog SETRNGSTR(PCHAINE,PRANG,PCHAR)
Value Char     PCHAINE
Value Shortint PRANG
Value Char     PCHAR

End  left$(PCHAINE,PRANG-1)+PCHAR+right$(PCHAINE,PRANG+len(PCHAR))

# FQ70465
#**
#* La fonction SUBSTIT1 permet de remplacer dans la chaine de caractères PCHAINE la balise $1$ par la valeur VAL1
#*
#* @param PCHAINE
#* @param VAL1
#*!
Funprog SUBSTIT1(PCHAINE, VAL1)
Value Char PCHAINE
Value Char VAL1
End func GLOFUNC.SUBSTITUTE(PCHAINE, VAL1, "", "", "", "", "", "", "", "")

#**
#* La fonction SUBSTIT2 permet de remplacer dans la chaine de caractères PCHAINE les balises $1$ et $2$
#* par les valeurs VAL1 et VAL2
#*
#* @param PCHAINE
#* @param VAL1
#* @param VAL2
#*!
Funprog SUBSTIT2(PCHAINE, VAL1, VAL2)
Value Char PCHAINE
Value Char VAL1
Value Char VAL2
End func GLOFUNC.SUBSTITUTE(PCHAINE, VAL1, VAL2, "", "", "", "", "", "", "")

#**
#* La fonction SUBSTIT3 permet de remplacer dans la chaine de caractères PCHAINE les balises $1$, $2$ et $3$
#* par les valeurs VAL1, VAL2 et VAL3
#*
#* @param PCHAINE
#* @param VAL1
#* @param VAL2
#* @param VAL3
#*!
Funprog SUBSTIT3(PCHAINE, VAL1, VAL2, VAL3)
Value Char PCHAINE
Value Char VAL1
Value Char VAL2
Value Char VAL3
End func GLOFUNC.SUBSTITUTE(PCHAINE, VAL1, VAL2, VAL3, "", "", "", "", "", "")

#**
#* La fonction SUBSTITUTE permet de remplacer dans une chaine de caractères les balises $n$ (n=1 à 9) par
#* les valeurs correspondantes passées en paramètre.
#*
#* Exemple : l'appel à
#*               func GLOFUNC.SUBSTITUTE("Le plan $1$ du bien $2$ a été mise à jour","libre 1","AAS0001","","","","","","","")
#*           renvoie
#*               "Le plan libre 1 du bien AAS0001 a été mis à jour"
#*
#* @param PCHAINE : chaine de caractères en entrée
#* @param VAL1    : chaine de caractères de remplacement 1
#* @param VAL2    : chaine de caractères de remplacement 2
#* @param VAL3    : chaine de caractères de remplacement 3
#* @param VAL4    : chaine de caractères de remplacement 4
#* @param VAL5    : chaine de caractères de remplacement 5
#* @param VAL6    : chaine de caractères de remplacement 6
#* @param VAL7    : chaine de caractères de remplacement 7
#* @param VAL8    : chaine de caractères de remplacement 8
#* @param VAL9    : chaine de caractères de remplacement 9
#*!
Funprog SUBSTITUTE(PCHAINE, VAL1, VAL2, VAL3, VAL4, VAL5, VAL6, VAL7, VAL8, VAL9)
Value Char PCHAINE
Value Char VAL1
Value Char VAL2
Value Char VAL3
Value Char VAL4
Value Char VAL5
Value Char VAL6
Value Char VAL7
Value Char VAL8
Value Char VAL9

  Local Char RCHAINE(255)

  For N = 1 To len(PCHAINE)
    If pat(mid$(PCHAINE,N,3),"$#$")
      RCHAINE += evalue("VAL"+num$(mid$(PCHAINE,N+1,1)))
      N += 2
    Else
      RCHAINE += mid$(PCHAINE,N,1)
    Endif
  Next

End RCHAINE


##  CBO 19/12/2011 tester si une date découpée en jj mm et AA est ok
# jour sous 2 chiffres
# mois sous 2 chiffres
# année sous 4 chiffres

Funprog ISDATEOK(PJJ, PMM, PAA)
Value Integer PJJ, PMM, PAA

    # sur les jours
    If PJJ < 1
        End 0
    Endif

    If PMM = 1 or PMM = 3 or PMM = 5 or PMM = 7 or PMM = 8 or PMM = 10 or PMM = 12
        If PJJ > 31
            End 0
        Endif
    Elsif PMM = 2
        If func BISSEXTILE(PAA)
            If PJJ > 29
                End 0
            Endif
        Else
            If PJJ > 28
                End 0
            Endif
        Endif
    Elsif PMM = 4 or PMM = 6 or PMM = 9 or PMM = 11
        If PJJ > 30
            End 0
        Endif
    Endif

    # sur les mois
    If PMM < 1 or PMM > 12
        End 0
    Endif
End 1

# FQ69690
#**
#* Retourne le texte numéro NUMERO de ATEXTE
#*
#* @param NUMERO
#*!
Funprog GET_ATEXTE(NUMERO)
Value Integer NUMERO
  Local Char RET(255)
  Call TEXTE(NUMERO,RET) From OBJDIV
End RET

#  CBO 19/12/2011 tester une année bissextile ?
# année sous 4 chiffres
Funprog BISSEXTILE(PANNEE)
Value Integer PANNEE

    If PANNEE = 1700 or  PANNEE = 1800 or  PANNEE = 1900 or  PANNEE = 2100 or  PANNEE = 2200
        End 0
    Endif
    If mod(PANNEE, 4) = 0
        End 1
    Endif
End 0
################################################## FQ93306
# Transformation d'un chaine de caractères
# contenant une date de la forme JJMMAAAA en
# type date
#
Subprog STRING_TO_DATE(P_CHAINE, P_DATE)
Value Char    P_CHAINE : # chaine de caractères en entrée à convertir
Variable Date P_DATE   : # date en sortie

Local Date    VALDAT
Local Integer DD , MM , YY , JOUR , MOIS , ANNEE
Local Integer I , V1 , V2 , V3

  DD = instr(1,FORMAT_DATE,"DD")
  MM = instr(1,FORMAT_DATE,"MM")
  YY = instr(1,FORMAT_DATE,"YY")
  If DD=0 or MM=0 or YY=0
   GERR = 1 : mkstat = 2 : GMESSAGE = GFMDAT4-":"-mess(149,100,1) : End : # Format incorrect
  Endif
  I = 1
  While I<=len(P_CHAINE)
   If !instr(1,"0123456789",mid$(P_CHAINE,I,1))
    P_CHAINE = left$(P_CHAINE,I-1)+right$(P_CHAINE,I+1)
   Else
    I += 1
   Endif
  Wend
  Case len(P_CHAINE)
   When 0 : # Date nulle
    JOUR  = 0
    MOIS  = 0
    ANNEE = 0
   When 4 : # Jour + mois
    If DD<MM
     JOUR = val(left$(P_CHAINE,2))
     MOIS = val(right$(P_CHAINE,3))
    Else
     MOIS = val(left$(P_CHAINE,2))
     JOUR = val(right$(P_CHAINE,3))
    Endif
    If JOUR=0 & MOIS=0
     ANNEE = 0
    Else
     ANNEE = year(date$)
    Endif
   When 6 : # Jour + mois + année sur 2
    V1 = val(left$(P_CHAINE,2))
    V2 = val(mid$(P_CHAINE,3,2))
    V3 = val(right$(P_CHAINE,5))
    If DD<MM
     If    YY<DD : ANNEE = V1 : JOUR  = V2 : MOIS  = V3
     Elsif YY>MM : JOUR  = V1 : MOIS  = V2 : ANNEE = V3
     Else        : JOUR  = V1 : ANNEE = V2 : MOIS  = V3
     Endif
    Else
     If    YY<MM : ANNEE = V1 : MOIS  = V2 : JOUR  = V3
     Elsif YY>DD : MOIS  = V1 : JOUR  = V2 : ANNEE = V3
     Else        : MOIS  = V1 : ANNEE = V2 : JOUR  = V3
     Endif
    Endif
    If ANNEE>mod(adxdcs,100)
     ANNEE += 100*int(adxdcs/100)
    Else
     ANNEE += 100*int(adxdcs/100)+100
    Endif
   When 8 : # Date complète
    If DD<MM
     If    YY<DD : V1 = 1 : V3 = 5 : V2 = 7
     Elsif YY>MM : V3 = 1 : V2 = 3 : V1 = 5
     Else        : V3 = 1 : V1 = 3 : V2 = 7
     Endif
    Else
     If    YY<MM : V1 = 1 : V2 = 5 : V3 = 7
     Elsif YY>DD : V2 = 1 : V3 = 3 : V1 = 5
     Else        : V2 = 1 : V1 = 3 : V3 = 7
     Endif
    Endif
    ANNEE = val(mid$(P_CHAINE,V1,4))
    MOIS  = val(mid$(P_CHAINE,V2,2))
    JOUR  = val(mid$(P_CHAINE,V3,2))
   When Default
    GERR = 1 : mkstat = 2 : GMESSAGE = mess(1,104,1) : End : # Date incorrecte
  Endcase
  If ANNEE=0 & JOUR=0 & MOIS=0
   P_DATE = [0/0/0]
  Elsif ANNEE<1800 or MOIS<1 or MOIS>12 or JOUR<1 or JOUR>31
   ERR = 0
   Onerrgo RIEN
   P_DATE = gdat$(P_CHAINE)
   Onerrgo
   If ERR
    GERR = 1 : mkstat = 2 : GMESSAGE = mess(1,104,1) : End : # Date incorrecte
   Endif
  Else
   P_DATE = gdat$(JOUR,MOIS,ANNEE)
  Endif
End

$RIEN
ERR = 1
Resume
