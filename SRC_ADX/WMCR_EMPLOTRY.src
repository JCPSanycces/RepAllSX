## CRUD-CLASSE ## EMPLOTRY
# 2018-11-06 07:06:18 967


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOTRY [TRY_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOTRY") From ASYRCOM : Endif
Local Instance EMPLOTRY Using C_EMPLOTRY

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOTRY") From ASYRCOM : Endif
EMPLOTRY = NewInstance C_EMPLOTRY AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [TRY_]TRY0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOTRY") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.AREAD([TRY_]REFNUM,[TRY_]NUMLIG))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOTRY.REFNUM ="-num$(EMPLOTRY.REFNUM)) From ASYRCOM
 Call TRACE("EMPLOTRY.NUMLIG ="-num$(EMPLOTRY.NUMLIG)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOTRY.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOTRY.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [TRY_]
FreeGroup EMPLOTRY
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOTRY,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File EMPLOTRY [TRY]
Default File [F:TRY]
Read [F:TRY]TRY0 = [L]_REFNUM;[L]_NUMLIG
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:TRY]UPDTICK)>0
 [L]_ETAG = num$([F:TRY]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOTRY,ACLE,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.AREAD([L]_REFNUM,[L]_NUMLIG))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOTRY,_REFNUM,_NUMLIG,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Value Char _REFNUM
Value Shortint _NUMLIG
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOTRY
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOTRY.APARENT=null
 [L]A_I = EMPLOTRY.freeSnapshot
 EMPLOTRY.snapshotEnabled = 0
 EMPLOTRY.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOTRY.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOTRY.APARENT=null
 EMPLOTRY.snapshotEnabled = 1
 EMPLOTRY.setAccessorEnabled = 1
Endif
LogicClose File [TRY]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_NUMLIG))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:TRY]
Read [F:TRY]TRY0 = [L]_REFNUM;[L]_NUMLIG
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+num$([L]_NUMLIG)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOTRY,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:TRY]AUUID)>0 & [F:TRY]AUUID=NullUuid
 [F:TRY]AUUID = getUuid
Endif
SetInstance EMPLOTRY With [F:TRY]
EMPLOTRY.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



