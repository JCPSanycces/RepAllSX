#<AdxTL>@(#)5.0.0.0 $Revision$
#       Analysis of the workload on a solution

#     USERANALYS       :   Analyze the workload and keep a xls summary
#     VISUANL          :   Open the summary excel file 
#     READANALYS       :   Load in a trace the xls file
#     DELANL           :   Delete the files used to enable a restart from scratch

Call VISUANL From ANALYSCOMP  : #  0 sans trace ; 1 avec trace
End
# ------------------------------------------------------------------------------------
Subprog USERANALYS(ISTRACE)
Value Integer ISTRACE

Local Char SID(12), SCLI(80), SUSR(30), SSER(10), SDOS(10), SCPU(10) , VALL1(200)
Local Integer I,NBSES
Local Char TDOS(10)(1..1000)
Local Char TSID(12)(1..1000)
Local Integer TCPU(1..1000)
Local Integer TTYPS(1..1000)
Local Char TX3USR(30)(1..1000)
Local Integer TTIM   : TTIM=time
If ISTRACE=1 : Call OUVRE_TRACE("Computer charge analysis") From LECFIC : Endif

Local File (SID,SCLI,SDOS,SCPU,SUSR,SSER) From System adxmac(0)+"@psadx -t -g -f -z" As [SYS_]
NBSES = 0
For [SYS_]
  If val([F:SYS_]SID)>0 and val([F:SYS_]SSER)>0
    NBSES += 1
    TDOS(NBSES)=[F:SYS_]SDOS
    TTYPS(NBSES)=val([F:SYS_]SSER)
    TX3USR(NBSES)=[F:SYS_]SUSR
    TSID(NBSES)=[F:SYS_]SID
    If instr(1,[F:SYS_]SCPU,":") >0
      TCPU(NBSES)=val(right$([F:SYS_]SCPU,instr(1,[F:SYS_]SCPU,":")+1))
      TCPU(NBSES)+=60*val(left$([F:SYS_]SCPU,instr(1,[F:SYS_]SCPU,":")-1))
    Else
      TCPU(NBSES)=val([F:SYS_]SCPU)
    Endif

  If ISTRACE=1
    VALL1=[F:SYS_]SDOS+";"+[F:SYS_]SSER+";"+[F:SYS_]SUSR+";"+[F:SYS_]SID+";"+[F:SYS_]SCPU+";"
    Call ECR_TRACE(VALL1,0) From GESECRAN 
  Endif

  Endif
#Infbox ":"-num$([F:SYS_]SID)-":"-num$([F:SYS_]SCLI)-":"-num$([F:SYS_]SUSR)-":"-num$([F:SYS_]SSER)-":"-num$([F:SYS_]SDOS)-":"-num$([F:SYS_]SCPU)
Next SYS_
Close Local File [SYS_]

#---------------- adxtyp ----------------------------------#
# 1       : # C/S
# 2       : # Session secondaire C/S
# 3       : # Batch
# 6       : # Eclipse
# 9,10,17 : # Session Web : Primaire/Secondaire/Futur
# 13      : # Terminal VT
# 12      : # Session Web-service
#----------------------------------------------------------#
Local Char NOMFIC(200)
Local Integer FIRSTW,P1,NBSESOLD
#ISTRACE=1
Local Char TDOSOLD(10)(1..1000)
Local Char TSIDOLD(12)(1..1000)
Local Integer TCPUOLD(1..1000)
Local Integer TTYPSOLD(1..1000),TTIMOLD
Local Char TX3USROLD(30)(1..1000)

NOMFIC = filpath("","charge","txt","X3_PUB")
Local Integer IERR
Onerrgo ERRLECF
Openi NOMFIC Using [HTO_]
Onerrgo
If IERR=1 : FIRSTW=1 : Goto SUITF : Endif

Iomode adxifs "" Using [HTO_]
Iomode adxirs chr$(10) Using [HTO_]
Iomode adxium GUTF8 Using [HTO_]
While fstat=0
  Rdseq VALL1  Using [HTO_]
  If fstat=0
   NBSESOLD+=1
   P1=instr(1,VALL1,";")
   TDOSOLD(NBSESOLD)=left$(VALL1,P1-1)
   VALL1=right$(VALL1,P1+1)

   P1=instr(1,VALL1,";")
   TTYPSOLD(NBSESOLD)=val(left$(VALL1,P1-1))
   VALL1=right$(VALL1,P1+1)

   P1=instr(1,VALL1,";")
   TX3USROLD(NBSESOLD)=left$(VALL1,P1-1)
   VALL1=right$(VALL1,P1+1)

   P1=instr(1,VALL1,";")
   TSIDOLD(NBSESOLD)=left$(VALL1,P1-1)
   VALL1=right$(VALL1,P1+1)

   P1=instr(1,VALL1,";")
   TCPUOLD(NBSESOLD)=val(left$(VALL1,P1-1))
   VALL1=right$(VALL1,P1+1)

   P1=instr(1,VALL1,";")
   TTIMOLD=val(left$(VALL1,P1-1))
  Endif
Wend
Openi Using [HTO_]


$SUITF
Openo NOMFIC,0 Using [HTO_]
Iomode adxifs "" Using [HTO_]
Iomode adxirs chr$(10) Using [HTO_]
Iomode adxium GUTF8 Using [HTO_]
For I=1 To NBSES
  VALL1=TDOS(I)+";"+num$(TTYPS(I))+";"+TX3USR(I)+";"+TSID(I)+";"+num$(TCPU(I))+";"+num$(TTIM)+";"
  Wrseq VALL1 Using [HTO_]
  If ISTRACE=1
    Call ECR_TRACE(VALL1,0) From GESECRAN 
  Endif
Next I
Openo Using [HTO_]
If FIRSTW=1 
  VALL1="Date;Time;Total sess.;Interactive Sess.;Eclipse Sess.;Active Sess;New Sess.;Diff user Inter Sess;"
  VALL1+="CPU delta Interact.;CPU delta Eclipse;CPU delta Batch;CPU delta total;delta time (sec);%use"
  Goto WRIANL
Endif

Local Char TABUSRIT(30)(1..1000)
Local Integer IFIND,DELTAT,PCTG
Local Integer NBSESINTER,NBSESECLIPS,NBSESACTIV,NBNEWSES,NBSESDIF
Local Integer TOTCPU,TOTCPUINTER,TOTCPUECLIPS,TOTCPUBATCH
For I=1 To NBSES
  If TTYPS(I)=1 or TTYPS(I)=2: NBSESINTER+=1 : Endif 
  If TTYPS(I)=6 : NBSESECLIPS+=1 : Endif 
  IFIND=find(TSID(I),TSIDOLD(1..NBSESOLD))
  If IFIND>0
    If ISTRACE=1  : Call ECR_TRACE(TSID(I)-num$(TCPUOLD(IFIND))-num$(TCPU(I)),0) From GESECRAN : Endif
    TOTCPU+=TCPU(I)-TCPUOLD(IFIND)
    If TCPU(I)>TCPUOLD(IFIND)  
      NBSESACTIV+=1 
      Case TTYPS(I)
        When 1,2  : TOTCPUINTER+=TCPU(I)-TCPUOLD(IFIND)
        When 3    : TOTCPUBATCH+=TCPU(I)-TCPUOLD(IFIND)
        When 6    : TOTCPUECLIPS+=TCPU(I)-TCPUOLD(IFIND)
      Endcase
    Endif
  Else
    NBNEWSES+=1
    TOTCPU+=TCPU(I)
    NBSESACTIV+=1
    Case TTYPS(I)
      When 1,2  : TOTCPUINTER+=TCPU(I)
      When 3    : TOTCPUBATCH+=TCPU(I)
      When 6    : TOTCPUECLIPS+=TCPU(I)
    Endcase
  Endif
  If TTYPS(I)=1 or TTYPS(I)=2 or TTYPS(I)=6
    If !find(TX3USR(I),TABUSRIT(1..NBSESDIF))
      NBSESDIF+=1 
      TABUSRIT(NBSESDIF)=TX3USR(I)
    Endif
  Endif 

Next I

#  Ecriture fichier de résultats à analyser
#  Colonne 1 : Date 
#          2 : Heure  
#          3 : Nb total de sessions (tous types)                    NBSES
#          4 : Nb de sessions interactives (type 1 et 2)            NBSESINTER
#          5 : Nb de sessions Eclipse (type 6)                      NBSESECLIPS
#          6 : Nb de sessions actives (CPU a bougé)                 NBSESACTIV
#          7 : Nb de nouvelles sessions                             NBNEWSES
#          8 : Nb de sessions (interactive + eclipse  -1,2,6-)      NBSESDIF
#              avec des utilisateurs X3 différents
#          9 : CPU delta interactif (type 1 et 2) en s              TOTCPUINTER
#         10 : CPU delta eclipse (type 6) en s                      TOTCPUECLIPS
#         11 : CPU delta batch  en s                                TOTCPUBATCH
#         12 : CPU delta (total) en s                               TOTCPU
#         13 : delta temps entre les 2 mesures  en s                DELTAT
#         14 : % d'utilisation nominale de la machine               PCTG
#              CPU delta total*100/delta temps

#          

If TTIM>TTIMOLD
  If TTIMOLD=0 and TTIM<500
    DELTAT=1
  Else
    DELTAT=TTIM-TTIMOLD
  Endif
Elsif TTIM<500
  DELTAT=TTIM+24*60*60-TTIMOLD
Else
  DELTAT=1
Endif  

If DELTAT>1
  PCTG=TOTCPU*100/DELTAT
Endif
VALL1=num$(date$)+";"+num$(time$)+";"+num$(NBSES)+";"+num$(NBSESINTER)+";"+num$(NBSESECLIPS)+";"+num$(NBSESACTIV)+";"
&     +num$(NBNEWSES)+";"+num$(NBSESDIF)+";"+num$(TOTCPUINTER)+";"+num$(TOTCPUECLIPS)+";"+num$(TOTCPUBATCH)+";"
&     +num$(TOTCPU)+";"+num$(DELTAT)+";"+num$(PCTG)
#Infbox VALL1

$WRIANL
NOMFIC = filpath("","ANALYSE_"+GINSTID,"xls","X3_PUB")
Openo NOMFIC,-1 Using [HTO_]
Iomode adxifs "" Using [HTO_]
Iomode adxirs chr$(10) Using [HTO_]
Iomode adxium GUTF8 Using [HTO_]
Wrseq VALL1 Using [HTO_]
Openo Using [HTO_]


If ISTRACE=1
  Call FERME_TRACE From LECFIC
  If GSERVEUR=0
    Call LEC_TRACE From LECFIC
  Endif
Endif
End
# ------------------------------------------------------------------------------------


$ERRLECF
IERR=1
Resume


# ------------------------------------------------------------------------------------
Subprog READANALYS

Local Char NOMFIC(200),VALL1(240)

NOMFIC = filpath("","ANALYSE_"+GINSTID,"xls","X3_PUB")

Local Integer IERR
Onerrgo ERRLECF
Openi NOMFIC Using [HTO_]
Onerrgo
If IERR=1
  Call ERREUR("File to analysis doesn't exist") From GESECRAN
  End
Endif

Iomode adxifs "" Using [HTO_]
Iomode adxirs chr$(10) Using [HTO_]
Iomode adxium GUTF8 Using [HTO_]

Call OUVRE_TRACE("Analysis"-GINSTID) From LECFIC
#VALL1="Date;Time;Total sess.;Interactive Sess.;Eclipse Sess.;Active Sess;New Sess.;Diff user Inter Sess;"
#VALL1+="CPU delta Interact.;CPU delta Eclipse;CPU delta Batch;CPU delta total;delta time (sec);%use"
#Call ECR_TRACE(VALL1,0) From GESECRAN 
While fstat=0
 Rdseq VALL1 Using  [HTO_]
 If fstat=0
   Call ECR_TRACE(VALL1,0) From GESECRAN 
 Endif
Wend
Openi Using [HTO_]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

# ------------------------------------------------------------------------------------
Subprog DELANL
Local Char NOMFIC(200)
Local Integer STAT
NOMFIC = filpath("","ANALYSE_"+GINSTID,"xls","X3_PUB")
If filinfo(NOMFIC,0)>=0
 Call EFFACE(NOMFIC,STAT) From ORDSYS
Endif
NOMFIC = filpath("","charge","txt","X3_PUB")
If filinfo(NOMFIC,0)>=0
 Call EFFACE(NOMFIC,STAT) From ORDSYS
Endif
End

# ------------------------------------------------------------------------------------
Subprog VISUANL
  Local Char URL(200),RETOUR(200)
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+"/"+"ANALYSE_"+GINSTID+".xls"
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

End
# ------------------------------------------------------------------------------------





