#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################
# Program Name: ECMSETXN (XJZSETXN)
########################################################

Subprog SE_TRANSACTION(BPCNUM,ORDNO,INVNO,SHIPNO,AMT,CVV,VANREF,TXNID,TXNTYP,TXNDAT,ACCNAM,ADDLIG0,ADDLIG1,CTY,SAT,POSCOD,CRY,EMAIL,CRDTYP,ACCL4D,CCEXP4,CCEXPIRY,PAYDES,RESPCOD,RESPMSG,VCRTYP,NICKNAME
& ,STAFLG,PRCCOD,RECNUM,CUR,PAYPRC,ONETIME,RESULT)
    Value Char BPCNUM
    Value Char ORDNO
    Value Char INVNO
    Value Char SHIPNO
    Value Decimal AMT
    Value Char CVV
    Value Char VANREF
    Value Char TXNID
    Value Char TXNTYP
    Value Char TXNDAT
    Value Char ACCNAM
    Value Char ADDLIG0
    Value Char ADDLIG1
    Value Char CTY
    Value Char SAT
    Value Char POSCOD
    Value Char CRY
    Value Char EMAIL
    Value Char CRDTYP
    Value Char ACCL4D
    Value Char CCEXP4
    Value Char CCEXPIRY
    Value Char PAYDES
    Value Char RESPCOD
    Value Char RESPMSG
    Value Integer VCRTYP
    Value Char NICKNAME
    Value Integer STAFLG
    Value Char PRCCOD
    Value Char RECNUM
    Value Char CUR
    Value Integer PAYPRC
    Value Integer ONETIME

    Variable Char RESULT : RESULT = ""
    Local Integer ERR : ERR = 0

    #Open Sage Exchange transactions
    If clalev([F:SEX]) = 0 : Local File SETXN [SEX] : Endif

    Local Char RESPID : RESPID = ""
    Local Char TRNDAT : TRNDAT = ""
    Local Integer CNTR : CNTR = 0
    Local Date DATE_TXNDAT
    Local Integer ISAUTH : ISAUTH = 0

    DATE_TXNDAT = TXNDAT

    If RECNUM = ""
        RECNUM = ORDNO
        VCRTYP = 2
        ISAUTH = 1
    Endif

    If RESPMSG <> ""
        If instr(1,RESPMSG,"APPROVED") > 0 or instr(1,RESPMSG,"SUCCESS")
            RESPID = "A"
        Endif
    Endif

    Raz [F:SEX]
  [F:SEX]TXNID = TXNID
  [F:SEX]TXNTYP = TXNTYP
  [F:SEX]REQRSP = 2   # 2 = response; request was processed by symphony site
  [F:SEX]RESP = RESPID
  [F:SEX]RSPCOD = RESPCOD
  [F:SEX]RSPMSG = RESPMSG
  [F:SEX]REF1 = ORDNO
    If INVNO = ""
      [F:SEX]REF2 = ORDNO
  Else
      [F:SEX]REF2 = INVNO
    Endif
  [F:SEX]AMT = AMT
  [F:SEX]CVV = CVV
  [F:SEX]VANREF = VANREF
  [F:SEX]TXNDATTIM = format$("DD2",DATE_TXNDAT)-time$
  [F:SEX]ACCNAM = ACCNAM
  [F:SEX]ADDLIG(0) = ADDLIG0
  [F:SEX]ADDLIG(1) = ADDLIG1  # Address 2
  [F:SEX]CTY = CTY          # City
  [F:SEX]SAT = SAT          # State
  [F:SEX]POSCOD = POSCOD      # Zip
  [F:SEX]CRY = CRY          # Country
  [F:SEX]EMAIL = EMAIL        # Email
  [F:SEX]PAYDES = PAYDES
  [F:SEX]CRDTYP = CRDTYP
  [F:SEX]BPCNUM = BPCNUM
  [F:SEX]TAXAMT = 0
  [F:SEX]EXPDAT = CCEXP4
#  [F:SEX]GUID = TXNID
  [F:SEX]PAYPRC = PAYPRC
  [F:SEX]TXNDAT = DATE_TXNDAT
  Write [F:SEX]


  If fstat = 1
    RESULT = RESULT - mess(25,7730,1)  # Error creating payment gateway transaction (" Error creating Sage Exchange transaction")
    ERR = ERR + 1
  Else
     If RECNUM <> ""
                     Gosub PROCAUTH
                 Else
         RESULT = RESULT - mess(26,7730,1)    # Receipt number not supplied (" Receipt Number not supplied")
     Endif
  Endif


  If vireblc( RESULT, 2 ) = ""
      Gosub SEBPC_DO
        Else
      RESULT = mess(27,7730,1) + ":" - RESULT    # Failure ("FAILED:")
  Endif


  If vireblc( RESULT, 2 ) = ""
      RESULT = mess(16,7730,1)   # Success
        Else
      RESULT = mess(27,7730,1) + ":" - RESULT    # Failure ("FAILED:")
  Endif

    Close Local File [SEX]
End

###########################
#Create Customer Card SEBPC
###########################
$SEBPC_DO

  Local Integer FOUND : FOUND = 0

      #Open Sage Exchange authorizations
  If clalev([F:SEB]) = 0 : Local File SEBPC [SEB] : Endif

  Read [F:SEB]SEB0=BPCNUM;NICKNAME
  If fstat
    FOUND = 0
  Else
    FOUND = 1
  Endif


  Raz [F:SEB]
  [F:SEB]BPCNUM = BPCNUM  #Customer
  [F:SEB]ACCNCKNAM = NICKNAME #Account nickname
  [F:SEB]PRCCOD = PRCCOD    #Processing code
  [F:SEB]ACCNAM = ACCNAM    #Name
  #[F:SEB]FSTNAM = ""   #First name
  #[F:SEB]LSTNAM = ""   #Last name
  [F:SEB]USEBILLADR = 0   #Billing address
  [F:SEB]ADDLIG(0) = ADDLIG0    #Address1
  [F:SEB]ADDLIG(1) = ADDLIG1    #Address2
  [F:SEB]CTY = CTY          #City
  [F:SEB]SAT = SAT          #State
  [F:SEB]POSCOD = POSCOD        #Zip
  [F:SEB]CRY = CRY          #Country
  [F:SEB]EMAIL = EMAIL          #Email
  [F:SEB]FLACT = 1    #Active flag
  [F:SEB]FLDEF = 1    #Default
  [F:SEB]CRDTYP = CRDTYP    #Card type
  [F:SEB]ACCL4D = ACCL4D    #Last four digits
  [F:SEB]EXPDAT = gdat$(1, val(left$(CCEXPIRY,2)), val(mid$(CCEXPIRY,3,2)))  #Expiration
  #[F:SEB]VLTID = ""    #Vault ID
  #[F:SEB]VLTREQ = ""   #Request
  #[F:SEB]VLTGUID = ""    #Vault GUID
  [F:SEB]ONETIME = ONETIME    #one time use card Y/N
  If FOUND = 0
    Write [F:SEB]
  Else
    Rewrite [F:SEB]
  Endif

  If fstat = 1
    RESULT = mess(20,7730,1)   # Error creating or updating payment gateway customer data ("[SEB]: Error creating/updating Sage Exchange Customer Data")
    ERR = ERR + 1
  Endif
  Close Local File [SEB]
Return

######################
# Create the auth
######################
$PROCAUTH
    #Open Sage Exchange authorizations
    If clalev([F:SEU]) = 0 : Local File SEAUTH [SEU] : Endif

    Local Char SCCEXPIRY

    SCCEXPIRY= ctrans(CCEXPIRY,"-","")

    If RECNUM = ""
  RESULT = mess(26,7730,1)    # Receipt number not supplied (" Receipt Number not supplied")
    ERR = 1
    Else
      Raz [F:SEU]
  [F:SEU]VCRNUM = ORDNO                 #Document Entry Number (string)
  [F:SEU]VCRTYP = VCRTYP                #Entry Type (int)
  [F:SEU]VCRSEQ = 1                 #Document Sequence Number (long int)
  [F:SEU]BPCNUM = BPCNUM                #Customer (string)
  [F:SEU]ACCNCKNAM = NICKNAME               #Account Nickname (string)
  [F:SEU]STAFLG = STAFLG                #Status [Local Menu 2095 (int) 3=Authorised;6=Captured]
  [F:SEU]CRDTYP = CRDTYP                #Card Type (string)
  [F:SEU]EXPDAT = gdat$(1, val(left$(CCEXPIRY,2)), val(mid$(CCEXPIRY,3,2))) #Expiration (date)
  [F:SEU]ACCL4D = ACCL4D                #Last Four Digits (string)
  [F:SEU]PRCCOD = PRCCOD                #Process Code [Miscellaneous Table 399 (string) 02=Auth;13=Capture]
  [F:SEU]VCRTYPORI = 2                #Source Document Type (int)
  [F:SEU]SOHNUM = ORDNO               #Order Number
  [F:SEU]SDHNUM = ""                #Shipment Number
  [F:SEU]SIHNUM = ""                #Invoice Number
  [F:SEU]AUTDAT = DATE_TXNDAT             #Authorization Date (date)
  [F:SEU]AUTID = RESPCOD                #Authorization Code
  [F:SEU]AUTMSG = RESPMSG                     #Authorization Message
  [F:SEU]AUTAMT = AMT               #Authorization Amount
  [F:SEU]ORIGAUTH = AMT               #Orignal Auth Amount
  [F:SEU]TAXAMT = 0               #Tax Amount
  [F:SEU]PAYDAT = DATE_TXNDAT             #Payment Date
#        If ISAUTH = 0
#      [F:SEU]PAYID = RESPCOD              #Payment Code (string 15)
#        [F:SEU]PAYAMT = AMT               #Payment Amount
#      [F:SEU]PAYNUM = RECNUM              #Payment Number (int)
#        Endif
  [F:SEU]TXNID = TXNID                #Transaction (string)
#  [F:SEU]VPSTXID = TXNID                #TransactionID (string)
  [F:SEU]VANREF = VANREF                #VAN Reference (string 20)
  [F:SEU]MANAUT = 0               #Manual Authorisation (string 4)
  [F:SEU]POSTAUT = 1                #Post (int)
  [F:SEU]CUR = CUR                #Currency (string)
#  #[F:SEU]SPSECKEY = ""               #Security Key (string 10)
#  #[F:SEU]ORIGAUTID = ""                #Authorization ID (string 15)
#  [F:SEU]ORIGTXNID= TXNID                     #Transaction ID (string 50)
#  [F:SEU]ORIGVPSTXID= TXNID             #Transaction ID (string 38)
  Write [F:SEU]


  If fstat = 1
    RESULT = mess(28,7730,1)    # Error creating payment gateway authorization ("[SEU]: Error creating Sage Exchange authorisation")
  Endif
    Endif
    Close Local File [SEU]
Return




