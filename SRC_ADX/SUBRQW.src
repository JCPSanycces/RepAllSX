#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier WARREQUEST
##########################################################################################################
Call OBJET ("RQW", GBIDC1, GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"      : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE": Gosub OUVRE_BOITE
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "LIENS"      : Gosub LIENS
    When "RAZCRE"     : Gosub RAZCRE
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "AV_ANNULE"  : Gosub AV_ANNULE
    When "ANNULE"     : Gosub ANNULE
    When "DEFLIG"     : Gosub DEFLIG
    When "LIENS_LIG"  : Gosub LIENS_LIG
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "INIMOD_LIG" : Gosub INIMOD_LIG
    When "VALLIG"     : Gosub VALLIG
    When "AVANTBOUT"  : Gosub AVANTBOUT
    When "FILTRE"     : Gosub FILTRE
    When "FILGAUCHE"  : Gosub FILGAUCHE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCRQWCPT(GLONANM)   # Code compteur pour la demande de garantie
Global Char GCRQWNUM(GLONVCR)   # N° de demande de garantie
Global Char GRQWBRACLATXT
Global Char GBOXRQW(10)
Global Char GBOXRQ2(10)

#Obtention du libellé du champ Marque
Local Char SZTXTNUM

  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(7)
  #  GCRQWCPT = [F:TCA]CODNUM(7)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  Gosub DECLARE From TABLEAUX
  #
  Call PARAML("", "MACBRAUSE", SZTXTNUM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  Call TEXTE(val(SZTXTNUM), GRQWBRACLATXT) From OBJDIV
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBRQW"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:R_QW]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [R_QW] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [RQW] With [R_QW]RQW0=[F:RQW]RQWNUM,
&                 [AFF]AFF0~=[F:RQW]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:RQW]FCY,
&                 [BPC]BPC0=[F:RQW]BPC
&              As [RQ2]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "RQW" Then
    GBOXRQW= "GAU_CHE"
  Else
    GBOXRQW = "GAU_CHE"+num$(find("RQW",OBJLIS(1..8))) : #Demandes de garantie
  Endif
  If OBJLIS(0) = "RQ2" Then
    GBOXRQ2= "GAU_CHE"
  Else
    GBOXRQ2 = "GAU_CHE"+num$(find("RQ2",OBJLIS(1..8))) : #En attente de validation
  Endif
Return

##########################################################################################################
$FERME
  Kill GCRQWCPT
  Kill GCRQWNUM
  Kill GRQWBRACLATXT
  #LSE 22/12/2005 FQ 33987
  If dim(GBOXRQW) > 0 Then
    Kill GBOXRQW
    Kill GBOXRQ2
  Endif
Return

##########################################################################################################
$SETBOUT
  Case REP
    When ""
      Call VIREBOUT(CHAINE,"H") From GOBJET
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"BU") From GOBJET
    When Default
  Endcase
  If [M:RQW0]RQWCFMFLG = 2 Then
    Call VIREBOUT(CHAINE,"U") From GOBJET
  Else
    Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCRE
  #Gestion de la navigation depuis le plan de travail Help-Desk
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FUNHDKAGD" Then
      Read [SRE]SRE0=[M:HDK0]HDKSRE
      If !fstat Then
        [M:RQW1]BPC = [F:SRE]SREBPC
        [M:RQW1]BPAADD = [F:SRE]SREBPAADD
        [M:RQW1]CCN = [F:SRE]SRECCN
        [M:RQW0]FCY = [F:SRE]SALFCY
      Endif
    Endif
  Endif
  #LSE V150 09/08/2005
  #On initialise le site
  [M:RQW0]FCY = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", [M:RQW0]FCY)
  GFCY = [M:RQW0]FCY
  Call GETDEV(GFCY) From DEVSUB
  Actzo [M:RQW0]
  Actzo [M:RQW1]
  If [M:RQW1]BPC = "" Then
    Grizo [M:RQW1]BPAADD
    Grizo [M:RQW1]CCN
  Else
    #Définit l'adresse par défaut
    If [M:RQW1]BPAADD = "" Then
      Read [BPC]BPC0=[M:RQW1]BPC
      If !fstat Then
        Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        If !fstat Then
          [M:RQW1]BPAADD = [F:BPA]BPAADD
          [M:RQW1]BPAADDCLA = [F:BPA]BPADES
        Endif
      Endif
    Endif
    #Définit l'interlocuteur par défaut de la demande
    If [M:RQW1]CCN = "" Then
      Call GETDEFCNT([M:RQW1]BPC, [M:RQW1]CCN) From CRMUTIL140
    Endif
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (début)
  If [M:RQW1]BPC <> "" Then
    Local Char SVALEUR(type([M:RQW1]BPC)-10)

    SVALEUR = [M:RQW1]BPC
    Call AM_BPC(SVALEUR) From W1RQW1
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (fin)
  [M:RQW0]RQWCFMFLG = 1
  Raz [M:RQW1]CFMDAT
  Raz [M:RQW1]CFMHOU
  Raz [M:RQW1]CFMUSR
  Raz [M:RQW1]CFMUSRCLA
  [M:RQW1]CREDAT = date$
  [M:RQW1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:RQW1]FULNAMUSR = [M:RQW1]CREUSR
  Else
    [M:RQW1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBRQWB
  Affzo [M:RQW0]1-99
  Affzo [M:RQW1]1-99
Return

##########################################################################################################
$LIENS
Local Integer INOLIGN
Local Integer INBLIG

  INOLIGN = 0
  If [M:RQW0]RQWCFMFLG = 2 Then
    Grizo [M:RQW0]FCY
    Grizo [M:RQW1]
  Else
    Actzo [M:RQW0]
    Actzo [M:RQW1]
  Endif
  [M:RQW0]LASCREMAC = ""
  #Nom du créateur de la demande
  Read [AUS]CODUSR=[M:RQW1]CREUSR
  If fstat Then
    [M:RQW1]FULNAMUSR = [M:RQW1]CREUSR
  Else
    [M:RQW1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  #Nom du valideur de la demande
  If [M:RQW1]CFMUSR = "" Then
    Raz [M:RQW1]CFMDAT
    Raz [M:RQW1]CFMHOU
    Raz [M:RQW1]CFMUSR
    Raz [M:RQW1]CFMUSRCLA
  Else
    Read [AUS]CODUSR=[M:RQW1]CFMUSR
    If fstat Then
      [M:RQW1]CFMUSRCLA = [M:RQW1]CFMUSR
    Else
      [M:RQW1]CFMUSRCLA = [F:AUS]NOMUSR
    Endif
  Endif
  #Intitulé du site d'installation
  If [M:RQW1]BPC = "" Then
    [M:RQW1]BPAADDCLA = ""
  Else
    If [M:RQW1]BPAADD = "" Then
      [M:RQW1]BPAADDCLA = ""
    Else
      Read [BPA]BPA0=1;[M:RQW1]BPC;[M:RQW1]BPAADD
      If fstat Then
        [M:RQW1]BPAADDCLA = ""
      Else
        [M:RQW1]BPAADDCLA = [F:BPA]BPADES
      Endif
    Endif
  Endif
  # Chargement des lignes dans le tableau
  Gosub LIENS From TABLEAUX
  #On grise les champs numéro de série
  For INBLIG = 0 To [M:RQW1]NBLIG-1
    If [M:RQW1]MACSERNUM(INBLIG) = "" Then
      Grizo [M:RQW1]MACSERNUM(INBLIG)
    Else
      Actzo [M:RQW1]MACSERNUM(INBLIG)
    Endif
  Next
  #Chargement de la variable pour la ligne sur le tunnel parc
  If [M:RQW1]NBLIG > 0 Then
    INOLIGN = 0
    Call RQWFILLTUNELMAC(INOLIGN)
  Else
    [M:RQW0]LASCREMAC = ""
  Endif
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBRQWB
  Affzo [M:RQW0]1-99
  Affzo [M:RQW1]1-99
Return

##########################################################################################################
$FILTRE
  Default File [RQW]
Return

##########################################################################################################
$FILGAUCHE
  Default File [RQW]
  If currbox = GBOXRQW Then
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "RQWCFMFLG = 2", "&") From GOBJSUB
  Elsif currbox = GBOXRQ2 Then
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "RQWCFMFLG <> 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "RQW") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:RQW0]FCY, 12, 7, GSOCIETE, GCURLEG, GCRQWCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", [M:RQW0]FCY, GCRQWCPT, date$, "", [M:RQW0]RQWNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:RQW]RQWNUM = [M:RQW0]RQWNUM
      Affzo [M:RQW0]RQWNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:RQW]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:RQW1]BPC = "" Then
    #Le code client est obligatoire.
    GMESSAGE = mess(78,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:RQW1]BPAADD = "" Then
    #Un site d'installation client doit être précisé.
    GMESSAGE = mess(79,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:RQW1]NBLIG < 1 Then
    #La demande de garantie doit comporter au minimum une fiche parc utilisée.
    GMESSAGE = mess(82,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Vérification de la saisie des numéros de série.
  Gosub CHECKSERNUM From SUBRQWB
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  # -- Enregistrement des lignes du tableau
  Gosub CREATION From TABLEAUX
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("RQW",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  #-------------------------------------#
  # Modification des lignes             #
  #-------------------------------------#
  Gosub MODIF From TABLEAUX
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("RQW",-1) From SUBPS2
  Call VALSTA("RQW",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
  [M:RQW1]CREHOU = [F:RQW]CREHOU
  Affzo [M:RQW0]1-99
  Affzo [M:RQW1]1-99
Return

##########################################################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
  Affzo [M:RQW0]1-99
  Affzo [M:RQW1]1-99
Return

##########################################################################################################
$AVANTBOUT
  #Bouton Validation
  If BOUT = "U" Then
    Local Integer IERRMACFLG

    Call VALIDATERQW(IERRMACFLG) From SUBRQWB
    # FGR 29/05/2008 : X3SUIVI47027 : Note pour (ma) mémoire
    #                  An ne test pas le code retour. Est-ce bien bon ?
    #                  A priori oui, parce que dans le sous-programme on positionne GERR.
    #                  Donc ICI, IERRMACFLG ne sert à priori pas.
  Endif
Return

##########################################################################################################
$AV_ANNULE
Return

##########################################################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX : # Effacement des lignes
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("RQW",-1) From SUBPS2
Return

##########################################################################################################
$DEFLIG
  #----------------------------------#
  # Définition du fichier des lignes #
  #----------------------------------#
  # Critère de lecture      (CRIT)   #
  # Nom du fichier          (FICLIG) #
  # Abréviation du fichier  (ABLIG)  #
  # Zone numéro de ligne    (ZONLIG) #
  #----------------------------------#
  Default Mask [RQW1]
  Default File [RCW]
  CRIT = 'RQWNUM="' + [M:RQW0]RQWNUM + '"'
  FICLIG = "WARREQCPN"
  ABLIG = "RCW"
  ZONLIG = "RQWNUMLIN"
Return

##########################################################################################################
$LIENS_LIG
Return

##########################################################################################################
$INICRE_LIG
  [F:RCW]RQWNUM = [M:RQW0]RQWNUM
Return

##########################################################################################################
$INIMOD_LIG
Return

##########################################################################################################
$VALLIG
Return

##########################################################################################################
Subprog C_BPAADD(VALEUR)
Variable Char    VALEUR()

  If [M:RQW1]BPC = "" Then
    #Un code client doit être indiqué pour saisir un site
    GMESSAGE = mess(76,182,1)
    GERR = 2
    mkstat = 2
  Else
    If VALEUR = "" Then
      [M:RQW1]BPAADDCLA = ""
    Else
      Read [BPA]BPA0=1;[M:RQW1]BPC;VALEUR
      If fstat Then
        #Le site d'installation indiqué est incorrect.
        GMESSAGE = mess(77,182,1)
        GERR = 2
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

  If [M:RQW1]BPC = "" Then
    [M:RQW1]BPAADDCLA = ""
  Else
    If VALEUR = "" Then
      [M:RQW1]BPAADDCLA = ""
    Else
      Read [BPA]BPA0=1;[M:RQW1]BPC;VALEUR
      If fstat Then
        [M:RQW1]BPAADDCLA = ""
      Else
        [M:RQW1]BPAADDCLA = [F:BPA]BPADES
      Endif
    Endif
  Endif
  Affzo [M:RQW1]BPAADDCLA
End

##########################################################################################################
Subprog AM_BPC(VALEUR)
Variable Char    VALEUR()

  [M:RQW1]BPAADD = ""
  [M:RQW1]BPAADDCLA = ""
  [M:RQW1]CCN = ""
  [M:RQW1]CCNCLA = ""
  If VALEUR = "" Then
    Grizo [M:RQW1]BPAADD
    Grizo [M:RQW1]CCN
  Else
    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    If !fstat Then
      [M:RQW1]BPAADD = [F:BPA]BPAADD
      [M:RQW1]BPAADDCLA = [F:BPA]BPADES
    Endif
    #Définit l'interlocuteur par défaut de la tâche
    If [M:RQW1]CCN = "" Then
      Call GETDEFCNT(VALEUR, [M:RQW1]CCN) From CRMUTIL140
    Endif
    Actzo [M:RQW1]BPAADD
    Actzo [M:RQW1]CCN
  Endif
  Gosub DISPCCN From SUBRQWB
  Affzo [M:RQW1]1-99
End

##########################################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  If [M:RQW1]QTY(nolign-1) = 0 Then
    [M:RQW1]QTY(nolign-1) = 1
  Endif
  Read [ITM]ITM0=VALEUR
  If fstat Then
    Actzo [M:RQW1]MACSERNUM(nolign-1)
  Else
    If [F:ITM]STOMGTCOD = 1 Then
      #Article non géré en stock
      Grizo [M:RQW1]MACSERNUM(nolign-1)
    Else
      #Article géré en stock
      If [F:ITM]SERMGTCOD = 1  Then
        Grizo [M:RQW1]MACSERNUM(nolign-1)
      Else
        Actzo [M:RQW1]MACSERNUM(nolign-1)
      Endif
    Endif
  Endif
  Affzo [M:RQW1]QTY(nolign-1), MACSERNUM(nolign-1)
End

##########################################################################################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 1 Then
    #La quantité doit être supérieure à zéro.
    GMESSAGE = mess(83,182,1)
    GERR = 2
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

  If [M:RQW1]MACSERNUM(nolign-1) <> "" Then
    VALEUR = 1
  Endif
  [M:RQW1]QTY(nolign-1) = VALEUR
  Affzo [M:RQW1]MACSERNUM(nolign-1), QTY(nolign-1)
End

##########################################################################################################
Subprog AM_MACSERNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    [M:RQW1]QTY(nolign-1) = 1
  Endif
  [M:RQW1]MACSERNUM(nolign-1) = VALEUR
  Affzo [M:RQW1]MACSERNUM(nolign-1), QTY(nolign-1)
End

##########################################################################################################
Subprog C_MACBPCPRI(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 0 Then
    #Le montant saisi doit être positif.
    GMESSAGE = mess(84,182,1)
    GERR = 2
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_MACBPCPRI(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    Read [BPC]BPC0=[M:RQW1]BPC
    If !fstat Then
      [M:RQW1]MACBPCCUR(nolign-1) = [F:BPC]CUR
    Endif
  Endif
  Affzo [M:RQW1]MACBPCCUR(nolign-1)
End

##########################################################################################################
Subprog IB_NBLIG

  Raz GBOUT1
  If GREP = "C" Then
    If [M:RQW1]ITMREF(nolign-1) <> "" Then
      GBOUT1 = mess(85,182,1)
    Endif
  Endif
  Call IB_NOTECHECK([M:RQW1]ITMREF(nolign-1),"ITM",3)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog C_MACSERNUM(VALEUR)
Variable Char    VALEUR()

Local Integer ISERFOUND
Local Integer ISERIN

  ISERFOUND = 0
  ISERIN = 0
  Read [ITM]ITM0=[M:RQW1]ITMREF(nolign-1)
  If !fstat Then
    If [F:ITM]STOMGTCOD = 1 Then
      #Article non géré en stock
      If VALEUR <> "" Then
        #Cet article n'est pas géré en numéro de série. Aucun numéro de série ne doit donc être saisi.
        GMESSAGE = mess(88,182,1)
        GERR = 2
        mkstat = 2
      Endif
    Else
      #Article géré en stock
      If [F:ITM]SERMGTCOD = 1 Then
        #Article non géré en numéro de série.
        If VALEUR <> "" Then
          #Cet article n'est pas géré en numéro de série. Aucun numéro de série ne doit donc être saisi.
          GMESSAGE = mess(88,182,1)
          GERR = 2
          mkstat = 2
        Endif
      Else
        #Article géré en numéro de série
        If VALEUR = "" Then
          #Cet article est géré en numéro de série. Un numéro de série doit donc être indiqué.
          GMESSAGE = mess(89,182,1)
          GERR = 2
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
  If GERR Then
    End
  Endif
  #Contrôle si le numéro de série saisi existe dans le fichier parc
  If [M:RQW1]ITMREF(nolign-1) <> "" Then
    If VALEUR <> "" Then
      Filter [MAC] Where [F:MAC]MACPDTCOD = [M:RQW1]ITMREF(nolign-1) and [F:MAC]MACSERNUM = VALEUR
      For [MAC] Hint Key MAC5
        ISERFOUND = 1
        Break
      Next
      Filter [MAC]
    Endif
  Endif
  #Contrôle si le numéro de série a été sorti du stock
  If [M:RQW1]ITMREF(nolign-1) <> "" Then
    If VALEUR <> "" Then
      Call STKCTRSERN(VALEUR,[M:RQW1]ITMREF(nolign-1),"",1,"",0,"",0,"",ISERIN) From STKACT
    Endif
  Endif
  If ISERFOUND = 0 Then
    Case ISERIN
      When 1
        #Avertissement. Ce numéro de série n'existe ni dans le fichier parc ni dans les fichiers de stocks.
        GMESSAGE = mess(42,177,1)
        GERR = 2
      When 3
        #Avertissement. Ce numéro de série n'a pas été sorti du stock et n'existe pas dans le fichier parc.
        GMESSAGE = mess(41,177,1)
        GERR = 2
      When Default
        #Avertissement. Ce numéro de série n'existe pas dans le fichier du parc client.
        GMESSAGE = mess(35,177,1)
        GERR = 2
    Endcase
  Else
    If ISERIN = 1 Then
      #Avertissement. Ce numéro de série n'existe pas dans les fichiers de stocks.
      GMESSAGE = mess(43,177,1)
      GERR = 2
    Elsif ISERIN = 3 Then
      #Avertissement. Ce numéro de série n'a pas été sorti du stock.
      GMESSAGE = mess(40,177,1)
      GERR = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CCN(VALEUR)
Variable Char    VALEUR()

  [M:RQW1]CCN = VALEUR
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBRQWB
  Affzo [M:RQW1]1-99
End

##########################################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [ITM]ITM0=VALEUR
    If !fstat Then
      If [F:ITM]HDKITMTYP > 2 Then
        Case [F:ITM]HDKITMTYP
          When 3
            #Cette référence article représente de la main d'oeuvre. Saisie refusée.
            GMESSAGE = mess(19,177,1)
            GERR = 2
            mkstat = 2
          When 4
            #Cette référence article représente des frais de mission. Saisie refusée.
            GMESSAGE = mess(20,177,1)
            GERR = 2
            mkstat = 2
          When 5
            #Cette référence article représente un contrat de service. Saisie refusée.
            GMESSAGE =  mess(21,177,1)
            GERR = 2
            mkstat = 2
        Endcase
        End
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_NBLIG
Local Integer ILIGNE

  #Effacement d'un groupe de lignes
  If status = 68 or status = 83 or status = 65 Then
    If [M:RQW0]RQWCFMFLG = 2 Then
      #La demande de garantie est validée. Suppression refusée.
      GMESSAGE = mess(177,177,1)
      GERR = 2
      mkstat = 2
      End
    Endif
  Endif
  ILIGNE = nolign-1
  Call RQWFILLTUNELMAC(ILIGNE)
End

##########################################################################################################
Subprog RQWFILLTUNELMAC(INOLIGN)
Variable Integer INOLIGN

Local Integer IMACFOUND

  MACFOUND = 0
  Filter [MAC] Where [F:MAC]MACPDTCOD = [M:RQW1]ITMREF(INOLIGN) and MACORI=5 and [F:MAC]MACORIVCR=[M:RQW0]RQWNUM and [F:MAC]MACORIVCRL = [M:RQW1]RQWNUMLIN(INOLIGN)
  For [MAC]
    IMACFOUND = 1
    Break
  Next
  Filter [MAC]
  If IMACFOUND = 1
    [M:RQW0]LASCREMAC = [F:MAC]MACNUM
  Else
    [M:RQW0]LASCREMAC = ""
  Endif
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog IB_CCN

  If [M:RQW1]BPC = "" Then
    Raz GBOUT2
  Endif
End

######################################################################################
Subprog IB_BPC
  Call IB_NOTECHECK([M:RQW1]BPC,"CRM",3)  From TRTNTSCTL # CRM notes
End
######################################################################################

