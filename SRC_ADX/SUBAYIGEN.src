#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV

Call OBJET("AYI",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend: Génération fiche Interface
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
                         #       'AYI_ACCWS'      Génération Web services liés à une interface type Accès généré
                         #       'AYI_ACCWS_Q'    Poser question pour Génération Web services liés à une interface type Accès généréValue Char DOSORG, FCYORG, TIMSTP, MODGEN
                         #       'CHK'            Vérification lien interface (non utilisé)
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
#

Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Integer CHKFLG      : CHKFLG      = find("CHK",OPTION) 
Local Integer ACCWS_FLG   : ACCWS_FLG   = find("AYI_ACCWS",OPTION)
Local Integer ACCWS_Q_FLG : ACCWS_Q_FLG = find("AYI_ACCWS_Q",OPTION)
Local Integer WS_SUBPRG_R, WS_INFOS_RET, WS_GEN_RET    # Code retour  0:Ok 1:Ko
Local Char WSTR1(250), WPUBLI_PREV(12)
Local Char U_TXTTOHEX(250),U_HEXTOTXT(250)
Local Char WS_GRP_PAR(GLONAPU), WS_GRP_WHR, WS_GRP_ORD   # Groupe des champs AXPARCOD, AXWHRCOD, AXORDCOD    
RET=1

Call TITOBJ("AYI","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 
#If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTINT    [AYI1] 
 Local File ATEXTE    [ATX1] 
 Local File AYTLINES  [AYN1] 
 Local File ATEXTRA   [AXX1]
 Local File AWEBSERVIC [AWE1]
Else 
 Local File =[L]DOSORG+".AYTINT"     [AYI1] 
 Local File =[L]DOSORG+".ATEXTE"     [ATX1] 
 Local File =[L]DOSORG+".AYTLINES"   [AYN1] 
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
 Local File =[L]DOSORG+".AWEBSERVIC"    [AWE1]
Endif 

# Initialisation Web services
Gosub WS_INI

#
Default File "[AYI1],[ATX1],[AYN1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="INT"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYI1]AYI0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(13,7910,1)-":"-[F:AYI1]INTCOD,0) From GESECRAN : Endif
 # Ajout lignes dans XML
 XT_TY="ELMT"  : XT_ID=[F:AYI1]INTCOD    
 Call LECTEXTRA(XT_VAL,"AYTINT","INTIT",[F:AYI1]FCYCOD,[F:AYI1]INTCOD) From AYTUTIA  : Gosub XMLF_ADD From AYTGEN 
 XT_TY="FLD"   : XT_ID="TYP"        : XT_VAL=num$([F:AYI1]TYP)   
                                      XT_LAB=mess([F:AYI1]TYP,7912,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="WEBSRCCOD"   : XT_VAL=[F:AYI1]WEBSRCCOD                 : Gosub XMLF_ADD From AYTGEN

 XT_TY="FLD"   : XT_ID="LNKADSDEF"  : XT_VAL=num$([F:AYI1]LNKADSDEF)
                                      XT_LAB=mess([F:AYI1]LNKADSDEF,1,1)        : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="LNKADS"     : XT_VAL=[F:AYI1]LNKADS                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="DSYINF"     : XT_VAL=num$([F:AYI1]DSYINF)
                                      XT_LAB=mess([F:AYI1]DSYINF,1,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="DSYWRN"     : XT_VAL=num$([F:AYI1]DSYWRN)
                                      XT_LAB=mess([F:AYI1]DSYWRN,1,1)           : Gosub XMLF_ADD From AYTGEN
 XT_TY="FLD"   : XT_ID="DSYERR"     : XT_VAL=num$([F:AYI1]DSYERR)
                                      XT_LAB=mess([F:AYI1]DSYERR,1,1)           : Gosub XMLF_ADD From AYTGEN
 
# modif SB ajout accès protégé
XT_TY="FLD"   : XT_ID="ACSMOD"     : XT_VAL=num$([F:AYI1]ACSMOD)
                                      XT_LAB=mess([F:AYI1]ACSMOD,1,1)           : Gosub XMLF_ADD From AYTGEN

# fin modif SB ajout accès protégé
# Optmisation
 XT_TY="TAB"   : XT_ID="OPTIMINBR"    :  XT_VAL="Optmisation"              : Gosub XMLF_ADD From AYTGEN
 For WI=0 To [F:AYI1]OPTIMINBR -1
   XT_TY="LIN"                                                             : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="OPTIMI"      : XT_VAL=num$([F:AYI1]OPTIMI(WI))
                                        XT_LAB=mess([F:AYI1]OPTIMI(WI),7933,1)  : Gosub XMLF_ADD From AYTGEN
 Next

 # Paramétres
 XT_TY="TAB"   : XT_ID="NUM40"    :  XT_VAL="Parameters"                   : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=6
&                       and LINCOD = toupper([F:AYI1]INTCOD) and  LINTYP = 40
   XT_TY="LIN"                                                             : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="PARCOD"     : XT_VAL=[F:AYN1]PARCOD                    : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F:AYN1]VALTYP) 
                                       XT_LAB=mess([F:AYN1]VALTYP,7925,1)       : Gosub XMLF_ADD From AYTGEN
   If [F:AYN1]VALTYP=1
     XT_TY="COL"  : XT_ID="VALEUR"     : XT_VAL=[F:AYN1]VALEUR                  : Gosub XMLF_ADD From AYTGEN
   Endif
 Next

 # Gestion WS lié à X3
 Gosub WS_MANAGE

 Read [AWE1]AWE1=[F:AYI1]WEBSRCCOD
 If !fstat
  Call PUBLIWS(DOSORG,[F:AYI1]WEBSRCCOD) From SUBAWE
 Endif

 If RET=0 : Break : Endif
Next
#

$FFINALLY
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN 
Gosub XMLF_CL  From AYTGEN
Close Local File [AYI1],[ATX1],[AYN1],[AXX1]
End


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#    Web service X3
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#    Initialisation
# - - - - - - - - - - - - - -
$WS_INI
# Question génération Web service
If ACCWS_Q_FLG
    ACCWS_FLG=1  
    Call OUINON(mess(129,7900,1),ACCWS_FLG) From GESECRAN
    ACCWS_FLG-=1
Endif
If ACCWS_FLG
   Call ECR_TRACE("  "-mess(72,7900,1)-[F:AYI1]INTCOD,0) From GESECRAN
Endif
# Initialisation accès Web services
Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
Return

#    Gestion Web service X3
# - - - - - - - - - - - - - -
$WS_MANAGE
#<SB modification - à faire en V5> 
 If [F:AYI1]WEBSRCCOD <> "" & find([F:AYI1]TYP,1,2,3,4,20,21)    # M2912
    Gosub WS_GEN     
    Gosub WS_INFOS
    If WS_INFOS_RET=0 or WS_GEN_RET=0
        RET=2     # Remonté sous forme d'avertissement
    Endif
 Endif
Return
#</SB modification> 

#    Obtenir les informations du Web Service X3 (demande de FD)
# - - - - - - - - - - - - - -
$WS_INFOS
WS_INFOS_RET=1

# Tableau groupe WS 
XT_TY="TAB"   : XT_ID="WS_GRP"    :  XT_VAL="Web service groups"                 : Gosub XMLF_ADD From AYTGEN
WPUBLI_PREV=""

WS_INTTYP=[F:AYI1]TYP : WS_WSRCOD=[F:AYI1]WEBSRCCOD
#Sb test génération interface...

Gosub GETWS_INF  From SUBAYIACT 
If WS_RET # Pb d'accès
    WS_INFOS_RET=0   
    If !TRADETFLG : Call ECR_TRACE(mess(13,7910,1)-[F:AYI1]INTCOD,0) From GESECRAN : Endif
    Call ECR_TRACE("  "-mess(131,7900,1)-WS_WSRCOD-":"-WS_MES,1) From GESECRAN     
    XT_TY="LIN"                                                         : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="ERROR"     : XT_VAL=WS_MES                  : Gosub XMLF_ADD From AYTGEN
    Case [F:AYI1]TYP
    When 1,4,2,20        # Accès sous-programme généré table et vue, Accès ss-prgm, Action ss-prgm 
        If !(WS_RET=2)      # Si Pb sur trt: on peux continuer
            Return
        Endif
    When Default
        Return
    Endcase
Endif
If dim([L]RUBCOD)<0 : Return : Endif
Case [F:AYI1]TYP
When 1,4,2        # Accès sous-programme généré table et vue 
                  # Accès sous-programme utilisateur

    # Indice des champs AXPARCOD, AXWHRCOD, AXORDCOD
    Raz WS_GRP_PAR, WS_GRP_WHR, WS_GRP_ORD
    WI=find("AXPARCOD",RUBCOD)
    If WI : WS_GRP_PAR=RUBGRP(WI-1) : Endif
    WI=find("AXWHRCOD",RUBCOD)
    If WI : WS_GRP_WHR=RUBGRP(WI-1) : Endif
    WI=find("AXORDCOD",RUBCOD)
    If WI : WS_GRP_ORD=RUBGRP(WI-1) : Endif

    For WI=0 To RUBNBR -1
        If WPUBLI_PREV<>RUBGRP(WI)
           XT_TY="LIN"                                                          : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPNAM"     : XT_VAL=RUBGRP(WI)                : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPSIZE"    : XT_VAL=num$(RUBDIM(WI))          : Gosub XMLF_ADD From AYTGEN
           If WS_GRP_PAR=RUBGRP(WI)
                XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDPAR"                : Gosub XMLF_ADD From AYTGEN
           Elsif WS_GRP_WHR=RUBGRP(WI)
                XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDWHR"                : Gosub XMLF_ADD From AYTGEN
           Elsif WS_GRP_ORD=RUBGRP(WI)
                XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDORD"                : Gosub XMLF_ADD From AYTGEN
           Else 
                XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDRES"                : Gosub XMLF_ADD From AYTGEN
          Endif
        Endif
        WPUBLI_PREV=RUBGRP(WI)
    Next 
    #
When 20           # Action sous-programme utilisateur

    # Indice du champ AXPARCOD
    Raz WS_GRP_PAR
    WI=find("AXPARCOD",RUBCOD)
    If WI : WS_GRP_PAR=RUBGRP(WI-1) : Endif

    For WI=0 To RUBNBR -1
        If WPUBLI_PREV<>RUBGRP(WI)
           XT_TY="LIN"                                                          : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPNAM"     : XT_VAL=RUBGRP(WI)                : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPSIZE"    : XT_VAL=num$(RUBDIM(WI))          : Gosub XMLF_ADD From AYTGEN
           If WS_GRP_PAR=RUBGRP(WI)
                XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDPAR"                : Gosub XMLF_ADD From AYTGEN
           Endif
           # Pas de GRPTYP (FD)
        Endif
        WPUBLI_PREV=RUBGRP(WI) 
    Next 
    #
When 3        # Accès liste gauche
    For WI=0 To RUBNBR-1
        If WPUBLI_PREV<>RUBGRP(WI)
           XT_TY="LIN"                                                          : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPNAM"     : XT_VAL=RUBGRP(WI)                : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPSIZE"    : XT_VAL=num$(RUBDIM(WI))          : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPTYP"     : XT_VAL="XTDRES"                  : Gosub XMLF_ADD From AYTGEN
        Endif
        WPUBLI_PREV=RUBGRP(WI)
    Next 
    #
When 21       # Action objet
    For WI=RUBNBR -1 To 0 Step -1    # Pour eviter de lire le numéro de ligne en premier sur les tableaux (car dim=1)
        If WPUBLI_PREV<>RUBGRP(WI)
           XT_TY="LIN"                                                          : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPNAM"     : XT_VAL=RUBGRP(WI)                : Gosub XMLF_ADD From AYTGEN
           XT_TY="COL"  : XT_ID="GRPSIZE"    : XT_VAL=num$(RUBDIM(WI))          : Gosub XMLF_ADD From AYTGEN
           # Pas de GRPTYP (FD)
        Endif
        WPUBLI_PREV=RUBGRP(WI)
    Next 
    #
When Default
    GERR=1 : GMESSAGE="Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
    Return
Endcase

# Tableau clé objet 
If[F:AYI1]TYP=21 # Action objet
    XT_TY="TAB"   : XT_ID="WS_KEY"    :  XT_VAL="Object keys"                 : Gosub XMLF_ADD From AYTGEN
    For WI=0 To dim(RUBKEYIND)-1
        XT_TY="LIN"                                                            : Gosub XMLF_ADD From AYTGEN
        XT_TY="COL"  : XT_ID="KEYCOD"     : XT_VAL=RUBCOD(RUBKEYIND(WI))         : Gosub XMLF_ADD From AYTGEN
        XT_TY="COL"  : XT_ID="KEYPOS"     : XT_VAL=num$(WI)                      : Gosub XMLF_ADD From AYTGEN
    Next 
Endif

Return


# Génération Web Services accès généré (vue et table)
# - - - - - - - - - - - - - -
$WS_GEN
WS_GEN_RET=1
#If ACCWS_FLG
   Local Mask    AWE2 [AWE2] : Raz [M:AWE2]
   Local Mask    AWE1 [AWE1] : Raz [M:AWE1]
   Local Mask    AWE0 [AWE0] : Raz [M:AWE0]
   WS_SUBPRG_R=1
   Gosub LOAD_PRG
   Case [F:AYI1]TYP
    When 1    # Accès généré Table
        Call GENSUBPRG([L]DOSORG, 1, [F:AYI1]CODFIC , [F:AYI1]WEBSRCCOD, WS_SUBPRG_R) From SUBAYIWSRGE1
    When 4    # Accès généré Vue 
        Call GENSUBPRG([L]DOSORG, 4, [F:AYI1]CODVUE , [F:AYI1]WEBSRCCOD, WS_SUBPRG_R) From SUBAYIWSRGE1
    When Default
        Call PUBLIWS([L]DOSORG,[F:AYI1]WEBSRCCOD) From SUBAWE
    Endcase  
    If WS_SUBPRG_R=0 
        WS_GEN_RET=0
        Call ECR_TRACE(mess(67,7900,1)-[F:AYI1]INTCOD,0) From GESECRAN
        Call ECR_TRACE("  "-mess(132,7900,1)-WS_WSRCOD-":"-GMESSAGE,1) From GESECRAN     
        GERR=0 : GMESSAGE=""
    Endif
#Endif
Return

$LOAD_PRG
Raz [M:AWE2] : Raz [M:AWE0] : Raz [M:AWE1]
[M:AWE0]PUBLI =  [F:AYI1]WEBSRCCOD
Local Char SUBPRGTT
Case [F:AYI1]TYP
 When 1       # Accès sous-programme généré accès sur table
    [M:AWE1]PRG = "WT"+[F:AYI1]WEBSRCCOD
    SUBPRGTT    = "ACCTAB"
 When 2,20
    [M:AWE1]PRG  =  [F:AYI1]PRG
    SUBPRGTT     = [F:AYI1]SUBPRG
 When 3,21
    [M:AWE1]PRG  = "WJ"+[F:AYI1]WEBSRCCOD
    SUBPRGTT     = ""
 When 4       # Accès sous-programme généré accès sur vue 
    [M:AWE1]PRG  = "WT"+[F:AYI1]WEBSRCCOD
    SUBPRGTT     = "ACCVIEW"
Endcase
Gosub CHMAPSPG From SUBAWE
Return




