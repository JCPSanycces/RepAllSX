#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CRE_CLOB : Création d'un clob dont le texte est stocké en mémoire
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En création ou modification d'un document
#          (si l'identifiant du clob correspond à l'abréviation du fichier
#           du document traité)
#------------------------------------------------------------------------
# Entrée : CODETEX : Identifiant du clob à créer
#          STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#                      -1 = Enregistrement bloqué
#########################################################################
Subprog CRE_CLOB(CODETEX,STAT)
Value    Char    CODETEX
Variable Integer STAT

#MAE, bg 56988 Local    Clbfile CLOB(6)
Local    Clbfile CLOB(GLONACB)

# Rien à créer : on considère que ce n'est pas une erreur
If CODETEX="" : STAT=1 : End : Endif

Raz STAT
Local File TEXCLOB [TXC]

If find(CODETEX,GCLOIDE(1..GCLOMAX))

   Call LIRE_CLOB(CLOB,CODETEX,STAT) From ACLOB
   If STAT=0
      Readlock [TXC]TXC0=CODETEX
      # L'enregistrement est bloqué
      If fstat=1
         STAT=-1 : GLOCK="$TEXCLOB"-CODETEX : End
      # Le clob n'existe pas, on l'écrit
      Elsif fstat
         [F:TXC]CODE   = CODETEX
         [F:TXC]TEXTE  = CLOB
         [F:TXC]IDENT1 = ""
         [F:TXC]IDENT2 = ""
         [F:TXC]IDENT3 = [F:TXC]CODE
         [F:TXC]CREUSR = GUSER
         [F:TXC]CREDAT = date$
         [F:TXC]CRETIM = time
         # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
         GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
         Write [TXC]
         If fstat
            STAT=0 : Call FSTA("TXC") From GLOCK : End
         Endif
      # Le clob existe déjà, on le réécrit
      Else
         [F:TXC]TEXTE  = CLOB
         # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
         GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
         Rewrite [TXC]
         If fstat
            STAT=0 : Call FSTA("TXC") From GLOCK : End
         Endif
      Endif
      # Nettoyage du texte du clob de la mémoire
      Call VIRE_CLOB(CODETEX,STAT) From ACLOB
      STAT=1
   Endif
Else
   STAT=1
Endif

End

#########################################################################
# DUP_CLOB : Dupplication d'un clob
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En création d'un document
#          (si l'identifiant du clob origine correspond à l'abréviation
#           du fichier du document d'origine)
#        - En initialisation de dupplication d'une donnée de base (RAZDUP)
#        - En initialisation de dupplication d'un document (RAZDUP)
#          (si l'identifiant du clob origine n'est pas un lien)
#        - Dans les automatismes de création d'un document à partir d'un autre
#          (si l'identifiant du clob origine n'est pas un lien)
#------------------------------------------------------------------------
# Entrée : ABRFIC  : Abréviation de la table de référence du clob à créer
#          CODETEX : Identifiant du clob origine (à duppliquer)
# Sortie : CODETEX : Identifiant du clob créer
#          STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#########################################################################
Subprog DUP_CLOB(ABRFIC,CODETEX,STAT)
Value    Char    ABRFIC
Variable Char    CODETEX
Variable Integer STAT

Local Integer WTEXSEQ

# Rien à duppliquer : on considère que ce n'est pas une erreur
If CODETEX="" : STAT=1 : End : Endif

Raz STAT
Local File TEXCPT  [TCC]
Local File TEXCLOB [TXC]

Read [TXC]TXC0=CODETEX
If !fstat
   Call NUM_TXC(ABRFIC,WTEXSEQ,STAT)
   If STAT=0
      [F:TXC]CODE = ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))
      Raz [F:TXC]IDENT1
      Raz [F:TXC]IDENT2
      [F:TXC]IDENT3=[F:TXC]CODE
      [F:TXC]CREUSR=GUSER
      [F:TXC]CREDAT=date$
      [F:TXC]CRETIM=time
      # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
      GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
      Write [TXC]
      If fstat
         STAT=0 : Call FSTA("TXC") From GLOCK
         Raz CODETEX : End
      Else
         CODETEX = [F:TXC]CODE
      Endif
      STAT=1
   Else
      STAT=0
   Endif
Else
   # On considère que ce n'est pas une erreur
   Raz CODETEX : STAT=1
Endif

End

#########################################################################
# SUP_CLOB : Suppression d'un clob
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En abandon de dupplication d'une donnée de base
#        - En abandon de dupplication d'un document
#          (si l'identifiant du clob n'est pas un lien)
#        - En suppression d'un document
#          (si l'identifiant du clob n'est pas un lien)
#------------------------------------------------------------------------
# Entrée : CODETEX : Identifiant du clob à supprimer
# Sortie : STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#########################################################################
Subprog SUP_CLOB(CODETEX,STAT)
Value    Char    CODETEX
Variable Integer STAT

Local Integer ASTAT

STAT=1

# Rien à supprimer : on considère que ce n'est pas une erreur
If CODETEX="" End Endif

Local File TEXCLOB [TXC]

Readlock [TXC]TXC0=CODETEX
If !fstat
   # Issue 79018 - 2012-01-05 by VPO : dde de liv, on perd les textes lors de la renumérot des lignes
   Call RANGE_CLOB([F:TXC]TEXTE,CODETEX,ASTAT) From ACLOB
   If ASTAT=1
      # Taille mémoire des textes dépassée
      [L]ASTATUS = fmet this.ASETERROR ("", mess(215,126,1)-"("+num$(GCLOMEM)-"Ko)", [V]CST_AERROR)
   Elsif ASTAT>1
    STAT=0
   Endif
   #
   Delete [TXC]
   If fstat
      STAT=0 : Call FSTA("TXC") From GLOCK
   Endif
Endif

End


#########################################################################
# NUM_TXC : Attribution d'un numéro identifiant un clob stocké dans TEXCLOB
#------------------------------------------------------------------------
# Entrée : WABRFIC  : Abréviation de la table de référence du clob à créer
# Sortie : WTEXSEC  : Numéro attribué
#          WRETOUR  : Status de sortie
#                       0  = OK
#                       99 = Erreur
#########################################################################
Subprog NUM_TXC(WABRFIC,WTEXSEQ,WRETOUR)
Value    Char    WABRFIC
Variable Integer WTEXSEQ
Variable Integer WRETOUR

Local    Integer WADXLOG     : # valeur de adxlog en entree du s/p
WADXLOG=adxlog

Local File TEXCPT [TCC]

# ----------
$TR_NUM_TXC
If !WADXLOG                  : # si adxlog=1 on est deja dans une transaction
    Trbegin [TCC]
Endif

Readlock [TCC]TCC0 = WABRFIC
If fstat = 1
   GOK=-1 : GLOCK = "$TEXCPT"-num$(ABRFIC) : Goto ROL_NUM_TXC
Elsif fstat                  : # il faut créer enr. avec le chrono = 1
   WTEXSEQ = 1
   Raz [F:TCC]
   [F:TCC]ABRFIC = WABRFIC
   [F:TCC]TEXSEQ = WTEXSEQ
         Write [TCC]
Else                         : # on a trouvé un chrono
   WTEXSEQ       = [F:TCC]TEXSEQ + 1
   [F:TCC]TEXSEQ = WTEXSEQ
   Rewrite [TCC]
Endif

If fstat
   GOK=0 : Call FSTA("TCC") From GLOCK : WRETOUR = 99 : Goto AB_NUM_TXC
Endif

If !WADXLOG
    Commit
Endif

End

# ----------
$ROL_NUM_TXC
If !WADXLOG
   Rollback
   Call ROLL From GLOCK
   If GROLL
      WRETOUR=99
#       Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
   Else
      Goto TR_NUM_TXC
   Endif
Endif
End

# ----------
$AB_NUM_TXC
If !WADXLOG
   Rollback
 #  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
End
