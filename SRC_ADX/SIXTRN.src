#<AdxTL>@(#)2.0.0.0 $Revision$
If !clalev ([F:XNTC]) : Local File =SI_DOSSIER+".XINUMTNCLT" [XNTC] : Endif
Trbegin [XNTC]
    Update [XNTC] With FLGREP=0
Commit

Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXTRN
End

$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
Resume

#########################################################################
#  SIXTRN : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog EXEC                                                          #
#     Alimentation du menu local 409 "Codes tournées"                   #
#########################################################################

Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
    Call OUVRE_TRACE("SIXTRN : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

If !clalev ([F:XNTC]) : Local File =SI_DOSSIER+".XINUMTNCLT" [XNTC] : Endif
If !clalev ([F:AST])  : Local File =SI_DOSSIER+".APLSTD"     [AST]  : Endif
If !clalev ([F:AST2]) : Local File =SI_DOSSIER+".APLSTD"     [AST2] : Endif
If !clalev ([F:TLA])  : Local File =SI_DOSSIER+".TABLAN"     [TLA]  : Endif

Local Integer I
Local Integer LMAX, LOK, LREW
Raz LMAX, LOK


# 1- Contrôles
# Vérification de la langue
Read [TLA]TLA0=[F:SPX]LAN
If fstat
    Call ECR_TRACE(SI_MES(245),1) From GESECRAN
    End
Endif

# Vérification qu'à la fin de la récupération il n'y aura pas de trou de le menu local
Read [XNTC]IND0 Last

Filter [AST] Where LAN=[F:SPX]LAN & LANCHP=409
Raz [F:AST]
Read [AST]LAN Last
Filter [AST]
LMAX = rowcount([F:XNTC])
If LMAX>0 | [F:AST]LANNUM>0
    LOK=1
Else
    Call ECR_TRACE("Table XINUMTNCLT vide",1) From GESECRAN
Endif    
If !LOK
    End
Endif
# 2- Alimentation du menu local 409
Call DEBTRANS From GLOCK
Trbegin [AST]
For [XNTC] Where FLGREP<>2
    Raz [F:AST]
    Read [AST]CLE=409;val([F:XNTC]X3CLE);[F:SPX]LAN
    If fstat
        LREW=0
    Else
        LREW=1
    Endif
    [F:AST]LANCHP = 409
    [F:AST]LANMES = [F:XNTC]LIBTRN
    If [F:AST]LANMES=""
        [F:AST]LANMES = SI_MES(169)-[F:XNTC]X3CLE
    Endif
    [F:AST]LANNUM = val([F:XNTC]X3CLE)
    [F:AST]LAN    = [F:SPX]LAN
    If LREW
        [F:AST]UPDDAT = date$
        [F:AST]UPDUSR = GUSER
        If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM = time : Endif
        SI_TABLE = "409"
        Gosub SI_BEFWRI From SIXFONCTION

        Rewrite [AST] 
    Else
        [F:AST]CREDAT = date$
        [F:AST]CREUSR = GUSER
        If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM = time : Endif
        SI_TABLE = "409"
        Gosub SI_BEFWRI From SIXFONCTION

        Write [AST] 
    Endif
    If fstat
        #Call ECR_TRACE("[AST] fstat="+num$(fstat)) From GESECRAN
        Call ECR_TRACE("[AST] fstat="+num$(fstat),1) From GESECRAN  # FGR 17/12/2009 : X3SUIVI60986
        GOK=0
    Endif
Next


Read [F:AST]CLE=409;0;[F:SPX]LAN
If fstat
    [F:AST]LAN    = [F:SPX]LAN
    [F:AST]LANCHP = 409 
    [F:AST]LANNUM = 0 
    Filter [AST2] Where LAN=[F:SPX]LAN & LANNUM<>0 & LANCHP=409
    [F:AST]LANMES = string$(rowcount([F:AST2]),"1") 
    Filter [AST2]
    [F:AST]CREDAT = date$
    [F:AST]CREUSR = GUSER
    If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM = time : Endif
    Write [AST] 
Else
    Filter [AST2] Where LAN=[F:SPX]LAN & LANNUM<>0 & LANCHP=409
    [F:AST]LANMES = string$(rowcount([F:AST2]),"1") 
    Filter [AST2]
    [F:AST]UPDDAT = date$
    [F:AST]UPDUSR = GUSER
    If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM = time : Endif
    Rewrite [AST] 
Endif

If GOK
    Update [XNTC] With FLGREP=2
Endif

If SI_SIMU=2
    Rollback
Else
    Commit
    # On ne valide que pour la langue pour laquelle on a modifié le menu local
    Call GENMENU(SI_DOSSIER,1,0,[F:SPX]LAN) From GENMENULOC
Endif

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


