#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################################
## MAJ onglet sélection DU5 suite au bug 64323
##############################################################################

Call MAJ_UTICPT24   
End

Subprog MAJ_UTICPT24

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT24:"-"DU5 Object Update") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT24") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT24(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT24(APPLI)
Value Char APPLI

Call MAJ_SEL(APPLI,"DU5") From PATCHAOB

Call VALFEN(APPLI,"DU5") From SUBAOB
End


Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT24(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTICPT24(APPLI)
End
