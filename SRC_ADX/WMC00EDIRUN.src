#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## CRUD-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 971

Gosub TEST From WMCR_EDIRUN : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,NUM)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EDIRUN : EDIRUN
# EDIRUND : EDIRUN EDIRUND
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EDIRUN._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EDIRUN.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EDIRUN.ACTX.AFOLDER,nomap,"")>0
 Local File EDIRUN [EDR]
 Local File EDIRUND [EDRD]
Else
 Local File =EDIRUN.ACTX.AFOLDER+".EDIRUN" [EDR]
 Local File =EDIRUN.ACTX.AFOLDER+".EDIRUND" [EDRD]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EDR] With
& [EDRD]EDRD0 = [F:EDR]NUM
& As [LNK_]
Return

############################################################################################
### EDIRUN(WEDR)
############################################################################################
Funprog  _MAJSQL_EDIRUN(WEDR)
Variable Instance WEDR Using C_EDIRUN
Local Integer ASTATUS,A_I,A_J
Default File [F:EDR]
If WEDR.ASTALIN=[V]CST_ANEW
 Call INICRE(WEDR) From ASYRSUB
 SetInstance [F:EDR] With WEDR
 Write [F:EDR]
 If fstat
  Call FSTA("EDR",WEDR,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEDR.updTick = [F:EDR]updTick
Elsif WEDR.ASTALIN=[V]CST_ALL or WEDR.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEDR) From ASYRSUB
 SetInstance [F:EDR] With WEDR
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEDR,"EDIRUN")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EDR]EDR0 = [F:EDR]NUM
 If fstat
  Call FSTA("EDR",WEDR,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEDR.updTick = [F:EDR]updTick
Elsif WEDR.ASTALIN=[V]CST_ADEL
 SetInstance [F:EDR] With WEDR
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEDR,"EDIRUN")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EDR]EDR0 = [F:EDR]NUM
 If fstat
  Call FSTA("EDR",WEDR,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EDIRUND(WEDRD)
############################################################################################
Funprog  _MAJSQL_EDIRUND(WEDRD)
Variable Instance WEDRD Using C_EDIRUND
Local Integer ASTATUS,A_I,A_J
Default File [F:EDRD]
If WEDRD.ASTALIN=[V]CST_ANEW
 Call INICRE(WEDRD) From ASYRSUB
 SetInstance [F:EDRD] With WEDRD
 Write [F:EDRD]
 If fstat
  Call FSTA("EDRD",WEDRD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEDRD.updTick = [F:EDRD]updTick
Elsif WEDRD.ASTALIN=[V]CST_ALL or WEDRD.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEDRD) From ASYRSUB
 SetInstance [F:EDRD] With WEDRD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEDRD,"EDIRUND")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EDRD]EDRD0 = [F:EDRD]NUM;[F:EDRD]NUMLIN
 If fstat
  Call FSTA("EDRD",WEDRD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEDRD.updTick = [F:EDRD]updTick
Elsif WEDRD.ASTALIN=[V]CST_ADEL
 SetInstance [F:EDRD] With WEDRD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEDRD,"EDIRUND")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EDRD]EDRD0 = [F:EDRD]NUM;[F:EDRD]NUMLIN
 If fstat
  Call FSTA("EDRD",WEDRD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



