#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR02   Migration des Commandes                    Module Achats#
#                Commandes normales                                      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR02") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR02(DOSSIER)
  Call MAJ_UUMGTRTPUR02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR02(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPOHM,WNAMPOPM,WNAMPOQM
Call MIGTABNAME (DOSSIER,"PORDER",WNAMPOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERP",WNAMPOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERQ",WNAMPOQM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPOHM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPOPM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPOQM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
#Local File =DOSSIER+".PORDER"    [POH]
#Local File =DOSSIER+".PORDERP"   [POP]
#Local File =DOSSIER+".PORDERQ"   [POQ]
#Local File =DOSSIER+".PORDERC"   [POC]
Local File =DOSSIER+".CPTANALIN"  [CAL]
Local File =DOSSIER+".PVCRVAT"    [PVV]
Local File =DOSSIER+".PVCRFOOT"   [PVF]

# Issue 81811 - 2012-04-24 by VPO : vider les tables
Call MIGTABRAZ (DOSSIER,"PORDER",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PORDERP",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PORDERQ",ERR) From TRTMIG
#Onerrgo ERR_SQL
#Trbegin [POH]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDER WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [POP]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDERP WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [POQ]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".PORDERQ WHERE POHTYP_0=1 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
If val(VERSION)<GMIGX3VER60
  Onerrgo ERR_SQL
  Trbegin [CAL]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='POP' AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER WHERE CPTANALIN.VCRNUM_0=PORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit

  Onerrgo ERR_SQL
  Trbegin [PVV]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".PVCRVAT WHERE VCRTYP_0=3 AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER WHERE PVCRVAT.VCRNUM_0=PORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit

  Onerrgo ERR_SQL
  Trbegin [PVF]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".PVCRFOOT WHERE VCRTYP_0=3 AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PORDER WHERE PVCRFOOT.VCRNUM_0=PORDER.POHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR02",ERR) From TRTMIG

End
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
ERR=1
Resume

##########################################################################
Subprog MAJ_UUMGTRTPUR02(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMPOHM,WNAMPOPM,WNAMPOQM
Call MIGTABNAME (DOSSIER,"PORDER",WNAMPOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERP",WNAMPOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PORDERQ",WNAMPOQM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPOHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPOPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPOQM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",2,ERR) From TRTMIG : #2=En cours
# Issue 88474 - 2013-05-06 by SR
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_POH (100) (adxwrb)
Local Char WTAB_POP (100) (adxwrb)
Local Char WTAB_POQ (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Char WTAB_PVV (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Shortint WCPT_POH,WCPT_POP,WCPT_POQ,WCPT_CAL,WCPT_PVV,WCPT_PVF

Call ECR_TIME("UUMGTRTPUR02 Purchase Orders Process : Update PORDER-P-Q") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PORDERQ",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:POH])  = 0 : Local File =DOSSIER+".PORDER"    [POH]  : Endif   # Fichier X3 "Vide"
If clalev([F:POP])  = 0 : Local File =DOSSIER+".PORDERP"    [POP]  : Endif   # Fichier X3 "Vide"
If clalev([F:POQ])  = 0 : Local File =DOSSIER+".PORDERQ"    [POQ]  : Endif   # Fichier X3 "Vide"

If clalev([F:POHM]) = 0 : Local File =DOSSIER+"."+WNAMPOHM   [POHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:POPM]) = 0 : Local File =DOSSIER+"."+WNAMPOPM   [POPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:POQM]) = 0 : Local File =DOSSIER+"."+WNAMPOQM   [POQM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)

Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_POH From UUMGTRTPUR00
# Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
Gosub OUVRE_PUR02

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [POPM] With [POHM]POH0~=[F:POPM]POHNUM,[BPS]BPS0=[F:POHM]BPSNUM
&    As [LNK]
&    Order By Key CLE = [F:POHM]POHTYP;[F:POHM]POHFCY;[F:POHM]POHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR02" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_POP00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:POHM]POHTYP=1 & [F:POHM]POHFCY=TABMIGKEY(2) & [F:POHM]POHNUM>TABMIGKEY(3)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:POHM]POHTYP=1 & [F:POHM]POHFCY>TABMIGKEY(2)"
Else
 CRITERE = "[F:POHM]POHTYP=1 "
Endif

Trbegin [POH],[POP], [POQ]
GOK = 1

For [LNK]CLE(3) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR02" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEPOP : Endif
  Endif
  #Raz [F:POH]
  # Issue 88474 - 2013-05-06 by SR
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_POH
  Endif
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_POH
  Endif
  [F:POH] = [F:POHM]

  If WSITE<>[F:POH]POHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:POH]POHFCY) From TRTX3CPT
      WSITE=[F:POH]POHFCY
  Endif

  [F:POH]CPY=GSOCIETE

   # Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AVPOH
  Endif
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AVPOH
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de commande
    #Raz [F:POP]
    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_POP
    Endif
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_POP
    Endif
    [F:POP] = [F:POPM]

    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      #Appel proc de migration sur detail
      Gosub MAJV6_POP
      If GOK<1 : Break : Endif
    Endif
    If val(VERSION)<GMIGX3VER70
      #Appel proc de migration sur detail
      Gosub MAJV7_POP
      If GOK<1 : Break : Endif
    Endif

   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub POP_STK : # pour stocker ref
#        WriteB [POP]
#    Else
#        Write [POP]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
#          Gosub POP_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PORDERP(POHNUM/POPLIN/POPSEQ)="-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub POP_STK : # pour stocker ref
     WriteB [POP]
     If fstat
        Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub POP_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next
  If GOK<1 : Break : Endif
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:POP]
    If fstat
        Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub POP_ERRTRA : # pour afficher les ref
        GOK=0
    Endif
 # Endif
 # End issue 108760
  If GOK<1 : Break : Endif

# Issue 112754 - 2017-01-26 by SR : Services
  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER120
    Gosub MAJ_POH
  Endif
  If GOK<1 : Break : Endif
  # --- alimentation des champs et écriture enreg
  # --- alimentation des champs et écriture enreg
  # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub POH_STK : # pour stocker ref
#      WriteB [F:POH]
#  Else
#      Write [F:POH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
#      Gosub POH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PORDER(POHNUM)"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub POH_STK : # pour stocker ref
   WriteB [F:POH]
   If fstat
    Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
    Gosub POH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
   Endif
   # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:POHM]POHTYP)
    TABMIGKEY(2) = [F:POHM]POHFCY
    TABMIGKEY(3) = [F:POHM]POHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLEPOP
Next

$FIN_BOUCLEPOP
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR02",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
  #If NEWMOTEUR & adxwrb>1
    Flush [F:POH]
    If fstat
        Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub POH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
    Flush [F:POP]
    If fstat
        Call ECR_TRACE("File PORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub POP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
    Flush [F:POQ]
    If fstat
        Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub POQ_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
    Flush [F:PVV]
    If fstat
        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVV_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEPOP : #on part sur rollback
    Endif
  #Endif
  # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEPOP
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR02",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_POP00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [POH], [POP]
Close Local File [POHM], [POPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PORDER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PORDERQ",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR02") From TRTMIG
Call ECR_TIME("UUMGTRTPUR02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$POH_STK
Call STK (WTAB_POH,WCPT_POH,[F:POH]POHNUM) From TRTMIG
Return
$POP_STK
Call STK (WTAB_POP,WCPT_POP,[F:POP]POHNUM-'/'-num$([F:POP]POPLIN)-'/'-num$([F:POP]POPSEQ)) From TRTMIG
Return
$POQ_STK
Call STK (WTAB_POQ,WCPT_POQ,[F:POQ]POHNUM-'/'-num$([F:POQ]POPLIN)-'/'-num$([F:POQ]POQSEQ)) From TRTMIG
Return
##############################################################################################
$POH_ERRTRA
Call ERRTRA (WTAB_POH,WCPT_POH,"File PORDER(POHNUM)=") From TRTMIG
Return
$POP_ERRTRA
Call ERRTRA (WTAB_POP,WCPT_POP,"File PORDERP(POHNUM/POPLIN/POPSEQ)=") From TRTMIG
Return
$POQ_ERRTRA
Call ERRTRA (WTAB_POQ,WCPT_POQ,"File PORDERQ(POHNUM/POPLIN/POQSEQ)=") From TRTMIG
Return

# Issue 88474 - 2013-05-06 by SR
$OUVRE_PUR02
# Issue 91588 - 2013-08-01 by SR : WDSPVOU et pas WDPSVOU
Local Char WDSPVOU(GLONUOM),WDSPWEU(GLONUOM)
Local   Decimal  WPRIPUR
Local   Decimal  WBASE, WMT, WRND, WTAXE, WMT1, WBASE1
Local   Integer  STAT, I, J
Local    Char    WUOM(GLONUOM)
Local    Char    WCUR(GLONCUR)
# Issue 91653 - 2013-08-05 by SR
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Local    Decimal WCOEFF, WCPRAMT, WUOMSTUCOE
Local    Decimal WCOEFF
Return

$RAZV6_POH
Raz [F:POH]BPAINV
Raz [F:POH]BPAPAY
Raz [F:POH]BPOADD
Raz [F:POH]BPOADDLIG
Raz [F:POH]BPOCRY
Raz [F:POH]BPOCRYNAM
Raz [F:POH]BPOCTY
Raz [F:POH]BPONAM
Raz [F:POH]BPOPOSCOD
Raz [F:POH]BPOSAT
Raz [F:POH]CCE
Raz [F:POH]CPY
Raz [F:POH]DEP
Raz [F:POH]DIE
Raz [F:POH]DSPVOU
Raz [F:POH]DSPWEU
Raz [F:POH]EECICT
Raz [F:POH]EECLOC
Raz [F:POH]EECNUM
Raz [F:POH]FFWADD
Raz [F:POH]FFWNUM
Raz [F:POH]FUPFLG
Raz [F:POH]ICTCTY
Raz [F:POH]INVDTALIN1
Raz [F:POH]INVDTALIN2
