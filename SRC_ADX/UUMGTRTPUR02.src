$MAJV6_AVPOH
#----- Alimentation société, indicateurs relance sur l'entête de commande -----#
Call PARAML([F:POH]POHFCY,"SALDSPWEU",[F:POH]DSPWEU) From ADOVAL
Call PARAML([F:POH]POHFCY,"SALDSPVOU",[F:POH]DSPVOU) From ADOVAL
Gosub LECT_BPSPOH
[F:POH]FUPFLG=[F:BPS]FUPFLG
[F:POH]OCNFLG=[F:BPS]OCNFLG
[L]WEECICT   =[F:BPS]EECICT
[L]WEECLOC   =[F:BPS]EECLOC
Return

$MAJV7_AVPOH
Call PARAML([F:POH]POHFCY,"SALDSPWEU",WDSPWEU) From ADOVAL
Call PARAML([F:POH]POHFCY,"SALDSPVOU",WDSPVOU) From ADOVAL
Return

$MAJ_POH
    # Issue 88474 - 2013-05-07 by SR : Ligne déplacée
    #----- Chargement arrondi devise commande -----#
    Gosub LECT_TCUCUR
    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Gosub LECT_BPSPOH
      #----- Alimentation des informations douanières si commande classique -----#
      If [F:POH]POHTYP<>2
        #----- Alimentation incoterm et lieu de transport CEE -----#
        If [F:POH]EECICT=""
          [F:POH]EECICT=[F:BPS]EECICT : # Incoterm
        Endif
        If GACTDEB=2 & [F:POH]EECLOC=0
          [F:POH]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
        Endif
        #----- Alimentation identification CEE du tiers facturant -----#
        If GACTDEB=2 & [F:POH]EECNUM=""
          Gosub LECT_BPRI
          [F:POH]EECNUM=[F:BPR]EECNUM : # Identification CEE
        Endif
      Endif

      If [F:POH]BPOADD=""
        #----- Si fournisseur divers, adr.commande = adr.expédition -----#
        If [F:BPS]BPSTYP=3
          [F:POH]BPOADD      =[F:POH]BPAADD
          [F:POH]BPONAM(0)   =[F:POH]BPRNAM(0)
          [F:POH]BPONAM(1)   =[F:POH]BPRNAM(1)
          [F:POH]BPOADDLIG(0)=[F:POH]BPAADDLIG(0)
          [F:POH]BPOADDLIG(1)=[F:POH]BPAADDLIG(1)
          [F:POH]BPOADDLIG(2)=[F:POH]BPAADDLIG(2)
          [F:POH]BPOPOSCOD   =[F:POH]POSCOD
          [F:POH]BPOCTY      =[F:POH]CTY
          [F:POH]BPOSAT      =[F:POH]SAT
          [F:POH]BPOCRY      =[F:POH]CRY
          [F:POH]BPOCRYNAM   =[F:POH]CRYNAM
        #----- alimentation code adresse expédition -----#
        Else
          [F:POH]BPOADD=[F:BPS]BPAADD
          If GACTSAD=2 : # Stockage systématique de l'adresse !
            #----- Lecture BPARTNER si nécessaire -----#
            Gosub LECT_BPRS
            #----- Lecture de l'adresse si nécessaire -----#
            Gosub LECT_BPAS
            #-----
            [F:POH]BPONAM(0)    = [F:BPR]BPRNAM(0)
            [F:POH]BPONAM(1)    = [F:BPR]BPRNAM(1)
            [F:POH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
            [F:POH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
            [F:POH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
            [F:POH]BPOCRY       = [F:BPA]CRY
            [F:POH]BPOCRYNAM    = [F:BPA]CRYNAM
            [F:POH]BPOSAT       = [F:BPA]SAT
            [F:POH]BPOPOSCOD    = [F:BPA]POSCOD
            [F:POH]BPOCTY       = [F:BPA]CTY
          Endif
        Endif
      Endif

      #----- Alimentation code adresse fournisseur payé -----#
      If [F:POH]BPAPAY=""
        If [F:BPS]BPRPAY=[F:POH]BPRPAY
          [F:POH]BPAPAY=[F:BPS]BPAPAY
        Else
          Gosub LECT_BPSP
          [F:POH]BPAPAY=[F:BPS]BPAADD
        Endif
      Endif

      #----- Alimentation code adresse fournisseur facturant -----#
      If [F:POH]BPAINV=""
        If [F:BPS]BPSINV=[F:POH]BPSINV
          [F:POH]BPAINV=[F:BPS]BPAINV
        Else
          Gosub LECT_BPSI
          [F:POH]BPAINV=[F:BPS]BPAADD
        Endif
      Endif

      #----- Alimentation champs pour le multi-référenciels comptabilité -----#
      If dim([F:POH]DIE)>0 & [F:POH]DIE(0)=""
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:POH]DIE(I-1)=GDIE(I)
        Next I
      Endif
      #----- Alimentation éléments et taxes ligne tarif -----#
      Gosub LECT_BPSPOH

      Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE

      #-----
      For I=0 To dim([F:POH]INVDTAVAT1)-1
        If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
          [F:POH]INVDTALIN1(I)=GINVDTALIN(I)
          If [F:POH]INVDTAVAT1(I)=""
            WJ=find(GINVDTALIN(I),WPFINUM(0..WNBPFI))
            If WJ>0 & WPFIVATRUL(WJ-1)=2
              WJTVC=find([F:BPS]VACBPR+'/'+WPFIVACITM(WJ-1),WTVCCLE(0..NBTVC))
              If WJTVC>0
                [F:POH]INVDTAVAT1(I)=WTVCVAT(WJTVC-1)
              Endif
            Endif
          Endif
        Endif
      Next I
    Endif

    Gosub MAJ_POHPOQ
    If GOK<1 : Return : Endif

    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      #----- Pour commande classique uniquement -----#
      If [F:POH]POHTYP=1
        [F:POH]TOTORD=[F:POH]TOTLINAMT
        #----- Calcul taxes des éléments de facturation en pied -----#
        For I=0 To [L]NBFAC-1
          [F:POH]TOTORD+=[L]INVLINAMT(I)
          If [L]INVDTAVAT(I)<>""
            #-----
            Raz TAXE : TAXE(1)=[L]INVDTAVAT(I)
            Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                       [L]INVLINAMT(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
            [L]DTAAMTTAX(I)=MONTANT(1)
            [L]DTADEDTAX(I)=MONTDED(1)
            #----- Recherche si taxe déja existante -----#
            J=find([L]INVDTAVAT(I),[L]TAX(0..[L]NBTAX-1))
            If J<>0 & [L]PURTYP(J-1)<>1
              K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
              If K<>0
                J+=K
                If [L]PURTYP(J-1)<>1
                  K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
                  If K<>0 J+=K Else J=0 : Endif
                Endif
              Else
                J=0
              Endif
            Endif
            #----- Nouvelle taxe -----#
            If J=0
              #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
              If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT0 : Endif
              #-----
              J=[L]NBTAX
              [L]NBTAX+=1
              [L]TAX   (J)=[L]INVDTAVAT(I)
              [L]PURTYP(J)=1
              WJTVT=find([L]INVDTAVAT(I),WTVTVAT(0..NBTVT))
              If WJTVT>0
                [L]VATTYP(J)=WTVTVATTYP(WJTVT-1)
              Else
                [L]VATTYP(J)=0
              Endif
            Else
              J-=1
            Endif
            #----- Mise à jour de la base et des montants de taxe -----#
            [L]BASTAX(J)+=[L]INVLINAMT(I)
            [L]AMTTAX(J)+=[L]DTAAMTTAX(I)
            [L]DEDTAX(J)+=[L]DTADEDTAX(I)
          Endif
  $MAJ_SUIT0
        Next I
        #----- Calcul total taxes -----#
        If [F:POH]VACTYP<>4
          [F:POH]TOTTAXAMT=sum([L]AMTTAX)
        Else
          [F:POH]TOTTAXAMT=0
        Endif
        [F:POH]TTVORD=[F:POH]TOTORD+[F:POH]TOTTAXAMT
        #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
        Gosub WRITE_PVV
        If GOK<1 : Return : Endif
      #----- Juste calcul total taxes lignes pour commandes ouvertes -----#
      Elsif [F:POH]POHTYP=2
        [F:POH]TOTORD=[F:POH]TOTLINAMT
        [F:POH]TTVORD=[F:POH]TOTLINATI
        If [F:POH]VACTYP<>4
          [F:POH]TOTTAXAMT=[F:POH]TTVORD-[F:POH]TOTORD
        Else
          [F:POH]TOTTAXAMT=0
        Endif
        Raz [F:POH]TOTLINAMT, [F:POH]TOTLINATI
      Endif

      #----- Ecriture du tableau des éléments dans la table PVCRFOOT -----#
      Gosub WRITE_PVF
      If GOK<1 : Return : Endif

      #----- Chargement HT et TTC commande en devise société -----#
      Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&                [F:POH]TOTORD,[F:POH]TOTORDL,[F:POH]CHGCOE,STAT) From TRTDEV
      If STAT <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     1-File PORDER"-[F:POH]POHNUM+", Error ="-num$(STAT),-1) From GESECRAN
      Endif
      Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&                [F:POH]TTVORD,[F:POH]TTVORDL,[F:POH]CHGCOE,STAT) From TRTDEV
      If STAT <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     2-File PORDER"-[F:POH]POHNUM+", Error ="-num$(STAT),-1) From GESECRAN
      Endif
      #----- Mise à jour code adresse tiers âyeur sur échéances -----#
      # Issue 108760 - 2015-06-15 by SR : Adaptation
      If func DOSVUE.ISVIEW(DOSSIER,"GACCDUDATE")<> 1
        Gosub UPD_DUD
        If GOK<1 : Return : Endif
      Endif
    Endif
Return

#----- Mise à jour code adresse tiers payeur sur échéances -----#
$UPD_DUD
# Issue 80368 - 2012-02-27 by VPO : pb de perf, ne passe pas toujours par l'index
# on remplace l'update par une lecture + maj
#    Update [DUD] Where TYP="*PO" & NUM=[F:POH]POHNUM & BPAPAY=""
#&                With  BPAPAY=[F:POH]BPAPAY
#    If fstat
#      Call ECR_TRACE("File GACCDUDATE"-"*PO"-[F:POH]POHNUM+",Error ="-num$(fstat),1) From GESECRAN
#      GOK=0 : Return
#    Endif

    For [DUD]DUD0 Hint Key DUD0 Where [F:DUD]TYP="*PO" & [F:DUD]NUM=[F:POH]POHNUM & [F:DUD]BPAPAY=""
      [F:DUD]BPAPAY=[F:POH]BPAPAY
      Rewrite [DUD]
      If fstat
        Call ECR_TRACE("File GACCDUDATE"-"*PO"-[F:POH]POHNUM+",Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Break
      Endif
    Next
Return
#############################
$WRITE_PVF
      Raz [F:PVF]
      If [F:POH]POHTYP=2
        [F:PVF]VCRTYP=5
      Else
        [F:PVF]VCRTYP=3
      Endif
      [F:PVF]VCRNUM=[F:POH]POHNUM
      [F:PVF]POHNUM=[F:POH]POHNUM
      [F:PVF]CREDAT=date$
      [F:PVF]CREUSR=GUSER
      For I=0 To [L]NBFAC-1
        WJ=find([L]INVDTA(I),WPFINUM(0..WNBPFI))
        Gosub RECUP_PFI From UUMGTRTPUR00
        [F:PVF]INVDTA   =[L]INVDTA(I)
        [F:PVF]INVDTAAMT=[L]INVDTAAMT(I)
        If [F:POH]POHTYP=2
          [F:PVF]INVORDAMT=0
          [F:PVF]INVLINAMT=0
        Elsif [L]INVLINFLG(I)<>6
          [F:PVF]INVORDAMT=[L]INVLINAMT(I)
          [F:PVF]INVLINAMT=0
        Else
          [F:PVF]INVORDAMT=0
          [F:PVF]INVLINAMT=[L]INVLINAMT(I)
        Endif
        [F:PVF]INVCPLAMT=[L]INVCPLAMT(I)
        [F:PVF]INVDTAFLG=1
        [F:PVF]INVLINFLG=[L]INVLINFLG(I)
        [F:PVF]INVORDFLG=[F:PFI]DACORD
        [F:PVF]DEBCDT   =[L]DEBCDT(I)
        [F:PVF]INVDTAVAT=[L]INVDTAVAT(I)
        [F:PVF]DTAAMTTAX=[L]DTAAMTTAX(I)
        [F:PVF]DTADEDTAX=[L]DTADEDTAX(I)
        [F:PVF]AMTCOD   =[F:PFI]AMTCOD
        If [F:PVF]AMTCOD=1
          [F:PVF]AMTCODLIB="%"
          [F:PVF]FORMAT   =func TRTX3FNC.GETFMTREM(1)
        Elsif [F:PVF]INVLINFLG<>6
          [F:PVF]AMTCODLIB=[F:POH]CUR
          [F:PVF]FORMAT   ="NZ:"+[F:TCU]CURFMT1+"[ ]"
        Else
          [F:PVF]AMTCODLIB=""
          [F:PVF]FORMAT   ="NzZ:"+[F:TCU]CURFMT1+"[ ]"
        Endif
        [F:PVF]CLCORD   =[F:PFI]CLCORD
        [F:PVF]CLCBAS   =[F:PFI]CLCBAS
        [F:PVF]IND=I+1

        # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#        If NEWMOTEUR
#            Gosub PVF_STK From UUMGTRTPUR00 : # pour stocker ref
#            WriteB [F:PVF]
#        Else
#            Write [F:PVF]
#        Endif
#        If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
#            Gosub PVF_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#          Else
#            If [F:POH]POHTYP=2
#            Call ECR_TRACE("File PVCRFOOT 5"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#            Else
#            Call ECR_TRACE("File PVCRFOOT 3"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
#          Endif
#          GOK=0 : Break
#        Endif
         Gosub PVF_STK From UUMGTRTPUR00 : # pour stocker ref
         WriteB [F:PVF]
         If fstat
            Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
            Gosub PVF_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
            GOK=0 : Break
         Endif
         # End issue 108760
      Next I
Return
#############################
$WRITE_PVV
      #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
      Raz [F:PVV]
      [F:PVV]VCRTYP=3
      [F:PVV]VCRNUM=[F:POH]POHNUM
      [F:PVV]POHNUM=[F:POH]POHNUM
      [F:PVV]CREDAT=date$
      [F:PVV]CREUSR=GUSER
      For I=0 To [L]NBTAX-1
        [F:PVV]TAX   =[L]TAX(I)
        [F:PVV]BASTAX=[L]BASTAX(I)
        [F:PVV]AMTTAX=[L]AMTTAX(I)
        [F:PVV]DEDTAX=[L]DEDTAX(I)
        [F:PVV]PURTYP=[L]PURTYP(I)
        [F:PVV]VATTYP=[L]VATTYP(I)
        #----- Chargement des taux de taxe -----#
        Filter [TRA] Where CPY=[F:POH]CPY & VAT=[F:PVV]TAX & STRDAT<=[F:POH]ORDDAT
        Read [TRA] TRA0 Last
        If fstat>2
          Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=[F:POH]ORDDAT
          Read [TRA]TRA0 Last
          If fstat>2  Raz [F:TRA] : Endif
        Endif
        [F:PVV]VATRAT=[F:TRA]VATRAT
        [F:PVV]DEDRAT=[F:TRA]DEDRAT
        #-----
        [F:PVV]IND=I+1

        # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#        If NEWMOTEUR
#            Gosub PVV_STK From UUMGTRTPUR00 : # pour stocker ref
#            WriteB [F:PVV]
#        Else
#            Write [F:PVV]
#        Endif
#        If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
#            Gosub PVV_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#          Else
#            Call ECR_TRACE("File PVCRVAT 3"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#          Endif
#          GOK=0 : Break
#        Endif
         Gosub PVV_STK From UUMGTRTPUR00 : # pour stocker ref
         WriteB [F:PVV]
         If fstat
            Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
            Gosub PVV_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
            GOK=0 : Break
         Endif
         # End issue 108760
      Next I
Return

########################################################################
$LECT_TCUCUR
    If [F:TCU]CUR<>[F:POH]CUR
      Read [TCU] TCU0=[F:POH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
Return

###################################
$LECT_BPSPOH
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  WBPS=[F:POH]BPSNUM
  Gosub LECT_BPS
Endif
Return
$LECT_BPSP
If [F:BPS]BPSNUM<>[F:POH]BPRPAY
  WBPS=[F:POH]BPRPAY
  Gosub LECT_BPS
Endif
Return
$LECT_BPSI
If [F:BPS]BPSNUM<>[F:POH]BPSINV
  WBPS=[F:POH]BPSINV
  Gosub LECT_BPS
Endif
Return
$LECT_BPS
  Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return

#####################################
$LECT_BPRI
If [F:BPR]BPRNUM<>[F:POH]BPSINV
  WBPR=[F:POH]BPSINV
  Gosub LECT_BPR
Endif
Return
$LECT_BPRS
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  WBPR=[F:POH]BPSNUM
  Gosub LECT_BPR
Endif
Return
$LECT_BPR
  Read [BPR] BPR0=WBPR : If fstat Raz [F:BPR] : Endif
Return

#####################################
$LECT_BPAS
If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
  Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
  If fstat  Raz [F:BPA] : Endif
Endif
Return

#################################################
$MAJ_POHPOQ
    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Gosub BOUCLE1_POQ
    #----- Reprise des éléments existant sur l'entête de commande -----#
      If dim([F:POHM]INVDTA)>0
        Raz K
        For I=0 To dim([F:POHM]INVDTA)-1
          If [F:POHM]INVDTA(I)<>0
            J=[L]NBFAC
            WJ=find([F:POHM]INVDTA(I),WPFINUM(0..WNBPFI))
            Gosub RECUP_PFI From UUMGTRTPUR00
            [L]INVDTA   (J)=[F:POHM]INVDTA(I)
            [L]INVDTAAMT(J)=[F:POHM]INVDTAAMT(I)
            [L]INVCPLAMT(J)=[F:POHM]INVCPLAMT(I)
            If [F:PFI]DACLIN=2
              [L]INVLINFLG(J)=6
            Else
              [L]INVLINFLG(J)=[F:PFI]DSPLIN
            Endif
            [L]DEBCDT   (J)=max(1,[F:PFI]INCDCR)
            SIGN=1-2*([L]DEBCDT(J)-1)
            If [F:POHM]AMTCOD(I)=2  : #----- Montant
              [L]INVLINAMT(J)=[F:POHM]INVDTAAMT(I)*SIGN
            Elsif [F:PFI]CLCBAS<>3 : #----- Pourcentage sur HT
              [L]INVLINAMT(J)=arr([F:POH]TOTLINAMT*[F:POHM]INVDTAAMT(I)/100,WRND)*SIGN
            Else                   : #----- Pourcentage sur TTC
              [L]INVLINAMT(J)=arr([F:POH]TTVORD*[F:POHM]INVDTAAMT(I)/100,WRND)*SIGN
            Endif
            If [F:PFI]VATRUL=2
              WJTVC=find([F:POH]VACBPR+'/'+[F:PFI]VACITM,WTVCCLE(0..NBTVC))
              If WJTVC>0
                [L]INVDTAVAT(J)=WTVCVAT(WJTVC-1)
              Endif
            Endif
            [L]NBFAC+=1
            # Issue 79881 - 2012-02-23 by VPO : le limite d'elt de facturation répartis est de 9
            #If [F:PFI]DSPLIN>1
            If [F:PFI]DSPLIN>1 & K<9
              [F:POH]INVDTALIN2(K)=[L]INVDTA   (J)
              [F:POH]INVDTAVAT2(K)=[L]INVDTAVAT(J)
              K+=1
            Endif
          Endif
        Next I
      Endif
    Endif
    Gosub BOUCLE2_POQ
Return

$BOUCLE2_POQ
    #-----
    # Issue 88474 - 2013-05-06 by SR
    If val(VERSION)<GMIGX3VER60
      Raz WTOTLINAMT, [F:POH]TOTLINATI
    Endif
    Link [POQM] With [ITM]ITM0=[F:POQM]ITMREF As [LNKQ]
    For [LNKQ]POQ0 Where POHNUM=[F:POH]POHNUM
      #Raz [F:POQ]
      # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER60
        Gosub RAZV6_POQ
      Endif
      If val(VERSION)<GMIGX3VER70
        Gosub RAZV7_POQ
      Endif
      # Issue 112754 - 2016-12-19 by SR : Services en V12
      #  version < V12, raz des champs v12
      If val(VERSION)<GMIGX3VER120
         Gosub RAZV12_POQ
      Endif
      [F:POQ] = [F:POQM]
      # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER60
        WPOPLIN=[F:POQ]POPLIN
        #----- Alimentation sté, adresse facturant et expéditeur sur lignes commande -----#
        [F:POQ]CPY      =[F:POH]CPY
        [F:POQ]BPAINV   =[F:POH]BPAINV
        #----- Alimentation du type d'achat -----#
        If [F:POQ]LINPURTYP=0  [F:POQ]LINPURTYP=1 : Endif
        #----- Alimentation du type de ligne -----#
        If [F:POQ]LINTYP=0  [F:POQ]LINTYP=1 : Endif
        #----- Alimentation des quantités poids et volume (sauf ligne service) -----#
        If find([F:POQ]LINTYP,1,2,4)
          Gosub LECT_ITMPOQ
          #-----
          [F:POQ]QTYWEU=[F:ITM]ITMWEI*[F:POQ]QTYSTU
          [F:POQ]QTYVOU=[F:ITM]ITMVOU*[F:POQ]QTYSTU

          WUOM1=[F:ITM]WEU
          WUOM2=[F:POH]DSPWEU
          WQTY=[F:POQ]QTYWEU
          Gosub CONVERT_QTY From UUMGTRTPUR00
          [F:POQ]QTYWEU=WQTY

          WUOM1=[F:ITM]VOU
          WUOM2=[F:POH]DSPVOU
          WQTY=[F:POQ]QTYVOU
          Gosub CONVERT_QTY From UUMGTRTPUR00
          [F:POQ]QTYVOU=WQTY
        Endif
        #----- Si ce n'est pas un service, qté, poids et volume pour répartition -----#
        If [F:POQ]LINTYP<>3
          WQTYPUU=[F:POQ]QTYPUU
          WQTYWEU=[F:POQ]QTYWEU
          WQTYVOU=[F:POQ]QTYVOU
        Endif
        #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
        If ([F:POQ]CLCAMT1<>0 | [F:POQ]CLCAMT2<>0)
&           & [F:POQ]CLCAMT3=0
&           & [F:POQ]CLCAMT4=0
&           & [F:POQ]CLCAMT5=0
&           & [F:POQ]CLCAMT6=0
&           & [F:POQ]CLCAMT7=0
          #----- Lecture ligne commande prix -----#
          Gosub LECT_POPPOQ
          #-----
          Raz WCLCAMT, WCLCFLG
          WCLCAMT1=[F:POQ]CLCAMT1 : WCLCFLG1=0
          WCLCAMT2=[F:POQ]CLCAMT2 : WCLCFLG2=0
          For I=2 To 3
            Case I
              When 2 : WTAX=[F:POP]VAT(I-1) : Gosub TRT_BASE
              When 3 : WTAX=[F:POP]VAT(I-1) : Gosub TRT_BASE
            Endcase
          Next I
          If WCLCFLG1 | WCLCFLG2
            If WCLCFLG1  Raz [F:POQ]CLCAMT1 : Endif
            If WCLCFLG2  Raz [F:POQ]CLCAMT2 : Endif
            For I=2 To 3
              If WCLCFLG(I)=1
                ##Assign "[F:POQ]CLCAMT"+num$(I) With WCLCAMT(I)
                Case I
                When 2 : [F:POQ]CLCAMT2=WCLCAMT(I)
                When 3 : [F:POQ]CLCAMT3=WCLCAMT(I)
                When Default
                Endcase
              Endif
            Next I
          Endif
        Endif
        #----- Calcul bases et taxes de la ligne de commande -----#
        If [F:POQ]LINTYP<>2 & [F:POQ]WIPSTA<2 & [F:POQ]LINSTA<>3
          WTOTLINAMT+=[F:POQ]LINAMT
          Gosub LECT_POPPOQ
          If WOKPOPPOQ
            #----- Pour toutes les commandes -----#
            Gosub MAJ_CALTAX_LIG    : # Calcul bases et taxes ligne
            #----- Si commande classique -----#
            If [F:POH]POHTYP=1
              Gosub MAJ_BASTAX_LIG  : # Màj bases et taxes pied à partir des lignes
              Gosub MAJ_ELEMENTS    : # Répartition éléments pied sur ligne et maj bases et taxes
            Endif
            #-----
          Endif
          #----- Total TTC lignes -----#
          [F:POH]TOTLINATI+=[F:POQ]LINATI
        Endif
        #----- Mise à jour type d'engagement (HT/HTND/TTC) -----#
        If [F:POQ]CMMTAX=0  [F:POQ]CMMTAX=1 : Endif
        #----- Mise à jour indicateur d'engagement (0=inactif, 1=actif) -----#
        If [F:POQ]CMMNUM<>"" & [F:POQ]LINCLEFLG<>2
          [F:POQ]CMMFLG=1
        Else
          [F:POQ]CMMFLG=0
        Endif
        #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
        If dim([F:POQM]MFGITM)>0    & [F:POQ]ITMREFORI="" [F:POQ]ITMREFORI=[F:POQM]MFGITM    : Endif
        If dim([F:POQM]MFGNUM)>0    & [F:POQ]VCRNUMORI="" [F:POQ]VCRNUMORI=[F:POQM]MFGNUM    : Endif
        If dim([F:POQM]OPENUM)>0    & [F:POQ]VCRLINORI=0  [F:POQ]VCRLINORI=[F:POQM]OPENUM    : Endif
        If dim([F:POQM]OPESPLNUM)>0 & [F:POQ]VCRSEQORI=0  [F:POQ]VCRSEQORI=[F:POQM]OPESPLNUM : Endif
        If [F:POQ]VCRNUMORI<>""    & [F:POQ]VCRTYPORI=0  [F:POQ]VCRTYPORI=10               : Endif
        #-----
      Endif
      # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER70
      # Mettre à jour les nouvelles zones V7
        [F:POQ]NETCUR = [F:POH]CUR
        [F:POQ]CPRCOE = 1
        [F:POQ]LINVOU = WDSPVOU
        [F:POQ]LINWEU = WDSPWEU
        [F:POQ]CPRCUR = GLOCALDEV
        Gosub CLC_POQ
      Endif
      # Issue 112754 - 2017-01-26 by SR : Services
      If val(VERSION)<GMIGX3VER120
       If    [F:POQ]POHTYP = 1 & [F:POQ]LINTYP <> 3  & [F:POQ]VCRTYPORI <> 10 : [F:POQ]ITMKND = 1
       Elsif [F:POQ]POHTYP = 1 & [F:POQ]LINTYP = 1   & [F:POQ]VCRTYPORI =  10 : [F:POQ]ITMKND = 2
       Elsif [F:POQ]POHTYP = 1 & [F:POQ]LINTYP = 3 : [F:POQ]ITMKND = 2
       Elsif [F:POQ]POHTYP = 2 : [F:POQ]ITMKND = 1
       Endif
      Endif
      # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#      If NEWMOTEUR
#          Gosub POQ_STK : # pour stocker ref
#          WriteB [POQ]
#      Else
#          Write [POQ]
#      Endif
#      If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
#            Gosub POQ_ERRTRA : # pour afficher les ref
#          Else
#            Call ECR_TRACE("File PORDERQ(POHNUM/POPLIN/POQSEQ)="-[F:POHQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#          Endif
#          GOK=0 : Break
#      Endif
       Gosub POQ_STK : # pour stocker ref
       WriteB [POQ]
       If fstat
          Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
          Gosub POQ_ERRTRA : # pour afficher les ref
          GOK=0 : Break
       Endif
      # End issue 108760
      # Issue 88474 - 2013-05-06 by SR
      If val(VERSION)<GMIGX3VER60
        #----- Création lignes comptables analytiques pour commandes classiques -----#
        If [F:POH]POHTYP=1
          Gosub LECT_POPPOQ
          If WOKPOPPOQ
            Gosub WRITE_CAL_POP
            If GOK<1 : Break : Endif
          Endif
        Endif
      Endif
    Next
Return

$WRITE_CAL_POP
  Raz [F:CAL]
  [F:CAL]ABRFIC="POP"
  [F:CAL]VCRNUM=[F:POP]POHNUM
  [F:CAL]VCRLIN=[F:POP]POPLIN
  [F:CAL]VCRSEQ=[F:POP]POPSEQ
  [F:CAL]ANALIG=1
  For I=1 To max(GNBCOA,2)
    [F:CAL]LED(I-1)=GLEDSOC(I)
    [F:CAL]COA(I-1)=GCOA(I)
  Next I
  [F:CAL]ACC(0)=[F:POQM]LINACC
  [F:CAL]ACC(1)=[F:POQM]LINCNA
  For I=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(I-1)=GDIE(I)
    ##If evalue("dim([F:POP]CCE"+num$(I)+")")>0
    ##  [F:CAL]CCE(I-1)=evalue("[F:POP]CCE"+num$(I))
    ##Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:POPM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:POPM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:POPM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:POPM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:POPM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:POPM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:POPM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:POPM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:POPM]CCE9
    When Default
    Endcase
  Next I

  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#      WriteB [F:CAL]
#  Else
#      Write [F:CAL]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#    Call ECR_TRACE("File CPTANALIN POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#  Endif
   Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
   WriteB [F:CAL]
   If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
      GOK=0 : Return
   Endif
   # End issue 108760

Return

$LECT_POPPOQ
If WREADPOPPOQ=0
  WOKPOPPOQ=0
  If [F:POH]POHTYP=1
    Read [POPM] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
  Else
    Filter [POPM] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
    Read [POPM] POP1 First
    Filter [POPM]
  Endif
  If fstat
     Raz [F:POP]
  Else
     [F:POP]=[F:POPM]
     WOKPOPPOQ=1
  Endif
  WREADPOPPOQ=1
Endif
Return

$BOUCLE1_POQ
    Link [POQM] With [ITM]ITM0=[F:POQM]ITMREF As [LNKQ]
    For [LNKQ]POQ0 Where POHNUM=[F:POH]POHNUM
      [F:POQ]=[F:POQM]
      #----- Calcul total des montants Ht ligne -----#
      If [F:POQ]LINTYP<>2 & [F:POQ]WIPSTA<2 & [F:POQ]LINSTA<>3
        [F:POH]TOTLINAMT+=[F:POQ]LINAMT
      Endif

      #----- Calcul total des quantités UA, poids, volume -----#
      If find([F:POQ]LINTYP,0,1,2,4)<>0
        Gosub LECT_ITMPOQ
        #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
        If [F:POH]DSPWEU=""  [F:POH]DSPWEU=[F:ITM]WEU : Endif
        If [F:POH]DSPVOU=""  [F:POH]DSPVOU=[F:ITM]VOU : Endif
        #-----
        [F:POQ]QTYWEU=[F:ITM]ITMWEI*[F:POQ]QTYSTU
        [F:POQ]QTYVOU=[F:ITM]ITMVOU*[F:POQ]QTYSTU

        WUOM1=[F:ITM]WEU
        WUOM2=[F:POH]DSPWEU
        WQTY=[F:POQ]QTYWEU
        Gosub CONVERT_QTY From UUMGTRTPUR00
        [F:POQ]QTYWEU=WQTY

        WUOM1=[F:ITM]VOU
        WUOM2=[F:POH]DSPVOU
        WQTY=[F:POQ]QTYVOU
        Gosub CONVERT_QTY From UUMGTRTPUR00
        [F:POQ]QTYVOU=WQTY
        #----- Cumuls qtés ligne -----#
        If [F:POQ]WIPSTA<2 & [F:POQ]LINSTA<>3 & [F:POH]POHTYP<>2
          [F:POH]TOTLINQTY+=[F:POQ]QTYPUU
          [F:POH]TOTLINWEU+=[F:POQ]QTYWEU
          [F:POH]TOTLINVOU+=[F:POQ]QTYVOU
        Endif
      Endif
    Next
Return


# Issue 88474 - 2013-05-06 by SR
###############################################
$CLC_POQ
# Calcul du CPR, cout achat et Montant achat
# Si SST (composé ou composant), pas de calcul
If [F:POQ]LINTYP>1 : Return : Endif
#-----
# WBASE,WMT pour le CPR, WBASE1,WMT1 pour LINCSTPUR
If [F:POQ]QTYUOM<>0
  WBASE=[F:POP]NETPRI*[F:POQ]QTYUOM : # Mt ligne avec précision maxi
Else
  WBASE=[F:POQ]LINAMT               : # Mt ligne arrondi suivant devise
Endif
WBASE1 = WBASE
#----- Eléments provenant du tarif -----#
# Issue 97209 - 2014-02-25 by SR : Remplacer POQ par POP
For I=1 To 9
  If GINVDTALIN(I-1)<>0
    Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
       #----- C'est un montant -----#
       If GDISCRGTYP(I-1)=1
         If GCLCRUL(I-1)=1 : # Par unité
           WMT1=evalue("[F:POP]DISCRGVAL"+num$(I))*[F:POQ]QTYUOM
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1 : Endif
         Else              : # Par ligne
           WMT1=evalue("[F:POP]DISCRGVAL"+num$(I))
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1 : Endif
         Endif
       #----- C'est un pourcentage -----#
       Else
          WMT1=arr([F:POQ]LINAMT*evalue("[F:POP]DISCRGVAL"+num$(I))/100,WRND)
          If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1 : WMT=WMT1 : Endif

       Endif
      If GINCDCR(I-1)=2  WBASE1-=WMT1  Else WBASE1+=WMT1 : Endif
      If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1
        If GINCDCR(I-1)=2  WBASE-=WMT  Else WBASE+=WMT : Endif
      Endif

  Endif
Next I
#----- Eléments provenant du pied de commande -----#
For I=1 To 9
  If [F:POH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:POH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    WBASE1+=evalue("[F:POQ]DISCRGAMT"+num$(I))
    If [F:PFI]NPRVLT=2
       WBASE+=evalue("[F:POQ]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I
#----- Conversion si nécessaire du montant en devise société -----#
If [F:POH]CUR<>GLOCALDEV
  WMT=WBASE
  Call CONVERT2([F:POH]CUR, GLOCALDEV, GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WMT,WBASE,STAT) From TRTDEV
  WBASE=arr(WBASE,10^-GDECPRI)
  WMT=WBASE1
  Call CONVERT2([F:POH]CUR, GLOCALDEV, GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WMT,WBASE1,STAT) From TRTDEV
  WBASE1=arr(WBASE1,10^-GDECPRI)
Endif
#----- Calcul prix unitaire d'achat en devise société et par unité de stock -----#
#----- Récupération prix d'achat sur commande -----#
WPRIPUR=[F:POP]NETPRI

WUOM  =[F:POQ]UOM
WCUR  =[F:POH]CUR

#--- Issue 111891
#WCOEFF = [F:POQ]QTYSTU / [F:POQ]QTYUOM
If [F:POQ]QTYUOM=0
  WCOEFF=1
Else
  WCOEFF=[F:POQ]QTYSTU/[F:POQ]QTYUOM
Endif
#---

#----- Conversion si nécessaire du montant en devise société -----#
If WCUR<>GLOCALDEV
  Call CONVERT2(WCUR,GLOCALDEV, GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif
#----- Le prix unitaire d'achat doit être par unité de stock -----#
If WUOM<>[F:POQ]STU
  If WCOEFF=0  WCOEFF=1 : Endif
  WPRIPUR=arr(WPRIPUR/WCOEFF,10^-GDECPRI)
Else
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
#&             [F:POQ]ITMREF,[F:POH]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
#WCPRAMT = arr([F:POQ]CPRAMT/WUOMSTUCOE,10^-GDECPRI)

#----- Calcul du prix unitaire de revient théorique en US -----#
If [F:POQ]QTYSTU<>0
  [F:POQ]CPRPRI=arr(WBASE/[F:POQ]QTYSTU,10^-GDECPRI)
Else
  [F:POQ]CPRPRI=WBASE
Endif


#----- Taxes non déductible -----#
# Issue 93448 - 2013-10-18 by MUARN : wtaxe non réinitialisé
WTAXE=[F:POQ]AMTTAXLIN1-[F:POQ]DEDTAXLIN1
WTAXE+=[F:POQ]AMTTAXLIN2-[F:POQ]DEDTAXLIN2
WTAXE+=[F:POQ]AMTTAXLIN3-[F:POQ]DEDTAXLIN3
WTAXE+=[F:POQ]AMTTAXRCP -[F:POQ]DEDTAXRCP
WTAXE+=[F:POQ]AMTTAXISS -[F:POQ]DEDTAXISS
WTAXE+=[F:POQ]AMTTAXOTH1-[F:POQ]DEDTAXOTH1
WTAXE+=[F:POQ]AMTTAXOTH2-[F:POQ]DEDTAXOTH2
If [F:POH]CUR<>GLOCALDEV
    WMT=WTAXE
    Call CONVERT2([F:POH]CUR, GLOCALDEV, GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WMT,WTAXE,STAT) From TRTDEV
      WTAXE=arr(WTAXE,10^-GDECPRI)
Endif
#----- Calcul prix de revient -----#
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:POQ]CPR   =[F:POQ]CPRPRI-WPRIPUR+(WPRIPUR*[F:POQ]CPRCOE)+WCPRAMT
[F:POQ]CPR   =[F:POQ]CPRPRI-WPRIPUR+(WPRIPUR*[F:POQ]CPRCOE)
If [F:POQ]QTYSTU<>0
   If GNODVATSTO = 2
    [F:POQ]CPR   += (WTAXE/[F:POQ]QTYSTU)
   Endif
Endif
[F:POQ]CPR   =arr([F:POQ]CPR,10^-GDECPRI)

#----- Calcul Montant achat ----#
# Issue number 92804 - 2013-09-19 by SR : Pour coût achat WPRIPUR doit être un montant
If [F:POQ]QTYUOM<>0
  WPRIPUR=[F:POP]NETPRI*[F:POQ]QTYUOM : # Mt ligne avec précision maxi
Else
  WPRIPUR=[F:POQ]LINAMT               : # Mt ligne arrondi suivant devise
Endif

# Issue 93448 - 2013-10-11 by MUARN : conversion en devise si nécessaire
#----- Conversion si nécessaire du montant en devise société -----#
If [F:POH]CUR<>GLOCALDEV
  Call CONVERT2([F:POH]CUR, GLOCALDEV, GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

WBASE1 += WTAXE
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:POQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:POQ]CPRCOE))+WCPRAMT
# Issue 91723 by TS
#[F:POQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:POQ]CPRCOE))
[F:POQ]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*[F:POQ]CPRCOE)
[F:POQ]LINCSTPUR=arr([F:POQ]LINCSTPUR,10^-GDECPRI)
 #----- Calcul Montant stock et cout achat-----#
If [F:POQ]QTYSTU<>0
  [F:POQ]LINAMTCPR = arr([F:POQ]CPR*[F:POQ]QTYSTU,10^-GDECPRI)
  [F:POQ]CSTPUR=arr([F:POQ]LINCSTPUR/[F:POQ]QTYSTU,10^-GDECPRI)
Else
  [F:POQ]LINAMTCPR=[F:POQ]CPR
  [F:POQ]CSTPUR   =[F:POQ]LINCSTPUR
Endif

Return

##################################
$LECT_ITMPOQ
  If [F:ITM]ITMREF<>[F:POQ]ITMREF
    WITM=[F:POQ]ITMREF
    Gosub LECT_ITM
  Endif
Return

$LECT_ITM
    Read [ITM] ITM0=WITM : If fstat  Raz [F:ITM] : Endif
Return

##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If WTAX<>""
  WJTVT=find(WTAX,WTVTVAT(0..NBTVT))
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=2 & WCLCAMT1<>0
    WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
  Endif
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=3 & WCLCAMT2<>0
    WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
  Endif
Endif
Return


#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 19/12/07 #
#                     de la ligne de commande                           #
#########################################################################
$MAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1)=[F:POP]VAT(0) : WCLCAMT(1)=[F:POQ]CLCAMT1
    When 2 : TAXE(2)=[F:POP]VAT(1) : WCLCAMT(2)=[F:POQ]CLCAMT2
    When 3 : TAXE(3)=[F:POP]VAT(2) : WCLCAMT(3)=[F:POQ]CLCAMT3
  Endcase
Next I
#-----
Raz MONTANT,MONTDED
Call CALTAXE2(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,3,TAXE,1,[F:POQ]LINAMT,WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:POQ]BASTAXLIN1=[F:POQ]LINAMT
      [F:POQ]AMTTAXLIN1=MONTANT(1)
      [F:POQ]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:POP]VAT(1)=""
        Raz [F:POQ]AMTTAXLIN2, [F:POQ]DEDTAXLIN2
      Else
        [F:POQ]AMTTAXLIN2=MONTANT(2)
        [F:POQ]DEDTAXLIN2=MONTDED(2)
        WJTVT=find([F:POP]VAT(1),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:POQ]BASTAXLIN1+=[F:POQ]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:POP]VAT(2)=""
        Raz [F:POQ]AMTTAXLIN3, [F:POQ]DEDTAXLIN3
      Else
        [F:POQ]AMTTAXLIN3=MONTANT(3)
        [F:POQ]DEDTAXLIN3=MONTDED(3)
        WJTVT=find([F:POP]VAT(2),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:POQ]BASTAXLIN1+=[F:POQ]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:POH]VACTYP<>4
  [F:POQ]LINATI=[F:POQ]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN1
      When 2 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN2
      When 3 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:POQ]LINATI=[F:POQ]LINAMT
Endif
[F:POQ]LINATIAMT=[F:POQ]LINATI
#----- Si commande ouverte, c'est fini ! -----#
If [F:POH]POHTYP=2  Return : Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
##  If evalue("dim([F:POP]DISCRGVAL"+num$(I)+")")>0

    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0

    Case I
    When 1 : WDISCRGVAL=[F:POP]DISCRGVAL1
    When 2 : WDISCRGVAL=[F:POP]DISCRGVAL2
    When 3 : WDISCRGVAL=[F:POP]DISCRGVAL3
    When 4 : WDISCRGVAL=[F:POP]DISCRGVAL4
    When 5 : WDISCRGVAL=[F:POP]DISCRGVAL5
    When 6 : WDISCRGVAL=[F:POP]DISCRGVAL6
    When 7 : WDISCRGVAL=[F:POP]DISCRGVAL7
    When 8 : WDISCRGVAL=[F:POP]DISCRGVAL8
    When 9 : WDISCRGVAL=[F:POP]DISCRGVAL9
    When Default
    Endcase


      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(WDISCRGVAL*[F:POQ]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=WDISCRGVAL
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:POQ]LINAMT*WDISCRGVAL/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:POH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:POP]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:POQ]BASTAXLIN1+=BASE
          [F:POQ]AMTTAXLIN1+=MONTANT(1)
          [F:POQ]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----#
      J=find(GINVDTALIN(I-1),[L]INVDTA(0..[L]NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If [L]NBFAC>=dim([L]INVDTA)  Goto MAJ_SUIT1 : Endif
        #-----
        J=[L]NBFAC
        [L]NBFAC+=1
        [L]INVDTA   (J)=GINVDTALIN       (I-1)
        [L]INVLINFLG(J)=6
        [L]DEBCDT   (J)=GINCDCR          (I-1)
        [L]INVDTAVAT(J)=[F:POH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      [L]INVLINAMT(J)+=BASE
    Endif
##  Endif
$MAJ_SUIT1
Next I
#-----
Return


#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 19/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de commande                   #
#########################################################################
$MAJ_BASTAX_LIG
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3
  Case I
    When 1 : WTAX   =[F:POP]VAT(0)     : WBASE  =[F:POQ]BASTAXLIN1
             WAMTTAX=[F:POQ]AMTTAXLIN1 : WDEDTAX=[F:POQ]DEDTAXLIN1
    When 2 : WTAX   =[F:POP]VAT(1)     : WBASE  =[F:POQ]LINAMT
             WAMTTAX=[F:POQ]AMTTAXLIN2 : WDEDTAX=[F:POQ]DEDTAXLIN2
    When 3 : WTAX   =[F:POP]VAT(2)     : WBASE  =[F:POQ]LINAMT
             WAMTTAX=[F:POQ]AMTTAXLIN3 : WDEDTAX=[F:POQ]DEDTAXLIN3
  Endcase
  If WTAX<>""
    WJTVT=find(WTAX,WTVTVAT(0..NBTVT))
    If I>1 & WJTVT>0
      Case WTVTVATBAS(WJTVT-1)
        When 2 : WBASE=[F:POQ]CLCAMT2 : # Base spéciale 1
        When 3 : WBASE=[F:POQ]CLCAMT3 : # Base spéciale 2
        # Issue 98865 - 2014-04-07 by MUARN : taxe spéciales dans CLCAMT2 et CLCAMT3 non 1 et 2
      Endcase
    Endif
    #----- Recherche si taxe déja existante -----#
    J=find(WTAX,[L]TAX(0..[L]NBTAX-1))
    If J<>0 & [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
      K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
      If K<>0
        J+=K
        If [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
          K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----#
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
      If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT2 : Endif
      #-----
      J=[L]NBTAX
      [L]NBTAX+=1
      [L]TAX   (J)=WTAX
      [L]PURTYP(J)=[F:POQ]LINPURTYP
      If WJTVT>0
      [L]VATTYP(J)=WTVTVATTYP(WJTVT-1)
      Else
      [L]VATTYP(J)=0
      Endif
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    [L]BASTAX(J)+=WBASE
    [L]AMTTAX(J)+=WAMTTAX
    [L]DEDTAX(J)+=WDEDTAX
  Endif
$MAJ_SUIT2
Next I
Return


###############################################################################
# MAJ_ELEMENTS : S/P de répartition des éléments de facturation  MBT 20/12/07 #
#                  sur les lignes de commande avec màj des bases              #
#                  et calcul des taxes si taxe produit                        #
###############################################################################
$MAJ_ELEMENTS
For I=0 To [L]NBFAC-1
  If [L]INVLINFLG(I)>1 & [L]INVLINFLG<6 & find([L]INVDTA(I),[F:POH]INVDTALIN2(0..8))>0
    J=find([L]INVDTA(I),[F:POH]INVDTALIN2(0..8))
    If WTOTLINAMT<[F:POH]TOTLINAMT
      Raz MTLIG
      Case [L]INVLINFLG
        When 2 : #----- Prorata par quantités -----#
          If [F:POH]TOTLINQTY<>0
            MTLIG=[L]INVLINAMT(I)*WQTYPUU/[F:POH]TOTLINQTY
          Endif
        When 3 : #----- Prorata par montants -----#
          If [F:POH]TOTLINAMT<>0
            MTLIG=[L]INVLINAMT(I)*[F:POQ]LINAMT/[F:POH]TOTLINAMT
          Endif
        When 4 : #----- Prorata par poids -----#
          If [F:POH]TOTLINWEU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYWEU/[F:POH]TOTLINWEU
          Endif
        When 5 : #----- Prorata par volume -----#
          If [F:POH]TOTLINVOU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYVOU/[F:POH]TOTLINVOU
          Endif
      Endcase
      MTLIG=arr(MTLIG,WRND)
    Else
      MTLIG=[L]INVLINAMT(I)-[L]CUMLIG(I)
    Endif
    #----- Chargement du montant réparti sur la ligne de commande -----#
    Case J
    When 1 : [F:POQ]DISCRGAMT1=MTLIG
    When 2 : [F:POQ]DISCRGAMT2=MTLIG
    When 3 : [F:POQ]DISCRGAMT3=MTLIG
    When 4 : [F:POQ]DISCRGAMT4=MTLIG
    When 5 : [F:POQ]DISCRGAMT5=MTLIG
    When 6 : [F:POQ]DISCRGAMT6=MTLIG
    When 7 : [F:POQ]DISCRGAMT7=MTLIG
    When 8 : [F:POQ]DISCRGAMT8=MTLIG
    When 9 : [F:POQ]DISCRGAMT9=MTLIG
    When Default
    Endcase
    [L]CUMLIG(I)+=MTLIG
    #----- Traitement de la taxe du montant réparti si taxe produit -----#
    If [L]INVDTAVAT(I)="" & [F:POP]VAT(0)<>""
      #----- Recherche si taxe déja existante -----#
      J=find([F:POP]VAT(0),[L]TAX(0..[L]NBTAX-1))
      If J<>0 & [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
        K=find([F:POP]VAT(0),[L]TAX(J..[L]NBTAX-1))
        If K<>0
          J+=K
          If [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
            K=find([F:POP]VAT(0),[L]TAX(J..[L]NBTAX-1))
            If K<>0 J+=K Else J=0 : Endif
          Endif
        Else
          J=0
        Endif
      Endif
      #----- Nouvelle taxe -----#
      If J=0
        #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
        If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT3 : Endif
        #-----
        J=[L]NBTAX
        [L]NBTAX+=1
        [L]TAX   (J)=[F:POP]VAT(0)
        [L]PURTYP(J)=[F:POQ]LINPURTYP
        WJTVT=find([F:POP]VAT(0),WTVTVAT(0..NBTVT))
        If WJTVT>0
          [L]VATTYP(J)=WTVTVATTYP(WJTVT-1)
        Else
          [L]VATTYP(J)=0
        Endif
      Else
        J-=1
      Endif
      #-----
      Raz TAXE : TAXE(1)=[F:POP]VAT(0)
      Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                  MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
      #----- Mise à jour de la base et des montants de taxe -----#
      [F:POQ]BASTAXLIN1+=MTLIG
      [F:POQ]AMTTAXLIN1+=MONTANT
      [F:POQ]DEDTAXLIN1+=MONTDED
      If [F:POH]VACTYP<>4  [F:POQ]LINATIAMT+=MONTANT : Endif
      [L]BASTAX(J)+=MTLIG
      [L]AMTTAX(J)+=MONTANT
      [L]DEDTAX(J)+=MONTDED
      #-----
    Endif
  Endif
$MAJ_SUIT3
Next I
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTPUR02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR02(APPLI)
End

