#<AdxTL>@(#)0.0.0.0 $Revision$ Articles en inventaire
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSBI] : Transmask [M:SBI1] To [M:CSBI] # Issue 25606 [M:CSBI] = [M:SBI1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ACV]) = 0 : Local File ACTIV      [ACV] : Endif
If clalev([F:CUN]) = 0 : Local File CUNSESSION [CUN] : Endif
If clalev([F:CSD]) = 0 : Local File CUNSERDET  [CSD] : Endif                      # hcb 110327

If GWRHACT = 2                                                    # hcb 62371
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif


#lecture code activite nombre de lignes par liste d inventaire
Global Integer GCOD_INV
Read [ACV]CODACT="INV"
If !fstat
   GCOD_INV =[F:ACV]DIME
Endif
If clalev([F:CUL]) = 0 : Local File CUNLISTE   [CUL] : Endif

#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
Local Char    WCUNLISNUM(GLONVCR)   # hcb 62371

#
Gosub LOAD_SCREEN
#
NAVIG="CONSSBI"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SBI1]FLG = 0
[M:SBI1]    = [M:CSBI]
Return
############################################################
$AP_MAGNETO
[M:SBI1]FLG = 0
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SBI1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SBI1]ITMREFSTR = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SBI1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:SBI1]TCLCODSTR = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:SBI1]TCLCODEND = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> ""
        [M:SBI1]BUYSTR    = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) <> ""
        [M:SBI1]BUYEND    = PARAM(I)
      Endif
    When 9 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSBI]) <> 0 & [M:CSBI]MEMO = "STD"  : # <MG> 26/04/00
  [M:SBI1] = [M:CSBI]                            : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
[M:SBI1]FLG = 0
Return
############################################################
$LECTURE
If [M:SBI1]FLG = 2
  [M:SBI1]FLG = 0
  NBLU = 0
  Return
Endif

# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
# hcb 64146 deb
         WCUNLISNUM = "*"
         If dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
            Raz WCUNLISNUM
            Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,[M:SBI1]WRH) From STKINV
         Endif
         If WCUNLISNUM <> ""
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
         Endif
# hcb 64146 fin
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
# hcb 64146 deb
         WCUNLISNUM = "*"
         If dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
            Raz WCUNLISNUM
            Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,[M:SBI1]WRH) From STKINV
         Endif
         If WCUNLISNUM <> ""
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
         Endif
# hcb 64146 fin
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SBI2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
# hcb 64146 deb
         WCUNLISNUM = "*"
         If dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
            Raz WCUNLISNUM
            Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,[M:SBI1]WRH) From STKINV
         Endif
         If WCUNLISNUM <> ""
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
         Endif
# hcb 64146 fin
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
# hcb 64146 deb
         WCUNLISNUM = "*"
         If dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
            Raz WCUNLISNUM
            Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,[M:SBI1]WRH) From STKINV
         Endif
         If WCUNLISNUM <> ""
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
         Endif
# hcb 64146 fin
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SBI1]FLG = 0
  [M:SBI1]FLG = 1
  Raz [M:SBI2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
# hcb 62371 deb
   If  dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
       Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,[ITV]ITV0=[F:ITW]ITMREF;[F:ITW]STOFCY
&                As [LNK]
&                Where evalue(WFIL)    &
&                      evalue(WFILS)  &
&                      evalue(WFILSPE)
&                Order By Key ITW1
   Else

      Link [ITF] With [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY,
&                 [ITM]ITM0=[F:ITF]ITMREF
&            As [LNK]
&            Where evalue(WFIL)  &
&                  evalue(WFILS) &
&                  evalue(WFILSPE)
&            Order By Key ITF1
   Endif
# hcb 62371 fin
Endif
Return
############################################################
$LOAD_FILTER
#Préparation filtre [ITF]
WFIL = "[F:ITF]CUNFLG=2"
# Filtre site
If [M:SBI1]FCY <> ""
  WFIL += "&[F:ITF]STOFCY=[M:SBI1]FCY"
Endif
# Filtre article
If [M:SBI1]ITMREFSTR <> "" | [M:SBI1]ITMREFEND <> ""
  If [M:SBI1]ITMREFSTR = [M:SBI1]ITMREFEND
    WFIL += "&[F:ITF]ITMREF=[M:SBI1]ITMREFSTR"
  Else
    WFIL += "&[F:ITF]ITMREF>=[M:SBI1]ITMREFSTR&[F:ITF]ITMREF<=[M:SBI1]ITMREFEND"
  Endif
Endif
# Filtre gestionnaire
If [M:SBI1]BUYSTR <> "" | [M:SBI1]BUYEND <> ""
  If [M:SBI1]BUYSTR = [M:SBI1]BUYEND
    WFIL += "&[F:ITF]BUY=[M:SBI1]BUYSTR"
  Else
    WFIL += "&[F:ITF]BUY>=[M:SBI1]BUYSTR&[F:ITF]BUY<=[M:SBI1]BUYEND"
  Endif
Endif
# Filtre catégorie
If [M:SBI1]TCLCODSTR <> "" | [M:SBI1]TCLCODEND <> ""
  If [M:SBI1]TCLCODSTR = [M:SBI1]TCLCODEND
    WFIL += "&[F:ITM]TCLCOD=[M:SBI1]TCLCODSTR"
  Else
    WFIL += "&[F:ITM]TCLCOD>=[M:SBI1]TCLCODSTR&[F:ITM]TCLCOD<=[M:SBI1]TCLCODEND"
  Endif
Endif

# Filtre dépôt
If dim([M:SBI1]WRH)>0 and [M:SBI1]WRH <> ""                             # hcb 62371
   WFIL += "&[F:ITW]WRH=[M:SBI1]WRH"
Endif


Return
############################################################
$LOA_LIGNE
[M:SBI2] = [F:ITM]
[M:SBI2] = [F:ITV]
[M:SBI2] = [F:ITF]
[M:SBI2]BUY(nolign-1)    = [F:ITF]BUY
[M:SBI2]INTSTO(nolign-1) = [F:ITV]PHYSTO       +[F:ITV]CTLSTO       +[F:ITV]REJSTO
[M:SBI2]PLFSTO(nolign-1) = [F:ITV]PLFPHYSTO    +[F:ITV]PLFCTLSTO    +[F:ITV]PLFREJSTO
[M:SBI2]BPRSTO(nolign-1) = [F:ITV]BPRPHYSTO    +[F:ITV]BPRCTLSTO    +[F:ITV]BPRREJSTO
[M:SBI2]SCOSTO(nolign-1) = [F:ITV]SCOPHYSTO    +[F:ITV]SCOCTLSTO    +[F:ITV]SCOREJSTO

[M:SBI2]TOTSTO(nolign-1) = [F:ITV]PHYSTO       +[F:ITV]CTLSTO       +[F:ITV]REJSTO    +
&                          [F:ITV]PLFPHYSTO    +[F:ITV]PLFCTLSTO    +[F:ITV]PLFREJSTO +
&                          [F:ITV]BPRPHYSTO    +[F:ITV]BPRCTLSTO    +[F:ITV]BPRREJSTO +
&                          [F:ITV]SCOPHYSTO    +[F:ITV]SCOCTLSTO    +[F:ITV]SCOREJSTO

Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SBI2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # hcb 68703

# hcb 62371 deb
Raz WCUNLISNUM
If dim([M:SBI1]WRH)>0 & [M:SBI1]WRH <> ""
   Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,[F:ITF]CUNLISNUM,WCUNLISNUM,[M:SBI1]WRH) From STKINV
Else
   Call EXI_LIS([F:ITF]STOFCY,[F:ITF]ITMREF,[F:ITF]CUNLISNUM,WCUNLISNUM,"") From STKINV
Endif
If WCUNLISNUM <> ""
   [M:SBI2]CUNLISNUM(nolign-1) = "$"
   [M:SBI2]CUNSSSNUM(nolign-1) = "$"
Else
   Filter [CUL] Where STOFCY=[F:ITF]STOFCY & CUNLISNUM=[F:ITF]CUNLISNUM
&               Order By Key CUL1
   For [CUL]
       [M:SBI2]CUNSSSNUM(nolign-1) = [F:CUL]CUNSSSNUM
       If dim([M:SBI2]WRH)>0
          [M:SBI2]WRH   (nolign-1) = [F:CUL]WRH
       Endif
       Break
   Next
   Filter [CUL]
Endif
# hcb 62371 fin

Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SBI1]FLG = 0
#             hcb 62371 deb
If dim([M:SBI1]WRH) > 0
   Raz   [M:SBI1]WRH
   Affzo [M:SBI1]WRH
Endif
#             hcb 62371 fin

End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SBI1]FLG = 0
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SBI1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog AV_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]TCLCODSTR
Endif
End
############################################################
Subprog AV_BUYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]BUYSTR
Endif

End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 10/09/2003 11:23:20 (HCB)
##########################################################################
Subprog IB_NBLIG
# Bouton 1 :  Situation inventaire
# Bouton 5 :  Session
# Bouton 6 :  Inventaires
# Bouton 7 :  Visu liste
# Bouton 8 :  Listes    (cas plusieurs listes pour le meme article)

GBOUT5 = mess(51,184,1)   # Session
If  [M:SBI2]CUNSSSNUM(nolign-1) = ""
    GBOUT5 = ""
Endif
# Comptage liste
GBOUT6= mess(458,199,1)
# hcb 62371 deb
If [M:SBI2]CUNLISNUM(nolign-1) = "$"
   GBOUT1 = ""
   GBOUT5 = ""
   GBOUT6 = ""
   GBOUT7 = ""
   GBOUT8 = mess(490,198,1)
Else
   GBOUT8 = ""
Endif
# hcb 62371 fin

End

Subprog B5_NBLIG
Gosub SET_NOL From STKINV
GCONSULT = 2
Call OBJET("SNX",[M:SBI2]CUNSSSNUM(NOL),GBIDC1) From GOBJET
GCONSULT = 0

End

Subprog B6_NBLIG
Gosub SET_NOL From STKINV
GCONSULT = 2
Call OBJET("SNL",[M:SBI2]CUNLISNUM(NOL),[M:SBI2]CUNSSSNUM(NOL)) From GOBJET
GCONSULT = 0

End


##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SBI") From SUBGTC

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSBI1) 05/02/2010  # hcb 62371
######################################################################################
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
[M:SBI1]FLG = 0
End

Subprog AS_WRH(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
   mkstat = 2
   End
Endif
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End

