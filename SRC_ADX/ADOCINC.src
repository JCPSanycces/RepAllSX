#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCINC","ADOCINC",3,"") From GTRAITE
End

###############################################################
$ACTION
    Case ACTION
     When "OUVRE"        : Gosub OUVRE
     When "DEBUT"        : Gosub DEBUT
     When "RAF"          : Gosub RAF
     When "SETBOUT"      : Gosub SETBOUT
     When "OK"           : Gosub OK
     When "FIN"          : Gosub FIN
     When "EDI"          : Gosub EDIT
     When Default
    Endcase
Return
###################################################################

###################################################################
$OUVRE
  Gosub OUVRE_TABLES  From ADOCINC

  Local Integer DOC_TYPE_INC :[L]DOC_TYPE_INC=0
  Local Char    I_LAN(GLONLAN)
  # Variables pour inclusion
  Local Char    I_TYP(GLONADI), I_COD(30), I_PAR(GLONADI), I_TIT(80)
  Local Integer I_LEV         , I_SUBLEV , II
  Local Char    TEXTES(250)(1..2000)
  #Gosub DECL_COMVAR From AGENLIBA
Return

$SETBOUT
  Call VIREBOUT(CHMEN,"I=") From GOBJET

  CHBOU += "=" : # Raffraîchir
  If [M:ADOI]NBDOC>0
    CHBOU += "I" : # Impression
  Endif

  Gosub SET_BOUT_SPE From GSAISIE
Return

$OK
  Effzo [M:ADOI] 10-20
  If [M:ADOI]LAN <>"" & [M:ADOI]TYP <>"" & [M:ADOI]COD <>"" & [M:ADOI]LEV <>0 & [M:ADOI]SUBLEV <>0
    Gosub CHARGE_MASQUE  From ADOCINC
    Affzo [M:ADOI]
  Endif
  FIN=0
Return

$DEBUT
$RAF
  Raz [M:ADOI]
  [M:ADOI]LAN    = PARAM(1)
  [M:ADOI]TYP    = PARAM(2)
  [M:ADOI]COD    = PARAM(3)
  [M:ADOI]LEV    = val(PARAM(4))
  [M:ADOI]SUBLEV = val(PARAM(5))

  Gosub CHARGE_MASQUE  From ADOCINC
  Affzo [M:ADOI]
Return

$FIN
Return

$EDIT
  Local Char WLIBEL(250) : Raz WLIBEL
  Local Integer WNOLIBEL : Raz WNOLIBEL
  Local Integer OUVREAFC , OUVREATX
  If !clalev([F:AFCW])   : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
  If !clalev([F:ATXW])   : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif

  WNOLIBEL= 0
  Read [F:AFCW]CODINT = "ADOCINC"
  If [S]fstat = 0
    WNOLIBEL = [F:AFCW]LIBMENU
    Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
    If [S]fstat = 0
      WLIBEL= [F:ATXW]TEXTE
    Endif
  Endif

  If WLIBEL="" : WLIBEL="ADOCINC"  : Endif
  If OUVREAFC  : Close File [AFCW] : Endif
  If OUVREATX  : Close File [ATXW] : Endif

  Local Char TABMSK(GLONAMK)(1)
  Local Char TABABR(GLONABR)(1)
  #on les mets dans ce sens pour avoir les info regroupées
  TABMSK(0)="ADOCINC" : TABABR(0)="ADOI"
  Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
  Call IMPSCR From ATRTX3
Return
###################################################################

##########################################################################
# PARAGRAPHES UTILISES PAR CE PROGRAMME                                  #
##########################################################################
###################################################################################################
# Paragraphe servant à Ouvrir les Tables du dossier Courant et du dossier Racine
$OUVRE_TABLES
  If !clalev([ADO2])  :  Local File ADOCUMENT            [ADO2] : Endif
  If !clalev([ADH2])  :  Local File ADOCCLB              [ADH2] : Endif
  If !clalev([ZDO2])  :  Local File =GDOSX3+".ADOCUMENT" [ZDO2] : Endif
  If !clalev([ZDH2])  :  Local File =GDOSX3+".ADOCCLB"   [ZDH2] : Endif
Return

# Paragraphe servant à Charger les zones non-CLE du masque ADOCINC [M:ADOI]
$CHARGE_MASQUE
  Call RECH_PAR_ADOCUMENT([M:ADOI]LAN, [M:ADOI]TYP, [M:ADOI]COD, [M:ADOI]LEV, [M:ADOI]SUBLEV, [M:ADOI]PAR, [M:ADOI]TIT)
  If [M:ADOI]PAR = 'INC'
    Gosub RECH_DOC_INC  From ADOCINC
  Else
    [L]DOC_TYPE_INC=0
  Endif

  # Si Paragraphe de type INC : Recherche des cas d'emploi du paragraphe Inclu sinon du paragraphe courant
  Call TEMPON("L")    From GESECRAN
  If [L]DOC_TYPE_INC & [L]I_LAN<>"" & [L]I_TYP<>"" & [L]I_COD<>"" & [L]I_LEV<>0 & [L]I_SUBLEV<>0
    Call RECH_PAR_ADOCUMENT([L]I_LAN   , [L]I_TYP   , [L]I_COD   , [L]I_LEV   , [L]I_SUBLEV, [L]I_PAR, [L]I_TIT)
    If [L]I_PAR=""
      [M:ADOI]RECHKO  = mess(85,176,1)  # Paragraphe inexistant
    Endif
    Call CHARGE_ADOCINC    ([L]I_LAN   , [L]I_TYP   , [L]I_COD   , [L]I_LEV   , [L]I_SUBLEV)
  Else
    If [M:ADOI]PAR=""
      [M:ADOI]RECHKO  = mess(85,176,1)  # Paragraphe inexistant
    Endif
    Call CHARGE_ADOCINC([M:ADOI]LAN, [M:ADOI]TYP, [M:ADOI]COD, [M:ADOI]LEV, [M:ADOI]SUBLEV)
  Endif
  Call TEMPOFF        From GESECRAN
Return

# Paragraphe servant à Recherche un Lien de DOC sous la forme : TYP/COD ou TYP/COD/LEV/SUBLEV dans le dossier courant ou Racine
$RECH_DOC_INC
  [L]I_LAN=[M:ADOI]LAN : Raz [L]I_TYP, [L]I_COD, [L]I_LEV, [L]I_SUBLEV

  # Lecture CLOB du dossier Courant
  Read [ADH2]ADH0=[M:ADOI]LAN;[M:ADOI]TYP;[M:ADOI]COD;[M:ADOI]LEV;[M:ADOI]SUBLEV
  If !fstat
    Setlob TEXTES       With [ADH2]TEXTE
    Gosub DECOD_INCL    From ADOCINC
  Else
    # Lecture CLOB du dossier Racine
    Read [ZDH2]ADH0=[M:ADOI]LAN;[M:ADOI]TYP;[M:ADOI]COD;[M:ADOI]LEV;[M:ADOI]SUBLEV
    If !fstat
      Setlob TEXTES     With [ZDH2]TEXTE
      Gosub DECOD_INCL  From ADOCINC
    Else
      [L]DOC_TYPE_INC=0
    Endif
  Endif
Return

# Paragraphe servant à Décoder un Lien de DOC sous la forme : TYP/COD ou TYP/COD/LEV/SUBLEV
$DECOD_INCL
  Gosub RECH_INCL   From AGENDOCA
  If fstat
    [L]DOC_TYPE_INC=0
  Else
    [L]DOC_TYPE_INC=1
    # Cas ou le lien est sans Niveau/Sous-Niveau : Il faut prendre ceux de la doc courante
    If [L]I_LEV=0    : [L]I_LEV   =[M:ADOI]LEV     :  Endif
    If [L]I_SUBLEV=0 : [L]I_SUBLEV=[M:ADOI]SUBLEV  :  Endif
  Endif
Return


##########################################################################
# LISTE DES FONCTIONS ET PROCEDURES UTILES                               #
##########################################################################
# RECH_PAR_ADOCUMENT : Fonction de Lecture du Paragraphe de DOC à Rechercher soit dans le dossier Courant soit dans le dossier Racine
# CHARGE_ADOCINC     : Procédure de chargement de la recherche des Cas d'emploi d'un paragraphe de DOC donné en entrée
##########################################################################
###################################################################################################
Subprog RECH_PAR_ADOCUMENT(CLAN, CTYP, CCOD, CLEV, CSUBLEV, CPAR, CTIT)
Value    Char    CLAN(), CTYP() , CCOD()
Value    Integer CLEV  , CSUBLEV
Variable Char    CPAR(), CTIT()

  # Ouverture éventuelle des Tables dans le dossier Courant et le dossier Racine
  Gosub OUVRE_TABLES  From ADOCINC

  Read [ADO2]ADO0=CLAN;CTYP;CCOD;CLEV;CSUBLEV
  If fstat
    Read [ZDO2]ADO0=CLAN;CTYP;CCOD;CLEV;CSUBLEV
    If fstat
      Raz [ADO2]
    Else
      [ADO2]=[ZDO2]
    Endif
  Endif
  CPAR=[ADO2]PAR
  CTIT=[ADO2]TIT
End

###################################################################################################
Subprog CHARGE_ADOCINC(CLAN, CTYP, CCOD, CLEV, CSUBLEV)
Value    Char    CLAN()
Value    Char    CTYP()
Value    Char    CCOD()
Value    Integer CLEV
Value    Integer CSUBLEV

# Variables de travail
Local Char    CHAR_SLASH      : [L]CHAR_SLASH='/'
Local Char    INC_DOC(250)
Local Char    SQLREQ  (250) (3)
Local Char    VAPPREFOLD(30)  : Raz VAPPREFOLD
Local Integer V_MAXLIG        : V_MAXLIG=1000
# Variables pour inclusion
Local Char    I_TYP(GLONADI), I_COD(30)
Local Integer I_LEV         , I_SUBLEV ,II
Local Char    TEXTES(250)(1..2000)
#Gosub DECL_COMVAR From AGENLIBA

  If !clalev([AMZ2])          : Local File AMSKZON [AMZ2] : Endif
  Read [AMZ2]CODE="ADOCINC";"INCCOD"
  If [S]fstat = 0
    V_MAXLIG=[AMZ2]DIME
  Endif

  # [L]INC_DOC =CTYP+[L]CHAR_SLASH+CCOD+[L]CHAR_SLASH+num$(CLEV)+[L]CHAR_SLASH+num$(CSUBLEV)
  # Initialisation du champs de recherche au code de documentation pour pouvoir gérer les blancs éventuels
  [L]INC_DOC=CCOD

  Gosub   SET_FIRST   From TRTFIRST
  Onerrgo ERR_SQL_TRA

  Raz SQLREQ
  SQLREQ(0)    = "SELECT DISTINCT A.LAN_0,A.TYP_0,A.COD_0,A.LEV_0,A.SUBLEV_0,'"+nomap +"' FROM "+nomap +".ADOCCLB A"
  SQLREQ(0)   -= "WHERE A.LAN_0='"+CLAN+"' AND A.TEXTE_0 like '%"+[L]INC_DOC+"%'"
  If GDOSX3<>nomap
    SQLREQ(0) -= "UNION"
    SQLREQ(1) -= "SELECT DISTINCT B.LAN_0,B.TYP_0,B.COD_0,B.LEV_0,B.SUBLEV_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCCLB B"
    SQLREQ(1) -= "WHERE B.LAN_0='"+CLAN+"' AND B.TEXTE_0 like '%"+[L]INC_DOC+"%'"
    SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCCLB A"
    SQLREQ(2) -= "WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0 AND A.LEV_0=B.LEV_0 AND A.SUBLEV_0=B.SUBLEV_0)"
  Endif
  SQLREQ(2) -="ORDER BY 1,2,3,4,5"

  # On boucle sur LAN+TYP+COD+LEV+SUBLEV sur le dossier courant et/ou le dossier Racine
  For (Char VLAN(3), Char VTYP(10), Char VCOD(30), Integer VLEV, Integer VSUBLEV, Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDO0]
    If VAPPREFOLD<>[ZDO0]VAPPREF
      If  clalev([ZDO1]) : Close File [ZDO1]                             : Endif
      If !clalev([ZDO1]) : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO1] : Endif
      If  clalev([ZDH1]) : Close File [ZDH1]                             : Endif
      If !clalev([ZDH1]) : Local File =[ZDO0]VAPPREF+".ADOCCLB"   [ZDH1] : Endif
    Endif
    # En limite du nombre MAX de ligne du tableau : On sort en Avertissement
    If [M:ADOI]NBDOC >= V_MAXLIG
       Call MESSAGE(mess(41,176,1)+":"-mess(56,176,1)-num$(V_MAXLIG)) From GESECRAN
       Break
    Endif

    # On recupere les informations au niveau de l'en-Tête : ADOCUMENT et du texte : ADOCCLB
    Raz  [ZDH1]
    Read [ZDH1]ADH0=[ZDO0]VLAN;[ZDO0]VTYP;[ZDO0]VCOD;[ZDO0]VLEV;[ZDO0]VSUBLEV

    # Recherche Texte à Décoder un Lien de DOC sous la forme : TYP/COD ou TYP/COD/LEV/SUBLEV
    Setlob TEXTES     With [ZDH1]TEXTE
    Raz [L]I_TYP, [L]I_COD, [L]I_LEV, [L]I_SUBLEV
    Gosub RECH_INCL   From AGENDOCA

    # Si on a bien un Type de Doc + un Code DOC : Il s'agit bien d'un lien de DOC : on le prend
    If   ( [L]I_TYP<>"" & [L]I_TYP=CTYP ) & ( [L]I_COD<>""   & [L]I_COD=CCOD       )
      # Cas ou le lien est sans Niveau/Sous-Niveau : Il faut prendre ceux de la doc courante
      If [L]I_LEV=0    : [L]I_LEV   =[ZDH1]LEV     :  Endif
      If [L]I_SUBLEV=0 : [L]I_SUBLEV=[ZDH1]SUBLEV  :  Endif

      If ( [L]I_LEV<>0  & [L]I_LEV=CLEV ) & ( [L]I_SUBLEV<>0 & [L]I_SUBLEV=CSUBLEV )
        # On recupere les informations au niveau de l'en-Tête : ADOCUMENT
        Raz  [ZDO1]
        Read [ZDO1]ADO0=[ZDO0]VLAN;[ZDO0]VTYP;[ZDO0]VCOD;[ZDO0]VLEV;[ZDO0]VSUBLEV

        # On charge le masque : ADOCINC [ADOI]
        [M:ADOI]NBDOC +=1
        [M:ADOI]INCLAN   ([M:ADOI]NBDOC-1) = [ZDO0]VLAN
        [M:ADOI]INCTYP   ([M:ADOI]NBDOC-1) = [ZDO0]VTYP
        [M:ADOI]INCCOD   ([M:ADOI]NBDOC-1) = [ZDO0]VCOD
        [M:ADOI]INCLEV   ([M:ADOI]NBDOC-1) = [ZDO0]VLEV
        [M:ADOI]INCSUBLEV([M:ADOI]NBDOC-1) = [ZDO0]VSUBLEV
        [M:ADOI]INCPAR   ([M:ADOI]NBDOC-1) = [ZDO1]PAR
        [M:ADOI]INCMODULE([M:ADOI]NBDOC-1) = [ZDO1]MODULE
        [M:ADOI]INCCODACT([M:ADOI]NBDOC-1) = [ZDO1]CODACT
        [M:ADOI]INCVLDFLG([M:ADOI]NBDOC-1) = [ZDO1]VLDFLG
        [M:ADOI]INCVLDDAT([M:ADOI]NBDOC-1) = [ZDO1]VLDDAT
      Endif
    Endif

    # On mémorise l'ancien dossier pour le prochain enregistrement
    VAPPREFOLD=[ZDO0]VAPPREF
  Next ZDO0

  # Afffichage du nombre total d'enregistraments trouvés et de la Recherche de paragraphe
  [M:ADOI]RECH  = CTYP+[L]CHAR_SLASH+CCOD+[L]CHAR_SLASH+num$(CLEV)+[L]CHAR_SLASH+num$(CSUBLEV)
  [M:ADOI]TOTAL = [M:ADOI]NBDOC

  If clalev([ZDO1])  :  Close File [ZDO1] : Endif
  If clalev([ZDH1])  :  Close File [ZDH1] : Endif

  Sorta   [M:ADOI]NBDOC [M:ADOI]NBDOC
  Gosub   UNSET_FIRST   From TRTFIRST

  Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL_TRA
  GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
  Call ERREUR(GMESSAGE) From GESECRAN
  ERR=1
  End
Return
