#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM007
# Issue X3-7922/120161 - 2016-12-02 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM007(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM007(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR

  IERR = 0
  Call ECR_TRACE("UTIPJM007: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTSK
  #
  If filinfo(filpath("FIL", "PJMTSK", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSK" [PJTAC]  # Child
  Local File =SZAPPLI + ".PJMTSK" [PJTAP]  # Parent
  # -------------------------
  Trbegin [PJTAC]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM007: Updating PJMTSK", 0) From GESECRAN
  Filter [PJTAC] Where [F:PJTAC]TASPAE <> ""
  For [PJTAC]PTA0
    # -----------------------------
    Read [PJTAP]PTA0=[F:PJTAC]OPPNUM;[F:PJTAC]TASPAE
    If !fstat Then
      If [F:PJTAP]PBUCOD <> "" Then
        [F:PJTAP]PBUCOD = ""
        NCOUNT += 1
        Rewrite [PJTAP]
        If fstat Then
          Call ECR_TRACE("File PJMTSK" - [F:PJTAP]OPPNUM - [F:PJTAP]TASCOD + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
    Endif
    # -----------------------------
  Next
  Filter [PJTAC]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM007: PJMTSK" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM007: PJMTSK" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM007 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM007 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM007(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM007(APPLI)
End

