#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GLE
# LE          : 14 Février   2011 11:52:55
# Moulinette pour initialiser le paramètre ACCPERCTL
# FQ70465
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM026: Initialisation du paramètre ACCPERCTL") From LECFIC
  Call EXE_UTIIMM026(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM026(APPLI)
 Value Char APPLI
  If clalev([F:ADW]) : Close Local File [ADW] : Endif
  Local File =APPLI+".ADOVAL" [ADW]
  If clalev([F:CPY]) : Close Local File [CPY] : Endif
  Local File =APPLI+".COMPANY" [CPY]
  Call ECR_TRACE("UTIIMM026: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM026
  Call ECR_TRACE("UTIIMM026: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM026
  Local Integer N_ADW : N_ADW = 0
  Local Char    L_FRADGI

  Trbegin [F:ADW]

  # Paramètre à "Non" au niveau Dossier
  Look [F:ADW]ADW0="";"";"ACCPERCTL"
  If fstat
    Raz [F:ADW]
    [F:ADW]CMP    = ""
    [F:ADW]FCY    = ""
    [F:ADW]PARAM  = "ACCPERCTL"       
    [F:ADW]CREDAT = date$
    [F:ADW]CRETIM = time
    [F:ADW]CREUSR = GUSER
    [F:ADW]VALEUR = "1"
    Write [F:ADW]
    If fstat
      Call ECR_TRACE("Error writing ADOVAL :"-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM-num$(fstat),1) From GESECRAN
      GOK = 0
    Endif
    N_ADW += 1
  Endif

  # Paramètre à "Oui" au niveau de la législation "FRA"
  Look [F:ADW]ADW0="*";"FRA";"ACCPERCTL"
  If fstat
    Raz [F:ADW]
    [F:ADW]CMP    = "*"
    [F:ADW]FCY    = "FRA"
    [F:ADW]PARAM  = "ACCPERCTL"       
    [F:ADW]CREDAT = date$
    [F:ADW]CRETIM = time
    [F:ADW]CREUSR = GUSER
    [F:ADW]VALEUR = "2"
    Write [F:ADW]
    If fstat
      Call ECR_TRACE("Error writing ADOVAL :"-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM-num$(fstat),1) From GESECRAN
      GOK = 0
    Endif
    N_ADW += 1
  Endif

  For [CPY] Where LEG = "FRA"
    L_FRADGI = func AFNC.PARAM("FRADGI",[CPY]CPY)
    Read [F:ADW]ADW0=[F:CPY]CPY;"";"ACCPERCTL"
    
    If fstat and L_FRADGI <> "2"
      # La société est en législation FRA mais ne suit pas les obligations DGI. Le paramètre est créé pour la société à "Non"
      Raz [F:ADW]
      [F:ADW]CMP    = [F:CPY]CPY
      [F:ADW]FCY    = ""
      [F:ADW]PARAM  = "ACCPERCTL"       
      [F:ADW]CREDAT = date$
      [F:ADW]CRETIM = time
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
        Call ECR_TRACE("Error writing ADOVAL :"-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM-num$(fstat),1) From GESECRAN
        GOK = 0
        Break
      Endif
      N_ADW += 1
    Else
      If L_FRADGI <> "2" and [F:ADW]VALEUR = "2"
        # La société est en législation FRA mais ne suit pas les obligations DGI. Le paramètre est mis à jour pour la société à "Non"
        [F:ADW]UPDDAT = date$
        [F:ADW]UPDTIM = time
        [F:ADW]UPDUSR = GUSER        
        [F:ADW]VALEUR = "1"
        Rewrite [F:ADW]
        If fstat
          Call ECR_TRACE("Error rewriting ADOVAL :"-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM-num$(fstat),1) From GESECRAN
          GOK = 0
          Break
        Endif
        N_ADW += 1
      Endif
    Endif
  Next

  If !GOK Then
    Goto AB_UTIIMM026
  Else
    Call ECR_TRACE("ADOVAL records created/updated :"-num$(N_ADW),0) From GESECRAN
    Commit
  Endif
Return

$AB_UTIIMM026
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","COMPANY","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM026(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","COMPANY","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM026(APPLI)
End
