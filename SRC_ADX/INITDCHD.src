#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("DCHARGES","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()

Gosub OUVFIC From INITDCH
Gosub DECLARATION From INITDCH
Local Char PARAM(30), VALEUR(30)

#56589
Local Integer RAZVEP

#Recup no de requete
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
CRITCPY="1=1"
CRITFCY="1=1"
CRITDCH="OPTSAL<>6 & OPTSAL<>7"
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "datdeb"      : If [L]VALEUR<>[0/0/0]
                         [L]VDATDEB =[L]VALEUR
                        Endif
   When "datfin"      : If [L]VALEUR<>[0/0/0]
                         [L]VDATFIN =[L]VALEUR
                        Endif
   When "cpy"         : If [L]VALEUR<>""
                         [L]CRITCPY -= '& [F:FGR]CPY="'+[L]VALEUR+'"'
                        Else
                         Call ERREUR (mess(68,10702,1)) From GESECRAN
                         GOK=0 : End
                        Endif
   When "fcydeb"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY>="'+[L]VALEUR+'"'
                        Endif
   When "fcyfin"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY<="'+[L]VALEUR+'"'
                        Endif
   When "detfcy"      : If [L]VALEUR="1": #Oui
                         [L]DETAIL =2
                        Else
                         [L]DETAIL =1
                        Endif
   When "declaration" : If [L]VALEUR<>""
                         [L]CRITDCH -= '& [F:DCH]EDTDCC="'+[L]VALEUR+'"'
                        Endif
   When "org"         : If [L]VALEUR<>""
                         [L]ORGANISME =[L]VALEUR
                        Endif
   When "arrbas"      : If [L]VALEUR="1" :#Oui
                         [L]ARRBASE= 2
                        Else
                         [L]ARRBASE=1
                        Endif
   When "arrmtt"      : If [L]VALEUR="1" :#Oui
                         [L]ARRMONTANT=2
                        Else
                         [L]ARRMONTANT=1
                        Endif
  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Gosub EFFACE From INITDCH
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [TM2]
Gosub TR1
Commit
End


########################################
$TR1
LIG=1
For [F:FGR]FGR0 Where evalue (CRITCPY)& evalue(CRITFCY)
 Gosub REINIT From INITDCH
 Read [F:FCY]FCY0 = [F:FGR]FCY
 If DETAIL=2
  SITE=[F:FGR]FCY
 Else
  SITE=[F:FGR]CPY
 Endif
 For [F:DCH]DCH1 Where evalue(CRITDCH)
  Gosub REINIT From INITDCH
  Gosub RECUP_RUB From INITDCH
  If OK =1
   #87135 : CICE
   Read[F:ADI]CODE=377;[F:DCH]CODDCS
   If !fstat
    If [F:ADI]A2='400'
      Gosub TR_CICE
    Else
     For [F:VEP]VEP0(1) Where PYRDAT>=VDATDEB & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
      MATRI=[F:VEP]EMP
      Read [ID]ID0=MATRI
      #63102 : Lectures inutiles = ralentissements
      If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
      #
      #55538
      NBVEP=0
      For [F:VEP]VEP0
       ##56589
       If NBVEP=0 : RAZVEP=1 : Else : RAZVEP=0 : Endif
       #
       DATMAT=[F:VEP]ENDDAT
       CTR=[F:VEP]CTRNUM
       #63102
       #Gosub LECEMP From WPDEFTABLE
       Gosub LECEMP From INITDCH
       #
       FLAG=1 :  DREF=[F:VEP]PYRDAT
       Gosub CODEXO From INITDCH
       Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
       If ORGANISME="" or ORGANISME=ORGCOURANT
        Gosub POPULATION From INITDCH
        If SALOK
         For R=1 To NRUB
          #44181
          #NBVEP=0
          Gosub REINIT From INITDCH
          Read[RUB]RUB0=GCURLEG;RUBCOD(R)
          If fstat : Break : Endif
          VDEBUT=0 : VFIN=0
          Case TYPECAL(R)
           When 1 : VDEBUT=1 : VFIN=1 :#PS
           When 2 : VDEBUT=2 : VFIN=2 :#PP
           When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
          Endcase
          If VDEBUT
           Gosub RECUP_AT From INITDCH
           For I=VDEBUT To VFIN
            Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
            If !fstat
             If FLGQTY(R)=2  :# Une quantité = Base
              QTY+=[F:HSP]BAS
             Endif
             TAUX+=[F:HSP]RAT
             If I=1   :#salarial
              BASESAL=[F:HSP]BAS
              #05/12/08 - 31032
              If SEPARE : TXSAL+=[F:HSP]RAT : MTTSAL+=[F:HSP]AMT : Endif
             Else     :#patronal
              BASEPAT=[F:HSP]BAS
              #05/12/08 - 31032
              If SEPARE : TXPAT+=[F:HSP]RAT : MTTPAT+=[F:HSP]AMT : Endif
             Endif
             MONTANT+=[F:HSP]AMT
            Else
             If I=1   :#salarial
              BASESAL=0
             Else     :#patronal
              BASEPAT=0
             Endif
            Endif
            Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
            If !fstat & FLGQTY(R)<>2  :#pas une quantité
             BASEREG+=[F:HSP]AMT
             #66903
             If SEPARE
              If I=1
                MTTREGSAL+=[F:HSP]AMT
              Else
                MTTREGPAT+=[F:HSP]AMT
              Endif
             Endif
             #
            Endif
           Next I
           LIMITE_BASE=0
           If [F:DCH]TYPBAS=2 :#cas particulier
            Gosub CAS_PART From INITDCH
           Endif
           Gosub AFFECT_BASE From INITDCH
           BASESAL=0 : BASEPAT=0
           If BASE<>0
            REGUL=1
            #87135: Loi CICE
            Gosub LOI_CICE From INITDCH
            Gosub ECRIT_LIGNES
           Endif
           If BASEREG<>0 #Ecrire une 2ième ligne
            BASE=BASEREG
            TAUX=100 : TAUXAT=0
            MONTANT=BASEREG
            REGUL=2
            #66903
            #05/12/08 - 31032
            #If SEPARE : TXSAL=0 : MTTSAL=0 : TXPAT=0 : MTTPAT=0 :  Endif
            If SEPARE
             MTTSAL=MTTREGSAL
             If MTTSAL : TXSAL=100 : Else TXSAL=0 : Endif
             MTTPAT=MTTREGPAT
             If MTTPAT : TXPAT=100 : Else TXPAT=0 : Endif
            Endif
            #
            Gosub ECRIT_LIGNES
           Endif
          Endif
         Next R
        Endif
       Endif
      Next :#VEP
     Next :#VEP
    Endif
   Endif
  Endif
 Next :#DCH
Next : #FGR
If ARRBASE=2 or ARRMONTANT=2
 Gosub ARRONDIR From INITDCH
Endif
Return

########################################
$TR_CICE
Local Date DATDEBCICE
Local Char DMA (2)
Raz DMA
DMA=func AFNC.PARAM("DMA", [F:FCY]FCY)
If DMA='' : DMA='12' : Endif
If DMA='12'
 DATDEBCICE=gdat$(1,1,year(VDATFIN))
Else
  If month(VDATFIN)=val(DMA)+1
   DATDEBCICE=gdat$(1,month(VDATFIN), year(VDATFIN))
  Else
   DATDEBCICE=gdat$(1,val(DMA)+1,year(VDATFIN)-1)
  Endif
Endif
For [F:VEP]VEP0(1) Where PYRDAT>=DATDEBCICE & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
 MATRI=[F:VEP]EMP
 Read [ID]ID0=MATRI
 #63102 : Lectures inutiles = ralentissements
 If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
 #
 #55538
 NBVEP=0
 For [F:VEP]VEP0
  ##56589
  If NBVEP=0 : RAZVEP=1 : Else : RAZVEP=0 : Endif
  #
  DATMAT=[F:VEP]ENDDAT
  CTR=[F:VEP]CTRNUM
  #63102
  #Gosub LECEMP From WPDEFTABLE
  Gosub LECEMP From INITDCH
  #
  FLAG=1 :  DREF=[F:VEP]PYRDAT
  Gosub CODEXO From INITDCH
  Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
  If ORGANISME="" or ORGANISME=ORGCOURANT
    Gosub POPULATION From INITDCH
    If SALOK
      For R=1 To NRUB
       #44181
       #NBVEP=0
       Gosub REINIT From INITDCH
       Read[RUB]RUB0=GCURLEG;RUBCOD(R)
       If fstat : Break : Endif
       VDEBUT=0 : VFIN=0
       Case TYPECAL(R)
         When 1 : VDEBUT=1 : VFIN=1 :#PS
         When 2 : VDEBUT=2 : VFIN=2 :#PP
         When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
       Endcase
       If VDEBUT
         Gosub RECUP_AT From INITDCH
         For I=VDEBUT To VFIN
           Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
           If !fstat
            If FLGQTY(R)=2  :# Une quantité = Base
              QTY+=[F:HSP]BAS
            Endif
            TAUX+=[F:HSP]RAT
            If I=1   :#salarial
              BASESAL=[F:HSP]BAS
              #05/12/08 - 31032
              If SEPARE : TXSAL+=[F:HSP]RAT : MTTSAL+=[F:HSP]AMT : Endif
            Else     :#patronal
              BASEPAT=[F:HSP]BAS
              #05/12/08 - 31032
              If SEPARE : TXPAT+=[F:HSP]RAT : MTTPAT+=[F:HSP]AMT : Endif
            Endif
            MONTANT+=[F:HSP]AMT
            Else
             If I=1   :#salarial
              BASESAL=0
             Else     :#patronal
              BASEPAT=0
             Endif
            Endif
            Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
            If !fstat & FLGQTY(R)<>2  :#pas une quantité
             BASEREG+=[F:HSP]AMT
             #66903
             If SEPARE
              If I=1
                MTTREGSAL+=[F:HSP]AMT
              Else
                MTTREGPAT+=[F:HSP]AMT
              Endif
             Endif
             #
           Endif
         Next I
         LIMITE_BASE=0
         If [F:DCH]TYPBAS=2 :#cas particulier
           Gosub CAS_PART From INITDCH
         Endif
         Gosub AFFECT_BASE From INITDCH
         BASESAL=0 : BASEPAT=0
         If BASE<>0
           REGUL=1
           #87135: Loi CICE
           Gosub LOI_CICE From INITDCH
           Gosub ECRIT_LIGNES
         Endif
         If BASEREG<>0 #Ecrire une 2ième ligne
           BASE=BASEREG
           TAUX=100 : TAUXAT=0
           MONTANT=BASEREG
           REGUL=2
           #66903
           #05/12/08 - 31032
           #If SEPARE : TXSAL=0 : MTTSAL=0 : TXPAT=0 : MTTPAT=0 :  Endif
           If SEPARE
             MTTSAL=MTTREGSAL
             If MTTSAL : TXSAL=100 : Else TXSAL=0 : Endif
             MTTPAT=MTTREGPAT
             If MTTPAT : TXPAT=100 : Else TXPAT=0 : Endif
           Endif
           #
           Gosub ECRIT_LIGNES
         Endif
        Endif
      Next R
    Endif
  Endif
 Next :#VEP
Next :#VEP
Return

########################################
$ECRIT_LIGNES
#56589
If RAZVEP : NBVEP=0 : Endif
Gosub LOI_TEPA From INITDCH
FLAG=0 : NBVEP+=1
Raz [F:TM2]
For[F:TM2]TM20 Where USR=GUSER & NUMREQ=[L]NUMREQ & DCHFCY=SITE & DCHCAI=[F:DCH]CAI
& & DCHORG=ORGCOURANT & CODDCC=[F:DCH]CODDCC & CODLIG=RUBCOD(R)
 If [F:TM2]WACRAT=TAUXAT & [F:TM2]FLGREG=REGUL & (([F:TM2]RAT=TAUX-TAUXAT) | ([F:DCH]CAI=GINDURS & ([F:ADI]A2="003" |[F:ADI]A2="004"| [F:ADI]A2="005")))
  #Même taux donc même ligne...
   FLAG=1
   [F:TM2]BAS+=BASE
   [F:TM2]AMT+=MONTANT
   #05/12/08 - 31032 + 67984
   If SEPARE & !QTY
    [F:TM2]AMTSAL+=MTTSAL
    [F:TM2]AMTPAT+=MTTPAT
   Endif
   #Quantité pour Heures supp (Loi TEPA)
   [F:TM2]QTY2+=QTY

#   If  NBVEP=1 :#Si le salarié a plusieurs payes on ne le compte qu'une fois.
#    If [F:ID]CIV=1
#     [F:TM2]NBRMEN+=1
#     [F:TM2]NBREMP+=1
#    Else
#     [F:TM2]NBRWOM+=1
#     [F:TM2]NBREMP+=1
#    Endif
#   Endif

#87135 : CICE
  If [F:ADI]A2="400" & CODDCC=[F:DCH]CODDCC
   If NBVEP=1 & BASE>0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
    Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
    Endif
   Elsif BASE<0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN-=1
      [F:TM2]NBREMP-=1
    Else
      [F:TM2]NBRWOM-=1
      [F:TM2]NBREMP-=1
    Endif
    NBVEP=0
   Endif
  Else
   If NBVEP=1 & CODDCC=[F:DCH]CODDCC
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
     Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
     Endif
   Endif
  Endif
#

   Rewrite [F:TM2]
   If fstat<>0
    GOK = 0 : Call FSTA("TM2") From GLOCK : Break
   Endif
   Break
   If GOK<1 : Break : Endif
  Endif
Next
If GOK<1 : Goto AB_TR1 : Endif
If FLAG=0
 [F:TM2]DAT=date$
 [F:TM2]USR=GUSER
 [F:TM2]NUMREQ=[L]NUMREQ
 [F:TM2]DCHFCY=SITE
 [F:TM2]DCHCAI=[F:DCH]CAI
 [F:TM2]DCHORG=ORGCOURANT
 [F:TM2]CODDCC=[F:DCH]CODDCC
 [F:TM2]NUMLIG=LIG
 LIG+=1
 [F:TM2]NUMORD=[F:DCH]NUMORD
 [F:TM2]CODLIG=RUBCOD(R)
 [F:TM2]DESLIG=[F:DCH]CODEDT1+[F:DCH]CODEDT2
 [F:TM2]FLGREG=REGUL
 [F:TM2]BAS=BASE
 [F:TM2]AMT=MONTANT
 #Quantité pour Heures supp (Loi TEPA)
 [F:TM2]QTY2=QTY
 [F:TM2]WACRAT=TAUXAT
 Gosub WR_TEPA From INITDCH
 [F:TM2]TOTRAT=[F:TM2]RAT+[F:TM2]WACRAT
 If [F:ID]CIV=1
  [F:TM2]NBRMEN=1
  [F:TM2]NBRWOM=0
  [F:TM2]NBREMP=1
 Else
  [F:TM2]NBRMEN=0
  [F:TM2]NBRWOM=1
  [F:TM2]NBREMP=1
 Endif
 #05/12/08 - 31032  + 67984
 If SEPARE & !QTY
  [F:TM2]RATSAL=TXSAL
  [F:TM2]AMTSAL=MTTSAL
  [F:TM2]RATPAT=TXPAT
  [F:TM2]AMTPAT=MTTPAT
 Endif
 Write [F:TM2]
 If fstat<>0
  GOK = 0 : Call FSTA("TM2") From GLOCK : Return
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
Endif
Return

########################################
$AB_TR1
Rollback
Return
