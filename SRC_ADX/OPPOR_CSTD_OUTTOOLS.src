Funprog GET_AUS_INTUSR(CTX, SCOD)
Variable Instance CTX Using OBJECT
Value Char SCOD

Local Char SARENDRE(GLONDCO)

  # Issue X3-85280 - 2018-04-13 by FGR/TEJAC
  SARENDRE = func _GET_ATEXTRA_TEXTE(CTX, "AUTILIS", "INTUSR", SCOD, AVOID.ACHAR)
End SARENDRE

#######################################################################################
#**
#* Generic function which return an ATEXTRA.TEXTE value with all PK fields parameters
#*
#* @param CTX      : Context
#* @param SCODFIC  : CODFIC value in ATEXTRA
#* @param SZONE    : ZONE value in ATEXTRA
#* @param SIDENT1  : First key value
#* @param SIDENT2  : Second key value
#*!
Funprog GET_ATEXTRA_TEXTE(CTX, SCODFIC, SZONE, SIDENT1, SIDENT2)
Variable Instance CTX Using OBJECT
Value Char SCODFIC
Value Char SZONE
Value Char SIDENT1
Value Char SIDENT2

Local Instance ZCLASS Using OBJECT
Local Char SARENDRE(GLONDCO)

  # Issue X3-86891 - 2018-04-13 by FGR
  SARENDRE = func _GET_ATEXTRA_TEXTE(CTX, SCODFIC, SZONE, SIDENT1, SIDENT2)
End SARENDRE

#######################################################################################
# PRIVATE FUNCTIONS
#######################################################################################
#**
#* Return a valid instance class variable for LECTEXTRA_SYR function
#*
#* @param CTX : Given instance class
#*!
Funprog _GET_VALID_CONTEXT(CTX)
Variable Instance CTX Using OBJECT

  # Issue X3-86891 - 2018-04-13 by FGR
  If CTX = null Then
    Local Instance ZCLASS Using C_OPPOR
    ZCLASS = NewInstance C_OPPOR AllocGroup null
  Else
    If dim(CTX.ACTX.LAN) > 0 Then
      # This is really a class
      Local Instance ZCLASS Using OBJECT
      ZCLASS = CTX
    Else
      # This is ACTX (context) pointer
      Local Instance ZCLASS Using C_OPPOR
      ZCLASS = NewInstance C_OPPOR AllocGroup null
    Endif
  Endif
End ZCLASS

#######################################################################################
#**
#* Return translated text with all parameter, with managing valid context
#*
#* @param CTX      : Context
#* @param SCODFIC  : CODFIC value in ATEXTRA
#* @param SZONE    : ZONE value in ATEXTRA
#* @param SIDENT1  : First key value
#* @param SIDENT2  : Second key value
#*!
Funprog _GET_ATEXTRA_TEXTE(CTX, SCODFIC, SZONE, SIDENT1, SIDENT2)
Variable Instance CTX Using OBJECT
Value Char SCODFIC
Value Char SZONE
Value Char SIDENT1
Value Char SIDENT2

Local Instance ZCLASS Using OBJECT
Local Char SARENDRE(GLONDCO)

  # Issue X3-86891 - 2018-04-13 by FGR
  Raz SARENDRE
  # -----------------
  ZCLASS = func _GET_VALID_CONTEXT(CTX)
  Call LECTEXTRA_SYR(ZCLASS, AVOID.ACHAR, SARENDRE, SCODFIC, SZONE, SIDENT1, SIDENT2) From ATEXTRA
  # -----------------
  If ZCLASS <> CTX Then
    FreeGroup ZCLASS
  Endif
End SARENDRE

