# Superviseur
# Gestion du masque MASSPRO 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone UPD
mkstat = 0
zoncou = "UPD"
IMPENT = [M]UPD(indice)
WNUM = IMPENT
If varinit([M]UPD,indice)=0
 IMPENT = 1
Endif
If varmode([M]UPD,indice)=0
 [M]UPD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]UPD(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_UPD(IMPENT) From MASSPRO
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "UPD" : GZNUM = 47882 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]UPD(indice) = IMPENT

## Zone ETRFCY
mkstat = 0
zoncou = "ETRFCY"
WCHAR = [M]ETRFCY(indice)
If varmode([M]ETRFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRFCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]ETRFCY(indice)) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]ETRFCY(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]ETRFCY(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ETRFCY([M]ETRFCY(indice)) From MASSPRO
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

