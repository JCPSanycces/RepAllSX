#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement TRTSNLSERE - Saisie des numéros de série à inventorier    #
#                         Dans le cas où ceux-ci sont gérés en globale #
########################################################################
# Action SAISTOSERE
#    Paramètres     - LABR    Abréviation masque : "SNL0" "SNL1" ou "SNU4"
#                   - LNOL    No ligne écran (nolign-1)
#
########################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "END"           : Gosub ACTEND

Endcase

Return

#########################################################################

$OUVRE
# gouvsnls = 1 automatique comptage sur ligne
# gouvsnls = 2 clic droit comtage sur ligne
#si variable globale GOUVSNLS <= 1 on sort
If GOUVSNLS < 1
  FIN = 1
  Return
Endif

Local  Char    LABR            : # Abréviation masque origine
Local  Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local  Integer I, OK
If clalev([F:STS])  =0  Local File STOSER    [STS]    Endif
If clalev([M:SNLS1])=0  Local Mask SNLSERE   [SNLS1]  Endif

# Récupération des paramètres
LABR    =     PARAM(1)
LNOL    = val(PARAM(2))
Return

#########################################################################
$DEBUT

Effzo [M:SNLS]
Local Integer I
Local Integer Y
Local Integer WZERSTOFLG    # # si stock nul à oui  pas de saisie des numéros de séries

I = 0
Y = 0
WZERSTOFLG = 0
# Chargement bloc Bloc 5
If LABR = "SNU4"
   [M:SNLS]STOFCY            = evalue("[M:"+LABR+"]STOFCY    (LNOL)")
   [M:SNLS]CUNSSSNUM         = evalue("[M:"+LABR+"]CUNSSSNUM (LNOL)")
   [M:SNLS]CUNLISNUM         = evalue("[M:"+LABR+"]CUNLISNUM (LNOL)")
Else
   [M:SNLS]STOFCY            = evalue("[M:"+LABR+"]STOFCY")
   [M:SNLS]CUNSSSNUM         = evalue("[M:"+LABR+"]CUNSSSNUM")
   [M:SNLS]CUNLISNUM         = evalue("[M:"+LABR+"]CUNLISNUM")
   [M:SNLS]LABRMODFLG        = evalue("[M:"+LABR+"]MODFLG    (LNOL)")
Endif
[M:SNLS]SERSEQ            = evalue("[M:"+LABR+"]SERSEQ    (LNOL)")
# MODFLG de l'écran origine  est sauvegardé car il est possible de faire des modif sur des series deja enregistré
# suite à l enregistrement d'un comptage. dans ce cas la mise à jour de la table CUNSERDET est faite à l'enregistrement
# de cette fenetre

If LABR = "SNL0" | LABR = "SNU4"
   [M:SNLS]ITMREF         = evalue("[M:"+LABR+"]ITMREF    (LNOL)")
   [M:SNLS]STU            = evalue("[M:"+LABR+"]STU       (LNOL)")
   WZERSTOFLG             = evalue("[M:"+LABR+"]ZERSTOFLG (LNOL)")
Else
   [M:SNLS]ITMREF         = evalue("[M:"+LABR+"]ITMREF")
   [M:SNLS]STU            = evalue("[M:"+LABR+"]STU")
   WZERSTOFLG             = evalue("[M:"+LABR+"]ZERSTOFLG (LNOL)")
   If dim([M:SNLS]ECCVALMAJ) > 0
      [M:SNLS]ECCVALMAJ   = evalue("[M:"+LABR+"]ECCVALMAJ (LNOL)")
   Endif
Endif
If dim([M:SNLS]LOC)       > 0
   [M:SNLS]LOC            = evalue("[M:"+LABR+"]LOC       (LNOL)")
Endif
If dim([M:SNLS]LOT)       > 0
   [M:SNLS]LOT            = evalue("[M:"+LABR+"]LOT       (LNOL)")
Endif
If dim([M:SNLS]SLO)       > 0
   [M:SNLS]SLO            = evalue("[M:"+LABR+"]SLO       (LNOL)")
Endif
[M:SNLS]STA               = evalue("[M:"+LABR+"]STA       (LNOL)")
[M:SNLS]QTYSTU            = evalue("[M:"+LABR+"]QTYSTU    (LNOL)")
[M:SNLS]QTYSTUNEW         = evalue("[M:"+LABR+"]QTYSTUNEW (LNOL)")
[M:SNLS]QTYSTUDEV         = evalue("[M:"+LABR+"]QTYSTUDEV (LNOL)")
[M:SNLS]SERSEQ            = evalue("[M:"+LABR+"]SERSEQ    (LNOL)")
[M:SNLS]STOCOU            = evalue("[M:"+LABR+"]STOCOU    (LNOL)")
# titre du bloc 10 suivant l'écart
If [M:SNLS]QTYSTUDEV < 0
   Chgtbk [M:SNLS]10 With mess(651,199,1)  # "No série à sortir"
   [M:SNLS]ECART = "S"
Else
   Chgtbk [M:SNLS]10 With mess(652,199,1)  # "No série à entrer"
   [M:SNLS]ECART = "E"
Endif
# Chargement bloc Bloc 10
# recherche dans la table CUNSERDET
Filter [CSD] Where [F:CSD]CUNSSSNUM = [M:SNLS]CUNSSSNUM &
&                  [F:CSD]CUNLISNUM = [M:SNLS]CUNLISNUM &
&                  [F:CSD]SERSEQ    = [M:SNLS]SERSEQ
&             Order By Key CSD0

For [CSD]
    If I >  GCOD_INV-1 : Break : Endif
    [M:SNLS]QTY        (I) = [F:CSD]QTY
    [M:SNLS]SERNUM     (I) = [F:CSD]SERDEB
    [M:SNLS]SERNUMF    (I) = [F:CSD]SERFIN
    [M:SNLS]MODFLG     (I) = 1
    I += 1
Next
[M:SNLS]NBLIG = I
Filter [CSD]

# recherche dans le masque SNLSEREW
If [M:SNLS]NBLIG = 0
   Y = 0
   I = 0
   For Y = 0 To [M:SNLSW]NBLIG-1
       If [M:SNLS]SERSEQ      = [M:SNLSW]SERSEQ  (Y)
          [M:SNLS]QTY     (I) = [M:SNLSW]QTY     (Y)
          [M:SNLS]SERNUM  (I) = [M:SNLSW]SERNUM  (Y)
          [M:SNLS]SERNUMF (I) = [M:SNLSW]SERNUMF (Y)
          [M:SNLS]MODFLG  (I) = 1
          I += 1
       Endif
   Next
  [M:SNLS]NBLIG = I
Endif

If [F:ITM]ITMREF <> [M:SNLS]ITMREF
   Read [F:ITM]ITM0=[M:SNLS]ITMREF
   If fstat
      Raz [F:ITM]
   Endif
Endif
If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SNLS]STOFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;[M:SNLS]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

#desactivation des rubriques ecrans suivant le contexte
Gosub FORMAT_INV_SNLSERE From STKINV1
If GSNLSTAIMG3 = 2 | GCONSULT = 2 | [M:SNL0]CUNLISSTA  > 5 |  WZERSTOFLG = 2 | GOUVSNLS = 9
   GOUVSNLS    = 9
   Diszo [M:SNLS]
Else
   Diszo [M:SNLS]5
Endif
Affzo [M:SNLS]1-99

Return

#########################################################################
$SETBOUT
Local Integer WI
# lignes suivantes en commentaire pour forcer le bouton "enregistrer" afin d éviter une ligne  de fin de tableau puis "escape"
#WI = find(2,[M:SNLS]MODFLG(0..[M:SNLS]NBLIG-1))
#If WI > 0 | REP  = "M"
   ETABOU(GENRE) = 1
   ETABOU(GABAN) = 1

#Else
#   ETABOU(GENRE) = 0
#   ETABOU(GABAN) = 0
#Endif
If GSNLSTAIMG3   = 2
   ETABOU(GENRE) = 0
   ETABOU(GABAN) = 0
Endif

Return

#########################################################################
$AVANT_ENR
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer WRET
If [M:SNLS]NBLIG =0 |
& ([M:SNLS]NBLIG<>0 & sigma(I=0,[M:SNLS]NBLIG-1,[M:SNLS]QTY(I))<>abs([M:SNLS]QTYSTUDEV))
   # Le nb de no série ne correspond pas à la qté à traiter
#   GMESSAGE = mess(246,199,1)
#   GERR=1 : FOK=0 : Return
   Call OUINON(mess(660,199,1), WI) From GESECRAN
   If WI  <> 2
      GERR = 1
      Return
   Endif
Endif

Local Integer Y
Raz [M:SNLS1]
If [M:SNLS]NBLIG>1
   [M:SNLS1] = [M:SNLS]
   # Vérification que les plages de no série sont bien croissantes
   # donc qu il ni a pas plusieurs fois les memes numéros
   Sorta [M:SNLS1]NBLIG [M:SNLS1]NBLIG Order By [M:SNLS1]SERNUM([S]indice)
   For Y=1 To [M:SNLS1]NBLIG-1
       If [M:SNLS1]SERNUM(Y) <= [M:SNLS1]SERNUMF(Y-1)
          GMESSAGE = mess(35,184,1)+"\"   # Suite discontinue des n° de série
          GMESSAGE += mess(445,184,1)+num$(Y+1) +" : "+[M:SNLS1]SERNUM(Y)+ " "+ mess(446,184,1)+ num$(Y)+" : "+[M:SNLS1]SERNUMF(Y-1)
          GERR=1
          FOK=0
          Break
       Endif
   Next Y
   Default Mask [M:SNLS]
Endif
For Y=0 To [M:SNLS]NBLIG-1
    If [M:SNLS]QTY (Y) = 1
       WNUMDEB         = [M:SNLS]SERNUM(Y)
       WNUMFIN         = [M:SNLS]SERNUM(Y)
       Gosub CTR_SERNUM
       If mkstat=2
          GERR=1
          FOK=0
          Break
       Endif
    Else
   # Vérification que les no série existent
       WNBSERIE = [M:SNLS]QTY   (Y)
       WNUMDEB  = [M:SNLS]SERNUM(Y)
       For J=2 To WNBSERIE
           Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
           If WRET=0
              Gosub CTR_SERNUM
              If mkstat=2
                 GERR=1
                 FOK=0
                 Break
              Else
                 WNUMDEB = WNUMFIN
              Endif
           Else
              GMESSAGE=WNUMDEB-":"-mess(476,197,1)    # erreur sur incrémentation des numeroes de series
              GERR=1
              FOK=0
              Break
           Endif
       Next J
    Endif
Next Y

Return


#########################################################################
$ENR

Local Integer I
Local Integer Y
Local Integer LRET

#---- stockage dans le masque SNLSEREW
# si des lignes SERSEQ existent deja dans le masque SNLSEREW => suppression
I    = 0
Y    = 0
LRET = 0

For I = 0 To [M:SNLSW]NBLIG-1
    If I > [M:SNLSW]NBLIG
           [M:SNLSW]NBLIG = I
       Break
    Else
       If [M:SNLS]SERSEQ      = [M:SNLSW]SERSEQ  (I)
          Dela I,1 [M:SNLSW]NBLIG
          I    -= 1
          [M:SNLSW]NBLIG -= 1
       Endif
    Endif
Next I
# stockage dans le masque SNLSEREW
I = 0
Y = [M:SNLSW]NBLIG
For I = 0 To [M:SNLS]NBLIG-1
    If [M:SNLS]QTY (I) <> 0
       [M:SNLSW]QTY     (Y) = [M:SNLS]QTY     (I)
       [M:SNLSW]SERNUM  (Y) = [M:SNLS]SERNUM  (I)
       [M:SNLSW]SERNUMF (Y) = [M:SNLS]SERNUMF (I)
       [M:SNLSW]SERSEQ  (Y) = [M:SNLS]SERSEQ
       [M:SNLSW]ECART   (Y) = [M:SNLS]ECART
       [M:SNLSW]ITMREF  (Y) = [M:SNLS]ITMREF
       [M:SNLSW]STOCOU  (Y) = [M:SNLS]STOCOU
       [M:SNLS]MODFLG   (I) = 1
       Y += 1
    Endif
Next
[M:SNLSW]NBLIG = Y
If LABRMODFLG <> 2
   Call ECR_CSD([M:SNLS]STOFCY,[M:SNLS]CUNSSSNUM,[M:SNLS]CUNLISNUM,[M:SNLS]SERSEQ,0,LRET) From STKINV1
Endif
FIN = 1
Return

#########################################################################
$ABA

Gosub DEBUT

Return


#########################################################################
$ACTEND

If GOUVSNLS    = 9
   Raz GOUVSNLS
   Return
Endif

Local Integer WI

WI = 0
WI = find(2,[M:SNLS]MODFLG(0..[M:SNLS]NBLIG-1))
If WI > 0
   WI = 0
# Vous n'avez pas enregistré votre saisie . Confirmez vous ?
   Call OUINON(mess(611,177,1), WI) From GESECRAN
   If WI  <> 2
      FIN =  0
      Return
   Else
      Gosub DEBUT
      Gosub AVANT_ENR
      If GERR=1
         FIN = 0
      Endif
   Endif
Else
  Gosub AVANT_ENR
  If GERR=1
     FIN = 0
  Endif
Endif

Return

#########################################################################
# Controle numéro de serie appelé aussi depuis IMPSNXS (GIMPORT à oui)
#########################################################################
$CTR_SERNUM
Local Integer I
Raz I
Case [M:SNLS]ECART
     When "E"
          Read [STS]STS3=[M:SNLS]ITMREF;[M:SNLS]STOCOU;WNUMFIN
          If !fstat
             If GIMPORT
                WIMPORT_ERR = 63
             Else
                GMESSAGE=WNUMFIN-":"-mess(223,187,1) # numéro de série existe déja pour cette ligne de stock
                mkstat = 2
             Endif
          Else
             Read [STS]STS0=[M:SNLS]ITMREF;WNUMFIN
             If !fstat
                If GIMPORT
                   WIMPORT_ERR = 64
                Else
                   GMESSAGE=WNUMFIN-":"-mess(3,187,1) # numéro de série existe déja pour cet article
                   mkstat = 2
                Endif
             Endif
          Endif
          If mkstat <> 2
             For I = 0 To [M:SNLSW]NBLIG-1
                 If [M:SNLSW]ITMREF(I) =  [M:SNLS]ITMREF
                    If [M:SNLSW]SERSEQ(I) <> [M:SNLS]SERSEQ
                       If [M:SNLSW]ECART(I) = [M:SNLS]ECART
                          If WNUMFIN >=  [M:SNLSW]SERNUM(I) & WNUMFIN <=  [M:SNLSW]SERNUMF(I)
                             If GIMPORT
                                WIMPORT_ERR = 62
                             Else
                                GMESSAGE=WNUMFIN-":"-mess(653,199,1) # Numero de série déja à inventorier
                                mkstat = 2
                             Endif
                          Endif
                       Endif
                    Endif
                 Endif
             Next I
          Endif

     When "S"
          Read [STS]STS0=[M:SNLS]ITMREF;WNUMFIN
          If fstat
             If GIMPORT
                WIMPORT_ERR = 65
             Else
                GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
                mkstat = 2
                Return
             Endif
          Endif
          If [F:STS]ISSDAT<>[0/0/0]
             If GIMPORT
                WIMPORT_ERR = 66
             Else
                GMESSAGE=WNUMFIN-":"-mess(37,184,1) # numéro de série sorti par une autre piece
                mkstat=2
                Return
             Endif
          Endif
          If [F:STS]SDHNUM<>""
             If GIMPORT
                WIMPORT_ERR = 67
             Else
                GMESSAGE=VALEUR-":"-mess(443,184,1)  # numero de série alloué par une autre piece
                mkstat=2
                Return
             Endif
          Endif
          If [F:STS]STOCOU<>[M:SNLS]STOCOU
             If GIMPORT
                WIMPORT_ERR = 73
             Else
                GMESSAGE=VALEUR-":"-mess(447,184,1)  # numero de série lié à une autre ligne de stock
                mkstat=2
                Return
             Endif
          Endif
     When Default
Endcase
Return

###########################################################################
Subprog AVANT_NBLIG
If [M:SNLS]QTY  (nolign-1) = 0
   [M:SNLS]QTY  (nolign-1) = abs([M:SNLS]QTYSTUDEV) - sum([M:SNLS]QTY(0..[M:SNLS]NBLIG-1))
   If [M:SNLS]QTY  (nolign-1) < 0
      [M:SNLS]QTY  (nolign-1) = 0
   Endif
   Affzo [M:SNLS]QTY(nolign-1)
Endif
End

###########################################################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL

NOL=nolign-1

# Le nb de no série ne correspond pas à la qté à traiter
If sum([M:SNLS]QTY(0..[M:SNLS]NBLIG-1))-[M:SNLS]QTY(NOL)+VALEUR > abs([M:SNLS]QTYSTUDEV)
   GMESSAGE = mess(246,199,1)
   mkstat=2
   End
Endif

End

##########################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
NOL=nolign-1

[M:SNLS]MODFLG(NOL) = 2
# Il n'y a pas encore de no série saisi
If [M:SNLS]SERNUM(NOL)=""
   End
Endif

# La quantité a diminué
If VALEUR  < [M:SNLS]QTY   (NOL)
   WNBSER  = VALEUR
   WNUMDEB = [M:SNLS]SERNUM(NOL)
   If WNBSER=1
      [M:SNLS]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SNLS]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2
         GMESSAGE=WNUMDEB-":"-mess(476,197,1)  # erreur sur incrémentation des numeroes de series
         End
      Endif
   Endif
   Affzo [M:SNLS]SERNUM(NOL), SERNUMF(NOL)
Else
   # Vérification que les no série existent
   WNBSER  = VALEUR-[M:SNLS]QTY    (NOL)
   WNUMDEB =        [M:SNLS]SERNUMF(NOL)
   For J=1 To WNBSER
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          Gosub CTR_SERNUM
          If mkstat=2
             Break
          Else
             WNUMDEB = WNUMFIN
          Endif
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrémentation des numeroes de series
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:SNLS]SERNUMF     (NOL)  = WNUMFIN
   Affzo [M:SNLS]SERNUM(NOL), SERNUMF(NOL)
Endif

End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)

NOL                 = nolign-1
[M:SNLS]MODFLG(NOL) = 2

If [M:SNLS]QTY   (NOL) = 0
   If NOL=0
      [M:SNLS]QTY(NOL) = abs([M:SNLS]QTYSTUDEV)
   Else
      [M:SNLS]QTY(NOL) = abs([M:SNLS]QTYSTUDEV)-sigma(I=0,NOL-1,[M:SNLS]QTY(I))
   Endif
   Affzo [M:SNLS]QTY(NOL)
Endif

If [M:SNLS]QTY          (NOL) = 1
   [M:SNLS]SERNUMF      (NOL) = VALEUR
   Affzo [M:SNLS]SERNUMF(NOL)
Else
   # Vérification que les no série existent
   # et alimentation du no série fin
   WNBSERIE = [M:SNLS]QTY(NOL)
   WNUMDEB  = VALEUR
   For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1)    # erreur sur incrémentation des numeroes de series
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:SNLS]SERNUMF      (NOL) = WNUMFIN
   Affzo [M:SNLS]SERNUMF(NOL)
Endif

End

######################################################################################
Subprog C_NBLIG

Case status
     When 65     :                                # Suppression d'une ligne
        [M:SNLS]QTY (nolign-1) = 0
        [M:SNLS]MODFLG(0) = 2                     # pour forcer l enregistrement
     When 68, 83 :                                # Suppression d'un groupe de lignes
        For I=nolign-1 To nolign1-1
            [M:SNLS]QTY (nolign-1) = 0
        Next
        [M:SNLS]MODFLG(0) = 2                     # pour forcer l enregistrement
     When Default
Endcase
End
######################################################################################

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
NOL                 = nolign-1
If [M:SNLS]QTY          (NOL) = 1
   WNUMDEB             = VALEUR
   WNUMFIN             = VALEUR
   Gosub CTR_SERNUM
   If mkstat=2
      End
   Endif
Else
   # Vérification que les no série existent
   # et alimentation du no série fin
   WNBSERIE = [M:SNLS]QTY(NOL)
   WNUMDEB  = VALEUR
   For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          Gosub CTR_SERNUM
          If mkstat=2
             Break
          Else
             WNUMDEB = WNUMFIN
          Endif
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1)    # erreur sur incrémentation des numeroes de series
          mkstat=2
          Break
       Endif
   Next J
Endif

End


######################################################################################

