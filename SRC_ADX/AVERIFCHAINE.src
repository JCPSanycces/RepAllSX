#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################
#  rechercher une chaine dans les sources
#
#-----------------------------------------------------------------------------------------------------------#

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End
 
Subprog AVERIFCHAINE(CHEMINTRA, NOMTRT, DOSSIER,
&     PORT, MACHINE, PDEMANDEUR, PMODULE, PCH1, PCH2, POPTION, PCH1ET2)
Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char NOMTRT       :  # Nom du source à analyser (jokers autorisés)

Value Char DOSSIER      :  # Si non patch, dossier analysé
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Integer PDEMANDEUR  : # niveau du dossier
Value Integer PMODULE
Value Char PCH1, PCH2
Value Integer POPTION, PCH1ET2



# POPTION
# 0 mot incomplet
# 1 mot complet
# 3 recherche des Call (*)
# 4 recherche des func (*)
# 5 les 2
#
# (*) si PCH1 est renseignée, on recherche les func et/ou Call se rapportant à ce traitement

# PCH1, PCH2 (**)
#
# si PCH1 ou PCH2 égale =NOMTRT, la chaîne est remplacée par le nom du traitement en cours de contrôle


Local Char TXTERR(200)
Local Integer NBERREUR
Local Char DOSSIER2(100)

Local Integer WIGNWRSEQ, WIGNWRTRT, NSK, NSKLEC, WMIGRATE

Local Integer NBTRAITES, NLIG, I, J

Local Integer BCHAINELEC, FST
Local Char WFILE(10), WABREV(5), WCHTRT(30)

Local Clbfile CHAINE(3), CHAINELEC(3), CHAININS(3)


#    NOMTRT = "AVERIF*"
    If NOMTRT = "" or instr(1, NOMTRT, "*")
        Call LISTETRT(PDEMANDEUR, PORT, MACHINE, DOSSIER) From AVERIFSRC
    Else
        GTTRAITEMENTS(1) = NOMTRT
        GNBTRTADX = 1
    Endif

# ----------------------------------------------------------------------------------------------------------
# affectation dela valeur à rechercher ds chaine à trouver

    Local Char WCHATROUVER(50), WCHATROUVER2(50)
    Local Integer WCH1ET2
    
    WCHATROUVER  = PCH1
    WCHATROUVER2 = PCH2

    WCH1ET2 = PCH1ET2  # 1 ou 0 (chaine1 ET 2 trouvées sur la même ligne)

    
    If WCHATROUVER2 = ""
        WCH1ET2 = 0
    Endif
# ----------------------------------------------------------------------------------------------------------

    Local Char ZADXIFS, ZADXIRS
    
    ZADXIFS = adxifs
    ZADXIRS = adxirs
    adxifs  = chr$(0)
    adxirs  = chr$(10)


    Call TEMPON("VERIFCHAINE Initialisation du traitement...") From GESECRAN
    
    If MACHINE = ""
        DOSSIER2 = DOSSIER
    Else
        DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
    Endif
    
    If clalev ([F:ADC])
        Close File [ADC]
    Endif
    Local File = DOSSIER2 + ".ADICTRT"   [ADC]    
    
    Openo CHEMINTRA, -1
    Wrseq
    Wrseq "Chaîne 1 :" - PCH1
    Wrseq "Chaîne 2 :" - PCH2
    If POPTION = 0
        Wrseq "Mot incomplet"
    # 0 mot incomplet
# 1 mot complet
# 3 recherche des Call (*)
# 4 recherche des func (*)
# 5 les 2
    Elsif POPTION = 1
        Wrseq "Mot complet"
    Elsif POPTION = 3
        Wrseq "Recherche des Call From"
    Elsif POPTION = 4
        Wrseq "Recherche des func ."
    Elsif POPTION = 5
        Wrseq "Recherche des Gosub From"
    Else
        Wrseq "Recherche des Call From,  Gosub From et func ."
    Endif
    If WCH1ET2
        Wrseq "Chaîne 1 ET 2" 
    Else
        Wrseq "Chaîne 1 OU/ET 2" 
    Endif
    
    Wrseq
    Wrseq
    Wrseq "------------------------- ### recherche ###-----------------------------------------"
    Wrseq
    Wrseq

    Openo
    
    Openo CHEMINTRA, -1  Using [FER]
    
#--------------------------------#
# Tableau des traitements adx
#--------------------------------#


    Call TEMPON("VERIFCHAINE") From GESECRAN

    For NF=1 To GNBTRTADX
        Gosub ANALYSE
    Next NF
 
    Wrseq Using [FER]
    Wrseq Using [FER]
    Wrseq num$(NBERREUR) - "lignes trouvées sur" - num$(NBTRAITES) - "sources traités."  Using [FER]
    Wrseq Using [FER]
    
    Wrseq Using [FER]
    Wrseq Using [FER]

    Wrseq "Fin des recherches." - time$  Using [FER]
    Wrseq Using [FER]

    adxifs=ZADXIFS
    adxirs=ZADXIRS

    Openo  Using [FER]
    Close File [ADC]
    Call TEMPOFF From GESECRAN

    Goto FINCALL


#------------------------------------------------------------------------------------------------------------------------#


$ANALYSE

    If mod(NF,100) = 0
        Call TEMPON("VERIFCHAINE :" - num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&        "nb :" - num$(NBERREUR)) From GESECRAN
    Endif    

    If func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), NOMTRT, DOSSIER2, PMODULE, 1, "", "",
&           0, TXTERR, PDEMANDEUR)
       Return
    Endif


    NBTRAITES += 1
    
    Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    
    Raz WIGNWRSEQ, WIGNWRTRT, WMIGRATE
    FST=0
    NLIG = -1
    CHAINELEC = ""
    BCHAINELEC = 0


    Read [ADC]ADC0 = GTTRAITEMENTS(NF)
    If fstat
        [F:ADC]MODULE = 0
    Endif
    If PCH1 = "=NOMTRT"
        WCHATROUVER = GTTRAITEMENTS(NF)
    Endif

    If PCH2 = "=NOMTRT"
        WCHATROUVER2 = GTTRAITEMENTS(NF)
    Endif
    

    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC

        Call VIRECOMCHK (CHAINE, 1, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        # CBO 20110124 FQ70150
        If WIGNWRTRT >= 20 and WIGNWRTRT < 30
            WIGNWRTRT -= 20
        Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40
            WIGNWRTRT -= 30
        Endif

        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            Return
        Endif

        #If GTTRAITEMENTS(NF) = "XXX" and NLIG = 1651
        #Dbgaff
        #Endif

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        While CHAINE <> ""
            #__________________________________________________________________________________________________

#If NLIG = 303 or nlig = 320
#Dbgaff
#Endif
            If WCH1ET2
            
                If POPTION
                    Call WFCHAINECOMPLETE(1, CHAINE, WCHATROUVER, I, POPTION, WCHTRT)
                    Call WFCHAINECOMPLETE(I, CHAINE, WCHATROUVER2, J, POPTION, WCHTRT)

                    If J
                        NBERREUR += 1
                        If PMODULE
                            Wrseq GTTRAITEMENTS(NF) - num$(NLIG) - CHAINE Using [FER]
                        Else
                            Wrseq GTTRAITEMENTS(NF) - "(Module" - num$([F:ADC]MODULE) + ")" - num$(NLIG) - CHAINE Using [FER]
                        Endif
                    Endif
                Else
                    I = instr(1, CHAINE, WCHATROUVER)
                    If I and instr(I + len(WCHATROUVER), CHAINE, WCHATROUVER2)
                        NBERREUR += 1
                        If PMODULE
                            Wrseq GTTRAITEMENTS(NF) - num$(NLIG) - CHAINE Using [FER]
                        Else
                            Wrseq GTTRAITEMENTS(NF) - "(Module" - num$([F:ADC]MODULE) + ")" - num$(NLIG) - CHAINE Using [FER]
                        Endif
                    Endif
                Endif

            Else
            
                If POPTION
                    Call WFCHAINECOMPLETE(1, CHAINE, WCHATROUVER, I, POPTION, WCHTRT)
                    If I = 0 and WCHATROUVER2 <> ""
                        Call WFCHAINECOMPLETE(1, CHAINE, WCHATROUVER2, I, POPTION, WCHTRT)
                    Endif
                    If I
                        NBERREUR += 1
                        If PMODULE
                            Wrseq GTTRAITEMENTS(NF) - num$(NLIG) - CHAINE Using [FER]
                        Else
                            Wrseq GTTRAITEMENTS(NF) - "(Module" - num$([F:ADC]MODULE) + ")" - num$(NLIG) - CHAINE Using [FER]
                        Endif
                    Endif
                Else
                    If instr(1, CHAINE, WCHATROUVER) or
&                   (WCHATROUVER2 <> "" and instr(1, CHAINE, WCHATROUVER2))
                        NBERREUR += 1
                        If PMODULE
                            Wrseq GTTRAITEMENTS(NF) - num$(NLIG) - CHAINE Using [FER]
                        Else
                            Wrseq GTTRAITEMENTS(NF) - "(Module" - num$([F:ADC]MODULE) + ")" - num$(NLIG) - CHAINE Using [FER]
                        Endif
                    Endif
                Endif
            Endif
            #__________________________________________________________________________________________________


            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        Wend
    Wend 
Return

$FINCALL
End
Subprog WFCHAINECOMPLETE(POSRECHERCHE, CHAINE, PCHATROUVER, RESULT, POPTION, RTRT)
Value Integer POSRECHERCHE
Value Clbfile CHAINE
Value Char PCHATROUVER
Variable Integer RESULT
Value Integer POPTION
Variable Char RTRT

Local Integer K
Local Char WCHSEP(30)


    WCHSEP = ".,;:()[]=></\*+-%$!?@ "
    RESULT = 0
    RTRT = ""
    If POSRECHERCHE = 0
        End
    Endif

    If POPTION = 1    
        RESULT = instr(POSRECHERCHE, CHAINE, PCHATROUVER)
        If RESULT = 0
            End
        Elsif RESULT = 1
            If (len(PCHATROUVER) + RESULT - 1) = len(CHAINE)
                RESULT = len(CHAINE)
            Else
                K = instr(1, WCHSEP, mid$(CHAINE, len(PCHATROUVER) + RESULT, 1))
                If K
                    RESULT += len(PCHATROUVER)
                Else
                    RESULT = 0
                Endif
            Endif
        Else
            K = instr(1, WCHSEP, mid$(CHAINE, RESULT - 1, 1))
            If K
                If (len(PCHATROUVER) + RESULT - 1) = len(CHAINE)
                    RESULT = len(CHAINE)
                Else
                    K = instr(1, WCHSEP, mid$(CHAINE, len(PCHATROUVER) + RESULT, 1))
                    If K
                        RESULT += len(PCHATROUVER)
                    Else
                        RESULT = 0
                    Endif
                Endif
            Endif
        Endif

    Else
    
        # call from TRT
        If POPTION = 3 or POPTION = 6
            RESULT = instr(POSRECHERCHE, CHAINE, "Call")
            If RESULT
                RESULT = instr(RESULT, CHAINE, "From")
                If RESULT
                    RTRT = right$(CHAINE, RESULT + 5)
                    If PCHATROUVER <> "" and PCHATROUVER <> RTRT
                        RESULT = 0
                        RTRT = ""
                    Endif
                Endif
            Endif
        Endif
    
        # func TRT.
        If RESULT = 0 and (POPTION = 4 or POPTION = 6)
            RESULT = instr(POSRECHERCHE, CHAINE, "func")
            If RESULT
                J = instr(RESULT, CHAINE, ".")
                If J
                    RTRT = mid$(CHAINE, RESULT + 5, J - RESULT - 5)
                    If PCHATROUVER <> "" and PCHATROUVER <> RTRT
                        RESULT = 0
                        RTRT = ""
                    Endif
                Else
                    RESULT = 0
                Endif
            Endif
        Endif
    
        # Gosub from TRT
        If RESULT = 0 and (POPTION = 5 or POPTION = 6)
            RESULT = instr(POSRECHERCHE, CHAINE, "Gosub")
            If RESULT
                RESULT = instr(RESULT, CHAINE, "From")
                If RESULT
                    RTRT = right$(CHAINE, RESULT + 5)
                    If PCHATROUVER <> "" and PCHATROUVER <> RTRT
                        RESULT = 0
                        RTRT = ""
                    Endif
                Endif
            Endif
        Endif

    Endif
End
