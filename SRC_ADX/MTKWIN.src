#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################## 
# MAJ_MODIF : Mise à jour des fichiers suite à une modification de suivi #
#             opératoire.                                                #
######################################################################## 

############################
$MAJ_MODIF
#Transaction de mise à jour suite à correction d'un suivi opé
#Maj par delta de la ligne suivi opé MKO, de l'opération MFO, de l'encours de charge
#Maj de l'entête de suivi et de l'entête OF
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR,I,WNBOPE,WPRN,WRET,LRET, WI, I, WNOL
Local Decimal WWCPLQTY,WWREJQTY,WWQUAQTY,WCPLOPETIM,WCPLSETTIM
Local Decimal WCPLQTY,WREJQTY,WQUAQTY
Local Decimal WCPLHOU
If [M:MTO1]TIMTYP = 1
   Local File MFGPRN [MFP] 
   WPRN = 1
   Read [F:MFP]MFP0 = [M:MTO1]MFGNUMOP
   If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
   Close File [F:MFP]
Endif
#Si apres supp de cette ligne il n'y a plus rien au titre de ce suivi
#On force l'utilisateur à passer par le bouton suppression
WNBOPE = [F:MTK]NBROPE-1
If [M:MTO1]CPLQTY = 0 & [M:MTO1]CPLOPETIM = 0 & [M:MTO1]CPLSETTIM = 0 &
&  WNBOPE = 0 & [F:MTK]NBRITM = 0 & [F:MTK]NBRMAT = 0
   Call ERREUR(mess(87,193,1)) From GESECRAN
   Return
Endif 
Raz WNBOPE
Trbegin [MKO]
Call DEBTRANS From GLOCK
If [M:MTO1]CPLQTY = 0 & [M:MTO1]CPLOPETIM = 0 & [M:MTO1]CPLSETTIM = 0 :#Suppression d'une ligne
    I = LLIG
    If clalev([F:XKO])<=0 : Local File MFGOPETRK [XKO] : Endif
    Readlock [F:MKO]MKO0 = [M:MTK0]MFGTRKNUM;[M:MTK1]OPETRKLIN(I)
    If fstat=1  GOK=-1 : GLOCK="$MFGOPETRK"-num$([M:MTK1]OPENUM(I)) 
        Goto TR_ROLLMOD
    Elsif fstat GOK=0  : Call RSTA("MKO",num$([M:MTK1]OPENUM(I))) From GLOCK
        Goto TR_ROLLMOD 
    Endif    
    Gosub ANNULE_SUIVOPE From SUBMTKC
    WNBOPE += 1
    If GOK < 1 : Goto TR_ROLLMOD : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
    If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
    GWIPCOST = "OPETRK_DEL"
    WRET = 0
    GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
    If WRET > 0 : GOK = 0 : Goto TR_ROLLMOD : Endif
#------------------------------------------------------------------------------------------------------------------
    Call OPETRK_DEL(WRET) From MWIPLIB  # intégration WIP 140 (TB)
    If WRET > 0 : GOK = 0 : Endif

    Delete [F:MKO]
    Readlock [F:MTK]MTK0 = [F:MKO]MFGTRKNUM  
    If fstat=1  GOK=-1 : GLOCK="$MFGHEADTRK"-[M:MTK0]MFGNUM 
       Return
    Elsif fstat GOK=0  : Call RSTA("MTK",[M:MTK0]MFGNUM) From GLOCK
       Return 
    Endif
    [F:MTK]NBROPE -=WNBOPE
    If [F:MTK]NBROPE = 0 & [F:MTK]NBRMAT = 0 & [F:MTK]NBRITM = 0
       Call ERREUR(mess(87,193,1)) From GESECRAN
       GOK = 0  
    Else
       If [F:MTK]NBROPE = 0 : [F:MTK]OPETRKFLG = 1 : Endif 
       Rewrite [F:MTK]     
       If fstat
          GOK = 0 : Call FSTA("MTK") From GLOCK : Return
       Endif
    Endif
Else                                                             :#modif suivi
    I = LLIG
    Gosub MAJFIC
    If GOK < 1 : Goto TR_ROLLMOD : Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
    If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
    GWIPCOST = "OPETRK_MOD"
    WRET = 0
    GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
    If WRET > 0 : GOK = 0 : Goto TR_ROLLMOD : Endif
#------------------------------------------------------------------------------------------------------------------
    Call OPETRK_MOD(WRET) From MWIPLIB  # intégration WIP 140 (TB)
    If WRET > 0 : GOK = 0 : Endif

    If GOK = 1 & [M:MTK0]MFGNUM <> "" 
       Call MAJMFGHEAD([F:MTK]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN) 
&      From SUBMTKC 
        Raz GPE
        GPOINT="UPDSCD"
        Gosub ENTREE From EXEFNC
        If !GPE
           # sr 08.02 si besoin maj de WORKLOAD demande 15029
           Read [F:MFG]MFG0 = [F:MTK]MFGNUM 
           If !fstat & find([F:MFG]SCDFLG,2,4) 
                [M:JALK]CODORI = 1
                [M:JALK]CODMAJ = 0
                [M:JALK]CODTRS = 0            # llc 16716
                [M:JALK]MFGFCY = [F:MFG]MFGFCY
                [M:JALK]MFGNUM = [F:MFG]MFGNUM
                [M:JALK]MFGSTA = [F:MFG]MFGSTA
                # llc 12.02 16779
                If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
                If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                    Read [PJA]PJA0=[M:JALK]MFGFCY
                    If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
                Endif
                Call DEJALONNE From JALLIBA
                If [M:JALK]CODRET = 0
                    Call JALONNE From JALLIB
                Endif    
           Endif
        Endif
        If GOK < 1 : Return : Endif
    Endif
Endif
If GOK < 1 : Goto TR_ROLLMOD  
Else       : Commit
             If [M:MTO1]DACMST = 3 
                # on avertit l'utilisateur qu'il faut éventuellement modifier les suivis des opérations liées
                Call MESSAGE(mess(211,190,1)) From GESECRAN
            Endif
Endif
Return
#
$TR_ROLLMOD    
Rollback
Return                     

#################################
$MAJFIC
Readlock [F:MKO]MKO0 = [M:MTK0]MFGTRKNUM;[M:MTK1]OPETRKLIN(I)
If fstat=1  GOK=-1 : GLOCK="$MFGOPETRK"-num$([M:MTK1]OPENUM(I)) 
    Return
Elsif fstat GOK=0  : Call RSTA("MKO",num$([M:MTK1]OPENUM(I))) From GLOCK
    Return 
Endif    
#----- MISE à jour statistiques ligne suivi opé -----#
If [M:MTK1]ROUOPENUM(I) <> 0 & [M:MTK1]TIMTYP(I) = 1
     Call VALSTA("MKO",-1) From SUBPS2 
     If GOK < 1 : Return : Endif
Endif
WWCPLQTY    =  [M:MTO1]CPLQTY    - [F:MKO]CPLQTY   
WWREJQTY    =  [M:MTO1]REJCPLQTY - [F:MKO]REJCPLQTY  
WCPLOPETIM  =  [M:MTO1]CPLOPETIM - [F:MKO]CPLOPETIM 
WCPLSETTIM  =  [M:MTO1]CPLSETTIM - [F:MKO]CPLSETTIM 
[F:MKO]CPLQTY    = [M:MTK1]CPLQTY(I)
[F:MKO]REJCPLQTY = [M:MTK1]REJCPLQTY(I)
[F:MKO]CPLOPETIM = [M:MTK1]CPLOPETIM(I)
[F:MKO]CPLSETTIM = [M:MTK1]CPLSETTIM(I)
For WI = 1 To 15
    [F:MKO]SCANUM(WI-1)    = evalue("[M:MTK1]SCANUM"+num$(WI)+"(I)")
    [F:MKO]TABREJQTY(WI-1) = evalue("[M:MTK1]TAREJQTY"+num$(WI)+"(I)")
Next
If [F:MKO]REJCPLQTY <> 0 & [F:MKO]TABREJQTY(0) = 0
   [F:MKO]TABREJQTY(0)  =  [F:MKO]REJCPLQTY
Endif    
[F:MKO]EMPNUM    = [M:MTK1]EMPNUM(I)
[F:MKO]MSGNUM    = [M:MTK1]MSGNUM(I)
[F:MKO]SETLABCOE = [M:MTK1]SETLABCOE(I)        # llc 11.02 16544
[F:MKO]OPELABCOE = [M:MTK1]OPELABCOE(I)        # llc 11.02 16544
[F:MKO]UPDDAT    = date$
[F:MKO]UPDUSR    = GUSER
[F:MKO]EXPNUM    = [C]EXPORT
# sr 07.02 besoin Kardol demande 13580
Local Char WACTION : WACTION = "M"
GPOINT = "MKOMAJ"   
Gosub  ENTREE From EXEFNC 
Rewrite [F:MKO]
If fstat GOK = 0 : Call FSTA("MKO") From GLOCK : GOK = 0 : Return : Endif
   
If [M:MTK1]ROUOPENUM(I) <> 0 & [M:MTK1]TIMTYP(I) = 1
    #----- MISE à jour statistiques ligne suivi opé -----#
   Call VALSTA("MKO",1) From SUBPS2 
   If GOK < 1 : Return : Endif
   Readlock [F:MFO]MFO0 = [M:MTK1]MFGNUMOP(I);[M:MTK1]OPENUM(I);[M:MTK1]OPESPLNUM(I)
   If fstat=1  GOK=-1 : GLOCK="$MFGOPE"-num$([M:MTK1]OPENUM(I)) 
      Return
   Elsif fstat GOK=0  : Call RSTA("MFO",num$([M:MTK1]OPENUM(I))) From GLOCK
      Return 
   Endif
   #----- MISE à jour statistiques ligne  opé -----#
   Call VALSTA("MFO",-1) From SUBPS2 
   If GOK < 1 : Return : Endif
   [F:MFO]CPLQTY    += WWCPLQTY * [M:MTK1]OPEWORCOE(I)
   [F:MFO]REJCPLQTY += WWREJQTY * [M:MTK1]OPEWORCOE(I)
   [F:MFO]CPLSETTIM += WCPLSETTIM
   [F:MFO]CPLOPETIM += WCPLOPETIM
   [F:MFO]CPLUNTTIM  = avg([M:MTK1]CPLUNTTIM(I)/[M:MTK1]OPEWORCOE(I),[F:MFO]CPLUNTTIM)
   If [M:MTK1]CLEFLG(I) = 2 & [F:MFO]MFOTRKFLG <> 5
      [F:MFO]OPESTA = 5
      [F:MFO]MFOTRKFLG = 5
      # CCC (10/01/08) DM 44021
      #[F:MFO]TRKLAST = [F:MTK]MFGTRKDAT
      WOPECLENBR += 1 
   Elsif [M:MTK1]CLEFLG(I) = 1 & [F:MFO]MFOTRKFLG = 5
      [F:MFO]OPESTA = 4
      [F:MFO]MFOTRKFLG = 4
      # CCC (10/01/08) DM 44021
      #Raz [F:MFO]TRKLAST
      WOPECLENBR -= 1    
   Endif
   Gosub MAJ_SUIVANTE From SUBMTKC
   If GOK < 1 : Return : Endif
   Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
   Read [F:MFI]MFI0 First
   If !fstat
      Call UPDATE_OWX("SM",[F:MFI]PJT) From MFGLIBO
   Endif
   Filter [MFI]
   Rewrite [F:MFO]
   If fstat
      GOK = 0 : Call FSTA("MFO") From GLOCK : Return
   Endif
    #----- MISE à jour statistiques ligne opé -----#
   Call VALSTA("MFO",-1) From SUBPS2 
   If GOK < 1 : Return : Endif
   If [M:MTK0]MFGNUM = "" 
      Readlock [F:MFG]MFG0 = [F:MFO]MFGNUM
      # FGR 14/01/2010 : X3SUIVI60986
      #If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([M:MTK1]MFGNUM(nolign-1)) : Return
      #Elsif fstat GOK=0  : Call RSTA("MFG",num$([M:MTK1]MFGNUM(nolign-1))) From GLOCK
      If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MFO]MFGNUM : Return
      Elsif fstat GOK=0  : Call RSTA("MFG",[F:MFO]MFGNUM) From GLOCK
             Return
      Endif
      #----- MISE à jour statistiques entête OF -----#
      Call VALSTA("MFG",-1) From SUBPS2 
      If GOK < 1 : Return : Endif
      [F:MFG]OPECLENBR += WOPECLENBR
      If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&        [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&        [F:MFG]MATCLENBR = [F:MFG]MATLINNBR 
         [F:MFG]MFGTRKFLG = 5
         # CCC (10/01/08) DM 44021
         #[F:MFG]TRKLAST   = [M:MTK0]MFGTRKDAT
      Else 
         [F:MFG]MFGTRKFLG = 4
         # CCC (10/01/08) DM 44021
         #Raz [F:MFG]TRKLAST
      Endif
      # CCC (10/01/08) DM 44021
      #If [F:MFG]TRKFIRST = "00/00/00" : [F:MFG]TRKFIRST = [M:MTK0]MFGTRKDAT : Endif
      If [F:MFG]TRKLAST<[M:MTK0]MFGTRKDAT
         [F:MFG]TRKLAST   = [M:MTK0]MFGTRKDAT
      Endif
      If [F:MFG]TRKLASTC<date$
         [F:MFG]TRKLASTC  = date$
      Endif
      If [F:MFG]TRKFIRST>[M:MTK0]MFGTRKDAT | [F:MFG]TRKFIRST = "00/00/00"
          [F:MFG]TRKFIRST = [M:MTK0]MFGTRKDAT 
      Endif
      If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
          [F:MFG]TRKFIRSTC = date$
      Endif
      Rewrite [F:MFG]
      If fstat
         GOK = 0 : Call FSTA("MFG") From GLOCK : Return
      Endif
      #----- MISE à jour statistiques entête OF -----#
      Call VALSTA("MFG",1) From SUBPS2 
      If GOK < 1 : Return : Endif
      Raz WOPECLENBR
      # sr 08.02 si besoin maj de WORKLOAD demande 15029
      If find([F:MFG]SCDFLG,2,4) 
            [M:JALK]CODORI = 1
            [M:JALK]CODMAJ = 0
            [M:JALK]CODTRS = 0                    # llc 11.02 16716
            [M:JALK]MFGFCY = [F:MFG]MFGFCY
            [M:JALK]MFGNUM = [F:MFG]MFGNUM
            [M:JALK]MFGSTA = [F:MFG]MFGSTA
            # llc 12.02 16779 + 17348
            If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
            If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                Read [PJA]PJA0=[M:JALK]MFGFCY
                If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
            Endif
            Call DEJALONNE From JALLIBA
            If [M:JALK]CODRET = 0
                Call JALONNE From JALLIB
            Endif    
            If GOK < 1 : Return : Endif
      Endif
   Endif
Endif
#Maj du fichier WORKSTATIO
Readlock [F:MWS]WST0 = [M:MTK1]CPLWST(I);[M:MTK0]MFGFCY
If !fstat 
     WCPLHOU = WCPLOPETIM
     If [M:MTK1]TIMUOMCOD(I) = 2 : WCPLHOU = WCPLHOU / 60 : Endif
     [F:MWS]CPLHOUTIM += func TRTX3.ARRTYP("", "", "TIH", WCPLHOU)
     Rewrite [F:MWS]
     If fstat
        GOK = 0 : Call FSTA("MWS") From GLOCK : Return
     Endif
Endif
Return



