#*********************************EXTRACTION SALARIE**********************************
#*************************************************************************************

######################################
$INITIALISATION
Raz SALAIRE
Raz HEURES
Raz NBJETP
Raz AMTBTP
AMTRET=0
#CODPREV=""

#59274
Raz TYPPREV  : Raz AMTPREV
NBRTYPPREV=0 : NBRAMTPREV=0

NBLIGN=0

#V08R09
Raz PRVAMT

#Bases brutes spécifiques
Raz CODBBS : Raz AMTBBS : Raz PLFBBS : NBRCODBBS=0 : NBRAMTBBS=0

#Bases plafonnées spécifiques
Raz CODBPS : Raz AMTBPS : NBRCODBPS=0 : NBRAMTBPS=0

#Sommes isolées
Raz CODISO : Raz BASEISO : Raz PLAFISO : NBRCODISO=0 : NBRBISO=0 : NBRPISO=0
# N4DS - MONTISO
Raz [L]MONTISO, [L]NBRMISO

#Bases spécifiques exonérations URSSAF
Raz CODEXO : Raz BRUTEXO : Raz PLAFEXO : NBRCODEXO=0 : NBRBEXO=0 : NBRPEXO=0
# N4DS - MONTEXO
Raz [L]MONTEXO, [L]NBRMONTEXO

Raz CODEPG : Raz AMTEPG : NBRCODEPG=0 : NBREPG=0
Raz NBRACT : Raz VALACT : NBRNBRACT=0 : NBRVAL=0
Raz CODAVG : Raz AMTAVG : NBRCODAVG=0 : NBRAVG=0
Raz CODXON : Raz AMTXON : NBRCODXON=0 : NBRXON=0
Raz CODIND : Raz AMTIND : NBRCODIND=0 : NBRIND=0
Raz AMTASS1: Raz AMTASS2: NBRASS1=0   : NBRASS2=0
#TEPA
Raz CODHRS : Raz AMTHRS : Raz HRSDAY
NBRCODHRS=0 : NBRHRS=0  : NBRHRSDAY=0
# V08R10
IDAE=-1

# (C) PROSPER V01X06 - Les avantages en nature sont désormais détaillés
Raz TAVNNATD : Raz TAMTAVNNATD : NBRAVNNATD=0 : NBRAMTAVNNATD=0
Raz TEXSPFLD : Raz TAMTEXSPFLD : NBREXSPFLD=0 : NBRAMTEXSPFLD=0

Raz [L]NBRURSBBECOD, [L]NBRURSBBEAMT
Raz [L]TURSBBECOD
Raz [L]TURSBBEAMT
Raz [L]NBRURSBBPCOD, [L]NBRURSBBPAMT
Raz [L]TURSBBPCOD
Raz [L]TURSBBPAMT
Raz [L]NBRBSPCENBRTI, [L]NBRBSPCEPRITI
Raz [L]TBSPCENBRTI
Raz [L]TBSPCEPRITI
Raz [L]NBRPACTYPCOT, [L]NBRPACBRTSAL, [L]NBRPACPLFSAL, [L]NBRPACNBRDAY
Raz [L]TPACTYPCOT, [L]TPACBRTSAL, [L]TPACPLFSAL, [L]TPACNBRDAY
Raz [L]NBRRAETYPSTU, [L]NBRRAEAMTPS, [L]NBRRAEAMTPP
Raz [L]TRAETYPSTU, [L]TRAEAMTPS, [L]TRAEAMTPP

Raz [L]DATVEPMIN, [L]DATVEPMAX

# N4DS - On initialise aussi les tables "DNA"
# If VDNA<>1
Gosub INITIALISATION From EXTRACTION2
# Endif

Return

