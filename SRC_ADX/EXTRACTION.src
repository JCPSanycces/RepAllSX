# TABEVT(NBREVT)=[F:TIM]COD
# NBREVT+=1
#Next
Return

######################################
$DECLAR_PERIO
Local Integer TEMPO
Local Char TZONE
Read [F:TD0]TD00=2;VSOCIETE;VNATFIL;VDNA
If !fstat
 Read [F:ADI]CODE=10367;[F:TD0]OPTFIL
 If !fstat
  Case left$([F:ADI]A1,1)
   When "A"
    DEBANN=[L]STRTRM1
    FINANN=[L]ENDTRM4
   When "S"
    If [F:ADI]A1="S01"
     DEBANN=[L]STRTRM1
     FINANN=[L]ENDTRM2
    Else
     DEBANN=[L]STRTRM3
     FINANN=[L]ENDTRM4
    Endif
   When "T"
    TEMPO=val(right$([F:ADI]A1,3))
    TZONE="[L]STRTRM"+num$(TEMPO)
    DEBANN=evalue(TZONE)
    TZONE="[L]ENDTRM"+num$(TEMPO)
    FINANN=evalue(TZONE)
   When "M"
    TEMPO=val(right$([F:ADI]A1,2))
    DEBANN=gdat$(1,TEMPO,year([L]ENDTRM1))
    FINANN=eomonth(DEBANN)
   Endcase
 Else
  Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI]",0) From GESECRAN
 Endif
Else
 Call ECR_TRACE(mess(4,10707,1)-"PRMTDS0 [TD0]",0) From GESECRAN
Endif
Return

######################################
$PARAMTDS
Read [TD0]TD00=2;VSOCIETE;VNATFIL;VDNA
If fstat>2
 #<Societe> Opération impossible : Paramètres TDS inexistant
 GMESSAGE=VSOCIETE-":"-mess(2,10705,1) :  GERR = 1 : SAI = 1 : Return
Endif
###55314
If [F:TD0]NATFIL="04" : VTYPDEC=3 : Else :  VTYPDEC=1 : Endif
Return

######################################
$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

