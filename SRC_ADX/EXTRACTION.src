$ANNEE
If val(GFLAG)=2
 [M:DIA]YEADDS=num$(year(GMOIPAY))
Else
 Call PARAM("","DADYEA",VALPAR) From ADOVAL
 [M:DIA]YEADDS=VALPAR
Endif
Affzo[M:DIA]YEADDS
Return

