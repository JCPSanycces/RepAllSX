#*************************************************************************************
#***********************RETRAITE (S44.)*********************************
#*************************************************************************************
$GERE_RETRAITE
#On raz même si la nature ne gère pas la retraite (Cf.39311)
# ML Unité : centièmes
[F:DAE]UOMTIMWRK=1 : Raz [F:DAE]LNGWRK

If VNATFIL="01" | VNATFIL="03" | VNATFIL="07"
 Gosub RETRAITE
Endif
Return

$RETRAITE
[F:DAE]LNGWRK=arr(AMTRET,1)*100
Return

#*************************************************************************************
#***********************PREVOYANCE (S45.)*********************************
#*************************************************************************************
$GERE_PREVOY
#On delete même si la nature ne gère pas la prévoyance (Cf.39311)
Delete [F:DAP] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
Delete [F:DPE] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
Delete [F:DPP] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
Delete [F:DAQ] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
Delete [F:DQE] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE

If VNATFIL="01" | VNATFIL="03" | VNATFIL="08"
 Gosub PREVOYANCE
 If ORGCOURANT<>""
  Gosub AYANT_DROITS
 Endif
Endif
Return

###################
$PREVOYANCE
#61316
#Contrat
ORGCOURANT=""
Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,"",ORGCOURANT,GINDPREV-1) From SUBORG
If ORGCOURANT<>""
 #Ref de contrat au niveau groupe : VNUMCTR
 Call ORGAFFIL (ORGCOURANT,[F:FCY]FCY,[F:ID]REFNUM,"",VNUMAFF,VNUMCTR) From SUBORA
 #Recherche organisme de prévoyance si c'est groupe IRC+IP
 Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
 If !fstat & [F:ORG]TYPIRC=7
  For IORG=0 To dim([F:ORG]GRPORG)-1
   Read[F:ORG2]ORG0=GCURLEG;[F:ORG]GRPORG(IORG)
   If !fstat & [F:ORG2]TYPIRC=GINDPREV-1
    ORGCOURANT=[F:ORG]GRPORG(IORG)
    Break
   Endif
  Next
 Endif
 #Relecture sur l'organisme de prévoyance a traiter
 Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
 ##61316
 If !fstat & [F:ORG]NUMDCS<>""
  Read[F:ADI]CODE=10340;[F:ORG]NUMDCS
  If ! fstat & [F:ADI]A1<>""
   Gosub PREVOY_ORG
  Else
   #Organisme non adhérent à la Dads-u
   Call ECR_TRACE(ORGCOURANT-":"-mess(14,10707,1),-1) From GESECRAN
   ORGCOURANT=""
  Endif
 Else
  #Organisme non adhérent à la Dads-u
  Call ECR_TRACE(ORGCOURANT-":"-mess(14,10707,1),-1) From GESECRAN
  ORGCOURANT=""
 Endif
 ##
Endif
Return

###################
#61316
$PREVOY_ORG
# Infos salarié
[F:DAE]DATANC(0)=[F:HRCTR]DATCPY
If [F:HRCTR]CTRDAT>[F:HRCTR]DATCPY
 [F:DAE]DATANC(1)=[F:HRCTR]CTRDAT
Else
 Raz  [F:DAE]DATANC(1)
Endif
[F:DAE]CODSITFAM=[F:ID]SITFAM
[F:DAE]ORGMAL=[F:HRCTR]ORGMAL
[F:DAE]ROWBRN=0
Filter [F:RIB] Where REFNUM=[F:HRCTR]REFNUM & find(TYPPAY,"NP","")<>0 & !find(MODSTL,"CHQ","ESP")
Read [F:RIB]RIB0 First
Filter [F:RIB]
If !fstat
 [F:DAE]IBAN=[F:RIB]IBAN
 [F:DAE]BIC=[F:RIB]BICCOD
 [F:DAE]BID=[F:RIB]BIDNUM
Endif
# Ancienneté
#V08R10
If year([F:DAE]XITDAT)-year([F:HRCTR]DATCPY)>0 & year([F:DAE]XITDAT)-year([F:HRCTR]DATCPY)<60
 [F:DAE]TYPANC(0)=1
 [F:DAE]UOMANC(0)=4    :#en années
 [F:DAE]AMTANC(0)=year([F:DAE]XITDAT)-year([F:HRCTR]DATCPY)
Elsif ([F:DAE]XITDAT-[F:HRCTR]DATCPY)+1<21960
 [F:DAE]TYPANC(0)=1
 [F:DAE]UOMANC(0)=1    :#En jours
 [F:DAE]AMTANC(0)=([F:DAE]XITDAT-[F:HRCTR]DATCPY)+1
Endif
#Ref de contrat au niveau organisme : VNUMCTR
Call ORGAFFIL (ORGCOURANT,[F:FCY]FCY,[F:ID]REFNUM,"",VNUMAFF,VNUMCTR2) From SUBORA
If VNUMCTR2<>"" : VNUMCTR=VNUMCTR2 : Endif
If VNUMCTR<>""
 #Raz [F:DAP]
 [F:DAP]=[F:DAE]
 [F:DAP]REFCTR=VNUMCTR
 #On optimise en réutilisant les mêmes variables...
 Call ORGPRV (ORGCOURANT,[F:FCY]FCY,[F:ID]REFNUM,"",VNUMAFF,VNUMCTR) From SUBORA
 #Code option
 [F:DAP]CODOPT=VNUMAFF
 #Code population
 [F:DAP]CODPOP=VNUMCTR
 #Nb enfants
 [F:DAP]NBRCHD= num$([F:ID]CHD)
 #Institution-> Code organisme + code délégataire
 [F:DAP]NUMDCS=[F:ORG]NUMDCS
 Write [DAP]
 If fstat<>0
  GOK = 0 : Call FSTA("DAP") From GLOCK
 Endif
 If GOK<1
  Gosub AB_TR : Return
 Endif
 Gosub PREVOY_DPE
 If GOK : Gosub PREVOY_DPP : Endif
Else
 #Référence contrat non trouvée
 Call ECR_TRACE(ORGCOURANT-":"-mess(15,10707,1),1) From GESECRAN
Endif
Return

###################
$PREVOY_DPE
#If CODPREV="" | val(CODPREV)<=0 : Return : Endif
For IPRV=1 To dim([F:HRCTR]EVECTRCOD)
 If [F:HRCTR]EVECTRCOD(IPRV-1)="" : Break : Endif
 If [F:HRCTR]EVECTRDAT(IPRV-1)>=[F:DAP]ETRDAT & [F:HRCTR]EVECTRDAT(IPRV-1)<=[F:DAP]XITDAT
#  Raz [F:DPE]
  [F:DPE]=[F:DAP]
  [F:DPE]NUMLIG=IPRV
  [F:DPE]EVECTRCOD=[F:HRCTR]EVECTRCOD(IPRV-1)
  [F:DPE]EVECTRDAT=[F:HRCTR]EVECTRDAT(IPRV-1)
  Write [DPE]
  If fstat<>0
   GOK = 0 : Call FSTA("DPE") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1
 Gosub AB_TR : Return
Endif
Return

###################
$PREVOY_DPP
#Raz [F:DPP]
[F:DPP]=[F:DAP]
[F:DPP]STRDATCTR=[F:DAE]ETRDAT
[F:DPP]ENDDATCTR=[F:DAE]XITDAT
#59274
If NBRTYPPREV
 KK=0
 For J=0 To NBRTYPPREV-1
  KK=find(TYPPREV(J),[F:DPP]CODTYPBAS(0..dim([F:DPP]CODTYPBAS)-1))
  If KK
   [F:DPP]AMTBAS(KK-1)+=arr(AMTPREV(J),0.01)
  Else
   [F:DPP]CODTYPBAS(J)=TYPPREV (J)
   [F:DPP]AMTBAS(J)=arr(AMTPREV(J),0.01)
  Endif
 Next
Endif
For IPRV=1 To 9
 ZONE="[F:DPP]AMTPRV"+num$(IPRV)
 Assign ZONE With PRVAMT(IPRV-1)
Next
[F:DPP]NBRPEO2=[F:HRCTR]NBRPEO2
[F:DPP]NBRPEO3=[F:HRCTR]NBRPEO3
[F:DPP]NBRPEO4=[F:HRCTR]NBRPEO4
#total (invisible à l'écran)
[F:DPP]NBRPEO1=[F:HRCTR]NBRPEO2+[F:HRCTR]NBRPEO3+[F:HRCTR]NBRPEO4
Write [DPP]
If fstat<>0
 GOK = 0 : Call FSTA("DPP") From GLOCK
Endif
If GOK<1
 Gosub AB_TR : Return
Endif
Return

###################
$AYANT_DROITS
#61450 : Ne plus se baser sur [F:HRCTR]AFFMUT
#If val([F:HRCTR]AFFMUT)<3: Return : Endif
#If val([F:HRCTR]AFFMUT)=3

#Adulte Conjoint
If [F:HRCTR]NBRPEO3>0
 #Raz [F:DAQ]
 [F:DAQ]=[F:DAE]
 [F:DAQ]NUMLIG=uniqid([DAQ])
 [F:DAQ]TYPBNF=1
 [F:DAQ]NAMBNF=[F:ID]JNTNAM
 [F:DAQ]SRNBNF=[F:ID]JNTNAM
 #[F:DAQ]DATBRNBNF=
 # A charge
 If [F:ID]ADT>0 : [F:DAQ]FLGBNF1=2 : Endif
 #[F:DAQ]NUMSSBNF(0)=
 #[F:DAQ]NUMSSBNF(1)=
 #[F:DAQ]ROWBRNBNF=
 [F:DAQ]ORGMALBNF=[F:DAE]ORGMAL
 Write [DAQ]
 If fstat<>0
  GOK = 0 : Call FSTA("DAQ") From GLOCK
  Endif
 If GOK<1
  Gosub AB_TR : Return
 Endif
 Gosub PREVOY_DQE
Endif

#Enfants
#For IPRV=1 To val([F:HRCTR]AFFMUT)-3
If [F:HRCTR]NBRPEO2
 For IPRV=1 To [F:HRCTR]NBRPEO2
  #Raz [F:DAQ]
  [F:DAQ]=[F:DAE]
  [F:DAQ]NUMLIG=uniqid([DAQ])
  [F:DAQ]TYPBNF=2        :#enfant
  Read [F:CHD]CHD0=[F:ID]REFNUM;IPRV
  If !fstat
   [F:DAQ]NAMBNF=[F:CHD]CHDNAM
   [F:DAQ]SRNBNF=[F:CHD]CHDSRN
   [F:DAQ]DATBRNBNF=[F:CHD]DATCHDBRN
  Endif
  # A charge
  If [F:ID]CHD>=IPRV: [F:DAQ]FLGBNF1=2 : Endif
  #[F:DAQ]NUMSSBNF(0)=
  #[F:DAQ]NUMSSBNF(1)=
  #[F:DAQ]ROWBRNBNF=
  [F:DAQ]ORGMALBNF=[F:DAE]ORGMAL
  Write [DAQ]
  If fstat<>0
   GOK = 0 : Call FSTA("DAQ") From GLOCK
  Endif
  If GOK<1
   Gosub AB_TR : Return
  Endif
  Gosub PREVOY_DQE
 Next
Endif

#Autres
If [F:HRCTR]NBRPEO4
 For IPRV=1 To [F:HRCTR]NBRPEO4
  #Raz [F:DAQ]
  [F:DAQ]=[F:DAE]
  [F:DAQ]NUMLIG=uniqid([DAQ])
  [F:DAQ]TYPBNF=3        :#Autres
  #[F:DAQ]NAMBNF=
  #[F:DAQ]SRNBNF=
  #[F:DAQ]DATBRNBNF=
  #[F:DAQ]FLGBNF1=
  #[F:DAQ]NUMSSBNF(0)=
  #[F:DAQ]NUMSSBNF(1)=
  #[F:DAQ]ROWBRNBNF=
  [F:DAQ]ORGMALBNF=[F:DAE]ORGMAL
  Write [DAQ]
  If fstat<>0
   GOK = 0 : Call FSTA("DAQ") From GLOCK
  Endif
  If GOK<1
   Gosub AB_TR : Return
  Endif
  Gosub PREVOY_DQE
 Next
Endif
Return

######################################
$PREVOY_DQE
#Raz [F:DQE]
[F:DQE]=[F:DAQ]
[F:DQE]LIG=1
[F:DQE]REFCTRBNF=[F:DAP]REFCTR
[F:DQE]CODOPTBNF=[F:DAP]CODOPT
#[F:DQE]STRDATBNF=
#[F:DQE]ENDDATBNF=
Write [DQE]
If fstat<>0
 GOK = 0 : Call FSTA("DQE") From GLOCK
Endif
If GOK<1
 Gosub AB_TR : Return
Endif
Return

#*************************************************************************************
#*************************************BTP(S56.)***************************************
#*************************************************************************************

$GERE_BTP
If VNATFIL="04"   :#Déclaration BTP
 Gosub AFFECTE_BTP
Endif
Return

######################################
$AFFECTE_BTP
Local Char CRITTIP (250)
Local Integer NBEVT

#No adhésion CCPB
[F:DAE]BUINUMCAI=[F:HRCTR]NUMCCP
#Temps de travail en heures ouvrées par défaut
#55316
[F:DAE]BUICODTIM=[F:HRCTR]BUICODTIM
[F:DAE]BUIDAYTYP=[F:HRCTR]BUIDAYTYP
[F:DAE]BUITIMWRK=AMTBTP(0)*100
#Ancienneté
If [F:HRCTR]DATANC<>[00/00/0000]
 [F:DAE]BUINBRYEA(0)=val([M:DIA]YEADDS)-year([F:HRCTR]DATANC)
Endif
If [F:HRCTR]DATANCAPT<>[00/00/0000]
 [F:DAE]BUINBRYEA(1)=val([M:DIA]YEADDS)-year([F:HRCTR]DATANCAPT)
Endif
#Bénéficiaire ASSEDIC oui/non
#55316
[F:DAE]BUICODASS=[F:HRCTR]BUICODASS
#Salaire mensuel
#55316
[F:DAE]BUICODSAL=[F:HRCTR]BUICODSAL
[F:DAE]BUISALMOY=AMTBTP(1)*100
#Horaire hebdomadaire
#55316
[F:DAE]BUICODHRS=[F:HRCTR]BUICODHRS
[F:DAE]BUIHRSEMP=[F:HRCTR]HRSWEK
[F:DAE]BUIHRSFCY=val(func AFNC.PARAM("HOUWEKLEG",[F:DAE]ETRFCY))
#Situation familiale
[F:DAE]BUISITFAM=[F:ID]SITFAM
#Nb d'enfants
[F:DAE]BUINBRCHD= num$([F:ID]CHD)
#Taux abattement frais prof.
[F:DAE]BUIRATEXS=[F:HRCTR]BUIRATEXS
#Statut cotisant
[F:DAE]BUISTAPAY=[F:HRCTR]BUISTAPAY
#Code métier
[F:DAE]BUICODJOB=[F:HRCTR]BUICODJOB
#Affiliation retraite compl & prevoyance
[F:DAE]BUIRETPRV=[F:HRCTR]BUIRETPRV
Return

