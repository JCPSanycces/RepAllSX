######################################
$AFFECTE_EMPLOYE
FLAGEMP=0
# N4DS - On ne gère la paye de rappel qu'en mode DADSU
If VDNA <> 2
 ### Gestion de paye de rappel sur les années précédentes
 If ENTREE<DEBANN
     Readlock [F:DAE]DAE0=[M:DIA]YEADDS;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;DEBANN;VTYPDEC;VDNA
 Else
     Readlock [F:DAE]DAE0=[M:DIA]YEADDS;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;ENTREE;VTYPDEC;VDNA
 Endif
Else
 Readlock [F:DAE]DAE0=[M:DIA]YEADDS;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;ENTREE;VTYPDEC;VDNA
Endif
If fstat=5
 FLAGEMP=1
Elsif [F:DAE]FLG=2    :# 63358 : déclaré
 #Mise à jour impossible : fiche déjà Déclarée. Matricule XXX - période XXX XXX
 Call ECR_TRACE(mess(89,10705,1)-mess(80,10703,1)-[F:DAE]EMPDDS-"-"-mess(158,200,1)-num$([F:DAE]ETRDAT)-num$([F:DAE]XITDAT),-1) From GESECRAN
 If SORTIE=FINANN : EFFECTIF+=1 : Endif : #à prendre dans effectif quand même !
 Return
Endif


#N4DS
#Pour la remise à zéro des zones calculées
#A faire avant le $AFFECTE_MONTANT (et le $RANGEMENT)!
Raz [F:DAE] : Raz [F:DAS] :
Raz [F:DAG] : Raz [F:DAH] : Raz [F:DAI] : Raz [F:DAJ] : Raz [F:DAK] : Raz [F:DAL] : Raz [F:DAM]: Raz [F:DAQ] : Raz [F:DQE]
Raz [F:DAP] : Raz [F:DPE] : Raz [F:DPP] : Raz [F:DMU] : Raz [F:DMP] : Raz [F:DME]
Raz [F:DNA] : Raz [F:DNB] : Raz [F:DNC] : Raz [F:DND] : Raz [F:DNE] : Raz [F:DNF] : Raz [F:DNG]
If GINTMT : Raz [F:DNH] : Endif

#Recupération des infos salariés
Read [F:ID]ID0=[F:HRCTR]REFNUM
If !fstat
    [F:DAE]=[F:ID]
    If [F:ID]JNTREFNUM<>""
        [F:DAE]FLGJNT=2
    Else
        [F:DAE]FLGJNT=1
    Endif
Endif
Read [F:AD]AD0=[F:HRCTR]REFNUM
If !fstat : [F:DAE]=[F:AD] : Endif

[F:DAE]=[F:HRCTR]

If [F:HRCTR]RSKWRK<>""
 Read [WAC]WAC0=[F:HRCTR]RSKWRK
 If fstat=0
  [F:DAE]=[F:WAC]
  [F:DAE]RSKWRK= [F:WAC]CODWAC
  #DBA le 07/10/04 : Historisation des taux AT.
  Filter [WAR] Where CODWAC=[F:WAC]CODWAC & DATWAC<=SORTIE
  Read [WAR]WAR0 Last
  Filter [WAR]
  If fstat=0
   [F:DAE]RATWAC=[F:WAR]RATWAC
  Endif
 Endif
Endif

#N4DS : Taux abat que si 'forfait'
#[F:DAE]DED alimenté par le transclass
If [F:HRCTR]OPEDED<>2 : Raz [F:DAE]DED : Endif

#[F:DAE]SEVEMP alimenté par le transclass
If [F:DAE]SEVEMP>2 : Raz [F:DAE]SEVEMP : Endif
If [F:HRCTR]SEVCTR<3 : [F:DAE]SEVJOB=[F:HRCTR]SEVCTR : Endif

[F:DAE]EMPDDS=[F:HRCTR]REFNUM
[F:DAE]YEAEMPDDS=[M:DIA]YEADDS
[F:DAE]FLG=1    :#Non déclaré
###55314
#[F:DAE]TYPDAE=1
[F:DAE]TYPDAE=VTYPDEC
###
[F:DAE]FLGDNA=VDNA
[F:DAE]ETRDAT=ENTREE
[F:DAE]XITDAT=SORTIE
[F:DAE]ETRGRD=EMOTIF
[F:DAE]XITGRD=SMOTIF

[F:DAE]DADFCY=[F:FCY]FCY

# Multi_leg & multi_société
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG=[F:CPY]LEG

#70719
Read [F:HRCGD]HRCGD0=[F:DAE]ETRGRD;GCURLEG
If !fstat & ([F:HRCGD]CODN4H="095" | [F:HRCGD]CODN4H="143")
    [F:DAE]PRUCTR=2
Endif

Call SIMPLEREAD([F:DAE]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
If !GERRHRM & ([F:HRXGD]CODN4H="096" | [F:HRXGD]CODN4H="144")
    [F:DAE]PRUCTR=2
Endif

#Si droit privé
If [F:DAE]PRUCTR=1
    [F:DAE]PRUFLG=[L]PRESENT #Contrat en vigeur au 31/12 (O/N)
Else
    [F:DAE]PRUFLG=1
Endif
If LASTMOIS<>12
    [F:DAE]MOVPAY=3
Else
    [F:DAE]MOVPAY=1
Endif
[F:DAE]NATBAS=1 :# Base réelle (non forfaitaire)
[F:DAE]AGFFLG=1 :# Salarié Non exonéré d'AGFF

Gosub AFFECTE_MONTANT

#62204
# N4DS - Avantages en nature et frais professionnels gérés différemment et en détail
# If ![F:DAE]AMTAVNNAT : Raz [F:DAE]AVNNAT : Endif
# If ![F:DAE]AMTEXSPFL : Raz [F:DAE]EXSPFL : Endif
#

#80108
If [F:DAE]CATJOB<>""
 Read[F:ADI]CODE=10357;[F:DAE]CATJOB
 If !fstat & ([F:ADI]A1='07' | [F:ADI]A1='37')
  Raz[F:DAE]RSKWRK,SCTFCY,CODRSK,CODOFC,RATWAC,HRSWRK
 Endif
Endif
If [F:DAE]PSNJOB<>""
 Read[F:ADI]CODE=10604;[F:DAE]PSNJOB
 If !fstat & ([F:ADI]A1='07' | [F:ADI]A1='37')
  Raz[F:DAE]RSKWRK,SCTFCY,CODRSK,CODOFC,RATWAC,HRSWRK
 Endif
Endif

# N4DS - Rangement des avantages en nature
Raz [L]X
Raz [F:DAE]AVNNATD, [F:DAE]AMTAVNNATD, [F:DAE]AVNNAT, [F:DAE]AMTAVNNAT, [F:DAE]NTIC
For J=0 To NBRAVNNATD - 1
    If [L]TAVNNATD([L]J) <> 0 & [L]TAMTAVNNATD([L]J) <> 0
        [F:DAE]AVNNATD([L]X) = [L]TAVNNATD([L]J)
        [F:DAE]AMTAVNNATD([L]X) = arr(TAMTAVNNATD([L]J),0.01)

        [F:DAE]AMTAVNNAT += [F:DAE]AMTAVNNATD([L]X)

        [L]LETTRE = mid$(mess(0, 10802, 1), [F:DAE]AVNNATD([L]X), 1)
        If [L]LETTRE = "I"
            [F:DAE]NTIC = 2
        Else
            [F:DAE]AVNNAT += [L]LETTRE
        Endif

        [L]X += 1
    Endif
Next

# N4DS - Rangement des frais professionnels

Raz [L]X
Raz [F:DAE]EXSPFLD, [F:DAE]AMTEXSPFLD, [F:DAE]AMTEXSPFL, [F:DAE]EXSPFL
For J=0 To NBREXSPFLD - 1
    If [L]TEXSPFLD([L]J) <> 0 & [L]TAMTEXSPFLD([L]J) <> 0
        [F:DAE]EXSPFLD([L]X) = [L]TEXSPFLD([L]J)
        [F:DAE]AMTEXSPFLD([L]X) = arr(TAMTEXSPFLD([L]J),0.01)

        [F:DAE]AMTEXSPFL += [F:DAE]AMTEXSPFLD([L]X)

        [L]LETTRE = mid$(mess(0, 10803, 1), [F:DAE]EXSPFLD([L]X), 1)
        [F:DAE]EXSPFL += [L]LETTRE

        [L]X += 1

    Endif
Next

# N4DS - BSPCE

Raz [L]X
Raz [F:DAE]BSPCENBRTI, [F:DAE]BSPCEPRITI, [F:DAE]BSPCEFRGTI, [F:DAE]BSPCEDATTI, [F:DAE]BSPCEDURTI
For J=0 To NBRBSPCENBRTI - 1
    If [L]TBSPCENBRTI([L]J) <> 0
        [F:DAE]BSPCENBRTI([L]X) = [L]TBSPCENBRTI([L]J)
        [F:DAE]BSPCEPRITI([L]X) = arr(TBSPCEPRITI([L]J),0.01)
        [L]X += 1
    Endif
Next

Raz [L]X
Raz [F:DAE]PACTYPCOT, [F:DAE]PACBRTSAL, [F:DAE]PACPLFSAL, [F:DAE]PACNBRDAY
For J=0 To [L]NBRPACTYPCOT - 1
    If [L]TPACTYPCOT([L]J) <> 0
        [F:DAE]PACTYPCOT([L]X) = [L]TPACTYPCOT([L]J)
        [F:DAE]PACBRTSAL([L]X) = arr([L]TPACBRTSAL([L]J),0.01)
        [F:DAE]PACPLFSAL([L]X) = arr([L]TPACPLFSAL([L]J),0.01)
        [F:DAE]PACNBRDAY([L]X) = arr([L]TPACNBRDAY([L]J),0.01)
        [L]X += 1
    Endif
Next

Raz [L]X
Raz [F:DAE]RAETYPSTU, [F:DAE]RAEAMTPS, [F:DAE]RAEAMTPP
For J=0 To [L]NBRRAETYPSTU - 1
    If [L]TRAETYPSTU([L]J) <> 0
        [F:DAE]RAETYPSTU([L]X) = [L]TRAETYPSTU([L]J)
        [F:DAE]RAEAMTPS([L]X) = arr([L]TRAEAMTPS([L]J),0.01)
        [F:DAE]RAEAMTPP([L]X) = arr([L]TRAEAMTPP([L]J),0.01)
        [L]X += 1
    Endif
Next

If K<NBPERIO :#pas la dernière fiche
    [F:DAE]YEAWRK=0
    [F:DAE]TRMWRK=0
    [F:DAE]MTHWRK=0
Else
    [F:DAE]YEAWRK=min(DERANN(0..K-1)) :#Valeur possible 1 ou 99
    If [F:DAE]YEAWRK=1
        [F:DAE]TRMWRK=98
        [F:DAE]MTHWRK=98
    Else
        For IDER=0 To K
            If DERTRM(IDER)<=12 : [F:DAE]TRMWRK=max([F:DAE]TRMWRK,DERTRM(IDER)): Endif
        Next
        If [F:DAE]TRMWRK<>0
            [F:DAE]MTHWRK=98
        Else
            [F:DAE]TRMWRK=99
            For IDER=0 To K
                If DERMTH(IDER)<=12 : [F:DAE]MTHWRK=max([F:DAE]MTHWRK,DERMTH(IDER)) : Endif
            Next
            If [F:DAE]MTHWRK=0 : [F:DAE]MTHWRK=99 : Endif
        Endif
    Endif
Endif

# Gestion N4DS - Si AED alors ne pas tenir compte de la paye de rappel
If VDNA <> 2
    ###Gestion de paye de rappel sur les années précédentes
    ###La date debut et de fin doit être égal au 01/01 !
    If [F:DAE]XITDAT<DEBANN
        [F:DAE]ETRDAT=DEBANN
        [F:DAE]XITDAT=DEBANN
    Endif
Else
    # Ben rien, on aura des enregistrements "2011" qui pointe sur des périodes des années antérieures ...
Endif

######Affectation des zones pour S40
Gosub AFFECTE_DAS

If VDNA=1
 # DBA remise du If ci-dessus : Ne pas faire en AED
 # car pas le champ FLGDNA dans les clé des tables servies ici
 # -> Erreur clé déjà existante  en extraction AED si Dads-u ok.
 Gosub AFFECTE_DAM
 Gosub AFFECTE_EPG
 Gosub AFFECTE_ACT
 Gosub AFFECTE_AVG
 Gosub AFFECTE_XON
 Gosub AFFECTE_IND
 Gosub AFFECTE_ASS
 ######Affectation des zones pour S44
 Gosub GERE_RETRAITE
 ######Affectation des zones pour S45
 Gosub GERE_PREVOY
 ######Affectation des zones pour S56
 Gosub GERE_BTP
Endif

Gosub AFFECTE_DNA From EXTRACTION2

# N4DS - Zone FLGAED pour détecter les déclencheurs AED
# Menu local alimenté par un cumul (VS4800xxx) qui renvoie 0 ou 1 , on ajoute 1 pour avoir la valeur du menu local
If dim([F:DAE]FLGAED) > 0
  [F:DAE]FLGAED += 1
Endif

If SORTIE=FINANN : EFFECTIF+=1 : Endif

Gosub SAUVE_DAE
#Matricule XXX - période XXX XXX
Call ECR_TRACE(mess(80,10703,1)-[F:DAE]EMPDDS-"-"-mess(10787,200,1)-num$([F:DAE]ETRDAT)-num$([F:DAE]XITDAT),0) From GESECRAN
Return

######################################
$SAUVE_DAE
If FLAGEMP=1
 If dim([F:DAE]CREDAT)>0 : [F:DAE]CREDAT = date$ : Endif
 If dim([F:DAE]CREUSR)>0 : [F:DAE]CREUSR = GUSER : Endif
 If dim([F:DAE]CRETIM)>0 : [F:DAE]CRETIM = time  : Endif
 #Faire ça à cause des trans-classe !!!
 If dim([F:DAE]UPDDAT)>0 : [F:DAE]UPDDAT = [0/0/0] : Endif
 If dim([F:DAE]UPDUSR)>0 : [F:DAE]UPDUSR = "" : Endif
 If dim([F:DAE]UPDTIM)>0 : [F:DAE]UPDTIM = 0  : Endif
 Write [F:DAE]
Else
 If dim([F:DAE]UPDDAT)>0 : [F:DAE]UPDDAT = date$ : Endif
 If dim([F:DAE]UPDUSR)>0 : [F:DAE]UPDUSR = GUSER : Endif
 If dim([F:DAE]UPDTIM)>0 : [F:DAE]UPDTIM = time  : Endif
 Rewrite [F:DAE]
Endif
If fstat<>0
 GOK = 0 : Call FSTA("DAE") From GLOCK
Endif
If GOK<1
 Gosub AB_TR :  Return
Endif
Return

######################################
$AFFECTE_MONTANT
Local Decimal RESULTAT, RESULDEC
Local Decimal WRESULT
Local Char CHAMP (20)
Gosub INITIALISATION
For [TD1]TD10 Where LEV=2 & CPY=VSOCIETE & NATFIL=VNATFIL & FLGDNA=VDNA
 RESULTAT=0 : MONTANT=0 : RESULDEC=0
 If VDNA<>2  | ![L]SLDOK
  For [VEP]VEP0 Where EMP=[F:DAE]EMPDDS & FCY=[F:DAE]ETRFCY & CTRNUM=[F:DAE]CTRNUM
&       & STRDAT>=[F:DAE]ETRDAT & STRDAT<=[F:DAE]XITDAT & RVSDAT=[0/0/0] & ORIDAT=[0/0/0] :#On exclut les extournes et les extournées
   Gosub MONTANT_COMMUN
  Next
 Else
  Read[VEP]VEP5=[F:VEP2]BUL
  If !fstat : Gosub MONTANT_COMMUN : Endif
 Endif
 RESULDEC=RESULTAT
 # N4DS - RESULTAT arrondi au centime
 RESULTAT=arr(RESULTAT,0.01)
 Gosub RANGEMENT
Next : # [TD1]
Return

#############################
$MONTANT_COMMUN
NO_VEP=1
If [F:TD1]TYP<>7 :#pas une variable
 If [F:TD1]TYP<7
  Filter [HSP] Where BUL=[F:VEP]BUL & RUB=[F:TD1]COD & (TYP=[TD1]TYP or TYP=[TD1]TYP+6)
 Else
  #Tax band
  Filter [HSP] Where BUL=[F:VEP]BUL & RUB=[F:TD1]COD & (TYP=[TD1]TYP+2)
 Endif
 For [HSP]HSP3
  If [F:TD1]TYP<>6 :#pas un cumul
   Gosub RECUP_MONTANT
   RESULTAT+=MONTANT
  Else
   Read[F:CUM]CUM0=GCURLEG;[F:TD1]COD
   If !fstat
    Gosub RECUP_CUMMTT
    If [F:CUM]CUMPER=7  :#périodicité dads-u
     If MONTANT<>0 : RESULTAT=MONTANT : Endif : #on prend la valeur de la dernière paye de la période
    Else
     RESULTAT+=MONTANT
    Endif
   Endif
  Endif
 Next
 Filter [HSP]
Else
 Gosub RECUP_VARIABLE
 RESULTAT+=MONTANT
Endif
If ([F:TD1]FLD="[F:DNB]DNACODPRM" | [F:TD1]FLD="[F:DNG]DNACODRAP") & MONTANT
 If [L]DATVEPMIN=[0/0/0] :  [L]DATVEPMIN=[F:VEP]STRDAT : Endif
 [L]DATVEPMIN=min([L]DATVEPMIN,[F:VEP]STRDAT)
 [L]DATVEPMAX=max([L]DATVEPMAX,[F:VEP]ENDDAT)
Endif
Return

######################################
$RANGEMENT
[L]I = instr(1, [F:TD1]FLD, "]")
[L]CHAMP = mid$([F:TD1]FLD, [L]I+1, len([F:TD1]FLD)-[L]I)
If [L]CHAMP<>""
    Case CHAMP

        When "SPEBASCOD" :  #Code Base brute spécif (S40)

            If NBRCODBBS<=100 & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    CODBBS(NBRCODBBS)=num$(RESULTAT)
                Else
                    CODBBS(NBRCODBBS)="0"+num$(RESULTAT)
                Endif
                NBRCODBBS+=1
            Endif

        #Base brute spécif (S40)
        When "SPEBASAMT" :
            If NBRAMTBBS<=100  & RESULTAT<>0
                AMTBBS(NBRAMTBBS)+=RESULTAT
                NBRAMTBBS+=1
            Endif

        When "SPEBASPLF"
            If NBRPLFBBS<=100  & RESULTAT<>0
                PLFBBS(NBRPLFBBS)+=RESULTAT
                NBRPLFBBS+=1
            Endif

        #Code Base plafonnée spécif (S40)
        When "SPECLGCOD"
            If NBRCODBPS<=100  & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    CODBPS(NBRCODBPS)=num$(RESULTAT)
                Else
                    CODBPS(NBRCODBPS)="0"+num$(RESULTAT)
                Endif
                NBRCODBPS+=1
            Endif

        #Base plafonnée spécif (S40)
        When "SPECLGAMT"
            If NBRAMTBPS<=100 & RESULTAT<>0
                AMTBPS(NBRAMTBPS)+=RESULTAT
                NBRAMTBPS+=1
            Endif

        #Code sommes isolées (S40)
        When "ALOAMTCOD"
            If NBRCODISO<=100 & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    CODISO(NBRCODISO)=num$(RESULTAT)
                Else
                    CODISO(NBRCODISO)="0"+num$(RESULTAT)
                Endif
                NBRCODISO+=1
            Endif

        #Bases sommes isolées (S40)
        When "ALOAMTBAS"
            If NBRBISO<=100  & RESULTAT<>0
                BASEISO(NBRBISO)+=RESULTAT
                NBRBISO+=1
            Endif

        #Plafond sommes isolées (S40)
        When "ALOAMTCLG"
            If NBRPISO<=100 & RESULTAT<>0
                PLAFISO(NBRPISO)+=RESULTAT
                NBRPISO+=1
            Endif

        # N4DS - Montant sommes isolées
        When "ALOAMTAMT"
            If NBRMISO<=100 & RESULTAT<>0
                MONTISO(NBRMISO)+=RESULTAT
                NBRMISO+=1
            Endif

        #Code type exo(S40)
        When "SPEEXOCOD"
            If NBRCODEXO<=100 & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    CODEXO(NBRCODEXO)=num$(RESULTAT)
                Else
                    CODEXO(NBRCODEXO)="0"+num$(RESULTAT)
                Endif
                NBRCODEXO+=1
            Endif

        #Base brute exo (S40)
        When "SPEEXOBAS"
            If NBRBEXO<=100  & RESULTAT<>0
                BRUTEXO(NBRBEXO)+=RESULTAT
                NBRBEXO+=1
            Endif

        #Base plaf exo (S40)
        When "SPEEXOCLG"
            If NBRPEXO<=100 & RESULTAT<>0
                PLAFEXO(NBRPEXO)+=RESULTAT
                NBRPEXO+=1
            Endif

        # N4DS - Montant exo ursaff
        When "SPEEXOAMT"
            If [L]NBRMONTEXO <= 100 & [L]RESULTAT <> 0
                [L]MONTEXO([L]NBRMONTEXO) += [L]RESULTAT
                [L]NBRMONTEXO += 1
            Endif

        #------------------------------------
        # N4DS - Urssaf / Base brute exceptionnelle
        #------------------------------------

        # Code
        When "URSBBECOD"
            If NBRURSBBECOD<=100 & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    [L]TURSBBECOD([L]NBRURSBBECOD)=num$(RESULTAT)
                Else
                    [L]TURSBBECOD([L]NBRURSBBECOD)="0"+num$(RESULTAT)
                Endif
                [L]NBRURSBBECOD+=1
            Endif

        # Montant
        When "URSBBEAMT"
            If NBRURSBBEAMT<=100  & RESULTAT<>0
                [L]TURSBBEAMT([L]NBRURSBBEAMT)+=RESULTAT
                [L]NBRURSBBEAMT += 1
            Endif

        #------------------------------------
        # N4DS - Urssaf / Base plafonnée
        #------------------------------------

        When "URSBBPCOD"
            If [L]NBRURSBBPCOD<=100 & [L]RESULTAT<>0
                If len(num$([L]RESULTAT))>1
                    [L]TURSBBPCOD([L]NBRURSBBPCOD)=num$(RESULTAT)
                Else
                    [L]TURSBBPCOD([L]NBRURSBBPCOD)="0"+num$(RESULTAT)
                Endif
                [L]NBRURSBBPCOD+=1
            Endif

        # Montant
        When "URSBBPAMT"
            If NBRURSBBPAMT<=100  & RESULTAT<>0
                [L]TURSBBPAMT([L]NBRURSBBPAMT)+=RESULTAT
                [L]NBRURSBBPAMT += 1
            Endif

        # N4DS - BSPCE

        When "BSPCENBRTI"
            If [L]NBRBSPCENBRTI <= 100 & [L]RESULTAT <> 0
                [L]TBSPCENBRTI([L]NBRBSPCENBRTI) += [L]RESULTAT
                [L]NBRBSPCENBRTI += 1
            Endif

        When "BSPCEPRITI"
            If [L]NBRBSPCEPRITI <= 100 & [L]RESULTAT <> 0
                [L]TBSPCEPRITI([L]NBRBSPCEPRITI) += [L]RESULTAT
                [L]NBRBSPCEPRITI += 1
            Endif

        # N4DS - CRPNPAC

        When "PACTYPCOT"
            If [L]NBRPACTYPCOT <= 100 & [L]RESULTAT <> 0
                [L]TPACTYPCOT([L]NBRPACTYPCOT) += [L]RESULTAT
                [L]NBRPACTYPCOT += 1
            Endif

        When "PACBRTSAL"
            If [L]NBRPACBRTSAL <= 100 & [L]RESULTAT <> 0
                [L]TPACBRTSAL([L]NBRPACBRTSAL) += [L]RESULTAT
                [L]NBRPACBRTSAL += 1
            Endif

        When "PACPLFSAL"
            If [L]NBRPACPLFSAL <= 100 & [L]RESULTAT <> 0
                [L]TPACPLFSAL([L]NBRPACPLFSAL) += [L]RESULTAT
                [L]NBRPACPLFSAL += 1
            Endif

        When "PACNBRDAY"
            If [L]NBRPACNBRDAY <= 100 & [L]RESULTAT <> 0
                [L]TPACNBRDAY([L]NBRPACNBRDAY) += [L]RESULTAT
                [L]NBRPACNBRDAY += 1
            Endif

        When "RAETYPSTU"
            If [L]NBRRAETYPSTU <= 100 & [L]RESULTAT <> 0
                [L]TRAETYPSTU([L]NBRRAETYPSTU) += [L]RESULTAT
                [L]NBRRAETYPSTU += 1
            Endif

        When "RAEAMTPS"
            If [L]NBRRAEAMTPS <= 100 & [L]RESULTAT <> 0
                [L]TRAEAMTPS([L]NBRRAEAMTPS) += [L]RESULTAT
                [L]NBRRAEAMTPS += 1
            Endif

        When "RAEAMTPP"
            If [L]NBRRAEAMTPP <= 100 & [L]RESULTAT <> 0
                [L]TRAEAMTPP([L]NBRRAEAMTPP) += [L]RESULTAT
                [L]NBRRAEAMTPP += 1
            Endif

        #Durée effective du travail (S44)
        When "LNGWRK"
            AMTRET+=RESULDEC

        #Code type base de prévoyance (S45)
        When "CODTYPBAS"
            #59274
            If NBRTYPPREV<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10374,1))
                TYPPREV(NBRTYPPREV)=RESULTAT
                NBRTYPPREV+=1
            Endif

        #Base prévoyance (S45)
        When "AMTBAS"
            #59274
            If NBRAMTPREV<=100 & RESULTAT<>0
                AMTPREV(NBRAMTPREV)=RESULTAT
                NBRAMTPREV+=1
            Endif

        #Temps de travail (S56)
        When "BUITIMWRK"
            AMTBTP(0)+=RESULDEC

        #Salaire moyen (S56)
        When "BUISALMOY"
            AMTBTP(1)+=RESULDEC

        #Code Epargne Salariale
        When "CODDAG" :
            If NBRCODEPG<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10954,1))
                CODEPG(NBRCODEPG)=RESULTAT
                NBRCODEPG+=1
            Endif

        #Mtt Epargne Salariale
        When "AMTDAG" :
            If NBREPG<=100 & RESULTAT<>0
                AMTEPG(NBREPG)+=RESULTAT
                NBREPG+=1
            Endif

        #Nb d'actions gratuites attribués
        When "NBRACT" :
            If NBRNBRACT<=100 & RESULTAT<>0
                NBRACT(NBRNBRACT)+=RESULTAT
                NBRNBRACT+=1
            Endif

        #Valeur unitaire action
        When "VALACT" :
            If NBRVAL<=100 & RESULDEC<>0
                VALACT(NBRVAL)+=RESULDEC
                NBRVAL+=1
            Endif

        # V08R10
        #Prix & Valeur de l'option
        When "NBRSTK" :
            If RESULTAT
                IDAE+=1   :#Init à -1
                If IDAE<=10
                    WRESULT=evalue([F:TD1]FLD)+RESULTAT
                    Assign [F:TD1]FLD With WRESULT
                Endif
            Endif

        When "VALSTK"
            If IDAE>=0 & IDAE<=10
                WRESULT=evalue([F:TD1]FLD)+RESULDEC
                Assign [F:TD1]FLD With WRESULT
            Endif

        When "PRISTK"
            If IDAE>=0 & IDAE<=10
                WRESULT=evalue([F:TD1]FLD)+RESULDEC
                Assign [F:TD1]FLD With WRESULT
            Endif

        #Code avantages particuliers
        When "CODDAI" :
        If NBRCODAVG<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10955,1))
            CODAVG(NBRCODAVG)=RESULTAT
            NBRCODAVG+=1
        Endif

        #Mtt particip. patron. financement avantages particuliers
        When "AMTDAI" :
            If NBRAVG<=100 & RESULTAT<>0
                AMTAVG(NBRAVG)+=RESULTAT
                NBRAVG+=1
            Endif

        #Code type sommes exonérées
        When "CODDAJ" :
            If NBRCODXON<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10956,1))
                CODXON(NBRCODXON)=RESULTAT
                NBRCODXON+=1
            Endif

        #Mtt somme exonérée
        When "AMTDAJ" :
            If NBRXON<=100 & RESULTAT<>0
                AMTXON(NBRXON)+=RESULTAT
                NBRXON+=1
            Endif

        #Code type indemnités versées
        When "CODDAK" :
            If NBRCODIND<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10957,1))
                CODIND(NBRCODIND)=RESULTAT
                NBRCODIND+=1
            Endif

        #Mtt indemnité versée
        When "AMTDAK" :
            If NBRIND<=100 & RESULTAT<>0
                AMTIND(NBRIND)+=RESULTAT
                NBRIND+=1
            Endif

        #Assiette exonéré de cot. SS
        When "AMTDAL1" :
            If NBRASS1<=100 & RESULTAT<>0
                AMTASS1(NBRASS1)+=RESULTAT
                NBRASS1+=1
            Endif

        #Assiette exonérée de cot CSG/CRDS
        When "AMTDAL2" :
        If NBRASS2<=100 & RESULTAT<>0
            AMTASS2(NBRASS2)+=RESULTAT
            NBRASS2+=1
        Endif

        #TEPA
        #Code type de rémunérations
        When "CODBRTHRS"  :
            If NBRCODHRS<=100  & RESULTAT<>0
                If len(num$(RESULTAT))>1
                    CODHRS(NBRCODHRS)=num$(RESULTAT)
                Else
                    CODHRS(NBRCODHRS)="0"+num$(RESULTAT)
                Endif
                NBRCODHRS+=1
            Endif

        When "AMTBRTHRS"  :
            If NBRHRS<=100  & RESULTAT<>0
                AMTHRS(NBRHRS)+=RESULTAT
                NBRHRS+=1
            Endif

        When "NBRHRSDAY"  :
            #61557 : (avec décimale)
            #If NBRHRSDAY<=100  & RESULTAT<>0
                # HRSDAY(NBRHRSDAY)+=RESULTAT
                # NBRHRSDAY+=1
            #Endif
            If NBRHRSDAY<=100  & RESULDEC<>0
                HRSDAY(NBRHRSDAY)+=RESULDEC
                NBRHRSDAY+=1
            Endif
            #

        #Base taxe apprentissage
        When "BASAPP" : BASTAXAPP+=RESULTAT

        #Total base formation pro continue (CDD)
        When "BASFOR1" : BASTAXFOR(0)+=RESULTAT

        #Total base formation pro continue
        When "BASFOR2" : BASTAXFOR(1)+=RESULTAT

        #Nouveauté 2008... (V08R08)
        When "YEAWRK"
            If RESULTAT : DERANN(K-1)=RESULTAT : Else : DERANN(K-1)=99 : Endif
        When "TRMWRK"
            DERTRM(K-1)=RESULTAT : #Durée trimestrielle
        When "MTHWRK"
            DERMTH(K-1)=RESULTAT : #Durée mensuelle

        #Nouveautés 2009...(V08R09)
        #S45
        When "AMTPRV1"
            PRVAMT(0)+=RESULDEC
        When "AMTPRV2"
            PRVAMT(1)+=RESULDEC
        When "AMTPRV3"
            PRVAMT(2)+=RESULDEC
        When "AMTPRV4"
            PRVAMT(3)+=RESULDEC
        When "AMTPRV5"
            PRVAMT(4)+=RESULDEC
        When "AMTPRV6"
            PRVAMT(5)+=RESULDEC
        When "AMTPRV7"
            PRVAMT(6)+=RESULDEC
        When "AMTPRV8"
            PRVAMT(7)+=RESULDEC
        When "AMTPRV9"
            PRVAMT(8)+=RESULDEC

        #V08R10
        #Contribution apprentissage Supp
        When "AMTAPPSUP"
            AMTAPPSUP+=RESULTAT

        # N4DS - Avantages en nature
        When "AVNNATD" :
            If [L]NBRAVNNATD<=100 & RESULTAT<>0
                [L]TAVNNATD([L]NBRAVNNATD)=RESULTAT
                [L]NBRAVNNATD+=1
            Endif

        When "AMTAVNNATD" :
            If NBRAMTAVNNATD<=100 & RESULTAT<>0
                [L]TAMTAVNNATD([L]NBRAMTAVNNATD)+=RESULTAT
                [L]NBRAMTAVNNATD+=1
            Endif

        # N4DS - Frais professionnels
        When "EXSPFLD" :
            If [L]NBREXSPFLD<=100 & RESULTAT<>0
                [L]TEXSPFLD([L]NBREXSPFLD)=RESULTAT
                [L]NBREXSPFLD+=1
            Endif

        When "AMTEXSPFLD" :
            If [L]NBRAMTEXSPFLD<=100 & RESULTAT<>0
                [L]TAMTEXSPFLD([L]NBRAMTEXSPFLD)+=RESULTAT
                [L]NBRAMTEXSPFLD+=1
            Endif

        When "DNABRTASS" :
            BRTASS+=RESULTAT
            #V08R10
            [F:DAE]DNABRTASS+=RESULDEC

        #DNA
        When "DNANBRTIM" : NBRTIM+=RESULTAT

        When "DNACODTPS" : CODTPS=RESULTAT :#code unique

        When "DNANBRTPS" : NBRTPS+=RESULTAT

        When "DNACODPRM" :
            If NBRPRM<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10968,1))
                CODPRM(NBRPRM)=RESULTAT
                NBRPRM+=1
            Endif

        When "DNAAMTPRM" :
            If NBRPRM2<=100 & RESULTAT<>0
                AMTPRM(NBRPRM2)+=RESULTAT
                NBRPRM2+=1
            Endif

        When "DNAINDMTH" :
            If NBRMTH<2 & (RESULTAT=5 | RESULTAT=6 | RESULTAT=15)
                INDMTH(NBRMTH)=RESULTAT
                NBRMTH+=1
            Endif

        When "DNAAMTMTH" :
            If NBRMTH2<2 & RESULTAT<>0
                AMTMTH(NBRMTH2)+=RESULTAT
                NBRMTH2+=1
            Endif

        When "DNACODIND" :
            If NBRINDDNA<len(mess(0,10969,1)) & RESULTAT<>0 & RESULTAT<=len(mess(0,10969,1))
                CODINDDNA(NBRINDDNA)=RESULTAT
                NBRINDDNA+=1
            Endif

        When "DNAAMTIND" :
            If NBRINDDNA2<len(mess(0,10969,1)) & RESULTAT<>0
                AMTINDDNA(NBRINDDNA2)+=RESULTAT
                NBRINDDNA2+=1
            Endif

        When "DNANBRCNG" : NBRCNG+=RESULTAT

        When "DNACODRAP" :
            If NBRCODRAP<=100 & RESULTAT<>0 & RESULTAT<=len(mess(0,10976,1))
                CODRAP(NBRCODRAP)=RESULTAT
                NBRCODRAP+=1
            Endif

        When "DNAAMTRAP" :
            If NBRCODRAP2<=100 & RESULTAT<>0
                AMTRAP(NBRCODRAP2)+=RESULTAT
                NBRCODRAP2+=1
            Endif

        When Default
            Onerrgo ERREUR
            WRESULT=evalue([F:TD1]FLD)+RESULTAT
            Assign [F:TD1]FLD With WRESULT
            Onerrgo
 Endcase
Endif

Return

#########################################
$ERREUR
Call ECR_TRACE([F:TD1]FLD-mess(93,100,1)-num$(errn)-errmes$(errn),0) From GESECRAN
Resume

######################################
$RECUP_MONTANT
MONTANT=0
Case [F:TD1]AMTTYP
 When 1 :
  MONTANT=[F:HSP]BAS
 When 2 :#-Base
  MONTANT=([F:HSP]BAS*-1)
 When 3 :#+Montant
  MONTANT=[F:HSP]AMT
 When 4 :#-Montant
  MONTANT=([F:HSP]AMT*-1)
 When 5 :#+Plafond
  MONTANT=([F:HSP]RAT)
 When 6 :#-Plafond
  MONTANT=([F:HSP]RAT*-1)
 When 7 :#+Tranche
  MONTANT=([F:HSP]AMT)
 When 8 :#-Tranche
  MONTANT=([F:HSP]AMT*-1)
Endcase
Return

######################################
$RECUP_CUMMTT
##44976+51524 : Pour prendre en compte les variables de reprise + N paies sur même mois...
Filter [VEPC] Where EMP=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM &  PYRDAT<[F:VEP]PYRDAT
Read[F:VEPC]VEP0 Last
Filter [VEPC]
# Si 1ière paie et cumul mensuel -> AMT
###52050 : pb quand fstat=4 !!!
###If fstat=5 & [F:CUM]CUMPER=1
If fstat & [F:CUM]CUMPER=1
 MONTANT=[F:HSP]AMT
Else
 MONTANT=[F:HSP]AMT-[F:HSP]BAS
Endif
If [F:TD1]AMTTYP=4 : MONTANT=MONTANT*-1 : Endif
Return

######################################
$RECUP_VARIABLE
MONTANT=0
#Lecture de la valeur de la variable de la paye courante au niveau salarié
Read [VLA]VLA0=4;"";"";"";[F:VEP]EMP;[F:VEP]PYRDAT;[F:TD1]COD;[F:VEP]BUL
If fstat=0
 MONTANT=[F:VLA]VARVAL
Else
 #Lecture de la valeur de la variable de la paye courante au niveau site
 Read [VLA]VLA0=3;"";"";[F:VEP]FCY;"";[F:VEP]PYRDAT;[F:TD1]COD;[F:VEP]BUL
 If fstat=0
  MONTANT=[F:VLA]VARVAL
 Else
  #Lecture de la valeur de la variable de la paye courante au niveau société
  Read [CFC]FCY0=[F:VEP]FCY
  If fstat=0
   Read [VLA]VLA0=2;"";[F:CFC]LEGCPY;"";"";[F:VEP]PYRDAT;[F:TD1]COD;[F:VEP]BUL
   If fstat=0
    MONTANT=[F:VLA]VARVAL
   Else
    #Lecture de la valeur de la variable de la paye courante au niveau dossier
    Read [VLA]VLA0=1;GCURLEG;"";"";"";[F:VEP]PYRDAT;[F:TD1]COD;[F:VEP]BUL
    If fstat=0
     MONTANT=[F:VLA]VARVAL
    Endif
   Endif
  Endif
 Endif
Endif
If MONTANT<>0
 If [F:TD1]AMTTYP=4 :#-Montant
  MONTANT=MONTANT*(-1)
 Endif
 ##79968 : non on ne prends plus la partie entiere en N4DS
 #On prend la partie entière
 #MONTANT=fix(MONTANT)
Endif
Return


#*************************************************************************************
#*************************REGIME COMPLEMENTAIRE (S40.G01.01)**************************
#*************************BASES BRUTES SPECIFIQUES (S40.G01.02)***********************
#*************************BASES PLAF. SPECIFIQUES (S40.G01.03)***********************
#*************************SOMMES ISOLEES (S40.G01.04)***********************
#*************************BASES EXO. URSSAF (S40.G01.06)***********************
#*************************************************************************************
$AFFECTE_DAS
Local Integer NBLOOPS
Delete [F:DAS] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & FLGDNA=VDNA

#Raz [F:DAS]

[F:DAS] = [F:DAE]

# If VDNA=1 => N4DS global

If VNATFIL<>"04"
    # Régimes spécifiques
    # Si Cadre on fait 2 tours ARRCO+AGIRC sinon on ne fait qu'1 tour ARRCO
    If [F:HRCTR]STAEMP>1  : NBLOOPS=2 : Else : NBLOOPS=1 : Endif
    # Indices de travail pour l'ARRCO
    INDIC=GINDARR : SAVORG=""
Else
    INDIC=GINDBTP : SAVORG="" : NBLOOPS=1
Endif

#79803
X=0

For J=0 To NBLOOPS-1
 #Indices de travail pour l'AGIRC
 If J=1 : INDIC=GINDAGI : SAVORG=ORGCOURANT : Endif
 ORGCOURANT=""
 Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,"",ORGCOURANT,INDIC-1) From SUBORG
 #39444 : Caisse ARRCO=Caisse AGIRC -> n'extraire qu'une seule caisse...
 If ORGCOURANT<>"" & ORGCOURANT<>SAVORG
  Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
  # N4DS : Le tableau ne stocke plus que les AGIRC/ARRCO
  # If fstat=0 & [F:ORG]TYPIRC>2
  If fstat=0 & find([F:ORG]TYPIRC, 4, 5, 6, 7)
   If [F:ORG]NUMDCS<>""
    [F:DAS]RGMCOD(J)=[F:ORG]NUMDCS :#Code Régime/Institution (Arrco/Agirc)
    Call ORGAFFIL (ORGCOURANT,[F:FCY]FCY,[F:ID]REFNUM,"",VNUMAFF,VNUMCTR) From SUBORA
    [F:DAS]RGMNUM(J)=VNUMCTR :#No contrat (Arrco/Agirc)
    [F:DAS]NBRRGM+=1
   Else
    Filter [F:ADI] Where NUMTAB=10340 & A1="90000"
    Read[F:ADI]CODE First
    Filter [F:ADI]
    If !fstat
     [F:DAS]RGMCOD(J)=[F:ADI]CODE            : #"NON Pas de régime complèmentaire" en std
     [F:DAS]RGMNUM(J)=""
     [F:DAS]NBRRGM+=1
    Endif
   Endif
  Endif
 Endif
 #79803
 Read [ADI]CODE=10340;[F:DAS]RGMCOD(J)
 If left$([F:ADI]A1,1)="A" | left$([F:ADI]A1,1)="C" | left$([F:ADI]A1,1)="G"
  X+=1
 Endif
Next

#79803
If !X : Raz [F:DAE]STACAT2 : Endif

#Bases brutes spécifiques (max 30)
X=0
For J=0 To NBRCODBBS-1
    KK = find (CODBBS(J),[F:DAS]SPEBASCOD(0..29))
    If KK=0  &  X<30
        [F:DAS]SPEBASCOD (X)= CODBBS(J)
        [F:DAS]SPEBASAMT (X)= arr(AMTBBS(J),0.01)
        [F:DAS]SPEBASPLF (X)= arr(PLFBBS(J), 0.01)
        X+=1
    Else
        [F:DAS]SPEBASAMT (KK-1)+=arr(AMTBBS(J),0.01)
        [F:DAS]SPEBASPLF (KK-1)= arr(PLFBBS(J), 0.01)
    Endif
Next
[F:DAS]NBRSPEBAS=X

#Bases plafonnées spécifiques (max J=23)
X=0
For J=0 To NBRCODBPS-1
    KK = find (CODBPS(J),[F:DAS]SPECLGCOD(0..22))
    If KK=0  &  X<23
        [F:DAS]SPECLGCOD (X)= CODBPS(J)
        [F:DAS]SPECLGAMT (X)= arr(AMTBPS(J),0.01)
        [L]X+=1
    Else
        [F:DAS]SPECLGAMT (KK-1)+=arr(AMTBPS(J),0.01)
    Endif
Next
[F:DAS]NBRSPECLG=X

# Bases brutes exonérées et plafonnées(max J=33)

[L]X=0
For [L]J = 0 To [L]NBRCODEXO - 1
    [L]KK = find([L]CODEXO([L]J),[F:DAS]SPEEXOCOD(0..32))
    If [L]KK = 0  &  [L]X < 33
        [F:DAS]SPEEXOCOD([L]X) = [L]CODEXO([L]J)
        [F:DAS]SPEEXOBAS([L]X) = arr([L]BRUTEXO([L]J), 0.01)
        [F:DAS]SPEEXOCLG([L]X) = arr([L]PLAFEXO([L]J), 0.01)
        # N4DS - Montant exo
        [F:DAS]SPEEXOAMT([L]X) = arr([L]MONTEXO([L]J), 0.01)
        [L]X += 1
    Else
        [F:DAS]SPEEXOBAS(KK-1) += arr([L]BRUTEXO([L]J), 0.01)
        [F:DAS]SPEEXOCLG(KK-1) += arr([L]PLAFEXO([L]J), 0.01)
        # N4DS - Montant exo
        [F:DAS]SPEEXOAMT(KK-1) += arr([L]MONTEXO([L]J), 0.01)
    Endif
Next
[F:DAS]NBRSPEEXO = [L]X

# Ursaff / Bases brutes et plafonnées

[L]X = 0
For [L]J = 0 To [L]NBRURSBBECOD - 1
    [L]KK = find([L]TURSBBECOD([L]J), [F:DAS]URSBBECOD(0..4))
    If [L]KK = 0 & [L]X < 5
        [F:DAS]URSBBECOD([L]X) = [L]TURSBBECOD([L]J)
        [F:DAS]URSBBEAMT([L]X) = arr([L]TURSBBEAMT([L]J), 0.01)
        [L]X += 1
    Else
        [F:DAS]URSBBEAMT(KK-1) += arr([L]TURSBBEAMT([L]J), 0.01)
    Endif
    [F:DAS]NBRURSBBE = [L]X
Next

[L]X = 0
For [L]J = 0 To [L]NBRURSBBPCOD - 1
    [L]KK = find([L]TURSBBPCOD([L]J), [F:DAS]URSBBPCOD(0..4))
    If [L]KK = 0 & [L]X < 5
        [F:DAS]URSBBPCOD([L]X) = [L]TURSBBPCOD([L]J)
        [F:DAS]URSBBPAMT([L]X) = arr([L]TURSBBPAMT([L]J), 0.01)
        [L]X += 1
    Else
        [F:DAS]URSBBPAMT(KK-1) += arr([L]TURSBBPAMT([L]J), 0.01)
    Endif
    [F:DAS]NBRURSBBP = [L]X
Next

# Endif

# *****Pour la DADS-U & la DNA ****

#Sommes isolées brutes et plafonnées (max 5)

X=0
For J=0 To NBRCODISO-1
    KK = find (CODISO(J),[F:DAS]ALOAMTCOD(0..4))
    If KK=0  &  X<5
        [F:DAS]ALOAMTYEA (X)=[M:DIA]YEADDS
        [F:DAS]ALOAMTCOD (X)= CODISO (J)
        [F:DAS]ALOAMTBAS (X)= arr(BASEISO(J),0.01)
        [F:DAS]ALOAMTCLG (X)= arr(PLAFISO(J),0.01)
        # N4DS - Montant somme isolée
        [F:DAS]ALOAMTAMT (X)= arr(MONTISO(J),0.01)
        X+=1
    Else
        [F:DAS]ALOAMTBAS (KK-1)+= arr(BASEISO(J),0.01)
        [F:DAS]ALOAMTCLG (KK-1)+= arr(PLAFISO(J),0.01)
        [F:DAS]ALOAMTAMT (KK-1)+= arr(MONTISO(J),0.01)
    Endif
Next
[F:DAS]NBRALO=X

Write [DAS]
If fstat<>0
 GOK = 0 : Call FSTA("DAS") From GLOCK
Endif
If GOK<1
 Gosub AB_TR : Return
Endif
Return

#TEPA
############################################
$AFFECTE_DAM
Delete [F:DAM] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE
X=0

For J=0 To NBRCODHRS-1
 Filter [F:DAM] Where YEAEMPDDS=[F:DAE]YEAEMPDDS & EMPDDS=[F:DAE]EMPDDS
&              & ETRDAT=[F:DAE]ETRDAT & CTRNUM=[F:DAE]CTRNUM & TYPDAE=[F:DAE]TYPDAE & CODBRTHRS=CODHRS(J)
 Read [F:DAM]DAM0 First
 Filter [F:DAM]
 If fstat
  X+=1
#  Raz [F:DAM]
  [F:DAM]=[F:DAE]
  [F:DAM]CODBRTHRS=CODHRS(J)
  [F:DAM]AMTBRTHRS=arr(AMTHRS(J),0.01)
  #61557
  #[F:DAM]NBRHRSDAY=arr(HRSDAY(J),0.01)
  [F:DAM]NBRHRSDAY=HRSDAY(J)
  [F:DAM]NUMLIG=X
  Write [F:DAM]
  If fstat<>0
   GOK = 0 : Call FSTA("DAM") From GLOCK
  Endif
 Else
  [F:DAM]AMTBRTHRS+=arr(AMTHRS(J),0.01)
  #61557
  #[F:DAM]NBRHRSDAY+=arr(HRSDAY(J),0.01)
  [F:DAM]NBRHRSDAY+=HRSDAY(J)
  Rewrite [F:DAM]
  If fstat<>0
   GOK = 0 : Call FSTA("DAM") From GLOCK
  Endif
 Endif
Next
Return

