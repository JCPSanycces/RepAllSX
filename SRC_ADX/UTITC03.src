#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTITC03   Moulinette d'entretien des listes de gauche des    Module TC #
#           objets                                                       #
##########################################################################
# FGR 09/07/2009 : X3SUIVI56335
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC03(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC03(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC03(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTITC03: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =DOSSIER + ".AOBJET"  [AOB] : Endif
  Raz COMPTEUR
  #
  For WOBJET="BCG", "BOD", "BPC", "BCG", "BOD", "BPC", "BPS", "BSG", "CAB", "CAD", "CFG", "CFM", "CGD",
&            "CO1", "COV", "CQU", "CQV", "CQW", "CSE", "CSH", "CTC", "CTN", "DEB", "DIH", "FID", "FPT", "HSH",
&            "ITF", "ITM", "ITS", "MFG", "MST", "MWC", "MWI", "MWS", "OPP", "PR2", "QST", "ROU", "SBX", "SCP",
&            "SD1", "SES", "SLE", "SND", "SNE", "SNX", "SSP", "ST1", "ST2", "STE", "STO", "STX", "TBO", "TCN",
&            "TCT", "TGL", "TGP", "TGT", "TLO", "TRU", "TSA", "TUV", "TWC", "TWD", "UGD", "PIH", "PJA", "SD3"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
        If B_OK <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
      If B_OK <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
      #
      COMPTEUR += 1
    Endif
  Next WOBJET
  #
  Close Local File [AOB]
  Call ECR_TRACE("UTITC03 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#  Read [ADS]DOSSIER=APPLI
#  If fstat THEN
#    Raz [F:ADS]
#  Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
# End MAE 108760
  Call MAJ_UTITC03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  Call MAJ_UTITC03(APPLI)
End

