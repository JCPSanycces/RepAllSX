#<AdxTL>@(#)3.0.0.0 $Revision$
# general comments :
#
#
# properties :
# CURSTAPER : attention, c'est 1 peigne contenant le statut de chaque période de l'exercice courant
# NEXSTAPER : attention, c'est 1 peigne contenant le statut de chaque période de l'exercice suivant
# CURTYPPST : attention, c'est 1 peigne contenant le type de comptabilisation de chaque période de l'exercice courant
# NEXTYPPST : attention, c'est 1 peigne contenant le type de comptabilisation de chaque période de l'exercice suivant
#
# PLN       : PLNS du contexte attention, c'est 1 peigne indiquant pour chaque plan si il est géré ou non (1 ou 0)
#
# IASCNX    : indique si le plan IAS est géré (contient le n° du contexte ou 0 sinon) (§§ INFO du niveau CPY §§)
# CNXOFPLN  : contexte pour chaque plan de la société
#
# Le contexte d'un plan est obtenu ainsi : (0 = plan non géré.  -1 = err n° de plan)
# LCNX = func CNX_CSTD.GETCNXOFPLN(PEVENT.PLAN, fmet GACTX.ACACHE.CNX.AGETVALCHAR(PEVENT.CPY, 1, "CNXOFPLN"))


###################
# DATA CLASS CNX
###################
$ACTION
  Case CURPRO
    When ""         : Gosub EVENTS    : # If CURPRO is empty, we are on class methods
  Endcase

Return

###############
# METHOD
###############
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_BEFORE" : Gosub AREAD_BEFORE     : # Get method attached to AREAD_BEFORE
        # When "AREAD"        : Gosub AREAD            : # Get method attached to AREAD
        When "AREAD_AFTER"  : Gosub AREAD_AFTER      : # Get method attached to AREAD_AFTER
        When Default
      Endcase
    When Default
  Endcase
Return

$METHODS
Return

$OPERATIONS
Return

###################################################################
#            Methods on class  -  CNX
###################################################################

$AREAD_BEFORE
Return

#$AREAD
# Si lecture n'est pas cochée au niveau mapping de la classe on passera par là
# La lecture du contexte sera prise en charge par le développeur
# avec les paramètres CPY & CNX à disposition
#Return

$AREAD_AFTER
  Local Char WSTAPER(25), WTYPPST(25)
  Local Shortint I, WPLN(20)
  #-1 -----------
  If ( this.CPY <> AVOID.ACHAR and this.CNX <> AVOID.AINT ) Then

    Local File FISCYEAR     [FIS]
    Filter [FIS] Where CPY=this.CPY & CNX=this.CNX & STAFIY=[V]CST_TECOURA
    Read [FIS] First
    Filter [FIS]
    #-2 -----------
    If (not fstat) Then
      # Current fiscal year start date
      this.CURFIYSTR = [F:FIS]DATSTRFIY
      # Current fiscal year end date
      this.CURFIYEND = [F:FIS]DATENDFIY
      # Current period start date of current fiscal year
      this.CURPERSTR = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      # Current period end date of current fiscal year
      this.CURPEREND = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
      # number of periods of current fiscal year
      this.CURNBRPER = [F:FIS]NBRPER
      # load STAPER and TYPPST of current fiscal year
      Gosub LOADINFOS_PER
      this.CURSTAPER = WSTAPER
      this.CURTYPPST = WTYPPST
    Endif
    #-2 -----------

    Filter [FIS] Where CPY=this.CPY & CNX=this.CNX & STAFIY=[V]CST_TESUIV
    Read [FIS] First
    Filter [FIS]
    #-2 -----------
    If (not fstat) Then
      # Next fiscal year start date
      this.NEXFIYSTR = [F:FIS]DATSTRFIY
      # Next fiscal year end date
      this.NEXFIYEND = [F:FIS]DATENDFIY
      # number of periods of next fiscal year
      this.NEXNBRPER = [F:FIS]NBRPER
      # load STAPER and TYPPST of next fiscal year
      Gosub LOADINFOS_PER
      this.NEXSTAPER = WSTAPER
      this.NEXTYPPST = WTYPPST
    Endif
    #-2 -----------

    # Account plans of the context
    this.PLN = AVOID.ACHAR
    Raz WPLN
    this.IASCNX = AVOID.AINT

    For I = 1 To this.NBPLC
        If [F:CNX]PLNCAA(I - 1) > 0
            WPLN([F:CNX]PLNCAA(I - 1)) = 1
            If [F:CNX]PLNCAA(I - 1) = [V]CST_PLNIAS
                # Context of IFRS account plan
                this.IASCNX = [F:CNX]CNX
            Endif
        Endif
    Next I
    For I = 1 To [V]CST_PLNMAX - 1
        If WPLN(I) = 1
            this.PLN += "1"
        Else
            this.PLN += "0"
        Endif
    Next I

  Endif
  #-1 -----------

  # Context of IFRS account plan (A voir si on garde ainsi : dépend de la société)
#  If this.IASCNX = AVOID.AINT
      this.IASCNX = func FINDCNX(this.CPY, this.CNXOFPLN)
#  Endif

  Return

###################################################################
#             CNX - Class properties
###################################################################

$PROPERTIES
Return

#** load STAPER and TYPPST of a fiscal year
#* [F:FIS] is readen
#*
$LOADINFOS_PER

    WSTAPER = AVOID.ACHAR
    WTYPPST = AVOID.ACHAR

    For I = 1 To [F:FIS]NBRPER
        WSTAPER += num$([F:FIS]STAPER(I - 1))
        WTYPPST += num$([F:FIS]TYPPST(I - 1))
    Next I
Return

#** return the IFRS account's context
#*  and load all the account's context
#*
#*
#* @param PCPY
#* @param RCNXOFPLN   all the account's context
#* to get a account's context, use the function GETCNXOFPLN :
#* LCNX = func CNX_CSTD.GETCNXOFPLN(PEVENT.PLAN, fmet GACTX.ACACHE.CNX.AGETVALCHAR(PEVENT.CPY, 1, "CNXOFPLN"))
#*!
Funprog FINDCNX(PCPY, RCNXOFPLN)
Value Char PCPY()
Variable Char RCNXOFPLN()

Local Shortint I, WCNX(20), IASCNX

   Local File CONTEXT [CNX00]

  IASCNX = AVOID.AINT
  RCNXOFPLN = AVOID.ACHAR

  For [CNX00] Where CPY = PCPY
#    If find([V]CST_PLNIAS, [F:CNX00]PLNCAA(0..14)) > 0
#      I = [F:CNX00]CNX
#      Break
#    Endif

      For I = 1 To [F:CNX00]NBPLC
          If [F:CNX]PLNCAA(I - 1) > 0
              WCNX([F:CNX]PLNCAA(I - 1)) = [F:CNX00]CNX
              If [F:CNX]PLNCAA(I - 1) = [V]CST_PLNIAS
                  # Context of IFRS account plan
                  IASCNX = [F:CNX]CNX
              Endif
          Endif
      Next I
  Next

  For I = 1 To [V]CST_PLNMAX - 1
      If WCNX(I) > 0
          If WCNX(I) < 10
              RCNXOFPLN += num$(WCNX(I))      # CNX de 1 à 9
          Else
              RCNXOFPLN += chr$(WCNX(I) + 55) # CNX = 10 -> A, 11 -> B...
          Endif
      Else
          RCNXOFPLN += "0"
      Endif
  Next I

End IASCNX

Funprog GETCNXOFPLN(PPLN, PCNXOFPLN)
Value Shortint PPLN
Value Char PCNXOFPLN()

Local Shortint I

  If PPLN < 1 or PPLN >= [V]CST_PLNMAX
      End -1
  Endif

  I = ascii(mid$(PCNXOFPLN, PPLN, 1))

  If I < 65
      End (I - 48)    # CNX de 1 à 9
  Endif
End (I - 55)          # CNX de 10 à ...

