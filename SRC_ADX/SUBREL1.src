#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RELAUTO","DRELAUTO",3,"") From GTRAITE
End

#################################################################
# Etiquette masque RELAUTO
#################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"
  Case LISTE
   When "SOICOD" : Gosub S_SOICOD
  Endcase
Endcase
Return

$S_SOICOD
Local Integer NB
Local Char    COD(GLONTAM)
NB = nbrecord([F:TAM])
If NB<1 : OK = 0 : Return : Endif

If dim([M:DIA]ALLCPY)>0 & dim([M:DIA]CPY)>0 & [M:DIA]ALLCPY<>2 & [M:DIA]CPY<>""

 If clalev([F:TAM2])=0  : Local File TABPAM     [TAM2]  : Endif
 If clalev([F:CPY])=0   : Local File COMPANY    [CPY]   : Endif

 ## Tableau des codes relevé
 Call LEC_CPY([M:DIA]CPY) From CPTLEC
 GCURLEG  = [F:CPY]LEG

 NBTEX = 0
 Filter [TAM2] Where LEG=GCURLEG | LEG="" Order By Key CLE=PAM Asc ; LEG Desc
 For [TAM2]CLE(1)
  [L]COD = [F:TAM2]SOI
  If [L]COD<>"" & !find([L]COD,TEX(1..NBTEX))
   NBTEX += 1
   TEX(NBTEX)   = [L]COD
   TEXTE(NBTEX) = [L]COD
  Endif
 Next
 Filter [TAM2]
Else

 NBTEX = 0
 For [F:TAM]
  [L]COD = [F:TAM]SOI
  If [L]COD<>"" & !find([L]COD,TEX(1..NBTEX))
   NBTEX += 1
   TEX(NBTEX)   = [L]COD
   TEXTE(NBTEX) = [L]COD
  Endif
 Next
Endif
Return

################################################################# Tiers
Subprog C_BPR(VALEUR)
Variable Char     VALEUR
If VALEUR<>""
 Case [M]TYPBPR
  When 1  :# Client
   Call LECTURE("BPC",VALEUR,"") From CONTOBJ
   If fstat
    mkstat= 2 : GMESSAGE=mess(67,117,1)  :# Ce n'est pas un client
   Endif 
  When 2  :# Fournisseur
   Call LECTURE("BPS",VALEUR,"") From CONTOBJ
   If fstat
    mkstat=2 : GMESSAGE=mess(68,117,1)  :# Ce n'est pas un fournisseur
   Endif
 Endcase
Endif
End

Subprog AS_SOIPER(VALEUR)
Variable Integer  VALEUR
If [M]TYPBPR=1
 If [M]BPR<>""
  Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
  If !fstat
   mkstat=2 : VALEUR=[F:BPC]SOIPER
  Endif
 Elsif VALEUR<2 : VALEUR=2
 Endif
Else 
 mkstat=1
Endif 
End 

Subprog C_SOIPER(VALEUR)
Variable Integer  VALEUR
If VALEUR=1 : mkstat=2 : End : Endif
End

################################################################# Société
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Local Integer STAT
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Affzo ALLSAC : Effzo SAC
  Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
 Endif 
Else
 Actzo CPY,ALLFCY,ALLSAC
Endif
End

Subprog AP_ALLCPY(VALEUR)
Variable Integer VALEUR
## Si le traitement est lançé pour toutes les sociétés, le montant relevé mini est à exprimer 
##   - en devise référentiel général principal si ttes les sociétés sont associées à la même devise pour le
##     référentiel général principal
##   - sinon en devise GCURSHR
Call SETCURFLD([M]CURRELMT) From CPTDIV
Affzo CURRELMT
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat=1 : Endif
If VALEUR="" : VALEUR=GDEFSOC : Endif
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR
Call LECMAINPLAN(1,VALEUR,[M]COA) From CPTDIV
End

Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
## Si le traitement est lançé pour une société, le montant relevé mini est à exprimer en devise de référentiel général principal
Call SETCUR(1,VALEUR,[M]CURRELMT) From CPTDIV
Affzo CURRELMT
End


################################################################# Site
Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If [M]ALLCPY=2
 [M]CURRELMT=GSYSCUR
 Affzo CURRELMT
 VALEUR = 2 : mkstat = 2 : End
Else
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 [M]CURRELMT=[F:CPY]ACCCUR
 Affzo CURRELMT
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 | [M]ALLFCY=2 : mkstat=1 : Endif
If VALEUR="" : VALEUR=GFCYDEF : Endif
End

Subprog C_FCY(VALEUR)
Variable Char     VALEUR
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If [F:FCY]LEGCPY<>[M]CPY
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
 mkstat=2
Endif
End

################################################################# Collectif
Subprog AS_ALLSAC(VALEUR)
Variable Integer VALEUR
Local Integer STAT
If [M]ALLCPY = 2
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
 Endif 
Endif
End

Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPSAC,SAC : Grizo GRPSAC,SAC
Else
 Actzo GRPSAC
 If [M]GRPSAC<>"" : Grizo SAC : Else : Actzo SAC : Endif
Endif
End

Subprog AS_GRPSAC(VALEUR)
Variable Char     VALEUR
If [M]ALLSAC=2 : mkstat=1 : End : Endif
End

Subprog C_GRPSAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo SAC : Grizo SAC
Else
 Actzo SAC
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char     VALEUR
If [M]ALLSAC = 2 | [M]GRPSAC<>""
 mkstat=1 : End
Endif
End

################################################################# Devise
Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPCUR,CUR : Grizo GRPCUR,CUR
Else
 Actzo GRPCUR
 If [M]GRPCUR<>"" : Grizo CUR : Else : Actzo CUR : Endif
Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char     VALEUR
If [M]ALLCUR=2 : mkstat=1 : End : Endif
End

Subprog C_GRPCUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Effzo CUR : Grizo CUR
Else
 Actzo CUR
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
If [M]ALLCUR=2 | [M]GRPCUR<>""
 mkstat=1 : End
Endif
End

################################################################# Codes relevés
Subprog C_ALLSOI(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SOICOD : Grizo SOICOD
Else
 Actzo SOICOD
Endif
End

Subprog AS_SOICOD(VALEUR)
Variable Char     VALEUR
If [M]ALLSOI=2 : mkstat=1 : End : Endif
End

Subprog C_SOICOD(VALEUR)
Variable Char     VALEUR
mkstat=2
#MAE, exi 74937
#For [F:ADI]CODE Where NUMTAB=3
# If VALEUR=[F:ADI]A1
For [F:TAM]
 If VALEUR=[F:TAM]SOI
  mkstat=0 : Break
 Endif
Next
If mkstat
 GMESSAGE=mess(73,117,1)  :# Code relevé inexistant
Endif
End

################################################################# Factures
Subprog C_DATFAKF(VALEUR)
Variable Date     VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]DATFAKD
 mkstat=1 : End
Endif
End

################################################################# Echéance du relevé
Subprog AS_DATECHE(VALEUR)
Variable Date     VALEUR
If [M]RELDATECH=2 : mkstat=1 : End : Endif
End

################################################################# MAJ relevé
Subprog AS_MAJON(VALEUR)
Variable Integer  VALEUR
If [M]RELDATECH=2
 mkstat=1 : End
Endif
End

################################################################# Nb mini échéances/relevé
Subprog C_RELNBECH(VALEUR)
Variable Decimal VALEUR
If VALEUR<1
 GMESSAGE = mess(6,199,1)
 mkstat = 2 : End
Endif
End

##############################################################################################
##############################################################################################
##############################################################################################
Subprog AV_INI(VALEUR)
Variable Char VALEUR()
Local Integer STAT
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 Call CNTCPYCOA(0,[M]COA,STAT) From CPTCNT
 If STAT
  [M]ALLSAC=2 : Affzo ALLSAC : Effzo SAC
  Grizo ALLSAC, SAC
 Else
  Actzo ALLSAC
 Endif 
Else
 Actzo CPY, ALLFCY, ALLSAC
 If [M]CPY<>""
  Call LECMAINPLAN(1,[M]CPY,[M]COA) From CPTDIV
 Endif
Endif
If [M]ALLFCY=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
If [M]ALLSAC=2
 Effzo GRPSAC,SAC : Grizo GRPSAC,SAC
Else
 Actzo GRPSAC
 If [M]GRPSAC<>"" : Grizo SAC : Else : Actzo SAC : Endif
Endif
If [M]ALLCUR=2
 Effzo GRPCUR,CUR : Grizo GRPCUR,CUR
Else
 Actzo GRPCUR
 If [M]GRPCUR<>"" : Grizo CUR : Else : Actzo CUR : Endif
Endif
If [M]ALLSOI=2
 Effzo SOICOD : Grizo SOICOD
Else
 Actzo SOICOD
Endif
End



