####################################################################################
# Check for Payment processing hold
# Called from TRTVENCDT
####################################################################################
$CDTSTA
Local Char PTE(GLONPTE)

  # Don't override 'prepayment not deposited'
  If CDTSTA = 4 Then
    Return
  Endif
  # Skip if payment terms don't relate to Sage Exchange
  If dim(OBJORI.PTE) > 0 & OBJORI.PTE <> "" Then
    [L]PTE = OBJORI.PTE
  Else
    [L]PTE = [F:BPC]PTE
  Endif
  If !func SEPPLIB_SYRA.SEPP_DOC([L]PTE) Then
    Return
  Endif
  # Customer hold --> prepayment
  If CDTSTA = 2 & NUMPIE <> "" Then
    Call CALACO(NUMPIE, date$, MONT) From TRTVENCDT_SYRA
    If CTX_LOKORD = 2 & MONT <> 0 Then
      CDTSTA = 4
      Return
    Endif
  Endif
  #
  CUR = ""
  OSTAUZ = 9999999999.99
  CDTSTA = 1
  If NUMPIE <> "" & !func SEPP_OK(2,NUMPIE,1) & OBJORI.ORDSTA <> 2 Then
    CDTSTA = 5
    Return
  Endif
  # If Sage Exchange document is in the process of being created, put on SE hold
  # I don't know again how to know if we are in Create/duplicate mode.
#  If NUMPIE="" & find(GREP,"C","D") & GFONCTION="GESSOH"
#    CDTSTA = 5
#    Return
#  Endif
Return

####################################################################################
Funprog SEPP_OK(VCRTYP,VCRNUM,CDTCHK)
Value Integer VCRTYP
Value Char    VCRNUM
Value Integer CDTCHK  # 1 = Credit check/pop, 0 = Re-auth

Local Decimal AUTAMT

  Local File SEAUTH [SEU]
  Local File SEPRC [SER]
  # Check for last card being rejected
  # For reauth, return true so that auto-pop occurs
  Filter [SEU] Where VCRTYP=[L]VCRTYP & VCRNUM=[L]VCRNUM
  Read [SEU]Last
  Filter [SEU]
  If fstat Then
    # No card
    Raz [F:SEU]
    End !CDTCHK | func SEPPLIB_SYRA.GET_REMAIN_AMT_NMU([L]VCRTYP, [L]VCRNUM)=0
  Elsif [F:SEU]STAFLG=4  # Last auth Rejected
    End !CDTCHK
  Endif
  # Get processing code
  Read [SER]SER0=[L]PRCCOD
  If fstat
    End 0
  Endif
  #
  # For Credits/Payments, a selected card is all that is needed
  If find([L]VCRTYP,18,41,51) & [F:SEU]STAFLG = 1 Then
    End 1
  Endif
  #
  # Post order auth
  # If verification flag set, card must be verified
  If ([F:SEU]POSTAUT = 2 & [F:SEU]STAFLG < 3) | ([F:SER]VERIF = 2 & [F:SEU]STAFLG = 2) Then
    End 1
  Endif
  #
  # Check that the AutAmt is less than the remaining order amt (sans markup)
  AUTAMT = func SEPPLIB_SYRA.GET_SEUAMT([L]VCRTYP,[L]VCRNUM,[F:SEU]STAFLG)
  If AUTAMT < func SEPPLIB_SYRA.GET_REMAIN_AMT_NMU([L]VCRTYP, [L]VCRNUM) & (CDTCHK | AUTAMT > 0) Then
    End 0
  Endif
  #
  # Check that the Auth has not expired - allow re-auth
  If date$ > [F:SEU]AUTDAT+[F:SER]AUTDAY & [F:SEU]STAFLG < 4 Then
    End CDTCHK
  Endif
End 1
