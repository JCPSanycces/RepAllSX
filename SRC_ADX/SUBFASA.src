#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque FASADV
######################################################################################



######################################################################################
# Autres  traitements liés.

#---------------------------------------------------
$LOAD_VAL_MSK_FROM_FAS
  # Alimentation par défaut des champs de l'écran FASADV en création
  If (GREP = "C" and not [M:FAS3]BREPRISE(G_NOL-1) ) Then
    # Réel
    [M:FASA]PERREFCLC  = [M:FAS3]FIYSTRDAT(G_NOL-1)

    # Initial
    [M:FASA]PERREFCLCI = [M:FAS3]FIYSTRDAT(G_NOL-1)
    [M:FASA]DPMI       = [M:FAS3]DPM      (G_NOL-1)
    [M:FASA]EXECLOCUMI = [M:FAS3]DPRCUM   (G_NOL-1)

    # Théorique
    [M:FASA]PERREFCLCT = [M:FAS3]FIYSTRDAT(G_NOL-1)
    [M:FASA]DPMT       = [M:FAS3]DPM      (G_NOL-1)
    [M:FASA]EXECLOCUMT = [M:FAS3]DPRCUM   (G_NOL-1)

  Endif
Return

#---------------------------------------------------
$COND_MSK_FIELDS
  # Conditionnement des champs de l'écran FASADV
  # Verrouillage des champs du bloc Aide fiscal si le plan n'est pas le plan fiscal ni le plan comptable.
  Actzo [M:FASA]1-99
  If ( find( [M:FAS3]DPRPLN(G_NOL-1), G301FIS, G301CPT) = 0 ) Then
    Diszo [M:FASA]LEGCUM
    Diszo [M:FASA]PERLEGCUM
    Diszo [M:FASA]LEGRVECUM
    Diszo [M:FASA]PERLEGRVE
  Endif
  If ( [M:FAS3]DPRPLN(G_NOL-1) <> G301FIS ) Then
    Diszo [M:FASA]ALWCUM
    Diszo [M:FASA]CRBCUM
    Diszo [M:FASA]DFDBLC
  Endif
  # Verrouillage des champs du bloc concession si le plan n'est pas le plan gérant la caducité ou
  # s'il ne s'agit pas d'un bien en concession ou si les concessions ne sont pas gérées par renouvellement
  If (G_ACTCCN = G_OUI) Then
    # Concessions gérées
    If ( [M:FAS1]OWNTYP <> GVML_TDCONCE or G_CCNRPR <> G_OUI or G_NOL <> find(G_CCNPLNCAD,[M:FAS3]DPRPLN) ) Then
      # Biens en concessions et Concessions transmis pa renouvellement et plan gérant la caducité
      Diszo [M:FASA]STRRNWVAL
      Diszo [M:FASA]TRFCADCUM
      Diszo [M:FASA]P_1CADCRB
      Diszo [M:FASA]P_1ACGRPR
      Diszo [M:FASA]P_1FISRPR
      Diszo [M:FASA]P_1RVERPR
      Diszo [M:FASA]E_1SUPCAD
      Diszo [M:FASA]P_1SUPCAD
    Endif
  Endif
  If (find([M:FAS3]DPM(G_NOL-1), G_DPMUO, G_DPMUR) = 0 ) Then
    Diszo [M:FASA]PERQTYCUM
  Endif
Return
