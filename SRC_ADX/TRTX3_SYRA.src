#######################################################################
#---------------------------------------------------------------------#
# Initialisation des codes comptables                                 #
#                                                                     #
# Initialisation d'un code comptable                                  #
# --> Ssi un seul code comptable existe pour le type de code donné    #
#                                                                     #
# Action associée : INITACCCOD                                        #
#---------------------------------------------------------------------#
Subprog INITACCCOD(SACCCOD, TYPCOD)
Variable Char SACCCOD()
Value Integer TYPCOD

  Local File GACCCODE [CAC]

  Local Char WACCCOD(type([F:CAC]ACCCOD)-10)

  Raz SACCCOD
  Filter [CAC] Where TYP = TYPCOD
  Read [CAC]CAC0 First
  If !fstat
    WACCCOD = [F:CAC]ACCCOD
    Read [CAC]CAC0 Last
    If !fstat and [F:CAC]ACCCOD = WACCCOD Then
      SACCCOD = WACCCOD
    Endif
  Endif
  Filter [CAC]
End
########################################################################
# UTILISE PAR LES VENTES                                               #
#                                                                      #
# VACBPR est passé en paramètre pr la prise en cpte du flag VATEXEFLG  #
########################################################################
#  Calcul de la taxe sur le prix unitaire                              #
#                                                   LD - décembre 1997 #
# En Entree PRIXBASE : Prix à la base du calcul                        #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           QTY      : Quantité                                        #
#           VACBPR   : Régime de taxe                                  #
#           CLCAMT1  : Base1 calcul taxe                               #
#           CLCAMT1  : Base2 calcul taxe                               #
# En sortie PRIXCALC : Prix calculé                                    #
#                                                                      #
########################################################################
Subprog CLCTAXEPRIV_ADAPTER(CTX,PRIXBASE,IVAT,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT1,CLCAMT2,PRIXCALC)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Decimal  PRIXBASE
Variable Instance IVAT(1..) Using OBJECT
Value    Integer  PRITYP
Value    Char     SOC
Value    Date     DAT
Value    Decimal  QTY
Value    Char     VACBPR    ()
Value    Char     VACBPR_LEG()
Value    Decimal  CLCAMT1
Value    Decimal  CLCAMT2
Variable Decimal  PRIXCALC

Local    Char     WVAT    (GLONVAT)(1..maxtab(IVAT))
Local    Char     WVAT_LEG(GLONADI)(1..maxtab(IVAT))
Local Integer     I

If IVAT = null : End : Endif

If dim(IVAT(1).VAT)<1 or dim(IVAT(1).VAT_LEG)<1 : End : Endif

#--Load the collection to dimensioned variable
For I=1 To maxtab(IVAT)
  If IVAT(I)<>null
    WVAT(I)     = IVAT(I).VAT
    WVAT_LEG(I) = IVAT(I).VAT_LEG
  Else
    WVAT(I)     = ""
    WVAT_LEG(I) = ""
  Endif
Next I

Call CLCTAXEPRIV (CTX,PRIXBASE,WVAT, WVAT_LEG,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT1,CLCAMT2,PRIXCALC)

##--Load back the result within the dimensioned variables to the collection
#For I=1 To maxtab(IVAT)
#  If IVAT(I)<>null
#    IVAT(I).VAT     = WVAT(I)
#    IVAT(I).VAT_LEG = WVAT_LEG(I)
#  Endif
#Next I

End
#----------------------------------------------------------------------------------------------------
Subprog CLCTAXEPRIV (CTX,PRIXBASE,VAT, VAT_LEG,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT1,CLCAMT2,PRIXCALC)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Decimal PRIXBASE
Value    Char    VAT    ()(0..)
Value    Char    VAT_LEG()(0..)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Decimal QTY
Value    Char    VACBPR    ()
Value    Char    VACBPR_LEG()
Value    Decimal CLCAMT1
Value    Decimal CLCAMT2
Variable Decimal PRIXCALC
#-----
Local    Libelle WTRT : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
#-----
Gosub CLC_TAXEPRI
End
#--------------------------------------------------------------------------------------------------
########################################################################
Subprog CLCTAXEPRI2_ADAPTER(CTX,PRIXBASE,IVAT,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT,PRIXCALC)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Decimal  PRIXBASE
Variable Instance IVAT(1..) Using OBJECT #(0..2) Using OBJECT # May need changed to (1..)
Value    Integer  PRITYP
Value    Char     SOC
Value    Date     DAT
Value    Decimal  QTY
Value    Char     VACBPR    ()
Value    Char     VACBPR_LEG()
Value    Decimal CLCAMT(0..)
#Value    Decimal  CLCAMT1
#Value    Decimal  CLCAMT2
Variable Decimal  PRIXCALC


#Subprog CLCTAXEPRI2(CTX,PRIXBASE,IVAT,PRITYP,SOC,DAT,QTY,CLCAMT,PRIXCALC)
#Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
#Value    Decimal PRIXBASE
#Variable Instance IVAT(1..) Using OBJECT #Value    Char    VAT()(0..2)
#Value    Integer PRITYP
#Value    Char    SOC
#Value    Date    DAT
#Value    Decimal QTY
#Value    Decimal CLCAMT(0..)
#Variable Decimal PRIXCALC

Local    Char     WVAT    (GLONVAT)(1..maxtab(IVAT))
Local    Char     WVAT_LEG(GLONADI)(1..maxtab(IVAT))
Local Integer     I

If IVAT = null : End : Endif

If dim(IVAT(1).VAT)<1 or dim(IVAT(1).VAT_LEG)<1 : End : Endif

#--Load the collection to dimensioned variable
For I=1 To maxtab(IVAT)
  If IVAT(I)<>null
    WVAT(I)     = IVAT(I).VAT
    WVAT_LEG(I) = IVAT(I).VAT_LEG
  Else
    WVAT(I)     = ""
    WVAT_LEG(I) = ""
  Endif
Next I

Call CLCTAXEPRI2 (CTX,PRIXBASE,WVAT, WVAT_LEG,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT,PRIXCALC)

##--Load back the result within the dimensioned variables to the collection
#For I=1 To maxtab(IVAT)
#  If IVAT(I)<>null
#    IVAT(I).VAT     = WVAT(I)
#    IVAT(I).VAT_LEG = WVAT_LEG(I)
#  Endif
#Next I

End
########################################################################
# CLCTAXEPRI2 : Calcul de la taxe sur le prix unitaire                 #
# -------------------------------------------------------------------- #
# Utilisé par les achats (gestion des 7 bases spéciales)               #
# VACBPR inutile (pas de prise en compte du flag VATEXEFLG)            #
########################################################################
# En Entree PRIXBASE : Prix à la base du calcul         MBT 10/02/2010 #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           QTY      : Quantité                                        #
#           CLCAMT1  : Base1 calcul taxe                               #
#           CLCAMT1  : Base2 calcul taxe                               #
# En sortie PRIXCALC : Prix calculé                                    #
########################################################################
Subprog CLCTAXEPRI2(CTX,PRIXBASE,VAT, VAT_LEG,PRITYP,SOC,DAT,QTY,VACBPR, VACBPR_LEG,CLCAMT,PRIXCALC)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Decimal PRIXBASE
Value    Char    VAT    ()(0..)
Value    Char    VAT_LEG()(0..)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Decimal QTY
Value    Char    VACBPR    ()
Value    Char    VACBPR_LEG()
Value    Decimal CLCAMT(0..)
Variable Decimal PRIXCALC
#-----
#Local    Char    VACBPR : Raz VACBPR
Local    Libelle WTRT   : WTRT=2 : # Avec 7 bases spéciales CLCAMT(0..6)
#-----
Gosub CLC_TAXEPRI
End
####################################################################################
$CLC_TAXEPRI
#--CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif
#Fq74432-Gbn-Ajout PE non documenté pour permettre aux US de court-circuiter lr calcul std des taxes au profit d'AVATAX
#Raz GPE : GPOINT="CLCTAXPRI" : Gosub ENTREE From EXEFNC : If GPE : Return : Endif   #CHECK IGNORE_LINE

Local    Decimal TXTVA, TXTAX
Local    Decimal TXTOT, TXTF1, TXTF2, TXTF(0..6)
Local    Char    TAX(GLONVAT)
Local    Integer STAT : STAT = 0
Local    Integer I
Local    Decimal WSVGPRIXBASE : WSVGPRIXBASE=PRIXBASE         : # 96182 : Pb Utilisation PE NEGPRI

# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
Local File TABVAT    [TVT]
Local File TABRATVAT [TRA]
Local File TABVACBPR [TVB]
#-----
Raz TXTOT, TXTF1, TXTF2, TXTF

For I=0 To 2
  If VAT(I) <> "" Then       # FGR 28/07/2015 : X3SUIVI108078
    Call LEC_TVT_LEG(CTX, VAT_LEG(I),VAT(I),WRET) From TRTLECLEG_SYRA
    If WRET : Raz [F:TVT] : Endif
    If !WRET
      TAX=VAT(I) : Gosub LECTAX
      If TXTAX<>0
        #----- Si taxe avec formule de calcul et no montant renseigné -----#
        If [F:TVT]VATFOR<>"" & [F:TVT]VATBAS<>1
          #----- Utilisation bases spéciales 1-7 en fonction du rang de la taxe -----#
          If WTRT=2
            TXTF(I)+=TXTAX/100
            If I=0
              TXTVA=TXTAX
            Endif
            If [F:TVT]VATCHA=2 & I<>0
              TXTF(I)+=(TXTAX/100)*(TXTVA/100)
            Endif
          #----- Utilisation bases spéciales 1-2 en fonction du paramétrage taxe -----#
          Else
            #----- Base = montant1 -----#
            If [F:TVT]VATBAS=2
              TXTF1+=TXTAX/100
              If I=0
                TXTVA=TXTAX
              Endif
              If [F:TVT]VATCHA=2 & I<>0
                TXTF1+=(TXTAX/100)*(TXTVA/100)
              Endif
            #----- Base = montant2 -----#
            Elsif [F:TVT]VATBAS=3
              TXTF2+=TXTAX/100
              If I=0
                TXTVA=TXTAX
              Endif
              If [F:TVT]VATCHA=2 & I<>0
                TXTF2+=(TXTAX/100)*(TXTVA/100)
              Endif
            Endif
          Endif
        #----- Si taxe sans formule de calcul ou no montant non renseigné -----#
        Else
          TXTOT+=TXTAX/100
          If I=0
            TXTVA=TXTAX
          Endif
          If [F:TVT]VATCHA=2 & I<>0
            TXTOT+=(TXTAX/100)*(TXTVA/100)
          Endif
        Endif
      Endif
    Endif
  Endif
Next I
#-----
TXTOT+=1

If PRITYP=1
  PRIXCALC=PRIXBASE*TXTOT
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXCALC+=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXCALC+=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXCALC+=CLCAMT2*TXTF2/QTY : Endif
  Endif
  PRIXCALC=arr(PRIXCALC,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
Else
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXBASE-=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXBASE-=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXBASE-=CLCAMT2*TXTF2/QTY : Endif
  Endif
  # 96182 : Pb Utilisation PE NEGPRI
  #PRIXCALC = max(0,PRIXBASE/TXTOT)    : # Bug 73097 : Eviter un prix négatif
  If WSVGPRIXBASE >= 0
      # Prix de base positif : Eviter un prix négatif
      PRIXCALC = max(0,PRIXBASE/TXTOT)
  Else
      # Prix de base négatif (par utilisation PE NEGPRI), c'est normal d'avoir un prix négatif
      PRIXCALC = PRIXBASE/TXTOT
  Endif
  # 96182

  PRIXCALC = arr(PRIXCALC,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
Endif
Filter [TRA]

Return
#--------------------------------------------------------------------------------------------------
$LECTAX
TXTAX=0
# Cas particulier société ??
#--CPO 71937 TRA et multi-lèg
#Filter [TRA] Where CPY=SOC & VAT=TAX & STRDAT<=DAT
Filter [TRA] Where CPY=SOC & VAT=TAX & STRDAT<=DAT & LEG= [F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
# sinon on se rabat sur le code dossier
 #Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT
 Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT & LEG= [F:TVT]LEG
 Read [TRA]TRA0 Last
 #--CPO et LD 83405 Bench GESSOH
 #If fstat>2 : STAT = 2 : Return : Endif
 If fstat>2 : STAT = 2 : Filter [F:TRA] : Return : Endif
Endif
#--/CPO

TXTAX = [F:TRA]VATRAT

If VACBPR<>""
    Local Integer WRET
    Call LEC_TVB_LEG(CTX,VACBPR_LEG,VACBPR,WRET) From TRTLECLEG_SYRA
    If WRET Raz [F:TVB] : Endif
    If [F:TVB]REGVAC<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif
Endif

Filter [TRA]
Return
#########################################################################################
# ------------------------- #
# Method for the VAT search #
# ------------------------- #
Funprog SEARCHVAT(MYPARAM, WMESSA)
Variable Instance MYPARAM  Using C_FINDVAT
Variable Char     WMESSA()

Local Integer WRET, I
Local Char    WEXPRESSION(250)
Local Char    WEXPRESSION2(250) :#--CPO 80360
Local Char    WSATRCP(GLONSAT), WSATISS(GLONSAT)

Local File TABVAC    [TVC] : # Table détermination des taxes
Local File TABVAT    [TVT] : # Table des codes taxes

# MYPARAM = FINDVAT : Classe de paramètres permettant la recherche des codes taxes. La Classe est chargée

For I = 1 To maxtab(MYPARAM.C_VAT)
   If MYPARAM.C_VAT(I)<>null
     MYPARAM.C_VAT(I).VAT     = AVOID.ACHAR
     MYPARAM.C_VAT(I).VAT_LEG = AVOID.ACHAR
   Endif
Next I

# --- Ouverture et chargement TAXLINK
Local File TAXLINK  [TLK]
# --- Transclasse [F:TLK] with MYPARAM.C_TLK(1)
If MYPARAM.C_TLK(1)<>null
  [L]WRET = fmet MYPARAM.C_TLK(1).LOAD_TO_TLK_FILE()
  If [L]WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"LOAD_TO_TLK_FILE"
    [L]WRET = fmet MYPARAM.ASETERROR('', WMESSA, WRET)
    End [L]WRET
  Endif
Endif

#----- Ajout d'un critère supplémentaire sur VACBPR et VACITM
Local Char LCRITITMBPR(255) : LCRITITMBPR="(VACITM=[F:TLK]VACITM | VACITM='') & ([F:TLK]VACBPR | VACBPR='')" #Fq75921-Gbn

[L]WRET=0
#----- Alimentation codes taxes classiques ligne (TVA, parafiscales et spéciales) -----#
If find(MYPARAM.TRAIT,1,11,12,13) | MYPARAM.TRAIT=3
  #----- TVA -----#
  If find(MYPARAM.TRAIT,1,11) | MYPARAM.TRAIT=3
    I=0
    If MYPARAM.C_VAT(I+1)<>null
      [F:TLK]VACITM=MYPARAM.C_VAT(I+1).VACITM
    Endif
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #--/CPO
      #MAE, bg75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
        #--CPO 71937 19.04.2013 Déclinaison multi-lég
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
        If WRET<=[V]CST_ASUCCESS
#        If WSTAT=0
          Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
          I+=1
          Raz [L]WRET : Raz [L]WMESSA
          Break
        Endif
        #--/
      Endif
    Next
    If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
    # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection

    [L]WRET=0
    If dim(MYPARAM.DTANUM)>0 & MYPARAM.DTANUM<>0 & MYPARAM.BPCBPS=1 & MYPARAM.C_VAT(2).VACITM<>""
      I=1
      If MYPARAM.C_VAT(I+1)<>null
        [F:TLK]VACITM=MYPARAM.C_VAT(I+1).VACITM
      Endif
      Gosub SET_LCRITITMBPR
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
      For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
        If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
        If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif
        WEXPRESSION2="1=1"
        If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif
        If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)
          #--CPO 71937 19.04.2013 Déclinaison multi-lég
          #TAXES(I)=[F:TVC]VAT : I+=1 : Break
  # A voir
  #          Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
  #          If WSTAT=0
          WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
          If WRET<=[V]CST_ASUCCESS
            Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
            I+=1
            Raz [L]WRET : Raz [L]WMESSA
            Break
          Endif
          #--/
        Endif
      Next
      If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
    Endif
    # Bug 82733
  Endif
  #----- Parafiscale / Spéciale -----#
 [L]WRET=0
 If find(MYPARAM.TRAIT,1,12) | MYPARAM.TRAIT=3
    I=1
    If MYPARAM.C_VAT(I+1)<>null
      [F:TLK]VACITM=MYPARAM.C_VAT(I+1).VACITM
    Endif
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
      #MAE, bg 75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
        #--CPO 71937 19.04.2013 Déclinaison multi-lég
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        #If WSTAT=0
        WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
        If WRET<=[V]CST_ASUCCESS
          Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
          I+=1
          Raz [L]WRET : Raz [L]WMESSA
          Break
        Endif
        #--/
      Endif
    Next
    If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
  Endif
  #----- Parafiscale / Spéciale -----#
  [L]WRET=0
  If find(MYPARAM.TRAIT,1,13) | MYPARAM.TRAIT=3
    I=2
    If MYPARAM.C_VAT(I+1)<>null
      [F:TLK]VACITM=MYPARAM.C_VAT(I+1).VACITM
    Endif
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
      #MAE, bg 75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
        #--CPO 71937 19.04.2013 Déclinaison multi-lég
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        #If WSTAT=0
        WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
        If WRET<=[V]CST_ASUCCESS
          Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
          I+=1
          Raz [L]WRET : Raz [L]WMESSA
          Break
        Endif
        #--/
      Endif
    Next
    If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
  Endif
Endif
#----- Alimentation autres codes taxes (provinciales et globales) -----#
[L]WRET=0
If MYPARAM.TRAIT=2 | MYPARAM.TRAIT=3
  [L]WSATRCP=[F:TLK]SATRCP
  [L]WSATISS=[F:TLK]SATISS
  If MYPARAM.C_VAT(1)<>null
    [F:TLK]VACITM=MYPARAM.C_VAT(1).VACITM
  Endif
  #----- Taxe provinciale entrée -----#
  If MYPARAM.TRAIT=3  I=3 Else  I=0 : Endif
  [F:TLK]SATFLG=1
  [F:TLK]SATRCP=[L]WSATRCP
 #[F:TLK]SATISS=""
  Gosub SET_LCRITITMBPR #Fq75921-Gbn
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1 : Break
      #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      #If WSTAT=0
      WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
      If WRET<=[V]CST_ASUCCESS
        Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
        I+=1
        Raz [L]WRET : Raz [L]WMESSA
        Break
      Endif
      #--/
    Endif
  Next
  If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
  #----- Taxe provinciale sortie -----#
  [L]WRET=0
  If TRAIT=3  I=4 Else  I=1 : Endif
  [F:TLK]SATFLG=2
 #[F:TLK]SATRCP=""
  [F:TLK]SATISS=[L]WSATISS
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
#    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,TAXES(0..I-1)) & evalue(WEXPRESSION2) :#--CPO 80360
     If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,MYPARAM.C_VAT(1..maxtab(MYPARAM.C_VAT)).VAT) & evalue(WEXPRESSION2) :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1 : Break
      #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      #If WSTAT=0
      WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
      If WRET<=[V]CST_ASUCCESS
        Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
        I+=1
        Raz [L]WRET : Raz [L]WMESSA
        Break
      Endif
      #--/
    Endif
  Next
  If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
  #----- Taxes provinciales globales ou autres -----#
  [L]WRET=0
  If TRAIT=3  I=5 Else  I=2 : Endif
  [F:TLK]SATFLG=3
  [F:TLK]SATRCP=[L]WSATRCP
  [F:TLK]SATISS=[L]WSATISS
  Gosub SET_LCRITITMBPR #Fq75921-Gbn
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#---CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
#    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,TAXES(0..I-1)) & evalue(WEXPRESSION2) :#--CPO 80360
    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,MYPARAM.C_VAT(1..maxtab(MYPARAM.C_VAT)).VAT) & evalue(WEXPRESSION2) :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1
      #If I>=dim(TAXES)  Break : Endif
      #Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      #If WSTAT=0
      WRET = func FINDVAT_SYRA.CONTTVC(MYPARAM.ACTX, [F:TVC]COD, [F:TLK]LEG, [F:TLK]FCY, "", [F:TLK]CPY, WMESSA)
      If WRET<=[V]CST_ASUCCESS
        Gosub ALIM_MYPARAMC_VAT : If [L]WRET >= [V]CST_AERROR Break Endif
        I+=1
        Raz [L]WRET : Raz [L]WMESSA
#        If I>=dim(TAXES)  Break : Endif
        If I>maxtab(MYPARAM.C_VAT)
          Break
        Endif
      Endif
      #--/
    Endif
  Next
  If [L]WRET >= [V]CST_AERROR End [L]WRET Endif
Endif

End [L]WRET


# ---------------------------------------------------------------------------------- #
# On a trouvé un code taxe : On alimente le tableau des taxes dans la classe FINDVAT #
#                            On alimente VAT et VAT_LEG                              #
# ---------------------------------------------------------------------------------- #
$ALIM_MYPARAMC_VAT
Local Integer WSTATUS

[L]WRET=[V]CST_AOK

If MYPARAM.C_VAT(I+1)=null
  [L]WRET = fmet MYPARAM.ADDLINE("C_VAT",I+1)
  If [L]WRET = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    WMESSA = func ASYRFNC.MES2(mess(266,133,1),'C_VAT','FINDVAT')
    [L]WRET=fmet MYPARAM.ASETERROR ("", WMESSA, [V]CST_AERROR)
    Return
  Endif
Endif
MYPARAM.C_VAT(I+1).VAT=[F:TVC]VAT
If MYPARAM.C_VAT(I+1).VAT <> ""
    MYPARAM.C_VAT(I+1).VAT_LEG = AVOID.ACHAR
    Call LEC_TVT_LEG(MYPARAM.ACTX, [F:TLK]LEG, MYPARAM.C_VAT(I+1).VAT, WSTATUS) From TRTLECLEG_SYRA
    If WSTATUS=0 MYPARAM.C_VAT(I+1).VAT_LEG = [F:TVT]LEG Endif
Endif

Return

#----- Ajout d'un critère supplémentaire sur VACBPR et VACITM #gbn-Fq76004
$SET_LCRITITMBPR
 Local Char LCRITITMBPR(255)
 If dim([F:TLK]VACITM)>0
  If [F:TLK]VACITM<>""
   LCRITITMBPR="(VACITM='"+[F:TLK]VACITM+"')"
  Endif
 Endif
 If dim([F:TLK]VACBPR)>0
  If LCRITITMBPR<>""
   LCRITITMBPR+="|(VACBPR='"+[F:TLK]VACBPR+"')"
  Else
   LCRITITMBPR="(VACBPR='"+[F:TLK]VACBPR+"')"
  Endif
 Endif
 If LCRITITMBPR=""
  LCRITITMBPR="1=1"
 Endif
Return


#--------------------------------------------------------------#
# Chargement de la désignation article dans la langue du tiers #
# et prend ITMDESx correspondant si non renseigné              #
#--------------------------------------------------------------#
Subprog CHARGE_DEFITMDES (LZON,LLAN,LITM,LDES,LABRITM)
Value    Char    LZON
Value    Char    LLAN
Value    Char    LITM
Variable Char    LDES
Value    Char    LABRITM

Local Char LZONITMDES(GLONAVA)
Local Integer NITMSALE

  # FGR 29/06/2009 : X3SUIVI56129
  If LITM = "" Then
    LDES = ""
  Else
    Call CHARGE_ITMDES (LZON,LLAN,LITM,LDES)
    If LDES = "" Then
      # FGR 02/07/2009 : X3SUIVI56270
      NITMSALE = 0
      If evalue("dim(" + LABRITM + "SBSITM)") >= 0 or LABRITM = "" Then
        # On demande par rapport à ITMSALES parce que SBSITM n'existe pas dans ITMMASTER
        # Donc on change de table pour aller chercher la désignation dans ITMMASTER.
        # C'est seulement dans le cas où la demande se fait par rapport à ITMSALES qu'on bascule
        # sur ITMMASTER. Si quelqu'un fait la demander par rapport à une table métier, si la désignation
        # y figure, c'est celle-là qui sera prise. Le but est de ne plus utiliser ITMSALES.ITMDES1.
        NITMSALE = 1
        Local File ITMMASTER [IT1_]  # FGR 05/01/2010 : X3SUIVI61333 Renommer [ITM_]en [IT1_]
        LABRITM = "[F:IT1_]"
        Read [IT1_]ITM0=LITM
        If fstat Then
          Raz [F:IT1_]
        Endif
      Endif
      #
      Case LZON
        When "DES1AXX"
          LZONITMDES = "ITMDES1"
        When "DES2AXX"
          LZONITMDES = "ITMDES2"
        When "DES3AXX"
          LZONITMDES = "ITMDES3"
        When Default
          LZONITMDES = "ITMDES1"
      Endcase
      If evalue("dim(" + LABRITM + LZONITMDES + ")") > 0 Then
        LDES = evalue(LABRITM + LZONITMDES)
      Endif
      If NITMSALE = 1 Then
        Close Local File [IT1_]
      Endif
    Endif
  Endif
End

#--------------------------------------------------------------#
# Chargement de la désignation article dans la langue du tiers #
#--------------------------------------------------------------#
Subprog CHARGE_ITMDES (LZON,LLAN,LITM,LDES)
Value    Char    LZON
Value    Char    LLAN
Value    Char    LITM
Variable Char    LDES
#-----
Raz LDES
Local File ATEXTRA [AXX]
If LZON<>"" & LLAN<>"" & LITM<>""
  Read [AXX] AXX0="ITMMASTER";LZON;LLAN;LITM;""
  If !fstat  LDES=[F:AXX]TEXTE : Endif
Endif
End

#-------------------------------------------------------------#
# Conversion quantité d"une unité vers une autre avec arrondi #
# ----------------------------------------------------------- #
# WUOM1 : Unité d'origine                                     #
# WUOM2 : Unité destination                                   #
# WQTY  : Quantité à convertir puis quantité convertie        #
#-------------------------------------------------------------#
Subprog CONVERT_QTY(CTX, WUOM1, WUOM2, WQTY)
Value    Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    WUOM1
Value    Char    WUOM2
Variable Decimal WQTY

  #----- Conversion quantité si unités différentes -----#
  If WUOM1<>WUOM2
    Local    Decimal WCOEF
    Local File TABCOEFF [TCO]
    # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
    If [F:TCO]UOM1=WUOM1 & [F:TCO]UOM2=WUOM2
      WCOEF=[F:TCO]COEUOM
    Else
      Read [TCO] TCO0=WUOM1;WUOM2
      If !fstat
        WCOEF=[F:TCO]COEUOM
      Else
        # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
        If [F:TCO]UOM1=WUOM2 & [F:TCO]UOM2=WUOM1
            If [F:TCO]COEUOM<>0
            WCOEF=1/[F:TCO]COEUOM
            Else
            WCOEF=1
            Endif
        Else
          Read [TCO] TCO0=WUOM2;WUOM1
          If !fstat & [F:TCO]COEUOM<>0
            WCOEF=1/[F:TCO]COEUOM
          Else
            Raz [F:TCO]
            WCOEF=1
          Endif
        Endif
      Endif
    Endif
    WQTY*=WCOEF
  Endif
  #----- Arrondi de la quantité -----#
  Local File TABUNIT [TUN]
  # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
  # Issue 85754 - 2012-11-08 by VPO : Erreur sur unité utilisée pour arrondi
  #If [F:TUN]UOM<>WUOM2
  If [F:TUN]UOM=WUOM2
      WQTY=arr(WQTY,10^-[F:TUN]UOMDEC)
  Else
    Read [TUN] TUN0=WUOM2
    If !fstat
      WQTY=arr(WQTY,10^-[F:TUN]UOMDEC)
    Endif
  Endif
  #-----
End

