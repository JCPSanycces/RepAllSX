#<AdxTL>@(#)0.0.0.0 $Revision$
# MFGPSSCH - Functions that determine the URL used for Production Scheduler
# They have been placed in this source so that the roles cannot be amended by customers
# to circumvent the licencing.

#**----------------------------------------------------------------<br/>
#* GETPSURL : Retrieve the URL to access Production Scheduler
#**<br/>----------------------------------------------------------------<br/>
#* @param SITE    = Site
#* @param RESBODY = Complete URL including authentication token
#*
#* @return STATUSCODE : Integer : The status code - 200 if successful.
#*!
Funprog GETPSURL (SITE, RESBODY)
    Variable Char SITE()
    Variable Clbfile RESBODY()

    Local Char USERROLE(1)
    Local Clbfile FEATURES(0)
    Local Clbfile RESHEAD(0)
    Local Char PSPATH(250)
    Local Char CLIENTID(250)
    Local Char SERVER(250)
    Local Integer OK

    # Get user role, show error if no access.
    [L]USERROLE = func GETUSERROLE([L]SITE, GFONCTION, GUSRFCY, GUSRAUZ, GNBAUZ)
    If [L]USERROLE = ""
        Call ERREUR(mess(383,193,1)) From GESECRAN
        OK = 1
        End OK
    Endif

    [L]FEATURES = func GETPSFEATURES([L]SITE, [L]USERROLE)

    # Get URL (including token) for Planner One
    Call PARAM([L]SITE,"PSCLIENTID",[L]CLIENTID) From ADOVAL
    [L]PSPATH = "ProductionScheduler/Default.aspx?clientId=" + [L]SITE + "&erpClientType=DESKTOP"
    [L]OK = func ASYRCONNAPP.FORMAT_URL([L]CLIENTID, [L]PSPATH, [L]FEATURES, [L]RESHEAD, [L]RESBODY)
End OK

#**----------------------------------------------------------------<br/>
#* GETUSERROLE : Get the user role based on the function option and whether this site is authorised
#**<br/>----------------------------------------------------------------<br/>
#* @param SITE    = Site
#* @param FUNCTION = Function name used to access Production Scheduler
#* @param USRFCY = Authorised sites
#* @param USRAUZ = Authorised options
#* @param NBAUZ = Number of authorised sites
#*
#* @return USERROLE : Char : Highest user role (P - Planner, C - Collaborator or V - Viewer) or blank if not authorised
#*!
Funprog GETUSERROLE(SITE, FUNCTION, USRFCY, USRAUZ, NBAUZ)
    Value Char SITE()
    Value Char FUNCTION()
    Value Char USRFCY()(1..)
    Value Char USRAUZ()(1..)
    Value Integer NBAUZ

    Local Integer I
    Local Char USERROLE(2)

    If FUNCTION = "FUNPSVIEW" | FUNCTION = "FUNPSVIEWD"
        [L]USERROLE = "V"
    Else
        If func ALLOPTIONS() = 1
            [L]USERROLE = "P"
        Else
            [L]I = 1
            If USRFCY (1) = "\"
                [L]I = 1
            Else
                [L]I = find(SITE, USRFCY)
            Endif

            # Check if site is authorised
            If I = 0
                [L]USERROLE = ""
            Else
                If (instr (1, USRAUZ (I), "P"))
                    [L]USERROLE = "P"
                Elsif (instr (1, USRAUZ (I), "C"))
                    [L]USERROLE = "C"
                Else
                    [L]USERROLE = "V"
                Endif
            Endif
        Endif
    Endif
End [L]USERROLE

#**----------------------------------------------------------------<br/>
#* ALLOPTIONS : Does this user have a profile with all options allowed?
#**<br/>----------------------------------------------------------------<br/>
#*
#* @return ALL : Integer : 1 if all options allowed otherwise 0
#*!
Funprog ALLOPTIONS()
    Local Integer ALL

    If !clalev([F:AFT])  Local File AFCTFCT   [AFT] : Endif

    [L]ALL = 0

    Read [AFT] AFT0 = GPROFIL
    If fstat = CST_AOK & [F:AFT]ALLFCT = 2
        [L]ALL = 1
    Endif

End ALL

#**----------------------------------------------------------------<br/>
#* GETPSFEATURES : Get the allowed features based on the user role
#**<br/>----------------------------------------------------------------<br/>
#* @param SITE   = Site
#* @param ROLE   = User role (P - Planner, C - Collaborator or V - Viewer)
#*
#* @return FEATURES : Char : Production Scheduler features allowed for the given role
#*!
Funprog GETPSFEATURES(SITE, ROLE)
    Value Char SITE()
    Value Char ROLE()

    Local Char INTUSR(80)
    Local Char FEATURE(40)(8)
    Local Clbfile FEATURES(0)

    [L]FEATURE(1) = "  - p1.admin\n"
    [L]FEATURE(2) = "  - p1.workingplanning\n"
    [L]FEATURE(3) = "  - p1.taskaction\n"
    [L]FEATURE(4) = "  - p1.optimization\n"
    [L]FEATURE(5) = "  - p1.marker\n"
    [L]FEATURE(6) = "  - p1.resourceaction\n"
    [L]FEATURE(7) = "  - p1.access\n"

    # Send the site as part of the authentication
    Append FEATURES, "site:" - SITE + "\n"

    # Send the user, name and roles
    Append FEATURES, "sub:" - GUSER + "\n"
    Call LECTEXTRA([L]INTUSR,"AUTILIS","INTUSR",GUSER,"") From ATEXTRA
    Append FEATURES, "name:" - [L]INTUSR + "\n"
    Append FEATURES, "auth:\n"

    Case ROLE
        When "P"
            Append FEATURES, [L]FEATURE(1)
            Append FEATURES, [L]FEATURE(2)
            Append FEATURES, [L]FEATURE(3)
            Append FEATURES, [L]FEATURE(4)
            Append FEATURES, [L]FEATURE(5)
            Append FEATURES, [L]FEATURE(6)
            Append FEATURES, [L]FEATURE(7)
        When "C"
            Append FEATURES, [L]FEATURE(5)
            Append FEATURES, [L]FEATURE(6)
            Append FEATURES, [L]FEATURE(7)
        When "V"
            Append FEATURES, [L]FEATURE(7)
    Endcase

End FEATURES

