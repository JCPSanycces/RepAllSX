#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TRACKTPL

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"                   : Gosub AINIT                        From TRACKTPLH_CSTD_EVT
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER        From TRACKTPLH_CSTD_EVT
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER        From TRACKTPLH_CSTD_EVT
      Endcase
    When "TKTD"
      Case [L]AEVENT
        When "AINSERT_BEFORE"          : Gosub TKTD_AINSERT_BEFORE          From TRACKTPLH_CSTD_EVT
        When "AINSERT_CONTROL_AFTER"   : Gosub TKTD_AINSERT_CONTROL_AFTER   From TRACKTPLH_CSTD_EVT
        When "AUPDATE_CONTROL_AFTER"   : Gosub TKTD_AUPDATE_CONTROL_AFTER   From TRACKTPLH_CSTD_EVT
        When "ADDLINE_AFTER"           : Gosub TKTD_ADDLINE_AFTER           From TRACKTPLH_CSTD_EVT
        When "ADELLINE_BEFORE"         : Gosub TKTD_ADELLINE_BEFORE         From TRACKTPLH_CSTD_EVT
        When "ADELLINE_AFTER"          : Gosub TKTD_ADELLINE_AFTER          From TRACKTPLH_CSTD_EVT

      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "CTR_UNISTEP"                  : Gosub  CTR_UNISTEP                From TRACKTPLH_CSTD_MPU
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "IS_STEP_EXIST"                : Gosub  IS_STEP_EXIST              From TRACKTPLH_CSTD_MPU
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "TRKNUM" :
      Case [L]ARULE
        When "CONTROL" : Gosub TRKNUM_CONTROL
      Endcase
  Endcase
Return

#**
#* TRKNUM
#*!
$TRKNUM_CONTROL
this.TRKNUM=toupper(this.TRKNUM)
Return

