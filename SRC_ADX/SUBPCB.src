End

##########################################################################
Subprog C_MPSBOMALT(VALEUR)
Variable Decimal VALEUR

# Issue 78125 GA 03/2012 replace action CONTALTMPS from TRTBOM
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif

Read [TBO]TBO0=[M]MPSALTTYP;VALEUR
If fstat
   GMESSAGE = mess(23,100,1) 
   mkstat=2 : End
Elsif [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:PCB0]STOFCY
   GMESSAGE = mess(48,193,1)
   mkstat = 2 : End
Elsif [F:TBO]MPSUSE <> 2
   GMESSAGE = mess(15,187,1)
   mkstat = 2 : End
Endif
End

##########################################################################
Subprog C_MRPBOMALT(VALEUR)
Variable Decimal VALEUR

# Issue 78125 GA 03/2012 replace action CONTALTMRP from TRTBOM
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif

Read [TBO]TBO0=[M]MRPALTTYP;VALEUR
If fstat
   GMESSAGE = mess(23,100,1) 
   mkstat=2 : End
Elsif [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:PCB0]STOFCY
   GMESSAGE = mess(48,193,1)
   mkstat = 2 : End
Elsif [F:TBO]MRPUSE <> 2
   GMESSAGE = mess(15,187,1)
   mkstat = 2 : End
Endif
End

######################################################################################
Subprog AS_MRPALTTYP(VALEUR)
Variable Integer VALEUR

GMENLOC(1)=1 : # pas de Commerce

End

######################################################################################
Subprog AS_MPSALTTYP(VALEUR)
Variable Integer VALEUR

GMENLOC(1)=1 : # pas de Commerce

End
