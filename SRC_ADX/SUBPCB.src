#<AdxTL>@(#)11.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LIENS"      : Gosub LIENS
  When "SETBOUT"    : Gosub SETBOUT
  When "RAZCRE"     : Gosub RAZCRE
  When "AV_IMPRIME" : Gosub COP_ECRAN
                      OK = 0
  When "FERME"      : Call IMPSCR        From ATRTX3
Endcase
Return

############################################################
$COP_ECRAN
Local Char WTIT(80)
Local Char WMSK(10)(2)
Local Char WABR(06)(2)
WTIT = mess(145,196,1)-[M:PCB0]STOFCY-[M:PCB0]ZSTOFCY
WMSK(0) = "PCB2"
WMSK(1) = "PCB4"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
WTIT = mess(146,196,1)-[M:PCB0]STOFCY-[M:PCB0]ZSTOFCY
WMSK(0) = "PCB1"
WMSK(1) = "PCB3"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return

############################################################
$LIENS
Local Integer I, INDRPL

If [F:PCB]MPSCOVRES = 0
  [F:PCB]MPSCOVRES = 2
  [M:PCB3]MPSCOVRES = 2
Endif
If [F:PCB]MRPCOVRES = 0
  [F:PCB]MRPCOVRES = 2
  [M:PCB4]MRPCOVRES = 2
Endif
[M:PCB1]WEE001 = mess(3,291,1)
[M:PCB1]WEE002 = mess(3,291,1)
[M:PCB2]WEE001 = mess(3,291,1)
[M:PCB2]WEE002 = mess(3,291,1)

Affzo [PCB1]WEE001
Affzo [PCB1]WEE002
Affzo [PCB2]WEE001
Affzo [PCB2]WEE002

Grizo [PCB1]WEE001
Grizo [PCB1]WEE002
Grizo [PCB2]WEE001
Grizo [PCB2]WEE002

Grizo [PCB3]MPSLASDAT
Grizo [PCB3]MPSLASLTI
Grizo [PCB4]MRPLASDAT
Grizo [PCB4]MRPLASLTI

INDRPL = 0
For I = 0 To 7
    [M:PCB3]RPLTYPS(I)     = [F:PCB]RPLTYPS(I)
    [M:PCB3]RPLMODS(I)     = [F:PCB]RPLMODS(I)
    If find([M:PCB3]RPLMODS(I),2,3) : INDRPL = 1 : Endif
    [M:PCB3]RPLBWDLTIS(I)  = [F:PCB]RPLBWDLTIS(I)
    [M:PCB3]RPLFRWLTIS(I)  = [F:PCB]RPLFRWLTIS(I)
    [M:PCB3]RPLUPDQTYS(I)  = [F:PCB]RPLUPDQTYS(I)
    [M:PCB3]RPLUPDDATS(I)  = [F:PCB]RPLUPDDATS(I)
    If [M:PCB3]RPLTYPS(I) = 0    : [M:PCB3]RPLTYPS(I) = I + 1 : Endif
    If [M:PCB3]RPLMODS(I) = 0    : [M:PCB3]RPLMODS(I) = 1     : Endif
    If [M:PCB3]RPLUPDQTYS(I) = 0 : [M:PCB3]RPLUPDQTYS(I) = 1  : Endif
    If [M:PCB3]RPLUPDDATS(I) = 0 : [M:PCB3]RPLUPDDATS(I) = 1  : Endif
    If [M:PCB3]RPLMODS(I) > 1
        Actzo [PCB3]RPLBWDLTIS(I)
        Actzo [PCB3]RPLFRWLTIS(I)
        Actzo [PCB3]RPLUPDQTYS(I)
        Actzo [PCB3]RPLUPDDATS(I)
    Else
        Diszo [PCB3]RPLBWDLTIS(I)
        Diszo [PCB3]RPLFRWLTIS(I)
        Diszo [PCB3]RPLUPDQTYS(I)
        Diszo [PCB3]RPLUPDDATS(I)
    Endif

Next I
[M:PCB3]NBLIGS = I
If INDRPL
    Actzo [PCB3]WIPPROS
    Actzo [PCB3]RESBLWLOTS
    Actzo [PCB3]REOPOLDISS
Else
    [M:PCB3]WIPPROS      = 1
    [M:PCB3]RESBLWLOTS   = 1
    [M:PCB3]REOPOLDISS   = 1
    Grizo [PCB3]25
Endif
Affzo [PCB3]25

INDRPL = 0
For I = 0 To 7
    [M:PCB4]RPLTYP(I)      = [F:PCB]RPLTYP(I)
    [M:PCB4]RPLMOD(I)      = [F:PCB]RPLMOD(I)
    If find([M:PCB4]RPLMOD(I),2,3) : INDRPL = 1 : Endif
    [M:PCB4]RPLBWDLTI(I)   = [F:PCB]RPLBWDLTI(I)
    [M:PCB4]RPLFRWLTI(I)   = [F:PCB]RPLFRWLTI(I)
    [M:PCB4]RPLUPDQTY(I)   = [F:PCB]RPLUPDQTY(I)
    [M:PCB4]RPLUPDDAT(I)   = [F:PCB]RPLUPDDAT(I)
    If [M:PCB4]RPLTYP(I) = 0    : [M:PCB4]RPLTYP(I) = I + 1 : Endif
    If [M:PCB4]RPLMOD(I) = 0    : [M:PCB4]RPLMOD(I) = 1     : Endif
    If [M:PCB4]RPLUPDQTY(I) = 0 : [M:PCB4]RPLUPDQTY(I) = 1  : Endif
    If [M:PCB4]RPLUPDDAT(I) = 0 : [M:PCB4]RPLUPDDAT(I) = 1  : Endif
    If [M:PCB4]RPLMOD(I) > 1
        Actzo [PCB4]RPLBWDLTI(I)
        Actzo [PCB4]RPLFRWLTI(I)
        Actzo [PCB4]RPLUPDQTY(I)
        Actzo [PCB4]RPLUPDDAT(I)
    Else
        Diszo [PCB4]RPLBWDLTI(I)
        Diszo [PCB4]RPLFRWLTI(I)
        Diszo [PCB4]RPLUPDQTY(I)
        Diszo [PCB4]RPLUPDDAT(I)
    Endif
Next I
[M:PCB4]NBLIG = I
If INDRPL
    Actzo [PCB4]WIPPRO
    Actzo [PCB4]RESBLWLOT
    Actzo [PCB4]REOPOLDIS
Else
    [M:PCB4]WIPPRO      = 1
    [M:PCB4]RESBLWLOT   = 1
    [M:PCB4]REOPOLDIS   = 1
    Grizo [PCB4]25
Endif
Affzo [PCB4]25

Affzo [PCB3]20
Affzo [PCB4]20

If GPCBSEL = "1" | GCONSULT <> 0
  Grizo [PCB2]
  Grizo [PCB4]
Endif
If GPCBSEL = "2" | GCONSULT <> 0 | GMODU(8) <> 2
  Grizo [PCB1]
  Grizo [PCB3]
Endif
If GMODU(8) <> 2
  [M:PCB2]MRPCAPLTI = 0
  Grizo [PCB2]MRPCAPLTI
Endif

Return

############################################################
$SETBOUT
If find(GPCBSEL,"1","2") : # GH 15/05/12 bug 78125
   Call VIREBOUT(CHAINE,"CDA") From GOBJET
Endif
Return

############################################################
$RAZCRE
[M:PCB1]WEE001 = mess(3,291,1)
[M:PCB1]WEE002 = mess(3,291,1)
[M:PCB2]WEE001 = mess(3,291,1)
[M:PCB2]WEE002 = mess(3,291,1)
Affzo [PCB1]WEE001
Affzo [PCB1]WEE002
Affzo [PCB2]WEE001
Affzo [PCB2]WEE002
For I = 0 To 7
    [M:PCB3]RPLTYPS(I)     = I + 1
    [M:PCB3]RPLMODS(I)     = 1
    [M:PCB3]RPLBWDLTIS(I)  = 0
    [M:PCB3]RPLFRWLTIS(I)  = 0
    [M:PCB3]RPLUPDQTYS(I)  = 1
    [M:PCB3]RPLUPDDATS(I)  = 1
    If [M:PCB3]RPLMODS(I) > 1
        Actzo [PCB3]RPLBWDLTIS(I)
        Actzo [PCB3]RPLFRWLTIS(I)
        Actzo [PCB3]RPLUPDQTYS(I)
        Actzo [PCB3]RPLUPDDATS(I)
    Else
        Diszo [PCB3]RPLBWDLTIS(I)
        Diszo [PCB3]RPLFRWLTIS(I)
        Diszo [PCB3]RPLUPDQTYS(I)
        Diszo [PCB3]RPLUPDDATS(I)
    Endif

Next I
[M:PCB3]NBLIGS = I

For I = 0 To 7
    [M:PCB4]RPLTYP(I)      = I + 1
    [M:PCB4]RPLMOD(I)      = 1
    [M:PCB4]RPLBWDLTI(I)   = 0
    [M:PCB4]RPLFRWLTI(I)   = 0
    [M:PCB4]RPLUPDQTY(I)   = 1
    [M:PCB4]RPLUPDDAT(I)   = 1
    If [M:PCB4]RPLMOD(I) > 1
        Actzo [PCB4]RPLBWDLTI(I)
        Actzo [PCB4]RPLFRWLTI(I)
        Actzo [PCB4]RPLUPDQTY(I)
        Actzo [PCB4]RPLUPDDAT(I)
    Else
        Diszo [PCB4]RPLBWDLTI(I)
        Diszo [PCB4]RPLFRWLTI(I)
        Diszo [PCB4]RPLUPDQTY(I)
        Diszo [PCB4]RPLUPDDAT(I)
    Endif
Next I
[M:PCB4]NBLIG = I

Affzo [PCB1]
Affzo [PCB2]
Affzo [PCB3]20
Affzo [PCB4]20

If  GMODU(8) <> 2 : # GH 15/05/12 bug 78125
  Grizo [PCB1]
  Grizo [PCB3]
  [M:PCB2]MRPCAPLTI = 0
  Grizo [PCB2]MRPCAPLTI
Endif
Return

############################################################
Subprog C_MRPMONNBR(VALEUR)
Variable Decimal VALEUR
Local Decimal WCTR
If [M:PCB2]MRPDAYNBR = 0 & [M:PCB2]MRPWEENBR = 0 & VALEUR = 0
  mkstat = 2
  GMESSAGE = mess(11,187,1)
Else
  WCTR =   [M:PCB2]MRPDAYNBR
  WCTR += ([M:PCB2]MRPWEENBR*7)
  WCTR += (VALEUR*31)
  If WCTR > 2000
    mkstat = 2
    GMESSAGE = mess(13,187,1)
  Endif
Endif
End

############################################################
Subprog C_MPSMONNBR(VALEUR)
Variable Decimal VALEUR
Local Decimal WCTR
If [M:PCB1]MPSDAYNBR = 0 & [M:PCB1]MPSWEENBR = 0 & VALEUR = 0
  mkstat = 2
  GMESSAGE = mess(11,187,1)
Else
  WCTR =   [M:PCB1]MPSDAYNBR
  WCTR += ([M:PCB1]MPSWEENBR*7)
  WCTR += (VALEUR*31)
  If WCTR > 2000
    mkstat = 2
    GMESSAGE = mess(13,187,1)
  Endif
Endif
End
Subprog AP_MPSPHYSTO(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:PCB1]MPSCTLSTO = 1
  [M:PCB1]MPSREJSTO = 1
  [M:PCB1]MPSTRFSTO = 1
  Affzo [PCB1]MPSCTLSTO
  Affzo [PCB1]MPSREJSTO
  Affzo [PCB1]MPSTRFSTO
  Grizo [PCB1]MPSCTLSTO
  Grizo [PCB1]MPSREJSTO
  Grizo [PCB1]MPSTRFSTO
Else
  Actzo [PCB1]MPSCTLSTO
  Actzo [PCB1]MPSREJSTO
  Actzo [PCB1]MPSTRFSTO
Endif
End

