  [M:PCB2]MRPCTLSTO = 1
  [M:PCB2]MRPREJSTO = 1
  [M:PCB2]MRPTRFSTO = 1
  Affzo [PCB2]MRPCTLSTO
  Affzo [PCB2]MRPREJSTO
  Affzo [PCB2]MRPTRFSTO
  Grizo [PCB2]MRPCTLSTO
  Grizo [PCB2]MRPREJSTO
  Grizo [PCB2]MRPTRFSTO
Else
  Actzo [PCB2]MRPCTLSTO
  Actzo [PCB2]MRPREJSTO
  Actzo [PCB2]MRPTRFSTO
