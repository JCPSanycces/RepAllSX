############################################################
Subprog AV_MRPMFGLTI(VALEUR)
Variable Integer VALEUR
If GMODU(8) <> 2 | [M]MRPALTTYP=3 : # Issue 78125 GA 03/2012
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  VALEUR = 1
  End
Endif

If [M]MRPCAPLTI <> 0
  GMENLOC(1) = 1
Else
  GMENLOC(2) = 1
Endif
End

############################################################
Subprog AS_MRPMFGLTI(VALEUR)
Variable Integer VALEUR
If GMODU(8) <> 2 | [M]MRPALTTYP=3 : # Issue 78125 GA 03/2012
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  mkstat = 2 : End
Endif

If [M]MRPCAPLTI <> 0
  GMENLOC(1) = 1
Else
  GMENLOC(2) = 1
Endif
End

############################################################
Subprog AV_MPSMFGLTI(VALEUR)
Variable Integer VALEUR
If GMODU(8) <> 2 | [M]MPSALTTYP=3  : # Issue 78125 GA 03/2012
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  VALEUR = 1
  End
Endif

If [M]MPSCAPLTI <> 0
  GMENLOC(1) = 1
Else
  GMENLOC(2) = 1
Endif
End

############################################################
Subprog AS_MPSMFGLTI(VALEUR)
Variable Integer VALEUR
If GMODU(8) <> 2 | [M]MPSALTTYP=3 : # Issue 78125 GA 03/2012
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  mkstat = 2 : End
Endif

If [M]MPSCAPLTI <> 0
  GMENLOC(1) = 1
Else
  GMENLOC(2) = 1
Endif
End

############################################################
Subprog C_MPSMFGLTI(VALEUR)
Variable Integer VALEUR

If VALEUR > 1
  If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
  mkstat = 2
  GMESSAGE = mess(94,193,1)
  For [TRO] Where find(FCY,"",[M:PCB0]STOFCY)<>0
&               & RCCUSE = 2
&               & find([M]MPSBOMALT,[F:TRO]BOMALT1,[F:TRO]BOMALT2,[F:TRO]BOMALT3)
    mkstat   = 0
    GMESSAGE = ""
    Break
  Next
Endif
End

############################################################
Subprog C_MRPMFGLTI(VALEUR)
Variable Integer VALEUR

If VALEUR > 1
  If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
  mkstat = 2
  GMESSAGE = mess(94,193,1)
  For [TRO] Where find(FCY,"",[M:PCB0]STOFCY)<>0
&               & MFGUSE = 2
&               & find([M]MRPBOMALT,[F:TRO]BOMALT1,[F:TRO]BOMALT2,[F:TRO]BOMALT3)

    mkstat   = 0
    GMESSAGE = ""
    Break
  Next
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/11/2003 09:04:07 (LLC)
##########################################################################
Subprog AM_RPLMODS(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M]RPLBWDLTIS(nolign-1) = 0
               [M]RPLFRWLTIS(nolign-1) = 0
               [M]RPLUPDQTYS(nolign-1) = 1
               [M]RPLUPDDATS(nolign-1) = 1
               Diszo [M]RPLBWDLTIS(nolign-1)
               Diszo [M]RPLFRWLTIS(nolign-1)
               Diszo [M]RPLUPDQTYS(nolign-1)
               Diszo [M]RPLUPDDATS(nolign-1)
    When 2,3:  Actzo [M]RPLBWDLTIS(nolign-1)
               Actzo [M]RPLFRWLTIS(nolign-1)
               Actzo [M]RPLUPDQTYS(nolign-1)
               Actzo [M]RPLUPDDATS(nolign-1)
Endcase
Affzo [M]RPLBWDLTIS(nolign-1)
Affzo [M]RPLFRWLTIS(nolign-1)
Affzo [M]RPLUPDQTYS(nolign-1)
Affzo [M]RPLUPDDATS(nolign-1)
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/11/2003 09:19:43 (LLC)
##########################################################################
Subprog AM_RPLMOD(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M]RPLBWDLTI(nolign-1) = 0
               [M]RPLFRWLTI(nolign-1) = 0
               [M]RPLUPDQTY(nolign-1) = 1
               [M]RPLUPDDAT(nolign-1) = 1
               Diszo [M]RPLBWDLTI(nolign-1)
               Diszo [M]RPLFRWLTI(nolign-1)
               Diszo [M]RPLUPDQTY(nolign-1)
               Diszo [M]RPLUPDDAT(nolign-1)
    When 2,3:  Actzo [M]RPLBWDLTI(nolign-1)
               Actzo [M]RPLFRWLTI(nolign-1)
               Actzo [M]RPLUPDQTY(nolign-1)
               Actzo [M]RPLUPDDAT(nolign-1)
Endcase
Affzo [M]RPLBWDLTI(nolign-1)
Affzo [M]RPLFRWLTI(nolign-1)
Affzo [M]RPLUPDQTY(nolign-1)
Affzo [M]RPLUPDDAT(nolign-1)
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/11/2003 09:39:53 (LLC)
##########################################################################
Subprog APRES_NBLIG
Local Integer I, INDRPL

INDRPL = 0
For I = 0 To [M]NBLIG - 1
    If find([M]RPLMOD(I),2,3) : INDRPL = 1 : Break : Endif
Next I
If INDRPL
    Actzo [M]WIPPRO
    Actzo [M]RESBLWLOT
    Actzo [M]REOPOLDIS
Else
    [M]WIPPRO = 1
    [M]RESBLWLOT = 1
    [M]REOPOLDIS = 1
    Grizo [M]WIPPRO
    Grizo [M]RESBLWLOT
    Grizo [M]REOPOLDIS
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/11/2003 09:40:06 (LLC)
##########################################################################
Subprog APRES_NBLIGS
Local Integer I, INDRPL

INDRPL = 0
For I = 0 To [M]NBLIGS - 1
    If find([M]RPLMODS(I),2,3) : INDRPL = 1 : Break : Endif
Next I
If INDRPL
    Actzo [M]WIPPROS
    Actzo [M]RESBLWLOTS
    Actzo [M]REOPOLDISS
Else
    [M]WIPPROS = 1
    [M]RESBLWLOTS = 1
    [M]REOPOLDISS = 1
    Grizo [M]WIPPROS
    Grizo [M]RESBLWLOTS
    Grizo [M]REOPOLDISS
Endif
End

