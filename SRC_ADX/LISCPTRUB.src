#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
 When "CONT1" : Gosub CONT1
 When "CONT2" : Gosub CONT2
# Pour ne pas controler que rubdeb>rubfin on fait End. Controle que rangdeb<rangfin
  If [M]PARCOD(nolign-1)="rubdeb" : End : Endif
Endcase
Return

$CONT1
Local Integer K
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Case [M]PARCOD(nolign-1)
 When "rubdeb"
  K = find("rngdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [RUB]RUB0=GCURLEG;VALPAR
   If !fstat
    [M:RPT]VALEUR1(K-1)=num$([F:RUB]ROW)
    Affzo [M:RPT]VALEUR1(K-1)
   Endif
  Endif
 When "rngdeb"
  K = find("rubdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [RUB]RUB1=GCURLEG;val(VALPAR)
   If !fstat
    [M:RPT]VALEUR1(K-1)=[F:RUB]COD
    Affzo [M:RPT]VALEUR1(K-1)
   Endif
  Endif
Endcase
Return

$CONT2
Local Integer K
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Case [M]PARCOD(nolign-1)
 When "rubdeb"
  K = find("rngdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [RUB]RUB0=GCURLEG;VALPAR
   If !fstat
    [M:RPT]VALEUR2(K-1)=num$([F:RUB]ROW)
    Affzo [M:RPT]VALEUR2(K-1)
   Endif
  Endif
 When "rngdeb"
  K = find("rubdeb",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [RUB]RUB1=GCURLEG;val(VALPAR)
   If !fstat
    [M:RPT]VALEUR2(K-1)=[F:RUB]COD
    Affzo [M:RPT]VALEUR2(K-1)
   Endif
  Endif
Endcase
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

End
