######################################################################################################
# Module        : Finance
# Description   : Search term list (Class BSISEALISD)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
# 2017-05-17    | DNE   |       | Search for main legal ledger corrected.
# 2017-05-17    | DNE   |       | $SET_BPRSAC_FIELD corrected for type supplier.
# 2017-05-17    | DNE   |       | Message for hard coded text created.
# 2017-05-26    | Bader |2017.R3| Support BTC reference (subdetail search for CAMT)
######################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AREAD_AFTER" : Gosub EVENT_AREAD_AFTER
                When "AUPDATE_CONTROL_BEFORE", "AINSERT_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "CPY"        : Gosub PROPERTY_CPY
        When "LEG"        : Gosub PROPERTY_LEG
        When "COA"        : Gosub PROPERTY_COA
        When "ACC"        : Gosub PROPERTY_ACC
        When "BPR"        : Gosub PROPERTY_BPR
        When "BPRSAC"     : Gosub PROPERTY_BPRSAC
        When "VAT"        : Gosub PROPERTY_VAT
        When "DSP"        : Gosub PROPERTY_DSP
        #angre
        When "DENCOD"     : Gosub PROPERTY_DENCOD
        When "SEABTC"     : Gosub PROPERTY_SEABTC
        When "SEAPAYREF"  : Gosub PROPERTY_OTHSEA_FIELDS
        When "SEABPRREF"  : Gosub PROPERTY_OTHSEA_FIELDS
        When "SEAOTH"     : Gosub PROPERTY_OTHSEA_FIELDS
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

$EVENT_AREAD_AFTER
    If this.ACC = "" Then
        Gosub DISABLE_ACC_FIELDS
    Else
        Gosub ENABLE_ACC_FIELDS
        Gosub SET_BPA_FIELDS_FOR_ACC
    Endif

    If this.BPR = "" Then
        Gosub DISABLE_BPR_FIELDS
    Else
        Gosub ENABLE_BPR_FIELDS
        Gosub SET_BPA_FIELDS_FOR_BPR
    Endif

    If this.SEABTC = "" and this.SEAPAYREF = "" and this.SEABPRREF = "" and this.SEAOTH = "" Then
        # all search fields are empty > enable all of them
        Gosub ENABLE_OTHSEA_FIELDS
        Gosub ENABLE_BTC_FIELD
    Else # not all search fields are empty > enable the filled ones
        If this.SEABTC = "" Then
            Gosub DISABLE_BTC_FIELD
        Else
            Gosub ENABLE_BTC_FIELD
        Endif

        If this.SEAPAYREF = "" and this.SEABPRREF = "" and this.SEAOTH = "" Then
            Gosub DISABLE_OTHSEA_FIELDS
        Else
            Gosub ENABLE_OTHSEA_FIELDS
        Endif
    Endif
Return


#angre
#Either account or BP must be entered
$AUPDATE_CONTROL_BEFORE
  If this.BPR = "" and this.ACC = ""
    ASTATUS = fmet this.ASETERROR("ACC",  this.BPRSAC + ": " + mess(00080,07703,1), [V]CST_AERROR)
    Return
  Endif
Return

########################################################################################################################

$PROPERTY_CPY
    Case [L]ARULE
        When "INIT"
            this.CPY = this.APARENT.CPY
    Endcase
Return

$PROPERTY_LEG
    Case [L]ARULE
        When "INIT"
            this.LEG = this.APARENT.LEG
    Endcase
Return

$PROPERTY_COA
    Case [L]ARULE
        When "INIT"
            Local File COMPANY [CPY]
            Local File GACM [GCM]
            Local File GLED [LED]
            Read [F:CPY]CPY0 = this.APARENT.CPY
            If fstat = 0 Then
                Read [F:GCM]GCM0 = [F:CPY]ACM
                If fstat = 0 Then
#2017-05-17 DNE MODIF BEGIN
                    Read [F:LED]LED0 = [GCM]LED( [GCM]GENLEDTYP - 1 ) # Main legal ledger as indicated in "Main legal ledger" field.
#2017-05-17 DNE MODIF ORIG
#                    Read [F:LED]LED0 = [F:GCM]LED
#2017-05-17 DNE MODIF END
                    If fstat = 0 Then
                        this.COA = [F:LED]COA
                    Else
                        ASTATUS = fmet this.ASETERROR("COA", [F:GCM]LED + ": " + mess(00023,00100,1), [V]CST_AERROR)
                    Endif
                Else
                    ASTATUS = fmet this.ASETERROR("COA", [F:CPY]ACM + ": " + mess(00023,00100,1), [V]CST_AERROR)
                Endif
            Else
                ASTATUS = fmet this.ASETERROR("COA", this.CPY +": " +  mess(00023,00100,1), [V]CST_AERROR)
            Endif
            LogicClose File [LED]
            LogicClose File [GCM]
            LogicClose File [CPY]
    Endcase
Return

#angre
$PROPERTY_DENCOD
  Case [L]ARULE
        When "CONTROL"
            Local File GACCDENCOD [CDA]
            Read [F:CDA]CDA0 = this.DENCOD;this.LEG
            If fstat <> 0 Then
                ASTATUS = fmet this.ASETERROR("DENCOD", this.DENCOD + ": " + mess(00023,00100,1), [V]CST_AERROR)
            Endif
  Endcase
Return

#angre
$PROPERTY_VAT
  Case [L]ARULE
        When "CONTROL"
            If this.VAT <> ""
              Local File TABVAT [TVT]
              Read [F:TVT]TVT0 = this.VAT;this.LEG
              If fstat <> 0 Then
                  ASTATUS = fmet this.ASETERROR("VAT", this.VAT + ": " + mess(00023,00100,1), [V]CST_AERROR)
              Endif
            Endif
  Endcase
Return

#angre
$PROPERTY_DSP
  Case [L]ARULE
    When "CONTROL"
        If this.DSP <> ""
          Local File CADSP [DSP]
          Read [F:DSP]DSP0(1) = this.DSP
          If fstat <> 0 Then
              ASTATUS = fmet this.ASETERROR("DSP", this.DSP + ": " + mess(00023,00100,1), [V]CST_AERROR)
          Endif
        Endif
  Endcase
Return


$PROPERTY_ACC
    Case [L]ARULE
        When "CONTROL"
            If this.ACC <> "" and this.BPR <> "" Then
                ASTATUS = fmet this.ASETERROR("ACC",  this.BPRSAC + ": " + mess(00079,07703,1), [V]CST_AERROR)
            Endif
        When "PROPAGATE"
            If this.ACC = "" Then

                Gosub ENABLE_BPR_FIELDS
            Else
                Gosub DISABLE_BPR_FIELDS
                # set BPATYP, BPANUM and BPAINV
                Gosub SET_BPA_FIELDS_FOR_ACC
                Gosub SET_VAT_FIELD
            Endif
    Endcase
Return

$PROPERTY_BPR
    Case [L]ARULE
        When "CONTROL"
            If this.BPR <> "" and this.ACC <> "" Then
                ASTATUS = fmet this.ASETERROR("BPR",  this.BPRSAC + ": " + mess(00079,07703,1), [V]CST_AERROR)
            Endif
        When "PROPAGATE"
            If this.BPR = "" Then
                Gosub ENABLE_ACC_FIELDS
                this.BPRSAC = ""
                this.ACCSAC = ""
            Else
                #angre
                this.VAT = ""
                Gosub DISABLE_ACC_FIELDS
                Gosub SET_BPA_FIELDS_FOR_BPR
                Gosub SET_BPRSAC_FIELD
            Endif
    Endcase
Return

$PROPERTY_BPRSAC
    Case [L]ARULE
        When "PROPAGATE"
            If this.BPRSAC <> ""
              Local File GACCOUNT [GAC]
              Read [F:GAC]GAC1 = this.COA;this.BPRSAC
              If fstat = 0 Then
                  If [F:GAC]SAC = [V]CST_AYES Then
                      this.ACCSAC = [F:GAC]ACC
                  Else
                      ASTATUS = fmet this.ASETERROR("BPRSAC", mess(9,106,1), [V]CST_AERROR)
                  Endif
              Else
                  ASTATUS = fmet this.ASETERROR("BPRSAC",  this.BPRSAC + ": " + mess(00023,00100,1), [V]CST_AERROR)
              Endif
              LogicClose File [GAC]
           Else
            this.ACCSAC = ""
           Endif
    Endcase
Return

$PROPERTY_OTHSEA_FIELDS
    Case [L]ARULE
        When "CONTROL"
            If (this.SEAPAYREF <> "" or this.SEABPRREF <> "" or this.SEAOTH <> "") and this.SEABTC <> "" Then
                ASTATUS = fmet this.ASETERROR("SEA",  this.BPRSAC + ": " + mess(00220,07703,1), [V]CST_AERROR)
            Endif
        When "PROPAGATE"
            If this.SEAPAYREF = "" and this.SEABPRREF = "" and this.SEAOTH = "" Then
                Gosub ENABLE_BTC_FIELD
            Else
                this.SEABTC = ""
                Gosub DISABLE_BTC_FIELD
            Endif
    Endcase
Return


$PROPERTY_SEABTC
    Case [L]ARULE
        When "CONTROL"
            If (this.SEAPAYREF <> "" or this.SEABPRREF <> "" or this.SEAOTH <> "") and this.SEABTC <> "" Then
                ASTATUS = fmet this.ASETERROR("BPR",  this.BPRSAC + ": " + mess(00220,07703,1), [V]CST_AERROR)
            Endif
        When "PROPAGATE"
            If this.SEABTC = "" Then
                Gosub ENABLE_OTHSEA_FIELDS
            Else
                this.SEAPAYREF = ""
                this.SEABPRREF = ""
                this.SEAOTH    = ""
                Gosub DISABLE_OTHSEA_FIELDS
            Endif
    Endcase
Return

########################################################################################################################

$ENABLE_ACC_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("ACC", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("VAT", "$isDisabled", "false")
Return

$DISABLE_ACC_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("ACC", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("VAT", "$isDisabled", "true")
Return

$ENABLE_BPR_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("BPR",    "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("BPRSAC", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("ACCSAC", "$isDisabled", "false")
Return

$DISABLE_BPR_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("BPR",    "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("BPRSAC", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("ACCSAC", "$isDisabled", "true")
Return

$ENABLE_BTC_FIELD
    ASTATUS = fmet this.ASETATTRIBUTE("SEABTC", "$isDisabled", "false")
Return

$DISABLE_BTC_FIELD
    ASTATUS = fmet this.ASETATTRIBUTE("SEABTC", "$isDisabled", "true")
Return

$ENABLE_OTHSEA_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("SEAPAYREF", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("SEABPRREF", "$isDisabled", "false")
    ASTATUS = fmet this.ASETATTRIBUTE("SEAOTH",    "$isDisabled", "false")
Return

$DISABLE_OTHSEA_FIELDS
    ASTATUS = fmet this.ASETATTRIBUTE("SEAPAYREF", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("SEABPRREF", "$isDisabled", "true")
    ASTATUS = fmet this.ASETATTRIBUTE("SEAOTH",    "$isDisabled", "true")
Return

########################################################################################################################

$SET_BPA_FIELDS_FOR_ACC
    this.BPATYP = 5
    this.BPANUM = this.COA + this.ACC
    Local File GACCOUNT [GAC]
    Read [F:GAC]GAC0 = this.COA;this.ACC
    If fstat = 0 Then
        this.BPAINV = [F:GAC]BPAADD
    Else
        ASTATUS = fmet this.ASETERROR("ACC", this.ACC + ": " +  mess(00023,00100,1), [V]CST_AERROR)
    Endif
    LogicClose File [GAC]
Return

$SET_VAT_FIELD
    Local File GACCOUNT [GAC]
    Read [F:GAC]GAC0 = this.COA;this.ACC
    If fstat = 0 Then
        If [F:GAC]FLGVAT = 1 Then
            # not sbjected
            this.VAT = ""
        Else
            Local File GACCDENCOD [CDA]
            Read [F:CDA]CDA0 = this.DENCOD;this.LEG
            If fstat = 0 Then
                If [F:CDA]RPCVAT > 1 Then
                    this.VAT = [F:GAC]VAT
                Endif
            Else
                ASTATUS = fmet this.ASETERROR("ACC", this.DENCOD + ": " + mess(00023,00100,1), [V]CST_AERROR)
            Endif
            LogicClose File [CDA]
        Endif
    Else
        ASTATUS = fmet this.ASETERROR("ACC", this.ACC + ": " + mess(00023,00100,1), [V]CST_AERROR)
    Endif
    LogicClose File [GAC]
Return

$SET_BPA_FIELDS_FOR_BPR
    this.BPATYP = 1
    this.BPANUM = this.BPR
#    Call INIADR(this.BPR, this.BPAINV) From SUBPAY
    Local File BPARTNER [BPR]
    Read [F:BPR]BPR0 = this.BPR
    If fstat = 0 Then
        this.BPAINV = [F:BPR]BPAADD
    Else
        ASTATUS = fmet this.ASETERROR("BPR", this.BPR + ": " + mess(00023,00100,1), [V]CST_AERROR)
    Endif
    LogicClose File [BPR]
Return

$SET_BPRSAC_FIELD
    Local Char BPRTYP(1)
    Local File BPARTNER [BPR]
    Local File BPCUSTOMER [BPC]
    Local File BPSUPPLIER [BPS]
    Read [F:BPR]BPR0 = this.BPR
    If fstat = 0 Then
        If [F:BPR]BPCFLG = [V]CST_AYES Then
            Read [F:BPC]BPC0 = this.BPR
            If fstat <> 0 Then
                ASTATUS = fmet this.ASETERROR("BPR", this.BPR + ": " + mess(00023,00100,1), [V]CST_AERROR)
                Return
            Endif
            If [F:BPC]BPCSTA = [V]CST_AYES Then
                [L]BPRTYP = "C"
            Endif
        Endif
        If [F:BPR]BPSFLG = [V]CST_AYES Then
            Read [F:BPS]BPS0 = this.BPR
            If fstat <> 0 Then
                ASTATUS = fmet this.ASETERROR("BPR", this.BPR + ": " + mess(00023,00100,1), [V]CST_AERROR)
                Return
            Endif
            If [F:BPS]ENAFLG = [V]CST_AYES Then
                [L]BPRTYP = "F"
            Endif
        Endif
    Else
        ASTATUS = fmet this.ASETERROR("BPR", this.BPR + ": " + mess(00023,00100,1), [V]CST_AERROR)
        Return
    Endif
    LogicClose File [BPS]
    LogicClose File [BPC]
    LogicClose File [BPR]

    Local Integer NBRLED
    Local Tinyint LEDTYP(20)
    Local Char    LEDCOD(20)(20)
    Local Char    LEDCUR(20)(20)     # Ledger currencies
    Local Char    COA(10)(20)        # Chart of accounts
    Local Char    COAFMT(10)(1..)    # Chart of accounts formats
    Local Char    COACOLHEA(10)(1..) # Chart of account column header
    Local Integer NBRDIE             # Number of dimension types (max 20)
    Local Char    DIE(GLONDIE)(20)   # Dimension types (DIE)
    Local Char    DIEFMT(10)(1..)    # Dimension types formats
    Local Char    DIECOLHEA(10)(1..) # Dimension types column header
    Local Integer DIEOBYFLG(1..)     # Obligatory flags (Y/N)
    Local Char    ERRMES(255)
    #get acounting structure for the company
    ASTATUS = func FINACM_SYRA.GET_FINSTC(GACTX, this.CPY, 1, NBRLED, LEDTYP, LEDCOD, LEDCUR, COA, COAFMT, COACOLHEA,
&       NBRDIE, DIE, DIEFMT, DIECOLHEA, DIEOBYFLG, ERRMES)

    Local Char CODCPT(GLONCAC)
    [L]CODCPT = func FINCAC_SYRA.GET_ACCCOD_BPR(GACTX, this.CPY, this.BPR, [L]BPRTYP)
    If [L]CODCPT <> "" Then
        Local File GACCCODE [CAC]
        Local File GACCOUNT [GAC]
        If [L]BPRTYP = "C" Then
            Read [F:CAC]CAC0 = 2;[L]CODCPT;[L]LEDCOD(0)
            If fstat = 0 Then
                Read [F:GAC]GAC0 = [L]LEDCOD(0);[F:CAC]ACC(0)
                If fstat = 0 Then
                    If [F:GAC]AUZBPR(0) = [V]CST_AYES Then
                        this.BPRSAC = [F:GAC]ACCSHO
                    Endif
                Else
                    ASTATUS = fmet this.ASETERROR("BPR", [F:CAC]ACC(0) + ": " + mess(00023,00100,1), [V]CST_AERROR)
                Endif
            Else
                ASTATUS = fmet this.ASETERROR("BPR", [L]CODCPT + ": " + mess(00023,00100,1), [V]CST_AERROR)
            Endif
        Elsif [L]BPRTYP = "F" Then
# 2017-05-17 DNE MODIF BEGIN
            Read [F:CAC]CAC0 = 3;[L]CODCPT;[L]LEDCOD(0)
# 2017-05-17 DNE MODIF ORIG
#            Read [F:CAC]CAC2 = 3;[L]CODCPT;[L]LEDCOD(0)
# 2017-05-17 DNE MODIF END
            Read [F:GAC]GAC0 = [L]LEDCOD(0);[F:CAC]ACC(0)
            If [F:GAC]AUZBPR(1) = [V]CST_AYES Then
                this.BPRSAC = [F:GAC]ACCSHO
            Endif
        Else
        Endif
        LogicClose File [GAC]
        LogicClose File [CAC]
    Else
# 2017-05-17 DNE MODIF BEGIN
        ASTATUS = fmet this.ASETERROR("BPR", mess(71,7772,1) - this.BPR, [V]CST_AERROR) # 'No accounting code has been found for this account:'
# 2017-05-17 DNE MODIF ORIG
#        ASTATUS = fmet this.ASETERROR("BPR", "No accounting code defined for" - this.BPR, [V]CST_AERROR)
# 2017-05-17 DNE MODIF END
    Endif
Return

########################################################################################################################

