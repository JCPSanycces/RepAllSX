#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:58"
A_USER  = "DOC"
A_STAMP = "20181109230358"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DLA0 [DLA0]
Gosub HORODAT
Local Inpbox "DLA0" From GFONCTION At A_STAMP With A_WINDPREV Mask [DLA0] As [SIM_]
Grizo [DLA0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DLA0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=92 : Y1(0)=1 : Y2(0)=4
Return

$ON_REFNUM
Onevent CONTROL Call C_REFNUM(zc) From W1DLA0
Onevent AFTER_CHANGE Gosub AMM_REFNUM From W1DLA0
Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1DLA0
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_REFNUM(zc) From W1DLA0
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1DLA0
Onkey 144 Titled GBOUTP Call P_REFNUM(zc) From W1DLA0
Onkey 146 Titled GBOUTA Call SA_REFNUM(zc) From W1DLA0
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = ""
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = ""
  PARMSK(5) = ""
  PARMSK(6) = func TOOLSHRLEG.LEGWRK
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","1","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action CONTOBJW
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARMSK(1) = "EML"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_REFNUM
Call AM_REFNUM(zc)
If !mkstat & GOBJET
 zoncou = "REFNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_REFNUM(VALEUR) From SUBDLA
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZREFNUM)")>indice
 [M]REFNUM(indice) = VALEUR
 Affzo ZREFNUM(indice)
Endif
Gosub _AFF
End

Subprog S_REFNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_REFNUM" : PROGSUB = "SUBDLA" : PROGSPE = "SPEDLA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = func TOOLSHRLEG.LEGWRK
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_REFNUM" : PROGSUB = "SUBDLA" : PROGSPE = "SPEDLA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_REFNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1DLA0
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_DAT
Onevent AFTER_CHANGE Gosub AMM_DAT From W1DLA0
Onevent CONTROL Call C_DAT(zc) From W1DLA0
Onevent BEFORE_AREA Gosub AV_DAT From W1DLA0
Return

$AV_DAT
Chgfmt [M]DAT(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 47432 : Endif
Gosub _AFF
End

$AMM_DAT
Call AM_DAT(zc)
If !mkstat & GOBJET
 zoncou = "DAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_DAT(VALEUR) From SUBDLA
If mkstat : GERR = 1 : GZONE = "DAT" : GZNUM = 47432 : Endif
Gosub _AFF
End

$ON_CTRNUM
Onevent CONTROL Call C_CTRNUM(zc) From W1DLA0
Onevent BEFORE_INPUT Call AS_CTRNUM(zc) From W1DLA0
Onevent AFTER_CHANGE Gosub AMM_CTRNUM From W1DLA0
Return

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
If !GWEBSERV
 ## Action SELEMPCTR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPCTR"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AAS_CTRNUM" : PROGSUB = "SUBDLA" : PROGSPE = "SPEDLA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = GCURLEG
 PARMSK(7) = [M]REFNUM
 PARMSK(8) = ACTION
 PARMSK(9) = "[F]REFNUM=[M:DLA0]REFNUM  & [F]CTRDAT<=[M:DLA0]DAT"
 PARMSK(10) = "([F]XITDAT=[0/0/0] | [F]XITDAT>=[M:DLA0]DAT)"
 PARMSK(11) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMPCTR","SELMAT","") From GACTION
 [M]REFNUM = PARMSK(7)
 ACTION = "BAS_CTRNUM" : PROGSUB = "SUBDLA" : PROGSPE = "SPEDLA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
 If mkstat=2
  [M]CTRNUM(INDIC) = VALEUR
  Affzo CTRNUM(INDIC) : mkstat = 2
 Endif
Endif
If !mkstat
 ## Action STD
 Call AS_CTRNUM(VALEUR) From SUBDLA
 If mkstat=2
  [M]CTRNUM(INDIC) = VALEUR
  Affzo CTRNUM(INDIC) : mkstat = 2
 Endif
 Onkey   2 Titled GBOUTS Call S_CTRNUM(zc) From W1DLA0
 Onkey 144 Titled GBOUTP Call P_CTRNUM(zc) From W1DLA0
 Onkey 146 Titled GBOUTA Call SA_CTRNUM(zc) From W1DLA0
Endif
Gosub _AFF
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
If !mkstat
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action CONTCTR
   Call CONTCTR(VALEUR,REFNUM) From DIVPAYE
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
Endif
Gosub _AFF
End

$AMM_CTRNUM
Call AM_CTRNUM(zc)
If !mkstat & GOBJET
 zoncou = "CTRNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CTRNUM(VALEUR) From SUBDLA
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
Gosub _AFF
End

Subprog S_CTRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTRLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTRLEG"
 PARMSK(1) = [M]REFNUM
 PARMSK(2) = "[F]REFNUM=[M:DLA0]REFNUM  & [F]CTRDAT<=[M:DLA0]DAT"
 PARMSK(3) = "([F]XITDAT=[0/0/0] | [F]XITDAT>=[M:DLA0]DAT)"
 PARMSK(4) = GCURLEG
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 PARMSK(10) = ""
 PARMSK(11) = ""
 PARMSK(12) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTRLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CIVA
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1DLA0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1DLA0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NOLIB
Return

$CHG_STY
Return


