#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update new collumn TYPNK
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ACLAFLD : FLGTR") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJACLA
End

#-------------------#
$MAJACLA
Local File =DOSSIER+".ACLASSE"   [ACLA]

If dim([F:ACLA]FLGTR)<=0 : Return : Endif

# Mise à jour de la table ACLASSE
Call ECR_TRACE(mess(81,125,1)-"ACLASSE:"-time$,0) From GESECRAN
Trbegin [ACLA]
 For [ACLA]
  If [F:ACLA]FLGTR=0
   If [F:ACLA]TYPCLA= 2
    [F:ACLA]FLGTR=2
   Else
    [F:ACLA]FLGTR = 1
   Endif
   Rewrite [ACLA]
   If fstat
    Call ERREUR("ACLASSE"-[F:ACLA]CODCLA,2) From DOSDIC
   Endif
  Endif
 Next ACLA

Commit

Close Local File [ACLA]


Return
