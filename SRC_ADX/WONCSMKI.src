# Supervisor
# Object management NCSMKI

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [19/10/2018]
A_HEURE = "08:15:35"
A_USER  = "ADMIN"
A_STAMP = "20181019081535"
Return

$DEFAUT
Default File [MKI]
Return

$OUVFIC
Local File MFGITMTRK [MKI]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "MFGITMTRK"
ABFIC  = "MKI"
ABTAB  = "MKI"
NOMINT = ""
TYPGES = 1
SELORD = 2
ZSITE  = "MFGFCY"
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = ""
FCYREQ = 1
PPAG   = 0
SELIND = "[F:MKI]MFGTRKNUM;[F:MKI]ITMTRKLIN"
DELDEF = 0
ADDURL = ""
NOMKEY = "MKI0"
FLGSTAT = 0
TITOBJ = 10833
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:MTK])=0 : Local File MFGHEADTRK   [MTK] : Endif
If clalev([F:MKM])=0 : Local File MFGMATTRK    [MKM] : Endif
If clalev([F:STJ])=0 : Local File STOJOU       [STJ] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY    [AFF] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(10833,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..0) , CLELIG(GLONAVA)
CLEPRIM = 'ITMTRKLIN'
CLESEC(0) = 'MFGTRKNUM'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
NBCOND += 1
OPT(NBCOND)    = 'P'
CONDIT(NBCOND) = "[F:MKI]ITMREF=[M]PRODUCT"
Call TEXTE(3651,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(0,MESSAG(NBCOND)) From OBJDIV
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(5)(0..GNBDERNIER)
Local Char     A_BUF2(20)(0..GNBDERNIER)
Local Integer  A_BUF3(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Decimal  A_BUF5(0..GNBDERNIER)
Local Char     A_BUF6(40)(0..GNBDERNIER)
If clalev([F:MKI9])>0 : Close Local File [MKI9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(5),
& Char     A_TAB2(20),
& Integer  A_TAB3,
& Char     A_TAB4(20),
& Decimal  A_TAB5,
& Char     A_TAB6(40)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6
& As [MKI9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:MKI]MFGFCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Return

$CHARGE_DERLU
If clalev([F:MKI9])>0
 Read [MKI9] = [F:MKI9]A_TABI
 [L]CLE = [F:MKI9]A_TABC
Endif
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]MFGFCY"
Call TEXTE(9145,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]MFGFCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]MFGTRKNUM"
Call TEXTE(10780,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]MFGTRKNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]ITMTRKLIN"
Call TEXTE(641,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 3
SELFMT(NBSEL) = "N:8F"
SELFOR(NBSEL) = "N:8#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]ITMTRKLIN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]ITMREF"
Call TEXTE(3651,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]ITMREF"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]CPLQTY"
Call TEXTE(9229,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "N:15F"
SELFOR(NBSEL) = "Nz:15F"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]CPLQTY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:MKI]PJT"
Call TEXTE(1886,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:MKI]PJT"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:MKI_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:MTK])=0 : Local file MFGHEADTRK [MTK] : Endif
Link [MKI] With
& [AFF]AFF0~=[F:MKI]MFGFCY;GPROFIL;GUSRFCT,
& [MTK]MTK0=[F:MKI]MFGTRKNUM
& As [MKI_]
Return

$DEFAUT_LISTE
Default file [MKI_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2"
Local Char     A_BUFJ1(20)(1..GNBSEL)
Local Integer  A_BUFJ2(1..GNBSEL)
Local Char     A_BUFJ3(15)(1..GNBSEL)
Local Char     A_BUFJ4(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(20),
& Integer  A_TABJ2,
& Char     A_TABJ3(15),
& Char     A_TABJ4(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..4)
Call TEXTE(10780,TITJOI(1)) From OBJDIV
Call TEXTE(641,TITJOI(2)) From OBJDIV
TITJOI(3) = mess(59,100,1) : # Type
TITJOI(4) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Nf:8#"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:20X"
End

$LIENS
Read [MTK]MTK0 = [F:MKI]MFGTRKNUM
If fstat : Raz [F:MTK] : Endif
Return

$LIAISONS
Return

Subprog TITTRN(COD,TIT)
Value Char COD
Variable Char TIT
Local Integer OUV
