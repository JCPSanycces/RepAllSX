#<AdxTL>@(#)10.0.0.0 $Revision$
dbgmode=1 : Dbgaff
Call AMIGSYR
End

Subprog AMIGSYR
Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","AMIGSYR","AMIGSYR",3,"SPEAMIGSYR") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####################
$INIT
If GPRODUIT=-1
GMESSAGE="Function not allowed on supervisor folders" : GERR=1 : FIN=1 : Return
Endif
Return

#####################
$INIT_DIA
[M]TRACE=2 : [M]TRACE1=2 : [M]TRACE2=2 : zonsui="STARTOBJ"
Return

#####################
$TERMINE
Return

Subprog C_TRACE(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  [M]GENE=1 : [M]SUPP=1 : Diszo GENE,SUPP
Else
  [M]GENE=1 : [M]SUPP=1 : Actzo GENE,SUPP
Endif
End

Subprog C_GENE(VALEUR)
Variable Integer VALEUR
If VALEUR=1 : [M]SUPP=1 : Diszo SUPP : Else Actzo SUPP : Endif
End

Subprog C_TRACE1(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  [M]GENE1=1 : [M]SUPP1=1 : Diszo GENE1,SUPP1
Else
  [M]GENE1=1 : [M]SUPP1=1 : Actzo GENE1,SUPP1
Endif
End

Subprog C_GENE1(VALEUR)
Variable Integer VALEUR
If VALEUR=1 : [M]SUPP1=1 : Diszo SUPP1 : Else Actzo SUPP1 : Endif
If VALEUR=1 : [M]MAJTYP=1 : Diszo MAJTYP : Else Actzo MAJTYP : Endif
End

Subprog C_TRACE2(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  [M]GENE2=1 : [M]SUPP2=1 : Diszo GENE2,SUPP2
Else
  [M]GENE2=1 : [M]SUPP2=1 : Actzo GENE2,SUPP2
Endif
End

Subprog C_GENE2(VALEUR)
Variable Integer VALEUR
If VALEUR=1 : [M]SUPP2=1 : Diszo SUPP2 : Else Actzo SUPP2 : Endif
End

$EXEC

  [M]ENDOBJ=""

  # Close the file in order to avoid folder mispatch when several folders need to be managed
  Call CLOSE_FILE From AMIGSYR1 : Call CLOSE_FILE From AMIGSYR2
  If [M]ENDOBJ="" : [M]ENDOBJ=[M]STARTOBJ : Endif
  Call OUVRE_TRACE("Syracuse transition on folder"-[M]DOSSIER) From LECFIC
  If [M]TRACE=2
    Call ECR_TRACE("******** Step 1 ********",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    Call GENE([M]DOSSIER,[M]STARTOBJ,[M]ENDOBJ,[M]GENE,[M]SUPP) From AMIGSYR1
  Endif

  If [M]TRACE1=2 or [M]TRACE2=2
    Call ECR_TRACE("******** Step 2 ********",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    Call GENE([M]DOSSIER,[M]STARTOBJ,[M]ENDOBJ,[M]GENE1,[M]SUPP1,[M]GENE2,[M]SUPP2,[M]MAJTYP,[M]CASCADE) From AMIGSYR2
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AMIGSYR) 14/03/2012 14:22:30 (DOM)
######################################################################################
Subprog AS_ENDOBJ(VALEUR)
Variable Char    VALEUR()
If [M]STARTOBJ<>"" & VALEUR=""
    VALEUR=[M]STARTOBJ
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AMIGSYR) 14/03/2012 14:22:54 (DOM)
######################################################################################
Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
 VALEUR=nomap
End


######################################################################################
