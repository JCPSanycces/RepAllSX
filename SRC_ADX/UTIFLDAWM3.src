#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ dans les modeles de données
#----------------------------------------------------------------------------------------#
Call PATCH(nomap)
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#-------------------#
$MAJFLG
Local File =DOSSIER+".AWRKLNK"   [AWM]

# Mise à jour de la table AWRKLNK
Call ECR_TRACE(mess(81,125,1)-"AWRKLNK:"-time$,0) From GESECRAN
Trbegin [AWM]
For [AWM]AWM0 
 If dim([AWM]FLGADLV)>0
   If [F:AWM]FLGADLV = 0
        [F:AWM]FLGADLV = 1
        Rewrite [AWM]
       If fstat
        Call ERREUR("AWRKLNK"-[F:AWM]MODELE,1) From DOSDIC
       Endif
 Endif
Endif
Next
Commit

Close Local File [AWM]

Return





