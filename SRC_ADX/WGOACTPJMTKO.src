#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OACTPJMTKO

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:11:41"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OACTPJMTKO",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PJTAC0;PJTAC0A;PJTAC0B;PJTAC1;PJTAC2;PJTAC0C;PJTAC0D;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PJTAC0])=0 : Local Mask PJMTACT0 [PJTAC0] : Endif
If clalev([M:PJTAC0A])=0 : Local Mask PJMTACT0A [PJTAC0A] : Endif
If clalev([M:PJTAC0B])=0 : Local Mask PJMTACT0B [PJTAC0B] : Endif
If clalev([M:PJTAC1])=0 : Local Mask PJMTACT1 [PJTAC1] : Endif
If clalev([M:PJTAC2])=0 : Local Mask PJMTACT2 [PJTAC2] : Endif
If clalev([M:PJTAC0C])=0 : Local Mask PJMTACT0C [PJTAC0C] : Endif
If clalev([M:PJTAC0D])=0 : Local Mask PJMTACT0D [PJTAC0D] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOACTPJMTKO
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OACTPJMTKO" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0]
&   Folder Mask [PJTAC0A]
& , Folder Mask [PJTAC0B]
& , Folder Mask [PJTAC1]
& , Folder Mask [PJTAC2]
& , Folder Mask [PJTAC0C]
& , Folder Mask [PJTAC0D]
& As [PJTAC0A]
Titled [PJTAC0A] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOACTPJMTKO
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OACTPJMTKO" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0]
&   Folder Mask [PJTAC0A]
& , Folder Mask [PJTAC0B]
& , Folder Mask [PJTAC1]
& , Folder Mask [PJTAC2]
& , Folder Mask [PJTAC0C]
& , Folder Mask [PJTAC0D]
& As [PJTAC0A]
Titled [PJTAC0A] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PJTAC0A] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PJTAC0A] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PJTAC0A]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(17010,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PJMTACT0"     : ABMSK(0)  = "PJTAC0"   : AMA(0) = 1
NOMMSK(1) = "PJMTACT0A"    : ABMSK(1)  = "PJTAC0A"  : AMA(1) = 1
NOMMSK(2) = "PJMTACT0B"    : ABMSK(2)  = "PJTAC0B"  : AMA(2) = 1
NOMMSK(3) = "PJMTACT1"     : ABMSK(3)  = "PJTAC1"   : AMA(3) = 1
NOMMSK(4) = "PJMTACT2"     : ABMSK(4)  = "PJTAC2"   : AMA(4) = 1
NOMMSK(5) = "PJMTACT0C"    : ABMSK(5)  = "PJTAC0C"  : AMA(5) = 1
NOMMSK(6) = "PJMTACT0D"    : ABMSK(6)  = "PJTAC0D"  : AMA(6) = 1
NBMASK = 6
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PJTAC0])>0 : Default Mask [PJTAC0] : Endif
 When 1 : If clalev([M:PJTAC0A])>0 : Default Mask [PJTAC0A] : Endif
 When 2 : If clalev([M:PJTAC0B])>0 : Default Mask [PJTAC0B] : Endif
 When 3 : If clalev([M:PJTAC1])>0 : Default Mask [PJTAC1] : Endif
 When 4 : If clalev([M:PJTAC2])>0 : Default Mask [PJTAC2] : Endif
 When 5 : If clalev([M:PJTAC0C])>0 : Default Mask [PJTAC0C] : Endif
 When 6 : If clalev([M:PJTAC0D])>0 : Default Mask [PJTAC0D] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PJTAC0])>0 : Gosub TITRES From W1PJMTACT0 : Endif
 When 1 : If clalev([M:PJTAC0A])>0 : Gosub TITRES From W1PJMTACT0A : Endif
 When 2 : If clalev([M:PJTAC0B])>0 : Gosub TITRES From W1PJMTACT0B : Endif
 When 3 : If clalev([M:PJTAC1])>0 : Gosub TITRES From W1PJMTACT1 : Endif
 When 4 : If clalev([M:PJTAC2])>0 : Gosub TITRES From W1PJMTACT2 : Endif
 When 5 : If clalev([M:PJTAC0C])>0 : Gosub TITRES From W1PJMTACT0C : Endif
 When 6 : If clalev([M:PJTAC0D])>0 : Gosub TITRES From W1PJMTACT0D : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PJTAC0])>0 : Close Local Mask [PJTAC0] : Endif
If clalev([M:PJTAC0A])>0 : Close Local Mask [PJTAC0A] : Endif
If clalev([M:PJTAC0B])>0 : Close Local Mask [PJTAC0B] : Endif
If clalev([M:PJTAC1])>0 : Close Local Mask [PJTAC1] : Endif
If clalev([M:PJTAC2])>0 : Close Local Mask [PJTAC2] : Endif
If clalev([M:PJTAC0C])>0 : Close Local Mask [PJTAC0C] : Endif
If clalev([M:PJTAC0D])>0 : Close Local Mask [PJTAC0D] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PJTAC0])>0 : Raz [M:PJTAC0] : Endif
 When 1 : If clalev([M:PJTAC0A])>0 : Raz [M:PJTAC0A] : Endif
 When 2 : If clalev([M:PJTAC0B])>0 : Raz [M:PJTAC0B] : Endif
 When 3 : If clalev([M:PJTAC1])>0 : Raz [M:PJTAC1] : Endif
 When 4 : If clalev([M:PJTAC2])>0 : Raz [M:PJTAC2] : Endif
 When 5 : If clalev([M:PJTAC0C])>0 : Raz [M:PJTAC0C] : Endif
 When 6 : If clalev([M:PJTAC0D])>0 : Raz [M:PJTAC0D] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PJTAC0])>0 : Affzo [M:PJTAC0] : Endif
 When 1 : If clalev([M:PJTAC0A])>0 : Affzo [M:PJTAC0A] : Endif
 When 2 : If clalev([M:PJTAC0B])>0 : Affzo [M:PJTAC0B] : Endif
 When 3 : If clalev([M:PJTAC1])>0 : Affzo [M:PJTAC1] : Endif
 When 4 : If clalev([M:PJTAC2])>0 : Affzo [M:PJTAC2] : Endif
 When 5 : If clalev([M:PJTAC0C])>0 : Affzo [M:PJTAC0C] : Endif
 When 6 : If clalev([M:PJTAC0D])>0 : Affzo [M:PJTAC0D] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = "ESAN09<>"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(16964,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(192,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 11 : Call TEXTE(1886,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 11 : CMEN(NBMEN) = "*" : LMEN(NBMEN) = 2001 : Call TEXTE(48408,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "PJMOPE"
  PARBOUT(2) = [M:PJTA0A]TASCOD
  PARBOUT(3) = num$([M:PJTAC0]OPENUM)
  PARBOUT(4) = num$([M:PJTAC0]OPESPLNUM)
  FLGEXE = 1
  GACTION = "PJMEVEO"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OEVENO","SUBPEV","") From GSAISIE
 When "*"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJTA0]KEYCONCAT
  PARBOUT(2) = [M:PJTAC0]TASFCY
  PARBOUT(3) = num$([M:PJTAC0]OPENUM)
  PARBOUT(4) = [M:PJTAC0]CREDAT
  PARBOUT(5) = ""
  FLGEXE = 1
  GACTION = "CONSPTE"
  Call CONSULT_CHAR(VALBOUT,"PTE",PARBOUT) From GCONSULT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


