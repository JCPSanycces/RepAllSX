#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYU",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Xtend:  Gestion Action Xtend
#        Objet temporaire pour dévelop
######################################################################################
$ACTION
Case ACTION
 When "AVANT_OUVRE"     : Gosub AVANT_OUVRE
 When "FERME"           : Gosub FERME
 When "LIENS"           : Gosub LIENS
 When "FILTRE"          : Gosub FILTRE
 When "OUVRE"           : Gosub OUVRE
 When "SETBOUT"         : Gosub SETBOUT

 When default
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), KEYLNK(30)
Local Integer WI, AYNPOS21
Gosub DSYFCY From SUBAYS     # Infos site
Return

#---------------------------------------------------------------#
$SETBOUT
CHAINE += "A" 
If CLECUR=0 | REP="M" | !VERROU
Else
 CHMEN+="1"    # Validation avec vérification 
Endif
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
Return


######################################################################################
## Ecran AYU1
######################################################################################
Subprog AS_OBJMNL(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
End

Subprog AS_OBJCOD(VALEUR)
Variable Char    VALEUR()
If [M]OBJTYP=2  # site
    VALEUR=GAYTFCYWRK : mkstat=2
Endif
End

Subprog AM_OBJTYP(VALEUR)
Variable Integer VALEUR
End

Subprog S_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer CHOIX, NBPARCOD, NBPARVAL, WI
Local Integer WMAX : WMAX=30
Local Char TEXTE (100)(1..WMAX,1..2), PARCOD(20)(0..WMAX), PARVAL(20)(0..WMAX)  # Commence à zéro pour SAITEX si 1 colonne
Local Char TIT(50)(1..3) 
Local Char WCURPAR   
Gosub LSTPAR
If NBPARCOD>0
    For WI=1 To NBPARCOD
        PARCOD(WI)=toupper(PARCOD(WI))
    Next
    CHOIX = find(VALEUR,PARCOD(1..NBPARCOD))
    If CHOIX=0 : CHOIX=1 : Endif
    Call SAITEX(NBPARCOD,PARCOD,CHOIX,TIT) From GESECRAN
    GSTATUT = status
    If status<>7 & CHOIX<>0
      VALEUR=PARCOD(CHOIX)
    Endif
Endif
End


Subprog S_PARVAL(VALEUR)
Variable Char    VALEUR()
Local Integer CHOIX, NBTEX, NBPARCOD, NBPARVAL
Local Integer WMAX : WMAX=30
Local Char TEXTE (100)(1..WMAX,1..2), parcod(20)(0..WMAX), PARVAL(20)(0..WMAX)  # Commence à zéro pour SAITEX si 1 colonne
Local Char TIT(50)(1..3) 
Local Char WCURPAR : WCURPAR=[AYU1]PARCOD(nolign-1)  
Gosub LSTPAR
If NBPARVAL>0
    CHOIX = find(VALEUR,PARVAL(1..NBPARVAL))
    If CHOIX=0 : CHOIX=1 : Endif
    Call SAITEX(NBPARVAL,PARVAL,CHOIX,TIT) From GESECRAN
    GSTATUT = status
    If status<>7 & CHOIX<>0
      VALEUR=PARVAL(CHOIX)
    Endif
Endif
End

Subprog C_PARVAL(VALEUR)
Variable Char    VALEUR()
Local Integer NBPARCOD, NBPARVAL
Local Integer WI, WMAX : WMAX=30
Local Char TEXTE (100)(1..WMAX,1..2), parcod(20)(0..WMAX), PARVAL(20)(0..WMAX)  # Commence à zéro pour SAITEX si 1 colonne
Local Char WCURPAR : WCURPAR=[AYU1]PARCOD(nolign-1) 
Gosub LSTPAR
If  NBPARVAL>0 
    For WI=1 To NBPARVAL
        PARVAL(WI)=toupper(PARVAL(WI))
    Next
    If !find(toupper(VALEUR), PARVAL(1..NBPARVAL))
        Call MESSAGE(mess(201,7900,1)) From GESECRAN
    Endif
Endif
End


######################################################################################
# Gestion des paramètres supportés - Nota: pas d'obligation
$LSTPAR
# Menu 7910
Case [M:AYU1]OBJTYP  
When 2     # Site
    NBPARCOD+=1 : PARCOD(NBPARCOD)="siteEnableTips": Gosub ADDBOOLVAL
When 3     # Page
When 4     # Profil
When 5     # Champ
When 6     # Entité
When 7     # Bloc
When 8     # Bloc cond.il
When 9     # Action
    NBPARCOD : PARCOD(NBPARCOD)="actX3ObjOther"
    If WCURPAR=toupper(PARCOD(NBPARCOD))
        PARVAL(NBPARVAL)="KEY" : NBPARVAL+=1 : PARVAL(NBPARVAL)="XML" : NBPARVAL+=1
    Endif
When 10    # DLK
    NBPARCOD+=1 : PARCOD(NBPARCOD)="dlkActProcessResult" : Gosub ADDBOOLVAL
    # NBPARCOD+=1 : PARCOD(NBPARCOD)="Test" : Gosub ADDBOOLVAL
When 11    # Elt. Spé
When 12    # Message
When 13    # Interface
When 14    # Par. avancé
When 14    # Menu
Endcase
Return

$ADDBOOLVAL
If WCURPAR=toupper(PARCOD(NBPARCOD))
    NBPARVAL+=1 : PARVAL(NBPARVAL)="true" : NBPARVAL+=1 : PARVAL(NBPARVAL)="false"
Endif
Return


######################################################################################
Subprog IB_OBJCOD
Case [M]OBJTYP
 When 3
  GBIDC1 ="AYG"
 When 4
  GBIDC1 ="AYD"
 When 5
  GBIDC1 ="AYF"
 When 6
  GBIDC1 ="AYE"
 When 7
  GBIDC1 ="AYB"
 When 8
  GBIDC1 ="AYW"
 When 9
  GBIDC1 ="AYA"
 When 10
  GBIDC1 ="AYL"
 When 11
  GBIDC1 ="AYX"
 When 12
  GBIDC1 ="AYM"
 When 13
  GBIDC1 ="AYE"
 When 14
  GBIDC1 ="AYG"
 When 15
  GBIDC1 ="AYC"
 When Default
  Raz GBOUT1
Endcase
End


