#<AdxTL>@(#)36.0.0.0 $Revision$
#######################################################
# subprog SELITU (ARTCLI,CLI,ART)
#      fenêtre de sélection art à partir référence art. chez le client
#
# subprog SELITU2 (ART,CLI)
#      fenêtre de sélection art à partir référence art
#
#######################################################
# Subprog SELITU(ARTCLI,CLI,ART)
#######################################################
Local Char ARTCLI
Local Char CLI
Local Char ART
ARTCLI=""
ART=""
CLI=""
Call SELITU(ARTCLI,CLI,ART)
End

Subprog SELITU(ARTCLI,CLI,ART)
Variable Char ARTCLI
Value    Char CLI
Value    Char ART

Gosub SEL_ITU
End

#######################################################
# Subprog SELITU2(ART,CLI)
#######################################################
Subprog SELITU2(ART,CLI)
Variable Char ART
Value    Char CLI
Local    Char ARTCLI

Gosub SEL_ITU
End

#######################################################
$SEL_ITU
Local Integer RELIT
Onerrgo ERREUR From CONTROLE
If clalev([F:ITU])=0
 Local File ITMBPC [ITU]
Else
 RELIT=1
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char CRIT2(50) : CRIT2="1=1"
$CHOOS
# Articles référencés pour le client
If ART = ""
   Choose [ITU] Where (BPCNUM=CLI) & evalue(CRIT2)
&  Order By Key ITU1
&  Using [F:ITU]ITMREF Titled mess(27,159,1),
&        [F:ITU]ITMREFBPC Titled mess(28,159,1),
&        [F:ITU]ITMDESBPC Titled mess(29,159,1)
&  Sized(96,297) Titled mess(30,159,1)
&  Starting At BPCNUM>=CLI 
Else
   Choose [ITU] Where (BPCNUM=CLI) & (ITMREF=ART) & evalue(CRIT2)
&  Order By Key ITU1 
&  Using [F:ITU]ITMREFBPC Titled mess(28,159,1),
&        [F:ITU]ITMDESBPC Titled mess(29,159,1)
&  Sized(40,213) Titled mess(30,159,1)  
&  Starting At BPCNUM>=CLI
Endif

If status=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=2
Elsif status=GSTASRA
 Gosub CRIT_CHOOS : Goto CHOOS
Elsif status<>7
 If !clalev([M:SOI1]) : ART=[F:ITU]ITMREF : Endif
 ARTCLI=[F:ITU]ITMREFBPC
#If RELIT : Read [ITU]ITU1 = CLI;ARTCLI : Endif
Else
 mkstat=2
Endif
Return

#---------------------------------------#
# Traitement de la sélection rapide     #
#---------------------------------------#
$CRIT_CHOOS

Local Char    VALCHP(30)
Local Integer K

CRIT2  = "1=1"

VALCHP = [F:ITU]ITMREF

Repeat
    K = instr(1,VALCHP,'"')
    If K : VALCHP = left$(VALCHP,K-1)+right$(VALCHP,K+1) : Endif
Until K=0

If VALCHP<>""
    CRIT2 -= "&" 
    If instr(1,VALCHP,"*") or instr(1,VALCHP,"?")
        CRIT2 -= 'pat([F:ITU]ITMREF,"'+VALCHP+'")'
    Else
        CRIT2 -= '[F:ITU]ITMREF >="'+VALCHP+'"'
    Endif
Endif

Return

