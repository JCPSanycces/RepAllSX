#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
#  table ASHWLNK, initialise the field ANCLNK from TARLNK
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Initialise field ANCLNK in table ASHWLNK") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#Gosub MAJTAB
End



#----------------------------------------------------------------------------------------#
$MAJTAB

Local Integer OPEN_FILE_KO
Raz OPEN_FILE_KO

Onerrgo FILE_OPEN_ERR
If DOSSIER=nomap
 Local File ASHWLNK [ASWK]
 Local File ASHWEXPPRO [ASWR]
Else
 Local File =DOSSIER+".ASHWLNK" [ASWK]
 Local File =DOSSIER+".ASHWEXPPRO" [ASWR]
Endif
Onerrgo

If OPEN_FILE_KO : Return : Endif

If dim([F:ASWK]ANCLNK)<0 or dim([F:ASWK]TARLNK)<0
 Return
Endif

Trbegin [ASWK]
For [ASWK] Where TARLNK <> "" and ANCLNK = ""
 Case [F:ASWK]AFFLNK
  When 1:
   Read[ASWR]ASWR0 = [F:ASWK]CODREP; [F:ASWK]TARLNK
   If !fstat and [F:ASWR]CODPRO <> ""
    [F:ASWK]ANCLNK = [F:ASWR]CODPRO
    Rewrite [ASWK]
   Endif
  When 2,3:
   [F:ASWK]ANCLNK = [F:ASWK]TARLNK
   Rewrite [ASWK]
 Endcase
Next
Commit

Close Local File [ASWK],[ASWR]
Return


$FILE_OPEN_ERR
 OPEN_FILE_KO = 1
Resume
