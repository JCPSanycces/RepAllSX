#<AdxTL>@(#)6.0.0.0 $Revision$
######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()

Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
Local Integer ICOUNT
Local Integer IAFFOK
Local Char SZMESS

  #----------------------------------------------------------------
  #   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
  #   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
  #----------------------------------------------------------------
  Gosub OUVRE 
  If GERREUR Then
    GERREUR = 0
    End
  Endif 
  Gosub DECLARE 
  For I = 1 To NBPAR
    J = instr(1,[L]PARAMETRE(I),"=")
    If J Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
        When "X3ETA"           : [L]ETAT = [L]VALEUR
        When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
        When "numedt"          : [L]PARAMETRE(I) = "numedt="  +num$([L]NUMREQ)
        When "nbcll"           : Gosub CPTNBCLL
        When "numscript"       : SZSCRIPT = [L]VALEUR
      Endcase
    Endif
  Next
  #Optimisation performances
  IPERF = 0
  IPBL = 0
  INTR = 0
  #Jauge
  SZMESS = mess(392,196,1)  #Préparation des données
  Gosub MAKESCPREP
End

#####################################################
# Calcul le nombre d'appels
#####################################################
$CPTNBCLL
  Call TEMPON("F") From GESECRAN
  INBCLL = 0
  Filter [SCA] Where [F:SCA]SCP = SZSCRIPT and [F:SCA]CLL <> "" Order By [F:SCA]CLL Asc
  For [SCA]
    If !INBCLL Then
      SZCLLCOD = [F:SCA]CLL
      INBCLL += 1
    Else
      If [F:SCA]CLL <> SZCLLCOD Then
        SZCLLCOD = [F:SCA]CLL
        INBCLL += 1
      Endif
    Endif
  Next
  Filter [SCA]
  [L]PARAMETRE(I) = "nbcll=" + num$(INBCLL)
  Call TEMPOFF From GESECRAN
Return

#####################################################
# Préparation des réponses
#####################################################
$MAKESCPREP
  IPERF = 0
  IPBL = 0
  INTR = 0
  INBCLL = 0
  Filter [SCA] Where [F:SCA]SCP = SZSCRIPT
  For [SCA]
    INBCLL += 1
  Next
  Filter [SCA]
  If !GINTRA Then
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, INBCLL) From GESECRAN
  Endif
  Filter [SCA] Where [F:SCA]SCP = SZSCRIPT Order By [F:SCA]QST Asc
  For [SCA]
    If IPERF = 0 Then
      Call DEBTRANS From GLOCK 
      Trbegin [SCA]
      INTR = 1
    Endif
    Case [F:SCA]ASWTYP
      When 2
        [F:SCA]ASWALH = num$([F:SCA]ASWNUM)
      When 3
        If [F:SCA]ASWDAT = [00/00/00] Then
          [F:SCA]ASWALH = mess(26,197,1) #Indéterminé
        Else
          IDAYCTL = day([F:SCA]ASWDAT)
          If IDAYCTL = 0 Then
            SZDAYCTL = "00"
          Else
            If IDAYCTL < 10 Then
              SZDAYCTL = '0' + num$(IDAYCTL)
            Else
              SZDAYCTL = num$(IDAYCTL)
            Endif
          Endif
          IMONCTL = month([F:SCA]ASWDAT)
          If IMONCTL = 0 Then
            SZMONCTL = "00"
          Else
            If IMONCTL < 10 Then
              SZMONCTL = '0' + num$(IMONCTL)
            Else
              SZMONCTL = num$(IMONCTL)
            Endif
          Endif
          If GLANGUE = "FRA" Then
            [F:SCA]ASWALH = SZDAYCTL - month$([F:SCA]ASWDAT) - num$(year([F:SCA]ASWDAT))
          Else
            [F:SCA]ASWALH = month$([F:SCA]ASWDAT) + ',' - SZDAYCTL + ',' - num$(year([F:SCA]ASWDAT))
          Endif
        Endif
      When 4
        Call GET_LIBM(1, [F:SCA]ASWBOL, GLANGUE, [F:SCA]ASWALH) From CRM_UTIL
    Endcase
    Rewrite [SCA]
    If fstat Then
      IPBL = 1
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Rollback
      INTR = 0
      Break
    Else
      If IPERF >= 1000 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
    If !GINTRA Then
      ICOUNT += 1
      Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
  Next
  Filter [SCA]
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
Return

########################################################################################### 
$OUVRE 
  If !clalev([F:SCA]) : Local File SCPASW [SCA] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
Return 
 
########################################################################################### 
$DECLARE 
Local Char    PARAM(30),VALEUR(30),ETAT(GLONARP)
Local Integer NUMREQ 
Local Integer INBCLL
Local Char SZSCRIPT
Local Integer IMONCTL
Local Char SZMONCTL
Local Integer IDAYCTL
Local Char SZDAYCTL
Local Char SZCLLCOD

  SZDAYCTL = ""
  IDAYCTL = 0
  SZMONCTL = ""
  IMONCTL = 0
  SZSCRIPT = ""
  INBCLL = 0
  SZCLLCOD = ""
Return
