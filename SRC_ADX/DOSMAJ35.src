#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################################
# DOSMAJ35 : Mises à jour à effectuer lors du passage à la version 160 (Release 35)
# moulinette avant la version V6.5
#################################################################################
# moulinette avant la Release 35 si necessaire
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

###########################################
# MOULINETTE EN AVANT maj
############################################
If left$(WVERSION,3) = "1.6"

Endif

Onerrgo
End

###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH, ZOK
WPATCH = 0
ZOK=0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif


###########################################
# module tronc commun
# pas de test du module
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 19
         Call UTI_MOUL([F:ADS]DOSSIER) From UTIMAJALDNUMTEX
      Endif
      If WPATCH < 20
         Call UTI_MOUL([F:ADS]DOSSIER) From UTIMAJPOSCOD
         Call UTI_MOUL([F:ADS]DOSSIER) From UTIMAJTCYUPP
         Call UTI_MOUL([F:ADS]DOSSIER) From UTIMAJBPABPABID
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITC38
      Endif
      If WPATCH < 30
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITC62   # FGR 29/07/2014 : X3SUIVI100229
      Endif
  Endif
Endif

###########################################
# module tiers
###########################################
If left$(WVERSION,3) = "1.6"
    If WPATCH < 18
      If [F:ADS]MODULE(2)= 2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
       Call UTI_MOUL([F:ADS]DOSSIER) From UTITRS007
      Endif
    Endif
Endif

###########################################
# module immos -
############################################
If left$(WVERSION,3) = "1.6"
    If [F:ADS]MODULE(13) = 2
        If WPATCH < 19
           Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM034
        Endif
    Endif
Endif

###########################################
# module ventes
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
          If WPATCH < 19
             Call UTI_MOUL([F:ADS]DOSSIER) From UTIVEN14
          Endif
  Endif
Endif

###########################################
# MODUL Manufacturing
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 107012 - 2015-09-17 by BEEBE : To be checked
  If left$(WVERSION,3) = "1.6"
     If [F:ADS]MODULE(6)=2
      Endif
     If WPATCH < 34
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA47  # Issue 107012 - 2015-09-17 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
     Endif
  Endif
Endif

###########################################
# module compta
############################################
If left$(WVERSION,3) = "1.6"
   If [F:ADS]MODULE(1)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
       If WPATCH < 18
            Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT52
       Endif
    Endif
Endif
###########################################
# module CRM
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 30
         Call UTI_MOUL([F:ADS]DOSSIER) From UTICRM013   # FGR 31/07/2014 : X3SUIVI100463
      Endif
  Endif
Endif

###########################################
# module Stock
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 31
         Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO23  # Issue 100246 - 2015-03-05 by CCC : Valuation report with accounting date
      Endif
  Endif
Endif

Onerrgo
End
###################################################################################
###################################################################################
###################################################################################
$ERREUR
Call ECR_TRACE(errp-"("+num$(errl)+")"-mess(6,123,1)-":"-num$(errn)-errmes$(errn)-errm,1) From GESECRAN
# Erreur
Resume

