#<AdxTL>@(#)5.0.0.0 $Revision$
#------------------------------------------------------------------------#
# Sous_programmes
#------------------------------------------------------------------------#

#------------------------------------------------------------------------#
# En-tûˆte de boûÛte
#------------------------------------------------------------------------#

$BOX
If AOB_NBRSCR
 Wrseq " ";
Endif
Case AWI_GLO
 When 0       : Wrseq 'Local ';
 When Default : Wrseq 'Global ';
Endcase
Case AWI_BOU
 When 0       : Wrseq 'Mesbox ';
 When Default : Wrseq 'Inpbox ';
Endcase
Wrseq '"'+FENETRE+'" From GFONCTION At A_STAMP ';
If FENETRE<>"CALCULETTE"
 Wrseq 'With A_WINDPREV ';
Endif
Wrseq 'Mask ['+CHAINE+"]"
Return

#------------------------------------------------------------------------#
# Onglets
#------------------------------------------------------------------------#

$ONGLETS
For I=2 To AWI_NBRMSK
 If K=0
  Wrseq '&   ';
 Else
  Wrseq '& , ';
 Endif
 K += 1
 If AWI_FLGMSK(I)=2
  Wrseq 'Folder Mask ['+AWI_ABRMSK(I)+']'
 Else
  Wrseq 'Invfol Mask ['+AWI_ABRMSK(I)+']'
 Endif
Next I
Return

$ONGLETS_SUP
For I=1 To AOB_NBRSCR
 If K=0
  Wrseq '&   ';
 Else
  Wrseq '& , ';
 Endif
 K += 1
 Wrseq 'Folder Mask ['+AOB_ABRSCR(I)+']'
Next I
Return

#------------------------------------------------------------------------#
# Description listes de gauche
#------------------------------------------------------------------------#

$LISTE_GAUCHE
If AWB_NBSEL(L)<>0
 Gosub SETCLE
 If AWB_NUM(L)="9"
  Gosub LISTE_DERLU
 Else
  Case AWB_TRE(L)
   When 1,5
    Gosub LISTE_SIMPLE
   When 2,3
    Gosub LISTE_HIERA
   When 4
    Gosub LISTE_RECUR
  Endcase
 Endif
Endif
Return

$SETCLE
Raz CLES, NBCLES , SNSCLES
If AWB_FIC(L)=""
 NBCLES = AWB_NBSEL(L)
Else
 CHAINE = AWB_IND(L)
 SNSCLES(1) = "+"
 While CHAINE<>""
  NBCLES += 1
  X = instr(1,CHAINE,"+")
  Y = instr(1,CHAINE,"-")
  If X & Y
   If X<Y
    SNSCLES(NBCLES+1) = "+"
   Else
    SNSCLES(NBCLES+1) = "-"
    X = Y
   Endif
  Elsif Y
   SNSCLES(NBCLES+1) = "-"
   X = Y
  Elsif X
   SNSCLES(NBCLES+1) = "+"
  Endif
  If X
   CLES(NBCLES) = left$(CHAINE,X-1)
   CHAINE = right$(CHAINE,X+1)
  Else
   CLES(NBCLES) = CHAINE
   CHAINE = ""
  Endif
 Wend
Endif
Return

#------------------------------------------------------------------------#

$LISTE_SIMPLE
If AWB_TRE(L)=5
 CHAINE = "Leftbox"
Else
 CHAINE = "Listbox"
Endif
If AWB_ABB(L)<>""
 Wrseq '&  '+CHAINE+' ['+AWB_ABB(L)+'] GAU_CHE'+AWB_NUM(L)
Elsif AWB_FCY(L)<>"" | AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'_] GAU_CHE'+AWB_NUM(L)
Else
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'] GAU_CHE'+AWB_NUM(L)
Endif
For I=1 To AWB_NBSEL(L)
 If AWB_SELFIC(I,L)<>""
  Wrseq '&   [L]SAIRAP('+num$(I)+') = ';
  If AWB_SELZON(I,L)=FLDTXT(L)
   Wrseq '[F:ATX]TEXTE Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Elsif AWB_SELNOLIB(I,L)<>0
   Wrseq 'mess([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+'(0),'+num$(AWB_SELNOLIB(I,L))+',1) ';
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Else
   Wrseq '[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+' ';
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Endif
 Else
  Wrseq '&   [L]SAIRAP('+num$(I)+') = ';
  Wrseq vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2)+' ';
  Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
 Endif
 If I<>AWB_NBSEL(L) : Wrseq " ,"; : Endif
 Wrseq
Next I
Return

#------------------------------------------------------------------------#

$LISTE_HIERA
If AWB_TRE(L)=2
 CHAINE = "Treebox"
Else
 CHAINE = "Pickbox"
Endif
If AWB_ABB(L)<>""
 Wrseq '&  '+CHAINE+' ['+AWB_ABB(L)+'] GAU_CHE'+AWB_NUM(L)
Elsif AWB_FCY(L)<>"" | AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'_] GAU_CHE'+AWB_NUM(L)
Else
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'] GAU_CHE'+AWB_NUM(L)
Endif
For I=1 To NBCLES-1
 If AWB_SELFIC(I,L)<>""
  If AWB_SELZON(I,L)=FLDTXT(L)
   Wrseq '&   [F:ATX]TEXTE Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Elsif AWB_SELTYPTYP(I,L)=8
   Wrseq '&   format$("D:'+GFMDAT4+'",'+AWB_SELZON(I,L)+') ';
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Elsif AWB_SELNOLIB(I,L)<>0
   Wrseq '&   mess([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+'(0),'+num$(AWB_SELNOLIB(I,L))+',1) ';
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Else
   Wrseq '&   [F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L);' ';
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Endif
 Else
  Wrseq '&   '+vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2);' ';
  Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
 Endif
 Wrseq " ,";
 Wrseq
Next I
K = 0
For I=max(1,NBCLES) To max(NBCLES,AWB_NBSEL(L))
 If K
  Wrseq '&   +" "+';
 Else
  Wrseq '&   '; : K = 1
 Endif
 If AWB_SELFIC(I,L)<>""
  If AWB_SELZON(I,L)=FLDTXT(L)
   Wrseq '[F:ATX]TEXTE'
  Elsif AWB_SELTYPTYP(I,L)=8
   Wrseq 'format$("D:'+GFMDAT4+'",'+AWB_SELZON(I,L)+')'
  Elsif AWB_SELNOLIB(I,L)<>0
   Wrseq 'mess([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+'(0),'+num$(AWB_SELNOLIB(I,L))+',1)'
  Else
   Case AWB_SELTYPTYP(I,L)
    When 2       : Wrseq 'format$("N:5#",[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
    When 3       : Wrseq 'format$("N:8#",[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
    When 7       : Wrseq '[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)
    When Default : Wrseq 'num$([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
   Endcase
  Endif
 Elsif AWB_SELEXP(I,L)<>""
  Case AWB_SELTYPTYP(I,L)
   When 2,3,4,5,6,8 : Wrseq "num$("+vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2)+")"
   When Default     : Wrseq vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2)
  Endcase
 Else
  Wrseq '""'
 Endif
Next I
Wrseq '&   Titled ""'
Return

#------------------------------------------------------------------------#

$LISTE_RECUR
CHAINE = "Treebox"
If AWB_ABB(L)<>""
 Wrseq '&  '+CHAINE+' ['+AWB_ABB(L)+'] GAU_CHE'+AWB_NUM(L)
Elsif AWB_FCY(L)<>"" | AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'_] GAU_CHE'+AWB_NUM(L)
Else
 Wrseq '&  '+CHAINE+' ['+AWB_ABR(L)+'] GAU_CHE'+AWB_NUM(L)
Endif
K = 0
For I=1 To AWB_NBSEL(L)
 If K
  Wrseq '&   +" "+';
 Else
  Wrseq '&   '; : K = 1
 Endif
 If AWB_SELFIC(I,L)<>""
  If AWB_SELTYPTYP(I,L)=8
   Wrseq 'format$("D:'+GFMDAT4+'",'+AWB_SELZON(I,L)+')'
  Elsif AWB_SELNOLIB(I,L)<>0
   Wrseq 'mess([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+'(0),'+num$(AWB_SELNOLIB(I,L))+',1)'
  Else
   Case AWB_SELTYPTYP(I,L)
    When 2       : Wrseq 'format$("N:5#",[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
    When 3       : Wrseq 'format$("N:8#",[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
    When 7       : Wrseq '[F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)
    When Default : Wrseq 'num$([F:'+AWB_SELABR(I,L)+']'+AWB_SELZON(I,L)+")"
   Endcase
  Endif
 Else
  Case AWB_SELTYPTYP(I,L)
   When 2,3,4,5,6,8 : Wrseq "num$("+vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2)+")"
   When Default     : Wrseq vireblc(format$("KT:250X",AWB_SELEXP(I,L)),2)
  Endcase
 Endif
Next I
Wrseq '&   Titled ""'
If AWB_OBJ(L)="ALI"
 Wrseq '&   With [ALI_]ALI0(3) = GLIAISON;[F:ALI]DSTOBJ;[F:ALI]DSTKEY'
Else
 Wrseq '&   With ['+AWB_ABR(L)+']'+AWB_CLE(L)+' = '+AWB_EXP(L)
Endif
Return

#------------------------------------------------------------------------#

$LISTE_DERLU
CHAINE = "Listbox"
Wrseq '&  '+CHAINE+' ['+ATB_ABR+mid$("123456789ABCDEF",val(AWB_NUM(L)),1)+'] GAU_CHE'+AWB_NUM(L)
Raz J, K
For I=1 To AWB_NBSEL(L)
 If J = 1 : Wrseq " ," : Else : J = 1 : Endif
 If AWB_SELFIC(I,L)<>""
  Wrseq '&   [L]SAIRAP('+num$(I)+') = ';
  If AWB_SELFIC(I,L)=ATB_FIC & AWB_SELZON(I,L)=FLDTXT(L)
   Wrseq '[F:'+ATB_ABR+mid$("123456789ABCDEF",val(AWB_NUM(L)),1)+']A_TAB'+num$(K+1)+' '; : K += 1
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Elsif AWB_SELNOLIB(I,L)<>0
   Wrseq 'mess([F:'+ATB_ABR+mid$("123456789ABCDEF",val(AWB_NUM(L)),1)+']A_TAB'+num$(K+1)+','+num$(AWB_SELNOLIB(I,L))+',1) '; : K += 1
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
  Else
   Wrseq '[F:'+ATB_ABR+mid$("123456789ABCDEF",val(AWB_NUM(L)),1)+']A_TAB'+num$(K+1)+' '; : K += 1
   Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+') ';
  Endif
 Else
  Wrseq '&   [L]SAIRAP('+num$(I)+') = ';
  Wrseq '[F:'+ATB_ABR+mid$("123456789ABCDEF",val(AWB_NUM(L)),1)+']A_TAB'+num$(K+1)+' '; : K += 1
  Wrseq 'Using '+AWB_SELFOR(I,L)+' Titled TITSEL'+AWB_NUM(L)+'('+num$(I)+')';
 Endif
Next I
Wrseq
Return

#------------------------------------------------------------------------#
# Link û  l'ouverture de la boûÛte
#------------------------------------------------------------------------#

$WRLINK
J = 0
If FLDTXT(L)<>"" and OKTXT=0
 Wrseq space$(SPA);"If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif"
 OKTXT = 1
Endif
If AWB_ACC(L)<>"" and OKACC=0
 Wrseq space$(SPA);"If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif"
 OKACC = 1
Endif
If AWB_FCY(L)<>"" and OKFCY=0
 Wrseq space$(SPA);"If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif"
 Wrseq space$(SPA);"If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif"
 OKFCY = 1
Endif
If !find(AWB_NUM(L),"","9") & AWB_FIC(L)<>"" & !find(AWB_ABR(L),"","ALI")
 Wrseq space$(SPA);"If clalev([F:"+AWB_ABR(L)+"])=0 ";
 Wrseq ": Local file"-AWB_FIC(L)-"["+AWB_ABR(L)+"] : Endif"
Endif
For I=1 To AWB_NBFIC(L)
 If AWB_EXPLNK(I,L)<>"" & AWB_OBLLNK(I,L)
  Wrseq space$(SPA);"If clalev([F:"+AWB_ABRLNK(I,L)+"])=0 ";
  Wrseq ": Local file"-AWB_FICLNK(I,L)-"["+AWB_ABRLNK(I,L)+"] : Endif"
 Endif
Next
# Pour forcer un link si une abrûˋviation est dûˋfinie dans le browser
If AWB_ABB(L)<>"" & AWB_FCY(L)="" & AWB_ACC(L)="" & FLDTXT(L)="" & sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))=0
 Wrseq "If clalev([F:"+left$(AWB_ABR(L),1)+"_"+right$(AWB_ABR(L),2)+"])=0 ";
 Wrseq ": Local file"-AWB_FIC(L)-"["+left$(AWB_ABR(L),1)+"_"+right$(AWB_ABR(L),2)+"] : Endif"
Endif
If AWB_ABR(L)="ALI"
 Wrseq space$(SPA);"If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif"
 Wrseq space$(SPA);"If clalev([F:ALI_])=0" : SPA += 1
Endif
Wrseq space$(SPA);"Link ["+AWB_ABR(L)+"] With";
If FLDTXT(L)<>""
 Wrseq
 Wrseq "& [ATX]NUMERO=GLANGUE;"+FLDTXT(L); : J += 1
Endif
If AWB_ACC(L)<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [ACC]CODACC=GUSER;[F:"+AWB_ABR(L)+"]"+AWB_ACC(L); : J += 1
Endif
If AWB_FCY(L)<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [AFF]AFF0~=[F:"+AWB_ABR(L)+"]"+AWB_FCY(L)+";GPROFIL;GUSRFCT," : J += 1
 Wrseq "& [FGR]FGR0=GGRPFCY;[F:"+AWB_ABR(L)+"]"+AWB_FCY(L); : J += 1
Endif
For I=1 To AWB_NBFIC(L)
 If J<MAXLNK & AWB_EXPLNK(I,L)<>"" & AWB_OBLLNK(I,L)
  If J : Wrseq "," Else Wrseq : Endif
  CHAINE = vireblc(format$("KT:250X",AWB_EXPLNK(I,L)),2)
  Wrseq "& ["+AWB_ABRLNK(I,L)+"]"+AWB_CLELNK(I,L)+"="+CHAINE; : J += 1
 Endif
Next I
If AWB_ABB(L)<>"" & AWB_FCY(L)="" & AWB_ACC(L)="" & FLDTXT(L)="" & sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))=0
 If J<MAXLNK
  If J : Wrseq "," Else Wrseq : Endif
  Wrseq "& ["+left$(AWB_ABR(L),1)+"_"+right$(AWB_ABR(L),2)+"]"+AWB_CLE(L)+" = ";
  Gosub SETCLE
  For I=1 To NBCLES
   Wrseq "[F:"+AWB_ABR(L)+"]"+CLES(I);
   If I<NBCLES : Wrseq ";"; : Endif
  Next I
  J += 1
 Endif
Endif
Wrseq
If AWB_ABB(L)<>""
 Wrseq "& As ["+AWB_ABB(L)+"]"
Else
 Wrseq "& As ["+AWB_ABR(L)+"_]"
Endif
If AWB_TRE(L)>=2 & AWB_TRE(L)<>4 : # Hiûˋrarchisûˋe/Picking/Picking simple (rûˋcursive => pas d'order by)
 If AWB_CLE(L)<>""
  If AWB_ORD(L)=2 : # Descendant
   Wrseq "& Order By Key "+AWB_CLE(L)+" Desc"
  Else
   Wrseq "& Order By Key "+AWB_CLE(L)
  Endif
 Endif
Endif
If AWB_ABR(L)="ALI"
 SPA -= 1 : Wrseq space$(SPA);"Endif"
Endif
Return

#------------------------------------------------------------------------#
# Actions sur boutons spûˋciaux
#------------------------------------------------------------------------#

$EXEBOUT1
If FLGOK
 Wrseq space$(SPA)+"OK = 1"
 Wrseq space$(SPA)+'ACTION = "AVANT_SUITE" : Gosub ACTION From =GPROGRAMME'
 Wrseq space$(SPA)+"If OK"
 SPA += 1
Endif
If ACT_TYP(A)=8 : # Traitement divers
 Wrseq space$(SPA)+'FLGEXE = 1'
 Gosub GENBOUT
Elsif ACT_TYP(A)<>len(mess(0,81,1))
 Wrseq space$(SPA)+"Local Char VALBOUT(250) , PARBOUT(250)(1.."+num$(MAXPAR)+")"
 For J=1 To MAXPAR
  If PAR_COD(A,J)<>""
   CHAINE = PAR_VAL(A,J)
   Case PAR_TYP(A,J)
    When 1,6
     If CHAINE="" : CHAINE = '""' : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = "+vireblc(format$("KT:80X",CHAINE),2)
    When 4
     If CHAINE="" : CHAINE = "[00/00/0000]" : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = "+vireblc(format$("KT:80X",CHAINE),2)
    When Default
     If CHAINE="" : CHAINE = '"0"' : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = num$("+vireblc(format$("KT:80X",CHAINE),2)+")"
   Endcase
  Endif
 Next J
 Wrseq space$(SPA)+'FLGEXE = 1'
 Gosub GENBOUT
 For J=1 To MAXPAR
  If PAR_COD(A,J)<>""
   If PAR_ADR(A,J)=1 & PAR_VAL(A,J)<>"" & !find(PAR_VAL(A,J),'""',"''")
    Case PAR_TYP(A,J)
     When 1,4,6
      Wrseq space$(SPA)+vireblc(format$("KT:80X",PAR_VAL(A,J)),2)+" = PARBOUT("+num$(J)+")"
     When Default
      Wrseq space$(SPA)+vireblc(format$("KT:80X",PAR_VAL(A,J)),2)+" = val(PARBOUT("+num$(J)+"))"
    Endcase
   Endif
  Endif
 Next J
Endif
If FLGOK
 SPA -= 1
 Wrseq space$(SPA)+"Endif"
Endif
Return

#------------------------------------------------------------------------#
# Actions sur boutons standard
#------------------------------------------------------------------------#

$EXEACT1
If ACT_TYP(A)=8 : # Traitement divers
 Wrseq space$(SPA)+'FLGEXE = 1'
 Gosub GENBOUT
Else
 Wrseq space$(SPA)+"Local Char VALBOUT(250) , PARBOUT(250)(1.."+num$(MAXPAR)+")"
 For J=1 To MAXPAR
  If PAR_COD(A,J)<>""
   CHAINE = PAR_VAL(A,J)
   Case PAR_TYP(A,J)
    When 1,6
     If CHAINE="" : CHAINE = '""' : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = "+vireblc(format$("KT:80X",CHAINE),2)
    When 4
     If CHAINE="" : CHAINE = "[00/00/0000]" : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = "+vireblc(format$("KT:80X",CHAINE),2)
    When Default
     If CHAINE="" : CHAINE = '"0"' : Endif
     Wrseq space$(SPA)+"PARBOUT("+num$(J)+") = num$("+vireblc(format$("KT:80X",CHAINE),2)+")"
   Endcase
  Endif
 Next J
 If ACT_TYP(A)<>len(mess(0,81,1))
  Wrseq space$(SPA)+'FLGEXE = 1'
  Gosub GENBOUT
  For J=1 To MAXPAR
   If PAR_COD(A,J)<>""
    If PAR_ADR(A,J)=1 & PAR_VAL(A,J)<>"" & !find(PAR_VAL(A,J),'""',"''")
     Case PAR_TYP(A,J)
      When 1,4,6
       Wrseq space$(SPA)+vireblc(format$("KT:80X",PAR_VAL(A,J)),2)+" = PARBOUT("+num$(J)+")"
      When Default
       Wrseq space$(SPA)+vireblc(format$("KT:80X",PAR_VAL(A,J)),2)+" = val(PARBOUT("+num$(J)+"))"
     Endcase
    Endif
   Endif
  Next J
 Endif
Endif
Return

#------------------------------------------------------------------------#
# Dûˋtails des actions sur boutons
#------------------------------------------------------------------------#

$GENBOUT
Wrseq space$(SPA)+'GACTION = "'+ACT_COD(A)+'"'
Case ACT_TYP(A)
 When 1 : # Objet
  If ACT_TYA(A)=2
   Wrseq space$(SPA)+"Call OBJET_CHAR(VALBOUT,PARBOUT(1),PARBOUT(2)) From GOBJET"
  Else
   Wrseq space$(SPA)+"Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET"
  Endif
 When 2 : # Consultation
  Wrseq space$(SPA)+'Call CONSULT_CHAR(VALBOUT,"'+ACT_PAR1(A)+'",PARBOUT) From GCONSULT'
 When 3 : # Traitement
  Wrseq space$(SPA)+'Call TRAITE_CHAR(VALBOUT,PARBOUT,"'+ACT_PAR2(A)+'","'+ACT_TRT(A);
  If find(ACT_PAR3(A),5,6)
   Wrseq '","'+ACT_PAR5(A)+'",'+num$(ACT_PAR3(A))+',"'+ACT_SPE(A)+'") From GTRAITE'
  Else
   Wrseq '","'+ACT_PAR4(A)+'",'+num$(ACT_PAR3(A))+',"'+ACT_SPE(A)+'") From GTRAITE'
  Endif
 When 4 : # Saisie
  Wrseq space$(SPA)+'Call SAISIE_CHAR(VALBOUT,PARBOUT,"'+ACT_PAR2(A)+'","'+ACT_TRT(A);
  Wrseq '","'+ACT_SPE(A)+'") From GSAISIE'
 When 5 : # Sel liste
  Wrseq space$(SPA)+'Call S_LIS_CHAR(VALBOUT,PARBOUT,"'+ACT_PAR5(A)+'","'+ACT_TRT(A);
  Wrseq '","'+ACT_SPE(A)+'") From GACTION'
 When 6 : # Sel table
  Wrseq space$(SPA)+'Call S_TAB_CHAR(VALBOUT,PARBOUT,"'+ACT_PAR5(A)+'","'+ACT_TRT(A);
  Wrseq '","'+ACT_SPE(A)+'") From GACTION'
 When 7 : # Aff divers
  Wrseq space$(SPA)+'Call S_AFF_CHAR(VALBOUT,PARBOUT,"'+ACT_PAR5(A)+'","'+ACT_TRT(A);
  Wrseq '","'+ACT_SPE(A)+'") From GACTION'
 When 8 : # Trt divers
  If ACT_SUB(A)<>""
   Wrseq space$(SPA)+'Call '+ACT_SUB(A);
   For J=1 To ACT_NBP(A)
    If mod(J,8)=0
     Wrseq
     Wrseq "&"+space$(SPA);
    Endif
    If J=1
     Wrseq "(";
    Else
     Wrseq ",";
    Endif
    If PAR_COD(A,J)<>""
     CHAINE = PAR_VAL(A,J)
     Case PAR_TYP(A,J)
      When 1,6
       If CHAINE="" : CHAINE = '""' : Endif
      When 4
       If CHAINE="" : CHAINE = "[00/00/0000]" : Endif
      When Default
       If CHAINE="" : CHAINE = '"0"' : Endif
     Endcase
     Wrseq vireblc(format$("KT:80X",CHAINE),2);
    Else
     Wrseq '""';
    Endif
    If J=ACT_NBP(A) : Wrseq ")"; : Endif
   Next J
   Wrseq " From "+ACT_TRT(A)
  Endif
  If ACT_INS(A)<>""
   Gosub INSTRU
  Endif
Endcase
Return

#------------------------------------------------------------------------#

$INSTRU
If ACT_TYP(A)<>8 | ACT_INS(A)=""
 Return
Endif
CHAINE2 = space$(SPA)+vireblc(format$("KT:250X",ACT_INS(A)),2)
J = instr(1,CHAINE2,"%")
While J<>0
 If instr(1,"0123456789",mid$(CHAINE2,J+2,1))
  T = 2
 Else
  T = 1
 Endif
 K = val(mid$(CHAINE2,J+1,T))
 If K=0
  CHAINE2 = left$(CHAINE2,J-1)+'""'+right$(CHAINE2,J+T+1)
 Else
  If PAR_COD(A,J)<>""
   CHAINE = PAR_VAL(A,J)
   Case PAR_TYP(A,J)
    When 1,6
     If CHAINE="" : CHAINE = '""' : Endif
    When 4
     If CHAINE="" : CHAINE = "[00/00/0000]" : Endif
    When Default
     If CHAINE="" : CHAINE = '"0"' : Endif
   Endcase
   CHAINE2 = left$(CHAINE2,J-1)+vireblc(format$("KT:250X",CHAINE),2)+right$(CHAINE2,J+T+1)
  Else
   CHAINE2 = left$(CHAINE2,J-1)+'""'+right$(CHAINE2,J+T+1)
  Endif
 Endif
 J = instr(1,CHAINE2,"%")
Wend
Wrseq CHAINE2
Return

#------------------------------------------------------------------------#
# Remplissage des listes de gauche
#------------------------------------------------------------------------#

$WRREMPLIT
If find(AWB_TRE(L),1,5) & AWB_GES(L)<>3 & AWB_ABR(L)<>"ALI"
 Wrseq "Gosub SETCLE_"+AWB_NUM(L)
Endif
Wrseq "If dim(FILTREG)<=0 or FILTREG"
SPA = 1
Gosub WRFILTRE
Gosub WRORDRE
Wrseq "Endif"
Wrseq 'GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC' : # mb 24.9.2 demande 15851
Wrseq 'ACTION = "HINT" : Gosub ACTION From =GPROGRAMME'
If AWI_OBJ<>""
 If AWB_NUM(L)<>""
  Wrseq "If HINTLIS("+num$(AWB_NUM(L))+")<>'' or NOHLIS("+num$(AWB_NUM(L))+")<>0"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE"+AWB_NUM(L)+" Hint Key =HINTLIS("+num$(AWB_NUM(L))+")"
  Wrseq "Else"
  Wrseq " Gosub CALNOH From GOBJET"
  Wrseq " If A_NOH"
  Wrseq "  Fillbox ["+AWI_BOX+"] GAU_CHE"+AWB_NUM(L)
  Wrseq " Else"
  Wrseq "  Fillbox ["+AWI_BOX+"] GAU_CHE"+AWB_NUM(L)+' Hint Key =""'
  Wrseq " Endif"
  Wrseq "Endif"
 Else
  Wrseq "If HINTLIS(0)<>'' or NOHLIS(0)<>0"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE Hint Key =HINTLIS(0)"
  Wrseq "Else"
  Wrseq " Gosub CALNOHOBJ From GOBJET"
  Wrseq " If A_NOH"
  Wrseq "  Fillbox ["+AWI_BOX+"] GAU_CHE"
  Wrseq " Else"
  Wrseq '  Fillbox ['+AWI_BOX+'] GAU_CHE Hint Key =""'
  Wrseq " Endif"
  Wrseq "Endif"
 Endif
Else
 If AWB_NUM(L)<>""
  Wrseq "If HINTLIS("+num$(AWB_NUM(L))+")<>'' or NOHLIS("+num$(AWB_NUM(L))+")<>0"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE"+AWB_NUM(L)+" Hint Key =HINTLIS("+num$(AWB_NUM(L))+")"
  Wrseq "Else"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE"+AWB_NUM(L)
  Wrseq "Endif"
 Else
  Wrseq "If HINTLIS(0)<>'' or NOHLIS(0)<>0"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE Hint Key =HINTLIS(0)"
  Wrseq "Else"
  Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE"
  Wrseq "Endif"
 Endif
Endif
Wrseq 'GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC' : # mb 24.9.2 demande 15851
SPA = 0
Gosub WRFINFILTRE
Return

#------------------------------------------------------------------------#

$WRFILTRE
If AWB_NUM(L)=""
 Wrseq space$(SPA);'If CRITERE=""  : CRITERE  = "1=1" : Endif'
 Wrseq space$(SPA);'If FILTSUP=""  : FILTSUP  = "1=1" : Endif'
 Wrseq space$(SPA);'If FILROLE=""  : FILROLE  = "1=1" : Endif'
 Wrseq space$(SPA);'If FILSUITE="" : FILSUITE = "1=1" : Endif'
 If AWB_ABB(L)<>""
  Wrseq space$(SPA);"Filter ["+AWB_ABB(L)+"] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE)";
  Wrseq " & evalue(FILSUITE)"
 Elsif AWB_FCY(L)<>"" or AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
  Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE)";
  Wrseq " & evalue(FILSUITE)"
 Else
  Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE)";
  Wrseq " & evalue(FILSUITE)"
 Endif
Else
 Wrseq space$(SPA);'If CRITERE=""   : CRITERE   = "1=1" : Endif'
 Wrseq space$(SPA);'If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif'
 Wrseq space$(SPA);'If FILSUITE=""  : FILSUITE  = "1=1" : Endif'
 If AWB_ABB(L)<>""
  Wrseq space$(SPA);"Filter ["+AWB_ABB(L)+"] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)"
 Elsif AWB_FCY(L)<>"" or AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
  Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)"
 Else
  Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)"
 Endif
Endif
Return

#------------------------------------------------------------------------#

$WRFINFILTRE
If AWB_ABB(L)<>""
 Wrseq space$(SPA);"Filter ["+AWB_ABB(L)+"]"
Elsif AWB_FCY(L)<>"" or AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
 Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"_]"
Else
 Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"]"
Endif
Return

#------------------------------------------------------------------------#

$WRORDER
If AWB_ABB(L)<>""
 Wrseq space$(SPA);"Filter ["+AWB_ABB(L)+"]";
Elsif AWB_FCY(L)<>"" or AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
 Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"_]";
Else
 Wrseq space$(SPA);"Filter ["+AWB_ABR(L)+"]";
Endif
Wrseq " Order With CLELISTE"
Return

#---------------------------------------------------------------------------------------------------#
# mb 10.7.2 A ce jour, on ne peut pas modifier l'index d'une liste Hiûˋrarchisûˋe (picking ou pas)
#           L'index de remplissage est celui dûˋclarûˋ û  l'ouverture de la boûÛte
# mb 7.5.3  Pour les autres listes (sauf Principale, objet combinûˋ et liaison) on peut le modifier
#           en utilisant la variable CLELISTE (cle1 desc;cle2 desc; etc)
#---------------------------------------------------------------------------------------------------#

$WRORDRE
If AWB_ABR(L)="ALI"
 Wrseq "&";space$(SPA);"      Order By Key "+AWB_CLE(L)
Elsif AWB_GES(L)=3 : # Objet combinûˋ
 Gosub SETCLE
 Wrseq "&";space$(SPA);"      Order By Key "+AWB_CLE(L)+"("+num$(NBCLES-1)+")" ;
 Case AWB_ORD(L)
  When 2       : Wrseq " Desc"
  When Default : Wrseq
 Endcase
Elsif AWB_TRE(L)=4         : # Liste rûˋcursive => pas d'order by
Elsif find(AWB_TRE(L),1,5) : # Liste simple ou Picking simple
 Wrseq "&";space$(SPA);"      Order With CLELISTE"
Elsif AWB_ORD(L)=2
 Wrseq "&";space$(SPA);"      Order By Key "+AWB_CLE(L)+" Desc"
Elsif AWB_ABB(L)<>"" | (AWB_FCY(L)<>"" | AWB_ACC(L)<>"" | FLDTXT(L)<>"" | sum(AWB_OBLLNK(1..AWB_NBFIC(L),L)))
 Wrseq "&";space$(SPA);"      Order By Key "+AWB_CLE(L);
 Case AWB_ORD(L)
  When 2       : Wrseq " Desc"
  When Default : Wrseq
 Endcase
Else
 Wrseq space$(SPA);"[G:"+AWB_ABR(L)+"]currind = "+num$(AWB_NOI(L))
 Wrseq space$(SPA);"[G:"+AWB_ABR(L)+"]currlen = 0"
Endif
Return

#------------------------------------------------------------------------#

$WRSETCLE
Wrseq "Local Char    CLELISTE(250)"
Wrseq "Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS"
If AWB_FIC(L)<>""
 Wrseq "INDLIS = "+num$(AWB_NOI(L))
 Wrseq "SNSLIS = "+num$(AWB_ORD(L))
 Gosub SETCLE
 If AWB_GES(L)=3 : # Objet combinûˋ
  J = NBCLES-1
 Else
  J = NBCLES
 Endif
 Wrseq "LENLIS = "+num$(J)
 # Issue 86155 - 2013-01-14 by VPO : gestion liste hierarchisûˋe
 Wrseq "GAUTRELIS = "+num$(AWB_TRE(L))
 CHAINE = ""
 For I=1 To J
  If CHAINE<>"" : CHAINE += ";" : Endif
  CHAINE += CLES(I)
  If (AWB_ORD(L)=2 & SNSCLES(I)="+") or (AWB_ORD(L)=1 & SNSCLES(I)="-")
   CHAINE -= "Desc"
  Endif
 Next I
 Wrseq 'CLELISTE = "'+CHAINE+'"'
Endif
Wrseq 'ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME'
Return

#------------------------------------------------------------------------#

$WRGRISE
If CLEGEO=""
 Wrseq CLEPRIM;
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & (AOB_GES<>3 | I<>NBCLE-2)
   Wrseq ","+CLESEC(I);
  Endif
 Next I
 Wrseq
Else : ## GEODE
 K = 0
 If !find(CLEPRIM,CLEFCY,CLEDEP)
  Wrseq CLEPRIM; : K = 1
 Endif
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & (AOB_GES<>3 | I<>NBCLE-2) & !find(CLESEC(I),CLEFCY,CLEDEP)
   If K : Wrseq ","+CLESEC(I);
   Else : Wrseq CLESEC(I); : K = 1
   Endif
  Endif
 Next I
 Wrseq
Endif
Return
