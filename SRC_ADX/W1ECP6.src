#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:06"
A_USER  = "DOC"
A_STAMP = "20181109230406"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRSAL"
  If [M]NBRSAL=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ECP6 [ECP6]
Gosub HORODAT
Local Inpbox "ECP6" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP6] As [SIM_]
Grizo [ECP6]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ECP6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=22
Return

$ON_NBRSAL
Onevent BEFORE_AREA Call AV_NBRSAL From W1ECP6
Return

Subprog AV_NBRSAL
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBRSAL" : Gosub TIT_COL From W1ECP6
Endif
Gosub _AFF
End

$ON_SALDAT
Onevent BEFORE_AREA Gosub AV_SALDAT From W1ECP6
Return

$AV_SALDAT
Chgfmt [M]SALDAT(indice) With "DPZ:"+GFMDAT4
Gosub _AFF
Return

$TIT_COL
Local Char TITCL(200)(1..6)
Raz TITCL
Case BASPAG
 When "NBRSAL"
  TITCL(1) = [M:ECP6]LIBSAL(0)
  TITCL(2) = [M:ECP6]LIBSAL(1)
  TITCL(3) = [M:ECP6]LIBSAL(2)
  TITCL(4) = [M:ECP6]LIBSAL(3)
  TITCL(5) = [M:ECP6]LIBSAL(4)
  TITCL(6) = [M:ECP6]LIBSAL(5)
  If !GORITITCOL
   Titcol [M]NBRSAL TITCL(1) For SALVAL
   Titcol [M]NBRSAL TITCL(2) For SALVAL1
   Titcol [M]NBRSAL TITCL(3) For SALVAL2
   Titcol [M]NBRSAL TITCL(4) For SALRUB
   Titcol [M]NBRSAL TITCL(5) For SALRUB1
   Titcol [M]NBRSAL TITCL(6) For SALRUB2
  Else
   Titcol [M:ECP6]NBRSAL TITCL(1) For SALVAL
   Titcol [M:ECP6]NBRSAL TITCL(2) For SALVAL1
   Titcol [M:ECP6]NBRSAL TITCL(3) For SALVAL2
   Titcol [M:ECP6]NBRSAL TITCL(4) For SALRUB
   Titcol [M:ECP6]NBRSAL TITCL(5) For SALRUB1
   Titcol [M:ECP6]NBRSAL TITCL(6) For SALRUB2
  Endif
Endcase
Return

$CHG_STY
Return


