#<AdxTL>@(#)3.0.0.0 $Revision$
# rÃĻgles concernant les ÃĐcrans et fenÃŠtres

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End




Subprog AVERIFECR (DOSSIER, PMODULE, PCHEMIN, PEXCLSUP, PORT, MACHINE, PCHEMINW, TLCLMSK, NBLCLMSK,
&       NBERRTOT, NBWARTOT, PNUMERREUR, PLIBVERIF)

Value Char DOSSIER
Value Integer PMODULE    :  # module <> 0 si sÃĐlectionnÃĐ
Value Char PCHEMIN       :  # Chemin oÃđ seront crÃĐÃĐs les fichiers de trace
Value Integer PEXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char PCHEMINW
Variable Char TLCLMSK()
Variable Integer NBLCLMSK
Variable Integer NBERRTOT, NBWARTOT
Value Integer PNUMERREUR
Value Char PLIBVERIF


Local Integer I, J, NBERR, NBANO, NBLIGNSEVT, BMASQUETRV, BTRAITEMSQ, WBOK
Local Char WWHERE(50), WMODULE(30), WFENETRE(50), DOSSIER2(100), WL1(150), WL2(150), WTEXTE(250)
Local Shortint SAUVEMODULE
Local Integer NBECR, NBECRERR, CPTRMSK, IAA, TERREUR(40)

Local Char TMSKENT(20)(5000), WECRANS(250)
#Local Char TFENETRE(20)(5000), TFENETREON(20)(5000), TACTION(20)(5000)
Local Char TFENETRE(20)(5000), TACTION(20)(5000)
Local Char TONGLET(20)(20000)
Local Integer TMODULE(5000)

Local Integer NBACTION, IA, NBFENETRE, NBONGLET, NBMSKEN, LM, MI1, MI2, MI3


    If MACHINE = ""
        DOSSIER2 = DOSSIER
    Else
        DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
    Endif
    
    
    BTRAITEMSQ = 1
    
    PNUMERREUR = mod(PNUMERREUR, 100)
    
    If clalev ([F:AWI])
        Close File [AWI]
    Endif
    If clalev ([F:AMK])
        Close File [AMK]
    Endif
    If clalev ([F:AOB])
        Close File [AOB]
    Endif
    If clalev ([F:AST])
        Close File [AST]
    Endif
    
    If clalev ([F:ACT])
        Close File [ACT]
    Endif
    If clalev ([F:ACN])
        Close File [ACN]
    Endif


    Local File = DOSSIER2 + ".AWINDOW"   [AWI]
    Local File = DOSSIER2 + ".AMSK"      [AMK]
    Local File = DOSSIER2 + ".AOBJET"    [AOB]
    Local File = DOSSIER2 + ".APLSTD"    [AST]
    
    Local File = DOSSIER2 + ".ACTION"    [ACT]
    Local File = DOSSIER2 + ".ACONSULT"  [ACN]
    
    Openo PCHEMIN, -1


Wrseq
Wrseq
Wrseq
Wrseq "-------------------------### VÃĐrification des" - PLIBVERIF + ". ###---------------------------"
Wrseq
Wrseq

If PNUMERREUR
    If GBTWARNING(GNUMMOUL, PNUMERREUR)
        Wrseq "Attention, seule l'anomalie nÂ°" - num$(200 + PNUMERREUR) - "est recherchÃĐe"
    Else
        Wrseq "Attention, seule l'erreur nÂ°" - num$(200 + PNUMERREUR) - "est recherchÃĐe"
    Endif
Endif
Wrseq

Openo
Openo PCHEMINW, -1

Wrseq
Wrseq
Wrseq
Wrseq "-------------------------### VÃĐrification des" - PLIBVERIF + ". ###---------------------------"
Wrseq
Wrseq
If PNUMERREUR
    If GBTWARNING(GNUMMOUL, PNUMERREUR)
        Wrseq "Attention, seule l'anomalie nÂ°" - num$(200 + PNUMERREUR) - "est recherchÃĐe"
    Else
        Wrseq "Attention, seule l'erreur nÂ°" - num$(200 + PNUMERREUR) - "est recherchÃĐe"
    Endif
Endif
Wrseq


Openo
Openo PCHEMIN,  -1 Using [FER]
Openo PCHEMINW, -1 Using [FWR]

    # nb de lignes d'1 fenÃŠtre VT
    If pat (DOSSIER, "*GEO*")
        NBLIGNSEVT = 8
    Else
        NBLIGNSEVT = 16
    Endif
    Raz TERREUR
    SAUVEMODULE = -1


    #############################################################    
    # chargement de la table des actions : les fenÃŠtres qui y sont associÃĐes


    NBACTION = 0
    Raz TFENETRE, TMODULE

    WWHERE = " MODULE >= 0"
    If PEXCLSUP = 2
        WWHERE = WWHERE - "and MODULE <> 1"
    Endif

    For [ACT]ACTION Where evalue(WWHERE)
        If [ACT]PARAM2 <> ""
            NBACTION += 1
            TFENETRE(NBACTION) = [ACT]PARAM2
##########                Read [AWI]AWI0 = [ACT]PARAM2
            TMODULE(NBACTION) = [ACT]MODULE
            TACTION(NBACTION) = [ACT]ACTION
        Endif
        If [ACT]PARAM4 <> ""
            NBACTION += 1
            TFENETRE(NBACTION) = [ACT]PARAM4
##########                Read [AWI]AWI0 = [ACT]PARAM4
            TMODULE(NBACTION) = [ACT]MODULE
            TACTION(NBACTION) = [ACT]ACTION
        Endif

    Next


# fenÃŠtres ---------------------------------------------------------------------------------------------

    
    If PNUMERREUR
        Call TEMPON("VERIFECR (ContrÃīles entre la fenÃŠtre et ses ÃĐcrans)" -
&               "module" - num$(PMODULE)) From GESECRAN
    Else
        Call TEMPON("VERIFECR (ContrÃīles entre la fenÃŠtre et ses ÃĐcrans)")     From GESECRAN
    Endif
    Wrseq "ContrÃīles entre la fenÃŠtre et ses ÃĐcrans" Using [FER]
    Wrseq "ContrÃīles entre la fenÃŠtre et ses ÃĐcrans" Using [FWR]


    
    # chargement de la table des fenÃŠtres et des masques
    NBFENETRE = 0
    NBONGLET = 0
    NBMSKEN = 0

    For [AWI]AWI0

        # chargement de tableaux pour le contrÃīle des ÃĐcrans sans fenÃŠtre
        NBFENETRE += 1
    #        TFENETRE(NBFENETRE) = [AWI]WIN
    #        TMODULE(NBFENETRE) = [AWI]MODULE
        If [AWI]MSKENT <> ""
            NBMSKEN += 1
            TMSKENT(NBMSKEN) = [AWI]MSKENT
            TFENETRE(NBMSKEN) = [AWI]WIN
        Endif
        IA = 0
        While IA < 15
            If [AWI]NOMMSK(IA) <> ""
                NBONGLET += 1
                TONGLET(NBONGLET) = [AWI]NOMMSK(IA)
#                TFENETREON(NBONGLET) = [AWI]WIN
            Endif
            IA += 1
        Wend
        #######################################################################

        # sÃĐlection demandÃĐe
        WBOK = 0    
        If PMODULE = 0
            WBOK = 1
        Elsif PMODULE = [F:AWI]MODULE
            WBOK = 1
        Endif
        
        If PEXCLSUP = 2 and [F:AWI]MODULE = 1
            WBOK = 0
        Endif    

        If WBOK
            I=0
            WECRANS = ""
            If PMODULE
                WMODULE = ""
            Else
                WMODULE = "(Module" - num$([F:AWI]MODULE) - func AVERIFSRC.LIBMODULE ([F:AWI]MODULE, SAUVEMODULE) + ") "
            Endif
            WFENETRE = "FenÃŠtre" - [F:AWI]WIN
        
            If [F:AWI]MSKENT = ""
                If [F:AWI]NBMSK = 0
                    WL1 = "Aucun ÃĐcran associÃĐ (Champ NBMSK = 0)."
                    Call ECRERR (1, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                Elsif [F:AWI]NBMSK > 1
                    WL1 = "Il n'y a pas d'entÃŠte mais" - num$([F:AWI]NBMSK) - "ÃĐcrans"
                    Call ECRERR (2, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                Endif
            Else
                Read [AMK]CODMSK = [F:AWI]MSKENT
                If fstat
                    I = 0
                Else
                    If [F:AMK]TYPMSK <> 5 : # EntÃŠte
        
                        WL1 = "L'ÃĐcran entÃŠte" - [F:AWI]MSKENT - "a le type" - mess([F:AMK]TYPMSK,929,1)
                        Call ECRERR (3, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        
                    Elsif func ERRMODULE([F:AMK]MODULE, [F:AWI]MODULE)
    
                        WL1 = "L'ÃĐcran entÃŠte" - [F:AWI]MSKENT - "est de module diffÃĐrent (" + num$([F:AMK]MODULE) + ")" - func AVERIFSRC.LIBMODULE ([F:AMK]MODULE, SAUVEMODULE)
                        Call ECRERR (4, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                    Endif
                
    #            If [F:AMK]CODACT <> [F:AWI]CODACT
    #                If [F:AMK]CODACT = ""
    #                    WL1 = "L'ÃĐcran entÃŠte" - [F:AWI]MSKENT - " n'a pas de code activitÃĐ, alors que la fenÃŠtre a" - [F:AWI]CODACT - "comme code d'activitÃĐ"
    #                Elsif [F:AWI]CODACT = ""
    #                    WL1 = "La fenÃŠtre n'a pas de code activitÃĐ, alors que l'ÃĐcran entÃŠte" - [F:AWI]MSKENT - "a" - [F:AMK]CODACT - "comme code d'activitÃĐ"
    #                Else
    #                    WL1 = "La fenÃŠtre a" - [F:AWI]CODACT - "comme code activitÃĐ, alors que l'ÃĐcran entÃŠte" - [F:AWI]MSKENT - "a" - [F:AMK]CODACT
    #                Endif                
    #                Call ECRERR (WFENETRE, WMODULE, 1, NBERR, NBANO, WL1, WL2)
    #            Endif
                
                    I = [F:AMK]NBRLIG
                Endif
            Endif
    
            CPTRMSK = 0
            For J=0 To 14
                If [F:AWI]NOMMSK(J) <> ""
                    WECRANS = WECRANS - [F:AWI]NOMMSK(J)
                    CPTRMSK += 1
                    Read [AMK]CODMSK = [F:AWI]NOMMSK(J)
                    If func ERRMODULE([F:AMK]MODULE, [F:AWI]MODULE)
        
                        WL1 = "L'ÃĐcran" - [F:AWI]NOMMSK(J) - "est de module diffÃĐrent (" + num$([F:AMK]MODULE) + ")" - func AVERIFSRC.LIBMODULE ([F:AMK]MODULE, SAUVEMODULE)
                        Call ECRERR (5, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                    Endif
        
                    If [F:AMK]TYPMSK = 6 : # Ecran VT
                        If [F:AMK]NBRLIG <> NBLIGNSEVT : # fenÃŠtre VT dans GEODE = 8 lignes
                            WL1 = "L'ÃĐcran" - [F:AWI]NOMMSK(J) - "a" - num$([F:AMK]NBRLIG) - "lignes : fenÃŠtre VT standard :" - num$(NBLIGNSEVT)
                            Call ECRERR (6, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        Endif
                    Else
                        If ((I + [F:AMK]NBRLIG) > 28)
                            WL1 = "Les ÃĐcrans entÃŠte et onglet" - [F:AWI]MSKENT - "+" - [F:AWI]NOMMSK(J) -
&                                 "ont" - num$(I) - "+" - num$([F:AMK]NBRLIG) - "lignes (> Ã  28)"
                            Call ECRERR (7, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        Endif
                    Endif
        
        
                    If [F:AWI]MSKENT <> ""
                        If find([F:AMK]TYPMSK,2,3,4,5) : # Dialogue, Plein ÃĐcran (avec ou sans liste), EntÃŠte
                            WL1 = "L'ÃĐcran" - [F:AWI]NOMMSK(J) - "de type" - mess([F:AMK]TYPMSK,929,1) - "Devrait ÃŠtre de type onglet"
                            Call ECRERR (8, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        Endif
                    Endif
                    If [F:AMK]TYPMSK = 6 : # Ecran VT
                        If [F:AWI]FVT <> 2    # n'est pas une fenÃŠtre VT
                            WL1 = "L'ÃĐcran" - [F:AWI]NOMMSK(J) - "de type" - mess([F:AMK]TYPMSK,929,1) - "n'est pas associÃĐ Ã  une fenÃŠtre VT."
                            Call ECRERR (9, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        Endif
                    Else
                        If [F:AWI]FVT = 2    # est une fenÃŠtre VT
                            WL1 = "L'ÃĐcran" - [F:AWI]NOMMSK(J) - "de type" - mess([F:AMK]TYPMSK,929,1) - "n'est pas de type VT et est associÃĐ Ã  une fenÃŠtre VT."
                            Call ECRERR (10, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        Endif
        
                    Endif
                
    #            If [F:AMK]CODACT <> [F:AWI]CODACT
    #                If [F:AMK]CODACT = ""
    #                    WL1 = "L'onglet" - [F:AWI]NOMMSK(J) - " n'a pas de code activitÃĐ, alors que la fenÃŠtre a" - [F:AWI]CODACT - "comme code d'activitÃĐ"
    #                Elsif [F:AWI]CODACT = ""
    #                    WL1 = "La fenÃŠtre n'a pas de code activitÃĐ, alors que l'onglet" - [F:AWI]NOMMSK(J) - "a" - [F:AMK]CODACT - "comme code d'activitÃĐ"
    #                Else
    #                    WL1 = "La fenÃŠtre a" - [F:AWI]CODACT - "comme code activitÃĐ, alors que l'onglet" - [F:AWI]NOMMSK(J) - "a" - [F:AMK]CODACT
    #                Endif                
    #                Call ECRERR (WFENETRE, WMODULE, 1, NBERR, NBANO, WL1, WL2)
    #            Endif
    
                Endif
            Next
        
   
            If [F:AWI]NBMSK <> CPTRMSK
               WL1 = "Nombre de masques (NBMSK) = " - num$([F:AWI]NBMSK) - "et" - num$(CPTRMSK) - "ÃĐcrans trouvÃĐs."
               WL2 = "("+ WECRANS - "trouvÃĐs)"
               Call ECRERR (11, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2,  TERREUR, PNUMERREUR, [F:AWI]MODULE)
            Endif
    
    
            # cas de l'objet
            If [F:AWI]OBJ = ""
                If [F:AWI]WINTYP = 2
                    WL1 = "La fenÃŠtre est de type objet mais ce dernier n'est pas renseignÃĐ."
                    Call ECRERR (12, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                Endif
            Else
                If [F:AWI]WINTYP <> 2
                    If [F:AWI]WINTYP
                        WL1 = "La fenÃŠtre est de type" - mess([F:AWI]WINTYP,923,1) - "et un objet est renseignÃĐ :" - [F:AWI]OBJ
                        Call ECRERR (13, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                    Else
                        WL1 = "Son type est non renseignÃĐ" - mess([F:AWI]WINTYP,923,1) - "et un objet est renseignÃĐ :" - [F:AWI]OBJ
                        Call ECRERR (14, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
        
                    Endif
                Endif
                # cas de l'objet
                Read [AOB]ABREV = [F:AWI]OBJ
                If fstat
                   WL1 = "L'objet" - [F:AWI]OBJ - "n'est pas trouvÃĐ"
                   Call ECRERR (15, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
        
                Else
                    If func ERRMODULE([F:AOB]MODULE, [F:AWI]MODULE)
                        WL1 = "Son module est" - func AVERIFSRC.LIBMODULE ([F:AWI]MODULE, SAUVEMODULE) - "et objet" -
&                             [F:AWI]OBJ - "de module" - func AVERIFSRC.LIBMODULE ([F:AOB]MODULE, SAUVEMODULE) - WMODULE
                        Call ECRERR (16, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
        
                    Endif
                Endif
            Endif
    
            # cas de la consultation
            If [F:AWI]CNS = ""
                If [F:AWI]WINTYP = 3 or [F:AWI]WINTYP = 4
                    WL1 = "La fenÃŠtre est de type" - mess([F:AWI]WINTYP,923,1) - "mais elle ne possÃĻde pas de consultation."
                    Call ECRERR (17, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                Endif
            Else
                If [F:AWI]WINTYP <> 3 and [F:AWI]WINTYP <> 4
                    WL1 = "La fenÃŠtre est de type" - mess([F:AWI]WINTYP,923,1) - "et elle possÃĻde une consultation" - [F:AWI]CNS
                    Call ECRERR (18, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                Else
                                # vÃĐrif si la consult existe bien
                    Read [ACN]ACN0 = [F:AWI]CNS
                    If fstat
        
                        WL1 = "FenÃŠtre" - [F:AWI]WIN - "est de type consultation :" - [F:AWI]CNS - "Elle n'est pas trouvÃĐe dans la table ACONSULT"
                        Call ECRERR (19, "", "", NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        IAA += 1
                    Else
                        If func ERRMODULE([ACN]MODULE, [AWI]MODULE)
                            WL1 = "FenÃŠtre " - [F:AWI]WIN - "(de module" - num$([AWI]MODULE) - func AVERIFSRC.LIBMODULE ([AWI]MODULE, SAUVEMODULE) + ") associÃĐe Ã  une action :" - TACTION(IA)
                            WL2 = "de consultation" - [F:AWI]CNS - "de module diffÃĐrent :" - num$([ACN]MODULE) - func AVERIFSRC.LIBMODULE ([ACN]MODULE, SAUVEMODULE)
                            Call ECRERR (20, "", "", NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                            IAA += 1
                        Endif
                    Endif
                Endif
            Endif
        
            If [F:AWI]OBJ = "" and [F:AWI]CNS = ""
                # recherche dans les actions
                IA = find([AWI]WIN, TFENETRE(1..NBACTION))
                If IA = 0
    
                    WL1 = "FenÃŠtre " - [F:AWI]WIN - "(de type" - mess([F:AWI]WINTYP,923,1) + ") associÃĐe Ã  aucun objet, consultation ou action." - WMODULE
                    Call ECRERR (21, "", "", NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                    IAA += 1
                Else
                    If func ERRMODULE(TMODULE(IA), [AWI]MODULE)
                        WL1 = "FenÃŠtre " - [F:AWI]WIN - "(de module" - num$([AWI]MODULE) - func AVERIFSRC.LIBMODULE ([AWI]MODULE, SAUVEMODULE) + ") associÃĐe Ã  une action :" - TACTION(IA)
                        WL2 = "Son module est diffÃĐrent :" - num$(TMODULE(IA)) - func AVERIFSRC.LIBMODULE (TMODULE(IA), SAUVEMODULE)
                        Call ECRERR (22, "", "", NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
                        IAA += 1
                    Endif
                Endif            
            Endif


# contrÃīle entre WINTYP et TYP __________________________________________________________________________________________

        
            If ([F:AWI]WINTYP = 2 or [F:AWI]WINTYP = 3) and [F:AWI]TYP > 2
                    WL1 = "La fenÃŠtre est de type" - mess([F:AWI]WINTYP,923,1) - "et devrait ÃŠtre une fenÃŠtre plein ÃĐcran"
                Call ECRERR (23, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
            Endif
            
            If [F:AWI]WINTYP = 4 and [F:AWI]TYP <> 2
                WL1 = "La fenÃŠtre est de type" - mess([F:AWI]WINTYP,923,1) - "et devrait ÃŠtre une boÃŪte de dialogue"
                Call ECRERR (24, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AWI]MODULE)
            Endif
        Endif
    Next



    Wrseq "" Using [FER]
    Wrseq num$(NBERR) - "erreurs"Using [FER]
    Wrseq "" Using [FER]
    Wrseq "" Using [FER]
    Wrseq "___________________________________________________________________________________________________________________" Using [FER]


    Wrseq "" Using [FWR]
    Wrseq num$(NBANO) - "anomalies"  Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq "___________________________________________________________________________________________________________________" Using [FWR]



# ÃĐcrans ---------------------------------------------------------------------------------------------
# recherche si un ÃĐcran existe sans ÃŠtre reliÃĐ Ã  une fenÃŠtre

    If BTRAITEMSQ
    
        If PNUMERREUR
            Call TEMPON("VERIFECR (ContrÃīles des ÃĐcrans orphelins)" -
&               "module" - num$(PMODULE)) From GESECRAN
        Else
            Call TEMPON("VERIFECR (ContrÃīles des ÃĐcrans orphelins)")     From GESECRAN
        Endif
    
        Wrseq Using [FWR]
        Wrseq Using [FWR]
        Wrseq "ContrÃīles des ÃĐcrans orphelins" Using [FWR]
        Wrseq Using [FWR]
        Wrseq Using [FWR]
    
    
        LM = 0
        NBECR = 0
        NBECRERR = 0

    
        If PMODULE = 0
            WWHERE = " MODULE >= 0"
        Else
            WWHERE = " MODULE = PMODULE"
        Endif

        If PEXCLSUP = 2
            WWHERE = WWHERE - "and MODULE <> 1"
        Endif
    
        IA = 0
        For [AMK]CODMSK Where evalue(WWHERE)

            If PMODULE
                WMODULE = ""
            Else
                WMODULE = "(Module" - num$([F:AMK]MODULE) - func AVERIFSRC.LIBMODULE ([F:AMK]MODULE, SAUVEMODULE) + ") "
            Endif
                
            NBECR += 1
            BMASQUETRV = 0
            
            BMASQUETRV = find([F:AMK]CODMSK, TMSKENT(1..NBMSKEN))
            If BMASQUETRV = 0
                BMASQUETRV = find([F:AMK]CODMSK, TONGLET(1..NBONGLET))
            Endif
    
            If BMASQUETRV = 0 and NBLCLMSK
                BMASQUETRV = find([F:AMK]CODMSK, TLCLMSK(1..NBLCLMSK))
                If BMASQUETRV
                    LM += 1
                Endif
            Endif        
            
            If BMASQUETRV = 0
                WL1 = "Masque " - [F:AMK]CODMSK - "associÃĐ Ã  aucune fenÃŠtre." - WMODULE
                Call ECRERR (25, "", "", NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, [F:AMK]MODULE)
                NBECRERR += 1
            Endif
     
        Next
    
        Wrseq "" Using [FWR]
        Wrseq "" Using [FWR]
        Wrseq num$(NBECRERR) - "ÃĐcrans en anomalie"  Using [FWR]
        Wrseq "" Using [FWR]
        Wrseq "" Using [FWR]
        Wrseq "___________________________________________________________________________________________________________________" Using [FWR]
 
    Endif

#____________________________________________________________________________________________


    Wrseq Using [FER]
    Wrseq num$(NBERR) - "erreurs" Using [FER]
    Wrseq Using [FER]
    Wrseq "Fin de vÃĐrifications des" - PLIBVERIF + "." - time$ Using [FER]
    Wrseq Using [FER]

    Wrseq  Using [FWR]
    Wrseq num$(NBANO) - "anomalies." Using [FWR]
    Wrseq  Using [FWR]
    Wrseq "Fin de vÃĐrifications des" - PLIBVERIF + "." - time$ Using [FWR]
    Wrseq Using [FWR]


    If PNUMERREUR
        MI2 = PNUMERREUR
        MI3 = PNUMERREUR
    Else
        MI2 = 1
        MI3 = GNBERREUR(GNUMMOUL)
    Endif
    For I = MI2 To MI3

        If GBTWARNING(GNUMMOUL, I)
            WTEXTE = "Ano"
        Else
            WTEXTE = "Err"
        Endif

        WTEXTE = WTEXTE - num$(I + 200) + " Nombre :" - num$(TERREUR(I))
        J = len(WTEXTE)
        J = 40 - J

        If J > 0
            WTEXTE = WTEXTE + string$(J, " ")
        Else
            WTEXTE = WTEXTE
        Endif

        If GBTWARNING(GNUMMOUL, I)
            Wrseq WTEXTE + "    " - GTLIBERREUR(GNUMMOUL, I) Using [FWR]
        Else
            Wrseq WTEXTE + "    " - GTLIBERREUR(GNUMMOUL, I) Using [FER]
        Endif
     
    Next I
    

    Wrseq Using [FER]
    Wrseq "Fin de vÃĐrification." - time$ Using [FER]
    Wrseq Using [FER]

    Wrseq "" Using [FWR]
    Wrseq "Fin de vÃĐrification." - time$ Using [FWR]
    Wrseq "" Using [FWR]


    NBERRTOT += NBERR
    NBWARTOT += NBANO
    
    Close File [AWI]
    Close File [AMK]
    Close File [AOB]
    Close File [AST]

    Close File [ACT]
    Close File [ACN]

    Openo Using [FER]
    Openo Using [FWR]
End

Subprog ECRERR (PINDERREUR, WFENETRE, WMODULE, NBERR, NBANO, WL1, WL2, TERREUR, PNUMERREUR, PMODULELU)
Value Integer PINDERREUR
Value Char WFENETRE, WMODULE
Variable Integer NBERR, NBANO
Variable Char WL1, WL2
Variable Integer TERREUR()
Value Integer PNUMERREUR, PMODULELU

    If PNUMERREUR and PNUMERREUR <> PINDERREUR
        End
    Endif

    If GBTWARNING(GNUMMOUL, PINDERREUR)
        NBANO += 1
        If WFENETRE <> "" or WMODULE <> ""
            Wrseq WFENETRE - WMODULE Using [FWR]
        Endif
    Else
        NBERR += 1
        If WFENETRE <> "" or WMODULE <> ""
            Wrseq WFENETRE - WMODULE Using [FER]
        Endif
    Endif
    GTRECAPERR(GNUMMOUL, PMODULELU, PINDERREUR) += 1

    If GBTWARNING(GNUMMOUL, PINDERREUR)
        Wrseq "  *** (Ano" - num$(PINDERREUR + 200) +")" - WL1 Using [FWR]
        If WL2 <> ""
            Wrseq "  ***" - WL2 Using [FWR]
        Endif
        Wrseq Using [FWR]
    Else
        Wrseq "  *** (Err" - num$(PINDERREUR + 200) +")" - WL1 Using [FER]
        If WL2 <> ""
            Wrseq "  ***" - WL2 Using [FER]
        Endif
        Wrseq Using [FER]
    Endif
    
    TERREUR(PINDERREUR) += 1
    WL1 = ""
    WL2 = ""

End

# indique si il y a une erreur de compatibilitÃĐ entre les 2 modules
Funprog ERRMODULE(PMODULE1, PMODULE2)
Value Integer PMODULE1, PMODULE2

    If PMODULE1 = PMODULE2
        End 0
    Endif

    If PMODULE1 = 1 or PMODULE1 = 9
        End 0
    Endif
    If PMODULE2 = 1 or PMODULE2 = 9
        End 0
    Endif

End 1
