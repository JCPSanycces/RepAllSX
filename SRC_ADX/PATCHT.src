[L]CLE2 = right$(NAMOBJ,instr(1,NAMOBJ,"~")+1)
For [ADO]ADO0 Where TYP = CLE1 & COD = CLE2 & find([ADO]LAN,[L]LANGUE(1..len([L]LANGUE)))
  If [ADO]CODACT>="X" & find([ADO]CODACT,ACTSPE(1..NBACT))=0
    MSG=mess(232,126,1)-CLE2-"("+[ADO]LAN+":"-num$([ADO]LEV)+";"+num$([ADO]SUBLEV)+")"
    MSG-=mess(171,126,1)-[ADO]CODACT-mess(173,126,1)
