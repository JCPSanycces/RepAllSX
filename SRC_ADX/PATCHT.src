#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCHT","PATCHT",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXECUTE
Endcase
Return

$INIT
Local Shortint MAXFIC
MAXFIC = 2000
Local Integer  OK, IJ, P, D , NBACT ,ER , OKTRT, I,J
Local Char     TRAIT(250)(1..MAXFIC), FIC_TRACE(GDIMFIC), FICPATCH(GDIMFIC) , FICBASE(GDIMFIC)
Local Char     EXT(3), APPLI(GDIMFIC)
Local Char     MACFIC(GLONAMC) , CHEMIN(GDIMFIC) , REPFIC(GDIMFIC) , FICCLI(GDIMFIC) , URL(10)
Local Char     OADXIFS(5), OADXIRS(5)
Local Integer  OADXIUM
Local Integer  TYPFIC, NBTRAIT, NBTRAIT_L, TYPE_PATCH, TYPENR , NB
Local Char     CHAINE(250),NAMOBJ(20),TYPOBJ(20),HEADER(100),MSG(200),TIT(200),REPERT(250)
Local Integer  STAT,NB_CONFLICTS,NOCT
Local Libelle  BUFFER(1..1000)
Local Libelle  FLGBLK(1..15)
Local Char     ACTSPE(GLONACV)(1..60)
Local Char     FIELDNAME(255)(1..50)
Local Char     CLE1(250),CLE2(250),LANGUE(GLONLAN)(1..50)
Local Char WBLC(20)
Local Char WACTBLC (GLONACV), WACTSEC(GLONACV), WACTAMC(GLONACV)

Local Mask PATCHT [DIA]
Local File ADOSSIER [ADS], ADOSACT [ADA]
Raz [M:DIA]
[M:DIA]FICHIER = GFICPATH
If pat(left$(GFICPATH,3),"!:\") or left$(GFICPATH,1)="#"
 [M:DIA]TYPEXP = 1
Else
 [M:DIA]TYPEXP = 2
Endif
Call CHARGE_DOS From PATCH
TMP = 1
TRA = 1
Return

$CONTROLE
CHEMIN = [M:DIA]FICHIER
If [M:DIA]TYPEXP=1
 FICCLI = [M:DIA]FICHIER
 Call SET_FICNAM(FICCLI,CHEMIN,URL) From ORDSYS
 Call COPSRV(FICCLI,CHEMIN,STAT) From ORDSYS
 If STAT : FIN = 1 : Return : Endif
 GFICPATH = FICCLI
Else
 FICCLI = ""
Endif
Return

$EXECUTE

OADXIRS=adxirs : OADXIFS=adxifs : OADXIUM=adxium

If find(right$(CHEMIN,len(CHEMIN)),"\","/")
 CHEMIN = left$(CHEMIN,len(CHEMIN)-1)
Endif

Call MACHINE(CHEMIN,MACFIC,REPFIC) From ORDSYS
Call EXISTE(CHEMIN,TYPFIC) From ORDSYS

Case TYPFIC
 When 2 : # C'est un répertoire
  FICBASE = CHEMIN
  EXT = "dat"
  If MACFIC="#"
   If GBROWS
    Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
    End
   Else
    Local File (LISFIC(GDIMFIC)) From System '#@cmd /c dir/b "'+REPFIC+'\*.'+EXT+'"' As [FTR_]
    NBTRAIT = 0
    For [FTR_]
     If pat([F:FTR_]LISFIC,'*.'+EXT)
      NBTRAIT += 1
      If NBTRAIT<=dim(TRAIT)
       K = instr(1,[F:FTR_]LISFIC,'.'+EXT)
       If K
        TRAIT(NBTRAIT) = left$([FTR_]LISFIC,K-1)
       Endif
      Endif
     Endif
    Next FTR_
    Close Local File [FTR_]
   Endif
  Else
   Call SYSTEME2(MACFIC,'lsadx -a'-nomap-'"'+REPFIC+'"'-EXT,'',NBTRAIT,TRAIT) From ORDSYS
  Endif
  If NBTRAIT>dim(TRAIT)
   Call ECR_TRACE(mess(29,139,1)-"."+EXT-"("+num$(NBTRAIT)+"/"+num$(dim(TRAIT))+")",1) From GESECRAN
   # Trop de fichiers
   Return
  Endif
  Sorta NBTRAIT,TRAIT
 When 1 : # C'est un fichier normal
  NBTRAIT  = 1
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
   Call REPERT(CHEMIN,FICBASE,TRAIT(1),EXT) From PATCH
  Endif
 When Default : # Ca n'existe pas
  Return
Endcase

FIC_TRACE = TRAIT(1)
If NBTRAIT>1
 FIC_TRACE += " -> "+TRAIT(NBTRAIT)
Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(175,126,1)-"|"+FIC_TRACE) From LECFIC : # Test des patches
Endif

If NBTRAIT=0
 Call ECR_TRACE("|"+mess(56,126,1)-FICBASE,0) From GESECRAN
# Pas de patch dans le répertoire
Endif

For D=0 To [M:DIA]NBDOS-1
 APPLI = [M:DIA]DOSSIER(D)
 GERR = 0
 Gosub OUVFIC
 If !GERR
  For P=1 To NBTRAIT
   If FICCLI<>""
    FICPATCH = CHEMIN
   Else
    FICPATCH = filpath(FICBASE,TRAIT(P),EXT,"","",MACFIC)
   Endif
   If filinfo(FICPATCH,0)<0 : # Il aurait pu disparaître!!
    Call ECR_TRACE("|"+FICPATCH-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
   Else
    Gosub READ_PATCH
   Endif
  Next P
 Endif
 Gosub FERMFIC
Next D

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

adxirs=OADXIRS : adxifs=OADXIFS : adxium=OADXIUM

Return

#############################################################################################
$OUVFIC
Onerrgo ERR
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ATABIND"   [ATI]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".AOBJTAB"   [AOT]
Local File =APPLI+".AFONCTION" [AFC]
Local File =APPLI+".ADOCUMENT" [ADO]
Local File =APPLI+".ADOCFNC"   [ADF]
Local File =APPLI+".ADOPAR"    [ADP]
Local File =APPLI+".ADOVAL"    [ADW]
Local File =APPLI+".ASUBPROG"  [ASU]
Local File =APPLI+".AMOTCLE"   [AMC]

Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ATYPERUL"    [ATYR]
Local File =APPLI+".ATYPERPAR"   [ATYRP]
Local File =APPLI+".ATYPELNK"    [ATYL]
Local File =APPLI+".ATYPELPAR"   [ATYLP]

Local File =APPLI+".ATYPEPRO"    [ATYP]

Local File =APPLI+".ACLASSE"    [ACLA]
&         ,=APPLI+".ACLAFLD"    [ACLAF]
&         ,=APPLI+".ACLAMET"    [ACLAM]
&         ,=APPLI+".ACLAMETSTD" [ACLAT]
&         ,=APPLI+".ACLAOPT"    [ACLAO]
&         ,=APPLI+".ACLACOL"    [ACLAC]
Local File =APPLI+".ASHW"       [ASW]
&         ,=APPLI+".ASHWFLD"    [ASWF]
&         ,=APPLI+".ASHWOPT"    [ASWO]
&         ,=APPLI+".ASHWCOL"    [ASWC]
&         ,=APPLI+".ASHWSEC"    [ASWS]
&         ,=APPLI+".ASHWBLC"    [ASWB]
&         ,=APPLI+".ASHWMET"    [ASWM]
&         ,=APPLI+".ASHWEXPPRO" [ASWR]
&         ,=APPLI+".ASHWLNK"    [ASWK]
&         ,=APPLI+".ASHWMENU"   [ASWMN]

Local File =GDOSX3+".ADICTRT"  [ADC]
Onerrgo
Return

$FERMFIC
Onerrgo ERR
Close Local File [ATB],[ATZ],[ATI],[AMK],[AMZ],[AMA],[AMP],[AWI],[AWT],[AWB]
Close Local File [AOB],[AOT],[AFC],[ADO],[ADF],[ADP],[ASU],[ADC],[AMC]
Close Local File [ATY],[ATYR],[ATYRP],[ATYL],[ATYLP], [ADW], [ATYP]
Close Local File [ACLA], [ACLAF], [ACLAM], [ACLAT], [ACLAO], [ACLAC]
Close Local File [ASW], [ASWF], [ASWO],[ASWC],[ASWS],[ASWB], [ASWM], [ASWR], [ASWK],[ASWMN]
Onerrgo
Return

$ERR
GERR = errn
Resume

#########################################################################################
# Program which tests conflicts due to specific developments before a patch integration
# Rev 1.1 Feb 14,2002
# Written by Dominique BOPP
# (C) 2002 ADONIX
#########################################################################################

$READ_PATCH
    Openi FICPATCH Using [PPP]
    adxifs="," : adxirs=chr$(10) : adxium=GUTF8

    Raz ACTSPE
    NB_CONFLICTS=0
    STAT=0

    While STAT=0
        Gosub READ_HEAD
        STAT=fstat
        If TYPENR=1
            HEADER = FIELDNAME(1)
            LANGUE = FIELDNAME(2)
            TYPE_PATCH=val(FIELDNAME(6))
            NBACT = 0
            While FIELDNAME(4)<>""
                NBACT += 1
                K = instr(1,FIELDNAME(4),"/")
                If K
                    ACTSPE(NBACT) = left$(FIELDNAME(4),K-1)
                    FIELDNAME(4)     = right$(FIELDNAME(4),K+1)
                Else
                    ACTSPE(NBACT) = FIELDNAME(4)
                    FIELDNAME(4)     = ""
                Endif
            Wend
            If TYPE_PATCH>=3 : # Spécifique + Vertical
                For [ADA]ADA0 Where DOSSIER=APPLI & CODACT>="X" & COP=2
                    If !find([F:ADA]CODACT,ACTSPE(1..NBACT)) & NBACT<dim(ACTSPE)
                        NBACT += 1
                        ACTSPE(NBACT) = [F:ADA]CODACT
                    Endif
                Next ADA
            Endif
        Elsif TYPENR=2
            TYPOBJ=FIELDNAME(1)
            NAMOBJ=FIELDNAME(2)
            Case TYPOBJ
                When "AMK" : Gosub ANA_MASK
                When "ATB" : Gosub ANA_TAB
                When "AWI" : Gosub ANA_WIN
                When "AOB" : Gosub ANA_OBJ
                When "ATY" : Gosub ANA_TYP
                When "AFC" : Gosub ANA_FCT
                When "ACT" : Gosub ANA_ACT
                When "ARP" : Gosub ANA_REP
                When "ACN" : Gosub ANA_CNS
                When "ADO" : Gosub ANA_DOC
                When "ADF" : Gosub ANA_ADF
                When "AWM" : Gosub ANA_AWM
                When "AVW" : Gosub ANA_AVW
                When "AML" : Gosub ANA_AML
                When "ADP" : Gosub ANA_ADP
                When "ASU" : Gosub ANA_ASU
                When "AGB" : Gosub ANA_AGB
                When "ACTX" : Gosub ANA_ACTX
                When "AUR" : Gosub ANA_AUR
                When "AOE" : Gosub ANA_AOE
                When "ATN" : Gosub ANA_ATN
                When "ADC" : Gosub ANA_ADC
                When "AHI" : Gosub ANA_AHI
                When "TAB" : Gosub ANA_TAB
                When "ANG" : Gosub ANA_ANG
                When "GAU" : Gosub ANA_GAU
                When "ACLA" : Gosub ANA_ACLA
                When "ASW" : Gosub ANA_ASW
                When "ATYP" : Gosub ANA_ATYP
                When "AMC" : Gosub ANA_AMC
                When "ADI","ADV" : Gosub ANA_ADI_ADV
                When "ETA" : Gosub ANA_CRY
                When "TRT","ADX" : Gosub ANA_TRT
            Endcase
            Gosub SKIPOBJ
        Elsif TYPENR=8
            Break : # End of patch reached
        Endif
    Wend
    Openi Using [PPP]
Return

$SKIPOBJ
If find(TYPOBJ,"TRT")
 Repeat
  Rdseq CHAINE Using [PPP]
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif find(TYPOBJ,"ADX","ELT","BIA","ARA")
 Rdseq NOCT Using [PPP]
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER Using [PPP]
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER Using [PPP]
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE Using [PPP]
 Until fstat or CHAINE=string$(10,"*")
 If fstat : ER = 25 : Return : Endif
Elsif TYPOBJ="ETA"
 Repeat
  Gosub READ_HEAD
  If TYPENR=3
   Rdseq NOCT Using [PPP]
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER Using [PPP]
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER Using [PPP]
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE Using [PPP]
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Endif
  Endif
 Until TYPENR=7 or ER
Elsif TYPOBJ="TAB"
 Repeat
  Gosub READ_HEAD
  If TYPENR=3
   Rdseq NOCT Using [PPP]
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER Using [PPP]
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER Using [PPP]
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE Using [PPP]
   Until fstat or CHAINE=string$(10,"*")
   If fstat : ER = 25 : Break : Endif
  Endif
 Until TYPENR<>3
 If ER : Return : Endif
Endif
If !find(TYPOBJ,"TAB","ETA")
 Repeat
  Gosub READ_HEAD
  If find(TYPENR,22,24,23,25) : # Blob , Clob
   Rdseq NOCT Using [PPP]
   Repeat
    NB = dim(BUFFER)
    If NOCT>NB
     Getseq NB , BUFFER Using [PPP]
     NOCT -= NB
    Else
     Getseq NOCT , BUFFER Using [PPP]
     NOCT = 0
    Endif
   Until NOCT=0
   Repeat
    Rdseq CHAINE Using [PPP]
   Until fstat or CHAINE=string$(10,"*")
   If fstat
    ER = 33 : Break
   Endif
  Endif
 Until fstat or TYPENR=7
 If fstat : ER = 25 : Endif
Endif
Return

$READ_HEAD
    Rdseq TYPENR,FIELDNAME Using [PPP]
    Call DELIMITE(FIELDNAME) From PATCH
Return

$WR_ERR
    If NB_CONFLICTS=0
        Call ECR_TRACE("",0) From GESECRAN
        Call ECR_TRACE(mess(177,126,1)-TRAIT(P)-mess(178,126,1)-APPLI-":"-HEADER,0) From GESECRAN
    Endif
    NB_CONFLICTS+=1
    Call ECR_TRACE("  "+MSG,0) From GESECRAN
Return

$VERIF_NUM
If clalev([F:XXX_]) : Close Local File [F:XXX_] : Endif
Local File =APPLI+"."+TABLE [XXX_]
Assign "[F:XXX_]"+CLE With val(NAMOBJ)
Read [XXX_] =
If fstat=0 & evalue("[XXX_]CODACT") >="X" & find(evalue("[XXX_]CODACT"),ACTSPE(1..NBACT))=0
    MSG=TIT-NAMOBJ-mess(171,126,1)-evalue("[XXX_]CODACT")-mess(173,126,1)
    Gosub WR_ERR
Endif
Return

$VERIF
If clalev([F:XXX_]) : Close Local File [F:XXX_] : Endif
Local File =APPLI+"."+TABLE [XXX_]
Assign "[F:XXX_]"+CLE With NAMOBJ
Read [XXX_] =
If fstat=0 & evalue("[XXX_]CODACT") >="X" & find(evalue("[XXX_]CODACT"),ACTSPE(1..NBACT))=0
    MSG=TIT-NAMOBJ-mess(171,126,1)-evalue("[XXX_]CODACT")-mess(173,126,1)
    Gosub WR_ERR
Endif
Return

# Mask analysis
$ANA_MASK
    Read [AMK]CODMSK=NAMOBJ
    If fstat=0
        If [AMK]CODACT>="X" & find([AMK]CODACT,ACTSPE(1..NBACT))=0
            MSG=mess(155,126,1)-NAMOBJ-mess(171,126,1)-[AMK]CODACT-mess(173,126,1)
            Gosub WR_ERR
        Else
            Raz FLGBLK
            For IJ=1 To [AMK]NBBLOC
                If[AMK]ACTBLOC(IJ-1)>="X" & find([AMK]ACTBLOC(IJ-1),ACTSPE(1..NBACT))=0
                    FLGBLK(IJ)=1
                    MSG=mess(176,126,1)-NAMOBJ-":"-mess(156,126,1)-num$(IJ)-mess(171,126,1)
                    MSG-=[AMK]ACTBLOC(IJ-1)-mess(173,126,1)
                    Gosub WR_ERR
                Endif
            Next IJ
            For [AMZ]CODZON Where [AMZ]CODMSK=[AMK]CODMSK & [AMZ]CODACT>="X" & NUMBLOC>=find(0,FLGBLK)
&                               & find([AMZ]CODACT,ACTSPE(1..NBACT))=0
                If FLGBLK([AMZ]NUMBLOC)=0
                    MSG=mess(176,123,1)-NAMOBJ-":"-mess(153,126,1)-"("+num$([AMZ]NUMBLOC)+","
                    MSG+=num$([AMZ]NOZONE)+")"-[AMZ]CODZON-mess(171,126,1)-[AMZ]CODACT-mess(173,126,1)
                    Gosub WR_ERR
                Endif
            Next
        Endif
    Endif
Return


# Table analysis
$ANA_TAB
    Read [ATB]CODFIC=NAMOBJ
    If fstat=0
        If [ATB]CODACT>="X" & find([ATB]CODACT,ACTSPE(1..NBACT))=0
            MSG=mess(152,126,1)-NAMOBJ-mess(171,126,1)-[ATB]CODACT-mess(173,126,1)
            Gosub WR_ERR
        Else
            For [ATZ]NUMLIG Where [ATZ]CODFIC=[ATB]CODFIC & [ATZ]CODACT>="X"
&             & find([ATZ]CODACT,ACTSPE(1..NBACT))=0
                MSG=mess(56,123,1)-NAMOBJ-":"-mess(153,126,1)-"("+num$([ATZ]NUMLIG)+")"-[ATZ]CODZONE
                MSG-=mess(171,126,1)-[ATZ]CODACT-mess(173,126,1)
                Gosub WR_ERR
            Next
            For [ATI]CODIND Where [ATI]CODFIC=[ATB]CODFIC & [ATI]CODACT>="X"
&             & find([ATI]CODACT,ACTSPE(1..NBACT))=0
                MSG=mess(56,123,1)-NAMOBJ-":"-mess(154,126,1)-"("+num$([ATI]NUMLIG)+")"-[ATI]CODIND
                MSG-=mess(171,126,1)-[ATZ]CODACT-mess(173,126,1)
                Gosub WR_ERR
            Next
        Endif
    Endif
Return

# Windows analysis
$ANA_WIN
    Read [AWI]AWI0=NAMOBJ
    If fstat=0
        If [AWI]CODACT>="X" & find([AWI]CODACT,ACTSPE(1..NBACT))=0
            MSG=mess(157,126,1)-NAMOBJ-mess(171,126,1)-[ATB]CODACT-mess(173,126,1)
            Gosub WR_ERR
        Endif
     For IJ=1 To [AWI]NBMSK
         If [AWI]ACTMSK(IJ-1)>="X" & find([AWI]ACTMSK(IJ-1),ACTSPE(1..NBACT))=0
             MSG=mess(15,124,1)-NAMOBJ-":"-mess(160,126,1)-"("+num$(IJ)+")"-[AWI]NOMMSK(IJ-1)
             MSG-=mess(171,126,1)-[AWI]ACTMSK(IJ-1)-mess(173,126,1)
             Gosub WR_ERR
         Endif
     Next IJ
     For [AWT] Where WIN=[F:AWI]WIN
          If [AWT]CODACTBOUT>="X" & find([AWT]CODACTBOUT,ACTSPE(1..NBACT))=0 : #CCL
             MSG=mess(14,126,1)-NAMOBJ-":"-mess(158,126,1)-[F:AWT]CODBOUT-mess(171,126,1)-[ATZ]CODACT
             MSG-=mess(173,126,1)
             Gosub WR_ERR
           Endif
     Next AWT
     For [AWB] Where WIN=[F:AWI]WIN
          For IJ=1 To [AWB]NBLIS
              If [AWB]ACTLIS(IJ-1)>="X" & find([AWB]ACTLIS(IJ-1),ACTSPE(1..NBACT))=0
                  MSG=mess(15,124,1)-NAMOBJ-":"-mess(162,126,1)-"("+num$(IJ)+")"-[AWB]OBJLIS(IJ-1)
                  MSG-=mess(171,126,1)-[AWB]ACTLIS(IJ-1)-mess(173,126,1)
                  Gosub WR_ERR
               Endif
           Next IJ
     Next AWB
    Endif
Return

# Objects analysis
$ANA_OBJ
    Read [AOB]ABREV=NAMOBJ
    If fstat=0
        If [AOB]CODACT>="X" & find([AOB]CODACT,ACTSPE(1..NBACT))=0
            MSG=mess(159,126,1)-NAMOBJ-mess(171,126,1)-[ATB]CODACT-mess(173,126,1)
            Gosub WR_ERR
        Else
            For [AOT]ABREV Where ABREV=NAMOBJ
                If [F:AOT]TABACT>="X" & find([F:AOT]TABACT,ACTSPE(1..NBACT))=0
                    MSG=mess(15,124,1)-NAMOBJ-":"-mess(161,126,1)-"("+num$([F:AOT]NUMLIG)+")"-[AOT]TABFIC
                    MSG-=mess(171,126,1)-[F:AOT]TABACT-mess(173,126,1)
                    Gosub WR_ERR
                Endif
            Next
        Endif
    Endif
Return

# Data type analysis
$ANA_TYP
  Read [ATY]CODTYP=NAMOBJ
  If fstat=0 & [ATY]CODACT >="X" & find([ATY]CODACT,ACTSPE(1..NBACT))=0
      MSG=mess(165,126,1)-NAMOBJ-mess(171,126,1)-[ATY]CODACT-mess(173,126,1)
      Gosub WR_ERR
  Endif
  # Get specifics rules
  For [ATYR] Where CODTYP=NAMOBJ
    If [F:ATYR]ACTRUL>="X" & find([F:ATYR]ACTRUL,ACTSPE(1..NBACT))=0
        MSG=mess(165,126,1)-NAMOBJ-":"-mess(260,126,1)-num$([F:ATYR]TYPRUL)-[F:ATYR]TRTRUL-[F:ATYR]PRGRUL-mess(171,126,1)
        MSG-=[F:ATYR]ACTRUL-mess(173,126,1)
        Gosub WR_ERR
    Endif
  Next
  # Get specifics links
  For [ATYL] Where CODTYP=NAMOBJ
    If [F:ATYL]ACTLNK>="X" & find([F:ATYL]ACTLNK,ACTSPE(1..NBACT))=0
        MSG=mess(165,126,1)-NAMOBJ-":"-mess(257,126,1)-[F:ATYL]CODLNK-num$([F:ATYL]TYPLNK)-[F:ATYL]REPLNK-mess(171,126,1)
        MSG-=[F:ATYL]ACTLNK-mess(173,126,1)
        Gosub WR_ERR
    Endif
  Next
Return

# Functions analysis
$ANA_FCT
    Read [AFC]CODINT=NAMOBJ
    If fstat=0
        If [AFC]CODACT>="X" & find([AFC]CODACT,ACTSPE(1..NBACT))=0
            MSG=mess(163,126,1)-NAMOBJ-mess(171,126,1)-[AFC]CODACT-mess(173,126,1)
            Gosub WR_ERR
        Else
            For IJ=1 To [AFC]NBOPT
                If[AFC]ACTOPT(IJ-1)>="X" & find([AFC]ACTOPT(IJ-1),ACTSPE(1..NBACT))=0
                    MSG=mess(75,123,1)-NAMOBJ-":"-mess(166,126,1)-"("+num$(IJ)+")"-[AFC]FLAG(IJ-1)
                    MSG-=mess(171,126,1)-[AFC]CODACT-mess(173,126,1)
                    Gosub WR_ERR
                Endif
            Next IJ
            For IJ=1 To [AFC]NBVAR
                If[AFC]ACTVAR(IJ-1)>="X" & find([AFC]ACTVAR(IJ-1),ACTSPE(1..NBACT))=0
                    MSG=mess(75,123,1)-NAMOBJ-":"-mess(167,126,1)-"("+num$(IJ)+")"-[AFC]VARIA(IJ-1)
                    MSG-=mess(171,126,1)-[AFC]CODACT-mess(173,126,1)
                    Gosub WR_ERR
                Endif
            Next IJ
        Endif
    Endif
Return

