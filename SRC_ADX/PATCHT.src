# Data Classes analysis
$ANA_ACLA
  Read [ACLA]ACLA0=NAMOBJ
  If fstat=0
    If [ACLA]CODACT>="X" & find([ACLA]CODACT,ACTSPE(1..NBACT))=0
        MSG=mess(250,126,1)-NAMOBJ-mess(171,126,1)-[ACLA]CODACT-mess(173,126,1)
        Gosub WR_ERR
    Else
      # Get specifics treatments
      For IJ=0 To [F:ACLA]NBRTRT-1
        If [F:ACLA]ACTTRT(IJ)>="X" & find([F:ACLA]ACTTRT(IJ),ACTSPE(1..NBACT))=0
            MSG=mess(250,126,1)-NAMOBJ-":"-mess(170,126,1)-[F:ACLA]CODTRT(IJ)-mess(171,126,1)
            MSG-=[F:ACLA]ACTTRT(IJ)-mess(173,126,1)
            Gosub WR_ERR
        Endif
      Next
      #options
      For [ACLAO]ACLAO0 Where CODCLA=[F:ACLA]CODCLA & [ACLAO]OPTACT>="X" & find([ACLAO]OPTACT,ACTSPE(1..NBACT))=0
          MSG=mess(250,126,1)-NAMOBJ-":"-mess(263,126,1)-[F:ACLAO]OPTCOD-mess(171,126,1)
          MSG-=[F:ACLAO]OPTACT-mess(173,126,1)
          Gosub WR_ERR
      Next
      #collections
      For [ACLAC]ACLAC0 Where CODCLA=[F:ACLA]CODCLA & [ACLAC]ACTCOL>="X" & find([ACLAC]ACTCOL,ACTSPE(1..NBACT))=0
          MSG=mess(250,126,1)-NAMOBJ-":"-mess(259,126,1)-[F:ACLAC]CODCOL-mess(171,126,1)
          MSG-=[F:ACLAC]ACTCOL-mess(173,126,1)
          Gosub WR_ERR
      Next
      #
      For [ACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA & [ACLAF]ACTFLD>="X" & find([ACLAF]ACTFLD,ACTSPE(1..NBACT))=0
          MSG=mess(250,126,1)-NAMOBJ-":"-mess(255,126,1)-[ACLAF]FLDCLA-mess(171,126,1)
          MSG-=[ACLAF]ACTFLD-mess(173,126,1)
          Gosub WR_ERR
      Next
      For [ACLAM]ACLAM0 Where CODCLA=[F:ACLA]CODCLA & [ACLAM]ACTMET>="X" & find([ACLAM]ACTMET,ACTSPE(1..NBACT))=0
          MSG=mess(250,126,1)-NAMOBJ-":"-mess(253,126,1)-[ACLAM]CODMET-mess(171,126,1)
          MSG-=[ACLAM]ACTMET-mess(173,126,1)
          Gosub WR_ERR
      Next
      For [ACLAT]ACLAT0 Where CODCLA=[F:ACLA]CODCLA & [ACLAT]ACTMETSTD>="X" & find([ACLAT]ACTMETSTD,ACTSPE(1..NBACT))=0
          MSG=mess(250,126,1)-NAMOBJ-":"-mess(254,126,1)-[ACLAT]CODMETSTD-mess(171,126,1)
          MSG-=[ACLAT]ACTMETSTD-mess(173,126,1)
          Gosub WR_ERR
      Next
    Endif
  Endif
Return

# Representation Classes analysis
$ANA_ASW
  Read [ASW]ASW0=NAMOBJ
  If fstat=0
    If [ASW]CODACT>="X" & find([ASW]CODACT,ACTSPE(1..NBACT))=0
        MSG=mess(251,126,1)-NAMOBJ-mess(171,126,1)-[ASW]CODACT-mess(173,126,1)
        Gosub WR_ERR
    Else
      # Get specifics treatments
      For IJ=0 To [F:ASW]NBRTRT-1
        If [F:ASW]ACTTRT(IJ)>="X" & find([F:ASW]ACTTRT(IJ),ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-mess(170,126,1)-[F:ASW]CODTRT(IJ)-mess(171,126,1)
            MSG-=[F:ASW]ACTTRT(IJ)-mess(173,126,1)
            Gosub WR_ERR
        Endif
      Next
      # Get specifics configuration
      For IJ=0 To [F:ASW]NBRFAC-1
        If [F:ASW]ACTLNKFAC(IJ)>="X" & find([F:ASW]ACTLNKFAC(IJ),ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-func AFNC.MES1(mess(274,126,1),mess(IJ+1,7964,1))-mess(171,126,1)
            MSG-=[F:ASW]ACTTRT(IJ)-mess(173,126,1)
            Gosub WR_ERR
        Endif
      Next
      For [ASWC]ASWC0 Where CODREP=[F:ASW]CODREP & [F:ASWC]ACTCOL>="X" & find([F:ASWC]ACTCOL,ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-mess(259,126,1)-[F:ASWC]CODCOL-mess(171,126,1)
            MSG-=[F:ASWC]ACTCOL-mess(173,126,1)
            Gosub WR_ERR
      Next
      For [ASWF]ASWF0 Where CODREP=[F:ASW]CODREP & [ASWF]ACTFLD>="X" & find([ASWF]ACTFLD,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(255,126,1)-[ASWF]CODFLD-mess(171,126,1)
          MSG-=[ASWF]ACTFLD-mess(173,126,1)
          Gosub WR_ERR
      Next
      For [ASWM]ASWM0 Where CODREP=[F:ASW]CODREP & [ASWM]ACTMET>="X" & find([ASWM]ACTMET,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(253,126,1)-[ASWM]CODMET-mess(171,126,1)
          MSG-=[ASWM]ACTMET-mess(173,126,1)
          Gosub WR_ERR
      Next
      For [ASWS]ASWS0 Where CODREP=[F:ASW]CODREP & [ASWS]ACTSEC>="X" & find([ASWS]ACTSEC,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(256,126,1)-[F:ASWS]CODSEC-mess(171,126,1)
          MSG-=[F:ASWS]ACTSEC-mess(173,126,1)
          Gosub WR_ERR
      Next
      For [ASWB]ASWB0 Where CODREP=[F:ASW]CODREP
          WSEC=[F:ASWB]SECBLC
          Gosub FIND_ACTSEC
          If [F:ASWB]ACTBLC>="X" & find([F:ASWB]ACTBLC,ACTSPE(1..NBACT))=0
              MSG=mess(251,126,1)-NAMOBJ-":"-mess(156,126,1)-[F:ASWB]CODBLC-mess(171,126,1)
              MSG-=[F:ASWB]ACTBLC-mess(173,126,1)
              Gosub WR_ERR
          Elsif WACTSEC>="X" & find(WACTSEC,ACTSPE(1..NBACT))=0
              MSG=mess(251,126,1)-NAMOBJ-":"-mess(156,126,1)-[F:ASWB]CODBLC-mess(171,126,1)
              MSG-=WACTSEC-mess(173,126,1)
              Gosub WR_ERR
          Endif
      Next
      For [ASWO]ASWO0 Where CODREP=[F:ASW]CODREP
       If [F:ASWO]OPTFLGCLA=2
        Read [ACLAO]ACLAO0=[F:ASW]CODCLA;[F:ASWO]OPTCOD
        If !fstat & [F:ACLAO]OPTACT>="X" & find([F:ACLAO]OPTACT,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(263,126,1)-[F:ACLAO]OPTCOD-mess(171,126,1)
          MSG-=[F:ACLAO]OPTACT-mess(173,126,1)
          Gosub WR_ERR
        Endif
       Elsif [F:ASWO]OPTACT>="X" & find([F:ASWO]OPTACT,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(263,126,1)-[F:ASWO]OPTCOD-mess(171,126,1)
          MSG-=[F:ASWO]OPTACT-mess(173,126,1)
          Gosub WR_ERR
       Endif
      Next

      For [ASWR]ASWR0 Where CODREP=[F:ASW]CODREP
          WBLC=[F:ASWR]BLCPRO
          Gosub FIND_ACTBLCSEC
          If [F:ASWR]ACTPRO>="X" & find([F:ASWR]ACTPRO,ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-mess(255,126,1)-[ASWR]CODPRO-mess(171,126,1)
            MSG-=[F:ASWR]ACTPRO-mess(173,126,1)
            Gosub WR_ERR
          Elsif WACTSEC>="X" & find(WACTSEC,ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-mess(255,126,1)-[ASWR]CODPRO-mess(171,126,1)
            MSG-=WACTSEC-mess(173,126,1)
            Gosub WR_ERR
          Elsif WACTBLC>="X" & find(WACTBLC,ACTSPE(1..NBACT))=0
            MSG=mess(251,126,1)-NAMOBJ-":"-mess(255,126,1)-[ASWR]CODPRO-mess(171,126,1)
            MSG-=WACTBLC-mess(173,126,1)
            Gosub WR_ERR
          Endif
      Next
      For [ASWK]ASWK0 Where CODREP=[F:ASW]CODREP & [ASWK]ACVLNK>="X" & find([ASWK]ACVLNK,ACTSPE(1..NBACT))=0
          MSG=mess(251,126,1)-NAMOBJ-":"-mess(257,126,1)-[ASWK]CODLNK-mess(171,126,1)
          MSG-=[ASWK]ACVLNK-mess(173,126,1)
          Gosub WR_ERR
      Next
    Endif
  Endif
Return

#--------------------------------------------#
# Find actvity code for a bloc/section (WBLC)
#--------------------------------------------#
$FIND_ACTBLCSEC
Raz WACTBLC, WACTSEC
Read [ASWB]ASWB0=[F:ASW]CODREP;WBLC
If !fstat
  WACTBLC=[F:ASWB]ACTBLC
  Read [ASWS]ASWS0=[F:ASW]CODREP;[F:ASWB]SECBLC
  If !fstat
    WACTSEC=[F:ASWS]ACTSEC
  Endif
Endif
Return

#--------------------------------------------#
# Find actvity code for a section (WSEC)
#--------------------------------------------#
$FIND_ACTSEC
Raz WACTSEC

Read [ASWS]ASWS0=[F:ASW]CODREP;WSEC
If !fstat
  WACTSEC=[F:ASWS]ACTSEC
Endif
Return

