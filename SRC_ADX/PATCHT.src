# Program test : is it present in the folder to be patched ?
$ANA_TRT
    Gosub TSTSUP
    If !OK
#      If APPLI<>GDOSX3
        Call EXISTE_ADX("",APPLI,NAMOBJ,OKTRT) From ORDSYS
        If OKTRT>0
            MSG=mess(170,126,1)-NAMOBJ+".adx"-mess(172,126,1)-mess(173,126,1)
            Gosub WR_ERR
        Elsif filinfo(filpath("TRT",NAMOBJ,"src",APPLI),0)>=0
