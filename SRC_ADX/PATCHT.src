## Test d'intégration d'un traitement/état

$TSTSUP
OK = 0
# Dans le dossier X3, on intègre toujours
If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>=0
 OK = 1 : Return
Endif
# Dans un dossier "test" aussi
Read [ADW]ADW0 = "";"";"TEST"
If !fstat & val([F:ADW]VALEUR)=2
 OK = 1 : Return
Endif
# Si le nom du patch commence par src, aussi
If pat(toupper(TRAIT(P)),"SRC*")
 OK = 1 : Return
Endif
# Si l'objet est spécifique et qu'il existe ou que c'est un dossier spécif, aussi
If find(left$(NAMOBJ,1),"X","Y","Z")
&  or left$(NAMOBJ,3)="SPE" or left$(NAMOBJ,3)="SPV"
&  or pat(NAMOBJ,"CNS*SPE")<>0 or pat(NAMOBJ,"CNS*SPV")<>0
 If filinfo(filpath("TRT",NAMOBJ,"src",APPLI),0)>0
  OK = 1 : Return
 Else
  Read [ADW]ADW0 = "";"";"SPECIF"
  If !fstat & val([F:ADW]VALEUR)=2
   OK = 1 : Return
  Endif
 Endif
Endif
Return

$ANA_AMC
[L]CLE1 = left$(NAMOBJ,instr(1,NAMOBJ,"~")-1)
[L]CLE2 = right$(NAMOBJ,instr(1,NAMOBJ,"~")+1)
For [AMC]AMC0(2) Where TYPZON = val(CLE1) & IDENT1 = CLE2
    If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
    If clalev([F:ASW])=0 : Local File ASHW [ASW] : Endif
    If clalev([F:ACLA])=0 : Local File ACLASSE [ACLA] : Endif
    If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
    Case val(CLE1)
      When 1 : Read [ATB]CODFIC=CLE2 : WACTAMC=[F:ATB]CODACT
      When 2 : Read [AMK]CODMSK=CLE2 : WACTAMC=[F:AMK]CODACT
      When 3 : Read [ACLA]ACLA0=CLE2 : WACTAMC=[F:ACLA]CODACT
      When 4 : Read [ASW]ASW0=CLE2   : WACTAMC=[F:ASW]CODACT
    Endcase
  If WACTAMC>="X" & find(WACTAMC,ACTSPE(1..NBACT))=0
    MSG=mess(119,124,1)-CLE1-CLE2
    MSG-=mess(171,126,1)-WACTAMC-mess(173,126,1)
    Gosub WR_ERR
  Endif
Next
Return

$ANA_DOC
