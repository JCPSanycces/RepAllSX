#########################################################
#  SUBSPCS : Fenêtre de selection des tarifs
#  (sans passer par sélection de l'objet)  
#########################################################

Subprog C_FINTAR(VALEUR)
Variable Char     VALEUR
If VALEUR < [M]DEBTAR
 Call message(mess(202,100,1)) From GESECRAN
 mkstat=1
Endif
End
########################################
Subprog AV_NBTAR
# --> déf. bouton gestion des tarifs  
Raz GBOUT1
If [M]PLI(nolign-1)<>""
  GBOUT1=mess(42,198,1)  
Endif
End

