##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'une cible                        #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File SECPST [SPT1]
    Local File SECPSTSEL [SPS1]
  Else
    Local File =[M]DOSORG+".SECPST" [SPT1]
    Local File =[M]DOSORG+".SECPSTSEL" [SPS1]
  Endif
  If [M]DOSDES = nomap Then
    Local File SECPST [SPT2]
    Local File SECPSTSEL  [SPS2]
  Else
    Local File =[M]DOSDES+".SECPST" [SPT2]
    Local File =[M]DOSDES+".SECPSTSEL" [SPS2]
  Endif
  OK=1
  Look [SPT2]SPT0=TABLE
  If !fstat Then
     OK = 2
     Call AVERTIR([M]DOSDES - TABLE - mess(148,196,1),OK) From GESECRAN
     If OK <> 2 Then
       OK = 0
     Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [SPT1], [SPS1], [SPT2], [SPS2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'une cible                 #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [SPT2]
  Delete [SPS2] Where SECPSTNUM = TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".SECPSTSEL" - TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("SPS2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [SPT2] Where SECPSTNUM = TABLE
  If fstat = 1 Then
    GOK = -1  
    GLOCK = "$" + [M]DOSDES + ".SECPST" - TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("SPT2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  If GOK = 1 Then
    Read [SPT1]SPT0=TABLE
    If !fstat Then
      [F:SPT2] = [F:SPT1]
      Write [SPT2]
      If fstat Then
        GOK = 0  
        Call FSTA("SPT2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [SPS1] Where [F:SPS1]SPSNUM = TABLE
    For [SPS1]
      [F:SPS2] = [F:SPS1]
      Write [SPS2]
      If fstat Then
        GOK = 0  
        Call FSTA("SPS2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [SPS1]
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback 
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback 
  Call ROLL From GLOCK  
  If !GROLL Then
    Goto TRT_COPIE 
  Endif 
Return
