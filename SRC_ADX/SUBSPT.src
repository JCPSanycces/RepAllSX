#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet SPT
Call OBJET ("SPT", GBIDC1, GBIDC2) From GOBJET
End

##########################################################################################################
## Gestio objet SPT Secteur LEAD Module Action commercial frevrier 2007
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "LIENS"        : Gosub LIENS
    When "SETBOUT"      : Gosub SETBOUT
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "INICRE"       : Gosub INICRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "INIMOD"       : Gosub INIMOD
    When "MODIF"        : Gosub MODIF
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
  If clalev([F:AIN])=0 : Local File CONTACTCRM [AIN] : Endif
  If clalev([F:LDS])=0 : Local File LEAD [LDS] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
  Gosub INITFORMULE From SUBSPTB
Return

##########################################################################################################
$DEBUT
  Diszo [M:SPT1]SPTSYN
Return

##########################################################################################################
$SETBOUT
  If GUSRAUZ(1) = "" Then
    If REP = "" Then
      CHMEN += "G"
    Endif
  Else
    If REP = "" Then
      If instr(1, GUSRAUZ(1), 'G') Then
        CHMEN += "G"
      Endif
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET    
Return

##########################################################################################################
$LIENS
  Gosub INITFORMULE From SUBSPTB
  Gosub LOAD_SPS From SUBSPTB
  Gosub REGROUPEMENT From SUBSPTB
  Diszo [M:SPT1]SPTSYN
Return

##########################################################################################################
$RAZCRE
  Gosub INITFORMULE From SUBSPTB
Return

##########################################################################################################
$RAZDUP
Return

##########################################################################################################
$VERIF_CRE_MOD
  GOK = 1
  Gosub VERIF_SPS From SUBSPTB
  If GOK < 1 Then
    OK = 0
    GERR = 2
    Return
  Endif
  Gosub REGROUPEMENT From SUBSPTB
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$INICRE
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 06/03/2009 : X3SUIVI52963 Texte traduisible
  Call MAJTEXTRA([M:SPT0]SECPSTAXX, "SECPST", "SECPSTAXX", [M:SPT0]SPTNUM, "") From ATEXTRA
  Gosub SAVE_SPS From SUBSPTB
  If GOK < 1 Then
    GERR = 2
    Return
  Endif
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  Affzo [M:SPT1]1-99
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$INIMOD
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_MOD
  Affzo [M:SPT1]1-99
Return

##########################################################################################################
$AV_ANNULE
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call SUPTEXTRA("SECPST", "SECPSTAXX", [M:SPT0]SPTNUM, "") From ATEXTRA
Return

##########################################################################################################
$ANNULE
Return

##########################################################################################################
Subprog AS_SPSOPD(VALEUR)
Variable Integer VALEUR
Local Integer INOLIGN

  INOLIGN = nolign
  #Raz GMENLOC
  If INOLIGN-1 = 0 Then
    [M:SPT1]SPSOPD(0) = 1
    If [M:SPT1]SPTSYN = "" Then
      [M:SPT1]SPTSYN = "1"
      Affzo [M:SPT1]SPTSYN
    Endif
    mkstat = 2
  Else
    GMENLOC(1) = 1
  Endif
End

##########################################################################################################
Subprog AM_SPSOPD(VALEUR)
Variable Integer VALEUR

  [M:SPT1]SPSOPD(nolign-1) = VALEUR
  Gosub REGROUPEMENT From SUBSPTB
  Affzo [M:SPT1]SPTSYN
End

##########################################################################################################
Subprog C_PARDEB(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  Raz SZMESSAGE
  IBRETOUR = 1
  Call CTRLPARENTHESE (VALEUR,0,SZMESSAGE,IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_PARDEB(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer INBPARENTHESE
Local Char SZRESULT

  Raz SZMESSAGE
  IBRETOUR = 1
  INBPARENTHESE = 0
  Raz SZRESULT
  Call GETNBPARENTHESE (VALEUR, 0,INBPARENTHESE,SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    End
  Endif
  [M:SPT1]NBPARDEB(nolign-1) = INBPARENTHESE
  [M:SPT1]PARDEB(nolign-1) = SZRESULT
  Gosub REGROUPEMENT From SUBSPTB
  Affzo [M:SPT1]SPTSYN
End

##########################################################################################################
Subprog AM_SPSTAB(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "LEAD" and VALEUR <> "CONTACTCRM" and VALEUR <> "BPADDRESS" Then
    #Erreur lecture table des tables
    GMESSAGE = mess(620,177,1)
    mkstat = 2
  Else
    [M:SPT1]SPSFIE(nolign-1) = ""
    [M:SPT1]SPSINDOK(nolign-1) = 0
    If VALEUR <> "" Then
      Read [ATB]CODFIC=VALEUR
      If fstat = 0 Then
        [M:SPT1]SPSABRFIC(nolign-1) = [F:ATB]ABRFIC
      Else
        #Erreur lecture table des tables
        GMESSAGE = mess(558,177,1)
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SPSFIE(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR
Local Integer IVALEUR
Local Integer INOLIGN

  INOLIGN = nolign
  [M:SPT1]SPSINDNUM(INOLIGN-1) = 0
  [M:SPT1]SPSFIETYP(INOLIGN-1) = 0
  If VALEUR <> "" Then
    If [M:SPT1]SPSTAB(INOLIGN-1) <> "" Then
      Read [ATB]CODFIC=[M:SPT1]SPSTAB(INOLIGN-1)
      If fstat = 0 Then
        [M:SPT1]SPSABRFIC(INOLIGN-1) = [F:ATB]ABRFIC
      Else
        [M:SPT1]SPSABRFIC(INOLIGN-1) = ""
      Endif
    Endif
  Endif
  If VALEUR = "" or [M:SPT1]SPSTAB(INOLIGN-1) = "" Then
    [M:SPT1]SPSINDOK(INOLIGN-1) = 0
  Else
    Local File =[M:SPT1]SPSTAB(INOLIGN-1) [XXX0]
    #
    If evalue("dim([F:XXX0]" + VALEUR + ")") > 1 Then
      [M:SPT1]SPSINDOK(INOLIGN-1) = 1
    Else
      [M:SPT1]SPSINDOK(INOLIGN-1) = 0
    Endif
    #
    SZVALEUR = "type([F:XXX0]" + VALEUR + ")"
    IVALEUR = evalue(SZVALEUR)
    Case IVALEUR
      When 1, 2, 4, 5, 6, 7, 9
        #Numerique
       [M:SPT1]SPSFIETYP(INOLIGN-1) = 2
       [M:SPT1]VALCODTYP(INOLIGN-1) = "DBC"
      When 3    
        #date
       [M:SPT1]SPSFIETYP(INOLIGN-1) = 3
       [M:SPT1]VALCODTYP(INOLIGN-1) = "D"
      When Default
        #Alphanumerique
       [M:SPT1]SPSFIETYP(INOLIGN-1) = 1
       [M:SPT1]VALCODTYP(INOLIGN-1) = "A"
    Endcase
    Close Local File [XXX0]
    Read [ATZ]CODZONE=[M:SPT1]SPSTAB(INOLIGN-1);VALEUR
    If fstat = 0 Then
      [M:SPT1]VALCODTYP(INOLIGN-1) = [F:ATZ]CODTYP
      [M:SPT1]VALLONG(INOLIGN-1) = [F:ATZ]LONG
      [M:SPT1]VALNOLIB(INOLIGN-1) = [F:ATZ]NOLIB
      [M:SPT1]VALTCT(INOLIGN-1) = ""
      [M:SPT1]VALNOLIB(INOLIGN-1) = [F:ATZ]NOLIB
      [M:SPT1]VALSUPP(INOLIGN-1) = ""
      [M:SPT1]VALOPTION(INOLIGN-1) = ""
    Endif
  Endif
  Affzo [M:SPT1]SPSTAB(nolign-1)
End

##########################################################################################################
Subprog AS_SPSINDNUM(VALEUR)
Variable Decimal VALEUR

  If [M:SPT1]SPSINDOK(nolign-1) <> 1 Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AS_SPSCND(VALEUR)
Variable Integer VALEUR

  GMENLOC(10) = 1
End

