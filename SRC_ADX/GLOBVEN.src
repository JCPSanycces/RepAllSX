###########################################################
# Définition des variables
###########################################################
Subprog DEFVAR

Call DEFVAR From WWAGLOBVEN
#CHECK IGNORE_BEGIN
GPOINT="DEFVARVEN" : Gosub ENTREE From EXEFNC
#CHECK IGNORE_END
End
###########################################################
# Initialisation des variables pour la session
###########################################################
Subprog INIVAR

GNETMAR = 1
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
# --- Nb de catégories de commission
Read [ACV]CODACT = "COM"
GCOMCAT = [F:ACV]DIME

GORDCAT = 4                       :   # Toutes les catégories de commande
# X3-1152 : Non invoiceable deliveries
#GDLVTYP = 5                       :   # Tous les types de livraisons
GDLVTYP = 4                       :   # Tous les types de livraisons
# X3-1152 : Non invoiceable deliveries
GFACTYP = 5                       :   # Tous les types de factures

End

