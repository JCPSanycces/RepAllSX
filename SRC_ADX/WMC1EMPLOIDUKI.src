####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : REFNUM Employee ID ( Field A 15)
####################################################################

$SET_REFNUM
If [L]_AOLDVAL<>this.REFNUM
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_REFNUM
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.REFNUM
 Gosub PROPAGATE_REFNUM
Endif
Return

$INIT_REFNUM
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "REFNUM"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_REFNUM
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "REFNUM"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_REFNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_REFNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_REFNUM
[L]CURPRO = "REFNUM"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.REFNUM,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_REFNUM
[L]CURPRO = "REFNUM"
Return

$_AOTHERS_REFNUM
[L]CURPRO = "REFNUM"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_REFNUM
[L]CURPRO = "REFNUM"
Return

$PROPAGATE_REFNUM
this.isReadonly = 0
[L]CURPRO = "REFNUM"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_REFNUM
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "REFNUM"
$_LNKPRO_REFNUM
Return

$_ALOADATTRIBUTE_REFNUM
[L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$isMandatory","true")
Return


