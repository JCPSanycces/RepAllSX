# 9 : AGDCKK Agreement ( Field Local menu number 1)
####################################################################

$SET_AGDCKK
If [L]_AOLDVAL<>this.AGDCKK
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_AGDCKK
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.AGDCKK
 Gosub PROPAGATE_AGDCKK
Endif
Return

$INIT_AGDCKK
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "AGDCKK"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.AGDCKK=0 and fmet this.AGETATTRIBUTE("AGDCKK","$isMandatory")="true"
 this.AGDCKK = 1
Endif
Return
 
$CONTROL_AGDCKK
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "AGDCKK"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_AGDCKK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_AGDCKK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_AGDCKK
[L]CURPRO = "AGDCKK"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.AGDCKK=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_AGDCKK
[L]CURPRO = "AGDCKK"
If this.AGDCKK<0 or this.AGDCKK>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.AGDCKK)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_AGDCKK
[L]CURPRO = "AGDCKK"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_AGDCKK
[L]CURPRO = "AGDCKK"
Return

$PROPAGATE_AGDCKK
this.isReadonly = 0
[L]CURPRO = "AGDCKK"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_AGDCKK
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
[L]CURPRO = "AGDCKK"
$_LNKPRO_AGDCKK
Return


