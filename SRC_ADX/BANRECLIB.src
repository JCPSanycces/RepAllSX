#<AdxTL>@(#)6.0.0.0 $Revision$
####################################################################################
# Process Name: BANRECLIB
# Description : Bank Reconciliation Library
# Date        : June 23rd, 2011
####################################################################################
$INIT_DESVCR

[M:HAE1]DESVCR = GADJREA
Call LECTEXTRA([M:HAE1]DESVCR,"ATABDIV","LNGDES","383",GADJREA) From ATEXTRA
Affzo [M:HAE1]DESVCR
Diszo [M:HAE1]DESVCR

Return
###################################################################################
Subprog CREBED(INUM)
Value Char INUM

Local Integer DOK

If [F:BAN]BAN <>  [F:BEH]BAN
    Read [F:BAN]BAN0=[F:BEH]BAN
Endif

For [F:DAE] Where NUM=INUM and LEDTYP = GTYPGEN and ACC = [F:BAN]BANACC

    If [F:DAE]ACCDAT <= [F:BEH]BNKDAT
        Raz [F:BED]
        [F:BED]RBKNUM = [F:BEH]RBKNUM
        [F:BED]ACCNUM = [F:DAE]ACCNUM
        [F:BED]ADJREA = GADJREA
        [F:BED]CREDAT = date$
        [F:BED]CREUSR = GUSER
        Write [F:BED]
    
        If fstat
          GOK = 0 : Call FSTA("BED") From GLOCK 
          Break 
        Endif
    Else
        DOK = 1
        Call OUINON(mess(70,120,1),DOK) From GESECRAN 
        If DOK = 1
          GOK = 0
          Break
        Endif
    Endif

Next

End

###################################################################################
$CHECK_RECONCILED

If !clalev([F:BEH])  : Local File BANREC     [BEH]  : Endif 
If !clalev([F:BED])  : Local File BANRECD    [BED]  : Endif 

# Lookup the Reconciliation Lock Parameter
Call PARAM([F:PYH]CPY,"RECLCK",PARAM2) From ADOVAL
If PARAM2 = "2"
  Filter [PAN] Where TYPNUM=TPYH & NUM=NPYH & RVSACCNUM=0
  For [PAN]
  
    Read [F:DAE]DAE2 = [F:PAN]ACCNUM
    
    If !fstat and [F:DAE]CHK <> ""

      # See if it exists on a Bank Reconciliation
      Read [F:BED]BED1 = [F:DAE]ACCNUM
      If fstat = 0
        Read [F:BEH]BEH0=[F:BED]RBKNUM
        If fstat = 0
          GMESSAGE = mess(69,120,1) - [F:BEH]RBKNUM
          If [F:BEH]STAFLG = 3  # Closed
            GERR = 1
          Else  # Just a warning
            Call ECR_TRACE(GMESSAGE,0) From GESECRAN
          Endif
          Break
        Endif
      Else      # Reconciled but not on a Bank Rec            
        GMESSAGE = mess(54,120,1)
        GERR = 1
        Break
      Endif
    Endif
  Next
  Filter [F:PAN]
Endif

Return
