Subprog AS_AMT1(VALEUR)
Variable Decimal VALEUR

Local Tinyint  DCLFMTVER_DVPHP
Local Tinyint  TOTQ06A_DVPHP
Local Tinyint  TOTQ06AR_DVPHP

Call SET_DCLFMTVER([F:DVPH]ENDDAT, [L]DCLFMTVER_DVPHP , [L]TOTQ06A_DVPHP , [L]TOTQ06AR_DVPHP  ) From CALVATPOR

If [L]DCLFMTVER_DVPHP = 0
  If find([M:DVPHP2]DCLFLD1(nolign-1),"010", "011", "090", "091", "092", "093", "094", "105")
    GMESSAGE = mess(101,7776,1)
    GERR     = 2
    mkstat   = 2
  Endif
Else
  If find([M:DVPHP2]DCLFLD1(nolign-1),"010", "011", "090", "091", "092", "093", "094", "106")
    GMESSAGE = mess(101,7776,1)
    GERR     = 2
    mkstat   = 2
  Endif
Endif

End
