######################################################################################
## Section automatically added (screen DVPHP0) 11/08/2017 15:01:48 (VAVIL)
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

If month([M:DVPHP0]ENDDAT) - month(VALEUR) = 0
  [M:DVPHP1]DCLMON = month([M:DVPHP0]ENDDAT)
  [M:DVPHP1]DCLQUA = 0
Else
  [M:DVPHP1]DCLMON = 0
  If month([M:DVPHP0]ENDDAT)<4
    [M:DVPHP1]DCLQUA = 1
  Elsif month([M:DVPHP0]ENDDAT)>=4 & month([M:DVPHP0]ENDDAT)<7
    [M:DVPHP1]DCLQUA = 2
  Elsif month([M:DVPHP0]ENDDAT)>=7 & month([M:DVPHP0]ENDDAT)<10
    [M:DVPHP1]DCLQUA = 3
  Else
    [M:DVPHP1]DCLQUA = 4
  Endif
Endif

Affzo [M:DVPHP1]

End
######################################################################################
######################################################################################
Subprog AM_AN1LOC(VALEUR)
Variable Integer VALEUR

Call SHOW_HIDE_ANLOC (VALEUR, [M:DVPHP1]AN2LOC)

End
######################################################################################
######################################################################################
Subprog AM_AN2LOC(VALEUR)
Variable Integer VALEUR

Call SHOW_HIDE_ANLOC ([M:DVPHP1]AN1LOC, VALEUR)

End
######################################################################################
######################################################################################
Subprog AS_AN1LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPHP1]HQRLOC | I = [M:DVPHP1]AN2LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
######################################################################################
######################################################################################
Subprog AS_AN2LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPHP1]HQRLOC | I = [M:DVPHP1]AN1LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
