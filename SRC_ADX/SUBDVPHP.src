#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################################
######################################################################################
### DCLTYP -> 1 Periodic; 2 Annual; 3 Recap; 4 European serv.
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "FILTRE"       : Gosub FILTRE
  When "RAZCRE"       : Gosub RAZCRE
  When "INICRE"       : Gosub INICRE
  When "INIMOD"       : Gosub INIMOD
  When "CREATION"     : Gosub CREATION
  When "APRES_CRE"    : Gosub APRES_CRE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "VERIF_CRE"    : Gosub VERIF_CRE
  When "VERIF_MOD"    : Gosub VERIF_MOD
  When "EXEBOUT"      : Gosub EXEBOUT
  When "LIENS"        : Gosub LIENS
  When "ANNULE"       : Gosub ANNULE
  When "MODIF"        : Gosub MODIF
  When "SETBOUT"      : Gosub SETBOUT
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev([F:CPY])   :  Local File COMPANY    [CPY]          : Endif
If !clalev([F:DVPB])  :  Local File DCLVATPORB [DVPB]         : Endif
If !clalev([F:DVPF])  :  Local File DCLVATPORF [DVPF]         : Endif
If !clalev([F:DVPL])  :  Local File DCLVATPORL [DVPL]         : Endif
If !clalev([F:DVPP])  :  Local File DCLVATPORP [DVPP]         : Endif
If !clalev([F:TCA])   :  Local File TABCOUAFF  [TCA]          : Endif
If !clalev([F:TCY])   :  Local File TABCOUNTRY [TCY]          : Endif

Local Char LNUM(GLONVCR)
Local Char SITE(GLONFCY)

Local Integer I, RCOUNT, STAT
#Issue 54535 – 2017-09-13 by MRDAB - Law 221/2017
Local Decimal TOT41, MAINTOT41
Local Char FLDNAME
#Issue end

Gosub DEC_COM_VARS From CALVATPOR

Return
######################################################################################
######################################################################################
$FILTRE

FILTSUP = "[F:DVPH]DCLTYP = 1"

Return
######################################################################################
######################################################################################
$RAZCRE

[M:DVPHP0]DCLTYP = 1

Return
######################################################################################
######################################################################################
$INICRE

Gosub GET_CPYVARS

Call LECTCA(2,OK) From SUBTCA
If fstat | !OK
  GERR=1 : GMESSAGE=mess(58,105,1)-mess(2,14,1)-mess(250,199,1) : Return
Endif
GMANCOU = [F:TCA]MANCOU(13)
GCPT    = [F:TCA]CODNUM(13)
STAT    = 0

If  GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:DVPHP0]DCLNUM,2)="")
  Call NUMERO (GCPT,SITE,[F:DVPH]STRDAT,"",LNUM,STAT) From SUBANM
  If GOK>0 & STAT=0
      [F:DVPH]DCLNUM   = LNUM
      [M:DVPHP0]DCLNUM = LNUM
      Affzo [M:DVPHP0]DCLNUM
  Else
     Local Char MESSA(80)
     GMESSAGE=mess(60,199,1)-"("+GCPT+") : "
     Gosub MESSAGE From SUBANM
     GMESSAGE-=MESSA : GERR=1 : GOK=0 : Return
  Endif
Endif

Gosub COMMON_INISAVE

Return
######################################################################################
######################################################################################
$INIMOD

Gosub COMMON_INISAVE

Return
######################################################################################
######################################################################################
$COMMON_INISAVE

Read [F:DVPP]DVPP0=[M:DVPHP0]CPY;year([M:DVPHP0]STRDAT)
If fstat : Raz [F:DVPP] : Endif

[F:DVPH]FAN1OPE = 0 #Operations in Continente
[F:DVPH]FAN2OPE = 0 #Operations in Azores
[F:DVPH]FAN3OPE = 0 #Operations in Madeira

For I = 0 To [M:DVPHP2]NBLIG2 - 1
  If [M:DVPHP2]AMT2 <> 0
    Case [F:DVPP]AN1LOC
      When 1
        [F:DVPH]FAN1OPE = 1
      When 2
        [F:DVPH]FAN2OPE = 2
      When 3
        [F:DVPH]FAN3OPE = 3
    Endcase
    Break
  Endif
Next

For I = 0 To [M:DVPHP2]NBLIG3 - 1
  If [M:DVPHP2]AMT3 <> 0
    Case [F:DVPP]AN2LOC
      When 1
        [F:DVPH]FAN1OPE = 1
      When 2
        [F:DVPH]FAN2OPE = 2
      When 3
        [F:DVPH]FAN3OPE = 3
    Endcase
    Break
  Endif
Next

If [M:DVPHP1]ANXI<>""
  [F:DVPH]FRECAP_UE = 5
Endif

If [M:DVPHP1]DCLMON>0
  [F:DVPH]FPERIOD = format$("N0:2", [M:DVPHP1]DCLMON)
Elsif [M:DVPHP1]DCLQUA>0
  Case [M:DVPHP1]DCLQUA
    When 1 : [F:DVPH]FPERIOD = "03T"
    When 2 : [F:DVPH]FPERIOD = "06T"
    When 3 : [F:DVPH]FPERIOD = "09T"
    When 4 : [F:DVPH]FPERIOD = "12T"
  Endcase
Endif

Filter [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & find([F:DVPL]LINTYP, 1, 2)
[F:DVPH]FAN1LINCOUNT = rowcount([F:DVPL]) : Filter [F:DVPL]

Filter [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & find([F:DVPL]LINTYP, 3, 4, 5, 6, 7)
[F:DVPH]FAN2LINCOUNT = rowcount([F:DVPL]) : Filter [F:DVPL]

Filter [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 8
[F:DVPH]FAN3LINCOUNT = rowcount([F:DVPL]) : Filter [F:DVPL]

Filter [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 9
[F:DVPH]FAN40LINCONT = rowcount([F:DVPL]) : Filter [F:DVPL]

Filter [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 10
[F:DVPH]FAN41LINCONT = rowcount([F:DVPL]) : Filter [F:DVPL]

Return
######################################################################################
######################################################################################
$EXEBOUT

If BOUT = "1"
  Gosub RELIT From GOBJSUB
Endif

Return
######################################################################################
######################################################################################
$LIENS

GSOCIETE = [F:DVPH]CPY

Call SET_DCLFMTVER([F:DVPH]ENDDAT, [L]DCLFMTVER, [L]TOTQ06A, [L]TOTQ06AR ) From CALVATPOR

Gosub GET_CPYVARS

Gosub LOAD_FIELDS

Gosub LOAD_LISTS

Gosub LOAD_DEC

[M:DVPHP0]CUR          = [F:CPY]ACCCUR
Affzo [M:DVPHP0]CUR

Call SHOW_HIDE_ANLOC ([M:DVPHP1]AN1LOC, [M:DVPHP1]AN2LOC)

Return
######################################################################################
######################################################################################
$LOAD_DEC

#annex I
[M:DVPHP3]FLDAN102 = [F:DVPH]FLDAN102
[M:DVPHP3]FLDAN104 = [F:DVPH]FLDAN104
[M:DVPHP3]FLDAN105 = [F:DVPH]FLDAN105
[M:DVPHP3]FLDAN106 = [F:DVPH]FLDAN106

#annex II
[M:DVPHP4]FLDAN22006B = [F:DVPH]FLDAN22006B
[M:DVPHP4]FLDAN22006V = [F:DVPH]FLDAN22006V
[M:DVPHP4]FLDAN22106B = [F:DVPH]FLDAN22106B
[M:DVPHP4]FLDAN22106V = [F:DVPH]FLDAN22106V

[M:DVPHP5]FLDAN22206B = [F:DVPH]FLDAN22206B
[M:DVPHP5]FLDAN22206V = [F:DVPH]FLDAN22206V
[M:DVPHP5]FLDAN22306B = [F:DVPH]FLDAN22306B
[M:DVPHP5]FLDAN22306V = [F:DVPH]FLDAN22306V

[M:DVPHP6]FLDAN22406B = [F:DVPH]FLDAN22406B
[M:DVPHP6]FLDAN22406V = [F:DVPH]FLDAN22406V
[M:DVPHP6]FLDAN206B   = [F:DVPH]FLDAN206B
[M:DVPHP6]FLDAN206V   = [F:DVPH]FLDAN206V
[M:DVPHP6]FLDAN207B   = [F:DVPH]FLDAN207B
[M:DVPHP6]FLDAN207V   = [F:DVPH]FLDAN207V

#annex III
[M:DVPHP7]FLDAN302    = [F:DVPH]FLDAN302
[M:DVPHP7]FLDAN303    = [F:DVPH]FLDAN303
[M:DVPHP7]FLDAN304    = [F:DVPH]FLDAN304
[M:DVPHP7]FLDAN305    = [F:DVPH]FLDAN305
[M:DVPHP7]FLDAN306    = [F:DVPH]FLDAN306
[M:DVPHP7]FLDAN307    = [F:DVPH]FLDAN307
[M:DVPHP7]FLDAN308    = [F:DVPH]FLDAN308
[M:DVPHP7]FLDAN309    = [F:DVPH]FLDAN309

#annex 40
[M:DVPHP8]FLDAN4003   = [F:DVPH]FLDAN4003
[M:DVPHP8]FLDAN4003A  = [F:DVPH]FLDAN4003A
[M:DVPHP8]FLDAN4003B  = [F:DVPH]FLDAN4003B
[M:DVPHP8]FLDAN4004   = [F:DVPH]FLDAN4004
[M:DVPHP8]FLDAN4004A  = [F:DVPH]FLDAN4004A
[M:DVPHP8]FLDAN4004B  = [F:DVPH]FLDAN4004B

#annex 41
[M:DVPHP9]FLDAN4103A  = [F:DVPH]FLDAN4103A
[M:DVPHP9]FLDAN4103B  = [F:DVPH]FLDAN4103B
[M:DVPHP9]FLDAN4104A  = [F:DVPH]FLDAN4104A
[M:DVPHP9]FLDAN4104B  = [F:DVPH]FLDAN4104B
#Issue 54535 – 2017-09-07 by MRDAB - Law 221/2017 - added fields C, D & total
[M:DVPHP9]FLDAN4103C  = [F:DVPH]FLDAN4103C
[M:DVPHP9]FLDAN4103D  = [F:DVPH]FLDAN4103D
[M:DVPHP9]FLDAN4104C  = [F:DVPH]FLDAN4104C
[M:DVPHP9]FLDAN4104D  = [F:DVPH]FLDAN4104D

[M:DVPHP9]FLDAN41TOT  = func CALVATPORP.CAL_TOT41()
#Issue end
Return
######################################################################################
######################################################################################
$LOAD_FIELDS

Raz [M:DVPHP2]

For [F:DVPF] Where [F:DVPF]DCLNUM = [M:DVPHP0]DCLNUM
  Assign "[M:DVPHP2]DCLFLD"+num$([F:DVPF]DCLPAG)+"("+num$(evalue("[M:DVPHP2]NBLIG"+num$([F:DVPF]DCLPAG)))+")" With [F:DVPF]DCLFLD
  Assign "[M:DVPHP2]AMT"+num$([F:DVPF]DCLPAG)   +"("+num$(evalue("[M:DVPHP2]NBLIG"+num$([F:DVPF]DCLPAG)))+")" With [F:DVPF]AMT
  Assign "[M:DVPHP2]NBLIG"+num$([F:DVPF]DCLPAG) With evalue("[M:DVPHP2]NBLIG"+num$([F:DVPF]DCLPAG)) + 1
Next

Return
######################################################################################
######################################################################################
$LOAD_LISTS

Raz [M:DVPHP3]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 1
  [M:DVPHP3]AMT(I)    = [F:DVPL]AMTBAS
  [M:DVPHP3]EECNUM(I) = [F:DVPL]EECNUM
  [M:DVPHP3]LIN(I)    = [F:DVPL]LSTLIN
  [M:DVPHP3]MON(I)    = [F:DVPL]MON
  [M:DVPHP3]YEA(I)    = [F:DVPL]YEA
  I                  += 1
  [M:DVPHP3]NBLIG1    = I
Next

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 2
  [M:DVPHP3]AMT2(I)      = [F:DVPL]AMTBAS
  [M:DVPHP3]LIN2(I)      = [F:DVPL]LSTLIN
  [M:DVPHP3]MON2(I)      = [F:DVPL]MON
  [M:DVPHP3]POREXPDCL(I) = [F:DVPL]VCRNUM
  [M:DVPHP3]YEA2(I)      = [F:DVPL]YEA
  I                     += 1
  [M:DVPHP3]NBLIG2       = I
Next

Raz [M:DVPHP4]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 3
  [M:DVPHP4]AMTBAS20(I)     = [F:DVPL]AMTBAS
  [M:DVPHP4]AMTVAT20(I)     = [F:DVPL]AMTVAT
  [M:DVPHP4]EECNUM20(I)     = [F:DVPL]EECNUM
  [M:DVPHP4]LINE20(I)       = [F:DVPL]LSTLIN
  [M:DVPHP4]MON20(I)        = [F:DVPL]MON
  [M:DVPHP4]PORIMPLIQN20(I) = [F:DVPL]VCRNUM
  [M:DVPHP4]CRY20(I)        = [F:DVPL]CRY
  [M:DVPHP4]YEA20(I)        = [F:DVPL]YEA
  I                        += 1
  [M:DVPHP4]NBLIG20         = I
Next

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 4
  [M:DVPHP4]AMTBAS21(I)     = [F:DVPL]AMTBAS
  [M:DVPHP4]AMTVAT21(I)     = [F:DVPL]AMTVAT
  [M:DVPHP4]EECNUM21(I)     = [F:DVPL]EECNUM
  [M:DVPHP4]LINE21(I)       = [F:DVPL]LSTLIN
  [M:DVPHP4]MON21(I)        = [F:DVPL]MON
  [M:DVPHP4]PORIMPLIQN21(I) = [F:DVPL]VCRNUM
  [M:DVPHP4]CRY21(I)        = [F:DVPL]CRY
  [M:DVPHP4]YEA21(I)        = [F:DVPL]YEA
  I                        += 1
  [M:DVPHP4]NBLIG21         = I
Next

Raz [M:DVPHP5]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 5
  [M:DVPHP5]AMTBAS22(I)     = [F:DVPL]AMTBAS
  [M:DVPHP5]AMTVAT22(I)     = [F:DVPL]AMTVAT
  [M:DVPHP5]EECNUM22(I)     = [F:DVPL]EECNUM
  [M:DVPHP5]LINE22(I)       = [F:DVPL]LSTLIN
  [M:DVPHP5]MON22(I)        = [F:DVPL]MON
  [M:DVPHP5]PORIMPLIQN22(I) = [F:DVPL]VCRNUM
  [M:DVPHP5]CRY22(I)        = [F:DVPL]CRY
  [M:DVPHP5]YEA22(I)        = [F:DVPL]YEA
  I                        += 1
  [M:DVPHP5]NBLIG22         = I
Next

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 6
  [M:DVPHP5]AMTBAS23(I)     = [F:DVPL]AMTBAS
  [M:DVPHP5]AMTVAT23(I)     = [F:DVPL]AMTVAT
  [M:DVPHP5]EECNUM23(I)     = [F:DVPL]EECNUM
  [M:DVPHP5]LINE23(I)       = [F:DVPL]LSTLIN
  [M:DVPHP5]MON23(I)        = [F:DVPL]MON
  [M:DVPHP5]PORIMPLIQN23(I) = [F:DVPL]VCRNUM
  [M:DVPHP5]CRY23(I)        = [F:DVPL]CRY
  [M:DVPHP5]YEA23(I)        = [F:DVPL]YEA
  I                        += 1
  [M:DVPHP5]NBLIG23         = I
Next

Raz [M:DVPHP6]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 7
  [M:DVPHP6]AMTBAS24(I)     = [F:DVPL]AMTBAS
  [M:DVPHP6]AMTVAT24(I)     = [F:DVPL]AMTVAT
  [M:DVPHP6]EECNUM24(I)     = [F:DVPL]EECNUM
  [M:DVPHP6]LINE24(I)       = [F:DVPL]LSTLIN
  [M:DVPHP6]MON24(I)        = [F:DVPL]MON
  [M:DVPHP6]PORIMPLIQN24(I) = [F:DVPL]VCRNUM
  [M:DVPHP6]CRY24(I)        = [F:DVPL]CRY
  [M:DVPHP6]YEA24(I)        = [F:DVPL]YEA
  I                        += 1
  [M:DVPHP6]NBLIG24         = I
Next

Raz [M:DVPHP7]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 8
  [M:DVPHP7]AMTBAS(I)     = [F:DVPL]AMTBAS
  [M:DVPHP7]AMTVAT(I)     = [F:DVPL]AMTVAT
  [M:DVPHP7]EECNUM(I)     = [F:DVPL]EECNUM
  [M:DVPHP7]LINE(I)       = [F:DVPL]LSTLIN
  [M:DVPHP7]MON(I)        = [F:DVPL]MON
  [M:DVPHP7]YEA(I)        = [F:DVPL]YEA
  I                      += 1
  [M:DVPHP7]NBLIG         = I
Next

Raz [M:DVPHP8]

I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 9
  [M:DVPHP8]AMTBAS40(I)   = [F:DVPL]AMTBAS
  [M:DVPHP8]AMTVAT40(I)   = [F:DVPL]AMTVAT
  [M:DVPHP8]EECNUM(I)     = [F:DVPL]EECNUM
  [M:DVPHP8]MON40(I)        = [F:DVPL]MON # Issue X3-54534 - 2017-09-08 by MADOR - 2 Object GESDVPHP- point...
  [M:DVPHP8]YEA40(I)        = [F:DVPL]YEA # Issue X3-54534 - 2017-09-08 by MADOR - 2 Object GESDVPHP- point...
  [M:DVPHP8]LINE(I)       = [F:DVPL]LSTLIN
  [M:DVPHP8]FLD40REN(I)   = [F:DVPL]FLD40REN
  I                      += 1
  [M:DVPHP8]NBLIG         = I
Next

Raz [M:DVPHP9]
I = 0
For [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM & [F:DVPL]LINTYP = 10
  [M:DVPHP9]AMTBAS41(I)   = [F:DVPL]AMTBAS
  [M:DVPHP9]AMTVAT41(I)   = [F:DVPL]AMTVAT
  [M:DVPHP9]EECNUM(I)     = [F:DVPL]EECNUM
  [M:DVPHP9]LINE(I)       = [F:DVPL]LSTLIN
  [M:DVPHP9]FLD41REN(I)   = [F:DVPL]FLD41REN
  I                      += 1
  [M:DVPHP9]NBLIG         = I
Next

Return
######################################################################################
######################################################################################
$CREATION

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$MODIF

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$COMMON_SAVE

Gosub SAVE_FIELDS

Gosub SAVE_LISTS

Return
######################################################################################
######################################################################################
$SAVE_FIELDS
#--- fields
For I = 0 To [M:DVPHP2]NBLIG1-1
  Read [F:DVPF]DVPF0 = [M:DVPHP0]DCLNUM;1;[M:DVPHP2]DCLFLD1(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHP0]DCLNUM
    [F:DVPF]DCLPAG = 1
    [F:DVPF]DCLFLD = [M:DVPHP2]DCLFLD1(I)
    [F:DVPF]AMT    = [M:DVPHP2]AMT1(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHP2]AMT1(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

If GOK=0 : Return : Endif

For I = 0 To [M:DVPHP2]NBLIG2-1
  Read [F:DVPF]DVPF0 = [M:DVPHP0]DCLNUM;2;[M:DVPHP2]DCLFLD2(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHP0]DCLNUM
    [F:DVPF]DCLPAG = 2
    [F:DVPF]DCLFLD = [M:DVPHP2]DCLFLD2(I)
    [F:DVPF]AMT    = [M:DVPHP2]AMT2(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHP2]AMT2(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

If GOK=0 : Return : Endif

For I = 0 To [M:DVPHP2]NBLIG3-1
  Read [F:DVPF]DVPF0 = [M:DVPHP0]DCLNUM;3;[M:DVPHP2]DCLFLD3(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHP0]DCLNUM
    [F:DVPF]DCLPAG = 3
    [F:DVPF]DCLFLD = [M:DVPHP2]DCLFLD3(I)
    [F:DVPF]AMT    = [M:DVPHP2]AMT3(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHP2]AMT3(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

Return
######################################################################################
######################################################################################
$SAVE_LISTS

#--- lists
Delete [F:DVPL] Where DCLNUM = [M:DVPHP0]DCLNUM
If fstat=1 : GOK=-1 : GLOCK="$DVPL" : Return : Endif

RCOUNT = 1
Raz [F:DVPL]
For I = 0 To [M:DVPHP3]NBLIG1 - 1
  [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM
  [F:DVPL]LINTYP = 1
  [F:DVPL]AMTBAS = [M:DVPHP3]AMT(I)
  [F:DVPL]EECNUM = [M:DVPHP3]EECNUM(I)
  [F:DVPL]LSTLIN = RCOUNT
  [F:DVPL]MON    = [M:DVPHP3]MON(I)
  [F:DVPL]YEA    = [M:DVPHP3]YEA(I)
  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif
  RCOUNT        += 1
Next

If GOK=0 : Return : Endif

RCOUNT = 1
Raz [F:DVPL]
For I = 0 To [M:DVPHP3]NBLIG2 - 1
  [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM
  [F:DVPL]LINTYP = 2
  [F:DVPL]AMTBAS = [M:DVPHP3]AMT2(I)
  [F:DVPL]LSTLIN = RCOUNT
  [F:DVPL]MON    = [M:DVPHP3]MON2(I)
  [F:DVPL]VCRNUM = [M:DVPHP3]POREXPDCL(I)
  [F:DVPL]YEA    = [M:DVPHP3]YEA2(I)
  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif
  RCOUNT        += 1
Next

If GOK=0 : Return : Endif

RCOUNT = 1
Raz [F:DVPL]
For I = 0 To [M:DVPHP4]NBLIG20 - 1
  [F:DVPL]DCLNUM = [M:DVPHP0]DCLNUM
  [F:DVPL]LINTYP = 3
  [F:DVPL]AMTBAS = [M:DVPHP4]AMTBAS20(I)
  [F:DVPL]AMTVAT = [M:DVPHP4]AMTVAT20(I)
  [F:DVPL]EECNUM = [M:DVPHP4]EECNUM20(I)
  [F:DVPL]LSTLIN = RCOUNT
  [F:DVPL]MON    = [M:DVPHP4]MON20(I)
  [F:DVPL]VCRNUM = [M:DVPHP4]PORIMPLIQN20(I)
  [F:DVPL]CRY    = [M:DVPHP4]CRY20(I)
  [F:DVPL]YEA    = [M:DVPHP4]YEA20(I)
  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif
  RCOUNT        += 1
Next

