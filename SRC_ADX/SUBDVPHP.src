Subprog C_AMTBAS21(VALEUR)
Variable Decimal VALEUR

If VALEUR > 0 & [M:DVPHP4]AMTVAT21(nolign-1) < 0 | VALEUR < 0 & [M:DVPHP4]AMTVAT21(nolign-1) > 0
  GMESSAGE = mess(6,199,1)
  mkstat   = 2
Endif

If abs(VALEUR) < abs([M:DVPHP4]AMTVAT21(nolign-1))
  GMESSAGE = mess(232,111,1)
  mkstat   = 2
Endif

End
