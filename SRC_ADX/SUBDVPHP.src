######################################################################################
######################################################################################
#Issue 54535 – 2017-09-11 by MRDAB - Law 221/2017
$VERIF_TOTALS41

[L]TOT41 = func CALVATPORP.CAL_TOT41()
[L]MAINTOT41 = func CALVATPORP.CAL_MAIN_TOT41()
If TOT41 <> MAINTOT41
  Call ECR_TRACE(mess(191,187,1),0) From GESECRAN
  OK = 0
  zonsui = "FLDAN41TOT"
Endif

Return
#Issue end
######################################################################################
######################################################################################
$APRES_MODIF

#Issue 54535 – 2017-09-11 by MRDAB - Law 221/2017
If COUZON = 'NBLIG' |
& COUZON = 'FLDAN4103A' | COUZON = 'FLDAN4104A' |
& COUZON = 'FLDAN4103B' | COUZON = 'FLDAN4104B' |
& COUZON = 'FLDAN4103C' | COUZON = 'FLDAN4104C' |
& COUZON = 'FLDAN4103D' | COUZON = 'FLDAN4104D'

  [L]FLDNAME = '[M:DVPHP9]' + COUZON

  [L]TOT41 = func CALVATPORP.CAL_TOT41() - evalue([L]FLDNAME) + val(CZ)
  [M:DVPHP9]FLDAN41TOT = [L]TOT41
  Affzo [M:DVPHP9]FLDAN41TOT
Endif
#Issue end

Return
######################################################################################
######################################################################################
$COMMON_APRESAV

[L]DCLNUM = [M:DVPHP0]DCLNUM

Call DEBTRANS From GLOCK

Trbegin  [F:DVPF]

Gosub FIELD_TOTALS From CALVATPORP
If !GOK
  Goto AB_APRESSAV
Endif

Gosub DEC_TOTALS   From CALVATPORP
If !GOK
  Goto AB_APRESSAV
Endif

Commit

Gosub LOAD_FIELDS
Gosub LOAD_DEC

Affzo [M:DVPHP2]
Affzo [M:DVPHP3]
Affzo [M:DVPHP4]
Affzo [M:DVPHP5]
Affzo [M:DVPHP6]
Affzo [M:DVPHP7]
#Issue 54535 – 2017-09-07 by MRDAB - Law 221/2017
Affzo [M:DVPHP9]
#Issue End

Return
######################################################################################
######################################################################################
$AB_APRESSAV

Rollback

Return
######################################################################################
######################################################################################
$ANNULE

Delete [F:DVPB] Where [F:DVPB]DCLNUM=[M:DVPHP0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORB" - [M:DVPHP0]DCLNUM : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM=[M:DVPHP0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORF" - [M:DVPHP0]DCLNUM : Return : Endif
Delete [F:DVPL] Where [F:DVPL]DCLNUM=[M:DVPHP0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORL" - [M:DVPHP0]DCLNUM : Return : Endif

Return
######################################################################################
######################################################################################
$SETBOUT

If GREP <> "" | !CLECUR
  Call  VIREBOUT(CHAINE,"12")  From GOBJET
Endif

Return
######################################################################################
######################################################################################
$GET_CPYVARS

If [F:CPY]CPY <> GSOCIETE
  Read [F:CPY]CPY0 = GSOCIETE
  If fstat : Raz [F:CPY] : Endif
Endif

GCURLEG = [F:CPY]LEG
SITE   = [F:CPY]MAIFCY
If SITE = "" : SITE = GSOCIETE : Endif

Return
######################################################################################
######################################################################################
Subprog SHOW_HIDE_ANLOC (AN1LOC, AN2LOC)
Value Integer AN1LOC
Value Integer AN2LOC

If [L]AN1LOC = 4
  Chgfmt [M:DVPHP2]NBLIG2 With "-P"
Else
  Chgfmt [M:DVPHP2]NBLIG2 With "N"
Endif
If [L]AN2LOC = 4
  Chgfmt [M:DVPHP2]NBLIG3 With "-P"
Else
  Chgfmt [M:DVPHP2]NBLIG3 With "N"
Endif

End
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

GSOCIETE = VALEUR

Gosub GET_CPYVARS

[M:DVPHP0]CUR          = [F:CPY]ACCCUR
Affzo [M:DVPHP0]CUR

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2"
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(218,125,1), "PORVAT", mess(1,1,1))
Endif

End
######################################################################################
######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

Read [F:DVPP]DVPP0 = [M:DVPHP0]CPY;year(VALEUR)
If fstat
  mkstat = 2
  GMESSAGE = mess(13,7710,1)
  End
Endif

End
######################################################################################
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

[M:DVPHP1]HQRLOC = [F:DVPP]HQRLOC
[M:DVPHP1]AN1LOC = [F:DVPP]AN1LOC
[M:DVPHP1]AN2LOC = [F:DVPP]AN2LOC
[M:DVPHP1]DCLYEA = year([M:DVPHP0]STRDAT)

If month(VALEUR) - month([M:DVPHP0]STRDAT) = 0
  [M:DVPHP1]DCLMON = month(VALEUR)
  [M:DVPHP1]DCLQUA = 0
Else
  [M:DVPHP1]DCLMON = 0
  If month(VALEUR)<4
    [M:DVPHP1]DCLQUA = 1
  Elsif month(VALEUR)>=4 & month(VALEUR)<7
    [M:DVPHP1]DCLQUA = 2
  Elsif month(VALEUR)>=7 & month(VALEUR)<10
    [M:DVPHP1]DCLQUA = 3
  Else
    [M:DVPHP1]DCLQUA = 4
  Endif
Endif

Call SHOW_HIDE_ANLOC ([M:DVPHP1]AN1LOC, [M:DVPHP1]AN2LOC)

Affzo [M:DVPHP1]

End
######################################################################################
######################################################################################
Subprog AS_QUARTER(VALEUR)
Variable Integer VALEUR

GMENLOC(1) = 1
GMENLOC(6) = 1
GMENLOC(7) = 1
GMENLOC(8) = 1
GMENLOC(9) = 1

End
