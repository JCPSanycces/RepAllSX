#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################
# SUBTRN : Règles d'arrondi                                          #
######################################################################
$ACTION
Case ACTION
  When "ANNULE"      : Gosub ANNULE    # FGR 21/09/2009 : X3SUIVI57993
  When "CREATION"    : Gosub CREATION  # FGR 21/09/2009 : X3SUIVI57993
  When "MODIF"       : Gosub MODIF     # FGR 21/09/2009 : X3SUIVI57993
  When "CHANGE"      : Gosub CHANGE    # FGR 21/09/2009 : X3SUIVI57993
 When Default
Endcase
Return

#############################################################
$ANNULE
  # FGR 21/09/2009 : X3SUIVI57993
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("TABROUND","RNDDESAXX",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("TABROUND","RNDSHOAXX",[L]CODE,"") From ATEXTRA
Return
#############################################################
$CREATION
Local Integer WKNOL

  # FGR 21/09/2009 : X3SUIVI57993
  For WKNOL=0 To [M]BASTAB-1
    Call MAJTEXTRA([M]RNDDESAXX(WKNOL),"TABROUND","RNDDESAXX",num$([M]RNDCOD(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]RNDSHOAXX(WKNOL),"TABROUND","RNDSHOAXX",num$([M]RNDCOD(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$MODIF
Local Integer WKNOL

  # FGR 21/09/2009 : X3SUIVI57993
  For WKNOL=0 To [M]BASTAB-1
    Call MAJTEXTRA([M]RNDDESAXX(WKNOL),"TABROUND","RNDDESAXX",num$([M]RNDCOD(WKNOL)),"") From ATEXTRA
    Call MAJTEXTRA([M]RNDSHOAXX(WKNOL),"TABROUND","RNDSHOAXX",num$([M]RNDCOD(WKNOL)),"") From ATEXTRA
  Next WKNOL
Return

#############################################################
$CHANGE
  # FGR 21/09/2009 : X3SUIVI57993
  Call CHANGE_AXX("TABROUND", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Return

######################################################################
Subprog C_RNDCOD(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]RNDCOD) From OBJDIV
End

#############################################
Subprog AS_RNDCOD(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
   Look [TRN]TRD0 = VALEUR
   If !fstat : mkstat = 2 : Endif
Endif
End

######################################################################
