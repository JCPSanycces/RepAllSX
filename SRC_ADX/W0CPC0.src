#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPC0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 22067 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBCPC
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"COMPETENCE","DES",[M:CPC0]COD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DES,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DES" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SHO
mkstat = 0
zoncou = "SHO"
indice = 0
If varinit([M]SHO,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHO,"COMPETENCE","SHO",[M:CPC0]COD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHO,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHO" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone LONDES
mkstat = 0
zoncou = "LONDES"
For indice=0 To 2
 If varmode([M]LONDES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LONDES" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone FLGKEY
mkstat = 0
zoncou = "FLGKEY"
indice = 0
IMPENT = [M]FLGKEY
If varinit([M]FLGKEY,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGKEY,indice)=0
 [M]FLGKEY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGKEY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGKEY(indice)
 Endif
Endif
[M]FLGKEY = IMPENT

## Zone CRSFLG
mkstat = 0
zoncou = "CRSFLG"
indice = 0
IMPENT = [M]CRSFLG
If varinit([M]CRSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]CRSFLG,indice)=0
 [M]CRSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CRSFLG(indice)
 Endif
Endif
[M]CRSFLG = IMPENT

## Zone NATCPC
mkstat = 0
zoncou = "NATCPC"
indice = 0
If varinit([M]NATCPC,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NATCPC,"10456","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NATCPC,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NATCPC" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]NATCPC,"10456","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NATCPC" : GZNUM = 3958 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]NATCPC,"10456",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "NATCPC" : GZNUM = 3958 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_NATCPC([M]NATCPC) From SUBCPC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NATCPC" : GZNUM = 3958 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CODSCA
mkstat = 0
zoncou = "CODSCA"
indice = 0
WCHAR = [M]CODSCA
If varmode([M]CODSCA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODSCA" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODSCA,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODSCA" : GZNUM = 45131 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("HRSCA","",[M]CODSCA,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CODSCA" : GZNUM = 45131 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CODSCA([M]CODSCA) From SUBCPC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODSCA" : GZNUM = 45131 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CODSCA or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CODSCA([M]CODSCA) From SUBCPC
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CODSCA" : GZNUM = 45131 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBSCA
mkstat = 0
zoncou = "NBSCA"
indice = 0
status = 1
zoncou = "NBSCA"
SAVACT = GACTION : GACTION = "STD"
Call AV_NBSCA From SUBCPC
GACTION = SAVACT
If mkstat=1 : Raz [M]NBSCA : Endif
If !mkstat
 If varmode([M]NBSCA,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NBSCA" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   NBLIG = [M]NBSCA
   For nolign=1 To NBLIG
    indice = nolign-1
    [M]NBSCA = nolign
    status = 75
    Call SAI_NBSCA(IMPFIC,ACTION,IMPTRT)
    If mkstat : Break : Endif
   Next nolign
   If mkstat : End : Endif
   indice = 0
  Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone AFF_LEVDES
mkstat = 0
zoncou = "AFF_LEVDES"
indice = 0
WCLOB = [M]AFF_LEVDES
If varmode([M]AFF_LEVDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AFF_LEVDES" : Gosub ACTION From =IMPTRT
 Endif
 If WCLOB<>[M]AFF_LEVDES or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AFF_LEVDES([M]AFF_LEVDES) From SUBCPC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFF_LEVDES" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBSCA(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBSCA
mkstat = 0
zoncou = "NBSCA"

## Zone NBSCA
mkstat = 0
zoncou = "NBSCA"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPC0"
Return

