#                                Endif
#                            Next I                   
#                        Else
#                            # objet combiné
#                            For I = 0 To 8
#                                If [AWB]BROLIS(I) = 2 and [AWB]TRELIS(I) = 2
#    
#                                    Call ECRTIT(WTIT, PMODULE, [F:AWI]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
#        
#                                    Wrseq WTXTMODULE + "Fenêtre/Objet de type combiné" - [F:AWI]WIN - "/" - [F:AWI]OBJ -": brother de type hiérarchisé"
#                                    NBERREUR += 1
