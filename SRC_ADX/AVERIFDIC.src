#    Filter [XTZ]
#    
#    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT) 
#    NBERRDIC += NBERREUR
#    NBWARDIC += NBWARNING

$FINIOCLG

# Recherche dans ASUBPROG de TYPASU = 1 ------------------------------------------

    WDT = date$ - 30
    

    
    
    If dim([F:ASU]TYPASU) <> -1
        If PMODULE
            Filter [ASU] Where [F:ASU]MODULE = PMODULE and [F:ASU]TYPASU = 1 and ([F:ASU]CREDAT > WDT or [F:ASU]UPDDAT > WDT) Order By PRG; SUBPRG
        Else
            If EXCLSUP = 2
                Filter [ASU] Where [F:ASU]MODULE <> 1 and [F:ASU]TYPASU = 1 and ([F:ASU]CREDAT > WDT or [F:ASU]UPDDAT > WDT) Order By MODULE; PRG; SUBPRG
            Else
                Filter [ASU] Where [F:ASU]TYPASU = 1 and ([F:ASU]CREDAT > WDT or [F:ASU]UPDDAT > WDT) Order By MODULE; PRG; SUBPRG
#                Filter [ASU] Where [F:ASU]TYPASU = 1 and ([F:ASU]CREDAT > WDT or [F:ASU]UPDDAT > WDT or [F:ASU]UPDDAT = [0/0/0]) Order By MODULE; PRG; SUBPRG
            Endif
        Endif
    
    
        NBERREUR = 0
        NBWARNING = 0
        NBTRAITES = 0
        WBTROUVE = 0
        WNUMERREUR = 12
        Gosub OUVRECR
        
        WTIT = "---> Dictionnaire des sous-programmes : TYPASU = 1 = Divers"
        For [ASU]
            Call ECRTIT(WTIT, PMODULE, [F:ASU]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
    
            Wrseq WTXTMODULE + "Le programme / sous-programme" - [F:ASU]PRG - "/" - [F:ASU]SUBPRG - "a le type à Divers" - [F:ASU]UPDDAT
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ASU]MODULE, WNUMERREUR) += 1
        Next
    
        Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
        NBERRDIC += NBERREUR
        NBWARDIC += NBWARNING
    
       
        Filter [ATY]
    Endif




# Recherche dans ACTION de TYPUTI = 1 ------------------------------------------

    WDT = date$ - 30
    
    If dim([F:ACT]TYPUTI) <> -1
        If PMODULE
            Filter [ACT] Where [F:ACT]MODULE = PMODULE and [F:ACT]TYPUTI = 1 and ([F:ACT]CREDAT > WDT or [F:ACT]UPDDAT > WDT) Order By ACTION
        Else
            If EXCLSUP = 2
                Filter [ACT] Where [F:ACT]MODULE <> 1 and [F:ACT]TYPUTI = 1 and ([F:ACT]CREDAT > WDT or [F:ACT]UPDDAT > WDT) Order By MODULE; ACTION
            Else
                Filter [ACT] Where [F:ACT]TYPUTI = 1 and ([F:ACT]CREDAT > WDT or [F:ACT]UPDDAT > WDT) Order By MODULE; ACTION
            Endif
        Endif
    
    
        NBERREUR = 0
        NBWARNING = 0
        NBTRAITES = 0
        WBTROUVE = 0
        WNUMERREUR = 13
        Gosub OUVRECR
        
        WTIT = "--->" - PLIBVERIF - ": TYPUTI = 1 = Divers"
        For [ACT]
            Call ECRTIT(WTIT, PMODULE, [F:ACT]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
    
            Wrseq WTXTMODULE + "L'action" - [F:ACT]ACTION - "a le type à Divers"
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ACT]MODULE, WNUMERREUR) += 1
        Next
    
        Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
        NBERRDIC += NBERREUR
        NBWARDIC += NBWARNING

       
        Filter [ATY]
    Endif



    Call TEMPOFF From GESECRAN

    Close File [ATZ]
    Close File [ATB]
    Close File [AMP]
    Close File [ATY]
    Close File [AST]
    Close File [AMK]
    Close File [AMZ]
    Close File [ACT]
    Close File [AFC]
#    Close File [ADO]
#    Close File [ADH]
    Close File [AMA]
    Close File [AWI]
    Close File [AWB]
    Close File [AOB]
    Close File [ASU]
    
    Close File [AMZ2]
    Close File [ATZ2]
    



    Wrseq
    Wrseq "Récapitulatif du contrôle des dictionnaires :"
    Wrseq
    Wrseq num$(NBWARDIC) - "anomalies"
    Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$
    Wrseq ""
    
    Openo
    Openo CHEMINTRA, -1
    Wrseq
    Wrseq "Récapitulatif du contrôle des dictionnaires :"
    Wrseq
    Wrseq num$(NBERRDIC) - "erreurs"
    Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$
    Wrseq ""
    
    
    Openo
    End
    
    
$OUVRECR
    If GBTWARNING(GNUMMOUL, WNUMERREUR) <> GBTWARNING(GNUMMOUL, WNUMERREUR - 1)
        Openo    
        If GBTWARNING(GNUMMOUL, WNUMERREUR)
            Openo CHEMINTRAW, -1
        Else
            Openo CHEMINTRA, -1
        Endif
    Endif
Return

$PLUSCPTR
    If GBTWARNING(GNUMMOUL, WNUMERREUR)
        NBWARNING += 1
    Else
        NBERREUR += 1
    Endif
Return


End

Subprog ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)
Value Shortint WBTROUVE
Value Integer NBERREUR, NBWARNING, NBTRAITES
Variable Integer NBERRTOT, NBWARTOT


    If WBTROUVE

        Wrseq
        If NBTRAITES
            Wrseq "nombre trouvé :" - num$(NBERREUR + NBWARNING) - "sur" - num$(NBTRAITES) - "trouvés"
        Else
            Wrseq "nombre trouvé :" - num$(NBERREUR + NBWARNING)
        Endif
        Wrseq
        Wrseq
    Endif
    
    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING
End
    
Subprog ECRDEBUT(PLIBVERIF)
Value Char PLIBVERIF
#----------------------------------#
#Traitement itératif sur les sources
#----------------------------------#

Wrseq
Wrseq
Wrseq
Wrseq "-------------------------### Vérification des" - PLIBVERIF + ". ###---------------------------"
Wrseq
Wrseq

End

Subprog ECRTIT(PTIT, PMODULESEL, PMODULELU, PTXTMODULE, SAUVEMENU, PBTROUVE)
Value Char PTIT
Value Integer PMODULESEL, PMODULELU
Variable Char PTXTMODULE
Variable Shortint SAUVEMENU, PBTROUVE

    If PMODULESEL = 0
        PTXTMODULE = "(module" - num$(PMODULELU) - "(" - func AVERIFSRC.LIBMODULE (PMODULELU, SAUVEMENU) - ") "
    Else
        PTXTMODULE = ""
    Endif
    
    # titre du contrôle
    If PBTROUVE = 0
        If PTIT = "IOCLG"
            Wrseq "---> Liste hierarchisée sur objet combiné interdit"
            Wrseq "     Liste présente sur objet tableau"
        Else
            Wrseq PTIT
        Endif
        Wrseq
        PBTROUVE = 1
    Endif
End
