#<AdxTL>@(#)3.0.0.0 $Revision$

######################################################
#   vérification dans les dicos
# - présence dans le dico des actions
# - subprog avec du code
#
######################################################


#------------------------------------------------------------------------------------------------------------------------#
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End

Subprog AVERIFDIC (CHEMINTRA, DOSSIER, PMODULE, EXCLSUP,
&                 PORT, MACHINE, CHEMINTRAW, NBERRTOT, NBWARTOT, PLIBVERIF)


Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Variable Integer NBERRTOT, NBWARTOT
Value Char PLIBVERIF

Local Char ZADXIFS, ZADXIRS


Local Char DOSSIER2(100), WTXTMODULE(50), WTIT(90), TEXCPT(10)(1..50)
Local Integer WBOK, I, NBTRAITES, NBERREUR, NBWARNING, NBEXCPT, NBERRDIC, NBWARDIC, WNUMERREUR
Local Shortint WBTROUVE, SAUVEMENU
Local Date WDT

ZADXIFS=adxifs : ZADXIRS=adxirs
adxifs=chr$(0):adxirs=chr$(10)

If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif

If clalev ([F:ATZ])
    Close File [ATZ]
Endif
If clalev ([F:ATB])
    Close File [ATB]
Endif
If clalev ([F:AMP])
    Close File [AMP]
Endif
If clalev ([F:ATY])
    Close File [ATY]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif
If clalev ([F:AMK])
    Close File [AMK]
Endif
If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:ACT])
    Close File [ACT]
Endif
If clalev ([F:AFC])
    Close File [AFC]
Endif
#If clalev ([F:ADO])
#    Close File [ADO]
#Endif
#If clalev ([F:ADH])
#    Close File [ADH]
#Endif
If clalev ([F:AMA])
    Close File [AMA]
Endif
If clalev ([F:AWI])
    Close File [AWI]
Endif
If clalev ([F:AWB])
    Close File [AWB]
Endif
If clalev ([F:AOB])
    Close File [AOB]
Endif
If clalev ([F:ASU])
    Close File [ASU]
Endif

If clalev ([F:AMZ2])
    Close File [AMZ2]
Endif
If clalev ([F:ATZ2])
    Close File [ATZ2]
Endif

Local File = DOSSIER2 + ".ATABZON" [ATZ]
Local File = DOSSIER2 + ".ATABLE" [ATB]
Local File = DOSSIER2 + ".AMSKPAR" [AMP]
Local File = DOSSIER2 + ".ATYPE" [ATY]
Local File = DOSSIER2 + ".APLSTD"  [AST]
Local File = DOSSIER2 + ".AMSK" [AMK]
Local File = DOSSIER2 + ".AMSKZON" [AMZ]
Local File = DOSSIER2 + ".ACTION" [ACT]
Local File = DOSSIER2 + ".AFONCTION" [AFC]

#Local File = DOSSIER2 + ".ADOCUMENT" [ADO]
#Local File = DOSSIER2 + ".ADOCCLB" [ADH]

Local File = DOSSIER2 + ".AMSKACT" [AMA]
Local File = DOSSIER2 + ".AWINDOW" [AWI]
Local File = DOSSIER2 + ".AWINBRO" [AWB]
Local File = DOSSIER2 + ".AOBJET" [AOB]
Local File = DOSSIER2 + ".ASUBPROG" [ASU]

Local File = DOSSIER2 + ".AMSKZON" [AMZ2]
Local File = DOSSIER2 + ".ATABZON" [ATZ2]

Call TEMPON("Vérifications de" - PLIBVERIF) From GESECRAN

SAUVEMENU = -1


Openo CHEMINTRAW, -1
Call ECRDEBUT(PLIBVERIF)
Openo

Openo CHEMINTRA, -1
Call ECRDEBUT(PLIBVERIF)


# ----------------------------------------------------------------------------------------


# Recherche des champs de table ayant le type BPN ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    NBERRDIC = 0
    NBWARDIC = 0
    WNUMERREUR = 1
    If GBTWARNING(GNUMMOUL, WNUMERREUR)
        Openo    
        Openo CHEMINTRAW, -1
    Endif
    
    Link [ATZ] With [F:ATB]CODFIC = CODFIC As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and [F:ATZ]CODTYP = "BPN"  and [F:ATB]TYPDLV <> 1 Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:ATB]MODULE <> 1 and [F:ATZ]CODTYP = "BPN"  and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Else
            Filter [XTZ] Where [F:ATZ]CODTYP = "BPN"  and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Endif
    Endif

    WTIT = "---> Type BPN trouvé à tort sur champs de table"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
 
#        Read [ATB]CODFIC = [F:ATZ]CODFIC
#        If fstat
#            Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "table non trouvée"
#        Else
            Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE
#        Endif
        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    



# Recherche des champs de table ayant le type VCR ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 2
    Gosub OUVRECR
    
    # Pas ce contrôle sur le module superviseur
    Link [ATZ] With [F:ATB]CODFIC = CODFIC As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and [F:ATZ]CODTYP = "VCR"  and [F:ATB]TYPDLV <> 1 Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        Filter [XTZ] Where [F:ATB]MODULE <> 1 and [F:ATZ]CODTYP = "VCR"  and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Endif

    WTIT = "---> Type VCR sur champs de table dont le paramètre VCROBJ n'est pas renseigné"
    For [XTZ]
        NBTRAITES += 1
        Read [AMP]CODPAR = 2; [F:ATZ]CODFIC; [F:ATZ]CODZONE; "VCROBJ"
        If fstat
            Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "Le paramètre VCROBJ n'existe pas."
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
        Else
            If [F:AMP]VALPAR = "" or [F:AMP]VALPAR = '""' or [F:AMP]VALPAR = "''"
                Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

                Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "Le paramètre VCROBJ n'est pas renseigné."
                Gosub PLUSCPTR
                GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
#Else
#Wrseq "-----------------Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "VCROBH =" - [F:AMP]VALPAR
  
            Endif
        Endif
    Next
   
    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING




# ----------------------------------------------------------------------------------------


# Recherche des champs de table ayant le type BPS ou BPC ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    NBERRDIC = 0
    NBWARDIC = 0
    WNUMERREUR = 3
    Gosub OUVRECR

    
    
    Link [ATZ] With [F:ATB]CODFIC = CODFIC As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and ([F:ATZ]CODTYP = "BPS" or [F:ATZ]CODTYP = "BPC")  and [F:ATZ]ANNUL <> 4 Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:ATB]MODULE <> 1 and ([F:ATZ]CODTYP = "BPS" or [F:ATZ]CODTYP = "BPC")  and [F:ATZ]ANNUL <> 4 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Else
            Filter [XTZ] Where ([F:ATZ]CODTYP = "BPS" or [F:ATZ]CODTYP = "BPC")  and [F:ATZ]ANNUL <> 4 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Endif
    Endif

    WTIT = "---> Type BPS ou BPC trouvé sur champs de table avec annulation différente de Autre"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
 
        Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "avec annulation à" - mess([F:ATZ]ANNUL, 24, 1)
        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]

    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)   


# Recherche des TYPES DONT LE FORMAT UTILISE UNE CLASSE F ------------------------------------------

    If PMODULE
        Filter [ATY] Where [F:ATY]MODULE = PMODULE Order By [F:ATY]CODTYP
    Else
        If EXCLSUP = 2
            Filter [ATY] Where [F:ATY]MODULE <> 1 Order By [F:ATY]MODULE; [F:ATY]CODTYP
        Else
            Filter [ATY] Where [F:ATY]MODULE >= 0 Order By [F:ATY]MODULE; [F:ATY]CODTYP
        Endif
    Endif


    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 4
    Gosub OUVRECR
    
    WTIT = "---> Type de donnée dont le format est issu d'une classe [F]"
    For [ATY]
        NBTRAITES += 1
        I = instr(1, [F:ATY]FORTYP, "[F")
        If I
            Call ECRTIT(WTIT, PMODULE, [F:ATY]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Le type" - [F:ATY]CODTYP - "a le format suivant :" - [F:ATY]FORTYP
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ATY]MODULE, WNUMERREUR) += 1
        Endif
    Next

    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING

   
    Filter [ATY]





# Recherche des var écran de type tableau : si graphe par défaut, alors option T ------------------------------------------


    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 5
    Gosub OUVRECR
    
    Link [AMZ] With [F:AMK]CODMSK = CODMSK As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:AMK]MODULE = PMODULE and [F:AMZ]CODTYP = "ABS" Order By [F:AMZ]CODMSK; [F:AMZ]CODZON
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:AMK]MODULE <> 1 and [F:AMZ]CODTYP = "ABS" Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON
        Else
            Filter [XTZ] Where [F:AMZ]CODTYP = "ABS" Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON
        Endif
    Endif


    WTIT = "---> option T absente du bloc tableau si graphe par défaut"
    For [XTZ]
        NBTRAITES += 1
        If ([F:AMK]BLOCTYPT([F:AMZ]NUMBLOC) = 3 or [F:AMK]BLOCTYPT([F:AMZ]NUMBLOC) = 4) and instr(1, [F:AMK]OPTION([F:AMZ]NUMBLOC), "T") = 0
            Call ECRTIT(WTIT, PMODULE, [F:AMK]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Ecran" - [F:AMZ]CODMSK - "Champ" - [F:AMZ]CODZON - "L'option est :" - [F:AMK]OPTION([F:AMZ]NUMBLOC)
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:AMK]MODULE, WNUMERREUR) += 1
        Endif
 
        If [F:AMK]BLOCTYPT([F:AMZ]NUMBLOC) = 2 and [F:AMK]BLOCTYPT([F:AMK]BLOCAFFD) = 2 and instr(1, [F:AMK]OPTION([F:AMZ]NUMBLOC), "T") = 0
            Call ECRTIT(WTIT, PMODULE, [F:AMK]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Ecran" - [F:AMZ]CODMSK - "Champ" - [F:AMZ]CODZON - "L'option est :" - [F:AMK]OPTION([F:AMZ]NUMBLOC)
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:AMK]MODULE, WNUMERREUR) += 1
        Endif
    Next
    
   
    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING



# Recherche des var bas de tableau : si aucun des champs est saisissable alors cette variable ne doit pas l'être -----------


Goto FINBTB

#    NBERREUR = 0
#    NBWARNING = 0
#    NBTRAITES = 0
#    WBTROUVE = 0
#    
#    Link [AMZ] With [F:AMK]CODMSK = CODMSK As [XTZ]
#    If PMODULE
#        Filter [XTZ] Where [F:AMK]MODULE = PMODULE and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF = 1 Order By [F:AMZ]CODMSK; [F:AMZ]CODZON
#    Else
#        If EXCLSUP = 2
#            Filter [XTZ] Where [F:AMK]MODULE <> 1 and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF = 1 Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON
#        Else
#            Filter [XTZ] Where [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF = 1 Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON
#        Endif
#    Endif
#
#    WTIT = "---> variables de type Tableau qui sont saisissables mais avec aucun champ ne l'étant"
#    For [XTZ]
#        NBTRAITES += 1
#
#        Filter [AMZ2] Where [F:AMZ2]CODMSK = [F:XTZ]CODMSK and [F:AMZ2]NUMBLOC = [F:XTZ]NUMBLOC and [F:AMZ2]SAIAFF = 1 and [F:XTZ]CODZON <> [F:AMZ2]CODZON
#        Read [AMZ2]CODZON First
#        
#        If fstat
#            Call ECRTIT(WTIT, PMODULE, [F:AMK]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)
#
#            Wrseq WTXTMODULE + "Ecran" - [F:AMZ]CODMSK - "Champ" - [F:AMZ]CODZON - "en saisie (bloc n°" - num$([F:XTZ]NUMBLOC) +")"
#            NBERREUR += 1
#        Endif
#        Filter [AMZ2]
#    Next
#   
#    Filter [XTZ]
#    
#    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
#    NBERRDIC += NBERREUR
#    NBWARDIC += NBWARNING

$FINBTB


# Recherche des actions : fenêtre principale renseignée alors la case batch est interdite ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    
    Raz TEXCPT
    TEXCPT(1) = "SAISHTSEL"
    NBEXCPT = 1
    WNUMERREUR = 6
    Gosub OUVRECR


    
    
    If PMODULE
        Filter [ACT] Where [F:ACT]MODULE = PMODULE and [F:ACT]PARAM2 <> "" and [F:ACT]ABTFLG = 2 Order By [F:ACT]PARAM2
    Else
        If EXCLSUP = 2
            Filter [ACT] Where [F:ACT]MODULE <> 1 and [F:ACT]PARAM2 <> "" and [F:ACT]ABTFLG = 2 Order By [F:ACT]MODULE; [F:ACT]PARAM2
        Else
            Filter [ACT] Where [F:ACT]PARAM2 <> "" and [F:ACT]ABTFLG = 2 Order By [F:ACT]MODULE; [F:ACT]PARAM2
        Endif
    Endif
    
    WTIT = "---> action batch avec une fenêtre principale"
    For [ACT]
        If find([F:ACT]ACTION, TEXCPT(1..NBEXCPT)) = 0
            Call ECRTIT(WTIT, PMODULE, [F:ACT]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Action" - [F:ACT]ACTION - "fenêtre principale" - [F:ACT]PARAM2
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ACT]MODULE, WNUMERREUR) += 1
        Endif
    Next

    Filter [ACT]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING


# Recherche des champs de table ayant annulation à autre avec le type lié à la table elle-même ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 7
    Gosub OUVRECR
    
    
    Link [ATZ] With [F:ATB]CODFIC = CODFIC;  [F:ATY]CODTYP = CODTYP As [XTZ]

    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and [ATY]FICLIEN = [F:ATB]CODFIC and [ATZ]ANNUL = 4  and [F:ATB]TYPDLV <> 1 Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:ATB]MODULE <> 1 and [ATY]FICLIEN = [F:ATB]CODFIC and [ATZ]ANNUL = 4 and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Else
            Filter [XTZ] Where [ATY]FICLIEN = [F:ATZ]CODFIC and [ATZ]ANNUL = 4 and [F:ATB]TYPDLV <> 1  Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Endif
    Endif

    WTIT = "---> champs ayant annulation à autre avec le type lié à la table elle-même"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

        Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "de type" - [F:ATZ]CODTYP - "lien" - [ATY]FICLIEN
        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING


# Recherche des champs de type clob et blob  de taille > 9 -----------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 8
    Gosub OUVRECR
    
    
    Link [ATZ] With [F:ATB]CODFIC = CODFIC As [XTZ]

    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and ([ATZ]CODTYP = "AB0" or [ATZ]CODTYP = "AC0"
&       or [ATZ]CODTYP = "AC1" or [ATZ]CODTYP = "ACB") and LONG > 9   and [F:ATB]TYPDLV <> 1 Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:ATB]MODULE <> 1 and ([ATZ]CODTYP = "AB0" or [ATZ]CODTYP = "AC0"
&       or [ATZ]CODTYP = "AC1" or [ATZ]CODTYP = "ACB") and LONG > 9   and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Else
            Filter [XTZ] Where ([ATZ]CODTYP = "AB0" or [ATZ]CODTYP = "AC0"
&       or [ATZ]CODTYP = "AC1" or [ATZ]CODTYP = "ACB") and LONG > 9   and [F:ATB]TYPDLV <> 1 Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Endif
    Endif

    WTIT = "---> clob et blob de longueur > 9"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

        Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "de type" - [F:ATZ]CODTYP - "longueur" - num$([ATZ]LONG)
        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING



# Recherche des champs de type blob et du champ associé de type AT ---------------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 9
    Gosub OUVRECR
    
    
    Link [ATZ] With [F:ATB]CODFIC = CODFIC As [XTZ]

    If PMODULE
        Filter [XTZ] Where [F:ATB]MODULE = PMODULE and [ATZ]CODTYP = "AB0" and [F:ATB]TYPDLV <> 1 and [F:ATB]TYPDLV <> 1 and
&       [F:ATB]CODFIC <> "AOBJEXTMPB"
&       Order By [F:ATZ]CODFIC; [F:ATZ]CODZONE
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:ATB]MODULE <> 1 and [ATZ]CODTYP = "AB0"  and [F:ATB]TYPDLV <> 1 and [F:ATB]TYPDLV <> 1 and
&       [F:ATB]CODFIC <> "AOBJEXTMPB" Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Else
            Filter [XTZ] Where [ATZ]CODTYP = "AB0"  and [F:ATB]TYPDLV <> 1 and [F:ATB]TYPDLV <> 1 and
&       [F:ATB]CODFIC <> "AOBJEXTMPB" Order By [F:ATB]MODULE; [F:ATZ]CODFIC; [F:ATZ]CODZONE
        Endif
    Endif

    WTIT = "---> champs de type blob sans champ associé de type AT"
    For [XTZ]
        NBTRAITES += 1
        Filter [ATZ2] Where [F:ATZ2]CODFIC = [F:ATZ]CODFIC and [F:ATZ2]CODTYP = "AT"
        Read [ATZ2]NUMLIG First
        
        If fstat
            Call ECRTIT(WTIT, PMODULE, [F:ATB]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

            Wrseq WTXTMODULE + "Table" - [F:ATZ]CODFIC - "Champ" - [F:ATZ]CODZONE - "n'a pas de champ associé de type AT"
            Gosub PLUSCPTR
            GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, WNUMERREUR) += 1
        Endif
    Next

    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)  
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING



# Recherche des fonctions de consultation qui ont un code impression ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 10
    Gosub OUVRECR
    
    
    Link [AFC] With [F:ACT]ACTION = ACTION As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:AFC]MODULE = PMODULE and ([F:AFC]RPT1 <> "" and [F:AFC]RPT1 <> "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]CODINT
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:AFC]MODULE <> 1 and ([F:AFC]RPT1 <> "" and [F:AFC]RPT1 <> "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]MODULE; [F:AFC]CODINT
        Else
            Filter [XTZ] Where ([F:AFC]RPT1 <> "" and [F:AFC]RPT1 <> "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]MODULE; [F:AFC]CODINT
        Endif
    Endif
#    If PMODULE
#        Filter [XTZ] Where [F:AFC]MODULE = PMODULE and ([F:AFC]RPT1 <> "" or [F:AFC]RPT1 = "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]CODINT
#    Else
#        If EXCLSUP = 2
#            Filter [XTZ] Where [F:AFC]MODULE <> 1 and ([F:AFC]RPT1 <> "" or [F:AFC]RPT1 = "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]MODULE; [F:AFC]CODINT
#        Else
#            Filter [XTZ] Where ([F:AFC]RPT1 <> "" or [F:AFC]RPT1 = "PRTSCR") and [F:ACT]PARAM1 <> ""  Order By [F:AFC]MODULE; [F:AFC]CODINT
#        Endif
#    Endif
    
    WTIT = "---> fonction de consultation dont dont le code impression a une valeur <> PRTSCR"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:AFC]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

        Wrseq WTXTMODULE + "Fonction" - [F:AFC]CODINT - "a un code impression :" - [F:AFC]RPT1
        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:AFC]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]
    
    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING







# Recherche des actions CONTOBJW et CONTOBJ des champs non oblig ------------------------------------------

    NBERREUR = 0
    NBWARNING = 0
    NBTRAITES = 0
    WBTROUVE = 0
    WNUMERREUR = 11
    Gosub OUVRECR
    
    
 Link [AMZ] With [F:AMK]CODMSK = CODMSK, [F:AMA]NOACT(2) = CODMSK;CODZON As [XTZ]
    If PMODULE
        Filter [XTZ] Where [F:AMK]MODULE = PMODULE and [F:AMZ]OBLIG = 1 and
&         ([F:AMA]ACTION = "CONTOBJW" or [F:AMA]ACTION = "CONTOBJ") Order By [F:AMZ]CODMSK; [F:AMZ]CODZON
    Else
        If EXCLSUP = 2
            Filter [XTZ] Where [F:AMK]MODULE <> 1 and [F:AMZ]OBLIG = 1 and
&         ([F:AMA]ACTION = "CONTOBJW" or [F:AMA]ACTION = "CONTOBJ") Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON
        Else
            Filter [XTZ] Where [F:AMZ]OBLIG <> 2 and
&         ([F:AMA]ACTION = "CONTOBJW" or [F:AMA]ACTION = "CONTOBJ") Order By [F:AMK]MODULE; [F:AMZ]CODMSK; [F:AMZ]CODZON

#            Filter [XTZ] Where [F:AMZ]OBLIG = 1 Order By [F:AMZ]CODMSK; [F:AMZ]CODZON
        Endif
    Endif
    
    WTIT = "---> action CONTOBJW  ou CONTOBJ mais champ avec flag obligatoire non positionné"
    For [XTZ]
        Call ECRTIT(WTIT, PMODULE, [F:AMK]MODULE, WTXTMODULE, SAUVEMENU, WBTROUVE)

        If [F:AMZ]OBLIG = 1
            Wrseq WTXTMODULE + "Ecran" - [F:AMK]CODMSK - "champ" - [F:AMA]CODZON - "a l'action" - [F:AMA]ACTION
        Else
            Wrseq WTXTMODULE + "Ecran" - [F:AMK]CODMSK - "champ" - [F:AMA]CODZON - "a l'action" - [F:AMA]ACTION -"et [F:AMZ]OBLIG =" - num$([F:AMZ]OBLIG)
        Endif

        Gosub PLUSCPTR
        GTRECAPERR(GNUMMOUL, [F:AMK]MODULE, WNUMERREUR) += 1
    Next

    Filter [XTZ]

    Call ECRCPTR (WBTROUVE, NBERREUR, NBWARNING, NBTRAITES, NBERRTOT, NBWARTOT)    
    NBERRDIC += NBERREUR
    NBWARDIC += NBWARNING





# Incompatibilité objet combiné - liste gauche principale hiérarchisée ------------------------------------------





    Goto FINIOCLG




###################
###################
###################
###################                 Contrôle abandonné
###################
###################
###################
###################




#    NBERREUR = 0
#    NBWARNING = 0
#    NBTRAITES = 0
