#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
####################################################################################################
# Traitement lié à l'action PJTREPEAT
####################################################################################################
####################################################################################################
$ACTION
  Case ACTION
    When "INIT"          : Gosub INIT
    When "DEBUT"         : Gosub DEBUT
    When "BOUTON"        : Gosub BOUTON
    When "EXEC"          : Gosub EXEC
    When "TERMINE"       : Gosub TERMINE
  Endcase
Return

####################################################################################################
$INIT
  Case GACTION
    When "PJTREPEAT"     : Gosub INIT_PJTREPEAT
    When "PJTQUESTIO"    : Gosub INIT_PJTQUESTIO
  Endcase
Return

####################################################################################################
$DEBUT
  Case GACTION
    When "PJTREPEAT"     : Gosub DEBUT_PJTREPEAT
    When "PJTQUESTIO"    : Gosub DEBUT_PJTQUESTIO
  Endcase
Return

####################################################################################################
$BOUTON
  Case GACTION
    When "PJTREPEAT"     : Gosub BOUTON_PJTREPEAT
    When "PJTQUESTIO"    : Gosub BOUTON_PJTQUESTIO
  Endcase
Return

####################################################################################################
$EXEC
  Case GACTION
    When "PJTREPEAT"     : Gosub EXEC_PJTREPEAT
    When "PJTQUESTIO"    : Gosub EXEC_PJTQUESTIO
  Endcase
Return

####################################################################################################
$TERMINE
  Case GACTION
    When "PJTREPEAT"     : Gosub TERMINE_PJTREPEAT
    When "PJTQUESTIO"    : Gosub TERMINE_PJTQUESTIO
  Endcase
Return

####################################################################################################
########################### ACTION PJTREPEAT #######################################################
####################################################################################################
####################################################################################################
$INIT_PJTREPEAT
Global Char GPJTBOUTCLICK(1)
Global Char GSTRTMODULE(GLONADC)
Global Integer GITRTMODULE

Local Char SBASTAB(GLONABR+GLONAVA+4)
Local Char SAZC(type(VALEUR)-10)
Local Char SOLDAZC(type(VALEUR)-10)

  If !GIMPORT Then
    Gosub DECLARE_VARIABLES From TRTPJT
    # --------------------------
    Call TRAITEMENT_MODULE(MODULE, GSTRTMODULE, GITRTMODULE)
    # --------------------------
    SAZC = VALEUR
    SOLDAZC = evalue("[M:" + CODMSK + "]" + FLDNAM)
    SBASTAB = func TRTPJT.GET_BAS_TABLEAU(ZONDET)
    # --------------------------
    If SBASTAB <> "" Then
      # Si c'est un tableau
      If evalue(SBASTAB) < 1 Then
        # Si le tableau est vide, y a rien à faire
        FIN = 1
      Endif
    Else
      # Cas où le détail n'est pas dans un tableau.
    Endif
  Else
    # En import on ressort
    FIN = 1
  Endif
  # --------------------------
Return

####################################################################################################
$DEBUT_PJTREPEAT
  [M:CHX]TEXTE = mess(1183,196,1)
  Affzo [M:CHX]TEXTE
Return

####################################################################################################
$BOUTON_PJTREPEAT
Local Char PJTACTION(GLONDCO)

  If GITRTMODULE = G_OUI Then
    PJTACTION = "BOUTON_PJTREPEAT"
    Gosub ACTION From =GSTRTMODULE
  Endif
  # ------------------
  GPJTBOUTCLICK = BOUT
  FIN = 1
Return

####################################################################################################
$EXEC_PJTREPEAT
  Case GPJTBOUTCLICK
    When "1"
      # Oui
      Call EXEC_PJTREPEAT_OUI(SBASTAB, ZONDET, SAZC)
    When "2"
      # Non : On sort sans rien faire
    When "3"
      # Oui si même valeur
      Call EXEC_PJTREPEAT_OUISI(SBASTAB, ZONDET, SOLDAZC, SAZC)
    When Default
  Endcase
Return

####################################################################################################
$TERMINE_PJTREPEAT
  Kill GPJTBOUTCLICK
  Kill GSTRTMODULE
  Kill GITRTMODULE
Return

####################################################################################################
########################### ACTION PJT QUESTIO #####################################################
####################################################################################################
####################################################################################################
$INIT_PJTQUESTIO
Global Char GSTRTMODULE(GLONADC)
Global Integer GITRTMODULE

Local Integer MODULE

  MODULE = val(PARAM(2))
  # --------------------------
  Call TRAITEMENT_MODULE(MODULE, GSTRTMODULE, GITRTMODULE)
Return

####################################################################################################
$DEBUT_PJTQUESTIO
  Gosub DEBUT_PJTREPEAT
Return

####################################################################################################
$BOUTON_PJTQUESTIO
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

  If ITRTMODULE = G_OUI Then
    PJTACTION = "BOUTON_PJTQUESTIO"
    Gosub ACTION From =STRTMODULE
  Endif
  # -------------
  PARAM(1) = BOUT
  FIN = 1
Return

####################################################################################################
$EXEC_PJTQUESTIO
Return

####################################################################################################
$TERMINE_PJTQUESTIO
  Kill GSTRTMODULE
  Kill GITRTMODULE
Return

####################################################################################################
####################################################################################################
################################ CODE EXECUTION DE L'ACTION A FAIRE ################################
####################################################################################################
####################################################################################################
Subprog EXEC_PJTREPEAT_OUI(SBASTAB, SZONDET, SAZC)
Value Char SBASTAB
Value Char SZONDET
Value Char SAZC

Local Integer NI
Local Char SUPDFLG(GLONAVA+GLONABR+GLONAVA+4)
Local Char SABRMSK(GLONABR)
# Issue X3-66544 - 2017-11-29 by FGR : BEGIN
Local Char    WCCEMSK(GLONABR)                   # Nom de l'écran des sections à initialiser/Dimension screen name
Local Integer WNOLIGN                            # Indice de la ligne/ line indice
Local Char    WCCEZON(GLONAVA+GLONABR+GLONAVA+4) # Nom du champ de la section à initialiser/Dimension field name
Local Char    STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Integer WACTIVPJM
# Issue X3-66544 - 2017-11-29 by FGR : END

  If SBASTAB <> "" Then
    If evalue(SBASTAB) > 0 Then
      SABRMSK = func TRTPJT.GET_ABRMSK(SZONDET)
      SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
      If evalue ("dim(" + SUPDFLG + ")") < 0 Then
        Raz SUPDFLG
      Endif
      Gosub OPEN_FILE
      # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)
      WACTIVPJM = func ASYRFNC.ACTIV("PJM")
      # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)
      For NI = 0 To evalue(SBASTAB)-1
        Assign (SZONDET + "(" + num$(NI) + ")") With SAZC
        #Affzo =SZONDET + "(" + num$(NI) + ")"
        Gosub WRITE_FILE_AFFZO
        # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
        # Code activité PJM actif et il existe un axe géré à l'affaire
        # Active activity code PJM and a dimension type is managed by project
        If WACTIVPJM and GPJMDIE <> "" Then
          ITRTMODULE = [V]CST_ANO
          If dim(GSTRTMODULE) > 0 Then
            STRTMODULE = GSTRTMODULE
          Endif
          If dim(GITRTMODULE) > 0 Then
            ITRTMODULE = GITRTMODULE
          Endif
          WNOLIGN = NI + 1
          WCCEMSK = SABRMSK
          # Initialisation de la section anaylitique d'une ligne de document /Dimension initialization for the line document
          Gosub PJT_INIT_CCED From TRTPJT
          If WCCEZON <> "" Then
            # Le nom du champ a été initialisé dans PJT_INIT_CCED car il existe bien un n° d'axe correspondant à l'axe géré à l'affaire
            # Field name has been initialized in PJT_INIT_CCED because there is a dimension type number tied to the dimension managed by projetc
            # Seul moyen que j'ai trouvé pour faire l'affzo ...
            # Only mean found to do the affzo ...
            Wrseq "Affzo " + WCCEZON + "(" + num$([L]WNOLIGN-1) + ")" Using [FPJT]
          Endif
        Endif
        # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
        If SUPDFLG <> "" Then
          Assign (SUPDFLG + "(" + num$(NI) + ")") With 1
        Endif
      Next NI
      Gosub CLOSE_FILE
    Endif
  Else
    SABRMSK = func TRTPJT.GET_ABRMSK(SZONDET)
    SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
    If evalue ("dim(" + SUPDFLG + ")") < 0 Then
      Raz SUPDFLG
    Endif
    Gosub OPEN_FILE
    Assign (SZONDET) With SAZC
    #Affzo =SZONDET
    Gosub WRITE_FILE_AFFZO
    If SUPDFLG <> "" Then
      Assign (SUPDFLG) With 1
    Endif
    Gosub CLOSE_FILE
  Endif
End

# X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)
####################################################################################################
# EXEC_PJTREPEAT_INIT_CCED
####################################################################################################
#**
#* Initialisation de la section analytique gérée à l'affaire sur les lignes d'un document
#* Utilisé par PJT_AFTER_MODIFY From TRTPJT
#* Utilisé lorsqu'il n'y a pas le champ PJT sur les lignes (si champ PJT sur les lignes l'init est faite depuis EXEC_PJTREPEAT_OUI ou EXEC_PJTREPEAT_OUISI)
#* Initialization of the dimension managed by project for the lines of a document
#* Used by PJT_AFTER_MODIFY From TRTPJT
#* Used when the field PJT is not on the lines (if field PJT on the lines init is done with EXEC_PJTREPEAT_OUI or EXEC_PJTREPEAT_OUISI)
#*
#* @param SBASTAB   Nom de la variable bas de tableau/Grid variable name
#* @param SZONDET   Non utilisé pour l'instant/Unused for the moment
#* @param SAZC      Non utilisé pour l'instant/Unused for the moment
#*
#*!
Subprog EXEC_PJTREPEAT_INIT_CCED(SBASTAB, SZONDET, SAZC)
Value Char SBASTAB
Value Char SZONDET
Value Char SAZC

Local Integer NI
Local Char SUPDFLG(GLONAVA+GLONABR+GLONAVA+4)
Local Char SABRMSK(GLONABR)
# Issue X3-66544 - 2017-11-29 by FGR : BEGIN
Local Char    WCCEMSK(GLONABR)                   # Nom de l'écran des sections à initialiser/Dimension screen name
Local Integer WNOLIGN                            # Indice de la ligne/ line indice
Local Char    WCCEZON(GLONAVA+GLONABR+GLONAVA+4) # Nom du champ de la section à initialiser/Dimension field name
Local Char    STRTMODULE(GLONADC)
Local Integer ITRTMODULE
# Issue X3-66544 - 2017-11-29 by FGR : END

  If SBASTAB <> "" Then
    If evalue(SBASTAB) > 0 Then
      SABRMSK = func TRTPJT.GET_ABRMSK(SBASTAB)
      SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
      If evalue ("dim(" + SUPDFLG + ")") < 0 Then
        Raz SUPDFLG
      Endif
      Gosub OPEN_FILE
      ITRTMODULE = [V]CST_ANO
      If dim(GSTRTMODULE) > 0 Then
        STRTMODULE = GSTRTMODULE
      Endif
      If dim(GITRTMODULE) > 0 Then
        ITRTMODULE = GITRTMODULE
      Endif
      WCCEMSK = SABRMSK
      For NI = 0 To evalue(SBASTAB)-1
        WNOLIGN = NI + 1
        Gosub PJT_INIT_CCED From TRTPJT
        # Initialisation de la section anaylitique d'une ligne de document /Dimension initialization for the line document
        If WCCEZON <> "" Then
          # Le nom du champ a été initialisé dans PJT_INIT_CCED car il existe bien un n° d'axe correspondant à l'axe géré à l'affaire
          # Field name has been initialized in PJT_INIT_CCED because there is a dimension type number tied to the dimension managed by projetc
          # Seul moyen que j'ai trouvé pour faire l'affzo ...
          # Only mean found to do the affzo ...
          Wrseq "Affzo " + WCCEZON + "(" + num$([L]WNOLIGN-1) + ")" Using [FPJT]
        Endif
        If SUPDFLG <> "" Then
          Assign (SUPDFLG + "(" + num$(NI) + ")") With 1
        Endif
      Next NI
      Gosub CLOSE_FILE
    Endif
  Else
    # Unused
    #    SABRMSK = func TRTPJT.GET_ABRMSK(SBASTAB)
    #    SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
    #    If evalue ("dim(" + SUPDFLG + ")") < 0 Then
    #      Raz SUPDFLG
    #    Endif
    #    Gosub OPEN_FILE
    #
    #    #Affzo =SZONDET
    #    Gosub WRITE_FILE_AFFZO
    #    If SUPDFLG <> "" Then
    #      Assign (SUPDFLG) With 1
    #    Endif
    #    Gosub CLOSE_FILE
  Endif
End
# X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)

####################################################################################################
Subprog EXEC_PJTREPEAT_OUISI(SBASTAB, SZONDET, SOLDAZC, SAZC)
Value Char SBASTAB
Value Char SZONDET
Value Char SOLDAZC
Value Char SAZC

Local Integer NI
Local Char SUPDFLG(GLONAVA+GLONABR+GLONAVA+4)
Local Char SABRMSK(GLONABR)
# Issue X3-66544 - 2017-11-29 by FGR : BEGIN
Local Char    WCCEMSK(GLONABR)                   # Nom de l'écran des sections à initialiser/Dimension screen name
Local Integer WNOLIGN                            # Indice de la ligne/ line indice
Local Char    WCCEZON(GLONAVA+GLONABR+GLONAVA+4) # Nom du champ de la section à initialiser/Dimension field name
Local Char    STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Integer WACTIVPJM
# Issue X3-66544 - 2017-11-29 by FGR : END

  If SBASTAB <> "" Then
    If evalue(SBASTAB) > 0 Then
      SABRMSK = func TRTPJT.GET_ABRMSK(SZONDET)
      SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
      If evalue ("dim(" + SUPDFLG + ")") < 0 Then
        Raz SUPDFLG
      Endif
      Gosub OPEN_FILE
      # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)
      WACTIVPJM = func ASYRFNC.ACTIV("PJM")
      # X3-3808  : Update project dimension on sales documents / X3-46226 (LD 08/28/17)
      For NI = 0 To evalue(SBASTAB)-1
        If evalue(SZONDET + "(" + num$(NI) + ")") = SOLDAZC Then
          Assign (SZONDET + "(" + num$(NI) + ")") With SAZC
          #Affzo =SZONDET + "(" + num$(NI) + ")"
          Gosub WRITE_FILE_AFFZO
          # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
          # Code activité PJM actif et il existe un axe géré à l'affaire
          # Active activity code PJM and a dimension type is managed by project
          If WACTIVPJM and GPJMDIE <> "" Then
            ITRTMODULE = [V]CST_ANO
            If dim(GSTRTMODULE) > 0 Then
              STRTMODULE = GSTRTMODULE
            Endif
            If dim(GITRTMODULE) > 0 Then
              ITRTMODULE = GITRTMODULE
            Endif
            WNOLIGN = NI + 1
            WCCEMSK = SABRMSK
            # Initialisation de la section anaylitique d'une ligne de document /Dimension initialization for the line document
            Gosub PJT_INIT_CCED From TRTPJT
            If WCCEZON <> "" Then
                # Le nom du champ a été initialisé dans PJT_INIT_CCED car il existe bien un n° d'axe correspondant à l'axe géré à l'affaire
                # Field name has been initialized in PJT_INIT_CCED because there is a dimension type number tied to the dimension managed by projetc
                # Seul moyen que j'ai trouvé pour faire l'affzo ...
                # Only mean found to do the affzo ...
                Wrseq "Affzo " + WCCEZON + "(" + num$([L]WNOLIGN-1) + ")" Using [FPJT]
            Endif
          Endif
          # X3-3808  : Update project dimension on sales documents / X3-49226 (LD 08/04/17)
          If SUPDFLG <> "" Then
            Assign (SUPDFLG + "(" + num$(NI) + ")") With 1
          Endif
        Endif
      Next NI
      Gosub CLOSE_FILE
    Endif
  Else
    SABRMSK = func TRTPJT.GET_ABRMSK(SZONDET)
    SUPDFLG = "[M:" + SABRMSK + "]UPDFLG"
    If evalue ("dim(" + SUPDFLG + ")") < 0 Then
      Raz SUPDFLG
    Endif
    Gosub OPEN_FILE
    If evalue(SZONDET) = SOLDAZC Then
      Assign (SZONDET) With SAZC
      #Affzo =SZONDET
      Gosub WRITE_FILE_AFFZO
      If SUPDFLG <> "" Then
        Assign (SUPDFLG) With 1
      Endif
    Endif
    Gosub CLOSE_FILE
  Endif
End

####################################################################################################
$OPEN_FILE
Local Char SZADXIFS(type(adxifs)-10)
Local Char SZADXIRS(type(adxirs)-10)
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)

  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  # --------------------------------------------------
  SZPROGNAME = "WPJT" + num$(adxuid(1))
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
  Openo SZFULLSRC, 0 Using [FPJT]
  # --------------------------------------------------
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [FPJT]
  Wrseq "#Traitement généré pour affzo dynamique" Using [FPJT]
  Wrseq "$AFFZO_DYNAMIQUE" Using [FPJT]
Return

####################################################################################################
$WRITE_FILE_AFFZO
  If SBASTAB <> "" Then
    Wrseq "Affzo " + SZONDET + "(" + num$(NI) + ")" Using [FPJT]
  Else
    Wrseq "Affzo " + SZONDET Using [FPJT]
  Endif
Return

####################################################################################################
$CLOSE_FILE
Local Integer IVALIDOK

  Wrseq "Return" Using [FPJT]
  # --------------------------------------------------
  Openo Using [FPJT]
  # --------------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  # --------------------------------------------------
  # Compilation du traitement généré
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  # --------------------------------------------------
  If IVALIDOK Then
    Gosub AFFZO_DYNAMIQUE From =SZPROGNAME
    Call EFFACE(SZFULLSRC, IVALIDOK) From ORDSYS
    Call EFFACE(SZFULLADX, IVALIDOK) From ORDSYS
  Endif
Return

####################################################################################################
Subprog TRAITEMENT_MODULE(MODULE, STRTMODULE, ITRTMODULE)
Value Integer MODULE
Variable Char STRTMODULE
Variable Integer ITRTMODULE

Local Integer PSUBB

  Case MODULE
    When 2
      # Compta tiers
      STRTMODULE = "TRTPJTREPACC"
    When 3
      # Compta tiers
      STRTMODULE = "TRTPJTREPAPAR"
    When 5
      # Vente
      STRTMODULE = "TRTPJTREPSAL"
    When 6
      # Achat
      STRTMODULE = "TRTPJTREPPUR"
    When 7
      # Stock
      STRTMODULE = "TRTPJTREPSTK"
    When 8
      # GPAO
      STRTMODULE = "TRTPJTREPGPAO"
    When 9
      # Tronc commun
      STRTMODULE = "TRTPJTREPTC"
    When 12
      # Support client
      STRTMODULE = "TRTPJTREPHDK"
    When 13
      # Action commerciale
      STRTMODULE = "TRTPJTREPCRM"
    When Default
      Raz STRTMODULE
  Endcase
  #
  ITRTMODULE = G_NON
  If STRTMODULE <> "" Then
    Call EXISTE_ADX("", "", STRTMODULE, PSUBB) From ORDSYS
    If PSUBB Then
      ITRTMODULE = G_OUI
    Endif
  Endif
End

