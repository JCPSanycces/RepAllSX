#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# SUBPOHA : Gestion des commandes standards d'achat        MBT 24/11/97 #
#           Modifié                                         HN Jui 2003 #
# --------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "POH"                       #
# Les traitements sur champ "Call" se trouvent dans le SUBPOH           #
#########################################################################

$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=3;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=3;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=3;GFLAG : If fstat Raz [F:PTR] : Endif
#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return

$FILTRE
#-----------------------------------------------#
# Ne traiter que les commandes de type standard #
#-----------------------------------------------#
Default File [POH]
FILTSUP="POHTYP=1"
Return

$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseigné (écran ou transaction), prendre celui-la -----#
If [M:POH0]DOCNAM<>""
  [L]AREPORT=[M:POH0]DOCNAM
Elsif [F:PTR]DOCNAM<>""
  [L]AREPORT=[F:PTR]DOCNAM
Endif
Return

$AP_IMPRIME
#---------------------------------------------------------------#
# Après une impression il faut être sur d'être sur le bon enreg #
#---------------------------------------------------------------#
Raz [L]AREPORT
Gosub RELIT From GOBJSUB
Return

$OUVRE
#----- Vérification si fonction appelable dans le contexte ! -----#
If clalev([M:POI1]) & !GIMPORT
  GMESSAGE=mess(17,130,1) : # Fonction non appelable dans le contexte !
  GERR=1 : OK=0 : Return
Endif
#-----
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
#----- Défini dans le WWAGLOBTC -----#
Global Libelle  GPOH_INDBASTAX(max(func AFNC.ACTIV("PVA"),20))
Global Libelle  GPOH_INDTAX       : # No de la ligne de taxe à traiter
Global Decimal  GPOH_RND          : # Arrondi de la devise de la commande
Global Integer  GPECBOUT  : GPECBOUT = 1 # Issue 42064 - 2011-12-28 by MUARN : PEC sur bouton droit
# Issue 84130 - 2013-03-26 by SR
Local  Integer  WCREOUVSTC : WCREOUVSTC = 0
If dim(GOUVSTC)<1 : Global Integer  GOUVSTC :WCREOUVSTC = 1 : Endif# Issue 84130 - 2013-03-22 by SR :Landed cost
#----- Ouverture fichier BUDPAR si module Compta à Oui -----#
If GMODU(2)=2  : # Compta
  If !clalev([F:BUP])  Local File BUDPAR     [BUP]  : Endif
Endif
If !clalev([F:GCM])    Local File GACM       [GCM]  : Endif
If !clalev([F:PSO])    Local File PREQUISO   [PSO]  : Endif
If !clalev([F:BPR])    Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPR2])   Local File BPARTNER   [BPR2] : Endif
If !clalev([F:BPS])    Local File BPSUPPLIER [BPS]  : Endif
If !clalev([F:BPS2])   Local File BPSUPPLIER [BPS2] : Endif
If !clalev([F:BPC])    Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:BPD])    Local File BPDLVCUST  [BPD]  : Endif
If !clalev([F:TCY])    Local File TABCOUNTRY [TCY]  : Endif
If !clalev([F:POS])    Local File POSCOD     [POS]  : Endif
If !clalev([F:TCA])    Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:TPT])    Local File TABPAYTERM [TPT]  : Endif
If !clalev([F:STCH])   Local File COSTSTCH   [STCH] : Endif # Issue 84130 - 2012-09-18 by MUARN : landed cost SDC
If !clalev([F:STCD])   Local File COSTSTCD   [STCD] : Endif # Issue 84130 - 2012-09-18 by MUARN : landed cost SDC
If !clalev([F:STCL])   Local File COSTSTCL   [STCL] : Endif # Issue 84130 - 2012-11-29 by SR : landed cost SDC
If !clalev([F:FCS])    Local File FRECST     [FCS]  : Endif # Issue 84130 - 2012-11-29 by SR : landed cost SDC
If !clalev([F:ICTD])   Local File INCOTERMD  [ICTD] : Endif # Issue 84130 - 2012-11-29 by SR : landed cost SDC
If !clalev([F:PID])    Local File PINVOICED  [PID]  : Endif # Issue 82703 - 2012-11-20 by SR : FCC
If !clalev([F:STCF])   Local File COSTSTCF   [STCF] : Endif # Issue 90991 - 2013-10-23 by MUARN : sdc sites
If !clalev([F:SHD])    Local File SHIPMENTD  [SHD]  : Endif # Issue  - 2015-09-10 by SR :Pour solde des lignes
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:ITS])  Local File ITMSALES   [ITS]  : Endif
  If !clalev([F:MVC])  Local File BPCUSTMVT  [MVC]  : Endif
  If !clalev([F:SOH])  Local File SORDER     [SOH]  : Endif
  If !clalev([F:SOP])  Local File SORDERP    [SOP]  : Endif
  If !clalev([F:SOQ])  Local File SORDERQ    [SOQ]  : Endif
  If !clalev([F:SVF])  Local File SVCRFOOT   [SVF]  : Endif
  If !clalev([F:SVV])  Local File SVCRVAT    [SVV]  : Endif
Endif
#----- Ouverture fichiers ordre de fabrication -----#
If GMODU(8)=2 : # Si module GPAO présent
  Gosub OPEN_FILES_MFG From MFGLIB
Endif
#----- Ouverture fichiers ordre de sous-traitance -----#
Gosub OPEN_FILES_SCO From SCOLIB

#----------------------------
# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

#----- Ouverture fichiers liens Appel d'offre avec DA et adresse -----#
If !clalev([F:PSA])  Local File PREQUISA  [PSA] : Endif
If !clalev([F:BPA])  Local File BPADDRESS [BPA] : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

# Issue 112754 - 2017-01-03 by MUARN
maxmem=max(int(maxmem/1024),45000)

#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
Raz GBIDC1 # Issue 108221 - 2015-06-11 by MUARN
#-----------------------------------------------------#
# Contrôle existence de la structure tarif par défaut #
# et chargement des libellés colonnes par défaut      #
#-----------------------------------------------------#
Raz GRCPFCY, GPLISTC, GPUU, GREVFLG, GAPPFLG, GPLIFLG, GVACFLG, GDATFLG,
&   GCOEUOM, GPURTRACE
Local Libelle  WMODULE : WMODULE=6
Local Char     CODE(3), SYMBOLE2(30)
Local Integer  I, WRET, WCOD, MAJCDE
Local Shortint OUVFICFLG
Local Libelle  WPE_POHCLEFLG, WCLEFLG, WTRAIT, WLINCLEFLG
If WRET<>0 OK=0 : Return : Endif
GPLISTC="néant" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- chargement des formats évalués -----#
For I=0 To 8 [M:POH2]FMTREM(I)="NZ:9.2#" : Next I
#------------------------------------------------------------------------#
# Ouverture masques des adresses, des pickings et des paramètres encours #
#------------------------------------------------------------------------#
If !clalev([M:AD61])  Local Mask ADRBPR   [AD61] : Endif
If !clalev([M:AD62])  Local Mask ADRBPR   [AD62] : Endif
If !clalev([M:PCEV])  Local Mask PCEE     [PCEV] : Endif
If !clalev([M:ORDK])  Local Mask ORDK     [ORDK] : Endif
If !clalev([M:SBCK])  Local Mask SBCK     [SBCK] : Endif
If !clalev([M:SCOK])  Local Mask SCOK     [SCOK] : Endif

# Issue 84130 - 2012-11-15 by MUARN : landed cost mise à jour des données structure de cout
If !clalev([M:STCP])  Local Mask STCPAR  [STCP]  : Endif
If !clalev([M:STCDW]) Local Mask STCDW   [STCDW] : Endif
If !clalev([M:STCD])  Local Mask STCD    [STCD]  : Endif
Call RAZSTCDW From STCLIB
Raz [M:STCD]

#-----------------------------------------------------------------#
# Récupération des paramètres achats et budgets                   #
# Chargement GITMFLG : 1=Réf.art  2=Réf.art/fou                   #
#            GREVFLG : 1=Modif sans avenant  2=Avec               #
#            GAPPFLG : 1=Modif sans changement des signataires    #
#                      2=Modif avec reprise du cycle de signature #
#            GPLIFLG : 0=Rien                                     #
#                      1=Conversion ligne      si OLDCUR<>CUR     #
#                        Taxes et calcul TTC   si GVACFLG=1       #
#                        Date livraison prévue si GDATFLG=1       #
#                      2=Recherche tarif                          #
#            GVACFLG : 0=Régime de taxe inchangé                  #
#                      1=Régime modifié, màj taxes et calcul TTC  #
#            GDATFLG : 0=Date de commande inchangée               #
#                      1=Date de commande modifiée                #
#-----------------------------------------------------------------#
GFCY=GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
Gosub CHARG_PARAM
If GMESSAGE<>""
  GERR=1 : OK=0 : Return
Endif
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0 : GVACFLG=0 : GDATFLG=0 : GORITITCOL=1
#----- Effacement fichier de travail -----#
If !GIMPORT : # Test à cause de la simulation d'import en génération auto cdes -----#
  Gosub EFFAC_PWRKORDERS From SUBPOHB : If OK=0  Return : Endif
Endif
#-----------------------------------------------#
# Déclaration des variables pour tableau lignes #
#-----------------------------------------------#
Gosub DECLARE From TABLEAUX
Return

$AFFMASK
#----------------------------------------------------#
# Premier affichage écran après appel de la fonction #
# -------------------------------------------------- #
#         Chargement des formats évalués             #
#----------------------------------------------------#
For I=0 To 8 [M:POH2]FMTREM(I)="NZ:9.2#" : Next I
Return

$SETBOUT
#-------------------------------------------------------------------------#
# Activation / Désactivation des menus (ToolBar) et boutons (bas d'écran) #
#-------------------------------------------------------------------------#
#----- Menus "Texte entête" et "Texte pied" dans la ToolBar -----#
If GREP="C" | GREP="D" | [M:POH0]POHNUM<>""
  CHMEN+="FG"
Endif
#----- Menus "Adresse commande"  et "Adresse expéditeur"  dans la ToolBar -----#
If GREP<>"" | CLECUR
  CHMEN+="HI"
Endif
#----- Menu "Informations douanières" -----#
If CLECUR
  CHMEN+="J"
Endif
#----- Menus "Acompte"  et "Situation cde"  dans la ToolBar -----#
If GREP="" & CLECUR
  CHMEN+="KL"
Endif
#----- Menu "Consultation commandes" dans la ToolBar -----#
If GREP="" & CLECUR & clalev([M:CPO2])=0
  CHMEN+="M"
Endif
#----- Menu "Transaction" -----#
CHMEN+="N"
#----- Menu "Traçabilité" -----#
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "O" Endif # SYMEU 10/12/2008 : branchement traçabilité pièces
#RBA 110811/US2
If func AFNC.ACTIV("EDIX3") <> 0
  If func CNSEDKSTD.GET_EDI_CATACT([M]POHNUM, 3) <> 0
    CHMEN += "U"#Historic
  Endif
  #CJ 110811/US9
  GFCY=[M:POH0]POHFCY : GBIDC2="I" : Gosub AUTORIS_OPT From CONTX3
  If GBIDI2
  #RBA 112138/US2
    CHMEN += "V" #Run EDI Issue
  Else
    Call VIREBOUT(CHMEN,"V") From GOBJET # No EDI Issue
  Endif
  #/CJ 110811/US9
Endif
#/RBA 112138/US2
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
#-----------------------------------------------------------------#
# Suppression des boutons # CODE                                  #
#                         D DUPLICATION suivant autorisation      #
#                         A ANNULATION  si commande soldée        #
#                                       si commande réceptionnée  #
#                                       si commande facturée      #
#-----------------------------------------------------------------#
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR
  If [M:POH1]CLEFLG>1 Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
  Raz GBIDI3
  If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
    Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
    Raz GMESSAGE, GERR
  Endif
  If [M:POH1]CLEFLG>1 | [M:POH1]RCPFLG>1 | [M:POH1]INVFLG>1 | GBIDI3<>0
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif
  # Issue 82703 - 2012-11-19 by SR : si facture complémentaire existe
  Look [PID] PID1(2)=1;[M:POH0]POHNUM
  [G:PID]currind=1 : [G:PID]currlen=0 : # Réinitialisation clé par défaut
  If !fstat  Call VIREBOUT (CHAINE,"A") From GOBJET : Endif
  #----- L'utilisateur a-t-il droit au solde ? -----#
  GFCY=[M:POH0]POHFCY : GBIDC2="T" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
  #-----
Endif
If GREP<>""   Call VIREBOUT(CHAINE,"12") From GOBJET   : Return    : Endif
If !CLECUR | [M:POH1]APPFLG>3 Call VIREBOUT(CHAINE,"1") From GOBJET : Endif
# Issue 88354 - 2013-03-04 by SR : Tester GCONSULT
If !CLECUR | [F:PTR]CLEBUT<>2 | GCONSULT <> 0  : Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
Return

$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
# 1 = Signataires                   #
# 2 = Solde                         #
#                                   #
# F = Texte entête                  #
# G = Texte pied                    #
# H = Adresse commande              #
# I = Adresse expédition            #
# J = Informations douanières       #
# K = Acomptes                      #
# L = Situation commande            #
# M = Consultation des commandes    #
# N = Visu transaction de saisie    #
#-----------------------------------#
Local  Libelle  WTYPADR
Local  Char     WABREV(5)
Local  Char     SAV_ZONCOU(GLONAVA)
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
Local  Integer  SAV_GCONSDIA : SAV_GCONSDIA=GCONSDIA
If GREP<>"" SAV_ZONCOU=COUZON Else SAV_ZONCOU="" : Endif
#----- S'assurer que la classe [F:POH] corresponde bien à la commande affichée -----#
If [F:POH]POHNUM<>[M:POH0]POHNUM
  Read [POH] POH0=[M:POH0]POHNUM : If fstat  Raz [F:POH] : Endif
Endif
# Issue 116879 - 2016-06-03 by SR : Si la modification n'est pas autorisée, il faut locker ici
#----- Si boutons avec màj, pose du verrou si nécessaire -----#
If find(BOUT,"2","F","G","H","I","J")
  If !VERROU  Gosub VERROU From GOBJET : OK=1 : Endif
Endif
#----- Si enregistrement bloqué par un autre utilsateur positionner GCONSDIA -----#
If find(BOUT,"F","G","J")
  If !VERROU & GSTAIMG(3)  GCONSDIA=2 : Endif
Endif
# End issue 116879
#-----
Case BOUT
  When "2" : Gosub AVANTBOUT_SOLDE
  When "F","G" : If GREP="" & dim(ACTMOD)>1 & !ACTMOD  GCONSDIA=2 : Endif
  When "H","I" : If GREP="" & (!ACTMOD | !VERROU)  GCONSULT=1 : Endif
  When "J" : Local  Integer WEXEFLG : WEXEFLG=1
Endcase
Return

$AVANTBOUT_SOLDE
#-----------------------------------------#
# Avant exécution du solde de la commande #
#-----------------------------------------#
#----- Vérification si commande bloquée logiquement -----#
If !VERROU  GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return : Endif
#----- L'utilisateur a-t-il droit au solde ? -----#
GFCY=[M:POH0]POHFCY
GBIDC2="T" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)  : GERR=1 : OK=0 : Return : Endif
#----- Commande déja soldée ! -----#
If [F:POH]CLEFLG=2
  GMESSAGE=mess(55,194,1) : GERR=1 : OK=0 : Return
Endif
#----- Cde non totalement signée, solde interdit (Test supprimé le 02/04/99) -----#
# If [F:POH]APPFLG<3
#   GMESSAGE=mess(60,194,1) : GERR=1 : OK=0 : Return
# Endif
#----- La commande va être entièrement soldée, voulez-vous continuer ? -----#
OK=2 : Call AVERTIR(mess(56,194,1),OK) From GESECRAN
If OK=1  OK=0 : Return : Endif
OK=1
#----- Aucune réception effectuée, voulez-vous solder la commande ? -----#
If [F:POH]RCPFLG=1
  OK=2 : Call OUINON(mess(59,194,1),OK) From GESECRAN
  If OK=1 OK=0 : Return Else OK=1 : Endif
Endif
#----- Solde d'une contremarque, le besoin vente ne sera plus pris en compte -----#
If sigma(I=0,[M:POH2]NBLIG-1,[M:POH2]SOHNUM(I)<>"")
  OK=1 : Call OUINON(mess(388,194,1),OK) From GESECRAN
  If OK=1 OK=0 : Return : Endif
Endif
#----- Commande soldée et acomptes actifs, il convient de les supprimer -----#
Call VERF_ACOMPTE_ACTIF(6,[M:POH0]POHNUM,OK) From TRTTPT
If OK=0
  OK=2 : Call OUINON(mess(554,199,1)+"\"+mess(205,100,1),OK) From GESECRAN
  If OK=1  OK=0 : Return : Endif
  OK=1
Endif
# Issue 106506 - 2015-05-28 by SR : Landed Cost
Filter [F:CTRD] Where POHNUM = [M:POH0]POHNUM & SHIPNUM = ""
Look [F:CTRD] First With Nohint
Filter [F:CTRD]
If !fstat : GMESSAGE=mess(512,194,1)  : GERR=1 : OK=0 : Return : Endif
#
If sigma(I=0,[M:POH2]NBLIG-1,[M:POH2]SHIQTYSTU(I)<>0)
# Issue 114095 - 2016-01-28 by SR : solde interdit si des expés non soldées existent
#  OK = 0
#  # Des expéditions existent et ne pourront pas être réceptionnées : Voulez-vous continuer ?
#  Call OUINON(mess(505,194,1),OK) From GESECRAN
#  If OK <> 2 : OK = 0 : Return : Endif
   GMESSAGE = mess(546,194,1) :  GERR = 1 : OK = 0 : Return
Endif
# End issue 106506
#----- En inter-site le solde est-il faisable ?
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz GBIDI3
  Call CTLMAJSOH("S", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
  #----- Si commande vente soldée, permettre quand même solde commande d'achat -----#
  If GBIDI3=9  Raz GBIDI3, GMESSAGE : Endif
  #-----
  If GBIDI3<>0 : OK=0 : Return : Endif
Endif
#----- C'est parti pour le solde complet de la commande -----#
#If GMODU(8)=2
  If clalev([M:SBCK])=0 Local Mask SBCK [SBCK] : Endif : # Si module GP présent
#Endif
If clalev([M:ORDK])=0 Local Mask ORDK   [ORDK] : Endif
If clalev([F:ITV]) =0 Local File ITMMVT [ITV]  : Endif
Return

$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 1 = Signataires                    #
# 2 = Solde                          #
#------------------------------------#
Case BOUT
  When "2" : Gosub RELIT    From GOBJSUB
             Gosub LECTURE_TRACE  :  # Pour inter-sites
Endcase
Return

$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
# F = Texte entête                          #
# G = Texte pied                            #
# H = Adresse commande                      #
# I = Adresse expédition                    #
# J = Informations douanières               #
# K = Acomptes                              #
# L = Situation de commande                 #
# M = Consultation des commandes            #
# N = Visu transaction de saisie            #
#-------------------------------------------#
Case BOUT
  When "F" : Gosub APRESBOUT_TEXTE
  When "G" : Gosub APRESBOUT_TEXTE
  When "H" : If !GCONSULT & GREP=""
               WTYPADR=1 : WABREV="AD61" : Gosub MAJ_ADRESSE From TRTACHCDE1
             Endif
  When "I" : If !GCONSULT & GREP=""
               WTYPADR=2 : WABREV="AD62" : Gosub MAJ_ADRESSE From TRTACHCDE1
             Endif
  When "J" : Gosub ACTIV_GSTAENR
Endcase
#VPO 14/03/11 72298 ajout test dim(SAV_ZONCOU)
If dim(SAV_ZONCOU)>0 & SAV_ZONCOU<>"" & !GIMPORT  SUIZON=SAV_ZONCOU : Endif
GCONSULT=SAV_GCONSULT
GCONSDIA=SAV_GCONSDIA
Return

#----- Activation du bouton enregistrer -----#
$ACTIV_GSTAENR
If GREP="" & WEXEFLG=9
  Gosub ENTRE_MODIF From GOBJSUB
Endif
Return

$APRESBOUT_TEXTE
#----------------------------------#
# Texte entête et pied de commande #
#----------------------------------#
If mkstat=4 & GREP="" : # Texte modifié
  Gosub ENTRE_MODIF From GOBJSUB
Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If GREP="" & ([M:POH1]TEX1<>"" | [M:POH1]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Return

$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro ligne   (ZONLIG)     #
#----------------------------------#
Default Mask [POH2]
Default File [POP]
CRIT   = 'POHNUM="'+[M:POH0]POHNUM+'"'
FICLIG = "PORDERP"
ABLIG  = "POP"
ZONLIG = "POPLIN"
Return

$LIENS_LIG
#--------------------------------------------------------#
# Après lecture ligne [F:POP] lecture complément [F:POQ] #
#--------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
Read [POQ] POQ0=[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ
If fstat Raz [F:POQ] : Endif

# Issue 84130 - 2013-01-22 by MUARN : landed cost
Raz [M:POH2]WSTCSEQ(NOL)

[M:POH2]=[F:POQ]
[M:POH2]PREQTYPUU(NOL)=[M:POH2]QTYPUU(NOL)
If [F:POQ]WIPNUM<>""  [M:POH2]STOMGTCOD(NOL)=2  Else  [M:POH2]STOMGTCOD(NOL)=1 : Endif
If dim([M:POH2]TSICOD1(NOL))>0 [M:POH2]TSICOD1(NOL)=[F:POP]TSICOD(0) : Endif
If dim([M:POH2]TSICOD2(NOL))>0 [M:POH2]TSICOD2(NOL)=[F:POP]TSICOD(1) : Endif
If dim([M:POH2]TSICOD3(NOL))>0 [M:POH2]TSICOD3(NOL)=[F:POP]TSICOD(2) : Endif
If dim([M:POH2]TSICOD4(NOL))>0 [M:POH2]TSICOD4(NOL)=[F:POP]TSICOD(3) : Endif
If dim([M:POH2]TSICOD5(NOL))>0 [M:POH2]TSICOD5(NOL)=[F:POP]TSICOD(4) : Endif
[M:POH2]VAT1(NOL)=[F:POP]VAT(0)
[M:POH2]VAT2(NOL)=[F:POP]VAT(1)
[M:POH2]VAT3(NOL)=[F:POP]VAT(2)
[M:POH2]WAPPFLG(NOL)=0
# Issue 84130 - 2012-11-29 by SR
[M:POH2]WSTCUPD(NOL)=0
#----- Chargement de l'indicateur de modification du coefficient -----#
Gosub CHARG_COEFLG From SUBPOH
#----- Lecture article-fournisseur -----#
If [F:ITP]ITMREF<>[F:POP]ITMREF | [F:ITP]BPSNUM<>[M:POH0]BPSNUM
   Read [ITP] ITP0=[F:POP]ITMREF;[M:POH0]BPSNUM
   If fstat Raz [F:ITP] : Endif
Endif
If [F:ITP]ITMREF<>""
  Call PCAL_QTY([F:ITP]PURMINQTY,[F:ITP]PUU,[M:POH2]PURMINQTY(NOL),[M:POH2]PUU(NOL),
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
Else
  [M:POH2]PURMINQTY(NOL)=0
Endif
#----- Mise à jour indicateur ligne (0=en cours de création, 1=Créée) -----#
[M:POH2]LINFLG(NOL)=1
#----- Chargement date pour budget -----#
If GPURCMMDAT=1
  [M:POH2]DATBUD(NOL)=[M:POH0]ORDDAT
Else
  [M:POH2]DATBUD(NOL)=[M:POH2]EXTRCPDAT(NOL)
Endif
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                "POP",0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"") From TRTX3CPT

# V6 Règle affectation
[M:POH2]PTOCOD(NOL) = func ITMLIB.GET_PTOCOD([M:POH2]ITMREF(NOL),[M:POH2]PRHFCY(NOL))
#VPO 09/12/10 17667
[M:POH2]UPDPSDFLG(NOL)=1
# Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
If [M:POH2]NETCUR(NOL)=""
  [M:POH2]NETCUR(NOL) = [M:POH1]CUR
Endif
If [M:POH2]CPRCUR(NOL) =""
  [M:POH2]CPRCUR(NOL) = GLOCALDEV
Endif
If [M:POH2]STCNUM(NOL)<> ""
  Diszo [POH2]CPRAMT(NOL), CPRCOE(NOL), CPR(NOL)
Else
  Actzo [POH2]CPRAMT(NOL), CPRCOE(NOL), CPR(NOL)
Endif
Return


$INICRE_LIG
#------------------------------------#
# Avant le Write de la ligne [F:POP] #
#------------------------------------#
[M:POH2]POPLIN(nolign-1)=[F:POP]POPLIN : # Renumérotation de 1000 en 1000 en création !
Gosub CHARGLIGNE
[F:POP]POHNUM=[M:POH0]POHNUM : [F:POP]POPSEQ=1 : [F:POP]POHTYP=1 : [F:POP]CPY=GSOCIETE
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
#----- Si création de la commande depuis les plans de travail -----#
If clalev([M:POI1])
  ABRFIC="POP" : Gosub POINT_GENPURORD From TRTACHCDE1
Endif
#-----
[M:POH2]CMMTAX(nolign-1)=max(GPURCMMTAX,1) : # Indicateur Type d'engagement
#-----
Return

$INIMOD_LIG
#--------------------------------------#
# Avant le Rewrite de la ligne [F:POP] #
#--------------------------------------#
Gosub CHARGLIGNE
#sr 09.11 demande 75936 : Réajuster le flag facturé selon les quantités commandées et facturées
# sr 12.11 Demande 78582 test fait à l'envers
If [F:POQ]QTYSTU >[F:POQ]INVQTYSTU : [F:POQ]LININVFLG=1 : Else [F:POQ]LININVFLG=2 : Endif
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Return

$VALLIG
#----------------------------------------------------------------------#
# Traitements complémentaires ligne commande                           #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
#----------------------------------------------------------------------#
Local Integer STAT
Gosub LECT_FICLIG From SUBPOHB : # Lecture fichiers ligne pour maj
Case SIGN
  When  1 : Gosub CRELIG
  When -1 : Gosub SUPLIG
  When Default
Endcase
Return

$CRELIG
#-----------------------------------------#
# Après Write de la ligne de commande POP #
#-----------------------------------------#
#----- Ecriture des comptes et sections de la ligne de commande -----#
Call ENREG_ACCCCE(nolign-1,"[M:POH2]LINACC","[M:POH2]LINDSP","[M:POH2]CCE","POP",
&                 0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"",TRTLIG) From TRTX3CPT
If GOK<1  Return : Endif
#-----
If [M:POH2]CREFLG(nolign-1)<>0  Goto MODLIG  : Endif

Raz [F:POQ]
[F:POQ]=[M:POH0]            : [F:POQ]=[M:POH1]   : [F:POQ]=[M:POH2]
# Issue 95516 - 2013-12-30 by SR :GENPURORD (pour POP) a pu changer le numéro de commande
[F:POQ]POHNUM = [F:POP]POHNUM
[F:POQ]POQSEQ=1             : [F:POQ]POHTYP=1
[F:POQ]POPLIN=[F:POP]POPLIN : [F:POQ]LININVFLG=1 : [F:POQ]LINPRNFLG=1
[F:POQ]CPY=GSOCIETE
If [F:POQ]ORI=0  [F:POQ]ORI=1 : Endif
If [F:POQ]LINCLEFLG=0
  [F:POQ]LINCLEFLG=1 : [M:POH2]LINCLEFLG(nolign-1)=1
Endif
#-----------------------------------------------------------------------#
# Si article géré en stock ou sous-traitance récup n.O/D et màj encours #
#-----------------------------------------------------------------------#
# Issue 112754 - 2016-09-27 by SR : Services
#If ([M:POH2]STOMGTCOD(nolign-1)>1 & [F:POQ]ORI<>2 & [F:POQ]LINTYP<>4) |
#&   [F:ITM]SCSFLG=2 | [F:POQ]LINTYP=2
If ([M:POH2]STOMGTCOD(nolign-1)>1 & [F:POQ]ORI<>2 & [F:POQ]LINTYP<>4) |
&   [F:POQ]ITMKND=2 | [F:POQ]LINTYP=2
  If [F:POQ]LINCLEFLG<>2
    Raz [M:ORDK]
    Call NUMERO(GWIP,[F:POP]PRHFCY,[M:POH0]ORDDAT,"",[F:POQ]WIPNUM,STAT) From SUBANM
    If GOK<0
      Return
    Elsif GOK<1 | STAT<>0
      GOK=0 : GERR=1 : GMESSAGE=GWIP-mess(60,199,1)
      Return
    Endif
    If [M:POH0]BETFCY=2 & [M:POH0]BETCPY<>2
      [F:POQ]WIPTYP=7 : [F:POQ]WIPSTA=1 : # type "TRF"
    Else
      [F:POQ]WIPTYP=2 : [F:POQ]WIPSTA=1 : # type "POF"
    Endif
    [M:ORDK]MAJCOD    = "C"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    If [F:POQ]WIPTYP=7
      [M:ORDK]ORIFCY  = [F:POQ]LINSTOFCY
    Else
      [M:ORDK]ORIFCY  = [F:POQ]POHFCY
    Endif
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = [F:POP]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = 0
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = [F:POQ]ORI
    [M:ORDK]MRPMES    = 1
    # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
      [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
      [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement pièce d'origine si ligne issue d'une SCF -----#
    If [F:POQ]ITMREFORI<>""
      [M:ORDK]ITMREFORI=[F:POQ]ITMREFORI
      [M:ORDK]VCRTYPORI=[F:POQ]VCRTYPORI
      [M:ORDK]VCRNUMORI=[F:POQ]VCRNUMORI
      [M:ORDK]VCRLINORI=[F:POQ]VCRLINORI
      [M:ORDK]VCRSEQORI=[F:POQ]VCRSEQORI
    #----- Chargement pièce d'origine si contremarque -----#
    Elsif [F:POQ]SOHNUM<>""
      [M:ORDK]VCRTYPORI=2
      [M:ORDK]VCRNUMORI=[F:POQ]SOHNUM
      [M:ORDK]VCRLINORI=[F:POQ]SOPLIN
      [M:ORDK]VCRSEQORI=[F:POQ]SOQSEQ
    #----- Si on vient des plans et un besoin pris, on charge la pièce d'origine -----#
    Elsif clalev([M:PMG]) & [M:PMG]NBLIG=1
      If [M:PMG]WIPNUM(0)<>""
        Read [ORD] ORD0=[M:PMG]WIPTYP(0);[M:PMG]WIPNUM(0);[M:PMG]ITMREF(0)
        If fstat  Raz [F:ORD] : Endif
      Else
        Raz [F:ORD]
      Endif
      If [F:ORD]VCRTYPORI>0 & [F:ORD]VCRNUMORI<>""
        [M:ORDK]ITMREFORI=[F:ORD]ITMREFORI
        [M:ORDK]VCRTYPORI=[F:ORD]VCRTYPORI
        [M:ORDK]VCRNUMORI=[F:ORD]VCRNUMORI
        [M:ORDK]VCRLINORI=[F:ORD]VCRLINORI
        [M:ORDK]VCRSEQORI=[F:ORD]VCRSEQORI
      Else
        [M:ORDK]VCRTYPORI=[M:PMG]VCRTYP(0)
        [M:ORDK]VCRNUMORI=[M:PMG]VCRNUM(0)
        [M:ORDK]VCRLINORI=[M:PMG]VCRLIN(0)
        [M:ORDK]VCRSEQORI=[M:PMG]VCRSEQ(0)
      Endif
    #----- Chargement pièce d'origine si un seul besoin pris -----#
    Elsif [F:POQ]RETQTYSTU<>0
      Raz GBIDI1
      If clalev([M:POI1]) & GIMPORT
        For [PWO] PWO0 Where PRONUM=[M:POI1]PRONUM
&                          & CODFNC="POI"
&                          & LINNUM=[M:POI1]POILIN([M:POH2]POHLIN(nolign-1))
          GBIDI1+=1
        Next
      Else
        For [PWO] PWO0 Where PRONUM=adxuid(1)
&                          & CODFNC="POH"
&                          & LINNUM=[M:POH2]POHLIN(nolign-1)
          GBIDI1+=1
        Next
      Endif
      If GBIDI1=1 & [F:PWO]PSDLIN=0
        Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
        If !fstat
          If [F:ORD]VCRTYPORI>0 & [F:ORD]VCRNUMORI<>""
            [M:ORDK]ITMREFORI=[F:ORD]ITMREFORI
            [M:ORDK]VCRTYPORI=[F:ORD]VCRTYPORI
            [M:ORDK]VCRNUMORI=[F:ORD]VCRNUMORI
            [M:ORDK]VCRLINORI=[F:ORD]VCRLINORI
            [M:ORDK]VCRSEQORI=[F:ORD]VCRSEQORI
          Else
            [M:ORDK]VCRTYPORI=[F:ORD]VCRTYP
            [M:ORDK]VCRNUMORI=[F:ORD]VCRNUM
            [M:ORDK]VCRLINORI=[F:ORD]VCRLIN
            [M:ORDK]VCRSEQORI=[F:ORD]VCRSEQ
          Endif
        Else
          Raz [F:ORD]
        Endif
      Endif
    Endif
    #-----
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    [M:ORDK]ABBFIL    = "POQ"
    Call WIP From TRTWIP : If GOK<1 Return : Endif
  Endif
Endif
# Issue 84764 & 84500 GA 10/2012 code extrait de EXPLOITE_PWO
If find([F:POQ]VCRTYPORI,10,36)  # Si achat sous-traitance
    [M:SBCK]MAJCOD = "C"
    [M:SBCK]WIPTYP = [F:PWO]WIPTYP    # Issue 92278 GA 09/2013
    [M:SBCK]WIPNUM = [F:PWO]WIPNUM
    [M:SBCK]ITMREF = [F:POQ]ITMREF    # FQ 72170 GA 03/2011 pb car [F:PWO]ITMREF est vide ?
    [M:SBCK]VCRNUM = [F:POQ]POHNUM
    [M:SBCK]VCRLIN = [F:POQ]POPLIN
    [M:SBCK]VCRSEQ = [F:POQ]POQSEQ
    If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
    [M:SBCK]BPSNUM = [F:POQ]BPSNUM
    [M:SBCK]BPAADD = [F:POQ]SCOADD
    [M:SBCK]ORDQTY = [F:POQ]QTYSTU
    [M:SBCK]ORDDAT = [F:POQ]ORDDAT # Issue 102679 GA 09/2014 [F:POQ]EXTRCPDAT-[F:POQ]OFS
    [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
    Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POQ]LINAMT,[M:SBCK]EXTPRI,STAT) From TRTDEV
    If [F:POQ]QTYSTU<>0 # Issue 96915 GA 02/2014
       [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
    Endif
    [M:SBCK]OFS    = [F:POQ]OFS
    [M:SBCK]MSGFLG = 1
    [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG
    [M:SBCK]ITMREFORI = [F:POQ]ITMREFORI
    [M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
    [M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
    [M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
    [M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI
    # Issue X3-68900 - 2018-01-24 by MUARN : modification dates sur EO
    [M:SBCK]UPDSCO    = [M:POH2]UPDSCO(nolign-1)
    Call MAJ_SBC From SBCLIB
    If [M:SBCK]CODRET<>0
      If [M:SBCK]VCRTYPORI=10
        GMESSAGE=mess(96,193,1)-":"-GMESSAGE
      Elsif [M:SBCK]VCRTYPORI=36
        GMESSAGE=mess(913,196,1)-":"-GMESSAGE
      Endif
      GERR=1 : GOK=0 : Return
    Endif
Endif
#----------------------------------------------------#
# Mise à jour des besoins pris "POS", "POP" et "SCF" #
#----------------------------------------------------#
If [F:POQ]RETQTYSTU<>0 & [F:POQ]SOHNUM=""
   Gosub EXPLOITE_PWO   From SUBPOHB : If GOK<1 Return : Endif
Endif
#-------------------------------------------------------------------#
# Mise à jour budget (engagements), en cde article et appel d'offre #
#-------------------------------------------------------------------#
[F:POQ]RCPCLEFLG=4

#----- Pas de mise à jour budget si inter-sites ou si ligne article composé -----#
If [F:POQ]LINTYP<>2 & ([M:POH0]BETCPY=2 | [M:POH0]BETFCY<>2)
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,"POQ",3,GBIDI1) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
[M:POH2]CMMNUM(nolign-1)=[F:POQ]CMMNUM

#----- Mise à jour éventuelle de la ligne commande vente -----#
If [F:POQ]SOHNUM<>""
  SYMBOLE2="SOH"+[F:POQ]SOHNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=mess(391,198,1)-[F:POQ]SOHNUM-mess(10,100,1) : GERR=1 : GOK=0 : Return
  Endif
  #-----
  Readlock [SOQ]SOQ0=[F:POQ]SOHNUM;[F:POQ]SOPLIN;[F:POQ]SOQSEQ
  If fstat=1  GOK=-1
    GLOCK="$SORDERQ"-[F:POQ]SOHNUM-num$([F:POQ]SOPLIN)-num$([F:POQ]SOQSEQ) : Return
  Elsif fstat GOK=0
    Call RSTA("SOQ",[F:POQ]SOHNUM-num$([F:POQ]SOPLIN)-num$([F:POQ]SOQSEQ)) From GLOCK : Return
  Endif
  [F:SOQ]FMINUM=[F:POQ]POHNUM
  [F:SOQ]FMILIN=[F:POQ]POPLIN
  [F:SOQ]FMISEQ=[F:POQ]POQSEQ
  #-----
  Gosub POINT_BEFREWFMI From TRTACHCDE1
  #-----
  Rewrite [SOQ]
  If fstat : GOK=0 : Call FSTA("SOQ") From GLOCK : Endif
  If SYMBOLE2<>""  Unlock=SYMBOLE2 : Endif
  If GOK=0  Return : Endif

  Gosub CRE_MTO_SO_PO From PURMTOLIB # 10.09
Elsif clalev([M:PMG]) & [M:PMG]NBLIG=1 & [M:PMG]VCRTYP=2 : # GH 29/02/2012 bug 79880
  #----- Si on vient des plans et un besoin pris, on charge la pièce d'origine -----#
  Read [SOQ]SOQ0=[M:PMG]VCRNUM;[M:PMG]VCRLIN;[M:PMG]VCRSEQ
  If !fstat
     Gosub CRE_MTO_SO_PO From PURMTOLIB
  Endif
Elsif find(GFONCTION,"FUNMPICK","FUNMPICKA") & clalev([F:PWO]) & dim([M:POI1]PRONUM)=1 : # GH 15/05/2014 bug 99197
  For [PWO]PWO0 Where PRONUM = [M:POI1]PRONUM & CODFNC="POI" & LINNUM=nolign & find(WIPTYP,1,8)<>0
     Call CRE_MTO_SO_PO([F:PWO]WIPTYP,[F:PWO]WIPNUM,[F:PWO]ITMREF) From FUNMPICK
  Next
Endif

#-----
If [F:POQ]WIPNUM<>""  Gosub MAJ_ITV     : If GOK<1 Return : Endif : Endif
If [F:POQ]PQHNUM<>""  Gosub MAJ_AOF     : If GOK<1 Return : Endif : Endif
Gosub CAL_MVS : # Calcul des montants HT et TTC restant en commande
#--------------------------------------------------#
# Calcul qté besoin en UA et Write de la ligne POQ #
#--------------------------------------------------#
Call PCAL_QTY([F:POQ]RETQTYSTU,[F:POQ]STU,[F:POQ]RETQTYPUU,[F:POQ]PUU,
&             [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
[M:POH2]FBUFLG(nolign-1)=[F:POQ]FBUFLG : [F:POQ]RCPCLEFLG=1
[F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&            +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
If [F:ITP]ITMREF<>[F:POQ]ITMREF | [F:ITP]BPSNUM<>[F:POQ]BPSNUM
  Read [ITP] ITP0=[F:POQ]ITMREF;[F:POQ]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
[F:POQ]ITMREFBPS=[F:ITP]ITMREFBPS
#----- Si création de la commande depuis les plans de travail -----#
If clalev([M:POI1])
  ABRFIC="POQ" : Gosub POINT_GENPURORD From TRTACHCDE1
Endif
#-----
[F:POQ]CREDAT=date$
[F:POQ]CREUSR=GUSER
[F:POQ]EXPNUM=[C]EXPORT
Write [POQ] : If fstat GOK=0 : Call FSTA("POQ") From GLOCK : Return : Endif
# Issue 84130 - 2012-11-22 by SR : landed cost mise à jour des données structure de cout
If [M:POH2]WSTCSEQ(nolign-1) <> 0
   Call STCMAJ("POH2",nolign-1,14,[F:POQ]POHNUM,[F:POQ]POPLIN,
&             [F:POQ]POQSEQ,WRET) From STCLIB
   If WRET : GOK = 0 : Return : Endif
Endif
#----- MISE à JOUR STATISTIQUES LIGNE COMMANDE -----#
Call VALSTA("POD",SIGN) From SUBPS2  : If GOK<1 Return : Endif
Return

$MODLIG
#-------------------------------------------#
# Après Rewrite de la ligne de commande POP #
#-------------------------------------------#
If [F:POQ]LINCLEFLG<>[M:POH2]LINCLEFLG(nolign-1)
  WPE_POHCLEFLG=1 : # Indicateur solde ligne modifié (Appel point d'entrée POHCLE)
Else
  WPE_POHCLEFLG=0 : # Indicateur solde ligne non modifié
Endif

#-----
[F:POQ]=[M:POH0] : [F:POQ]=[M:POH1] : [F:POQ]=[M:POH2]
#VPO 09/12/10 17667 maj qte sur une DA
If [M:POH2]UPDPSDFLG(nolign-1)=2 & TRTLIG="M"
  Gosub MAJ_PREQUISQTE From SUBPOHB : If GOK<1 Return : Endif
Endif
#----- Mise à jour qtés besoins sous-traitance pris en compte -----#
# FQ 75631 GA 09/2011 Maj de SCM => suppression de & [F:POQ]WIPNUM<>""
If find([F:POQ]VCRTYPORI,10,36)  # Si achat sous-traitance
  [M:POH2]RETQTYSTU(nolign-1)=[M:POH2]QTYSTU(nolign-1)
  [F:POQ]RETQTYSTU=[M:POH2]QTYSTU(nolign-1)
  [F:POQ]RETQTYPUU=[M:POH2]QTYPUU(nolign-1)
  #-----
  Raz [M:SBCK]                    # Issue 92278 GA 09/2013
  [M:SBCK]MAJCOD    = "M"
  [M:SBCK]VCRNUM    = [F:POQ]POHNUM
  [M:SBCK]VCRLIN    = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ    = [F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
  [M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
  [M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
  [M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI
  [M:SBCK]BPSNUM    = [F:POQ]BPSNUM
  [M:SBCK]BPAADD    = [F:POQ]SCOADD
  If [F:POQ]LINCLEFLG<>2
     [M:SBCK]ORDQTY=[F:POQ]QTYSTU
  Elsif [F:POQ]RCPQTYSTU<>0
     [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU : # ligne cde soldée donc qté commandée = qté réceptionnée
  Else
     [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD="A"
  Endif
  [M:SBCK]ORDDAT = [F:POQ]ORDDAT # Issue 102679 GA 09/2014 [F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,STAT) From TRTDEV
  If [F:POQ]QTYSTU<>0 # Issue 96915 GA 02/2014
     [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  Endif
  [M:SBCK]OFS    = [F:POQ]OFS
  [M:SBCK]MSGFLG = 1                        # llc 03.01 (inutile après tout)
  [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG         # 03.02 13517
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    If [M:SBCK]VCRTYPORI=10
      GMESSAGE=mess(96,193,1)-":"-GMESSAGE
    Elsif [M:SBCK]VCRTYPORI=36
      GMESSAGE=mess(913,196,1)-":"-GMESSAGE
    Endif
    GERR=1 : GOK=0 : Return
  Endif
  # Issue 93008
  #If [M:SBCK]CLEFLG<>[F:POQ]LINCLEFLG
  #  [F:POQ]LINCLEFLG=[M:SBCK]CLEFLG
  #  [M:POH2]LINCLEFLG(nolign-1)=[M:SBCK]CLEFLG
  #Endif
Endif
#----- Mise à jour de l'encours (POF) -----#
# Issue 112754 - 2016-11-28 by SR : Services
If ([M:POH2]STOMGTCOD(nolign-1)>1 & [F:POQ]ORI<>2 & [F:POQ]LINTYP<>4) |
&   [F:POQ]ITMKND=2 | [F:POQ]LINTYP=2
  Raz [M:ORDK]
  If [F:POQ]LINCLEFLG<>2
    Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
    If fstat  Raz [F:ORD] : Endif
    [M:ORDK]          = [F:ORD]
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = [F:POP]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = [F:POQ]RCPQTYSTU
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = [F:POQ]ORI
    [M:ORDK]MRPMES    = 1
   # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
      [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
      [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
    If [F:ORD]WIPNUM=""
      If [F:POQ]WIPTYP=7
        [M:ORDK]ORIFCY    = [F:POQ]LINSTOFCY
        If [F:POQ]OCNLIN<>0
          [M:ORDK]VCRTYPORI = 2
          [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
          [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
          [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
        Else
          [M:ORDK]VCRTYPORI = 0
          [M:ORDK]VCRNUMORI = ""
          [M:ORDK]VCRLINORI = 0
          [M:ORDK]VCRSEQORI = 0
        Endif
      Else
        [M:ORDK]ORIFCY    = [F:POQ]POHFCY
        [M:ORDK]ITMREFORI = [F:POQ]ITMREFORI
        [M:ORDK]VCRTYPORI = [F:POQ]VCRTYPORI
        [M:ORDK]VCRNUMORI = [F:POQ]VCRNUMORI
        [M:ORDK]VCRLINORI = [F:POQ]VCRLINORI
        [M:ORDK]VCRSEQORI = [F:POQ]VCRSEQORI
      Endif
    Endif
    #-----
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    [M:ORDK]ABBFIL    = "POQ"
  Else
    [M:ORDK]MAJCOD    = "A"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
  Endif
  Call WIP From TRTWIP : If GOK<1 Return : Endif
Endif
[F:POQ]UPDDAT=date$
[F:POQ]UPDUSR=GUSER
[F:POQ]EXPNUM=[C]EXPORT
#----- Ne pas effectuer de màj si modif ligne soldée à cause de la répartion et engagement HT -----#
If [F:POQ]LINCLEFLG<>2 | [F:POQ]CMMTAX<>1
  #----- Pas de mise à jour budget si inter-sites ou si ligne article composé -----#
  If [F:POQ]LINTYP<>2 & ([M:POH0]BETCPY=2 | [M:POH0]BETFCY<>2)
    If WLINCLEFLG=2 & [F:POQ]LINCLEFLG<>2
      GBIDC2="POQ2" : # Désolde ligne commande
    Else
      GBIDC2="POQ1" : # Modification ligne commande
    Endif
    Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,GBIDC2,3,GBIDI1) From TRTACHDIV1
    If GOK<1 Return : Endif
  Endif
  [F:POQ]RCPCLEFLG-=3
Elsif [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG>2
  [F:POQ]RCPCLEFLG=1
Endif
#-----
If [F:POQ]WIPNUM<>""  Gosub MAJ_ITV     : If GOK<1 Return : Endif : Endif
Gosub CAL_MVS : # Calcul des montants HT et TTC restant en commande
#-------------------------#
# Rewrite de la ligne POQ #
#-------------------------#
[M:POH2]FBUFLG(nolign-1)=[F:POQ]FBUFLG
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
If WPE_POHCLEFLG
  WTRAIT=1
  If [F:POQ]LINCLEFLG=2  WCLEFLG=1  Else  WCLEFLG=2 : Endif
  Gosub POINT_POHCLE From TRTACHCDE1
Endif
#-----
Rewrite [POQ]
If fstat GOK=0 : Call FSTA("POQ") From GLOCK : Return : Endif
# Issue 84130 - 2012-11-22 by SR : landed cost mise à jour des données structure de cout
If [M:POH2]WSTCSEQ(nolign-1) <> 0
   Call STCMAJ("POH2",nolign-1,14,[F:POQ]POHNUM,[F:POQ]POPLIN,
&             [F:POQ]POQSEQ,WRET) From STCLIB
   If WRET : GOK = 0 : Return : Endif
Endif
# Issue 110948 - 2015-09-10 by SR :Mise à jour des éventuelles expéditions
# Issue 111004 - 2015-09-14 by SR : WLINCLEFLG à la place de [M:POH2]LINCLEFLGOLD sur dossiers autres que GX3APP
If WLINCLEFLG <> [F:POQ]LINCLEFLG
  Gosub MAJ_SHD From TRTACHDIV1
Endif
# End issue 110948

# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
# Pour chaque réception existante, il faudra faire ou défaire la PEC des FCC
If WPE_POHCLEFLG & [F:POQ]RCPQTYSTU <> 0
   If [F:POQ]LINCLEFLG = 2
    Call REGPRIX_FCC(2,"",0) From TRTACHFAC1
   Else
    Call REGPRIX_FCC(3,"",0) From TRTACHFAC1
   Endif
Endif
#-----------------------------------------------------------------------#
# Mise à jour statistiques ligne commande & opération de sous-traitance #
#-----------------------------------------------------------------------#
Call VALSTA("POD",SIGN) From SUBPS2  : If GOK<1 Return : Endif
Return

$SUPLIG
#-----------------------------------------------------------#
# Avant Delete ou Rewrite de la ligne de commande POP       #
# Suppression du budget (engagements), màj en cde article   #
# Soustraction statistiques ligne commande                  #
# Historisation des changements ligne si modif avec avenant #
#-----------------------------------------------------------#
Local Shortint I  : I=999
If GREP<>"A" I=nolign : Endif
Readlock [POQ] POQ0=[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ
If fstat=1  GOK=-1
   GLOCK="$PORDERQ"-[F:POP]POHNUM-num$(I) : Return
Elsif fstat GOK=0
   Call RSTA("POQ",[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)) From GLOCK : Return
Endif
If TRTLIG="M"  WLINCLEFLG=[F:POQ]LINCLEFLG : Endif
#----- Ne pas effectuer de màj si modif ligne soldée à cause de la répartition et engagement HT -----#
If TRTLIG<>"M" | [F:POQ]LINCLEFLG<>2 | [M:POH2]LINCLEFLG(nolign-1)<>2 | [F:POQ]CMMTAX<>1
  [F:POQ]RCPCLEFLG+=3
  #----- Pas de mise à jour budget si inter-sites ou si ligne article composé -----#
  If [F:POQ]LINTYP<>2 & ([M:POH0]BETCPY=2 | [M:POH0]BETFCY<>2)
    If TRTLIG="A"
      GBIDC2="POQ"    : # Suppression ligne commande
    Else
      If [F:POQ]LINCLEFLG<>2 & [M:POH2]LINCLEFLG(nolign-1)=2
        GBIDC2="POQ2" : # Solde ligne commande
      Else
        GBIDC2="POQ1" : # Modification ligne commande
      Endif
    Endif
    Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,GBIDC2,3,GBIDI1) From TRTACHDIV1
    If GOK<1 Return : Endif
  Endif
Endif
#-----
If [F:POQ]WIPNUM<>""  Gosub MAJ_ITV     : If GOK<1 Return : Endif : Endif
Gosub CAL_MVS : # Calcul des montants HT et TTC restant en commande
If GREVFLG=2 Call HISTO_CDE("POP","POQ",TRTLIG) From TRTACHCDE1
             If GOK<1 Return : Endif : Endif
Call VALSTA("POD",SIGN) From SUBPS2  : If GOK<1 Return : Endif
#-----
If TRTLIG="A"
  #----- Suppression du texte ligne si nécessaire -----#
  If left$([F:POQ]LINTEX,3)="POQ"
    Call SUP_CLOB([F:POQ]LINTEX,GBIDI1) From TRTX3TEX
  Endif
Elsif TRTLIG="M"
  #----- Cas particulier où l'on modifie le texte en le supprimant -----#
  If [M:POH2]LINTEX(nolign-1)="" & left$([F:POQ]LINTEX,3)="POQ"
    Call SUP_CLOB([F:POQ]LINTEX,GBIDI1) From TRTX3TEX
  Endif
  #VPO 09/12/10 17667 maj qte sur une DA
  If [M:POH2]UPDPSDFLG(nolign-1)=2
    Gosub MAJ_PREQUIS From SUBPOHB : If GOK<1 Return : Endif
  Endif
  Return : # Si modif c'est fini
Endif
#-----
Gosub LECT_FICLIG From SUBPOHB : # Relecture fichiers ligne à cause du VALSTA !
#----- Mise à jour ordre de sous-traitance et/ou OF -----#
# FQ 75631 GA 09/2011 Maj de SCM => suppression de & [F:POQ]WIPNUM<>""
If find([F:POQ]VCRTYPORI,10,36)  # Si achat sous-traitance
  Raz [M:SBCK]                    # Issue 92278 GA 09/2013
  [M:SBCK]MAJCOD    = "A"
  [M:SBCK]VCRNUM    = [F:POQ]POHNUM
  [M:SBCK]VCRLIN    = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ    = [F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
  [M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
  [M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
  [M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI
  [M:SBCK]MSGFLG    = 1
  [M:SBCK]CLEFLG    = [F:POQ]LINCLEFLG
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    If [M:SBCK]VCRTYPORI=10
      GMESSAGE=mess(96,193,1)-":"-GMESSAGE
    Elsif [M:SBCK]VCRTYPORI=36
      GMESSAGE=mess(913,196,1)-":"-GMESSAGE
    Endif
    If [M:SBCK]CODRET<>9
       GOK=1 : Raz GMESSAGE   # Autoriser la suppression si EO/OF absent
    Else
       GERR=1 : GOK=0 : Return # Issue 98737 GA 04/2014 EO/OF locked: no update possible
    Endif
  Endif
Endif
#-----------------------------------------------------------------------#
# Avant Delete de la ligne de commande POP                              #
# Suppression de la 'POF', Delete de POQ, suppression flag appel offre  #
# Suppression du texte de la ligne si nécessaire                        #
# Réintégration des quantités demandées si une demande a été prise      #
# Mise à jour ligne commande vente si contremarque                      #
#-----------------------------------------------------------------------#
If [F:POQ]WIPNUM<>""
  [M:ORDK]MAJCOD = "A"
  [M:ORDK]WIPTYP = [F:POQ]WIPTYP
  [M:ORDK]WIPNUM = [F:POQ]WIPNUM
  [M:ORDK]ITMREF = [F:POQ]ITMREF
  Call WIP From TRTWIP : If GOK<1 Return : Endif
Endif
#----- Suppression comptes et sections de la ligne de commande -----#
Call ENREG_ACCCCE(0,"","","","POP",0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"","A") From TRTX3CPT
If GOK<1  Return : Endif
#-----
Gosub MAJ_PREQUIS From SUBPOHB : If GOK<1 Return : Endif
Gosub MAJ_SORDERQ From SUBPOHB : If GOK<1 Return : Endif

# Issue 84130 - 2012-11-22 by SR : landed cost mise à jour des données structure de cout
Delete [F:STCD] Where VCRTYP =14 & VCRNUM = [F:POQ]POHNUM & VCRLIN =[F:POQ]POPLIN & VCRSEQ = 1
If fstat=1 GOK=-1 : GLOCK="$COSTSTCD"-[F:POP]POHNUM-num$([F:POQ]POPLIN) : Return : Endif
Delete [POQ]
If fstat=1 GOK=-1 : GLOCK="$PORDERQ"-[F:POP]POHNUM-num$(I) : Return : Endif
If [F:POQ]PQHNUM<>"" Gosub MAJ_AOF    : If GOK<1 Return : Endif : Endif
Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
If GFCY<>GFCYDEF(6)
  GFCY=GFCYDEF(6)
  Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
  Gosub CHARG_PARAM : Raz GMESSAGE
Endif
# Issue 71069 - 2013-08-19 by MUARN : pjt
[M:POH0]POHFCY=GFCY
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:POH0]POHFCY,"[M:POH2]PJT") From TRTPJT
Endif
#----- chargement des formats évalués -----#
For I=0 To 8 [M:POH2]FMTREM(I)="NZ:9.2#" : Next I
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

#----- Ecran POH0 -----#
Actzo [POH0]1-99
#[M:POH0]POHFCY=GFCY # Issue 71069 - 2013-08-19 by MUARN : pjt
If GUSRFCY(1)<>"\" & GNBAUZ=1 & [M:POH0]POHFCY<>""
  Diszo [POH0]POHFCY        : # Saisie inutile si un seul site permis
Else
  Actzo [POH0]POHFCY        : # Activation saisie si plusieurs sites possibles
Endif
[M:POH0]ORDDAT=date$
#----- Ecran POH1 -----#
Actzo [POH1]1-15
Grizo [POH1]STOFCY : Raz GSTOFCY : # Site d'expédition par défaut
If dim([M:POH1]CCE)>0 Actzo [POH1]CCE : Endif
[M:POH1]INVFCY    =GFINRSP
[M:POH1]EXTRCPDAT1=date$
[M:POH1]BUY=GUSER
[M:POH1]APPFLG=1 : [M:POH1]PRNFLG=1 : [M:POH1]CLEFLG=1
[M:POH1]RCPFLG=1 : [M:POH1]INVFLG=1
#----- Ecran POH2 ----#
Actzo [POH2]5
Raz [M:POH2]POHCOU
[M:POH2]WREFFLG=GITMFLG
#----- Ecran POH3 -----#
Actzo [POH3]5
Raz [M:POH3]TOTORD,    [M:POH3]TTVORD
Raz [M:POH3]TOTLINQTY, [M:POH3]TOTLINWEU, [M:POH3]TOTLINVOU
[M:POH3]DSPWEU =GSALDSPWEU
[M:POH3]DSPVOU =GSALDSPVOU
# Issue 46305 - 2011-12-21 by MUARN : montant mini de commande message bloquant o/n
[M:POH2]POHMINAMT = GPOHMINAMT
[M:POH3]POHMINAMT = GPOHMINAMT
If !GIMPORT
  Diszo [POH3]20 : # Désactivation du bloc ARC
Else
  Actzo [POH3]20 : # Activation du bloc ARC pour l'import
Endif
#Chgtbk [POH3]20 with mess(584,197,1)
#-----
GREVFLG=1 : GAPPFLG=1 : GPLIFLG=0
Raz [M:AD61], [M:AD62] : # Effacement des masques adresses fournisseur
Raz [M:PCEV]           : # Effacement informations douanières
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:POH1]TEX1, [M:POH1]TEX2, [M:POH2]LINTEX
If !GIMPORT  Call RESET_IMAGE (4) From GESECRAN : Endif
#----- affectation des infos du fournisseur ------#
If [M:POH0]BPSNUM <> ""
    VALEUR = [M:POH0]BPSNUM
    Read [F:BPS]BPS0 = VALEUR
    Call AM_BPSNUM(VALEUR) From SUBPOH
    # Issue 116874 - 2016-06-01 by MUARN : SUBPOHD
    # Issue 71276 - 2015-06-11 by SR : Déplacé dans SUBPOHB
    Gosub BAM_BPSNUM From SUBPOHD
Endif

# Issue 86819 - 2013-01-03 by MUARN : en intersoc on garde données ventes précédentes
If GMODU(5)=2 : # Si module Ventes présent
  Raz [F:SOH], [F:SOP] : # à cause de l'INISEC
Endif

# Issue 84130 - 2012-11-23 by MUARN : landed cost mise à jour des données structure de cout
Call RAZSTCDW From STCLIB

# Issue 71069 - 2013-08-14 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POH0]POHFCY,"[M:POH2]PJT") From TRTPJT
Endif

$FINRAZCRE
Return

$RAZDUP
#-------------------#
# Avant duplication #
#-------------------#
# Issue 84130 - 2013-01-16 by MUARN : landed cost
Local Shortint NOL
Local    Decimal  WCPRAMT
Local    Integer  WSTAT
# Issue 110426 - 2015-08-21 by MUARN : intersoc relance contrôle pour changement paramétrage
Local    Char     WPOHFCY(GLONFCY) : [L]WPOHFCY=[M:POH0]POHFCY
Local    Char     WBPSNUM(GLONBPS) : [L]WBPSNUM=[M:POH0]BPSNUM

Actzo [POH0]ORDDAT
Raz GBIDC2, GMESSAGE, mkstat
If [M:POH0]ORDDAT<date$
  [M:POH0]ORDDAT=date$
  GDATFLG=1 : GBIDC2="ORDDAT" : Affzo [POH0]ORDDAT
Endif
[M:POH0]OLDCUR=[M:POH1]CUR
Call CONTDEV([M:POH1]CUR,[M:POH0]ORDDAT) From TRTDEV
If mkstat
  Raz GMESSAGE, mkstat
  If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
    Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat Raz [F:BPR] : Endif
  Endif
  If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
    Read [BPS] BPS0=[M:POH0]BPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  If [M:POH0]OLDCUR<>[F:BPS]CUR
    GBIDC3=[F:BPS]CUR : Call AM_CUR(GBIDC3) From SUBPOH
    GBIDC2="CUR" : Affzo [POH1]10
  Endif
  Call CONTDEV([M:POH1]CUR,[M:POH0]ORDDAT) From TRTDEV
  If mkstat
    Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
  Endif
Endif
# Issue 101746 - 2014-08-27 by MUARN : mise à jour cours devise
Local    Integer I
Call COURSITE(GCUR,GFCY,[M:POH1]CHGTYP,[M:POH0]ORDDAT,[M:POH1]CHGCOE,I) From TRTDEV
If !GIMPORT  Affzo [POH1]CHGCOE : Endif

If !mkstat & GBIDC2<>""
  Call PAMPLIFLG([M:POH2]NBLIG,GBIDC2) From TRTACHPRI1
Endif
Raz GBIDC2, mkstat
#----- Le demandeur ne peut être modifié que s'il n'y a pas de filtre -----#
If GBUYFLT<2
  [M:POH1]BUY=GUSER : Actzo [POH1]BUY : Affzo [POH1]5
Endif
#----- Gestion des textes entête et pied -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:POH1]TEX1,3)="POH"
  Call DUP_CLOB("POH",[M:POH1]TEX1,WRET) From TRTX3TEX
  If WRET<1  Raz [M:POH1]TEX1 : Endif
Endif
If left$([M:POH1]TEX2,3)="POH"
  Call DUP_CLOB("POH",[M:POH1]TEX2,WRET) From TRTX3TEX
  If WRET<1  Raz [M:POH1]TEX2 : Endif
Endif
#--------------------------------------------------------------------#
# Effacement entête : No cde, No avenant, ARC, indicateurs à "Non"   #
# Effacement champs ligne : ARC, No AOF, No cde vente et indicateurs #
#--------------------------------------------------------------------#
GREVFLG=1 : GAPPFLG=1 : GPLIFLG=0
Raz [M:POH0]REVNUM,[M:POH2]POHCOU,
&   [M:POH3]OCNDAT,[M:POH3]OCNNUM,[M:POH3]OCNREM
[M:POH1]APPFLG=1 : [M:POH1]PRNFLG=1 : [M:POH1]CLEFLG=1
[M:POH1]RCPFLG=1 : [M:POH1]INVFLG=1

# Issue 71069 - 2013-08-22 by MUARN :PJT
# Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Duplication avec paramètre à OUI => si le code affaire de la ligne est <> de celui de l'en-tête, on reprend l'en-tête
Call TRAITE_DUPLICATION("[M:POH1]PJTH") From TRTPJT

# Issue 84130 - 2012-11-23 by MUARN : landed cost mise à jour des données structure de cout
Call RAZSTCDW From STCLIB
# Issue 82703 - 2012-10-04 by SR : FCC Razer REACSTPUR
For I=0 To [M:POH2]NBLIG-1
  Raz [M:POH2]LINOCNDAT(I),[M:POH2]LINOCNNUM(I),[M:POH2]LINREVNUM(I),
&     [M:POH2]SOHNUM(I),   [M:POH2]SOPLIN(I),   [M:POH2]SOQSEQ(I),
&     [M:POH2]CREFLG(I),   [M:POH2]UPDFLG(I),   [M:POH2]RETQTYSTU(I),
&     [M:POH2]PQHNUM(I),   [M:POH2]PPDLIN(I),   [M:POH2]LINRCPNBR(I),
&     [M:POH2]LININVNBR(I),[M:POH2]RCPQTYSTU(I),[M:POH2]CMMNUM(I),
&     [M:POH2]REACSTPUR(I)
  #MAE, LCC 106504 Raz des qtés expédiées
  Raz [M:POH2]SHIQTYSTU(I)
# Issue 84130 - 2013-01-22 by MUARN : landed cost
  Raz [M:POH2]CPR(I), [M:POH2]LINAMTCPR(I), [M:POH2]CSTPUR(I), [M:POH2]LINCSTPUR(I)
  [M:POH2]LINCLEFLG(I)=1 : [M:POH2]FBUFLG(I)=1
  # Issue 113592 - 2016-01-08 by MUARN : Charges en STC
  Raz [M:POH2]FCSCPR(I), [M:POH2]FCSCSTPUR(I)

  # Issue 84129 - 2013-01-22 by MUARN : landed cost récupération des données de base
  Call RECH_COST([M:POH2]PRHFCY(I),[M:POH0]BPSNUM, [M:POH2]ITMREF(I), [M:POH2]CPRCOE(I), WCPRAMT, [M:POH2]STCNUM(I)) From STCLIB
  If GLOCALDEV <> GSYSCUR
    Call CONVERT2(GSYSCUR,GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WCPRAMT,WCPRAMT,WSTAT) From TRTDEV
    [M:POH2]CPRAMT(I)=arr(WCPRAMT,10^-GDECPRI)
  Else
    [M:POH2]CPRAMT(I)=WCPRAMT
  Endif
  If [M:POH2]CPRCOE(I)=0 [M:POH2]CPRCOE(I)=1 Endif
  [M:POH2]NETCUR(I) = [M:POH1]CUR
  [M:POH2]CPRCUR(I) = GLOCALDEV

  If [M:POH2]STCNUM(I)<> ""
    Diszo [POH2]CPRAMT(I), CPRCOE(I), CPR(I)
  Else
    Actzo [POH2]CPRAMT(I), CPRCOE(I), CPR(I)
  Endif

  #VPO 09/12/10 17667
  [M:POH2]UPDPSDFLG(I)=1
  # Issue 75218 - 2011-07-21 by VPO : Pb en duplication, la reception est considérée facturée
  Raz [M:POH2]INVQTYSTU(I)
  # Issue 84732 - 2012-09-24 by SR : Réinitialisation du flag "ORI"
  [M:POH2]ORI(I)=1
  #----- Gestion des textes lignes article -----#
  If left$([M:POH2]LINTEX(I),3)="POQ"
    Call DUP_CLOB("POQ",[M:POH2]LINTEX(I),WRET) From TRTX3TEX
    If WRET<1  Raz [M:POH2]LINTEX(I) : Endif
  Endif
  NOL=I
  [M:POH2]WSTCSEQ(I)=0

  # Issue 84130 - 2013-01-16 by MUARN : landed cost structure de coût-calcul
  If [M:POH2]STCNUM(I)<>""
     Gosub ALIM_STCP From SUBPOH
     Call GES_STCDW("POH2",NOL,WRET) From STCCLC
   Endif

Next I
# sr 08.11 Demande 75370 : Remettre à 0 le montant facturé sur les éléments de facturation
For I = 0 To [M:POH3]NBFAC-1
    Raz [M:POH3]INVCPLAMT(I)
Next I
If !GIMPORT
  Affzo [POH0]FIL2, REVNUM : Affzo [POH1]25 : Affzo [POH3]5,20
Endif
Raz [M:POH0]OLDCUR
Actzo  [POH0]BPSNUM
Actzo  [POH1]ORDREF, PTE, 10-15
If [M:POH0]BETFCY<>2 Grizo [POH1]STOFCY Else Actzo [POH1]STOFCY : Endif
If dim([M:POH1]CCE)>0 Actzo [POH1]CCE : Endif
Actzo  [POH2]5
Actzo  [POH3]5
If !GIMPORT
  Diszo [POH3]20 : # Désactivation du bloc ARC
Else
  Actzo [POH3]20 : # Activation du bloc ARC pour l'import
Endif

# Issue 71069 - 2016-01-28 by MUARN :pjt
Actzo [POH1]PJTH

Call NTSDUP([M:POH0]BPSNUM,"BPSNUM") From TRTNTSCTL   # supplier notes

# Issue 84130 - 2012-10-29 by MUARN : coeff/cout modifiable si pas de SDC
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]STCNUM(I)<> ""
    Diszo [POH2]CPRAMT(I), CPRCOE(I), CPR(I)
  Else
    Actzo [POH2]CPRAMT(I), CPRCOE(I), CPR(I)
  Endif
Next I
If !GIMPORT : Affzo [M:POH2]1-99 : Endif

# Issue 86819 - 2013-01-03 by MUARN : en intersoc on garde données ventes précédentes
If GMODU(5)=2 : # Si module Ventes présent
  Raz [F:SOH], [F:SOP] : # à cause de l'INISEC
Endif
# Issue 110426 - 2015-08-21 by MUARN : intersoc relance contrôle pour changement paramétrage
Gosub CTRL_INTERSITE  From SUBPOHB

# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POH0]POHFCY,"[M:POH2]PJT") From TRTPJT
Endif

Return

$LIENS
#--------------------------------------------#
# Chargement GFCY : Site de la commande      #
#            GCUR : Devise commande          #
# Récupération des paramètres ACHATS, BUDGET #
#--------------------------------------------#
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0

#----- Si commande inter-sites avec correspondance dans les ventes ------#
If [F:POH]SALFCY<>""
  If [F:FCY]FCY<>[F:POH]SALFCY
    Read [FCY] FCY0=[F:POH]SALFCY : If fstat  Raz [F:FCY] : Endif
  Endif
  GCPY=[F:FCY]LEGCPY
  Call PARAML([F:POH]SALFCY,"LINBPD",GBIDC3) From ADOVAL
  GLINBPD=val(GBIDC3)
  If [F:SOH]SOHNUM<>[M:POH3]OCNNUM
    Read [SOH] SOH0=[M:POH3]OCNNUM : If fstat  Raz [F:SOH] : Endif
  Endif
  If [F:SOH]DME>0  [M:POH0]DME=[F:SOH]DME : Endif
Elsif [F:POH]BETFCY=2
  If find([F:POH]STOFCY,GSITE(1..GNBSITE))
    GCPY=GSOCSITE(find([F:POH]STOFCY,GSITE(1..GNBSITE)))
  Endif
Else
  If GFCY=[F:POH]POHFCY
    Call DEFRCPFCY([F:POH]POHFCY) From TRTACHDEF1
  Endif
Endif
#-----
If GFCY<>[F:POH]POHFCY GFCY=[F:POH]POHFCY : Gosub CHARG_PARAM : Raz GMESSAGE : Endif
GCUR=[F:POH]CUR
#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#-----
If [F:TCU]CUR<>GCUR
  Read [TCU] TCU0=GCUR : If fstat  Raz [F:TCU] : [F:TCU]CURRND=0.01 : Endif
Endif
GPOH_RND=[F:TCU]CURRND
#---------------------------------------------------------------------#
# Chargement de la classe [M:AD61] zones adresse fournisseur commande #
#---------------------------------------------------------------------#
If [F:POH]CRY<>"" | [F:POH]CTY<>""
  [M:AD61]       = [F:POH]
  [M:AD61]ADBBPR = [F:POH]BPSNUM
  [M:AD61]ADBFLG = 2
Else
  Raz [M:AD61]
  [M:AD61]BPAADD = [F:POH]BPAADD
  [M:AD61]ADBBPR = [F:POH]BPSNUM
Endif
#-----------------------------------------------------------------------#
# Chargement de la classe [M:AD62] zones adresse fournisseur expéditeur #
#-----------------------------------------------------------------------#
If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
  [M:AD62]BPAADD      = [F:POH]BPOADD
  [M:AD62]BPRNAM(0)   = [F:POH]BPONAM(0)
  [M:AD62]BPRNAM(1)   = [F:POH]BPONAM(1)
  [M:AD62]BPAADDLIG(0)= [F:POH]BPOADDLIG(0)
  [M:AD62]BPAADDLIG(1)= [F:POH]BPOADDLIG(1)
  [M:AD62]BPAADDLIG(2)= [F:POH]BPOADDLIG(2)
  [M:AD62]CRY         = [F:POH]BPOCRY
  [M:AD62]CRYNAM      = [F:POH]BPOCRYNAM
  [M:AD62]SAT         = [F:POH]BPOSAT
  [M:AD62]POSCOD      = [F:POH]BPOPOSCOD
  [M:AD62]CTY         = [F:POH]BPOCTY
  [M:AD62]ADBBPR      = [F:POH]BPSNUM
  [M:AD62]ADBFLG      = 2
Else
  Raz [M:AD62]
  [M:AD62]BPAADD = [F:POH]BPOADD
  [M:AD62]ADBBPR = [F:POH]BPSNUM
Endif
#----- Chargement informations douanières -----#
[M:PCEV] = [F:POH]
[M:PCEV]WPOSCOD=[F:POH]POSCOD
[M:PCEV]WBPSNUM=[F:POH]BPSNUM
[M:PCEV]WBPAADD=[F:POH]BPAADD
[M:PCEV]WCRY   =[F:POH]CRY
#-----
[M:POH1]EECICT2=[F:POH]EECICT
[M:POH1]ICTCTY2=[F:POH]ICTCTY
#--------------------------------------------------------------------#
# Lecture BPSUPPLIER avec chargement libellés/formats colonnes tarif #
# Lecture BPARTNER                                                   #
#--------------------------------------------------------------------#
If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
  Read [BPS] BPS0=[M:POH0]BPSNUM
  If fstat
    Raz [F:BPS] : GOK=0 : Call RSTA("BPS",[M:POH0]BPSNUM) From GLOCK : Return
  Endif
Endif
#----- Alimentation à partir du modèle d'édition du fournisseur commande -----#
Call ALI_PRTMOD("POH0",8) From TRTX3
#-----
If [M:AD61]ADBFLG=2
  [M:POH0]BPRNAM=[M:AD61]BPRNAM(0)
Else
  [M:POH0]BPRNAM=[F:BPS]BPSNAM
Endif
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
  GSOC_UPDFLG=1 : # Pour forcer l'affichage des entêtes de colonne variables
Endif
Call FMTREM("POH2",GCUR) From TRTPRICE
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#-----
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM
  If fstat
    Raz [F:BPR] : GOK=0 : Call RSTA("BPR",[M:POH0]BPSNUM) From GLOCK : Return
  Endif
Endif
#----- Lecture du fournisseur risque -----#
If [F:BPS]BPSRSK=[F:BPS]BPSNUM
  [F:BPS2]=[F:BPS]
Elsif [F:BPS]BPSNUM<>[F:BPS]BPSRSK
  Read [BPS2] BPS0=[F:BPS]BPSRSK : If fstat  Raz [F:BPS2] : Endif
Endif
#----------------------------------------------------#
# Conversion Mt mini commande et Mt encours autorisé #
#----------------------------------------------------#
If GSYSCUR<>GCUR
  Local Integer STAT
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&              [F:BPS]ORDMINAMT,[M:POH2]ORDMINAMT,STAT)  From TRTDEV
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&              [F:BPS]ORDFREFRT,[M:POH2]ORDFREFRT,STAT)  From TRTDEV    # 106430.n
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&              [F:BPS2]OSTAUZAMT,[M:POH0]OSTAUZAMT,STAT) From TRTDEV
Else
  GBIDD1=1
  [M:POH2]ORDMINAMT=[F:BPS]ORDMINAMT
  [M:POH2]ORDFREFRT=[F:BPS]ORDFREFRT  # 106430.n
  [M:POH0]OSTAUZAMT=[F:BPS2]OSTAUZAMT
Endif
# Issue 46305 - 2011-12-21 by MUARN : montant mini de commande message bloquant o/n
[M:POH2]POHMINAMT = GPOHMINAMT
#----- Chargement des sections analytiques entête -----#
[M:POH0]NBAXE2=GNBDIE
If dim([M:POH1]NBAXE)>0
  Call CHARG_CCEH("POH1","NBAXE","POH") From TRTX3CPT
Endif
#----- Chargement des éléments de facturation et des taxes -----#
Call CHARG_ELEMENTS (3,[M:POH0]POHNUM,"POH3") From TRTACHELT1
Call CHARG_TAXES    (3,[M:POH0]POHNUM,"POH3") From TRTACHELT1
#----- Activation ou désactivation de certains champs -----#
If [F:POH]CLEFLG=2 :  # Commande soldée
  Diszo  [POH0]POHFCY, ORDDAT, BPSNUM
  Diszo  [POH1]1-15
  If dim([M:POH1]CCE)>0 Diszo [POH1]CCE : Endif
  Grizo  [POH1]CHGTYP, 25
  Diszo  [POH2]5
  Diszo  [POH3]5-20
Else
  Diszo  [POH0]POHFCY, ORDDAT, BPSNUM
  #----- Cde réceptionnée ou facturée pas de modif fou facturant/payé, devise, régime -----#
  If [F:POH]INVFLG>1 | [F:POH]INVNBR>0 | [F:POH]RCPFLG>1 | [F:POH]RCPNBR>0
     Diszo [POH1]BPSINV, BPAINV, BPRPAY, BPAPAY, CUR, CHGTYP, VACBPR, 25
     # Issue 71069 - 2016-04-06 by MUARN : PJT
     Diszo [POH1]PJTH
  Else
     Actzo [POH1]BPSINV, BPAINV, BPRPAY, BPAPAY, CUR, CHGTYP, VACBPR, 25
     # Issue 71069 - 2016-04-06 by MUARN : PJT
     Actzo [POH1]PJTH
  Endif
  # Issue 91822 - 2014-01-30 by MUARN : inter-site et commande ventes déjà créée pas de modification de la devise
  If [M:POH0]SALFCY<>"" & [M:POH3]OCNNUM<>""
    Diszo [POH1]CUR, CHGTYP
  Else
    Actzo [POH1]CUR, CHGTYP
  Endif
  #-----
  Actzo [POH1]ORDREF, PTE, MDL, EECICT2, ICTCTY2, BPTNUM, INVFCY, EXTRCPDAT1
  # Issue 89502 - 2013-04-23 by MUARN : landed cost - code regroupement
  Actzo [POH1]GPGCOD
  If dim([M:POH1]CCE)>0 Actzo [POH1]CCE : Endif
  If GBUYFLT<2 Actzo [POH1]BUY Else Diszo [POH1]BUY : Endif
  # Issue 71069 - 2013-08-14 by MUARN : pjt
  #Actzo  [POH2]5
  Actzo  [POH3]5-20
  If [F:POH]SALFCY<>""
    Diszo [POH1]STOFCY
    Diszo [POH3]20
    #Chgtbk [POH3]20 With mess(585,197,1)
  Else
    Grizo [POH1]STOFCY
    Actzo [POH3]20
    #Chgtbk [POH3]20 With mess(584,197,1)
  Endif
Endif
#-----------------------#
# Chargement des lignes #
#-----------------------#
Raz [M:POH2]POHCOU
# Issue 84130 - 2012-11-23 by MUARN : landed cost mise à jour des données structure de cout
Call RAZSTCDW From STCLIB
Gosub LIENS From TABLEAUX

#----- Chargement des valeurs par défaut devises et montants -----#
[M:POH2]WCUR     =GCUR
[M:POH2]WCUR1    =GCUR
[M:POH2]WREFFLG  =GITMFLG
[M:POH3]ORDMINAMT=[M:POH2]ORDMINAMT
# Issue 46305 - 2011-12-21 by MUARN : montant mini de commande message bloquant o/n
[M:POH3]POHMINAMT = [M:POH2]POHMINAMT
[M:POH3]WCUR     =GCUR
#----- Si commande inter-sites avec correspondance dans les ventes -----#
#If [F:POH]SALFCY<>"" & ([M:POH0]DME=3 | GLINBPD<>2)
#  GRCPFCY=[M:POH2]PRHFCY(0)
#  GSTOFCY=[M:POH1]STOFCY
#Endif
#----- Si inter-sites, valeurs par défaut des sites de réception et expédition -----#
If [M:POH0]BETFCY=2
  GRCPFCY=[M:POH2]PRHFCY(0)
  GSTOFCY=[M:POH1]STOFCY
Else
  GSTOFCY=""
Endif
#----- Affichage site de réception par défaut (background) si inter-sites -----#
If [M:POH0]BETFCY=2
  [M:POH1]PRHFCYLIB=space$(max(22-(len(mess(605,197,1))+GLONFCY),0))+mess(605,197,1)-GRCPFCY
Else
  [M:POH1]PRHFCYLIB=""
Endif
#-----
If GFONC1="GESPOH"  Call RAZ_CLOB From ACLOB   : Endif

# Issue 71069 - 2013-08-14 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON & [F:POH]CLEFLG=1 Then
 Call PJT_MODFCY([M:POH0]POHFCY,"[M:POH2]PJT") From TRTPJT
Endif
If [F:POH]CLEFLG=1 :  # Commande non soldée
  Actzo  [POH2]5
Endif

If [F:POH]CLEFLG=2  GCONSDIA=2 Else GCONSDIA=0 : Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If [M:POH1]TEX1<>"" | [M:POH1]TEX2<>""
    Call SET_IMAGE (4)   From GESECRAN
  Else
    Call RESET_IMAGE (4) From GESECRAN
  Endif
Endif
# Issue 84041 - 2012-08-27 by MUARN : engagement ancienne devise
[M:POH1]OLDCURCMM = [M:POH1]CUR

# Issue 84130 - 2013-01-21 by MUARN : landed cost - onglet cout du document
If GFONCTION = "GESPOH" & !GIMPORT
  Call CSTDOC("POH2","POH3", [M:POH0]POHNUM, 14, [M:POH1]CHGCOE) From STCLIB
Endif

# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POH0]POHFCY,"[M:POH2]PJT") From TRTPJT
Endif

Call UPDATE_CONTAINER([M:POH2]TCTRNUM,[M:POH2]TCTRQTY) From SUBPOHC # 106430.n

Return

$VERIF_CRE
#---------------------------#
# Vérifications en création #
#---------------------------#
Gosub VERIF
If OK=0 Return Else OK=1 : Endif

# Issue 71069 - 2016-09-27 by MUARN : pjt et inisec, déplacé en VERIF
# Issue 71069 - 2016-06-10 by SR : US 180
#----- Si on vient des plans et un besoin pris et multi affaire,si besoin = DA/OF/SST/SOF, on charge le PTJH----#
If clalev([M:PMG]) & [M:PMG]NBLIG=1 &  GPJTSNGDOC <> 2 & [M:POH1]PJTH = ""
   # DA:On prend le PJT de l'entête de DA (VCRTYP non chargé dans ce cas dans BENCHLIBP,on doit relire ORDERS)
   If [M:PMG]WIPTYP(0) = 2 & [M:PMG]WIPSTA(0) = 2 & [M:PMG]WIPNUM(0)<>""
        Read [ORD] ORD0=[M:PMG]WIPTYP(0);[M:PMG]WIPNUM(0);[M:PMG]ITMREF(0)
        If fstat  Raz [F:ORD] : Endif
        If [F:ORD]VCRTYP = 14
           Read [F:PSH]PSH0 = [F:ORD]VCRNUM
           # Issue 71069 - 2016-09-27 by MUARN : pjt et inisec, déplacé en VERIF, [M] au lieu [F]
           If !fstat : [M:POH1]PJTH = [F:PSH]PJTH : Endif
        Endif
   # sous-traitance avec ou sans OF : On récupère le PJT de la première ligne de la commande
   Elsif [M:PMG]VCRTYP(0) = 36 & [M:PMG]WIPTYP(0) = 4  & [M:PMG]WIPSTA(0) = 1 |
&        [M:PMG]VCRTYP(0) = 36 & [M:PMG]WIPTYP(0) = 13 & [M:PMG]WIPSTA(0) = 1 |
&        [M:PMG]VCRTYP(0) = 10 & [M:PMG]WIPTYP(0) = 4  & [M:PMG]WIPSTA(0) = 1
         # Issue 71069 - 2016-09-27 by MUARN : pjt et inisec, déplacé en VERIF, [M] au lieu [F]
         [M:POH1]PJTH = [M:POH2]PJT(0)
   # Cde de vente :On prend le PJT de l'entête de cde
   Elsif [M:PMG]SOHNUM(0) <> ""
         Read [F:SOH]SOH0 = [M:PMG]SOHNUM(0)
         # Issue 71069 - 2016-09-27 by MUARN : pjt et inisec, déplacé en VERIF, [M] au lieu [F]
         If !fstat : [M:POH1]PJTH = [F:SOH]PJT : Endif
   Endif
Endif
# End issue 71069
# Issue 71069 - 2016-09-27 by MUARN : pjt et inisec
If GFONC1 <> "GESPOH"
  Call INIT_CCEH("POH1","NBAXE","POH") From TRTX3CPT
Endif

# Ouverture fichier trace pour alertes budget si nécessaire
# et pour inter-sites
Gosub OUVERTURE_TRACE
Return

$INICRE

#---------------------------#
# Chargement avant le Write #
#---------------------------#
Local Integer STAT
[F:POH]POHTYP=1 : [F:POH]PURTYP=1 : [F:POH]CPY=GSOCIETE
If GAPPPOH>1 [F:POH]APPFLG=0 Else [F:POH]APPFLG=4 : Endif
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:POH0]POHNUM,2)="")
  Call NUMERO(GCODNUM,GFCY,[M:POH0]ORDDAT,"",[M:POH0]POHNUM,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  [F:POH]POHNUM=[M:POH0]POHNUM
Endif
#-----
# Issue 71069 - 2016-09-27 by MUARN : pjt et inisec, déplacé en VERIF_CRE
## Issue 71069 - 2016-06-10 by SR : US 180
##----- Si on vient des plans et un besoin pris et multi affaire,si besoin = DA/OF/SST/SOF, on charge le PTJH----#
#If clalev([M:PMG]) & [M:PMG]NBLIG=1 &  GPJTSNGDOC <> 2 & [F:POH]PJTH = ""
#   # DA:On prend le PJT de l'entête de DA (VCRTYP non chargé dans ce cas dans BENCHLIBP,on doit relire ORDERS)
#   If [M:PMG]WIPTYP(0) = 2 & [M:PMG]WIPSTA(0) = 2 & [M:PMG]WIPNUM(0)<>""
#        Read [ORD] ORD0=[M:PMG]WIPTYP(0);[M:PMG]WIPNUM(0);[M:PMG]ITMREF(0)
#        If fstat  Raz [F:ORD] : Endif
#        If [F:ORD]VCRTYP = 14
#           Read [F:PSH]PSH0 = [F:ORD]VCRNUM
#           If !fstat : [F:POH]PJTH = [F:PSH]PJTH : Endif
#        Endif
#   # sous-traitance avec ou sans OF : On récupère le PJT de la première ligne de la commande
#   Elsif [M:PMG]VCRTYP(0) = 36 & [M:PMG]WIPTYP(0) = 4  & [M:PMG]WIPSTA(0) = 1 |
#&        [M:PMG]VCRTYP(0) = 36 & [M:PMG]WIPTYP(0) = 13 & [M:PMG]WIPSTA(0) = 1 |
#&        [M:PMG]VCRTYP(0) = 10 & [M:PMG]WIPTYP(0) = 4  & [M:PMG]WIPSTA(0) = 1
#         [F:POH]PJTH = [M:POH2]PJT(0)
#   # Cde de vente :On prend le PJT de l'entête de cde
#   Elsif [M:PMG]SOHNUM(0) <> ""
#         Read [F:SOH]SOH0 = [M:PMG]SOHNUM(0)
#         If !fstat : [F:POH]PJTH = [F:SOH]PJT : Endif
#   Endif
#Endif
## End issue 71069
Gosub CHARGENTETE
If [F:POH]CLEFLG=2 & [F:POH]APPFLG=0
  [F:POH]APPFLG=1
Endif
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
# Issue 84130 - 2012-12-17 by SR : Calculer le CPR,etc... sur toutes les lignes
Call MAJ_REPART_LIG From SUBPOHC
Return

$CREATION
#------------------------------#
# Création des lignes commande #
#------------------------------#
Local Decimal  QTY, WORDNOT, WORDATI
If clalev ([F:PSO])<=0 Local File PREQUISO  [PSO] : OUVFICFLG=1  : Endif
If clalev ([F:ITV])<=0 Local File ITMMVT    [ITV] : OUVFICFLG+=2 : Endif
#----- Ecriture des éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(3,[M:POH0]POHNUM,"POH3","C") From TRTACHELT1
If GOK<1  Goto ERR_CREATION : Endif
#----- Ecriture du tableau des taxes -----#
Call ENREG_TAXES   (3,[M:POH0]POHNUM,"POH3","C") From TRTACHELT1
If GOK<1  Goto ERR_CREATION : Endif
#-----
Raz WORDNOT, WORDATI
Gosub CREATION From TABLEAUX
If GOK<1  Goto ERR_CREATION : Endif
#----- Relecture fournisseur si nécessaire (écrasement par les S/P de compta) -----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
#-----
If OUVFICFLG>1 Close Local File [ITV] : OUVFICFLG-=2  : Endif
If OUVFICFLG=1 Close Local File [PSO] : Raz OUVFICFLG : Endif
#---------------------------------------------------------------------------#
# Mises à jour : Réajustement si nécessaire nbre lignes dépassant le budget #
#                Mise à jour "En commande" dans fichier "Mvts fournisseurs" #
#---------------------------------------------------------------------------#
Gosub REAJUST_ENTETE
#----- Pas de mise à jour si commande inter-sites, intra-société -----#
If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
  If GOK<1 Goto ERR_CREATION : Endif
Endif
#----- Création des acomptes -----#
If [F:POH]VACTYP=4 [F:POH]TTVORD=[F:POH]TOTORD : Endif
Call ACOMPTES(6,1,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&            [F:POH]CUR,[F:POH]CHGTYP,[F:POH]BPSINV,[F:POH]BPRPAY,[F:POH]BPAPAY,
&            1,OK) From TRTTPT
If GOK<1 : Goto ERR_CREATION : Endif
#----- Inter-sociétés -----#
If [M:POH0]SALFCY<>"" & [F:POH]APPFLG>2 : # Intersite & Commande signée au moins partiellement
  #----- Appel au programme de création de commande de vente
  Call GENSOH("C",1,GBIDI3) From TRTVENISOC
  #----- Le composant vente écrit toujours dans la trace
  If GPURTRACE=1  GPURTRACE=2 : Endif
  If GOK<1
    Goto ERR_CREATION
  Else
    Gosub UPDATE_INTERSITE From TRTACHISO1
    If GOK<1  Goto ERR_CREATION : Endif
    Affzo [POH3]OCNNUM, OCNDAT, OCNREM
  Endif
Endif
#----- Mise à jour statistiques entête commande -----#
SIGN=1 : Call VALSTA("POH",SIGN) From SUBPS2 : If GOK<1 Goto ERR_CREATION : Endif
#----- Autres mise à jour ? -----#
Return
$ERR_CREATION
Raz [M:POH0]POHNUM
Return

$APRES_CRE
# V6 Affectations
Gosub MAJ_MTO_AP_ALL_POH From PURMTOLIB        # mise à jour des affectations

# sr 09.11 Demande 76337 : Possibilité de filtre en Intersite
Filter [F:TPT]

#---------------------------------------------------------------#
# Effacement fichier de travail et affichage numéro de commande #
#---------------------------------------------------------------#
#----- Test à cause de la simulation d'import en génération auto cdes -----#
If !GIMPORT
  Gosub EFFAC_PWRKORDERS From SUBPOHB  : # Effacement fichier de travail
Endif
#-----
Read [POH] POH0=[M:POH0]POHNUM       : # Il faut relire à cause des màj workflow
[M:POH1]=[F:POH]
If !GIMPORT  Affzo [POH0]POHNUM : Affzo [POH1] : Endif
#----- Activation lecture trace si signature auto par le Workflow -----#
If GPURTRACE=1 & [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  GPURTRACE=2
Endif
#------
Gosub LECTURE_TRACE    From SUBPOHA  : # Lecture fichier trace si nécessaire
If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
  Read [PTR] PTR0=3;GPTRNUM      : If fstat Raz [F:PTR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POH0]BPSNUM     : # Relecture fournisseur si nécessaire
  Read [BPS] BPS0=[M:POH0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:BPS]NORPRNFLG=2 & [F:PTR]DOCFLG=2 & [F:POH]APPFLG>2 & !GIMPORT
  Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
  Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
  #-----
  If [M:POH0]DOCNAM<>""  [L]REPORT1=[M:POH0]DOCNAM  Else  [L]REPORT1=[F:PTR]DOCNAM : Endif
  #-----
  Call ETAT([L]REPORT1,"GESPOH",TBPAR,TBVAL) From ETAT
 #Call ETAT([L]REPORT1,"","",0,"",TBPAR,TBVAL) From AIMP3 : # Erreur PARAM inexistant !!
  #----- Relecture pour réactualisation de l'indicateur d'impression -----#
  Raz [M:POH2]POHCOU
  Gosub RELIT From GOBJSUB
  Affzo [POH2]10 : Affzo [POH3]15
Else
  #----- Affichage icone texte sauf en import -----#
  If !GIMPORT
    If [M:POH1]TEX1<>"" | [M:POH1]TEX2<>""
      Call SET_IMAGE(4)   From GESECRAN
    Else
      Call RESET_IMAGE(4) From GESECRAN
    Endif
  Endif
  #-----
  Raz [M:POH2]POHCOU
  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS From SUBPOHA
  Endif
  If !GIMPORT  Affzo [POH2] : Affzo [POH3]15 : Endif
Endif
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0   : # Effacement indicateurs
Return


$AB_CREATION
#-------------------------------------------#
# Abandon de la création suite à une erreur #
#-------------------------------------------#
Gosub LECT_EFFAC_TRACE
Gosub RAZ_CMMNUM
Return

$AVANT_MOD
#-----------------------------------------------------#
# Après appui sur le bouton "Modif"                   #
# GREVFLG : Modification avec avenant  (1=Non, 2=Oui) #
# GAPPFLG : Reprise signature du début (1=Non, 2=Oui) #
# GPLIFLG : Recalcul tarif ligne  (0 et 1=Non, 2=Oui) #
#-----------------------------------------------------#
If GREVFLG<>0 Return : Endif : # L'AVANT_MOD a déjà été executée !
GREVFLG=1 : # GAPPFLG=1 : GPLIFLG=0
#----- Commande soldée, modification interdite !
If [F:POH]CLEFLG=2
  GMESSAGE=mess(47,194,1) : GERR=1 : OK=0 : GREVFLG=0 : Return
Endif
# Issue 106758 - 2015-03-05 by SR : Ssi non signée, non réceptionnée, non facturée
#If [F:POH]APPFLG=1 :  Return : Endif
If [F:POH]APPFLG=1 & [F:POH]RCPFLG=1 & [F:POH]INVFLG=1 :  Return : Endif
# End issue 106758

Raz GBIDI3
#----- Modif inter-site autorisée ?
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Call CTLMAJSOH("M", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
  If GBIDI3<>0 : GERR=1 : OK=0 : GREVFLG=0 : Return : Endif
Endif
#----- Commande signée, modification ?
If [F:POH]APPFLG=2 | [F:POH]APPFLG=3
   OK=2 : Call AVERTIR(mess(48,194,1),OK) From GESECRAN
   If OK=1 OK=0 : GREVFLG=0 : Return Else OK=1 : Endif
   # Issue 77496 - 2011-11-04 by VPO : Commandes achat/vente inter-sociétés désynchronisées
   #-- En inter-site contrôler que l'on peut supprimer la commande de vente
   If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
     Raz GBIDI3
     Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
     # Issue 87519 - 2013-04-02 by SR : Point d'entrée permettant de modifier une commande d'achat Intersite
     GPOINT = "CUSCTLSOH" : Gosub ENTREE From EXEFNC
     # Issue 96496 - 2014-02-06 by MUARN : ajout raz de GREVFLG
     If GBIDI3<>0 : GERR=1 : OK=0 : GREVFLG=0 : Return : Endif
   Endif
# Issue 77496 - 2011-11-04 by VPO : Commandes achat/vente inter-sociétés désynchronisées
Elsif [F:POH]APPFLG=5
   #-- En inter-site contrôler que l'on peut supprimer la commande de vente
   If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
     Raz GBIDI3
     Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
     # Issue 87519 - 2013-04-02 by SR : Point d'entrée permettant de modifier une commande d'achat Intersite
     GPOINT = "CUSCTLSOH" : Gosub ENTREE From EXEFNC
     If GBIDI3<>0 : GERR=1 : OK=0 : Return : Endif
   Endif
Endif
# Issue X3-71652 - 2018-01-26 by SDEM : begin
If GPURREV < 2 OK=1 : Return : Endif : # Pas de gestion d'avenant # Issue X3-71652 - 2018-01-22 by SDEM :
#---- Commande réceptionnée ou facturée, modification avec avenant ?
If [F:POH]RCPFLG>1 | [F:POH]INVFLG>1
   If GPURREV=2 Then
     OK=2 : Call OUINON (mess(49,194,1),OK) From GESECRAN
     If OK=1 Return Else OK=1 : Goto AVEC_AVENANT : Endif
   Elsif GPURREV=3 Then
     OK=1 : Goto AVEC_AVENANT
    Endif
Endif


#----- Commande envoyée au fournisseur, modification avec avenant ?
If [F:POH]PRNFLG=2 & [F:POH]APPFLG>2
  If GPURREV=2 Then
    OK=2 : Call OUINON (mess(50,194,1),OK) From GESECRAN
    If OK=1 Return Else OK=1 : Goto AVEC_AVENANT : Endif
  Elsif GPURREV=3 Then
    OK=1 : Goto AVEC_AVENANT
  Endif

Endif
#----- Modification avec avenant ?
If [F:POH]APPFLG<>3 Return : Endif
If GPURREV=2 Then
  OK=2
  Call OUINON (mess(51,194,1),OK) From GESECRAN
  If OK=1 Return Else OK=1 : Endif
Elsif GPURREV=3 Then
  OK=1
Endif
# Issue X3-71652 - 2018-01-26 by SDEM : end

$AVEC_AVENANT
GREVFLG=2 : [M:POH0]REVNUM+=1
If !GIMPORT Affzo [POH0]FIL2, REVNUM : Endif
Return

$VERIF_MOD
#------------------------------#
# Vérification en modification #
#------------------------------#
#----- S'assurer que la classe [F:POH] corresponde bien à la commande affichée -----#
# Issue 101272 - 2014-07-04 by SR : en import, relire systématiquement
If [F:POH]POHNUM<>[M:POH0]POHNUM | GIMPORT
  Read [POH] POH0=[M:POH0]POHNUM : If fstat  Raz [F:POH] : Endif
Endif
#-----
Gosub VERIF
If OK=0 Return Else OK=1 : Endif
#---- Annulation des signatures existantes ! Poursuivre, Abandonner ----#
If GAPPPOH>1 & [F:POH]APPFLG>1 & [F:POH]APPFLG<4 & (GAPPFLG=2 | FLG=2)
   OK=2 : Call AVERTIR(mess(64,194,1),OK) From GESECRAN
   If OK=1 OK=0 : Return Else OK=1 : Endif
   #-- En inter-site contrôler que l'on peut supprimer la commande de vente
   If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
     Raz GBIDI3
     Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
     # Issue 87519 - 2013-04-02 by SR : Point d'entrée permettant de modifier une commande d'achat Intersite
     GPOINT = "CUSCTLSOH" : Gosub ENTREE From EXEFNC
     If GBIDI3<>0 : GERR=1 : OK=0 : Return : Endif
   Endif
# Issue 77496 - 2011-11-04 by VPO : Commandes achat/vente inter-sociétés désynchronisées
Elsif GAPPPOH>1 & [F:POH]APPFLG=5 & (GAPPFLG=2 | FLG=2)
   #-- En inter-site contrôler que l'on peut supprimer la commande de vente
   If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
     Raz GBIDI3
     Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
     # Issue 87519 - 2013-04-02 by SR : Point d'entrée permettant de modifier une commande d'achat Intersite
     GPOINT = "CUSCTLSOH" : Gosub ENTREE From EXEFNC
     If GBIDI3<>0 : GERR=1 : OK=0 : Return : Endif
   Endif
Endif
#----- Test des modifications effectuées pour positionnement de MAJCDE ----#
Read [POH] POH0=[M:POH0]POHNUM
If fstat  Call RSTA("POH",[M:POH0]POHNUM) From GLOCK : OK=0 : Return : Endif
#-----
If [M:POH0]ORDDAT<>[F:POH]ORDDAT | [M:POH1]PTE   <>[F:POH]PTE    |
&  [M:POH1]CUR   <>[F:POH]CUR    | [M:POH3]TTVORD<>[F:POH]TTVORD |
&  [M:POH1]BPSINV<>[F:POH]BPSINV
  MAJCDE=1
Else
  MAJCDE=0
Endif
#----- Messages d'avertissement pour les acomptes -----#
If [M:POH1]PRNFLG<2 & [M:POH1]RCPFLG<2 & [M:POH1]INVFLG<2 & MAJCDE=1
  #----- Contrôle qu'aucun acompte n'a été versé ----#
  Call ACOMPTES(6,3,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&               [F:POH]CUR,0,"","","",1,OK) From TRTTPT
  If OK<>0
    #----- Ancienne condition de paiement avec acomptes ? -----#
    GBIDI2=1
    #MAE, ajout LEG
    For [TPT] TPT0 Where PTE=[F:POH]PTE & PAMTYP=2 & (LEG=GCURLEG | LEG="")
      GBIDI2=2 : Break
    Next
    #----- Nouvelle condition de paiement avec acomptes ? -----#
    GBIDI3=1
    #MAE, ajout LEG
    For [TPT] TPT0 Where PTE=[M:POH1]PTE & PAMTYP=2 & (LEG=GCURLEG | LEG="")
      GBIDI3=2 : Break
    Next
    #----- Il y avait précédemment des acomptes saisis ou générés -----#
    If OK<>3 | GBIDI2=2
      If [M:POH1]PTE<>[F:POH]PTE
        GBIDC2=mess(195,191,1)-":\" : # Modification de la condition de paiement
      Elsif [M:POH3]TTVORD<>[F:POH]TTVORD
        GBIDC2=mess(196,191,1)-":\" : # Modification du montant de la commande
      Else
        GBIDC2=""
      Endif
      #-----
      If GBIDI3=2 : # Voulez-vous que les acomptes existants pour cette commande soient recalculés ?
        GBIDC2+=mess(198,191,1)
      Else        : # Voulez-vous que les acomptes existants pour cette commande soient supprimés ?
        GBIDC2+=mess(197,191,1)
      Endif
      #-----
      OK=2 : Call OUINON(GBIDC2,OK) From GESECRAN
      If OK=1  MAJCDE=0 : Endif
    Endif
  Else
    # Issue 101292 - 2014-08-12 by MUARN : acompte réglé contôle montant réglé et nouveau montant commande
    #MAJCDE=0 : # Acomptes versés pas de maj d'acompte !
    Local Decimal  WMNT_ACC
    If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
    Raz WMNT_ACC
    For [F:DUD] Where TYP="*PO" & NUM=[F:POH]POHNUM & (PAYCUR <> 0 | TMPCUR <> 0)
      WMNT_ACC += [F:DUD]TMPCUR + [F:DUD]PAYCUR
    Next
    If WMNT_ACC > [M:POH3]TTVORD
      MAJCDE=0
    Else
      Raz GMESSAGE, GERR
      MAJCDE=0
    Endif

  Endif
  OK=1
Endif
#----- Ouverture fichier trace pour alertes budget si nécessaire -----#
Gosub OUVERTURE_TRACE
Return

$AVANT_MODFIC
#----------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:POH]  #
# Soustraction statistiques entête commande avant modification   #
# Historisation des changements entête si modif avec avenant     #
#----------------------------------------------------------------#
Local Integer SIGN
SIGN=-1 : Call VALSTA("POH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
If GREVFLG=2 Call HISTO_CDE("POH","","M") From TRTACHCDE1 : Endif
#----- Mise à jour fournisseur facturant des lignes si nécessaire -----#
If [M:POH1]BPSINV<>[F:POH]BPSINV | [M:POH1]BPAINV<>[F:POH]BPAINV
  Update [POQ] Where POHNUM=[F:POH]POHNUM
&              With  BPSINV=[M:POH1]BPSINV, BPAINV=[M:POH1]BPAINV
  If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Return : Endif
Endif
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
If [M:POH1]TEX1="" & left$([F:POH]TEX1,3)="POH"
  Call SUP_CLOB([F:POH]TEX1,WRET) From TRTX3TEX
Endif
If [M:POH1]TEX2="" & left$([F:POH]TEX2,3)="POH"
  Call SUP_CLOB([F:POH]TEX2,WRET) From TRTX3TEX
Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOH>1 & (GAPPFLG=2 | FLG=2 | [F:POH]APPFLG=1)
  Call ANNULE_SUIVI("POH",mess(652,197,1),1,WRET) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif

# V6 Affectations
Gosub AVANT_MODFIC_POH From PURMTOLIB

Return

$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
If GREVFLG=2 [F:POH]PRNFLG=1 : [F:POH]REVNUM=[M:POH0]REVNUM : Endif
Gosub CHARGENTETE
If [F:POH]CLEFLG<>2 & (GAPPFLG=2 | FLG=2 | [F:POH]APPFLG=1)
  If GAPPPOH>1 [F:POH]APPFLG=0 Else [F:POH]APPFLG=4 : Endif
Endif
#----- Mise à jour indicateurs réceptionné et facturé -----#
If [F:POH]RCPNBR=0 [F:POH]RCPFLG=1 Else [F:POH]RCPFLG=2 : Endif
If [F:POH]RCPLINNBR=[F:POH]LINNBR       [F:POH]RCPFLG=3 : Endif
If [F:POH]INVNBR=0 [F:POH]INVFLG=1 Else [F:POH]INVFLG=2 : Endif
If [F:POH]INVLINNBR=[F:POH]LINNBR       [F:POH]INVFLG=3 : Endif
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
# Issue 84130 - 2012-12-17 by SR : Calculer le CPR,etc... sur toutes les lignes
Call MAJ_REPART_LIG From SUBPOHC
Return

$MODIF
#----------------------------------#
# Modification des lignes commande #
#----------------------------------#
Local Decimal  QTY, WORDNOT, WORDATI
If clalev ([F:PSO])<=0 Local File PREQUISO  [PSO] : OUVFICFLG=1  : Endif
If clalev ([F:ITV])<=0 Local File ITMMVT    [ITV] : OUVFICFLG+=2 : Endif
#----- Ecriture des éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(3,[M:POH0]POHNUM,"POH3","M") From TRTACHELT1
If GOK<1  Return : Endif
#----- Ecriture du tableau des taxes -----#
Call ENREG_TAXES   (3,[M:POH0]POHNUM,"POH3","M") From TRTACHELT1
If GOK<1  Return : Endif
#-----
Raz WORDNOT, WORDATI
Gosub MODIF From TABLEAUX
#----- Relecture fournisseur si nécessaire (écrasement par les S/P de compta) ----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
   Read [BPS] BPS0=[F:POH]BPSNUM
   If fstat Raz [F:BPS] : Endif
Endif
#-----
If OUVFICFLG>1 Close Local File [ITV] : OUVFICFLG-=2  : Endif
If OUVFICFLG=1 Close Local File [PSO] : Raz OUVFICFLG : Endif
If GOK<1 : Return : Endif
#---------------------------------------------------------------------------#
# Mises à jour : Réajustement si nécessaire nbre lignes dépassant le budget #
#                Mise à jour "En commande" dans fichuer "Mvts fournisseurs" #
#                Mise à jour statistiques entête commande                   #
#---------------------------------------------------------------------------#
Gosub REAJUST_ENTETE
#----- Pas de mise à jour si commande inter-sites, intra-société -----#
If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
  If GOK<1 Return : Endif
Endif
#------------------------------------------------------------------#
# Ajustement des acomptes en fonction des modifications effectuées #
#   - si la commande n'est pas imprimée                            #
#   - si la commande n'est pas réceptionnée                        #
#   - si la commande n'est pas facturée                            #
#------------------------------------------------------------------#

# Issue 87952 - 2013-02-15 by MUARN : acompte supprimé si commande imprimée puis avenant
#If [F:POH]PRNFLG<2 & [F:POH]RCPFLG<2 & [F:POH]INVFLG<2 & MAJCDE=1
If [M:POH1]PRNFLG<2 & [F:POH]RCPFLG<2 & [F:POH]INVFLG<2 & MAJCDE=1
  #----- Contrôle qu'aucun acompte n'a été versé ----#
  If [F:POH]VACTYP=4 [F:POH]TTVORD=[F:POH]TOTORD : Endif
  #----- Suppression des acomptes liés à cette commande -----#
  Call ACOMPTES(6,2,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&               [F:POH]CUR,0,"","","",1,OK) From TRTTPT
  If GOK<1 Return : Endif
  #----- Récréation des acomptes -----#
  Call ACOMPTES(6,1,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&               [F:POH]CUR,[F:POH]CHGTYP,[F:POH]BPSINV,[F:POH]BPRPAY,[F:POH]BPAPAY,
&               1,OK) From TRTTPT
  If GOK<1 Return : Endif
Endif
#----- Inter-sociétés -----#

If [F:POH]SALFCY<>""
  Raz GBIDI3
  If [F:POH]APPFLG<3 & [F:POH]OCNNUM<>""
    #-- Appel au programme de suppression de commande de vente
    # Issue 87519 - 2013-04-02 by SR : Point d'entrée permettant de ne pas supprimer la commande de vente et de faire
    # une mise à jour spécifique
    GPE = 1
    GPOINT = "CUSUPDSOH" : Gosub ENTREE From EXEFNC
    If GPE = 1
       Call GENSOH("A", 1, GBIDI3) From TRTVENISOC
    Endif
    #-- Le composant vente écrit toujours dans la trace
    If GPURTRACE=1 : GPURTRACE=2 : Endif
    If GOK<1 : Return : Endif
  Elsif [F:POH]APPFLG>2 & [F:POH]OCNNUM=""
    #-- Appel au programme de création de commande de vente
    Call GENSOH("C", 1, GBIDI3) From TRTVENISOC
    #-- Le composant vente écrit toujours dans la trace
    If GPURTRACE=1 : GPURTRACE=2 : Endif
    If GOK<1 : Return : Endif
  Elsif [F:POH]OCNNUM<>""
    #-- Appel au programme de modif de commande de vente
    Call GENSOH("M", 1, GBIDI3) From TRTVENISOC
    If GPURTRACE=1 : GPURTRACE=2 : Endif
    If GOK<1 : Return : Endif
  Endif
  Gosub UPDATE_INTERSITE From TRTACHISO1
  If GOK<1  Return : Endif
  Affzo [POH3]OCNNUM, OCNDAT, OCNREM
Endif
#-----
SIGN=1 : Call VALSTA("POH",SIGN) From SUBPS2 : If GOK<1 Return  : Endif
#----- Autres mise à jour ? -----#
Return


$APRES_MOD
# V6 Affectations
Gosub MAJ_MTO_AP_ALL_POH From PURMTOLIB

# sr 09.11 Demande 76337 : Possibilité de filtre en Intersite
Filter [F:TPT]

#--------------------------------------------------------------------------#
# Après modification : affichage indicateurs entête et rechargement lignes #
#--------------------------------------------------------------------------#
Read [POH] POH0=[M:POH0]POHNUM      : # Il faut relire à cause des màj workflow
[M:POH1]=[F:POH] : If !GIMPORT  Affzo [POH1] : Endif
Raz [M:POH2]POHCOU
Gosub LIENS From SUBPOHA
If !GIMPORT  Affzo [POH2] : Affzo [POH3]20 : Endif
Gosub EFFAC_PWRKORDERS From SUBPOHB : # Effacement fichier de travail
Gosub LECTURE_TRACE    From SUBPOHA : # Lecture fichier trace si nécessaire
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0   : # Effacement indicateurs
Return


$AB_MODIF
#-----------------------------------------------#
# Abandon de la modification suite à une erreur #
#-----------------------------------------------#
Gosub LECT_EFFAC_TRACE
Gosub RAZ_CMMNUM
Return

$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
Gosub EFFAC_PWRKORDERS From SUBPOHB : # Effacement fichier de travail
GREVFLG=0 : GAPPFLG=1 : GPLIFLG=0   : # Effacement indicateurs
Gosub SUPPRESS_TEX                  : # Suppression des textes entête, pied et lignes
# Issue 84130 - 2012-11-22 by SR : landed cost mise à jour des données structure de cout
Call RAZSTCDW From STCLIB
GOK=SAVGOK                          : # Restitution de GOK
Return

########################################################################
$AV_ANNULE
# V6 Affectations
Gosub SUP_MTO_AV_ALL From PURMTOLIB
Return

$VERF_ANU
#-------------------------------------------------#
# Contrôles de suppression :                      #
# Interdit si commande réceptionnée ou soldée     #
# Avertissement et choix si commande signée       #
# Avertissement et choix si commande contremarque #
#-------------------------------------------------#
If [F:POH]RCPFLG>1
  GMESSAGE=mess(15,194,1) : GERR=1 : OK=0 : Return : Endif
If [F:POH]CLEFLG>1
  GMESSAGE=mess(16,194,1) : GERR=1 : OK=0 : Return : Endif
If [F:POH]APPFLG>1 & [F:POH]APPFLG<4
   OK=2 : Call AVERTIR(mess(17,194,1),OK)  From GESECRAN
   If OK=1 OK=0 : Return : Endif
Endif
# Issue 106506 - 2015-05-05 by SR : Landed Cost
Filter [POQ] Where POHNUM = [F:POH]POHNUM & SHIQTYSTU <> 0
Look [POQ]PTD0 First With Nohint
Filter [F:POQ]
If !fstat
  # Au moins une ligne expédiée\Suppression interdite
  GMESSAGE=mess(503,194,1) : GERR=1 : OK=0 : Return
Endif
Filter [F:CTRD] Where POHNUM = [F:POH]POHNUM & SHIPNUM = ""
Look [F:CTRD] First With Nohint
Filter [F:CTRD]
If !fstat
  # Au moins une ligne chargée dans un container\Suppression interdite
  GMESSAGE=mess(510,194,1) : GERR=1 : OK=0 : Return
Endif
# End issue 106506

#----- Si commande de contremarque, confirmation de la suppression -----#
If sigma(OK=0,[M:POH2]NBLIG-1,(len([M:POH2]SOHNUM(OK))))
   OK=2 : Call AVERTIR(mess(167,194,1),OK) From GESECRAN
   If OK=1 OK=0 : Return : Endif
Endif

# V6 Affectations
Gosub VERF_ANU From PURMTOLIB

#----- Contrôle qu'aucun acompte n'a été versé ----#
Call ACOMPTES(6,3,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&            [F:POH]CUR,0,"","","",1,OK) From TRTTPT :
If OK=0 Return : Endif
#-- Pour l'inter-site uniquement
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz GBIDI3
  Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI3) From TRTVENISOC
  If GBIDI3<>0  : GERR=1 : OK=0 : Return : Endif
   OK=2 : Call AVERTIR(mess(272,194,1),OK) From GESECRAN
   If OK=1 OK=0 : Return : Endif
   Gosub OUVERTURE_TRACE
Endif

Return

$ANNULE
#--------------------------------------#
# Supression des textes entête et pied #
#--------------------------------------#
If left$([F:POH]TEX1,3)="POH"
  Call SUP_CLOB([F:POH]TEX1,GBIDI1) From TRTX3TEX
Endif
If left$([F:POH]TEX2,3)="POH"
  Call SUP_CLOB([F:POH]TEX2,GBIDI1) From TRTX3TEX
Endif
#---------------------------------------------------#
# Historisation entête commande si no avenant <> 0  #
# Annulation des lignes commande                    #
# Action VALLIG appelée à chaque ligne avec SIGN=-1 #
#---------------------------------------------------#
Local Decimal  QTY, WORDNOT, WORDATI
Local Shortint OUVFICFLG
If [F:POH]REVNUM<>0 GREVFLG=2
                    Call HISTO_CDE("POH","","A") From TRTACHCDE1
                    If GOK<1  Return : Endif : Endif
If clalev ([F:PSO])<=0 Local File PREQUISO  [PSO] : OUVFICFLG=1  : Endif
If clalev ([F:ITV])<=0 Local File ITMMVT    [ITV] : OUVFICFLG+=2 : Endif
#----- Suppression éléments de facturation avec comptes et sections -----#
Call ENREG_ELEMENTS(3,[M:POH0]POHNUM,"POH3","A") From TRTACHELT1
If GOK<1  Return : Endif
#----- Suppression du tableau des taxes -----#
Call ENREG_TAXES   (3,[M:POH0]POHNUM,"POH3","A") From TRTACHELT1
If GOK<1  Return : Endif
#-----
Raz WORDNOT, WORDATI
Gosub ANNULE From TABLEAUX
#----- Relecture fournisseur si nécessaire (écrasement par les S/P de compta) ----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
   Read [BPS] BPS0=[F:POH]BPSNUM
   If fstat Raz [F:BPS] : Endif
Endif
#-----
If OUVFICFLG>1 Close Local File [ITV] : OUVFICFLG-=2  : Endif
If OUVFICFLG=1 Close Local File [PSO] : Raz OUVFICFLG : Endif
If GOK<1 Return : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOH>1
  If dim(WRET)<1  Local Integer WRET : Endif
  Call ANNULE_SUIVI("POH",mess(653,197,1),1,WRET) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
#----- Pas de mise à jour si commande inter-sites, intra-société -----#
If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
  If GOK<1 Return : Endif
Endif
#----- Suppression des acomptes liés à cette commande -----#
Call ACOMPTES(6,2,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&             [F:POH]CUR,0,"","","",1,OK) From TRTTPT : If GOK<1 Return : Endif
#-- Pour l'inter-site uniquement
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  Raz GBIDI3
  #-- Appel au programme de suppression de commande de vente
  Call GENSOH("A", 1, GBIDI3) From TRTVENISOC
  #-- Le composant vente écrit toujours dans la trace
  If GPURTRACE=1 : GPURTRACE=2 : Endif
  If GBIDI3<>0 : OK=0 : Return : Endif
Endif
#----- Soustraction statistiques entête commande -----#
SIGN=-1 : Call VALSTA("POH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return

# Issue 84130 - 2012-11-29 by SR
# Si modification de zones impactantes
$APRES_MODIF
Case COUZON
    When "ITMREF","GROPRI","QTYSTU","QTYVOU","QTYWEU","UOM","WEU","VOU","ORDDAT","QTYUOM"
          [M:POH2]WSTCUPD(nolign-1) = 2
    When Default
Endcase
Return

$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:AD61])  Close Local Mask [AD61] : Endif
If clalev([M:AD62])  Close Local Mask [AD62] : Endif
If clalev([M:PCEV])  Close Local Mask [PCEV] : Endif
#-----
If dim(GPOH_INDBASTAX)>0  Kill GPOH_INDBASTAX  : Endif
If dim(GPOH_INDTAX)>0     Kill GPOH_INDTAX     : Endif
If dim(GPOH_RND)>0        Kill GPOH_RND        : Endif
# Issue 84130 - 2013-03-22 by SR : Landed cost
If dim(GPECBOUT)>0        Kill GPECBOUT        : Endif
If dim(GOUVSTC)>0 & WCREOUVSTC = 1  Kill GOUVSTC        : Endif
#-----
If GFONC1="GESPOH"
  Raz GORITITCOL, GMENBOUT, GCONSDIA
Endif
#----- Test à cause de la simulation d'import en génération auto cdes -----#
If !GIMPORT
  Gosub EFFAC_PWRKORDERS From SUBPOHB : # Effacement fichier de travail
Endif
#-----
Gosub FERMETURE_TRACE  From SUBPOHA : # Fermeture fichier trace si nécessaire
# Issue 84130 - 2012-11-15 by MUARN : landed cost mise à jour des données structure de cout
If clalev([M:STCDW]) : Raz [M:STCDW] : Endif

#----- Effacement icone texte sauf en import -----#
If !GIMPORT  Call RESET_IMAGE(4) From GESECRAN : Endif

GCREFONC = 0 # FGR 18/02/2014 : X3SUIVI96940 on remet une valeur normale.

# Issue 102708 - 2014-10-22 by MUARN : en sortie de tunnel pour les ventes
#--- Si on vient par tunnel des commandes
#    positionner mkstat qui permettra de forcer un réaffichage au retour du tunnel
If GFONC1 = "GESSOH" mkstat=GSTALIT : Endif

Return

$VERIF
#---------------------------------------------------------------#
# Vérifications : Au moins une ligne,  Sections obligatoires    #
#                 Traitement tarifs groupés                     #
#                 Recalcul tarif ligne si nécessaire            #
#                 Budget dépassé, ...etc                        #
#---------------------------------------------------------------#
Local Decimal  MNT, MNT2
Local Integer  STAT
Local Shortint J, K, FLG : Raz FLG
Local Integer WOK
Local Shortint RES

If [M:POH2]NBLIG=0
  GMESSAGE=mess(61,199,1) : GERR=1 : OK=0 : Goto RETOURNBLIG
Endif

# VPO 07/12/10 69066 verifier valeur Condition de paiement, Code escompte, Regime de taxe
# VPO 01/03/11 71999 ameliorer message d'erreur
# sr 09.11 Demande 76337 : Possibilité de filtre en Intersite
Filter [F:TPT]
If [M:POH1]PTE<>""
    #Call CONTROLE("TPT","",[M:POH1]PTE,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~PTE")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    #-- X3Suivi 71937 : Données par législation pour le Conditions de paiement
    #--CPO 71937 01/08/2013 Suite dev review
    Call CONTTPT([M:POH1]PTE,GCURLEG,'','',[M:POH0]POHFCY,'','') From SUBTPT
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~PTE")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
Endif
If [M:POH1]DEP<>""
    #--CPO 71937 TABDEPAGIO
    mkstat = 0
    #Call CONTROLE("TDA","!",[M:POH1]DEP,"",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~DEP")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    Call CONTTDA([M:POH1]DEP,GCURLEG,"POH1","DEP",[M:POH0]POHFCY,"","") From SUBTDA
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~DEP")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    #--/CPO
Endif
If [M:POH1]VACBPR<>""
    mkstat=0
    # 71937 : Multilégislation
    #Call CONTADI([M:POH1]VACBPR,"1","") From SUBADI
    #If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~VACBPR")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    #Call CONTROLE("ADI","",[M:POH1]VACBPR,"1",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~VACBPR")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    Call CONTTVB([M:POH1]VACBPR,GCURLEG,"POH1","VACBPR",[M:POH0]POHFCY,"","") From SUBTVB
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","POH1~VACBPR")+'"\'+GMESSAGE : Goto RETOURNBLIG : Endif
    # 71937 : Multilégislation
Endif

If !GIMPORT
  #----- Relecture transaction de saisie si nécessaire -----#
  If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM
     Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
  #----- Contrôle sections obligatoires -----#
  If GHEADIE=1 : # Sections d'entête saisissables
    For I=1 To GNBDIE
      If [M:POH1]CCE(I-1)="" & GOBLDIE(I)=2 & GENVDIE(I)<>2
        GMESSAGE=mess(177,199,1) : GERR=2 : Break
      Endif
    Next I
  Endif
  #-----
  Gosub TEST_VALID From SUBPOH
Else
  If dim(I)<0  Local Integer I : Endif
  #----- Si import : Màj bases taxables et calcul taxes éléments facturation -----#
  If [M:POH2]CLCFLG=2
    Gosub CALCUL_MT_ELEMENT From SUBPOHC
  Endif
  Raz [M:POH2]CLCFLG
  [M:POH3]TOTORD=sum([M:POH3]INVORDAMT)+sum([M:POH3]INVLINAMT)+[M:POH3]TOTLINAMT
  If [M:POH1]VACTYP<>4
    [M:POH3]TOTTAXAMT=sum([M:POH3]AMTTAX)
  Else
    [M:POH3]TOTTAXAMT=0
  Endif
  [M:POH3]TTVORD=[M:POH3]TOTORD+[M:POH3]TOTTAXAMT
Endif

#-----
# Issue 110880 - 2015-09-08 by MUARN : sous-pro compta travaille avec nolign
If dim(SAVNOLIGN)    <0  Local Integer  SAVNOLIGN        : Endif
SAVNOLIGN = nolign
For I=0 To [M:POH2]NBLIG-1
  #----- Vérification validité des articles en duplication -----#
  #----- Vérification des dates de réception en duplication
  If GREP="D"
    Call C_ITMREF([M:POH2]ITMREF(I)) From SUBPOH
    If mkstat
      GMESSAGE=mess(18,197,1)-num$(I+1)-[M:POH2]ITMREF(I)-GMESSAGE
      OK=0 : Break
    Endif
    # Issue 110880 - 2015-09-08 by MUARN : a faire aussi en création
#    # Issue 93840 - 2013-11-20 by MUARN : contrôler les axes en duplication
#    For J = 1 To GNBDIE
#      WVAL = evalue("[M:POH2]CCE"+num$(J)+"("+num$(I) +")")
#      Call SAIS_CCE(WVAL,J,"[M:POH2]LINACC","") From TRTX3CPT
#      If !mkstat
#        Call CTRL_CCE(WVAL,J,"[M:POH2]LINACC",GFINRSP,[M:POH0]ORDDAT) From TRTX3CPT
#        If GMESSAGE <> ""
#          GERR = 1
#          GMESSAGE -= mess(18,197,1) - num$(I+1)
#          OK = 0
#          Break 2
#        Endif
#      Endif
#      # Issue 106269 - 2015-02-13 by MUARN : contrôle axes invisibles et duplication
#      Raz mkstat
#      Call CTLCCE(WVAL,GDIE(J),GFINRSP,[M:POH2]EXTRCPDAT(nolign-1),nolign-1,
#&         "GDIE(1","[M:POH2]CCE#","GCOA(1","[M:POH2]LINACC#") From SELCCE
#      If mkstat : Raz mkstat : OK=0 : GERR=1 : Break 2 : Endif
#    Next
    # Issue 94815 - 2013-11-29 by SR : contrôle date de réception
    If [M:POH2]LINTYP(I)<>4
      If [F:FCY]FCY<>[M:POH2]PRHFCY(I)
           Read [FCY] FCY0=[M:POH2]PRHFCY(I) : If fstat Raz [F:FCY] : Endif
      Endif
      # Issue 95328 - 2013-12-16 by SR : Ne pas passer la date de commande dans ce contexte
      Call CTL_JOU2([M:POH2]EXTRCPDAT(I),[0/0/0],[M:POH2]OFS(I)) From TRTACHCDE1
      If mkstat
        GMESSAGE=mess(245,194,1)-[M:POH2]PRHFCY(I)+"\"+GMESSAGE
        GMESSAGE= mess(18,197,1) - num$(I+1) - ":" - GMESSAGE
        GERR = 1
        OK = 0
          Break
      Endif
    Endif
  Endif
  # Issue 110880 - 2015-09-08 by MUARN : a faire aussi en création
  # Issue 93840 - 2013-11-20 by MUARN : contrôler les axes en duplication
  # Issue 110880 - 2015-09-08 by MUARN : sous-pro compta travaille avec nolign
  nolign = I+1
  For J = 1 To GNBDIE
    WVAL = evalue("[M:POH2]CCE"+num$(J)+"("+num$(I) +")")
    Call SAIS_CCE(WVAL,J,"[M:POH2]LINACC","") From TRTX3CPT
    If !mkstat
      Call CTRL_CCE(WVAL,J,"[M:POH2]LINACC",GFINRSP,[M:POH0]ORDDAT) From TRTX3CPT
      If GMESSAGE <> ""
        GERR = 1
        GMESSAGE -= mess(18,197,1) - num$(I+1)
        OK = 0
        Break 2
      Endif
    Endif
    # Issue 106269 - 2015-02-13 by MUARN : contrôle axes invisibles et duplication
    Raz mkstat
    Call CTLCCE(WVAL,GDIE(J),GFINRSP,[M:POH2]EXTRCPDAT(nolign-1),nolign-1,
&       "GDIE(1","[M:POH2]CCE#","GCOA(1","[M:POH2]LINACC#") From SELCCE
    If mkstat : Raz mkstat : OK=0 : GERR=1 : Break 2 : Endif
  Next
  #----- Vérification date expédition si commande inter-sociétés et ligne non soldée -----#
  If [M:POH0]BETFCY=2 & [M:POH0]SALFCY<>"" & [M:POH2]LINCLEFLG(I)<>2
    Call C_SHIDAT([M:POH2]EXTRCPDAT(I),[M:POH0]BPCORD,[M:POH2]PRHFCY(I),
&                 [M:POH2]LINSTOFCY(I),[M:POH0]ORDDAT) From TRTVENISOC
    If mkstat
      GMESSAGE=mess(18,197,1)-num$(I+1)-":"-GMESSAGE : OK=0 : Break
    # Issue 96390 - 2014-03-18 by MUARN : période indisponible en plan de l'acheteur
    Elsif GERR=2 & GIMPORT
      GMESSAGE=mess(645,197,1)-":"-mess(81,197,1)-":"-[M:POH2]LINSTOFCY(I)-":"-GMESSAGE : GERR=1
      OK=0 : Break
    Endif
  Endif
  #----- Contrôle quantité minimum de commande -----#
  If [M:POH2]QTYPUU(I)<[M:POH2]PURMINQTY(I) & !clalev([F:XEPA])
    Raz J, GBIDD1
    While J<[M:POH2]NBLIG
      K=find([M:POH2]ITMREF(I),[M:POH2]ITMREF(J..[M:POH2]NBLIG-1))
      If K=0
        J=[M:POH2]NBLIG
      Else
        GBIDD1+=[M:POH2]QTYPUU(J+(K-1))
        J+=K
      Endif
    Wend
    #VPO 15/10/10 17730/59532 contrôle selon paramètre
    If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
    #If GBIDD1<[M:POH2]PURMINQTY(I)
    If GBIDD1<[M:POH2]PURMINQTY(I) & GPOHMINQTY<3
      GMESSAGE =[M:POH2]ITMREF(I)
      GMESSAGE-=mess(14,194,1)-format$("N:15F",[M:POH2]PURMINQTY(I))
      GMESSAGE-=[M:POH2]PUU(I)
      If GPOHMINQTY=1
          GERR=1 : OK=0 : Break
      Else : #GPOHMINQTY=2
          #pour ne pas afficher 2 fois le message si meme article
          If I=0 | find([M:POH2]ITMREF(I),[M:POH2]ITMREF(0..I-1))=0
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR=1 : OK=0 : Break
              Endif
          Endif
          Raz GMESSAGE
      Endif
    Endif
  Endif

  # Issue 59217 - 2014-10-17 by MUARN : obligation tarif achat
  #----- Contrôle tarif à zéro pour commande de contremarque (sauf inter-sites) -----#
  If [M:POH2]SOHNUM(I)<>"" & ([M:POH0]BETFCY<>2 | [M:POH0]BETCPY=2)
    If [M:POH2]GROPRI(I)=0 & [M:POH2]PRIREN(I)=0 & [M:POH2]NETPRI(I)=0 & GPURCTLPRI0 <> 2
     #----- Erreur si pas de tarif -----#
      GMESSAGE =[M:POH2]SOHNUM(I)+"/"+num$([M:POH2]SOPLIN(I))
      GMESSAGE+="/"+num$([M:POH2]SOQSEQ(I))-mess(67,197,1)-mess(84,197,1)
      OK=0
      GERR=1
      Break
    Endif
  Endif

  # Issue 93038 - 2013-10-10 by MUARN : VAT1 non alimenté en champs invisible
  If [M:POH2]VAT1(I)= "" & [M:POH2]LINTYP(I)<>2
    GMESSAGE=mess(18,197,1)-num$(I+1)-mess(126,104,1)
    OK=0 : GERR=0 : Break
  Endif

  # Issue 84130 - 2013-03-21 by SR : Landed cost
  If [M:POH2]STCNUM(I) <> "" & [M:POH2]WSTCSEQ(I) <> 0
     Raz J
     J = find([M:POH2]WSTCSEQ(I),[M:STCDW]WSTCSEQ(0..[M:STCDW]NBLIG-1))
     If J<1
        GMESSAGE = mess(457,194,1) - num$(I+1)
        GERR = 1 : OK = 0
        Break
     Endif
  Endif
Next I
# Issue 110880 - 2015-09-08 by MUARN : sous-pro compta travaille avec nolign
nolign = SAVNOLIGN

If OK=0 Goto RETOURNBLIG : Endif
#-----
If GPURGRUDIS>1 & GPLIFLG<>2 Call TAR_GROUPE("POH") From TRTACHTAR1 : Endif
Gosub RECALCUL_TARLIG From SUBPOHB
For I=0 To [M:POH2]NBLIG-1
  If [M:POH0]BETFCY=2 & [M:POH2]LINSTOFCY(I)=""
    GMESSAGE=mess(311,194,1)-num$(I+1) : GERR=1
    nolign=I+1 : OK=0 : Break
  Endif
  If [M:POH2]WAPPFLG(I)=2 FLG=2 : Endif
  If [M:POH2]FBUFLG(I)=2 & GCNTBUD=2
   #GMESSAGE=mess(39,194,1)-num$(I+1) : GERR=1
    # Issue 112085 - 2015-10-28 by MUARN : Déplacé de SUBPOHA à C
    Call CTRL_BUDLIN(I) From SUBPOHC
    # Issue X3-38639 - 2017-08-03 by MUARN : controler GERR
    If GERR > 0
      nolign=I+1 : OK=0 : Break
    Endif
  Endif
Next I
If OK=0 Goto RETOURNBLIG : Endif
#----- Ne pas effectuer les contrôles si commande inter-sites intra-société -----#
If [M:POH0]BETFCY<>2 | [M:POH0]BETCPY=2
  #----- Vérification Mt mini de commande -----#
  If [M:POH3]TOTLINAMT<[M:POH2]ORDMINAMT
    Local Integer WCTLFLG : WCTLFLG=1
    # --------------------------------------------------- #
    # WCTLFLG  Indicateur contrôle mt minimum commande    #
    #      0 = Pas de contrôle                            #
    #      1 = Avertissement ou choix (valeur par défaut) #
    #      2 = Contrôle bloquant                          #
    # --------------------------------------------------- #
    Gosub POINT_CTLORDMIN From TRTACHCDE1
    # Issue 46305 - 2011-12-21 by MUARN : montant mini de commande bloquant o/n
    If ([M:POH2]POHMINAMT=1 & WCTLFLG=1) | WCTLFLG=2
      GMESSAGE=mess(46,194,1) : GERR=1 : OK=0 : Goto RETOURNBLIG
    Elsif [M:POH2]POHMINAMT=2 & WCTLFLG=1
      OK=2 : Call AVERTIR(mess(46,194,1),OK) From GESECRAN
      If OK=1 OK=0 : Goto RETOURNBLIG Else OK=1 : Endif
    Endif
  Endif
  #----- 106430 - Verify Max order (Warn only - never block) -----#
  If [M:POH2]ORDMAXAMT>0 & [M:POH3]TOTLINAMT>[M:POH2]ORDMAXAMT
    OK=2 : Call AVERTIR(mess(507,194,1),OK) From GESECRAN
    If OK=1 OK=0 : Goto RETOURNBLIG Else OK=1 : Endif
  Endif
  #----- Vérification encours autorisé -----#
  If [F:BPS]BPSNUM<>[M:POH0]BPSNUM : # Relecture fournisseur si nécessaire
    Read [BPS] BPS0=[M:POH0]BPSNUM : If fstat  Raz [F:BPS] : Endif
  Endif
  #----- Lecture du fournisseur risque -----#
  If [F:BPS]BPSRSK=[F:BPS]BPSNUM
    [F:BPS2]=[F:BPS]
  Elsif [F:BPS]BPSNUM<>[F:BPS]BPSRSK
    Read [BPS2] BPS0=[F:BPS]BPSRSK : If fstat  Raz [F:BPS2] : Endif
  Endif
  If [F:BPS2]OSTCTL<>2 & [M:POH0]OSTAUZAMT<>0
    Call CALENC_BPS([F:BPS]BPSRSK,[M:POH0]ORDDAT,MNT) From TRTBPMVT
    If GOSTSCTL=1  GBIDC2=GCURSHR  Else  GBIDC2=GLOCALDEV : Endif
    Call CONVERT(GBIDC2,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,MNT,MNT2,STAT) From TRTDEV
    If GREP="M"  MNT2-=[F:POH]TTVORD : Endif
    MNT2+=[M:POH3]TTVORD
    If MNT2>[M:POH0]OSTAUZAMT
     #GMESSAGE="("+num$(MNT2-[M:POH3]TTVORD)-"+"-num$([M:POH3]TTVORD)-">"-num$([M:POH0]OSTAUZAMT)-GCUR+")"
      GMESSAGE="("+num$([M:POH0]OSTAUZAMT)-GCUR+")"
      If [F:BPS2]OSTCTL<3
        #----- Dépassement maximum encours autorisé ! -----#
        OK=2 : Call AVERTIR(mess(52,194,1)-GMESSAGE,OK) From GESECRAN
        If OK=1  OK=0 : Raz GMESSAGE : Goto RETOURNBLIG  Else  OK=1 : Raz GMESSAGE : Endif
      Else
        #----- Blocage fournisseur pour dépassement d'en-cours ! -----#
        GMESSAGE=mess(371,194,1)-GMESSAGE : GERR=1 : OK=0 : Goto RETOURNBLIG
      Endif
    Endif
  Endif
Endif
#----- Contrôle en duplication que la devise ne soit pas périmée -----#
If GREP="D"
  Call CONTDEV([M:POH1]CUR,[M:POH0]ORDDAT) From TRTDEV
  If mkstat  GERR=1 : OK=0 : Raz mkstat : Goto RETOURNBLIG : Endif
Endif
#----- Autres contrôles -----#

# Issue 71069 - 2013-08-22 by MUARN : PJT
Call PJT_CONTROLE_HEAD_DETAIL("[M:POH1]PJTH", "[M:POH2]PJT") From TRTPJT
If GERR <> 0
  OK = 0
  Return
Endif

#85785 * RMA * document amount cannot be negative
If func PORLEGLIB.DIGSIGN([M:POH0]POHFCY, "") & ([M:POH3]TTVORD<0)
  GERR = 1: GMESSAGE = mess(216,191,1) : OK = 0 : Return
Endif

Return
#----- Retour à la saisie (des lignes) -----#
$RETOURNBLIG
# FQ 73645 GA 05/2011 Cas particulier du regroupement
If dim([M:PMG]RGRFLG)>0 & [M:PMG]RGRFLG=4 : GOK=-1 : Endif
OK=0
Return

$CHARGENTETE
#------------------------------------------------------#
# Chargement entête avant le Write ou le Rewrite       #
# Nombre de lignes et adresse si modifiée              #
# Nombre de lignes en dépassement de budget            #
# Nombre de lignes soldées et indicateur cde soldée    #
# Mise à jour date, No ARC et avenant sur lignes écran #
# Màj indicateur de reprise du cycle de signature      #
#------------------------------------------------------#

# Issue 93321 - 2013-11-18 by MUARN : si PURGRUDIS = non, et onglet Total invisable, non calculé
#----- Recalcul totaux HT, TVA et TTC -----#
[F:POH]TOTORD=sum([M:POH3]INVORDAMT)+sum([M:POH3]INVLINAMT)+[M:POH3]TOTLINAMT
If [M:POH1]VACTYP<>4
  [F:POH]TOTTAXAMT=sum([M:POH3]AMTTAX)
Else
  [F:POH]TOTTAXAMT=0
Endif
[F:POH]TTVORD=[M:POH3]TOTORD+[M:POH3]TOTTAXAMT

Local Integer I
#----- Chargement HT et TTC commande en devise société -----#
Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&            [F:POH]TOTORD,[F:POH]TOTORDL,[F:POH]CHGCOE,I) From TRTDEV
Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&            [F:POH]TTVORD,[F:POH]TTVORDL,[F:POH]CHGCOE,I) From TRTDEV
#-----

[F:POH]LINNBR=[M:POH2]NBLIG
#----- La date de l'entête est maj avec la plus petite issue du détail -----#
[M:POH1]EXTRCPDAT1=min([M:POH2]EXTRCPDAT(0..[M:POH2]NBLIG-1))
[F:POH]EXTRCPDAT1=[M:POH1]EXTRCPDAT1
#----- Traitement du nom et de l'adresse du fournisseur commande -----#
If [M:AD61]ADBFLG<>2
  [F:POH]BPAADD=[M:AD61]BPAADD
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[F:POH]BPSNUM
      Read [BPR] BPR0=[F:POH]BPSNUM
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPAADD
      Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPAADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:POH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
    [F:POH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
    [F:POH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:POH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:POH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:POH]CRY          = [F:BPA]CRY
    [F:POH]CRYNAM       = [F:BPA]CRYNAM
    [F:POH]SAT          = [F:BPA]SAT
    [F:POH]POSCOD       = [F:BPA]POSCOD
    [F:POH]CTY          = [F:BPA]CTY
  Else
    Raz [F:POH]BPRNAM,[F:POH]BPAADDLIG,[F:POH]CRY,[F:POH]CRYNAM,
&       [F:POH]SAT,[F:POH]POSCOD,[F:POH]CTY
  Endif
Else
  [F:POH]=[M:AD61]
Endif
#----- Traitement du nom et de l'adresse du fournisseur expéditeur -----#
If [M:AD62]ADBFLG<>2
  [F:POH]BPOADD=[M:AD62]BPAADD
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[F:POH]BPSNUM
      Read [BPR] BPR0=[F:POH]BPSNUM
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
      Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:POH]BPONAM(0)    = [F:BPR]BPRNAM(0)
    [F:POH]BPONAM(1)    = [F:BPR]BPRNAM(1)
    [F:POH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:POH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:POH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:POH]BPOCRY       = [F:BPA]CRY
    [F:POH]BPOCRYNAM    = [F:BPA]CRYNAM
    [F:POH]BPOSAT       = [F:BPA]SAT
    [F:POH]BPOPOSCOD    = [F:BPA]POSCOD
    [F:POH]BPOCTY       = [F:BPA]CTY
  Else
    Raz [F:POH]BPONAM,[F:POH]BPOADDLIG,[F:POH]BPOCRY,[F:POH]BPOCRYNAM,
&       [F:POH]BPOSAT,[F:POH]BPOPOSCOD,[F:POH]BPOCTY
  Endif
Else
  [F:POH]BPOADD       = [M:AD62]BPAADD
  [F:POH]BPONAM(0)    = [M:AD62]BPRNAM(0)
  [F:POH]BPONAM(1)    = [M:AD62]BPRNAM(1)
  [F:POH]BPOADDLIG(0) = [M:AD62]BPAADDLIG(0)
  [F:POH]BPOADDLIG(1) = [M:AD62]BPAADDLIG(1)
  [F:POH]BPOADDLIG(2) = [M:AD62]BPAADDLIG(2)
  [F:POH]BPOCRY       = [M:AD62]CRY
  [F:POH]BPOCRYNAM    = [M:AD62]CRYNAM
  [F:POH]BPOSAT       = [M:AD62]SAT
  [F:POH]BPOPOSCOD    = [M:AD62]POSCOD
  [F:POH]BPOCTY       = [M:AD62]CTY
Endif
#----- Chargement informations douanières -----#
[F:POH] = [M:PCEV]
#-----
For I=0 To dim([F:POH]DISCRGTYP)-1
  [F:POH]DISCRGTYP (I)=GDISCRGTYP(I)
  [F:POH]INVDTALIN1(I)=GINVDTALIN(I)
Next I
# Issue 74079 - 2011-06-20 by SR : Recalculer le nombre de lignes complètement réceptionnées et facturées
Raz [F:POH]FBULINNBR, [F:POH]CLELINNBR, [F:POH]RCPLINNBR,[F:POH]INVLINNBR
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]FBUFLG(I)   =2 [F:POH]FBULINNBR+=1 : Endif
  # Issue 109173 - 2015-07-03 by MUARN : mise à jour ligne soldée en fonction quantité
  If GPOHCLE=1 | GPOHCLE=2    : # Solde si égalité ou supérieur ou à la demande
    If [M:POH2]RCPQTYSTU(I) >=[M:POH2]QTYSTU(I)
      [M:POH2]LINCLEFLG(I) = 2
    Endif
  Elsif GPOHCLE=4 | GPOHCLE=5 : # Solde suivant % tolérance + reste à la demande
    GBIDD1=[M:POH2]QTYSTU(I)-[M:POH2]RCPQTYSTU(I)
    If [F:ITM]ITMREF<>[M:POH2]ITMREF(I)
      Read [ITM] ITM0=[M:POH2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
    Endif
    If GBIDD1<=0 | abs((GBIDD1/[M:POH2]QTYSTU(I))*100)<=[F:ITM]MINRMNPRC
      [M:POH2]LINCLEFLG(I) = 2
    Endif
  Endif
  If [M:POH2]LINCLEFLG(I)=2 [F:POH]CLELINNBR+=1 : Endif
  # Issue 74079 - 2011-06-20 by SR : Recalculer le nombre de lignes complètement réceptionnées et facturées
  If [M:POH2]RCPQTYSTU(I) >= [M:POH2]QTYSTU(I) : [F:POH]RCPLINNBR+=1 : Endif
  If [M:POH2]INVQTYSTU(I) >= [M:POH2]QTYSTU(I) : [F:POH]INVLINNBR+=1 : Endif

  If [F:POH]OCNDAT<>[0/0/0] | [F:POH]OCNNUM<>""
    If ([M:POH2]LINOCNDAT(I)=[0/0/0] & [M:POH2]LINOCNNUM(I)="") |
&       [M:POH2]CREFLG(I)=0 | [M:POH2]UPDFLG(I)<>0
      #------------------------------------------------------------------#
      # LINOCNDAT(I) : Date ARC ligne                                    #
      # LINOCNNUM(I) : Numéro ARC ligne                                  #
      # LINOCNFLG(I) : Indicateur champs ARC ligne saisis ou modifiés    #
      #                0 = Rien n'a été saisi ou modifié                 #
      #                1 = Date ARC a été saisie ou modifiée             #
      #                2 = Numéro ARC a été saisi ou modifié             #
      #                3 = Date et numéro ARC ont été saisis ou modifiés #
      #------------------------------------------------------------------#
      If !find([M:POH2]LINOCNFLG(I),1,3) | [M:POH2]LINOCNDAT(I)=[0/0/0]
        [M:POH2]LINOCNDAT(I)=[F:POH]OCNDAT
        [M:POH2]UPDFLG(I)=1
      Endif
      If !find([M:POH2]LINOCNFLG(I),2,3) | [M:POH2]LINOCNNUM(I)=""
        [M:POH2]LINOCNNUM(I)=[F:POH]OCNNUM
        [M:POH2]UPDFLG(I)=1
      Endif
    Endif
  Endif
  If [F:POH]REVNUM<>0 & (GREVFLG=2 | [M:POH2]CREFLG(I)=0)
    If [M:POH2]CREFLG(I)=0 | [M:POH2]UPDFLG(I)<>0
      [M:POH2]LINREVNUM(I)=[F:POH]REVNUM
    Endif
  Endif
  If [M:POH2]WAPPFLG(I)=2 GAPPFLG=2 : Endif
Next I
If [F:POH]CLELINNBR=[F:POH]LINNBR [F:POH]CLEFLG=2 Else [F:POH]CLEFLG=1 : Endif
Return

$CHARGLIGNE
#-----------------------------------------------#
# Chargement ligne avant le Write ou le Rewrite #
# Codes statistiques article et codes taxe      #
#-----------------------------------------------#
Local Shortint NOL : NOL=nolign-1
If dim([M:POH2]TSICOD1(NOL))>0 [F:POP]TSICOD(0)=[M:POH2]TSICOD1(NOL) : Endif
If dim([M:POH2]TSICOD2(NOL))>0 [F:POP]TSICOD(1)=[M:POH2]TSICOD2(NOL) : Endif
If dim([M:POH2]TSICOD3(NOL))>0 [F:POP]TSICOD(2)=[M:POH2]TSICOD3(NOL) : Endif
If dim([M:POH2]TSICOD4(NOL))>0 [F:POP]TSICOD(3)=[M:POH2]TSICOD4(NOL) : Endif
If dim([M:POH2]TSICOD5(NOL))>0 [F:POP]TSICOD(4)=[M:POH2]TSICOD5(NOL) : Endif
[F:POP]VAT(0)=[M:POH2]VAT1(NOL)
[F:POP]VAT(1)=[M:POH2]VAT2(NOL)
[F:POP]VAT(2)=[M:POH2]VAT3(NOL)
Return

$CHARG_PARAM
#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#            GFINRSP    : Site financier                               #
#            GRCPFCY    : Site réception par défaut                    #
#            GSALDSPWEU : Unité de poids  pour répartition             #
#            GSALDSPVOU : Unité de volume pour répartition             #
# Récupération des paramètres ACHATS                                   #
# Récupération des paramètres BUDGET                                   #
#            GBUDCTLPOH : Contrôle en gestion commande (1=Non 2=Oui)   #
#            GBUDCTLPOL : Contrôle indicatif ligne cde (1=Non 2=Oui)   #
#            GPURCMM    : Mise à jour des engagements  (1=Non 2=Oui)   #
#            GPURCMMDAT : Date engagement (1=Date cde  2=Date Récept)  #
#            GCNTBUD    : type de contrôle engagements                 #
#                         (1=Aucun 2=Bloquant 3=Non bloquant)          #
# Contrôle existence paramétrage des règles de signature pour GSOCIETE #
#----------------------------------------------------------------------#
Local  Char     PARAM2(10)
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"PTR",3,GPTRNUM) From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  #----- Compteur des commandes -----#
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1) : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(2) : GCODNUM=[F:TCA]CODNUM(2)
  #------ Compteur des encours article ------#
  Call LECTCA(7,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #----- Contrôle longueur compteur pas supérieure à 15 caractères -----#
  #Call CTRCPT(GWIP,25,OK) From STKLIB
  #If OK<>0  GERR=1 : GMESSAGE=mess(222,199,1) : OK=0 : Return : Endif
  #------ Compteur des encours opération ------#
  If GMODU(8)=2 : # Module GP présent
    Call LECTCA(8,OK) From SUBTCA
    If fstat | !OK
      GMESSAGE=mess(58,105,1)-mess(8,14,1)-mess(250,199,1) : Return
    Endif
    GOPS=[F:TCA]CODNUM(4)
  Endif
  #-----
  # Issue 71069 - 2013-08-13 by MUARN : PJT
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
Endif
#-----
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH
Call PARAML(GFCY,"SALDSPWEU",GSALDSPWEU) From ADOVAL
Call PARAML(GFCY,"SALDSPVOU",GSALDSPVOU) From ADOVAL
If GMODU(2)=2 : # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)    From WWGLOBCPT
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
  Call PARAML(GFINRSP,"BUDCTLPOH",PARAM2) From ADOVAL
  GBUDCTLPOH=val(PARAM2)
  Call PARAML(GFINRSP,"BUDCTLPOL",PARAM2) From ADOVAL
  GBUDCTLPOL=val(PARAM2)
  Call PARAML(GFCY,"PURCMM",PARAM2)       From ADOVAL
  GPURCMM=val(PARAM2)
  Call PARAML(GFCY,"PURCMMDAT",PARAM2)    From ADOVAL
  GPURCMMDAT=val(PARAM2)
  Call PARAML(GFINRSP,"BUDCNTCMM",PARAM2) From ADOVAL
  GCNTBUD=val(PARAM2)
  If GCNTBUD=4 : # Contrôle budgétaire selon opérateur
    Call PARAMUTIL("CNTBUD",PARAM2,"",GFINRSP) From SUBAUS
    GCNTBUD=val(PARAM2)
  Endif
Else : # Dossier sans module comptabilité
  GBUDCTLPOH=1 : GBUDCTLPOL=1 : GPURCMM=1 : GPURCMMDAT=1 : GCNTBUD=1
Endif
# Issue 84130 - 2012-12-17 by MAE : Landed cost
Call PARAML(GSOCIETE,"NODVATSTO",PARAM2) From ADOVAL
  GNODVATSTO=val(PARAM2)

# Issue 105027 - 2015-02-10 by MUARN : landed cost inter-site élément de facturation pour coût stock
Call PARAM(GSOCIETE,"BETFCYCST",PARAM2) From ADOVAL
GBETFCYCST=val(PARAM2)

Raz GMESSAGE
Return

$MAJ_AOF
#--------------------------------#
# Mise à jour de l'appel d'offre #
#--------------------------------#
Local Shortint FLG
If SIGN=1 FLG=2 Else FLG=1 : Endif
Update [PPD] Where BPSNUM=[F:POQ]BPSNUM & PQHNUM=[F:POQ]PQHNUM &
&                  ITMREF=[F:POQ]ITMREF & PPDLIN=[F:POQ]PPDLIN
&            With ORDFLG=FLG
If fstat GOK=0 : Call FSTA("PPD") From GLOCK : Endif
Return

$REAJUST_ENTETE
#-----------------------------------------------------------------#
# Mise à jour du nbre de lignes dépassant le budget si nécessaire #
#-----------------------------------------------------------------#
Local Shortint I, FBUNBR : Raz FBUNBR
For I=0 To [M:POH2]NBLIG-1
    If [M:POH2]FBUFLG(I)=2 FBUNBR+=1 : Endif
Next I
If [F:POH]FBULINNBR=FBUNBR  Return : Endif
#-----
Update [POH] Where POHNUM=[M:POH0]POHNUM With FBULINNBR=FBUNBR
If fstat GOK=0 : Call FSTA("POH") From GLOCK : Endif
[F:POH]FBULINNBR=FBUNBR : # La classe [F] n'est pas màj par l'Update
Return

$CAL_MVS
#----------------------------------------------------#
# Calcul des montants HT et TTC  restant en commande #
#----------------------------------------------------#
If [F:POQ]LINCLEFLG=2 | [F:POQ]QTYPUU=0  Return : Endif
#-----
If [F:POQ]INVQTYPUU>[F:POQ]RCPQTYPUU
  #----- Si article facturé avant réception ou jamais réceptionné -----#
  WORDNOT+=([F:POQ]LINAMT*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
  WORDATI+=([F:POQ]LINATI*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
Else
  #----- Autres cas -----#
  WORDNOT+=([F:POQ]LINAMT*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
  WORDATI+=([F:POQ]LINATI*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
Endif
#-----
Return

$MAJ_ITV
#--------------------------------------------------------------------#
# Mise à jour de la qté cdée dans l'article-site si ligne non soldée #
#--------------------------------------------------------------------#
If [F:POQ]LINCLEFLG=2 | [F:POQ]LINTYP>3 : Return : Endif
QTY=[F:POQ]QTYSTU-[F:POQ]RCPQTYSTU : If QTY<=0 Return : Endif
Local Integer STA : STA=0
Call LECITV([F:POP]PRHFCY,[F:POP]ITMREF,"",STA) From STKLIB
If STA=2
  GMESSAGE="ITMMVT :"-[F:POP]PRHFCY-[F:POP]ITMREF-mess(60,100,1)
  If GOK=1  GOK=-1 : Endif
Endif
If GOK<>1 Return : Endif
If STA>2  Return : Endif
If STA<2
  [F:ITV]ORDSTO+=QTY*SIGN
  Rewrite [ITV] : If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Endif
Endif
Return

$REMP_DERLU
#-------------------------------------------------------------------------#
# MAE, pour raz liste gauche si navigation autre que depuis fournisseur   #
# TS, dans les achats, on conserve toujours la liste gauche               #
#-------------------------------------------------------------------------#
#If GFONC1<>"GESPOH"
#   If GPILNAV>1
#      If GNAVIG(GPILNAV-1)<>"GESBPS"
#         adxmxl=0
#      Endif
#   Else
#      adxmxl=0
#   Endif
#Endif
Return

$FILGAUCHE
#-------------------------------------------------------------------------#
# MAE, pour raz liste gauche si navigation autre que depuis fournisseur   #
# TS, dans les achats, on conserve toujours la liste gauche               #
#-------------------------------------------------------------------------#
#If GFONC1<>"GESPOH"
#   If GPILNAV>1
#      If GNAVIG(GPILNAV-1)<>"GESBPS"
#         If ILIS=0 adxmxl=0 Endif
#      Endif
#   Elsif ILIS=0
#      adxmxl=0
#   Endif
#Endif
Return

$COPIE_LIG
#-----------------------------------------------------------#
# Copie des champs d'une ligne en duplication ou éclatement #
# J = indice ligne à créer  (Destination)                   #
# K = indice de travail pour boucle de chargement           #
# L = indice ligne à copier (Origine)                       #
#-----------------------------------------------------------#
Local    Decimal  WCPRAMT   # Issue 84129 - 2013-01-22 by MUARN : landed cost
Local    Integer  WSTAT   # Issue 84129 - 2013-01-22 by MUARN : landed cost

# Issue 82703 - 2012-10-04 by SR : FCC : Razer REACSTPUR
Raz [M:POH2]LINOCNDAT(J),[M:POH2]LINOCNNUM(J),[M:POH2]LINREVNUM(J),
&   [M:POH2]SOHNUM(J),   [M:POH2]SOPLIN(J),   [M:POH2]SOQSEQ(J),
&   [M:POH2]CREFLG(J),   [M:POH2]UPDFLG(J),   [M:POH2]RETQTYSTU(J),
&   [M:POH2]PQHNUM(J),   [M:POH2]PPDLIN(J),   [M:POH2]LINRCPNBR(J),
&   [M:POH2]LININVNBR(J),[M:POH2]POHLIN(J),   [M:POH2]RCPQTYSTU(J),
&   [M:POH2]CMMNUM(J),   [M:POH2]REACSTPUR(J)
[M:POH2]LINCLEFLG(J)=1 : [M:POH2]FBUFLG(J)=1 : [M:POH2]WAPPFLG(J)=2 : [M:POH2]ORI(J)=1
[M:POH2]ITMREF(J)    = [M:POH2]ITMREF(L)
[M:POH2]ITMDES(J)    = [M:POH2]ITMDES(L)
[M:POH2]ITMDES1(J)   = [M:POH2]ITMDES1(L)
# Issue 112754 - 2016-12-05 by SR : Services
[M:POH2]ITMKND(J)    = [M:POH2]ITMKND(L)
[M:POH2]LINSTOFCY(J) = [M:POH2]LINSTOFCY(L)
[M:POH2]PRHFCY(J)    = [M:POH2]PRHFCY(L)
[M:POH2]FCYADD(J)    = [M:POH2]FCYADD(L)
[M:POH2]USEPLC(J)    = [M:POH2]USEPLC(L)
[M:POH2]UOM(J)       = [M:POH2]UOM(L)
[M:POH2]UOMFLG(J)    = [M:POH2]UOMFLG(L)
[M:POH2]QTYUOM(J)    = [M:POH2]QTYUOM(L)
[M:POH2]UOMPUUCOE(J) = [M:POH2]UOMPUUCOE(L)
[M:POH2]PUU(J)       = [M:POH2]PUU(L)
[M:POH2]QTYPUU(J)    = [M:POH2]QTYPUU(L)
[M:POH2]STU(J)       = [M:POH2]STU(L)
[M:POH2]QTYSTU(J)    = [M:POH2]QTYSTU(L)
[M:POH2]EXTRCPDAT(J) = [M:POH2]EXTRCPDAT(L)
[M:POH2]GROPRI(J)    = [M:POH2]GROPRI(L)
[M:POH2]NETPRI(J)    = [M:POH2]NETPRI(L)
[M:POH2]QUAFLG(J)    = [M:POH2]QUAFLG(L)
[M:POH2]PJT(J)       = [M:POH2]PJT(L)
If dim([M:POH2]EECINCRAT(J))>0  [M:POH2]EECINCRAT(J)=[M:POH2]EECINCRAT(L) : Endif
[M:POH2]ORICRY(J)    = [M:POH2]ORICRY(L)
[M:POH2]RETRCPDAT(J) = [M:POH2]RETRCPDAT(L)
# Issue X3-64840 - 2017-11-30 by SR : Lead Time
[M:POH2]OFS(J)       = [M:POH2]OFS(L)
[M:POH2]PURMINQTY(J) = [M:POH2]PURMINQTY(L)
[M:POH2]VAT1(J)      = [M:POH2]VAT1(L)
[M:POH2]VAT2(J)      = [M:POH2]VAT2(L)
[M:POH2]VAT3(J)      = [M:POH2]VAT3(L)
If dim([M:POH2]TAXRCP(J))>0   [M:POH2]TAXRCP(J) =[M:POH2]TAXRCP(L)  : Endif
If dim([M:POH2]TAXISS(J))>0   [M:POH2]TAXISS(J) =[M:POH2]TAXISS(L)  : Endif
If dim([M:POH2]TAXOTH1(J))>0  [M:POH2]TAXOTH1(J)=[M:POH2]TAXOTH1(L) : Endif
If dim([M:POH2]TAXOTH2(J))>0  [M:POH2]TAXOTH2(J)=[M:POH2]TAXOTH2(L) : Endif
If dim([M:POH2]MATTOL(J))>0   [M:POH2]MATTOL(J)=[M:POH2]MATTOL(L)   : Endif   # Three way matching GRNA
# Issue 71276 - 2015-03-27 by SR : Versions
If dim([M:POH2]ECCVALMAJ)>0
  [M:POH2]ECCVALMAJ(J) = [M:POH2]ECCVALMAJ(L)
Endif
If dim([M:POH2]ECCVALMIN)>0
  [M:POH2]ECCVALMIN(J) = [M:POH2]ECCVALMIN(L)
Endif
# End issue 71276

[M:POH2]LINTYP(J)    = [M:POH2]LINTYP(L)
For K=1 To GNBCOA
  Assign "[M:POH2]LINACC"+num$(K)+"(J)" With evalue("[M:POH2]LINACC"+num$(K)+"(L)")
Next K
[M:POH2]LINPURTYP(J) = [M:POH2]LINPURTYP(L)
#---- Duplication du texte si nécessaire -----#
[M:POH2]LINTEX(J)=[M:POH2]LINTEX(L)
If left$([M:POH2]LINTEX(J),3)="POQ"
  Call DUP_CLOB("POQ",[M:POH2]LINTEX(J),GBIDI1) From TRTX3TEX
  If GBIDI1<1  Raz [M:POH2]LINTEX(J) : Endif
Endif
#-----
# Issue 70985 - 2012-02-17 by MUARN : alimentation coefficient frais d'approche et coût achat forfaitaire
Call RECH_COST([M:POH2]PRHFCY(J),[M:POH0]BPSNUM, [M:POH2]ITMREF(J), [M:POH2]CPRCOE(J), WCPRAMT, [M:POH2]STCNUM(J)) From STCLIB
If GLOCALDEV <> GSYSCUR
  Call CONVERT2(GSYSCUR,GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WCPRAMT,WCPRAMT,WSTAT) From TRTDEV
  [M:POH2]CPRAMT(J)=arr(WCPRAMT,10^-GDECPRI)
Else
  [M:POH2]CPRAMT(J)=WCPRAMT
Endif
If [M:POH2]CPRCOE(J)=0 [M:POH2]CPRCOE(J)=1 Endif
[M:POH2]NETCUR(J) = [M:POH1]CUR
[M:POH2]CPRCUR(J) = GLOCALDEV
[M:POH2]QTYWEU(J) = [M:POH2]QTYWEU(L)
[M:POH2]LINWEU(J) = [M:POH2]LINWEU(L)
[M:POH2]QTYVOU(J) = [M:POH2]QTYVOU(L)
[M:POH2]LINVOU(J) = [M:POH2]LINVOU(L)

If [M:POH2]STCNUM(J)<> ""
  Diszo [POH2]CPRAMT(J), CPRCOE(J), CPR(J)
Else
  Actzo [POH2]CPRAMT(J), CPRCOE(J), CPR(J)
Endif
[M:POH2]WSTCUPD(J)=2

[M:POH2]LINBUY(J)    = [M:POH2]LINBUY(L)
[M:POH2]LINAMT(J)    = [M:POH2]LINAMT(L)
[M:POH2]LINATI(J)    = [M:POH2]LINATI(L)
[M:POH2]LINATIAMT(J) = [M:POH2]LINATIAMT(L)
[M:POH2]CLCAMT1(J)   = [M:POH2]CLCAMT1(L)
[M:POH2]CLCAMT2(J)   = [M:POH2]CLCAMT2(L)
[M:POH2]CLCAMT3(J)   = [M:POH2]CLCAMT3(L)
If dim([M:POH2]CLCAMT4(J))>0  [M:POH2]CLCAMT4(J)=[M:POH2]CLCAMT4(L) : Endif
If dim([M:POH2]CLCAMT5(J))>0  [M:POH2]CLCAMT5(J)=[M:POH2]CLCAMT5(L) : Endif
If dim([M:POH2]CLCAMT6(J))>0  [M:POH2]CLCAMT6(J)=[M:POH2]CLCAMT6(L) : Endif
If dim([M:POH2]CLCAMT7(J))>0  [M:POH2]CLCAMT7(J)=[M:POH2]CLCAMT7(L) : Endif
[M:POH2]PRIREN(J)    = [M:POH2]PRIREN(L)
[M:POH2]STOMGTCOD(J) = [M:POH2]STOMGTCOD(L)
[M:POH2]LINFLG(J)    = 2
[M:POH2]ITMREFORI(J) = [M:POH2]ITMREFORI(L)
[M:POH2]VCRTYPORI(J) = [M:POH2]VCRTYPORI(L)
[M:POH2]VCRNUMORI(J) = [M:POH2]VCRNUMORI(L)
[M:POH2]VCRLINORI(J) = [M:POH2]VCRLINORI(L)
[M:POH2]VCRSEQORI(J) = [M:POH2]VCRSEQORI(L)
[M:POH2]PREQTYPUU(J) = [M:POH2]PREQTYPUU(L)
[M:POH2]LIKQTYCOE(J) = [M:POH2]LIKQTYCOE(L)
[M:POH2]PTOCOD(J)    = [M:POH2]PTOCOD(L)
#----- Frais/remises et motifs tarif -----#
For K=1 To 9
  If evalue("dim([M:POH2]DISCRGVAL"+num$(K)+"(L))")>0
    Assign "[M:POH2]DISCRGVAL"+num$(K)+"(J)"
&           With evalue("[M:POH2]DISCRGVAL"+num$(K)+"(L)")
    Assign "[M:POH2]DISCRGREN"+num$(K)+"(J)"
&           With evalue("[M:POH2]DISCRGREN"+num$(K)+"(L)")
  Endif
Next K
#----- Sections analytiques -----#
For K=1 To GNBDIE
  Assign "[M:POH2]CCE"+num$(K)+"(J)" With evalue("[M:POH2]CCE"+num$(K)+"(L)")
Next K
#----- Codes statistiques article -----#
For K=1 To 5
  If evalue("DIM([M:POH2]TSICOD"+num$(K)+"(L))")>0
    Assign "[M:POH2]TSICOD"+num$(K)+"(J)"
&           With evalue("[M:POH2]TSICOD"+num$(K)+"(L)")
  Endif
Next K
#----- Point d'entrée COPLINPOH pour compléter la duplication de ligne -----#
Gosub POINT_COPLINPOH From SUBPOHB
#-----
Return

$SUPPRESS_TEX
#-----------------------------------------#
# Suppression des textes après un abandon #
#-----------------------------------------#
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:POH1]TEX1,3)="POH"
    Call SUP_CLOB([M:POH1]TEX1,GBIDI1) From TRTX3TEX
  Endif
  If left$([M:POH1]TEX2,3)="POH"
    Call SUP_CLOB([M:POH1]TEX2,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For I=0 To [M:POH2]NBLIG-1
  If left$([M:POH2]LINTEX(I),3)="POQ" & [M:POH2]CREFLG(I)=0
    Call SUP_CLOB([M:POH2]LINTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
#-----
Call RAZ_CLOB From ACLOB
Return

$OUVERTURE_TRACE
#---------------------------------------#
# Ouverture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE=0 & !GIMPORT & ((GPURCMM=2 & GMODU(2)=2) | [M:POH0]SALFCY<>"")
  # Issue 86615 - 2013-01-04 by MUARN : modification nom fichier ajout mess(74,187,1)
  Call OUVRE_TRACE(mess(74,187,1)-"/"-mess(173,197,1)) From LECFIC : GPURTRACE=1
Endif
Return

$LECTURE_TRACE
#-----------------------------------------------------------#
# Lecture du fichier trace des alertes budget si nécessaire #
#-----------------------------------------------------------#
If GPURTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  GPURTRACE=0
Endif
Return

$LECT_EFFAC_TRACE
#----------------------------------------------------------#
# Lecture et effacement trace si abandon de la transaction #
#----------------------------------------------------------#
If GPURTRACE=2 & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call SUPP_TRACE  From LECFIC
  GPURTRACE=0
Endif
Return

$FERMETURE_TRACE
#---------------------------------------#
# Fermeture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE<>0 & !GIMPORT & GWEBSERV<>1
  Call FERME_TRACE From LECFIC : GPURTRACE=0
Endif
Return

$RAZ_CMMNUM
#----------------------------------------------------------------#
# Effacement des éventuels numéros d'engagement non encore créés #
#----------------------------------------------------------------#
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]CREFLG(I)=0  Raz [M:POH2]CMMNUM(I) : Endif
Next I
Return

#--------------------------------------#
# Chargement des textes entête et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:POH1]TEX1<>""
  If left$([M:POH1]TEX1,3)="POH"
    Call CRE_CLOB([M:POH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:POH1]TEX1,3)<>"BPS"
    Call DUP_CLOB("POH",[M:POH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POH]TEX1=[M:POH1]TEX1
Endif
If [M:POH1]TEX2<>""
  If left$([M:POH1]TEX2,3)="POH"
    Call CRE_CLOB([M:POH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:POH1]TEX2,3)<>"BPS"
    Call DUP_CLOB("POH",[M:POH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POH]TEX2=[M:POH1]TEX2
Endif
Return

#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:POH2]LINTEX(nolign-1)<>""
  If left$([M:POH2]LINTEX(nolign-1),3)="POQ"
    Call CRE_CLOB([M:POH2]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:POH2]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("POQ",[M:POH2]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POQ]LINTEX=[M:POH2]LINTEX(nolign-1)
Endif
Return

#---------------------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (frais/remises, comptes et sections analytiques) #
#---------------------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:POH2]DISCRGVAL1)>0 | dim([M:POH2]LINACC1)>0 | dim([M:POH2]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE3"+GPTRNUM+"2"
  BASPAG="NBFAC" : Gosub TIT_COL From ="W1WE3"+GPTRNUM+"3"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:POH2]NBLIG=0
    [M:POH2]NBLIG=1 : Affzo [POH2]5 : Effzo [POH2]5
  Endif
  If [M:POH3]NBFAC=0
    [M:POH3]NBFAC=1 : [M:POH3]FORMAT(0)="NZ:9.2#" : Affzo [POH3]5 : Effzo [POH3]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG

# Issue 84130 - 2013-01-24 by MUARN : landed cost
If GFONCTION = "GESPOH" & !GIMPORT
  Titcol [M:CSTO]NBCST mess(796,197,1) + " (" + GCUR + ")" For TOTDOC
  Titcol [M:CSTO]NBCST mess(797,197,1) + " (" + GLOCALDEV + ")" For TOTSOC
Endif

Return

#------------------------------------------------------------------------#
# commande en création, alimentée par le fournisseur via les navigations #
#------------------------------------------------------------------------#
$AVANT_CHOI    #----MAE, le 19/02/08----#
If GCREFONC=1
   REPONSE=GSTANEW
   Gosub NOUVEAU From GOBJSUB
   Gosub SETBOUT From GOBJSUB
   #MAE, le 28/10/08, on grise le fournisseur quand on créé une commande à partir des fournisseurs
   # FGR 18/02/2014 : X3SUIVI96940 ne pas faire le diszo : ça désactive les actions sur champ (contrôle, AM...)
   #   If [M:POH0]BPSNUM <>""
   #    Diszo [M:POH0]BPSNUM
   #   Endif
   # FGR 18/02/2014 : X3SUIVI96940 empêche l'exécution du AM_BPCORD
   #GCREFONC = 0
   GCREFONC = 2
Endif
Return

