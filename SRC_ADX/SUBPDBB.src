#<AdxTL>@(#)8.0.0.0 $Revision$
#############################################################################################
#   Programmes utilitaires pour la gestion des débits de points
#
#   SETGRAY     : Gestion du grisage des zones
#
#############################################################################################

###########################################################
# Gestion du grisage des zones
###########################################################
$SETGRAY

Local Integer ITERPIO
ITERPIO = 0

Actzo [M:PDB0]NULPIO
Actzo [M:PDB1]NULPIOVAL

If [M:PDB0]BPR = ""
    If [M:PDB0]ITMREF = ""
        If [M:PDB0]PBL = ""
            Grizo [M:PDB0]NULPIO
            [M:PDB0]NULPIO = 1

            Grizo [M:PDB1]NULPIOVAL
            For ITERPIO = 0 To [M:PDB1]NBLIG - 1
                [M:PDB1]NULPIOVAL(ITERPIO) = 1
            Next
        Endif
    Endif
Endif

Return
