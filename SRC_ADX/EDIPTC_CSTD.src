#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIPTC                                                           #
# Manages main class EDIPTC (this) and child class EDIPTCD (this.EPTD)        #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"  : Gosub ADELETE_CONTROL_AFTER
        When "AINIT"                  : Gosub AINIT
      Endcase
    When "EPTD" :
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EPTD_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"           : Gosub MET_VALIDATE
    When "MET_GET_FORM"           : Gosub MET_GET_FORM
    When "MET_POST_JSON"          : Gosub MET_POST_JSON
    When "MET_PUT_JSON"           : Gosub MET_PUT_JSON
    When "MET_DEL_JSON"           : Gosub MET_DEL_JSON
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CACHEUUID"
      Case [L]ARULE
        When "INIT"       : Gosub CACHEUUID_INIT
      Endcase
    When "PTCCOD"
      Case [L]ARULE
        When 'CONTROL'    : Gosub PTCCOD_CONTROL
      Endcase
    When "CODACT"
    When "PTCTYP"
      Case [L]ARULE
        When 'INIT'       : Gosub PTCTYP_INIT
        When 'CONTROL'    : Gosub PTCTYP_CONTROL
        When 'PROPAGATE'  : Gosub PTCTYP_PROPAGATE    #X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
      Endcase
    When "EPTD.PTCLINVAL"
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub EPTD_PTCLINVAL_PROPAGATE
      Endcase
    When "EPTD.PTCLINVALDIR"
      Case [L]ARULE
        When 'CONTROL'    : Gosub EPTD_PTCLINVALDIR_CONTROL
        When 'PROPAGATE'  : Gosub EPTD_PTCLINVALDIR_PROPAGATE
      Endcase
    When "EPTM.PTCMLINVAL"
      Case [L]ARULE
        When 'CONTROL'    : Gosub EPTM_PTCLINVAL_CONTROL
      Endcase
  Endcase
Return

####################################################################

$CACHEUUID_INIT
  this.CACHEUUID = NullUuid()
Return

####################################################################

$PTCCOD_CONTROL
  If this.PTCCOD <> ""
    this.PTCCOD = func EDILIBA.FORMATVAL("PTCCOD", this.PTCCOD)
  Endif
Return

####################################################################

$PTCTYP_INIT
  If this.PTCTYP = 0: this.PTCTYP = 2 : Endif # Directories
Return

$PTCTYP_CONTROL
  #Impossible to change the protocol type in EDI Version 1
#  If this.PTCTYP <> 2  #X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
    #Changing protocol type not allowed
#    ASTATUS = fmet this.ASETERROR(CURPRO,mess(13,2006,1),[V]CST_AERROR)
#  Endif
Return

$PTCTYP_PROPAGATE  #X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
  If this.snapshot.PTCTYP<>this.PTCTYP or (this.PTCTYP=2 and this.EPTM<>null)
    Gosub CLEAR_VALUES
   Endif
   Gosub MET_GET_FORM
Return
#####################################################################

$EPTD_PTCLINVALDIR_CONTROL
  Local Char WERR(250), WLINVAL(250), WFICPATCH (250)

  #test for a directory type of protocol
  If this.APARENT.PTCTYP <> 0 # Directories
    Local Integer WMAN , WPRINTSERVER
    If this.PTCLINCOD = "DIRARCHIVE" or this.PTCLINCOD = "DIRSIGNATURE" or this.PTCLINCOD = "DIRATTACHMENT": WMAN=0: Else: WMAN=1: Endif  #SAM 112148
    If this.PTCLINCOD = "DIRPRINTSERVER"
      WPRINTSERVER=func PS_MANDATORY(this)
      If WPRINTSERVER=1: WMAN=1: Endif
    Endif
    If this.PTCLINVALTYP="FIC"
&   and this.PTCLINVALDIR = ""
&   and WMAN=1 #SAM 112148
      #"Volume must be defined"
      ASTATUS = fmet this.ASETERROR("PTCLINVALDIR", mess(6,2007,1), [V]CST_AWARNING)
    Else
      #If !((this.PTCLINCOD = "DIRARCHIVE" and this.PTCLINVALDIR = "")   #SAM 112148
        If ! (WMAN=0 and this.PTCLINVALDIR = "")     #SAM 112148
        Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
        WLINVAL = this.PTCLINVALDIR
        If !pat(this.PTCLINVALDIR,"["): WLINVAL = "["+this.PTCLINVALDIR+"]":    Endif
        If func ASYRSTO.CTL_VOLFIL(2, WLINVAL,[L]WFICPATCH,E_TYPE_FOLDER,WERR) <> 0
          #      WERR= mess(216,188,1)-num$(this.NUMLIN) - WERR
          ASTATUS = fmet this.ASETERROR("PTCLINVALDIR", WERR, [V]CST_AERROR)
        Endif
      Endif
    Endif
  Endif
Return

$EPTD_PTCLINVALDIR_PROPAGATE
# X3-46078 RBA
this.PTCLINVAL = func ASYRSTO.GETFULLPATH(this.PTCLINVALDIR,"")
#  Local File AVOLUME [AVL]
#  Read [AVL]CODE=this.PTCLINVALDIR
#  If fstat=[V]CST_AOK
#    this.PTCLINVAL=[F:AVL]ROOT
#  Else
#    this.PTCLINVAL=""
#  Endif
#  this.APARENT.VALID = [V]CST_ANO
#  LogicClose File [AVL]
Return

####################################################################
$EPTM_PTCLINVAL_CONTROL
  Local Char WERR(250)
  If this.APARENT.PTCTYP <> 0 # Directories
    Local Integer WMAN
    If this.PTCMLINCOD = "SMTP" or this.PTCMLINCOD = "THEME" or this.PTCMLINCOD = "MAIL1"
&   or this.PTCMLINCOD = "SUBJECT" or this.PTCMLINCOD = "BODY"
      WMAN=1: Else: WMAN=0
    Endif
    If this.PTCMLINVAL = "" and WMAN=1
      WERR= mess(10,123,1) # Mandatory field
      ASTATUS = fmet this.ASETERROR("PTCMLINVAL", WERR, [V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$EPTD_PTCLINVAL_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

#********************************************************************
# Method EPTD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EPTD_ADDLINE_AFTER
  #Manage key identifiers

  #on ajoute une ligne
  this.NUMLIN    = 1 + max(this.APARENT.EPTD(1..maxtab(this.APARENT.EPTD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EPTD)
    If this.APARENT.EPTD(I) <> null
      If this.APARENT.EPTD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EPTD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EPTD(AFT_LINE).SORT
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPTD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPTD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EPTD)
        If this.APARENT.EPTD(I) <> null
          OFFSET_LINE = this.APARENT.EPTD(I).AORDER - this.AORDER
#          If this.APARENT.EPTD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EPTD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPTD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EPTD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

Return

#####################################################################

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)
  WOK = fmet this.MET_VALIDATE()

  If WOK = [V]CST_ATRUE
    For I=1 To maxtab(this.EPTM)
      this.EPTM(I).PTCCOD=this.PTCCOD
    Next
    WOK = fmet this.MET_POST_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Invalid protocol"
    ASTATUS = fmet this.ASETERROR("VALID", mess(44,2006,1), [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_PUT_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Invalid protocol"
    ASTATUS = fmet this.ASETERROR("VALID", mess(44,2006,1), [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_DEL_JSON(WERR)
  If WOK <> [V]CST_AINFO
    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
  Endif
Return

$CLEAR_VALUES
Local Integer WLINE
For WLINE= 1 To maxtab(this.EPTD)
  If this.EPTD(WLINE)<>null
    Call DELETELINES(this,"EPTD") From EDILIBA
  Endif
Next
For WLINE= 1 To maxtab(this.EPTM)
  If this.EPTM(WLINE)<>null
    Call DELETELINES(this,"EPTM") From EDILIBA
  Endif
Next
Return
#********************************************************************
# Method AINIT
#********************************************************************
#*
#*!
$AINIT
  If this.EPTD()=null #X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
   [L]ASTATUS = fmet this.MET_GET_FORM()
  Endif
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
  Local Integer WOK
  Local Integer WNBERR : WNBERR = 0
  Local Char WERR(250) : WERR = ""
  Local Integer I

  #assign paths
#  Local File AVOLUME [AVL]
  If this.PTCTYP <>0 # Directories
    For I = 1 To maxtab(this.EPTD)
      If this.EPTD(I)<>null
&     and this.EPTD(I).ASTALIN <> [V]CST_ADEL
&     and this.EPTD(I).ASTALIN <> [V]CST_ANEWDEL
&     and this.EPTD(I).PTCLINVALTYP="FIC"
#  X3-46078 RBA
#      Read [AVL]CODE=this.EPTD(I).PTCLINVALDIR
#      If fstat=[V]CST_AOK
#        this.EPTD(I).PTCLINVAL=[F:AVL]ROOT
#      Else
#        this.EPTD(I).PTCLINVAL=""
#      Endif
       this.EPTD(I).PTCLINVAL = func ASYRSTO.GETFULLPATH(this.EPTD(I).PTCLINVALDIR,"")
      Endif
    Next I
  Endif
#  LogicClose File [AVL]

  #test for a directory type of protocol --> are already done by control
  If this.PTCTYP <>0 # Directories
    For I = 1 To maxtab(this.EPTD)
      Local Integer WMAN
      If this.EPTD(I).PTCLINCOD = "DIRARCHIVE" or this.EPTD(I).PTCLINCOD = "DIRSIGNATURE" or this.EPTD(I).PTCLINCOD = "DIRATTACHMENT": WMAN=0 : Else WMAN=1: Endif #SAM 112148
      If this.EPTD(I).PTCLINCOD = "DIRPRINTSERVER" #X3-98743 (02/07/2018 JUCON)
        Local Integer WPRS
        WPRS=func PS_MANDATORY(this)
        If WPRS=1: WMAN=1: Else WMAN=0: Endif
      Endif
      If this.EPTD(I)<>null
&     and this.EPTD(I).ASTALIN <> [V]CST_ADEL
&     and this.EPTD(I).ASTALIN <> [V]CST_ANEWDEL
&     and this.EPTD(I).PTCLINVALTYP="FIC"
&     and this.EPTD(I).PTCLINVALDIR = ""
&     and WMAN=1  #SAM 112148
      #"Volume must be defined"
        WNBERR = WNBERR + 1
      Endif
    Next I
  Endif

  If WNBERR > 0
    this.VALID = [V]CST_ANO

    #if the protocol begins not valid, all linked flows mustn't be valid and activated
    #unvalidate and unactivate all flows activated and/or validated using this EDIPTC
    Local Instance WEDIFLO Using C_EDIFLO
    WEDIFLO = NewInstance C_EDIFLO AllocGroup null
    Local File EDIFLO [EFL]
    Filter [EFL] Where [EFL]PTCCOD = this.PTCCOD and ([EFL]VALID = [V]CST_AYES or [EFL]FLGACT = [V]CST_AYES)
    For [EFL]
      WOK = fmet WEDIFLO.AREAD([EFL]FLOCOD,[EFL]FLOREL)
      If WOK = [V]CST_AOK
        WOK = fmet WEDIFLO.MET_UNVALIDATE()
        WOK = fmet WEDIFLO.AUPDATE()
        #Flow has been invalidated and deactivated-[EFL]FLOCOD+"~"+[EFL]FLOREL
        WERR = mess(28,2006,1)-[EFL]FLOCOD+"~"+[EFL]FLOREL
        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
      Endif
    Next
    LogicClose File [EFL]
    FreeGroup WEDIFLO : WEDIFLO=null

  Else
    # Set Valid
    this.VALID = [V]CST_AYES
  Endif

  If this.VALID = [V]CST_AYES
    ARET_VALUE = [V]CST_ATRUE
  Else
    ARET_VALUE = [V]CST_AFALSE
  Endif
Return

#********************************************************************
# Method MET_GET_FORM
#********************************************************************
#
#* Get form
#*
#* @return WOK
#*!
$MET_GET_FORM
  Local Integer WOK, I, K, WPOS

  If this.PTCTYP <> 0
    Local Integer WPTCTYPTAB(1..)
    Local Char WPTCLINVALTYP(10)(1..)
    Local Char WCODTAB(20)(1..)
    Local Char WLBLTAB(50)(1..)
    Local Char WMLBLTAB(50)(1..) # X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
#    Local Char WVALTAB(250)(1..)  #temporary

    I = 0
    #directory type parameters
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRISSUE"     : WLBLTAB(I) = mess(1,2007,1) #"Issue volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRRECEIPT"   : WLBLTAB(I) = mess(2,2007,1) #"Receipt volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRARCHIVE"   : WLBLTAB(I) = mess(3,2007,1) #"Archive volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRERROR"     : WLBLTAB(I) = mess(4,2007,1) #"Error volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRIMPORT"    : WLBLTAB(I) = mess(5,2007,1) #"Import volume"

    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRISSUETEST" : WLBLTAB(I) = mess(61,2007,1) #"Issue test volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRIMPORTTEST": WLBLTAB(I) = mess(62,2007,1) #"Import test volume"

# Init SAM 112148 XML signature
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP : WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRSIGNATURE": WLBLTAB(I) = mess(63,2007,1) #"Signed documents volume"
# End SAM 112148

# Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP: WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRATTACHMENT": WLBLTAB(I) = mess(95,2007,1) #"Attachment documents volume"
    I = I+1 : WPTCTYPTAB(I) = this.PTCTYP: WPTCLINVALTYP(I) = "FIC" : WCODTAB(I) = "DIRPRINTSERVER":WLBLTAB(I) = mess(104,2007,1)#"Print server volume'"
# End Epic X3-64474 _ US X3-85220

    For I = 1 To maxtab(WPTCTYPTAB)
      If this.PTCTYP = WPTCTYPTAB(I)
        WPOS = fmet this.ADDLINE('EPTD',[V]CST_ALASTPOS)
        this.EPTD(WPOS).PTCLINCOD    = WCODTAB(I)
        this.EPTD(WPOS).PTCLINDES    = WLBLTAB(I)
        this.EPTD(WPOS).PTCLINVALTYP = WPTCLINVALTYP(I)
      Endif
    Next I

    #Ini X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
    If this.PTCTYP=1 # Email protocol
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "SMTP"     : WMLBLTAB(K) = mess(96,2007,1)     #"Notification SMTP Server"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "THEME"    : WMLBLTAB(K) = mess(97,2007,1)     #"Notification theme"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "MAIL1"    : WMLBLTAB(K) = mess(98,2007,1)-"1" #"Destination address 1"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "MAIL2"    : WMLBLTAB(K) = mess(98,2007,1)-"2" #"Destination address 2"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "SUBJECT"  : WMLBLTAB(K) = mess(99,2007,1)     #"Subject of mail'"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "TITLE"   : WMLBLTAB(K) = mess(100,2007,1)    #"Tittle of notification"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "SUBTITLE": WMLBLTAB(K) = mess(101,2007,1)    #"ISubtittle of notification"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "BODY"     : WMLBLTAB(K) = mess(102,2007,1)    #"Body of mail"
      K = K+1 : WPTCTYPTAB(K) = this.PTCTYP : WPTCLINVALTYP(K) = "EML" : WCODTAB(K) = "SGN"      : WMLBLTAB(K) = mess(103,2007,1)    #"Mail signature"
      For I=1 To K
        WPOS = fmet this.ADDLINE('EPTM',[V]CST_ALASTPOS)
        If this.PTCCOD<>""
          this.EPTM(WPOS).PTCCOD        = this.PTCCOD
        Endif
        this.EPTM(WPOS).NUMLIN        = WPOS
        this.EPTM(WPOS).PTCMLINCOD    = WCODTAB(I)
        this.EPTM(WPOS).PTCMLINDES    = WMLBLTAB(I)
        this.EPTM(WPOS).PTCMLVALTYP   = WPTCLINVALTYP(I)
      Next K
    Endif
    #End X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file  (JUCON 21/05/18)
  Endif
  If maxtab(WPTCTYPTAB) > 0
    WOK = [V]CST_AOK
  Else
    WOK = [V]CST_AERROR
  Endif
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_POST_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_POST_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "protocol"
  Local Char WKEY(250)          : WKEY = this.PTCCOD
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIPTC"
  Endif
  #on peut supprimer par l'ID uis recrer
  Gosub JSON_DELETE From EDILIBC
  Gosub JSON_CREATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_PUT_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_PUT_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIPTC"
  Endif
  Gosub JSON_UPDATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_DEL_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_DEL_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "protocol"
  Local Char WKEY(250)          : WKEY = this.PTCCOD
  Gosub JSON_DELETE From EDILIBC
  ARET_VALUE = WOK
Return

#####################################################################

#********************************************************************
# Funprog GET_MOVEEND_FLG
#********************************************************************
#@param WPTCCOD
#@return WFLG_MOVEEND
#*!
Funprog GET_MOVEEND_FLG(WPTCCOD)
Value Char WPTCCOD
  Local Integer WFLG_MOVEEND : WFLG_MOVEEND = [V]CST_AFALSE
  Local File EDIPTC [EPT]
  Read [EPT]EPT0 = WPTCCOD
  If !fstat
    If [EPT]PTCTYP = 2
      Local File EDIPTCD [EPTD]
      Filter [EPTD] Where [EPTD]PTCCOD = WPTCCOD and [EPTD]PTCLINCOD = "DIRARCHIVE"
      For [EPTD]
        If [EPTD]PTCLINVAL <> ""
          WFLG_MOVEEND = [V]CST_ATRUE
        Endif
        Break
      Next
      LogicClose File [EPTD]
    Endif
  Endif
  LogicClose File [EPT]
End WFLG_MOVEEND

#********************************************************************
# Funprog GET_IMPORTPATH
#********************************************************************
#@param WPTCCOD
#@return WPATH
#*!
Funprog GET_IMPORTPATH(WPTCCOD)
Value Char WPTCCOD
  Local Char WPATH(250)
  Local File EDIPTCD [EPTD]
  Filter [EPTD] Where PTCCOD = WPTCCOD and PTCLINCOD = "DIRIMPORT"
  For [EPTD]
    WPATH = [EPTD]PTCLINVAL
    Break
  Next
  LogicClose File [EPTD]
End WPATH

#********************************************************************
# Funprog PS_MANDATORY
#********************************************************************
#@param WPTCCOD
#@return WPS
#*!
Funprog PS_MANDATORY(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WPS
  If dim(WOBJECT.APARENT.EPTD())>0
    If WOBJECT.APARENT.EPTD(9).PTCLINVALDIR<>"": WPS=1: Endif
  Else
    If WOBJECT.EPTD(9).PTCLINVALDIR<>"": WPS=1: Endif
  Endif

End WPS

