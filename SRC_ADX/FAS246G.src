#<AdxTL>@(#)0.0.0.0 $Revision$
#** ####################################################################################################################
#*
#* Label      : action
#* Purpose    : standard entry point
#*
#*####################################################################################################################
$ACTION
  Case ACTION
    When "FIN"   : Gosub FIN
    When Default :
  Endcase
Return

#** ####################################################################################################################
#*
#* Label      : fin
#* Purpose    : will unlock the FAS246G object
#*
#*! ####################################################################################################################
$FIN
  Unlock FAS246G
Return

#** ####################################################################################################################
#*
#* SubProg    : IMPRIME
#* Purpose    : called just before the printing of the document by Crystal Reports
#*
#* Parameters :
#*   @param count  : value integer          - number of parameters
#*   @param params : variable char()(1 .. ) - parameters grid
#*
#*! ####################################################################################################################
Subprog IMPRIME(COUNT, PARAMS)
  Value Integer COUNT
  Variable Char PARAMS()(1 .. )
  Local Char PARAM(255)
  Local Char CPY(GLONCPY) : # FQ102999 5->GLONCPY
  Local Char FCY(GLONFCY) : # FQ102999 5->GLONFCY
  Local Char CODFLX(5)
  Local Char REFSTR(20)
  Local Char REFEND(20)
  Local Date DATSTR
  Local Date DATEND
  Local Integer TYP
  Local Integer PLAN
  Local Integer I

  GOK = 0

  # lock the FAS246G object
  Lock FAS246G With lockwait = 3
  If fstat Then
    # message: Required resource is locked by another process
    Call ECR_TRACE(mess(00206,09137,1), 1) From GESECRAN
    End
  Endif

  CPY    = func GET_PARAM("cpy",    PARAMS, COUNT)
  PARAM  = func GET_PARAM("datstr", PARAMS, COUNT)
  DATSTR = gdat$(PARAM)
  PARAM  = func GET_PARAM("datend", PARAMS, COUNT)
  DATEND = gdat$(PARAM)
  PARAM  = func GET_PARAM("typper", PARAMS, COUNT)
  TYP = val(PARAM)

  # open tables
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS]) = 0 Then : Local File FISCYEAR [FIS] : Endif

  Link [CNX] With [FIS]FIY0 = [F:CNX]CPY;[F:CNX]CNX
&   As [LNK]
&   Where [F:CNX]CPY = [L]CPY
&   Order By [F:FIS]DATSTRFIY
  For [LNK]
    If TYP = 1 Then
      # fiscal year
      If [L]DATSTR = [F:FIS]DATSTRFIY and [L]DATEND = [F:FIS]DATENDFIY Then
        GOK = 1
      Endif
    Else
      # periods
      For I = 0 To [F:FIS]NBRPER
        If [L]DATSTR = [F:FIS]DATSTRPER(I) and [L]DATEND = [F:FIS]DATENDPER(I) Then
          GOK = 1
        Endif
      Next I
    Endif
  Next

  # close tables
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif
  If clalev([F:FIS]) <> 0 Then : Close Local File [FIS] : Endif

  If GOK = 0 Then
    Call ECR_TRACE(mess(1010,2299,1), 1) From GESECRAN
  Else
    Call EMPTY_TEMPORARY_TABLE()
    FCY    = func GET_PARAM("fcy",    PARAMS, COUNT)
    CODFLX = func GET_PARAM("codflx", PARAMS, COUNT)
    PARAM  = func GET_PARAM("plan",   PARAMS, COUNT)
    REFSTR = func GET_PARAM("refstr", PARAMS, COUNT)
    REFEND = func GET_PARAM("refend", PARAMS, COUNT)
    PLAN = val(PARAM)
    Call COLLECT_DATA(CPY, FCY, CODFLX, PLAN, TYP, DATSTR, DATEND, REFSTR, REFEND)
  Endif
End

#** ####################################################################################################################
#*
#* FunProg    : get_param
#* Purpose    : obtain the value of a parameter
#* Return     : char() - empty if the parameter is missing
#*
#* Parameters :
#*   @param name   : value char()           - parameter name
#*   @param params : variable char()(1 .. ) - parameters grid
#*   @param count  : value integer          - number of parameters
#*
#*! ####################################################################################################################
Funprog GET_PARAM(NAME, PARAMS, COUNT)
  Value Char NAME()
  Variable Char PARAMS()(1 .. )
  Value Integer COUNT
  Local Integer N
  Local Integer I

  N = len(NAME)
  For I = 1 To COUNT
    If left$(PARAMS(I), N + 1) = (NAME + "=") Then
      End right$(PARAMS(I), N + 2)
    Endif
  Next
End ""

#** ####################################################################################################################
#*
#* SubProg    : collect_data
#* Purpose    : collects the data
#*
#* Parameters :
#*   @param company : value char()  - the company ID
#*   @param codflux : value char()  - flux code
#*   @param plan    : value integer - the plan
#*   @param typper  : value integer - period type
#*   @param datstr  : value date    - start date
#*   @param datend  : value date    - end date
#*   @param refstr  : value char()  - start asset ID
#*   @param refend  : value char()  - end asset ID
#*
#*! ####################################################################################################################
Subprog COLLECT_DATA(COMPANY, SITE, CODFLUX, PLAN, TYPPER, DATSTR, DATEND, REFSTR, REFEND)
  Value Char COMPANY()
  Value Char SITE()
  Value Char CODFLUX()
  Value Integer PLAN
  Value Integer TYPPER
  Value Date DATSTR
  Value Date DATEND
  Value Char REFSTR()
  Value Char REFEND()

  # open tables
  If clalev([F:T246]) = 0 Then : Local File TMPFAS246G [T246] : Endif
  If clalev([F:FLU]) = 0  Then : Local File FXDLIFL    [FLU]  : Endif
  If clalev([F:FAS]) = 0  Then : Local File FXDASSETS  [FAS]  : Endif
  If clalev([F:PFL]) = 0  Then : Local File PARFLUX    [PFL]  : Endif
  If clalev([F:DEP]) = 0  Then : Local File DEPREC     [DEP]  : Endif
  If clalev([F:GAC]) = 0  Then : Local File GACCOUNT   [GAC]  : Endif
  If clalev([F:CNX]) = 0  Then : Local File CONTEXT    [CNX]  : Endif

  If TYPPER = 1 Then
    # fiscal year
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [PFL]PFL0 = [F:FLU]CODTXS;[F:FLU]COA;[F:FLU]TXSCAT,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]FIYENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  CODFLUX
&       and [F:FLU]AASREF    >= REFSTR
&       and [F:FLU]AASREF    <= REFEND
&       and [F:FLU]FIYSTRDAT =  DATSTR
&       and [F:FLU]FIYENDDAT =  DATEND
&       and [F:FLU]PERSTRDAT =  [0/0/0]
&       and [F:FLU]PERENDDAT =  [0/0/0]
&     Order By [F:FLU]TXSCAT;[F:FLU]GAC;[F:FLU]AASREF
  Else
    # periods
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [PFL]PFL0 = [F:FLU]CODTXS;[F:FLU]COA;[F:FLU]TXSCAT,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]PERENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       =  COMPANY
&       and [F:FLU]DPRPLN    =  PLAN
&       and [F:FLU]CODTXS    =  CODFLUX
&       and [F:FLU]AASREF    >= REFSTR
&       and [F:FLU]AASREF    <= REFEND
&       and [F:FLU]PERSTRDAT =  DATSTR
&       and [F:FLU]PERENDDAT =  DATEND
&     Order By [F:FLU]TXSCAT;[F:FLU]GAC;[F:FLU]AASREF
  Endif

  If SITE <> "" Then
    Filter [LNK] Where [F:FLU]FCY = SITE
  Endif

  Call DEBTRANS() From GLOCK
  Trbegin [T246], [FLU], [FAS], [PFL], [DEP], [GAC], [CNX]
  # main loop
  For [LNK]
    Raz [T246]

    # collect data
    [F:T246]CPY    = [F:FLU]CPY
    [F:T246]FCY    = [F:FLU]FCY
    [F:T246]CNX    = [F:FLU]CNX
    [F:T246]COA    = [F:FLU]COA
    [F:T246]GAC    = [F:FLU]GAC
    [F:T246]AASREF = [F:FLU]AASREF
    [F:T246]CODTXS = [F:FLU]CODTXS
    [F:T246]POSTXS = [F:FLU]TXSCAT
    [F:T246]DPRPLN = [F:FLU]DPRPLN
    [F:T246]DATSTR = DATSTR
    [F:T246]DATEND = DATEND
    [F:T246]BASSTR = [F:FLU]BSEVALSTR

### START ###
    If [F:FLU]RVAAMT <> 0 Then
      [F:T246]DPRSTR  = [F:FLU]RVAAMT - [F:FLU]INCBUY
      [F:T246]NETSTR  = [F:T246]BASSTR - [F:T246]DPRSTR
      [F:T246]BASDISP = [F:T246]DPRSTR
      [F:T246]DPRDSP  = -[F:T246]DPRSTR
      If [F:FLU]RVAAMT < 0 Then
        [F:T246]BASDEC = -[F:FLU]RVAAMT
      Else
        [F:T246]BASINC = [F:FLU]RVAAMT
      Endif
    Else
      [F:T246]DPRSTR  = [F:FLU]DPRCUMSTR
      [F:T246]NETSTR  = [F:T246]BASSTR - [F:T246]DPRSTR
      [F:T246]BASADDN = [F:FLU]INCBUY
      [F:T246]BASDISP = [F:FLU]DCRSAL
      If [F:FLU]TXSCATORI <> "" or [F:FLU]FCYORI <> "" Then
        [F:T246]TRFVAL = [F:FLU]INCTRF
        [F:T246]DPRDSP = [F:FLU]INCDPRTRF
      Else
        [F:T246]TRFVAL = -[F:FLU]DCRTRF
        [F:T246]DPRDSP = -([F:FLU]DCRDPEOUT + [F:FLU]DCRDPRTRF)
      Endif
    Endif
###  END  ###

    [F:T246]DPRCUM = [F:FLU]DPE + [F:FLU]EXCDPR
    [F:T246]BASEND = [F:T246]BASSTR + [F:T246]BASADDN - [F:T246]BASDISP + [F:T246]TRFVAL - [F:T246]BASDEC + [F:T246]BASINC
    [F:T246]DPREND = [F:T246]DPRSTR + [F:T246]DPRCUM + [F:T246]DPRDSP
    [F:T246]NETEND = [F:T246]BASEND - [F:T246]DPREND
    [F:T246]NETVAL = [F:T246]BASADDN - [F:T246]BASDISP + [F:T246]TRFVAL - [F:T246]DPRCUM - [F:T246]DPRDSP - [F:T246]BASDEC + [F:T246]BASINC
    [F:T246]CREUSR  = GUSER
    [F:T246]CREDAT  = date$

    Write [F:T246]
    If fstat <> 0 Then
      GOK = 0
      Call FSTA("T246") From GLOCK
      Break
    Endif
  Next
  If GOK = 0 Then
    Rollback
    # message: Rollback following error in transaction
    Call ECR_TRACE(mess(17,107,1), 1) From GESECRAN
  Else
    Commit
  Endif

  # close tables
  If clalev([F:T246]) <> 0 Then : Close Local File [T246] : Endif
  If clalev([F:FLU]) <> 0  Then : Close Local File [FLU]  : Endif
  If clalev([F:FAS]) <> 0  Then : Close Local File [FAS]  : Endif
  If clalev([F:PFL]) <> 0  Then : Close Local File [PFL]  : Endif
  If clalev([F:DEP]) <> 0  Then : Close Local File [DEP]  : Endif
  If clalev([F:GAC]) <> 0  Then : Close Local File [GAC]  : Endif
  If clalev([F:CNX]) <> 0  Then : Close Local File [CNX]  : Endif
End

#** ####################################################################################################################
#*
#* SubProg    : empty_temporary_table
#* Purpose    : clean-up the temporary table
#*
#*! ####################################################################################################################
Subprog EMPTY_TEMPORARY_TABLE()
  If clalev([F:T246]) = 0 Then : Local File TMPFAS246G [T246] : Endif
  Trbegin [T246]
  Delete [T246] Where CREUSR = GUSER # and CREDAT < date$
  If fstat = 1 Then
    Rollback
    # message: Problem in deleting the temporary file
    Call ECR_TRACE(mess(155,197,1), 1) From GESECRAN
    #
    # no need to stop the process at this point
    #
  Else
    Commit
  Endif
  If clalev([F:T246]) <> 0 Then : Close Local File [T246] : Endif
End

