#<AdxTL>@(#)12.0.0.0 $Revision$
#################################################################################################
# Actions called from the process "AIMP3" : to print in batch DCLVATDEB1 DCLVATENC1
#################################################################################################
# Issue X3-67186 - 2018-02-12 by MDJ : No record returned if AREPORTM empty
# Issue X3-74646 - 2018-02-05 by FHA : UK VAT Vat Box management

$ACTION
Case ACTION
 When "FICHIER"     : Gosub FICHIER
Endcase
Return

#################################################################################################
## Set the Crystal report's parameters "_FormatExport" and "_ExportFile"
$FICHIER
If !GSERVEUR : Return : Endif

Local Char    CHEMINCLI(250), RPTEXT(4), NAM_PRT(GLONADP)
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

# To give file extension to the file created by Crystal Report
Call PARAM(GFCYSOC,"VATRPTBAT",NAM_PRT) From ADOVAL
Read [AIM]AIM0=NAM_PRT

NBPAR += 1
PARAMETRE(NBPAR) = "_FormatExport="+chr$(1)+num$([F:AIM]PRTFMT)

Case [F:AIM]PRTFMT
 When 1:        RPTEXT=".rpt"
 When 3:        RPTEXT=".doc"
 When 5:        RPTEXT=".rtf"
 When 9, 10:    RPTEXT=".txt"
 When 27, 28:   RPTEXT=".xls"
 When 29:       RPTEXT=".pdf"
 When Default : RPTEXT=""
Endcase

Call PARAMUTIL("VATRPTDIR",CHEMINCLI,GUSER,"") From SUBAUS
NBPAR += 1
PARAMETRE(NBPAR) = "_ExportFile="+chr$(1)+CHEMINCLI+[L]ETAT+"_"+TBVAL(1)+[L]RPTEXT

# Mandatory.
# To avoid the process AIMP3 to set a value to the file name
OK = 0

Return

#################################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:TVB])=0 : Local File TABVACBPR  [TVB] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif

Local Char    SOCIETE(GLONCPY) , SOC(GLONCPY)
Local Char    ETAT(GLONARP) , TYP_ETAT(GLONARP)
Local Char    RACINE(10) , VALEUR(30) , PARAM(50) , PARAM2(50)
Local Integer NBSOC , ISOC , JSOC , IPER , JPER, K
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer NBRLEG
Local Char    TABLEG(GLONADI)(1..GNBSOC)
Local Integer NUMREQ, STAT
Local Char VALPAR(GLONADW), P(250)
Local Decimal TSD

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K : ETAT = left$(ETAT,K-1) : Endif
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????" : TYP_ETAT = ETAT : Endif


Case TYP_ETAT

 When "CONTVAPCE"

    Call IMPRIME(NBPAR,PARAMETRE) From CPTRPT
    If GOK<1 : End : Endif

    Local Char VALEUR(200)
    Local Char SOCIETE(GLONCPY), SOCREF(GLONCPY)
    Local Char TYPREF(1)

    Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT

    Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
    If [F:CPY]CPYLEGFLG=2
     SOCREF = SOCIETE
    Else
     Filter [FGR] Where CPY=SOCIETE
     Read [FGR]FGR0 First
     Filter [FGR]
     Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
     SOCREF = [F:FCY]LEGCPY
    Endif

    Call SETMAINREF(SOCREF,GTYPGEN,GTYPANA) From CPTDIV
    [L]TYPREF = num$(GTYPGEN)
    Call SETPARAM("referentiel",NBPAR,PARAMETRE,TYPREF) From ETAT


 When "DCLVATDEB1","DCLVATDEB2"
    If clalev([F:DLV])=0 : Local File DCLVAT  [DLV] : Endif
    Call GETPARAM("numrpt",NBPAR,PARAMETRE,PARAM) From ETAT

    # The reprinting is based on the records already created in the table AREPORTM
    # or (X3-67186) the reprinting creates records in the table AREPORTM if they don't exist yet (old versions)
    # The printing creates a record in the table AREPORTM

    #*X3-67186  If TYP_ETAT="DCLVATDEB1"
    NUMREQ = val(PARAM)

    If TYP_ETAT="DCLVATDEB2"
      # the variable ETAT must contains the original report code of the déclaration: DCLVATDEB1
      Call GETPARAM("etattva",NBPAR,PARAMETRE,ETAT) From ETAT
    Endif

    #*X3-67186
    # Search for records in AREPORTM: if not existing,  records are added.
    Filter [ARM] Where NUMREQ=[L]NUMREQ and RPTCOD = ETAT
      Read [ARM]ARM0 First
      If fstat <> 0
        Filter [DLV] Where NUMRPT=NUMREQ
        NBSOC = 0
        For [DLV]DLV0(1)
          NBSOC += 1
          TBSOC(NBSOC) = [F:DLV]CPY
        Next
        Filter [DLV]
        Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV
        Call DEBTRANS From GLOCK
        Gosub TRT_GTE From RPTLEG
        Gosub TRT_TVB From RPTLEG
        Gosub TRT_TVT From RPTLEG
       Endif
       Filter [ARM]
     #Endif
     #*X3-67186 END

 When "DCLVATENC1","DCLVATENC2"
    If clalev([F:DVP])=0 : Local File DCLVATPAY  [DVP] : Endif
    Call GETPARAM("numrpt",NBPAR,PARAMETRE,PARAM) From ETAT
    # The reprinting bases on the record already created in the table AREPORTM
    # The printing creates a record in the table AREPORTM
    If TYP_ETAT="DCLVATENC1"
     NUMREQ = val(PARAM)
     Filter [DVP] Where NUMRPT=NUMREQ
     NBSOC = 0
     For [DVP]DVP0(1)
      NBSOC += 1
      TBSOC(NBSOC) = [F:DVP]CPY
     Next
     Filter [DLV]
     Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV
     Call DEBTRANS From GLOCK
     K = 0
     Gosub TRT_TVB From RPTLEG
     Gosub TRT_TVT From RPTLEG
    Endif

 When "DCLCUSVATBEL1","DCLCUSVATBEL2"
    If !clalev([F:DLCB])   : Local File DCLCUSVATBE   [DLCB]   : Endif

    Call GETPARAM("numrpt", NBPAR, PARAMETRE, P) From ETAT
    NUMREQ = val(P)

    Filter [DLCB] Where NUMRPT=[L]NUMREQ
    Read [DLCB] First
    Filter [DLCB]

    Call PARAML([F:DLCB]CPY, "BELCUSTSD", VALPAR) From ADOVAL

    Call SETCUR(1,[F:DLCB]CPY,GLOCALDEV)From CPTDIV
    [L]TSD = val(VALPAR)
    If GLOCALDEV<>GCURSHR
     Call CONVERT(GCURSHR,GLOCALDEV,GLOCALDEV,GTYPCURSHR,[F:DLCB]ENDDAT,[L]TSD,[L]TSD,STAT) From TRTDEV
    Endif
    VALPAR = num$([L]TSD)
    Call SETPARAM("seuil", NBPAR, PARAMETRE, VALPAR) From ETAT
 When "DCLVATBOXDEB2", "DCLVATBOXPAY2"
    Local Char CRITBOX(100)
    Local Char WDCLFNCORI(12)                                 :# Issue X3-74646
    # Reprinting the french vat based on the VAT boxes.
    # Search the company criteria entered when the french vat was printed.
    # If all values of the CPY field are the same in DCLVATBOXH, the criteria was all company
    # Else the criteria was the value of CPY
    If !clalev([F:DLVB]) : Local File DCLVATBOXH   [DLVB] : Endif
    Call GETPARAM("numrpt",NBPAR,PARAMETRE,PARAM) From ETAT
    NUMREQ = val(PARAM)
    If ETAT="DCLVATBOXDEB2" : CRITBOX = "DCLVATTYP=1" : Endif
    If ETAT="DCLVATBOXPAY2" : CRITBOX = "DCLVATTYP=2" : Endif
    Raz SOC, K
    Raz [L]WDCLFNCORI                                         :# Issue X3-74646
    For [DLVB]DLVB0(4) Where NUMRPT=NUMREQ & evalue(CRITBOX)
     [L]WDCLFNCORI=[F:DLVB]VATFNC                             :# Issue X3-74646
     If SOC =""
      SOC = [F:DLVB]CPY
     Elsif SOC<>"" & SOC<>[F:DLVB]CPY
      K = 1 : # Many companies => criteria All company
      Break
     Endif
    Next
    If !K
     Call SETPARAM("societe",NBPAR,PARAMETRE,SOC) From ETAT
    Endif
    # Issue X3-74646
    Raz PARAM
    Call GETPARAM("dclfncori",NBPAR,PARAMETRE,PARAM) From ETAT
    If PARAM <> [L]WDCLFNCORI & [L]WDCLFNCORI<>""
      PARAM = [L]WDCLFNCORI
    Endif
    If PARAM<>""
      PARAM=toupper(PARAM)
      Call SETPARAM("dclfncori",NBPAR,PARAMETRE,PARAM) From ETAT
    Endif
    # End issue X3-74646
Endcase
End

