##########################################################################################################
$BOUTON
#Case BOUT
#    When "A"
#        VALEUR = [M:CCN5]BPRNUM(GCCN5NOL)
#        FIN = 1
#    When Default
#Endcase

Case BOUT
    When "A"
        If (nolign-1)>=0
            If [M:CCN5]BPRNUM(nolign-1)<>""
                VALEUR = [M:CCN5]BPRNUM(nolign-1)
                FIN = 1
                mkstat=99
            Endif
        Endif
    When "C"
        Gosub ONLOAD
    When Default
Endcase

Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
#$ONOK
#VALEUR = [M:CCN5]BPRNUM(GCCN5NOL)
#mkstat = 4
#Return





##########################################################################################################
$ONLOAD

Local Char SZWHERE (250)(20)
Raz SZWHERE
Local Integer ILIGNEWHERE
ILIGNEWHERE=0
Local Char SZAND
Raz SZAND
Local Char SZVALEUR (100)
Raz SZVALEUR
Local Char SZRECHERCHE (100)
Raz SZRECHERCHE

Local Integer IBNONVIDE
IBNONVIDE=0
Local Integer ILIGNE
ILIGNE = 0

Local Integer INBLIGNETOTAL
INBLIGNETOTAL=0

#Raz [M:CCN5]NBREC
#Raz [M:CCN5]NAM
#Raz [M:CCN5]ZIP
#Raz [M:CCN5]CTY
#Raz [M:CCN5]TEL
#Raz [M:CCN5]CRY
#Raz [M:CCN5]BPRNUM

Effzo [M:CCN5]15
[M:CCN5]NBREC=0


If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif

#Il faut créer le link
Link [BPA] With [BPR] BPR0=[F:BPA]BPANUM  As [BPRA] Where [F:BPR]BPRNUM<>"" and [F:BPA]BPATYP=1


#Recherche de Tiers
If GFONCTION = "GESBPR"
# Pas de restriction
Endif

#Recherche de Prospect
If GFONCTION = "GESBPP"
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPR]PPTFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

#Recherche de Client
If GFONCTION = "GESBPC"
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPR]BPCFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

#Recherche de Fournisseurs
If GFONCTION = "GESBPS"
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPR]BPSFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

#Recherche de Transporteurs
If GFONCTION = "GESBPT"
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPR]BPTFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

#Recherche de Représentants
If GFONCTION = "GESREP"
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPR]REPFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif


If [M:CCN5]BPRNAM<>""
    SZVALEUR=[M:CCN5]BPRNAM
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPR]BPRNAM)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:CCN5]BPRZIP<>""
    SZVALEUR=[M:CCN5]BPRZIP
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPA]POSCOD)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:CCN5]BPRCTY<>""
    SZVALEUR=[M:CCN5]BPRCTY
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPA]CTY)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:CCN5]BPRADEDEF=2
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPA]BPAADDFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

ILIGNE=0
While ILIGNE< ILIGNEWHERE
    If SZWHERE <>""
        IBNONVIDE=1
    Endif
    ILIGNE=ILIGNE+1
Wend


If IBNONVIDE=1
    Filter  [BPRA] Where evalue (SZWHERE ) Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
Else
    Filter  [BPRA] Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
Endif

INBLIGNETOTAL=rowcount([BPRA])
ILIGNE=0
For [BPRA]
    If ILIGNE >= dim([M:CCN5]NAM) - 1 : Break : Endif
    If [F:BPA]BPANUM<>""

        [M:CCN5]BPRNUM(ILIGNE) = [F:BPR]BPRNUM

        [M:CCN5]NAM(ILIGNE) = [F:BPR]BPRNAM
        [M:CCN5]ZIP(ILIGNE) = [F:BPA]POSCOD
        [M:CCN5]CTY(ILIGNE) = [F:BPA]CTY
        [M:CCN5]TEL(ILIGNE) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        [M:CCN5]CRY(ILIGNE) = [F:BPA]CRY

        [M:CCN5]BPAADDFLG(ILIGNE) = [F:BPA]BPAADDFLG
        [M:CCN5]BPADES(ILIGNE) = [F:BPA]BPADES

        ILIGNE += 1
    Endif
Next

Filter [BPRA]

[M:CCN5]NBREC = ILIGNE

Affzo [M:CCN5]1-99

If ILIGNE<INBLIGNETOTAL
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963, 182, 2)
    GERR = 2
Endif


Return

