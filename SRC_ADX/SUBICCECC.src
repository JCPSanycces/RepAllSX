######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If dim([M]ECCVALMAJ)<0 : End : Endif

# Versions number are certainly different from between all items
Effzo [M:DIA]ECCVALMAJ, ECCVALMIN

Call ECCAFF(VALEUR,"DIA") From SUBICDECC

End

Subprog AM_TOUS(VALEUR)
Variable Integer VALEUR
If dim([M]ECCVALMAJ)<0 : End : Endif

# fields will be activated if necessary on ITMREF modification
Diszo [M:DIA]ECCVALMAJ, ECCVALMIN
Effzo [M:DIA]ECCVALMAJ, ECCVALMIN
End

