#<AdxTL>@(#)7.0.0.0 $Revision$ 
###############################################################
## AGENXSD    Génération du traitement des WEB services       ##
###############################################################
###############################################################

Raz GPILOBJ , GNBMASKOUV
Call OBJET("AWE",GBIDC1,GBIDC2) From GOBJET
End


$GENXSD
#If GUSER="CCORA" : Dbgaff : Endif
If clalev([F:A_TX])=0 : Local File =APPLI+".ATEXTE"  [A_TX] : Endif
If clalev([F:A_ST])=0 : Local File =APPLI+".APLSTD"  [A_ST] : Endif
If clalev([F:A_XX])=0 : Local File =APPLI+".ATEXTRA" [A_XX] : Endif



Call GLOBWEB(APPLI) From INTRUTILA

# Création de la table iso des codes langues
Local Integer IISO,JK
Local Char NAMCH(30)
Local Char TLANISO(10)(1..GI_NBLAN)
If clalev([F:T_LA])=0 : Local File =APPLI+".TABLAN" [T_LA] : Endif
If clalev([F:A_XX])=0 : Local File =APPLI+".ATEXTRA" [A_XX] : Endif
If clalev([F:A_ST])=0 : Local File =APPLI+".APLSTD"  [A_ST] : Endif

For IISO=1 To GI_NBLAN
  Read [T_LA]TLA0=GI_LLAN(IISO)
  If fstat=0 and [F:T_LA]LANISO<>"" and instr(1,[F:T_LA]LANISO,"_")<>0
    TLANISO(IISO)=left$([F:T_LA]LANISO,instr(1,[F:T_LA]LANISO,"_")-1) 
  Else
    TLANISO(IISO)=GI_LLAN(IISO)
  Endif
Next IISO



# Ouverture du fichier résultat
Local Char DIRSEP, NOMFIC(200),VALL1(250),NAMFILE
Local Char PROP(100),VALP(100),VALLM(100),ACOD1
Local Integer RES,TCODAGE
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

NAMFILE=PUBLI
#  Voir pour créer un type spécial si ATYPOBJ=3 pour écrire sur le répertoire des import/export
NOMFIC = func NOMFIC(APPLI,NAMFILE)

Call GLOBWEB(APPLI) From INTRUTILA
# GI_LLAN   : langues à utiliser pour la génération
# GI_NBLAN  : nombre de langues du dossier

Local Integer ECBLOCXS



Openo NOMFIC,0 Using [XSD_]
Iomode adxifs ""  Using [XSD_]
Iomode adxirs chr$(10)  Using [XSD_]
#  Le codage est passé pour les XSD export sinon par défaut c'est de l'utf-8
#  TCODAGE donne dans ce cas la valeur : 1 ascii  GASCII : 2 utf8 GUTF8 : 3 ucs2 GUCS2
ACOD1="utf-8" : TCODAGE=GUTF8
If dim(ACODAGE)>0 and ACODAGE>=1 and ACODAGE<=3 
    Case ACODAGE
    When 1 : TCODAGE=GASCII : ACOD1=ENCODING
    When 3 : TCODAGE=GUCS2 : ACOD1=mess(ACODAGE,945,1)
  Endcase
Endif     

Iomode adxium TCODAGE  Using [XSD_]
#  Ecriture du fichier XSD

Wrseq '<?xml version="1.0" encoding="'+ACOD1+'" ?>' Using [XSD_]
#Wrseq '<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">' Using [XSD_]
#VALL1='<xs:schema targetNamespace="http://com.sage/X3/'+PUBLI
#VALL1+='" xmlns:xs="http://www.w3.org/2001/XMLSchema"'
#VALL1+=' xmlns="http://com.sage/X3/'+PUBLI+'">'
#Wrseq VALL1 Using [XSD_]
VALL1='<xs:schema '
VALL1+='xmlns:xs="http://www.w3.org/2001/XMLSchema"'
VALL1+=' xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"'
VALL1+=' xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"'
VALL1+=' xmlns="http://com.sage/X3/'+PUBLI+'"'
Wrseq VALL1 Using [XSD_]
VALL1 =' jaxb:version="2.0"'
VALL1+=' targetNamespace="http://com.sage/X3/'+PUBLI+'">'
Wrseq VALL1 Using [XSD_]

#  ---- Nouvelle structure des annotations  --  CC   08/03/2010

Gosub VERGEN From AGENWEB
If ATYPOBJ=3
  Local Char HORDAT(14)
  Call ENVVAR(HORDAT) From INTRUTILA
Endif

Wrseq '<xs:annotation>' Using [XSD_]
If ATYPOBJ=1
  VALL1='Web Service Object "'+PUBLI+'" defined in"'+GINSTID+'+'+APPLI+'"'
Elsif ATYPOBJ=2
  VALL1='Web Service Subprogram"'+PUBLI+'" defined in"'+GINSTID+'+'+APPLI+'"'
Elsif ATYPOBJ=3
  VALL1='Import/Export Model "'+PUBLI+'" defined in"'+GINSTID+'+'+APPLI+'"'
Endif
Wrseq '<xs:documentation xml:lang="'+"en"+'">'+VALL1+'</xs:documentation>' Using [XSD_]
Wrseq '<xs:appinfo>' Using [XSD_]
VALL1='<jaxb:globalBindings typesafeEnumMemberName="generateError"'
VALL1+=' underscoreBinding="asCharInWord">'
Wrseq VALL1 Using [XSD_]
#VALL1='  <jaxb:javaType name="java.util.Date" xmlType="xs:date"/>'
#Wrseq VALL1 Using [XSD_]
VALL1='</jaxb:globalBindings>'
Wrseq VALL1 Using [XSD_]
VALL1='<sx3:schemainfos'
VALL1+= ' xmlns:sx3="http://com.sage/safex3/schema/infos"'
VALL1+= ' xsi:schemaLocation="http://com.sage/safex3/schema/infos safex3_schema_infos.xsd">'
Wrseq VALL1 Using [XSD_]

Wrseq '<webservice>' Using [XSD_]
Wrseq '<publicname>'+PUBLI+'</publicname>' Using [XSD_]
If ATYPOBJ=1
  Wrseq '<wsobject>' Using [XSD_]
  Wrseq '<id>'+OBJET+'</id>' Using [XSD_]
  Wrseq '<transaction>'+VARIANTE+'</transaction>' Using [XSD_]
  Wrseq '<window>'+[F:A_WI]WIN+'</window>' Using [XSD_]
  Wrseq '</wsobject>' Using [XSD_]
Elsif ATYPOBJ=2
  Wrseq '<wssubprogram>' Using [XSD_]
  Wrseq '<program>'+PRG+'</program>' Using [XSD_]
  Wrseq '<subprogram>'+SUBPRG+'</subprogram>' Using [XSD_]
  Wrseq '</wssubprogram>' Using [XSD_]
Elsif ATYPOBJ=3
  Wrseq '<wsimport>' Using [XSD_]
  Wrseq '<model>'+MODELE+'</model>' Using [XSD_]
  Wrseq '</wsimport>' Using [XSD_]
Endif

If ATYPOBJ<>3
  Wrseq '<wrapper>'+'WJ'+PUBLI+'</wrapper>' Using [XSD_]
Else
  Wrseq '<wrapper>'+'</wrapper>' Using [XSD_]
Endif
Wrseq '<timestamp>'+HORDAT+'</timestamp>' Using [XSD_]
Wrseq '<generatorvers>'+VERGEN+'</generatorvers>' Using [XSD_]
Wrseq '</webservice>' Using [XSD_]
Wrseq '<x3folder>'+APPLI+'</x3folder>' Using [XSD_]
Wrseq '<x3solution>'+GINSTID+'</x3solution>' Using [XSD_]
Wrseq '</sx3:schemainfos>' Using [XSD_]
Wrseq '</xs:appinfo>' Using [XSD_]
Wrseq '</xs:annotation>' Using [XSD_]


Goto SUITDOCCC

# ----- Ancienne mouture a conserver avant mise au point finale ------------------------------

Wrseq '<xs:annotation>' Using [XSD_]
Wrseq '<xs:documentation>'+'Infos'+'</xs:documentation>' Using [XSD_]
If ATYPOBJ=1
  Wrseq '<xs:documentation>'+PUBLI-[F:A_WI]WIN-OBJET-VARIANTE-HORDAT+'</xs:documentation>' Using [XSD_]
Elsif ATYPOBJ=2
  Wrseq '<xs:documentation>'+PUBLI-PRG-SUBPRG-HORDAT+'</xs:documentation>' Using [XSD_]
Elsif ATYPOBJ=3
  Local Char HORDAT(14)
  Call ENVVAR(HORDAT) From INTRUTILA
  Wrseq '<xs:documentation>'+PUBLI-'Import/Export model'-HORDAT+'</xs:documentation>' Using [XSD_]
Endif
Gosub VERGEN From AGENWEB
Wrseq '<xs:documentation>'+APPLI-GINSTID-VERGEN+'</xs:documentation>' Using [XSD_]
Wrseq '</xs:annotation>' Using [XSD_]

$SUITDOCCC

# ---------------------------------------------------------------------------------------------

#  Traitement unitaire des groupes
#  On ne traite que les groupes de niveau 1 et on inclus les groupes imbriqués

#  Création de la table des niveaux
Local Integer TGNIV(1..100),TLIGNIV(1..100),NBGNIV,NIVMAX
Local Integer NIVCOU
Local Integer MSKCOU,BLCOU,IINTIT,MAXOCCURS
Local Char NAMBLCOU

For I=1 To [M:AWE2]NBLIG
 If [M:AWE2]SELECT(I-1)=2 
   If [M:AWE2]GROUPE(I-1)<>NAMBLCOU
     NAMBLCOU=[M:AWE2]GROUPE(I-1)
     NBGNIV+=1
     TLIGNIV(NBGNIV)=I
     TGNIV(NBGNIV)=[M:AWE2]NIVEAU(I-1)
     If [M:AWE2]NIVEAU(I-1)>NIVMAX : NIVMAX=[M:AWE2]NIVEAU(I-1) : Endif
   Endif
 Endif
Next I

Raz MSKCOU,BLCOU,NAMBLCOU
If ATYPOBJ<=2
  For I=1 To [M:AWE2]NBLIG
    If [M:AWE2]SELECT(I-1)=2 
      If [M:AWE2]NIVEAU(I-1)=1
        If [M:AWE2]GROUPE(I-1)<>NAMBLCOU
          If ATYPOBJ>=2 or (dim(DETBLC)>0 & DETBLC(MASQUE(I),BLOC(I))=0)
            If ATYPOBJ=1 : MSKCOU=MASQUE(I) : BLCOU=BLOC(I) : Endif 
            NAMBLCOU=[M:AWE2]GROUPE(I-1)
            Gosub ECRBLOCXS
          Endif
        Endif
        If ATYPOBJ=1 and DETBLC(MASQUE(I),BLOC(I))<>0 : Goto SUITCHPXS : Endif
        If ATYPOBJ=1 and TYPBLC(MSKCOU,BLCOU)=1 & PARAM(I)=BASTAB(MSKCOU,BLCOU) : Goto SUITCHPXS : Endif
        NAMCH=[M:AWE2]CHAMP(I-1)
        VALL1= '      <xs:element name="'+NAMCH+'" type="'+NAMCH+'" '
#    Obligatoire ou pas
        MAXOCCURS=1
        If ATYPOBJ=1 and TYPBLC(MSKCOU,BLCOU)<>1 and ATYPOBJ=1 and [M:AWE2]DIME(I-1)>1 : MAXOCCURS=[M:AWE2]DIME(I-1) : Endif
        If [M:AWE2]OBLIG(I-1)=2    : # Le champ est obligatoire
          VALL1+='minOccurs="1" maxOccurs="'
        Else
          VALL1+='minOccurs="0" maxOccurs="'
        Endif
        VALL1+=num$(MAXOCCURS)+'"/>'
        Wrseq VALL1  Using [XSD_]
      Endif
    Endif
 $SUITCHPXS
  Next I
  If ECBLOCXS=1 : Gosub FINBLOCKXS : Endif
# Groupe ADXTEC
  If ATYPOBJ<=2
    Wrseq '<xs:complexType name="'+"ADXTEC"+'">' Using [XSD_]
    Wrseq '    <xs:sequence>' Using [XSD_]
    Wrseq '      <xs:element name="'+'WW_MODSTAMP'+'" type="'+'WW_MODSTAMP'+'" minOccurs="1" maxOccurs="1"/>' Using [XSD_]
    Wrseq '      <xs:element name="'+'WW_MODUSER'+'" type="'+'WW_MODUSER'+'" minOccurs="1" maxOccurs="1"/>' Using [XSD_]
    Wrseq '    </xs:sequence>' Using [XSD_]
    Wrseq '</xs:complexType>' Using [XSD_]
  Endif
Elsif ATYPOBJ=3
  Raz MSKCOU,BLCOU,NAMBLCOU
  Local Char GRMAPX
  For J=1 To NBGNIV
   NAMBLCOU=[M:AWE2]GROUPE(TLIGNIV(J)-1)
   Gosub ECRBLOCIMP
   For I=TLIGNIV(J) To [M:AWE2]NBLIG
    If [M:AWE2]GROUPE(I-1)=NAMBLCOU
      If [M:AWE2]SELECT(I-1)=2 
        NAMCH=[M:AWE2]CHAMP(I-1)
        VALL1= '      <xs:element name="'+NAMCH+'" type="'+NAMCH+'" '
#    Obligatoire ou pas
        If [M:AWE2]OBLIG(I-1)=2    : # Le champ est obligatoire
          VALL1+='minOccurs="1" maxOccurs="1"/>'
        Else
          VALL1+='minOccurs="0" maxOccurs="1"/>'
        Endif
        Wrseq VALL1  Using [XSD_]
      Endif
    Else    
      If [M:AWE2]NIVEAU(I-1)<=TGNIV(J)
        Break 1
      Elsif [M:AWE2]NIVEAU(I-1)=TGNIV(J)+1
        If GRMAPX="" or GRMAPX<>[M:AWE2]GROUPE(I-1)
          GRMAPX=[M:AWE2]GROUPE(I-1)
          VALL1= '      <xs:element name="'+GRMAPX+'" type="'+GRMAPX+'" '
          If [M:AWE2]DIME(I-1)=9999
            VALL1+='minOccurs="'+'0'+'" maxOccurs="'+'unbounded'+'"/>'
          Else
            VALL1+='minOccurs="'+'0'+'" maxOccurs="'+num$([M:AWE2]DIME(I-1))+'"/>'
          Endif
          Wrseq VALL1  Using [XSD_]
        Endif 
     Endif
    Endif
   Next I
  Next J
  If ECBLOCXS=1 : Gosub FINBLOCKXS  : Endif
Endif


# Traitement de la liste gauche
If ATYPOBJ=1
  Wrseq '<xs:complexType name="'+"LEFTLIST"+'">' Using [XSD_]
  Wrseq '  <xs:annotation>' Using [XSD_]
  Wrseq '    <xs:documentation xml:lang="en">'+'Query Result'+'</xs:documentation>' Using [XSD_]
  Wrseq '  </xs:annotation>' Using [XSD_]
  Wrseq '  <xs:sequence>' Using [XSD_]
  Local Integer CREST
  Read [A_OL]AOL0=OBJET
  If fstat=0
    CREST=1
    For I=1 To [F:A_OL]NBSEL
      VALP=[F:A_OL]SELZON(I-1)  : # Nom du champ
      If VALP="" : VALP="C"+num$(I) : Endif
      Wrseq '      <xs:element name="'+VALP+'" type="'+VALP+'" minOccurs="0" maxOccurs="1"/>' Using [XSD_]
    Next I
  Endif
  Wrseq '  </xs:sequence>' Using [XSD_]
  Wrseq '</xs:complexType>' Using [XSD_]
# On crée les simple type si il n'existe pas déjà
  If CREST=1
    Local Integer MENLEFTL,ILK,IILEFTLONG
    For I=1 To [F:A_OL]NBSEL
      VALP=[F:A_OL]SELZON(I-1)
      IILEFTLONG=0
      If VALP="" : VALP="C"+num$(I) : Endif
#   Recherche si la zone est déjà décrite
      ILK=find(VALP,[M:AWE2]CHAMP(0..[M:AWE2]NBLIG))
      If ILK=0 or [M:AWE2]SELECT(ILK-1)<>2
        If  [F:A_OL]SELFIC(I-1)<>"" and [F:A_OL]SELZON(I-1)<>""
          Read [A_TZ]CODZONE=[F:A_OL]SELFIC(I-1);[F:A_OL]SELZON(I-1)
          If fstat=0
            If [F:A_TZ]NOLIB<>0 : MENLEFTL=[F:A_TZ]NOLIB : Endif
          Endif
# On cherche une longueur soit sur la colonne soit sur le type de données
          If [F:A_TZ]LONG<>0 
            IILEFTLONG=[F:A_TZ]LONG
          Elsif [F:A_TZ]CODTYP<>"ATX" and [F:A_TZ]CODTYP<>"ATT"
            Read [A_TY]CODTYP=[F:A_TZ]CODTYP
            If fstat=0
              IILEFTLONG=[F:A_TY]LNGTYP        
            Endif
          Endif
        Endif
        Wrseq '<xs:simpleType name="'+VALP+'">' Using [XSD_]
        Wrseq '  <xs:annotation>' Using [XSD_]
        Wrseq '    <xs:documentation xml:lang="en">'+'LEFTLIST-'+VALP+'</xs:documentation>' Using [XSD_]
        If MENLEFTL<>0
          Wrseq '    <xs:documentation>Local Menu '+num$(MENLEFTL)+'</xs:documentation>' Using [XSD_]
        Endif
        Wrseq '  </xs:annotation>' Using [XSD_]
        Wrseq '    <xs:restriction base="xs:string">' Using [XSD_]
        If IILEFTLONG=0 
          If [F:A_OL]SELLNG(I-1)<>0
            IILEFTLONG=[F:A_OL]SELLNG(I-1)
          Else
            IILEFTLONG=30 
          Endif
        Endif
        Wrseq '      <xs:maxLength value="'+num$(IILEFTLONG)+'"/>' Using [XSD_]
        Wrseq '    </xs:restriction>' Using [XSD_]
        Wrseq '</xs:simpleType>' Using [XSD_]
      Endif
    Next I
  Endif
Endif

# Création du KEYS
If ATYPOBJ=1
  Wrseq '<xs:complexType name="'+"KEYS"+'">' Using [XSD_]
  Wrseq '  <xs:annotation>' Using [XSD_]
  Wrseq '    <xs:documentation xml:lang="en">'+'Object identification key'+'</xs:documentation>' Using [XSD_]
  Wrseq '  </xs:annotation>' Using [XSD_]
  Wrseq '  <xs:sequence>' Using [XSD_]
  Filter [A_TI] Where CODFIC=[F:A_OB]NOMFIC and NUMLIG=1
  For [A_TI]
    Local Char DESC1(100)
    DESC1=[F:A_TI]DESCRIPT
$CRECLT
    J=instr(1,DESC1,"+")
    If J>0
      VALP=left$(DESC1,J-1)
      Gosub CRESEQKEY
      DESC1=right$(DESC1,J+1)
      Goto CRECLT
    Else
      VALP=DESC1
      Gosub CRESEQKEY
    Endif
    Break 1
  Next
  Filter [A_TI]
  Wrseq '  </xs:sequence>' Using [XSD_]
  Wrseq '</xs:complexType>' Using [XSD_]
Endif

# Traitement de l'entité globale
Wrseq '<xs:element name="'+PUBLI+'">' Using [XSD_]
If ATYPOBJ<=2
 Wrseq '  <xs:annotation>' Using [XSD_]
 For indice=1 To GI_NBLAN
   Call LECTEXTRAL(VALLM ,"AWEBSERVIC","LIBW",PUBLI,"",GI_LLAN(indice))
   If VALLM="" : VALLM='Global entity' : Endif
   Gosub MVALC From INTRUTILA
   Wrseq '    <xs:documentation xml:lang="'+tolower(TLANISO(indice))+'">'+VALLM+'</xs:documentation>' Using [XSD_]
 Next indice
 Wrseq '  </xs:annotation>' Using [XSD_]
Endif
Wrseq '  <xs:complexType>' Using [XSD_]
If ATYPOBJ=1
  Wrseq '   <xs:choice>' Using [XSD_]
  Wrseq '    <xs:sequence>' Using [XSD_]
  Wrseq '    <xs:element name="LEFTLIST" type="LEFTLIST" minOccurs="0"  maxOccurs="unbounded"/>' Using [XSD_]
  Wrseq '    </xs:sequence>' Using [XSD_]

Endif

Wrseq '    <xs:sequence>' Using [XSD_]

#  Traitement de l'entité globale : on n'écrit que les groupes de niveau 1
Local Char MINOCC
MINOCC = ""
Raz MSKCOU,BLCOU,NAMBLCOU
For I=1 To [M:AWE2]NBLIG
 If [M:AWE2]SELECT(I-1)=2
  If [M:AWE2]GROUPE(I-1)<>NAMBLCOU and [M:AWE2]NIVEAU(I-1)=1 
    If ATYPOBJ=1 : MSKCOU=MASQUE(I) : BLCOU=BLOC(I): Endif 
    NAMBLCOU=[M:AWE2]GROUPE(I-1)
    If ATYPOBJ=2 or ATYPOBJ=3 or (dim(DETBLC)>0 & DETBLC(MSKCOU,BLCOU)=0)
     If ATYPOBJ=1 and TYPBLC(MSKCOU,BLCOU)=1  : #  Tableau
       NAMCH=[M:AWE2]CHAMP(I-1)
       Wrseq '      <xs:element name="'+NAMCH+'" type="'+NAMCH
&                  +'" minOccurs="'+'0'+'" maxOccurs="1"/>' Using [XSD_]
       If DIMTAB(MSKCOU,BLCOU)=9999
             Wrseq '      <xs:element name="'+[M:AWE2]GROUPE(I-1)+'" type="'+[M:AWE2]GROUPE(I-1) 
&                  +'" minOccurs="0"'+' maxOccurs="'+'unbounded'+'"/>' Using [XSD_]
       Else
             Wrseq '      <xs:element name="'+[M:AWE2]GROUPE(I-1)+'" type="'+[M:AWE2]GROUPE(I-1) 
&                  +'" minOccurs="0"'+' maxOccurs="'+num$(DIMTAB(MSKCOU,BLCOU))+'"/>' Using [XSD_]
       Endif
     Else
       If [M:AWE2]DIME(I-1)=9999
             Wrseq '      <xs:element name="'+[M:AWE2]GROUPE(I-1)+'" type="'+[M:AWE2]GROUPE(I-1) 
&                  +'" minOccurs="0"'+' maxOccurs="'+'unbounded'+'"/>' Using [XSD_]
       Else
             If dim(TYPBLC)<0 or TYPBLC(MSKCOU,BLCOU)=1
               Wrseq '      <xs:element name="'+[M:AWE2]GROUPE(I-1)+'" type="'+[M:AWE2]GROUPE(I-1) 
&                    +'" minOccurs="0"'+' maxOccurs="'+num$([M:AWE2]DIME(I-1))+'"/>' Using [XSD_]
             Else
               Wrseq '      <xs:element name="'+[M:AWE2]GROUPE(I-1)+'" type="'+[M:AWE2]GROUPE(I-1) 
&                    +'" minOccurs="0"'+' maxOccurs="'+"1"+'"/>' Using [XSD_]
             Endif
       Endif
     Endif
    Endif
  Endif
 Endif
Next I

If ATYPOBJ<=2
 Wrseq '      <xs:element name="'+'ADXTEC'+'" type="'+'ADXTEC'
&                  +'" minOccurs="'+'0'+'" maxOccurs="1"/>' Using [XSD_]
Endif
Wrseq '    </xs:sequence>' Using [XSD_]
If ATYPOBJ=1
  Wrseq '   </xs:choice>' Using [XSD_]
Endif
Wrseq '  </xs:complexType>' Using [XSD_]
Wrseq '</xs:element>' Using [XSD_]




# Traitement des élements
# On rajoute les éléments de ADXTEC
If ATYPOBJ<=2
  Wrseq '<xs:simpleType name="'+'WW_MODSTAMP'+'">' Using [XSD_]
  Wrseq '    <xs:restriction base="'+'xs:string'+'">' Using [XSD_]
  Wrseq '      <xs:maxLength value="'+'14'+'"/>' Using [XSD_]
  Wrseq '    </xs:restriction>' Using [XSD_]
  Wrseq '</xs:simpleType>' Using [XSD_]
  Wrseq '<xs:simpleType name="'+'WW_MODUSER'+'">' Using [XSD_]
  Wrseq '    <xs:restriction base="'+'xs:string'+'">' Using [XSD_]
  Wrseq '      <xs:maxLength value="'+'10'+'"/>' Using [XSD_]
  Wrseq '    </xs:restriction>' Using [XSD_]
  Wrseq '</xs:simpleType>' Using [XSD_]
Endif
Local Integer ILK
For I=1 To [M:AWE2]NBLIG
 If I>1
   ILK=find([M:AWE2]CHAMP(I-1),[M:AWE2]CHAMP(0..I-2))
 Endif
 If [M:AWE2]SELECT(I-1)=2 and ILK=0
  NAMCH=[M:AWE2]CHAMP(I-1)
  VALL1='<xs:simpleType name="'+NAMCH+'">'
  Wrseq VALL1 Using [XSD_]
  Wrseq '  <xs:annotation>' Using [XSD_]
  If [M:AWE2]NOLIB(I-1)<>0
    Wrseq '    <xs:documentation>Local Menu '+num$([M:AWE2]NOLIB(I-1))+'</xs:documentation>' Using [XSD_]
  Endif
  If [M:AWE2]NOTEX(I-1)<>0
    For indice=1 To GI_NBLAN
      Read [A_TX]NUMERO = GI_LLAN(indice);[M:AWE2]NOTEX(I-1)
      If fstat=0
        VALLM = [F:A_TX]TEXTE
        Gosub MVALC From INTRUTILA
        Wrseq '    <xs:documentation xml:lang="'+tolower(TLANISO(indice))+'">'+[M:AWE2]GRPCHP(I-1)+": "+VALLM+'</xs:documentation>' Using [XSD_]
      Endif
    Next indice
  Else
    If [M:AWE2]INTIT(I-1)<>""
      VALLM = [M:AWE2]INTIT(I-1)
      Gosub MVALC From INTRUTILA
      Wrseq '    <xs:documentation>'+[M:AWE2]GRPCHP(I-1)+": "+VALLM+'</xs:documentation>' Using [XSD_]
    Else
      Wrseq '    <xs:documentation>'+[M:AWE2]GRPCHP(I-1)+'</xs:documentation>' Using [XSD_]
    Endif
  Endif
  
  If [M:AWE2]NOLIB(I-1)>1
      Wrseq '      <xs:appinfo>' Using [XSD_]
      Wrseq '          <jaxb:typesafeEnumClass/>' Using [XSD_]
      Wrseq '      </xs:appinfo>' Using [XSD_]
  Endif
  Wrseq '  </xs:annotation>' Using [XSD_]
  If [M:AWE2]NOLIB(I-1)<=1
    Local Char TYPEDATA
    Case [M:AWE2]TYPPAR(I-1)
      When 1 : TYPEDATA="xs:string"
      When 2 : TYPEDATA="xs:int"
      When 3 : TYPEDATA="xs:decimal"
      When 4 : TYPEDATA="xs:date"
      When 7 : TYPEDATA="xs:base64Binary"  :  # A défaut de mieux
      When 6 : TYPEDATA="xs:string"  :  # A défaut de mieux
      When Default : TYPEDATA="xs:string"
    Endcase 

    If [M:AWE2]NOLIB(I-1)=1 
      TYPEDATA="xs:boolean" 
    Endif

    Local Integer RESTRICTOP
    Gosub ISRESTRICOP
    If [M:AWE2]LONG(I-1)<>0
        If [M:AWE2]TYPPAR(I-1)=1
          Wrseq '      <xs:maxLength value="'+num$([M:AWE2]LONG(I-1))+'"/>' Using [XSD_]
        Elsif [M:AWE2]TYPPAR(I-1)=6
          Local Decimal LL : 
          LL=512*2^[M:AWE2]LONG(I-1)-2
          Wrseq '      <xs:maxLength value="'+num$(LL)+'"/>' Using [XSD_]
        Elsif [M:AWE2]TYPPAR(I-1)=7
          Local Decimal LL : LL=1024*2^[M:AWE2]LONG(I-1)-4
          Wrseq '      <xs:maxLength value="'+num$(LL)+'"/>' Using [XSD_]
        Endif
    Endif
     If [M:AWE2]AUTMIN(I-1)=2
       Gosub ISRESTRICOP
       If [M:AWE2]MININCLU(I-1)=2
         Wrseq '<xs:minInclusive value="'+num$([M:AWE2]VALMIN(I-1))+'"/>' Using [XSD_]         
       Else
         Wrseq '<xs:minExclusive value="'+num$([M:AWE2]VALMIN(I-1))+'"/>' Using [XSD_]
       Endif
     Endif
     If [M:AWE2]AUTMAX(I-1)=2
      Gosub ISRESTRICOP
       If [M:AWE2]MAXINCLU(I-1)=2
         Wrseq '<xs:maxInclusive value="'+num$([M:AWE2]VALMAX(I-1))+'"/>' Using [XSD_]         
       Else
         Wrseq '<xs:maxExclusive value="'+num$([M:AWE2]VALMAX(I-1))+'"/>' Using [XSD_]
       Endif
     Endif
     If [M:AWE2]FRACTIONDIG(I-1)<>0
        Gosub ISRESTRICOP
         Wrseq '<xs:fractionDigits value="'+num$([M:AWE2]FRACTIONDIG(I-1))+'"/>' Using [XSD_]         
     Endif
     If [M:AWE2]TOTALDIGIT(I-1)<>0
       Gosub ISRESTRICOP 
        Wrseq '<xs:totalDigits value="'+num$([M:AWE2]TOTALDIGIT(I-1))+'"/>' Using [XSD_]         
     Endif
     If [M:AWE2]PATTERN(I-1)<>""
       Gosub ISRESTRICOP 
        Wrseq '<xs:pattern value="'+num$([M:AWE2]PATTERN(I-1))+'"/>' Using [XSD_]         
     Endif

    If RESTRICTOP=1 : Wrseq '    </xs:restriction>' Using [XSD_] : Endif
    Wrseq '</xs:simpleType>' Using [XSD_]
  Else
      Wrseq '    <xs:restriction base="xs:string">' Using [XSD_]
     Local Integer JK
    For indice=1 To GI_NBLAN
      Read [A_ST]LAN=GI_LLAN(indice);123;275 
      If fstat=0
        VALLM = [F:A_ST]LANMES
        Gosub MVALC From INTRUTILA
      Else
        VALLM="Not initialized"
      Endif
      Wrseq '      <xs:enumeration value="'+format$("N0:##",0)+':'+GI_LLAN(indice)+':'+VALLM+'">' Using [XSD_]
      Wrseq '            <xs:annotation>' Using [XSD_]
      Wrseq '                  <xs:appinfo>' Using [XSD_]
      Wrseq '                        <jaxb:typesafeEnumMember name="'+GI_LLAN(indice)+'_'+format$("N0:##",0)+'"/>' Using [XSD_] 
      Wrseq '                  </xs:appinfo>' Using [XSD_]
      Wrseq '            </xs:annotation>' Using [XSD_]
      Wrseq '      </xs:enumeration>' Using [XSD_]
      
      For JK=1 To func APLSTD.LENMEN(APPLI,[M:AWE2]NOLIB(I-1))
        Read [A_ST]LAN=GI_LLAN(indice);[M:AWE2]NOLIB(I-1);JK 
        If fstat=0
          VALLM = [F:A_ST]LANMES
          Gosub MVALC From INTRUTILA
            Wrseq '      <xs:enumeration value="'+format$("N0:##",JK)+':'+GI_LLAN(indice)+':'+VALLM+'">' Using [XSD_]
            Wrseq '            <xs:annotation>' Using [XSD_]
            Wrseq '                  <xs:appinfo>' Using [XSD_]
            Wrseq '                        <jaxb:typesafeEnumMember name="'+GI_LLAN(indice)+'_'+format$("N0:##",JK)+'"/>' Using [XSD_] 
            Wrseq '                  </xs:appinfo>' Using [XSD_]
            Wrseq '            </xs:annotation>' Using [XSD_]
            Wrseq '      </xs:enumeration>' Using [XSD_]        
        Endif
      Next JK
    Next indice
      Wrseq '    </xs:restriction>' Using [XSD_]
     Wrseq '</xs:simpleType>' Using [XSD_]
  Endif
 Endif
Next I


Wrseq '</xs:schema>' Using [XSD_]
Openo Using [XSD_]
Return


 $ISRESTRICOP
 If RESTRICTOP=0
   RESTRICTOP=1
   Wrseq '    <xs:restriction base="'+TYPEDATA+'">' Using [XSD_]
 Endif
Return

$ECRBLOCXS
If ECBLOCXS=1 or (ATYPOBJ=1 and DETBLC(MSKCOU,BLCOU)<>0) : Gosub FINBLOCKXS : Endif
ECBLOCXS=1
Wrseq '<xs:complexType name="'+NAMBLCOU+'">' Using [XSD_]
If ATYPOBJ=1
  Wrseq '  <xs:annotation>' Using [XSD_]
  If INTITBLC(MSKCOU,BLCOU)<>0
    For indice=1 To GI_NBLAN
      Read [A_TX]NUMERO = GI_LLAN(indice);INTITBLC(MSKCOU,BLCOU)
      If fstat=0
        VALLM = [F:A_TX]TEXTE
        Gosub MVALC From INTRUTILA
        Wrseq '    <xs:documentation xml:lang="'+tolower(TLANISO(indice))+'">'+ABREV(MSKCOU)+"_"+num$(BLCOU)+":"-VALLM+'</xs:documentation>' Using [XSD_]
      Endif
    Next indice
  Else
    Wrseq '    <xs:documentation>'+ABREV(MSKCOU)+"_"+num$(BLCOU)+'</xs:documentation>' Using [XSD_]
  Endif
  Wrseq '  </xs:annotation>' Using [XSD_]
Endif
  Wrseq '    <xs:sequence>' Using [XSD_]
Return

$ECRBLOCIMP
If ECBLOCXS=1 : Gosub FINBLOCKXS : Endif
ECBLOCXS=1
Wrseq '<xs:complexType name="'+NAMBLCOU+'">' Using [XSD_]
Wrseq '    <xs:sequence>' Using [XSD_]
Return


$FINBLOCKXS
  Wrseq '    </xs:sequence>' Using [XSD_]
  Wrseq '</xs:complexType>' Using [XSD_]
Return


$CRESEQKEY
  Wrseq '      <xs:element name="'+VALP+'" type="'+VALP+'" minOccurs="1" maxOccurs="1"/>' Using [XSD_]
Return

# -----------------------------------------------------------------

Subprog LECTEXTRAL(VALEUR,TABLE,CHAMP,CLE1,CLE2,LANGUE)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2, LANGUE
Read [A_XX]AXX0 = TABLE;CHAMP;LANGUE;CLE1;CLE2
If fstat=0
 VALEUR = [F:A_XX]TEXTE
Else 
 Read [A_XX]AXX0 = TABLE;CHAMP;GLANDEF;CLE1;CLE2
 If fstat=0 
  VALEUR = [F:A_XX]TEXTE 
 Else
  VALEUR = "" 
 Endif
Endif
End

# -----------------------------------------------------------------

Funprog NOMFIC(APPLI,NAMFILE)
Value Char APPLI,NAMFILE
Local Char NOMFIC(GDIMFIC)
Call NAMEFIC(APPLI,"XSD","",NAMFILE,NOMFIC) From INTRUTILA
End NOMFIC


